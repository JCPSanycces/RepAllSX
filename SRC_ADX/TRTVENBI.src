#############################################################################
# Appelé depuis l'action du traitement de la règle de synchro               #
# $DEBUT_ FAT :  Pour ouvrir tables et masques utilises dans les func       #
#   Attention : pour les tables mettre une abreviation non standard         #
# $FIN_ FAT :                                                               #
#############################################################################

$DEBUT_FAT
#--- Ouverture tables standard
If clalev([F:CPY])=0   :  Local File =GDOSSIER+".COMPANY"     [CPY] : Endif
If clalev([F:FCY])=0   :  Local File =GDOSSIER+".FACILITY"    [FCY] : Endif
If clalev([F:TCU])=0   :  Local File =GDOSSIER+".TABCUR"      [TCU] : Endif

# FGR 20/06/2014 : X3SUIVI100123 (début)
If GTABCPT <> "" Then
  If clalev([F:TCH])=0 :  Local File =GDOSSIER+"."+GTABCPT+"TABCHANGE" [TCH] : Endif
Else
  If clalev([F:TCH])=0 :  Local File =GDOSSIER+".TABCHANGE"   [TCH] : Endif
Endif
If clalev([F:GCM])=0   :  Local File =GDOSSIER+".GACM"        [GCM] : Endif
If clalev([F:LED])=0   :  Local File =GDOSSIER+".GLED"        [LED] : Endif
If clalev([F:GAC])=0   :  Local File =GDOSSIER+".GACCOUNT"    [GAC] : Endif
# FGR 20/06/2014 : X3SUIVI100123 (fin)

If clalev([F:SFI])=0   :  Local File =GDOSSIER+".SFOOTINV"    [SFI] : Endif
If clalev([F:PRS])=0   :  Local File =GDOSSIER+".PRICSTRUCT"  [PRS] : Endif
If clalev([F:BPD])=0   :  Local File =GDOSSIER+".BPDLVCUST"   [BPD] : Endif

#--- Ouverture tables documents
If clalev([F:JSQH])=0  : Local File =GDOSSIER+".SQUOTE"      [JSQH] : Endif
If clalev([F:JSQD])=0  : Local File =GDOSSIER+".SQUOTED"     [JSQD] : Endif
If clalev([F:JSOH])=0  : Local File =GDOSSIER+".SORDER"      [JSOH] : Endif
If clalev([F:JSOP])=0  : Local File =GDOSSIER+".SORDERP"     [JSOP] : Endif
If clalev([F:JSOQ])=0  : Local File =GDOSSIER+".SORDERQ"     [JSOQ] : Endif
If clalev([F:JSDH])=0  : Local File =GDOSSIER+".SDELIVERY"   [JSDH] : Endif
If clalev([F:JSDD])=0  : Local File =GDOSSIER+".SDELIVERYD"  [JSDD] : Endif
If clalev([F:JSRH])=0  : Local File =GDOSSIER+".SRETURN"     [JSRH] : Endif
If clalev([F:JSRD])=0  : Local File =GDOSSIER+".SRETURND"    [JSRD] : Endif
If clalev([F:JSIH])=0  : Local File =GDOSSIER+".SINVOICE"    [JSIH] : Endif
If clalev([F:JSIV])=0  : Local File =GDOSSIER+".SINVOICEV"   [JSIV] : Endif
If clalev([F:JSID])=0  : Local File =GDOSSIER+".SINVOICED"   [JSID] : Endif
If clalev([F:JSVF])=0  : Local File =GDOSSIER+".SVCRFOOT"    [JSVF] : Endif
If clalev([F:JSFI])=0  : Local File =GDOSSIER+".SFOOTINV"    [JSFI] : Endif

#--- Ouverture masques
If clalev([M:SBIW])=0  : Local Mask =GDOSSIER+".SBIW"        [SBIW] : Raz [M:SBIW] : Endif
Return

#----------------------------------------------------------------------------
$FIN_FAT
# FGR 20-06-2014 : X3SUIVI100123 : Les fermer pour le multi-dossiers
#--- fermeture tables standard
If clalev([F:CPY])  :  Close Local File [CPY] : Endif
If clalev([F:FCY])  :  Close Local File [FCY] : Endif
If clalev([F:TCU])  :  Close Local File [TCU] : Endif

# FGR 20/06/2014 : X3SUIVI100123 (début)
If clalev([F:TCH])  :  Close Local File [TCH] : Endif
If clalev([F:TCH])  :  Close Local File [TCH] : Endif
If clalev([F:GCM])  :  Close Local File [GCM] : Endif
If clalev([F:LED])  :  Close Local File [LED] : Endif
If clalev([F:GAC])  :  Close Local File [GAC] : Endif
# FGR 20/06/2014 : X3SUIVI100123 (fin)

If clalev([F:SFI])  :  Close Local File [SFI] : Endif
If clalev([F:PRS])  :  Close Local File [PRS] : Endif
If clalev([F:BPD])  :  Close Local File [BPD] : Endif

#--- fermeture tables documents
If clalev([F:JSQH]) :  Close Local File [JSQH] : Endif
If clalev([F:JSQD]) :  Close Local File [JSQD] : Endif
If clalev([F:JSOH]) :  Close Local File [JSOH] : Endif
If clalev([F:JSOP]) :  Close Local File [JSOP] : Endif
If clalev([F:JSOQ]) :  Close Local File [JSOQ] : Endif
If clalev([F:JSDH]) :  Close Local File [JSDH] : Endif
If clalev([F:JSDD]) :  Close Local File [JSDD] : Endif
If clalev([F:JSRH]) :  Close Local File [JSRH] : Endif
If clalev([F:JSRD]) :  Close Local File [JSRD] : Endif
If clalev([F:JSIH]) :  Close Local File [JSIH] : Endif
If clalev([F:JSIV]) :  Close Local File [JSIV] : Endif
If clalev([F:JSID]) :  Close Local File [JSID] : Endif
If clalev([F:JSVF]) :  Close Local File [JSVF] : Endif
If clalev([F:JSFI]) :  Close Local File [JSFI] : Endif

#--- fermeture masques
If clalev([M:SBIW]) :  Close Local Mask [SBIW] : Endif
Return

#############################################################################
# GETGRONOT : Montant brut de la ligne ( saisie en HT ou TTC )              #
# ( concerne les factures validées ( Taxes déjà ventilées à la ligne )      #
#############################################################################
Funprog GETGRONOT(TYPDOC,NUMDOC,LINDOC,SEQDOC,DEVDES)
Value    Integer TYPDOC           : # Type de document
Value    Char    NUMDOC           : # No document
Value    Integer LINDOC           : # No ligne document
Value    Integer SEQDOC           : # No sous-ligne document (sequence)
Value    Char    DEVDES           : # Devise de destination
#-----
Local    Decimal VALEUR           : # Montant brut HT de la ligne
#-----
Local    Char    APPEL (25) : APPEL="GETGRONOT"
Local    Char    WLIG       : WLIG=num$(LINDOC)+"~"+num$(SEQDOC)
Local    Integer ILIG
Local    Integer STAT
#-----

# Si appel hors BI, on positionne GDOSSIER avec dossier courant
If GDOSSIER=""
  Local Integer GDOSVIDE : GDOSVIDE = 1
  GDOSSIER=nomap
Endif

Gosub DEBUT_FAT                   : # pour ouvrir environnement si pas fait par action standard

Gosub MSK_SBIW

ILIG=find(WLIG,[M:SBIW]LIG)
If ILIG
   VALEUR=[M:SBIW]GRONOTLIN(ILIG-1)
Endif

Gosub CONVERSION
If STAT : Raz VALEUR : Endif

If (dim(GDOSVIDE)>1)
  GDOSSIER=""
Endif

End VALEUR

#############################################################################
# GETSALDCA  : Recup. du montant HT des remises ou des frais ventes         #
#############################################################################
Funprog GETSALDCA(TYPDOC,NUMDOC,LINDOC,SEQDOC,DEVDES,TYPAMT)
Value    Integer TYPDOC           : # Type de document
Value    Char    NUMDOC           : # No document
Value    Integer LINDOC           : # No ligne document
Value    Integer SEQDOC           : # No sous-ligne document (sequence)
Value    Char    DEVDES           : # Devise de destination
Value    Integer TYPAMT           : # Type de valeur ( 1=Total frais / 2=Total remise )
#-----
Local    Decimal VALEUR           : # Montant remise ( ou frais ) HT de la ligne
#-----
Local    Char    APPEL (25) : APPEL="GETSALDCA"
Local    Char    WLIG       : WLIG=num$(LINDOC)+"~"+num$(SEQDOC)
Local    Integer ILIG
Local    Integer STAT
#-----

# Si appel hors BI, on positionne GDOSSIER avec dossier courant
If GDOSSIER=""
  Local Integer GDOSVIDE : GDOSVIDE = 1
  GDOSSIER=nomap
Endif

Gosub DEBUT_FAT                   : # pour ouvrir environnement si pas fait par action standard

#Raz [M:SBIW]

Gosub MSK_SBIW

If LINDOC<>0
    # Numéro de ligne renseigné : Montant d'une ligne
    ILIG=find(WLIG,[M:SBIW]LIG)
    If ILIG
       If TYPAMT=1 : VALEUR=[M:SBIW]CRGNOTLIN(ILIG-1) : Endif
       If TYPAMT=2 : VALEUR=[M:SBIW]DISNOTLIN(ILIG-1) : Endif
    Endif
Else
    # Numéro de ligne à 0       : Montant de tout le document
    If TYPAMT=1 : VALEUR=sum([M:SBIW]CRGNOTLIN) : Endif
    If TYPAMT=2 : VALEUR=sum([M:SBIW]DISNOTLIN) : Endif
Endif

Gosub CONVERSION
If STAT : Raz VALEUR : Endif

If (dim(GDOSVIDE)>1)
  GDOSSIER=""
Endif

End VALEUR

#############################################################################
# GETPNTBOM     : Recup. du compose d'une ligne de nomenclature             #
#############################################################################
Funprog GETPNTBOM(TYPDOC,NUMDOC,LINDOC,SEQDOC,TYPDEM)
Value    Integer TYPDOC           : # Type de document
Value    Char    NUMDOC           : # No document
Value    Integer LINDOC           : # No ligne document
Value    Integer SEQDOC           : # No sous-ligne document (sequence)
Value    Integer TYPDEM           : # Type demande ( 1=article compose / 2=designation compose )
#-----
Local    Char    VALEUR (250)     : # Code article ou designation article saisie
#-----
Local    Char    APPEL (25) : APPEL="GETPNTBOM"
Local    Char    WLIG       : WLIG=num$(LINDOC)+"~"+num$(SEQDOC)
Local    Integer ILIG
Local    Integer STAT
#-----

# Si appel hors BI, on positionne GDOSSIER avec dossier courant
If GDOSSIER=""
  Local Integer GDOSVIDE : GDOSVIDE = 1
  GDOSSIER=nomap
Endif

Gosub DEBUT_FAT                   : # pour ouvrir environnement si pas fait par action standard

Gosub MSK_SBIW

ILIG=find(WLIG,[M:SBIW]LIG)
If ILIG
   If TYPDEM=1 : VALEUR=[M:SBIW]PNTITMREF(ILIG-1) : Endif
   If TYPDEM=2 : VALEUR=[M:SBIW]PNTITMDES1(ILIG-1) : Endif
Endif

If (dim(GDOSVIDE)>1)
  GDOSSIER=""
Endif

End VALEUR


#############################################################################
# GETBPTNUM     : Recup. du transporteur ligne                              #
#############################################################################
Funprog GETBPTNUM(TYPDOC,NUMDOC,LINDOC,SEQDOC)
Value    Integer TYPDOC           : # Type de document
Value    Char    NUMDOC           : # No document
Value    Integer LINDOC           : # No ligne document
Value    Integer SEQDOC           : # No sous-ligne document (sequence)
#-----
Local    Char    VALEUR (250)     : # Code article ou designation article saisie
#-----
Local    Char    APPEL (25) : APPEL="GETBPTNUM"
Local    Char    WLIG       : WLIG=num$(LINDOC)+"~"+num$(SEQDOC)
Local    Integer ILIG
Local    Integer STAT
#-----

# Si appel hors BI, on positionne GDOSSIER avec dossier courant
If GDOSSIER=""
  Local Integer GDOSVIDE : GDOSVIDE = 1
  GDOSSIER=nomap
Endif

Gosub DEBUT_FAT                   : # pour ouvrir environnement si pas fait par action standard

Gosub MSK_SBIW

ILIG=find(WLIG,[M:SBIW]LIG)
If ILIG
   VALEUR=[M:SBIW]DBPTNUM(ILIG-1)
Endif

If (dim(GDOSVIDE)>1)
  GDOSSIER=""
Endif

End VALEUR


#############################################################################
# MSK_SBIW : Chargement du masque de travail commun a tous  les documents   #
#############################################################################
$MSK_SBIW

Local    Decimal MAJREM (0..8)    : # Colonnes frais/remises ( en montant ou % )

Default Mask [SBIW]
If [M:SBIW]VCRTYP=TYPDOC & [M:SBIW]VCRNUM=NUMDOC : Goto MS_F : Endif

#--- Chargement de SBIW
Raz [M:SBIW]

Case TYPDOC
  When   1    Gosub MSK_SQH
  When  20    Gosub MSK_SOH
  When  13    Gosub MSK_SOQ
  When   2    Gosub MSK_SDH
  When   3    Gosub MSK_SRH
  When   4    Gosub MSK_SIH
Endcase

#---
GPOINT="MSK_SBIW" : Gosub ENTREE From EXEFNC                                    : #CHECK IGNORE_LINE
#---

$MS_F

Return

#--- Pour un Devis ----------------------------------------------------------
$MSK_SQH

If [F:JSQH]SQHNUM<>NUMDOC
   Read [JSQH]SQH0=NUMDOC
   If fstat : STAT=1 : Return : Endif
Endif
[M:SBIW]=[F:JSQH]

[M:SBIW]VCRTYP=1 : [M:SBIW]VCRNUM=NUMDOC
[M:SBIW]CHGDAT=[F:JSQH]QUODAT

If [M:SBIW]CUR<>[F:TCU]CUR
   Read [TCU]TCU0=[M:SBIW]CUR
Endif

If [F:BPD]BPCNUM<>[F:JSQH]BPCORD | [F:BPD]BPAADD<>[F:JSQH]BPAADD
   Read [BPD]BPD0=[F:JSQH]BPCORD;[F:JSQH]BPAADD
Endif
[M:SBIW]BPTNUM=[F:BPD]BPTNUM       : # transporteur du document ( ou par defaut )

Raz nolign
For [JSQD] Where SQHNUM=NUMDOC
    nolign +=1
    [M:SBIW]=[F:JSQD]
    [M]LIG(nolign-1)=num$([F:JSQD]SQDLIN)+"~0"

   # --- montant ligne HT
   [M]AMTNOTLIN(nolign-1)=arr([M]NETPRINOT(nolign-1)*[M]QTY(nolign-1),[F:TCU]CURRND)

   # --- les frais /remises
    Raz MAJREM
    For I=0 To dim(MAJREM)-1
        If evalue ("dim([F:JSQD]DISCRGVAL"+num$(I+1)+")")>0
           MAJREM(I)=evalue("[F:JSQD]DISCRGVAL"+num$(I+1))
        Endif
    Next I
    Gosub M_MAJREM

   # --- les éléments de facturation répartis
    For I=0 To dim([F:JSQD]DDTANOT)-1
        If [F:JSQD]DDTANUM(I)>0 & [F:JSQD]DDTANOT(I)<>0
            Read [SFI] SFI0=[F:JSQD]DDTANUM(I)
            If !fstat
              If [F:SFI]INCDCR=1 [M]DTACRGNOT(nolign-1)+=[F:JSQD]DDTANOT(I) Endif
              If [F:SFI]INCDCR=2 [M]DTADISNOT(nolign-1)+=[F:JSQD]DDTANOT(I) Endif
            Endif
        Endif
    Next I

   # --- marge totale de la ligne
   [M]LINPFM(nolign-1)=arr([M]PFM(nolign-1)*[M]QTY(nolign-1),[F:TCU]CURRND)

   # --- le transporteur a la ligne
   [M:SBIW]DBPTNUM(nolign-1)=[M:SBIW]BPTNUM

Next
Raz MAJREM

Gosub M_CPL_LIG

Return

#--- Pour une Commande ------------------------------------------------------
$MSK_SOH

If [F:JSOH]SOHNUM<>NUMDOC
   Read [JSOH]SOH0=NUMDOC
   If fstat : STAT=1 : Return : Endif
Endif
[M:SBIW]=[F:JSOH]

[M:SBIW]VCRTYP=20 : [M:SBIW]VCRNUM=NUMDOC
[M:SBIW]CHGDAT=[F:JSOH]ORDDAT

If [M:SBIW]CUR<>[F:TCU]CUR
   Read [TCU]TCU0=[M:SBIW]CUR
Endif

Raz nolign
For [JSOQ] Where SOHNUM=NUMDOC
    nolign +=1
    [M:SBIW]=[F:JSOQ]
    [M:SBIW]LIG(nolign-1)=num$([F:JSOQ]SOPLIN)+"~"+num$([F:JSOQ]SOQSEQ)
    Raz [F:JSOP]
    Read [JSOP]SOP0=[F:JSOH]SOHNUM;[F:JSOQ]SOPLIN;[F:JSOQ]SOQSEQ
    If !fstat
       [M:SBIW]=[F:JSOP]
    Endif

   # --- montant ligne HT
   [M]AMTNOTLIN(nolign-1)=arr([M]NETPRINOT(nolign-1)*[M]QTY(nolign-1),[F:TCU]CURRND)

   # --- les frais /remises
    Raz MAJREM
    For I=0 To dim(MAJREM)-1
        If evalue ("dim([F:JSOP]DISCRGVAL"+num$(I+1)+")")>0
           MAJREM(I)=evalue("[F:JSOP]DISCRGVAL"+num$(I+1))
        Endif
    Next I
    Gosub M_MAJREM

   # --- les éléments de facturation répartis
    For I=0 To dim([F:JSOQ]DDTANOT)-1
        If [F:JSOQ]DDTANUM(I)>0 & [F:JSOQ]DDTANOT(I)<>0
            Read [SFI] SFI0=[F:JSOQ]DDTANUM(I)
            If !fstat
              If [F:SFI]INCDCR=1 [M]DTACRGNOT(nolign-1)+=[F:JSOQ]DDTANOT(I) Endif
              If [F:SFI]INCDCR=2 [M]DTADISNOT(nolign-1)+=[F:JSOQ]DDTANOT(I) Endif
            Endif
        Endif
    Next I

   # --- marge totale de la ligne
   [M:SBIW]LINPFM(nolign-1)=arr([M:SBIW]PFM(nolign-1)*[M:SBIW]QTY(nolign-1),[F:TCU]CURRND)

   # --- le transporteur a la ligne
   If [M:SBIW]DBPTNUM(nolign-1)="" : [M:SBIW]DBPTNUM(nolign-1)=[M:SBIW]BPTNUM : Endif

Next
Raz MAJREM

Gosub M_CPL_LIG

Return


#--- Pour une Demande de livraison ( Cde ouverte ) --------------------------
$MSK_SOQ

If clalev([F:JSOC])=0 : Local File =GDOSSIER+".SORDERC"    [JSOC] : Endif

# LINDOC=[F:JSOQ]SOPLIN : SEQDOC=[F:JSOQ]SOQSEQ
[M:SBIW]CHGDAT=[F:JSOH]ORDDAT

If [F:JSOH]SOHNUM<>NUMDOC
   Read [JSOH]SOH0=NUMDOC
   If fstat : STAT=1 : Return : Endif
Endif
[M:SBIW]=[F:JSOH]

[M:SBIW]VCRTYP=13 : [M:SBIW]VCRNUM=NUMDOC
[M:SBIW]CHGDAT=[F:JSOH]ORDDAT

If [M:SBIW]CUR<>[F:TCU]CUR
   Read [TCU]TCU0=[M:SBIW]CUR
Endif

Raz nolign
For [JSOQ] Where SOHNUM=NUMDOC
    nolign +=1
    [M:SBIW]=[F:JSOQ]
    [M:SBIW]LIG(nolign-1)=num$([F:JSOQ]SOPLIN)+"~"+num$([F:JSOQ]SOQSEQ)

    If [F:JSOC]SOHNUM<>NUMDOC | [F:JSOC]SOPLIN<>[F:JSOQ]SOPLIN
       Read [JSOC]SOC0=[F:JSOQ]SOHNUM;[F:JSOQ]SOPLIN
    Endif
    Raz [F:JSOP]
    If [F:JSOC]PLI=""
       Filter [JSOP] Where SOHNUM=[F:JSOQ]SOHNUM & SOPLIN=[F:JSOQ]SOPLIN &
&                         STRDAT<=[F:JSOQ]SHIDAT & ENDDAT>=[F:JSOQ]SHIDAT
       Read [JSOP]SOP0 First
       If fstat : Raz [F:JSOP] : Endif
       Filter [JSOP]
    Else
       ### Faire une recherche tarif ( voir TRTVENLIV ) pour alimenter la classe [F:JSOP] ###
       ### Il faut charger les donnes prix : --> c est pas de la tarte !...
    Endif
    [M:SBIW]=[F:JSOP]

    # --- montant ligne HT
    [M]AMTNOTLIN(nolign-1)=arr([M]NETPRINOT(nolign-1)*[M]QTY(nolign-1),[F:TCU]CURRND)

    # --- les frais /remises
    Raz MAJREM
    For I=0 To dim(MAJREM)-1
        If evalue ("dim([F:JSOP]DISCRGVAL"+num$(I+1)+")")>0
           MAJREM(I)=evalue("[F:JSOP]DISCRGVAL"+num$(I+1))
        Endif
    Next I
    Gosub M_MAJREM

    # --- marge totale de la ligne
    [M:SBIW]LINPFM(nolign-1)=arr([M:SBIW]PFM(nolign-1)*[M:SBIW]QTY(nolign-1),[F:TCU]CURRND)

    # --- le transporteur a la ligne ( A FAIRE )

Next
Raz MAJREM

Gosub M_CPL_LIG

Return


#--- Pour une Livraison -----------------------------------------------------
$MSK_SDH

If [F:JSDH]SDHNUM<>NUMDOC
   Read [JSDH]SDH0=NUMDOC
   If fstat : STAT=1 : Return : Endif
Endif
[M:SBIW]=[F:JSDH]

[M:SBIW]VCRTYP=2 : [M:SBIW]VCRNUM=NUMDOC
[M:SBIW]CHGDAT=[F:JSDH]DLVDAT

If [M:SBIW]CUR<>[F:TCU]CUR
   Read [TCU]TCU0=[M:SBIW]CUR
Endif

Raz nolign
For [JSDD] Where SDHNUM=NUMDOC
    nolign +=1
    [M:SBIW]=[F:JSDD]
    [M]LIG(nolign-1)=num$([F:JSDD]SDDLIN)+"~0"

    # --- montant ligne HT
    [M]AMTNOTLIN(nolign-1)=arr([M]NETPRINOT(nolign-1)*[M]QTY(nolign-1),[F:TCU]CURRND)

    # --- les frais /remises
    Raz MAJREM
    For I=0 To dim(MAJREM)-1
        If evalue ("dim([F:JSDD]DISCRGVAL"+num$(I+1)+")")>0
           MAJREM(I)=evalue("[F:JSDD]DISCRGVAL"+num$(I+1))
        Endif
    Next I
    Gosub M_MAJREM

   # --- les éléments de facturation répartis
    For I=0 To dim([F:JSDD]DDTANOT)-1
        If [F:JSDD]DDTANUM(I)>0 & [F:JSDD]DDTANOT(I)<>0
            Read [SFI] SFI0=[F:JSDD]DDTANUM(I)
            If !fstat
              If [F:SFI]INCDCR=1 [M]DTACRGNOT(nolign-1)+=[F:JSDD]DDTANOT(I) Endif
              If [F:SFI]INCDCR=2 [M]DTADISNOT(nolign-1)+=[F:JSDD]DDTANOT(I) Endif
            Endif
        Endif
    Next I

    # --- marge totale de la ligne
    [M]LINPFM(nolign-1)=arr([M]PFM(nolign-1)*[M]QTY(nolign-1),[F:TCU]CURRND)

    # --- le transporteur a la ligne
    If [M:SBIW]DBPTNUM(nolign-1)="" : [M:SBIW]DBPTNUM(nolign-1)=[M:SBIW]BPTNUM : Endif

Next
Raz MAJREM

Gosub M_CPL_LIG

Return

#--- Pour un Retour ---------------------------------------------------------
$MSK_SRH

If [F:JSRH]SRHNUM<>NUMDOC
   Read [JSRH]SRH0=NUMDOC
   If fstat : STAT=1 : Return : Endif
Endif
[M:SBIW]=[F:JSRH]

[M:SBIW]VCRTYP=3 : [M:SBIW]VCRNUM=NUMDOC
[M:SBIW]CHGTYP=1 : [M:SBIW]CHGRAT=0 : [M:SBIW]CHGDAT=[F:JSRH]RTNDAT

If [M:SBIW]CUR<>[F:TCU]CUR
   Read [TCU]TCU0=[M:SBIW]CUR
Endif

Raz nolign
For [JSRD] Where SRHNUM=NUMDOC
    nolign +=1
    [M:SBIW]=[F:JSRD]
    [M]LIG(nolign-1)=num$([F:JSRD]SRDLIN)+"~0"
    Raz MAJREM

    #-- Retour : pas de gestion de frais remises

    [M]GRONOTLIN(nolign-1)=arr([M:SBIW]NETPRINO(nolign-1)*[M:SBIW]QTY(nolign-1),[F:TCU]CURRND)
Next
Raz MAJREM

Gosub M_CPL_LIG

Return

#--- Pour une Facture -------------------------------------------------------
$MSK_SIH

If [F:JSIH]NUM<>NUMDOC
   Read [JSIH]SIH0=NUMDOC
   If fstat : STAT=1 : Return : Endif
Endif
[M:SBIW]=[F:JSIH]

If [F:JSIV]NUM<>NUMDOC
   Read [JSIV]SIV0=NUMDOC
   If fstat : STAT=1 : Return : Endif
Endif
[M:SBIW]=[F:JSIV]

[M:SBIW]VCRTYP=4 : [M:SBIW]VCRNUM=NUMDOC
[M:SBIW]CHGTYP=[F:JSIH]CURTYP
[M:SBIW]CHGRAT=func TRTX3BI.GETRATCUR("JSIH")
[M:SBIW]CHGDAT=[F:JSIV]INVDAT

If [M:SBIW]CUR<>[F:TCU]CUR
   Read [TCU]TCU0=[M:SBIW]CUR
Endif

If [F:BPD]BPCNUM<>[F:JSIV]BPCORD | [F:BPD]BPAADD<>[F:JSIV]BPAADD
   Read [BPD]BPD0=[F:JSIV]BPCORD;[F:JSIV]BPAADD
Endif
[M:SBIW]BPTNUM=[F:BPD]BPTNUM       : # transporteur du document ( ou par defaut )

Raz nolign
For [JSID] Where NUM=NUMDOC
    nolign +=1
    [M:SBIW]=[F:JSID]
    [M:SBIW]LIG(nolign-1)=num$([F:JSID]SIDLIN)+"~0"
    # --- les frais /remises
    Raz MAJREM
    For I=0 To dim(MAJREM)-1
        If evalue ("dim([F:JSID]DISCRGVAL"+num$(I+1)+")")>0
           MAJREM(I)=evalue("[F:JSID]DISCRGVAL"+num$(I+1))
        Endif
    Next I
    Gosub M_MAJREM
    # --- les éléments de facturation répartis
    For I=0 To dim([F:JSID]DDTANOT)-1
        If [F:JSID]DDTANUM(I)>0 & [F:JSID]DDTANOT(I)<>0
            Read [SFI] SFI0=[F:JSID]DDTANUM(I)
            If !fstat
              If [F:SFI]INCDCR=1 [M]DTACRGNOT(nolign-1)+=[F:JSID]DDTANOT(I) Endif
              If [F:SFI]INCDCR=2 [M]DTADISNOT(nolign-1)+=[F:JSID]DDTANOT(I) Endif
            Endif
        Endif
    Next I
    # --- marge totale de la ligne
    [M]LINPFM(nolign-1)=arr([M]PFM(nolign-1)*[M]QTY(nolign-1),[F:TCU]CURRND)

    # --- le transporteur a la ligne
    If [M:SBIW]INVTYP=1
       If [M:SBIW]SIHORI=1                        : # pour les factures directes
          [M:SBIW]DBPTNUM(nolign-1)=[M:SBIW]BPTNUM
       Endif
       If [M:SBIW]SIHORI=2                        : # pour les factures de commandes
          If [M:SBIW]SOHNUM(nolign-1)<>"" & [M:SBIW]SOPLIN(nolign-1)<>0 & [M:SBIW]SOQSEQ(nolign-1)<>0
             Read [JSOQ]SOQ0=[M:SBIW]SOHNUM(nolign-1);[M:SBIW]SOPLIN(nolign-1);[M:SBIW]SOQSEQ(nolign-1)
             If fstat : Raz [F:JSOQ] : Endif
             [M:SBIW]DBPTNUM(nolign-1)=[F:JSOQ]BPTNUM
             If [F:JSOQ]BPTNUM<>""
                [M:SBIW]DBPTNUM(nolign-1)=[F:JSOQ]BPTNUM
              Else
                If [F:JSOH]SOHNUM<>[M:SBIW]SOHNUM(nolign-1)
                   Read [JSOH]SOH0=[M:SBIW]SOHNUM(nolign-1)
                   If fstat : Raz [F:JSOH] : Endif
                   [M:SBIW]DBPTNUM(nolign-1)=[F:JSOH]BPTNUM
                Endif
             Endif
          Endif
          If [M:SBIW]DBPTNUM(nolign-1)="" : [M:SBIW]DBPTNUM(nolign-1)=[M:SBIW]BPTNUM : Endif
       Endif
       If [M:SBIW]SIHORI=3                         : # pour les factures de livraisons
          If [M:SBIW]SDHNUM(nolign-1)<>""
             Read [JSDH]SDH0=[M:SBIW]SOHNUM(nolign-1)
             If fstat : Raz [F:JSDH] : Endif
             [M:SBIW]DBPTNUM(nolign-1)=[F:JSOQ]BPTNUM
          Endif
          If [M:SBIW]DBPTNUM(nolign-1)="" : [M:SBIW]DBPTNUM(nolign-1)=[M:SBIW]BPTNUM : Endif
        Endif
     Endif

    If [M:SBIW]INVTYP=2            : # pas de transporteur ligne pour les avoirs (pour l instant)
    Endif

Next

Raz MAJREM

Gosub M_CPL_LIG

Return

#----------------------------------------------------------------------------
$M_MAJREM
Local    Decimal QTE,BRUT,NET
Local    Decimal REMISE           : # Total des remises ( HT ou TTC )
Local    Decimal FRAIS            : # Total des frais ( HT ou TTC )
Local    Decimal COEFFICIENT      : # Coeff de passage de TTC à HT
Local    Decimal NETPRI, NETPRINOT

If [F:PRS]BPCBPS<>1 | [F:PRS]PLISTC<>[M:SBIW]PLISTC
   Read [PRS]PRS0=1;[M:SBIW]PLISTC
   If fstat : [M:SBIW]GRONOTLIN(nolign-1)=[M:SBIW]AMTNOTLIN(nolign-1) : Goto M_MAJREM_F : Endif
Endif

QTE=[M:SBIW]QTY(nolign-1)

If QTE=0 : QTE=1 : Endif
BRUT=[M:SBIW]GROPRI(nolign-1) : NET=[M:SBIW]GROPRI(nolign-1)
NETPRI=[M:SBIW]NETPRI(nolign-1) : NETPRINOT=[M:SBIW]NETPRINOT(nolign-1)

For I=0 To 8
   If [F:PRS]NPRNOTFLG(I)=2 & MAJREM(I)<>0                        : # utilisé dans le prix net et significatif
      If [F:PRS]INCDCR(I)=1                                       : # majoration ( c est un frais )
         If [F:PRS]VALTYP(I)=1                                    : # en montant
            If [F:PRS]CLCRUL(I)=1                                 : # par unite
               NET +=MAJREM(I) : FRAIS +=MAJREM(I)
            Endif
            If [F:PRS]CLCRUL(I)<>1                                : # par ligne ( ou document )
               NET +=MAJREM(I)/QTE : FRAIS +=MAJREM(I)/QTE
            Endif
         Elsif [F:PRS]VALTYP(I)=2                                 : # en % cumul
            FRAIS +=(BRUT*MAJREM(I))/100 : NET +=(BRUT*MAJREM(I))/100
         Else                                                     : # en % cascade
            FRAIS +=(NET*MAJREM(I))/100  : NET +=(NET*MAJREM(I))/100
         Endif

      Else                                                        : # minoration ( c est une remise )
         If [F:PRS]VALTYP(I)=1                                    : # en montant
            If [F:PRS]CLCRUL(I)=1                                 : # par unite
               NET -=MAJREM(I) : REMISE +=MAJREM(I)
            Endif
            If [F:PRS]CLCRUL(I)<>1                                : # par ligne ( ou document )
               NET -=MAJREM(I)/QTE : REMISE +=MAJREM(I)/QTE
            Endif
         Elsif [F:PRS]VALTYP(I)=2                                 : # en % culmul
            REMISE +=(BRUT*MAJREM(I))/100 : NET -=(BRUT*MAJREM(I))/100
         Else                                                     : # en % cascade
            REMISE +=(NET*MAJREM(I))/100 : NET -=(NET*MAJREM(I))/100
         Endif
      Endif
   Endif
Next I

#-- recherche coefficent de passage TTC --> HT
COEFFICIENT=1
If [M:SBIW]PRITYP=2
    If NETPRINOT<>0 COEFFICIENT=NETPRI/NETPRINOT Endif
Endif
If COEFFICIENT=0 : COEFFICIENT=1 : Endif
FRAIS= FRAIS/COEFFICIENT : REMISE=REMISE/COEFFICIENT

[M:SBIW]DISNOTLIN(nolign-1)=arr(REMISE*[M:SBIW]QTY(nolign-1),[F:TCU]CURRND)
[M:SBIW]CRGNOTLIN(nolign-1)=arr(FRAIS*[M:SBIW]QTY(nolign-1),[F:TCU]CURRND)

[M]GRONOTLIN(nolign-1)=[M:SBIW]AMTNOTLIN(nolign-1)-[M:SBIW]CRGNOTLIN(nolign-1)+[M:SBIW]DISNOTLIN(nolign-1)

$M_MAJREM_F

Return






#----------------------------------------------------------------------------
$M_CPL_LIG
For I=0 To dim([M]ITMREF)-1
    If [M]ITMREF(I)="" : Break : Endif

#   --- compose / composant
    If find([M]LINTYP(I),2,6,10)
       [M]PNTITMREF(I)=[M]ITMREF(I) : [M]PNTITMDES1(I)=[M]ITMDES1(I)
    Endif
    If find([M]LINTYP(I),3,4,5,7,8,9,11,12,13) & I>0
       [M]PNTITMREF(I)=[M]PNTITMREF(I-1) : [M]PNTITMDES1(I)=[M]PNTITMDES1(I-1)
       [M]CPNITMREF(I)=[M]ITMREF(I)
    Endif
Next I

Return

#############################################################################
$CONVERSION
Local Decimal VALEURDES
Local Char    WDEVSOC (20)
If [M:SBIW]CUR<>DEVDES
   Gosub PREP_CONVERSION From TRTX3BI
   WDEVSOC=func TRTX3BI.GETCUR([M:SBIW]SALFCY)
   Call COURMNT([M:SBIW]CUR,DEVDES,WDEVSOC,[M:SBIW]CHGTYP,[M:SBIW]CHGDAT,1,VALEUR,VALEURDES,[M:SBIW]CHGRAT,STAT) From TRTDEV
   If !STAT : VALEUR=VALEURDES : Endif
Endif
Return


#############################################################################




#############################################################################
# GETVATLIG : Recup. du montant de TVA d'une ligne de document              #
# ( en V6 pour les documents autre que la facture )                         #
#                    RIEN A FAIRE DANS L'IMMEDIAT                           #
#############################################################################
Funprog GETVATLIG(TYPDOC,NUMDOC,LINDOC,SEQDOC,DEVDES)
Value    Integer TYPDOC           : # Type de document
Value    Char    NUMDOC           : # No document
Value    Integer LINDOC           : # No ligne document
Value    Integer SEQDOC           : # No sous-ligne document (sequence)
Value    Char    DEVDES           : # Devise de destination
#-----
Local    Decimal VALEUR           : # Montant de TVA d'une ligne de document
#-----
Local    Char    APPEL (25) : APPEL="GETVATLIG"
Local    Char    WLIG       : WLIG=num$(LINDOC)+"~"+num$(SEQDOC)
Local    Integer ILIG
Local    Integer STAT
#-----

Gosub CONVERSION
If STAT : Raz VALEUR : Endif

End VALEUR

#############################################################################
# GETDTANOT : Recup. du montant HT d'un élément de facturation TTC          #
#                        VOIR SI NECESSAIRE
#############################################################################
Funprog GETDTANOT(TYPDOC,NUMDOC,DTANUM,DEVDES)
Value    Integer TYPDOC           : # Type de document
Value    Char    NUMDOC           : # No document
Value    Integer DTANUM           : # No element facturation
Value    Char    DEVDES           : # Devise de destination
#-----
Local    Decimal VALEUR          : # Montant HT d'un élément de facturation TTC
#-----
Local    Char    APPEL (25) : APPEL="GETDTANOT"
Local    Integer STAT
#-----

Gosub CONVERSION
If STAT : Raz VALEUR : Endif

End VALEUR

#############################################################################
# GETDTAATI : Recup. du montant TTC d'un élément de facturation HT          #
#                        VOIR SI NECESSAIRE
#############################################################################
Funprog GETDTAATI(TYPDOC,NUMDOC,DTANUM,DEVDES)
Value    Integer TYPDOC           : # Type de document
Value    Char    NUMDOC           : # No document
Value    Integer DTANUM           : # No element facturation
Value    Char    DEVDES           : # Devise de destination
#-----
Local    Decimal VALEUR           : # Montant TTC d'un élément de facturation HT
#-----
Local    Char    APPEL (25) : APPEL="GETDTAATI"
Local    Integer STAT
#-----

Gosub CONVERSION
If STAT : Raz VALEUR : Endif

End VALEUR

#############################################################################
# GETCOMREP     : Recup. de la commission du representant 1 ou 2            #
#############################################################################
Funprog GETCOMREP(TYPDOC,NUMDOC,LINDOC,SEQDOC,TYP)
Value    Integer TYPDOC           : # Type de document
Value    Char    NUMDOC           : # No document
Value    Integer LINDOC           : # No ligne document
Value    Integer SEQDOC           : # No sous-ligne document (sequence)
Value    Integer TYP              : # Type ( 1=représentant1 / 2=représentant2 )
#-----
Local    Decimal VALEUR           : # Montant HT de la commission
#-----
Local    Char    APPEL (25) : APPEL="GETCOMREP"
Local    Char    WLIG       : WLIG=num$(LINDOC)+"~"+num$(SEQDOC)
Local    Integer ILIG
Local    Integer STAT
Local    Decimal WREPAMT
#-----

# Si appel hors BI, on positionne GDOSSIER avec dossier courant
If GDOSSIER=""
  Local Integer GDOSVIDE : GDOSVIDE = 1
  GDOSSIER=nomap
Endif

Gosub DEBUT_FAT                   : # pour ouvrir environnement si pas fait par action standard

#Raz [M:SBIW]

Gosub MSK_SBIW

ILIG=find(WLIG,[M:SBIW]LIG)
If ILIG
    nolign=ILIG
    Gosub C_COMREP
    If STAT : Raz WREPAMT : Endif
Endif

If (dim(GDOSVIDE)>1)
  GDOSSIER=""
Endif


End WREPAMT
#############################################################################

$C_COMREP
Local Char    WREPNUM(30), WCOMFOR(10)
Local Decimal WREPRAT, WREPBAS

If clalev([F:REP]) = 0 Local File =GDOSSIER+".SALESREP" [REP] Endif

If evalue("dim([M]REP"+num$(TYP)+"(nolign-1))")<0 Return Endif

WREPNUM=evalue("[M]REP"+num$(TYP)+"(nolign-1)")
WREPRAT=evalue("[M]REPRAT"+num$(TYP)+"(nolign-1)")

If WREPNUM <> [F:REP]REPNUM
    Read [REP]REP0=WREPNUM
    If fstat Raz [F:REP] Endif
Endif

Case [F:REP]COMBAS
    When 1   : WREPBAS = [M]NETPRINOT(nolign-1) * [M]QTY(nolign-1)
    When 2   : WREPBAS = [M]PFM(nolign-1) * [M]QTY(nolign-1)
    When 3   : WCOMFOR=evalue("[F:REP]COMFOR"+num$(TYP))
               Gosub FORMULE_REP
Endcase
If [F:TCU]CUR<>[M]CUR
  Read [TCU] TCU0=[M]CUR : If fstat  Raz [F:TCU] : Endif
Endif
WREPBAS=arr(WREPBAS,[F:TCU]CURRND)

WREPAMT = WREPBAS * WREPRAT/100 * [M]REPCOE(nolign-1)
If [F:TCU]CUR<>[M]CUR
  Read [TCU] TCU0=[M]CUR : If fstat  Raz [F:TCU] : Endif
Endif
WREPAMT=arr(WREPAMT,[F:TCU]CURRND)

Return

$FORMULE_REP

If WCOMFOR= "" Return Endif

If clalev ([F:TFO]) = 0 Local File =GDOSSIER+".TABFOR"   [TFO] Endif
If clalev ([F:ITS]) = 0 Local File =GDOSSIER+".ITMSALES" [ITS] Endif

Read [TFO]TFO0=3;WCOMFOR
If fstat Return Endif
If instr(1,[F:TFO]FORFOR,"ITS]")
   If [F:ITS]ITMREF <> [M]ITMREF(nolign-1)
      Read [ITS]ITS0=[M]ITMREF(nolign-1)
      If fstat Raz [ITS] Endif
   Endif
Endif

Onerrgo ERR_FORMULE
WREPBAS = evalue([F:TFO]FORFOR)
Onerrgo
Goto FIN_FOR_REP

$ERR_FORMULE
WREPBAS = 0
Resume

$FIN_FOR_REP
Return

#######################################################################################
# GETSFIDCA  : Recup. du montant HT frais ou remise des éléments répartis d'une ligne #
#######################################################################################
Funprog GETSFIDCA(TYPDOC,NUMDOC,LINDOC,SEQDOC,DEVDES,TYPAMT)
Value    Integer TYPDOC           : # Type de document
Value    Char    NUMDOC           : # No document
Value    Integer LINDOC           : # No ligne document
Value    Integer SEQDOC           : # No sous-ligne document (sequence)
Value    Char    DEVDES           : # Devise de destination
Value    Integer TYPAMT           : # Type de valeur ( 1=Total frais / 2=Total remise )
#-----
Local    Decimal VALEUR           : # Montant remise ( ou frais ) HT des éléments de la ligne
#-----
Local    Char    APPEL (25) : APPEL="GETSFIDCA"
Local    Char    WLIG       : WLIG=num$(LINDOC)+"~"+num$(SEQDOC)
Local    Integer ILIG
Local    Integer STAT
#-----

# Si appel hors BI, on positionne GDOSSIER avec dossier courant
If GDOSSIER=""
  Local Integer GDOSVIDE : GDOSVIDE = 1
  GDOSSIER=nomap
Endif

Gosub DEBUT_FAT                   : # pour ouvrir environnement si pas fait par action standard

#Raz [M:SBIW]

Gosub MSK_SBIW

ILIG=find(WLIG,[M:SBIW]LIG)
If ILIG
   If TYPAMT=1 : VALEUR=[M:SBIW]DTACRGNOT(ILIG-1) : Endif
   If TYPAMT=2 : VALEUR=[M:SBIW]DTADISNOT(ILIG-1) : Endif
Endif

Gosub CONVERSION
If STAT : Raz VALEUR : Endif

If (dim(GDOSVIDE)>1)
  GDOSSIER=""
Endif

End VALEUR


#######################################################################################
# GETSVFNOT  : Recup. du montant HT frais/remise des élts de facturation d'un document#
#######################################################################################
Funprog GETSVFNOT (TYPDOC,NUMDOC,DEVDES,TYPAMT)
Value    Integer TYPDOC           : # Type de document
Value    Char    NUMDOC           : # No document
Value    Char    DEVDES           : # Devise de destination
Value    Integer TYPAMT           : # Type de valeur ( 1=Total frais / 2=Total remise )
#-----
Local    Decimal VALEUR           : # Montant remise ( ou frais ) HT des éléments
#-----
Local    Char    APPEL (25) : APPEL="GETSVFNOT"
Local    Integer WI
Local    Integer STAT
#-----

# Si appel hors BI, on positionne GDOSSIER avec dossier courant
If GDOSSIER=""
  Local Integer GDOSVIDE : GDOSVIDE = 1
  GDOSSIER=nomap
Endif

Gosub DEBUT_FAT                   : # pour ouvrir environnement si pas fait par action standard

#Raz [M:SBIW]

#Gosub MSK_SBIW  # FGR 18/06/2014 : X3SUIVI100123 : ne sert à rien

#     le tableau des elements
For [JSVF]SVF2 Where VCRTYP=TYPDOC & VCRNUM=NUMDOC
  If [F:JSVF]DTA<>0
     Read [JSFI]SFI0=[F:JSVF]DTA
     If fstat Raz [F:JSFI] Endif
     #Fq74233-gbn
     If TYPAMT=[F:JSFI]INCDCR
      Case TYPAMT
       When 2       : VALEUR += -1*([F:JSVF]DTANOT)
       When Default : VALEUR += [F:JSVF]DTANOT
      Endcase
     Endif
  Endif
Next

Gosub CONVERSION
If STAT : Raz VALEUR : Endif

#If TYPAMT=2 VALEUR=abs(VALEUR) Endif #Fq74233-gbn

If (dim(GDOSVIDE)>1)
  GDOSSIER=""
Endif

End VALEUR

#############################################################################
# GETPFMTOT : Marge totale des lignes d'un document                         #
#############################################################################
Funprog GETPFMTOT(TYPDOC,NUMDOC,DEVDES)
Value    Integer TYPDOC           : # Type de document
Value    Char    NUMDOC           : # No document
Value    Char    DEVDES           : # Devise de destination
#-----
Local    Decimal VALEUR           : # Montant total de la marge
#-----
Local    Char    APPEL (25) : APPEL="GETPFMTOT"
Local    Integer STAT
#-----

# Si appel hors BI, on positionne GDOSSIER avec dossier courant
If GDOSSIER=""
  Local Integer GDOSVIDE : GDOSVIDE = 1
  GDOSSIER=nomap
Endif

Gosub DEBUT_FAT                   : # pour ouvrir environnement si pas fait par action standard

Gosub MSK_SBIW

VALEUR=sum([M:SBIW]LINPFM)

Gosub CONVERSION
If STAT : Raz VALEUR : Endif

If (dim(GDOSVIDE)>1)
  GDOSSIER=""
Endif

End VALEUR

#############################################################################
# GETCSTTOT : Cout total des lignes d'un document                           #
#############################################################################
Funprog GETCSTTOT(TYPDOC,NUMDOC,DEVDES)
Value    Integer TYPDOC           : # Type de document
Value    Char    NUMDOC           : # No document
Value    Char    DEVDES           : # Devise de destination
#-----
Local    Decimal VALEUR           : # Montant total de la marge
#-----
Local    Char    APPEL (25) : APPEL="GETCSTTOT"
Local    Integer STAT
#-----
# Si appel hors BI, on positionne GDOSSIER avec dossier courant
If GDOSSIER=""
  Local Integer GDOSVIDE : GDOSVIDE = 1
  GDOSSIER=nomap
Endif

Gosub DEBUT_FAT                   : # pour ouvrir environnement si pas fait par action standard

Gosub MSK_SBIW

VALEUR=sum([M:SBIW]AMTNOTLIN)-sum([M:SBIW]LINPFM)

Gosub CONVERSION
If STAT : Raz VALEUR : Endif

If (dim(GDOSVIDE)>1)
  GDOSSIER=""
Endif

End VALEUR
