#<AdxTL>@(#)11.0.0.0 $Revision$
######################################################################################
## Xtend: Gestion copies à partir des usages Xtend
######################################################################################
##  Gestion Ecran
#
##  Actions
#    AYTCOPUSG    Copie à partir de la fonction cas d'usage
#
##  Gosub
#
##  Subprog
#
#  Rq #*: déactivation code activité 
######################################################################################
$ACTION
   Case ACTION
    When "INIT"     : Gosub COPUSG_INI
    When "INIT_DIA" : Gosub COPUSG_DIA
    When "CONTROLE" : Gosub COPUSG_CTL
    When "EXEC"     : Gosub COPUSG_EXEC
   Endcase
Return

######################################################################################
#    AYTCOPUSG    Procédure générale de copie(copie d'un site Xtend)
#                     Ecran              AYTCOP
#                     Ecrans appelants:  AYU1 et AYU2 
#     Nota: utilise des fonctions de AYTCOP et AYTFCYCOP
# 
# $$$$
######################################################################################
$COPUSG_INI 
#-----------------------------
Local Char FCYORG(GLONAYS), WSTR1(200), WDES(50), WMSG(250)
Local Char DOSORG(GDIMFIC), MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000@XTEND ; sodaix01:5000 ; XTEND
Local Char DOSDES(GDIMFIC), MACDES(GDIMFIC), DOSNAMDES(GDIMFIC)
Local Char FCYORG(GLONAYS), FCYDES(GLONAYS)
Local Char OBJCOD(GLONAOB), ELTCOD(GLONAY9), PRGCOP(GLONADC)
#* ELTCODACT(GLONACV), 
Local Char SAVACTION(10), WSTR(250), WDES_SAV(50), DES(50)
Local Integer RET, WI, WNBELT
Local Integer TRADETFLG   : TRADETFLG = 1    # Rapport détaillé
Local Integer TMPONFLG                       # Popup avancement

If !find(2,  [M:AYU2]WSEL)
    GMESSAGE=mess(115,7900,1) : GERR=2 : FIN=1
Endif

Return

$COPUSG_DIA
#-----------------------------
[M:DIA]OBJCOD=[M:AYU1]OBJX3COD
[M:DIA]ELTCOD=""
[M:DIA]FCYORG=GAYTFCYWRK
[M:DIA]DOSORG=nomap
[L]DOSORG = [M:DIA]DOSORG : [L]FCYORG = [M:DIA]FCYORG : Gosub  FCYREADORG From AYTCOP     # classe AYS2
#
[M:DIA]DOSDES=""
If [M:DIA]DOSDES=""
    If GDOSPATH<>"" 
        Call C_DOSSIER(GDOSPATH) From DOSCONT
        If mkstat
         mkstat = 0
        Else
         [M:DIA]DOSDES = GDOSPATH
        Endif
    Else
         [M:DIA]DOSDES = [M:DIA]DOSORG
    Endif
Endif
#
[M:DIA]FCYDES=""
If [M:DIA]FCYDES=""
  If GAYTFCYCOP="" 
    [M:DIA]FCYDES=[M:DIA]FCYORG
  Else
    [M:DIA]FCYDES=GAYTFCYCOP
  Endif
Endif
[L]DOSDES = [M:DIA]DOSDES : [L]FCYDES = [M:DIA]FCYDES : Gosub  FCYREADDES From AYTCOP      # classe AYS2
#
[M:DIA]OBJCOD=[M:AYU1]OBJX3COD   # AYA, AYI...
Call TITOBJ([M:DIA]OBJCOD,"",WDES_SAV) From CONTOBJ : [M:DIA]DES=WDES_SAV
Return

$COPUSG_CTL
#-----------------------------
Gosub COP_CTLFCY From AYTCOP
If RET=0 : SAI=1 : Return : Endif
#
Return

$COPUSG_EXEC
#-----------------------------
TRA=1
WMSG=mess(112,7900,1)-[M]FCYORG-"("-[M:DIA]DOSORG-") -> "-[M:DIA]FCYDES-"("-[M:DIA]DOSDES-")"
If !GSERVEUR
  TRA=1
  Call TEMPON(WMSG) From GESECRAN 
  TMPONFLG = 1     # Popup avancement
  Call OUVRE_TRACE(WMSG) From LECFIC
Endif
OK=1
#
Call MACHINE([M:DIA]DOSORG,MACORG,DOSNAMORG) From ORDSYS
Call MACHINE([M:DIA]DOSDES,MACDES,DOSNAMDES) From ORDSYS
#
[L]OBJCOD    = [M:DIA]OBJCOD        # Code objet Xtend
#* [L]ELTCODACT = [M:DIA]ELTCODACT     # Code activité 
Gosub COPOBJ_DEB 
If RET=0 : FIN=1 : Goto COPUSG_FIN : Endif

# Boucle
For WI=0 To [M:AYU2]NBLIG-1
  If [M:AYU2]WSEL(WI)=2
    [L]ELTCOD  = [M:AYU2]COD(WI) :  [M:DIA]DES = WDES_SAV +":"-[L]ELTCOD
    Call TEMPON(mess(91,123,1)-[M:DIA]DES-"("+[M:DIA]FCYDES+")") From GESECRAN
    Gosub COPOBJ_FOR : If RET=0 : Break : Endif
    [M:AYU2]WSEL(WI)=1 : Affzo [M:AYU2]WSEL(WI)
  Endif
Next
If RET=0 : FIN=1 : Goto COPUSG_FIN : Endif

Gosub COPOBJ_FIN : If RET=0 : Goto COPUSG_FIN : Endif
If RET=0 : FIN=1 : Goto COPUSG_FIN : Endif

$COPUSG_FIN
If !GSERVEUR
  Call TEMPOFF() From GESECRAN 
Endif
Return



######################################################################################
## Gosub
######################################################################################
#------------------------------------------------------------#
# Boucle: Initialisation 
# $$$$
#------------------------------------------------------------#
$COPOBJ_DEB
Gosub COPOBJ_DEB From AYTFCYCOP
Return

#------------------------------------------------------------#
# Boucle: dedans
# $$$$
#------------------------------------------------------------#
$COPOBJ_FOR
Gosub COPOBJ_FOR From AYTFCYCOP
Return

#------------------------------------------------------------#
# Boucle: Fin
# $$$$
#------------------------------------------------------------#
$COPOBJ_FIN
Gosub COPOBJ_FIN From AYTFCYCOP
Return


