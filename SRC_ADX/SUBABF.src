#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion objet ABF
Raz GPILOBJ,GNBMASKOUV
Call OBJET("ABF",GBIDC1,GBIDC2) From GOBJET
End

#--------------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "APRES_MOD"   : Gosub APRES_MOD
 When "APRES_CRE"   : Gosub APRES_CRE
 When "AP_ANNULE"   : Gosub AP_ANNULE
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "VERF_LISTE"  : Gosub VERF_LISTE
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "INIMOD"      : Gosub INIMOD
 When "INICRE"      : Gosub INICRE

Endcase
Return

#--------------------------------------------------------------------------------#
$OUVRE
Local Integer OKK , I
Gosub SET_DIME
If clalev([F:ABI])=0  : Local File ABIDIM     [ABI]  : Endif
If clalev([F:ABJ])=0  : Local File ABIDIMFLD  [ABJ]  : Endif
If clalev([F:ABF2])=0 : Local File ABITABDAT  [ABF2] : Endif
If clalev([F:AHH])=0  : Local File ABIHIERA   [AHH]  : Endif
If clalev([F:ABM])=0  : Local File ABIDATMRT  [ABM]  : Endif
If clalev([F:AOB])=0  : Local File AOBJET     [AOB]  : Endif
If clalev([F:ATI])=0  : Local File ATABIND    [ATI]  : Endif
If clalev([F:ABY])=0  : Local File ABIREGDES  [ABY]  : Endif
If clalev([F:ABY2])=0 : Local File ABIREGDES  [ABY2]  : Endif
If clalev([F:ABY3])=0 : Local File ABIREGDES  [ABY3]  : Endif
Return

$SET_DIME
Local Integer DI , DD
DI = min(dim([F:ABE]INDAGG),dim([M:ABF5]INDEX),dim([M:ABF5]TBINDEX))
DD = min(dim([F:ABE]DIMAGG),dim([M:ABF5]DIME),dim([M:ABF5]TBDIME))
Return

$INICRE
$INIMOD
OKK = 1
For [ABY]ABY2 Where TABDES =[M]CODABF
 Read [F:ABZ]ABZ1 = [M]CODABF;[F:ABY]FLDDES
 If fstat
  OKK =0 : Break
 Endif
Next
If OKK = 1
 For [ABY]ABY1(1) Where TABDES =[M]CODABF
  For I=1 To [M:ABF2]NBRFLD
   Read [ABY2]ABY1 = [F:ABY]CODREG;[M:ABF2]CODFLD(I-1)
   If fstat
   OKK = 0 : Break 2
   Endif
  Next
 Next
Endif
If !OKK
 # "Des rêgles de synchronisation sont associées à cette table de fait"
 Call AVERTIR(mess(115,148,1)+"\"+mess(152,123,1)-"?",OK) From GESECRAN
 If OK <> 2 : GOK = 0 : Endif
Endif
Return

#--------------------#
$LIENS
Call TEXTE([M:ABF0]INTIT,[M:ABF0]ZINTIT) From OBJDIV
Raz nolign
For [ABZ]ABZ0 Where CODABF=[M]CODABF
 nolign += 1
 [M:ABF2] = [F:ABZ]
 Call TEXTE([M:ABF2]INTFLD(nolign-1),[M:ABF2]ZINTFLD(nolign-1)) From OBJDIV
 Call TEXTE([M:ABF2]INTSSC(nolign-1),[M:ABF2]ZINTSSC(nolign-1)) From OBJDIV
Next ABZ
[M:ABF2]NBRFLD = nolign
For nolign =1 To [M:ABF2]NBRFLD
 Gosub GRISE_TUNNEL
Next nolign
Raz nolign
For [ABK]ABK0 Where CODABF=[M]CODABF
 nolign += 1
 [M:ABF3] = [F:ABK]
 CHAINE = [F:ABK]EXPLNK
 Gosub VERIF_EXP2
 [M]NBCHPLNK(nolign-1) = NBCHAMP
 Call TEXTE([M:ABF3]INTLNK(nolign-1),[M:ABF3]ZINTLNK(nolign-1)) From OBJDIV
 Call TEXTE([M:ABF3]INTCOMP(nolign-1),[M:ABF3]ZINTCOMP(nolign-1)) From OBJDIV
Next ABK
[M:ABF3]NBRLNK = nolign
Raz nolign
For [ABX]ABX0 Where CODABF=[M]CODABF
 nolign += 1
 [M:ABF4] = [F:ABX]
Next ABX
[M:ABF4]NBRIND = nolign
Raz nolign
For [ABE]ABE0 Where CODABF=[M]CODABF
 nolign += 1
 [M:ABF5] = [F:ABE]
 [M:ABF5]TBNBRDIME(nolign-1) = [F:ABE]NBRAGD
 For I=0 To DD-1 : [M:ABF5]TBTYPE(((nolign-1)*DD)+I)   = [F:ABE]TYPAGG(I) : Next I
 For I=0 To DD-1 : [M:ABF5]TBDIME(((nolign-1)*DD)+I)   = [F:ABE]DIMAGG(I) : Next I
 For I=0 To DD-1 : [M:ABF5]TBCHAMPS(((nolign-1)*DD)+I) = [F:ABE]LNKAGG(I) : Next I
 For I=0 To DD-1 : [M:ABF5]TBNIVEAU(((nolign-1)*DD)+I) = [F:ABE]NIVAGG(I) : Next I
 For I=0 To DD-1 : [M:ABF5]TBCHAMP(((nolign-1)*DD)+I)  = [F:ABE]FLDAGG(I) : Next I
 [M:ABF5]TBNBRINDEX(nolign-1) = [F:ABE]NBRAGI
 For I=0 To DI-1 : [M:ABF5]TBINDEX(((nolign-1)*DI)+I)  = [F:ABE]INDAGG(I) : Next I
Next ABE
[M:ABF5]NBRAGG = nolign
For I=0 To [M:ABF5]NBRAGG-1
 Chgstl [M:ABF5]CODAGG(I) With ""
Next I
Chgstl [M:ABF5]CODAGG(0) With "AWARNLOW"
Gosub GRISE_AUZ
nolign = 1
Gosub CHARGE
Return

#--------------------#
$GRISE_AUZ
If [M]AUZFCY<>2
 Raz [ABF1]FLDFCY , FNC
 Grizo [ABF1]FLDFCY , FNC
Else
 Actzo [ABF1]FLDFCY , FNC
Endif
Return

#--------------------#
$CHARGE
Local Integer I
Gosub SET_DIME
[M:ABF5]NOLCUR = nolign
[M:ABF5]NBRDIME = [M:ABF5]TBNBRDIME([M:ABF5]NOLCUR-1)
For I=0 To DD-1 : [M:ABF5]TYPDIM(I) = [M:ABF5]TBTYPE((([M:ABF5]NOLCUR-1)*DD)+I)   : Next I
For I=0 To DD-1 : [M:ABF5]DIME(I)   = [M:ABF5]TBDIME((([M:ABF5]NOLCUR-1)*DD)+I)   : Next I
For I=0 To DD-1 : [M:ABF5]CHAMPS(I) = [M:ABF5]TBCHAMPS((([M:ABF5]NOLCUR-1)*DD)+I) : Next I
For I=0 To DD-1 : [M:ABF5]NIVEAU(I) = [M:ABF5]TBNIVEAU((([M:ABF5]NOLCUR-1)*DD)+I) : Next I
For I=0 To DD-1 : [M:ABF5]CHAMP(I)  = [M:ABF5]TBCHAMP((([M:ABF5]NOLCUR-1)*DD)+I)  : Next I
[M:ABF5]NBRINDEX = [M:ABF5]TBNBRINDEX([M:ABF5]NOLCUR-1)
For I=0 To DI-1 : [M:ABF5]INDEX(I)  = [M:ABF5]TBINDEX((([M:ABF5]NOLCUR-1)*DI)+I)  : Next I
Return

#--------------------#
$SAUVE
Local Integer I
Gosub SET_DIME
[M:ABF5]TBNBRDIME([M:ABF5]NOLCUR-1) = [M:ABF5]NBRDIME
For I=0 To DD-1 : [M:ABF5]TBTYPE((([M:ABF5]NOLCUR-1)*DD)+I)   = [M:ABF5]TYPDIM(I) : Next I
For I=0 To DD-1 : [M:ABF5]TBDIME((([M:ABF5]NOLCUR-1)*DD)+I)   = [M:ABF5]DIME(I)   : Next I
For I=0 To DD-1 : [M:ABF5]TBCHAMPS((([M:ABF5]NOLCUR-1)*DD)+I) = [M:ABF5]CHAMPS(I) : Next I
For I=0 To DD-1 : [M:ABF5]TBNIVEAU((([M:ABF5]NOLCUR-1)*DD)+I) = [M:ABF5]NIVEAU(I) : Next I
For I=0 To DD-1 : [M:ABF5]TBCHAMP((([M:ABF5]NOLCUR-1)*DD)+I)  = [M:ABF5]CHAMP(I)  : Next I
[M:ABF5]TBNBRINDEX([M:ABF5]NOLCUR-1) = [M:ABF5]NBRINDEX
For I=0 To DI-1 : [M:ABF5]TBINDEX((([M:ABF5]NOLCUR-1)*DI)+I)  = [M:ABF5]INDEX(I)  : Next I
Return

#--------------------#
$CREATION
For nolign=1 To [M:ABF2]NBRFLD
 Raz [F:ABZ]
 [F:ABZ] = [M:ABF0]
 [F:ABZ] = [M:ABF2]
 [F:ABZ]NUMFLD = nolign
 Write [ABZ]
 If fstat
  GOK=0 : Call FSTA("ABZ") From GLOCK : Break
 Endif
Next nolign
For nolign=1 To [M:ABF3]NBRLNK
 Raz [F:ABK]
 [F:ABK] = [M:ABF0]
 [F:ABK] = [M:ABF3]
 [F:ABK]NUMLNK = nolign
 #[F:ABK]OPTJNT = 1 : # Jointure interne
 [F:ABK]TYPJNT = 1 : # Jointure obligatoire
 Write [ABK]
 If fstat
  GOK=0 : Call FSTA("ABK") From GLOCK : Break
 Endif
Next nolign
For nolign=1 To [M:ABF4]NBRIND
 Raz [F:ABX]
 [F:ABX] = [M:ABF0]
 [F:ABX] = [M:ABF4]
 [F:ABX]NUMIND = nolign
 Write [ABX]
 If fstat
  GOK=0 : Call FSTA("ABX") From GLOCK : Break
 Endif
Next nolign
For nolign=1 To [M:ABF5]NBRAGG
 Raz [F:ABE]
 [F:ABE] = [M:ABF0]
 [F:ABE] = [M:ABF5]
 [F:ABE]NUMAGG = nolign
 [F:ABE]NBRAGD = [M:ABF5]TBNBRDIME(nolign-1)
 For I=0 To DD-1 : [F:ABE]TYPAGG(I) = [M:ABF5]TBTYPE(((nolign-1)*DD)+I)   : Next I
 For I=0 To DD-1 : [F:ABE]DIMAGG(I) = [M:ABF5]TBDIME(((nolign-1)*DD)+I)   : Next I
 For I=0 To DD-1 : [F:ABE]LNKAGG(I) = [M:ABF5]TBCHAMPS(((nolign-1)*DD)+I) : Next I
 For I=0 To DD-1 : [F:ABE]NIVAGG(I) = [M:ABF5]TBNIVEAU(((nolign-1)*DD)+I) : Next I
 For I=0 To DD-1 : [F:ABE]FLDAGG(I) = [M:ABF5]TBCHAMP(((nolign-1)*DD)+I)  : Next I
 [F:ABE]NBRAGI = [M:ABF5]TBNBRINDEX(nolign-1)
 For I=0 To DI-1 : [F:ABE]INDAGG(I) = [M:ABF5]TBINDEX(((nolign-1)*DI)+I)  : Next I
 Write [ABE]
 If fstat
  GOK=0 : Call FSTA("ABE") From GLOCK : Break
 Endif
Next nolign
Return

#--------------------#
$MODIF
Delete [ABZ] Where CODABF=[M]CODABF
If fstat=1 : GOK=-1 : GLOCK="$ABITABFLD" : Return
Elsif fstat>5 : GOK=0 : Call FSTA("ABZ") From GLOCK : Return
Endif
Delete [ABK] Where CODABF=[M]CODABF
If fstat=1 : GOK=-1 : GLOCK="$ABITABLNK" : Return
Elsif fstat>5 : GOK=0 : Call FSTA("ABK") From GLOCK : Return
Endif
Delete [ABX] Where CODABF=[M]CODABF
If fstat=1 : GOK=-1 : GLOCK="$ABITABIND" : Return
Elsif fstat>5 : GOK=0 : Call FSTA("ABX") From GLOCK : Return
Endif
Delete [ABE] Where CODABF=[M]CODABF
If fstat=1 : GOK=-1 : GLOCK="$ABITABAGG" : Return
Elsif fstat>5 : GOK=0 : Call FSTA("ABE") From GLOCK : Return
Endif
Gosub CREATION
For [ABY]ABY2 Where TABDES =[M]CODABF
 Read [F:ABZ]ABZ1 = [M]CODABF;[F:ABY]FLDDES
 If fstat
  Delete [ABY]Curr
  If fstat=1 : GOK=-1 : GLOCK="$ABIREGDES" : Break
  Elsif fstat>5 : GOK=0 : Call FSTA("ABY") From GLOCK : Break
  Endif
 Endif
Next
If GOK<1 : Return : Endif
Local Integer NBRIND
For [ABY]ABY1(1) Where TABDES =[M]CODABF
 Gosub NBRIND
 For [ABZ]ABZ1 Where CODABF = [F:ABY]TABDES
  Read [ABY2]ABY1 = [F:ABY]CODREG;[F:ABZ]CODFLD
  If fstat
   NBRIND +=1
   [F:ABY2]CODREG  = [F:ABY]CODREG
   [F:ABY2]TABDES  = [F:ABZ]CODABF
   [F:ABY2]NUMDES  = NBRIND
   [F:ABY2]FLDDES  = [F:ABZ]CODFLD
   [F:ABY2]FORDES  = ""
   Write [ABY2]
   If fstat
    GOK=0 : Call FSTA("ABY2") From GLOCK : Break
   Endif
  Endif
 Next
Next
Return

$NBRIND
Filter [F:ABY3] Where CODREG = [F:ABY]CODREG
Read [F:ABY3]ABY0 Last
If !fstat
 NBRIND = [F:ABY3]NUMDES
Endif
Filter [F:ABY3]
Return
#--------------------------#
$APRES_MODIF
Local Integer EXISTE,J
If (zoncou = "CODFLD" | status = 65 & zoncou = "NBRFLD") & [M]CODFLD(nolign-1) <> ""
 OK =1
 For [ABM]
  EXISTE =0
  For J=0 To dim([F:ABM]CODABF)-1
   If [F:ABM]CODABF(J) = [M]CODABF
    EXISTE = 1
   Endif
  Next J
  If EXISTE
   For [AHH]AHH0 Where ABM = [F:ABM]COD
    For I=0 To [AHH]NBAHH-1
     If [AHH]CODABF(I) = [M]CODABF & [AHH]CODFLD(I) = [M]CODFLD(nolign-1)
      GMESSAGE = func AFNC.TEXTE([F:AHH]DES)
      GMESSAGE = func AFNC.MES2(mess(68,148,1),[M]CODFLD(nolign-1),[F:AHH]COD-"("+GMESSAGE+")")
      OK = 0 : Break 2
     Endif
    Next I
   Next AHH
  Endif
 Next ABM
Endif
If !OK : Return : Endif
If (zoncou = "CODLNK" | status = 65 & zoncou = "NBRLNK") & [M]CODLNK(nolign-1) <> ""
 OK =1
 For [ABM]
  EXISTE =0
  For J=0 To dim([F:ABM]CODABF)-1
   If [F:ABM]CODABF(J) = [M]CODABF
    EXISTE = 1
   Endif
  Next J
  If EXISTE
   For [AHH]AHH0 Where ABM = [F:ABM]COD
    For I=0 To [AHH]NBAHH-1
     If [AHH]CODDIM1(I) = [M]CODLNK(nolign-1)
      GMESSAGE = func AFNC.TEXTE([F:AHH]DES)
      GMESSAGE = func AFNC.MES2(mess(69,148,1),[M]CODLNK(nolign-1),[F:AHH]COD-"("+GMESSAGE+")")
      OK = 0  : Break 2
     Endif
    Next I
   Next AHH
  Endif
 Next ABM
Endif
Return

#--------------------------#
$APRES_CRE
If [M]CODABF<>""
 Call VALIDATION([M]CODABF,nomap,0)
Endif
Return

#--------------------------#
$APRES_MOD
Gosub APRES_CRE
Return

#--------------------------#
$VERIF_CRE
$VERIF_MOD
Local Integer NBCLE
Local Char    CLE(GLONAVA)(1..100) , CHAINE(250)
Local Char    INTITULE(80)
If [M:ABF0]INTEVAL = ""
 INTITULE = [M:ABF0]ZINTIT
Else
 INTITULE = evalue([M:ABF0]INTEVAL)
Endif
For [F:ABF2]ABF0 Where CODABF <> [M:ABF0]CODABF
 If [F:ABF2]INTEVAL = ""
  If func AFNC.TEXTE([F:ABF2]INTIT) = INTITULE
   OK =0
   Break
  Endif
 Else
  Onerrgo ERCALC
  GBIDC1 = evalue([F:ABF2]INTEVAL)
  Onerrgo
  If GBIDC1 = INTITULE
   OK =0
   Break
  Endif
 Endif
Next
If OK =0
 # Nom de table de fait deja existante
 GMESSAGE = INTITULE-":"-mess(103,148,1) : # Intitulé de table de fait deja existante
 Return
Endif

If [M:ABF2]NBRFLD=0
 GMESSAGE = mess(52,148,1) : # Il doit y avoir au moins un champ
 OK = 0 : Return
Endif

If [M:ABF1]FLDFCY<>""
 K = find([M:ABF1]FLDFCY,[M:ABF2]CODFLD(0..[M:ABF2]NBRFLD-1))
 If !K
  GMESSAGE = [M:ABF1]FLDFCY-":"-mess(14,148,1) : # Champ site inexistant
  OK = 0
 Elsif [M:ABF2]CODTYP(K-1)<>"FCY"
  GMESSAGE = [M:ABF1]FLDFCY-":"-mess(15,148,1)-"("+[M:ABF2]CODTYP(K-1)+")" : # Champ site de type incorrect
  OK = 0
 Elsif [M:ABF2]ACTFLD(K-1)<>""
  GMESSAGE = mess(33,148,1)-"("+[M:ABF2]ACTFLD(K-1)+")" : # Le champ site ne peut avoir de code activité
  OK = 0
 Endif
 If !OK : zonsui = "[M:ABF1]FLDFCY" : Return : Endif
Endif
If [M:ABF1]FLDDAT<>""
 K = find([M:ABF1]FLDDAT,[M:ABF2]CODFLD(0..[M:ABF2]NBRFLD-1))
 If !K
  GMESSAGE = [M:ABF1]FLDDAT-":"-mess(16,148,1) : # Champ date inexistant
  zonsui = "[M:ABF1]FLDDAT"
  OK = 0
 Else
  Read [ATY]CODTYP = [M:ABF2]CODTYP(K-1)
  If [F:ATY]TYPTYP<>8
   GMESSAGE = [M:ABF1]FLDDAT-":"-mess(17,148,1)-"("+[M:ABF2]CODTYP(K-1)+")" : # Champ date de type incorrect
   zonsui = "[M:ABF1]FLDDAT"
   OK = 0
  Elsif [M:ABF2]ACTFLD(K-1)<>""
   GMESSAGE = mess(34,148,1)-"("+[M:ABF2]ACTFLD(K-1)+")" : # Le champ date ne peut avoir de code activité
   zonsui = "[M:ABF2]CODFLD("+num$(K-1)+")"
   OK = 0
  Endif
 Endif
 If !OK : zonsui = "[M:ABF1]FLDDAT" : Return : Endif
Endif

NBCLE = 0
For I=0 To [M:ABF3]NBRLNK-1
 CHAINE = [M]EXPLNK(I)
 Repeat
  NBCLE += 1
  K = instr(1,CHAINE,";")
  If K
   CLE(NBCLE) = left$(CHAINE,K-1)
   CHAINE     = right$(CHAINE,K+1)
  Else
   CLE(NBCLE) = CHAINE
   CHAINE     = ""
  Endif
 Until CHAINE=""
Next I

For I=0 To [M:ABF2]NBRFLD-1
 If [M:ABF2]TYPFLD(I)<> 4 & find([M:ABF2]CODFLD(I),CLE(1..NBCLE))
  GMESSAGE = [M:ABF2]CODFLD(I)-":"-mess(107,148,1) : # Champ technique obligatoire dans les liens
  zonsui = "[M:ABF2]CODFLD("+num$(I)+")"
  OK = 0 : Break
 Endif
Next I
If !OK : Return : Endif

If [M:ABF1]FLDFCY<>""
 For I=0 To [M:ABF5]NBRAGG-1
  If [M]TBNBRDIME(I)=0
   GMESSAGE = [M:ABF5]CODAGG(I)-":"-mess(53,148,1) : # L'agrégat n'a aucune dimension
   zonsui = "[ABF5]NBRAGG("+num$(I)+")"
   OK = 0 : Break
  Endif
  OK = 0
  For J=0 To [M]TBNBRDIME(I)-1
   If [M]TBCHAMPS(I*DD+J)=[M:ABF1]FLDFCY
    OK = 1 : Break
   Endif
  Next J
  If !OK
   # Le champ site n'est pas présent dans l'agrégat
   GMESSAGE = [M:ABF1]FLDFCY-":"-mess(45,148,1)-[M:ABF5]CODAGG(I)
   zonsui = "[ABF5]NBRAGG("+num$(I)+")"
   Break
  Endif
 Next I
Endif
If !OK : Return : Endif

If [M:ABF5]NBRAGG>0
 K = find("ACS",[M:ABF2]CODTYP(0..[M:ABF2]NBRFLD-1))
 If K
  GMESSAGE = [M:ABF2]CODFLD(K-1)-":"-mess(49,148,1) : # Incompatibilité entre agrégats et code d'accès
  zonsui = "[M:ABF2]CODFLD("+num$(K-1)+")"
  OK = 0 : Return
 Endif
Endif
Return

#----------------------------------#
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V1") From GOBJET
Endif
Return

#----------------------------------#
$EXEBOUT
Case BOUT
 When "V" : Call VALIDATION([M]CODABF,nomap,0)
Endcase
Return

#--------------------------#
$AP_ANNULE
Local Char PREF(4)
Local Integer STAT
Call SET_PREF([L]CODE,PREF)
If filinfo(filpath("TRT",PREF+[L]CODE,"src",0),0)>0
 Call EFFACE(filpath("TRT",PREF+[L]CODE,"src",0),STAT) From ORDSYS
 Call EFFACE_ADX("","",PREF+[L]CODE,STAT) From ORDSYS
Endif
Return

#----------------------------------#
Subprog SET_PREF(CODE,PREF)
Value Char CODE
Variable Char PREF
PREF = "WMF"
End

#--------------------------------#
Subprog ACTIV(ACTIV,OK)
Value Char ACTIV
Variable Integer OK
OK = 1
If ACTIV<>""
 Read [ACV]CODACT=ACTIV
 If fstat or [F:ACV]FLACT<>2
  OK = 0
 Endif
Endif
End

#########################################################
## Pour les patches des transactions
#########################################################
Subprog PATCH(APPLI)
Value Char APPLI
Call GENDOS(APPLI)
End

#------------------------------------------------------------#
# Appelé en validation dossier
#------------------------------------------------------------#

Subprog GENDOS(APPLI)
Value Char APPLI
Local Integer OK
If filinfo(filpath("FIL","ABITABFLD","fde",APPLI),0)<=0 : End : Endif
If clalev([F:AB2])=0 : Local File =APPLI+".ABITABFLD" [AB2] : Endif
If clalev([F:ABZ])=0 : Local File =APPLI+".ABITABFLD" [ABZ] : Endif
If clalev([F:ABE])=0 : Local File =APPLI+".ABITABAGG" [ABE] : Endif
If clalev([F:ACV])=0 : Local File =APPLI+".ACTIV"     [ACV] : Endif
For [AB2]ABZ0(1)
 Call ECR_TRACE([F:AB2]CODABF,0) From GESECRAN
 Call VALIDATION([F:AB2]CODABF,APPLI,1)
Next AB2
End

#---------------------------------------------------------#
# Pour synchroniser les agrégats
#---------------------------------------------------------#

Subprog VALIDATION(CODE,DOSSIER,SILENCE)
Value    Char    CODE
Value    Char    DOSSIER
Value    Integer SILENCE

Local Char     NOMPROG(GLONADC) , FICSRC(GDIMFIC)
Local Char     SAVIFS(10) , SAVIRS(10) , IDENT(20)
Local Integer  SAVIUM
Local Integer  I , J , K , OK , NBCLE , NBRFLD , NIVCLE(1..16)
Local Char     CHAINE(250) , CHAINE2(250) , MAGIC(80) , PREF(4)
Local Char     MACHINE(GDIMFIC) , APPLI(GLONADS)
Local Char     CLE(GLONAVA)(1..16)
Local Char     CODFLD(GLONAVA)(1..350)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

If clalev([F:ABE])=0 : Local File =DOSSIER+".ABITABAGG" [ABE] : Endif
If clalev([F:ABZ])=0 : Local File =DOSSIER+".ABITABFLD" [ABZ] : Endif
If clalev([F:ACV])=0 : Local File =DOSSIER+".ACTIV"     [ACV] : Endif

MAGIC   = mess(77,133,1) : # Superviseur Adonix
Call SET_PREF(CODE,PREF)
NOMPROG = PREF+CODE
IDENT   = "## BI-AGREGAT ##"

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

If !SILENCE
 Call TEMPON(mess(159,133,1)-NOMPROG) From GESECRAN : # Validation du traitement
Endif

Read [ABZ]ABZ0(1)=CODE
If !fstat
 Gosub TRT_DEB
 If OK
  Gosub ETIQ
  Gosub TRT_FIN
 Endif
Endif

If !SILENCE
 Call TEMPOFF From GESECRAN
Endif

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
End

#-------------------------------------------------------#
$TRT_DEB
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
FICSRC = filpath("TRT",NOMPROG,"src",APPLI,"",MACHINE)
If filinfo(FICSRC,0)>=0
 Openi FICSRC Using [SSS_]
 Raz I, OK
 Rdseq CHAINE Using [SSS_]
 While !fstat
  I += 1 : If I>5 : Break : Endif
  If left$(CHAINE,len(IDENT))=IDENT
   OK = 1 : Break
  Endif
  Rdseq CHAINE Using [SSS_]
 Wend
 Openi Using [SSS_]
 If I<=1
  OK = 1
 Elsif !OK
  # Ce traitement est déjà utilisé par un autre paramètrage
  Call ECR_TRACE(NOMPROG-":"-mess(215,139,1),1) From GESECRAN
  Return
 Endif
Else
 OK = 1
Endif
Openo FICSRC , 0
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq "#"-MAGIC
Wrseq IDENT-mess(3,148,1)-CODE : # Tables de faits
Wrseq
Return

#-------------------------------------------------------#
$TRT_FIN
Wrseq
Openo
Call VALID("TRT",NOMPROG,DOSSIER,OK) From VALMSKSUB
Return

#-------------------------------------------------------#
$ETIQ
Raz NBRFLD , CODFLD
For [ABZ]ABZ0 Where CODABF=CODE & TYPFLD=1 : # Mesures
 Call ACTIV([F:ABZ]ACTFLD,K)
 If K
  NBRFLD += 1
  CODFLD(NBRFLD) = [F:ABZ]CODFLD
 Endif
Next ABZ
For [ABE]ABE0 Where CODABF=CODE
 Call ACTIV([F:ABE]ACTAGG,K)
 If K
  Raz CLE , NBCLE ,NIVCLE
  For I=1 To [F:ABE]NBRAGD
   If [F:ABE]LNKAGG(I-1)<>""
    CHAINE = [F:ABE]LNKAGG(I-1)
    While CHAINE<>""
     K = instr(1,CHAINE,";")
     If K
      CHAINE2 = left$(CHAINE,K-1)
      CHAINE = right$(CHAINE,K+1)
     Else
      CHAINE2 = CHAINE
      CHAINE = ""
     Endif
     Read [ABZ]ABZ1=CODE;CHAINE2
     If fstat
      K = 0
     Else
      Call ACTIV([F:ABZ]ACTFLD,K)
     Endif
     If K & !find(CHAINE2,CLE(1..NBCLE))
      If NBCLE>=dim(CLE)
       NBCLE = 0 : Break 2
      Else
       NBCLE += 1
       CLE(NBCLE)    = CHAINE2
       NIVCLE(NBCLE) = [F:ABE]NIVAGG(I-1)
      Endif
     Endif
    Wend
   Endif
  Next I
  If NBCLE=0 & [F:ABE]INDAGG<>""
   Raz CLE , NBCLE , NIVCLE
   CHAINE = [F:ABE]INDAGG
   While CHAINE<>""
    I = instr(1,CHAINE,"+")
    J = instr(1,CHAINE,"-")
    If I & J
     I = min(I,J)
    Elsif J & !I
     I = J
    Endif
    If I
     CHAINE2 = left$(CHAINE,I-1)
     CHAINE = right$(CHAINE,I+1)
    Else
     CHAINE2 = CHAINE
     CHAINE = ""
    Endif
    Read [ABZ]ABZ1=CODE;CHAINE2
    If fstat
     K = 0
    Else
     Call ACTIV([F:ABZ]ACTFLD,K)
    Endif
    If K & !find(CHAINE2,CLE(1..NBCLE))
     NBCLE += 1
     CLE(NBCLE)    = CHAINE2
     NIVCLE(NBCLE) = 0
    Endif
   Wend
  Endif
  Wrseq '$ALIM_'+num$([F:ABE]NUMAGG)
  If NBCLE>0
   Wrseq 'OUVTAB = DOSSIER+".'+[F:ABE]CODABF+'_'+[F:ABE]CODAGG+'" : ';
   Wrseq 'Local File =OUVTAB [AAA_]'
   Wrseq 'OUVTAB = DOSSIER+".F_'+CODE+'" : ';
   Wrseq 'Local File =OUVTAB [AAA0] '
   Wrseq '& Order by Key CLE=';
   For I=1 To NBCLE
    If I>1 : Wrseq ';'; : Endif
    Wrseq CLE(I);
   Next I
   Wrseq
   Wrseq 'Trbegin [AAA_]'
   Wrseq ' Delete [AAA_] Where 1=1'
   Wrseq ' For [AAA0]CLE('+num$(NBCLE)+')'
   Wrseq '  Raz [F:AAA_]'
   For I=1 To NBCLE
    Wrseq '  If dim([F:AAA_]'+CLE(I)+')>0';
    Wrseq ' : [F:AAA_]'+CLE(I)+' = ';
    Case NIVCLE(I)
     When 5        : Wrseq 'num$(month([F:AAA0]'+CLE(I)+"))";
     When 8        : Wrseq 'num$(year([F:AAA0]'+CLE(I)+"))";
     When Default  : Wrseq '[F:AAA0]'+CLE(I);
    Endcase
    Wrseq ' : Endif'
   Next I
   Wrseq '  For [AAA0]CLE'
   Wrseq '  #'
   For I=1 To NBRFLD
    Wrseq '   If dim([F:AAA_]'+CODFLD(I)+')>0 : [F:AAA_]'+CODFLD(I)+' += [F:AAA0]'+CODFLD(I)+' : Endif'
   Next I
   Wrseq '  Next AAA0'
   Wrseq '  Write [AAA_]'
   Wrseq '  If fstat'
   Wrseq '   Call ERREUR("'+[F:ABE]CODABF+'_'+[F:ABE]CODAGG+'"';
   For I=1 To NBCLE
    If !mod(I,5) : Wrseq : Wrseq '&   '; : Endif
    Wrseq '-num$([F:AAA0]'+CLE(I)+')';
   Next I
   Wrseq ',1) From DOSDIC'
   Wrseq '  Endif'
   Wrseq ' Next AAA0('+num$(NBCLE)+')'
   Wrseq 'Commit'
  Endif
  Wrseq 'Return'
  Wrseq
 Endif
Next ABE
Wrseq '$OUVRE'
For [ABE]ABE0 Where CODABF=CODE
 Call ACTIV([F:ABE]ACTAGG,K)
 If K
  Wrseq 'OUVTAB = DOSSIER+".'+[F:ABE]CODABF+'_'+[F:ABE]CODAGG+'" : ';
  Wrseq 'Local File =OUVTAB [AAA'+num$([F:ABE]NUMAGG)+']'
 Endif
Next ABE
Wrseq 'Return'
Wrseq
Wrseq '$FERME'
For [ABE]ABE0 Where CODABF=CODE
 Call ACTIV([F:ABE]ACTAGG,K)
 If K
  Wrseq 'Close Local File [AAA'+num$([F:ABE]NUMAGG)+']'
 Endif
Next ABE
Wrseq 'Return'
Wrseq
Wrseq '$INSERT'
For [ABE]ABE0 Where CODABF=CODE
 Call ACTIV([F:ABE]ACTAGG,K)
 If K
  Raz CLE , NBCLE , NIVCLE
  For I=1 To [F:ABE]NBRAGD
   If [F:ABE]LNKAGG(I-1)<>""
    CHAINE = [F:ABE]LNKAGG(I-1)
    While CHAINE<>""
     K = instr(1,CHAINE,";")
     If K
      CHAINE2 = left$(CHAINE,K-1)
      CHAINE = right$(CHAINE,K+1)
     Else
      CHAINE2 = CHAINE
      CHAINE = ""
     Endif
     Read [ABZ]ABZ1=CODE;CHAINE2
     If fstat
      K = 0
     Else
      Call ACTIV([F:ABZ]ACTFLD,K)
     Endif
     If K & !find(CHAINE2,CLE(1..NBCLE))
      If NBCLE>=dim(CLE)
       NBCLE = 0 : Break 2
      Else
       NBCLE += 1
       CLE(NBCLE) = CHAINE2
       NIVCLE(NBCLE) = [F:ABE]NIVAGG(I-1)
      Endif
     Endif
    Wend
   Endif
  Next I
  If NBCLE=0 & [F:ABE]INDAGG<>""
   Raz CLE , NBCLE , NIVCLE
   CHAINE = [F:ABE]INDAGG
   While CHAINE<>""
    I = instr(1,CHAINE,"+")
    J = instr(1,CHAINE,"-")
    If I & J
     I = min(I,J)
    Elsif J & !I
     I = J
    Endif
    If I
     CHAINE2 = left$(CHAINE,I-1)
     CHAINE = right$(CHAINE,I+1)
    Else
     CHAINE2 = CHAINE
     CHAINE = ""
    Endif
    Read [ABZ]ABZ1=CODE;CHAINE2
    If fstat
     K = 0
    Else
     Call ACTIV([F:ABZ]ACTFLD,K)
    Endif
    If K & !find(CHAINE2,CLE(1..NBCLE))
     NBCLE += 1
     CLE(NBCLE) = CHAINE2
     NIVCLE(NBCLE) = 0
    Endif
   Wend
  Endif
  For I=1 To NBCLE
   Wrseq 'If dim([F:AAA'+num$([F:ABE]NUMAGG)+']'+CLE(I)+')>0';
   Wrseq ' : [F:AAA'+num$([F:ABE]NUMAGG)+']'+CLE(I)+' = ';
   Case NIVCLE(I)
    When 5        : Wrseq 'month([F:AAA_]'+CLE(I)+")";
    When 8        : Wrseq 'year([F:AAA_]'+CLE(I)+")";
    When Default  : Wrseq '[F:AAA_]'+CLE(I);
   Endcase
   Wrseq ' : Endif'
  Next I
  Wrseq 'Read [AAA'+num$([F:ABE]NUMAGG)+'] ='
  Wrseq 'If !fstat'
  For I=1 To NBRFLD
   Wrseq ' If dim([F:AAA'+num$([F:ABE]NUMAGG)+']'+CODFLD(I)+')>0';
   Wrseq ' : [F:AAA'+num$([F:ABE]NUMAGG)+']'+CODFLD(I)+' += [F:AAA_]'+CODFLD(I)+' : Endif'
  Next I
  Wrseq ' Rewrite [AAA'+num$([F:ABE]NUMAGG)+']'
  Wrseq ' If fstat'
  Wrseq '  Call ERREUR("'+[F:ABE]CODABF+'_'+[F:ABE]CODAGG+'"';
  For I=1 To NBCLE
   If !mod(I,5) : Wrseq : Wrseq '&   '; : Endif
   Wrseq '-num$([F:AAA_]'+CLE(I)+')';
  Next I
  Wrseq ',1) From DOSDIC'
  Wrseq ' Endif'
  Wrseq 'Else'
  Wrseq ' Raz [AAA'+num$([F:ABE]NUMAGG)+']'
  For I=1 To NBRFLD
   Wrseq ' If dim([F:AAA'+num$([F:ABE]NUMAGG)+']'+CODFLD(I)+')>0';
   Wrseq ' : [F:AAA'+num$([F:ABE]NUMAGG)+']'+CODFLD(I)+' = [F:AAA_]'+CODFLD(I)+' : Endif'
  Next I
  For I=1 To NBCLE
   Wrseq ' If dim([F:AAA'+num$([F:ABE]NUMAGG)+']'+CLE(I)+')>0';
   Wrseq ' : [F:AAA'+num$([F:ABE]NUMAGG)+']'+CLE(I)+' = [F:AAA_]'+CLE(I);
   Wrseq ' : Endif'
  Next I
  Wrseq ' Write [AAA'+num$([F:ABE]NUMAGG)+']'
  Wrseq ' If fstat'
  Wrseq '  Call ERREUR("'+[F:ABE]CODABF+'_'+[F:ABE]CODAGG+'"';
  For I=1 To NBCLE
   If !mod(I,5) : Wrseq : Wrseq '&   '; : Endif
   Wrseq '-num$([F:AAA_]'+CLE(I)+')';
  Next I
  Wrseq ',1) From DOSDIC'
  Wrseq ' Endif'
  Wrseq 'Endif'
 Endif
Next ABE
Wrseq 'Return'
Wrseq
Wrseq '$ERASE'
For [ABE]ABE0 Where CODABF=CODE
 Call ACTIV([F:ABE]ACTAGG,K)
 If K
  Raz CLE , NBCLE , NIVCLE
  For I=1 To [F:ABE]NBRAGD
   If [F:ABE]LNKAGG(I-1)<>""
    CHAINE = [F:ABE]LNKAGG(I-1)
    While CHAINE<>""
     K = instr(1,CHAINE,";")
     If K
      CHAINE2 = left$(CHAINE,K-1)
      CHAINE = right$(CHAINE,K+1)
     Else
      CHAINE2 = CHAINE
      CHAINE = ""
     Endif
     Read [ABZ]ABZ1=CODE;CHAINE2
     If fstat
      K = 0
     Else
      Call ACTIV([F:ABZ]ACTFLD,K)
     Endif
     If K & !find(CHAINE2,CLE(1..NBCLE))
      If NBCLE>=dim(CLE)
       NBCLE = 0 : Break 2
      Else
       NBCLE += 1
       CLE(NBCLE) = CHAINE2
       NIVCLE(NBCLE) = [F:ABE]NIVAGG(I-1)
      Endif
     Endif
    Wend
   Endif
  Next I
  If NBCLE=0 & [F:ABE]INDAGG<>""
   Raz CLE , NBCLE , NIVCLE
   CHAINE = [F:ABE]INDAGG
   While CHAINE<>""
    I = instr(1,CHAINE,"+")
    J = instr(1,CHAINE,"-")
    If I & J
     I = min(I,J)
    Elsif J & !I
     I = J
    Endif
    If I
     CHAINE2 = left$(CHAINE,I-1)
     CHAINE = right$(CHAINE,I+1)
    Else
     CHAINE2 = CHAINE
     CHAINE = ""
    Endif
    Read [ABZ]ABZ1=CODE;CHAINE2
    If fstat
     K = 0
    Else
     Call ACTIV([F:ABZ]ACTFLD,K)
    Endif
    If K & !find(CHAINE2,CLE(1..NBCLE))
     NBCLE += 1
     CLE(NBCLE) = CHAINE2
     NIVCLE(NBCLE) = 0
    Endif
   Wend
  Endif
  For I=1 To NBCLE
   Wrseq 'If dim([F:AAA'+num$([F:ABE]NUMAGG)+']'+CLE(I)+')>0';
   Wrseq ' : [F:AAA'+num$([F:ABE]NUMAGG)+']'+CLE(I)+' = ';
   Case NIVCLE(I)
    When 5        : Wrseq 'month([F:AAA_]'+CLE(I)+")";
    When 8        : Wrseq 'year([F:AAA_]'+CLE(I)+")";
    When Default  : Wrseq '[F:AAA_]'+CLE(I);
   Endcase
   Wrseq ' : Endif'
  Next I
  Wrseq 'Read [AAA'+num$([F:ABE]NUMAGG)+'] ='
  Wrseq 'If !fstat'
  For I=1 To NBRFLD
   Wrseq ' If dim([F:AAA'+num$([F:ABE]NUMAGG)+']'+CODFLD(I)+')>0';
   Wrseq ' : [F:AAA'+num$([F:ABE]NUMAGG)+']'+CODFLD(I)+' -= [F:AAA_]'+CODFLD(I)+' : Endif'
  Next I
  Wrseq ' Rewrite [AAA'+num$([F:ABE]NUMAGG)+']'
  Wrseq ' If fstat'
  Wrseq '  Call ERREUR("'+[F:ABE]CODABF+'_'+[F:ABE]CODAGG+'"';
  For I=1 To NBCLE
   If !mod(I,5) : Wrseq : Wrseq '&   '; : Endif
   Wrseq '-num$([F:AAA_]'+CLE(I)+')';
  Next I
  Wrseq ',1) From DOSDIC'
  Wrseq ' Endif'
  Wrseq 'Endif'
 Endif
Next ABE
Wrseq 'Return'
Wrseq
Return

#--------------------------------------------------------------------------------#
$SEL_TABLE
Case TABLE
 When "SELFLDABF"
  OBJET = "ABZ"
  SUPP = PARAM(1)
  START = "CODFLD"
 When "SELFLDABF1"
  OBJET = "ABZ"
  OPTIONS = "|"
  If PARAM(1)<>""
   CRITERE  = 'CODABF = "'+PARAM(1)+'"'
   ORDRE = 'CODFLD'
  Else
   CRITERE = '1=1'
   ORDRE = 'CODABF;CODFLD'
  Endif
  START = 'CODFLD'
Endcase
Return

#--------------------------------------------------------------------------------#
$SEL_LISTE
Case LISTE
 When "ASELABF"
  Local Char TEX(GLONDES)(1..GNBSEL) , TEXTE(GLONDES)(1..GNBSEL,1..2)
  Local Char OVALEUR(10)
  For I=0 To NBRFLD-1
   NBTEX += 1
   TEX(NBTEX)     = [M:ABF2]CODFLD(I)
   TEXTE(NBTEX,2) = [M:ABF2]ZINTFLD(I)
   If NBTEX>=dim(TEX)-1 : Break : Endif
  Next I
  OVALEUR = VALEUR
  TIT(0)  = mess(12,123,1)  : # Sélection
  TIT(1)  = mess(149,123,1) : # Champs
  TIT(2)  = mess(30,109,1)  : # Intitulé
 When "ASELAGG"
  Local Char TEX(GLONDES)(1..GNBSEL) , TEXTE(GLONDES)(1..GNBSEL,1..1)
  Local Char OVALEUR(10)
  Local Integer K
  If clalev([F:ABE])=0 : Local File ABITABAGG [ABE] : Endif
  If clalev([F:ACV])=0 : Local File ACTIV     [ACV] : Endif
  For [ABE]ABE1
   Call ACTIV([F:ABE]ACTAGG,K)
   If K
    NBTEX += 1
    TEX(NBTEX) = [F:ABE]CODABF+"_"+[F:ABE]CODAGG
    If NBTEX>=dim(TEX)-1 : Break : Endif
   Endif
  Next I
  TIT(0)  = mess(4,148,1)   : # Tables agrégats
Endcase
Return

#---------------------------------#
$VERF_LISTE
Case LISTE
 When "ASELABF"
  If !instr(1,OVALEUR,VALEUR)
   VALEUR = OVALEUR+VALEUR
  Else
   VALEUR = OVALEUR
  Endif
  mkstat = 2
Endcase
Return

#-------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File ABITABDAT [ABF1]
 Local File ABITABFLD [ABZ1]
 Local File ABITABIND [ABX1]
 Local File ABITABLNK [ABK1]
 Local File ABITABAGG [ABE1]
 Local File ATEXTE    [ATX1]
Else
 Local File =[M]DOSORG+".ABITABFLD" [ABF1]
 Local File =[M]DOSORG+".ABITABFLD" [ABZ1]
 Local File =[M]DOSORG+".ABITABIND" [ABX1]
 Local File =[M]DOSORG+".ABITABLNK" [ABK1]
 Local File =[M]DOSORG+".ABITABAGG" [ABE1]
 Local File =[M]DOSORG+".ATEXTE"    [ATX1]
Endif
If [M]DOSDES=nomap
 Local File ABITABDAT [ABF2]
 Local File ABITABFLD [ABZ2]
 Local File ABITABIND [ABX2]
 Local File ABITABLNK [ABK2]
 Local File ABITABAGG [ABE2]
 Local File ATEXTE    [ATX2]
Else
 Local File =[M]DOSDES+".ABITABDAT" [ABF2]
 Local File =[M]DOSDES+".ABITABFLD" [ABZ2]
 Local File =[M]DOSDES+".ABITABIND" [ABX2]
 Local File =[M]DOSDES+".ABITABLNK" [ABK2]
 Local File =[M]DOSDES+".ABITABAGG" [ABE2]
 Local File =[M]DOSDES+".ATEXTE"    [ATX2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ABF1] , [ABZ1], [ABX1], [ABK1], [ABE1], [ATX1]
&              , [ABF2] , [ABZ2], [ABX2], [ABK2], [ABE2], [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [ABF2], [ABZ2] , [ABX2] , [ABK2] , [ABE2] , [ATX2]
 Delete [ABF2] Where CODABF=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ABITABDAT" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ABF2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ABZ2] Where CODABF=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ABITABFLD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ABZ2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ABX2] Where CODABF=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ABITABIND" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ABX2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ABK2] Where CODABF=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ABITABLNK" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ABK2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ABE2] Where CODABF=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ABITABAGG" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ABK2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ABF1] Where CODABF=TABLE
  [F:ABF2] = [F:ABF1]
  Call COPTEXTE([F:ABF1]INTIT,[F:ABF2]INTIT) From OBJDIV
  If GOK<1 : Break : Endif
  Write [ABF2]
  If fstat
   GOK = 0 : Call FSTA("ABF2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ABZ1] Where CODABF=TABLE
  [F:ABZ2] = [F:ABZ1]
  Call COPTEXTE([F:ABZ1]INTFLD,[F:ABZ2]INTFLD) From OBJDIV
  If GOK<1 : Break : Endif
  Write [ABZ2]
  If fstat
   GOK = 0 : Call FSTA("ABZ2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ABX1] Where CODABF=TABLE
  [F:ABX2] = [F:ABX1]
  Write [ABX2]
  If fstat
   GOK = 0 : Call FSTA("ABX2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ABK1] Where CODABF=TABLE
  [F:ABK2] = [F:ABK1]
  Call COPTEXTE([F:ABK1]INTLNK,[F:ABK2]INTLNK) From OBJDIV
  Write [ABK2]
  If fstat
   GOK = 0 : Call FSTA("ABK2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ABE1] Where CODABF=TABLE
  [F:ABE2] = [F:ABE1]
  Write [ABE2]
  If fstat
   GOK = 0 : Call FSTA("ABE2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#--------------------------------------------------------------------------------#
Subprog C_NBRFLD
Local Integer NOL
If status=83 or status=68
 For NOL=nolign-1 To nolign1-1
  Gosub ANUCOD
 Next NOL
Elsif status=65
 NOL = nolign-1
 Gosub ANUCOD
Endif
End

$ANUCOD
Local Integer I , J , K , L , I1
I = 0 : J = 0
While I<[M:ABF3]NBRLNK
 Call TSTCHP([M:ABF3]EXPLNK(I),[M:ABF2]CODFLD(NOL),";",K)
 If K
  Dela I,1,[M:ABF3]NBRLNK [M:ABF3]NBRLNK
  [M:ABF3]NBRLNK -= 1
  J = 1
 Else
  I += 1
 Endif
Wend
If J : Affzo [ABF3] : Endif
I = 0 : J = 0
While I<[M:ABF4]NBRIND
 Call TSTCHP([M:ABF4]EXPIND(I),[M:ABF2]CODFLD(NOL),"+",K)
 If K
  Dela I,1,[M:ABF4]NBRIND [M:ABF4]NBRIND
  [M:ABF4]NBRIND -= 1
  J = 1
 Else
  I += 1
 Endif
Wend
If J : Affzo [ABF4] : Endif
Gosub SET_DIME
I = 0 : J = 0
While I<[M:ABF5]NBRAGG
 For L=0 To [M:ABF5]TBNBRDIME(I)-1
  Call TSTCHP([M:ABF5]TBCHAMPS(DD*I+L),[M:ABF2]CODFLD(NOL),";",K)
  If K : Break : Endif
 Next L
 If !K
  For L=0 To [M:ABF5]TBNBRINDEX(I)-1
   Call TSTCHP([M:ABF5]TBINDEX(DI*I+L),[M:ABF2]CODFLD(NOL),"+",K)
   If K : Break : Endif
  Next L
 Endif
 If K
  Dela I,1 [M:ABF5]NBRAGG
  J = 1
  For I1=I To [M:ABF5]NBRAGG-1
   [M:ABF5]TBNBRDIME(I1) = [M:ABF5]TBNBRDIME(I1+1)
   For L=0 To DD-1
    [M:ABF5]TBCHAMPS(DD*I1+L) = [M:ABF5]TBCHAMPS(DD*(I1+1)+L)
    [M:ABF5]TBCHAMP(DD*I1+L)  = [M:ABF5]TBCHAMP(DD*(I1+1)+L)
    [M:ABF5]TBTYPE(DD*I1+L)   = [M:ABF5]TBTYPE(DD*(I1+1)+L)
    [M:ABF5]TBDIME(DD*I1+L)   = [M:ABF5]TBDIME(DD*(I1+1)+L)
    [M:ABF5]TBNIVEAU(DD*I1+L) = [M:ABF5]TBNIVEAU(DD*(I1+1)+L)
   Next L
   [M:ABF5]TBNBRINDEX(I1) = [M:ABF5]TBNBRINDEX(I1+1)
   For L=0 To DI-1
    [M:ABF5]TBINDEX(DI*I1+L) = [M:ABF5]TBINDEX(DI*(I1+1)+L)
   Next L
  Next I1
  [M:ABF5]NBRAGG -= 1
 Else
  I += 1
 Endif
Wend
If J
 nolign = 1 : Gosub CHARGE
 Affzo [ABF5]
Endif
Return

Subprog TSTCHP(CHAINE,VALEUR,SEP,OK)
Value    Char    CHAINE
Value    Char    CHAMP
Value    Char    SEP
Variable Integer OK
Local Integer I , J , K
Local Char    CHAMP(GLONAVA)
OK = 0
While CHAINE<>""
 I = instr(1,CHAINE,SEP)
 If I
  CHAMP  = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CHAMP  = CHAINE
  CHAINE = ""
 Endif
 If CHAMP=VALEUR
   OK = 1 : Break
 Endif
Wend
End

Subprog AVANT_NBRFLD
GBIDC1 = [M]CODFLD(nolign-1)
End

Subprog APRES_NBRFLD
Local Integer I , J , K , NOL
Local Char    CHAINE(80)
NOL = nolign-1
If status<>6 & [M]CODFLD(NOL)<>GBIDC1 & GBIDC1<>""
 If [M:ABF1]FLDFCY=GBIDC1
  [M:ABF1]FLDFCY = [M]CODFLD(NOL) : Affzo [ABF1]FLDFCY
 Endif
 If [M:ABF1]FLDDAT=GBIDC1
  [M:ABF1]FLDDAT = [M]CODFLD(NOL) : Affzo [ABF1]FLDDAT
 Endif
 For I=0 To [M:ABF3]NBRLNK-1
  Call SWITCH([M:ABF3]EXPLNK(I),GBIDC1,[M]CODFLD(NOL),";",K)
  If K : Affzo [ABF3]EXPLNK(I) : Endif
 Next I
 For I=0 To [M:ABF4]NBRIND-1
  Call SWITCH([M:ABF4]EXPIND(I),GBIDC1,[M]CODFLD(NOL),"+",K)
  If K : Affzo [ABF4]EXPIND(I) : Endif
 Next I
 For I=0 To [M:ABF5]NBRDIME-1
  Call SWITCH([M:ABF5]CHAMPS(I),GBIDC1,[M]CODFLD(NOL),";",K)
  If K : Affzo [ABF5]CHAMPS(I) : Endif
 Next I
 For I=0 To [M:ABF5]NBRINDEX-1
  Call SWITCH([M:ABF5]INDEX(I),GBIDC1,[M]CODFLD(NOL),"+",K)
  If K : Affzo [ABF5]INDEX(I) : Endif
 Next I
 Gosub SET_DIME
 For I=0 To dim([M:ABF5]TBNBRDIME)-1
  For J=0 To [M:ABF5]TBNBRDIME(I)-1
   Call SWITCH([M:ABF5]TBCHAMPS(DD*I+J),GBIDC1,[M]CODFLD(NOL),";",K)
  Next J
 Next I
 For I=0 To dim([M:ABF5]TBNBRINDEX)-1
  For J=0 To [M:ABF5]TBNBRINDEX(I)-1
   Call SWITCH([M:ABF5]TBINDEX(DI*I+J),GBIDC1,[M]CODFLD(NOL),"+",K)
  Next J
 Next I
Endif
End

$ERR
Resume

Subprog C_CODFLD(VALEUR)
Variable Char    VALEUR()
If VALEUR<>[M]CODFLD(nolign-1)
 Onerrgo ERR
 Call PLAGE_ZON([M]CODABF,VALEUR) From CONTOBJ
 If mkstat : End : Endif
 Onerrgo
Endif
End

Subprog AM_CODFLD(VALEUR)
Variable Char    VALEUR()
Local Integer NBTEX , NUM
Local Char    TEX(50)(0..50) , INTIT(30)
NBTEX = 0
For [ABZ]DICO Where CODFLD = VALEUR
 NBTEX += 1
 Call TEXTE([F:ABZ]INTFLD,INTIT) From OBJDIV
 TEX(NBTEX) =  format$("K:11X",[F:ABZ]CODABF)+format$("K:4X",[F:ABZ]CODTYP)
 TEX(NBTEX) += format$("Nz:5F",[F:ABZ]LNGFLD)+" "+INTIT
 If NBTEX>=dim(TEX)-1 : Break : Endif
Next
If NBTEX
 Call SAITEX(NBTEX,TEX,NUM,mess(108,123,1)-VALEUR) From GESECRAN
 If NUM<>0 & status<>7
  Read [ABF]ABF0 = vireblc(left$(TEX(NUM),10),2)
  Read [ABZ]ABZ1 = [F:ABF]CODABF;VALEUR
  [M] = [F:ABZ]
  Call TEXTE([F:ABZ]INTFLD,[M:ABF2]ZINTFLD(nolign-1)) From OBJDIV
 Endif
Endif
End

Subprog SWITCH(CHAINE,OLD,NEWREC,SEP,FLG)
Variable Char    CHAINE
Value    Char    OLD
Value    Char    NEWREC
Value    Char    SEP
Variable Integer FLG
Local Integer I , J
Local Char    OCHAINE(80)
I = 0
While I<=len(CHAINE)
 J = instr(I+1,CHAINE,SEP)
 If J=0 : J = len(CHAINE)+1 : Endif
 If seg$(CHAINE,I+1,J-1)=OLD
  CHAINE = left$(CHAINE,I)+NEWREC+right$(CHAINE,J)
 Endif
 I = J
Wend
FLG = (CHAINE<>OCHAINE)
End

Subprog C_INTEVAL(VALEUR)
Variable Char    VALEUR()
Local Integer    ERN
Local Char       INTITULE(80)
If VALEUR = "" & [M:ABF0]ZINTIT = ""
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 2 : End
Endif
If VALEUR = "" : End : Endif
Onerrgo ERCALC
INTITULE = evalue(VALEUR)
If ERN : GMESSAGE = mess(65,106,1)-":"-errmes$(ERN) : mkstat = 2 : End : Endif
If instr(1,evalue(VALEUR),",")
 GMESSAGE = ","-":"-mess(113,123,1) : # Cacarctère invalide
 mkstat = 2 : End
Endif
End

$ERCALC
ERN = errn
Resume

Subprog C_ZINTFLD(VALEUR)
Variable Char    VALEUR()
Local Char       INTITULE(80)
Local Integer    I,ERN
If VALEUR <> "$"
 If instr(1,VALEUR,",")
  GMESSAGE = ","-":"-mess(113,123,1) : # Cacarctère invalide
  mkstat = 2 : End
 Endif
 INTITULE = VALEUR
 [M:ABF2]INTVALFLD(nolign-1) = ""
Else
 If [M:ABF2]INTVALFLD(nolign-1) <> ""
  Onerrgo ERCALC
  INTITULE = evalue([M:ABF2]INTVALFLD(nolign-1))
  If ERN : Errbox mess(65,106,1)-":"-errmes$(ERN) : mkstat = 2 : End : Endif
  If instr(1,evalue([M:ABF2]INTVALFLD(nolign-1)),",")
   GMESSAGE = ","-":"-mess(113,123,1) : # Cacarctère invalide
   mkstat = 2 : End
  Endif
 Else
  GMESSAGE = "$"-":"-mess(113,123,1) : # Cacarctère invalide
  mkstat = 2 : End
 Endif
Endif
For I=0 To dim([M:ABF2]ZINTFLD)-1
 If I <> nolign-1
  If [M:ABF2]ZINTFLD(I) <> "$"
   If INTITULE = [M:ABF2]ZINTFLD(I)
    GMESSAGE = mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
    mkstat=2 : Break
   Endif
  Else
   If INTITULE = evalue([M:ABF2]INTVALFLD(I))
    GMESSAGE = mess(131,123,1)-":"-mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
    mkstat=2 : Break
   Endif
  Endif
 Endif
Next I
End

Subprog AS_MENLOC(VALEUR)
Variable Decimal VALEUR
If [M]CODTYP(nolign-1) = "ADI" : mkstat =1 : End : Endif
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
If ([F:ATY]TYPTYP<>1 | [F:ATY]NOLIB<>0) & [F:ATY]OBJLIEN<>"ADI" : mkstat=1 : End : Endif
End

Subprog AS_TABDIV(VALEUR)
Variable Decimal VALEUR
If [M]CODTYP(nolign-1) <> "ADI" : mkstat =1 : End : Endif
End

Subprog D_LNGFLD(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
If !fstat & ([F:ATY]FORTYP="" | [F:ATY]LNGTYP=0) : # S'il s'agit d'un type de donnée standard
 Case [F:ATY]TYPTYP
  When 1       : VALEUR=15  : # Libellé
  When 2       : VALEUR=4   : # Entier Court
  When 3       : VALEUR=8   : # Entier Long
  When 4       : VALEUR=9.2 : # Décimal
  When 7       : VALEUR=10  : # Alphanumérique
 Endcase
Endif
End

Subprog AS_LNGFLD(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
If [F:ATY]FORTYP<>"" | [F:ATY]LNGTYP<>0 | [F:ATY]TYPTYP=1 | [F:ATY]TYPTYP=8 : mkstat=1 : End : Endif
End

Subprog C_LNGFLD(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 : mkstat=1 : End : Endif
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
Local Decimal ENTIER , DECIM
ENTIER = int(VALEUR)
DECIM  = 10*(VALEUR-ENTIER)
While DECIM<>int(DECIM)
 DECIM *= 10
Wend
Case [F:ATY]TYPTYP
 When 1 : If DECIM<>0 | ENTIER>20 : mkstat=1 : Endif : # Libellé
 When 2 : If DECIM<>0 | ENTIER>4 : mkstat=1 : Endif  : # Entier court
 When 3 : If DECIM<>0 | ENTIER>8 : mkstat=1 : Endif  : # Entier long
 When 4 : If DECIM+ENTIER<1 | DECIM+ENTIER>32 : mkstat=1 : Endif : # DCB
 When 7 : If DECIM<>0 | ENTIER>250 : mkstat=1 : Endif             : # Char
 When 8 : If DECIM<>0 | !find(ENTIER,4,6,8) : mkstat=1 : Endif   : # Date
Endcase
If mkstat : GMESSAGE = mess(111,123,1) : Endif : # Longueur incorrecte
End

Subprog C_EXPIND(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(vireblc(VALEUR,4))
Local Char    CHAINE(250)
Local Integer I
CHAINE = VALEUR
Gosub DEFCLE
For I=1 To NBCLE
 If !find(CLE(I),[M:ABF2]CODFLD(0..[M:ABF2]NBRFLD-1))
  GMESSAGE = CLE(I)-":"-mess(41,100,1) : # Champ inexistant
  mkstat = 2 : Break
 Elsif find(CLE(I),CLE(1..I-1))
  GMESSAGE = CLE(I)-":"-mess(18,148,1) : # Champ défini 2 fois
  mkstat = 2 : Break
 Endif
Next I
End

Subprog C_AUZFCY(VALEUR)
Variable Integer VALEUR
[M]AUZFCY = VALEUR
Gosub GRISE_AUZ
End

Subprog AS_NBRAGG
If [M]NOLCUR<>0
 Chgstl [M]CODAGG([M]NOLCUR-1) With ""
Endif
Chgstl [M]CODAGG(nolign-1) With "AWARNLOW"
Gosub CHARGE
Affzo 15-20
End

Subprog AS_NBRDIME
If [M]NBRAGG=0 or [M]CODAGG([M]NOLCUR-1)="" : mkstat = 2 : End : Endif
End

Subprog C_NBRDIME
If adxgtb<>0 : Gosub SAUVE : Endif
End

Subprog AS_NBRINDEX
If [M]NBRAGG=0 or [M]CODAGG([M]NOLCUR-1)="" : mkstat = 2 : End : Endif
End

Subprog C_NBRINDEX
If adxgtb<>0 : Gosub SAUVE : Endif
End

Subprog AS_DIME(VALEUR)
Variable Char     VALEUR
If [M]TYPDIM(nolign-1)<>4 : mkstat = 2 : End : Endif
End

Subprog AS_TYPOPE(VALEUR)
Variable Integer VALEUR
End

Subprog AS_PARENT(VALEUR)
Variable Char    VALEUR()
If [M]TYPDIM(nolign-1)=1 : mkstat = 1 : End : Endif
End

Subprog AS_CHAMP(VALEUR)
Variable Char    VALEUR()
If [M]TYPDIM(nolign-1)=1 : mkstat = 1 : End : Endif
End

Subprog AS_TYPDAT(VALEUR)
Variable Char    VALEUR()
Call AS_TYPDAT(VALEUR) From SUBABI
End

Subprog C_TYPDAT(VALEUR)
Variable Char    VALEUR()
Call C_TYPDAT(VALEUR) From SUBABI
End

Subprog C_CODTYP(VALEUR)
Variable Char    VALEUR()
Call LECTURE("ATY",VALEUR,"") From CONTOBJ
If find([F:ATY]TYPTYP,9,10) or find(VALEUR,"AXX","AX1","AX2","AX3","ATX") : # Pas de blob/clob, textes trad
 GMESSAGE = mess(14,133,1) : # Type de données incorrect
 mkstat = 2 : End
Elsif VALEUR="ACS"
 K = find("ACS",[M]CODTYP(0..nolign-2),[M]CODTYP(nolign..[M]NBRFLD-1))
 If K
  GMESSAGE = mess(51,148,1) : # Il ne peut y avoir qu'un seul code d'accès
  mkstat = 2 : End
 Endif
Endif
[M:ABF2]CODTYP(nolign-1) = VALEUR : Gosub GRISE_TUNNEL
End

Subprog AS_TYPFLD(VALEUR)
Variable Integer VALEUR
If [M]CODTYP(nolign-1)="ACS" : # Code d'accès => technique
 VALEUR = 4 : mkstat = 2 : End
Endif
End

Subprog C_TYPFLD(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
 If !find([F:ATY]TYPTYP,1,2,3,4,5,6)
  GMESSAGE = mess(38,148,1) : # Le champ doit être numérique
  mkstat = 2 : End
 Endif
Elsif VALEUR=2
 Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
 If [F:ATY]TYPTYP=8
  Effzo TYPDAT(nolign-1)
 Endif
Endif
End

Subprog C_NBRLNK
Local Integer NOL
If status=83 or status=68
 For NOL=nolign-1 To nolign1-1
  Gosub ANULNK
 Next NOL
Elsif status=65
 NOL = nolign-1
 Gosub ANULNK
Endif
End

$ANULNK
Local Integer I , J , K , L , I1
Gosub SET_DIME
I = 0 : J = 0
While I<[M:ABF5]NBRAGG
 K = 0
 For L=0 To [M:ABF5]TBNBRDIME(I)-1
  If [M:ABF5]TBCHAMPS(DD*I+L)=[M:ABF3]EXPLNK(NOL) & [M:ABF5]TBDIME(DD*I+L)=[M:ABF3]CODLNK(NOL)
   K = 1 : Break
  Endif
 Next L
 If K
  Dela I,1 [M:ABF5]NBRAGG
  J = 1
  For I1=I To [M:ABF5]NBRAGG-1
   [M:ABF5]TBNBRDIME(I1) = [M:ABF5]TBNBRDIME(I1+1)
   For L=0 To DD-1
    [M:ABF5]TBCHAMPS(DD*I1+L) = [M:ABF5]TBCHAMPS(DD*(I1+1)+L)
    [M:ABF5]TBCHAMP(DD*I1+L)  = [M:ABF5]TBCHAMP(DD*(I1+1)+L)
    [M:ABF5]TBTYPE(DD*I1+L)   = [M:ABF5]TBTYPE(DD*(I1+1)+L)
    [M:ABF5]TBDIME(DD*I1+L)   = [M:ABF5]TBDIME(DD*(I1+1)+L)
    [M:ABF5]TBNIVEAU(DD*I1+L) = [M:ABF5]TBNIVEAU(DD*(I1+1)+L)
   Next L
   [M:ABF5]TBNBRINDEX(I1) = [M:ABF5]TBNBRINDEX(I1+1)
   For L=0 To DI-1
    [M:ABF5]TBINDEX(DI*I1+L) = [M:ABF5]TBINDEX(DI*(I1+1)+L)
   Next L
  Next I1
  [M:ABF5]NBRAGG -= 1
 Else
  I += 1
 Endif
Wend
If J
 nolign = 1 : Gosub CHARGE
 Affzo [ABF5]
Endif
Return

Subprog AVANT_NBRLNK
GBIDC1 = [M]CODLNK(nolign-1)
GBIDC2 = [M]EXPLNK(nolign-1)
End

Subprog APRES_NBRLNK
Local Integer I , J , K , NOL
Local Char    CHAINE(80)
NOL = nolign-1
If status<>6
 For I=0 To [M:ABF5]NBRDIME-1
  If GBIDC1<>"" & [M:ABF5]DIME(I)=GBIDC1 & GBIDC1<>[M]CODLNK(NOL)
   [M:ABF5]DIME(I) = [M]CODLNK(NOL)
   Affzo [ABF5]DIME(I)
  Endif
  If GBIDC2<>"" & [M:ABF5]CHAMPS(I)=GBIDC2 & GBIDC2<>[M]EXPLNK(NOL)
   [M:ABF5]CHAMPS(I) = [M]EXPLNK(NOL)
   Affzo [ABF5]CHAMPS(I)
  Endif
 Next I
 Gosub SET_DIME
 For I=0 To dim([M:ABF5]TBNBRDIME)-1
  For J=0 To [M:ABF5]TBNBRDIME(I)-1
   If GBIDC1<>"" & [M:ABF5]TBDIME(DD*I+J)=GBIDC1 & GBIDC1<>[M]CODLNK(NOL)
    [M:ABF5]TBDIME(DD*I+J)=[M]CODLNK(NOL)
   Endif
   If GBIDC2<>"" & [M:ABF5]TBCHAMPS(DD*I+J)=GBIDC2 & GBIDC2<>[M]EXPLNK(NOL)
    [M:ABF5]TBCHAMPS(DD*I+J)=[M]EXPLNK(NOL)
   Endif
  Next J
 Next I
Endif
End

$VERIF_EXP
Local Char    CHAINE(250)
Local Integer I , TT ,K
VALEUR = toupper(VALEUR)
For I=0 To [M]NBRLNK-1
 If I<>nolign-1 & [M]CODLNK(I)=[M]CODLNK(nolign-1) & [M]EXPLNK(I)=VALEUR
  GMESSAGE = mess(29,100,1)-num$(I+1) : # Code déjà défini en ligne
  mkstat = 2 : Break
 Endif
Next I
If mkstat : End : Endif
Call LECTURE("ABI",[M]CODLNK(nolign-1),"") From CONTOBJ
CHAINE = [F:ABI]CLE
Gosub DEFCLE
CHAINE = VALEUR
$VERIF_EXP2
Local Integer NBCHAMP , K
Local Char    CHAMP(GLONAVA)(1..16)
NBCHAMP = 0
Repeat
 NBCHAMP += 1
 K = instr(1,CHAINE,";")
 If K
  CHAMP(NBCHAMP) = left$(CHAINE,K-1)
  CHAINE         = right$(CHAINE,K+1)
 Else
  CHAMP(NBCHAMP) = CHAINE
  CHAINE         = ""
 Endif
Until K=0
Return

Subprog AM_EXPLNK(VALEUR)
Variable Char    VALEUR()
Gosub VERIF_EXP
If NBCHAMP<>NBCLE & NBCHAMP<>[M]NBCHPLNK(nolign-1)
 GMESSAGE = mess(19,148,1)+"\"+[F:ABI]CLE-"("+num$(NBCLE)+")"+"\"+mess(205,100,1) : # Nombre de champs incorrect
 Call OUINON(GMESSAGE,I) From GESECRAN
 Raz GMESSAGE
 If I<>2
  mkstat = 2 : End
 Endif
Endif
For I=1 To NBCHAMP
 K = find(CHAMP(I),[M:ABF2]CODFLD(0..[M:ABF2]NBRFLD-1))
 If !K
  GMESSAGE = CHAMP(I)-":"-mess(41,100,1) : # Champ inexistant
  mkstat = 2 : Break
 Endif
 K = find(CHAMP(I),[M:ABF2]CODFLD(0..[M:ABF2]NBRFLD-1))
 If K & [M:ABF2]TYPFLD(K-1) <> 4
  GMESSAGE = CHAMP(I)-":"- mess(107,148,1)+"\"+mess(150,148,1) : # Champ technique obligatoire dans les liens
  Call OUINON(GMESSAGE,I) From GESECRAN
  Raz GMESSAGE
  If I=2 : [M:ABF2]TYPFLD(K-1) = 4 : Affzo [M:ABF2]TYPFLD(K-1) : Endif
  mkstat = 2 : Break
 Endif
 Read [ABJ]ABJ1 = [M]CODLNK(nolign-1);CLE(I)
 Read [ATY]CODTYP = [F:ABJ]CODTYP
 TT = [F:ATY]TYPTYP
 Read [ATY]CODTYP = [M:ABF2]CODTYP(K-1)
 If TT<>[F:ATY]TYPTYP
  GMESSAGE = [M:ABF2]CODFLD(K-1)-":"-mess(21,148,1)-"\("-mess(36,148,1)-":"-mess(TT,30,1)+")"
  # Champ de type incorrect.. le champ doit être de type
  mkstat = 2 : Break
 Endif
Next I
[M]NBCHPLNK(nolign-1) = NBCHAMP
End

Subprog C_EXPLNK(VALEUR)
Variable Char    VALEUR()
End

$DEFCLE
Local Integer NBCLE , K
Local Char    CLE(GLONAVA)(1..16)
Call SETCLE(NBCLE,CLE,CHAINE) From LNKSUB
Return

Subprog C_DIME(VALEUR)
Variable Char    VALEUR()
If !find(VALEUR,[M:ABF3]CODLNK(0..[M:ABF3]NBRLNK-1))
 GMESSAGE = VALEUR-":"-mess(20,148,1) : # Dimension non définie sur la table
 mkstat = 2  : End
Endif
End

Subprog AS_CHAMPS(VALEUR)
Variable Char    VALEUR
Local Integer I , J , K
Case [M]TYPDIM(nolign-1)
 When 1
  K = 0 : J = -1
  For I=0 To [M:ABF2]NBRFLD-1
   If [M:ABF2]TYPFLD(I)=3 & !find([M:ABF2]CODFLD(I),[M]CHAMPS(0..nolign-2),[M]CHAMPS(nolign..[M]NBRDIME-1))
    Read [ATY]CODTYP = [M:ABF2]CODTYP(I)
    If [F:ATY]TYPTYP=8
     K += 1 : If J<0 : J = I : Endif
    Endif
   Endif
  Next I
  If K=1
   VALEUR = [M:ABF2]CODFLD(J) : mkstat = 2
  Elsif VALEUR="" & J>=0
   VALEUR = [M:ABF2]CODFLD(J)
  Endif
 When 2
  K = 0 : J = -1
  For I=0 To [M:ABF2]NBRFLD-1
   If [M:ABF2]TYPFLD(I)=3 & !find([M:ABF2]CODFLD(I),[M]CHAMPS(0..nolign-2),[M]CHAMPS(nolign..[M]NBRDIME-1))
    Read [ATY]CODTYP = [M:ABF2]CODTYP(I)
    If [F:ATY]TYPTYP=1
     K += 1 : If J<0 : J = I : Endif
    Endif
   Endif
  Next I
  If K=1
   VALEUR = [M:ABF2]CODFLD(J) : mkstat = 2
  Elsif VALEUR="" & J>=0
   VALEUR = [M:ABF2]CODFLD(J)
  Endif
 When 3
  K = 0 : J = -1
  For I=0 To [M:ABF2]NBRFLD-1
   If [M:ABF2]TYPFLD(I)=3 & !find([M:ABF2]CODFLD(I),[M]CHAMPS(0..nolign-2),[M]CHAMPS(nolign..[M]NBRDIME-1))
    If [M:ABF2]CODTYP(I)="ADI"
     K += 1 : If J<0 : J = I : Endif
    Endif
   Endif
  Next I
  If K=1
   VALEUR = [M:ABF2]CODFLD(J) : mkstat = 2
  Elsif VALEUR="" & J>=0
   VALEUR = [M:ABF2]CODFLD(J)
  Endif
 When 4
  K = 0 : J = -1
  For I=0 To [M:ABF3]NBRLNK-1
   If !find([M:ABF3]EXPLNK(I),[M]CHAMPS(0..nolign-2),[M]CHAMPS(nolign..[M]NBRDIME-1))
    If [M]DIME(nolign-1)=[M]CODLNK(I)
     K += 1 : If J<0 : J = I : Endif
    Endif
   Endif
  Next I
  If K=1
   VALEUR = [M:ABF3]EXPLNK(J) : mkstat = 2
  Elsif VALEUR="" & J>=0
   VALEUR = [M:ABF3]EXPLNK(J)
  Endif
Endcase
End

Subprog C_CHAMPS(VALEUR)
Variable Char    VALEUR()
Local Integer I , J , K , OK
Call UNICITE(VALEUR,[M]CHAMPS(0..[M]NBRDIME-1)) From OBJDIV
If mkstat : End : Endif
Case [M]TYPDIM(nolign-1)
 When 1
  K = find(VALEUR,[M:ABF2]CODFLD(0..[M:ABF2]NBRFLD-1))
  If !K
   GMESSAGE = VALEUR-":"-mess(41,100,1) : # Champ inexistant
   mkstat = 2 : End
  Endif
  If [M:ABF2]TYPFLD(K-1)<>3
   GMESSAGE = VALEUR-":"-mess(36,148,1)-mess(3,7821,1) : # Le champ doit être de type dimension
   mkstat = 2 : End
  Endif
  Read [ATY]CODTYP = [M:ABF2]CODTYP(K-1)
  If [F:ATY]TYPTYP<>8
   GMESSAGE = VALEUR-":"-mess(21,148,1) : # Type de champ incorrect
   mkstat = 2 : End
  Endif
 When 2
  K = find(VALEUR,[M:ABF2]CODFLD(0..[M:ABF2]NBRFLD-1))
  If !K
   GMESSAGE = VALEUR-":"-mess(41,100,1) : # Champ inexistant
   mkstat = 2 : End
  Endif
  If [M:ABF2]TYPFLD(K-1)<>3
   GMESSAGE = VALEUR-":"-mess(36,148,1)-mess(3,7821,1) : # Le champ doit être de type dimension
   mkstat = 2 : End
  Endif
  Read [ATY]CODTYP = [M:ABF2]CODTYP(K-1)
  If [F:ATY]TYPTYP<>1
   GMESSAGE = VALEUR-":"-mess(21,148,1) : # Type de champ incorrect
   mkstat = 2 : End
  Endif
 When 3
  K = find(VALEUR,[M:ABF2]CODFLD(0..[M:ABF2]NBRFLD-1))
  If !K
   GMESSAGE = VALEUR-":"-mess(41,100,1) : # Champ inexistant
   mkstat = 2 : End
  Endif
  If [M:ABF2]TYPFLD(K-1)<>3
   GMESSAGE = VALEUR-"("+mess([M:ABF2]TYPFLD(K-1),7821,1)+")"-":"-mess(36,148,1)-mess(3,7821,1)
   # Le champ doit être de type dimension
   mkstat = 2 : End
  Endif
  If [M:ABF2]CODTYP(K-1)<>"ADI"
   GMESSAGE = VALEUR-":"-mess(21,148,1) : # Type de champ incorrect
   mkstat = 2 : End
  Endif
 When 4
  For I=0 To [M:ABF3]NBRLNK-1
   If [M:ABF3]CODLNK(I)=[M]DIME(nolign-1) & [M]EXPLNK(I)=VALEUR
    OK = 1 : Break
   Endif
  Next I
  If !OK
   GMESSAGE = VALEUR-":"-mess(37,124,1) : # Expression incorrecte
   mkstat = 2 : End
  Endif
Endcase
End

Subprog S_CHAMPS(VALEUR)
Variable Char VALEUR()
Local Integer NBLIB , NUMERO
Local Char    TBLIB(50)(0..30) , CHAMP(50)(1..30)
Local Char    TEXTE(80)
Case [M]TYPDIM(nolign-1)
 When 1
  For I=0 To [M:ABF2]NBRFLD-1
   Read [ATY]CODTYP = [M:ABF2]CODTYP(I)
   If [M:ABF2]TYPFLD(I)=3 & [F:ATY]TYPTYP=8
    NBLIB += 1
    CHAMP(NBLIB) = [M:ABF2]CODFLD(I)
    TBLIB(NBLIB) = [M:ABF2]CODFLD(I)-[M:ABF2]ZINTFLD(I)
   Endif
  Next I
 When 2
  For I=0 To [M:ABF2]NBRFLD-1
   Read [ATY]CODTYP = [M:ABF2]CODTYP(I)
   If [M:ABF2]TYPFLD(I)=3 & [F:ATY]TYPTYP=1
    NBLIB += 1
    CHAMP(NBLIB) = [M:ABF2]CODFLD(I)
    TBLIB(NBLIB) = [M:ABF2]CODFLD(I)-[M:ABF2]ZINTFLD(I)
   Endif
  Next I
 When 3
  For I=0 To [M:ABF2]NBRFLD-1
   If [M:ABF2]TYPFLD(I)=3 & [M:ABF2]CODTYP(I)="ADI"
    NBLIB += 1
    CHAMP(NBLIB) = [M:ABF2]CODFLD(I)
    TBLIB(NBLIB) = [M:ABF2]CODFLD(I)-[M:ABF2]ZINTFLD(I)
   Endif
  Next I
 When 4
  For I=0 To [M:ABF3]NBRLNK-1
   If [M:ABF3]CODLNK(I)=[M]DIME(nolign-1)
    NBLIB += 1
    CHAMP(NBLIB) = [M:ABF3]EXPLNK(I)
    TBLIB(NBLIB) = [M:ABF3]EXPLNK(I)
   Endif
  Next I
Endcase
If NBLIB
 Call SAITEX(NBLIB,TBLIB,NUMERO,mess(109,124,1)) From GESECRAN : # Sélection champ
 If NUMERO
  VALEUR = CHAMP(NUMERO)
 Endif
Endif
End

Subprog C_NIVEAU(VALEUR)
Variable Integer VALEUR
Local Char    T(1)
Local Integer K
Gosub SET_TYPDAT From SUBABI
T = TEX(VALEUR)
K = find([M]CHAMPS(nolign-1),[M:ABF2]CODFLD(0..[M:ABF2]NBRFLD-1))
If !instr(1,"D"+[M:ABF2]TYPDAT(K-1),T)
 GMESSAGE = mess(22,148,1) : # Niveau incorrect
 mkstat = 2 : End
Endif
End

Subprog AS_NIVEAU(VALEUR)
Variable Integer VALEUR
If [M]TYPDIM(nolign-1)<>1
 mkstat = 1 : End
Endif
Local Integer I , J , K
Local Char    CHAINE(250)
K = find([M]CHAMPS(nolign-1),[M:ABF2]CODFLD(0..[M:ABF2]NBRFLD-1))
Raz GMENLOC
For I=2 To len(mess(0,7825,1))
 GMENLOC(I) = 1
Next I
Gosub SET_TYPDAT From SUBABI
CHAINE = sum(TEX(1..NBTEX))
For I=1 To len([M:ABF2]TYPDAT(K-1))
 J = instr(1,CHAINE,mid$([M:ABF2]TYPDAT(K-1),I,1))
 If J & mid$([M:ABF2]TYPDAT(K-1),I,1)<>"Q"
  GMENLOC(J) = 0
 Endif
Next I
End

Subprog C_INDEX(VALEUR)
Variable Char    VALEUR()
Local Integer NBCHAMP
Local Char    CHAMP(GLONAVA)(1..17)
Local Integer K
Gosub DEFINDEX
Call SETCLE(NBCHAMP,CHAMP,VALEUR) From LNKSUB
For I=1 To NBCHAMP
 If !find(CHAMP(I),CLE(1..NBCLE))
  GMESSAGE = CHAMP(I)-":"-mess(23,148,1) : # Champ non défini dans cet agrégat
  mkstat = 2 : Break
 Elsif find(CHAMP(I),CHAMP(I+1..NBCHAMP))
  GMESSAGE = CHAMP(I)-":"-mess(18,148,1) : # Champ défini 2 fois
  mkstat = 2 : Break
 Endif
Next I
End

$DEFINDEX
Local Integer I , J , K
Local Integer NBCLE
Local Char    CLE(GLONAVA)(0..30) , LIBCLE(50)(0..30)
NBCLE = 0
For I=0 To [M]NBRDIME-1
 CHAINE = [M]CHAMPS(I)
 Repeat
  NBCLE += 1
  K = instr(1,CHAINE,";")
  If K
   CLE(NBCLE) = left$(CHAINE,K-1)
   CHAINE     = right$(CHAINE,K+1)
  Else
   CLE(NBCLE) = CHAINE
   CHAINE     = ""
  Endif
  J = find(CLE(NBCLE),[M:ABF2]CODFLD(0..[M:ABF2]NBRFLD-1))
  If J
   LIBCLE(NBCLE) = CLE(NBCLE)-[M:ABF2]ZINTFLD(J-1)
  Endif
 Until CHAINE=""
Next I
Return

Subprog S_INDEX(VALEUR)
Variable Char    VALEUR()
Local Integer NUMERO
Gosub DEFINDEX
If NBCLE
 Call SAITEX(NBCLE,LIBCLE,NUMERO,mess(109,124,1)) From GESECRAN : # Sélection champ
 If NUMERO
  VALEUR += CLE(NUMERO) : mkstat = 2
 Endif
Endif
End

$GRISE_TUNNEL
Local Integer OKK
Read [F:ATY]CODTYP = [M:ABF2]CODTYP(nolign-1)
If !fstat & [F:ATY]OBJLIEN <> ""
  Read [AOB]ABREV = [F:ATY]OBJLIEN
  If !fstat & [F:AOB]NOMFIC <> ""
   Read [ATI]NUMLIG = [F:AOB]NOMFIC;1
   If !fstat & instr(1,[F:ATI]DESCRIPT,"+")=0
    OKK = 1
   Endif
  Endif
Endif
GPE = 0
GPOINT = "ABITUNNEL" : Gosub ENTREE From EXEFNC
If !OKK
 [M:ABF2]TUNNEL(nolign-1) = 1
 Affzo [M:ABF2]TUNNEL(nolign-1)
 Grizo [M:ABF2]TUNNEL(nolign-1)
Else
 Actzo [M:ABF2]TUNNEL(nolign-1)
Endif
Return
Subprog IB_NBRIND
End

Subprog AV_NBRIND
End

Subprog B1_OPTJNT(VALEUR)
Variable Integer VALEUR
Local Char MESSA(250)
Case VALEUR
 When 1  : MESSA = [M:ABF0]CODABF-":"-[M:ABF3]CODLNK(nolign-1)
 When 2  : MESSA = [M:ABF0]CODABF-"*:"-[M:ABF3]CODLNK(nolign-1)
 When 3  : MESSA = [M:ABF0]CODABF-":*"-[M:ABF3]CODLNK(nolign-1)
Endcase
If MESSA<> ""
 Call MESSAGE(MESSA) From GESECRAN
Endif
End

Subprog C_ZINTLNK(VALEUR)
Variable Char    VALEUR()
Local Char       INTITULE(80)
Local Integer    I,ERN
If VALEUR <> "$"
 If VALEUR = "" :  [M:ABF3]INTVALLNK(nolign-1) = "" : End : Endif
 If instr(1,VALEUR,",")
  GMESSAGE = ","-":"-mess(113,123,1) : # Cacarctère invalide
  mkstat = 2 : End
 Endif
 INTITULE = VALEUR
 [M:ABF3]INTVALLNK(nolign-1) = ""
Else
 If [M:ABF3]INTVALLNK(nolign-1) <> ""
  Onerrgo ERCALC
  INTITULE = evalue([M:ABF3]INTVALLNK(nolign-1))
  If ERN : Errbox mess(65,106,1)-":"-errmes$(ERN) : mkstat = 2 : End : Endif
  If instr(1,evalue([M:ABF3]INTVALLNK(nolign-1)),",")
   GMESSAGE = ","-":"-mess(113,123,1) : # Cacarctère invalide
   mkstat = 2 : End
  Endif
 Else
  GMESSAGE = "$"-":"-mess(113,123,1) : # Cacarctère invalide
  mkstat = 2 : End
 Endif
Endif
For I=0 To dim([M:ABF3]ZINTLNK)-1
 If I <> nolign-1
  If [M:ABF3]ZINTLNK(I) <> "$"
   If INTITULE = [M:ABF3]ZINTLNK(I)
    GMESSAGE = mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
    mkstat=2 : Break
   Endif
  Else
   If INTITULE = evalue([M:ABF3]INTVALLNK(I))
    GMESSAGE = mess(131,123,1)-":"-mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
    mkstat=2 : Break
   Endif
  Endif
 Endif
Next I
End

