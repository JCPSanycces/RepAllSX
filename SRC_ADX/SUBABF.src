Subprog B3_ZINTSSC(VALEUR)
Variable Char    VALEUR()
Local Integer NBLIB , NUMERO , I
Local Char    TBLIB(50)(0..[M]NBRFLD) , ZINTVAL(60)(1..[M]NBRFLD) ,  ZTEX(60)(1..[M]NBRFLD)
Local Char    TEXTE(80)
For I=0 To [M]NBRFLD-1
 If [M]ZINTSSC(I) <> ""
  If !find(func ABICREDES.TEXTEBI([M]INTSSC(I),[M]INTVALSSC(I),GLANGUE),TBLIB(1..NBLIB))
   NBLIB += 1
   ZINTVAL(NBLIB) = [M]INTVALSSC(I)
   ZTEX(NBLIB)    = [M]ZINTSSC(I)
   TBLIB(NBLIB) = func ABICREDES.TEXTEBI([M]INTSSC(I),[M]INTVALSSC(I),GLANGUE)
  Endif
 Endif
Next I
If NBLIB
 Call SAITEX(NBLIB,TBLIB,NUMERO,mess(18,100,1)) From GESECRAN : # Sélection
 If NUMERO
  VALEUR = ZTEX(NUMERO)
  [M]INTVALSSC(nolign-1) =    ZINTVAL(NBLIB)
 Endif
Endif
End

