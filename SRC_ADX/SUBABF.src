Subprog C_FLDDAT(VALEUR)
Variable Char    VALEUR()
If VALEUR ="" : End Endif
Local Integer I
I=find(VALEUR,[M:ABF2]CODFLD(0..[M:ABF2]NBRFLD-1))
If !I
 GMESSAGE = VALEUR-":"-mess(41,100,1) : # Champ inexistant
 mkstat = 2 : End
Endif
Read [F:ATY]CODTYP = [M:ABF2]CODTYP(I-1)
If !fstat
 If [F:ATY]TYPTYP<>8
  GMESSAGE = VALEUR-":"-mess(74,75,1) : # Ce champ n'est pas de type date
  mkstat = 2 : End
 Endif
Endif
End


