#<AdxTL>@(#)12.0.0.0 $Revision$
#########################################################################
# SUBPOHB : Gestion des commandes standards d'achat        MBT 28/01/98 #
#           ModifiĂŠ                                        HN Juil 2003 #
# --------------------------------------------------------------------- #
# Traitements complĂŠmentaires de l'objet "POH"                          #
# Les traitements sur champ "Call"     se trouvent dans le SUBPOH       #
# Les actions "Gosub" de l'objet "POH" se trouvent dans le SUBPOHA      #
#########################################################################

$ACTION
#---------------------------------------------------------------------#
# Actions sur la saisie de fenĂŞtre (GSAISIE)                          #
# VISUETAPOQ : Affichage situation ligne de commande                  #
# VISUETAPSH : Affichage des demandes d'achat d'une ligne de commande #
# SAIPECB1   : Prise en compte des besoins d'achat                    #
#---------------------------------------------------------------------#
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "TITRE"       : Gosub TITRE_FEN
 When "DEBUT"       : Gosub DEBUT
 When "OK"          : Gosub OK
 When "ABA"         : Gosub ABA
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SETBOUT"     : Gosub SETBOUT_FEN
 When "FINSAI"      : Gosub FINSAI
Endcase
Return

#######################################################################
# Actions sur la saisie de fenĂŞtre (GSAISIE)                          #
# ------------------------------------------------------------------- #
# VISUETAPOQ : Affichage situation ligne de commande                  #
# VISUETAPSH : Affichage des demandes d'achat d'une ligne de commande #
# SAIPECB1   : Prise en compte des besoins d'achat                    #
#######################################################################
#--------------------------------------------------------------#
# Avant la dĂŠfinition des boutons et l'ouverture de la fenĂŞtre #
#--------------------------------------------------------------#
$OUVRE
Case GACTION
 When "VISUETAPOQ" : Gosub OUV_VISUETAPOQ
 When "VISUETAPSH" : Gosub OUV_VISUETAPSH
 When "SAIPECB1"   : Gosub OUV_SAIPECB1
Endcase
Return
#-------------------------------------------#
# Titre juste avant ouverture de la fenĂŞtre #
#-------------------------------------------#
$TITRE_FEN
Case GACTION
 When "VISUETAPOQ" : TIT=mess(115,195,1)-NUMCDE-num$(LINCDE)
 When "VISUETAPSH" : TIT=mess(206,195,1)
 When "SAIPECB1"   : TIT=mess(42,195,1)
Endcase
Return
#---------------------------------#
# AprĂ¨s l'ouverture de la fenĂŞtre #
#---------------------------------#
$DEBUT
Case GACTION
 When "VISUETAPOQ" : Gosub DEB_VISUETAPOQ
 When "VISUETAPSH" : Gosub DEB_VISUETAPSH
 When "SAIPECB1"   : Gosub DEB_SAIPECB1
Endcase
Return
#--------------------------------#
# AprĂ¨s l'exĂŠcution du bouton OK #
#--------------------------------#
$OK
Case GACTION
 When "SAIPECB1"   : Gosub OK_SAIPECB1
Endcase
Return
#-------------------------------------#
# AprĂ¨s l'exĂŠcution du bouton ABANDON #
#-------------------------------------#
$ABA
Case GACTION
 When "SAIPECB1"   : Gosub ABA_SAIPECB1
Endcase
Return
#------------------------------------#
# AprĂ¨s chaque modification de champ #
#------------------------------------#
$APRES_MODIF
Case GACTION
 When "SAIPECB1"   : REP="M"
Endcase
Return
#-------------------------------#
# Grisage/dĂŠgrisage des boutons #
#-------------------------------#
$SETBOUT_FEN
Case GACTION
 When "SAIPECB1"   : Gosub SETB_SAIPECB1
Endcase
Return
#------------------------------------------#
# Avant de revenir Ă  la fenĂŞtre prĂŠcĂŠdente #
#------------------------------------------#
$FINSAI
Case GACTION
 When "VISUETAPOQ" : Gosub FINSAI_VISUETAPOQ
 When "VISUETAPSH" : Gosub FINSAI_VISUETAPSH
 When "SAIPECB1"   : Gosub FINSAI_SAIPECB1
Endcase
Return

#VPO 09/12/10 17667 maj qte sur une DA
$MAJ_PREQUISQTE
#--------------------------------------------------------------------#
# Mise Ă  jour des demandes d'achats aprĂ¨s modif qte / ligne commande #
#--------------------------------------------------------------------#
If [F:POQ]RETQTYPUU=0 & [F:POQ]RETQTYSTU=0 Return : Endif
If [F:POQ]SOHNUM<>"" Return : Endif
Local Char CLEFIC(35), SYMBOL2(30)

If clalev([M:POD1])>0
  GBIDD1= [F:POQ]QTYPUU
  GBIDD2= [F:POQ]QTYSTU
Else
  GBIDD1= [M:POH2]QTYPUU(nolign-1)
  GBIDD2= [M:POH2]QTYSTU(nolign-1)
Endif

Gosub MAJ_LIG_DAQTE

If SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
If GOK<1  Return : Endif

If clalev([M:POD1])>0
  [M:POD1]RETQTYPUU(nolign-1)=[F:PSO]QTYPUU
Else
  [M:POH2]RETQTYSTU(nolign-1)=[F:PSO]QTYSTU
Endif
[F:POQ]RETQTYSTU=[F:PSO]QTYSTU
[F:POQ]RETQTYPUU=[F:PSO]QTYPUU
Return


#VPO 09/12/10 17667 maj qte sur une DA
#---------------------------------------------------------------------------#
# Mise Ă  jour d'une ligne demande d'achats aprĂ¨s modif qte / ligne commande #
#---------------------------------------------------------------------------#
# Remarque : GBIDD1 = QuantitĂŠ en PUU                                       #
# Remarque : GBIDD2 = QuantitĂŠ en STU                                       #
#---------------------------------------------------------------------------#
$MAJ_LIG_DAQTE
#----- Lecture du fichier lien commande-demande -----#
# ici on a une seule ligne dans PREQUISO [PSO]
CLEFIC=[F:POQ]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)
Readlock [PSO]PSO1=[F:POQ]POHNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ
If fstat=1
  GOK=-1 : GLOCK="$PREQUISO"-CLEFIC            : Return
Elsif fstat
  GOK=0  : Call RSTA("PSO",CLEFIC) From GLOCK : Return
Endif
#----- Lecture avec blocage de l'entĂŞte demande -----#
CLEFIC=[F:PSO]PSHNUM
SYMBOL2="PSH"+[F:PSO]PSHNUM : Lock=SYMBOL2
If fstat
  GMESSAGE="$PREQUIS"-CLEFIC-mess(10,100,1) : GERR=1 : GOK=0 : Raz SYMBOL2 : Return
Endif
Readlock [PSH] PSH0=[F:PSO]PSHNUM
If fstat=1
  GOK=-1 : GLOCK="$PREQUIS"-CLEFIC            : Return
Elsif fstat
  GOK=0  : Call RSTA("PSH",CLEFIC) From GLOCK : Return
Endif
#----- Lecture avec blocage de la ligne demande -----#
CLEFIC=[F:PSO]PSHNUM-num$([F:PSO]PSDLIN)
Readlock [PSD] PSD0=[F:PSO]PSHNUM;[F:PSO]PSDLIN
If fstat=1
  GOK=-1 : GLOCK="$PREQUISD"-CLEFIC           : Return
Elsif fstat
  GOK=0  : Call RSTA("PSD",CLEFIC) From GLOCK : Return
Endif
#-----

#----- MĂ j quantitĂŠs commandĂŠes -----#
If GBIDD1<=([F:PSD]QTYPUU-[F:PSD]ORDQTYPUU)
  [F:PSO]QTYSTU=GBIDD2
  [F:PSO]QTYPUU=GBIDD1
Else
  #on prend au max ce qu'il reste Ă  commander
  [F:PSO]QTYSTU=min(GBIDD2,[F:PSD]QTYSTU-[F:PSD]ORDQTYSTU)
  [F:PSO]QTYPUU=min(GBIDD1,[F:PSD]QTYPUU-[F:PSD]ORDQTYPUU)
Endif
# Issue 103475 - 2014-10-23 by SR : PUU et STU ĂŠtaient mĂŠlangĂŠs
#[F:PSD]ORDQTYPUU+=[F:PSO]QTYSTU
#[F:PSD]ORDQTYSTU+=[F:PSO]QTYPUU
[F:PSD]ORDQTYPUU+=[F:PSO]QTYPUU
[F:PSD]ORDQTYSTU+=[F:PSO]QTYSTU
# End issue 103475
#----- MĂ j indicateurs solde, commande -----#
If [F:PSD]QTYSTU<=[F:PSD]ORDQTYSTU
  If [F:PSD]LINCLEFLG<>2  [F:PSD]LINCLEFLG=2 : [F:PSH]CLELINNBR+=1 : Endif
  If [F:PSD]LINORDFLG<>2  [F:PSD]LINORDFLG=2 : [F:PSH]ORDLINNBR+=1 : Endif
Else
  If [F:PSD]LINCLEFLG=2 [F:PSH]CLELINNBR-=1 : [F:PSD]LINCLEFLG=1 : Endif
  If [F:PSD]LINORDFLG=2 [F:PSH]ORDLINNBR-=1 : [F:PSD]LINORDFLG=1 : Endif
Endif

#----- RĂŠĂŠcriture lien ligne demande-ligne commande -----#
Rewrite [PSO]
If fstat  GOK=0 : Call FSTA("PSO") From GLOCK : Return : Endif

#----- Sauvegarde des nombres de lignes ĂŠcrasĂŠs par piĂ¨ce auto PQUIS (Call TRTMAJCMM) -----#
If dim([L]WCLELINNBR)<1  Local Shortint WCLELINNBR : Endif
If dim([L]WORDLINNBR)<1  Local Shortint WORDLINNBR : Endif
[L]WCLELINNBR=[F:PSH]CLELINNBR
[L]WORDLINNBR=[F:PSH]ORDLINNBR
#-------------Supp du PrĂŠ-engagement pour la qtĂŠ besoin ----------------------#
Call TRTMAJCMM([F:PSD]PSHNUM,[F:PSD]PSDLIN,0,-1,1,"PSD4",2,GBIDI1) From TRTACHDIV1
If GOK<1 Return : Endif
#----- Restauration des nombres de lignes -----#
[F:PSH]CLELINNBR=[L]WCLELINNBR
[F:PSH]ORDLINNBR=[L]WORDLINNBR

#-----------------------------------
#on doit ecrire PSD apres TRTMAJCMM
#----- RĂŠĂŠcriture ligne demande -----#
Rewrite [PSD]
If fstat  GOK=0 : Call FSTA("PSD") From GLOCK : Return : Endif

#----- MĂ j indicateurs commande et solde -----#
If [F:PSH]ORDLINNBR<[F:PSH]LINNBR [F:PSH]ORDFLG=1 Else [F:PSH]ORDFLG=2 : Endif
If [F:PSH]CLELINNBR<[F:PSH]LINNBR [F:PSH]CLEFLG=1 Else [F:PSH]CLEFLG=2 : Endif
#----- RĂŠĂŠcriture entĂŞte demande -----#
Rewrite [PSH]
If fstat  GOK=0 : Call FSTA("PSH") From GLOCK : Return : Endif
Unlock=SYMBOL2 : Raz SYMBOL2
#----- Mise Ă  jour ordre POP correspondant Ă  la ligne DA -----#
Gosub MAJ_POP
Return


$MAJ_PREQUIS
#--------------------------------------------------------------------#
# Mise Ă  jour des demandes d'achats aprĂ¨s suppression ligne commande #
# ou aprĂ¨s modification de la commande (qtĂŠ)                         #
#--------------------------------------------------------------------#
If [F:POQ]RETQTYPUU=0 & [F:POQ]RETQTYSTU=0 Return : Endif
If [F:POQ]SOHNUM<>"" Return : Endif
Local Char CLEFIC(35), SYMBOL2(30)
#----- Lecture du fichier lien commande-demande -----#
For [PSO]PSO1 Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POQSEQ=[F:POQ]POQSEQ
  Gosub MAJ_LIGNE_DA : If GOK<1  Break : Endif
Next
If SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
If GOK<1  Return : Endif

#----- Si modif, on sort -----#
#VPO 09/12/10 17667 maj qte sur une DA
If TRTLIG="M" : Return : Endif

#----- Suppression des enregistrements lien -----#
CLEFIC=[F:POQ]POHNUM-num$([F:POQ]POPLIN)
Delete [PSO] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POQSEQ=[F:POQ]POQSEQ
If fstat=1
  GOK=-1 : GLOCK="$PREQUISO"-CLEFIC           : Return
Elsif fstat
  GOK=0  : Call RSTA("PSO",CLEFIC) From GLOCK : Return
Endif
Return

$MAJ_LIGNE_DA
#---------------------------------------------------------------------------#
# Mise Ă  jour d'une ligne demande d'achats aprĂ¨s suppression ligne commande #
#---------------------------------------------------------------------------#
#----- Lecture avec blocage de l'entĂŞte demande -----#
CLEFIC=[F:PSO]PSHNUM
SYMBOL2="PSH"+[F:PSO]PSHNUM : Lock=SYMBOL2
If fstat
  GMESSAGE="$PREQUIS"-CLEFIC-mess(10,100,1) : GERR=1 : GOK=0 : Raz SYMBOL2 : Return
Endif
Readlock [PSH] PSH0=[F:PSO]PSHNUM
If fstat=1
  GOK=-1 : GLOCK="$PREQUIS"-CLEFIC            : Return
Elsif fstat
  GOK=0  : Call RSTA("PSH",CLEFIC) From GLOCK : Return
Endif
#----- Lecture avec blocage de la ligne demande -----#
CLEFIC=[F:PSO]PSHNUM-num$([F:PSO]PSDLIN)
Readlock [PSD] PSD0=[F:PSO]PSHNUM;[F:PSO]PSDLIN
If fstat=1
  GOK=-1 : GLOCK="$PREQUISD"-CLEFIC           : Return
Elsif fstat
  GOK=0  : Call RSTA("PSD",CLEFIC) From GLOCK : Return
Endif
#-----
If dim([L]WSOLDPSH)<1  Local Libelle WSOLDPSH : Endif
[L]WSOLDPSH=1
#----- MĂ j quantitĂŠs commandĂŠes et indicateurs solde, commande -----#
[F:PSD]ORDQTYPUU-=[F:PSO]QTYPUU : [F:PSD]ORDQTYSTU-=[F:PSO]QTYSTU
If [F:PSD]LINCLEFLG=2 [F:PSH]CLELINNBR-=1 : [F:PSD]LINCLEFLG=1 : [L]WSOLDPSH=2 : Endif
If [F:PSD]LINORDFLG=2 [F:PSH]ORDLINNBR-=1 : [F:PSD]LINORDFLG=1 : Endif
#----- RĂŠĂŠcriture ligne demande -----#
Rewrite [PSD]
If fstat  GOK=0 : Call FSTA("PSD") From GLOCK : Return : Endif
#----- Si dĂŠsolde d'un reliquat, rĂŠajustement des qtĂŠs pour prĂŠ-engagement -----#
If [L]WSOLDPSH=2 & [F:PSO]QTYSTU<[F:PSD]QTYSTU-[F:PSD]ORDQTYSTU
  [F:PSO]QTYSTU=[F:PSD]QTYSTU-[F:PSD]ORDQTYSTU
  [F:PSO]QTYPUU=[F:PSD]QTYPUU-[F:PSD]ORDQTYPUU
Endif
#----- Sauvegarde des nombres de lignes ĂŠcrasĂŠs par piĂ¨ce auto PQUIS (Call TRTMAJCMM) -----#
If dim([L]WCLELINNBR)<1  Local Shortint WCLELINNBR : Endif
If dim([L]WORDLINNBR)<1  Local Shortint WORDLINNBR : Endif
[L]WCLELINNBR=[F:PSH]CLELINNBR
[L]WORDLINNBR=[F:PSH]ORDLINNBR
#-----
#VPO 09/12/10 17667 maj qte sur une DA
If TRTLIG="M"
  #-------------On refait le PrĂŠ-engagement de la qtĂŠ besoin ----------------------#
  Call TRTMAJCMM([F:PSD]PSHNUM,[F:PSD]PSDLIN,0,+1,1,"PSD4",3,STAT) From TRTACHDIV1
Else
  Call TRTMAJCMM([F:PSD]PSHNUM,[F:PSD]PSDLIN,0,+1,1,"PSD3",2,GBIDI1) From TRTACHDIV1
Endif
If GOK<1  Return : Endif
#----- Restauration des nombres de lignes -----#
[F:PSH]CLELINNBR=[L]WCLELINNBR
[F:PSH]ORDLINNBR=[L]WORDLINNBR

# Issue 78807 - 2011-12-20 by VPO : pb sur pre-engagement
#on doit ecrire PSD apres TRTMAJCMM
#----- RĂŠĂŠcriture ligne demande -----#
Rewrite [PSD]
If fstat  GOK=0 : Call FSTA("PSD") From GLOCK : Return : Endif

#----- MĂ j indicateurs commande et solde -----#
If [F:PSH]ORDLINNBR<[F:PSH]LINNBR [F:PSH]ORDFLG=1 Else [F:PSH]ORDFLG=2 : Endif
If [F:PSH]CLELINNBR<[F:PSH]LINNBR [F:PSH]CLEFLG=1 Else [F:PSH]CLEFLG=2 : Endif
#----- RĂŠĂŠcriture entĂŞte demande -----#
Rewrite [PSH]
If fstat  GOK=0 : Call FSTA("PSH") From GLOCK : Return : Endif
Unlock=SYMBOL2 : Raz SYMBOL2
#----- Mise Ă  jour ordre POP correspondant Ă  la ligne DA -----#
Gosub MAJ_POP
Return

$MAJ_POP
#----- Mise Ă  jour ordre POP correspondant Ă  la ligne DA -----#
If [F:PSD]WIPNUM<>""
  Raz [M:ORDK]
  Read [ORD] ORD0=2;[F:PSD]WIPNUM;[F:PSD]ITMREF
  If fstat  Raz [F:ORD] : Endif
  [M:ORDK]          = [F:ORD]
  [M:ORDK]MAJCOD    = "M"
  [M:ORDK]WIPTYP    = 2
  [M:ORDK]WIPSTA    = 2
  [M:ORDK]WIPNUM    = [F:PSD]WIPNUM
  [M:ORDK]ITMREF    = [F:PSD]ITMREF
  [M:ORDK]STOFCY    = [F:PSD]PRHFCY
  [M:ORDK]PJT       = [F:PSD]PJT
  [M:ORDK]BPRNUM    = [F:PSD]BPSNUM
  [M:ORDK]STRDAT    = [F:PSD]EXTORDDAT
  [M:ORDK]ENDDAT    = [F:PSD]EXTRCPDAT
  [M:ORDK]VCRTYP    = 14
  [M:ORDK]VCRNUM    = [F:PSD]PSHNUM
  [M:ORDK]VCRLIN    = [F:PSD]PSDLIN
  [M:ORDK]VCRSEQ    = 0
  [M:ORDK]EXTQTY    = [F:PSD]QTYSTU-[F:PSD]ORDQTYSTU
  [M:ORDK]CPLQTY    = 0
  [M:ORDK]ALLQTY    = 0
  [M:ORDK]SHTQTY    = 0
  [M:ORDK]FMI       = 1
  [M:ORDK]MRPMES    = 1
  # Issue 71276 - 2015-02-27 by SR : Versions
  If dim([M:ORDK]ECCVALMAJ)> 0
   [M:ORDK]ECCVALMAJ = [F:PSD]ECCVALMAJ
   [M:ORDK]ECCVALMIN = [F:PSD]ECCVALMIN
  Endif
  # End issue 71276
  #----- Chargement infos origine si erreur lecture sur l'ordre Ă  modifier -----#
  If [F:ORD]WIPNUM=""
    [M:ORDK]ORIFCY    = [F:PSD]PSHFCY
    [M:ORDK]VCRTYPORI = 0
    [M:ORDK]VCRNUMORI = ""
    [M:ORDK]VCRLINORI = 0
    [M:ORDK]VCRSEQORI = 0
  Endif
  #-----
  [M:ORDK]BOMALT    = 0
  [M:ORDK]ORI       = 1
  [M:ORDK]ABBFIL    = "PSD"
  Call WIP From TRTWIP : If GOK<1  Return : Endif
Endif
Return

$MAJ_SORDERQ
#-----------------------------------------------------------------------#
# MISE Ă  JOUR LIGNE COMMANDE VENTE APRĂ¨S SUPPRESSION LIGNE CONTREMARQUE #
#-----------------------------------------------------------------------#
If [F:POQ]SOHNUM="" Return : Endif
Lock="SOH"+[F:POQ]SOHNUM
If fstat
  GMESSAGE="$SORDER"-[F:POQ]SOHNUM-mess(10,100,1) : GERR=1 : GOK=0 : Return
Endif
Local File SORDERQ [SOQ]
Update [SOQ] Where SOHNUM=[F:POQ]SOHNUM & SOPLIN=[F:POQ]SOPLIN & SOQSEQ=[F:POQ]SOQSEQ
&            With FMINUM="", FMILIN=0, FMISEQ=0
If fstat & fstat<>4 GOK=0 : Call FSTA("SOQ") From GLOCK : Endif
Unlock="SOH"+[F:POQ]SOHNUM
Close Local File [SOQ]
Default File [POP]
Return

$LECT_FICLIG
#--------------------------------------------------------------------#
# LECTURE DES FICHIERS ASSOCIĂŠS Ă  LA LIGNE POUR UTILISATION DANS MĂ J #
#   - BPARTNER   [BPR] : Business Partner                            #
#   - BPSUPPLIER [BPS] : Fournisseurs                                #
#   - ITMMASTER  [ITM] : ARTICLES                                    #
#   - ITMBPS     [ITP] : ARTICLES-FOURNISSEURS                       #
#   - FACILITY   [FCY] : SITES DE RĂŠCEPTION                          #
#   - ITMFACILIT [ITF] : ARTICLES-SITES                              #
#--------------------------------------------------------------------#
If [F:BPR]BPRNUM<>[F:POH]BPSNUM
   Read [BPR] BPR0=[F:POH]BPSNUM
   If fstat Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[F:POH]BPSNUM
   Read [BPS] BPS0=[F:POH]BPSNUM
   If fstat Raz [F:BPS] : Endif
Endif
If [F:ITM]ITMREF<>[F:POP]ITMREF
   Read [ITM] ITM0=[F:POP]ITMREF
   If fstat Raz [F:ITM] : Endif
Endif
If [F:ITP]ITMREF<>[F:POP]ITMREF | [F:ITP]BPSNUM<>[F:POH]BPSNUM
   Read [ITP] ITP0=[F:POP]ITMREF;[F:POH]BPSNUM
   If fstat Raz [F:ITP] : Endif
Endif
If [F:FCY]FCY<>[F:POP]PRHFCY
   Read [FCY] FCY0=[F:POP]PRHFCY
   If fstat Raz [F:FCY] : Endif
Endif
If [F:ITF]ITMREF<>[F:POP]ITMREF | [F:ITF]STOFCY<>[F:POP]PRHFCY
   Read [ITF] ITF0=[F:POP]ITMREF;[F:POP]PRHFCY
   If fstat Raz [F:ITF] : Endif
Endif
Return

$CTL_QTYUOM
#---------------------------------------------------------------------#
# ContrĂ´le sur quantitĂŠ en UC : Calcul et contrĂ´le quantitĂŠs UA et US #
#---------------------------------------------------------------------#
Local Decimal  QTEUC, QTEUA, QTEUS, WCOEF, SAV_QTEUA
Local Shortint NOL : NOL=nolign-1
#----- Relecture article si nĂŠcessaire -----#
If [F:ITM]ITMREF<>[M:POH2]ITMREF(NOL)
  Read [ITM] ITM0=[M:POH2]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
Endif
#-----
If [M:POH2]UOM(NOL)=[M:POH2]STU(NOL)
  Call PCAL_QTY(VALEUR,[M:POH2]UOM(NOL),GBIDD1,[M:POH2]PUU(NOL),
&             [M:POH2]ITMREF(NOL),[M:POH0]BPSNUM,3,WCOEF) From TRTACHQTE1
  QTEUA=VALEUR*WCOEF
  WCOEF=arr(WCOEF,0.000001)
Else
  QTEUA=VALEUR*[M:POH2]UOMPUUCOE(NOL)
  WCOEF=[M:POH2]UOMPUUCOE(NOL)
Endif
SAV_QTEUA=QTEUA
Gosub POINT_PURQTYRND From SUBPOHB
Call PCAL_QTY(QTEUA,[M:POH2]PUU(NOL),QTEUS,[M:POH2]STU(NOL),
&             [M:POH2]ITMREF(NOL),[M:POH0]BPSNUM,1,GBIDD1) From TRTACHQTE1
If [M:POH2]UOM(NOL)=[M:POH2]STU(NOL)
  If QTEUS<[M:POH2]RETQTYSTU(NOL)

    # Issue 80414 - 2012-03-05 by VPO : ctl qtĂŠ min de commande
    #----- Pas de contrĂ´le qtĂŠ minimum si migration IntĂŠgrale -----#
    If !(clalev([F:XEPA]) & clalev([F:XLPA]) )
        #-----
        # Issue 112754 - 2016-11-28 by SR : Services
        If QTEUA<[M:POH2]PURMINQTY(NOL) |
&         (QTEUS<>[M:POH2]RETQTYSTU(NOL) & [M:POH2]ITMKND(NOL)<>2 & [F:ITM]SCPFLG<>2)
           GBIDD1=QTEUA : GBIDD2=QTEUS
           Call MESSAGE_QTE(2,NOL) From SUBPOHB
           If mkstat : Return : Endif
        Endif
    Endif

    QTEARR=arr(SAV_QTEUA,10^-WNBDEC)
    If QTEARR>=SAV_QTEUA-10^-(WNBDEC+3)
      QTEUA=QTEARR
    Else
      QTEUA=QTEARR+10^-WNBDEC
    Endif
    Call PCAL_QTY(QTEUA,[M:POH2]PUU(NOL),QTEUS,[M:POH2]STU(NOL),
&                 [M:POH2]ITMREF(NOL),[M:POH0]BPSNUM,1,GBIDD1) From TRTACHQTE1
  Endif
  QTEUC=QTEUS
  If [M:POH2]COEFLG(NOL)=0 & QTEUC<>0
    WCOEF=max(arr(QTEUA/QTEUC,0.000001),0.000001)
  Endif
Else
  QTEUC=VALEUR
  WCOEF=[M:POH2]UOMPUUCOE(NOL)
Endif
#sr 09.11 demande 75936 : Ne pas commander moins que la qtĂŠ dĂŠjĂ  facturĂŠe
If [M:POH2]INVQTYSTU(NOL) <> 0 & QTEUS < [M:POH2]INVQTYSTU(NOL)
    GMESSAGE = mess(422,194,1) - ":" - num$([M:POH2]INVQTYSTU(NOL))
    mkstat   = 1
    GERR     = 1
    Return
Endif
#----- Pas de contrĂ´le qtĂŠ minimum si migration IntĂŠgrale -----#
If clalev([F:XEPA]) & clalev([F:XLPA])  Return : Endif
#-----
#VPO 09/12/10 17667 maj qte sur une DA
#& (QTEUS<[M:POH2]RETQTYSTU(NOL) & [F:ITM]SCSFLG<>2 & [F:ITM]SCPFLG<>2)
# Issue 112754 - 2016-11-28 by SR : Services
#& (QTEUS<>[M:POH2]RETQTYSTU(NOL) & [F:ITM]SCSFLG<>2 & [F:ITM]SCPFLG<>2)
If QTEUA<[M:POH2]PURMINQTY(NOL) |
& (QTEUS<>[M:POH2]RETQTYSTU(NOL) & [M:POH2]ITMKND(NOL)<>2 & [F:ITM]SCPFLG<>2)
   GBIDD1=QTEUA : GBIDD2=QTEUS
   Call MESSAGE_QTE(2,NOL) From SUBPOHB
Endif
Return


$ECLATE_LIG_POH2
#--------------------------------------------------#
# Eclatement ligne : AppelĂŠ Ă  partir du TRTACHCDE1 #
#--------------------------------------------------#
Call TEMPON("O") From GESECRAN
Local File PWRKORDERS [PW2]
Default Mask [POH2]
If NOL+1<[M:POH2]NBLIG &
&  [M:POH2]POPLIN(NOL)+[M:PSQ1]NBLIG>=[M:POH2]POPLIN(NOL+1)
      GMESSAGE=mess(72,194,1) : GERR=1 : Return : Endif
status=73 : nolign=NOL+1 : RETQTY=[M:POH2]RETQTYSTU(NOL)
Insa NOL+1,[M:PSQ1]NBLIG,[M:POH2]NBLIG+[M:PSQ1]NBLIG-1 [M:POH2]NBLIG
[M:POH2]NBLIG+=[M:PSQ1]NBLIG
# Issue 100120 - 2012-12-12 by MUARN : poids et volume
Local    Decimal  WOLDQTYSTU

For I=1 To [M:PSQ1]NBLIG
    J=NOL+I : nolign=J+1 : L=NOL : Gosub COPIE_LIG From SUBPOHA
    # Issue 92258 - 2013-09-04 by MUARN : garder les sections ana de la ligne d'origine
    #If dim([M:POH2]CCE1) >0  Raz [M:POH2]CCE1  (J) : Endif
    #If dim([M:POH2]CCE2) >0  Raz [M:POH2]CCE2  (J) : Endif
    #If dim([M:POH2]CCE3) >0  Raz [M:POH2]CCE3  (J) : Endif
    #If dim([M:POH2]CCE4) >0  Raz [M:POH2]CCE4  (J) : Endif
    #If dim([M:POH2]CCE5) >0  Raz [M:POH2]CCE5  (J) : Endif
    #If dim([M:POH2]CCE6) >0  Raz [M:POH2]CCE6  (J) : Endif
    #If dim([M:POH2]CCE7) >0  Raz [M:POH2]CCE7  (J) : Endif
    #If dim([M:POH2]CCE8) >0  Raz [M:POH2]CCE8  (J) : Endif
    #If dim([M:POH2]CCE9) >0  Raz [M:POH2]CCE9  (J) : Endif
    #If dim([M:POH2]CCE10)>0  Raz [M:POH2]CCE10 (J) : Endif
    #If dim([M:POH2]CCE11)>0  Raz [M:POH2]CCE11 (J) : Endif
    #If dim([M:POH2]CCE12)>0  Raz [M:POH2]CCE12 (J) : Endif
    #If dim([M:POH2]CCE13)>0  Raz [M:POH2]CCE13 (J) : Endif
    #If dim([M:POH2]CCE14)>0  Raz [M:POH2]CCE14 (J) : Endif
    #If dim([M:POH2]CCE15)>0  Raz [M:POH2]CCE15 (J) : Endif
    #If dim([M:POH2]CCE16)>0  Raz [M:POH2]CCE16 (J) : Endif
    #If dim([M:POH2]CCE17)>0  Raz [M:POH2]CCE17 (J) : Endif
    #If dim([M:POH2]CCE18)>0  Raz [M:POH2]CCE18 (J) : Endif
    #If dim([M:POH2]CCE19)>0  Raz [M:POH2]CCE19 (J) : Endif
    #If dim([M:POH2]CCE20)>0  Raz [M:POH2]CCE20 (J) : Endif
#----- Chargement des nouvelles valeurs de la ligne -----#
    [M:POH2]PRHFCY(J)    = [M:PSQ1]PRHFCY(I-1)
    [M:POH2]FCYADD(J)    = [M:PSQ1]FCYADD(I-1)
    [M:POH2]EXTRCPDAT(J) = [M:PSQ1]EXTRCPDAT(I-1)
#----- Chargement des quantitĂŠs -----#
    Case [M:PSQ1]QTYFLG
      When 1 : [M:POH2]QTYUOM(J)=[M:PSQ1]QTY(I-1)
               [M:POH2]QTYPUU(J)=[M:POH2]QTYUOM(J)*[M:POH2]UOMPUUCOE(J)
               # Issue 100120 - 2014-05-19 by MUARN : poids et volume
               WOLDQTYSTU = [M:POH2]QTYSTU(NOL)
               Call QTEARR([M:POH2]QTYPUU(J),[M:POH2]PUU(J)) From TRTDIV
               Call PCAL_QTY([M:POH2]QTYPUU(J),[M:POH2]PUU(J),
&                            [M:POH2]QTYSTU(J),[M:POH2]STU(J),
&                            [M:POH2]ITMREF(J),[M:POH0]BPSNUM,1,GBIDD1) From TRTACHQTE1
      When 2 : [M:POH2]QTYPUU(J)=[M:PSQ1]QTY(I-1)
               [M:POH2]QTYUOM(J)=[M:POH2]QTYPUU(J)*(1/[M:POH2]UOMPUUCOE(J))
               # Issue 100120 - 2014-05-19 by MUARN : poids et volume
               WOLDQTYSTU = [M:POH2]QTYSTU(NOL)
               Call QTEARR([M:POH2]QTYUOM(J),[M:POH2]UOM(J)) From TRTDIV
               Call PCAL_QTY([M:POH2]QTYPUU(J),[M:POH2]PUU(J),
&                            [M:POH2]QTYSTU(J),[M:POH2]STU(J),
&                            [M:POH2]ITMREF(J),[M:POH0]BPSNUM,1,GBIDD1) From TRTACHQTE1
      When 3 : WOLDQTYSTU = [M:POH2]QTYSTU(NOL) # Issue 100120 - 2014-05-19 by MUARN : poids et volume
               [M:POH2]QTYSTU(J)=[M:PSQ1]QTY(I-1)
               Call PCAL_QTY([M:POH2]QTYSTU(J),[M:POH2]STU(J),
&                            [M:POH2]QTYPUU(J),[M:POH2]PUU(J),
&                            [M:POH2]ITMREF(J),[M:POH0]BPSNUM,1,GBIDD1) From TRTACHQTE1
               [M:POH2]QTYUOM(J)=[M:POH2]QTYPUU(J)*(1/[M:POH2]UOMPUUCOE(J))
               Call QTEARR([M:POH2]QTYUOM(J),[M:POH2]UOM(J)) From TRTDIV
    Endcase
    # Issue 100120 - 2014-05-19 by MUARN : poids et volume
    Call CONVERT_VOUWEU("POH2",J,[M:POH2]LINWEU(J),[M:POH2]LINVOU(J),[M:POH2]QTYSTU(J),WOLDQTYSTU) From STCLIB
    If RETQTY>[M:POH2]QTYSTU(J) [M:POH2]RETQTYSTU(J)=[M:POH2]QTYSTU(J)
                                RETQTY-=[M:POH2]QTYSTU(J)
                           Else [M:POH2]RETQTYSTU(J)=RETQTY
                                Raz RETQTY : Endif
#----- Mise Ă  jour fichier de travail picking des "POS","POP","TRS","TRP" & "SCF" -----#
    If [M:POH2]RETQTYSTU(J)<>0 & [M:POH2]SOHNUM(J)="" Gosub ECLATE_PWO : Endif
#----- Chargement numĂŠro d'appel d'offre sur 1Ă¨re ligne uniquement -----#
    If I=1 [M:POH2]PQHNUM(J) = [M:POH2]PQHNUM(NOL)
           [M:POH2]PPDLIN(J) = [M:POH2]PPDLIN(NOL)
    Else Raz [M:POH2]PQHNUM(J),[M:POH2]PPDLIN(J) : Endif
#-----
    status=0 : Call LINNUM("POPLIN") From TABLEAUX
    Call APRES_NBLIG From SUBPOH
Next I
#----- Affichage pour initialisation des sections analytique Ă  cause du Dela -----#
Affzo [POH2]5
#----- Suppression du texte associĂŠ Ă  la ligne d'origine -----#
If [M:POH2]CREFLG(NOL)=0 & left$([M:POH2]LINTEX(NOL),3)="POQ"
  Call SUP_CLOB([M:POH2]LINTEX(NOL),GBIDI1) From TRTX3TEX
Endif
#----- Suppression de la ligne d'origine -----#
status=65 : nolign=NOL+1 : Call AVANT_NBLIG From SUBPOH
Dela NOL,1,[M:POH2]NBLIG-1 [M:POH2]NBLIG : [M:POH2]NBLIG-=1
Call TEMPOFF From GESECRAN
Close Local File [PW2]
Affzo [POH2]5-15
Return

$RECALCUL_TARLIG
#---------------------------------------------------------#
# Recalcul tarif ligne : Prix, remises et dates livraison #
# GPLIFLG=0 Rien                                          #
#        =1 Conversion ligne      si OLDCUR<>CUR          #
#           Taxes et calcul TTC   si GVACFLG=1            #
#           Date livraison prĂŠvue si GDATFLG=1            #
#        =2 Recherche tarif                               #
#---------------------------------------------------------#
If GPLIFLG=0 | [M:POH2]NBLIG=0 : Goto FIN_RECALCUL_TARLIG : Endif
Local Decimal  MT1, MT2, DISCRGVAL(0..8)
Local Integer  STAT
Local Shortint I, J, CURFLG
Local    Decimal  WCPRAMT # Issue 70985 - 2012-04-03 by MUARN : landed cost
Local    Integer  WSTAT   # Issue 70985 - 2012-04-03 by MUARN : landed cost

If GPLIFLG=1
  If [M:POH0]OLDCUR<>"" & [M:POH0]OLDCUR<>[M:POH1]CUR : I=1 : CURFLG=1 : Endif
  If GVACFLG=1 | GDATFLG=1  I=1 : Endif
Endif
If GPLIFLG=1 & I=0  Goto FIN_RECALCUL_TARLIG : Endif
Local Date     OLDRCPDAT
Local Decimal  OLDNETPRI
Local Libelle  OLDVACTYP
Local Libelle  NEWVACTYP          : NEWVACTYP=[M:POH1]VACTYP
Local Char     NEWVACBPR(GLONTVB) : NEWVACBPR=[M:POH1]VACBPR
Local Char     WVAT(GLONVAT)
#-----
# 71937 : MultilĂŠgislation
#If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>[M:POH0]OLDVACBPR
#  Read [ADI] CODE=1;[M:POH0]OLDVACBPR : If fstat  Raz [F:ADI] : Endif
#Endif
#OLDVACTYP=[F:ADI]N1
If !clalev([F:TVB]) Local File TABVACBPR [TVB] Endif
Local Integer GRET
Call LEC_TVB_LEG(GCURLEG,[M:POH0]OLDVACBPR,GRET) From TRTLECLEG
If GRET Raz [F:TVB] : Endif
OLDVACTYP=[F:TVB]REGVAC
# 71937 : MultilĂŠgislation

#-----
For I=0 To [M:POH2]NBLIG-1
  OLDRCPDAT=[M:POH2]RETRCPDAT(I) : OLDNETPRI=[M:POH2]NETPRI(I)
  #----- Lecture article maitre -----#
  If [F:ITM]ITMREF<>[M:POH2]ITMREF(I)
    Read [ITM] ITM0=[M:POH2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
  Endif
  #-----
  [M:POH1]VACBPR=[M:POH0]OLDVACBPR
  [M:POH1]VACTYP=OLDVACTYP
  #-----
  Call MAJ_CUMULS_LIG(I,-2) From SUBPOHC
  Call MAJ_BASTAX_LIG(I,-1) From SUBPOHC
  #-----
  [M:POH1]VACBPR=NEWVACBPR
  [M:POH1]VACTYP=NEWVACTYP
  #----- Recalcul date rĂŠception si aucun picking & date cde modifiĂŠe -----#
  If ([M:POH2]RETQTYSTU(I)=0 | [M:POH2]SOHNUM(I)<>"") & GDATFLG=1 & [M:POH2]LINTYP(I)<2
    If [F:ITF]ITMREF<>[M:POH2]ITMREF(I) | [F:ITF]STOFCY<>[M:POH2]PRHFCY(I)
      Read [ITF] ITF0=[M:POH2]ITMREF(I);[M:POH2]PRHFCY(I)
      If fstat Raz [F:ITF] : [F:ITF]OFS=[F:ITM]OFS : Endif
    Endif
    [M:POH2]RETRCPDAT(I)=[M:POH0]ORDDAT+[M:POH2]OFS(I)
    If [F:FCY]FCY<>[M:POH2]PRHFCY(I)
      Read [FCY] FCY0=[M:POH2]PRHFCY(I) : If fstat Raz [F:FCY] : Endif
    Endif
    Call CTL_JOU2([M:POH2]RETRCPDAT(I),[M:POH0]ORDDAT,[M:POH2]OFS(I)) From TRTACHCDE1
    Raz mkstat, GMESSAGE
  Endif
  #----- Date de rĂŠception thĂŠorique pas infĂŠrieure Ă  la date cde -----#
  If [M:POH2]RETRCPDAT(I)<[M:POH0]ORDDAT
    [M:POH2]RETRCPDAT(I)=[M:POH0]ORDDAT
  Endif
  #----- Pas de prix sur une ligne d'article sous-traitĂŠ -----#
  If [M:POH2]LINTYP(I)<>2
    #----- Rechargement des codes taxe si rĂŠgime taxe modifiĂŠ -----#
    If GVACFLG=1
      Call ALIVATCOD(2,[M:POH0]BPSNUM,[M:POH2]ITMREF(I),"POH2",I) From TRTX3
    Endif
    #----- Recherche tarif pour chargement dans la ligne -----#
    If GPLIFLG=2
      [M:POH2]LINFLG(I)=0 : GPUU=[M:POH2]PUU(I) : Call RECH_TARIF("POH",I) From TRTACHTAR1
    Endif
    #----- Conversion tarif existant sur la ligne -----#
    If CURFLG=1   Gosub CONVERSION_LIG  : Endif
  Endif
  #----- Changement date prĂŠvue de livraison -----#
  If OLDRCPDAT<>[M:POH2]RETRCPDAT(I)
    [M:POH2]EXTRCPDAT(I)=[M:POH2]RETRCPDAT(I)
  Endif
  #----- Calcul montant ligne HT et TTC -----#
  If GPLIFLG=2 | CURFLG=1 | GVACFLG=1
    [M:POH2]LINAMT(I)=[M:POH2]NETPRI(I)*[M:POH2]QTYUOM(I)
    Call ARRDEV([M:POH2]LINAMT(I),GCUR)    From TRTDIV
    Call MAJ_CALTAX_LIG("POH2",I)  From TRTACHDIV1
  Endif
  #-----

  # Issue 70985 - 2012-04-24 by MUARN : landed cost
  # Issue 90991 - 2013-10-23 by MUARN : maj donnĂŠes site
  #----- Initialisation des landed cost -----#
  [M:POH2]NETCUR(I) = [M:POH1]CUR
  If GPLIFLG = 2 & [M:POH2]LINTYP(I)=1
    If [F:ITP]ITMREF<>[M:POH2]ITMREF(I) | [F:ITP]BPSNUM<>[M:POH0]BPSNUM
      Read [ITP] ITP0=[M:POH2]ITMREF(I);[M:POH0]BPSNUM
    Endif
    Call RECH_COST([M:POH2]PRHFCY(I),[M:POH0]BPSNUM, [M:POH2]ITMREF(I), [M:POH2]CPRCOE(I), WCPRAMT, [M:POH2]STCNUM(I)) From STCLIB
    If GLOCALDEV <> GSYSCUR
      Call CONVERT2(GSYSCUR,GLOCALDEV, GLOCALDEV,[M:POH1]CHGTYP,[M:POH0]ORDDAT,
&               WCPRAMT,WCPRAMT,WSTAT) From TRTDEV
      [M:POH2]CPRAMT(I)=arr(WCPRAMT,10^-GDECPRI)
    Else
      [M:POH2]CPRAMT(I)=WCPRAMT
    Endif
    If [M:POH2]CPRCOE(I)=0 [M:POH2]CPRCOE(I)=1 Endif
    If [F:ITP]PUU<>""
      [M:POH2]PUU(I)=[F:ITP]PUU
    Else
      [M:POH2]PUU(I)=[F:ITM]PUU
    Endif
    Call PCAL_QTY([M:POH2]QTYUOM(I),[M:POH2]UOM(I),[M:POH2]QTYPUU(I),[M:POH2]PUU(I),
&             [M:POH2]ITMREF(I),[M:POH0]BPSNUM,1,GCOEUOM) From TRTACHQTE1
    [M:POH2]UOMPUUCOE(I)=GCOEUOM
  Endif
  If [M:POH2]CPRCOE(I)=0 [M:POH2]CPRCOE(I)=1 Endif
  # fin Issue 70985 - 2012-02-27 by MUARN : landed cost

  Call MAJ_BASTAX_LIG(I,+1) From SUBPOHC
  Call MAJ_CUMULS_LIG(I,+2) From SUBPOHC
  #-----
  If [M:POH2]CREFLG(I)<>0 [M:POH2]UPDFLG(I)=1 : Endif
  [M:POH2]LINFLG(I)=1 :  [M:POH2]WAPPFLG(I)=2
Next I
#----- Appel tarifs groupĂŠs -----#
If GPURGRUDIS>1  Call TAR_GROUPE("POH") From TRTACHTAR1 : Endif
#----- Si modif rĂŠgime de taxe, recalcul ĂŠlĂŠments pied de commande -----#
If GVACFLG=1
  For I=0 To dim([M:POH2]INVDTAVAT1)-1
    Read [PFI] PFI0=GINVDTALIN(I) : If fstat Raz [F:PFI] : Endif
    If [F:PFI]VATRUL=2
      If !clalev([F:TVC])  Local File TABVAC [TVC] : Endif
      Call RECHVATFOOT(2,[M:POH0]BPSNUM,[F:PFI]PFINUM,"POH3",WVAT) From TRTX3
      [M:POH2]INVDTAVAT1(I)=WVAT
    Endif
  Next I
  #-----
  For I=0 To [M:POH3]NBFAC-1
    [M:POH1]VACTYP=OLDVACTYP
    Call MAJ_ELEMENT (I,1,-1) From SUBPOHC
    [M:POH1]VACTYP=NEWVACTYP
    Read [PFI] PFI0=[M:POH3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
    If [F:PFI]VATRUL=2
      If !clalev([F:TVC])  Local File TABVAC [TVC] : Endif
      Call RECHVATFOOT(2,[M:POH0]BPSNUM,[F:PFI]PFINUM,"POH3",WVAT) From TRTX3
      [M:POH3]INVDTAVAT(I)=WVAT
    Endif
    Call MAJ_ELEMENT (I,0,+1) From SUBPOHC
  Next I
Endif
#-----
If GPIHCALTAX=2 | (dim([M:POH3]DISVATFLG)>1 & find(2,[M:POH3]DISVATFLG(0..[M:POH3]NBFAC-1)))
  For GPOH_INDTAX=1 To [M:POH3]NBTAX
    Gosub CAL_TAXE_GLOB From SUBPOHC
  Next GPOH_INDTAX
Endif
#-----
If !GIMPORT  Affzo [POH2]1-99 : Affzo [POH3]5-15 : Endif
$FIN_RECALCUL_TARLIG
Raz [M:POH0]OLDCUR, GPLIFLG, GVACFLG, GDATFLG
Return

$CONVERSION_LIG
#-------------------------------------------------------------#
# CONVERSION TARIF EXISTANT SUR LA LIGNE AVEC NOUVELLE DEVISE #
#-------------------------------------------------------------#
# Call COURDEV([M:POH0]OLDCUR,[M:POH1]CUR,[M:POH1]CHGTYP,[M:POH0]ORDDAT,GBIDD1,STAT) From TRTDIV
# [M:POH2]GROPRI(I)=arr([M:POH2]GROPRI(I)*GBIDD1,10^-GDECPRI)
Call CONVERT2([M:POH0]OLDCUR,[M:POH1]CUR,GLOCALDEV,[M:POH1]CHGTYP,[M:POH0]ORDDAT,
&             [M:POH2]GROPRI(I),MT2,STAT) From TRTDEV
[M:POH2]GROPRI(I)=arr(MT2,10^-GDECPRI)

For J=1 To 9
    If evalue ("DIM([M:POH2]DISCRGVAL"+num$(J)+"(I))")>0
       If GFMTREM(J-1)="M"
          MT1=evalue ("[M:POH2]DISCRGVAL"+num$(J)+"(I)")
#         Call CONVERT(MT1,[M:POH0]OLDCUR,MT2,[M:POH1]CUR,GBIDD1) From TRTDIV
          Call CONVERT([M:POH0]OLDCUR,[M:POH1]CUR,GLOCALDEV,[M:POH1]CHGTYP,[M:POH0]ORDDAT,
&                      MT1,MT2,STAT) From TRTDEV
          Assign "[M:POH2]DISCRGVAL"+num$(J)+"(I)" With MT2
       Endif
       DISCRGVAL(J-1)=evalue ("[M:POH2]DISCRGVAL"+num$(J)+"(I)")
    Endif
Next J
If dim(GCALNETLIN)>0  GCALNETLIN=I+1        : Endif
If dim(GCALNETABR)>0  GCALNETABR="[M:POH2]" : Endif
Call CALNET(2,[F:BPS]PLISTC,[M:POH2]GROPRI(I),DISCRGVAL,[M:POH2]QTYUOM(I),
&           [M:POH2]NETPRI(I),[M:POH1]CUR) From TRTPRICE
Return

#--------------------------------------------------------------#
# MESSAGE_QTE : S/P d'avertissement sur contrĂ´le des quantitĂŠs #
#--------------------------------------------------------------#
# Subprog MESSAGE_QTE (CODE,NOL)                               #
#    CODE  : 1 = Affichage du message                          #
#            2 = Chargement de GMESSAGE car action de contrĂ´le #
#    NOL   : Indice de la ligne en cours (nolign-1)            #
#                                                              #
# Remarque : GBIDD1 = QuantitĂŠ en UA                           #
#            GBIDD2 = QuantitĂŠ en US                           #
#--------------------------------------------------------------#
Subprog MESSAGE_QTE (CODE,NOL)
Value Integer  CODE
Value Shortint NOL
Local Integer WOK
Local Integer WNB : WNB=0 : #VPO 09/12/10 17667
Raz GMESSAGE, mkstat
#VPO 09/12/10 17667
[M:POH2]UPDPSDFLG(NOL)=1
#----- Pas de contrĂ´le qtĂŠ minimum si migration IntĂŠgrale -----#
If clalev([F:XEPA]) & clalev([F:XLPA])  End : Endif
#--- Test qtĂŠ infĂŠrieure Ă  qtĂŠ initiale besoins pris en compte (sauf contremarque) ---#
#If GBIDD2<[M:POH2]RETQTYSTU(NOL) & [M:POH2]SOHNUM(NOL)=""
If GBIDD2<>[M:POH2]RETQTYSTU(NOL) & [M:POH2]SOHNUM(NOL)=""
  #If [M:POH2]CREFLG(NOL)=0 & GBIDD2<[M:POH2]RETQTYSTU(NOL)
  If [M:POH2]CREFLG(NOL)=0 & GBIDD2<>[M:POH2]RETQTYSTU(NOL)
    Local Integer WPRONUM
    Local Char    WCODFNC(3)
    Local Integer WLINNUM
    If clalev([M:POI1])>0 & GIMPORT
      WPRONUM=[M:POI1]PRONUM
      WCODFNC="POI"
      WLINNUM=[M:POI1]POILIN([M:POH2]POHLIN(NOL))
    Else
      WPRONUM=adxuid(1)
      WCODFNC="POH"
      WLINNUM=[M:POH2]POHLIN(NOL)
    Endif
    Filter [PWO] Where PRONUM=WPRONUM
&                    & CODFNC=WCODFNC
&                    & LINNUM=WLINNUM
&                    & (WIPTYP=2 | WIPTYP=7)
&                    & WIPSTA=2
    #VPO 09/12/10 17667 si une seule ligne de DA, on autorise la modif
    #Read [PWO] PWO0 First
    For [PWO]PWO0
       If [F:PWO]WIPSTA=2 & [F:PWO]WIPTYP=2
        WNB+=1
       Else
        WNB+=2
       Endif
    Next
    Filter [PWO]
    #If !fstat
    If WNB>1 & GBIDD2<[M:POH2]RETQTYSTU(NOL)
      GMESSAGE=mess(3,194,1)-format$("N:15F",[M:POH2]RETQTYSTU(NOL))-[M:POH2]STU(NOL)
    Elsif WNB=1
        #le flag va servir pour la mise Ă  jour en modif sur vallig
        [M:POH2]UPDPSDFLG(NOL)=2
    Endif
  Elsif [M:POH2]CREFLG(NOL)<>0
    If !clalev([F:PSO])  Local File PREQUISO  [PSO] : Endif
    Filter [PSO] Where POHNUM=[M:POH0]POHNUM
&                    & POPLIN=[M:POH2]POPLIN(NOL)
&                    & POQSEQ=1
    #VPO 09/12/10 17667 si une seule ligne de DA, on autorise la modif
    #Read [PSO] PSO1 First
    For [PSO]PSO1
        WNB+=1
    Next
    Filter [PSO]
    #If !fstat
    If WNB>1 & GBIDD2<[M:POH2]RETQTYSTU(NOL)
      GMESSAGE=mess(3,194,1)-format$("N:15F",[M:POH2]RETQTYSTU(NOL))-[M:POH2]STU(NOL)
    Elsif WNB=1
        #le flag va servir pour la mise Ă  jour en modif sur vallig
        [M:POH2]UPDPSDFLG(NOL)=2
    Endif
  Endif
  #VPO 09/12/10 17667 si une seule ligne de DA, on autorise la modif
  #If !fstat
  #  GMESSAGE=mess(3,194,1)-format$("N:15F",[M:POH2]RETQTYSTU(NOL))-[M:POH2]STU(NOL)
  #Endif
Endif
#----- Positionnement mkstat et affichage si CODE=1 -----#
If GMESSAGE<>""
  mkstat=1
  If CODE=1 GERR=1 : Endif
  End
Endif
#VPO 15/10/10 17730/59532 contrĂ´le selon paramĂ¨tre
If GPOHMINQTY=0 : GPOHMINQTY=1 : Endif
#----- Test qtĂŠ infĂŠrieure Ă  qtĂŠ minimum d'achat -----#
#If GBIDD1<[M:POH2]PURMINQTY(NOL) & [M:POH2]SOHNUM(NOL)="" & [M:POH2]RETQTYSTU(NOL)=0
If GBIDD1<[M:POH2]PURMINQTY(NOL) & [M:POH2]SOHNUM(NOL)="" & [M:POH2]RETQTYSTU(NOL)=0 & GPOHMINQTY<3
  GMESSAGE=mess(14,194,1)-format$("N:15F",[M:POH2]PURMINQTY(NOL))-[M:POH2]PUU(NOL)
  If GPOHMINQTY=1
      mkstat=1
      If CODE=1 GERR=1 : Endif
      End
  Else : #GPOHMINQTY=2
      #pour ne pas afficher 2 fois le message sur C_QTYUOM et AM_QTYUOM
      If dim(GWPOHMINQTY)<0 : Global Char GWPOHMINQTY (200) : Endif
      If GWPOHMINQTY <> "POH"+[M:POH0]POHNUM+num$(NOL)+[M:POH2]ITMREF(NOL)
          GWPOHMINQTY = "POH"+[M:POH0]POHNUM+num$(NOL)+[M:POH2]ITMREF(NOL)
          WOK=2
          Call AVERTIR (GMESSAGE, WOK)From GESECRAN
          If WOK=1
              Raz GMESSAGE
              mkstat=1
              If CODE=1 GERR=1 : Endif
              End
          Endif
      Else
          Raz GWPOHMINQTY
      Endif
      Raz GMESSAGE
  Endif
Endif
End


#############################################################################
# PICKING : S/P de prise en compte des besoins d'achat         MBT 17/12/98 #
# ------------------------------------------------------------------------- #
#   FOURN    : NumĂŠro du fournisseur                                        #
#   REFART   : RĂŠfĂŠrence de l'article                                       #
#   ACHETEUR : Code de l'acheteur                                           #
#   QTEAOF   : QuantitĂŠ de l'appel d'offre sĂŠlectionnĂŠ en UA                #
#   UA       : UnitĂŠ d'achat de la commande et de la qtĂŠ ci-dessus          #
#   CODE     : Code traitement  1 = Prise en compte des "POS"               #
#                                   sans filtre acheteur                    #
#                               2 = Prise en compte des "POP"               #
#                               3 = Prise en compte des "POS" & "POP"       #
#                               4 = Prise en compte des "SCS","SCP" & "SCF" #
#                                   sr 75543 : Seulement les SCF            #
#                               5 = Prise en compte des "POS" & "POP"       #
#                                   gĂŠnĂŠrĂŠs par la production               #
#                               6 = Prise en compte des DA pour les         #
#                                   articles non gĂŠrĂŠs en stock             #
#                               7 = Prise en compte des "TRS" & "TRP"       #
#                                   gĂŠnĂŠrĂŠs par les besoins inter-sites     #
#                                   sans filtre par acheteur                #
#                               8 = idem codes 2 + 7                        #
#                               9 = Prise en compte des "EOS","EOP" & "EOF" #
#                                   sr 86705 : Seulement les EOF            #
#   RCPFCY    : Site de rĂŠception (Si la zone est renseignĂŠe alors les      #
#               besoins sont filtrĂŠs sur ce site)                           #
#   SHIFCY    : Site d'expĂŠdition (Si la zone est renseignĂŠe alors les      #
#               besoins "TRS" et "TRP" sont filtrĂŠs sur ce site)            #
# ------------------------------------------------------------------------- #
# RemplacĂŠ par l'action SAIPECB1 avec paramĂ¨tres :             MBT 07/12/00 #
#   PARAM(1) = BPSNUM : NumĂŠro du fournisseur                               #
#   PARAM(2) = ITMREF : RĂŠfĂŠrence de l'article                              #
#   PARAM(3) = BUY    : Code de l'acheteur                                  #
#   PARAM(4) = QTEAOF : QuantitĂŠ en UA de l'appel d'offre sĂŠlectionnĂŠ       #
#   PARAM(5) = UA     : UnitĂŠ d'achat                                       #
#   PARAM(6) = TRAIT  : Code traitement (idem ci-dessus)                    #
#   PARAM(7) = CODFNC : Code fonction ("PSH", "POH", "POD")                 #
#   PARAM(8) = WITMKND : Type d'article                                     #
#############################################################################
#--------------------------------------------------------------#
# Avant la dĂŠfinition des boutons et l'ouverture de la fenĂŞtre #
#--------------------------------------------------------------#
$OUV_SAIPECB1
Local Char     FOURN   (GLONBPS) : FOURN=PARAM(1)
Local Char     REFART  (GLONITM) : REFART=PARAM(2)
Local Char     ACHETEUR(GLONAUS) : ACHETEUR=PARAM(3)
Local Decimal  QTEAOF            : QTEAOF=val(PARAM(4))
Local Char     UA(GLONUOM)       : UA=PARAM(5)
Local Integer  CODE              : CODE=val(PARAM(6))
Local Char     FONCTION(3)       : FONCTION=PARAM(7)
# Issue 112754 - 2016-10-03 by SR : Services
Local Integer  WITMKND           : WITMKND=val(PARAM(8))
#----- Variables locales -----#
Local Char     CRITERES(250), CRITLNK(70), CCELIG(200), CCEPSD(200), SECTION(GLONCCE)
Local Char     WITMDES(GLONDES),  WITMDES1(GLONDES)
Local Char     WLINTEX(GLONTXC),  WLINTEXPSD(GLONTXC)
# Issue 71069 - 2016-01-04 by SR : PJT longueur WPJT
Local Char     WPJT(GLONPJT), SAVPQHNUM(GLONPQH), WVCRNUM(GLONVCR)
Local Libelle  WLINPURTYP
Local Char     CRITBETPOH(240)
Local Decimal  MT1, MT2, DISCRGVAL(0..8)
Local Integer  OK, STAT, SAVPPDLIN
Local Shortint I, J, K, L, NBRGR
Local Shortint SAVNOLIGN, SAVNBLIG, SAVBUDCTLPOL, AOFFLG, NOL : NOL=nolign-1
Local Shortint WRET # Issue 42064 - 2012-01-18 by MUARN : contrĂ´le contre-marque
Local Char     RCPFCY(GLONFCY), SHIFCY(GLONFCY), WNOMSITE(6)
Local Decimal  WRETQTY, WRETQTYSTU, WPICQTYPUU, WPICQTYSTU
# Issue 112754 - 2016-09-27 by SR :Services
Local Char     FONCTIONB(3)  : FONCTIONB = FONCTION
# Issue X3-55891 - 2018-09-07 by MUARN : exploitation table article/fournisseur/site
Local Integer WITMBPS : WITMBPS = 0
Local Integer WRETOUR
#----- Sauvegarde de nolign, NBLIG et GBUDCTLPOL -----#
SAVNOLIGN=nolign : SAVNBLIG=[M:POH2]NBLIG : SAVBUDCTLPOL=GBUDCTLPOL
# Issue 42064 - 2011-12-26 by MUARN : PEC sur commande selon flag
# Issue 112754 - 2016-11-17 by SR : Toujours ouverture si service de SST
If ([F:PTR]PICRETFLG = 1 & GPECBOUT = 1) & WITMKND <> 2
  FIN = 1
  Return
Endif
# Issue 112754 - 2016-09-27 by SR : Services
# FONCTION = "POH" : appel de l'action depuis  ITMREF
# FONCTION = "PO1" : appel de l'action depuis  ITMKND
# Depuis l'article, Pas d'ouverture si sous-traitance ou service et type d'article saisissable
# Sauf si appel depuis le bouton
If FONCTION = "POH"
   If varmode([M:POH2]ITMKND)=0  &  WITMKND > 1  & GPECBOUT <> 2    : FIN = 1 : Return
   Endif
Endif
## Depuis le type d'article, Pas d'ouverture  si type = "Standard"
If FONCTION = "PO1" & WITMKND =1 : FIN = 1 : Return : Endif
## On remet "POH" dans FONCTION pour suite du traitement
If FONCTION = "PO1" : FONCTION = "POH" : Endif
# End issue 112754
# Issue X3-55891 - 2018-10-05 by SR : Pas d'ouverture si site de rĂŠception vide
If [M:POH2]PRHFCY(nolign-1) = "" : FIN = 1 : Return : Endif
# Si triplette Article/Fournisseur/Site de rĂŠception  par dĂŠfaut du site de commande bloquĂŠe, pas d'ouverture
Raz WITMBPS, WRETOUR
# Intersite
If [M:POH0]BETFCY = 2 & [M:POH0]BETCPY <> 2
  Call BPSNUM_DOUBTFUL_LEVEL(1,REFART,[M:POH0]BPSNUM,GRCPFCY,WITMBPS,WRETOUR) From TRTACHCTL1
Else
  Call BPSNUM_DOUBTFUL_LEVEL(2,REFART,[M:POH0]BPSNUM,GRCPFCY,WITMBPS,WRETOUR) From TRTACHCTL1
Endif
If WRETOUR <> 0 : FIN = 1 : Return : Endif
# End issue X3-55891

#----- Si inter-sites avec correspondance dans les ventes -----#
Raz RCPFCY, SHIFCY
If [M:POH0]SALFCY<>""
  If [M:POH2]NBLIG<>0 & ([M:POH0]DME=3 | GLINBPD<>2)
    RCPFCY=GRCPFCY        : # Site de rĂŠception unique
  Endif
  If [M:POH0]DME=3
    SHIFCY=[M:POH1]STOFCY : # Site d'expĂŠdition unique
  Endif
Endif
#----- Si aucun besoin n'existe, ne pas ouvrir la fenĂŞtre de picking -----#
If CODE<>6 Goto VERIF_ORD_PICKING : Endif
#----- VĂŠrification existence des besoins dans le fichier des DA  -----#
CRITERES='LINORDFLG=1 & ITMREF=REFART & LINCLEFLG=1 & LINAPPFLG>2'
If GBUYFLT=2   CRITERES-='& (LINBUY=ACHETEUR | LINBUY="")' : Endif
If RCPFCY<>""  CRITERES-='& PRHFCY=RCPFCY'                 : Endif
#----- Chargement du filtre supplĂŠmentaire pour inter-sites -----#
If [M:POH0]BETFCY=2 & [M:POH0]BPCORD<>"" & RCPFCY=""
  WNOMSITE="PRHFCY" : Gosub CRITBETPOH : # Sites de rĂŠception des adresses client livrĂŠ
Else
  CRITBETPOH="1=1"
Endif
#-----
For [PSD] Where evalue(CRITERES) & evalue(CRITBETPOH)
  For [PWO] PWO0 Where PRONUM=adxuid(1)
&                    & CODFNC=FONCTION
&                    & WIPTYP=2
&                    & WIPNUM=[F:PSD]PSHNUM
&                    & PSDLIN=[F:PSD]PSDLIN
&                    & ITMREF=[F:PSD]ITMREF
    [F:PSD]ORDQTYSTU+=[F:PWO]QTYSTU
  Next
  If [F:PSD]QTYSTU>[F:PSD]ORDQTYSTU
    #----- ContrĂ´le existence du site et appartenance Ă  la mĂŞme stĂŠ juridique -----#
    If [F:FCY]FCY<>[F:PSD]PSHFCY
      Read [FCY] FCY0=[F:PSD]PSHFCY : If fstat Raz [F:FCY] : Endif
    Endif
    If [F:FCY]LEGCPY=GSOCIETE I=1 : Endif
  Endif
  # Issue 42064 - 2012-01-24 by MUARN : PEC selon transaction et clic droit
  If I=1
    If GPECBOUT = 2 : GPECBOUT = 1 Endif
    Break
  Endif
Next
# Issue 112754 - 2016-10-17 by SR : Services
#If I=0 mkstat=98 : FIN=1 : Endif
If I=0  & CODE=6
  Goto VERIF_SOQ_PICKING
Endif

If I=0 mkstat=98 : FIN=1 : Endif
Return
#----- VĂŠrification existence des besoins dans le fichier encours -----#
# Issue 75543 - 2011-08-18 by SR : Code = 4 : Seulement les SCF
# Issue 86705 - 2012-12-17 by SR : Code = 9,92,93,98,96 : Si EO alors Seulement les EOF
$VERIF_ORD_PICKING
# Issue 93771 GA 12/2013 changement de fournisseur interdit en sous-traitance
# on filtre les WIPTYP=4 ou 13 sur le fournisseur courant
Case CODE
  When 1 : CRITERES='WIPTYP=2 & WIPSTA=3 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"'
  When 2 : CRITERES='WIPTYP=2 & WIPSTA=2 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"'
  When 3 : CRITERES='WIPTYP=2 & WIPSTA>1 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"'
  When 4 : CRITERES='WIPTYP=4 & WIPSTA=1 & ITMREF=REFART & (BPRNUM=FOURN | BPRNUM="")'
  When 5 : CRITERES='WIPTYP=2 & WIPSTA>1 & ITMREF=REFART & left$(ABBFIL,2)<>"PO" & ABBFIL<>"PSD"'
  When 7 : CRITERES='WIPTYP=7 & WIPSTA>1 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"'
  When 8 : CRITERES ='(WIPTYP=2 & WIPSTA=2 & ITMREF=REFART & left$(ABBFIL,2)<>"PO") |'
           CRITERES-='(WIPTYP=7 & WIPSTA>1 & ITMREF=REFART & left$(ABBFIL,2)<>"PO")'
  When 9 : CRITERES='WIPTYP=13 & WIPSTA = 1 & ITMREF=REFART & BPRNUM=FOURN'
  #VPO 25/01/11 70999 un art ss-traitĂŠ peut aussi ĂŞtre achetĂŠ via POS (cas 92,93,98,96)
  When 92 : CRITERES='((WIPTYP=13 & WIPSTA = 1 & ITMREF=REFART & BPRNUM=FOURN)|'
            CRITERES+='(WIPTYP=2 & WIPSTA=2 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"))'
  When 93 : CRITERES='((WIPTYP=13 & WIPSTA = 1 & ITMREF=REFART & BPRNUM=FOURN)|'
            CRITERES+='(WIPTYP=2 & WIPSTA>1 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"))'
  When 98 : CRITERES='((WIPTYP=13 & WIPSTA = 1 & ITMREF=REFART & BPRNUM=FOURN)|'
            CRITERES+='(WIPTYP=2 & WIPSTA=2 & ITMREF=REFART & left$(ABBFIL,2)<>"PO") |'
            CRITERES+='(WIPTYP=7 & WIPSTA>1 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"))'
  When 96 : CRITERES='((WIPTYP=13 & WIPSTA = 1 & ITMREF=REFART & BPRNUM=FOURN)|'
            CRITERES+='(WIPTYP=2 & WIPSTA>1 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"))'
  When Default
           CRITERES='WIPTYP=2 & WIPSTA>1 & ITMREF=REFART & left$(ABBFIL,2)<>"PO"'
Endcase
#----- Filtre sur site de rĂŠception et site d'expĂŠdition -----#
If RCPFCY<>""          CRITERES-='& STOFCY=RCPFCY' : Endif
If SHIFCY<>"" & CODE>6 CRITERES-='& (ORIFCY=SHIFCY | WIPTYP<>7)' : Endif
#----- Chargement du filtre supplĂŠmentaire pour inter-sites -----#
If [M:POH0]BETFCY=2 & [M:POH0]BPCORD<>"" & RCPFCY=""
  WNOMSITE="STOFCY" : Gosub CRITBETPOH : # Sites de rĂŠception des adresses client livrĂŠ
Else
  CRITBETPOH="1=1"
Endif
#----- Filtre sur acheteur -----#
If GBUYFLT=2 & CODE<>1 & CODE<>7
  CRITLNK='[F:ITF]BUY=ACHETEUR | [F:ITF]BUY="" | [F:ORD]WIPTYP=7'
Else
  CRITLNK="1=1"
Endif
#-----
Filter [ORD] Where evalue(CRITERES) & evalue(CRITBETPOH)
Link [ORD] With [ITF] ITF0=[F:ORD]ITMREF;[F:ORD]STOFCY As [ORF]
For [ORF] Where evalue(CRITLNK)
  Gosub POINT_ORDLEC From TRTACHMGT1 : # Appel point d'entrĂŠe ORDLEC
  For [PWO] PWO0 Where PRONUM=adxuid(1)
&                    & CODFNC=FONCTION
&                    & WIPTYP=[F:ORD]WIPTYP
&                    & WIPNUM=[F:ORD]WIPNUM
&                    & ITMREF=[F:ORD]ITMREF
    [F:ORD]RMNEXTQTY-=[F:PWO]QTYSTU
  Next
  If [F:ORD]RMNEXTQTY>0
    #----- ContrĂ´le existence du site et appartenance Ă  la mĂŞme stĂŠ juridique -----#
    If [F:FCY]FCY<>[F:ORD]STOFCY
      Read [FCY] FCY0=[F:ORD]STOFCY : If fstat Raz [F:FCY] : Endif
    Endif
    If [F:FCY]LEGCPY=GSOCIETE
      #---- "POP" demande d'achat : Prise en compte si ligne complĂ¨tement signĂŠe ----#
      If [F:ORD]WIPSTA=2 & [F:ORD]ABBFIL="PSD"
        Read [PSD] PSD0=[F:ORD]VCRNUM;[F:ORD]VCRLIN
        If fstat Raz [F:PSD] : Endif
        If [F:PSD]LINAPPFLG>2 I=1 : Endif
      #---- "POS","TRS", "SCF" et "EOF" besoins autres : Prise en compte sans restriction ----#
      Else
        I=1
      Endif
    Endif
  Endif
  # Issue 42064 - 2012-01-24 by MUARN : PEC selon transaction et clic droit
  If I = 1
    If GPECBOUT = 2 : GPECBOUT = 1 Endif
    Break
  Endif
Next
Filter [ORD]
# Issue 42064 - 2012-01-18 by MUARN : contrĂ´le contre-marque
# Issue 112754 - 2016-10-17 by SR : Pas pour les services de SST
If I=0  & WITMKND <> 2 : Goto VERIF_SOQ_PICKING Endif
Return

#----- VĂŠrification existence des besoins dans le fichier encours -----#
# Issue 42064 - 2012-01-18 by MUARN : contrĂ´le contre-marque
$VERIF_SOQ_PICKING
If !clalev([F:SOQ])  Local File SORDERQ [SOQ] : Endif
CRITERES='ITMREF=REFART'
For [SOQ] SOQ4 Where SOQSTA<>3
&                  & SOHCAT<>4
&                  & find(FMI,2,3)<>0
&                  & FMINUM=""
&                  & evalue(CRITERES)
  #----- ContrĂ´le existence du site et appartenance Ă  la mĂŞme stĂŠ juridique -----#
  If [F:FCY]FCY<>[F:SOQ]STOFCY
    Read [FCY] FCY0=[F:SOQ]STOFCY : If fstat Raz [F:FCY] : Endif
  Endif
  If [F:FCY]LEGCPY=GSOCIETE
    Raz [F:ITP]
    # Issue X3-55891 - 2018-09-07 by MUARN : exploitation table article/fournisseur/site
    #Read [ITP] ITP0=[F:SOQ]ITMREF;[M:POH0]BPSNUM
    #If [F:ITP]DOUFLG>2 Raz [F:ITP] : Endif
    Call FIND_ITMBPSFCY_ITMBPS([F:SOQ]ITMREF,[M:POH0]BPSNUM,[F:SOQ]STOFCY,WITMBPS) From TRTACHDEF1
    # End issue X3-55891
    Call CTLITMBUY([F:SOQ]ITMREF,[M:POH1]BUY,WRET) From TRTACHCTL1
    If !WRET I = 1 : Endif
  Endif
  If I=1 Break : Endif
Next
If I=0
  If GPECBOUT = 2
    GPECBOUT = 1
    Call MESSAGE(mess(96,194,1)) From GESECRAN
  Endif
  mkstat = 98
  FIN = 1
Endif
If GPECBOUT = 2 : GPECBOUT = 1 Endif
Return

#--------------------------------------------------------------------------------------#
# Constitution du filtre avec tous les sites de rĂŠception des adresses du client livrĂŠ #
#--------------------------------------------------------------------------------------#
$CRITBETPOH
If !clalev([F:BPD])  Local File BPDLVCUST  [BPD] : Endif
If !clalev([F:FCY])  Local File FACILITY   [FCY] : Endif
Raz CRITBETPOH
For [BPD] BPD0 Where BPCNUM=[M:POH0]BPCORD & RCPFCY<>"" & RCPFCY<>[M:POH1]STOFCY & ENAFLG=2
  Read [FCY] FCY0=[F:BPD]RCPFCY
  If !fstat & [F:FCY]LEGCPY=GSOCIETE
    If CRITBETPOH=""
      CRITBETPOH=WNOMSITE+'="'+[F:BPD]RCPFCY+'"'
    Else
      CRITBETPOH-='|'-WNOMSITE+'="'+[F:BPD]RCPFCY+'"'
    Endif
  Endif
  If len(CRITBETPOH)>225  Break : Endif : # Le maximum est atteint !
Next
#----- Si aucun site trouvĂŠ, mettre une condition impossible (site="") -----#
If CRITBETPOH=""  CRITBETPOH=WNOMSITE+'=""' : Endif
Return


#---------------------------------#
# AprĂ¨s l'ouverture de la fenĂŞtre #
#---------------------------------#
$DEB_SAIPECB1
#----- Ouverture fichier table des unitĂŠs si nĂŠcessaire -----#
If clalev([F:TUN])=0 Local File TABUNIT [TUN] : Endif
#----- Lecture fournisseur et article si nĂŠcessaire -----#
If [F:BPS]BPSNUM<>FOURN
  Read [BPS] BPS0=FOURN  : If fstat Raz [F:BPS] : Endif
Endif
If [F:ITM]ITMREF<>REFART
  Read [ITM] ITM0=REFART : If fstat Raz [F:ITM] : Endif
Endif
#----- Chargement des zones dans le masque -----#
Raz [M:PPI1]
[M:PPI1]BPSNUM =FOURN         : [M:PPI1]BPSNAM=[F:BPS]BPSNAM
[M:PPI1]ITMREF =REFART
#[M:PPI1]ITMDES=[F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PPI1]ITMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
# Issue 112754 - 2016-10-17 by SR :Services on  en a besoin pour savoir ce qu'on doit charger
[M:PPI1]ITMKND = WITMKND
[M:PPI1]UOM    =[F:ITM]STU    : [M:PPI1]ORDBUY=ACHETEUR
[M:PPI1]PUU    =UA            : [M:PPI1]QTEAOF=QTEAOF
[M:PPI1]CODE   =CODE          : [M:PPI1]CHXDAT=2
[M:PPI1]PQHNUM =[F:PQD]PQHNUM : [M:PPI1]PQDLIN=[F:PQD]PQDLIN
[M:PPI1]RCPFCY =RCPFCY        : [M:PPI1]SHIFCY=SHIFCY
[M:PPI1]WCODFNC=FONCTION
# Issue 10622 - 2012-01-17 by MUARN : ajout fenĂŞtre critĂ¨re
[M:PPI1]FCY=[M:POH0]POHFCY
Call PCAL_QTY(QTEAOF,UA,[M:PPI1]PPDQTY,[M:PPI1]UOM,REFART,FOURN,1,GBIDD1) From TRTACHQTE1
#----- Affichage foreground -----#
If [M:PPI1]QTEAOF=0 : Grizo [PPI1]PPDQTY : Endif

# Issue 71069 - 2013-08-20 by MUARN : PJT
If GPJTSNGDOC=2 & [M:POH1]PJTH<>""
  [M:PPI1]PJTSTR=[M:POH1]PJTH
  [M:PPI1]PJTEND=[M:POH1]PJTH
  # champ PJTDOC afin de savoir le code affaire encours sur PEC en mono affaire
  [M:PPI1]PJTDOC=[M:POH1]PJTH
Endif

# 106430.n - Purchase planning, display product UOM
[M:PPI1]WEU    = [F:ITM]WEU
[M:PPI1]VOU    = [F:ITM]VOU
[M:PPI1]ITMWEI = [F:ITM]ITMWEI
[M:PPI1]ITMVOL = [F:ITM]ITMVOU

Affzo [PPI1]1-99
Return
#--------------------------------#
# AprĂ¨s l'exĂŠcution du bouton OK #
#--------------------------------#
$OK_SAIPECB1
#VPO 27/01/11 70999 on doit passer par une struct intermediaire PWO0
If !clalev([F:PWO0])   Local File PWRKORDERS   [PWO0] : Endif
Local Char SWMESS(80),WZONE  # Issue 71069 - 2013-08-21 by MUARN : PJT
If [M:PPI1]TOTQTY=0  FIN=1 : Return : Endif
#----- ContrĂ´le quantitĂŠ prise avec quantitĂŠ de l'appel d'offre -----#
If [M:POH2]PQHNUM(NOL)<>"" & [M:PPI1]TOTQTY<[M:PPI1]PPDQTY
  OK=2 : Call AVERTIR(mess(87,194,1),OK) From GESECRAN
  If OK=1 mkstat=1 : FIN=1 : Return : Endif
Endif
#----- Choix : Prix de l'appel d'offre ou recherche tarif -----#
If [M:POH2]PQHNUM(NOL)<>"" & [F:PPH]PLISTC=[F:BPS]PLISTC & [F:PPD]PRI<>0
  OK=2 : Call OUINON(mess(88,194,1),OK) From GESECRAN
  #----- Chargement du tarif de l'appel d'offre dans la ligne -----#
  If OK=2 Gosub TARIF_AOF : AOFFLG=1 : Endif
Endif
#----------------------------------------------------------------------#
# Point d'entrĂŠe ECLBESOINS pour modifier la gestion des regroupements #
# -------------------------------------------------------------------- #
# Variables utilisables par le point d'entrĂŠe :                        #
# La classe [M:PPI1]                                                   #
# FOURN     : NumĂŠro du fournisseur                                    #
# REFART    : RĂŠfĂŠrence de l'article                                   #
# WSRTFLG   : Indicateur de tri (0=Tri Ă  faire,  1=Tri effectuĂŠ)       #
# TRAIT     : Code traitement                                          #
#             1 = Prise en compte besoins depuis commandes classiques  #
#             2 = Prise en compte besoins depuis plan de l'acheteur    #
#             3 = Prise en compte besoins depuis les plans d'appro     #
# -------------------------------------------------------------------- #
# Variable modifiable par le point d'entrĂŠe :                          #
# ECLAT_PSH : Eclatement par demandes d'achat     (1=Non / 2=Oui)      #
# ECLAT_DAT : Eclatement par dates de besoin      (1=Non / 2=Oui)      #
# ECLAT_PJT : Eclatement par codes affaire        (1=Non / 2=Oui)      #
# ECLAT_LPT : Eclatement par type d'achat         (1=Non / 2=Oui)      #
# ECLAT_CCE : Eclatement par sections analytiques (1=Non / 2=Oui)      #
# ECLAT_DES : Eclatement par dĂŠsignation article  (1=Non / 2-4=Oui)    #
#               2 = Oui, avec dĂŠsignation traduite ITMDES              #
#               3 = Oui, avec dĂŠsignation standard ITMDES1             #
#               4 = Oui, avec code texte ligne LINTEX                  #
#----------------------------------------------------------------------#
Local Libelle WSRTFLG   : WSRTFLG=0
Local Libelle TRAIT     : TRAIT=1
Local Libelle ECLAT_PSH : ECLAT_PSH=1
Local Libelle ECLAT_DAT : ECLAT_DAT=1
Local Libelle ECLAT_PJT : ECLAT_PJT=2
Local Libelle ECLAT_LPT : ECLAT_LPT=2
Local Libelle ECLAT_CCE : ECLAT_CCE=2
Local Libelle ECLAT_DES : ECLAT_DES=2
Gosub POINT_ECLBESOINS From TRTACHCDE1
#----- Provoque la rupture Ă  chaque ligne pour SCF, SCS, EOF, EOS -----#
#VPO 25/01/11 70999 un art ss-traitĂŠ peut aussi ĂŞtre achetĂŠ via POS (cas 92,93,98,96)
##If CODE=4 | CODE=9  ECLAT_CCE=2 : Endif
If CODE=4 | CODE=9 | (CODE>90 & CODE<100) :  ECLAT_CCE=2 : Endif
#-----
#VPO 25/01/11 70999 un art ss-traitĂŠ peut aussi ĂŞtre achetĂŠ via POS (cas 92,93,98,96)
# il faut mettre les lignes normales Ă  la fin donc ajout tri sur WIPTYP desc
If !WSRTFLG
  If ECLAT_DAT>1
    If ECLAT_PSH>1 | (ECLAT_CCE>1 & ECLAT_PJT<2)
      #---- Tri du tableau picking par site rĂŠception, date besoin, no DA et affaire ----#
      Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]WIPTYP(indice) *(-1),
&                                                [M:PPI1]STOFCY(indice),
&                                                [M:PPI1]ORIFCY(indice),
&                                                [M:PPI1]ENDDAT(indice),
&                                                [M:PPI1]VCRNUM(indice),
&                                                [M:PPI1]WPJT(indice),
&                                                [M:PPI1]VCRLIN(indice)
    Else
      #---- Tri du tableau picking par site rĂŠception, date besoin et affaire ----#
      Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]WIPTYP(indice) *(-1),
&                                                [M:PPI1]STOFCY(indice),
&                                                [M:PPI1]ORIFCY(indice),
&                                                [M:PPI1]ENDDAT(indice),
&                                                [M:PPI1]WPJT(indice),
&                                                [M:PPI1]VCRNUM(indice),
&                                                [M:PPI1]VCRLIN(indice)
    Endif
  Elsif ECLAT_PSH>1
    #----- Tri du tableau de picking par site rĂŠception, no DA et affaire -----#
    Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]WIPTYP(indice) *(-1),
&                                              [M:PPI1]STOFCY(indice),
&                                              [M:PPI1]ORIFCY(indice),
&                                              [M:PPI1]VCRNUM(indice),
&                                              [M:PPI1]WPJT(indice),
&                                              [M:PPI1]VCRLIN(indice)
  Elsif ECLAT_PJT>1 & ECLAT_CCE<2
    #----- Tri du tableau de picking par site rĂŠception et affaire -----#
    Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]WIPTYP(indice) *(-1),
&                                              [M:PPI1]STOFCY(indice),
&                                              [M:PPI1]ORIFCY(indice),
&                                              [M:PPI1]WPJT(indice),
&                                              [M:PPI1]VCRNUM(indice),
&                                              [M:PPI1]VCRLIN(indice)
  Elsif ECLAT_CCE>1 & ECLAT_PJT<2
    #----- Tri du tableau de picking par site rĂŠception, et no DA -----#
    Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]WIPTYP(indice) *(-1),
&                                              [M:PPI1]STOFCY(indice),
&                                              [M:PPI1]ORIFCY(indice),
&                                              [M:PPI1]VCRNUM(indice),
&                                              [M:PPI1]VCRLIN(indice)
  Elsif ECLAT_PJT<2
    #----- Tri du tableau de picking par site rĂŠception -----#
    Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]WIPTYP(indice) *(-1),
&                                              [M:PPI1]STOFCY(indice),
&                                              [M:PPI1]ORIFCY(indice),
&                                              [M:PPI1]VCRNUM(indice),
&                                              [M:PPI1]VCRLIN(indice)
  Else
    #----- Tri du tableau de picking par site rĂŠception et affaire -----#
    Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]WIPTYP(indice) *(-1),
&                                              [M:PPI1]STOFCY(indice),
&                                              [M:PPI1]ORIFCY(indice),
&                                              [M:PPI1]WPJT(indice),
&                                              [M:PPI1]VCRNUM(indice),
&                                              [M:PPI1]VCRLIN(indice)
  Endif
Endif
#----- Exploitation du picking avec regroupement ĂŠventuel -----#
Default Mask [POH2] : GBUDCTLPOL=1
Call TEMPON ("O") From GESECRAN
Call DEBTRANS From GLOCK
Trbegin [PWO]
  [M:POH2]ITMREF(NOL)=[M:PPI1]ITMREF
  Raz [M:POH2]LINSTOFCY(NOL), [M:POH2]PRHFCY(NOL), [M:POH2]FCYADD(NOL),
&     [M:POH2]QTYPUU(NOL),[M:POH2]QTYSTU(NOL), [F:PWO]
  [M:POH2]RETRCPDAT(NOL)=GHIDATE
  nolign=NOL+1 : Call LINNUM("POPLIN") From TABLEAUX
  [M:POH2]POHCOU+=1 : [M:POH2]POHLIN(NOL)=[M:POH2]POHCOU
  [F:PWO]PRONUM = adxuid(1)
  [F:PWO]CODFNC = [M:PPI1]WCODFNC
  [F:PWO]LINNUM = [M:POH2]POHLIN(NOL)
  [F:PWO]ITMREF = [M:PPI1]ITMREF
  [F:PWO]PUU    = [M:PPI1]PUU
  [F:PWO]STU    = [M:POH2]STU(NOL)
  #VPO 27/01/11 70999 on doit passer par une struct intermediaire PWO0
  [F:PWO0]=[F:PWO]
  For I=0 To [M:PPI1]NBLIG-1
    If [M:PPI1]PICQTY(I)<>0 Gosub CHARG_LIG_CDE : Endif
    # Issue 71069 - 2013-08-21 by MUARN : PJT
    #If GOK=0 | mkstat Break : Endif
    If GOK=0 | mkstat | GERR : Break : Endif
  Next I
  # Issue 71069 - 2013-08-21 by MUARN : PJT
  #If GOK=0 | mkstat Goto AB_PICKING : Endif
  If GOK=0 | mkstat | GERR Goto AB_PICKING : Endif
  Gosub FIN_CHARG_LIG_CDE                    : If GOK=0 | mkstat Goto AB_PICKING : Endif
  Gosub CHARG_LIG_SUPPLEMENT From TRTACHSCO1 : If GOK=0 | mkstat Goto AB_PICKING : Endif
  If NOL+1>SAVNOLIGN
    mkstat=99
  Else
    [M:POH2]CTLPOHCOU=[M:POH2]POHLIN(NOL)
  Endif
Commit
[M:POH0]NBCRELIG=[M:PPI1]NBCRELIG
Call TEMPOFF From GESECRAN
Return
#----- Abandon transaction en cas d'erreur s'ĂŠcriture sur [F:PWO] ----#
$AB_PICKING
If GOK=0  Call FSTA("PWO") From GLOCK : Endif
Rollback : mkstat=1
Call TEMPOFF From GESECRAN
FIN=1
Return
#-------------------------------------#
# AprĂ¨s l'exĂŠcution du bouton ABANDON #
#-------------------------------------#
$ABA_SAIPECB1
Gosub DEB_SAIPECB1
Raz REP
Return
#-------------------------------#
# Grisage/dĂŠgrisage des boutons #
#-------------------------------#
$SETB_SAIPECB1
If [M:PPI1]TOTQTY=0
  ETABOU(GVALI)=0 : # DĂŠsactivation OK
Else
  ETABOU(GVALI)=1 : # Activation OK
Endif
# Issue 15330 - 2012-01-23 by MUARN : ajout boutons tout inclure/tout exclure
If [M:PPI1]NBLIG=0
  ETABOU(GSPE1)=0 : ETABOU(GSPE2)=0 : # DĂŠsactivation Inclure / Exclure
Else
  ETABOU(GSPE1)=1 : ETABOU(GSPE2)=1 : # Activation    Inclure / Exclure
Endif
Return
#------------------------------------------#
# Avant de revenir Ă  la fenĂŞtre prĂŠcĂŠdente #
#------------------------------------------#
$FINSAI_SAIPECB1
nolign=SAVNOLIGN : NOL=nolign-1 : [M:POH2]NBLIG=SAVNBLIG : GBUDCTLPOL=SAVBUDCTLPOL
If mkstat=1 | mkstat=2 Goto RETOUR_ITMREF : Endif
If mkstat=99
  GMODIF=1 : mkstat=0 : Return
Endif
# Issue 112754 - 2016-09-27 by SR : Services
If [F:ITM]SCSFLG=2 & varmode([M:POH2]ITMKND) = 0 & FONCTIONB = "POH" : Return : Endif
#-----
# Issue 82533 - 2012-06-11 by MUARN : prise en compte obligatoire pour sous-traitance
#If [F:ITM]PURFLG<>2
  #----- Des besoins doivent ĂŞtre pris en cpte pour un article sous-traitance -----#
  # Issue 112754 - 2016-09-27 by SR : Services
#  If [F:ITM]SCSFLG=2 & [M:POH2]RETQTYSTU(NOL)=0
  If [F:ITM]SCSFLG=2 & WITMKND = 2 & [M:POH2]RETQTYSTU(NOL)=0
    If mkstat=98
      GMESSAGE=mess(126,194,1) : GERR=1
    Else
    # Issue 112754 - 2016-09-27 by SR : Services
#      GMESSAGE=mess(121,194,1) : GERR=1
      GMESSAGE=mess(573,194,1) : GERR=1
    Endif
    Goto RETOUR_ITMREF
  Endif
  # Issue 82533 - 2012-06-20 by GA si et seulement si [F:ITM]PURFLG<>2
  #----- Des besoins doivent ĂŞtre pris en cpte pour un article sous-traitĂŠ non achetĂŠ -----#
  If [F:ITM]PURFLG<>2 & [F:ITM]SCPFLG=2 & [M:POH2]RETQTYSTU(NOL)=0
    If mkstat=98
      GMESSAGE=mess(355,194,1) : GERR=1
    Else
      GMESSAGE=mess(354,194,1) : GERR=1
    Endif
    Goto RETOUR_ITMREF
  Endif
#Endif
#----- Des besoins POP doivent ĂŞtre pris pour un article avec DA obligatoire -----#
If [F:ITM]PRQFLG=2 & [M:POH2]RETQTYSTU(NOL)=0
  GMESSAGE=mess(164,194,1) : GERR=1 : Goto RETOUR_ITMREF
Endif
#-----
If mkstat<>98
   Gosub CHARG_COEFLG From SUBPOH : # Chargement indicateur modif du coef
Endif
mkstat=0
#----- Affichage site de rĂŠception et quantitĂŠs -----#
If !GIMPORT
  Affzo [POH2]ITMDES(NOL),ITMDES1(NOL),LINSTOFCY(NOL), PRHFCY(NOL),FCYADD(NOL),USEPLC(NOL),
&             UOM(NOL),QTYUOM(NOL),UOMPUUCOE(NOL),PUU(NOL),QTYPUU(NOL),STU(NOL),
&             QTYSTU(NOL),PJT(NOL),EXTRCPDAT(NOL), GROPRI(NOL)
  nolign=SAVNOLIGN : # Le nolign peut ĂŞtre perdu Ă  cause de l'Affzo !
  # Issue 71069 - 2013-08-21 by MUARN : PJT
  Affzo [POH1]PJTH
Endif
#----- ContrĂ´le existence du site de rĂŠception si celui-ci n'est pas saisi -----#
If !GIMPORT
  If [F:PTR]PTRTYP<>3 | [F:PTR]PTRNUM<>GPTRNUM : # Relecture transaction si nĂŠcessaire
    Read [PTR] PTR0=3;GPTRNUM : If fstat Raz [F:PTR] : Endif
  Endif
Endif
If [F:PTR]RCPFCYCOD<>1
  If [F:FCY]FCY<>[M:POH2]PRHFCY(NOL)
    Read [FCY] FCY0=[M:POH2]PRHFCY(NOL)
    If fstat
      Raz [F:FCY] : GMESSAGE=mess(80,194,1) : GERR=1 : Goto RETOUR_ITMREF
    Endif
  Endif
Endif
Return
$RETOUR_ITMREF
# Issue 112754 - 2016-10-03 by SR : Services
# Si on est sur la zone article, on raze tout et on recommence
# Si on est sur le type d'artcle, on reste bloquĂŠ et on permet de changer la valeur de cette zone
If FONCTIONB = "POH"
  Raz [M:POH2]ITMREF(NOL), [M:POH2]PQHNUM(NOL), [M:POH2]PPDLIN(NOL), VALEUR
  # Issue 82533 - 2012-06-20 by GA
  Raz [M:POH2]ITMDES(NOL),ITMDES1(NOL),LINSTOFCY(NOL), PRHFCY(NOL),FCYADD(NOL),USEPLC(NOL),
&              UOM(NOL),QTYUOM(NOL),UOMPUUCOE(NOL),PUU(NOL),QTYPUU(NOL),STU(NOL),
&              QTYSTU(NOL),PJT(NOL),EXTRCPDAT(NOL)
  Affzo [M:POH2]
Endif
mkstat=1
Return

# Issue 15330 - 2011-12-27 by MUARN : ajout bouton tout inclure en PEC
# Issue 13072 - 2012-01-19 by MUARN : contrĂ´le mini de commande
Subprog INCLURE
#--------------------------------------------#
# Chargement des qtĂŠs prises par les besoins #
#--------------------------------------------#
Local Decimal WQTEUA
For I=0 To [M:PPI1]NBLIG-1
  # Issue 71069 - 2016-03-29 by MUARN : demande livraison
  # Issue 71069 - 2016-03-13 by MUARN : PJT
  If GPJTSNGDOC=2 & I=0 & [M:PPI1]TOTQTY=0 & GFONCTION<>"GESPOD"
    [M:PPI1]PJTDOC=[M:PPI1]WPJT(I)
  Elsif GPJTSNGDOC=2 & [M:PPI1]PJTDOC<>[M:PPI1]WPJT(I)
    Goto NEXT_I
  Endif
  # End issue 71069
  Call PCAL_QTY([M:PPI1]RMNEXTQTY(I),[M:PPI1]UOM,WQTEUA,[M:PPI1]PUU,
&            [M:PPI1]ITMREF,[M:PPI1]BPSNUM,1,GBIDD1) From TRTACHQTE1
  Read [ITP] ITP0=[M:PPI1]ITMREF;[M:PPI1]BPSNUM
  If fstat
    [M:PPI1]PICQTY(I)= [M:PPI1]RMNEXTQTY(I)
  Else
    If WQTEUA < [F:ITP]PURMINQTY
      Call PCAL_QTY([F:ITP]PURMINQTY, [M:PPI1]PUU, [M:PPI1]PICQTY(I), [M:PPI1]UOM,
&               [M:PPI1]ITMREF, [M:PPI1]BPSNUM,1,GBIDD1) From TRTACHQTE1
    Else
      [M:PPI1]PICQTY(I)= [M:PPI1]RMNEXTQTY(I)
    Endif
  Endif
  # 106430 - Purchase planning
  If GFONCTION="GESPOH"
    [M:PPI1]LINWEI(I) = [M:PPI1]ITMWEI * [M:PPI1]PICQTY(I)
    [M:PPI1]LINVOL(I) = [M:PPI1]ITMVOL * [M:PPI1]PICQTY(I)
  Endif
$NEXT_I # Issue 74069 - 2016-03-07 by MUARN : PJT
Next I
[M:PPI1]TOTQTY=sum([M:PPI1]PICQTY(0..[M:PPI1]NBLIG-1))
[M:PPI1]WEITOT=sum([M:PPI1]LINWEI(0..[M:PPI1]NBLIG-1))  # 106430.n
[M:PPI1]VOLTOT=sum([M:PPI1]LINVOL(0..[M:PPI1]NBLIG-1))  # 106430.n
Affzo [PPI1]TOTQTY,WEITOT,VOLTOT,10
Enable GSTAFIN
End

# Issue 15330 - 2011-12-27 by MUARN : ajout bouton tout exclure en PEC
Subprog EXCLURE
#------------------------------------#
# Raz de toutes les quantitĂŠs prises #
#------------------------------------#
# Issue 71069 - 2016-03-29 by MUARN : demande livraison
# Issue 71069 - 2016-03-07 by MUARN : pjt
If GFONCTION<>"GESPOD" : Raz [M:PPI1]PJTDOC : Endif
Raz [M:PPI1]TOTQTY, [M:PPI1]PICQTY
Raz [M:PPI1]LINWEI, [M:PPI1]LINVOL, [M:PPI1]WEITOT, [M:PPI1]VOLTOT  # 106430.n
Affzo [PPI1]TOTQTY,WEITOT,VOLTOT,10
End

###################################
$CHARG_LIG_CDE
#-------------------------------------------------------------------#
# Chargement de la ligne de commande Ă  partir de l'ĂŠcran de picking #
#-------------------------------------------------------------------#
#VPO 27/01/11 70999 on doit passer par une struct intermediaire PWO0
[F:PWO0]WIPTYP = [M:PPI1]WIPTYP(I)
[F:PWO0]WIPSTA = [M:PPI1]WIPSTA(I)
[F:PWO0]ITMREF = [M:PPI1]ITMREF      # FQ 73188 GA 04/2011 pb suite 70999
[F:PWO0]PUU    = [M:PPI1]PUU
If [M:PPI1]WIPNUM(I)<>"" [F:PWO0]WIPNUM = [M:PPI1]WIPNUM(I)
                         [F:PWO0]PSDLIN = 0
                    Else [F:PWO0]WIPNUM = [M:PPI1]VCRNUM(I)
                         [F:PWO0]PSDLIN = [M:PPI1]VCRLIN(I) : Endif
# Issue 42064 - 2011-12-27 by MUARN : ajout contre marque sur PEC
If [M:PPI1]WIPCOD(I)="SOF"
  [F:PWO0]WIPNUM = [M:PPI1]SOHNUM(I)
  [F:PWO0]PSDLIN = [M:PPI1]SOPLIN(I)
Endif
#----- Lecture BPARTNER si nĂŠcessaire -----#
If [F:BPR]BPRNUM<>[M:POH0]BPSNUM
  Read [BPR] BPR0=[M:POH0]BPSNUM
  If fstat  Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
Endif
#----- Lecture article si nĂŠcessaire -----#
If [F:ITM]ITMREF<>[M:PPI1]ITMREF
  Read [ITM] ITM0=[M:PPI1]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
#----- Chargement des dĂŠsignations article -----#
#Call CHARGE_ITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,WITMDES) From TRTX3
#If WITMDES="" WITMDES=[F:ITM]ITMDES1 : Endif
Call CHARGE_DEFITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,WITMDES, "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
#WITMDES1=[F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,WITMDES1, "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
#-----
[F:PWO0]PUU=[M:PPI1]PUU : Raz WPJT
#----- Chargement sections analytiques de la DA pour contrĂ´le -----#
Raz CCEPSD, WLINTEXPSD, WLINPURTYP
If [M:PPI1]WIPCOD(I)="POP"
  Read [PSD] PSD0=[M:PPI1]VCRNUM(I);[M:PPI1]VCRLIN(I)
  If fstat  Raz [F:PSD] : Endif
  Read [CAL] CAL0="PSD";0;[M:PPI1]VCRNUM(I);[M:PPI1]VCRLIN(I);0;"";1
  If fstat  Raz [F:CAL] : Endif
  If GNBDIE>0
    For J=1 To GNBDIE : CCEPSD+=[F:CAL]CCE(J-1) : Next J
  Endif
  WPJT=[F:PSD]PJT
  If [F:PSD]ITMDES<>""  WITMDES =[F:PSD]ITMDES  : Endif
  If [F:PSD]ITMDES1<>"" WITMDES1=[F:PSD]ITMDES1 : Endif
  WLINTEXPSD=[F:PSD]LINTEX
  WLINPURTYP=[F:PSD]LINPURTYP
Else
  WPJT=[M:PPI1]WPJT(I)
Endif
#-- Si prise en compte sous-traitance (SCx ou EOx) rupture Ă  chaque ligne --#
If find([M:PPI1]WIPTYP(I),4,13)
  CCEPSD=num$(I) : # Provoque la rupture
Endif
#----- Si 1Ă¨re fois -----#
If [M:POH2]PRHFCY(NOL)=""
  #VPO 27/01/11 70999 on doit passer par une struct intermediaire PWO0
  [F:PWO]=[F:PWO0]
  Gosub DEB_CHARG_LIG_CDE
  # Issue 71069 - 2013-08-21 by MUARN : PJT
  If GERR : Return : Endif
Endif
# Issue 116182 - 2016-06-21 by MUARN : ajout SOHNUM et SOPLIN pour contremarque
#----- Si rupture, fin de la ligne en cours et passage Ă  une autre ligne -----#
If  [M:POH2]PRHFCY(NOL)   <>[M:PPI1]STOFCY(I)                |
&   [M:POH2]LINSTOFCY(NOL)<>[M:PPI1]ORIFCY(I)                |
&   [M:POH2]SOHNUM(NOL)   <>[M:PPI1]SOHNUM(I)                |
&   [M:POH2]SOPLIN(NOL)   <>[M:PPI1]SOPLIN(I)                |
&  ([M:POH2]RETRCPDAT(NOL)<>[M:PPI1]ENDDAT(I) & ECLAT_DAT>1) |
&  (WVCRNUM               <>[M:PPI1]VCRNUM(I) & ECLAT_PSH>1) |
&  ([M:POH2]PJT(NOL)      <>WPJT              & ECLAT_PJT>1) |
&  ([M:POH2]LINPURTYP(NOL)<>WLINPURTYP        & ECLAT_LPT>1) |
&  (CCELIG                <>CCEPSD            & ECLAT_CCE>1) |
&  ([M:POH2]ITMDES(NOL)   <>WITMDES           & ECLAT_DES=2) |
&  ([M:POH2]ITMDES1(NOL)  <>WITMDES1          & ECLAT_DES=3) |
&  (WLINTEX               <>WLINTEXPSD        & ECLAT_DES=4)
  #-----
  Gosub FIN_CHARG_LIG_CDE                    : If GOK=0 | mkstat  Return : Endif
  Gosub CHARG_LIG_SUPPLEMENT From TRTACHSCO1 : If GOK=0 | mkstat  Return : Endif
  #-----
  Gosub NEW_LINE : If mkstat  Return : Endif
  # Issue 119291 - 2016-10-21 by SR : Ne pas garder les ĂŠventuelles infos de la SST prĂŠcĂŠdente
  [M:POH2]VCRTYPORI(NOL) = 1
  Raz [M:POH2]VCRNUMORI(NOL), VCRLINORI(NOL), VCRSEQORI(NOL),ITMREFORI(NOL)
  #VPO 27/01/11 70999 on doit passer par une struct intermediaire PWO0
  [F:PWO]=[F:PWO0]
  Gosub DEB_CHARG_LIG_CDE
  # Issue 71069 - 2013-08-21 by MUARN : PJT
  If GERR : Return : Endif
Else
  #VPO 18/02/11 71725 on doit passer par une struct intermediaire PWO0
  [F:PWO]=[F:PWO0]
Endif
#----- Conversion qtĂŠ prise en UA puis US -----#
WRETQTY=min([M:PPI1]PICQTY(I),[M:PPI1]RMNEXTQTY(I))
Call PCAL_QTY(WRETQTY,[M:PPI1]UOM,[F:PWO]QTYPUU,[F:PWO]PUU,
&             [M:PPI1]ITMREF,[M:PPI1]BPSNUM,3,GBIDD2) From TRTACHQTE1
WPICQTYPUU=WRETQTY*GBIDD2
Call PCAL_QTY(WRETQTY,[M:PPI1]UOM,[F:PWO]QTYSTU,[F:PWO]STU,
&             [M:PPI1]ITMREF,[M:PPI1]BPSNUM,1,GBIDD2) From TRTACHQTE1
WPICQTYSTU=[F:PWO]QTYSTU
If WRETQTY<>[M:PPI1]PICQTY(I)
  Call PCAL_QTY([M:PPI1]PICQTY(I),[M:PPI1]UOM,WPICQTYPUU,[F:PWO]PUU,
&               [M:PPI1]ITMREF,[M:PPI1]BPSNUM,3,GBIDD2) From TRTACHQTE1
  WPICQTYPUU=[M:PPI1]PICQTY(I)*GBIDD2
  Call PCAL_QTY([M:PPI1]PICQTY(I),[M:PPI1]UOM,WPICQTYSTU,[F:PWO]STU,
&               [M:PPI1]ITMREF,[M:PPI1]BPSNUM,1,GBIDD2) From TRTACHQTE1
Endif
WRETQTYSTU=[F:PWO]QTYSTU
#----- Mise Ă  jour qtĂŠ en UA et US -----#
[M:POH2]QTYPUU(NOL)+=WPICQTYPUU
[M:POH2]QTYSTU(NOL)+=WPICQTYSTU
[M:POH2]RETQTYSTU(NOL)+=[F:PWO]QTYSTU
#-----
If dim(WUOMFLG)>0 & find(WUOMFLG,1,2,3)
  [M:POH2]UOM(NOL)      =[F:PWO]PUU
  [M:POH2]UOMFLG(NOL)   =1
  [M:POH2]UOMPUUCOE(NOL)=1
  GCOEUOM=1
  If ECLAT_PSH=9  ECLAT_PSH=1 : Endif
  If ECLAT_CCE=9  ECLAT_CCE=1 : Endif
  WUOMFLG=0
Endif
#----- Mises Ă  jour si DA -----#
If [M:PPI1]WIPCOD(I)="POP"
  #----- Mise Ă  jour des prix, frais, remises et motif si DA et si pas prix AOF -----#
  If AOFFLG<>1 : # Pas de prix appel d'offre
    If NBRGR=0 : # Si premiĂ¨re fois : Transclasse pour rĂŠcupĂŠration zones spĂŠcifiques
      #----- Chargement comptes et sections analytiques -----#
      Call CHARG_ACCCCE(NOL,"[M:POH2]LINACC","","[M:POH2]CCE",
&                    "PSD",0,[F:PSD]PSHNUM,[F:PSD]PSDLIN,0,"") From TRTX3CPT
      #-----
      SAVPQHNUM=[M:POH2]PQHNUM(NOL)
      SAVPPDLIN=[M:POH2]PPDLIN(NOL)
      [M:POH2]=[F:PSD]
      [M:POH2]PQHNUM(NOL)    = SAVPQHNUM
      [M:POH2]PPDLIN(NOL)    = SAVPPDLIN
      [M:POH2]ITMREF(NOL)    = [M:PPI1]ITMREF
    # Issue 89832 GA 05/2013 DA multi-site, Raz de l'adresse ligne prĂŠcĂŠdente avant de changer de site de rcp
    If NOL>0 & [M:POH2]PRHFCY(NOL)<> "" & [M:POH2]PRHFCY(NOL)<>[M:PPI1]STOFCY(I)
       Raz [M:POH2]FCYADD(NOL)
    Endif
      [M:POH2]PRHFCY(NOL)    = [M:PPI1]STOFCY(I)

      [M:POH2]ITMDES(NOL)    = WITMDES
      [M:POH2]ITMDES1(NOL)   = WITMDES1
      [M:POH2]PJT(NOL)       = WPJT
      [M:POH2]LINPURTYP(NOL) = WLINPURTYP
      [M:POH2]PUU(NOL)       = [F:PWO]PUU
      [M:POH2]STU(NOL)       = [F:PWO]STU
      [M:POH2]QTYPUU(NOL)    = WPICQTYPUU
      [M:POH2]QTYSTU(NOL)    = WPICQTYSTU
      [M:POH2]RETQTYSTU(NOL) = [F:PWO]QTYSTU
      #----- Appel point d'entrĂŠe UOMPSHPOH pour rĂŠcup unitĂŠ de la DA -----#
      Gosub POINT_UOMPSHPOH From TRTACHCDE1
      #-----
      If GPURTEXPSH<>2  Raz [M:POH2]LINTEX(NOL) : Endif
      Raz [M:POH2]LINAMT(NOL), [M:POH2]LINBUY(NOL), [M:POH2]LINCLEFLG(NOL),
&         [M:POH2]FBUFLG(NOL)

      #----- Si 1Ă¨re fois, prix non nul et fournisseur identique : Chargement prix -----#
      If [F:PSD]NETPRI<>0 & [M:POH0]BPSNUM=[F:PSD]BPSNUM
        #----- Conversion prix unitaire si unitĂŠs DA et commande diffĂŠrentes -----#
        If [F:PSD]PUU<>[M:POH2]UOM(NOL)
          Call PCAL_QTY([M:POH2]QTYUOM(NOL),[M:POH2]UOM(NOL),MT1,[F:PSD]PUU,
&                       [M:POH2]ITMREF(NOL),[M:POH0]BPSNUM,1,MT2) From TRTACHQTE1
          [M:POH2]GROPRI(NOL)=arr([M:POH2]GROPRI(NOL)*MT2,10^-GDECPRI)
          For J=1 To 9
            If evalue("dim([M:POH2]DISCRGVAL"+num$(J)+"(NOL))")>0
              If GDISCRGTYP(J-1)=1 & GCLCRUL(J-1)=1
&               MT1=evalue("[M:POH2]DISCRGVAL"+num$(J)+"(NOL)*MT2")
                Call ARRDEV(MT1,[M:POH1]CUR) From TRTDIV
                Assign "[M:POH2]DISCRGVAL"+num$(J)+"(NOL)" With MT1
              Endif
              DISCRGVAL(J-1)=evalue("[M:POH2]DISCRGVAL"+num$(J)+"(NOL)")
            Endif
          Next J
          If dim(GCALNETLIN)>0  GCALNETLIN=NOL+1      : Endif
          If dim(GCALNETABR)>0  GCALNETABR="[M:POH2]" : Endif
          Call CALNET(2,[F:BPS]PLISTC,[M:POH2]GROPRI(NOL),DISCRGVAL,[M:POH2]QTYUOM(NOL),
&                       [M:POH2]NETPRI(NOL),[M:POH1]CUR) From TRTPRICE
        Endif
        #----- Conversion prix si devises DA et commande diffĂŠrentes -----#
        If [M:POH1]CUR<>[F:PSD]CUR
          Call CONVERT2([F:PSD]CUR,[M:POH1]CUR,GLOCALDEV,[M:POH1]CHGTYP,[M:POH0]ORDDAT,
&                       [M:POH2]GROPRI(NOL),MT2,STAT) From TRTDEV
          [M:POH2]GROPRI(NOL)=arr(MT2,10^-GDECPRI)
          For J=1 To 9
            If evalue("DIM([M:POH2]DISCRGVAL"+num$(J)+"(NOL))")>0
              If GFMTREM(J-1)="M"
                MT1=evalue("[M:POH2]DISCRGVAL"+num$(J)+"(NOL)")
                Call CONVERT([F:PSD]CUR,[M:POH1]CUR,GLOCALDEV,[M:POH1]CHGTYP,[M:POH0]ORDDAT,
&                            MT1,MT2,STAT) From TRTDEV
                Assign "[M:POH2]DISCRGVAL"+num$(J)+"(NOL)" With MT2
              Endif
              DISCRGVAL(J-1)=evalue("[M:POH2]DISCRGVAL"+num$(J)+"(NOL)")
            Endif
          Next J
          If dim(GCALNETLIN)>0  GCALNETLIN=NOL+1      : Endif
          If dim(GCALNETABR)>0  GCALNETABR="[M:POH2]" : Endif
          Call CALNET(2,[F:BPS]PLISTC,[M:POH2]GROPRI(NOL),DISCRGVAL,[M:POH2]QTYUOM(NOL),
&                       [M:POH2]NETPRI(NOL),[M:POH1]CUR) From TRTPRICE
        Endif
        [M:POH2]LINFLG(NOL)=3 : # Recherche tarif annulĂŠe
      Else
        Raz [M:POH2]GROPRI(NOL), [M:POH2]NETPRI(NOL), [M:POH2]PRIREN(NOL)
        For J=1 To 9
          If evalue("dim([M:POH2]DISCRGVAL"+num$(J)+"(NOL))")>0
            Assign "[M:POH2]DISCRGVAL"+num$(J)+"(NOL)" With 0
            Assign "[M:POH2]DISCRGREN"+num$(J)+"(NOL)" With 0
          Endif
        Next J
      Endif
      If [M:POH0]BPSNUM<>[F:PSD]BPSNUM
        [M:POH2]LINFLG(NOL)=0 : # Recherche tarif activĂŠe
      Endif
    Else       : # Si plusieurs DA sur la mĂŞme ligne : Effacement prix ...
      Raz [M:POH2]GROPRI(NOL), [M:POH2]NETPRI(NOL), [M:POH2]PRIREN(NOL)
      For J=1 To 9
        If evalue("dim([M:POH2]DISCRGVAL"+num$(J)+"(NOL))")>0
          Assign "[M:POH2]DISCRGVAL"+num$(J)+"(NOL)" With 0
          Assign "[M:POH2]DISCRGREN"+num$(J)+"(NOL)" With 0
        Endif
      Next J
      [M:POH2]LINFLG(NOL)=0 : # Recherche tarif activĂŠe
    Endif
  Endif
Endif
#----- Effacement lien texte ligne DA si plusieurs besoins -----#
If NBRGR=1 & ECLAT_DES<>4  Raz [M:POH2]LINTEX(NOL) : Endif
#----- Mise Ă  jour date de rĂŠception -----#
If [M:POH2]RETRCPDAT(NOL)>[M:PPI1]ENDDAT(I)
  [M:POH2]RETRCPDAT(NOL)=[M:PPI1]ENDDAT(I)
Endif
#----- Ecriture fichier de travail -----#
NBRGR+=1
Write [PWO]
If fstat GOK=0 : Endif
Return

$NEW_LINE
#----------------#
# Nouvelle ligne #
#----------------#
# ------------------------------------------------------------------------ #
# Cette fonction est utilisĂŠe par TRTACHSCO1 pour ajout d'une ligne POH2   #
# ------------------------------------------------------------------------ #
nolign+=1 : NOL+=1
status=73 : Call INSERE("POPLIN") From TABLEAUX  : If mkstat  Return : Endif
If dim([M:POH2]ITMREF)<[M:POH2]NBLIG+2  mkstat=1 : Return : Endif
Insa NOL,1,[M:POH2]NBLIG [M:POH2]NBLIG : [M:POH2]NBLIG+=1
[M:PPI1]NBCRELIG+=1
J=NOL : L=SAVNOLIGN-1 : Gosub COPIE_LIG From SUBPOHA
status=0 : Call LINNUM("POPLIN")  From TABLEAUX
[M:POH2]POHCOU+=1 : [M:POH2]POHLIN(NOL)=[M:POH2]POHCOU
[F:PWO0]LINNUM=[M:POH2]POHLIN(NOL)  # FQ 73188 GA 04/2011 avant [F:PWO]LINNUM
Raz [M:POH2]QTYPUU(NOL),    [M:POH2]QTYSTU(NOL), [M:POH2]LINFLG(NOL),
&   [M:POH2]PREQTYPUU(NOL), [M:POH2]LINPURTYP(NOL)
Gosub RAZ_LINACC From SUBPOH
Gosub RAZ_CCE    From SUBPOH
If dim(AOFFLG)>0 & AOFFLG=1  [M:POH2]LINFLG(NOL)=3 : Endif
Return

$DEB_CHARG_LIG_CDE
#------------------------------------#
# DĂŠbut chargement ligne de commande #
#------------------------------------#
#----- Lecture article si nĂŠcessaire -----#
If [F:ITM]ITMREF<>[M:PPI1]ITMREF
  Read [ITM] ITM0=[M:PPI1]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
#-----
[F:PWO]ITMREF   = [M:PPI1]ITMREF
[F:PWO]PUU      = [M:PPI1]PUU
[F:PWO]STU      = [F:ITM]STU
[F:PWO]WIPTYP   = [M:PPI1]WIPTYP(I)
[F:PWO]WIPSTA   = [M:PPI1]WIPSTA(I)
If [M:PPI1]WIPNUM(I)<>""
  [F:PWO]WIPNUM = [M:PPI1]WIPNUM(I)
  [F:PWO]PSDLIN = 0
Else
  [F:PWO]WIPNUM = [M:PPI1]VCRNUM(I)
  [F:PWO]PSDLIN = [M:PPI1]VCRLIN(I)
Endif
#-----

  # Issue 71069 - 2013-08-21 by MUARN : PJT
  # Si premiĂ¨re ligne & pas de code affaire Ă  l'entĂŞte on alimente le code affaire Ă  l'entĂŞte
  If [M:POH2]NBLIG <1 & [M:POH1]PJTH = "" & GPJTSNGDOC = 2
     [M:POH1]PJTH = WPJT
     WZONE = "[M:POH1]PJTH"
     If func TRTPJT.IS_PJT_AVAILABLE(WPJT,WZONE, SWMESS) = G_NON Then
      Call PJT_ADD_MSG(WPJT, SWMESS) From TRTPJT
      GERR = 1
      OK = 0
      GMESSAGE = SWMESS
      Raz [M:POH1]PJTH
      Return
    Endif
  Else
    [M:POH2]PJT(NOL)      =WPJT
    WZONE = "[M:POH2]PJT"
    If func TRTPJT.IS_PJT_AVAILABLE(WPJT,WZONE, SWMESS) = G_NON Then
      Call PJT_ADD_MSG(WPJT, SWMESS) From TRTPJT
      GERR = 1
      OK = 0
      GMESSAGE = SWMESS
      Raz [M:POH1]PJTH
      Return
    Endif
  Endif
  # FIN Issue 71069 - 2013-08-21 by MUARN

[M:POH2]PRHFCY(NOL)   =[M:PPI1]STOFCY(I)
[M:POH2]LINSTOFCY(NOL)=[M:PPI1]ORIFCY(I)
CCELIG                =CCEPSD
[M:POH2]RETRCPDAT(NOL)=[M:PPI1]ENDDAT(I)
WVCRNUM               =[M:PPI1]VCRNUM(I)
NBRGR                 =0
[M:POH2]ITMREF(NOL)   =[F:PWO]ITMREF
[M:POH2]ITMDES(NOL)   =WITMDES
[M:POH2]ITMDES1(NOL)  =WITMDES1
WLINTEX               =WLINTEXPSD
[M:POH2]PJT(NOL)      =WPJT
[M:POH2]LINPURTYP(NOL)=WLINPURTYP
[M:POH2]UOM(NOL)      =[F:PWO]PUU
[M:POH2]PUU(NOL)      =[F:PWO]PUU
[M:POH2]STU(NOL)      =[F:PWO]STU
# Issue 42064 - 2011-12-27 by MUARN : contre marque en PEC
[M:POH2]SOHNUM(NOL)   = [M:PPI1]SOHNUM(I)
[M:POH2]SOPLIN(NOL)   = [M:PPI1]SOPLIN(I)
[M:POH2]SOQSEQ(NOL)   = [M:PPI1]SOPLIN(I)
# Issue 120586 - 2016-12-27 by MUARN : contre marque
If [M:POH2]SOHNUM(NOL)<>""
  Read [SOQ] SOQ0=[M:POH2]SOHNUM(NOL);[M:POH2]SOPLIN(NOL);[M:POH2]SOQSEQ(NOL)
  [M:POH2]ORI(NOL)=[F:SOQ]FMI
Else
  [M:POH2]ORI(NOL)=1
Endif
[M:POH2]UOMPUUCOE(NOL)=1
#----- Suite chargement pour sous-traitance -----#
If find([F:PWO]WIPTYP,4,13)
  Gosub CHARG_LIG_STT From TRTACHSCO1
Else
  [M:POH2]LINTYP(NOL)=1  : # Ligne classique (indĂŠpendante)
Endif
Return

$FIN_CHARG_LIG_CDE
#----------------------------------#
# Fin chargement ligne de commande #
#----------------------------------#
# Issue 94186 - 2013-11-08 by MUARN : poids/volume
Local    Decimal  WOLDQTYSTU
Local    Decimal  WCPRAMT
Local    Integer  WSTAT   # Issue 100343 - 2014-05-23 by MUARN

WOLDQTYSTU = [M:POH2]QTYSTU(NOL)

#----- Chargement site d'expĂŠdition si nĂŠcessaire -----#
If [M:POH0]BETFCY=2 & [M:POH2]LINSTOFCY(NOL)=""
  If [F:ITM]ITMREF<>[M:POH2]ITMREF(NOL)
    Read [ITM] ITM0=[M:POH2]ITMREF(NOL) : If fstat : Raz [F:ITM] : Endif
  Endif
  If [F:ITM]STOMGTCOD>1
    Look [ITF] ITF0=[M:POH2]ITMREF(NOL);[M:POH1]STOFCY
    If !fstat
      [M:POH2]LINSTOFCY(NOL)=[M:POH1]STOFCY
    Endif
  Else
    [M:POH2]LINSTOFCY(NOL)=[M:POH1]STOFCY
  Endif
Endif
#----- Chargement code adresse par dĂŠfaut du site de rĂŠception -----#
If [F:FCY]FCY<>[M:POH2]PRHFCY(NOL)
  Read [FCY] FCY0=[M:POH2]PRHFCY(NOL) : If fstat Raz [F:FCY] : Endif
Endif
# Issue 87616 - 2013-01-31 by MUARN : en picking si 2 sites diffĂŠrents on garde l'adresse du site prĂŠcĂŠdent
#If [M:POH2]FCYADD(NOL)=""          # FQ 73618 GA 05/2011 ne pas ĂŠcraser si dĂŠjĂ  renseignĂŠ
If [M:POH2]FCYADD(NOL)="" |( NOL>0 & [M:POH2]PRHFCY(NOL)<> [M:POH2]PRHFCY(NOL-1))
   [M:POH2]FCYADD(NOL)=[F:FCY]BPAADD
Endif
#-----
If [F:ITM]ITMREF<>[M:POH2]ITMREF(NOL)
  Read [ITM] ITM0=[M:POH2]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITF]ITMREF<>[M:POH2]ITMREF(NOL) | [F:ITF]STOFCY<>[M:POH2]PRHFCY(NOL)
  Read [ITF] ITF0=[M:POH2]ITMREF(NOL);[M:POH2]PRHFCY(NOL) : If fstat Raz [F:ITF] : Endif
Endif
If [M:POH2]LINBUY(NOL)="" | [M:POH2]LINTYP(NOL)=1
  If [F:ITM]BUY<>"" [M:POH2]LINBUY(NOL)=[F:ITM]BUY : Endif
  If [F:ITF]BUY<>"" [M:POH2]LINBUY(NOL)=[F:ITF]BUY : Endif
Endif
#----- si lignes sous-traitance, dĂŠlai rĂŠappro dĂŠjĂ  chargĂŠ ! -----#
If !find([M:POH2]VCRTYPORI(NOL),10,36)
  If [F:ITM]OFS<>0  [M:POH2]OFS(NOL)   =[F:ITM]OFS : Endif
  If [F:ITF]OFS<>0  [M:POH2]OFS(NOL)   =[F:ITF]OFS : Endif
Endif
#----- Chargement de l'indicateur "GĂŠrĂŠ en stock" -----#
If [F:ITM]STOMGTCOD>1
 # Issue 112754 - 2016-09-27 by SR : Services
#  If [F:ITF]ITMREF<>VALEUR | [F:ITF]STOFCY<>[M:POH2]PRHFCY(NOL)
#   Read [ITF] ITF0=VALEUR;[M:POH2]PRHFCY(NOL)
  If [F:ITF]ITMREF<>[M:POH2]ITMREF(NOL) | [F:ITF]STOFCY<>[M:POH2]PRHFCY(NOL)
    Read [ITF] ITF0=[M:POH2]ITMREF(NOL);[M:POH2]PRHFCY(NOL)
    If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
  Endif
# End issue 112754
  [M:POH2]STOMGTCOD(NOL)=[F:ITF]STOMGTCOD
  If [F:ITF]QUAFLG>1  [M:POH2]QUAFLG(NOL)=2              # hcb V6CQ
                Else  [M:POH2]QUAFLG(NOL)=1              # hcb V6CQ
  Endif                                                  # hcb V6CQ
Else
  [M:POH2]STOMGTCOD(NOL)=[F:ITM]STOMGTCOD
  [M:POH2]QUAFLG(NOL)=1                                  # hcb V6CQ
Endif
#-----
If dim([M:POH2]TSICOD1(NOL))>0 [M:POH2]TSICOD1(NOL)=[F:ITM]TSICOD(0) : Endif
If dim([M:POH2]TSICOD2(NOL))>0 [M:POH2]TSICOD2(NOL)=[F:ITM]TSICOD(1) : Endif
If dim([M:POH2]TSICOD3(NOL))>0 [M:POH2]TSICOD3(NOL)=[F:ITM]TSICOD(2) : Endif
If dim([M:POH2]TSICOD4(NOL))>0 [M:POH2]TSICOD4(NOL)=[F:ITM]TSICOD(3) : Endif
If dim([M:POH2]TSICOD5(NOL))>0 [M:POH2]TSICOD5(NOL)=[F:ITM]TSICOD(4) : Endif
#----- Chargement quantitĂŠ minimum d'achat -----#
If [F:ITP]ITMREF<>[M:POH2]ITMREF(NOL) | [F:ITP]BPSNUM<>[M:POH0]BPSNUM
  Read [ITP] ITP0=[M:POH2]ITMREF(NOL);[M:POH0]BPSNUM
  If fstat  Raz [F:ITP] : Endif
Endif
If [F:ITP]ITMREF<>""
  If [F:ITP]QUAFLG>1  [M:POH2]QUAFLG(NOL)=2
                Else  [M:POH2]QUAFLG(NOL)=1 : Endif
  Call PCAL_QTY([F:ITP]PURMINQTY,[F:ITP]PUU,[M:POH2]PURMINQTY(NOL),[M:POH2]PUU(NOL),
&               [M:POH2]ITMREF(NOL),[M:POH0]BPSNUM,1,GBIDD2) From TRTACHQTE1
Else
  [M:POH2]PURMINQTY(NOL)=0
Endif
#-----
Local Decimal QTEUA, SAV_QTEUA
If [M:POH2]QTYPUU(NOL)<>0
  Call PCAL_QTY([M:POH2]QTYPUU(NOL),[M:POH2]PUU(NOL),
&               [M:POH2]QTYSTU(NOL),[M:POH2]STU(NOL),
&               [M:POH2]ITMREF(NOL),[M:POH0]BPSNUM,1,GBIDD1) From TRTACHQTE1
  [L]QTEUA=[M:POH2]QTYPUU(NOL)
Else
  Call PCAL_QTY([M:POH2]QTYSTU(NOL),[M:POH2]STU(NOL),
&               [M:POH2]QTYPUU(NOL),[M:POH2]PUU(NOL),
&               [M:POH2]ITMREF(NOL),[M:POH0]BPSNUM,3,GBIDD1) From TRTACHQTE1
  [L]QTEUA=[M:POH2]QTYSTU(NOL)*GBIDD1
Endif
#----- Appel au point d'entrĂŠe permettant de choisir l'arrondi de la qtĂŠ UA -----#
SAV_QTEUA=QTEUA
Gosub POINT_PURQTYRND From SUBPOHB
[M:POH2]QTYPUU(NOL)=[L]QTEUA
#----- Recalcul quantitĂŠ US aprĂ¨s arrondi ĂŠventuel de l'UA -----#
Call PCAL_QTY([M:POH2]QTYPUU(NOL),[M:POH2]PUU(NOL),
&             [M:POH2]QTYSTU(NOL),[M:POH2]STU(NOL),
&             [M:POH2]ITMREF(NOL),[M:POH0]BPSNUM,1,GBIDD1) From TRTACHQTE1
#----- Si qtĂŠ US infĂŠrieure au besoin pris en compte, ajuster qtĂŠs Ă  la hausse -----#
If [M:POH2]QTYSTU(NOL)<[M:POH2]RETQTYSTU(NOL)
  QTEARR=arr(SAV_QTEUA,10^-WNBDEC)
  If QTEARR>=SAV_QTEUA-10^-(WNBDEC+3)
    [M:POH2]QTYPUU(NOL)=QTEARR
  Else
    [M:POH2]QTYPUU(NOL)=QTEARR+10^-WNBDEC
  Endif
  Call PCAL_QTY([M:POH2]QTYPUU(NOL),[M:POH2]PUU(NOL),
&               [M:POH2]QTYSTU(NOL),[M:POH2]STU(NOL),
&               [M:POH2]ITMREF(NOL),[M:POH0]BPSNUM,1,GBIDD1) From TRTACHQTE1
Endif
#-----
[M:POH2]QTYUOM(NOL)=[M:POH2]QTYPUU(NOL)*(1/[M:POH2]UOMPUUCOE(NOL))
Call QTEARR([M:POH2]QTYUOM(NOL),[M:POH2]UOM(NOL)) From TRTDIV
[M:POH2]PREQTYPUU(NOL)=[M:POH2]QTYPUU(NOL)
#-----
If [M:POH2]RETRCPDAT(NOL)<[M:POH0]ORDDAT  [M:POH2]RETRCPDAT(NOL)=[M:POH0]ORDDAT : Endif
[M:POH2]EXTRCPDAT(NOL)=[M:POH2]RETRCPDAT(NOL)
#----- Recherche tarif si nĂŠcessaire avec rĂŠcupĂŠration ĂŠventuelle d'un dĂŠlai -----#
If [M:POH2]LINFLG(NOL)=0 & [M:POH2]LINTYP(NOL)<>2
  GPUU=[M:POH2]PUU(NOL) : Call RECH_TARIF ("POH",NOL) From TRTACHTAR1
Elsif [M:POH2]LINTYP(NOL)=2
  #----- Effacement des ĂŠlĂŠments tarif si article composĂŠ (produit fini) -----#
  Raz [M:POH2]GROPRI(NOL), [M:POH2]NETPRI(NOL), [M:POH2]PRIREN(NOL)
  For J=0 To 8
    If evalue("dim([M:POH2]DISCRGVAL"+num$(J+1)+"(NOL))")>0
      Assign "[M:POH2]DISCRGVAL"+num$(J+1)+"(NOL)" With 0
      Assign "[M:POH2]DISCRGREN"+num$(J+1)+"(NOL)" With 0
    Endif
  Next J
  Raz [M:POH2]LINAMT(NOL),  [M:POH2]LINATI(NOL),  [M:POH2]LINATIAMT(NOL)
  Raz [M:POH2]CLCAMT1(NOL), [M:POH2]CLCAMT2(NOL), [M:POH2]CLCAMT3(NOL)
  If dim([M:POH2]CLCAMT4)>0  Raz [M:POH2]CLCAMT4(NOL) : Endif
  If dim([M:POH2]CLCAMT5)>0  Raz [M:POH2]CLCAMT5(NOL) : Endif
  If dim([M:POH2]CLCAMT6)>0  Raz [M:POH2]CLCAMT6(NOL) : Endif
  If dim([M:POH2]CLCAMT7)>0  Raz [M:POH2]CLCAMT7(NOL) : Endif
  # Issue 117079 - 2016-06-15 by MUARN : ne pas effacer codes taxe
  #----- Effacement de codes taxes -----#
  #Raz [M:POH2]VAT1(NOL), [M:POH2]VAT2(NOL), [M:POH2]VAT3(NOL)
  #If dim([M:POH2]TAXRCP)>0   Raz [M:POH2]TAXRCP(NOL)  : Endif
  #If dim([M:POH2]TAXISS)>0   Raz [M:POH2]TAXISS(NOL)  : Endif
  #If dim([M:POH2]TAXOTH1)>0  Raz [M:POH2]TAXOTH1(NOL) : Endif
  #If dim([M:POH2]TAXOTH2)>0  Raz [M:POH2]TAXOTH2(NOL) : Endif
Endif
If [M:POH2]LINFLG(NOL)=1 [M:POH2]LINFLG(NOL)=2 : Endif
#----- Ajustement date thĂŠorique de rĂŠception en fonction des indisponibilitĂŠs -----#
If [M:POH2]LINTYP(NOL)<>4
  Call CTL_JOU2([M:POH2]RETRCPDAT(NOL),[M:POH0]ORDDAT,[M:POH2]OFS(NOL)) From TRTACHCDE1
  If mkstat
    GMESSAGE=mess(245,194,1)-[M:POH2]PRHFCY(NOL)+"\"+GMESSAGE
    GMESSAGE=format$("D:"+GFMDAT,[M:POH2]RETRCPDAT(NOL))-GMESSAGE
    Call MESSAGE(GMESSAGE) From GESECRAN
  Endif
  Raz mkstat, GMESSAGE
  [M:POH2]EXTRCPDAT(NOL)=[M:POH2]RETRCPDAT(NOL)
#----- Pour les matiĂ¨res fournies, on reprend les valeurs du service -----#
Else
  [M:POH2]EXTRCPDAT(NOL)=[M:POH2]EXTRCPDAT(max(NOL-1,0))
  [M:POH2]RETRCPDAT(NOL)=[M:POH2]RETRCPDAT(max(NOL-1,0))
  [M:POH2]OFS      (NOL)=[M:POH2]OFS      (max(NOL-1,0))
Endif
#----- Relecture fichiers si nĂŠcessaire -----#
If [F:BPR]BPRNUM<>[M:POH0]BPSNUM
  Read [BPR] BPR0=[M:POH0]BPSNUM      : If fstat Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[M:POH0]BPSNUM
  Read [BPS] BPS0=[M:POH0]BPSNUM      : If fstat Raz [F:BPS] : Endif
Endif
If [F:ITM]ITMREF<>[M:POH2]ITMREF(NOL)
  Read [ITM] ITM0=[M:POH2]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITP]ITMREF<>[M:POH2]ITMREF(NOL) & [F:ITP]BPSNUM<>[M:POH0]BPSNUM
  Read [ITP] ITP0=[M:POH2]ITMREF(NOL);[M:POH0]BPSNUM : If fstat Raz [F:ITP] : Endif
Endif
#----- RĂŠcupĂŠration des liens texte article ou article-fournisseur -----#
If left$([M:POH2]LINTEX(NOL),3)="PSD"
  Call DUP_CLOB("POQ",[M:POH2]LINTEX(NOL),STAT) From TRTX3TEX
  If STAT<1  Raz [M:POH2]LINTEX(NOL) : Endif
Endif
If left$([M:POH2]LINTEX(NOL),3)<>"POQ"
  If [F:ITP]TEX<>""
    [M:POH2]LINTEX(NOL)=[F:ITP]TEX
  Else
    [M:POH2]LINTEX(NOL)=[F:ITM]PURTEX
  Endif
Endif
#----- Chargement indicateur modif du coef -----#
Gosub CHARG_COEFLG From SUBPOH
#----- Initialisation des comptes et du type d'achat -----#
If [M:POH2]LINACC1(NOL)="" & [M:POH2]LINACC2(NOL)="" & [M:POH2]LINACC3(NOL)=""
  # Issue 70985 - 2012-03-16 by MUARN : landed cost dĂŠplacĂŠ dans SUBPOHB nombre de lignes
  #Call INIT_COMPTES_LIGNE (NOL) From SUBPOH
  Call INIT_COMPTES_LIGNE(NOL) From SUBPOHB
Endif
If [M:POH2]LINPURTYP(NOL)=0
  Call D_LINPURTYP([M:POH2]LINPURTYP(NOL)) From SUBPOH
Endif

If GNBDIE>0
#----- Initialisation sections analytiques si nĂŠcessaire -----#
  # Issue X3-111565 - 2018-10-09 by SR : Lecture du document d'origine pour INISEC "POP"
  If clalev([F:MFO]) & GMODU(8)=2 & find([M:POH2]LINTYP(NOL),1,3)
    If [M:POH2]VCRTYPORI(NOL)=10
      If [F:MFO]MFGNUM   <>[M:POH2]VCRNUMORI(NOL) |
&        [F:MFO]OPENUM   <>[M:POH2]VCRLINORI(NOL) |
&        [F:MFO]OPESPLNUM<>[M:POH2]VCRSEQORI(NOL)
        Read [MFO] MFO0=[M:POH2]VCRNUMORI(NOL);[M:POH2]VCRLINORI(NOL);[M:POH2]VCRSEQORI(NOL)
        If fstat  Raz [F:MFO] : Endif
      Endif
    Else
      Raz [F:MFO]
    Endif
  Endif
  #----- Lecture de l'article sous-traitĂŠ si sous-traitance Ă  cause de l'INISEC "POP" -----#
  If clalev([F:SCI]) & [M:POH2]LINTYP(NOL)=2
    If [M:POH2]VCRTYPORI(NOL)=36
      If [F:SCI]SCONUM <>[M:POH2]VCRNUMORI(NOL) |
&        [F:SCI]SCILIN <>[M:POH2]VCRLINORI(NOL)
        Read [SCI] SCI0=[M:POH2]VCRNUMORI(NOL);[M:POH2]VCRLINORI(NOL)
        If fstat  Raz [F:SCI] : Endif
      Endif
    Endif
  Endif
  #----- Lecture de l'opĂŠration si sous-traitance Ă  cause de l'INISEC "POP" -----#
  If clalev([F:SCS]) & [M:POH2]LINTYP(NOL)=3
    If [M:POH2]VCRTYPORI(NOL)=36
      If [F:SCS]SCONUM <>[M:POH2]VCRNUMORI(NOL) |
&        [F:SCS]SCILIN <>[M:POH2]VCRLINORI(NOL) |
&        [F:SCS]SCSLIN <>[M:POH2]VCRSEQORI(NOL)
        Read [SCS] SCS0=[M:POH2]VCRNUMORI(NOL);[M:POH2]VCRLINORI(NOL);[M:POH2]VCRSEQORI(NOL)
        If fstat  Raz [F:SCS] : Endif
      Endif
    Endif
  Endif
  #----- Lecture du composant si sous-traitance Ă  cause de l'INISEC "POP" -----#
  If clalev([F:SCM]) & [M:POH2]LINTYP(NOL)=4
    If [M:POH2]VCRTYPORI(NOL)=36
      If [F:SCM]SCONUM <>[M:POH2]VCRNUMORI(NOL) |
&        [F:SCM]SCILIN <>[M:POH2]VCRLINORI(NOL) |
&        [F:SCM]SCMLIN <>[M:POH2]VCRSEQORI(NOL)
        Read [SCM] SCM0=[M:POH2]VCRNUMORI(NOL);[M:POH2]VCRLINORI(NOL);[M:POH2]VCRSEQORI(NOL)
        If fstat  Raz [F:SCM] : Endif
      Endif
    Else
      Raz [F:SCM]
    Endif
  Endif
  #----- Lecture ligne commande vente contremarque Ă  cause de l'INISEC "POID" -----#
  If GMODU(5)=2 & [M:POH2]SOHNUM(NOL)<>""
    If [F:SOP]SOHNUM<>[M:POH2]SOHNUM(NOL) |
&      [F:SOP]SOPLIN<>[M:POH2]SOPLIN(NOL) |
&      [F:SOP]SOPSEQ<>[M:POH2]SOQSEQ(NOL)
      Read [SOP] SOP0=[M:POH2]SOHNUM(NOL);[M:POH2]SOPLIN(NOL);[M:POH2]SOQSEQ(NOL)
      If fstat  Raz [F:SOP] : Endif
    Endif
  Elsif GMODU(5)=2
    Raz [F:SOP]
  Endif
# End issue X3-111565
  For J=1 To GNBDIE
    If evalue("[M:POH2]CCE"+num$(J)+"(NOL)")=""
      Call INIT_CCE(SECTION,J,"POP","[M:POH2]LINACC",NOL) From TRTX3CPT
      Assign "[M:POH2]CCE"+num$(J)+"(NOL)" With SECTION
    Endif
  Next J
Endif
#-----
If GACTDEB=2
  If !varinit([M:POH2]EECINCRAT,NOL)  [M:POH2]EECINCRAT(NOL)=[F:BPS]EECINCRAT : Endif
Endif
#-----
If !varinit([M:POH2]ORICRY,NOL)  [M:POH2]ORICRY(NOL) =[F:BPR]CRY    : Endif
If !varinit([M:POH2]LINBUY,NOL)  [M:POH2]LINBUY(NOL) =[M:POH1]BUY   : Endif
If !varinit([M:POH2]WAPPFLG,NOL) [M:POH2]WAPPFLG(NOL)=1             : Endif
#----- Alimentation codes taxe si nĂŠcessaire -----#
If [M:POH2]LINTYP(NOL)<>2
  Call ALIVATCOD(2,[M:POH0]BPSNUM,[M:POH2]ITMREF(NOL),"POH2",NOL) From TRTX3
Endif

# Issue 94186 - 2013-11-08 by MUARN : poids/volume
If [M:POH2]LINTYP(NOL)<2
  Call CONVERT_VOUWEU("POH2",NOL,[M:POH2]LINWEU(NOL),[M:POH2]LINVOU(NOL),[M:POH2]QTYSTU(NOL),WOLDQTYSTU) From STCLIB
Else
  Call CONVERT_VOUWEU("POH2",NOL,[M:POH2]LINWEU(NOL),[M:POH2]LINVOU(NOL),[M:POH2]QTYSTU(NOL),0) From STCLIB
Endif
If !GIMPORT Affzo [POH2]QTYVOU(NOL),QTYWEU(NOL) : Endif

# Issue 94186 - 2013-11-08 by MUARN : donnĂŠes landed cost
# Issue 90991 - 2013-10-23 by MUARN : maj donnĂŠes site
# Issue 95686 - 2014-01-08 by MUARN : landed cost dĂŠsactivĂŠs en sous traitance
If [M:POH2]LINTYP(NOL)>1
 Raz [M:POH2]STCNUM(NOL), [M:POH2]CPRAMT(NOL)
 [M:POH2]CPRCOE(NOL)=1
Else
  Call RECH_COST([M:POH2]PRHFCY(NOL),[M:POH0]BPSNUM, [M:POH2]ITMREF(NOL), [M:POH2]CPRCOE(NOL), WCPRAMT, [M:POH2]STCNUM(NOL)) From STCLIB
  If GLOCALDEV <> GSYSCUR
    Call CONVERT2(GSYSCUR,GLOCALDEV, GLOCALDEV,[M:POH1]CHGTYP,[M:POH0]ORDDAT,
&                    WCPRAMT,WCPRAMT,WSTAT) From TRTDEV
    [M:POH2]CPRAMT(NOL)=arr(WCPRAMT,10^-GDECPRI)
  Else
    [M:POH2]CPRAMT(NOL)=WCPRAMT
  Endif
Endif
If [M:POH2]STCNUM(NOL)<> ""
  Diszo [POH2]CPRAMT(NOL), CPRCOE(NOL), CPR(NOL)
Else
  Actzo [POH2]CPRAMT(NOL), CPRCOE(NOL), CPR(NOL)
Endif
Affzo [POH2]CPRCOE(NOL), CPRAMT(NOL), NETCUR(NOL), CPRCUR(NOL), STCNUM(NOL)

#----- Traitement aprĂ¨s ligne pour lignes aprĂ¨s ligne courante -----#
If NOL+1>SAVNOLIGN  Call APRES_NBLIG From SUBPOH : Endif
Return


$TARIF_AOF
#-----------------------------------------------#
# Initialisation tarif et date prĂŠvue livraison #
# Ă  partir de l'appel d'offre                   #
#-----------------------------------------------#
If [M:POH2]PQHNUM(NOL)=""       |
&  [F:PPH]PLISTC<>[F:BPS]PLISTC |
&  [F:PPD]PRI=0 Return : Endif
Local Decimal  MT1, MT2, DISCRGVAL(0..8)
Local Integer  STAT
Local Shortint I, J
If [F:PPD]PRIDIV=0 [F:PPD]PRIDIV=1 : Endif
[M:POH2]GROPRI(NOL)=[F:PPD]PRI/[F:PPD]PRIDIV
[M:POH2]PRIREN(NOL)=GUPDPRIPUR
For J=1 To 9
  If evalue ("DIM([M:POH2]DISCRGVAL"+num$(J)+"(NOL))")>0 &
&    evalue ("[F:PPD]DISCRGVAL"+num$(J))<>0
    Assign "[M:POH2]DISCRGVAL"+num$(J)+"(NOL)"
&                   With evalue ("[F:PPD]DISCRGVAL"+num$(J))
    Assign "[M:POH2]DISCRGREN"+num$(J)+"(NOL)" With GUPDPRIPUR
    DISCRGVAL(J-1)=evalue("[F:PPD]DISCRGVAL"+num$(J))
  Endif
Next J
If dim(GCALNETLIN)>0  GCALNETLIN=NOL+1      : Endif
If dim(GCALNETABR)>0  GCALNETABR="[M:POH2]" : Endif
Call CALNET(2,[F:BPS]PLISTC,[M:POH2]GROPRI(NOL),DISCRGVAL,[M:POH2]QTYUOM(NOL),
&           [M:POH2]NETPRI(NOL),[M:POH1]CUR) From TRTPRICE
If [M:POH1]CUR<>[F:PPD]CUR [M:POH0]OLDCUR=[F:PPD]CUR : I=NOL
                           Gosub CONVERSION_LIG : Endif
[M:POH2]RETRCPDAT(NOL)=[M:POH0]ORDDAT+[F:PPD]LTI
[M:POH2]EXTRCPDAT(NOL)=[M:POH2]RETRCPDAT(NOL)
[M:POH2]OFS(NOL)=[F:PPD]LTI
[M:POH2]LINFLG(NOL)=3
Return

$EFFAC_PWRKORDERS
#--------------------------------------------------------#
# Effacement fichier de travail "Besoins pris en compte" #
#--------------------------------------------------------#
If adxlog=1  Return : Endif : # Pas d'effacement si appel depuis TRTACHISO1
#-----
If dim(WPRONUM)<1  Local Integer WPRONUM    : Endif
If dim(WCODFNC)<1  Local Char    WCODFNC(3) : Endif
#-----
If clalev([M:POI1])>0 & GIMPORT
  WPRONUM=[M:POI1]PRONUM : WCODFNC="POI"
Else
  WPRONUM=adxuid(1)      : WCODFNC="POH"
Endif
#-----
Call DEBTRANS From GLOCK
$TR_PWO
GOK=1
Trbegin [PWO]
  Delete [PWO] Where PRONUM=WPRONUM & CODFNC=WCODFNC
  If fstat=1  GOK=-1 : OK=0 : GLOCK="$PWRKORDERS"-num$(WPRONUM)-WCODFNC
              Goto ROLL_PWO
  Elsif fstat GOK=0  : OK=0 : Call RSTA("PWO",num$(WPRONUM)-WCODFNC) From GLOCK
              Goto AB_PWO
  Endif
Commit
Return
$AB_PWO
Rollback : Return
$ROLL_PWO
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_PWO : Endif : Return

$EFFAC_LIG_PWRKORDERS
#--------------------------------------------------------------------#
# EFFACEMENT FICHIER DE TRAVAIL "BESOINS PRIS EN COMPTE" D'UNE LIGNE #
#--------------------------------------------------------------------#
If dim(WPRONUM)<1  Local Integer WPRONUM    : Endif
If dim(WLINNUM)<1  Local Integer WLINNUM    : Endif
If dim(WCODFNC)<1  Local Char    WCODFNC(3) : Endif
#-----
If clalev([M:POI1])>0 & GIMPORT
  WPRONUM=[M:POI1]PRONUM : WCODFNC="POI" : WLINNUM=[M:POI1]POILIN(nolign-1)
Else
  WPRONUM=adxuid(1)      : WCODFNC="POH" : WLINNUM=[M:POH2]POHLIN(nolign-1)
Endif
#-----
Call DEBTRANS From GLOCK
$TR_LIG_PWO
GOK=1
Trbegin [PWO]
  Delete [PWO] Where PRONUM=WPRONUM
&                  & CODFNC=WCODFNC
&                  & LINNUM=WLINNUM
  If fstat=1
    GLOCK="$PWRKORDERS"-num$(WPRONUM)-WCODFNC-num$(WLINNUM)
    GOK=-1 : Goto ROLL_LIG_PWO
  Elsif fstat
    Call RSTA("PWO",num$(WPRONUM)-WCODFNC-num$(WLINNUM)) From GLOCK
    GOK=0  : Goto AB_LIG_PWO
  Endif
Commit
Return
$AB_LIG_PWO
Rollback : Return
$ROLL_LIG_PWO
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_LIG_PWO : Endif : Return

$ECLATE_PWO
#--------------------------------------------------------------------#
# ECLATEMENT FICHIER DE TRAVAIL "BESOINS PRIS EN COMPTE" D'UNE LIGNE #
#--------------------------------------------------------------------#
[M:POH2]POHCOU+=1 : [M:POH2]POHLIN(J)=[M:POH2]POHCOU
Call DEBTRANS From GLOCK
$TR_ECLATE_PWO
GOK=1
Trbegin [PWO]
  GBIDD1=[M:POH2]RETQTYSTU(J)
  For [PWO] PWO0 Where PRONUM=adxuid(1)
&                    & CODFNC="POH"
&                    & LINNUM=[M:POH2]POHLIN(NOL)
    If [F:PWO]QTYSTU<>0
      Readlock [PWO] Curr
      If fstat=1
        GLOCK="$PWRKORDERS"-num$(adxuid(1))-"POH"-num$([M:POH2]POHLIN(NOL))
        GOK=-1 : Break
      Elsif fstat
        Call RSTA("PWO",num$(adxuid(1))-"POH"-num$([M:POH2]POHLIN(NOL))) From GLOCK
        GOK=0 :  Break
      Endif
      [F:PW2]=[F:PWO]
      If [F:PWO]QTYSTU>GBIDD1 [F:PW2]QTYSTU=GBIDD1 : Endif
      [F:PWO]QTYSTU-=[F:PW2]QTYSTU
      Rewrite [PWO]
      If fstat GOK=0 : Call FSTA("PWO") From GLOCK : Break : Endif
      [F:PW2]LINNUM=[M:POH2]POHLIN(J)
      Call PCAL_QTY([F:PW2]QTYSTU,[F:PW2]STU,[F:PW2]QTYPUU,[F:PW2]PUU,
&                   [M:POH2]ITMREF(J),[M:POH0]BPSNUM,1,GBIDD2) From TRTACHQTE1
      Write [PW2]
      If fstat GOK=0 : Call FSTA("PW2") From GLOCK : Break : Endif
      GBIDD1-=[F:PW2]QTYSTU
    Endif
    If GBIDD1=0 Break : Endif
  Next
  If GOK=-1 Goto ROLL_ECLATE_PWO : Endif
  If GOK=0  Goto AB_ECLATE_PWO   : Endif
Commit
Return
$AB_ECLATE_PWO
Rollback : Return
$ROLL_ECLATE_PWO
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_ECLATE_PWO : Endif : Return


$EXPLOITE_PWO
#----------------------------------------------------------------------#
# Exploitation fichier de travail "Besoins pris en compte" d'une ligne #
#----------------------------------------------------------------------#
Local Char    CLEFIC(60), SYMBOL2(30)
Local Integer WPRONUM, WLINNUM
Local Char    WCODFNC(3)
If clalev([M:POI1])>0 & GIMPORT
  WPRONUM=[M:POI1]PRONUM : WCODFNC="POI" : WLINNUM=[M:POI1]POILIN([M:POH2]POHLIN(nolign-1))
Elsif clalev([M:POD1])>0
  WPRONUM=adxuid(1)      : WCODFNC="POD" : WLINNUM=[M:POD1]POHLIN(nolign-1)
Else
  WPRONUM=adxuid(1)      : WCODFNC="POH" : WLINNUM=[M:POH2]POHLIN(nolign-1)
Endif
For [PWO] PWO0 Where PRONUM=WPRONUM
&                  & CODFNC=WCODFNC
&                  & LINNUM=WLINNUM
  Gosub TRT_EXPLOITE_PWO : If GOK<1  Break : Endif
Next
If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Return


########################################################################
# Exploitation fichier de travail "Besoins pris en compte" d'une ligne #
# -------------------------------------------------------------------- #
# Gosub appelĂŠ depuis les traitements SUBPOIA et SUBPOHB               #
#   - Mise Ă  jour des ordres "POS", "POP", "TRS", "TRP", "SCF" et "EOF"#
#   - Mise Ă  jour de la DA et du fichier de lien si "POP"              #
#   - Mise Ă  jour supplĂŠmentaire sous-traitance si "SCF" ou "EOF"      #
########################################################################
$TRT_EXPLOITE_PWO
If [F:PWO]PSDLIN=0 & ([F:PWO]WIPTYP=2 | [F:PWO]WIPTYP=7)
  #----- Consommation des TPS si TRS (contrat inter-sites) -----#
  If [F:PWO]WIPTYP=7 & [F:PWO]WIPSTA=3
    Read [ORD] ORD0=8;[F:PWO]WIPNUM;[F:PWO]ITMREF
    If !fstat
      Gosub POINT_ORDLEC From TRTACHMGT1 : # Appel point d'entrĂŠe ORDLEC
      [M:ORDK]=[F:ORD]
      [M:ORDK]MAJCOD  = "M"
      [M:ORDK]WIPTYP  = 8
      [M:ORDK]WIPNUM  = [F:PWO]WIPNUM
      [M:ORDK]ITMREF  = [F:PWO]ITMREF
      [M:ORDK]EXTQTY -= [F:PWO]QTYSTU
      If left$([M:ORDK]ABBFIL,1)<>"P"  [M:ORDK]ABBFIL="PUR" : Endif
      Call WIP From TRTWIP : If GOK<1  Return : Endif
    Else
      Raz [F:ORD]
    Endif
  Endif
  #----- Mise Ă  jour des ordres (Consommation) POS, POP, TRS ou TRP -----#
  Read [ORD] ORD0=[F:PWO]WIPTYP;[F:PWO]WIPNUM;[F:PWO]ITMREF
  If fstat
    Raz [F:ORD]
  Else
    Gosub POINT_ORDLEC From TRTACHMGT1 : # Appel point d'entrĂŠe ORDLEC
  Endif
  [M:ORDK]=[F:ORD]
  [M:ORDK]MAJCOD    = "M"
  [M:ORDK]WIPTYP    = [F:PWO]WIPTYP
  [M:ORDK]WIPNUM    = [F:PWO]WIPNUM
  [M:ORDK]ITMREF    = [F:PWO]ITMREF
  [M:ORDK]EXTQTY   -= [F:PWO]QTYSTU
  #VPO 09/12/10 17667 maj qte sur une DA
  If dim([M:POH2]UPDPSDFLG)>0 & [M:POH2]UPDPSDFLG(nolign-1)=2
    If [F:PWO]PSDLIN=0
      Read [PSD] PSD0=[F:ORD]VCRNUM;[F:ORD]VCRLIN
    Else
      Read [PSD] PSD0=[F:PWO]WIPNUM;[F:PWO]PSDLIN
    Endif
    If [M:POH2]QTYPUU(nolign-1)<=([F:PSD]QTYPUU-[F:PSD]ORDQTYPUU)
      [F:PWO]QTYSTU=[M:POH2]QTYSTU(nolign-1)
    Else
      #on prend au max ce qu'il reste Ă  commander
      [F:PWO]QTYSTU=min([M:POH2]QTYSTU(nolign-1),[F:PSD]QTYSTU-[F:PSD]ORDQTYSTU)
    Endif
    [F:POQ]RETQTYSTU=[F:PWO]QTYSTU
  Elsif dim([M:POD1]UPDPSDFLG)>0 & [M:POD1]UPDPSDFLG(nolign-1)=2
    If [F:PWO]PSDLIN=0
      Read [PSD] PSD0=[F:ORD]VCRNUM;[F:ORD]VCRLIN
    Else
      Read [PSD] PSD0=[F:PWO]WIPNUM;[F:PWO]PSDLIN
    Endif
    If [M:POD1]QTYPUU(nolign-1)<=([F:PSD]QTYPUU-[F:PSD]ORDQTYPUU)
      [F:PWO]QTYSTU=[F:POQ]QTYSTU
      [F:PWO]QTYPUU=[F:POQ]QTYPUU
    Else
      #on prend au max ce qu'il reste Ă  commander
      [F:PWO]QTYSTU=min([F:POQ]QTYSTU,[F:PSD]QTYSTU-[F:PSD]ORDQTYSTU)
      [F:PWO]QTYPUU=min([F:POQ]QTYPUU,[F:PSD]QTYPUU-[F:PSD]ORDQTYPUU)
    Endif
    [F:POQ]RETQTYSTU=[F:PWO]QTYSTU
    [F:POQ]RETQTYPUU=[F:PWO]QTYPUU
  Endif
  If left$([M:ORDK]ABBFIL,1)<>"P"  [M:ORDK]ABBFIL="PUR" : Endif
  Call WIP From TRTWIP : If GOK<1  Return : Endif
  #-----
Else
  Raz [F:ORD]
Endif
If [F:PWO]PSDLIN=0 & !find([F:PWO]WIPTYP,4,13)
  CLEFIC=[F:ORD]VCRNUM
Else
  CLEFIC=[F:PWO]WIPNUM
Endif
If [F:PWO]QTYSTU<>0 & CLEFIC<>""
  #--------------------------------------------------#
  # Consommation d'une ligne de demande de livraison #
  #--------------------------------------------------#
  If [F:ORD]ABBFIL="POC" & [F:PWO]WIPSTA<3
    Gosub CONSOMMATION_LIGNE_DL : If GOK<1  Return : Endif
  #-------------------------------------------------------------#
  # Mise Ă  jour demandes d'achat entĂŞte, ligne et fichier liens #
  #-------------------------------------------------------------#
  Elsif [F:PWO]WIPSTA=2 & [F:PWO]WIPTYP=2 & ([F:ORD]ABBFIL="PSD" | [F:ORD]ABBFIL="")
    SYMBOL2="PSH"+CLEFIC : Lock=SYMBOL2
    #----- Si entĂŞte DA bloquĂŠe logiquement --> Abandon -----#
    If fstat
      GMESSAGE="$PREQUIS"-CLEFIC-mess(10,100,1) : GERR=1 : GOK=0 : Raz SYMBOL2 : Return
    Endif
    #----- Lecture de l'entĂŞte DA avec blocage physique -----#
    Readlock [PSH] PSH0=CLEFIC
    If fstat=1
      GOK=-1 : GLOCK="$PREQUIS"-CLEFIC            : Return
    Elsif fstat
      GOK=0  : Call RSTA("PSH",CLEFIC) From GLOCK : Return
    Endif
    If [F:PWO]PSDLIN=0
      CLEFIC+=" "+num$([F:ORD]VCRLIN)
      Readlock [PSD] PSD0=[F:ORD]VCRNUM;[F:ORD]VCRLIN
    Else
      CLEFIC+=" "+num$([F:PWO]PSDLIN)
      Readlock [PSD] PSD0=[F:PWO]WIPNUM;[F:PWO]PSDLIN
    Endif
    If fstat=1
      GOK=-1 : GLOCK="$PREQUISD"-CLEFIC           : Return
    Elsif fstat
      GOK=0  : Call RSTA("PSD",CLEFIC) From GLOCK : Return
    Endif
    #VPO 09/12/10 17667 maj qte sur une DA
    If dim([M:POH2]UPDPSDFLG)>0 & [M:POH2]UPDPSDFLG(nolign-1)=2
      If [M:POH2]QTYPUU(nolign-1)<=([F:PSD]QTYPUU-[F:PSD]ORDQTYPUU)
        [F:PWO]QTYSTU=[M:POH2]QTYSTU(nolign-1)
      Else
        #on prend au max ce qu'il reste Ă  commander
        [F:PWO]QTYSTU=min([M:POH2]QTYSTU(nolign-1),[F:PSD]QTYSTU-[F:PSD]ORDQTYSTU)
      Endif
      [F:POQ]RETQTYSTU=[F:PWO]QTYSTU
    Elsif dim([M:POD1]UPDPSDFLG)>0 & [M:POD1]UPDPSDFLG(nolign-1)=2
      If [M:POD1]QTYPUU(nolign-1)<=([F:PSD]QTYPUU-[F:PSD]ORDQTYPUU)
        [F:PWO]QTYSTU=[F:POQ]QTYSTU
        [F:PWO]QTYPUU=[F:POQ]QTYPUU
      Else
        #on prend au max ce qu'il reste Ă  commander
        [F:PWO]QTYSTU=min([F:POQ]QTYSTU,[F:PSD]QTYSTU-[F:PSD]ORDQTYSTU)
        [F:PWO]QTYPUU=min([F:POQ]QTYPUU,[F:PSD]QTYPUU-[F:PSD]ORDQTYPUU)
      Endif
      [F:POQ]RETQTYSTU=[F:PWO]QTYSTU
      [F:POQ]RETQTYPUU=[F:PWO]QTYPUU
    Endif
    #--------------------------------------------------------------------------#
    # Point d'entrĂŠe permettant de solder une ligne DA partiellement consommĂŠe #
    #--------------------------------------------------------------------------#
    Gosub POINT_CONSOPSH From TRTACHPSH1 : If GOK<1  Return : Endif
    #-----
    If [F:PWO]QTYSTU>[F:PSD]QTYSTU-[F:PSD]ORDQTYSTU
      [F:PWO]QTYSTU=[F:PSD]QTYSTU-[F:PSD]ORDQTYSTU
    Endif
    If [F:PWO]QTYSTU<0  Raz [F:PWO]QTYSTU : Endif
    #----- Si indicateur de signature  modifiĂŠ  --> Abandon -----#
    If [F:PSD]LINAPPFLG<3
      GMESSAGE="$PREQUISD"-CLEFIC-mess(224,194,1) : GERR=1 : GOK=0 : Return
    Endif
    #----- Chargement et ĂŠcriture fichier lien demande-commande -----#
    Raz [F:PSO]
    [F:PSO]PSHNUM=[F:PSD]PSHNUM
    [F:PSO]PSDLIN=[F:PSD]PSDLIN
    [F:PSO]POHNUM=[F:POQ]POHNUM
    [F:PSO]POPLIN=[F:POQ]POPLIN
    [F:PSO]POQSEQ=[F:POQ]POQSEQ
    [F:PSO]PUU   =[F:PSD]PUU
    [F:PSO]QTYSTU=[F:PWO]QTYSTU
    [F:PSO]STU   =[F:POQ]STU
    #----- Convertion de la qtĂŠ avec le coef utilisĂŠ lors de la crĂŠation de la DA -----#
    If [F:PSD]QTYSTU<>0 GBIDD1=[F:PSD]QTYPUU/[F:PSD]QTYSTU Else GBIDD1=1 : Endif
    [F:PSO]QTYPUU=[F:PSO]QTYSTU*GBIDD1
    Call QTEARR([F:PSO]QTYPUU,[F:PSO]PUU) From TRTDIV
    Write [PSO]
    If fstat  GOK=0 : Call FSTA("PSO") From GLOCK : Return : Endif
    #----- Mise Ă  jour ligne DA : QuantitĂŠs commandĂŠes en UA et US -----#
    [F:PSD]ORDQTYPUU+=[F:PSO]QTYPUU
    [F:PSD]ORDQTYSTU+=[F:PSO]QTYSTU
    #----- Si ligne DA complĂ¨tement commandĂŠe : MĂ j flags solde et cde -----#
    If [F:PSD]QTYSTU<=[F:PSD]ORDQTYSTU | [L]WSOLDPSH=2
      If [F:PSD]LINCLEFLG<>2  [F:PSD]LINCLEFLG=2 : [F:PSH]CLELINNBR+=1 : Endif
      If [F:PSD]LINORDFLG<>2  [F:PSD]LINORDFLG=2 : [F:PSH]ORDLINNBR+=1 : Endif
    Endif
    Rewrite [PSD]
    If fstat  GOK=0 : Call FSTA("PSD") From GLOCK : Return : Endif
    #----- Si solde forcĂŠ, rĂŠajustement des qtĂŠs pour prĂŠ-engagement -----#
    If [L]WSOLDPSH=2 & [F:PSD]QTYSTU>[F:PSD]ORDQTYSTU
      [F:PSO]QTYSTU+=[F:PSD]QTYSTU-[F:PSD]ORDQTYSTU
      [F:PSO]QTYPUU=[F:PSO]QTYSTU*GBIDD1
      Call QTEARR([F:PSO]QTYPUU,[F:PSO]PUU) From TRTDIV
    Endif
    #----- Mise Ă  jour entĂŞte DA : Indicateurs commande et solde -----#
    If [F:PSH]LINNBR<=[F:PSH]ORDLINNBR  [F:PSH]ORDFLG=2 : Endif
    If [F:PSH]LINNBR<=[F:PSH]CLELINNBR  [F:PSH]CLEFLG=2 : Endif
    Rewrite [PSH]
    If fstat  GOK=0 : Call FSTA("PSH") From GLOCK : Return : Endif
    #----- MĂ j prĂŠ-engagements -----#
    Call TRTMAJCMM([F:PSD]PSHNUM,[F:PSD]PSDLIN,0,-1,1,"PSD3",2,GBIDI1) From TRTACHDIV1
    If GOK<1  Return : Endif
    #-----
    # Issue 78807 - 2011-12-20 by VPO : pb sur pre-engagement
    #on doit ecrire PSD apres TRTMAJCMM
    #----- RĂŠĂŠcriture ligne demande -----#
    Rewrite [PSD]
    If fstat  GOK=0 : Call FSTA("PSD") From GLOCK : Return : Endif
   #-----
    # Issue 74341 - 2011-07-26 by VPO : il faut remettre Ă  jour la POP regĂŠnĂŠrĂŠe
    If [F:PWO]PSDLIN>0 & [F:PWO]WIPTYP=2
        #----- Mise Ă  jour des ordres (Consommation)POP -----#
        Read [ORD] ORD0=2;[F:PSD]WIPNUM;[F:PSD]ITMREF
        If fstat
          Raz [F:ORD]
        Else
          Gosub POINT_ORDLEC From TRTACHMGT1 : # Appel point d'entrĂŠe ORDLEC
        Endif
        [M:ORDK]=[F:ORD]
        [M:ORDK]MAJCOD    = "M"
        [M:ORDK]WIPTYP    = 2
        [M:ORDK]WIPNUM    = [F:PSD]WIPNUM
        [M:ORDK]ITMREF    = [F:PSD]ITMREF
        [M:ORDK]EXTQTY   -= [F:PSO]QTYSTU
        If left$([M:ORDK]ABBFIL,1)<>"P"  [M:ORDK]ABBFIL="PUR" : Endif
        Call WIP From TRTWIP : If GOK<1  Return : Endif
    Endif
    ##fin Issue 74341
    #-----
    Unlock=SYMBOL2 : Raz SYMBOL2
  Endif
  #----- Mise Ă  jour opĂŠration sous-traitance si encours SCx ou EOx -----#
  If find([F:PWO]WIPTYP,4,13) # Issue 84764 & 84500 GA 10/2012 code dĂŠplacĂŠ
     Gosub EXPLOITE_PWO From TRTACHSCO1
  Endif
Endif
Return

#---------------------------------------------------------#
# Consommation d'une ligne demande de livraison planifiĂŠe #
#---------------------------------------------------------#
$CONSOMMATION_LIGNE_DL
If !clalev([F:POQ2])  Local File PORDERQ  [POQ2] : Endif
#----- Lecture ligne DL Ă  consommer -----#
Read [POQ2] POQ0=[F:ORD]VCRNUM;[F:ORD]VCRLIN;[F:ORD]VCRSEQ
If fstat
  Call RSTA("POQ",[F:ORD]VCRNUM-num$([F:ORD]VCRLIN)-num$([F:ORD]VCRSEQ)) From GLOCK
  Raz [F:POQ2] : GOK=0 : Return
Endif
#----- Sauvegarde du buffer de l'encours -----#
If [F:POQ2]OCNLIN<>0
  If !clalev([F:ORD2])  Local File ORDERS  [ORD2] : Endif
  [F:ORD2]=[F:ORD]
Endif
#----- Test si prise en compte totale alors suppression ligne DL -----#
If [F:PWO]QTYSTU>=[F:POQ2]QTYSTU
  Gosub SUP_LIGNE_DL
Else
  Gosub MAJ_LIGNE_DL
Endif
Return

#-----------------------------------------------------------#
# Mise Ă  jour demande de livraison planifiĂŠe (consommation) #
#-----------------------------------------------------------#
$MAJ_LIGNE_DL
#----- Lecture avec blocage physique de la ligne de DL Ă  consommer -----#
Readlock [POQ2] POQ0=[F:ORD]VCRNUM;[F:ORD]VCRLIN;[F:ORD]VCRSEQ
If fstat=1
  GLOCK="$PORDERQ"-[F:ORD]VCRNUM-num$([F:ORD]VCRLIN)-num$([F:ORD]VCRSEQ)
  GOK=-1 : Return
Elsif fstat
  Call RSTA("POQ",[F:ORD]VCRNUM-num$([F:ORD]VCRLIN)-num$([F:ORD]VCRSEQ)) From GLOCK
  GOK=0  : Return
Endif
#----- Mise Ă  jour des champs de la table -----#
[F:POQ2]QTYPUU   -=[F:PWO]QTYPUU
[F:POQ2]QTYSTU   -=[F:PWO]QTYSTU
[F:POQ2]RETQTYPUU-=[F:PWO]QTYPUU
[F:POQ2]RETQTYSTU-=[F:PWO]QTYSTU
If [F:POQ2]RETQTYPUU<0  Raz [F:POQ2]RETQTYPUU : Endif
If [F:POQ2]RETQTYSTU<0  Raz [F:POQ2]RETQTYSTU : Endif
[F:POQ2]UPDUSR=GUSER
[F:POQ2]UPDDAT=date$
#----- RĂŠĂŠcriture de la ligne de DL -----#
Rewrite [POQ2]
If fstat
  GOK=0  : Call FSTA("POQ") From GLOCK : Return
Endif
#----- Appel du S/P ventes pour modification de la ligne quantitĂŠ (SORDERQ) -----#
If [F:POQ2]OCNLIN<>0
  Raz [M:SORW]
  [M:SORW]MAJCOD   = "M"
  [M:SORW]SOHNUM   = [F:POQ2]LINOCNNUM
  [M:SORW]SOPLIN   = [F:POQ2]OCNLIN
  [M:SORW]SOQSEQ   = [F:POQ2]OCNSEQ
  [M:SORW]QTY      = -[F:PWO]QTYPUU
  [M:SORW]DEMSTA   = [F:POQ2]WIPSTA
  [M:SORW]USEPLC   = [F:POQ2]USEPLC
  [M:SORW]SOQSTA   = [F:POQ2]LINSTA
  Call MAJ_SOQ From TRTVENMSIT : [F:ORD]=[F:ORD2]
  If GOK<1  Return : Endif
Endif
Return

#--------------------------------------------#
# Suppression demande de livraison planifiĂŠe #
#--------------------------------------------#
$SUP_LIGNE_DL
#----- Appel du S/P ventes pour suppression de la ligne quantitĂŠ (SORDERQ) -----#
If [F:POQ2]OCNLIN<>0
  Raz [M:SORW]
  [M:SORW]MAJCOD   = "A"
  [M:SORW]SOHNUM   = [F:POQ2]LINOCNNUM
  [M:SORW]SOPLIN   = [F:POQ2]OCNLIN
  [M:SORW]SOQSEQ   = [F:POQ2]OCNSEQ
  Call MAJ_SOQ From TRTVENMSIT : [F:ORD]=[F:ORD2]
  If GOK<1 : Return : Endif
Endif
#----- Mise Ă  jour DA et fichier lien si nĂŠcessaire -----#
If [F:POQ2]RETQTYPUU<>0 | [F:POQ2]RETQTYSTU<>0
  If clalev([M:PMG]) & [M:PMG]MAJCOD="X" : # On vient du TRTACHPSH1 crĂŠation DA Ă  partir DL
    #
    # Ne rien faire pour l'instant dans ce cas car la nouvelle DA crĂŠĂŠe fait double emploi
    # avec les DA consommĂŠes par la DL, ces DA doivent rester consommĂŠes
    #
    #----- Lecture du fichier lien commande-demande Ă  supprimer -----#
    #For [PSO]PSO1 Where POHNUM=[F:POQ2]POHNUM & POPLIN=[F:POQ2]POPLIN & POQSEQ=[F:POQ2]POQSEQ
    #  Gosub MAJ_LIGNE_DA : If GOK<1  Break : Endif
    #Next
    #If SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
    #If GOK<1  Return : Endif
    #----- Suppression des enregistrements lien -----#
    #CLEFIC=[F:POQ2]POHNUM-num$([F:POQ2]POPLIN)
    #Delete [PSO] Where POHNUM=[F:POQ2]POHNUM & POPLIN=[F:POQ2]POPLIN & POQSEQ=[F:POQ2]POQSEQ
    #If fstat=1
    #  GOK=-1 : GLOCK="$PREQUISO"-CLEFIC           : Return
    #Elsif fstat
    #  GOK=0  : Call RSTA("PSO",CLEFIC) From GLOCK : Return
    #Endif
  Else
    #----- MĂ j du fichier lien commande-demande avec nouvelle rĂŠfĂŠrence commande -----#
    Update [PSO] Where POHNUM=[F:POQ2]POHNUM & POPLIN=[F:POQ2]POPLIN & POQSEQ=[F:POQ2]POQSEQ
&                With  POHNUM=[F:POQ]POHNUM,   POPLIN=[F:POQ]POPLIN,   POQSEQ=[F:POQ]POQSEQ
    If fstat=1
      GLOCK="$PREQUISO"-[F:POQ2]POHNUM-num$([F:POQ2]POPLIN)-num$([F:POQ2]POQSEQ)
      GOK=-1 : Return
    Elsif fstat
      Call RSTA("PSO",[F:POQ2]POHNUM-num$([F:POQ2]POPLIN)-num$([F:POQ2]POQSEQ)) From GLOCK
      GOK=0  : Return
    Endif
  Endif
Endif
#----- Suppression de la ligne de DL -----#
Delete [POQ2] Where POHNUM=[F:ORD]VCRNUM
&                 & POPLIN=[F:ORD]VCRLIN
&                 & POQSEQ=[F:ORD]VCRSEQ
If fstat=1
  GLOCK="$PORDERQ"-[F:ORD]VCRNUM-num$([F:ORD]VCRLIN)-num$([F:ORD]VCRSEQ)
  GOK=-1 : Return
Elsif fstat
  Call RSTA("POQ",[F:ORD]VCRNUM-num$([F:ORD]VCRLIN)-num$([F:ORD]VCRSEQ)) From GLOCK
  GOK=0  : Return
Endif
Return


#############################################################################
# SITUATION_LIG_CDE : S/P d'affichage dĂŠtail ligne cde         MBT 17/12/98 #
#   NUMCDE   : NumĂŠro   de la commande Ă  traiter                            #
#   LINCDE   : NumĂŠro   de la ligne de commande Ă  traiter                   #
#   SEQCDE   : SĂŠquence de la ligne de commande Ă  traiter                   #
#   ABMSK    : AbrĂŠviation du masque ĂŠcran contenant les lignes             #
#   NOL      : NumĂŠro de ligne tableau des lignes commande (nolign-1)       #
# ------------------------------------------------------------------------- #
# RemplacĂŠ par l'action VISUETAPOQ avec paramĂ¨tres :           MBT 05/12/00 #
#   PARAM(1) = NUM    : NumĂŠro   de la commande Ă  traiter                   #
#   PARAM(2) = LIN    : NumĂŠro   de la ligne de commande Ă  traiter          #
#   PARAM(3) = SEQ    : SĂŠquence de la ligne de commande Ă  traiter          #
#   PARAM(4) = WABMSK : AbrĂŠviation du masque ĂŠcran contenant les lignes    #
#   PARAM(5) = NOLIG  : NumĂŠro de ligne tableau lignes commande (nolign-1)  #
#############################################################################
#--------------------------------------------------------------#
# Avant la dĂŠfinition des boutons et l'ouverture de la fenĂŞtre #
#--------------------------------------------------------------#
$OUV_VISUETAPOQ
#----- Variables locales -----#
Local Char     NUMCDE(GLONPOH) : NUMCDE=PARAM(1)
Local Integer  LINCDE          : LINCDE=val(PARAM(2))
Local Integer  SEQCDE          : SEQCDE=val(PARAM(3))
Local Char     WABMSK(4)       : WABMSK =PARAM(4)
Local Shortint NOL             : NOL=val(PARAM(5))
Local Shortint SAVGNOLIGN, I, J, K
Local Integer  WPNDLIN(30)
Local Char     WPNHNUM(GLONPNH)(30)
SAVNOLIGN=nolign
If evalue("[M:"+WABMSK+"]NBLIG=0") |
&  evalue("[M:"+WABMSK+"]ITMREF(NOL)=''") | GREP="C" | GREP="D"
  FIN=1
Endif
Return
#---------------------------------#
# AprĂ¨s l'ouverture de la fenĂŞtre #
#---------------------------------#
$DEB_VISUETAPOQ
Local Char WQLYCTLDEM(GLONVCR) : #VPO 09/12/10 69709
# Issue 106506 - 2015-05-07 by SR : Landed Cost
Local Decimal WQTYSHD
Local Decimal WAMT  # Issue X3-70225 - 2018-08-07 by SDEM
Local Integer WSTAT # Issue X3-70225 - 2018-08-07 by SDEM
Local Decimal WRATCUR # Issue X3-70225 - 2018-08-07 by SDEM

Raz [M:PDQ2]
Call TEMPON("O") From GESECRAN
#----- Lecture ligne commande Ă  traiter si nĂŠcessaire -----#
If [F:POQ]POHNUM<>NUMCDE | [F:POQ]POPLIN<>LINCDE | [F:POQ]POQSEQ<>SEQCDE
  Read [POQ] POQ0=NUMCDE;LINCDE;SEQCDE : If fstat Raz [F:POQ] : Endif
Endif
#----- Ouverture des fichiers si nĂŠcessaire ----#
If clalev([F:PTD])<=0 Local File PRECEIPTD [PTD] : Endif
If clalev([F:PND])<=0 Local File PRETURND  [PND] : Endif
If clalev([F:PIH])<=0 Local File PINVOICE  [PIH] : Endif
If clalev([F:PID])<=0 Local File PINVOICED [PID] : Endif
# Issue 75929 - 2011-09-01 by SR : Travailler sur une autre abrĂŠviation
If clalev([F:STJ1])<=0 Local File STOJOU    [STJ1] : Endif
#If clalev([F:STJ])<=0 Local File STOJOU    [STJ] : Endif
If clalev([F:ITM])<=0 Local File ITMMASTER [ITM] : Endif
# Issue 106506 - 2015-05-07 by SR : Landed Cost
If clalev([F:SHD])<=0 Local File SHIPMENTD [SHD] : Endif
# Issue 110325 - 2016-02-11 by SR : PrĂŠ rĂŠception de commande
If clalev([F:SHH])<=0 Local File SHIPMENT [SHH] : Endif


#----- Chargement des zones dans le masque -----#
[M:PDQ2]ITMREF   =evalue("[M:"+WABMSK+"]ITMREF(NOL)")
[M:PDQ2]ITMDES   =evalue("[M:"+WABMSK+"]ITMDES(NOL)")
[M:PDQ2]QTYPUU   =evalue("[M:"+WABMSK+"]QTYPUU(NOL)")
[M:PDQ2]PUU      =evalue("[M:"+WABMSK+"]PUU(NOL)")
[M:PDQ2]PUU2     =evalue("[M:"+WABMSK+"]PUU(NOL)")
[M:PDQ2]PUU3     =evalue("[M:"+WABMSK+"]PUU(NOL)")
# Issue 106506 - 2015-05-07 by SR : Landed Cost
[M:PDQ2]PUU4     =evalue("[M:"+WABMSK+"]PUU(NOL)")
[M:PDQ2]LINCLEFLG=evalue("[M:"+WABMSK+"]LINCLEFLG(NOL)")
[M:PDQ2]LINCLELIB=mess([M:PDQ2]LINCLEFLG,1,1)
[M:PDQ2]RCPQTYPUU=[F:POQ]RCPQTYPUU
[M:PDQ2]LINRCPNBR=[F:POQ]LINRCPNBR
[M:PDQ2]INVQTYPUU=[F:POQ]INVQTYPUU
[M:PDQ2]LININVNBR=[F:POQ]LININVNBR
#-----
[M:PDQ2]NETPRI1  =evalue("[M:"+WABMSK+"]NETPRI(NOL)")
[M:PDQ2]CUR1     =evalue("[M:"+WABMSK+"]WCUR")
[M:PDQ2]LINAMT   =evalue("[M:"+WABMSK+"]LINAMT(NOL)")
[M:PDQ2]CUR2     =evalue("[M:"+WABMSK+"]WCUR")
[M:PDQ2]LINATI   =evalue("[M:"+WABMSK+"]LINATI(NOL)")
[M:PDQ2]CUR3     =evalue("[M:"+WABMSK+"]WCUR")

#----- Chargement des rĂŠceptions effectuĂŠes sur la ligne de commande -----#
Filter [PTD] Where POHNUM=NUMCDE & POPLIN=LINCDE & POQSEQ=SEQCDE
&            Order By Key PTD2
Raz I
For [PTD]
  [M:PDQ2]PTHNUM(I)   =[F:PTD]PTHNUM
  [M:PDQ2]PTDLIN(I)   =[F:PTD]PTDLIN
  [M:PDQ2]RCPDAT(I)   =[F:PTD]RCPDAT
  [M:PDQ2]PRHFCY(I)   =[F:PTD]PRHFCY
  If [F:ITM]ITMREF<>[F:PTD]ITMREF
    Read [ITM]ITM0=[F:PTD]ITMREF
    If fstat : Raz [F:ITM]ITMREF : Endif
  Endif
  If [F:PTD]STOMGTCOD>1
    Raz WQLYCTLDEM : #VPO 09/12/10 69709
    Raz GBIDD1, GBIDD2, GBIDD3
    For [STJ1]STJ1 Where STOFCY = [F:PTD]PRHFCY   &
&                       VCRTYP = 6               &
&                       VCRNUM = [F:PTD]PTHNUM   &
&                       VCRLIN = [F:PTD]PTDLIN   &
&                       ITMREF = [F:PTD]ITMREF   &
&                       UPDCOD = 2               &
&                       REGFLG <>2
      If [F:STJ1]QTYSTU>0
        If left$([F:STJ1]STA,1)="A"
          If [F:STJ1]PCU=[M:PDQ2]PUU
            GBIDD1+=[F:STJ1]QTYPCU
          Else
            GBIDD1+=[F:STJ1]QTYSTU*[F:PTD]QTYPUU/[F:PTD]QTYSTU
          Endif
        Elsif left$([F:STJ1]STA,1)="Q"
          If [F:STJ1]PCU=[M:PDQ2]PUU
            GBIDD2+=[F:STJ1]QTYPCU
          Else
            GBIDD2+=[F:STJ1]QTYSTU*[F:PTD]QTYPUU/[F:PTD]QTYSTU
          Endif
          #VPO 09/12/10 69709 ajuster les quantites par statut en fonction des mouvements de stock
          # on rĂŠcupĂ¨re demande d'analyse
          If [F:STJ1]QLYCTLDEM<>""  WQLYCTLDEM=[F:STJ1]QLYCTLDEM : Endif
        Elsif left$([F:STJ1]STA,1)="R"
          If [F:STJ1]PCU=[M:PDQ2]PUU
            GBIDD3+=[F:STJ1]QTYPCU
          Else
            GBIDD3+=[F:STJ1]QTYSTU*[F:PTD]QTYPUU/[F:PTD]QTYSTU
          Endif
        Endif
      Endif
    Next
    #VPO 09/12/10 69709 ajuster les quantites par statut en fonction des mouvements de stock
    # selon demande d'analyse
    If WQLYCTLDEM<>""
      For [STJ1] STJ1 Where STOFCY=[F:PTD]PRHFCY
&                    & VCRNUM=WQLYCTLDEM
&                    & VCRTYPORI=6
&                    & VCRNUMORI=[F:PTD]PTHNUM
&                    & VCRLINORI=[F:PTD]PTDLIN
&                    & ITMREF = [F:PTD]ITMREF
&                    & UPDCOD = 2
&                    & REGFLG<>2
        If left$([F:STJ1]STA,1)="A"
          If [F:STJ1]PCU=[M:PDQ2]PUU
            GBIDD1+=[F:STJ1]QTYPCU
          Else
            GBIDD1+=[F:STJ1]QTYSTU*[F:PTD]QTYPUU/[F:PTD]QTYSTU
          Endif
        Elsif left$([F:STJ1]STA,1)="Q"
          If [F:STJ1]PCU=[M:PDQ2]PUU
            GBIDD2+=[F:STJ1]QTYPCU
          Else
            GBIDD2+=[F:STJ1]QTYSTU*[F:PTD]QTYPUU/[F:PTD]QTYSTU
          Endif
        Elsif left$([F:STJ1]STA,1)="R"
          If [F:STJ1]PCU=[M:PDQ2]PUU
            GBIDD3+=[F:STJ1]QTYPCU
          Else
            GBIDD3+=[F:STJ1]QTYSTU*[F:PTD]QTYPUU/[F:PTD]QTYSTU
          Endif
        Endif
      Next
    Endif
    If [F:PTD]UOMSTUCOE=0 : [F:PTD]UOMSTUCOE=1 : Endif
    #----- QuantitĂŠ en A en PUU -----#
    Call QTEARR(GBIDD1, [F:PTD]PUU) From TRTDIV
    [M:PDQ2]AAAQTYPUU(I)=GBIDD1
    #----- QuantitĂŠ en Q en PUU -----#
    Call QTEARR(GBIDD2, [F:PTD]PUU) From TRTDIV
    [M:PDQ2]QQQQTYPUU(I)=GBIDD2
    #----- QuantitĂŠ en R en PUU -----#
    Call QTEARR(GBIDD3, [F:PTD]PUU) From TRTDIV
    [M:PDQ2]RRRQTYPUU(I)=GBIDD3
  Else
    [M:PDQ2]AAAQTYPUU(I)=[F:PTD]QTYPUU-[F:PTD]RRRQTYPUU
    Raz [M:PDQ2]QQQQTYPUU(I)
    [M:PDQ2]RRRQTYPUU(I)=[F:PTD]RRRQTYPUU
  Endif
  [M:PDQ2]RTNQTYPUU(I)=[F:PTD]RTNQTYPUU
  I+=1 : [M:PDQ2]NBRCP=I
  If I>dim([M:PDQ2]PTHNUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
Next
Filter [PTD]

# Issue 106506 - 2015-05-07 by SR : Landed Cost
# Issue 110325 - 2016-02-11 by SR : GĂŠrer prĂŠ receptions de commande
#----- Chargement des expĂŠditions effectuĂŠes sur la ligne de commande -----#
Link [F:SHD] With [F:SHH]SHH0 = [F:SHD]SHIPNUM As [LNK] Where POHNUM=NUMCDE & POPLIN=LINCDE & POQSEQ=SEQCDE
&            Order By Key SHD1
#Filter [SHD] Where POHNUM=NUMCDE & POPLIN=LINCDE & POQSEQ=SEQCDE
#&            Order By Key SHD1
Raz I
Raz WQTYSHD
#For [F:SHD]
For [F:LNK]
  [M:PDQ2]SHIPNUM(I)      = [F:SHD]SHIPNUM
  [M:PDQ2]SHIPLIN(I)      = [F:SHD]SHIPLIN
  [M:PDQ2]CTRNUM(I)       = [F:SHD]CTRNUM
  [M:PDQ2]SHIQTYPUU(I)    = [F:SHD]SHIQTYPUU
  [M:PDQ2]PRCPQTYPUU(I)   = [F:SHD]PRCPQTYPUU
  [M:PDQ2]SHDRCPQTYPUU(I) = [F:SHD]RCPQTYPUU
  [M:PDQ2]SHDCUR(I)       = [F:SHD]NETCUR
  [M:PDQ2]SHDLINAMT(I)    = [F:SHD]LINAMT
  [M:PDQ2]CLEFLG(I)       = [F:SHD]CLEFLG
  [M:PDQ2]SHIPTYP(I)      = [F:SHH]SHIPTYP
  [M:PDQ2]WSHIPTYP(I)     = mess([F:SHH]SHIPTYP,2510,1)
  WQTYSHD                += [F:SHD]SHIQTYPUU
  I+=1 : [M:PDQ2]NBSHD=I
  If I>dim([M:PDQ2]SHIPNUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
Next
[M:PDQ2]SHDQTYPUU         = WQTYSHD
[M:PDQ2]LINSHDNBR         = [M:PDQ2]NBSHD
#Filter [F:SHD]
# End issue 106506
# End issue 110325

#----- Chargement des factures effectuĂŠes sur la ligne de commande -----#
Filter [PID] Where TYPORI=1 & NUMORI=NUMCDE & LINORI=LINCDE & SEQORI=SEQCDE
&            Order By Key PID1
Raz I
For [PID]
  Gosub CHARG_LIG_FAC
  If I>dim([M:PDQ2]NUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
Next
If I>dim([M:PDQ2]NUM)-1 Goto AFFICH_SITUATION_LIG_CDE : Endif
#----- Chargement des factures effectuĂŠes sur ligne rĂŠception -----#
If [M:PDQ2]NBRCP>0
  For J=0 To [M:PDQ2]NBRCP-1
    Filter [PID] Where TYPORI=2 & NUMORI=[M:PDQ2]PTHNUM(J) & LINORI=[M:PDQ2]PTDLIN(J)
&                Order By Key PID1
    For [PID]
      Gosub CHARG_LIG_FAC
      If I>dim([M:PDQ2]NUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
    Next
    If I>dim([M:PDQ2]NUM)-1 Break : Endif
  Next J
  If I>dim([M:PDQ2]NUM)-1 Goto AFFICH_SITUATION_LIG_CDE : Endif
Endif
#--- Chargement avoirs et factures complĂŠmentaires sur factures sĂŠlectionnĂŠes ---#
If [M:PDQ2]NBFAC>0
  For J=0 To [M:PDQ2]NBFAC-1
    Filter [PID] Where TYPORI=4 & NUMORI=[M:PDQ2]NUM(J) & LINORI=[M:PDQ2]PIDLIN(J)
&                Order By Key PID1
    For [PID]
      Gosub CHARG_LIG_FAC
      If I>dim([M:PDQ2]NUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
    Next
    If I>dim([M:PDQ2]NUM)-1 Break : Endif
  Next J
  If I>dim([M:PDQ2]NUM)-1 Goto AFFICH_SITUATION_LIG_CDE : Endif
Endif
#----- Chargement des retours effectuĂŠs sur ligne de rĂŠception -----#
Raz K
If [M:PDQ2]NBRCP>0
  For J=0 To [M:PDQ2]NBRCP-1
    Filter [PND] Where PTHNUM=[M:PDQ2]PTHNUM(J) & PTDLIN=[M:PDQ2]PTDLIN(J)
&                Order By Key PND1
    For [PND]
      If K>29 GMESSAGE=mess(26,100,1) : GERR=2 : Break 2 : Endif
      WPNHNUM(K)=[F:PND]PNHNUM : WPNDLIN(K)=[F:PND]PNDLIN : K+=1
    Next
  Next J
Endif
#----- Chargement des avoirs sur retours sĂŠlectionnĂŠs -----#
If K>0
  For J=0 To K-1
    Filter [PID] Where TYPORI=3 & NUMORI=WPNHNUM(J) & LINORI=WPNDLIN(J)
&                Order By Key PID1
    For [PID]
      Gosub CHARG_LIG_FAC
      If I>dim([M:PDQ2]NUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break 2 : Endif
    Next
  Next J
  If I>dim([M:PDQ2]NUM)-1 Goto AFFICH_SITUATION_LIG_CDE : Endif
Endif

# Issue 82703 - 2012-10-12 by MUARN : ajout montant total factures complĂŠmentaires
[M:PDQ2]CUR4      =evalue("[M:"+WABMSK+"]WCUR")
#--- Issue 95710 by TS
#[M:PDQ2]AMTPIHFCC =sigma(I=0,[M:PDQ2]NBFAC-1,[M:PDQ2]AMTNOTLIN(I)*([M:PDQ2]PIHTYP(I)=2))
#[M:PDQ2]AMTPIHFCC =sigma(I=0,[M:PDQ2]NBFAC-1,
#&                  [M:PDQ2]AMTNOTLIN(I)*([M:PDQ2]PIHTYP(I)=2)
#&                 +[M:PDQ2]AMTNOTLIN(I)*([M:PDQ2]PIHTYP(I)=3&[M:PDQ2]NETPRI(I)=0&[M:PDQ2]FACQTYPUU(I)=0))
#---
# Issue X3-70225 - 2018-08-07 by SDEM : Start

[M:PDQ2]AMTPIHFCC =0
For NI=0 To [M:PDQ2]NBFAC-1
  Read [F:PIH]PIH0=[M:PDQ2]NUM(NI)
  If [M:PDQ2]PIHTYP(NI)=2 or ([M:PDQ2]PIHTYP(NI)=3 and [M:PDQ2]NETPRI(NI)=0 and [M:PDQ2]FACQTYPUU(NI)=0)
    If [M:PDQ2]CUR(NI)= [M:PDQ2]CUR4 Then
      [M:PDQ2]AMTPIHFCC +=[M:PDQ2]AMTNOTLIN(NI)
    Else
      WI=find([F:POH]CUR,[F:PIH]CURLED)
      If WI & [F:PIH]RATDIV(WI-1)<>0
        WRATCUR=[F:PIH]RATMLT(WI-1)/[F:PIH]RATDIV(WI-1)
        WAMT=[M:PDQ2]AMTNOTLIN(NI)
        WAMT=WAMT*WRATCUR
      Else
        WAMT=0
        Call CONVERT2([M:PDQ2]CUR(NI),[M:PDQ2]CUR4,GLOCALDEV,[F:PIH]CURTYP,[M:PDQ2]ACCDAT(NI),
&       [M:PDQ2]AMTNOTLIN(NI),WAMT,WSTAT) From TRTDEV
      Endif
      [M:PDQ2]AMTPIHFCC += WAMT
    Endif
  Endif
Next NI
# Issue X3-70225 - 2018-08-07 by SDEM : End

#----- Affichage foreground -----#
$AFFICH_SITUATION_LIG_CDE
Filter [PID] : Filter [PND]
Affzo [PDQ2]
Call TEMPOFF From GESECRAN
Return
#------------------------------------------#
# Avant de revenir Ă  la fenĂŞtre prĂŠcĂŠdente #
#------------------------------------------#
$FINSAI_VISUETAPOQ
nolign=SAVNOLIGN
Return

#--------------------------#
# Chargement ligne facture #
#--------------------------#
$CHARG_LIG_FAC
[M:PDQ2]NUM(I)      =[F:PID]NUM
[M:PDQ2]PIDLIN(I)   =[F:PID]PIDLIN
# Issue 82703 - 2012-10-11 by MUARN : ajout type facture et origine
[M:PDQ2]PIHTYP(I)   =[F:PID]PIHTYP
[M:PDQ2]TYPORI(I)   =[F:PID]TYPORI

If [F:PIH]NUM<>[F:PID]NUM
  Read [PIH] PIH0=[F:PID]NUM : If fstat Raz [F:PIH] : Endif
Endif
[M:PDQ2]ACCDAT(I)   =[F:PIH]ACCDAT
[M:PDQ2]FCY(I)      =[F:PID]FCY
If [F:PID]PIHTYP>2 [M:PDQ2]FACQTYPUU(I)=0-[M:PDQ2]FACQTYPUU(I) : Endif
[M:PDQ2]FACQTYPUU(I)=[F:PID]QTYPUU
If [F:PID]PIHTYP>2 [M:PDQ2]FACQTYPUU(I)=0-[M:PDQ2]FACQTYPUU(I) : Endif
[M:PDQ2]NETPRI(I)   =[F:PID]NETPRI
[M:PDQ2]CUR(I)      =[F:PIH]CUR
[M:PDQ2]AMTNOTLIN(I)=[F:PID]AMTNOTLIN
If [F:PID]PIHTYP>2 [M:PDQ2]AMTNOTLIN(I)=0-[M:PDQ2]AMTNOTLIN(I) : Endif
I+=1 : [M:PDQ2]NBFAC=I
Return


#############################################################################
# SITUATION_LIG_DA  : S/P d'affichage des DA d'un ligne cde     HN 31/03/00 #
#   NUMCDE   : NumĂŠro   de la commande Ă  traiter                            #
#   LINCDE   : NumĂŠro   de la ligne de commande Ă  traiter                   #
#   SEQCDE   : SĂŠquence de la ligne de commande Ă  traiter                   #
#   ABMSK    : AbrĂŠviation du masque ĂŠcran contenant les lignes             #
#   NOL      : NumĂŠro de ligne tableau des lignes commande (nolign-1)       #
# ------------------------------------------------------------------------- #
# RemplacĂŠ par l'action VISUETAPSH avec paramĂ¨tres :           MBT 05/12/00 #
#   PARAM(1) = NUM    : NumĂŠro   de la commande Ă  traiter                   #
#   PARAM(2) = LIN    : NumĂŠro   de la ligne de commande Ă  traiter          #
#   PARAM(3) = SEQ    : SĂŠquence de la ligne de commande Ă  traiter          #
#   PARAM(4) = WABMSK : AbrĂŠviation du masque ĂŠcran contenant les lignes    #
#   PARAM(5) = NOLIG  : NumĂŠro de ligne tableau lignes commande (nolign-1)  #
#   PARAM(6) = CODFNC : Code fonction ("POH")                               #
#############################################################################
#--------------------------------------------------------------#
# Avant la dĂŠfinition des boutons et l'ouverture de la fenĂŞtre #
#--------------------------------------------------------------#
$OUV_VISUETAPSH
#----- Variables locales -----#
Local Char     NUMCDE(GLONPOH) : NUMCDE=PARAM(1)
Local Integer  LINCDE          : LINCDE=val(PARAM(2))
Local Integer  SEQCDE          : SEQCDE=val(PARAM(3))
Local Char     WABMSK(4)       : WABMSK =PARAM(4)
Local Shortint NOL             : NOL=val(PARAM(5))
Local Char     FONCTION(3)     : FONCTION=PARAM(6)
Local Shortint SAVGNOLIGN, I
#-----
SAVNOLIGN=nolign
# Issue 17667 - 2012-01-16 by VPO : ajout visu des DA consommĂŠes sur POD1 - GBOUT9
If clalev([M:POD1])>0
  If evalue("[M:"+WABMSK+"]NBLIG=0") | evalue("[M:"+WABMSK+"]ITMREF=''")
    FIN=1
  Endif
Else
  If evalue("[M:"+WABMSK+"]NBLIG=0") | evalue("[M:"+WABMSK+"]ITMREF(NOL)=''")
    FIN=1
  Endif
Endif
Return
#---------------------------------#
# AprĂ¨s l'ouverture de la fenĂŞtre #
#---------------------------------#
$DEB_VISUETAPSH
Raz [M:PDQ4], I
Call TEMPON("O") From GESECRAN
#----- Lecture ligne commande Ă  traiter si nĂŠcessaire -----#
If [F:POQ]POHNUM<>NUMCDE | [F:POQ]POPLIN<>LINCDE | [F:POQ]POQSEQ<>SEQCDE
  Read [POQ] POQ0=NUMCDE;LINCDE;SEQCDE : If fstat Raz [F:POQ] : Endif
Endif
#----- Ouverture des fichiers si nĂŠcessaire ----#
If !clalev([F:PSO])  Local File PREQUISO   [PSO]  : Endif
If !clalev([F:PSD])  Local File PREQUISD   [PSD]  : Endif
If !clalev([F:PWO])  Local File PWRKORDERS [PWO]  : Endif
If !clalev([F:PWO2]) Local File PWRKORDERS [PWO2] : Endif
If !clalev([F:ORD])  Local File ORDERS     [ORD]  : Endif
#----- Chargement des zones dans le masque -----#
[M:PDQ4]POHNUM=NUMCDE
[M:PDQ4]POPLIN=LINCDE
# Issue 17667 - 2012-01-16 by VPO : ajout visu des DA consommĂŠes sur POD1 - GBOUT9
If clalev([M:POD1])>0
  [M:PDQ4]ITMREF=evalue("[M:"+WABMSK+"]ITMREF")
  [M:PDQ4]ITMDES=evalue("[M:"+WABMSK+"]ITMDES")
  WBPSNUM=[M:POD1]BPSNUM
  Local Decimal  WCOEUOM
  [M:PDQ4]QTYUOM=evalue("[M:"+WABMSK+"]QTYPUU(NOL)")
  [M:PDQ4]UOM   =evalue("[M:"+WABMSK+"]PUU")
  #----- Calcul qtĂŠ commande en US -----#
  [M:PDQ4]STU   =evalue("[M:"+WABMSK+"]STU")
  Call PCAL_QTY([M:PDQ4]QTYUOM,[M:PDQ4]UOM,[M:PDQ4]QTYSTU,[M:PDQ4]STU,
&               [M:PDQ4]ITMREF,WBPSNUM,1,WCOEUOM) From TRTACHQTE1
Else
  [M:PDQ4]ITMREF=evalue("[M:"+WABMSK+"]ITMREF(NOL)")
  [M:PDQ4]ITMDES=evalue("[M:"+WABMSK+"]ITMDES(NOL)")
  WBPSNUM=[M:POH0]BPSNUM
  [M:PDQ4]QTYUOM=evalue("[M:"+WABMSK+"]QTYUOM(NOL)")
  [M:PDQ4]UOM   =evalue("[M:"+WABMSK+"]UOM(NOL)")
  [M:PDQ4]QTYSTU=evalue("[M:"+WABMSK+"]QTYSTU(NOL)")
  [M:PDQ4]STU   =evalue("[M:"+WABMSK+"]STU(NOL)")
Endif
#----- Chargement des DA de la ligne de commande -----#
If evalue("[M:"+WABMSK+"]CREFLG(NOL)")<>0
  #----- Ligne de commande dĂŠjĂ  crĂŠĂŠe et donc mĂ j PREQUISO effectuĂŠe -----#
  # Issue 17667 - 2012-01-16 by VPO : ajout visu des DA consommĂŠes sur POD1 - GBOUT9
  #For [PSO] PSO1 Where POHNUM=NUMCDE & POPLIN=LINCDE
  For [PSO] PSO1 Where POHNUM=NUMCDE & POPLIN=LINCDE & POQSEQ=SEQCDE
    [M:PDQ4]PSHNUM(I)=[F:PSO]PSHNUM
    [M:PDQ4]PSDLIN(I)=[F:PSO]PSDLIN
    [M:PDQ4]WUOM  (I)=[M:PDQ4]UOM
    [M:PDQ4]WUOM1 (I)=[M:PDQ4]UOM
    [M:PDQ4]WSTU  (I)=[M:PDQ4]STU
    [M:PDQ4]WSTU1 (I)=[M:PDQ4]STU
    #----- Alimentation des quantitĂŠs prises en UC et US -----#
    If [M:PDQ4]UOM=[F:PSO]PUU
      [M:PDQ4]WQTYUOM(I)=[F:PSO]QTYPUU
    Elsif [M:PDQ4]UOM=[F:PSO]STU
      [M:PDQ4]WQTYUOM(I)=[F:PSO]QTYSTU
    Else
      Call PCAL_QTY([F:PSO]QTYPUU,[F:PSO]PUU,[M:PDQ4]WQTYUOM(I),[M:PDQ4]UOM,[M:PDQ4]ITMREF,
&                   [M:POH0]BPSNUM ,1,GBIDD1) From TRTACHQTE1
    Endif
    [M:PDQ4]WQTYSTU(I)=[F:PSO]QTYSTU
    #-----
    Gosub QTE_RESTANTE
    #-----
    I+=1 : [M:PDQ4]NBLIG=I
    If I>dim([M:PDQ4]PSHNUM)-1  GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
  Next
Else
  #----- La ligne de commande n'est pas encore crĂŠĂŠe -----#
  For [PWO] PWO0 Where PRONUM=adxuid(1)
&                    & CODFNC=FONCTION
&                    & LINNUM=evalue("[M:"+WABMSK+"]POHLIN(NOL)")
&                    & WIPTYP=2
&                    & WIPSTA=2
    If [F:PWO]PSDLIN=0
      Read [ORD] ORD0=[F:PWO]WIPTYP;[F:PWO]WIPNUM;[F:PWO]ITMREF
      If fstat  Raz [F:ORD] : Endif
      If [F:ORD]ABBFIL="PSD"
        [M:PDQ4]PSHNUM(I)=[F:ORD]VCRNUM
        [M:PDQ4]PSDLIN(I)=[F:ORD]VCRLIN
      Else
        [M:PDQ4]PSHNUM(I)=""
        [M:PDQ4]PSDLIN(I)=0
      Endif
    Else
      [M:PDQ4]PSHNUM(I)=[F:PWO]WIPNUM
      [M:PDQ4]PSDLIN(I)=[F:PWO]PSDLIN
    Endif
    If [M:PDQ4]PSHNUM(I)<>""
      [M:PDQ4]WUOM(I) =[M:PDQ4]UOM
      [M:PDQ4]WUOM1(I)=[M:PDQ4]UOM
      [M:PDQ4]WSTU (I)=[M:PDQ4]STU
      [M:PDQ4]WSTU1(I)=[M:PDQ4]STU
      #----- Alimentation des quantitĂŠs prises en UC et US -----#
      If [M:PDQ4]UOM=[F:PWO]PUU
        [M:PDQ4]WQTYUOM(I)=[F:PWO]QTYPUU
      Elsif [M:PDQ4]UOM=[F:PWO]STU
        [M:PDQ4]WQTYUOM(I)=[F:PWO]QTYSTU
      Else
        Call PCAL_QTY([F:PWO]QTYPUU,[F:PWO]PUU,[M:PDQ4]WQTYUOM(I),[M:PDQ4]UOM,[M:PDQ4]ITMREF,
&                     [M:POH0]BPSNUM ,1,GBIDD1) From TRTACHQTE1
      Endif
      [M:PDQ4]WQTYSTU(I)=[F:PWO]QTYSTU
      #-----
      Gosub QTE_RESTANTE
      #-----
      I+=1 : [M:PDQ4]NBLIG=I
      If I>dim([M:PDQ4]PSHNUM)-1  GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
    Endif
  Next
Endif
#----- Affichage foreground -----#
Affzo [PDQ4]
Call TEMPOFF From GESECRAN
Return
#------------------------------------------------#
# Chargement des quantitĂŠs restantes en UC et US #
#------------------------------------------------#
$QTE_RESTANTE
If [F:PSD]PSHNUM<>[M:PDQ4]PSHNUM(I) | [F:PSD]PSDLIN<>[M:PDQ4]PSDLIN(I)
  Read [PSD] PSD0=[M:PDQ4]PSHNUM(I);[M:PDQ4]PSDLIN(I)
  If fstat  Raz [F:PSD] : Endif
Endif
#----- Ligne DA non sodĂŠe -----#
If [F:PSD]LINCLEFLG<>2
  If [M:PDQ4]UOM=[F:PSD]PUU
    [M:PDQ4]WQTYRES(I)=[F:PSD]QTYPUU-[F:PSD]ORDQTYPUU
  Elsif [M:PDQ4]UOM=[F:PSD]STU
    [M:PDQ4]WQTYRES(I)=[F:PSD]QTYSTU-[F:PSD]ORDQTYSTU
  Else
    GBIDD1=[F:PSD]QTYPUU-[F:PSD]ORDQTYPUU
    Call PCAL_QTY(GBIDD1,[F:PSD]PUU,[M:PDQ4]WQTYRES(I),[M:PDQ4]UOM,[M:PDQ4]ITMREF,
&                 [M:POH0]BPSNUM ,1,GBIDD2) From TRTACHQTE1
  Endif
  #-----
  [M:PDQ4]WQTYRESSTU(I)=[F:PSD]QTYSTU-[F:PSD]ORDQTYSTU
  #----- Recherche des prises en compte non enregistrĂŠes -----#
  For [PWO2] PWO0 Where PRONUM=adxuid(1)
&                     & CODFNC=FONCTION
&                     & WIPTYP=2
&                     & WIPSTA=2
    Raz GBIDI2
    If [F:PWO2]PSDLIN=0
      Read [ORD] ORD0=[F:PWO2]WIPTYP;[F:PWO2]WIPNUM;[F:PWO2]ITMREF
      If fstat  Raz [F:ORD] : Endif
      If [F:ORD]ABBFIL="PSD"
&      & [F:ORD]VCRNUM=[M:PDQ4]PSHNUM(I)
&      & [F:ORD]VCRLIN=[M:PDQ4]PSDLIN(I)
         GBIDI2=1
      Endif
    Elsif [F:PWO2]WIPNUM=[M:PDQ4]PSHNUM(I)
&       & [F:PWO2]PSDLIN=[M:PDQ4]PSDLIN(I)
      GBIDI2=1
    Endif
    If GBIDI2
      If [M:PDQ4]UOM=[F:PWO2]PUU
        [M:PDQ4]WQTYRES(I)-=[F:PWO2]QTYPUU
      Elsif [M:PDQ4]UOM=[F:PWO2]STU
        [M:PDQ4]WQTYRES(I)-=[F:PWO2]QTYSTU
      Else
        Call PCAL_QTY([F:PWO2]QTYPUU,[F:PWO2]PUU,GBIDD1,[M:PDQ4]UOM,[M:PDQ4]ITMREF,
&                     [M:POH0]BPSNUM ,1,GBIDD2) From TRTACHQTE1
        [M:PDQ4]WQTYRES(I)-=GBIDD1
      Endif
      #-----
      [M:PDQ4]WQTYRESSTU(I)-=[F:PWO2]QTYSTU
    Endif
  Next
#----- Ligne DA soldĂŠe -----#
Else
  Raz [M:PDQ4]WQTYRES(I), [M:PDQ4]WQTYRESSTU(I)
Endif
Return
#------------------------------------------#
# Avant de revenir Ă  la fenĂŞtre prĂŠcĂŠdente #
#------------------------------------------#
$FINSAI_VISUETAPSH
nolign=SAVNOLIGN
Return


#---------------------------------------------------#
# Appel du point d'entrĂŠe PURQTYRND depuis les      #
# trts SUBPSH, SUBPOH, SUBPOI, SUBPOD et TRTACHPOD1 #
# ------------------------------------------------- #
# SpĂŠcification du type d'arrondi Ă  effectuer       #
#    sur la quantitĂŠ d'achat                        #
#  QTEUA      : Contient la qtĂŠ d'achat Ă  arrondir  #
#  UOMUA ou [M]PUU(NOL) ou                          #
#  [F:POQ]PUU : Contient l'unitĂŠ d'achat            #
#  TYPARRONDI : 0 Normal (au plus proche)           #
#               1 Arrondi Ă  la dĂŠcimale infĂŠrieure  #
#               2 Arrondi Ă  l'entier    infĂŠrieur   #
#               3 Arrondi Ă  la dĂŠcimale supĂŠrieure  #
#               4 Arrondi Ă  l'entier    supĂŠrieur   #
#---------------------------------------------------#
$POINT_PURQTYRND
Local Libelle TYPARRONDI, WNBDEC
Local Decimal QTEARR
Local Char    WUNITACH(GLONUOM)
# Issue 76174 - 2011-09-13 by VPO : ajout cas depuis CALQTY de TRTDIV
If dim(CALQTYTRTDIV)>0 & CALQTYTRTDIV=1
  WUNITACH=UOMUA
Elsif (!clalev([M:PMG]) | clalev([M:POI1])) & dim(NOL)>0
  WUNITACH=[M]PUU(NOL)
Else
  WUNITACH=[F:POQ]PUU
Endif
Raz TYPARRONDI
If dim(GPURQTYRND)>0 & GPURQTYRND>0 & GPURQTYRND<6
  TYPARRONDI=GPURQTYRND-1
Endif
GPOINT="PURQTYRND" : Gosub ENTREE From EXEFNC
If TYPARRONDI>4  Raz TYPARRONDI : Endif
If TYPARRONDI=0   : # Arrondi au plus proche
  Call QTEARR(QTEUA,WUNITACH) From TRTDIV
  # Issue 81507 - 2012-05-16 by MUARN : initialisation de WNBDEC
  If clalev([F:TUN])=0  Local File TABUNIT [TUN] : Endif
  If [F:TUN]UOM<>WUNITACH
    Read [TUN]TUN0=WUNITACH : If fstat Raz [F:TUN] : Endif
  Endif
  WNBDEC=[F:TUN]UOMDEC
Else
  If TYPARRONDI=2 | TYPARRONDI=4
    WNBDEC=0
  Else
    If clalev([F:TUN])=0  Local File TABUNIT [TUN] : Endif
    If [F:TUN]UOM<>WUNITACH
      Read [TUN]TUN0=WUNITACH : If fstat Raz [F:TUN] : Endif
    Endif
    WNBDEC=[F:TUN]UOMDEC
  Endif
  QTEARR=arr(QTEUA,10^-WNBDEC)
  If TYPARRONDI<3 : # Arrondi infĂŠrieur
    If QTEARR<=QTEUA+10^-(WNBDEC+3)
      QTEUA=QTEARR
    Else
      QTEUA=QTEARR-10^-WNBDEC
    Endif
  Else            : # Arrondi supĂŠrieur
    If QTEARR>=QTEUA-10^-(WNBDEC+3)
      QTEUA=QTEARR
    Else
      QTEUA=QTEARR+10^-WNBDEC
    Endif
  Endif
Endif
#----- La qtĂŠ UA ne doit pas ĂŞtre nulle -----#
If QTEUA=0
  If TYPARRONDI=2 | TYPARRONDI=4
    QTEUA=1
  Else
    If !clalev([F:TUN])  Local File TABUNIT [TUN] : Endif
    If [F:TUN]UOM<>WUNITACH
      Read [TUN]TUN0=WUNITACH : If fstat Raz [F:TUN] : Endif
    Endif
    WNBDEC=[F:TUN]UOMDEC
    QTEUA=10^-WNBDEC
  Endif
Endif
Return

#---------------------------------------------#
# Appel du point d'entrĂŠe COPLINPOH depuis le #
#         traitement SUBPOHA                  #
# ------------------------------------------- #
# L = indice de la ligne Ă  copier             #
# J = indice de la nouvelle ligne Ă  crĂŠer     #
# Masques ĂŠcrans [M:POH0], [M:POH1], [M:POH2] #
#          et [M:POH3] disponibles            #
#---------------------------------------------#
$POINT_COPLINPOH
GPOINT="COPLINPOH" : Gosub ENTREE From EXEFNC
Return

# Issue 70985 - 2012-02-28 by MUARN : landed cost-dĂŠplacĂŠ de SUBPOH Ă  SUBPOHB, trop de lignes
Subprog INI_TARIF(NOL,COUZON)
#-------------------------#
# Initialisation du tarif #
#-------------------------#
Value  Shortint NOL
Value  Char     COUZON
Local  Date     OLDRCPDAT
Local Integer   STAT
Local Decimal  DISCRGVAL(0..8)

# Raz Issue 93144 GA 10/2013 LINTYP parfois  non renseignĂŠ si gĂŠnĂŠration de commande depuis [M:POI1]
# If [M:POH2]ITMREF(NOL)=[F:ITM]ITMREF & [F:ITM]SCPFLG=2 End Endif

If [M:POH2]LINFLG(NOL)<>3 & [M:POH2]LINTYP(NOL)<>2
  OLDRCPDAT=[M:POH2]RETRCPDAT(NOL)
  GPUU=[M:POH2]PUU(NOL) : Call RECH_TARIF ("POH",NOL) From TRTACHTAR1
  If OLDRCPDAT<>[M:POH2]RETRCPDAT(NOL)
    If [F:FCY]FCY<>[M:POH2]PRHFCY(NOL)
      Read [FCY] FCY0=[M:POH2]PRHFCY(NOL) : If fstat Raz [F:FCY] : Endif
    Endif
    Call CTL_JOU2 ([M:POH2]RETRCPDAT(NOL),[M:POH0]ORDDAT,[M:POH2]OFS(NOL)) From TRTACHCDE1
    Raz mkstat, GMESSAGE
    [M:POH2]EXTRCPDAT(NOL)=[M:POH2]RETRCPDAT(NOL)
    If COUZON<>"EXTRCPDAT" & !GIMPORT Affzo [POH2]EXTRCPDAT(NOL) : Endif
  Endif
Endif
[M:POH2]LINAMT(NOL)=[M:POH2]NETPRI(NOL)*[M:POH2]QTYUOM(NOL)
Call ARRDEV([M:POH2]LINAMT(NOL),GCUR) From TRTDIV
If !GIMPORT
   Affzo [POH2]GROPRI(NOL)
   If GCOLREM(0)<>"" Affzo [POH2]DISCRGVAL1(NOL) : Endif
   If GCOLREM(1)<>"" Affzo [POH2]DISCRGVAL2(NOL) : Endif
   If GCOLREM(2)<>"" Affzo [POH2]DISCRGVAL3(NOL) : Endif
   If GCOLREM(3)<>"" Affzo [POH2]DISCRGVAL4(NOL) : Endif
   If GCOLREM(4)<>"" Affzo [POH2]DISCRGVAL5(NOL) : Endif
   If GCOLREM(5)<>"" Affzo [POH2]DISCRGVAL6(NOL) : Endif
   If GCOLREM(6)<>"" Affzo [POH2]DISCRGVAL7(NOL) : Endif
   If GCOLREM(7)<>"" Affzo [POH2]DISCRGVAL8(NOL) : Endif
   If GCOLREM(8)<>"" Affzo [POH2]DISCRGVAL9(NOL) : Endif
   Affzo [POH2]NETPRI(NOL), LINAMT(NOL)
Endif
If [M:POH2]LINFLG(NOL)=1 [M:POH2]LINFLG(NOL)=2 : Endif
End

# Issue 70985 - 2012-03-16 by MUARN : landed cost dĂŠplacĂŠ de SUBPOH nombre de lignes
########################################################################
# INIT_COMPTES_LIGNE : S/P d'initialisation               MBT 01/09/06 #
#                des comptes d'une ligne de commande                   #
# -------------------------------------------------------------------- #
# Subprog INIT_COMPTES_LIGNE (NOL)                                     #
#   NOL    : Indice de la ligne de commande Ă  traiter (nolign-1)       #
########################################################################
Subprog INIT_COMPTES_LIGNE (NOL)
Value    Shortint NOL
#-----
Local    Shortint I
#----- Chargement de comptes avec "" pour dĂŠsactiver l'action d'init -----#
For I=1 To 10
  If evalue("dim([M:POH2]LINACC"+num$(I)+")")>0
    Assign "[M:POH2]LINACC"+num$(I)+"(NOL)" With ""
  Endif
Next I
#----- Si ligne vide, pas la peine d'initialiser ! -----#
If [M:POH2]ITMREF(NOL)=""  End : Endif
#-----
Local    Char     ID1(20)(1..1), ID2(20)(1..3)
Local    Shortint J, SAVNOLIGN : SAVNOLIGN=nolign
Local    Integer  STA
Local    Char     TPLAN  (GLONCOA)(1..10)
Local    Char     TCOMPTE(GLONGAC)(1..10)
Local    Char     WMESSAGE(80)
#----- Si import il faut prĂŠserver les classes [F:POP] et [F:POQ] -----#
If GIMPORT  Local File PORDERP [POP], PORDERQ [POQ] : Endif
#-----
If !clalev([F:GAD])  Local File GAUTACED [GAD] : Endif
Local File PORDER [TB0], PORDERQ [TB1], CPTANALIN [TB2]
nolign=NOL+1
#-----
[F:TB0]=[M:POH0] : [F:TB0]=[M:POH1] : [F:TB0]=[M:POH2] : [F:TB0]=[M:POH3]
[F:TB1]=[M:POH0] : [F:TB1]=[M:POH1] : [F:TB1]=[M:POH2] : [F:TB1]=[M:POH3]
For I=0 To dim([F:TB0]INVDTALIN1)-1 : [F:TB0]INVDTALIN1(I)=GINVDTALIN(I) : Next I
If [F:TB1]LINPURTYP=0
  Case [M:POH2]LINTYP(NOL)
    When 3       : [F:TB1]LINPURTYP=3
    When Default : [F:TB1]LINPURTYP=1
  Endcase
Endif
#----- Chargement table liĂŠe PORDERP pour la piĂ¨ce auto PORD -----#
[F:POP]=[M:POH0] : [F:POP]=[M:POH1] : [F:POP]=[M:POH2] : [F:POP]=[M:POH3]
Gosub CHARGLIGNE From SUBPOHA
#----- Chargement pseudo fichier lignes comptables CPTANALIN [TB2] -----#
Raz [F:TB2]
[F:TB2]ABRFIC="POP"
[F:TB2]VCRNUM=[M:POH0]POHNUM
[F:TB2]VCRLIN=[M:POH2]POPLIN(NOL)
[F:TB2]VCRSEQ=1
[F:TB2]ANALIG=1
#-----
For I=1 To max(GNBCOA,2)
  J=GTYPLED(I)
  If J
    [F:TB2]LED(J-1)=GLEDSOC(I)
    [F:TB2]COA(J-1)=GCOA(I)
    [F:TB2]ACC(J-1)=evalue("[M:POH2]LINACC"+num$(I)+"(NOL)")
  Endif
Next I
#-----
For I=1 To max(GNBDIE,GOPTCANA)
  [F:TB2]DIE(I-1)=GDIE(I)
  If evalue("dim([M:POH2]CCE"+num$(I)+")")>0
    [F:TB2]CCE(I-1)=evalue("[M:POH2]CCE"+num$(I)+"(NOL)")
  Endif
Next I
#-----
ID1(1)=[M:POH0]POHNUM : # Num pas chargĂŠ en crĂŠation si cteur auto !!
ID2(1)=[M:POH0]POHNUM
ID2(2)=num$([M:POH2]POPLIN(NOL))
ID2(3)="1"
If [M:POH0]POHNUM=""  Raz ID1,ID2 : Endif
#-----
Call COMPTE("PORD",1,ID1,ID2,TPLAN,TCOMPTE,STA,WMESSAGE) From TRTACHCDE1
If STA
  Raz TPLAN, TCOMPTE
Else
  For I=1 To 10
    If TPLAN(I)<>""
     #J=find(TPLAN(I),GCOA(1..GNBCOA))
      J=find([F:GAD]LEDTYP(I-1),GTYPLED(1..GNBTYPLED))
      If J
        Assign "[M:POH2]LINACC"+num$(J)+"(NOL)" With TCOMPTE(I)
      Endif
    Endif
  Next I
Endif
#-----
If GPURCMMDAT=1
  [M:POH2]DATBUD(NOL)=[M:POH0]ORDDAT
Else
  [M:POH2]DATBUD(NOL)=[M:POH2]EXTRCPDAT(NOL)
Endif
#-----
Close Local File [TB0], [TB1], [TB2]
nolign=SAVNOLIGN
End

# Issue 84130 - 2012-03-16 by MUARN : landed cost dĂŠplacĂŠ de SUBPOH nombre de lignes
$CTRL_INTERSITE
#-----------------------------------------------------#
# ContrĂ´le et chargement des zones pour l'inter-sites #
# --------------------------------------------------- #
# WPOHFCY : Site de commande                          #
# WBPSNUM : Fournisseur de la commande                #
# WORI    : Origine de l'appel (1=POHFCY, 2=BPSNUM)   #
#-----------------------------------------------------#
If GREP="D"
  Local Char    SVGCPY(GLONCPY) : SVGCPY=GCPY
  Local Integer SVGBET          : SVGBET=[M:POH0]BETFCY
  Local Char    SSTOFCY(GLONFCY): SSTOFCY=[M:POH1]STOFCY# Issue 83689 - 2012-07-25 by MUARN : changement de site en intersite et meme sociĂŠtĂŠ
Endif
Raz GRCPFCY
Call CTRL_INTERSITE(WPOHFCY,WBPSNUM,2,[M:POH0]BETFCY,[M:POH0]BETCPY,[M:POH0]SALFCY,
&                   [M:POH1]STOFCY,[M:POH0]BPCORD,[M:POH1]INVFCY,[M:POH1]BPCINV,
&                   [M:POH0]DME) From TRTACHCTL1
If mkstat  GERR=1 : Return : Endif

#----- Si inter-sites et site d'expĂŠdition vide, il doit ĂŞtre saisissable -----#
If !GIMPORT & [M:POH0]BETFCY=2 & [M:POH1]STOFCY=""
  If [F:PTR]PTRTYP<>3 & [F:PTR]PTRNUM<>GPTRNUM
    Read [PTR] PTR0=3;GPTRNUM : If fstat  Raz [F:PTR] : Endif
  Endif
  If [F:PTR]STOFCYCOD<>1
    GMESSAGE=mess(257,194,1) : GERR=1 : mkstat=1 : Return
  Endif
Endif
#----- Si inter-sociĂŠtĂŠs et site de facturation vide, il doit ĂŞtre saisissable -----#
If !GIMPORT & [M:POH0]BETCPY=2 & [M:POH0]SALFCY<>"" & [M:POH1]INVFCY=""
  If [F:PTR]PTRTYP<>3 & [F:PTR]PTRNUM<>GPTRNUM
    Read [PTR] PTR0=3;GPTRNUM : If fstat  Raz [F:PTR] : Endif
  Endif
  If [F:PTR]INVFCYCOD<>1
    GMESSAGE=mess(297,194,1) : GERR=1 : mkstat=1 : Return
  Endif
Endif
#-----
If [M:POH0]BETFCY=2
  [M:POH0]ORIFCY=WPOHFCY
  [M:POH1]PRHFCYLIB=space$(max(22-(len(mess(605,197,1))+GLONFCY),0))+mess(605,197,1)-GRCPFCY
  Actzo [POH1]STOFCY
Else
  Raz [M:POH0]ORIFCY, [M:POH1]PRHFCYLIB, GSTOFCY
  Grizo [POH1]STOFCY
Endif
Affzo [POH0]BETFCY, BETCPY
Affzo [POH1]PRHFCYLIB, STOFCY, INVFCY
If GREP="D" & [M:POH2]NBLIG<>0
  # Issue 83689 - 2012-07-25 by MUARN : changement de site en intersite et meme sociĂŠtĂŠ
  #If [M:POH0]BETFCY<>2 | SVGCPY<>GCPY
  If [M:POH0]BETFCY<>2 | SVGCPY<>GCPY | SSTOFCY <> [M:POH1]STOFCY
    For I=0 To [M:POH2]NBLIG-1
      Raz [M:POH2]LINSTOFCY(I)
      If [M:POH0]BETFCY=2
        Look [ITF] ITF0=[M:POH2]ITMREF(I);[M:POH1]STOFCY
        If !fstat
          [M:POH2]LINSTOFCY(I)=[M:POH1]STOFCY
        Endif
      Endif
    Next
  Endif
Endif
Return

