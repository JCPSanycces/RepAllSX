#<AdxTL>@(#)8.0.0.0 $Revision$
Raz GNBMASKOUV , GPILOBJ
Call OBJET("AFT",GBIDC1,GBIDC2) From GOBJET
End

#---------------------------------------------------------#
$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBAFTB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
 When "APRES_CRE"    : Gosub APRES_CRE
 When "SETBOUT"      : Gosub SETBOUT
 When "FIN"          : Gosub FIN
 When "LIENS"        : Gosub LIENS
 When "RAZCRE"       : Gosub RAZCRE
 When "INICRE"       : Gosub INICRE
 When "INIMOD"       : Gosub INIMOD
 When "ECRITURE"     : Gosub ECRITURE
 When "CREATION"     : Gosub CREATION
 When "MODIF"        : Gosub MODIF
 When "ANNULE"       : Gosub ANNULE
 When "CHANGE"       : Gosub CHANGE
 When "APRES_MOD"    : Gosub APRES_MOD
 When "AP_ANNULE"    : Gosub AP_ANNULE
 When "INIT"         : Gosub INIT
 When "INIT_DIA"     : Gosub INIT_DIA
 When "CONTROLE"     : Gosub CONTROLE
 When "EXEC"         : Gosub EXEC
Endcase
If PSUBB
 Gosub ACTION From SUBAFTB
Endif
Return
#---------------------------------------------------------#

$AP_ANNULE
$APRES_MOD
Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
Return

#---------------------------------------------------------#
$OUVRE
# =1 accès d'après habilitations, =2 accès toutes les fonctions
Local Integer FLGMOD
# Pour éviter de générer tous les profils si un seul a été modifié
Local Char    PRFMOD(GLONAFT)

Local Char    MESSAGE(250)
PRFMOD = "~"
If clalev([F:AUS2])=0 : Local File AUTILIS [AUS2] : Endif
Return

#---------------------------------------------------------#
$SETBOUT
If [M]PRFCOD=GSUPER
 Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
If !CLECUR or [M:AFT1]ALLFCT=2 or REP<>""
 Call VIREBOUT(CHAINE,"12") From GOBJET : # Habilitations, Copie
Endif
If CLECUR & REP=""
 CHMEN += "4" : # Mise à jour des codes accés
Endif
Return

#---------------------------------------------------------#
$AVANT_MODFIC
If [M:AFT1]ALLFCT<>[F:AFT]ALLFCT
 Gosub FLAGS
Endif
Return

#---------------------------------------------------------#
$APRES_CRE
Gosub FLAGS
Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
Return

#------------------------#
$FLAGS
Case [M:AFT1]ALLFCT
 When 1 : FLGMOD = 1
 When 2 : If FLGMOD=0 : FLGMOD = 2 : Endif
Endcase
If PRFMOD<>[M:AFT0]PRFCOD
 If PRFMOD="~"
  PRFMOD = [M:AFT0]PRFCOD
 Else
  PRFMOD = ""
 Endif
Endif
Return

#---------------------------------------------------------#
$CHANGE
Update [AXX] Where CODFIC="AFCTFCT" & ZONE = "INTPRF" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA AFCTFCT"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

#---------------------------------------------------------#
$FIN
## mise à jour de la table AFCTFCY (droits profil fonction)
If FLGMOD
 # Mise à jour des droits d'accès aux fonctions
 # Cette opération peut être longue mais elle est nécessaire pour que vos modifications soient prises en compte
 # Voulez-vous faire cette mise à jour maintenant ?
 MESSAGE = mess(88,127,1)+"\"+mess(105,127,1)+"\"+mess(106,127,1)
 OK = 2 : Call OUINON(MESSAGE,OK) From GESECRAN
 If OK=2
  Call MAJAFF2(PRFMOD) From SUBAFP1
  If FLGMOD=1
   Call MAJAFF(PRFMOD) From SUBAFP1
  Endif
 Endif
Endif
Return

#---------------------------------------------------------#
$LIENS

# Chargement des droits d'accès liés au profil fonction
If [M:AFT0]PRFCOD<>""
 If [F:AFT]ALLACS<>2
  nolign = 0
  For [ACC]CODACC Where PRFCOD=[M:AFT0]PRFCOD & [ACC]CODACC<>"" & USR=""
   If !find([F:ACC]CODACC,[M:AFT1]CODACC)
    If nolign>dim([M:AFT1]CODACC)-1
     Call ERREUR(mess(26,100,1)) From GESECRAN : # Tableau plein
     Break
    Endif
    nolign += 1
    [M:AFT1] = [F:ACC]
   Endif
  Next
  [M:AFT1]NBACC = nolign
 Endif
Endif

# Chargement des droits sur les groupes d'édition
I = len(mess(0,97,1))
If I>dim([M:AFT3]AUTETA) or I>dim([F:AFT]AUTETA)
 Call ERREUR(mess(26,100,1)) From GESECRAN : # Tableau plein
Endif
[M:AFT3]NBETA = min(len(mess(0,97,1)),dim([F:AFT]AUTETA),dim([M:AFT3]AUTETA))
For I=1 To [M:AFT3]NBETA
 [M:AFT3]AUTETA(I-1) = [F:AFT]AUTETA(I-1)
Next I

# Chargement des sites
K = 0
For I=1 To len(mess(0,14,1))
 If left$(mess(I,14,1),1)="#"
  Break
 Elsif GMODU(I)=2
  [M:AFT2]MODULE(K) = I
  [M:AFT2]FCYDEF(K) = [F:AFT]FCYDEF(I-1)
  K += 1
 Endif
Next I
[M:AFT2]NBSIT = K

Gosub GRISE_ACS
Gosub GRISE_ETA

Return

#---------------------------------------------------------#
$ANNULE
Delete [ACC] Where PRFCOD=[L]CODE
If fstat=1  : GOK=-1 : Call RSTA("ACC",[L]CODE) From GLOCK : Return : Endif
Delete [AXX] Where CODFIC="AFCTFCT" & ZONE = "INTPRF"  & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK
Endif
Return

#----------------------#
$GRISE_ACS
If [M]PRFCOD=GSUPER
 [M:AFT1]ALLFCT=2
 [M:AFT1]ALLACS=2
 Affzo [M:AFT1]ALLFCT, ALLACS
 Grizo [M:AFT1]ALLFCT, ALLACS
 Effzo [M:AFT1]15
 Grizo [M:AFT1]15
Elsif !instr(1,GUSRAUZ(1),"A")
 Grizo [M:AFT1]ALLFCT, ALLACS, 15
Else
 Actzo [M:AFT1]ALLFCT, ALLACS
 If [M]ALLACS=2
  Effzo [M:AFT1]15
  Grizo [M:AFT1]15
 Else
  Actzo [M:AFT1]15
 Endif
Endif

#F_add_admca_managment
# Issue 107311
If GPROFIL<>GSUPER
  Actzo [M:AFT1]ALLFCT
  Grizo [M:AFT1]ALLFCT
Endif
# End issue 107311
Return

#----------------------#
$GRISE_ETA
If [M]PRFCOD=GSUPER
 [M:AFT3]DIFIMP = 2
 [M:AFT3]FILTRE = "*"
 For I=0 To [M]NBETA-1
  [M:AFT3]AUTETA(I) = 2
 Next I
 Affzo [AFT3]DIFIMP,FILTRE, 30
 Diszo [AFT3]DIFIMP,FILTRE, 30
Elsif [M]ALLFCT=2
 Actzo [M:AFT3]DIFIMP
 [M:AFT3]FILTRE = "*"
 For I=0 To [M]NBETA-1
  [M:AFT3]AUTETA(I) = 2
 Next I
 Affzo [AFT3]FILTRE, 30
 Diszo [AFT3]FILTRE, 30
Else
 Actzo [M:AFT3]DIFIMP, FILTRE, 30
Endif
Return

#---------------------------------------------------------#
$RAZCRE
#F_add_admca_managment
# Issue 113908
If GPROFIL<>GSUPER
  Actzo [M:AFT1]ALLFCT
  Grizo [M:AFT1]ALLFCT
Endif
# End issue 113908

[M:AFT1]FLGPOR = 2
Affzo [M:AFT1]FLGPOR

[M:AFT3]NBETA  = len(mess(0,97,1))
For I=0 To [M:AFT3]NBETA-1
 [M:AFT3]AUTETA(I) = 2
Next I
Affzo [AFT3]
K = 0
For I=1 To len(mess(0,14,1))
 If left$(mess(I,14,1),1)="#"
  Break
 Elsif GMODU(I)=2
  [M:AFT2]MODULE(K) = I
  K += 1
 Endif
Next I
[M:AFT2]NBSIT = K
Affzo [AFT2]
Return

#---------------------------------------------------------#
$INICRE
Gosub ECRITURE
Return

#---------------------------------------------------------#
$INIMOD
$ECRITURE
For I=0 To dim([F:AFT]AUTETA)-1
 If [F:AFT]AUTETA(I)<>1 & [F:AFT]AUTETA(I)<>2
  [F:AFT]AUTETA(I)=2
 Endif
Next I
Raz [F:AFT]FCYDEF
For I=0 To [M:AFT2]NBSIT-1
 [F:AFT]FCYDEF([M:AFT2]MODULE(I)-1) = [M:AFT2]FCYDEF(I)
Next I
Return

#---------------------------------------------------------#
$MODIF
Delete [ACC] Where PRFCOD=CLECUR1
If fstat=1
 GOK=-1 : Call RSTA("ACC",CLECUR1) From GLOCK : Return
Endif
Gosub CREATION
Return

#---------------------------------------------------------#
$CREATION
Call MAJTEXTRA([M]INTPRF,"AFCTFCT","INTPRF",[M]PRFCOD,"") From ATEXTRA
If [M:AFT1]ALLACS=2 : # Tous accès autorisés
 For [ACS]ACS0
  Raz [F:ACC]
  [F:ACC]CONSUL = 2
  [F:ACC]EXEC   = 2
  [F:ACC]MODIF  = 2
  [F:ACC]USR = ""
  [F:ACC]PRFCOD = [M:AFT0]PRFCOD
  [F:ACC]CODACC = [F:ACS]CODACC
  Write [ACC]
  If fstat
   GOK = 0 : Call FSTA("ACC") From GLOCK : Break
  Endif
 Next ACS
 If GOK<1
  Return
 Endif
Else
 For nolign=1 To [M:AFT1]NBACC
  Raz [F:ACC]
  [F:ACC] = [M:AFT1]
  [F:ACC]PRFCOD = [M:AFT0]PRFCOD
  [F:ACC]USR = ""
  Write [ACC]
  If fstat
   GOK = 0 : Call FSTA("ACC") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Return : Endif
Endif
Raz [F:ACC]
[F:ACC]CONSUL = 2
[F:ACC]EXEC   = 2
[F:ACC]MODIF  = 2
[F:ACC]USR = ""
[F:ACC]CODACC = ""    : # Code accès vide pour Crystal Report
[F:ACC]PRFCOD = [M:AFT0]PRFCOD
Write [ACC]
If fstat
 GOK = 0 : Call FSTA("ACC") From GLOCK : Return
Endif
Return

#------------------------------------------------------------------------------------------------------#
# Action ACOPACSAFT : Copie des codes accés du profil fonction sur les utilisateurs du même profil
#------------------------------------------------------------------------------------------------------#

$INIT
Local File AUTILIS [AUS] , AFCTFCT [AFT] , ACCES [ACC] , ACCCOD [ACS] , ACCES [ACC2] , AMETUTI [AME]
Local Char    PROFIL(GLONAFT) , SYMBOLE(80) , MESSA(250) , CODE(GLONACS) , NAMAUS(50)
Local Char    CRITERE(250)
Local Integer ER , NBRAUS , OPTION
PROFIL  = PARAM(1)      : # Profil fonction
CODE    = PARAM(2)      : # Code d'accès (si vide=tous les codes du profil sont copiés)
OPTION  = val(PARAM(3)) : # 0->indéterminé, 1->maj/rajout, 2->annule et remplace
CRITERE = "1=1"
If CODE<>""
 OPTION = 1
Endif
If OPTION<>0
 BCRIT = ""
Endif
Return

#---------------------------#
$INIT_DIA
[M:AFT9]PRFCOD  = PROFIL
[M:AFT9]OPTION  = max(1,OPTION)
[M:AFT9]CRITERE = CRITERE
Return

#---------------------------#
$CONTROLE
If clalev([M:AFT9])>0
 OPTION  = [M:AFT9]OPTION
 CRITERE = [M:AFT9]CRITERE
Endif
If CRITERE=""
 CRITERE = "1=1"
Endif
Read [AFT]AFT0=PROFIL
If fstat
 # Profil fonction incorrect
 Call ERREUR(PROFIL-":"-mess(206,139,1)) From GESECRAN
 FIN = 0 : Return
Endif
If CODE<>""
 OK = 0
 For [ACC2] Where PRFCOD=[L]PROFIL & CODACC=[L]CODE
  OK = 1 : Break
 Next ACC2
 If !OK
  Call ERREUR([L]CODE-":"-mess(56,133,1)) From GESECRAN : # Code d'accès inexistant
  FIN = 0 : Return
 Endif
Endif
Raz ER , NBRAUS , NAMAUS
Onerrgo ER
For [AUS] Where evalue(CRITERE)
 K = 0
 If [F:AUS]PRFFCT<>""
  If [F:AUS]PRFFCT=[L]PROFIL
   K = 1
  Endif
 Elsif [F:AUS]CODMET<>""
  Read [AME]AME0=[F:AUS]CODMET
  If !fstat & [F:AME]PRFFCT=[L]PROFIL
   K = 1
  Endif
 Endif
 If K
  NBRAUS += 1
  If NBRAUS>5
   NAMAUS += ",..." : Break
  Elsif NBRAUS>1
   NAMAUS += ","
  Endif
  NAMAUS += [F:AUS]USR
 Endif
Next AUS
Onerrgo
If ER
 Call ERREUR(errmes$(ER)) From GESECRAN
 If BCRIT="" : FIN = 1 : Else : SAI = 1 : Endif : Return
Elsif NBRAUS=0
 # Il n'y a aucun utilisateur à traiter
 Call ERREUR(mess(94,130,1)) From GESECRAN
 If BCRIT="" : FIN = 1 : Else : SAI = 1 : Endif : Return
Endif
If [F:AFT]ALLACS=2
 If OPTION<>2
  # Le choix  de mise à jour n'est pas compatible avec les droits d'accés sur le profil fonction #
  Call ERREUR(func AFNC.MES(mess(93,130,1),PROFIL)) From GESECRAN
  If BCRIT="" : FIN = 1 : Else : SAI = 1 : Endif : Return
 Else
  # Tous les utilisateurs ($1$) avec le profil fonction $2$ vont avoir tous les codes accés autorisés
  # Voulez-vous continuer ?
  Call AVERTIR(func AFNC.MES2(mess(84,130,1),NAMAUS,PROFIL)+"\"+mess(205,100,1),OK) From GESECRAN
  If OK<>2 : FIN = 1 : Return : Endif
 Endif
Elsif CODE<>""
 # Mise à jour code d'accés $1$ sur tous les utilisateurs ($2$) avec le profil fonction $3$
 # Voulez-vous continuer ?
 Call AVERTIR(func AFNC.MES3(mess(83,130,1),CODE,NAMAUS,PROFIL)+"\"+mess(205,100,1),OK) From GESECRAN
 If OK<>2 : FIN = 1 : Return : Endif
Elsif OPTION=2
 # Voulez-vous remplacer tous les codes d'accés des utilisateurs ($1$) par ceux du profil fonction $2$ ?
 Call AVERTIR(func AFNC.MES2(mess(89,130,1),NAMAUS,PROFIL),OK) From GESECRAN
 If OK<>2 : FIN = 1 : Return : Endif
Else
 # Voulez-vous mettre à jour les codes d'accés des utilisateurs ($1$) avec ceux du profil fonction $2$ ?
 Call AVERTIR(func AFNC.MES2(mess(90,130,1),NAMAUS,PROFIL),OK) From GESECRAN
 If OK<>2 : FIN = 1 : Return : Endif
Endif
# Mise à jour code d'accés $1$ sur tous les utilisateurs ($2$) avec le profil fonction $3$
TIT = func AFNC.MES3(mess(83,130,1),CODE,NAMAUS,PROFIL)
Return

$ER
ER = errn
Resume

#---------------------------#
$EXEC
TRA = 1
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call DEBTRANS From GLOCK
For [AUS] Where evalue(CRITERE)
 K = 0
 If [F:AUS]PRFFCT<>""
  If [F:AUS]PRFFCT=[L]PROFIL
   K = 1
  Endif
 Elsif [F:AUS]CODMET<>""
  Read [AME]AME0=[F:AUS]CODMET
  If !fstat & [F:AME]PRFFCT=[L]PROFIL
   K = 1
  Endif
 Endif
 If K
  If OPTION<>2 & [F:AUS]ALLACS=2
   # L'utilisateur # a déjà tous les droits à tous les codes d'accès
   Call ECR_TRACE(func AFNC.MES(mess(91,130,1),[F:AUS]USR),-1) From GESECRAN
  Else
   SYMBOLE = "AUS"+[F:AUS]USR
   Lock =SYMBOLE
   If fstat
    # Utilisateur en cours de modification
    Call ECR_TRACE([F:AUS]USR-":"-mess(85,130,1),1) From GESECRAN
   Else
    Gosub TR_MAJ
    If GOK=1
     Call ECR_TRACE(func AFNC.MES(MESSA,[F:AUS]USR),0) From GESECRAN
    Endif
    Unlock =SYMBOLE
   Endif
  Endif
 Endif
Next AUS
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

#---------------------------#
$TR_MAJ
GOK = 1
Trbegin [AUS] , [ACC]
 If OPTION=2
  Delete [ACC] Where USR=[F:AUS]USR
  If fstat=1
   GOK=-1 : GLOCK = "$ACCES" : Goto ROLL_TR_MAJ
  Elsif fstat>5
   GOK = 0 : Call RSTA("ACC","") From GLOCK : Goto AB_TR_MAJ
  Endif
  If [F:AFT]ALLACS=1 & [F:AUS]ALLACS=2
   MESSA = mess(86,130,1) : # L'utilisateur # n'a plus accés à tous les codes
  Elsif [F:AFT]ALLACS=2 & [F:AUS]ALLACS=1
   MESSA = mess(87,130,1) : # L'utilisateur # a maintenant accés à tous les codes
  Else
   MESSA = mess(88,130,1) : # Mise à jour des codes d'accés sur l'utilisateur #
  Endif
  [F:AUS]ALLACS = [F:AFT]ALLACS
  Rewrite [AUS]
  If fstat
   GOK=0 : Call FSTA("AUS") From GLOCK : Goto AB_TR_MAJ
  Endif
  If [F:AFT]ALLACS=2
   For [ACS]ACS0
    Raz [F:ACC]
    [F:ACC]CONSUL = 2
    [F:ACC]EXEC   = 2
    [F:ACC]MODIF  = 2
    [F:ACC]USR    = [F:AUS]USR
    [F:ACC]CODACC = [F:ACS]CODACC
    Write [ACC]
    If fstat
     GOK = 0 : Call FSTA("ACC") From GLOCK : Break
    Endif
   Next ACS
   If GOK<>1 : Goto AB_TR_MAJ : Endif
  Else
   For [ACC2] Where PRFCOD=[L]PROFIL & CODACC<>""
    Raz [F:ACC]
    [F:ACC] = [F:ACC2]
    [F:ACC]USR    = [F:AUS]USR
    [F:ACC]PRFCOD = ""
    Write [ACC]
    If fstat
     GOK = 0 : Call FSTA("ACC") From GLOCK : Break
    Endif
   Next ACC2
   If GOK<>1 : Goto AB_TR_MAJ : Endif
  Endif
  Raz [F:ACC]
  [F:ACC]CONSUL = 2
  [F:ACC]EXEC   = 2
  [F:ACC]MODIF  = 2
  [F:ACC]USR    = [F:AUS]USR
  [F:ACC]CODACC = ""
  [F:ACC]PRFCOD = ""
  Write [ACC]
  If fstat
   GOK = 0 : Call FSTA("ACC") From GLOCK : Goto AB_TR_MAJ
  Endif
 Else
  If CODE<>""
   MESSA = func AFNC.MES2(mess(92,130,1),CODE,"#") : # Mise à jour du code d'accés $1$ sur l'utilisateur $2$
  Else
   MESSA = mess(88,130,1) : # Mise à jour des codes d'accés sur l'utilisateur #
  Endif
  For [ACC2] Where PRFCOD=[L]PROFIL & CODACC<>"" & ([L]CODE="" or CODACC=[L]CODE)
   Read [ACC]CODACC=[F:AUS]USR;[F:ACC2]CODACC
   If fstat
    Raz [F:ACC]
    [F:ACC] = [F:ACC2]
    [F:ACC]USR    = [F:AUS]USR
    [F:ACC]PRFCOD = ""
    Write [ACC]
    If fstat
     GOK = 0 : Call FSTA("ACC") From GLOCK : Break
    Endif
   Else
    [F:ACC] = [F:ACC2]
    [F:ACC]USR    = [F:AUS]USR
    [F:ACC]PRFCOD = ""
    Rewrite [ACC]
    If fstat
     GOK = 0 : Call FSTA("ACC") From GLOCK : Break
    Endif
   Endif
  Next ACC2
  If GOK<>1 : Goto AB_TR_MAJ : Endif
 Endif
Commit
Return

$AB_TR_MAJ
Rollback
Return

$ROLL_TR_MAJ
Rollback
Call ROLL From GLOCK
If GROLL
 Return
Else
 Goto TR_MAJ
Endif

#---------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File AFCTPRF [AFP1]
 Local File AFCTFCY [AFF1]
 Local File AFCTFCT [AFT1]
 Local File ACCES   [ACC1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".AFCTPRF" [AFP1]
 Local File =[M]DOSORG+".AFCTFCY" [AFF1]
 Local File =[M]DOSORG+".AFCTFCT" [AFT1]
 Local File =[M]DOSORG+".ACCES"   [ACC1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File AFCTPRF  [AFP2]
 Local File AFCTFCY  [AFF2]
 Local File AFCTFCT  [AFT2]
 Local File FACILITY [FCY2]
 Local File COMPANY  [CPY2]
 Local File ACCES    [ACC2]
 Local File ACCCOD   [ACS2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".AFCTPRF"  [AFP2]
 Local File =[M]DOSDES+".AFCTFCY"  [AFF2]
 Local File =[M]DOSDES+".AFCTFCT"  [AFT2]
 Local File =[M]DOSDES+".FACILITY" [FCY2]
 Local File =[M]DOSDES+".COMPANY"  [CPY2]
 Local File =[M]DOSDES+".ACCES"    [ACC2]
 Local File =[M]DOSDES+".ACCCOD"   [ACS2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif

# Issue 85849 - 2012-11-16 by VPO
Gosub OUVDOS From ATEXTRA

#SAM 121274
Local Integer OK , TRACE
OK = 1

# 120993 - caused by change made by someone else... -
If GTRACE=""
 Read [AFT2]AFT0= TABLE
 If !fstat
  Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN : # Copie profil fonction
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
  #SAM 121274
  If GTRACE=""
    Call OUVRE_TRACE(mess(28,130,1)-TABLE) From LECFIC
    TRACE=1
  Endif
  Call DEBTRANS From GLOCK
  Gosub TR_COP
  If TRACE
    Call FERME_TRACE From LECFIC
  Endif
Endif

Close Local File  [AFT1], [ACC1] , [FCY2], [AFT2], [ACC2], [ACS2], [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

#---------------#
$TR_COP
GOK = 1
Trbegin [AFT2], [ACC2]

 # Copie profil fonction
 Read [AFT1]AFT0= TABLE
 # Issue 85849 - 2012-11-16 by VPO
 Delete [AXX2] Where CODFIC="AFCTFCT" & ZONE="INTPRF" & IDENT1=TABLE & IDENT2=""
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ATEXTRA" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AXX2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AFT2] Where PRFCOD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AFCTFCT" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AFT2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ACC2] Where PRFCOD=TABLE and USR = ""
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACCES" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AFT2","") From GLOCK : Goto AB_TR_COP
 Endif
 [F:AFT2] = [F:AFT1]
 For I = 0 To min(dim([F:AFT1]FCYDEF),dim([F:AFT2]FCYDEF))-1
  Read [FCY2]FCY0 = [F:AFT1]FCYDEF(I)
  If fstat
   [F:AFT2]FCYDEF(I)= ""
  Endif
 Next I
 If dim([F:AFT2]UPDUSR)>0 : [F:AFT2]UPDUSR = GUSER : Endif
 If dim([F:AFT2]UPDDAT)>0 : [F:AFT2]UPDDAT = date$ : Endif
 # Issue 85849 - 2012-11-16 by VPO
 Call COPTEXTRA("AFCTFCT","INTPRF",TABLE,"") From ATEXTRA
 Write [AFT2]
 If fstat
  GOK=0 : Call FSTA("AFT2") From GLOCK : Goto AB_TR_COP
 Endif

 # Copie habilitation fonctionnelle
 Delete [AFP2] Where [AFP2]PRFCOD=[L]TABLE
 If fstat=1 : GOK = -1 : GLOCK = [F:AFP2]PRFCOD : Goto ROLL_TR_COP : Endif
 For [AFP1] Where PRFCOD=[L]TABLE
  If [F:AFP1]FCYGRU<>""
   If [F:AFP1]FCYGRUCOD=1
    Look [CPY2]CPY0 = [F:AFP1]FCYGRU
    If fstat
     Look [FCY2]FCY0 = [F:AFP1]FCYGRU
    Endif
   Else
    Look [FCY2]FCY0 = [F:AFP1]FCYGRU
   Endif
  Endif
  If [F:AFP1]FCYGRU<>"" & fstat
   Call ECR_TRACE([F:AFP1]FNC-[F:AFP1]FCYGRU-mess(60,104,1),1) From GESECRAN : # Société/site non transféré
  Else
   Raz [F:AFP2]
   [F:AFP2] = [F:AFP1]
   If dim([F:AFP2]UPDUSR)>0 : [F:AFP2]UPDUSR = GUSER : Endif
   If dim([F:AFP2]UPDDAT)>0 : [F:AFP2]UPDDAT = date$ : Endif
   Write [AFP2]
   If fstat
    GOK = 0 : Call FSTA("AFP2") From GLOCK : Break
   Endif
  Endif
 Next AFP1
 If GOK<0   : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 # Copie profil fonction site
 Delete [AFF2] Where [AFF2]PRFCOD=[L]TABLE
 If fstat=1 : GOK = -1 : GLOCK = [F:AFF2]PRFCOD : Goto ROLL_TR_COP : Endif
 For [AFF1]AFF1 Where PRFCOD=[L]TABLE
  If [F:AFF1]FCY<>""
   Look [FCY2]FCY0 = [F:AFF1]FCY
  Endif
  If [F:AFF1]FCY<>"" & fstat
   Call ECR_TRACE([F:AFF1]FNC-[F:AFF1]FCY-mess(59,104,1),1) From GESECRAN : # Site non transféré
  Else
   Raz [F:AFF2]
   [F:AFF2] = [F:AFF1]
   Write [AFF2]
   If fstat
    GOK = 0 : Call FSTA("AFF2") From GLOCK : Break
   Endif
  Endif
 Next
 If GOK<0   : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

# Transfert des codes d'accès si existants
 For [ACC1]CODACC Where PRFCOD=TABLE and USR = ""
  Read [ACS2]ACS0 = [F:ACC1]CODACC
  If !fstat
   [F:ACC2] = [F:ACC1]
   Write [ACC2]
   If fstat
    GOK=0 : Call FSTA("ACC2") From GLOCK : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 Call  UPDATE_RIGHTSETAG([M]DOSDES) From ASYRFNC
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL
 Return
Else
 Goto TR_COP
Endif

#---------------------------------------------------------#
## Ecran AFT1        Accès
#---------------------------------------------------------#

Subprog C_ALLFCT(VALEUR)
Variable Integer VALEUR
[M]ALLFCT = VALEUR
Gosub GRISE_ETA
End

Subprog C_ALLACS(VALEUR)
Variable Integer VALEUR
[M]ALLACS = VALEUR
Gosub GRISE_ACS
End

Subprog IB_NBACC
Local Integer OK
OK = 0
If nolign>0
 For [ACC] Where PRFCOD=[M:AFT0]PRFCOD & CODACC=[M]CODACC(nolign-1)
  OK = 1 : Break
 Next ACC
Endif
If !OK : Raz GBOUT1 : Endif
End

Subprog C_CODACC(VALEUR)
Variable Char VALEUR
If VALEUR="" : End : Endif
Call UNICITE(VALEUR,[M]CODACC(0..[M]NBACC-1)) From OBJDIV
If !mkstat
 Call CONTROLE("ACS","",VALEUR,"",mkstat) From CONTOBJ
Endif
End

Subprog AM_CODACC(VALEUR)
Variable Char     VALEUR
End

Subprog AP_CONSUL(VALEUR)
Variable Integer VALEUR
Local Integer NOL
NOL=nolign-1
If VALEUR=1
 [M]MODIF(NOL) = 1
 Affzo MODIF(NOL)
Endif
End

Subprog AM_CONSUL(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 [M]MODIF(nolign-1) = 1
Endif
End

Subprog AS_MODIF(VALEUR)
Variable Integer VALEUR
If [M]CONSUL(nolign-1)=1
 [M]MODIF(nolign-1) = 1
 mkstat = 2 : End
Endif
End

#---------------------------------------------------------#
## Ecran AFT2
#---------------------------------------------------------#

Subprog C_FCYDEF(VALEUR)
Variable Char    VALEUR()
Local Char XVALEUR(GLONFCY)
Local Char ACTION(20)
XVALEUR = VALEUR
If VALEUR="" : End : Endif
Local Integer OK
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
Case GPRODUIT
 When -1 : # Superviseur
  OK = 2
 When 0 : # X3
  Case [M]MODULE(nolign-1)
   When 1       : OK = 2             : # Superviseur
   When 2       : OK = [F:FCY]FINFLG : # Comptabilité
   When 3       : OK = [F:FCY]FINFLG : # Tiers
   When 4       : OK = [F:FCY]FINFLG : # Immos
   When 5       : OK = [F:FCY]SALFLG : # Ventes
   When 6       : OK = [F:FCY]PURFLG : # Achats
   When 7       : OK = [F:FCY]WRHFLG : # Stocks
   When 8       : OK = [F:FCY]MFGFLG : # Production
   When Default : OK = 2             : # Tronc commun, etc...
  Endcase
 When 3 : # AbelX3
  Case [M]MODULE(nolign-1)
   When 1       : OK = 2             : # Superviseur
   When 4       : OK = [F:FCY]FINFLG : # Financement
   When 5       : OK = [F:FCY]FINFLG : # Immobilisation
   When Default : OK = 0             : # Autre
  Endcase
 When Default
  OK = 2
Endcase
ACTION = "C_ZONE" : Gosub ACTION
If OK<>2
 GMESSAGE = mess(128,123,1) : # Type de site incorrect
 mkstat = 2 : End
Endif
End

######################################################################################

