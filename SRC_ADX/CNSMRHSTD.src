#<AdxTL>@(#)11.0.0.0 $Revision$ Consultation MRH
#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : [M:CMRH]    = [M:MRH1]
  When "FIN_CRIT"   : [M:MRH1]FLG = 0
                      [M:MRH1]    = [M:CMRH]
  When Default
Endcase
Return
############################################################
$AUTORIS
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITW]) = 0 : Local File ITMWRH     [ITW] : Endif
If clalev([F:STO]) = 0 : Local File STOCK      [STO] : Endif
If clalev([F:STA]) = 0 : Local File STOALL     [STA] : Endif
If clalev([F:STJ]) = 0 : Local File STOJOU     [STJ] : Endif
If clalev([F:TFO]) = 0 : Local File TABFOR     [TFO] : Endif
Return
############################################################
$OUVRE
Local  Char    WPAR
Local  Char    WFILITM1(250)
Local  Char    WFILITM2(250)
Local  Char    WFILITM3(250)
Local  Char    WFILITF (250)
Local  Char    WFILS   (250)
Local  Char    WFILITW (250)
Local  Char    WFILFOR (250)
Local  Char    WFILSPE (250)
Local  Integer WFSTAT, WREAD, WSKIP, WLIG
Local  Integer WGCONSULT : WGCONSULT = GCONSULT
#
Local Integer I, J, K, L, M
#
Local Char    WSTOFCY,    WWRH,       WITMREF,    WITMDES1, WUOM
Local Decimal WPHYSTO,    WCTLSTO,    WREJSTO,    WTOTSTO
Local Decimal WPLFPHYSTO, WPLFCTLSTO, WPLFREJSTO
Local Decimal WPHYALL,    WCTLALL,    WREJALL,    WDETSHT,  WGLOALL, WGLOSHT
Local Decimal WAVASTO,    WWAISTO,    WSCCLNDSTO, WSCCALL
#--- Bug 83700
Local Decimal WPHYSTODIS, WCTLSTODIS

Gosub LOAD_SCREEN
NAVIG="CONSMRH"
SUITE  = 1
RETOUR = 1
nolign = 1
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> ""
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:MRH1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
  Endcase
Next I

[M:MRH1]SRTKEY = 1
If dim([M:MRH1]QTYTYP) > 0
   [M:MRH1]QTYTYP = 2
Endif
If clalev([M:CMRH]) <> 0 & [M:CMRH]MEMO = "STD"
  [M:MRH1] = [M:CMRH]
Endif
[M:MRH1]FLG = 0
Return
############################################################
$FERME
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LECTURE
If [M:MRH1]FCY = ""
  NBLU = 0
  Return
Endif
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    nolign = 1
    WPAGE  = 0
    For [LNK]
      If nolign <= MAXLIG
        Gosub LOA_LIGNE
        NBLU    = 2
        nolign += 1
        NOL    += 1
      Else
        Break
      Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [LNK]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Effzo [M:MRH2]
    WLIG = 0
    For [LNK]
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [LNK]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    -= 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [LNK]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
$LECTURE_FIN
Return
############################################################
$TRT_FILTER

If [M:MRH1]FLG = 0
  [M:MRH1]FLG = 1
  Raz [M:MRH2]
  Gosub LOAD_FILTER
  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
  Case [M:MRH1]SRTKEY
    When 1 :
      Link [ITW] With [ITM]ITM0=[F:ITW]ITMREF,[ITF]ITF0=[F:ITW]ITMREF;[F:ITW]STOFCY
&              As    [LNK]
&              Where evalue(WFILITF)                 &
&                    evalue(WFILITW)                 &
&                    evalue(WFILFOR)                 &
&                    evalue(WFILITM1)                &
&                    evalue(WFILITM2)                &
&                    evalue(WFILITM3)                &
&                    evalue(WFILSPE)
&              Order By Key ITW1
    When 2 :
      If clalev ([F:AXX])=0  : Local File ATEXTRA   [AXX]  : Endif # FGR 30/06/2009 : X3SUIVI56189
      Link [ITW] With [ITM]ITM0=[F:ITW]ITMREF,[ITF]ITF0=[F:ITW]ITMREF;[F:ITW]STOFCY,
&                     [AXX]AXX0="ITMMASTER";"DES1AXX";GLANGUE;[F:ITF]ITMREF;""
&              As    [LNK]
&              Where evalue(WFILITF)                 &
&                    evalue(WFILITW)                 &
&                    evalue(WFILFOR)                 &
&                    evalue(WFILITM1)                &
&                    evalue(WFILITM2)                &
&                    evalue(WFILITM3)                &
&                    evalue(WFILSPE)
&              Order By [F:AXX]TEXTE                               # FGR 30/06/2009 : X3SUIVI56189
    When 3 :
      Link [ITW] With [ITM]ITM0=[F:ITW]ITMREF,[ITF]ITF0=[F:ITW]ITMREF;[F:ITW]STOFCY
&              As    [LNK]
&              Where evalue(WFILITF)                 &
&                    evalue(WFILITW)                 &
&                    evalue(WFILFOR)                 &
&                    evalue(WFILITM1)                &
&                    evalue(WFILITM2)                &
&                    evalue(WFILITM3)                &
&                    evalue(WFILSPE)
&              Order By [F:ITM]SEAKEY;[F:ITM]ITMREF
    When 4 :
      Link [ITW] With [ITM]ITM0=[F:ITW]ITMREF,[ITF]ITF0=[F:ITW]ITMREF;[F:ITW]STOFCY
&              As    [LNK]
&              Where evalue(WFILITF)                 &
&                    evalue(WFILITW)                 &
&                    evalue(WFILFOR)                 &
&                    evalue(WFILITM1)                &
&                    evalue(WFILITM2)                &
&                    evalue(WFILITM3)                &
&                    evalue(WFILSPE)
&              Order By [F:ITM]CFGLIN;[F:ITM]ITMREF
  Endcase
Endif
Return

############################################################
$LOA_LIGNE
Raz WSTOFCY,    WWRH,       WITMREF,    WITMDES1, WUOM
Raz WPHYSTO,    WCTLSTO,    WREJSTO,    WTOTSTO
Raz WPLFPHYSTO, WPLFCTLSTO, WPLFREJSTO
Raz WPHYALL,    WCTLALL,    WREJALL,    WDETSHT,  WGLOALL, WGLOSHT
Raz WAVASTO,    WWAISTO,    WSCCLNDSTO, WSCCALL
#--- Bug 83700
Raz WPHYSTODIS, WCTLSTODIS

WWRH     = [F:ITW]WRH
WUOM     = [F:ITM]STU
WSTOFCY  = [F:ITF]STOFCY
WITMREF  = [F:ITM]ITMREF
WITMDES1 = [F:ITM]ITMDES1

# A partir des stocks (stocks A,Q,R et alloué détail)
For [STO]STO3 Where ITMREF=WITMREF & STOFCY=WSTOFCY &
&                   WRH=WWRH
  #--- Bug 83700
  If [M:MRH1]QTYTYP=2
    If [F:STO]OWNER=[F:STO]STOFCY | [F:STO]OWNER=""
      Case left$([F:STO]STA,1)
        When "A" : If [F:STO]LOCCAT=1
                      WPHYSTO    += [F:STO]QTYSTUACT
                      #--- Bug 83700
                      WPHYSTODIS += [F:STO]QTYSTUACT
                   Elsif [F:STO]LOCCAT=2
                      WPLFPHYSTO += [F:STO]QTYSTUACT
                   Endif
                   WPHYALL       += [F:STO]CUMALLQTA
        When "Q" : If [F:STO]LOCCAT=1
                      WCTLSTO    += [F:STO]QTYSTUACT
                      #--- Bug 83700
                      WCTLSTODIS += [F:STO]QTYSTUACT
                   Elsif [F:STO]LOCCAT=2
                      WPLFCTLSTO += [F:STO]QTYSTUACT
                   Endif
                   WCTLALL       += [F:STO]CUMALLQTA
        When "R" : If [F:STO]LOCCAT=1
                      WREJSTO    += [F:STO]QTYSTUACT
                   Elsif [F:STO]LOCCAT=2
                      WPLFREJSTO += [F:STO]QTYSTUACT
                   Endif
                   WREJALL       += [F:STO]CUMALLQTA
      Endcase
    Else
      WSCCLNDSTO += [F:STO]QTYSTUACT
      WSCCALL    += [F:STO]CUMALLQTA
    Endif
  #--- Bug 83700
  Else
    If [F:STO]OWNER=[F:STO]STOFCY | [F:STO]OWNER=""
      Case left$([F:STO]STA,1)
        When "A" : If [F:STO]LOCCAT=1
                      WPHYSTO    += [F:STO]QTYSTU
                      WPHYSTODIS += [F:STO]QTYSTUACT
                   Elsif [F:STO]LOCCAT=2
                      WPLFPHYSTO += [F:STO]QTYSTU
                   Endif
                   WPHYALL       += [F:STO]CUMALLQTY
        When "Q" : If [F:STO]LOCCAT=1
                      WCTLSTO    += [F:STO]QTYSTU
                      WCTLSTODIS += [F:STO]QTYSTUACT
                   Elsif [F:STO]LOCCAT=2
                      WPLFCTLSTO += [F:STO]QTYSTU
                   Endif
                   WCTLALL       += [F:STO]CUMALLQTY
        When "R" : If [F:STO]LOCCAT=1
                      WREJSTO    += [F:STO]QTYSTU
                   Elsif [F:STO]LOCCAT=2
                      WPLFREJSTO += [F:STO]QTYSTU
                   Endif
                   WREJALL       += [F:STO]CUMALLQTY
      Endcase
    Else
      WSCCLNDSTO += [F:STO]QTYSTU
      WSCCALL    += [F:STO]CUMALLQTY
    Endif
  Endif
  #---
Next

# Qte totale
WTOTSTO = WPHYSTO + WCTLSTO + WREJSTO

If [M:MRH1]ZERFLG = 2 & WTOTSTO = 0
  nolign -= 1
  NOL    -= 1
  Goto LOA_LIGNE_FIN
Endif

# A partir des allocation (alloué et manquant global, manquant détail)
For [STA]STA0 Where STOFCY=WSTOFCY & ITMREF=WITMREF &
&                   WRH=WWRH & find(ALLTYP,1,4,5)
  If [F:STA]ALLTYP=1
     WGLOALL += [F:STA]QTYSTUACT
  Elsif [F:STA]ALLTYP=4
     WDETSHT += [F:STA]QTYSTUACT
  Elsif [F:STA]ALLTYP=5
     WGLOSHT += [F:STA]QTYSTUACT
  Endif
Next

# A partir des mouvements de stock (sorties en attente)
For [STJ]STJ0 Where STOFCY=WSTOFCY & UPDCOD=1 & ITMREF=WITMREF &
&                   WRH=WWRH & REGFLG=1
    WWAISTO += [F:STJ]ACTQTY
Next

#--- Bug 83700
# Qte disponible
#If [M:MRH1]DISPOFLG=2
#    WAVASTO = WPHYSTO + WCTLSTO + WWAISTO - WGLOALL - WDETSHT
#Else
#    WAVASTO = WPHYSTO - WGLOALL - WDETSHT
#Endif
If [M:MRH1]DISPOFLG=2
    WAVASTO = WPHYSTODIS + WCTLSTODIS + WWAISTO - WGLOALL - WDETSHT
Else
    WAVASTO = WPHYSTODIS - WGLOALL - WDETSHT
Endif
#---

[M:MRH2]STOFCY (nolign-1) = WSTOFCY
[M:MRH2]WRH    (nolign-1) = WWRH
[M:MRH2]ITMREF (nolign-1) = WITMREF
[M:MRH2]ITMDES1(nolign-1) = WITMDES1

[M:MRH2]PHYSTO (nolign-1) = WPHYSTO
[M:MRH2]CTLSTO (nolign-1) = WCTLSTO
[M:MRH2]REJSTO (nolign-1) = WREJSTO
[M:MRH2]TOTSTO (nolign-1) = WTOTSTO

[M:MRH2]PLFPHYSTO (nolign-1) = WPLFPHYSTO
[M:MRH2]PLFCTLSTO (nolign-1) = WPLFCTLSTO
[M:MRH2]PLFREJSTO (nolign-1) = WPLFREJSTO

[M:MRH2]PHYALL (nolign-1) = WPHYALL
[M:MRH2]CTLALL (nolign-1) = WCTLALL
[M:MRH2]REJALL (nolign-1) = WREJALL
[M:MRH2]DETSHT (nolign-1) = WDETSHT
[M:MRH2]GLOALL (nolign-1) = WGLOALL
[M:MRH2]GLOSHT (nolign-1) = WGLOSHT

[M:MRH2]SCCLNDSTO (nolign-1) = WSCCLNDSTO
[M:MRH2]SCCALL    (nolign-1) = WSCCALL

[M:MRH2]AVASTO (nolign-1) = WAVASTO
[M:MRH2]WAISTO (nolign-1) = WWAISTO
[M:MRH2]UOM    (nolign-1) = WUOM

$LOA_LIGNE_FIN
Return
############################################################
$LOAD_FILTER
# Préparation filtre [ITF]
WFILITF = "[F:ITF]STOFCY=[M:MRH1]FCY&[F:ITF]STOMGTCOD>1"
If [M:MRH1]ITMREFSTR <> "" | [M:MRH1]ITMREFEND <> ""
  WFILITF = WFILITF+"&[F:ITF]ITMREF>=[M:MRH1]ITMREFSTR&[F:ITF]ITMREF<=[M:MRH1]ITMREFEND"
Endif
If [M:MRH1]BUYSTR <> "" | [M:MRH1]BUYEND <> ""
  WFILITF = WFILITF+"&[F:ITF]BUY>=[M:MRH1]BUYSTR&[F:ITF]BUY<=[M:MRH1]BUYEND"
Endif
# filtre dépôt sur [ITW]
#MAE, bg 73081, raz de wfilitw
WFILITW = ""
If dim([M:MRH1]WRHSTR) > 0 & ([M:MRH1]WRHSTR <> "" | [M:MRH1]WRHEND <> "")
  WFILITW = "[F:ITW]WRH>=[M:MRH1]WRHSTR&[F:ITW]WRH<=[M:MRH1]WRHEND"
Endif
# Préparation filtre [ITM]
WFILITM1 = "1=1"
WFILITM2 = "1=1"
WFILITM3 = "1=1"
If [M:MRH1]TCLCODSTR <> "" | [M:MRH1]TCLCODEND <> ""
  WFILITM1 += "&[F:ITM]TCLCOD>=[M:MRH1]TCLCODSTR&[F:ITM]TCLCOD<=[M:MRH1]TCLCODEND"
Endif
If [M:MRH1]CFGLINSTR <> "" | [M:MRH1]CFGLINEND <> ""
  WFILITM1 += "&[F:ITM]CFGLIN>=[M:MRH1]CFGLINSTR&[F:ITM]CFGLIN<=[M:MRH1]CFGLINEND"
Endif
#
If dim([M:MRH1]TSICODSTR) > 0
  For I = 0 To dim([M:MRH1]TSICODSTR)-1
    If [M:MRH1]TSICODSTR(I) <> "" | [M:MRH1]TSICODEND(I) <> ""
      If len(WFILITM1) > 200
        WFILITM2 += "&[F:ITM]TSICOD("+num$(I)+")>='"+[M:MRH1]TSICODSTR(I)+
&                "'&[F:ITM]TSICOD("+num$(I)+")<='"+[M:MRH1]TSICODEND(I)+"'"
      Else
        WFILITM1 += "&[F:ITM]TSICOD("+num$(I)+")>='"+[M:MRH1]TSICODSTR(I)+
&                "'&[F:ITM]TSICOD("+num$(I)+")<='"+[M:MRH1]TSICODEND(I)+"'"
      Endif
    Endif
  Next I
Endif
#
If [M:MRH1]SEAKEYSTR <> "" | [M:MRH1]SEAKEYEND <> ""
  WFILITM3 += "&[F:ITM]SEAKEY>=[M:MRH1]SEAKEYSTR&[F:ITM]SEAKEY<=[M:MRH1]SEAKEYEND"
Endif
If [M:MRH1]EANCODSTR <> "" | [M:MRH1]EANCODEND <> ""
  WFILITM3 += "&[F:ITM]EANCOD>=[M:MRH1]EANCODSTR&[F:ITM]EANCOD<=[M:MRH1]EANCODEND"
Endif
# Filtre formule
If [M:MRH1]SELFOR <> ""
  Read [TFO]TFO0=11;[M:MRH1]SELFOR
  If fstat = 0
    If WFILS = "1=1"
      WFILFOR = [F:TFO]FORFOR
    Else
      WFILFOR = WFILS+"&"+[F:TFO]FORFOR
    Endif
  Endif
Endif
#
If WFILFOR= ""
  WFILFOR = "1=1"
Endif
If WFILITF  = ""
  WFILITF  = "1=1"
Endif
If WFILITW  = ""
  WFILITW  = "1=1"
Endif
If WFILITM1 = ""
  WFILITM1 = "1=1"
Endif
If WFILITM2 = ""
  WFILITM2 = "1=1"
Endif
If WFILITM3 = ""
  WFILITM3 = "1=1"
Endif
Return
############################################################
$SETBOUT
If [M:MRH1]FCY <> "" & [M:MRH2]NBLIG > 0
  CHMEN = "1"
  Gosub SET_BOUT_SPE From GSAISIE
Endif
Return
############################################################
$EXEBOUT
Return
############################################################
Subprog IB_NBLIG
If nolign > 0
  If [M]GLOALL(nolign-1) = 0 & GFONC1<> "GESPNH" : Raz GBOUT4 : Endif
  If [M]DETSHT(nolign-1) = 0 : Raz GBOUT6 : Endif
Endif
End
############################################################
Subprog AM_TITFLG(VALEUR)
Variable Integer VALEUR
[M:MRH1]FLG = 0
End
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:MRH1]FLG = 0
#
If dim([M:MRH1]WRHSTR) > 0
   Raz   [M:MRH1]WRHSTR, [M:MRH1]WRHEND
   Affzo [M:MRH1]WRHSTR
   Affzo [M:MRH1]WRHEND
Endif
End
############################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Read [FCY]FCY0=VALEUR
If fstat | fstat = 0 & [F:FCY]WRHGES <> 2
  mkstat = 2
  GMESSAGE = mess(985,196,1)
Endif
End
############################################################
Subprog AS_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
[M]FLG = 0
End
############################################################
Subprog AS_ITMREFEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]ITMREFSTR
Endif
End
############################################################
Subprog C_ITMREFEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]ITMREFSTR
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End
############################################################
Subprog AM_ITMREFEND(VALEUR)
Variable Char    VALEUR()
[M]FLG = 0
End
############################################################
Subprog AS_WRHSTR(VALEUR)
Variable Char    VALEUR()
# Actzo ou Grizo des dépôts selon le site  #
If [M]FCY <>[F:FCY]FCY
  Read [FCY]FCY0=[M]FCY
Endif
If [F:FCY]WRHGES <> 2
  Raz   [M]WRHSTR, [M]WRHEND
  Affzo [M]WRHSTR
  Affzo [M]WRHEND
 mkstat = 2
Endif
End
############################################################
Subprog AS_WRHEND(VALEUR)
Variable Char    VALEUR()
# Actzo ou Grizo des dépôts selon le site  #
If [M]FCY <>[F:FCY]FCY
  Read [FCY]FCY0=[M]FCY
Endif
If [F:FCY]WRHGES <> 2
  Raz   [M]WRHSTR, [M]WRHEND
  Affzo [M]WRHSTR
  Affzo [M]WRHEND
 mkstat = 2
Endif
End
############################################################
Subprog AM_WRHSTR(VALEUR)
Variable Char    VALEUR()
[M]FLG = 0
End
############################################################
Subprog AV_WRHEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]WRHSTR
Endif
End
############################################################
Subprog C_WRHEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]WRHSTR
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End
############################################################
Subprog AM_WRHEND(VALEUR)
Variable Char    VALEUR()
[M]FLG = 0
End
############################################################
Subprog AS_TCLCODSTR(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog C_TCLCODEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]TCLCODSTR
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End
############################################################
Subprog C_BUYEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]BUYSTR
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End
############################################################
Subprog AS_TSICODEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" | VALEUR < [M]TSICODSTR(indice)
  VALEUR = [M]TSICODSTR(indice)
Endif
End
############################################################
Subprog C_TSICODEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]TSICODSTR(indice)
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End
