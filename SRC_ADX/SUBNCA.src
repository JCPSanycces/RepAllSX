#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion objet NCA
Raz GBIDC1, GBIDC2
Call OBJET("NCA",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "RAZCRE"    : Gosub RAZCRE
 When "RAZDUP"    : Gosub RAZDUP
 When "SEL_TABLE" : Gosub SEL_TABLE
 When default
Endcase
Return

$OUVRE
If clalev([F:SCU])=0 : Local File SUCURSAL [SCU] : Endif
If clalev([F:ATZ2])=0 : Local File ATABZON [ATZ2] : Endif
Local Integer LONSEQ     : # Longueur séquence
Read [ATZ2]CODZONE = "NUMCAI";"RANSTR"
LONSEQ = [F:ATZ2]LONG
Local Char CHAINE(LONSEQ)
Return

$LIENS
CHAINE = "0"
While len([M]RANSTR)<LONSEQ
 [M]RANSTR = CHAINE+[M]RANSTR
Wend
While len([M]RANEND)<LONSEQ
 [M]RANEND = CHAINE+[M]RANEND
Wend
While len([M]LASNUM)<LONSEQ
 [M]LASNUM = CHAINE+[M]LASNUM
Wend
Return

$RAZCRE
Gosub RAZE
Return

$RAZDUP
Gosub RAZE
Return

$RAZE
[M]FLGSHL = 0
[M]LASNUM = ""
Return

$SEL_TABLE
Case TABLE
 When "SELSCU"  : Gosub SELSCU  : # Sélection dépendances
Endcase
Return


$SELSCU
Local Char TYPD(GLONADI), CLASSE(GLONADI)
If clalev([F:SCU])=0 : Local File SUCURSAL [SCU] : Endif

[L]TYPD    = PARAM(1) : # Type document (FC/ND/NC)
[L]CLASSE  = PARAM(2) : # Classe
CRITERE = "TYP = '"+[L]TYPD+"'"
CRITERE += " & CLS = '"+[L]CLASSE+"'"
#CRITERE += " & SCU <> 0"
Default File [SCU]
OBJET   = "SCU"
START   = "[F:SCU]SCU"
Return

####################################################################################
# Etiquettes du masque NCA1
####################################################################################

Subprog C_RANEND(VALEUR)
Variable Char VALEUR()
If VALEUR<=[M]RANSTR
 ## Valeur incorrecte
 GMESSAGE = mess(83,123,1)
 mkstat = 2 : End
Endif
End

Subprog C_VLYEND(VALEUR)
Variable Date    VALEUR
End

Subprog AM_SCU(VALEUR)
Variable Char    VALEUR()
Local Char CHAINE(4)
CHAINE = "0"
While len(VALEUR)<4
 VALEUR = CHAINE+VALEUR
Wend
End

Subprog AS_LASNUM(VALEUR)
Variable Decimal VALEUR
If GREP = "D" : VALEUR = 0 : [M]FLGSHL = 0 : Endif 
End

Subprog AP_RANSTR(VALEUR)
Variable Char    VALEUR()
Local Char CHAINE(8)
CHAINE = "0"
While len(VALEUR)<8
 VALEUR = CHAINE+VALEUR
Wend
End

Subprog AP_RANEND(VALEUR)
Variable Char    VALEUR()
Local Char CHAINE(8)
CHAINE = "0"
While len(VALEUR)<8
 VALEUR = CHAINE+VALEUR
Wend
End





