#<AdxTL>@(#)10.0.0.0 $Revision$
# Gestion du masque VISUROUG - Visualisation graphique gamme multi-niveaux
######################################################################################

$ACTION
  Case ACTION
    When "AB2_NBLIG"  : # Avant tunnel vers articles
    When "BB2_NBLIG"  : Gosub BB2_NBLIG  # Apres tunnel vers articles
    When "BB1_ROUNUM" : Gosub BB1_ROUNUM # Apres tunnel vers gammes
    When "BB3_NBLIG"  : Gosub BB3_NBLIG  # Après tunnel vers gammes

    When "SEL_TABLE"  : Gosub SEL_TABLE  # Sélections
    When "VERF_TABLE" : Gosub VERF_TABLE  # Sélections
  Endcase
Return

######################################################################################
Subprog AM_ROUNUM(VALEUR)
Variable Char    VALEUR()

  Gosub OUVRE_ROH
  # Si on change la valeur de l'article, on réinitiale les zones, sinon on reste "coincé" sur le 1er site saisi
  If dim(SEL_NUM)>0 and SEL_NUM=G_NON and ROUNUMS<>VALEUR and VALEUR<>"" and ROUNUMS<>"" Then
    Effzo [M:VROG]15-60

    [M:VROG]ROUALT  = 0
    [M:VROG]FCY     = ""
    [M:VROG]BOMALT  = 0

    # Issue 104937 - 2015-11-25 by CCC : versioning in routes
    If dim([M:VROG]ROUECCMAJ)>0
        Raz [M:VROG]ROUECCMAJ,ROUECCMIN
    Endif
    If dim([M:VROG]BOMECCMAJ)>0
        Raz [M:VROG]BOMECCMAJ,BOMECCMIN
    Endif

    # Actzo [M:VROG]FCY
    Affzo [M:VROG]
  Endif
  If VALEUR<>""
    # Lecture article
    Read [ITM]ITM0=VALEUR
    If fstat  :   End : Endif
    If [M]FCY<>""
      # Lecture article-site
      Read [ITF]ITF0=VALEUR;[M]FCY
      If fstat : End : Endif
      If dim([M:VROG]MFGLOTQTY)>0 [M:VROG]MFGLOTQTY = [F:ITF]MFGLOTQTY Endif
    Endif
  Endif
  # Issue 104937 - 2015-11-25 by CCC : versioning in routes
  Call AFFECC(VALEUR,[M:VROG]FCY,[M:VROG]ROUALT,[M:VROG]BOMALT) From SUBVROUG
End


######################################################################################
Subprog AS_NBLIG
Local Integer NOL

  Gosub OUVRE_ROH
  NOL = nolign-1
  If NOL>0
    Gosub CHARGE_ROO From VISUROUG
  Else
    Gosub CHARGE_ROH From VISUROUG
  Endif
End

######################################################################################
Subprog S_ROUNUM(VALEUR)
Variable Char VALEUR()

  Gosub OUVRE_ROH
  SEL_NUM = G_OUI
  #Si la selection porte sur la table des gammes, on récupère l'alternative
  If !find(GREP,"C","D") & VALEUR <> ""
    Read [F:ROH] Curr
    If !fstat & [F:ROH]ITMREF = VALEUR
      If [F:ROH]ITMREF=ROUNUMS and ([M:VROG]ROUALT<>[F:ROH]ROUALT | [M:VROG]FCY<>[F:ROH]FCY) Then
        [M:VROG]ROUALT = [F:ROH]ROUALT
        [M:VROG]FCY    = [F:ROH]FCY
        Local Integer ROUFLGS
        ROUFLGS = [M:VROG]ROUFLG
        Gosub TRT_AFFROU From VISUROUG
        If ROUFLGS=1 Then
          Gosub ALL_LEV_ROUG From VISUROUG
        Endif
      Else
        [M:VROG]ROUALT = [F:ROH]ROUALT
        [M:VROG]FCY    = [F:ROH]FCY
        [M:VROG]BOMALT = func SUBVROUG.INIBOMALT(VALEUR,[F:ROH]ROUALT,[M:VROG]BOMALTTYP)
      Endif
      Call INIVER(VALEUR,[M:VROG]ROUALT,[M:VROG]FCY,[M:VROG]BOMALT,[M:VROG]DATREF)

      Affzo [M:VROG]ROUALT, FCY
    Endif
  Endif
End

######################################################################################
# Etiquette appelée après le retour par tunnel sur la gamme
######################################################################################
$OUVRE_ROH

  If !clalev([F:ROH]) Then
    Local File ROUTING [ROH]
    Read [F:ROH]ROH0=[M:VROG]ROUNUM;[M:VROG]ROUALT;[M:VROG]FCY
  Endif
Return

######################################################################################
$BB1_ROUNUM # FQ 60986 avant Subprog BB1_ROUNUM(VALEUR) # ?????
  SEL_NUM = G_OUI
  If dim(ROUNUMS)>0 and ROUNUMS<>[F:ROH]ITMREF and [F:ROH]ITMREF<>''
    [M:VROG]FCY    = [F:ROH]FCY
    [M:VROG]ROUNUM = [F:ROH]ITMREF
    [M:VROG]ROUALT = [F:ROH]ROUALT
    Affzo [M:VROG]FCY, ROUNUM, ROUALT
  Endif

  # Il faut réinitialiser GACTION qui était passée à GOBJETC0A lors du tunnel sur gamme
  GACTION="VISUROHG"
End

######################################################################################
$BB2_NBLIG

  # Si on est allé dans les gammes par bouton successifs, ROH est fermée :
  # il faut donc la rouvrir sur le bon enregistrement
  Gosub OUVRE_ROH
Return

######################################################################################
$BB3_NBLIG

#  Gosub TRT_AFFROU From VISUROUG
  # Il faut réinitialiser GACTION qui était passée à GOBJETC0A lors du tunnel sur gamme
  GACTION="VISUROHG"
Return

######################################################################################
Subprog AS_ROUNUM(VALEUR)
Variable Char  VALEUR()
Global   Char  ROUNUMS
Global Integer SEL_NUM

  # Sauvegarde de la valeur initiale de la gamme
  SEL_NUM = G_NON
  ROUNUMS = [M:VROG]ROUNUM
End

######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran VISUROUG) 20/10/2008 11:02:54 (MABON)
######################################################################################
Subprog AM_ROUALT(VALEUR)
Variable Decimal VALEUR

  #Si la sélection porte sur la table des alternatives de gammes, on récupère le site
  Gosub OUVRE_ROH
  If !find(GREP,"C","D") & VALEUR <> 0
    If [M:VROG]FCY=[F:ROH]FCY and [M:VROG]FCY<>"" Then
      # Dans ce cas, on vient de la sélection sur ROUALT, et donc [M:VROG]FCY a été renseigné par S_ROUALT
      Read [F:ROH]ROH0=[M:VROG]ROUNUM;VALEUR;[M:VROG]FCY
    Else
      # Dans ce cas, on a saisi ROUALT manuellement, donc [M:VROG]FCY n'est pas connu
      Filter [F:ROH]Where ITMREF=[M:VROG]ROUNUM and ROUALT=VALEUR
      Read [F:ROH] First
      Filter [F:ROH]
    Endif
    If !fstat Then
      [M:VROG]FCY = [F:ROH]FCY
      Affzo [M:VROG]FCY
    Endif
    # RECHERCHE DES NOMENCLATURES ASSOCIEES AU COUPLE GAMME+ALT
    [M:VROG]BOMALT = func SUBVROUG.INIBOMALT([M:VROG]ROUNUM,VALEUR,[M:VROG]BOMALTTYP)
    Affzo [M:VROG]BOMALT
    # Issue 104937 - 2015-11-25 by CCC : versioning in routes
    Call INIVER([M:VROG]ROUNUM,VALEUR,[M:VROG]FCY,[M:VROG]BOMALT,[M:VROG]DATREF)
    Call AFFECC([M:VROG]ROUNUM,[M:VROG]FCY,VALEUR,[M:VROG]BOMALT) From SUBVROUG
  Endif
End


######################################################################################
#Si la sélection porte sur la table des alternatives de gammes, on récupère le site
######################################################################################
Subprog S_ROUALT(VALEUR)
Variable Decimal VALEUR
Local    Char    FCYS

  Gosub OUVRE_ROH
  If fstat<>4 and mkstat<>2 Then
    # Vérification sur [F:ROH]FCY : s'il est vide, c'est qu'on a quitté la sélection sans rien sélectionner
    If [F:ROH]FCY<>"" Then
      If !find(GREP,"C","D") & VALEUR <> 0
        Read [F:ROH] Curr
        FCYS = [M:VROG]FCY
        If !fstat Then
          [M:VROG]FCY = [F:ROH]FCY
          Affzo [M:VROG]FCY
        Endif
        # Même si ROUALT n'a pas changé, FCY a pu changer quant à lui : il faut donc recharger les nouveaux éléments
        If VALEUR=[M:VROG]ROUALT Then
          If FCYS<>[F:ROH]FCY Then
            [M:VROG]ROUALT = VALEUR
            Local Integer ROUFLGS
            ROUFLGS = [M:VROG]ROUFLG
            Gosub TRT_AFFROU From VISUROUG
            If ROUFLGS=1 Then
              Gosub ALL_LEV_ROUG From VISUROUG
            Endif
          Endif
        Endif
      Endif
      # Issue 104937 - 2015-11-25 by CCC : versioning in routes
      Call AFFECC([M:VROG]ROUNUM,[M:VROG]FCY,[M:VROG]ROUALT,[M:VROG]BOMALT) From SUBVROUG
    Endif
  Endif
End


######################################################################################
Subprog IB_NBLIG
Local Integer TUNNEL_ROU

  TUNNEL_ROU = G_NON
  If GPILNAV > 1 Then
    If find(GNAVIG(GPILNAV-1),"GESROU") or find(GNAVIG(GPILNAV),"GESROU") Then
      TUNNEL_ROU = G_OUI
    Endif
  Endif

  TUNNEL_ITM = G_NON
  If GPILNAV > 1 Then
    If find(GNAVIG(GPILNAV-1),"GESITM") or find(GNAVIG(GPILNAV),"GESITM") Then
      TUNNEL_ITM = G_OUI
    Endif
  Endif

  If nolign > 1 Then
    If ([M:VROG]EQUNUM(nolign-1)="" and [M:VROG]ITMSST(nolign-1)="")
&      or (find("GESITM",GNAVIG(1..GPILNAV))) Then
      GBOUT2 = ""
    Endif
    GBOUT3 = ""
    GBOUT4 = ""
  Endif

  If TUNNEL_ITM=G_OUI Then
    GBOUT2 = ""
  Endif

  If TUNNEL_ROU=G_OUI Then
    GBOUT3 = ""
  Endif
End


######################################################################################
# On ne peut pas faire un tunnel sur les articles lorsqu'on vient des articles
Subprog IB_ROUNUM
Local Integer TUNNEL

  TUNNEL = G_NON
  If GPILNAV > 1 Then
    If find(GNAVIG(GPILNAV-1),"GESITM") or find(GNAVIG(GPILNAV),"GESITM") Then
      TUNNEL = G_OUI
    Endif
  Endif

  If TUNNEL=G_OUI Then
    GBOUT1 = ""
  Endif
End


######################################################################################

Funprog CTRROU(PROUALT, PROUNUM, PFCY)
Value Integer PROUALT
Value Char PROUNUM
Value Char PFCY

Local Integer LRET

If PROUNUM <> ""
    Look [ROH1]ROH0(1)=PROUNUM
    Filter [ROH1]
    If fstat
        End 3
    Endif
Endif

If PROUALT <> 0 & PROUNUM <> ""
    Look [ROH1]ROH0(2)=PROUNUM;PROUALT
    Filter [ROH1]
    If fstat
        End 2
    Endif
Endif

If PROUALT <> 0 & PROUNUM <> "" & PFCY<>""
    Look [ROH1]ROH1= PFCY;PROUNUM;PROUALT
    If fstat
        End 1
    Endif
Endif

End 0
######################################################################################
## Etiquette ajoutée par le superviseur (écran VISUROUG) 15/11/2012 11:34:48 (CCC)
######################################################################################
Subprog C_ROUNUM(VALEUR)
Variable Char    VALEUR()
Case func CTRROU([M:VROG]ROUALT,VALEUR,[M:VROG]FCY)
    When 0 : # OK
    When 1 :
        Effzo [M:VROG]15-60
        Effzo [M:VROG]FCY
    When 2 :
        Effzo [M:VROG]15-60
        Effzo [M:VROG]ROUALT,ZROUALT
        Effzo [M:VROG]FCY
    When 3 : # No routing exists for this routing number
        GMESSAGE = [M:VROG]ROUNUM-mess(153,196,1)
        mkstat = 2
        GERR=1
Endcase
End

Subprog C_ROUALT(VALEUR)
Variable Decimal VALEUR
Case func CTRROU(VALEUR,[M:VROG]ROUNUM,[M:VROG]FCY)
    When 0 : # OK
    When 1 : # No routing exists for this site
        Effzo [M:VROG]15-60
        Effzo [M:VROG]FCY
    When 2,3 : # No routing exists for this routing number+code
        GMESSAGE = [M:VROG]ROUNUM-num$(VALEUR)-mess(153,196,1)
        mkstat = 2
        GERR=1
Endcase
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

If func CTRROU([M:VROG]ROUALT,[M:VROG]ROUNUM,VALEUR)
    # No routing exists for this routing number+code+site
    GMESSAGE = [M:VROG]ROUNUM-num$([M:VROG]ROUALT)-VALEUR-mess(153,196,1)
    mkstat = 2
    GERR=1
Endif
End


######################################################################################
$SEL_TABLE
Case COUZON
    When "BOMALT"                : Gosub SEL_BOMALT
    When "ROUECCMAJ","ROUECCMIN" : Gosub SELROUECC
Endcase
Return

$VERF_TABLE
Case COUZON
    When "ROUECCMAJ"             : Gosub SELROUECCMIN
Endcase
Return

$SEL_BOMALT
OBJET="BOD"     # choix de la sélection
START="BOMALT"  # Zone à récupérer
CRITERE="ITMREF='"+[M:VROG]ROUNUM+"' & BOMALTTYP="+num$([M:VROG]BOMALTTYP)
Return

######################################################
$SELROUECC
OBJET="RVV1"
CRITERE="ITMREF='"+[M:VROG]ROUNUM+"' & FCY='"+[M:VROG]FCY+"'"
Case COUZON
  When "ROUECCMAJ"
       EXPSTART="ECCVALMAJ='"+VALEUR+"' & ECCVALMIN='"+[M:VROG]ROUECCMIN+"'"
  When "ROUECCMIN"
       CRITERE-="& ECCVALMAJ='"+[M:VROG]ROUECCMAJ+"'"
       EXPSTART="ECCVALMAJ='"+[M:VROG]ROUECCMAJ+"' & ECCVALMIN='"+VALEUR+"'"
       START="ECCVALMIN"
Endcase
Return

$SELROUECCMIN
VALEUR = [F:RVV]ECCVALMAJ
START  = ""

If ([F:RVV]ECCVALMAJ<>[M:VROG]ROUECCMAJ | [F:RVV]ECCVALMIN<>[M:VROG]ROUECCMIN)
&  & ([M:VROG]DATREF<[F:RVV]STRDAT | ([M:VROG]DATREF>[F:RVV]ENDDAT & [F:RVV]ENDDAT<>[0/0/0]))
   [M:VROG]DATREF=[F:RVV]STRDAT : Affzo [VROG]DATREF
Endif

If [F:RVV]ECCVALMIN<>[M:VROG]ROUECCMIN
   [M:VROG]ROUECCMIN = [F:RVV]ECCVALMIN
   Affzo [VROG]ROUECCMIN
   mkstat=4
Endif
Return


######################################################################################
## Etiquette ajoutée par le superviseur (écran VISUROUG) 15/11/2012 13:34:38 (CCC)
######################################################################################
Subprog C_BOMALT(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0
    Look [F:BOH1]BOH0=[M:VROG]ROUNUM;VALEUR;[M:VROG]BOMALTTYP
    If fstat
        GMESSAGE=mess(95,193,1)
        mkstat=2
    Endif
Endif
# Issue 104937 - 2015-11-25 by CCC : versioning in routes
Call AFFECC([M:VROG]ROUNUM,[M:VROG]FCY,[M:VROG]ROUALT,VALEUR) From SUBVROUG
End


######################################################################################
# Renvoie le n° d'alternative de nomenclature associé à la gamme
######################################################################################
Funprog INIBOMALT(PROUNUM, PROUALT,PBOMALTTYP)
Value Char    PROUNUM
Value Integer PROUALT
Value Integer PBOMALTTYP

Local Integer LRET
Read [TRO1]TRO0= PROUALT
If !fstat
    ## GH 20/12/12 bug 86846
    #GBIDI1=0
    #While GBIDI1<4
    #    GBIDI1+=1
    #    LRET = evalue("[F:TRO1]BOMALT"+num$(GBIDI1))
    #    Look [BOH1]BOH0=PROUNUM;LRET;PBOMALTTYP
    #    If !fstat
    #        Break
    #    Endif
    #Wend
    For GBIDI1=1 To 3
        LRET = evalue("[F:TRO1]BOMALT"+num$(GBIDI1))
        Look [BOH1]BOH0=PROUNUM;LRET;PBOMALTTYP
        If !fstat : Break : Endif
    Next GBIDI1
Endif
# Si aucune alt nomencl. trouvée, on essaie l'alternative de la gamme, sinon 0
If fstat
    LRET = PROUALT
    Look [BOH1]BOH0=PROUNUM;LRET;PBOMALTTYP
    If fstat
        Raz LRET
    Endif
Endif
End LRET

######################################################################################
## Etiquette ajoutée par le superviseur (écran VISUROUG) 19/02/2014 14:18:14 (GH)
######################################################################################
Subprog C_DATREF(VALEUR)
Variable Date    VALEUR

# Issue 104937 - 2015-11-25 by CCC : versioning in routes
If dim([M:VROG]BOMECCMAJ)>0
    If VALEUR=[0/0/0] & [M:VROG]BOMECCMAJ<>""
        GMESSAGE=mess(10,123,1)
        mkstat=2
        End
    Endif
    If dim([M:VROG]ROUECCMAJ)>0 & [M:VROG]ROUECCMAJ<>""
        Filter [RVV] Where ITMREF=[M:VROG]ROUNUM
&                        & FCY   =[M:VROG]FCY
&                        & ROUALT=[M:VROG]ROUALT
&                        & STRDAT<=VALEUR
&                        & (ENDDAT>=VALEUR | ENDDAT=[0/0/0])
        Look [RVV] First
        Filter [RVV]
        If fstat
            GMESSAGE=mess(63,198,1)+"\"+mess(432,184,1)-num$(VALEUR) # Routing \ Unavailable version at this date:
            mkstat=2
            End
        Endif
    Endif
    If [M:VROG]BOMECCMAJ<>""
        Filter [EVL] Where ITMREF=[M:VROG]ROUNUM
&                        & BOMALT=[M:VROG]BOMALT
&                        & ECCTYP=2
&                        & STRDAT<=VALEUR
&                        & (ENDDAT>=VALEUR | ENDDAT=[0/0/0])
        Look [EVL] First
        Filter [EVL]
        If fstat
            GMESSAGE=mess(136,195,1)+"\"+mess(432,184,1)-num$(VALEUR) # Production BOM \ Unavailable version at this date:
            mkstat=2
            End
        Endif
    Endif
Endif

mkstat=4 : # pour declencher l'affichage de l'arborescence apres passage sur la zone
End

######################################################################################
Subprog AM_DATREF(VALEUR)
Variable Date    VALEUR

Call INIVER([M:VROG]ROUNUM,[M:VROG]ROUALT,[M:VROG]FCY,[M:VROG]BOMALT,VALEUR)

End

#**----------------------------------------------------------------<br/>
#* INIVER : Initialize version number of routing and/or BOM in [M:VROG]
#*          Routing & BOM codes can be initialized too.
#**<br/>----------------------------------------------------------------<br/>
#* @param PROUNUM = routing number
#* @param PROUALT = routing code (if =0 then it will be modified if a routing version is found)
#* @param PFCY    = site
#* @param PBOMALT = BOM code (if =0 then it will be modified if a BOM version is found)
#* @param PDAT    = search date
#**<br/>----------------------------------------------------------------
#*!
Subprog INIVER(PROUNUM, PROUALT, PFCY, PBOMALT, PDAT)
Value Char    PROUNUM
Variable Decimal PROUALT
Value Char    PFCY
Variable Decimal PBOMALT
Value Date    PDAT

    # Issue 104937 - 2015-11-30 by CCC : if route managed by version => find the good version
    If dim([M:VROG]ROUECCMAJ)>0 & func RVMLIB.NBRCPNROU(PROUNUM)>0
        Filter [RVV] Where ITMREF=PROUNUM
&                        & FCY   =PFCY
&                        & (ROUALT=PROUALT | PROUALT=0)
&                        & STRDAT<=PDAT
&                        & (ENDDAT>=PDAT | ENDDAT=[0/0/0])
&                    Order By USESTA Desc
        Read [RVV] First
        Filter [RVV]
        If !fstat
            PROUALT           = [F:RVV]ROUALT
            [M:VROG]ROUECCMAJ = [F:RVV]ECCVALMAJ
            [M:VROG]ROUECCMIN = [F:RVV]ECCVALMIN
            [M:VROG]ROUECCSTR = [F:RVV]STRDAT
            [M:VROG]ROUECCEND = [F:RVV]ENDDAT
            Affzo [M:VROG]ROUALT,ROUECCMAJ,ROUECCMIN,ROUECCSTR,ROUECCEND
        Endif
    Endif
    # Issue 104937 - 2015-11-30 by CCC : if BOM managed by version => find the good version
    If dim([M:VROG]BOMECCMAJ)>0 & func ECCLIB.NBRCPN(PROUNUM)>0
        Filter [EVL] Where ITMREF=PROUNUM
&                        & (BOMALT=PBOMALT | PBOMALT=0)
&                        & ECCTYP=2
&                        & STRDAT<=PDAT
&                        & (ENDDAT>=PDAT | ENDDAT=[0/0/0])
&                    Order By USESTA Desc
        Read [EVL] First
        Filter [EVL]
        If !fstat
            PBOMALT           = [F:EVL]BOMALT
            [M:VROG]BOMECCMAJ = [F:EVL]ECCVALMAJ
            [M:VROG]BOMECCMIN = [F:EVL]ECCVALMIN
            [M:VROG]BOMECCSTR = [F:EVL]STRDAT
            [M:VROG]BOMECCEND = [F:EVL]ENDDAT
            Affzo [M:VROG]BOMALT,BOMECCMAJ,BOMECCMIN,BOMECCSTR,BOMECCEND
        Endif
    Endif
End

######################################################################################
#**----------------------------------------------------------------<br/>
#* GETECCDAT : Return the start and end validity dates of a route
#**<br/>----------------------------------------------------------------<br/>
#* @param PITM = Route number
#* @param PFCY = Site
#* @param PECCMAJ = Major version
#* @param PECCMIN = Minor version
#* @param PSTRDAT = Start date of validity period (returned)
#* @param PENDDAT = End date of validity period (returned)
#**<br/>----------------------------------------------------------------
#*!
Subprog GETECCDAT(PITM, PFCY, PECCMAJ, PECCMIN, PSTRDAT, PENDDAT)
Value Char PITM
Value Char PFCY
Value Char PECCMAJ
Value Char PECCMIN
Variable Date PSTRDAT
Variable Date PENDDAT

Raz PSTRDAT, PENDDAT

If clalev([F:RVV])=0 : Local File RVMVAL [RVV] : Endif

Read [RVV]RVV1=PITM;PFCY;PECCMAJ;PECCMIN
If !fstat
    PSTRDAT = [F:RVV]STRDAT
    PENDDAT = [F:RVV]ENDDAT
Endif

End

#**----------------------------------------------------------------<br/>
#* GETECCVAL : Return the version number of a route corresponding to a date
#**<br/>----------------------------------------------------------------<br/>
#* @param PITM = Route number
#* @param PFCY = Site
#* @param PDAT = Date
#* @param PALT = Route code (optional, if not entered it will be returned)
#* @param PECCMAJ = Major version (returned)
#* @param PECCMIN = Minor version (returned)
#**<br/>----------------------------------------------------------------
#*!
Subprog GETECCVAL(PITM, PFCY, PDAT, PALT, PECCMAJ, PECCMIN, PECCSTR, PECCEND)
Value Char PITM
Value Char PFCY
Value Date PDAT
Variable Integer PALT
Variable Char PECCMAJ
Variable Char PECCMIN
Variable Date PECCSTR
Variable Date PECCEND

Raz PECCMAJ, PECCMIN, PECCSTR, PECCEND

If func RVMLIB.NBRCPNROU(PITM)=0 : End : Endif

If clalev([F:RVV])=0 : Local File RVMVAL [RVV] : Endif

Filter [RVV] Where ITMREF = PITM
&                & FCY    = PFCY
&                & STRDAT<= PDAT
&                & ENDDAT>= PDAT
&                & (PALT=0 | ROUALT=PALT)
&            Order By USESTA Desc
Read [RVV] First
Filter [RVV]
If !fstat
    PECCMAJ = [F:RVV]ECCVALMAJ
    PECCMIN = [F:RVV]ECCVALMIN
    PALT    = [F:RVV]ROUALT
    PECCSTR = [F:EVL]STRDAT
    PECCEND = [F:EVL]ENDDAT
Endif

End

#**----------------------------------------------------------------<br/>
#* NBRCPNROU2 : return the number of component for the version number
#**<br/>----------------------------------------------------------------<br/>
#* @param ITM = Product
#* @param FCY = Site
#* @param ALT = routing code (optional)
#* @param DAT = reference date (optional)
#* @return Number of components to enter for a version of the route</br>
#*         0 => route with no versioning<br/>
#*         1 => route with only major version</br>
#*         2 => route with major and minor version
#**<br/>----------------------------------------------------------------
#*!
Funprog NBRCPNROU2(ITM,FCY,ALT,DAT)
Value Char    ITM()
Value Char    FCY()
Value Integer ALT
Value Date    DAT

Local Integer LRVVFLG

If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
If [F:ITM]ITMREF<>[L]ITM
   Read [ITM]ITM0 = [L]ITM
   If fstat : Raz [F:ITM] : End 0 : Endif
Endif
If [F:ITM]ECCROUFLG=2
    LRVVFLG = 0
    If ALT<>0 | DAT<>[0/0/0]
        Filter [RVV] Where ITMREF=[L]ITM
&                        & FCY   =[L]FCY
&                        & ([L]ALT=0 | ROUALT=[L]ALT)
&                        & ( [L]DAT=[0/0/0]
&                          | ( STRDAT<=[L]DAT
&                            & (ENDDAT=[0/0/0] | ENDDAT>=[L]DAT)
&                            )
&                          )

        Look [RVV] First
        Filter [RVV]
        If !fstat : LRVVFLG=1 : Endif
    Endif
    If ALT=0 & DAT=[0/0/0] | LRVVFLG
        If [F:ITM]ECCMIN<>"" : End 2
        Elsif [F:ITM]ECCMAJ<>"" : End 1
        Endif
    Endif
Endif
End 0

#**----------------------------------------------------------------<br/>
#* AFFECC : Actzo/Grizo of version numbers (BOM & Routes)
#**<br/>----------------------------------------------------------------<br/>
#* @param PITM = Product code
#* @param PFCY = Site
#* @param PROUALT = Routing code
#* @param PBOMALT = BOM code
#**<br/>----------------------------------------------------------------
#*!
Subprog AFFECC(PITM,PFCY,PROUALT,PBOMALT)
Value Char    PITM
Value Char    PFCY
Value Integer PROUALT
Value Integer PBOMALT

If dim([M:VROG]ROUECCMAJ)>0
    Case func SUBVROUG.NBRCPNROU2(PITM,PFCY,PROUALT,[0/0/0])
        When 0 : Effzo [M:VROG]ROUECCMAJ, ROUECCMIN, ROUECCSTR, ROUECCEND
                 Grizo [M:VROG]ROUECCMAJ
                 Grizo [M:VROG]ROUECCMIN
        When 1 : Effzo [M:VROG]ROUECCMIN
                 Actzo [M:VROG]ROUECCMAJ
                 Grizo [M:VROG]ROUECCMIN
        When 2 : Actzo [M:VROG]ROUECCMAJ
                 Actzo [M:VROG]ROUECCMIN
    Endcase
Endif

If dim([M:VROG]BOMECCMAJ)>0
    If PBOMALT=0
        Effzo [M:VROG]BOMECCMAJ, BOMECCMIN, BOMECCSTR, BOMECCEND
        Grizo [M:VROG]BOMECCMAJ, BOMECCMIN
    Else
        Case func ECCLIB.NBRCPN(PITM)
            When 0 : Effzo [M:VROG]BOMECCMAJ, BOMECCMIN, BOMECCSTR, BOMECCEND
        Grizo [M:VROG]BOMECCMAJ
        Grizo [M:VROG]BOMECCMIN
            When 1 : Effzo [M:VROG]BOMECCMIN
                     Actzo [M:VROG]BOMECCMAJ
                     Grizo [M:VROG]BOMECCMIN
            When 2 : Actzo [M:VROG]BOMECCMAJ
                     Actzo [M:VROG]BOMECCMIN
        Endcase
    Endif
Endif
End


######################################################################################

######################################################################################
## Section automatically added (screen VISUROUG) 11/26/2015 17:01:29 (CCC)
######################################################################################
Subprog C_ROUECCMAJ(VALEUR)
Variable Char    VALEUR()

Read [RVV]RVV1(3) = [M:VROG]ROUNUM;[M:VROG]FCY;VALEUR
Filter [RVV]
If fstat
    GMESSAGE = mess(308,193,1) : mkstat=2 : # Non existing version

# if we are entering major version, we can know if minor version is enterable by checking product parameter
Elsif func ECCLIB.NBRCPN([M:VROG]ROUNUM)=1
    [M:VROG]ROUECCSTR = [F:RVV]STRDAT
    [M:VROG]ROUECCEND = [F:RVV]ENDDAT
    If ([M:VROG]DATREF<[F:RVV]STRDAT | ([M:VROG]DATREF>[F:RVV]ENDDAT & [F:RVV]ENDDAT<>[0/0/0]))
        [M:VROG]DATREF=[F:RVV]STRDAT
        Affzo [VROG]DATREF
    Endif
    Affzo [VROG]ROUECCSTR,ROUECCEND
Endif

End

######################################################################################
Subprog C_ROUECCMIN(VALEUR)
Variable Char    VALEUR()

Read [RVV]RVV1 = [M:VROG]ROUNUM;[M:VROG]FCY;[M:VROG]ROUECCMAJ;VALEUR
If fstat
    GMESSAGE = mess(308,193,1) : mkstat=2 : # Non existing version
Else
    [M:VROG]ROUECCSTR = [F:RVV]STRDAT
    [M:VROG]ROUECCEND = [F:RVV]ENDDAT
    If ([M:VROG]DATREF<[F:RVV]STRDAT | ([M:VROG]DATREF>[F:RVV]ENDDAT & [F:RVV]ENDDAT<>[0/0/0]))
        [M:VROG]DATREF=[F:RVV]STRDAT
        Affzo [VROG]DATREF
    Endif
    Affzo [VROG]ROUECCSTR,ROUECCEND
Endif
End

######################################################################################
Subprog C_BOMECCMAJ(VALEUR)
Variable Char    VALEUR()

Filter [EVL] Where ECCTYP=2
Read [EVL]EVL1 = [M:VROG]ROUNUM;VALEUR
Filter [EVL]
If fstat
    GMESSAGE = mess(308,193,1) : mkstat=2 : # Non existing version
Elsif func ECCLIB.NBRCPN([M:VROG]ROUNUM)=1
    Gosub CTLBOMDAT
Endif

End

######################################################################################
Subprog C_BOMECCMIN(VALEUR)
Variable Char    VALEUR()

Read [EVL]EVL1 = [M:VROG]ROUNUM;[M:VROG]BOMECCMAJ;VALEUR;2
Filter [EVL]
If fstat
    GMESSAGE = mess(308,193,1) : mkstat=2 : # Non existing version
Else
    Gosub CTLBOMDAT
Endif
End

$CTLBOMDAT
# if validity periods of route and BOM overlap => it's OK
If  ([M:VROG]ROUECCSTR<=[F:EVL]ENDDAT | [F:EVL]ENDDAT=[0/0/0])
& & ([M:VROG]ROUECCEND>=[F:EVL]STRDAT | [M:VROG]ROUECCEND=[0/0/0])

    [M:VROG]BOMECCSTR = [F:EVL]STRDAT
    [M:VROG]BOMECCEND = [F:EVL]ENDDAT

    # determine which reference date fit to route version and bom version
    [M:VROG]DATREF=func SUBVROUG.CLCDATREF([M:VROG]ROUECCSTR, [M:VROG]ROUECCEND, [M:VROG]BOMECCSTR, [M:VROG]BOMECCEND, [M:VROG]DATREF)

    Affzo [VROG]BOMECCSTR,BOMECCEND,DATREF
Else
    GMESSAGE = mess(432,184,1)-num$([M:VROG]DATREF)
    mkstat=2
Endif
Return

#**----------------------------------------------------------------<br/>
#* CLCDATREF : Calculate a date suitable to 2 prediods
#**<br/>----------------------------------------------------------------<br/>
#* @param PSTRDAT1 = Start date of 1st period
#* @param PENDDAT1 = End date of 1st period
#* @param PSTRDAT2 = Start date of 2nd period
#* @param PENDDAT2 = End date of 2nd period
#* @param PDAT = reference date
#* @return PDAT if this date is suitable to the 2 periods. Otherwise, it will correspond to If PDAT is OK
#**<br/>----------------------------------------------------------------
#*!
Funprog CLCDATREF(PSTRDAT1, PENDDAT1, PSTRDAT2, PENDDAT2, PDAT)
Value Date PSTRDAT1
Value Date PENDDAT1
Value Date PSTRDAT2
Value Date PENDDAT2
Value Date PDAT

If PENDDAT1=[0/0/0] : PENDDAT1=[31/12/2999] : Endif
If PENDDAT2=[0/0/0] : PENDDAT2=[31/12/2999] : Endif

#1- If PDAT suits to both periods
If PDAT>=max(PSTRDAT1, PSTRDAT2) & PDAT<=max(PENDDAT1, PENDDAT2)
    End PDAT
Endif

#2- If period 2 is outside of period 1
If PSTRDAT2>PENDDAT1 | PENDDAT2<PSTRDAT1
    # If PDAT in period 1 => return PDAT
    If PSTRDAT1<=PDAT & PDAT<=PENDDAT1
        End PDAT
    Else
        # If PDAT not in period 1 => return PSTRDAT1
        End PSTRDAT1
    Endif
Else
#3- Period 2 overlaps period 1 but PDAT is not in these 2 periods
    End max(PSTRDAT1,PSTRDAT2)
Endif

End [0/0/0]

