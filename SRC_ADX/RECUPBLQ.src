#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","RECUPBLQ","UTIRECBLQ",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE
Endcase
Return

$OUVRE
If dim(DOSSIER)<1
 Local Char DOSSIER(GLONADP)
 DOSSIER = nomap
Endif
If clalev([F:HAE])=0 : Local File =DOSSIER+".GACCENTRY"     [HAE] : Endif
If clalev([F:DAE])=0 : Local File =DOSSIER+".GACCENTRYD"    [DAE] : Endif
If clalev([F:DAA])=0 : Local File =DOSSIER+".GACCENTRYA"    [DAA] : Endif
If clalev([F:CMM])=0 : Local File =DOSSIER+".GCOMMIT"       [CMM] : Endif
If clalev([F:CMD])=0 : Local File =DOSSIER+".GCOMMITD"      [CMD] : Endif
If clalev([F:FIY])=0 : Local File =DOSSIER+".FISCALYEAR"    [FIY] : Endif
If clalev([F:PER])=0 : Local File =DOSSIER+".PERIOD"        [PER] : Endif
If clalev([F:FCY])=0 : Local File =DOSSIER+".FACILITY"      [FCY] : Endif
If clalev([F:CPY])=0 : Local File =DOSSIER+".COMPANY"       [CPY] : Endif
If clalev([F:GAC])=0 : Local File =DOSSIER+".GACCOUNT"      [GAC] : Endif
If clalev([F:BLQ])=0 : Local File =DOSSIER+".BLAQTY"        [BLQ] : Endif
If clalev([F:TCU])=0 : Local File =DOSSIER+".TABCUR"        [TCU] : Endif
If clalev([F:TUN])=0 : Local File =DOSSIER+".TABUNIT"       [TUN] : Endif
If clalev([F:CCE])=0 : Local File =DOSSIER+".CACCE"         [CCE] : Endif
If clalev([F:FGR])=0 : Local File =DOSSIER+".FACGROUP"      [FGR] : Endif
If clalev([F:GCM])=0 : Local File =DOSSIER+".GACM"          [GCM] : Endif
If clalev([F:LED])=0 : Local File =DOSSIER+".GLED"          [LED] : Endif

If clalev([F:HAT])=0 : Local File =DOSSIER+".GACCTMP"        [HAT] : Endif
If clalev([F:DAT])=0 : Local File =DOSSIER+".GACCTMPD"       [DAT] : Endif

Return

$INIT
Gosub OUVRE
TMP = 1
Return

$INIT_DIA
[M:DIA]SOCIETE = GDEFSOC
Call SETMAINREF([M:DIA]SOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Call DEFEXE([M:DIA]SOCIETE,GTYPANA,[M:DIA]EXERCICE) From CPTSUB
Call DATEXE([M:DIA]SOCIETE,GTYPANA,[M:DIA]EXERCICE,[M:DIA]DATDEB,[M:DIA]DATFIN) From CPTSUB
Return

$EXEC
Call RECUPBLQ([M:DIA]SOCIETE,[M:DIA]TOUSITE,[M:DIA]SITE,[M:DIA]LEDTYP,
&             [M:DIA]EXERCICE,[M:DIA]DEVISE,
&             [M:DIA]BALANA,[M:DIA]COMPTE,GSERVEUR,0)
TRA = 1
Return

##########################################################################################################
$INISOC
Local Integer LNBSOC : LNBSOC=nbrecord([F:CPY])
GDIMSOC=LNBSOC+20
Global Char    GSOC(GLONCPY)(1..GDIMSOC)
Global Char    GDEVSOC(GLONCUR)(1..GDIMSOC)
Global Char    GLEGSOC(GLONADI)(1..GDIMSOC)
Global Char    GGCMSOC(GLONGCM)(1..GDIMSOC)
Return

##########################################################################################################
Subprog RECUPBLQ2(DOSSIER,SOCIETE,TOUSITE,SITE,LEDTYP,EXERCICE,DEVISE,BALANA,COMPTE,BATCH,DIRECT)
Value Char    DOSSIER
Value Char    SOCIETE
Value Integer TOUSITE
Value Char    SITE
Value Integer LEDTYP
Value Integer EXERCICE
Value Char    DEVISE
Value Integer BALANA
Value Char    COMPTE
Value Integer BATCH
Value Integer DIRECT

If clalev([F:CPY])=0 : Local File =DOSSIER+".COMPANY"       [CPY] : Endif
If clalev([F:FCY])=0 : Local File =DOSSIER+".FACILITY"      [FCY] : Endif
If clalev([F:GCM])=0 : Local File =DOSSIER+".GACM"          [GCM] : Endif

Local Integer ISOC
ISOC   = find(SOCIETE,GSOC(1..GNBSOC))
If !ISOC
 Gosub INISOC
Endif

Call LEC_CPY(SOCIETE) From CPTLEC
Local Integer IGCM
IGCM   = find([F:CPY]ACM,GGCM(1..GGCMNBR))
If !IGCM
 If GNBSOC<>nbrecord([F:CPY]) : Gosub INISOC : Endif
 Call GLOBVAR From SETGLBGCM
Endif

Goto RECUP

##########################################################################################################
Subprog RECUPBLQ(SOCIETE,TOUSITE,SITE,LEDTYP,EXERCICE,DEVISE,BALANA,COMPTE,BATCH,DIRECT)
Value Char    SOCIETE
Value Integer TOUSITE
Value Char    SITE
Value Integer LEDTYP
Value Integer EXERCICE
Value Char    DEVISE
Value Integer BALANA
Value Char    COMPTE
Value Integer BATCH
Value Integer DIRECT    : # Paramètres de récup non saisis

Local Char DOSSIER(GLONADP)
DOSSIER=nomap

$RECUP
Gosub OUVRE

# Indice de travail
Local Integer MAXPER, MAXDEV
MAXPER=func AFNC.ACTIV("PER")
MAXDEV = nbrecord([TCU])

# Variable pour le filtre standard
Local Char   FILTECT(250)(0..4)
Local Integer IFILE

# Variable générale
Local Integer ISOC               # Indice de société sous GSOC
Local Date    DATDEB , DATFIN    # Date début et fin d'exercice

# Variable commune de travails
Local Char    DEVBAL(GLONCUR) , SITBAL(GLONFCY)

Local Integer TEST            # Variable qui permet d'ajouter des éléments dans la trace.
Local Integer OK              # Flag pour le controle de mono-société.
Local Integer ANOM            # Nombre d'anomalies rencontrées
Local Integer I,J,K

# 311209 : Pour les indices d'axes correpondants aux axes du référentiel
Local Integer INDDIE1,INDDIE2,INDDIE3,INDDIE4,INDDIE5,INDDIE6,INDDIE7,INDDIE8,INDDIE9

Local Char    MESSA(80)                        # Message d'erreur
Local Integer STAT                             # Statut d'erreur

# Variables : Feature 79527 - SP2US26
Local Char   FILTHAT(250)(0..4)
Local Integer IFILH

######################### Trace détaillée si TEST=1
TEST  = 0

#-- Vérification d'équilibre : Pas de critère sur compte
If BALANA<>2 : COMPTE = "" :  Endif

If !(BATCH | DIRECT)
 If BALANA=2
  Call OUVRE_TRACE(mess(73,116,1)) From LECFIC        # Récupération balance analytique
 Else
  Call OUVRE_TRACE(mess(74,116,1)) From LECFIC        # Vérification balance analytique
 Endif
Endif

If !TEST & BALANA=2 & !DIRECT
 Call MONOCPY(SOCIETE, OK) From AX3MONO # <JFL>
 If !OK : Goto FIN : Endif
Endif

GSOCIETE = [L]SOCIETE
Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV
If SOCIETE<>[F:FIY]CPY | [L]LEDTYP<>[F:FIY]LEDTYP | EXERCICE<>[F:FIY]FIYNUM
 Read [FIY]FIY0 = SOCIETE;[L]LEDTYP;EXERCICE
 If fstat
  Call ECR_TRACE(SOCIETE-num$(EXERCICE)-mess(52,116,1),1) From GESECRAN     # Exercice incorrect
  ANOM = 1 : Goto FIN
 Endif
Endif
DATDEB = [F:FIY]FIYSTR
DATFIN = [F:FIY]FIYEND
ISOC = find(SOCIETE,GSOC(1..GNBSOC))

Call LEC_CPY(SOCIETE) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC

Gosub BUILD_INDDIE

#-- Feature 79527 - SP2US26
Gosub VERF_HAT
Read [LNK] First
If !fstat
 If BALANA=2
  Call ECR_TRACE(mess(186,123,1)+"."-mess(49,114,1),1) From GESECRAN
  Goto FIN
 Else
  Call ECR_TRACE(mess(43,187,1)+"."-mess(49,114,1),-1) From GESECRAN
 Endif
Endif

If BALANA<>2
 Gosub TSTBLQ
Else
 Gosub RECBLQ
Endif

$FIN
If BALANA=2 & !DIRECT
 Call MULTICPY(SOCIETE) From AX3MONO # <JFL>
Endif
If !(BATCH | DIRECT)
 Call FERME_TRACE From LECFIC
Endif
End

$BUILD_INDDIE
Gosub DECLARE_GLOBAL From SUBCMM
Call INI_GLOBAL(SOCIETE,STAT,MESSA) From SUBCMM
Call LEC_LED([F:GCM]LED([L]LEDTYP-1)) From CPTLEC
If !fstat
 For I=0 To [F:LED]DIENBR-1
  J=find([F:LED]DIE(I),GENGAXE(1..20))
  If J
   Assign "INDDIE"+num$(I+1) With J-1
  Endif
 Next
Endif
Return

############################################################################################################
#-- Resynchronisation de la balance
############################################################################################################
$RECBLQ

# Variable pour le filtre de pagination (gestion snapshot too old)
Local Char    FILTPAG(250)(0..4)
Local Integer IFILP
Local Char    CPTDEB(GLONGAC),TRSDEB(GLONBPR),CCEDEB(GLONCCE)(1..9)
Local Char    CPTCUR(GLONGAC),TRSCUR(GLONBPR),CCECUR(GLONCCE)(1..9)
Local Integer FLCCE(1..9), RGCLE

# Variable pour le filtre de RAZ balance
Local Char    FILTBAL(250)(0..4)
Local Integer IFILTA

#-- Variable pour la re-synchronisation des montants
Local Decimal QTY(1..MAXDEV,0..MAXPER)                                    # Quantités Ligne Compte/Tiers
Local Decimal QTYE(1..MAXDEV,0..MAXPER), QTYP(1..MAXDEV,0..MAXPER)        # Quantités Engagées/Pré-engagées Ligne Compte/Tiers
Local Decimal CQTY(1..MAXDEV,0..MAXPER)                                   # Cumuls Ligne Tiers
Local Decimal CQTYE(1..MAXDEV,0..MAXPER),CQTYP(1..MAXDEV,0..MAXPER)       # Cumuls Engagées/Pré-engagées Ligne Tiers

#-- Stockage du nombre & intitulé de devises parcourues (Qty Lignes + Qty Lignes Tiers)
Local Integer NBDEV, CNBDEV
Local Char    TBDEV(GLONCUR)(1..MAXDEV),CTBDEV(GLONCUR)(1..MAXDEV)

#-- Variable pour stocker les autres valeurs
Local Integer BALFIY, BALSNS
Local Char    BALCPY(GLONCPY), BALFCY(GLONFCY)
Local Char    BALACC(GLONGAC), BALBPR(GLONBPR), BALCUR(GLONCUR)

Local Char    BALSEC1(GLONCCE) , BALSEC2(GLONCCE) , BALSEC3(GLONCCE)
Local Char    BALSEC4(GLONCCE) , BALSEC5(GLONCCE) , BALSEC6(GLONCCE)
Local Char    BALSEC7(GLONCCE) , BALSEC8(GLONCCE) , BALSEC9(GLONCCE)

#-- Paramètres d'optimisation des boucles pour éviter le vieux snapshot too old
Local Integer NBECR, TOTECR, ECRMAX  : ECRMAX = 10000     # Nombre pièces à re-synchroniser
Local Integer NBCPT, TOTCPT, CPTMAX  : CPTMAX = 200       # Nombres comptes re-synchroniser
Local Integer STOP

Local Integer NBAXI                # Nombre d'axe pour le référentiel
Local Integer FLSOC,FLSIT,FLDEV    # Flag de travail
Local Integer K,IDEV

#-- Information sur le nombres d'axes à gérer
Call INDLED([F:GCM]LED(LEDTYP-1),"",I,J) From CPTDIV
NBAXI = GLEDDIENBR(I)
If !NBAXI : Return : Endif

#-- Entête fichier Trace
Call LEC_CPY(SOCIETE) From CPTLEC
Call ECR_TRACE(mess(73,116,1),0) From GESECRAN                                    # Récupération balance analytique
Call ECR_TRACE(mess(2,116,1)-SOCIETE,0) From GESECRAN                             # Société
Call ECR_TRACE(mess(3,116,1)-num$(EXERCICE),0) From GESECRAN                      # Exercice
If TOUSITE=2
 Call ECR_TRACE(mess(4,116,1),0) From GESECRAN                                    # Tous sites
Elsif SITE<>""
 Call ECR_TRACE(mess(5,116,1)-SITE,0) From GESECRAN                               # Site
Endif
If DEVISE<>""
 Call ECR_TRACE(mess(55,116,1)-DEVISE,0) From GESECRAN                            # Devise
Endif
If COMPTE<>""
 Call ECR_TRACE(mess(76,116,1)-COMPTE,0) From GESECRAN                            # Nature
Endif

#-- Début récupération
Call ECR_TRACE(mess(49,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

#-- Remise à zéro
Call ECR_TRACE(mess(149,124,1),0) From GESECRAN
Gosub RAZBAL

#-- Information sur la devise
If DEVISE=""
 FLDEV = 0
Else
 FLDEV = 1
Endif


#-- Récupération par site
If TOUSITE=2 or SITE=""
 If TOUSITE=2
  FLSOC = 1 : FLSIT = 1
 Else
  FLSOC = 1 : FLSIT = 0
 Endif
 For [FCY]FCY0 Where LEGCPY=SOCIETE & FINFLG=2
  SITE = [F:FCY]FCY
  Gosub RECBLQSIT
 Next
Else
 FLSOC = 0 : FLSIT = 1
 Gosub RECBLQSIT
Endif
Call ECR_TRACE(mess(50,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN    # Fin récupération
Return

$RECBLQSIT
#Engagement
Raz FILTECT, IFILE

# Il faut conditionné le RECCMM en fonction du STAT issu du Call INI_GLOBAL(SOCIETE,STAT,MESSA) From SUBCMM fait dans $BUILD_INDDIE
# Si il n'y a pas de référentiel flagué engagement, rien ne sert de récupérer les quantités dans les engagement
If !STAT & [F:LED]CMM=2
 Call ADDCRIT(FILTECT,IFILE,"LEDTYP",'[F:CMD]LEDTYP('+num$([L]LEDTYP-1)+')='+num$([L]LEDTYP)," & ") From GOBJSUB
 Call ADDCRIT(FILTECT,IFILE,"CPY",'[F:CMD]CPY="'+SOCIETE+'"'," & ") From GOBJSUB
 Call ADDCRIT(FILTECT,IFILE,"FCYLIN",'[F:CMD]FCYLIN="'+SITE+'"'," & ") From GOBJSUB
 Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:CMD]ACCDAT>=['+format$(GFMD,DATDEB)+']'," & ") From GOBJSUB
 Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:CMD]ACCDAT<=['+format$(GFMD,DATFIN)+']'," & ") From GOBJSUB
 If COMPTE<>""
  Call ADDCRIT(FILTECT,IFILE,"ACC",'[F:CMD]ACC('+num$([L]LEDTYP-1)+')="'+COMPTE+'"'," & ") From GOBJSUB
 Endif
 If DEVISE<>""
  Call ADDCRIT(FILTECT,IFILE,"CUR",'[F:CMD]CUR="'+DEVISE+'"'," & ") From GOBJSUB
 Endif
 Call ADDCRIT(FILTECT,IFILE,"QTY",'[F:CMD]QTY<>0'," & ") From GOBJSUB

 Gosub RECCMM
Endif

#Ligne DAA
Raz FILTECT, IFILE

Call ADDCRIT(FILTECT,IFILE,"LEDTYP",'[F:DAA]LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"CPY",'[F:DAA]CPY="'+SOCIETE+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"FCYLIN",'[F:DAA]FCYLIN="'+SITE+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:DAA]ACCDAT>=['+format$(GFMD,DATDEB)+']'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:DAA]ACCDAT<=['+format$(GFMD,DATFIN)+']'," & ") From GOBJSUB
If COMPTE<>""
 Call ADDCRIT(FILTECT,IFILE,"ACC",'[F:DAA]ACC="'+COMPTE+'"'," & ") From GOBJSUB
Endif
If DEVISE<>""
 Call ADDCRIT(FILTECT,IFILE,"CUR",'[F:DAA]CUR="'+DEVISE+'"'," & ") From GOBJSUB
Endif
Call ADDCRIT(FILTECT,IFILE,"QTY",'[F:DAA]QTY<>0'," & ") From GOBJSUB

Gosub RECDAA
Return


############################################################################################################
#-- Resynchronisation de la balance des quantités engagements et pré-engagements
############################################################################################################
$RECCMM

# Appelé par les procédures de migration
If func DOSSUB.ISHISTFOLD(DOSSIER)=1 & func DOSVUE.ISVIEW(DOSSIER,"GCOMMIT")=1
 Return
Endif

Case NBAXI
 When 1
  Filter [CMD]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA([L]LEDTYP-1);ACC([L]LEDTYP-1);BPRACC
& ;CCE(INDDIE1);NUM;LIN
#& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA;ACC;BPRACC;CCE(0);NUM;LIN
  RGCLE = 7
 When 2
  Filter [CMD]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA([L]LEDTYP-1);ACC([L]LEDTYP-1);BPRACC
& ;CCE(INDDIE1);CCE(INDDIE2);NUM;LIN
#& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA;ACC;BPRACC;CCE(0);CCE(1);NUM;LIN
  RGCLE = 8
 When 3
  Filter [CMD]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA([L]LEDTYP-1);ACC([L]LEDTYP-1);BPRACC
& ;CCE(INDDIE1);CCE(INDDIE2);CCE(INDDIE3);NUM;LIN
#& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA;ACC;BPRACC;CCE(0);CCE(1);CCE(2);NUM;LIN
  RGCLE = 9
 When 4
  Filter [CMD]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA([L]LEDTYP-1);ACC([L]LEDTYP-1);BPRACC
& ;CCE(INDDIE1);CCE(INDDIE2);CCE(INDDIE3);CCE(INDDIE4);NUM;LIN
#& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA;ACC;BPRACC;CCE(0);CCE(1);CCE(2);CCE(3);NUM;LIN
  RGCLE = 10
 When 5
  Filter [CMD]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA([L]LEDTYP-1);ACC([L]LEDTYP-1);BPRACC
& ;CCE(INDDIE1);CCE(INDDIE2);CCE(INDDIE3);CCE(INDDIE4);CCE(INDDIE5);NUM;LIN
#& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA;ACC;BPRACC;CCE(0);CCE(1);CCE(2);CCE(3);CCE(4);NUM;LIN
  RGCLE = 11
 When 6
  Filter [CMD]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA([L]LEDTYP-1);ACC([L]LEDTYP-1);BPRACC
& ;CCE(INDDIE1);CCE(INDDIE2);CCE(INDDIE3);CCE(INDDIE4);CCE(INDDIE5);CCE(INDDIE6);NUM;LIN
#& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA;ACC;BPRACC;CCE(0);CCE(1);CCE(2);CCE(3);CCE(4);CCE(5);NUM;LIN
  RGCLE = 12
 When 7
  Filter [CMD]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA([L]LEDTYP-1);ACC([L]LEDTYP-1);BPRACC
& ;CCE(INDDIE1);CCE(INDDIE2);CCE(INDDIE3);CCE(INDDIE4);CCE(INDDIE5);CCE(INDDIE6);CCE(INDDIE7);NUM;LIN
#& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA;ACC;BPRACC;CCE(0);CCE(1);CCE(2);CCE(3);CCE(4);CCE(5);CCE(6);NUM;LIN
  RGCLE = 13
 When 8
  Filter [CMD]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA([L]LEDTYP-1);ACC([L]LEDTYP-1);BPRACC
& ;CCE(INDDIE1);CCE(INDDIE2);CCE(INDDIE3);CCE(INDDIE4);CCE(INDDIE5);CCE(INDDIE6);CCE(INDDIE7);CCE(INDDIE8);NUM;LIN
#& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA;ACC;BPRACC;CCE(0);CCE(1);CCE(2);CCE(3);CCE(4);CCE(5);CCE(6);CCE(7);NUM;LIN
  RGCLE = 14
 When 9
  Filter [CMD]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA([L]LEDTYP-1);ACC([L]LEDTYP-1);BPRACC
& ;CCE(INDDIE1);CCE(INDDIE2);CCE(INDDIE3);CCE(INDDIE4);CCE(INDDIE5);CCE(INDDIE6);CCE(INDDIE7);CCE(INDDIE8);CCE(INDDIE9);NUM;LIN
#& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA;ACC;BPRACC;CCE(0);CCE(1);CCE(2);CCE(3);CCE(4);CCE(5);CCE(6);CCE(7);CCE(8);NUM;LIN
  RGCLE = 15
Endcase

TOTECR = 0
TOTCPT = 0
CPTDEB = ""
TRSDEB = ""
For I=1 To 9
 Raz CCEDEB(I)
 Raz FLCCE(I)
Next

#RecuBAL: RAZREP

#-- Link GACCOUNT & GCOMMIT
Link [CMD] With [GAC]GAC0~=[F:CMD]COA([L]LEDTYP-1);[F:CMD]ACC([L]LEDTYP-1), [CMM]CMM0~=[F:CMD]NUM
& As [LNK]
& Where evalue(FILTECT)

#-- Boucle optimisée pour éviter le snapshot too old tout en utilisant les index
Gosub SET_FIRST From TRTFIRST
$BOUCLE_CMM
NBECR  = 0
NBCPT  = 0
STOP = 0
Raz FILTPAG, IFILP

J=NBAXI
While J>0
 If FLCCE(J)
  Call ADDCRIT(FILTPAG,IFILP,"ACC",'[F:CMD]ACC('+num$([L]LEDTYP-1)+')="'+CPTDEB+'"'," & ") From GOBJSUB
  Call ADDCRIT(FILTPAG,IFILP,"BPR",'[F:CMD]BPRACC="'+TRSDEB+'"'," & ") From GOBJSUB
  For I=1 To J-2
   Call ADDCRIT(FILTPAG,IFILP,"CCE",'[F:CMD]CCE('+num$(I)+')="'+CCEDEB(I)+'"'," & ") From GOBJSUB
  Next
  Call ADDCRIT(FILTPAG,IFILP,"CCE",'[F:CMD]CCE('+num$(I)+')>"'+CCEDEB(I)+'"'," & ") From GOBJSUB
  Break
 Endif
 J-=1
Wend
If J=0
 If TRSDEB<>""
  Call ADDCRIT(FILTPAG,IFILP,"ACC",'[F:CMD]ACC('+num$([L]LEDTYP-1)+')="'+CPTDEB+'"'," & ") From GOBJSUB
  Call ADDCRIT(FILTPAG,IFILP,"BPR",'[F:CMD]BPRACC>"'+TRSDEB+'"'," & ") From GOBJSUB
 Elsif CPTDEB<>""
  Call ADDCRIT(FILTPAG,IFILP,"ACC",'[F:CMD]ACC('+num$([L]LEDTYP-1)+')>"'+CPTDEB+'"'," & ") From GOBJSUB
 Endif
Endif

If FILTPAG="" : FILTPAG="1=1" : Endif

#-- Ligne de pièces analytique
For [LNK]CLE(5) Where evalue(FILTPAG) : # Société + site + compte
 BALACC = [F:GAC]ACC
 If TRSDEB="" & [F:GAC]SAC=2
  Gosub RAZCMMCOL
 Endif
 For [LNK]CLE(6)
  If NBCPT>=CPTMAX or NBECR>=ECRMAX
   STOP = 1
   CPTDEB = CPTCUR
   TRSDEB = TRSCUR
   For I=1 To NBAXI
    Assign "CCEDEB("+num$(I)+")" With evalue("CCECUR("+num$(I)+")")
   Next
   FLCCE(NBAXI)=1
   Break 2
  Endif
  CPTCUR = [F:CMD]ACC([L]LEDTYP-1)
  TRSCUR = [F:CMD]BPRACC

  Gosub BALCMMCPT
  If [F:GAC]SAC=2
   Gosub CUMCMMCOL
  Endif
  NBCPT += 1
 Next
 If [F:GAC]SAC=2
  Gosub BALCMMCOL
 Endif
Next
TOTCPT += NBCPT
TOTECR += NBECR
If TEST : Call ECR_TRACE(time$-"break"-num$(TOTCPT)-num$(TOTECR),0) From GESECRAN : Endif
If STOP
 Goto BOUCLE_CMM
Else
 J=NBAXI
 While J>1
  If FLCCE(J)
   FLCCE(J) = 0
   FLCCE(J-1) = 1
   Goto BOUCLE_CMM
  Endif
  J-=1
 Wend
 If FLCCE(1)
  FLCCE(1) = 0
  Goto BOUCLE_CMM
 Elsif TRSDEB<>""
  TRSDEB = ""
  Goto BOUCLE_CMM
 Endif
Endif
Gosub UNSET_FIRST From TRTFIRST
Filter [CMD]
Return

$BALCMMCPT
For [LNK]CLE(RGCLE)
 Raz QTYE, QTYP
 Raz NBDEV, TBDEV
 For [LNK]CLE
  NBECR += 1
  If !FLDEV | DEVISE=[F:CMM]CUR
   IDEV = find([F:CMM]CUR,TBDEV(1..NBDEV))
   If !IDEV : NBDEV += 1 : TBDEV(NBDEV) = [F:CMM]CUR : IDEV = NBDEV : Endif
   Gosub CUMCMMCPT
  Endif
  For I=1 To NBAXI
    Assign "CCECUR("+num$(I)+")" With evalue("[F:CMD]CCE("+num$(evalue("INDDIE"+num$(I)))+")")
  Next
 Next
 If NBDEV
  Gosub MAJCMMCPT
 Endif
Next
Return

$CUMCMMCPT
If [F:CMM]SNS = 1
 BALSNS = +1
Else
 BALSNS = -1
Endif

If [F:CMD]FIY = EXERCICE
 If [F:CMM]TYP=1
  QTYP(IDEV,[F:CMD]PER)  += BALSNS*[F:CMD]QTY
 Else
  QTYE(IDEV,[F:CMD]PER)  += BALSNS*[F:CMD]QTY
 Endif
Endif
Return

$MAJCMMCPT
Call DEBTRANS From GLOCK
Gosub TRCMM2
Return

$TRCMM2
GOK = 1
Trbegin [BLQ]
BALCPY = SOCIETE
BALACC = CPTCUR
BALBPR = TRSCUR
BALFIY = EXERCICE

#For I=1 To NBAXI
# Assign "BALSEC"+num$(I) With evalue("[F:CMD]CCE("+num$(I-1)+")")
#Next
#For I=NBAXI+1 To 9
# Assign "BALSEC"+num$(I) With ""
#Next

For I=1 To 9
 Assign "BALSEC"+num$(I) With evalue("[F:CMD]CCE("+num$(evalue("INDDIE"+num$(I)))+")")
Next

If TEST : Call ECR_TRACE(time$-"blq"-SITE-BALACC-BALSEC1-BALSEC2-BALSEC3,0) From GESECRAN : Endif
Gosub CRECMMBAL
If GOK<1 : Goto AB_TRCMM2 : Endif

Commit
Return

############################################################################################################
#-- Ré écriture de la Balance des quantités engagements et pré-engagements
############################################################################################################
$CRECMMBAL
For IDEV=1 To NBDEV
 If DEVISE="" or DEVISE=TBDEV(IDEV)
  BALCUR = TBDEV(IDEV)
  # MAJ Société
  If FLSOC
   BALFCY = ""
   Gosub MAJCMMBAL
   If GOK<1 : Return : Endif
   If BALBPR<>""
    BALBPR=""
    Gosub MAJCMMBAL
    If GOK<1 : Return : Endif
   Endif
  Endif
  BALBPR=TRSCUR
  # MAJ Site
  If FLSIT
   BALFCY = [F:CMD]FCYLIN
   Gosub MAJCMMBAL
   If GOK<1 : Return : Endif
   If BALBPR<>""
    BALBPR=""
    Gosub MAJCMMBAL
    If GOK<1 : Return : Endif
   Endif
  Endif
 Endif
Next IDEV
Return

$MAJCMMBAL
If BALACC<>""
 Readlock [BLQ]BLQ0 = [L]LEDTYP;BALCPY;BALFCY;BALFIY;BALACC;BALBPR;BALSEC1;BALSEC2;BALSEC3;BALSEC4;BALSEC5;BALSEC6;BALSEC7;BALSEC8;BALSEC9;BALCUR
 If fstat
  Raz [F:BLQ]
  [F:BLQ]LEDTYP = [L]LEDTYP
  [F:BLQ]CPY    = BALCPY
  [F:BLQ]FCY    = BALFCY
  [F:BLQ]FIY    = BALFIY
  [F:BLQ]ACC    = BALACC
  [F:BLQ]BPR    = BALBPR
  [F:BLQ]CCE1   = BALSEC1
  [F:BLQ]CCE2   = BALSEC2
  [F:BLQ]CCE3   = BALSEC3
  [F:BLQ]CCE4   = BALSEC4
  [F:BLQ]CCE5   = BALSEC5
  [F:BLQ]CCE6   = BALSEC6
  [F:BLQ]CCE7   = BALSEC7
  [F:BLQ]CCE8   = BALSEC8
  [F:BLQ]CCE9   = BALSEC9
  [F:BLQ]CUR    = BALCUR
  [F:BLQ]ACCNUM = uniqid([F:BLQ])
  #[F:BLQ]LED    = [F:CMM]LED
  #[F:BLQ]COA    = [F:CMD]COA
  [F:BLQ]LED    = [F:CMM]LED([L]LEDTYP-1)
  [F:BLQ]COA    = [F:CMD]COA([L]LEDTYP-1)
  [F:BLQ]UOM    = [F:CMD]UOM

  For I=1 To 9
   Assign "[F:BLQ]DIE("+num$(I-1)+")"  With evalue("[F:CMD]DIE("+num$(I-1)+")")
  Next
  Gosub CALCMMBAL
  Write [BLQ]
 Else
  #[F:BLQ]LED    = [F:CMM]LED
  #[F:BLQ]COA    = [F:CMD]COA
  [F:BLQ]LED    = [F:CMM]LED([L]LEDTYP-1)
  [F:BLQ]COA    = [F:CMD]COA([L]LEDTYP-1)
  [F:BLQ]UOM    = [F:CMD]UOM

  For I=1 To 9
   Assign "[F:BLQ]DIE("+num$(I-1)+")"  With evalue("[F:CMD]DIE("+num$(I-1)+")")
  Next
  Gosub CALCMMBAL
  Rewrite [BLQ]
 Endif
 If fstat
  GOK=0 : Call FSTA("BLQ") From GLOCK : Return
 Endif
Endif
Return

$CALCMMBAL
For K=0 To MAXPER-1
 [F:BLQ]QTYCMM(K)       += QTYE(IDEV,K)
 [F:BLQ]QTYPRP(K)       += QTYP(IDEV,K)
Next K
Return

$AB_TRCMM2
$AB_TRCMM22
Rollback
Return

$ROLL_TRCMM2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TRCMM2 : Endif


############################################################################################################
#- Collectif
############################################################################################################
######################################################
$RAZCMMCOL
If TEST : Call ECR_TRACE("raz collectif"-[F:GAC]ACC,0) From GESECRAN : Endif
Raz CQTYE, CQTEP
Raz CNBDEV, CTBDEV
Return

######################################################
$CUMCMMCOL
For IDEV=1 To NBDEV
 JDEV = find(TBDEV(IDEV),CTBDEV(1..CNBDEV))
 If !JDEV : CNBDEV += 1 : CTBDEV(CNBDEV) = TBDEV(IDEV) : JDEV = CNBDEV : Endif
 For K=0 To MAXPER-1
  CQTYE(JDEV,K) += QTYE(IDEV,K)
  CQTYP(JDEV,K) += QTYP(IDEV,K)
 Next K
Next IDEV
Return

######################################################
$BALCMMCOL
If TEST : Call ECR_TRACE("maj collectif"-[F:GAC]ACC,0) From GESECRAN : Endif
Call DEBTRANS From GLOCK
Gosub TRCMM22
Return

$TRCMM22
GOK = 1
NBDEV = CNBDEV
For IDEV=1 To NBDEV
 TBDEV(IDEV) = CTBDEV(IDEV)
 For K=0 To MAXPER-1
  QTYE(IDEV,K) = CQTYE(IDEV,K)
  QTYP(IDEV,K) = CQTYP(IDEV,K)
 Next K
Next IDEV
If NBDEV
 Trbegin [BLQ]
 BALCPY = SOCIETE
 BALACC = CPTCUR
 BALBPR = ""
 BALFIY = EXERCICE
# For I=1 To NBAXI
#  Assign "BALSEC"+num$(I) With evalue("[F:CMD]CCE("+num$(I-1)+")")
# Next
# For I=NBAXI+1 To 9
#  Assign "BALSEC"+num$(I) With ""
# Next
 For I=1 To 9
  Assign "BALSEC"+num$(I) With evalue("[F:CMD]CCE("+num$(evalue("INDDIE"+num$(I)))+")")
 Next

 If TEST : Call ECR_TRACE(time$-"blq"-SITE-BALACC-BALSEC1-BALSEC2-BALSEC3,0) From GESECRAN : Endif
 Gosub CRECMMBAL
 If GOK<1 : Goto AB_TRCMM22 : Endif
 Commit
Endif
Return


############################################################################################################
#-- Resynchronisation de la balance en quantité (pièces analytiques)
############################################################################################################
$RECDAA

# Appelé par les procédures de migration
If func DOSSUB.ISHISTFOLD(DOSSIER)=1 & func DOSVUE.ISVIEW(DOSSIER,"GACCENTRYA")=1
 Return
Endif

Case NBAXI
 When 1
  Filter [DAA]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA;ACC;BPR;CCE(0);ACCNUM;ANALIN
  RGCLE = 7
 When 2
  Filter [DAA]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA;ACC;BPR;CCE(0);CCE(1);ACCNUM;ANALIN
  RGCLE = 8
 When 3
  Filter [DAA]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA;ACC;BPR;CCE(0);CCE(1);CCE(2);ACCNUM;ANALIN
  RGCLE = 9
 When 4
  Filter [DAA]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA;ACC;BPR;CCE(0);CCE(1);CCE(2);CCE(3);ACCNUM;ANALIN
  RGCLE = 10
 When 5
  Filter [DAA]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA;ACC;BPR;CCE(0);CCE(1);CCE(2);CCE(3);CCE(4);ACCNUM;ANALIN
  RGCLE = 11
 When 6
  Filter [DAA]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA;ACC;BPR;CCE(0);CCE(1);CCE(2);CCE(3);CCE(4);CCE(5);ACCNUM;ANALIN
  RGCLE = 12
 When 7
  Filter [DAA]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA;ACC;BPR;CCE(0);CCE(1);CCE(2);CCE(3);CCE(4);CCE(5);CCE(6);ACCNUM;ANALIN
  RGCLE = 13
 When 8
  Filter [DAA]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA;ACC;BPR;CCE(0);CCE(1);CCE(2);CCE(3);CCE(4);CCE(5);CCE(6);CCE(7);ACCNUM;ANALIN
  RGCLE = 14
 When 9
  Filter [DAA]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA;ACC;BPR;CCE(0);CCE(1);CCE(2);CCE(3);CCE(4);CCE(5);CCE(6);CCE(7);CCE(8);ACCNUM;ANALIN
  RGCLE = 15
Endcase

TOTECR = 0
TOTCPT = 0
CPTDEB = ""
TRSDEB = ""
For I=1 To 9
 Raz CCEDEB(I)
 Raz FLCCE(I)
Next

#-- Link GACCOUNT & GACCENTRYD & GACCENTRY
Link [DAA] With [GAC]GAC0~=[F:DAA]COA;[F:DAA]ACC, [HAE]HAE0~=[F:DAA]TYP;[F:DAA]NUM,
&               [DAE]DAE0~=[F:DAA]TYP;[F:DAA]NUM;[F:DAA]LIN;[F:DAA]LEDTYP
& As [LNK]
& Where evalue(FILTECT)

#-- Boucle optimisée pour éviter le snapshot too old tout en utilisant les index
Gosub SET_FIRST From TRTFIRST
$BOUCLE_DAA
NBECR  = 0
NBCPT  = 0
STOP = 0
Raz FILTPAG, IFILP

J=NBAXI
While J>0
 If FLCCE(J)
  Call ADDCRIT(FILTPAG,IFILP,"ACC",'[F:DAA]ACC="'+CPTDEB+'"'," & ") From GOBJSUB
  Call ADDCRIT(FILTPAG,IFILP,"ACC",'[F:DAA]BPR="'+TRSDEB+'"'," & ") From GOBJSUB
  For I=1 To J-2
   Call ADDCRIT(FILTPAG,IFILP,"CCE",'[F:DAA]CCE('+num$(I)+')="'+CCEDEB(I)+'"'," & ") From GOBJSUB
  Next
  Call ADDCRIT(FILTPAG,IFILP,"CCE",'[F:DAA]CCE('+num$(I)+')>"'+CCEDEB(I)+'"'," & ") From GOBJSUB
  Break
 Endif
 J-=1
Wend
If J=0
 If TRSDEB<>""
  Call ADDCRIT(FILTPAG,IFILP,"ACC",'[F:DAA]ACC="'+CPTDEB+'"'," & ") From GOBJSUB
  Call ADDCRIT(FILTPAG,IFILP,"BPR",'[F:DAA]BPR>"'+TRSDEB+'"'," & ") From GOBJSUB
 Elsif CPTDEB<>""
  Call ADDCRIT(FILTPAG,IFILP,"ACC",'[F:DAA]ACC>"'+CPTDEB+'"'," & ") From GOBJSUB
 Endif
Endif


If FILTPAG="" : FILTPAG="1=1" : Endif

#-- Ligne de pièces analytique
For [LNK]CLE(5) Where  evalue(FILTPAG) : # Société + site + compte
 BALACC = [F:GAC]ACC
 If TRSDEB="" & [F:GAC]SAC=2
  Gosub RAZDAACOL
 Endif

 For [LNK]CLE(6)

  If NBCPT>=CPTMAX or NBECR>=ECRMAX
   STOP = 1
   CPTDEB = CPTCUR
   TRSDEB = TRSCUR
   For I=1 To NBAXI
    Assign "CCEDEB("+num$(I)+")" With evalue("CCECUR("+num$(I)+")")
   Next
   FLCCE(NBAXI)=1
   Break 2
  Endif
  CPTCUR = [F:DAA]ACC
  TRSCUR = [F:DAA]BPR
  For I=1 To NBAXI
    Assign "CCECUR("+num$(I)+")" With evalue("[F:DAA]CCE("+num$(I-1)+")")
  Next

  Gosub BALDAACPT
  If [F:GAC]SAC=2
   Gosub CUMDAACOL
  Endif
  NBCPT += 1
 Next
 If [F:GAC]SAC=2
  Gosub BALDAACOL
 Endif
Next
TOTCPT += NBCPT
TOTECR += NBECR
If TEST : Call ECR_TRACE(time$-"break"-num$(TOTCPT)-num$(TOTECR),0) From GESECRAN : Endif
If STOP
 Goto BOUCLE_DAA
Else
 J=NBAXI
 While J>1
  If FLCCE(J)
   FLCCE(J) = 0
   FLCCE(J-1) = 1
   Goto BOUCLE_DAA
  Endif
  J-=1
 Wend
 If FLCCE(1)
  FLCCE(1) = 0
  Goto BOUCLE_DAA
 Elsif TRSDEB<>""
  TRSDEB = ""
  Goto BOUCLE_DAA
 Endif
Endif
Gosub UNSET_FIRST From TRTFIRST
Filter [DAA]
Return

$BALDAACPT
For [LNK]CLE(RGCLE)
 Raz QTY
 Raz NBDEV, TBDEV

 For [LNK]CLE
  NBECR += 1
  If [F:HAE]CAT<>3 & [F:HAE]CAT<>5
   If !FLDEV | DEVISE=[F:HAE]CUR
    IDEV = find([F:HAE]CUR,TBDEV(1..NBDEV))
    If !IDEV : NBDEV += 1 : TBDEV(NBDEV) = [F:HAE]CUR : IDEV = NBDEV : Endif
    Gosub CUMDAACPT
   Endif
  Endif
 Next
 If NBDEV
  Gosub MAJDAACPT
 Endif
Next
Return

$CUMDAACPT
If [F:DAE]FIY = EXERCICE
 If [F:DAA]SNS>0
  QTY(IDEV,[F:DAE]PER)  += [F:DAA]QTY
 Else
  QTY(IDEV,[F:DAE]PER)  -= [F:DAA]QTY
 Endif
Endif
Return

$MAJDAACPT
Call DEBTRANS From GLOCK
Gosub TRDAA2
Return

$TRDAA2
GOK = 1
Trbegin [BLQ]
BALCPY = SOCIETE
BALACC = CPTCUR
BALBPR = TRSCUR
BALFIY = EXERCICE

For I=1 To NBAXI
 Assign "BALSEC"+num$(I) With evalue("[F:DAA]CCE("+num$(I-1)+")")
Next
For I=NBAXI+1 To 9
 Assign "BALSEC"+num$(I) With ""
Next

If TEST : Call ECR_TRACE(time$-"blq"-SITE-CROISE-BALACC-BALSEC1-BALSEC2-BALSEC3,0) From GESECRAN : Endif

Gosub CREDAABAL
If GOK<1 : Goto AB_TRDAA2 : Endif
Commit
Return

############################################################################################################
#-- Ré écriture de la Balance
############################################################################################################
$CREDAABAL
For IDEV=1 To NBDEV
 If DEVISE="" or DEVISE=TBDEV(IDEV)
  BALCUR = TBDEV(IDEV)
  # MAJ Société
  If FLSOC
   BALFCY = ""
   Gosub MAJDAABAL
   If GOK<1 : Return : Endif
  Endif
  # MAJ Site
  If FLSIT
   BALFCY = [F:DAA]FCYLIN
   Gosub MAJDAABAL
   If GOK<1 : Return : Endif
  Endif
 Endif
Next IDEV
Return

$MAJDAABAL
If BALACC<>""
 Readlock [BLQ]BLQ0 = [L]LEDTYP;BALCPY;BALFCY;BALFIY;BALACC;BALBPR;BALSEC1;BALSEC2;BALSEC3;BALSEC4;BALSEC5;BALSEC6;BALSEC7;BALSEC8;BALSEC9;BALCUR
 If fstat
  Raz [F:BLQ]
  [F:BLQ]LEDTYP = [L]LEDTYP
  [F:BLQ]CPY    = BALCPY
  [F:BLQ]FCY    = BALFCY
  [F:BLQ]FIY    = BALFIY
  [F:BLQ]ACC    = BALACC
  [F:BLQ]BPR    = BALBPR
  [F:BLQ]CCE1   = BALSEC1
  [F:BLQ]CCE2   = BALSEC2
  [F:BLQ]CCE3   = BALSEC3
  [F:BLQ]CCE4   = BALSEC4
  [F:BLQ]CCE5   = BALSEC5
  [F:BLQ]CCE6   = BALSEC6
  [F:BLQ]CCE7   = BALSEC7
  [F:BLQ]CCE8   = BALSEC8
  [F:BLQ]CCE9   = BALSEC9
  [F:BLQ]CUR    = BALCUR
  [F:BLQ]ACCNUM = uniqid([F:BLQ])
  [F:BLQ]LED    = [F:DAA]LED
  [F:BLQ]COA    = [F:DAA]COA
  For I=1 To 9
   Assign "[F:BLQ]DIE("+num$(I-1)+")"  With evalue("[F:DAA]DIE("+num$(I-1)+")")
  Next
  Gosub CALDAABAL
  Write [BLQ]
 Else
  Gosub CALDAABAL
  Rewrite [BLQ]
 Endif
 If fstat
  GOK=0 : Call FSTA("BLQ") From GLOCK : Return
 Endif
Endif
Return

$CALDAABAL
For K=0 To MAXPER-1
 [F:BLQ]QTY(K)    += QTY(IDEV,K)
Next K
Return

$AB_TRDAA2
$AB_TRDAA22
Rollback
Return

$ROLL_TRDAA2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TRDAA2 : Endif


############################################################################################################
#- Collectif
############################################################################################################
######################################################
$RAZDAACOL
If TEST : Call ECR_TRACE("raz collectif"-[F:GAC]ACC,0) From GESECRAN : Endif
Raz CQTY
Raz CNBDEV, CTBDEV
Return

######################################################
$CUMDAACOL
For IDEV=1 To NBDEV
 JDEV = find(TBDEV(IDEV),CTBDEV(1..CNBDEV))
 If !JDEV : CNBDEV += 1 : CTBDEV(CNBDEV) = TBDEV(IDEV) : JDEV = CNBDEV : Endif
 For K=0 To MAXPER-1
  CQTY(JDEV,K) += QTY(IDEV,K)
 Next K
Next IDEV
Return

######################################################
$BALDAACOL
If TEST : Call ECR_TRACE("maj collectif"-[F:GAC]ACC,0) From GESECRAN : Endif
TRSCUR = ""
Call DEBTRANS From GLOCK
Gosub TRDAA22
Return

$TRDAA22
GOK = 1
NBDEV = CNBDEV
For IDEV=1 To NBDEV
 TBDEV(IDEV) = CTBDEV(IDEV)
 For K=0 To MAXPER-1
  QTY(IDEV,K) = CQTY(IDEV,K)
 Next K
Next IDEV
If NBDEV
 Trbegin [BLQ]
 BALCPY = SOCIETE
 BALACC = CPTCUR
 BALBPR = ""
 BALFIY = EXERCICE
 For I=1 To NBAXI
  Assign "BALSEC"+num$(I) With evalue("[F:DAA]CCE("+num$(I-1)+")")
 Next
 For I=NBAXI+1 To 9
  Assign "BALSEC"+num$(I) With ""
 Next
 If TEST : Call ECR_TRACE(time$-"blq"-SITE-BALACC-BALSEC1-BALSEC2-BALSEC3,0) From GESECRAN : Endif
 Gosub CREDAABAL
 If GOK<1 : Goto AB_TRDAA22 : Endif
 Commit
Endif
Return

########################################
$RAZBAL
Raz FILTBAL, IFILTA
Call ADDCRIT(FILTBAL,IFILTA,"LEDTYP",'LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTBAL,IFILTA,"CPY",'CPY="'+SOCIETE+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTBAL,IFILTA,"FIY",'FIY='+num$(EXERCICE)," & ") From GOBJSUB
If COMPTE<>""
 Call ADDCRIT(FILTBAL,IFILTA,"ACC",' ACC="'+COMPTE+'"'," & ") From GOBJSUB
Endif
If DEVISE<>""
 Call ADDCRIT(FILTBAL,IFILTA,"CUR",' CUR="'+DEVISE+'"'," & ") From GOBJSUB
Endif

If TOUSITE=2
 For [FCY]FCY0 Where LEGCPY=SOCIETE & FINFLG=2
  SITBAL = [F:FCY]FCY
  Call DEBTRANS From GLOCK
  Gosub TRCMM1
 Next
 SITBAL = ""
 Call DEBTRANS From GLOCK
 Gosub TRCMM1
Else
 If SITE<>""
  SITBAL = SITE
 Else
  SITBAL = ""
 Endif
 Call DEBTRANS From GLOCK
 Gosub TRCMM1
Endif
Return

$TRCMM1
If TEST : Call ECR_TRACE(time$-"raz n"-SITBAL,0) From GESECRAN : Endif
GOK = 1
Trbegin [BLQ]
Delete [BLQ] Where evalue(FILTBAL) & FCY=SITBAL
If fstat=1
 GOK = -1 : GLOCK = "$BALANA" : Goto ROLL_TRCMM1
Endif
Commit
Return

$AB_TRCMM1
Rollback
Return

$ROLL_TRCMM1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TRCMM1 : Endif



#########################################################################################################
#########################################################################################################
## Vérification de la balance des engagements
#########################################################################################################
#########################################################################################################
$TSTBLQ
Local Integer MAXSIT
MAXSIT = 5

# Ajout du filtre sur les sites financiers
Link [FGR] With [FCY]FCY0=[F:FGR]FCY
& As [LFGR]
& Where [FGR]CPY=SOCIETE & [FCY]FINFLG=2

For [LFGR]FGR0
 MAXSIT += 1
Next

Local Char    TBCUR(GLONCUR)(1..MAXDEV)
Local Char    TBSIT(GLONFCY)(1..MAXSIT)
Local Char    TIERS(GLONBPR)

# Quantité
Local Decimal BALQTY(0..MAXPER)
Local Decimal COLQTY(0..MAXPER)
Local Decimal GLQTY(1..MAXDEV,0..MAXPER)
Local Decimal SOCQTY(1..MAXDEV,0..MAXPER)
Local Decimal SITQTY(1..MAXSIT,1..MAXDEV,0..MAXPER)

# Quantité Engagées et Pré-engagées
Local Decimal BALQTYE(0..MAXPER),BALQTYP(0..MAXPER)
Local Decimal COLQTYE(0..MAXPER),COLQTYP(0..MAXPER)
Local Decimal GLQTYE(1..MAXDEV,0..MAXPER),GLQTYP(1..MAXDEV,0..MAXPER)
Local Decimal SOCQTYE(1..MAXDEV,0..MAXPER),SOCQTYP(1..MAXDEV,0..MAXPER)
Local Decimal SITQTYE(1..MAXSIT,1..MAXDEV,0..MAXPER),SITQTYP(1..MAXSIT,1..MAXDEV,0..MAXPER)
Local Integer BALSNS

Local Char    FMQTE(10)        # Format de l'unité d'oeuvre
Local Integer P,POIERR
Local Integer NBCUR, NBSIT


#-- Entête fichier Trace
Call LEC_CPY(SOCIETE) From CPTLEC
Call ECR_TRACE(mess(74,116,1),0) From GESECRAN                                     # Vérification balance analytique
Call ECR_TRACE(mess(2,116,1)-SOCIETE,0) From GESECRAN                              # Société
Call ECR_TRACE(mess(3,116,1)-num$(EXERCICE),0) From GESECRAN                       # Exercice
If TOUSITE=2
 Call ECR_TRACE(mess(4,116,1),0) From GESECRAN                                     # Tous sites
Elsif SITE<>""
 Call ECR_TRACE(mess(5,116,1)-SITE,0) From GESECRAN                                # Site
Endif
If DEVISE<>""
 Call ECR_TRACE(mess(55,116,1)-DEVISE,0) From GESECRAN                             # Devise
Endif
If COMPTE<>""
 Call ECR_TRACE(mess(76,116,1)-COMPTE,0) From GESECRAN                             # Nature
Endif
Call ECR_TRACE(mess(70,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN    # Début vérification
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

ANOM = 0

#------------ Engagement
Raz FILTECT, IFILE

Call ADDCRIT(FILTECT,IFILE,"LEDTYP",'[F:CMD]LEDTYP('+num$([L]LEDTYP-1)+')='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"CPY",'[F:CMD]CPY="'+SOCIETE+'"'," & ") From GOBJSUB
If TOUSITE<>2 & SITE<>""
 Call ADDCRIT(FILTECT,IFILE,"FCYLIN",'[F:CMD]FCYLIN="'+SITE+'"'," & ") From GOBJSUB
Endif
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:CMD]ACCDAT>=['+format$(GFMD,DATDEB)+']'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:CMD]ACCDAT<=['+format$(GFMD,DATFIN)+']'," & ") From GOBJSUB
If COMPTE<>""
 Call ADDCRIT(FILTECT,IFILE,"ACC",'[F:CMD]ACC('+num$([L]LEDTYP-1)+')="'+COMPTE+'"'," & ") From GOBJSUB
Endif
If DEVISE<>""
 Call ADDCRIT(FILTECT,IFILE,"CUR",'[F:CMD]CUR="'+DEVISE+'"'," & ") From GOBJSUB
Endif
Call ADDCRIT(FILTECT,IFILE,"QTY",'[F:CMD]QTY<>0'," & ") From GOBJSUB

Gosub TSTCMM
#------------

#------------ Ligne DAA
Raz FILTECT, IFILE

Call ADDCRIT(FILTECT,IFILE,"LEDTYP",'[F:DAA]LEDTYP='+num$(LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"CPY",'[F:DAA]CPY="'+SOCIETE+'"'," & ") From GOBJSUB
If TOUSITE<>2 & SITE<>""
 Call ADDCRIT(FILTECT,IFILE,"FCYLIN",'[F:DAA]FCYLIN="'+SITE+'"'," & ") From GOBJSUB
Endif
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:DAA]ACCDAT>=['+format$(GFMD,DATDEB)+']'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:DAA]ACCDAT<=['+format$(GFMD,DATFIN)+']'," & ") From GOBJSUB
If COMPTE<>""
 Call ADDCRIT(FILTECT,IFILE,"CPY",'[F:DAA]ACC="'+COMPTE+'"'," & ") From GOBJSUB
Endif
If DEVISE<>""
 Call ADDCRIT(FILTECT,IFILE,"CUR",'[F:DAA]CUR="'+DEVISE+'"'," & ") From GOBJSUB
Endif
Call ADDCRIT(FILTECT,IFILE,"QTY",'[F:DAA]QTY<>0'," & ") From GOBJSUB

Gosub TSTDAA
#------------

Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(71,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN    # Fin Vérification
If ANOM
 Call ECR_TRACE(num$(ANOM)-mess(7,116,1),0) From GESECRAN                          # anomalies
Else
 Call ECR_TRACE(mess(8,116,1),0) From GESECRAN                                     # Aucune anomalie
Endif
Return


#########################################################################################################
## Vérification de la balance des engagements
#########################################################################################################
$TSTCMM

NBCUR = 0
NBSIT = 0

#-- Link GACCOUNT & GCOMMIT
Link [CMD] With [GAC]GAC0~=[F:CMD]COA([L]LEDTYP-1);[F:CMD]ACC([L]LEDTYP-1), [CMM]CMM0~=[F:CMD]NUM
& As [LNK]
& Where evalue(FILTECT)
& Order By Key CLE = [F:CMD]ACC([L]LEDTYP-1);[F:CMD]BPRACC;[F:CMD]FCYLIN;[F:CMD]ACCDAT;[F:CMD]NUM;[F:CMD]LIN

Filter [BLQ]
Gosub SET_FIRST From TRTFIRST

For [LNK]CLE(1)   : # Compte
 COMPTE = [F:CMD]ACC([L]LEDTYP-1)
 Raz SITQTYE, SITQTYP
 Call LEC_TUN([F:GAC]UOM) From CPTLEC
 If [F:TUN]UOMDEC=0
  FMQTE = "15.5#"
 Else
  FMQTE = num$(14-[F:TUN]UOMDEC)+"."+num$([F:TUN]UOMDEC)+"#"
 Endif
 For [LNK]CLE(2)  : # Tiers
  TIERS = [F:CMD]BPRACC
  Raz SOCQTYE, SOCQTYP
  For [LNK]CLE(3) : # Site
   Raz GLQTYE, GLQTYP
   SITBAL = [F:CMD]FCYLIN
   For [LNK]CLE   : # Détail
    K = find([F:CMD]CUR,TBCUR(1..NBCUR))
    If !K
     NBCUR += 1 : K = NBCUR
     TBCUR(NBCUR) = [F:CMD]CUR
    Endif
    If [F:CMM]SNS = 1
     BALSNS = +1
    Else
     BALSNS = -1
    Endif
    If [F:CMM]TYP=1
     GLQTYP(K,[F:CMD]PER)    += BALSNS*[F:CMD]QTY
    Else
     GLQTYE(K,[F:CMD]PER)    += BALSNS*[F:CMD]QTY
    Endif
   Next
   # Vérif pour 1 compte  1 tiers et 1 site
   Gosub VER_CMM_BPR_SIT
   For P=0 To MAXPER-1
    For K=1 To NBCUR
     SOCQTYE(K,P)    += GLQTYE(K,P)
     SOCQTYP(K,P)    += GLQTYP(K,P)
    Next K
   Next P
   J = find(SITBAL,TBSIT(1..NBSIT))
   If !J
    NBSIT += 1 : J = NBSIT
    TBSIT(NBSIT) = SITBAL
   Endif
   For P=0 To MAXPER-1
    For K=1 To NBCUR
     SITQTYE(J,K,P)    += GLQTYE(K,P)
     SITQTYP(J,K,P)    += GLQTYP(K,P)
    Next K
   Next P
  Next
  # Vérif pour 1 compte  1 tiers et société
  If TOUSITE=2 : Gosub VER_CMM_BPR_SOC : Endif
 Next
 # Vérif pour 1 compte collectif, société et site
 If [F:GAC]SAC=2
  Gosub VER_CMM_CPT
 Endif
Next
Gosub UNSET_FIRST From TRTFIRST
Filter [CMD]
Return

###############################################
## Sous-programmes d'erreurs
###############################################
$VER_CMM_BPR_SIT
If TIERS="" & [F:GAC]SAC=2 : Return : Endif
If TEST : Call ECR_TRACE(time$-"VER_BPR_SIT"-SITBAL-COMPTE-TIERS,0) From GESECRAN : Endif
For K=1 To NBCUR
 DEVBAL = TBCUR(K)
 POIERR = 1  :# bug 7889 : controle bloquant en devise société
 # If DEVBAL<>[F:GCM]CUR(LEDTYP-1) : POIERR=0 : Endif

 Raz BALQTYE, BALQTYP
 For [BLQ]BLQ0 Where [F:BLQ]LEDTYP=[L]LEDTYP & [F:BLQ]CPY=SOCIETE & [F:BLQ]FCY=SITBAL & [F:BLQ]FIY=EXERCICE & [F:BLQ]ACC=COMPTE & [F:BLQ]BPR=TIERS & [F:BLQ]CUR=DEVBAL
  For P=1 To MAXPER-1
   BALQTYE(P)     += [F:BLQ]QTYCMM(P)
   BALQTYP(P)     += [F:BLQ]QTYPRP(P)
  Next P
 Next

 For P=1 To MAXPER-1
  If BALQTYE(P)<>GLQTYE(K,P) | BALQTYP(P)<>GLQTYP(K,P)
   Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
   Call ECR_TRACE(mess(58,116,1)-DEVBAL-SITBAL-COMPTE-TIERS,POIERR) From GESECRAN            #  Erreur
   Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                       #  Période
   Call ECR_TRACE(format$("K:30X",mess(60,116,1))
&                +format$("N:"+FMQTE,BALQTYE(P))+" "+[F:GAC]UOM+"   "
&                +format$("N:"+FMQTE,BALQTYP(P))+" "+[F:GAC]UOM,0) From GESECRAN    #  Balance
   Call ECR_TRACE(format$("K:30X",mess(61,116,1))
&                +format$("N:"+FMQTE,GLQTYE(K,P))+" "+[F:GAC]UOM+"   "
&                +format$("N:"+FMQTE,GLQTYP(K,P))+" "+[F:GAC]UOM,0) From GESECRAN       #  Grand Livre
   ANOM += 1
  Endif
 Next P
Next K
Return

$VER_CMM_BPR_SOC
If TIERS="" & [F:GAC]SAC=2 : Return : Endif
If TEST : Call ECR_TRACE(time$-"VER_BPR_SOC"-COMPTE-TIERS,0) From GESECRAN : Endif
For K=1 To NBCUR
 DEVBAL = TBCUR(K)
 POIERR = 1  :# bug 7889 : controle bloquant en devise société
# If DEVBAL<>[F:GCM]CUR(LEDTYP-1) : POIERR=0 : Endif
 Raz BALQTYE, BALQTYP
 For [BLQ]BLQ0 Where [F:BLQ]LEDTYP=[L]LEDTYP & [F:BLQ]CPY=SOCIETE & [F:BLQ]FCY="" & [F:BLQ]FIY=EXERCICE & [F:BLQ]ACC=COMPTE & [F:BLQ]BPR=TIERS & [F:BLQ]CUR=DEVBAL
  For P=1 To MAXPER-1
   BALQTYE(P)     += [F:BLQ]QTYCMM(P)
   BALQTYP(P)     += [F:BLQ]QTYPRP(P)
  Next P
 Next

 For P=1 To MAXPER-1
  If BALQTYE(P)<>SOCQTYE(K,P) | BALQTYP(P)<>SOCQTYP(K,P)
   Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
   Call ECR_TRACE(mess(58,116,1)-DEVBAL-SOCIETE-COMPTE-TIERS,POIERR) From GESECRAN            #  Erreur
   Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                        #  Période
   Call ECR_TRACE(format$("K:30X",mess(60,116,1))
&                +format$("N:"+FMQTE,BALQTYE(P))+" "+[F:GAC]UOM+"   "
&                +format$("N:"+FMQTE,BALQTYP(P))+" "+[F:GAC]UOM,0) From GESECRAN         #  Balance
   Call ECR_TRACE(format$("K:30X",mess(61,116,1))
&                +format$("N:"+FMQTE,SOCQTYE(K,P))+" "+[F:GAC]UOM+"   "
&                +format$("N:"+FMQTE,SOCQTYP(K,P))+" "+[F:GAC]UOM,0) From GESECRAN       #  Grand Livre
   ANOM += 1
  Endif
 Next P
Next K
Return


$VER_CMM_CPT
If TEST : Call ECR_TRACE(time$-"VER_CPT"-COMPTE,0) From GESECRAN : Endif
For K=1 To NBCUR
 DEVBAL = TBCUR(K)
 POIERR = 1  :# bug 7889 : controle bloquant en devise société
# If DEVBAL<>[F:GCM]CUR(LEDTYP-1) : POIERR=0 : Endif

 Raz SOCQTYE, SOCQTYP
 For J=1 To NBSIT
  SITBAL = TBSIT(J)
  Raz BALQTYE, BALQTYP
  For [BLQ]BLQ0 Where [F:BLQ]LEDTYP=[L]LEDTYP & [F:BLQ]CPY=SOCIETE & [F:BLQ]FCY=SITBAL & [F:BLQ]FIY=EXERCICE & [F:BLQ]ACC=COMPTE & [F:BLQ]BPR="" & [F:BLQ]CUR=DEVBAL
   For P=1 To MAXPER-1
    BALQTYE(P)     += [F:BLQ]QTYCMM(P)
    BALQTYP(P)     += [F:BLQ]QTYPRP(P)
   Next P
  Next
  For P=1 To MAXPER-1
   SOCQTYE(K,P)    += SITQTYE(J,K,P)
   SOCQTYP(K,P)    += SITQTYP(J,K,P)
   If BALQTYE(P)<>SITQTYE(J,K,P) | BALQTYP(P)<>SITQTYP(J,K,P)
    Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
    Call ECR_TRACE(mess(58,116,1)-DEVBAL-SITBAL-COMPTE-TIERS,POIERR) From GESECRAN            #  Erreur
    Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                 -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                        #  Période

    Call ECR_TRACE(format$("K:30X",mess(60,116,1))
&                 +format$("N:"+FMQTE,BALQTYE(P))+" "+[F:GAC]UOM+"   "
&                 +format$("N:"+FMQTE,BALQTYP(P))+" "+[F:GAC]UOM,0) From GESECRAN    #  Balance
    Call ECR_TRACE(format$("K:30X",mess(61,116,1))
&                 +format$("N:"+FMQTE,SITQTYE(J,K,P))+" "+[F:GAC]UOM+"   "
&                 +format$("N:"+FMQTE,SITQTYP(J,K,P))+" "+[F:GAC]UOM,0) From GESECRAN       #  Grand Livre
    ANOM += 1
   Endif
  Next P
 Next J

 If TOUSITE=2   :# 17783
  Raz BALQTYE, BALQTYP
  For [BLQ]BLQ0 Where [F:BLQ]LEDTYP=[L]LEDTYP & [F:BLQ]CPY=SOCIETE & [F:BLQ]FCY="" & [F:BLQ]FIY=EXERCICE & [F:BLQ]ACC=COMPTE & [F:BLQ]BPR="" & [F:BLQ]CUR=DEVBAL
   For P=1 To MAXPER-1
    BALQTYE(P)     += [F:BLQ]QTYCMM(P)
    BALQTYP(P)     += [F:BLQ]QTYPRP(P)
   Next P
  Next

  For P=1 To MAXPER-1
   If BALQTYE(P)<>SOCQTYE(K,P) | BALQTYP(P)<>SOCQTYP(K,P)
    Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
    Call ECR_TRACE(mess(58,116,1)-DEVBAL-SOCIETE-COMPTE-TIERS,POIERR) From GESECRAN            #  Erreur
    Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                 -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                        #  Période

    Call ECR_TRACE(format$("K:30X",mess(60,116,1))
&                 +format$("N:"+FMQTE,BALQTYE(P))+" "+[F:GAC]UOM+"   "
&                 +format$("N:"+FMQTE,BALQTYP(P))+" "+[F:GAC]UOM,0) From GESECRAN         #  Balance
    Call ECR_TRACE(format$("K:30X",mess(61,116,1))
&                 +format$("N:"+FMQTE,SOCQTYE(K,P))+" "+[F:GAC]UOM+"   "
&                 +format$("N:"+FMQTE,SOCQTYP(K,P))+" "+[F:GAC]UOM,0) From GESECRAN       #  Grand Livre
    ANOM += 1
   Endif
  Next P
 Endif
Next K
Return


#########################################################################################################
## Vérification de la balance
#########################################################################################################
$TSTDAA

NBCUR = 0
NBSIT = 0

#-- Link GACCOUNT & GACCENTRYD & GACCENTRY
Link [DAA] With [GAC]GAC0~=[F:DAA]COA;[F:DAA]ACC, [HAE]HAE0~=[F:DAA]TYP;[F:DAA]NUM,
&               [DAE]DAE0~=[F:DAA]TYP;[F:DAA]NUM;[F:DAA]LIN;[F:DAA]LEDTYP
& As [LNK]
& Where evalue(FILTECT)
& Order By Key CLE = [F:DAA]ACC;[F:DAA]BPR;[F:DAA]FCYLIN;[F:DAA]ACCDAT;[F:DAA]ACCNUM

Filter [BLQ]

Gosub SET_FIRST From TRTFIRST

For [LNK]CLE(1)   : # Compte
 COMPTE = [F:DAA]ACC
 Raz SITQTY
 Call LEC_TUN([F:GAC]UOM) From CPTLEC
 If [F:TUN]UOMDEC=0
  FMQTE = "15.5#"
 Else
  FMQTE = num$(14-[F:TUN]UOMDEC)+"."+num$([F:TUN]UOMDEC)+"#"
 Endif

 For [LNK]CLE(2)  : # Tiers
  TIERS = [F:DAA]BPR
  Raz SOCQTY
  For [LNK]CLE(3) : # Site
   Raz GLQTY
   SITBAL = [F:DAA]FCYLIN
   For [LNK]CLE   : # Détail
    If [F:HAE]CAT<>3 & [F:HAE]CAT<>5
     K = find([F:DAA]CUR,TBCUR(1..NBCUR))
     If !K
      NBCUR += 1 : K = NBCUR
      TBCUR(NBCUR) = [F:DAA]CUR
     Endif
     If [F:DAA]SNS>0
      GLQTY(K,[F:DAE]PER)    += [F:DAA]QTY
     Else
      GLQTY(K,[F:DAE]PER)    -= [F:DAA]QTY
     Endif
    Endif
   Next
   # Vérif pour 1 compte  1 tiers et 1 site
   Gosub VER_DAA_BPR_SIT
   For P=0 To MAXPER-1
    For K=1 To NBCUR
     SOCQTY(K,P)    += GLQTY(K,P)
    Next K
   Next P
   J = find(SITBAL,TBSIT(1..NBSIT))
   If !J
    NBSIT += 1 : J = NBSIT
    TBSIT(NBSIT) = SITBAL
   Endif
   For P=0 To MAXPER-1
    For K=1 To NBCUR
     SITQTY(J,K,P)    += GLQTY(K,P)
    Next K
   Next P
  Next
  # Vérif pour 1 compte  1 tiers et société
  If TOUSITE=2 : Gosub VER_DAA_BPR_SOC : Endif
 Next
 # Vérif pour 1 compte collectif, société et site
 If [F:GAC]SAC=2
  Gosub VER_DAA_CPT
 Endif
Next
Gosub UNSET_FIRST From TRTFIRST
Filter [DAA]
Return

###############################################
## Sous-programmes d'erreurs
###############################################
$VER_DAA_BPR_SIT
If TIERS="" & [F:GAC]SAC=2 : Return : Endif
If TEST : Call ECR_TRACE(time$-"VER_BPR_SIT"-SITBAL-COMPTE-TIERS,0) From GESECRAN : Endif
For K=1 To NBCUR
 DEVBAL = TBCUR(K)
 POIERR = 1  :# bug 7889 : controle bloquant en devise société
 # If DEVBAL<>[F:GCM]CUR(LEDTYP-1) : POIERR=0 : Endif

 Raz BALQTY
 For [BLQ]BLQ0 Where [F:BLQ]LEDTYP=[L]LEDTYP & [F:BLQ]CPY=SOCIETE & [F:BLQ]FCY=SITBAL & [F:BLQ]FIY=EXERCICE & [F:BLQ]ACC=COMPTE & [F:BLQ]BPR=TIERS & [F:BLQ]CUR=DEVBAL
  For P=1 To MAXPER-1
   BALQTY(P)     += [F:BLQ]QTY(P)
  Next P
 Next

 For P=1 To MAXPER-1
  If BALQTY(P)<>GLQTY(K,P)
   Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
   Call ECR_TRACE(mess(58,116,1)-DEVBAL-SITBAL-COMPTE-TIERS,POIERR) From GESECRAN            #  Erreur
   Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                       #  Période
   Call ECR_TRACE(format$("K:30X",mess(60,116,1))
&                +format$("N:"+FMQTE,BALQTY(P))+" "+[F:GAC]UOM,0) From GESECRAN    #  Balance
   Call ECR_TRACE(format$("K:30X",mess(61,116,1))
&                +format$("N:"+FMQTE,GLQTY(K,P))+" "+[F:GAC]UOM,0) From GESECRAN       #  Grand Livre
   ANOM += 1
  Endif
 Next P
Next K
Return

$VER_DAA_BPR_SOC
If TIERS="" & [F:GAC]SAC=2 : Return : Endif
If TEST : Call ECR_TRACE(time$-"VER_BPR_SOC"-COMPTE-TIERS,0) From GESECRAN : Endif
For K=1 To NBCUR
 DEVBAL = TBCUR(K)
 POIERR = 1  :# bug 7889 : controle bloquant en devise société
# If DEVBAL<>[F:GCM]CUR(LEDTYP-1) : POIERR=0 : Endif
 Raz BALQTY
 For [BLQ]BLQ0 Where [F:BLQ]LEDTYP=[L]LEDTYP & [F:BLQ]CPY=SOCIETE & [F:BLQ]FCY="" & [F:BLQ]FIY=EXERCICE & [F:BLQ]ACC=COMPTE & [F:BLQ]BPR=TIERS & [F:BLQ]CUR=DEVBAL
  For P=1 To MAXPER-1
   BALQTY(P)     += [F:BLQ]QTY(P)
  Next P
 Next

 For P=1 To MAXPER-1
  If BALQTY(P)<>SOCQTY(K,P)
   Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
   Call ECR_TRACE(mess(58,116,1)-DEVBAL-SOCIETE-COMPTE-TIERS,POIERR) From GESECRAN            #  Erreur
   Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                        #  Période
   Call ECR_TRACE(format$("K:30X",mess(60,116,1))
&                +format$("N:"+FMQTE,BALQTY(P))+" "+[F:GAC]UOM,0) From GESECRAN         #  Balance
   Call ECR_TRACE(format$("K:30X",mess(61,116,1))
&                +format$("N:"+FMQTE,SOCQTY(K,P))+" "+[F:GAC]UOM,0) From GESECRAN       #  Grand Livre
   ANOM += 1
  Endif
 Next P
Next K
Return


$VER_DAA_CPT
If TEST : Call ECR_TRACE(time$-"VER_CPT"-COMPTE,0) From GESECRAN : Endif
For K=1 To NBCUR
 DEVBAL = TBCUR(K)
 POIERR = 1  :# bug 7889 : controle bloquant en devise société
# If DEVBAL<>[F:GCM]CUR(LEDTYP-1) : POIERR=0 : Endif

 Raz SOCQTYE, SOCQTYP
 For J=1 To NBSIT
  SITBAL = TBSIT(J)
  Raz BALQTY
  For [BLQ]BLQ0 Where [F:BLQ]LEDTYP=[L]LEDTYP & [F:BLQ]CPY=SOCIETE & [F:BLQ]FCY=SITBAL & [F:BLQ]FIY=EXERCICE & [F:BLQ]ACC=COMPTE & [F:BLQ]BPR="" & [F:BLQ]CUR=DEVBAL
   For P=1 To MAXPER-1
    BALQTY(P)     += [F:BLQ]QTY(P)
   Next P
  Next
  For P=1 To MAXPER-1
   SOCQTY(K,P) += SITQTY(J,K,P)
   If BALQTY(P)<>SITQTY(J,K,P)
    Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
    Call ECR_TRACE(mess(58,116,1)-DEVBAL-SITBAL-COMPTE-TIERS,POIERR) From GESECRAN            #  Erreur
    Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                 -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                        #  Période
    Call ECR_TRACE(format$("K:30X",mess(60,116,1))
&                 +format$("N:"+FMQTE,BALQTY(P))+" "+[F:GAC]UOM,0) From GESECRAN    #  Balance
    Call ECR_TRACE(format$("K:30X",mess(61,116,1))
&                 +format$("N:"+FMQTE,SITQTY(J,K,P))+" "+[F:GAC]UOM,0) From GESECRAN       #  Grand Livre
    ANOM += 1
   Endif
  Next P
 Next J
 If TOUSITE=2   :# 17783
  Raz BALQTY
  For [BLQ]BLQ0 Where [F:BLQ]LEDTYP=[L]LEDTYP & [F:BLQ]CPY=SOCIETE & [F:BLQ]FCY="" & [F:BLQ]FIY=EXERCICE & [F:BLQ]ACC=COMPTE & [F:BLQ]BPR="" & [F:BLQ]CUR=DEVBAL
   For P=1 To MAXPER-1
    BALQTY(P)     += [F:BLQ]QTY(P)
   Next P
  Next

  For P=1 To MAXPER-1
   If BALQTY(P)<>SOCQTY(K,P)
    Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
    Call ECR_TRACE(mess(58,116,1)-DEVBAL-SOCIETE-COMPTE-TIERS,POIERR) From GESECRAN            #  Erreur
    Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                 -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                        #  Période
    Call ECR_TRACE(format$("K:30X",mess(60,116,1))
&                 +format$("N:"+FMQTE,BALQTY(P))+" "+[F:GAC]UOM,0) From GESECRAN         #  Balance
    Call ECR_TRACE(format$("K:30X",mess(61,116,1))
&                 +format$("N:"+FMQTE,SOCQTY(K,P))+" "+[F:GAC]UOM,0) From GESECRAN       #  Grand Livre
    ANOM += 1
   Endif
  Next P
 Endif
Next K
Return

#-- Feature 79527 - SP2US26
$VERF_HAT
Raz FILTHAT, IFILH

Call ADDCRIT(FILTHAT,IFILH,"LEDTYP",'[F:DAT]LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTHAT,IFILH,"CPY",'[F:DAT]CPY="'+SOCIETE+'"'," & ") From GOBJSUB
If TOUSITE<>2 & SITE<>""
 Call ADDCRIT(FILTHAT,IFILH,"FCY",'[F:DAT]FCYLIN="'+SITE+'"'," & ") From GOBJSUB
Endif
Call ADDCRIT(FILTHAT,IFILH,"FIY",'FIY='+num$(EXERCICE)," & ") From GOBJSUB
If COMPTE<>""
 Call ADDCRIT(FILTHAT,IFILH,"ACC",'[F:DAT]ACC="'+COMPTE+'"'," & ") From GOBJSUB
Endif
If DEVISE<>""
 Call ADDCRIT(FILTHAT,IFILH,"CUR",'[F:DAT]CUR="'+DEVISE+'"'," & ") From GOBJSUB
Endif


#-- Link GACCOUNT & GACCENTRY
Link [DAT] With [HAT]HAT0~=[F:DAT]TYP;[F:DAT]NUM As [LNK]
&              Where [F:HAT]FLG>=100 & evalue(FILTHAT)
Return


###################################################################################
###################################################################################
###################    Etiquette du masque          ###############################
###################################################################################
###################################################################################
########################################
Subprog AM_SOCIETE(VALEUR)
Variable Char VALEUR
GSOCIETE = VALEUR
Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Filter [FIY] Where CPY=VALEUR & LEDTYP=GTYPANA & FIYSTA=2
Read [FIY]FIY0 First
Filter [FIY]
[M]EXERCICE = [F:FIY]FIYNUM
[M]DATDEB   = [F:FIY]FIYSTR
[M]DATFIN   = [F:FIY]FIYEND
If !GIMPORT
 Affzo EXERCICE, DATDEB, DATFIN
Endif
End

########################################
Subprog AS_TOUSITE(VALEUR)
Variable Integer  VALEUR
Call INIALLFCY(VALEUR,[M]SOCIETE) From CPTTRT
End

Subprog AS_SITE(VALEUR)
Variable Char VALEUR
If [M]TOUSITE = 2 : VALEUR = "" : mkstat = 1 : End : Endif
End


########################################
Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Call LEDTYP_CHOICE([M:DIA]SOCIETE,3) From CPTDIV  # Faudrait prévoir plusieurs options ?
Local Integer NBLED
Raz GMENLOC
Call LEC_CPY([M:DIA]SOCIETE) From CPTLEC
 If !fstat
  Call LEC_GCM([F:CPY]ACM) From CPTLEC
  If !fstat
   For NBLED=1 To len(mess(0,2644,1))
    Call LEC_LED([F:GCM]LED(NBLED-1)) From CPTLEC
    If !fstat
     If [F:LED]ANA<>2 and [F:LED]CMM<>2
      GMENLOC(NBLED)=1
     Endif
    Else
     GMENLOC(NBLED)=1
    Endif
   Next NBLED
  Endif
 Endif
End

End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Char LED(GLONLED),DEV(GLONCUR)
Local Integer ILED
Call LECLED([M:DIA]SOCIETE,VALEUR,LED,DEV) From CPTDIV
ILED = find(LED,GLED(1..GLEDNBR))
If !ILED : End : Endif
[M:DIA]COA = GLEDCOA(ILED)
End

########################################
Subprog AS_EXERCICE(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 Filter [FIY] Where CPY=[M]SOCIETE & LEDTYP=GTYPANA & FIYSTA=2
 Read [FIY]FIY0 First
 Filter [FIY]
 VALEUR = [F:FIY]FIYNUM
 [M]DATDEB = [F:FIY]FIYSTR
 [M]DATFIN = [F:FIY]FIYEND
Endif
End

Subprog C_EXERCICE(VALEUR)
Variable Decimal VALEUR
Read [FIY]FIY0 = [M]SOCIETE;GTYPANA;VALEUR
If fstat
 GMESSAGE = mess(52,116,1) : mkstat = 2 : End    # Exercice incorrect
Endif
If [F:FIY]FIYSTA=1
 GMESSAGE=mess(20,101,1) : mkstat=2 : End : # Exercice non ouvert
Elsif [F:FIY]FIYSTA>2
 Local Integer OK
 OK = 1 : Call AVERTIR(mess(21,101,1),OK) From GESECRAN : # Exercice clôturé
 If OK<>2 : mkstat = 2 : End : Endif
Endif
[M]DATDEB = [F:FIY]FIYSTR
[M]DATFIN = [F:FIY]FIYEND
End

########################################

