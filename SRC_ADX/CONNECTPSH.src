#<AdxTL>@(#)10.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBMMSINT","MMSINT",4,"SPEMMSINT") From GTRAITE
End


######################################################################
# CONNECTPSH : MMS Import des Demandes d'achats                      #
######################################################################
$ACTION
Case ACTION
 When "IMP_ZONE"    : Gosub IMP_ZONE
 When "IMP_TAB"     : Gosub IMP_TAB
Endcase
Return

######################################################################
$IMP_ZONE
$IMP_TAB
If IMPFIC = "PSH" | IMPFIC = "PSD"
    ##If IMPZON <>"ITMREF" & IMPZON <>"PUU"
    If IMPZON <>"PUU"
        IMPMOD=1
    Endif
Endif
Return

######################################################################
Subprog TRAITE(ID,OS,FICCSV,FICCLI,CONPIT,CONREF,REJ,FICREJ,REF,FICREF,ERRG,ERRNOFIC)
Value Char ID(),OS(),FICCSV(),FICCLI(),CONPIT(),CONREF()
Value Integer REJ
Value Char FICREJ()
Value Integer REF
Value Char FICREF()
Variable Integer ERRG,ERRNOFIC

Local Integer ERR : ERR=0
Local Integer NOLIG : NOLIG=0
Local Integer OUVFICREJ: OUVFICREJ=0
Local Integer OUVFICREF: OUVFICREF=0

Local Clbfile LIGCLOB(10)
Local Clbfile LIGENTETE(10)
Local Integer ERRFIC : ERRFIC=0

Local Char WPSHREF(30) : Raz WPSHREF

Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
adxium = GUTF8
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs

If clalev ([F:PSH]) = 0 : Local File PREQUIS  [PSH] : Endif
If clalev ([F:PSD]) = 0 : Local File PREQUISD [PSD] : Endif

Gosub INITPIVOT From CONNECTFCT

If clalev ([F:MMV]) = 0 : Local File MMSDEFVAL [MMV] : Endif
If clalev ([F:MMS]) = 0 : Local File MMSPAR [MMS] : Endif
Read [MMS]MMS0=CONREF
GIMPORT=1

 GCONPSH_NBF+=1
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE("==========================",0) From GESECRAN
 If FICCLI<>""
  GCONPSH_FIC(GCONPSH_NBF)=FICCLI
  Call ECR_TRACE(mess(220,139,1)-"|"+FICCLI,0) From GESECRAN : # Traitement du fichier
 Else
  GCONPSH_FIC(GCONPSH_NBF)=FICCSV
  Call ECR_TRACE(mess(38,115,1)-"|"+FICCSV,0) From GESECRAN : # Lecture du fichier
 Endif

 Gosub OUVFIC
 Onerrgo FIN_ERRGO
 Gosub LIREFIC
 If ERRFIC
    ERRG+=1 : ERRNOFIC+=1
    Call ECR_TRACE(mess(14,7710,1),1) From GESECRAN : # Lecture du fichier impossible
    Goto FIN
 Endif
 While !ERRFIC
     Gosub CHARGEPIVOT From CONNECTFCT
     If !ERR
         If WPSHREF<>"" & WPSHREF<>func CONNECTFCT.GETVAL("PREQUIS","PSHNUMMMS",NBPIVZON,WPIVTABZON,WPIVVAL)
             Gosub VALID_PSH
             If !ERR : WPSHREF=func CONNECTFCT.GETVAL("PREQUIS","PSHNUMMMS",NBPIVZON,WPIVTABZON,WPIVVAL) : Gosub CHARGE_PSH : Endif
         Elsif WPSHREF=""
             WPSHREF=func CONNECTFCT.GETVAL("PREQUIS","PSHNUMMMS",NBPIVZON,WPIVTABZON,WPIVVAL) : Gosub CHARGE_PSH
         Endif
         If !ERR : Gosub CHARGE_PSD : Endif
     Endif
     If ERR & REJ
        ERRG+=1
        # on doit ecrire dans le fichier des rejets
        Gosub ECR_REJ
     Else
        Gosub LIREFIC
     Endif
     ERR=0
 Wend
 If !ERR
     If WPSHREF<>""
         Gosub VALID_PSH
     Endif
 Endif
 If ERR & REJ
    ERRG+=1
    # on doit ecrire dans le fichier des rejets
    Gosub ECR_REJ
 Endif
$FIN
 Onerrgo
 Gosub FERMEFIC
 GIMPORT=0
 adxium = SAVADXIUM
 adxifs = SAVADXIFS
 adxirs = SAVADXIRS
End
############
$FIN_ERRGO
 ERRG+=1 : ERRNOFIC+=1
 Call ECR_TRACE(mess(17,7710,1),1) From GESECRAN : # Erreur sur traitement d'une ligne du fichier
 Goto FIN
############


######################################################################
#Ouverture du fichier CSV
$OUVFIC
 If OS="unix"
    IRS = chr$(10)
 Else
    IRS = chr$(13)+chr$(10)
 Endif

 Openi FICCSV,0 Using [FCSV]
 adxifs=""
 adxirs=IRS
 adxium=GUTF8
 Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs
 Iomode adxifs adxifs Using [FCSV]
 Iomode adxirs adxirs Using [FCSV]
 Iomode adxium adxium Using [FCSV]
 If WPIVHEATYP<>1
    Rdseq LIGCLOB Using [FCSV]
    If fstat=0
        LIGENTETE=LIGCLOB
        Call FILE_UTF8_BOM(LIGENTETE) From CONNECTFCT : # FQ 65094 GA 06/2010
    Endif
 Endif
Return

$LIREFIC
Rdseq LIGCLOB Using [FCSV]
If fstat<>0
    ERRFIC=1
Else
    If NOLIG=0  & WPIVHEATYP=1
       Call FILE_UTF8_BOM(LIGCLOB) From CONNECTFCT : # FQ 65094 GA 06/2010
    Endif
    GCONPSH_ENR+=1
    NOLIG+=1
Endif
Return

$FERMEFIC
 Openi Using [FCSV]
 Openo Using [FREJ]
Return

######################################################################
#Ouverture du fichier REJ
$OUVFICREJ
 If OS="unix"
    IRS = chr$(10)
 Else
    IRS = chr$(13)+chr$(10)
 Endif

 Openo FICREJ,0 Using [FREJ]
 adxifs=""
 adxirs=IRS
 adxium=GUTF8
 Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs
 Iomode adxifs adxifs Using [FREJ]
 Iomode adxirs adxirs Using [FREJ]
 Iomode adxium adxium Using [FREJ]
 OUVFICREJ=1
 If WPIVHEATYP<>1
    Wrseq LIGENTETE Using [FREJ]
 Endif
Return

$ECR_REJ
If !OUVFICREJ
    Gosub OUVFICREJ
Endif
If OS="unix"
    IRS = chr$(10)
Else
    IRS = chr$(13)+chr$(10)
Endif
Openi FICCSV,0 Using [FREF]
adxifs=""
adxirs=IRS
adxium=GUTF8
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs
Iomode adxifs adxifs Using [FREF]
Iomode adxirs adxirs Using [FREF]
Iomode adxium adxium Using [FREF]

Rdseq LIGCLOB Using [FREF]
While !fstat
    If pat(LIGCLOB,WPSHREF+";*")
        Wrseq LIGCLOB Using [FREJ]
    Endif
    Rdseq LIGCLOB Using [FREF]
Wend
Openi Using [FREF]
GCONPSH_REJ+=1

If !ERRFIC
# on se positionne sur la demande suivante
Gosub LIREFIC
While !ERRFIC & pat(LIGCLOB,WPSHREF+";*")
    Gosub LIREFIC
Wend
Endif

Raz WPSHREF
Return

######################################################################
#Ouverture du fichier REF
$OUVFICREF
 If OS="unix"
    IRS = chr$(10)
 Else
    IRS = chr$(13)+chr$(10)
 Endif

 Openo FICREF,0 Using [FREF]
 adxifs=""
 adxirs=IRS
 adxium=GUTF8
 Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs
 Iomode adxifs adxifs Using [FREF]
 Iomode adxirs adxirs Using [FREF]
 Iomode adxium adxium Using [FREF]
 OUVFICREF=1
 If WPIVHEATYP<>1
    Wrseq "PSHNUMMMS;PSHNUM" Using [FREF]
 Endif
Return

$ECR_REF
If REF
    If !OUVFICREF
        Gosub OUVFICREF
    Endif
    Wrseq [F:PSH]PSHNUMMMS+";"+[F:PSH]PSHNUM Using [FREF]
Endif
Return
######################################################################
$INIVARNB
Global Integer GCONPSH_NBF : GCONPSH_NBF = 0 : #nombre de fichiers
Global Char    GCONPSH_FIC(GDIMFIC)(1..1000) : Raz GCONPSH_FIC
Global Integer GCONPSH_ENR : GCONPSH_ENR = 0 : #enreg lus
Global Integer GCONPSH_LUS : GCONPSH_LUS = 0 : #elements maitre lus
Global Integer GCONPSH_NEW : GCONPSH_NEW = 0 : #enreg importés/nouveaux
Global Integer GCONPSH_MAJ : GCONPSH_MAJ = 0 : #enreg importés/maj
Global Integer GCONPSH_REJ : GCONPSH_REJ = 0 : #enreg rejetés
Return

$SUPVARNB
  # Désallocation des variables globales
  If dim(GCONPSH_NBF)>0 Then Kill GCONPSH_NBF Endif
  If dim(GCONPSH_FIC)>0 Then Kill GCONPSH_FIC Endif
  If dim(GCONPSH_ENR)>0 Then Kill GCONPSH_ENR Endif
  If dim(GCONPSH_LUS)>0 Then Kill GCONPSH_LUS Endif
  If dim(GCONPSH_NEW)>0 Then Kill GCONPSH_NEW Endif
  If dim(GCONPSH_MAJ)>0 Then Kill GCONPSH_MAJ Endif
  If dim(GCONPSH_REJ)>0 Then Kill GCONPSH_REJ Endif
Return
######################################################################

$VALID_PSH
Onerrgo FIN_ERRGO_PSH
Local Integer OK
OK=1

Gosub SETCLE : #pour avoir les zones cle renseignees
nolign = 1
For MA=0 To NBMASK
  TRTMSK="W0"+NOMMSK(MA)
  ##Infbox num$(MA)-TRTMSK
  If AMA(MA)
    Gosub SETMASK From =WINPROG
    mkstat=0
    GNBAFF=0
    #Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
    If ABMSK(MA)="PSH1"
        For NOLIG=1 To [M:PSH1]NBLIG
            nolign=NOLIG
            indice=nolign-1
            Call SAI_NBLIG("PSD","IMP_TAB","CONNECTPSH") From =TRTMSK
        Next NOLIG
        nolign = 1
        indice=0
    Else
        Call SAIMSK("PSH","IMP_ZONE","CONNECTPSH") From =TRTMSK
    Endif
    If mkstat
        GREP = "" : REP="" : OK=0
        Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPSH-GMESSIMP,1) From GESECRAN : # erreur
    Endif
    Setmode
  Endif
Next MA

If !OK : Goto FIN_PSH_VERROU : Endif

Gosub VALID
If !OK : Goto FIN_PSH_VERROU : Endif
Gosub DEVERROU

Goto FIN_PSH

###########################################################
$CHARGE_PSD
Onerrgo FIN_ERRGO_PSH
Local Integer OK
OK=1


Local Char WPSDREF(30)
WPSDREF=func CONNECTFCT.GETVAL("PREQUISD","PSDNUMMMS",NBPIVZON,WPIVTABZON,WPIVVAL)
If WPSDREF=""
    Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-mess(9,7710,1),1) From GESECRAN : # Ligne x Référence non renseignée
    Goto FIN_PSH_VERROU
Endif

#on affecte les valeurs du mask
[M:PSH1]NBLIG+=1
NOPSD=[M:PSH1]NBLIG
nolign=NOPSD
If find("PREQUISD"+"/"+"ITMREF",WPIVTABZON(1..NBPIVZON))>0
 [M:PSH1]ITMREF(nolign-1)=func CONNECTFCT.GETVAL("PREQUISD","ITMREF",NBPIVZON,WPIVTABZON,WPIVVAL)
Endif
If [M:PSH1]PRHFCY (nolign-1)=""
   [M:PSH1]PRHFCY (nolign-1) = [M:PSH0]PSHFCY
Endif

mkstat=0
Call CONTROLE("ITM","AB",[M:PSH1]ITMREF(nolign-1),"",mkstat) From CONTOBJ
If mkstat
    GREP = "" : REP="" : OK=0
    Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPSH-GMESSAGE,1) From GESECRAN : # erreur
Endif

mkstat=0
Call C_ITMREF([M:PSH1]ITMREF(nolign-1)) From =PROGSUB
If mkstat
    GREP = "" : REP="" : OK=0
    Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPSH-GMESSAGE,1) From GESECRAN : # erreur
Endif
If !OK : Goto FIN_PSH_VERROU : Endif

Call AM_ITMREF([M:PSH1]ITMREF(nolign-1)) From =PROGSUB
If mkstat
    GREP = "" : REP="" : OK=0
    Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPSH-GMESSAGE,1) From GESECRAN : # erreur
Endif
If !OK : Goto FIN_PSH_VERROU : Endif

# Issue 117031 - 2016-06-08 by RBA
nolign=NOPSD
Gosub VALDEFMSKPSD
nolign=NOPSD
For NOPIV=1 To NBPIVZON
    nolign=NOPSD
    If pat(WPIVTABZON(NOPIV),"PREQUISD/WSEC") #find("PREQUISD"+"/"+"WSEC",WPIVTABZON(1..NBPIVZON))>0
        If pat(GVERSION,"1.5.*")
           J=[F:MMS]AXI : #CHECK IGNORE_LINE
        Else
           J=find([F:MMS]DIEIMP,GDIE(1..GNBDIE))
        Endif
        If J
           Call ASSIGNVAL(CONPIT,WPIVTABZON(NOPIV),"[M:PSH1]CCE"+num$(J)+"(nolign-1)",WPIVVAL(NOPIV),OK) From CONNECTFCT
        Endif
    Elsif pat(WPIVTABZON(NOPIV),"PREQUISD/*")
        If evalue("dim([M:PSH1]"+WPIVZON(NOPIV)+")")>0 & WPIVVALFIC(NOPIV)<>""
           Call ASSIGNVAL(CONPIT,WPIVTABZON(NOPIV),"[M:PSH1]"+WPIVZON(NOPIV)+"(nolign-1)",WPIVVAL(NOPIV),OK) From CONNECTFCT
        Endif
    Endif
Next
If !OK : Goto FIN_PSH_VERROU : Endif

#nolign=NOPSD
#Gosub VALDEFMSKPSD
#nolign=NOPSD
#For NOPIV=1 To NBPIVZON
#    If pat(WPIVTABZON(NOPIV),"PREQUISD/*")
#        nolign=NOPSD
#        If evalue("dim([M:PSH1]"+WPIVZON(NOPIV)+")")>0 & WPIVVALFIC(NOPIV)<>""
#           Call ASSIGNVAL(CONPIT,WPIVTABZON(NOPIV),"[M:PSH1]"+WPIVZON(NOPIV)+"(nolign-1)",WPIVVAL(NOPIV),OK) From CONNECTFCT
#        Endif
#    Endif
#Next
#If !OK : Goto FIN_PSH_VERROU : Endif
#
##nolign=NOPSD
##If [M:PSH1]LINCLEFLG(nolign-1)=0 : [M:PSH1]LINCLEFLG(nolign-1)=1 : Endif
##If [M:PSH1]LINORDFLG(nolign-1)=0 : [M:PSH1]LINORDFLG(nolign-1)=1 : Endif
#
##on affecte la section analytique
#nolign=NOPSD
#If find("PREQUISD"+"/"+"WSEC",WPIVTABZON(1..NBPIVZON))>0
#    If pat(GVERSION,"1.5.*")
#        J=[F:MMS]AXI : #CHECK IGNORE_LINE
#    Else
#        J=find([F:MMS]DIE,GDIE(1..GNBDIE))
#    Endif
#    If J
#        Assign "[M:PSH1]CCE"+num$(J)+"(nolign-1)" With func CONNECTFCT.GETVAL("PREQUISD","WSEC",NBPIVZON,WPIVTABZON,WPIVVAL)
#    Endif
#Endif
# /Issue 117031 - 2016-06-08 by RBA

nolign=NOPSD
Call APRES_NBLIG From =PROGSUB
If mkstat
    GREP = "" : REP="" : OK=0
    Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPSH-GMESSAGE,1) From GESECRAN : # erreur
Endif
If !OK : Goto FIN_PSH_VERROU : Endif

Goto FIN_PSH

###########################################################
$CHARGE_PSH
GCONPSH_LUS+=1
Onerrgo FIN_ERRGO_PSH
Local Shortint IADIME : IADIME = 30    : # Taille pour le Setmode
Local Integer  INBAFF                  : # Pile/Indice
Local Integer  IAFFCOD(0..IADIME)      : # Code instruction
Local Char     IAFFMASK(GLONABR)(0..IADIME)  : # Abréviation écran
Local Char     IAFFCHP(50)(0..IADIME)        : # Zone écran
Local Integer  IAFFIND(0..IADIME)            : # Indice de la zone
Local Char     IAFFTXT(250)(0..IADIME) : # Texte
Local Integer  IAFFRANG(0..IADIME)     : # Rang
Local Integer  IAFFOPT1(0..IADIME)     : # Option1 Ex: Status, premier rang affzo 10-20
Local Integer  IAFFOPT2(0..IADIME)     : # Option2 Ex: Raccourci clavier, dernier rang affzo 10-20

Local Char    PROGOBJ(GLONADC) , PROGSUB(GLONADC) , PROGSPE(GLONADC) , PROGSPV(GLONADC)
Local Char    PROGIMP(GLONADC) , PROGIMS(GLONADC)
Local Char    OBJLIS(GLONAOB)(1..8)
Local Integer AMA(0..16) , RESTMSK(0..16)
Local Integer CRE, MODI, SUPPR, ISITE
Local Char    ERRMES(50)
Local Integer NRMASK , ILIS , RELIT
Local Integer PSPE, PSUB, PSPV, PSTD
Local Integer PIMP
Local Char    SYMBOLE(35)
Local Char    CLECUR1(GLONID1) , CLECUR2(GLONID2)(0..16), CLE2(GLONID2)(0..16)
Local Char    SCLE2(GLONID2) , COUZON(GLONAVA)
Local Integer TPCLE1 , TPCLE2(0..16)
Local Char    SAVCLE1(GLONID1) , SAVCLE2(GLONID2)
Local Char    FILTRE(240) , FILTSUP(240) , CRITTAB(250)
Local Char    CRITERE(250) , FILROLE(250) , FILSUITE(250)
Local Integer ICRITERE , IFILROLE , IFILSUITE
Local Char    ACTION(20) , CHAINE(20) , REP(1)
Local Char    MESSA(250)
Local Char    IDENT(50), ABREV(GLONAOB), SITCUR(15)
Local Integer MA, CL , CLECUR, AFFICHE, AUTENA, OPTENA, OPTDOC , OKTRT,OK
Local Integer TUNNEL, VERROU
Local Integer NBMEN , NBRMEN , ETAMEN(1..60)
Local Char    CHMEN(30) , BOUT(1)
Local Integer GCONTR : GCONTR=0 : # transaction en cours
Local Char GCLEPSH(max(GLONPSH,30))
Local Char GREPCON : # "C" ou "M"

Local Char WFICPSHNUM(GLONPSH)
Local Char WFICBPSNUM(GLONBPR)
Local Char WFICSTOFCY(GLONFCY)
Local Char WTCLCOD(GLONITG)
Local Integer WGETREF


OK=1
GABREV="PSH"
ABREV="PSH"
ABFIC="PSH"
WINPROG="WGOPSH"
# sr 02.12 Demande 80297
# Issue 81372 - 2012-05-04 by SR
Call ISWINDOWOK (nomap,"OPSH") From INTRUTILB
##  "WOPSH SUBPSH SPEPSH SPVPSH"
Call SETPROG("PSH",PROGOBJ,PROGSUB,PROGSPE,PROGSPV,PSTD,PSUB,PSPE,PSPV) From CONTOBJ
Gosub DEFVAR From =WINPROG

# Issue 79241 - 2012-01-12 by VPO : pb sur action SPE OUVRE
If evalue("clalev([F:"+ABFIC+"])")=0 : Gosub OUVFIC From =PROGOBJ : Endif

Gosub OUVRE_MSK From GOBJET
For MA=0 To NBMASK
    Gosub RAZMASK From =WINPROG
Next MA
Gosub OUVRE From =PROGOBJ

Raz GFLAG
ACTION="DEFTRANS"
Gosub ACTION From =PROGSUB

ACTION="OUVRE"
# Issue 79241 - 2012-01-12 by VPO : pb sur action SPE OUVRE
#Gosub ACTION From =PROGSUB
#Appel des actions OUVRE spécifiques et verticales
Gosub ACTIONG From SUBIMPOBJ

If !OK : Goto FIN_PSH_ERR : Endif

If evalue("clalev([F:"+ABFIC+"])")=0 : Gosub OUVFIC From =PROGOBJ : Endif

Default File [F:PSH]
If [F:PIT]TYP=29 : #MMS demande d'achats
GCLEPSH=func CONNECTFCT.GETVAL("PREQUIS","PSHNUMMMS",NBPIVZON,WPIVTABZON,WPIVVAL)
Else
GCLEPSH=func CONNECTFCT.GETVAL("PREQUIS","PSHNUM",NBPIVZON,WPIVTABZON,WPIVVAL)
Endif
If GCLEPSH=""
    Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-mess(9,7710,1),1) From GESECRAN : # Ligne x Référence non renseignée
    Goto FIN_PSH_ERR
Endif

If !OK : Goto FIN_PSH_ERR : Endif

Raz [F:PSH]
Raz [F:PSD]
GCLE=""
WGETREF=0
Gosub SETCLE : #pour vider les zones
If [F:PIT]TYP=29 : #MMS demande d'achats
    Read [F:PSH]PSH3=GCLEPSH
Else
    Read [F:PSH]PSH0=GCLEPSH
Endif

If fstat
    GREPCON = "C"
    WFICPSHNUM=func CONNECTFCT.GETVAL("PREQUIS","PSHNUM",NBPIVZON,WPIVTABZON,WPIVVAL)
    If WFICPSHNUM<>""
        Read [F:PSH]PSH0=WFICPSHNUM
        If !fstat
            If [F:PSH]PSHNUMMMS<>"" & GCLEPSH<>[F:PSH]PSHNUMMMS
                Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPSH-mess(64,7710,1),1) From GESECRAN : # la demande d'achat ne correspond pas
                Goto FIN_PSH_ERR
            Endif
            GREPCON = "M"
        Endif
    Endif
Else
    GREPCON = "M"
    Gosub SETCLE
    Gosub VERROU
    If !OK : Goto FIN_PSH_ERR : Endif
    Onerrgo FIN_ERRGO_VERROU
Endif

If GREPCON = "C"
 CLECUR = 0
 CHAINE = "C"
 ACTION = "SETBOUT"     : Gosub ACTIONG From SUBIMPOBJ
 If !OK : Goto FIN_PSH_ERR : Endif
 ###ACTION = "IMP_SETBOUT" : Gosub ACTION  From SUBIMPOBJ
 OK=(instr(1,CHAINE,"C")<>0)
 If OK
   GREP = "C" : REP = "C"
   ACTION = "RAZCRE"      : Gosub ACTIONG From SUBIMPOBJ
   ###ACTION = "IMP_RAZCRE"  : Gosub ACTION From SUBIMPOBJ
 Endif
Else
 If [F:PIT]TYP=29 : #MMS demande d'achats
     WFICPSHNUM=func CONNECTFCT.GETVAL("PREQUIS","PSHNUM",NBPIVZON,WPIVTABZON,WPIVVAL)
     If WFICPSHNUM<>"" & WFICPSHNUM<>[F:PSH]PSHNUM
        Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPSH-mess(64,7710,1),1) From GESECRAN : # la demande d'achat ne correspond pas
        Goto FIN_PSH_ERR
     Elsif WFICPSHNUM=""
        Call SETVAL("PREQUIS","PSHNUM",NBPIVZON,WPIVTABZON,WPIVVAL,WPIVVALFIC,[F:PSH]PSHNUM) From CONNECTFCT
     Endif
     Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPSH-mess(68,7710,1),1) From GESECRAN : # La demande d'achat existe déjà et ne peut pas etre modifiée.
     Goto FIN_PSH_ERR
 Endif
 Gosub SETCLE
 Gosub VERROU
 If !OK : Goto FIN_PSH_ERR : Endif
 Onerrgo FIN_ERRGO_VERROU
 nolign = 1
 For IMA=0 To NBMASK
  If AMA(IMA)
   Gosub CHARGEMSK From =WINPROG
  Endif
 Next IMA
 For MA=0 To NBMASK
    Gosub SETMASK From =WINPROG
 Next MA
 ACTION = "LIENS"     : Gosub ACTIONG From SUBIMPOBJ
 ###ACTION = "IMP_LIENS" : Gosub ACTION  From SUBIMPOBJ
 CLECUR = 1
 CHAINE = "M"
 ACTION = "SETBOUT"     : Gosub ACTIONG From SUBIMPOBJ
 ###ACTION = "IMP_SETBOUT" : Gosub ACTION  From SUBIMPOBJ
 If instr(1,CHAINE,"M")
  OK = 1
  ACTION = "AVANT_MOD"     : Gosub ACTIONG From SUBIMPOBJ
  ###ACTION = "IMP_AVANT_MOD" : Gosub ACTION  From SUBIMPOBJ
 Else
  OK = 0
 Endif
 GREP = "M" : REP = "M"
Endif

If !OK | GREP="" : Goto FIN_PSH_VERROU : Endif

#on affecte les valeurs du mask
If GREP="C"
    Gosub VALDEFMSKPSH
Endif
nolign = 1
For MA=0 To NBMASK
     Gosub SETMASK From =WINPROG
     nolign=1
     For NOPIV=1 To NBPIVZON
         If pat(WPIVTABZON(NOPIV),"PREQUIS/*")
             If evalue("dim([M:"+ABMSK(MA)+"]"+WPIVZON(NOPIV)+")")>0 & WPIVVALFIC(NOPIV)<>""
                Call ASSIGNVAL(CONPIT,WPIVTABZON(NOPIV),"[M:"+ABMSK(MA)+"]"+WPIVZON(NOPIV),WPIVVAL(NOPIV),OK) From CONNECTFCT
             Endif
         Endif
     Next
Next MA
#cas particulier


If !OK : Goto FIN_PSH_VERROU : Endif

$FIN_PSH
Return
$FIN_PSH_VERROU
If GCONTR : Rollback : GCONTR=0 : Endif
Gosub DEVERROU
$FIN_PSH_ERR
Call ECR_TRACE(string$(20,"*"),0) From GESECRAN
ERR=1
OK=0
Return

#####FIN onerrgo###########
$FIN_ERRGO_VERROU
Onerrgo
#on est en erreur sur la ligne
Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPSH,1) From GESECRAN : # erreur
If errn
    Call ECR_TRACE(errp+"("+num$(errl)+"):"-errmes$(errn),1) From GESECRAN
Endif
If GCONTR : Rollback : GCONTR=0 : Endif
Gosub DEVERROU
$FIN_ERRGO_PSH
Onerrgo
Call ECR_TRACE(string$(20,"*"),0) From GESECRAN
ERR=1
OK=0
Resume


$VERROU
OK = 1
ACTION = "VERROU"     : Gosub ACTIONG From SUBIMPOBJ
If !OK : Return : Endif
###ACTION = "IMP_VERROU" : Gosub ACTION From SUBIMPOBJ
###If !OK : Return : Endif
OK = 1
SYMBOLE = format$("K:3X",ABFIC)+GCLE
Lock =SYMBOLE With lockwait=0
If fstat
  Call ECR_TRACE(GCLEPSH-mess(61,141,1),1) From GESECRAN : # Fiche en cours de modification
  Call ECR_TRACE(string$(20,"*"),0) From GESECRAN
  OK = 0
Endif
Return

$DEVERROU
ACTION = "DEVERROU"     : Gosub ACTIONG From SUBIMPOBJ
###ACTION = "IMP_DEVERROU" : Gosub ACTION From SUBIMPOBJ
SYMBOLE = format$("K:3X",ABFIC)+GCLE
If SYMBOLE <> ""
    Unlock =SYMBOLE
Endif
SYMBOLE = ""
Return

$SETCLE
CLECUR1 = [F:PSH]PSHNUM
GCLE = [F:PSH]PSHNUM
Return

$VALID
 Gosub DEFAUT From =PROGOBJ
 Raz mkstat
 OK = 1
 Gosub VALIDOBJ
 If !OK
   # ici on sort de subprog VALID avec GMESSAGE=vide, si OK a été razé via $ACTIONG
   # qui a mis le message dans la trace puis l’a razé
   If GMESSAGE="" : GMESSAGE=ACTION : Endif
   Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPSH-GMESSAGE,1) From GESECRAN : # erreur
   GMESSAGE=""
 Elsif GOK>=1
   If GREPCON="C"
        GCONPSH_NEW += 1
        If WGETREF : Gosub ECR_REF : Endif
   Elsif GREPCON="M"
        GCONPSH_MAJ += 1
   Endif
 Endif
 Raz GREP
Return

$VALIDOBJ
If GREP="C"
 ACTION = "VERIF_CRE"     : Gosub ACTIONG From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 ###ACTION = "IMP_VERIF_CRE" : Gosub ACTION  From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 Gosub TR1
 If GOK<1
   Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPSH-mess(100,141,1),1) From GESECRAN : # Erreur création
 Else
  Gosub SETCLE : CLECUR = 1
  ACTION = "APRES_CRE"     : Gosub ACTIONG From SUBIMPOBJ
  ###ACTION = "IMP_APRES_CRE" : Gosub ACTION From SUBIMPOBJ
  ###Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPSH,-1) From GESECRAN
  Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
  Call WORKFLOW(2,ABREV,"C",IDENT) From AWRK
 Endif
Elsif GREP="M"
 ACTION = "VERIF_MOD"     : Gosub ACTIONG From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 ###ACTION = "IMP_VERIF_MOD" : Gosub ACTION From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 Gosub TR2
 If GOK<1
   Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPSH-mess(101,141,1),1) From GESECRAN : # Erreur modification
 Else
  Gosub SETCLE
  ACTION = "APRES_MOD"     : Gosub ACTIONG From SUBIMPOBJ
  ###ACTION = "IMP_APRES_MOD" : Gosub ACTION From SUBIMPOBJ
  ###Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPSH,-1) From GESECRAN
  Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
  Call WORKFLOW(2,ABREV,"M",IDENT) From AWRK
 Endif
Endif
Return

$TR1
GOK = 1
If !GCONTR
Trbegin ADOVAL
Endif
 Gosub DEFAUT From =PROGOBJ
 Raz [F]
 nolign = 1
 Gosub CHARGEFIC From SUBIMPOBJ
 Gosub INICRE From GOBJSUB
 ###Gosub INIEXP From SUBIMPOBJ
 ACTION = "INICRE"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 ###ACTION = "IMP_INICRE" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Write
 If fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK
  Goto AB_TR1
 Endif
 ACTION = "CREATION"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 ###ACTION = "IMP_CREATION" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
GCONTR =0
Return

$AB_TR1
Rollback
GCONTR =0
ACTION = "AB_CREATION"     : Gosub ACTIONG From SUBIMPOBJ
###ACTION = "IMP_AB_CREATION" : Gosub ACTION  From SUBIMPOBJ
Return

$ROLL_TR1
Rollback
GCONTR =0
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$TR2
GOK=1
If !GCONTR
Trbegin ADOVAL
Endif
 Gosub DEFAUT From =PROGOBJ
 nolign = 1
 Gosub CHARGEFIC From SUBIMPOBJ
 Readlock =
 If fstat=1
  GOK=-1 : Call FSTA(ABFIC) From GLOCK : Goto ROLL_TR2
 Elsif fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK : Goto AB_TR2
 Endif
 ACTION = "AVANT_MODFIC"    : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 ###ACTION = "IMP_AVANT_MODFIC" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 nolign = 1
 Gosub CHARGEFIC From SUBIMPOBJ
 Gosub INIMOD From GOBJSUB
 ###Gosub INIEXP From SUBIMPOBJ
 ACTION = "INIMOD"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 ###ACTION = "IMP_INIMOD" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 Rewrite
 If fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK : Goto AB_TR2
 Endif
 ACTION = "MODIF"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 ###ACTION = "IMP_MODIF" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
Commit
GCONTR =0
Return

$AB_TR2
Rollback
GCONTR =0
ACTION = "AB_MODIF"     : Gosub ACTIONG From SUBIMPOBJ
###ACTION = "IMP_AB_MODIF" : Gosub ACTION From SUBIMPOBJ
Return

$ROLL_TR2
Rollback
GCONTR =0
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

#####################################################
$VALDEFMSKPSH
nolign=1
For MA=0 To NBMASK
    Gosub SETMASK From =WINPROG
    For [MMV]MMV0 Where ID=CONREF & CODFIC="PREQUIS"
        If evalue("dim([M:"+ABMSK(MA)+"]"+[F:MMV]CODZONE+")")>0
            TYP = evalue("type([M:"+ABMSK(MA)+"]"+[F:MMV]CODZONE+")")
            Case TYP
            When 1, 2, 4, 5, 6, 7, 9
               Assign "[M:"+ABMSK(MA)+"]"+[F:MMV]CODZONE With val([F:MMV]VALDEF)
            When 3
                Assign "[M:"+ABMSK(MA)+"]"+[F:MMV]CODZONE With [F:MMV]VALDEF
            When Default
               Assign "[M:"+ABMSK(MA)+"]"+[F:MMV]CODZONE With [F:MMV]VALDEF
            Endcase
        Endif
        If evalue("dim([M:"+ABMSK(MA)+"]X"+[F:MMV]CODZONE+")")>0
            TYP = evalue("type([M:"+ABMSK(MA)+"]X"+[F:MMV]CODZONE+")")
            Case TYP
            When 1, 2, 4, 5, 6, 7, 9
               Assign "[M:"+ABMSK(MA)+"]X"+[F:MMV]CODZONE With val([F:MMV]VALDEF)
            When 3
                Assign "[M:"+ABMSK(MA)+"]X"+[F:MMV]CODZONE With [F:MMV]VALDEF
            When Default
               Assign "[M:"+ABMSK(MA)+"]X"+[F:MMV]CODZONE With [F:MMV]VALDEF
            Endcase
        Endif
    Next
Next MA
Return

#####################################################
$VALDEFMSKPSD
For [MMV]MMV0 Where ID=CONREF & CODFIC="PREQUISD"
    If evalue("dim([M:PSH1]"+[F:MMV]CODZONE+")")>0
        TYP = evalue("type([M:PSH1]"+[F:MMV]CODZONE+")")
        Case TYP
        When 1, 2, 4, 5, 6, 7, 9
           Assign "[M:PSH1]"+[F:MMV]CODZONE+"(nolign-1)" With val([F:MMV]VALDEF)
        When 3
            Assign "[M:PSH1]"+[F:MMV]CODZONE+"(nolign-1)" With [F:MMV]VALDEF
        When Default
           Assign "[M:PSH1]"+[F:MMV]CODZONE+"(nolign-1)" With [F:MMV]VALDEF
        Endcase
    Endif
    If evalue("dim([M:PSH1]X"+[F:MMV]CODZONE+")")>0
        TYP = evalue("type([M:PSH1]X"+[F:MMV]CODZONE+")")
        Case TYP
        When 1, 2, 4, 5, 6, 7, 9
           Assign "[M:PSH1]X"+[F:MMV]CODZONE+"(nolign-1)" With val([F:MMV]VALDEF)
        When 3
            Assign "[M:PSH1]X"+[F:MMV]CODZONE+"(nolign-1)" With [F:MMV]VALDEF
        When Default
           Assign "[M:PSH1]X"+[F:MMV]CODZONE+"(nolign-1)" With [F:MMV]VALDEF
        Endcase
    Endif
Next
Return

