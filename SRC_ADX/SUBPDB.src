#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion objet PDB
Call OBJET ("PDB", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"      : Gosub OUVRE
    When "FERME"      : Gosub FERME
    When "SETBOUT"    : Gosub SETBOUT
    When "LIENS"      : Gosub LIENS
    When "RAZCRE"     : Gosub RAZCRE
    When "INICRE"     : Gosub INICRE
    When "VERIF_CRE"  : Gosub VERIF_CRE
    When "VERIF_MOD"  : Gosub VERIF_MOD
    When "VERF_ANU"   : Gosub VERF_ANU
    When "CREATION"   : Gosub CREATION
    When "MODIF"      : Gosub MODIF
    When "APRES_CRE"  : Gosub APRES_CRE
    When "APRES_MOD"  : Gosub APRES_MOD
    When "ANNULE"     : Gosub ANNULE
    When "DEFLIG"     : Gosub DEFLIG
    When "LIENS_LIG"  : Gosub LIENS_LIG
    When "INICRE_LIG" : Gosub INICRE_LIG
    When "INIMOD_LIG" : Gosub INIMOD_LIG
    When "VALLIG"     : Gosub VALLIG
    When "FILTRE"     : Gosub FILTRE
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  Gosub DECLARE From TABLEAUX
Return

##########################################################################################################
$FERME
Return

##########################################################################################################
$SETBOUT
  Call VIREBOUT(CHAINE,"H") From GOBJET    
  #Ajout du bouton supprimer
  If CLECUR and SUPPR Then
    CHAINE += "A"  
  Endif
Return

##########################################################################################################
$VERF_ANU
  Call DEBTRANS From GLOCK
  Trbegin [PDB]
  Delete [PDB] Where [F:PDB]BPR = [M:PDB0]BPR and [F:PDB]ITMREF = [M:PDB0]ITMREF and [F:PDB]PBL = [M:PDB0]PBL
  If fstat Then
    #La suppression de la règle de débit de points a été abandonnée.
    GMESSAGE = mess(134,177,1)
    GERR = 1
    Rollback
    OK = 0
    Return
  Endif
  Delete [PBD] Where [F:PBD]BPR = [M:PDB0]BPR and [F:PBD]ITMREF = [M:PDB0]ITMREF and [F:PBD]PBL = [M:PDB0]PBL
  If fstat Then
    #La suppression de la règle de débit de points a été abandonnée.
    GMESSAGE = mess(134,177,1)
    GERR = 1
    Rollback
    OK = 0
    Return
  Else
    #La règle de débit de points a été supprimée.
    GMESSAGE = mess(135,177,1)
    GERR = 1
    Commit    
  Endif
  Raz [M:PDB0]
  Raz [M:PDB1]
  Affzo [M:PDB0]1-99
  Affzo [M:PDB1]1-99
  OK = 0
Return

##########################################################################################################
$FILTRE
  Default File [PDB]
Return

##########################################################################################################
$RAZCRE
  #---------------------------------------------------#
  #Affichage de la dénomination de la famille de compétence
  #---------------------------------------------------#
  If [M:PDB0]PBL = "" Then
    [M:PDB0]PBLCLA = ""
  Else
    Read [PBL]PBL0=[M:PDB0]PBL
    If fstat Then
      [M:PDB0]PBLCLA = ""
    Else
      # FGR 23/09/2009 : X3SUIVI58024
      #[M:PDB0]PBLCLA = [F:PBL]GRPPBLDES
      Call LECTEXTRA([M:PDB0]PBLCLA,"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
    Endif
  Endif
  [M:PDB0]NULPIO = 1
  Gosub SETGRAY From SUBPDBB
  Affzo [M:PDB0]1-99
Return

##########################################################################################################
$LIENS
  #---------------------------------------------------#
  #Affichage de la dénomination de la famille de compétence
  #---------------------------------------------------#
  If [M:PDB0]PBL = "" Then
    [M:PDB0]PBLCLA = ""
  Else
    Read [PBL]PBL0=[M:PDB0]PBL
    If fstat Then
      [M:PDB0]PBLCLA = ""
    Else
      # FGR 23/09/2009 : X3SUIVI58024
      #[M:PDB0]PBLCLA = [F:PBL]GRPPBLDES
      Call LECTEXTRA([M:PDB0]PBLCLA,"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
    Endif
  Endif
  # Chargement des lignes dans le tableau
  Gosub LIENS From TABLEAUX
  Gosub SETGRAY From SUBPDBB
Return

##########################################################################################################
$INICRE
Return

##########################################################################################################
$VERIF_CRE_MOD
#Vérifie la saisie des débits complémentaires
Local Integer ITERPDB

  For ITERPDB = 0 To [M:PDB1]NBLIG-1
    If [M:PDB1]ITM(ITERPDB) <> "" Then
      If [M:PDB1]NBRPIT(ITERPDB) <= 0 Then
        #La régle de débit complémentaire en ligne XXX est incorrectement renseignée.
        GMESSAGE = mess(167,177,1) - num$(ITERPDB+1) - mess(168,177,1)
        GERR = 1
        OK = 0
        Break
      Endif
      If [M:PDB1]DEBFRY(ITERPDB) <= 0 Then
        #La régle de débit complémentaire en ligne XXX est incorrectement renseignée.
        GMESSAGE = mess(167,177,1) - num$(ITERPDB+1) - mess(168,177,1)
        GERR = 1
        OK = 0
        Break
      Endif
      If [M:PDB1]DEBFRYBAS(ITERPDB) = "" Then
        #La régle de débit complémentaire en ligne XXX est incorrectement renseignée.
        GMESSAGE = mess(167,177,1) - num$(ITERPDB+1) - mess(168,177,1)
        GERR = 1
        OK = 0
        Break
      Endif
    Endif
  Next
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$VERIF_CRE
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$VERIF_MOD
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$CREATION
  # -- Enregistrement des lignes du tableau
  Gosub CREATION From TABLEAUX
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$MODIF
  #-------------------------------------#
  # Modification des lignes             #
  #-------------------------------------#
  Gosub MODIF From TABLEAUX
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$APRES_CRE
  Gosub LIENS From TABLEAUX
  Gosub SETGRAY From SUBPDBB
Return

##########################################################################################################
$APRES_MOD
  Gosub LIENS From TABLEAUX
  Gosub SETGRAY From SUBPDBB
Return

##########################################################################################################
$ANNULE
  Gosub ANNULE From TABLEAUX : # Effacement des lignes
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$DEFLIG
  #----------------------------------#
  # Définition du fichier des lignes #
  #----------------------------------#
  # Critère de lecture      (CRIT)   #
  # Nom du fichier          (FICLIG) #
  # Abréviation du fichier  (ABLIG)  #
  # Zone numéro de ligne    (ZONLIG) #
  #----------------------------------#
  Default Mask [PDB1]
  Default File [PBD]
  CRIT = 'BPR="' + [M:PDB0]BPR + '"' + ' & ITMREF="' + [M:PDB0]ITMREF + '"' + ' & PBL="' + [M:PDB0]PBL + '"'
  FICLIG = "PITDEBD"
  ABLIG = "PBD"
  ZONLIG = "PBDLIN"
Return

##########################################################################################################
$LIENS_LIG
Return

##########################################################################################################
$INICRE_LIG
  [F:PBD]BPR = [M:PDB0]BPR
  [F:PBD]ITMREF = [M:PDB0]ITMREF
  [F:PBD]PBL = [M:PDB0]PBL
Return

##########################################################################################################
$INIMOD_LIG
Return

##########################################################################################################
$VALLIG
Return

##########################################################################################################
Subprog C_PBL(VALEUR)
Variable Char    VALEUR()

  #On vérifie la saisie
  Gosub CTLSHORTCUT From SUBPBLB
  If GERR Then
    End
  Endif
End

##########################################################################################################
Subprog AM_PBL(VALEUR)
Variable Char    VALEUR()

  [M:PDB0]PBL = VALEUR
  #Affichage de la dénomination de la famille de compétence
  If [M:PDB0]PBL = "" Then
    [M:PDB0]PBLCLA = ""
  Else
    Read [PBL]PBL0=[M:PDB0]PBL
    If fstat Then
      [M:PDB0]PBLCLA = ""
    Else
      # FGR 23/09/2009 : X3SUIVI58024
      #[M:PDB0]PBLCLA = [F:PBL]GRPPBLDES
      Call LECTEXTRA([M:PDB0]PBLCLA,"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
    Endif
  Endif
  Affzo [M:PDB0]PBLCLA
End

##########################################################################################################
Subprog AM_ITM(VALEUR)
Variable Char    VALEUR()

  [M:PDB1]NULPIOVAL(nolign-1) = 1
  [M:PDB1]ITM(nolign-1) = VALEUR
  Affzo [M:PDB1]ITM(nolign-1), NULPIOVAL(nolign-1)
End

##########################################################################################################
Subprog C_ITM(VALEUR)
Variable Char    VALEUR()

Local Integer I

  #Vérifie si ce code solution n'a pas déjà été préalablement saisi dans ce tableau
  For I = 0 To dim ([M:PDB1]ITM)-1
    If I <> nolign-1 Then
      If [M:PDB1]ITM(I) = VALEUR and [M:PDB1]ITM(I) <> "" Then
        mkstat = 2
        GMESSAGE = mess(434,196,1) #Cet article a déjà été saisi.
        GERR = 2
        Break
      Endif
    Endif
  Next
End
