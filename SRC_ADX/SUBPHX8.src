######################################################################################
# Gestion du masque PHX8
######################################################################################
Subprog C_QSTNUM(VALEUR)
Variable Char    VALEUR()

Local Integer IRETOUR

  If GPHX8DIRTY <> 0 Then
    IRETOUR = 1
    # Vous n'avez pas enregistré votre saisie. Confirmez-vous ?
    Call OUINON (mess(611,177,1), IRETOUR) From GESECRAN
    If IRETOUR = 1 Then
      mkstat = 2
      VALEUR = [M:PHX8]QSTNUM
      Affzo [M:PHX8]QSTNUM
      End
    Else
      If VALEUR = [M:PHX8]QSTNUM Then
        # si on a ressaisi la même valeur c'est qu'on veut relire la même question
        # FLORENT ICI : voir aussi avec le bouton ABANDON si c'est pas mieux
      Endif
    Endif
  Endif
End

######################################################################################
Subprog AM_QSTNUM(VALEUR)
Variable Char    VALEUR()

Local Integer ISOK
Local Char SZNEWQST

  # Pour mémoire : on peut rappeler la même question :
  #                => si on n'a pas enregistré, les modifications sont perdues
  #                   on revient à la situation précédente
  # ON EST OBLIGE DE SAUVER QUESTION PAR QUESTION
  SZNEWQST = ""
  ISOK = 0
  #Vérifie si le numéro de question n'existe pas.
  Read [SCQ]SCQ0=[M:PHX8]SCPNUM;VALEUR
  If fstat Then
    Call RAZPHX8ZO From TRTPHX8
    #Recherche s'il existe déjà une question de départ
    [M:PHX8]STRQST = 2
    Filter [SCQ] Where [F:SCQ]SCPNUM=[M:PHX8]SCPNUM
    For [SCQ]
      If [F:SCQ]STRQST = 2 Then
        [M:PHX8]STRQST = 1
        Break
      Endif
    Next
    Filter [SCQ]
    #Affecte les informations de stockage par défaut. 
    [M:PHX8]ASWTAB = 1
    [M:PHX8]ASWKEY = "CLLCMP"
    GICANNEW = 0
    GICANSAV = 1
  Else
    Call LOADQST(VALEUR, 0, SZNEWQST, ISOK) From TRTPHX8
  Endif
  [M:PHX8]QSTNUM = VALEUR
  Affzo [M:PHX8]1-99
  #
  GPHX8DIRTY = 0
End

######################################################################################
Subprog AS_NBCND
Local Integer NUMLIG

  NUMLIG = nolign - 1
  Call AFFICHE_CONDITION(NUMLIG) From TRTPHX8
End

######################################################################################
Subprog AS_CND(VALEUR)
Variable Integer VALEUR

  [M:PHX8]NOLCND = nolign-1
  If [M:PHX8]QSTTYP = 1 Then
    # Alphanumérique
    GMENLOC(6) = 1
    GMENLOC(7) = 1
    GMENLOC(8) = 1
    GMENLOC(9) = 1
    GMENLOC(10) = 1
    GMENLOC(11) = 1
    GMENLOC(12) = 1
    GMENLOC(13) = 1
    GMENLOC(14) = 1
  Elsif [M:PHX8]QSTTYP = 2 Then
    # Numérique
    GMENLOC(3) = 1
    GMENLOC(4) = 1
    GMENLOC(5) = 1
    GMENLOC(11) = 1
    GMENLOC(12) = 1
    GMENLOC(13) = 1
    GMENLOC(14) = 1
  Elsif [M:PHX8]QSTTYP = 3 Then
    # Date
    GMENLOC(3) = 1
    GMENLOC(4) = 1
    GMENLOC(5) = 1
    GMENLOC(6) = 1
    GMENLOC(7) = 1
    GMENLOC(8) = 1
    GMENLOC(9) = 1
    GMENLOC(11) = 1
    GMENLOC(12) = 1
  Elsif [M:PHX8]QSTTYP = 4 Then
    # Booléen
    GMENLOC(3) = 1
    GMENLOC(4) = 1
    GMENLOC(5) = 1
    GMENLOC(6) = 1
    GMENLOC(7) = 1
    GMENLOC(8) = 1
    GMENLOC(9) = 1
    GMENLOC(10) = 1
    GMENLOC(13) = 1
    GMENLOC(14) = 1
  Endif
End

######################################################################################
Subprog AM_CND(VALEUR)
Variable Integer VALEUR

  GPHX8DIRTY = 1
  Call ACCES_CONDITIONS([M:PHX8]NOLCND) From TRTPHX8
End

######################################################################################
Subprog AM_NEXQST(VALEUR)
Variable Char    VALEUR()

  GPHX8DIRTY = 1
End

######################################################################################
Subprog AM_ASWTAB(VALEUR)
Variable Integer VALEUR

  Raz [M:PHX8]ASWKEY
  Raz [M:PHX8]ASWFIE
  Case VALEUR
    When 1
      [M:PHX8]ASWKEY = "CLLCMP"
    When 2
      [M:PHX8]ASWKEY = "CLLCMP"
    When 3
      [M:PHX8]ASWKEY = "CLLCCN"
    When Default
  Endcase
  [M:PHX8]ASWTAB = VALEUR
  #
  Affzo [M:PHX8]ASWTAB
  Affzo [M:PHX8]ASWFIE
  Affzo [M:PHX8]ASWKEY
  #
  Call LOAD_ADI_M From TRTPHX8
End

######################################################################################
Subprog C_ASWFIE(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    If [M:PHX8]ASWTAB = 1 Then
      Read [ATZ]CODZONE="BPARTNER";VALEUR
      If fstat Then
        mkstat = 2
        GMESSAGE = mess(501, 196, 1) #Ce champs n'est pas défini dans la table sélectionnée. Saisie refusée.
        GERR = 3
      Endif
    Elsif [M:PHX8]ASWTAB = 2 Then
      Read [ATZ]CODZONE="BPCUSTOMER";VALEUR
      If fstat Then
        mkstat = 2
        GMESSAGE = mess(501, 196, 1) #Ce champs n'est pas défini dans la table sélectionnée. Saisie refusée.
        GERR = 3
      Endif
    Elsif [M:PHX8]ASWTAB = 3 Then
      Read [ATZ]CODZONE="CONTACTCRM";VALEUR
      If fstat Then
        mkstat = 2
        GMESSAGE = mess(501, 196, 1) #Ce champs n'est pas défini dans la table sélectionnée. Saisie refusée.
        GERR = 3
      Endif
    Endif
  Endif
End

######################################################################################
Subprog AM_ASWFIE(VALEUR)
Variable Char    VALEUR()

  [M:PHX8]ASWFIE = VALEUR
  Affzo [M:PHX8]ASWFIE
  Call LOAD_ADI_M From TRTPHX8
End

######################################################################################
Subprog IB_ALHCND

  If [M:PHX8]CNDTYP = "" Then
    Raz GBOUT1
  Else
    GBOUT1 = mess(375,196,1) #Réponses possibles
  Endif
End

######################################################################################
Subprog C_ALHCND(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    mkstat = 2
    End
  Endif
End

######################################################################################
Subprog AM_ALHCND(VALEUR)
Variable Char    VALEUR()

Local Char SZVALEUR
Local Char SZLIB

  GPHX8DIRTY = 1
  SZLIB = ""
  SZVALEUR = VALEUR
  If [M:PHX8]MUSTCONV = 1 Then
    If [M:PHX8]CNDTYP = "ADI" Then
      [M:PHX8]ALHCNDBAS(nolign-1) = VALEUR
      Call GET_LIB([M:PHX8]ICNDTYP, SZVALEUR, SZLIB) From CRM_UTIL
      VALEUR = SZLIB
    Elsif [M:PHX8]CNDTYP = "M" Then
      [M:PHX8]ALHCNDBAS(nolign-1) = VALEUR
      SZLIB = VALEUR
      VALEUR = mess(val(SZLIB),[M:PHX8]ICNDTYP,1)
    Endif
  Endif
  [M:PHX8]MUSTCONV = 0
  [M:PHX8]ALHCND(nolign-1) = VALEUR
  Affzo [M:PHX8]ALHCND(nolign-1)
End

######################################################################################
Subprog APRES_NBCNA
Local Integer NLIGNE

  # FGR 16/06/2009 : X3SUIVI55329
  NLIGNE = nolign
  Call COPY_TB_ALHCND From TRTPHX8
  nolign = NLIGNE
End

