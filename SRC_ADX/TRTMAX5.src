#<AdxTL>@(#)1.0.0.0 $Revision$
################################################################################################################
# Etape 5 de la définition d'un mailing                                   Module CRM           5 décembre 2000 #
################################################################################################################
# Saisie du texte E-Mail.
################################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

################################################################################################################
$OUVRE
Return

################################################################################################################
$DEFBOUT
Return

################################################################################################################
$SETBOUT
  If [M:MAX5]EMAOBC <> "" Then
    ETABOU(GVALI) = 1
  Else
    ETABOU(GVALI) = 0
  Endif
Return

################################################################################################################
$OUVRE_BOITE
Return

################################################################################################################
$DEBUT
  Read [OMM]OMM0=GSZOPGNUM
  If fstat Then
    [M:MAX5]EMAOBC = ""
    [M:MAX5]EMATEX = ""
  Else
    [M:MAX5]EMAOBC = [F:OMM]EMAOBC
    [M:MAX5]EMATEX = [F:OMM]EMATEX
  Endif
  Affzo [M:MAX5]
Return

################################################################################################################
$AV_CHOIX
Return

################################################################################################################
AP_CHOIX
Return

################################################################################################################
$AVANT_BOUTON
Return

################################################################################################################
$FINSAI
  Raz [M:MAX5]
Return

################################################################################################################
$FIN
Return

################################################################################################################
$ABANDON
Return

################################################################################################################
$APRES_MODIF
Return

################################################################################################################
$BOUTON
Return

################################################################################################################
$ONMENU
Return

#########################################################
# Sous-programmes
#########################################################
################################################################################################################
$ONOK
  If [M:MAX5]EMAOBC <> "" Then
    Call DEBTRANS From GLOCK
    Trbegin [OMM]
    Readlock [OMM]OMM0=GSZOPGNUM
    #Il s'agit d'un nouvel enregistrement
    If !fstat Then
      [F:OMM]EMAOBC = [M:MAX5]EMAOBC
      [F:OMM]EMATEX = [M:MAX5]EMATEX
      Rewrite [OMM]
      If fstat Then
        GMESSAGE = mess(101,141,1) #Erreur modification
        GERR = 1
        Unlock [OMM]
        Rollback 
        End
      Else
        Commit
        Unlock [OMM]
      Endif
    Endif
    GIEMATXT = 1
    GSZEMASUBJECT = [M:MAX5]EMAOBC
    GISTECPL(GICSTEP-1) = 1
  Endif
Return
