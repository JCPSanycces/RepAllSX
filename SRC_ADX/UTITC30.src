#<AdxTL>@(#)11.0.0.0 $Revision$
##########################################################################
# UTITC30   Moulinette de validation du browser ICC                      #
##########################################################################
##########################################################################
Local Char DOSSIER(30)

  If 0 Then
    DOSSIER = nomap
    # Issue 108760 - 2015-08-07 by MAE :
    #Call SAIDOS(DOSSIER,"") From SAIDOS
    Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
    If DOSSIER <> "" Then
      If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
      # Issue 108760 - 2015-08-07 by MAE :
      #Read [ADS]DOSSIER=[L]DOSSIER
      #If fstat THEN
      #  Raz [F:ADS]
      #Endif
      If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE("Correction") From LECFIC
      Call MAJ_UTITC30(DOSSIER)
      Call TEMPOFF     From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
  Else
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    For [ADS]DOSSIER
      If !find([F:ADS]DOSSIER,"X3INDV6","X3TESTV6") Then
        DOSSIER = [F:ADS]DOSSIER
        Call MAJ_UTITC30(DOSSIER)
      Endif
    Next
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC30(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Char WOBJET(GLONAOB)
Local Integer B_OK

  Call ECR_TRACE("UTITC30: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  If clalev([F:AOB]) = 0 : Local File =DOSSIER + ".AOBJET"  [AOB] : Endif
  Raz COMPTEUR
  #
  WOBJET="ICC"
  Read [AOB]ABREV=WOBJET
  If !fstat Then
    Call MAJ_SEL(DOSSIER, WOBJET) From PATCHAOB
    Call VALID (WOBJET, DOSSIER, 1, B_OK) From VALOBJ
    If B_OK <> 1 Then
      Call ECR_TRACE("Erreur revalidation objet" - WOBJET, 1) From GESECRAN
    Else
      Call VALID("IITC", DOSSIER, 1, B_OK) From VALWIN
      If B_OK <> 1 Then
        Call ECR_TRACE("Erreur revalidation fenêtre IITC", 1) From GESECRAN
      Endif
    Endif
    #
    COMPTEUR += 1
  Endif
  #
  Close Local File [AOB]
  Call ECR_TRACE("UTITC30 :" - num$(COMPTEUR) - "record processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS]DOSSIER=APPLI
  #If fstat THEN
  #  Raz [F:ADS]
  #Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"AOBJET") : End : Endif
  # End MAE 108760
  Call MAJ_UTITC30(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If func DOSVUE.ISVIEW(APPLI,"AOBJET") : End : Endif
  Call MAJ_UTITC30(APPLI)
End

