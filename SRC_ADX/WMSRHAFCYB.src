$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 1427: RES='Sites'
   When 1344: RES='Site'
  Endcase
 When "ENG":
  Case _ID
   When 1427: RES='Sites'
   When 1344: RES='Site'
  Endcase
 When "ITA":
  Case _ID
   When 1427: RES='Siti'
   When 1344: RES='Sito'
  Endcase
 When "POR":
  Case _ID
   When 1427: RES='Estab.'
   When 1344: RES='Estab.'
  Endcase
 When "SPA":
  Case _ID
   When 1427: RES='Plantas'
   When 1344: RES='Planta'
  Endcase
 When "BRI":
  Case _ID
   When 1427: RES='Sites'
   When 1344: RES='Site'
  Endcase
 When "GER":
  Case _ID
   When 1427: RES='Standorte'
   When 1344: RES='Standort'
  Endcase
 When "POL":
  Case _ID
   When 1427: RES='Lokalizacje'
   When 1344: RES='Lokalizacja'
  Endcase
 When "CHI":
  Case _ID
   When 1427: RES='地点'
   When 1344: RES='地点'
  Endcase
 When "ARB":
  Case _ID
   When 1427: RES='المواقع'
   When 1344: RES='الموقع'
  Endcase
Endcase
Return
