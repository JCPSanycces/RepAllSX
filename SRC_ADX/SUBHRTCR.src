#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
## Etiquette ajoutée par le superviseur (Objet HRTCR)
######################################################################################
$ACTION
Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "AP_CHANGE"    : Gosub AP_CHANGE
  When "AP_ANNULE"    : Gosub AP_ANNULE
  When "CREATION"     : Gosub CREATION
  When "MODIF"        : Gosub MODIF
  When "APRES_CHOI"   : Gosub APRES_CHOI
  When "FERME"        : Gosub FERME
  When "SEL_TABLE"   : Gosub SEL_TABLE
  When Default
Endcase
Return


######################################################################################
$OUVRE
  If !clalev([F:WSTG]) : Local File STAGE [WSTG] : Endif
  #LIPET - X3-29535 - 20-03-2017 - START
  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
  #LIPET - X3-29535 - 20-03-2017 - END
Return

$FERME
 #LIPET - X3-29535 - 20-03-2017 - START
 If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
 #LIPET - X3-29535 - 20-03-2017 - END
Return

$APRES_CHOI
If REPONSE=GSTAENR
  Filter [F:WSTG] Where TCRCOD=[M]TCRCOD
  Local Integer WOK
  If(rowcount([F:WSTG]))
    #LIPET - X3-29535 - 20-03-2017 - START
    #Call OUINON(mess(319,717,1)+chr$(10)+chr$(13)+mess(320,717,1),WOK) From GESECRAN
     Call OUINON(mess(319,10717,1)+chr$(10)+chr$(13)+mess(320,10717,1),WOK) From GESECRAN
    #LIPET - X3-29535 - 20-03-2017 - END
    If WOK<>2
      REPONSE=GSTAFIN
    Endif
  Endif
Endif
Return


# ATEXTRA voir TABVACBPR/SUBTVB
$MODIF
$CREATION

Gosub MAJ_ATEXTRA

Return

$MAJ_ATEXTRA
If GREP="D"
 Call DUPTEXTRA("HRTRACSTREP","DES",CLECUR1,"","HRTRACSTREP","DES",[M:HRTCR0]TCRCOD,"")  From ATEXTRA
Endif
Call MAJTEXTRA ([M:HRTCR0]DES,"HRTRACSTREP","DES",[M:HRTCR0]TCRCOD,"") From ATEXTRA

Return

$AP_CHANGE
Call CHGTEXTRA("HRTRACSTREP","DES",[L]OCODE,"",[L]NCODE,"") From ATEXTRA
Return

$AP_ANNULE
Call SUPTEXTRA("HRTRACSTREP","DES", [M:HRTCR0]TCRCOD,"") From ATEXTRA
Return

$SEL_TABLE

  Case TABLE
  When "SELHRTCR"
    If clalev ([F:HRTCR])=0 : Local File HRTRACSTREP [HRTCR] : Endif
    Filter [F:HRTCR]
    OBJET="HRTCR"

    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRTCR]LEG="'+GCURLEG+'" | [F:HRTCR]LEG="")',"&") From GOBJSUB
  Endcase

Return
####################################
Subprog C_CSTPRC(VALEUR)
Variable Decimal VALEUR

If VALEUR>100 or VALEUR<0
  #LIPET - X3-29535 - 20-03-2017 - START
  #GMESSAGE=mess(315,717,1) : #"La valeur doit être comprise entre 0 et 100"
  GMESSAGE=mess(315,10717,1) : #"La valeur doit être comprise entre 0 et 100"
  #LIPET - X3-29535 - 20-03-2017 - END
  mkstat=2
Endif
End

####################################
#
# Uniqueness only on these two fields for easiest modification. Full controls on orgfin2
#
Subprog C_ORGFIN(VALEUR)
Variable Char    VALEUR()

Gosub CHECK_UNICITE
End

####################################
Subprog C_ORGFIN2(VALEUR)
Variable Char    VALEUR()

Gosub CHECK_UNICITE
End

####################################
Subprog AM_CSTPRC(VALEUR)
Variable Decimal VALEUR

Gosub RESET_FIELD
End

####################################
Subprog AM_CSTFXD(VALEUR)
Variable Decimal VALEUR

Gosub RESET_FIELD
End



####################################
Subprog AS_TYPFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & nolign>1
 VALEUR = [M]TYPFIN(nolign-2)
Endif
End

####################################
Subprog AS_CSTMAX(VALEUR)
Variable Decimal VALEUR
Gosub GET_NOLIGN
If [M]CSTPRC(LIN)=0 : mkstat=1 : Endif
End

####################################
Subprog AS_CSTMAXUNT(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
Gosub GET_NOLIGN

If [M]CSTMAX(LIN)=0 and [M]CSTFXD(LIN)=0 : mkstat=1 : Endif
End


######################################################################################
$RESET_FIELD

If VALEUR=0 : Return : Endif
Local Integer IS_CSTFXD
IS_CSTFXD=(zoncou="CSTFXD")
Gosub GET_NOLIGN

If IS_CSTFXD
 Effzo [M]CSTPRC(LIN)
 Effzo [M]CSTMAX(LIN)
 Effzo [M]CSTMAXUNT(LIN)
Else
 Effzo[M]CSTFXD(LIN)
Endif

Return

##############################################################

$CHECK_UNICITE

If VALEUR="" : Return : Endif

Local Char ORGFIN(30),ORGFIN2(30),TYPCRG(30),TYPFIN(30)
Local Char CODE(30)
Gosub GET_NOLIGN

ORGFIN=[M]ORGFIN(LIN)
ORGFIN2=[M]ORGFIN2(LIN)
TYPCRG=[M]TYPCRG(LIN)
TYPFIN=[M]TYPFIN(LIN)

Assign zoncou With VALEUR


If ORGFIN=ORGFIN2 and ORGFIN="" : Return : Endif
If (zoncou="ORGFIN2" and ORGFIN=ORGFIN2)
  #LIPET - X3-29535 - 20-03-2017 - START
  #GMESSAGE=mess(316,717,1)    :#"Organisme déjà présent sur la ligne"
  GMESSAGE=mess(316,10717,1)    :#"Organisme déjà présent sur la ligne"
  #LIPET - X3-29535 - 20-03-2017 - END
  mkstat=2
Endif


# check unicité des lignes
Local Integer I
For I=0 To [M]NBCOU-1
  If I<>LIN
    If([M]TYPCRG(I)=TYPCRG and [M]TYPFIN(I)=TYPFIN)
      If( VALEUR<>"" & (VALEUR=[M]ORGFIN(I) |VALEUR=[M]ORGFIN2(I)))
        CODE=VALEUR
        Break
      Endif
#      If (zoncou="ORGFIN" & ORGFIN<>"" & (ORGFIN=[M]ORGFIN(I) |ORGFIN=[M]ORGFIN2(I)))
#        CODE=ORGFIN
#        Break
#      Endif
#     If (zoncou="ORGFIN2" & ORGFIN2<>"" & (ORGFIN2=[M]ORGFIN(I) |ORGFIN2=[M]ORGFIN2(I)))
#        CODE=ORGFIN2
#        Break
#      Endif
    Endif
  Endif
Next

If CODE<>""
    #"$1$ DÉJÀ PRÉSENT SUR LA LIGNE $2$"
  #GMESSAGE=TYPCRG+"/"+TYPFIN+"/"+CODE-"déjà présent sur la ligne"-num$(I+1)
  #LIPET - X3-29535 - 20-03-2017 - START
  #GMESSAGE=func AFNC.MES2(mess(317,717,1),TYPCRG+"/"+TYPFIN+"/"+CODE,num$(I+1))
  GMESSAGE=func AFNC.MES2(mess(317,10717,1),TYPCRG+"/"+TYPFIN+"/"+CODE,num$(I+1))
  #LIPET - X3-29535 - 20-03-2017 - END
  mkstat=2
Endif

Return


$GET_NOLIGN
  Local Integer LIN
  LIN=nolign-1
Return

# Changement calcul
#**
#*
#*
#* @param TCRCOD Repartition Code
#* @param TYPCRG Expensive(Frais) Type
#* @param TYPFIN Fundind(Financement) type
#* @param ORGFIN Oganisation(Organisme de financement)
#* @param NBHOURS Number of hours
#* @param NBNIGHT Number of nignt
#* @param AMOUNT Montant
#* @param RESULT Tab of montant (item=0 father Distribution, item=1 son Distribution)
#*!
Subprog CALCULATE(TCRCOD,TYPCRG,TYPFIN,ORGFIN,NBHOURS,NBNIGHT,AMOUNT,RESULT)
Value Char TCRCOD(),TYPCRG(),TYPFIN(),ORGFIN()
Value Decimal NBHOURS
Value Integer NBNIGHT
Variable Decimal AMOUNT
Variable Decimal RESULT()
Local Decimal W_COEFF

RESULT=AMOUNT
If AMOUNT=0
  RESULT(0)=0
  RESULT(1)=0
  End
Endif


If clalev([F:HRTCR])=0 : Local File HRTRACSTREP     [HRTCR] : Endif
Read [F:HRTCR]HRTCR1=TCRCOD;TYPCRG;TYPFIN;ORGFIN
If !fstat
   Gosub GET_COEFF
  # Forfait
  If [F:HRTCR]CSTFXD<>0
    RESULT(0)=[F:HRTCR]CSTFXD*W_COEFF   :# min([F:HRTCR]CSTFXD,AMOUNT)
    RESULT(1)=0 #max(0,AMOUNT-RESULT(0)) :# max(0,AMOUNT-[F:HRTCR]CSTFXD)
  Elsif [F:HRTCR]CSTMAX=0
    RESULT(0)=(AMOUNT*[F:HRTCR]CSTPRC)/100
    RESULT(1)=(AMOUNT-RESULT(0))
  Else
   Local Decimal MAXUNIT
   MAXUNIT=max(0,[F:HRTCR]CSTMAX*W_COEFF)
   If W_COEFF=0
    RESULT(0)=0
    RESULT(1)=0
   Else
    RESULT(0)=min(MAXUNIT,(AMOUNT*[F:HRTCR]CSTPRC)/100)
    RESULT(1)=AMOUNT-RESULT(0)
   Endif
  Endif
Endif

End

$GET_COEFF

Case [F:HRTCR]CSTMAXUNT
  When 1 : W_COEFF=NBHOURS
  When 2 : W_COEFF=NBNIGHT
  When Default : W_COEFF=1
Endcase


Return

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
#LIPET - X3-29535 - 20-03-2017 - START
  GCURLEG = VALEUR
#LIPET - X3-29535 - 20-03-2017 - END
End


######################################################################################

