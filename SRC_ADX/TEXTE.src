#<AdxTL>@(#)0.0.0.0 $Revision$
#CHECK IGNORE_SOURCE
############################################################### 
# S/Programmes de gestion des Textes à traduire (ATEXTRA) 
###############################################################
## Subprog CREER(TEXTE,NUMERO,CHAPITRE,LONGUEUR)
## Subprog MODIF(TEXTE,NUMERO,CHAPITRE,LONGUEUR)
## Subprog LECTURE(TEXTE,NUMERO)
## Subprog LECTRAD(TEXTE,NUMERO,LANGUE)
## Subprog DESSHOLNG  # déclare et initialise les globales servant de paramètres
## Subprog COPTEXTE(NUM1,NUM2)
###############################################################
 
############################################################### 
# Création d'un nouveau texte
###############################################################
Subprog CREER(TEXTE,NUMERO,CHAPITRE,LONGUEUR)
Value    Char    TEXTE
Variable Decimal NUMERO
Value    Char    CHAPITRE
Value    Integer LONGUEUR
Local    Integer NUM
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
Call DEBTRANS From GLOCK
$DEB_CREER
GOK=1
Trbegin [AXX]
Lock [AXX]
If fstat
  GOK=-1 : GLOCK="$ATEXTRA" : Goto ROLL_CREER
Endif
#Filter [AXX] Where LANGUE=GLANGUE
Read [AXX]AXX2 Last # le dernier absolu (mai 2001)
#Filter [AXX]
If fstat : NUM=1 : Else : NUM=[F:AXX]NUMERO+1 : Endif
Raz [F:AXX]
[F:AXX]NUMERO=NUM : [L]NUMERO=NUM
[F:AXX]TEXTE  = TEXTE
[F:AXX]CHAP   = CHAPITRE
[F:AXX]LANGUE = GLANGUE
[F:AXX]LNG    = LONGUEUR
Write [AXX]
If fstat
 GOK =  0 : Call FSTA("AXX") From GLOCK : Goto AB_CREER
Endif
Commit
End

$AB_CREER
Rollback
End

$ROLL_CREER
Rollback 
Call ROLL From GLOCK
If GROLL : End : Else Goto DEB_CREER : Endif

############################################################### 
# Modif d'un texte existant 
############################################################### 
Subprog MODIF(TEXTE,NUMERO,CHAPITRE,LONGUEUR) 
Variable Char    TEXTE 
Variable Decimal NUMERO 
Value    Char    CHAPITRE 
Value    Integer LONGUEUR 
Local    Integer EXISTE, NUM  
TEXTE = vireblc(TEXTE,2)  
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif 
  
Readlock [AXX]AXX0 = GLANGUE;NUMERO  : # modif le 23/07/98 par jl  
If fstat=1  
 GOK = -1 : GLOCK="$ATEXTRA"-GLANGUE-num$(NUMERO) : End  
Endif   
# si texte existe déjà : on prend le numero 
Filter [AXX] Where LANGUE=GLANGUE & LNG=[L]LONGUEUR & CHAP=[L]CHAPITRE & TEXTE=[L]TEXTE   
EXISTE = 0   
For [AXX]   
  EXISTE = 1 : Break    
Next   
Filter [AXX]    
If EXISTE   
  NUMERO=[F:AXX]NUMERO   
  End 
Endif
# en Import ne pas ouvrir la boite de choix mais créer (bug 6464 TB Oct 2000)
If GIMPORT
  Call DEBTRANS From GLOCK : Goto C_NEW 
Endif
 
$LE_CHOIX  
Gosub CHTEX  
Case CHOIX  
  When 0       : mkstat=2 : End   
  When CNEW    : Call DEBTRANS From GLOCK : Goto C_NEW  
  When CMOD    : Goto C_MOD  
  When CREC    : Goto C_REC  
  When CABD    : mkstat=2 : End  
  When Default : mkstat=2 : End   
Endcase  
  
$C_NEW  
GOK=1
Trbegin [AXX]
Lock [AXX]
If fstat
  GOK=-1 : GLOCK = "$ATEXTRA" : Goto ROLL_NEW
Endif
Filter [AXX] Where LANGUE=GLANGUE
Read [AXX] Last
Filter [AXX]
If fstat : NUM=1 : Else : NUM=[F:AXX]NUMERO+1 : Endif
[F:AXX]NUMERO = NUM : [L]NUMERO=NUM
[F:AXX]LANGUE = GLANGUE  
[F:AXX]CHAP   = [L]CHAPITRE  
[F:AXX]LNG    = [L]LONGUEUR   
[F:AXX]TEXTE  = [L]TEXTE   
Write [AXX]  
If fstat  
   GOK = 0 : Call FSTA("AXX") From GLOCK : Goto AB_NEW  
Endif  
Commit
End
$AB_NEW
Rollback
End
$ROLL_NEW
Rollback 
Call ROLL From GLOCK
If GROLL : End : Else : : Goto C_NEW : Endif
  
  
$C_MOD  
[F:AXX]TEXTE = TEXTE  
Rewrite [AXX]  
If fstat  
  GOK = 0 : Call FSTA("AXX") From GLOCK : End  
Endif  
End  
  
$C_REC  
Case OK  
  When 0     : Goto LE_CHOIX  
  When -1    : mkstat=2 : End  
Endcase     
End  
  
$CHTEX  
Local Integer NBTEX, NUMTEX(adxmxl)  
Local Char    TEX(50) (adxmxl), TIT(30)  
Local Integer OK   
Local Integer CHOIX, CNEW, CMOD, CREC, CABD  
NBTEX = 0  
NBTEX +=1   : TEX(NBTEX)=mess(25,123,1) : CNEW=NBTEX : # Nouveau texte  
If NUMERO<>0  
  NBTEX +=1 : TEX(NBTEX)=mess(26,123,1) : CMOD=NBTEX : # Modif texte  
Endif   
NBTEX +=1   : TEX(NBTEX)=mess(27,123,1) : CREC=NBTEX : # Recherche  
NBTEX +=1   : TEX(NBTEX)=mess(5,123,1)  : CABD=NBTEX : # Abandon  
##CHOIX = CREC  
CHOIX = CNEW  # Proposer 'Nouveau' par défaut   bug 6695  (TB 13/11/00) 
TIT = mess(28,123,1) : # Texte  
Call SAITEX(NBTEX,TEX,CHOIX,TIT) From GESECRAN  
Case CHOIX   
  When CREC : Gosub RECHTEX  
Endcase   
Return  
  
$RECHTEX  
Local Integer RANG   
NBTEX = 0  
# A cause du nb important d'articles, la sélection est filtrée : (20/12/99)
If CHAPITRE = "ITEM"
 Filter [AXX] Where LANGUE=GLANGUE & CHAP=CHAPITRE &
&             vireblc(left$(TEXTE,15),2) = vireblc(left$([L]TEXTE,15),2)
&             Order By TEXTE
 For [AXX]
  If !find([F:AXX]TEXTE,TEX(1..NBTEX)) & NBTEX<min(dim(TEX)-1,adxmxl-1) : # pour eviter les doublons
    NBTEX +=1  
    TEX(NBTEX) = [F:AXX]TEXTE : NUMTEX(NBTEX) = [F:AXX]NUMERO  
  Endif    
 Next  
 If NBTEX = 0 : # réduire le modèle de sélection ?
     Filter [AXX] Where LANGUE=GLANGUE & CHAP=CHAPITRE &
&             vireblc(left$(TEXTE,5),2) = vireblc(left$([L]TEXTE,5),2)
&             Order By TEXTE
     For [AXX]
      If !find([F:AXX]TEXTE,TEX(1..NBTEX)) & NBTEX<min(dim(TEX)-1,adxmxl-1) : # pour eviter les doublons
        NBTEX +=1  
        TEX(NBTEX) = [F:AXX]TEXTE : NUMTEX(NBTEX) = [F:AXX]NUMERO  
      Endif    
     Next  
 Endif
 Filter [AXX]
Elsif CHAPITRE = "TBDIV"
 Filter [AXX] Where LANGUE=GLANGUE & CHAP=CHAPITRE & LNG=LONGUEUR & TEXTE>=[L]TEXTE
&             Order By TEXTE
 For [AXX]
  If !find([F:AXX]TEXTE,TEX(1..NBTEX)) & NBTEX<min(dim(TEX)-1,adxmxl-1) : # pour eviter les doublons
    NBTEX +=1  
    TEX(NBTEX) = [F:AXX]TEXTE : NUMTEX(NBTEX) = [F:AXX]NUMERO  
  Endif    
 Next
 Filter [AXX]  
Else
 For [AXX]AXX1 Where LANGUE=GLANGUE & CHAP=CHAPITRE & LNG=LONGUEUR   
  If !find([F:AXX]TEXTE,TEX(1..NBTEX)) & NBTEX<min(dim(TEX)-1,adxmxl-1) : # pour eviter les doublons
    NBTEX +=1  
    TEX(NBTEX) = [F:AXX]TEXTE : NUMTEX(NBTEX) = [F:AXX]NUMERO  
  Endif    
 Next  
Endif

If NBTEX>0  
  RANG=1  
  TIT=mess(12,123,1) : # Choix  
  Call SAITEX(NBTEX,TEX,RANG,TIT) From GESECRAN  
  If status<>7 & RANG<>0  : # un texte est choisi  
    TEXTE  = TEX(RANG)  
    NUMERO = NUMTEX(RANG)  
    OK=1  
  Else   
    OK=0                  : # pas de texte choisi 
  Endif  
Else                      : # pas de texte a choisir (c'est le 1er texte) 
  OK=-1  
Endif  
# Infbox "Sortie Recherche:"+TEXTE+num$(NUMERO)  
  
Return  

############################################################### 
# Relecture d'un texte
############################################################### 
# En langue locale
Subprog LECTURE(TEXTE,NUMERO)
Variable Char    TEXTE()
Value    Decimal NUMERO
If NUMERO=0 : TEXTE="" : End : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
#DBA le 22/04/03 : en attendant mieux !!!
#Read [AXX]AXX0 = GLANGUE;NUMERO
Filter [AXX] Where LANGUE=GLANGUE & NUMERO=[L]NUMERO
Read [AXX]AXX1 First
Filter [AXX]
If !fstat
 TEXTE = [F:AXX]TEXTE
Endif
End

# Dans une autre langue
Subprog LECTRAD(TEXTE,NUMERO,LANGUE)
Variable Char    TEXTE()
Value    Decimal NUMERO
Value    Char    LANGUE
If NUMERO=0 : TEXTE="" : End : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
#DBA le 22/04/03 : en attendant mieux !!!
#Read [AXX]AXX0 = LANGUE;NUMERO
#If fstat
#Read [AXX]AXX0 = GLANGUE;NUMERO
#Endif
Filter [AXX] Where LANGUE=[L]LANGUE & NUMERO=[L]NUMERO
Read [AXX]AXX1 First
Filter [AXX]
If fstat
 Filter [AXX] Where LANGUE=GLANGUE & NUMERO=[L]NUMERO
 Read [AXX]AXX1 First
 Filter [AXX]
Endif
If !fstat
 TEXTE = [F:AXX]TEXTE
Endif
End

############################################################### 
# Remplacement d'une chaine par une autre dans un texte
#  (remplacer la chaine AVANT par la chaine APRES dans TEXTE
############################################################### 
Subprog DYNAMIC(TEXTE,AVANT,APRES)
Variable Char   TEXTE ()
Value    Char AVANT ()
Value    Char APRES ()
Local    Integer IYA 
IYA=1
While IYA 
  IYA = instr(1,TEXTE,AVANT)
  If IYA 
    TEXTE=left$(TEXTE,IYA-1)+APRES+right$(TEXTE,IYA+len(AVANT))
  Endif   
Wend
End

############################################################### 
# Recherche de la longueur des types de données DES et SHO
############################################################### 
Subprog DESSHOLNG
Global Integer GDESLNG, GSHOLNG
If clalev ([F:ATY])=0 : Local File ATYPE [ATY] : Endif
Read [ATY]CODTYP="DES"
If !fstat : GDESLNG=[F:ATY]LNGTYP : Endif
Read [ATY]CODTYP="SHO"
If !fstat : GSHOLNG=[F:ATY]LNGTYP : Endif
End

##################################################################### 
# Pour la copie d'objet, structure tarif et élément de facturations #
##################################################################### 
Subprog COPTEXTE(NUM1,NUM2)
Value    Integer NUM1
Variable Integer NUM2
Local    Char    LANTEX(3)(1..20) : # Langues communes aux dossiers
Local    Integer I, NBLANTEX

NUM2 = 0
If NUM1=0 : End : Endif

# Il faut faire un Gosub OUVDOS From TEXTE dans le traitement appelant
If clalev([F:ADS1])>0 & clalev([F:ADS2])>0
 NBLANTEX = 0
 For I=0 To [F:ADS1]NBRLAN-1
  If find([F:ADS1]LAN(I),[F:ADS2]LAN(0..[F:ADS2]NBRLAN-1))
   NBLANTEX += 1
   LANTEX(NBLANTEX) = [F:ADS1]LAN(I)
  Endif
 Next I
Else
 NBLANTEX = 1
 LANTEX(NBLANTEX) = GLANGUE
Endif

If !NBLANTEX : End : Endif : # Pas de langue commune
Read [AXX1]AXX0 = LANTEX(1);NUM1
If fstat  : End : Endif

Filter [AXX2] Where LANGUE=LANTEX(1) & CHAP=[F:AXX1]CHAP & TEXTE=[F:AXX1]TEXTE & LNG=[F:AXX1]LNG
Read [AXX2]AXX0 First
Filter [AXX2]
If !fstat
 NUM2 = [F:AXX2]NUMERO
Else
 Lock [AXX2]
 If fstat
  GOK = -1 : GLOCK = "$ATEXTRA" : End
 Endif
 Read [AXX2]AXX2 Last
 If fstat : NUM2 = 1 : Else : NUM2 = [F:AXX2]NUMERO+1 : Endif
 [F:AXX2] = [F:AXX1]
 [F:AXX2]NUMERO = NUM2
 Write [AXX2]
 If fstat
  GOK=0 : Call FSTA("AXX2") From GLOCK : End
 Endif
 For I=2 To NBLANTEX
  Read [AXX1]AXX0 = LANTEX(I) ; NUM1
  If !fstat
   [F:AXX2] = [F:AXX1]
   [F:AXX2]NUMERO = NUM2
   Write [AXX2]
   If fstat
    GOK=0 : Call FSTA("AXX2") From GLOCK : Break
   Endif
  Endif
 Next I
Endif
End

$OUVDOS
Local Char APPLI(20), MERE(20), MACHINE(20)
If dim([M]DOSORG)<=0 | dim([M]DOSDES)<=0
 Return
Endif
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif

Call MOTHER([M]DOSORG,APPLI,MERE,MACHINE)
If MERE<>""
 If MACHINE=""
  If MERE=nomap
   Local File ADOSSIER [ADS1]
  Else
   Local File =MERE+".ADOSSIER" [ADS1]
  Endif
 Else
  Local File =MACHINE+"@"+MERE+".ADOSSIER" [ADS1]
 Endif
 Read [ADS1]DOSSIER = APPLI
 If fstat : Raz [F:ADS1] : Endif
Endif  

Call MOTHER([M]DOSDES,APPLI,MERE,MACHINE)
If MERE<>""
 If MACHINE=""
  If MERE=nomap
   Local File ADOSSIER [ADS2]
  Else
   Local File =MERE+".ADOSSIER" [ADS2]
  Endif
 Else
  Local File =MACHINE+"@"+MERE+".ADOSSIER" [ADS2]
 Endif
 Read [ADS2]DOSSIER = APPLI
 If fstat : Raz [F:ADS2] : Endif
Endif
Return 

Subprog MOTHER(DOSSIER,APPLI,MERE,MACHINE)
Value    Char DOSSIER
Variable Char APPLI
Variable Char MERE
Variable Char MACHINE
Local Char    CHEMIN(250), LIGNE(80), VARIA(20), VALEUR(20)
Local Integer I, J
Local Char    SAVIRS(5), SAVIRS(5)

Raz APPLI, MERE, MACHINE
I = instr(1,DOSSIER,"@")
If I
 APPLI   = toupper(right$(DOSSIER,I+1))
 MACHINE = left$(DOSSIER,I-1)
Else
 APPLI   = toupper(DOSSIER)
 MACHINE = ""
Endif

CHEMIN = filpath("","APL","ini",APPLI,"",MACHINE)
If filinfo(CHEMIN,0)<0 : End : Endif

SAVIRS = adxirs
SAVIFS = adxifs
adxirs = chr$(10)
adxifs = ""
Openi CHEMIN Using [INI]
fstat = 0
Repeat
 Rdseq LIGNE Using [INI]
 If !fstat
  I = instr(1,LIGNE,"=")
  If I
   VARIA  = vireblc(left$(LIGNE,I-1),2)
   VALEUR = vireblc(right$(LIGNE,I+1),2)
   I = instr(1,VALEUR,'"')
   J = instr(I+1,VALEUR,'"')
   If I & J
    VALEUR = seg$(VALEUR,I+1,J-1)
   Else
    I = instr(1,VALEUR,"'")
    J = instr(I+1,VALEUR,"'")
    If I & J
     VALEUR = seg$(VALEUR,I+1,J-1)
    Endif
   Endif
   Case VARIA
    When "adxmother(1)" : MERE = VALEUR : Break
   Endcase
  Endif
 Endif
Until fstat
Openi Using [INI]
adxirs = SAVIRS
adxifs = SAVIFS
End

##################################################
# Equivalent de SAITEX... webisé  (TB Oct 2000)
##################################################
# Action SELAXXUPD Choix de mise à jour ; action suite (SELAXX) choix de texte
$ACTION
Case ACTION
 When "SEL_LISTE"  Gosub SEL_LISTE
 When "VERF_LISTE" Gosub VERF_LISTE
 When "FIN_LISTE"  Gosub FIN_LISTE # tester Annuler ou croix
Endcase
Return

$SEL_LISTE
Case LISTE
   When "CHCHAP"  : Gosub CHCHAP
   When "CHTEX"   : Gosub CHTEXW
   When "TEXTRA"  : Gosub TEXTRA
Endcase
Return

$VERF_LISTE
Case LISTE
   When "CHCHAP"  : Gosub VERF_CHAP
   When "CHTEX"   : Gosub VERF_CH
   When "TEXTRA"  : Gosub VERF_TEX
Endcase
Return

$FIN_LISTE
If status = 7 mkstat = 2 Endif
Return

$CHCHAP
TIT = mess(35,124,1)
I = find ("",GCHAPITRE) 
If I > 1
#### For NBTEX=0 To I-2
 For NBTEX=1 To I-1
  TEX(NBTEX) = GCHAPITRE(NBTEX-1) 
 Next
 NBTEX=I-1
Endif
Return

$VERF_CHAP
#### PARAM(1) = TEXTE(CHOIX)
Return

$CHTEXW
# s'il existe déjà, on affecte le n°, sinon on ouvre la boîte de choix
Local Integer EXISTE
Local Integer CNEW, CMOD, CREC, CABD  
PARAM(1) = vireblc(PARAM(1),2) 
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif 

# lecture sur le numéro de texte :
Readlock [AXX]AXX0 = GLANGUE;val(PARAM(2))  
If fstat=1
    GERR = 1 : GMESSAGE=mess(60,100,1)-PARAM(2) : mkstat=2 : Return  # 12/03/01
Endif   
Unlock [AXX]  # rajouté le 03/05/01 Si on ne modifiait pas ou si on ne créait pas il restait locké

# si le texte tel qu'il a été saisi existe déjà : on prend le numero 
Filter [AXX] Where LANGUE=GLANGUE & LNG=val(PARAM(4)) & CHAP=PARAM(3) & TEXTE=PARAM(1) 
EXISTE = 0   
For [AXX]   
  EXISTE = 1 : Break
Next
Filter [AXX]    
GOK=1
If EXISTE
  PARAM(2) = num$([F:AXX]NUMERO) # > sera perdu si action suite !!
  NBTEX = 0  : # pour ne pas ouvrir la sélection 
  GOK   = 9  : # positionner une globale pour sauter l'action suite
  Return 
Endif
# en Import ne pas ouvrir la boite de choix mais créer (bug 6464 TB Oct 2000)
If GIMPORT | GREP="C" | GREP="D"
  Gosub C_NEWW : GOK = 9 : Return
Endif

NBTEX =1
TEXTE(NBTEX)=mess(25,123,1) : TEX(NBTEX)=num$(NBTEX)
CNEW=NBTEX : # Nouveau texte
If val(PARAM(2)) <> 0
  NBTEX +=1 : TEXTE(NBTEX)=mess(26,123,1) : TEX(NBTEX)=num$(NBTEX)
  CMOD=NBTEX : # Modif texte  
Endif   
NBTEX +=1   : TEXTE(NBTEX)=mess(27,123,1) : TEX(NBTEX)=num$(NBTEX)
CREC=NBTEX  : # Recherche  
NBTEX +=1   : TEXTE(NBTEX)=mess(5,123,1)  : TEX(NBTEX)=num$(NBTEX)
CABD=NBTEX  : # Abandon  

CHOIX = CREC
TIT = mess(28,123,1) : # Texte  
Return

# CHOIX est déclaré dans l'action (GACTION)

$VERF_CH
GOK=1
Case CHOIX
  When CMOD : Gosub C_MODW  
              GOK = 9  : # positionner une globale pour sauter l'action suite
  When CNEW : Gosub C_NEWW 
              GOK = 9 
#  When CREC : Gosub RECHTEX  # remplacé par l'action suite (SELAXX)
  When CABD : mkstat=2 : GOK = 9 
Endcase 
Return

$VERF_TEX
PARAM(1) = TEXTE(CHOIX)
PARAM(2) = num$(NUMTEX(CHOIX))
Return

$TEXTRA     #  équivalent de $RECHTEX
If GOK = 9 | mkstat  
  GOK=1              # rajouté le 02/10/01 (TB)
  Return 
Endif
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif 
TIT=mess(12,123,1) : # Choix  
## Attention >>>  TEXTE est la variable locale (dimensionnée) à l'action
Local Integer NUMTEX(min(adxmxl,dim(TEX)))  
NBTEX = 0  
# A cause du nb important d'articles, la sélection est filtrée 
If PARAM(3) = "ITEM"
 Filter [AXX] Where LANGUE=GLANGUE & CHAP=PARAM(3) &
&             vireblc(left$([F]TEXTE,15),2) = vireblc(left$(PARAM(1),15),2)
&             Order By TEXTE
 For [AXX]
  If !find([F:AXX]TEXTE,TEXTE(1..NBTEX)) & NBTEX<min(dim(TEX)-1,adxmxl-1) : # pour eviter les doublons
    NBTEX +=1  : TEX(NBTEX) = num$(NBTEX)
    TEXTE(NBTEX) = [F:AXX]TEXTE : NUMTEX(NBTEX) = [F:AXX]NUMERO  
  Endif    
 Next  
 If NBTEX = 0 : # réduire le modèle de sélection ?
     Filter [AXX] Where LANGUE=GLANGUE & CHAP=PARAM(3) &
&             vireblc(left$([F]TEXTE,5),2) = vireblc(left$(PARAM(1),5),2)
&             Order By TEXTE
     For [AXX]
      If !find([F:AXX]TEXTE,TEXTE(1..NBTEX)) & NBTEX<min(dim(TEX)-1,adxmxl-1) :# pour eviter les doubles
        NBTEX +=1  : TEX(NBTEX) = num$(NBTEX)
        TEXTE(NBTEX) = [F:AXX]TEXTE : NUMTEX(NBTEX) = [F:AXX]NUMERO  
      Endif    
     Next  
 Endif
 Filter [AXX]

## Elsif PARAM(3) = "TBDIV" # POUR TOUS LES CHAPITRES >>>>>> (03/10/01)
Else
 Filter [AXX] Where LANGUE=GLANGUE & CHAP=PARAM(3) & LNG=val(PARAM(4)) & [F]TEXTE>=PARAM(1)
&             Order By TEXTE
 For [AXX]
  If !find([F:AXX]TEXTE,TEXTE(1..NBTEX)) & NBTEX<min(dim(TEX)-1,adxmxl-1)
    NBTEX +=1  : TEX(NBTEX) = num$(NBTEX)
    TEXTE(NBTEX) = [F:AXX]TEXTE : NUMTEX(NBTEX) = [F:AXX]NUMERO  
  Endif    
 Next
 Filter [AXX]  

##Else
# For [AXX]AXX1 Where LANGUE=GLANGUE & CHAP=PARAM(3) & LNG=val(PARAM(4))
#  If !find([F:AXX]TEXTE,TEXTE(1..NBTEX)) & NBTEX<min(dim(TEX)-1,adxmxl-1)
#    NBTEX +=1  : TEX(NBTEX) = num$(NBTEX)
#    TEXTE(NBTEX) = [F:AXX]TEXTE : NUMTEX(NBTEX) = [F:AXX]NUMERO  
#  Endif
# Next
Endif

# attention s'il n'y a qu'un élément, la liste ne s'affiche pas et l'élément est considéré comme sélectionné
If NBTEX=1
  # ramener le numero et le texte (09/05/01)
  CHOIX = 1 # ne suffit pas car VERF_LISTE n'est pas fait >
  PARAM(1) = TEXTE(CHOIX)
  PARAM(2) = num$(NUMTEX(CHOIX))
Endif

If NBTEX=0
  GERR = 1
  GMESSAGE = mess(99,100,1) # "Pas de fiche sélectionnée"
  mkstat = 2
Endif
Return  

$C_MODW
# le texte a été lu dans CHTEXW  
# risquait de rester locké; relire et écrire ds une transac (03/05/01)
Call DEBTRANS From GLOCK 
Trbegin [AXX]
Readlock [AXX]AXX0 = GLANGUE;val(PARAM(2))   # 03/05/01 (TB)
[F:AXX]TEXTE = PARAM(1)
Rewrite [AXX]  
If fstat  
  GOK = 0 : Call FSTA("AXX") From GLOCK : Rollback
Else
  Commit
Endif  
Return  
  
$C_NEWW  
Local Integer NUM
Call DEBTRANS From GLOCK 
$TR1
Trbegin [AXX]
Lock [AXX]
If fstat
  GOK=-1 : GLOCK = "$ATEXTRA" : Goto ROLL_NEWW
Endif

#Filter [AXX] Where LANGUE=GLANGUE
#Read [AXX] Last
#Filter [AXX]  # RISQUE DE DESYNCHRO >> Prendre le dernier absolu  (22/05/01)

Read [AXX]AXX2 Last
If fstat : NUM=1 : Else : NUM=[F:AXX]NUMERO+1 : Endif
[F:AXX]NUMERO = NUM : PARAM(2) = num$(NUM)
[F:AXX]LANGUE = GLANGUE  
[F:AXX]CHAP   = PARAM(3) 
[F:AXX]LNG    = val(PARAM(4))
[F:AXX]TEXTE  = PARAM(1)
Write [AXX]  
If fstat  
   GOK = 0 : Call FSTA("AXX") From GLOCK : Goto AB_NEWW  
Endif  
Commit
Return

$AB_NEWW
Rollback
Return

$ROLL_NEWW
Rollback
Call ROLL From GLOCK
If GROLL : GMESSAGE=mess(14,100,1) : GERR=1 : Return : Else : Goto TR1 : Endif

