#<AdxTL>@(#)6.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Migration dossier historisé
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Creation V7 directory for historic folder") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#--------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MIGRATION
End

#-------------------#
$MIGRATION
Local Char    APPLI(GDIMFIC) , VOLUME(1)
Local Char    REPERT(GDIMFIC)
Local Char    MACHINE(GDIMFIC)
Local Char    DIRSEP(1)
Local Integer I , ERREUR
Local Integer STAT

Local File ADOSSIER [ADS_M]
Read [ADS_M]DOSSIER=[L]DOSSIER
If fstat or [F:ADS_M]DOSHIS="" : Return : Endif

MACHINE = adxmac(0)
VOLUME  = [F:ADS_M]VOLUME
APPLI   = [F:ADS_M]DOSHIS

Gosub SET_DIRECT_SYS From DOSAPL
Gosub SET_DIRECT_STO From DOSAPL
For I=1 To NBDIR
 Call CREREP(filpath(TBDIR(I),"","",APPLI,VOLUME,MACHINE),ERREUR) From DOSAPL
Next I

# Création version de l'archive et de la classe OBJECT

If filinfo(filpath("","vers","atx",APPLI),0)<=0
 Call SYSTEME(MACHINE,'archive -n -f -d'-APPLI,"",STAT) From ORDSYS
 Call CRE_CLASS_OBJECT(APPLI) From DOSAPL
Elsif filinfo(filpath("STC","OBJECT","stc",APPLI),0)<=0
 Call CRE_CLASS_OBJECT(APPLI) From DOSAPL
Endif
Return

