#<AdxTL>@(#)1.0.0.0 $Revision$
############################################################################
# UTITRC1   Utilitaire de récupération du bug 39339    Module Tronc commun #
# ------------------------------------------------------------------------ #
# Problème à résoudre :                                                    #
#   Initialiser la valeur du champ BPAADDFLG si nécessaire                 #
############################################################################

Call MAJ_UTITRC1
End

Subprog MAJ_UTITRC1
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTITRC1") From SAIDOS
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTITRC1 : Utilitaire de màj indicateur code adresse par défaut") From LECFIC
If DOSSIER<>"" Call EXE_UTITRC1(DOSSIER) : Endif
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End

Subprog EXE_UTITRC1(DOSSIER)
Value Char DOSSIER
#----- Variables locales -----#
Local Char     WMSG(80), CLE2(15), CLE3(3), CRITERE(60), WNUM(21), WADR(3)
Local Integer COMPTEUR, STOP
Local Integer  NBENR,    NBCOR,    CLE1,    WFLAG
#-----
Call ECR_TRACE("UTITRC1 : Début traitement du dossier "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:BPA]) =0  Local File =DOSSIER+".BPADDRESS"   [BPA] : Endif
If clalev([F:BPR]) =0  Local File =DOSSIER+".BPARTNER"    [BPR] : Endif
If clalev([F:CPY]) =0  Local File =DOSSIER+".COMPANY"     [CPY] : Endif
If clalev([F:FCY]) =0  Local File =DOSSIER+".FACILITY"    [FCY] : Endif
If clalev([F:AUS]) =0  Local File =DOSSIER+".AUTILIS"     [AUS] : Endif
If clalev([F:GAC]) =0  Local File =DOSSIER+".GACCOUNT"    [GAC] : Endif
#----- Début du traitement -----#
Call DEBTRANS From GLOCK
Raz CLE1, CLE2, CLE3, NBENR, NBCOR, STOP
#-----
$BOUCLE_BPA
If  STOP=1
  CRITERE = 'BPATYP='+num$(CLE1)+' & BPANUM="'+CLE2+'" & BPAADD>"'+CLE3+'"'
  STOP = 2
Elsif STOP=2
  CRITERE = 'BPATYP='+num$(CLE1)+' & BPANUM>"'+CLE2+'"'
  STOP = 3
Elsif STOP=3
  CRITERE = 'BPATYP>'+num$(CLE1)
  STOP = 0
Else
  CRITERE = "1=1" 
Endif
Raz COMPTEUR
Trbegin [BPA]
  For [BPA] BPA0 Where evalue(CRITERE)
    WNUM=num$([F:BPA]BPATYP)-[F:BPA]BPANUM-[F:BPA]BPAADD
    NBENR+=1
    Raz WADR
    Case [F:BPA]BPATYP
      When 1 : #----- Tiers -----#
        If [F:BPR]BPRNUM<>[F:BPA]BPANUM
          Read [BPR] BPR0=[F:BPA]BPANUM   : If fstat  Raz [F:BPR] : Endif
        Endif
        WADR=[F:BPR]BPAADD
      When 2 : #----- Société -----#
        If [F:CPY]CPY<>[F:BPA]BPANUM
          Read [CPY] CPY0=[F:BPA]BPANUM   : If fstat  Raz [F:CPY] : Endif
        Endif
        WADR=[F:CPY]BPAADD
      When 3 : #----- Site -----#
        If [F:FCY]FCY<>[F:BPA]BPANUM
          Read [FCY] FCY0=[F:BPA]BPANUM   : If fstat  Raz [F:BPR] : Endif
        Endif
        WADR=[F:FCY]BPAADD
      When 4 : #----- Utilisateur -----#
        If [F:AUS]USR<>[F:BPA]BPANUM
          Read [AUS] CODUSR=[F:BPA]BPANUM : If fstat  Raz [F:AUS] : Endif
        Endif
        WADR=[F:AUS]BPAADD
      When 5 : #----- Compte -----#
        If [F:GAC]ACC<>[F:BPA]BPANUM
          Read [GAC] GAC0=[F:BPA]BPANUM   : If fstat  Raz [F:GAC] : Endif
        Endif
        WADR=[F:GAC]BPAADD
    Endcase
    If [F:BPA]BPAADD=WADR  WFLAG=2  Else  WFLAG=1 : Endif
    If [F:BPA]BPAADDFLG<>WFLAG
      If COMPTEUR=0
        Call ECR_TRACE("----- Début de transaction ("+WNUM+")",0) From GESECRAN
      Endif
      COMPTEUR+=1
      Readlock [BPA] Curr
      If fstat 
        Call ECR_TRACE("File BPADDRESS"-WNUM+", Error ="-num$(fstat),1) From GESECRAN
        GOK=0
      Else
        [F:BPA]BPAADDFLG=WFLAG
        Rewrite [BPA]
        If fstat
          Call ECR_TRACE("File BPADDRESS, Error ="-num$(fstat),1) From GESECRAN
          GOK=0
        Else
          Call ECR_TRACE(WNUM-"Indicateur BPAADDFLG mis à"-num$(WFLAG),0) From GESECRAN
          NBCOR+=1
        Endif
      Endif
      If GOK=1
        COMPTEUR+=1
        If COMPTEUR>GMAXUPDTRS
          CLE1=[F:BPA]BPATYP : CLE2=[F:BPA]BPANUM : CLE3=[F:BPA]BPAADD : STOP=1 : Break
        Endif
      Else
        Break
      Endif
    Endif
  Next
  If GOK=0
    Rollback
    Call ECR_TRACE("----- Transaction abandonnée ("+WNUM+")",1) From GESECRAN
    Goto FIN_UTITRC1
  Endif
Commit
If COMPTEUR>0
  Call ECR_TRACE("----- Transaction validée ("+WNUM+")",0) From GESECRAN
Endif
If STOP  Goto BOUCLE_BPA : Endif
#----- Fin du traitement -----#
$FIN_UTITRC1
WMSG ="UTITRC1 : Nbre d'enregistrements traités :"-num$(NBENR)
WMSG+=" dont corrigés :"-num$(NBCOR)
Call ECR_TRACE(WMSG,0) From GESECRAN
Close Local File [BPA], [BPR], [CPY], [FCY], [AUS], [GAC]
End
