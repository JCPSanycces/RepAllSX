##########################################################################################################
#  Sous-programmes pour la gestion des solutions                 Module CRM     12 octobre 2000  #
##################################################################################################
#                                                                                                #
#  CRE_KWD    : Assure la mise à jour d'un mot-clé.                                              #
#  CKWD       : Création d'un nouveau mot-clé.                                                   #
#  UKWD       : Modification d'un mot-clé.                                                       #
#  DKWD       : Suppression d'un mot clé.                                                        #
#  DISPICON   : Affichage des icônes
#  SAVEHD3    : Enregistrement des CLOBs
#  DELHD3     : Suppression des CLOBs
#  LOADHD3    : Chargement des CLOBs
#                                                                                                #
##################################################################################################

##########################################################################################################
#  CRE_KWD : Assure la mise à jour d'un mot-clé.
##################################################################################################
Subprog CRE_KWD(SZOLDVAL, SZNEWVAL)
Variable Char SZOLDVAL
Variable Char SZNEWVAL

  #Rien
  If SZOLDVAL = "" and SZNEWVAL = "" Then
    End
  Endif

Local Integer ISPAPLC
Local Char SZOWORD
Local Char SZNWORD

  ISPAPLC = 0
  SZOWORD = toupper(SZOLDVAL)
  SZNWORD = toupper(SZNEWVAL)
  If SZOWORD <> "" Then
    ISPAPLC = instr(1, SZOWORD, ' ')
    If ISPAPLC > 0 Then
      SZOWORD = left$(SZOWORD, ISPAPLC-1)
    Endif
  Endif
  If SZNWORD <> "" Then
    ISPAPLC = instr(1, SZNWORD, ' ')
    If ISPAPLC > 0 Then
      SZNWORD = left$(SZNWORD, ISPAPLC-1)
    Endif
  Endif
  #Pas de modification
  If SZOLDVAL = SZNEWVAL Then
    End
  Endif
  #Création d'une nouvelle valeur
  If SZOLDVAL = "" and SZNEWVAL <> "" Then
    Call CKWD(SZNWORD)
  Endif
  #Modification d'un ancien mot-clé.
  If SZOLDVAL <> "" and SZNEWVAL <> "" Then
    Call UKWD(SZOWORD, SZNWORD)
  Endif
  #Suppression d'un mot clé
  If SZOLDVAL <> "" and SZNEWVAL = "" Then
    Call DKWD(SZOWORD)
  Endif
End

##########################################################################################################
# CKWD : Création d'un nouveau mot clé
###########################################################################
Subprog CKWD(SZNEWWRD)
Variable Char SZNEWWRD

Local Integer IMORE

  If !clalev([F:EKW]) : Local File EXKWORD [EKW] : Endif
  IMORE = 0
  Readlock [EKW]EKW0=SZNEWWRD
  If !fstat Then
    Call DEBTRANS From GLOCK
    IMORE = [F:EKW]WRDCOU
    IMORE += 1
    [F:EKW]WRDCOU = IMORE
    Trbegin [EKW]
    Rewrite [EKW]
    If fstat Then
      GMESSAGE = mess(101,141,1) #Erreur modification
      GERR = 1
      Unlock [EKW]
      Rollback
      End
    Endif
    Commit
  Else    
    Call DEBTRANS From GLOCK
    [F:EKW]KEYWRD = SZNEWWRD
    [F:EKW]WRDCOU = 1
    Trbegin [EKW]
    Write [EKW]
    If fstat Then
      GMESSAGE = mess(100,141,1) #Erreur création
      GERR = 1
      Unlock [EKW]
      Rollback
      End
    Endif
    Commit
  Endif
End

##########################################################################################################
# UKWD : Modification d'un mot clé
###########################################################################
Subprog UKWD(SZOLDWRD, SZNEWWRD)
Variable Char SZOLDWRD
Variable Char SZNEWWRD

  Call DKWD(SZOLDWRD)
  Call CKWD(SZNEWWRD)
End

##########################################################################################################
# DKWD : Suppression d'un mot clé
###########################################################################
Subprog DKWD(SZOLDWRD)
Variable Char SZOLDWRD

Local Integer ILESS

  If !clalev([F:EKW]) : Local File EXKWORD [EKW] : Endif
  ILESS = 0
  #Décrement ou supprime l'ancienne valeur.
  Readlock [EKW]EKW0=SZOLDWRD
  If !fstat Then
    Call DEBTRANS From GLOCK
    ILESS = [F:EKW]WRDCOU
    ILESS -= 1
    [F:EKW]WRDCOU = ILESS
    Trbegin [EKW]
    If ILESS <= 0 Then
      Delete [EKW] Curr
    Else
      Rewrite [EKW]
    Endif
    If fstat Then
      GMESSAGE = mess(101,141,1) #Erreur modification
      GERR = 1
      Unlock [EKW]
      Rollback
      End
    Endif
    Commit
  Endif
End

##########################################################################################################
#Affichage des icônes
######################################################
$DISPICON
  Gosub DEFICONNUM From CRMUTIL150
  #Synthèse description demande de service
  If len([M:SOL1]PBLFULDES) > GLONCLE Then
    If [M:SOL1]PBLDESFLG Then
      [M:SOL1]PBLDESICO = SZICOSYNDON
    Else
      [M:SOL1]PBLDESICO = SZICOSYN
    Endif
  Else    
    [M:SOL1]PBLDESICO = "-1"    
  Endif
  #Synthèse solution
  If len([M:SOL2]SOLFULDES) > GLONCLE Then
    If [M:SOL2]SOLDESFLG Then
      [M:SOL2]SOLDESICO = SZICOSYNDON
    Else
      [M:SOL2]SOLDESICO = SZICOSYN
    Endif
    Actzo [M:SOL2]SOLDESICO
  Else
    [M:SOL2]SOLDESICO = "-1"    
    Grizo [M:SOL2]SOLDESICO
  Endif
Return

##########################################################################################################
#Enregistrement des CLOBs
######################################################
$SAVEHD3
Local Char SZCTLCLOB(250)

  Gosub DELHD3
  If GOK < 1 Then
    Return
  Endif
  Raz SZCTLCLOB
  Setlob SZCTLCLOB With [M:SOL1]PBLFULDES
  If SZCTLCLOB <> "" Then
    Raz [F:HD3]
    [F:HD3]NUM = [M:SOL1]NUMPBLDES
    [F:HD3]TYP = [M:SOL1]TYPPBLDES
    [F:HD3]CLOB = [M:SOL1]PBLFULDES
    Write [HD3]
    If fstat Then
      #Erreur lors de l'enregistrement de la description complète de la demande d'origine. Transaction abandonnée.
      GMESSAGE = mess(842,182,1)
      GERR = 1
      Call FSTA("HD3") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
  Raz SZCTLCLOB
  Setlob SZCTLCLOB With [M:SOL2]SOLFULDES
  If SZCTLCLOB <> "" Then
    Raz [F:HD3]
    [F:HD3]NUM = [M:SOL2]NUMSOLDES
    [F:HD3]TYP = [M:SOL2]TYPSOLDES
    [F:HD3]CLOB = [M:SOL2]SOLFULDES
    Write [HD3]
    If fstat Then
      #Erreur lors de l'enregistrement de la description complète de la solution. Transaction abandonnée.
      GMESSAGE = mess(844,182,1)
      GERR = 1
      Call FSTA("HD3") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
#Suppression des CLOBs
######################################################
$DELHD3
  Delete [HD3] Where [F:HD3]NUM = [M:SOL1]NUMPBLDES and [F:HD3]TYP = [M:SOL1]TYPPBLDES
  If fstat Then
    #Erreur lors de la suppression de la description complète de la demande d'origine. Transaction abandonnée.
    GMESSAGE = mess(843,182,1)
    GERR = 1
    Call FSTA("HD3") From GLOCK
    GOK = 0
    Return
  Endif
  Delete [HD3] Where [F:HD3]NUM = [M:SOL2]NUMSOLDES and [F:HD3]TYP = [M:SOL2]TYPSOLDES
  If fstat Then
    #Erreur lors de la suppression de la description complète de la solution. Transaction abandonnée.
    GMESSAGE = mess(845,182,1)
    GERR = 1
    Call FSTA("HD3") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
# Chargement des CLOBs
######################################################
$LOADHD3
Local Integer ILOOKFORCLOB

  ILOOKFORCLOB = 1
  If [M:SOL1]NUMPBLDES = "" Then
    Raz [M:SOL1]PBLFULDES
    ILOOKFORCLOB = 0
  Endif
  If [M:SOL1]TYPPBLDES = "" Then
    Raz [M:SOL1]PBLFULDES
    ILOOKFORCLOB = 0
  Endif
  If ILOOKFORCLOB Then
    Read [HD3]HD30=[M:SOL1]NUMPBLDES;[M:SOL1]TYPPBLDES
    If fstat Then
      Raz [M:SOL1]PBLFULDES
    Else
      [M:SOL1]PBLFULDES = [F:HD3]CLOB
    Endif
  Endif
  ILOOKFORCLOB = 1
  If [M:SOL2]NUMSOLDES = "" Then
    Raz [M:SOL2]SOLFULDES
    ILOOKFORCLOB = 0
  Endif
  If [M:SOL2]TYPSOLDES = "" Then
    Raz [M:SOL2]SOLFULDES
    ILOOKFORCLOB = 0
  Endif
  If ILOOKFORCLOB Then
    Read [HD3]HD30=[M:SOL2]NUMSOLDES;[M:SOL2]TYPSOLDES
    If fstat Then
      Raz [M:SOL2]SOLFULDES
    Else
      [M:SOL2]SOLFULDES = [F:HD3]CLOB
    Endif
  Endif
Return
