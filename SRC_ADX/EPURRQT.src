#<AdxTL>@(#)8.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AHISTO","AHISTO",3,"") From GTRAITE
End

#------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"  : Gosub OUVRE
 When "FILTRE" : Gosub FILTRE
 When "EPURE"  : Gosub EPURE
Endcase
Return

$OUVRE
Local Integer REQUETE , DROIT
Local Char    FICTRA(GDIMFIC) , MESSA(80) , OGFONCTION(GLONAFC)
Local Char    FILRQT(250)
OFONCTION = GFONCTION
GFONCTION = "AREQUETE"
Call AUTORIS From EXEFNC
DROIT = instr(1,GUSRAUZ(1),"U")
GFONCTION = OFONCTION
Call AUTORIS From EXEFNC
If clalev([ABP])=0  : Local File ABATPAR  [ABP]  : Endif
If clalev([ABR])=0  : Local File ABATRQT  [ABR]  : Endif
If clalev([ABL])=0  : Local File ABATRQTL [ABL]  : Endif
If clalev([ABR2])=0 : Local File ABATRQT  [ABR2] : Endif
Read [ABP]SPOOL First
If !SIMUL
 FICTRA = func SERVSYS.GET_FILE_SERVEUR("tra") : #109897    # Issue X3-70499 - 2018-03-05 by CCC : whole path => with extension file
 If FICTRA=""
    GMESSAGE = mess(86,133,1)-func SERVSYS.GET_BATCH_TRA_DIRECTORY("", "")
    GERR = 1
    Return
 Endif
 MESSA = mess(37,134,1) : # Epuration requêtes
 MESSA -= "=>["+format$(GFMD,REFDAT)+"]"
 MESSA -= "("+GUSER+")"
 Call STRACE(FICTRA,54100,0,MESSA) From SERVEUR
Endif
Gosub DEBLOCAGE_RQT
Return

## 1  : En attente
## 2  : En cours
## 3  : Terminée
## 4  : Bloquée
## 5  : A tuer
## 6  : Avortée
## 7  : Erreur
## 8  : Hors délai

$FILTRE
FILTSUP = '!find(FLAG,1,2,4,5)'
If !DROIT
 FILTSUP -= '& DOSSIER="'+nomap+'" & USER="'+GUSER+'"'
Endif
Return

$EPURE
REQUETE = [F:F1]NUMREQ
If !SIMUL
 #109897
 #Call EFF_FIC(REQUETE,[F:ABP]APPLI)
 Call EFF_FIC(REQUETE)
 Call EFF_JOB([F:F1]JOB)
Endif
Return

#---------------------------------------------------------------#
# Demande 97415 du 4.3.14
# Les requêtes "Bloquée" sans requêtes du même groupe
# "En attente" ou "En cours" sont mises en "Hors délai"
# pour pouvoir être épurées
#---------------------------------------------------------------#

$DEBLOCAGE_RQT
FILRQT = 'FLAG = 4'
FILRQT -= '& DFIN<=['+format$(GFMD,REFDAT)+']'
If !DROIT
 FILRQT -= '& DOSSIER="'+nomap+'" & USER="'+GUSER+'"'
Endif
GOK = 1
Filter [ABR] Where evalue(FILRQT)
If !SIMUL
 Gosub TR_DEBLOC
Else
 Gosub LST_DEBLOC
Endif
Filter [ABR]
Return

$TR_DEBLOC
Trbegin [ABR]
 Gosub LST_DEBLOC
 If GOK<1 : Goto AB_DEBLOC : Endif
Commit
Return

$AB_DEBLOC
Rollback
Return

$LST_DEBLOC
For [ABR]FLAG
 K = 0
 For [ABR2]FLAG Where NUMGRP=[F:ABR]NUMGRP & find(FLAG,1,2)
  K = 1
 Next ABR2
 If !K
  If !SIMUL
   [F:ABR]FLAG = 8
   Rewrite [ABR]
   If fstat
    GOK = 0 : Call FSTA("ABR") From GLOCK : Break
   Endif
  Else
   # Modification du statut de la requête $1$: $2$ -> $3$
   Call ECR_TRACE(func AFNC.MES3(mess(114,134,1),num$([F:ABR]NUMREQ),mess([F:ABR]FLAG,21,1),mess(8,21,1)),0) From GESECRAN
  Endif
 Endif
Next ABR
Return

#--------------------------------------------------#
#  Effacement fichiers temporaires
#--------------------------------------------------#

Subprog EFF_FIC(REQUETE)
Value Integer REQUETE
Local Char    FICHIER(GDIMFIC), CODE(20), SUF(10), REP(10)
Local Integer ERR , STAT

Local Char    SERVEUR(250)
 Local File ABATPAR [ABP]
 Read [ABP]SPOOL First
 SERVEUR = [F:ABP]APPLI :#109897 OK

# Le nom des fichiers requêtes sont maintenant (20.6.2) en format fixe,
# mais les fichiers ont pu être générés dans l'ancienne version

For REP="TRA","tmp"
 For SUF = "tra", "pid", "log", "bat"
  For CODE = format$("N0:8#",REQUETE) , num$(REQUETE)
   FICHIER = filpath(REP,"RQT"+CODE,SUF,SERVEUR)
   Call EXISTE(FICHIER,ERR) From ORDSYS
   If ERR = 1
    Call EFFACE(FICHIER,STAT) From ORDSYS
    Break
   Endif
  Next CODE
 Next SUF
Next REP

#109897
For REP="TRA","tmp"
 For SUF = "tra", "pid", "log", "bat"
  For CODE = format$("N0:8#",REQUETE) , num$(REQUETE)
   FICHIER = func SERVSYS.GET_ONEFILE_BATCH(REP,"RQT"+CODE,SUF)
   Call EXISTE(FICHIER,ERR) From ORDSYS
   If ERR = 1
    Call EFFACE(FICHIER,STAT) From ORDSYS
    Break
   Endif
  Next CODE
 Next SUF
Next REP

End

# Suppression des fichiers job
Subprog EFF_JOB(JOB)
Value Char JOB
Local Char SUF(10)
If JOB<>""
 For SUF = "job", "sta", "req", "run", "old", "kil"
  Call DELJOB(JOB,SUF) From SERVJOB
 Next SUF
Endif
End

