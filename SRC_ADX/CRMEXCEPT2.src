############################################################################################################
$XMLCNT
  #Interlocuteur
  Call TEXTE(10981, SZCTAOBTITLE) From OBJDIV
  Gosub DOSTARTTAG From CRMXML140
  #On extrait les champs de la table 
  For ITERSORT = 1 To 250
    For ICONTACT = 0 To dim(SZTAGCNT) - 1
      If SZTAGCNT(ICONTACT) = "" Then
        Break
      Endif
      If IHIDECNT(ICONTACT) = 0 Then
        If ISORTCNT(ICONTACT) = ITERSORT Then
          SZLABELFORFILL = SZLABELCNT(ICONTACT)
          Gosub DOSTARTFIELD From CRMXML140
          If SZTAGCNT(ICONTACT) = "CCNFULNAM" Then
            Read [AIN]AIN0=[F:CNT]CCNCRM
            If !fstat Then
              Call BUILDFULNAM("AIN", SZDATAFORFILL) From CRMUTIL140
              Gosub WRITEXML From CRMXML140
              Gosub DOENDFIELD From CRMXML140
            Endif
          Else
            SZABR = "CNT"
            SZFIE = SZFIECNT(ICONTACT)
            SZTABLE = "CONTACT"
            Gosub WRITEXML From CRMXML140
            Gosub DOENDFIELD From CRMXML140
          Endif
        Endif
      Endif
    Next
  Next
  Gosub DOENDTAG From CRMXML140
Return

