          Gosub DOENDFIELD From CRMXML140
        Endif
      Endif
    Next
  Next
  Gosub DOENDTAG From CRMXML140
Return

############################################################################################################
$XSDSRM
Local Integer INBSRNMAX

  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + "xs:complexType name=" + VQ + "SRM_TYPE" + VQ + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + "xs:sequence" + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  #On extrait les champs de la table 
  For ITERSORT = 1 To 250
    For ISREMAC  = 0 To dim(SZTAGSRM) - 1
      If SZTAGSRM(ISREMAC) = "" Then
        Break
      Endif
      If IHIDESRM(ISREMAC) = 0 Then
        If ISORTSRM(ISREMAC) = ITERSORT Then
          SZLABELFORFILL = SZLABELSRM(ISREMAC)
          SZABR = "SRM"
          SZFIE = SZFIESRM(ISREMAC)
          SZTABLE = "SREMAC"
          Gosub CHKSRMMANDATORY
          Gosub ADDXSDITEM From CRMXML140
        Endif
      Endif
    Next
  Next
  Read [ACV]CODACT="SCN"
  If fstat Then
    INBSRNMAX = 99
  Else
    INBSRNMAX = [F:ACV]DIME
  Endif
  #Génération de la racine
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + "xs:element name=" + VQ + "SRN" + VQ + " maxOccurs=" + VQ + num$(INBSRNMAX) + VQ + " minOccurs=" + VQ + "0" + VQ + " type=" + VQ + "SRN_TYPE" + VQ + C
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + "xs:sequence" + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + "xs:complexType" + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

############################################################################################################
# Détermine les champs obligatoires
######################################################
$CHKSRMMANDATORY
  SZMANDATORY = " minOccurs = " + VQ + "0" + VQ
  SZLMANDATORY = ""
  If SZFIE = "MACNUM" Then
    SZMANDATORY = " minOccurs = " + VQ + "1" + VQ
    SZLMANDATORY = "xs:minLength value= " + VQ + "1" + VQ
  Endif
Return

