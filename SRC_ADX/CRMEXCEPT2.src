############################################################################################################
$XMLMST
  Call TEXTE(18418, SZCTAOBTITLE) From OBJDIV      #Secteur de marché
  Gosub DOSTARTTAG From CRMXML140
  #On extrait les champs de la table
  For ITERSORT = 1 To 250
    For IMARSCT = 0 To dim(SZTAGMST) - 1
      If SZTAGMST(IMARSCT) = "" Then
        Break
      Endif
      If IHIDEMST(IMARSCT) = 0 Then
        If ISORTMST(IMARSCT) = ITERSORT Then
          SZLABELFORFILL = SZLABELMST(IMARSCT)
          Gosub DOSTARTFIELD From CRMXML140
          If SZTAGMST(IMARSCT) = "MSTHD6CLOB0" Then
            #On extrait le clob Description
            Raz SZBUFFTOFILL
            If [F:MST]TYPFULDES <> "" Then
              If [F:MST]NUMFULDES <> "" Then
                Read [HD6]HD60=[F:MST]NUMFULDES;[F:MST]TYPFULDES
                If !fstat Then
                  Raz SZDESCLOBMST
                  Setlob SZDESCLOBMST With [F:HD6]CLOB
                  If SZDESCLOBMST(0) <> "" Then
                    Gosub ADDDEBXMLCLOB From CRMXML140
                    For ITERCLOB = 0 To dim(SZDESCLOBMST) - 1
                      If SZDESCLOBMST(ITERCLOB) <> "" Then
                        SZBUFFTOFILL(0) = SZDESCLOBMST(ITERCLOB)
                        Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                        Wrseq SZBUFFTOFILL(0) Using [FXML]
                      Endif
                    Next
                    Gosub ADDENDXMLCLOB From CRMXML140
                  Endif
                Endif
              Endif
            Endif
          Else
            SZABR = "MST"
            SZFIE = SZFIEMST(IMARSCT)
            SZTABLE = "MARSCT"
            Gosub WRITEXML From CRMXML140
          Endif
          Gosub DOENDFIELD From CRMXML140
        Endif
      Endif
    Next
  Next
  Gosub DOENDTAG From CRMXML140
Return

