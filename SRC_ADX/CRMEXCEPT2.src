############################################################################################################
$XMLTSK
  Call TEXTE(1195, SZCTAOBTITLE) From OBJDIV      #Tâche
  Gosub DOSTARTTAG From CRMXML140
  #On extrait les champs de la table INTERVEN
  For ITERSORT = 1 To 250
    For ITASK = 0 To dim(SZTAGTSK) - 1
      If SZTAGTSK(ITASK) = "" Then
        Break
      Endif
      If IHIDETSK(ITASK) = 0 Then
        If ISORTTSK(ITASK) = ITERSORT Then
          SZLABELFORFILL = SZLABELTSK(ITASK)
          Gosub DOSTARTFIELD From CRMXML140
          Case SZTAGTSK(ITASK)
            When "TSKHD6CLOB0"
              #On extrait le clob Description
              Raz SZBUFFTOFILL
              If [F:TSK]TYPFULOBJ <> "" Then
                If [F:TSK]NUMFULOBJ <> "" Then
                  Read [HD6]HD60=[F:TSK]NUMFULOBJ;[F:TSK]TYPFULOBJ
                  If !fstat Then
                    Raz SZOBJCLOBTSK
                    Setlob SZOBJCLOBTSK With [F:HD6]CLOB
                    If SZOBJCLOBTSK(0) <> "" Then
                      Gosub ADDDEBXMLCLOB From CRMXML140
                      For ITERCLOB = 0 To dim(SZOBJCLOBTSK) - 1
                        If SZOBJCLOBTSK(ITERCLOB) <> "" Then
                          SZBUFFTOFILL(0) = SZOBJCLOBTSK(ITERCLOB)
                          Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                          Wrseq SZBUFFTOFILL(0) Using [FXML]
                        Endif
                      Next
                      Gosub ADDENDXMLCLOB From CRMXML140
                    Endif
                  Endif
                Endif
              Endif
            When "TSKHD4CLOB0"
              #On extrait le clob Compte-rendu
              Raz SZBUFFTOFILL
              If [F:TSK]TYPFULRPO <> "" Then
                If [F:TSK]NUMFULRPO <> "" Then
                  Read [HD4]HD40=[F:TSK]NUMFULRPO;[F:TSK]TYPFULRPO
                  If !fstat Then
                    Raz SZRPOCLOBTSK
                    Setlob SZRPOCLOBTSK With [F:HD4]CLOB
                    If SZRPOCLOBTSK(0) <> "" Then
                      Gosub ADDDEBXMLCLOB From CRMXML140
                      For ITERCLOB = 0 To dim(SZRPOCLOBTSK) - 1
                        If SZRPOCLOBTSK(ITERCLOB) <> "" Then
                          SZBUFFTOFILL(0) = SZRPOCLOBTSK(ITERCLOB)
                          Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                          Wrseq SZBUFFTOFILL(0) Using [FXML]
                        Endif
                      Next
                      Gosub ADDENDXMLCLOB From CRMXML140
                    Endif
                  Endif
                Endif
              Endif
            When Default
              SZABR = "TSK"
              SZFIE = SZFIETSK(ITASK)
              SZTABLE = "TASK"
              Gosub WRITEXML From CRMXML140
          Endcase
          Gosub DOENDFIELD From CRMXML140
        Endif
      Endif
    Next
  Next
  Gosub DOENDTAG From CRMXML140
Return

############################################################################################################
$XMLCLL
  Call TEXTE(13606, SZCTAOBTITLE) From OBJDIV      #Appel
  Gosub DOSTARTTAG From CRMXML140
  #On extrait les champs de la table INTERVEN
  For ITERSORT = 1 To 250
    For IPHONECALL = 0 To dim(SZTAGCLL) - 1
      If SZTAGCLL(IPHONECALL) = "" Then
        Break
      Endif
      If IHIDECLL(IPHONECALL) = 0 Then
        If ISORTCLL(IPHONECALL) = ITERSORT Then
          SZLABELFORFILL = SZLABELCLL(IPHONECALL)
          Gosub DOSTARTFIELD From CRMXML140
          Case SZTAGCLL(IPHONECALL)
            When "CLLHD5CLOB0"
              #On extrait le clob Description
              Raz SZBUFFTOFILL
              If [F:CLL]TYPFULOBJ <> "" Then
                If [F:CLL]NUMFULOBJ <> "" Then
                  Read [HD5]HD50=[F:CLL]NUMFULOBJ;[F:CLL]TYPFULOBJ
                  If !fstat Then
                    Raz SZOBJCLOBCLL
                    Setlob SZOBJCLOBCLL With [F:HD5]CLOB
                    If SZOBJCLOBCLL(0) <> "" Then
                      Gosub ADDDEBXMLCLOB From CRMXML140
                      For ITERCLOB = 0 To dim(SZOBJCLOBCLL) - 1
                        If SZOBJCLOBCLL(ITERCLOB) <> "" Then
                          SZBUFFTOFILL(0) = SZOBJCLOBCLL(ITERCLOB)
                          Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                          Wrseq SZBUFFTOFILL(0) Using [FXML]
                        Endif
                      Next
                      Gosub ADDENDXMLCLOB From CRMXML140
                    Endif
                  Endif
                Endif
              Endif
            When "CLLHD4CLOB0"
              #On extrait le clob Compte-rendu
              Raz SZBUFFTOFILL
              If [F:CLL]TYPFULRPO <> "" Then
                If [F:CLL]NUMFULRPO <> "" Then
                  Read [HD4]HD40=[F:CLL]NUMFULRPO;[F:CLL]TYPFULRPO
                  If !fstat Then
                    Raz SZRPOCLOBCLL
                    Setlob SZRPOCLOBCLL With [F:HD4]CLOB
                    If SZRPOCLOBCLL(0) <> "" Then
                      Gosub ADDDEBXMLCLOB From CRMXML140
                      For ITERCLOB = 0 To dim(SZRPOCLOBCLL) - 1
                        If SZRPOCLOBCLL(ITERCLOB) <> "" Then
                          SZBUFFTOFILL(0) = SZRPOCLOBCLL(ITERCLOB)
                          Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                          Wrseq SZBUFFTOFILL(0) Using [FXML]
                        Endif
                      Next
                      Gosub ADDENDXMLCLOB From CRMXML140
                    Endif
                  Endif
                Endif
              Endif
            When Default
              SZABR = "CLL"
              SZFIE = SZFIECLL(IPHONECALL)
              SZTABLE = "PHONECALL"
              Gosub WRITEXML From CRMXML140
          Endcase
          Gosub DOENDFIELD From CRMXML140
        Endif
      Endif
    Next
  Next
  Gosub DOENDTAG From CRMXML140
Return

############################################################################################################
$XMLCTT
  Call TEXTE(14505, SZCTAOBTITLE) From OBJDIV      #Tentative d'appel
  Gosub DOSTARTTAG From CRMXML140
  #On extrait les champs de la table 
  For ITERSORT = 1 To 250
    For ICALLATTEMP = 0 To dim(SZTAGCTT) - 1
      If SZTAGCTT(ICALLATTEMP) = "" Then
        Break
      Endif
      If IHIDECTT(ICALLATTEMP) = 0 Then
        If ISORTCTT(ICALLATTEMP) = ITERSORT Then
          SZLABELFORFILL = SZLABELCTT(ICALLATTEMP)
          Gosub DOSTARTFIELD From CRMXML140
          SZABR = "CTT"
          SZFIE = SZFIECTT(ICALLATTEMP)
          SZTABLE = "CALLATTEMP"
          Gosub WRITEXML From CRMXML140
          Gosub DOENDFIELD From CRMXML140
        Endif
      Endif
    Next
  Next
  Gosub DOENDTAG From CRMXML140
Return

############################################################################################################
$XMLAIN
  Call TEXTE(10981, SZCTAOBTITLE) From OBJDIV      #Interlocuteur
  Gosub DOSTARTTAG From CRMXML140
  #On extrait les champs de la table 
  For ITERSORT = 1 To 250
    For ICONTACTCRM = 0 To dim(SZTAGAIN) - 1
      If SZTAGAIN(ICONTACTCRM) = "" Then
        Break
      Endif
      If IHIDEAIN(ICONTACTCRM) = 0 Then
        If ISORTAIN(ICONTACTCRM) = ITERSORT Then
          SZLABELFORFILL = SZLABELAIN(ICONTACTCRM)
          Gosub DOSTARTFIELD From CRMXML140
          SZABR = "AIN"
          SZFIE = SZFIEAIN(ICONTACTCRM)
          SZTABLE = "CONTACTCRM"
          Gosub WRITEXML From CRMXML140
          Gosub DOENDFIELD From CRMXML140
        Endif
      Endif
    Next
  Next
  Gosub DOENDTAG From CRMXML140
Return

############################################################################################################
$XSDSRE
Local Integer INBSRMMAX

  #Génération de la racine
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + "xs:element name=" + VQ + SZAOBABREV + VQ + " type=" + VQ + SZAOBABREV + "_TYPE" + VQ + C
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + "xs:complexType name=" + VQ + SZAOBABREV + "_TYPE" + VQ + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + "xs:sequence" + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  #On extrait les champs de la table 
  For ITERSORT = 1 To 250
    For ISERREQUEST  = 0 To dim(SZTAGSRE) - 1
      If SZTAGSRE(ISERREQUEST) = "" Then
        Break
      Endif
      If IHIDESRE(ISERREQUEST) = 0 Then
        If ISORTSRE(ISERREQUEST) = ITERSORT Then
          SZLABELFORFILL = SZLABELSRE(ISERREQUEST)
          Case SZTAGSRE(ISERREQUEST)
            When "SREHD1CLOB0"
              SZABR = "HD1"
              SZFIE = "CLOB"
              SZTABLE = "HD1CLOB"
            When Default
              SZABR = "SRE"
              SZFIE = SZFIESRE(ISERREQUEST)
              SZTABLE = "SERREQUEST"
          Endcase
          Gosub CHKSREMANDATORY
          Gosub ADDXSDITEM From CRMXML140
        Endif
      Endif
    Next
  Next
  Read [ACV]CODACT="SMA"
  If fstat Then
    INBSRMMAX = 999
  Else
    INBSRMMAX = [F:ACV]DIME
  Endif
  #Génération de la racine
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + "xs:element name=" + VQ + "SRM" + VQ + " maxOccurs=" + VQ + num$(INBSRMMAX) + VQ + " minOccurs=" + VQ + "0" + VQ + " type=" + VQ + "SRM_TYPE" + VQ + C
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + "xs:sequence" + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + "xs:complexType" + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

############################################################################################################
# Détermine les champs obligatoires
######################################################
$CHKSREMANDATORY
  SZLMANDATORY = ""
  SZMANDATORY = " minOccurs = " + VQ + "0" + VQ
  If SZFIE = "SREBPC" Then
    SZMANDATORY = " minOccurs = " + VQ + "1" + VQ
    SZLMANDATORY = "xs:minLength value= " + VQ + "1" + VQ
  Elsif SZFIE = "SRETTR" Then
    SZMANDATORY = " minOccurs = " + VQ + "1" + VQ
    SZLMANDATORY = "xs:minLength value= " + VQ + "1" + VQ
  Endif
Return
