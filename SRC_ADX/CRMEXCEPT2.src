############################################################################################################
$XMLSOL3
  Gosub DOSTARTTAG From CRMXML140
  #On extrait les champs de la table
  For ITERSORT = 1 To 250
    For ISOLUTION = 0 To dim(SZTAGSOL) - 1
      If SZTAGSOL(ISOLUTION) = "" Then
        Break
      Endif
      If IHIDESOL(ISOLUTION) = 0 Then
        If ISORTSOL(ISOLUTION) = ITERSORT Then
          SZLABELFORFILL = SZLABELSOL(ISOLUTION)
          Gosub DOSTARTFIELD From CRMXML140
          Case SZTAGSOL(ISOLUTION)
            When "PBLHD3CLOB0"
              #On extrait le clob Description de la demande
              Raz SZBUFFTOFILL
              If [F:SOL]TYPPBLDES <> "" Then
                If [F:SOL]NUMPBLDES <> "" Then
                  Read [HD3]HD30=[F:SOL]NUMPBLDES;[F:SOL]TYPPBLDES
                  If !fstat Then
                    Raz SZPBLCLOBSOL
                    Setlob SZPBLCLOBSOL With [F:HD3]CLOB
                    If SZPBLCLOBSOL(0) <> "" Then
                      Gosub ADDDEBXMLCLOB From CRMXML140
                      For ITERCLOB = 0 To dim(SZPBLCLOBSOL) - 1
                        If SZPBLCLOBSOL(ITERCLOB) <> "" Then
                          SZBUFFTOFILL(0) = SZPBLCLOBSOL(ITERCLOB)
                          Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                          Wrseq SZBUFFTOFILL(0) Using [FXML]
                        Endif
                      Next
                      Gosub ADDENDXMLCLOB From CRMXML140
                    Endif
                  Endif
                Endif
              Endif
            When "SOLHD3CLOB0"
              #On extrait le clob Description de la solution
              Raz SZBUFFTOFILL
              If [F:SOL]TYPSOLDES <> "" Then
                If [F:SOL]NUMSOLDES <> "" Then
                  Read [HD3]HD30=[F:SOL]NUMSOLDES;[F:SOL]TYPSOLDES
                  If !fstat Then
                    Raz SZSOLCLOBSOL
                    Setlob SZSOLCLOBSOL With [F:HD3]CLOB
                    If SZSOLCLOBSOL(0) <> "" Then
                      Gosub ADDDEBXMLCLOB From CRMXML140
                      For ITERCLOB = 0 To dim(SZSOLCLOBSOL) - 1
                        If SZSOLCLOBSOL(ITERCLOB) <> "" Then
                          SZBUFFTOFILL(0) = SZSOLCLOBSOL(ITERCLOB)
                          Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                          Wrseq SZBUFFTOFILL(0) Using [FXML]
                        Endif
                      Next
                      Gosub ADDENDXMLCLOB From CRMXML140
                    Endif
                  Endif
                Endif
              Endif
            When Default
              SZABR = "SOL"
              SZFIE = SZFIESOL(ISOLUTION)
              SZTABLE = "SOLUTION"
              Gosub WRITEXML From CRMXML140
          Endcase
          Gosub DOENDFIELD From CRMXML140
        Endif
      Endif
    Next
  Next
  Gosub DOENDTAG From CRMXML140
Return

