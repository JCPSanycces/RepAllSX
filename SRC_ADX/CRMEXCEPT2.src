#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################################################
$SETBAPEXCEPT
Local Char SZAOBEXPTAB(GLONATB)
Local Char SZAOBEXPABR(GLONABR)

  #Tables de travail
  If !clalev([F:BAP]) : Local File BAPPOINT [BAP] : Endif
  If !clalev([F:HD4]) : Local File HD4CLOB [HD4] : Endif
  If !clalev([F:HD6]) : Local File HD6CLOB [HD6] : Endif
  #Tables pour gestion des exceptions
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  SZAOBEXPTAB = "BAPPOINT"
  SZAOBEXPABR = "BAP"
  Gosub SETAOBEXCEPT From CRMEXCEPT

Local Integer IBAPPOINT

  IBAPPOINT = IAOBEXPCOUNT
  IBAPPOINT += 2 #Pour les clobs

Local Char SZTAGBAP(30)(IBAPPOINT)
Local Char SZFIEBAP(30)(IBAPPOINT)
Local Integer IHIDEBAP(IBAPPOINT)
Local Integer ISORTBAP(IBAPPOINT)
Local Char SZLABELBAP(30)(IBAPPOINT)
Local Integer IDISPLAYBAP

  IDISPLAYBAP = 1
  Raz IHIDEBAP
  Raz ISORTBAP
  Raz SZLABELBAP
  IBAPPOINT = 0
  Filter [ATZ] Where [F:ATZ]CODFIC = SZAOBEXPTAB
  For [ATZ]CODZONE
    IDIMCONTROL = evalue("Dim([F:" + SZAOBEXPABR + "]" + [F:ATZ]CODZONE + ")")
    For ITERDIM = 0 To IDIMCONTROL - 1
      SZTAGBAP(IBAPPOINT) = SZAOBEXPABR + [F:ATZ]CODZONE + num$(ITERDIM)
      If ITERDIM = 0 Then
        SZFIEBAP(IBAPPOINT) = [F:ATZ]CODZONE
      Else
        SZFIEBAP(IBAPPOINT) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
      Endif
      Call TEXTE([F:ATZ]NOLONG, SZLABELBAP(IBAPPOINT)) From OBJDIV
      IBAPPOINT += 1
    Next
  Next
  Filter [ATZ]
  SZTAGBAP(IBAPPOINT) = "BAPHD6CLOB0"
  Call TEXTE(14733, SZLABELBAP(IBAPPOINT)) From OBJDIV   #Objectif du rendez-vous
  IBAPPOINT += 1
  SZTAGBAP(IBAPPOINT) = "BAPHD4CLOB0"
  Call TEXTE(14438, SZLABELBAP(IBAPPOINT)) From OBJDIV   #Compte-rendu
  IDIMCONTROL = dim(SZTAGBAP) - 1
  #Définition des attributs
  For ITER = 0 To IDIMCONTROL
    #Attribut de visibilité
    Gosub SETBAPHIDE
  Next
  #Attribut de tri
  Gosub SETBAPSORT
  #On vérifie les doublons possibles de tags
  IDUPLICATE = 0
  While 1
    IDUPLICATE = 0
    For ITER = 0 To IDIMCONTROL
      For ITER2 = 0 To IDIMCONTROL
        If ITER2 <> ITER Then
          If SZTAGBAP(ITER) <> "" Then
            If SZTAGBAP(ITER2) <> "" Then
              If SZTAGBAP(ITER2) = SZTAGBAP(ITER) Then
                SZTAGBAP(ITER2) = SZTAGBAP(ITER2) + "X"
                IDUPLICATE = 1
                Break
              Endif
            Endif
          Endif
        Endif
      Next
      If IDUPLICATE Then
        Break
      Endif
    Next
    If IDUPLICATE = 0 Then
      Break
    Endif
  Wend

#Dimensionnement des buffers clobs
Local Integer I4LNGCLOB
Local Integer I4NBBYTES
Local Integer I4BUFFSIZE
Local Integer I6LNGCLOB
Local Integer I6NBBYTES
Local Integer I6BUFFSIZE

  #Description
  Read [ATY]CODTYP="HD6"
  If fstat Then
    I6LNGCLOB = 3
  Else
    I6LNGCLOB = [F:ATY]LNGTYP
  Endif
  If I6LNGCLOB = 0 Then
    I6LNGCLOB = 3    
  Endif
  I6NBBYTES = 1024*(2^I6LNGCLOB)
  I6BUFFSIZE = I6NBBYTES / 35
  I6BUFFSIZE += 5

Local Char SZOBJCLOBBAP(35)(I6BUFFSIZE)

  #Compte-rendu
  Read [ATY]CODTYP="HD4"
  If fstat Then
    I4LNGCLOB = 6
  Else
    I4LNGCLOB = [F:ATY]LNGTYP
  Endif
  If I4LNGCLOB = 0 Then
    I4LNGCLOB = 6
  Endif
  I4NBBYTES = 1024*(2^I4LNGCLOB)
  I4BUFFSIZE = I4NBBYTES / 35
  I4BUFFSIZE += 5

Local Char SZRPOCLOBBAP(35)(I4BUFFSIZE)

  #Modification de la présentation et du tri par point d'entrée
  Gosub PE_AOBEXP From TRTCRMPE
Return

############################################################################################################
#Attribut de visibilité
################################################
$SETBAPHIDE
  #Par défaut, chaque champ est visible
  IHIDEBAP(ITER) = 0
  If SZFIEBAP(ITER) = "TYPFULOBJ" Then
    #Clob
    IHIDEBAP(ITER) = 1
  Elsif SZFIEBAP(ITER) = "NUMFULOBJ" Then
    #Clob
    IHIDEBAP(ITER) = 1
  ElsIf SZFIEBAP(ITER) = "OBJFLG" Then
    #Clob
    IHIDEBAP(ITER) = 1
  ElsIf SZFIEBAP(ITER) = "TYPFULRPO" Then
    #Clob
    IHIDEBAP(ITER) = 1
  ElsIf SZFIEBAP(ITER) = "NUMFULRPO" Then
    #Clob
    IHIDEBAP(ITER) = 1
  ElsIf SZFIEBAP(ITER) = "RPOFLG" Then
    #Clob
    IHIDEBAP(ITER) = 1
  ElsIf SZFIEBAP(ITER) = "APTDATX" Then
    IHIDEBAP(ITER) = 1
  ElsIf left$(SZFIEBAP(ITER), 9) = "APTCCNNUM" Then
    IHIDEBAP(ITER) = 1
  ElsIf left$(SZFIEBAP(ITER), 9) = "APTREPNUM" Then
    IHIDEBAP(ITER) = 1
  ElsIf left$(SZFIEBAP(ITER), 6) = "APTRER" Then
    IHIDEBAP(ITER) = 1
  ElsIf SZFIEBAP(ITER) = "APTTYPADD" Then
    IHIDEBAP(ITER) = 1
  ElsIf SZFIEBAP(ITER) = "APTCODADD" Then
    IHIDEBAP(ITER) = 1
  ElsIf SZFIEBAP(ITER) = "APTRECADD" Then
    IHIDEBAP(ITER) = 1
  #Elsif SZFIEBAP(ITER) = "APTORITXT" Then  # FGR 11/03/2010 : X3SUIVI62924
  #  IHIDEBAP(ITER) = 1
  ElsIf SZFIEBAP(ITER) = "APTCMGNUM" Then
    IHIDEBAP(ITER) = 1
  ElsIf SZFIEBAP(ITER) = "APTOPGNUM" Then
    IHIDEBAP(ITER) = 1
  ElsIf SZFIEBAP(ITER) = "APTOPGTYP" Then
    IHIDEBAP(ITER) = 1
  ElsIf SZFIEBAP(ITER) = "UPDDAT" Then
    #Date modif
    IHIDEBAP(ITER) = 1
  ElsIf SZFIEBAP(ITER) = "UPDUSR" Then
    #Opérateur modif
    IHIDEBAP(ITER) = 1
  Endif
Return

############################################################################################################
#Attribut de tri
################################################
$SETBAPSORT
  ISORT = 0
  For ITER = 0 To dim(SZTAGBAP) - 1
    ISORT = 0
    If SZFIEBAP(ITER) = "APTNUM" Then
      ISORT = 1
    Elsif SZFIEBAP(ITER) = "SALFCY" Then
      ISORT = 2
    ElsIf SZFIEBAP(ITER) = "APTCMP" Then
      ISORT = 3
    ElsIf SZFIEBAP(ITER) = "APTPJT" Then
      ISORT = 4
    ElsIf SZFIEBAP(ITER) = "APTTYP" Then
      ISORT = 5
    ElsIf SZFIEBAP(ITER) = "APTDAT" Then
      ISORT = 6
    ElsIf SZFIEBAP(ITER) = "APTHOU" Then
      ISORT = 7
    ElsIf SZFIEBAP(ITER) = "APTDATEND" Then
      ISORT = 8
    ElsIf SZFIEBAP(ITER) = "APTHOUEND" Then
      ISORT = 9
    ElsIf SZFIEBAP(ITER) = "FULDAY" Then
      ISORT = 10
    ElsIf SZFIEBAP(ITER) = "APTWEE" Then
      ISORT = 11
    ElsIf SZFIEBAP(ITER) = "APTDUR" Then
      ISORT = 12
    ElsIf SZFIEBAP(ITER) = "APTOBJ" Then
      ISORT = 13
    ElsIf SZTAGBAP(ITER) = "BAPHD6CLOB0" Then
      ISORT = 14
    ElsIf SZFIEBAP(ITER) = "APTPLC" Then
      ISORT = 15
    ElsIf SZFIEBAP(ITER) = "APTADD" Then
      ISORT = 16
    ElsIf SZFIEBAP(ITER) = "APTADD(1)" Then
      ISORT = 17
    ElsIf SZFIEBAP(ITER) = "APTADD(2)" Then
      ISORT = 18
    ElsIf SZFIEBAP(ITER) = "APTZIP" Then
      ISORT = 19
    ElsIf SZFIEBAP(ITER) = "APTCTY" Then
      ISORT = 20
    ElsIf SZFIEBAP(ITER) = "APTSAT" Then
      ISORT = 21
    ElsIf SZFIEBAP(ITER) = "APTCRY" Then
      ISORT = 22
    ElsIf SZFIEBAP(ITER) = "APTTEL" Then
      ISORT = 23
    ElsIf SZFIEBAP(ITER) = "APTDON" Then
      ISORT = 24
    ElsIf SZFIEBAP(ITER) = "APTRPO" Then
      ISORT = 25
    ElsIf SZTAGBAP(ITER) = "BAPHD4CLOB0" Then
      ISORT = 26
    ElsIf SZFIEBAP(ITER) = "APTSAO" Then
      ISORT = 27
    #Elsif SZFIEBAP(ITER) = "APTORI" Then
    #  ISORT = 28
    Elsif SZFIEBAP(ITER) = "APTORIADI" Then   # FGR 11/03/2010 : X3SUIVI62924
      ISORT = 28
    Elsif SZFIEBAP(ITER) = "APTORIVCR" Then
      ISORT = 29
    ElsIf SZFIEBAP(ITER) = "APTORIVCRL" Then
      ISORT = 30
    Endif
    ISORTBAP(ITER) = ISORT
  Next
  ISORT = 31
  For ITER = 0 To dim(SZTAGBAP) - 1
    If ISORTBAP(ITER) = 0 Then
      ISORTBAP(ITER) = ISORT
    Endif
    ISORT += 1
  Next
Return

############################################################################################################
$HTMLBAP
  Call TEXTE(14423, SZHTMLTITLE) From OBJDIV      #Rendez-vous
  Gosub DOSTARTTABLE From CRMXML140
  #On extrait les champs de la table
  For ITERSORT = 1 To 250
    For IBAPPOINT = 0 To dim(SZTAGBAP) - 1
      If SZTAGBAP(IBAPPOINT) = "" Then
        Break
      Endif
      If IHIDEBAP(IBAPPOINT) = 0 Then
        If ISORTBAP(IBAPPOINT) = ITERSORT Then
          Case SZTAGBAP(IBAPPOINT)
            When "BAPHD6CLOB0"
              #On extrait le clob Description
              IBAPPOINT = dim(SZTAGBAP) - 2
              Raz SZBUFFTOFILL
              If [F:BAP]TYPFULOBJ <> "" Then
                If [F:BAP]NUMFULOBJ <> "" Then
                  Read [HD6]HD60=[F:BAP]NUMFULOBJ;[F:BAP]TYPFULOBJ
                  If !fstat Then
                    Raz SZOBJCLOBBAP
                    Setlob SZOBJCLOBBAP With [F:HD6]CLOB
                    If SZOBJCLOBBAP(0) <> "" Then
                      SZLABELFORFILL = SZLABELBAP(IBAPPOINT)
                      Gosub ADDDEBTRCLOB From CRMXML140
                      For ITERCLOB = 0 To dim(SZOBJCLOBBAP) - 1
                        If SZOBJCLOBBAP(ITERCLOB) <> "" Then
                          SZBUFFTOFILL(0) = SZOBJCLOBBAP(ITERCLOB)
                          Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                          Wrseq SZBUFFTOFILL(0) Using [FXML]
                        Endif
                      Next
                      Gosub ADDENDTRCLOB From CRMXML140
                    Endif
                  Endif
                Endif
              Endif
            When "BAPHD4CLOB0"
              #On extrait le clob Compte-rendu
              IBAPPOINT = dim(SZFIEBAP) - 1
              Raz SZBUFFTOFILL
              If [F:BAP]TYPFULRPO <> "" Then
                If [F:BAP]NUMFULRPO <> "" Then
                  Read [HD4]HD40=[F:BAP]NUMFULRPO;[F:BAP]TYPFULRPO
                  If !fstat Then
                    Raz SZRPOCLOBBAP
                    Setlob SZRPOCLOBBAP With [F:HD4]CLOB
                    If SZRPOCLOBBAP(0) <> "" Then
                      SZLABELFORFILL = SZLABELBAP(IBAPPOINT)
                      Gosub ADDDEBTRCLOB From CRMXML140
                      For ITERCLOB = 0 To dim(SZRPOCLOBBAP) - 1
                        If SZRPOCLOBBAP(ITERCLOB) <> "" Then
                          SZBUFFTOFILL(0) = SZRPOCLOBBAP(ITERCLOB)
                          Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                          Wrseq SZBUFFTOFILL(0) Using [FXML]
                        Endif
                      Next
                      Gosub ADDENDTRCLOB From CRMXML140
                    Endif
                  Endif
                Endif
              Endif
            When Default
              SZABR = "BAP"
              SZFIE = SZFIEBAP(IBAPPOINT)
              SZTABLE = "BAPPOINT"
              SZLABELFORFILL = SZLABELBAP(IBAPPOINT)
              Gosub WRITEHTMLTR From CRMXML140
          Endcase
        Endif
      Endif
    Next
  Next
  Gosub DOENDTABLE From CRMXML140
Return

############################################################################################################
$XMLBAP
  Call TEXTE(14423, SZCTAOBTITLE) From OBJDIV      #Rendez-vous
  Gosub DOSTARTTAG From CRMXML140
  #On extrait les champs de la table
  For ITERSORT = 1 To 250
    For IBAPPOINT = 0 To dim(SZTAGBAP) - 1
      If SZTAGBAP(IBAPPOINT) = "" Then
        Break
      Endif
      If IHIDEBAP(IBAPPOINT) = 0 Then
        If ISORTBAP(IBAPPOINT) = ITERSORT Then
          SZLABELFORFILL = SZLABELBAP(IBAPPOINT)
          Gosub DOSTARTFIELD From CRMXML140
          Case SZTAGBAP(IBAPPOINT)
            When "BAPHD6CLOB0"
              #On extrait le clob Description
              Raz SZBUFFTOFILL
              If [F:BAP]TYPFULOBJ <> "" Then
                If [F:BAP]NUMFULOBJ <> ""
                  Read [HD6]HD60=[F:BAP]NUMFULOBJ;[F:BAP]TYPFULOBJ
                  If !fstat Then
                    Raz SZOBJCLOBBAP
                    Setlob SZOBJCLOBBAP With [F:HD6]CLOB
                    If SZOBJCLOBBAP(0) <> "" Then
                      Gosub ADDDEBXMLCLOB From CRMXML140
                      For ITERCLOB = 0 To dim(SZOBJCLOBBAP) - 1
                        If SZOBJCLOBBAP(ITERCLOB) <> "" Then
                          SZBUFFTOFILL(0) = SZOBJCLOBBAP(ITERCLOB)
                          Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                          Wrseq SZBUFFTOFILL(0) Using [FXML]
                        Endif
                      Next
                      Gosub ADDENDXMLCLOB From CRMXML140
                    Endif
                  Endif
                Endif
              Endif
            When "BAPHD4CLOB0"
              #On extrait le clob Compte-rendu
              Raz SZBUFFTOFILL
              If [F:BAP]TYPFULRPO <> "" Then
                If [F:BAP]NUMFULRPO <> "" Then
                  Read [HD4]HD40=[F:BAP]NUMFULRPO;[F:BAP]TYPFULRPO
                  If !fstat Then
                    Raz SZRPOCLOBBAP
                    Setlob SZRPOCLOBBAP With [F:HD4]CLOB
                    If SZRPOCLOBBAP(0) <> "" Then
                      Gosub ADDDEBXMLCLOB From CRMXML140
                      For ITERCLOB = 0 To dim(SZRPOCLOBBAP) - 1
                        If SZRPOCLOBBAP(ITERCLOB) <> "" Then
                          SZBUFFTOFILL(0) = SZRPOCLOBBAP(ITERCLOB)
                          Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                          Wrseq SZBUFFTOFILL(0) Using [FXML]
                        Endif
                      Next
                      Gosub ADDENDXMLCLOB From CRMXML140
                    Endif
                  Endif
                Endif
              Endif
            When Default
              SZABR = "BAP"
              SZFIE = SZFIEBAP(IBAPPOINT)
              SZTABLE = "BAPPOINT"
              Gosub WRITEXML From CRMXML140
          Endcase
          Gosub DOENDFIELD From CRMXML140
        Endif
      Endif
    Next
  Next
  Gosub DOENDTAG From CRMXML140
Return

############################################################################################################
$XMLSRE
  #Demande de service
  Call TEXTE(14603, SZCTAOBTITLE) From OBJDIV
  Gosub DOSTARTTAG From CRMXML140
  #On extrait les champs de la table 
  For ITERSORT = 1 To 250
    For ISERREQUEST  = 0 To dim(SZTAGSRE) - 1
      If SZTAGSRE(ISERREQUEST) = "" Then
        Break
      Endif
      If IHIDESRE(ISERREQUEST) = 0 Then
        If ISORTSRE(ISERREQUEST) = ITERSORT Then
          SZLABELFORFILL = SZLABELSRE(ISERREQUEST)
          Gosub DOSTARTFIELD From CRMXML140
          Case SZTAGSRE(ISERREQUEST)
            When "SREHD1CLOB0"
              #On extrait le clob
              Raz SZBUFFTOFILL
              If [F:SRE]TYPFULDES<> "" Then
                If [F:SRE]NUMFULDES <> "" Then
                  Read [HD1]HD10=[F:SRE]NUMFULDES;[F:SRE]TYPFULDES
                  If !fstat Then
                    Raz SZDESCLOBSRE
                    Setlob SZDESCLOBSRE With [F:HD1]CLOB
                    If SZDESCLOBSRE(0) <> "" Then
                      Gosub ADDDEBXMLCLOB From CRMXML140
                      For ITERCLOB = 0 To dim(SZDESCLOBSRE) - 1
                        If SZDESCLOBSRE(ITERCLOB) <> "" Then
                          SZBUFFTOFILL(0) = SZDESCLOBSRE(ITERCLOB)
                          Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                          Wrseq SZBUFFTOFILL(0) Using [FXML]
                        Endif
                      Next
                      Gosub ADDENDXMLCLOB From CRMXML140
                    Endif
                  Endif
                Endif
              Endif
            When Default
              SZABR = "SRE"
              SZFIE = SZFIESRE(ISERREQUEST)
              SZTABLE = "SERREQUEST"
              Gosub WRITEXML From CRMXML140
          Endcase
          Gosub DOENDFIELD From CRMXML140
        Endif
      Endif
    Next
  Next
  Gosub DOENDTAG From CRMXML140
Return

############################################################################################################
$XMLITN
  Call TEXTE(14563, SZCTAOBTITLE) From OBJDIV      #Intervention
  Gosub DOSTARTTAG From CRMXML140
  #On extrait les champs de la table INTERVEN
  For ITERSORT = 1 To 250
    For IINTERVEN = 0 To dim(SZTAGITN) - 1
      If SZTAGITN(IINTERVEN) = "" Then
        Break
      Endif
      If IHIDEITN(IINTERVEN) = 0 Then
        If ISORTITN(IINTERVEN) = ITERSORT Then
          SZLABELFORFILL = SZLABELITN(IINTERVEN)
          Gosub DOSTARTFIELD From CRMXML140
          Case SZTAGITN(IINTERVEN)
            When "ITNHD6CLOB0"
              #On extrait le clob Complément d'informations
              Raz SZBUFFTOFILL
              If [F:ITN]TYPFULOBJ <> "" Then
                If [F:ITN]NUMFULOBJ <> "" Then
                  Read [HD6]HD60=[F:ITN]NUMFULOBJ;[F:ITN]TYPFULOBJ
                  If !fstat Then
                    Raz SZOBJCLOBITN
                    Setlob SZOBJCLOBITN With [F:HD6]CLOB
                    If SZOBJCLOBITN(0) <> "" Then
                      Gosub ADDDEBXMLCLOB From CRMXML140
                      For ITERCLOB = 0 To dim(SZOBJCLOBITN) - 1
                        If SZOBJCLOBITN(ITERCLOB) <> "" Then
                          SZBUFFTOFILL(0) = SZOBJCLOBITN(ITERCLOB)
                          Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                          Wrseq SZBUFFTOFILL(0) Using [FXML]
                        Endif
                      Next
                      Gosub ADDENDXMLCLOB From CRMXML140
                    Endif
                  Endif
                Endif
              Endif
            When "ITNHD2CLOB0"
              #On extrait le clob Compte-rendu
              Raz SZBUFFTOFILL
              If [F:ITN]TYPFULRPO <> "" Then
                If [F:ITN]NUMFULRPO <> "" Then
                  Read [HD2]HD20=[F:ITN]NUMFULRPO;[F:ITN]TYPFULRPO
                  If !fstat Then
                    Raz SZRPOCLOBITN
                    Setlob SZRPOCLOBITN With [F:HD2]CLOB
                    If SZRPOCLOBITN(0) <> "" Then
                      Gosub ADDDEBXMLCLOB From CRMXML140
                      For ITERCLOB = 0 To dim(SZRPOCLOBITN) - 1
                        If SZRPOCLOBITN(ITERCLOB) <> "" Then
                          SZBUFFTOFILL(0) = SZRPOCLOBITN(ITERCLOB)
                          Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                          Wrseq SZBUFFTOFILL(0) Using [FXML]
                        Endif
                      Next
                      Gosub ADDENDXMLCLOB From CRMXML140
                    Endif
                  Endif
                Endif
              Endif
            When Default
              SZABR = "ITN"
              SZFIE = SZFIEITN(IINTERVEN)
              SZTABLE = "INTERVEN"
              Gosub WRITEXML From CRMXML140
          Endcase
          Gosub DOENDFIELD From CRMXML140
        Endif
      Endif
    Next
  Next
  Gosub DOENDTAG From CRMXML140
Return

############################################################################################################
$XMLRRS
  Call TEXTE(24749, SZCTAOBTITLE) From OBJDIV      #Ressource réservée
  Gosub DOSTARTTAG From CRMXML140
  #On extrait les champs de la table 
  For ITERSORT = 1 To 250
    For IRESRES = 0 To dim(SZTAGRRS) - 1
      If SZTAGRRS(IRESRES) = "" Then
        Break
      Endif
      If IHIDERRS(IRESRES) = 0 Then
        If ISORTRRS(IRESRES) = ITERSORT Then
          SZLABELFORFILL = SZLABELRRS(IRESRES)
          Gosub DOSTARTFIELD From CRMXML140
          SZABR = "RRS"
          SZFIE = SZFIERRS(IRESRES)
          SZTABLE = "RESRES"
          Gosub WRITEXML From CRMXML140
          Gosub DOENDFIELD From CRMXML140
        Endif
      Endif
    Next
  Next
  Gosub DOENDTAG From CRMXML140
Return

############################################################################################################
$XMLHDT
  If [F:HDT]HDTDONDAT = [00/00/00] Then
    #Consommation à effectuer
    SZCTAOBTITLE = mess(77,177,1)
  Else
    #Consommation effectuée
    SZCTAOBTITLE = mess(78,177,1)
  Endif
  Gosub DOSTARTTAG From CRMXML140
  #On extrait les champs de la table 
  For ITERSORT = 1 To 250
    For IHDKTASK = 0 To dim(SZTAGHDT) - 1
      If SZTAGHDT(IHDKTASK) = "" Then
        Break
      Endif
      If IHIDEHDT(IHDKTASK) = 0 Then
        If ISORTHDT(IHDKTASK) = ITERSORT Then
          SZLABELFORFILL = SZLABELHDT(IHDKTASK)
          Gosub DOSTARTFIELD From CRMXML140
          Case SZTAGHDT(IHDKTASK)
            When "HDTACBCLOB0"
              #On extrait le clob Texte
              Raz SZBUFFTOFILL
              If [F:HDT]HDTSALTEX <> "" Then
                Read [TXC]TXC0=[F:HDT]HDTSALTEX
                If !fstat Then
                  Raz SZACBCLOBHDT
                  Setlob SZACBCLOBHDT With [F:TXC]TEXTE
                  If SZACBCLOBHDT(0) <> "" Then
                    Gosub ADDDEBXMLCLOB From CRMXML140
                    For ITERCLOB = 0 To dim(SZACBCLOBHDT) - 1
                      If SZACBCLOBHDT(ITERCLOB) <> "" Then
                        SZBUFFTOFILL(0) = SZACBCLOBHDT(ITERCLOB)
                        Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                        Wrseq SZBUFFTOFILL(0) Using [FXML]
                      Endif
                    Next
                    Gosub ADDENDXMLCLOB From CRMXML140
                  Endif
                Endif
              Endif
            When Default
              SZABR = "HDT"
              SZFIE = SZFIEHDT(IHDKTASK)
              SZTABLE = "HDKTASK"
              Gosub WRITEXML From CRMXML140
          Endcase
          Gosub DOENDFIELD From CRMXML140
        Endif
      Endif
    Next
  Next
  Gosub DOENDTAG From CRMXML140
Return

############################################################################################################
$XMLSRM
  #Parc concerné
  Call TEXTE(22065, SZCTAOBTITLE) From OBJDIV
  Gosub DOSTARTTAG From CRMXML140
  #On extrait les champs de la table 
  For ITERSORT = 1 To 250
