  Raz SZDATAFORFILL
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXOMFIELD + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

##########################################################################################################
$ADDDEBXMLCLOB
  SZCLOBIFS = adxifs
  SZCLOBIRS = adxirs
  adxifs = ""
  adxirs = ""
Return

##########################################################################################################
$ADDENDXMLCLOB
  adxifs = SZCLOBIFS
  adxirs = SZCLOBIRS
Return

##########################################################################################################
# --- Remplace les caractères spéciaux non interprétables par xml
##############################################################################
Subprog MODVAL(VALLM)
Variable Char VALLM

Local Char VALL1(200)
Local Char CAR(30)
Local Char REP(30)
Local Char REP1(30)
Local Integer RG
Local Integer DEB

  VALL1=VALLM
  CAR='"' : REP="&quot;"   : REP1="&#34;"  : Gosub MODVALC
  CAR="&" : REP="&amp;"    : REP1="&#38;"  : Gosub MODVALC
  CAR="'" : REP="&apos;"   : REP1="&#39;"  : Gosub MODVALC
  CAR="<" : REP="&lt;"     : REP1="&#60;"  : Gosub MODVALC
  CAR=">" : REP="&gt;"     : REP1="&#62;"  : Gosub MODVALC
  #
  CAR=chr$(160) : REP="&nbsp;"   : REP1="&#160;"  : Gosub MODVALC
  CAR=chr$(161) : REP="&iexcl;"  : REP1="&#161;"  : Gosub MODVALC
  CAR=chr$(162) : REP="&cent;"   : REP1="&#162;"  : Gosub MODVALC
  CAR=chr$(163) : REP="&pound;"  : REP1="&#163;"  : Gosub MODVALC
  CAR=chr$(164) : REP="&curren;" : REP1="&#164;"  : Gosub MODVALC
  CAR=chr$(165) : REP="&yen;"    : REP1="&#165;"  : Gosub MODVALC
  CAR=chr$(166) : REP="&brvbar;" : REP1="&#166;"  : Gosub MODVALC
  CAR=chr$(167) : REP="&sect;"   : REP1="&#167;"  : Gosub MODVALC
  CAR=chr$(168) : REP="&uml;"    : REP1="&#168;"  : Gosub MODVALC
  CAR=chr$(169) : REP="&copy;"   : REP1="&#169;"  : Gosub MODVALC
  CAR=chr$(170) : REP="&ordf;"   : REP1="&#170;"  : Gosub MODVALC
  CAR=chr$(171) : REP="&laquo;"  : REP1="&#171;"  : Gosub MODVALC
  CAR=chr$(172) : REP="&not;"    : REP1="&#172;"  : Gosub MODVALC
  CAR=chr$(173) : REP="&shy;"    : REP1="&#173;"  : Gosub MODVALC
  CAR=chr$(174) : REP="&reg;"    : REP1="&#174;"  : Gosub MODVALC
  CAR=chr$(175) : REP="&macr;"   : REP1="&#175;"  : Gosub MODVALC
  CAR=chr$(176) : REP="&deg;"    : REP1="&#176;"  : Gosub MODVALC
  CAR=chr$(177) : REP="&plusmn;" : REP1="&#177;"  : Gosub MODVALC
  CAR=chr$(178) : REP="&sup2;"   : REP1="&#178;"  : Gosub MODVALC
  CAR=chr$(179) : REP="&sup3;"   : REP1="&#179;"  : Gosub MODVALC
  CAR=chr$(180) : REP="&acute;"  : REP1="&#180;"  : Gosub MODVALC
  CAR=chr$(181) : REP="&micro;"  : REP1="&#181;"  : Gosub MODVALC
  CAR=chr$(182) : REP="&para;"   : REP1="&#182;"  : Gosub MODVALC
  CAR=chr$(183) : REP="&middot;" : REP1="&#183;"  : Gosub MODVALC
  CAR=chr$(184) : REP="&cedil;"  : REP1="&#184;"  : Gosub MODVALC
  CAR=chr$(185) : REP="&sup1;"   : REP1="&#185;"  : Gosub MODVALC
  CAR=chr$(186) : REP="&ordm;"   : REP1="&#186;"  : Gosub MODVALC
  CAR=chr$(187) : REP="&raquo;"  : REP1="&#187;"  : Gosub MODVALC
  CAR=chr$(188) : REP="&frac14;" : REP1="&#188;"  : Gosub MODVALC
  CAR=chr$(189) : REP="&frac12;" : REP1="&#189;"  : Gosub MODVALC
  CAR=chr$(190) : REP="&frac34;" : REP1="&#190;"  : Gosub MODVALC
  CAR=chr$(191) : REP="&iquest;" : REP1="&#191;"  : Gosub MODVALC
  CAR=chr$(192) : REP="&Agrave;" : REP1="&#192;"  : Gosub MODVALC
  CAR=chr$(193) : REP="&Aacute;" : REP1="&#193;"  : Gosub MODVALC
  CAR=chr$(194) : REP="&Acirc;"  : REP1="&#194;"  : Gosub MODVALC
  CAR=chr$(195) : REP="&Atilde;" : REP1="&#195;"  : Gosub MODVALC
  CAR=chr$(196) : REP="&Auml;"   : REP1="&#196;"  : Gosub MODVALC
  CAR=chr$(197) : REP="&Aring;"  : REP1="&#197;"  : Gosub MODVALC
  CAR=chr$(198) : REP="&AElig;"  : REP1="&#198;"  : Gosub MODVALC
  CAR=chr$(199) : REP="&Ccedil;" : REP1="&#199;"  : Gosub MODVALC
  CAR=chr$(200) : REP="&Egrave;" : REP1="&#200;"  : Gosub MODVALC
  CAR=chr$(201) : REP="&Eacute;" : REP1="&#201;"  : Gosub MODVALC
  CAR=chr$(202) : REP="&Ecirc;"  : REP1="&#202;"  : Gosub MODVALC
  CAR=chr$(203) : REP="&Euml;"   : REP1="&#203;"  : Gosub MODVALC
  CAR=chr$(204) : REP="&Igrave;" : REP1="&#204;"  : Gosub MODVALC
  CAR=chr$(205) : REP="&Iacute;" : REP1="&#205;"  : Gosub MODVALC
  CAR=chr$(206) : REP="&Icirc;"  : REP1="&#206;"  : Gosub MODVALC
  CAR=chr$(207) : REP="&Iuml;"   : REP1="&#207;"  : Gosub MODVALC
  CAR=chr$(208) : REP="&ETH;"    : REP1="&#208;"  : Gosub MODVALC
  CAR=chr$(209) : REP="&Ntilde;" : REP1="&#209;"  : Gosub MODVALC
  CAR=chr$(210) : REP="&Ograve;" : REP1="&#210;"  : Gosub MODVALC
  CAR=chr$(211) : REP="&Oacute;" : REP1="&#211;"  : Gosub MODVALC
  CAR=chr$(212) : REP="&Ocirc;"  : REP1="&#212;"  : Gosub MODVALC
  CAR=chr$(213) : REP="&Otilde;" : REP1="&#213;"  : Gosub MODVALC
  CAR=chr$(214) : REP="&Ouml;"   : REP1="&#214;"  : Gosub MODVALC
  CAR=chr$(215) : REP="&times;"  : REP1="&#215;"  : Gosub MODVALC
  CAR=chr$(216) : REP="&Oslash;" : REP1="&#216;"  : Gosub MODVALC
  CAR=chr$(217) : REP="&Ugrave;" : REP1="&#217;"  : Gosub MODVALC
  CAR=chr$(218) : REP="&Uacute;" : REP1="&#218;"  : Gosub MODVALC
  CAR=chr$(219) : REP="&Ucirc;"  : REP1="&#219;"  : Gosub MODVALC
  CAR=chr$(220) : REP="&Uuml;"   : REP1="&#220;"  : Gosub MODVALC
  CAR=chr$(221) : REP="&Yacute;" : REP1="&#221;"  : Gosub MODVALC
  CAR=chr$(222) : REP="&THORN;"  : REP1="&#222;"  : Gosub MODVALC
  CAR=chr$(223) : REP="&szlig;"  : REP1="&#223;"  : Gosub MODVALC
  CAR=chr$(224) : REP="&agrave;" : REP1="&#224;"  : Gosub MODVALC
  CAR=chr$(225) : REP="&aacute;" : REP1="&#225;"  : Gosub MODVALC
  CAR=chr$(226) : REP="&acirc;"  : REP1="&#226;"  : Gosub MODVALC
  CAR=chr$(227) : REP="&atilde;" : REP1="&#227;"  : Gosub MODVALC
  CAR=chr$(228) : REP="&auml;"   : REP1="&#228;"  : Gosub MODVALC
  CAR=chr$(229) : REP="&aring;"  : REP1="&#229;"  : Gosub MODVALC
  CAR=chr$(230) : REP="&aelig;"  : REP1="&#230;"  : Gosub MODVALC
  CAR=chr$(231) : REP="&ccedil;" : REP1="&#231;"  : Gosub MODVALC
  CAR=chr$(232) : REP="&egrave;" : REP1="&#232;"  : Gosub MODVALC
  CAR=chr$(233) : REP="&eacute;" : REP1="&#233;"  : Gosub MODVALC
  CAR=chr$(234) : REP="&ecirc;"  : REP1="&#234;"  : Gosub MODVALC
  CAR=chr$(235) : REP="&euml;"   : REP1="&#235;"  : Gosub MODVALC
  CAR=chr$(236) : REP="&igrave;" : REP1="&#236;"  : Gosub MODVALC
  CAR=chr$(237) : REP="&iacute;" : REP1="&#237;"  : Gosub MODVALC
  CAR=chr$(238) : REP="&icirc;"  : REP1="&#238;"  : Gosub MODVALC
  CAR=chr$(239) : REP="&iuml;"   : REP1="&#239;"  : Gosub MODVALC
  CAR=chr$(240) : REP="&eth;"    : REP1="&#240;"  : Gosub MODVALC
  CAR=chr$(241) : REP="&ntilde;" : REP1="&#241;"  : Gosub MODVALC
  CAR=chr$(242) : REP="&ograve;" : REP1="&#242;"  : Gosub MODVALC
  CAR=chr$(243) : REP="&oacute;" : REP1="&#243;"  : Gosub MODVALC
  CAR=chr$(244) : REP="&ocirc;"  : REP1="&#244;"  : Gosub MODVALC
  CAR=chr$(245) : REP="&otilde;" : REP1="&#245;"  : Gosub MODVALC
  CAR=chr$(246) : REP="&ouml;"   : REP1="&#246;"  : Gosub MODVALC
  CAR=chr$(247) : REP="&divide;" : REP1="&#247;"  : Gosub MODVALC
  CAR=chr$(248) : REP="&oslash;" : REP1="&#248;"  : Gosub MODVALC
  CAR=chr$(249) : REP="&ugrave;" : REP1="&#249;"  : Gosub MODVALC
  CAR=chr$(250) : REP="&uacute;" : REP1="&#250;"  : Gosub MODVALC
  CAR=chr$(251) : REP="&ucirc;"  : REP1="&#251;"  : Gosub MODVALC
  CAR=chr$(252) : REP="&uuml;"   : REP1="&#252;"  : Gosub MODVALC
  CAR=chr$(253) : REP="&yacute;" : REP1="&#253;"  : Gosub MODVALC
  CAR=chr$(254) : REP="&thorn;"  : REP1="&#254;"  : Gosub MODVALC
  CAR=chr$(255) : REP="&yuml;"   : REP1="&#255;"  : Gosub MODVALC
End

##############################################################################
$MODVALC
  DEB = 1
  Repeat
   RG = instr(DEB,VALLM,CAR)
   If RG <> 0 and mid$(VALLM,RG+1,1) <> "#" Then
     VALL1=left$(VALLM,RG-1) + REP1 + right$(VALLM,RG+1)
     VALLM = VALL1
     DEB = RG + 1
   Else
     DEB = RG + 1
   Endif
  Until RG = 0
Return

##########################################################################################################
$XSDPART1
#Caractères XML
Local Char A(2)
Local Char B(4)
Local Char C(4)
Local Char D(2)
Local Char VQ(2)
Local Char SP(2)

  SP = '_'
  VQ = '"'
  A = "<"
  B = "</"
  C = "/>"
  D = ">"

Local Integer IWHERE
Local Char SZBUFFTOFILL(250)(2)         #Buffers d'écriture
Local Char SZADXIFS(type(adxifs)-10)    #Séparateurs
Local Char SZADXIRS(type(adxirs)-10)    #Séparateurs
Local Char SZXMLFILENAME(250)
Local Char SZWFNAME(250)
Local Char SZELEMENTTYPE(100)
Local Char SZMANDATORY(100)
Local Char SZLMANDATORY(100)
Local Integer IFIELENGTH
Local Integer IDECLENGTH
Local Integer IDECLENGTH2
Local Integer IMMNUM

  SZELEMENTTYPE = ""
  SZMANDATORY = ""
  SZLMANDATORY = ""
  IFIELENGTH = 0
  IDECLENGTH = 0
  IDECLENGTH2 = 0
  IMMNUM = 0
  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  Raz SZBUFFTOFILL
  IWHERE = 1
  #Fichier XSD
  SZWFNAME = SZAOBABREV + "INXSD"
  SZXMLFILENAME = ""
  #Ouverture du fichier HTML
  # FGR 23/04/2008 : X3SUIVI46965 Fichiers générés sur le serveur puis rappatriés sur la poste à la fermeture
  #Call BUILDFICNAME(IWHERE, SZWFNAME, "xsd", SZXMLFILENAME)
  Call BUILDFICNAME(0, SZWFNAME, "xsd", SZXMLFILENAME)
  If SZXMLFILENAME = ""
    #Erreur lors de l'ouverture du fichier XML
    IERRINF = 95
    ICHAPTER = 177
    #On restaure les variables adxifs et adxirs
    adxifs = SZADXIFS
    adxirs = SZADXIRS
    Return
  Endif
  Openo SZXMLFILENAME, 0 Using [FXML]
  Gosub DOSTARTXSD
Return

##########################################################################################################
$XSDPART2
  Gosub DOENDXSD
  #On ferme le fichier XML
  Openo Using [FXML]
  # FGR 23/04/2008 : X3SUIVI46965 Fichiers générés sur le serveur puis rappatriés sur la poste à la fermeture
  Callui RETOUR="" With "UIAction=" + chr$(1) + "GetFileAlways",
&                       "UIRemoteFile=" + chr$(1) + SZXMLFILENAME,
&                       "UILocalDir=" + chr$(1) + "Report",
&                       "UILocalFile=" + chr$(1) + SZWFNAME+ ".xsd"
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
  #On renvoie le nom du fichier généré
  SZFULLRETFILE = SZXMLFILENAME
  SZRETFILENAME = SZWFNAME + ".xsd"
Return

##########################################################################################################
$DOSTARTXSD
Local Integer ITERCLOB
Local Integer ITERSORT
Local Char SZCLOBIFS(type(adxifs)-10)
Local Char SZCLOBIRS(type(adxirs)-10)
Local Char SZABR(GLONABR)
Local Char SZFIE(250)
Local Char SZTABLE(GLONATB)

  ITERSORT = 0
  ITERCLOB = 0
  Call TEMPON("E") From GESECRAN
  #En-tête du fichier XML
  Raz SZBUFFTOFILL
  Call XMLENTET(SZBUFFTOFILL(0))
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  #En-tête du schéma
  Raz SZBUFFTOFILL
  Call XSDENTET(SZAOBABREV, SZBUFFTOFILL(0))
  Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

##########################################################################################################
$DOENDXSD
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = B + "xs:schema" + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Call TEMPOFF From GESECRAN
Return

##########################################################################################################
#  Crée l'entête de tout fichier xsd
##############################################################################
Subprog XSDENTET(SZABREV, ZONE)
Value Char SZABREV
Variable Char ZONE

Local Char VQ(10)
Local Char SZSCHEMA(250)

  VQ='"'
  SZCHEMA = SZABREV + "INXSD.xsd"
  ZONE = "<xs:schema xmlns:xs=" + VQ + "http://www.w3.org/2001/XMLSchema" + VQ
  ZONE = ZONE + " targetNamespace=" + VQ + "http://adonix.com/" + SZCHEMA + VQ
  ZONE = ZONE + " xmlns=" + VQ + "http://adonix.com/" + SZCHEMA + VQ
  ZONE = ZONE + " elementFormDefault=" + VQ + "qualified" + VQ + ">"
End

##########################################################################################################
#  Ajout d'un élément dans un schéma XSD
##############################################################################
$ADDXSDITEM
  If SZABR = "" Then
    Return
  Endif
  If SZTABLE = "" Then
    Return
  Endif
  If SZFIE = "" Then
    Return
  Endif
  Read [ATZ]CODZONE=SZTABLE;SZFIE
  If fstat Then
    Return
  Endif
  #
  SZELEMENTTYPE = ""
  Case [F:ATZ]CODTYP
    When "A"
      IFIELENGTH = [F:ATZ]LONG
      Gosub SETSTRINGTYPE
      SZELEMENTTYPE = ""
    When "ADI"
      Gosub SETADITYPE
      SZELEMENTTYPE = ""
    When "D"
      SZELEMENTTYPE = "date"
    When "HM"
      SZELEMENTTYPE = "time"
    When "M", "MM"
      If [F:ATZ]NOLIB = 1 Then
        SZELEMENTTYPE = "Boolean"
      Else
        IMMNUM = [F:ATZ]NOLIB
        Gosub SETMMTYPE
        SZELEMENTTYPE = ""
      Endif
    When "C", "L"
      IFIELENGTH = [F:ATZ]LONG
      Gosub SETINTEGERTYPE
      SZELEMENTTYPE = ""
    When "DCB"
      IFIELENGTH = fix([F:ATZ]LONG)
      IDECLENGTH2 = [F:ATZ]LONG - IFIELENGTH
      IDECLENGTH = val(right$(num$(IDECLENGTH2), 3))
      If IDECLENGTH <= 0 Then
        IFIELENGTH = 8
        Gosub SETINTEGERTYPE
        SZELEMENTTYPE = ""
      Else
        Gosub SETDECIMALTYPE
        SZELEMENTTYPE = ""
      Endif
    When Default
      Read [ATY]CODTYP=[F:ATZ]CODTYP
      If !fstat Then
        Case [F:ATY]TYPTYP
          When 1
            If [F:ATY]NOLIB = 1 Then
              SZELEMENTTYPE = "Boolean"
            Else
              IMMNUM = [F:ATY]NOLIB
              Gosub SETMMTYPE
              SZELEMENTTYPE = ""
            Endif
          When 2, 3
            IFIELENGTH = [F:ATY]LNGTYP
            Gosub SETINTEGERTYPE
            SZELEMENTTYPE = ""
          When 4, 5, 6
            IFIELENGTH = fix([F:ATY]LNGTYP)
            IDECLENGTH2 = [F:ATY]LNGTYP - IFIELENGTH
            IDECLENGTH = val(right$(num$(IDECLENGTH2), 3))
            If IDECLENGTH <= 0 Then
              IFIELENGTH = 8
              Gosub SETINTEGERTYPE
              SZELEMENTTYPE = ""
            Else
              Gosub SETDECIMALTYPE
              SZELEMENTTYPE = ""
            Endif
          When 7
            IFIELENGTH = [F:ATY]LNGTYP
            Gosub SETSTRINGTYPE
            SZELEMENTTYPE = ""
          When 8
            SZELEMENTTYPE = "date"
          When 9
            SZELEMENTTYPE = "string"
          When 10
            SZELEMENTTYPE = "string"
        Endcase
      Endif
  Endcase
  If SZELEMENTTYPE = "" Then
    Return
  Endif
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + "xs:element name=" + VQ + SZABR + SZFIE + VQ + " type=" + VQ + "xs:" + SZELEMENTTYPE + VQ + SZMANDATORY + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Gosub ADDDOCUMENTATION
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + "xs:element" + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

##########################################################################################################
# Ajoute l'étiquette du champ à des fins documentaires
#################################################
$ADDDOCUMENTATION
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + "xs:annotation" + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + "xs:documentation" + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = SZLABELFORFILL
  Call MODVAL(SZBUFFTOFILL(0))
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + "xs:documentation" + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + "xs:annotation" + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

##########################################################################################################
# Génération d'un élément de type ADI
###################################################
$SETADITYPE
Local Char SZADIDEFAULT(100)
Local Char SZADITEXT(100)
Local Integer IADIONLYONCE
Local Integer IADISEPARATOR
Local Integer IADINUMTAB

  IADISEPARATOR = instr(1, [F:ATZ]EXPLIEN, ";")
  IADISEPARATOR -= 1
  IADINUMTAB = val(left$([F:ATZ]EXPLIEN, IADISEPARATOR))
  IADIONLYONCE = 0
  SZADITEXT = ""
  SZADIDEFAULT = ""
  Filter [ADI] Where [F:ADI]NUMTAB = IADINUMTAB and [F:ADI]DEFVAL = 2
  For [ADI]
    Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, SZADITEXT) From CRM_UTIL
    SZADIDEFAULT = [F:ADI]CODE - SZADITEXT
    Call MODVAL(SZADIDEFAULT)
  Next
  Filter [ADI]
  SZADITEXT = ""
  Filter [ADI] Where [F:ADI]NUMTAB = IADINUMTAB
  For [ADI]
    If IADIONLYONCE = 0 Then
      Raz SZBUFFTOFILL
      If SZADIDEFAULT = "" Then
        SZBUFFTOFILL(0) = A + "xs:element name=" + VQ + SZABR + SZFIE + VQ + SZMANDATORY + D
      Else
        SZBUFFTOFILL(0) = A + "xs:element name=" + VQ + SZABR + SZFIE + VQ + " default=" + VQ + SZADIDEFAULT + VQ + SZMANDATORY + D
      Endif
      Wrseq SZBUFFTOFILL(0) Using [FXML]
      Gosub ADDDOCUMENTATION
      Raz SZBUFFTOFILL
      SZBUFFTOFILL(0) = A + "xs:simpleType" + D
      Wrseq SZBUFFTOFILL(0) Using [FXML]
      Raz SZBUFFTOFILL
      SZBUFFTOFILL(0) = A + "xs:restriction base=" + VQ + "xs:string" + VQ + D
      Wrseq SZBUFFTOFILL(0) Using [FXML]
      IADIONLYONCE = 1
    Endif
    Raz SZBUFFTOFILL
    Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, SZADITEXT) From CRM_UTIL
    Call MODVAL(SZADITEXT)
    SZBUFFTOFILL(0) = A + "xs:enumeration value=" + VQ + [F:ADI]CODE + " " + SZADITEXT + VQ + C
    Wrseq SZBUFFTOFILL(0) Using [FXML]
  Next
  Filter [ADI]
  If IADIONLYONCE Then
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = B + "xs:restriction" + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = B + "xs:simpleType" + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = B + "xs:element" + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
  Endif
Return

##########################################################################################################
# Génération d'un élément de type M ou MM
###################################################
$SETMMTYPE
Local Char SZMMTEXT(250)
Local Char SZDEFMMTEXT(250)
Local Integer IMMONLYONCE

  IMMONLYONCE = 0
  SZMMTEXT = ""
  SZDEFMMTEXT = ""
  For ITERMM = 1 To len(mess(0,IMMNUM,1))
    SZMMTEXT = ""
    SZMMTEXT = mess(ITERMM,IMMNUM,1)
    If SZMMTEXT <> ""
      SZDEFMMTEXT = mess(1,IMMNUM,1)
      Call MODVAL(SZDEFMMTEXT)
      If IMMONLYONCE = 0 Then
        Raz SZBUFFTOFILL
        SZBUFFTOFILL(0) = A + "xs:element name=" + VQ + SZABR + SZFIE + VQ + " default=" + VQ + num$(ITERMM) + " " + SZDEFMMTEXT + VQ + SZMANDATORY + D
        Wrseq SZBUFFTOFILL(0) Using [FXML]
        Gosub ADDDOCUMENTATION
        Raz SZBUFFTOFILL
        SZBUFFTOFILL(0) = A + "xs:simpleType" + D
        Wrseq SZBUFFTOFILL(0) Using [FXML]
        Raz SZBUFFTOFILL
        SZBUFFTOFILL(0) = A + "xs:restriction base=" + VQ + "xs:string" + VQ + D
        Wrseq SZBUFFTOFILL(0) Using [FXML]
        IMMONLYONCE = 1
      Endif
      Raz SZBUFFTOFILL
      Call MODVAL(SZMMTEXT)
      SZBUFFTOFILL(0) = A + "xs:enumeration value=" + VQ + num$(ITERMM) + " " + SZMMTEXT + VQ + C
      Wrseq SZBUFFTOFILL(0) Using [FXML]
    Endif
  Next
  If IMMONLYONCE Then
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = B + "xs:restriction" + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = B + "xs:simpleType" + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = B + "xs:element" + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
  Endif
Return

##########################################################################################################
# Génération d'un élément de type Chaine
###################################################
$SETSTRINGTYPE
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + "xs:element name=" + VQ + SZABR + SZFIE + VQ + SZMANDATORY + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Gosub ADDDOCUMENTATION
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + "xs:simpleType" + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + "xs:restriction base=" + VQ + "xs:string" + VQ + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + "xs:maxLength value=" + VQ + num$(IFIELENGTH) + VQ + C
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  If SZLMANDATORY <> "" Then
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = A + SZLMANDATORY + C
    Wrseq SZBUFFTOFILL(0) Using [FXML]
  Endif
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + "xs:restriction" + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + "xs:simpleType" + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + "xs:element" + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

##########################################################################################################
# Génération d'un élément de type Entier court ou long
###################################################
$SETINTEGERTYPE
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + "xs:element name=" + VQ + SZABR + SZFIE + VQ + " default=" + VQ + "0" + VQ + SZMANDATORY + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Gosub ADDDOCUMENTATION
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + "xs:simpleType" + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + "xs:restriction base=" + VQ + "xs:decimal" + VQ + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + "xs:totalDigits value=" + VQ + num$(IFIELENGTH) + VQ + C
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + "xs:fractionDigits value=" + VQ + "0" + VQ + C
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + "xs:restriction" + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + "xs:simpleType" + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + "xs:element" + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

