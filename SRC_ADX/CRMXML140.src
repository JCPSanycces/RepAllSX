##########################################################################################################
##########################################################################################################
# Gestion des exceptions
#########################################################
$CHKEXCEPTION
  IRUNBYEXCEPTION = 0
  Case SZTABLE
    When "INTERVEN"
      Gosub ITNEXCEPTION From CRMEXCEPT
    When "RESRES"
      Gosub RRSEXCEPTION From CRMEXCEPT
    When "SREMAC"
      Gosub SRMEXCEPTION From CRMEXCEPT
    When "SREMACCPN"
      Gosub SRNEXCEPTION From CRMEXCEPT
    When "HDKTASK"
      Gosub HDTEXCEPTION From CRMEXCEPT
    When "SERREQUEST"
      Gosub SREEXCEPTION From CRMEXCEPT
    When "SOLUTION"
      Gosub SOLEXCEPTION From CRMEXCEPT
    When "CONTACT"
      Gosub CNTEXCEPTION From CRMEXCEPT
    When "CONTACTCRM"
      Gosub AINEXCEPTION From CRMEXCEPT
    When "MACHINES"
      Gosub MACEXCEPTION From CRMEXCEPT
    When "BPARTNER"
      Gosub BPREXCEPTION From CRMEXCEPT
    When "BPCUSTOMER"
      Gosub BPCEXCEPTION From CRMEXCEPT
    When "BPADDRESS"
      Gosub BPAEXCEPTION From CRMEXCEPT
    When "SALESREP"
      Gosub REPEXCEPTION From CRMEXCEPT
    When "MARSCT"
      Gosub MSTEXCEPTION From CRMEXCEPT
    When "REPSEC"
      Gosub RSEEXCEPTION From CRMEXCEPT
    When "OPPOR"
      Gosub OPPEXCEPTION From CRMEXCEPT
    When "TASK"
      Gosub TSKEXCEPTION From CRMEXCEPT
    When "PHONECALL"
      Gosub CLLEXCEPTION From CRMEXCEPT
    When "CALLATTEMP"
      Gosub CTTEXCEPTION From CRMEXCEPT
    When "BAPPOINT"
      Gosub BAPEXCEPTION From CRMEXCEPT
  Endcase
Return

##########################################################################################################
# Construit un nom de fichier
##############################################################################
Subprog BUILDFICNAME(IDIRECTORY, SZWISHEDNAME, SZWISHEDEXT, SZWHOLENAME)
Value Integer IDIRECTORY
Value Char SZWISHEDNAME
Value Char SZWISHEDEXT
Variable Char SZWHOLENAME

Local Char SZDIRECTORY(250)
Local Char SZREPORTLANG(250)

  # IDIRECTORY
  #   0 = Serveur
  #   1 = Client (Rts/Temp)
  SZWHOLENAME = ""
  SZREPORTLANG = ""
  If IDIRECTORY = 0 Then
    # Serveur
    #SZREPORTLANG = "REPORT/" + GLANGUE  # FGR 26/08/2015 : X3SUIVI110569
    SZREPORTLANG = "tmp"                 # FGR 26/08/2015 : X3SUIVI110569
    SZWISHEDNAME = SZWISHEDNAME + "_" + GUSER
    SZWHOLENAME = filpath(SZREPORTLANG, SZWISHEDNAME, SZWISHEDEXT, nomap)
  Elsif IDIRECTORY = 1 Then
    # Client
    Call GETREPREPCLIENT(SZDIRECTORY, 1) From CRMUTIL140
    SZWHOLENAME = SZDIRECTORY + '\' + toupper(SZWISHEDNAME) + "." + SZWISHEDEXT
  Endif
End

##########################################################################################################
#  Crée l'entête de tout fichier xml
##############################################################################
Subprog XMLENTET(ZONE)
Variable Char ZONE

Local Char VQ(10)

  VQ='"'
  ZONE="<?xml version="+VQ+"1.0"+VQ+" encoding="+VQ+"ISO-8859-1"
  ZONE=ZONE+VQ+" standalone="+VQ+"yes"+VQ+" ?>"
End

##########################################################################################################
# Construit la liaison avec une feuille de style XSLT
##################################################################################
Subprog XMLXSLT(SZXSLNAME, ZONE)
Value Char SZXSLNAME
Variable Char ZONE
Local Char VQ(10)

  VQ='"'
  ZONE = "<?xml-stylesheet type=" + VQ + "text/xsl" + VQ + " HREF=" + VQ + SZXSLNAME + ".xsl" + VQ + "?>"
End

##########################################################################################################
$FILLBUFFER
Local Integer IRUNBYEXCEPTION
Local Date SZBUFFDAT
Local Decimal SZBUFFFLOAT

  Raz SZBUFFTOFILL
  IRUNBYEXCEPTION = 0
  #Traitement des exception
  Gosub CHKEXCEPTION
  If IRUNBYEXCEPTION Then
    Return
  Endif
  IEVALTYPE = evalue("Type([F:" + SZABR + "]" + SZFIE + ")")
  If IEVALTYPE = 1 or IEVALTYPE = 2 Then
    #Numérique
    Assign ("SZBUFFFLOAT") With evalue("[F:" + SZABR + "]" + SZFIE)
    SZBUFFTOFILL(0) = num$(SZBUFFFLOAT)
  Elsif IEVALTYPE = 3 Then
    #Date
    Assign ("SZBUFFDAT") With evalue("[F:" + SZABR + "]" + SZFIE)
    SZBUFFTOFILL(0) = format$(GFMD,SZBUFFDAT)
  Elsif IEVALTYPE >= 4 and IEVALTYPE <= 9 Then
    #Numérique
    Assign ("SZBUFFFLOAT") With evalue("[F:" + SZABR + "]" + SZFIE)
    SZBUFFTOFILL(0) = num$(SZBUFFFLOAT)
  Elsif IEVALTYPE >= 10 Then
    #Alpha
    Assign ("SZBUFFTOFILL(0)") With evalue("[F:" + SZABR + "]" + SZFIE)
  Endif
  #Traitement des menus locaux, tables diverses et types de données objets
  Gosub FILLWITHLINK
Return

##########################################################################################################
$FILLWITHLINK
Local Char SZLIEFIE(250)
Local Char SZLIEKEY(250)
Local Char SZCRITIBB(250)
Local Char SZCURRENTVALUE(250)
Local Char SZ2CURRENTVALUE(250)
Local Integer IADISEPARATOR

  IRUNBYEXCEPTION = 0
  If SZTABLE = "" Then
    Return
  Endif
  If SZFIE = "" Then
    Return
  Endif
  If SZBUFFTOFILL(0) = "" Then
    Return
  Endif
  # ------------------------------
  IADISEPARATOR = 0
  Raz SZCURRENTVALUE
  Raz SZ2CURRENTVALUE
  SZCURRENTVALUE = SZBUFFTOFILL(0)
  SZCRITIBB = ""
  SZLIEFIE = ""
  SZLIEKEY = ""
  Read [ATZ]CODZONE=SZTABLE;SZFIE
  If fstat Then
    Return
  Endif
  #
  Case [F:ATZ]CODTYP
    When "ADI"
      IADISEPARATOR = instr(1, [F:ATZ]EXPLIEN, ";")
      IADISEPARATOR -= 1
      Read [ADI]CODE=val(left$([F:ATZ]EXPLIEN, IADISEPARATOR));SZCURRENTVALUE
      If !fstat
        Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, SZ2CURRENTVALUE) From CRM_UTIL
        SZBUFFTOFILL(0) = "(" + SZCURRENTVALUE + ") " + SZ2CURRENTVALUE
      Endif
    When "M"
      SZBUFFTOFILL(0) = mess(val(SZCURRENTVALUE),[F:ATZ]NOLIB,1)
    When "MM"
      SZBUFFTOFILL(0) = mess(val(SZCURRENTVALUE),[F:ATZ]NOLIB,1)
    When "HM"
      SZBUFFTOFILL(0) = left$(SZCURRENTVALUE,2) + ":" + mid$(SZCURRENTVALUE,3,2)
    When "AXX"
      Call GET_TRADWVAL(SZTABLE, SZABR, SZFIE, SZBUFFTOFILL(0)) From CRM_UTIL
    When Default
      Read [ATY]CODTYP=[F:ATZ]CODTYP
      If !fstat Then
        If [F:ATY]OBJLIEN <> "" Then
          Read [AOB]ABREV=[F:ATY]OBJLIEN
          If !fstat Then
            If [F:ATY]TYPTYP = 7 Then
              Read [ATB]CODFIC=[F:AOB]NOMFIC
              If !fstat Then
                SZLIEFIE = [F:ATB]INTIT
                SZLIEKEY = ""
                Filter [ATZ] Where [F:ATZ]CODFIC = [F:AOB]NOMFIC
                For [ATZ]CODZONE
                  If instr(1, [F:ATZ]OPTION, 'C') Then
                    SZLIEKEY = [F:ATZ]CODZONE
                    Break
                  Endif
                Next
                Filter [ATZ]
                If SZLIEKEY <> "" Then
                  SZCRITIBB = "[F:IBBX]" + SZLIEKEY + "=SZCURRENTVALUE"
                  Read [ATZ]CODZONE=[F:AOB]NOMFIC;SZLIEFIE
                  If !fstat Then
                    If [F:ATZ]CODTYP = "AXX" or [F:ATZ]CODTYP = "AX1" or [F:ATZ]CODTYP = "AX2" or [F:ATZ]CODTYP = "AX3" Then
                      Call GET_TRADAUT([F:AOB]NOMFIC, SZLIEFIE, SZCURRENTVALUE, SZBUFFTOFILL(0)) From CRM_UTIL
                    Else
                      Local File =[F:AOB]NOMFIC [IBBX]
                      Filter [IBBX] Where evalue(SZCRITIBB)
                      For [IBBX]
                        SZ2CURRENTVALUE = evalue("[F:IBBX]" + SZLIEFIE)
                        Break
                      Next
                      Filter [IBBX]
                      Close Local File [IBBX]
                      If SZ2CURRENTVALUE <> "" Then
                        SZBUFFTOFILL (0) = "(" + SZCURRENTVALUE + ") " + SZ2CURRENTVALUE
                      Endif
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
  Endcase
Return

##########################################################################################################
# Ecriture d'une ligne de tableau HTML
#############################################################
$WRITEHTMLTR
  If SZSCREENTYPE = "PALM" Then
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = '<TR>'
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = '<TD CLASS="cLabel">'
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    SZBUFFTOFILL(0) = SZLABELFORFILL
    Call MODVAL(SZBUFFTOFILL(0))
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = '</TD></TR><TR><TD CLASS="cData">'
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    If SZDATAFORFILL = "" Then
      Gosub FILLBUFFER
    Else
      SZBUFFTOFILL(0) = SZDATAFORFILL
    Endif
    Call MODVAL(SZBUFFTOFILL(0))
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = '</TD></TR>'
    Wrseq SZBUFFTOFILL(0) Using [FXML]
  Else
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = '<TR VALIGN="top">'
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = '<TD CLASS="cLabel" WIDTH="20%">'
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    SZBUFFTOFILL(0) = SZLABELFORFILL
    Call MODVAL(SZBUFFTOFILL(0))
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = '</TD><TD CLASS="cData" WIDTH="80%">'
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    If SZDATAFORFILL = "" Then
      Gosub FILLBUFFER
    Else
      SZBUFFTOFILL(0) = SZDATAFORFILL
    Endif
    Call MODVAL(SZBUFFTOFILL(0))
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = '</TD></TR>'
    Wrseq SZBUFFTOFILL(0) Using [FXML]
  Endif
  Raz SZDATAFORFILL
Return

##########################################################################################################
$ADDDEBTRCLOB
  If SZSCREENTYPE = "PALM" Then
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = '<TR>'
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = '<TD CLASS="cLabel">'
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    SZBUFFTOFILL(0) = SZLABELFORFILL
    Call MODVAL(SZBUFFTOFILL(0))
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = '</TD></TR><TR><TD CLASS="cData">'
    Wrseq SZBUFFTOFILL(0) Using [FXML]
  Else
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = '<TR VALIGN="top">'
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = '<TD CLASS="cLabel" WIDTH="20%">'
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    SZBUFFTOFILL(0) = SZLABELFORFILL
    Call MODVAL(SZBUFFTOFILL(0))
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = '</TD><TD CLASS="cData" WIDTH="80%">'
    Wrseq SZBUFFTOFILL(0) Using [FXML]
  Endif
  SZCLOBIFS = adxifs
  SZCLOBIRS = adxirs
  adxifs = ""
  adxirs = ""
Return

##########################################################################################################
$ADDENDTRCLOB
  adxifs = SZCLOBIFS
  adxirs = SZCLOBIRS
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = '</TD></TR>'
  Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

##########################################################################################################
$DOSTARTHTML
#Définition des styles
Local Char STYTABLEBORDER(30)
Local Char STYTITLECOLOR(30)
Local Char STYTITLEBACKCOLOR(30)
Local Char STYLABELCOLOR(30)
Local Char STYLABELBACKCOLOR(30)
Local Char STYLABELBORDERCOLOR(30)

  STYTABLEBORDER = chr$(35) + "003D22"        #Pantone 3435
  STYTITLECOLOR = chr$(35) + "003D22"         #Pantone 3435
  STYTITLEBACKCOLOR = chr$(35) + "008469"     #Pantone 335
  STYLABELCOLOR = chr$(35) + "003D22"         #Pantone 3435
  STYLABELBACKCOLOR = chr$(35) + "DAE5B9"     #Pantone 579
  STYLABELBORDERCOLOR = chr$(35) + "003D22"   #Pantone 3435

Local Integer ITERCLOB
Local Integer ITERSORT
Local Char SZCLOBIFS(type(adxifs)-10)
Local Char SZCLOBIRS(type(adxirs)-10)
Local Char SZABR(GLONABR)
Local Char SZFIE(250)
Local Char SZTABLE(GLONATB)
Local Integer IHREFCONTROL

  IHREFCONTROL = 0
  ITERSORT = 0
  ITERCLOB = 0
  Call TEMPON("E") From GESECRAN
  #En-tête du fichier HTML
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = "<HTML><HEAD><STYLE>"
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = "TABLE.cMain {BORDER-STYLE:solid;BORDER-COLOR:" + STYTABLEBORDER + ";BORDER-WIDTH:1;FONT-SIZE:x-small}"
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = "TD.cTitle {FONT-STYLE:ITALIC;FONT-WEIGHT:BOLD;FONT-SIZE:large;COLOR:" + STYTITLECOLOR + ";BACKGROUND-COLOR:"+ STYTITLEBACKCOLOR +"}"
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = "A.cAHREF {TEXT-DECORATION:none;FONT-STYLE:ITALIC;FONT-WEIGHT:BOLD;" + "FONT-SIZE:large;COLOR:" + STYTITLECOLOR + ";BACKGROUND-COLOR:" + STYTITLEBACKCOLOR + "}"
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = "TD.cLabel {FONT-STYLE:ITALIC;COLOR:" + STYLABELCOLOR + ";BORDER-STYLE:solid;" +"BORDER-COLOR:" + STYLABELBORDERCOLOR + ";BORDER-WIDTH:1;BACKGROUND-COLOR:" + STYLABELBACKCOLOR + "}"
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = "TD.cData {FONT-STYLE:NORMAL;COLOR:#000000}"
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = "</STYLE><TITLE>"
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = SZHTMLTITLE
  Call MODVAL(SZBUFFTOFILL(0))
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = "</TITLE></HEAD><BODY><DIV>"
  Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

##########################################################################################################
$DOENDHTML
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = '<A NAME="LNK' + num$(IHREFCONTROL) + '"></A>'
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = "</DIV></BODY></HTML>"
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Call TEMPOFF From GESECRAN
Return

##########################################################################################################
$DOSTARTTABLE
  #Ajout d'un nouveau tableau
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = '<TABLE CLASS="cMain"CELLSPACING="5" CELLPADDING="5">'
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = "<THEAD><TR>"
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  If SZSCREENTYPE = "PALM" Then
    Raz SZBUFFTOFILL
    SZBUFFTOFILL = '<TD CLASS="cTitle">'
    Wrseq SZBUFFTOFILL(0) Using [FXML]
  Else
    Raz SZBUFFTOFILL
    SZBUFFTOFILL = '<TD CLASS="cTitle" COLSPAN="2">'
    Wrseq SZBUFFTOFILL(0) Using [FXML]
  Endif
  If IHREFCONTROL > 0 Then
    Raz SZBUFFTOFILL
    SZBUFFTOFILL = '<A NAME="LNK' + num$(IHREFCONTROL) + '"></A>'
    Wrseq SZBUFFTOFILL(0) Using [FXML]
  Endif
  IHREFCONTROL += 1
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = '<A CLASS="cAHREF" HREF="' + chr$(35)+ 'LNK' + num$(IHREFCONTROL) +'">'
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = SZHTMLTITLE
  Call MODVAL(SZBUFFTOFILL(0))
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = "</A></TD></TR></THEAD><TBODY>"
  Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

##########################################################################################################
$DOENDTABLE
  Raz SZBUFFTOFILL
  SZBUFFTOFILL = "</TBODY></TABLE><BR>"
  Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

##########################################################################################################
$HTMLPART1
Local Integer IWHERE
Local Char SZHTMLTITLE(250)
Local Char SZLABELFORFILL(250)
Local Char SZDATAFORFILL(250)
Local Char SP(2)
Local Char SZBUFFTOFILL(250)(2)                 #Buffers d'écriture
Local Char SZADXIFS(type(adxifs)-10)            #Séparateurs
Local Char SZADXIRS(type(adxirs)-10)            #Séparateurs
Local Char SZXMLFILENAME(250)
Local Char SZWFNAME(250)
Local Char SZSUBPROG(GLONADC)
Local Char SZAOBABREV(GLONABR)

  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  Raz SZBUFFTOFILL
  Raz SZLABELFORFILL
  Raz SZDATAFORFILL
  SP = '_'
  IWHERE = 1
Return

##########################################################################################################
$HTMLPART2
  If SZSCREENTYPE = "" Then
    SZSCREENTYPE = "PC"
  Endif
  If SZPECONTEXT = "" Then
    SZPECONTEXT = SZSUBPROG
  Endif
  #Fichier XML
  If IGENERICFILENAME Then
    SZWFNAME = SZSUBPROG
  Else
    SZWFNAME = SZAOBABREV + SP + SZRECNUM
  Endif
  SZXMLFILENAME = ""
  #Ouverture du fichier HTML
  Call BUILDFICNAME(0, SZWFNAME, "htm", SZXMLFILENAME)
  If SZXMLFILENAME = ""
    #Erreur lors de l'ouverture du fichier HTML
    IERRINF = 72
    ICHAPTER = 177
    #On restaure les variables adxifs et adxirs
    adxifs = SZADXIFS
    adxirs = SZADXIRS
    Return
  Endif
  Openo SZXMLFILENAME, 0 Using [FXML]
  Gosub DOSTARTHTML
Return

##########################################################################################################
$HTMLPART3
  Gosub DOENDHTML
  #On ferme le fichier HTML
  Openo Using [FXML]
  # FGR 05/12/2007 : X3Suivi44572 (DEBUT) On transfert le fichier sur le poste (VISTA)
  #                   Seulement si on a demandé qu'il soit sur le client (donc IWHERE = 1)
  Callui RETOUR="" With "UIAction="+chr$(1)+"GetFileAlways",
&                       "UIRemoteFile="+ chr$(1) +SZXMLFILENAME,
&                       "UILocalDir="+ chr$(1) +"Report",
&                       "UILocalFile="+ chr$(1) +SZWFNAME+ ".xml"
  # FGR 05/12/2007 : X3Suivi44572 (FIN) On transfert le fichier sur le poste (VISTA)
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
  #On renvoie le nom du fichier généré
  SZFULLRETFILE = SZXMLFILENAME
  SZRETFILENAME = SZWFNAME + ".xml"
Return

##########################################################################################################
$XMLPART1
#Caractères XML
Local Char A(2)
Local Char B(4)
Local Char C(4)
Local Char D(2)
Local Char VQ(2)
Local Char SP(2)

  SP = '_'
  VQ = '"'
  A = "<"
  B = "</"
  C = "/>"
  D = ">"

Local Integer IWHERE
Local Char SZHTMLTITLE(250)
Local Char SZLABELFORFILL(250)
Local Char SZDATAFORFILL(250)
Local Char SZBUFFTOFILL(250)(2)             #Buffers d'écriture
Local Char SZADXIFS(type(adxifs)-10)        #Séparateurs
Local Char SZADXIRS(type(adxirs)-10)        #Séparateurs
Local Char SZXMLFILENAME(250)
Local Char SZWFNAME(250)
Local Char SZSUBPROG(GLONADC)
Local Char SZAOBABREV(GLONABR)

  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  Raz SZBUFFTOFILL
  Raz SZLABELFORFILL
  Raz SZDATAFORFILL
  IWHERE = 1

Local Char SZCTAOB(100)
Local Char SZCTAOBTITLE(100)
Local Char SZCTAOBNUM(100)
Local Char SZCTLEVEL(100)
Local Char SZCTPARENTAOB(100)
Local Char SZCTPARENTNUM(100)

  SZCTAOB = ""
  SZCTAOBTITLE = ""
  SZCTAOBNUM = ""
  SZCTLEVEL = ""
  SZCTPARENTAOB = ""
  SZCTPARENTNUM = ""

#Définition des tags XML
Local Char SZXROOT(100)
Local Char SZXUTILITY(100)
Local Char SZXTITLE(100)
Local Char SZXRECORD(100)
Local Char SZXAOB(100)
Local Char SZXAOBTITLE(100)
Local Char SZXAOBNUM(100)
Local Char SZXLEVEL(100)
Local Char SZXPARENTAOB(100)
Local Char SZXPARENTNUM(100)
Local Char SZXAOBDATA(100)
Local Char SZXSORT(100)
Local Char SZXLABEL(100)
Local Char SZXFIELD(100)

  SZXROOT = "XROOT"
  SZXUTILITY = "XUTILITY"
  SZXTITLE = "XTITLE"
  SZXRECORD = "XRECORD"
  SZXAOB = "XAOB"
  SZXAOBTITLE = "XAOBTITLE"
  SZXAOBNUM = "XAOBNUM"
  SZXLEVEL = "XLEVEL"
  SZXPARENTAOB = "XPARENTAOB"
  SZXPARENTNUM = "XPARENTNUM"
  SZXAOBDATA = "XAOBDATA"
  SZXSORT = "XSORT"
  SZXLABEL = "XLABEL"
  SZXFIELD = "XFIELD"
  #Modification du nom des tags XML
  Gosub PE_XMLTAG From TRTCRMPE
  If SZXROOT = "" Then
    SZXROOT = "XROOT"
  Endif
  If SZXUTILITY = "" Then
    SZXUTILITY = "XUTILITY"
  Endif
  If SZXTITLE = "" Then
    SZXTITLE = "XTITLE"
  Endif
  If SZXRECORD = "" Then
    SZXRECORD = "XRECORD"
  Endif
  If SZXAOB = "" Then
    SZXAOB = "XAOB"
