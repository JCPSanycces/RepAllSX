##########################################################################################################
$DOSTART1XML
Local Integer ITERCLOB
Local Integer ITERSORT
Local Char SZCLOBIFS(type(adxifs)-10)
Local Char SZCLOBIRS(type(adxirs)-10)
Local Char SZABR(GLONABR)
Local Char SZFIE(250)
Local Char SZTABLE(GLONATB)

  ITERSORT = 0
  ITERCLOB = 0
  Call TEMPON("E") From GESECRAN
  #En-tête du fichier XML
  Raz SZBUFFTOFILL
  Call XMLENTET(SZBUFFTOFILL(0))
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  #Ajout de la liaison avec une feuille de transformation
  If SZXSLSHEET <> "" Then
    Raz SZBUFFTOFILL
    Call XMLXSLT(SZXSLSHEET, SZBUFFTOFILL(0))
    Wrseq SZBUFFTOFILL(0) Using [FXML]
  Endif
Return

##########################################################################################################
$DOSTART2XML
  #Ecriture du ROOT
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXROOT + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  #Ecriture des données utilitaires
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXUTILITY + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXTITLE + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = SZHTMLTITLE
  Call MODVAL(SZBUFFTOFILL(0))
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXTITLE + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXUTILITY + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

