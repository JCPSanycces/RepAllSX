$XMLPART3
  Gosub DOENDXML
  #On ferme le fichier XML
  Openo Using [FXML]
  # FGR 23/04/2008 : X3SUIVI46965 Fichiers générés sur le serveur puis rappatriés sur la poste à la fermeture
  Callui RETOUR="" With "UIAction=" + chr$(1) + "GetFileAlways",
&                       "UIRemoteFile=" + chr$(1) + SZXMLFILENAME,
&                       "UILocalDir=" + chr$(1) + "Report",
&                       "UILocalFile=" + chr$(1) + SZWFNAME+ ".xml"
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
  #On renvoie le nom du fichier généré
  SZFULLRETFILE = SZXMLFILENAME
  SZRETFILENAME = SZWFNAME + ".xml"
Return

