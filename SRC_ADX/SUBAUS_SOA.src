#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################
Subprog PARAMUTIL(PARAM,VALEUR,USR,SITE)
Value    Char    PARAM     : # Parameter code
Variable Char    VALEUR    : # Value returned from the ADOVAL table
Value    Char    USR       : # User code or empty if GUSER
Value    Char    SITE      : # Site otherwise default site search module

Local Integer OK , OFSTAT, RESULT
Local Char    PPROFIL(GLONAFT) , OPRFCOD(GLONAFT) , OPARAM(GLONADP) , OUSR(GLONAUS) , OMET(GLONAME)

OFSTAT = fstat
[L]VALEUR = ""

#Local Instance ADOVALAUS Using C_ADOVALAUS
#If ADOVALAUS = null
#  ADOVALAUS =  NewInstance C_ADOVALAUS AllocGroup null
#Endif
Local File ADOVALAUS [ADU]

If [L]USR<>AVOID.ACHAR
  #RESULT = fmet ADOVALAUS.AREAD([L]USR,[L]PARAM)
  Read [ADU]ADU0 = [L]USR;[L]PARAM
Else
  Local Char SOA_GUSER(5) : Call GUSER(SOA_GUSER) From ESSGLOB_SOA
  #RESULT = fmet ADOVALAUS.AREAD(SOA_GUSER,[L]PARAM)
  Read [ADU]ADU0 = [L]SOA_GUSER;[L]PARAM
Endif
If fstat = [V]CST_AOK
  #[L]VALEUR = ADOVALAUS.VALEUR
  VALEUR = [ADU]VALEUR
  LogicClose File [ADU]
  End
Else
  If dim([F:AFT]PRFCOD) > 0
    OPRFCOD = [F:AFT]PRFCOD
  Else
    Local File AFCTFCT [AFT]
  Endif

  If dim([F:ADP]PARAM) > 0
    OPARAM  = [F:ADP]PARAM
  Else
    Local File ADOPAR [ADP]
  Endif

  If dim([F:AUS]USR) > 0
    OUSR = [F:AUS]USR
  Else
    Local File AUTILIS [AUS]
  Endif

  If dim([F:AME]CODMET) > 0
    OMET = [F:AME]CODMET
  Else
    Local File AMETUTI [AME]
  Endif

  Read [ADP]ADP1 = [L]PARAM
  If !fstat & [F:ADP]VALDEF=[V]CST_AYES
    If [L]SITE<>AVOID.ACHAR
      #Call PARAM([L]SITE,[L]PARAM,[L]VALEUR) From ADOVAL
      VALEUR = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 3, [L]SITE, [L]PARAM)
    Else
      If [L]USR<>AVOID.ACHAR
        If [L]USR<>[F:AUS]USR
          Read [AUS]CODUSR = [L]USR
        Endif
        If [F:AUS]PRFFCT=AVOID.ACHAR
          Read [AME]AME0 = [F:AUS]CODMET
          PPROFIL = [F:AME]PRFFCT
        Else
          PPROFIL = [F:AUS]PRFFCT
        Endif
      Else
        Local Char SOA_GPROFIL(5) : Call GPROFIL(SOA_GPROFIL) From ESSGLOB_SOA
        PPROFIL = SOA_GPROFIL
      Endif
      If PPROFIL=AVOID.ACHAR
        #Call PARAM([L]SITE,[L]PARAM,[L]VALEUR) From ADOVAL
        VALEUR = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 1, AVOID.ACHAR, [L]PARAM)
      Else
        Read [AFT]AFT0 = PPROFIL
        If !fstat
          Call DFLCHAP([F:ADP]CHAPITRE,[L]SITE,OK)
          #Call PARAM([L]SITE,[L]PARAM,[L]VALEUR) From ADOVAL
          VALEUR = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 3, [L]SITE, [L]PARAM)
        Endif
      Endif
    Endif
  Endif
  If OPRFCOD<>AVOID.ACHAR : Read [AFT]AFT0   = OPRFCOD : Endif
  If OPARAM<>AVOID.ACHAR  : Read [ADP]ADP1   = OPARAM  : Endif
  If OUSR<>AVOID.ACHAR    : Read [AUS]CODUSR = OUSR    : Endif
  If OMET<>AVOID.ACHAR    : Read [AME]AME0   = OMET    : Endif
Endif
fstat = OFSTAT

LogicClose File [ADU]

End
##############################################################################
Subprog DFLCHAP(CHAPITRE,SITE,OK)
Value    Char    CHAPITRE
Variable Char    SITE
Variable Integer OK

$DEFAUT_CHAP
Local Libelle SOA_GMODU(1..20) : Call GMODU(SOA_GMODU) From ESSGLOB_SOA
If dim(SOA_GMODU)<0 : End : Endif
OK = 0

L_MODULE = func AFNC.GET_MODULE_FROM_CHP(nomap,CHAPITRE)
If L_MODULE<=0
  Case CHAPITRE
    When "SUP"
      [L]SITE =[F:AFT]FCYDEF(0)
      If SOA_GMODU(1)=[V]CST_AYES # & !GIMPORT
        OK = [V]CST_ANO
      Endif
  Endcase
Else
  SITE = func AFNC.GET_SITE_FROM_MDL(nomap,L_MODULE,[F:AFT]PRFCOD)
  If SOA_GMODU(L_MODULE)=[V]CST_AYES # & !GIMPORT
    OK = [V]CST_ANO
  Endif
Endif

End
##############################################################################

