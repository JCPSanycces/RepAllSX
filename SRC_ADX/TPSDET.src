#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(30)(1..3) ,  VALEUR(10)
PARAM(1) = "MAT1"
VALEUR   = "CPE"
Call TRAITE_CHAR(VALEUR,PARAM,"","TPSDET","TPSDET",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
Endcase
Return

$INIT
If clalev([F:TIM])=0 : Local File TIMCOD [TIM] : Endif
If clalev([F:TIP])=0 : Local File TIMEMP [TIP] : Endif
#LIPET - 14-02-2017 - X3-25348 - START
#Local Char    CODE(GLONTPS) , MATRI(GLONMAT)
Local Char    CODE(GLONTPS) , MATRI(GLONEML)
#LIPET - 14-02-2017 - X3-25348 - END
Local Integer TYPCOD, I
CODE   = VALEUR
MATRI  = PARAM(1)
TYPCOD = val(PARAM(2))
If (TYPCOD=0 & CODE="") or MATRI=""
 FIN = 1 : Return
Endif
#ADNGO - 2017-01-13 - X3-11765 - START
#Link [TIP] With [TIM]TIM0=[F:TIP]TIM As [LTIP]
Link [TIP] With [TIM]TIM0=GCURLEG;[F:TIP]TIM As [LTIP]
#ADNGO - 2017-01-13 - X3-11765 - END
If TYPCOD<>0
 Filter [LTIP] Where [F:TIP]REFNUM=MATRI & [F:TIM]CATTIM=TYPCOD Order By Key TIP1 Desc
Else
#ADNGO - 2017-01-13 - X3-11765 - START
 #Read [TIM]TIM0 = CODE
 Read [TIM]TIM0 = GCURLEG;CODE
#ADNGO - 2017-01-13 - X3-11765 - END
 If fstat
  FIN = 1
  Return
 Endif
 Filter [LTIP] Where [F:TIP]REFNUM=MATRI & [F:TIP]TIM=CODE Order By Key TIP1 Desc
Endif

Read [LTIP] First
If fstat>2
 GERR = 1
 #ADNGO - 2017-01-13 - X3-11765 - START
 #GMESSAGE = mess(56,709,1)-string$(TYPCOD<>0,mess(TYPCOD,412,1))-CODE : # Pas de temps de type ...
 GMESSAGE = mess(56,10709,1)-string$(TYPCOD<>0,mess(TYPCOD,10412,1))-CODE : # Pas de temps de type ...
 #ADNGO - 2017-01-13 - X3-11765 - END
 FIN = 1
 Return
Endif
Return

$INIT_DIA
If TYPCOD=0
#LIPET - 14-02-2017 - X3-25348 - START
 Call LECTEXTRA([M:DIA]CMT,"TIMCOD","DES",GCURLEG,[M:DIA]TIM) From ATEXTRA
 TIT = MATRI-":"-[F:TIM]COD-[M:DIA]CMT
 #TIT = MATRI-":"-[F:TIM]COD
#LIPET - 14-02-2017 - X3-25348 - END
Else
#ADNGO - 2017-01-13 - X3-11765 - START
 #TIT = MATRI-":"-mess(TYPCOD,412,1)
 TIT = MATRI-":"-mess(TYPCOD,10412,1)
 #ADNGO - 2017-01-13 - X3-11765 - END
Endif
Raz [M:DIA]
nolign = 0
For [LTIP]
 nolign += 1
 If nolign>=dim([M:DIA]STRDAT)
  Break
 Endif
 [M:DIA] = [F:TIP]
## Bug 24619
# If nolign>1
#  [M:DIA]CUMDAY(nolign-1) = [M:DIA]CUMDAY(nolign-2)
#  [M:DIA]CUMHOU(nolign-1) = [M:DIA]CUMHOU(nolign-2)
# Endif
# [M:DIA]CUMDAY(nolign-1) += [M:DIA]NBRDAY(nolign-1)
# [M:DIA]CUMHOU(nolign-1) += [M:DIA]NBRHOU(nolign-1)
## Fin Bug 24619
Next
[M:DIA]NBRLIG = nolign
Filter [LTIP]
## Suggestion 24619
For I=[M:DIA]NBRLIG To 1 Step -1
 If I<[M:DIA]NBRLIG
  [M:DIA]CUMDAY(I-1) = [M:DIA]CUMDAY(I)
  [M:DIA]CUMHOU(I-1) = [M:DIA]CUMHOU(I)
 Endif
 [M:DIA]CUMDAY(I-1) += [M:DIA]NBRDAY(I-1)
 [M:DIA]CUMHOU(I-1) += [M:DIA]NBRHOU(I-1)
Next I
## Fin Bug 24619
Return

