#######################################################################################
# Classe OPPORSBB
#######################################################################################
# EVENTS                                                                              #
#######################################################################################
$ACONTROL
Local Char SMESS(250)        # Issue X3-87228 - 2018-06-26 by FGR/ALMON

  If this.APARENT = null Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(192,2260,1), [V]CST_AFATAL))
    Return
  Endif
  # Issue X3-87228 - 2018-06-26 by FGR/ALMON : BEGIN
  If func PIMPL_CSTD_PROGS.GET_PIMTYP_VALUE(this.ACTX, this.SBBPJT, AVOID.ACHAR, AVOID.ACHAR, SMESS) = 1 Then
    If this.CONSFLG <> [V]CST_ANO Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("CONSFLG", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
  # Issue X3-87228 - 2018-06-26 by FGR/ALMON : END
Return

#######################################################################################
$ADELETE_CONTROL_BEFORE
  If this.APARENT = null Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(193,2260,1), [V]CST_AFATAL))
    Return
  Endif
Return

