#<AdxTL>@(#)0.0.0.0 $Revision$
#-----------------------------------------------------------------------#
#     chargement dans le fichier de travail                             #
#-----------------------------------------------------------------------#
$CHARGESWI
Local Integer WWEEK
Local Date    WDAT

  # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:20/12/16)
#  Call DEBTRANS From GLOCK
#  $CHGFIC
#  GOK=1
#  Trbegin [SWICND]
  # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:20/12/16)

  #--ATTENTION : trouver une solution car tables faisant partie du Link avec TIM !!!
  #--Erreur suite Readlock : pour l'instant mis en commentaire
  ## -------------------> lecture entête commande
  #Readlock [SOH]SOH0 Curr
  #If    fstat=1 : GOK=-1 : GLOCK="$SORDER"+[F:SOH]SOHNUM : Goto ROL_CHGFIC
  #Elsif fstat   : GOK=0  : Call RSTA("SOH",[F:SOH]SOHNUM) From GLOCK : Goto AB_TRT
  #Endif
  #
  ## -------------------> lecture détail cde qte
  #Readlock [SOQ]SOQ0 Curr
  #If    fstat=1 : GOK=-1 : GLOCK="$SORDERQ"+[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ) : Goto ROL_CHGFIC
  #Elsif fstat   : GOK=0  : Call RSTA("SOQ",[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)-num$([F:SOQ]SOQSEQ)) From GLOCK : Goto AB_TRT
  #Endif

  Gosub SEL_DETCOMPL From FUNAUTINVSCH
  If OK = 2
    # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:20/12/16)
    # --> lock fichier entête commande
    SYMBOLE = "SOH"+[F:SOH]SOHNUM
    Lock = SYMBOLE
    If fstat
       # modification en cours sur un autre poste
       Call ECR_TRACE("$SORDER :"-[F:SOH]SOHNUM-mess(10,100,1),1) From GESECRAN
       OK=1
    Endif

    If OK=2
        # --> ouverture de la txn de maj après le lock SYMBOLE
        Call DEBTRANS From GLOCK
        $CHGFIC
        GOK=1
        Trbegin [SWICND]
        # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:20/12/16)

        Raz [F:SWICND]
        [F:SWICND]PRONUM  = adxuid(1)
        [F:SWICND]SWIKEY  = [F:SOH]SALFCY
        [F:SWICND]SWIKEY += "~"+[F:SOH]BPCINV

        [F:SWICND]SWIKEY1 = WIME

        Case WIME
         When "1" : #1 fac/date prochaine fac
            [F:SWICND]SWIKEY1 += "~"+num$([SVICLNK]NEXINVDAT)
         When "2" : #1 fac/cde
            [F:SWICND]SWIKEY1 += "~"+[F:SOH]SOHNUM
         When "3" : #1 fac/client
            [F:SWICND]SWIKEY1 += "~"+[F:SOH]BPCORD
            [F:SWICND]SWIKEY1 += "~"+[F:SOQ]BPAADD
         When "4" : #1 fac/projet
            #--Fait juste en dessous...
         When Default
        Endcase

        [F:SWICND]SWIKEY1 += "~"+[F:SOH]CUR
        [F:SWICND]SWIKEY1 += "~"+num$([F:SOH]PRITYP)

        #-- Ca n'est plus le PJT de l'entête qui compte
        If GPJTSNGDOC = G_OUI Then
          #-- Si le PJT est unique par pièce il est discriminant : on le prend
          [F:SWICND]SWIKEY1 += "~"+[F:SOH]PJT
        Else
          If WIME="4"
            #--Si 1 fac/projet on le prends à la ligne
            [F:SWICND]SWIKEY1 += "~"+[F:SOQ]PJT
          Else
            #-- Sinon, il n'est pas discriminant : on l'ignore
            [F:SWICND]SWIKEY1 += "~"
          Endif
        Endif

        [F:SWICND]SWIKEY1 += "~"+[F:SOH]BPCPYR
        [F:SWICND]SWIKEY1 += "~"+[F:SOH]VACBPR

        [F:SWICND]SWIKEY1 += "~"+[F:SOH]BPIEECNUM
        [F:SWICND]SWIKEY1 += "~"+[F:SOH]EECICT
        [F:SWICND]SWIKEY1 += "~"+num$([F:SOH]EECLOC)

        [F:SWICND]NUM = [F:SOH]SOHNUM
        [F:SWICND]LIN = [F:SOQ]SOPLIN
        [F:SWICND]SEQ = [F:SOQ]SOQSEQ

        [F:SWICND]SWIDATA  = [F:SOH]BPCGRU
        [F:SWICND]SWIDATA += "~"+[F:SOH]PTE
        [F:SWICND]SWIDATA += "~"+num$([F:SOH]BETFCY)
        [F:SWICND]SWIDATA += "~"+[F:SOH]ORIFCY
        [F:SWICND]SWIDATA += "~"+[F:SOH]PLISTC
        [F:SWICND]SWIDATA += "~"+toupper(vireblc([F:SOH]BPINAM(0),4))
        [F:SWICND]SWIDATA += toupper(vireblc([F:SOH]BPIADDLIG(0),4))
        [F:SWICND]SWIDATA += toupper(vireblc([F:SOH]BPIPOSCOD,4))
        [F:SWICND]SWIDATA += toupper(vireblc([F:SOH]BPICTY,4))
        [F:SWICND]SWIDATA += toupper(vireblc([F:SOH]BPISAT,4))

        Gosub CHARGESWI1

        Gosub CHARGESWI2

        #-- Codes adresses client commande et facture
        [F:SWICND]SWIDATA += [F:SOH]BPAORD
        [F:SWICND]SWIDATA += [F:SOH]BPAINV

        [F:SWICND]SWILINNBR = [F:SOH]LINNBR

        #-- Chargement qté à facturer dans (SWICND]
        #-- WQTY     = qté à facturer en UV
        #-- WQTYSTU  = qté à facturer en US
        [F:SWICND]QTY=[F:SVICD]INVCNDQTY

      #--A REVOIR A enlever
      #  If WQTY>[F:SVICD]INVCNDQTY
      #    WQTY    = [F:SVICD]INVCNDQTY
      #  Endif
      #  Raz [F:SWICND]QTY
      #  #-- Si ligne de commande normale ou de nomenclature
      #  If [F:SOH]SOHCAT=4 | !find([F:SOP]LINTYP,2,3,4,5,10,11,12,13)
      #     [F:SWICND]QTY    = WQTY
      ##     [F:SWICND]QTYSTU = WQTYSTU
      #  #-- Si composé kit/sous-traité
      #  Elsif find([F:SOP]LINTYP,2,10)
      #     [F:SWICND]QTY    = WQTY
      ##     [F:SWICND]QTYSTU = WQTYSTU
      #     #-- Stockage qté livré et cdé composé pour calcul qté composant
      #     WQTYCPE       = WQTY
      #     WSOQQTY       = [F:SOQ]QTY
      #  #-- Si composant kit/sous-traité
      #  Elsif find([F:SOP]LINTYP,3,4,5,11,12,13)
      #     [F:SWICND]QTY    = WQTYCPE*([F:SOQ]QTY/WSOQQTY)
      ##     [F:SWICND]QTYSTU = [F:SWICND]QTY*[F:SOP]SAUSTUCOE
      ##     Call QTEARR ([F:SWICND]QTYSTU,[F:SOP]STU) From TRTDIV
      #  Endif
      #--/A REVOIR

        #-- Pour rajouter des conditions de regroupements
        GPOINT="AUTINVSCHREG" : Gosub ENTREE From EXEFNC

        Gosub CHARGESWI3

        #--Reporter la clé de [SVIC]
        #--Utile car le parcours de la table temporaire se fera sur un Link avec les tables en-tête/lignes d'origine
        [F:SWICND]VCRTYP       = [F:SVICLNK]VCRTYP
        [F:SWICND]VCRNUMORI    = [F:SVICLNK]VCRNUMORI
        [F:SWICND]VCRLINORI    = [F:SVICLNK]VCRLINORI
        [F:SWICND]VCRSEQORI    = [F:SVICLNK]VCRSEQORI
        [F:SWICND]INVCNDTYP    = [F:SVIC]INVCNDTYP
        [F:SWICND]VCRINVCNDLIN = [F:SVICLNK]VCRINVCNDLIN
        #--
        Write [SWICND]
        If fstat
           GOK=0 : Call FSTA("SWICND") From GLOCK : Goto AB_TRT
        Endif
        Commit
    # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:20/12/16)
    Endif
#  Else
#    Rollback
    # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15765 (LD:20/12/16)
  Endif

Return

$AB_TRT

  Rollback

  WTRBEGIN = 0
  Raz WKEY, WKEY1, WNUM, WDATA
  #-- Sage Exchange
  If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([F:SIH]PTE)
    Call POST_AUTH(2,[F:SIV]SIHORINUM,SEERR,SEMESSAGE) From SEPPLIB
  Endif
  $ERR_TRT
  Call PJT_WRITE_MSG() From TRTPJT
  WMESS =mess(17,107,1)
  Call ECR_TRACE("         "+WMESS,0)From GESECRAN
  Raz WMESS

Return

$CHARGESWI1

        # LTA - Sage sales tax USA
        If func AFNC.ACTIV("LTA")
          [F:SWICND]SWIDATA +="~"+[F:SOH]SSTENTCOD
        Endif
Return


$CHARGESWI2
        #-- Gestion de GRUFLG (flag regroupement des éléments de facturation)
        Local Integer I, J : I=0
        While [L]GRUNON(I)>0 and I<RCNTDFI-1
            J=find([L]GRUNON(I), [F:SOH]INVDTA)
            If J>0
              #--Afin de tenir compte du paramètrage éclatement à "1ère Facture"
              #--Si cde déjà facturée, la facture suivante prends 0 pour l'élément de facturation
              If [F:SOH]INVSTA>1
                [F:SWICND]SWIDATA += "~" + "0"
              Else
                [F:SWICND]SWIDATA += "~" + vireblc( num$( [F:SOH]INVDTAAMT(J-1) ) ,4 )
              Endif
            Endif
            I+=1
        Wend

Return


$CHARGESWI3
        If [F:SWICND]SWIDATA<>""
          Filter [SWICND1] Where PRONUM=[F:SWICND]PRONUM & SWIKEY=[F:SWICND]SWIKEY & SWIKEY1=[F:SWICND]SWIKEY1 &
&                               SWIDATA=[F:SWICND]SWIDATA
          Read [SWICND1] First
          If fstat
            WSWIKEYD +=1
            [F:SWICND]SWIKEYD=WSWIKEYD
          Else
            [F:SWICND]SWIKEYD=[F:SWICND1]SWIKEYD
          Endif
          Filter [SWICND1]
        Endif

Return


$LOAD_SWICND
Local Char CRITERE(255)
Local Char CRITSVCRINVCND(255),CRITSVCRINVCNDLIN(255)

Local Char FILSUPENT(250), FILSUPDET(250)
Local Integer WSWIKEYD

  #--Schedule header
  CRITSVCRINVCND     = '1=1'
  #--Schedule line
  CRITSVCRINVCNDLIN  = '1=1'
  CRITSVCRINVCNDLIN += '&[F:SVICD]INVCNDSTA<=1'
  CRITSVCRINVCND    += '&[F:SVICD]NEXINVDAT<=['+format$(GFMD,[M:DIA]INVDAT)+']'
  If [M:DIA]DEMDLVDAT <> [0/0/0]
     CRITSVCRINVCND    += '&[F:SVICD]NEXINVDAT<=['+format$(GFMD,[M:DIA]DEMDLVDAT)+']'
  Endif
  CRITSVCRINVCND    += '&[F:SVICD]VCRTYP=10'

  #----Grouping cryteria
  # SIV.SALFCY       : SALES SITE
  # SIV.BPCINV       : BILL-To CUSTOMER
  # SIV.BPCORD       : SOLD-To CUSTOMER ? IS-IT USE For EXISTING INVOICE PROCESSES?
  # SIV.BPRPAY       : PAY-By PARTNER
  # SIV.BPCGRU       : GROUP CUSTOMER
  # SIV.CUR          : CURRENCY
  # SIH.VAC          : TAX RULE
  # SIV.PRITYP       : PRICE -/+ TAX
  # SIH.PTE          : PAYMENT TERM
  # SIH.BPRNAM(0)    : BILL-O CUSTOMER NAME 1
  # SIH.BPAADDLIG(0) : ADDRESS LINE 1
  # SIH.POSCOD       : POSTAL CODE
  # SIH.CTY          : CITY
  # SIH.CRY          : COUNTRY
  # SIH.SAT          : STATE

  #--Etape 1
  #--Set up des critères de filtre pour les lignes intermédiaires
  #--CRITERE : contient des filtres sur la table en-tête à l'origine de la ligne intermédiaire
  #--Objectif : sélectionner les lignes intermédiaires à traiter lors de la facturation courante
  #--> critères de saisie
  CRITERE = '[SOH]SALFCY="'+[M:DIA]SALFCY+'"'
  If [M:DIA]SOHNUMDEB <> ""
     CRITERE -= '&[SOH]SOHNUM>="'+[M:DIA]SOHNUMDEB+'"'
  Endif
  If [M:DIA]SOHNUMFIN <> ""
     CRITERE -= '&[SOH]SOHNUM<="'+[M:DIA]SOHNUMFIN+'"'
  Endif
  If [M:DIA]BPCINVDEB <> ""
     CRITERE -= '&[SOH]BPCINV>="'+[M:DIA]BPCINVDEB+'"'
  Endif
  If [M:DIA]BPCINVFIN <> ""
     CRITERE -= '&[SOH]BPCINV<="'+[M:DIA]BPCINVFIN+'"'
  Endif

  # V6.2 : Certification
  # Si ctrl date documents : La commande doit avoir une date <= à la date de la facture
  If GCTLDATORI=2  CRITERE -='& [SOH]ORDDAT<=['+format$(GFMD,[M:DIA]INVDAT)+']' Endif

  #--> Critères supplémentaires
  CRITERE -= "&[SOH]HLDSTA<2"                 :# order holds
  CRITERE -= "&[SOH]SOHCAT=1"                 :# cat  cde         =  normale
  #CRITERE -= "& ALLSTA <> 1"                  :# état alloc       allouée même partiellement
  CRITERE -= "&[SOH]INVSTA<>3"                :# état facture     non facturée
  # 107888 : Scheduled invoices : X3-21154 (LD:18/01/17)
  # The invoice mode should not be taken into account
  #CRITERE -= "&[SOH]IME<>6"                   :# mode facturation <> fact manuelle
  # 107888 : Scheduled invoices : X3-21154 (LD:18/01/17)
  CRITERE -= "&[SOH]APPFLG>2"                 :# état signature cde : signée

  #---------------------------------------------------------------------#
  # Point d'entree ajout filtres supplémentaires                        #
  #---------------------------------------------------------------------#
  FILSUPENT="1=1"
  FILSUPDET="1=1"
  GPOINT="AUTINVSCHFIL" : Gosub ENTREE From EXEFNC

  #--Etape 1
  #--Set up des critères de filtre pour les lignes intermédiaires
  #--CRITERE : contient des filtres sur la table en-tête à l'origine de la ligne intermédiaire
  #--Objectif : sélectionner les lignes intermédiaires à traiter lors de la facturation courante

  #--> Critères supplémentaires
  CRITDET = "[SOQ]SOQSTA<>3"
  #--Sur SVICD
  #If [M:DIA]DEMDLVDAT <> [0/0/0]
  #   CRITDET -= "&[SOQ]SHIDAT<=["+format$(GFMD,[M:DIA]DEMDLVDAT)+"]"
  #Endif
  #CRITDET -= '&[SOQ]SOHNUM="'+[F:SOH]SOHNUM+'"' #--Plus besoin car fera partie du link
  CRITDET -= "&[SOQ]DEMSTA=1"

  #--Etape 3
  #--Déterminer les éléments de facturation avec flag regroupement "Non si différent"
  #--Ces derniers vont alors faire partie des critères de regroupement
  #--On ajoute dans le tableau [L]GRUNOM les numeros des élements
  #--dont la regle de regroupement est à "Non si différent", pour ce document
  Gosub OPEN_SFI From TRTX3CPY

  Gosub LOAD_SWICND1

  Gosub LOAD_SWICND2

  WOK=1
  #If dim(GPJTSNGDOC)<1 : Global Integer GPJTSNGDOC : GPJTSNGDOC= G_NON : Endif #--A VIRER !! pour mock

  #--Etape 4
  #--Link de la table des lignes intermédiaires avec les tables en-tête/lignes à l'origine de ces dernières
  #--Les filtres utilisés :
  #--CRITSVCRINVCND      : porte directement sur la tables des échéanciers
  #--CRITSVCRINVCNDLIN   : porte directement sur les lignes de la table des échéanciers
  #--CRITERE             : porte sur les champs de la table en-tête d'origine (içi SORDER)
  #--FILSUPENT           : positionné par point d'entrée - contient les éventuels filtres sur champs en-tête table origine
  #--CRITDET             : porte sur les champs de la table lignes d'origine (içi SORDERQ uniquement)
  #--FILSUPDET           : positionné par point d'entrée - contient les éventuels filtres sur champs ligne table origine

#  #--Définition du Link entre table intermédiaire et en-tête/lignes origine
#  Link [SVICD] With [SVIC]SVIC0~=[SVICD]VCRTYP;
#&                                [SVICD]VCRNUMORI;[SVICD]VCRLINORI;[SVICD]VCRSEQORI,
#&                   [SOH]SOH0  ~=[SVICD]VCRNUMORI,
#&                   [SOQ]SOQ0  ~=[SVICD]VCRNUMORI;[SVICD]VCRLINORI;[SVICD]VCRSEQORI
#&               As  [SVICLNK]
#&           Where evalue(CRITSVCRINVCND) and
#&                 evalue(CRITSVCRINVCNDLIN) and
#&                (evalue(CRITERE) and evalue(FILSUPENT)) and
#&                (evalue(CRITDET) and evalue(FILSUPDET))
Gosub LOAD_SWICND_LINK From FUNAUTINVSCH
#--Boucle sur link et alimentation de la table temporaire (compte tenue des critères de regroupement)
#--Parcours des enregistrements intermédiaires afin de remplir la table temporaire
#--Objectif : chargement des différents critères de regroupement
#--           afin d'avoir un parcours linéaire de la création des factures
#--ESSENTIEL à l'utilisation du GENSIH !!! (car continue à lire au travers du READ_DETAIL de TRTSIHSVICSOH)

  WIME="1" # by default : 1 fac/date prochaine fac
  If [M:DIA]IMESVIC>0
    WIME=num$([M:DIA]IMESVIC)
  Endif

#  For [SVICLNK]
#    Gosub CHARGESWI
#    If WOK=0 : Break : Endif
#  Next
  Gosub LOAD_SWICND_USE_LINK From FUNAUTINVSCH

  Close File [SVICLNK]

Return

$LOAD_SWICND1

  Local Integer RCNTDFI : RCNTDFI= nbrecord([F:SFI])

Return

$LOAD_SWICND2

  If RCNTDFI<=5 : RCNTDFI = 10 : Endif
  Local Integer GRUNON([L]RCNTDFI), I1, I2, I12, PDESVCR, PORIVCR
  PDESVCR=4  :#--'Facture'
  PORIVCR=10 :#--'Cde normale'
  I2=0
  Read [SFI]First
  While fstat=0
      I12=find([L]PDESVCR, [F:SFI]DESVCR(0..dim([F:SFI]DESVCR)-1))
      #--Deux règles de transfert portent sur le doc de destination "Facture"
      #--Il faut pointer sur le flux "Cde normale" -> "Facture"
      #--Normalement, c'est le suivant...
      If I12>0
        I1=find([L]PORIVCR, [F:SFI]ORIVCR(I12-1..dim([F:SFI]ORIVCR)-1))
        If I1>0 & [F:SFI]GRUFLG(I1-1) = 2
            [L]GRUNON(I2)=[F:SFI]SFINUM
            I2+=1
        Endif
      Endif
      Read [F:SFI] Next
  Wend

Return

