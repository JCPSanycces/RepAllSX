#<AdxTL>@(#)3.0.0.0 $Revision$
Local    Char    WCRIT(250)
Local    Integer I,J 
Local Char CRIT(20)(5)

WCRIT = ""
I = 0
J = instr(1,WCRIT,',')
While J>0
   CRIT(I) = seg$(WCRIT,1,J)
   WCRIT = right$(WCRIT,J+1)
   I += 1
   J = instr(1,WCRIT,',')
Wend
If WCRIT<>""
   CRIT(I)=WCRIT
   I+=1
Endif
Infbox "C0"+CRIT(0)-"C1"+CRIT(1)-"C2"+CRIT(2)-"I"+num$(I)
End

#########################################################################
# Saisie des codes préparation                                   SUBPCO #
#########################################################################
# Fonction : GESPCO                                                     #
# Action :   SAIPCO                                                     #
# Fenêtre :  IPCO                                                       #
#########################################################################

$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "OUVRE_BOITE"   : Gosub OUVRE_BOITE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "BOUTON"        : Gosub BOUTON
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "ENR"           : Gosub ENR
 When "CRE"           : Gosub CRE
 When "SUP"           : Gosub SUP
 When "ABA"           : Gosub ABANDON
 When "FIN"           : Gosub FIN
Endcase

Return

#########################################################################
$OUVRE

Local  Char    WCRIT(250)
Local  Integer I,J,WRET
Global Integer GNBCRIT

If !clalev([F:PRC]) Local File TABPRECOD [PRC] Endif
Return

#########################################################################
$OUVRE_BOITE
Return

#########################################################################
$DEBUT

Raz [M:PCO]

Return

#########################################################################
$SETBOUT
Return

#########################################################################
$BOUTON
Return

#########################################################################
$APRES_MODIF

If COUZON="STOFCY"
   Raz REP
Elsif COUZON="PRECOD"
   If GREP="C"
      REP=GREP
   Endif
Else
   REP=GREP
Endif

Return

#########################################################################
$ENR

Raz WRET
Trbegin [PRC]

For [PRC] Where STOFCY=[M:PCO]STOFCY & PRECOD=[M:PCO]PRECOD
   Delete [PRC]
Next

Gosub CRE_PRC
If WRET<>0 Goto AB_TRT Endif

Commit

REP = ""

Return

#########################################################################
$CRE

Raz WRET
Trbegin [PRC]

Gosub CRE_PRC
If WRET<>0 Goto AB_TRT Endif

Commit

REP =""
GREP="M"

Return

#########################################################################
$CRE_PRC

Call MAJTEXTRA ([M:PCO]DESAXX,"TABPRECOD","DESAXX",[M:PCO]PRECOD,[M:PCO]STOFCY) From ATEXTRA

Raz [F:PRC]

[F:PRC]       = [M:PCO]
[F:PRC]PREDES = [M:PCO]DESAXX
[F:PRC]CREDAT = date$   
[F:PRC]CREUSR = GUSER
[F:PRC]EXPNUM = [C]EXPORT
[F:PRC]UPDUSR = ""
[F:PRC]UPDDAT = [0/0/0]  

[F:PRC]NUMCRIT = 1
If [M:PCO]NBLIG1>0
   [F:PRC]CRIT = [M:PCO]CRIT1(0)
   If [M:PCO]NBLIG1>1
      For I=1 To [M:PCO]NBLIG1-1
         [F:PRC]CRIT += ","+[M:PCO]CRIT1(I)
      Next I
   Endif
   # Alimentation des formules
   Gosub ALI_FOR
   If WRET<>0 Return Endif

   Write [PRC]
   If fstat
      Call FSTA("PRC") From GLOCK
      WRET=1 : Return
   Endif  
Endif

If GNBCRIT>=2
   [F:PRC]NUMCRIT = 2
   If [M:PCO]NBLIG2>0
      Raz [F:PRC]FOR1, [F:PRC]FOR2, [F:PRC]FOR3, [F:PRC]FOR4, [F:PRC]FOR5
      [F:PRC]CRIT = [M:PCO]CRIT2(0)
      If [M:PCO]NBLIG2>1
         For I=1 To [M:PCO]NBLIG2-1
            [F:PRC]CRIT += ","+[M:PCO]CRIT2(I)
         Next I
      Endif
      # Alimentation des formules
      Gosub ALI_FOR
      If WRET<>0 Return Endif

      Write [PRC]
      If fstat
         Call FSTA("PRC") From GLOCK
         WRET=1 : Return
      Endif  
   Endif
Endif

If GNBCRIT>=3
   [F:PRC]NUMCRIT = 3
   If [M:PCO]NBLIG3>0
      Raz [F:PRC]FOR1, [F:PRC]FOR2, [F:PRC]FOR3, [F:PRC]FOR4, [F:PRC]FOR5
      [F:PRC]CRIT = [M:PCO]CRIT3(0)
      If [M:PCO]NBLIG3>1
         For I=1 To [M:PCO]NBLIG3-1
            [F:PRC]CRIT += ","+[M:PCO]CRIT3(I)
         Next I
      Endif
      # Alimentation des formules
      Gosub ALI_FOR
      If WRET<>0 Return Endif

      Write [PRC]
      If fstat
         Call FSTA("PRC") From GLOCK
         WRET=1 : Return
      Endif  
   Endif
Endif

If GNBCRIT>=4
   [F:PRC]NUMCRIT = 4
   If [M:PCO]NBLIG4>0
      Raz [F:PRC]FOR1, [F:PRC]FOR2, [F:PRC]FOR3, [F:PRC]FOR4, [F:PRC]FOR5
      [F:PRC]CRIT = [M:PCO]CRIT4(0)
      If [M:PCO]NBLIG4>1
         For I=1 To [M:PCO]NBLIG4-1
            [F:PRC]CRIT += ","+[M:PCO]CRIT4(I)
         Next I
      Endif
      # Alimentation des formules
      Gosub ALI_FOR
      If WRET<>0 Return Endif

      Write [PRC]
      If fstat
         Call FSTA("PRC") From GLOCK
         WRET=1 : Return
      Endif  
   Endif
Endif

If GNBCRIT>=5
   [F:PRC]NUMCRIT = 5
   If [M:PCO]NBLIG5>0
      Raz [F:PRC]FOR1, [F:PRC]FOR2, [F:PRC]FOR3, [F:PRC]FOR4, [F:PRC]FOR5
      [F:PRC]CRIT = [M:PCO]CRIT5(0)
      If [M:PCO]NBLIG5>1
         For I=1 To [M:PCO]NBLIG5-1
            [F:PRC]CRIT += ","+[M:PCO]CRIT5(I)
         Next I
      Endif
      # Alimentation des formules
      Gosub ALI_FOR
      If WRET<>0 Return Endif

      Write [PRC]
      If fstat
         Call FSTA("PRC") From GLOCK
         WRET=1 : Return
      Endif  
   Endif
Endif

Return

#########################################################################
ALI_FOR

Local Char WC(20)
Local Char WP1(250),WP2(250),WP3(250)
Local Char WF1(250),WF2(250),WF3(250)

WCRIT = [F:PRC]CRIT
J = instr(1,WCRIT,',')
While J>0
   WC    = left$(WCRIT,J-1)
   WCRIT = right$(WCRIT,J+1)

   If instr(1,WC,"*") | instr(1,WC,"?") | instr(1,WC,"!") | instr(1,WC,"#")
      If len(WP1)+len(WC)+13 <200
         WP1 += string$(WP1<>"","|")+'pat(%,"'+WC+'")'+'<>0'
      Elsif len(WP2)+len(WC)+13 <200
         WP2 += string$(WP2<>"","|")+'pat(%,"'+WC+'")'+'<>0'
      Elsif len(WP3)+len(WC)+13 <200
         WP3 += string$(WP3<>"","|")+'pat(%,"'+WC+'")'+'<>0'
      Else
         WRET=1 : Break
      Endif
   Else
      If len(WF1)+len(WC)+6 <200
         WF1+=string$(WF1="","find(%")+',"'+WC+'"'
      Elsif len(WF2)+len(WC)+6 <200
         WF2+=string$(WF2="","find(%")+',"'+WC+'"'
      Elsif len(WF3)+len(WC)+6 <200
         WF3+=string$(WF3="","find(%")+',"'+WC+'"'
      Else
         WRET=1 : Break
      Endif
   Endif
   J = instr(1,WCRIT,',')
Wend

If WRET=1 Return Endif

WC = WCRIT
If instr(1,WC,"*") | instr(1,WC,"?") | instr(1,WC,"!") | instr(1,WC,"#")
   If len(WP1)+len(WC)+13 <200
      WP1 += string$(WP1<>"","|")+'pat(%,"'+WC+'")'+'<>0'
   Elsif len(WP2)+len(WC)+13 <200
      WP2 += string$(WP2<>"","|")+'pat(%,"'+WC+'")'+'<>0'
   Elsif len(WP3)+len(WC)+13 <200
      WP3 += string$(WP3<>"","|")+'pat(%,"'+WC+'")'+'<>0'
   Else
      WRET=1
   Endif
Else
   If len(WF1)+len(WC)+6 <200
      WF1+=string$(WF1="","find(%")+',"'+WC+'"'
   Elsif len(WF2)+len(WC)+6 <200
      WF2+=string$(WF2="","find(%")+',"'+WC+'"'
   Elsif len(WF3)+len(WC)+6 <200
      WF3+=string$(WF3="","find(%")+',"'+WC+'"'
   Else
      WRET=1
   Endif
Endif

If len(WP3)+len(WF3)>195
   WRET=1 : Return
Endif

If WP1<>""
   [F:PRC]FOR1 = WP1
   If WP2<>""
      [F:PRC]FOR2 = WP2
      If WP3<>""
         [F:PRC]FOR3 = WP3
         If WF1<>""
            [F:PRC]FOR4 = WF1+")>0"
            If WF2<>""
               [F:PRC]FOR5 = WF2+")>0"
               If WF3<>""
                  [F:PRC]FOR3 += "|"+WF3+")>0"
               Endif
            Endif
         Endif
      Elsif WF1<>""
         [F:PRC]FOR3 = WF1+")>0"
         If WF2<>""
            [F:PRC]FOR4 = WF2+")>0"
            If WF3<>""
               [F:PRC]FOR5 = WF3+")>0"
            Endif
         Endif
      Endif
   Elsif WF1<>""
      [F:PRC]FOR2 = WF1+")>0"
      If WF2<>""
         [F:PRC]FOR3 = WF2+")>0"
         If WF3<>""
            [F:PRC]FOR4 = WF3+")>0"
         Endif
      Endif
   Endif
Elsif WF1<>""
   [F:PRC]FOR1 = WF1+")>0"
   If WF2<>""
      [F:PRC]FOR2 = WF2+")>0"
      If WF3<>""
         [F:PRC]FOR3 = WF3+")>0"
      Endif
   Endif
Endif

Return

#########################################################################
$SUP

Raz WRET
Trbegin [PRC]

For [PRC] Where STOFCY=[M:PCO]STOFCY & PRECOD=[M:PCO]PRECOD
   Delete [PRC]
   If fstat
      Call FSTA("PRC") From GLOCK
      WRET=1 : Break
   Endif
Next

If WRET<>0 Goto AB_TRT Endif

Commit

Raz [M:PCO]STOFCY, [M:PCO]PRECOD, [M:PCO]DESAXX 
For I=0 To dim([M:PCO]CRIT1)-1
   Raz [M:PCO]CRIT1(I),[M:PCO]CRIT2(I),[M:PCO]CRIT3(I)
   Raz [M:PCO]CRIT4(I),[M:PCO]CRIT5(I) 
Next I
Raz [M:PCO]NBLIG1,[M:PCO]NBLIG2,[M:PCO]NBLIG3,[M:PCO]NBLIG4,[M:PCO]NBLIG5

Affzo [M:PCO]1,99

Return

#########################################################################
$ABANDON

For I=0 To dim([M:PCO]CRIT1)-1
   Raz [M:PCO]CRIT1(I),[M:PCO]CRIT2(I),[M:PCO]CRIT3(I)
   Raz [M:PCO]CRIT4(I),[M:PCO]CRIT5(I) 
Next I
Raz [M:PCO]NBLIG1,[M:PCO]NBLIG2,[M:PCO]NBLIG3,[M:PCO]NBLIG4,[M:PCO]NBLIG5

If GREP="C"
   Raz [M:PCO]STOFCY, [M:PCO]PRECOD, [M:PCO]DESAXX 
   Affzo [M:PCO]PRECOD
   GREP=""
Else
   Read [PRC]PRC0=[M:PCO]STOFCY;1;[M:PCO]PRECOD
   If !fstat Gosub ALI_PCO Endif
Endif

Affzo [M:PCO]DESAXX
Affzo [M:PCO]10,15,20,25,30

REP  = ""

Return

#########################################################################
$FIN

Raz [M:PCO]

Return

#########################################################################
$ALI_PCO

[M:PCO] = [F:PRC]

Call LECTEXTRA ([M:PCO]DESAXX,"TABPRECOD","DESAXX",[M:PCO]PRECOD,[M:PCO]STOFCY) From ATEXTRA

Read [PRC]PRC0=[M:PCO]STOFCY;1;[M:PCO]PRECOD
If !fstat
   WCRIT = [F:PRC]CRIT
   I = 0
   J = instr(1,WCRIT,',')
   While J>0
      [M:PCO]CRIT1(I) = left$(WCRIT,J-1)
      WCRIT           = right$(WCRIT,J+1)
      I += 1
      J  = instr(1,WCRIT,',')
   Wend
   If WCRIT<>""
      [M:PCO]CRIT1(I) = WCRIT
      [M:PCO]NBLIG1   = I+1
   Endif
Endif

If GNBCRIT>=2
   Read [PRC]PRC0=[M:PCO]STOFCY;2;[M:PCO]PRECOD
   If !fstat
      WCRIT = [F:PRC]CRIT
      I = 0
      J = instr(1,WCRIT,',') 
      While J>0
         [M:PCO]CRIT2(I) = left$(WCRIT,J-1)
         WCRIT           = right$(WCRIT,J+1)
         I += 1
         J  = instr(1,WCRIT,',')   
      Wend
      If WCRIT<>""
         [M:PCO]CRIT2(I) = WCRIT
         [M:PCO]NBLIG2   = I+1
      Endif 
   Endif
Endif

If GNBCRIT>=3
   Read [PRC]PRC0=[M:PCO]STOFCY;3;[M:PCO]PRECOD
   If !fstat
      WCRIT = [F:PRC]CRIT
      I = 0
      J = instr(1,WCRIT,',') 
      While J>0
         [M:PCO]CRIT3(I) = left$(WCRIT,J-1)
         WCRIT           = right$(WCRIT,J+1)
         I += 1
         J  = instr(1,WCRIT,',')   
      Wend
      If WCRIT<>""
         [M:PCO]CRIT3(I) = WCRIT
         [M:PCO]NBLIG3   = I+1
      Endif
   Endif
Endif

If GNBCRIT>=4
   Read [PRC]PRC0=[M:PCO]STOFCY;4;[M:PCO]PRECOD
   If !fstat
      WCRIT = [F:PRC]CRIT
      I = 0
      J = instr(1,WCRIT,',') 
      While J>0
         [M:PCO]CRIT4(I) = left$(WCRIT,J-1)
         WCRIT           = right$(WCRIT,J+1)
         I += 1
         J  = instr(1,WCRIT,',')   
      Wend
      If WCRIT<>""
         [M:PCO]CRIT4(I) = WCRIT
         [M:PCO]NBLIG4   = I+1
      Endif
   Endif
Endif

If GNBCRIT>=5
   Read [PRC]PRC0=[M:PCO]STOFCY;5;[M:PCO]PRECOD
   If !fstat
      WCRIT = [F:PRC]CRIT
      I = 0
      J = instr(1,WCRIT,',') 
      While J>0
         [M:PCO]CRIT5(I) = left$(WCRIT,J-1)
         WCRIT           = right$(WCRIT,J+1)
         I += 1
         J  = instr(1,WCRIT,',')   
      Wend
      If WCRIT<>""
         [M:PCO]CRIT5(I) = WCRIT
         [M:PCO]NBLIG5   = I+1
      Endif
   Endif
Endif

Return

#########################################################################
$AB_TRT 
Rollback 
Return 

#########################################################################
# Actions sur les zones de l'écran
#########################################################################

#########################################################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()

If VALEUR<>[M:PCO]STOFCY
   Raz GNBCRIT 
   Read [PRC]PRC0=VALEUR;0;""
   If fstat
      GMESSAGE=mess(227,184,1) : mkstat=2 : End
   Elsif [F:PRC]FOR2="1"
      GNBCRIT = 1
      Chgtbk [M:PCO]10 With mess(val([F:PRC]FOR1),2749,1)
      Chgtbk [M:PCO]15 With ""
      Chgtbk [M:PCO]20 With ""
      Chgtbk [M:PCO]25 With ""
      Chgtbk [M:PCO]30 With ""
      Grizo [M:PCO]15,20,25,30              # hcb 99248
   Elsif [F:PRC]FOR3="1"
      GNBCRIT = 2
      Chgtbk [M:PCO]10 With mess(val([F:PRC]FOR1),2749,1)
      Chgtbk [M:PCO]15 With mess(val([F:PRC]FOR2),2749,1)
      Chgtbk [M:PCO]20 With ""
      Chgtbk [M:PCO]25 With ""
      Chgtbk [M:PCO]30 With ""
      Grizo [M:PCO]20,25,30
   Elsif [F:PRC]FOR4="1"
      GNBCRIT = 3
      Chgtbk [M:PCO]10 With mess(val([F:PRC]FOR1),2749,1)
      Chgtbk [M:PCO]15 With mess(val([F:PRC]FOR2),2749,1)
      Chgtbk [M:PCO]20 With mess(val([F:PRC]FOR3),2749,1)
      Chgtbk [M:PCO]25 With ""
      Chgtbk [M:PCO]30 With ""
      Grizo [M:PCO]25,30
   Elsif [F:PRC]FOR5="1"
      GNBCRIT = 4
      Chgtbk [M:PCO]10 With mess(val([F:PRC]FOR1),2749,1)
      Chgtbk [M:PCO]15 With mess(val([F:PRC]FOR2),2749,1)
      Chgtbk [M:PCO]20 With mess(val([F:PRC]FOR3),2749,1)
      Chgtbk [M:PCO]25 With mess(val([F:PRC]FOR4),2749,1)
      Chgtbk [M:PCO]30 With ""
      Grizo [M:PCO]30
   Else
      GNBCRIT = 5
      Chgtbk [M:PCO]10 With mess(val([F:PRC]FOR1),2749,1)
      Chgtbk [M:PCO]15 With mess(val([F:PRC]FOR2),2749,1)
      Chgtbk [M:PCO]20 With mess(val([F:PRC]FOR3),2749,1)
      Chgtbk [M:PCO]25 With mess(val([F:PRC]FOR4),2749,1)
      Chgtbk [M:PCO]30 With mess(val([F:PRC]FOR5),2749,1)
   Endif

   If [M:PCO]STOFCY<>""
      Raz [M:PCO]
      Affzo [M:PCO]PRECOD, DESAXX
      Affzo [M:PCO]10,15,20,25,30
   Endif
Endif

End

#########################################################################
Subprog AM_PRECOD(VALEUR)
Variable Char    VALEUR()
Local    Char    WCRIT(250)
Local    Integer I,J 

For I=0 To dim([M:PCO]CRIT1)-1
   Raz [M:PCO]CRIT1(I),[M:PCO]CRIT2(I),[M:PCO]CRIT3(I)
   Raz [M:PCO]CRIT4(I),[M:PCO]CRIT5(I) 
Next I
Raz [M:PCO]NBLIG1,[M:PCO]NBLIG2,[M:PCO]NBLIG3,[M:PCO]NBLIG4,[M:PCO]NBLIG5

Read [PRC]PRC1=[M:PCO]STOFCY;VALEUR
If fstat
   GREP="C"
Else
   GREP="M"
   [M:PCO]PRECOD = VALEUR
   Gosub ALI_PCO
Endif

Affzo [M:PCO]DESAXX
Affzo [M:PCO]10,15,20,25,30

End

#########################################################################
Subprog S_CRIT1(VALEUR)
Variable Char    VALEUR()
Local    Integer WFOR
WFOR = 1
If !GWEBSERV Gosub SEL_CRIT Endif
End

Subprog S_CRIT2(VALEUR)
Variable Char    VALEUR()
Local    Integer WFOR
WFOR = 2
If !GWEBSERV Gosub SEL_CRIT Endif
End

Subprog S_CRIT3(VALEUR)
Variable Char    VALEUR()
Local    Integer WFOR
WFOR = 3
If !GWEBSERV Gosub SEL_CRIT Endif
End

Subprog S_CRIT4(VALEUR)
Variable Char    VALEUR()
Local    Integer WFOR
WFOR = 4
If !GWEBSERV Gosub SEL_CRIT Endif
End

Subprog S_CRIT5(VALEUR)
Variable Char    VALEUR()
Local    Integer WFOR
WFOR = 5
If !GWEBSERV Gosub SEL_CRIT Endif
End

#########################################################################
$SEL_CRIT
Local Char    PARMSK(250)(1..20), SAVACT(20)

If [F:PRC]STOFCY<>[M:PCO]STOFCY | [F:PRC]NUMCRIT<>0 | [F:PRC]PRECOD<>""
   Read [PRC]PRC0=[M:PCO]STOFCY;0;""
   If fstat 
      GMESSAGE=mess(227,184,1) : mkstat=2 : Return
   Endif
Endif
# Alimentation du paramétrage ds WFOR selon le critère sur lequel on sélectionne 
Case WFOR
 When 1 : WFOR=val([F:PRC]FOR1)
 When 2 : WFOR=val([F:PRC]FOR2)
 When 3 : WFOR=val([F:PRC]FOR3)
 When 4 : WFOR=val([F:PRC]FOR4)
 When 5 : WFOR=val([F:PRC]FOR5)
Endcase

SAVACT = GACTION
Case WFOR
 When 2              : GACTION = "SELITF"
                       PARMSK(1) = [M:PCO]STOFCY
                       Call S_TAB_CHAR(VALEUR,PARMSK,"SELITF","STKSEL","") From GACTION
 When 3              : PARMSK(1) = "ITG"
                       PARMSK(2) = "!"
                       Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
 When 4,5,6,7,8      : GACTION = "SELADI"
                       PARMSK(1) = num$(WFOR-4+20)
                       Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 When 9              : PARMSK(1) = "BPC"
                       PARMSK(2) = "A"
                       Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
 When 10             : PARMSK(1) = "BCG"
                       PARMSK(2) = "!"
                       Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
 When 11,12,13,14,15 : GACTION = "SELADI"
                       PARMSK(1) = num$(WFOR-11+30)
                       Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
Endcase
GACTION = SAVACT
Return

