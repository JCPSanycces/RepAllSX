#<AdxTL>@(#)2.0.0.0 $Revision$
# Traitement de suppression de plan : UDELPLN
# FQ67657
# CBO 2015.12.10 FQ113077 : Erreur en batch

Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
    Call TRAITE_CHAR(VALBOUT, PARBOUT, "", "UDELPLN", "UDELPLN", 3, "") From GTRAITE
End

$ACTION
Case ACTION
    When "INIT"        : Gosub INIT
    When "INIT_DIA"    : Gosub INIT_DIA
    When "OUVRE"       : Gosub OUVRE
    When "DEBUT"       : Gosub DEBUT
    When "OK"          : GOK=1
    When "END"         : GOK=0
    When "CONTROLE"    : Gosub CONTROLE
    When "EXEC"        : Gosub EXEC
    When "TERMINE"     : Gosub TERMINE
    When "SETBOUT"     : Gosub SETBOUT
Endcase

Return

$INIT_DIA
$INIT
#############################################################################################################

    If !clalev([M:DIA])
      Local Mask UDELPLN   [DIA]
    Endif

    If !clalev([F:CNX])
        Local File CONTEXT  [CNX]
    Endif
    If !clalev ([F:AMZ])
        Local File = "AMSKZON" [AMZ]
    Endif
    If !clalev ([F:ATX])
        Local File = "ATEXTE" [ATX]
    Endif

    Global Integer GTOUSPLANS, GTPLANS_SELEC(G301MAX), GCTXUO
    Global Integer GWFLGCNXUO, GWSUPPLNSUB, GWSUPPLNMIN, GB301CPTFIS

Return

$OUVRE
Return

$SETBOUT

#    If [M:DIA]SAUVE = G_OUI and
#&      (GWFLGCNXUO = G_OUI and [M:DIA]SUPCTXUO = G_OUI or GWFLGCNXUO <> G_OUI) and
#&      (GWSUPPLNSUB = G_OUI and [M:DIA]SUPPLNSUB = G_OUI or GWSUPPLNSUB <> G_OUI) and
#&      (GWSUPPLNMIN = G_OUI and [M:DIA]SUPPLNMIN = G_OUI or GWSUPPLNMIN <> G_OUI)
#        If find("O", CHBOU) = 0
#            CHBOU += "O"
#        Endif
#    Else
#        Call VIREBOUT(CHBOU, "O") From GOBJET
#    Endif
Return

$DEBUT
    # vérifier si l'utilisateur a les droits au site
#    If (GUSRFCY(1) <> "" and GUSRFCY(1) <> "\")
#        Infbox "droits restreints" - GUSRFCY(1) - GUSRFCY(2)
#    Endif

    If [M:DIA]CPYTOUS = G_NON
        Actzo [M:DIA]CPY
    Else
        Diszo [M:DIA]CPY
    Endif

    If GWFLGCNXUO = G_OUI
        Actzo SUPCTXUO
    Else
        Diszo SUPCTXUO
    Endif

    If GWSUPPLNSUB = G_OUI
        Actzo [M:DIA]SUPPLNSUB
    Else
        Diszo [M:DIA]SUPPLNSUB
    Endif

    If GWSUPPLNMIN = G_OUI
        Actzo [M:DIA]SUPPLNMIN
    Else
        Diszo [M:DIA]SUPPLNMIN
    Endif

    [M:DIA]TXTMIN = mess(49, 7784, 1)
    [M:DIA]TXTSUB = mess(50, 7784, 1)
    [M:DIA]TXTUO  = mess(51, 7784, 1)
    Affzo [M:DIA]

Return


$CONT_BATCH # Issue 113077
$CONTROLE

Local Integer I, J
Local Char LIBCALL(250)

    If GOK < 1
        Return
    Endif

#    If (GUSRFCY(1) <> "" and GUSRFCY(1) <> "\")
#        GMESSAGE = "droits restreints" - GUSER - GUSRFCY(1) - GUSRFCY(2) - GUSRFCY(3) - GUSRFCY(4) - GUSRFCY(5)
#        GERR = 1
#        mkstat = 2
#        Return
#    Endif

    # Messages pédagogiques :

    If GWFLGCNXUO = G_OUI and [M:DIA]SUPCTXUO <> G_OUI
#        GMESSAGE = "Confirmation contexte de gestion des UO obligatoire"
#        GMESSAGE = mess(32, 7784, 1)
        Call LIBCHPATZ(GLANGUE, "UDELPLN", "SUPCTXUO", LIBCALL) From UDELPLN2
        GMESSAGE = mess(897, 9900, 1) - '"' - LIBCALL - '"' - mess(1, 7824, 1)
        GERR = 1
        GOK = 0
        zonsui = "SUPCTXUO"
        Return
    Endif

    If GWSUPPLNSUB = G_OUI and [M:DIA]SUPPLNSUB <> G_OUI
#        GMESSAGE = "Confirmation plan de subvention obligatoire"
#        GMESSAGE = mess(33, 7784, 1)
        Call LIBCHPATZ(GLANGUE, "UDELPLN", "SUPPLNSUB", LIBCALL) From UDELPLN2
        GMESSAGE = mess(897, 9900, 1) - '"' - LIBCALL - '"' - mess(1, 7824, 1)
        GERR = 1
        GOK = 0
        zonsui = "SUPPLNSUB"
        Return
    Endif


    If GWSUPPLNMIN = G_OUI and [M:DIA]SUPPLNMIN <> G_OUI
#        GMESSAGE = "Confirmation plan  <> G_OUI obligatoire"
#        GMESSAGE = mess(34, 7784, 1)
        Call LIBCHPATZ(GLANGUE, "UDELPLN", "SUPPLNMIN", LIBCALL) From UDELPLN2
        GMESSAGE = mess(897, 9900, 1) - '"' - LIBCALL - '"' - mess(1, 7824, 1)
        GERR = 1
        GOK = 0
        zonsui = "SUPPLNMIN"
        Return
    Endif

    If [M:DIA]SAUVE <> G_OUI
#        GMESSAGE = "Confirmation sauvegarde effectuée obligatoire"
#        GMESSAGE = mess(31, 7784, 1)
        Call LIBCHPATZ(GLANGUE, "UDELPLN", "SAUVE", LIBCALL) From UDELPLN2
        GMESSAGE = mess(897, 9900, 1) - '"' - LIBCALL - '"' - mess(1, 7824, 1)
        GERR = 1
        GOK = 0
        Return
    Endif

    # tous les plans du contexte ?
    I = 0
    J = 0
    GTOUSPLANS = G_OUI
    Raz GTPLANS_SELEC, GMESSAGE
    While I < [M:DIA]NBDPRPLN
        If [M:DIA]PLNCAA(I) > 0

            # plan à traiter
            If [M:DIA]SUPPRESSION(I) = G_OUI

                GTPLANS_SELEC(J) = [M:DIA]PLNCAA(I)
                J += 1
            Else
                GTOUSPLANS = G_NON
            Endif
        Endif

            I += 1
    Wend

    # Issue 113077
    If [M:DIA]CNX = G300CPFI
        GB301CPTFIS = 1
    Else
        GB301CPTFIS = 0
    Endif
    # End Issue 113077

    # comme on n'a pas chargé ces plans : ils ne peuvent être sélectionnés donc le contexte ne peut être détruit !
    GCTXUO = [M:DIA]SUPCTXUO
    If GB301CPTFIS
        GTOUSPLANS = G_NON
    Endif
    If GTOUSPLANS = G_NON
        GCTXUO = G_NON
    Endif
    If GMESSAGE <> ""
        Return
    Endif

    If J = 0
#        GMESSAGE = "Aucun plan sélectionné"
       GMESSAGE = mess(35, 7784, 1)
        mkstat = 2
        GERR = 1
        GOK = 0
        Return
    Endif

Return


# traitement
$EXEC
Local Integer LOK

    If GOK = 0
        Return
    Endif

If GUSER <> "CBO"
    If [M:DIA]FLGSIM = G_NON
        Call OUINON(mess(188, 7774, 1), LOK) From GESECRAN
    Else
        Call OUINON(mess(176, 7774, 1), LOK) From GESECRAN
    Endif
    If (LOK = 1) Then
        FIN      = 0
        GERR     = 1
        Return
    Endif
Endif


    Call UDELPLN([M:DIA]CPY, [M:DIA]CNX, [M:DIA]FLGSIM,
&                GTOUSPLANS, GTPLANS_SELEC, GCTXUO) From UDELPLN2

    GERR = 0
    GOK  = 1

Return

$TERMINE

    GERR = 0
    GMESSAGE = ""
    Close File [CNX]
    Close Mask [DIA]

Return

$RAZ_TABPLN

    Raz [M:DIA]PLNCAA, SUPPRESSION, FLGPROACC
    [M:DIA]NBDPRPLN = 0
    GWSUPPLNMIN = G_NON
    GWSUPPLNSUB = G_NON
    GWFLGCNXUO  = G_NON
    GB301CPTFIS = 0

    [M:DIA]SUPPLNMIN  = G_NON
    [M:DIA]SUPPLNSUB  = G_NON
    [M:DIA]SUPCTXUO  = G_NON
    Diszo [M:DIA]SUPPLNMIN, SUPPLNSUB, SUPCTXUO
Return

######################################################################################

######################################################################################

Subprog AM_CPYTOUS(VALEUR)
Variable Integer VALEUR

    If VALEUR = G_OUI
        [M:DIA]CPY = ""
        Diszo [M:DIA]CPY
    Else
        Actzo [M:DIA]CPY
    Endif

    If VALEUR <> [M]CPYTOUS and [M:DIA]NBDPRPLN > 0
        Gosub RAZ_TABPLN
    Endif
    Affzo [M:DIA]
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()

    If [M]CPYTOUS <> G_OUI & VALEUR = ""
        GMESSAGE = mess(27, GML_IMPFXD, 1)
        mkstat=1
        End
    Endif

    If VALEUR <> [M]CPY and [M:DIA]NBDPRPLN > 0
        Gosub RAZ_TABPLN
        Affzo [M:DIA]
    Endif

    If VALEUR <> ""
        If func UDELPLN2.CTRLE_SOCIETE(VALEUR) = 0
            mkstat=1
            End
        Endif
    Endif
End

Subprog AS_CNX(VALEUR)
Variable Integer VALEUR

Local Integer I

    If [M:DIA]CPY = ""
        Raz GMENLOC
    Else
        For I = 1 To 11
            GMENLOC(I) = 1
        Next I
        For [CNX] Where CPY = [M:DIA]CPY
            GMENLOC([F:CNX]CNX) = 0
        Next
    Endif

End

Subprog AP_CNX(VALEUR)
Variable Integer VALEUR

Local Integer I
    # Chargement des plans du contexte sélectionné :
    # - pas de soc sélectionnée, tous les plans UTILISES pour ce contexte
    # - soc sélectionnée, tous les plans du contexte !

    If VALEUR = [M]CNX and [M:DIA]NBDPRPLN > 0
        End
    Endif

    Gosub RAZ_TABPLN

    GWFLGCNXUO = G_NON
    nolign = 0

    If [M:DIA]CPY = ""

        I = 1
        While I < G301MAX
            If mess(I, 3101, 1) <> ""

                Filter [CNX] Where CNX = VALEUR and find(I, PLNCAA) > 0
                Read [CNX]CNX0 First
                If fstat = 0
                    If VALEUR = G300CPFI and (I = G301CPT or I = G301FIS)
                        GB301CPTFIS = 1
                    Else
                        [M:DIA]PLNCAA(nolign)      = I
                        [M:DIA]SUPPRESSION(nolign) = G_NON
                        [M:DIA]FLGPROACC(nolign)   = G_NON
                        nolign += 1
                    Endif
                Endif
                Filter [CNX]
            Endif

            I += 1
        Wend
    Else

        Read [CNX]CNX0 = [M:DIA]CPY; VALEUR
        If fstat = 0
#                    If VALEUR = G300CPFI and ([M:DIA]PLNCAA(nolign - 1) = G301CPT or [M:DIA]PLNCAA(nolign - 1) = G301FIS)
#        mkstat = 2
#    Endif
            GWFLGCNXUO = [F:CNX]FLGCNXUO
            I = 0
            While I < G301MAX - 1
                If [F:CNX]PLNCAA(I) > 0
                    If VALEUR = G300CPFI and ([F:CNX]PLNCAA(I) = G301CPT or [F:CNX]PLNCAA(I) = G301FIS)
                        GB301CPTFIS = 1
                    Else
                        [M:DIA]PLNCAA(nolign)      = [F:CNX]PLNCAA(I)
                        [M:DIA]SUPPRESSION(nolign) = G_NON
                        [M:DIA]FLGPROACC(nolign)   = func SUBTPE.PLAN_COMPTABILISE([F:CNX]CPY, [F:CNX]PLNCAA(I), G_OUI)
                        nolign += 1
                    Endif
                Endif

                I += 1
            Wend
        Endif

    Endif

    [M:DIA]NBDPRPLN = nolign

    If GWFLGCNXUO = G_OUI
        Actzo [M:DIA]SUPCTXUO
    Else
        Diszo [M:DIA]SUPCTXUO
    Endif
    Affzo [M:DIA]
End

Subprog C_SUPPRESSION(VALEUR)
Variable Integer VALEUR

    If func UDELPLN2.CTRLE_SUPPRESSION_PLAN(1, VALEUR, [M:DIA]PLNCAA(nolign - 1),
&       [M:DIA]FLGPROACC(nolign - 1)) = 0

        mkstat = 2
        GERR = 1
        GOK = 0
    Endif
End

# Séletion automatique de toutes les lignes (hors plans non supprimables)
Subprog B1_NBDPRPLN
Local Integer I

    For I = 0 To [M:DIA]NBDPRPLN - 1
        If func UDELPLN2.CTRLE_SUPPRESSION_PLAN(1, G_OUI, [M:DIA]PLNCAA(I),
&       [M:DIA]FLGPROACC(I)) = 0

            GMESSAGE = ""
        Else
           [M:DIA]SUPPRESSION(I) = G_OUI
        Endif
    Next I
    Affzo [M:DIA]
End

