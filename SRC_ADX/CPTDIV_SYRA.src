#**
#*
#* @deprecated Use <b>GET_GCM From FINACM_SYRA</b> instead.
#*
#*!
Subprog SETGCM(ACTX,COMPANY,MODEL)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    COMPANY   : # Company or Site
Variable Char    MODEL     : # Accounting Core Model
Local Char ERRMES(250)
Local Integer ASTATUS
[L]ASTATUS = func FINACM_SYRA.GET_GCM(ACTX,COMPANY,MODEL,ERRMES)
End


#**
#*
#* @deprecated Use <b>GET_CUR From FINCUR_SYRA</b> instead.
#*
#*!
Subprog SETCUR(ACTX,CAS,COMPANY,LEDCUR)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Integer CAS          # 1:réf. principal général   2: réf. principal analytique
Value    Char    COMPANY()
Variable Char    LEDCUR()
Local Char ERRMES(250)
Local Integer ASTATUS
[L]ASTATUS = func FINCUR_SYRA.GET_CUR(ACTX,CAS,COMPANY,LEDCUR,ERRMES)
End


##########################################################################
Funprog FINDAFTSITE(WUSER,WMOD,WFCY)
Value Char WUSER, WFCY
Value Integer WMOD

Local File AFCTFCT   [AFT]
Local File AUTILIS   [AUS]

Link [F:AUS] With [F:AFT]AFT0=[F:AUS]PRFFCT As [LNK]
& Where [F:AUS]USR=WUSER

Read [LNK] First
If fstat : Raz [LNK]
  Else
End [F:AFT]FCYDEF(WMOD)  # 6 for ACH #99095.n
Endif

End WFCY

###############################################################################
# Issue X3-81871 - 2018-03-08 by FGR : BEGIN
###############################################################################
# Plans de comptes et axes à saisir pour une société
###############################################################################
Subprog SETPLAN(ACTX, SOCIETE, NBPLAN, PLAN, REFTYP, NBAXE, AXE, OBLIG)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    SOCIETE     # Société ou site
Variable Integer NBPLAN      # Nb de plans comptables (max 10)
Variable Char    PLAN()(1..) # Plans (COA) (en 1:général principal, si <>1, en 2:analytique principal)
Variable Integer REFTYP(1..) # Types référentiels (en 1:général principal, si <>1, en 2:analytique principal)
Variable Integer NBAXE       # Nb d'axes à saisir (max 20)
Variable Char    AXE()(1..)  # Axes (DIE)
Variable Integer OBLIG(1..)  # Obligatoire (O/N)

Local Char MODELE(GLONGCM)
Local Integer SAI_AMONT
Local Integer INI_AXE

  SAI_AMONT = [V]CST_ATRUE
  INI_AXE = [V]CST_ATRUE
  Call SETGCM(SOCIETE, MODELE) From CPTDIV
  Gosub SET_PLAN
End

###############################################################################
# Plans de comptes et axes à saisir pour un modéle comptable  (Idem SETPLAN sauf qu'ici on
# renvoie tous les axes même ceux qui sont déflagués 'Saisie en amont' SETPLAN2 sert
# notamment pour l'affichage des axes des fiches sociétés et site (sections par défaut)
###############################################################################
Subprog SETPLAN2(ACTX, SOCIETE, MODELE, NBPLAN, PLAN, REFTYP, NBAXE, AXE, OBLIG)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    SOCIETE     # Société ou site
Value    Char    MODELE      # Modèle comptable
Variable Integer NBPLAN      # Nb de plans comptables (max 10)
Variable Char    PLAN()(1..) # Plans (COA) (en 1:général principal, si <>1 en 2:analytique principal)
Variable Integer REFTYP(1..) # Types référentiels (en 1:général principal, si <>1 en 2:analytique principal)
Variable Integer NBAXE       # Nb d'axes à saisir (max 20)
Variable Char    AXE()(1..)  # Axes (DIE)
Variable Integer OBLIG(1..)  # Obligatoire (O/N)

Local Integer SAI_AMONT
Local Integer INI_AXE

  SAI_AMONT = [V]CST_AFALSE
  INI_AXE = [V]CST_ATRUE
  Gosub SET_PLAN
End

###############################################################################
## Plans de comptes non automatiques pour une société
###############################################################################
Subprog SETPLAN3(ACTX, SOCIETE, NBPLAN, PLAN, REFTYP)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    SOCIETE     # Société ou site
Variable Integer NBPLAN      # Nb de plans comptables (max 10)
Variable Char    PLAN()(1..) # Plans (COA) (en 1:général principal, si <>1 en 2:analytique principal)
Variable Integer REFTYP(1..) # Types référentiels (en 1:général principal, si <>1 en 2:analytique principal)

Local Char MODELE(GLONGCM)
Local Integer SAI_AMONT
Local Integer INI_AXE

  SAI_AMONT = [V]CST_AFALSE
  INI_AXE = [V]CST_AFALSE
  Call SETGCM(ACTX, SOCIETE, MODELE)
  Gosub SET_PLAN
End

# -----------------------------------------------------------------------------
$SET_PLAN
Local Integer IGCM
Local Integer ILED
Local Integer IREF
Local Integer IDIE
Local Integer NBREF
Local Char REFER(GLONLED)(1..max(1,len(mess(0,2644,1))))
Local Char CODAXE(GLONDIE)
Local Char REF(GLONLED)
Local Integer IOPTCANA

  # ------------------------
  Local File COMPANY [CPY]
  # ------------------------
  IOPTCANA = func ASYRFNC.ACTIV("ANA")
  Raz NBPLAN
  If INI_AXE = [V]CST_ATRUE Then
    Raz NBAXE
  Endif
  # ------------------------
  Call LEC_CPY(ACTX, SOCIETE) From CPTLEC_SYRA
  # ------------------------
  IGCM = (fmet ACTX.ACACHE.GGCM.AGETVALCHAR(MODELE, "GCM") = MODELE)
  If IGCM = [V]CST_ATRUE Then
    # ------------------------
    NBREF = 1
    REFTYP(NBREF) = fmet ACTX.ACACHE.GGCM.AGETVALNUM(MODELE, "LEDTYPGEN")
    REFER(NBREF) = fmet ACTX.ACACHE.GGCM.AGETVALCHAR(MODELE, "LEDGEN")
    If REFTYP(NBREF) <> fmet ACTX.ACACHE.GGCM.AGETVALNUM(MODELE, "LEDTYPANA") Then
      NBREF+=1
      REFTYP(NBREF) = fmet ACTX.ACACHE.GGCM.AGETVALNUM(MODELE, "LEDTYPANA")
      REFER(NBREF) = fmet ACTX.ACACHE.GGCM.AGETVALCHAR(MODELE, "LEDANA")
    Endif
    # ------------------------
    For IREF = 1 To NBREF
      NBPLAN += 1
      ILED = ((fmet ACTX.ACACHE.GLED.AGETVALCHAR(REFER(IREF), "LED") = REFER(IREF)))
      If ILED = [V]CST_ATRUE Then
        PLAN(IREF) = fmet ACTX.ACACHE.GLED.AGETVALCHAR(REFER(IREF), "COA")
        REF = PLAN(IREF)
        Gosub AXES
      Endif
    Next IREF
    # ------------------------
    For IREF = 1 To len(mess(0,2644,1))
      If IREF = fmet ACTX.ACACHE.GGCM.AGETVALCHAR(MODELE, "LEDTYPGEN") or IREF = fmet ACTX.ACACHE.GGCM.AGETVALCHAR(MODELE, "LEDTYPANA") Then
        REF = fmet ACTX.ACACHE.GGCM.AGETVALCHAR(MODELE, "LED" + num$(IREF))
        If REF <> AVOID.ACHAR and !find(REF,REFER(1..NBREF)) Then
          If fmet ACTX.ACACHE.GGCM.AGETVALNUM(MODELE, "CFMAUT" + num$(IREF)) <> [V]CST_AYES Then
            NBREF += 1
            REFER(NBREF) = REF
            ILED = ((fmet ACTX.ACACHE.GLED.AGETVALCHAR(REF, "LED") = REF))
            If ILED = [V]CST_ATRUE Then
              NBPLAN += 1
              PLAN(NBPLAN) = fmet ACTX.ACACHE.GLED.AGETVALCHAR(REF, "COA")
              Gosub AXES
            Endif
            REFTYP(NBPLAN) = IREF
          Endif
        Endif
      Endif
    Next IREF
  Endif
Return

$AXES
Local Integer VU
Local Integer SAIAXE

  If INI_AXE = [V]CST_AFALSE Then
    Return
  Endif
  If NBAXE >= IOPTCANA Then
    Return
  Endif
  For IDIE = 1 To fmet ACTX.ACACHE.GLED.AGETVALCHAR(REF, "DIENBR")
    CODAXE = fmet ACTX.ACACHE.GLED.AGETVALCHAR(REF, "DIE" + num$(IDIE))
    VU = find(CODAXE,[F:CPY]DIE(0..dim([F:CPY]DIE)-1))
    If VU <> 0 Then
      SAIAXE = [F:CPY]DACDIE(VU-1)
    Else
      SAIAXE = [V]CST_AYES             # Sait-on jamais...
    Endif
    If CODAXE <> AVOID.ACHAR and !find(CODAXE,AXE(1..NBAXE)) and NBAXE < dim(AXE) and (SAI_AMONT = [V]CST_AFALSE or SAIAXE = [V]CST_AYES)
      NBAXE += 1
      AXE(NBAXE) = CODAXE
      VU = find(CODAXE,[F:CPY]DIE(0..dim([F:CPY]DIE)-1))
      If VU <> 0 Then
        OBLIG(NBAXE) = [F:CPY]OBYDIE(VU-1)
      Else
        OBLIG(NBAXE) = [V]CST_ANO      # Sait-on jamais...
      Endif
      If NBAXE >= IOPTCANA Then
        Break
      Endif
    Endif
  Next IDIE
Return
# Issue X3-81871 - 2018-03-08 by FGR : END
###############################################################################

