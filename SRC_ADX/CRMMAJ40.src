##########################################################################################################
#Moulinette AVANT
#Module Support client
Subprog ACR1MAJ40
End

#######################################################################
#Moulinette AVANT
#Module Action commerciale
Subprog ACR2MAJ40

  Call AMAJCRMV6V7([F:ADS]DOSSIER)
End

##########################################################################################################
#Moulinette APRES
#Module Support client
Subprog CR1MAJ40
End

#######################################################################
#Moulinette APRES
#Module Action commerciale
Subprog CR2MAJ40

  Call MAJCRMV6V7([F:ADS]DOSSIER)
End

