#<AdxTL>@(#)11.0.0.0 $Revision$ Validation datawarehouse
Local Char VALBOUT(250) , PARBOUT(250)(1..20)
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","ABIVALBAS","ABIVALBAS",3,"") From GTRAITE
End

#------------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "CONT_BATCH"  : Gosub CONT_BATCH
 When "EXEC"        : Gosub EXEC
Endcase
Return

#------------------------------------------------------------#
$OUVRE_BATCH
$INIT
Local Integer  W , SILENCE , FORCE ,  USRFORCE
Local Char     MACHINE(250)
TIT = mess(2,148,1) : # Validation Datawarehouse
Return

#------------------------------------------------------------#
$INIT_DIA
If PARAM(1)<>""
 [M]CODDOS = PARAM(1)
Else
 Local File ABIDATWRH [ABW]
 For [ABW]
  [M]CODDOS = [F:ABW]COD
  Break
 Next ABW
 Close Local File [ABW]
Endif
Return

#------------------------------------------------------------#
$CONTROLE
$CONT_BATCH
If [M]CODDOS=""
 SAI = 1 : Return
Endif
Return

#------------------------------------------------------------#
$EXEC
# Affichage boîte d'info ??
If GSERVEUR
 SILENCE = 1
Else
 SILENCE = 0
 TRA = 1
Endif

FORCE    = ([M]FORCE=2)
USRFORCE = ([M]USR=2)

If TRA
 Call OUVRE_TRACE(TIT) From LECFIC
Endif

# Mise à jour des flags audits "bi" sur les tables des dossiers d'extractions
Call MAJFLG_AUDIT(nomap)

# Validation des datawhare


If !SILENCE
 Call OUVRE_VLC(TIT-[M]CODDOS,"","") From GESECRAN
Endif
Call ECR_TRACE("",0) From GESECRAN
Call VALIDATION(nomap,[M]CODDOS,FORCE,USRFORCE,SILENCE,OK)
If !SILENCE
 Call FERME_VLC From GESECRAN
Endif


$FIN
If TRA
 Call FERME_TRACE From LECFIC
Endif
Return

#---------------------------------------------------------------------------------------------#
Subprog MAJFLG_AUDIT(APPLI)
Value Char APPLI

Local Shortint MAXORG , MAXDOS

# cg size is increased jira 59653 200 instead of 100
MAXORG = 200 : # Nombre maxi de tables (table+dossier) d'origine
MAXDOS = 20  : # Nombre maxi de dossier

Local Integer  I , K , J , NBORG , NBDOS , NBADX
Local Schar    TBADX(250)(1..MAXDOS) , TBAPP(GLONADS)(1..MAXDOS) , TBDOS(GDIMFIC)(1..MAXDOS)
Local Schar    TBORG(GDIMFIC)(1..MAXORG) , TBATB(GLONATB)(1..MAXORG)
Local Integer  TBMAJ(1..MAXORG),NBA,NBN
Local Schar    TABLE(GDIMFIC)
Local Char     CHAINE(250) , SYMB(250)

If clalev([F:ABV])=0 : Local File =APPLI+".ABIREGORG" [ABV] : Endif
If clalev([F:ABY])=0 : Local File =APPLI+".ABIREGDES" [ABY] : Endif
If clalev([F:ABF])=0 : Local File =APPLI+".ABITABDAT" [ABF] : Endif
If clalev([F:ABI])=0 : Local File =APPLI+".ABIDIM"    [ABI] : Endif

Call ECR_TIME(mess(131,139,1)) From DOSSUB : # Mise à jour des flags d'audit

Raz NBORG , NBDOS
## Dimension
For [ABI]ABI0 Where TYPMAJ = 3
 Raz NBADX
 For I=1 To [F:ABV]NBRDOS
  If [F:ABV]ADXDOS(I-1)<>""
         # cg add the test of the dim
       If NBADX >= dim (TBADX)
            Call ECR_TRACE("Limit reached on table dimension "+num$(NBADX),-1) From GESECRAN
            Break
       Else
            NBADX += 1
            TBADX(NBADX) = [F:ABV]ADXDOS(I-1)
       Endif
  Endif
 Next I
 If NBADX=0
    NBADX = 1
    TBADX(NBADX) = APPLI
 Endif
 For I=1 To NBADX
  TABLE = TBADX(I)+"."+[F:ABI]TABORG
  K = find(TABLE,TBORG(1..NBORG))
  If K
   TBMAJ(K) = 1
  Else
     # cg add the test of the dim
     If NBORG >= dim (TBORG)
           Call ECR_TRACE("Limit reached on table dimension "+num$(NBORG),-1) From GESECRAN
           Break
     Else
           NBORG += 1
           TBORG(NBORG) = TABLE
           TBATB(NBORG) = [F:ABI]TABORG
           TBMAJ(NBORG) = 1 : # 3 dans la table ABIDIM 1 ici pour l'algo comme dans les table de fait
           If !find(TBADX(I),TBDOS(1..NBDOS))
                # cg add the test of the dim
                If NBDOS >= dim (TBDOS)
                      Call ECR_TRACE("Limit reached on table dimension "+num$(NBDOS),-1) From GESECRAN
                      Break
                Else
                      NBDOS += 1
                      TBDOS(NBDOS) = TBADX(I)
                      K = instr(1,TBDOS(NBDOS),"@")
                      If K
                           TBAPP(NBDOS) = right$(TBDOS(NBDOS),K+1)
                      Else
                           TBAPP(NBDOS) = TBDOS(NBDOS)
                      Endif
                Endif
          Endif
     Endif
  Endif
 Next I
Next
## Regle de synchro
For [ABY]ABY0(1)
 Read [ABV]ABV0=[F:ABY]CODREG
 Read [ABF]ABF0=[F:ABY]TABDES
 Raz NBADX
 For I=1 To [F:ABV]NBRDOS
  If [F:ABV]ADXDOS(I-1)<>""
       # cg add the test of the dim
       If NBADX >= dim (TBADX)
            Call ECR_TRACE("Limit reached on table dimension "+num$(NBADX),-1) From GESECRAN
            Break
       Else
            NBADX += 1
            TBADX(NBADX) = [F:ABV]ADXDOS(I-1)
       Endif
  Endif
 Next I
 If NBADX=0
      NBADX = 1
      TBADX(NBADX) = APPLI
 Endif
 For I=1 To NBADX
  TABLE = TBADX(I)+"."+[F:ABV]TABORG
  K = find(TABLE,TBORG(1..NBORG))
  If K
       TBMAJ(K) = min([F:ABF]TYPMAJ,TBMAJ(K))
  Else
       # cg add the test of the dim
       If NBORG >= dim (TBORG)
            Call ECR_TRACE("Limit reached on table dimension "+num$(NBORG),-1) From GESECRAN
            Break
       Else
            NBORG += 1
            TBORG(NBORG) = TABLE
            TBATB(NBORG) = [F:ABV]TABORG
            TBMAJ(NBORG) = [F:ABF]TYPMAJ : # Mise à jour incrémentale
            If !find(TBADX(I),TBDOS(1..NBDOS))
                If NBDOS  >= dim (TBDOS)
                    Call ECR_TRACE("Limit reached on table dimension "+num$(NBDOS),-1) From GESECRAN
                    Break
                Else
                    NBDOS += 1
                    TBDOS(NBDOS) = TBADX(I)
                    K = instr(1,TBDOS(NBDOS),"@")
                    If K
                      TBAPP(NBDOS) = right$(TBDOS(NBDOS),K+1)
                    Else
                      TBAPP(NBDOS) = TBDOS(NBDOS)
                    Endif
                Endif
            Endif
      Endif
  Endif
 Next I
Next ABY
If NBORG
 For I=1 To NBDOS
  Local File =TBDOS(I)+".ATABLE" [AAA_] , =TBDOS(I)+".ATABIND" [AAI_]
  If dim([F:AAA_]AUDBI)>0
   # Raz des flags d'audit BI
   For [AAA_] Where AUDBI=2
    K = find(TBDOS(I)+"."+[F:AAA_]CODFIC,TBORG(1..NBORG))
    If !K or TBMAJ(K)<>1
     K = 1
     CHAINE = ""
     #Gosub MAJ_ATABLE : # Pour le moment, on laisse le trigger
    Endif
   Next AAA_
   # Maj des flag d'audit BI
   For J=1 To NBORG
    If left$(TBORG(J),len(TBDOS(I)))=TBDOS(I) & TBMAJ(J)=1
     Read [AAA_]CODFIC=TBATB(J)
     If !fstat
      If [F:AAA_]AUDBI<>2
       CHAINE = ""
       For [ABV]ABV1 Where TABORG=[F:AAA_]CODFIC
        If [F:ABV]INDLEC<>""
         CHAINE = [F:ABV]INDLEC : Break
        Endif
       Next ABV
       If CHAINE=""
        For [AAI_]NUMLIG Where CODFIC=TBATB(J) & HOMONYM=1
         CHAINE = [F:AAI_]CODIND : Break
        Next AAI_
       Endif
       If CHAINE=""
        Call ECR_TRACE(TBATB(J)-":"-mess(42,148,1),1) From GESECRAN : # Index unique non trouvé
       Else
        K = 2
        Gosub MAJ_ATABLE
       Endif
      Else
       K = 1
       For [ABV]ABV1 Where TABORG=[F:AAA_]CODFIC
        If [F:ABV]INDLEC<>"" & [F:AAA_]AUDCLE<>[F:ABV]INDLEC
         # La clé de parcours est différente de la clé d'audit référencée dans la table #
         K = 0
         Call ECR_TRACE([F:ABV]TABORG+"\"+func AFNC.MES(mess(67,148,1),TBORG(J)),1) From GESECRAN
        Endif
       Next ABV
       If K : # On force la regeneration de tout les triggers.
        Trbegin ADOVAL
         Call TRIGGER(TBAPP(I),[F:AAA_]CODFIC,"I") From ATRIGGER
         Call TRIGGER(TBAPP(I),[F:AAA_]CODFIC,"U") From ATRIGGER
         Call TRIGGER(TBAPP(I),[F:AAA_]CODFIC,"D") From ATRIGGER
        Commit
       Endif
      Endif
     Endif
    Endif
   Next J
  Endif
  Close Local File [AAA_] , [AAI_]
 Next I
Endif
End

#-------------------------------|
$MAJ_ATABLE
SYMB = "ATB"+[F:AAA_]CODFIC
If TBAPP(I)=nomap : Lock =SYMB With lockwait=0
Else              : Lock =SYMB From =TBDOS(I) With lockwait=0
Endif
If fstat
 Call ECR_TRACE(TBDOS(I)+"."+[F:AAA_]CODFIC-":"-mess(204,139,1),1) From GESECRAN : # Table verrouillée
Else
 Call ECR_TRACE(mess(81,125,1)-TBDOS(I)+"."+[F:AAA_]CODFIC,0) From GESECRAN : # Mise à jour de la table
 Trbegin [AAA_]
  Readlock [AAA_]CODFIC Curr
  If !fstat
   [F:AAA_]AUDBI = K
   [F:AAA_]AUDCLE = CHAINE
   Rewrite [AAA_]
   If fstat
    Call ERREUR("ATABLE"-[F:AAA_]CODFIC,2) From DOSDIC
   Endif
  Endif
 Commit
 If TBAPP(I)=nomap : Unlock =SYMB
 Else              : Unlock =SYMB From =TBDOS(I)
 Endif
 If instr(1,TBDOS(I),"@")<>0
  # Vous devez revalider la table $1$ dans le dossier $2$
  Call ECR_TRACE(func AFNC.MES2(mess(41,148,1),[F:AAA_]CODFIC,TBDOS(I)),-1) From GESECRAN
 Else
  Trbegin ADOVAL
   Call TRIGGER(TBAPP(I),[F:AAA_]CODFIC,"I") From ATRIGGER
   Call TRIGGER(TBAPP(I),[F:AAA_]CODFIC,"U") From ATRIGGER
   Call TRIGGER(TBAPP(I),[F:AAA_]CODFIC,"D") From ATRIGGER
  Commit
 Endif
Endif
Return

$ERREUR
ER = errn
Resume

#------------------------------------------------------------------------------------------------#
Subprog VALIDATION(APPLI,DATWAR,FORCE,USRFORCE,SILENCE,OK)
Value Char APPLI , DATWAR
Value Integer FORCE ,USRFORCE , SILENCE
Variable Integer OK

Local Shortint MAXFLD , MAXIDX , MAXDIV , MAXMEN , MAXDIM , MAXFAT , MAXFIL

MAXFAT = 100 : # Nombre maxi de tables de faits
MAXFLD = 250 : # Nombre de champs maxi dans une table de faits
MAXIDX = 8   : # Nombre d'index maxi dans une table de faits
MAXMEN = 500 : # Nombre maxi de menus locaux
MAXDIV = 250 : # Nombre maxi de tables diverses
MAXDIM = 500 : # Nombre maxi de dimensions
MAXFIL = 500 : # Nombre maxi de tables dans le dataware
MAXCLE = 16  : # Nombre maxi de partie de clé

Local Integer  NBFLD , NBIDX , NBDIM , NBFAT , NBTAB , NBFIC , NBMEN , NBDIV , NBCUR
Local Integer  I , J , K , W , NBCLE , L , STAT , ER , OKTAB , PARTIEL
Local Char     TBINT(GLONDES)(1..MAXFLD)
Local Schar    TBFLD(GLONAVA)(1..MAXFLD) , TBTYP(GLONATY)(1..MAXFLD) , TBACT(GLONACV)(1..MAXFLD)
Local Decimal  TBLNG(1..MAXFLD)
Local Schar    TBIND(80)(1..MAXIDX) , TBACX(GLONACV)(1..MAXIDX)
Local Integer  TBMEN(1..MAXMEN) , TBDIV(1..MAXDIV)
Local Schar    TBDIM(GLONABI)(1..MAXDIM) , TBFAT(GLONABF)(1..MAXFAT)
Local Schar    TBTAB(30)(1..MAXFIL)
Local Schar    TABLE(GDIMFIC)
Local Integer  NBA,NBN

Local Char     ZON(20) , INTTAB(GLONDES) , CHAINE(255)
Local Integer  TBHOM(1..MAXIDX) , NBPAR
Local Char     CLE(GLONAVA)(1..MAXCLE) , INDEX(250)
Local Char     MACHINE(GDIMFIC) , APPREF(GDIMFIC)
Local Char     ORDSYS(250) , SUF(3) , FIC(GDIMFIC) , LISFIC(30)(1..MAXFIL)

Global Decimal GCOEFTAB
Global Integer GCRE

If clalev([F:ABW])=0 : Local File =APPLI+".ABIDATWRH" [ABW] : Endif
If clalev([F:ABM])=0 : Local File =APPLI+".ABIDATMRT" [ABM] : Endif
If clalev([F:ABF])=0 : Local File =APPLI+".ABITABDAT" [ABF] : Endif
If clalev([F:ABZ])=0 : Local File =APPLI+".ABITABFLD" [ABZ] : Endif
If clalev([F:ABI])=0 : Local File =APPLI+".ABIDIM"    [ABI] : Endif
If clalev([F:ABJ])=0 : Local File =APPLI+".ABIDIMFLD" [ABJ] : Endif
If clalev([F:ABK])=0 : Local File =APPLI+".ABITABLNK" [ABK] : Endif
If clalev([F:ABE])=0 : Local File =APPLI+".ABITABAGG" [ABE] : Endif
If clalev([F:ABX])=0 : Local File =APPLI+".ABITABIND" [ABX] : Endif
If clalev([F:AC2])=0 : Local File =APPLI+".ACTIV"     [AC2] : Endif

GCOEFTAB = 0.5
PARTIEL  = 0

$VALID
Read [ABW]ABW0=DATWAR
If fstat
 Call ECR_TRACE(DATWAR-":"-mess(1,148,1),1) From GESECRAN : # Datawarehouse inexistante
 End
Else
 Call MACHINE_BO([F:ABW]SOLBI,MACHINE) From ABICREBAS
 If MACHINE=""
  Call ECR_TRACE(mess(78,148,1),1) From GESECRAN : # Impossible de déterminer la machine BO
  End
 Endif
Endif

Raz OK , ER
Onerrgo ERREUR
GCRE = (filinfo(filpath("","","",[F:ABW]COD,"",MACHINE),0)<0)
Onerrgo
If ER
 Call ECR_TRACE(mess(121,148,1)-MACHINE,1) From GESECRAN : # Problème d'accès sur la machine BO
 End
Elsif GCRE & adxmac(0)<>""
 Call ECR_TRACE(mess(128,125,1),1) From GESECRAN : # Création de dossier impossible sur machine distante
 End
Elsif filinfo(filpath("FIL","ADOVAL","fde",[F:ABW]COD,"",MACHINE),0)>0
 Call TYPDOS(MACHINE+"@"+[F:ABW]COD,K,CHAINE) From DOSCONT
 # Ce dossier correspond à une application
 Call ERREUR([L]COD-":"-mess(208,139,1)-CHAINE) From GESECRAN
 OK = 0 : End
Elsif filinfo(filpath("","synchro","",[F:ABW]COD,"",MACHINE),0)>0
 # Resynchronisation en cours
 Call ECR_TRACE([F:ABW]COD-":"-mess(148,124,1),1) From GESECRAN
 End
Elsif filinfo(filpath("","valid","",[F:ABW]COD,"",MACHINE),0)>0
 # En cours de validation
 Call ECR_TRACE([F:ABW]COD-":"-mess(128,117,1),1) From GESECRAN
 End
Elsif filinfo(filpath("","epuration","",[F:ABW]COD,"",MACHINE),0)>0
 # En cours de validation
 Call ECR_TRACE([F:ABW]COD-":"-mess(146,148,1),1) From GESECRAN
 End
Else
 Call RECPROSOL(APPLI,"mainport",CHAINE,ER)
 If GADONIX=2 & nomap="SUPERV" : CHAINE ="17000" : Endif
 If ER or adxtcp<>val(CHAINE)
  # Utiliser le service # pour valider le datawarehouse
  Call ECR_TRACE(func AFNC.MES(mess(97,148,1),CHAINE),-1) From GESECRAN
  Call ECR_TRACE(func AFNC.MES1(mess(151,148,1),[F:ABW]COD),1) From GESECRAN
  End
 Endif
 Call VERF_REFBO(MACHINE,[F:ABW]COD,CHAINE,OK) From SUBABW
 If !OK
  # Ce datawarehouse est utilisé par le dossier #
  Call ECR_TRACE(func AFNC.MES(mess(98,148,1),CHAINE),-1) From GESECRAN
  Call ECR_TRACE(func AFNC.MES1(mess(151,148,1),[F:ABW]COD),1) From GESECRAN
  End
 Endif
Endif

Call ECR_TRACE(mess(2,148,1)-[F:ABW]COD,0) From GESECRAN : # Validation Datawarehouse

# Création des répertoires

Call CREAPL(APPLI,OK) From ABICREBAS
If !OK : Goto FIN_VALID : Endif

# Création user base

If GCRE or USRFORCE
 Call CREBASE(APPLI,OK) From ABICREBAS
 If !OK : Goto FIN_VALID : Endif
Endif

# Création des Droits

If filinfo(filpath("FIL","AX3DAT","fde",[F:ABW]COD,"",MACHINE),0)<0 or FORCE or APPLI<>nomap
 Call CREDROIT(APPLI,FORCE,OK) From ABICREBAS
 If !OK : Goto FIN_VALID : Endif
Else
 Call SET_DROITS From TRTGRANT
Endif

If PARTIEL : End : Endif

# Création du lock de validation

Openo filpath("","valid","",[F:ABW]COD,"",MACHINE),0 Using [LOK_]
Wrseq adxmac(-2)-adxusr-format$(GFMD,date$)-"-"-time$ Using [LOK_]
Openo Using [LOK_]

If clalev([F:ATB]) : Close Local File [ATB] : Endif
If clalev([F:ATZ]) : Close Local File [ATZ] : Endif
If clalev([F:ATY]) : Close Local File [ATY] : Endif
If clalev([F:ACV]) : Close Local File [ACV] : Endif
If clalev([F:ADV]) : Close Local File [ADV] : Endif
If clalev([F:ATX]) : Close Local File [ATX] : Endif
If clalev([F:AXX]) : Close Local File [AXX] : Endif
If clalev([F:AML]) : Close Local File [AML] : Endif

If [F:ABW]NBRDOS=0 or [F:ABW]ADXDOS(0)=""
 APPREF = APPLI
Else
 APPREF = [F:ABW]ADXDOS(0)
Endif

Local File =APPREF+".ATABLE"  [ATB]
Local File =APPREF+".ATABZON" [ATZ]
Local File =APPREF+".ATYPE"   [ATY]
Local File =APPREF+".ACTIV"   [ACV]
Local File =APPREF+".ATABTAB" [ADV]
Local File =APPREF+".ATEXTE"  [ATX]
Local File =APPREF+".ATEXTRA" [AXX]
Local File =APPREF+".AMENLOC" [AML]

Call ECR_TIME(mess(14,123,1)-mess(3,148,1)) From DOSSUB : # Validation Tables de faits

Raz NBTAB
Raz NBMEN , NBDIV , NBFAT
For I=0 To [F:ABW]NBRABM-1
 If [F:ABW]CODABM(I)<>""
  Read [ABM]ABM0=[F:ABW]CODABM(I)
  If fstat
   K = 0
  Else
   Call ACTIV([F:ABM]CODACT,K)
  Endif
  If K
   For J=1 To [F:ABM]NBRABF
    Read [ABF]ABF0 = [F:ABM]CODABF(J-1)
    If !fstat & !find([F:ABF]CODABF,TBFAT(1..NBFAT))
     Call ACTIV([F:ABF]CODACT,K)
    Endif
    If K
     NBFAT += 1
     TBFAT(NBFAT) = [F:ABF]CODABF
     Raz NBFLD
     For [ABZ]ABZ1 Where CODABF=[F:ABF]CODABF
      Call ACTIV([F:ABZ]ACTFLD,K)
      If K
       NBFLD += 1
       TBFLD(NBFLD) = [F:ABZ]CODFLD
       Call TEXTE([F:ABZ]INTFLD,TBINT(NBFLD)) From OBJDIV
       Read [ATY]CODTYP=[F:ABZ]CODTYP
       If !fstat
        If find([F:ATY]CODTYP,"AXX","ATX")
         TBTYP(NBFLD) = "DES"
         TBLNG(NBFLD) = [F:ATY]LNGTYP
        Elsif [F:ABZ]TYPFLD=2 & [F:ATY]CODTYP="ADI" : # Information et table diverse
         TBTYP(NBFLD) = "DES"
         TBLNG(NBFLD) = [F:ATY]LNGTYP
        Elsif [F:ABZ]TYPFLD=2 & [F:ATY]TYPTYP=1 : # Information et menu local
         TBTYP(NBFLD) = "A"
         Read [AML]MENLOC=[F:ABZ]MENLOC
         If !fstat and [F:AML]LONG<>0
          TBLNG(NBFLD) = [F:AML]LONG
         Else
          TBLNG(NBFLD) = GLONDES
         Endif
        Else
         TBTYP(NBFLD) = [F:ATY]CODTYP
         TBLNG(NBFLD) = max([F:ABZ]LNGFLD,[F:ATY]LNGTYP)
        Endif
       Else
        TBTYP(NBFLD) = "A"
        TBLNG(NBFLD) = 1
       Endif
       TBACT(NBFLD) = [F:ABZ]ACTFLD
       #If [F:ABZ]TYPFLD<>2 : # Information
        If [F:ABZ]MENLOC<>0 & !find([F:ABZ]MENLOC,TBMEN(1..NBMEN))
         NBMEN += 1
         TBMEN(NBMEN) = [F:ABZ]MENLOC
        Elsif [F:ABZ]TABDIV<>0 & !find([F:ABZ]TABDIV,TBDIV(1..NBDIV))
         NBDIV += 1
         TBDIV(NBDIV) = [F:ABZ]TABDIV
        Endif
       #Endif
      Endif
     Next ABZ
     # Rajout des champs de clé
     NBIDX = 1
     TBACX(NBIDX) = ""
     TBHOM(NBIDX) = 1
     TBIND(NBIDX) = ""
     For ZON="ADOS","AREG","AIND","ACLE"
      NBFLD += 1
      TBFLD(NBFLD) = ZON
      TBACT(NBFLD) = ""
      Case ZON
       When "ADOS" : TBTYP(NBFLD) = "ADS" : TBLNG(NBFLD) = GLONADS : TBINT(NBFLD) = "Folder"
       When "AREG" : TBTYP(NBFLD) = "ABV" : TBLNG(NBFLD) = GLONABV : TBINT(NBFLD) = "Rule"
       When "AIND" : TBTYP(NBFLD) = "C"   : TBLNG(NBFLD) = 4       : TBINT(NBFLD) = "Index"
       When "ACLE" : TBTYP(NBFLD) = "ID2" : TBLNG(NBFLD) = GLONID2 : TBINT(NBFLD) = "Key"
      Endcase
      If TBIND(NBIDX)<>""
       TBIND(NBIDX) += "+"
      Endif
      TBIND(NBIDX) += ZON
     Next ZON
     For [ABX]ABX0 Where CODABF=[F:ABF]CODABF
      Call ACTIV([F:ABX]ACTIND,K)
      If K
       CHAINE = [F:ABX]EXPIND
       Gosub DEFCLE
       K = 1
       For L=1 To NBCLE
        If !find(CLE(L),TBFLD(1..NBFLD))
         K = 0 : Break
        Endif
       Next L
       If K
        NBIDX += 1
        TBIND(NBIDX) = [F:ABX]EXPIND
        TBACX(NBIDX) = [F:ABX]ACTIND
        TBHOM(NBIDX) = 2
       Endif
      Endif
     Next ABX
     Call TEXTE([F:ABF]INTIT,INTTAB) From OBJDIV
     NBTAB += 1
     TBTAB(NBTAB) = 'F_'+[F:ABF]CODABF
     Call MAJTAB(TBTAB(NBTAB),[F:ABF]ABRABF,INTTAB,100,[F:ABF]STK
&                ,NBFLD,TBFLD,TBINT,TBTYP,TBLNG,TBACT,NBIDX,TBIND,TBACX,TBHOM,FORCE,SILENCE,OKTAB)
     If !OKTAB : Break 2 : Endif
    Endif
   Next J
  Endif
 Endif
Next I
If !OKTAB : Goto FIN_VALID : Endif


Call ECR_TIME(mess(14,123,1)-mess(4,148,1)) From DOSSUB : # Validation Tables agrégats

NBDIM = 0
For I=1 To NBFAT
 Read [ABF]ABF0=TBFAT(I)
 For [ABK] Where CODABF=TBFAT(I)
  If !find([F:ABK]CODLNK,TBDIM(1..NBDIM))
   Call ACTIV_DIM([F:ABK]CODLNK,K)
   If K
    NBDIM += 1
    TBDIM(NBDIM) = [F:ABK]CODLNK
    Gosub DIMPERE
   Endif
  Endif
 Next ABK
 For [ABE] Where CODABF=TBFAT(I)
  Raz NBFLD , INDEX , NBPAR
  For J=1 To [F:ABE]NBRAGD
   If [F:ABE]DIMAGG(J-1)<>"" & !find([F:ABE]DIMAGG(J-1),TBDIM(1..NBDIM))
    Call ACTIV_DIM([F:ABE]DIMAGG(J-1),K)
    If K
     NBDIM += 1
     TBDIM(NBDIM) = [F:ABE]DIMAGG(J-1)
     Gosub DIMPERE
    Endif
   Endif
   CHAINE = [F:ABE]LNKAGG(J-1)
   While CHAINE<>""
    K = instr(1,CHAINE,";")
    If K
     ZON = left$(CHAINE,K-1)
     CHAINE = right$(CHAINE,K+1)
    Else
     ZON = CHAINE
     CHAINE = ""
    Endif
    If !find(ZON,TBFLD(1..NBFLD))
     Read [ABZ]ABZ1=TBFAT(I);ZON
     If !fstat
      Call ACTIV([F:ABZ]ACTFLD,K)
      If !K
       # Lien impossible
       Call ECR_TRACE([F:ABE]LNKAGG(J-1)-":"-mess(45,105,1),-1) From GESECRAN
      Else
       NBFLD += 1
       TBFLD(NBFLD) = ZON
       If NBPAR=dim(CLE)
        INDEX = ""
       Elsif NBPAR<dim(CLE)
        If INDEX<>"" : INDEX += "+" : Endif
        INDEX += ZON
       Endif
       NBPAR += 1
       Call TEXTE([F:ABZ]INTFLD,TBINT(NBFLD)) From OBJDIV
       Read [ATY]CODTYP=[F:ABZ]CODTYP
       If !fstat
        If find([F:ATY]CODTYP,"AXX","ATX")
         TBTYP(NBFLD) = "DES"
         TBLNG(NBFLD) = [F:ATY]LNGTYP
        Elsif [F:ABZ]TYPFLD=2 & [F:ATY]CODTYP="ADI" : # Information et table diverse
         TBTYP(NBFLD) = "DES"
         TBLNG(NBFLD) = [F:ATY]LNGTYP
        Elsif [F:ABZ]TYPFLD=2 & [F:ATY]TYPTYP=1 : # Information et menu local
         TBTYP(NBFLD) = "A"
         Read [AML]MENLOC=[F:ABZ]MENLOC
         If !fstat and [F:AML]LONG<>0
          TBLNG(NBFLD) = [F:AML]LONG
         Else
          TBLNG(NBDLF) = GLONDES
         Endif
        Elsif [F:ATY]CODTYP="D" & [F:ABE]NIVAGG(J-1)<>1
         TBTYP(NBFLD) = "C"
         TBLNG(NBFLD) = 4
        Else
         TBTYP(NBFLD) = [F:ATY]CODTYP
         TBLNG(NBFLD) = max([F:ABZ]LNGFLD,[F:ATY]LNGTYP)
        Endif
       Else
        TBTYP(NBFLD) = "A"
        TBLNG(NBFLD) = 10
       Endif
      Endif
      TBACT(NBFLD) = [F:ABZ]ACTFLD
     Endif
    Endif
   Wend
  Next J
  If NBFLD
   For [ABZ] Where CODABF=TBFAT(I) & TYPFLD=1 : # Mesures
    Call ACTIV([F:ABZ]ACTFLD,K)
    If K
     NBFLD += 1
     TBFLD(NBFLD) = [F:ABZ]CODFLD
     Call TEXTE([F:ABZ]INTFLD,TBINT(NBFLD)) From OBJDIV
     TBTYP(NBFLD) = [F:ABZ]CODTYP
     TBLNG(NBFLD) = [F:ABZ]LNGFLD
     TBACT(NBFLD) = [F:ABZ]ACTFLD
    Endif
   Next ABZ
   NBIDX = 0
   If INDEX<>""
    NBIDX += 1
    TBIND(NBIDX) = INDEX
    TBACX(NBIDX) = ""
    TBHOM(NBIDX) = 2
   Endif
   For J=1 To [F:ABE]NBRAGI
    CHAINE = [F:ABE]INDAGG(J-1)
    Gosub DEFCLE
    K = 1
    For L=1 To NBCLE
     If !find(CLE(L),TBFLD(1..NBFLD))
      K = 0 : Break
     Endif
    Next L
    If K
     NBIDX += 1
     TBIND(NBIDX) = [F:ABE]INDAGG(J-1)
     TBACX(NBIDX) = ""
     TBHOM(NBIDX) = 2
    Endif
   Next J
   If NBIDX=0
    Call ECR_TRACE(TBFAT(I)+"_"+[F:ABE]CODAGG-":"-mess(265,139,10),1) From GESECRAN : # Aucune clé disponible
   Else
    NBTAB += 1
    TBTAB(NBTAB) = TBFAT(I)+"_"+[F:ABE]CODAGG
    Call MAJTAB(TBTAB(NBTAB),[F:ABF]ABRABF,"",100,"",NBFLD,TBFLD,TBINT,TBTYP,TBLNG,TBACT,NBIDX,TBIND,TBACX
&              ,TBHOM,FORCE,SILENCE,OKTAB)
   Endif
  Endif
 Next ABE
Next I


Call ECR_TIME(mess(14,123,1)-mess(5,148,1)) From DOSSUB : # Validation Tables de dimensions

# Génération

For I=1 To NBDIM
 Read [ABI]ABI0 = TBDIM(I)
 Raz NBFLD
 For [ABJ] Where CODDIM=TBDIM(I)
  Call ACTIV([F:ABJ]ACTDIM,K)
  If K
   NBFLD += 1
   TBFLD(NBFLD) = [F:ABJ]FLDDIM
   Call TEXTE([F:ABJ]INTDIM,TBINT(NBFLD)) From OBJDIV
   Read [ATY]CODTYP=[F:ABJ]CODTYP
   If !fstat
    If find([F:ATY]CODTYP,"AXX","ATX")
     TBTYP(NBFLD) = "DES"
     TBLNG(NBFLD) = [F:ATY]LNGTYP
    Elsif [F:ABJ]TYPFLD=2 & [F:ATY]CODTYP="ADI": # Information et table diverse
     TBTYP(NBFLD) = "DES"
     TBLNG(NBFLD) = [F:ATY]LNGTYP
    Elsif [F:ABJ]TYPFLD=2 & [F:ATY]TYPTYP=1 : # Information et menu local
     TBTYP(NBFLD) = "A"
     Read [AML]MENLOC=[F:ABJ]MENLOC
     If !fstat and [F:AML]LONG<>0
      TBLNG(NBFLD) = [F:AML]LONG
     Else
      TBLNG(NBFLD) = GLONDES
     Endif
    Else
     TBTYP(NBFLD) = [F:ATY]CODTYP
     TBLNG(NBFLD) = max([F:ABJ]LNG,[F:ATY]LNGTYP)
    Endif
   Else
    TBTYP(NBFLD) = "A"
    TBLNG(NBFLD) = 10
   Endif
   TBACT(NBFLD) = [F:ABJ]ACTDIM
   #If [F:ABJ]TYPFLD<>2 : # Information
   If [F:ABJ]MENLOC<>0 & !find([F:ABJ]MENLOC,TBMEN(1..NBMEN))
    NBMEN += 1
    TBMEN(NBMEN) = [F:ABJ]MENLOC
   Elsif [F:ABJ]TABDIV<>0 & !find([F:ABJ]TABDIV,TBDIV(1..NBDIV))
    NBDIV += 1
    TBDIV(NBDIV) = [F:ABJ]TABDIV
   Endif
   #Endif
  Endif
 Next ABJ
 CHAINE = [F:ABI]CLE
 Gosub DEFCLE
 K = 1
 For L=1 To NBCLE
  If !find(CLE(L),TBFLD(1..NBFLD))
   K = 0 : Break
  Endif
 Next L
 If !K
  # Impossible de générer l'index
  Call ECR_TRACE('D_'+[F:ABI]CODDIM-":"-mess(200,139,1)-[F:ABI]CLE,1) From GESECRAN
 Else
  NBIDX = 1
  TBIND(NBIDX) = [F:ABI]CLE
  TBACX(NBIDX) = ""
  TBHOM(NBIDX) = 1
  Call TEXTE([F:ABI]INTIT,INTTAB) From OBJDIV
  NBTAB += 1
  TBTAB(NBTAB) = 'D_'+[F:ABI]CODDIM
  Call MAJTAB(TBTAB(NBTAB),[F:ABI]ABRDIM,INTTAB,100,""
&            ,NBFLD,TBFLD,TBINT,TBTYP,TBLNG,TBACT,NBIDX,TBIND,TBACX,TBHOM,FORCE,SILENCE,OKTAB)
 Endif
Next I

Call ECR_TIME(mess(14,123,1)-mess(6,148,1)) From DOSSUB : # Validation Tables de dimension superviseur

# Table des codes accès

TABLE = "ACCES"
Read [ATB]CODFIC=TABLE
Raz NBFLD
For ZON="CODACC","USR"
 NBFLD += 1
 Read [ATZ]CODZONE=TABLE;ZON
 Call TEXTE([F:ATZ]NOCOURT,TBINT(NBFLD)) From OBJDIV
 Case ZON
  When "USR"    : TBFLD(NBFLD) = ZON   : TBTYP(NBFLD) = "A"           : TBLNG(NBFLD) = 30
  When "CODACC" : TBFLD(NBFLD) = "ACC" : TBTYP(NBFLD) = [F:ATZ]CODTYP : TBLNG(NBFLD) = [F:ATZ]LONG
 Endcase
 TBACT(NBFLD) = ""
Next ZON
NBIDX = 1
TBIND(NBIDX) = "USR+ACC"
TBACX(NBIDX) = ""
TBHOM(NBIDX) = 1
Call TEXTE([F:ATB]INTITFIC,INTTAB) From OBJDIV
NBTAB += 1
TBTAB(NBTAB) = "AX3ACC"
Call MAJTAB(TBTAB(NBTAB),"AXAC",INTTAB,[F:ATB]NBENREG,""
&           ,NBFLD,TBFLD,TBINT,TBTYP,TBLNG,TBACT,NBIDX,TBIND,TBACX,TBHOM,FORCE,SILENCE,OKTAB)

# Table des dates

Raz NBFLD
For ZON="DATDAT","DATDAY","DATWEK","DATDEC","DATQUI","DATMOI","DATTRE","DATSIX","DATYEA"
 NBFLD += 1
 TBFLD(NBFLD) = ZON
 TBINT(NBFLD) = mess(NBFLD-1,7825,1)
 Case ZON
  When "DATDAT" : TBTYP(NBFLD) = "D" : TBLNG(NBFLD) = 0  : TBACT(NBFLD) = "" : TBINT(NBFLD) = mess(88,100,1)
  When "DATDAY" : TBTYP(NBFLD) = "A" : TBLNG(NBFLD) = 10 : TBACT(NBFLD) = ""
  When "DATWEK" : TBTYP(NBFLD) = "A" : TBLNG(NBFLD) = 10 : TBACT(NBFLD) = ""
  When "DATDEC" : TBTYP(NBFLD) = "A" : TBLNG(NBFLD) = 10 : TBACT(NBFLD) = ""
  When "DATQUI" : TBTYP(NBFLD) = "A" : TBLNG(NBFLD) = 10 : TBACT(NBFLD) = ""
  When "DATMOI" : TBTYP(NBFLD) = "A" : TBLNG(NBFLD) = 15 : TBACT(NBFLD) = ""
  When "DATTRE" : TBTYP(NBFLD) = "A" : TBLNG(NBFLD) = 10 : TBACT(NBFLD) = ""
  When "DATSIX" : TBTYP(NBFLD) = "A" : TBLNG(NBFLD) = 10 : TBACT(NBFLD) = ""
  When "DATYEA" : TBTYP(NBFLD) = "A" : TBLNG(NBFLD) = 4  : TBACT(NBFLD) = ""
 Endcase
Next ZON
NBIDX = 1
TBIND(NBIDX) = "DATDAT"
TBACX(NBIDX) = ""
TBHOM(NBIDX) = 1
NBTAB += 1
TBTAB(NBTAB) = "AX3DAT"
Call MAJTAB(TBTAB(NBTAB),"AXDT",mess(11,148,1),1000,""
&           ,NBFLD,TBFLD,TBINT,TBTYP,TBLNG,TBACT,NBIDX,TBIND,TBACX,TBHOM,1,SILENCE,OKTAB)

# Table des dossiers

Raz NBFLD
For ZON = "CODDOS","ADXDOS"
 NBFLD += 1
 TBFLD(NBFLD) = ZON
 Case ZON
  When "CODDOS" : TBTYP(NBFLD) = "A"   : TBLNG(NBFLD) = 10      : TBINT(NBFLD) = mess(37,100,1)
  When "ADXDOS" : TBTYP(NBFLD) = "ADD" : TBLNG(NBFLD) = GLONADD : TBINT(NBFLD) = mess(85,115,1)
 Endcase
 TBACT(NBFLD) = ""
Next ZON
NBIDX = 1
TBIND(NBIDX) = "CODDOS"
TBACX(NBIDX) = ""
TBHOM(NBIDX) = 1
INTTAB = mess(85,115,1)
NBTAB += 1
TBTAB(NBTAB) = "AX3DOS"
Call MAJTAB(TBTAB(NBTAB),"AXDS",INTTAB,10,""
&        ,NBFLD,TBFLD,TBINT,TBTYP,TBLNG,TBACT,NBIDX,TBIND,TBACX,TBHOM,FORCE,SILENCE,OKTAB)

# Table des menus locaux

TABLE = "APLSTD"
Read [ATB]CODFIC=TABLE
Raz NBFLD
For ZON="LANNUM","LANMES"
 NBFLD += 1
 TBFLD(NBFLD) = ZON
 Read [ATZ]CODZONE=TABLE;ZON
 Call TEXTE([F:ATZ]NOCOURT,TBINT(NBFLD)) From OBJDIV
 TBTYP(NBFLD) = [F:ATZ]CODTYP
 TBLNG(NBFLD) = [F:ATZ]LONG
 TBACT(NBFLD) = ""
Next ZON
NBIDX = 1
TBIND(NBIDX) = "LANNUM"
TBACX(NBIDX) = ""
TBHOM(NBIDX) = 1
For I=1 To NBMEN
 NBTAB += 1
 TBTAB(NBTAB) = "AX3MNL"+num$(TBMEN(I))
 Call MAJTAB(TBTAB(NBTAB),"AXMN",mess(56,142,1)-num$(TBMEN(I)),100,""
&            ,NBFLD,TBFLD,TBINT,TBTYP,TBLNG,TBACT,NBIDX,TBIND,TBACX,TBHOM,FORCE,SILENCE,OKTAB)
Next I

# Table des tables diverses

TABLE = "ATABDIV"
Read [ATB]CODFIC=TABLE
For I=1 To NBDIV
 Read [ADV]CODE=TBDIV(I)
 If fstat
  # La table diverse $1$ n'est pas référencée dans le dossier $2$
  Call ECR_TRACE(func AFNC.MES2(mess(47,148,1),num$(TBDIV(I)),APPREF),-1) From GESECRAN
  Raz [F:ADV]
 Endif
 Raz NBFLD
 For ZON="CODE","LNGDES","SHODES"
  Case ZON
   When "CODE"
    NBFLD += 1
    TBFLD(NBFLD) = ZON
    Read [ATZ]CODZONE=TABLE;ZON
    Call TEXTE([F:ATZ]NOCOURT,TBINT(NBFLD)) From OBJDIV
    TBTYP(NBFLD) = [F:ATZ]CODTYP
    TBLNG(NBFLD) = [F:ATZ]LONG
    TBACT(NBFLD) = ""
   When "LNGDES","SHODES"
    NBFLD += 1
    TBFLD(NBFLD) = ZON
    Read [ATZ]CODZONE=TABLE;ZON
    Call TEXTE([F:ATZ]NOCOURT,TBINT(NBFLD)) From OBJDIV
    TBTYP(NBFLD) = "DES"
    TBLNG(NBFLD) = GLONDES
    TBACT(NBFLD) = ""
   When Default
  Endcase
 Next

   Raz NBA
   For II=0 To dim([F:ADV]COLALPTYP)-1
     Call LECTEXTRA(CHAINE,"ATABTAB","COLALPDES",[F:ADV]NUMCAR,num$(II)) From ATEXTRA
     If CHAINE<>""
      NBFLD += 1
      NBA +=1
      ZON = "A"+num$(NBA)
      J = 0
      TBFLD(NBFLD) = ZON
      TBINT(NBFLD) = CHAINE
      Raz CHAINE
      CHAINE = [F:ADV]COLALPTYP(II)
      Read [ATZ]CODZONE=TABLE;ZON
      Read [ATY]CODTYP=CHAINE
      If !fstat & CHAINE<>""
       If [F:ATY]TYPTYP=1 & J<>0
        TBTYP(NBFLD) = "DES"
        TBLNG(NBFLD) = GLONDES
       Else
        TBTYP(NBFLD) = [F:ATY]CODTYP
        TBLNG(NBFLD) = max([F:ATY]LNGTYP,[F:ATZ]LONG)
       Endif
      Else
       TBTYP(NBFLD) = [F:ATZ]CODTYP
       TBLNG(NBFLD) = [F:ATZ]LONG
      Endif
      TBACT(NBFLD) = ""
     Endif
   Next

   Raz NBN
   For II=0 To dim([F:ADV]COLNUMTYP)-1
     Call LECTEXTRA(CHAINE,"ATABTAB","COLNUMDES",[F:ADV]NUMCAR,num$(II)) From ATEXTRA
     If CHAINE<>""
      NBFLD += 1
      NBN +=1
      ZON = "N"+num$(NBN)
      J = val([F:ADV]COLNUMSUP(II))
      TBFLD(NBFLD) = ZON
      TBINT(NBFLD) = CHAINE
      Raz CHAINE
      CHAINE = [F:ADV]COLNUMTYP(II)
      Read [ATZ]CODZONE=TABLE;ZON
      Read [ATY]CODTYP=CHAINE
      If !fstat & CHAINE<>""
       If [F:ATY]TYPTYP=1 & J<>0
        TBTYP(NBFLD) = "DES"
        TBLNG(NBFLD) = GLONDES
       Else
        TBTYP(NBFLD) = [F:ATY]CODTYP
        TBLNG(NBFLD) = max([F:ATY]LNGTYP,[F:ATZ]LONG)
       Endif
      Else
       TBTYP(NBFLD) = [F:ATZ]CODTYP
       TBLNG(NBFLD) = [F:ATZ]LONG
      Endif
      TBACT(NBFLD) = ""
     Endif
   Next

 NBIDX = 1
 TBIND(NBIDX) = "CODE"
 TBACX(NBIDX) = ""
 TBHOM(NBIDX) = 1
 NBTAB += 1
 TBTAB(NBTAB) = "AX3ADI"+num$(TBDIV(I))
 Call MAJTAB(TBTAB(NBTAB),"AXDI",mess(63,139,1)-num$(TBDIV(I)),100,""
&            ,NBFLD,TBFLD,TBINT,TBTYP,TBLNG,TBACT,NBIDX,TBIND,TBACX,TBHOM,FORCE,SILENCE,OKTAB)
Next I

# Table des autorisations par site

TABLE = "AFCTFCY"
Read [ATB]CODFIC=TABLE
Raz NBFLD
For ZON="FCY","PRFCOD","FNC"
 NBFLD += 1
 Read [ATZ]CODZONE=TABLE;ZON
 Call TEXTE([F:ATZ]NOCOURT,TBINT(NBFLD)) From OBJDIV
 Case ZON
  When "PRFCOD" : TBFLD(NBFLD) = "USR" : TBTYP(NBFLD) = "A"           : TBLNG(NBFLD) = 30
  When "FNC"    : TBFLD(NBFLD) = "REP" : TBTYP(NBFLD) = "A"           : TBLNG(NBFLD) = 30
  When Default  : TBFLD(NBFLD) = ZON   : TBTYP(NBFLD) = [F:ATZ]CODTYP : TBLNG(NBFLD) = [F:ATZ]LONG
 Endcase
 TBACT(NBFLD) = ""
Next ZON
NBIDX = 1
TBIND(NBIDX) = "FCY+USR+REP"
TBACX(NBIDX) = ""
TBHOM(NBIDX) = 1
Call TEXTE([F:ATB]INTITFIC,INTTAB) From OBJDIV
NBTAB += 1
TBTAB(NBTAB) = "AX3FCTFCY"
Call MAJTAB(TBTAB(NBTAB),"AXFC",INTTAB,[F:ATB]NBENREG,""
&           ,NBFLD,TBFLD,TBINT,TBTYP,TBLNG,TBACT,NBIDX,TBIND,TBACX,TBHOM,FORCE,SILENCE,OKTAB)

# On vire les tables qui ne sont plus référencées dans le dataware

ORDSYS = "lsadx -a"-[F:ABW]COD-"FIL fde"
Call SYSTEME2(MACHINE,ORDSYS,"",NBFIC,LISFIC) From ORDSYS

For I=1 To NBFIC
 If !find(LISFIC(I),TBTAB(1..NBTAB))
  Call ECR_TRACE(mess(53,125,1)-LISFIC(I),0) From GESECRAN : # Suppression table
  Call SYSTEME(MACHINE,"valfil -n"-[F:ABW]COD-LISFIC(I),"",STAT) From ORDSYS
  Call SYSTEME(MACHINE,"valfil -d"-[F:ABW]COD-LISFIC(I),"",STAT) From ORDSYS
  For SUF = "srf", "fde", "dat", "idx" , "cfg"
   FIC = filpath("FIL",LISFIC(I),SUF,[F:ABW]COD,"",MACHINE)
   If filinfo(FIC,0)>=0
    Call EFFACE(FIC,STAT) From ORDSYS
   Endif
  Next SUF
 Endif
Next I

$FIN_VALID
Call EFFACE(filpath("","valid","",[F:ABW]COD,"",MACHINE),STAT) From ORDSYS
End

# Recherche des dimensions parentes

$DIMPERE
NBCUR = NBDIM
While NBCUR<=NBDIM
 CHAINE = TBDIM(NBCUR)
 Gosub LECDIM
 NBCUR += 1
Wend
Return

$LECDIM
K = 0
For [ABJ] Where CODDIM=CHAINE
 If [F:ABJ]DIMFAT<>"" & !find([F:ABJ]DIMFAT,TBDIM(1..NBDIM))
  Call ACTIV_DIM([F:ABJ]DIMFAT,K)
  If K
   NBDIM += 1
   TBDIM(NBDIM) = [F:ABJ]DIMFAT
  Endif
 Endif
Next ABJ
Return

#----------------------------------------------------------#
Subprog RECPROSOL(APPLI,PROPERTY,DATA,ER)
Value Char APPLI,PROPERTY
Variable Char DATA
Variable Integer ER
Local Char NOMFIC(GDIMFIC) , LIGNE(255)
Local Integer I
Raz ER , DATA
Call NAMEFIC(APPLI,"SOL","","",NOMFIC) From INTRUTILA
If filinfo(NOMFIC,7)<0 : ER = 1 : End : Endif
Openi NOMFIC,0 Using [CST_]
Iomode adxifs ""  Using [CST_]
Iomode adxirs chr$(10)  Using [CST_]
Iomode adxium GUTF8  Using [CST_]
Rdseq LIGNE Using [CST_]
While !fstat
 I = instr(1,toupper(LIGNE),"<SOLUTION ")
 If I
  I = instr(1,LIGNE,GINSTID)
  If I
   J = instr(1,LIGNE,PROPERTY+'="')
   K = instr(1,LIGNE,PROPERTY+"='")
   If J
    I = instr(J+len(PROPERTY)+2,LIGNE,'"')
    DATA = seg$(LIGNE,J+len(PROPERTY)+2,I-1)
    Break
   Elsif K
    I = instr(K+len(PROPERTY)+2,LIGNE,"'")
    DATA = seg$(LIGNE,K+len(PROPERTY)+2,I-1)
    Break
   Endif
  Endif
 Endif
 Rdseq LIGNE Using [CST_]
Wend
End

#--------------------------------#
Subprog ACTIV_DIM(DIMENS,OK)
Value Char DIMENS
Variable Integer OK
OK = 1
Read [ABI]ABI0=DIMENS
If fstat
 OK = 0
Elsif [F:ABI]CODACT<>""
 Read [AC2]CODACT=[F:ABI]CODACT
 If fstat or [F:AC2]FLACT<>2
  OK = 0
 Endif
Endif
End

#--------------------------------#
Subprog ACTIV(ACTIV,OK)
Value Char ACTIV
Variable Integer OK
OK = 1
If ACTIV<>""
 Read [AC2]CODACT=ACTIV
 If fstat or [F:AC2]FLACT<>2
  OK = 0
 Endif
Endif
End

#--------------------------------#
$DEFCLE
NBCLE = 0
While CHAINE<>""
 K = instr(1,CHAINE,"+")
 L = instr(1,CHAINE,"-")
 If K & L
  K = min(K,L)
 Elsif L & !K
  K = L
 Endif
 NBCLE += 1
 If K
  CLE(NBCLE) = left$(CHAINE,K-1)
  CHAINE = right$(CHAINE,K+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
Wend
Return

#----------------------------------------------------------------------------------------------------------#
Subprog MAJTAB(TABLE,ABREV,INTIT,NBENR,STK,NBFLD,TBFLD,TBINT,TBTYP,TBLNG,TBACT,NBIDX,TBIND,TBACX,TBHOM
&             ,FORCE,SILENCE,OK)
Value Char    TABLE , ABREV
Value Char    INTIT
Value Decimal NBENR
Value Clbfile STK
Value Integer NBFLD
Value Char    TBFLD()(1..)
Value Char    TBINT()(1..)
Value Char    TBTYP()(1..)
Value Decimal TBLNG(1..)
Value Char    TBACT()(1..)
Value Integer NBIDX
Value Char    TBIND()(1..)
Value Char    TBACX()(1..)
Value Integer TBHOM(1..)
Value Integer FORCE
Value Integer SILENCE
Variable Integer OK

Local Integer STAT , DIFF , EXISTE
Local Integer CDBA , KDBA , TDBA , MEXT
Local Char    VERFIC(1) , CHAINE(250)
Local Integer MAXCOL , MAXLNGCLE , MAXPARCLE , MAXLNG , MAXZON
Local Integer NBBLOB , LGBLOB , MAXBLOB
Local Char    MESSAGE(250)(1..5) , MESSA1(250)
Local Char    FNOMFIC(GDIMFIC) , FOLDFIC(GDIMFIC) , FICTRA(GDIMFIC)
Local Char    FNEWFIC(GDIMFIC) , FICCFG(GDIMFIC)
Local Char    APPLI(GLONABW) , MACHINE(GDIMFIC) , TYPDBA(20)
Local Char    FINITIAL(20), OINITIAL(20) , FNEXT(20), FPCTINC(20)
Local Char    ONOM(10)(1..500), OTYP(5)(1..500), OLNG(5)(1..500)
Local Integer ONZON, ONIND
Local Char    OBID(250) , OABR(GLONABR) , ODBA(5)
Local Char    STORAGE(250)
Local Char    ORDSYS(255)(1..2)
Local Char    OREPET(5)(1..500) , OVERFIC(1)
Local Char    ONOMCLE(10)(1..15), OTYPCLE(2)(1..15), OINDEX(250)(1..15)

If !SILENCE
 Call AFF_VLC(mess(41,125,1),TABLE) From GESECRAN : # Validation de la table
Endif
If GTRACE<>""
 Call ECR_TRACE(mess(41,125,1)-TABLE,0) From GESECRAN : # Validation de la table
Endif

# Type de données Ascii ou Unicode

CDBA = [F:ABW]CODDBA

# Environnement

Call MACHINE_BO([F:ABW]SOLBI,MACHINE) From ABICREBAS
Call VAR_BOWORLD("type",[F:ABW]SOLBI,"database",TYPDBA,STAT) From ABICREBAS
APPLI = [F:ABW]COD

# Coefficient multiplicateur (uniquement pour le contrôle de la longueur de l'enregistrement)

If GADONIX=2
 KDBA = 2
Else
 Case TYPDBA
  When "ORACLE"
   Call VARADX("ADXEXTSIZE",MACHINE,CHAINE) From ADXD
   MEXT = val(CHAINE)
   Call VARADX("STUSIZE",MACHINE,CHAINE) From ADXD
   KDBA = val(CHAINE)
   If KDBA<=0 : KDBA = 2 : Endif
  When "SQLSERVER"
   Case CDBA
    When 1 : # Ascii
     KDBA = 1
    When 2 : # Unicode
     KDBA = 2
    When Default
     KDBA = 1
   Endcase
 Endcase
Endif
If MEXT<=0 : MEXT = 1536 : Endif

# Limites

VERFIC    = GADOVERS
MAXCOL    = 512
MAXZON    = 255
MAXLNGCLE = 256
MAXPARCLE = 16
Case TYPDBA
 When "ORACLE": MAXLNG = 32000 : # Oracle
 When Default : MAXLNG = 32000 : # SAM 116263 8060
Endcase
MAXBLOB   = 65536
If GADONIX=2
 MAXLNG = 32000 : # SAM 116263 8060 8060 : # Spécial développement
Endif

FNOMFIC = filpath("FIL",TABLE,"srf",APPLI,"",MACHINE)
FOLDFIC = filpath("FIL",TABLE,"old",APPLI,"",MACHINE)
FNEWFIC = filpath("FIL",TABLE,"new",APPLI,"",MACHINE)
FICTRA  = filpath("tmp",TABLE,"tra",APPLI,"",MACHINE)
FICCFG  = filpath("FIL",TABLE,"cfg",APPLI,"",MACHINE)

# Si le fichier TABLE.tra existe dans le répertoire tmp, on l'efface

If filinfo(FICTRA,0)>=0
 Call EFFACE(FICTRA,STAT) From ORDSYS
Endif

# Si le fichier TABLE.srf existait déjà, on relit les infos

Raz FINITIAL, FNEXT, FPCTINC
If filinfo(FNOMFIC,0)>0
 Openi FNOMFIC Using [LEC_]
 Iomode adxifs chr$(9) Using [LEC_]
 Iomode adxirs chr$(10) Using [LEC_]
 Iomode adxium GUTF8 Using [LEC_]
 Rdseq OBID Using [LEC_]  : # Commentaire
 OVERFIC = mid$(OBID,7,1)
 Rdseq OABR Using [LEC_]  : # Abréviation
 Rdseq OBID Using [LEC_]  : # Répertoire
 Rdseq ODBA , OINITIAL , FNEXT , FPCTINC Using [LEC_] : # Infos base
 Rdseq OBID Using [LEC_]  : # Nb zones
 ONZON = val(OBID)
 For I=1 To ONZON
  Rdseq ONOM(I) , OTYP(I) , OLNG(I) , OREPET(I) , OBID Using [LEC_]
 Next I
 Rdseq OBID Using [LEC_]
 ONIND = min(val(OBID),dim(ONOMCLE))
 For I=1 To ONIND
  Rdseq ONOMCLE(I) , OTYPCLE(I) , OINDEX(I) Using [LEC_]
 Next I
 Openi Using [LEC_]
 EXISTE = 1
 DIFF = 0
Else
 EXISTE = 0
 DIFF = 1
Endif
DIFF = (FORCE<>0)

GPOINT = "MAJTAB" : Gosub ENTREE From EXEFNC : # Bug 82436 pouvoir modifier la table AX3DAT

# Création du ".new" ou du ".srf"

If EXISTE
 Openo FNEWFIC , 0 Using [ECR_]
Else
 Openo FNOMFIC , 0 Using [ECR_]
Endif
Iomode adxifs chr$(9) Using [ECR_]
Iomode adxirs chr$(10) Using [ECR_]
Iomode adxium GUTF8 Using [ECR_]
If VERFIC<>OVERFIC : DIFF = 1 : Endif
Wrseq "#<AdxF"+VERFIC+">@(#)%I% "+INTIT Using [ECR_]
If OABR<>ABREV : DIFF = 1 : Endif
Wrseq ABREV Using [ECR_]
Wrseq '""' Using [ECR_]

# Calcul et vérif de la longueur et du nombre de colonnes

NBZONE = 0
NBZTAB = 0
LNGENR = 0
For I=1 To NBFLD
 K = 1
 If TBACT(I)<>""
  Read [ACV]CODACT = TBACT(I)
  If fstat or [F:ACV]FLACT<>2
   K = 0
  Endif
 Endif
 If K
  Read [ATY]CODTYP = TBTYP(I)
  If fstat
   LNGZON = 1
  Else
   Case [F:ATY]TYPTYP
    When 1 : LNGZON = 1                  : # Libellé
    When 2 : LNGZON = 2                  : # Entier court
    When 3 : LNGZON = 4                  : # Entier long
    When 4 : LNGZON = 8                  : # DCB
    When 5 : LNGZON = 4                  : # Float
    When 6 : LNGZON = 8                  : # Double
    When 7                               : # Alphanumérique
     If find([F:ATY]CODTYP,"ADI")
      LNGZON = GLONADI+1
     Elsif [F:ATY]LNGTYP<>0
      LNGZON = [F:ATY]LNGTYP+1
     Else
      LNGZON = TBLNG(I)+1
     Endif
     LNGZON *= KDBA                      : # Coeff x (Ascii/Utf8)
    When 8    : LNGZON = 3               : # Date
    When 9,10                            : # Blob, clob
     LNGZON = 0
     NBBLOB += 1
     If [F:ATY]LNGTYP<>0
      LGBLOB += 1024*(2^[F:ATY]LNGTYP)
     Else
      LGBLOB += 1024*(2^TBLNG(I))
     Endif
   Endcase
  Endif
  LNGENR += LNGZON
  NBZTAB += 1
  NBZONE += 1
 Endif
Next

If NBZTAB>MAXCOL
 MESSA1 = TABLE-":"-mess(213,123,1)-":"-num$(NBZTAB)-"("+num$(MAXCOL)+")" : # Nombre de colonnes trop grand
 Call ECR_TRACE(MESSA1,1) From GESECRAN
Endif

If NBZONE>MAXZON
 MESSA1 = TABLE-":"-mess(49,123,1)-":"-num$(NBZONE)-"("+num$(MAXZON)+")" : # Nombre de zones trop grand
 Call ECR_TRACE(MESSA1,1) From GESECRAN
Endif

If LNGENR>MAXLNG
 MESSA1 = TABLE-":"-mess(50,123,1)-":"-num$(LNGENR)-"("+num$(MAXLNG)+")" : # Longueur de ligne trop grande
 Call ECR_TRACE(MESSA1,1) From GESECRAN
Endif

If LGBLOB+LNGENR>MAXBLOB & NBBLOB>1
 MESSA1 = TABLE-":"-mess(212,123,1)-":"-num$(LGBLOB+LNGENR)-"("+num$(MAXBLOB)+")"
 Call ECR_TRACE(MESSA1,1) From GESECRAN :  # Longueur des blobs trop grande
Endif

# Taille de la table

TAILLE = NBENR*LNGENR
TAILLE *= GCOEFTAB
If TAILLE > 10*1024*1024
 FINITIAL = num$(min(MEXT,int(TAILLE/(1024*1024))+1))+"M" : # On limite à 1,5 G0
Else
 FINITIAL = num$(int(TAILLE/1024)+1)+"K"
Endif

Case TYPDBA
 When "ORACLE"
  If OINITIAL<>FINITIAL : DIFF = 1 : Endif
  Wrseq "3" , FINITIAL , FNEXT , FPCTINC Using [ECR_]
  If val(ODBA)<>3 : DIFF = 1 : Endif
 When "SQLSERVER"
  Wrseq "5" Using [ECR_]
  If val(ODBA)<>5 : DIFF = 1 : Endif
Endcase

# Comptage des index

NBINDEX = 0
I = 0
While I<NBIDX
 I += 1
 K = 1
 If TBACX(I)<>""
  Read [ACV]CODACT = TBACX(I)
  If fstat or [F:ACV]FLACT<>2
   K = 0
  Endif
 Endif
 If K
  If find(TBIND(I),TBIND(I+1..NBIDX))
   Dela I,1 TBIND,TBACX,TBHOM
   I -= 1
   NBIDX -= 1
  Else
   NBINDEX += 1
  Endif
 Endif
Wend

# Ecriture des zones

Wrseq NBZONE Using [ECR_]
If NBZONE<>ONZON : DIFF = 1 : Endif
For I=1 To NBFLD
 Read [ATY]CODTYP = TBTYP(I)
 If fstat or !find([F:ATY]TYPTYP,9,10)
  Gosub ECRIZONE
 Endif
Next
# On met les blobs/clobs à la fin
For I=1 To NBFLD
 Read [ATY]CODTYP = TBTYP(I)
 If !fstat & find([F:ATY]TYPTYP,9,10)
  Gosub ECRIZONE
 Endif
Next

# Ecritures des index

Wrseq min(NBINDEX,dim(ONOMCLE)) Using [ECR_]
If NBINDEX<>ONIND : DIFF = 1 : Endif
NBINDEX = 0
For I=1 To NBIDX
 K = 1
 If TBACX(I)<>""
  Read [ACV]CODACT = TBACX(I)
  If fstat or [F:ACV]FLACT<>2
   K = 0
  Endif
 Endif
 If K & TBIND(I)<>"" & NBINDEX<dim(ONOMCLE)
  NBINDEX += 1
  If !find(TBIND(I),OINDEX)
   DIFF = 1
  Endif
  Wrseq ABREV+num$(NBINDEX-1), num$((TBHOM(I)<>2)+1) , TBIND(I) Using [ECR_]
 Endif
Next ABX
Openo Using [ECR_]

# Vérification du fichier de configuration

If STK<>""
 Openi FICCFG Using [FIC]
 Iomode adxifs "" Using [FIC]
 Iomode adxirs "" Using [FIC]
 Iomode adxium GUTF8 Using [FIC]
 Wrseq STK Using [FIC]
 Openi Using [FIC]
Elsif filinfo(FICCFG,0)>0
 Call EFFACE(FICCFG,STAT) From ORDSYS
Endif

# Validation de la table

OK = 1
If DIFF
 If EXISTE
  Call MOVE(FNOMFIC,FOLDFIC,STAT) From ORDSYS
  Call MOVE(FNEWFIC,FNOMFIC,STAT) From ORDSYS
 Endif
 ORDSYS(1) = "valfil -s" : # Silencieux
 If FORCE
  ORDSYS(1) -= "-f"      : # Forcé
 Endif
 ORDSYS(1)  -= "-x"      : # Optimisé
 If STORAGE<>""
  ORDSYS(1) -= '-o'-'"'+STORAGE+'"'
 Endif
 ORDSYS(1) -= APPLI-TABLE
 ORDSYS(2)  = FICTRA
 Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
 Openi FICTRA Using [TR_]
 Iomode adxifs "" Using [TR_]
 Iomode adxirs chr$(10) Using [TR_]
 Iomode adxium GUTF8 Using [TR_]
 Raz MESSAGE
 Rdseq MESSAGE(1) Using [TR_]
 Rdseq MESSAGE(2) Using [TR_]
 Rdseq MESSAGE(3) Using [TR_]
 Openi Using [TR_]
 If MESSAGE(1)<>""
  Call ECR_TRACE(mess(51,123,1)-TABLE+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3),1) From GESECRAN
  # Erreur en validation de la table
  OK = 0
 Endif
Else
 Call EFFACE(FNEWFIC,STAT) From ORDSYS
Endif
If OK
 If EXISTE
  Call EFFACE(FOLDFIC,STAT) From ORDSYS
 Endif
 Call EFFACE(FICTRA ,STAT) From ORDSYS
Endif
End

#-------------------------------#
$ECRIZONE
K = 1
If TBACT(I)<>""
 Read [ACV]CODACT = TBACT(I)
 If fstat or [F:ACV]FLACT<>2
  K = 0
 Endif
Endif
If !K : Return : Endif
LNGZON = 0
Read [ATY]CODTYP = TBTYP(I)
If fstat
 TYPZON = 7
 LNGZON = 1
 Read [ATY]CODTYP = "A"
Else
 If find([F:ATY]TYPTYP,4,7,9,10) : # DCB, Alpha, Blob, Clob
  If find([F:ATY]CODTYP,"ADI")
   LNGZON = GLONADI
  Elsif [F:ATY]LNGTYP<>0
   LNGZON = [F:ATY]LNGTYP
  Else
   LNGZON = TBLNG(I)
  Endif
 Endif
Endif
If [F:ATY]TYPTYP=4
 LNGTOT = min(int(LNGZON),28)
 LNGDEC = LNGZON-LNGTOT
 While int(LNGDEC)<>LNGDEC
  LNGDEC *= 10
 Wend
 If instr(1,[F:ATY]OPTION,"F")
  If LNGDEC>0
   LNGTOT = min(14,LNGTOT+LNGDEC)
  Endif
  LNGDEC = min(LNGTOT-1,28-LNGDEC) : # Il ne faut pas dépasser 28
 Else : # On ajoute le nombre de décimales à la partie entière
  LNGTOT += max(min(LNGDEC,28-LNGTOT-LNGDEC),0)
  LNGDEC += 1       : # Par sécurité
 Endif
 If LNGTOT+LNGDEC>28 : LNGDEC = 28-LNGTOT : Endif
 LNGZON = val(num$(LNGTOT)+"."+num$(LNGDEC))
 Wrseq TBFLD(I), [F:ATY]TYPTYP, num$(LNGTOT)+"."+num$(LNGDEC), 1, '"'+TBINT(I)+'"' Using [ECR_]
Else
 Case [F:ATY]TYPTYP
  When 7
   Case CDBA
    When 2
     TYPZON = 79 : # Unicode
    When Default
     TYPZON = 7  : # Ascii
   Endcase
  When 9
   TYPZON = 81 : # Blob
  When 10
   TYPZON = 82 : # Clob
  When 11 : # Uuid
    TYPZON = 84
  When 12 : # Datetime
    TYPZON = 85
  When Default
   TYPZON = [F:ATY]TYPTYP
 Endcase
 If  TBFLD(I)<>"" & !find(TBFLD(I),[L]ONOM)
  DIFF = 1
 Endif
 Wrseq TBFLD(I), TYPZON, LNGZON, 1, '"'+TBINT(I)+'"' Using [ECR_]
Endif
Return

