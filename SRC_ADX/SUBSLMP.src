#<AdxTL>@(#)2.0.0.0 $Revision$
# Picking modification lots                                             # 
#########################################################################

#########################################################################
$TIROIR
ILIS = val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB
If WAFFPICK <> 0
    WPICK = 2
    Gosub RAFFRAICHI
Endif
Return

#########################################################################
$REMP_DERLU
# Pas de dernier lu
If GFONC1 <> "GESSLM"
   adxmxl = 0
Endif
Return

#########################################################################
$FILGAUCHE
If GFONC1 <> "GESSLM"
   If ILIS = 0  : adxmxl = 0  : Endif
Endif
If currbox <> GBOXSTO  : Return  : Endif

Raz FILGAUSUP(0)
Raz FILGAUSUP(1)

If WAFFPICK=0
   # Rien dans la liste de picking
   FILGAUSUP(0)='[F:STO]ITMREF=""&[F:STO]STOFCY=""'
Else
    # Filtre article, site
    FILGAUSUP(0) ='[F:STO]ITMREF=[M:SLM1]ITMREF&[F:STO]STOFCY=[M:SLM1]STOFCY'
    FILGAUSUP(0)+='&[F:STO]CUNLOKFLG<>2'
    FILGAUSUP(1) = '&[F:STO]LOT=[M:SLM1]LOT'
    If [M:SLM1]SLOMOD = 2 & dim([M:SLM1]SLO) > 0 & [M:SLM1]SLO <> ""     #  hcb 79144
        FILGAUSUP(1) += '&[F:STO]SLO=[M:SLM1]SLO'
    Endif
    # Filtre catégorie emplacement
    If WCRITLOC <> ""
       FILGAUSUP(1) += '&'+WCRITLOC
    Endif
    # Filtre statuts
    If WCRITSTA <> ""
       FILGAUSUP(1) += '&('+WCRITSTA+')'
    Else
       Raz WCRIT
       If [M:SLM1]AAASTA = 2
          WCRIT += WCRITSTOA
       Endif
       If [M:SLM1]QQQSTA = 2
          If WCRIT <> "" : WCRIT += '|' : Endif
          WCRIT += WCRITSTOQ
       Endif
       If [M:SLM1]RRRSTA = 2
          If WCRIT <> "" : WCRIT += '|' : Endif
          WCRIT += WCRITSTOR
       Endif
       If WCRIT <> ''
          FILGAUSUP(1) += '&('+WCRIT+')'
       Endif
    Endif
Endif
Return

#########################################################################
$AP_FILGAUCHE
Case currbox
    When GBOXSTO : WPICK = 2 : Gosub RAFFRAICHI
    When Default
Endcase
Return

#########################################################################
$PICKE
Local Char LUSCAV
Local Char LFMT
Local Integer LMODIF
Local Decimal LCOE

If REP = ""
   If !CLECUR | !VERROU | !ACTMOD 
       OK=0
       Return
   Endif
Endif

If currbox <> GBOXSTO : Return : Endif

If [M:SLM1]LOTDES = "" 
    OK=0 : GERR=1
    GMESSAGE =mess(472,199,1)
    Return
Endif
If dim([M:SLM1]SLODES) > 0
    If ([M:SLM1]SLOMOD = 2 & [M:SLM1]SLODES = "")
        OK=0 : GERR=1
        GMESSAGE =mess(472,199,1)
        Return
    Endif
Endif
# Contrôle de l'insertion
If [M:SLM1]NBLIG + 1 >= dim([M:SLM1]STA) - 1 
   OK=0 : GERR=1
   GMESSAGE=mess(122,199,1) 
   Return 
Endif

Read [STO]STO0=[F:STO]STOFCY;[F:STO]STOCOU
If fstat 
   Call RSTA ("STO",[F:STO]STOFCY-num$([F:STO]STOCOU)) From GLOCK
   FOK=0 : Return
Endif

Gosub FILL_LINE From SUBSLMB
Diszo [M:SLM1]10
Return

#########################################################################
$DEPICK
Local Integer DP_LRET

Case currbox
    When GBOXSTO : Look [STO]STO0=[F:STO]STOFCY;[F:STO]STOCOU
                   If fstat 
                       Call RSTA ("STO",[F:STO]STOFCY-num$([F:STO]STOCOU)) From GLOCK
                       FOK=0 : Return
                   Endif

                   Call DEPICK([F:STO]STOFCY, [F:STO]STOCOU, "SLM1", DP_LRET) From SUBSLMB
                   Affzo [M:SLM1]
                   OK = !DP_LRET
    When Default
Endcase
Return
#########################################################################
$FIN_PICK

If REP=""
   If !VERROU
      GMESSAGE=mess(10,100,1) : GERR=1 : OK=0 : Return
   Elsif !CLECUR | !ACTMOD | GCONSULT
      GMESSAGE=mess(9,123,1)  : GERR=1 : OK=0 : Return
   Endif
Endif

Local Integer LRET
Local Decimal LQTY

Case currbox
    When GBOXSTO : Affzo [M:SLM1]1-99 
                   If [M:SLM1]NBLIG <> 0
                       # Repositionnement sur la ligne pickée
                       zonsui = "[M:SLM1]NBLIG("+num$(nolign-1)+")"
                   Endif
    When Default
Endcase

Return

#########################################################################
# Etiquettes de traitement                                              #
#########################################################################

$REMPBOX
#-----------------------------------------------------------------------#
# Remplissage des boites de picking                                     #
#-----------------------------------------------------------------------#
ILIS=val(right$(currbox,8))

Gosub REMP_LISGAU From GOBJSUB
WPICK = 2
Gosub RAFFRAICHI


Return

######################################################################### 
$RAFFRAICHI
#-----------------------------------------------------------------------#
# Raffraichissement des listes de picking pour les lignes déjà saisies  #
#-----------------------------------------------------------------------#
For I=0 To [M:SLM1]NBLIG-1
    Case currbox
        When GBOXSTO : Read [STO]STO0=[M:SLM1]STOFCY;[M:SLM1]WSTOCOU(I)
        When Default
    Endcase
    If    WPICK=1 Gosub DEPICK From GOBJSUB
    Elsif WPICK=2 Gosub REPICK From GOBJSUB
    Endif
Next I     
Return

