If dim([M:POT8]FLGEXCPEN) > 0 : Chgfmt [M:POT8]FLGEXCPEN With "-LA:1" : Raz [M:POT8]FLGEXCPEN : Endif
If dim([M:POT8]NBRPEN) > 0 : Chgfmt [M:POT8]NBRPEN With "-Nx:4" : Raz [M:POT8]NBRPEN : Endif
If dim([M:POT8]PEN) > 0 : Chgfmt [M:POT8]PEN With "-K:20X" : Raz [M:POT8]PEN : Endif
If dim([M:POT8]STRDATPEN) > 0 : Chgfmt [M:POT8]STRDATPEN With "-D:"+GFMDAT4 : Raz [M:POT8]STRDATPEN : Endif
If dim([M:POT8]ENDDATPEN) > 0 : Chgfmt [M:POT8]ENDDATPEN With "-D:"+GFMDAT4 : Raz [M:POT8]ENDDATPEN : Endif
If dim([M:POT8]LIBPEN) > 0 : Chgfmt [M:POT8]LIBPEN With "-K:20X" : Raz [M:POT8]LIBPEN : Endif
If dim([M:POT8]COMMENT) > 0 : Chgfmt [M:POT8]COMMENT With "-K:20X" : Raz [M:POT8]COMMENT : Endif
If dim([M:POT8]PRVORG) > 0 : Chgfmt [M:POT8]PRVORG With "-K:20X" : Raz [M:POT8]PRVORG : Endif
If dim([M:POT8]PRVCOL) > 0 : Chgfmt [M:POT8]PRVCOL With "-K:20X" : Raz [M:POT8]PRVCOL : Endif
If dim([M:POT8]PRVIND) > 0 : Chgfmt [M:POT8]PRVIND With "-K:20X" : Raz [M:POT8]PRVIND : Endif
If dim([M:POT8]WPEN) > 0 : Chgfmt [M:POT8]WPEN With "-K:20X" : Raz [M:POT8]WPEN : Endif
If dim([M:POT8]WSTRDATPEN) > 0 : Chgfmt [M:POT8]WSTRDATPEN With "-D:"+GFMDAT4 : Raz [M:POT8]WSTRDATPEN : Endif
If dim([M:POT8]WENDDATPEN) > 0 : Chgfmt [M:POT8]WENDDATPEN With "-D:"+GFMDAT4 : Raz [M:POT8]WENDDATPEN : Endif
If dim([M:POT8]WPRVORG) > 0 : Chgfmt [M:POT8]WPRVORG With "-K:20X" : Raz [M:POT8]WPRVORG : Endif
If dim([M:POT8]WPRVCOL) > 0 : Chgfmt [M:POT8]WPRVCOL With "-K:20X" : Raz [M:POT8]WPRVCOL : Endif
If dim([M:POT8]WPRVIND) > 0 : Chgfmt [M:POT8]WPRVIND With "-K:20X" : Raz [M:POT8]WPRVIND : Endif
If dim([M:POT8]WCOMMENT) > 0 : Chgfmt [M:POT8]WCOMMENT With "-K:20X" : Raz [M:POT8]WCOMMENT : Endif
If dim([M:POT8]WNOLPEN) > 0 : Chgfmt [M:POT8]WNOLPEN With "-Nx:4" : Raz [M:POT8]WNOLPEN : Endif
