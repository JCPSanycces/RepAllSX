  If dim([M:POT3]RCEGRP)>0 : Chgfmt [M:POT3]RCEGRP   With "-LA:11658" : Raz [M:POT3]RCEGRP :Endif
  If dim([M:POT3]SEX)>0 : Chgfmt [M:POT3]SEX   With "-LA:314" : Raz [M:POT3]SEX : Endif
  If dim([M:POT3]PDISTR)>0 : Chgfmt [M:POT3]PDISTR   With "-D:"+GFMDAT4 : Raz [M:POT3]PDISTR : Endif
  If dim([M:POT3]PDIEND)>0 : Chgfmt [M:POT3]PDIEND   With "-D:"+GFMDAT4 : Raz [M:POT3]PDIEND : Endif
  If dim([M:POT3]HDCFLG)>0 : Chgfmt [M:POT3]HDCFLG   With "-LA:1" : Raz [M:POT3]HDCFLG : Endif
