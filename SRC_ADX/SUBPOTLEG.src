############################################################
#
# Library of Legislation procedures for Positions screens
#
# Window  : OPOT
# Screens : POT3
#
############################################################

Subprog DISPLAY_HIDE()
Local Char WSIGN(1)
#show name block
Local Integer WDISPBLCK
Local Char WNAMEBLCK(36)

If clalev([F:AMKW])=0 : Local File AMSK [AMKW] : Endif
Read [F:AMKW]CODMSK = "POT3"
Case GCURLEG
When "" :
      WSIGN="-"
      WDISPBLCK=0
When Default:
      WSIGN=""
      WDISPBLCK=1
Endcase
# name block
If WDISPBLCK=1
  WNAMEBLCK=func AFNC.TEXTE([F:AMKW]TITBLOC(0))
Endif
Chgtbk [M:POT3]10  With WNAMEBLCK
If WDISPBLCK=1
  WNAMEBLCK=func AFNC.TEXTE([F:AMKW]TITBLOC(1))
Endif
Chgtbk [M:POT3]15        With WNAMEBLCK
If dim([M:POT3]CCV)>0     : Chgfmt [M:POT3]CCV       With WSIGN+"K:"+num$(GLONCCV)+"X"   : Endif
If dim([M:POT3]DES)>0     : Chgfmt [M:POT3]DES       With WSIGN+"KP:30X"                 : Endif
If dim([M:POT3]SALMIN)>0  : Chgfmt [M:POT3]SALMIN    With WSIGN+"N:6.2"                  : Endif
If dim([M:POT3]SALMAX)>0  : Chgfmt [M:POT3]SALMAX    With WSIGN+"N:6.2"                  : Endif
If dim([M:POT3]CPYPOT)>0  : Chgfmt [M:POT3]CPYPOT    With WSIGN+"K:"+num$(GLONCPY)+"BX"  : Endif
If dim([M:POT3]ZCPYPOT)>0 : Chgfmt [M:POT3]ZCPYPOT   With WSIGN+"KP:20X"                 : Endif
If dim([M:POT3]FCYPOT)>0  : Chgfmt [M:POT3]FCYPOT    With WSIGN+"K:"+num$(GLONFCY)+"BX"  : Endif
If dim([M:POT3]ZFCYPOT)>0 : Chgfmt [M:POT3]ZFCYPOT   With WSIGN+"KP:20X"                 : Endif
#Chgfmt [M:POT3]SRVPOT    With WSIGN+"K:5BX"
#Chgfmt [M:POT3]ZSRVPOT   With WSIGN+"KP:20X"
#Chgfmt [M:POT3]POT2      With WSIGN+"K:10X"
#Chgfmt [M:POT3]ZPOT2     With WSIGN+"KP:20X"
#Chgfmt [M:POT3]CPYPOT    With WSIGN+"K:5AX"
#Chgfmt [M:POT3]FCYPOT    With WSIGN+"K:5AX"

#JOJAC - 2016-04-25 - REQ114309 US87 - START
If dim([M:POT3]PDISTR)>0    : Chgfmt [M:POT3]PDISTR   With WSIGN+"D:"+GFMDAT4 : Endif
If dim([M:POT3]PDIEND)>0    : Chgfmt [M:POT3]PDIEND   With WSIGN+"D:"+GFMDAT4 : Endif
If dim([M:POT3]HDCSTR)>0    : Chgfmt [M:POT3]HDCSTR   With WSIGN+"D:"+GFMDAT4 : Endif
If dim([M:POT3]HDCEND)>0    : Chgfmt [M:POT3]HDCEND   With WSIGN+"D:"+GFMDAT4 : Endif
If dim([M:POT2]EMPMDL)>0    : Chgfmt [M:POT2]EMPMDL   With WSIGN+"K:15X" : Endif
If dim([M:POT2]NAMMDL)>0    : Chgfmt [M:POT2]NAMMDL   With WSIGN+"K:15X" : Endif
#JOJAC - 2016-04-25 - REQ114309 US87 - END

If WSIGN=""
  If [M:POT3]CCV="" Then [M:POT3]DES="" : Endif
  Affzo [M:POT3]5-10
Endif
If WSIGN="-"
  If dim([M:POT3]CCV)>0     : Raz [M:POT3]CCV     : Endif
  If dim([M:POT3]DES)>0     : Raz [M:POT3]DES     : Endif
  If dim([M:POT3]SALMIN)>0  : Raz [M:POT3]SALMIN  : Endif
  If dim([M:POT3]SALMAX)>0  : Raz [M:POT3]SALMAX  : Endif
  If dim([M:POT3]CPYPOT)>0  : Raz [M:POT3]CPYPOT  : Endif
  If dim([M:POT3]ZCPYPOT)>0 : Raz [M:POT3]ZCPYPOT : Endif
  If dim([M:POT3]FCYPOT)>0  : Raz [M:POT3]FCYPOT  : Endif
  If dim([M:POT3]ZFCYPOT)>0 : Raz [M:POT3]ZFCYPOT : Endif
#  Raz [M:POT3]SRVPOT
#  Raz [M:POT3]ZSRVPOT
#  Raz [M:POT3]POT2
#  Raz [M:POT3]ZPOT2

#JOJAC - 2016-04-25 - REQ114309 US87 - START
If dim([M:POT3]PDISTR)>0  : Raz [M:POT3]PDISTR : Endif
If dim([M:POT3]PDIEND)>0  : Raz [M:POT3]PDIEND : Endif
If dim ([M:POT3]HDCSTR)>0 : Raz [M:POT3]HDCSTR : Endif
If dim([M:POT3]HDCEND)>0  : Raz [M:POT3]HDCEND : Endif
If dim([M:POT2]EMPMDL)>0  : Raz [M:POT2]EMPMDL : Endif
If dim([M:POT2]NAMMDL)>0  : Raz [M:POT2]NAMMDL : Endif
#JOJAC - 2016-04-25 - REQ114309 US87 - END
Endif

#JOJAC - 2016-04-25 - REQ114309 US87 - START
#ADNGO - 2017-10-11 - X3-34466 - START
#If GCURLEG ='ZAF' & func AFNC.ACTIV("EQM")
If func DIVPAYE.IS_KZA(GCURLEG) & func AFNC.ACTIV("EQM")
#ADNGO - 2017-10-11 - X3-34466 - END
  If dim([M:POT3]JOBGRA)>0    : Chgfmt [M:POT3]JOBGRA   With "K:20X" : Raz [M:POT3]JOBGRA : Endif
  If dim([M:POT3]OCPLEV)>0    : Chgfmt [M:POT3]OCPLEV   With "LA:11670" : Raz [M:POT3]OCPLEV : Endif
