  If dim([M:POT3]OFOCOD)>0    : Chgfmt [M:POT3]OFOCOD     With "K:20X"      :  Endif
  If dim([M:POT3]EQUEMPTYP)>0 : Chgfmt [M:POT3]EQUEMPTYP  With "LA:11671"   :  Endif
  If dim([M:POT3]STG)>0       : Chgfmt [M:POT3]STG        With "LA:1"       :  Endif
  If dim([M:POT3]PDIFLG)>0    : Chgfmt [M:POT3]PDIFLG     With "LA:1"       :  Endif
  If dim([M:POT3]RCEGRP)>0    : Chgfmt [M:POT3]RCEGRP     With "LA:11658"   :  Endif
  If dim([M:POT3]SEX)>0       : Chgfmt [M:POT3]SEX        With "LA:314"     :  Endif
  If dim([M:POT3]PDISTR)>0    : Chgfmt [M:POT3]PDISTR     With "D:"+GFMDAT4 :  Endif
  If dim([M:POT3]PDIEND)>0    : Chgfmt [M:POT3]PDIEND     With "D:"+GFMDAT4 :  Endif
  If dim([M:POT3]HDCFLG)>0    : Chgfmt [M:POT3]HDCFLG     With "LA:1"       :  Endif
  If dim([M:POT3]HDCTYP)>0    : Chgfmt [M:POT3]HDCTYP     With "K:20X"      :  Endif
  If dim([M:POT3]HDCSTR)>0    : Chgfmt [M:POT3]HDCSTR     With "D:"+GFMDAT4 :  Endif
  If dim([M:POT3]HDCEND)>0    : Chgfmt [M:POT3]HDCEND     With "D:"+GFMDAT4 :  Endif
Endif
