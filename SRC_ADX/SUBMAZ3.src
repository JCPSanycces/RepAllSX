#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion du masque MAZ3
########################################
Subprog AS_NBOPG
Local Char SZTBLTYP

  SZTBLTYP = "CCN"
  If nolign-1 >= dim([M:MAZ3]OPGNUM)-1 Then
    End
  Endif
  If nolign > 0 Then
    If GSZPREOPG <> [M:MAZ3]OPGNUM(nolign-1) Then
      GSZPREOPG = [M:MAZ3]OPGNUM(nolign-1)
      Call LOADOPGINF([M:MAZ3]OPGNUM(nolign-1), SZTBLTYP) From TRTMAZ3
      Call LOADSEL([M:MAZ3]OPGNUM(nolign-1), SZTBLTYP) From TRTMAZ3
      Affzo [M:MAZ3]
    Endif
  Endif
End

########################################
Subprog C_NBOPG
Local Char SZTBLTYP

  SZTBLTYP = "CCN"
