#<AdxTL>@(#)11.0.0.0 $Revision$
# Gestion du masque QCR1

$ACTION
#Infbox ACTION
Case ACTION

 When "OUVRE"        : Gosub OUVRE        From SUBQCRA
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE  From SUBQCRA

 When "FILTRE"       : Gosub FILTRE       From SUBQCRA
 When "LIENS"        : Gosub LIENS        From SUBQCRA
 When "DEFLIG"       : Gosub DEFLIG       From SUBQCRA
 When "LIENS_LIG"    : Gosub LIENS_LIG    From SUBQCRA

 When "SETBOUT"      : Gosub SETBOUT      From SUBQCRA
 When "EXEBOUT"      : Case BOUT
                            When "2" :
                                 Raz WCRITSTO4
                                 Call CREE_FORMULE([M:QCR1]FORSTA,"[F:STO]STA",WCRITSTO4) From TRTCATEG
                                 Gosub TIROIR From SUBQCRP
                       Endcase

 When "RAZCRE"       : Gosub RAZCRE       From SUBQCRA
 When "RAZDUP"       : Gosub RAZDUP       From SUBQCRA

 When "VERIF_CRE"    : Gosub VERIF_CRE    From SUBQCRA
 When "VERIF_MOD"    : Gosub VERIF_MOD    From SUBQCRA
 When "INICRE"       : Gosub INICRE       From SUBQCRA
 When "INIMOD"       : Gosub INIMOD       From SUBQCRA
 When "CREATION"     : Gosub CREATION     From SUBQCRA
 When "INICRE_LIG"   : Gosub INICRE_LIG   From SUBQCRA
 When "VALLIG"       : Gosub VALLIG       From SUBQCRA
 When "APRES_CRE"    : Gosub APRES_CRE    From SUBQCRA
 When "MODIF"        : Gosub MODIF        From SUBQCRA
 When "APRES_MOD"    : Gosub APRES_MOD    From SUBQCRA
 When "AB_CREATION"  : Gosub AB_CREATION  From SUBQCRA
 When "AB_MODIF"     : Gosub AB_MODIF     From SUBQCRA

 When "ABANDON"      : Gosub ABANDON      From SUBQCRA
  #When "FIN"          : Gosub ABANDON      From SUBQCRA                       # hcb 110327
 When "FERME"        : Gosub FERME        From SUBQCRA
 When "APRES_MODIF"  : Gosub APRES_MODIF  From SUBQCRA
 When "STATUT"       : Gosub STATUT       From SUBQCRA

 When "TIROIR"           : Gosub TIROIR       From SUBQCRP
 When "REMP_DERLU"       : Gosub REMP_DERLU   From SUBQCRP
 When "FILGAUCHE"        : Gosub FILGAUCHE    From SUBQCRP
 When "AP_FILGAUCHE"     : Gosub AP_FILGAUCHE From SUBQCRP
 When "HINT"             : Gosub HINT_KEY     From SUBQCRP
 When "DEB_PICK"         : Gosub DEB_PICK     From SUBQCRP
 When "PICKE"            : Gosub PICKE        From SUBQCRP
 When "DEPICK"           : Gosub DEPICK       From SUBQCRP
 When "FIN_PICK"         : Gosub FIN_PICK     From SUBQCRP


 When Default
Endcase

#########################################################################
#    Débranchements d'actions                                           #
#########################################################################
Case ACTION
 When "BB3_ITMREFSEL"    : VALEUR=[M:QCR1]ITMREFSEL
 When Default
Endcase

Return

$SET_NOL
    Local Integer NOL
    NOL = nolign-1
Return

Subprog AS_QTYSTUDES(VALEUR)
Variable Decimal VALEUR
End

Subprog D_VCRNUM(VALEUR)
Variable Char    VALEUR()
[M:QCR1]VCRTYP = 29
End

Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()
#-- Il faut une valeur saisie ou retournée par un compteur sinon erreur
If (VALEUR="" &  GSTKCPT(14)="")
   mkstat = 2
   End
Endif
#-- Si on est en création , n° saisi vide et un compteur est présent on sort
If (GREP="C" & VALEUR="" &  GSTKCPT(14)<>"")
   End
Endif

#-- Si dernier lu non chargé, on vérifie l'existence du n° saisi
If [M:QCR1]VCRNUM="" & GREP<>"C"
   Look [F:SGH]SGH0=VALEUR
   If fstat
      GMESSAGE=mess(178,199,1)
      mkstat=2
      End
   Endif
Endif

If VALEUR<>"" & GSTKCPTMAN(14)<>2
   Look [F:SGH]SGH0=VALEUR
   If fstat
      Raz VALEUR
      End
   Endif
Endif

End

Subprog AS_STOFCY(VALEUR)
Variable Char    VALEUR()
# Si ligne déjà saisie, plus d'accés au site de stock
If [M:QCR1]NBLIG <> 0
   mkstat=2
Endif

End

Subprog AM_ITMREFSEL(VALEUR)
Variable Char    VALEUR()
Local Integer  LRET
Local Shortint WRET

GQCRAUZSST = "Q*"
If VALEUR=""
  [M:QCR1]ITMREFSEL = VALEUR
  End
Endif
Raz [M:QCR1]AUZSST,FORSTA,LOTSTR,LOTEND,LOCSTR,LOCEND
Raz [M:QCR1]SERNUMSTR,SERNUMEND,NBUOM,UOM,LPNNUMDEB,LPNNUMEND                # hcb X3-88857
Call LECITM([M:QCR1]STOFCY,VALEUR,"",3,"",LRET) From STKLIB
If LRET
  mkstat=2 : End
Endif
If [F:ITF]STOFCY <>[M:QCR1]STOFCY | [F:ITF]ITMREF <> VALEUR
   Read [ITF]ITF0 = VALEUR;[M:QCR1]STOFCY
   If fstat
      GMESSAGE=VALEUR-[M:QCR1]STOFCY-":"-mess(139,197,1)
      mkstat=2 : End
   Else
# Article non géré en stock
      If [F:ITF]STOMGTCOD = 1
         GMESSAGE = VALEUR-":"-mess(2,196,1)-[M:QCR1]STOFCY
         mkstat=2 : End
      Endif
   Endif
Endif
# sru
#Call LECSRU([M:QCR1]STOFCY,[F:ITM]TCLCOD,34,"","",LRET)
#&             From STKLIB
#If LRET<>0 mkstat=2 : End Endif
#GQCRAUZSST = [F:SRU]AUZSST

[M:QCR1]ITMREFSEL = VALEUR

End

Subprog IB_NBLIG
If [M:QCR1]CREFLG(nolign-1)>0
   GBOUT1 = mess(463, 198, 1)
Endif
#                                                           # hcb 110327 deb
# Btn 2 = saisie serie globales
# No séries concernés
GBOUT2 = mess(655,199,1)

# pas de saisie des series concernés si :
# saisie détail impossible
# l article ne gère pas les series globales
# pas de STOCOU
# pas de quantité qualifiée
If GBOUT1 = "" | [F:ITM]SERMGTCOD <> 4 | [M:QCR1]WSTOCOU (nolign-1)= 0 | [M:QCR1]QTYSTUDES (nolign-1)= 0
   Raz GBOUT2
Endif

#                                                           # hcb 110327 end
End



##########################################################################
Subprog APRES_NBLIG
Local Decimal LSTOCOU
Local Decimal LQTY , LQTYRES
Local Integer NOL
Local Integer LRET
NOL                    = nolign-1
LSTOCOU                = [M:QCR1]WSTOCOU(NOL)
LQTY                   = [M:QCR1]QTYSTUDES(NOL)

Call DELSTO([M:QCR1]STOFCY, nolign-1, nolign-1, LRET) From SUBQCRB
If LRET = 0
   Local Decimal WQTY                                                                   # hcb 110327
   WQTY = LQTY                                                                          # hcb 110327
   Gosub CRERESSTO From SUBQCRB
#                                                                                       # hcb 110327 deb
   If [F:ITM]SERMGTCOD = 4
      If  WQTY <> LQTY & [M:QCR1]SERNUM(NOL) <> ""
          GMESSAGE = mess(302,199,1)   # Désynchronisation des numéros de série (Stock / Séries)
      Else
      # Création série en cours de traitement
          If [M:QCR1]SERNUM(NOL) <> ""
             Call CRE_STOSERW([M:QCR1]ITMREF(NOL),[M:QCR1]SERNUM(NOL),LQTY,LRET) From STKLIB
             If LRET <>0
                End
             Endif
          Endif
      Endif
   Endif
#                                                                                       # hcb 110327 end
   [M:QCR1]WWIPQTY(NOL)   = [F:STO]CUMWIPQTY
   [M:QCR1]WWIPQTA(NOL)   = [F:STO]CUMWIPQTA
Endif
End

Subprog C_NBLIG
Local Integer LRET
Case status
     When 65     :                       # Suppression d'une ligne
          If [M:QCR1]CREFLG(nolign-1)=0
             Call DELSTO([M:QCR1]STOFCY, nolign-1, nolign-1, LRET) From SUBQCRB
          Else
             mkstat = 2
          Endif

     When 68, 83 :                       # Suppression d'un groupe de lignes
          For I=nolign-1 To nolign1-1
              If [M:QCR1]CREFLG(I)<>0
                 mkstat=2
                 Break
              Endif
          Next
          If !mkstat
             Call DELSTO([M:QCR1]STOFCY, nolign-1, nolign1-1,LRET) From SUBQCRB
          Endif

     When 75     :
          If [M:QCR1]CREFLG(nolign-1)<>0
             mkstat=2
          Endif
     Endcase

     If LRET
        mkstat=2
    Endif

End

Subprog AVANT_NBLIG
Local Integer LRET

If [M:QCR1]ITMREF(nolign-1)<>""
   If GREP = "M"
      If dim(GCTRDATQCR) <= 0
         If [M:QCR1]IPTDAT < date$
            Global Integer GCTRDATQCR
            # Attention ! la date d imputation est antérieure à la date du jour
            Call MESSAGE(mess(162,184,1)) From GESECRAN
          Endif
       Endif
   Endif
   Call LECITM2( [M:QCR1]STOFCY, [M:QCR1]ITMREF(nolign-1), "", LRET ) From STKLIB
# sru
#   Call LECSRU([M:QCR1]STOFCY,[F:ITM]TCLCOD,34,"","",LRET)
#&             From STKLIB
#   If LRET<>0 mkstat=2 : End Endif
#   GQCRAUZSST = [F:SRU]AUZSST
Endif
End

Subprog AM_QTYPCU(VALEUR)
Variable Decimal VALEUR
Local Integer LRET

Call MAJQTY(1,VALEUR,LRET) From SUBQCRB
If LRET
   mkstat=2
   End
Endif

End

Subprog AM_QTYSTUDES(VALEUR)
Variable Decimal VALEUR

Local Decimal WQTE, WQTYARR
Local Integer LRET, NOL
NOL=nolign-1

Call MAJQTY(2,VALEUR,LRET) From SUBQCRB
If LRET
   mkstat=2 : End
Endif

#--- Contrôle cohérence Qté US, UC et coeff UC/US
If [M:QCR1]PCU(NOL)<>[M:QCR1]STU(NOL)
   Call CTRQTYPCU([M:QCR1]PCU(NOL),[M:QCR1]PCUSTUCOE(NOL),VALEUR,WQTYARR) From STKLIB
   If WQTYARR<>VALEUR
      Call MESSAGE(mess(160,184,1)-"("+[M:QCR1]PCU(NOL)+")\"+mess(161,184,1)-":"-num$(WQTYARR)) From GESECRAN
   Endif
Endif
End

Subprog C_STADES(VALEUR)
Variable Char    VALEUR()
If left$(VALEUR,1) <> "Q"
   mkstat = 2
   End
Endif

If [M:QCR1]LOC(nolign-1) <> ""
   If [F:STC]LOC <> [M:QCR1]LOC(nolign-1)
      Read [STC]STC0=[M:QCR1]STOFCY;[M:QCR1]LOC(nolign-1)
      If fstat
         End
      Endif
   Endif
   Call STKCTRSTA(VALEUR,[F:STC]AUZSST,1,2,0,mkstat) From STKACT
Endif
End

Subprog AM_WRHSEL(VALEUR)
Variable Char    VALEUR()
[M:QCR1]WRHSEL = VALEUR
End

Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
If GWRHACT = 2
   If VALEUR <> [F:FCY]FCY
      Read [FCY]FCY0=VALEUR
   Endif
   If [F:FCY]WRHGES <> 2
      Grizo [M:QCR1]WRHSEL
   Else
      Actzo [M:QCR1]WRHSEL
   Endif
Endif
GFCY = VALEUR                       # hcb 53503
Gosub CHARG_PARAM From SUBQCRA      # hcb 53503
#                                                                           # hcb 110327 deb
Subprog B2_NBLIG
GOUVCHGS = 2
End
#                                                                           # hcb 110327 end

