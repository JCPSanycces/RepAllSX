#<AdxTL>@(#)7.0.0.0 $Revision$
##############################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE From SUBADVB
 When "LIENS1"      : Gosub LIENS1
 When "CHANGE"      : Gosub CHANGE
 When "CONTSUP"     : Gosub CONTSUP
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "FILTRE"      : Gosub FILTRE    # Issue 97156 - 2014-02-27 by SR
 When "FILGAUCHE"   : Gosub FILGAUCHE # Issue 97156 - 2014-02-27 by SR
Endcase

Return

##############################################################
$LIENS1
#Paramétrage des catégories clients
#--- Issue 107165 by TS remplacement TITN1 par L_TITN(1) (idem pour TYPN1 et SUPN1)
Case NOTAB
    When 29 + GCATCLI
        L_TITN(1) = mess(2770, 200, 1) #Catégorie client
        L_TYPN(1) = "M"
        L_SUPN(1) = "2970"
    When 103
        GMESSAGE = mess(93,187,1)             # table diverse livrée .................
    When Default
Endcase
Return

#-------------------#
# Changement de clé #
#-------------------#
$CHANGE
Case [L]SUPP
  When "1","2" : Gosub CHG_REGIME_NIVEAU
Endcase
Return
#---------------------------#
# Contrôles supplémentaires #
#---------------------------#
$CONTSUP
# Bug 66449 : Plus de ctrl necessaire
#If [M]NUMTAB=15 : Gosub CTL_FLOREG : Endif

Return
#----------------------------------------------------#
# Changement d'un code régime ou d'un niveau de taxe #
#----------------------------------------------------#
$CHG_REGIME_NIVEAU
#-----
Local Char WFILTRE(20)
Local Char WCOD(15)
Local Char WEXPTST(250)
#----
Case [L]SUPP
  When "1" : [L]WFILTRE="VACBPR=[L]NCODE"
  When "2" : [L]WFILTRE="VACITM=[L]NCODE"
Endcase
#-----
If !clalev([F:TVC])   Local File TABVAC [TVC] : Endif
If !clalev([M:TVC1])  Local Mask TVC1  [TVC1] : Endif
#-----
Gosub OUVRE From WOTVC
Gosub OUVRE From SUBTVC
#-----
For [TVC] Where evalue([L]WFILTRE) With Nohint
  [M:TVC1] = [F:TVC]
  Gosub LIENS  From SUBTVC
  Gosub INICRE From SUBTVC
  [L]WCOD   =[F:TVC]COD
  [L]WEXPTST=[F:TVC]EXPTST
  Update [TVC] Where COD=[L]WCOD With EXPTST=[L]WEXPTST
  If fstat=1
    GOK=-1 : GLOCK="$TABVAC"-[L]WCOD : Break
  Elsif fstat
    GOK=0 : Call RSTA("TVC",[L]WCOD) From GLOCK : Break
  Endif
Next
#-----
Return
#---------------------------------------------#
# Table div. 15                               #
# - contrôle des valeurs des flux             #
# (uniquement 'Introduction' ou 'Expédition') #
#---------------------------------------------#
# Bug 66449 : Plus de ctrl necessaire : nvx MM 2241 avec uniquement 'Introduction' et 'Expédition'
#$CTL_FLOREG
#If [M]NUMTAB<>15 : Return : Endif
#If zoncou="A1"
#  If VALEUR<>mess(1,205,1) and VALEUR<>mess(2,205,1) : mkstat=1 : End : Endif
#Endif
#Return

$SEL_TABLE
#MAE, le 17/02/09, bg 52550, si on est dans les conditions de paiement en sélection sur la table des modes de réglement
Local Char NUMTAB(10)
[L]NUMTAB = PARAM(1) : # table diverse
If GPILNAV>1
    If [L]NUMTAB <> "3" | GNAVIG(GPILNAV-1) <> "GESTPT" | GCURLEG = "": Return : Endif
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:ADI]LEG="'+GCURLEG+'" or [F:ADI]LEG="")',"&") From GOBJSUB
Endif
Return


# Issue 97156 - 2014-02-27 by SR
$FILTRE
If dim(FILTSUP)>0
  If  FILTSUP = ""
      FILTSUP = "NUMTAB <> 5"
  Else
      FILTSUP += " & NUMTAB <> 5"
  Endif
Endif
Return

# Issue 97156 - 2014-02-27 by SR
$FILGAUCHE
If dim(FILGAUSUP)>0
   FILGAUSUP -= "& NUMTAB <> 5"
Endif
Return
