#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################################
## VAT Legislation=BEL
#############################################################################
# Issue X3-82605 - 2018-03-20 by FHA : Making DCLVATPAY Subrog independant of DIA screen
Local Char PARAM(10)(1..2) , VALEUR(10)
GFONCTION="DCLVATBEL"
Call S_AFF_CHAR(VALEUR,PARAM,"","DCLVATSTD","XYDCLVATSTD") From GACTION
#Call TRAITE_CHAR(VALEUR,PARAM,"","DCLVATBEL","DCLVATBEL",4,"XYDCLVATBEL") From GTRAITE
End

$ACTION
Case ACTION
  When "OUVRE_BATCH" : Gosub OUVRE_BATCH

  When "INIT"        : Gosub INIT
  When "CONTROLE"    : Gosub CONTROLE
  When "EXEC"        : Gosub EXEC
  When "TERMINE"     : Gosub TERMINE
  When "SORTIE"      : Gosub SORTIE
  When "DEBUT"       : Gosub DEBUT
  When "OK"          : FIN = 1 : GOK = 1
  When "END"         : FIN = 1 : GOK = 0
  When "SEL_TABLE"   : Gosub SEL_TABLE
Endcase
Return

$INIT
Gosub OPEN_FIL
Gosub DECLARE
Local Mask DCLVATBEL [DIA]
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","dclbel") From GMEMO
# When the batch task runs, the Call TRACE_MASQUE(MSKCRIT,ABRCRIT,nomap) writes the data of the DCLVATFRA screen linked with
# DCLVATBAT task rather then DCLVATBEL.
If GSERVEUR=1 : BCRIT="DCLVATBEL" : Endif
Return

$OPEN_FIL
If !clalev([F:DLVB])   : Local File DCLVATBOXH   [DLVB]   : Endif
If !clalev([F:DLVB1])  : Local File DCLVATBOXH   [DLVB1]  : Endif
If !clalev([F:DLVBD])  : Local File DCLVATBOXDBD [DLVBD]  : Endif
If !clalev([F:DLVBD1]) : Local File DCLVATBOXDBD [DLVBD1] : Endif
If !clalev([F:VTB])    : Local File VATBOX       [VTB]    : Endif
If !clalev([F:VTD])    : Local File VATBOXD      [VTD]    : Endif
If !clalev([F:FGR])    : Local File FACGROUP     [FGR]    : Endif
If !clalev([F:CPY])    : Local File COMPANY      [CPY]    : Endif
If !clalev([F:FCY])    : Local File FACILITY     [FCY]    : Endif
If !clalev([F:TCA])    : Local File TABCOUAFF    [TCA]    : Endif
If !clalev([F:GTE])    : Local File GTYPACCENT   [GTE]    : Endif
If !clalev([F:TVT])    : Local File TABVAT       [TVT]    : Endif
If !clalev([F:TCU])    : Local File TABCUR       [TCU]    : Endif
If !clalev([F:HAE])    : Local File GACCENTRY    [HAE]    : Endif
If !clalev([F:HAE2])   : Local File GACCENTRY    [HAE2]   : Endif
If !clalev([F:DAE])    : Local File GACCENTRYD   [DAE]    : Endif
If !clalev([F:DAE2])   : Local File GACCENTRYD   [DAE2]   : Endif
If !clalev([F:TRA])    : Local File TABRATVAT    [TRA]    : Endif
If !clalev([F:GAC])    : Local File GACCOUNT     [GAC]    : Endif
If !clalev([F:GAC2])   : Local File GACCOUNT     [GAC2]   : Endif
If !clalev([F:VRQT])   : Local File SELVATRQT    [VRQT]   : Endif
If !clalev([F:TVTD])   : Local File LEGTVTDEB    [TVTD]   : Endif

If clalev([F:AOE])=0  : Local File AOBJEXT    [AOE]  : Endif
If clalev([F:AOD])=0  : Local File AOBJEXTD   [AOD]  : Endif
If clalev([F:AOR])=0  : Local File AOBJEXTR   [AOR]  : Endif
If clalev([F:ATB])=0  : Local File ATABLE     [ATB]  : Endif
If clalev([M:AOE0])=0 : Local Mask AOE0       [AOE0] : Endif
If clalev([M:AOE1])=0 : Local Mask AOE1       [AOE1] : Endif
If clalev([M:AOE2])=0 : Local Mask AOE2       [AOE2] : Endif
If clalev([M:EXP1])=0 : Local Mask EXPOBJ     [EXP1] : Endif : # to load the template
If clalev([M:EXP2])=0 : Local Mask EXPOBJ2    [EXP2] : Endif : # Ecran référence (export + export enchaîné)
Return

$DECLARE
Local Integer  I, STAT, ERR_STOP, OK
Local Integer  NBLOCK                     : # Number of locks
Local Char     TSYMBOLE(50)(1..GNBSITE)   : # Lock
Local Char     VALPAR(GLONAOE)            : # To store the value of a parameter
Local Char     NUMIMP(8)                  : # Request number
Local Char     COMPTEUR(GLONANM)          : # Counter that assigns the request number
Global Integer GNUMRPT                    : # Request number used to print VAT declaration
Local Integer  INDCPY, NBRLEG             : # Number of companies that belong to a group- Number of legislations
Local Char     TABCPY(GLONCPY)(1..GNBSOC) : # List of the legal companies that belong to a group
Local Char     TABLEG(GLONADI)(1..GNBSOC) : # List of the legislations of the legal companies that belong to a group
Local Char     WLEG(GLONADI)              : # Current legislation of the company
Local Char     CURLEG(GLONADI)            : # Legislation used to select the right record in the VATBOX table

Local Integer  NBTYPDEB                   : # Number of document types (GTE) defined with tax/debits
Filter [GTE] Where VAT=2
NBTYPDEB = rowcount([F:GTE])
Filter [GTE]
Local Char     TTYPDEB(GLONGTE)(1..NBTYPDEB) # List of of document types (GTE) defined with tax/debits

Local Char     OPT(1)                     : # Take into account the "1"=accounting date or "2"=source document date
Local Char     CRITERE(250)               : # Criteria
Local Char     TCOA(GLONCOA)              : # Chart of account
Local Char     DEVLED(GLONCUR)            : # Currency of the general main ledger
Local Char     MESSAGE(250)               : # error message in case export fails

Local Integer  SAVGPARTRABTC              : # The value of the GPARTRABTC parameter is saved
Return

######################################################################################
$DEBUT
# A memo exists.We display it
If [M:DIA]TYPGEN<>0 : Affzo [M:DIA] : Endif
Return

######################################################################################
$CONTROLE
If GOK<1 : FIN = 1 : Return : Endif

If [M:DIA]TYPGEN=3 : GNUMRPT = [M:DIA]NUMRPT : Gosub TRABTC : Return : Endif

If [M:DIA]GRU<>""
 Link [FGR] With [FCY]FCY0=[F:FGR]FCY As [LNK] Where CPY=[M:DIA]GRU
Elsif [M:DIA]FCY<>""
 Link [FGR] With [FCY]FCY0=[F:FGR]FCY As [LNK] Where CPY=[M:DIA]CPY & FCY=[M:DIA]FCY
Else
 Link [FGR] With [FCY]FCY0=[F:FGR]FCY As [LNK] Where CPY=[M:DIA]CPY
Endif

Raz CURLEG

For [LNK]
 # Check that the user has the access to all the sites of the group
 If GUSRFCY(1)<>"\" & !find([F:FGR]FCY,GUSRFCY(1..GNBAUZ))
  GERR = 2 : GMESSAGE=[F:FGR]FCY-mess(2,104,1)
  FIN = 1 : Break
 Endif
 NBLOCK+=1
 TSYMBOLE(NBLOCK) = "DCLVATBEL\"+[F:FGR]FCY
 Lock =TSYMBOLE(NBLOCK) With lockwait=0
 If fstat
  # Opération en cours sur autre poste
  GERR = 2 : GMESSAGE=mess(30,100,1)
  FIN = 1 : Break
 Endif

 # Check that the VATBOX table contains a record for the legislation of the company
 # If the declaration is run for a group, either a company of a group has a BEL legislation
 # and we take the BEL legislation if a record in the VATBOX table matches,
 # or we take the legislation of the first group's company which has a record in the VATBOX table
 If !find([F:FCY]LEGCPY,TABCPY(1..INDCPY))
  # Store all the legal companies required to the VAT declaration
  INDCPY+=1
  TABCPY(INDCPY) = [F:FCY]LEGCPY
  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
  If !fstat
   # Store in the CURLEG variable, the legislation to take into account for the search in the VATBOX table
   If [M:DIA]GRU<>""
    If [F:CPY]LEG="BEL"
     CURLEG ="BEL"
    Elsif CURLEG=""
     CURLEG = [F:CPY]LEG
    Endif
   Else
    CURLEG = [F:CPY]LEG
   Endif
   Look [VTB]VTB0(2)="DCLVATBEL";CURLEG
   If fstat
    If [M:DIA]GRU<>""
     If CURLEG="BEL"
      GMESSAGE = mess(100,102,1)-[M:DIA]GRU-"-"-mess(26,113,1)-[F:CPY]CPY-mess(218,107,1)-[F:CPY]LEG-"-"-mess(366,107,1)
      GERR = 2 : FIN = 1 : Break
     Else
      # We will check the legislation of the next company
      Raz CURLEG
     Endif
    Else
     GMESSAGE = mess(26,113,1)-[F:CPY]CPY-mess(218,107,1)-[F:CPY]LEG-"-"-mess(366,107,1)
     GERR = 2 : FIN = 1 : Break
    Endif
   Endif
  Endif
 Endif
Next

If FIN=1 : Return : Endif

If CURLEG="" & [M:DIA]GRU<>""
 GMESSAGE = mess(100,102,1)-[M:DIA]GRU-"-"-mess(26,113,1)-[F:CPY]CPY-mess(218,107,1)-[F:CPY]LEG-"-"-mess(366,107,1)
 GERR = 2 : FIN = 1
Endif

If FIN=1 : Return : Endif

Gosub READ_PARAM
If FIN=1 : Return : Endif

Gosub TRABTC

TMP = 1
Return

$TRABTC
# To not display the log file "MASQUE_TRACE" managed by the supervisor in GTRAITE
If GSERVEUR=1 & dim(GPARTRABTC)>0
 SAVGPARTRABTC = GPARTRABTC
 GPARTRABTC = 1
Endif
Return

######################################################################################
$READ_PARAM
# Request number
Read [TCA]TCA0=2;"";""
If !fstat : COMPTEUR= [F:TCA]CODNUM(3) : Endif
If COMPTEUR="" : COMPTEUR = "DLV" : Endif
Call NUMERO(COMPTEUR,"",[0/0/0],"",NUMIMP,STAT) From SUBANM
If STAT
 # Problème lors de la récupération du compteur
 Gosub MESSAGE From SUBANM
 Call ERREUR(mess(60,199,1)-"("+COMPTEUR+") : "-MESSA) From GESECRAN
 FIN = 1 : Return
Endif
GNUMRPT = val(NUMIMP)

Call LEGCPY(TABCPY,NBRLEG,TABLEG) From CPTDIV

If NBRLEG=1
 WLEG   = TABLEG(1)
 Gosub LECPARAM_GTE
Endif

Return

#############################################################################
$LECPARAM_GTE
# Load the list of the  document types (GTE) defined with tax on issue
Filter [GTE] Where LEG=[L]WLEG | LEG="" Order By Key CLE=TYP Asc ; LEG Desc
Raz NBTYPDEB, TTYPDEB
For [GTE]CLE(1)
 If [F:GTE]VAT = 2
  NBTYPDEB += 1
  TTYPDEB(NBTYPDEB) = [F:GTE]TYP
 Endif
Next
Filter [GTE]
Return

######################################################################################
$EXEC
If GSERVEUR
 [M:DIA]TRCFLG = 2
 If dim(GPARTRABTC)>0
  GPARTRABTC = SAVGPARTRABTC
 Endif
Endif
If !GSERVEUR & [M:DIA]TRCFLG=2
 Call OUVRE_TRACE(mess(71,107,1)) From LECFIC
Endif
If [M:DIA]TRCFLG=2
 Call ECR_TRACE(mess(71,107,1),0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 ## Display the criteria in the log file
 Call ECR_TRACE(mess(14,103,1)-":",0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Call ECR_TRACE(mess(29,115,1)-":"-mess([M:DIA]TYPGEN,2678,1),0) From GESECRAN
 Call ECR_TRACE(mess(38,114,1)-":"-num$(GNUMRPT),0) From GESECRAN
 Call ECR_TRACE(mess(100,102,1)-":"-[M:DIA]GRU,0) From GESECRAN
 Call ECR_TRACE(mess(26,113,1)-":"-[M:DIA]CPY,0) From GESECRAN
 Call ECR_TRACE(mess(12,105,1)-":"-[M:DIA]FCY,0) From GESECRAN
 Call ECR_TRACE(mess(14,119,1)-":"-format$(GFMDAT,[M:DIA]STRDAT)-mess(95,100,1)-format$(GFMDAT,[M:DIA]ENDDAT),0) From GESECRAN
 Call ECR_TRACE(mess(55,100,1)-":"-mess([M:DIA]FLGFIL,1,1),0) From GESECRAN
 Call ECR_TRACE(mess(143,124,1)-":"-mess([M:DIA]DETDCL,1,1),0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

# Actual or Simulation
If [M:DIA]TYPGEN<>3
 # Delete the simulations in the tables
 Call DEBTRANS From GLOCK
 Gosub TR_DELDLV
 If GOK<1 : Return : Endif
 # Run the declaration
 Gosub DECLARATION
 If GOK<1 & [M:DIA]TYPGEN=1
  # If one error occurs in an actual declaration, all the records saved for the request in the DCLVATBEL* tables must be deleted
  Call DEBTRANS From GLOCK
  Gosub TR_DELRQT
 Elsif GOK=1
  # In order to print the vat report we add some records to the DCLVATBEL table
  Call DEBTRANS From GLOCK
  Gosub TR_UPDREPORT
 Endif
Endif

If ([M:DIA]TYPGEN=1 | [M:DIA]TYPGEN=3) & GOK=1 & [M:DIA]FLGFIL=2
 # File generation
 # S'il n'y a pas de TVA/débits, on crée quand même un enregistrement
 # dans les fichiers temporaires afin de pouvoir afficher les
 # critères sélectionnés (notamment dans une réimpression)
 If [M:DIA]GRU<>""
  Call PARAML("", "BELVATAOE", VALPAR) From ADOVAL
 Else
  Call PARAML([M:DIA]CPY, "BELVATAOE", VALPAR) From ADOVAL
 Endif
 If VALPAR=""
  Call ECR_TRACE("BELVATAOE :"-mess(171,133,1),1) From GESECRAN
 Else
  Raz [M:EXP2]NOMEXP
  Raz [M:EXP2]STAT
  [M:EXP2] = [M:DIA]

  If [M:EXP2]TYPEXP=2
   [M:EXP2]NOMEXP = [M:DIA]FILDIRLOC
   If right$([M:EXP2]NOMEXP, len([M:EXP2]NOMEXP))<>"/" : [M:EXP2]NOMEXP += "/" : Endif
  Endif
  [M:EXP2]NOMEXP += "BETVA_" + num$(GNUMRPT) + "_" + format$("DDMMYY",[M:DIA]STRDAT) + "-" + format$("DDMMYY",[M:DIA]ENDDAT) + "_"+format$("DDMMYY",date$)+"-"+format$("hhmm", date$)
  [M:EXP2]MODELE = VALPAR
  Filter [DLVB] Where NUMRPT = GNUMRPT & TYPBOX=2
  If rowcount([DLVB])=0
   Call ECR_TRACE("0"-mess(82,141,1), 0) From GESECRAN
  Else
   Call EXPORTSIL From GEXPOBJ
   If [M:EXP2]STAT=0 and !GSERVEUR
    If [M:DIA]TYPEXP=1
     Call ECR_TRACE(mess(178,115,1)-[M:EXP2]NOMEXP, 0) From GESECRAN
    Else
     Call ECR_TRACE("|"+mess(14,9003,1)-[M:EXP2]NOMEXP, 0) From GESECRAN
    Endif
   Endif
  Endif
  Filter [DLVB]
 Endif
Endif

If !GSERVEUR & [M:DIA]TRCFLG=2
 Call FERME_TRACE From LECFIC
Endif
If GOK<1 : Return : Endif
Return

######################################################################################
# We begin to delete the simulations that matches the execution criteria
$TR_DELDLV
GOK = 1
Trbegin [DLVB],[DLVBD]
 If [M:DIA]CPY<>"" & [M:DIA]FCY<>""
  # Obviously the declaration is run in simulation when FCY<>"".
  # When the actual declaration will be run for the company or a group containing the company,
  # all the simulations will be removed

  Filter [DLVBD1] Where CPY=[M:DIA]CPY & FCY=[M:DIA]FCY & SIM=2
  For [DLVBD1]DLVBD0(2)
   Delete [DLVB] Where NUMRPT=[F:DLVBD1]NUMRPT & VATFNC="DCLVATBEL"
   If fstat=1 | fstat>5
    GOK = 0 : Call RSTA("DLVB",[M:DIA]CPY-[M:DIA]FCY-num$([F:DLVBD1]NUMRPT)) From GLOCK : Break
   Endif
   # To check that the request has deleted a DCLVATBEL recording and not a DCLVATFRA recording
   If adxdlrec>0
    Delete [DLVBD] Where NUMRPT=[F:DLVBD1]NUMRPT
    If fstat=1 | fstat>5
     GOK = 0 : Call RSTA("DLVBD",[M:DIA]CPY-[M:DIA]FCY-num$([F:DLVBD1]NUMRPT)) From GLOCK : Break
    Endif
   Endif
  Next
  Filter [DLVBD1]
  If GOK<1 : Goto AB_TR_DELDLV : Endif
  # If DCLVATBOXDBD is empty but not DCLVATBOXH
  Delete [DLVB] Where CPY=[M:DIA]CPY & FCY=[M:DIA]FCY & SIM=2 & VATFNC="DCLVATBEL"
  If fstat=1 | fstat>5
   GOK = 0 : Call RSTA("DLVB",[M:DIA]CPY-[M:DIA]FCY) From GLOCK
   Goto AB_TR_DELDLV
  Endif

 Elsif [M:DIA]CPY<>""
  # Delete the company
  Filter [DLVB1] Where CPY=[M:DIA]CPY & SIM=2 & VATFNC="DCLVATBEL"
  For [DLVB1]DLVB0(4)
   Delete [DLVBD] Where NUMRPT=[F:DLVB1]NUMRPT
   If fstat=1 | fstat>5
    GOK = 0 : Call RSTA("DLVBD",[M:DIA]CPY-num$([F:DLVB1]NUMRPT)) From GLOCK : Break
   Endif
   Delete [DLVB] Where NUMRPT=[F:DLVB1]NUMRPT
   If fstat=1 | fstat>5
    GOK = 0 : Call RSTA("DLVB",[M:DIA]CPY-num$([F:DLVB1]NUMRPT)) From GLOCK : Break
   Endif
  Next
  Filter [DLVB1]
  If GOK<1 : Goto AB_TR_DELDLV : Endif
  # Delete the groups that contain the company
  Filter [DLVBD1] Where CPY=[M:DIA]CPY & SIM=2
  For [DLVBD1]DLVBD1(2)
   Delete [DLVB] Where NUMRPT=[F:DLVBD1]NUMRPT & VATFNC="DCLVATBEL"
   If fstat=1 | fstat>5
    GOK = 0 : Call RSTA("DLVB",[M:DIA]CPY-num$([F:DLVBD1]NUMRPT)) From GLOCK : Break
   Endif
   # To check that the request has deleted a DCLVATBEL recording and not a DCLVATFRA recording
   If adxdlrec>0
    Delete [DLVBD] Where NUMRPT=[F:DLVBD1]NUMRPT
    If fstat=1 | fstat>5
     GOK = 0 : Call RSTA("DLVBD",[M:DIA]CPY-num$([F:DLVBD1]NUMRPT)) From GLOCK : Break
    Endif
   Endif
  Next
  Filter [DLVBD1]
  If GOK<1 : Goto AB_TR_DELDLV : Endif

 Elsif [M:DIA]GRU<>""
  # Delete the group
  Filter [DLVB1] Where GRPCPY=[M:DIA]GRU & SIM=2 & VATFNC="DCLVATBEL"
  For [DLVB1]DLVB0(4)
   Delete [DLVBD] Where NUMRPT=[F:DLVB1]NUMRPT
   If fstat=1 | fstat>5
    GOK = 0 : Call RSTA("DLVBD",[M:DIA]GRU-num$([F:DLVB1]NUMRPT)) From GLOCK : Break
   Endif
   Delete [DLVB] Where NUMRPT=[F:DLVB1]NUMRPT
   If fstat=1 | fstat>5
    GOK = 0 : Call RSTA("DLVB",[M:DIA]GRU-num$([F:DLVB1]NUMRPT)) From GLOCK : Break
   Endif
  Next
  Filter [DLVB1]
  If GOK<1 : Goto AB_TR_DELDLV : Endif
  # If DCLVATBOXDBD is empty but not DCLVATBOXH
  Delete [DLVB] Where GRPCPY=[M:DIA]GRU & SIM=2 & VATFNC="DCLVATBEL"
  If fstat=1 | fstat>5
   GOK = 0 : Call RSTA("DLVB",[M:DIA]GRU) From GLOCK
   Goto AB_TR_DELDLV
  Endif

  # Delete the companies of the group
  For I=1 To INDCPY
   Filter [DLVBD1] Where CPY=TABCPY(I) & SIM=2
   For [DLVBD1]DLVBD1(2)
    Delete [DLVB] Where NUMRPT=[F:DLVBD1]NUMRPT & VATFNC="DCLVATBEL"
    If fstat=1 | fstat>5
     GOK = 0 : Call RSTA("DLVB",TABCPY(I)-num$([F:DLVBD1]NUMRPT)) From GLOCK : Break 2
    Endif
    # To check that the request has deleted a DCLVATBEL recording and not a DCLVATFRA recording
    If adxdlrec>0
     Delete [DLVBD] Where NUMRPT=[F:DLVBD1]NUMRPT
     If fstat=1 | fstat>5
      GOK = 0 : Call RSTA("DLVBD",TABCPY(I)-num$([F:DLVBD1]NUMRPT)) From GLOCK : Break 2
     Endif
    Endif
   Next
   # If DCLVATBOXDBD is empty but not DCLVATBOXH
   Delete [DLVB] Where CPY=TABCPY(I) & SIM=2 & VATFNC="DCLVATBEL"
   If fstat=1 | fstat>5
    GOK = 0 : Call RSTA("DLVB",TABCPY(I)) From GLOCK : Break
   Endif
  Next
  Filter [DLVBD1]
  If GOK<1 : Goto AB_TR_DELDLV : Endif
 Endif
Commit
Return

$AB_TR_DELDLV
Rollback
Return

######################################################################################
$TR_DELRQT
Trbegin [DLVB],[DLVBD]
 Delete [DLVB] Where NUMRPT=GNUMRPT
 If fstat=1 | fstat>5
  GOK = 0 : Call RSTA("DLVB",num$(GNUMRPT)) From GLOCK : Goto AB_TR_DELDLV
 Else
  Delete [DLVBD] Where NUMRPT=GNUMRPT
  If fstat=1 | fstat>5
   GOK = 0 : Call RSTA("DLVBD",num$(GNUMRPT)) From GLOCK : Goto AB_TR_DELDLV
  Endif
 Endif
 # Raz NUMDCL and AMTVAT
 Columns [HAE] (TYP,NUM,NUMDCL)
 For [HAE] Where NUMDCL=GNUMRPT
  Update [DAE] Where TYP=[F:HAE]TYP and NUM=[F:HAE]NUM and AMTVAT<>0 With AMTVAT=0
  If fstat
   GOK = 0 : Call FSTA("DAE") From GLOCK
   Break
  Endif
  Raz [F:HAE]NUMDCL
  Rewrite [F:HAE]
  If fstat
   GOK  = 0 : Call FSTA("HAE") From GLOCK
   Break
  Endif
 Next
 Columns [HAE]

 If GOK=0
  Goto AB_TR_DELDLV
 Endif
Commit
Return

######################################################################################
$TR_UPDREPORT
Trbegin [DLVB]
 ## Add the vat boxes whose type=Title or Total (VATBOX table) and validity period is ok, in the DCLVATBEL table
 For [VTB] Where VATFNC="DCLVATBEL" & LEG=CURLEG & (TYPBOX=1 or TYPBOX=3)
&&               (VLYSTR=[0/0/0] | VLYSTR<=[M:DIA]ENDDAT) & (VLYEND=[0/0/0] | VLYEND>=[M:DIA]STRDAT)
  Raz [DLVB]
  [F:DLVB]DCLVATTYP = 1
  [F:DLVB]NUMRPT = GNUMRPT
  [F:DLVB]GRPCPY = [M:DIA]GRU
  [F:DLVB]CPY    = [M:DIA]CPY
  [F:DLVB]FCY    = [M:DIA]FCY
  [F:DLVB]STRDAT = [M:DIA]STRDAT
  [F:DLVB]ENDDAT = [M:DIA]ENDDAT
  [F:DLVB]VATBOX = [F:VTB]VATBOX
  [F:DLVB]TYPBOX = [F:VTB]TYPBOX
  [F:DLVB]SIM    = [M:DIA]TYPGEN
  [F:DLVB]LIN    = [F:VTB]LIN
  [F:DLVB]REFTEX = [F:VTB]LEG+"~"+num$([F:VTB]LIN)
  [F:DLVB]VATFNC = [F:VTB]VATFNC
  If [F:DLVB]TYPBOX=3 : # Total
   [F:DLVB]AMT = func CALCFOR([F:VTB]CLCFOR)
   If ([F:VTB]CNDFOR = 2)
    # Balance must be positive
    If ([F:DLVB]AMT < 0) Then : [F:DLVB]AMT = 0 : Endif
   Elsif([F:VTB]CNDFOR = 3)
    # Balance must be negative
    If ([F:DLVB]AMT > 0) Then : [F:DLVB]AMT = 0 : Endif
   Endif
  Endif
  [F:DLVB]CUR    = [L]DEVLED
  Write [DLVB]
  If fstat
   GOK=0 : Call FSTA("DLVB") From GLOCK : Break
  Endif
 Next
 If GOK=0 : Rollback : Return : Endif
 ## Add the vat boxes whose type=detail (VATBOX table) and validity period is ok (VATBOXD table) which don't
 ## have any record in DCLVATBEL
 For [VTB] Where VATFNC="DCLVATBEL" & LEG=CURLEG & [VTB]TYPBOX=2
  Look [DLVB]DLVB0=[M:DIA]GRU;[M:DIA]CPY;1;GNUMRPT;[F:VTB]VATBOX
  If fstat
   OK = 1
   For [VTD] Where VATFNC="DCLVATBEL" & LEG=[F:CPY]LEG & VATBOX=[F:VTB]VATBOX
    OK = 0
    If ([F:VTD]VLYSTR=[0/0/0] | [F:VTD]VLYSTR<=[M:DIA]ENDDAT) & ([F:VTD]VLYEND=[0/0/0] | [F:VTD]VLYEND>=[M:DIA]STRDAT)
     OK = 1 : Break
    Endif
   Next
   If OK=1
    Raz [DLVB]
    [F:DLVB]DCLVATTYP = 1
    [F:DLVB]NUMRPT = GNUMRPT
    [F:DLVB]GRPCPY = [M:DIA]GRU
    [F:DLVB]CPY    = [M:DIA]CPY
    [F:DLVB]FCY    = [M:DIA]FCY
    [F:DLVB]STRDAT = [M:DIA]STRDAT
    [F:DLVB]ENDDAT = [M:DIA]ENDDAT
    [F:DLVB]VATBOX = [F:VTB]VATBOX
    [F:DLVB]TYPBOX = [F:VTB]TYPBOX
    [F:DLVB]SIM    = [M:DIA]TYPGEN
    [F:DLVB]AMT    = 0
    [F:DLVB]LIN    = [F:VTB]LIN
    [F:DLVB]REFTEX = [F:VTB]LEG+"~"+num$([F:VTB]LIN)
    [F:DLVB]VATFNC = [F:VTB]VATFNC
    [F:DLVB]CUR    = [L]DEVLED
    Write [DLVB]
    If fstat
     GOK=0 : Call FSTA("DLVB") From GLOCK : Break
    Endif
   Endif
  Endif
 Next
 If GOK=0 : Rollback : Return : Endif
Commit
Return

Funprog CALCFOR(FORMULE)
Value    Char    FORMULE
Local Decimal TOTAL
Local Char    CHAINE1(250), CHAINE2(250)
Local Integer I, SNSNEG
TOTAL = 0
CHAINE1 = vireblc(FORMULE,2)
Repeat I = instr(1,CHAINE1," ")
 Raz SNSNEG
 If I<>0
  CHAINE2 = vireblc(left$(CHAINE1,I-1),2)
  CHAINE1 = vireblc(right$(CHAINE1,I+1),2)
 Else
  CHAINE2 = CHAINE1
 Endif
 If left$(CHAINE2,1)="-"
  CHAINE2 = right$(CHAINE2,2)
  SNSNEG = 1
 Endif
 Read [DLVB1]DLVB0=[M:DIA]GRU;[M:DIA]CPY;1;GNUMRPT;CHAINE2
 If !fstat
  If SNSNEG
   TOTAL -= [F:DLVB1]AMT
  Else
   TOTAL += [F:DLVB1]AMT
  Endif
 Endif
Until I=0
End TOTAL

######################################################################################
$DECLARATION
 # Only VAT boxes created in the VATBOXD table (<=> that match TYPBOX=2 or TYPBOX=4)
Link [VTD] With [VTB]VTB1~=[F:VTD]VATFNC;[F:VTD]LEG;[F:VTD]VATBOX
& As [LNK_V]
& Where VATFNC="DCLVATBEL" & LEG=CURLEG

ERR_STOP = 0

[L]CRITERE="1=1"
If [M:DIA]FCY<>"" : [L]CRITERE-='& [F:FCY]FCY = "'+[M:DIA]FCY+'"' : Endif

For [CPY] Where ([M:DIA]CPY<>"" & CPY=[M:DIA]CPY) | ([M:DIA]GRU<>"" & find(CPY,TABCPY(1..INDCPY))) & CPYLEGFLG=2

 # Accounting date or  source document date ?
 Call PARAML([F:CPY]CPY,"DCLVATDAT",OPT) From ADOVAL

 # Load document type and tax code that are available for the legislation of the company
 If NBRLEG>1 & WLEG<>[F:CPY]CPYLEGFLG
  WLEG=[F:CPY]LEG
  Gosub LECPARAM_GTE
 Endif

 # general ledger
 Call SETCUR(1,[F:CPY]CPY,DEVLED)From CPTDIV # Runs Call SETMAINREF([F:CPY]CPY,GTYPGEN,GTYPANA) From CPTDIV
 Call LECPLAN([F:CPY]CPY,GTYPGEN,TCOA) From CPTDIV

 For [FCY]FCY1 Where LEGCPY=[F:CPY]CPY & FINFLG=2 & evalue(CRITERE)
  If [M:DIA]TRCFLG=2
   Call ECR_TRACE (mess(362,107,1)-[F:FCY]FCY-mess(26,113,1)-[F:CPY]CPY,0) From GESECRAN
  Endif

  # Issue number X3-82605 adding parameters [M:DIA]DETDCL,[M:DIA]TRCFLG,[M:DIA]GRU,[M:DIA]CPY,[M:DIA]FCY
  Call DCLVATDEB([F:CPY]CPY,[F:FCY]FCY,[M:DIA]STRDAT,[M:DIA]ENDDAT,[M:DIA]TYPGEN,OPT,
&                TTYPDEB,NBTYPDEB,TCOA,DEVLED,ERR_STOP,[M:DIA]DETDCL,[M:DIA]TRCFLG,[M:DIA]GRU,[M:DIA]CPY,[M:DIA]FCY) From DCLVATBOXDEB

  If GOK<1 : Break 2 : Endif
  If [M:DIA]TRCFLG=2
   Call ECR_TRACE (mess(363,107,1)-[F:FCY]FCY-mess(26,113,1)-[F:CPY]CPY,0) From GESECRAN
  Endif
 Next
Next
If ERR_STOP : GOK = 0 : Endif
If GOK<1 : Return : Endif
Return

######################################################################################
$TERMINE
Local Integer NBPAR1
Local Char    TBPAR1(20)(1..10) , TBVAL1(50)(1..10)
Local Char    NAM_PRT(GLONADP)

# Print the report if the declaration is run in simulation mode or in actual mode and no error occurs
If ([M:DIA]TYPGEN=2 | ([M:DIA]TYPGEN=1 & GOK=1))
 If GSERVEUR=1
  # Batch
  NBPAR1 = 0
  NBPAR1 +=1 : TBPAR1(NBPAR1) = "numrpt"        : TBVAL1(NBPAR1) = num$(GNUMRPT)
  NBPAR1 +=1 : TBPAR1(NBPAR1) = "detail_piece"  : TBVAL1(NBPAR1) = num$(2)
  NBPAR1 +=1 : TBPAR1(NBPAR1) = "impselections" : TBVAL1(NBPAR1) = num$(1)
  If [M:DIA]FCY<>""
   Call PARAML([M:DIA]FCY,"VATRPTBAT",NAM_PRT) From ADOVAL
  Elsif [M:DIA]CPY<>""
   Call PARAML([M:DIA]CPY,"VATRPTBAT",NAM_PRT) From ADOVAL
  Else
   Call PARAML("","VATRPTBAT",NAM_PRT) From ADOVAL
  Endif
  Call ETAT("DCLVATDEBBEL1",NAM_PRT,"",0,"",TBPAR1,TBVAL1) From AIMP3
 Else
  Call IMPRIME("DCLVATDEBBEL1","DCLVATBEL") From ETAT
 Endif
Endif

# Logfile
If !GSERVEUR & [M:DIA]TRCFLG=2
 TRA = 1
Else
 TRA = 0
Endif
Return

######################################################################################
$SORTIE
If dim(GNUMRPT)>0 : Kill GNUMRPT : Endif
# Unlock
For I=1 To NBLOCK
 Unlock =TSYMBOLE(I)
Next
Return

######################################################################################
# Selection of the request number
$SEL_TABLE
Case TABLE
 When "SELRPT"
  Default File [VRQT] : # View
  SIZCOL = 200
  NBCOL = 7
  COL(1) = "[F:VRQT]NUMRPT"
  TIT(1) = mess(38,114,1) : # Requête numéro
  FMTCOL(1) = "N:8"
  COL(2) = "[F:VRQT]GRPCPY"
  TIT(2) = mess(28,111,1) : # Groupe sociétés
  FMTCOL(2) = "K:5c"
  COL(3) = "[F:VRQT]CPY"
  TIT(3) = mess(2,116,1) : # Société
  FMTCOL(3) = "K:5c"
  COL(4) = "[F:VRQT]FCY"
  TIT(4) = mess(5,116,1) : # Site
  FMTCOL(4) = "K:5c"
  COL(5) = "[F:VRQT]STRDAT"
  TIT(5) = mess(369,107,1) : # Date début déclaration
  FMTCOL(5) = "DZz:DD[/]MM[/]YYYY"
  COL(6) = "[F:VRQT]ENDDAT"
  TIT(6) = mess(370,107,1) : # Date fin déclaration
  FMTCOL(6)= "DZz:DD[/]MM[/]YYYY"
  COL(7) = "[F:VRQT]CREUSR"
  TIT(7) = mess(37,133,1) : # Utilisateur
  FMTCOL(7) = "K:5B"
  DEFPAG=1
  SENS = 2
Endcase
Return

#############################################################################
## BATCH
#############################################################################
$OUVRE_BATCH
# Initializes the right window in a batch process
BCRIT = "DCLVAT"+PARAM(1)
Gosub OPEN_FIL
Gosub DECLARE
Return

######################################################################################
## DCLVATBEL screen
######################################################################################
Subprog C_TYPGEN(VALEUR)
Variable Integer VALEUR
Call GRISE(VALEUR)
Affzo [M:DIA]
End

Subprog AM_TYPGEN(VALEUR)
Variable Integer VALEUR
Call INI(VALEUR)
Call GRISE(VALEUR)
Affzo [M:DIA]
End

Subprog GRISE(LTYPGEN)
Value Integer LTYPGEN
Case LTYPGEN
  When 1 : # Actual
   Raz [M:DIA]NUMRPT,FCY
   Actzo [DIA]
   Grizo [DIA]NUMRPT, FCY
   If [M:DIA]TYPEXP = 1 : Grizo [DIA]VOLFIL : Else Actzo [DIA]VOLFIL : Endif
  When 2 : # Simulation
   Raz [M:DIA]NUMRPT, VOLFIL, TYPEXP
   Actzo [DIA]
   Grizo [DIA]NUMRPT, FLGFIL, TYPEXP, VOLFIL
  When 3 : # Regeneration
   Actzo [DIA]
   Effzo [DIA]GRU, CPY, FCY, STRDAT, ENDDAT, DETDCL
   Grizo [DIA]GRU, CPY, FCY, STRDAT, ENDDAT, DETDCL
   If [M:DIA]TYPEXP = 1 : Grizo [DIA]VOLFIL : Else Actzo [DIA]VOLFIL : Endif
Endcase
If [M:DIA]GRU<>"" : Effzo [M:DIA]CPY,FCY : Grizo [M:DIA]CPY,FCY : Endif
If [M:DIA]FLGFIL<>2
 Grizo [DIA]TYPEXP, VOLFIL
Else
 Actzo [DIA]TYPEXP
Endif
End

Subprog INI(LTYPGEN)
Value Integer LTYPGEN
Case LTYPGEN
  When 1 : # Actual
   [M:DIA]FLGFIL = 2 : # File generation
   [M:DIA]TYPEXP = 1 : Actzo [M:DIA]TYPEXP : # Client
   Raz [M:DIA]VOLFIL : Grizo [M:DIA]VOLFIL
   [M:DIA]TRCFLG = 2 : # Trace
   [M:DIA]DETDCL = 2 : # Detail of the declaration
  When 2 : # Simulation
   [M:DIA]FLGFIL = 1 : # File generation
   [M:DIA]TRCFLG = 2 : # Log file
   [M:DIA]DETDCL = 1 : # Detail of the declaration
  When 3 : # Regenération
   [M:DIA]FLGFIL = 2 : # File generation
   [M:DIA]TYPEXP = 1 : # Client
   Raz [M:DIA]VOLFIL : Grizo [M:DIA]VOLFIL
   [M:DIA]TRCFLG = 2 : # Log file
   [M:DIA]DETDCL = 1 : # Detail of the declaration
Endcase
If GBATCH & [M:DIA]FLGFIL=2 & [M:DIA]TYPEXP=1
 [M:DIA]TYPEXP=2 : Actzo [DIA]VOLFIL
Endif
End

######################################################################################
Subprog C_NUMRPT(VALEUR)
Variable Decimal VALEUR
If [M:DIA]TYPGEN=3
 If VALEUR=0
  GMESSAGE = mess(10,123,1) : # Zone obligatoire
  mkstat = 2 : End
 Endif

 Filter [DLVB] Where NUMRPT=VALEUR & DCLVATTYP=1 & SIM<>2 & TYPBOX=2
 Read [DLVB]DLVB0 First
 Filter [DLVB]
 If !fstat
  [M:DIA]GRU    = [F:DLVB]GRPCPY
  [M:DIA]CPY    = [F:DLVB]CPY
  [M:DIA]FCY    = [F:DLVB]FCY
  [M:DIA]STRDAT = [F:DLVB]STRDAT
  [M:DIA]ENDDAT = [F:DLVB]ENDDAT
  Affzo [M:DIA]
 Else
  GMESSAGE = mess(00119,00133,1) :# Requête inexistante
  mkstat = 2 : End
 Endif
Endif
End

######################################################################################
Subprog C_GRU(VALEUR)
Variable Char    VALEUR()

Local Char VALPAR(GLONCUR), DEVISE (GLONCUR)
Raz DEVISE
If !clalev([F:FGR]) : Local File FACGROUP [FGR] : Endif
If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif

Link [FCY] With [FGR]FGR1(1)=[F:FCY]FCY As [LNK] Where [F:FGR]CPY=VALEUR
For [LNK]FCY1(1)
 # Check that the BELVAT parameter is set to Yes for all the companies of the group.
 Raz VALPAR
 Call PARAML([F:FCY]FCY,"BELVAT",VALPAR) From ADOVAL
 If VALPAR<>num$(2)
  GMESSAGE = mess(231,107,1)
  mkstat = 2 : Break
 Endif
 # Check that the currency of the main general ledger is the same for all the companies of the group
 Raz VALPAR
 Call SETCUR(1,[F:FCY]LEGCPY,VALPAR) From CPTDIV
 If DEVISE=""
  DEVISE = VALPAR
 Elsif DEVISE<>VALPAR
  GMESSAGE = DEVISE-VALPAR-":"-mess(359,107,1)
  mkstat = 2 : Break
 Endif
Next
If mkstat=2 : End : Endif
If VALEUR<>""
 Effzo [M:DIA]CPY,FCY
 Grizo [M:DIA]CPY, FCY
Else
 Actzo [M:DIA]CPY
 If [M]TYPGEN=2 : # Simulation
  Actzo [M:DIA]FCY
 Endif
Endif
Affzo [M:DIA]CPY,FCY
End

######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Char VALPAR(1)
# Check that the BELVAT parameter is set to Yes for all the companies of the group.
If VALEUR<>""
## Check that the BELVAT parameter is set to Yes
 Raz VALPAR
 Call PARAML(VALEUR,"BELVAT",VALPAR) From ADOVAL
 If VALPAR<>num$(2)
  GMESSAGE = mess(231,107,1)
  mkstat = 2 : End
 Endif
Endif
If VALEUR="" & [M]GRU=""
 GMESSAGE =  mess(10,123,1)
 mkstat = 2 : End
Endif
End

######################################################################################
Subprog D_STRDAT(VALEUR)
Variable Date    VALEUR
VALEUR = gdat$(1,month(date$)-1,year(date$))
End

######################################################################################
Subprog D_ENDDAT(VALEUR)
Variable Date    VALEUR
VALEUR = eomonth([M]STRDAT)
End

######################################################################################
Subprog C_TRCFLG(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
 Effzo [M:DIA] DETDCL
 Grizo [M:DIA] DETDCL
Elsif VALEUR=2 & [M:DIA]TYPGEN<>3
 Actzo [M:DIA] DETDCL
Endif
Affzo [M:DIA]DETDCL
End

######################################################################################
Subprog C_FLGFIL(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Actzo [M:DIA]TYPEXP
 If [M:DIA]TYPEXP=2
  Actzo [M:DIA]VOLFIL
 Else
  Effzo [M:DIA]VOLFIL
  Grizo [M:DIA]VOLFIL
 Endif
Else
 Effzo [M:DIA]VOLFIL
 Grizo [M:DIA]TYPEXP,VOLFIL
Endif
Affzo [M:DIA]TYPEXP,VOLFIL
End

######################################################################################
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : mkstat = 2 : End
Endif

If VALEUR<>2
 Effzo [M:DIA]VOLFIL
 Grizo [M:DIA]VOLFIL
Else
 Actzo [M:DIA]VOLFIL
Endif
Affzo [M:DIA]VOLFIL
End

######################################################################################
Subprog AS_VOLFIL(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : End : Endif
If [M]GRU<>""
 Call PARAML([M]GRU,"BELVATFIL",VALEUR) From ADOVAL
Else
 Call PARAML([M]CPY,"BELVATFIL",VALEUR) From ADOVAL
Endif
If VALEUR=""
 VALEUR = "["+GDIRDEC+"]"
Endif
End

######################################################################################
Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FILDIRLOC,E_TYPE_FOLDER,GMESSAGE)
End

######################################################################################
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK
OK=1
If PARAM="BELVATFIL" and VALEUR<>""
 Local Char TMP(250)
 Gosub ENUM_VOLFIL_TYPE From ASYRSTO
 If func ASYRSTO.CTL_VOLFIL(2,VALEUR,TMP,E_TYPE_FOLDER,GMESSAGE)<>0
  OK = 0 : End
 Endif
Endif
End

######################################################################################
Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Call GRISE([M:DIA]TYPGEN)
End

