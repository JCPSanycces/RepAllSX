#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Shop floor tracking Inactive employees screen
#
######################################################################################
$ACTION

Case [L]ACTION
    When "DEBUT"    : Gosub DEBUT
    When Default
Endcase

Return

######################################################################################
$DEBUT

  Local Integer ITEAMNUM : ITEAMNUM = val(PARAM(1))
  Local Integer WMAX

  If !clalev([F:SFTTM2])  : Local File SFTTEM   [SFTTM2]  : Endif
  If !clalev([F:SFTTH])   : Local File SFTTEMH  [SFTTH]  : Endif

  Effzo [M:SFTI]

  nolign = 0

  WMAX = dim([M:SFTI]EMPNUM)

  [M:SFTI]TEAMNUM = ITEAMNUM

  Filter [SFTTM2] Where TEAMNUM = ITEAMNUM Order By Key SFTX = TEAMLIN
  For [SFTTM2]
    If nolign < WMAX
      [M:SFTI]EMPNUM(nolign) = [SFTTM2]EMPNUM
      [M:SFTI]STRDAT(nolign) = [SFTTM2]STRDAT
    Else
      Call ERREUR(mess(321,107,1)) From GESECRAN
      Goto CLEAN_EXIT
    Endif

    nolign += 1
  Next

  If nolign > 0
    nolign += 1
  Endif

  Filter [SFTTH] Where TEAMNUM = ITEAMNUM Order By Key SFTX = ENDDAT; CREDATTIM; TEAMNUM; EMPNUM; TEAMSEQ
  For [SFTTH]
    If nolign < WMAX
      [M:SFTI] = [F:SFTTH]
      [M:SFTI]EMPNUM(nolign) = [SFTTH]EMPNUM
      [M:SFTI]STRDAT(nolign) = [SFTTH]STRDAT
      [M:SFTI]ENDDAT(nolign) = [SFTTH]ENDDAT
    Else
      Call ERREUR(mess(321,107,1)) From GESECRAN
      Goto CLEAN_EXIT
    Endif

    nolign += 1
  Next

CLEAN_EXIT:
  LogicClose File [SFTTM2]
  LogicClose File [SFTTH]

  If nolign > 0
    [M:SFTI]NBLIG = nolign - 1
  Endif

  Diszo [M:SFTI]
  Affzo [M:SFTI]

Return

######################################################################################
Subprog AV_EMPDES(VALEUR)
Variable Char    VALEUR()

  VALEUR = func GETEMPDES([M:SFTI]EMPNUM(nolign-1))

End

####################################################################################
Funprog GETEMPDES(EMPNUM)
Value Integer EMPNUM
  Local Char EMPDESC(30)

  Read [F:TMA]TMA0=EMPNUM
  [L]EMPDESC = [F:TMA]EMPDES

End EMPDESC

