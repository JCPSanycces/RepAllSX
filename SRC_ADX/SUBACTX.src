#----------------------------------------------------------------------------#
Subprog B1_PARAM(VALEUR)
Variable Char    VALEUR()
Read [ADP]ADP1=VALEUR
If fstat : Raz [F:ADP] : Endif
Call OBJET("ADP",VALEUR,[F:ADP]CHAPITRE) From GOBJET
VALEUR = [F:ADP]PARAM
End

#----------------------------------------------------------------------------#
Subprog B2_PARAM(VALEUR)
Variable Char    VALEUR()
Read [ADP]ADP1=VALEUR
If fstat : Raz [F:ADP] : Endif
Call VISU("ADP",VALEUR,[F:ADP]CHAPITRE) From SUBAOP
End

Subprog CONT_CTX(VALEUR)
Variable Char VALEUR
Local Integer K
If VALEUR="" : End : Endif
Call STD(VALEUR,K)
If GADONIX<>2 & K
 Look [ACTX]ACTX0=VALEUR
 If fstat
  # Les variables globales commençant par $1$ sont réservées $2$/std
  GMESSAGE = func AFNC.MES2(mess(197,139,1),"[A-W]",mess(1,7804,1))
  mkstat = 2 : End
 Endif
Elsif GADONIX=2 & !K
 Look [ACTX]ACTX0=VALEUR
 If fstat
  # Les variables globales commençant par $1$ sont réservées $2$/spé
  GMESSAGE = func AFNC.MES2(mess(197,139,1),"X,Y,Z",mess(3,7804,1))
  mkstat = 2 : End
 Endif
Endif
Filter [ACTX] Where left$([ACTX]CODCTX,12)=left$(VALEUR,12) & [ACTX]CODCTX<>VALEUR
Read [ACTX]ACTX0 First
Filter [ACTX]
If !fstat
 # Les 12 premiers caractères sont déja utilisés par une autre variable globale
 GMESSAGE = VALEUR-":"-mess(127,139,1)-[F:ACTX]CODCTX
 mkstat = 2 : End
Endif
VALEUR = format$("KTv2:250X",VALEUR)
End

#----------------------------------------------------------------------------#
Subprog AM_CODTYP(VALEUR)
Variable Char    VALEUR()
[M]CODTYP = VALEUR
Gosub GRISE_TYPTYP
[M]TYPTYP = [F:ATY]TYPTYP
Affzo TYPTYP
End

Subprog C_LNGTYP(VALEUR)
Variable Char    VALEUR()
Local Decimal ENTIER , DECIM , CHIFFRE
If left$(VALEUR,1)<"0" or left$(VALEUR,1)>"9"
 End
Endif
CHIFFRE = val(num$(VALEUR))
If CHIFFRE=0 : mkstat=1 : End : Endif
Call LECTURE("ATY",[M]CODTYP,"") From CONTOBJ
ENTIER = int(CHIFFRE)
DECIM  = 10*(CHIFFRE-ENTIER)
While DECIM<>int(DECIM)
 DECIM *= 10
Wend
Case [F:ATY]TYPTYP
 When 7  : If DECIM<>0 | ENTIER>255            : mkstat = 1 : Endif : # Char
 When 9  : If DECIM<>0 | ENTIER>20             : mkstat = 1 : Endif : # Blob
 When 10 : If DECIM<>0 | ENTIER>20             : mkstat = 1 : Endif : # Clob
Endcase
If mkstat
 GMESSAGE = mess(111,123,1) : # Longueur incorrecte
Endif
End

#----------------------------------------------------------------------------#
Subprog AV_DES1(VALEUR)
Variable Char    VALEUR()
If [M]PARAM <> ""
 Read [ADP]ADP1=[M]PARAM
 Call TEXTE([F:ADP]NAM,VALEUR) From OBJDIV
Else
 VALEUR = ""
Endif
End

