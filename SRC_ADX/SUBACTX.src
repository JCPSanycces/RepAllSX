#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion objet ACTX
Raz GPILOBJ,GNBMASKOUV

Call OBJET("ACTX",GBIDC1,GBIDC2) From GOBJET
End


#----------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "EXEBOUT"     : Gosub EXEBOUT
 When "SETBOUT"     : Gosub SETBOUT
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "ANNULE"      : Gosub ANNULE
 When "AP_ANNULE"   : Gosub AP_ANNULE
 When "APRES_MOD"   : Gosub APRES_MOD
 When "APRES_CRE"   : Gosub APRES_CRE
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "RAZCRE"      : Gosub RAZCRE
Endcase
Return

#----------------------------------------------------------------------------#
$OUVRE
If clalev([F:ADP2])=0  : Local File ADOPAR  [ADP2]  : Endif
# ??? decide later: control chapter
# Gosub SET_CATEG
Return

#----------------------------------------------------------------------------#
$VERIF_CRE
$VERIF_MOD
Local Integer L_NEED_CHP
If [M]PUBFLG=2 & len([M]TEXTE)=0
 # Le descriptif doit être renseignée pour une variable publiée
 Call ERREUR(mess(196,139,1)) From GESECRAN
 OK = 0 : zonsui = "TEXTE" : Return
Endif

Call L_CHECKCOD([M]CODCTX, L_NEED_CHP)
If L_NEED_CHP = 1
 # check chapitre not empty
 If [M]CHAPTER = ""
  # Error: Veuillez mettre une valeur pour le chapitre du contexte
  Call ERREUR(mess(127,127,1)) From GESECRAN
  OK = 0 : zonsui = "CHAPTER" : Return
 Endif
 # check initialisation not empty
 If [M]PARAM = "" and [M]FORINI = "" and [M]TRTINI = ""
  # Error: Veuillez fournir un paramètre, une formule ou un traîtement d'initialisation.
  Call ERREUR(mess(133,127,1)) From GESECRAN
  OK = 0 : zonsui = "TRTINI" : Return
 Endif
Endif

Return
#----------------------------------------------------------------------------#


#----------------------------------------------------------------------------#
$LIENS
Call TEXTE([M:ACTX1]INTIT,[M:ACTX1]ZINTIT) From OBJDIV
[M]FORDIM0 = [F:ACTX]FORDIM(0)
[M]FORDIM1 = [F:ACTX]FORDIM(1)
Gosub GRISE_CHAMP
Gosub GRISE_TYPTYP
[M]TYPTYP = [F:ATY]TYPTYP
Gosub GRISE_FORDIM
Gosub GRISE_CHAPTER
Gosub GRISE_TRTINI
Gosub GRISE_FORINI
Gosub GRISE_PARAM
Gosub GRISE_CHGMOD
Call LECTURE_DOC("ACTX",[M]CODCTX,[M]TEXTE,K) From SUBADO
Return
#----------------------------------------------------------------------------#
$CREATION
$MODIF
# JPGA 27-27-2010 BUG-66277 : ECRIRE_DOC 2 parametres ajoutes : Module et Code activité
Call ECRIRE_DOC("ACTX",[M]CODCTX,[M]TEXTE,[M]ZINTIT,[M]MODULE,[M]CODACT) From SUBADO
Return
#----------------------------------------------------------------------------#
$ANNULE
Call EFFACE_DOC("ACTX",[L]CODE) From SUBADO
Return
#----------------------------------------------------------------------------#
$AP_ANNULE
Call REMOVE(APPLI,[M:ACTX1]CHAPTER) From ACTXVAL
#Call VALIDATION(APPLI,"",0)
#If [M:ACTX1]PARAM<>""
# Read [ADP]ADP1 = [M:ACTX1]PARAM
# Call VALCHAP(APPLI,[F:ADP]CHAPITRE,0)
#Endif

# CCL : For SCM : creation of meta hors transaction
Call TRACE_COR_ADO("ACTX",[L]CODE,"A") From AGENLIBA

Return
#----------------------------------------------------------------------------#
$INIMOD
$INICRE
[F:ACTX]FORDIM(0) = [M]FORDIM0
[F:ACTX]FORDIM(1) = [M]FORDIM1
Return
#----------------------------------------------------------------------------#
$EXEBOUT
Case BOUT
 When "V"
  Call AVERTIR(mess(131,127,1),OK) From GESECRAN
  If OK=1 : Return: Endif
  Call OUVRE_VLC(mess(295,123,1),mess(1,13,1),"") From GESECRAN
  Call OUVRE_TRACE(mess(295,123,1)) From LECFIC
  Call VALIDATION(nomap,"",0)
  Call FERME_VLC From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endcase
Return
#----------------------------------------------------------------------------#
$SETBOUT
If CLECUR=0 | REP<>"" |(!VERROU & (dim([L]MLOCK)<=0 or ![L]MLOCK))
 Call VIREBOUT(CHAINE,"V2") From GOBJET
Endif
Call STD([M:ACTX1]CODCTX,K)
If GADONIX<>2 & K
 Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
CHMEN += "4"
Return

Subprog STD(CODCTX,STD)
Value Char CODCTX
Variable Integer STD
STD = 0
If !find(left$(CODCTX,1),"X","Y","Z") # ???
 STD = 1
Endif
End

#----------------------------------------------------------------------------#
$APRES_CRE
# CCL : For SCM : creation of meta hors transaction
Call TRACE_COR_ADO("ACTX",[M]CODCTX,"C") From AGENLIBA

Return

$APRES_MOD
#Call VALIDATION(nomap,[M:ACTX1]CHAPTER,0)
#If [M:ACTX1]PARAM<>""
# Read [ADP]ADP1 = [M:ACTX1]PARAM
# Call VALCHAP(nomap,[F:ADP]CHAPITRE,0)
#Endif

# CCL : For SCM : creation of meta hors transaction
Call TRACE_COR_ADO("ACTX",[M]CODCTX,"M") From AGENLIBA
Return

#----------------------------------------------------------------------------#
$GRISE_TRTINI
If [M:ACTX1]FORINI<>"" or [M:ACTX1]PARAM<>""
 Effzo [ACTX1]TRTINI
 Grizo [ACTX1]TRTINI
Else
 Call STD([M:ACTX1]CODCTX,K)
 If GADONIX<>2 & K
  Diszo [ACTX1]TRTINI
 Else
  Actzo [ACTX1]TRTINI
 Endif
Endif
Return

#----------------------------------------------------------------------------#
$GRISE_TYPTYP
Read [ATY]CODTYP = [M:ACTX1]CODTYP
If !fstat & [F:ATY]LNGTYP=0 & ([F:ATY]TYPTYP=7 | [F:ATY]TYPTYP=10 | [F:ATY]TYPTYP=9)
 Actzo [ACTX1]LNGTYP
Else
 Effzo [ACTX1]LNGTYP
 Grizo [ACTX1]LNGTYP
Endif
Return

#----------------------------------------------------------------------------#
$GRISE_CHAPTER # ???
Local Integer OK2
# activate/deactivate field CHAPTER according to the CODE
Call L_CHECKCOD([M]CODCTX,OK2)
If OK2 = 1
 Actzo [M]CHAPTER
Else
 Effzo [M]CHAPTER
 Grizo [M]CHAPTER
Endif

#??? should this logic be kept?
#If [M:ACTX1]PARAM<>""
# Diszo [ACTX1]CHAPTER
#Else
# Call STD([M:ACTX1]CODCTX,K)
# If GADONIX<>2 & K
#  Diszo [ACTX1]CHAPTER
# Else
#  Actzo [ACTX1]CHAPTER
# Endif
#Endif
Return
#----------------------------------------------------------------------------#
$GRISE_FORINI
If [M]TRTINI<>"" or [M]PARAM<>""
 Effzo [ACTX1]FORINI
 Grizo [ACTX1]FORINI
Else
 Actzo [ACTX1]FORINI
Endif
Return
#----------------------------------------------------------------------------#
$GRISE_PARAM
If [M]FORINI<>"" or [M]TRTINI<>""
 Effzo [ACTX1]PARAM
 Grizo [ACTX1]PARAM
Else
 Actzo [ACTX1]PARAM
Endif
Return
#----------------------------------------------------------------------------#
$GRISE_FORDIM
If [M]PARAM<>""
 Effzo [ACTX1]FORDIM0,FORDIM1
 Grizo [ACTX1]FORDIM0,FORDIM1
 Grizo [ACTX1]FORDIM0,FORDIM1
Elsif [M]FORDIM0<>""
 Actzo [ACTX1]FORDIM0,FORDIM1
Else
 Actzo [ACTX1]FORDIM0
 Effzo [ACTX1]FORDIM1
 Grizo [ACTX1]FORDIM1
Endif
Return
#----------------------------------------------------------------------------#
$GRISE_CHAMP
Call STD([M:ACTX1]CODCTX,K)
If GADONIX<>2 & K
 Diszo [ACTX1]CODTYP
 Diszo [ACTX1]30
 Diszo [ACTX1]35
Else
 Actzo [ACTX1]CODTYP
 Actzo [ACTX1]30
 Actzo [ACTX1]35
Endif
Return
#----------------------------------------------------------------------------#
$GRISE_CHGMOD
If [M]PARAM<>"" or[M]FORINI<>"" or [M]TRTINI<>""
 Actzo [ACTX1]CHGMOD
Else
 Effzo [ACTX1]CHGMOD
 Grizo [ACTX1]CHGMOD
Endif
Return
#----------------------------------------------------------------------------#
$SET_CATEG # ??? decide later: control chapter
Local Char    CATEGUSR(8) , CATEGVAR(8) , CATEGADX(8)
CATEGUSR = "USR" # ??? ASUP AFOLD AUSR APAR...
CATEGVAR = "PAR"
CATEGADX = "ADX"
Return
#----------------------------------------------------------------------------#
$SEL_TABLE
Case TABLE
 When "SELACTX"
  CRITERE = 'CHAPTER="'+[M]CHAPTER+'"'
  OBJET   = "AG2"
  START   = "RANG"
 When "SELACTX2"
  CRITERE = 'CHAPTER<>""'
  OBJET   = "AG3"
 Endcase
Return

#----------------------------------------------------------------------------#
$FIN_LISTE
If VALEUR <> ""
 [M:ACTX1]CHAPTER = vireblc(VALEUR,3)
Endif
Return
#----------------------------------------------------------------------------#
Subprog GENDOS(APPLI)
Value Char    APPLI
Call ECR_TRACE(mess(14,123,1)-mess(295,123,1)-mess(178,126,1)-APPLI,0) From GESECRAN : # Validation Variables contextes
Call VALIDATION(APPLI,"",1)
End
#----------------------------------------------------------------------------#
Subprog PATCH(APPLI)
Value Char    APPLI
Call GENDOS(APPLI)
End

#----------------------------------------------------------------------------#
Subprog VALIDATION(DOSSIER,CHAPTER,SILENCE)
Value Char    DOSSIER
Value Char    CHAPTER
Value Integer SILENCE
Local Integer OK
Call VALIDATION(DOSSIER,CHAPTER,SILENCE) From ACTXVAL
End

#----------------------------------------------------------------------------#
Subprog VALCHAP(DOSSIER,CHAP,SILENCE)
Value Char    DOSSIER
Value Char    CHAP
Value Integer SILENCE
Call VALIDATION(DOSSIER,CHAP,SILENCE) From ACTXVAL
End
#----------------------------------------------------------------------------#
#----------------------------------------------------------------------------#
#----------------------------------------------------------------------------#
#----------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File ACONTEXT  [ACTX1]
 Local File ATEXTE    [ATX1]
 Local File ADOCUMENT [ADO1]
 Local File ADOCCLB   [ADH1]
Else
 Local File =[M]DOSORG+".ACONTEXT"  [ACTX1]
 Local File =[M]DOSORG+".ATEXTE"    [ATX1]
 Local File =[M]DOSORG+".ADOCUMENT" [ADO1]
 Local File =[M]DOSORG+".ADOCCLB"   [ADH1]
Endif
If [M]DOSDES=nomap
 Local File ACONTEXT  [ACTX2]
 Local File ATEXTE    [ATX2]
 Local File ADOCUMENT [ADO2]
 Local File ADOCCLB   [ADH2]
Else
 Local File =[M]DOSDES+".ACONTEXT"  [ACTX2]
 Local File =[M]DOSDES+".ATEXTE"    [ATX2]
 Local File =[M]DOSDES+".ADOCUMENT" [ADO2]
 Local File =[M]DOSDES+".ADOCCLB"   [ADH2]
Endif
OK = 1
If GTRACE=""
 Read [ACTX2]ACTX0 = TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [ACTX1], [ATX1], [ACTX2], [ATX2]
Close Local File [ADO1], [ADH1], [ADO2], [ADH2]
Return

$TR_COP
GOK = 1
Trbegin [ACTX2] , [ATX2]
 Delete [ACTX2] Where CODCTX=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACONTEXT" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ACTX2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ACTX1]ACTX0 Where CODCTX=TABLE
  [F:ACTX2] = [F:ACTX1]
  Call COPTEXTE([F:ACTX1]INTIT,[F:ACTX2]INTIT) From OBJDIV
  If GOK<1 : Break : Endif
  If dim([F:ACTX2]UPDUSR)>0 : [F:ACTX2]UPDUSR = GUSER : Endif
  If dim([F:ACTX2]UPDDAT)>0 : [F:ACTX2]UPDDAT = date$ : Endif
  If dim([F:ACTX2]UPDTIM)>0 : [F:ACTX2]UPDTIM = time  : Endif
  Write [ACTX2]
  If fstat
   GOK=0 : Call FSTA("ACTX2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 Call COPIE_DOC("ACTX",TABLE,[M]DOSORG,[M]DOSDES) From SUBADO
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif


$RAZCRE
Gosub GRISE_CHGMOD
Return

#----------------------------------------------------------------------------#
#----------------------------------------------------------------------------#
#----------------------  SUBPROG DE L'ECRAN ACTX1  ---------------------------#
#----------------------------------------------------------------------------#
Subprog C_PARAM(VALEUR)
Variable Char    VALEUR()
If [L]VALEUR<>""
 Read [ADP]ADP1 = VALEUR
 If fstat
  GMESSAGE = VALEUR-":"-mess(11,133,1) :  # Paramètre inexistant
  mkstat=2 : End
 Else
  If [ADP]NIVDEF<> 1 and [ADP]NIVDEF<> 4
   GMESSAGE = VALEUR-":"-mess(135,127,1) :  # paramètre n'est pas définit au niveau de dossier/utilisateur.
   mkstat=2 : End
  Else
   Read [ATY]CODTYP = [M:ACTX1]CODTYP
   Case [F:ADP]TYPVAL
    When 1   : If [F:ATY]TYPTYP<>7                 : Gosub MESS_PARAM : mkstat = 2 : End : Endif
    When 2,4 : If !find([F:ATY]TYPTYP,1,2,3,4,5,6) : Gosub MESS_PARAM : mkstat = 2 : End : Endif
    When 3   : If [F:ATY]TYPTYP<>8                 : Gosub MESS_PARAM : mkstat = 2 : End : Endif
   Endcase
  Endif
 Endif
 Read [ACTX]ACTX2  = VALEUR
 If !fstat  & [M:ACTX1]CODCTX<>[F:ACTX]CODCTX
  GMESSAGE = VALEUR-":"-mess(134,127,1)-[F:ACTX]CODCTX : # Ce paramètre est utilisé par le code context xxx
  mkstat=2 : End
 Endif
Endif
End

$MESS_PARAM
GMESSAGE = mess(14,133,1) : # Type de données incorrect
GMESSAGE += "\|"+mess(293,139,1)-"("-mess([F:ATY]TYPTYP,30,1)-") <>" : # Variables globales
GMESSAGE -= mess(7,42,1)-"("-mess([F:ADP]TYPVAL ,11,1)-")" : # Paramètres
Return

Subprog AM_TEXTE(VALEUR)
Variable Clbfile VALEUR
Local Integer OK
Call MODIF_DOC("ACTX",[M]CODCTX,OK) From SUBADO
If !OK : VALEUR = [M]TEXTE : Affzo TEXTE : Endif
End

