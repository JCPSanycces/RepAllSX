## Etiquette ajoutée par le superviseur (écran ACTX1) 09/03/2012 16:10:20 (KUYAN)
######################################################################################
Subprog AM_FORINI(VALEUR)
Variable Char    VALEUR()
Local Integer K
[M]FORINI = VALEUR
Gosub GRISE_TRTINI
Gosub GRISE_PARAM
Gosub GRISE_CHGMOD
If VALEUR <> "" : [M]CHGMOD = 2 : Endif
Affzo [M]CHGMOD
End

Subprog AM_TRTINI(VALEUR)
Variable Clbfile VALEUR
Local Integer K
[M]TRTINI = VALEUR
Gosub GRISE_FORINI
Gosub GRISE_PARAM
Gosub GRISE_CHGMOD
If VALEUR <> "" : [M]CHGMOD = 2 : Endif
Affzo [M]CHGMOD
End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran ACTX1) 13/07/2012 14:28:38 (KUYAN)
######################################################################################
Subprog S_PARAM(VALEUR)
Variable Char    VALEUR()
 Local Integer NBFLD, CHOI,I,OK
 Local Char    TEX(GLONDES)(1..3000,1..5) , TIT(GLONDES)(0..5)
 Local File ADOPAR [ADP]

 For [ADP]
  If [F:ADP]NIVDEF = 1 or [F:ADP]NIVDEF = 4
   NBFLD+= 1
   TEX(NBFLD,1) = [F:ADP]PARAM
   Call TEXTE([F:ADP]NAM,TEX(NBFLD,2)) From OBJDIV
   TEX(NBFLD,3) = [F:ADP]CHAPITRE
   TEX(NBFLD,4) = [F:ADP]GRPPAR
   TEX(NBFLD,5) = mess([F:ADP]NIVDEF,987,1)
  Endif
 Next

 CHOI = 0
 TIT(0) = mess(8,31,1) # Sélection
 TIT(1) = mess(143,105,1) # Paramètre
 TIT(2) = mess(30,109,1)      # Intitulé
 TIT(3) = mess(78,100,1) # Chapitre
 TIT(4) = mess(73,9953,1) # Groupe
 TIT(5) = mess(51,101,1) # Niveau de définition
 Call SAITEX_COL_MAX(NBFLD,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0
  VALEUR = TEX(CHOI,1)
 Endif

 Close Local File [ADP]
End




