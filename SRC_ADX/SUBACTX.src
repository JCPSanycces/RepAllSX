## Etiquette ajoutée par le superviseur (écran ACTX1) 01/03/2012 13:58:14 (KUYAN)
######################################################################################

#----------------------------------------------------------------------------#
Subprog C_CODCTX(VALEUR)
Variable Char    VALEUR()
#Call CONT_CTX(VALEUR)
End

#----------------------------------------------------------------------------#
Subprog AM_CODCTX(VALEUR)
Variable Char    VALEUR()
Local Char L_CODCTX
Local Integer OK
Local Integer K

# temporary internal function
If clalev([F:AGB])=0 : Local File AGLOBVAR [AGB] : Endif
If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif

Read [ACTX]ACTX0 = VALEUR
If !fstat : End : Endif

# activate/deactivate field CHAPTER according to the CODE
Call L_CHECKCOD(VALEUR,OK)
If OK = 1
 Actzo [M]CHAPTER
Else
 Effzo [M]CHAPTER
 Grizo [M]CHAPTER
Endif

Call L_LAST_RANG([M]CHAPTER, [M]RANG)

L_CODCTX = "G"+VALEUR
#L_CODCTX = VALEUR
Read [AGB]AGB0 = L_CODCTX
If !fstat
 Call AVERTIR(func AFNC.MES1(mess(128,127,1), L_CODCTX),OK) From GESECRAN
 If OK=1 : End: Endif
 [M]=[F:AGB]
 [M]CODCTX = VALEUR
 [M]FORDIM0 = [F:AGB]FORDIM(0)
 [M]FORDIM1 = [F:AGB]FORDIM(1)
 Effzo [M]CHAPTER
 Call L_LAST_RANG([M]CHAPTER, [M]RANG)
 Call TEXTE([M]INTIT,[M]ZINTIT) From OBJDIV
 Read [ATY]CODTYP = [M]CODTYP
 If !fstat
  [M]TYPTYP = [F:ATY]TYPTYP
 Endif
 Call LECTURE_DOC("ACTX",[M]CODCTX,[M]TEXTE,OK) From SUBADO
 Gosub GRISE_CHAMP
 Gosub GRISE_TYPTYP
 Gosub GRISE_FORDIM
 Gosub GRISE_CHAPTER
 Gosub GRISE_TRTINI
 Affzo [M]
 If [M]FORDIM0<>"" or [M]FORDIM1 <>""
  Call AVERTIR(mess(129,127,1),OK) From GESECRAN
 Endif
Endif
Affzo [M]
End

#----------------------------------------------------------------------------#
Subprog B1_CODCTX(VALEUR)
Variable Char    VALEUR()
 Local Integer NBFLD, CHOI,I,OK
 Local Char    TEX(GLONDES)(1..3000,1..4) , TIT(GLONDES)(0..4)
 Local File AGLOBVAR [AGB]

 For [F:AGB]AGB0
  NBFLD+= 1
  TEX(NBFLD,1) = [F:AGB]CODVAR
  Call TEXTE([F:AGB]INTIT,TEX(NBFLD,2)) From OBJDIV
  TEX(NBFLD,3) = [F:AGB]TRTSTD
  TEX(NBFLD,4) = mess([AGB]MODULE,14,1)
 Next

 CHOI = 0
 TIT(0) = mess(8,31,1) # Sélection
 TIT(1) = mess(37,100,1) # Code
 TIT(2) = mess(30,109,1)      # Intitulé
 TIT(3) = mess(1,13,1) # Traitement
 TIT(4) = mess(58,105,1) # Module

 Call SAITEX_COL_MAX(NBFLD,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0
  VALEUR = right$(TEX(CHOI,1),2)
  Read [ACTX]ACTX0 = VALEUR
  If !fstat
   Call AVERTIR(mess(130,127,1),OK) From GESECRAN
  Endif
 Endif

 Close Local File [AGB]
End




######################################################################################
Subprog L_LAST_RANG(L_CHAPTER, RES_RANG)
Value Char L_CHAPTER
Variable Decimal RES_RANG
 Filter [ACTX] Where CHAPTER = L_CHAPTER
 Read [ACTX]ACTX1 Last
 If !fstat
  RES_RANG = [F:ACTX]RANG+10
 Else
  RES_RANG = 10
 Endif
 Filter [ACTX]
End



Subprog AM_CHAPTER(VALEUR)
Variable Char    VALEUR()
Call L_LAST_RANG(VALEUR,[M]RANG)
End


Subprog C_CHAPTER(VALEUR)
Variable Char    VALEUR()
If VALEUR = "ACACHE" # since we have a class ACONTEXTACACHE
 GMESSAGE = VALEUR-":"-mess(140,143,1) :  # Code chapitre interdit.
 mkstat=2 : End
Endif
End

######################################################################################
Subprog L_CHECKCOD(CODE, RES_NEED_CHP) # also used in SUBADP
Value Char CODE
Variable Integer RES_NEED_CHP
 Raz RES_NEED_CHP
 # for code other than "USER","LAN","FLOD", CHAPRER is mandatory
 If CODE <> "USER" and CODE <> "LAN" and CODE <> "AFOLDER" and CODE <> "LOGIN" and CODE <> "LANISO"
&   & CODE<>"ASOLUTION" and CODE <> "APRFCOD" and CODE <> "ALLACS"
  RES_NEED_CHP = 1
 Endif
End
