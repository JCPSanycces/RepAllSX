# Classe GRPCOLL_L_CPY
#--Test

Call TEST()

#Infbox "Sortie sous-pro :"-num$(freeheap/1024)
End

Subprog TEST
Local Integer  RET,I

#Infbox "Mémoire avant :"-num$(freeheap/1024)

Local Instance GROUPES Using C_GRPCOLL

GROUPES = NewInstance [XXX] With C_GRPCOLL

RET = fmet GROUPES.GROUPADD("SAFT")
RET = fmet GROUPES.GROUPADD("MIX")

#For I=1 To maxtab(GROUPES.L_FCY)
#	Infbox "FCY="+GROUPES.L_FCY(I).FCY-"ASTALIN="+num$(GROUPES.L_FCY(I).ASTALIN)
#Next
#For I=1 To maxtab(GROUPES.L_CPY)
#	Infbox "CPY="+GROUPES.L_CPY(I).CPY-"ASTALIN="+num$(GROUPES.L_CPY(I).ASTALIN)
#Next
#For I=1 To maxtab(GROUPES.L_LEG)
#	Infbox "LEG="+GROUPES.L_LEG(I).LEG-"ASTALIN="+num$(GROUPES.L_LEG(I).ASTALIN)
#Next

FreeInstance =GROUPES.AllocGrp
#Infbox "Mémoire après FreeInstance :"-num$(freeheap/1024)
End
#########################################################################################
#----------------------------------------------------------------------------------------
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#  Case [L]CURPTH
#     When ""
#        Case [L]AEVENT
#        Endcase
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "GROUPADD"				 : Gosub GROUPADD
  Endcase
Return
