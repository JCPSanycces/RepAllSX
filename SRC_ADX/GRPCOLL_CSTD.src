#----------------------------------------------------------------------------------------
$PROPERTIES

#  Case CURPTH
#    When ""
#      Case CURPRO
#        When Default
#      Endcase
#    Endcase

Return
#########################################################################################
$GROUPADD
  Local Integer WRET
  Local Integer NBFCY, NBCPY, NBLEG
  Local Integer I,W, IJ
	Local Integer TROUVE

  If GROUPE=""
  	#WRET = fmet this.ASETERROR("","",[V]CST_AINFO) :#--message ? "Le groupe doit être fourni en paramètre" ?
  	ASTATUS = [V]CST_AINFO
  	Return
  Endif

	#--Est-ce que le groupe est déjà dans la collection ?
	If find(GROUPE,this.GRP(1..maxtab(this.GRP)).GRP)>0 : Return : Endif

	I = fmet this.ADDLINE("GRP",[V]CST_ALASTPOS)
	If I>0
		WRET = fmet this.GRP(I).AREAD(GROUPE)
		If WRET
			#--Le message est déjà positionné par le AREAD
			#WRET= fmet this.ASETERROR("","Erreur à l'ajout dans la collection du groupe :"-GROUPE,[V]CST_AINFO)
			#ASTATUS = [V]CST_AINFO
			Return
		Endif
	Endif
	#--Un fois le groupe ajouté, on supprime le/les site(s), la/les société(s) et la/les législation(s)
	#--non communes avec les autres groupes, (si pas dans les collections)

	#--Chargement de la collection L_CPY pour le premier groupe
	If maxtab(this.GRP)=1
  	For IJ = 1 To maxtab(this.GRP(1).L_CPY)
  		If this.GRP(1).L_CPY(IJ)<>null and find(this.GRP(1).L_CPY(IJ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
    		NBCPY = fmet this.ADDLINE("L_CPY",[V]CST_ALASTPOS)
    		If NBCPY>0
    			this.L_CPY(NBCPY).CPY    = this.GRP(1).L_CPY(IJ).CPY
    			this.L_CPY(NBCPY).CPYLEG = this.GRP(1).L_CPY(IJ).CPYLEG
    		Endif
  		Endif
  	Next IJ
	Endif

	#--Chargement de la collection L_FCY pour le premier groupe
	If maxtab(this.GRP)=1
  	For IJ = 1 To maxtab(this.GRP(1).L_FCY)
  		If this.GRP(1).L_FCY(IJ)<>null and find(this.GRP(1).L_FCY(IJ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
    		NBFCY = fmet this.ADDLINE("L_FCY",[V]CST_ALASTPOS)
    		If NBFCY>0
      		this.L_FCY(NBFCY).FCY 			= this.GRP(1).L_FCY(IJ).FCY
      		this.L_FCY(NBFCY).FCYCPY 		= this.GRP(1).L_FCY(IJ).FCYCPY
      		this.L_FCY(NBFCY).FCYCPYLEG = this.GRP(1).L_FCY(IJ).FCYCPYLEG
      	Endif
  		Endif
  	Next IJ
	Endif

	#--Chargement de la collection L_LEG pour le premier groupe
	If maxtab(this.GRP)=1
  	For IJ = 1 To maxtab(this.GRP(1).L_LEG)
  		If this.GRP(1).L_LEG(IJ)<>null and find(this.GRP(1).L_LEG(IJ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
    		NBLEG = fmet this.ADDLINE("L_LEG",[V]CST_ALASTPOS)
    		If NBLEG>0
    			this.L_LEG(NBLEG).LEG = this.GRP(1).L_LEG(IJ).LEG
    		Endif
  		Endif
  	Next IJ
	Endif

	If maxtab(this.GRP)>1
  	#--Il faut s'assurer que les sociétés déjà existantes dans this.L_CPY, sont toutes dans le groupe que l'on rajoute
  	For IJ= 1 To maxtab(this.L_CPY)
  		If this.L_CPY(IJ)<>null and find(this.L_CPY(IJ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  			W=0
      	TROUVE = sigma(1,maxtab(this.GRP(I).L_CPY),
&				(indcum)*( this.GRP(I).L_CPY(indcum).CPY=this.L_CPY(IJ).CPY & find(this.GRP(I).L_CPY(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 )
&								&( W=0 and sigma(W=1,1,1)) )
    		If TROUVE = 0
    			#--On la supprime, car pas commune
    			WRET = fmet this.ADELLINE("L_CPY",this.L_CPY(IJ).AORDER)
    		Endif

    	Endif
  	Next

  	#--Il faut s'assurer que les sites déjà existants dans this.L_FCY, sont tous dans le groupe que l'on rajoute
  	For IJ= 1 To maxtab(this.L_FCY)
  		If this.L_FCY(IJ)<>null and find(this.L_FCY(IJ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  			W=0
      	TROUVE = sigma(1,maxtab(this.GRP(I).L_FCY),
&				(indcum)*( this.GRP(I).L_FCY(indcum).FCY=this.L_FCY(IJ).FCY & find(this.GRP(I).L_FCY(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 )
&								&( W=0 and sigma(W=1,1,1)) )
    		If TROUVE = 0
    			#--On le supprime, car pas commun
    			WRET = fmet this.ADELLINE("L_FCY",this.L_FCY(IJ).AORDER)
    		Endif

  		Endif
  	Next

  	#--Il faut s'assurer que les législations déjà existantes dans this.L_LEG, sont toutes dans le groupe que l'on rajoute
  	For IJ= 1 To maxtab(this.L_LEG)
  		If this.L_LEG(IJ)<>null and find(this.L_LEG(IJ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  			W=0
      	TROUVE = sigma(1,maxtab(this.GRP(I).L_LEG),
&				(indcum)*( this.GRP(I).L_LEG(indcum).LEG=this.L_LEG(IJ).LEG & find(this.GRP(I).L_LEG(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 )
&								&( W=0 and sigma(W=1,1,1)) )
    		If TROUVE = 0
    			#--On la supprime, car pas commune
    			WRET = fmet this.ADELLINE("L_LEG",this.L_LEG(IJ).AORDER)
    		Endif
  		Endif
  	Next
	Endif

Return

$GROUPADD_OLD
  Local Integer WRET
  Local Integer NBFCY, NBCPY, NBLEG
  Local Integer I,W, IJ
	Local Integer TROUVE

  If GROUPE=""
  	#WRET = fmet this.ASETERROR("","",[V]CST_AINFO) :#--message ? "Le groupe doit être fourni en paramètre" ?
  	ASTATUS = [V]CST_AINFO
  	Return
  Endif

	#--Est-ce que le groupe est déjà dans la collection ?
	If find(GROUPE,this.GRP(1..maxtab(this.GRP)).GRP)>0 : Return : Endif

	I = fmet this.ADDLINE("GRP",[V]CST_ALASTPOS)
	If I>0
		WRET = fmet this.GRP(I).AREAD(GROUPE)
		If WRET
			#--Le message est déjà positionné par le AREAD
			#WRET= fmet this.ASETERROR("","Erreur à l'ajout dans la collection du groupe :"-GROUPE,[V]CST_AINFO)
			#ASTATUS = [V]CST_AINFO
			Return
		Endif
	Endif
	#--Un fois le groupe ajouté, on ajoute la/les société(s) et la/les législation(s)
	#--communes avec les autres groupes, si pas encore dans la collection

	#--Chargement de la collection L_CPY
	For IJ = 1 To maxtab(this.GRP(I).L_CPY)
		If this.GRP(I).L_CPY(IJ)<>null and find(this.GRP(I).L_CPY(IJ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0

  		#--La société est-elle dans la collection ?
  		#--Le "find" renvoie des valeurs indépendemment de ASTALIN !!!
  		#--Passage par un sigma
    	#If find(this.GRP(I).L_CPY(IJ).CPY, this.L_CPY(1..maxtab(this.L_CPY)).CPY)=0
    	W=0
    	TROUVE = sigma(1,maxtab(this.L_CPY),
&											(indcum)*((this.L_CPY(indcum).CPY=this.GRP(I).L_CPY(IJ).CPY) & (find(this.L_CPY(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0)))
#&											*(W=0 and sigma(W=1,1,1)))
			If TROUVE=0
    		#--Si elle ne l'est pas, on l'ajoute si présente dans les sociétés L_CPY de tous les autres groupes
    		#--Là il faut s'accrocher...
  #  		TROUVE = find(this.GRP(I).L_CPY(IJ).CPY, this.GRP(1..maxtab(this.GRP)).L_CPY(1..maxtab(this.GRP(IJK).L_CPY)).CPY)
    		TROUVE = 0
    		If maxtab(this.GRP)>1
      		For IJK = 1 To maxtab(this.GRP)
      			If this.GRP(IJK)<>null and find(this.GRP(IJK).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      				#--Passage par sigma
      				#TROUVE = find(this.GRP(I).L_CPY(IJ).CPY, this.GRP(IJK).L_CPY(1..maxtab(this.GRP(IJK).L_CPY)).CPY)
      				W=0
      				TROUVE = sigma(1,maxtab(this.GRP(IJK).L_CPY),
&							(indcum)*((this.GRP(IJK).L_CPY(indcum).CPY=this.GRP(I).L_CPY(IJ).CPY)& (find(this.GRP(IJK).L_CPY(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0)))
#&							*(W=0 and sigma(W=1,1,1)))
      				If TROUVE = 0 : Break : Endif
      			Endif
    			Next IJK
    		Else
    			#--Nous avons un seul groupe, donc on ajoute
    			TROUVE=1
    		Endif
  			If TROUVE
      		NBCPY = fmet this.ADDLINE("L_CPY",[V]CST_ALASTPOS)
      		If NBCPY>0
      			this.L_CPY(NBCPY).CPY    = this.GRP(I).L_CPY(IJ).CPY
      			this.L_CPY(NBCPY).CPYLEG = this.GRP(I).L_CPY(IJ).CPYLEG
      		Endif
      	Endif

  		Endif

		Endif
	Next IJ

	#--Maintenant il faut s'assurer que les sociétés déjà existantes dans this.L_CPY, sont toutes dans le groupes que l'on rajoute
	#--Elles sont surement dans les groupes ajoutés avant...
	For IJ= 1 To maxtab(this.L_CPY)
		If this.L_CPY(IJ)<>null and find(this.L_CPY(IJ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
			#--Passage par sigma
  		#TROUVE = find(this.L_CPY(IJ).CPY, this.GRP(I).L_CPY(1..maxtab(this.GRP(I).L_CPY)).CPY)
    	W=0
    	TROUVE = sigma(1,maxtab(this.GRP(I).L_CPY),
&				(indcum)*((this.GRP(I).L_CPY(indcum).CPY=this.L_CPY(IJ).CPY) & (find(this.GRP(I).L_CPY(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0)))
#&				*(W=0 and sigma(W=1,1,1)))
  		If TROUVE = 0
  			#--On la supprime, car pas commune
  			WRET = fmet this.ADELLINE("L_CPY",this.L_CPY(IJ).AORDER)
  			#--On supprime également la législation
  			#--Passage par sigma
  			#TROUVE = find(this.L_CPY(IJ).CPYLEG, this.GRP(I).L_LEG(1..maxtab(this.GRP(I).L_LEG)).LEG)
    		W=0
    		TROUVE = sigma(1,maxtab(this.L_LEG),
&					(indcum)*((this.L_LEG(indcum).LEG=this.L_CPY(IJ).CPYLEG)& (find(this.L_LEG(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0)))
#&					*(W=0 and sigma(W=1,1,1)))
  			If TROUVE
    			#--On la supprime, car pas commune
    			WRET = fmet this.ADELLINE("L_LEG",this.L_LEG(TROUVE).AORDER)
				Endif
  		Endif
  	Endif
	Next

	#--Chargement de la collection L_FCY
	For IJ = 1 To maxtab(this.GRP(I).L_FCY)

		If this.GRP(I).L_FCY(IJ)<>null and find(this.GRP(I).L_FCY(IJ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0

  		#--La société est-elle dans la collection ?
  		#--Passage par sigma
#    	If find(this.GRP(I).L_FCY(IJ).FCY,this.L_FCY(1..maxtab(this.L_FCY)).FCY)=0 and
#& 		   find(this.GRP(I).L_FCY(IJ).FCYCPY, this.L_CPY(1..maxtab(this.L_CPY)).CPY)>0
    	W=0
    	TROUVE = sigma(1,maxtab(this.L_FCY),
&											(indcum)*((this.L_FCY(indcum).FCY=this.GRP(I).L_FCY(IJ).FCY)& (find(this.L_FCY(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0)))
#&											*(W=0 and sigma(W=1,1,1)))
			If TROUVE=0
    		W=0
    		TROUVE = sigma(1,maxtab(this.L_CPY),
&											(indcum)*((this.L_CPY(indcum).CPY=this.GRP(I).L_FCY(IJ).FCYCPY)& (find(this.L_CPY(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0)))
#&											*(W=0 and sigma(W=1,1,1)))
				If TROUVE>0

      		#--Si elle ne l'est pas, on l'ajoute si présente dans les sociétés L_CPY de tous les autres groupes
    #  		TROUVE = find(this.GRP(I).L_FCY(IJ).FCY, this.GRP(1..maxtab(this.GRP)).L_FCY(1..maxtab(this.GRP(IJK).L_FCY)).FCY)
      		TROUVE = 0
      		If maxtab(this.GRP)>1
        		For IJK = 1 To maxtab(this.GRP)
        			If this.GRP(IJK)<>null and find(this.GRP(IJK).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        				#--Passage par sigma
        				#TROUVE = find(this.GRP(I).L_FCY(IJ).FCY, this.GRP(IJK).L_FCY(1..maxtab(this.GRP(IJK).L_FCY)).FCY)
        				W=0
        				TROUVE = sigma(1,maxtab(this.GRP(IJK).L_FCY),
&								(indcum)*((this.GRP(IJK).L_FCY(indcum).FCY=this.GRP(I).L_FCY(IJ).FCY)& (find(this.GRP(IJK).L_FCY(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0)))
#&								*(W=0 and sigma(W=1,1,1)))
        				If TROUVE = 0 : Break : Endif
        			Endif
      			Next IJK
      		Else
      			#--Nous avons un seul groupe, donc on ajoute
      			TROUVE=1
      		Endif

    			If TROUVE
        		NBFCY = fmet this.ADDLINE("L_FCY",[V]CST_ALASTPOS)
        		If NBFCY>0
          		this.L_FCY(NBFCY).FCY 			= this.GRP(I).L_FCY(IJ).FCY
          		this.L_FCY(NBFCY).FCYCPY 		= this.GRP(I).L_FCY(IJ).FCYCPY
          		this.L_FCY(NBFCY).FCYCPYLEG = this.GRP(I).L_FCY(IJ).FCYCPYLEG
          	Endif
        	Endif
				Endif
  		Endif

		Endif
	Next IJ

	#--Maintenant il faut s'assurer que les sites déjà existants dans this.L_FCY, sont tous dans le groupes que l'on rajoute
	#--Ils sont surement dans les groupes ajoutés avant...
	For IJ= 1 To maxtab(this.L_FCY)
		If this.L_FCY(IJ)<>null and find(this.L_FCY(IJ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
			#--Passage par sigma
  		#TROUVE = find(this.L_FCY(IJ).FCY,this.GRP(I).L_FCY(1..maxtab(this.GRP(I).L_FCY)).FCY)
    	W=0
    	TROUVE = sigma(1,maxtab(this.GRP(I).L_FCY),
&				(indcum)*((this.GRP(I).L_FCY(indcum).FCY=this.L_FCY(IJ).FCY)& (find(this.GRP(I).L_FCY(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0)))
#&				*(W=0 and sigma(W=1,1,1)))
  		If TROUVE = 0
  			#--On la supprime, car pas commune
  			WRET = fmet this.ADELLINE("L_FCY",this.L_FCY(IJ).AORDER)
  		Endif
		Endif
	Next

	#--chargement de la collection L_LEG
	For IJ = 1 To maxtab(this.GRP(I).L_LEG)
		If this.GRP(I).L_LEG(IJ)<>null and find(this.GRP(I).L_LEG(IJ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0

  		#--La société est-elle dans la collection ?
  		#--Passage par sigma
    	#If find(this.GRP(I).L_LEG(IJ).LEG,this.L_LEG(1..maxtab(this.L_LEG)).LEG)=0
    	W=0
    	TROUVE = sigma(1,maxtab(this.L_LEG),
&											(indcum)*((this.L_LEG(indcum).LEG=this.GRP(I).L_LEG(IJ).LEG)& (find(this.L_LEG(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0)))
#&											*(W=0 and sigma(W=1,1,1)))
			If TROUVE=0

    		#--Si elle ne l'est pas, on l'ajoute si présente dans les sociétés L_CPY de tous les autres groupes
  #  		TROUVE = find(this.GRP(I).L_LEG(IJ).LEG, this.GRP(1..maxtab(this.GRP)).L_LEG(1..maxtab(this.GRP(IJK).L_LEG)).LEG)
    		TROUVE = 0
    		If maxtab(this.GRP)>1
      		For IJK = 1 To maxtab(this.GRP)
      			If this.GRP(IJK)<>null and find(this.GRP(IJK).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      				#--Passage par sigma
      				#TROUVE = find(this.GRP(I).L_LEG(IJ).LEG, this.GRP(IJK).L_LEG(1..maxtab(this.GRP(IJK).L_LEG)).LEG)
      				W=0
      				TROUVE = sigma(1,maxtab(this.GRP(IJK).L_LEG),
&							(indcum)*((this.GRP(IJK).L_LEG(indcum).LEG=this.GRP(I).L_LEG(IJ).LEG)& (find(this.GRP(IJK).L_LEG(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0)))
#&							*(W=0 and sigma(W=1,1,1)))
      				If TROUVE = 0 : Break : Endif
    				Endif
    			Next IJK
      	Else
      		#--Nous avons un seul groupe, donc on ajoute
      		TROUVE=1
      	Endif
  			If TROUVE
  				#--Cohérence entre sociétés communes et législations communes
  				#--Passage par sigma
  				#If find(this.GRP(I).L_LEG(IJ).LEG,this.L_CPY(1..maxtab(this.L_CPY)).CPYLEG)
    			W=0
    			TROUVE = sigma(1,maxtab(this.L_CPY),
&						(indcum)*((this.L_CPY(indcum).CPYLEG=this.GRP(I).L_LEG(IJ).LEG)& (find(this.L_CPY(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0)))
#&						*(W=0 and sigma(W=1,1,1)))
					If TROUVE
        		NBLEG = fmet this.ADDLINE("L_LEG",[V]CST_ALASTPOS)
        		If NBLEG>0
        			this.L_LEG(NBLEG).LEG = this.GRP(I).L_LEG(IJ).LEG
        		Endif
        	Endif
      	Endif

  		Endif

		Endif
	Next IJ

	#--Maintenant il faut s'assurer que les législations déjà existantes dans this.L_LEG, sont toutes dans le groupes que l'on rajoute
	#--Elles sont surement dans les groupes ajoutés avant...
	For IJ= 1 To maxtab(this.L_LEG)
		If this.L_LEG(IJ)<>null and find(this.L_LEG(IJ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
			#--Passage par sigma
  		#TROUVE = find(this.L_LEG(IJ).LEG,this.GRP(I).L_LEG(1..maxtab(this.GRP(I).L_LEG)).LEG)
    	W=0
    	TROUVE = sigma(1,maxtab(this.GRP(I).L_LEG),
&				(indcum)*((this.GRP(I).L_LEG(indcum).LEG=this.L_LEG(IJ).LEG)& (find(this.GRP(I).L_LEG(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0)))
#&				*(W=0 and sigma(W=1,1,1)))
  		If TROUVE = 0
  			#--On la supprime, car pas commune
  			WRET = fmet this.ADELLINE("L_LEG",this.L_LEG(IJ).AORDER)
  		Endif
		Endif
	Next

Return

