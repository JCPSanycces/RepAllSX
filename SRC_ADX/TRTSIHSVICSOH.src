  Call ERREUR (GBIDC3) From GESECRAN

Return
#-------------------------------------------------------------------------------------
$MAJ_STRDAT_ENDDAT

Return
#-------------------------------------------------------------------------------------
$CALCUL_DEBUT_PERIODE

Return
#-------------------------------------------------------------------------------------
$CALCUL_FIN_PERIODE

Return
#-------------------------------------------------------------------------------------
$SETBPCINVADD
  # --- adresse client facture
  [M:ADB3]BPAADD       = [F:SOH]BPAINV
  [M:ADB3]ADBBPR       = [F:SOH]BPCINV
  [M:ADB3]BPRNAM(0)    = [F:SOH]BPINAM(0)
  [M:ADB3]BPRNAM(1)    = [F:SOH]BPINAM(1)
  [M:ADB3]BPAADDLIG(0) = [F:SOH]BPIADDLIG(0)
  [M:ADB3]BPAADDLIG(1) = [F:SOH]BPIADDLIG(1)
  [M:ADB3]BPAADDLIG(2) = [F:SOH]BPIADDLIG(2)
  [M:ADB3]POSCOD       = [F:SOH]BPIPOSCOD
  [M:ADB3]CTY          = [F:SOH]BPICTY
  [M:ADB3]SAT          = [F:SOH]BPISAT
  [M:ADB3]CRY          = [F:SOH]BPICRY
  [M:ADB3]CRYNAM       = [F:SOH]BPICRYNAM
  [M:ADB3]CNTNAM       = [F:SOH]CNINAM

  If [M:ADB3]BPRNAM <> "" |  [M:ADB3]BPAADDLIG <> "" |
&    [M:ADB3]POSCOD <> "" |  [M:ADB3]CTY <> ""      |
&    [M:ADB3]SAT    <> "" |
&    [M:ADB3]CRY    <> "" |  [M:ADB3]CRYNAM <> ""
      [M:ADB3]ADBFLG = 3
  Else
      [M:ADB3]ADBFLG = 0
  Endif

Return
#-------------------------------------------------------------------------------------
$SETBPCORDADD
  # --- adresse livraison
  # Alimentation code adresse (client livré) dans [M:ADB2] pour saisie adresse libre
  If dim([M:ADB2]BPAADD) > 0
      [M:ADB2]BPAADD   = [F:SOH]BPAADD
  Endif
  [M:ADB2]ADBBPR       = [F:SOH]BPCORD
  [M:ADB2]BPRNAM(0)    = [F:SOH]BPDNAM(0)
  [M:ADB2]BPRNAM(1)    = [F:SOH]BPDNAM(1)
  [M:ADB2]BPAADDLIG(0) = [F:SOH]BPDADDLIG(0)
  [M:ADB2]BPAADDLIG(1) = [F:SOH]BPDADDLIG(1)
  [M:ADB2]BPAADDLIG(2) = [F:SOH]BPDADDLIG(2)
  [M:ADB2]POSCOD       = [F:SOH]BPDPOSCOD
  [M:ADB2]CTY          = [F:SOH]BPDCTY
  [M:ADB2]SAT          = [F:SOH]BPDSAT
  [M:ADB2]CRY          = [F:SOH]BPDCRY
  [M:ADB2]CRYNAM       = [F:SOH]BPDCRYNAM
  [M:ADB2]CNTNAM       = [F:SOH]CNDNAM
  #If [F:SOH]BPCORD = [F:SOH]BPCINV & dim([M:ADB2]EECNUM)>0
  #   [M:ADB2]EECNUM = [F:SOH]BPIEECNUM
  #Endif

  If [M:ADB2]BPRNAM <> "" | [M:ADB2]BPAADDLIG <> "" |
&    [M:ADB2]POSCOD <> "" | [M:ADB2]CTY <> ""      |
&    [M:ADB2]SAT    <> "" |
&    [M:ADB2]CRY    <> "" | [M:ADB2]CRYNAM <> ""
      [M:ADB2]ADBFLG = 3
  Else
      [M:ADB2]ADBFLG = 0
  Endif
  If func AFNC.ACTIV("LTA") and dim([M:ADB2]ADRVAL) > 0 #LTA.sn
    [M:ADB2]ADRVAL = [F:SOH]ADRVAL
  Endif                                                 #LTA.en

Return
#-------------------------------------------------------------------------------------
$SETBPCINF

  [M]BPCINV         = [F:SVIC]BPCINV
  [M]SIHORI         = 10        #--scheduling invoice
  [M:SIH1]SIHORITYP = 10        #--Sales order
  [M]SIHORINUM      = [F:SOH]SOHNUM
  [M]SIHORIDAT      = [F:SOH]ORDDAT
  [M]INVREF         = [F:SOH]CUSORDREF
  If [F:BPC]BPCNUM<>[M:SIH0]BPCINV
    Read [BPC]BPC0=[M:SIH0]BPCINV
    If fstat : Raz [F:BPC] : Endif
  Endif
  If dim([M:SIH2]BPRFCT) > 0 [M:SIH2]BPRFCT = [F:BPC]FCTNUM Endif
  # 107888 : Scheduled invoices : X3-4955 (LD:18/10/16)
  # Nécessaire au call NEW_SFIT fait en AM_BPCINV
  [M]CUR            = [F:SOH]CUR
  # 107888 : Scheduled invoices : X3-4955 (LD:18/10/16)
Return
#-------------------------------------------------------------------------------------
$SETITMSOQ

  [M]ITMREF(nolign-1) = [F:SOQ]ITMREF
  #--Hidden fields (Ok to set them here)
  [M]SOHNUM(nolign-1) = [F:SOQ]SOHNUM
  [M]SOPLIN(nolign-1) = [F:SOQ]SOPLIN
  [M]SOQSEQ(nolign-1) = [F:SOQ]SOQSEQ
  [M]SIDORI(nolign-1) = 10

  # 107888 : Scheduled invoices : X3-4955 (LD:20/10/16)
#  If find([F:SOP]LINTYP,6,7,8,9)>0
#    [M:SIH4]LINTYP(nolign-1) =  1 #--Forcing to "normal" item
#  Else
#    [M:SIH4]LINTYP(nolign-1) = [F:SOP]LINTYP
#  Endif
  # 107888 : Scheduled invoices : X3-4955 (LD:20/10/16)

  #--Reading product tables for further use...
  #--- Lecture des tables articles
  If [F:ITM]ITMREF <> [M]ITMREF(nolign-1)
     Read [ITM]ITM0=[M]ITMREF(nolign-1)
     If fstat Raz [F:ITM] Endif
  Endif
  If [F:ITS]ITMREF <> [M]ITMREF(nolign-1)
     Read [ITS]ITS0 = [M]ITMREF(nolign-1)
     If fstat Raz [F:ITS] Endif
  Endif
  If ([F:ITU]ITMREF <> [M]ITMREF(nolign-1)) | ([F:ITU]BPCNUM <> [M:SIH1]BPCORD)
     Read [F:ITU]ITU0 = [M]ITMREF(nolign-1);[M:SIH1]BPCORD
     If fstat Raz [F:ITU] Endif
  Endif

  # 107888 : Scheduled invoices : X3-4955 (LD:19/10/16)
  # Initialisation des prix avant le passage en import du champ GROPRI pour ne pas déclencher l'AM_ et tout réécraser
  Gosub SETPRISOQ

  [M:SIH4]XSERMGTCOD(nolign-1) = [F:ITM]SERMGTCOD

  [M:SIH4]RTNSTOUPD(nolign-1) = 1
  # 107888 : Scheduled invoices : X3-4955 (LD:19/10/16)

Return
#-------------------------------------------------------------------------------------
$SETQTYSOQ

  [M]QTY   (nolign-1) = [SVICD]INVCNDQTY
  [M]INVPRC(nolign-1) = [SVICD]INVPERCENT
  # 107888 : Scheduled invoices : X3-4952 (LD:20/10/16)
  [M]YQTY  (nolign-1) = [SVICD]INVCNDQTY
  [M]CQTY  (nolign-1) = [SVICD]INVCNDQTY

  # Refait car CTLUOM peut l'écraser
  [M]SAUSTUCOE(nolign-1)=[F:SOP]SAUSTUCOE

  # 107888 : Scheduled invoices : X3-4952 (LD:20/10/16)
  Gosub SETPRISOQ

Return
#-------------------------------------------------------------------------------------
$SETSAUCON

  [M]SAU(nolign-1) = [SVICD]SAU
  If [SVICD]SAU<>[SOP]SAU
    mkstat=2
  Endif
  #  Gosub SETPRISOQ

Return
#-------------------------------------------------------------------------------------
$SETPRISOQ

  [M]GROPRI(nolign-1) = [F:SOP]GROPRI

  # 107888 : Scheduled invoices : X3-4955 (LD:24/10/16)
  [M]PRIREN(nolign-1)    = [F:SOP]PRIREN

  If dim([M:SIH4]DISCRGVAL1(nolign-1))>0 [M:SIH4]DISCRGVAL1(nolign-1)= [F:SOP]DISCRGVAL1 :  [M:SIH4]DISCRGREN1(nolign-1)= [F:SOP]DISCRGREN1 Endif
  If dim([M:SIH4]DISCRGVAL2(nolign-1))>0 [M:SIH4]DISCRGVAL2(nolign-1)= [F:SOP]DISCRGVAL2 :  [M:SIH4]DISCRGREN2(nolign-1)= [F:SOP]DISCRGREN2 Endif
  If dim([M:SIH4]DISCRGVAL3(nolign-1))>0 [M:SIH4]DISCRGVAL3(nolign-1)= [F:SOP]DISCRGVAL3 :  [M:SIH4]DISCRGREN3(nolign-1)= [F:SOP]DISCRGREN3 Endif
  If dim([M:SIH4]DISCRGVAL4(nolign-1))>0 [M:SIH4]DISCRGVAL4(nolign-1)= [F:SOP]DISCRGVAL4 :  [M:SIH4]DISCRGREN4(nolign-1)= [F:SOP]DISCRGREN4 Endif
  If dim([M:SIH4]DISCRGVAL5(nolign-1))>0 [M:SIH4]DISCRGVAL5(nolign-1)= [F:SOP]DISCRGVAL5 :  [M:SIH4]DISCRGREN5(nolign-1)= [F:SOP]DISCRGREN5 Endif
  If dim([M:SIH4]DISCRGVAL6(nolign-1))>0 [M:SIH4]DISCRGVAL6(nolign-1)= [F:SOP]DISCRGVAL6 :  [M:SIH4]DISCRGREN6(nolign-1)= [F:SOP]DISCRGREN6 Endif
  If dim([M:SIH4]DISCRGVAL7(nolign-1))>0 [M:SIH4]DISCRGVAL7(nolign-1)= [F:SOP]DISCRGVAL7 :  [M:SIH4]DISCRGREN7(nolign-1)= [F:SOP]DISCRGREN7 Endif
  If dim([M:SIH4]DISCRGVAL8(nolign-1))>0 [M:SIH4]DISCRGVAL8(nolign-1)= [F:SOP]DISCRGVAL8 :  [M:SIH4]DISCRGREN8(nolign-1)= [F:SOP]DISCRGREN8 Endif
  If dim([M:SIH4]DISCRGVAL9(nolign-1))>0 [M:SIH4]DISCRGVAL9(nolign-1)= [F:SOP]DISCRGVAL9 :  [M:SIH4]DISCRGREN9(nolign-1)= [F:SOP]DISCRGREN9 Endif

  [M]NETPRI(nolign-1)    = [F:SOP]NETPRI
  [M]NETPRINOT(nolign-1) = [F:SOP]NETPRINOT
  [M]NETPRIATI(nolign-1) = [F:SOP]NETPRIATI
  [M]PFM(nolign-1)       = [F:SOP]PFM
  # 107888 : Scheduled invoices : X3-4955 (LD:24/10/16)

Return
#-------------------------------------------------------------------------------------
$SETINVDTA
Local Integer NBPOSTE
  # Init. du tableau des éléments de facturation
  NBPOSTE = dim([M:SIH2]INVDTA)
  Call STRUFOOT (7,"SIH2",NBPOSTE,[M:SIH2]CURTYP,[F:SOH]CUR,[M:SIH2]CUR,"OUI") From SUBSFIT
  [M]NBFAC = NBPOSTE
  #--Nouvelle règle de transfert : Echéancier -> Factures
  #--Ce code n'a plus lieu d'être (géré par le SVIC_ORISOH_SIH_PLUS etc)
  #....

Return
#-------------------------------------------------------------------------------------
$SVIC_ORISOH_SIH_PLUS

  #--Transferts : Echéancier -> Factures
  #--Avant le GENSIH car le GENSIH=>SAI_NBLIG=>APRES_NBLIG=>APRES_LIGNE=>ADD_TOT=>MAJ_SFIT_QTY
  #--qui a besoin d'avoir dans le [M:SFIT] les DTA avec le VCRENT de la cde en cours
  #--Le VCRENT est alimenté par le SVIC_ORISOH_SIH_PLUS...
  Gosub SVIC_ORISOH_SIH_PLUS From SUBSFIT
  If GERR <> 0 Then
    Return
  Endif

Return
#-------------------------------------------------------------------------------------
$SET_LIG_SVIC_INVCNDSTA
Local Tinyint PNEWINVCNDSTA : [L]PNEWINVCNDSTA = 5

  #--Setting the VCRINVCNDSTA flag to 5 'On invoice'
  #--First, the global working handler has to be instantiate if not done yet
  If GSIDHYBHANDLE=null
    GSIDHYBHANDLE = NewInstance C_SIDHYBHANDLE AllocGroup null
  Endif
  Local Integer WRET,WOK,SIDHYBHANDLER_LINE

  [M:SIH4]STRDAT      (nolign-1)=[F:SVICD]PERFROM
  [M:SIH4]ENDDAT      (nolign-1)=[F:SVICD]PERTO
  [M:SIH4]SIDORI      (nolign-1)=10
  [M:SIH4]VCRINVCNDTYP(nolign-1)=[F:SVICD]VCRTYP
  [M:SIH4]SOHNUM      (nolign-1)=[F:SVICD]VCRNUMORI
  [M:SIH4]SOPLIN      (nolign-1)=[F:SVICD]VCRLINORI
  [M:SIH4]SOQSEQ      (nolign-1)=[F:SVICD]VCRSEQORI
  [M:SIH4]VCRINVCNDLIN(nolign-1)=[F:SVICD]VCRINVCNDLIN

  #--Let's find the invoice line's original schedule invoice's index into the GSIDHYBHANDLE class's SVCRINVCND collection, if present
  #--Set the WSIDHYBHANDLER_LINE with record's into the SVCRINVCND collection of GSIDHYBHANDLE
  Local Integer SAVE_NOL,NOL : : SAVE_NOL=NOL : NOL=nolign-1
  Gosub GSIDHYBHANDLE_GET_INDEX_WITH_INSTANCE_ADD_USING_M_SIH From LIBSAL_INVCND_SIH #--Because of the different kind of schedule invoice origins
  NOL=SAVE_NOL
  If SIDHYBHANDLER_LINE<1
     GERR=1 : GMESSAGE=mess(511,192,1)-[F:SVIC]VCRNUMORI-mess(162,154,1)-[F:SVIC]ITMREF-":"
     GMESSAGE -= mess(529,192,1) #'Erreur lors du chargement en mémoire de l'échéancier de facturation'
     mkstat=1   : Return
  Endif

  WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SET_LIG_INVCNDSTA([F:SVICD]VCRINVCNDLIN,PNEWINVCNDSTA)
  If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
    # Error management
    GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE))
    If WRET>=[V]CST_AERROR
      GERR = 1
    Endif
    WRET = func SUBINVCND.RAZMAXMSG(GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE),"SVCRINVCND")
  Endif

Return
#-------------------------------------------------------------------------------------

