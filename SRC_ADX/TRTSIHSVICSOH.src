  Case IMPZON
    When "ITMREF"
      # 107888 : Scheduled invoices : X3-4952 (LD:20/10/16)
      IMPMOD = 1
      # 107888 : Scheduled invoices : X3-4952 (LD:20/10/16)
      Gosub SETITMSOQ
      Gosub MAJ_STRDAT_ENDDAT
      Gosub SVIC_ORISOH_SIH_PLUS
      # 107888 : Scheduled invoices : X3-4952 (LD:20/10/16)
    When "ITMDES"
      # 1er champ saisissable après l'article
      # Init des champs non saisissables avec la ligne commande
      # Trop tôt sur ITMREF car l'init serait écrasée par AM_ITMREF
      [M:SIH4]LINTYP(nolign-1) = [F:SOP]LINTYP
      [M:SIH4]FOCFLG(nolign-1) = [F:SOP]FOCFLG

      # TSICOD non saisissable
      If dim([M:SIH4]TSICOD1(nolign-1))>0 [M:SIH4]TSICOD1(nolign-1)=[F:SOP]TSICOD(0) Endif
      If dim([M:SIH4]TSICOD2(nolign-1))>0 [M:SIH4]TSICOD2(nolign-1)=[F:SOP]TSICOD(1) Endif
      If dim([M:SIH4]TSICOD3(nolign-1))>0 [M:SIH4]TSICOD3(nolign-1)=[F:SOP]TSICOD(2) Endif
      If dim([M:SIH4]TSICOD4(nolign-1))>0 [M:SIH4]TSICOD4(nolign-1)=[F:SOP]TSICOD(3) Endif
      If dim([M:SIH4]TSICOD5(nolign-1))>0 [M:SIH4]TSICOD5(nolign-1)=[F:SOP]TSICOD(4) Endif

      # SIDTEX non saisissable
      # ---   Suivi texte détail cde sur fac : Duplication
      Local Integer WRET
      If find (GSALTEXLIN,5)
          [M:SIH4]SIDTEX(nolign-1) = [F:SOQ]SOQTEX
          If left$([F:SOQ]SOQTEX,3)="SOQ"
             Call DUP_CLOB("SID",[M:SIH4]SIDTEX(nolign-1),WRET) From TRTX3TEX
             If WRET<1 Raz [M:SIH4]SIDTEX(nolign-1) Endif
          Endif
      Endif

      [M:SIH4]STOMGTCOD(nolign-1)=[F:SOQ]STOMGTCOD

      [M:SIH4]DSTOFCY(nolign-1) = [F:SOH]STOFCY

      # Init de champs saisissables avec la ligne commande
      # Si on ne veut pas passer en AM_ de ces champs (et écraser des valeurs)
      Gosub SETSAUCON
      [M:SIH4]SAUSTUCOE(nolign-1)=[F:SOP]SAUSTUCOE

#      If GUSER="LD"
#        Call ECR_TRACE("ITMDES SAU="-[M]SAU(nolign-1),0) From GESECRAN
#        Call ECR_TRACE("ITMDES SAUSTUCOE="-num$([M]SAUSTUCOE(nolign-1)),0) From GESECRAN
#      Endif
      # 107888 : Scheduled invoices : X3-4952 (LD:20/10/16)

    When "DPJT"
      # FGR 02/01/2012 : X3SUIVI71065
      IMPMOD = 1
      [M]DPJT(nolign-1) = [F:SOQ]PJT
    When "QTY"
      IMPMOD=1
      Gosub SETQTYSOQ
      Gosub SET_LIG_SVIC_INVCNDSTA
      # 107888 : Scheduled invoices : X3-6337 (LD:28/10/16)
#      If GUSER="LD"
#          Call ECR_TRACE("BEF QTY [M]SIHORINUM="-[M]SIHORINUM-"[F:SVICD]VCRNUMORI="-[F:SVICD]VCRNUMORI,0) From GESECRAN
#      Endif
      If [M]SIHORINUM<>"" and [M]SIHORINUM<>[F:SVICD]VCRNUMORI
        Raz [M]SIHORINUM
      Endif
#      If GUSER="LD"
#          Call ECR_TRACE("AFT QTY [M]SIHORINUM="-[M]SIHORINUM-"[F:SVICD]VCRNUMORI="-[F:SVICD]VCRNUMORI,0) From GESECRAN
#      Endif
      # 107888 : Scheduled invoices : X3-6337 (LD:28/10/16)

    # 107888 : Scheduled invoices : X3-4952 (LD:20/10/16)
    # Init depuis ITMDES pour éviter de passer en AM_
#    When "SAU"
#      Gosub SETSAUCON
    # 107888 : Scheduled invoices : X3-4952 (LD:20/10/16)
#      If GUSER="LD"
#        Call ECR_TRACE("GROPRI SAU="-[M]SAU(nolign-1),0) From GESECRAN
#        Call ECR_TRACE("GROPRI SAUSTUCOE="-num$([M]SAUSTUCOE(nolign-1)),0) From GESECRAN
#      Endif
    When "GROPRI"
      # 107888 : Scheduled invoices : X3-4952 (LD:20/10/16)
      # Ne pas forcer l'AM : Il y a l'action DIVPRIPFM qui recalcule le prix net, le prix net HT et TTC et la marge
      # On pourrait ne pas tomber sur les mêmes résultat que la commande
      #IMPMOD = 1
      # 107888 : Scheduled invoices : X3-4952 (LD:20/10/16)
      Gosub SETPRISOQ
      # 107888 : Scheduled invoices : X3-4952 (LD:20/10/16)
      [M]YQTYSTU(nolign-1) = [M]QTYSTU(nolign-1)
      # 107888 : Scheduled invoices : X3-4952 (LD:20/10/16)
      # VCRINVCNDTYP VCRINVCNDLIN SIDORI non saisissables, init depuis QTY
#    When "VCRINVCNDTYP"
#      IMPMOD=1
#      [M:SIH4]VCRINVCNDTYP(nolign-1)=10
#    When "VCRINVCNDLIN"
#      IMPMOD=1
#      [M:SIH4]VCRINVCNDLIN(nolign-1)=[F:SVICD]VCRINVCNDLIN
#      If [M]SIHORINUM<>"" and [M]SIHORINUM<>[F:SVICD]VCRNUMORI
#        Raz [M]SIHORINUM
#      Endif
#    When "SIDORI"
#      IMPMOD=1
#      [M:SIH4]SIDORI(nolign-1)=10 #--Scheduling invoice
      # 107888 : Scheduled invoices : X3-4952 (LD:20/10/16)

    When "INVPRC"
      IMPMOD=1
      [M:SIH4]INVPRC(nolign-1)=[F:SVICD]INVPERCENT
    When "CCE1"
      #--Axes lignes Commande vers facture
      # Chargement sections analytiques
      Call CHARG_ACCCCE(nolign-1,"","","[M:SIH4]CCE",
&                    "SOP",0,[F:SOP]SOHNUM,[F:SOP]SOPLIN,[F:SOP]SOPSEQ,"") From TRTX3CPT
      # Initialisation des sections analytiques vides
      Local Integer I
      Local Char    SECTION
      For I=1 To GNBDIE
          If evalue("dim([M:SIH4]CCE"+num$(I)+"(NOL))") >0 & evalue("[M:SIH4]CCE"+num$(I)+"(NOL)")=""
              Call INISEC(SECTION, "SID", I) From TRTX3CPT
              Assign "[M:SIH4]CCE"+num$(I)+"(NOL)" With SECTION
          Endif
      Next
    When "ECCVALMAJ" :
      #X3SUIVI105605 (début) ici pour ne le faire que sur les proforma
      If [M:SIH0]INVTYP = 5 Then
        Raz [M:SIH4]ECCVALMAJ(nolign-1)
      Else
        [M:SIH4]ECCVALMAJ(nolign-1) = [F:SOQ]ECCVALMAJ
      Endif
    When "ECCVALMIN" :
      #X3SUIVI105605 (début) ici pour ne le faire que sur les proforma
      If [M:SIH0]INVTYP = 5 Then
        Raz [M:SIH4]ECCVALMIN(nolign-1)
      Else
        [M:SIH4]ECCVALMIN(nolign-1) = [F:SOQ]ECCVALMIN
      Endif
    When "VACITM1" :
      [M:SIH4]VACITM1(nolign-1) = [F:SOP]VACITM(0)
      [M:SIH4]VACITM2(nolign-1) = [F:SOP]VACITM(1)
      [M:SIH4]VACITM3(nolign-1) = [F:SOP]VACITM(2)

      # 107888 : Scheduled invoices : X3-4952 (LD:19/10/16)
    #When "VAT1" :
      # VAT1 VAT2 VAT3 non saisissables, init depuis VACITM1
      [M:SIH4]VAT1(nolign-1)    = [F:SOP]VAT(0)
      [M:SIH4]VAT2(nolign-1)    = [F:SOP]VAT(1)
      [M:SIH4]VAT3(nolign-1)    = [F:SOP]VAT(2)

      # CLCAMT1 non saisissable, calculé dans l'action en AM_QTY
#    When "CLCAMT1"
#      [M:SIH4]CLCAMT1(nolign-1) = [F:SOP]CLCAMT1
#      [M:SIH4]CLCAMT2(nolign-1) = [F:SOP]CLCAMT2
#      # Date utilisée pour le calcul des taxes (prix HT/TTC)
#      # Si on a une base de calcul de taxe, c'est qu'il y a une formule
#      Local    Decimal  WANC_CLCAMT1, WANC_CLCAMT2
#      WANC_CLCAMT1=[M:SIH4]CLCAMT1(nolign-1) : WANC_CLCAMT2=[M:SIH4]CLCAMT2(nolign-1)
#      If [M:SIH4]CLCAMT1(nolign-1)<>0 | [M:SIH4]CLCAMT2(nolign-1)<>0
#        # Recalcul des montants de base calcul de taxe (peuvent être dépendant de la qté)
#        Call ALICLCAMT([M:SIH4]ITMREF(nolign-1), [M:SIH4]QTY(nolign-1), nolign-1, "SIH4", [M:SIH4]CLCAMT1(nolign-1), [M:SIH4]CLCAMT2(nolign-1)) From TRTX3
#      Endif
#      # Recalcul des taxes systématique avec [M]INVDAT (au cas où le taux ait changé entre date cde et date facture)
#      Local Date WDATCONVPRI
#      WDATCONVPRI=[M:SIH0]INVDAT
#      If [M:SIH1]PRITYP=1
#        [M:SIH4]NETPRINOT(nolign-1) = [M:SIH4]NETPRI(nolign-1)
#        Call CLCTAXEPRIV([M:SIH4]NETPRI(nolign-1),[F:SOP]VAT,[M:SIH1]PRITYP,GSOCIETE,WDATCONVPRI,
#&                        [M:SIH4]QTY(nolign-1),[M:SIH1]VACBPR,[M:SIH4]CLCAMT1(nolign-1),[M:SIH4]CLCAMT2(nolign-1),[M:SIH4]NETPRIATI(nolign-1)) From TRTX3
#      Else
#        [M:SIH4]NETPRIATI(nolign-1) = [M:SIH4]NETPRI(nolign-1)
#        Call CLCTAXEPRIV([M:SIH4]NETPRI(nolign-1),[F:SOP]VAT,[M:SIH1]PRITYP,GSOCIETE,WDATCONVPRI,
#&                        [M:SIH4]QTY(nolign-1),[M:SIH1]VACBPR,[M:SIH4]CLCAMT1(nolign-1),[M:SIH4]CLCAMT2(nolign-1),[M:SIH4]NETPRINOT(nolign-1)) From TRTX3
#      Endif
      # 107888 : Scheduled invoices : X3-4952 (LD:19/10/16)

      #TODO Update the schedule invoice line with the new price if not done

   # 107888 : Scheduled invoices : X3-4952 (LD:13/10/16)
#    When "DPJT"
#      IMPMOD = 1
#      [M]DPJT(nolign-1) = [F:SOQ]PJT
   # 107888 : Scheduled invoices : X3-4952 (LD:13/10/16)

    When "EECFLOPHY"
      [M:SIH4]EECFLOPHY(nolign-1) = 1 #--Not a "physical" exchange

   # 107888 : Scheduled invoices : X3-4955 (LD:13/10/16)
   # Inutile STOFCY est à l'entête, non saisissable sur les lignes,
   # Init en INICRE_LIG
#    When "DSTOFCY"
#      IMPMOD = 1
#      [M:SIH4]DSTOFCY(nolign-1) = [F:SOQ]STOFCY

    # STOMGTCOD non saisissable, init depuis ITMDES avec la ligne commande
#    When "STOMGTCOD"
#      IMPMOD = 1
#      [M:SIH4]STOMGTCOD(nolign-1)=[F:SOQ]STOMGTCOD
    # TSICOD non saisissables, init depuis ITMDES avec la ligne commande
#    When "TSICOD1"
#      If dim([M:SIH4]TSICOD1(nolign-1))>0 [M:SIH4]TSICOD1(nolign-1)=[F:SOP]TSICOD(0) Endif
#    When "TSICOD2"
#      If dim([M:SIH4]TSICOD2(nolign-1))>0 [M:SIH4]TSICOD2(nolign-1)=[F:SOP]TSICOD(1) Endif
#    When "TSICOD3"
#      If dim([M:SIH4]TSICOD3(nolign-1))>0 [M:SIH4]TSICOD3(nolign-1)=[F:SOP]TSICOD(2) Endif
#    When "TSICOD4"
#      If dim([M:SIH4]TSICOD4(nolign-1))>0 [M:SIH4]TSICOD4(nolign-1)=[F:SOP]TSICOD(3) Endif
#    When "TSICOD5"
#      If dim([M:SIH4]TSICOD5(nolign-1))>0 [M:SIH4]TSICOD5(nolign-1)=[F:SOP]TSICOD(4) Endif

#    When "SIDTEX"
    # SIDTEX non saisissable, init depuis ITMDES avec la ligne commande
#      # ---   Suivi texte détail cde sur fac : Duplication
#      Local Integer WRET
#      If find (GSALTEXLIN,5)
#          [M:SIH4]SIDTEX(nolign-1) = [F:SOQ]SOQTEX
#          If left$([F:SOQ]SOQTEX,3)="SOQ"
#             Call DUP_CLOB("SID",[M:SIH4]SIDTEX(nolign-1),WRET) From TRTX3TEX
#             If WRET<1 Raz [M:SIH4]SIDTEX(nolign-1) Endif
#          Endif
#      Endif
#      # ---   Suivi texte sur fac : Recherche texte article et duplication
#      If find (GSALTEXLIN,3)
#         [M:SIH4]SIDTEX(nolign-1) = [F:ITU]ITSTEX
#         If [M:SIH4]SIDTEX(nolign-1)=""
#            [M:SIH4]SIDTEX(nolign-1) = [F:ITS]ITSTEX
#         Endif
#      Endif
#    When "LINTYP"
    # LINTYP non saisissable, init depuis ITMDES avec la ligne commande
#      If find([F:SOP]LINTYP,6,7,8,9)>0
#        [M:SIH4]LINTYP(nolign-1) =  1
#      Else
#        [M:SIH4]LINTYP(nolign-1) = [F:SOP]LINTYP
#      Endif
#    When "FOCFLG"
    # FOCFLG non saisissable, init depuis ITMREF avec la ligne commande
#      [M:SIH4]FOCFLG(nolign-1) = [F:SOP]FOCFLG
    # 107888 : Scheduled invoices : X3-4955 (LD:13/10/16)
    When "GRPFLG"
#      [M:SIH4]GRPFLG(nolign-1)  = 1
    # 107888 : Scheduled invoices : X3-4955 (LD:20/10/16)
#    When "REP1"
#      [M:SIH4]REP1   (nolign-1) = [F:SOP]REP1
#      [M:SIH4]REPRAT1(nolign-1) = [F:SOP]REPRAT1
#      [M:SIH4]REPCOE (nolign-1) = [F:SOP]REPCOE
#    When "REP2"
#      [M:SIH4]REP2   (nolign-1) = [F:SOP]REP2
#      [M:SIH4]REPRAT2(nolign-1) = [F:SOP]REPRAT2
#      [M:SIH4]REPCOE (nolign-1) = [F:SOP]REPCOE
    When "REP1"
      [M:SIH4]REP1   (nolign-1) = [F:SOP]REP1
      [M:SIH4]REPCOE (nolign-1) = [F:SOP]REPCOE
    When "REP2"
      [M:SIH4]REP2   (nolign-1) = [F:SOP]REP2
      [M:SIH4]REPCOE (nolign-1) = [F:SOP]REPCOE
    When "REPRAT1"
      [M:SIH4]REPRAT1(nolign-1) = [F:SOP]REPRAT1
    When "REPRAT2"
      [M:SIH4]REPRAT2(nolign-1) = [F:SOP]REPRAT2

#      If GUSER="LD"
#          Call ECR_TRACE("REPRAT2 [M]SIHORINUM="-[M]SIHORINUM,0) From GESECRAN
