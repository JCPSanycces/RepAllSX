Local Integer NBAPPELS
#--Same init strategy as done in TRTVENFAC.ALISOHSIH...
#--1) fields init throught transclass
#[M:SIH0] = [F:SOH]
#[M:SIH1] = [F:SOH]
#[M:SIH2] = [F:SOH]
#--2) init DIE/CCE throught TRTX3CPT
#--3) init NBFAC and INVDTAxxx throught SUBSFIT
#--4) init throught manual assign

  #--IMPZON = 1 triggers the AM_field !
#  Case IMPZON
      # 107888 : Scheduled invoices : X3-4955 (LD:18/10/16)
      # SIVTYP already
#    When "SIVTYP"
#      IMPMOD=1
#      [M]SIVTYP = GSIVTYP
      # 107888 : Scheduled invoices : X3-4955 (LD:18/10/16)
  Case IMPZON
    When "SALFCY"
      IMPMOD = 1
      [M]SALFCY = [F:SOH]SALFCY
    When "INVDAT"
      IMPMOD = 1
      [M]INVDAT = date$
      [M]INVSTA = 1
      [M]STARPT = 1
      [M]STOMVTFLG = 1
    When "BPCINV"
      IMPMOD = 1
      Gosub SETBPCINF
    When "INVREF"
      IMPMOD = 1
      [M]INVREF = [F:SOH]CUSORDREF
    When "BPAADD"
      # 107888 : Scheduled invoices : X3-4955 (LD:18/10/16)
      # Facture échéance pas d'adr liv différente sur les lignes : On prend celle de l'entête
      If [F:SOH]BPAADD <> "" Then
        [M]BPAADD = [F:SOH]BPAADD
        IMPMOD = 1
      Endif
      Gosub SETBPCORDADD
      Gosub SETBPCINVADD

      # Champ saisissable après le client facture
      # Init des champs non saisissables avec l'entête commande
      # Trop tôt sur BPCINV car l'init serait écrasée par AM_BPCINV
#      If GUSER="LD"
#        Call ECR_TRACE("BPAADD ORIFCY="-[M]ORIFCY-"[F:SOH]ORIFCY"-[F:SOH]ORIFCY,0) From GESECRAN
#        Call ECR_TRACE("BPAADD BETFCY="-num$([M]BETFCY),0) From GESECRAN
#      Endif
      [M]BETCPY = [F:SOH]BETCPY
      [M]BETFCY = [F:SOH]BETFCY
      If [M]BETFCY=2 & [M]ORIFCY="" [M]ORIFCY=[F:SOH]ORIFCY : Endif

      For I=0 To func AFNC.ACTIV("STC")-1
        [M]TSCCOD(I) = [F:SOH]TSCCOD(I)
      Next
#      If GUSER="LD"
#        Call ECR_TRACE("BPAADD ORIFCY="-[M]ORIFCY-"[F:SOH]ORIFCY"-[F:SOH]ORIFCY,0) From GESECRAN
#        Call ECR_TRACE("BPAADD BETFCY="-num$([M]BETFCY),0) From GESECRAN
#      Endif
      # 107888 : Scheduled invoices : X3-4955 (LD:20/10/16)
    When "PJT"
      If [M:SIH4]NBLIG = 0 Then
        #--Seulement pour la première ligne
        IMPMOD = 1
        [M]PJT = [F:SOH]PJT
      Endif
      Local Char SMESSAGE(250)
      If func TRTPJT.IS_PJT_AVAILABLE([M]PJT, "[M:SIH1]PJT", SMESSAGE) = G_NON Then
        Call PJT_ADD_MSG([M:SIH1]PJT, SMESSAGE) From TRTPJT
        Raz [M:SIH1]PJT
      Endif
    When "CUR"
      IMPMOD = 1
      [M]CUR = [F:SOH]CUR
    When "PTE"
      IMPMOD = 1
      [M]PTE = [F:SOH]PTE
    When "REP"
      IMPMOD = 1
      Case indice
        When 0
          [M]REP(0) = [F:SOH]REP(0)
        When 1
          [M]REP(1) = [F:SOH]REP(1)
      Endcase
    When "INVDTAAMT"
    When "UMRNUM"
#      Local Char WMESS_UMRNUM(250)
#
#      Raz WMESS_UMRNUM
#      Call INIT_CTL_UMRNUM(GSOCIETE,[M]BPRPAY,[M]PTE,[M]UMRNUM,WMESS_UMRNUM) From TRTVENSDD
#      If WMESS_UMRNUM<>""
#       Call ECR_TRACE(WMESS_UMRNUM,-1) From GESECRAN
#       Raz mkstat #--We don't want to stop the invoice generation process
#      Endif
    When "VACBPR"
      #--faire unitairement a cause de l'AM_ sur BPCINV notamment
      IMPMOD = 1
      [M]VACBPR = [F:SOH]VACBPR
    When "BPCORD"
      #--faire unitairement a cause de l'AM_ sur BPCINV notamment
      IMPMOD = 1
      [M]BPCORD = [F:SOH]BPCORD
    When "BPCGRU"
      #--faire unitairement a cause de l'AM_ sur BPCINV notamment
      IMPMOD = 1
      [M]BPCGRU = [F:SOH]BPCGRU
    When "BPRPAY"
      #--faire unitairement a cause de l'AM_ sur BPCINV notamment
      IMPMOD = 1
      [M]BPRPAY = [F:SOH]BPCPYR
    When "PRITYP"
      #--faire unitairement a cause de l'AM_ sur BPCINV notamment
      IMPMOD = 1
      [M]PRITYP = [F:SOH]PRITYP
      # 107888 : Scheduled invoices : X3-4955 (LD:19/10/16)
      # Unuseful because CHGTYP is hidden
#    When "CHGTYP"
#      #--faire unitairement a cause de l'AM_ sur BPCINV notamment
#      IMPMOD = 1
#      [M]CHGTYP = [F:SOH]CHGTYP
      # 107888 : Scheduled invoices : X3-4955 (LD:18/10/16)
    When "STRDATSVC"
      #--chargement dates début/fin période prestation  pour CCA/FCA
      #--Line level
#      IMPMOD = 1
#      [M]STRDATSVC = [SVICD]PERFROM
    When "ENDDATSVC"
      #--chargement dates début/fin période prestation  pour CCA/FCA
      #--Line level
#      IMPMOD = 1
#      [M]ENDDATSVC = [SVICD]PERTO
      # 107888 : Scheduled invoices : X3-4955 (LD:19/10/16)
    #When "CCE"
    When "NBAXE"
     #--Axes lignes Commande vers facture
      #Chargement des sections analytiques entête facture à partir de la commande d'origine
      Call CHARG_CCEH("SIH2","NBAXE","SOH") From TRTX3CPT
      #Initialisation sections analytiques vides
      If dim([M:SIH2]NBAXE)>0
        Local Char SECTION
        [M:SIH2]NBAXE = GNBDIE
        For I=1 To GNBDIE
          If [M:SIH2]CCE(I-1)=""
            [M:SIH2]DIE(I-1)=GDIE(I)
            Call INISEC(SECTION,"SIH",GDIE(I)) From SUBCDE
            [M:SIH2]CCE(I-1) = SECTION
          Endif
        Next I
      Endif
      # 107888 : Scheduled invoices : X3-4955 (LD:19/10/16)
    When "EECNAT"
#      IMPMOD = 1
#      [M]EECNAT  = [F:SOH]EECNAT
#      [M]EECNATR = ""
       If [F:TMD]MDL<>[F:SOH]MDL
         Read [TMD]TMD0 = [F:SOH]MDL
         If  fstat : Raz [F:TMD] : Endif
       Endif
       If dim([M:SIH0]EECNAT)>0
         [M:SIH0]EECTRN = [F:TMD]EECTRN
       Endif
   When "EECSCH"
#      IMPMOD = 1
#      [M]EECSCH  = [F:SOH]EECSCH
#      [M]EECSCHR = ""
      # 107888 : Scheduled invoices : X3-4955 (LD:19/10/16)
      # EECLOC non saisissable, init depuis EECICT
#   When "EECLOC"
#      IMPMOD = 1
#      [M]EECLOC = [F:SOH]EECLOC
      # 107888 : Scheduled invoices : X3-4955 (LD:19/10/16)
   When "EECTRN"
      #IMPMOD = 1
      #[M]EECTRN = [F:SOH]EECTRN
   When "EECICT"
      IMPMOD = 1
      [M]EECICT = [F:SOH]EECICT
      # 107888 : Scheduled invoices : X3-4955 (LD:19/10/16)
      # Initialisation de toutes les infos douanières sur EECICT car il est saisissable sur SIH1
      # ICTCTY est saisissable sur SIH1
      # FFWNUM FFWADD BPIEECNUM EECLOC ne sont pas saisissables
      [M]FFWNUM = [F:SOH]FFWNUM
      [M]FFWADD = [F:SOH]FFWADD
      [M]ICTCTY = [F:SOH]ICTCTY
      [M]EECLOC = [F:SOH]EECLOC
      If [F:TMD]MDL<>[F:SOH]MDL
        Read [TMD]TMD0 = [F:SOH]MDL
        If  fstat : Raz [F:TMD] : Endif
      Endif
      If dim([M:SIH0]EECNAT)>0
        [M:SIH0]EECTRN = [F:TMD]EECTRN
      Endif
      [M]BPIEECNUM = [F:SOH]BPIEECNUM
#   When "ICTCTY"
#      IMPMOD = 1
#      [M]ICTCTY = [F:SOH]ICTCTY
#   When "FFWNUM"
       # FFWNUM non saisissable, init depuis EECICT
#      IMPMOD = 1
#      [M]FFWNUM = [F:SOH]FFWNUM
#      [M]FFWADD = [F:SOH]FFWADD
#   When "BPIEECNUM"
       # BPIEECNUM non saisissable, init depuis EECICT
#      IMPMOD = 1
#      [M]BPIEECNUM = [F:SOH]BPIEECNUM
      # 107888 : Scheduled invoices : X3-4955 (LD:19/10/16)
   When "EECNUMCRY"
#      IMPMOD = 1
#      [M]EECNUMCRY = [F:SOH]EECNUMCRY
      # 107888 : Scheduled invoices : X3-4955 (LD:19/10/16)
   When "EECNUM"
#      IMPMOD = 1
#      [M]EECNUM = [F:SOH]EECNUM
      # 107888 : Scheduled invoices : X3-4955 (LD:19/10/16)
#   When "CDTSTA"
       # Champ inexistant
#      IMPMOD = 1
#      [M]CDTSTA = [F:SOH]CDTSTA
#   When "PLISTC"
       # PLISTC non saisissable
#      IMPMOD = 1
#      [M]PLISTC = [F:SOH]PLISTC
#      [M]CUR    = [F:SOH]CUR
#      # Alimentation concernant les colonnes frais/remises en fonction de la structure tarif de la société
#      Call ALICOLREM (1,5,GFLAG,"SIH4",[M]CUR,0,[M]PLISTC) From TRTPRICE
      # 107888 : Scheduled invoices : X3-4955 (LD:19/10/16)
#   When "TSCCOD"
      # TSCCOD non saisissables, init depuis ORIDOCNUM avec l'entête commande
#      IMPMOD = 1
#      For I=0 To func AFNC.ACTIV("STC")-1
#        [M]TSCCOD(I) = [F:SOH]TSCCOD(I)
#      Next
      # 107888 : Scheduled invoices : X3-4955 (LD:19/10/16)
   When "DEP"
      IMPMOD = 1
      [M]DEP = [F:SOH]DEP
      # 107888 : Scheduled invoices : X3-4955 (LD:18/10/16)
      # Unuseful because done in AM_DEP
#      # 102423 : Belgium Early discounts
#      # Early discount rate determination
#      If find(GDEPMGTMOD, 1,5)
#          Call ALIDISVAT (5, [M:SIH2]DEP, GBIDI1, [M:SIH2]DEPRAT) From SUBTDA
#      Endif
#      #  102423
      # 107888 : Scheduled invoices : X3-4955 (LD:18/10/16)
    When "STRDUDDAT"
      IMPMOD = 1
      [M]STRDUDDAT = [M]INVDAT
    When "CURTYP"
      # 107888 : Scheduled invoices : X3-4955 (LD:19/10/16)
      # [M]CHGTYP charged in AM_BPCINV, is not modifiable on the order
      IMPMOD = 1
      [M]CURTYP = [M]CHGTYP
      #----- Chargement zones devises et cours -----#
      Call INI_COURS("SIH2",GSOCIETE,[M:SIH2]CUR,[M:SIH0]INVDAT,[M:SIH2]CURTYP) From SUBBICS
    When "BPRFCT"
#      IMPMOD = 1
#      [M]BPRFCT = [F:SOH]FCTNUM

    # 107888 : Scheduled invoices : X3-4955 (LD:18/10/16)
#    When "BETCPY"
      # BETCPY non saisissables, init depuis ORIDOCNUM avec l'entête commande
#       IMPMOD = 1
#       [M]BETCPY = [F:SOH]BETCPY
#    When "BETFCY"
      # BETFCY non saisissables, init depuis ORIDOCNUM avec l'entête commande
#       IMPMOD = 1
#       [M]BETFCY = [F:SOH]BETFCY
#    When "ORIFCY"
      # ORIFCY non saisissables, init depuis ORIDOCNUM avec l'entête commande
#      If [M]BETFCY=2 & [M]ORIFCY="" [M]ORIFCY=[F:SOH]ORIFCY : Endif
    When "STOFCY"
       IMPMOD = 1
       [M]STOFCY = [F:SOQ]STOFCY
    # 107888 : Scheduled invoices : X3-4955 (LD:18/10/16)
  Endcase

Return
#-----------------------------------------------------------------------
$READ_DETAIL

Local Char    WOLD_SWIKEY (250) : WOLD_SWIKEY       = [SWICND]SWIKEY
Local Char    WOLD_SWIKEY1(250) : WOLD_SWIKEY1      = [SWICND]SWIKEY1
Local Char    WOLD_SWIDATA(250) : WOLD_SWIDATA      = [SWICND]SWIDATA
Local Integer WOLD_VCRINVCNDLIN : WOLD_VCRINVCNDLIN = [SWICND]VCRINVCNDLIN
#If GUSER="LD" Dbgaff Endif
  nolign = 0
  LIG_DETAIL = "C" # uniquement de la creation
  If LEC_DETAIL = 0 Then
    If [F:SOH]SOHNUM<>[SVIC]VCRNUMORI
      Read [F:SOH]SOH0=[SVIC]VCRNUMORI
      If fstat : LEC_DETAIL=2 : Return : Endif
      #----- Blocage logique de la demande
      SYMBOLE = "SOH"+[F:SOH]SOHNUM
      Lock = SYMBOLE
      If fstat
         # modification en cours sur un autre poste
         GERR=1 : GMESSAGE=[F:SOH]SOHNUM-":"-mess(10,100,1)
         Call ECR_TRACE(GMESSAGE,1) From GESECRAN
         LEC_DETAIL=2 : Return
      Endif
      #-----
    Endif
    Read [SOQ]SOQ0=[SVIC]VCRNUMORI;[SVIC]VCRLINORI;[SVIC]VCRSEQORI
    If fstat
      Unlock =SYMBOLE
      LEC_DETAIL=3 : Return
    Endif
    Read [SOP]SOP0=[SOQ]SOHNUM;[SOQ]SOPLIN;[SOQ]SOQSEQ
    If fstat
      Unlock =SYMBOLE
      LEC_DETAIL=3 : Return
    Endif
#    # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15763 (LD:15/12/16)
#    Read [SVICD]SVICD0=[SWICND]VCRNUMORI;[SWICND]VCRLINORI;[SWICND]VCRSEQORI
#    If fstat
#      Unlock =SYMBOLE
#      LEC_DETAIL=3 : Return
#    Endif
#    # 107888 : Scheduled invoices : New fields 'To invoice' - X3-15763 (LD:15/12/16)
    LEC_DETAIL=1
  Else
    Read [SWILNK_]CLE Next
    If !fstat
      If WOLD_SWIKEY=[SWICND]SWIKEY and WOLD_SWIKEY1=[SWICND]SWIKEY1 and WOLD_SWIDATA=[SWICND]SWIDATA
        If [F:SOH]SOHNUM<>[SVIC]VCRNUMORI
          Read [F:SOH]SOH0=[SVIC]VCRNUMORI
          If fstat : LEC_DETAIL=2 : Return : Endif
          #----- Blocage logique de la demande
          SYMBOLE = "SOH"+[F:SOH]SOHNUM
          Lock = SYMBOLE
          If fstat
             # modification en cours sur un autre poste
             GERR=1 : GMESSAGE=[F:SOH]SOHNUM-":"-mess(10,100,1)
             Call ECR_TRACE(GMESSAGE,1) From GESECRAN
             LEC_DETAIL=2 : Return
          Endif
          #-----
        Endif
        If [F:SOQ]SOHNUM<>[SVIC]VCRNUMORI or [F:SOQ]SOPLIN<>[SVIC]VCRLINORI or [F:SOQ]SOQSEQ<>[SVIC]VCRSEQORI
          Read [SOQ]SOQ0=[SVIC]VCRNUMORI;[SVIC]VCRLINORI;[SVIC]VCRSEQORI
          If fstat
            Unlock =SYMBOLE
            LEC_DETAIL=2 : Return
          Endif
          Read [SOP]SOP0=[SOQ]SOHNUM;[SOQ]SOPLIN;[SOQ]SOQSEQ
          If fstat
            Unlock =SYMBOLE
            LEC_DETAIL=2 : Return
          Endif
          LEC_DETAIL=1
        Endif
      Else
        #--rupture => facture suivante...
        LEC_DETAIL=2
      Endif
    Elsif fstat = 4 Then
      # fin lecture
      LEC_DETAIL = 2
      Unlock =SYMBOLE
      Raz [SWICND]
    Else
      # erreur
      LEC_DETAIL = 3
      Unlock =SYMBOLE
      Raz [SWICND]
    Endif
  Endif

  #--A VIRER !! pour mock
  #GCPO_NBREAD+=1
  #Call ECR_TRACE("Itérations : "+num$(GCPO_NBREAD),0) From GESECRAN
  #If GCPO_NBREAD>150 : Raz [SWICND] : LEC_DETAIL=3 : Return Endif
  #--
  If LEC_DETAIL = 1
    # 107888 : Scheduled invoices : X3-4952 (LD:17/10/16)
#    Call ECR_TRACE(mess(511,192,1)-":"-mess(144,183,1)-num$([F:SVICD]NEXINVDAT)-mess(542,192,1)-":"
#&                 -mess(332,182,1)-[F:SVIC]VCRNUMORI-mess(3,61,1)-num$([F:SVIC]VCRLINORI)
#&                 -mess(162,154,1)-[F:SVIC]ITMREF,0) From GESECRAN
    # 107888 : Scheduled invoices : X3-6923 (LD:17/01/17)
#    Call ECR_TRACE(mess(511,192,1)-":"-mess(274,191,1)-num$([F:SVICD]NEXINVDAT)-mess(542,192,1)-":"
#&                 -mess(98,197,1)-[F:SVIC]VCRNUMORI-mess(3,61,1)-num$([F:SVIC]VCRLINORI)
#&                 -mess(162,154,1)-[F:SVIC]ITMREF,0) From GESECRAN
    Call ECR_TRACE(mess(511,192,1)-":"-mess(274,191,1)-num$([F:SVICD]NEXINVDAT)-mess(542,192,1)-":"
&                 -mess(98,197,1)-[F:SVIC]VCRNUMORI-"\"-mess(3,61,1)-num$([F:SVIC]VCRLINORI)
&                 -mess(162,154,1)-[F:SVIC]ITMREF,0) From GESECRAN
    # 107888 : Scheduled invoices : X3-6923 (LD:17/01/17)
    # 107888 : Scheduled invoices : X3-4952 (LD:17/10/16)
  Endif

Return
