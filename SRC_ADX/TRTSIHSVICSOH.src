#<AdxTL>@(#)0.0.0.0 $Revision$
# TRTSIHSVICSOH  : Facturation automatique des échéanciers de facturation
###########################################################################################
#    pour GENSIH composant calcul facture
#    chargement masques SIH0 SIH1 SIH2 SIH4
###########################################################################################
$ACTION_GS

  Case GWACTION_GS
    When "READ_DETAIL"
      Gosub READ_DETAIL
    When "MSK_ENTETE"
      Gosub MSK_ENTETE
    When "MSK_DETAIL"
      Gosub MSK_DETAIL
    When "ERREUR"
      Gosub ERREUR
    When "CREATION"
      # 107888 : Scheduled invoices : X3-4952 (LD:17/10/16)
      #Call ECR_TRACE(mess(51,197,1)-mess(1016,182,1)-[F:SIH]NUM,0) From GESECRAN
      Call ECR_TRACE(mess(51,197,1)-mess(122,197,1)-[F:SIH]NUM,0) From GESECRAN
      # 107888 : Scheduled invoices : X3-4952 (LD:17/10/16)
  Endcase

Return
