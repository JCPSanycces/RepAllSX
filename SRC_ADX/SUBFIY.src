######################################################################################
Subprog AM_FIYEND(VALEUR)
Variable Date    VALEUR

Date DATDEB
Date DATFIN

DATFIN = VALEUR
DATDEB = [M]FIYSTR(nolign-1)

If func AFNC.PARAM("FRADGI",[M]CPY)="2"
  If DATFIN>addmonth(DATDEB, 23)
    GMESSAGE = mess(1,104,1) - ":" - format$("D:"+GFMDAT4,DATFIN) - "-" - format$("D:"+GFMDAT4,DATDEB) - "> 23" - mess(3,913,1)
    mkstat = 2
  Endif
Endif

End


