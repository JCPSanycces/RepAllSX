#<AdxTL>@(#)0.0.0.0 $Revision$ Exercices
Call OBJET("FIY",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "MODIF"        : Gosub MODIF
 When "APRES_MOD"    : Gosub APRES_MOD
 When "SETBOUT"      : Gosub SETBOUT
 When "EXEBOUT"      : Gosub EXEBOUT
 When "LIENS0"       : Gosub LIENS0
 When "LIENS"        : Gosub LIENS
 When "APRES_CHOI"   : Gosub APRES_CHOI
 When "FILGAUCHE"    : Gosub FILGAUCHE
 When "FILTRE"       : Gosub FILTRE
Endcase
Return

$OUVRE
If GMODU(2)=2  :# Compta
 If clalev([F:JOU])=0  : Local File GJOURNAL [JOU] : Endif
Endif
If clalev([F:GCM])=0  : Local File GACM [GCM]        : Endif
If clalev([F:LED])=0  : Local File GLED [LED]        : Endif
If clalev([F:FIY2])=0 : Local File FISCALYEAR [FIY2] : Endif
Local Char    SOCIETE(GLONCPY)
Local Char    CRITERE(255)
Local Integer EXERCICE , NBPER , DEL , JOUR , I_J , J_K, N, TYPREF
Local Date    DEBEX , FINEX
If CLE2<>"" : # Passé en argument
 Gosub TEST_CPY_LEG
Endif
If CLE2="" : CLE2 = GDEFSOC : Endif
Gosub TEST_CPY_LEG
Return

$TEST_CPY_LEG
# JML 19/11/98 Seulement pour sociétés juridiques
Call LECTURE("CPY",CLE2,"") From CONTOBJ
If [F:CPY]CPYLEGFLG<>2
 Raz [F:CPY], CLE2
Endif
Return

$FILGAUCHE
CRITERE += FILTRE
If CRITERE<>"" : CRITERE +="&" : Endif
CRITERE +="LEDTYPAUT<>2"
Return

$FILTRE
If FILTSUP<>"" : FILTSUP +="&" : Endif
FILTSUP +="LEDTYPAUT<>2"
Return

$APRES_MODIF
If find(COUZON,"CPY","LEDTYP")
 Gosub LECTURE From GOBJSUB
Endif
Return

$LIENS0
Call LECTURE("CPY",CLECUR2,"") From CONTOBJ
[M]CPY  = [F:CPY]CPY
CLE2    = [M]CPY
[M]ZCPY = [F:CPY]CPYNAM
Return

$LIENS
[M]OFIYSTR(nolign-1) = [F:FIY]FIYSTR
[M]OFIYEND(nolign-1) = [F:FIY]FIYEND
Return

$SETBOUT
If GREP<>"" | !CLECUR | VERROU=0
 Call VIREBOUT(CHAINE,"XO") From GOBJET
Endif
Call VIREBOUT(CHAINE,"DCAH") From GOBJET
CHAINE += "><09"
Return

$EXEBOUT
Case REP
 When "X"
  If GOK=1
   If [M]LEDTYP<>[F:FIY]LEDTYP :  Read [FIY]FIY1= [M]CPY;[M]LEDTYP : Endif
   Gosub LECTURE From GOBJSUB
  Endif
 When "O"
  If GOK=1
   If [M]LEDTYP<>[F:FIY]LEDTYP :  Read [FIY]FIY1= [M]CPY;[M]LEDTYP : Endif
   Gosub LECTURE From GOBJSUB
  Endif
Endcase
Return

$APRES_CHOI
Case REPONSE
 When GSTASUI : Gosub SUIVANT   : REPONSE = 0
 When GSTAPRE : Gosub PRECEDENT : REPONSE = 0
 When GSTAFIR : Gosub PREMIER   : REPONSE = 0
 When GSTALAS : Gosub DERNIER   : REPONSE = 0
Endcase
Return

$SUIVANT
Filter [FIY] Where CPY=[M]CPY and LEDTYPAUT<>2
Read [FIY]FIY0 > [M]CPY;[M]LEDTYP
If fstat<=2
 [M]CPY    = [F:FIY]CPY
 [M]LEDTYP = [F:FIY]LEDTYP
 Gosub LECTURE From GOBJSUB
Else
 GMESSAGE = mess(11,100,1) : # Début/Fin de fichier
Endif
Filter [FIY]
Return

$PRECEDENT
Filter [FIY] Where CPY=[M]CPY and LEDTYPAUT<>2
Read [FIY]FIY0 < [M]CPY;[M]LEDTYP
If fstat<=2
 [M]CPY    = [F:FIY]CPY
 [M]LEDTYP = [F:FIY]LEDTYP
 Gosub LECTURE From GOBJSUB
Else
 GMESSAGE = mess(11,100,1) : # Début/Fin de fichier
Endif
Filter [FIY]
Return

$PREMIER
Filter [FIY] Where CPY=[M]CPY and LEDTYPAUT<>2
Read [FIY]FIY0 First
If fstat<=2
 [M]CPY    = [F:FIY]CPY
 [M]LEDTYP = [F:FIY]LEDTYP
 Gosub LECTURE From GOBJSUB
Else
 # Début/Fin de fichier
 GMESSAGE = mess(11,100,1)
Endif
Filter [FIY]
Return

$DERNIER
Filter [FIY] Where CPY=[M]CPY and LEDTYPAUT<>2
Read [FIY]FIY0 Last
If fstat<=2
 [M]CPY    = [F:FIY]CPY
 [M]LEDTYP = [F:FIY]LEDTYP
 Gosub LECTURE From GOBJSUB
Else
 # Début/Fin de fichier
 GMESSAGE = mess(11,100,1)
Endif
Filter [FIY]
Return

$MODIF
# Recadrage des périodes sur les exercices
SOCIETE = [M]CPY
For nolign=1 To [M]BASTAB
 NOL = nolign-1
 DEL = 0
 ## On recadre les périodes ssi on a changé la date début ou la date fin de l'exercice (bug 12204)
 If [M]OFIYSTR(NOL)<>[M]FIYSTR(NOL) | [M]OFIYEND(NOL)<>[M]FIYEND(NOL)
  For [PER]PER0 Where CPY=SOCIETE & LEDTYP=[M:FIY1]LEDTYP & FIYNUM=nolign With Lock
   If fstat=1
    GOK=-1 : GLOCK="$PERIOD"-SOCIETE : Break 2
   Endif
   If DEL
    Delete [PER]
    If fstat=1
     GOK=-1 : GLOCK="$PERIOD"-SOCIETE : Break 2
    Elsif fstat>5
     GOK=0 : Call RSTA("PER",SOCIETE) From GLOCK : Break 2
    Endif
   Else
    #If [F:PER]PERNUM=1 | [PER]PEREND<[M]FIYEND(NOL)
    # Demande de recadrage des périodes par mois...
    If [F:PER]PERNUM=1 | FINEX+1<[M]FIYEND(NOL)
     If [PER]PERNUM = 1
      [F:PER]PERSTR = [M]FIYSTR(NOL)
     Else
      [F:PER]PERSTR = FINEX+1
     Endif
     [F:PER]PEREND = eomonth([F:PER]PERSTR)
     FINEX = [F:PER]PEREND
     If FINEX>=[M]FIYEND(NOL)
      [F:PER]PEREND = [M]FIYEND(NOL)
      DEL = 1
     Endif
    Elsif [PER]PEREND>=[M]FIYEND(NOL)
     [F:PER]PERSTR = FINEX+1
     [F:PER]PEREND = [M]FIYEND(NOL)
     DEL = 1
    Endif
    Rewrite [PER]
    If fstat
     GOK=0 : Call FSTA("PER") From GLOCK : Break 2
    Endif
   Endif
  Next
  If DEL=0
   Filter [PER] Where CPY=SOCIETE & LEDTYP=[M:FIY1]LEDTYP & FIYNUM=NOL+1
   Read [PER]PER0 Last
   Filter [PER]

   # Demande de recadrage des périodes par mois...
   [F:PER]PEREND = eomonth([F:PER]PERSTR)
   FINEX = [F:PER]PEREND
   If FINEX>=[M]FIYEND(NOL)
    [F:PER]PEREND = [M]FIYEND(NOL)
   Endif

   Rewrite [PER]
   If fstat
    GOK=0 : Call FSTA("PER") From GLOCK : Break
   Endif

   DEL = 0
   #NBPER = 12
   # -2 car dans la balance, la periode 0 correspond au solde à nouveau et la dernière période une pièce de cloture(IT)
   NBPER = func AFNC.ACTIV("PER")-2
   While FINEX<[M]FIYEND(NOL)
    For I=[F:PER]PERNUM+1 To NBPER
     Raz [PER]
     [F:PER]CPY       = SOCIETE
     [F:PER]LEDTYP    = [M:FIY1]LEDTYP
     [F:PER]FIYNUM    = NOL+1
     [F:PER]PERNUM    = I
     [F:PER]PERSTA    = 1
     [F:PER]PERSTOSTA = 1
     [F:PER]PERSTR    = FINEX+1
     If I=NBPER
      [F:PER]PEREND = [M]FIYEND(NOL)
     Else
      [F:PER]PEREND = eomonth([F:PER]PERSTR)
     Endif
     FINEX = [F:PER]PEREND
     If FINEX>=[M]FIYEND(NOL)
      [F:PER]PEREND = [M]FIYEND(NOL)
      DEL = 1
     Endif
     GPOINT = "AV_CREPER" : Gosub ENTREE From EXEFNC
     Write [PER]
     If fstat
      GOK=0 : Call FSTA("PER") From GLOCK : Break 2
     Endif
     If DEL : Break : Endif
    Next I
   Wend
  Endif
  If GMODU(14)=G_OUI
   If func GLOBIENS.DESYNC_CNX(SOCIETE, [M:FIY1]LEDTYP)
    GOK=0
    Return
   Endif
  Endif
 Endif
Next nolign
If GOK<1 : Return : Endif
Call FIYAUT(SOCIETE,[M:FIY1]LEDTYP,0,GOK) From SUBFIY
If !GOK : Return : Endif
Return

$APRES_MOD
For nolign=1 To [M]BASTAB
 [M]OFIYSTR(nolign-1) = [M]FIYSTR(nolign-1)
 [M]OFIYEND(nolign-1) = [M]FIYEND(nolign-1)
Next
Return


#############################################################
# Création d'un nouvel exercice
#############################################################
$CHARGE_CRE
NBPER    = 12
SOCIETE  = [M:FIY1]CPY
EXERCICE = [M:FIY1]BASTAB+1
TYPREF   = [M:FIY1]LEDTYP
DEBEX    = [M:FIY1]FIYEND([M:FIY1]BASTAB-1)+1
FINEX    = addmonth(DEBEX,NBPER)-1

Raz [M:DIA]

# chargement du bloc "Autres référentiels" de l'écran CREFIY
# La fenêtre de création d’exercices aura un tableau des référentiels initialisé à l’ensemble des référentiels
# dont la date de fin du dernier exercice est la même que celle du référentiel courant
# (on ne pourra que supprimer des référentiels)

N=1
K=0
Read [GCM]GCM0=[F:CPY]ACM
For K=0 To dim([F:GCM]LED)-1
 If [F:GCM]LED(K)<>""
  If K+1<>[M:FIY1]LEDTYP
   # lecture du dernier exercice pour la société [M]CPY et le type de référentiel K
   Filter [FIY2] Where CPY=[M:FIY1]CPY and LEDTYP=[L]K+1 and LEDTYP<>[M:FIY1]LEDTYP and LEDTYPAUT<>2
   Read [FIY2] Last
   Filter [FIY2]
   # si pas d'erreur de lecture et dates de nouvel exercice identiques, on ajoute le référentiel dans le tableau
   If fstat=0 and addmonth([FIY2]FIYEND,NBPER)=[L]FINEX
    [M:DIA]TYP([M:DIA]NBLED) = K+1
    [M:DIA]LEDFLG([M:DIA]NBLED) = 2
    [M:DIA]NBLED += 1
    N+=1
   Endif
  Endif
 Endif
Next
[M:DIA]CPY       = [M:FIY1]CPY
[M:DIA]LEDTYP    = [M:FIY1]LEDTYP
[M:DIA]ZCPY      = [M:FIY1]ZCPY
[M:DIA]FIYNUM(0) = EXERCICE
[M:DIA]DAT1(0)   = DEBEX
[M:DIA]DAT2(0)   = FINEX
[M:DIA]CREAT(0)  = 2
For I_J=1 To dim([M:DIA]DAT1)-1
 [M:DIA]FIYNUM(I_J) = [M:DIA]FIYNUM(I_J-1)+1
 [M:DIA]DAT1(I_J)   = [M:DIA]DAT2(I_J-1)+1
 [M:DIA]DAT2(I_J)   = addmonth([M:DIA]DAT1(I_J),12)-1
 [M:DIA]CREAT(I_J)  = 1
Next I_J
[M:DIA]NBLIG = dim([M:DIA]DAT1)
Return

$VALID_CRE
Call DEBTRANS From GLOCK
# Création pour le référentiel courant
For I_J=0 To [M:DIA]NBLIG-1
 If [M:DIA]CREAT(I_J)=2
  TYPREF   = [M:FIY1]LEDTYP
  EXERCICE = [M:FIY1]BASTAB+I_J+1
  DEBEX    = [M:DIA]DAT1(I_J)
  FINEX    = [M:DIA]DAT2(I_J)
  Gosub TR3
  If GOK<1 : Break : Endif

  If GMODU(14)=G_OUI
   If func GLOBIENS.DESYNC_CNX(SOCIETE, TYPREF)
    GOK=0 : Break
   Endif
  Endif
 Else
  Break
 Endif
Next I_J
If GOK<1 : Return : Endif

# Création pour les autres référentiels cochés OUI
For N=0 To [M:DIA]NBLED-1
 If [M:DIA]LEDFLG(N)=2 # Création = Oui
  TYPREF   = [M:DIA]TYP(N)
  For I_J=0 To [M:DIA]NBLIG-1
   If [M:DIA]CREAT(I_J)=2
    EXERCICE = [M:FIY1]BASTAB+I_J+1
    DEBEX    = [M:DIA]DAT1(I_J)
    FINEX    = [M:DIA]DAT2(I_J)
    Gosub TR3
    If GOK<1 : Break : Endif

    If GMODU(14)=G_OUI
     If func GLOBIENS.DESYNC_CNX(SOCIETE, TYPREF)
      GOK=0 : Break
     Endif
    Endif
   Else
    Break
   Endif
  Next I_J
 Endif
Next N
If GOK<1 : Return : Endif
Return

$TR3
GOK=1
If GMODU(2)=2  :# Compta
 Trbegin [PER], [FIY2]
Else
 Trbegin [PER], [FIY2]
Endif
 Raz [FIY2]
 [F:FIY2]CPY    = SOCIETE
 [F:FIY2]LEDTYP = TYPREF
 [F:FIY2]FIYNUM = EXERCICE
 [F:FIY2]FIYSTR = DEBEX
 [F:FIY2]FIYEND = FINEX
 [F:FIY2]FIYSTA = 1
 [F:FIY2]CREDAT = date$
 [F:FIY2]CREUSR = GUSER
 Write [FIY2]
 If fstat
  GOK=0 : Call FSTA("FIY2") From GLOCK : Goto AB_TR3
 Endif
 Call FIYAUT(SOCIETE,TYPREF,EXERCICE,GOK) From SUBFIY
 If !GOK : Goto AB_TR3 : Endif
 For I=1 To NBPER
  Raz [PER]
  [F:PER]CPY       = SOCIETE
  [F:PER]FIYNUM    = EXERCICE
  [F:PER]LEDTYP    = TYPREF
  [F:PER]PERNUM    = I
  [F:PER]PERSTA    = 1
  [F:PER]PERSTOSTA = 1
  If I=1
   [F:PER]PERSTR = DEBEX
  Else
   [F:PER]PERSTR = addmonth(DEBEX,I-1)
  Endif
  If I=NBPER
   [F:PER]PEREND = FINEX
  Else
   [F:PER]PEREND = addmonth(DEBEX,I)-1
  Endif
  GPOINT = "AV_CREPER" : Gosub ENTREE From EXEFNC
  Write [PER]
  If fstat
   GOK=0 : Call FSTA("PER") From GLOCK : Break
  Endif
  Call PERAUT(SOCIETE,TYPREF,EXERCICE,[F:PER]PERNUM,GOK) From SUBPER
  If !GOK : Break : Endif
 Next I

  # FQ110860
  If GMODU(14)=G_OUI
   If func GLOBIENS.DESYNC_CNX(SOCIETE, TYPREF)
    GOK=0
   Endif
  Endif

 If GOK<1 : Goto AB_TR3 : Endif

# Création de ETAJOU
Commit
Return

$AB_TR3
Rollback
Return

#############################################################
# Ouverture d'un exercice
#############################################################
$CHARGE_OUV
SOCIETE  = [M:FIY1]CPY
Raz [M:DIA]

J_K = 0
For I_J=0 To [M:FIY1]BASTAB-1
 If [M:FIY1]FIYSTA(I_J)=1 : # Non ouvert
  If J_K>dim([M:DIA]DAT1)-1
   Break
  Endif
  [M:DIA]FIYNUM(J_K) = [M:FIY1]FIYNUM(I_J)
  [M:DIA]DAT1(J_K)   = [M:FIY1]FIYSTR(I_J)
  [M:DIA]DAT2(J_K)   = [M:FIY1]FIYEND(I_J)
  If J_K=0
   [M:DIA]CREAT(J_K) = 2
  Else
   [M:DIA]CREAT(J_K) = 1
  Endif
  J_K += 1
 Endif
Next I_J
[M:DIA]NBLIG = J_K

# chargement du bloc "Autres référentiels" de l'écran CREFIY
# La fenêtre d’ouverture d’exercice aura un tableau des référentiels initialisé à l’ensemble des référentiels
# qui ont les mêmes dates de début et de fin que celles du référentiel courant.

N=1
K=0
Read [GCM]GCM0=[F:CPY]ACM
For K=0 To dim([F:GCM]LED)-1
 If [F:GCM]LED(K)<>""
  If K+1<>[M:FIY1]LEDTYP
   # lecture du premier exercice non ouvert pour la société [M]CPY et le type de référentiel K
   Filter [FIY2] Where CPY=[M:FIY1]CPY and LEDTYP=[L]K+1 and LEDTYP<>[M:FIY1]LEDTYP and FIYSTA=1 and LEDTYPAUT<>2
   Read [FIY2] First
   Filter [FIY2]
   # si pas d'erreur de lecture et dates de premier exercice non ouvert identiques
   # on ajoute le référentiel dans le tableau
   If fstat=0 and [FIY2]FIYSTR=[M]DAT1(0) and [FIY2]FIYEND=[M]DAT2(0)
    [M:DIA]TYP([M:DIA]NBLED)    = K+1
    [M:DIA]LEDFLG([M:DIA]NBLED) = 2
    [M:DIA]NBLED += 1
    N+=1
   Endif
  Endif
 Endif
Next

[M:DIA]CPY    = [M:FIY1]CPY
[M:DIA]ZCPY   = [M:FIY1]ZCPY
[M:DIA]LEDTYP = [M:FIY1]LEDTYP

# chargement du bloc "Autres référentiels" de l'écran CREFIY
For [LED] Where LEDTYP<>[M:FIY1]LEDTYP
 [M:DIA]NBLED += 1
Next
Return

$VALID_OUV
## N'autoriser l'ouverture que de deux exercices au plus
Local Integer LEDGEN, LEDIAS
Read [CPY]CPY0=[M:DIA]CPY
If func AFNC.PARAM("FRADGI",[M:DIA]CPY)="2"
 Call LECLEDMAIN(1,[M:DIA]CPY,LEDGEN) From CPTDIV
 Call LECLEDMAIN(3,[M:DIA]CPY,LEDIAS) From CPTDIV
 If ([M:DIA]LEDTYP=LEDGEN | [M:DIA]LEDTYP=LEDIAS) & func SUBFIY.CTLOUV([M:DIA]LEDTYP)=0
  GERR = 1
  # pas plus d'un exercice ouvert antérieur ou postérieur à l'exercice en cours
  GMESSAGE = [M:DIA]CPY-mess([M:DIA]LEDTYP,2644,1)-mess(64,101,1)
  Return
 Endif
 For N=0 To [M:DIA]NBLED-1
  If [M:DIA]LEDFLG(N)=2 & ([M:DIA]TYP(N)=LEDGEN | [M:DIA]TYP(N)=LEDIAS) & func SUBFIY.CTLOUV([M:DIA]TYP(N))=0
   GERR = 1
   # pas plus d'un exercice ouvert antérieur ou postérieur à l'exercice en cours
   GMESSAGE = [M:DIA]CPY-mess([M:DIA]TYP(N),2644,1)-mess(64,101,1)
   Break
  Endif
 Next
 If GERR
  Return
 Endif
Endif

Call DEBTRANS From GLOCK
For I_J=0 To [M:DIA]NBLIG-1
 If [M:DIA]CREAT(I_J)=2
  TYPREF   = [M:FIY1]LEDTYP
  EXERCICE = [M:DIA]FIYNUM(I_J)
  DEBEX    = [M:DIA]DAT1(I_J)
  FINEX    = [M:DIA]DAT2(I_J)
  Gosub TR4
  If GOK<1 : Break : Endif
 Else
  Break
 Endif
Next I_J

# Ouverture d'exercices pour les autres référentiels cochés OUI
For N=0 To [M:DIA]NBLED-1
 If [M:DIA]LEDFLG(N)=2 # Création = Oui
  TYPREF   = [M:DIA]TYP(N)
  For I_J=0 To [M:DIA]NBLIG-1
   If [M:DIA]CREAT(I_J)=2
    EXERCICE = [M:DIA]FIYNUM(I_J)
    DEBEX    = [M:DIA]DAT1(I_J)
    FINEX    = [M:DIA]DAT2(I_J)
    Gosub TR4
    If GOK<1 : Break : Endif
   Else
    Break
   Endif
  Next I_J
 Endif
Next N
Return

$TR4
GOK=1
Trbegin [FIY2]
 Readlock [FIY2]FIY0=[L]SOCIETE;[L]TYPREF;[L]EXERCICE
 If fstat=1
  GOK = -1 : GLOCK = "$FISCALYEAR"-SOCIETE-num$(EXERCICE) : Goto ROLL_TR4
 Elsif fstat
  GOK = 0 : Call RSTA("FIY",SOCIETE-num$(EXERCICE)) From GLOCK : Goto AB_TR4
 Endif
 [F:FIY2]FIYSTA = 2     : # Ouvert
 [F:FIY2]UPDDAT = date$
 [F:FIY2]UPDUSR = GUSER
 Rewrite [FIY2]
 If fstat
  GOK=0 : Call FSTA("FIY") From GLOCK : Goto AB_TR4
 Endif
 Call FIYAUT(SOCIETE,TYPREF,EXERCICE,GOK) From SUBFIY
 If !GOK : Goto AB_TR4 : Endif
Commit
Return

$AB_TR4
Rollback
Return

$ROLL_TR4
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR4 : Endif

##############################################################################
Subprog FIYAUT(SOC,REF,EXE,OK)
Value Char SOC()
Value Integer REF
Value Integer EXE
Variable Integer OK

If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif
If clalev([F:PER2])=0 : Local File PERIOD     [PER2] : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif
If clalev([F:FIY2])=0 : Local File FISCALYEAR [FIY2] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif

Local Integer N
Local Char FILTRE(50)

If EXE>0
 FILTRE = "FIYNUM="+num$([L]EXE)
Else
 FILTRE = "1=1"
Endif

OK=1
For [CPY] Where CPY=SOC
 Read [GCM]GCM0=[F:CPY]ACM
 # Pour tous les types de référentiels
 For N=1 To len(mess(0,2644,1))
  If [F:GCM]LED(N-1)<>"" & [F:GCM]CFMAUT(N-1) = 2 & [F:GCM]ORILEDTYP(N-1)=[L]REF

   # Pour tous les exercices du Référentiel de Référence / d'origine
   Delete [FIY2] Where CPY=[F:CPY]CPY and LEDTYP=N and evalue(FILTRE)
   If fstat
    OK=0 : Call FSTA("FIY") From GLOCK : Break 2
   Endif

   For [FIY]FIY0 Where CPY=[F:CPY]CPY and LEDTYP=[F:GCM]ORILEDTYP(N-1) and evalue(FILTRE)
    Read [FIY2]FIY0 = [F:FIY]CPY;N;[F:FIY]FIYNUM
    If fstat
     Raz [FIY2]
     [F:FIY2] = [F:FIY]
     [F:FIY2]LEDTYP = N
     [F:FIY2]LEDTYPAUT = 2
     [F:FIY2]CREDAT = date$
     [F:FIY2]CREUSR = GUSER
     Write [FIY2]
     If fstat
      Call ECR_TRACE(mess(13,100,1)-"FISCALYEAR"-":"-[F:FIY2]CPY-num$([F:FIY2]LEDTYP)-num$([F:FIY2]FIYNUM),1) From GESECRAN
      GOK = 0 : Break 3
     Endif
    Endif

    # Pour toutes les périodes du Référentiel de Référence / d'origine
    Delete [PER2] Where CPY=[F:CPY]CPY and LEDTYP=N and FIYNUM=[F:FIY]FIYNUM
    If fstat
     OK=0 : Call FSTA("PER") From GLOCK : Break 2
    Endif
    For [PER]PER0 Where CPY=[F:CPY]CPY and LEDTYP=[F:GCM]ORILEDTYP(N-1) and FIYNUM=[F:FIY]FIYNUM
     Read [PER2]PER0 = [F:PER]CPY;N;[F:PER]FIYNUM;[F:PER]PERNUM
     If fstat
      Raz [PER2]
      [F:PER2] = [F:PER]
      [F:PER2]LEDTYP = N
      [F:PER2]LEDTYPAUT = 2
      Write [PER2]
      If fstat
       OK=0 : Call FSTA("PER") From GLOCK : Break 3
      Endif
     Endif
    Next
   Next
  Endif
 Next
Next
Close Local File [CPY],[GCM],[PER],[PER2]
End

##############################################################################
Funprog CTLOUV(TYPLED)
Value Integer TYPLED
Local Integer CUREXO, I_J, NBROPN

If !clalev([F:FIY2]) : Local File FISCALYEAR [FIY2] : Endif

## Nombre d'exercices ouverts
Filter [FIY2] Where CPY=[M]CPY & LEDTYP=TYPLED & FIYSTA=2
NBROPN = rowcount([FIY2])

# date$ updated by datesyst
Filter [FIY2] Where CPY=[M]CPY & LEDTYP=TYPLED & FIYSTR<=datesyst & FIYEND>=datesyst
Read [FIY2]FIY0 First
Filter [FIY2]
If fstat : End 0 : Endif
CUREXO = [F:FIY2]FIYNUM

For I_J=0 To [M:DIA]NBLIG-1
 If [M:DIA]CREAT(I_J)=2
  If [M:DIA]FIYNUM(I_J)<CUREXO-1 | [M:DIA]FIYNUM(I_J)>CUREXO+1
   NBROPN = 99
  Else NBROPN +=1
  Endif
  If NBROPN>2 : Break : Endif
 Endif
Next
If NBROPN>2
 End 0
Else
 End 1
Endif
End

##############################################################################
## Etiquettes masque [FIY1]
##############################################################################
Subprog C_CPY(VALEUR)
Variable Char VALEUR
Call CONTALLFCY(VALEUR) From CPTSUB
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer OPTION
OPTION = 6
Call LEDTYP_CHOICE([M:FIY1]CPY,OPTION) From CPTDIV
End

Subprog AS_FIYEND(DAT)
Variable Date DAT
Gosub SETNOL
If [M]FIYSTA(NOL)>2 | ([M]FIYSTA(NOL)=2 & (NOL<>[M]BASTAB-1 & [M]FIYSTA(NOL+1)<>1))
 # Ouvert | ( Ouvert & suivant<>Non ouvert )
 mkstat=2 : End
Endif
End

Subprog C_FIYEND(DAT)
Variable Date DAT
Local Integer I, JOUR, AN
Gosub SETNOL
For [PER]PER0 Where CPY=[M]CPY & FIYNUM=NOL+1
 If DAT<[F:PER]PEREND
  If [F:PER]PERSTA>1 : # Non ouvert
   #### La période du xx/xx/xx au yy/yy/yy est ouverte
   GMESSAGE = mess(4,101,1)-format$("D:"+GFMDAT4,[F:PER]PERSTR)-mess(95,100,1)
&            -format$("D:"+GFMDAT4,[F:PER]PEREND)-mess(6,101,1)
   #MAE, bg 70563 mkstat = 2 : End
   mkstat = 2 : Break
  Endif
  Break
 Endif
Next
If mkstat : End : Endif

If [M]FIYEND(NOL)<>DAT
 For [PER]PER0 Where CPY=[M]CPY & FIYNUM=NOL+1
  If [F:PER]PERSTA=3
   GMESSAGE = mess(59,101,1)-"\"-format$("D:"+GFMDAT4,[F:PER]PERSTR)-"-"-format$("D:"+GFMDAT4,[F:PER]PEREND)
   mkstat = 2 : Break
  Endif
 Next
Endif
If mkstat : End : Endif

If [M]FIYEND(NOL)<>DAT
 [M]FIYEND(NOL) = DAT
 For I=NOL+1 To [M]BASTAB-1
  JOUR = [M]FIYEND(I)-[M]FIYSTR(I)
  [M]FIYSTR(I) = [M]FIYEND(I-1)+1
  [M]FIYEND(I) = [M]FIYSTR(I)+JOUR
  # bug 14810 : la date de fin était mal calculée à cause des 29 février
  If 2 >= month([M]FIYSTR(I))  :# détermine où se situe le mois de février dans le nouvel intervalle
    AN = year([M]FIYSTR(I))
  Else
    AN = year([M]FIYEND(I))
  Endif
  # ajouter ou enlever 1 jour selon la présence du 29/02 dans l'exercice
  # avant (JOUR=365 ou 364) et après (month(gdat$())) le recalcul des dates
  # (month(gdat$(29,2,nn))=3 signifie que le 29/02 de l'année nn n'existe pas)
  If JOUR = 365
    If month(gdat$(29,2,AN))=3 : [M]FIYEND(I)-=1 : Endif
  Elsif JOUR = 364
    If month(gdat$(29,2,AN))=2 : [M]FIYEND(I)+=1 : Endif
  Endif
  Affzo FIYSTR(I),FIYEND(I)
 Next I
Endif
End

Subprog C_BASTAB
End

$SETNOL
Local Integer NOL
NOL=nolign-1
Return

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Raz [M]LEDTYP
End

