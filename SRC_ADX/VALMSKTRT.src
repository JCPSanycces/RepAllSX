#<AdxTL>@(#)7.0.0.0 $Revision$
#################################################################################
## VALMSKTRT Ecriture du traitement automatique
#################################################################################
$VALTRT
IPROG  = 1
PRIACT = 0
Gosub TRT_DEB
Gosub TITRES
Gosub VISU
Gosub HARDCOP
For B=1 To BLC_NBR
 For L=1 To LIG_NBR(B)
  If LIG_PRO(B,L)<>IPROG
   Gosub TRT_FIN
   IPROG = LIG_PRO(B,L)
   Gosub TRT_DEB
  Endif
  Gosub EVENEMENT
  For TYPACT=1 To MAXTYP
   If LIG_SAI(B,L)=1 or LIG_ZON(B,L)=BLC_BAS(B) or find(TYPACT,2,3,6)
    # Avant zone, init et aprû´s zone, et variable de bas de tableau
    DA = LIG_PTA(B,L)
    FA = LIG_PTA(B,L)+LIG_ACT(B,L)-1
    K = find(TYPACT,ACT_TYP(DA..FA))
    If K
     A = DA+K-1
     Gosub ETIQUETTE
    Endif
   Endif
  Next TYPACT
 Next L
Next B
Gosub TRT_FIN
If IPROG<NBPROG
 IPROG += 1
 Gosub TRT_DEB
 Gosub TRT_FIN
Endif
Return

$HARDCOP
Wrseq "$HARDCOP"
Wrseq "Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)"
Local Integer I1
For I1=1 To BLC_NBR
 If BLC_TYP(I1)<>5
  Wrseq "X1("+num$(I1-1)+")="+num$(BLC_X(I1))+" : X2("+num$(I1-1)+")="+num$(BLC_X(I1)+BLC_NCO(I1)-1)
&    +" : Y1("+num$(I1-1)+")="+num$(BLC_Y(I1))+" : Y2("+num$(I1-1)+")="+num$(BLC_Y(I1)+BLC_NLI(I1)-1)
 Endif
Next I1
Wrseq "Return"
Wrseq
Return

$TRT_MES
Wrseq '$_AFF'
Wrseq 'If GIMPORT'
Wrseq ' Gosub AFF From GSAISIE'
Wrseq 'Else'
Wrseq ' If GMESSAGE <>""'
Wrseq '  Gosub ERR From GSAISIE'
Wrseq ' Else'
Wrseq '  Raz GERR , GZNUM'
Wrseq ' Endif'
Wrseq 'Endif'
Wrseq 'Return'
Wrseq
Return

$TRT_DEB
NOMPROG = "W"+num$(IPROG)+TET_AUT
FICSRC = filpath("TRT",NOMPROG,"src",APPLI)
Openo FICSRC , 0
adxifs = ""
adxirs = chr$(10)
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq "#"-MAGIC
Wrseq "#"-mess(15,123,1)-ECRAN-TET_TXT : # Gestion du masque
Wrseq
Gosub TRT_MES
Return

$TRT_FIN
If IPROG=NBPROG
 Gosub TIT_COL
 Gosub CHG_STY
Else
 If IPROG=1
  Wrseq "$CHG_STY"
  Wrseq "Gosub CHG_STY From W"+num$(NBPROG)+TET_AUT
  Wrseq "Return"
  Wrseq
 Endif
 Wrseq "$TIT_COL"
 Wrseq "Gosub TIT_COL From W"+num$(NBPROG)+TET_AUT
 Wrseq "Return"
 Wrseq
Endif
Wrseq
Openo
Call VALID("TRT",NOMPROG,APPLI,OK) From VALMSKSUB
Return

####################################################
## Gûˋnûˋration des titres des champs et blocs ûˋvaluûˋs
####################################################
$TITRES
Wrseq "$HORODAT"
Wrseq "Local Date    A_DATE"
Wrseq "Local Char    A_HEURE(10) , A_USER(10)"
Wrseq "Local Char    A_STAMP(15)"
Wrseq "A_DATE  = [";format$(GFMD,JOUR)+"]"
Wrseq 'A_HEURE = "';HEURE;'"'
Wrseq 'A_USER  = "';GUSER;'"'
Wrseq 'A_STAMP = "';format$('D:YYYYMMDD',JOUR);ctrans(HEURE,':','');'"'
Wrseq "Return"
Wrseq

Wrseq "$TITRES"
For B=1 To BLC_NBR
 If BLC_EVL(B)<>""
  Wrseq "Chgtbk [M:";TET_ABR+"]";BLC_RNG(B);" With ";vireblc(format$("KT:250X",BLC_EVL(B)),2)
 Endif
 If BLC_TYP(B)=2
  For L=1 To LIG_NBR(B)
   If LIG_EVL(B,L)<>"" & left$(LIG_EVL(B,L),1)<>"#"
    If instr(1,format$("KT:250X",LIG_EVL(B,L)),"indice") & LIG_DIM(B,L)>1
     Wrseq "For indice=0 To"-num$(LIG_DIM(B,L)-1)
     Wrseq " Chgtzn [M:";TET_ABR;"]";LIG_ZON(B,L);"(indice) With ";vireblc(format$("KT:250X",LIG_EVL(B,L)),2)
     Wrseq "Next indice"
    Else
     Wrseq "Chgtzn [M:";TET_ABR;"]";LIG_ZON(B,L);" With ";vireblc(format$("KT:250X",LIG_EVL(B,L)),2)
    Endif
   Endif
  Next L
 Endif
Next B
Wrseq "Return"
Wrseq

If find(1,BLC_TYP(1..BLC_NBR))
 Wrseq '$CHG_FMT'
 Wrseq 'Case zoncou'
 For B=1 To BLC_NBR
  If BLC_TYP(B)=1
   Wrseq ' When "'+BLC_BAS(B)+'"'
   Wrseq '  If [M]'+BLC_BAS(B)+'=0'
   For L=1 To LIG_NBR(B)
    If left$(LIG_FMT(B,L),1)="="
     Wrseq '   If '+vireblc(format$("KT:250X",right$(LIG_FMT(B,L),2)),2)+'<>""'
     Wrseq '    Chgfmt'-LIG_ZON(B,L)-'With'-vireblc(format$("KT:250X",right$(LIG_FMT(B,L),2)),2)
     Wrseq '   Else'
     Wrseq '    Chgfmt'-LIG_ZON(B,L)-'With "-K:1X"'
     Wrseq '   Endif'
    Endif
   Next L
   Wrseq '  Endif'
  Endif
 Next B
 Wrseq 'Endcase'
 Wrseq 'Return'
 Wrseq
Endif
Return

###########################################################
$CHG_STY
Wrseq "$CHG_STY"
SPA = 0
For B=1 To BLC_NBR
 If sum(LIG_STC(B,1..LIG_NBR(B)))<>""
  If BLC_TYP(B)=1
   Wrseq space$(SPA);"For nolign=1 To [M:"+TET_ABR+"]"+BLC_BAS(B)
   SPA += 1
  Endif
  For L=1 To LIG_NBR(B)
   If LIG_STC(B,L)<>""
    K = 0
    J = 0
    CHAMP = "[M:"+TET_ABR+"]"+LIG_ZON(B,L)
    If BLC_TYP(B)=1 : CHAMP += "(nolign-1)" : Endif
    For [ASL]ASL0 Where COD=LIG_STC(B,L)
     K += 1
     If [F:ASL]CND<>""
      If K=1 : Wrseq space$(SPA);"If"; : Else : Wrseq space$(SPA);"Elsif"; : Endif
      FORMULE = vireblc(format$("KT:250X",[F:ASL]CND),2)
      Repeat
       I = instr(1,FORMULE,"zc")
       If I
        FORMULE = left$(FORMULE,I-1)+CHAMP+right$(FORMULE,I+2)
       Endif
      Until I=0
      Repeat
       I = instr(1,FORMULE,"zoncou")
       If I
        FORMULE = left$(FORMULE,I-1)+'"'+'[M:'+TET_ABR+']'+LIG_ZON(B,L)+'"'+right$(FORMULE,I+6)
       Endif
      Until I=0
      Wrseq " ";FORMULE
     Else
      J = 1
      Wrseq space$(SPA);"Else"
     Endif
     If [F:ASL]STY="EMPTY"
      Wrseq space$(SPA+1);'# Without style'
     Else
      Wrseq space$(SPA+1);'Chgstl ';CHAMP;
      If [F:ASL]STY<>""
       Wrseq ' With "'+[F:ASL]STY+'"'
      Else
       Wrseq ' With ""'
      Endif
     Endif
    Next ASL
    If K<>0
     If J=0
      Wrseq space$(SPA);"Else"
      Wrseq space$(SPA+1);'Chgstl ';CHAMP;
      Wrseq ' With ""'
     Endif
     Wrseq space$(SPA);"Endif"
    Endif
   Endif
  Next L
  If BLC_TYP(B)=1
   SPA -= 1
   Wrseq space$(SPA);"Next nolign"
  Endif
 Endif
Next B
Wrseq "Return"
Wrseq
Return

####################################################
## Gûˋnûˋration Visualisation ûˋcran
####################################################
$VISU
Wrseq '$VISU'
Wrseq 'Local Integer A_REPONSE'
Wrseq 'Global Integer GPRE_VIEW'
Wrseq 'If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif'
Wrseq 'Local Mask'-TET_AUT-'['+TET_ABR+']'
Wrseq 'Gosub HORODAT'
Wrseq 'Local Inpbox "'+TET_AUT+'" From GFONCTION At A_STAMP With A_WINDPREV Mask ['+TET_ABR+'] As [SIM_]'
For B=1 To BLC_NBR
 If BLC_TYP(B)<5
  Wrseq 'Grizo ['+TET_ABR+']'+num$(BLC_RNG(B))
 Endif
Next B
Wrseq 'Boxact [SIM_]'
Wrseq 'Gosub TITRES'
Wrseq 'Boxinp [SIM_] Using A_REPONSE'
Wrseq 'Close Local Inpbox [SIM_]'
Wrseq 'Close Local Mask ['+TET_ABR+']'
Wrseq 'Kill GPRE_VIEW'
Wrseq 'Return'
Wrseq
Return

####################################################
## Gûˋnûˋration des ûˋtiquettes des champs
####################################################

$ETIQUETTE

## Cas particulier pour appeler l'APRES_MODIF des modû´les GOBJET, GSAISIE...

If TYPACT=7 : # Aprû´s_modif
 Wrseq "$AMM_"+LIG_ZON(B,L)
 If LIG_FNU(B,L)=TABLO | LIG_TYP(B,L)=FMTVAR | find(LIG_TYI(B,L),9)
  Wrseq "Call AM_"+LIG_ZON(B,L)
 Else
  Wrseq "Call AM_"+LIG_ZON(B,L)+"(zc)"
 Endif
 Wrseq "If !mkstat & GOBJET"
 Wrseq ' zoncou = "'+LIG_ZON(B,L)+'" : Gosub APRES_MODIF From =GPROGRAMME'
 Wrseq "Endif"
 Wrseq "Return"
 Wrseq
Endif

# Cas particulier pour ne pas passer d'argument dans le cas des tableaux et formats variables
# Cas particulier pour l'avant_zone pour faire un gosub au lieu d'un call (optimisation)

If LIG_FNU(B,L)=TABLO | LIG_TYP(B,L)=FMTVAR | find(LIG_TYI(B,L),9)
 Wrseq "Subprog "+ACT_ETQ(A)+LIG_ZON(B,L)
 Gosub PROGRAMME
 Wrseq "End"
Elsif TYPACT=2 : # Avant_zone
 Wrseq "$"+ACT_ETQ(A)+LIG_ZON(B,L)
 Gosub PROGRAMME
 Wrseq "Return"
Else
 Wrseq "Subprog "+ACT_ETQ(A)+LIG_ZON(B,L)+"(VALEUR)"
 Case LIG_TYI(B,L)
  When 1       : Wrseq "Variable Integer VALEUR"
  When 7       : Wrseq "Variable Char    VALEUR()"
  When 8       : Wrseq "Variable Date    VALEUR"
  When 9       : Wrseq "Variable Blbfile VALEUR"
  When 10      : Wrseq "Variable Clbfile VALEUR"
  When Default : Wrseq "Variable Decimal VALEUR"
 Endcase
 Gosub PROGRAMME
 Wrseq "End"
Endif
Wrseq
Return

$PROGRAMME
SPA  = 0
NBIF = 0
If LIG_FNU(B,L)=TABLO
 Wrseq space$(SPA)+"Local Decimal BASPAG"
Endif
Gosub AZC
FLACTION = 0
FLCONT   = 0
FLSAI    = 0
Case TYPACT
 When  1 : Gosub INIT_BOUTON
 When  2 : Gosub AVANT_ZONE
 When  3 : Gosub INIT
 When  4 : Gosub AVANT_SAISIE
 When  5 : Gosub CONTROLE
 When  6 : Gosub APRES_ZONE
 When  7 : Gosub APRES_MODIF
 When  8 : Gosub SELECTION
 When  9 : BOUT =  1 : Gosub BOUTON
 When 10 : BOUT =  2 : Gosub BOUTON
 When 11 : BOUT =  3 : Gosub BOUTON
 When 12 : BOUT =  4 : Gosub BOUTON
 When 13 : Gosub AVANT_LIGNE
 When 14 : Gosub APRES_LIGNE
 When 15 : BOUT =  5 : Gosub BOUTON
 When 16 : BOUT =  6 : Gosub BOUTON
 When 17 : BOUT =  7 : Gosub BOUTON
 When 18 : BOUT =  8 : Gosub BOUTON
 When 19 : BOUT =  9 : Gosub BOUTON
 When 20 : BOUT = 10 : Gosub BOUTON
 When 21 : BOUT = 11 : Gosub BOUTON
 When 22 : BOUT = 12 : Gosub BOUTON
 When 23 : BOUT = 13 : Gosub BOUTON
 When 24 : BOUT = 14 : Gosub BOUTON
 When 25 : BOUT = 15 : Gosub BOUTON
 When 26 : BOUT = 16 : Gosub BOUTON
 When 27 : BOUT = 17 : Gosub BOUTON
 When 28 : BOUT = 18 : Gosub BOUTON
 When 29 : BOUT = 19 : Gosub BOUTON
 When 30 : BOUT = 20 : Gosub BOUTON
 When 31 : Gosub CLIC
 When 51 : Gosub SELECTION_AVANCEE
 When 52 : Gosub PROPRIETE
Endcase
If left$(ECRAN,8)<>"DEBUGGER"
 #Wrseq space$(SPA);"Gosub AFF From GSAISIE" : # mb pour ûˋviter de polluer GMESSAGE
  Wrseq space$(SPA);"Gosub _AFF" : # mb 3.6.13 Pour avoir des temps de rûˋponse monstrueux
Endif
Return

####################################################
## Types d'action
####################################################

####################################################
## Avant bouton
####################################################
$INIT_BOUTON
Gosub ACTION
Return

####################################################
## Avant zone
####################################################
$AVANT_ZONE

# Valeur par dûˋfaut saisie ou du type de donnûˋes en "*"

If find("%DEFOBL",ACT_ACT(DA..FA))
 If LIG_FNU(B,L)=TABLO
  Wrseq space$(SPA);"[M]";LIG_ZON(B,L);
 Else
  Wrseq space$(SPA);AZC;
 Endif
 Wrseq " = ";vireblc(format$("KT:80X",right$(LIG_INI(B,L),2)),2)
Endif

# ContrûÇle d'accû´s

If find("%ACCAVT",ACT_ACT(DA..FA))
 Wrseq space$(SPA);'Call ACCES2("'+LIG_ACC(B,L)+'") From OBJDIV'
Endif

# Init du lien

If find("%INILNK",ACT_ACT(DA..FA))
 L1 = LIG_SUI(B,L)
 If LIG_ACC(B,L1)<>""
  Wrseq space$(SPA);'Call ACCES2("'+LIG_ACC(B,L1)+'") From OBJDIV'
  Wrseq space$(SPA);'If mkstat : End : Endif'
 Endif

 Case LIG_ZTY(B,L)

  When FMTATX : # Texte superviseur

   PAROBJ = ""
   K = find("%CNTOBJ",ACT_ACT(LIG_PTA(B,L1)..LIG_PTA(B,L1)+LIG_ACT(B,L1)-1))
   If K
    A = LIG_PTA(B,L1)+K-1
    PARAM = ""
    If LIG_ZSP(B,L1)>0
     For P=1 To ACT_PAR(A)
      If PAR_COD(A,P)=LIG_OBJ(B,L1)
       PARAM = PAR_VAL(A,P) : Break
      Endif
     Next P
    Endif
    Gosub PARNUM
    PAROBJ = PARAM
   Endif
   If PAROBJ="" : PAROBJ = '""' : Endif

   Wrseq space$(SPA);"If clalev([F:";LIG_ABR(B,L1);"])=0 : Local File ";
   Wrseq LIG_FIC(B,L1);" [";LIG_ABR(B,L1);"] : Endif"

   If LIG_FIC(B,L1)=TET_FIC
    Wrseq space$(SPA);"Local File ";LIG_FIC(B,L1);" [F_]"
    Wrseq space$(SPA);"[F:F_]=[F:";LIG_ABR(B,L1);"]"
   Endif

   Wrseq space$(SPA);'Call LECTURE("';LIG_OBJ(B,L1);'",[M]';LIG_ZON(B,L1);'(indice),';PAROBJ;') From CONTOBJ'
   Wrseq space$(SPA);"Call TEXTE([F:";LIG_ABR(B,L1);"]";LIG_ZLI(B,L1);",";AZC;") From OBJDIV"

   If LIG_FIC(B,L1)=TET_FIC
    Wrseq space$(SPA);"[F:";LIG_ABR(B,L1);"]=[F:F_]"
    Wrseq space$(SPA);"Close Local File [F_]"
   Endif

  When FMTAXX,FMTADI,"AX1","AX2","AX3" : # texte traduisible

   PAROBJ = ""
   K = find("%CNTOBJ",ACT_ACT(LIG_PTA(B,L1)..LIG_PTA(B,L1)+LIG_ACT(B,L1)-1))
   If !K
    K = find("%SELOBJ",ACT_ACT(LIG_PTA(B,L1)..LIG_PTA(B,L1)+LIG_ACT(B,L1)-1))
    If !K
     K = find("%PROOBJ",ACT_ACT(LIG_PTA(B,L1)..LIG_PTA(B,L1)+LIG_ACT(B,L1)-1))
    Endif
   Endif
   If K
    A = LIG_PTA(B,L1)+K-1
    PARAM = ""
    If LIG_ZSP(B,L1)>0
     For P=1 To ACT_PAR(A)
      If PAR_COD(A,P)=LIG_OBJ(B,L1)
       PARAM = PAR_VAL(A,P) : Break
      Endif
     Next P
    Endif
    If PARAM<>"" : Gosub PARNUM : Endif
    PAROBJ = PARAM
   Endif
   PARFIC = ""
   PARZON = ""
   K = find("%INILNK",ACT_ACT(LIG_PTA(B,L)..LIG_PTA(B,L)+LIG_ACT(B,L)-1))
   If K
    A = LIG_PTA(B,L)+K-1
    For P=1 To ACT_PAR(A)
     Case PAR_COD(A,P)
      When "TABLE1" : PARAM = PAR_VAL(A,P) : If PARAM<>"" : Gosub PARNUM : Endif : PARFIC = PARAM
      When "ZONE"   : PARAM = PAR_VAL(A,P) : If PARAM<>"" : Gosub PARNUM : Endif : PARZON = PARAM
     Endcase
    Next P
   Endif
   If PARFIC="" or PARZON=""
    PARFIC = '"'+LIG_FIC(B,L1)+'"'
    PARZON = '"'+LIG_ZLI(B,L1)+'"'
   Endif
   If PAROBJ=""
    Wrseq space$(SPA);'Call LECTEXTRA(';AZC;',';PARFIC;',';PARZON;',num$([M]';LIG_ZON(B,L1);'(indice)),"") From ATEXTRA'
   Else
    Wrseq space$(SPA);'Call LECTEXTRA(';AZC;',';PARFIC;',';PARZON;',';PAROBJ;',num$([M]';LIG_ZON(B,L1);'(indice))) From ATEXTRA'
   Endif

  When Default : # Lien normal

   PAROBJ = ""
   K = find("%CNTOBJ",ACT_ACT(LIG_PTA(B,L1)..LIG_PTA(B,L1)+LIG_ACT(B,L1)-1))
   If K
    A = LIG_PTA(B,L1)+K-1
    PARAM = ""
    For P=1 To ACT_PAR(A)
     If PAR_COD(A,P)=LIG_OBJ(B,L1)
      PARAM = PAR_VAL(A,P) : Break
     Endif
    Next P
    Gosub PARNUM
    PAROBJ = PARAM
   Endif
   If PAROBJ="" : PAROBJ = '""' : Endif

   Wrseq space$(SPA);'If clalev([F:'+LIG_ABR(B,L1)+'])=0';
   K = find(LIG_FIC(B,L1),TABCPT(1..CPTNB))
   If K
    Wrseq
    Wrseq space$(SPA);' If dim(GTABCPT)>0 & GTABCPT<>"" & find("'+OBJCPT(K)+'",GABRCPT(1..GNBTABCPT))'
    Wrseq space$(SPA);'  Local File =GTABCPT+"'+LIG_FIC(B,L1)+'" ['+LIG_ABR(B,L1)+']'
    Wrseq space$(SPA);' Else '
    Wrseq space$(SPA);'  Local File '+LIG_FIC(B,L1)+' ['+LIG_ABR(B,L1)+']'
    Wrseq space$(SPA);' Endif'
   Else
    Wrseq space$(SPA);' : Local File '+LIG_FIC(B,L1)+' ['+LIG_ABR(B,L1)+'] : ';
   Endif
   Wrseq space$(SPA);'Endif'

   If GPRODUIT=4 : # LOAN
    Wrseq space$(SPA);"Local Char PAROBJ(250)(16)"
    K = find("%CNTOBJ",ACT_ACT(LIG_PTA(B,L1)..LIG_PTA(B,L1)+LIG_ACT(B,L1)-1))
    If K
     A = LIG_PTA(B,L1)+K-1
     For P=1 To ACT_PAR(A)
      If left$(PAR_COD(A,P),len(LIG_OBJ(B,L1)))=LIG_OBJ(B,L1)
       K = val(right$(PAR_COD(A,P),len(LIG_OBJ(B,L1))+1))
       PARAM = PAR_VAL(A,P)
       Gosub PARNUM
       Wrseq space$(SPA);"PAROBJ(";num$(K);") = ";PARAM
      Endif
     Next P
    Endif
    PAROBJ = "PAROBJ"
   Endif

   If LIG_FIC(B,L1)=TET_FIC
    K = find(LIG_FIC(B,L1),TABCPT(1..CPTNB))
    If K
     Wrseq space$(SPA);' If dim(GTABCPT)>0 & GTABCPT<>"" & find("'+OBJCPT(K)+'",GABRCPT(1..GNBTABCPT))'
     Wrseq space$(SPA);'  Local File =GTABCPT+"'+LIG_FIC(B,L1)+'" [F_]'
     Wrseq space$(SPA);' Else '
     Wrseq space$(SPA);'  Local File '+LIG_FIC(B,L1)+' [F_]'
     Wrseq space$(SPA);' Endif'
    Else
     Wrseq space$(SPA);'Local File '+LIG_FIC(B,L1)+' [F_] '
    Endif
    Wrseq space$(SPA);"[F:F_]=[F:";LIG_ABR(B,L1);"]"
   Endif

   Wrseq space$(SPA);'Call LECTURE("';LIG_OBJ(B,L1);'",num$([M]';LIG_ZON(B,L1);'(indice)),';PAROBJ;') From CONTOBJ'
   Wrseq space$(SPA);AZC;" = [F:";LIG_ABR(B,L1);"]";LIG_ZLI(B,L1)

   If LIG_FIC(B,L1)=TET_FIC
    Wrseq space$(SPA);"[F:";LIG_ABR(B,L1);"]=[F:F_]"
    Wrseq space$(SPA);"Close Local File [F_]"
   Endif

 Endcase
Endif

# Init des variables pour les formats devises et unitûˋs

If find("%BASDEV",ACT_ACT(DA..FA))
 For P=1 To BLC_PAR(B)
  Wrseq space$(SPA);BLC_PVA(B,P);' = "EUR"'
  Wrseq space$(SPA);BLC_PVA(B,P);" = ";BLC_PVL(B,P)
 Next P
 Wrseq space$(SPA);"Gosub SETDEV From TRTDIV"
Endif

# Tableau avec intitulûˋ ûˋvaluûˋ => appel û  TIT_COL

If find("%BASEVL",ACT_ACT(DA..FA))
 Wrseq space$(SPA);"If adxgtb=1 & !GORITITCOL & nolign=1"
 Wrseq space$(SPA);" Local Char BASPAG(10)"
 Wrseq space$(SPA);' BASPAG = "'+BLC_BAS(B)+'" : Gosub TIT_COL From W'+num$(NBPROG)+ECRAN
 Wrseq space$(SPA);"Endif"
Endif

Gosub ACTION

# Format variable

If find("%FMTVAR",ACT_ACT(DA..FA))
 If LIG_FMT(B,L)<>""
  Wrseq space$(SPA);"If ";vireblc(format$("KT:250X",right$(LIG_FMT(B,L),2)),2)+'<>""'
  Wrseq space$(SPA);" Chgfmt [M]";LIG_ZON(B,L);"(indice) With ";vireblc(format$("KT:250X",right$(LIG_FMT(B,L),2)),2)
  Wrseq space$(SPA);"Else"
  Wrseq space$(SPA);" Chgfmt [M]";LIG_ZON(B,L);'(indice) With "-K:1X"'
  Wrseq space$(SPA);"Endif"
 Elsif LIG_FTY(B,L)='="K'
  Wrseq space$(SPA);"If"-right$(LIG_FCH(B,L),3)+'<>""'
  Wrseq space$(SPA);" Chgfmt [M]";LIG_ZON(B,L);"(indice) With ";
  Wrseq vireblc(format$("KT:250X",right$(LIG_FTY(B,L),2)+LIG_FOP(B,L)+":"+LIG_FCH(B,L)),2)
  Wrseq space$(SPA);"Else"
  Wrseq space$(SPA);" Chgfmt [M]";LIG_ZON(B,L);'(indice) With "-K:1X"'
  Wrseq space$(SPA);"Endif"
 Else
  Wrseq space$(SPA);"Chgfmt [M]";LIG_ZON(B,L);"(indice) With ";
  Wrseq vireblc(format$("KT:250X",right$(LIG_FTY(B,L),2)+LIG_FOP(B,L)+":"+LIG_FCH(B,L)),2)
 Endif
Endif

Return

####################################################
## Initialisation
####################################################
$INIT
If LIG_ZON(B,L)=BLC_BAS(B)
 Wrseq space$(SPA);"If varinit([M]"+LIG_ZON(B,L)+")=0" : SPA += 1
Else
 Wrseq space$(SPA);"If varinit([M]"+LIG_ZON(B,L)+",indice)=0" : SPA += 1
Endif

# Valeur par dûˋfaut saisie ou du type de donnûˋes

If find("%DEFVAL",ACT_ACT(DA..FA))
 If LIG_FNU(B,L)=TABLO
  Wrseq space$(SPA);"[M]";LIG_ZON(B,L);
 Else
  Wrseq space$(SPA);AZC;
 Endif
 Wrseq " = ";vireblc(format$("KT:80X",LIG_INI(B,L)),2)

# Menus locaux

Elsif find("%MENINI",ACT_ACT(DA..FA))
 Wrseq space$(SPA);AZC;" = 1"
Endif

Gosub ACTION

# Bloc Flash

If find("%FLASH",ACT_ACT(DA..FA))
 If LIG_LNG(B,L)<>0
  Wrseq space$(SPA);'Local Clbfile CLOB('+num$(LIG_LNG(B,L))+')'
 Else
  Wrseq space$(SPA);'Local Clbfile CLOB(9)'
 Endif
 Wrseq space$(SPA);'[L]CLOB = '+AZC
 Wrseq space$(SPA);'Local Char SAVGFONC : SAVGFONC = GFONCTION '
 Wrseq space$(SPA);'Call CLOBEXP("'+BLC_VIEW(B)+'",[L]CLOB) From SUBAPSMON'
 Wrseq space$(SPA); AZC+' = [L]CLOB'
 Wrseq space$(SPA);'If SAVGFONC<>GFONCTION : GFONCTION=SAVGFONC : Call AUTORIS from EXEFNC : Endif'
Endif

# Bloc browser

If find("%BROWSE",ACT_ACT(DA..FA))
 Wrseq space$(SPA);'Call INITURL('+AZC+',"'+BLC_LIEN1(B)+'","'+BLC_LIEN2(B)
&     +'","'+BLC_LIEN3(B)+'") From INTRUTILA'
Endif

# Bloc BO

If find("%BO",ACT_ACT(DA..FA))
 Wrseq space$(SPA);'Call INITBO('+AZC+') From INTRUTILA'
Endif

# Init XSL

If find("%INIXSL",ACT_ACT(DA..FA))
 A1=find(LIG_ZON(B,L),BLC_PAR1(1..MAXBLOC))
 If A1<>0
  Wrseq space$(SPA);'Call INIXSL('+AZC+',"'+BLC_LIEN1(A1)+'") From INTRUTILA'
 Else
  A1=find(LIG_ZON(B,L),BLC_PAR2(1..MAXBLOC))
  Wrseq space$(SPA);'Call INIXSL('+AZC+',"'+BLC_LIEN2(A1)+'") From INTRUTILA'
 Endif
Endif

SPA -= 1 : Wrseq space$(SPA);"Endif"
Return

####################################################
## Avant saisie de la zone
####################################################
$AVANT_SAISIE
FLSAI = 1
Wrseq space$(SPA);'Local Integer INDIC : INDIC = indice'
Wrseq space$(SPA);'Raz mkstat'

# Initialisation des boutons

If find("%INIBOU",ACT_ACT(DA..FA))
 For J=1 To MAXBOUT
  If J<=4 : K = 8+J : Else : K = 10+J : Endif
  A1 = find(K,ACT_TYP(DA..FA))
  While A1
   A2 = DA+A1-1
   If ACT_ACT(A2)<>"%NULL"
    If J=1 & LIG_TUN(B,L)=2 & LIG_OBJ(B,L)=FMTADI
     A3 = A : A = A2
     Gosub PAROBJ
     A = A3
     If PAROBJ<>'""'
      Wrseq space$(SPA);'Call TITADI(GBOUT'+num$(J)+','+PAROBJ+') From TRTDIV'
     Endif
    Else
     If ACT_TIT(A2)<>0
      Wrseq space$(SPA);'Call TEXTE(';ACT_TIT(A2);',GBOUT';num$(J);') From OBJDIV'
     Endif
    Endif
    Break
   Endif
   #A1 = find(K,ACT_TYP(DA+A1+1..FA))
   A3 = A1
   A1 = find(K,ACT_TYP(DA+A1..FA))
   If A1 : A1 += A3 : Endif
  Wend
 Next J
Endif

# Sûˋlection

If find("%INISEL",ACT_ACT(DA..FA)) | find("%SELOBJ",ACT_ACT(DA..FA)) | find("%TABSEL",ACT_ACT(DA..FA))
 A1 = find(8,ACT_TYP(DA..FA))
 If A1
  A2 = DA+A1-1
  If ACT_TIT(A2)<>0
   Wrseq space$(SPA);'Call TEXTE(';ACT_TIT(A2);',GBOUTS) From OBJDIV'
  Endif
 Endif
Endif

# Propriûˋtûˋs

If find("%PROOBJ",ACT_ACT(DA..FA))
 A1 = find(52,ACT_TYP(DA..FA))
 If A1
  A2 = DA+A1-1
  If ACT_TIT(A2)<>0
   Wrseq space$(SPA);'Call TEXTE(';ACT_TIT(A2);',GBOUTP) From OBJDIV'
  Endif
 Endif
Endif

# Sûˋlection avancûˋe

If find("%SELAVA",ACT_ACT(DA..FA))
 A1 = find(51,ACT_TYP(DA..FA))
 If A1
  A2 = DA+A1-1
  If ACT_TIT(A2)<>0
   Wrseq space$(SPA);'Call TEXTE(';ACT_TIT(A2);',GBOUTA) From OBJDIV'
  Endif
 Endif
Endif

# Clic sur IcûÇne

If find("%INIICO",ACT_ACT(DA..FA))
 A1 = find(31,ACT_TYP(DA..FA))
 If A1
  A2 = DA+A1-1
  If ACT_TIT(A2)<>0
   Wrseq space$(SPA);'Call TEXTE(';ACT_TIT(A2);',GBOUTI) From OBJDIV'
  Endif
 Endif
Endif

# Appel de l'action init_bouton (tant qu'adonix ne la gû´re pas)

If find(1,ACT_TYP(DA..FA))
 Wrseq "Call IB_"+LIG_ZON(B,L);
 If LIG_FNU(B,L)<>TABLO & LIG_TYP(B,L)<>FMTVAR & !find(LIG_TYI(B,L),9)
  Wrseq "(";AZC;")";
 Endif
 Wrseq
Endif

# Condition de saisie

If find("%CNSSAI",ACT_ACT(DA..FA))
 Wrseq space$(SPA);"If !("+vireblc(format$("KT:120X",LIG_CNS(B,L)),2)+")"
 Wrseq space$(SPA);' Affzo '+LIG_ZON(B,L)+' : mkstat = 2'
 Wrseq space$(SPA);"Endif"
 Wrseq space$(SPA);"If !mkstat" : SPA += 1 : NBIF += 1
Endif

# Init des menus locaux

If find("%MENSAI",ACT_ACT(DA..FA))
 Wrseq space$(SPA);"Call INICOMBO("+num$(LIG_LIB(B,L))+") From COMBOS"
Endif

# Bas de tableau affichûˋ

If find("%BASAFF",ACT_ACT(DA..FA))
 Wrseq space$(SPA);'mkstat = 2 : GMESSAGE = ""'
 Wrseq space$(SPA);"If !mkstat" : SPA += 1 : NBIF += 1
Endif

# Actions std

Gosub ACTION

# Dûˋclaration des onkey

If find("%INIBOU",ACT_ACT(DA..FA))
 For J=1 To MAXBOUT
  If J<=4 : K = 8+J : Else : K = 10+J : Endif
  A1 = find(K,ACT_TYP(DA..FA))
  If A1
   If J<=12
    Wrseq space$(SPA);"Onkey "+num$(128+J)+" Titled GBOUT"+num$(J)+" Call B"+num$(J)+"_"+LIG_ZON(B,L);
   Else
    Wrseq space$(SPA);"Onkey "+num$(157+J)+" Titled GBOUT"+num$(J)+" Call B"+num$(J)+"_"+LIG_ZON(B,L);
   Endif
   If LIG_FNU(B,L)<>TABLO & LIG_TYP(B,L)<>FMTVAR & !find(LIG_TYI(B,L),9)
    Wrseq "(zc)";
   Endif
   Wrseq " From"-NOMPROG
  Endif
 Next J
Endif

If find("%INISEL",ACT_ACT(DA..FA)) | find("%SELOBJ",ACT_ACT(DA..FA)) | find("%TABSEL",ACT_ACT(DA..FA))
 A1 = find(8,ACT_TYP(DA..FA))
 If A1
  A2 = DA+A1-1
  If ACT_TIT(A2)<>0
   Wrseq space$(SPA);'Onkey   2 Titled GBOUTS Call S_'+LIG_ZON(B,L); : # Sûˋlection
   Gosub ADD_ZC
  Endif
 Endif
Endif

If find("%PROOBJ",ACT_ACT(DA..FA))
 Wrseq space$(SPA);'Onkey 144 Titled GBOUTP Call P_'+LIG_ZON(B,L); : # Propriûˋtûˋs
 Gosub ADD_ZC
Endif

If find("%SELAVA",ACT_ACT(DA..FA))
 Wrseq space$(SPA);'Onkey 146 Titled GBOUTA Call SA_'+LIG_ZON(B,L); : #   Sûˋlection avancûˋe
 Gosub ADD_ZC
Endif

If find("%INIICO",ACT_ACT(DA..FA))
 A1 = find(31,ACT_TYP(DA..FA))
 If A1
  A2 = DA+A1-1
  If ACT_TIT(A2)<>0
   Wrseq space$(SPA);'Onkey 178 Titled GBOUTI Call CL_'+LIG_ZON(B,L);'(zc) From ';NOMPROG : # Click sur icone
  Endif
 Endif
Endif

# Traitement des tables diverses

K = find("%ADIOBL",ACT_ACT(DA..FA))
If K
 A = DA+K-1
 Gosub PAROBJ
 If PAROBJ<>'""'
  Wrseq space$(SPA);'If ';AZC;'="" : Call INIADI(';AZC;',';PAROBJ;') From TRTDIV : Endif'
 Endif
Endif

# Menu locaux de type MM

If find("%MENSAI",ACT_ACT(DA..FA))
 Wrseq space$(SPA);"If ";AZC;"<1 | GMENLOC(";AZC;")=1"
 Wrseq space$(SPA);" ";AZC;" = find(0,GMENLOC(1..len(mess(0,"+num$(LIG_LIB(B,L))+",1))))"
 Wrseq space$(SPA);"Endif"
Endif

# Menu locaux de type autre

If find("%MENAVT",ACT_ACT(DA..FA))
 Wrseq space$(SPA);"If ";AZC;"<1"
 Wrseq space$(SPA);" ";AZC;" = 1"
 Wrseq space$(SPA);"Endif"
Endif

# ContrûÇle d'accû´s

K = find("%ACCSAI",ACT_ACT(DA..FA))
If K
 A = DA+K-1
 Gosub DEB_ACTION
 Wrseq space$(SPA);'Call ACCES("'+LIG_ACC(B,L)+'") From OBJDIV'
 Gosub FIN_ACTION
Endif

# Discombo, pour le type MM

If find("%MENDIS",ACT_ACT(DA..FA))
 Wrseq space$(SPA);"If !mkstat"
 Wrseq space$(SPA);" Discombo 0 From"-LIG_ZON(B,L)+"(INDIC)"
 Wrseq space$(SPA);" If sum(GMENLOC)<>0"
 Wrseq space$(SPA);"  Gosub COMBOS From COMBOS"
 Wrseq space$(SPA);"  For WI=1 to WN : Discombo WCOMBO(WI) From"-LIG_ZON(B,L)+"(INDIC) : Next WI"
 Wrseq space$(SPA);" Endif"
 Wrseq space$(SPA);"Endif"
Endif

Gosub FIN_IF
Return

####################################################
## ContrûÇles
####################################################
$CONTROLE
FLCONT = 1

# Zone obligatoire

K = find("%OBLIG",ACT_ACT(DA..FA))
If K
 A = DA+K-1
 Gosub DEB_ACTION
 Case LIG_TYI(B,L)
  When 1,2,3,4,5,6
   Wrseq space$(SPA);"If ";AZC;"=0"
  When 7
   Wrseq space$(SPA);'If vireblc(';AZC;',2)=""'
  When 8
   Wrseq space$(SPA);'If ';AZC;'=[0/0/0]'
  When 9 , 10
   Wrseq space$(SPA);'If len(';AZC;')=0'
 Endcase
 Wrseq space$(SPA);' mkstat = 1 : GMESSAGE = mess(10,123,1)'
 Wrseq space$(SPA);"Endif"
 Gosub FIN_ACTION
Endif

# ContrûÇle des choix possibles d'un menu local

If find("%MENCNT",ACT_ACT(DA..FA))
 Wrseq space$(SPA);"If ";AZC;">0 & ";AZC;"<dim(GMENLOC) & GMENLOC(";AZC;")<>0"
 Wrseq space$(SPA);" mkstat = 1 : End"
 Wrseq space$(SPA);"Endif"
Endif

# Actions STD de prioritûˋ 1

PRIACT = 1 : Gosub ACTION

# ContrûÇle associûˋ û  un objet

K = find("%CNTOBJ",ACT_ACT(DA..FA))
If K
 A = DA+K-1
 Gosub DEB_ACTION
 Gosub PAROBJ
 If GPRODUIT=4 : # LOAN
  Wrseq space$(SPA);"Local Char PAROBJ(250)(16)"
  For P=1 To ACT_PAR(A)
   If left$(PAR_COD(A,P),len(LIG_OBJ(B,L)))=LIG_OBJ(B,L)
    K = val(right$(PAR_COD(A,P),len(LIG_OBJ(B,L))+1))
    PARAM = PAR_VAL(A,P)
    Gosub PARNUM
    Wrseq space$(SPA);"PAROBJ(";num$(K);") = ";PARAM
   Endif
  Next P
  PAROBJ = "PAROBJ"
 Endif
 Wrseq space$(SPA);'Call ';
 Case LIG_TYI(B,L)
  When 2,3,4,5,6 : Wrseq 'CONTNUM(';
  When 1         : Wrseq 'CONTLIB(';
  When Default   : If dim(GAUTOSEL)>0 : Wrseq 'CONTSEL('; Else Wrseq 'CONTROLE('; : Endif
 Endcase
 Wrseq '"'+LIG_OBJ(B,L)+'","';
 If LIG_OBL(B,L)<>2      : Wrseq '!'; : Endif
 If LIG_FIC(B,L)=TET_FIC : Wrseq '$'; : Endif
 Wrseq LIG_OBP(B,L);'",';AZC;',';PAROBJ;',mkstat) From CONTOBJ'
 Gosub FIN_ACTION
Endif

# Actions STD de prioritûˋ 3

PRIACT = 3 : Gosub ACTION

# Table de contrûÇle

K = find("%TABCNT",ACT_ACT(DA..FA))
If K
 A = DA+K-1
 Gosub DEB_ACTION
 Wrseq space$(SPA);"Call ";
 Case LIG_TYI(B,L)
  When 1         : Wrseq "CONTACL_LIB(";
  When 2,3,4,5,6 : Wrseq "CONTACL_NUM(";
  When 8         : Wrseq "CONTACL_DAT(";
  When Default   : Wrseq "CONTACL_CHAR(";
 Endcase
 Wrseq '"'+LIG_CTL(B,L)+'",'+PAR_VAL(A,1)+',';AZC;') From SUBACL'
 Gosub FIN_ACTION
Endif

Gosub FIN_IF
Return

####################################################
## Aprû´s zone
####################################################
$APRES_ZONE
FLCONT = 1

# Actions STD

Gosub ACTION

Gosub FIN_IF
Return

####################################################
## Aprû´s modif
####################################################
$APRES_MODIF
FLCONT = 1

# Actions STD

Gosub ACTION

# Zone liûˋe

If find("%LIEN",ACT_ACT(DA..FA))
 Wrseq space$(SPA);'If !mkstat & evalue("dim("+clanam([M])+"Z'+LIG_ZON(B,L)+')")>indice'
 Wrseq space$(SPA);' [M]'+LIG_ZON(B,L)+'(indice) = ';AZC
 Wrseq space$(SPA);' Affzo Z'+LIG_ZON(B,L)+'(indice)'
 Wrseq space$(SPA);'Endif'
Endif

Gosub FIN_IF
Return

####################################################
## Sûˋlection
####################################################
$SELECTION

# Sûˋlection de l'objet liûˋ

K = find("%SELOBJ",ACT_ACT(DA..FA))
If K
 A = DA+K-1
 Gosub PAROBJ
 Wrseq space$(SPA);'Local Char PARMSK(250)(1..16)'
 Wrseq space$(SPA);'PARMSK(1) = "'+LIG_OBJ(B,L)+'"'
 Wrseq space$(SPA);'PARMSK(2) = "';
 If LIG_OBL(B,L)<>2      : Wrseq "!"; : Endif
 If LIG_FIC(B,L)=TET_FIC : Wrseq "$"; : Endif
 Wrseq LIG_OBP(B,L)+'"'
 If GPRODUIT=4
  For P=1 To ACT_PAR(A)
   If left$(PAR_COD(A,P),len(LIG_OBJ(B,L)))=LIG_OBJ(B,L)
    K = val(right$(PAR_COD(A,P),len(LIG_OBJ(B,L))+1))
    PARAM = PAR_VAL(A,P)
    Gosub PARNUM
    Wrseq space$(SPA);"PARMSK(";num$(3+K);") = ";PARAM
   Endif
  Next P
 Elsif PAROBJ<>'""'
  Wrseq space$(SPA);'PARMSK(3) = '+PAROBJ
 Endif
 Wrseq space$(SPA);"Call ";
 Case LIG_TYI(B,L)
  When 1           : Wrseq "S_TAB_LIB(";
  When 2,3,4,5,6   : Wrseq "S_TAB_NUM(";
  When 8           : Wrseq "S_TAB_DAT(";
  When Default     : Wrseq "S_TAB_CHAR(";
 Endcase
 Wrseq AZC;',PARMSK,"SELOBJ","SELOBJ","") From GACTION'
Endif

# Table de contrûÇle

If find("%TABSEL",ACT_ACT(DA..FA))
 Wrseq space$(SPA);'Local Char PARMSK(250)(1..20)'
 Wrseq space$(SPA);'PARMSK(1) = "'+LIG_CTL(B,L)+'"'
 Wrseq space$(SPA);'PARMSK(2) = '+PAR_VAL(A,1)
 Wrseq space$(SPA);"Call ";
 If ACT_MOD(A)=1
  Wrseq "S_LIS";
 Else
  Wrseq "S_TAB";
 Endif
 Case LIG_TYI(B,L)
  When 1         : Wrseq "_LIB";  : K = 1
  When 2,3,4,5,6 : Wrseq "_NUM";  : K = 2
  When 8         : Wrseq "_DAT";  : K = 3
  When Default   : Wrseq "_CHAR"; : K = 4
 Endcase
 Wrseq '(';AZC;',PARMSK,"';
 If ACT_MOD(A)=1
  Wrseq "ASELCTI";
 Else
  Wrseq "ASELCTA";
 Endif
 Wrseq mid$("INDC",K,1)+'","SUBACL","") From GACTION'
Endif

# Sûˋlection STD

Gosub ACTION

Return

####################################################
## Click sur icone
####################################################
$CLIC
Gosub ACTION
Wrseq space$(SPA);'If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif'
Return

####################################################
## Sûˋlection avancûˋe
####################################################
$SELECTION_AVANCEE
K = find("%SELAVA",ACT_ACT(DA..FA))
If K
 A = DA+K-1
 Gosub PAROBJ
 Wrseq space$(SPA);'Local Char PARMSK(250)(1..16) , SAVACT(20)'
 Wrseq space$(SPA);'SAVACT = GACTION : GACTION = "SELOBJAW"'
 Wrseq space$(SPA);'PARMSK(1) = "'+LIG_OBJ(B,L)+'"'
 If PAROBJ<>'""'
  Wrseq space$(SPA);'PARMSK(2) = '+PAROBJ
 Endif
 If LIG_FIC(B,L)=TET_FIC
  Wrseq space$(SPA);'PARMSK(3) = "$"'
 Endif
 Wrseq space$(SPA);"Call ";
 Case LIG_TYI(B,L)
  When 1         : Wrseq "SAISIE_LIB(";
  When 2,3,4,5,6 : Wrseq "SAISIE_NUM(";
  When 8         : Wrseq "SAISIE_DAT(";
  When Default   : Wrseq "SAISIE_CHAR(";
 Endcase
 Wrseq AZC;',PARMSK,"DSELOBJAW","SELOBJAW","';PAR_VAL(A,2);'") From GSAISIE'
 Wrseq space$(SPA);'GACTION = SAVACT'
Endif
Return

####################################################
## Propriûˋtûˋs
####################################################
$PROPRIETE
K = find("%PROOBJ",ACT_ACT(DA..FA))
If K
 A = DA+K-1
 Gosub PAROBJ
 Wrseq "Local Char PAROBJ(250)"
 Case GPRODUIT
  When 4 : # Loan
   Raz TBPARAM , NBP
   For P=1 To ACT_PAR(A)
    If left$(PAR_COD(A,P),len(LIG_OBJ(B,L)))=LIG_OBJ(B,L)
     K = val(right$(PAR_COD(A,P),len(LIG_OBJ(B,L))+1))
     PARAM = PAR_VAL(A,P)
     Gosub PARNUM
     TBPARAM(K) = PARAM
     If K>NBP : NBP = K : Endif
    Endif
   Next P
   PAROBJ = ""
   For P=0 To NBP
    If P : PAROBJ += '+"~"+' : Endif
    PAROBJ += TBPARAM(P)
   Next P
 Endcase
 If PAROBJ<>""
  Wrseq "PAROBJ = ";PAROBJ
 Endif
 Wrseq space$(SPA);'Call VISU("'+LIG_OBJ(B,L)+'",';
 If LIG_TYI(B,L)=7
  Wrseq AZC;
 Else
  Wrseq 'num$(';AZC;')';
 Endif
 Wrseq ',PAROBJ) From SUBAOP'
Endif
Return

####################################################
## Avant ligne
####################################################
$AVANT_LIGNE
Gosub ACTION
Return

####################################################
## Aprû´s ligne
####################################################
$APRES_LIGNE
Gosub ACTION
Return

####################################################
## Boutons
####################################################
$BOUTON
# Tunnel liûˋ û  un objet
If BOUT=1
 K = find("%TUNOBJ",ACT_ACT(DA..FA))
 If K
  A = DA+K-1
  Gosub PAROBJ
  If GPRODUIT=4 : # LOAN
   Wrseq space$(SPA);"Local Char PAROBJ(250)(16)"
   For P=1 To ACT_PAR(A)
    If left$(PAR_COD(A,P),len(LIG_OBJ(B,L)))=LIG_OBJ(B,L)
     K = val(right$(PAR_COD(A,P),len(LIG_OBJ(B,L))+1))
     PARAM = PAR_VAL(A,P)
     Gosub PARNUM
     Wrseq space$(SPA);"PAROBJ(";num$(K);") = ";PARAM
    Endif
   Next P
   PAROBJ = "PAROBJ"
  Endif
  If LIG_TYI(B,L)=7
   Wrseq space$(SPA);'Call OBJET("'+LIG_OBJ(B,L)+'",';AZC;','+PAROBJ+') From GOBJET'
  Elsif LIG_TYI(B,L)<>8
   Wrseq space$(SPA);'Local Char VALCHAR(20)'
   Wrseq space$(SPA);'VALCHAR = num$(';AZC;')'
   Wrseq space$(SPA);'Call OBJET("'+LIG_OBJ(B,L)+'",VALCHAR,'+PAROBJ+') From GOBJET'
   Wrseq space$(SPA);AZC;' = val(VALCHAR)'
  Endif
  Return
 Endif
Endif
Gosub ACTION
Wrseq space$(SPA);'If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif'
Return

####################################################
## Dûˋclaration des ûˋvûˋnements (140)
####################################################
$EVENEMENT

#  Actions
NBETQ = 0
For A=LIG_PTA(B,L) To LIG_PTA(B,L)+LIG_ACT(B,L)-1
 If find(ACT_ETQ(A),"IB_","AV_","D_","AS_","C_","AP_","AM_","AVANT_","APRES_","P_")
  NBETQ = 1 : Break
 Endif
Next A
If NBETQ=0 : Return : Endif

Wrseq "$ON_";LIG_ZON(B,L)
NBETQ = 0
For A=LIG_PTA(B,L) To LIG_PTA(B,L)+LIG_ACT(B,L)-1
 If LIG_SAI(B,L)=1 or LIG_ZON(B,L)=BLC_BAS(B) or find(ACT_TYP(A),2,3,6)
  If !find(ACT_ETQ(A),TBETQ(1..NBETQ))
   NBETQ += 1
   TBETQ(NBETQ) = ACT_ETQ(A)
   EVT = 0
   Case ACT_ETQ(A)
    When "IB_"    : EVT = 1 : EVTCOD = "BEFORE_INPUT"

     If find(4,ACT_TYP(LIG_PTA(B,L)..LIG_PTA(B,L)+LIG_ACT(B,L)-1))
      PFIX = "AS"
      EVT = 0  : # mb test
     Else
      PFIX = "IB"
     Endif
#                         Il faudrait "ON_RIGHT_CLICK"..........IB
    When "AV_"    : EVT = 1 : EVTCOD = "BEFORE_AREA"   : PFIX = "AV"
    When "D_"     : EVT = 1 : EVTCOD = "INIT_AREA"     : PFIX = "D"
    When "AS_"    : EVT = 1 : EVTCOD = "BEFORE_INPUT"  : PFIX = "AS"
    When "C_"     : EVT = 1 : EVTCOD = "CONTROL"       : PFIX = "C"
    When "AP_"    : EVT = 1 : EVTCOD = "AFTER_AREA"    : PFIX = "AP"
    When "AM_"    : EVT = 1 : EVTCOD = "AFTER_CHANGE"  : PFIX = "AM"
    When "AVANT_" : EVT = 1 : EVTCOD = "BEFORE_LINE"   : PFIX = "AVANT"
    When "APRES_" : EVT = 1 : EVTCOD = "AFTER_LINE"    : PFIX = "APRES"
   Endcase
   Case EVT
    When 1
     If PFIX="AM"
      Wrseq 'Onevent '+EVTCOD+' Gosub AMM_'+LIG_ZON(B,L)+' From '+NOMPROG
     Elsif LIG_FNU(B,L)=TABLO or LIG_TYP(B,L)=FMTVAR or find(LIG_TYI(B,L),9)
      Wrseq 'Onevent '+EVTCOD+' Call '+PFIX+'_'+LIG_ZON(B,L);
      Gosub ADD_ZC
     Elsif PFIX="AV"
      Wrseq 'Onevent '+EVTCOD+' Gosub AV_'+LIG_ZON(B,L)+' From '+NOMPROG
     Else
      Wrseq 'Onevent '+EVTCOD+' Call '+PFIX+'_'+LIG_ZON(B,L);
      Gosub ADD_ZC
     Endif
   Endcase
  Endif
 Endif
Next
Wrseq "Return"
Wrseq
Return

$ADD_ZC
If LIG_FNU(B,L)<>TABLO & LIG_TYP(B,L)<>FMTVAR & !find(LIG_TYI(B,L),9)
 Wrseq "(zc)";
Endif
Wrseq ' From '+NOMPROG
Return

####################################################
## Traitement gûˋnûˋral d'une action
####################################################
$ACTION
For A=DA To FA
 If ACT_TYP(A)=TYPACT & left$(ACT_ACT(A),1)<>"%" & (PRIACT=0 or ACT_PRI(A)=PRIACT)
  If ACT_MOD(A)>=1 & ACT_MOD(A)<=8 : # & find(ACT_EXE(A),1,3)
   Gosub DEB_ACTION
   Case ACT_MOD(A)
    When 1 : Gosub GOBJET
    When 2 : Gosub GCONSULT
    When 3 : Gosub GTRAITE
    When 4 : Gosub GSAISIE
    When 5 : Gosub GACTION
    When 6 : Gosub GACTION
    When 7 : Gosub GACTION
    When 8 : Gosub SANS_MODELE
   Endcase
   Gosub FIN_ACTION
  Endif
 Endif
Next A
PRIACT = 0
Return

$DEB_ACTION
Case ACT_EXE(A)
 When 1 : Wrseq space$(SPA);"If !GWEBSERV" : NBIF += 1 : SPA += 1
 When 2 : Wrseq space$(SPA);"If  GWEBSERV" : NBIF += 1 : SPA += 1
Endcase
If FLACTION & (FLCONT | FLSAI)
 Wrseq space$(SPA);'If !mkstat' : NBIF += 1 : SPA += 1
Endif
Wrseq space$(SPA);"## Action"-ACT_ACT(A)
FLACTION = 0
Return

$FIN_ACTION
If FLCONT
 Wrseq space$(SPA);'If mkstat : GERR = 1 : GZONE = "'+LIG_ZON(B,L)+'"'+' : GZNUM = '+num$(LIG_TIT(B,L))+' : Endif'
Endif
If find(TYPACT,13,14) : # Avant_ligne/Apres_ligne
 Wrseq space$(SPA);'If mkstat : End : Endif'
Endif
If FLSAI
 If LIG_FNU(B,L)<>TABLO & !find(LIG_TYI(B,L),9)
  Wrseq space$(SPA);'If mkstat=2'
  Wrseq space$(SPA);' [M]'+LIG_ZON(B,L);'(INDIC) = ';AZC
  Wrseq space$(SPA);' Affzo '+LIG_ZON(B,L);'(INDIC) : mkstat = 2'
  Wrseq space$(SPA);'Endif'
 Endif
Endif
FLACTION = 1
Case ACT_EXE(A)
 When 1,2 : Gosub FIN_IF : NBIF = 0
Endcase
Return

####################################################
## Traitement des modû´les
####################################################
$GOBJET
Gosub SAV_ACT
Gosub ACT_AVZ
If PAR_ADR(A,1)=2 & PAR_VAL(A,1)<>"zc" : # cas oû¿ le premier argument est passûˋ par valeur
 Case PAR_TYP(A,1)
  When 1   : Wrseq space$(SPA);"Local Char    OBJCLE(30)"
  When 2,5 : Wrseq space$(SPA);"Local Integer OBJCLE"
  When 3   : Wrseq space$(SPA);"Local Decimal OBJCLE"
  When 4   : Wrseq space$(SPA);"Local Date    OBJCLE"
  When 6   : Wrseq space$(SPA);"Local Clbfile OBJCLE(9)"
  When 7   : Wrseq space$(SPA);"Local Blbfile OBJCLE"
 Endcase
 Wrseq space$(SPA);"OBJCLE = ";PAR_VAL(A,1)
 PAR_VAL(A,1) = "OBJCLE"
Endif
Gosub WR_CALL
Gosub ACT_APZ
Gosub REST_ACT
Return

$GCONSULT
Gosub SAV_ACT
Gosub ACT_AVZ
Gosub GET_PARAM
Gosub AZC
Wrseq space$(SPA);'Call'-ACT_SPR(A);
Wrseq '('+AZC+',"'+ACT_CNS(A)+'",PARMSK) From'-ACT_PRG(A)
Gosub SET_PARAM
Gosub ACT_APZ
Gosub REST_ACT
Return

$GTRAITE
Gosub SAV_ACT
Gosub ACT_AVZ
Gosub GET_PARAM
Gosub AZC
Wrseq space$(SPA)+'Call'-ACT_SPR(A);
Wrseq '('+AZC+',PARMSK,"'+ACT_FEN(A)+'","'+ACT_TRT(A)+'","';
If ACT_TPF(A)=5 or ACT_TPF(A)=6
 Wrseq ACT_IDE(A);
Else
 Wrseq ACT_CRI(A);
Endif
Wrseq '",'+num$(ACT_TPF(A))+',"'+ACT_SPE(A)+'") From'-ACT_PRG(A)
Gosub SET_PARAM
Gosub ACT_APZ
Gosub REST_ACT
Return

$GSAISIE
Gosub SAV_ACT
Gosub ACT_AVZ
Gosub GET_PARAM
Gosub AZC
Wrseq space$(SPA)+'Call'-ACT_SPR(A);
Wrseq '('+AZC+',PARMSK,"'+ACT_FEN(A)+'","'+ACT_TRT(A)+'","'+ACT_SPE(A)+'") From'-ACT_PRG(A)
Gosub SET_PARAM
Gosub ACT_APZ
Gosub REST_ACT
Return

$GACTION
Gosub SAV_ACT
Gosub ACT_AVZ
Gosub GET_PARAM
Gosub AZC
Wrseq space$(SPA)+'Call'-ACT_SPR(A);
Wrseq '('+AZC+',PARMSK,"'+ACT_IDE(A)+'","'+ACT_TRT(A)+'","'+ACT_SPE(A)+'") From'-ACT_PRG(A)
Gosub SET_PARAM
Gosub ACT_APZ
Gosub REST_ACT
Return

$SANS_MODELE
If ACT_SPR(A)<>"" & ACT_SPE(A)<>"" & ACT_PRG(A)<>""
 Wrseq space$(SPA)+'Local Integer OKTRT'
 Wrseq space$(SPA)+'Call EXISTE_ADX("","","'+ACT_SPE(A)+'",OKTRT) From ORDSYS'
 Wrseq space$(SPA)+'If OKTRT>0'
 TRTSUB = ACT_SPE(A)
 ETQSUB = ACT_SPR(A)
 SPA += 1
 Gosub GEN_CALL
 SPA -= 1
 Wrseq space$(SPA)+"Else"
 TRTSUB = ACT_PRG(A)
 ETQSUB = ACT_SPR(A)
 SPA += 1
 Gosub GEN_CALL
 SPA -= 1
 Wrseq space$(SPA)+"Endif"
Elsif ACT_SPR(A)<>"" & ACT_PRG(A)<>""
 TRTSUB = ACT_PRG(A)
 ETQSUB = ACT_SPR(A)
 Gosub GEN_CALL
Endif
If ACT_INS(A)<>""
 LIGNE = space$(SPA)+ACT_INS(A)
 Repeat
  J = instr(1,LIGNE,"%")
  If J
   If instr(1,"0123456789",mid$(LIGNE,J+2,1))
    L1 = 2
   Else
    L1 = 1
   Endif
   K = val(mid$(LIGNE,J+1,L1))
   If K=0
    PARAM = "[M]"+LIG_ZON(B,L)
   Else
    If K=1 & ACT_AZC(A)=2
     Gosub AZC
     PARAM = AZC
    Else
     PARAM = PAR_VAL(A,K)
     Gosub AVZC
    Endif
   Endif
   LIGNE = left$(LIGNE,J-1)+PARAM+right$(LIGNE,J+L1+1)
  Endif
 Until J=0
 Wrseq LIGNE
Endif
Return

$GEN_CALL
NOPAR = 0
If find(7,PAR_TYP(A,1..ACT_PAR(A)))
 Wrseq space$(SPA)+"Local Blbfile BLOB"
Endif
Wrseq space$(SPA)+'Call'-ETQSUB;
If ACT_AZC(A)=2
 Gosub AZC
 Wrseq "(";AZC;
 NOPAR = 1
Endif
For P=1 To ACT_PAR(A)
 If ACT_AZC(A)<>2 | P>1
  If NOPAR>0 & mod(NOPAR,8)=0 : Wrseq : Wrseq "&"+space$(SPA); : Endif
  If NOPAR=0 : Wrseq "("; : Else : Wrseq ","; : Endif
  PARAM = PAR_VAL(A,P)
  Gosub AVZC
  If PAR_COD(A,P)=LIG_OBJ(B,L) & PAR_ADR(A,P)=2
   Gosub PARNUM
  Elsif find(PAR_TYP(A,P),1,6)
   Gosub PARALPHA
  Elsif find(PAR_TYP(A,P),7)
   If PARAM="" or PARAM='""'
    PARAM = "BLOB"
   Endif
  Endif
  Wrseq PARAM;
  NOPAR += 1
 Endif
Next P
If NOPAR>0 : Wrseq ")"; : Endif
Wrseq " From"-TRTSUB
Return

####################################################
## Affichage des colonnes ûˋvaluûˋes
####################################################
$TIT_COL
SPA = 0
If sum(BLC_IEV(1..BLC_NBR))>0
 L3 = 0
 For B=1 To BLC_NBR
  If BLC_IEV(B)>0
   L1 = 0
   For L=1 To LIG_NBR(B)
    If LIG_SAI(B,L)<3 & LIG_FNU(B,L)<>TABLO
     If left$(LIG_EVL(B,L),1)="#"
      L1 += 1
     Elsif LIG_EVL(B,L)<>""
      L1 += 1
     Endif
    Endif
   Next L
   L3 = max(1,L1,L3)
  Endif
 Next B
 Wrseq space$(SPA);"$TIT_COL"
 Wrseq space$(SPA);"Local Char TITCL(200)(1.."+num$(L3)+")"
 Wrseq space$(SPA);"Raz TITCL"
 Wrseq space$(SPA);"Case BASPAG"
 For B=1 To BLC_NBR
  If BLC_IEV(B)>0
   Wrseq space$(SPA);' When "';BLC_BAS(B);'"'
   SPA += 2 : Gosub SET_TITCOL : SPA -= 2
  Endif
 Next B
 Wrseq space$(SPA);"Endcase"
 Wrseq space$(SPA);"Return"
 Wrseq
Endif
Return

$SET_TITCOL
L1 = 0
For L=1 To LIG_NBR(B)
 If LIG_SAI(B,L)<3 & LIG_FNU(B,L)<>TABLO
  If left$(LIG_EVL(B,L),1)="#"
   L1 += 1
   Wrseq space$(SPA);'TITCL('+num$(L1)+') = "'+evalue(right$(LIG_EVL(B,L),2))+'"'
  Elsif LIG_EVL(B,L)<>""
   L1 += 1
   Wrseq space$(SPA);'TITCL('+num$(L1)+') = '+vireblc(format$("KT:60X",LIG_EVL(B,L)),2)
  Endif
 Endif
Next L
Wrseq space$(SPA);"If !GORITITCOL"
L1 = 0
For L=1 To LIG_NBR(B)
 If LIG_SAI(B,L)<3 & LIG_FNU(B,L)<>TABLO & left$(LIG_EVL(B,L),1)<>""
  L1 += 1
  Wrseq space$(SPA);' Titcol [M]'+BLC_BAS(B)+' ';
  Wrseq 'TITCL('+num$(L1)+') For ';
  Wrseq LIG_ZON(B,L)
 Endif
Next L
Wrseq space$(SPA);"Else"
L1 = 0
For L=1 To LIG_NBR(B)
 If LIG_SAI(B,L)<3 & LIG_FNU(B,L)<>TABLO & left$(LIG_EVL(B,L),1)<>""
  L1 += 1
  Wrseq space$(SPA);' Titcol [M:'+TET_ABR+']'+BLC_BAS(B)+' ';
  Wrseq 'TITCL('+num$(L1)+') For ';
  Wrseq LIG_ZON(B,L)
 Endif
Next L
Wrseq space$(SPA);"Endif"
Return

# Sous-programme obsolû´te (14.1.4) : Titcol avec toutes les colonnes
$SET_TITCOL_OLD
L1 = 0
For L=1 To LIG_NBR(B)
 If LIG_SAI(B,L)<3 & LIG_FNU(B,L)<>TABLO
  L1 += 1
  If left$(LIG_EVL(B,L),1)="#"
   Wrseq space$(SPA);'TITCL('+num$(L1)+') = "'+evalue(right$(LIG_EVL(B,L),2))+'"'
  Elsif LIG_EVL(B,L)<>""
   Wrseq space$(SPA);'TITCL('+num$(L1)+') = '+vireblc(format$("KT:60X",LIG_EVL(B,L)),2)
  Elsif LIG_TIT(B,L)<>0
   Wrseq space$(SPA);'Call TEXTE('+num$(LIG_TIT(B,L))+',TITCL('+num$(L1)+')) From OBJDIV'
  Endif
 Endif
Next L
Wrseq space$(SPA);"If !GORITITCOL"
Wrseq space$(SPA);' Titcol [M]'+BLC_BAS(B)+' ';
For L=1 To L1
 Wrseq "TITCL("+num$(L)+")";
 If L=L1
  Wrseq
 Elsif mod(L,5)=0
  Wrseq ", "
  Wrseq "& ";space$(SPA);
 Else
  Wrseq ", ";
 Endif
Next L
Wrseq space$(SPA);"Else"
Wrseq space$(SPA);' Titcol [M:'+TET_ABR+']'+BLC_BAS(B)+' ';
For L=1 To L1
 Wrseq "TITCL("+num$(L)+")";
 If L=L1
  Wrseq
 Elsif mod(L,5)=0
  Wrseq ", "
  Wrseq "& ";space$(SPA);
 Else
  Wrseq ", ";
 Endif
Next L
Wrseq space$(SPA);"Endif"
Return

####################################################
## Sous-prog divers
####################################################
$ACT_AVZ
If ACT_AVZ(A)=2
 Wrseq space$(SPA);"Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)"
 Wrseq space$(SPA);'ACTION = "A'+ACT_ETQ(A)+LIG_ZON(B,L)+'"';
 Wrseq ' : PROGSUB = "'+TET_STD+'" : PROGSPE = "'+TET_SPE+'" : PROGSPV = "'+TET_SPV+'"'
 Wrseq space$(SPA);"Gosub ACTSUB From GOBJSUB"
Endif
Return

$ACT_APZ
If ACT_AVZ(A)=2
 Wrseq space$(SPA);'ACTION = "B'+ACT_ETQ(A)+LIG_ZON(B,L)+'"';
 Wrseq ' : PROGSUB = "'+TET_STD+'" : PROGSPE = "'+TET_SPE+'" : PROGSPV = "'+TET_SPV+'"'
 Wrseq space$(SPA);"Gosub ACTSUB From GOBJSUB"
Endif
Return

$SAV_ACT
Wrseq space$(SPA)+"Local Char    PARMSK(250)(1..20) , SAVACT(20)"
Wrseq space$(SPA)+'SAVACT = GACTION : GACTION = "'+ACT_ACT(A)+'"'
Return

$REST_ACT
Wrseq space$(SPA)+"GACTION = SAVACT"
Return

$AZC
If LIG_FNU(B,L)=TABLO
 AZC = "BASPAG"
Elsif find(LIG_TYI(B,L),9) : # Blob Clob
 AZC = "[M]"+LIG_ZON(B,L)
Elsif LIG_TYP(B,L)=FMTVAR or TYPACT=2 : # Avant zone => Sous-prog
 AZC = "zc"
Else
 AZC = "VALEUR"
Endif
Return

$AVZC
If TYPACT=2 & find(PARAM,"VALEUR","[L]VALEUR") : # Avant zone VALEUR -> zc
 PARAM = "zc"
Endif
Return

$GET_PARAM
NOPAR = 0
For P=1 To ACT_PAR(A)
 If ACT_AZC(A)<>2 | P>1
  NOPAR += 1
  PARAM = PAR_VAL(A,P)
  Gosub AVZC
  If find(PAR_TYP(A,P),2,3,5) or PAR_COD(A,P)=LIG_OBJ(B,L)
   Gosub PARNUM
  Elsif find(PAR_TYP(A,P),1,6)
   Gosub PARALPHA
  Endif
  Wrseq space$(SPA)+"PARMSK("+num$(NOPAR)+") = "+PARAM
 Endif
Next P
Return

$SET_PARAM
NOPAR = 0
For P=1 To ACT_PAR(A)
 If ACT_AZC(A)<>2 | P>1
  NOPAR += 1
  PARAM = PAR_VAL(A,P)
  Gosub AVZC
  If PAR_ADR(A,P)=1 & PARAM<>""
   If PARAM<>'""' & PARAM<>"''" & PARAM<>"0"
    Case PAR_TYP(A,P)
     When 1,4
      Wrseq space$(SPA)+PARAM+" = PARMSK("+num$(NOPAR)+")"
     When Default
      Wrseq space$(SPA)+PARAM+" = val(PARMSK("+num$(NOPAR)+"))"
    Endcase
   Endif
  Endif
 Endif
Next IATR
Return

$PARNUM
If num$(val(PARAM))=PARAM
 PARAM = '"'+PARAM+'"'
Elsif PARAM=""
 PARAM = '""'
Elsif left$(PARAM,4)<>"num$" and left$(PARAM,1)<>'"' and left$(PARAM,1)<>"'"
 PARAM = "num$("+PARAM+")"
Endif
Return

$PARALPHA
If num$(val(PARAM))=PARAM
 PARAM = '"'+PARAM+'"'
Elsif PARAM=""
 PARAM = '""'
Endif
Return

$WR_CALL
Wrseq space$(SPA);'Call'-ACT_SPR(A)+"(";
For P=1 To ACT_PAR(A)
 If P>1 : Wrseq ","; : Endif
 Wrseq PAR_VAL(A,P);
Next P
Wrseq ") From"-ACT_PRG(A)
Return

$PAROBJ
PARAM = ""
For P=1 To ACT_PAR(A)
 If PAR_COD(A,P)=LIG_OBJ(B,L)
  PARAM = PAR_VAL(A,P) : Break
 Endif
Next P
If PARAM=""
 PARAM = '""'
Endif
Gosub PARNUM : # Le paramû´tre objet est toujours alpha
PAROBJ = PARAM
Return

$FIN_IF
For K=1 To NBIF
 SPA -= 1 : Wrseq space$(SPA);"Endif"
Next K
Return
