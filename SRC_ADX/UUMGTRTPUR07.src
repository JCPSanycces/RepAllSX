#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UUMGTRTPUR07   Migration des Retours                      Module Achats#
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
 # Issue 108760 - 2015-06-12 by SR : adaptation
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTPUR07") From LECFIC
  Endif

  #Call RAZ_UUMGTRTPUR07(DOSSIER)
  Call MAJ_UUMGTRTPUR07(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

##########################################################################
Subprog RAZ_UUMGTRTPUR07(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  End
Endif

Local Char WNAMPNHM,WNAMPNDM
Call MIGTABNAME (DOSSIER,"PRETURN",WNAMPNHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"PRETURND",WNAMPNDM,ERR) From TRTMIG

If ERR
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMPNHM,"fde",DOSSIER),0) < 0
  End
Endif
If filinfo(filpath("FIL",WNAMPNDM,"fde",DOSSIER),0) < 0
  End
Endif

##2 - On vide les fichiers selon le cas
#######################################

Call MIGTABRAZ (DOSSIER,"PRETURN",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"PRETURND",ERR) From TRTMIG

# Issue 101446 - 2014-07-11 by MUARN : Prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR07",7,ERR) From TRTMIG : #7=Erreur
  End
Endif
If val(VERSION)<GMIGX3VER60
  Local File =DOSSIER+".CPTANALIN"  [CAL]
  Trbegin [CAL]
  Delete [CAL] Where ABRFIC="PND"
  Commit
Endif

##3 - On vide AMIGKEY pour le flux
####################
Call MIGRAZKEY (DOSSIER,"UUMGTRTPUR07",ERR) From TRTMIG

End

##########################################################################
Subprog MAJ_UUMGTRTPUR07(DOSSIER)
Value Char DOSSIER

# Issue 108760 - 2015-06-12 by SR : adaptation
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR07",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

# Issue 89740 - 2013-05-06 by MAE : Prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR07",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

Local Char WNAMPNHM,WNAMPNDM
Call MIGTABNAME (DOSSIER,"PRETURN",WNAMPNHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"PRETURND",WNAMPNDM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR07",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMPNHM,"fde",DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR07",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMPNDM,"fde",DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR07",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR07",2,ERR) From TRTMIG : #2=En cours
# Issue 108857 - 2015-06-15 by SR : Déplacé avant définition des variables qui utilisent adxwrb
Gosub MIG_OUVRE From TRTMIG

###################
Local Char WTAB_PNH (100) (adxwrb)
Local Char WTAB_PND (100) (adxwrb)
Local Char WTAB_CAL (100) (adxwrb)
Local Shortint WCPT_PNH,WCPT_PND,WCPT_CAL

Call ECR_TIME("UUMGTRTPUR07 Purchase Returns Process : Update PRETURN-D") From DOSSUB
Call ECR_TRACE("UUMGTRTPUR07 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#

Call MIGTABINIT (DOSSIER,"PRETURN",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"PRETURND",ERR) From TRTMIG
##Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABINIT (DOSSIER,"CPTANALIN",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:PNH])  = 0 : Local File =DOSSIER+".PRETURN"    [PNH]  : Endif   # Fichier X3 "Vide"
If clalev([F:PND])  = 0 : Local File =DOSSIER+".PRETURND"    [PND]  : Endif   # Fichier X3 "Vide"

If clalev([F:PNHM]) = 0 : Local File =DOSSIER+"."+WNAMPNHM   [PNHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:PNDM]) = 0 : Local File =DOSSIER+"."+WNAMPNDM   [PNDM] : Endif   # Fichier X3 renommé Avant Migration

# Issue X3-113507
# PNHTYP value search :
# Tables are opened in the migrated folder
If !clalev([F:FGRM]) : Local File =DOSSIER+".FACGROUP"  [FGRM]        : Endif
If !clalev([F:TPNM]) : Local File =DOSSIER+".TABPNHTYP" [TPNM]        : Endif
# Tables are opened in the reference folder (in case we don't find anything in the migrated folder)
If !clalev([F:FGRR]) : Local File =[F:ADS]DOSREF+".FACGROUP"  [FGRR]  : Endif
If !clalev([F:TPNR]) : Local File =[F:ADS]DOSREF+".TABPNHTYP" [TPNR]  : Endif
Local Char SGCURLEG(GLONADI), SGCURFCY(GLONFCY)
# End issue 113507

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBLUS, NBCOMMIT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

Gosub OUVRE_PUR From UUMGTRTPUR00
Gosub OUVRE_PUR05

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTPUR07",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

#-----  Lien des tables entête & lignes -----#
Link [PNDM] With [PNHM]PNH0~=[F:PNDM]PNHNUM
&    As [LNK]
&    Order By Key CLE = [F:PNHM]PNHFCY;[F:PNHM]PNHNUM

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTPUR07" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_PNH00
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:PNHM]PNHFCY=TABMIGKEY(1) & [F:PNHM]PNHNUM>TABMIGKEY(2)"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:PNHM]PNHFCY>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [PNH],[PND]
GOK = 1

For [LNK]CLE(2) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTPUR07" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  #  version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
    Gosub RAZV6_PNH
  Endif
#  version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
    Gosub RAZV7_PNH
  Endif
#  version < V8, raz des champs v8
  If val(VERSION)<GMIGX3VER80
    Gosub RAZV8_PNH
  Endif

  [F:PNH] = [F:PNHM]

  If WSITE<>[F:PNH]PNHFCY
    #----- Alimentation de la société sur l'entête de demande d'achat -----#
      Call RECUP_GLOBAL_CPT(DOSSIER,[F:PNH]PNHFCY) From TRTX3CPT
      WSITE=[F:PNH]PNHFCY
  Endif

  #Appel proc de migration sur entete
  #  version < V6, traitement v6
  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_PNH
    If GOK<1 : Break : Endif
  Endif
  #  version < V7, traitement v7
  If val(VERSION)<GMIGX3VER70
    Gosub MAJV7_PNH
    If GOK<1 : Break : Endif
  Endif
  #  version < V8, traitement v8
  If val(VERSION)<GMIGX3VER80
    Gosub MAJV8_PNH
    If GOK<1 : Break : Endif
  Endif

  ############################
  #-- Boucle sur les lignes
  ############################
  For [LNK]CLE
    #rupture par ligne de retour
    #  version < V6, raz des champs v6
    If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_PND
    Endif
    #  version < V7, raz des champs v7
    If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_PND
    Endif

    # Issue 112754 - 2016-12-19 by SR : Services en V12
    #  version < V12, raz des champs v12
    If val(VERSION)<GMIGX3VER120
      Gosub RAZV12_PND
    Endif
    [F:PND] = [F:PNDM]

    #Appel proc de migration sur detail
    #  version < V6, traitement v6
    If val(VERSION)<GMIGX3VER60
      Gosub MAJV6_PND
      If GOK<1 : Break : Endif
    Endif
    #  version < V7, traitement v7
    If val(VERSION)<GMIGX3VER70
      Gosub MAJV7_PND
      If GOK<1 : Break : Endif
    Endif

    # Issue 112754 - 2016-12-19 by SR : Services en V12
    #  version < V12, traitement v12
    If val(VERSION)<GMIGX3VER120
      Gosub MAJV12_PND
      If GOK<1 : Break : Endif
    Endif
    # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#    If NEWMOTEUR
#        Gosub PND_STK : # pour stocker ref
#        WriteB [PND]
#    Else
#        Write [PND]
#    Endif
#    If fstat
#          If NEWMOTEUR & adxwrb>1
#          Call ECR_TRACE("File PRETURND, Error ="-num$(fstat),1) From GESECRAN
#          Gosub PND_ERRTRA : # pour afficher les ref
#        Else
#          Call ECR_TRACE("File PRETURND(PNHNUM/PNDLIN)"-[F:PND]PNHNUM-num$([F:PND]PNDLIN)+", Error ="-num$(fstat),1) From GESECRAN
#        Endif
#        GOK=0 : Break
#    Endif
     Gosub PND_STK : # pour stocker ref
     WriteB [PND]
     If fstat
        Call ECR_TRACE("File PRETURND, Error ="-num$(fstat),1) From GESECRAN
        Gosub PND_ERRTRA : # pour afficher les ref
        GOK=0 : Break
     Endif
     # End issue 108760
  Next

  If GOK<1 : Break : Endif

  # --- alimentation des champs et écriture enreg
   # --- alimentation des champs et écriture enreg
   # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#  If NEWMOTEUR
#      Gosub PNH_STK : # pour stocker ref
#      WriteB [F:PNH]
#  Else
#      Write [F:PNH]
#  Endif
#  If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File PRETURN, Error ="-num$(fstat),1) From GESECRAN
#      Gosub PNH_ERRTRA : # pour afficher les ref
#    Else
#      Call ECR_TRACE("File PRETURN(PNHNUM)"-[F:PNH]PNHNUM+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Break
#  Endif
   Gosub PNH_STK : # pour stocker ref
   WriteB [F:PNH]
   If fstat
      Call ECR_TRACE("File PRETURN, Error ="-num$(fstat),1) From GESECRAN
      Gosub PNH_ERRTRA : # pour afficher les ref
      GOK=0 : Break
   Endif
   # End issue 108760
  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:PNHM]PNHFCY
    TABMIGKEY(2) = [F:PNHM]PNHNUM
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR07",7,ERR) From TRTMIG : #7=Erreur
Else
  # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#  If NEWMOTEUR & adxwrb>1
    Flush [F:PNH]
    If fstat
        Call ECR_TRACE("File PRETURN, Error ="-num$(fstat),1) From GESECRAN
        Gosub PNH_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:PND]
    If fstat
        Call ECR_TRACE("File PRETURND, Error ="-num$(fstat),1) From GESECRAN
        Gosub PND_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:CAL]
    If fstat
        Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
        Gosub CAL_ERRTRA From UUMGTRTPUR00: # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
 #  Endif
# End issue 108760
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTPUR07",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTPUR07",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_PNH00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [PNH], [PND]
Close Local File [PNHM], [PNDM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"PRETURN",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"PRETURND",ERR) From TRTMIG
##Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABEND (DOSSIER,"CPTANALIN",ERR) From TRTMIG
Call MIGTRTEND (DOSSIER,"UUMGTRTPUR07") From TRTMIG
Call ECR_TIME("UUMGTRTPUR07 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

$OUVRE_PUR05
Local File =DOSSIER+".PORDER"     [POH]
# issue 108760 : Pour initialisation type de retour : vu pendant le dev de 108760
#----- New field PNHTYP  -----#
If dim([F:PNH]PNHTYP) > 0
  Local File =DOSSIER+".FACGROUP"   [FGR]
  Local File =DOSSIER+".TABPNHTYP"  [TPN]
Endif
# Issue 112754 - 2016-12-19 by SR : Services en v12
Local File =DOSSIER+".PRECEIPTD"    [PTD]
# Issue 112434 - 2015-11-12 by SR
Local Integer LACTPTX : LACTPTX=func AFNC.ACTIVDOS([F:ADS]DOSSIER,"PTX")

Local Char WBPS(GLONBPS),WBPR(GLONBPR),WPOH(GLONVCR)
Return
############################
$RAZV6_PNH
Raz [F:PNH]BPAINV
Raz [F:PNH]BPAPAY
Raz [F:PNH]BPRPAY
Raz [F:PNH]CCE
Raz [F:PNH]CPY
Raz [F:PNH]DIE
Raz [F:PNH]EECNUM
Raz [F:PNH]EECNUMDEB
Raz [F:PNH]FFWADD
Raz [F:PNH]ICTCTY
Raz [F:PNH]VACTYP
Raz [F:PNH]WRHE
Return
############################
$RAZV7_PNH

Return
############################
$RAZV8_PNH
If dim([F:PNH]PNHTYP) > 0
  Raz [F:PNH]PNHTYP
Endif
Return

# Issue 112754 - 2016-12-19 by SR : Services
############################
$RAZV12_PND
Raz [F:PND]ITMKND
Return

############################
$RAZV6_PND
Raz [F:PND]AMTTAXISS
Raz [F:PND]AMTTAXLIN1
Raz [F:PND]AMTTAXLIN2
Raz [F:PND]AMTTAXLIN3
Raz [F:PND]AMTTAXOTH1
Raz [F:PND]AMTTAXOTH2
Raz [F:PND]AMTTAXRCP
Raz [F:PND]BASTAXLIN1
Raz [F:PND]BPAINV
Raz [F:PND]BPOCRY
Raz [F:PND]CLCAMT3
Raz [F:PND]CLCAMT4
Raz [F:PND]CLCAMT5
Raz [F:PND]CLCAMT6
Raz [F:PND]CLCAMT7
Raz [F:PND]CPY
Raz [F:PND]DEDTAXISS
Raz [F:PND]DEDTAXLIN1
Raz [F:PND]DEDTAXLIN2
Raz [F:PND]DEDTAXLIN3
Raz [F:PND]DEDTAXOTH1
Raz [F:PND]DEDTAXOTH2
Raz [F:PND]DEDTAXRCP
Raz [F:PND]LIKQTYCOE
Raz [F:PND]LINCAT
Raz [F:PND]LINTYP
Raz [F:PND]POHTYP
Raz [F:PND]SATISS
Raz [F:PND]TAXISS
Raz [F:PND]TAXOTH1
Raz [F:PND]TAXOTH2
Raz [F:PND]TAXRCP
Raz [F:PND]WRH
Return
############################
$RAZV7_PND
Return
################################################
$PNH_STK
Call STK (WTAB_PNH,WCPT_PNH,[F:PNH]PNHNUM) From TRTMIG
Return
$PND_STK
Call STK (WTAB_PND,WCPT_PND,[F:PND]PNHNUM-'/'-num$([F:PND]PNDLIN)) From TRTMIG
Return
##############################################################################################
$PNH_ERRTRA
Call ERRTRA (WTAB_PNH,WCPT_PNH,"File PRETURN(PNHNUM)=") From TRTMIG
Return
$PND_ERRTRA
Call ERRTRA (WTAB_PND,WCPT_PND,"File PRETURND(PNHNUM/PNDLIN)=") From TRTMIG
Return


########################################################################
$MAJV6_PNH
    [F:PNH]CPY=GSOCIETE
    #----- Alimentation code adresse transitaire -----#
    If [F:PNH]FFWNUM<>"" & [F:PNH]FFWADD=""
      Gosub LECT_BPRFFW
      [F:PNH]FFWADD=[F:BPR]BPAADD
    Endif
    #----- Alimentation code adresse fournisseur facturant -----#
    If [F:PNH]BPAINV=""
      Gosub LECT_BPSI
      [F:PNH]BPAINV=[F:BPS]BPAADD
    Endif
    #----- Alimentation tiers payé et code adresse tiers payé -----#
    If [F:PNH]BPRPAY=""
      Gosub LECT_BPSPNH
      [F:PNH]BPRPAY=[F:BPS]BPRPAY
      [F:PNH]BPAPAY=[F:BPS]BPAPAY
    Endif
    #----- Alimentation du type de régime de taxe -----#
    If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>[F:PNH]VACBPR
      Read [ADI] CODE=1;[F:PNH]VACBPR : If fstat Raz [F:ADI] : Endif
    Endif
    [F:PNH]VACTYP=[F:ADI]N1
    #----- Passage de la nature transaction CEE à 2 caractères -----#
    If len([F:PNH]EECNAT)>2 & left$([F:PNH]EECNAT,1)="0"
      [F:PNH]EECNAT=right$([F:PNH]EECNAT,2)
    Endif
    #----- Alimentation de l'identification CEE -----#
    If GACTDEB=2 & [F:PNH]EECNUM=""
      Gosub LECT_BPRI
      [F:PNH]EECNUM=[F:BPR]EECNUM
    Endif
    #----- Alimentation champs pour le multi-référentiels comptabilité -----#
    If dim([F:PNH]DIE)>0 & [F:PNH]DIE(0)=""
      For I=1 To max(GNBDIE,GOPTCANA)
        [F:PNH]DIE(I-1)=GDIE(I)
      Next I
    Endif
Return
########################################################################
$MAJV7_PNH

Return
########################################################################
$MAJV8_PNH
#----- New field PNHTYP initialization -----#
# Issue 112434 - 2015-11-12 by SR :
#If dim([F:PNH]PNHTYP) > 0
If func AFNC.ACTIVDOS([F:ADS]DOSSIER,"TRSNE")
  If [F:PNH]PNHTYP = ""
    Local Char    SGFCY(GLONFCY)    : SGFCY=GFCY
    Local Char    WPNHTYP(GLONTPN)
    # Issue 112434 - 2015-11-12 by SR :
    GFCY = [F:PNH]PNHFCY
    Gosub PNHTYP #From TRTACHRET1 # # Issue X3-113507
    If WPNHTYP<>""
     [F:PNH]PNHTYP=WPNHTYP
    Else
     GOK=0 : Call ECR_TRACE("     1-File PRETURN"-[F:PNH]PNHNUM+", Error : Impossible to define a purchase return type",1) From GESECRAN
    Endif
    GFCY=SGFCY
  Endif
Endif
Return
########################################################################
# Issue X3-113507
$PNHTYP
# ----------------------------------------------------- #
# First, we search return type in the migrated folder   #
# ----------------------------------------------------- #
WPNHTYP = ""
SGCURLEG=GCURLEG : SGCURFCY=GCURFCY
Call GETSOC([F:PNH]PNHFCY) From DEVSUB

Link [TPNM] With [FGRM]FGR0=[F:TPNM]GFY;GFCY As [KTPNM]

Filter [TPNM] Where ([F:TPNM]GFY="" | [FGRM]FCY=GFCY) & ([F:TPNM]LEG=GCURLEG | [F:TPNM]LEG="" ) Order By [F:TPNM]LEG Desc;[F:FGRM]FCY Desc
Read [KTPNM] First
If fstat=0
  WPNHTYP = [F:TPNM]PNHTYP
Endif

Filter [KTPNM]
If clalev([KTPNM]) : Close File [KTPNM] : Endif

# No return type found for the legislation, we search return type with no legislation
If WPNHTYP=""
  Link [TPNR] With [FGRR]FGR0=[F:TPNR]GFY;GFCY As [KTPNR]

  Filter [TPNR] Where ([F:TPNR]GFY="" | [FGRR]FCY=GFCY) & ([F:TPNR]LEG=GCURLEG | [F:TPNR]LEG="" ) Order By [F:TPNR]LEG Desc;[F:FGRR]FCY Desc
  Read [KTPNR] First
  If fstat=0
    WPNHTYP = [F:TPNR]PNHTYP
  Endif

  Filter [KTPNR]
  If clalev([KTPNR]) : Close File [KTPNR] : Endif
Endif

GCURLEG=SGCURLEG : GCURFCY=SGCURFCY

Return
########################################################################
$LECT_BPRFFW
  If [F:BPR]BPRNUM<>[F:PNH]FFWNUM
    WBPR=[F:PNH]FFWNUM
    Gosub LECT_BPR
  Endif
Return

$LECT_BPRI
  If [F:BPR]BPRNUM<>[F:PNH]BPSINV
    WBPR=[F:PNH]BPSINV
    Gosub LECT_BPR
  Endif
Return

$LECT_BPR
    Read [BPR] BPR0=WBPR : If fstat  Raz [F:BPR] : Endif
Return

############################
$LECT_BPSI
  If [F:BPS]BPSNUM<>[F:PNH]BPSINV
    WBPS=[F:PNH]BPSINV
    Gosub LECT_BPS
  Endif
Return

$LECT_BPSPNH
  If [F:BPS]BPSNUM<>[F:PNH]BPSNUM
    WBPS=[F:PNH]BPSNUM
    Gosub LECT_BPS
  Endif
Return

$LECT_BPSPND
  If [F:BPS]BPSNUM<>[F:PND]BPSNUM
    WBPS=[F:PND]BPSNUM
    Gosub LECT_BPS
  Endif
Return

$LECT_BPS
    Read [BPS] BPS0=WBPS : If fstat  Raz [F:BPS] : Endif
Return

########################################################################
$MAJV6_PND
      #----- Alimentation société et adresse fourniss. facturant sur lignes retour -----#
      [F:PND]CPY   =[F:PNH]CPY
      [F:PND]BPAINV=[F:PNH]BPAINV
      #----- Alimentation dy type commande -----#
      If [F:PND]POHTYP=0 & [F:PND]POHNUM<>""
        Gosub LECT_POHPND
        [F:PND]POHTYP=[F:POH]POHTYP
      Endif
      #----- Alimentation de la province de sortie et du pays expéditeur -----#
      If (LACTPTX & [F:PND]SATISS="") | [F:PND]BPOCRY=""
        If [F:PND]POHNUM<>""
          Gosub LECT_POHPND
          If [F:POH]BPOSAT<>"" | [F:POH]BPOCRY<>""
            If LACTPTX & len([F:POH]BPOSAT)<=4 & toupper([F:POH]BPOSAT)=[F:POH]BPOSAT
              [F:PND]SATISS=[F:POH]BPOSAT
            Endif
            [F:PND]BPOCRY=[F:POH]BPOCRY
          Else
            #----- Lecture de l'adresse d'expédition si nécessaire -----#
            Gosub LECT_BPAPOH
            #-----
            [F:PND]SATISS=[F:BPA]SAT
            If LACTPTX & len([F:BPA]SAT)<=4 & toupper([F:BPA]SAT)=[F:BPA]SAT
              [F:PND]SATISS=[F:BPA]SAT
            Endif
            [F:PND]BPOCRY=[F:BPA]CRY
          Endif
        Elsif [F:PNH]BETFCY=2 & [F:PND]LINSTOFCY<>""
          #----- Lecture du site d'expédition si nécessaire -----#
          Gosub LECT_FCYSTO
          #----- Lecture de l'adresse d'expédition si nécessaire -----#
          Gosub LECT_BPASTO
          #-----
          If LACTPTX & len([F:BPA]SAT)<=4 & toupper([F:BPA]SAT)=[F:BPA]SAT
            [F:PND]SATISS=[F:BPA]SAT
          Endif
          [F:PND]BPOCRY=[F:BPA]CRY
        Else
          #----- Lecture fournisseur si nécessaire -----#
          Gosub LECT_BPSPNH
          #----- Lecture de l'adresse d'expédition si nécessaire -----#
          Gosub LECT_BPAPNH
          #-----
          [F:PND]SATISS=[F:BPA]SAT
          If LACTPTX & len([F:BPA]SAT)<=4 & toupper([F:BPA]SAT)=[F:BPA]SAT
            [F:PND]SATISS=[F:BPA]SAT
          Endif
          [F:PND]BPOCRY=[F:BPA]CRY
        Endif
      Endif
      #----- Calcul des bases et taxes de la ligne de retour -----#
      If [F:PND]BASTAXLIN1=0  ABREV="PND" : Gosub MAJ_CALTAX_LIG : Endif
      #----- Alimentation Type ligne et catégorie de mouvement -----#
      If [F:PND]LINTYP=0  [F:PND]LINTYP=1 : Endif
      If [F:PND]LINCAT=0  [F:PND]LINCAT=1 : Endif
      #----- Création lignes comptables analytiques -----#
      Gosub WRITE_CAL_PND
Return
########################################################################
$MAJV7_PND
Return

# Issue 112754 - 2016-12-19 by SR : Services en V12
########################################################################
$MAJV12_PND
[F:PND]ITMKND = 1
If [F:PND]PTHNUM <> ""
  Gosub LECT_PTDPND
  If [F:PTD]ITMKND > 1 : [F:PND]ITMKND = [F:PTD]ITMKND : Endif
Else
  Gosub LECT_ITMPND
  If [F:ITM]SCSFLG > 1 : [F:PND]ITMKND = 3 : Endif
Endif
Return

###########################
$LECT_FCYSTO
  If [F:FCY]FCY<>[F:PND]LINSTOFCY
    Read [FCY] FCY0=[F:PND]LINSTOFCY : If fstat  Raz [F:FCY] : Endif
  Endif
Return

##################################
$LECT_POHPND
  If [F:POH]POHNUM<>[F:PND]POHNUM
    WPOH=[F:PND]POHNUM
    Gosub LECT_POH
  Endif
Return

$LECT_POH
  Read [POH] POH0=WPOH : If fstat  Raz [F:POH] : Endif
Return

##################################
$LECT_BPAPOH
  If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:POH]BPSNUM | [F:BPA]BPAADD<>[F:POH]BPOADD
    Read [BPA] BPA0=1;[F:POH]BPSNUM;[F:POH]BPOADD : If fstat  Raz [F:BPA] : Endif
  Endif
Return

$LECT_BPASTO
  If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>[F:PND]LINSTOFCY | [F:BPA]BPAADD<>[F:FCY]BPAADD
    Read [BPA] BPA0=3;[F:PND]LINSTOFCY;[F:FCY]BPAADD : If fstat  Raz [F:BPA] : Endif
  Endif
Return

$LECT_BPAPNH
  If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:PNH]BPSNUM | [F:BPA]BPAADD<>[F:BPS]BPAADD
    Read [BPA] BPA0=1;[F:PNH]BPSNUM;[F:BPS]BPAADD : If fstat  Raz [F:BPA] : Endif
  Endif
Return

# Issue 112754 - 2016-12-19 by SR : Services en V12
##################################
$LECT_PTDPND
  If [F:PTD]PTHNUM<>[F:PND]PTHNUM | [F:PTD]PTDLIN <> [F:PND]PTDLIN
    Read [PTD] PTD0= [F:PND]PTHNUM;[F:PND]PTDLIN : If fstat  Raz [F:PTD] : Endif
  Endif
Return
##################################
$LECT_ITMPND
If [F:ITM]ITMREF <> [F:PND]ITMREF
  Read [F:ITM]ITM0 = [F:PND]ITMREF : If fstat : Raz [F:ITM] : Endif
Endif
Return
# End issue 112754
########################################################################
$WRITE_CAL_PND
Raz [F:CAL]
[F:CAL]ABRFIC="PND"
[F:CAL]VCRNUM=[F:PND]PNHNUM
[F:CAL]VCRLIN=[F:PND]PNDLIN
[F:CAL]ANALIG=1
For I=1 To max(GNBCOA,2)
  [F:CAL]LED(I-1)=GLEDSOC(I)
  [F:CAL]COA(I-1)=GCOA(I)
Next I
[F:CAL]ACC(0)=[F:PNDM]LINACC
[F:CAL]ACC(1)=[F:PNDM]LINCNA
For I=1 To max(GNBDIE,GOPTCANA)
  [F:CAL]DIE(I-1)=GDIE(I)
  #If evalue("dim([F:PNDM]CCE"+num$(I)+")")>0
  #  [F:CAL]CCE(I-1)=evalue("[F:PNDM]CCE"+num$(I))
  #Endif
    Case I
    When 1 : [F:CAL]CCE(I-1)=[F:PNDM]CCE1
    When 2 : [F:CAL]CCE(I-1)=[F:PNDM]CCE2
    When 3 : [F:CAL]CCE(I-1)=[F:PNDM]CCE3
    When 4 : [F:CAL]CCE(I-1)=[F:PNDM]CCE4
    When 5 : [F:CAL]CCE(I-1)=[F:PNDM]CCE5
    When 6 : [F:CAL]CCE(I-1)=[F:PNDM]CCE6
    When 7 : [F:CAL]CCE(I-1)=[F:PNDM]CCE7
    When 8 : [F:CAL]CCE(I-1)=[F:PNDM]CCE8
    When 9 : [F:CAL]CCE(I-1)=[F:PNDM]CCE9
    When Default
    Endcase
Next I

# Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#If NEWMOTEUR
#  Gosub CAL_STK From UUMGTRTPUR00 : # pour stocker ref
#  WriteB [F:CAL]
#Else
#  Write [F:CAL]
#Endif
#If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
#      Gosub CAL_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
#    Else
#      Call ECR_TRACE("File CPTANALIN PND 0"-[F:PND]PNHNUM-num$([F:PND]PTDLIN)+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Return
#Endif
 Gosub CAL_STK From UUMGTRTPUR00 : # pour stocker ref
 WriteB [F:CAL]
If fstat
   Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
   Gosub CAL_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
   GOK=0 : Return
Endif
# End issue 108760

Return


#########################################################################
# MAJ_CALTAX_LIG   : S/P de calcul des bases et des taxes  MBT 02/10/09 #
#                     de la ligne de DA ou de retour                    #
#########################################################################
$MAJ_CALTAX_LIG
#-----
WCUR   =[F:PND]NETCUR
WITMREF=[F:PND]ITMREF
WBPSNUM=[F:PND]BPSNUM
WQTYPUU=[F:PND]QTYUOM
WDOCDAT=[F:PND]RTNDAT
WVACBPR=[F:PNH]VACBPR
WVACTYP=[F:PNH]VACTYP
WLINAMT=[F:PND]LINAMT
#----- Calcul des taxes du montant ligne (marchandise) -----#
Call ALICLCAMT2(WITMREF,WQTYPUU,-1,ABREV,WCLCAMT) From TRTX3
#-----
TAXE(1)=[F:PND]VAT(0)
TAXE(2)=[F:PND]VAT(1)
TAXE(3)=[F:PND]VAT(2)
#-----
Raz MONTANT,MONTDED
Call CALTAXE2(GSOCIETE,WDOCDAT,WVACBPR,WCUR,3,TAXE,1,WLINAMT,WCLCAMT,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
#-----
[F:PND]BASTAXLIN1 = [F:PND]LINAMT
[F:PND]CLCAMT1    = WCLCAMT(1)
[F:PND]AMTTAXLIN1 = MONTANT(1)
[F:PND]DEDTAXLIN1 = MONTDED(1)
#-----
If [F:PND]VAT(1)=""
  [F:PND]CLCAMT2    = 0
  [F:PND]AMTTAXLIN2 = 0
  [F:PND]DEDTAXLIN2 = 0
Else
  [F:PND]CLCAMT2   = WCLCAMT(2)
  [F:PND]AMTTAXLIN2 = MONTANT(2)
  [F:PND]DEDTAXLIN2 = MONTDED(2)
  WJTVT=find(TAXE(2),WTVTVAT(0..NBTVT))
  If WJTVT>0 & WTVTVATCHA(WJTVT-1)=2
    [F:PND]BASTAXLIN1 = [F:PND]BASTAXLIN1+[F:PND]AMTTAXLIN2
  Endif
Endif
#-----
If [F:PND]VAT(2)=""
  [F:PND]CLCAMT3    = 0
  [F:PND]AMTTAXLIN3 = 0
  [F:PND]DEDTAXLIN3 = 0
Else
  [F:PND]CLCAMT3    = WCLCAMT(3)
  [F:PND]AMTTAXLIN3 = MONTANT(3)
  [F:PND]DEDTAXLIN3 = MONTDED(3)
  WJTVT=find(TAXE(3),WTVTVAT(0..NBTVT))
  If WJTVT>0 & WTVTVATCHA(WJTVT-1)=2
    [F:PND]BASTAXLIN1 = [F:PND]BASTAXLIN1+[F:PND]AMTTAXLIN3
  Endif
Endif
#-----
If WVACTYP<>4
  [F:PND]LINATIAMT = [F:PND]LINAMT+[F:PND]AMTTAXLIN1+[F:PND]AMTTAXLIN2+[F:PND]AMTTAXLIN3
Else
  [F:PND]LINATIAMT = [F:PND]LINAMT
Endif
#----- Calcul de la taxe des montants remises/frais de la ligne tarif -----#
Gosub LECT_BPSPND
If [F:PRS]BPCBPS<>2 | [F:PRS]PLISTC<>[F:BPS]PLISTC
  Read [PRS] PRS0=2;[F:BPS]PLISTC : If fstat  Raz [F:PRS] : Endif
Endif
#-----
Gosub LECT_TCUCUR
#-----
For I=1 To 9
##  If evalue("dim([F:"+ABREV+"]DISCRGVAL"+num$(I)+")")>0
    If [F:PRS]NPRNOTFLG(I-1)=1 & [F:PRS]INVDTA(I-1)<>0

    Case I
    When 1 : WDISCRGVAL=[F:PND]DISCRGVAL1
    When 2 : WDISCRGVAL=[F:PND]DISCRGVAL2
    When 3 : WDISCRGVAL=[F:PND]DISCRGVAL3
    When 4 : WDISCRGVAL=[F:PND]DISCRGVAL4
    When 5 : WDISCRGVAL=[F:PND]DISCRGVAL5
    When 6 : WDISCRGVAL=[F:PND]DISCRGVAL6
    When 7 : WDISCRGVAL=[F:PND]DISCRGVAL7
    When 8 : WDISCRGVAL=[F:PND]DISCRGVAL8
    When 9 : WDISCRGVAL=[F:PND]DISCRGVAL9
    When Default
    Endcase

      #----- C'est un montant -----#
      If [F:PRS]VALTYP(I-1)=1
        If [F:PRS]CLCRUL(I-1)=1 : # Par unité
          BASE=arr(WDISCRGVAL*[F:PND]QTYPUU,WRND)
        Else              : # Par ligne
          BASE=WDISCRGVAL
        Endif
      #----- C'est un pourcentage -----#
      Else
        BASE=arr([F:PND]LINAMT*WDISCRGVAL/100,WRND)
      Endif
      #----- Inversion du montant si minoration -----#
      If [F:PRS]INCDCR(I-1)=2  BASE=-BASE : Endif
      #----- Màj base et mt taxe ligne si taux produit -----#
      WJ=find([F:PRS]INVDTA(I-1),WPFINUM(0..WNBPFI))
      If WJ>0 & WPFIVATRUL(WJ-1)=1
      ##If [F:PFI]VATRUL=1
        Raz TAXE : TAXE(1)=[F:PND]VAT(0)
        If BASE<>0
          Call CALTAXE(GSOCIETE,WDOCDAT,WVACBPR,WCUR,1,TAXE,1,BASE,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
          [F:PND]BASTAXLIN1 = [F:PND]BASTAXLIN1+BASE
          [F:PND]AMTTAXLIN1 = [F:PND]AMTTAXLIN1+MONTANT(1)
          [F:PND]DEDTAXLIN1 = [F:PND]DEDTAXLIN1+MONTDED(1)
        Endif
      Endif
    Endif
##  Endif
Next I
#-----
Return

##################################
$LECT_TCUCUR
If [F:TCU]CUR<>WCUR
  Read [TCU] TCU0=WCUR
  If !fstat  WRND=[F:TCU]CURRND  Else  WRND=0.01 : Endif
Else
  WRND=[F:TCU]CURRND
Endif
Return
########################################################################
########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 108760 - 2015-06-12 by SR : adaptation
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
Call MAJ_UUMGTRTPUR07(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTPUR07(APPLI)
End

