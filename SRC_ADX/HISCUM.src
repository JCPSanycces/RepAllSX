#<AdxTL>@(#)1.0.0.0 $Revision$
####################################################
## Etat HISCUM
####################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Call TEMPON("O") From GESECRAN

Local Char    SOCIETE(GLONCPY) , SITEDEB(GLONFCY) , SITEFIN(GLONFCY) , MATDEB(GLONEML) , MATFIN(GLONEML)
Local Date    DATEDEB , DATEFIN
Local Char    PARAM(20) , PROFIL(GLONPRF) , SERVICE(GLONSRV), POPULATION(GLONPOP), CODCUM(GLONCUM)
Local Char    CRITERE1(250) , CRITERE2(250)
Local Integer K , NUMREQ , OK

If clalev([F:HSP])=0    : Local File HISTOPAYE [HSP]  : Endif
If clalev([F:VEP])=0    : Local File VALEMP    [VEP]  : Endif
If clalev([F:HRPOA])=0    : Local File POPULA    [HRPOA]  : Endif
If clalev([F:FGR])=0    : Local File FACGROUP  [FGR]  : Endif
If clalev([F:CUM])=0    : Local File CUMUL     [CUM]  : Endif
If clalev([F:TMP])=0    : Local File TMPHISTO  [TMP]  : Endif
If clalev([F:ACC])=0    : Local File ACCES     [ACC]  : Endif
If clalev([F:ID])=0     : Local File EMPLOID   [ID]   : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR  [HRCTR]: Endif


Call GETPARAM("cumul",NBPAR,PARAMETRE,CODCUM)
Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE)
Call GETPARAM("sitedeb",NBPAR,PARAMETRE,SITEDEB)
Call GETPARAM("sitefin",NBPAR,PARAMETRE,SITEFIN)
Call GETPARAM("datedeb",NBPAR,PARAMETRE,PARAM) : DATEDEB = PARAM
Call GETPARAM("datefin",NBPAR,PARAMETRE,PARAM) : DATEFIN = PARAM
Call GETPARAM("population",NBPAR,PARAMETRE,POPULATION)
Call GETPARAM("matdeb",NBPAR,PARAMETRE,MATDEB)
Call GETPARAM("matfin",NBPAR,PARAMETRE,MATFIN)
Call GETPARAM("profil",NBPAR,PARAMETRE,PROFIL)
Call GETPARAM("service",NBPAR,PARAMETRE,SERVICE)
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) : [L]NUMREQ = val(PARAM)

PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

CRITERE1 = "[F:HSP]TYP=6 & [F:HSP]RUB='"+CODCUM+"'"
If DATEDEB<>[0/0/0]
 CRITERE1 -= "& [F:HSP]DAT>=["+format$(GFMD,DATEDEB)+"]"
Endif
If DATEFIN<>[0/0/0]
 CRITERE1 -= "& [F:HSP]DAT<=["+format$(GFMD,DATEFIN)+"]"
Endif
If MATDEB<>""
 CRITERE1 -= '& [F:HSP]EMP>="'+MATDEB+'"'
Endif
If MATFIN<>""
 CRITERE1 -= '& [F:HSP]EMP<="'+MATFIN+'"'
Endif


CRITERE2 = '[F:FGR]CPY="'+SOCIETE+'"'
If SITEDEB<>""
 CRITERE2 -= '& [F:VEP]FCY>="'+SITEDEB+'"'
Endif
If SITEFIN<>""
 CRITERE2 -= '& [F:VEP]FCY<="'+SITEFIN+'"'
Endif
If PROFIL<>""
 CRITERE2 -= '& [F:VEP]PRF="'+PROFIL+'"'
Endif
If SERVICE<>""
 CRITERE2 -= '& [F:VEP]SRV="'+SERVICE+'"'
Endif

If POPULATION<>""
 Link [HSP] With [VEP]VEP5=[F:HSP]BUL
& , [FGR]FGR0=SOCIETE;[F:VEP]FCY
& , [HRPOA]POA0=POPULATION;[F:HSP]EMP
& As [LHSP]
& Where evalue(CRITERE1) & evalue(CRITERE2) & [F:HRPOA]REFNUM<>""
& Order By Key CLE=[F:HSP]EMP;[F:HSP]CTRNUM;[F:HSP]DAT
Else
 Link [HSP] With [VEP]VEP5=[F:HSP]BUL
& , [FGR]FGR0=SOCIETE;[F:VEP]FCY
& As [LHSP]
& Where evalue(CRITERE1) & evalue(CRITERE2)
& Order By Key CLE=[F:HSP]EMP;[F:HSP]CTRNUM;[F:HSP]DAT
Endif

#FQ69466 - MABON 30/11/2010
SVFONCTION = GFONCTION
Call GETPARAM("X3FCT",NBPAR,PARAMETRE,GFONCTION)
Call AUTORIS From EXEFNC

Call DEBTRANS From GLOCK
Gosub TR1
Call TEMPOFF From GESECRAN
#FQ69466 - SEGAY 09/12/13
GFONCTION = SVFONCTION
Call AUTORIS From EXEFNC
End

$TR1
GOK = 1
Trbegin [TMP]
 Delete [TMP] Where USR=GUSER & DAT<date$
 If fstat=1
  GOK = -1 : GLOCK = "TMPHISTO"-GUSER : Goto ROLL_TR1
 Endif
 K = 0
 For [LHSP]CLE(2)
  Read [ID]ID0=[F:HSP]EMP
  If !fstat
   Filter [HRCTR] Where REFNUM=[F:HSP]EMP & CTRNUM=[F:HSP]CTRNUM
   Read [HRCTR]CTR0 Last
   Filter [HRCTR]
   If !fstat
    Call CONTROLE([F:HSP]EMP,[F:HSP]DAT,[F:HSP]CTRNUM,"",OK,1) From DIVPAYE
   Else
    OK = 0
   Endif
  Else OK = 0
  Endif
  If OK
   #39248
   #For [LHSP]CLE (2)
   For [LHSP]CLE
    Raz [F:TMP]
    K+=1
    [F:TMP]USR    = GUSER
    [F:TMP]RQT    = [L]NUMREQ
    [F:TMP]BUL    = [F:HSP]BUL
    [F:TMP]EMP    = [F:HSP]EMP
    [F:TMP]CTRNUM = [F:HSP]CTRNUM
    [F:TMP]RUB    = [F:HSP]RUB
    Call LECTURE("CUM",[F:HSP]RUB,GCURLEG) From CONTOBJ
    [F:TMP]ROW    = [F:CUM]CUMROW
    [F:TMP]DAT    = [F:HSP]DAT
    [F:TMP]LIG    = K
    [F:TMP]AMT(0) = [F:HSP]AMT
    [F:TMP]AMT(1) = [F:HSP]AMT-[F:HSP]BAS
    Write [TMP]
    If fstat
     GOK = 0 : Call FSTA("TMP") From GLOCK : Break 2
    Endif
   Next
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End
