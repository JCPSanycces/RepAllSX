#<AdxTL>@(#)7.0.0.0 $Revision$
###############################################################################################################
#
#   Génération HTML d'une Tâche                                                         Version 140
#   Module CRM                             
#   
###############################################################################################################

Subprog TSKINHTML(SZRECNUM, IGENERICFILENAME, SZSCREENTYPE, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZRECNUM
Value Integer IGENERICFILENAME
Value Char SZSCREENTYPE
Value Char SZPECONTEXT
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF
ICHAPTER = 0
IERRINF = 0
SZFULLRETFILE = ""
SZRETFILENAME = ""

If SZRECNUM = "" : End : Endif

Gosub HTMLPART1 From CRMXML140

Call TEXTE(1195, SZHTMLTITLE) From OBJDIV      #Tâche
SZSUBPROG = "TSKINHTML"
SZAOBABREV = "TSK"

Gosub HTMLPART2 From CRMXML140
If IERRINF : End : Endif

Gosub DOCOREHTML

Gosub HTMLPART3 From CRMXML140

End

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOCOREHTML

Gosub SETTSKEXCEPT From CRMEXCEPT

#On extrait
Filter [TSK] Where [F:TSK]TSKNUM = SZRECNUM

For [TSK]
    Gosub HTMLTSK From CRMEXCEPT
Next

Filter [TSK]

Return



