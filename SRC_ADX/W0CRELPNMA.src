#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CRELPNMA 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone STOFCY
mkstat = 0
zoncou = "STOFCY"
indice = 0
If varmode([M]STOFCY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "STOFCY" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]STOFCY,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "STOFCY" : GZNUM = 1347 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "ACONTFCY"
  Call CONTSITE([M]STOFCY) From SUBAGF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "STOFCY" : GZNUM = 1347 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("FCY","D",[M]STOFCY,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "STOFCY" : GZNUM = 1347 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone TCTRNUM
mkstat = 0
zoncou = "TCTRNUM"
indice = 0
WCHAR = [M]TCTRNUM
If varmode([M]TCTRNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TCTRNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]TCTRNUM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "TCTRNUM" : GZNUM = 7892 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("TCTR","A",[M]TCTRNUM,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "TCTRNUM" : GZNUM = 7892 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]TCTRNUM or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_TCTRNUM([M]TCTRNUM) From SUBCRELPNMA
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "TCTRNUM" : GZNUM = 7892 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone TCTRTYP
mkstat = 0
zoncou = "TCTRTYP"
indice = 0
IMPENT = [M]TCTRTYP
If varinit([M]TCTRTYP,indice)=0
 IMPENT = 1
Endif
[M]TCTRTYP = IMPENT

## Zone ENAFLG
mkstat = 0
zoncou = "ENAFLG"
indice = 0
IMPENT = [M]ENAFLG
If varinit([M]ENAFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]ENAFLG,indice)=0
 [M]ENAFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENAFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ENAFLG(indice)
 Endif
Endif
[M]ENAFLG = IMPENT

## Zone MONITMFLG
mkstat = 0
zoncou = "MONITMFLG"
indice = 0
IMPENT = [M]MONITMFLG
WNUM = IMPENT
If varinit([M]MONITMFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]MONITMFLG,indice)=0
 [M]MONITMFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "MONITMFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]MONITMFLG(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_MONITMFLG(IMPENT) From SUBCRELPNMA
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "MONITMFLG" : GZNUM = 19284 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]MONITMFLG = IMPENT

## Zone MONLOTFLG
mkstat = 0
zoncou = "MONLOTFLG"
indice = 0
IMPENT = [M]MONLOTFLG
WNUM = IMPENT
If varinit([M]MONLOTFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]MONLOTFLG,indice)=0
 [M]MONLOTFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "MONLOTFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]MONLOTFLG(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_MONLOTFLG(IMPENT) From SUBCRELPNMA
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "MONLOTFLG" : GZNUM = 26223 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]MONLOTFLG = IMPENT

## Zone LOC
mkstat = 0
zoncou = "LOC"
indice = 0
If varmode([M]LOC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LOC" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("LOC","!",[M]LOC,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "LOC" : GZNUM = 3623 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_LOC([M]LOC) From SUBCRELPNMA
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "LOC" : GZNUM = 3623 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone NBRLPN
mkstat = 0
zoncou = "NBRLPN"
indice = 0
WNUM = [M]NBRLPN
If varmode([M]NBRLPN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRLPN" : Gosub ACTION From =IMPTRT
 Endif
 If [M]NBRLPN=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "NBRLPN" : GZNUM = 1120 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>[M]NBRLPN or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_NBRLPN([M]NBRLPN) From SUBCRELPNMA
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NBRLPN" : GZNUM = 1120 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone PRTFLG
mkstat = 0
zoncou = "PRTFLG"
indice = 0
IMPENT = [M]PRTFLG
WNUM = IMPENT
If varinit([M]PRTFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]PRTFLG,indice)=0
 [M]PRTFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PRTFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PRTFLG(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_PRTFLG(IMPENT) From SUBCRELPNMA
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PRTFLG" : GZNUM = 810 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]PRTFLG = IMPENT

## Zone LBEFMT
mkstat = 0
zoncou = "LBEFMT"
indice = 0
If varmode([M]LBEFMT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LBEFMT" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ARP","!",[M]LBEFMT,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "LBEFMT" : GZNUM = 2209 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PRT
mkstat = 0
zoncou = "PRT"
indice = 0
If varmode([M]PRT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PRT" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("AIM","!",[M]PRT,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PRT" : GZNUM = 5231 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CRELPNMA"
Return

