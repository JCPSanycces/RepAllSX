#<AdxTL>@(#)0.0.0.0 $Revision$ Object management HRAET
$ACTION
Case ACTION
  When "OUVRE"          : Gosub OUVRE
  When "LIENS"          : Gosub LIENS
  When "CREATION"       : Gosub CREATION
  When "MODIF"          : Gosub MODIF
  When "RAZCRE"         : Gosub RAZCRE
  When Default
Endcase
Return

$OUVRE
  If clalev([F:HRAET])=0    : Local File HRATTEARTYP  [HRAET]   : Endif
  If clalev([F:HRAER])=0    : Local File HRATTEARRAT  [HRAER]   : Endif
Return

$LIENS
  Read [HRAET]HRAET0 = [M:HRAET0]TYPCOD

  Call ENABLEGRID([M:HRAET0]FIXEDAMT)

  Filter [F:HRAER] Where AETYP = [F:HRAET]TYPCOD
  nolign = 0
  For [HRAER]HRAER0
    nolign += 1
    [M:HRAET1] = [F:HRAER]
  Next
  Assign "[M:HRAET1]AEDNBR" With nolign
  Filter [HRAER]
Return

$CREATION
$MODIF
  Read [HRAET]HRAET0 = [M:HRAET0]TYPCOD
  Local Integer ADDCNT
  Filter [F:HRAER]
  Delete [F:HRAER] Where [F:HRAER]AETYP=[M:HRAET0]TYPCOD
  If fstat=1 | fstat>5
    GOK=0 : Call RSTA("AEDR",[F:HRAET]AUUID) From GLOCK : Return
  Endif

  If [M:HRAET0]FIXEDAMT <> 2
    For nolign = 1 To [M:HRAET1]AEDNBR
      Raz [F:HRAER]
      [F:HRAER] = [M:HRAET1]
      [F:HRAER]AETYP = [F:HRAET]TYPCOD
      [F:HRAER]LIGNBR = nolign
      Write [F:HRAER]
      If fstat
        GOK=0 : Call FSTA("HRAER") From GLOCK : Break
      Endif
    Next
  Endif
Return

$RAZCRE
  Local Char COUNTER(30)
  Local Integer STAT

  Call NUMERO("AETYP", "", date$, "", COUNTER, STAT) From SUBANM
  If STAT
    GMESSAGE = mess(104,117,1) - "AETYP"
    GOK = 0 : End
  Endif
  [M:HRAET0]TYPCOD = COUNTER
  Affzo [M:HRAET0]TYPCOD
Return

Subprog AS_AEFROM(VALEUR)
Variable Decimal VALEUR
  If nolign > 1
    If [M:HRAET1]AETO(nolign - 2) = 0
      GMESSAGE = mess(21,11800,1)
      mkstat = 2 : GERR=1
      End
    Endif

    If nolign > 1 & [M:HRAET1]AETO(nolign - 2) > 0
      VALEUR = [M:HRAET1]AETO(nolign - 2) + 0.01
      Affzo [M:HRAET1]AEFROM
    Endif
  Endif
End

Subprog C_AEFROM(VALEUR)
Variable Decimal VALEUR
  # Check From against previous line To amount
  If nolign > 1
    If [M:HRAET1]AETO(nolign - 2) = 0
      GMESSAGE = mess(21,11800,1)
      mkstat = 2 : GERR=1
      End
    Endif

    If VALEUR - [M:HRAET1]AETO(nolign - 2) <> 0.01
      GMESSAGE = mess(22,11800,1)
      mkstat = 2 : GERR=1
      End
    Endif
  Endif

  If (VALEUR > 0 & [M:HRAET1]AETO(nolign - 1) > 0)
    If VALEUR >= [M:HRAET1]AETO(nolign - 1)
      GMESSAGE = mess(15,11800,1)
      mkstat = 2 : GERR=1
    Endif
  Endif
End

Subprog C_AETO(VALEUR)
Variable Decimal VALEUR
  If VALEUR > 0
    If VALEUR <= [M:HRAET1]AEFROM(nolign - 1)
      GMESSAGE = mess(16,11800,1)
      mkstat = 2 : GERR=1
    Endif
  Endif
End

Subprog C_DEDRAT(VALEUR)
Variable Decimal VALEUR

  If func CHECKCAPTUREDVALS(VALEUR, [M:HRAET1]AMOUNT(nolign - 1)) > 1
    GMESSAGE = mess(17,11800,1)
    mkstat = 2 : GERR=1
  Endif

End

Subprog C_AMOUNT(VALEUR)
Variable Decimal VALEUR
  If func CHECKCAPTUREDVALS([M:HRAET1]DEDRAT(nolign - 1), VALEUR) > 1
    GMESSAGE = mess(17,11800,1)
    mkstat = 2 : GERR=1
  Endif
End

Funprog CHECKCAPTUREDVALS(A, B)
Value Decimal A, B
Local Integer RET: RET = 0

If A > 0 : RET += 1 Endif
If B > 0 : RET += 1 Endif

End RET

Subprog AM_FIXEDAMT(VALEUR)
Variable Integer VALEUR

  Call ENABLEGRID(VALEUR)

End

Subprog ENABLEGRID(VFIXEDAMT)
Value Integer VFIXEDAMT

  If VFIXEDAMT = 1
    Actzo [M:HRAET1]
  Else
    Grizo [M:HRAET1]
  Endif

End

