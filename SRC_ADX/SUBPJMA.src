##########################################################################################################
Subprog _LOAD_TITLES_20()

  # Issue X3-106111 - 2018-08-30 by FGR
  If TECFINOVE20 <> null Then
    FreeGroup TECFINOVE20
  Endif
  # -------------------------
  TECFINOVE20 = NewInstance C_TECFINOVE AllocGroup null
  # -------------------------
  IRET = fmet TECFINOVE20._GET_DEFAULT_GRP()
  TECFINOVE20.UOM = fmet GZINSPJM.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFCY, GZINSPJM.SALFCY, "UNITWORK")
  #TECFINOVE20.PROJECT  = GZINSPJM               # Issue X3-82778 - 2018-06-18 by FGR : not necessary
  TECFINOVE20.ISBUDUPD = [V]CST_ANO
  TECFINOVE20.OPPNUM   = GZINSPJM.OPPNUM
  TECFINOVE20.CUR      = GZINSPJM.PJM(1).CUROPP
  TECFINOVE20.SHOWGRP  = "20"
  #
  IRET = fmet TECFINOVE20.TITLE_EXTRACT()
End

