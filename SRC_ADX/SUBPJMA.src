Subprog SET_STYLES_10_20()

  Call SET_STYLES_10()
  Call SET_STYLES_20()
End

##########################################################################################################
Subprog SET_STYLES_10()

  # PJMBUD     (pink)
  Chgstl [M:PJM5E]PSCBUDQTY   With "PJMBUD"
  Chgstl [M:PJM5E]PSCBUDAMT   With "PJMBUD"
  # PJMEXPENSE (green)
  Chgstl [M:PJM5E]PSCQTY1     With "PJMEXPENSE"
  Chgstl [M:PJM5E]PSCAMT1     With "PJMEXPENSE"
  Chgstl [M:PJM5E]PSCQTY2     With "PJMEXPENSE"
  Chgstl [M:PJM5E]PSCAMT2     With "PJMEXPENSE"
  Chgstl [M:PJM5E]PSCQTY3     With "PJMEXPENSE"
  Chgstl [M:PJM5E]PSCAMT3     With "PJMEXPENSE"
  Chgstl [M:PJM5E]PSCQTY4     With "PJMEXPENSE"
  Chgstl [M:PJM5E]PSCAMT4     With "PJMEXPENSE"
  Chgstl [M:PJM5E]PSCQTY5     With "PJMEXPENSE"
  Chgstl [M:PJM5E]PSCAMT5     With "PJMEXPENSE"
  # PJMREMAINS (yellow)
  Chgstl [M:PJM5E]PSCREMQTY   With "PJMREMAINS"
  Chgstl [M:PJM5E]PSCREMAMT   With "PJMREMAINS"
  Chgstl [M:PJM5E]PSCWIPQTY   With "PJMREMAINS"
  Chgstl [M:PJM5E]PSCWIPAMT   With "PJMREMAINS"
  # PJMTOTAL   (orange)
  Chgstl [M:PJM5E]PSCTOTQTY   With "PJMTOTAL"
  Chgstl [M:PJM5E]PSCTOTAMT   With "PJMTOTAL"
  # Issue X3-106658 - 2018-09-05 by ALMON : START : Apply specific display styles for POS and NEG values
  If [M:PJM5E]PSCMARGQTY < 0 Then
    Chgstl [M:PJM5E]PSCMARGQTY  With "PJMTOTVARR"
  Else
    Chgstl [M:PJM5E]PSCMARGQTY  With "PJMTOTVARG"
  Endif
  If [M:PJM5E]PSCMARGAMT < 0 Then
    Chgstl [M:PJM5E]PSCMARGAMT  With "PJMTOTVARR"
  Else
    Chgstl [M:PJM5E]PSCMARGAMT  With "PJMTOTVARG"
  Endif
  If [M:PJM5E]PSCPCTMQTY < 0 Then
    Chgstl [M:PJM5E]PSCPCTMQTY  With "PJMTOTVARR"
  Else
    Chgstl [M:PJM5E]PSCPCTMQTY  With "PJMTOTVARG"
  Endif
  If [M:PJM5E]PSCPCTMAMT < 0 Then
    Chgstl [M:PJM5E]PSCPCTMAMT  With "PJMTOTVARR"
  Else
    Chgstl [M:PJM5E]PSCPCTMAMT  With "PJMTOTVARG"
  Endif
  # Issue X3-106658 - 2018-09-05 by ALMON END

End

##########################################################################################################
Subprog SET_STYLES_20()

  # PJMREVENUE ("TBA")
  Chgstl [M:PJM5R]PSCFREEC6A  With "PJMREVENUE"
  Chgstl [M:PJM5R]PSCFREEC6B  With "PJMREVENUE"
  # Issue X3-106658 - 2018-09-05 by ALMON : START : Apply specific display styles for POS and NEG values
  If [M:PJM5R]PSCMARGBUD6 < 0 Then
    Chgstl [M:PJM5R]PSCMARGBUD6  With "PJMFINNEGV"
  Else
    Chgstl [M:PJM5R]PSCMARGBUD6  With "PJMFINPOSV"
  Endif
  If [M:PJM5R]PSCPCTMBUD6 < 0 Then
    Chgstl [M:PJM5R]PSCPCTMBUD6  With "PJMFINNEGV"
  Else
    Chgstl [M:PJM5R]PSCPCTMBUD6  With "PJMFINPOSV"
  Endif
  If [M:PJM5R]PSCMARGTOT6 < 0 Then
    Chgstl [M:PJM5R]PSCMARGTOT6  With "PJMFINNEGV"
  Else
    Chgstl [M:PJM5R]PSCMARGTOT6  With "PJMFINPOSV"
  Endif
  If [M:PJM5R]PSCPCTMTOT6 < 0 Then
    Chgstl [M:PJM5R]PSCPCTMTOT6  With "PJMFINNEGV"
  Else
    Chgstl [M:PJM5R]PSCPCTMTOT6  With "PJMFINPOSV"
  Endif
  # Issue X3-106658 - 2018-09-05 by ALMON END
  Chgstl [M:PJM5R]PSCFREEC7A  With "PJMREVENUE"
  Chgstl [M:PJM5R]PSCFREEC7B  With "PJMREVENUE"
  Chgstl [M:PJM5R]PSCFREEC8A  With "PJMREVENUE"
  Chgstl [M:PJM5R]PSCFREEC8B  With "PJMREVENUE"
  Chgstl [M:PJM5R]PSCFREEC9A  With "PJMREVENUE"
  Chgstl [M:PJM5R]PSCFREEC9B  With "PJMREVENUE"
  Chgstl [M:PJM5R]PSCFREEC10A With "PJMREVENUE"
  Chgstl [M:PJM5R]PSCFREEC10B With "PJMREVENUE"

End

##########################################################################################################
Subprog DISPLAY_EMPLOYEES()

Local Integer NI

  Affzo [M:PJM6]
  For NI = 0 To [M:PJM6]NBPJM6-1
    Diszo [M:PJM6]PAFCLB(NI)
  Next NI
End

##########################################################################################################
$RELIT_GZINSPJM
Local Integer MY_STATUS
Local Char SOPPNUM(GLONOPP)

  SOPPNUM = GZINSPJM.OPPNUM
  If GZINSPJM <> null Then
    FreeGroup GZINSPJM
  Endif
  GZINSPJM = NewInstance C_OPPOR AllocGroup null
  GZINSPJM.TCHTOREAD = "PJM"
  [L]MY_STATUS = fmet GZINSPJM.AREAD(SOPPNUM)
  If [L]MY_STATUS <> [V]CST_AOK Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM)
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(163,2260,1)
    Endif
    If [L]MY_STATUS <> [V]CST_AWARNING Then
      Return
    Endif
  Endif
Return

##########################################################################################################
Subprog RECOVERS_ERROR_IN_CLASSIC(GZINSPJM)
Variable Instance GZINSPJM Using C_OPPOR

Local Integer NI                                 # Hybrid part
Local Char SMESSAGE(type(GMESSAGE)-10)
Local Integer MY_STATUS
Local Integer IMESSAGE
Local Integer IOPEN_TRACE

  # Hybrid part (begin)
  IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(GZINSPJM, SMESSAGE)
  If IMESSAGE = [V]CST_AWARNING Then
    GMESSAGE = SMESSAGE
    GERR = 2
  Elsif IMESSAGE = [V]CST_AERROR or IMESSAGE = [V]CST_AFATAL Then
    GMESSAGE = SMESSAGE
    GOK = 0
    GERR = 1
  Endif
  # Hybrid part (end)
  # -------------------------
  # To help debug process : write a classic log file with all errors in class.
  If GERR <> 0 Then
    If GTRACE = AVOID.ACHAR Then
      Call OUVRE_TRACE("MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG" + GUSER) From LECFIC
      IOPEN_TRACE = [V]CST_AYES
    Endif
    Call ECR_TRACE("->", 0) From GESECRAN
    Call MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(GZINSPJM) From SYRSTACKTOOLS
    If IOPEN_TRACE = [V]CST_AYES Then
      Call FERME_TRACE From LECFIC
    Endif
  Endif
  # -------------------------
  #[L]MY_STATUS = fmet GZINSPJM.PJM_RESET_ERRORS()         # Issue X3-96497 - 2018-06-28 by FGR
  [L]MY_STATUS = fmet GZINSPJM.RESET_ERRORS()              # Issue X3-96497 - 2018-06-28 by FGR
End

##########################################################################################################
Subprog COPY_SCREEN_TO_CLASS()

Local Integer NI                                 # Hybrid part
Local Integer ILINE                              # Hybrid part
Local Integer ASTATUS                            # Hybrid part

  # -------------------------
  # Hybrid part (begin)
  # [M:PJM2] ----------------------------------
  For NI = 1 To maxtab(GZINSPJM.CPP)
    If GZINSPJM.CPP(NI) <> null and find(GZINSPJM.CPP(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
      ILINE = find(num$(GZINSPJM.CPP(NI).AUUID), [M:PJM2]AUUID(0..[M:PJM2]NBPJM2-1))
      If ILINE = 0 Then
        ILINE = find(NI, [M:PJM2]COLLIN(0..[M:PJM2]NBPJM2-1))
      Endif
      If ILINE = 0 Then
        [L]ASTATUS = fmet GZINSPJM.ADELLINE("CPP",GZINSPJM.CPP(NI).AORDER)
        If [L]ASTATUS = [V]CST_ANOTDEFINED Then  # Issue X3-96497 - 2018-06-27 by FGR
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
          GOK = 0
          GERR = 1
          Break
        Endif
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
  # [M:PJM3] ----------------------------------
  For NI = 1 To maxtab(GZINSPJM.SBB)
    If GZINSPJM.SBB(NI) <> null and find(GZINSPJM.SBB(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
      ILINE = find(num$(GZINSPJM.SBB(NI).AUUID), [M:PJM3]AUUID(0..[M:PJM3]NBPJM3-1))
      If ILINE = 0 Then
        ILINE = find(NI, [M:PJM3]COLLIN(0..[M:PJM3]NBPJM3-1))
      Endif
      If ILINE = 0 Then
        [L]ASTATUS = fmet GZINSPJM.ADELLINE("SBB",GZINSPJM.SBB(NI).AORDER)
        If [L]ASTATUS = [V]CST_ANOTDEFINED Then  # Issue X3-96497 - 2018-06-27 by FGR
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
          GOK = 0
          GERR = 1
          Break
        Endif
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
  # [M:PJM4] ----------------------------------
  # Nothing to do for this screen
  # [M:PJM6] ----------------------------------
  For NI = 1 To maxtab(GZINSPJM.PJM(1).PAF)
    If GZINSPJM.PJM(1).PAF(NI) <> null and find(GZINSPJM.PJM(1).PAF(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
      ILINE = find(num$(GZINSPJM.PJM(1).PAF(NI).AUUID), [M:PJM6]AUUID(0..[M:PJM6]NBPJM6-1))
      If ILINE = 0 Then
        ILINE = find(NI, [M:PJM6]COLLIN(0..[M:PJM6]NBPJM6-1))
      Endif
      If ILINE = 0 Then
        [L]ASTATUS = fmet GZINSPJM.PJM(1).ADELLINE("PAF",GZINSPJM.PJM(1).PAF(NI).AORDER)
        If [L]ASTATUS = [V]CST_ANOTDEFINED Then  # Issue X3-96497 - 2018-06-27 by FGR
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
          GOK = 0
          GERR = 1
          Break
        Endif
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
  # Hybrid part (end)
End

##########################################################################################################
Subprog DISPLAY_PJM_PROJECT()

Local Integer MY_STATUS
Local Integer NI

  Call SHOW_PJM_HEADER()
  # -------------------------
  nolign = 0
  For NI = 1 To maxtab(GZINSPJM.CPP)
    If GZINSPJM.CPP(NI) <> null and find(GZINSPJM.CPP(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      nolign += 1
      Call SHOW_PJM_PJM2(NI)
    Endif
  Next NI
  [M:PJM2]NBPJM2 = nolign
  Affzo [M:PJM2]1-99
  # -------------------------
  nolign = 0
  For NI = 1 To maxtab(GZINSPJM.SBB)
    If GZINSPJM.SBB(NI) <> null and find(GZINSPJM.SBB(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      nolign += 1
      Call SHOW_PJM_PJM3(NI)
    Endif
  Next NI
  [M:PJM3]NBPJM3 = nolign
  Affzo [M:PJM3]1-99
  # -------------------------
  [L]MY_STATUS = func CDIE_CLASS_TO_SCREEN(GZINSPJM.PJM(1), "PJM4", "NBRDIE", "SUBPJMA")
  Affzo [M:PJM4]1-99
  # -------------------------
  nolign = 0
  For NI = 1 To maxtab(GZINSPJM.PJM(1).PAF)
    If GZINSPJM.PJM(1).PAF(NI) <> null and find(GZINSPJM.PJM(1).PAF(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      nolign += 1
      Call SHOW_PJM_PJM6(NI)
    Endif
  Next NI
  [M:PJM6]NBPJM6 = nolign
  Affzo [M:PJM6]1-99
End

##########################################################################################################
Subprog SHOW_PJM_HEADER()

  SetInstance [M:PJM0] With GZINSPJM
  SetInstance [M:PJM1] With GZINSPJM
  SetInstance [M:PJM0] With GZINSPJM.PJM(1)
  SetInstance [M:PJM1] With GZINSPJM.PJM(1)
  [M:PJM0]PIMDESAXX = GZINSPJM.PIMPL.PIMDESAXX
  [M:PJM0]PIMDESAX1 = GZINSPJM.PIMPL.PIMDESAX1
  # -------------------------
  # Issue X3-107974 - 2018-10-09 by FGR : BEGIN
  #If GFCY <> [M:PJM0]SALFCY Then
  #  GFCY = [M:PJM0]SALFCY
  #  Call GETDEV(GFCY) From DEVSUB
  #  GFINRSP = fmet GZINSPJM.ACTX.ACACHE.AFCY.AGETVALCHAR([M:PJM0]SALFCY, "FINRSPFCY")
  #  #---- Chargement de GCUR
  #  Call CHARGE_GCUR() From TRTX3
  #Endif
  Call LOAD_CURRENT_FCY()
  # Issue X3-107974 - 2018-10-09 by FGR : END
  Affzo [M:PJM0]1-99
  Affzo [M:PJM1]1-99
End

##########################################################################################################
Subprog SHOW_PJM_PJM2(VNLINE)
Value Integer VNLINE

  SetInstance [M:PJM2]5 With GZINSPJM.CPP(VNLINE)
  [M:PJM2]COLLIN(nolign-1) = VNLINE   # Line index in the collection
End

##########################################################################################################
Subprog SHOW_PJM_PJM3(VNLINE)
Value Integer VNLINE

  SetInstance [M:PJM3]5 With GZINSPJM.SBB(VNLINE)
  [M:PJM3]COLLIN(nolign-1) = VNLINE   # Line index in the collection
End

##########################################################################################################
Subprog SHOW_PJM_PJM4(VNLINE)
Value Integer VNLINE

  SetInstance [M:PJM4]5 With GZINSPJM.PJM(1).CDIE(VNLINE)
  [M:PJM4]COLLIN(nolign-1) = VNLINE   # Line index in the collection
End

##########################################################################################################
Subprog SHOW_PJM_PJM6(VNLINE)
Value Integer VNLINE

  SetInstance [M:PJM6]5 With GZINSPJM.PJM(1).PAF(VNLINE)
  [M:PJM6]COLLIN(nolign-1) = VNLINE   # Line index in the collection
  Call LECTEXTRA([M:PJM6]PAFNAM(nolign-1),"AUTILIS","INTUSR",[M:PJM6]PAFCLB(nolign-1),"") From ATEXTRA
End

##########################################################################################################
Subprog EXTRACT_ALL_10_20()

  Call EXTRACT_ALL_10()
  Call EXTRACT_ALL_20()
  Call DISPLAY_10_20()
  Call SET_STYLES_10_20()
End

