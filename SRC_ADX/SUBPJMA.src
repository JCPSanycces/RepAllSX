##########################################################################################################
Subprog EXTRACT_ALL_10()

Local Instance TECFINOVE Using C_TECFINOVE
Local Integer IRET

  TECFINOVE = NewInstance C_TECFINOVE AllocGroup null
  #TECFINOVE.PROJECT  = GZINSPJM              # Issue X3-82778 - 2018-06-18 by FGR : not necessary # Note FGR : optimisation for financial overview loading.
  TECFINOVE.ISBUDUPD = [V]CST_ANO             # Issue X3-82778 - 2018-06-18 by FGR : not [V]CST_AYES
  TECFINOVE.OPPNUM   = GZINSPJM.OPPNUM        # Issue X3-106111 - 2018-08-30 by FGR : not [M:PJM0]OPPNUM
  TECFINOVE.CUR      = GZINSPJM.PJM(1).CUROPP # Issue X3-106111 - 2018-08-30 by FGR : not [M:PJM1]CUROPP
  TECFINOVE.UOM      = fmet TECFINOVE.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFCY, GZINSPJM.SALFCY, "UNITWORK") # Issue X3-106111 - 2018-08-30 by FGR : not [M:PJM0]SALFCY
  TECFINOVE.SHOWGRP  = "10"
  TECFINOVE.MULPRJ   = [V]CST_ANO
  #--------------------------------
  If TECFINOVE.UOM = AVOID.ACHAR Then
    GMESSAGE = func AFNC.MES1(mess(398,2260,1), [M:PJM0]SALFCY)
    GOK = 0
    End
  Endif
  #--------------------------------
  IRET = func PJMRPTEXT.COMPUTE_TECFINOVE(TECFINOVE, func GET_KEYEXT_10())
  FreeGroup TECFINOVE
  #--------------------------------
End

