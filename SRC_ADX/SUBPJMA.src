  Call DISPLAY_20()
End

##########################################################################################################
Subprog DISPLAY_10()

  Local File PJMFINOVRRPT [PJMRPT]
  Filter [F:PJMRPT] Where [F:PJMRPT]KEYEXT = func GET_KEYEXT_10() and [F:PJMRPT]OPPNUM  = GZINSPJM.OPPNUM and [F:PJMRPT]PBUCOD = AVOID.ACHAR and [F:PJMRPT]PCCCOD = AVOID.ACHAR
  For [F:PJMRPT]
    [M:PJM5E] = [F:PJMRPT]
    [M:PJM5E]EXTDAT = gdat$(day([F:PJMRPT]CREDATTIM),month([F:PJMRPT]CREDATTIM),year([F:PJMRPT]CREDATTIM))
    [M:PJM5E]PSCU = fmet GZINSPJM.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFCY, [M:PJM0]SALFCY, "UNITWORK")
    Break
  Next
  Filter [F:PJMRPT]
  # -------------------------
  If [M:PJM5E]EXTDAT = [0/0/0] Then
    Chgstl [M:PJM5E]EXTDAT With "BACKYELLOW"
  Elsif [M:PJM5E]EXTDAT = date$ Then
    Chgstl [M:PJM5E]EXTDAT With ""
  Elsif [M:PJM5E]EXTDAT = date$-7 Then
    Chgstl [M:PJM5E]EXTDAT With "BACKORANGE"
  Else
    Chgstl [M:PJM5E]EXTDAT With "BACKRED"
  Endif
  # -------------------------
  If [M:PJM1]DUEDAT <> AVOID.ADATE and [M:PJM1]ENDDAT <> AVOID.ADATE Then
    If [M:PJM1]DUEDAT < [M:PJM1]ENDDAT Then
      Chgstl [M:PJM1]DUEDAT With "PJMWARN1"
    Elsif [M:PJM1]DUEDAT = [M:PJM1]ENDDAT or [M:PJM1]DUEDAT > [M:PJM1]ENDDAT Then
      Chgstl [M:PJM1]DUEDAT With ""
    Endif
  Else
    Chgstl [M:PJM1]DUEDAT With ""
  Endif
  # -------------------------
  Affzo [M:PJM5E]1-99
End

##########################################################################################################
Subprog DISPLAY_20()

  Local File PJMFINOVRRPT [PJMRPT]
  Filter [F:PJMRPT] Where [F:PJMRPT]KEYEXT = func GET_KEYEXT_20() and [F:PJMRPT]OPPNUM  = GZINSPJM.OPPNUM and [F:PJMRPT]PBUCOD = AVOID.ACHAR and [F:PJMRPT]PCCCOD = AVOID.ACHAR
  For [F:PJMRPT]
    [M:PJM5R] = [F:PJMRPT]
    [M:PJM5R]PSCU = fmet GZINSPJM.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFCY, [M:PJM0]SALFCY, "UNITWORK")
    Break
  Next
  Filter [F:PJMRPT]
  Affzo [M:PJM5R]1-99
End

