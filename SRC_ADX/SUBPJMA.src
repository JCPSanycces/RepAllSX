  TECFINOVE.OPPNUM   = GZINSPJM.OPPNUM        # Issue X3-106111 - 2018-08-30 by FGR : not [M:PJM0]OPPNUM
  TECFINOVE.CUR      = GZINSPJM.PJM(1).CUROPP # Issue X3-106111 - 2018-08-30 by FGR : not [M:PJM1]CUROPP
  TECFINOVE.UOM      = fmet TECFINOVE.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFCY, GZINSPJM.SALFCY, "UNITWORK") # Issue X3-106111 - 2018-08-30 by FGR : not [M:PJM0]SALFCY
