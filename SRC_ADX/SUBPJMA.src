##########################################################################################################
Funprog GET_AUTHORIZATION(SBOUT)
Value Char SBOUT

Local Integer IARENDRE

  # Issue X3-99928 - 2018-07-19 by FGR
  GBIDC2 = SBOUT
  Gosub AUTORIS_OPT From CONTX3
  If !GBIDI2 Then
    IARENDRE = [V]CST_ANO
  Else
    IARENDRE = [V]CST_AYES
  Endif
End IARENDRE

##########################################################################################################
Funprog GET_AUTHORIZATION_AFC(SAFC, SBOUT)
Value Char SAFC
Value Char SBOUT

Local Integer IARENDRE
Local Char SAVFONCTION(type(GFONCTION)-1)

  # Issue X3-99928 - 2018-07-19 by FGR
  SAVFONCTION = GFONCTION
  GFONCTION = SAFC
  Call AUTORIS From EXEFNC
  IARENDRE = func GET_AUTHORIZATION(SBOUT)
  GFONCTION = SAVFONCTION
  Call AUTORIS From EXEFNC
End IARENDRE

