$ON_PTETYP
Onevent INIT_AREA Call D_PTETYP(zc) From W1CONSPTE1
Return

Subprog D_PTETYP(VALEUR)
Variable Char    VALEUR()
If varinit([M]PTETYP,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"640","") From SUBADI
Endif
Gosub _AFF
End

$ON_PTESTA
Onevent INIT_AREA Call D_PTESTA(zc) From W1CONSPTE1
Return

Subprog D_PTESTA(VALEUR)
Variable Integer VALEUR
If varinit([M]PTESTA,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_FCY
Return

$CHG_STY
Return


