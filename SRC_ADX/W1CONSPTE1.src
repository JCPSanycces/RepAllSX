#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CONSPTE1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:25"
A_USER  = "DOC"
A_STAMP = "20181109230325"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CONSPTE1 [PTE1]
Gosub HORODAT
Local Inpbox "CONSPTE1" From GFONCTION At A_STAMP With A_WINDPREV Mask [PTE1] As [SIM_]
Grizo [PTE1]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PTE1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=112 : Y1(0)=1 : Y2(0)=22
Return

$ON_PAUS
Return

$ON_PTEQTY
Onevent BEFORE_AREA Gosub AV_PTEQTY From W1CONSPTE1
Return

$AV_PTEQTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find([M:PTE1]PTEUOM(nolign-1),GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]PTEQTY(indice) With "NPz:"+GUNTFMT
Gosub _AFF
Return

$ON_PTEUOM
Return

$ON_PTEDAT
Onevent BEFORE_AREA Gosub AV_PTEDAT From W1CONSPTE1
Return

$AV_PTEDAT
Chgfmt [M]PTEDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_OPPNUM
Return

$ON_PBUCOD
Return

