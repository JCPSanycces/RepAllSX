#<AdxTL>@(#)7.0.0.0 $Revision$  Gestion du fichier TRVACC
Call OBJET("VAC",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "MODIF"       : Gosub MODIF
 When "CREATION"    : Gosub CREATION
Endcase
Return

$OUVRE
#MIPEA - 2016-08-01 - REQ 114309 US280 - START
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If clalev([F:FCY])=0  : Local File FACILITY [FCY]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY  [CPY]  : Endif
If clalev([F:WAC])=0  : Local File TRVACC   [WAC]  : Endif
If clalev([F:WAR])=0  : Local File TRVACCRAT[WAR]  : Endif
#MIPEA - 2016-08-01 - REQ 114309 US280 - END
Return

$LIENS
Gosub CHARGE
Return

$CHARGE
nolign=0
For[F:WAR]WAR0 Where CODWAC=[M]CODWAC
 nolign += 1
 [M]=[F:WAR]
Next
#JOJAC - 2016-09-05 - X3PEOP-1691 - START
If func AFNC.ACTIV("VAC")
#JOJAC - 2016-09-05 - X3PEOP-1691 - END
  [M]NBLIG = nolign
Endif
#MIPEA - 2016-08-04 - REQ 114309 US280 - START
Filter [FCY] Where [FCY]RSKWRK=[M:VAC0]CODWAC
Read [FCY] Last
 If !fstat
  Read [CPY]CPY0=[F:FCY]LEGCPY
  If !fstat
   [M:VAC0]LEG = [F:CPY]LEG
   Endif
   Endif
Filter [FCY]
Affzo [M:VAC0]
#MIPEA - 2016-08-04 - REQ 114309 US280 - END
Return

$CREATION
# 30863
Gosub MODIF
Return

$MODIF
Delete [WAR] Where CODWAC=[M]CODWAC
If fstat=1
 GOK =-1 : GLOCK = "$TRVACCRAT" : Return
Endif
# 30863
#JOJAC - 2016-09-05 - X3PEOP-1691 - START
If func AFNC.ACTIV("VAC")
#JOJAC - 2016-09-05 - X3PEOP-1691 - END
  For nolign=1 To [M]NBLIG
   [F:WAR]CODWAC = [M]CODWAC
   [F:WAR]RATWAC = [M]RATWAC(nolign-1)
   [F:WAR]DATWAC = [M]DATWAC(nolign-1)
   Write [WAR]
   If fstat<>0
    GOK = 0 : Call FSTA("WAR") From GLOCK : Break
   Endif
  Next
Endif
#MIPEA - 2016-08-04 - REQ 114309 US280 - START
Filter [FCY] Where [FCY]RSKWRK=[M:VAC0]CODWAC
Read [FCY] Last
 If !fstat
  Read [CPY]CPY0=[F:FCY]LEGCPY
  If !fstat
   [M:VAC0]LEG = [F:CPY]LEG
  Endif
 Endif
Filter [FCY]
Affzo [M:VAC0]
#MIPEA - 2016-08-04 - REQ 114309 US280 - END
Return

