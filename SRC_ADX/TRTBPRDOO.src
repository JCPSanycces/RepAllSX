#<AdxTL>@(#)1.0.0.0 $Revision$
###########################################################################################
#   Gestion des donneurs d'ordres                        Module CRM         20 juillet 2000
###########################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When "OK"           : Gosub ONOK
 When Default
Endcase
Return


$OUVRE
Global Char GSZALH (30)(5)
Global Char GSZDAT (30)(5)
Global Char GSZINT (30)(5)
Global Char GSZDCB (30)(5)
Global Char GSZTTRBLC (30)(4)
Global Integer ISDIRTY
Global Integer INCUSTMODE
Local Integer I 
ISDIRTY = 0
INCUSTMODE = 0
I = 0
#Initialise GSZALH, GSZDAT, GSZINT, GSZDCB
For I = 0 To dim(GSZALH) - 1
    GSZALH(I) = ""
    GSZDAT(I) = ""
    GSZINT(I) = ""
    GSZDCB(I) = ""
Next
#Initialise GSZTTRBLC
I = 0
For I = 0 To dim(GSZTTRBLC) - 1
    GSZTTRBLC(I) = ""
Next

If !clalev([F:BPM]) : Local File BPMISC [BPM] : Endif
If !clalev([F:BPG]) : Local File BPMISCCGF [BPG] : Endif

#Charge les infos de configuration
Read [BPG] BPG0 = "DOO";GLANGUE
If !fstat
    I = 0
    For I = 0 To dim(GSZALH) - 1
        GSZALH(I) = [F:BPG]TTRALH(I)
        GSZDAT(I) = [F:BPG]TTRDAT(I)
        GSZINT(I) = [F:BPG]TTRINT(I)
        GSZDCB(I) = [F:BPG]TTRDCB(I)
    Next
    I = 0
    For I = 0 To dim(GSZTTRBLC) - 1
       GSZTTRBLC(I) = [F:BPG]TTRBLC(I)
    Next
Endif
Return

$DEFBOUT
Return

$SETBOUT
If ISDIRTY
    ETABOU(GVALI) = 1
Else
    ETABOU(GVALI) = 0
Endif

If INCUSTMODE
    ETABOU(GVALI) = 0
    ETAMEN(1) = 0
    ETAMEN(2) = 1
Else
    ETAMEN(1) = 1
    ETAMEN(2) = 0
Endif
Return

$OUVRE_BOITE
Return

$DEBUT
Local Integer U
U = 0
#Initialise la fenêtre avec les valeurs passées en paramètre.
[M:DOO1]BPRNUM = PARAM(1)
Read [BPR] BPR0 = PARAM(1)
If !fstat
    [M:DOO1]BPRNAM = [F:BPR]BPRNAM
Endif
[M:DOO1]CUR = PARAM(2)

#Chargement des informations
Read [BPM] BPM0 = "DOO";[M:DOO1]BPRNUM
If !fstat
        [M:DOO1]ALH1 = [F:BPM]ALHX(0)
        [M:DOO1]ALH2 = [F:BPM]ALHX(1)
        [M:DOO1]ALH3 = [F:BPM]ALHX(2)
        [M:DOO1]ALH4 = [F:BPM]ALHX(3)
        [M:DOO1]ALH5 = [F:BPM]ALHX(4)
        [M:DOO1]DAT1 = [F:BPM]DATX(0)
        [M:DOO1]DAT2 = [F:BPM]DATX(1)
        [M:DOO1]DAT3 = [F:BPM]DATX(2)
        [M:DOO1]DAT4 = [F:BPM]DATX(3)
        [M:DOO1]DAT5 = [F:BPM]DATX(4)
        [M:DOO1]INT1 = [F:BPM]INTX(0)
        [M:DOO1]INT2 = [F:BPM]INTX(1)
        [M:DOO1]INT3 = [F:BPM]INTX(2)
        [M:DOO1]INT4 = [F:BPM]INTX(3)
        [M:DOO1]INT5 = [F:BPM]INTX(4)
        [M:DOO1]DCB1 = [F:BPM]DCBX(0)
        [M:DOO1]DCB2 = [F:BPM]DCBX(1)
        [M:DOO1]DCB3 = [F:BPM]DCBX(2)
        [M:DOO1]DCB4 = [F:BPM]DCBX(3)
        [M:DOO1]DCB5 = [F:BPM]DCBX(4)
Endif

#Désactive les champs inutilisés
If GSZALH(0) = "" : Grizo [M:DOO1]ALH1 : Endif
If GSZALH(1) = "" : Grizo [M:DOO1]ALH2 : Endif
If GSZALH(2) = "" : Grizo [M:DOO1]ALH3 : Endif
If GSZALH(3) = "" : Grizo [M:DOO1]ALH4 : Endif
If GSZALH(4) = "" : Grizo [M:DOO1]ALH5 : Endif
If GSZDAT(0) = "" : Grizo [M:DOO1]DAT1 : Endif
If GSZDAT(1) = "" : Grizo [M:DOO1]DAT2 : Endif
If GSZDAT(2) = "" : Grizo [M:DOO1]DAT3 : Endif
If GSZDAT(3) = "" : Grizo [M:DOO1]DAT4 : Endif
If GSZDAT(4) = "" : Grizo [M:DOO1]DAT5 : Endif
If GSZINT(0) = "" : Grizo [M:DOO1]INT1 : Endif
If GSZINT(1) = "" : Grizo [M:DOO1]INT2 : Endif
If GSZINT(2) = "" : Grizo [M:DOO1]INT3 : Endif
If GSZINT(3) = "" : Grizo [M:DOO1]INT4 : Endif
If GSZINT(4) = "" : Grizo [M:DOO1]INT5 : Endif
If GSZDCB(0) = "" : Grizo [M:DOO1]DCB1 : Endif
If GSZDCB(1) = "" : Grizo [M:DOO1]DCB2 : Endif
If GSZDCB(2) = "" : Grizo [M:DOO1]DCB3 : Endif
If GSZDCB(3) = "" : Grizo [M:DOO1]DCB4 : Endif
If GSZDCB(4) = "" : Grizo [M:DOO1]DCB5 : Endif

Affzo [M:DOO1]
Return

$AV_CHOIX
Return

AP_CHOIX
Return

$AVANT_BOUTON
Return

$FINSAI
Close Local File [BPG]
Close Local File [BPM]

Raz [M:DOO1]

Kill GSZALH
Kill GSZDAT
Kill GSZINT
Kill GSZDCB
Kill GSZTTRBLC 
Kill ISDIRTY
Kill INCUSTMODE
Return

$FIN
Return

$ABANDON
Return

$APRES_MODIF
If !INCUSTMODE : ISDIRTY = 1 : Endif
Return

$BOUTON
Return

$ONMENU
Case BOUT
    When "B"
        Gosub ONCUST
    When "C"
        Gosub ONSAVECUST
    When Default
Endcase
Return

$ONOK
Gosub ONSAVE
FIN = 0
Return

#########################################################
# Sous-programmes
#########################################################
#########################################################
# Traitement du bouton Enregistrement
$ONSAVE
Local Integer Z
Z = 0

If [M:DOO1]BPRNUM = ""
    GMESSAGE = mess(226, 196, 2) #Un tiers doit être mentionné pour effectuer l'enregistrement.
    GERR = 2
    Return
Endif

Call DEBTRANS From GLOCK
Readlock [BPM] BPM0 = "DOO";[M:DOO1]BPRNUM
If fstat = 5
    #Enregistrement non trouvé, il faut le créer
    [F:BPM]ALHX(0) = [M:DOO1]ALH1
    [F:BPM]ALHX(1) = [M:DOO1]ALH2
    [F:BPM]ALHX(2) = [M:DOO1]ALH3
    [F:BPM]ALHX(3) = [M:DOO1]ALH4
    [F:BPM]ALHX(4) = [M:DOO1]ALH5

    [F:BPM]DATX(0) = [M:DOO1]DAT1
    [F:BPM]DATX(1) = [M:DOO1]DAT2
    [F:BPM]DATX(2) = [M:DOO1]DAT3
    [F:BPM]DATX(3) = [M:DOO1]DAT4
    [F:BPM]DATX(4) = [M:DOO1]DAT5

    [F:BPM]INTX(0) = [M:DOO1]INT1
    [F:BPM]INTX(1) = [M:DOO1]INT2
    [F:BPM]INTX(2) = [M:DOO1]INT3
    [F:BPM]INTX(3) = [M:DOO1]INT4
    [F:BPM]INTX(4) = [M:DOO1]INT5

    [F:BPM]DCBX(0) = [M:DOO1]DCB1
    [F:BPM]DCBX(1) = [M:DOO1]DCB2
    [F:BPM]DCBX(2) = [M:DOO1]DCB3
    [F:BPM]DCBX(3) = [M:DOO1]DCB4
    [F:BPM]DCBX(4) = [M:DOO1]DCB5

    [F:BPM]BPRNUM = [M:DOO1]BPRNUM
    [F:BPM]BPRTYP = "DOO"
    Trbegin [BPM]
    Write [BPM]
    If fstat
         Rollback
         GMESSAGE = mess(227, 196, 2) #Erreur lors de l'enregistrement. Transaction abandonnée.
         GERR = 1
         Return
    Else
        Commit
    Endif
Elsif fstat = 0
    #Enregistrement trouvé, il faut le réécrire pour préserver les éventuelles modifs.
    [F:BPM]ALHX(0) = [M:DOO1]ALH1
    [F:BPM]ALHX(1) = [M:DOO1]ALH2
    [F:BPM]ALHX(2) = [M:DOO1]ALH3
    [F:BPM]ALHX(3) = [M:DOO1]ALH4
    [F:BPM]ALHX(4) = [M:DOO1]ALH5

    [F:BPM]DATX(0) = [M:DOO1]DAT1
    [F:BPM]DATX(1) = [M:DOO1]DAT2
    [F:BPM]DATX(2) = [M:DOO1]DAT3
    [F:BPM]DATX(3) = [M:DOO1]DAT4
    [F:BPM]DATX(4) = [M:DOO1]DAT5

    [F:BPM]INTX(0) = [M:DOO1]INT1
    [F:BPM]INTX(1) = [M:DOO1]INT2
    [F:BPM]INTX(2) = [M:DOO1]INT3
    [F:BPM]INTX(3) = [M:DOO1]INT4
    [F:BPM]INTX(4) = [M:DOO1]INT5

    [F:BPM]DCBX(0) = [M:DOO1]DCB1
    [F:BPM]DCBX(1) = [M:DOO1]DCB2
    [F:BPM]DCBX(2) = [M:DOO1]DCB3
    [F:BPM]DCBX(3) = [M:DOO1]DCB4
    [F:BPM]DCBX(4) = [M:DOO1]DCB5

    [F:BPM]BPRNUM = [M:DOO1]BPRNUM
    [F:BPM]BPRTYP = "DOO"
    Trbegin [BPM]
    Rewrite [BPM]
    If fstat
         Rollback
         GMESSAGE = mess(227, 196, 2) #Erreur lors de l'enregistrement. Transaction abandonnée.
         GERR = 1
         Return
    Else
        Commit
    Endif
Endif
ISDIRTY = 0
ETABOU(GSPE1) = 0
Return

#########################################################
#Traitement du bouton Définir l'écran
$ONCUST
Local Integer V
V = 0
Raz [M:DOO1]

Actzo [M:DOO1]ALH1
Actzo [M:DOO1]ALH2
Actzo [M:DOO1]ALH3
Actzo [M:DOO1]ALH4
Actzo [M:DOO1]ALH5

Actzo [M:DOO1]DAT1
Actzo [M:DOO1]DAT2
Actzo [M:DOO1]DAT3
Actzo [M:DOO1]DAT4
Actzo [M:DOO1]DAT5

Actzo [M:DOO1]INT1
Actzo [M:DOO1]INT2
Actzo [M:DOO1]INT3
Actzo [M:DOO1]INT4
Actzo [M:DOO1]INT5

Actzo [M:DOO1]DCB1
Actzo [M:DOO1]DCB2
Actzo [M:DOO1]DCB3
Actzo [M:DOO1]DCB4
Actzo [M:DOO1]DCB5

[M:DOO1]ALH1 = GSZALH(0)
[M:DOO1]ALH2 = GSZALH(1)
[M:DOO1]ALH3 = GSZALH(2)
[M:DOO1]ALH4 = GSZALH(3)
[M:DOO1]ALH5 = GSZALH(4)

[M:DOO1]DAT1 = date$
[M:DOO1]DAT2 = date$
[M:DOO1]DAT3 = date$
[M:DOO1]DAT4 = date$
[M:DOO1]DAT5 = date$

Affzo [M:DOO1]
INCUSTMODE = 1
Return

#########################################################
# Traitement du bouton Sauvegarder la configuration
$ONSAVECUST
Local Integer W
W = 0
Call DEBTRANS From GLOCK

Read [BPG] BPG0 = "DOO";GLANGUE
If fstat = 5
    #Enregistrement non trouvé, il faut le créer
    [F:BPG]BPRTYP = "DOO"
    [F:BPG]LAN = GLANGUE

    [F:BPG]TTRALH(0) = [M:DOO1]ALH1
    [F:BPG]TTRALH(1) = [M:DOO1]ALH2
    [F:BPG]TTRALH(2) = [M:DOO1]ALH3
    [F:BPG]TTRALH(3) = [M:DOO1]ALH4
    [F:BPG]TTRALH(4) = [M:DOO1]ALH5

    For W = 0 To dim([F:BPG]TTRDAT) - 1
        [F:BPG]TTRDAT(W) = GSZDAT(W)
        [F:BPG]TTRINT(W) = GSZINT(W)
        [F:BPG]TTRDCB(W) = GSZDCB(W)
    Next

    [F:BPG]TTRBLC(0) = GSZTTRBLC(0)
    [F:BPG]TTRBLC(1) = GSZTTRBLC(1)
    [F:BPG]TTRBLC(2) = GSZTTRBLC(2)
    [F:BPG]TTRBLC(3) = GSZTTRBLC(3)
    Trbegin [BPG]
    Write [BPG]
    If fstat
         Rollback
         GMESSAGE = mess(227, 196, 2) #Erreur lors de l'enregistrement. Transaction abandonnée.
         GERR = 1
         Return
    Else
        Commit
    Endif
Elsif fstat = 0
    #Enregistrement trouvé, il faut le réécrire pour préserver les éventuelles modifs.
    [F:BPG]BPRTYP = "DOO"
    [F:BPG]LAN = GLANGUE

    [F:BPG]TTRALH(0) = [M:DOO1]ALH1
    [F:BPG]TTRALH(1) = [M:DOO1]ALH2
    [F:BPG]TTRALH(2) = [M:DOO1]ALH3
    [F:BPG]TTRALH(3) = [M:DOO1]ALH4
    [F:BPG]TTRALH(4) = [M:DOO1]ALH5

    For W = 0 To dim([F:BPG]TTRDAT) - 1
        [F:BPG]TTRDAT(W) = GSZDAT(W)
        [F:BPG]TTRINT(W) = GSZINT(W)
        [F:BPG]TTRDCB(W) = GSZDCB(W)
    Next

    [F:BPG]TTRBLC(0) = GSZTTRBLC(0)
    [F:BPG]TTRBLC(1) = GSZTTRBLC(1)
    [F:BPG]TTRBLC(2) = GSZTTRBLC(2)
    [F:BPG]TTRBLC(3) = GSZTTRBLC(3)
    Trbegin [BPG]
    Rewrite [BPG]
    If fstat
         Rollback
         GMESSAGE = mess(227, 196, 2) #Erreur lors de l'enregistrement. Transaction abandonnée.
         GERR = 1
         Return
    Else
         Commit
    Endif
Endif

GMESSAGE = mess(231, 196, 2) #La fenêtre doit être réouverte pour bénéficier des modifications.
GERR = 2

INCUSTMODE = 0
FIN = 1
Return

