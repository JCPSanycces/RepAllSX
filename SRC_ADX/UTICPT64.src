#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UTICPT64   UTI process                                    Module CPT   #
#            Lignes de codes comptables V7
##########################################################################

If clalev([F:ADS])=0
    Local File ADOSSIER [ADS]
Endif

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOS(WDOSSIER,"") From SAIDOS

If WDOSSIER <> ""
  Read [ADS]DOSSIER=WDOSSIER
  If fstat <> 0
        Raz [F:ADS]
  Endif
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTICPT64(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTICPT64(DOSSIER)
Value Char DOSSIER


Local Integer WCOMPTEUR
Call ECR_TRACE("UTICPT64 : Start of process on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:CCL])  =0  Local File =DOSSIER+".GACCCODLIG"   [CCL] : Endif

WCOMPTEUR = 0
Call DEBTRANS From GLOCK

Trbegin [CCL]
GOK=1

Read [CCL]CCL0 = 1;70
If fstat
 Raz [CCL]
 [F:CCL]TYP    = 1
 [F:CCL]NUMLIG = 70
 [F:CCL]OBL    = 1
 [F:CCL]TXT    = 176
 [F:CCL]TYPCPT = 2
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/1-70",1) From DOSDIC : Goto E_END
 Else
  WCOMPTEUR+=1
 Endif
Endif

Read [CCL]CCL0 = 1;71
If fstat
 Raz [CCL]
 [F:CCL]TYP    = 1
 [F:CCL]NUMLIG = 71
 [F:CCL]OBL    = 1
 [F:CCL]TXT    = 177
 [F:CCL]TYPCPT = 2
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/1-71",1) From DOSDIC : Goto E_END
 Else
  WCOMPTEUR+=1
 Endif
Endif

Read [CCL]CCL0 = 22;9
If fstat
 Raz [CCL]
 [F:CCL]TYP    = 22
 [F:CCL]NUMLIG = 9
 [F:CCL]OBL    = 1
 [F:CCL]TXT    = 175
 [F:CCL]TYPCPT = 2
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/22-9",1) From DOSDIC : Goto E_END
 Else
  WCOMPTEUR+=1
 Endif
Endif

Read [CCL]CCL0 = 25;1
If fstat
 Raz [CCL]
 [F:CCL]TYP    = 25
 [F:CCL]NUMLIG = 1
 [F:CCL]OBL    = 1
 [F:CCL]TXT    = 167
 [F:CCL]TYPCPT = 2
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/25-1",1) From DOSDIC : Goto E_END
 Else
  WCOMPTEUR+=1
 Endif
Endif

Read [CCL]CCL0 = 25;2
If fstat
 Raz [CCL]
 [F:CCL]TYP    = 25
 [F:CCL]NUMLIG = 2
 [F:CCL]OBL    = 1
 [F:CCL]TXT    = 168
 [F:CCL]TYPCPT = 2
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/25-2",1) From DOSDIC : Goto E_END
 Else
  WCOMPTEUR+=1
 Endif
Endif

$E_END
If GOK=1
 Commit
Else
 Rollback
Endif

Close Local File [CCL]

Call ECR_TRACE("UTICPT64 : "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTIXXX63 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif
If filinfo(filpath("FIL","GACCCODLIG","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTICPT64(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3
     End 
Endif
If filinfo(filpath("FIL","GACCCODLIG","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTICPT64(APPLI)
End
