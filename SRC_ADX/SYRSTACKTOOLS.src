# Issue 99999 - 2015-10-09 by CFF : rename functions MSGSTACK_COPY_TO and MSGSTACK_GET_FIRST_MAX_MESSAGE

#**
#* Return the classic code trace from the stack message status
#*
#* @param  PNSTA : Stack error status
#* @return (Integer) : Classic level code
#*!
Funprog GET_CLASSICERRLEVEL(PNSTA)
Value Integer PNSTA

  Local Integer RNRET

  # ----------------------------------------------------
  #   Stack error status | Trace status
  # ----------------------------------------------------
  #   CST_ASUCCESS       |  0  (info)
  #   CST_AINFO          |  0  (info)
  #   CST_AWARNING       | -1  (warning)
  #   CST_AERROR         |  1  (error)
  #   CST_AFATAL         |  1  (error)
  # ----------------------------------------------------
  Case PNSTA
    When [V]CST_AINFO:
      RNRET = 0
    When [V]CST_ASUCCESS:
      RNRET = 0
    When [V]CST_AWARNING:
      RNRET = -1
    When [V]CST_AERROR:
      RNRET = 1
    When [V]CST_AFATAL:
      RNRET = 1
    When Default:
      RNRET = 0
  Endcase

End RNRET

# Issue 99999 - 2015-10-09 by CFF : change function name MSGSTACK_COPY_TO to MSGSTACK_COPY_TO_INST
#**
#* Copy the data stack from an instance to the given another instance
#*
#* @see MSGSTACK_COPY_TO()
#*
#* @param POOBJECT : Instance
#* @param POOBJECTTO : Destination instance
#* @return (Integer) : Return CST_ATRUE
#*!
Funprog MSGSTACK_COPY_TO_INST(POOBJECT, POOBJECTTO)
Variable Instance POOBJECT Using OBJECT
Variable Instance POOBJECTTO Using OBJECT

  Local Integer LIN, NSTATUS

  For [L]LIN = 1 To maxtab(POOBJECT.AERROR)
    If (POOBJECT.AERROR([L]LIN) <> null and POOBJECT.AERROR([L]LIN).DEL <> [V]CST_AYES) Then
      [L]NSTATUS = fmet POOBJECTTO.ASETERROR(POOBJECT.AERROR([L]LIN).PRO, POOBJECT.AERROR([L]LIN).MES, POOBJECT.AERROR([L]LIN).STA)
    Endif
  Next

End [V]CST_ATRUE

# Issue 99999 - 2015-10-09 by CFF : change function name MSGSTACK_COPY_TO_ALL to MSGSTACK_COPY_TO
#**
#* Copy the data stack from an instance (including collections) to the given another instance
#*
#* @see MSGSTACK_COPY_TO_INST()
#*
#* @param POOBJECT : Instance
#* @param POOBJECTTO : Destination instance
#* @return (Integer) : Return CST_ATRUE
#*!
Funprog MSGSTACK_COPY_TO(POOBJECT, POOBJECTTO)
Variable Instance POOBJECT Using OBJECT
Variable Instance POOBJECTTO Using OBJECT

Local Integer NSTATUS
Local Instance OCTX Using =[V]CST_C_NAME_CLASS_CONTEXT

  OCTX = NewInstance [ZCTX] With =[V]CST_C_NAME_CLASS_CONTEXT
  [L]NSTATUS = fmet POOBJECT._AERROR(OCTX, [V]CST_ANO) : # this invoke allows to agregate all class' and subclasses' stacks in OCTX's stack

  [L]NSTATUS = func SYRSTACKTOOLS.MSGSTACK_COPY_TO_INST(OCTX, POOBJECTTO)

  FreeGroup OCTX

End [V]CST_ATRUE

#**
#* Get the message of the first most stack level of a instance
#*
#* @param PINST Instance
#* @param RMESSAGE Returned message
#* @return Level of message returned, or CST_AOK if no error message found
#*!
Funprog MSGSTACK_GET_FIRST_UPPER_MESSAGE(PINST, RMESSAGE)
Variable Instance PINST Using OBJECT
Variable Char RMESSAGE

  Local Integer  NSTATUS, RETSTA
  Local Instance OCTX Using =[V]CST_C_NAME_CLASS_CONTEXT

  OCTX = NewInstance [ZCTX] With =[V]CST_C_NAME_CLASS_CONTEXT
  NSTATUS = fmet PINST._AERROR(OCTX, [V]CST_ANO) : # this invoke allows to agregate all class' and subclasses' stacks in OCTX's stack

  [L]RETSTA = func SYRSTACKTOOLS._MSGSTACK_GET_FIRST_MAX_MESSAGE_INST([L]OCTX, [V]CST_AOK, RMESSAGE)

  FreeGroup OCTX

End [L]RETSTA

#**
#* Get the message of the first most stack level of a instance excluding collections
#*
#* @param PINST Instance
#* @param RMESSAGE Returned message
#* @return Level of message returned, or CST_AOK if no error message found
#*!
Funprog MSGSTACK_GET_FIRST_UPPER_MESSAGE_INST(PINST, RMESSAGE)
Variable Instance PINST Using OBJECT
Variable Char RMESSAGE

  Local Integer RETSTA

  [L]RETSTA = func SYRSTACKTOOLS._MSGSTACK_GET_FIRST_MAX_MESSAGE_INST(PINST, [V]CST_AOK, RMESSAGE)

End [L]RETSTA

#**
#* Get the message of the first most stack level of a instance excluding collections
#*
#* @private
#* @param PINST Instance
#* @param PMINSTA
#* @param RMESSAGE Returned message
#* @return Level of message returned, or CST_AOK if no error message found
#*!
Funprog _MSGSTACK_GET_FIRST_MAX_MESSAGE_INST(PINST, PMINSTA, RMESSAGE)
Variable Instance PINST Using OBJECT
Value Integer PMINSTA
Variable Char RMESSAGE

  Local Integer  NI, RETSTA

  RMESSAGE = AVOID.ACHAR
  RETSTA = [V]CST_AOK

  For NI = 1 To maxtab(PINST.AERROR)
    If (PINST.AERROR(NI) <> null and PINST.AERROR(NI).DEL <> [V]CST_AYES) Then
      If (PINST.AERROR(NI).STA > PMINSTA) Then
        # Get current error level message
        RMESSAGE = PINST.AERROR(NI).MES
        If (PINST.AERROR(NI).PRO <> AVOID.ACHAR) Then
          # Issue 99999 - 2015-10-09 by CFF : Add ':' caracter between PRO and MES
          RMESSAGE = PINST.AERROR(NI).PRO + ":" - RMESSAGE
          #TODO: Get the code number in dictionnary, decode it (by TEXTE subprog) and put his label instead of the code
        Endif
        #
        [L]RETSTA = PINST.AERROR(NI).STA
        If ([L]RETSTA = [V]CST_AFATAL) Then
          # No more message greater than this one
          Break
        Endif
        #
        PMINSTA = [L]RETSTA
      Endif
    Endif
  Next NI

End [L]RETSTA

# Issue 99999 - 2015-10-09 by CFF : function name MSGSTACK_GET_FIRST_MAX_MESSAGE to MSGSTACK_GET_FIRST_MAX_MESSAGE_INST
#**
#* Return the message of the first most critical stack level of a instance excluding collections
#*
#* @param POOBJECT : Instance
#* @return (String) : Message found or empty message if no error found
#*!
Funprog MSGSTACK_GET_FIRST_MAX_MESSAGE_INST(POOBJECT)
Variable Instance POOBJECT Using OBJECT

  Local Char SMESSAGE(255)
  Local Integer RET
  Local Integer  NI, NMAXSTA, NMAXERR

  [L]SMESSAGE = AVOID.ACHAR
# Issue 999999 - 2016-06-20 by CFF : comment
#  [L]NMAXSTA = [V]CST_AOK
  [L]NMAXSTA = [V]CST_AWARNING

  [L]RET = func SYRSTACKTOOLS._MSGSTACK_GET_FIRST_MAX_MESSAGE_INST(POOBJECT, [V]CST_AWARNING, [L]SMESSAGE)
End [L]SMESSAGE

  [L]NMAXERR = 0
  For NI = 1 To maxtab(POOBJECT.AERROR)
    If (POOBJECT.AERROR(NI) <> null and POOBJECT.AERROR(NI).DEL <> [V]CST_AYES) Then
      If (POOBJECT.AERROR(NI).STA > [L]NMAXSTA) Then
        # Get current error level message
        [L]NMAXSTA = POOBJECT.AERROR(NI).STA
        SMESSAGE = POOBJECT.AERROR(NI).MES
        If (POOBJECT.AERROR(NI).PRO <> AVOID.ACHAR) Then
          # Issue 99999 - 2015-10-09 by CFF : Add ':' caracter between PRO and MES
          SMESSAGE = POOBJECT.AERROR(NI).PRO + ": " + SMESSAGE
          #TODO: Get the code number in dictionnary, decode it (by TEXTE subprog) and put his label instead of the code
        Endif
        [L]NMAXERR += 1
        If ([L]NMAXSTA = [V]CST_AFATAL) Then
          Break
        Endif
      Endif
    Endif
  Next NI

# Issue 999999 - 2016-06-20 by CFF : change test with the number of error message greater or equal to CST_AERROR
#  If (maxtab(POOBJECT.AERROR) > 0 and SMESSAGE = AVOID.ACHAR) Then
  If ([L]NMAXERR > 0 and SMESSAGE = AVOID.ACHAR) Then
    # If there is at least an error, and not error text : get a default error message
    SMESSAGE = mess(128,187,1)
  Endif

End SMESSAGE

# Issue 99999 - 2015-10-09 by CFF : Change function name MSGSTACK_GET_FIRST_MAX_MESSAGE_ALL to MSGSTACK_GET_FIRST_MAX_MESSAGE
#**
#* Return the message of the first most stack level of a instance including collections
#*
#* @param POOBJECT : Instance
#* @return (String) : Message found or error message if not found
#*!
Funprog MSGSTACK_GET_FIRST_MAX_MESSAGE(POOBJECT)
Variable Instance POOBJECT Using OBJECT
Local Char SMESSAGE(255)

Local Integer  NSTATUS
Local Instance OCTX Using =[V]CST_C_NAME_CLASS_CONTEXT

  OCTX = NewInstance [ZCTX] With =[V]CST_C_NAME_CLASS_CONTEXT
  NSTATUS = fmet POOBJECT._AERROR(OCTX, [V]CST_ANO) : # this invoke allows to agregate all class' and subclasses' stacks in OCTX's stack

  SMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE_INST(OCTX)

  FreeGroup OCTX

End SMESSAGE

#**
#* Dump messages stack of an instance into a opened classic log
#*
#* @see MSGSTACK_DUMP_FILTERED_MESSAGES_INTO_CLASSIC_LOG()
#*
#* @param POOBJECT : Instance
#*!
Subprog MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(POOBJECT)
Variable Instance POOBJECT Using OBJECT

  Call MSGSTACK_DUMP_FILTERED_MESSAGES_INTO_CLASSIC_LOG(POOBJECT, -1, -1)

End

#**
#* Dump filtered messages stack of an instance into a opened classic log
#*
#* @see MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG()
#*
#* @param POOBJECT : Instance
#* @param PSTAFROM : [Optional] Start filter. -1 if not used
#* @param PSTATO : [Optional] End filter. -1 if not used
#*!
Subprog MSGSTACK_DUMP_FILTERED_MESSAGES_INTO_CLASSIC_LOG(POOBJECT, PSTAFROM, PSTATO)
Variable Instance POOBJECT Using OBJECT
Value Integer PSTAFROM
Value Integer PSTATO

  Local Integer N_I
  Local Char MESSAGE(250)
  Local Integer NSTATUS
  Local Instance OCTX Using =[V]CST_C_NAME_CLASS_CONTEXT

  OCTX = NewInstance [ZCTX] With =[V]CST_C_NAME_CLASS_CONTEXT
  NSTATUS = fmet POOBJECT._AERROR(OCTX, [V]CST_ANO) : # this invoke allows to agregate all class' and subclasses' stacks in OCTX's stack

#  If (POOBJECT.ACTX <> null)
#    If (POOBJECT.ACTX.AERROR <> null)
#      RET = func SYRSTACKTOOLS.MSGSTACK_COPY_TO_INST(POOBJECT.ACTX, OCTX)
#    Endif
#  Endif

  For [L]N_I = 1 To maxtab(OCTX.AERROR)
    If (OCTX.AERROR(N_I) <> null) Then
      If (PSTAFROM = -1 or (PSTAFROM > -1 and OCTX.AERROR([L]N_I).STA >= PSTAFROM)) Then
        If (PSTATO = -1 or (PSTATO > -1 and OCTX.AERROR([L]N_I).STA <= PSTATO)) Then
          Call MSGSTACK_GET_FORMATTED_MESSAGE(OCTX, [L]N_I, MESSAGE) From SYRSTACKTOOLS
          Call ECR_TRACE(MESSAGE, func SYRSTACKTOOLS.GET_CLASSICERRLEVEL(OCTX.AERROR([L]N_I).STA)) From GESECRAN
        Endif
      Endif
    Endif
  Next N_I

  FreeGroup OCTX
End

#**
#* Dump messages stack of an instance into the given log
#*
#* @see MSGSTACK_FILTERED_DUMP_MESSAGES_INTO_LOG(), ALOG class
#*
#* @param POOBJECT : Instance
#* @param POLOG : Log instance
#*!
Subprog MSGSTACK_DUMP_MESSAGES_INTO_LOG(POOBJECT, POLOG)
Value Instance POOBJECT  Using OBJECT
Value Instance POLOG Using OBJECT

  Call MSGSTACK_FILTERED_DUMP_MESSAGES_INTO_LOG(POOBJECT, POLOG, -1, -1) From SYRSTACKTOOLS

End

