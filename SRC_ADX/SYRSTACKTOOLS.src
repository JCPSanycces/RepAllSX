#**
#* Dump filtered messages stack of an instance into the given log
#*
#* @see MSGSTACK_DUMP_MESSAGES_INTO_LOG(), ALOG class
#*
#* @param POOBJECT : Instance
#* @param POLOG : Log instance
#* @param PSTAFROM : [Optional] Start filter. -1 if not used
#* @param PSTATO   : [Optional] End filter. -1 if not used
#*!
Subprog MSGSTACK_FILTERED_DUMP_MESSAGES_INTO_LOG(POOBJECT, POLOG, PSTAFROM, PSTATO)
Variable Instance POOBJECT Using OBJECT
Value Instance POLOG Using OBJECT
Value Integer PSTAFROM
Value Integer PSTATO

  Local Integer N_I, NSTATUS
  Local Char MESSAGE(250)
  Local Integer NSTATUS
  Local Instance OCTX Using =[V]CST_C_NAME_CLASS_CONTEXT

  OCTX = NewInstance [ZCTX] With =[V]CST_C_NAME_CLASS_CONTEXT
  NSTATUS = fmet POOBJECT._AERROR(OCTX, [V]CST_ANO) : # this invoke allows to agregate all class' and subclasses' stacks in OCTX's stack

  # Issue 999999 - 2015-11-02 by cfavre : Add ACTX error
#  If (POOBJECT.ACTX <> null)
#    If (POOBJECT.ACTX.AERROR <> null)
#      RET = func SYRSTACKTOOLS.MSGSTACK_COPY_TO_INST(POOBJECT.ACTX, OCTX)
#    Endif
#  Endif
  # End issue 999999

  For [L]N_I = 1 To maxtab(OCTX.AERROR)
    If (OCTX.AERROR(N_I) <> null) Then
      If (PSTAFROM = -1 or (PSTAFROM > -1 and OCTX.AERROR([L]N_I).STA >= PSTAFROM)) Then
        If (PSTATO = -1 or (PSTATO > -1 and OCTX.AERROR([L]N_I).STA <= PSTATO)) Then
          Call MSGSTACK_GET_FORMATTED_MESSAGE(OCTX, [L]N_I, MESSAGE) From SYRSTACKTOOLS
          NSTATUS = fmet POLOG.APUTLINE(MESSAGE, OCTX.AERROR([L]N_I).STA)
        Endif
      Endif
    Endif
  Next N_I

  FreeGroup OCTX
End

#**
#* Write a line in the AXUNIT log if PNLOGLINE is set to [V]CST_AYES.
#*
#* @param PSMESSAGE (String)  : Message to log
#* @param PNLOGLINE (Integer) : Flag to write ([V]CST_AYES) or not ([V]CST_ANO) in the log
#*!
Subprog QLF_LOG_LINE(PSMESSAGE, PNLOGLINE)
Value Char PSMESSAGE
Value Integer PNLOGLINE

  If (PNLOGLINE = [V]CST_AYES) Then
    Call LOG_LINE(PSMESSAGE) From AXUNIT
  Endif
End

#**
#* @deprecated Use MSGSTACK_DUMP_MESSAGES_INTO_QLF_LOG() instead
#*!
Subprog QLF_LOG_MESSAGES(POOBJECT, PNWRITE)
Variable Instance POOBJECT Using OBJECT
Value Integer PNWRITE

  Call MSGSTACK_DUMP_MESSAGES_INTO_QLF_LOG(POOBJECT, PNWRITE) From SYRSTACKTOOLS

End

#**
#* Dump messages stack of a instance into the QLF log
#*
#* @param POOBJECT : Instance
#* @param PNWRITE : Flag to write (CST_AYES) or not (CST_ANO) in the log
#*!
Subprog MSGSTACK_DUMP_MESSAGES_INTO_QLF_LOG(POOBJECT, PNWRITE)
Variable Instance POOBJECT Using OBJECT
Value Integer PNWRITE
# Issue 999999 - 2015-11-05 by cfavre : Change loop on AERROR collection with a while _FIND_NEXT_ROW()

Local Integer NI, COUNT, COUNTACTX
Local Integer NSTATUS
Local Char MESSAGE(250)
Local Instance OCTX Using =[V]CST_C_NAME_CLASS_CONTEXT

  If (PNWRITE = [V]CST_AYES) Then

    OCTX = NewInstance [ZCTX] With =[V]CST_C_NAME_CLASS_CONTEXT
    NSTATUS = fmet POOBJECT._AERROR(OCTX, [V]CST_ANO)

    [L]COUNT = maxtab(OCTX.AERROR)
    If (COUNT > 0)
      Call QLF_LOG_LINE(string$(40, "*") + "BEGIN MESSAGE LOGS (NB=" + num$(COUNT) + ")", PNWRITE)
    Endif
    # Issue 999999 - 2015-11-04 by cfavre : Add potential messages from ACTX strcture
    [L]COUNTACTX = maxtab(POOBJECT.ACTX.AERROR)
    If ([L]COUNTACTX > 0)
      Call QLF_LOG_LINE(string$(40, "*") + "BEGIN ACTX MESSAGE LOGS (NB=" + num$([L]COUNTACTX) + ")", PNWRITE)
      NI = [V]CST_ANOTDEFINED
      While func SYRSTACKTOOLS._FIND_NEXT_ROW(POOBJECT.ACTX.AERROR, NI, 0, 0) = [V]CST_ATRUE
        Call MSGSTACK_GET_FORMATTED_MESSAGE(POOBJECT.ACTX, NI, MESSAGE) From SYRSTACKTOOLS
        Call QLF_LOG_LINE(MESSAGE, PNWRITE)
      Wend
      Call QLF_LOG_LINE(string$(40, "*") + "END ACTX MESSAGE LOGS", PNWRITE)
    Endif
    # End issue 999999
    NI = [V]CST_ANOTDEFINED
    While func SYRSTACKTOOLS._FIND_NEXT_ROW(OCTX.AERROR, NI, 0, 0) = [V]CST_ATRUE
      Call MSGSTACK_GET_FORMATTED_MESSAGE(OCTX, NI, MESSAGE) From SYRSTACKTOOLS
      Call QLF_LOG_LINE(MESSAGE, PNWRITE)
    Wend
    If (COUNT > 0)
      Call QLF_LOG_LINE(string$(40, "*") + "END MESSAGE LOGS", PNWRITE)
    Endif

    FreeGroup OCTX
  Endif
End

#**
#* Give the formatted message from a instance stack message given by this index order
#*
#* @param POOBJECT : Instance
#* @param PNI : Index of message (0 if not used)
#* @param RMESSAGE : Message
#*!
Subprog MSGSTACK_GET_FORMATTED_MESSAGE(POOBJECT, PNI, RMESSAGE)
Variable Instance POOBJECT Using OBJECT
Value Integer PNI
Variable Char RMESSAGE

  Local Char PRO(250), SLEVEL(250), SNI(10)

  RMESSAGE = func SYRSTACKTOOLS.GET_LOG_FORMATTED_MESSAGE(POOBJECT.AERROR(PNI).MES, PNI, POOBJECT.AERROR(PNI).STA, POOBJECT.AERROR(PNI).PRO, POOBJECT.AERROR(PNI).NUM)
#  RMESSAGE += format$("DD2", POOBJECT.AERROR(PNI).CREDATTIM)
End

#**
#* Return formatted message for log from given properties of message stack
#*
#* @param PMES : Message
#* @param PNI : [Optional] Index
#* @param PSTA : Status
#* @param PPRO : Propertie
#* @param PNUM : [Optional] Internal code
#* @return (Char) : Formatted message
#*!
Funprog GET_LOG_FORMATTED_MESSAGE(PMES, PNI, PSTA, PPRO, PNUM)
Value Char PMES
Value Integer PNI
Value Integer PSTA
Value Char PPRO
Value Integer PNUM

  Local Char SMESSAGE(250), SNI(10), SLEVEL(250), SPRO(250), SNUM(10)

  # Contruct message : 1 2 [3] 4 (5)
  # 1 Stack caracter
  # 2 Index of message
  # 3 Level caracter
  # 4 Message (propertie + message)
  # 5 Internal code
  # Example : ± 1 [E] This is a message (200)

  # Index in stack
  If (PNI > 0) Then
    SNI = num$(PNI)
  Endif

  # Level caracter (replace the pictogram)
  Case PSTA
    When [V]CST_AINFO:
      SLEVEL = "I"
    When [V]CST_ASUCCESS:
      SLEVEL = "S"
    When [V]CST_AWARNING:
      SLEVEL = "W"
    When [V]CST_AERROR:
      SLEVEL = "E"
    When [V]CST_AFATAL:
      SLEVEL = "F"
    When Default:
      SLEVEL = AVOID.ACHAR
  Endcase
  If (SLEVEL <> AVOID.ACHAR) Then
    SLEVEL = "[" + SLEVEL + "]"
  Endif

  # Internal code
  If (PNUM > 0) Then
    SNUM = "(" + num$(PNUM) + ")"
  Endif

  # Message with Property
  SMESSAGE = func SYRSTACKTOOLS.GET_FORMATTED_MESSAGE(PMES, PPRO)

  # Final message with all parameters
  # Issue 999999 - 2015-11-04 by cfavre : Delete the SNUM information of message
  # SMESSAGE = "±" - SNI - SLEVEL - SMESSAGE - SNUM
  SMESSAGE = "±" - SNI - SLEVEL - SMESSAGE

End SMESSAGE

#**
#* Return formatted message for log from given properties of message stack
#*
#* @param PMES
#* @param PPRO
#* @return (Char) : Formatted message
#*!
Funprog GET_FORMATTED_MESSAGE(PMES, PPRO)
Value Char PMES
Value Char PPRO

  Local Char SMESSAGE(250), SPRO(250)

  # Message
  SPRO = PPRO
  If SPRO <> AVOID.ACHAR
    SPRO += ": "
  Endif
  SMESSAGE = SPRO + PMES

End SMESSAGE

#**
#* Find the next row from given collection and given index
#*
#* @param PAERROR
#* @param RLINE
#* @param PASTALIN_ON Number. The flags the row should have. [ANEW(2), ADEL(16), ANEWDEL(1), AUPD(4)] or ALL(0)
#* @param PASTALIN_OFF. The flags the row should not have. [ANEW(2), ADEL(16), ANEWDEL(1), AUPD(4)] or ALL(0)
#*
#* |-16|-8-|-4-|-2-|-1-|<br/>
#* |---|---|---|---|---| ALL<br/>
#* |---|---|---|---|-X-| ANEWDEL<br/>
#* |---|---|---|-X-|---| ANEW<br/>
#* |---|---|-X-|---|---| AUPD<br/>
#* |-X-|---|---|---|---| ADEL<br/>
#*!
Funprog _FIND_NEXT_ROW(PAERROR, RLINE, PASTALIN_ON, PASTALIN_OFF)
Variable Instance PAERROR(1..) Using C_AERROR
Variable Integer RLINE
Value Tinyint PASTALIN_ON
Value Tinyint PASTALIN_OFF

  Local Integer I, RET

  [L]RET = [V]CST_AFALSE

  If (RLINE = [V]CST_ANOTDEFINED)
    RLINE = 0
  Endif

  # Loop on PAERROR collection
  For [L]I = RLINE + 1 To maxtab(PAERROR)
    If (PAERROR([L]I) <> null)
      # No filter parameters
      If (PASTALIN_ON = [V]CST_ALL and PASTALIN_OFF = [V]CST_ALL)
        RLINE = [L]I
        [L]RET = [V]CST_ATRUE
        Break
      Else
        # Filter Row ON
        If (PASTALIN_ON <> [V]CST_ALL)
          If (PASTALIN_ON = PAERROR([L]I).ASTALIN)
            RLINE = [L]I
            [L]RET = [V]CST_ATRUE
            Break
          Endif
        Endif
        # Filter Row OFF
        If (PASTALIN_OFF <> [V]CST_ALL)
          If (PASTALIN_OFF <> PAERROR([L]I).ASTALIN)
            RLINE = [L]I
            [L]RET = [V]CST_ATRUE
            Break
          Endif
        Endif
      Endif
    Endif
  Next [L]I

End [L]RET

