#RRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRR
# Points d'entrée objet de reprise 
#RRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRR

#=====================================================================
# Traitement du tableau des infos par plan de l'objet de reprise.     
#=====================================================================

#==============================================================#
# Cette action est appelée pour chaque enregistrement lu dans  #
# la table temporaire par plan pour l'objet métier sur lequel  #
# on vient de cliquer.                                         #
# Alimenter ici les zones du tableau par plan spécifique à l'  #
# action                                                       #
# Table temporaire -> [F:TPF]   | Pour les BCO                 #
# Masque           -> [M:MFS0]  |                              #
# ligne courante   -> nolign    |                              #
#==============================================================#
$LOADPLN
  # Chargement du masque tableau des infos "spécifiques" par plan suite à clique sur bien    
  # Appelée pour chaque enreg de la table temporaire             
  # Masque: [M:MFS0]   Table: [F:TPF]   Ligne courante: nolign 
Return

#==============================================================#
# Cette action est appelée pour chaque enregistrement de la    #
# table temporaire à mettre à jour.                            #
# Alimenter ici les zones spécifiques à l'action de la table   #
# temporaire par plan à partir des zones du tableau par plan   #
# Table temporaire -> [F:TPF]   | Pour les BCO                 #
# Masque           -> [M:MFS0]  |                              #
# ligne courante   -> nolign    |                              #
#==============================================================#
$SAVEPLN
  # MAJ table temporaire avec les infos "spécifiques" du masque tableau des infos par plan    
  # Appelée pour chaque enreg de la table temporaire             
  # Table: [F:TPF]   Masque: [M:MFS0]   Ligne courante: nolign 
Return


################################################################################
# Traitement du masque de reprise de l'action massive                          #
# -----> MFASTRFCR                                                             #
################################################################################

#==============================================================#
# Actions de contrôle sur champ                                #
#==============================================================#
#


##########################################################################

##########################################################################


#==============================================================#
# Traitements appelés par Gosub, Call et Func                  #
#==============================================================#


################################################################################
# Traitement de gestion de la trace - informations particulières à l'action    #
################################################################################


#==============================================================#
# Traitements appelés par Gosub, Call et Func                  #
#==============================================================#

#===============================
$ECR_ENTETE
Local    Char    LINE(115)         

  If ( FLGDET = G_OUI ) Then
    # Entête (ligne 1)
    # Entête (ligne 1)
    LINE = string$(115,"*")  
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
    LINE =      left$( mess(324,7773,1)      + string$(23,' '), 23)+"!"
    LINE +=     left$( mess(302,7773,1)      + string$(20,' '), 20)+"!"
    LINE +=     left$( mess(303,7773,1)      + string$(10,' '), 10)+"!"
    LINE +=     left$( mess(325,7773,1)      + string$(19,' '), 19)+'!'
    LINE +=     left$( mess(326,7773,1)      + string$(18,' '), 18)+'!'
    LINE +=     left$( mess(327,7773,1)      + string$(20,' '), 20)+'!'
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
    LINE =      left$( " "                  + string$(44,' '), 44)+"!"
    LINE +=     left$( mess(307,7773,1)      + string$(10,' '), 10)+"!"
    LINE +=     left$( " "                  + string$(19,' '), 19)+'!'
    LINE +=     left$( " "                  + string$(18,' '), 18)+'!'
    LINE +=     left$( " "                  + string$(20,' '), 20)+'!'
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
    LINE = string$(115,"*")  
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
  Endif  

Return


#===============================
$ECR_LIGNE
Local    Char    LINE(115)
Local    Char    LREF
Local    Decimal LBSEVAL
         

  #=================================== 
  If ( FLGDET = G_OUI ) Then

    LREF  = [F:MAS1]CODLOF+"/"+num$([F:MAS1]LINLOF)
    LBSEVAL = [F:MAS1]AMTNOTCPY+[F:MAS1]AMTVATCPY-[F:MAS1]AMTVATRCPY 

    #  (ligne 1)
    LINE  = left$( LREF                                    + string$(23,' '), 23) +"!"
    LINE += left$( [F:MAS1]ACT                             + string$(20,' '), 20) +"!"
    LINE += left$( format$("N:3.6",LTAUXPRO)               + string$(10,' '), 10) +"!"
    LINE += left$( format$('N:'+GFMT3, [F:MAS1]AMTVATRCPY) + string$(19,' '), 19) +"!"
    LINE += left$( format$('N:'+GFMT3, LREGUL)            + string$(18,' '), 18) +"!"
    LINE += left$( format$('N:'+GFMT3, LBSEVAL )           + string$(20,' '), 20) +"!"
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3

    #  (ligne 2) 
    LINE  = left$( [F:MAS1]DES                             + string$(44,' '), 44) +"!"
    LINE += left$( format$("N:3.6",[F:MAS1]RATVATREC)      + string$(10,' '), 10) +"!"
    LINE += left$( " "                                     + string$(19,' '), 19) +"!"
    LINE += left$( " "                                     + string$(18,' '), 18) +"!"
    LINE += left$( " "                                     + string$(20,' '), 20) +"!"
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
    LINE = ""
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3

  Endif  
  #=================================== 

Return


#===============================
$GESTRACE
Local Char LDES
Local Integer I, LERROR, ERROR
Local    Char    LINE(115) 
Local Integer IFIRST        
    

  Case TRTYP
    When 1         # Ouverture de la trace
      Call OUVRE_TRACE(mess(322,7773,1),1) From TRACEABX3
    When 20        # Paramètres de l'action
      # Date d'effet
      LINE  =  mess(321,7773,1)     
      LINE +=  left$( num$([M:FASR]MVTDAT) + string$(20,' '), 20) 
      Call ECR_TRACE("", GTRC_PARAM, LINE,0,1) From TRACEABX3 
    When Default
  Endcase
Return

######################################################################
# Sous-pro et routines communes 
######################################################################

#=====================================================================
Subprog LAUNCH_ACT(PACTTYP)
Value Char PACTTYP

 Case PACTTYP
   When GTAMUNI
     Infbox mess(1,GML_MSGACT,1) 
   When GTAMMAS
     Local Char PARAM(30)(1..5)
     Local Char VALEUR
     PARAM(1)=GTAMMAS            # Massif / unitaire
     PARAM(2)="LOFVATREG"        # Nom de l'action métier
     PARAM(3)=num$(GVML_OMDEPEN)  # Objet métier de référence
     PARAM(4)=num$(G_OUI)        # Mono société
     PARAM(5)=num$(G_NON)        # Plan d'amortissement
     #  Traitement      Fenêtre 
     Call TRAITE_CHAR(VALEUR,PARAM,"","TRTLOFVATREG","LOFVATREG",4,"") From GTRAITE  
   When Default
  Endcase
End

















