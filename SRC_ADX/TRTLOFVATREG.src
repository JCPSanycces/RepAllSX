# GTAMUNI unitaire ou GTAMMAS massif
 Call LAUNCH_ACT(GTAMMAS)
End
#==============================================================#
#            Gestion de l'action métier LOFVATREG              #
#==============================================================#

####  Call ECR_TRACE("Informations à tracer",0) From GESECRAN 

######################################################################
# Etiquettes modèle Traitement standard / saisie fenêtre / gobjet
######################################################################
$ACTION

 #Infbox "TRTLOFVATREG /"-ACTION
 Case ACTION
  When "INIT"         : Gosub INIT
  When "INIT_DIA"     : Gosub INIT_DIA
  When "AVANT_PAR"    : Gosub AVANT_PAR
  When "OUVRE"        : Gosub OUVRE
  When "OUVRE_BATCH"  : Gosub OUVRE_BATCH
  When "DEBUT"        : Gosub DEBUT
  When "CONTROLE"     : Gosub CONTROLE
  When "APRES_MODIF"  : Gosub APRES_MODIF
  When "SETBOUT"      : Gosub SETBOUT
  When "AP_CHOIX"     : Gosub AP_CHOIX
  When "BOUTON"       : Gosub BOUTON
  When "END"          : Gosub END_BOITE
  When "OK"           : Gosub OK
  When "EXEC"         : Gosub EXEC
  When "FIN"          : Gosub FIN
  When "TERMINE"      : Gosub TERMINE
  When "SORTIE"       : Gosub SORTIE
  When Default
 Endcase
Return

#=====================================================================
$OUVRE_BATCH             # (Massif uniquement - Soumission batch uniquement)
  Gosub ACTION From =TRTMODACT
  Gosub OUVRE_TABLES
Return

#=====================================================================
$INIT_DIA                    # (Massif - Saisie des paramètres)
 If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
 TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Gosub ACTION From =TRTMODACT  
Return 

#=====================================================================
$INIT                    # (Massif uniquement - interactif et exécution batch)
 If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
 TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Gosub ACTION From =TRTMODACT 
 If GSERVEUR
  #==> Déclaration globales 
  Gosub CREE_GLOBTRT 
  #==> Déclaration globales nécessaires à la fonction
  # FQ46680
  Call GET_ELEM_REG_TVA ("") From TRTFAS
 Endif
Return

#=====================================================================
$AVANT_PAR               # (Massif uniquement - Interactif et soumission batch)

  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT

  ##### Ouverture des masques de la fenêtre de l'action massive pour pouvoir les garder jusqu'à
  ##### EXEC - Ouverture manuelle des masques de la fenêtre. 
  ##### Nécessaire jusqu'à ce qu'une modif permette de lancer une action massive avec plus
  ##### d'un écran de critère.
  Local Char WINACT : WINACT=ACTMETNAM+""
  Local Integer I_MSK
  If !clalev([F:AWI]) : Local File AWINDOW : Endif
  If !clalev([F:AMK]) : Local File AMSK    : Endif
  Read [AWI]AWI0=WINACT
  If !fstat
   Local Mask =[F:AWI]MSKENT
   For I_MSK=0 To [F:AWI]NBMSK
     Read [AMK]CODMSK=[F:AWI]NOMMSK(I_MSK)
     Local Mask =[F:AMK]CODMSK 
   Next I_MSK
  Endif
  ##### Fin spécificité.

Return

#=====================================================================
$OUVRE                   # (Massif interactif et Unitaire)

  If dim(TRTMODACT)<0
   Global Char TRTMODACT
   TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Endif
  Gosub ACTION From =TRTMODACT

  #==> Ouverture des tables
  Gosub OUVRE_TABLES

  If !GSERVEUR        
   Gosub CREE_GLOBTRT 
  Endif

  #==> Trace du traitement
  G_TRACE       = G_NON
     
  #==> Déclaration globales nécessaires à la fonction
  # FQ46680
  Call GET_ELEM_REG_TVA ("") From TRTFAS

  Local Char OLDCPY(GLONCPY)

Return

#=====================================================================
$CREE_GLOBTRT
  Global Integer    G_TRACE, G_NBLOF, G_NBLOF_TRT
  Global Date       G_FINPERCPF, G_FINPERIAS
  Global Decimal    G_DEDVAT, G_CRBVAT, G_INIDEDAMT
Return

#=====================================================================
$DEBUT # (Massif et Unitaire)


  Gosub ACTION From =TRTMODACT

  #--> On rend le masque invalide pour faire tous les contrôles
  # Setmok [M:FASR] With 0
  
Return

#=====================================================================
$CONTROLE
  Gosub ACTION From =TRTMODACT

  If FIN = 1 : Return : Endif
Return

#=====================================================================
$APRES_MODIF

  Gosub ACTION From =TRTMODACT
  Case COUZON
    When "FLGCPY"
      If ( val(CZ) = G_OUI ) Then
        [M:FASR]STRDAT = GDEBEXECPF : Affzo [M:FASR]STRDAT
        [M:FASR]MVTDAT = GFINEXECPF : Affzo [M:FASR]MVTDAT
      Endif
    When "FLGFCY"
      If ( val(CZ) = G_OUI and OLDCPY <> [M:MHC]FCYCPY(nolign-1) ) Then
        OLDCPY = [M:MHC]FCYCPY(nolign-1)
        [M:FASR]STRDAT = GDEBEXECPF : Affzo [M:FASR]STRDAT
        [M:FASR]MVTDAT = GDEBEXECPF : Affzo [M:FASR]MVTDAT
      Endif
    When Default
  Endcase 
Return

#=====================================================================
$SETBOUT                 # (Massif interactif et unitaire : )
  Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$AP_CHOIX                 # (Unitaire : )
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$BOUTON                  # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$END_BOITE               # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$OK                      # (Massif intéractif et unitaire)

 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$EXEC                    # (Massif intéractif et batch)
  Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$FIN                     # ()
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$TERMINE                  # ()
 Gosub ACTION From =TRTMODACT

  Call FERME_BOITE From GESECRAN

  #==> Suppression des globales nécessaires à la fonction
  If dim(G_ECIMPBAS)   >0 : Kill G_ECIMPBAS  : Endif     
  If dim(G_ECVARPRO)   >0 : Kill G_ECVARPRO  : Endif     
  If dim(G_TENCOURS)   >0 : Kill G_TENCOURS  : Endif    
  If dim(G_REGULIAS)   >0 : Kill G_REGULIAS  : Endif    
  If dim(G_TRACE)      >0 : Kill G_TRACE     : Endif     
  If dim(G_NBLOF)      >0 : Kill G_NBLOF     : Endif     
  If dim(G_NBLOF_TRT)  >0 : Kill G_NBLOF_TRT : Endif  
  If dim(G_FINPERCPF)  >0 : Kill G_FINPERCPF : Endif  
  If dim(G_FINPERIAS)  >0 : Kill G_FINPERIAS : Endif  
  If dim(G_DEDVAT)     >0 : Kill G_DEDVAT    : Endif  
  If dim(G_CRBVAT)     >0 : Kill G_CRBVAT    : Endif  
  If dim(G_INIDEDAMT)  >0 : Kill G_INIDEDAMT : Endif  
     
Return

#=====================================================================
$SORTIE                  
 Gosub ACTION From =TRTMODACT
Return

######################################################################
# Points d'entrée de l'action métier communs unitaire / massif 
######################################################################

$ACTMET
 #Infbox "TRTLOFVATREG/ACTMET = "+ num$(ACTMET) 
 Case ACTMET

  When "SET_GLO_MAS"        :   Gosub SET_GLO_MAS         
  When "SET_CRITACT"        :   Gosub SET_CRITACT          # UM - CRITACT critère de sélection particulier à l'action métier
  When "FILL_HEA"           :   Gosub FILL_HEA             # U  - Alimentation partie spécifique en-tête

# Locker

  When "OUVR_LOCK"          :   Gosub OUVR_LOCK            # UM - Ouverture de tables annexes pour les lock
  When "MAS1_CONTROLE"      :   Gosub MAS1_CONTROLE        # UM  - Exclusion élément de la population à sélectionner
  When "MAS1_LOCK_AUTRE"    :   Gosub MAS1_LOCK_AUTRE      # UM - Lock objet lié à l'enr en ligne de la population

# Charger

  When "OUVR_ALIM_TMP1"     :   Gosub OUVR_ALIM_TMP1       # UM - Ouverture de tables annexes pour l'alim des table tmp.
  When "MAS1_ALIM_TMP1"     :   Gosub MAS1_ALIM_TMP1       # UM - Transfert zones tables de données -> tables tempo

# Applique_temp 

  When "OUVR_APPL_TMP1"     :   Gosub OUVR_APPL_TMP1       # UM - Ouverture de tables annexes 
  When "TMP1_APPL_TMP1"     :   Gosub TMP1_APPL_TMP1       # UM - Application des paramètres de l'action aux enr de la table temporaire principale
  When "TPF1_APPL_TPF1"     :   Gosub TPF1_APPL_TPF1       # UM - Application des paramètres de l'action aux enr de la table temporaire annexe

# Report_mask Report objet principal dans les masques (unitaire uniquement) 

  When "TMP1_ALIM_MASK"     :   Gosub TMP1_ALIM_MASK       # U  - Tansfert table temporaire principale -> masques de l'écran
  When "TPF1_ALIM_MASK"     :   Gosub TPF1_ALIM_MASK       # U  - Tansfert table temporaire annexe     -> masques de l'écran
  When "REAF_ALIM_MASK"     :   Gosub REAF_ALIM_MASK       # U  - Tansfert tables temporaires -> masques de l'écran (pour réaffichage)

# Applique_dirt Mise à jour directe (massif uniquement)

  When "OUVR_APPL_DIRT"     :   Gosub OUVR_APPL_DIRT       # M  - Ouverture de tables annexes pour la maj directe en massif
  When "MAS1_APPL_DIRT"     :   Gosub MAS1_APPL_DIRT       # M  - Mise à jour directe des tables de données avec les paramètres de l'action

# reporter

  When "OUVR_ALIM_TABLE"    :   Gosub OUVR_ALIM_TABLE      # UM - Ouverture tables annexes avant report tables tempo -> tables de données
  When "TMP1_ALIM_TABLE"    :   Gosub TMP1_ALIM_TABLE      # UM - Report table temporaire principale -> table de données
  When "TPF1_ALIM_TABLE"    :   Gosub TPF1_ALIM_TABLE      # UM - Report table temporaire par plan   -> table de données par plan

  When Default

 Endcase
Return
#=====================================================================
# Unitaire / massif : 
$SET_GLO_MAS
  # Aucune dépense susceptible de subir une régularisation de TVA
  GMSGNOOBJLCK= mess(469,7773,1)
Return


#=====================================================================
# Unitaire / massif : Critère de sélection particulier à l'action métier
$SET_CRITACT
  # CRITACT contient les critères de sélection suppplémentaires à appliquer à la population à sélectionner
  # FQ 46680
  CRITACT="1=1"
Return

#=====================================================================
# Unitaire : Permet d'alimenter des zones spécifiques de l'en-tête de la fenêtre
$FILL_HEA
Return

#=====================================================================
# Unitaire et massif : Sert à ouvrir des tables utilisées dans MAS1_CONTROLE 
#                      et MAS1_LOCK_AUTRE
$OUVR_LOCK
  Gosub OUVRE_TABLES
Return

#=====================================================================
# Unitaire / massif : contrôle élément pour retrait de la population
$MAS1_CONTROLE
Return

#=====================================================================
# Unitaire / massif : Lock d'objet lié à l'enregistrement en ligne
#                     Alimenter RMES si un message soit apparaître
$MAS1_LOCK_AUTRE
Return

#=====================================================================
# Unitaire / massif : Sert à ouvrir des tables utilisées dans MAS1_ALIM_TMP1
$OUVR_ALIM_TMP1
Return

#=====================================================================
# Unitaire / massif : Chargement de la population en table temporaire
#                     Etiquette appelée par le s/p CHARGER
#                     Si une erreur se produit dans cette étiquette
#                     Alimenter RMES avec le message qui doit apparaître
#                     dans une boîte en unitaire ou en massif
$MAS1_ALIM_TMP1
Return

#=====================================================================
# Unitaire / massif : Ouverture de tables annexes
$OUVR_APPL_TMP1
Return

#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire principale
$TMP1_APPL_TMP1
Return

#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire annexe (par plan)
$TPF1_APPL_TPF1
Return

#=====================================================================
# Unitaire : Permet de reporter les infos de TMP1 dans les masques de l'objet métier
#            Positionner ACTMODIF à 1 si des infos de l'objet métier sont modifiées
$TMP1_ALIM_MASK
Return

#=====================================================================
# Unitaire : Permet de reporter les infos de TPF1 dans les masques de l'objet métier
#            Positionner ACTMODIF à 1 si des infos de l'objet métier sont modifiées
$TPF1_ALIM_MASK
Return

#=====================================================================
# Unitaire : Permet de réafficher les masques de l'objet métier si des modifs 
#            y ont été reportées.
REAF_ALIM_MASK
Return

#=====================================================================
# Massif : Sert à ouvrir des tables utilisées dans MAS1_APPL_MAS1
$OUVR_APPL_DIRT
  Gosub OUVRE_TABLES
  # Société courante : rupture société pour émission en-tête trace
  Local Char    TRC_CPY 
  Local Char    TXTPROG(40)
  Local Integer NBLOF

  TXTPROG = mess(322,7773,1) 
  G_NBLOF   = NBOBJLCK
  Call TEMPOFF() From GESECRAN
  Call OUVRE_BOITE(TXTPROG, G_NBLOF) From GESECRAN
  Call SET_BOITE(TXTPROG, G_NBLOF) From GESECRAN
        
  NBMAJ_RECALC = G_NON # Gbn-10012005-Bug n°27388

Return

#=====================================================================
# Massif : Application paramètres action aux tables de données : mise à jour directe
$MAS1_APPL_DIRT
If ( G_TRACE = G_OUI) Then : Infbox "MAS1_APPL_DIRT" : Endif

Local Char    TXTPROG(40)
Local Integer NBLOF_TRT, LOK
Local Date    W_CNX_DATE(1..5)

Local Char    LCLASSE
Local Decimal LREGUL, LTAUXPRO
Local Integer RTRN

Local Integer LCDRET, CDRET 
Local Char    LCDINT(10)
  #-> A rupture société on émet un en-tête dans la trace
  If ( [F:MAS1]CPY<>TRC_CPY ) Then

    # FQ46680
    #==> Paramétrage TVA
    Call GET_ELEM_REG_TVA([F:MAS1]CPY) From TRTFAS   

    Gosub ECR_ENTETE
    TRC_CPY=[F:MAS1]CPY
    Raz G_NBLOF_TRT

    # Récupération date de fin de période contexte fiscale & comptable pour génération événement
    Call GET_CNX_DAT([F:MAS1]CPY, G300CPFI, W_CNX_DATE, CDRET) From GLOBIENS
    G_FINPERCPF = W_CNX_DATE(4)
    If ( G_FINPERCPF = [0/0/0] ) Then
      G_FINPERCPF = W_CNX_DATE(2)
    Endif    
    # Récupération date de fin de période contexte IAS (si géré)  pour génération événement
    If ( GCNXPROIAS = G_OUI ) Then
      Call GET_CNX_DAT([F:MAS1]CPY, G300IAS, W_CNX_DATE, CDRET) From GLOBIENS
      G_FINPERIAS = W_CNX_DATE(4)    
      If ( G_FINPERIAS = [0/0/0] ) Then
        G_FINPERIAS = W_CNX_DATE(2)
      Endif 
    Endif   
  Endif

  G_NBLOF_TRT += 1
  TXTPROG    = mess(293,7773,1)+[F:MAS1]CODLOF+num$([F:MAS1]LINLOF)+'['+num$(G_NBLOF_TRT)+'/'+num$(G_NBLOF)+']'
  Call AFF_BOITE(TXTPROG,G_NBLOF_TRT,LOK) From GESECRAN

  LCLASSE = "[F:MAS1]"


  # FQ46680
  # Call REGUL_TVA_DEPENSE(LCLASSE, [F:MAS1]CPY, LREGUL, LTAUXPRO, G_INIDEDAMT,  RTRN) From TRTFAS
  Call REGUL_TVA_DEPENSE("TRTLOFVATREG", LCLASSE, [F:MAS1]CPY, LREGUL, LTAUXPRO, G_INIDEDAMT,  RTRN) From TRTFAS
  If (RTRN > 0 ) Then
    # Erreur technique
    Case RTRN
      When 1
        RMES= mess(323,7773,1)-[F:MAS1]CODLOF+"/"+num$([F:MAS1]LINLOF)-mess(295,7773,1)-[F:MAS1]ACT     
      When 2 
        RMES= mess(323,7773,1)-[F:MAS1]CODLOF+"/"+num$([F:MAS1]LINLOF)-mess(296,7773,1)
      When Default
    Endcase
    GOK=0 : Return
  Endif
 
  If ( RTRN = 0 ) Then
    Gosub ECR_LIGNE
    NBCPYMAJ += 1
  Endif

  #-----------------
  If ( FLGSIM = G_NON and RTRN = 0 ) Then
    Rewrite [MAS1]
    #-------------------
    If (fstat) Then 
      # Erreur technique
      RMES= mess(104,7773,1)+" LAYOUTFAS"+mess(105,7773,1)+" 01"+mess(106,7773,1)-[F:MAS1]CODLOF+"/"+num$([F:MAS1]LINLOF)          
      GOK=0 : Return
      #-------------------
    Else
      # Génération des évènements 
      LCDINT= "LOFVATREG1"
      If (LREGUL < 0 ) Then
       G_DEDVAT = 0
       G_CRBVAT = abs(LREGUL)     
      Else
       G_CRBVAT = 0
       G_DEDVAT = LREGUL     
      Endif
      Call GENER_EVE ( GVML_OMDEPEN, [F:MAS1]CPY, [F:MAS1]FCY, [F:MAS1]CODLOF, [F:MAS1]LINLOF,
&                      LCDINT, G_FINPERCPF, [0/0/0], LCDRET ) From GENEVE
      # FQ 46680
      If (GCNXPROIAS = G_OUI and G_REGULIAS = G_OUI ) Then
        LCDINT= "LOFVATREG6"
        Call GENER_EVE ( GVML_OMDEPEN, [F:MAS1]CPY, [F:MAS1]FCY, [F:MAS1]CODLOF, [F:MAS1]LINLOF,
&                        LCDINT, G_FINPERIAS, [0/0/0], LCDRET ) From GENEVE
      Endif 
      #---------------------
      If ( LCDRET > 20 ) Then
        RMES= mess(107,7773,1)-LCDINT+"-"+num$(LCDRET)
        GOK = 0: Return          
      Endif
      #---------------------
    Endif 
    #-------------------
  Endif
  #-----------------

Return



#=====================================================================
# Unitaire / massif : Ouverture de tables annexes avant report du contenu des tables temporaires dans les tables de données
$OUVR_ALIM_TABLE
Return

#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire principale dans la table de données principale
$TMP1_ALIM_TABLE
Return

#=====================================================================
