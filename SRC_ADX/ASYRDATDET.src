End

#-----------------------------#
Funprog PREFIX_INSTANCE(GRI)
Value Char GRI
Local Char PAR(250)
Local Integer I
For I=len(GRI) To 1 Step -1
 If mid$(GRI,I,1)="."
  PAR = left$(GRI,I-1) : Break
 Endif
Next I
End PAR

#----------------------------#
Funprog FINAL_INSTANCE(GRI)
Value Char GRI
Local Char INS(250)
Local Integer I
INS = GRI
For I=len(GRI) To 1 Step -1
 If mid$(GRI,I,1)="."
  INS = right$(GRI,I+1) : Break
 Endif
Next I
End INS

#-----------------------------------------------------------------#
# Search path instance class of property X3 for alias Syracuse
#-----------------------------------------------------------------#

Funprog PATH_PROPERTY(INS,PTH)
Value Char INS , PTH
Local Char    WPRO(250) , WINS(250) , WRAC(50)
Local Char    RAC(10) , CHAINE(250)
Local Char    TBINS(30)(1..20)
Local Integer TBIND(1..20)
Local Integer I , J , K
WINS = INS
WRAC = ""
For RAC="WREP","WQRY"
 If left$(WINS,4)=RAC
  K = instr(1,WINS,".")
  If K
   WRAC = left$(WINS,K-1)
   WINS = right$(WINS,K+1)
  Else
   WRAC = WINS
   WINS = ""
  Endif
  Break
 Endif
Next RAC
I = 0
While WINS<>""
 K = instr(1,WINS,".")
 If K
  CHAINE = left$(WINS,K-1)
  WINS = right$(WINS,K+1)
 Else
  CHAINE = WINS
  WINS = ""
 Endif
 I += 1
 K = instr(1,CHAINE,"(")
 If K
  TBIND(I) = val(right$(CHAINE,K+1))
  TBINS(I) = left$(CHAINE,K-1)
 Else
  TBIND(I) = -1
  TBINS(I) = CHAINE
 Endif
Wend
WPRO = PTH
K = 1
For J=1 To I
 K = instr(K,WPRO,".")
 If TBIND(J)>=0 & K
  CHAINE = '('+num$(TBIND(J))+')'
  WPRO = left$(WPRO,K-1)+CHAINE+right$(WPRO,K)
  K += len(CHAINE)
 Endif
 K += 1
Next J
If WRAC<>""
 WPRO = WRAC+"."+WPRO
Endif
End WPRO

#------------------------------------------------------#
$ASSIGN_KEYS_LOOKUP
For C=1 To NBK
 CHAINE = seg$(TBLOO(C),2,len(TBLOO(C))-1)
 If CHAINE<>CURPRO
  If find(left$(TBLNK(C),1),'"',"'")
   NODEPRO = '"'+CHAINE+'"'
   NODESVAL= '"'+seg$(TBLNK(C),2,len(TBLNK(C))-1)+'"'
   Gosub ADDSTRING From ASYRJSO
  Else
   WCHAINE = seg$(TBLNK(C),2,len(TBLNK(C))-1)
   K = find(WCHAINE,REP.PRO(1..maxtab(REP.PRO)).PRO)
   If K
    NODEPRO = '"'+CHAINE+'"'
    TYP = REP.PRO(K).TYP
    VRB = func PATH_PROPERTY(INSPAR,REP.PRO(K).PTH)
    Gosub CODPRO_VALUE
    NODESVAL= WVALUE
    Gosub ADDSTRING From ASYRJSO
   Endif
  Endif
 Endif
Next C
Return

#------------------------#
$LOOKUP_KEYS
NBK = 0
CURPRO = ""
For C=1 To maxtab(REP.PRO(VRI).LNK(LOU).CLE)
 If REP.PRO(VRI).LNK(LOU).CLE(C)<>null
  NBK += 1
  If REP.PRO(VRI).LNK(LOU).CLE(C).LOO<>""
   TBLOO(NBK) = '{'+REP.PRO(VRI).LNK(LOU).CLE(C).LOO+'}'
  Elsif find(left$(REP.PRO(VRI).LNK(LOU).CLE(C).VPR,1),"'",'"')
   TBLOO(NBK) = func ASYRJSO.PARAM(REP.PRO(VRI).LNK(LOU).CLE(C).VPR)
  Else
   TBLOO(NBK) = '{'+REP.PRO(VRI).LNK(LOU).CLE(C).PAR+'}'
  Endif
  If REP.PRO(VRI).LNK(LOU).CLE(C).PRO<>""
   TBLNK(NBK) = '{'+REP.PRO(VRI).LNK(LOU).CLE(C).PRO+'}'
  Elsif find(left$(REP.PRO(VRI).LNK(LOU).CLE(C).VPR,1),"'",'"')
   TBLNK(NBK) = func ASYRJSO.PARAM(REP.PRO(VRI).LNK(LOU).CLE(C).VPR)
  Else
   TBLNK(NBK) = '{'+REP.PRO(VRI).LNK(LOU).CLE(C).VPR+'}'
  Endif
  If REP.PRO(VRI).LNK(LOU).CLE(C).PRO=REP.PRO(VRI).PRO
   CURPRO = seg$(TBLOO(NBK),2,len(TBLOO(NBK))-1)
  Endif
 Endif
Next C
Return

#-------------------------------#
$UUID_COL
If evalue("dim("+INSPAR+".AUUID)")>0
 VRP = INSPAR
Elsif INSCLA<>"" & evalue("dim("+func PATH_PROPERTY(INSPAR,INSCLA)+".AUUID)")>0
 VRP = func PATH_PROPERTY(INSPAR,INSCLA)
Else
 VRP = ""
Endif
If VRP<>""
 VRU = evalue(VRP+".AUUID")
Endif
Return

#----------------------------------#
$VALUES
REF = (REP.PRO(VRI).PLK=2)
If !REF
 If VRC<>""
  NODEPRO = '"'+VRC+'"'
 Else
  NODEPRO = ''
 Endif
 Gosub CODPRO_VALUE
 NODESVAL = WVALUE
 Gosub ADDSTRING From ASYRJSO
Endif
Return

#----------------------------------#
$ATTRIBUTE
REF = (REP.PRO(VRI).PLK=2)
NBA = 0
WCHAINE = func INSTANCE_CLASS(REP.PRO(VRI).TPC,INSPAR,REP.PRO(VRI).PTH)
If WCHAINE="" : Return : Endif
For A=1 To evalue("maxtab("+WCHAINE+".ATT)")
 If evalue(WCHAINE+".ATT("+num$(A)+")")<>null
  WPROD = evalue(WCHAINE+".ATT("+num$(A)+").PRO")
  L = instr(1,WPROD,"(")
  If L : WIND = val(right$(WPROD,L+1)) : WPROD = left$(WPROD,L-1) : Else : WIND = 0 : Endif
  If WPROD=func PROPERTY_CLASS(REP.PRO(VRI).PTH) & D=WIND
   WCODE = evalue(WCHAINE+".ATT("+num$(A)+").COD")
   If func ASYRSUB.ATTOKJSON(WCODE)
    If dim(NAT)>0 & NAT=0
     NAT = 1
     NODEPRO = '"$properties"'
     Gosub ADDOBJECT From ASYRJSO
    Endif
    If NBA=0
     NBA = 1
     If REF
      NODEPRO = '"'+VRC+'"'
     Else
      NODEPRO = '"'+VRC+'"'
     Endif
     Gosub ADDOBJECT From ASYRJSO

    Endif
    NODEPRO = '"'+WCODE+'"'
    NODESVAL = '"'+escJson(evalue(WCHAINE+".ATT("+num$(A)+").ATT"))+'"'
    Gosub ADDSTRING From ASYRJSO
   Endif
  Endif
 Endif
Next A
If NBA
 Gosub ENDNIV From ASYRJSO
Endif
Return

#----------------------------------#
$PROPERTY
REF = (REP.PRO(VRI).PLK=2)
NBA = 0
If REF
 NODEPRO = '"'+VRC+'"'
 Gosub CODPRO_VALUE
 NODESVAL = WVALUE
 Gosub ADDSTRING From ASYRJSO
Endif
Gosub DESCRIPTION
If NBA
 Gosub ENDNIV From ASYRJSO
Endif
Return

#-----------------------------------------------#
$DESCRIPTION
Local Instance INSATT Using OBJECT
Local Char ATT(250)
Local Integer AAM,AAI,ATTTYP
Local Char LISTATTREF(20)(1..)
Local  Instance PATTRIBUTES Using C_ATTRIBUTES


WCHAINE = func INSTANCE_CLASS(REP.PRO(VRI).TPC,INSPAR,REP.PRO(VRI).PTH)
If WCHAINE="" : Return : Endif
[L]INSATT = evalue(WCHAINE)
K = 0
If func ASYRSUB.AGETPROATTRIBUTES([L]INSATT,func PROPERTY_CLASS(REP.PRO(VRI).PTH),PATTRIBUTES)
 AAM = func ASYRSUB.AGETLISTATTOKREF(LISTATTREF)
 For AAI=1 To AAM
  WCODE = LISTATTREF(AAI)
  If func ASYRSUB.AGETPROATTRIBUTE(PATTRIBUTES,WCODE,ATT,ATTTYP)
   If NBA=0
    NBA = 1
    If REF
     NODEPRO = '"'+VRC+func ASYRJSO.REF+'"'
    Else
     NODEPRO = '"'+VRC+'"'
    Endif
    Gosub ADDOBJECT From ASYRJSO
   Endif
   K = 1
   Gosub ADDJSO From ASYRJSO
   Call SETATTRIBUTE(PJSON,WCODE,ATTTYP,ATT) From ASYRJSO
  Endif
 Next AAI
Endif

If REF & !K
 If NBA=0
  NBA = 1
  NODEPRO = '"'+VRC+func ASYRJSO.REF+'"'
 Gosub ADDOBJECT From ASYRJSO
 Endif
 NODEPRO = '"'+func ASYRSUB.CODATT("T")+'"'
 NODESVAL = '""'
 Gosub ADDSTRING From ASYRJSO
Endif
Return

#-------------------------------------#
Funprog INSTANCE_CLASS(TYP,INS,PTH)
Value Integer TYP
Value Char INS , PTH
Local Char WCHAINE(250)
Case TYP
 When 0 : # Property not in class or representation
  WCHAINE = ""
 When 1 : # Property of representation
  WCHAINE = INS
 When 2 : # Property of class
  WCHAINE = func PATH_PROPERTY(INS,PTH)
  For I=len(WCHAINE) To 1 Step -1
   If mid$(WCHAINE,I,1)="."
    WCHAINE = left$(WCHAINE,I-1) : Break
   Endif
  Next I
Endcase
End WCHAINE

#----------------------------------#
Funprog PROPERTY_CLASS(PROCLA)
Value Char PROCLA
Local Char    PRO(250)
Local Integer I , J
PRO = PROCLA
I = instr(1,PROCLA,".")
While I
 J = I
 I = instr(J+1,PROCLA,".")
Wend
If J
 PRO = right$(PROCLA,J+1)
Endif
End PRO

#--------------------#
$HEADER

TYP = 7
VRA = PROENT(1)
VRC = "uuid"
Gosub HEADER_PRO

TYP = 11
VRA = PROENT(2)
VRC = "etag"
Gosub HEADER_PRO

TYP = 2
VRA = PROENT(4)
VRC = "index"
Gosub HEADER_PRO

Return

#---------------------------------#
$HEADER_PRO
# Propertie on representation or class ?
Local Char WHEAD(10)
If dim(WREP)>0
 WHEAD = "WREP"
Else
 WHEAD = "WQRY"
Endif
If left$(INSPAR,len(WHEAD))=WHEAD & evalue("dim("+INSPAR+"."+REP.ICL+".AUUID)")>0
 VRP = INSPAR+"."+REP.ICL
Elsif evalue("dim("+INSPAR+"."+VRA+")")>0
 VRP = INSPAR
Elsif INSCLA<>"" & evalue("dim("+func PATH_PROPERTY(INSPAR,INSCLA)+"."+VRA+")")>0
 VRP = func PATH_PROPERTY(INSPAR,INSCLA)
Else
 VRP = ""
Endif
If VRP<>""
 VRB = VRP+"."+VRA
 Gosub CODPRO_VALUE
 # If update date is null, try with create date
 If VRA=PROENT(2) & WVALUE=func ASYRSUB.SYR_NULL
  VRA = PROENT(3)
  Goto HEADER_PRO
 Endif
 If VRA=PROENT(2) & evalue("dim("+VRB+")")<=0
  Return
 Endif
 If VRA=PROENT(4) & WVALUE="0"
  Return
 Endif
 If VRA=PROENT(1) & WVALUE='"'+num$(NullUuid)+'"'
  WVALUE = '"'+num$(getUuid)+'"'
 Endif
 NODEPRO = '"$'+VRC+'"'
 NODESVAL = WVALUE
 Gosub ADDSTRING  From ASYRJSO
Endif
Return

#-----------------------------------#
# Find default value
#-----------------------------------#

$DEF_VALUE
DEF = 0
Onerrgo RIEN
Case TYP
 When 1 : # Boolean
  DEF = (evalue(VRB)<>2)
 When 2,3,4 : # Integer/Decimal/Real
  DEF = (evalue(VRB)=0)
 When 5 : # Date
  DEF = (format$("D:YYYY[-]MM[-]DD",evalue(VRB))="    -  -  ")
 When 6 : # Time
  DEF = (format$("K:##[:]##[:]##",num$(evalue(VRB)))="  :  :  ")
 When 7 : # String
  DEF = (func ASYRJSO.TRANS(num$(evalue(VRB)))="")
 When 8,9 : # Clob/Blob
  DEF = (len(evalue(VRB))=0)
 When 10 : # Menu local
  DEF = (evalue(VRB)=0)
 When 11 : # Datetime
  DEF = (evalue(VRB)="1970-01-01T00:00:00Z")
 When Default
  DEF = (evalue(VRB)="")
Endcase
Onerrgo
Return

$RIEN
Resume

#----------------------------------------#
# Encoding parameters in strings value
#----------------------------------------#

Funprog ENCODE_PARAMETERS(PARAM)
Value Char PARAM
Local Char WVALUE(250)
Onerrgo ERROR_ENCODE
WVALUE = num$(evalue(PARAM))
Onerrgo
End WVALUE

#---------------------------#
$ERROR_ENCODE
WVALUE = '"'+"'{"+WVALUE+"}'"+'<error'-errmes$(errn)+'>"'
Resume

#---------------------------#
# Value typed Syracuse
#---------------------------#

$CODPRO_VALUE
Local Char WCNT(100)
Onerrgo ERROR_VALUE
# TYP AML 7875
Case TYP
 When 1 : # Boolean
  WVALUE = func ASYRSUB.BOOLEAN_TO_SYR(evalue(VRB))
 When 2,3,4 : # Number
  WVALUE = num$(evalue(VRB))
 When 5 : # Date
  WVALUE = '"'+func ASYRSUB.DATE_TO_SYR(evalue(VRB))+'"'
 When 6 : # Time
  WVALUE = '"'+func ASYRSUB.TIME_TO_SYR(evalue(VRB))+'"'
 When 7 : # Char
  WVALUE = '"'+func ASYRSUB.STRING_TO_SYR(num$(evalue(VRB)))+'"' : # Strings & uuid
 When 8,9 : # Clob/Blob
  WVALUE = '{}' : #WVALUE = '{ "$contentType":"text/plain" }'
  WCNT=evalue('fmet '+func ASYRDATDET.PREFIX_INSTANCE(VRB)+'.AGETATTRIBUTE("'+func ASYRDATDET.FINAL_INSTANCE(VRB)+'","$isLobFound")')
  #106100
  #If WCNT="false" | evalue('fmet '+func ASYRDATDET.PREFIX_INSTANCE(VRB)+'.AGETATTRIBUTE("'+func ASYRDATDET.FINAL_INSTANCE(VRB)+'","$isHidden")')="true"
  If WCNT="false"
   WVALUE = func ASYRSUB.SYR_NULL
  Else
   WCNT=evalue('fmet '+func ASYRDATDET.PREFIX_INSTANCE(VRB)+'.AGETATTRIBUTE("'+func ASYRDATDET.FINAL_INSTANCE(VRB)+'","$contentType")')
   If WCNT<>"" : WVALUE = '{ "$contentType":"'+WCNT+'" }' : Endif
  Endif
 When 10 : # Enum
  WVALUE = num$(max(val(num$(evalue(VRB))),0))
 When 11 : # Datetime
  WVALUE = '"'+func ASYRSUB.DATETIME_TO_SYR(evalue(VRB))+'"'
 When 25 : # Textes superviseur
  WVALUE = '"'+func ASYRSUB.STRING_TO_SYR(evalue('fmet '+func PREFIX_INSTANCE(VRB)+'.AGETTEXT("'+func FINAL_INSTANCE(VRB)+'")'))+'"'
 When 26 : # Textes paramétrage
  WVALUE = '"'+func ASYRSUB.STRING_TO_SYR(num$(evalue(VRB)))+'"'
Endcase
If WVALUE='"'+func ASYRSUB.SYR_NULL+'"'
 WVALUE = func ASYRSUB.SYR_NULL
Endif
Onerrgo
Return

#---------------------------#
$ERROR_VALUE
WVALUE = '"'+"'{"+VRB+"}'"+'<error'-errmes$(errn)+'>"'
Resume
