# Mask management PLFPRO

######################################################################################
## Section automatically added (screen PLFPRO) 07/12/2017 12:44:29 (TIVAN)
######################################################################################
Subprog C_YEAPLF1(VALEUR)
Variable Char    VALEUR()
End

Subprog AP_LEGPLF1(VALEUR)
Variable Char    VALEUR()
End

Subprog C_CPYPLF1(VALEUR)
Variable Char    VALEUR()
  If dim([M:DIA]LEGPLF1)>0 & [M:DIA]LEGPLF1<>"" Then
    If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
    Read [F:CPY]CPY0=VALEUR
    If !fstat & [F:CPY]LEG<>"" Then
      If [F:CPY]LEG<>[M:DIA]LEGPLF1 Then
        GMESSAGE=mess(269,10717,1)-[M:DIA]LEGPLF1 : # La législation de la société doit être
        mkstat=2
      Endif
    Endif
  Endif
End

Subprog AM_CPYPLF1(VALEUR)
Variable Char    VALEUR()
  # On grise ou on dégrise le site
  If VALEUR = "" Then
   Actzo [M:DIA]FCYPLF1
  Else
   Diszo [M:DIA]FCYPLF1
  Endif
[F:PLF]YEAPLF = [M:DIA]YEAPLF1
[F:PLF]CPYPLF = VALEUR
[F:PLF]FCYPLF = [M:DIA]FCYPLF1
Gosub READ_BUR
End

Subprog C_FCYPLF1(VALEUR)
Variable Char    VALEUR()
If dim([M:DIA]LEGPLF1)>0 & [M:DIA]LEGPLF1<>"" Then
    If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
    Read [F:FCY]FCY0=VALEUR
    If !fstat & [F:FCY]LEG<>"" Then
      If [F:FCY]LEG<>[M:DIA]LEGPLF1 Then
        GMESSAGE=mess(270,10717,1)-[M:DIA]LEGPLF1 : # La législation du site doit être
        mkstat=2
      Endif
    Endif
  Endif
End

Subprog AM_FCYPLF1(VALEUR)
Variable Char    VALEUR()
  # On grise ou on dégrise la société
  If VALEUR = "" Then
   Actzo [M:DIA]CPYPLF1
  Else
   Diszo [M:DIA]CPYPLF1
  Endif
[F:PLF]YEAPLF = [M:DIA]YEAPLF1
[F:PLF]CPYPLF = [M:DIA]CPYPLF1
[F:PLF]FCYPLF = VALEUR
Gosub READ_BUR
End

Subprog C_STRD(VALEUR)
Variable Date    VALEUR
If day(VALEUR)<>1 Then
    GMESSAGE=mess(311,717,1) : # La date de début doit être le premier jour d'un mois
    mkstat=2
  Endif
  If !mkstat Then Call CTRL_DATES_PLF(VALEUR,[M:DIA]ENDD) From SUBPLF2 : Endif
End



$READ_BUR
# JML 02/09/2015 We need a budget to have the startind/ending dates
Read [BUR]BUR0(3)=[F:PLF]YEAPLF;[F:PLF]CPYPLF;[F:PLF]FCYPLF;[F:PLF]LEGPLF
If fstat
 Read [BUR]BUR0(3)=[F:PLF]YEAPLF;[F:PLF]CPYPLF;"";[F:PLF]LEGPLF
Endif
If fstat
 Read [BUR]BUR0(3)=[F:PLF]YEAPLF;"";"";[F:PLF]LEGPLF
Endif
If fstat
 Raz [F:BUR]
 Actzo [M:DIA]STRD, ENDD
 Raz [M:DIA]STRD
 Raz [M:DIA]ENDD
Else
 Grizo [M:DIA]STRD, ENDD
 [M:DIA]STRD = [F:BUR]STRDAT
 [M:DIA]ENDD = [F:BUR]ENDDAT
Endif
Affzo [M:DIA]STRD,ENDD
Return

######################################################################################
Subprog AM_STRD(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0]
 [M:DIA]ENDD = addmonth(VALEUR,12) - 1
Endif
If [M:DIA]ENDD<>[0/0/0] & VALEUR>[M:DIA]ENDD
 Call ECR_TRACE(mess(1,104,1)-">"-format$("D:"+GFMDAT,[M:DIA]ENDD),1) From GESECRAN
 #### Date incorrecte
 mkstat = 2 : End
Endif
End

Subprog C_ENDD(VALEUR)
Variable Date    VALEUR
  If day(VALEUR)<>day(eomonth(VALEUR)) Then
    GMESSAGE=mess(312,717,1) : # La date de fin doit être le dernier jour d'un mois
    mkstat=2
  Endif
  If !mkstat Then Call CTRL_DATES_PLF([M:DIA]STRD,VALEUR) From SUBPLF2 : Endif
End

Subprog AM_ENDD(VALEUR)
Variable Date    VALEUR
If VALEUR<[M:DIA]STRD
 Call ECR_TRACE(mess(1,104,1)-"<"-format$("D:"+GFMDAT,[M:DIA]STRD),1) From GESECRAN
 #### Date incorrecte
 mkstat = 2 : End
Endif
End
######################################################################################
Subprog AV_REPDEM(VALEUR)
Variable Integer VALEUR
# On positionne les demandes acceptées à Oui
If [M]STADEM(nolign-1) = len(mess(0,10454,1))
 VALEUR = 2
Endif
End

Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR > [M:DIA]ENDDAT and [M:DIA]ENDDAT <> [00/00/00] Then
  [M:DIA]ENDDAT = VALEUR : Affzo [M:DIA]ENDDAT
Endif
End
