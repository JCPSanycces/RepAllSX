######################################################################################
Subprog AM_YEAPLF1(VALEUR)
Variable Char    VALEUR()
[F:PLF]YEAPLF = VALEUR
[F:PLF]CPYPLF = [M:DIA]CPYPLF1
[F:PLF]FCYPLF = [M:DIA]FCYPLF1
Gosub READ_BUR
End


