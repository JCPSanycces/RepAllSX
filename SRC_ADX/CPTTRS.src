#<AdxTL>@(#)4.0.0.0 $Revision$
GTEST=0
Raz GPILOBJ, GPILCOD
Call OBJET("BIC",GBIDC1,"1") From GOBJET
End
#
# X3-39795  MDJ  Manage ORIGIN and ORICOD fields in GL Entry
#
$ACTION
Case ACTION
 When "AVANT_SUITE"     : Gosub AVANT_SUITE
 When "SEL_TABLE"       : Gosub SEL_TABLE
Endcase
Return

#################################
Subprog TRANSFERT(CODE,NUM,TYP,STAT)
Value    Char    CODE
Value    Char    NUM
Value    Char    TYP
Variable Integer STAT

Local Integer  ERR, OK , NBPRT
Local Integer  I , J , K , V
Local Decimal  BASE, MONTANT, CUMMNT, TAQTY, CUMQTY
Local Date     OLDDAT , NEWDAT, PREMDAT , DERDAT
Local Char     MESSA(80), CRITTRS(200)
Local Char     PCEAUTO(GLONGAU)
Local Char     GACPVS(GLONGAC),GACORI(GLONGAC)
Local Integer  MAXLIG

#-- Multi-référentiel
Local Integer NBLED
Local Char    CODLED(GLONLED)(1..len(mess(0,2644,1)))
Local Char WPARAM
#

If clalev([F:GAU])=0 : Local File GAUTACE     [GAU]  : Endif
If clalev([F:GAD])=0 : Local File GAUTACED    [GAD]  : Endif
If clalev([F:GAG])=0 : Local File GAUTACEF    [GAG]  : Endif
If clalev([F:TCU])=0 : Local File TABCUR      [TCU]  : Endif
If clalev([F:TUN])=0 : Local File TABUNIT     [TUN]  : Endif
If clalev([F:ACV])=0 : Local File ACTIV       [ACV]  : Endif
If clalev([F:CAL])=0 : Local File CPTANALIN   [CAL]  : Endif
If clalev([F:GCM])=0 : Local File GACM        [GCM]  : Endif

Local File GACCTMP     [HAE]
Local File GACCTMPD    [DAE]
Local File GACCTMPA    [DAA]

Local Mask SAICURLED [SCL], GACCENTFMT  [HAEF], GACCENTW  [HAEW]
Local Mask GACCENT0 [HAE0], GACCENT1 [HAE1], GACCENT2   [HAE2], VENTILE    [VTL], VENTILE2 [VT2]

If clalev([F:CPY])=0 : Local File COMPANY   [CPY]  : Endif
If clalev([F:PER])=0 : Local File PERIOD    [PER]  : Endif

# Existence du code, pièces automatique
If CODE="KIK1" | CODE="KIK2"
 Call PARAM("","GAU"+[L]CODE,[L]PCEAUTO) From ADOVAL
Endif
If [L]PCEAUTO="" : [L]PCEAUTO=[L]CODE : Endif
Read [F:GAU]GAU0 = [L]PCEAUTO
If fstat : MESSA = [L]PCEAUTO : STAT = 1 : Goto FIN : Endif

# Lecture table déclenchante
Onerrgo ERREUR
Local File =[F:GAU]TBL [TB0]
Onerrgo
If ERR : MESSA = [F:GAU]TBL : STAT = 3 : Goto FIN : Endif

# Recherche des prestations
#---  La génération de pièces de transfert ne s'intérrese uniquement aux lignes liées au Référentiel analytique principal de la société.
 Filter [F:TB0] Where [F:TB0]NUM=[L]NUM
 Read [F:TB0] First
 If dim([F:TB0]CPY) > 0
  WPARAM = [F:TB0]CPY
 Elsif dim([F:TB0]FCY) > 0
  WPARAM = [F:TB0]FCY
 Elsif dim([F:TB0]FCYLIN) > 0
  WPARAM = [F:TB0]FCYLIN
 Endif

 #-- Vérification du paramètre
 If func AFNC.PARAM("ITAPRE",WPARAM)<>"2" : End : Endif

 #-- La société gére t'elle un référentiel Analytique
 Call SETREF(WPARAM,NBLED,CODLED) From CPTDIV    # CODLED(2) me renvoie le référentiel analytique principal.
 If CODLED(2)="" : End : Endif
 #-- Indice de référentiel analytique principal
 Call SETMAINREF(WPARAM,GTYPGEN,GTYPANA) From CPTDIV

 For [F:TB0]
  Raz [L]GACORI
  If [F:TB0]STRDAT <> [00/00/00] & [F:TB0]ENDDAT <> [00/00/00] & [F:TB0]PERNBR<>0
  #--- Partie Négoce (il faut passer par la table CPTANALIN)
  If [F:GAU]TBL="SINVOICED"
   Read [CAL]CAL0 = "SID";0;[F:TB0]NUM;[F:TB0]SIDLIN;0;"";1
   Read [F:GAC]GAC0 = [F:CAL]COA(GTYPANA-1);[F:CAL]ACC(GTYPANA-1)
   If fstat : MESSA = [F:CAL]ACC(GTYPANA-1)  : STAT = 29 : Goto FIN : Endif
   [L]GACORI = [F:CAL]ACC(GTYPANA-1)
   [L]CRITTRS = "ABRFIC='SID' & VCRTYP=0 & VCRNUM='"+[F:TB0]NUM+"' & VCRLIN="+num$([F:TB0]SIDLIN)+" & VCRSEQ=0"
  Elsif [F:GAU]TBL="PINVOICED"
   Read [CAL]CAL0 = "PID";0;[F:TB0]NUM;[F:TB0]PIDLIN;0;"";1
   Read [F:GAC]GAC0 = [F:CAL]COA(GTYPANA-1);[F:CAL]ACC(GTYPANA-1)
   If fstat : MESSA = [F:CAL]ACC(GTYPANA-1)   : STAT = 29 : Goto FIN : Endif
   [L]GACORI = [F:CAL]ACC(GTYPANA-1)
   [L]CRITTRS = "ABRFIC='PID' & VCRTYP=0 & VCRNUM='"+[F:TB0]NUM+"' & VCRLIN="+num$([F:TB0]PIDLIN)+" & VCRSEQ=0"
  Elsif dim([F:TB0]COA) > 0 &  dim([F:TB0]ACC) > 0 & [F:TB0]COA(GTYPANA-1)<>"" & [F:TB0]ACC(GTYPANA-1)<>""
   #--- Partie Facture Tiers
    Read [F:GAC]GAC0 = [F:TB0]COA(GTYPANA-1);[F:TB0]ACC(GTYPANA-1)
    If fstat : MESSA = [F:TB0]ACC(GTYPANA-1) : STAT = 29 : Goto FIN : Endif
    [L]GACORI = [F:TB0]ACC(GTYPANA-1)
    [L]CRITTRS = "NUM='"+[F:TB0]NUM+"' & LIG="+num$([F:TB0]LIG)
  Else
   Raz [F:GAC]
  Endif
  If [F:GAC]GACPVS = "" : MESSA = [F:GAC]ACC : STAT = 30 : Goto FIN : Endif
  [L]GACPVS=[F:GAC]GACPVS
   Gosub TR1
  Endif
 Next
Filter [F:TB0]
End

#################################
$TR1
#################################
Raz NBPRT, CUMMNT
PREMDAT = [F:TB0]STRDAT-1
NEWDAT  = [F:TB0]STRDAT

Repeat
 NBPRT+=1
 OLDDAT = NEWDAT
 Call INCDATE(OLDDAT,NEWDAT,[F:TB0]STRDAT,[F:TB0]PERNBR,[F:TB0]PERTYP)
Until NEWDAT>[F:TB0]ENDDAT
MAXLIG = max(NBPRT,100)
Local Char TDATE(10)(1..MAXLIG)

# Calcul des périodicités
Raz NBPRT, CUMMNT, TDATE
PREMDAT = [F:TB0]STRDAT-1
NEWDAT  = [F:TB0]STRDAT

Repeat
 NBPRT+=1
 TDATE(NBPRT) = NEWDAT
 OLDDAT = NEWDAT
 Call INCDATE(OLDDAT,NEWDAT,[F:TB0]STRDAT,[F:TB0]PERNBR,[F:TB0]PERTYP)
Until NEWDAT>[F:TB0]ENDDAT

# Création des pièces de transfert
# 1- Extourne facture

  Raz [M:HAE0]
  Raz [M:HAE1]
  Raz [M:HAE2]
  Raz [M:VTL]
  Raz [M:VT2]
  Raz I,J,K

  ## Evaluation de l'en-tête
  Call TETE(STAT,MESSA) From TRTPCE
  If STAT : Goto FIN : Endif

  ## Initialisation masque de référence [HAEF]
  Call INIMSKFMT3([M]FCY,1,[M]DACDIA,[M]TYP,[M]ACCDAT,STAT) From SUBGASA
  For I=1 To [M:HAEF]NBRLED
   Assign "[M:HAE1]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
   Assign "[M:HAE2]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
  Next

  [M:HAE1]REFINT = "TR"+[L]TYP+[L]NUM

  ## Affectation des lignes
  ## Ligne d'annulation de charges/produits
  Read [GAD]GAD0 = [L]PCEAUTO;1

  ## Ouverture des tables liées
  # Table secondaire
  Onerrgo ERREUR
  Local File =[F:GAD]LINTBL1 [TB1] : I=1
  Onerrgo
  If ERR : MESSA = [F:GAD]LINTBL1 : STAT = 6 : Goto FIN : Endif
  # Table analytique
  Onerrgo ERREUR
  Local File =[F:GAD]LINTBL2 [TB2] : K=1
  Onerrgo
  If ERR : MESSA = [F:GAD]LINTBL2 : STAT = 7 : Goto FIN : Endif

  # Création de la ligne
  [M:HAE2]ACC1(0) = [L]GACORI
  Call LIGNE(0,"",STAT,MESSA) From TRTPCE
  If STAT : Goto FIN : Endif

  # Ventilation analytique
  If [M:HAE2]DSP(0)=""
   For [TB2] Where evalue(CRITTRS)
    Call LIGANA(0,STAT,MESSA) From TRTPCE
    If STAT : Break : Endif
   Next
   If STAT : Goto FIN : Endif
   Call FINREP(0) From TRTPCE
  Endif

  ## Ligne de provision
  Read [GAD]GAD0 = [L]PCEAUTO;2
  [M:HAE2]ACC1(1) = [L]GACPVS
  Call LIGNE(1,"",STAT,MESSA) From TRTPCE
  If STAT : Goto FIN  : Endif

  # Ventilation analytique
  If [M:HAE2]DSP(1)=""
   For [TB2] Where evalue(CRITTRS)
    Call LIGANA(1,STAT,MESSA) From TRTPCE
    If STAT : Break : Endif
   Next
   If STAT : Goto FIN : Endif
   Call FINREP(1) From TRTPCE
  Endif
  If I=1 : Close Local File [TB1] : Endif
  If K=1 : Close Local File [TB2] : Endif
  Raz I,K

  [M:HAE2]NBLIG = 2
  ## Validation pièce
  Call CONTROLE(STAT,MESSA) From CPTBATCH
  If GOK<1 or STAT : Goto FIN : Endif
  Local Char    TZONE(10)(1..10) : # Table of the zones to be forced (Ex: ORICOD)   #*X3-39795
  Local Char    TVAL(30)(1..10)  : # Table of values for zones to be forced         #*X3-39795
  TZONE(5)= "ORIGIN" : TVAL(5)= "2"        :#Automatic loading  # X3-39795
  TZONE(6)= "ORICOD" : TVAL(6)= "CPTTRS"                        # X3-39795
  #*X3-39795 Call VALPIECE(STAT,MESSA) From CPTBATCH
  Call VALPIECE2(STAT,MESSA,TZONE,TVAL) From CPTBATCH
  If GOK<1 or STAT : Goto FIN : Endif
  If GTRACE<>"" : Call ECR_TRACE(mess(93,117,1)-":"-GTYPPCE-GNUMPCE,0) From GESECRAN   : Endif     # Annulation comptable

# 2- Pièces de transfert "répétitive"
Raz MONTANT, TAQTY
Raz CUMMNT, CUMQTY
For J=1 To NBPRT
    Raz [M:HAE0]
    Raz [M:HAE1]
    Raz [M:HAE2]
    Raz [M:VTL]
    Raz [M:VT2]

    ## Evaluation de l'en-tête
    [M:HAE0]ACCDAT = TDATE(J)
    Call TETE(STAT,MESSA) From TRTPCE
    If STAT : Goto FIN : Endif

    ## Initialisation masque de référence [HAEF]
    Call INIMSKFMT3([M]FCY,1,[M]DACDIA,[M]TYP,[M]ACCDAT,STAT) From SUBGASA
    For I=1 To [M:HAEF]NBRLED
     Assign "[M:HAE1]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
     Assign "[M:HAE2]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
    Next

    [M:HAE1]REFINT = "TR"+[L]TYP+[L]NUM

    ## Affectation des lignes
    Gosub MNT_QTY
    If STAT : Goto FIN : Endif
    ## Ligne de charge & produit
    Read [GAD]GAD0 = [L]PCEAUTO;3
    ## Ouverture des tables liées
    # Table secondaire
    Onerrgo ERREUR
    Local File =[F:GAD]LINTBL1 [TB1] : I=1
    Onerrgo
    If ERR : MESSA = [F:GAD]LINTBL1 : STAT = 6 : Goto FIN : Endif

    # Table analytique
    Onerrgo ERREUR
    Local File =[F:GAD]LINTBL2 [TB2] : K=1
    Onerrgo
    If ERR : MESSA = [F:GAD]LINTBL2 : STAT = 7 : Goto FIN : Endif

    # Création des lignes
    [M:HAE2]ACC1(0) = [L]GACORI
    Call LIGNE(0,"",STAT,MESSA) From TRTPCE
    If STAT : Goto FIN : Endif
    Read [GAG]GAG0 = [L]PCEAUTO;3;"SNS"
    If evalue([F:GAG]FORCLC)>0
     [M:HAE2]CDT(0) = MONTANT
     [M:HAE2]DEB(0) = 0
    Else
     [M:HAE2]DEB(0) = MONTANT
     [M:HAE2]CDT(0) = 0
    Endif
    [M:HAE2]QTY(0) = TAQTY

    # Ventilation analytique
    If [M:HAE2]DSP(0)=""
     For [TB2] Where evalue(CRITTRS)
      Call LIGANA(0,STAT,MESSA) From TRTPCE
      If STAT : Break : Endif
     Next
     If STAT : Goto FIN : Endif
     Call FINREP(0) From TRTPCE
    Endif
    If I=1 : Close Local File [TB1] : Endif
    If K=1 : Close Local File [TB2] : Endif
    Raz I,K

   ## Ligne de provision
    Read [GAD]GAD0 = [L]PCEAUTO;4
   ## Ouverture des tables liées
    # Table secondaire
    Onerrgo ERREUR
    Local File =[F:GAD]LINTBL1 [TB1] : I=1
    Onerrgo
    If ERR : MESSA = [F:GAD]LINTBL1 : STAT = 6 : Goto FIN : Endif
    # Table analytique
    Onerrgo ERREUR
    Local File =[F:GAD]LINTBL2 [TB2] : K=1
    Onerrgo
    If ERR : MESSA = [F:GAD]LINTBL2 : STAT = 7 : Goto FIN : Endif

    # Création des lignes
    [M:HAE2]ACC1(1) = [L]GACPVS
    Call LIGNE(1,"",STAT,MESSA) From TRTPCE
    If STAT : Goto FIN : Endif
    Read [GAG]GAG0 = [L]PCEAUTO;4;"SNS"
    If evalue([F:GAG]FORCLC)>0
     [M:HAE2]DEB(1) = MONTANT
     [M:HAE2]CDT(1) = 0
    Else
     [M:HAE2]CDT(1) = MONTANT
     [M:HAE2]DEB(1) = 0
    Endif
    [M:HAE2]QTY(1) = TAQTY

    # Ventilation analytique
    If [M:HAE2]DSP(1)=""
     For [TB2] Where evalue(CRITTRS)
      Call LIGANA(1,STAT,MESSA) From TRTPCE
      If STAT : Break : Endif
     Next
     If STAT : Goto FIN : Endif
     Call FINREP(1) From TRTPCE
    Endif
    If I=1 : Close Local File [TB1] : Endif
    If K=1 : Close Local File [TB2] : Endif
    Raz I,K

    [M:HAE2]NBLIG = 2
    If dim([M]DOEPTR)>0 : [M]DOEPTR([M:HAE2]NBLIG-1) = 1 : Endif


    # Validation pièce
    Call CONTROLE(STAT,MESSA) From CPTBATCH
    If GOK<1 or STAT : Goto FIN : Endif
    #*X3-39795 Call VALPIECE(STAT,MESSA) From CPTBATCH
    Local Char    TZONE(10)(1..10) : # Table of the zones to be forced (Ex: ORICOD)   #*X3-39795
    Local Char    TVAL(30)(1..10)  : # Table of values for zones to be forced          #*X3-39795
    TZONE(5)= "ORIGIN" : TVAL(5)= "2"        :#Automatic loading  # X3-39795
    TZONE(6)= "ORICOD" : TVAL(6)= "CPTTRS"                        # X3-39795
    Call VALPIECE2(STAT,MESSA,TZONE,TVAL) From CPTBATCH
    If GOK<1 or STAT : Goto FIN : Endif
    If GTRACE<>"" :  Call ECR_TRACE(mess(150,117,1)-":"-GTYPPCE-GNUMPCE,0) From GESECRAN   : Endif     # Transfert compte
Next
Return

#################################
$MNT_QTY
#################################
###### MONTANT ##################
## Positionnement sur la devise (utile pour arrondi)
Call LECTURE("TCU",[M:HAE1]CUR,"") From CONTOBJ
## Calcul montant de base
# Bug 16528 : On doit donner la possibilité de paramètrer le montant
Read [GAG]GAG0=[L]PCEAUTO;1;"AMT"
If !fstat : BASE=evalue([F:GAG]FORCLC) Else BASE=[F:TB0]AMTNOTLIN : Endif
MONTANT = arr((BASE+CUMMNT)/NBPRT,[F:TCU]CURRND)-
&         arr(CUMMNT/NBPRT,[F:TCU]CURRND)
CUMMNT += BASE
###### QUANTITE ##################
## Calcul de la quantité
## Recherche de l'arrondi sur quantité
# Bug 10 143 : Pas la même désignation pour unité d'oeuvre pour la pièce KIK3 : facturation vente.
Raz STAT
If dim([F:TB0]UOM) > 0
    Call LECTURE("TUN",[F:TB0]UOM,"") From CONTOBJ
Elsif dim([F:TB0]SAU) > 0
    Call LECTURE("TUN",[F:TB0]SAU,"") From CONTOBJ
Else
    MESSA=mess(51,15,1)-mess(20,117,1)   # Unité d'oeuvre inexistante
    STAT=99 : Return
Endif
# Bug 16528 : On doit donner la possibilité de paramètrer la quantité
If dim([F:TB0]QTY) > 0
  Read [GAG]GAG0=[L]PCEAUTO;1;"QTY"
  If !fstat : BASE=evalue([F:GAG]FORCLC) Else BASE=[F:TB0]QTY : Endif
  TAQTY = arr((BASE+CUMQTY)/NBPRT,10^-[F:TUN]UOMDEC)-
&         arr(CUMQTY/NBPRT,10^-[F:TUN]UOMDEC)
  CUMQTY += BASE
Elsif dim([F:TB0]QTYUOM) > 0
  Read [GAG]GAG0=[L]PCEAUTO;1;"QTY"
  If !fstat : BASE=evalue([F:GAG]FORCLC) Else BASE=[F:TB0]QTYUOM : Endif
  TAQTY = arr((BASE+CUMQTY)/NBPRT,10^-[F:TUN]UOMDEC)-
&         arr(CUMQTY/NBPRT,10^-[F:TUN]UOMDEC)
  CUMQTY += BASE
Else
    MESSA=mess(33,105,1)-mess(20,117,1)   # Quantité inexistante
    STAT=99 : Return
Endif
Return

#################################
$FIN
#################################
If STAT
   Gosub MESSAGE  From CPTAUTO
   MESSA = mess(69,103,1)-":"-MESSA   : # Prestations
   GMESSAGE = MESSA-"("+num$(STAT)+")"
   GOK = 2
Endif
End

#################################
$ERREUR
#################################
ERR = errn
Resume
Return


###############################################################################################
#      Calcul des périodicités
###############################################################################################
Subprog INCDATE(OLDDAT,NEWDAT,INIDAT,NPERIO,UPERIO)
Variable Date    OLDDAT
Variable Date    NEWDAT
Variable Date    INIDAT
Value    Integer NPERIO
Value    Integer UPERIO

Local Integer I , J

Case UPERIO
 When 1 : # Jour
  NEWDAT = OLDDAT+NPERIO
 When 2 : # Semaine
  NEWDAT = OLDDAT+7*NPERIO
 When 3 : # Décade
  For I=1 To NPERIO
   J = day(OLDDAT)
   If    J<=10
    NEWDAT = OLDDAT+10
   Elsif J<=20
    NEWDAT = OLDDAT+10
    If month(NEWDAT)<>month(OLDDAT)
     NEWDAT = eomonth(OLDDAT)
    Endif
   Else
    J = mod(day(INIDAT),10)
    If J=0 : J = 10 : Endif
    NEWDAT = gdat$(J,month(OLDDAT)+1,year(OLDDAT))
   Endif
   OLDDAT = NEWDAT
  Next I
 When 4 : # Quinzaine
  For I=1 To NPERIO
   J = day(OLDDAT)
   If    J<=15
    NEWDAT = OLDDAT+15
    If month(NEWDAT)<>month(OLDDAT)
     NEWDAT = eomonth(OLDDAT)
    Endif
   Else
    J = mod(day(INIDAT),15)
    If J=0 : J = 15 : Endif
    NEWDAT = gdat$(J,month(OLDDAT)+1,year(OLDDAT))
   Endif
   OLDDAT = NEWDAT
  Next I
 When 5 : # Mois
  NEWDAT = addmonth(OLDDAT,NPERIO)
  If OLDDAT=eomonth(OLDDAT)
   NEWDAT = eomonth(NEWDAT)
  Endif
Endcase
End

#################################################
## Zoom sur les pièces analytique              ##
#################################################
$SEL_TABLE
Case GACTION
 When "CPTTRS"
    Onerrgo ERREUR From CONTROLE
    If clalev([F:HAE])=0 : Local File GACCENTRY [HAE] : Endif
    Onerrgo
    If GERREUR : GERREUR=0 : Return : Endif

    Local Integer MAXPCE, NBTEX : MAXPCE=100 : Raz NBTEX
    Local Char    TEX1(GLONGTE+GLONVCR+1)(1..MAXPCE), TEX2(30)(1..MAXPCE), TEX3(30)(1..MAXPCE)
    Local Integer TEX4(1..MAXPCE)

    For [HAE]HAE5 Where REFINT="TR"+PARAM(1)+PARAM(2)
        If NBTEX=MAXPCE : Break : Endif
        NBTEX += 1
        TEX4(NBTEX) = NBTEX
        TEX1(NBTEX) = [F:HAE]TYP-[F:HAE]NUM
        TEX2(NBTEX) = format$("DD[/]MM[/]YYYY",[F:HAE]ACCDAT)
        TEX3(NBTEX) = [F:HAE]DESVCR
    Next
    GMESSAGE=""

    If clalev([F:ZZZ])<>0 : Close Local File [ZZZ]  : Endif    # CP 10/05/01
    OK=1 # CP 17/05/01

    If NBTEX
        Local File (Char AA(GLONGTE+GLONVCR+1), Char BB(30), Char CC(30), Integer NUM)
&             From Variable TEX1(1..NBTEX), TEX2(1..NBTEX), TEX3(1..NBTEX), TEX4(1..NBTEX) As [ZZZ]
        COL(1)="AA"
        COL(2)="BB"
        COL(3)="CC"
        NBCOL = 3

        TIT(1) = mess(11,105,1)  : # Numéro de pièce
        TIT(2) = mess(14,105,1)  : # Date comptable
        TIT(3) = mess(36,105,1)  : # Libellé
        ORDRE  = "NUM"
        Call TITOBJ("GAS","!",TIT) From CONTOBJ
    Else  : # Pas de pièce générée
        OK=0
    Endif
 Endcase
Return

#################################
$AVANT_SUITE
#################################
If BOUT="2" : # Pièce analytique
 I=instr(1,VALBOUT," ")
 If !I
  OK=0
 Else
  [L]VALC1="GAS" : [L]VALC3=left$(VALBOUT,I-1) : [L]VALC2=right$(VALBOUT,I+1)
  GCONSULT=1
 Endif
Endif
Return

