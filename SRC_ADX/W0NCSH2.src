#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque NCSH2 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone NCSROOCAU
mkstat = 0
zoncou = "NCSROOCAU"
indice = 0
If varinit([M]NCSROOCAU,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]NCSROOCAU,"803","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]NCSROOCAU,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "NCSROOCAU" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]NCSROOCAU,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "NCSROOCAU" : GZNUM = 54865 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]NCSROOCAU,"803","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NCSROOCAU" : GZNUM = 54865 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]NCSROOCAU,"803",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "NCSROOCAU" : GZNUM = 54865 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone NCSREASON
mkstat = 0
zoncou = "NCSREASON"
indice = 0
If varinit([M]NCSREASON,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]NCSREASON,"802","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]NCSREASON,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "NCSREASON" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]NCSREASON,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "NCSREASON" : GZNUM = 2675 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]NCSREASON,"802","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NCSREASON" : GZNUM = 2675 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]NCSREASON,"802",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "NCSREASON" : GZNUM = 2675 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone SEVERITY
mkstat = 0
zoncou = "SEVERITY"
indice = 0
IMPENT = [M]SEVERITY
If varinit([M]SEVERITY,indice)=0
 IMPENT = 1
Endif
If varmode([M]SEVERITY,indice)=0
 Call INICOMBO(2030) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_SEVERITY(IMPENT) From SUBNCSH
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,2030,1))))
 Endif
 [M]SEVERITY(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SEVERITY" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SEVERITY(indice)
 Endif
 If !mkstat
  If IMPENT=0
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "SEVERITY" : GZNUM = 20701 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
    mkstat = 1 : GMESSAGE = mess(99,123,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "SEVERITY" : GZNUM = 20701 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]SEVERITY = IMPENT

## Zone IMPACT
mkstat = 0
zoncou = "IMPACT"
indice = 0
IMPENT = [M]IMPACT
If varinit([M]IMPACT,indice)=0
 IMPENT = 1
Endif
If varmode([M]IMPACT,indice)=0
 Call INICOMBO(2031) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_IMPACT(IMPENT) From SUBNCSH
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,2031,1))))
 Endif
 [M]IMPACT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "IMPACT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]IMPACT(indice)
 Endif
 If !mkstat
  If IMPENT=0
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "IMPACT" : GZNUM = 54154 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
    mkstat = 1 : GMESSAGE = mess(99,123,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "IMPACT" : GZNUM = 54154 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]IMPACT = IMPENT

## Zone DATEREQ
mkstat = 0
zoncou = "DATEREQ"
indice = 0
If varmode([M]DATEREQ,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DATEREQ" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone NCSPLANNER
mkstat = 0
zoncou = "NCSPLANNER"
indice = 0
If varmode([M]NCSPLANNER,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NCSPLANNER([M]NCSPLANNER) From SUBNCSH
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NCSPLANNER : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NCSPLANNER" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  Call CONTROLE("AUS","!",[M]NCSPLANNER,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "NCSPLANNER" : GZNUM = 9996 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_NCSPLANNER([M]NCSPLANNER) From SUBNCSH
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NCSPLANNER" : GZNUM = 9996 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone NCSMANAGER
mkstat = 0
zoncou = "NCSMANAGER"
indice = 0
If varmode([M]NCSMANAGER,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NCSMANAGER([M]NCSMANAGER) From SUBNCSH
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NCSMANAGER : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NCSMANAGER" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]NCSMANAGER,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "NCSMANAGER" : GZNUM = 54345 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("AUS","",[M]NCSMANAGER,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "NCSMANAGER" : GZNUM = 54345 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBLIG2
mkstat = 0
zoncou = "NBLIG2"
indice = 0
status = 1
zoncou = "NBLIG2"
If varmode([M]NBLIG2,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG2" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG2
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG2 = nolign
   status = 75
   Call SAI_NBLIG2(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBLIG2 From SUBNCSH
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBLIG2" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call AP_NBLIG2 From SUBNCSH
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NBLIG2" : GZNUM = 0 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBLIG2(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG2
mkstat = 0
zoncou = "NBLIG2"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBLIG2 From SUBNCSH
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBLIG2" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone NCSAPPUSR
mkstat = 0
zoncou = "NCSAPPUSR"
WCHAR = [M]NCSAPPUSR(indice)
If varmode([M]NCSAPPUSR,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NCSAPPUSR([M]NCSAPPUSR(indice)) From SUBNCSH
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NCSAPPUSR(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NCSAPPUSR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  Call CONTROLE("AUS","!",[M]NCSAPPUSR(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "NCSAPPUSR" : GZNUM = 52578 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_NCSAPPUSR([M]NCSAPPUSR(indice)) From SUBNCSH
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NCSAPPUSR" : GZNUM = 52578 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]NCSAPPUSR(indice) or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_NCSAPPUSR([M]NCSAPPUSR(indice)) From SUBNCSH
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "NCSAPPUSR" : GZNUM = 52578 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone TRANSTYPE
mkstat = 0
zoncou = "TRANSTYPE"
WCHAR = [M]TRANSTYPE(indice)
If varinit([M]TRANSTYPE,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]TRANSTYPE(indice),"807","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]TRANSTYPE,indice)=0
  SAVACT = GACTION : GACTION = "STD"
  Call AS_TRANSTYPE([M]TRANSTYPE(indice)) From SUBNCSH
  GACTION = SAVACT
  If mkstat=1 : Raz [M]TRANSTYPE(indice) : Endif
  If !mkstat
   IMPMOD = 0 : IMPZON = "TRANSTYPE" : Gosub ACTION From =IMPTRT
  Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]TRANSTYPE(indice),"807","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "TRANSTYPE" : GZNUM = 3209 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","!",[M]TRANSTYPE(indice),"807",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "TRANSTYPE" : GZNUM = 3209 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "STD"
     Call C_TRANSTYPE([M]TRANSTYPE(indice)) From SUBNCSH
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "TRANSTYPE" : GZNUM = 3209 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      If WCHAR<>[M]TRANSTYPE(indice) or IMPMOD
       SAVACT = GACTION : GACTION = "STD"
       Call AM_TRANSTYPE([M]TRANSTYPE(indice)) From SUBNCSH
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "TRANSTYPE" : GZNUM = 3209 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone APPRSTAT
mkstat = 0
zoncou = "APPRSTAT"
IMPENT = [M]APPRSTAT(indice)
WNUM = IMPENT
If varinit([M]APPRSTAT,indice)=0
 IMPENT = 1
Endif
If varmode([M]APPRSTAT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_APPRSTAT(IMPENT) From SUBNCSH
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]APPRSTAT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "APPRSTAT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]APPRSTAT(indice)
 Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_APPRSTAT(IMPENT) From SUBNCSH
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "APPRSTAT" : GZNUM = 52454 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]APPRSTAT(indice) = IMPENT

## Zone APPRREASON
mkstat = 0
zoncou = "APPRREASON"
WCHAR = [M]APPRREASON(indice)
If varmode([M]APPRREASON,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_APPRREASON([M]APPRREASON(indice)) From SUBNCSH
 GACTION = SAVACT
 If mkstat=1 : Raz [M]APPRREASON(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "APPRREASON" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_APPRREASON([M]APPRREASON(indice)) From SUBNCSH
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "APPRREASON" : GZNUM = 2675 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]APPRREASON(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_APPRREASON([M]APPRREASON(indice)) From SUBNCSH
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "APPRREASON" : GZNUM = 2675 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone NBLIG2
mkstat = 0
zoncou = "NBLIG2"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "NCSH2"
Return

