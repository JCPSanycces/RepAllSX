#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ITCMATCHM 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_VARAMT
Onevent AFTER_CHANGE Gosub AMM_VARAMT From W2ITCMATCHM
Return

$AMM_VARAMT
Call AM_VARAMT(zc)
If !mkstat & GOBJET
 zoncou = "VARAMT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_VARAMT(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_VARAMT(VALEUR) From SUBICMM
If mkstat : GERR = 1 : GZONE = "VARAMT" : GZNUM = 3603 : Endif
Gosub _AFF
End

$ON_MATFLG
Onevent INIT_AREA Call D_MATFLG(zc) From W2ITCMATCHM
Onevent BEFORE_INPUT Call AS_MATFLG(zc) From W2ITCMATCHM
Return

Subprog D_MATFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]MATFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_MATFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

