######################################################################################
Subprog AM_STR1(VALEUR)
Variable Date    VALEUR
If nolign = 1
  Case [M:HRPEO0]PAYFRQ
    When 1 : [M:HRPEO1]END1(nolign-1) = [M:HRPEO1]STR1(nolign-1)+6
    When 2 : [M:HRPEO1]END1(nolign-1) = gdat$(15,month([M:HRPEO1]STR1(nolign-1)),year(addmonth([M:HRPEO1]STR1(nolign-1),1)))
    When 3 : [M:HRPEO1]END1(nolign-1) = [M:HRPEO1]STR1(nolign-1)+13
    When 6 : [M:HRPEO1]END1(nolign-1) = eomonth([M:HRPEO1]STR1(nolign-1))
  Endcase
Endif

If [M:HRPEO1]END1(nolign-1) <> [00/00/00]
  [M]NBSEM(nolign-1) = ([M:HRPEO1]END1(nolign-1)-VALEUR+1)/7
  Affzo [M]NBSEM(nolign-1)
Endif

End

Subprog AM_END1(VALEUR)
Variable Date    VALEUR
If [M:HRPEO1]STR1(nolign-1) <> [00/00/00]
  [M]NBSEM(nolign-1) = (VALEUR-[M]STR1(nolign-1)+1)/7
  Affzo [M]NBSEM(nolign-1)
Endif
End

######################################################################################
## Section automatically added (screen HRPEO1) 09/24/2016 06:47:01 (JOJAC)
######################################################################################
Subprog AM_TAXMON(VALEUR)
Variable Decimal VALEUR
Local Integer PERINYEA
Local Integer DAYTOADD

If nolign > [M:HRPEO1]PERNUM
  If [M:HRPEO0]PAYFRQ = 1 : PERINYEA = nolign  : Endif
Else
  If [M:HRPEO0]PAYFRQ = 1 : PERINYEA = [M:HRPEO1]PERNUM  : Endif
Endif
[M:HRPEO1]TAXMON(nolign-1)=VALEUR
Affzo [M:HRPEO1]TAXMON(nolign-1)

For nolign = 2 To PERINYEA
  If [M:HRPEO1]TAXMON(nolign-1)= [M:HRPEO1]TAXMON(nolign-2)
    [M:HRPEO1]PERMON(nolign-1)=([M:HRPEO1]PERMON(nolign-2)+1)
  Else
    [M:HRPEO1]PERMON(nolign-1)=1
  Endif
Next
Gosub PERIODMONTH
Affzo [M:HRPEO1]20
End

