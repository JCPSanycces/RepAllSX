#DBA le 17/11/2004 : Bug 26592
######################################################################################
Subprog D_PYRDAT(VALEUR)
Variable Date    VALEUR
#JASMI - 2017-02-24 - START
If nolign>1
  If day([M]CYCSTRDAT) = 1
  #JOJAC - 2017-02-27 - START
    If [M:HRPEO0]PAYFRQ = 6
      VALEUR=eomonth(addmonth([M:HRPEO1]PYRDAT(nolign-2),1))
    Elsif [M:HRPEO0]PAYFRQ = 1
      VALEUR=[M:HRPEO1]PYRDAT(nolign-2)+7
    Endif
  Else
    If [M:HRPEO0]PAYFRQ = 6
      VALEUR=addmonth([M:HRPEO1]PYRDAT(nolign-2),1)
    Elsif [M:HRPEO0]PAYFRQ = 1
      VALEUR=[M:HRPEO1]PYRDAT(nolign-2)+7
    Endif
  Endif

  [M:HRPEO1]STA(nolign-1) = [M:HRPEO1]STA(0)
  [M:HRPEO1]TAXMON(nolign-1)=nolign
  #[M:HRPEO1]PERMON(nolign-1)=1

  #JOJAC - 2017-06-02 - START
  If [M:HRPEO0]PAYFRQ = 3
   VALEUR=[M:HRPEO1]PYRDAT(nolign-2)+14
  Endif
  #JOJAC - 2017-06-02 - END

Endif
#JASMI - 2017-02-24 - END
End

Funprog WEEKLY(FLDNAM)
Value Char FLDNAM
Local Date RETDAT
RETDAT = evalue("[M:HRPEO1]"+FLDNAM+"("+num$((nolign-2))+")+6")
End RETDAT

Subprog AM_PYRDAT(VALEUR)
Variable Date    VALEUR
If func AFNC.ACTIV("KFR") & func DIVPAYE.IS_KFR_LEG(GCURLEG) & [M:HRPEO0]PAYFRQ=6 |
&  func AFNC.ACTIV("KPO") & func DIVPAYE.IS_KPO_LEG(GCURLEG) & [M:HRPEO0]PAYFRQ=6
  If clalev([F:TIP])=0  : Local File TIMEMP    [TIP] : Endif
  #58640
  If GTPS
   If clalev([F:TIG])=0  : Local File TIMREGUL  [TIG] : Endif
  Endif
  If clalev([F:FCY])=0  : Local File FACILITY  [FCY] : Endif
  If clalev([F:HRPEO2])=0 : Local File HRPERIOD    [HRPEO2]: Endif
  Local Char CRITERE (100)
  Local Integer WOK

  CRITERE="1=1"
  If [M:HRPEO0]FCY<>"" : CRITERE="FCY='"+[M:HRPEO0]FCY+"'" : Endif
  For [F:FCY]FCY0 Where evalue(CRITERE)
  #JOJAC - START
  #Read[F:HRPEO2]HRPEO0=[M:HRPEO0]PERCOD;[F:FCY]FCY;[M:HRPEO1]PYRDAT(nolign-1)
   Read[F:HRPEO2]HRPEO3=[M:HRPEO0]PERCOD;[M:HRPEO1]PYRDAT(nolign-1)
  #JOJAC - END
   If fstat | [F:FCY]FCY=[M:HRPEO0]FCY
    Filter [F:TIP] Where [F:TIP]DATPYR=[M:HRPEO1]PYRDAT(nolign-1) & [F:TIP]FCY=[F:FCY]FCY
    Read [F:TIP]TIP0 First
    Filter [F:TIP]
    If !fstat
     #Evènements saisis à cette date de paie.
     WOK = 1: Call AVERTIR(mess(112,10709,1),WOK) From GESECRAN
     If WOK<>2 : mkstat=2  : Endif
     Break
    Else
     If GTPS
      #58744
      #Filter [TIG] Where [F:TIG]DATPYR=[M:HRPEO1]PYRDAT(nolign-1)
      Filter [TIG] Where [F:TIG]DATPYR=[M:HRPEO1]PYRDAT(nolign-1) & [F:TIG]FCY=[F:FCY]FCY
      Read[F:TIG]TIG0 First
      Filter [F:TIG]
      If !fstat
       #Evènements saisis à cette date de paie.
       WOK = 1 : Call AVERTIR(mess(112,10709,1),WOK) From GESECRAN
       If WOK<>2 : mkstat=2 : Endif
       Break
      Endif
     Endif
    Endif
   Endif
  Next
  If mkstat : End : Endif
Endif
End

