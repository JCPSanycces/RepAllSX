#JASMI - 2017-02-23 - END
    [M:HRPEO1]PYRDAT(0) = gdat$(15,month(VALEUR),year(addmonth(VALEUR,1)))
    #[M:HRPEO1]END1(0) = gdat$(15,month([M:HRPEO1]STR1(0)),year(addmonth([M:HRPEO1]STR1(0),1)))
    [M:HRPEO1]END2(0) = gdat$(15,month([M:HRPEO1]STR2(0)),year(addmonth([M:HRPEO1]STR2(0),1)))
    [M:HRPEO1]END3(0) = gdat$(15,month([M:HRPEO1]STR3(0)),year(addmonth([M:HRPEO1]STR3(0),1)))
    [M:HRPEO1]END3(0) = gdat$(15,month([M:HRPEO1]STR4(0)),year(addmonth([M:HRPEO1]STR4(0),1)))
    [M]NBSEM(0) = ([M]END1(0)-[M]STR1(0)+1)/7
  When 3
  #JOJAC - 2017-06-01 - START
  [M:HRPEO1]STR3(0)=VALEUR-14
    [M:HRPEO1]PYRDAT(0) = VALEUR+13
    [M:HRPEO1]END1(0) = [M:HRPEO1]STR1(0)+13
    [M:HRPEO1]END2(0) = [M:HRPEO1]STR2(0)+13
    [M:HRPEO1]END3(0) = [M:HRPEO1]STR3(0)+13
    [M:HRPEO1]END4(0) = [M:HRPEO1]STR4(0)+13
    [M]NBSEM(0) = ([M]END1(0)-[M]STR1(0)+1)/7
  #JOJAC - 2017-06-01 - END
##JASMI - 2017-02-23 - START
