######################################################################################
Subprog AM_END2(VALEUR)
Variable Date    VALEUR

If [M:HRPEO0]PAYFRQ=6
  If nolign > 1
    If [M:HRPEO1]CALMON(nolign-2) < 12
      [M:HRPEO1]CALMON(nolign-1) = [M:HRPEO1]CALMON(nolign-2)+1
    Else
      [M:HRPEO1]CALMON(nolign-1) = 1
    Endif
  Endif
Endif

If [M:HRPEO0]PAYFRQ=1
  If nolign > 1
    [M:HRPEO1]CALMON(nolign-1) = month([M:HRPEO1]END2(nolign-1))
  Endif
Endif

Affzo [M:HRPEO1]CALMON(nolign-1)

[M:HRPEO0]CYCENDDAT = VALEUR
Affzo [M:HRPEO0]CYCENDDAT

End


