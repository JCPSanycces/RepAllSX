Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

If clalev([F:FCY])=0 : Local File FACILITY [FCY]  : Endif
Read [FCY]FCY0 = VALEUR

GCURLEG = [F:FCY]LEG
[M:HRPEO0]CPY=[F:FCY]LEGCPY   : Affzo [M:HRPEO0]CPY
[M:HRPEO0]LEG=GCURLEG  : Affzo [M:HRPEO0]LEG

If VALEUR <> ""
  Grizo [M:HRPEO0]CPY
  Grizo [M:HRPEO0]LEG
Else
  Raz [M:HRPEO0]CPY : Affzo [M:HRPEO0]CPY
  Raz [M:HRPEO0]LEG : Affzo [M:HRPEO0]LEG
  Actzo [M:HRPEO0]CPY
  Actzo [M:HRPEO0]LEG
Endif
End

######################################################################################
## Section automatically added (screen HRPEO1) 09/29/2016 12:12:24 (JOJAC)
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Raz [M:HRPEO0]LEG : Affzo [M:HRPEO0]LEG

If clalev([F:CPY])=0 : Local File COMPANY [CPY]  : Endif
Read [CPY]CPY0 = VALEUR
If fstat
  End
Endif

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
GCURLEG = [F:CPY]LEG
[M:HRPEO0]LEG=GCURLEG  : Affzo [M:HRPEO0]LEG
Grizo [M:HRPEO0]LEG

If [M:HRPEO0]CPY = ""
  Actzo [M:HRPEO0]CPY
Endif
End

$SEL_TABLE
Case TABLE
  When "SELHRPEO"
    If clalev([F:HRPEOH])=0  :  Local File HRPEOHEA [HRPEOH]  :  Endif
    If clalev([F:HRPEOD])=0  :  Local File HRPEODET [HRPEOD]  :  Endif

#Link [HRPEOD] With [F:HRPEOH]HRPEOH0 = [HRPEOD]PERCOD;[HRPEOD]PERYEA As [LNK]
Default File [HRPEOH]
Call SELOBJ("HRPEO",OPTIONS,NBCOL,COL,TIT) From CONTOBJ
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRPEOH]FLGENA=2)',"&") From GOBJSUB
    #Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([LNK]FLGENA=2)',"&") From GOBJSUB
    If PARAM(1)<>""
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRPEOH]LEG="'+PARAM(1)+'"| [F:HRPEOH]LEG="")',"&") From GOBJSUB
    Endif
    If PARAM(2)<>""
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRPEOH]CPY="'+PARAM(2)+'"| [F:HRPEOH]CPY="")',"&") From GOBJSUB
    Endif
    If PARAM(3)<>""
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRPEOH]FCY="'+PARAM(3)+'"| [F:HRPEOH]FCY="")',"&") From GOBJSUB
    Endif
Endcase
Return

