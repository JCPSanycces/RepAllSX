# fin 55439
########################################
Subprog C_PERYEA(VALEUR)
Variable Decimal VALEUR
If VALEUR<1600
 GMESSAGE = mess(47,10709,1) : # Date incorrecte
 mkstat = 2 : End
Endif

Filter [F:HRPEOH] Where PERYEA < VALEUR & PERCOD = [M:HRPEO0]PERCOD
Read First
If fstat <> 4
  Filter [F:HRPEOH]
  Filter [F:HRPEOH] Where PERYEA = VALEUR-1 & PERCOD = [M:HRPEO0]PERCOD
  Read First
  If fstat = 4
    GERR=1
    GMESSAGE = mess(231,10709,1)
    mkstat=2
  Endif
Endif
Filter [F:HRPEOH]
End

Subprog D_STR1(VALEUR)
Variable Date    VALEUR
#JASMI - 2017-02-24 - START
If nolign>1
  VALEUR=[M:HRPEO1]END1(nolign-2)+1
Endif
#JASMI - 2017-02-24 - END
End

Subprog D_END1(VALEUR)
Variable Date    VALEUR
#JASMI - 2017-02-24 - START
If nolign>1
  [M:HRPEO1]STR2(nolign-1)=[M:HRPEO1]END2(nolign-2)+1
   #JOJAC - 2017-02-27 - START
  If [M:HRPEO0]PAYFRQ=6 #Monthly
    [M:HRPEO1]END2(nolign-1)=addmonth([M:HRPEO1]STR2(nolign-1),1)-1
  Elsif [M:HRPEO0]PAYFRQ=1 #Weekly
    [M:HRPEO1]END2(nolign-1)   =  ([M:HRPEO1]END2(nolign-2)+7)
  #JOJAC - 2017-06-01 - START
  Elsif [M:HRPEO0]PAYFRQ=3 #Bi-Weekly
    [M:HRPEO1]END2(nolign-1)   =  ([M:HRPEO1]END2(nolign-2)+14)
  #JOJAC - 2017-06-01 - END
  Endif
   #JOJAC - 2017-02-27 - START
  VALEUR = [M:HRPEO1]END2(nolign-1)-6
  Gosub FIN_SEMAINE
Endif
#JASMI - 2017-02-24 - END
#JOJAC - 2017-03-06 - START

#Calculation of calendar month
#Monthly Frequency
#If [M:HRPEO0]PAYFRQ=6
#  If nolign > 1
#    If [M:HRPEO1]CALMON(nolign-2) < 12
#      [M:HRPEO1]CALMON(nolign-1) = [M:HRPEO1]CALMON(nolign-2)+1
#    Else
#      [M:HRPEO1]CALMON(nolign-1) = 12
#    Endif
#  Endif
#Endif

#Weekly frequency
#If [M:HRPEO0]PAYFRQ=1
  If nolign > 1
    [M:HRPEO1]CALMON(nolign-1) = month([M:HRPEO1]END2(nolign-1))
  Endif
#Endif

#Calculation of taxmonth
If [M:HRPEO1]CALMON(nolign-1)= [M:HRPEO1]CALMON(nolign-2)
   [M:HRPEO1]TAXMON(nolign-1) = [M:HRPEO1]TAXMON(nolign-2)
Else
  [M:HRPEO1]TAXMON(nolign-1) = [M:HRPEO1]TAXMON(nolign-2)+1
Endif
#MIPEA - 2018-01-22- US X3-72537- START
#If nolign = 2 & [M:HRPEO1]TAXMON(nolign-1) <> 1 Then [M:HRPEO1]TAXMON(nolign-1) = 1 : Endif
#If nolign = 3 & [M:HRPEO1]TAXMON(nolign-1) <> 1 Then [M:HRPEO1]TAXMON(nolign-1) = 1 : Endif
#MIPEA - 2018-01-19- US X3-72537- END

If [M:HRPEO0]PAYFRQ = 1
  If nolign = 2 & [M:HRPEO1]TAXMON(nolign-1) <> 1 Then [M:HRPEO1]TAXMON(nolign-1) = 1 : Endif
  If nolign = 3 & [M:HRPEO1]TAXMON(nolign-1) <> 1 Then [M:HRPEO1]TAXMON(nolign-1) = 1 : Endif
Endif

If [M:HRPEO1]TAXMON(nolign-1) > 12 Then [M:HRPEO1]TAXMON(nolign-1) = 12 : Endif

#Calculation of period in month
If nolign>1
  If [M:HRPEO1]TAXMON(nolign-1)= [M:HRPEO1]TAXMON(nolign-2)
    [M:HRPEO1]PERMON(nolign-1)=([M:HRPEO1]PERMON(nolign-2)+1)
  Else
    [M:HRPEO1]PERMON(nolign-1)=1
  Endif
Endif

#Calculate period in month of total
Gosub PERIODMONTH

Affzo [M:HRPEO1]CALMON(nolign-1)
Affzo [M:HRPEO1]TAXMON(nolign-1)
Affzo [M]PERMON(nolign-1)
#JOJAC - 2017-03-06 - END
End

Subprog D_STR3(VALEUR)
Variable Date    VALEUR
#JASMI - 2017-02-24 - START
If nolign>1
  VALEUR=[M:HRPEO1]END3(nolign-2)+1
Endif
#JASMI - 2017-02-24 - END
End

$DEBUT_SEMAINE
Local Integer ANNEE , SEMAINE
Local Date    DATFIN
Call DAT(VALEUR,ANNEE,SEMAINE) From SUBPLN
Call SEMAINE(ANNEE,SEMAINE,VALEUR,DATFIN) From SUBPLN
Return

$FIN_SEMAINE
Local Integer ANNEE , SEMAINE
Local Date    DATDEB
Call DAT(VALEUR,ANNEE,SEMAINE) From SUBPLN
Call SEMAINE(ANNEE,SEMAINE,DATDEB,VALEUR) From SUBPLN
Return

Subprog C_STR1(VALEUR)
Variable Date    VALEUR
Variable Date SAV_VALEUR
#MIPEA - 2017-11-20- US X3-63170- START
If nolign = 1
  If VALEUR <> [0/0/0]
    GFIRDAY = dayn(VALEUR)
    [M:HRPEO0]FIRDAY = GFIRDAY
    Affzo [M:HRPEO0]FIRDAY
  Endif
Endif
#MIPEA - 2017-11-20- US X3-63170- END
If func AFNC.PARAM("WEEK",[M:HRPEO0]FCY)<>"1"
  Gosub DEBUT_SEMAINE
Endif

If nolign > 1
  If VALEUR <> ([M:HRPEO1]END1(nolign-2))+1
    #The date does not follow on the prior periods end date
    GMESSAGE=mess(234,10709,1)
    mkstat=2
  Endif
Endif
End

Subprog C_END1(VALEUR)
Variable Date    VALEUR
#JASMI - 2017-08-02 - X3-51105 - START
##JOJAC - 2017-02-14 - START
#If func AFNC.PARAM("WEEK",[M:HRPEO0]FCY)<>"1"
#  Gosub FIN_SEMAINE
#  If mkstat : End : Endif
#  If VALEUR-[M]STR1(nolign-1)>42
#   GMESSAGE = mess(13,10709,1) : # Pas plus de 6 semaines
#   mkstat = 2 : End
#  Endif
#  [M]NBSEM(nolign-1) = (VALEUR-[M]STR1(nolign-1)+1)/7
#Endif
##JOJAC - 2017-02-14 - END
#
#If func AFNC.PARAM("WEEK",[M:HRPEO0]FCY)<>"1"
#  Gosub FIN_SEMAINE
#  If mkstat : End : Endif
#  If VALEUR-[M]STR1(nolign-1)>42
#   GMESSAGE = mess(13,10709,1) : # Pas plus de 6 semaines
#   mkstat = 2 : End
#  Endif
#  [M]NBSEM(nolign-1) = (VALEUR-[M]STR1(nolign-1)+1)/7
#Endif
##Endif
##MIPEA - 2017-02-13- X3-11322- END
#JASMI - 2017-08-02 - X3-51105 - END

#JOJAC - 2016-09-19 - X3PEOP-1193 - END
#MIPEA - 2017-02-13- X3-11322- START
Case [M]PAYFRQ
  When 1
    If VALEUR-[M]STR1(nolign-1)>=7
#JASMI - 2017-08-02 - X3-50811 - START
#      GMESSAGE = mess(210,10709,1)
      GMESSAGE = func AFNC.MES1(mess(210,10709,1),"7")
#JASMI - 2017-08-02 - X3-50811 - END
      mkstat=2 :
    Endif
  When 3
    If VALEUR-[M]STR1(nolign-1)>=14
#JASMI - 2017-08-02 - X3-50811 - START
#      GMESSAGE = mess(211,10709,1)
      GMESSAGE = func AFNC.MES1(mess(210,10709,1),"14")
#JASMI - 2017-08-02 - X3-50811 - END
      mkstat=2 :
    Endif
#JASMI - 2017-08-02 - X3-51105 - START
  When 6
    If func AFNC.PARAM("WEEK",[M:HRPEO0]FCY)<>"1"
      Gosub FIN_SEMAINE
      If mkstat : End : Endif
      If VALEUR-[M]STR1(nolign-1)>42
       GMESSAGE = mess(13,10709,1) : # Pas plus de 6 semaines
       mkstat = 2 : End
      Endif
      [M]NBSEM(nolign-1) = (VALEUR-[M]STR1(nolign-1)+1)/7
    Endif
#JASMI - 2017-08-02 - X3-51105 - END
Endcase
#MIPEA - 2017-02-13- X3-11322- end
#JOJAC - 2016-09-19 - X3PEOP-1193 - END
End

Subprog C_END2(VALEUR)
Variable Date    VALEUR

If [M:HRPEO0]PAYFRQ = 1
  If VALEUR > [M:HRPEO1]STR2(nolign-1)+6
    GMESSAGE = mess(237,10709,1)-format$("D:"+GFMDAT,[M]STR2(nolign-1)+6)
    mkstat=2
  Endif
Endif

If [M:HRPEO0]PAYFRQ = 6
  If VALEUR > (addmonth([M:HRPEO1]STR2(nolign-1),1))-1
    GMESSAGE = mess(237,10709,1)-format$("D:"+GFMDAT,(addmonth([M]STR2(nolign-1),1))-1)
    mkstat=2
  Endif
Endif
End

Subprog C_STR2(VALEUR)
Variable Date    VALEUR
Local    Integer FLGCTL
Local Date STRDAT
Local Integer CURYEA
Local Date TAXYEA
Local Integer DAYDIF

If GCURLEG = 'ZAF'
  STRDAT = VALEUR
  CURYEA = year(STRDAT)
  TAXYEAR = gdat$(1,03,CURYEA)
  DAYDIFF = TAXYEAR - VALEUR
#
#  If DAYDIFF > 13 or DAYDIFF < -13
#    GMESSAGE = mess(211,10709,1)
#    mkstat=2
#  Endif
#JOJAC - 2016-09-19 - X3PEOP-1193 - END
#  Case [M:HRPEO0]PAYFRQ
#    When 1
