######################################################################################
Subprog C_TAXMON(VALEUR)
Variable Decimal VALEUR
If VALEUR < 1 | VALEUR > 12
  GMESSAGE = mess(214,10709,1)
  mkstat = 2
Endif

If nolign > 1
  If VALEUR - [M:HRPEO1]TAXMON(nolign-2) > 1 | VALEUR - [M:HRPEO1]TAXMON(nolign-2) < 0 | VALEUR < [M:HRPEO1]TAXMON(nolign-2)
    GMESSAGE = mess(215,10709,1)
    mkstat=2
  Endif
Endif
End

