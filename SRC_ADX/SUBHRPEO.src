Subprog CONTHRPEO(VALEUR)
Variable Char VALEUR
If clalev([HRPEOH]) = 0 :  Local File HRPEOHEA [HRPEOH] : Endif
If VALEUR <> ""
  Filter [F:HRPEOH] Where PERCOD=VALEUR
  Read [F:HRPEOH] First
  Filter [F:HRPEOH]
  If fstat
      GMESSAGE = VALEUR-":"-mess(23,100,1)
      mkstat = 2 : End
  #JOJAC - 2017-05-09 - X3-28374 - START
  #Else
  Elsif GCURLEG <> ""
  #JOJAC - 2017-05-09 - X3-28374 - END
      Filter [F:HRPEOH] Where PERCOD=VALEUR & LEG=GCURLEG
      Read [F:HRPEOH] First
      Filter [F:HRPEOH]
      If fstat
        GMESSAGE = VALEUR-":"-mess(62,127,1)-":"-[F:HRPEOH]LEG
        mkstat = 2 : End
      Endif
  Endif
Endif
Filter [F:HRPEOH]
End

