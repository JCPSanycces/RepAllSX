Variable Decimal VALEUR
If VALEUR = [M:HRPEO0]PERYEA + 1
  [M:HRPEO0]CYCSTRDAT = ([M:HRPEO0]CYCENDDAT)+1
  Affzo [M:HRPEO0]CYCSTRDAT
Else
  Effzo [M:HRPEO0]CYCSTRDAT
