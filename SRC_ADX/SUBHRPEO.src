#JOJAC - 2016-09-19 - X3PEOP-1193 - START
Subprog FREQUENCY
Local Integer PERINYEA # Periods in year
Local Integer DAYTOADD # Days to add
Local Integer YESNO : YESNO = 2 :#YES
Local Date PERTEST
Local Date PERDAY
Local Date SAV_CYCENDDAT

If [M:HRPEO1]STR1 = "00/00/00"
  Call AM_CYCSTRDAT([M:HRPEO0]CYCSTRDAT)
Endif

[M:HRPEO1]PERNUM=1

#WEEKLY
If [M:HRPEO0]PAYFRQ = 1
  If GCURLEG <> 'BRI'
    Call OUINON(mess(212,10709,1), YESNO) From GESECRAN
    If YESNO = 1
      PERINYEA = 52
    Else
      PERINYEA = 53
    Endif
  Else
    PERINYEA = 52
  Endif
    #DAYTOADD = 7  :
    Gosub CALCULPER
Endif

#BI-MONTHLY
If [M:HRPEO0]PAYFRQ = 2 : PERINYEA = 24 : Gosub CALCULBM  : Endif

#FORTNIGHTLY
If [M:HRPEO0]PAYFRQ = 3
  #Call OUINON("Do you want to create 27 periods", YESNO) From GESECRAN
  Call OUINON(mess(213,10709,1), YESNO) From GESECRAN
  If YESNO = 1
    PERINYEA = 26
  Else
    PERINYEA = 27
  Endif
  DAYTOADD = 14  : Gosub CALCULPER
Endif  #WEEKLY

If [M:HRPEO0]PAYFRQ = 4 : PERINYEA = 13 : DAYTOADD = 28 : Gosub CALCULPER : Endif  #4-WEEKLY
If [M:HRPEO0]PAYFRQ = 5 : PERINYEA = 4  : DAYTOADD = 4   : Gosub CALCULQUA : Endif
If [M:HRPEO0]PAYFRQ = 6 : PERINYEA = 12 : DAYTOADD = 6 : Gosub CALCULANN : Endif  #MONTHLY
Affzo [M:HRPEO0]CYCENDDAT

#If GCURLEG = 'ZAF' & ([M:HRPEO0]PAYFRQ = 1 | [M:HRPEO0]PAYFRQ = 6)
#  If day([M:HRPEO0]CYCENDDAT) > 7 & month([M:HRPEO0]CYCENDDAT) > 2
#    GERR=2
#    GMESSAGE = mess(230,10709,1)
#    SAV_CYCENDDAT = [M:HRPEO0]CYCENDDAT
#    Raz [M:HRPEO0]CYCENDDAT : Affzo [M:HRPEO0]CYCENDDAT
#    Raz [M:HRPEO1] : Affzo [M:HRPEO1]
#    zonsui = "[M:HRPEO0]CYCSTRDAT"
#    End
#  Endif
#Endif

GERR = 2
GMESSAGE = mess(239,10709,1)

#mkstat = 4
Affzo [M:HRPEO1]20



End

$CALCULPER
For nolign = 2 To (PERINYEA)
Next

[M:HRPEO1]PERNUM=(nolign-1)
Affzo [M:HRPEO1]20



Return

$CALCULBM #bi-monthly
For nolign = 2 To 23
  If mod(nolign,2) = 0 #EVEN 16 to eomonth
    [M:HRPEO1]STA(nolign-1) = [M:HRPEO1]STA(0)
    [M:HRPEO1]STR1(nolign-1)=gdat$(16,month([M:HRPEO1]END1(nolign-2)),year([M:HRPEO1]END1(nolign-2)))
    [M:HRPEO1]END1(nolign-1)=eomonth(gdat$(1,month([M:HRPEO1]STR1(nolign-2)),year([M:HRPEO1]STR1(nolign-2))))
    [M:HRPEO1]STR2(nolign-1)=gdat$(16,month([M:HRPEO1]END2(nolign-2)),year([M:HRPEO1]END2(nolign-2)))
    [M:HRPEO1]END2(nolign-1)=eomonth(gdat$(1,month([M:HRPEO1]STR2(nolign-2)),year([M:HRPEO1]STR2(nolign-2))))
    [M:HRPEO1]STR3(nolign-1)=gdat$(16,month([M:HRPEO1]END3(nolign-2)),year([M:HRPEO1]END3(nolign-2)))
    [M:HRPEO1]END3(nolign-1)=eomonth(gdat$(1,month([M:HRPEO1]STR3(nolign-2)),year([M:HRPEO1]STR3(nolign-2))))
    [M:HRPEO1]STR4(nolign-1)=gdat$(16,month([M:HRPEO1]END4(nolign-2)),year([M:HRPEO1]END4(nolign-2)))
    [M:HRPEO1]END4(nolign-1)=eomonth(gdat$(1,month([M:HRPEO1]STR4(nolign-2)),year([M:HRPEO1]STR4(nolign-2))))
    [M:HRPEO1]PYRDAT(nolign-1)=eomonth(gdat$(1,month([M:HRPEO1]PYRDAT(nolign-2)),year([M:HRPEO1]PYRDAT(nolign-2))))
#      [M:HRPEO1]PERNUM(nolign-1) = nolign
  Else #UNEVEN 1 to 15 addmonth
    [M:HRPEO1]STA(nolign-1) = [M:HRPEO1]STA(0)
    [M:HRPEO1]STR1(nolign-1)    = gdat$(1,month(addmonth([M:HRPEO1]END1(nolign-2),1)),year(addmonth([M:HRPEO1]END1(nolign-2),1)))
    [M:HRPEO1]END1(nolign-1)    = gdat$(15,month([M:HRPEO1]STR1(nolign-1)),year([M:HRPEO1]STR1(nolign-1)))
    [M:HRPEO1]STR2(nolign-1)    = gdat$(1,month(addmonth([M:HRPEO1]END2(nolign-2),1)),year(addmonth([M:HRPEO1]END2(nolign-2),1)))
    [M:HRPEO1]END2(nolign-1)    = gdat$(15,month([M:HRPEO1]STR2(nolign-1)),year([M:HRPEO1]STR2(nolign-1)))
    [M:HRPEO1]STR3(nolign-1)    = gdat$(1,month(addmonth([M:HRPEO1]END3(nolign-2),1)),year(addmonth([M:HRPEO1]END3(nolign-2),1)))
    [M:HRPEO1]END3(nolign-1)    = gdat$(15,month([M:HRPEO1]STR3(nolign-1)),year([M:HRPEO1]STR3(nolign-1)))
    [M:HRPEO1]STR4(nolign-1)    = gdat$(1,month(addmonth([M:HRPEO1]END4(nolign-2),1)),year(addmonth([M:HRPEO1]END4(nolign-2),1)))
    [M:HRPEO1]END4(nolign-1)    = gdat$(15,month([M:HRPEO1]STR4(nolign-1)),year([M:HRPEO1]STR4(nolign-1)))
    [M:HRPEO1]PYRDAT(nolign-1)  = gdat$(15,month([M:HRPEO1]PYRDAT(nolign-2)),year(addmonth([M:HRPEO1]PYRDAT(nolign-2),1)))
#      [M:HRPEO1]PERNUM(nolign-1) = nolign
  Endif
  #Gosub PERMONTH
Next

Gosub PERIODMONTH
[M:HRPEO1]PERNUM=nolign+1
Affzo [M:HRPEO1]20
Return

$CALCULQUA
For nolign = 2 To 4
  [M:HRPEO1]PYRDAT(nolign-1)=eomonth(addmonth([M:HRPEO1]PYRDAT(nolign-2),3))
  [M:HRPEO1]STR1(nolign-1)=gdat$(1,month(addmonth([M:HRPEO1]END1(nolign-2),1)),year(addmonth([M:HRPEO1]END1(nolign-2),1)))
  [M:HRPEO1]END1(nolign-1)=eomonth(addmonth([M:HRPEO1]END1(nolign-2),3))
  [M:HRPEO1]STR2(nolign-1)=gdat$(1,month(addmonth([M:HRPEO1]END2(nolign-2),1)),year(addmonth([M:HRPEO1]END2(nolign-2),1)))
  [M:HRPEO1]END2(nolign-1)=eomonth(addmonth([M:HRPEO1]END2(nolign-2),3))
  [M:HRPEO1]STR3(nolign-1)=gdat$(1,month(addmonth([M:HRPEO1]END3(nolign-2),1)),year(addmonth([M:HRPEO1]END3(nolign-2),1)))
  [M:HRPEO1]END3(nolign-1)=eomonth(addmonth([M:HRPEO1]END3(nolign-2),3))
  [M:HRPEO1]STR4(nolign-1)=gdat$(1,month(addmonth([M:HRPEO1]END4(nolign-2),1)),year(addmonth([M:HRPEO1]END4(nolign-2),1)))
  [M:HRPEO1]END4(nolign-1)=eomonth(addmonth([M:HRPEO1]END4(nolign-2),3))
Next

[M:HRPEO1]PERNUM=nolign-1
Affzo [M:HRPEO1]20
Return

$CALCULANN

For nolign = 2 To 12
Next

[M:HRPEO1]PERNUM=nolign-1
nolign=12
Affzo [M:HRPEO1]20

Return

$PERMONTH
#Calculate calendar month
[M:HRPEO1]CALMON(nolign-1)=month([M:HRPEO1]END2(nolign-1))
#Calculate tax month
If [M:HRPEO0]PAYFRQ = 6
  If [M:HRPEO1]CALMON(nolign-1)= [M:HRPEO1]CALMON(nolign-2)
    [M:HRPEO1]TAXMON(nolign-1)=([M:HRPEO1]TAXMON(nolign-2))
  Else
    [M:HRPEO1]TAXMON(nolign-1)=([M:HRPEO1]TAXMON(nolign-2)+1)
  Endif
Else
  [M:HRPEO1]TAXMON(nolign-1)=0
Endif

[M]CALMON(nolign-1)=month([M]END1(nolign-1))
  If [M]CALMON(nolign-1)= [M]CALMON(nolign-2)
    [M]PERMON(nolign-1)=([M]PERMON(nolign-2)+1)
  Else
    [M]PERMON(nolign-1)=1
    If [M]PERMON(nolign-1) = [M]PERMON(nolign-2)
      [M]PERMON(nolign-1)=([M]PERMON(nolign-2)+1)
    Endif
  Endif
Return


$PERIODMONTH
Local Integer PER(1..12)

For nolign = 1 To [M:HRPEO1]PERNUM+1
  Case [M:HRPEO1]TAXMON(nolign-1)
    When 1  :  PER(1)+=1
    When 2  :  PER(2)+=1
    When 3  :  PER(3)+=1
    When 4  :  PER(4)+=1
    When 5  :  PER(5)+=1
    When 6  :  PER(6)+=1
    When 7  :  PER(7)+=1
    When 8  :  PER(8)+=1
    When 9  :  PER(9)+=1
    When 10 :  PER(10)+=1
    When 11 :  PER(11)+=1
    When 12 :  PER(12)+=1
  Endcase
Next

For nolign = 1 To [M:HRPEO1]PERNUM+1
  Case [M:HRPEO1]TAXMON(nolign-1)
    When 1  : [M:HRPEO1]PERMON1(nolign-1) = num$([M:HRPEO1]PERMON(nolign-1))+"/"+num$(PER(1))   :  [M:HRPEO1]PERMON2(nolign-1)= PER(1)
    When 2  : [M:HRPEO1]PERMON1(nolign-1) = num$([M:HRPEO1]PERMON(nolign-1))+"/"+num$(PER(2))   :  [M:HRPEO1]PERMON2(nolign-1)= PER(2)
    When 3  : [M:HRPEO1]PERMON1(nolign-1) = num$([M:HRPEO1]PERMON(nolign-1))+"/"+num$(PER(3))   :  [M:HRPEO1]PERMON2(nolign-1)= PER(3)
    When 4  : [M:HRPEO1]PERMON1(nolign-1) = num$([M:HRPEO1]PERMON(nolign-1))+"/"+num$(PER(4))   :  [M:HRPEO1]PERMON2(nolign-1)= PER(4)
    When 5  : [M:HRPEO1]PERMON1(nolign-1) = num$([M:HRPEO1]PERMON(nolign-1))+"/"+num$(PER(5))   :  [M:HRPEO1]PERMON2(nolign-1)= PER(5)
    When 6  : [M:HRPEO1]PERMON1(nolign-1) = num$([M:HRPEO1]PERMON(nolign-1))+"/"+num$(PER(6))   :  [M:HRPEO1]PERMON2(nolign-1)= PER(6)
    When 7  : [M:HRPEO1]PERMON1(nolign-1) = num$([M:HRPEO1]PERMON(nolign-1))+"/"+num$(PER(7))   :  [M:HRPEO1]PERMON2(nolign-1)= PER(7)
    When 8  : [M:HRPEO1]PERMON1(nolign-1) = num$([M:HRPEO1]PERMON(nolign-1))+"/"+num$(PER(8))   :  [M:HRPEO1]PERMON2(nolign-1)= PER(8)
    When 9  : [M:HRPEO1]PERMON1(nolign-1) = num$([M:HRPEO1]PERMON(nolign-1))+"/"+num$(PER(9))   :  [M:HRPEO1]PERMON2(nolign-1)= PER(9)
    When 10 : [M:HRPEO1]PERMON1(nolign-1) = num$([M:HRPEO1]PERMON(nolign-1))+"/"+num$(PER(10))  :  [M:HRPEO1]PERMON2(nolign-1)= PER(10)
    When 11 : [M:HRPEO1]PERMON1(nolign-1) = num$([M:HRPEO1]PERMON(nolign-1))+"/"+num$(PER(11))  :  [M:HRPEO1]PERMON2(nolign-1)= PER(11)
    When 12 : [M:HRPEO1]PERMON1(nolign-1) = num$([M:HRPEO1]PERMON(nolign-1))+"/"+num$(PER(12))  :  [M:HRPEO1]PERMON2(nolign-1)= PER(12)
  Endcase

Affzo [M:HRPEO1]PERMON1(nolign-1)
Affzo [M:HRPEO1]PERMON2(nolign-1)


Next
Return
#JOJAC - 2016-09-19 - X3PEOP-1193 - END

Funprog GET_TAX_YEAR_DATE(DATTYPE)
Value Char DATTYPE
Date RET : RET = date$
Local Char VPARAM
Local Char VSITE
Local Date DTAXSTR, DTAXEND
Local Char TMP_TAXSTRDAT(30), TMP_TAXENDDAT(30)

  If DATTYPE = "TAXSTRDAT" Then
    Call PARAM(VSITE, DATTYPE, TMP_TAXSTRDAT) From ADOVAL
    If TMP_TAXSTRDAT = "" Then : TMP_TAXSTRDAT = "00000000" : Endif
    DTAXSTR = gdat$(TMP_TAXSTRDAT)
    RET = DTAXSTR
  Else
    Call PARAM(VSITE, DATTYPE, TMP_TAXENDDAT) From ADOVAL
    If TMP_TAXENDDAT = "" Then : TMP_TAXENDDAT = "00000000" : Endif
    DTAXEND = gdat$(TMP_TAXENDDAT)
    RET = DTAXEND
  Endif
End RET

