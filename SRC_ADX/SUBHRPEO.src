######################################################################################
#MIPEA - 2017-11-20- US X3-63170- START
#JASMI - 2017-12-07 - X3-67705 - START
#Subprog SET_GFIRDAY(PERCOD)
#Value Char PERCOD
Subprog SET_GFIRDAY(THISPERCOD)
Value Char THISPERCOD
#JASMI - 2017-12-07 - X3-67705 - END

If clalev([HRPEOH8])=0 : Local File HRPEOHEA [HRPEOH8] : Endif
If clalev([F:HRPEOD8])=0 : Local File HRPEODET [HRPEOD8] : Endif

#JASMI - 2017-12-07 - X3-67705 - START
#Link [HRPEOH8] With [F:HRPEOD8]HRPEOD0(1) = [HRPEOH8]PERCOD As [LNK] Where [HRPEOH8]PERCOD = PERCOD & [HRPEOH8]FLGENA=2
Link [HRPEOH8] With [F:HRPEOD8]HRPEOD0(1) = [HRPEOH8]PERCOD As [LNK] Where [HRPEOH8]PERCOD = THISPERCOD & [HRPEOH8]FLGENA=2
#JASMI - 2017-12-07 - X3-67705 - END

Read [LNK] First

If !fstat
  GFIRDAY = dayn([F:HRPEOD8]PERSTR(0))
Else
  GERR=2
#JASMI - 2017-12-07 - X3-67705 - START
#  GMESSAGE = mess(164,107,1) + ":" - PERCOD - "-" - mess(23,100,1)
  GMESSAGE = mess(164,107,1) + ":" - THISPERCOD - "-" - mess(23,100,1)
#JASMI - 2017-12-07 - X3-67705 - END
Endif

End
#MIPEA - 2017-11-20- US X3-63170- END

