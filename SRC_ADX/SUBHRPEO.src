#        GMESSAGE = mess(211,10709,1)
#        mkstat=2 :
#      Endif
#  Endcase
  #JOJAC - 2016-09-19 - X3PEOP-1193 - END

  If nolign > 1
    If VALEUR <> ([M:HRPEO1]END2(nolign-2))+1
      #The date does not follow on the prior periods end date
      GMESSAGE=mess(234,10709,1)
      mkstat=2
    Endif
  Endif
Endif

# FQ85883 - MABON 22/11/12 - Point d'entrée CTLSTRMON
FLGCTL=2
GPOINT = "CTLSTRMON" : Gosub ENTREE From EXEFNC

If FLGCTL=2 Then
  If VALEUR<[M]STR1(nolign-1) or VALEUR>[M]END1(nolign-1)
   GMESSAGE = mess(49,10709,1)-format$("D:"+GFMDAT,[M]STR1(nolign-1))-"-"-format$("D:"+GFMDAT,[M]END1(nolign-1))
  # La date doit être dans la fourchette
   mkstat = 2 : End
  Endif
Endif

#JASMI - 2017-08-02 - X3-50811 - START
If nolign = 1
  If VALEUR <> [M:HRPEO0]CYCSTRDAT
    GMESSAGE=mess(236,10709,1)
    mkstat=2
  Endif
Endif
#JASMI - 2017-08-02 - X3-50811 - END

#If day(VALEUR) > 7
#  GMESSAGE = mess(230,10709,1)
#  mkstat=2
#Endif
End

