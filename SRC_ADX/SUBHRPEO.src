#<AdxTL>@(#)0.0.0.0 $Revision$ Extraction periods
#MIPEA SOURCE REMERGE
#**********************************************************
#* Modifications :
#**********************************************************
#*!
Call OBJET("HRPEO",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "STYLE"     : Gosub STYLE
 When "RAZDUP"    : Gosub RAZDUP
 When "VERIF_CRE" : Gosub VERIF_CRE
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "SETBOUT"   : Gosub SETBOUT
 When "AV_VERF_ANU" : Gosub AV_VERF_ANU
 When "VERF_ANU"  : Gosub VERF_ANU
 When "RAZCRE"    : Gosub RAZCRE
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "ANNULE"    : Gosub ANNULE
 When "SEL_TABLE" : Gosub SEL_TABLE
 When "FIN_ACTION"  : Gosub FIN_ACTION
 When "SETBOUT"   : Gosub SETBOUT
Endcase
Return

$FIN_ACTION
Case BOUT
  When "1" :
    If mkstat=4 & GREP=""
      Gosub ENTRE_MODIF From GOBJSUB
    Endif
Endcase
Return

$APRES_CHOI
Gosub CREATION
#Case RESPONSE
#  When GSTACRE : Gosub CREATION
#Endcase
Return

$OUVRE
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If clalev([ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([HRPEOD])=0 : Local File HRPEODET [HRPEOD] : Endif
Call MANAGE_LOCALISATION("OHRPEO") From DIVPAYE
Return

$LIENS
Gosub STYLE
nolign=0

For [F:HRPEOD] Where [F:HRPEOD]PERCOD=[M:HRPEO0]PERCOD & [F:HRPEOD]PERYEA = [M:HRPEO0]PERYEA
  nolign+=1
  [M:HRPEO1]PYRDAT(nolign-1)  = [F:HRPEOD]PYRDAT
  [M:HRPEO1]STA(nolign-1)     = [F:HRPEOD]STA
  [M:HRPEO1]STR1(nolign-1)    = [F:HRPEOD]PERSTR(0)
  [M:HRPEO1]END1(nolign-1)    = [F:HRPEOD]PEREND(0)
  [M:HRPEO1]STR2(nolign-1)    = [F:HRPEOD]PERSTR(1)
  [M:HRPEO1]END2(nolign-1)    = [F:HRPEOD]PEREND(1)
  [M:HRPEO1]STR3(nolign-1)    = [F:HRPEOD]PERSTR(2)
  [M:HRPEO1]END3(nolign-1)    = [F:HRPEOD]PEREND(2)
  [M:HRPEO1]STR4(nolign-1)    = [F:HRPEOD]PERSTR(3)
  [M:HRPEO1]END4(nolign-1)    = [F:HRPEOD]PEREND(3)
  [M:HRPEO1]CALMON(nolign-1)  = [F:HRPEOD]CALMON
  [M:HRPEO1]NBSEM(nolign-1)   = [F:HRPEOD]NBSEM
  [M:HRPEO1]TAXMON(nolign-1)  = [F:HRPEOD]TAXMON
  [M:HRPEO1]PERMON(nolign-1)  = [F:HRPEOD]PERMON
  [M:HRPEO1]PERMON1(nolign-1) = [F:HRPEOD]PERMON1
  [M:HRPEO1]PERMON2(nolign-1) = [F:HRPEOD]PERMON2
Next

[M:HRPEO1]PERNUM=nolign
Affzo [M:HRPEO1]
Grizo [M:HRPEO0]PAYFRQ
Grizo [M:HRPEO0]FCY
Grizo [M:HRPEO0]CPY
Grizo [M:HRPEO0]LEG
GCURLEG = [M:HRPEO0]LEG
#Disale delete button if a period exist later that record loaded

#MIPEA - 2017-07-13- US X3-36405- START
If clalev([VEP8])=0 : Local File VALEMP [VEP8] : Endif
If clalev([TIP8])=0 : Local File TIMEMP [TIP8] : Endif
If clalev([HRCTR8])=0 : Local File EMPLOCTR [HRCTR8] : Endif

Filter [F:VEP8] Where PERCOD = [M]PERCOD & PERYEA = [M]PERYEA
If rowcount([F:VEP8])>0 Then
#LIPET - 2018-10-03 - X3-110203 - START
#      Diszo [HRPEO0]CYCSTRDAT
#      Diszo [HRPEO1]20
      Grizo [HRPEO0]CYCSTRDAT
      Grizo [HRPEO1]20
#LIPET - 2018-10-03 - X3-110203 - END
Else
  Actzo [HRPEO0]CYCSTRDAT
  Actzo [HRPEO1]20
Endif

For I=0 To [M]PERNUM-1

Link [TIP8] With [HRCTR8]CTR0(2)=[F:TIP8]REFNUM;[F:TIP8]CTRNUM
&  As [LNK]
&  Where [F:HRCTR8]PERCOD = [M]PERCOD & [F:TIP8]DATPYR=[M:HRPEO1]PYRDAT(I)

   If rowcount([LNK])>0 | rowcount([F:VEP8])>0 Then
#LIPET - 2018-10-03 - X3-110203 - START
#      Diszo [HRPEO0]CYCSTRDAT
#      Diszo [HRPEO1]20
      Grizo [HRPEO0]CYCSTRDAT
      Grizo [HRPEO1]20
#LIPET - 2018-10-03 - X3-110203 - END
      Break
   Else
      Actzo [HRPEO0]CYCSTRDAT
      Actzo [HRPEO1]20
   Endif
Next
Filter [F:VEP8]
#MIPEA - 2017-07-13- US X3-36405- END

#JASMI - 2017-08-06 - X3-51668 - START
If [M:HRPEO0]PAYFRQ = 6
  Chgfmt [M:HRPEO1]NBSEM   With 'N:1'
  Chgfmt [M:HRPEO1]PERMON  With '-K:10'
  Chgfmt [M:HRPEO1]PERMON1 With '-K:10'
  Chgfmt [M:HRPEO1]PERMON2 With '-K:10'
  Chgfmt [M:HRPEO1]CALMON  With 'N:4'
Else
  Chgfmt [M:HRPEO1]NBSEM   With '-N:1'
  Chgfmt [M:HRPEO1]PERMON  With 'K:10'
  Chgfmt [M:HRPEO1]PERMON1 With 'K:10'
  Chgfmt [M:HRPEO1]PERMON2 With 'K:10'
  Chgfmt [M:HRPEO1]CALMON  With '-N:4'
Endif
#JASMI - 2017-08-06 - X3-51668 - END

#MIPEA - 2017-11-20- US X3-63170- START
  [M:HRPEO0]FIRDAY = dayn([M:HRPEO1]STR1(0))
  Affzo [M:HRPEO0]FIRDAY
  GFIRDAY = dayn([M:HRPEO1]STR1(0))
#MIPEA - 2017-11-20- US X3-63170- END

Return

$CREATION
$MODIF
Local Integer I, ANNEE, SEM
Local Date    DAT

###Delete [F:HRPEOH] Where [F:HRPEOH]PERCOD = [M:HRPEO0]PERCOD and [F:HRPEOH]PERYEA = [M:HRPEO0]PERYEA
Delete [F:HRPEOD] Where [F:HRPEOD]PERCOD = [M:HRPEO0]PERCOD and [F:HRPEOD]PERYEA = [M:HRPEO0]PERYEA
If fstat=1 | fstat>5
  GOK=0 : Call RSTA("HRPEOD",[M:HRPEO0]PERCOD) From GLOCK : Return
Endif
For nolign=1 To [M:HRPEO1]PERNUM
#MIPEA - 2017-02-08- X3-12122- START
  Raz [F:HRPEOD]
#MIPEA - 2017-02-08- X3-12122- END
  [F:HRPEOD]PERCOD    = [M:HRPEO0]PERCOD
  [F:HRPEOD]PERYEA    = [M:HRPEO0]PERYEA
  [F:HRPEOD]PYRDAT    = [M:HRPEO1]PYRDAT(nolign-1)
  [F:HRPEOD]STA       = [M:HRPEO1]STA(nolign-1)
  [F:HRPEOD]PERSTR(0) = [M:HRPEO1]STR1(nolign-1)
  [F:HRPEOD]PEREND(0) = [M:HRPEO1]END1(nolign-1)
  [F:HRPEOD]PERSTR(1) = [M:HRPEO1]STR2(nolign-1)
  [F:HRPEOD]PEREND(1) = [M:HRPEO1]END2(nolign-1)
  [F:HRPEOD]PERSTR(2) = [M:HRPEO1]STR3(nolign-1)
  [F:HRPEOD]PEREND(2) = [M:HRPEO1]END3(nolign-1)
  [F:HRPEOD]PERSTR(3) = [M:HRPEO1]STR4(nolign-1)
  [F:HRPEOD]PEREND(3) = [M:HRPEO1]END4(nolign-1)
  [F:HRPEOD]CALMON    = [M:HRPEO1]CALMON(nolign-1)
  [F:HRPEOD]NBSEM     = [M:HRPEO1]NBSEM(nolign-1)
  [F:HRPEOD]TAXMON    = [M:HRPEO1]TAXMON(nolign-1)
  [F:HRPEOD]PERMON    = [M:HRPEO1]PERMON(nolign-1)
  [F:HRPEOD]PERMON1   = [M:HRPEO1]PERMON1(nolign-1)
  [F:HRPEOD]PERMON2   = [M:HRPEO1]PERMON2(nolign-1)
  [F:HRPEOD]PERNUM    = nolign
#MIPEA - 2017-02-08- X3-12122- START
  If nolign = 1
    #JOJAC - 2017-02-21 - START
    #[L]DAT   = [F:HRPEOD]PERSTR(0)
    [L]DAT   = [M]STR1(0)
    #JOJAC - 2017-02-21 - END
  Endif

  I     = 0
  ANNEE = year([L]DAT)
  Repeat
   #MIPEA - 2017-11-26- US X3-63170- START
   GFIRDAY = dayn([M:HRPEO1]STR1(0))
   #MIPEA - 2017-11-26- US X3-63170- END
   Call DAT([L]DAT,ANNEE,SEM) From SUBPLN
   [F:HRPEOD]NUMWEK(I) = SEM
   [F:HRPEOD]YEAWEK(I) = ANNEE
   [L]DAT +=7
   I +=1
  Until [L]DAT>=[M:HRPEO1]END1(nolign-1) | I>5
#MIPEA - 2017-02-08- X3-12122- END

  Write [HRPEOD]
  If fstat
    GOK=0 : Call FSTA("HRPEOD") From GLOCK : Break
  Endif
Next nolign
Return

$ANNULE
Delete [F:HRPEOD] Where [F:HRPEOD]PERCOD = [M:HRPEO0]PERCOD and [F:HRPEOD]PERYEA = [M:HRPEO0]PERYEA
If fstat
  GOK=0 : Call FSTA("HRPEO") From GLOCK
Endif
Return

$VERIF_CRE
$VERIF_MOD
Local Integer WOK

If [M:HRPEO1]PERNUM > 0
  nolign = [M:HRPEO1]PERNUM
  If [M:HRPEO1]END2(nolign-1) <> [M:HRPEO0]CYCENDDAT
    [M:HRPEO0]CYCENDDAT = [M:HRPEO1]END2(nolign-1)
    Affzo [M:HRPEO0]CYCENDDAT
  Endif
Endif

#Check if grids are populated
If [M:HRPEO0]PAYFRQ = 1
  If [M:HRPEO1]PERNUM <> 52 and  [M:HRPEO1]PERNUM <> 53
    GERR=1
    GMESSAGE = mess(227,10709,1)
    OK = 0
    Return
  Endif
Endif

If [M:HRPEO0]PAYFRQ = 6
  If [M:HRPEO1]PERNUM <> 12
    GERR=1
    GMESSAGE = mess(228,10709,1)
    OK = 0
    Return
  Endif
Endif

OK = 1
Sorta [M]PERNUM [M]PERNUM Order By [M]PYRDAT(indice)
Affzo 20
If GTPS
 For I=0 To [M]PERNUM-2
  For J=I+1 To [M]PERNUM-1
   If [M]STR1(J)<=[M]END1(I) and [M]END1(J)>=[M]STR1(I)
    WOK = 2 : Call AVERTIR("(1)"-mess(50,10709,1)-num$(I+1)-num$(J+1),WOK) From GESECRAN
    If WOK<>2 : OK = 0 : Break 2 : Endif
   Endif
   If [M]STR2(J)<=[M]END2(I) and [M]END2(J)>=[M]STR2(I)
    WOK = 2 : Call AVERTIR("(2)"-mess(50,10709,1)-num$(I+1)-num$(J+1),WOK) From GESECRAN
    If WOK<>2 : OK = 0 : Break 2 : Endif
   Endif
  Next J
 Next I
 If !OK : Return : Endif

For I=1 To [M]PERNUM-1
  If [M]STR1(I)<>[M]END1(I-1)+1
   WOK = 2 : Call AVERTIR("(1)"-mess(51,10709,1)-num$(I)-num$(I+1),WOK) From GESECRAN
   If WOK<>2 : OK = 0 : Break : Endif
  Endif
  If  [M]STR2(I)<>[M]END2(I-1)+1
   WOK = 2 : Call AVERTIR("(2)"-mess(51,10709,1)-num$(I)-num$(I+1),WOK) From GESECRAN
   If WOK<>2 : OK = 0 : Break : Endif
  Endif
 Next I
Endif

If [M:HRPEO0]CYCENDDAT = '00/00/00'
  GMESSAGE = mess(226,10709,1)
  OK = 0
Endif

If [M:HRPEO0]FLGENA = 2
  Filter [F:HRPEOH] Where PERCOD = [M:HRPEO0]PERCOD and FLGENA = 2 and PERYEA <> [M:HRPEO0]PERYEA
  Read First
  If !fstat
    [M:HRPEO0]FLGENA = 0
    Affzo [M:HRPEO0]FLGENA
    GMESSAGE = mess(233,10709,1)
  Endif
Endif
Filter [F:HRPEOH]

For nolign = 2 To [M:HRPEO1]PERNUM
  If [M:HRPEO1]STR2(nolign-1) <> [M:HRPEO1]END2(nolign-2)+1
    GMESSAGE = mess(234,10709,1)
    OK=0
  Endif
Next

For nolign = 1 To [M:HRPEO1]PERNUM
  If [M:HRPEO1]TAXMON(nolign-1) < 1 | [M:HRPEO1]TAXMON(nolign-1) > 12
    GMESSAGE = mess(235,10709,1)
    OK=0
  Endif
Next

If nolign = [M:HRPEO1]PERNUM
  If [M:HRPEO1]END2(nolign-1)<>[M:HRPEO0]CYCENDDAT
    [M:HRPEO0]CYCSTRDAT=[M:HRPEO1]END2(nolign-1)
    Affzo [M:HRPEO0]CYCENDDAT
  Endif
Endif


If GCURLEG = 'ZAF' & ([M:HRPEO0]PAYFRQ = 1 | [M:HRPEO0]PAYFRQ = 6)
  If day([M:HRPEO0]CYCENDDAT) > 7 & month([M:HRPEO0]CYCENDDAT) > 2
    GERR=2
    GMESSAGE = mess(230,10709,1)
    SAV_CYCENDDAT = [M:HRPEO0]CYCENDDAT
    Raz [M:HRPEO0]CYCENDDAT : Affzo [M:HRPEO0]CYCENDDAT
    Raz [M:HRPEO1] : Affzo [M:HRPEO1]
    zonsui = "[M:HRPEO0]CYCSTRDAT"
    OK=0
  Endif
Endif

Return

#JOJAC - 2016-09-29 - X3PEOP-1193 - START
$RAZCRE
If [M:HRPEO0]LEG = ""
  GCURLEG = ""
Endif
#Activate frequency field when in creation mode
If GREP = 'C' | GREP = 'D'
  Actzo [M:HRPEO0]PAYFRQ
  Actzo [M:HRPEO0]FCY
  If [M:HRPEO0]FCY = ""
    Actzo [M:HRPEO0]CPY
    Actzo [M:HRPEO0]LEG
  Endif
Endif

#MIPEA - 2017-11-29- US X3-63170- START
If GREP = "C"
  Local Char TEMPGFIRDAY(1)

#MIPEA - 2018-01-17- US X3-67274- START
  Call PARAM("", "FIRDAY", TEMPGFIRDAY) From ADOVAL
#  Call PARAM(GCURLEG, "FIRDAY", TEMPGFIRDAY) From ADOVAL
#MIPEA - 2018-01-17- US X3-67274- END
  GFIRDAY = val(TEMPGFIRDAY)
  [M:HRPEO0]FIRDAY = GFIRDAY
  Affzo [M:HRPEO0]FIRDAY
Endif
#MIPEA - 2017-11-29- US X3-63170- END

  Gosub STYLE
Return
#JOJAC - 2016-09-29 - X3PEOP-1193 - END

# 34705
$RAZDUP
#If COUZON="PERYEA"
# Effzo [HRPEO1]20
#Endif
Gosub RAZCRE
Return

$STYLE
Gosub DISPLAY_HIDE From SUBHRPEOLEG

#If [M:HRPEO0]PAYFRQ = 1
#  Chgfmt [M:HRPEO1]NBSEM   With 'N:1'
#  Chgfmt [M:HRPEO1]PERMON With 'K:10'
#  Chgfmt [M:HRPEO1]PERMON1 With 'K:10'
#  Chgfmt [M:HRPEO1]PERMON2 With 'K:10'
#  Chgfmt [M:HRPEO1]CALMON  With 'N:4'
#Endif
#
#If [M:HRPEO0]PAYFRQ <> 1
#  Chgfmt [M:HRPEO1]NBSEM   With '-N:1'
#  Chgfmt [M:HRPEO1]PERMON  With '-K:10'
#  Chgfmt [M:HRPEO1]PERMON1 With '-K:10'
#  Chgfmt [M:HRPEO1]PERMON2 With '-K:10'
#  Chgfmt [M:HRPEO1]CALMON  With '-N:4'
#Endif
#JOJAC - 2016-09-29 - X3PEOP-1193 - END
Return

#55439
$SETBOUT
Filter [F:HRPEOD] Where PERCOD = [M:HRPEO0]PERCOD and PERYEA > [M:HRPEO0]PERYEA
Read [F:HRPEOD]HRPEOD0 First
If fstat = 0
  Call VIREBOUT(CHAINE,"A") From GOBJET
Else
  CHAINE +="A"
Endif
Filter [F:HRPEOD]

#LIPET - 2018-10-03 - X3-110203 - START
If GREP = "D" Then
  Actzo [HRPEO1]20
Endif
#LIPET - 2018-10-03 - X3-110203 - END
Return

#JOJAC - 2016-11-07 - START
$AV_VERF_ANU
#  Gosub ANNULE
Return
#JOJAC - 2016-11-07 - END

$VERF_ANU

If [M:HRPEO1]PERNUM > 0
  Local Integer FLGPER(0..[M:HRPEO1]PERNUM-1)
Endif

If clalev([F:VEP])=0  : Local File VALEMP [VEP]    : Endif
If clalev([F:HRPEOH])=0 : Local File HRPERIOD [HRPEOH]   : Endif
If clalev([F:TIP])=0 : Local File TIMEMP   [TIP]  : Endif
If GTPS
 If clalev([F:TIG])=0 : Local File TIMREGUL [TIG]  : Endif
Endif

If GMAS
 If clalev([F:MHS])=0 : Local File MSHISTO [MHS]   : Endif
Endif
Gosub VALORIS
OK=1

#For I=0 To [M]PERNUM-1
# If FLGPER(I)=0
Filter [VEP] Where PERCOD = [M]PERCOD and PERYEA = [M]PERYEA
Read [VEP]VEP4 First
Filter [VEP]
If !fstat
 # Période d'extraction utilisée dans la feuille de paie
 GERR = 1 : GMESSAGE = mess(189,10709,1)-[F:VEP]EMP-num$([F:VEP]PYRDAT)
 OK = 0
Endif
Return

$VALORIS
#Ask Jaco
#For I=0 To [M]PERNUM-1
# FLGPER(I) = 1
# Read [HRPEOH]PEO0="";[M]PYRDAT(I)
# If !fstat
#  FLGPER(I) *= [F:HRPEOH]PERSTR(0) = [M:HRPEO1]STR1(I)
#  FLGPER(I) *= [F:HRPEOH]PEREND(0) = [M:HRPEO1]END1(I)
#  FLGPER(I) *= [F:HRPEOH]PERSTR(1) = [M:HRPEO1]STR2(I)
#  FLGPER(I) *= [F:HRPEOH]PEREND(1) = [M:HRPEO1]END2(I)
#  FLGPER(I) *= [F:HRPEOH]PERSTR(2) = [M:HRPEO1]STR3(I)
#  FLGPER(I) *= [F:HRPEOH]PEREND(2) = [M:HRPEO1]END3(I)
#  #31761
#  FLGPER(I) *= [F:HRPEOH]PERSTR(3) = [M:HRPEO1]STR4(I)
