    [M:HRPEO1]END4(0) = eomonth(addmonth([M:HRPEO1]STR4(0),2))
    [M]NBSEM(0) = ([M]END1(0)-[M]STR1(0)+1)/7
  When 6
    [M:HRPEO1]STR3(0)=addmonth(VALEUR,-1)
