    [M:HRPEO1]PYRDAT(0) = eomonth(addmonth(VALEUR,2))
    #[M:HRPEO1]END1(0) = eomonth(addmonth([M:HRPEO1]STR1(0),2))
    [M:HRPEO1]END2(0) = eomonth(addmonth([M:HRPEO1]STR2(0),2))
