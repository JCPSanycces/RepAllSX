######################################################################################
## Section automatically added (screen HRPEO1) 10/19/2016 13:59:40 (JOJAC)
######################################################################################
Subprog C_CYCSTRDAT(VALEUR)
Variable Date    VALEUR
Local Date TAXYEAR
Local Integer DAYDIFF
Local Integer PERDAY
Local Integer PERMON
Local Integer PERYEA

#Check that cycle start date is not more than 14 days for ZAF
If GCURLEG = 'ZAF'
#JASMI - 2017-08-02 - X3-51335 - START
#  TAXYEAR = gdat$(1,03,([M:HRPEO0]PERYEA)-1)
  TAXYEAR = gdat$(1,03,([M:HRPEO0]PERYEA)-1)-1
#JASMI - 2017-08-02 - X3-51335 - END
  DAYDIFF = TAXYEAR - VALEUR
  If DAYDIFF > 14 or DAYDIFF < -14
    GMESSAGE = mess(211,10709,1)
    mkstat=2
  Endif
Endif

#Check that start date is 6 April for UK
If  GCURLEG = 'BRI'
   [L]PERDAY = day(VALEUR)
   [L]PERMON = month(VALEUR)
   [L]PERYEA = year(VALEUR)

    If [L]PERDAY <> 6 | [L]PERMON <> 4
      GERR=2
      GMESSAGE = mess(232,10709,1)+num$([L]PERYEA)
      mkstat=2
    Endif
Endif

If GCURLEG = 'ZAF'
  If year(VALEUR) <> ([M:HRPEO0]PERYEA)-1
    GMESSAGE = mess(217,10709,1)
    mkstat=2
  Endif
#JASMI - 2017-09-14 - X3-55995 - START
#Else
Endif
If GCURLEG = 'BRI'
#JASMI - 2017-09-14 - X3-55995 - END
  If year(VALEUR) <> [M:HRPEO0]PERYEA
    GMESSAGE = mess(217,10709,1)
    mkstat=2
  Endif
Endif

Filter [F:HRPEOD] Where [F:HRPEOD]PERCOD = [M:HRPEO0]PERCOD & [F:HRPEOD]PERYEA = [M:HRPEO0]PERYEA-1
Read [F:HRPEOD] Last
If fstat = 0
  If VALEUR <>   [F:HRPEOD]PEREND(1)+1
    #The cycle start date does not follow on the prior year cycle end date
    GMESSAGE = mess(224,10709,1)
    mkstat = 2
  Endif
Endif
Filter [F:HRPEOD]
End

