#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SIPAR2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_NBPPL
Onevent BEFORE_AREA Call AV_NBPPL From W2SIPAR2
Return

Subprog AV_NBPPL
Local Decimal BASPAG
[M]NBPPL = 4
Gosub _AFF
End

$ON_LIBINTTARA
Onevent BEFORE_AREA Gosub AV_LIBINTTARA From W2SIPAR2
Return

$AV_LIBINTTARA
zc = SI_MES(203+nolign)
Gosub _AFF
Return

$ON_DISCRGACH
Onevent CONTROL Call C_DISCRGACH(zc) From W2SIPAR2
Onevent AFTER_CHANGE Gosub AMM_DISCRGACH From W2SIPAR2
Onevent BEFORE_INPUT Call AS_DISCRGACH(zc) From W2SIPAR2
Return

Subprog AS_DISCRGACH(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_DISCRGACH(zc) From W2SIPAR2
Gosub _AFF
End

Subprog C_DISCRGACH(VALEUR)
Variable Decimal VALEUR
## Action STD
Call C_DISCRGACH(VALEUR) From SUBSIP
If mkstat : GERR = 1 : GZONE = "DISCRGACH" : GZNUM = 2808 : Endif
Gosub _AFF
End

$AMM_DISCRGACH
Call AM_DISCRGACH(zc)
If !mkstat & GOBJET
 zoncou = "DISCRGACH" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DISCRGACH(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_DISCRGACH(VALEUR) From SUBSIP
If mkstat : GERR = 1 : GZONE = "DISCRGACH" : GZNUM = 2808 : Endif
Gosub _AFF
End

Subprog S_DISCRGACH(VALEUR)
Variable Decimal VALEUR
If !GWEBSERV
 ## Action SELSIXCOR2
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELSIXCOR2"
 PARMSK(1) = num$(nolign)
 Call S_LIS_NUM(VALEUR,PARMSK,"SELSIXCOR2","SIXACTION","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$CHG_STY
Return


