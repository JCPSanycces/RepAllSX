#<AdxTL>@(#)10.0.0.0 $Revision$
# V6 Calcul du coût de sous-traitance
# Gestion du masque SWF0             Traitement FUNWIPSCO
# Finalisation d'en-cours EO à partir de la table WIPCOST
# Solde des encours et calcul du PRS
##########################################################################
#
# NE CONCERNE QUE LES WIPCOST DONT L'ENTETE MFGWIP POINTE SUR UN EO
############################################################################################

$ACTION
Case ACTION
 When "INIT"        Gosub INIT     From FUNWIPMFC
 When "OUVRE_BATCH" Gosub INIT     From FUNWIPMFC
 When "CONTROLE"    Gosub CONTROLE From FUNWIPMFC
 When "EXEC"        Gosub EXEC     From FUNWIPMFC
 When "TERMINE"     Gosub TERMINE  From FUNWIPMFC
Endcase
Return

##################################################################################################
################################    ACTIONS CHAMPS    ############################################
##################################################################################################
Subprog D_STOFCY(VALEUR)
Variable Char    VALEUR()
Call FIND_GFCYDEF(6) From TRTX3  # FQ 54218
VALEUR = GFCY                  : # Site d'achat par défaut
Call GETCPY(VALEUR,"",0,"") From TRTX3CPT   # Issue 75315 - 2011-07-25 by CCC : Alimentation de GNBDIE
End

##########################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
# charger les éventuels paramètres de niveau site
Call GLOBVAR(VALEUR)    From WWGLOBACH
Call GETCPY(VALEUR,"",0,"") From TRTX3CPT   # Issue 75315 - 2011-07-25 by CCC : Alimentation de GNBDIE
End

##########################################################################
Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()

Local Char LWAICTL(2)

If VALEUR <> ""
    If !func FUNWIPMFC.CTRMFG([M]VCRTYP,VALEUR)  : # se positionne sur SCO
        mkstat = 2
    Elsif [M]PRF1=1 & [F:SCO]SCOTRKFLG<6
        GMESSAGE = mess(225,193,1) #"Le prix de revient n'a pas encore été calculé pour cet ordre"
        mkstat=2
    Elsif [M]PRF2=1 & [F:SCO]SCOTRKFLG=6
        GMESSAGE = mess(85,193,1) : #"Le prix de revient a déjà été calculé pour cet ordre"
        mkstat=2
    Elsif [F:SCO]SCOSTA < 4 & [M]SIMFLG<>2 : # contrôler que l'EO est clos
        [M]SIMFLG = 2 : [M]MFGTYP=1
        [M]PRF1=2
        [M]PRF2=1
        Diszo PRF1,PRF2
        Affzo SIMFLG,PRF1,PRF2
        GERR=2 : GMESSAGE = mess(399,194,1) : #"Cet ordre de sous-traitance n'est pas clos !"
    Endif
    If mkstat : End : Endif

    Raz LWAICTL

    ##########################
    # Fix Issue 113906 - 29th Jan 2016 - JAMCC
    Call PARAM([F:SCI]PRHFCY , "EOMMVTWAI", LWAICTL) From ADOVAL
    #Call PARAM([F:MFG]MFGFCY, "EOMMVTWAI", LWAICTL) From ADOVAL
    ##########################
    If LWAICTL="3"
        If func FUNTEOCLO.CTRL_WAITRS_EO(VALEUR)>0
            mkstat=2
            GMESSAGE = mess(477,194,1)
            End
        Endif
    Endif

Endif

If VALEUR<>""
    [M]MFGTYP = ([F:SCO]SCOSTA=4)+1
    [M]FILMFG = ""
    [M]FILFLG = 1
Else
    [M]MFGTYP = ([M]SIMFLG<>2)+1
Endif
Call UPDMSG(VALEUR) From FUNWIPMFC

If GERR=2 : zonsui="SIMFLG" : Endif
If VALEUR="" & [M]FILMFG = "" :  mkstat = 2 : Endif
End

######################################################################################
Subprog C_PRNCOD(VALEUR)
Variable Integer VALEUR
    If VALEUR>1
        Actzo PRVCSTPRT,EDIPRV
        Actzo FLXBUD
        If [M]FLXBUD<>2
            Actzo ORIDEVCLC
        Else
            Grizo ORIDEVCLC
        Endif
    Else
        [M]PRVCSTPRT = 1
        [M]EDIPRV = 1
        Diszo PRVCSTPRT,EDIPRV
        Grizo FLXBUD
        Grizo ORIDEVCLC
    Endif
    Affzo PRVCSTPRT,EDIPRV
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran SWF0) 20/01/2009 10:43:12 (CCC)
######################################################################################
Subprog C_FLXBUD(VALEUR)
Variable Integer VALEUR
    If VALEUR=2
        Grizo ORIDEVCLC
    Else
        Actzo ORIDEVCLC
    Endif
End

######################################################################################
Subprog C_PRF2(VALEUR)
Variable Integer VALEUR
If VALEUR<>2 & [M]PRF1<>2
    GMESSAGE = mess(266,199,1)
    mkstat=2
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran SWF0) 10/05/2010 16:45:18 (CCC)
######################################################################################

Subprog D_SIMFLG(VALEUR)
Variable Integer VALEUR
[M]MFGTYP=1+(VALEUR<>2)
Call UPDMSG([M]VCRNUM) From FUNWIPMFC
End

Subprog AM_SIMFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    [M]PRF1=2
    [M]PRF2=1
    Diszo PRF1,PRF2
Else
    Actzo PRF1,PRF2
Endif
[M]MFGTYP=1+(VALEUR<>2)

Call UPDMSG([M]VCRNUM) From FUNWIPMFC
End

######################################################################################
## GH 10/01/2013 Dm 77455
######################################################################################

Subprog S_VCRNUM(VALEUR)
Variable Char    VALEUR()

[M]FILSELMFG = "[SCI]PRHFCY='"+[M]STOFCY+"'"
If [M]SIMFLG<>2
   [M]FILSELMFG-= "& [SCO]SCOSTA=4" : # ordre clos
Endif
If [M]PRF1=2
  [M]FILSELMFG-= "& "
  If [M]PRF2=2 : [M]FILSELMFG+= "(" : Endif
  [M]FILSELMFG+= "find([SCO]SCOTRKFLG,4,5)<>0" : # En cours ou soldé
Endif
If [M]PRF2=2
   If [M]PRF1=2 : [M]FILSELMFG-= "| (" : Else  [M]FILSELMFG-= "& " : Endif
   [M]FILSELMFG+= "[SCO]SCOTRKFLG=6 & [MWH]MFGTRKFLG=5" : # 5 = Soldé
   If [M]PRF1=2 : [M]FILSELMFG+= "))" : Endif
Endif
End

######################################################################################

Subprog IB_VCRNUM
If [M]PRF2<>2
   Raz GBOUT3
Elsif [M]PRF1<>2
   GBOUT3=mess(439,194,1) : # Sélection EO avec prix revient calculé
Else
   GBOUT3=mess(440,194,1) : # Sélection EO clos
Endif
End

######################################################################################

Subprog B2_VCRNUM(VALEUR)
Variable Char    VALEUR()

[M]FILFLG = ([M]FILMFG<>"")+1
If [M]FILMFG<>"" : VALEUR="" : Endif

Call UPDMSG(VALEUR) From FUNWIPMFC
End

######################################################################################

Subprog B3_VCRNUM(VALEUR)
Variable Char    VALEUR()

# ici , on a forcément [M]SIMFLG=1 & [M]PRF2=2
[M]FILSELMFG = "[SCI]PRHFCY='"+[M]STOFCY+"' & [SCO]SCOSTA=4" : # ordre clos
If [M]PRF1<>2
   [M]FILSELMFG-= " & [SCO]SCOTRKFLG=6" : # Prix de revient calculé
Else
   [M]FILSELMFG-= "& find([SCO]SCOTRKFLG,4,5)<>0"  : # En cours ou soldé
Endif
End

