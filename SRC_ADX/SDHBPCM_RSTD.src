#############################################################################
# Traitement SDHBPCM_RSTD : Liste livraison mobiles                         #
#   Classe représentation SDHBPCM : Liste des cdes (2 onglets sur mobile)   #
#   Classe données        SDHBPCM : Liste des cdes (2 onglets sur mobile)   #
#       Nota : le champ THIS.TESTJDE est dispo pour test                    #
#############################################################################

##############################
## $ACTION                  ##
##############################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
     When ""
        Case [L]AEVENT
          When "AQUERY_TRANS_AFTER"    : Gosub AQUERY_TRANS_AFTER      : #-- Permet d'alimenter la query avant affichage         --#
          #-- Action pour le Détail --#
          When "AREAD_AFTER"           : Gosub AREAD_AFTER             : #-- Lecture supplementaire avant affichage Détail       --#
        Endcase
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return
#--------------------------------------

##############################
## $PROPERTIES              ##
##############################
$PROPERTIES
  Case CURPRO

    When Default
  Endcase
Return
#####################################################################
## $AQUERY_TRANS_AFTER : Alimente propriétés exposées de la query  ##
#####################################################################
$AQUERY_TRANS_AFTER

Local File ATEXTRA   [AXX]
Local File FACILITY  [FCY]

#-- Site vente --#
this.WSTOFCY   = this.SDH.STOFCY
Read [FCY]FCY0 = this.SDH.STOFCY
If !fstat
   this.WSTOFCY  -= '(' + [F:FCY]FCYSHO + ')'
Endif

Return

#####################################################################
## $AREAD_AFTER : Alimente propriétés exposées du détail           ##
#####################################################################
$AREAD_AFTER

Local File BPCUSTOMER [BPC]
Local File ATEXTRA    [AXX]
Local File BPARTNER   [BPR]
Local File BPCARRIER    [BPT]

#-- Lecture BPC (client) pour la la livraison --#
Read [F:BPC]BPC0=this.SDH.BPCORD
this.WBPCNAM = [F:BPC]BPCNAM

#-- Lecture BPT (Transporteur) pour la livraison --#
Read [F:BPT]BPT0=this.SDH.BPTNUM
this.WBPTNAM = [F:BPT]BPTNAM

#-- Si Type livraison ([F:SDH]LND) <>2 --> On rend invisible le champ date retour --#
If [F:SDH]LND=2
  #-- Mise en invisible de la propriété 'Retour prêt' --> on met THIS.SDH.ASETATTRIBUTE car SDH  est l'instance défini dans la CR --#
  Local Integer WOK
  WOK = fmet this.SDH.ASETATTRIBUTE("LNDRTNDAT","$isHidden","true")
Endif

#-- Si date retour est affichée [30/11/1899] (test [00/00/00])  --> On raz le champ date retour  --#
If this.SDH.LNDRTNDAT = [00/00/00]
 #--   --> raz de THIS.SDH.LNDRTNDAT --> comment fait-on ? ????????????????????????????????????????????????????????
 #--  En attendant -->
  Local Integer WOK
  WOK = fmet this.SDH.ASETATTRIBUTE("LNDRTNDAT","$isHidden","true")
  # OU
  #   WOK = FMET THIS.ASETATTRIBUTE("SDH.LNDRTNDAT","$isHidden","true")
Endif

Return

