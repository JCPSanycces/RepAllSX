Call NYTBIL("A-TS","ADX","",1,1)
#Call NOTPAY("CLIENT1","ADX","")
#Call PROROG("LS","ADX","PAR",1)
End
##################################################################
# Called from the VISUBIL action

$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "DEBUT"      : Gosub DEBUT
 When "AB1_NBRLIG" : Gosub AB_NBRLIG
 When "BB1_NBRLIG" : Gosub BB_NBRLIG
 When "AB2_NBRLIG" : Gosub AB_NBRLIG
 When "BB2_NBRLIG" : Gosub BB_NBRLIG
 When "AB3_NBRLIG" : Gosub AB_NBRLIG
 When "BB3_NBRLIG" : Gosub BB_NBRLIG
 When Default
Endcase
Return

$OUVRE
Onerrgo ERREUR From CONTROLE
Local Mask NYTBILZOOM [DIA]
If !clalev([F:PYH]) : Local File PAYMENTH   [PYH] : Endif
If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([F:PAN]) : Local File PAYACCNUM  [PAN] : Endif
If !clalev([F:TPY]) : Local File TABPAYTYP  [TPY] : Endif
If !clalev([F:DAE]) : Local File GACCENTRYD [DAE] : Endif
If !clalev([F:TCU]) : Local File TABCUR     [TCU] : Endif
Onerrgo
If GERREUR : FIN=1 : Return : Endif
Local Char    CRITERE(255), TIERS(GLONBPR), SOCIETE(GLONCPY), SITE(GLONFCY), SAVGFONC1(10), DEVLED(GLONCUR)
Local Integer TIERSTYP, PORTEFEUILLE, OK, SAVCONS
TIERS  = PARAM(1)
SOCIETE = PARAM(2)
SITE = PARAM(3)
TIERSTYP = val(PARAM(4))
PORTEFEUILLE = val(PARAM(5))
Return

$DEBUT
# Critères :
# - Etape mise en portefeuille effectuée
# - Portefeuille non déjà dévalorisé
# - Règlement du tiers, de la société et éventuellement du site demandé
# - Si client : recette
# - Si fournisseur : dépense

Gosub CHARG_PYH
Affzo [M:DIA]

If [M:DIA]NBRLIG=0
 # Pas d'effet non échu
 Call ERREUR(mess(49,121,1)) From GESECRAN
 FIN=1
Endif
Return


$CHARG_PYH
#71921
#[L]CRITERE = "STAFLG(2)=2 & STAFLG(9)<>2 & AMTNYTBIL<>0"
#&            -"& BPR='"+[L]TIERS+"' & CPY='"+[L]SOCIETE+"'"
[L]CRITERE = "STAFLG(2)=2 & STAFLG(9)<>2 & AMTNYTBIL<>0 & BPR='"+[L]TIERS+"'"
If [L]SOCIETE<>""
 [L]CRITERE -= "& CPY='"+[L]SOCIETE+"'"
Endif

If [L]SITE<>""
 [L]CRITERE -= "& FCY='"+[L]SITE+"'"
Endif
Case [L]TIERSTYP
 When 1 : [L]CRITERE -= "& BPRTYP=1 & SNS<>1" :# Recette client
 When 2 : [L]CRITERE -= "& BPRTYP=2 & SNS=1"  :# Dépense fournisseur
Endcase

# Types de règlement avec étape Mise en portefeuille et
# Portefeuille demandé
nolign = 1
Raz [M:DIA]

Link [PYH] With [TPY]TPY0=[F:PYH]PAYTYP, [CPY]CPY0=[F:PYH]CPY
& As [LNK]
& Where [F:TPY]STA3=2 & [F:TPY]UPDBIL=[L]PORTEFEUILLE+1 & evalue(CRITERE) & ([F:CPY]LEG=[F:TPY]LEG | [F:TPY]LEG='')
& Order By Key LNK0=CPY;DUDDAT;NUM;[TPY]LEG Desc

Columns [TPY](PAYTYP)
For [F:LNK]LNK0(3)
 [M:DIA] = [F:PYH]
 If [L]SOCIETE<>[F:PYH]CPY | DEVLED=""
  Call SETCUR(1,[F:PYH]CPY,DEVLED) From CPTDIV
 Endif
 Filter [PAN] Where TYPNUM=3 & NUM=[F:PYH]NUM & STA=3
 Read [PAN]PAN0 First
 If fstat=0
  Read [DAE]DAE2=[F:PAN]ACCNUM
  [M:DIA]ACETYP(nolign-1) = [F:DAE]TYP
  [M:DIA]ACENUM(nolign-1) = [F:DAE]NUM
 Endif
 [M:DIA]DEVSOC(nolign-1) = [L]DEVLED
 [M:DIA]NBRLIG += 1
 nolign += 1
 If dim([M:DIA]ACETYP)<=nolign
  Call ERREUR(mess(26,100,1)) From GESECRAN : Break
 Endif
Next
Filter [F:PAN]
Columns [TPY]
Return


#########################################
## Subprog NYTBIL modélisé. A supprimer
#########################################

# Effets en portefeuille non échus
Subprog NYTBIL(TIERS,SOCIETE,SITE,TIERSTYP,PORTEFEUILLE)
Value Char    TIERS(),SOCIETE(),SITE()
Value Integer TIERSTYP,PORTEFEUILLE

Local Char DEVLED(GLONCUR)

Onerrgo ERREUR From CONTROLE
Local Mask NYTBILZOOM[DIA]
Local File PAYMENTH , TABCUR , TABPAYTYP , COMPANY , PAYACCNUM
&          , GACCENTRYD
Onerrgo
If GERREUR : GERREUR=0 : End : Endif
Local Char    CRITERE(255)
# Critères :
# - Etape mise en portefeuille effectuée
# - Portefeuille non déjà dévalorisé
# - Règlement du tiers, de la société et éventuellement du site demandé
# - Si client : recette
# - Si fournisseur : dépense

Gosub CHARG_PYH

If [M:DIA]NBRLIG=0
 # Pas d'effet non échu
 Call ERREUR(mess(49,121,1)) From GESECRAN
Else
 # Zoom
 #Call AFFICHE(mess(7,100,1)) From GESECRAN
 Call AFFWIN(mess(7,100,1),"FBILZOOM") From GESECRAN
Endif
End

###################################################################

# Impayés
Subprog NOTPAY(TIERS,SOCIETE,SITE)
Value Char    TIERS(),SOCIETE(),SITE()

Onerrgo ERREUR From CONTROLE
Local Mask NOTPAYZOOM[NPZ]
Local File PAYMENTH , TABCUR , PAYACCNUM , GACCENTRYD , ATABDIV , ATEXTRA
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

Local Char    CRITERE(255)

# Critères :
# - Règlement impayé
# - Règlement du tiers, de la société et éventuellement du site demandé
[L]CRITERE = "STAFLG(10)=2 & BPR='"+[L]TIERS+"'"

If [L]SOCIETE<>""
 [L]CRITERE -= "& CPY='"+[L]SOCIETE+"'"
Endif

If [L]SITE<>""
 [L]CRITERE -= "& FCY='"+[L]SITE+"'"
Endif

nolign = 1
Raz [M:NPZ]
Filter [PYH] Where evalue(CRITERE) Order By CPY;ACCDAT;NUM
For [F:PYH]
 Call LECTURE("ADI",[F:PYH]RENNOTPAY,"310") From CONTOBJ
 Filter [F:PAN] Where TYPNUM=3 & NUM=[F:PYH]NUM & STA=11
&               & find(TYPVCR,"L","N")
 For [F:PAN]
  [M:NPZ] = [F:PYH]
  Call LECTEXTRA([M:NPZ]MOTIF(nolign-1),"ATABDIV","LNGDES","310",[F:PYH]RENNOTPAY) From ATEXTRA
  Read [F:DAE]DAE2 = [F:PAN]ACCNUM
  If fstat = 0
   [M:NPZ]ACCDAT(nolign-1) = [F:DAE]ACCDAT
   [M:NPZ]DES(nolign-1)    = [F:DAE]DES
   [M:NPZ]PIECE(nolign-1)  = [F:DAE]NUM
   [M:NPZ]NBRLIG += 1
   nolign += 1
   If dim([M:NPZ]PIECE)<=nolign
    Call ERREUR(mess(26,100,1)) From GESECRAN : Break 2
   Endif
  Endif
 Next
Next
Filter [F:PYH]
Filter [F:PAN]

If [M:NPZ]NBRLIG=0
 # Pas d'impayé
 Call ERREUR(mess(50,121,1)) From GESECRAN
Else
 # Zoom
 Call AFFWIN(mess(7,100,1),"FNOTPAYZOM") From GESECRAN
Endif
End

###################################################################

# Prorogations
Subprog PROROG(TIERS,SOCIETE,SITE,TIERSTYP)
Value Char    TIERS(),SOCIETE(),SITE()
Value Integer TIERSTYP

Onerrgo ERREUR From CONTROLE
Local Mask PROROGZOOM[PRZ]
Local File TABCUR , GACCENTRYD , PAYMENTH, PROROG
#Local File PROROG Order By Key CLE = NUM;ACCDAT
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

Local Char    CRITERE(255)

# Critères :
# - Prorogation du tiers demandé
[L]CRITERE = "BPR='"+[L]TIERS+"' & TYP="+num$([L]TIERSTYP)

nolign = 1
Raz [M:PRZ]
Filter [PRO] Where evalue(CRITERE)
Link [PRO] With [F:PYH]PYH0=[F:PRO]NUM  As [LNK] Order By Key CLE = [F:PYH]CPY;[F:PRO]NUM;[F:PRO]NEWDUDDAT

For [F:LNK]CLE(1)
 If ([L]SOCIETE="" or [F:PYH]CPY=[L]SOCIETE) & ([L]SITE="" or [F:PYH]FCY=[L]SITE)
  For [F:LNK]CLE
  [M:PRZ] = [F:PRO]
  [M:PRZ]CPY(nolign-1) = [F:PYH]CPY
   For I=0 To 9
    If I=0
     [M:PRZ]OLDDUDDAT(nolign-1) = [F:PRO]OLDDUDDAT
     [M:PRZ]NEWDUDDAT(nolign-1) = [F:PRO]NEWDUDDAT
     [M:PRZ]CREDAT(nolign-1)    = [F:PRO]CREDAT
     [M:PRZ]CREUSR(nolign-1)    = [F:PRO]CREUSR
    Endif
    If [F:PRO]ACCNUM(I)<>0
     Read [F:DAE]DAE2 = [F:PRO]ACCNUM(I)
     If fstat = 0
      [M:PRZ]TYPPIECE(nolign-1) = [F:DAE]TYP
      [M:PRZ]PIECE(nolign-1)    = [F:DAE]NUM
     Endif
    Elsif I<>0
     Break
    Endif
    [M:PRZ]NBRLIG += 1
    nolign += 1
    If dim([M:PRZ]PIECE)<=nolign
     Call ERREUR(mess(26,100,1)) From GESECRAN : Break 3
    Endif
   Next
  Next
 Endif
Next
Filter [F:PRO]

If [M:PRZ]NBRLIG=0
 # Pas de prorogation
 Call ERREUR(mess(51,121,1)) From GESECRAN
Else
 # Zoom
 Call AFFWIN(mess(7,100,1),"FPROROGZOM") From GESECRAN
Endif
End

##########################################
## Etiquettes du masque NYTBILZOOM
##########################################
Subprog IB_NBRLIG
Raz GBOUT1,GBOUT2,GBOUT3
If [M]NBRLIG<>0
 GBOUT1 = mess(27,117,1)   # Règlement
Endif
If dim([M]FRMNUM)>0 & [M]FRMNUM(nolign-1)<>"" & [M]FRMFLG(nolign-1)=1
 GBOUT2 = mess(126,117,1)   # Bordereau
Endif
If dim([M]FRMNUM)>0 & [M]FRMNUM(nolign-1)<>"" & [M]FRMFLG(nolign-1)=2
 GBOUT3 = mess(123,117,1)   # Domiciliation
Endif
End

$AB_NBRLIG
SAVCONS=GCONSULT
GCONSULT=2
SAVGFONC1=GFONC1
Global Char GBIDC4(30), GBIDC5(30), GBIDC6(30)
Raz GBIDC1,GBIDC2,GBIDC3,GBIDC4, GBIDC5, GBIDC6
Case ACTION
 When "AB1_NBRLIG"
  GBIDC4 = "PAY"
  GBIDC5 = [M]NUM(nolign-1)
 When "AB2_NBRLIG"
  GBIDC4 = "FRM"
  GBIDC5 = [M]FRMNUM(nolign-1)
  GBIDC6 = num$([M]FRMFLG(nolign-1))
 When "AB3_NBRLIG"
  GBIDC4 = "PAB"
  GBIDC5 = [M]FRMNUM(nolign-1)
  GBIDC6 = num$([M]FRMFLG(nolign-1))
Endcase

Return

$BB_NBRLIG
GCONSULT=SAVCONS
GFONC1=SAVGFONC1
Kill GBIDC4, GBIDC5, GBIDC6
Return

