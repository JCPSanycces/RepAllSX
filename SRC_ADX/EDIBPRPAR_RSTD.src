#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Representation Class EDIBPRPAR                                              #
# Author : RBA + JUCON                                                               #
###############################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AQUERY_TRANS_AFTER"    : Gosub AQUERY_TRANS_AFTER
      Endcase
    When "EBP"
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub EBP_AREAD_AFTER
      Endcase
    When "EBP.EBPD"
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub EBP_EBPD_AREAD_AFTER
        When Default
      Endcase

   Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "EBP.BPANUM"      #SAM 110811
      Case [L]ARULE
        When "PROPAGATE" : Gosub EBP_BPANUM_PROPAGATE
      Endcase
    When "EBP.PUBENT"      #SAM 112148
      Case [L]ARULE
        When "INIT"      : Gosub EBP_PUBENT_INIT
        When "PROPAGATE" : Gosub EBP_PUBENT_PROPAGATE
      Endcase
        When "EBP.PUBENTCH"      #X3-74782 Chorus new fields (JUCON 06/02/2018)
      Case [L]ARULE
        When "PROPAGATE" : Gosub EBP_PUBENTCH_PROPAGATE
      Endcase
    When "EBP.IDTYPE"      #SAM 110811
      Case [L]ARULE
        When "PROPAGATE" : Gosub EBP_IDTYPE_PROPAGATE
      Endcase
  Endcase
Return

#####################################################################

$EBP_BPANUM_PROPAGATE
  If this.BPANUM<>""
    Local File BPARTNER [BPR]
    Read[BPR]BPR0=this.BPANUM
    If !fstat
      this.APARENT.FISCODE=[F:BPR]CRN
      this.APARENT.VATNUM= [F:BPR]EECNUM
    Endif
    LogicClose File [BPR]

    Call EBP_EBP_DISPLAY(this)  #X3-74782 Chorus new fields (JUCON 06/02/2018)
  Endif
Return

#####################################################################

$EBP_PUBENT_INIT
  If func AFNC.ACTIV("KSP")>0 and this.BPANUM<>"" #X3-74782 Chorus new fields (JUCON 06/02/2018)
    Local Integer I
    For I = 1 To maxtab (this.C_EBPD)
      Call EBP_EBPD_DISPLAY(this.C_EBPD(I))
    Next I
  Endif
Return

$EBP_PUBENT_PROPAGATE
  If func AFNC.ACTIV("KSP")>0 and this.BPANUM<>"" #X3-74782 Chorus new fields (JUCON 06/02/2018)
    Local Integer I
    For I = 1 To maxtab (this.C_EBPD)
      Call EBP_EBPD_DISPLAY(this.C_EBPD(I))
    Next I
  Endif
Return
#End SAM 112148

#####################################################################
#Ini X3-74782 Chorus new fields (JUCON 06/02/2018)
$EBP_PUBENTCH_PROPAGATE
  If func AFNC.ACTIV("KFR")>0 and this.BPANUM<>""
    Call EBP_EBP_DISPLAY(this)
  Endif
Return
#End X3-74782 Chorus new fields (JUCON 06/02/2018)

#####################################################################
$EBP_IDTYPE_PROPAGATE
  Call EBP_EBP_DISPLAY(this)
Return
#End SAM 110811

#********************************************************************
# Method AREAD_AFTER
#********************************************************************
#*
#*!
$EBP_AREAD_AFTER
  Local Integer WOK
  Local Char WBPRNAM(35)
  WOK = func EDILIBB.GET_BPRNAM(this.BPANUM, WBPRNAM)
  this.BPRNAM = WBPRNAM

  Local Char WBPADES(30)
  WOK = func EDILIBB.GET_BPADES(this.BPATYP, this.BPANUM, this.BPAADD, WBPADES)
  this.BPADES = WBPADES

  this.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.PARCOD,"PARDES")

  #Init SAM 110811
  Local Integer WOK, WSIGN
  Local Char WPROP(15), WPROP1(15)

  WPROP = "$isDisabled"

  Local File BPARTNER [BPR]
  Read[BPR]BPR0=this.BPANUM
  If !fstat
    this.APARENT.FISCODE= [F:BPR]CRN
    this.APARENT.VATNUM = [F:BPR]EECNUM
  Endif
  LogicClose File [BPR]

  WOK = fmet this.ASETATTRIBUTE('FISCODE', WPROP, 'true')
  WOK = fmet this.ASETATTRIBUTE('LOCODE' , WPROP,'false')
  WOK = fmet this.ASETATTRIBUTE('GLN'    , WPROP,'false')
  WOK = fmet this.ASETATTRIBUTE('DUNS',    WPROP,'false')
  WOK = fmet this.ASETATTRIBUTE('VATNUM' , WPROP, 'true')

  Call EBP_EBP_DISPLAY(this)

  If func AFNC.ACTIV("KSP")>0 and this.BPANUM<>""
    For I = 1 To maxtab (this.C_EBPD)
      Call EBP_EBPD_DISPLAY(this.C_EBPD(I))
    Next I

    Local File EDIBPRPAR [EBP]
    Read [EBP]EBP0=this.BPATYP;this.BPANUM;this.BPAADD;this.PARCOD
    If !fstat and this.C_EBPD<>null
      For I=1 To 4
        this.C_EBPD(I).CENROL=[F:EBP]CENROL(I-1)
        this.C_EBPD(I).CODE  =[F:EBP]CODE  (I-1)
        this.C_EBPD(I).DES   =[F:EBP]DES   (I-1)
      Next
    Endif
    LogicClose File [EBP]
  Endif
  #End SAM 112148
# INI X3-74782 Chorus new fields (JUCON 06/02/2018)
  If func AFNC.ACTIV("KFR")>0 and this.BPANUM<>""
    Local File EDIBPRPAR [EBP]
    Read [EBP]EBP0=this.BPATYP;this.BPANUM;this.BPAADD;this.PARCOD
    If fstat=[V]CST_AOK
      this.CHBPCSERCOD= [F:EBP]CHBPCSERCOD
      this.CHBPCSERNAM= [F:EBP]CHBPCSERNAM
      this.CHENGNUMENG= [F:EBP]CHENGNUMENG
    Endif
  Endif
# END X3-74782 Chorus new fields (JUCON 06/02/2018)


Return

#********************************************************************
# Method EBP_EBPD_AREAD_AFTER
#********************************************************************
#*
#*!
$EBP_EBPD_AREAD_AFTER
   Call EBP_EBPD_DISPLAY(this)
Return


#********************************************************************
# Subprog EBP_EBP_DISPLAY
#********************************************************************
#
#* @param WOBJECT
#*!
Subprog EBP_EBP_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local Integer WOK
  Local Char WPROP(15)

  WPROP = "$isDisabled"

  Case WOBJECT.IDTYPE
    When 6       :  WOK = fmet WOBJECT.ASETATTRIBUTE('EXCEDICOD', WPROP, 'false')
    When Default :  WOK = fmet WOBJECT.ASETATTRIBUTE('EXCEDICOD', WPROP, 'true')
  Endcase
#INI X3-74782 Chorus new fields (JUCON 06/02/2018)
  If WOBJECT.BPANUM<>""
    Local File BPARTNER [BPR]
    Read [BPR]BPR0=WOBJECT.BPANUM
    If fstat=[V]CST_AOK
      Case [F:BPR]CRY
        When  "ES"
          WOK = fmet WOBJECT.ASETATTRIBUTE('PUBENT'     , WPROP, 'false')
          WOK = fmet WOBJECT.ASETATTRIBUTE('PUBENTCH'   , WPROP, 'true')
          WOK = fmet WOBJECT.ASETATTRIBUTE('CHBPCSERCOD', WPROP, 'true')
          WOK = fmet WOBJECT.ASETATTRIBUTE('CHBPCSERNAM', WPROP, 'true')
          WOK = fmet WOBJECT.ASETATTRIBUTE('CHENGNUMENG', WPROP, 'true')
        When "FR"
          WOK = fmet WOBJECT.ASETATTRIBUTE('PUBENT'     , WPROP, 'true')
          WOK = fmet WOBJECT.ASETATTRIBUTE('PUBENTCH'   , WPROP, 'false')
          If WOBJECT.PUBENTCH=2
            WOK = fmet WOBJECT.ASETATTRIBUTE('CHBPCSERCOD', WPROP, 'false')
            WOK = fmet WOBJECT.ASETATTRIBUTE('CHBPCSERNAM', WPROP, 'false')
            WOK = fmet WOBJECT.ASETATTRIBUTE('CHENGNUMENG', WPROP, 'false')
          Else
            WOK = fmet WOBJECT.ASETATTRIBUTE('CHBPCSERCOD', WPROP, 'true')
            WOK = fmet WOBJECT.ASETATTRIBUTE('CHBPCSERNAM', WPROP, 'true')
            WOK = fmet WOBJECT.ASETATTRIBUTE('CHENGNUMENG', WPROP, 'true')
          Endif
        When Default
          WOK = fmet WOBJECT.ASETATTRIBUTE('PUBENT'     , WPROP, 'true')
          WOK = fmet WOBJECT.ASETATTRIBUTE('PUBENTCH'   , WPROP, 'true')
          WOK = fmet WOBJECT.ASETATTRIBUTE('CHBPCSERCOD', WPROP, 'true')
          WOK = fmet WOBJECT.ASETATTRIBUTE('CHBPCSERNAM', WPROP, 'true')
          WOK = fmet WOBJECT.ASETATTRIBUTE('CHENGNUMENG', WPROP, 'true')
          WOK = fmet WOBJECT.ASETATTRIBUTE('CENROL',      WPROP, 'true')
          WOK = fmet WOBJECT.ASETATTRIBUTE('CODE'  ,      WPROP, 'true')
          WOK = fmet WOBJECT.ASETATTRIBUTE('DES'   ,      WPROP, 'true')
      Endcase
    Else
      WOK = fmet WOBJECT.ASETATTRIBUTE('PUBENT'     , WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('PUBENTCH'   , WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('CHBPCSERCOD', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('CHBPCSERNAM', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('CHENGNUMENG', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('CENROL',      WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('CODE'  ,      WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('DES'   ,      WPROP, 'true')
    Endif
    LogicClose File [BPR]
  Else
    WOK = fmet WOBJECT.ASETATTRIBUTE('PUBENT'     , WPROP, 'true')
    WOK = fmet WOBJECT.ASETATTRIBUTE('PUBENTCH'   , WPROP, 'true')
    WOK = fmet WOBJECT.ASETATTRIBUTE('CENROL',      WPROP, 'true')
    WOK = fmet WOBJECT.ASETATTRIBUTE('CODE'  ,      WPROP, 'true')
    WOK = fmet WOBJECT.ASETATTRIBUTE('DES'   ,      WPROP, 'true')
    WOK = fmet WOBJECT.ASETATTRIBUTE('CHBPCSERCOD', WPROP, 'true')
    WOK = fmet WOBJECT.ASETATTRIBUTE('CHBPCSERNAM', WPROP, 'true')
    WOK = fmet WOBJECT.ASETATTRIBUTE('CHENGNUMENG', WPROP, 'true')
  Endif
  #END X3-74782 Chorus new fields (JUCON 06/02/2018)
End
#End SAM 110811

#********************************************************************
# Subprog EBP_C_EBPD_DISPLAY
#********************************************************************
#
#* @param WOBJECT
#*!
Subprog EBP_EBPD_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local Integer WOK
  Local Char WPROP(15)

  WPROP = "$isDisabled"

  Case WOBJECT.APARENT.PUBENT
   When 1:
     WOK = fmet WOBJECT.ASETATTRIBUTE('CENROL', WPROP, 'true')
     WOK = fmet WOBJECT.ASETATTRIBUTE('CODE'  , WPROP, 'true')
     WOK = fmet WOBJECT.ASETATTRIBUTE('DES'   , WPROP, 'true')
   When 2:
     WOK = fmet WOBJECT.ASETATTRIBUTE('CENROL', WPROP, 'true')
     WOK = fmet WOBJECT.ASETATTRIBUTE('CODE'  , WPROP, 'false')
     WOK = fmet WOBJECT.ASETATTRIBUTE('DES'   , WPROP, 'false')
   Endcase
End
#End SAM 112148

#********************************************************************
# Method AQUERY_TRANS_AFTER
#********************************************************************
#*
#*!
$AQUERY_TRANS_AFTER
  Local Integer WOK

  Local Char WBPRNAM(35)
  WOK = func EDILIBB.GET_BPRNAM(this.EBP.BPANUM, WBPRNAM)
  this.EBP.BPRNAM = WBPRNAM

  Local Char WBPADES(30)
  WOK = func EDILIBB.GET_BPADES(this.EBP.BPATYP, this.EBP.BPANUM, this.EBP.BPAADD, WBPADES)
  this.EBP.BPADES = WBPADES

  this.EBP.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.EBP.PARCOD,"PARDES")

Return

