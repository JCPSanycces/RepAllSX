#FRLAA - 2016-12-09 - REQUIREMENT X3-11647 US X3-12771 - START
$ACTION
  Case [L]ACTION
    When "INIT"       : Gosub INIT
    When "DEBUT"      : Gosub DEBUT
    When "OK"         : Gosub OK
    When "END"        : FIN = 1
    When "APRES_MODIF": Gosub APRES_MODIF
  Endcase
Return

$INIT
Local Mask EPAGPP    [EPAPP]   :   Raz   [EPAPP]
Return

#Defualt date to current paymonth
$DEBUT
[M:EPAPP]PAYMON = eomonth(GMOIPAY)
#Grizo [M:EPAPP]LEG

Diszo [M:EPAPP]CPY
Diszo [M:EPAPP]FCY
Grizo [M:EPAPP]ALLFCY
Diszo [M:EPAPP]SRV
Diszo [M:EPAPP]PRF
Diszo [M:EPAPP]POT
Diszo [M:EPAPP]JOBPOT

Affzo [M:EPAPP]
Return

$OK
FIN = 1 : GOK = 1
Gosub EXEC
Return

$EXEC
Local Integer RETVAL : RETVAL = 0
#Creating/Updating records

Local Char CREFILTER(255) : CREFILTER = "1=1"
Gosub CREATE_FILTER

[L]RETVAL =  func EPAFUNCTIONS.EPAPAYPLAN([M:EPAPP]PAYMON,CREFILTER)

Return

