$APRES_MODIF
If [M:EPAPP]LEG="" and COUZON<>"ALLCPY" and COUZON<>"PAYMON" Then
   Diszo [M]SRV
   GERR  = 1
   GMESSAGE = mess(232,143,1)
   zonsui = "[M:EPAPP]LEG" #Put the focus on the field.
   #FIN = 0 # Instruct the supervisor to keep the window open
   GOK = 0
   Return
Endif

Return


Subprog AM_ALLPOT(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
   Raz [M:EPAPP]POT
   Grizo [M:EPAPP]POT
Else
  Actzo [M:EPAPP]POT
Endif

Affzo [M:EPAPP]
End

Subprog AM_ALLJOBPOT(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
   Raz [M:EPAPP]JOBPOT
   Grizo [M:EPAPP]JOBPOT
Else
  Actzo [M:EPAPP]JOBPOT
Endif

Affzo [M:EPAPP]
End

$CREATE_FILTER

If [M:EPAPP]ALLFCY = 1 and [M:EPAPP]FCY <> ""
  CREFILTER -= "& [F:HRCTR]ETRFCY = '"+[M:EPAPP]FCY+"'"
Endif

If [M:EPAPP]ALLCPY = 1 and [M:EPAPP]CPY <> "" and [M:EPAPP]FCY = ""
  CREFILTER -= "& [F:FCY]LEGCPY = '"+[M:EPAPP]CPY+"'"
Endif

If [M:EPAPP]ALLSRV = 1 and [M:EPAPP]SRV <> ""
  CREFILTER -= "& [F:HRCTR]ETRSRV = '"+[M:EPAPP]SRV+"'"
Endif

If [M:EPAPP]ALLPRF = 1 and [M:EPAPP]PRF <> ""
  CREFILTER -= "& [F:HRCTR]PROPRF = '"+[M:EPAPP]PRF+"'"
Endif

If [M:EPAPP]ALLPOT = 1 and [M:EPAPP]POT <> ""
  CREFILTER -= "& [F:HRCTR]POT = '"+[M:EPAPP]POT+"'"
Endif

If [M:EPAPP]ALLJOBPOT = 1 and [M:EPAPP]JOBPOT <> ""
  CREFILTER -= "& [F:HRCTR]JOBPOT = '"+[M:EPAPP]JOBPOT+"'"
Endif

Return



Subprog AM_PAYMON(VALEUR)
Variable Date    VALEUR
VALEUR = eomonth(VALEUR)
End


#FRLAA - 2016-12-09 - REQUIREMENT X3-11647 US X3-12771 - END


