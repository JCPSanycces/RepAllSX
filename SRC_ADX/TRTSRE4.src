#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################################################
#   Traitement de gestion de la consultation des solutions trouvées       Module CRM    septembre 2000   #
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "FIR"          : Gosub PREMIER
    When "PRE"          : Gosub PRECEDENT
    When "SUI"          : Gosub SUIVANT
    When "LAS"          : Gosub DERNIER
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GILASTNOL
Global Integer GIHBDISP
Global Integer GIFIRSOL
Global Integer GINBFSOL

  GILASTNOL = 0
  GIHBDISP = 0
  GIFIRSOL = 0
  GINBFSOL = 0
  Gosub CMNOUVRE
Return

##########################################################################################################
$CMNOUVRE
Global Char GSZSOLKEY(GLONVCR)
Global Char G8
Global Char G9(30)(25)

  GSZSOLKEY = ""
  G8 = ""
  Raz G9
  If !clalev([F:SOR]) : Local File SOLRESULT [SOR] : Endif
  If !clalev([F:HD3]) : Local File HD3CLOB [HD3] : Endif
  If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Local Integer ISOPEN

  ISOPEN = 0
  If GPILNAV > 1 Then
    Case GNAVIG(GPILNAV-1)
      When "GESSRE"
        Call ISFUNOPEN("GESSOL", ISOPEN) From CRMUTIL140
        If ISOPEN Then
          ETABOU(GSPE1) = 0
        Else
          ETABOU(GSPE1) = 1
        Endif
      When "FUNHDKAGD"
        Call ISFUNOPEN("GESSOL", ISOPEN) From CRMUTIL140
        If ISOPEN Then
          ETABOU(GSPE1) = 0
        Else
          ETABOU(GSPE1) = 1
        Endif
      When Default
        ETABOU(GSPE1) = 0
    Endcase
  Else
    ETABOU(GSPE1) = 0
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  Call TEMPON("R") From GESECRAN
  Gosub CMNDEBUT
  Call LOADRES(0)
  GIHBDISP = 1
  Call TEMPOFF From GESECRAN
Return

##########################################################################################################
$CMNDEBUT
  Gosub SEARCHSOL
  Call CLEANSOR
Return

##########################################################################################################
$PREMIER
  Call LOADRES(1)
Return

##########################################################################################################
$PRECEDENT
  Call LOADRES(2)
Return

##########################################################################################################
$SUIVANT
  Call LOADRES(3)
Return

##########################################################################################################
$DERNIER
  Call LOADRES(4)
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  If GIHBDISP Then
    Gosub CMNFINSAI
    #Nettoie l'écran avant de partir.
    Raz [M:SRE4]
  Endif
  Kill GILASTNOL
  Kill GIHBDISP
  Kill GIFIRSOL
  Kill GINBFSOL
  Gosub CMNFINSAI2
Return

##########################################################################################################
$CMNFINSAI
  #Vide la table des résultats si elle a été remplie
  If !clalev([F:SOR]) : Local File SOLRESULT [SOR] : Endif
  Trbegin [SOR]
  Delete [SOR] Where [F:SOR]SSS = GIDENT and [F:SOR]TYP = "SOL"
  If fstat Then
    Rollback
  Else
    Commit
  Endif
Return

##########################################################################################################
$CMNFINSAI2
  Kill GSZSOLKEY
  Kill G8
  Kill G9
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
#
#  LOADRES     : Charge les solutions trouvées dans la fenêtre de résultat.
#  SEARCHSOL   : Exécute la recherche des solutions selon les critères saisis.
#  LOOKUP_SOL  : Programme d'exécution d'une recherche par hash-code pour une clé donnée.
#  DO_STRSEA   : Effectue une recherche au sein des champs texte des solutions.
#  CLEANSOR    : Nettoie la table SOLRESULT d'éventuelles sorties par plantage.
#
########################################################################################################
Subprog LOADRES(IWHATTODO)
Value Integer IWHATTODO

Local Integer ITER
Local Integer ITER2
Local Integer IZ
Local Integer IX
Local Integer IMAXREC
Local Integer ISRE4NOL

  ISRE4NOL = 0
  ITER = 0
  ITER2 = 0
  IZ = 0
  IX = 0
  IMAXREC = 0
  #0 : Premier chargement
  #1 : Premier
  #2 : Précédent
  #3 : Suivant
  #4 : Dernier
  Case IWHATTODO
    When 1
      IX = 0
      GIFIRSOL = 0
      If GINBFSOL < dim([M:SRE4]NUM) Then
        End
      Endif
    When 2
      If GINBFSOL < dim([M:SRE4]NUM) Then
        End
      Endif
      IMAXREC = GIFIRSOL - dim([M:SRE4]NUM)
      If IMAXREC <= 0 Then
        IX = 0
      Else
        IX = GIFIRSOL - dim([M:SRE4]NUM)
      Endif
    When 3
      If GINBFSOL < dim([M:SRE4]NUM) Then
        End
      Endif
      IMAXREC = GIFIRSOL + dim([M:SRE4]NUM) + dim([M:SRE4]NUM) - 1
      If GINBFSOL < IMAXREC Then
        IX = GINBFSOL - dim([M:SRE4]NUM)
      Else
        IX = GIFIRSOL + dim([M:SRE4]NUM)
      Endif
    When 4
      If GINBFSOL < dim([M:SRE4]NUM) Then
        End
      Endif
      IX = GINBFSOL - dim([M:SRE4]NUM)
  Endcase
  Raz [M:SRE4]
  GIFIRSOL = IX
  If GIHBDISP Then
    Filter [SOR] Where [F:SOR]SSS = GIDENT and [F:SOR]TYP = "SOL" and [F:SOR]NUM >= GIFIRSOL
  Else
    Filter [SOR] Where [F:SOR]SSS = GIDENT and [F:SOR]TYP = "SOL"
  Endif
  For [SOR]SOR2
    If GIHBDISP Then
      If IZ > dim([M:SRE4]NUM)-1 Then
        Break
      Endif
      If [F:SOR]SOLNUM <> "" Then
        [M:SRE4]NUM(IZ) = [F:SOR]SOLNUM
        [M:SRE4]CLSNUM(IZ) = [F:SOR]NUM
        Read [SOL]SOL0=[M:SRE4]NUM(IZ)
        If fstat Then
          [M:SRE4]DAT(IZ) = [00/00/00]
          [M:SRE4]AUS(IZ) = ""
        Else
          [M:SRE4]DAT(IZ) = [F:SOL]CREDAT
          [M:SRE4]AUS(IZ) = [F:SOL]CREUSR
        Endif
        If IZ = 0 Then
          ISRE4NOL = IZ
          Gosub SETNEWSOL From SUBSRE4
        Endif
        IZ +=1
      Endif
    Else
      If IZ <= dim([M:SRE4]NUM)-1 Then
        If [F:SOR]SOLNUM <> "" Then
          [M:SRE4]NUM(IZ) = [F:SOR]SOLNUM
          [M:SRE4]CLSNUM(IZ) = [F:SOR]NUM
          Read [SOL]SOL0=[M:SRE4]NUM(IZ)
          If fstat Then
            [M:SRE4]DAT(IZ) = [00/00/00]
            [M:SRE4]AUS(IZ) = ""
          Else
            [M:SRE4]DAT(IZ) = [F:SOL]CREDAT
            [M:SRE4]AUS(IZ) = [F:SOL]CREUSR
          Endif
          If IZ = 0 Then
            ISRE4NOL = IZ
            Gosub SETNEWSOL From SUBSRE4
          Endif
          IZ +=1
        Endif
      Endif
      GINBFSOL += 1
    Endif
  Next
  Filter [SOR]
  #
  GSZSOLKEY = [M:SRE4]NUM(0)
  G8 = [M:SRE4]NUM(0)
  Raz G9
  Read [SOL]SOL0=G8
  If !fstat Then
    For ITER = 0 To dim([F:SOL]CODSOL)-1
      If [F:SOL]CODSOL(ITER) <> "" Then
        G9(ITER2) = [F:SOL]CODSOL(ITER)
        ITER2 += 1
      Endif
    Next
  Endif
  [M:SRE4]NBSOL = IZ
  Affzo [M:SRE4]1-99
End

###############################################################################################
$ADD_AND_SEARCHSOL
  # FGR 13/11/2008 : X3SUIVI50281
  If IINDSZWHERE > 0 Then
    SZWHERE(IINDSZWHERE) = "and"
  Endif
Return

###############################################################################################
$SEARCHSOL
Local Integer I
Local Integer INBF
#Variables pour recherche par mots.
Local Integer INBRECC
#Variables pour recherche sur filtre
Local Integer IARRNBLIN
Local Integer INBPBL
Local Integer INBAUS
Local Integer ISTS
Local Char SZPBLNUM(GLONVCR)(6)
Local Char SZAUSNUM(GLONAUS)(6)
  #Autres variables
Local Integer ICONTINUE
Local Char SZLIB5X(250)
Local Integer ISEAMATCH
Local Integer IUSEFILTER
Local Char SZWORDSEAMASK
  # FGR 13/11/2008 : X3SUIVI50281
Local Char SZWHERE(250)(20)
Local Integer IINDSZWHERE

  #Initialisation
  Raz SZWHERE
  IINDSZWHERE = 0
  I = 0
  INBF = 0
  #Variables pour recherche par mots
  IUSEFILTER = 0
  SZWORDSEAMASK = ""
  ISEAMATCH = 0
  ICONTINUE = 0
  #Variables recherche sur filtre
  IARRNBLIN = 0
  INBPBL = 0
  INBAUS = 0
  ISTS = 0
  Raz SZPBLNUM
  Raz SZAUSNUM
  If type([M:SRE4]SOLFLG) > 0  Then
    INBRECC = 0
  Else
    INBRECC = 1
  Endif
  Call USEFILTER(IUSEFILTER)
  Call SETWRDSEA(SZWORDSEAMASK)
  #On contrôle si des critères ont été saisis.
  If IUSEFILTER = 0 Then
    If SZWORDSEAMASK = "00000" Then
      GMESSAGE = mess(838,182,1) #Aucun critère de recherche n'a été saisi.
      GERR = 2
      FIN = 1
      Return
    Endif
  Endif
  If IUSEFILTER = 0 Then
    #Recherche sans critères partie droite
    #Recherche plein texte
    Call DO_STRSEA(SZWORDSEAMASK, INBRECC)
  Endif
  If IUSEFILTER = 1 Then
    #Utilisation des critères partie droite
    ICONTINUE = 1
    #Recherche par mots-clé
    If mid$(SZWORDSEAMASK, 5, 1) = "1" Then
      If [M:SRE3]KEYWRD <> "" Then
        SZLIB5X = [M:SRE3]KEYWRD
        Call LOOKUP_SOL(1, "SOLKWD", SZLIB5X, INBRECC)
      Endif
      If left$(SZWORDSEAMASK, 4) = "0000" Then
        ICONTINUE = 0
      Endif
    Endif
    If ICONTINUE Then
      #Contrôle du tableau des familles de compétence.
      If [M:SRE3]NBPBL <> 0 Then
        For I = 0 To [M:SRE3]NBPBL-1
          If [M:SRE3]PBLGRP(I) <> "" Then
            SZPBLNUM(I) = [M:SRE3]PBLGRP(I)
          Endif
        Next
        #Calcul le nombre réél de familles de compétences saisies
        INBPBL = 0
        For I = 0 To dim(SZPBLNUM)-1
          If SZPBLNUM(I) = "" Then
            Break
          Endif
          INBPBL += 1
        Next
      Endif
      #Contrôle du tableau des collaborateurs
      If [M:SRE3]NBAUS <> 0 Then
        For I = 0 To [M:SRE3]NBAUS-1
          If [M:SRE3]AUS(I) <> "" Then
            SZAUSNUM(I) = [M:SRE3]AUS(I)
          Endif
        Next
        #Calcul le nombre réél de collaborateurs saisis
        INBAUS = 0
        For I = 0 To dim(SZAUSNUM)-1
          If SZAUSNUM(I) = "" Then
            Break
          Endif
          INBAUS += 1
        Next
      Endif
      ISTS = 1
      # =============================
      # FGR 13/11/2008 : X3SUIVI50281
      Raz SZWHERE
      IINDSZWHERE = 0
      If [M:SRE3]CREDATFLG = 2 Then
        Gosub ADD_AND_SEARCHSOL
        SZWHERE(IINDSZWHERE) = SZWHERE(IINDSZWHERE) - "[F:SOL]CREDAT >= [M:SRE3]STRDAT and [F:SOL]CREDAT <= [M:SRE3]ENDDAT"
        IINDSZWHERE += 1
      Endif
      If INBAUS > 0 Then
        Gosub ADD_AND_SEARCHSOL
        SZWHERE(IINDSZWHERE) = SZWHERE(IINDSZWHERE) - "find([F:SOL]CREUSR, SZAUSNUM)<>0"
        IINDSZWHERE += 1
      Endif
      If INBPBL > 0 Then
        Gosub ADD_AND_SEARCHSOL
        SZWHERE(IINDSZWHERE) = SZWHERE(IINDSZWHERE) - "find([F:SOL]PBLGRP, SZPBLNUM)<>0"
        IINDSZWHERE += 1
      Endif
      If IINDSZWHERE = 0 Then
        ISTS = 0
      Endif
      #Enregistrement du résultat de la recherche
      If ISTS Then
        Filter [SOL] Where evalue(SZWHERE) Order By [F:SOL]CREDAT Desc
        For [SOL]
          Read [SOR]SOR3=[F:SOL]NUM;GIDENT;"SOL"
          If fstat Then
            ISEAMATCH = 1
            If left$(SZWORDSEAMASK, 4) <> "0000" Then
              #On complète avec la recherche plein texte
              Call CHK_STRSEA([F:SOL]NUM, SZWORDSEAMASK, [F:SOL]TTR, [F:SOL]PBLDES, [F:SOL]SOLDES, ISEAMATCH)
            Endif
            If ISEAMATCH Then
              Call DEBTRANS From GLOCK
              Trbegin [SOR]
              Raz [F:SOR]
              [F:SOR]          = [F:SOL]
              [F:SOR]CREDATSOL = [F:SOL]CREDAT
              [F:SOR]SOLNUM    = [F:SOL]NUM
              [F:SOR]NUM       = INBRECC
              [F:SOR]SSS       = GIDENT
              [F:SOR]TYP       = "SOL"
              [F:SOR]CREDAT    = date$
              [F:SOR]CREDAT    = date$
              If [F:SOL]CODSOL(0) <> "" Then
                [F:SOR]MORSOL  = "+"
              Endif
              Write [SOR]
              If fstat Then
                GMESSAGE = mess(100,141,1) #Erreur création
                GERR = 1
                FIN = 1
                Rollback
                # FGR 08/02/2010 : X3SUIVI60986
                #Return
                Break
              Else
                Commit
                INBRECC += 1
              Endif
            Endif
          Endif
        Next
        Filter [SOL]
        If FIN = 1 Then
          # FGR 08/02/2010 : X3SUIVI60986
          Return
        Endif
      Else
        GMESSAGE = mess(838,182,1) #Aucun critère de recherche n'a été saisi.
        GERR = 2
        FIN = 1
        Return
      Endif
    Endif
  Endif
  INBF = 0
  Filter [SOR] Where [F:SOR]SSS = GIDENT and [F:SOR]TYP = "SOL"
  For [SOR] SOR2
    INBF += 1
    Break
  Next
  Filter [SOR]
  If GERR Then
    FIN = 1
  Else
    If !INBF Then
      GMESSAGE = mess(288,196,1) #Aucune solution ne correspond aux critères de recherche.
      GERR = 2
      FIN = 1
    Endif
  Endif
Return

###################################################################################################
# Détermine si des critères en partie droite en été saisis
###################################################################################################
Subprog USEFILTER(IUSEFLG)
Variable Integer IUSEFLG

Local Integer I

  IUSEFLG = 0
  #Contrôle du tableau des familles de compétence.
  For I = 0 To [M:SRE3]NBPBL-1
    If [M:SRE3]PBLGRP(I) <> "" Then
      IUSEFLG = 1
      Break
    Endif
  Next
  If IUSEFLG Then
    End
  Endif
  #Contrôle du tableau des collaborateurs
  For I = 0 To [M:SRE3]NBAUS-1
    If [M:SRE3]AUS(I) <> "" Then
      IUSEFLG = 1
      Break
    Endif
  Next
  If IUSEFLG Then
    End
  Endif
  #Vérifie si la solution est compatible avec le créneau de dates saisi.
  If [M:SRE3]CREDATFLG = 2 Then
    If [M:SRE3]STRDAT <> [00/00/00] and [M:SRE3]ENDDAT <> [00/00/00] Then
      IUSEFLG = 1
    Endif
  Endif
End

##########################################################################################################
# Détermine les critères saisie en partie gauche
###################################################################################################
Subprog SETWRDSEA(SZMASK)
Variable Char SZMASK

Local Integer I1
Local Integer I2
Local Integer I3
Local Integer I4
Local Integer I5

  SZMASK = "00000"
  I1 = 0
  I2 = 0
  I3 = 0
  I4 = 0
  I5 = 0
  If [M:SRE3]TTRDESFLG = 2 Then
    If [M:SRE3]TTRDES <> "" Then
      I1 = 1
    Endif
  Endif
  If [M:SRE3]SREHD1FLG = 2 Then
    If [M:SRE3]TTRDES <> "" Then
      I2 = 1
    Endif
  Endif
  If [M:SRE3]SOLFLG = 2 Then
    If [M:SRE3]SOL <> "" Then
      I3 = 1
    Endif
  Endif
  If [M:SRE3]SOLHD3FLG = 2 Then
    If [M:SRE3]SOL <> "" Then
      I4 = 1
    Endif
  Endif
  If [M:SRE3]KEYWRDFLG = 2 Then
    If [M:SRE3]KEYWRD <> "" Then
      I5 = 1
    Endif
  Endif
  SZMASK = num$(I1) + num$(I2) + num$(I3) + num$(I4) + num$(I5)
End

############################################################################################
# Effectue une recherche plein texte seule (sans croisement avec les critères partie gauche)
############################################################################################
Subprog DO_STRSEA(SZSEAMASK, INBRECC)
Value Char SZSEAMASK
Variable Integer INBRECC

Local Char SZLIB5(250)
Local Char SZLIB1(250)
Local Char SZLIB3(250)
Local Char SZCLE
Local Integer ICUT
Local Integer ICLECOUNT
Local Integer I
Local Integer ITER
Local Integer ISPACE(35)
Local Char SZUPTTR(80)
Local Char SZUPDES(250)
Local Char SZUPSOL(250)
Local Integer IFOUND
Local Integer IBUFFEMPTY
Local Integer ILNGCLOB
Local Integer INBBYTES
Local Integer IBUFFSIZE

  ILNGCLOB = 0
  INBBYTES = 0
  IBUFFSIZE = 0
  IBUFFEMPTY = 0
  IFOUND = 0
  ITER = 0
  I = 0
  SZUPTTR = ""
  SZUPDES = ""
  SZUPSOL = ""
  #Première chose
  #Recherche par mots-clé
  If mid$(SZSEAMASK, 5, 1) = "1" Then
    If [M:SRE3]KEYWRD <> "" Then
      SZLIB5 = [M:SRE3]KEYWRD
      Call LOOKUP_SOL(0, "SOLKWD", SZLIB5, INBRECC)
    Endif
  Endif
  #
  If mid$(SZSEAMASK, 1, 1) = "1" or mid$(SZSEAMASK, 2, 1) = "1" Then
    # Traitement de la recherche sur titre et synthèse demande
    # Découpe la chaine en mots indépendants
    Raz ISPACE
    I = 0
    SZLIB1 = [M:SRE3]TTRDES + " "
    ISPACE(0) = instr(1, SZLIB1, " ")
    If ISPACE(0) > 0 Then
      I = 1
      While 1
        ISPACE(I) = instr(ISPACE(I-1)+1, SZLIB1, " ")
        If ISPACE(I) = 0 Then
          Break
        Endif
        I += 1
        Wend
      Else
        End
      Endif

    Local Char SZWORD1(35)(I)
    #
    Raz SZWORD1
    SZWORD1(0) = toupper(ctrans(left$(SZLIB1, ISPACE(0)-1)))
    I = 1
    While 1
      If ISPACE(I) <> 0 Then
        SZWORD1(I) = toupper(ctrans(mid$(SZLIB1, ISPACE(I-1)+1, (ISPACE(I)-ISPACE(I-1))-1)))
      Else
        Break
      Endif
      I += 1
    Wend
  Endif
  #
  If mid$(SZSEAMASK, 3, 1) = "1" or mid$(SZSEAMASK, 4, 1) = "1" Then
    #Traitement de la recherche sur synthèse solution
    # Découpe la chaine en mots indépendants
    Raz ISPACE
    I = 0
    SZLIB3 = [M:SRE3]SOL + " "
    ISPACE(0) = instr(1, SZLIB3, " ")
    If ISPACE(0) > 0 Then
      I = 1
      While 1
        ISPACE(I) = instr(ISPACE(I-1)+1, SZLIB3, " ")
        If ISPACE(I) = 0 Then
          Break
        Endif
        I += 1
      Wend
    Else
      End
    Endif

    Local Char SZWORD3(35)(I)
    Raz SZWORD3
    SZWORD3(0) = toupper(ctrans(left$(SZLIB3, ISPACE(0)-1)))
    I = 1
    While 1
      If ISPACE(I) <> 0 Then
        SZWORD3(I) = toupper(ctrans(mid$(SZLIB3, ISPACE(I-1)+1, (ISPACE(I)-ISPACE(I-1))-1)))
      Else
        Break
      Endif
      I += 1
    Wend
  Endif
  #
  If mid$(SZSEAMASK, 2, 1) = "1" or mid$(SZSEAMASK, 4, 1) = "1" Then
    Read [ATY]CODTYP="HD3"
    If fstat Then
      ILNGCLOB = 6
    Else
      ILNGCLOB = [F:ATY]LNGTYP
    Endif
    If ILNGCLOB = 0 Then
      ILNGCLOB = 6
    Endif
    #
    INBBYTES = 1024 * (2^ILNGCLOB)
    IBUFFSIZE = INBBYTES / 200
    IBUFFSIZE += 5

    Local Char SZBUFFER1(250)(IBUFFSIZE)
    Local Char SZBUFFER2(250)(IBUFFSIZE) # FGR 11/10/2012 : X3SUIVI85143
  Endif
  #
  I = 0
  SZCLE = ""
  ICUT = 2500
  ICLECOUNT = ICUT
  While ICLECOUNT >= ICUT
    ICLECOUNT = 0
    #
    Filter [SOL] Where [F:SOL]NUM > SZCLE Order By [F:SOL]NUM Asc
    For [SOL]
      SZCLE = [F:SOL]NUM
      IFOUND = 0
      If IFOUND = 0 Then
        If mid$(SZSEAMASK, 1, 1) = "1" Then
          SZUPTTR = toupper(ctrans([F:SOL]TTR))
          SZUPDES = toupper(ctrans([F:SOL]PBLDES))
          For I = 0 To dim(SZWORD1)-1
            If SZWORD1(I) <> "" Then
              If instr(1, SZUPTTR, SZWORD1(I)) or instr(1, SZUPDES, SZWORD1(I)) Then
                IFOUND = 1
                Break
              Endif
            Endif
          Next
        Endif
      Endif
      If IFOUND = 0 Then
        If mid$(SZSEAMASK, 3, 1) = "1" Then
          SZUPSOL = toupper(ctrans([F:SOL]SOLDES))
          For I = 0 To dim(SZWORD3)-1
            If SZWORD3(I) <> "" Then
              If instr(1, SZUPSOL, SZWORD3(I)) Then
                IFOUND = 1
                Break
              Endif
            Endif
          Next
        Endif
      Endif
      If IFOUND = 0 Then
        If mid$(SZSEAMASK, 2, 1) = "1" Then
          IBUFFEMPTY = 1
          Read [HD3]HD30=[F:SOL]NUM;"PBL"
          If !fstat Then
            Raz SZBUFFER1
            Setlob SZBUFFER1 With [F:HD3]CLOB
            #Vérifie si buffer contient quelque chose
            For ITER = 0 To dim(SZBUFFER1)-1
              If SZBUFFER1(ITER) <> "" Then
                IBUFFEMPTY = 0
                Break
              Endif
            Next
            If IBUFFEMPTY = 0 Then
              For I = 0 To dim(SZWORD1)-1
                If SZWORD1(I) <> "" Then
                  Call FINDINCLOB(SZBUFFER1, "HD3", SZWORD1(I), IFOUND) From CRMUTIL140
                  If IFOUND Then
                    Break
                  Endif
                Endif
              Next
            Endif
          Endif
        Endif
      Endif
      If IFOUND = 0 Then
        If mid$(SZSEAMASK, 4, 1) = "1" Then
          IBUFFEMPTY = 1
          Read [HD3]HD30=[F:SOL]NUM;"SOL"
          If !fstat Then
            Raz SZBUFFER2
            Setlob SZBUFFER2 With [F:HD3]CLOB
            #Vérifie si buffer contient quelque chose
            For ITER = 0 To dim(SZBUFFER2)-1
              If SZBUFFER2(ITER) <> "" Then
                IBUFFEMPTY = 0
                Break
              Endif
            Next
            If IBUFFEMPTY = 0 Then
              For I = 0 To dim(SZWORD3)-1
                If SZWORD3(I) <> "" Then
                  Call FINDINCLOB(SZBUFFER2, "HD3", SZWORD3(I), IFOUND) From CRMUTIL140
                  If IFOUND Then
                    Break
                  Endif
                Endif
              Next
            Endif
          Endif
        Endif
      Endif
      If IFOUND Then
        Read [SOR]SOR3=[F:SOL]NUM;GIDENT;"SOL"
        If fstat Then
          Trbegin [SOR]
          Raz [F:SOR]
          [F:SOR]           = [F:SOL]
          [F:SOR]CREDATSOL  = [F:SOL]CREDAT
          [F:SOR]SOLNUM     = [F:SOL]NUM
          [F:SOR]NUM        = INBRECC
          [F:SOR]SSS        = GIDENT
          [F:SOR]TYP        = "SOL"
          [F:SOR]CREDAT     = date$
          If [F:SOL]CODSOL(0) <> "" Then
            [F:SOR]MORSOL   = "+"
          Endif
          Write [SOR]
          If fstat Then
            GMESSAGE = mess(100,141,1) #Erreur création
            GERR = 1
            Rollback
            Break
          Else
            Commit
            INBRECC += 1
          Endif
        Endif
      Endif
      ICLECOUNT += 1
      If ICLECOUNT >= ICUT Then
        Break
      Endif
      If GERR Then
        Break
      Endif
    Next
    Filter [SOL]
    If GERR Then
      Break
    Endif
  Wend
End

##########################################################################################################
# Nettoie la table SOLRESULT d'éventuelles sorties par plantage.
#########################################################
Subprog CLEANSOR
Local Date DMON

  DMON = date$ - 15
  Call DEBTRANS From GLOCK
  Trbegin [SOR]
  Delete [SOR] Where [F:SOR]CREDAT <= DMON
  If fstat Then
    Rollback
  Else
    Commit
  Endif
End

##########################################################################################################
# Ajoute le complément de critères partie gauche aux compléments de critères partie droite
#####################################################################################
Subprog CHK_STRSEA(SZSOLNUM, SZSEAMASK, SZSOLTTR, SZSOLPBLDES, SZSOLSOLDES, IMATCH)
Value Char SZSOLNUM
Value Char SZSEAMASK
Variable Char SZSOLTTR
Variable Char SZSOLPBLDES
Variable Char SZSOLSOLDES
Variable Integer IMATCH

  IMATCH = 0
  If SZSOLNUM = "" Then
    End
  Endif

Local Char SZLIB1(250)
Local Char SZLIB3(250)
Local Integer I
Local Integer ITER
Local Integer ISPACE(35)
Local Char SZUPTTR(80)
Local Char SZUPDES(250)
Local Char SZUPSOL(250)
Local Integer IBUFFEMPTY
Local Integer ILNGCLOB
Local Integer INBBYTES
Local Integer IBUFFSIZE

  ILNGCLOB = 0
  INBBYTES = 0
  IBUFFSIZE = 0
  IBUFFEMPTY = 0
  ITER = 0
  SZUPTTR = ""
  SZUPDES = ""
  SZUPSOL = ""
  If mid$(SZSEAMASK, 1, 1) = "1" or mid$(SZSEAMASK, 2, 1) = "1" Then
    #Traitement de la recherche sur titre et synthèse demande
    # Découpe la chaine en mots indépendants
    Raz ISPACE
    I = 0
    SZLIB1 = [M:SRE3]TTRDES + " "
    ISPACE(0) = instr(1, SZLIB1, " ")
    If ISPACE(0) > 0 Then
      I = 1
      While 1
        ISPACE(I) = instr(ISPACE(I-1)+1, SZLIB1, " ")
        If ISPACE(I) = 0 Then
          Break
        Endif
        I += 1
      Wend
    Else
      End
    Endif

    Local Char SZWORD1(35)(I)
    Raz SZWORD1
    SZWORD1(0) = toupper(ctrans(left$(SZLIB1, ISPACE(0)-1)))
    I = 1
    While 1
      If ISPACE(I) <> 0 Then
        SZWORD1(I) = toupper(ctrans(mid$(SZLIB1, ISPACE(I-1)+1, (ISPACE(I)-ISPACE(I-1))-1)))
      Else
        Break
      Endif
      I += 1
    Wend
  Endif
  If mid$(SZSEAMASK, 3, 1) = "1" or mid$(SZSEAMASK, 4, 1) = "1" Then
    #Traitement de la recherche sur synthèse solution
    # Découpe la chaine en mots indépendants
    Raz ISPACE
    SZLIB3 = [M:SRE3]SOL + " "
    ISPACE(0) = instr(1, SZLIB3, " ")
    If ISPACE(0) > 0 Then
      I = 1
      While 1
        ISPACE(I) = instr(ISPACE(I-1)+1, SZLIB3, " ")
        If ISPACE(I) = 0 Then
          Break
        Endif
        I += 1
        Wend
    Else
      End
    Endif

    Local Char SZWORD3(35)(I)
    Raz SZWORD3
    SZWORD3(0) = toupper(ctrans(left$(SZLIB3, ISPACE(0)-1)))
    I = 1
    While 1
      If ISPACE(I) <> 0 Then
        SZWORD3(I) = toupper(ctrans(mid$(SZLIB3, ISPACE(I-1)+1, (ISPACE(I)-ISPACE(I-1))-1)))
      Else
        Break
      Endif
      I += 1
    Wend
  Endif
  #
  If mid$(SZSEAMASK, 2, 1) = "1" or mid$(SZSEAMASK, 4, 1) = "1" Then
    Read [ATY]CODTYP="HD3"
    If fstat Then
      ILNGCLOB = 6
    Else
      ILNGCLOB = [F:ATY]LNGTYP
    Endif
    If ILNGCLOB = 0 Then
      ILNGCLOB = 6
    Endif

    INBBYTES = 1024 * (2^ILNGCLOB)
    IBUFFSIZE = INBBYTES / 200
    IBUFFSIZE += 5

    Local Char SZBUFFER1(250)(IBUFFSIZE)
  Endif
  #
  If mid$(SZSEAMASK, 1, 1) = "1" Then
    SZUPTTR = toupper(ctrans(SZSOLTTR))
    SZUPDES = toupper(ctrans(SZSOLPBLDES))
    For I = 0 To dim(SZWORD1)-1
      If SZWORD1(I) <> "" Then
        If instr(1, SZUPTTR, SZWORD1(I)) or instr(1, SZUPDES, SZWORD1(I)) Then
          IMATCH = 1
          Break
        Endif
      Endif
    Next
  Endif
  If IMATCH Then
    End
  Endif
  #
  If mid$(SZSEAMASK, 3, 1) = "1" Then
    SZUPSOL = toupper(ctrans(SZSOLSOLDES))
    For I = 0 To dim(SZWORD3)-1
      If SZWORD3(I) <> "" Then
        If instr(1, SZUPSOL, SZWORD3(I)) Then
          IMATCH = 1
          Break
        Endif
      Endif
    Next
  Endif
  If IMATCH Then
    End
  Endif
  #
  If mid$(SZSEAMASK, 2, 1) = "1" Then
    IBUFFEMPTY = 1
    Read [HD3]HD30=SZSOLNUM;"PBL"
    If !fstat Then
      Raz SZBUFFER1
      Setlob SZBUFFER1 With [F:HD3]CLOB
      #Vérifie si buffer contient quelque chose
      For ITER = 0 To dim(SZBUFFER1)-1
        If SZBUFFER1(ITER) <> "" Then
          IBUFFEMPTY = 0
          Break
        Endif
      Next
      If IBUFFEMPTY = 0 Then
        For I = 0 To dim(SZWORD1)-1
          If SZWORD1(I) <> "" Then
            Call FINDINCLOB(SZBUFFER1, "HD3", SZWORD1(I), IMATCH) From CRMUTIL140
            If IMATCH Then
              Break
            Endif
          Endif
        Next
      Endif
    Endif
  Endif
  If IMATCH Then
    End
  Endif
  #
  If mid$(SZSEAMASK, 4, 1) = "1" Then
    IBUFFEMPTY = 1
    Read [HD3]HD30=SZSOLNUM;"SOL"
    If !fstat Then
      Raz SZBUFFER2
      Setlob SZBUFFER2 With [F:HD3]CLOB
      #Vérifie si buffer contient quelque chose
      For ITER = 0 To dim(SZBUFFER2)-1
        If SZBUFFER2(ITER) <> "" Then
          IBUFFEMPTY = 0
          Break
        Endif
      Next
      If IBUFFEMPTY = 0 Then
        For I = 0 To dim(SZWORD3)-1
          If SZWORD3(I) <> "" Then
            Call FINDINCLOB(SZBUFFER2, "HD3", SZWORD3(I), IMATCH) From CRMUTIL140
            If IMATCH Then
              Break
            Endif
          Endif
        Next
      Endif
    Endif
  Endif
  If IMATCH Then
    End
  Endif
End

##########################################################################################################
# Vérifie si une solution trouvée par mot-clé est compatible avec les filtres.
###################################################################################################
Subprog CHKFILTER(SZFSOLKEY, ISCOMP)
Value Char SZFSOLKEY
Variable Integer ISCOMP

Local Integer I
Local Integer INBPBL
Local Integer INBAUS
Local Integer ISPBLCOMP
Local Integer ISAUSCOMP
Local Integer ISDATCOMP
Local Char SZPBLNUM(GLONVCR)(6)
Local Char SZAUSNUM(GLONAUS)(6)

  INBPBL = 0
  INBAUS = 0
  ISPBLCOMP = 0
  ISAUSCOMP = 0
  ISDATCOMP = 0
  Raz SZPBLNUM
  Raz SZAUSNUM
  #Contrôle du tableau des familles de compétence.
  If [M:SRE3]NBPBL <> 0 Then
    For I = 0 To [M:SRE3]NBPBL-1
      If [M:SRE3]PBLGRP(I) <> "" Then
        SZPBLNUM(I) = [M:SRE3]PBLGRP(I)
      Endif
    Next
    #Calcul le nombre réél de familles de compétences saisies
    INBPBL = 0
    For I = 0 To dim(SZPBLNUM)-1
      If SZPBLNUM(I) = "" Then
        Break
      Endif
      INBPBL += 1
    Next
  Endif
  #Contrôle du tableau des collaborateurs
  If [M:SRE3]NBAUS <> 0 Then
    For I = 0 To [M:SRE3]NBAUS-1
      If [M:SRE3]AUS(I) <> "" Then
        SZAUSNUM(I) = [M:SRE3]AUS(I)
      Endif
    Next
    #Calcul le nombre réél de collaborateurs saisis
    INBAUS = 0
    For I = 0 To dim(SZAUSNUM)-1
      If SZAUSNUM(I) = "" Then
        Break
      Endif
      INBAUS += 1
    Next
  Endif
  #Vérifie si la solution est compatible avec les familles de compétences saisies
  If INBPBL Then
    ISPBLCOMP = 0
    For I = 0 To dim(SZPBLNUM)-1
      If SZPBLNUM(I) <> "" Then
        Read [SOL]SOL0=SZFSOLKEY
        If !fstat Then
          If [F:SOL]PBLGRP = SZPBLNUM(I) Then
            ISPBLCOMP = 1
            Break
          Endif
        Endif
      Endif
    Next
  Else
    ISPBLCOMP = 1
  Endif
  #Vérifie si la solution est compatible avec les collaborateurs saisis
  If INBAUS Then
    ISAUSCOMP = 0
    For I = 0 To dim(SZAUSNUM)-1
      If SZAUSNUM(I) <> "" Then
        Read [SOL]SOL0=SZFSOLKEY
        If !fstat Then
          If [F:SOL]CREUSR = SZAUSNUM(I) Then
            ISAUSCOMP = 1
            Break
          Endif
        Endif
      Endif
    Next
  Else
    ISAUSCOMP = 1
  Endif
  #Vérifie si la solution est compatible avec le créneau de dates saisi.
  If [M:SRE3]CREDATFLG = 2 Then
    If [M:SRE3]STRDAT <> [00/00/00] and [M:SRE3]ENDDAT <> [00/00/00] Then
      Read [SOL]SOL0=SZFSOLKEY
      If !fstat Then
        If [F:SOL]CREDAT >= [M:SRE3]STRDAT and [F:SOL]CREDAT <= [M:SRE3]ENDDAT Then
          ISDATCOMP = 1
        Else
          ISDATCOMP = 0
        Endif
      Else
        ISDATCOMP = 0
      Endif
    Else
      ISDATCOMP = 1
    Endif
  Else
    ISDATCOMP = 1
  Endif
  #Vérifie la compatibilité avec les trois critères.
  If ISPBLCOMP = 1 and ISAUSCOMP = 1 and ISDATCOMP = 1 Then
    ISCOMP = 1
  Else
    ISCOMP = 0
  Endif
End

################################################################################
# Programme d'exécution d'une recherche pour un clé donné.                     #
################################################################################
Subprog LOOKUP_SOL(ICHKFLTFLG, SZTYPE, SZLOOKFOR, INBREC)
Value Integer ICHKFLTFLG
Value Char SZTYPE
Variable Char SZLOOKFOR
Variable Integer INBREC

Local Integer I
Local Integer ISC
Local Integer ISPACE(35)
# FGR 13/11/2008 : X3SUIVI50281
Local Char SZWHERE(250)(50)
Local Integer IINDSZWHERE
Local Integer IERROR   # FGR 08/02/2010 : X3SUIVI60986

  #Initialise les variables
  I = 0
  ISC = 0
  Raz ISPACE
  IERROR = 0    # FGR 08/02/2010 : X3SUIVI60986
  # Découpe la chaine en mots indépendants
  If SZLOOKFOR = "" Then
    End
  Endif
  #
  SZLOOKFOR = SZLOOKFOR + " "
  ISPACE(0) = instr(1, SZLOOKFOR, " ")
  If ISPACE(0) > 0 Then
    I = 1
    While 1
      ISPACE(I) = instr(ISPACE(I-1)+1, SZLOOKFOR, " ")
      If ISPACE(I) = 0 Then
        Break
      Endif
      I += 1
    Wend
  Else
    End
  Endif

Local Char SZWORD(35)(I)
Local Integer ILEN

  # FGR 13/11/2008 : X3SUIVI50281
  Raz SZWHERE
  IINDSZWHERE = 0
  Raz SZWORD
  SZWORD(0) = toupper(left$(SZLOOKFOR, ISPACE(0)-1))
  I = 1
  While 1
    If ISPACE(I) <> 0 Then
      SZWORD(I) = toupper(mid$(SZLOOKFOR, ISPACE(I-1)+1, (ISPACE(I)-ISPACE(I-1))-1))
    Else
      Break
    Endif
    I += 1
  Wend
  # =============================
  # FGR 13/11/2008 : X3SUIVI50281
  Raz SZWHERE
  IINDSZWHERE = 0
  For I = 0 To dim([F:SOL]KEYWRD)-1
    If IINDSZWHERE > 0 Then
      SZWHERE(IINDSZWHERE) = "or"
    Else
      SZWHERE(IINDSZWHERE) = "("
    Endif
    SZWHERE(IINDSZWHERE) = SZWHERE(IINDSZWHERE) - "find([F:SOL]KEYWRD("+num$(I)+"), SZWORD(I))<>0"
    IINDSZWHERE += 1
  Next
  SZWHERE(IINDSZWHERE-1) = SZWHERE(IINDSZWHERE-1) - ")"
  For I = 0 To dim(SZWORD)-1
    ILEN = len(SZWORD(I))
    If ILEN > 1 Then
      Filter [SOL] Where evalue(SZWHERE)
      For [SOL]
        Read [SOR]SOR3=[F:SOL]NUM;GIDENT;"SOL"
        If fstat Then
          If ICHKFLTFLG Then
            Call CHKFILTER([F:SOL]NUM, ISC)
          Else
            ISC = 1
          Endif
          If ISC Then
            Call DEBTRANS From GLOCK
            Trbegin [SOR]
            Raz [F:SOR]
            [F:SOR]              = [F:SOL]
            [F:SOR]CREDATSOL     = [F:SOL]CREDAT
            If [F:SOL]CODSOL(0) <> "" Then
              [F:SOR]MORSOL      = "+"
            Endif
            [F:SOR]SOLNUM        = [F:SOL]NUM
            [F:SOR]NUM           = INBREC
            [F:SOR]SSS           = GIDENT
            [F:SOR]TYP           = "SOL"
            [F:SOR]CREDAT        = date$
            Write [SOR]
            If fstat Then
              GMESSAGE = mess(100,141,1) #Erreur création
              GERR = 1
              Rollback
              # FGR 08/02/2010 : X3SUIVI60986
              #End
              Break
            Else
              Commit
              INBREC += 1
            Endif
          Endif
        Endif
      Next
      Filter [SOL]
      If IERROR = 1 Then
        # FGR 08/02/2010 : X3SUIVI60986
        End
      Endif
    Endif
  Next
End
