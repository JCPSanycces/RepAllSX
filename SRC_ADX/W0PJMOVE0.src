IMPTBL = 0

## Zone OPPNUM
mkstat = 0
zoncou = "OPPNUM"
indice = 0
WCHAR = [M]OPPNUM
If varmode([M]OPPNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPPNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]OPPNUM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 1886 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("PIM","A",[M]OPPNUM,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 1886 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]OPPNUM or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_OPPNUM([M]OPPNUM) From PJMOVE
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 1886 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

