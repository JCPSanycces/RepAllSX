#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Classe OPPORSTB
#######################################################################################
$ENDDAT
  Case [L]ARULE
    When "PROPAGATE" : Gosub ENDDAT_PROPAGATE
  Endcase
Return

$ENDDAT_PROPAGATE
  this.STRDAT = this.ENDDAT
Return

#######################################################################################
$STE
  # Issue X3-36832 - 2017-06-01 by FGR
  Case [L]ARULE
    When "PROPAGATE" : Gosub STE_PROPAGATE
  Endcase
Return

$STE_PROPAGATE
  # Issue X3-36832 - 2017-06-01 by FGR
  If this.STE <> AVOID.ACHAR Then
    Local File ATABDIV [ADI]
    Read [ADI]CODE=400;this.STE
    If [F:ADI]N3 = [V]CST_AYES or [F:ADI]N3 = [V]CST_ANO Then
      this.DON = [F:ADI]N3
    Else
      this.DON = [V]CST_ANO
    Endif
  Endif
Return

