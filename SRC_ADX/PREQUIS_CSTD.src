#<AdxTL>@(#)0.0.0.0 $Revision$
# Structure PREQUIS

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AINSERT_CONTROL_AFTER"   : Gosub AINSERT_CONTROL_AFTER  From PREQUIS_CMET
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE From PREQUIS_CMET
        When "AUPDATE_CONTROL_AFTER"   : Gosub AUPDATE_CONTROL_AFTER  From PREQUIS_CMET
        When "AINSERT_BEFORE"          : Gosub AINSERT_BEFORE         From PREQUIS_CMET
        When "AUPDATE_BEFORE"          : Gosub AUPDATE_BEFORE         From PREQUIS_CMET
        When "AINSERT_AFTER"           : Gosub AINSERT_AFTER          From PREQUIS_CMET
        When "AUPDATE_AFTER"           : Gosub AUPDATE_AFTER          From PREQUIS_CMET
        When "ADELETE_CONTROL_BEFORE"  : Gosub ADELETE_CONTROL_BEFORE From PREQUIS_CMET
      Endcase
    When "PSD"
      Case [L]AEVENT
        When "ADDLINE_BEFORE"         : Gosub PSD_ADDLINE_BEFORE        From PREQUIS_CMET
        When "ADDLINE_AFTER"          : Gosub PSD_ADDLINE_AFTER         From PREQUIS_CMET
        When "AINSERT_CONTROL_AFTER"  : Gosub PSD_AINSERT_CONTROL_AFTER From PREQUIS_CMET
        When "AUPDATE_CONTROL_AFTER"  : Gosub PSD_AUPDATE_CONTROL_AFTER From PREQUIS_CMET
        When "AINSERT_BEFORE"         : Gosub PSD_AINSERT_BEFORE        From PREQUIS_CMET
        When "ADELLINE_BEFORE"        : Gosub PSD_ADELLINE_BEFORE       From PREQUIS_CMET
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "_MET_MAJPSH"             : Gosub _MET_MAJPSH    From PREQUIS_LIB
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "REQUSR" :
      Case [L]ARULE
        When "INIT"   : Gosub INIT_REQUSR From PREQUIS_CPRO
      Endcase
    When "PRQDAT" :
      Case [L]ARULE
        When "INIT"   : Gosub INIT_PRQDAT From PREQUIS_CPRO
      Endcase
    When "PSHFCY" :
      Case [L]ARULE
        When "INIT"      : Gosub INIT_PSHFCY From PREQUIS_CPRO
        When "PROPAGATE" : Gosub PROPAGATE_PSHFCY From PREQUIS_CPRO
      Endcase
  Endcase
Return

