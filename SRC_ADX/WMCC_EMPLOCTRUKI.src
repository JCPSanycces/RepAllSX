#<AdxTL>@(#)0.0.0.0 $Revision$Class Additional fields
# Supervisor
## CRUD-CLASSE ## EMPLOCTRUKI
# 2018-11-06 07:05:29 081


############################################################################################
### Subprog _AINSERT
############################################################################################
Subprog _AINSERT(EMPLOCTRUKI,ASTATUS)
Variable Instance EMPLOCTRUKI Using C_EMPLOCTRUKI
Variable Integer ASTATUS

If EMPLOCTRUKI = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLOCTRUKI

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_EMPLOCTRUKI

End

#-----------------------------------------------------#

############################################################################################
### Subprog AINSERT
############################################################################################
Subprog AINSERT(EMPLOCTRUKI,ASTATUS)
Variable Instance EMPLOCTRUKI Using C_EMPLOCTRUKI
Variable Integer ASTATUS

If EMPLOCTRUKI = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOCTRUKI
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

If !adxlog
 Gosub AINSERT_TR_EMPLOCTRUKI
Else
 Gosub AINSERT_EMPLOCTRUKI
Endif

Gosub _AINSERT_AFTER
[L]A_I = EMPLOCTRUKI.freeSnapshot
EMPLOCTRUKI.snapshotEnabled = 1
$AINSERT_END
End

#-----------------------------------------------------#

$AINSERT_CONTROL
Gosub _AINSERT_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOCTRUKI._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOCTRUKI._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOCTRUKI._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AINSERT_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_BEFORE
If EMPLOCTRUKI.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLOCTRUKI.ASTALIN = [V]CST_ANEW
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCTRUKI.ACTION("AINSERT_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For [L]A_I=1 To maxtab(EMPLOCTRUKI.UKADD)
 If EMPLOCTRUKI.UKADD([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOCTRUKI.UKADD([L]A_I).ACTION("AINSERT_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_AFTER

For [L]A_I=1 To maxtab(EMPLOCTRUKI.UKADD)
 If EMPLOCTRUKI.UKADD([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOCTRUKI.UKADD([L]A_I).ACTION("AINSERT_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCTRUKI.ACTION("AINSERT_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_TR_EMPLOCTRUKI
Trbegin [F:CTRUKI]
 Gosub AINSERT_EMPLOCTRUKI
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AINSERT_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AINSERT_EMPLOCTRUKI
Raz [F:CTRUKI]
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCTRUKI.ACTION("AINSERT_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLOCTRUKI._MAJSQL_EMPLOCTRUKI(EMPLOCTRUKI))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCTRUKI.ACTION("AINSERT_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_ABORT
Rollback
$_AINSERT_ABORT
If EMPLOCTRUKI.snapshotEnabled=1
 [L]A_RETIK = EMPLOCTRUKI.revertUpdTick
Endif
[L]ASTATUS = max(fmet EMPLOCTRUKI.ACTION("AINSERT_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AINSERT_AFTER
If find(EMPLOCTRUKI.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EMPLOCTRUKI.ASTALIN = [V]CST_ALL
Endif
For [L]A_I=1 To maxtab(EMPLOCTRUKI.UKADD)
 If EMPLOCTRUKI.UKADD([L]A_I)<>null
  If EMPLOCTRUKI.UKADD([L]A_I).ASTALIN=[V]CST_ADEL or EMPLOCTRUKI.UKADD([L]A_I).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EMPLOCTRUKI.UKADD([L]A_I)
   EMPLOCTRUKI.UKADD([L]A_I) = null
  Elsif EMPLOCTRUKI.UKADD([L]A_I).ASTALIN <> [V]CST_ALL
   EMPLOCTRUKI.UKADD([L]A_I).ASTALIN = [V]CST_ALL
  Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif
Return



