#####################################################################
Subprog CONVERT3(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,COURS,STAT)
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise de destination
Value    Char    DEVSOC           : # Devise société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Decimal MTORG            : # Montant origine
Variable Decimal MTDES            : # Montant destination
Value    Decimal COURS            : # Cours devise -> destination eventuelt donné
Variable Integer STAT             : # Status de retour (0 = OK)

Local  Decimal AMTINT             : # Montant intermédiaire
Local  Integer ORGFLG, DESFLG     : # Flags monnaies origine et destination
Local  Decimal ARRONDI
Local  Integer I

Local Integer  SOA_GDIMDEV        : # Dimension variables devises
Call GDIMDEV(SOA_GDIMDEV) From ESSGLOB_SOA

Local Date SOA_GDEVDAT(1..SOA_GDIMDEV) : # Date de passage à l'euro
Local Char SOA_GDEVISE(GLONCUR)(1..SOA_GDIMDEV)  : # Codes devises
Local Integer SOA_GNBDEV : # Nombre de devises
Call GDEVISE(SOA_GNBDEV,SOA_GDEVDAT,SOA_GDEVISE) From ESSGLOB_SOA

Local Char     SOA_GEURO(30)           : # Euro code
Local Decimal  SOA_GAROEURO            : # Euro conversion rounding

Call GEURO(SOA_GEURO)       From ESSGLOB_SOA
Call GAROEURO(SOA_GAROEURO) From ESSGLOB_SOA

If clalev([F:TCU])=0 : Local File TABCUR [TCU] : Endif
If [F:TCU]CUR<>DEVDES
 Read [TCU]TCU0 = DEVDES
Endif
ARRONDI = [F:TCU]CURRND

STAT=0
If DEVORG="" | DEVDES=""
  # Cannot call error in propogate - see INIDEV_CONTROL in propery control
  # Devise inexistante
  #Call ERREUR(mess(151,105,1)) From GESECRAN : STAT=1     #??? will this need to be handeled in a diferent place
  End
Endif

If DEVORG=DEVDES
 MTDES =MTORG
 End
Endif

ORGFLG=1 : DESFLG=1
I = find(DEVORG, SOA_GDEVISE(1..SOA_GNBDEV))
If SOA_GDEVDAT(I) <= DATCOURS : ORGFLG = 2 : Endif   : # Si devise 'Out', GDEVDAT=31/12/9999
I = find(DEVDES, SOA_GDEVISE(1..SOA_GNBDEV))
If SOA_GDEVDAT(I) <= DATCOURS : DESFLG = 2 : Endif

If COURS<>0
  If ORGFLG=1
    #-------- 'Out' --> 'Out'
    If DESFLG=1
       MTDES = arr(MTORG*COURS, ARRONDI)
    Else
      #-------- 'Out' --> 'In'
      If DEVDES = SOA_GEURO
         MTDES = arr(MTORG*COURS, ARRONDI)
      Else      : # Si on a un cours, c'est celui de l'Euro
         AMTINT = arr(MTORG*COURS, 10^(-SOA_GAROEURO))
         Call CONVERT(SOA_GEURO,DEVDES,DEVSOC,TYPCOURS,DATCOURS,AMTINT,MTDES,STAT) From TRTDEV_SOA
      Endif
    Endif
  Else
    If DESFLG=1
      #-------- 'In' --> 'Out'
      If DEVORG=SOA_GEURO
         MTDES = arr(MTORG*COURS, ARRONDI)
      Else
         Call CONVERT(DEVORG,SOA_GEURO,DEVSOC,TYPCOURS,DATCOURS,MTORG,AMTINT,STAT) From TRTDEV_SOA
         MTDES = arr(AMTINT*COURS, ARRONDI)
      Endif
    Else
      #-------- 'In' --> 'In'  : # si cours renseigné, on n'en tient pas compte
     Call CONVERT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT) From TRTDEV_SOA
    Endif
  Endif
Else
  Call CONVERT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT) From TRTDEV_SOA
Endif
End
#####################################################################
Subprog CONTEXE(ACCES,SOA_GMESSAGE)
Value    Char    ACCES
Variable Char    SOA_GMESSAGE       : # Message d'erreur

Local Char     SOA_GUSER(GLONAUS)  : # Code utilisateur # User code
Call GUSER(SOA_GUSER) From ESSGLOB_SOA

Local Integer  SOA_GUSRACS         : # Tous codes d'accès # All access codes
Call GUSRACS(SOA_GUSRACS) From ESSGLOB_SOA

If ACCES=AVOID.ACHAR or SOA_GUSRACS=2
  # mkstat = 0 :   # ???
  End
Endif

If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
Read [ACC]CODACC = SOA_GUSER;ACCES
If fstat | [F:ACC]EXEC<>2
 SOA_GMESSAGE = mess(7,104,1)
 #mkstat = 1   # ???
Else
 #mkstat = 0   # ???
Endif
End

#####################################################################
Subprog CTLVLYDAT(DAT,DATDEB,DATFIN,SOA_GMESSAGE)
Value    Date     DAT
Value    Date     DATDEB
Value    Date     DATFIN
Variable Char     SOA_GMESSAGE

If !(DAT>=DATDEB & (DATFIN=[0/0/0] | DAT<=DATFIN))
 SOA_GMESSAGE = mess(13,104,1)
 #mkstat = 2  ## ???
Endif
End
#####################################################################

