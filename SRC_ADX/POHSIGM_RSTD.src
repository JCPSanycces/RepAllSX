#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe POHSIGM_RSTD

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#  Case [L]CURPTH
#     When ""
#      Case [L]AEVENT
#      Endcase
#  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "RCHRONO" # Sequence number
      Case [L]ARULE
        When "GET" : Gosub RCHRONO_GET
      Endcase
    When "DEVTTC" # Currency
      Case [L]ARULE
        When "GET" : Gosub DEVTTC_GET
      Endcase
    When "RCLEDEC" # Purchase order number
      Case [L]ARULE
        When "GET" : Gosub RCLEDEC_GET
      Endcase
    When "RTIMENV" # Issue time
      Case [L]ARULE
        When "GET" : Gosub RTIMENV_GET
      Endcase
    When "RVALCTX1" # Buyer
      Case [L]ARULE
        When "GET" : Gosub RVALCTX1_GET
      Endcase
    When "RVALCTX2" # Supplier
      Case [L]ARULE
        When "GET" : Gosub RVALCTX2_GET
      Endcase
    When "RVALCTX3" # Company name
      Case [L]ARULE
        When "GET" : Gosub RVALCTX3_GET
      Endcase
    When "RVALCTX4" # Inv amt -tax
      Case [L]ARULE
        When "GET" : Gosub RVALCTX4_GET
      Endcase
    When "RVALCTX5" # Inv amt +tax
      Case [L]ARULE
        When "GET" : Gosub RVALCTX5_GET
      Endcase
    When "RVALCTX6" # Currency
      Case [L]ARULE
        When "GET" : Gosub RVALCTX6_GET
      Endcase
    When "RVALCTX7" # Order date
      Case [L]ARULE
        When "GET" : Gosub RVALCTX7_GET
      Endcase
    When "ROPERATION" # Answer
      Case [L]ARULE
        When "GET" : Gosub ROPERATION_GET
      Endcase
 Endcase
Return

$RCHRONO_GET
  this.RCHRONO = this.AWS.CHRONO
Return

$DEVTTC_GET
  this.DEVTTC = this.AWS.VALCTX6
Return

$RCLEDEC_GET
# this.RCLEDEC = this.AWS.CLEDEC
Return

$RTIMENV_GET
  this.RTIMENV = left$(this.AWS.TIMENV,2)+mid$(this.AWS.TIMENV,3,2) +right$(time$,7)
Return

$RVALCTX1_GET
  this.RVALCTX1 = this.AWS.VALCTX1
Return

$RVALCTX2_GET
  this.RVALCTX2 = this.AWS.VALCTX2 + " " + this.AWS.VALCTX3
Return

$RVALCTX3_GET
# this.RVALCTX3 = this.AWS.VALCTX3
Return

$RVALCTX4_GET
  this.RVALCTX4 = val(this.AWS.VALCTX4)
Return

$RVALCTX5_GET
  this.RVALCTX5 = val(this.AWS.VALCTX5)
Return

$RVALCTX6_GET
  this.RVALCTX6 = this.AWS.VALCTX6
Return

$RVALCTX7_GET
  Local Integer IDAY
  Local Integer IMONTH
  Local Integer IYEAR

  IDAY = val(left$(this.AWS.VALCTX7,2))
  IMONTH = val(mid$(this.AWS.VALCTX7,4,2))
  IYEAR = val(mid$(this.AWS.VALCTX7,7,4))
  this.RVALCTX7 = gdat$(IDAY, IMONTH, IYEAR)
Return

$ROPERATION_GET
  If this.AWS.OPERATION = 'VAL'
    this.ROPERATION = 2
  Else
    this.ROPERATION = 1
  Endif
Return

