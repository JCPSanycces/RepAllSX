#<AdxTL>@(#)0.0.0.0 $Revision$
Gosub SI_CONTEXT From SIXFONCTION
SI_SIMU=2
Local File SIPARX3  [SPX]
Local File SIPARVAC [SPV]
Read [SPX] First
Call EXEC From SIXTUN
End

$TRT_ERR
    Call ECR_TRACE( errp-"ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
    GOK=0
Resume

#########################################################################
#  SIXTUN : pour traitements de bascule Integrale --> X3                #
#########################################################################
#                                                                       #
# Subprog EXEC                                                          #
#     Migration des unités                                              #
#########################################################################

Subprog EXEC

Local Integer WOUV_TRACE

If GTRACE = ""
    Call OUVRE_TRACE("SIXTUN : "+SI_MES(1)) From LECFIC
    WOUV_TRACE=1
Endif

Onerrgo TRT_ERR

If !clalev ([F:XUNI]) : Local File =SI_DOSSIER+".XIUNIFAC" [XUNI] : Endif
If !clalev ([F:XSOC]) : Local File =SI_DOSSIER+".XISOC"    [XSOC] : Endif
If !clalev ([F:TUN])  : Local File =SI_DOSSIER+".TABUNIT"  [TUN] : Endif
If !clalev ([F:TLA])  : Local File =SI_DOSSIER+".TABLAN"   [TLA]  : Endif

Local Integer I
Local Integer LERR, LREW

# 1- Contrôles
# Vérification de la langue
Read [TLA]TLA0=[F:SPX]LAN
If fstat
    Call ECR_TRACE(SI_MES(245),1) From GESECRAN
    End
Endif

Read [XSOC] First

# 2- Alimentation de la table TABUNIT
Call DEBTRANS From GLOCK
Trbegin [TUN]
For [XUNI] Where FLGREP<>2 & X3CLE<>""

    If !GOK : Break : Endif

    Raz LERR
    Raz [F:TUN]

    If !func SIXFONCTION.SI_CTL("UOM",[F:XUNI]X3CLE,"XIUNIFAC ("+[F:XUNI]CODUNI+")")
        LERR=1
    Endif
    
    # Récupération de la désignation
    Raz [F:AXX]
    [F:AXX]CODFIC = "TABUNIT"
    [F:AXX]ZONE   = "DES"
    [F:AXX]LANGUE = [F:SPX]LAN
    [F:AXX]IDENT1 = [F:XUNI]X3CLE
    [F:AXX]IDENT2 = ""

    Read [AXX]AXX0=[F:AXX]CODFIC;[F:AXX]ZONE;[F:AXX]LANGUE;[F:AXX]IDENT1;[F:AXX]IDENT2
    If fstat
        LREW=0
    Else
        LREW=1
    Endif

    [F:AXX]TEXTE  = [F:XUNI]LIB

    If LREW
        Rewrite [F:AXX]
    Else
        Write [F:AXX]
    Endif
    If fstat
        Call ECR_TRACE(mess(34,105,1)-[F:TUN]UOM-"("+[F:XUNI]CODUNI+")"-mess(30,109,1)-":"-func SIXFONCTION.FSTATMSG(fstat), 1) From GESECRAN
    Endif
    
    Read [TUN]TUN0=[F:XUNI]X3CLE
    If fstat
        LREW=0
    Else
        LREW=1
    Endif

    [F:TUN]UOM = [F:XUNI]X3CLE
    [F:TUN]UOMDEC = [F:XSOC]NBRDMLQTE
    If !LREW
        If [F:TUN]UOM="HRS"
            [F:TUN]UOMTYP = 5
        Else
            [F:TUN]UOMTYP = 8
        Endif
    Endif



    If !LERR
        If LREW
            [F:TUN]UPDDAT = date$
            [F:TUN]UPDUSR = GUSER
            SI_TABLE = "TABUNIT"
            Gosub SI_BEFWRI From SIXFONCTION
    
            Rewrite [TUN] 
        Else
            [F:TUN]CREDAT = date$
            [F:TUN]CREUSR = GUSER
            SI_TABLE = "TABUNIT"
            Gosub SI_BEFWRI From SIXFONCTION
    
            Write [TUN] 
        Endif
        If fstat
            Call ECR_TRACE(mess(34,105,1)-[F:TUN]UOM-"("+[F:XUNI]CODUNI+")"-mess(30,109,1)-":"-func SIXFONCTION.FSTATMSG(fstat), 1) From GESECRAN
            LERR=1
        Endif
    Endif

    If GOK & LERR=0
        [F:XUNI]FLGREP=2
        Rewrite [XUNI]
    Endif
    
Next

If GOK & SI_SIMU<>2
    Commit
Else
    Rollback
Endif

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End
