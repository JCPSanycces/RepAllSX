#**
#* This Function allows to remove metadata from the gitRepo and from mongodb
#*
#* @param ENTITY_TYPE : (optional) The type of entities to export 'tables', 'classes', 'views', ...
#* @param ENTITY_NAME : (optional) The name of entities to export 'AABREV', 'ABANK', 'ATABLE', ...
#* @param RESHEAD : Clbfile : The response header
#* @param RESBODY : Clbfile : Document Descriptor UUID or 'null' if document was not found.
#* @return STATUSCODE : Integer : The status code return by the javascript runner module.
#*!
Funprog REMOVE_METADATA(ENTITY_TYPE,ENTITY_MAJMONGO, ENTITY_NAME, RESHEAD, RESBODY)
Value Char ENTITY_TYPE()
Value Integer ENTITY_MAJMONGO
Value Char ENTITY_NAME()
Variable Clbfile RESHEAD()
Variable Clbfile RESBODY()

Local Char SYRACUSE_FUNCTION(30):SYRACUSE_FUNCTION="removeMetadataFromX3"
Goto UPDATE_METADATA

#**
#* This Function allows to extract metadata from sql (sql server, oracle, ...) to mongodb
#* See : https://github.com/Sage-ERP-X3/Syracuse/blob/master/node_modules/etna-etl/lib/syncArea.md
#*
#* @param ENTITY_TYPE : (optional) The type of entities to export 'tables', 'classes', 'views', ...
#* @param ENTITY_NAME : (optional) The name of entities to export 'AABREV', 'ABANK', 'ATABLE', ...
#* @param RESHEAD : Clbfile : The response header
#* @param RESBODY : Clbfile : Document Descriptor UUID or 'null' if document was not found.
#* @return STATUSCODE : Integer : The status code return by the javascript runner module.
#*!
Funprog EXTRACT_METADATA(ENTITY_TYPE,ENTITY_MAJMONGO, ENTITY_NAME, RESHEAD, RESBODY)
Value Char ENTITY_TYPE()
Value Integer ENTITY_MAJMONGO
Value Char ENTITY_NAME()
Variable Clbfile RESHEAD()
Variable Clbfile RESBODY()

Local Char SYRACUSE_FUNCTION(30):SYRACUSE_FUNCTION="extractMetadataFromX3"

$UPDATE_METADATA
Local Integer STATUSCODE
Local Clbfile ARGUMENTS(0) : ARGUMENTS = '{'
If GSERVEUR : Append ARGUMENTS,  '"solution": "'+GINSTID+'","folder": "'+nomap+'",' : Endif :#For the batch serveur
Append ARGUMENTS,  '"entityType": "'+ENTITY_TYPE+'",'  +  '"entityName": ["'+ENTITY_NAME+'"] }'
Append ARGUMENTS, ', {"exportToMongo":'+func ASYRSUB.BOOLEAN_TO_SYR(ENTITY_MAJMONGO)+'}'
#If GFONCTION ="GESADI"
 #Call ECR_TRACE("SYRACUSE_FUNCTION"-SYRACUSE_FUNCTION-"arguments="-ARGUMENTS,0) From GESECRAN
#Endif
STATUSCODE = func ASYRWEBSER.EXEC_JS('etna-etl/lib/sync',SYRACUSE_FUNCTION, 'wait', ARGUMENTS, '', 0, '', '0', RESHEAD, RESBODY)
End STATUSCODE

#**
#* UPD_META : Update JSon file associated to an object
#*
#* @param OBJET : Object code
#* @param CLE1  : 1st element of primary key
#* @param CLE2  : 2nd element of primary key
#* @param MAJ   : operation type ('C'=creation,'M'=modification,'A'=deletion)
#* @param ERRMES: Return the error message if the process fails
#* @return Error code : [V]CST_AOK -> OK <br>
#*                      or the status code returned by the javascript runner module if an error occured
#*!
Funprog UPD_META(OBJET,CLE1,CLE2,MAJ,ERRMES)
Value Char OBJET
Value Char CLE1
Value Char CLE2()(0..)
Value Char MAJ
Variable Char ERRMES
Local Integer STAT
Raz ERRMES
STAT = [V]CST_AOK

If func ASYRFNC.IS_UPDATE_MONGO=[V]CST_AFALSE : End [V]CST_AOK: Endif

Local Char    TRA(1) , CODE(60) , CODLOT(GLONADI)
Local Integer K,FOUND

K = instr(1,MAJ,"~")
If K
 TRA    = left$(MAJ,K-1)
 CODLOT = right$(MAJ,K+1)
Else
 TRA    = MAJ
 CODLOT = ""
Endif

Gosub SET_TYPOBJ
FOUND = find(OBJET,TYPOBJ(1..NBTYP))
If !FOUND
 End [V]CST_AOK
Endif

# cas particulier
Case OBJET
 When "AAR","ARX","ASY","AMM"
  If TRA="M" : End [V]CST_AOK : Endif
 When "ADI"
  If find(TRA,"M","C") : End [V]CST_AOK : Endif
 When "ADO"
  If TRA="A"
   If clalev([F:ADO])=0 : Local File ADOCUMENT [ADO] : Endif
   Look [ADO]ADO0(3) = CLE2(0);CLE1;CLE2(1)
   If !fstat : TRA = "M" : Endif
  Endif
Endcase

Call CALCUL_CODE(OBJET,CLE1,CLE2,CODE)

If !func OKOBJMARQUAGE(OBJET,CODE)
 End [V]CST_AOK
Endif

If CODE<>"" and TYPNAMCOL(FOUND)<>"" : # enregistrement

 #Cas particulier pour extraction SCM
 Case OBJET
 When "AWR"
  If CODE<>""
   CODE = CLE1+"~"
  Endif
 When "ADP"
  CODE = CLE1
 When "AOP"
  CODE = CLE1
 When "ADO"
  CODE = CLE1+"~"+CLE2(1)
 When "ADZ"
  CODE = CLE1
 When "AMC"
  CODE = CLE2+"~"+CLE1
 When "APH"
  CODE = CLE1
 When "ADI"
  If CLE2(0)<>""
   CODE = CLE2(0)
  Else
   CODE = CLE1
  Endif
 Endcase

 # manage particular deletion
 If MAJ='A'
  Case OBJET
   When "TCA"
    Local File TABCOUAFF [TCA_]
    #For [F:TCA_] Where MODULE=val(CLE2(0)) and MOTCLE=CLE1 and CPY<>CLE2(1)
    For [F:TCA_] Where MODULE=val(CLE2(0)) and LEG=CLE1 and CPY<>CLE2(1)
     MAJ = "M"
     Break
    Next
    Close Local File [TCA_]
   When "ADZ"
    Local File ADOCFLD [ADZ_]
    For [ADZ_] Where LAN<>CLE2(0) and MOTCLE=CLE1
     MAJ = "M"
     Break
    Next
    Close Local File [ADZ_]
   When "ADI"
    Local Integer WCODE : WCODE= val(CODE)
    Local File ATABDIV [ADI__]
    For [ADI__] Where  NUMTAB=WCODE
     MAJ = "M"
     Break
    Next
    Close Local File [ADI__]
   When "ADO"
    Local File ADOCUMENT [ADO_]
    For [ADO_] Where TYP=CLE1 & COD=CLE2(1)
     MAJ = "M"
     Break
    Next
    Close Local File [ADO_]
  Endcase

 Endif
 Local Clbfile RESHEAD, RESBODY
 # Issue X3-44592 - 2017-09-25 by CCC : Use PATCH.ISOK_DELETE + add ATY as removable object
 # Issue X3-70104 - 2018-02-05 by CCC
 #   AI0 is the abbreviation of the table --> used for creation of patch file
 #   AM3 is the abbreviation of the object --> used to identify the definition file
 If MAJ='A' and ( func PATCH.ISOK_DELETE(TYPOBJ(FOUND)) > 0
&              or TYPOBJ(FOUND)="AM3" )
  STAT = func ASYRMETA.REMOVE_METADATA(TYPNAMCOL(FOUND), TYPMAJMONGO(FOUND),  CODE, RESHEAD, RESBODY)
 Else
  STAT = func ASYRMETA.EXTRACT_METADATA(TYPNAMCOL(FOUND), TYPMAJMONGO(FOUND),  CODE, RESHEAD, RESBODY)
 Endif
 If STAT<>[V]CST_AHTTP_OK
    Setlob ERRMES With RESBODY
 Else
    STAT=[V]CST_AOK
 Endif
Endif

End STAT


#------------------------------------------------------------------#
$SET_TYPOBJ
If !clalev([AD97]) : Local File ATABDIV [AD97] : Endif
Local Char    TYPOBJ(GLONAOB)(1..), CUROBJ(GLONAOB), TYPNAMCOL(50)(1..)
Local Integer TYPMAJMONGO(1..)
Local Integer NBTYP
NBTYP = 0
For [AD97] Where NUMTAB=97 & ENAFLG=2
&              & N2>1   # Issue X3-112889 - 2018-10-24 by CCC : only types with "Meta update" flag
 NBTYP += 1
 TYPOBJ(NBTYP) = [AD97]CODE
 TYPNAMCOL(NBTYP) = [AD97]A1
 TYPMAJMONGO(NBTYP) = [AD97]N3
Next
Return

Funprog GETCOLLECTION(CODEOBJ)
Value Char CODEOBJ
Local File ATABDIV [AD97_]
Local Char COLLECTION(80)
For [AD97_] Where NUMTAB=97 & ENAFLG=2 and CODE=[L]CODEOBJ
 [L]COLLECTION = [AD97_]A1
 Break
Next
LogicClose File [AD97_]
End [L]COLLECTION

Funprog GETMAJMONGO(CODEOBJ)
Value Char CODEOBJ
Local File ATABDIV [AD97_]
Local Integer COLLECTION : [L]COLLECTION  = 1
For [AD97_] Where NUMTAB=97 & ENAFLG=2 and CODE=[L]CODEOBJ
 [L]COLLECTION = [AD97_]N3
 Break
Next
LogicClose File [AD97_]
End [L]COLLECTION





######################################
Subprog CALCUL_CODE(OBJET,CLE1,CLE2,CODE)
Value Char OBJET
Value Char CLE1
Value Char CLE2()(0..)
Variable Char CODE

If clalev([F:ATI])=0 : Local File ATABIND   [ATI] : Endif
Local Char CHPS(GLONAVA)(1..16)
Local Integer NBCHP

Case OBJET
 When "ARV"
  CODE = CLE2(0)+"~"+CLE1+"~"+CLE2(1)
 When "AAR","ARX","ASY","AMM"
  CODE = CLE1
 When "ETA"
  CODE = CLE2+"~"+CLE1
 When "ADI"
  CODE = CLE2+"~"+CLE1
 When "ASU","ASB","APP","GTC","APR"
  CODE = CLE2+"~"+CLE1
 When "ADO"
  CODE = CLE2(0)+"~"+CLE1+"~"+CLE2(1)
 When "AWR"
  If CLE2(0)=""
   CODE = "~"+CLE1
  Endif
 When "ADZ","ADF","TFO","TCA","AVR"
  CODE = CLE2(0)+"~"+CLE1
 When Default
  Gosub NOMFIC From ="WO"+OBJET
  Read [ATI]NUMLIG(2)=NOMFIC;1
  Call SETCLE(NBCHP,CHPS,[F:ATI]DESCRIPT) From LNKSUB
  If NBCHP>1
   CODE = CLE2(0)+"~"+CLE1
   For I=3 To NBCHP
    CODE += "~"+CLE2(I)
   Next
  Else
   CODE = CLE1
  Endif
Endcase
End


#######################################################################
Funprog OKOBJMARQUAGE(OBJET,CODE)
Value Char OBJET,CODE
Local Integer NOK
# JML 07/12/2000, on ne marque plus le dictionnaire commençant par W,Y,Z !
NOK  = find(left$(CODE,1),"Y","Z")
NOK += left$(CODE,1)="W" & find(OBJET,"AWI","AMK")
NOK += (OBJET="AWI" & find(left$(CODE,2),"OY","OZ"))
End !NOK

