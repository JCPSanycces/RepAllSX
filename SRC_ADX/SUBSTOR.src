# Actions champs de l'écran STOR : Resynchronisation stock
############################################################
Subprog AS_STOFCY(VALEUR)
Variable Char    VALEUR()
If [M]FCYALL = 2
  VALEUR = ""
  mkstat = 2
Endif
End
############################################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  [M]FCYALL = 2
  Affzo [M]FCYALL
Endif 
End
############################################################
Subprog C_FCYALL(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  [M]STOFCY = ""
  Affzo [M]STOFCY
Endif
End
##########################################################################
Subprog AM_TCLCODSTR(VALEUR)
Variable Char    VALEUR()
    If [M:STOR]TCLCODEND=[M:STOR]TCLCODSTR | [M:STOR]TCLCODEND<VALEUR
        [M:STOR]TCLCODEND = VALEUR
        Affzo [M:STOR]TCLCODEND
    Endif
End

Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
    If [M:STOR]ITMREFEND=[M:STOR]ITMREFSTR | [M:STOR]ITMREFEND<VALEUR
        [M:STOR]ITMREFEND = VALEUR
        Affzo [M:STOR]ITMREFEND
    Endif
End

Subprog AV_FEACTL(VALEUR)            # hcb unicite
Variable Integer VALEUR              # hcb unicite
If GFEALOTLEV <> 2                   # hcb unicite
   Diszo   [M:STOR]FEACTL            # hcb unicite 
Endif                                # hcb unicite 
End                                  # hcb unicite


