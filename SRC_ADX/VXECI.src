#<AdxTL>@(#)0.0.0.0 $Revision$
# Mask Management VXECI


$ACTION
  Case ACTION
    When "DEBUT"         : Gosub DEBUT
    When "OK"            : Gosub OK
  Endcase
Return


######################################################################################
$DEBUT
  Raz   [M:XECI]
  Affzo [M:XECI]
Return

######################################################################################
$OK
  Local Instance SFTTXN Using C_SFTTXN
  SFTTXN = NewInstance C_SFTTXN AllocGroup null
  Local Integer CSTATUS

  [L]CSTATUS = fmet SFTTXN.EMPLOYEE_CLOCKIN([M:XECI]EMPNUM, [M:XECI]FCY)

  Local Date ODATE
  Local Char OTIME(5)
  Call TIMESTAMP([M:XECI]FCY, ODATE, OTIME) From SFTLIB
  OTIME = left$(OTIME,2) + ":" + right$(OTIME,3)
  Call MESSAGE(func AFNC.MES2(mess(73,2422,1),num$([M:XECI]EMPDES), OTIME) ) From GESECRAN

  FreeGroup SFTTXN
  Kill SFTTXN
Return



######################################################################################
Subprog C_EMPNUM(VALEUR)
Variable Decimal VALEUR

  If !clalev([TMA]) : Local File TABMAT [TMA] : Endif

  Read [TMA]TMA0=VALEUR
  If fstat
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(23,100,1)
    mkstat = 1
    End
  Endif

  If [F:TMA]EMPTYP = 2
    #GMESSAGE = mess(76,2422,1)
    Call ERREUR(func AFNC.MES1(mess(76,2422,1), num$(VALEUR))) From GESECRAN #CT-1797
    mkstat = 1
    End
  Endif

  LogicClose File [TMA] #No longer need file

  If func SFTLIB.EMPLOYEEACTIVE(VALEUR) = [V]CST_ANO
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(2,126,1)
    mkstat = 1
    End
  Endif

  If func SFTLIB.EMPLOYEE_CLOCKED_IN(VALEUR) = [V]CST_AYES
    #GMESSAGE = mess(14,2422,1)
    Call ERREUR(func AFNC.MES1(mess(14,2422,1), num$(VALEUR))) From GESECRAN #CT-1797
    mkstat = 1
    End
  Endif

End


######################################################################################
Subprog AM_EMPNUM(VALEUR)
Variable Decimal VALEUR
  #Get the employee default site (if it exists)
  If !clalev([TMA]) : Local File TABMAT [TMA] : Endif

  Read [TMA]TMA0=VALEUR

  # Default employee description and the site if populated
  [M:XECI]EMPDES = [F:TMA]EMPDES
  [M:XECI]FCY=[F:TMA]DEFFCY

  LogicClose File [TMA]
  Affzo [M:XECI]FCY
End


######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" : End : Endif

  Local Char PARAMRET(4)
  Raz PARAMRET
  Call PARAM(VALEUR,"SFTEMPCLK",PARAMRET) From ADOVAL
  If val([L]PARAMRET) = [V]CST_ANO
    GMESSAGE = mess(75,2422,1)
    mkstat = 1
    End
  Endif

End


######################################################################################

