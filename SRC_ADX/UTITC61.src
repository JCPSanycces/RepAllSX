#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################
# UTITC61  Migration of Notes description from A type field to ATEXTRA AX2  SAM # 99684  #
# FGR :  April 2014                                                                      #
##########################################################################################
Local Char DOSSIER(30) : DOSSIER = nomap

  # Issue 108760 - 2015-08-07 by MAE :
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  If DOSSIER <> ""
    If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
    # Issue 108760 - 2015-08-07 by MAE :
    #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
    If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE(mess(45,9901,1)-mess(47,195,1)-mess(892,10031,1)) From LECFIC  # Updating notes categories

    If [F:ADS]MODULE(8) = 2 Then
      Call MAJ_UTITC61(DOSSIER)
    Endif
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

#############################
Subprog MAJ_UTITC61(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR, WNOT, WRET
Local Integer TODO
Local Char SKEY1(250)
Local Char SKEY2(250)

  Call ECR_TRACE("UTITC61 : Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER+".ATEXTRA" [AXX]
  Local File =DOSSIER+".AMSKPAR" [AMP]
  Raz COMPTEUR
  Read [AMP]CODPAR=2;"NOTCATEG";"NTGDESAXX";"CLECUR2"
  If !fstat Then
    If [F:AMP]VALPAR = "NTGCOD" Then
      Call DEBTRANS From GLOCK
      GOK = 1
      TODO = 0
      For [F:AXX] Where CODFIC = "NOTCATEG" and ([F:AXX]IDENT2 = "1" or [F:AXX]IDENT2 = "2" or [F:AXX]IDENT2 = "3") and not ([F:AXX]IDENT1 = "1" or [F:AXX]IDENT1 = "2" or [F:AXX]IDENT1 = "3")
        TODO = 1
        Break
      Next
      If TODO = 1 Then
        Trbegin [AXX] # Note category and Texts to translate
        For [F:AXX] Where CODFIC = "NOTCATEG"
          SKEY1 = [F:AXX]IDENT1
          SKEY2 = [F:AXX]IDENT2
          # -------------
          [F:AXX]IDENT1 = SKEY2
          [F:AXX]IDENT2 = SKEY1
          # -------------
          Look [F:AXX]AXX0="NOTCATEG";[F:AXX]ZONE;[F:AXX]LANGUE;SKEY2;SKEY1
          If fstat Then
            Rewrite [F:AXX]
            If fstat Then
              GOK = 0
              # MAE, ISSU N°110362
              #Call ECR_TRACE(mess(44,125,1) - mess(658,182,1)) From GESECRAN
              Call ECR_TRACE(mess(44,125,1) - mess(658,182,1),1) From GESECRAN
              Call FSTA("AXX") From GLOCK
              Break
            Else
              COMPTEUR += 1
            Endif
          Else
            Delete [F:AXX]AXX0="NOTCATEG";[F:AXX]ZONE;[F:AXX]LANGUE;SKEY1;SKEY2
          Endif
        Next
        If !GOK Then
          Rollback
        Else
          Commit
        Endif
      Endif
    Endif
  Endif
  Call ECR_TRACE("UTITC61 :" - num$(COMPTEUR) - mess(192,124,1),0) From GESECRAN
End

########################################################################
#  For automatic execution during patch integration                    #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 : End : Endif
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif

  # On  regarde si le module Formation est à "Oui"
  If [F:ADS]MODULE(8) <> 2 : End : Endif
  If filinfo(filpath("FIL","NOTCATEG","fde",APPLI),0)<=0 : End : Endif
  If filinfo(filpath("FIL","ATEXTRA","fde",APPLI),0)<=0 : End : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If func DOSVUE.ISVIEW(APPLI,"NOTCATEG") : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"ATEXTRA") : End : Endif
  Call MAJ_UTITC61(APPLI)
End

#######################################################################
# For execution during folder validation
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 End : Endif
  If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  # On  regarde si le module Formation est à "Oui"
  If [F:ADS]MODULE(8) <> 2 : End : Endif  # 8 from Common Data on Folders
  If filinfo(filpath("FIL","NOTCATEG","fde",APPLI),0)<=0 : End : Endif
  If filinfo(filpath("FIL","ATEXTRA","fde",APPLI),0)<=0 : End : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If func DOSVUE.ISVIEW(APPLI,"NOTCATEG") : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"ATEXTRA") : End : Endif
  Call MAJ_UTITC61(APPLI)
End

