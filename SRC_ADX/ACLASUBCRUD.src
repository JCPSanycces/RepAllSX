#<AdxTL>@(#)4.0.0.0 $Revision$
Gosub TEST From ACLAVAL
End

$ADDCLB
Append CLOB,space$(DIF)+LIGNE+chr$(10)
Return

$ADDCLB0
Append CLOB,LIGNE+chr$(10)
Return

#-------------------------------------------------------#
# Ajout entete
#-------------------------------------------------------#
$ENTETE_SUBPROG
DIF = 0
NIVEAU = 1
NBFOR = 0
NIVPARCOURS = 0
LIGNE = "" : Gosub ADDCLB
LIGNE = "############################################################################################"   : Gosub ADDCLB
LIGNE = "### Subprog "+PROGRAM  : Gosub ADDCLB
LIGNE = "############################################################################################"   : Gosub ADDCLB
Gosub HEADER
LIGNE = "" : Gosub ADDCLB
LIGNE = "If"-[L]ROOTNAM-"= null : End : Endif" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
If left$(PROGRAM,1)="_"
 LIGNE = "Gosub _AVARIABLES From "+ACLA.ACLAV.TRTCRUD : Gosub ADDCLB
Else
 LIGNE = "Gosub AVARIABLES From "+ACLA.ACLAV.TRTCRUD : Gosub ADDCLB
Endif
Gosub ERREUR_ACTION_GOTO
LIGNE = ""  : Gosub ADDCLB
If PROGRAM="ADELETE"
 LIGNE = "Local Instance ALNKDELTAB Using C_ALNKDELTAB" : Gosub ADDCLB
 LIGNE = ""   : Gosub ADDCLB
Endif
Return

$INIT_SNAPSHOT
LIGNE = "[L]A_I = "+[L]ROOTNAM+".freeSnapshot" : Gosub ADDCLB
LIGNE = [L]ROOTNAM+".snapshotEnabled = 1" : Gosub ADDCLB
Return

#-------------------------------------------------------#
# Entete
#-------------------------------------------------------#
$HEADER
LIGNE = "Subprog "+PROGRAM+"("+[L]ROOTNAM
If PROGRAM=[V]CST_APRGAREAD : #  Read on ajoute les parametre
 For I=1 To ACLA.NBCLEREF
  LIGNE += ",_"+ACLA.ACLAI(I).CLEREF
 Next
Endif
LIGNE += ",ASTATUS)"  : Gosub ADDCLB
LIGNE = "Variable Instance "+[L]ROOTNAM+" Using "+ACLA.ACLAV.NOMSTC : Gosub ADDCLB
If PROGRAM=[V]CST_APRGAREAD : # Read  on ajoute les parametre
 For I=1 To ACLA.NBCLEREF
  LIGNE = "Value"-func ACLAVALTRT.DECLARE_TYPTYP(ACLA.ACLAI(I).CLEINTREF)-"_"+ACLA.ACLAI(I).CLEREF
  Gosub ADDCLB
 Next
Endif
LIGNE = "Variable Integer ASTATUS"  : Gosub ADDCLB
Return

#-------------------------------------------------------#
# Ajout read table principale avec parametres
#-------------------------------------------------------#
$READ_TABLE_PRINCIPALE_PARAM
LIGNE = "Default File [F:"+ACLA.ACLAK( NIVEAU).ABRLNK+"]"  : Gosub ADDCLB
LIGNE = "Read [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"+ACLA.ACLAK(NIVEAU).CLELNK-"= [L]_"+ACLA.ACLAK(NIVEAU).INDEX(1)
For I=2 To ACLA.ACLAK(NIVEAU).NBRIND
 LIGNE += ";[L]_"+ACLA.ACLAK(NIVEAU).INDEX(I)
Next I
Gosub ADDCLB
LIGNE = "If fstat" : Gosub ADDCLB
DIF += 1
Gosub ERROR_READ
DIF -= 1
LIGNE =  "Endif" : Gosub ADDCLB
If ACLA.FLTREF<>""
 LIGNE = "If ("+ACLA.FLTREF+")=0" : Gosub ADDCLB
 DIF += 1
 Gosub ERROR_READ
  DIF -= 1
 LIGNE =  "Endif" : Gosub ADDCLB
Endif
Return

$ERROR_READ
LIGNE = "[L]A_ERROR = "
For I=1 To ACLA.ACLAK(NIVEAU).NBRIND
 If I>1 : LIGNE += '+"~"+' : Endif
 If  ACLA.ACLAK(NIVEAU).TYPIND(I)<>[V]CST_ATYPCHAR : LIGNE += 'num$(' : Endif
 LIGNE += '[L]_'+ACLA.ACLAK(NIVEAU).INDEX(I)
 If  ACLA.ACLAK(NIVEAU).TYPIND(I)<>[V]CST_ATYPCHAR : LIGNE += ")" : Endif
 If len(LIGNE)>100
  Gosub ADDCLB
  LIGNE ="& "
 Endif
Next I
Gosub ADDCLB0
LIGNE =  '& -":"-mess(23,100,1)' : Gosub ADDCLB0
LIGNE = '[L]ASTATUS = func ASYRSUB._ASETSTATUS('+[L]ROOTNAM+',"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto '+PROGRAM+'_END' : Gosub ADDCLB
Return

#-------------------------------------------------------#
# Gestion erreur avec Goto
#-------------------------------------------------------#
$ERREUR_ACTION_GOTO
If left$(PROGRAM,1)<>"_"
 LIGNE = "If [L]ASTATUS>=[V]CST_AERROR : Goto"-PROGRAM+"_END : Endif" : Gosub ADDCLB
Endif
Return

#-------------------------------------------------------#
# Gestion erreur
#-------------------------------------------------------#
$ERREUR_ACTION_RECURSIF
LIGNE = ""
If ISFOR>0
 LIGNE = 'If [L]ASTATUS>=[V]CST_AERROR : Break'-string$(NBFOR>1,num$(NBFOR))+" : Endif" : Gosub ADDCLB
Else
 LIGNE = 'If [L]ASTATUS>=[V]CST_AERROR : Return : Endif' : Gosub ADDCLB
Endif
Return

#-------------------------------------------------------#
# Ajout control code accés et auto par site
#-------------------------------------------------------#
$AJOUT_ACCES_SITE
If PROGRAM="AREAD"
 If ACLA.TYPCLA<>2 : Return : Endif
 If ACLA.FCYSTR<>""
  LIGNE = "[L]A_STRSITE = [F:"+ACLA.ACLAK(1).ABRLNK+"]"+ACLA.FCYSTR : Gosub ADDCLB
 Else
  LIGNE = '[L]A_STRSITE = ""' : Gosub ADDCLB
 Endif
 If ACLA.ACCSTR<>""
  LIGNE = "[L]A_STRACC = [F:"+ACLA.ACLAK(1).ABRLNK+"]"+ACLA.ACCSTR : Gosub ADDCLB
 Else
  LIGNE = '[L]A_STRACC = ""' : Gosub ADDCLB
 Endif
Else
 If ACLA.FCYSTR<>""
  LIGNE = "[L]A_STRSITE = "+[L]ROOTCLA+"."+ACLA.FCYSTR : Gosub ADDCLB
 Else
  LIGNE = '[L]A_STRSITE = ""' : Gosub ADDCLB
 Endif
 If ACLA.ACCSTR<>""
  LIGNE = "[L]A_STRACC = "+[L]ROOTCLA+"."+ACLA.ACCSTR : Gosub ADDCLB
 Else
  LIGNE = '[L]A_STRACC = ""' : Gosub ADDCLB
 Endif
Endif
Return

#-------------------------------------------------------#
# Retourne la table de la chaine TABLE~ABR
#-------------------------------------------------------#
Funprog TABLE(CHAINE)
Value Char CHAINE
If instr(1,CHAINE," ")
 End left$(CHAINE,instr(1,CHAINE," ")-1)
Endif
End CHAINE

#-------------------------------------------------------#
# Retourne l'abréviation de la chaine TABLE~ABR
#-------------------------------------------------------#
Funprog ABREV(CHAINE)
Value Char CHAINE
If instr(1,CHAINE," ")
 End right$(CHAINE,instr(1,CHAINE," ")+1)
Endif
End CHAINE

#-------------------------------------------------------#
# Test si UUID est vide
#-------------------------------------------------------#
$ADD_UUID
LIGNE = "If dim([F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]AUUID)>0 & [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]AUUID=NullUuid" : Gosub ADDCLB
DIF +=1
LIGNE = "[F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]AUUID = getUuid" : Gosub ADDCLB
DIF -=1
LIGNE = "Endif" : Gosub ADDCLB
Return

#-------------------------------------------------------#
# Si dans l'expression de lien , il y a des champs de la table sans [F:ABR] je le rajoute
#-------------------------------------------------------#
Funprog RECHCHP(CHAINE,TABLE,ABREV,DOSSIER)
Value Char CHAINE
Value Char TABLE
Value Char ABREV
Value Char DOSSIER

Local File =DOSSIER+".ATABZON"    [ATZ_]

For [F:ATZ_] Where CODFIC = TABLE
 If CHAINE = [F:ATZ_]CODZONE
  CHAINE = "[F:"+ABREV+"]"+[F:ATZ_]CODZONE
  Break
 Endif
Next

Close Local File [F:ATZ_]
End CHAINE

#-------------------------------------------------------#
# Declare ACTION :
#-------------------------------------------------------#
Subprog DECLARE_ACTION(WCLASSE,ACTION,VARPRO,APATH,AABR,LIGNE,DIF,CLOB)
Value Char WCLASSE
Value Char ACTION
Value Char VARPRO
Value Char APATH
Value Char AABR
Value Char LIGNE
Variable Integer DIF
Variable Clbfile CLOB
If instr(0,ACTION,"AUPDATE")>0 & VARPRO=""
 LIGNE = "[L]A_ASTALIN = "+WCLASSE+".ASTALIN" : Gosub ADDCLB
 LIGNE = "[L]ASTATUS = max([L]ASTATUS,fmet "+WCLASSE+'.ACTION('
 LIGNE += '[V]CST_ASTALIN([L]A_ASTALIN)+"'+right$(ACTION,len("AUPDATE")+1)+'"))' : Gosub ADDCLB
Else
 LIGNE = "[L]ASTATUS = max([L]ASTATUS,fmet "+WCLASSE+'.ACTION("'+ACTION+'"))' : Gosub ADDCLB
Endif
End

#-------------------------------------------------------#
# Etiquette ABORT dans crud C U D
#-------------------------------------------------------#
$ABORT
LIGNE = "#-----------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$"+PROGRAM+"_ABORT" : Gosub ADDCLB
If ACLA.FLGTR=2
 LIGNE = "Rollback" : Gosub ADDCLB
Endif
LIGNE = "$_"+PROGRAM+"_ABORT" : Gosub ADDCLB
LIGNE = "If "+[L]ROOTNAM+".snapshotEnabled=1" : Gosub ADDCLB
DIF += 1
LIGNE = "[L]A_RETIK = "+[L]ROOTNAM+".revertUpdTick" : Gosub ADDCLB
DIF -=1
LIGNE = "Endif" : Gosub ADDCLB
If PROGRAM="AUPDATE"
 Gosub TRT_AFTERREWRITE_KO From ACLAREWRITECRUD
Endif
#Call DECLARE_ACTION([L]ROOTNAM,PROGRAM+"_ABORT","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
#Gosub ERREUR_ACTION_GOTO
#LIGNE = "[L]A_ABORT = fmet "+[L]ROOTNAM+'.ACTION("'+PROGRAM+'_ABORT")' : Gosub ADDCLB
LIGNE = "[L]ASTATUS = max(fmet "+[L]ROOTNAM+'.ACTION("'+PROGRAM+'_ABORT"),[L]ASTATUS)' : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "#-----------------------------------------------------#" : Gosub ADDCLB
LIGNE = ""  : Gosub ADDCLB
Return

#-------------------------------------------------------#
# Ajout close logic
#-------------------------------------------------------#
$CLOSELOGICFILE
J = 0 : Raz LIGNE
For I=1 To maxtab(ACLA.ACLAK)
 If ACLA.ACLAK(I).TABLNK<> "" & ACLA.ACLAK(I).ABRLNK<> ""
  J + = 1
  If  J=1
   LIGNE = "LogicClose File"-"["+ACLA.ACLAK(I).ABRLNK+"]"
  Else
   LIGNE -= ",["+ACLA.ACLAK(I).ABRLNK+"]"
  Endif
 Endif
Next
If LIGNE<>"" : Gosub ADDCLB :Endif
Return

