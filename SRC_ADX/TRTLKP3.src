#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################################################
#   Traitement de sélection d'un parc concerné                               Module CRM        2 juin 2003
##########################################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When "OK"           : Gosub ONOK
 When Default
Endcase
Return

##########################################################################################################
$OUVRE
Local Integer ITER
Local Integer IBFOUND
ITER = 0
IBFOUND=0

If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
If !clalev([F:MAC]) : Local File MACHINES [MAC] : Endif

#PARAM(1) = N° de ligne appelante

#Obtention du libellé du champ Marque
Global Char GLKP3MACBRA
Local Char SZTXTNUM
Call PARAML("", "MACBRAUSE", SZTXTNUM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
Call TEXTE(val(SZTXTNUM), GLKP3MACBRA) From OBJDIV
If GLKP3MACBRA = ""
    Call TEXTE(14543, GLKP3MACBRA) From OBJDIV
Endif

#LSE 09/01/2006 FQ34168
For ITER = 0 To [M:SRE7]NBMAC - 1
    If [M:SRE7]MAC(ITER)<>""
        IBFOUND=1
        Break
    Endif
Next
If IBFOUND=0
    GERR = 2
    FIN = 1
    GMESSAGE = mess(212,177,1)
    Return
Endif

Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
If [M:LKP3]NBLIG > 0
    ETABOU(GVALI) = 1
Else
    ETABOU(GVALI) = 0
Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT

[M:LKP3]NOL = val(PARAM(1))

[M:LKP3]TTR = [M:SRE1]SRETTR

Gosub LOADLKP3
Affzo [M:LKP3]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
Kill GLKP3MACBRA

#Nettoie l'écran avant de partir.
If clalev([M:LKP3])
    Raz [M:LKP3]
Endif
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
$ONOK
VALEUR = [M:LKP3]MACNUM(nolign - 1)
[M:SRE9]HDTMACSRE([M:LKP3]NOL) = [M:LKP3]MACNUM(nolign - 1)
mkstat = 4
Return


##########################################################################################################
# Chargement du parc concerné
#########################################################
$LOADLKP3

Local Integer ITER
ITER = 0

For ITER = 0 To [M:SRE7]NBMAC - 1
    Read [MAC] MAC0 = [M:SRE7]MAC(ITER)
    If !fstat
        [M:LKP3]MACNUM(ITER) = [F:MAC]MACNUM
        [M:LKP3]MACPDTCOD(ITER) = [F:MAC]MACPDTCOD
        #Call LECTEXTRA([M:LKP3]MACPDTDES(ITER), "ITMMASTER", "DES1AXX", [M:LKP3]MACPDTCOD(ITER), "") From ATEXTRA
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[M:LKP3]MACPDTCOD(ITER),[M:LKP3]MACPDTDES(ITER), "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
        [M:LKP3]MACSERNUM(ITER) = [F:MAC]MACSERNUM
        [M:LKP3]MACQTY(ITER) = [F:MAC]MACQTY
        [M:LKP3]MACBRACLA(ITER) = [F:MAC]MACBRACLA
        [M:LKP3]NBLIG += 1
    Endif
Next

Return

