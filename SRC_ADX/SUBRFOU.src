#<AdxTL>@(#)6.0.0.0 $Revision$
#############################################################
#                                                           #
# Traitement lié à l'action d'éclatement des POS            #
# dans le but de leur affecter des fournisseurs différents  #
#                                                           #
#     Action : TRTREPFOU                                    #
#                                       MM        06/01     #
#############################################################
$ACTION
Case ACTION
    When "INIT"       : Gosub INIT
    When "OUVRE"      : Gosub OUVRE
    When "DEBUT"      : Gosub DEBUT
    When "OK"         : Gosub OK
    When "EXEC"       : Gosub EXEC
Endcase

Return

#############################################################
$INIT
Return

#############################################################
$OUVRE

Local Integer I, J, NOL
Local Decimal WQTY1, WWRK, WMOD
If clalev ([M:ORDK])= 0 : Local Mask ORDK [ORDK] : Endif

NOL = val(PARAM(1))
Return

#############################################################
$DEBUT
Raz [M:RFOU]
Raz [M:RFOK]

# Quantité à répartir
[M:RFOU]RMNEXTQTY = [M:MGP]RMNEXTQTY(NOL)
# Article
[M:RFOU]ITMREF    = [M:MGP]ITMREF(NOL)
# Désignation
[M:RFOU]ITMDES1   = [M:MGP]ITMDES1(NOL)
# Unité d'achat
[M:RFOU]STU       = [M:MGP]STU(NOL)
Read [ORD]ORD0 = [M:MGP]WIPTYP(NOL);[M:MGP]WIPNUM(NOL);[M:RFOU]ITMREF
If  fstat <> 0 : GERR=1 : GMESSAGE = (mess(297,196,1)) : Return : Endif


# Remplissage du tableau
# récupération du nombre de fournisseur
I= 0
Filter [ITP] Where [F:ITP]ITMREF = [M:RFOU]ITMREF

For [ITP]ITP1
    # Fournisseur
    [M:RFOU]BPSNUM(I) = [F:ITP]BPSNUM
    # priorité
    [M:RFOU]PIO(I)    = [F:ITP]PIO
    I += 1
Next
Filter [ITP]


# éclatement par défaut : la quantité de l'article à commander
# est divisée à part égale entre chaque fournisseur,
# S'il existe un relicat, il est attribué au fournisseur prioritaire


If I>0
    WQTY1 = ([M:RFOU]RMNEXTQTY / I)
Endif
# arrondi
Call QTEARR(WQTY1, [M:RFOU]STU) From TRTDIV
WWRK = WQTY1 * I
WMOD = [M:RFOU]RMNEXTQTY - WWRK

[M:RFOU]SOMQTY  = 0
For J= 0 To I-1
    If (J=0 & WMOD >= 0)
       [M:RFOU]REPQTY(J) =  WQTY1 + WMOD
    Else
        If (J = I-1 & WMOD < 0)
           [M:RFOU]REPQTY(J) =  WQTY1 + WMOD
            # si on se retrouve avec une quantité négative
           If [M:RFOU]REPQTY(J) < 0 : [M:RFOU]REPQTY(J)= 0 : Endif
        Else
           [M:RFOU]REPQTY(J) =  WQTY1
        Endif
    Endif
    [M:RFOU]SOMQTY += [M:RFOU]REPQTY(J)
Next J

# Calcul du pourcentage associé à la quantité par défaut
[M:RFOU]SOMPERCEN = 0
For J= 0 To I-1
 [M:RFOU]PERCEN(J) = ([M:RFOU]REPQTY(J) *100 )/[M:RFOU]RMNEXTQTY
 #arrondi
 [M:RFOU]PERCEN(J) =  arr([M:RFOU]PERCEN(J),0.01)
 [M:RFOU]SOMPERCEN += [M:RFOU]PERCEN(J)
Next J



[M:RFOU]YNBLIG = I
Affzo [M:RFOU]1-99


Return


#############################################################
$OK
Local Integer OK

# Pour gérer la fin sans validation
If [M:RFOU]YNBLIG <> 0
    OK = 1
    Call OUINON(mess(20,196,1), OK) From GESECRAN
    If OK<> 2 : GERR = 1 : FIN = 0 : Return : Endif
Endif


Gosub MAJ_OK
J = 0
For I=0 To [M:RFOU]YNBLIG-1
    If [M:RFOU]REPQTY(I) >0
       [M:RFOK]REPQTY(J)       = [M:RFOU]REPQTY(I)
       [M:RFOK]BPSNUM(J)       = [M:RFOU]BPSNUM(I)
       [M:RFOK]WIPNUM(J)       = [M:RFOU]WIPNUM(I)
       J += 1
   Endif
Next I

[M:RFOK]NBLIG = J
Return

#############################################################
$EXEC
# Rafraichissement de l'écran

If [M:RFOK]NBLIG = 0 : Return : Endif

# ouverture des n lignes à gérer
If [M:RFOK]NBLIG > 1
   Insa nolign, [M:RFOK]NBLIG-1,[M:MGP]NBLIG+[M:RFOK]NBLIG-1 [M:MGP]NBLIG
Endif
[M:MGP]NBLIG +=  [M:RFOK]NBLIG - 1

#Alimentation des nouvelles lignes
J= 0

For I = nolign-1 To (nolign-1 + [M:RFOK]NBLIG -1)
If [M:RFOK]BPSNUM(J) <> [M:MGP]BPSNUM(I) : [M:MGP]POHNUM(I) = "" : Endif
[M:MGP]BPSNUM(I)     = [M:RFOK]BPSNUM(J) #fournisseur
[M:MGP]BPRNUM(I)     = [M:RFOK]BPSNUM(J) #tiers
[M:MGP]RMNEXTQTY(I)  = [M:RFOK]REPQTY(J) #quantité restante
[M:MGP]EXTQTY(I)     = [M:RFOK]REPQTY(J) #quantité prévue
[M:MGP]WIPNUM(I)     = [M:RFOK]WIPNUM(J)
[M:MGP]PECQTY(I)     = [M:MGP]RMNEXTQTY(I)
    Call PCAL_QTY([M:MGP]PECQTY(I), [M:MGP]STU(I),[M:MGP]PUUPECQTY(I),[M:MGP]PUU(I),
&                 [M:MGP]ITMREF(I),[M:MGP]BPSNUM(I),1,GBIDD1) From TRTACHQTE1
If J > 0
    [M:MGP]WIPSTA(I)     = [M:MGP]WIPSTA(nolign-1)
    [M:MGP]WIPTYP(I)     = [M:MGP]WIPTYP(nolign-1)
    [M:MGP]WIPTYPSTA(I)  = [M:MGP]WIPTYPSTA(nolign-1)
    [M:MGP]VCRLIN(I)     = [M:MGP]VCRLIN(nolign-1)
    [M:MGP]VCRNUM(I)     = [M:MGP]VCRNUM(nolign-1)
    [M:MGP]VCRSEQ(I)     = [M:MGP]VCRSEQ(nolign-1)
    [M:MGP]VCRTYP(I)     = [M:MGP]VCRTYP(nolign-1)
    [M:MGP]ITMREF(I)     = [M:MGP]ITMREF(nolign-1)
    [M:MGP]STOFCY(I)     = [M:MGP]STOFCY(nolign-1)
    [M:MGP]STRDAT(I)     = [M:MGP]STRDAT(nolign-1)
    [M:MGP]ENDDAT(I)     = [M:MGP]ENDDAT(nolign-1)
    [M:MGP]STU(I)        = [M:MGP]STU(nolign-1)
    [M:MGP]POHIND(I)     = [M:MGP]POHIND(nolign-1)
    [M:MGP]POHNUM(I)     = ""
    [M:MGP]MRPMES(I)     = [M:MGP]MRPMES(nolign-1)
    [M:MGP]XMRPMES(I)    = [M:MGP]XMRPMES(nolign-1)
    [M:MGP]MRPDAT(I)     = [M:MGP]MRPDAT(nolign-1)
    [M:MGP]ALLQTY(I)     = [M:MGP]ALLQTY(nolign-1)
    [M:MGP]SHTQTY(I)     = [M:MGP]SHTQTY(nolign-1)
    [M:MGP]REQDAT(I)     = [M:MGP]REQDAT(nolign-1)
    [M:MGP]PUU(I)        = [M:MGP]PUU(nolign-1)
    [M:MGP]PUUSTUCOE(I)  = [M:MGP]PUUSTUCOE(nolign-1)
    [M:MGP]NETPRI(I)     = [M:MGP]NETPRI(nolign-1)
    [M:MGP]CUR(I)        = [M:MGP]CUR(nolign-1)
    [M:MGP]PJT(I)        = [M:MGP]PJT(nolign-1)
    [M:MGP]CPLQTY(I)     = [M:MGP]CPLQTY(nolign-1)
    [M:MGP]ITMDES1(I)    = [M:MGP]ITMDES1(nolign-1)
    [M:MGP]PIO(I)        = [M:MGP]PIO(nolign-1)
    [M:MGP]FMI(I)        = [M:MGP]FMI(nolign-1)
    [M:MGP]VCRTYPORI(I)  = [M:MGP]VCRTYPORI(nolign-1)
    [M:MGP]VCRLINORI(I)  = [M:MGP]VCRLINORI(nolign-1)
    [M:MGP]VCRSEQORI(I)  = [M:MGP]VCRSEQORI(nolign-1)
    [M:MGP]ITMREFORI(I)  = [M:MGP]ITMREFORI(nolign-1)
    [M:MGP]BOMALT(I)     = [M:MGP]BOMALT(nolign-1)
    [M:MGP]BOMOPE(I)     = [M:MGP]BOMOPE(nolign-1)
    [M:MGP]PLANNER2(I)   = [M:MGP]PLANNER2(nolign-1)
    [M:MGP]BUY(I)        = [M:MGP]BUY(nolign-1)
    [M:MGP]ORIFCY(I)     = [M:MGP]ORIFCY(nolign-1)
    [M:MGP]VCRNUMORI(I)  = [M:MGP]VCRNUMORI(nolign-1)
    [M:MGP]USEPLC(I)     = [M:MGP]USEPLC(nolign-1)
    # Issue X3-38525 - YARAM : While spliting supplier order suggestion into 2, purchase site is not updated when I = 1 .
    [M:MGP]POHFCY(I)     = [M:MGP]POHFCY(nolign-1)
Endif
 J += 1
Next I


Affzo [M:MGP]20
Return
#############################################################
$MAJ_OK
# MAJ de la table ORDERS

# creation des nouveaux ordres
For I=0 To [M:RFOU]YNBLIG -1
    If [M:RFOU]REPQTY(I) > 0
        Raz [M:ORDK]
        [M:ORDK]MAJCOD = "C"
        [M:ORDK] = [F:ORD]
        [M:ORDK]WIPNUM = ""
        [M:ORDK]BPRNUM = [M:RFOU]BPSNUM(I)
        [M:ORDK]EXTQTY = [M:RFOU]REPQTY(I)
        Call WIP From TRTWIP
        [M:RFOU]WIPNUM(I)=[M:ORDK]WIPNUM
    Endif
Next

#Destruction de l'enregistrement initial
Trbegin[ORD]
   Readlock [ORD]ORD0 = [M:MGP]WIPTYP(NOL);[M:MGP]WIPNUM(NOL);[M:RFOU]ITMREF
   If  fstat <> 0 : GERR=1 : GMESSAGE =(mess(297,196,1)) : Rollback : Return : Endif
   Delete [F:ORD]
   If  fstat <> 0 : GERR=1 : GMESSAGE =(mess(28,125,1)) : Rollback : Return : Endif
   Unlock [ORD]
Commit

Return

########################################
#
#     ETIQUETTES ECRAN
#
########################################
Subprog AVANT_YNBLIG
[M:RFOU]SOMQTY     -= [M:RFOU]REPQTY(nolign -1)
[M:RFOU]SOMPERCEN  -= [M:RFOU]PERCEN(nolign -1)
End

########################################
Subprog APRES_YNBLIG
[M:RFOU]SOMQTY     += [M:RFOU]REPQTY(nolign -1)
[M:RFOU]SOMPERCEN  += [M:RFOU]PERCEN(nolign -1)
Affzo [M:RFOU]SOMQTY, SOMPERCEN

End


#######################################
# si l'utilisateur modifie la quantité par défaut, calcul du nouveau pourcentage
Subprog AM_REPQTY(VALEUR)
Variable Decimal VALEUR
If VALEUR <> [M:RFOU]REPQTY(nolign -1)
    [M:RFOU]PERCEN(nolign -1) = (VALEUR *100 )/[M:RFOU]RMNEXTQTY
    [M:RFOU]PERCEN(nolign -1) = arr([M:RFOU]PERCEN(nolign -1) , 0.01)
Endif
End


########################################
# si l'utilisateur modifie le pourcentage par défaut, calcul de la nouvelle quantité
Subprog AM_PERCEN(VALEUR)
Variable Decimal VALEUR
If VALEUR <> [M:RFOU]PERCEN(nolign -1)
   [M:RFOU]REPQTY(nolign-1)= ( (VALEUR *[M:RFOU]RMNEXTQTY)/ 100 )
   Call QTEARR(  [M:RFOU]REPQTY(nolign-1), [M:RFOU]STU) From TRTDIV
Endif
Affzo [M:RFOU]REPQTY(nolign -1)
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran REPFOU) 12/11/2012 15:08:24 (SR)
# Issue 85772 - 2012-11-12 by SR : contrôler selon paramètre général ITMBPS
######################################################################################
Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()
# Issue 89025 - 2013-03-29 by SR
Local Integer WRETOUR
If clalev([F:ITP]) = 0 : Local File ITMBPS [ITP] : Endif
# Issue 6976 - 2014-10-08 by MUARN : changement de masque
Look [ITP]ITP0 = [M:RFOU]ITMREF;VALEUR
If fstat
    # Issue 6976 - 2011-12-16 by MUARN : référencement inutile si article type générique
    If [F:ITM]ITMREF <> [M:RFOU]ITMREF
      Read [ITM]ITM0=[M:RFOU]ITMREF
      If fstat : Raz [F:ITM] : Endif
    Endif
    If [F:ITM]GENFLG <>2
      # couple article - fournisseur n'existe pas
      If GITMBPS = 1
          # paramètre général : on ne continue pas
          Call ERREUR(mess(8,194,1)) From GESECRAN
          mkstat = 2
          End
      Elsif GITMBPS = 2
          # paramètre général : facultatif donc avertir
          Call AVERTIR(mess(8,194,1),WRETOUR) From GESECRAN
          If WRETOUR = 1
              VALEUR = [M:RFOU]BPSNUM(nolign-1)
              mkstat = 2
              End
          Endif
      Endif
    Endif
Endif
End

######################################################################################

