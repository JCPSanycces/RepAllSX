#<AdxTL>@(#)0.0.0.0 $Revision$ Gûˋnûˋration traitements
Call GENTRT(nomap)
End

$ACTION
Case ACTION
 When "INIT" : TIT = mess(19,10702,1) : # Gûˋnûˋration traitements
 When "EXEC" : Call GENTRT(nomap)
Endcase
Return

###########################################
## Gûˋnûˋration traitement de gestion des tables
###########################################
Subprog GENDOS(APPLI)
Value Char APPLI
Call GENTRT(APPLI)
End

Subprog GENTRT(APPLI)
Value Char APPLI

Local File =APPLI+".ATABLE"  [ATB]
Local File =APPLI+".ATABZON" [ATZ]
Local File =APPLI+".ATABIND" [ATI]
Local File =APPLI+".ATYPE"   [ATY]

Local Char    TRAITEMENT(10) , FICSRC(250) , TETADO(80) , SAVIFS(5) , SAVIRS(5)
Local Char    CHAMP(10) , TEXTE(50), VCLE(10)
Local Integer I , J , K , OK, SPA, CONTRAT, CHILDREN #67074

GNBEMPTAB = 0
For [ATB]CODFIC Where left$(CODFIC,5)="EMPLO"
 GNBEMPTAB += 1
 GEMPTAB(GNBEMPTAB) = [F:ATB]CODFIC
 Read [ATI]NUMLIG(2) = [F:ATB]CODFIC;1
 Case [F:ATI]DESCRIPT
  When "REFNUM"        : GTYPTAB(GNBEMPTAB) = 1
  When "REFNUM+NUMLIG" : GTYPTAB(GNBEMPTAB) = 2
  When Default         : GTYPTAB(GNBEMPTAB) = 3
 Endcase
Next
Sorta GNBEMPTAB GEMPTAB,GTYPTAB Order By GTYPTAB(indice+1)

TRAITEMENT = "WPDEFTABLE"

TETADO = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"

FICSRC = filpath("TRT",TRAITEMENT,"src",APPLI)
SAVIFS = adxifs
SAVIRS = adxirs
adxifs = ""
adxirs = chr$(10)

Openo FICSRC,0

Wrseq
Wrseq "$DEFAUT"
Wrseq "Case TABLE"
For I=1 To GNBEMPTAB
 Read [ATB]CODFIC = GEMPTAB(I)
 Wrseq ' When ';format$('K:15X','"'+GEMPTAB(I)+'"');' : Default File [';[F:ATB]ABRFIC;']'
Next
Wrseq "Endcase"
Wrseq "Return"
Wrseq

Wrseq "$LECEMP"
# En attendant les modifs
Wrseq "If dim(CTR)<0"
Wrseq " Local Char CTR(GLONHRCTR)"
Wrseq "Endif"
For I=1 To GNBEMPTAB
 Read [ATB]CODFIC = GEMPTAB(I)
 If GEMPTAB(I)="EMPLOCHD" : CHILDREN=1 : Else : CHILDREN=0 : Endif    #67074

 If left$([F:ATB]ABRFIC,2)="HR"
  VCLE=right$([F:ATB]ABRFIC,3)
 Else
  VCLE=[F:ATB]ABRFIC
 Endif

 Read [ATI]NUMLIG(2) = GEMPTAB(I);1
 If [F:ATI]DESCRIPT = "REFNUM"
 #Wrseq "Read ["+[F:ATB]ABRFIC+"]"+[F:ATB]ABRFIC+"0 = MATRI"
  Wrseq "Read ["+[F:ATB]ABRFIC+"]"+VCLE+"0 = MATRI"
 Elsif left$([F:ATI]DESCRIPT,13) = "REFNUM+CTRNUM"
  SPA = 0 : CONTRAT = 1  
  Gosub LIRE_TABLE
 Else
  SPA = 0 : CONTRAT = 0
  Gosub LIRE_TABLE
 Endif
Next I
Wrseq "Return"
Wrseq

Wrseq "$OUVRE"
For I=1 To GNBEMPTAB
 Read [ATB]CODFIC = GEMPTAB(I)
 Wrseq "If clalev([F:"+[F:ATB]ABRFIC+"])=0 : Local File "+[F:ATB]CODFIC+" ["+[F:ATB]ABRFIC+"] : Endif"
Next I
Wrseq "Return"
Wrseq

Wrseq "$VARTEMPS"
Wrseq "NBVAR = 0"
For [ATZ]NUMLIG Where CODFIC="TIMRECAP" & CODTYP="CDY"
 Wrseq 'NBVAR += 1 : TBVAR(NBVAR) = "';[F:ATZ]CODZONE;'"'
 Call TEXTE([F:ATZ]NOLONG,TEXTE) From OBJDIV
 Wrseq 'LIBVAR(NBVAR) = "';TEXTE;'"'
Next
Wrseq "Return"
Wrseq

Wrseq "$DATETEMPS"
Wrseq "NBDAT = 0"
For [ATZ]NUMLIG Where CODFIC="TIMEMPDAT" & left$(CODZONE,3)="DAT" & CODTYP="D"
 Wrseq 'NBDAT += 1 : TBDAT(NBDAT) = "';right$([F:ATZ]CODZONE,4);'"'
 Call TEXTE([F:ATZ]NOLONG,TEXTE) From OBJDIV
 Wrseq 'LIBDAT(NBDAT) = "';TEXTE;'"'
Next
Wrseq "Return"
Wrseq



Openo

Call VALID("TRT",TRAITEMENT,APPLI,OK) From VALMSKSUB

adxifs = SAVIFS
adxirs = SAVIRS

End

$LIRE_TABLE
OK = 0
Read [ATI]NUMLIG(2) = GEMPTAB(I);2
If !fstat
 J = instr(1,[F:ATI]DESCRIPT,"+")
 If J & CONTRAT
  J += instr(1,right$([F:ATI]DESCRIPT,J+1),"+")
 Endif
 If J
  CHAMP = right$([F:ATI]DESCRIPT,J+1)
  Read [ATZ]CODZONE = GEMPTAB(I);CHAMP
  If !fstat
   Read [ATY]CODTYP = [F:ATZ]CODTYP
   If [F:ATY]TYPTYP=8
    OK = 1
   Endif
  Endif
 Endif
Endif
If OK

 If CONTRAT
  Wrseq space$(SPA); "If CTR<>''"
  Wrseq space$(SPA+1); "Filter ["+[F:ATB]ABRFIC+"] Where REFNUM=MATRI & CTRNUM=CTR & ";CHAMP;"<=DATMAT"
  Wrseq space$(SPA); "Else"
  Wrseq space$(SPA+1); "Filter ["+[F:ATB]ABRFIC+"] Where REFNUM=MATRI & ";CHAMP;"<=DATMAT"
  Wrseq space$(SPA); "Endif"
 Else
  Wrseq space$(SPA); "Filter ["+[F:ATB]ABRFIC+"] Where REFNUM=MATRI & ";CHAMP;"<=DATMAT"
 Endif
  
 #Wrseq space$(SPA); "Read ["+[F:ATB]ABRFIC+"]"+[F:ATB]ABRFIC+"1 Last"
 Wrseq space$(SPA); "Read ["+[F:ATB]ABRFIC+"]"+VCLE+"1 Last"

 Wrseq space$(SPA);"If fstat : Raz [F:"+[F:ATB]ABRFIC+"] : Endif"
 Wrseq space$(SPA);"Filter ["+[F:ATB]ABRFIC+"]"
Else
 If CONTRAT
  Wrseq space$(SPA);"Filter ["+[F:ATB]ABRFIC+"] Where REFNUM=MATRI & CTRNUM=[F:HRCTR]CTRNUM"
 Else
  Wrseq space$(SPA);"Filter ["+[F:ATB]ABRFIC+"] Where REFNUM=MATRI"
 Endif
 #67074
 If !CHILDREN
  #Wrseq space$(SPA);"Read ["+[F:ATB]ABRFIC+"]"+[F:ATB]ABRFIC+"0 First"
  Wrseq space$(SPA);"Read ["+[F:ATB]ABRFIC+"]"+VCLE+"0 First"
 Else
  #Wrseq space$(SPA);"Read ["+[F:ATB]ABRFIC+"]"+[F:ATB]ABRFIC+"1 Last"
  Wrseq space$(SPA);"Read ["+[F:ATB]ABRFIC+"]"+VCLE+"1 Last"
 Endif
 Wrseq space$(SPA);"If fstat : Raz [F:"+[F:ATB]ABRFIC+"] : Endif"
 Wrseq space$(SPA);"Filter ["+[F:ATB]ABRFIC+"]"
Endif
Return



