#<AdxTL>@(#)5.0.0.0 $Revision$
Raz GBIDC1, GBIDC2 , GPILOBJ , GNBMASKOUV
Local Char PARAM(30)(1..2) , VALEUR(10)
GACTION = "AVOCAB"
Call SAISIE_CHAR(VALEUR,PARAM,"AVOCAB","AVOCAB","") From GSAISIE
End

#----------------------------------------------------------------------#
$ACTION
Case GACTION

 When "AVOCAB" : # Perso vocabulaire

  Case ACTION
   When "DEBUT"        : Gosub DEBUT
   When "SETBOUT"      : Gosub SETBOUT
   When "APRES_MODIF"  : Gosub APRES_MODIF
   When "AVANT_CRE"    : Gosub AVANT_CRE
   When "AVANT_SUP"    : Gosub AVANT_SUP
   When "BOUTON"       : Gosub BOUTON
   When "CRE"          : Gosub CRE
   When "ENR"          : Gosub ENR
   When "SUP"          : Gosub SUP
   When "ABA"          : Gosub ABA
   When "FIN"          : Gosub FIN
   When "SUI"          : Gosub SUI
   When "PRE"          : Gosub PRE
   When "FIR"          : Gosub FIR
   When "LAS"          : Gosub LAS
  Endcase

 When "AVOCABVAL" : # Validation avec saisie no de version

  Case ACTION
   When "INIT"         : Gosub INIT
   When "EXEC"         : Gosub EXEC
  Endcase

 When "AVOCABCOP" : # Copie

  Case ACTION
   When "INIT_DIA"     : Gosub INIT_COP
   When "EXEC"         : Gosub EXEC_COP
   When Default
  Endcase

Endcase
Return

#---------------------------------------------#
$DEBUT
Local Char    SUPER(GLONADS)
Local Char    LANGUE(GLONLAN) , CLECUR1(GLONLAN)
Local Char    SYMBOLE(10)
Local Integer VERSION , CLECUR2 , VERCUR
Local Char    CLETXT(20)
Local Integer NUMMOD(1..10000) , NBMOD , NBAST
SYMBOLE = "AVOCAB"
Call PARAM("","SUPDOS",SUPER) From ADOVAL
If nomap=SUPER & GADONIX<>2
    GMESSAGE = mess(112,125,1) : # Opération impossible sur ce dossier
    GERR = 1 : FIN = 1
    Return
Endif
If clalev([F:AVO])=0 : Local File AVOCAB [AVO] : Endif
Local File ATEXTE           [AX1]
Local File APLSTD           [AS1]
Local File TABLAN           [TLA1]

Local File =SUPER+".ATEXTE" [AX2]
Local File =SUPER+".APLSTD" [AS2]
Local File =SUPER+".TABLAN" [TLA2]

LANGUE  = GLANGUE
Read [AVO]AVO0(1) = LANGUE
VERSION = max([F:AVO]CUR,1)
VERCUR = [F:AVO]CUR
Gosub LECTURE
Return

#---------------------------------------------#
$SETBOUT
If REP<>"" or GCONSULT or CLECUR2=0
 Call VIREBOUT(CHMEN,"12") From GOBJET  : # Copie/Validation
Endif
If GCONSULT
 Call VIREBOUT(CHBOU,"SC") From GOBJET : # Suppression/Création
Endif
If CLECUR2=0
 Call VIREBOUT(CHBOU,"S") From GOBJET
Endif
Return

#---------------------------------------------#
$LECTURE
Raz [M]
[M]LAN = LANGUE
[M]VER = VERSION
Gosub SETCUR
CLECUR1 = LANGUE
CLECUR2 = VERSION
Read [TLA1]TLA0 = LANGUE
If !fstat : [M]LANMAIN=[F:TLA1]LANMAIN : Endif
If [M]LANMAIN<>"" : [M]WLAN = [M]LANMAIN : Else : [M]WLAN=[M]LAN : Endif
REP = ""
nolign = 0
For [AVO]AVO0 Where LAN=LANGUE & VER=VERSION
 nolign += 1
 [M] = [F:AVO]
 [M]CUR = VERCUR
 Case [F:AVO]TYP
  When 1
   Read [AX2]NUMERO = [M]WLAN;[F:AVO]NUM
   If !fstat
    [M]STD(nolign-1) = [F:AX2]TEXTE
    [M]LNG(nolign-1) = [F:AX2]LONG
   Endif
   If [M]LNG(nolign-1)=0
    For [AX2]DERNUM Where NUMERO=[F:AVO]NUM
     If [F:AX2]LONG<>0
      [M]LNG(nolign-1) = [F:AX2]LONG
      Break
     Endif
    Next AX2
   Endif
   If [M]LNG(nolign-1)=0
    [M]LNG(nolign-1) = GLONDES
   Endif
  When 2
   Read [AS2]CLE = [F:AVO]CHP;[F:AVO]NUM;[M]WLAN
   If !fstat
    [M]STD(nolign-1) = [F:AS2]LANMES
   Endif
   [M]LNG(nolign-1) = type([F:AS2]LANMES)-10
 Endcase
 [M]CLE(nolign-1) = num$([F:AVO]TYP)-num$([F:AVO]CHP)-num$([F:AVO]NUM)
Next
[M]NBLIG = nolign
Affzo
Return

$SETCUR
If VERCUR=0
 [M]LIBCUR = mess(1,7817,1) : # Aucune
Else
 [M]LIBCUR = mess(VERCUR,7840,1)
Endif
Return

#---------------------------------------------#
$APRES_MODIF
Case COUZON
 When "LAN"
  Read [AVO]AVO0(2)=zc;[M]VER
  If !fstat
   LANGUE = zc
   Gosub LECTURE
  Else
   Effzo [M:AVO1]20
   Affzo [M:AVO1]20
   REP = "C"
  Endif
 When "VER"
  Read [AVO]AVO0(2)=[M]LAN;zc
  If !fstat
   VERSION = zc
   Gosub LECTURE
  Else
   REP = "C"
  Endif
 When Default
  If REP=""
   If GCONSULT
    GERR = 1 : GMESSAGE = mess(9,123,1) : # Modification impossible
   Else
    Lock =SYMBOLE
    If fstat
     GERR = 1 : GMESSAGE = mess(10,100,1) : # Modification en cours sur un autre poste
    Else
     REP = "M"
     Grizo LAN , VER
    Endif
   Endif
  Endif
Endcase
Return

#-----------------------#
$BOUTON
Case BOUT
 When "2"
  Read [AVO]AVO0(1) = LANGUE
  [M]CUR = [F:AVO]CUR
  VERCUR = [M]CUR
  Gosub SETCUR
  Affzo [M]LIBCUR
Endcase
Return

#-----------------------#
$AVANT_CRE
For I=1 To [M]NBLIG : [M]FLG(I-1) = 1 : Next I
Return

#-----------------------#
$AVANT_SUP
Lock =SYMBOLE
If fstat
 GERR = 1 : GMESSAGE = mess(10,100,1)
Else
 [M]NBLIG = 0
Endif
Return

#-----------------------#
$ABA
LANGUE = CLECUR1
VERSION = CLECUR2
Gosub LECTURE
Actzo LAN , VER
Unlock =SYMBOLE
Return

#-----------------------#
$SUP
Gosub VALID
Unlock =SYMBOLE
CLECUR2 = 0
Gosub LECTURE
Return

#-----------------------#
$CRE
$ENR
Gosub VALID
REP = ""
CLECUR1 = LANGUE
CLECUR2 = VERSION
Actzo LAN , VER
Unlock =SYMBOLE
Return

#-----------------------#
$SUI
Read [AVO]AVO0(2) = CLECUR1;CLECUR2
Read [AVO]AVO0(2) Nxt
Goto SUIPRE

#-----------------------#
$PRE
Read [AVO]AVO0 = CLECUR1;CLECUR2
Read [AVO]AVO0 Prev
Goto SUIPRE

#-----------------------#
$FIR
Read [AVO]AVO0 First
Goto SUIPRE

#-----------------------#
$LAS
Read [AVO]AVO0 Last
Goto SUIPRE

#-----------------------#
$SUIPRE
If !fstat
 LANGUE  = [F:AVO]LAN
 VERSION = [F:AVO]VER
 Gosub LECTURE
Endif
Return

#-----------------------#
$FIN
Unlock =SYMBOLE
Return

#-----------------------#
$VALID
Raz NBMOD , NUMMOD , NBAST
Gosub TR1
If GOK<1 : Return : Endif
Read [AVO]AVO0(1) = LANGUE
[M]CUR = [F:AVO]CUR
VERCUR = [M]CUR
Gosub SETCUR
Affzo [M]LIBCUR
If NBAST>0
 Local Char SYMB(10)
 SYMB = "APLSTD"
 Lock =SYMB With lockwait=0
 If !fstat
  Call GENMENU(nomap,0,0,[M]LAN) From GENMENULOC
 Endif
 Unlock =SYMB
Endif
If NBMOD>0
 Call VALMSK(nomap,[M]LAN,NUMMOD,NBMOD)
Endif
Return

#-----------------------#
$TR1
GOK = 1
Trbegin [AVO]

# Textes supprimés

 For [AVO]AVO0 Where LAN=[M]LAN & VER=VERSION
  CLETXT = num$([F:AVO]TYP)-num$([F:AVO]CHP)-num$([F:AVO]NUM)
  If !find(CLETXT,[M]CLE(0..[M]NBLIG-1))
   If VERCUR=VERSION
    Case [F:AVO]TYP
     When 1
      Read [AX2]NUMERO = [M]LAN;[F:AVO]NUM
      If !fstat
       Read [AX1]NUMERO = [M]LAN;[F:AVO]NUM
       If fstat
        [F:AX1]LAN    = [M]LAN
        [F:AX1]NUMERO = [F:AVO]NUM
        [F:AX1]TEXTE  = [F:AX2]TEXTE
        Write [AX1]
       Else
        [F:AX1]TEXTE = [F:AX2]TEXTE
        Rewrite [AX1]
       Endif
       If fstat
        GOK = 0 : Call FSTA("AX1") From GLOCK : Break
       Endif
      Endif
      NBMOD += 1
      NUMMOD(NBMOD) = [F:AVO]NUM
     When 2
      Read [AS2]CLE = [F:AVO]CHP;[F:AVO]NUM;[M]LAN
      If !fstat
       Read [AS1]CLE = [F:AVO]CHP;[F:AVO]NUM;[M]LAN
       If fstat
        [F:AS1]LANCHP = [F:AVO]CHP
        [F:AS1]LANNUM = [F:AVO]NUM
        [F:AS1]LAN    = [M]LAN
        [F:AS1]LANMES = [F:AS2]LANMES
        Write [AS1]
       Else
        [F:AS1]LANMES = [F:AS2]LANMES
        Rewrite [AS1]
       Endif
       If fstat
        GOK = 0 : Call FSTA("AS1") From GLOCK : Break
       Endif
      Endif
      NBAST += 1
    Endcase
   Endif
   Delete [AVO]
   If fstat=1
    GOK = -1 : GLOCK = "$AVOCAB"-[M]LAN-num$(VERSION)-num$([M]CHP(nolign-1))-num$([M]NUM(nolign-1)) : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

# Textes modifiés

 For nolign=1 To [M]NBLIG
  If [M]FLG(nolign-1)
   Readlock [AVO]AVO0 = [M]LAN;VERSION;[M]TYP(nolign-1);[M]CHP(nolign-1);[M]NUM(nolign-1)
   If fstat=1
    GOK = -1 : GLOCK = "$AVOCAB"-[M]LAN-num$(VERSION)-num$([M]CHP(nolign-1))-num$([M]NUM(nolign-1)) : Break
   Elsif fstat
    [F:AVO] = [M]
    Write [AVO]
   Else
    [F:AVO] = [M]
    Rewrite [AVO]
   Endif
   If fstat
    GOK = 0 : Call FSTA("AVO") From GLOCK : Break
   Endif
   If VERCUR=VERSION
    Case [F:AVO]TYP
     When 1
      Read [AX1]NUMERO = [M]LAN;[F:AVO]NUM
      If fstat
       [F:AX1]LAN    = [M]LAN
       [F:AX1]NUMERO = [F:AVO]NUM
       [F:AX1]TEXTE  = [F:AVO]TXT
       Write [AX1]
      Else
       [F:AX1]TEXTE = [F:AVO]TXT
       Rewrite [AX1]
      Endif
      If fstat
       GOK = 0 : Call FSTA("AX1") From GLOCK : Break
      Endif
      NBMOD += 1
      NUMMOD(NBMOD) = [F:AVO]NUM
     When 2
      Read [AS1]CLE = [F:AVO]CHP;[F:AVO]NUM;[M]LAN
      If fstat
       [F:AS1]LANCHP = [F:AVO]CHP
       [F:AS1]LANNUM = [F:AVO]NUM
       [F:AS1]LAN    = [M]LAN
       [F:AS1]LANMES = [F:AVO]TXT
       Write [AS1]
      Else
       [F:AS1]LANMES = [F:AVO]TXT
       Rewrite [AS1]
      Endif
      If fstat
       GOK = 0 : Call FSTA("AS1") From GLOCK : Break
      Endif
      NBAST += 1
    Endcase
   Endif
  Endif
 Next nolign
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

 # Mise à jour du numéro de version courante

 Read [AVO]AVO0(2) = LANGUE;VERCUR
 If !fstat
  Update [AVO] Where LAN=[M]LAN With CUR=VERCUR
 Else
  Update [AVO] Where LAN=[M]LAN With CUR=0
 Endif

Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#----------------------------------------------------------------------#
# Appelé depuis la validation de dossier
#----------------------------------------------------------------------#

Subprog GENDOS
Local Integer VERCUR , VERSION
If clalev([F:AVO])=0 : Local File =[F:ADS]DOSSIER+".AVOCAB"  [AVO] : Endif

Local File =[F:ADS]DOSSIER+".TABLAN"  [ZTLA]

# jira 65070
# only in case of derived language
# call from SUBADS2 in creation and if language is added during validation
# Loop on language of folder and only if the language is not std
Local Integer WIND
Local Char WLANGUE

For WIND = 0 To [F:ADS]NBRLAN-1
  WLANGUE = [F:ADS]LAN (WIND)
  If  WLANGUE <> ""
    Read [F:ZTLA]TLA0 = WLANGUE
    If fstat = 0
        # language must not be a std language
        If [F:ZTLA]LANSTD <> 2
            # recuperation du premier record de la langue
            # contient le numero de la version courante à appliquer
            # si version courante = 0  on n applique rien pas normal
            Read [AVO]AVO0(1) = WLANGUE
            If !fstat and [F:AVO]CUR<>0
                  VERSION = [F:AVO]CUR
                  VERCUR  = [F:AVO]CUR
                  Call ECR_TIME(mess(148,133,1)-WLANGUE) From DOSSUB : # Personnalisation vocabulaire
                  Call VALVOC([F:ADS]DOSSIER,WLANGUE,VERSION,VERCUR,1,2,3)
                  Call ECR_TIME("End: "+mess(148,133,1)) From DOSSUB : # Personnalisation vocabulaire
            Endif
        Endif
    Endif
  Endif
Next WIND


Close Local File [AVO], [ZTLA]
End

#----------------------------------------------------------------------#
# Action AVOCABVAL
#----------------------------------------------------------------------#

$INIT
TMP = 1
Local Char    LANGUE(GLONLAN)
Local Integer VERCUR , VERSION
LANGUE  = [M:AVO1]LAN
VERSION = [M:AVO1]VER
Read [AVO]AVO0(1) = LANGUE
VERCUR = [F:AVO]CUR
Local Mask AVO9 [AVO9]
[M:AVO9]OPTION1 = 1 : # Version courante
[M:AVO9]OPTION2 = 2 : # Revalidation des écrans
Return

#-----------------------#
$EXEC
If [M:AVO9]OPTION2=2
 Call TEMPON("V") From GESECRAN
 Call OUVRE_TRACE(mess(144,133,1)) From LECFIC : # Revalidation des écrans
Endif

If [M:AVO9]OPTION2=2 and dim([M:AVO9]OPTION3)>0 and [M:AVO9]OPTION3=2
 [M:AVO9]OPTION2 =1
 Call VALVOC(nomap,LANGUE,VERSION,VERCUR,[M:AVO9]OPTION1,[M:AVO9]OPTION2,0)
 Call VALDICOADDLANG(nomap)
 [M:AVO9]OPTION2 =2
Else
 Call VALVOC(nomap,LANGUE,VERSION,VERCUR,[M:AVO9]OPTION1,[M:AVO9]OPTION2,0)
Endif

If [M:AVO9]OPTION2=2
 Call FERME_TRACE From LECFIC
 Call TEMPOFF From GESECRAN
 TRA = 1
Endif

FIN = 1
Return

#-------------------------------------------------------------#
Subprog VALVOC(APPLI,LANGUE,VERSION,VERCUR,OPTION1,OPTION2,ROPTION)
Value Char    APPLI,LANGUE
Value Integer VERSION , VERCUR , OPTION1 , OPTION2
Value Integer ROPTION


Local Char    CLETXT(20),LANMAIN(GLONLAN)
Local Integer NUMMOD(1..10000) , NBMOD , NBAST

If APPLI=GDOSX3 & GADONIX<>2
    Call ECR_TRACE(APPLI-":"-mess(112,125,1),1) From GESECRAN : # Opération impossible sur ce dossier
    End
Elsif GDOSX3=""
    Call ECR_TRACE(mess(78,125,1),1) From GESECRAN : # Superviseur inexistant
    End
Endif

If clalev([F:AVO])=0  : Local File =APPLI+".AVOCAB"  [AVO]  : Endif
If clalev([F:AX1])=0  : Local File =APPLI+".ATEXTE"  [AX1]  : Endif
If clalev([F:AXRR])=0 : Local File =APPLI+".ATEXTE"  [AXRR] : Endif

If clalev([F:AS1])=0  : Local File =APPLI+".APLSTD"  [AS1]  : Endif
If clalev([F:ASRR])=0 : Local File =APPLI+".APLSTD"  [ASRR]  : Endif

If clalev([F:TLA1])=0 : Local File =APPLI+".TABLAN" [TLA1] : Endif

If clalev([F:AX2])=0  : Local File =GDOSX3+".ATEXTE" [AX2]  : Endif
If clalev([F:AS2])=0  : Local File =GDOSX3+".APLSTD" [AS2]  : Endif

Read [F:TLA1]TLA0 = LANGUE
If !fstat
    [L]LANMAIN = [F:TLA1] LANMAIN
Endif

Raz NBMOD , NUMMOD , NBAST
Call DEBTRANS From GLOCK
Gosub TR2
If GOK<>1 or OPTION2<>2
        End
Endif

# Validation des menus locaux
Call ECR_TRACE("Update local menu for "-LANGUE,0) From GESECRAN
If NBAST>0
  Local Char SYMB(10)
  SYMB = "APLSTD"
  Lock =SYMB With lockwait=0
  If !fstat
     Call GENMENU(APPLI,0,0,LANGUE) From GENMENULOC
  Endif
  Unlock =SYMB
Else
  If ROPTION = 3
      # dans tous les cas sur gendos + lagnue derivée on le fait
      # il se peut que avocab on n est rien dans ce fichier mais il faut quand même
      # lancer la generation des menux laocux pour avoir le ,menloc.js dans la langue
     Local Char SYMB(10)
     SYMB = "APLSTD"
     Lock =SYMB With lockwait=0
     If !fstat
        Call GENMENU(APPLI,0,0,LANGUE) From GENMENULOC
     Endif
     Unlock =SYMB
  Endif
Endif

#Création des répertoires X3_PUB s'il n'existent pas
# a ne pas faire si on vient de gendos pas necessaire roption = 3
If ROPTION <> 3
  Call CREREPPUB(APPLI) From INTRUTILC
Endif

# Création de la liste des langues du dossier (connectx3langs)
Call CRELIBWEBD(APPLI) From INTRUTILC

# Validation des écrans
If NBMOD>0
    Call ECR_TRACE("START : screen validation for "-LANGUE,0) From GESECRAN
    If ROPTION = 3
      # valico complet car ajout de langue ou creation de dossier
      # a voir ?????
        Call VALMSK(APPLI,LANGUE,NUMMOD,NBMOD)
    Else
      Call VALMSK(APPLI,LANGUE,NUMMOD,NBMOD)
    Endif
    Call ECR_TRACE("END : screen validation for "-LANGUE,0) From GESECRAN
Endif

Close Local File
End

#----------------------------------#
# langue derivée on remet les enreg de atexte et aplstd avec langue std

$TR_DELINS_LANGUE

If [L]LANMAIN="" : Return : Endif

Read [F:TLA1]TLA0 = LANGUE
If !fstat and [F:TLA1]LANSTD=2
       Return
Endif

 GOK = 1
 # pour la table ATEXTE
 Delete [AX1] Where LAN=LANGUE
 If fstat=1
      GOK=-1 : GLOCK = "$ATEXTE"-num$([F:AX1]NUMERO) : Return
 Endif

 For [AX1]NUMERO Where LAN=LANMAIN
     [F:AXRR]       = [F:AX1]
     [F:AXRR]LAN    = LANGUE
     Write [AXRR]
     If fstat
          # jira 69361 more detail in log
          Call LOG_ERROR_DETAILS(1, "AXRR",LANGUE+"~"+num$([F:AX1]NUMERO),"") From GLOCK
          GOK = 0
          Break
     Endif
 Next
 If GOK<=0 : Return : Endif

 # Pour la table APLSTD
 Delete [AS1] Where  LAN=LANGUE
 If fstat=1
        GOK=-1 : GLOCK = "$APLSTD"-num$([AS1]LANCHP) : Return
 Endif
 For [AS1]LAN Where LAN=LANMAIN
        [F:ASRR]     = [F:AS1]
        [F:ASRR]LAN   = LANGUE
        Write [ASRR]
        If fstat
              # jira 69361 more detail in log
              Call LOG_ERROR_DETAILS(1, "ASRR",num$([F:AS1]LANCHP)+"~"+num$([F:AS1]LANNUM)+"~"+LANGUE,"") From GLOCK
              GOK = 0
              Break
        Endif
 Next
 If GOK<=0 : Return : Endif

Return


#----------------------------------#
$TR2
GOK = 1
Trbegin [AVO]

 If [L]LANMAIN<>"" : # Duplication de langue primaire dans la langue derivee
    Call ECR_TRACE("START : duplication texte and aplstd  "-LANGUE,0) From GESECRAN
    # supression de tous les textes et messages + copie de ceux de la langue principale
    Gosub TR_DELINS_LANGUE
    If   GOK<0
          Goto ROLL_TR2
    Elsif !GOK
          Goto AB_TR2
    Endif
 Endif
Call ECR_TRACE("AVOCAB :  "-LANGUE-"version: "-num$(VERCUR),0) From GESECRAN

# si on vient de gendos pas besoin car on a fait la copie des textes  dans TR_DELINS_LANGUE
If ROPTION <> 3
 For [AVO]AVO0 Where LAN=LANGUE & VER=VERCUR
  CLETXT = num$([F:AVO]TYP)-num$([F:AVO]CHP)-num$([F:AVO]NUM)
  Case [F:AVO]TYP
   When 1
    Read [AX2]NUMERO = LANGUE;[F:AVO]NUM
    If !fstat
     Read [AX1]NUMERO = LANGUE;[F:AVO]NUM
     If fstat
      [F:AX1]LAN    = LANGUE
      [F:AX1]NUMERO = [F:AVO]NUM
      [F:AX1]TEXTE  = [F:AX2]TEXTE
      Write [AX1]
     Else
      [F:AX1]TEXTE = [F:AX2]TEXTE
      Rewrite [AX1]
     Endif
     If fstat
      GOK = 0 : Call FSTA("AX1") From GLOCK : Break
     Endif
     NBMOD += 1
     NUMMOD(NBMOD) = [F:AVO]NUM
    Endif
   When 2
    Read [AS2]CLE = [F:AVO]CHP;[F:AVO]NUM;LANGUE
    If !fstat
     Read [AS1]CLE = [F:AVO]CHP;[F:AVO]NUM;LANGUE
     If fstat
      [F:AS1]LANCHP = [F:AVO]CHP
      [F:AS1]LANNUM = [F:AVO]NUM
      [F:AS1]LAN    = LANGUE
      [F:AS1]LANMES = [F:AS2]LANMES
      Write [AS1]
     Else
      [F:AS1]LANMES = [F:AS2]LANMES
      Rewrite [AS1]
     Endif
     If fstat
      GOK = 0 : Call FSTA("AS1") From GLOCK : Break
     Endif
     NBAST += 1
    Endif
  Endcase
 Next AVO
 If   GOK<0 : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif

Endif


# Mise en place des nouveaux textes de avocab

 If OPTION1=1 : # Version courante
  Call ECR_TRACE("AVOCAB :  "-LANGUE-"version: "-num$(VERSION),0) From GESECRAN
  For [AVO]AVO0 Where LAN=LANGUE & VER=VERSION
   Case [F:AVO]TYP
    When 1
     Read [AX1]NUMERO = LANGUE;[F:AVO]NUM
     If fstat
      [F:AX1]LAN    = LANGUE
      [F:AX1]NUMERO = [F:AVO]NUM
      [F:AX1]TEXTE  = [F:AVO]TXT
      Write [AX1]
     Else
      [F:AX1]TEXTE = [F:AVO]TXT
      Rewrite [AX1]
     Endif
     If fstat
      GOK = 0 : Call FSTA("AX1") From GLOCK : Break
     Endif
     If !find([F:AVO]NUM,NUMMOD(1..NBMOD))
      NBMOD += 1
      NUMMOD(NBMOD) = [F:AVO]NUM
     Endif
    When 2
     Read [AS1]CLE = [F:AVO]CHP;[F:AVO]NUM;LANGUE
     If fstat
      [F:AS1]LANCHP = [F:AVO]CHP
      [F:AS1]LANNUM = [F:AVO]NUM
      [F:AS1]LAN    = LANGUE
      [F:AS1]LANMES = [F:AVO]TXT
      Write [AS1]
     Else
      [F:AS1]LANMES = [F:AVO]TXT
      Rewrite [AS1]
     Endif
     If fstat
      GOK = 0 : Call FSTA("AS1") From GLOCK : Break
     Endif
     NBAST += 1
   Endcase
  Next AVO
  If   GOK<0 : Goto ROLL_TR2
  Elsif !GOK : Goto AB_TR2
  Endif
 Endif



 # Mise à jour du numéro de version courante

 If OPTION1=1 : # Version courante
    Update [AVO] Where LAN=LANGUE With CUR=VERSION
 Else : # Version standard
    Update [AVO] Where LAN=LANGUE With CUR=0
 Endif

Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

#----------------------------------------------------------------------#
# Validation des objets
#----------------------------------------------------------------------#

Subprog VALDICOADDLANG(APPLI)
Value Char    APPLI

Local Integer REQUETE,OK,ER

OK = 2
Call OUINON(mess(139,123,1),OK) From GESECRAN : # Validation écran
If OK<>2 : End : Endif

Local Mask VALDICO [DIA]

[M:DIA]TYPVAL = 3
[M:DIA]VALIDDIF = 2
Call C_TYPVAL([M:DIA]TYPVAL) From VALDICO
#116686 DERIVED LANGUAGE: GET CONNECTED With A NEW LANGUAGE
Call CRERQT(nomap,GUSER,"",0,"VALDICO",1,date$,left$(time$,2)+seg$(time$,4,5),"","DIA",REQUETE) From REQUETES
If GOK=1
  # Requête transmise au serveur
  Call MESSAGE(mess(29,134,1)+" ("+num$(REQUETE)+")") From GESECRAN
Endif
End

#----------------------------------------------------------------------#
# Validation des objets
#----------------------------------------------------------------------#

Subprog VALMSK(APPLI,LANGUE,NUMMOD,NBMOD)
Value Char    APPLI , LANGUE
Value Integer NUMMOD(1..)
Value Integer NBMOD

Local Integer OKMSK
Local Integer Z , OK
Local Char    MASQUE(GLONAMK)

Local File =APPLI+".AMSK"     [AMK9]
Local File =APPLI+".AMSKZON"  [AMZ9]
Local File =APPLI+".AWINDOW"  [AWI9]
Local File =APPLI+".AWINBOUT" [AWT9]
Local File =APPLI+".AWINBRO"  [AWB9]

Gosub OUVFIC From VALMSKLEC
Gosub OUVFIC From VALWINLEC

For [AMZ9]CODE(1)
 OKMSK = 0
 MASQUE = [F:AMZ9]CODMSK
 Read [AMK9]CODMSK = MASQUE
 If !fstat & [F:AMK9]MDL<>2 & (GPRODUIT<>0 or APPLI<>GDOSX3 or find([F:AMK9]MODULE,1,9,10))
  For Z=0 To [F:AMK9]NBBLOC-1
   If find([F:AMK9]TITBLOC(Z),NUMMOD(1..NBMOD))
    OKMSK = 1 : Break
   Endif
  Next Z
  If !OKMSK & find([F:AMK9]INTMSK,NUMMOD(1..NBMOD))
   OKMSK = 1
  Endif
  If !OKMSK
   For [AMZ9]CODE
    If find([F:AMZ9]INTIT,NUMMOD(1..NBMOD))
     OKMSK = 1 : Break
    Endif
   Next
  Endif
  If OKMSK
   Call VALID(MASQUE,APPLI,1,LANGUE,1,OK) From VALMSK
  Endif
 Endif
Next

For [AWI9]AWI0
 If [F:AWI9]MDL<>2 & (GPRODUIT<>0 or APPLI<>GDOSX3 or find([F:AWI9]MODULE,1,9,10))
  MASQUE = [F:AWI9]WIN
  OKMSK = 0
  For Z=0 To [F:AWI9]NBMSK-1
   If find([F:AWI9]INTMSK(Z),NUMMOD(1..NBMOD))
    OKMSK = 1 : Break
   Endif
  Next Z
  If !OKMSK & find([F:AWI9]DES,NUMMOD(1..NBMOD))
   OKMSK = 1
  Endif
  If !OKMSK
   For [AWT9]AWT0 Where WIN=MASQUE
    If find([F:AWT9]TXTBOUT,NUMMOD(1..NBMOD))
     OKMSK = 1 : Break
    Endif
   Next
  Endif
  If !OKMSK
   Read [AWB9]AWB0 = MASQUE
   If !fstat
    For Z=0 To [F:AWB9]NBLIS-1
     If find([F:AWB9]INTLIS(Z),NUMMOD(1..NBMOD))
      OKMSK = 1 : Break
     Endif
    Next Z
   Endif
  Endif
  If OKMSK
   Call VALID(MASQUE,APPLI,1,OK) From VALWIN
  Endif
 Endif
Next

# Classe

Local File =APPLI+".ACLASSE"     [ACLA9]
Local File =APPLI+".ACLAFLD"     [ACLAF9]
Local File =APPLI+".ACLAMET"     [ACLAM9]
Local File =APPLI+".ACLACOL"    [ACLAC9]
Local File =APPLI+".ACLAOPT"     [ACLAO9]
Local Char ACLASSE(GLONACLA)
Local Integer OKACLA

For [ACLA9]ACLA0
 OKACLA = 0
 ACLASSE = [F:ACLA9]CODCLA
 If  (GPRODUIT<>0 or APPLI<>GDOSX3 or find([F:ACLA9]MODULE,1,9,10))
  If !OKACLA & find([F:ACLA9]INTCLA,NUMMOD(1..NBMOD))
   OKACLA = 1
  Endif
  If !OKACLA
   For [F:ACLAC9]ACLAC0 Where CODCLA= ACLASSE
    If find([F:ACLAC9]INTCOL,NUMMOD(1..NBMOD))
     OKACLA = 1 : Break
    Endif
   Next
  Endif
  If !OKACLA
   For [F:ACLAM9]ACLAM0 Where CODCLA= ACLASSE
    If find([F:ACLAM9]INTMET,NUMMOD(1..NBMOD))
     OKACLA = 1 : Break
    Endif
   Next
  Endif
  If !OKACLA
   For [F:ACLAO9]ACLAO0 Where CODCLA= ACLASSE
    If find([F:ACLAO9]OPTLIB,NUMMOD(1..NBMOD))
     OKACLA = 1 : Break
    Endif
   Next
  Endif
  If !OKACLA
   For [ACLAF9]ACLAF0 Where CODCLA=ACLASSE
    If find([F:ACLAF9]INTFLD,NUMMOD(1..NBMOD))
     OKACLA = 1 : Break
    Endif
   Next
  Endif
  If OKACLA
   Call VALIDATION(0,APPLI,ACLASSE) From SUBACLA
  Endif
 Endif
Next

# Representation

Local File =APPLI+".ASHW"        [ASW9]
Local File =APPLI+".ASHWFLD"     [ASWF9]
Local File =APPLI+".ASHWCOL"     [ASWC9]
Local File =APPLI+".ASHWBLC"     [ASWB9]
Local File =APPLI+".ASHWEXPPRO"  [ASWR9]
Local File =APPLI+".ASHWLNK"     [ASWK9]
Local File =APPLI+".ASHWMET"     [ASWM9]
Local File =APPLI+".ASHWSEC"     [ASWS9]
Local Char    AREP(GLONASW)
Local Integer OKREP

For [ASW9]ASW0
 OKREP = 0
 AREP = [F:ASW9]CODREP
 If (GPRODUIT<>0 or APPLI<>GDOSX3 or find([F:ASW9]MODULE,1,9,10))
  If !OKREP & find([F:ASW9]INTREP,NUMMOD(1..NBMOD))
   OKREP = 1
  Endif
  If !OKREP
   For [ASWB9]ASWB0 Where CODREP = [L]AREP
    If find([F:ASWB9]INTBLC,NUMMOD(1..NBMOD))
     OKREP = 1 : Break
    Endif
   Next
  Endif
  If !OKREP
   For [F:ASWC9]ASWC0 Where CODREP = [L]AREP
    If find([F:ASWC9]INTCOL,NUMMOD(1..NBMOD))
     OKREP = 1 : Break
    Endif
   Next
  Endif
  If !OKREP
   For [F:ASWR9]ASWR0 Where CODREP = [L]AREP
    If find([F:ASWR9]INTPRO,NUMMOD(1..NBMOD))
     OKREP = 1 : Break
    Endif
   Next
  Endif
  If !OKREP
   For [ASWF9]ASWF0  Where CODREP = [L]AREP
    If find([F:ASWF9]INTFLD,NUMMOD(1..NBMOD))
     OKREP = 1 : Break
    Endif
   Next
  Endif
  If !OKREP
   For [ASWK9]ASWK0  Where CODREP = [L]AREP
    If find([F:ASWK9]INTLNK,NUMMOD(1..NBMOD))
     OKREP = 1 : Break
    Endif
   Next
  Endif
  If !OKREP
   For [ASWM9]ASWM0  Where CODREP = [L]AREP
    If find([F:ASWM9]INTMET,NUMMOD(1..NBMOD))
     OKREP = 1 : Break
    Endif
   Next
  Endif
  If !OKREP
   For [ASWS9]ASWS0  Where CODREP = [L]AREP
    If find([F:ASWS9]INTSEC,NUMMOD(1..NBMOD))
     OKREP = 1 : Break
    Endif
   Next
  Endif
  If OKREP
   Call VALIDATION(0,APPLI,AREP) From SUBASW
  Endif
 Endif
Next


Close Local File
End

#----------------------------------------------------------------------#
# AVOCABCOP COPIE
#----------------------------------------------------------------------#

$INIT_COP
Local Char    LANGUE(GLONLAN) , SUPER(GLONADS)
Local Integer VERSION , VERCUR
Call PARAM("","SUPDOS",SUPER) From ADOVAL
LANGUE   = PARAM(1)
VERSION  = val(PARAM(2))
[M]OBJET = mess(148,133,1) : # Personnalisation vocabulaire
TMP = 1
Return

#-----------------------#
$EXEC_COP
If [M]TOUDOS=2
 If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
 For [ADS]DOSSIER Where DOSSIER<>[M]DOSORG & DOSSIER<>SUPER
  If filinfo(filpath("FIL","AVOCAB","fde",[F:ADS]DOSSIER),0)>0
   [M]DOSDES = [F:ADS]DOSSIER
   Gosub TRTCOP
  Endif
 Next
Elsif [M]DOSDES<>SUPER
 Gosub TRTCOP
Else
 Call MESSAGE(mess(112,125,1)) From GESECRAN : # Opération impossible sur ce dossier
Endif
Return

#-----------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File AVOCAB  [AVO1]
Else
 Local File =[M]DOSORG+".AVOCAB"  [AVO1]
Endif
If [M]DOSDES=nomap
 Local File AVOCAB  [AVO2]
 Local File ATEXTE  [ATX2]
 Local File APLSTD  [AST2]
Else
 Local File =[M]DOSDES+".AVOCAB"  [AVO2]
 Local File =[M]DOSDES+".ATEXTE"  [ATX2]
 Local File =[M]DOSDES+".APLSTD"  [AST2]
Endif
Local File =SUPER+".ATEXTE"      [ATX3]
Local File =SUPER+".APLSTD"      [AST3]
Read [AVO2]AVO0(1) = LANGUE
VERCUR = [F:AVO2]CUR
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [AVO1], [AVO2] , [ATX2] , [AST2] , [ATX3] , [AST3]
Return

$TR_COP
GOK = 1
Trbegin [AVO2]
 For [AVO2] Where LAN=LANGUE & VER=VERSION

  # Restitution des textes standard si la version copiée est la version courante sur le dossier destination

  If VERSION=VERCUR
   Case [F:AVO2]TYP
    When 1
     Read [ATX3]NUMERO = LANGUE;[F:AVO2]NUM
     If !fstat
      Readlock [ATX2]NUMERO = LANGUE;[F:AVO2]NUM
      If fstat=1
       GOK = -1 : GLOCK = "$ATEXTE"-num$([F:AVO2]NUM) : Break
      Elsif !fstat
       [F:ATX2]TEXTE = [F:ATX3]TEXTE
       Rewrite [ATX2]
       If fstat
        GOK = 0 : Call FSTA("ATX2") From GLOCK : Break
       Endif
      Endif
     Endif
    When 2
     Read [AST3]CLE = [F:AVO2]CHP;[F:AVO2]NUM;LANGUE
     If !fstat
      Readlock [AST2]CLE = [F:AVO2]CHP;[F:AVO2]NUM;LANGUE
      If fstat=1
       GOK = -1 : GLOCK = "$APLSTD"-num$([F:AVO2]CHP)-num$([F:AVO2]NUM) : Break
      Elsif !fstat
       [F:AST2]LANMES = [F:AST3]LANMES
       Rewrite [AST2]
       If fstat
        GOK = 0 : Call FSTA("AST2") From GLOCK : Break
       Endif
      Endif
     Endif
   Endcase
  Endif

  # Suppression avant copie

  Delete [AVO2]
  If fstat=1
   GOK=-1 : GLOCK = "$AVOCAB"-num$([F:AVO2]NUM) : Goto ROLL_TR_COP
  Endif
 Next AVO2

 For [AVO1] Where LAN=LANGUE & VER=VERSION

  # Copie en gardant la versio installée sur le dossier destination

  [F:AVO2] = [F:AVO1]
  [F:AVO2]CUR = VERCUR
  Write [AVO2]
  If fstat
   GOK=0 : Call FSTA("AVO2") From GLOCK : Break
  Endif

  # Mise à jour des textes si la version copiée est la version courante sur le dossier destination

  If VERSION=VERCUR
   Case [F:AVO2]TYP
    When 1
     Readlock [ATX2]NUMERO = LANGUE;[F:AVO2]NUM
     If fstat=1
      GOK = -1 : GLOCK = "$ATEXTE"-num$([F:AVO2]NUM) : Break
     Elsif !fstat
      [F:ATX2]TEXTE = [F:AVO2]TXT
      Rewrite [ATX2]
      If fstat
       GOK = 0 : Call FSTA("ATX2") From GLOCK : Break
      Endif
     Endif
    When 2
     Readlock [AST2]CLE = [F:AVO2]CHP;[F:AVO2]NUM;LANGUE
     If fstat=1
      GOK = -1 : GLOCK = "$APLSTD"-num$([F:AVO2]CHP)-num$([F:AVO2]NUM) : Break
     Elsif !fstat
      [F:AST2]LANMES = [F:AVO2]TXT
      Rewrite [AST2]
      If fstat
       GOK = 0 : Call FSTA("AST2") From GLOCK : Break
      Endif
     Endif
   Endcase
  Endif

 Next AVO1
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#----------------------------------------------------------------------#
Subprog C_TYP(VALEUR)
Variable Integer VALEUR
If VALEUR<>[M]TYP(nolign-1)
 [M]FLG(nolign-1) = 1
Endif
End

Subprog AS_CHP(VALEUR)
Variable Decimal VALEUR
If [M]TYP(nolign-1)=1 : mkstat = 1 : End : Endif
End

Subprog C_CHP(VALEUR)
Variable Decimal VALEUR
If VALEUR<>[M]CHP(nolign-1)
 [M]FLG(nolign-1) = 1
Endif
End

Subprog C_NUM(VALEUR)
Variable Decimal VALEUR
Call UNICITE(num$([M]TYP(nolign-1))-num$([M]CHP(nolign-1))-num$(VALEUR),[M]CLE) From OBJDIV
If mkstat : End : Endif
Case [M]TYP(nolign-1)
 When 1
  If VALEUR>=GMAXTXTSTD & VALEUR<GNEWTXTSTD :#115210/6
   GMESSAGE = mess(147,133,1) : # Numéro incorrect
   mkstat = 2 : End
  Endif
  Read [AX2]NUMERO = [M]WLAN;VALEUR
  If fstat
   GMESSAGE = mess(93,115,1) : # Texte inexistant
   mkstat = 2 : End
  Endif
  [M]STD(nolign-1) = [F:AX2]TEXTE
  If [F:AX2]LONG<>0
   [M]LNG(nolign-1) = [F:AX2]LONG
  Else
   For [AX2]DERNUM Where NUMERO=VALEUR
    If [F:AX2]LONG<>0
     [M]LNG(nolign-1) = [F:AX2]LONG
     Break
    Endif
   Next AX2
   If [M]LNG(nolign-1)=0
    [M]LNG(nolign-1) = GLONDES
   Endif
  Endif
 When 2
  Read [AS2]CLE = [M]CHP(nolign-1);VALEUR;[M]WLAN
  If fstat
   GMESSAGE = mess(93,115,1) : # Texte inexistant
   mkstat = 2 : End
  Endif
  [M]STD(nolign-1) = [F:AS2]LANMES
  [M]LNG(nolign-1) = type([F:AS2]LANMES)-10
Endcase
[M]CLE(nolign-1) = num$([M]TYP(nolign-1))-num$([M]CHP(nolign-1))-num$(VALEUR)
If VALEUR<>[M]NUM(nolign-1)
 [M]FLG(nolign-1) = 1
Endif
End

Subprog C_TXT(VALEUR)
Variable Char    VALEUR()
  Local Integer  WOK

  If len(VALEUR)>[M]LNG(nolign-1)
    Call AVERTIR( mess(122,123,1)-"("+num$([M]LNG(nolign-1))+")",WOK) From GESECRAN # Text too long
    If WOK = 1 Then mkstat=2: End: Endif
  Endif
  If VALEUR<>[M]TXT(nolign-1)
   [M]FLG(nolign-1) = 1
  Endif
End

Subprog IB_NUM
If [M]TYP(nolign-1)<> 2 | [M]CHP(nolign-1) = 0 : GBOUTS = "" : Endif
End

Subprog S_NUM(VALEUR)
Variable Decimal VALEUR
Local Integer NBLIB , NUMERO
Local Char    TBLIB(50)(0..500), TEXTE(80)
Local Integer CHAMP(1..500)

If !clalev([F:AST]) : Local File APLSTD  [AST] : Endif

For [AST]LAN Where LANCHP = [M]CHP(nolign-1) & LAN = GLANGUE & [F:AST]LANNUM > 0
 NBLIB += 1
 If NBLIG > dim(CHAMP) : Break : Endif
 CHAMP(NBLIB) = [F:AST]LANNUM
 TBLIB(NBLIB) = [F:AST]LANMES
Next
If NBLIB
 Call SAITEX(NBLIB,TBLIB,NUMERO,mess(22,123,1)) From GESECRAN : # Sélection
 If NUMERO
  VALEUR = CHAMP(NUMERO)
 Endif
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran AVO1) 11/01/2016 14:58:19 (CCL)
######################################################################################
Subprog AM_LAN(VALEUR)
Variable Char    VALEUR()
Read [TLA1]TLA0 = VALEUR
If !fstat
 [M]LANMAIN =[F:TLA1]LANMAIN
 If [M]LANMAIN<>"" : [M]WLAN = [M]LANMAIN : Else : [M]WLAN=VALEUR : Endif
 Affzo [M]LANMAIN
 Affzo [M]ZLANMAIN
Endif
End


