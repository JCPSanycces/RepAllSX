#<AdxTL>@(#)5.0.0.0 $Revision$
#########################################################################
# Contient les traitements utilisée pour la modélisation                #
# Etiquettes                                                            #
#########################################################################
#    ACTION MODELISATION E-COMMERCE                                     #
#                                                                       #
# GACTION  : TRTAUTDOPE  : Décalage automatique des opés                #
#                                                                       #
#########################################################################
$ACTION
Case ACTION
 When "INIT"          : Gosub INIT
 When "INIT_DIA"      : Gosub INIT_DIA
 When "CONTROLE"      : Gosub CONTROLE
 When "EXEC"          : Gosub EXEC
 When "TERMINE"       : Gosub TERMINE
Endcase
Return

#########################################################################
$INIT

# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub OUVRE
Return

#########################################################################
$INIT_DIA
Local Char    LFCY : LFCY = PARAM(1)
Local Integer LWOP : LWOP = val(PARAM(2))
Local Integer LWOF : LWOF = val(PARAM(3))
Local Char    LNUM : LNUM = PARAM(4)
Local Integer LOPE : LOPE = val(PARAM(5))
Local Integer LRET : LRET = 0 

# titre de la boîte 
TIT = mess(172,195,1)

Raz [M:DIA] 
If LFCY <> "" : [M:DIA]MFGFCY = LFCY : Endif
If LWOP <> 0  : [M:DIA]WOPFLG = LWOP : Endif
If LWOF <> 0  : [M:DIA]WOFFLG = LWOF : Endif
If LOPE <> 0  & LNUM <> ""
    [M:DIA]OPENUMDEB = LOPE
    [M:DIA]OPENUMFIN = LOPE
    [M:DIA]MFGNUMDEB = LNUM 
    [M:DIA]MFGNUMFIN = LNUM 
    [M:DIA]INDAUT    = 1
Endif
Return

#########################################################################
$CONTROLE
If !GSERVEUR             &
&  [M:DIA]MFGNUMDEB = "" & 
&  [M:DIA]MFGNUMFIN = "" &   
&  [M:DIA]STRDATDEB = [0/0/0] &
&  [M:DIA]STRDATFIN = [0/0/0] &
&  [M:DIA]WSTDEB    = "" &
&  [M:DIA]WSTFIN    = "" &
&  [M:DIA]OPENUMDEB = 0 &
&  [M:DIA]OPENUMFIN = 0 &
&  [M:DIA]FORMULE   = ""
   GERR = 3
   GMESSAGE = mess(64,190,1)
   FOK = 0  
   Return 
Endif
TIT=" "
TMP=1
Return

##########################################################################
$EXEC
If !GSERVEUR
    TRA = 1
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
    Call PRTSCR("MAUTPSO","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
    Call ECR_TRACE(" ",0) From GESECRAN 
Endif
# lecture site
Call LECTURE ("FCY", [M:DIA]MFGFCY, "") From CONTOBJ   

# lecture indisponibilités
Read [F:TUV]UVY0=[F:FCY]UVYCOD  
If fstat : Raz [F:TUV] : Endif

# préparation des critères de filtre
Gosub SEL_OP

# traitement des opérations
Gosub TRT_OP
Return

##########################################################################
$TERMINE
If !GSERVEUR
    # fermeture trace 
    Call FERME_TRACE From LECFIC
    # aucune suppression effectuee ou lecture trace
    If !NBOP
         GERR = 2 : GMESSAGE = mess(88,193,1) 
    Endif
    # lecture trace
Endif
Return


########################################################################
$OUVRE
Local Integer  OK
Local Integer  NBOP
Local Char     TIT(50)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)
Local Char     FORMULE1(255)
Local Char     WMESS(85)
Local Char     WMESS1(85)
Local Char     WMESS2(85)
Local Char     WMESS3(85)
Local Char     WMFGFCY(GLONFCY)
Local Char     WMFGNUM(GLONVCR)
Local Date     WSTRDAT
Local Integer  WOPENUM
Local Integer  WOPESPLNUM
Local Integer  WSTA
Local Date     WDATE, WDATED, WDATEF
Local Date     WNEWDAT         # 15821 01.03 MM
Local Decimal  WCAP (11) 
Local Integer  WRET, WCOR, I, J
Local Integer  IMAX : IMAX = 10
Local Integer  WCOUNT
# 01.10 mm 62008 - CUSFLT : zone de filtres supplémentaires 
Local Char     CUSFLT(255)

Gosub CHARG_PARAM
#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:ORD])  = 0 : Local File ORDERS      [ORD]  : Endif
If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:MFI])  = 0 : Local File MFGITM      [MFI]  : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT      [MFM]  : Endif
If clalev([F:MFO])  = 0 : Local File MFGOPE      [MFO]  : Endif
If clalev([F:OPS])  = 0 : Local File OPERATIONS  [OPS]  : Endif
If clalev([F:SCH])  = 0 : Local File SCHEDULING  [SCH]  : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER   [ITM]  : Endif
If clalev([F:ITV])  = 0 : Local File ITMMVT      [ITV]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT  [ITF]  : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY    [FCY]  : Endif
If clalev([F:MWS])  = 0 : Local File WORKSTATIO  [MWS]  : Endif
If clalev([F:TRO])  = 0 : Local File TABROUALT   [TRO]  : Endif
If clalev([F:TUV])  = 0 : Local File TABUNAVAIL  [TUV]  : Endif
If clalev([F:CPV])  = 0 : Local File CAPVAR      [CPV]  : Endif
If clalev([F:TWD])  = 0 : Local File TABWEEDIA   [TWD]  : Endif
If clalev([F:TFO])  = 0 : Local File TABFOR      [TFO]  : Endif 

# --- Déclaration classes ecran --- #
Local Mask ORDK    [ORDK]
Local Mask MFGK    [MFGK]

Return

########################################################################
# Préparation du filtre sur la table opération                         #
########################################################################
$SEL_OP
Raz CRITERE
Raz CRITERE1
Raz CRITERE2
If LNUM = ""
    If [M:DIA]WOPFLG = 2
        CRITERE  = "[F:MFO]MFGSTA=2"
        Gosub LOAD_CRITERE
    Endif
    
    If [M:DIA]WOFFLG = 2
        CRITERE  = "[F:MFO]MFGSTA=1"
        Gosub LOAD_CRITERE
    Endif

    # fin de la première partie
    CRITERE1 += ")"
Else
    CRITERE1 = "1=1"
Endif

CRITERE  = "[F:MFO]MFGFCY=[M:DIA]MFGFCY"     # site de production
Gosub LOAD_CRITERE2

If [M:DIA]MFGNUMDEB <> ""               # borne début OF
    CRITERE = "[F:MFO]MFGNUM>= [M:DIA]MFGNUMDEB"
    Gosub LOAD_CRITERE2   
Endif

If [M:DIA]MFGNUMFIN <> ""               # borne fin   OF       
    CRITERE = "[F:MFO]MFGNUM<=[M:DIA]MFGNUMFIN"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]ROUALTDEB <> 0                # borne début alternative
    CRITERE = "[F:MFG]ROUALT>=[M:DIA]ROUALTDEB"      
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]ROUALTFIN <> 0                # borne fin   alternative
    CRITERE = "[F:MFG]ROUALT<=[M:DIA]ROUALTFIN"                       
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]ROUNUMDEB <> ""               # borne début gamme
    CRITERE = "[F:MFG]ROUNUM>=[M:DIA]ROUNUMDEB"      
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]ROUNUMFIN <> ""               # borne fin   gamme
    CRITERE = "[F:MFG]ROUNUM<=[M:DIA]ROUNUMFIN"                       
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]WSTDEB <> ""                  # borne début poste
    CRITERE = "[F:MFO]EXTWST>=[M:DIA]WSTDEB"      
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]WSTFIN <> ""                  # borne fin   poste
    CRITERE = "[F:MFO]EXTWST<=[M:DIA]WSTFIN"                       
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]OPENUMDEB <> 0                # borne début opération
    CRITERE = "[F:MFO]OPENUM>=[M:DIA]OPENUMDEB"      
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]OPENUMFIN <> 0                # borne fin   opération
    CRITERE = "[F:MFO]OPENUM<=[M:DIA]OPENUMFIN"                       
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]STRDATDEB <> [0/0/0]          # borne début date 
    CRITERE = "[F:MFO]OPESTR>=[M:DIA]STRDATDEB"                        
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]STRDATFIN <> [0/0/0]          # borne fin   date
    CRITERE = "[F:MFO]OPESTR<=[M:DIA]STRDATFIN"               
    Gosub LOAD_CRITERE2
Endif

Gosub ANALYSE_FORMULE
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif

Return  

##################################################
$ANALYSE_FORMULE
# analyse présence formule de sélection
If [M:DIA]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif      
Else
    Read [F:TFO]TFO0=10;[M:DIA]FORMULE
    If fstat 
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif  
    Else  
        If FORMULE1 = "" 
            FORMULE1  = [F:TFO]FORFOR                 
        Else
            FORMULE1 += "&" 
            FORMULE1 += [F:TFO]FORFOR                 
        Endif
    Endif
Endif

Return


############################################################
$LOAD_CRITERE
If len(CRITERE1)=0 
    CRITERE1 += "("
Else 
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE  
Return

############################################################
$LOAD_CRITERE2
If len(CRITERE)+len(CRITERE1)+1 < 255
  CRITERE1 += "&"
  CRITERE1 += CRITERE  
Else
  If CRITERE2 <> ""
     CRITERE2 += "&"
  Endif
  CRITERE2 += CRITERE
Endif
Return


#---------------------------------------------------------------------#
# Traitement des ordres                                               #
#---------------------------------------------------------------------#
$TRT_OP

# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
# 01.10 mm 62008
Raz CUSFLT
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif

# FQ 79216 GA 01/2012 remplacement de l'abréviation XMFO par LNK
If CRITERE2 <> ""
    Link [MFO] With [MFG]MFG0=[F:MFO]MFGNUM As [LNK] 
&               Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1)
&               Order By MFGNUM Asc; OPENUM Asc; OPESPLNUM Asc
Else
    Link [MFO] With [MFG]MFG0=[F:MFO]MFGNUM As [LNK] 
&              Where evalue(CRITERE1) & evalue(CUSFLT) & evalue(FORMULE1) 
&              Order By MFGNUM Asc; OPENUM Asc; OPESPLNUM Asc
Endif
For  [LNK]
    If !find([F:MFG]SCDFLG,2,4)   : Goto NXT1 : Endif
    If [F:MFG]MFGTRKFLG > 2   
        If [M:DIA]EDIFLG = 1     
            WMESS  = mess(156,197,1)-mess([F:MFO]MFGSTA,317,1)-[F:MFO]MFGNUM
            WMESS1 = "          "+mess(230,190,1)
            Call ECR_TRACE(WMESS,0)  From GESECRAN
            Call ECR_TRACE(WMESS1,0) From GESECRAN
            Raz WMESS, WMESS1
            NBOP += 1
            Goto NXT1 
        Endif
    Endif
    If [F:MFG]OPTFLG    = 2 
        WMESS  = mess(156,197,1)-mess([F:MFO]MFGSTA,317,1)-[F:MFO]MFGNUM
        WMESS1 = "          "+mess(122,193,1)
        Call ECR_TRACE(WMESS,0)  From GESECRAN
        Call ECR_TRACE(WMESS1,0) From GESECRAN
        Raz WMESS, WMESS1
        NBOP += 1
        Goto NXT1 
    Endif 
    WMFGFCY = [F:MFO]MFGFCY
    WMFGNUM = [F:MFO]MFGNUM
    WSTRDAT = [F:MFO]OPESTR
    WSTA    = [F:MFO]MFGSTA
    WOPENUM = [F:MFO]OPENUM
    Read [MWS]WST0=[F:MFO]EXTWST;[F:MFO]MFGFCY
    If fstat : Goto NXT1   : Endif
    Read [F:SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
    If fstat : Goto NXT1   : Endif
    If [F:SCH]SCDCOD > 6   : Goto NXT1 : Endif
    Gosub TRTPSO
$NXT1
Next
Filter [LNK]
#
Return

#-----------------------------------------------------------------------#
# Traitement décalage                                                   #
#-----------------------------------------------------------------------#
$TRTPSO
# FQ 67806 GA 11/2010 PE BEFTRTLIG idem FUNMAUTO
Local Integer GPE : GPE=1
GPOINT = "BEFTRTLIG" : Gosub ENTREE From EXEFNC
If !GPE Return Endif

Gosub VERROU
If !OK : Return : Endif
Call DEBTRANS From GLOCK
GOK = 1

Gosub MAJPSO
Gosub DEVERROU
Return

#-----------------------------------------------------------------------#
# Décalage                                                              #
#-----------------------------------------------------------------------#
$MAJPSO
#
Trbegin [MFG]
    Raz [MFGK]
    [M:MFGK]SCDFLG  = [F:MFG]SCDFLG
    If [M:DIA]KPREC = 2 : [M:MFGK]SCDFLG = 8 : Endif
    If [M:DIA]KSUIV = 2 : [M:MFGK]SCDFLG = 9 : Endif
    Gosub DECALAGE
    [M:MFGK]FRCSTRDAT = WDATE
    GMESSAGE = ""
    Call CONT_FRC_AUTO(WMFGNUM, WOPENUM, WOPESPLNUM, [M:MFGK]FRCSTRDAT) From MFGLIBO   
    If GMESSAGE <> "" 
        WMESS  = mess(156,197,1)-mess(WSTA,317,1)-WMFGNUM
        WMESS1 = "          "+GMESSAGE
        Goto FIN_TRACE
    Endif
    [M:MFGK]CODMAJ     = "F"
    [M:MFGK]CODTRS     = 0
    [M:MFGK]MFGNUM     = [F:MFG]MFGNUM
    [M:MFGK]MFGFCY     = [F:MFG]MFGFCY
    [M:MFGK]MFGSTA     = [F:MFG]MFGSTA
    [M:MFGK]OPENUMFRC  = [F:MFO]OPENUM
    If [F:MFO]FRCSTRDAT <> [0/0/0] 
        WMESS2 = "          "+mess(96,190,1)-format$(GFMD,[F:MFO]FRCSTRDAT)
    Endif
    Call MAJ_OF From MFGAUTLIB
    If [M:MFGK]CODRET <> 0 : Goto AB_TRTPSO : Endif  
    WMESS   = mess(156,197,1)-mess(WSTA,317,1)-WMFGNUM
    WMESS1  = "          "+mess(209,197,1)-num$(WOPENUM)-mess(204,197,1)-mess(4,197,1)-
&             format$(GFMD,WSTRDAT)-mess(38,197,1)-format$(GFMD,[M:MFGK]FRCSTRDAT)
    If GMESSAGE <> "" : WMESS3 = "          "+GMESSAGE : Endif
$FIN_TRACE
    Call ECR_TRACE(WMESS,0)  From GESECRAN
    Call ECR_TRACE(WMESS1,0) From GESECRAN
    If WMESS2 <> "" : Call ECR_TRACE(WMESS2,0) From GESECRAN : Endif
    If WMESS3 <> "" : Call ECR_TRACE(WMESS3,0) From GESECRAN : Endif
    Raz WMESS, WMESS1, WMESS2, WMESS3
    NBOP += 1
Commit
Return

#-----------------------------------------------------------------------#
# Calcul de la nouvelle date                                            #
#-----------------------------------------------------------------------#
$DECALAGE
WDATE  = WSTRDAT
WCOUNT = 0

If [M:DIA]XTRT<>0   # 15821 01.03 MM
    If [M:DIA]XTRT > 0 # décalage aval
        J = [M:DIA]XTRT
        I = 10
        While (J>0 & WCOUNT <= 2000) # si WCOUNT = 2000 à priori on boucle
            If I >= IMAX 
                WDATED = WDATE + 1
                WDATEF = WDATE + 11
                #  (llc 08.00 v130) nouvelle gestion des capacités
                Call LOACAP (WDATED,WDATEF,WCAP,WRET) From JALLIBB
                I = 0
            Endif
            If WCAP(I) > 0 : J -= 1 : Endif
            WDATE  += 1
            I      += 1
            WCOUNT += 1
        Wend
    Else            # décalage amont
        J = abs([M:DIA]XTRT)
        I = 10
        While (J>0 & WCOUNT <= 2000) # si WCOUNT = 2000 à priori on boucle
            If I >= IMAX 
                WDATED = WDATE - 10
                WDATEF = WDATE
                #  (llc 08.00 v130) nouvelle gestion des capacités
                Call LOACAP (WDATED,WDATEF,WCAP,WRET) From JALLIBB
                I = 0
            Endif
            If WCAP(9-I) > 0 : J -= 1 : Endif
            WDATE  -= 1
            I      += 1
            WCOUNT += 1
        Wend
    Endif
Elsif [M:DIA]XDATE<>[0/0/0] # 15821 01.03 MM   
    WNEWDAT =[M:DIA]XDATE  
    If WNEWDAT -WDATE >0   # Décalage aval
        J=0
        I = 10
        While (J=0 & WCOUNT <= 2000) # si WCOUNT = 2000 à priori on boucle
            If I >= IMAX 
                WDATED = WNEWDAT  
                WDATEF = WNEWDAT  + 9
                Call LOACAP (WDATED,WDATEF,WCAP,WRET) From JALLIBB
                I = 0
            Endif
            If WCAP(I) > 0 : WDATE=WNEWDAT   :J=1 : Endif
            WNEWDAT  += 1
            I      += 1
            WCOUNT += 1
       Wend
    Else             # décalage amont
        J=0
        I = 10
        While (J=0 & WCOUNT <= 2000) # si WCOUNT = 2000 à priori on boucle
            If I >= IMAX 
                WDATED = WNEWDAT  -9
                WDATEF = WNEWDAT  
                Call LOACAP (WDATED,WDATEF,WCAP,WRET) From JALLIBB
                I = 0
            Endif
            If WCAP(9-I) > 0 : WDATE=WNEWDAT  :J=1 : Endif
            WNEWDAT  -= 1
            I      += 1
            WCOUNT += 1
        Wend
    Endif
Endif
# Fin 15821 01.03 MM

Return

#-----------------------------------------------------------------------#
# Positionnement d'un verrou sur l'entête OF                            #
#-----------------------------------------------------------------------#
$VERROU
SYMBOLE = "MFG"+[F:MFG]MFGNUM
Lock = SYMBOLE With lockwait = 0
OK = 1
If fstat 
    Call ECR_TRACE([F:MFG]MFGNUM - mess(10,100,1),1) From GESECRAN 
    OK = 0
Endif 
Return

#-----------------------------------------------------------------------#
# Suppression du verrou sur l'entête OF                                 #
#-----------------------------------------------------------------------#
$DEVERROU
Unlock=SYMBOLE
Return

$ROL_TRTPSO
Rollback
Call ROLL From GLOCK
If GROLL 
     Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Else Goto MAJPSO : Endif
Return

$AB_TRTPSO
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return


######################################################################## 
$CHARG_PARAM

#----- Variables globales stock 
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return 

#######################################################################
#                     ETIQUETTES                                      #
#######################################################################

Subprog C_WOFFLG(VALEUR)
Variable Integer  VALEUR
If [M:DIA]WOPFLG = 1 & VALEUR = 1
    GERR = 1 : GMESSAGE = mess(359,199,1)
    mkstat = 2  : # une case au moins doit être cochée !
Endif
End

########################################
Subprog C_STRDATFIN(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:DIA]STRDATDEB : mkstat = 2 : Endif
End

########################################
Subprog AM_MFGNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]MFGNUMFIN = VALEUR : Endif
End

########################################
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY                   # mm 12.02
    GFCY=VALEUR                     # mm 12.02
    Gosub CHARG_PARAM
Endif                               # mm 12.02
End

########################################
Subprog AM_WSTDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]WSTFIN = VALEUR : Endif
End

########################################
Subprog AM_ROUNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]ROUNUMFIN = VALEUR : Endif
End

########################################
Subprog AM_ROUALTDEB(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 : [M:DIA]ROUALTFIN = VALEUR : Endif
End

########################################
Subprog C_ROUALTFIN(VALEUR)
Variable Decimal VALEUR
If VALEUR < [M:DIA]ROUALTDEB : mkstat = 2 : End : Endif
End


##########################################################################
# pour les batchs                                                        #
##########################################################################
Subprog PARAM(DOSSIER,USER,P1,P2,OK) 
#-----------------------------#
# obligatoire pour les batchs #
#-----------------------------#
Value    Char    DOSSIER   : # dossier de lancement
Value    Char    USER      : # utilisateur
Variable Char    P1()(1..) : # on peut avoir 2 fois 50 chaînes de 15 caractères
Variable Char    P2()(1..) 
Variable Integer OK 
 
Gosub OUVRE

#
Local Char    WIN (GLONFEN)
WIN="DAUTDOPE" 
Call PARAM (DOSSIER,USER,P1,P2,OK,TIT,WIN) From CPTTRT

End  
###########################################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

########################################
Subprog AV_MFGFCY(VALEUR)
Variable Char    VALEUR()
If [M:DIA]INDAUT <> 0
    Grizo [DIA]5
    Grizo [DIA]10
    Grizo [DIA]20
Endif
If [M:DIA]XTRT = 0 
    [M:DIA]KPREC = 1
    [M:DIA]KSUIV = 1
    # GH 22/02/2012 bug 80223
    #Grizo [DIA]25
    Grizo [DIA] KPREC, KSUIV
Endif
End

########################################
Subprog AM_OPENUMDEB(VALEUR)
Variable Decimal VALEUR

If VALEUR <> 0 : [M:DIA]OPENUMFIN = VALEUR : Endif
If VALEUR = 0 & [M:DIA]OPENUMFIN = 0    
    [M:DIA]KPREC = 1
    [M:DIA]KSUIV = 1
    # GH 22/02/2012 bug 80223
    #Grizo [DIA]25
    #Affzo [DIA]25
    Grizo [DIA] KPREC, KSUIV
    Affzo [DIA] KPREC, KSUIV
    End
Endif
If [M:DIA]XTRT > 0 
    Actzo [DIA]KPREC
    [M:DIA]KSUIV = 1
    Grizo [DIA]KSUIV
#Else  # GH 22/02/2012 bug 80223
Elsif [M:DIA]XTRT < 0
    [M:DIA]KPREC = 1
    Grizo [DIA]KPREC
    Actzo [DIA]KSUIV
Endif
Affzo [DIA]25
End

########################################
Subprog C_OPENUMFIN(VALEUR)
Variable Decimal VALEUR
If VALEUR < [M:DIA]OPENUMDEB : mkstat = 2 : End : Endif
End

########################################
Subprog AM_OPENUMFIN(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 & [M:DIA]OPENUMDEB = 0
    [M:DIA]KPREC = 1
    [M:DIA]KSUIV = 1
    # GH 22/02/2012 bug 80223
    #Grizo [DIA]25
    #Affzo [DIA]25
    Grizo [DIA] KPREC, KSUIV
    Affzo [DIA] KPREC, KSUIV
    End
Endif
If [M:DIA]XTRT > 0 
    Actzo [DIA]KPREC
    [M:DIA]KSUIV = 1
    Grizo [DIA]KSUIV
#Else  # GH 22/02/2012 bug 80223
Elsif [M:DIA]XTRT < 0 
    [M:DIA]KPREC = 1
    Grizo [DIA]KPREC
    Actzo [DIA]KSUIV
Endif
Affzo [DIA]25    
End

########################################
# GH 22/02/2012 bug 80223
Subprog AS_XTRT(VALEUR)
Variable Decimal VALEUR
If [M:DIA]XDATE=[0/0/0] : Grizo [DIA]XDATE : Endif
End

########################################
# GH 22/02/2012 bug 80223
Subprog C_XTRT(VALEUR)
Variable Decimal VALEUR

#15821 01.03 MM
If VALEUR<>0 
    Grizo [DIA]XDATE  
Else 
    Actzo [DIA]XDATE 
Endif
End

########################################
Subprog AM_XTRT(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 | ([M:DIA]OPENUMDEB = 0 & [M:DIA]OPENUMFIN = 0) 
    [M:DIA]KPREC = 1
    [M:DIA]KSUIV = 1
    # GH 22/02/2012 bug 80223
    #Grizo [DIA]25
    Grizo [DIA] KPREC, KSUIV
Endif
If VALEUR > 0 & ([M:DIA]OPENUMDEB <> 0 | [M:DIA]OPENUMFIN <> 0) 
    [M:DIA]KPREC = 1
    Actzo [DIA]KPREC
    [M:DIA]KSUIV = 1
    Grizo [DIA]KSUIV
Endif
If VALEUR < 0 & ([M:DIA]OPENUMDEB <> 0 | [M:DIA]OPENUMFIN <> 0)
    [M:DIA]KPREC = 1
    Grizo [DIA]KPREC
    [M:DIA]KSUIV = 1
    Actzo [DIA]KSUIV
Endif
Affzo [DIA]25 

# GH 22/02/2012 bug 80223 déplacé dans C_XTRT
#15821 01.03 MM
#If VALEUR<>0 
#    Grizo [DIA]XDATE  
#Else 
#    Actzo [DIA]XDATE 
#Endif

End

########################################
#15821 01.03 MM
Subprog AS_XDATE(VALEUR)
Variable Date    VALEUR

If [M:DIA]XTRT=0 : Grizo [DIA]XTRT : Endif
End

########################################
#15821 01.03 MM
Subprog C_XDATE(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] & [M:DIA]XTRT=0
   # GH 22/02/2012 bug 80223 # une fois sur la zone XDATE, on ne pouvait pas revenir à la zone XTRT
   #GERR = 1 : GMESSAGE = mess(6,199,1)
   #mkstat =2 # une case au moins doit être cochée !
   Actzo [DIA]XTRT
   zonsui = "[DIA]XTRT"
Endif
End
