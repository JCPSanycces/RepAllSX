#<AdxTL>@(#)8.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Generation trigger
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Generation trigger") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End


#----------------------------------------------#
Subprog PATCH(APPLI)
Value Char APPLI
Gosub GENTRIGGER
End

#----------------------------------------------------------------------------------------#

$GENTRIGGER

If [L]APPLI=GDOSX3 : Return : Endif :  # 113647

Local File ADOSSIER [ADS]

Read [ADS]DOSSIER=[L]APPLI
If fstat : Return : Endif

If dim(GINFO)<=0
 Global Integer GINFO
Endif

GINFO = 0

Call TRIGGER_ALL From DOSTAB

Close Local File [ADS]

Return

