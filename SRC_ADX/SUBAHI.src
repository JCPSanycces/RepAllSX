#<AdxTL>@(#)10.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("AHI",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBAHIB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "SETBOUT"   : Gosub SETBOUT
 When "INICRE"    : Gosub INICRE
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "VERIF_CRE" : Gosub VERIF_CRE
Endcase
If PSUBB
 Gosub ACTION From SUBAHIB
Endif
Return

$OUVRE
If clalev([F:AHD2])=0 : Local File AHISTOD [AHD2] : Endif
Return

$VERIF_CRE
$VERIF_MOD
If [M]NBRTBL=0
 Call ERREUR(mess(17,106,1)) From GESECRAN : # Il n'y a aucune ligne saisie
 OK = 0
Endif
Return

$LIENS
Call TEXTE([F:AHI]DES,[M]ZDES) From OBJDIV
Call TEXTE([F:AHI]DESSHO,[M]ZDESSHO) From OBJDIV
nolign = 0
For [AHD]AHD0 Where COD=[F:AHI]COD
 nolign += 1
 [M] = [F:AHD]
Next
[M]NBRTBL = nolign
Return

$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET
Else
 CHMEN += "6" : # Paramètres histo
Endif
Return

$INICRE
[F:AHI]FLG1 = 1
[F:AHI]FLG2 = 1
Return

$CREATION
For nolign=1 To [M]NBRTBL
 [F:AHD] = [M]
 [F:AHD]LIG = nolign
 Write [AHD]
 If fstat
  GOK = 0 : Call FSTA("AHD") From GLOCK : Break
 Endif
Next
Return

$MODIF
Delete [AHD] Where COD=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$AHISTOD"-CLECUR1 : Return
Endif
Gosub CREATION
Return

################################################################
$TRTCOP
If [M]DOSORG=nomap 
 Local File AHISTO    [AHI1] 
 Local File AHISTOD   [AHD1] 
 Local File ATEXTE    [ATX1] 
Else 
 Local File =[M]DOSORG+".AHISTO"    [AHI1]
 Local File =[M]DOSORG+".AHISTOD"   [AHD1] 
 Local File =[M]DOSORG+".ATEXTE"    [ATX1] 
Endif 
If [M]DOSDES=nomap 
 Local File AHISTO    [AHI2] 
 Local File AHISTOD   [AHD2] 
 Local File ATEXTE    [ATX2] 
Else 
 Local File =[M]DOSDES+".AHISTO"    [AHI2]
 Local File =[M]DOSDES+".AHISTOD"   [AHD2]
 Local File =[M]DOSDES+".ATEXTE"    [ATX2]
Endif 
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [AHI1], [AHD1], [ATX1], [AHI2], [AHD2], [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [AHI2] , [AHD2] , [ATX2]
 Delete [AHI2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AHISTO" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AHI2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AHD2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AHISTOD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AHD2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AHI1]AHI0 Where COD=TABLE
  [F:AHI2] = [F:AHI1]
  Call COPTEXTE([F:AHI1]DES,[F:AHI2]DES) From OBJDIV
  If GOK<1 : Break : Endif
  Call COPTEXTE([F:AHI1]DESSHO,[F:AHI2]DESSHO) From OBJDIV
  If GOK<1 : Break : Endif
  If dim([F:AHI2]UPDUSR)>0 : [F:AHI2]UPDUSR = GUSER : Endif
  If dim([F:AHI2]UPDDAT)>0 : [F:AHI2]UPDDAT = date$ : Endif
  If dim([F:AHI2]UPDTIM)>0 : [F:AHI2]UPDTIM = time : Endif
  Write [AHI2]
  If fstat
   GOK=0 : Call FSTA("AHI2") From GLOCK : Break
  Endif
 Next AHI1
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [AHD1]AHD0 Where COD=TABLE
  [F:AHD2] = [F:AHD1]
  If dim([F:AHD2]UPDUSR)>0 : [F:AHD2]UPDUSR = GUSER : Endif
  If dim([F:AHD2]UPDDAT)>0 : [F:AHD2]UPDDAT = date$ : Endif
  If dim([F:AHD2]UPDTIM)>0 : [F:AHD2]UPDTIM = time : Endif
  Write [AHD2]
  If fstat
   GOK=0 : Call FSTA("AHD2") From GLOCK : Break
  Endif
 Next AHD1
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

########################################
## Ecran AHI1
########################################
Subprog C_TBL(VALEUR)
Variable Char    VALEUR()
If GPRODUIT<>1
 Call UNICITE(VALEUR,[M]TBL(0..[M]NBRTBL-1)) From OBJDIV
Endif
End

Subprog C_LNKTBL(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Local Integer NOL , I1 , I2 , K , NBLIEN , TYPDON
 Local Char    CHAINE(250) , CHAMP(20)
 NOL = nolign-1
 K = find(VALEUR,[M]TBL(0..[M]NBRTBL-1))
 If VALEUR=[M]TBL(NOL) or !K or [M]LNKTBL(K-1)<>""
  GMESSAGE = mess(17,123,1) : # Table non définie
  mkstat = 2 : End
 Endif
 If GPRODUIT=1
  Filter [ATZ] Where CODFIC=[M]TBL(nolign-1) & LIEN=VALEUR
  Read [ATZ]CODZONE First
  If fstat
   [V]GMESSAGE=mess(1,124,1)-[M]TBL(nolign-1) : # Pas de lien vers la table
   mkstat     =2
  Endif
  Filter [ATZ]
 Else
  NBLIEN = 1
  For I1=0 To [M]NBRTBL-1
   If I1<>NOL & VALEUR=[M]LNKTBL(I1)
    NBLIEN += 1
   Endif
  Next I1
  If NBLIEN>20
   GMESSAGE = VALEUR-":"-mess(12,133,1)-"(20)" : # Trop de liens sur cette table
   mkstat = 2 : End
  Endif
  Read [ATI]NUMLIG(2) = VALEUR;1
  CHAINE = [F:ATI]DESCRIPT
  While CHAINE<>""
   I1 = instr(1,CHAINE,"+")
   I2 = instr(1,CHAINE,"-")
   If     I1 & I2 : I1 = min(I1,I2)
   Elsif !I1 & I2 : I1 = I2
   Endif
   If I1
    CHAMP  = left$(CHAINE,I1-1)
    CHAINE = right$(CHAINE,I1+1)
   Else
    CHAMP  = CHAINE
    CHAINE = ""
   Endif
   Read [ATZ]CODZONE = [M]TBL(NOL);CHAMP
   If fstat
    GMESSAGE = CHAMP-":"-mess(13,133,11)-[M]TBL(NOL) : # Champ inexistant sur la table
    mkstat = 2 : Break
   Else
    Read [ATY]CODTYP = [F:ATZ]CODTYP
    TYPDON = [F:ATY]TYPTYP
    Read [ATZ]CODZONE = VALEUR;CHAMP
    Read [ATY]CODTYP = [F:ATZ]CODTYP
    If fstat or TYPDON<>[F:ATY]TYPTYP
     GMESSAGE = CHAMP-":"-mess(14,133,1)-"("+TYPDON+"/"+[F:ATZ]CODTYP+")" : # Type de données incorrect
     mkstat = 2 : Break
    Endif
   Endif
  Wend
 Endif
Endif
End

Subprog AS_CPYFLD(VALEUR)
Variable Char VALEUR()
If [M]LNKTBL(nolign-1)<>""
 mkstat = 1 : End
Endif
End

Subprog C_CPYFLD(VALEUR)
Variable Char VALEUR()
If VALEUR="" : End : Endif
Read [ATZ]CODZONE = [M]TBL(nolign-1);VALEUR
If fstat
 GMESSAGE = mess(13,133,1)-[M]TBL(nolign-1) : # Champ inexistant sur la table
 mkstat = 2 : End
Endif
Read [ATY]CODTYP = [F:ATZ]CODTYP
If [F:ATY]OBJLIEN<>"CPY"
 GMESSAGE = [F:ATZ]CODTYP-":"-mess(14,133,1) : # Type de données incorrect
 mkstat = 2 : End
Endif
End

Subprog AS_FCYFLD(VALEUR)
Variable Char VALEUR()
If [M]LNKTBL(nolign-1)<>"" or [M]CPYFLD(nolign-1)<>""
 mkstat = 1 : End
Endif
End

Subprog C_FCYFLD(VALEUR)
Variable Char VALEUR()
If VALEUR="" : End : Endif
Read [ATZ]CODZONE = [M]TBL(nolign-1);VALEUR
If fstat
 GMESSAGE = mess(13,133,1)-[M]TBL(nolign-1) : # Champ inexistant sur la table
 mkstat = 2 : End
Endif
Read [ATY]CODTYP = [F:ATZ]CODTYP
If [F:ATY]OBJLIEN<>"FCY"
 GMESSAGE = [F:ATZ]CODTYP-":"-mess(14,133,1) : # Type de données incorrect
 mkstat = 2 : End
Endif
End

Subprog AS_DATFLD(VALEUR)
Variable Char VALEUR()
If [M]LNKTBL(nolign-1)<>""
 mkstat = 1 : End
Endif
End

Subprog C_DATFLD(VALEUR)
Variable Char VALEUR()
If VALEUR="" : End : Endif
Read [ATZ]CODZONE = [M]TBL(nolign-1);VALEUR
If fstat
 GMESSAGE = mess(13,133,1)-[M]TBL(nolign-1) : # Champ inexistant sur la table
 mkstat = 2 : End
Endif
Read [ATY]CODTYP = [F:ATZ]CODTYP
If [F:ATY]TYPTYP<>8
 GMESSAGE = [F:ATZ]CODTYP-":"-mess(14,133,1) : # Type de données incorrect
 mkstat = 2 : End
Endif
End

Subprog AS_FRM(VALEUR)
Variable Char    VALEUR()
If [M]LNKTBL(nolign-1)<>""
 mkstat = 1 : End
Endif
End

Subprog C_GRUTBL(VALEUR)
Variable Char    VALEUR()
If [L]VALEUR="" : End : Endif
Local Shortint I
I=find(VALEUR,[M]TBL(0..[M]NBRTBL-1))
If find(VALEUR,[M]TBL(nolign-1),[M]LNKTBL(nolign-1)) or !I
 GMESSAGE= mess(17,123,1) : # Table non définie
 mkstat = 2 : End
Endif
Filter [ATZ] Where CODFIC=VALEUR & LIEN=[M]TBL(nolign-1)
Read [ATZ]CODZONE First
If fstat
 Filter [ATZ] Where CODFIC=[M]TBL(nolign-1) & LIEN=VALEUR
 Read [ATZ]CODZONE First
 Filter [ATZ]
 If fstat
  [V]GMESSAGE=mess(1,124,1)-[M]TBL(nolign-1) : # Pas de lien vers la table
  mkstat = 2 : End
 Endif
Endif
Filter [ATZ]
Read [ATZ]CODZONE=VALEUR;"HISPTR"
If fstat
 [V]GMESSAGE="HISPTR :"-mess(13,133,1)-VALEUR : # Champ inexistant sur la table
 mkstat = 2 : End
Endif
Read [ATZ]CODZONE=[M]TBL(nolign-1);"HISPTR"
If fstat
 [V]GMESSAGE="HISPTR :"-mess(13,133,1)-[M]TBL(nolign-1) : # Champ inexistant sur la table
 mkstat = 2 : End
Endif
End

Subprog AS_PROLBL(VALEUR)
Variable Integer VALEUR
If [M]LNKTBL(nolign-1)<>""
 mkstat = 1 : End
Endif
End

Subprog D_COE(VALEUR)
Variable Decimal VALEUR
Filter [AHD2] Where TBL=[M:AHI1]TBL(nolign-1)
Read [AHD2] First
If !fstat : [L]VALEUR=[F:AHD2]COE : Else [L]VALEUR=1 : Endif
Filter [AHD2]
End

Subprog C_COE(VALEUR)
Variable Decimal VALEUR
Local Shortint I
For I=0 To [M:AHI1]NBRTBL-1
 If I<>nolign-1 & [M:AHI1]TBL(I)=[M:AHI1]TBL(nolign-1)
& & [M:AHI1]COE(I)<>[L]VALEUR
  [M:AHI1]COE(I)=[L]VALEUR
  Affzo [AHI1] COE(I)
 Endif
Next
End

Subprog IB_FRM
GBOUT3 = "" : # Désactivation du bouton analyse formule
End
