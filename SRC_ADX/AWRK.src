#<AdxTL>@(#)3.0.0.0 $Revision$
Local Mask AMK0 [AMK0]
Local File AMSK [AMK]
#GBIDC1 = "AOB0"
GBIDC1 = "ZZMBAMK3"
Read [AMK]CODMSK = GBIDC1
[M] = [F]
Call WORKFLOW(2,"AMK","M",GBIDC1)
End

#-------------------------------------------------#
# Traitement d'un Workflow (normal)
#-------------------------------------------------#

Subprog WORKFLOW(TYPEVT,CODEVT,OPERAT,CLEOBJ)
Value Integer TYPEVT : # Type d'évènement Workflow (objet/import/etc.)
Value Char    CODEVT : # Code évènement
Value Char    OPERAT : # Opération (Modification/Bouton/etc.)
Value Char    CLEOBJ : # Clé de l'objet si typevt=objet ou chrono origine/dest si typevt=signature

Local Integer DIFFERE , SIMUL , TYPDEC
Local Char    CODE(GLONAWA) , GRPDEB(GLONVCR)
Raz DIFFERE , SIMUL , TYPDEC , CODE , GRPDEB
Goto WORKSUITE

#-------------------------------------------------------------------------------------#
# Traitement d'un Workflow avec plus d'arguments (différé/code/simul/ligne)
#-------------------------------------------------------------------------------------#

Subprog WORKPLUS(TYPEVT,CODEVT,OPERAT,CLEOBJ,CODE,SIMUL,DIFFERE,TYPDEC,GRPDEB)
Value Integer    TYPEVT
Value Char       CODEVT
Value Char       OPERAT
Value Char       CLEOBJ
Value Char       CODE    : # Code workflow (cas du bouton W et du workflow manuel)
Value Integer    SIMUL   : # Permet de simuler OU de générer un workflow manuel
Value Integer    DIFFERE : # Envoi message différé (transactions de création/modification d'un objet)
Value Integer    TYPDEC  : # Déclenchement workflow avant/après mise à jour classe [F] (modif objet)
Variable Char    GRPDEB  : # Premier chrono groupe (utilisé pour l'envoi différé)
Goto WORKSUITE

$WORKSUITE
Local Integer I , J , K , L , C , D , F , U , OK , NEWUSR , STAT , TRACE , LEVSIG
Local Char    NOMPROG(GLONADC) , NOMPREG(GLONADC) , NOMPRIG(GLONADC) , PREF(4)
Local Char    NUMORG(GLONVCR) , USRORG(GLONAUS) , NUMSIG(GLONVCR)
Local Char    USRWRK(GLONAUS) , MAIWRK(GLONMAI)
Local Char    CHRONO(GLONVCR) , USRDES(GLONAUS) , NUMGRP(GLONVCR)
Local Char    FORMULE(255) , TABLE(GLONATB+1+GLONABR) , RESULT(255)
Local Char    TEXOBJ(250) , OBJJOI(20) , CONTXT(250) , CLEJOI(250)
Local Char    RETORG(GLONID1) , CLESIG(250)
Local Integer NBLIG , NBENR , NBJOI , NBCLE , NBGRP
Local Char    DEST(80) , EMAIL(GLONMAI) , TOP(GLONAUS)
Local Integer DELEG , GRPENV , REQREC , REQIMP
Local Integer USR_NB , TYPCND , NBRUSR
Local Char    CHAINE(250) , CLE(GLONID1)(1..16) , VALCLE(250)
Local Char    FILTGRP(250) , MESSA(80)
Local Integer ERN , ERT , ERD
Local Char    ERM(250)
Local Char    S_USER(GLONAUS) , S_CLEOBJ(GLONID2) , S_ABREV(GLONAOB) , REASON(GLONDES)
Local Integer S_NBRUSR
Local Integer ACTWRK
Local Char    NUMTRA(250) , REGCUR(GLONAWA)
Local Char    REP(30) , JOB(50) , EXT(10)
Local Char    CPTWRG(GLONANM) , CPTWRK(GLONANM)
Local Char    IDTGRP(GLONID1)
Local Char    CONTXT_DESKTOP(250),CONTXT_MOBILE(250)     # X3PLAT-1475 Workflow link on representation

# Nom de la trace ouverte par l'applicatif
NUMTRA = GTRACE

# Pas de workflow dans la gestion de ces objets
If TYPEVT=2 & find(GABREV,"AWM","AWR","AWV","AWO","AWA","ANM") : End : Endif

# Pour une signature ou pour une annulation de signature, CLEOBJ contient les codes (~) du suivi signé
If TYPEVT=9 or (TYPEVT=1 & CODEVT="CAN") : CLESIG = CLEOBJ : CLEOBJ = "" : Endif

ERD = 0
Onerrgo ERR
If clalev([F:AWA])=0  : Local File AWRKPAR    [AWA]  : Endif
If clalev([F:AWA2])=0 : Local File AWRKPAR    [AWA2] : Endif
If clalev([F:AWF])=0  : Local File AWRKPARF   [AWF]  : Endif
If clalev([F:AWH])=0  : Local File AWRKPARH   [AWH]  : Endif
If clalev([F:AWR])=0  : Local File AWRKREG    [AWR]  : Endif
If clalev([F:AWV])=0  : Local File AWRKREGVAL [AWV]  : Endif
If clalev([F:AWM])=0  : Local File AWRKLNK    [AWM]  : Endif
If clalev([F:AWU])=0  : Local File AWRKUSR    [AWU]  : Endif
If clalev([F:AWU2])=0 : Local File AWRKUSR    [AWU2] : Endif
If clalev([F:AUS2])=0 : Local File AUTILIS    [AUS2] : Endif
If clalev([F:AWG])=0  : Local File AWRKHISMES [AWG]  : Endif
If clalev([F:AWG2])=0 : Local File AWRKHISMES [AWG2] : Endif
If clalev([F:AWO])=0  : Local File AWRKHISDES [AWO]  : Endif
If clalev([F:AWJ])=0  : Local File AWRKHISJOI [AWJ]  : Endif
If clalev([F:AWS2])=0 : Local File AWRKHISSUI [AWS2] : Endif
If clalev([F:ANM])=0  : Local File ACODNUM    [ANM]  : Endif
If clalev([F:AVN])=0  : Local File AVALNUM    [AVN]  : Endif

If clalev([F:AIN])=0 & GCONTACTCRM
 Local File CONTACTCRM [AIN]
Endif
If clalev([F:CNT])=0
 If GCONTACT
  Local File CONTACT [CNT]
 Elsif GCONTACT2
  #CHECK UNUSED_BEGIN
  Local File CONTACT2 [CNT]
  #CHECK UNUSED_END
 Endif
Endif
Onerrgo
If ERN : End : Endif

Onerrgo ERR
CPTWRG = func SUBTCA.NAMCPT(1,1) : # Compteur chrono groupe
CPTWRK = func SUBTCA.NAMCPT(1,2) : # Compteur chrono ligne
Onerrgo
If ERN : End : Endif

If CPTWRG="" : CPTWRG = "WRG" : Endif
If CPTWRK="" : CPTWRK = "WRK" : Endif

Onerrgo ERR
Look [ANM]ANM0 = CPTWRG
Onerrgo
If ERN | fstat : End : Endif

# Variables dimensionnées suivant le paramètrage
Local Shortint DIME
DIME = dim([F:AWR]TABFLD)  : Local Char    VALEXP(30)(1..DIME)    : # Nb de valeurs de règles
DIME = dim([F:AWF]VARCTX)  : Local Char    CTX(GLONID1)(1..DIME)  : # Nb de variables contexte
DIME = dim([F:AWV]USER)    : Local Char    USER(GLONAUS)(1..DIME) : # Nb d'utilisateurs par défaut
DIME = dim([F:AWH]CNDDES)  : Local Integer COND(1..DIME)          : # Nb de destinataires dans la règle

# Autres variables dimensionnées
Gosub SET_DIM
Local Clbfile TEXLIG(DIMCLB) , TEXTMP(DIMCLB) , TEXCLB(DIMCLB)
Local Char    PCEJOI(200)(1..DIMJOI)
Local Char    USR_EMAIL(GLONMAI)(1..DIMUSR) , USR_CODE(GLONAUS)(1..DIMUSR)
Local Char    USR_NATURE(20)(1..DIMUSR) , USR_TOP(GLONAUS)(1..DIMUSR)
Local Integer USR_SUIVI(1..DIMUSR) , USR_ENVOI(1..DIMUSR) , USR_DEL(1..DIMUSR)
Local Integer REPCHR(0..dim([F:AWF]ACTSIG))
Local Char    SIG_DEL(GLONAUS)(1..dim([F:AWV]USER),1..DIMUSR)

# Ouverture de la table AWRKPAR sous l'abréviation [AWAY] pour gérer les règles de signatures
# déclenchées par la règle principale ouverte sous l'abréviation [AWAX]
# Utilisation d'un 'Columns' pour éviter de se trimbaler le clob

If clalev([F:AWAX])=0
 Local File AWRKPAR [AWAX]
 Columns [AWAX]  (TYPEVT,ENAFLG,CODEVT,ENAMES,ENASUI,ENAACT,CODE,TYPDEC,OPERATION)
 #VPO20160105 add ([F]CODEVT="" or [F]CODEVT=[L]CODEVT)
 Filter [AWAX] Where [F]TYPEVT=[L]TYPEVT & [F]ENAFLG=2 & ([F]CODEVT="" or [F]CODEVT=[L]CODEVT)
 Read [AWAX]AWA1 First
 While !fstat
  [F:AWA] = [F:AWAX]
  Gosub TEST_WORK
  If OK
   GOK = 1
   Gosub OK
   If GOK<>1 : Break : Endif
  Endif
  Read [AWAX]AWA1 Next
 Wend
 Close Local File [AWAX]
Elsif clalev([F:AWAY])=0
 Local File AWRKPAR [AWAY]
 Columns [AWAY]  (TYPEVT,ENAFLG,CODEVT,ENAMES,ENASUI,ENAACT,CODE,TYPDEC,OPERATION)
 #VPO20160105 add ([F]CODEVT="" or [F]CODEVT=[L]CODEVT)
 Filter [AWAY] Where [F]TYPEVT=[L]TYPEVT & [F]ENAFLG=2 & ([F]CODEVT="" or [F]CODEVT=[L]CODEVT)
 Read [AWAY]AWA1 First
 While !fstat
  [F:AWA] = [F:AWAY]
  Gosub TEST_WORK
  If OK
   GOK = 1
   Gosub OK
   If GOK<>1 : Break : Endif
  Endif
  Read [AWAY]AWA1 Next
 Wend
 Close Local File [AWAY]
Endif

GTRACE = NUMTRA
End

#-------------------#
$TEST_WORK
OK =  ([F:AWA]CODEVT="" or [F:AWA]CODEVT=[L]CODEVT)
OK *= ([F:AWA]ENAMES=2 or [F:AWA]ENASUI=2 or [F:AWA]ENAACT=2)
OK *= ([L]CODE="" or [F:AWA]CODE=[L]CODE)
OK *= ([L]TYPDEC=0 or ([L]TYPDEC=1 & [F:AWA]TYPDEC<=1) or ([L]TYPDEC=[F:AWA]TYPDEC))
If OK
 Case [F:AWA]TYPEVT
  When 2 : # Objet
   OK =  instr(1,[F:AWA]OPERATION,OPERAT)
   OK += (instr(1,OPERAT,"~") & instr(1,[F:AWA]OPERATION,right$(OPERAT,2)))
  When 4 : # Etat
   OK = instr(1,[F:AWA]OPERATION,OPERAT)
   OK += ([F:AWA]OPERATION="" & OPERAT="C")
  When 8 : # Import
   OK = 1
   For I=1 To len(OPERAT)
    OK *= (instr(1,[F:AWA]OPERATION,mid$(OPERAT,I,1)))
   Next I
  When 9 : # Signature
   OK = 0
   If instr(1,[F:AWA]OPERATION,OPERAT)
    OK = 1
   Endif
  When Default
   OK = 1
 Endcase
 If OK
  Call SET_PREF([F:AWA]CODE,PREF) From SUBAWA
  NOMPROG = PREF+[F:AWA]CODE
  Call EXISTE_ADX("","",NOMPROG,OK) From ORDSYS
 Endif
Endif
Return

#-------------------#
$SET_DIM
Local Shortint DIMJOI : DIMJOI = 50          : # Nb maxi de pièces jointes
Local Shortint DIMUSR : DIMUSR = 150         : # Nb maxi de destinataires (principal+copie)
Local Shortint DIMCLB : DIMCLB = func DIMCLB : # Taille des blobs
Return

#-------------------#
Funprog DIMCLB
Local Shortint DIMCLB
Local File ADOVAL [ADWF]
Read [ADWF]ADW0="";"";"AWRKDIMCLB"
If !fstat
 DIMCLB = val([F:ADWF]VALEUR)
Endif
DIMCLB = max(DIMCLB,6) : # Plutôt qu'utiliser GLONACB qui provoque une erreur + de mémoire dispo
Close Local File [ADWF]
End DIMCLB

#----------------------------------------------------------------------#
$OK
[L]REGCUR = [F:AWA]CODE
Read [AWA]AWA0 = [L]REGCUR
Read [AWF]AWF0 = [L]REGCUR
Read [AWH]AWH0 = [L]REGCUR
ERD     = ([F:AWA]DEBUG=2)
GRPENV  = ([F:AWA]GRPENV=2)
NUMGRP  = ""
TRACE   = 0

# Début de trace
If ERD
 # Traitement de la règle workflow
 If !GSERVEUR & !GIMPORT & !SIMUL & (TYPEVT<>9 or GTRACE="")
  TRACE = 1
  Call OUVRE_TRACE(mess(135,75,1)-[F:AWA]CODE-mess([L]TYPEVT,988,1)) From LECFIC
 Else
  ERM = string$(80,"-")+"\"+mess(135,75,1)-[F:AWA]CODE-mess([L]TYPEVT,988,1)+"\"+string$(80,"-")
  Gosub TRACE
 Endif
Endif

# Traitement spécial pour la signature
Case TYPEVT
 When 9       : Gosub SIGNATURE
 When Default : Gosub AUTRES
Endcase

If GRPENV & !DIFFERE & !SIMUL
 Call ENVOI_GROUPE(GRPDEB)
Endif

# Fin de trace
If ERD
 If TRACE
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
 Else
  ERM = string$(80,"-")
  Gosub TRACE
 Endif
Endif
Return

#--------------------#
$ERR
ERN = errn
ERM = "|"+errp-"("+num$(errl)+")"-mess(6,123,1)-num$(ERN)-":"-errmes$(ERN)-errm+"|"
Gosub TRACE_ERR
Resume

#--------------------#
$TRACE_ERR
If dim([L]ERD)>0 & [L]ERD
 If dim([L]ERT)>0
  Case ERT
   When 1  : ERM = mess(56,123,1) +"\"+ERM : # Texte ligne
   When 2  : ERM = mess(55,75,1)  +"\"+ERM : # Règle workflow
   When 3  : ERM = mess(60,75,1)  +"\"+ERM : # Conditions
   When 4  : ERM = mess(27,115,1) +"\"+ERM : # Action
   When 5  : ERM = mess(26,75,1)  +"\"+ERM : # Destinataires
   When 6  : ERM = mess(28,123,1) +"\"+ERM : # Texte
   When 7  : ERM = mess(118,124,1)+"\"+ERM : # Pièces jointes
   When 8  : ERM = mess(57,75,1)  +"\"+ERM : # Contexte retour
   When 9  : ERM = mess(61,117,1) +"\"+ERM : # Suivi
   When 10 : ERM = mess(58,75,1)  +"\"+ERM : # Compteur groupe
   When 11 : ERM = mess(77,105,1) +"\"+ERM : # No Chrono
   When 12 : ERM = mess(59,75,1)  +"\"+ERM : # Envoi du message
   When 13 : ERM = mess(79,75,1)  +"\"+ERM : # Environnement signature
   When 14 : ERM = mess(148,75,1) +"\"+ERM : # Environnement workflow
   When 15 : ERM = mess(188,75,1) +"\"+ERM : # Importance du message
  Endcase
 Endif
 If dim([L]TYPEVT)>0
  ERM += "\"+mess(6,123,1)-mess(1,75,1)-mess([L]TYPEVT,988,1)-[L]CODEVT-":"-[F:AWA]CODE : # Erreur/Workflow
  If FORMULE<>""
   ERM += "\"+mess(65,106,1)-":"-FORMULE : # Erreur en évaluation de la formule
  Endif
 Endif
 If dim([L]ERN)>0
  Call ECR_TRACE(ERM,ERN) From GESECRAN
  If ERN<>0 : GOK = 0 : Endif
 Else
  Call ECR_TRACE(ERM,-1) From GESECRAN
 Endif
Endif
Return

#--------------------#
$TRACE
If ERD or SIMUL
 Call ECR_TRACE(ERM,0) From GESECRAN
Endif
Return

#----------------------------------------------------------------------#
$SIGNATURE
ERT = 13

# Evènement origine et signataire
Raz I , NUMORG , USRORG , NUMSIG , USRWRK , MAIWRK , LEVSIG , USRDES , REASON
CHAINE = CLESIG
While CHAINE<>""
 I += 1
 K = instr(1, CHAINE,"~")
 If K
  VALCLE = left$(CHAINE,K-1)
  CHAINE = right$(CHAINE,K+1)
 Else
  VALCLE = CHAINE
  CHAINE = ""
 Endif
 Case I
  When 1 : NUMORG = VALCLE      : # Chrono origine
  When 2 : USRORG = VALCLE      : # Destinataire chrono d'origine
  When 3 : NUMSIG = VALCLE      : # Chrono sur lequel a été déclenché la signature
  When 4 : USRDES = VALCLE      : # Destinataire du chrono sur lequel a été déclenché la signature
  When 5 : USRWRK = VALCLE      : # User qui a déclenché la signature
  When 6 : MAIWRK = VALCLE      : # E-mail du signataire (utilisateur externe par lien http)
  When 7 : LEVSIG = val(VALCLE) : # Niveau de signature (0=évènement d'origine)
  When 8 : ACTWRK = val(VALCLE) : # Déclenché par l'action SIGWRK
  When 9 : REASON = VALCLE      : # Motif signature courante
 Endcase
Wend
If NUMORG<>""
 Read [AWS2]AWS0 = NUMORG ; USRORG
 If fstat
  ERN = fstat : ERM = mess(77,105,1)-":"-NUMORG+"/"+USRORG-mess(87,100,1) : # Chrono inexistant
  Gosub TRACE_ERR : Return
 Endif
 Raz REPCHR
 CHAINE = [F:AWS2]NUMGRP
 Read [AWF]AWF0 = [F:AWS2]CODWRK
 Filter [AWS2] Where [F]NUMGRP=CHAINE & [F]CHRONO=[L]NUMORG
 For [AWS2]AWS4(3)
  If [F:AWS2]ACTSIG="" or [F:AWS2]FLGSIG<=3
   REPCHR(0) += 1 : # Nb de réponses qu'il reste à faire
  Else
   K = find([F:AWS2]ACTSIG,[F:AWF]ACTSIG)
   If K
    REPCHR(K) += 1 : # Réponses par code réponse
   Endif
  Endif
 Next AWS2
 Filter [AWS2]
 Read [AWF]AWF0 = [F:AWA]CODE
 Read [AWS2]AWS0 = NUMORG ; USRORG
Else
 Read [AWS2]AWS0 = NUMSIG ; USRDES
 If fstat
  ERN = fstat : ERM = mess(77,105,1)-":"-NUMSIG+"/"+USRDES-mess(87,100,1) : # Chrono inexistant
  Gosub TRACE_ERR : Return
 Endif
Endif
Read [AWA2]AWA0 = [F:AWS2]CODWRK
If fstat
 ERN = fstat : ERM = [F:AWS2]CODWRK-":"-mess(107,75,1) : # Paramètrage workflow inexistant
 Gosub TRACE_ERR : Return
Endif
Call SET_PREF([F:AWA2]CODE,PREF) From SUBAWA
NOMPRIG = PREF+[F:AWA2]CODE

# Identification icône retour et valeurs de l'évènement d'origine
IDTGRP    = [F:AWS2]IDENTGRP   : # Identifiant ligne
RETORG    = [F:AWS2]IDENTRET   : # Clé de l'objet sur lequel a été déclenché le workflow d'origine
CONTXT    = [F:AWS2]CONTXT     : # Référence de l'icône retour (permet le retour sur l'objet déclencheur)
CONTXT_DESKTOP = [F:AWS2]CONTXTDSKTOP     # X3PLAT-1475 Workflow link on representation
CONTXT_MOBILE = [F:AWS2]CONTXTMOBILE      # X3PLAT-1475 Workflow link on representation
CLEOBJ    = NUMSIG             : # Numéro du chrono signé
For I=1 To dim(CTX)
 CTX(I)   = evalue("[F:AWS2]VALCTX"+num$(I))
Next I
S_USER    = [F:AWS2]EMETTEUR   : # Destinataire qui a déclenché le workflow d'origine
S_CLEOBJ  = [F:AWS2]CLEDEC     : # Clé de déclenchement (objet ou regroupement)
S_ABREV   = [F:AWS2]ABROBJ     : # Abréviation de l'objet du workflow d'origine
S_NBRUSR  = [F:AWS2]NBRUSR     : # Nb de signataires définis par la règle du worflow d'origine
NBRUSR    = [F:AWS2]NBRUSR     : # Nb de signataires définis par la règle du worflow
For J=1 To NBRUSR
 If evalue("dim([F:AWS2]USRSIG"+num$(J)+")")>0
  USER(J) = evalue("[F:AWS2]USRSIG"+num$(J)) : # Signataires définis par la règle du worflow
 Endif
Next J

# Lecture de la table principale
Gosub OUVREF From =NOMPRIG
If TABREF=""
 ERN = 1 : ERM = mess(80,75,1) : # Table de référence inexistante
 Gosub TRACE_ERR : Return
Endif
If !ACTWRK
 Gosub LNKREF From =NOMPRIG
 CHAINE = [F:AWS2]IDENTREF
 K = instr(1,CHAINE,"/")
 CHAINE = right$(CHAINE,K+1)
 For I=1 To dim(DEFREF)
  If DEFREF(I)<>""
   K = instr(1,CHAINE,"~")
   If K
    VALCLE = left$(CHAINE,K-1)
    CHAINE = right$(CHAINE,K+1)
   Else
    VALCLE = CHAINE
    CHAINE = ""
   Endif
   ERN = 0
   Onerrgo ERR
   Case TYPREF(I)
    When 1,2,3,4,5,6 : Assign ("[F]"+DEFREF(I)) With val(VALCLE)
    When Default     : Assign ("[F]"+DEFREF(I)) With VALCLE
   Endcase
   Onerrgo
  Endif
 Next I
 Read [F] =
 If fstat
  ERN = fstat : ERM = TABREF-":"-mess(81,75,1) : # Enregistrement non trouvé
  Gosub TRACE_ERR : Return
 Endif
Endif

# Lecture des tables 1,1
# Issue X3-110447 - 2018-10-11 by ALSHE : call also when triggered by action SIGWRK (SAIWRKSIG)
#If !ACTWRK
 Gosub LECENT From =NOMPRIG
#Endif

# Ouverture du link
Gosub CRITLNK From =NOMPRIG
CHAINE = num$(NBRFLD)
Gosub CRITLNK From =NOMPROG
NBRFLD = val(CHAINE)
# Issue X3-110447 - 2018-10-11 by ALSHE : call also when triggered by action SIGWRK (SAIWRKSIG)
#If !ACTWRK
 Gosub LNKLIG From =NOMPRIG
#Endif

# Filtre groupe
Gosub LNKGRP From =NOMPRIG
CHAINE = [F:AWS2]IDENTGRP
K = instr(1,CHAINE,"/")
CHAINE = right$(CHAINE,K+1)
Raz FILTGRP
For I=1 To dim(DEFGRP)
 If DEFGRP(I)<>""
  K = instr(1,CHAINE,"~")
  If K
   VALCLE = left$(CHAINE,K-1)
   CHAINE = right$(CHAINE,K+1)
  Else
   VALCLE = CHAINE
   CHAINE = ""
  Endif
  If I>1 : FILTGRP += ' & ' : Endif
  FILTGRP += DEFGRP(I)+'='
  Case TYPGRP(I)
   When 1,2,3,4,5,6 : FILTGRP += VALCLE
   When 8           : FILTGRP += '['+right$(VALCLE,7)+'/'+mid$(VALCLE,5,2)+'/'+left$(VALCLE,4)+']'
   When Default     : FILTGRP += '"'+VALCLE+'"'
  Endcase
 Endif
Next I
If FILTGRP="" : FILTGRP = "1=1" : Endif

# Délégués signataires par niveau de signature
Raz SIG_DEL , I , J
For I=1 To NBRUSR
 For [AWS2]AWS1 Where [F:AWS2]TYPEVT=2 & [F:AWS2]CLEOBJ=S_CLEOBJ & [F:AWS2]IDENTGRP=IDTGRP & NUMORG=[L]NUMORG & LEVSIG=I-1
  If !find([F:AWS2]USRSIG,USER(I,I),SIG_DEL(I..I,1..dim(SIG_DEL)))
   J = find("",SIG_DEL(I..I,1..dim(SIG_DEL)))
   If J
    SIG_DEL(I,J) = [F:AWS2]USRSIG
   Endif
  Endif
 Next AWS2
Next I

# Pour récupérer le modèle sur le workflow d'origine
Gosub DEFENT From =NOMPRIG
CHAINE = MODELE

# Et la règle d'affectation signature et societe
Gosub DEFENT From =NOMPROG
MODELE = CHAINE

If REGLE<>""
 Raz USER , NBRUSR
 Read [AWR]AWR1 = REGLE ; SOCIETE
 If fstat
  Read [AWR]AWR1 = REGLE ; ""
 Endif
 If [F:AWR]MODELE<>MODELE
  # Le modèle de la règle de signature n'est pas le même que celui du workflow d'origine
  ERN = 1 : ERM = MODELE-":"-mess(103,75,1)
  Gosub TRACE_ERR : Return
 Endif
 Call SET_PREF(REGLE,PREF) From SUBAWR
 NOMPREG = PREF+REGLE
 Read [AWV]AWV0(2) = REGLE ; SOCIETE
 If !fstat
  For U=1 To dim([F:AWV]USRDEF)
   If !func SUBAWV.FORAUS([F:AWV]USRDEF(U-1),[F:AWV]FLGFOR)
    USER(U) = [F:AWV]USRDEF(U-1)
   Else
    ERN = 0
    Onerrgo ERR
    FORMULE = format$("KTv2:255X",[F:AWV]USRDEF(U-1))
    USER(U) = evalue(FORMULE)
    If ERN : Raz USER(U) : Endif
    Onerrgo
   Endif
  Next U
 Else
  Read [AWV]AWV0(2) = REGLE ; ""
  If !fstat
   For U=1 To dim([F:AWV]USRDEF)
    If !func SUBAWV.FORAUS([F:AWV]USRDEF(U-1),[F:AWV]FLGFOR)
     USER(U) = [F:AWV]USRDEF(U-1)
    Else
     ERN = 0
     Onerrgo ERR
     FORMULE = format$("KTv2:255X",[F:AWV]USRDEF(U-1))
     USER(U) = evalue(FORMULE)
     If ERN : Raz USER(U) : Endif
     Onerrgo
    Endif
   Next U
  Endif
 Endif
Endif

Case [F:AWA2]TYPWRK
 When 2 : # Entête
  Gosub TRT_REGLE
  Gosub TRT_WORK
 When 3 : # Ligne
  If NBRFLD=0
   Gosub TRT_REGLE
   Gosub TRT_WORK
  Elsif ACTWRK
   Gosub TRT_LIGNES
  Else
   K = 6
   Gosub TRT_ACTION
   If GOK<>1 : Return : Endif
   Raz NBGRP
   Case NBRFLD
    When 1       For [LNK_]CLE(1) Where evalue(FILTGRP) : Gosub TRT_LIGNES : Next LNK_
    When 2       For [LNK_]CLE(2) Where evalue(FILTGRP) : Gosub TRT_LIGNES : Next LNK_
    When 3       For [LNK_]CLE(3) Where evalue(FILTGRP) : Gosub TRT_LIGNES : Next LNK_
    When 4       For [LNK_]CLE(4) Where evalue(FILTGRP) : Gosub TRT_LIGNES : Next LNK_
    When 5       For [LNK_]CLE(5) Where evalue(FILTGRP) : Gosub TRT_LIGNES : Next LNK_
    When 6       For [LNK_]CLE(6) Where evalue(FILTGRP) : Gosub TRT_LIGNES : Next LNK_
    When 7       For [LNK_]CLE(7) Where evalue(FILTGRP) : Gosub TRT_LIGNES : Next LNK_
    When Default For [LNK_]CLE(8) Where evalue(FILTGRP) : Gosub TRT_LIGNES : Next LNK_
   Endcase
   If !NBGRP
    ERM = mess(22,110,1) : # Aucune ligne trouvée
    Gosub TRACE
   Endif
  Endif
Endcase

Return

#----------------------------------------------------------------------#
$AUTRES
Gosub DEFENT From =NOMPROG : # Définition des variables liées à la règle
Gosub OUVREF From =NOMPROG : # Ouverture de la table principale
Gosub LECENT From =NOMPROG : # Lecture des tables liées 1,1
Gosub LNKGRP From =NOMPROG : # Définition de la clé de groupe
Gosub LNKREF From =NOMPROG : # Définition de la clé de la table de référence

ERM = mess(138,75,1)-LNKREF : # Table de référence
If CLEREF<>""
 ERM -= ":"-mess(55,123,1)-"="-evalue(CLEREF) : # clé
Endif
Gosub TRACE

Raz NUMORG , USRORG , NUMSIG , MAIWRK , LEVSIG , ACTWRK , USRDES , REASON
Raz CTX , S_CLEOBJ , S_ABREV , S_NBRUSR , S_USER , NBRUSR

If TYPEVT=1 & CODEVT="CAN" : # Annulation signature
 I = 0
 CHAINE = CLESIG
 While CHAINE<>""
  I += 1
  K = instr(1, CHAINE,"~")
  If K
   VALCLE = left$(CHAINE,K-1)
   CHAINE = right$(CHAINE,K+1)
  Else
   VALCLE = CHAINE
   CHAINE = ""
  Endif
  Case I
   When 1 : NUMORG = VALCLE      : # Chrono origine
   When 2 : USRORG = VALCLE      : # Destinataire chrono d'origine
   When 3 : NUMSIG = VALCLE      : # Chrono sur lequel a été déclenché la signature
   When 4 : USRDES = VALCLE      : # Destinataire du chrono sur lequel a été déclenché la signature
   When 5 : USRWRK = VALCLE      : # User qui a déclenché la signature
   When 6 : LEVSIG = val(VALCLE) : # Niveau de signature (0=évènement d'origine)
   When 7 : REASON = VALCLE      : # Motif signature
  Endcase
 Wend
 Read [AWS2]AWS0=NUMSIG;USRDES
 For I=1 To dim(CTX)
  CTX(I) = evalue("[F:AWS2]VALCTX"+num$(I))
 Next I
 S_USER   = USRWRK
 S_CLEOBJ = [F:AWS2]CLEDEC
 LEVSIG   = [F:AWS2]LEVSIG
 If NUMORG<>""
  Read [AWS2]AWS0=NUMORG;USRORG
 Endif
 S_ABREV  = [F:AWS2]ABROBJ
 S_NBRUSR = [F:AWS2]NBRUSR
 NBRUSR   = [F:AWS2]NBRUSR
 For J=1 To NBRUSR
  If evalue("dim([F:AWS2]USRSIG"+num$(J)+")")>0
   USER(J) = evalue("[F:AWS2]USRSIG"+num$(J))
  Endif
 Next J
Else
 USRWRK   = GUSER  : # User qui déclenche le workflow
 S_USER   = USRWRK
 S_ABREV  = GABREV
Endif

If REGLE<>""
 Raz USER , NBRUSR
 ERN = 0
 ERM = mess(151,75,1)-REGLE
 Read [AWR]AWR1 = REGLE ; SOCIETE
 If !fstat
  ERM -= REGLE-SOCIETE
 Else
  Read [AWR]AWR1 = REGLE ; ""
  If fstat
   ERN = 1 : ERM = REGLE-mess(104,75,1) : # Règle d'affectation inexistante
  Endif
 Endif
 Gosub TRACE
 Call SET_PREF(REGLE,PREF) From SUBAWR
 NOMPREG = PREF+REGLE
 Read [AWV]AWV0(2) = REGLE ; SOCIETE
 If !fstat
  For U=1 To dim([F:AWV]USRDEF)
   If !func SUBAWV.FORAUS([F:AWV]USRDEF(U-1),[F:AWV]FLGFOR)
    USER(U) = [F:AWV]USRDEF(U-1)
   Else
    ERN = 0
    Onerrgo ERR
    FORMULE = format$("KTv2:255X",[F:AWV]USRDEF(U-1))
    USER(U) = evalue(FORMULE)
    If ERN : Raz USER(U) : Endif
    Onerrgo
   Endif
  Next U
 Else
  Read [AWV]AWV0(2) = REGLE ; ""
  If !fstat
   For U=1 To dim([F:AWV]USRDEF)
    If !func SUBAWV.FORAUS([F:AWV]USRDEF(U-1),[F:AWV]FLGFOR)
     USER(U) = [F:AWV]USRDEF(U-1)
    Else
     ERN = 0
     Onerrgo ERR
     FORMULE = format$("KTv2:255X",[F:AWV]USRDEF(U-1))
     USER(U) = evalue(FORMULE)
     If ERN : Raz USER(U) : Endif
     Onerrgo
    Endif
   Next U
  Endif
 Endif
Endif
If MODELE<>""
 Read [AWM]AWM0 = MODELE
 Case [F:AWA]TYPWRK
  When 2 : # Entête
   Gosub TRT_REGLE
   Gosub TRT_WORK
  When 3 : # Ligne
   Gosub CRITLNK From =NOMPROG
   Gosub LNKLIG From =NOMPROG
   If NBRFLD=0
    If [L]TYPEVT=10 : # Manuel
     Gosub TRT_LIG_MAN
    Else
     Gosub TRT_REGLE
     Gosub TRT_WORK
    Endif
   Else
    K = 6
    Gosub TRT_ACTION
    If GOK<>1 : Return : Endif
    Raz NBGRP
    Case NBRFLD
     When 1       : For [LNK_]CLE(1) : Gosub TRT_LIGNES : Next LNK_
     When 2       : For [LNK_]CLE(2) : Gosub TRT_LIGNES : Next LNK_
     When 3       : For [LNK_]CLE(3) : Gosub TRT_LIGNES : Next LNK_
     When 4       : For [LNK_]CLE(4) : Gosub TRT_LIGNES : Next LNK_
     When 5       : For [LNK_]CLE(5) : Gosub TRT_LIGNES : Next LNK_
     When 6       : For [LNK_]CLE(6) : Gosub TRT_LIGNES : Next LNK_
     When 7       : For [LNK_]CLE(7) : Gosub TRT_LIGNES : Next LNK_
     When Default : For [LNK_]CLE(8) : Gosub TRT_LIGNES : Next LNK_
    Endcase
    If !NBGRP
     ERM = mess(22,110,1) : # Aucune ligne trouvée
     Gosub TRACE
    Endif
   Endif
 Endcase
Else
 Gosub TRT_WORK
Endif
Return

#----------------------------------------------------------------------#
$TRT_LIGNES
Raz TEXLIG , NBLIG
Raz FORMULE , ERN
NBGRP += 1
ERT = 1
# Issue X3-110447 - 2018-10-11 by ALSHE : read all lines for workflow message independent of ACTWRK
K = 5
Gosub TRT_ACTION
For [LNK_]CLE
 If (ACTWRK & evalue(FILTGRP) & evalue(CRITLNK)) or (!ACTWRK & evalue(CRITLNK))
  NBLIG += 1
  K = 4
  Gosub TRT_ACTION
  If GOK<>1 : Break : Endif
  If [F:AWA]TEXLIG<>""
   ERN = 0
   Onerrgo ERR
   FORMULE = format$("KTv2:255X",[F:AWA]TEXLIG)
   TEXTMP = evalue(FORMULE)
   If ERN : Raz TEXTMP : Endif
   If NBLIG>1 : Append TEXLIG,chr$(13)+chr$(10) : Endif
   Append TEXLIG,TEXTMP
   Onerrgo
  Endif
 Endif
Next LNK_
If GOK<>1
 Return
Elsif !NBLIG
 ERM = mess(22,110,1) : # Aucune ligne trouvée
 Gosub TRACE : Return
Else
 ERM = mess(167,117,1)-num$(NBLIG) : # Nombre de lignes =
 Gosub TRACE
Endif
Gosub TRT_REGLE
Gosub TRT_WORK
Return

#----------------------------------------------------------------------#
$TRT_LIG_MAN
Raz TEXLIG , NBLIG
Raz FORMULE , ERN
ERT = 1
K = 5
Gosub TRT_ACTION
For [LNM_]CLE
 NBLIG += 1
 K = 4
 Gosub TRT_ACTION
 If GOK<>1 : Break : Endif
 If [F:AWA]TEXLIG<>""
  ERN = 0
  Onerrgo ERR
  FORMULE = format$("KTv2:255X",[F:AWA]TEXLIG)
  TEXTMP = evalue(FORMULE)
  If ERN : Raz TEXTMP : Endif
  If NBLIG>1 : Append TEXLIG,chr$(13)+chr$(10) : Endif
  Append TEXLIG,TEXTMP
  Onerrgo
 Endif
Next LNM_
Onerrgo
If GOK<>1
 Return
Elsif !NBLIG
 ERM = mess(22,110,1) : # Aucune ligne trouvée
 Gosub TRACE : Return
Else
 ERM = mess(167,117,1)-num$(NBLIG) : # Nombre de lignes =
 Gosub TRACE
Endif
Gosub TRT_REGLE
Gosub TRT_WORK
Return

#----------------------------------------------------------------------#
$TRT_REGLE
Raz VALEXP
If REGLE="" : Return : Endif
Raz FORMULE , ERN , NBRUSR
ERT = 2
Onerrgo ERR
For I=1 To [F:AWR]NBRFLD
 If [F:AWR]EXPFLD(I-1)<>""
  TABLE = [F:AWR]TABFLD(I-1)+"~"+[F:AWR]ABRFLD(I-1)
  Gosub LNKREG From =NOMPREG
  If [F:AWR]SYNFLD(I-1)=0
   FORMULE = format$("KTv2:255X",[F:AWR]EXPFLD(I-1))
   VALEXP(I) = num$(evalue(FORMULE))
  Else
   Raz NBENR
   For [LNR_]
    NBENR += 1
    Case [F:AWR]SYNFLD(I-1)
     When 1 : # mini
      FORMULE = format$("KTv2:255X",[F:AWR]EXPFLD(I-1))
      If NBENR=1
       VALEXP(I) = num$(evalue(FORMULE))
      Else
       VALEXP(I) = num$(min(val(VALEXP(I)),evalue(FORMULE)))
      Endif
     When 2 : # Maxi
      FORMULE = format$("KTv2:255X",[F:AWR]EXPFLD(I-1))
      If NBENR=1
       VALEXP(I) = num$(evalue(FORMULE))
      Else
       VALEXP(I) = num$(max(val(VALEXP(I)),evalue(FORMULE)))
      Endif
     When 3 , 4 : # Somme , moyenne
      FORMULE = format$("KTv2:255X",[F:AWR]EXPFLD(I-1))
      VALEXP(I) = num$(val(VALEXP(I))+evalue(FORMULE))
    Endcase
   Next LNR_
   If [F:AWR]SYNFLD(I-1)=4 & NBENR<>0
    VALEXP(I) = num$(val(VALEXP(I))/NBENR)
   Endif
  Endif
 Endif
Next I
Read [AWV]AWV0(2) = REGLE ; SOCIETE
If !fstat
 Filter [AWV] Where REGLE=[F:AWR]REGLE & CPY=SOCIETE
Else
 Filter [AWV] Where REGLE=[F:AWR]REGLE & CPY=""
Endif
For [AWV]AWV0
 OK = 1
 For U=1 To dim([F:AWV]USRDEF)
  If !func SUBAWV.FORAUS([F:AWV]USRDEF(U-1),[F:AWV]FLGFOR)
   USER(U) = [F:AWV]USRDEF(U-1)
  Else
   ERN = 0
   Onerrgo ERR
   FORMULE = format$("KTv2:255X",[F:AWV]USRDEF(U-1))
   USER(U) = evalue(FORMULE)
   If ERN : Raz USER(U) : Endif
  Endif
 Next U
 For J=1 To [F:AWR]NBRFLD
  Case [F:AWR]OPEFLD(J-1)
   When 2 : # =
    If VALEXP(J)<>[F:AWV]VALREG(J-1)
     OK = 0 : Break
    Endif
   When 3 : # <>
    If VALEXP(J)=[F:AWV]VALREG(J-1)
     OK = 0 : Break
    Endif
   When 4 : # >
    If val(VALEXP(J))<=val([F:AWV]VALREG(J-1))
     OK = 0 : Break
    Endif
   When 5 : # >=
    If val(VALEXP(J))<val([F:AWV]VALREG(J-1))
     OK = 0 : Break
    Endif
   When 6 : # <
    If val(VALEXP(J))>=val([F:AWV]VALREG(J-1))
     OK = 0 : Break
    Endif
   When 7 : # <=
    If val(VALEXP(J))>val([F:AWV]VALREG(J-1))
     OK = 0 : Break
    Endif
   When 8 : # Comme
    If pat(VALEXP(J),[F:AWV]VALREG(J-1))=0
     OK = 0 : Break
    Endif
  Endcase
 Next J
 If OK
  For U=1 To dim([F:AWV]USRDEF)
   If !func SUBAWV.FORAUS([F:AWV]USER(U-1),[F:AWV]FLGFOR)
    USER(U) = [F:AWV]USER(U-1)
   Else
    ERN = 0
    Onerrgo ERR
    FORMULE = format$("KTv2:255X",[F:AWV]USER(U-1))
    USER(U) = evalue(FORMULE)
    If ERN : Raz USER(U) : Endif
   Endif
  Next U
  Break
 Endif
Next AWV
Filter [AWV]
Onerrgo
ERM = ""
For U=1 To dim([F:AWV]USRDEF)
 If USER(U)="" : Break : Endif
 ERM -= USER(U)
 NBRUSR += 1
Next U
If vireblc(ERM,2)<>""
 ERM = mess(136,75,1)-REGLE-":"-ERM : # Utilisateurs déterminés par la règle
 Gosub TRACE
Endif
Return

#----------------------------------------------------------------------#
$TRT_WORK

# Mise à jour variable contexte
Raz FORMULE , ERN
ERT = 14
Onerrgo ERR
If TYPEVT<>9 & (TYPEVT<>1 or CODEVT<>"CAN") : # Signature et Evènement annulation signature
 For J=1 To dim([F:AWF]VARCTX)
  ERN = 0
  If [F:AWF]VARCTX(J-1)<>""
   FORMULE = format$("KTv2:255X",[F:AWF]VARCTX(J-1))
   CTX(J) = num$(evalue(FORMULE))
   If ERN : Raz CTX(J) : Endif
   FORMULE = ""
  Endif
 Next J
 If CLEGRP<>""
  S_CLEOBJ = evalue(CLEGRP)
 Else
  S_CLEOBJ = CLEOBJ
 Endif
 S_NBRUSR = [L]NBRUSR
Endif
Onerrgo

# Condition d'exécution workflow
Gosub CTL_CONDIT
If !OK : Return : Endif

# Contexte retour CCL
#Gosub TRT_CONTXT

If !SIMUL
 # Attribution du chrono groupe
 If NUMGRP=""
  ERN = 0
  Onerrgo ERR
  If !adxlog
   Trbegin ADOVAL
    Call NUMERO(CPTWRG,"",date$,"",NUMGRP,STAT) From SUBANM
   Commit
  Else
   Call NUMERO(CPTWRG,"",date$,"",NUMGRP,STAT) From SUBANM
  Endif
  Onerrgo
  If ERN : OK = 0 : Return : Endif : # Pour éviter des erreurs sur des workflow de fin de session
  If STAT<>0
   Gosub MESSAGE From SUBANM
   ERT = 10 : ERN = STAT : ERM = MESSA : Gosub TRACE_ERR : Return
  Endif
  ERM = mess(58,75,1)-NUMGRP : # Compteur groupe
  Gosub TRACE
  If GRPDEB=""
   GRPDEB = NUMGRP
  Endif
 Endif

 # Attribution du chrono ligne
 If !adxlog
  Trbegin ADOVAL
   Call NUMERO(CPTWRK,"",date$,"",CHRONO,STAT) From SUBANM
  Commit
 Else
  Call NUMERO(CPTWRK,"",date$,"",CHRONO,STAT) From SUBANM
 Endif
 If STAT<>0
  Gosub MESSAGE From SUBANM
  ERT = 11 : ERN = STAT : ERM = MESSA : Gosub TRACE_ERR : Return
 Endif
 ERM = mess(77,105,1)-CHRONO : # No Chrono
 Gosub TRACE

Endif

# Contexte retour CCL
Gosub TRT_CONTXT

If CLEGRP<>""
 ERM = "*"-mess(139,75,1)-TABGRP+","-mess(55,123,1)-evalue(CLEGRP) : # Regroupement , clé
 Gosub TRACE
Endif

# Exécution action début workflow
K = 1
Gosub TRT_ACTION
If GOK<>1 : Return : Endif

# Message actif et au moins un destinataire principal
OK = ([F:AWA]ENAMES=2 & find(2,[F:AWH]ENVOI))

# Suivi actif, un signataire au moins en visé
# ou onglet signature renseigné avec au moins un destinataire qui doit signer
OK += ([F:AWA]ENASUI=2 & (find(2,[F:AWH]SUIVI) | find(3,[F:AWH]SUIVI)))
If OK
 Gosub TRT_DEST
 If USR_NB=0 & [L]OPERAT="W" & [F:AWA]ENAMES=2
  Gosub TRT_TEXTE
  If !SIMUL
   Gosub TRT_MAIL
   If GOK<>1 : Return : Endif
  Endif
  ERM = mess(66,75,1) : # Envoi mail
  Gosub TRACE
 Elsif USR_NB=0
  ERN = 1 : ERM = mess(54,75,1) : # Aucun destinataire
  Gosub TRACE
 Else
  If [F:AWA]ENAMES=2 & (find(2,USR_ENVOI) | find(3,USR_ENVOI))
   If !find(2,USR_ENVOI)
    ERN = 1 : ERM = mess(61,75,1) : # Pas de destinataire principal
    Gosub TRACE_ERR
   Else
    Gosub TRT_PIECE
    Gosub TRT_TEXTE
    If !SIMUL
     Gosub TRT_MAIL
     If GOK<>1 : Return : Endif
    Endif
    ERM = mess(66,75,1) : # Envoi mail
    Gosub TRACE
    For I=1 To USR_NB
     If USR_ENVOI(I)>1 : # Oui/Copie
      ERM = "-"-USR_EMAIL(I)
      If USR_CODE(I)<>"" : ERM -= '"'+USR_CODE(I)+'"' : Endif
      If USR_ENVOI(I)>2 : ERM -= "("+mess(USR_ENVOI(I),2919,1)+")" : Endif
      Gosub TRACE
     Endif
    Next I
   Endif
  Endif
  If [F:AWA]ENASUI=2 & (find(2,USR_SUIVI) | find(3,USR_SUIVI))
   If !SIMUL
    Gosub TRT_SUIVI
    If GOK<>1 : Return : Endif
   Endif
   ERM = mess(67,75,1) : # Suivi signature
   Gosub TRACE
   For I=1 To USR_NB
    If USR_SUIVI(I)>1 : # Oui/Avec signature
     ERM = "-"-USR_CODE(I)
     If USR_SUIVI(I)>2 : ERM -= "("+mess(USR_SUIVI(I),2920,1)+")" : Endif
     Gosub TRACE
    Endif
   Next I
  Endif
 Endif
Endif

# Exécution action fin de workflow
K = 2
Gosub TRT_ACTION
If GOK<>1 : Return : Endif

Return

#----------------------------------------------------------------------#
$CTL_CONDIT
Raz FORMULE , ERN
ERT = 3
Onerrgo ERR
OK = 1
For I=1 To [F:AWA]NBCOND
 If [F:AWA]TYPCND(I-1)=2 & [F:AWA]CONDITION(I-1)<>""
  FORMULE = format$("KTv2:255X",[F:AWA]CONDITION(I-1))
  OK = evalue(FORMULE)
  If ERN
   OK = 0 : Break
  Elsif !OK
   Break
  Endif
 Endif
Next I
Onerrgo
If !OK
 ERM = FORMULE+"\"+mess(137,75,1) : # Condition d'entête non remplie
 Gosub TRACE
Endif
Return

#----------------------------------------------------------------------#
$TRT_ACTION
Raz FORMULE , ERN
ERT = 4
If [F:AWA]ENAACT=2
 If !SIMUL
  GOK = 1
  Case K
   When 1 : Gosub EXEACT_AVT From =NOMPROG : # Début workflow
   When 2 : Gosub EXEACT_APR From =NOMPROG : # Fin workflow
   When 4 : Gosub EXEACT_LIG From =NOMPROG : # Ligne
   When 5 : Gosub EXEACT_AVL From =NOMPROG : # Avant ligne
   When 6 : Gosub EXEACT_AVG From =NOMPROG : # Avant groupe
  Endcase
  # Pour retrouver l'environnement au cas où une des actions déclenche un workflow
  Read [AWA]AWA0 = [L]REGCUR
  Read [AWF]AWF0 = [L]REGCUR
  Read [AWH]AWH0 = [L]REGCUR
  If ERN
   Gosub TRACE
  Elsif CHAINE<>""
   ERM = mess(65,75,1)-CHAINE : # Exécution action
   Gosub TRACE
  Endif
  FORMULE = ""
 Endif
Endif
Return

#------------------------------------------------------------------------------------#
$TRT_DEST

Raz USR_EMAIL , USR_CODE , USR_ENVOI , USR_SUIVI , USR_NATURE , USR_DEL , USR_TOP , USR_NB
ERT = 5
Raz ERN , FORMULE
Onerrgo ERR
If [L]TYPEVT=1 & [L]CODEVT="CAN" & [F:AWA]ENAMES=2
 K = instr(1,[L]CLEOBJ,"~")
 If K
  For [AWS2]AWS1 Where [F]NUMORG=left$([L]CLEOBJ,K-1) & [F]CHRONO>right$([L]CLEOBJ,K+1) & [F]EMAIL<>""
   Read [AWO]AWO0 = [F:AWS2]CHRONO;[F:AWS2]EMAIL
   If !fstat
    K = find([F:AWS2]EMAIL,USR_EMAIL)
    If !K & USR_NB<dim(USR_CODE)
     USR_NB += 1
     USR_CODE(USR_NB)  = [F:AWS2]DEST
     USR_EMAIL(USR_NB) = [F:AWS2]EMAIL
     USR_ENVOI(USR_NB) = 2
     USR_SUIVI(USR_NB) = 1
    Endif
   Endif
  Next AWS2
 Endif
Endif
Raz COND
For I=1 To min(dim([L]COND),[F:AWH]NBDEST)
 COND(I) = 1
 ERN = 0
 If [F:AWH]CNDDES(I-1)<>""
  FORMULE = format$("KTv2:255X",[F:AWH]CNDDES(I-1))
  COND(I) = evalue(FORMULE)
  If ERN : Raz COND(I) : Endif
 Endif
Next I
For I=1 To min(dim([L]COND),[F:AWH]NBDEST)
 If COND(I)<>0
  Raz DEST , EMAIL , DELEG , ERN
  If [F:AWH]DESTIN(I-1)<>""
   FORMULE = format$("KTv2:255X",[F:AWH]DESTIN(I-1))
   CHAINE = evalue(FORMULE)
   If ERN : Raz CHAINE : Endif
   FORMULE = ""
   Case [F:AWH]TYPDES(I-1)
    When 1 : # Utilisateur
     If instr(1,CHAINE,"@")<>0
      EMAIL = CHAINE
      For [AUS2] Where toupper(ADDEML)=toupper(EMAIL)
       DEST = [F:AUS2]USR : Break
      Next AUS2
      Gosub TRT_USER
     Else
      DEST = CHAINE
      For [AUS2] Where USR=DEST
       EMAIL = [F:AUS2]ADDEML : Break
      Next AUS2
      Gosub TRT_USER
     Endif
    When 2 : # Tiers
     If dim([F:CNT]WEB)>0
      If instr(1,CHAINE,"@")<>0
       EMAIL = CHAINE
       If dim([F:CNT]BPATYP)=1 : # tiers
        For [CNT]CNT0 Where BPATYP=1 & CNTFNC=[F:AWH]FNCDES(I-1) & toupper(WEB)=toupper(EMAIL)
         DEST = [F:CNT]BPANUM : Break
        Next CNT
        Gosub TRT_USER
       Else
        For [CNT]CNT0 Where CNTTYP=[F:AWH]TYPDES(I-1) & CNTFNC([F:AWH]FNCDES(I-1)-1)=2 & toupper(WEB)=toupper(EMAIL)
         #CHECK UNUSED_BEGIN
         DEST = [F:CNT]CNTNUM : Break
         #CHECK UNUSED_END
        Next CNT
        Gosub TRT_USER
       Endif
      Else
       DEST = ""
       If dim([F:CNT]BPATYP)=1 : # tiers
        For [CNT]CNT0 Where BPATYP=1 & BPANUM=CHAINE & CNTFNC=[F:AWH]FNCDES(I-1) & WEB<>""
         EMAIL = [F:CNT]WEB : Gosub TRT_USER
        Next
       Else
        #CHECK UNUSED_BEGIN
        For [CNT]CNT0 Where CNTTYP=[F:AWH]TYPDES(I-1) & CNTNUM=CHAINE & CNTFNC([F:AWH]FNCDES(I-1)-1)=2 & WEB<>""
         EMAIL = [F:CNT]WEB : Gosub TRT_USER
        Next
        #CHECK UNUSED_END
       Endif
      Endif
     Endif
    When Default
     ACTION = "USER" : Gosub ACTION
     Gosub TRT_USER
   Endcase
  Endif
 Endif
Next I
Onerrgo
Return

$TRT_USER
If DEST="" & EMAIL<>""
 K = find(EMAIL,USR_EMAIL)
 If K & [F:AWH]ENVOI(I-1)>USR_ENVOI(K)
  USR_ENVOI(K)  = [F:AWH]ENVOI(I-1)
 Elsif !K & USR_NB<dim(USR_EMAIL)
  USR_NB += 1
  USR_EMAIL(USR_NB)  = EMAIL
  If [F:AWA]ENAMES=2
   USR_ENVOI(USR_NB)  = [F:AWH]ENVOI(I-1)
  Endif
  If [F:AWA]ENASUI=2
   USR_SUIVI(USR_NB)  = [F:AWH]SUIVI(I-1)
  Endif
 Endif
Elsif DEST<>""
 If [F:AWH]OPTDEL(I-1)=4 : # Premier de libre
  Filter [AWU2] Where USER=DEST & VLYSTR<=date$ & (VLYEND=[0/0/0] or VLYEND>=date$)
&                   & (NATURE="" or NATURE=[F:AWH]NATURE(I-1))
&                   & TYPDEL=2 : # Pouvoir de signature #X3-46831 : TYPDEL>=2
  Read [AWU2] First
  Filter [AWU2]
  If !fstat
   DELEG = 1 : # mb 10.4.15 bug 107023
   EMAIL = ""
   DEST = [F:AWU2]USRDEL : # Le premier libre avec pouvoir de signature devient destinataire principal
  Endif
 Endif
 TOP  = DEST
 Gosub AJOUT_USR
 If [F:AWH]OPTDEL(I-1)>1
  DELEG = 1
  For [AWU] Where USER=DEST & VLYSTR<=date$ & (VLYEND=[0/0/0] or VLYEND>=date$)
&               & (NATURE="" or NATURE=[F:AWH]NATURE(I-1))
   Case [F:AWU]TYPDEL
    When 1 : # Copie pour info
     EMAIL = ""
     DEST = [F:AWU]USRDEL
     Gosub AJOUT_USR
     If NEWUSR
      USR_ENVOI(USR_NB)  = 3
      USR_SUIVI(USR_NB)  = 1
     Endif
    When 2 : # Pouvoir de signature
     Case [F:AWH]OPTDEL(I-1)
      When 2 : # Tous
       EMAIL = ""
       DEST = [F:AWU]USRDEL
       Gosub AJOUT_USR
      When 3 : # Cascade
       EMAIL = ""
       DEST = [F:AWU]USRDEL
       Gosub AJOUT_USR
       # Recherche récursive des délégués
       Filter [AWU2] Where TYPDEL=2 & VLYSTR<=date$ & (VLYEND=[0/0/0] or VLYEND>=date$) & (NATURE="" or NATURE=[F:AWH]NATURE(I-1))
       Call CASCADE(I,ERD,SIMUL,NEWUSR,DELEG,ERT,USR_NB,TOP,EMAIL,DEST,USR_CODE,USR_TOP,USR_NATURE,USR_EMAIL,USR_DEL,USR_ENVOI,USR_SUIVI)
       Filter [AWU2]
     Endcase
    When 3 : # Exceptionnel (géré dans le suivi)
     # Utilisateur pouvant consulter les suivis à signer des autres utilisateurs (suivant la nature)
   Endcase
  Next AWU
 Endif
Endif
Return

#------------------------------------------------------------------------------------------------------------------------------------#
Subprog CASCADE(I,ERD,SIMUL,NEWUSR,DELEG,ERT,USR_NB,TOP,EMAIL,DEST,USR_CODE,USR_TOP,USR_NATURE,USR_EMAIL,USR_DEL,USR_ENVOI,USR_SUIVI)
Value    Integer I , ERD , SIMUL , NEWUSR , DELEG
Variable Integer USR_NB
Variable Char    TOP , EMAIL , DEST
Variable Char    USR_CODE()(1..) , USR_TOP()(1..) , USR_NATURE()(1..) , USR_EMAIL()(1..)
Variable Integer USR_DEL(1..) , USR_ENVOI(1..) , USR_SUIVI(1..)
Local    Integer K , CURNUM
Local    Char    ERM(250) , DELORG(GLONAUS) , CURUSR(GLONAUS)
DELORG = DEST
Read [AWU2]AWU0 First
While !fstat
 If [F:AWU2]USER=DELORG
  If !find([F:AWU2]USRDEL,USR_CODE(1..USR_NB))
   EMAIL  = ""
   DEST   = [F:AWU2]USRDEL
   CURUSR = [F:AWU2]USER
   CURNUM = [F:AWU2]NUMDEL
   Gosub AJOUT_USR
   Call CASCADE(I,ERD,SIMUL,NEWUSR,DELEG,ERT,USR_NB,TOP,EMAIL,DEST,USR_CODE,USR_TOP,USR_NATURE,USR_EMAIL,USR_DEL,USR_ENVOI,USR_SUIVI)
   Read [AWU2]AWU0=CURUSR;CURNUM
  Elsif ERD
   # Le destinataire $1$ est délégué de $2$ mais il a déjà été référencé
   ERM = func AFNC.MES2(mess(195,75,1),[F:AWU2]USRDEL,DELORG)
   Gosub TRACE_ERR
  Endif
 Endif
 Read [AWU2]AWU0 Next
Wend
End

#------------------------#
$AJOUT_USR
Local Char ACTION(50)
ACTION="AJOUT_USR" : Gosub ACTION : #112752
If EMAIL="" & [F:AWH]TYPDES(I-1)=1 : # Utilisateur (pas Tiers)
 For [AUS2] Where USR=DEST
  EMAIL = [F:AUS2]ADDEML : Break
 Next AUS2
Endif
NEWUSR = 0
K = find(DEST,USR_CODE)
If !K
 If USR_NB<dim(USR_CODE)
  K = find(EMAIL,USR_EMAIL)
  If EMAIL="" or !K
   K = 1
  Else
   If ERD : # mb 1.4.10 En mode trace, on ne regarde pas si l'adresse email est déjà utilisée
    # Mode trace: l'utilisateur $1$ n'a pas été rajouté car son adresse email $2$ est déjà utilisée pour l'utilisateur $3$
    ERM = func AFNC.MES3(mess(194,75,1),DEST,EMAIL,string$(K>0,USR_CODE(K)))
    Gosub TRACE
   Endif
   K = 0
  Endif
 Endif
 If K
  NEWUSR = 1
  USR_NB += 1
  USR_CODE(USR_NB)   = DEST
  USR_TOP(USR_NB)    = TOP
  USR_DEL(USR_NB)    = DELEG+1
  USR_NATURE(USR_NB) = [F:AWH]NATURE(I-1)
  If [F:AWA]ENAMES=2 & EMAIL<>""
   USR_EMAIL(USR_NB)  = EMAIL
   USR_ENVOI(USR_NB)  = [F:AWH]ENVOI(I-1)
  Endif
  If [F:AWA]ENASUI=2
   USR_SUIVI(USR_NB)  = [F:AWH]SUIVI(I-1)
  Endif
 Endif
Elsif K
 If [F:AWH]ENVOI(I-1)<>USR_ENVOI(K) & [F:AWA]ENAMES=2
  # Permet de mettre en destinataire principal un utilisateur qui est en copie
  Case USR_ENVOI(K)
   When 1 : # Non
    USR_ENVOI(K) = [F:AWH]ENVOI(I-1)
   When 3 : # Copie
    If [F:AWH]ENVOI(I-1)=2 : USR_ENVOI(K) = 2 : Endif : # Oui/Principal
  Endcase
 Endif
 If [F:AWH]SUIVI(I-1)>USR_SUIVI(K) & [F:AWA]ENASUI=2
  USR_SUIVI(K) = max(USR_SUIVI(K),[F:AWH]SUIVI(I-1))
 Endif
Endif
Return

#----------------------------------------------------------------------#
$TRT_TEXTE
Raz TEXCLB , TEXOBJ
Raz FORMULE , ERN
ERT = 6
Gosub SET_SEP From SUBAWA
Onerrgo ERR
TEXCLB = [F:AWA]TEXTE
I = 1 : C = 0
While TEXCLB<>""
 D = instr(I,TEXCLB,SEP)
 If D
  F = instr(D+1,TEXCLB,SEP)
  If !F
   ERM = mess(116,75,1) : # Séparateurs mal définis dans le texte
   ERN = 1 : Gosub TRACE_ERR : Break
  Endif
  FORMULE = format$("KTv2:255X",seg$(TEXCLB,D+1,F-1))
  TEXTMP = ""
  If toupper(left$(FORMULE,4))="CLB/" : # Clob
   If right$(FORMULE,5)<>""
    TEXTMP = num$(evalue(right$(FORMULE,5)))
   Endif
  Elsif toupper(FORMULE)="LIG" : # Emplacement du tableau des lignes
   TEXTMP = TEXLIG
  Elsif toupper(left$(FORMULE,4))="SIG/" : # Emplacement lien http pour signature directe
   # Avant : SIG/code action/Formule texte à évaluer
   # Après : SIG/code action/Chrono/Texte à mettre devant le lien http
   K = instr(1,FORMULE,"/")
   K = instr(K+1,FORMULE,"/")
   If K
    If right$(FORMULE,K+1)<>""
     If evalue(right$(FORMULE,K+1))<>""
      TEXTMP = SEP+left$(FORMULE,K)+[L]CHRONO+"/"+evalue(right$(FORMULE,K+1))+SEP
     Endif
    Else
     TEXTMP = SEP+left$(FORMULE,K)+[L]CHRONO+"/"+SEP
    Endif
   Endif
  Elsif FORMULE<>""
   TEXTMP = num$(evalue(FORMULE))
  Endif
  TEXCLB = left$(TEXCLB,D-1)+TEXTMP+right$(TEXCLB,F+1)
  I = D+len(TEXTMP)
 Else
  Break
 Endif
Wend
ERN = 0
If [F:AWA]OBJET<>""
 FORMULE = format$("KTv2:255X",[F:AWA]OBJET)
 TEXOBJ = evalue(FORMULE)
 If ERN : Raz TEXOBJ : Endif
Endif
Onerrgo
Return

#----------------------------------------------------------------------#
$TRT_PIECE
Raz PCEJOI , NBJOI , OBJJOI , CLEJOI
Raz FORMULE , ERN
ERT = 7
Onerrgo ERR
If [F:AWA]JOINT<>"" : # Fichier joint au paramètrage workflow
 FORMULE = format$("KTv2:255X",[F:AWA]JOINT)
 RESULT = evalue(FORMULE)
 If !ERN
  While RESULT<>""
   I = instr(1,RESULT,";")
   If I
    CHAINE = left$(RESULT,I-1)
    RESULT = right$(RESULT,I+1)
   Else
    CHAINE = RESULT
    RESULT = ""
   Endif
   If instr(1,CHAINE,"#") or instr(1,CHAINE,"~~")
    I = func TRTFIC(CHAINE,NBJOI,PCEJOI)
   Else
    NBJOI += 1
    PCEJOI(NBJOI) = CHAINE
   Endif
  Wend
 Endif
Endif
If [F:AWA]TRACE=2 : # Trace (de la requête par exemple)
 If max(instr(1,NUMTRA,"/"),instr(1,NUMTRA,"\"),instr(1,NUMTRA,"@"))
  CHAINE = NUMTRA
 Else
  CHAINE = filpath("TRA",NUMTRA,"tra")
 Endif
 If CHAINE<>"" & filinfo(CHAINE,0)<0 : # CCL 114350
  CHAINE = filpath("TRA",NUMTRA,"tra")
 Endif
 If CHAINE<>"" & filinfo(CHAINE,0)>0
  NBJOI += 1
  PCEJOI(NBJOI) = CHAINE
 Endif
Endif
If [F:AWA]JOIOBJ=2 : # Pièces jointes à l'objet
 OBJJOI = CODEVT
 CLEJOI = CLEOBJ
 If [F:AWA]TYPEVT=9
  CLEJOI = S_CLEOBJ
  OBJJOI = S_ABREV
 Endif
Endif
Onerrgo
Return

#----------------------------------------------------#
Funprog TRTFIC(CHAINE,NBJOI,PCEJOI)
Value    Char    CHAINE
Variable Integer NBJOI
Variable Char    PCEJOI()(1..)
Local Char    REP(GDIMFIC) , MAC(GLONAMC) , FIC(GDIMFIC)
Local Char    ORDRE(250) , SEP(1) , VOL(20)
Local Integer I , J
CHAINE = func ASYRSYS._GETFULLPATH(CHAINE)
If instr(1,CHAINE,"/")
 SEP = "/"
Elsif instr(1,CHAINE,"\")
 SEP = "\"
Else
 Case GOS(0)
  When "unix"  : SEP = "/"
  When Default : SEP = "\"
 Endcase
Endif
Call MACHINE(CHAINE,MAC,FIC) From ORDSYS
I = instr(1,FIC,'~~')
If I
 J = instr(I+2,FIC,'~~')
 If I & J
  REP = left$(FIC,I-1)
  If !instr(1,REP,SEP)
   REP = filpath(REP,"","")
  Endif
  FIC = seg$(CHAINE,I+2,J-1)+"*."+right$(CHAINE,J+2)
 Endif
Else
 I = instr(1,FIC,'#')
 If I
  FIC = ctrans(func SETFIC(FIC,REP),"#","*")
 Endif
Endif
ORDRE = MAC+'@lsadx -a '+nomap-'"'+REP+'"'-'"'+FIC+'"'
Local File (PJ(GLONADC)) From System ORDRE As [PJ_]
For [PJ_]
 If NBJOI<dim(PCEJOI)
  NBJOI += 1
  If MAC<>""
   PCEJOI(NBJOI) = MAC+"@"
  Else
   PCEJOI(NBJOI) = ""
  Endif
  PCEJOI(NBJOI) += REP+SEP+[F:PJ_]PJ
 Endif
Next PJ_
Close Local File [PJ_]
End NBJOI

#--------------------------------------#
Funprog SETFIC(CHEMIN,REP)
Value Char CHEMIN
Variable Char REP
Local Integer I
Local Char    FIC(250)
FIC = CHEMIN
I = max(instr(1,FIC,"/"),instr(1,FIC,"\"))
If I=0
 REP = ""
Else
 While I
  FIC = right$(FIC,I+1)
  I = max(instr(1,FIC,"/"),instr(1,FIC,"\"))
 Wend
 REP = left$(CHEMIN,len(CHEMIN)-len(FIC)-1)
Endif
End FIC

#----------------------------------------------------------------------#
$TRT_CONTXT
Raz CONTXT
Raz FORMULE , ERN
If [F:AWA]RETOUR<>2 : # Icône retour
 Return
Endif

#111371
# X3PLAT-1475 Workflow link on representation-start
#If [F:AWS2]CONTXT<>"" | [F:AWS2]CONTXTDSKTOP<>"" | [F:AWS2]CONTXTMOBILE<>""
# CONTXT=[F:AWS2]CONTXT
# Return
#Endif
## X3PLAT-1475 Workflow link on representation-end
ERT = 8
Onerrgo ERR
If GFONCTION<>""
 If GPRODUIT=1 : # Géode
  CONTXT = GFCY+"~"+GDEP+"/"
 Endif
 If [F:AWA]BAKFCT<>"" : # Fonction de retour
  CONTXT += [F:AWA]BAKFCT
  CONTXT += "/"+num$([F:AWA]BAKMEN)
  If [F:AWA]BAKLNK<>"" : # Liens sur fonction de retour
   If left$([F:AWA]BAKFCT,3)="GES" & len([F:AWA]BAKFCT)=6
    CONTXT += "/OBJ"+right$([F:AWA]BAKFCT,4)
   Else
    CONTXT += "/"+[F:AWA]BAKFCT
   Endif
   #CONTXT += "/"+OPERAT
   CONTXT += "/M" : # mb 25.2.14 bug 97162
   Raz CLE , NBCLE
   CHAINE = [F:AWA]BAKLNK
   If CHAINE=""
    CHAINE = CLEOBJ
   Endif
   While CHAINE<>""
    NBCLE += 1
    K = instr(1,CHAINE,";")
    If K
     FORMULE = left$(CHAINE,K-1)
     CLE(NBCLE) = num$(evalue(FORMULE))
     CHAINE     = right$(CHAINE,K+1)
    Else
     FORMULE = CHAINE
     CLE(NBCLE) = num$(evalue(FORMULE))
     CHAINE     = ""
    Endif
    FORMULE = ""
   Wend
   If left$([F:AWA]BAKFCT,3)="GES" & len([F:AWA]BAKFCT)=6
    If NBCLE<2
     CHAINE = CLE(1)
    Else
     CHAINE = CLE(2)+"~"+CLE(1)
     If NBCLE>2
      CHAINE += sigma(I=3,NBCLE,"~"+CLE(I))
     Endif
    Endif
   Else
    CHAINE = CLE(1)
    For K=2 To NBCLE
     CHAINE += "~"+CLE(K)
    Next K
   Endif
   CONTXT += "/"+CHAINE
  Else
   CONTXT += "///"
  Endif
  Gosub TRT_CONTXT_SYRA              # X3PLAT-1475 Workflow link on=epresentationwrite
 Else
  CHAINE = CLEOBJ
  If GPRODUIT=1 : # Géode
   If [L]TYPEVT=2 & [L]CODEVT<>""
    Call CNVKEY([L]CODEVT,CHAINE) From CONTOBJ
   Elsif GFONCTION="GES"+GABREV
    Call CNVKEY(GABREV,CHAINE) From CONTOBJ
   Endif
  Endif
  Gosub TRT_CONTXT_SYRA              # X3PLAT-1475 Workflow link on=epresentationwrite
  If CONTXT="" & [L]CONTXT_DESKTOP="" & [L]CONTXT_MOBILE=""      # X3PLAT-1475 Workflow link on representation - do not default CONTXT if representations specified
    CONTXT += GFONCTION
    CONTXT += "/"+num$([F:AWA]BAKMEN)
    CONTXT += "/"+[L]CODEVT
    #CONTXT += "/"+OPERAT
    CONTXT += "/M" : # mb 25.2.14 bug 97162
    CONTXT += "/"+CHAINE
  Endif
 Endif
#X3-45543: We have to call this function to be be certain to have a link with last values
Else
  CONTXT=[F:AWS2]CONTXT :#X3-49868
  Gosub TRT_CONTXT_SYRA
#X3-45543
Endif
Onerrgo
Return

# X3PLAT-1475 Workflow link on representation - start
# Set the url for both desktop and mobile
$TRT_CONTXT_SYRA
 #TODO: how to handle geode
If [F:AWA]RETOUR<>2 : # Icône retour
 Return
Endif

Local Char TABKEY(50)(1..10),TABKEYVAL(50)(1..10),TABPAR(50)(1..10),TABPARVAL(250)(1..10)
Local Integer ASTATUS
Local Clbfile WURL

Raz CLE, NBCLE, FORMULE, ERN, CONTXT_DESKTOP, CONTXT_MOBILE

# Set desktop contxt
If [F:AWA]BAKSYRA<>""
  CHAINE = [F:AWA]BAKLNKSYRA
  ERT = 8
  Onerrgo ERR
     While CHAINE<>""
      NBCLE += 1
      K = instr(1,CHAINE,";")
      If K
       TABKEY(NBCLE) = left$(CHAINE,K-1)
       If TABKEY(NBCLE)="[L]DEST"
        TABKEY(NBCLE) = "DEST"
        TABKEYVAL(NBCLE) = '[L]DEST'
       Else
        TABKEYVAL(NBCLE) = num$(evalue(TABKEY(NBCLE)))
       Endif
       CHAINE     = right$(CHAINE,K+1)
      Else
       TABKEY(NBCLE) = CHAINE
       If TABKEY(NBCLE)="[L]DEST"
        TABKEY(NBCLE) = "DEST"
        TABKEYVAL(NBCLE) = '[L]DEST'
       Else
        TABKEYVAL(NBCLE) = num$(evalue(TABKEY(NBCLE)))
       Endif
       CHAINE     = ""
      Endif
     Wend
   Onerrgo
  #Build the url
  ASTATUS = func ASYRFNC.AGET_SYRAURL(GACTX,[V]CST_ATRUE,[F:AWA]BAKSYRA,1,TABKEY,TABKEYVAL,TABPAR,TABPARVAL,WURL)
  If [L]ASTATUS <> [V]CST_AOK
    GMESSAGE = mess(862,9137,1)
    mkstat=1
    Return
  Endif
  CONTXT_DESKTOP=WURL
Endif

# Set mobile contxt
If [F:AWA]BAKMOBILE<>""
  #X3-45543 : Optimization: Not useless to fill tabkey and tabkeyval if keys are the same.
  If [F:AWA]BAKLNKMOBILE<>[F:AWA]BAKLNKSYRA
    Raz NBCLE, TABKEY, TABKEYVAL
  #X3-45543
    CHAINE = [F:AWA]BAKLNKMOBILE
    ERT = 8
    Onerrgo ERR
      While CHAINE<>""
        NBCLE += 1
        K = instr(1,CHAINE,";")
        If K
         TABKEY(NBCLE) = left$(CHAINE,K-1)
         If TABKEY(NBCLE)="[L]DEST"
          TABKEY(NBCLE) = "DEST"
          TABKEYVAL(NBCLE) = '[L]DEST'
         Else
          TABKEYVAL(NBCLE) = num$(evalue(TABKEY(NBCLE)))
         Endif
         CHAINE     = right$(CHAINE,K+1)
        Else
         TABKEY(NBCLE) = CHAINE
         If TABKEY(NBCLE)="[L]DEST"
          TABKEY(NBCLE) = "DEST"
          TABKEYVAL(NBCLE) = '[L]DEST'
         Else
          TABKEYVAL(NBCLE) = num$(evalue(TABKEY(NBCLE)))
         Endif
         CHAINE     = ""
        Endif
      Wend
    Onerrgo
  Endif :#X3-45543
#SAM 121201
  #Build the url
  #ASTATUS = func ASYRFNC.AGET_SYRAURL(GACTX,[V]CST_ATRUE,[F:AWA]BAKMOBILE,1,TABKEY,TABKEYVAL,TABPAR,TABPARVAL,WURL)
  ASTATUS = func ASYRFNC.AGET_SYRAURLMOB(GACTX,[V]CST_ATRUE,[F:AWA]BAKMOBILE,1,TABKEY,TABKEYVAL,TABPAR,TABPARVAL,WURL)
  If [L]ASTATUS <> [V]CST_AOK
    GMESSAGE = mess(862,9137,1)
    mkstat=1
    Return
  Endif
  CONTXT_MOBILE=WURL
Endif
Return

# X3PLAT-1475 Workflow link on representation - end
#----------------------------------------------------------------------#
$TRT_MAIL

# Accusé de réception
REQREC = [F:AWA]REQREC

# Importance du message
Raz FORMULE , ERN
REQIMP = 2 : # Normal
ERT = 15
Onerrgo ERR
If dim([F:AWA]FORIMP)>0 & [F:AWA]FORIMP<>""
 FORMULE = format$("KTv2:255X",[F:AWA]FORIMP)
 CHAINE = num$(evalue(FORMULE))
 If ERN : GOK = 1 : Endif : # C'est pas important
 If !ERN & val(CHAINE)>=1 & val(CHAINE)<=3
  REQIMP = val(CHAINE)
 Endif
Endif

If [F:AWA]INTERV=2 & !GSERVEUR & !SIMUL & !GIMPORT
 # Modification manuelle du message
 Local Mask AWAX [AWAY]
 [M:AWAY]TEXTE = TEXCLB
 [M:AWAY]TEXOBJ = TEXOBJ
 For I=1 To USR_NB
  Case USR_ENVOI(I)
   When 2
    [M:AWAY]NBDEST += 1
    [M:AWAY]DEST([M:AWAY]NBDEST-1) = USR_EMAIL(I)
    If USR_CODE(I)<>"" : [M:AWAY]DEST([M:AWAY]NBDEST-1) -= "("+USR_CODE(I)+")" : Endif
   When 3
    [M:AWAY]NBCOP += 1
    [M:AWAY]COP([M:AWAY]NBCOP-1) = USR_EMAIL(I)
    If USR_CODE(I)<>"" : [M:AWAY]COP([M:AWAY]NBCOP-1) -= "("+USR_CODE(I)+")" : Endif
  Endcase
 Next I
 If dim([M:AWAY]REQIMP)>0 : [M:AWAY]REQIMP = REQIMP : Endif
 [M:AWAY]REQREC = REQREC
 [M:AWAY]TYPMES = [F:AWA]TYPMES
 Local Char VALWRK(10) , PARWRK(10)(1..2) , SPEWRK(GLONADC)
 VALWRK = [F:AWA]CODE
 Call TRTSPE(nomap,"SAIWRKMES",SPEWRK) From SUBACT
 Call SAISIE_CHAR(VALWRK,PARWRK,"SAIWRKMES","SAIWRKMES",SPEWRK) From GSAISIE
 If !find(GSTATUT,GSTAOK,GSTARET) : # La touche FIN indique qu'on ne veut pas envoyer de message
  Close Local Mask [AWAY]
  Return
 Endif
 TEXCLB = [M:AWAY]TEXTE
 TEXOBJ = [M:AWAY]TEXOBJ
 Raz USR_ENVOI
 For I=1 To [M:AWAY]NBDEST
  CHAINE = [M:AWAY]DEST(I-1)
  K = instr(1,CHAINE," (")
  If K : CHAINE = left$(CHAINE,K-1) : Endif
  CHAINE = vireblc(CHAINE,2)
  If CHAINE<>""
   K = find(CHAINE,USR_EMAIL)
   If K
    USR_ENVOI(K) = 2
   Else
    USR_NB += 1
    USR_EMAIL(USR_NB) = CHAINE
    USR_ENVOI(USR_NB) = 2
   Endif
  Endif
 Next I
 For I=1 To [M:AWAY]NBCOP
  CHAINE = [M:AWAY]COP(I-1)
  K = instr(1,CHAINE," (")
  If K : CHAINE = left$(CHAINE,K-1) : Endif
  CHAINE = vireblc(CHAINE,2)
  If CHAINE<>""
   K = find(CHAINE,USR_EMAIL)
   If K
    USR_ENVOI(K) = 3
   Else
    USR_NB += 1
    USR_EMAIL(USR_NB) = CHAINE
    USR_ENVOI(USR_NB) = 3
   Endif
  Endif
 Next I
 If dim([M:AWAY]REQIMP)>0 : REQIMP = [M:AWAY]REQIMP : Endif
 REQREC = [M:AWAY]REQREC
 Close Local Mask [AWAY]
Endif

GPE = 0
GPOINT = "MESSAGE" : Gosub ENTREE From EXEFNC
If GPE : Return : Endif

# Historisation message
If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR1
Else
 Gosub HISTO_MES
Endif
If GOK<1 : Return : Endif

# Envoi du mail
If !GRPENV & !DIFFERE
# X3PLAT-1475 Workflow link on representation-start
# Call ENVOI_MAIL([F:AWA]TYPMES,REQREC,REQIMP,USRWRK,MAIWRK,OBJJOI,CLEJOI,CHRONO,ERD
#&               ,USR_EMAIL,USR_ENVOI,USR_SUIVI,USR_NB,TEXCLB,TEXOBJ
#&               ,PCEJOI,NBJOI,[F:AWA]TYPJOI,[F:AWA]CATJOI,CONTXT) From AWRKMEL
 Call ENVOI_MAIL_SYRA([F:AWA]TYPMES,REQREC,REQIMP,USRWRK,MAIWRK,OBJJOI,CLEJOI,CHRONO,ERD
&               ,USR_EMAIL,USR_CODE,USR_ENVOI,USR_SUIVI,USR_NB,TEXCLB,TEXOBJ
&               ,PCEJOI,NBJOI,[F:AWA]TYPJOI,[F:AWA]CATJOI,CONTXT
&               ,CONTXT_DESKTOP,CONTXT_MOBILE) From AWRKMEL               # X3PLAT-1475 Workflow link on representation
Endif
Return

#--------------#
$TR1
Trbegin [AWG] , [AWO] , [AWJ]
 Gosub HISTO_MES
 If GOK=0 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

#--------------#
$HISTO_MES
Raz [F:AWG]
[F:AWG]CHRONO = [L]CHRONO
[F:AWG]NUMGRP = [L]NUMGRP
[F:AWG]REFGRP = [L]GRPDEB
[F:AWG]DATENV = date$
[F:AWG]TIMENV = left$(time$,2)+mid$(time$,4,2)+right$(time$,7)
[F:AWG]DEBUG  = [F:AWA]DEBUG
If !GRPENV & !DIFFERE
 [F:AWG]FLGENV  = 2 : # Message envoyé
Else
 [F:AWG]FLGENV  = 1
Endif
If dim([F:AWG]GRPENV)>0
 [F:AWG]GRPENV = GRPENV+1
Endif
[F:AWG]OBJET  = TEXOBJ
[F:AWG]TEXTE  = TEXCLB
[F:AWG]OBJJOI = [L]OBJJOI
[F:AWG]TYPJOI = [F:AWA]TYPJOI
[F:AWG]CATJOI = [F:AWA]CATJOI
[F:AWG]CLEOBJ = [L]CLEJOI
[F:AWG]REQREC = max(1,[L]REQREC)
If dim([F:AWG]REQIMP)>0
 [F:AWG]REQIMP = max(1,[L]REQIMP)
Endif
[F:AWG]USER   = USRWRK
[F:AWG]MAIL   = MAIWRK
[F:AWG]TYPMES = [F:AWA]TYPMES

If [F:AWA]RETOUR=2
 [F:AWG]CONTXT = [L]CONTXT                             # X3PLAT-1475 Workflow link on representation
 [F:AWG]CONTXTDSKTOP = [L]CONTXT_DESKTOP               # X3PLAT-1475 Workflow link on representation
 [F:AWG]CONTXTMOBILE = [L]CONTXT_MOBILE                # X3PLAT-1475 Workflow link on representation
Endif
Write [AWG]
If fstat
 GOK=0 : Call FSTA("AWG") From GLOCK : Return
Endif
For I=1 To USR_NB
 If find(USR_ENVOI(I),2,3) : # Oui/Copie
  Raz [F:AWO]
  [F:AWO]CHRONO = [L]CHRONO
  [F:AWO]EMAIL  = USR_EMAIL(I)
  [F:AWO]USER   = USR_CODE(I)
  [F:AWO]ENVOI  = USR_ENVOI(I)-1
  [F:AWO]SUIVI  = USR_SUIVI(I)
  Write [AWO]
  If fstat
   GOK=0 : Call FSTA("AWO") From GLOCK : Break
  Endif
 Endif
Next I
If GOK=0 : Return : Endif
For I=1 To NBJOI
 If PCEJOI(I)<>""
  Raz [F:AWJ]
  [F:AWJ]CHRONO = [L]CHRONO
  [F:AWJ]JOINUM = I
  [F:AWJ]JOINAM = PCEJOI(I)
  Write [AWJ]
  If fstat
   GOK=0 : Call FSTA("AWJ") From GLOCK : Break
  Endif
 Endif
Next I
Return

#----------------------------------------------------------------------#
$TRT_SUIVI
# Historisation suivi
If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR2
Else
 Gosub HISTO_SUIVI
Endif
Return

#--------------#
$TR2
Trbegin [AWS2]
 Gosub HISTO_SUIVI
 If GOK=0 : Goto AB_TR2 : Endif
Commit
Return

$AB_TR2
Rollback
Return

#--------------#
$HISTO_SUIVI
For I=1 To USR_NB
 If USR_SUIVI(I)>1
  Raz FORMULE , ERN
  ERT = 9
  Onerrgo ERR
  Raz [F:AWS2]
  [F:AWS2]CHRONO    = [L]CHRONO
  [F:AWS2]DEST      = USR_CODE(I)
  [F:AWS2]EMAIL     = USR_EMAIL(I)
  [F:AWS2]NUMGRP    = [L]NUMGRP
  [F:AWS2]CPY       = [L]SOCIETE
  [F:AWS2]DELEGUE   = USR_DEL(I)
  [F:AWS2]ENVOI     = USR_ENVOI(I)
  [F:AWS2]EMETTEUR  = USRWRK
  [F:AWS2]MAIENV    = MAIWRK
  [F:AWS2]DATENV    = date$
  [F:AWS2]TIMENV    = left$(time$,2)+mid$(time$,4,2)+right$(time$,7)
  [F:AWS2]NATURE    = USR_NATURE(I)
  If [F:AWF]TEXSUI<>""
   FORMULE = format$("KTv2:255X",[F:AWF]TEXSUI)
   [F:AWS2]TEXSUI   = evalue(FORMULE)
   If ERN : Raz [F:AWS2]TEXSUI : Endif
  Endif
  [F:AWS2]TYPEVT    = [L]TYPEVT
  [F:AWS2]CODEVT    = [L]CODEVT
  [F:AWS2]CODWRK    = [F:AWA]CODE
  [F:AWS2]OPERATION = OPERAT
  [F:AWS2]CLEOBJ    = CLEOBJ
  [F:AWS2]CONTXT    = CONTXT : # Icône retour
  [F:AWS2]CONTXTDSKTOP = CONTXT_DESKTOP    # X3PLAT-1475 Workflow link on representation
  [F:AWS2]CONTXTMOBILE = CONTXT_MOBILE     # X3PLAT-1475 Workflow link on representation
  ERN = 0
  If [F:AWF]DELSIG<>""
   FORMULE = [F:AWF]DELSIG
   [F:AWS2]DATMAXSIG = evalue(FORMULE)
  Endif
  If [F:AWF]DELSIG="" | ERN
   [F:AWS2]DATMAXSIG = date$
  Endif
  [F:AWS2]FLGSIG = USR_SUIVI(I) : # A viser , A signer
  [F:AWS2]USRTOP = USR_TOP(I) : # Utilisateur principal par opposition avec délégués
  If [F:AWA]TYPEVT=9 : # Signature
   If NUMORG<>"" : # Chrono du premier workflow
    [F:AWS2]NUMORG = NUMORG
    [F:AWS2]USRORG = USRORG
   Else : # Chrono signé
    [F:AWS2]NUMORG = NUMSIG
    [F:AWS2]USRORG = USRDES
   Endif
   [F:AWS2]LEVSIG = LEVSIG : # Numéro de signature
   [F:AWS2]ABROBJ = S_ABREV
  Elsif [F:AWA]TYPEVT=2
   [F:AWS2]ABROBJ = GABREV
  Endif
  [F:AWS2]NBRUSR = [L]NBRUSR
  For J=1 To [L]NBRUSR
   If evalue("dim([F:AWS2]USRSIG"+num$(J)+")")>0
    Assign "[F:AWS2]USRSIG"+num$(J) With [L]USER(J)
   Endif
  Next J
  Gosub LNKREF From =NOMPROG
  [F:AWS2]IDENTREF  = LNKREF : # Identifiant table déclenchante
  If CLEREF<>""
   [F:AWS2]IDENTREF += "/"+evalue(CLEREF)
  Endif
  If [F:AWA]RETOUR=2
   If [F:AWA]TYPEVT=9
    [F:AWS2]IDENTRET = RETORG
   Elsif [F:AWA]BAKLNK<>""
    Gosub LNKRET From =NOMPROG
    [F:AWS2]IDENTRET  = FCTRET : # Identifiant retour
    If CLERET<>""
     [F:AWS2]IDENTRET += "/"+evalue(CLERET)
    Endif
   Else
    [F:AWS2]IDENTRET  = GFONCTION
    If CLEOBJ<>""
     [F:AWS2]IDENTRET += "/"+CLEOBJ
    Endif
   Endif
  Endif
  [F:AWS2]IDENTGRP  = TABGRP : # Identifiant groupe
  If CLEGRP<>""
   [F:AWS2]IDENTGRP += "/"+evalue(CLEGRP)
  Endif
  [F:AWS2]CLEDEC = S_CLEOBJ
  For J=1 To dim([F:AWF]VARCTX)
   Assign "[F:AWS2]VALCTX"+num$(J) With CTX(J)
  Next J

  GPOINT = "MODAWS" : Gosub ENTREE From EXEFNC

  Onerrgo
  Write [AWS2]
  If fstat
   GOK=0 : Call FSTA("AWS2") From GLOCK : Break
  Endif
 Endif
Next I
Return

#----------------------------------------------------------------------#
$ACTION
Call EXISTE_ADX("","","AWRKB",K) From ORDSYS
If K>0 : Gosub ACTION From AWRKB : Endif
Return

#----------------------------------------------------------------------#
Subprog ENVOI_GROUPE(GRPDEB)
Value Char    GRPDEB
Local Integer I , J , K , OK
Local Integer NBJOI , USR_NB
Local Integer ERD , TRACE

Gosub SET_DIM
Local Char    USR_EMAIL(GLONMAI)(1..DIMUSR),USR_CODE(GLONAUS)(1..DIMUSR)
Local Integer USR_ENVOI(1..DIMUSR) , USR_SUIVI(1..DIMUSR) , REQIMP
Local Clbfile TEXCLB(DIMCLB) , TEXTMP(DIMCLB)
Local Char    PCEJOI(200)(1..DIMJOI)

If GRPDEB="" : End : Endif

If clalev([F:AWG])=0  : Local File AWRKHISMES [AWG]  : Endif
If clalev([F:AWG2])=0 : Local File AWRKHISMES [AWG2] : Endif
If clalev([F:AWO])=0  : Local File AWRKHISDES [AWO]  : Endif
If clalev([F:AWJ])=0  : Local File AWRKHISJOI [AWJ]  : Endif

Filter [AWG] Where REFGRP=GRPDEB
Read [AWG]AWG1 First

While !fstat
 If [F:AWG]FLGENV=1
  If !adxlog
   Call DEBTRANS From GLOCK
   Gosub TR3
  Else
   Gosub GRPMES
  Endif
  If GOK<1 : Break : Endif
  If [F:AWG]DEBUG=2
   ERD = 1
   If !TRACE & !GIMPORT & !GSERVEUR & GTRACE=""
    Call OUVRE_TRACE(mess(68,75,1)-GRPDEB) From LECFIC
    TRACE = 1
   Endif
  Endif
# X3PLAT-1475 Workflow link on representation - start
#  Call ENVOI_MAIL([F:AWG]TYPMES,[F:AWG]REQREC,REQIMP,[F:AWG]USER,[F:AWG]MAIL,[F:AWG]OBJJOI,[F:AWG]CLEOBJ
#&                ,[F:AWG]CHRONO,ERD,USR_EMAIL,USR_ENVOI,USR_SUIVI,USR_NB,TEXCLB,[F:AWG]OBJET
#&                ,PCEJOI,NBJOI,[F:AWG]TYPJOI,[F:AWG]CATJOI,[F:AWG]CONTXT) From AWRKMEL
  Call ENVOI_MAIL_SYRA([F:AWG]TYPMES,[F:AWG]REQREC,REQIMP,[F:AWG]USER,[F:AWG]MAIL,[F:AWG]OBJJOI,[F:AWG]CLEOBJ
&                ,[F:AWG]CHRONO,ERD,USR_EMAIL,USR_CODE,USR_ENVOI,USR_SUIVI,USR_NB,TEXCLB,[F:AWG]OBJET
&                ,PCEJOI,NBJOI,[F:AWG]TYPJOI,[F:AWG]CATJOI,[F:AWG]CONTXT
&                ,[F:AWG]CONTXTDSKTOP,[F:AWG]CONTXTMOBILE) From AWRKMEL
# X3PLAT-1475 Workflow link on representation - end
 Endif
 Read [AWG]AWG1 Next
Wend

Filter [AWG]

If TRACE
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End

#--------------------------#
$TR3
Trbegin [AWG2]
 Gosub GRPMES
 If GOK=-1 : Gosub ROLL_TR3
 Elsif GOK=0 : Goto AB_TR3
 Endif
Commit
Return

$AB_TR3
Rollback
Return

$ROLL_TR3
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR3 : Endif

#--------------------------#
$GRPMES
# Chargement des destinataires
Raz USR_NB , USR_EMAIL, USR_ENVOI
For [AWO] Where CHRONO=[F:AWG]CHRONO
 USR_NB += 1
 USR_EMAIL(USR_NB) = [F:AWO]EMAIL
 USR_CODE(USR_NB) = [F:AWO]USER
 USR_ENVOI(USR_NB) = [F:AWO]ENVOI+1
 USR_SUIVI(USR_NB) = [F:AWO]SUIVI
Next AWO
# Texte
TEXCLB = [F:AWG]TEXTE
# Pièce jointe
Raz PCEJOI , NBJOI
For [AWJ] Where CHRONO=[F:AWG]CHRONO
 NBJOI += 1
 PCEJOI(NBJOI) = [F:AWJ]JOINAM
Next AWJ
# Importance du message
If dim([F:AWG]REQIMP)<=0
 REQIMP = 2 : # Normal
Else
 REQIMP = [F:AWG]REQIMP
Endif

#-----------------------------------------------------------------------------------#
# Recherche des messages avec les mêmes caractéristiques
#-----------------------------------------------------------------------------------#
# - émetteur
# - type de serveur
# - contexte de retour
# - objet du message (sujet)
# - accusé de réception
# - destinataires
# - flags signataires
#-----------------------------------------------------------------------------------#

For [AWG2]AWG1 Where REFGRP=[F:AWG]REFGRP & CHRONO<>[F:AWG]CHRONO
&                  & USER=[F:AWG]USER & TYPMES=[F:AWG]TYPMES & CONTXT=[F:AWG]CONTXT
&                  & OBJET=[F:AWG]OBJET & REQREC=[F:AWG]REQREC
&                  & CONTXTDSKTOP=[F:AWG]CONTXTDSKTOP & CONTXTMOBILE=[F:AWG]CONTXTMOBILE    # X3PLAT-1475 Workflow link on representation
 If [F:AWG2]FLGENV=1 & (dim([F:AWG2]GRPENV)<0 or [F:AWG2]GRPENV=2)
  OK = 1
  For I=1 To USR_NB
   Read [AWO]AWO0 = [F:AWG2]CHRONO;USR_EMAIL(I)
   If fstat | [F:AWO]ENVOI+1<>USR_ENVOI(I)
    OK = 0 : Break
   Endif
  Next I
  If OK
   For [AWO] Where CHRONO=[F:AWG2]CHRONO
    If !find([F:AWO]EMAIL,USR_EMAIL(1..USR_NB))
     OK = 0 : Break
    Endif
   Next AWO
  Endif
  If OK
   If dim([F:AWG2]REQIMP)>0
    REQIMP = max(REQIMP,[F:AWG2]REQIMP)
   Endif
   TEXTMP = [F:AWG2]TEXTE
   If len(TEXTMP)+len(TEXCLB)<=1024*2^DIMCLB
    # Mise à jour flag envoyé
    Gosub MAJFLG_LIN
    If GOK<1 : Break : Endif
    # Fusion du texte
    Append TEXCLB,TEXTMP
   Endif
   # Fusion des pièces jointes
   For [AWJ] Where CHRONO=[F:AWG2]CHRONO
    If !find([F:AWJ]JOINAM,PCEJOI) & NBJOI<dim(PCEJOI)
     NBJOI += 1
     PCEJOI(NBJOI) = [F:AWJ]JOINAM
    Endif
   Next AWJ
  Endif
 Endif
Next AWG2
Gosub MAJFLG_GRP : # Mise à jour flag envoyé
Return

#-------------------#
$MAJFLG_LIN
Readlock [AWG2]AWG0 Curr
If fstat=1
 GOK=-1 : GLOCK="$AWRKHISMES" : Return
Elsif fstat
 GOK=0 : Call FSTA("AWG2") From GLOCK : Return
Endif
[F:AWG2]FLGENV = 2
Rewrite [AWG2]
If fstat
 GOK=0 : Call FSTA("AWG2") From GLOCK : Return
Endif
Return

#-------------------#
$MAJFLG_GRP
Readlock [AWG]AWG0 Curr
If fstat=1
 GOK=-1 : GLOCK="$AWRKHISMES" : Return
Elsif fstat
 GOK=0 : Call FSTA("AWG") From GLOCK : Return
Endif
[F:AWG]FLGENV = 2
Rewrite [AWG]
If fstat
 GOK=0 : Call FSTA("AWG") From GLOCK : Return
Endif
Return

#----------------------------------------------------------------------#
# Utilisé dans le cas d'une modication d'objet avortée
#----------------------------------------------------------------------#

Subprog VIRE_GROUPE(GRPDEB)
Value Char    GRPDEB

If GRPDEB="" : End : Endif

If clalev([F:AWG])=0  : Local File AWRKHISMES [AWG]  : Endif
If clalev([F:AWO])=0  : Local File AWRKHISDES [AWO]  : Endif
If clalev([F:AWJ])=0  : Local File AWRKHISJOI [AWJ]  : Endif
If clalev([F:AWS2])=0 : Local File AWRKHISSUI [AWS2] : Endif

If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR4
Else
 Gosub ANNULE_GRP
Endif
End

$TR4
Trbegin [AWG] , [AWJ] , [AWO] , [AWS2]
 Gosub ANNULE_GRP
 If GOK=0 : Goto AB_TR4 : Endif
Commit
Return

$AB_TR4
Rollback
Return

#---------------------------#
$ANNULE_GRP
For [AWG] Where REFGRP=GRPDEB
 Delete [AWJ] Where CHRONO=[F:AWG]CHRONO
 If fstat
  GOK = 0 : Call RSTA("AWJ","") From GLOCK : Break
 Endif
 Delete [AWO] Where CHRONO=[F:AWG]CHRONO
 If fstat
  GOK = 0 : Call RSTA("AWO","") From GLOCK : Break
 Endif
 Delete [AWS2] Where CHRONO=[F:AWG]CHRONO
 If fstat
  GOK = 0 : Call RSTA("AWS2","") From GLOCK : Break
 Endif
Next AWG
If GOK=0 : Return : Endif
Delete [AWG] Where REFGRP=GRPDEB
If fstat
 GOK = 0 : Call RSTA("AWG","") From GLOCK
Endif
Return

