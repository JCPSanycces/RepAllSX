Subprog ECRVALSDP(PABR)
Value Char PABR
Local Integer I
If GSTOTRACE=4
    For I=0 To GACTMAT-1
        Call ECRTRACE("[M:"+PABR+"]MATCST("+num$(I)+")="+num$(evalue("[M:"+PABR+"]MATCST(I)")),0) From STKVAL
    Next
    For I=0 To GACTMAC-1
        Call ECRTRACE("[M:"+PABR+"]MACCST("+num$(I)+")="+num$(evalue("[M:"+PABR+"]MACCST(I)")),0) From STKVAL
    Next
    For I=0 To GACTLAB-1
        Call ECRTRACE("[M:"+PABR+"]LABCST("+num$(I)+")="+num$(evalue("[M:"+PABR+"]LABCST(I)")),0) From STKVAL
    Next
    Call ECRTRACE("[M:"+PABR+"]SCOCST ="+num$(evalue("[M:"+PABR+"]SCOCST")),0) From STKVAL
    Call ECRTRACE("[M:"+PABR+"]INVDTACST ="+num$(evalue("[M:"+PABR+"]INVDTACST")),0) From STKVAL

    Call ECRTRACE("[M:"+PABR+"]OVEMATCST="+num$(evalue("[M:"+PABR+"]OVEMATCST")),0) From STKVAL
    Call ECRTRACE("[M:"+PABR+"]OVEMACCST="+num$(evalue("[M:"+PABR+"]OVEMACCST")),0) From STKVAL
    Call ECRTRACE("[M:"+PABR+"]OVELABCST="+num$(evalue("[M:"+PABR+"]OVELABCST")),0) From STKVAL
    Call ECRTRACE("[M:"+PABR+"]OVESCOCST="+num$(evalue("[M:"+PABR+"]OVESCOCST")),0) From STKVAL
    For I=0 To [M:SDP]NBONA-1
        If evalue("[M:"+PABR+"]OVENAT(I)")="" : Break : Endif
        Call ECRTRACE("[M:"+PABR+"]OVENAT="+evalue("[M:"+PABR+"]OVENAT(I)")-"="-num$(evalue("[M:"+PABR+"]ONAAMT(I)")),0) From STKVAL
    Next
Endif
End

