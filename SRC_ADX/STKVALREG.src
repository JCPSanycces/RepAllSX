#<AdxTL>@(#)8.0.0.0 $Revision$
#<gen>
# REGPRIX : Routine de regularisation de prix                            V 150#
# REGPRIX2 : Idem REGPRIX mais renvoie le montant absorbé et le montant non absorbé
# CALCABS        Calcule le montant absorbé et le montant absorbé
#                d'un changement de valeur
#
# Paramètres E:  LFCY     = Site
#                LQTYORI  = Quantité en stock
#                           --> correspond au nb d'articles qui absorbent LAMT
#                LAMTORI  = Montant du stock
#                LQTY     = Quantité d'articles concernés par la différence de montant
#                LAMT     = Montant à absorber
#
# Paramètres S:  LABS     = Montant absorbé par les [M:SDPO]QTY articles
#
# La différence LAMT-LABS donne le montant non absorbé
# SAVDETSJV : PCOE : coefficient multiplicateur
# PIND : indice de la ligne en cours
# PORDVAL : 1=Ordre ; 2=Valo ; 3=Ordre & Valo; 4=Valo2; 5=Ordre+Valo2; 6=Valo+Valo2; 7=Ordre+Valo+Valo2
# STKAMT : renvoie le montant d'une ligne de document hors FG, sa qté et le montant des FG
# AV_REGPRIX : Sous-programme à appeler avant une régularisation de prix
# afin de connaitre
#</gen>

###############################################################################
# REGPRIX : Routine de regularisation de prix                            V 150#
###############################################################################
# PFCY    = Site
# PTRSTYP = Type transaction (3=réception / 5=entrée OF / 11=retour)
# PITM    = Numéro article
# PIPTDAT = Date d'imputation
# PTRSCOD = Code mouvement
# PVCRTYP = Type d'ordre
# PVCRNUM = Numéro d'ordre
# PVCRLIN = Ligne
# PTYPREG = Type d'ordre à l'origine de la régularisation (facture...)
# PNUMREG = Numéro d'ordre à l'origine de la régularisation (facture...)
# PLINREG = Ligne à l'origine de la régularisation (facture...)
# PNEWAMT = Nouveau montant (pour la quantité concernée)
# [M:SDP]QTY    = Quantité concernée (=0 si pour toute la quantité)
# PRET    = Code retour 0 = OK
#                     1 = Erreur en lecture de fichier
#                     2 = pas de mouvement d'origine trouvé
#                     3 = Quantité active non renseignée dans un mouvement
#                     4 = Erreur en écriture de fichier
#                     5 = La régularisation base lot doit se faire sur toute la quantité de l'entrée
#                     6 = Le masque SAIDECPRI n'est pas ouvert
#                     7 = Période indéfinie ou traitement interdit à cette date
#                     8 = Pas assez de lignes dans le masque SRW
#                     9 = Désynchro entre STOCOST et ITMMVT
###############################################################################
Subprog REGPRIX(PFCY, PTRSTYP, PITM, PIPTDAT, PTRSCOD, PVCRTYP, PVCRNUM, PVCRLIN, PTYPREG, PNUMREG, PLINREG, PCNVRPT, PRET)
Value    Char    PFCY
Value    Integer PTRSTYP
Value    Char    PITM
Value    Date    PIPTDAT
Value    Char    PTRSCOD
Value    Integer PVCRTYP
Value    Char    PVCRNUM
Value    Integer PVCRLIN
Value    Integer PTYPREG
Value    Char    PNUMREG
Value    Integer PLINREG
Value    Decimal PCNVRPT
Variable Integer PRET

Local Decimal LABS, LNABS, LNABS2
Local Integer LRET

Call REGPRIX4(PFCY, PTRSTYP, PITM, PIPTDAT, PTRSCOD, PVCRTYP, PVCRNUM, PVCRLIN, PTYPREG, PNUMREG, PLINREG, PCNVRPT, "", LABS, LNABS, LNABS2, LRET)
PRET = LRET

End

# Idem REGPRIX mais renvoie le montant absorbé et le montant non absorbé
Subprog REGPRIX2(PFCY, PTRSTYP, PITM, PIPTDAT, PTRSCOD, PVCRTYP, PVCRNUM, PVCRLIN, PTYPREG, PNUMREG, PLINREG, PCNVRPT, PMNTABS, PMNTNABS, PRET)
Value    Char    PFCY
Value    Integer PTRSTYP
Value    Char    PITM
Value    Date    PIPTDAT
Value    Char    PTRSCOD
Value    Integer PVCRTYP
Value    Char    PVCRNUM
Value    Integer PVCRLIN
Value    Integer PTYPREG
Value    Char    PNUMREG
Value    Integer PLINREG
Value    Decimal PCNVRPT
Variable Decimal PMNTABS
Variable Decimal PMNTNABS
Variable Integer PRET

Local Decimal LNABS2
Local Integer LRET

Call REGPRIX4(PFCY, PTRSTYP, PITM, PIPTDAT, PTRSCOD, PVCRTYP, PVCRNUM, PVCRLIN, PTYPREG, PNUMREG, PLINREG, PCNVRPT, "", PMNTABS, PMNTNABS, LNABS2, LRET)
PRET = LRET

End

# Idem REGPRIX2 mais renvoie aussi le montant non absorbé dû à la fermeture des périodes comptables
Subprog REGPRIX3(PFCY, PTRSTYP, PITM, PIPTDAT, PTRSCOD, PVCRTYP, PVCRNUM, PVCRLIN, PTYPREG, PNUMREG, PLINREG, PCNVRPT, PMNTABS, PMNTNABS, PMNTNABS2, PRET)
Value    Char    PFCY
Value    Integer PTRSTYP
Value    Char    PITM
Value    Date    PIPTDAT
Value    Char    PTRSCOD
Value    Integer PVCRTYP
Value    Char    PVCRNUM
Value    Integer PVCRLIN
Value    Integer PTYPREG
Value    Char    PNUMREG
Value    Integer PLINREG
Value    Decimal PCNVRPT
Variable Decimal PMNTABS
Variable Decimal PMNTNABS
Variable Decimal PMNTNABS2
Variable Integer PRET

Local Integer LRET

Call REGPRIX4(PFCY, PTRSTYP, PITM, PIPTDAT, PTRSCOD, PVCRTYP, PVCRNUM, PVCRLIN, PTYPREG, PNUMREG, PLINREG, PCNVRPT, "", PMNTABS, PMNTNABS, PMNTNABS2, LRET)
PRET = LRET

End

# Idem REGPRIX3 mais avec une option possible PSUP
# PSUP = 'T' => La quantité
Subprog REGPRIX4(PFCY, PTRSTYP, PITM, PIPTDAT, PTRSCOD, PVCRTYP, PVCRNUM, PVCRLIN, PTYPREG, PNUMREG, PLINREG, PCNVRPT, PSUP, PMNTABS, PMNTNABS, PMNTNABS2, PRET)
Value    Char    PFCY
Value    Integer PTRSTYP
Value    Char    PITM
Value    Date    PIPTDAT
Value    Char    PTRSCOD
Value    Integer PVCRTYP
Value    Char    PVCRNUM
Value    Integer PVCRLIN
Value    Integer PTYPREG
Value    Char    PNUMREG
Value    Integer PLINREG
Value    Decimal PCNVRPT
Value    Char    PSUP
Variable Decimal PMNTABS
Variable Decimal PMNTNABS
Variable Decimal PMNTNABS2
Variable Integer PRET

Call ECRTRACE("PVCRTYP="+num$(PVCRTYP),0) From STKVAL
Call ECRTRACE("PVCRNUM="+num$(PVCRNUM),0) From STKVAL
Call ECRTRACE("PVCRLIN="+num$(PVCRLIN),0) From STKVAL
Call ECRTRACE("PTYPREG="+num$(PTYPREG),0) From STKVAL
Call ECRTRACE("PNUMREG="+num$(PNUMREG),0) From STKVAL
Call ECRTRACE("PLINREG="+num$(PLINREG),0) From STKVAL
Call ECRTRACE("[M:SDP]AMTTOT="+num$([M:SDP]AMTTOT),0) From STKVAL
Call ECRTRACE("[M:SDP]QTY="+num$([M:SDP]QTY),0) From STKVAL

Local File STOJOUVAL  [SJV]
Local File STOJOUOVE  [SJO]
Local File STOJOU     [STJ]
Local File STOJOU     [STJ1]    # Pour sous-pro ECRSTJ
Local File STOJOU     [STJ2]
Local File ITMMASTER  [ITM]
Local File ITMMVT     [ITV]
Local File ITMMVTHIS  [ITH]
Local File STOCOST    [STP]
Local File STOLOTFCY  [SLF]
Local File STOLOT     [STL]
If PTRSTYP=3
    Local File PRECEIPTD [PTD]
Endif
If !clalev([F:TCM])  : Local File TABCOSTMET [TCM]  : Endif
If !clalev([F:TVM])  : Local File TABCOSTMVT [TVM]  : Endif
If !clalev([F:ACV])  : Local File ACTIV      [ACV]  : Endif
If !clalev([F:PER])  : Local File PERIOD     [PER]  : Endif
If !clalev([F:OVE])  : Local File OVERHEAD   [OVE]  : Endif

If !clalev([M:SRW])  : Local Mask STKREGW    [SRW]  : Endif

If !clalev([M:SDP])
    PRET = 6
    GOK=0
    End
Endif
If !clalev([M:SDPD]) : Local Mask SAIDECPRI  [SDPD] : Endif    # Ecran des delta de montants
If !clalev([M:SDPO]) : Local Mask SAIDECPRI  [SDPO] : Endif    # Ecran des montants d'origine


Local Char    WPAR
Local Integer LIND, I, J, K, INDLIG
Local Decimal LQTYPHYORI          # Quantité physique totale de la ligne de doc
Local Decimal LABSTRT(2), LNABSTRT(2)
Local Decimal LABSSTP1, LABSSTP, LABSSLF    # Variables temporaires du mnt absorbé par un élément de pile fifo ou un lot
Local Char    REQ(250)
Local Integer SRWCOR

Raz [M:SRW], [M:SDPO], [M:SDPD]

Call ECRVALSDP("SDP")

# L'association des 5 champs suivants est unique dans tout le tableau
# [M:SRW]LOT;SLO;VCRTYP;VCRNUM;VCRLIN
# Pour chaque association on stocke:
# [M:SRW]QTYSTU = Qté
# [M:SRW]AMTABS = Mnt absorbé
# [M:SRW]AMTNABS= Mnt non absorbé
# [M:SRW]QTYSTOLOT = Qté en stock du lot/sous-lot

Local Decimal LMNTABS       # Montant absorbable
Local Decimal LCUMQTETRT    # Variable de calcul (contient la qté restant à régulariser)
Local Decimal LCUMMNTABS(2) # Montant total absorbé par le stock (sert à la màj de ITMMVT etITMMVTHIS)
Local Decimal LCUMMNTNABS(2)# Montant total non absorbé par le stock (sert à la màj de ITMMVT etITMMVTHIS)
Local Decimal LAMT2ABS, LQTY2ABSTOT, LAMT2ABSTOT
Local Decimal LAMTORILOT    # Montant d'origine pour un lot
Local Decimal LCUMABSSTP    # Cumul du montant absorbé par la pile FIFO
Local Decimal WRND_SOC      # Arrondi des montants
Local Integer LPRINAT       # Méthode de valo utilisée lors de l'entrée
Local Char    LFILSTJ(250), LFILSTJ1(250)
Local Decimal LQTYLOT, LTOTSTOLOT # Qté mvts d'un lot , qté tot des lots en stock
Local Decimal LAMTABSTOT    # Montant total absorbé par le lot
Local Decimal LCUMABSSLF    # Cumul du montant absorbé sur un lot avant màj des STJ
Local Decimal LOTCSTDEV     # Montant du lot dans la devise en cours
Local Decimal LQTYREG       # Quantité à régulariser (=PQTY ou LQTYORI si PQTY=0)
Local Decimal LQTYABSSTP    # Quantité de la pile FIFO devant absorber le "montant à absorber"
Local Decimal LQTYABSTOT    # Quantité absorbant le "montant absorbé"
Local Decimal LABSSTPTOT    # Montant à absorber par la pile FIFO à chaque ligne de doc
Local Decimal LQTYSTP       # Quantité encore dans la pile fifo des documents en cours de régul
Local Decimal LQTYVCR       # Active quantity corresponding to a document line with original potency
Local Decimal LQTYVCRNOW    # Active quantity corresponding to a document line with the actual potency
Local Decimal LDEV          # Montant non absorbé d'une ligne de doc
Local Decimal LQTYLOTPHY    # Get the physical quantity entered for a lot by the document(s) concerned by the adjustment

Local Decimal LQTYTMP
Local Decimal LQTYTMP1, LQTYTMP2
Local Decimal LMNTTMP             # variable temporaire
Local Decimal LCOEF
Local Integer LMVTORI             # Indique si la recherche du prix à comparer provient du montant d'origine (réception) ou du dernier mouvement (facture)

Local Integer LREG

Local Date    LIPT
Local Integer LCTRIPT(dim([M:SRW]AMTABS)), LCTRIPTOK

Local Decimal LBASQTY, LBASAMT
Local Char    LTABNAT(GLONONA)(dim([F:OVE]OVENAT))
Local Decimal LTABFXD(dim([F:OVE]OVENAT))
Local Decimal LTABVAR(dim([F:OVE]OVENAT))
Local Integer LTABTYP(dim([F:OVE]OVENAT))
Local Decimal LTABVAL(1+GACTMAT+GACTMAC+GACTLAB+1+1+4+1)

#------------------------------------------------------------------------------#
#            Variables paramètres modifiables dans le point d'entrée           #
#------------------------------------------------------------------------------#
Local Integer LMODSTP(2) # Conditionne la réévaluation des mnt absorbés et non absorbés
                         # selon ce qui a été absorbé par la pile Fifo
Local Integer LUPDTAB    # Conditionne la mise à jour des tables STOCOST, STOLOT, STOJOU, ITMMVT, ITMMVTHIS
#------------------------------------------------------------------------------#

Raz LPRINAT
Raz LQTYLOT, LTOTSTOLOT
#---------- Lecture des fichiers ------------------#
Gosub LECFIC

# Issue 88646 - 2013-03-28 by CCC : pb arrondi
Call LOADVAR(LTABVAL, "[M:SDP]", 0, "", 1, 0, 0) From STKVALECR
[M:SDP]AMTTOT = arr([M:SDP]AMTTOT,GRNDVAL)
Call REPVAL([M:SDP]AMTTOT, LTABVAL, GRNDVAL, LTABVAL) From STKVALECR
Call LOADFIC("[M:SDP]", LTABVAL, "", "CST", 1, 0) From STKVALECR

# CCC (2010-01-14) Bug 58998 : Pas de contrôle de date, c'est la compta qui s'en charge
#Call STKCTRIPT(PIPTDAT,PFCY,"123") From STKLIB
#If mkstat=2
#    # GMESSAGE chargé
#    PRET=7
#    GOK=0
#    End
#Endif

#----------- Init des tableaux de quantité par lot et par ligne de doc ---------------#
# Issue 68672 - 2010-10-28 by CCC
LMVTORI = 0
If [M:SDP]QTY=0 | find(PTYPREG,10,36) | instr(1,PSUP,"T")
    LFILSTJ1 = "REGFLG<>2"
Else
    LMVTORI=1
    LFILSTJ1 = 'find(VCRNUMREG,"",VCRNUM)<>0'
Endif

If find(PTYPREG,10,36)
    # Issue 88707 - 2013-03-21 by CCC : L'article peut se trouver sur plusieurs lignes d'OF => il faut préciser la ligne d'OF
    #LFILSTJ = "STOFCY=PFCY & UPDCOD=2 & ITMREF=PITM & VCRTYPORI=PTYPREG & VCRNUMORI=PNUMREG"
    LFILSTJ = "STOFCY=PFCY & UPDCOD=2 & ITMREF=PITM & VCRTYPORI=PTYPREG & VCRNUMORI=PNUMREG & VCRLINORI=PLINREG"
    # CCC (15/04/05) Bug 29749 : On peut déclarer le composé dans les composants d'un OF
    LFILSTJ += "&VCRTYP<>12"
    # Issue 65762 - 2010-10-05 by CCC : Exclure les lignes de contrôle qualité créées en 130
    LFILSTJ += "&VCRTYP<>28"
    # Issue 118579 - 2016-11-02 by ERMIL : Exclude VCRTYP 4 and TRSTYP 29 for sub contract orders
    LFILSTJ += "& VCRTYP<>4 & TRSTYP<>29"

    # CCC (2010-04-22) Bug 64242 : En 130, des mouvements pouvaient avoir PRINAT à 0
    #                  On les mets à jour avant de faire la régul
    Update [STJ] Where evalue(LFILSTJ) & PRINAT=0 & PRIREGFLG<>2 & REGFLG=1
&                With PRINAT = LPRINAT

    # Issue 82159 - 2012-07-04 by CCC
    # Récupération des natures qui existent dans SDP
    For I=0 To [M:SDP]NBONA-1
        [M:SDPO]OVENAT(I) = [M:SDP]OVENAT(I)
        [M:SDPO]ONATYP(I) = [M:SDP]ONATYP(I)
    Next
    [M:SDPO]NBONA = [M:SDP]NBONA

    # Issue 113330 - 2016-01-05 by CCC : order has to take into account the date to be sure
    # to take into account IPTDAT of the receipt and not adjustments done when the stock period was closed
    Filter [STJ] Where evalue(LFILSTJ) & evalue(LFILSTJ1)
&                Order By IPTDAT
    For [STJ]
        Raz LDEV
        If !sigma(0,[M:SRW]NBLIG-1, [M:SRW]LOT(indcum)=[F:STJ]LOT
&                             & [M:SRW]SLO(indcum)=[F:STJ]SLO
&                             & [M:SRW]VCRTYP(indcum)=[F:STJ]VCRTYP
&                             & [M:SRW]VCRNUM(indcum)=[F:STJ]VCRNUM
&                             & [M:SRW]VCRLIN(indcum)=[F:STJ]VCRLIN )
            For [STJ1]reckey Where LOT=[F:STJ]LOT
&                                & SLO=[F:STJ]SLO
&                                & VCRTYP=[F:STJ]VCRTYP
&                                & VCRNUM=[F:STJ]VCRNUM
&                                & VCRLIN=[F:STJ]VCRLIN
&                                & STOFCY=[F:STJ]STOFCY
&                                & ITMREF=[F:STJ]ITMREF
                LDEV+=[F:STJ1]AMTDEV
                # Issue 87601 - 2013-01-29 by CCC
                If GACTDECCST
                    If [F:STJ1]CREMVTDAT>=GDATDECCST & GDATDECCST>[0/0/0]
                        Read [SJV]SJV0=[F:STJ1]STOFCY;2;[F:STJ1]ITMREF;[F:STJ1]IPTDAT;[F:STJ1]MVTSEQ;[F:STJ1]MVTIND
                        If !fstat # les mvt inverses peuvent être lus mais n'ont pas de mouvement de valeur
                            Call LOADSDPX("SDPO","[F:SJV]","DEV",1) From STKVAL
                        Endif
                    Else
                        [M:SDPO]MATCST([F:ITM]BRDCOD-1) += [F:STJ1]AMTDEV
                    Endif
                Endif
            Next
        Endif
        [M:SDPO]AMTTOT += [F:STJ]AMTVAL + LDEV
        If GACTDECCST
            # Issue 83620 - 2012-08-13 by CCC
            If [F:STJ]CREMVTDAT>=GDATDECCST & GDATDECCST>[0/0/0]
                Read [SJV]SJV0=[F:STJ]STOFCY;2;[F:STJ]ITMREF;[F:STJ]IPTDAT;[F:STJ]MVTSEQ;[F:STJ]MVTIND
                If !fstat # les mvt inverses peuvent être lus mais n'ont pas de mouvement de valeur
                    Call LOADSDPX("SDPO","[F:SJV]","V",1) From STKVAL
                    # Issue 87601 - 2013-01-29 by CCC
                    #Call LOADSDPX("SDPO","[F:SJV]","DEV",1) From STKVAL
                Endif
            Else
                # Issue 87601 - 2013-01-29 by CCC
                #[M:SDPO]MATCST([F:ITM]BRDCOD-1) += [F:STJ]VARVAL + [F:STJ]AMTDEV
                [M:SDPO]MATCST([F:ITM]BRDCOD-1) += [F:STJ]VARVAL
            Endif
        Endif

        LQTYPHYORI += [F:STJ]QTYSTU
        Gosub REMPTAB
        If !GOK : Break : Endif
    Next
    Filter [STJ]
    For [STJ] Where evalue(LFILSTJ)
        # Issue 82159 - 2012-07-04 by CCC
        For [SJO] Where STOFCY=[F:STJ]STOFCY
&                 & UPDCOD=2
&                 & ITMREF=[F:STJ]ITMREF
&                 & IPTDAT=[F:STJ]IPTDAT
&                 & MVTSEQ=[F:STJ]MVTSEQ
&                 & MVTIND=[F:STJ]MVTIND      # Lecture des SJO correspondant à STJ

            LIND = find([F:SJO]OVENAT,[M:SDPO]OVENAT)
            If LIND>0
                LIND-=1
            Else
                LIND = [M:SDPO]NBONA
                [M:SDPO]OVENAT(LIND) = [F:SJO]OVENAT
                [M:SDPO]ONATYP(LIND) = [F:SJO]TYPCST
                [M:SDPO]NBONA += 1
            Endif
            [M:SDPO]ONAAMT(LIND) += [F:SJO]ONAAMT
        Next
    Next
Else
    LFILSTJ = "STOFCY=PFCY & VCRTYP=PVCRTYP & VCRNUM=PVCRNUM & VCRLIN=PVCRLIN & ITMREF=PITM & UPDCOD=2"
    # CCC (2010-04-22) Bug 64242 : En 130, des mouvements pouvaient avoir PRINAT à 0
    #                  On les mets à jour avant de faire la régul
    Update [STJ] Where evalue(LFILSTJ) & PRINAT=0 & PRIREGFLG<>2 & REGFLG=1
&                With PRINAT = LPRINAT

    # Issue 80207 - 2012-02-21 by CCC : Il faut lire tous les mouvements pour récupérer les FG correspondants
    If PTRSTYP=3
        # Issue 113330 - 2016-01-05 by CCC : add Order by
        Filter [STJ] Where evalue(LFILSTJ)
&                    Order By STOFCY;VCRTYP;VCRNUM;VCRLIN;IPTDAT
    Else
        # Issue 113330 - 2016-01-05 by CCC : add Order by
        Filter [STJ] Where evalue(LFILSTJ) & evalue(LFILSTJ1)
&                    Order By STOFCY;VCRTYP;VCRNUM;VCRLIN;IPTDAT
    Endif
# Issue 113330 - 2016-01-05 by CCC : order has to take into account the date to be sure
# to take into account IPTDAT of the receipt and not adjustments done when the stock period was closed
#    For [STJ] Hint Key STJ1
    For [STJ]
        If PTRSTYP<>3 | LMVTORI=0 & [F:STJ]REGFLG<>2 |  LMVTORI=1 & find([F:STJ]VCRNUMREG,"",[F:STJ]VCRNUM)<>0
            Raz LDEV
            If !sigma(0,[M:SRW]NBLIG-1, [M:SRW]LOT(indcum)=[F:STJ]LOT
&                             & [M:SRW]SLO(indcum)=[F:STJ]SLO
&                             & [M:SRW]VCRTYP(indcum)=[F:STJ]VCRTYP
&                             & [M:SRW]VCRNUM(indcum)=[F:STJ]VCRNUM
&                             & [M:SRW]VCRLIN(indcum)=[F:STJ]VCRLIN )
                For [STJ1]reckey Where LOT=[F:STJ]LOT
&                                & SLO=[F:STJ]SLO
&                                & VCRTYP=[F:STJ]VCRTYP
&                                & VCRNUM=[F:STJ]VCRNUM
&                                & VCRLIN=[F:STJ]VCRLIN
&                                & STOFCY=[F:STJ]STOFCY
&                                & ITMREF=[F:STJ]ITMREF
&                                & (LMVTORI=0 | evalue(LFILSTJ1))
                    LDEV+=[F:STJ1]AMTDEV
                    If GACTDECCST
                        Read [SJV]SJV0=[F:STJ1]STOFCY;2;[F:STJ1]ITMREF;[F:STJ1]IPTDAT;[F:STJ1]MVTSEQ;[F:STJ1]MVTIND
                        If !fstat
                            Call LOADSDPX("SDPO","[F:SJV]","DEV",1) From STKVAL
                        Endif
                    Endif
                Next
            Endif
            If LMVTORI
                [M:SDPO]AMTTOT += [F:STJ]VARVAL + LDEV
            Else
                [M:SDPO]AMTTOT += [F:STJ]AMTVAL + LDEV
            Endif
            If GACTDECCST
                # Issue 83620 - 2012-08-13 by CCC
                If [F:STJ]CREMVTDAT>=GDATDECCST & GDATDECCST>[0/0/0]
                    Read [SJV]SJV0=[F:STJ]STOFCY;2;[F:STJ]ITMREF;[F:STJ]IPTDAT;[F:STJ]MVTSEQ;[F:STJ]MVTIND
                    If !fstat # les mvt inverses peuvent être lus mais n'ont pas de mouvement de valeur
                        Call LOADSDPX("SDPO","[F:SJV]",string$(LMVTORI<>0,"D")+"V",1) From STKVAL
                    Endif
                Else
                    If LMVTORI
                        [M:SDPO]MATCST([F:ITM]BRDCOD-1) += [F:STJ]VARVAL
                    Else
                        [M:SDPO]MATCST([F:ITM]BRDCOD-1) += [F:STJ]AMTVAL
                    Endif
                Endif
            Endif
# CCC (2010-05-19) Bug 64737 : En V6, plus de conversion
#        # CCC (14/02/05) Bug 28345 : Utilisation devise société dans la valeur du lot
#        Call CONVERT2(GLOCALDEV,GSYSCUR,GLOCALDEV,GCHGTYP,[F:STJ]IPTDAT,
#&                     [F:STJ]AMTORD,LMNTTMP,PRET) From TRTDEV
#        If PRET
#            PRET=6
#            GOK=0
#            Break
#        Endif

            LQTYPHYORI += [F:STJ]QTYSTU
            Gosub REMPTAB
            If !GOK : Break : Endif
        Endif
    Next
    Filter [STJ]
    For [STJ] Where evalue(LFILSTJ)
        # Issue 100192 - 2014-06-25 by CCC
        #If PTRSTYP=3
            For [SJO] Where STOFCY=[F:STJ]STOFCY
&                     & UPDCOD=2
&                     & ITMREF=[F:STJ]ITMREF
&                     & IPTDAT=[F:STJ]IPTDAT
&                     & MVTSEQ=[F:STJ]MVTSEQ
&                     & MVTIND=[F:STJ]MVTIND      # Lecture des SJO correspondant à STJ

                LIND = find([F:SJO]OVENAT,[M:SDPO]OVENAT)
                If LIND>0
                    LIND-=1
                Else
                    LIND = [M:SDPO]NBONA
                    [M:SDPO]OVENAT(LIND) = [F:SJO]OVENAT
                    [M:SDPO]ONATYP(LIND) = [F:SJO]TYPCST
                    [M:SDPO]NBONA += 1
                Endif
                [M:SDPO]ONAAMT(LIND) += [F:SJO]ONAAMT
                LBASAMT -= [F:SJO]ONAAMT
            Next
            LBASAMT += [F:STJ]VARVAL + [F:STJ]AMTDEV
        #Endif
    Next
#    Next
#    Filter [STJ]
Endif

If PRET
    GOK=0
    End
Endif

# Issue 118200 - 2016-09-20 by ERMIL : Do not recalculate overheads for Assembly (added TYP 31 to If statement)
# Issue 100192 - 2014-06-25 by CCC : Overhead have to be calculated except in the case of WO or EO
## Issue 80207 - 2012-02-21 by CCC : Il faut lire tous les mouvements pour récupérer les FG correspondants
#If PTRSTYP=3
If !find(PTYPREG,10,36,31)
    # Le delta va être calculé hors FG
    [M:SDPO]AMTTOT -= [M:SDPO]OVEMATCST+[M:SDPO]OVEMACCST+[M:SDPO]OVELABCST+[M:SDPO]OVESCOCST
    Raz [M:SDPO]OVEMATCST,[M:SDPO]OVEMACCST,[M:SDPO]OVELABCST,[M:SDPO]OVESCOCST
Endif
#-------- Calcul du montant à absorber au total -------------#
[M:SDPO]QTY = sum([M:SRW]QTYSTU)
If [M:SDPO]QTY=0
    PRET=2
    GOK=0
    End
Endif

Call ECRVALSDP("SDPO")

LQTYREG = [M:SDP]QTY
If find(PTYPREG,6,17)
    LQTYREG *= [M:SDPO]QTY/LQTYPHYORI
Endif

[M:SDPD]AMTTOT = [M:SDP]AMTTOT-LQTYREG*[M:SDPO]AMTTOT/[M:SDPO]QTY
For I=0 To dim([M:SDP]MATCST)-1
    [M:SDPD]MATCST(I) = [M:SDP]MATCST(I)-LQTYREG*[M:SDPO]MATCST(I)/[M:SDPO]QTY
Next
[M:SDPD]OVEMATCST = [M:SDP]OVEMATCST-LQTYREG*[M:SDPO]OVEMATCST/[M:SDPO]QTY

For I=0 To dim([M:SDP]MACCST)-1
    [M:SDPD]MACCST(I) = [M:SDP]MACCST(I)-LQTYREG*[M:SDPO]MACCST(I)/[M:SDPO]QTY
Next
[M:SDPD]OVEMACCST = [M:SDP]OVEMACCST-LQTYREG*[M:SDPO]OVEMACCST/[M:SDPO]QTY

For I=0 To dim([M:SDP]LABCST)-1
    [M:SDPD]LABCST(I) = [M:SDP]LABCST(I)-LQTYREG*[M:SDPO]LABCST(I)/[M:SDPO]QTY
Next
[M:SDPD]OVELABCST = [M:SDP]OVELABCST-LQTYREG*[M:SDPO]OVELABCST/[M:SDPO]QTY

#[M:SDPD]SCOTOT = [M:SDP]SCOTOT-LQTYREG*[M:SDPO]SCOTOT/[M:SDPO]QTY
[M:SDPD]SCOCST = [M:SDP]SCOCST-LQTYREG*[M:SDPO]SCOCST/[M:SDPO]QTY
[M:SDPD]OVESCOCST = [M:SDP]OVESCOCST-LQTYREG*[M:SDPO]OVESCOCST/[M:SDPO]QTY

[M:SDPD]INVDTACST = [M:SDP]INVDTACST-LQTYREG*[M:SDPO]INVDTACST/[M:SDPO]QTY

# Issue 118200 - 2016-09-20 by ERMIL : Do not recalculate overheads for Assembly (added TYP 31 to If statement)
# Issue 100192 - 2014-06-25 by CCC : Overhead have to be calculated except in the case of WO or EO
## Issue 78242 - 2012-01-09 by CCC : Calcul des FG avec le nouveau montant
#If PTRSTYP=3   # Réception
If !find(PTYPREG,10,36,31)
    #Raz [M:SDPD]OVEMATCST, [M:SDPD]OVEMACCST, [M:SDPD]OVELABCST, [M:SDPD]OVESCOCST

    For I=0 To dim([M:SDPO]OVENAT)-1
        If [M:SDPO]OVENAT(I)=""
            Break
        Endif
        [M:SDPD]OVENAT  ([M:SDPD]NBONA) = [M:SDPO]OVENAT(I)

        #X3-58978 MJH.sn When creating a credit memo for a returned receipt, we want the value to subtract instead of add.
        If PTYPREG = 17 and PVCRTYP = 8
          [M:SDPD]ONAAMT  ([M:SDPD]NBONA) = [M:SDPO]ONAAMT(I)
        Else
          [M:SDPD]ONAAMT  ([M:SDPD]NBONA) = -[M:SDPO]ONAAMT(I)#Original
        Endif#X3-58978 MJH.en

        [M:SDPD]ONATYP  ([M:SDPD]NBONA) = [M:SDPO]ONATYP(I)
        [M:SDPD]NBONA +=1
        # OVE has been deleted before for SDPO in case of receipt
        Case [M:SDPO]ONATYP(LIND)
            When 3   : [M:SDPO]OVEMACCST += [M:SDPO]ONAAMT(I)
            When 4   : [M:SDPO]OVELABCST += [M:SDPO]ONAAMT(I)
            When 5   : [M:SDPO]OVESCOCST += [M:SDPO]ONAAMT(I)
            When Default : [M:SDPO]OVEMATCST += [M:SDPO]ONAAMT(I)
        Endcase
        [M:SDPO]AMTTOT += [M:SDPO]ONAAMT(I)
    Next

        # Calcul du nouveau montant hors frais généraux et éléments de facturation
        LBASAMT += ([M:SDPD]AMTTOT-[M:SDPD]INVDTACST-[M:SDPD]OVEMATCST-[M:SDPD]OVEMACCST-[M:SDPD]OVELABCST-[M:SDPD]OVESCOCST)
&                 -[M:SDPO]INVDTACST

        # Issue 88769 - 2013-03-21 by CCC
        #If LQTYREG=0
            LBASQTY = [M:SDPO]QTY
        #Else
        #    LBASQTY = LQTYREG
        #Endif

        # Issue 100192 - 2014-06-23 by CCC
        GPOINT = "BASFGADJ"
        Gosub ENTREE From EXEFNC

        If PTRSTYP=3
            Read [PTD] PTD0=PVCRNUM;PVCRLIN
            Call CALOVELIN(PITM, PFCY, 3, 14,[F:PTD]POHNUM,[F:PTD]POPLIN, [F:PTD]POQSEQ,
&                          LBASQTY, LBASAMT,
&                          "", LTABNAT, LTABTYP, LTABFXD, LTABVAR, PRET) From STKVAL
        Else
            Call CALOVELIN(PITM, PFCY, PTRSTYP, 0,"",0, 0,
&                          LBASQTY, LBASAMT,
&                          "", LTABNAT, LTABTYP, LTABFXD, LTABVAR, PRET) From STKVAL
        Endif
        If PRET>1
            Call ECR_TRACE(PVCRNUM-num$(PVCRLIN)-PITM-mess(5,213,1)-":"-mess(7,21,1)-num$(WRET),1) From GESECRAN
            PRET=8
            GOK=0
            End
        Endif
        Raz PRET

        For I=0 To dim(LTABNAT)-1
            If LTABNAT(I)=""
                Break
            Endif
            LIND = find(LTABNAT(I),[M:SDPD]OVENAT)-1
            If LIND<0
                LIND = [M:SDPD]NBONA
                [M:SDPD]NBONA+=1
            Endif
            [M:SDPD]OVENAT  (LIND) = LTABNAT(I)
            [M:SDPD]ONAAMT  (LIND) += LTABFXD(I)+LTABVAR(I)
            [M:SDPD]ONATYP  (LIND) = LTABTYP(I)
        Next
        [M:SDPD]AMTTOT-=[M:SDPD]OVEMATCST + [M:SDPD]OVEMACCST + [M:SDPD]OVELABCST + [M:SDPD]OVESCOCST
        Raz [M:SDPD]OVEMATCST, [M:SDPD]OVEMACCST, [M:SDPD]OVELABCST, [M:SDPD]OVESCOCST
        For I=0 To [M:SDPD]NBONA-1
            Case [M:SDPD]ONATYP(LIND)
                When 3   : [M:SDPD]OVEMACCST += [M:SDPD]ONAAMT(I)
                When 4   : [M:SDPD]OVELABCST += [M:SDPD]ONAAMT(I)
                When 5   : [M:SDPD]OVESCOCST += [M:SDPD]ONAAMT(I)
                When Default : [M:SDPD]OVEMATCST += [M:SDPD]ONAAMT(I)
            Endcase

            [M:SDPD]AMTTOT += [M:SDPD]ONAAMT(I)
        Next
Else
    For I=0 To [M:SDPO]NBONA-1    # Toutes les natures (anciennes et nouvelles) sont présentes dans [SDPO]
        [M:SDPD]OVENAT(I) = [M:SDP]OVENAT(I)
        [M:SDPD]ONATYP(I) = [M:SDP]ONATYP(I)
        [M:SDPD]ONAAMT(I) = [M:SDP]ONAAMT(I)-[M:SDPO]ONAAMT(I)
    Next
    [M:SDPD]NBONA = [M:SDPO]NBONA
Endif

# Issue 88646 - 2013-03-28 by CCC : pb arrondi
[M:SDPD]AMTTOT = arr([M:SDPD]AMTTOT,GRNDVAL)
Call LOADVAR(LTABVAL, "[M:SDPD]", 0, "", 1, 0, GRNDVAL) From STKVALECR
Call LOADFIC("[M:SDPD]", LTABVAL, "", "CST", 1, 0) From STKVALECR

Call ECRVALSDP("SDPD")

# La somme des composantes peut faire que le delta est nul
# Issue number 109768 - 2016-02-11 by STLIG : Test [M:SRW]IPTDAT instead of PIPTDAT ...
If [M:SDPD]AMTTOT=0 & (GACTDECCST=0 | [M:SRW]IPTDAT(0)<GDATDECCST)    # Pas de régul à faire
    Raz GPE
    GPOINT = "NULAMTADJ"
    Gosub ENTREE From EXEFNC
    If GPE=0
        End
    Endif
Elsif GACTDECCST=1
&   & sigma(0,dim([M:SDPD]MATCST)-1,abs([M:SDPD]MATCST(indcum)))=0
&   & sigma(0,dim([M:SDPD]MACCST)-1,abs([M:SDPD]MACCST(indcum)))=0
&   & sigma(0,dim([M:SDPD]LABCST)-1,abs([M:SDPD]LABCST(indcum)))=0
&   & [M:SDPD]SCOCST=0
&   & [M:SDPD]INVDTACST=0
&   & [M:SDPD]OVEMATCST=0
&   & [M:SDPD]OVEMACCST=0
&   & [M:SDPD]OVELABCST=0
&   & [M:SDPD]OVESCOCST=0
    Raz GPE
    GPOINT = "NULAMTADJ"
    Gosub ENTREE From EXEFNC
    If GPE=0
        End
    Endif
Endif

If  [M:SDP]QTY=0
& | find([F:TCM]ISSVLTCOD(0),5,8) & [F:TCM]PRIREGS=2    # Issue 94844 - 2014-01-15 by CCC
# Issue 112666 & 114528 09.2016 by CCC : get the active quantity with actual potency
#    LQTYREG=[M:SDPO]QTY
    LQTYREG=sum([M:SRW]QTYSTUNOW)
Else
    LQTYREG*=sum([M:SRW]QTYSTUNOW)/sum([M:SRW]QTYSTU)
Endif

# Issue 85364 - 2012-10-24 by CCC : Pouvoir éviter la régul d'entrée
Raz GPE
GPOINT="BEFADJCPT"
Gosub ENTREE From EXEFNC
If GPE=1
    End
Endif

Raz LQTYABSTOT

#------- Calculate the amount that can be absorbed -----------#
$CLCABS

# Issue 112666 & 114528 09.2016 by CCC : the distribution of amount is by physical quantity (as it's done during creation)
LQTY2ABSTOT = sum([M:SRW]QTYPHY)

If LREG=2
    # Issue 69634 - 2011-01-06 by CCC : C'est l'écart global qu'il faut tester
    #If [M:SDP]AMTTOT<>0
    If [M:SDPD]AMTTOT<>0
        Case WMAXABSCOD
            When 1, 2:    #---- Tout est absorbé / Absorption base site
                # Il faut calculer le maximum d'absorption dans les 2 cas
                # car on peut avoir un montant négatif supérieur à la valeur du stock
                #LQTYSTO = [F:ITV]AVCBASQTY #MJH X3-101694.o
                LQTYSTO = arr([F:ITV]AVCBASQTY/([M:SDPO]QTY/LQTYPHYORI),WRND_SOC) #MJH X3-101694.n This needs to be in physical stock, not active stock
                # Issue 92701 - 2013-10-23 by CCC : utilisation de AVCBASAMT au lieu de AVC*Qté
                Call CALCABS(PFCY,
&                            LQTYSTO, [F:ITV]AVCBASAMT,
&                            [M:SDP]QTY, [M:SDPD]AMTTOT,
&                            LMNTABS, LQTYABSTOT) #MJH. X3-101694.  Use [M:SDP]QTY (physical) instead of LQTYREG (active)
                LMNTABS = arr(LMNTABS,WRND_SOC)
                #---- Répartition de l'absorbé sur les lots-lignes doc
                # Les prix des différentes lignes de doc doivent être égaux après la régul (cas des suivis de prod sur OF avec prévisionnel recalculé en cours de prod)
                # Mt = montant total de toutes les lignes de doc avant régul
                # Mi = Montant d'une ligne de doc avant régul
                # dt = variation de montant total sur toutes les lignes de doc
                # di = variation d'une ligne de doc
                # Qt = quanttité totale de toutes les lignes de doc
                # Qi = quantité d'une ligne de doc
                # On a donc : (Mt + dt)/Qt = (Mi+di)/Qi
                # => di = (Mt+dt)*Qi/Qt - Mi
                # At = Montant total absorbé
                # Nt = Montant total non absorbé
                # Ai = Montant absrobé par la ligne de doc
                # Ni = Montant non absorbé par la ligne de doc
                # => di = Ai+Ni et dt = At+Nt
                # => di = (Mt+At+Nt)*Qi/Qt - Mi
                # => di = (Mt+At)*Qi/Qt - Mi + Nt*Qi/Qt
                #         \________________/   \______/
                #                 Ai              Ni

                For I=0 To [M:SRW]NBLIG-2
                    [M:SRW]AMTABS(I) = arr(([M:SDPO]AMTTOT+LMNTABS)*[M:SRW]QTYPHY(I)/LQTY2ABSTOT-[M:SRW]AMTORI(I),WRND_SOC)
                    [M:SRW]AMTNABS(I) = arr(([M:SDPD]AMTTOT-LMNTABS)*[M:SRW]QTYPHY(I)/LQTY2ABSTOT,WRND_SOC)
                Next
                [M:SRW]AMTABS([M:SRW]NBLIG-1) = LMNTABS - sum([M:SRW]AMTABS)
                [M:SRW]AMTNABS([M:SRW]NBLIG-1) = [M:SDPD]AMTTOT - LMNTABS - sum([M:SRW]AMTNABS)

            When 3:    #----- Absorption base lot
                # On ne peut pas faire une absorption base lot si on ne régularise pas toute la qté
                # Ou alors il faudrait que le(s) lot(s) soi(en)t précisé(s)
                If LQTYREG<>sum([M:SRW]QTYSTUNOW)
                    # Issue 79670 - 2012-01-27 by CCC : Le cas d'une ligne de doc mono-lot peut être traitée
                    If sigma(0,[M:SRW]NBLIG-1,([M:SRW]LOT(indcum)=[M:SRW]LOT(0))&([M:SRW]SLO(indcum)=[M:SRW]SLO(0)))<>[M:SRW]NBLIG
                        PRET=5
                        GOK =0
                        End
                    Endif
                Endif
                # Issue 95614 - 2014-03-05 by CCC : LCUMMNTABS was not reset for each lot
                #                                   Variances are computed in order to have the same unit value for all lots
                LAMT2ABSTOT = [M:SDPO]AMTTOT+[M:SDPD]AMTTOT
                # Issue 112666 & 114528 09.2016 by CCC : the distribution of amount is by physical quantity (as it's done during creation)
                #LQTY2ABSTOT = [M:SDPO]QTY

                # Issue 104485 - 2014-12-17 by CCC : if modification of charges on inter-sites receipt
                #    only amount of delta has to be distributed amongst each lot depending on their quantity
                If PTYPREG=6
                    # Receipt price modification, for safety, read PTH
                    If clalev([F:PTH])=0 : Local File PRECEIPT [PTH] : Endif
                    If [F:PTH]PTHNUM<>PNUMREG
                        Read [PTH]PTH0=PNUMREG
                    Endif
                    If [F:PTH]BETFCY=2 & [F:PTH]BETCPY<>2
                        LAMT2ABSTOT = [M:SDPD]AMTTOT
                    Endif
                Endif

                For I=0 To [M:SRW]NBLIG-1
                    If I=0 | !sigma(0,I-1,[M:SRW]SLO(I)=[M:SRW]SLO(indcum) & [M:SRW]LOT(I)=[M:SRW]LOT(indcum))
                        LQTYLOTPHY = sigma(I,[M:SRW]NBLIG-1,[M:SRW]QTYPHY(indcum)*([M:SRW]LOT(indcum)=[M:SRW]LOT(I) & [M:SRW]SLO(I)=[M:SRW]SLO(indcum)))
                        LQTYLOT    = sigma(I,[M:SRW]NBLIG-1,[M:SRW]QTYSTU(indcum)*([M:SRW]LOT(indcum)=[M:SRW]LOT(I) & [M:SRW]SLO(I)=[M:SRW]SLO(indcum)))
                        # Issue 104485 - 2014-12-17 by CCC
                        If PTYPREG=6 & [F:PTH]BETFCY=2 & [F:PTH]BETCPY<>2
                            LAMTORILOT=0
                            # Issue 112666 & 114528 09.2016 by CCC
                            #LAMT2ABS = arr( LAMT2ABSTOT*LQTYLOT/LQTY2ABSTOT, WRND_SOC)
                            LAMT2ABS = arr( LAMT2ABSTOT*LQTYLOTPHY/LQTY2ABSTOT, WRND_SOC)
                        Else
                            LAMTORILOT = sigma(I,[M:SRW]NBLIG-1,[M:SRW]AMTORI(indcum)
&                                                              *([M:SRW]LOT(I)=[M:SRW]LOT(indcum) & [M:SRW]SLO(I)=[M:SRW]SLO(indcum)))
                            # Issue 112666 & 114528 09.2016 by CCC
                            #LAMT2ABS = arr( LAMT2ABSTOT*LQTYLOT/LQTY2ABSTOT
                            LAMT2ABS = arr( LAMT2ABSTOT*LQTYLOTPHY/LQTY2ABSTOT
&                                         - LAMTORILOT,
&                                         WRND_SOC)
                        Endif
                        Raz [F:SLF]
                        If [M:SRW]SLO(I)<>""
                            Read [SLF]SLF0=PITM;[M:SRW]LOT(I);[M:SRW]SLO(I);PFCY
                        Else
                            Filter [SLF] Where ITMREF=PITM & LOT=[M:SRW]LOT(I) & STOFCY=PFCY
                            Read [SLF] First
                            Filter [SLF]
                        Endif
# CCC (2010-05-19) Bug 64737 : En V6, plus de conversion
#                        Call CONVERT2(GSYSCUR,GLOCALDEV,GLOCALDEV,GCHGTYP,date$,
#&                                     [F:SLF]AVCBASAMT,LOTCSTDEV,PRET) From TRTDEV
#                        If PRET
#                            PRET=6
#                            GOK=0
#                            Break
#                        Endif
                        Call CALCABS(PFCY,
&                                    [M:SRW]QTYSTOLOT(I), [F:SLF]AVCBASAMT,
&                                    LQTYLOTPHY, LAMT2ABS,
&                                    LMNTABS, LQTYTMP) # Issue 112666 & 114528 09.2016 by CCC : use LQTYLOTPHY (physical qty) instead of LQTYLOT (active qty)
                        LMNTABS = arr(LMNTABS,WRND_SOC)
                        LQTYABSTOT += LQTYTMP
                        #---- Répartition de l'absorbé sur les lots-lignes doc
                        LCUMQTETRT = LQTYLOT
                        Raz LCUMMNTABS, LCUMMNTNABS
                        J = 0
                        While J<[M:SRW]NBLIG
                            Raz K
                            J = sigma(J,[M:SRW]NBLIG-1,(indcum+1)
&                                               *(  [M:SRW]LOT(indcum)=[M:SRW]LOT(I)
&                                                 & [M:SRW]SLO(indcum)=[M:SRW]SLO(I)
&                                                 & K=0 & sigma(K=1,1,1) ) )
                            If J=0
                                Break
                            Endif
                            J-=1
                            If LCUMQTETRT > [M:SRW]QTYSTU(J)
                                [M:SRW]AMTABS(J) = arr((LAMTORILOT
&                                                      +LMNTABS)
&                                                     *[M:SRW]QTYSTU(J)/LQTYLOT
&                                                     -[M:SRW]AMTORI(J),WRND_SOC)
                                [M:SRW]AMTNABS(J) = arr((LAMT2ABS-LMNTABS)*[M:SRW]QTYSTU(J)/LQTYLOT,WRND_SOC)
                                LCUMQTETRT -= [M:SRW]QTYSTU(J)
                            Else
                                [M:SRW]AMTABS(J) = LMNTABS-LCUMMNTABS
                                # Issue 82753 - 2012-06-07 by CCC
                                #[M:SRW]AMTNABS(J) = [M:SDPD]AMTTOT-LMNTABS-LCUMMNTNABS
                                [M:SRW]AMTNABS(J) = LAMT2ABS-LMNTABS-LCUMMNTNABS
                            Endif
                            LCUMMNTABS += [M:SRW]AMTABS(J)    # sert pour éviter les erreurs d'arrondis
                            LCUMMNTNABS += [M:SRW]AMTNABS(J)
                            J+=1
                        Wend
                        LAMT2ABSTOT-=LCUMMNTABS+LCUMMNTNABS+LAMTORILOT
                        # Issue 112666 & 114528 09.2016 by CCC
                        #LQTY2ABSTOT-=LQTYLOT
                        LQTY2ABSTOT-=LQTYLOTPHY
                        If LQTY2ABSTOT=0
                            Break
                        Endif
                    Endif
                Next
        Endcase
    Endif
#    If GACTDECCST
#        Gosub CALCDETABS
#    Endif
Else
    For I=0 To [M:SRW]NBLIG-2
        # Issue 112666 & 114528 09.2016 by CCC : the distribution of amount is by physical quantity (as it's done during creation)
        #[M:SRW]AMTNABS(I) = arr([M:SDPD]AMTTOT*[M:SRW]QTYSTU(I)/[M:SDPO]QTY,WRND_SOC)
        [M:SRW]AMTNABS(I) = arr([M:SDPD]AMTTOT*[M:SRW]QTYPHY(I)/LQTY2ABSTOT,WRND_SOC)
    Next
    [M:SRW]AMTNABS([M:SRW]NBLIG-1) = [M:SDPD]AMTTOT - sum([M:SRW]AMTNABS)
Endif

#121495.n MJH
#When coming from an assembly, if the finished products price was manually entered,
#we dont want it to recalculate after modification of issues for its component.
If dim(SKIP_PARENT) > 0  and SKIP_PARENT = [F:ITV]ITMREF
  [M:SRW]AMTABS = 0
Endif

If PRET
    GOK=0
    End
Endif

For I=0 To [M:SRW]NBLIG-1
    [M:SRW]AMTABS2(I)  = [M:SRW]AMTABS(I)
    [M:SRW]AMTNABS2(I) = [M:SRW]AMTNABS(I)
Next

# Calcul des dates d'imputation pour chaque ligne de doc en fonction du statut de la période
Raz LIPT, LCTRIPT, PMNTNABS2, LCTRIPTOK
Raz GPE
# !! PE identique dans FUNWIPMFC
GPOINT="CTRIPTADJ"    #CHECK IGNORE_LINE
Gosub ENTREE From EXEFNC
If !GPE
    For INDLIG=0 To [M:SRW]NBLIG-1
        If LIPT<>[M:SRW]IPTDAT(INDLIG)
            Raz mkstat
            Call STKCTRIPT([M:SRW]IPTDAT(INDLIG),PFCY,"123") From STKLIB
            If mkstat=2
                # CCC (2010-05-07) Bug 64095 : Pouvoir annuler la validation si mouvement hors période ouverte
                # Issue 113330 - 2016-01-06 by CCC : Display message during receipt closing too
                If LCTRIPTOK=0
&                & ( (clalev([M:MWF0])>0 & [M:MWF0]VCRNUM<>"" & dim(GISSADJ)<=0)
&                   |(clalev([M:PIH0])>0)
&                   |(clalev([M:PTH0])>0) )
                    LCTRIPTOK=2
                    # Issue 113330 - 2016-01-06 by CCC : Risk of major impact on stock valuation
                    #Call OUINON(GMESSAGE+"\"+mess(205,100,1),LCTRIPTOK) From GESECRAN
                    Call OUINON(GMESSAGE+"\"+mess(442,184,1)+"\"+mess(205,100,1),LCTRIPTOK) From GESECRAN
                    If LCTRIPTOK=1
                        PRET=7
                        GOK=0
                        End
                    Endif
                Else
                    Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
                Endif
            Endif
            Raz GMESSAGE
            LCTRIPT(INDLIG)=mkstat
            LIPT = [M:SRW]IPTDAT(INDLIG)
        Else
            LCTRIPT(INDLIG)=LCTRIPT(INDLIG-1)
        Endif
        If LCTRIPT(INDLIG)=2
            PMNTNABS2 += [M:SRW]AMTABS(INDLIG)
            [M:SRW]AMTNABS(INDLIG) += [M:SRW]AMTABS(INDLIG)
            [M:SRW]AMTABS(INDLIG) = 0
            If GACTVLT2
                [M:SRW]AMTNABS2(INDLIG) += [M:SRW]AMTABS2(INDLIG)
                [M:SRW]AMTABS2(INDLIG) = 0
            Endif

              # Issue number 109768 - 2016-02-11 by STLIG : Original stock movement date invalid.
              # Use accounting date else latest open period (stock) start date.
              [M:SRW]IPTDAT(INDLIG) = PIPTDAT
              Call STKCTRIPT([M:SRW]IPTDAT(INDLIG),PFCY,"123") From STKLIB
              If (mkstat = 2)
                For [PER] Where CPY=GSOCIETE & LEDTYP=GTYPGEN & PERSTR<=date$ & PERSTR>PIPTDAT & PERSTOSTA<>4
                    [M:SRW]IPTDAT(INDLIG) = [F:PER]PERSTR
                    mkstat = 0
                    Break
                Next
                If (mkstat = 2)
                  PRET = 7
                  GOK = 0
                  End
                Endif
              Endif

        Endif
    Next
Endif

Local Char LMES(250)(2)
Raz LMES
LMES(0)="before: AMTABS"
LMES(1)="before: AMTNABS"
For I=0 To [M:SRW]NBLIG-1
    LMES(0)-=num$(I)-"->"-num$([M:SRW]AMTABS(I))-";"
    LMES(1)-=num$(I)-"->"-num$([M:SRW]AMTNABS(I))-";"
Next

If GACTDECCST
    Gosub CALCDETABS
Endif

Call ECRTRACE(LMES(0),0) From STKVAL
Call ECRTRACE(LMES(1),0) From STKVAL
Raz LMES
LMES(0)="after: AMTABS"
LMES(1)="after: AMTNABS"
For I=0 To [M:SRW]NBLIG-1
    LMES(0)-=num$(I)-"->"-num$([M:SRW]AMTABS(I))-";"
    LMES(1)-=num$(I)-"->"-num$([M:SRW]AMTNABS(I))-";"
Next
Call ECRTRACE(LMES(0),0) From STKVAL
Call ECRTRACE(LMES(1),0) From STKVAL

#---- Init des variables paramètres de màj ----#
If find([F:TCM]ISSVLTCOD,5,8) | GACTVLT2 & find([F:TCM]ISSVLTCOD(1),5,8)
    LMODSTP = 4
Else
    # Issue 83455 - 2013-03-28 by CCC
    Call PARAM(PFCY,"ABSLIM",WPAR) From ADOVAL
    If WPAR="2"
        LMODSTP = 4
    Else
        LMODSTP = 0
    Endif
Endif

LUPDTAB = 1+2+4+8+16    # Par défaut on met tout à jour

GPOINT="BEFREGUL"
Gosub ENTREE From EXEFNC

SRWCOR=0
If GACTDECCST
  SRWCOR=2
#  If find(GUSER,"GH","CCC")
#     Call OUINON("Correction [M:SRW]",SRWCOR) From GESECRAN
#  Endif
  If SRWCOR=2
   SRWCOR=0
   Case [F:TCM]ISSVLTCOD
     When 4 : If mod(LUPDTAB,16)>=8 : SRWCOR=4 : Endif
     When 5 : If mod(LUPDTAB,2)>=1  : SRWCOR=5 : Endif
     When 6 : If mod(LUPDTAB,4)>=2  : SRWCOR=6 : Endif
   Endcase
  Else
   SRWCOR=0
  Endif
Endif
If SRWCOR : Gosub COR_DEB : Endif

$MAJ_TABLE
If find(SRWCOR,0,5,6)
  For INDLIG=0 To [M:SRW]NBLIG-1
      #--------- Mise à jour de la table STOCOST ------------#
      If mod(LUPDTAB,2)>=1 & find(SRWCOR,0,5)
&     & (INDLIG=0 | !sigma(0,INDLIG-1,[M:SRW]VCRNUM(INDLIG)=[M:SRW]VCRNUM(indcum) & [M:SRW]VCRLIN(INDLIG)=[M:SRW]VCRLIN(indcum)))
          Gosub MAJ_FIFO
          If PRET : Break : Endif
      Endif

      #--------- Mise à jour de la table STOLOTFCY ------------#
      If mod(LUPDTAB,4)>=2 & find(SRWCOR,0,6)
&     & (INDLIG=0 | !sigma(0,INDLIG-1,[M:SRW]SLO(INDLIG)=[M:SRW]SLO(indcum) & [M:SRW]LOT(INDLIG)=[M:SRW]LOT(indcum)))
          Gosub MAJ_LOT
          If PRET : Break : Endif
      Endif

      #--------- Mise à jour des mouvements ------------#
      Raz LCUMMNTABS, LCUMMNTNABS
      If mod(LUPDTAB,8)>=4 & SRWCOR=0
          Gosub MAJ_MVT     # Met à jour LCUMMNTABS et LCUMMNTNABS avec les valeur de VARVAL et AMTDEV pour màj ITH
          If PRET : Break : Endif
      Endif

      #--------- Mise à jour table ITMMVTHIS ------------#
      If mod(LUPDTAB,32)>=16 & SRWCOR=0
          Gosub ECR_ITMMVTHIS
          If PRET : Break : Endif
      Endif
  Next
  If !PRET & find(SRWCOR,5,6)
     Gosub COR_FIN : Goto MAJ_TABLE
  Endif
Endif


If !PRET & find(SRWCOR,0,4) & mod(LUPDTAB,16)>=8
    Gosub ECR_ITMMVT
    If SRWCOR : Gosub COR_FIN : Goto MAJ_TABLE : Endif
Endif

If !PRET
    PMNTABS  = sum([M:SRW]AMTABS)
    PMNTNABS = sum([M:SRW]AMTNABS)
Else
    GOK=0
Endif

Close Local File [SJV], [SJO], [STJ], [STJ1], [STJ2], [ITM], [ITV], [ITH], [SLF], [STP]

End

############################################
$LECFIC

# Chargement de l'arrondi des montants et de GSOCIETE
Call GETDEV(PFCY) From DEVSUB
# Issue 80993 - 2012-05-10 by CCC
#If clalev([F:TCU]) = 0 : Local File TABCUR [TCU] : Endif
#Read [TCU] TCU0=GLOCALDEV
#If !fstat [L]WRND_SOC=[F:TCU]CURRND Else [L]WRND_SOC=0.01 : Endif
#WRND_SOC = 10^-7

If dim(GRNDVAL)<=0 : Global Decimal GRNDVAL : Endif
Call INIRNDVAL("","") From STKVALECR
WRND_SOC=GRNDVAL

# Chargement de la méthode de valo
Local Char LTCM(GLONTCM)
# Lecture ITMMASTER si nécessaire
If clalev([F:ITM]) =0  Local File ITMMASTER  [ITM]   Endif
If [F:ITM]ITMREF<>PITM
    Read [ITM]ITM0=PITM
    If fstat
        GOK = 0
        Call RSTA("ITM",PITM) From GLOCK
        PRET=1
        Return
    Endif
Endif

Call GETTCM(PITM,PFCY,LTCM,PRET) From STKVAL

#--- Lecture avec le code mouvement ----#
Read [TVM]TVM0=LTCM;PTRSTYP;PTRSCOD
If fstat & PTRSCOD<>""
    #---- Si code mouvement non trouvé pour ce type de pièce, on cherche sans code mouvement ---#
    Read [TVM]TVM0=LTCM;PTRSTYP;""
Endif
If fstat
    #--- Si pas d'exception : lecture de TABCOSTMET ----#
    If LTCM <> [F:TCM]VLTCOD
        Read [TCM]TCM0=LTCM
        If fstat
            GOK = 0
            Call RSTA("TCM",LTCM) From GLOCK
            PRET=1
            Return
        Endif
    Endif

    LPRINAT = [F:TCM]RCPVLTCOD+1
    LREG = [F:TCM]PRIREG
    Call ECRTRACE("[F:TCM]PRIREG="+num$([F:TCM]PRIREG),0) From STKVAL
Else
    LPRINAT = [F:TVM]MVTVLT+1
    LREG = [F:TVM]PRIREGX
    Call ECRTRACE("[F:TVM]PRIREGX="+num$([F:TVM]PRIREGX),0) From STKVAL
Endif

If LREG = 1
    WMAXABSCOD = 1
Else
    Call PARAM(PFCY,"MAXABSCOD",WPAR) From ADOVAL
    WMAXABSCOD = val(WPAR)
Endif

Read [ITV]ITV0=PITM;PFCY

Return

#####################################################
$REMPTAB
    Raz I
    # Issue 112666 & 114528 09.2016 by CCC : read STL to get potency
    If [F:ITM]STOMGTCOD=3
        If ([STL]ITMREF<>PITM | [F:STL]LOT<>[F:STJ]LOT | [F:STL]SLO<>[F:STJ]SLO)
            [F:STL]POT=100
            Read [STL]STL0=PITM;[F:STJ]LOT;[F:STJ]SLO
        Endif
    Else
        [F:STL]POT=100
    Endif
    LIND = sigma(0,[M:SRW]NBLIG-1, (indcum+1)
&                           *(  [M:SRW]LOT(indcum)=[F:STJ]LOT
&                             & [M:SRW]SLO(indcum)=[F:STJ]SLO
&                             & [M:SRW]VCRTYP(indcum)=[F:STJ]VCRTYP
&                             & [M:SRW]VCRNUM(indcum)=[F:STJ]VCRNUM
&                             & [M:SRW]VCRLIN(indcum)=[F:STJ]VCRLIN
&                             & I=0 & sigma(I=1,1,1)))
    If LIND=0
        I = sigma(0,[M:SRW]NBLIG-1, (indcum+1)
&                            *(  [M:SRW]LOT(indcum)=[F:STJ]LOT
&                              & [M:SRW]SLO(indcum)=[F:STJ]SLO
&                              & I=0 & sigma(I=1,1,1)))
        If I>0
            [M:SRW]QTYSTOLOT([M:SRW]NBLIG) = [M:SRW]QTYSTOLOT(I-1)
        Else
            [M:SRW]QTYSTOLOT([M:SRW]NBLIG) = func STKLIB.QTYLOT(PITM,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]STOFCY)
            LTOTSTOLOT += [M:SRW]QTYSTOLOT([M:SRW]NBLIG)
        Endif
        [M:SRW]LOT([M:SRW]NBLIG) = [F:STJ]LOT
        [M:SRW]SLO([M:SRW]NBLIG) = [F:STJ]SLO
        [M:SRW]VCRTYP([M:SRW]NBLIG) = [F:STJ]VCRTYP
        [M:SRW]VCRNUM([M:SRW]NBLIG) = [F:STJ]VCRNUM
        [M:SRW]VCRLIN([M:SRW]NBLIG) = [F:STJ]VCRLIN
        [M:SRW]IPTDAT([M:SRW]NBLIG) = [F:STJ]IPTDAT
        [M:SRW]QTYSTU([M:SRW]NBLIG) = [F:STJ]ACTQTY
        # Issue 112666 & 114528 09.2016 by CCC : get physical quantity and active quantity with actual potency
        [M:SRW]QTYSTUNOW([M:SRW]NBLIG) = [F:STJ]QTYSTU * [F:STL]POT/100
        [M:SRW]QTYPHY([M:SRW]NBLIG) = [F:STJ]QTYSTU
        If LMVTORI
            [M:SRW]AMTORI([M:SRW]NBLIG) = [F:STJ]VARVAL+LDEV
        Else
            [M:SRW]AMTORI([M:SRW]NBLIG) = [F:STJ]AMTVAL+LDEV
        Endif
        [M:SRW]NBLIG+=1
        If [M:SRW]NBLIG>=dim([M:SRW]LOT)
            PRET = 8
            GOK = 0
        Endif
    Else
        [M:SRW]QTYSTU(LIND-1) += [F:STJ]ACTQTY
        # Issue 112666 & 114528 09.2016 by CCC : get physical quantity and active quantity with actual potency
        [M:SRW]QTYSTUNOW(LIND-1) += [F:STJ]QTYSTU * [F:STL]POT/100
        [M:SRW]QTYPHY(LIND-1) += [F:STJ]QTYSTU
        If LMVTORI
            [M:SRW]AMTORI(LIND-1) += [F:STJ]VARVAL+LDEV
        Else
            [M:SRW]AMTORI(LIND-1) += [F:STJ]AMTVAL+LDEV
        Endif
    Endif
Return

##############################################################

Subprog UPD_STOCOST(PITM, PFCY)
Value Char    PITM(), PFCY()

Local Integer J, INDLIG, SRWCOR
Local Decimal LCOEF, LTOTCST, WRND_SOC

[L]WRND_SOC = [V]GRNDVAL
[L]LCOEF = 1

Call ECRTRACE("---------------------- STOCOST -----------------",0) From STKVAL
Gosub SAVDETSTP
Rewrite [STP]
End

##############################################################
$MAJ_FIFO
Call ECRTRACE("---------------------- STOCOST -----------------",0) From STKVAL

# somme des [M:SRW]AMTABS pour un triplet (type de doc, n° de doc et n° de ligne de doc)
# correspondant à l'indice INDLIG
REQ ="SELECT sum(QTYSTUACT_0)"
REQ+=" From STOCOST"
REQ+=" Where ITMREF_0 = '"+PITM+"'"
REQ+=  " and STOFCY_0 = '"+PFCY+"'"
Raz LQTYSTP
For (Decimal QTYSTP) From num$(GTYPDBA*2+1) Sql REQ As [STPQ]
    LQTYSTP=[F:STPQ]QTYSTP
    Break
Next
If LQTYSTP<>[F:ITV]AVCBASQTY
    PRET = 9
    GOK=0
    Call ECR_TRACE(PFCY-PITM-":"-mess(34,196,1)+" ITV:"+num$([F:ITV]AVCBASQTY)+" / STP:"+num$(LQTYSTP),1) From GESECRAN
    Return
Endif

LABSSTPTOT = sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]AMTABS(indcum)
&                        *( [M:SRW]VCRTYP(INDLIG)=[M:SRW]VCRTYP(indcum)
&                         & [M:SRW]VCRNUM(INDLIG)=[M:SRW]VCRNUM(indcum)
&                         & [M:SRW]VCRLIN(INDLIG)=[M:SRW]VCRLIN(indcum)))

LQTYVCR = sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]QTYSTU(indcum)
&                         *( [M:SRW]VCRTYP(INDLIG)=[M:SRW]VCRTYP(indcum)
&                         &  [M:SRW]VCRNUM(INDLIG)=[M:SRW]VCRNUM(indcum)
&                         &  [M:SRW]VCRLIN(INDLIG)=[M:SRW]VCRLIN(indcum)))

LQTYVCRNOW = sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]QTYSTUNOW(indcum)
&                         *( [M:SRW]VCRTYP(INDLIG)=[M:SRW]VCRTYP(indcum)
&                         &  [M:SRW]VCRNUM(INDLIG)=[M:SRW]VCRNUM(indcum)
&                         &  [M:SRW]VCRLIN(INDLIG)=[M:SRW]VCRLIN(indcum)))

Raz [F:STP]
Readlock [STP]STP1=PITM;PFCY;[M:SRW]VCRTYP(INDLIG);[M:SRW]VCRNUM(INDLIG);[M:SRW]VCRLIN(INDLIG)
If fstat=1
    Call FSTA("STP") From GLOCK
    GOK=0
    PRET=4
    Return
Endif

# Issue 112666 & 114528 09.2016 by CCC
#LQTYABSSTP = LQTYVCR
LQTYABSSTP = max(LQTYVCRNOW,[F:STP]QTYSTUACT)    # active quantity in STP can be bigger than expected because of potency change distributed on all FIFO elements

If mod(LMODSTP,4)>=2  # Tout ce qui a été calculé comme absorbable doit l'être sur l'élément de pile
    LQTYABSSTP = [F:STP]QTYSTUACT
Endif
Raz LCUMABSSTP, LABSSTP1

#--- 1: absorption par l'élément de pile de l'entrée en cours de régul ---#
If !fstat & LQTYABSSTP>0

    # Issue 112666 & 114528 09.2016 by CCC
    #LABSSTP1 = LABSSTPTOT * [F:STP]QTYSTUACT*LQTYPHYORI/(LQTYABSSTP*min(LQTYPHYORI,[F:ITV]AVCBASQTY))
    LABSSTP1 = LABSSTPTOT * [F:STP]QTYSTUACT/LQTYABSSTP
    # Issue X3-26696 - 2017-03-07 by ERMIL : Added checks below to avoid divide by zero
    Case WMAXABSCOD
        When 1, 2:    #---- Whole amount is absorbed / Absorption by site
            If [F:ITV]AVCBASQTY<sum([M:SRW]QTYSTUNOW) & [F:ITV]AVCBASQTY<>0
                LABSSTP1 *= sum([M:SRW]QTYSTUNOW)/[F:ITV]AVCBASQTY
            Endif

        When 3:       #---- Absorption by lot-site
            If LTOTSTOLOT<sum([M:SRW]QTYPHY) & LTOTSTOLOT<>0
                LABSSTP1 *= sum([M:SRW]QTYPHY)/LTOTSTOLOT
            Endif
    Endcase

    Call ECRTRACE("STOFCY="+[F:STP]STOFCY-"ITMREF="+[F:STP]ITMREF-"CSTCOU="+num$([F:STP]CSTCOU),0) From STKVAL
    Call ECRTRACE("    CST="+num$([F:STP]CST)-"+"-num$(LABSSTP1),0) From STKVAL
    [F:STP]CST += LABSSTP1
    Call ECRTRACE(" -->CST="+num$([F:STP]CST),0) From STKVAL
    If GACTDECCST
        If LABSSTPTOT=0
            LCOEF=0
        Else
            LCOEF = LABSSTP1/LABSSTPTOT
        Endif
        Gosub SAVDETSTP
    Endif
    If SRWCOR : Return : Endif
    Rewrite [STP]
    LQTYABSSTP -= [F:STP]QTYSTUACT
    LCUMABSSTP += LABSSTP1
Elsif SRWCOR
    Return
Endif

#--- 2: absorption par les autres éléments de pile si autorisé par PE ---#
If (LABSSTPTOT-LABSSTP1)<>0 & mod(LMODSTP,2)>=1
    # Calcul de la quantité des lignes de documents encore dans la pile fifo
    Raz LQTYSTP
    For J=0 To [M:SRW]NBLIG-1
        If sigma(0,J-1,[M:SRW]VCRTYP(J)=[M:SRW]VCRTYP(indcum)
&                     &[M:SRW]VCRNUM(J)=[M:SRW]VCRNUM(indcum)
&                     &[M:SRW]VCRLIN(J)=[M:SRW]VCRLIN(indcum))=0
          Raz [F:STP]
          Read [STP]STP1=PITM;PFCY;[M:SRW]VCRTYP(J);[M:SRW]VCRNUM(J);[M:SRW]VCRLIN(J)
          LQTYSTP += [F:STP]QTYSTUACT
        Endif
    Next
    # Boucle sur les éléments de pile autres que les documents en cours de régul
    For [STP] Where ITMREF=PITM
&                 & STOFCY=PFCY
&                 & !(VCRTYP=[M:SRW]VCRTYP(INDLIG) & VCRNUM=[M:SRW]VCRNUM(INDLIG) & VCRLIN=[M:SRW]VCRLIN(INDLIG))
        If sigma(0,[M:SRW]NBLIG-1,[F:STP]VCRTYP=[M:SRW]VCRTYP(indcum)
&                                &[F:STP]VCRNUM=[M:SRW]VCRNUM(indcum)
&                                &[F:STP]VCRLIN=[M:SRW]VCRLIN(indcum))=0
            LABSSTP = (LABSSTPTOT-LABSSTP1)*[F:STP]QTYSTUACT/abs([F:ITV]AVCBASQTY-LQTYSTP)
            Call ECRTRACE("STOFCY="+[F:STP]STOFCY-"ITMREF="+[F:STP]ITMREF-"CSTCOU="+num$([F:STP]CSTCOU),0) From STKVAL
            Call ECRTRACE("    CST="+num$([F:STP]CST)-"+"-num$(LABSSTP),0) From STKVAL
            [F:STP]CST += LABSSTP
            Call ECRTRACE(" -->CST="+num$([F:STP]CST),0) From STKVAL
            If GACTDECCST
                If LABSSTPTOT=0
                    LCOEF=0
                Else
                    LCOEF = LABSSTP/LABSSTPTOT
                Endif
                Gosub SAVDETSTP
            Endif
            Rewrite [STP]
            LCUMABSSTP += LABSSTP
        Endif
    Next
Endif

#--- 3: Répartition dans le non absorbé de ce qui n'a pas pu être absorbé par la pile ---#
If LCUMABSSTP<>LABSSTPTOT & mod(LMODSTP,8)>=4
    For J=INDLIG To [M:SRW]NBLIG-1
        If [M:SRW]VCRTYP(INDLIG)=[M:SRW]VCRTYP(J)
&          & [M:SRW]VCRNUM(INDLIG)=[M:SRW]VCRNUM(J)
&          & [M:SRW]VCRLIN(INDLIG)=[M:SRW]VCRLIN(J)
            # Issue 73371 - 2011-04-19 by CCC
            #If find([F:TCM]ISSVLTCOD,5,8)
                LMNTTMP = arr([M:SRW]AMTABS(J)*LCUMABSSTP/LABSSTPTOT,WRND_SOC)
                [M:SRW]AMTNABS(J) += [M:SRW]AMTABS(J)-LMNTTMP
                [M:SRW]AMTABS(J)   = LMNTTMP
                If GACTDECCST
                    For I=0 To GACTMAT-1
                        LMNTTMP = arr([M:SRW]MATCST(GACTMAT*J+I)*LCUMABSSTP/LABSSTPTOT,WRND_SOC)
                        [M:SRW]DEVMATCST(GACTMAT*J+I) += [M:SRW]MATCST(GACTMAT*J+I)-LMNTTMP
                        [M:SRW]MATCST(GACTMAT*J+I)     = LMNTTMP
                    Next
                    For I=0 To GACTMAC-1
                        LMNTTMP = arr([M:SRW]MACCST(GACTMAC*J+I)*LCUMABSSTP/LABSSTPTOT,WRND_SOC)
                        [M:SRW]DEVMACCST(GACTMAC*J+I) += [M:SRW]MACCST(GACTMAC*J+I)-LMNTTMP
                        [M:SRW]MACCST(GACTMAC*J+I)     = LMNTTMP
                    Next
                    For I=0 To GACTLAB-1
                        LMNTTMP = arr([M:SRW]LABCST(GACTLAB*J+I)*LCUMABSSTP/LABSSTPTOT,WRND_SOC)
                        [M:SRW]DEVLABCST(GACTLAB*J+I) += [M:SRW]LABCST(GACTLAB*J+I)-LMNTTMP
                        [M:SRW]LABCST(GACTLAB*J+I)     = LMNTTMP
                    Next
                    LMNTTMP = arr([M:SRW]SCOCST(J)*LCUMABSSTP/LABSSTPTOT,WRND_SOC)
                    [M:SRW]DEVSCOCST(J) += [M:SRW]SCOCST(J)-LMNTTMP
                    [M:SRW]SCOCST(J)     = LMNTTMP
                    LMNTTMP = arr([M:SRW]INVDTACST(J)*LCUMABSSTP/LABSSTPTOT,WRND_SOC)
                    [M:SRW]DEVINVDTACST(J) += [M:SRW]INVDTACST(J)-LMNTTMP
                    [M:SRW]INVDTACST(J)     = LMNTTMP

                    LMNTTMP = arr([M:SRW]OVEMATCST(J)*LCUMABSSTP/LABSSTPTOT,WRND_SOC)
                    [M:SRW]DEVOVEMATCST(J) += [M:SRW]OVEMATCST(J)-LMNTTMP
                    [M:SRW]OVEMATCST(J)     = LMNTTMP
                    LMNTTMP = arr([M:SRW]OVEMACCST(J)*LCUMABSSTP/LABSSTPTOT,WRND_SOC)
                    [M:SRW]DEVOVEMACCST(J) += [M:SRW]OVEMACCST(J)-LMNTTMP
                    [M:SRW]OVEMACCST(J)     = LMNTTMP
                    LMNTTMP = arr([M:SRW]OVELABCST(J)*LCUMABSSTP/LABSSTPTOT,WRND_SOC)
                    [M:SRW]DEVOVELABCST(J) += [M:SRW]OVELABCST(J)-LMNTTMP
                    [M:SRW]OVELABCST(J)     = LMNTTMP
                    LMNTTMP = arr([M:SRW]OVESCOCST(J)*LCUMABSSTP/LABSSTPTOT,WRND_SOC)
                    [M:SRW]DEVOVESCOCST(J) += [M:SRW]OVESCOCST(J)-LMNTTMP
                    [M:SRW]OVESCOCST(J)     = LMNTTMP
                Endif
            #Endif
            If GACTVLT2 #& find([F:TCM]ISSVLTCOD(1),5,8)
                LMNTTMP = arr([M:SRW]AMTABS2(J)*LCUMABSSTP/LABSSTPTOT,WRND_SOC)
                [M:SRW]AMTNABS2(J) += [M:SRW]AMTABS2(J)-LMNTTMP
                [M:SRW]AMTABS2(J)   = LMNTTMP
            Endif
        Endif
    Next
Endif
Return

##############################################################

Subprog UPD_STOLOTFCY(PITM, PFCY)
Value Char    PITM(), PFCY()

Local Integer I, J, PRET, INDLIG,SRWCOR
Local Decimal LAMTABSTOT, LABSSLF, LCUMABSSLF, LMNTTMP, LCOEF, LTOTCST, WRND_SOC

[L]WRND_SOC = [V]GRNDVAL
Gosub MAJ_LOT
End

##############################################################
$MAJ_LOT
Call ECRTRACE("---------------------- STOLOTFCY -----------------",0) From STKVAL

Readlock [SLF]SLF0 = PITM;[M:SRW]LOT(INDLIG);[M:SRW]SLO(INDLIG);PFCY
If fstat
# Issue 88230 & 89851 - 2013-05-17 by CCC : La fiche lot peut ne pas exister dans certains cas => on ne bloque pas
#    Call FSTA("SLF") From GLOCK
#    GOK=0
#    PRET=4
    If [M:SRW]QTYSTU(INDLIG)<>0
        Call ECR_TRACE(mess(394,184,1)-PITM-PFCY-[M:SRW]LOT(INDLIG)-[M:SRW]SLO(INDLIG),-1) From GESECRAN
    Endif
    Return
Endif

# Montant total absorbé par le lot
LAMTABSTOT = sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]AMTABS(indcum)*([M:SRW]LOT(INDLIG)=[M:SRW]LOT(indcum) & [M:SRW]SLO(INDLIG)=[M:SRW]SLO(indcum)))
Raz LCUMABSSLF

If [M:SRW]QTYSTOLOT(INDLIG)<>0
    # Issue 112666 & 114528 09.2016 by CCC
    #LABSSLF = LAMTABSTOT*[F:SLF]AVCBASQTY/[M:SRW]QTYSTOLOT(INDLIG)
    #LCOEF = [F:SLF]AVCBASQTY/[M:SRW]QTYSTOLOT(INDLIG)
    LCOEF = ([F:SLF]AAACUMQTY+[F:SLF]QQQCUMQTY+[F:SLF]RRRCUMQTY)/[M:SRW]QTYSTOLOT(INDLIG)
    LABSSLF = LAMTABSTOT*LCOEF
    If LABSSLF + [F:SLF]AVCBASAMT < 0
        LABSSLF = -[F:SLF]AVCBASAMT
        LCOEF = LABSSLF/LAMTABSTOT
    Endif
Else
    Raz LABSSLF, LCOEF
Endif

Call ECRTRACE("ITMREF="+[F:SLF]ITMREF-"LOT="+[F:SLF]LOT-"SLO="+[F:SLF]SLO,0) From STKVAL
If [F:SLF]AVCBASQTY<>0
    Call ECRTRACE("    AVCBASAMT="+num$([F:SLF]AVCBASAMT)-"+"-num$(LABSSLF),0) From STKVAL
    LCUMABSSLF += LABSSLF
    [F:SLF]AVCBASAMT += LABSSLF
    [F:SLF]AVCBASAMT = arr([F:SLF]AVCBASAMT,WRND_SOC)
Else
    Call ECRTRACE(" AVCBASQTY=0",0) From STKVAL
    [F:SLF]AVCBASAMT = 0
Endif

If GACTDECCST
#       If LAMTABSTOT=0
#           LCOEF=0
#       Else
#           LCOEF = LABSSLF/LAMTABSTOT
#       Endif
    Gosub SAVDETSLF
Endif
If SRWCOR : Return : Endif

# Issue 87150 - 2013-01-22 by CCC : Si rien n'a changé sur le lot & que la qté=0, on ne change pas son prix unitaire
If !(LABSSLF=0 & [F:SLF]AVCBASAMT=0 & [F:SLF]AVCBASQTY=0)
    If [F:SLF]AVCBASAMT=0
        # Il faut forcer le PM lot à 0 car il est utilisé dans la valo
        [F:SLF]AVC=0
        If GACTDECCST
            For I=0 To dim([F:SLF]AMATAVC)-1
                [F:SLF]AMATAVC(I) = 0
            Next
            [F:SLF]AOVEMATAVC = 0

            For I=0 To dim([F:SLF]AMACAVC)-1
                [F:SLF]AMACAVC(I) = 0
            Next
            [F:SLF]AOVEMACAVC = 0

            For I=0 To dim([F:SLF]ALABAVC)-1
                [F:SLF]ALABAVC(I) = 0
            Next
            [F:SLF]AOVELABAVC = 0

            [F:SLF]ASCOAVC = 0
            [F:SLF]AOVESCOAVC = 0

            [F:SLF]AINVDTAAVC = 0
        Endif
    Else
        Gosub UPDLOTAVC From STKVALMAJ2
    Endif
Endif

Call ECRTRACE(" -->AVCBASAMT="+num$([F:SLF]AVCBASAMT),0) From STKVAL
Call ECRTRACE(" -->AVC="+num$([F:SLF]AVC),0) From STKVAL
Rewrite [SLF]
If fstat
    PRET=4
    GOK=0
    Return
Endif

# Issue 74240 - 2011-06-10 by CCC
# Si méthode de valo PM Lot et que tout ne peut pas être absorbé par le lot,
# on crée de l'écart non absorbé
If ([F:TCM]ISSVLTCOD=6 | GACTVLT2 & [F:TCM]ISSVLTCOD(1)=6) & LCUMABSSLF<>LAMTABSTOT
    For J=INDLIG To [M:SRW]NBLIG-1
        If [M:SRW]VCRTYP(INDLIG)=[M:SRW]VCRTYP(J)
&        & [M:SRW]VCRNUM(INDLIG)=[M:SRW]VCRNUM(J)
&        & [M:SRW]VCRLIN(INDLIG)=[M:SRW]VCRLIN(J)
&        & [M:SRW]LOT(INDLIG)   =[M:SRW]LOT(J)
&        & ([M:SRW]SLO(INDLIG)="" | [M:SRW]SLO(INDLIG)  =[M:SRW]SLO(J))
            If [F:TCM]ISSVLTCOD=6
                LMNTTMP = arr([M:SRW]AMTABS(J)*LCUMABSSLF/LAMTABSTOT,WRND_SOC)
                [M:SRW]AMTNABS(J) += [M:SRW]AMTABS(J)-LMNTTMP
                [M:SRW]AMTABS(J)   = LMNTTMP
            Endif
            If GACTVLT2 & [F:TCM]ISSVLTCOD(1)=6
                LMNTTMP = arr([M:SRW]AMTABS2(J)*LCUMABSSLF/LAMTABSTOT,WRND_SOC)
                [M:SRW]AMTNABS2(J) += [M:SRW]AMTABS2(J)-LMNTTMP
                [M:SRW]AMTABS2(J)   = LMNTTMP
            Endif
        Endif
    Next
Endif
Return

###############################################################
$MAJ_MVT
    Call ECRTRACE("---------------------- STOJOU -----------------",0) From STKVAL
    # Il faut préciser l'article car pour la sous-traitance, les matières ont le même n° de document
    LQTYTRT    = [M:SRW]QTYSTU(INDLIG)
    LABSTRT    = [M:SRW]AMTABS(INDLIG)
    LNABSTRT   = [M:SRW]AMTNABS(INDLIG)
    If GACTVLT2
        LABSTRT(1) = [M:SRW]AMTABS2(INDLIG)
        LNABSTRT(1)= [M:SRW]AMTNABS2(INDLIG)
    Endif
    LIPT    = [M:SRW]IPTDAT(INDLIG)

    # Issue 118579 - 2016-11-02 by ERMIL : Exclude TRSTYP 29 for subcontract
    For [STJ2] Where STOFCY = PFCY
&                  & VCRTYP = [M:SRW]VCRTYP(INDLIG)
&                  & VCRNUM = [M:SRW]VCRNUM(INDLIG)
&                  & VCRLIN = [M:SRW]VCRLIN(INDLIG)
&                  & TRSTYP <>29
&                  & ITMREF = PITM
&                  & LOT    = [M:SRW]LOT(INDLIG)
&                  & SLO=[M:SRW]SLO(INDLIG)
&                  & REGFLG<>2

        Call ECRTRACE("STOFCY="+[F:STJ2]STOFCY-"ITMREF="+[F:STJ2]ITMREF-"IPTDAT="+num$([F:STJ2]IPTDAT)-"MVTSEQ="+num$([F:STJ2]MVTSEQ),0) From STKVAL
        Call ECRTRACE("    AMTORD="+num$([F:STJ2]AMTORD)-"AMTVAL="+num$([F:STJ2]AMTVAL)-"AMTVAL2="+num$([F:STJ2]AMTVAL2),0) From STKVAL
        Call ECRTRACE("    PRIORD="+num$([F:STJ2]PRIORD)-"PRIVAL="+num$([F:STJ2]PRIVAL)-"PRIVAL2="+num$([F:STJ2]PRIVAL2),0) From STKVAL
        If [F:STJ2]IPTDAT<>LIPT
            Gosub ECR_MVTREG2
        Else
            Gosub ECR_MVTINV
            Gosub ECR_MVTNEW
        Endif
        LCUMMNTABS  += [F:STJ]VARVAL
        LCUMMNTNABS += [F:STJ]AMTDEV
        If GACTVLT2
            LCUMMNTABS(1)  = [F:STJ]VARVAL2
            LCUMMNTNABS(1) = [F:STJ]AMTDEV2
        Endif
    Next
Return
###############################################################################
# ECR_MVTINV : Ecrit le mouvement inverse avant le mvt de régul
###############################################################################
$ECR_MVTINV
    Readlock [STJ]STJ0 = [F:STJ2]STOFCY;[F:STJ2]UPDCOD;[F:STJ2]ITMREF;[F:STJ2]IPTDAT;[F:STJ2]MVTSEQ;[F:STJ2]MVTIND
    [F:STJ]REGFLG=2
    Rewrite [STJ]
    If fstat
        Call FSTA("STJ") From GLOCK
        GOK = 0
        PRET=4
        Return
    Endif

    # Issue 91122 - 2013-09-06 by CCC : Traceability
    If [F:ITM]TRKCOD = 2
        Gosub MAJ_STOTRK_REGFLG
        If GOK<1
           Return
        Endif
    Endif

    Call ECRTRACE("Write opposite movement only with quantity",0) From STKVAL
    [F:STJ]ACTQTY = -[F:STJ]ACTQTY
    [F:STJ]QTYSTU = -[F:STJ]QTYSTU
    [F:STJ]QTYPCU = -[F:STJ]QTYPCU
    [F:STJ]AMTORD = 0
    [F:STJ]AMTVAL = 0
    [F:STJ]VARORD = 0
    [F:STJ]VARVAL = 0
    [F:STJ]AMTDEV = 0
    [F:STJ]PRINAT = 0    # Cela permet de distinguer les vrais mouvements d'annulation avec prix=0 des mouvements d'annulations dus à la régul
    If GACTVLT2
        [F:STJ]AMTVAL2= 0
        [F:STJ]VARVAL2= 0
        [F:STJ]AMTDEV2= 0
        [F:STJ]PRINAT2= 0    # Cela permet de distinguer les vrais mouvements d'annulation avec prix=0 des mouvements d'annulations dus à la régul
    Endif
    [F:STJ]AGGIFAFLG = 1
    [F:STJ]NUMVCR = ""
    [F:STJ]GTE = ""
    Raz [F:STJ]ACCDAT

    [F:STJ]VCRTYPREG = PTYPREG
    [F:STJ]VCRNUMREG = PNUMREG
    [F:STJ]VCRLINREG = PLINREG
    [F:STJ]PRIREGFLG = 2
    Call ECRSTJ(0,PRET) From STKLIB
    If PRET
        Call FSTA("STJ") From GLOCK
        PRET=4
        GOK=0
        Return
    Endif
Return

###############################################################################
# ECR_MVTNEW : Ecrit le mouvement de régularisation dans STOJOU
###############################################################################
$ECR_MVTNEW
    Local Date LSAV
    Call ECRTRACE("Write new movement",0) From STKVAL

    Gosub ALIM_STJ
    If PRET : Return : Endif

    Gosub ECR_STJ
    If PRET : Return : Endif

    LABSTRT    -= [F:STJ]VARORD
    # Issue 84936 - 2012-10-04 by CCC : PRINAT2 --> PRINAT
    # Issue 78143 - 2012-10-04 by CCC
    LNABSTRT   -= [F:STJ]AMTDEV-(!(LREG=2 & [F:STJ]PRINAT = 8))*[F:STJ]VARORD
    If GACTVLT2
        LABSTRT(1) -= [F:STJ]VARORD
        # Issue 78143 - 2012-10-04 by CCC
        LNABSTRT(1)-= [F:STJ]AMTDEV2-(!(LREG=2 & [F:STJ]PRINAT2 = 8))*[F:STJ]VARORD
    Endif

Return

###############################################################################
# ECR_MVTREG2 : Ecrit le mouvement de régularisation dans STOJOU
###############################################################################
$ECR_MVTREG2
    # Issue number 109768 - 2016-02-11 by STLIG : New stock movement date = LIPT not CREDAT ...
    Call ECRTRACE("Write new movement IPTDAT=" +LIPT +" & REGFLG=2",0) From STKVAL

    Gosub ALIM_STJ
    If PRET : Return : Endif

    [F:STJ]IPTDAT = LIPT
    [F:STJ]ACTQTY = 0
    [F:STJ]QTYSTU = 0
    [F:STJ]QTYPCU = 0
    [F:STJ]REGFLG = 2

    Gosub ECR_STJ
    If PRET : Return : Endif

    LABSTRT    -= [F:STJ]VARORD
    LNABSTRT   -= [F:STJ]AMTDEV
    If GACTVLT2
        LABSTRT(1) -= [F:STJ]VARORD
        LNABSTRT(1)-= [F:STJ]AMTDEV2
    Endif

Return

$ALIM_STJ
    [F:STJ] = [F:STJ2]
    Raz [F:SJV]
    If GACTDECCST & [F:STJ]CREMVTDAT>=GDATDECCST & GDATDECCST>[0/0/0]
        Read [SJV]SJV0 = [F:STJ]STOFCY;[F:STJ]UPDCOD;[F:STJ]ITMREF;[F:STJ]IPTDAT;[F:STJ]MVTSEQ;[F:STJ]MVTIND
        If fstat
            GOK=0
            Call FSTA("SJV") From GLOCK
            PRET=4
            Return
        Endif
    Endif

    LQTYTRT -= [F:STJ]ACTQTY
    If LQTYTRT=0    # Dernier enregistrement à traiter    (en évitant un calcul on évite les erreurs d'arrondi)
        [F:STJ]VARORD  = LABSTRT
        [F:STJ]AMTORD += [F:STJ]VARORD
        If LREG=2 & LPRINAT = 8    #Prix de l'ordre
            [F:STJ]AMTDEV  = LNABSTRT
            [F:STJ]AMTVAL += LABSTRT
            [F:STJ]VARVAL  = LABSTRT
            [F:STJ]PRINAT = 8
        Else
            [F:STJ]AMTDEV  = LABSTRT + LNABSTRT
            [F:STJ]VARVAL = 0
            #[F:STJ]AMTVAL inchangé
        Endif
        If GACTVLT2
            If LREG=2 & [F:STJ]PRINAT2 = 8    #Prix de l'ordre
                [F:STJ]AMTDEV2  = LNABSTRT(1)
                [F:STJ]AMTVAL2 += LABSTRT(1)
                [F:STJ]VARVAL2  = LABSTRT(1)
            Else
                [F:STJ]AMTDEV2  = LABSTRT(1) + LNABSTRT(1)
                [F:STJ]VARVAL2  = 0
                #[F:STJ]AMTVAL2 inchangé
            Endif
        Endif
    Else
        [F:STJ]VARORD  = arr([M:SRW]AMTABS(INDLIG)*[F:STJ]ACTQTY/[M:SRW]QTYSTU(INDLIG),WRND_SOC)
        [F:STJ]AMTORD += [F:STJ]VARORD
        If LREG=2 & [F:STJ]PRINAT = 8    #Prix de l'ordre
            [F:STJ]AMTDEV  = arr([M:SRW]AMTNABS(INDLIG)*[F:STJ]ACTQTY/[M:SRW]QTYSTU(INDLIG),WRND_SOC)
            [F:STJ]VARVAL  = [F:STJ]VARORD
            [F:STJ]AMTVAL += [F:STJ]VARVAL
        Else
            [F:STJ]AMTDEV  = arr(([M:SRW]AMTABS(INDLIG)+[M:SRW]AMTNABS(INDLIG))*[F:STJ]ACTQTY/[M:SRW]QTYSTU(INDLIG),WRND_SOC)
            [F:STJ]VARVAL  = 0
            #[F:STJ]AMTVAL inchangé
        Endif
        If GACTVLT2
            If LREG=2 & [F:STJ]PRINAT2 = 8    #Prix de l'ordre
                [F:STJ]AMTDEV2  = arr([M:SRW]AMTNABS2(INDLIG)*[F:STJ]ACTQTY/[M:SRW]QTYSTU(INDLIG),WRND_SOC)
                [F:STJ]VARVAL2  = [F:STJ]VARORD
                [F:STJ]AMTVAL2 += [F:STJ]VARVAL2
            Else
                [F:STJ]AMTDEV2  = arr(([M:SRW]AMTABS2(INDLIG)+[M:SRW]AMTNABS2(INDLIG))*[F:STJ]ACTQTY/[M:SRW]QTYSTU(INDLIG),WRND_SOC)
                [F:STJ]VARVAL2  = 0
                #[F:STJ]AMTVAL2 inchangé
            Endif
        Endif
    Endif
    [F:STJ]AGGIFAFLG = 1
    [F:STJ]NUMVCR = ""
    [F:STJ]GTE = ""
    Raz [F:STJ]ACCDAT
    [F:STJ]PRIORD = arr([F:STJ]AMTORD/[F:STJ]ACTQTY,WRND_SOC)
    [F:STJ]PRIVAL = arr([F:STJ]AMTVAL/[F:STJ]ACTQTY,WRND_SOC)
    If GACTVLT2
        [F:STJ]PRIVAL2= arr([F:STJ]AMTVAL2/[F:STJ]ACTQTY,WRND_SOC)
    Endif

    [F:STJ]VCRTYPREG = PTYPREG
    [F:STJ]VCRNUMREG = PNUMREG
    [F:STJ]VCRLINREG = PLINREG
    [F:STJ]PRIREGFLG = 2

    Call ECRTRACE("    AMTORD="+num$([F:STJ]AMTORD)-"AMTVAL="+num$([F:STJ]AMTVAL)-"AMTVAL2="+num$([F:STJ]AMTVAL2),0) From STKVAL
    Call ECRTRACE("    VARORD="+num$([F:STJ]VARORD)-"VARVAL="+num$([F:STJ]VARVAL)-"VARVAL2="+num$([F:STJ]VARVAL2),0) From STKVAL
    Call ECRTRACE("    PRIORD="+num$([F:STJ]PRIORD)-"PRIVAL="+num$([F:STJ]PRIVAL)-"PRIVAL2="+num$([F:STJ]PRIVAL2),0) From STKVAL
    Call ECRTRACE("    AMTDEV="+num$([F:STJ]AMTDEV)-"AMTDEV2="+num$([F:STJ]AMTDEV2),0) From STKVAL

    If GACTDECCST
        If !clalev([SJV1]) : Local File STOJOUVAL [SJV1] : Endif
        [F:SJV1] = [F:SJV]
        Call SAVDETSJV([F:STJ]ACTQTY/[M:SRW]QTYSTU(INDLIG), INDLIG, 1+2*(LREG=2&[F:STJ]PRINAT=8)+4*(GACTVLT2&LREG=2&[F:STJ]PRINAT2=8))
    Endif
Return

$ECR_STJ
    Call ECRSTJ(0,PRET) From STKLIB
    If PRET
        GOK=0
        Call FSTA("STJ") From GLOCK
        PRET=4
        Return
    Endif
    # Issue 83620 - 2012-08-13 by CCC : On teste que le mvt a été créé après GDATDECCST
    If GACTDECCST & [F:STJ]CREMVTDAT>=GDATDECCST & GDATDECCST>[0/0/0]
        [F:SJV] = [F:STJ]    # Récupération de la nouvelle clé

        Call SJVTRACE("[F:SJV]","[F:SJV1]","O")
        Call SJVTRACE("[F:SJV]","[F:SJV1]","V")
        Call SJVTRACE("[F:SJV]","[F:SJV1]","DEV")
        If GACTVLT2
            Call SJVTRACE("[F:SJV]","[F:SJV1]","V2")
        Endif

        Write [SJV]
        If fstat
            Call FSTA("SJV") From GLOCK
            GOK=0
            PRET=4
            Return
        Endif
        If ([M:SRW]AMTABS(INDLIG)+[M:SRW]AMTNABS(INDLIG))<>0
            # On enregistre la valeur totale pour chaque nature. On n'a pas besoin d'avoir une valeur "absorbée" et "non absorbée"
            # Le calcul de delta à la prochaine régul se fera sur la valeur réelle
            Call SAVSJO([F:STJ]ACTQTY/sum([M:SRW]QTYSTU))
        Endif
    Endif

Return

#**----------------------------------------------------------------<br/>
#* SJVTRACE : logs detail values of STOJOUVAL
#**<br/>----------------------------------------------------------------<br/>
#* @param PABR1 = Abreviation1
#* @param PABR2 = Abreviation2 (optional, if entered, logs difference between PABR1 and PABR2)
#* @param PREFIX = Prefix of fields' names
#**<br/>----------------------------------------------------------------
#*!
Subprog SJVTRACE(PABR1,PABR2,PREFIX)
Value Char PABR1
Value Char PABR2
Value Char PREFIX

Local Integer I
Local Decimal LVAL
    For I=0 To GACTMAT-1
        LVAL=evalue(PABR1+PREFIX+"MATCST("+num$(I)+")")
        If PABR2<>"" : LVAL-=evalue(PABR2+PREFIX+"MATCST("+num$(I)+")") : Endif
        Call ECRTRACE(PREFIX+"MATCST("+num$(I)+") "+string$(PABR2<>"","+")+"="+num$(LVAL),0) From STKVAL
    Next
    If evalue("dim("+PABR1+PREFIX+"OVEMATTOT)")>0
        LVAL=evalue(PABR1+PREFIX+"OVEMATTOT")
        If PABR2<>"" : LVAL-=evalue(PABR2+PREFIX+"OVEMATTOT") : Endif
        Call ECRTRACE(PREFIX+"OVEMATTOT "+string$(PABR2<>"","+")+"="+num$(LVAL),0) From STKVAL
    Elsif evalue("dim("+PABR1+PREFIX+"OVEMAT)")>0
        LVAL=evalue(PABR1+PREFIX+"OVEMAT")
        If PABR2<>"" : LVAL-=evalue(PABR2+PREFIX+"OVEMAT") : Endif
        Call ECRTRACE(PREFIX+"OVEMAT "+string$(PABR2<>"","+")+"="+num$(LVAL),0) From STKVAL
    Endif

    For I=0 To GACTMAC-1
        LVAL=evalue(PABR1+PREFIX+"MACCST("+num$(I)+")")
        If PABR2<>"" : LVAL-=evalue(PABR2+PREFIX+"MACCST("+num$(I)+")") : Endif
        Call ECRTRACE(PREFIX+"MACCST("+num$(I)+") "+string$(PABR2<>"","+")+"="+num$(LVAL),0) From STKVAL
    Next
    If evalue("dim("+PABR1+PREFIX+"OVEMACTOT)")>0
        LVAL=evalue(PABR1+PREFIX+"OVEMACTOT")
        If PABR2<>"" : LVAL-=evalue(PABR2+PREFIX+"OVEMACTOT") : Endif
        Call ECRTRACE(PREFIX+"OVEMACTOT "+string$(PABR2<>"","+")+"="+num$(LVAL),0) From STKVAL
    Elsif evalue("dim("+PABR1+PREFIX+"OVEMAC)")>0
        LVAL=evalue(PABR1+PREFIX+"OVEMAC")
        If PABR2<>"" : LVAL-=evalue(PABR2+PREFIX+"OVEMAC") : Endif
        Call ECRTRACE(PREFIX+"OVEMAC "+string$(PABR2<>"","+")+"="+num$(LVAL),0) From STKVAL
    Endif

    For I=0 To GACTLAB-1
        LVAL=evalue(PABR1+PREFIX+"LABCST("+num$(I)+")")
        If PABR2<>"" : LVAL-=evalue(PABR2+PREFIX+"LABCST("+num$(I)+")") : Endif
        Call ECRTRACE(PREFIX+"LABCST("+num$(I)+") "+string$(PABR2<>"","+")+"="+num$(LVAL),0) From STKVAL
    Next
    If evalue("dim("+PABR1+PREFIX+"OVELABTOT)")>0
        LVAL=evalue(PABR1+PREFIX+"OVELABTOT")
        If PABR2<>"" : LVAL-=evalue(PABR2+PREFIX+"OVELABTOT") : Endif
        Call ECRTRACE(PREFIX+"OVELABTOT "+string$(PABR2<>"","+")+"="+num$(LVAL),0) From STKVAL
    Elsif evalue("dim("+PABR1+PREFIX+"OVELAB)")>0
        LVAL=evalue(PABR1+PREFIX+"OVELAB")
        If PABR2<>"" : LVAL-=evalue(PABR2+PREFIX+"OVELAB") : Endif
        Call ECRTRACE(PREFIX+"OVELAB "+string$(PABR2<>"","+")+"="+num$(LVAL),0) From STKVAL
    Endif

    If evalue("dim("+PABR1+PREFIX+"SCOTOT)")>0
        LVAL=evalue(PABR1+PREFIX+"SCOTOT")
        If PABR2<>"" : LVAL-=evalue(PABR2+PREFIX+"SCOTOT") : Endif
        Call ECRTRACE(PREFIX+"SCOTOT "+string$(PABR2<>"","+")+"="+num$(LVAL),0) From STKVAL
    Elsif evalue("dim("+PABR1+PREFIX+"SCOCST)")>0
        LVAL=evalue(PABR1+PREFIX+"SCOCST")
        If PABR2<>"" : LVAL-=evalue(PABR2+PREFIX+"SCOCST") : Endif
        Call ECRTRACE(PREFIX+"SCOCST "+string$(PABR2<>"","+")+"="+num$(LVAL),0) From STKVAL
    Endif
    If evalue("dim("+PABR1+PREFIX+"OVESCOTOT)")>0
        LVAL=evalue(PABR1+PREFIX+"OVESCOTOT")
        If PABR2<>"" : LVAL-=evalue(PABR2+PREFIX+"OVESCOTOT") : Endif
        Call ECRTRACE(PREFIX+"OVESCOTOT "+string$(PABR2<>"","+")+"="+num$(LVAL),0) From STKVAL
    Elsif evalue("dim("+PABR1+PREFIX+"OVESCO)")>0
        LVAL=evalue(PABR1+PREFIX+"OVESCO")
        If PABR2<>"" : LVAL-=evalue(PABR2+PREFIX+"OVESCO") : Endif
        Call ECRTRACE(PREFIX+"OVESCO "+string$(PABR2<>"","+")+"="+num$(LVAL),0) From STKVAL
    Endif

    If evalue("dim("+PABR1+PREFIX+"INVDTATOT)")>0
        LVAL=evalue(PABR1+PREFIX+"INVDTATOT")
        If PABR2<>"" : LVAL-=evalue(PABR2+PREFIX+"INVDTATOT") : Endif
        Call ECRTRACE(PREFIX+"INVDTATOT "+string$(PABR2<>"","+")+"="+num$(LVAL),0) From STKVAL
    Elsif evalue("dim("+PABR1+PREFIX+"INVDTA)")>0
        LVAL=evalue(PABR1+PREFIX+"INVDTA")
        If PABR2<>"" : LVAL-=evalue(PABR2+PREFIX+"INVDTA") : Endif
        Call ECRTRACE(PREFIX+"INVDTA "+string$(PABR2<>"","+")+"="+num$(LVAL),0) From STKVAL
    Endif

End


# Issue 91122 - 2013-09-06 by CCC : Traceability
###############################################################################
#  Maj à jour REGFLG de STOTRK pour les articles
#                        avec tracabilite détaillée
###############################################################################
$MAJ_STOTRK_REGFLG
Local    Integer WTYP
Local    Char    WNUM(GLONVCR)
Local    Decimal WLIN
Local    Integer WTYPORI
Local    Char    WNUMORI(GLONVCR)
Local    Decimal WLINORI
If !clalev([F:STR])  Local File STOTRK [STR] : Endif
#-----------------------------------------------------------------------
# Détermination numéros pièce et pièce origine
# Le numéro de pièce pour gestion de la traçabilité est sélectionné selon
# le type de mouvement
#     - Numéro de pièce d'origine pour :
#         Les entrées OF
#         Les sorties OF
#         Les réintégration de stock
#         Les retours reception
#         Les retours livraison
#     - Numéro de pièce dans les autres cas
#-----------------------------------------------------------------------
# La traçabilité est géré sur:
#     - OF        : Entrée OF, Sortie OF, Réintégration de stock
#                   ENTRéE et sortie diverse (si origine=OF)
#     - Composé   : Assemblage et désassemblage
#     - Réception : Retour fournisseur
#     - Livraison : Retour client
#-----------------------------------------------------------------------

# Issue 101520 - 2015-05-13 by CCC : Rules have to be the same as MAJTRK From STKLIB
Case [F:STJ]TRSTYP
  When 1, 2, 3, 4
    If find([F:STJ]VCRTYPORI,10,36)
      WTYP       = [F:STJ]VCRTYPORI
      WNUM       = [F:STJ]VCRNUMORI
      WLIN       = [F:STJ]VCRLINORI
      WTYPORI    = [F:STJ]VCRTYP
      WNUMORI    = [F:STJ]VCRNUM
      WLINORI    = [F:STJ]VCRLIN
    Else
      WTYP       = [F:STJ]VCRTYP
      WNUM       = [F:STJ]VCRNUM
      WLIN       = [F:STJ]VCRLIN
      WTYPORI    = [F:STJ]VCRTYPORI
      WNUMORI    = [F:STJ]VCRNUMORI
      WLINORI    = [F:STJ]VCRLINORI
    Endif
  When 5, 6, 11, 12, 18, 19
    WTYP         = [F:STJ]VCRTYPORI
    WNUM         = [F:STJ]VCRNUMORI
    WLIN         = [F:STJ]VCRLINORI
    WTYPORI      = [F:STJ]VCRTYP
    WNUMORI      = [F:STJ]VCRNUM
    WLINORI      = [F:STJ]VCRLIN
  When Default
    WTYP         = [F:STJ]VCRTYP
    WNUM         = [F:STJ]VCRNUM
    WLIN         = [F:STJ]VCRLIN
    WTYPORI      = [F:STJ]VCRTYPORI
    WNUMORI      = [F:STJ]VCRNUMORI
    WLINORI      = [F:STJ]VCRLINORI
Endcase
#--- PE pour gérer la traçabilité sur le suivi au lieu de l'OF
# This entry point has to be used too if entry point ORI_TRK in STKLIB is used
 GPOINT = "ORI_TRK"
 Gosub ENTREE From EXEFNC

#--- Séquence à écrire dans le point d'entrée
#If find([F:STJ]TRSTYP,5,6,19)
#    WTYP         = [F:STJ]VCRTYP
#    WNUM         = [F:STJ]VCRNUM
#    WLIN         = [F:STJ]VCRLIN
#    WTYPORI      = [F:STJ]VCRTYPORI
#    WNUMORI      = [F:STJ]VCRNUMORI
#    WLINORI      = [F:STJ]VCRLINORI
# Endif

#--- Issue 110327
# Si gestion série globale et traçabilité par no série
If [F:ITM]SERMGTCOD=4 & find([F:ITM]TRKLEV,1,4)
  Update [STR] Where ITMREF    = [F:STJ]ITMREF
&                  & LOT       = [F:STJ]LOT
&                  & SLO       = [F:STJ]SLO
&                  & IPTDAT    = [F:STJ]IPTDAT
&                  & STOFCY    = [F:STJ]STOFCY
&                  & MVTSEQSTJ = [F:STJ]MVTSEQ
&                  & REGFLG    = 1
&              With  REGFLG    = 2
  Return
Endif
#---

# Warning : For counts, MVTSEQ can be changed in STR
If [F:STJ]MVTIND<>0
    Filter [STR] Where ITMREF = [F:STJ]ITMREF
&                    & LOT    = [F:STJ]LOT
&                    & SLO    = [F:STJ]SLO
&                    & IPTDAT = [F:STJ]IPTDAT
&                    & MVTIND = [F:STJ]MVTIND
&                    & STOFCY = [F:STJ]STOFCY
&                    & VCRTYP = WTYP
&                    & VCRNUM = WNUM
&                    & VCRLIN = WLIN
&                    & VCRTYPORI = WTYPORI
&                    & VCRNUMORI = WNUMORI
&                    & VCRLINORI = WLINORI
&                    & REGFLG = 1
    Read [STR]STR0 First
    Filter [STR]
Else
    Filter [STR] Where ITMREF = [F:STJ]ITMREF
&                    & LOT    = [F:STJ]LOT
&                    & SLO    = [F:STJ]SLO
&                    & IPTDAT = [F:STJ]IPTDAT
&                    & MVTSEQ = [F:STJ]MVTSEQ
&                    & MVTIND = 0
&                    & STOFCY = [F:STJ]STOFCY
&                    & VCRTYP = WTYP
&                    & VCRNUM = WNUM
&                    & VCRLIN = WLIN
&                    & VCRTYPORI = WTYPORI
&                    & VCRNUMORI = WNUMORI
&                    & VCRLINORI = WLINORI
&                    & REGFLG = 1
    Read [STR]STR0 First
    Filter [STR]
Endif
If !fstat
    [F:STR]REGFLG=2
    Rewrite [STR]
    If fstat
        GOK=0
        Call FSTA("STR") From GLOCK
        Return
    Endif
Endif

Return


###############################################################################
# ECR_ITMMVT : Met à jour la table ITMMVT suite à la régularisation
###############################################################################

Subprog UPD_ITMMVT(PITM,PFCY)
Value Char PITM(), PFCY()

Local Integer I, PRET, SRWCOR, NO_POINT
Local Decimal LCOEF, LQTYTMP, WRND_SOC

[L]WRND_SOC = [V]GRNDVAL

Gosub ECR_ITMMVT
GPOINT = ""
End

###############################################################################
$ECR_ITMMVT

Readlock [ITV]ITV0=PITM;PFCY
If fstat
    Call FSTA("ITV") From GLOCK
    GOK=0
    PRET=4
    Return
Endif

# Issue 66185 - 2010-08-16 by CCC : Le PMP est fonction du prix d'ordre qui lui même est mis à jour
#       en fonction de la 1ère méthode de valo. => on ne s'occupe pas de savoir le mnt absorbé sur la 2ème méthode
#If [F:TCM]ISSVLTCOD<>4 & GACTVLT2 & [F:TCM]ISSVLTCOD(1)=4
#    [F:ITV]AVCBASAMT += sum([M:SRW]AMTABS2)
#    LCOEF = sum([M:SRW]AMTABS2)/sum([M:SRW]AMTABS)
#Else
#    [F:ITV]AVCBASAMT += sum([M:SRW]AMTABS)
#    LCOEF = 1
#Endif
LCOEF=1

If GACTDECCST
   Gosub SAVDETITV
Endif
If SRWCOR : Return : Endif

Call ECRTRACE("----------- ITMMVT ------------",0) From STKVAL
Call ECRTRACE("[F:ITV]avcbasamt ="+num$([F:ITV]AVCBASAMT),0) From STKVAL
Call ECRTRACE("[F:ITV]avcbasqty ="+num$([F:ITV]AVCBASQTY),0) From STKVAL
Call ECRTRACE("[F:ITV]avc ="+num$([F:ITV]AVC),0) From STKVAL

# Issue 87150 - 2013-01-22 by CCC : Si rien n'a changé sur le pmp & que la qté=0, on ne change pas son prix unitaire
If !(sum([M:SRW]AMTABS)=0 & [F:ITV]AVCBASAMT=0 & [F:ITV]AVCBASQTY=0 )
    # GH 21/05/2012 Bug 81221 mise en homogénéité avec $MAJ_LOT
    If [F:ITV]AVCBASQTY=0
        [F:ITV]AVCBASAMT = 0
    Else
        [F:ITV]AVCBASAMT += sum([M:SRW]AMTABS)
    Endif
Endif

# Issue 112077 - 2017-01-25 by ERMIL : Use correct value for GRNDVAL to reduce rounding errors
Local Decimal RNDVAL_SAV, WRND_SAV
RNDVAL_SAV = GRNDVAL
WRND_SAV = WRND_SOC

Call INIRNDVAL("ITMMVT","AVC") From STKVALECR
WRND_SOC = GRNDVAL

# Issue 87150 - 2013-01-22 by CCC : Si rien n'a changé sur le pmp & que la qté=0, on ne change pas son prix unitaire
If [F:ITV]AVCBASAMT=0 & (sum([M:SRW]AMTABS)<>0 | [F:ITV]AVCBASQTY<>0 )

    # GH 21/05/2012 Bug 81221 mise en homogénéité avec $MAJ_LOT
    [F:ITV]AVC=0
    If GACTDECCST
        For I=0 To dim([F:ITV]AMATAVC)-1
            [F:ITV]AMATAVC(I) = 0
        Next
        [F:ITV]AOVEMATAVC = 0

        For I=0 To dim([F:ITV]AMACAVC)-1
            [F:ITV]AMACAVC(I) = 0
        Next
        [F:ITV]AOVEMACAVC = 0

        For I=0 To dim([F:ITV]ALABAVC)-1
            [F:ITV]ALABAVC(I) = 0
        Next
        [F:ITV]AOVELABAVC = 0

        [F:ITV]ASCOAVC = 0
        [F:ITV]AOVESCOAVC = 0

        [F:ITV]AINVDTAAVC = 0
    Endif
Elsif [F:ITV]AVCBASQTY<>0
    [F:ITV]AVC=arr([F:ITV]AVCBASAMT/[F:ITV]AVCBASQTY,WRND_SOC)
    If GACTDECCST
        For I=0 To dim([F:ITV]AMATAVC)-1
            [F:ITV]AMATAVC(I) = arr([F:ITV]AMATCST(I)/[F:ITV]AVCBASQTY,WRND_SOC)
        Next
        [F:ITV]AOVEMATAVC = arr([F:ITV]AOVEMATCST/[F:ITV]AVCBASQTY,WRND_SOC)

        For I=0 To dim([F:ITV]AMACAVC)-1
            [F:ITV]AMACAVC(I) = arr([F:ITV]AMACCST(I)/[F:ITV]AVCBASQTY,WRND_SOC)
        Next
        [F:ITV]AOVEMACAVC = arr([F:ITV]AOVEMACCST/[F:ITV]AVCBASQTY,WRND_SOC)

        For I=0 To dim([F:ITV]ALABAVC)-1
            [F:ITV]ALABAVC(I) = arr([F:ITV]ALABCST(I)/[F:ITV]AVCBASQTY,WRND_SOC)
        Next
        [F:ITV]AOVELABAVC = arr([F:ITV]AOVELABCST/[F:ITV]AVCBASQTY,WRND_SOC)

        [F:ITV]ASCOAVC = arr([F:ITV]ASCOCST/[F:ITV]AVCBASQTY,WRND_SOC)
        [F:ITV]AOVESCOAVC = arr([F:ITV]AOVESCOCST/[F:ITV]AVCBASQTY,WRND_SOC)

        [F:ITV]AINVDTAAVC = arr([F:ITV]AINVDTACST/[F:ITV]AVCBASQTY,WRND_SOC)
    Endif
Endif

If clalev([M:SDPD]) & sigma(0,[M:SRW]NBLIG-1,[F:ITV]VCRTYP = [M:SRW]VCRTYP(indcum)
&                                          & [F:ITV]VCRNUM = [M:SRW]VCRNUM(indcum)
&                                          & [F:ITV]VCRLIN = [M:SRW]VCRLIN(indcum))>0
    # Le dernier prix doit inclure le non absorbé (Cf Bug 25843)
    [F:ITV]LASRCPPRI += arr([M:SDPD]AMTTOT/sum([M:SRW]QTYSTU),WRND_SOC)
# Issue 104503 - 2015-02-24 by CCC
#    # CCC (16/12/05) Bug 33665
#    # Si on est en train de régulariser la dernière réception => on met à jour le dernier prix d'achat
#    If [F:ITV]VCRTYP=6
#        [F:ITV]LASPURPRI = [F:ITV]LASRCPPRI
#    Endif
    If GACTDECCST
        LQTYTMP = sum([M:SRW]QTYSTU)
        #------ Matière -----#
        For I=0 To GACTMAT-1
            [F:ITV]LMATCST(I) += [M:SDPD]MATCST(I) / LQTYTMP
        Next
        [F:ITV]LOVEMATCST += [M:SDPD]OVEMATCST/LQTYTMP

        #------ Machine -----#
        For I=0 To GACTMAC-1
            [F:ITV]LMACCST(I) += [M:SDPD]MACCST(I) / LQTYTMP
        Next
        [F:ITV]LOVEMACCST += [M:SDPD]OVEMACCST/LQTYTMP

        #------ Main d'oeuvre -----#
        For I=0 To GACTLAB-1
            [F:ITV]LLABCST(I) += [M:SDPD]LABCST(I) / LQTYTMP
        Next
        [F:ITV]LOVELABCST += [M:SDPD]OVELABCST/LQTYTMP

        #------ Sous-traitance -----#
        #[F:ITV]LSCOCST    += [M:SDPD]SCOTOT/LQTYTMP
        [F:ITV]LSCOCST    += [M:SDPD]SCOCST/LQTYTMP
        [F:ITV]LOVESCOCST += [M:SDPD]OVESCOCST/LQTYTMP

        [F:ITV]LINVDTACST += [M:SDPD]INVDTACST/LQTYTMP
    Endif
Endif

If dim([L]NO_POINT)<0
   GPOINT = "BEFREGITV"
   Gosub ENTREE From EXEFNC
Endif

Call ECRTRACE(" --> after update",0) From STKVAL
Call ECRTRACE("[F:ITV]avcbasamt ="+num$([F:ITV]AVCBASAMT),0) From STKVAL
Call ECRTRACE("[F:ITV]avcbasqty ="+num$([F:ITV]AVCBASQTY),0) From STKVAL
Call ECRTRACE("[F:ITV]avc ="+num$([F:ITV]AVC),0) From STKVAL

# Issue 112077 - 2017-01-25 by ERMIL : Reset GRNDVAL to previous value
GRNDVAL = RNDVAL_SAV
WRND_SOC = WRND_SAV

Call REWITV From STKLIB
If fstat
    Call FSTA("ITV") From GLOCK
    GOK=0
    PRET=4
    Return
Endif
Return

###############################################################################
# ECR_ITMMVTHIS : Met à jour la table ITMMVTHIS suite à la régularisation
#                 La date utilisée est [M:SRW]IPTDAT
###############################################################################
$ECR_ITMMVTHIS
Local Integer LFIYNUM
Local Integer LCRE

    Call GETITH(PITM,PFCY,[M:SRW]IPTDAT(INDLIG),1,LCRE) From STKLIB
    If !fstat
        If !LCRE
            [F:ITH]UPDDAT = date$
            [F:ITH]UPDUSR = GUSER
            [F:ITH]EXPNUM = [C]EXPORT
        Endif
        LFIYNUM = [F:ITH]FIYNUM
        [F:ITH]AMTDEV += LCUMMNTNABS
        If GACTVLT2
            [F:ITH]AMTDEV2+= LCUMMNTNABS(1)
        Endif

# CCC (18/10/04) Bug 25843 : Le dernier prix doit inclure le non absorbé
        If [F:ITH]VCRTYP = PVCRTYP & [F:ITH]VCRNUM = PVCRNUM & [F:ITH]VCRLIN = PVCRLIN
            [F:ITH]LASRCPPRI += arr([M:SDPD]AMTTOT/[M:SDPO]QTY,10^-6)
# Issue 104503 - 2015-02-24 by CCC
#            If [F:ITH]VCRTYP=6
#                #[F:ITH]LASPURPRI = [F:ITH]LASRCPPRI
#                [F:ITH]LASPURPRI += arr(([M:SDPD]AMTTOT
#&                                       -[M:SDPD]INVDTACST
#&                                       -[M:SDPD]OVEMATCST-[M:SDPD]OVEMACCST-[M:SDPD]OVELABCST-[M:SDPD]OVESCOCST)/[M:SDPO]QTY,WRND_SOC)
#            Endif
        Endif

        # Les cumuls correspondent aux valeurs de VARVAL => sans le non absorbé
        [F:ITH]MONRCPAMT += LCUMMNTABS
        [F:ITH]YEARCPAMT += LCUMMNTABS
        Call REWITH From STKLIB
        Call ECRTRACE("[F:ITH]FIYNUM ="+num$([F:ITH]FIYNUM)-"[F:ITH]PERNUM ="+num$([F:ITH]PERNUM),0) From STKVAL
        Call ECRTRACE("[F:ITH]MONRCPAMT ="+num$([F:ITH]MONRCPAMT)+"("+string$(LCUMMNTABS>0,"+")+num$(LCUMMNTABS)+")",0) From STKVAL
        Call ECRTRACE("[F:ITH]YEARCPAMT ="+num$([F:ITH]YEARCPAMT)+"("+string$(LCUMMNTABS>0,"+")+num$(LCUMMNTABS)+")",0) From STKVAL
        Call ECRTRACE("[F:ITH]AMTDEV ="+num$([F:ITH]AMTDEV)+"("+string$(LCUMMNTNABS>0,"+")+num$(LCUMMNTNABS)+")",0) From STKVAL
        Filter [ITH] Where ITMREF = PITM
&                        & STOFCY = PFCY
&                        & FIYNUM = LFIYNUM
&                        & [F:STJ]IPTDAT < PERSTR
        For [ITH]
            Readlock [ITH] Curr
            If fstat
                Break
            Endif
            [F:ITH]YEARCPAMT += LCUMMNTABS
            Call REWITH From STKLIB
            Call ECRTRACE("[F:ITH]FIYNUM ="+num$([F:ITH]FIYNUM)-"[F:ITH]PERNUM ="+num$([F:ITH]PERNUM),0) From STKVAL
            Call ECRTRACE("[F:ITH]YEARCPAMT ="+num$([F:ITH]YEARCPAMT)+"("+string$(LCUMMNTABS>0,"+")+num$(LCUMMNTABS)+")",0) From STKVAL
        Next
        Filter [ITH]
    Endif
    If fstat
        Call FSTA("ITH") From GLOCK
        GOK=0
        PRET=4
        Return
    Endif
Return

###############################################################################
# Bug 81221 GH 24/05/12
# Tentative de correction des montants décomposés négatifs dans
#     - AxxxCST(..) dans les tables ITMMVT STOLOTFCY
#     - xxxCST (..) dans la table STOCOST
# avec xxx=MAT,MAC,LAB,SCO + OVExxx
# via modification des valeurs de [M:SRW]
###############################################################################

$COR_SRW
If LCOEF=0 : Return : Endif

Gosub COR_DEF
[L]MSKDEF=dbgstr(1)
[V]GRNDVAL = [L]WRND_SOC
SRWCOR*=-1

Case SRWCOR
  When -4 : FILABR="ITV" : PFXZON="A" : # PMP
  When -5 : FILABR="STP" : PFXZON=""  : # FIFO
  When -6 : FILABR="SLF" : PFXZON="A" : # Lot
Endcase

Raz [M:SDT2] : Call LOADSDPX("SDT2","[F:"+FILABR+"]",PFXZON,1) From STKVAL
Default Mask [SDT2] : Gosub COR_TST
If sum([L]AREPARTIR)<>0
  Raz [M:SDT1]
  Call LOADSDPX("SDT1","[F:"+FILABR+"1]",PFXZON,1) From STKVAL

  N = 0
  For I=0 To GACTMAT-1
    TABOLD(N) = [M:SDT1]MATCST(I)   : TABNEW(N) = [M:SDT2]MATCST(I)   : N+=1
  Next
  For I=0 To GACTMAC-1
    TABOLD(N) = [M:SDT1]MACCST(I)   : TABNEW(N) = [M:SDT2]MACCST(I)   : N+=1
  Next
  For I=0 To GACTLAB-1
    TABOLD(N) = [M:SDT1]LABCST(I)   : TABNEW(N) = [M:SDT2]LABCST(I)   : N+=1
  Next
  TABOLD(N) = [M:SDT1]SCOCST        : TABNEW(N) = [M:SDT2]SCOCST      : N+=1
  TABOLD(N) = [M:SDT1]OVEMATCST     : TABNEW(N) = [M:SDT2]OVEMATCST   : N+=1
  TABOLD(N) = [M:SDT1]OVEMACCST     : TABNEW(N) = [M:SDT2]OVEMACCST   : N+=1
  TABOLD(N) = [M:SDT1]OVELABCST     : TABNEW(N) = [M:SDT2]OVELABCST   : N+=1
  TABOLD(N) = [M:SDT1]OVESCOCST     : TABNEW(N) = [M:SDT2]OVESCOCST   : N+=1
  For I=0 To N-1
    TABDELTA(I)=TABNEW(I)-TABOLD(I)
  Next

  If sum([L]AREPARTIR)<>0
    For I=0 To dim([L]AREPARTIR)-1
      If AREPARTIR(I)<>0
         If I=0    : # couts matiere
            Gosub REPCSTMAT
            Gosub REPCSTDIV
            Gosub REPFG
         Elsif I<4 : # couts non matiere (machine, main d'oeuvre, sous-traitance)
            # CSTDIV, CSTMAT, FG
            Gosub REPCSTDIV
            Gosub REPCSTMAT
            Gosub REPFG
         Elsif I=4 : # frais generaux matiere
            Gosub REPFG
            Gosub REPCSTMAT
            Gosub REPCSTDIV
         Else      : # frais generaux non matiere (machine, main d'oeuvre, sous-traitance)
            Gosub REPFG
            Gosub REPCSTDIV
            Gosub REPCSTMAT
         Endif
         If AREPARTIR(I)<[V]GRNDVAL : AREPARTIR(I)=0 : Break : Endif
      Endif
    Next I
  Endif

  If sum([L]AREPARTIR)=0
    # on ramène les mts<0 à zéro
    For I=0 To N-1
      If TABNEW(I)<0 : TABDELTA(I)-=TABNEW(I) : TABNEW(I)=0 : Endif
    Next

    [M:SRW2] = [M:SRW] : # Sauvegarde

    # Répartition  des corrections sur les différentes lignes de [M:SRW] selon les qtés (avec saupoudrage des arrondis)
    TOTQTY=0 : N=0

    For J=0 To [M:SRW]NBLIG-1
        Gosub COR_LIGOK
        If LIGOK
           TOTQTY+= [M:SRW]QTYSTU(J)
        Endif
    Next

    [V]GSTOTRACE = [L]SAVTRA : # on réactive momentanéement la trace
    Call ECRTRACE("------- Dispatch on lines [M:SRW] with LCOEF ="-num$(LCOEF)-"-------",0) From STKVAL
    ZONCST="MAT"    : Gosub COR_CST
    ZONCST="MAC"    : Gosub COR_CST
    ZONCST="LAB"    : Gosub COR_CST
    ZONCST="SCO"    : Gosub COR_CST
    ZONCST="OVEMAT" : Gosub COR_CST
    ZONCST="OVEMAC" : Gosub COR_CST
    ZONCST="OVELAB" : Gosub COR_CST
    ZONCST="OVESCO" : Gosub COR_CST
    [V]GSTOTRACE=2 : # on désactive à nouveau la trace

    # on vérifie
    # [M:SDT1] = [F:ITV]
    # [M:SDT2] = [F:ITV] + [M:SRW] sans correction des mts<0
    # [M:SDT3] = [F:ITV] + [M:SRW] avec correction des mts<0
    Case SRWCOR
      When -4 : [F:ITV] = [F:ITV1] : Gosub SAVDETITV
      When -5 : [F:STP] = [F:STP1] : Gosub SAVDETSTP
      When -6 : [F:SLF] = [F:SLF1] : Gosub SAVDETSLF
    Endcase
    Raz [M:SDT3] : Call LOADSDPX("SDT3","[F:"+FILABR+"]",PFXZON,1) From STKVAL
    Default Mask [SDT3] : Gosub COR_TST
    If sum([L]AREPARTIR)<>0 |
&      (sigma(0,GACTMAT-1,[M:SDT2]MATCST(indcum)) + sigma(0,GACTMAC-1,[M:SDT2]MACCST(indcum)) + sigma(0,GACTLAB-1,[M:SDT2]LABCST(indcum)) + [M:SDT2]SCOCST
&      + [M:SDT2]OVEMATCST + [M:SDT2]OVEMACCST + [M:SDT2]OVELABCST + [M:SDT2]OVESCOCST) <>
&      (sigma(0,GACTMAT-1,[M:SDT3]MATCST(indcum)) + sigma(0,GACTMAC-1,[M:SDT3]MACCST(indcum)) + sigma(0,GACTLAB-1,[M:SDT3]LABCST(indcum)) + [M:SDT3]SCOCST
&      + [M:SDT3]OVEMATCST + [M:SDT3]OVEMACCST + [M:SDT3]OVELABCST + [M:SDT3]OVESCOCST)
      [M:SRW] = [M:SRW2] : # restauration
      K=2
    Else
      K=0
    Endif
  Else
    K = 1
  Endif

  ## trace
  [V]GSTOTRACE = [L]SAVTRA : # on réactive momentanéement la trace

  If !K
     Call ECRTRACE("------- Negative breakdown amounts -> Correction done -------",0) From STKVAL
  Else
     Call ECRTRACE("------- Negative breakdown amounts -> Correction undone (K="+num$(K)+")-------",0) From STKVAL
  Endif

  Case SRWCOR
    When -4 : Call ECRTRACE("STOFCY="+PFCY-"ITMREF="+PITM,0) From STKVAL
    When -5 : Call ECRTRACE("STOFCY="+PFCY-"ITMREF="+PITM
&                          -"VCRTYP="+num$([M:SRW]VCRTYP(INDLIG))-"VCRNUM="+[M:SRW]VCRNUM(INDLIG)-"VCRLIN="+num$([M:SRW]VCRLIN(INDLIG)),0) From STKVAL
    When -6 : Call ECRTRACE("STOFCY="+PFCY-"ITMREF="+PITM
&                          -"LOT="+[M:SRW]LOT(INDLIG)-"SLO="+[M:SRW]SLO(INDLIG),0) From STKVAL
  Endcase

  For I=0 To GACTMAT-1
      Call ECRTRACE("[F:"+FILABR+"]"+PFXZON+"MATCST("+num$(I)+")="+num$([M:SDT1]MATCST(I))-"->"-num$([M:SDT2]MATCST(I))-string$(K<>1,"->"-num$([M:SDT3]MATCST(I))),0) From STKVAL
  Next
  For I=0 To GACTMAC-1
      Call ECRTRACE("[F:"+FILABR+"]"+PFXZON+"MACCST("+num$(I)+")="+num$([M:SDT1]MACCST(I))-"->"-num$([M:SDT2]MACCST(I))-string$(K<>1,"->"-num$([M:SDT3]MACCST(I))),0) From STKVAL
  Next
  For I=0 To GACTLAB-1
      Call ECRTRACE("[F:"+FILABR+"]"+PFXZON+"LABCST("+num$(I)+")="+num$([M:SDT1]LABCST(I))-"->"-num$([M:SDT2]LABCST(I))-string$(K<>1,"->"-num$([M:SDT3]LABCST(I))),0) From STKVAL
  Next
  Call ECRTRACE("[F:"+FILABR+"]"+PFXZON+"SCOCST="+num$([M:SDT1]SCOCST)-"->"-num$([M:SDT2]SCOCST)-string$(K<>1,"->"-num$([M:SDT3]SCOCST)),0) From STKVAL
  Call ECRTRACE("[F:"+FILABR+"]"+PFXZON+"OVEMATCST="+num$([M:SDT1]OVEMATCST)-"->"-num$([M:SDT2]OVEMATCST)-string$(K<>1,"->"-num$([M:SDT3]OVEMATCST)),0) From STKVAL
  Call ECRTRACE("[F:"+FILABR+"]"+PFXZON+"OVEMACCST="+num$([M:SDT1]OVEMACCST)-"->"-num$([M:SDT2]OVEMACCST)-string$(K<>1,"->"-num$([M:SDT3]OVEMACCST)),0) From STKVAL
  Call ECRTRACE("[F:"+FILABR+"]"+PFXZON+"OVELABCST="+num$([M:SDT1]OVELABCST)-"->"-num$([M:SDT2]OVELABCST)-string$(K<>1,"->"-num$([M:SDT3]OVELABCST)),0) From STKVAL
  Call ECRTRACE("[F:"+FILABR+"]"+PFXZON+"OVESCOCST="+num$([M:SDT1]OVESCOCST)-"->"-num$([M:SDT2]OVESCOCST)-string$(K<>1,"->"-num$([M:SDT3]OVESCOCST)),0) From STKVAL

  [V]GSTOTRACE=2 : # on désactive à nouveau la trace
  ##
Endif

Default Mask [L]MSKDEF
SRWCOR*=-1
Return

###############################################################################

$COR_DEB
If dim([L]SAVTRA)<0 : Local Integer SAVTRA : Endif
[L]SAVTRA = [V]GSTOTRACE : [V]GSTOTRACE=2 : # on inhibe la trace durant la correction de [M:SRW]
Return

$COR_FIN
[V]GSTOTRACE = [L]SAVTRA
SRWCOR=0
Return

###############################################################################

$COR_DEF
If dim([L]TABDELTA)>0 : Return : Endif

Local Integer I, J, K, N, IMAX
Local Integer LIGOK
Local Integer JFIN1, JFIN2, JFIN3
Local Decimal AREPARTIR(6), TOTQTY
Local Decimal SUM1, SUM2, NMT, COECOR
Local Char    MSKDEF(250), FILABR(3), PFXZON(1), ZONCST(10)


JFIN1=GACTMAT
JFIN2=JFIN1+GACTMAC+GACTLAB+1
JFIN3=JFIN2+4

Local Decimal TABNEW(JFIN3), TABOLD(JFIN3), TABDELTA(JFIN3)

If !clalev([M:SDT1]) : Local Mask SAIDECPRI  [SDT1] : Endif
If !clalev([M:SDT2]) : Local Mask SAIDECPRI  [SDT2] : Endif
If !clalev([M:SDT3]) : Local Mask SAIDECPRI  [SDT3] : Endif
If !clalev([M:SRW2]) : Local Mask STKREGW    [SRW2] : Endif

Return
###############################################################################

$COR_TST
# couts matiere, machine, main d'oeuvre, sous-traitance
AREPARTIR(0) =-sigma(0,GACTMAT-1,[M]MATCST(indcum)*([M]MATCST(indcum)<0))
AREPARTIR(1) =-sigma(0,GACTMAC-1,[M]MACCST(indcum)*([M]MACCST(indcum)<0))
AREPARTIR(2) =-sigma(0,GACTLAB-1,[M]LABCST(indcum)*([M]LABCST(indcum)<0))
AREPARTIR(3) =-[M]SCOCST*([M]SCOCST<0)
# frais generaux matiere, non matiere (machine + main d'oeuvre + sous-traitance)
AREPARTIR(4) =-[M]OVEMATCST*([M]OVEMATCST<0)
AREPARTIR(5) =-[M]OVEMACCST*([M]OVEMACCST<0)
AREPARTIR(5)+=-[M]OVELABCST*([M]OVELABCST<0)
AREPARTIR(5)+=-[M]OVESCOCST*([M]OVESCOCST<0)
Return

###############################################################################

$COR_LIGOK
Case SRWCOR
  When -4 : LIGOK = 1
  When -5 : LIGOK = ([M:SRW]VCRTYP(INDLIG)=[M:SRW]VCRTYP(J) & [M:SRW]VCRNUM(INDLIG)=[M:SRW]VCRNUM(J) & [M:SRW]VCRLIN(INDLIG)=[M:SRW]VCRLIN(J))
  When -6 : LIGOK = ([M:SRW]LOT(INDLIG)=[M:SRW]LOT(J) & [M:SRW]SLO(INDLIG)=[M:SRW]SLO(J))
Endcase
Return

###############################################################################

$COR_CST
If find(ZONCST,"MAT","MAC","LAB") :
   IMAX= evalue("[V]GACT"+ZONCST)
   For I=0 To IMAX-1
     Gosub COR_SRWLIG
     N+=1
   Next
Else
   IMAX=1
   I=0
   Gosub COR_SRWLIG
   N+=1
Endif
Return

###############################################################################

$COR_SRWLIG
SUM1=evalue("[M:SDT1]"+ZONCST+"CST(I)")
SUM2=evalue("[M:SDT2]"+ZONCST+"CST(I)")
If TABOLD(N)=SUM1 & TABNEW(N)=SUM2 : Return : Endif

COECOR = TABNEW(N)-SUM1
COECOR/= TOTQTY
COECOR/= LCOEF

SUM1=0 : SUM2=0
For J=0 To [M:SRW]NBLIG-1
    Gosub COR_LIGOK
    If LIGOK
       K=J*IMAX+I
       NMT = arr(COECOR*([M:SRW]QTYSTU(J)+SUM2),[V]GRNDVAL)-SUM1
       Assign "[M:SRW]"+ZONCST+"CST(K)" With NMT
       Call ECRTRACE("Line"-num$(J+1)-":"-ZONCST+"CST("+num$(I)+") = "+num$(NMT),0) From STKVAL
       SUM1 +=  NMT
       SUM2 += [M:SRW]QTYSTU(J)
     Endif
Next
Return

###############################################################################
# répartition sur les couts matière MATCST(0..GACTMAT-1)
$REPCSTMAT
If AREPARTIR(I)<[V]GRNDVAL : Return : Endif
Call REPMONT(AREPARTIR(I),TABDELTA,TABNEW,0,JFIN1-1)

If AREPARTIR(I)<[V]GRNDVAL : Return : Endif
Call REPMONT(AREPARTIR(I),TABOLD,TABNEW,0,JFIN1-1)
Return

###############################################################################
# répartition sur les couts non matière MACCST(0..GACTMAC-1), LABCST(0..GACTMAC-1) et SCOCST
$REPCSTDIV
If AREPARTIR(I)<[V]GRNDVAL : Return : Endif
Call REPMONT(AREPARTIR(I),TABDELTA,TABNEW,JFIN1,JFIN2-1)

If AREPARTIR(I)<[V]GRNDVAL : Return : Endif
Call REPMONT(AREPARTIR(I),TABOLD,TABNEW,JFIN1,JFIN2-1)
Return

###############################################################################
# répartition sur les frais généraux OVE...CST
$REPFG
If AREPARTIR(I)<[V]GRNDVAL : Return : Endif
Call REPMONT(AREPARTIR(I),TABDELTA,TABNEW,JFIN2,JFIN3-1)

If AREPARTIR(I)<[V]GRNDVAL : Return : Endif
Call REPMONT(AREPARTIR(I),TABOLD,TABNEW,JFIN2,JFIN3-1)
Return

###############################################################################
Subprog REPMONT(AREPARTIR,TABMT,TABNEW,JDEB,JFIN)
Variable Decimal AREPARTIR, TABMT(), TABNEW()
Value Integer JDEB, JFIN

Local Integer J
Local Decimal TOT, MT

For J=JDEB To JFIN
  If TABMT(J)>0 & TABNEW(J)>0
     TOT = sigma(J,JFIN,TABMT(indcum)*(TABMT(indcum)>0 & TABNEW(indcum)>0))
     If TOT=0 : Break : Endif

     MT = arr(min(TABNEW(J),TABMT(J),TABMT(J)*AREPARTIR/TOT),[V]GRNDVAL)
     If MT<>0
         TABMT(J)-= MT
         TABNEW(J)-= MT
         AREPARTIR -= MT
         If AREPARTIR<[V]GRNDVAL : AREPARTIR=0 : Endif
         If AREPARTIR=0 : Break : Endif
     Endif
  Endif
Next J
End

###############################################################################
# CALCABS        Calcule le montant absorbé et le montant absorbé
#                d'un changement de valeur
###############################################################################
# Paramètres E:  LFCY     = Site
#                LQTYORI  = Quantité en stock
#                           --> correspond au nb d'articles qui absorbent LAMT
#                LAMTORI  = Montant du stock
#                LQTY     = Quantité d'articles concernés par la différence de montant
#                LAMT     = Montant à absorber
#
# Paramètres S:  LABS     = Montant absorbé par les [M:SDPO]QTY articles
#
# La différence LAMT-LABS donne le montant non absorbé
###############################################################################
Subprog CALCABS( LFCY, LQTYORI, LAMTORI, LQTY, LAMT, LABS, LQTYABS)
Value    Char    LFCY
Value    Decimal LQTYORI
Value    Decimal LAMTORI
Value    Decimal LQTY
Value    Decimal LAMT
Variable Decimal LABS
Variable Decimal LQTYABS

Local Char    WPAR
Local Integer WMAXCOD
Local Decimal WMAXABS, LQTYTOT

  If LQTYORI=0
    LABS = 0
    End
  Endif

#Vérifie que l'absorption doit être effectuée
  Call PARAM(LFCY,"MAXABSCOD",WPAR) From ADOVAL
  WMAXCOD = val(WPAR)

  If WMAXCOD=1
    LABS = LAMT
  Else
    # L'absorption doit être faite
    # => On récupère la valeur du maxi d'absorption
    Call PARAM(LFCY,"MAXABSPER",WPAR) From ADOVAL
    WMAXABS = val(WPAR)/100
    # Dans le cas d'une régul d'avoir sur retour fournisseur on a une quantité négative

    #MJH X3-77649.n we need to get the total amount invoiced on this line so far
    If [F:ITV]VCRTYP = 6 and clalev([F:PID]) and LQTYORI <> LQTY #MJH X3-101694. When MAXABSCOD is set to site/lot, it uses the full receipt amount per lot
      Local File PINVOICE [PIHA]
      Local File PINVOICED [PIDA]
      Link [PIDA] With [PIHA] PIH0~=[F:PIDA]NUM As [PIHD] Where [PIHA]STA = 3 and [F:PIDA]ITMREF = [F:PID]ITMREF and [F:PIDA]NUMORI = [F:PID]NUMORI
      For [PIHD]
        LQTYTOT += [F:PIDA]QTYPUU
      Next
    Endif

    LQTYTOT += LQTY
#    If LQTYORI>=abs(LQTY) #X3-77649.o
    If LQTYORI>=abs(LQTYTOT) #X3-77649.n
      LABS = LAMT
    Else
#      LTMP  = LQTYORI*LAMT/abs(LQTY)   # Absorption directe par le stock encore présent
      LTMP  = LQTYORI*LAMT/abs(LQTYTOT) #X3-77649.n
      LTMP2 = LTMP+LAMTORI              # nouveau montant après absorption directe
      LTMP3 = WMAXABS * LTMP2 * sgn(LAMT) # Montant maxi supplémentaire pouvant être absorbé
      LABS  = LTMP+LTMP3                # Montant pouvant être absorbé au maxi
      If LABS<0
        LABS = max (LAMT, LABS)
      Else
        LABS = min (LAMT, LABS)
      Endif
    Endif
  Endif

  # CCC (30/08/05) Bug 30212 : On ne peut pas retrancher plus que la valeur du stock
  If LAMTORI+LABS < 0
    LABS = -LAMTORI
  Endif
  LQTYABS = min(abs(LQTYORI),abs(LQTY))
End

##################################################
$CALCDETABS
If dim(LCOEF)<1 : Local Decimal LCOEF : Endif
If dim(LCOEFDEV)<1 : Local Decimal LCOEFDEV : Endif


If [M:SDPD]AMTTOT<>0
    Local Decimal LTABCLE(dim(LTABVAL))
    Call LOADVAR(LTABCLE, "[M:SDPD]", 0, "", 1, 0, 0) From STKVALECR
    For I=0 To [M:SRW]NBLIG-1
        Raz LTABVAL
        Call REPVAL([M:SRW]AMTABS(I), LTABCLE, WRND_SOC, LTABVAL) From STKVALECR
        Call LOADFIC2("[M:SRW]", LTABVAL, "", "CST", I, 1, 0) From STKVALECR
        Raz LTABVAL
        Call REPVAL([M:SRW]AMTNABS(I), LTABCLE, WRND_SOC, LTABVAL) From STKVALECR
        Call LOADFIC2("[M:SRW]", LTABVAL, "DEV", "CST", I, 1, 0) From STKVALECR
    Next
Else
    Local Decimal LTABCLE([M:SRW]NBLIG)
    Local Decimal LTABVALQTY([M:SRW]NBLIG)  # Issue 103336 - 2014-10-13 by CCC : distribution according to quantities
    Local Decimal LVAL
    Local Integer LDIMZON, LINDZONMAX
    Raz LTABCLE
    # Si le montant global est nul, on répartit les détails selon les quantités des lignes
    For I=0 To [M:SRW]NBLIG-1
        If WMAXABSCOD= 3 & LTOTSTOLOT<>0
            LTABCLE(I) = [M:SRW]QTYSTOLOT(I)
        Else
            LTABCLE(I) = [M:SRW]QTYSTU(I)
        Endif
    Next
    LMAX=0
    For LZON="MAT","MAC","LAB","SCO","INVDTA","OVEMAT","OVEMAC","OVELAB","OVESCO"
        If find(LZON,"MAT","MAC","LAB")
            LDIMZON = evalue("GACT"+LZON)
        Else
            LDIMZON=1
        Endif
        For J=0 To LDIMZON-1
            Raz LTABVALQTY
            LVAL = evalue("[M:SDPD]"+LZON+"CST(J)")
            Call REPVAL(LVAL, LTABCLE, WRND_SOC, LTABVALQTY) From STKVALECR
            For I=0 To [M:SRW]NBLIG-1
                Assign "[M:SRW]"+string$(LCTRIPT(I)=2,"DEV")+LZON+"CST(I*LDIMZON+J)" With LTABVALQTY(I)
            Next
            # On retient la valeur la plus importante pour lui affecter les erreurs d'arrondis
            If LMAX<abs(LVAL)
                LZONMAX=LZON
                LINDZONMAX=J
                LMAX=abs([M:SDPD]MATCST(J))
            Endif
        Next
    Next
    # Chaque ligne de SRW doit avoir une somme du détail nulle
    # L'écart trouvé sur une ligne se retrouve forcément à l'opposé sur les autres lignes
    # car la somme globale fait déjà 0
    For I=0 To [M:SRW]NBLIG-1
        Raz LTABVAL
        Call LOADVAR3(LTABVAL, "[M:SRW]", 0, "", "CST", I, 1, 0, 0) From STKVALECR
        If sum(LTABVAL)<>0
            LDIMZON = evalue("dim([M:SDPD]"+LZONMAX+"CST)")
                If LDIMZON>1
                    Assign "[M:SRW]"+string$(LCTRIPT(I)=2,"DEV")+LZONMAX+"CST(I*GACT"+LZONMAX+"+LINDZONMAX)"
&                     With evalue("[M:SRW]"+string$(LCTRIPT(I)=2,"DEV")+LZONMAX+"CST(I*GACT"+LZONMAX+"+LINDZONMAX)")
&                        - sum(LTABVAL)
                Else
                    Assign "[M:SRW]"+string$(LCTRIPT(I)=2,"DEV")+LZONMAX+"CST(I)"
&                     With evalue("[M:SRW]"+string$(LCTRIPT(I)=2,"DEV")+LZONMAX+"CST(I)")
&                        - sum(LTABVAL)
                Endif
        Endif
    Next
Endif
Return

## Si [M:SDPD]AMTTOT=0 on absorbe tout
#
#    For I=0 To [M:SRW]NBLIG-2
#        If [M:SDPD]AMTTOT= 0
#            If LCTRIPT(I)=2                # Si on n'absorbe rien à cause du contrôle de date
#                LCOEF = 0
#                If WMAXABSCOD= 3 & LTOTSTOLOT<>0
#                    LCOEFDEV = [M:SRW]QTYSTOLOT(I)/LTOTSTOLOT
#                Else
#                    LCOEFDEV = [M:SRW]QTYSTU(I)/sum([M:SRW]QTYSTU)
#                Endif
#            Else
#                If WMAXABSCOD= 3 & LTOTSTOLOT<>0
#                    LCOEF = [M:SRW]QTYSTOLOT(I)/LTOTSTOLOT
#                Else
#                    LCOEF = [M:SRW]QTYSTU(I)/sum([M:SRW]QTYSTU)
#                Endif
#                LCOEFDEV = 0
#            Endif
#        Else
#            LCOEF = [M:SRW]AMTABS(I)/[M:SDPD]AMTTOT
#            LCOEFDEV = [M:SRW]AMTNABS(I)/[M:SDPD]AMTTOT
#        Endif
##----- Matière -----#
#        For J=0 To GACTMAT-1
#            [M:SRW]MATCST(I*GACTMAT+J) = arr([M:SDPD]MATCST(J) * LCOEF,WRND_SOC)
#        Next
#        [M:SRW]OVEMATCST(I) = arr([M:SDPD]OVEMATCST * LCOEF,WRND_SOC)
##----- Machine -----#
#        For J=0 To GACTMAC-1
#            [M:SRW]MACCST(I*GACTMAC+J) = arr([M:SDPD]MACCST(J) * LCOEF,WRND_SOC)
#        Next
#        [M:SRW]OVEMACCST(I) = arr([M:SDPD]OVEMACCST * LCOEF,WRND_SOC)
##----- Main d'oeuvre -----#
#        For J=0 To GACTLAB-1
#            [M:SRW]LABCST(I*GACTLAB+J) = arr([M:SDPD]LABCST(J) * LCOEF,WRND_SOC)
#        Next
#        [M:SRW]OVELABCST(I) = arr([M:SDPD]OVELABCST * LCOEF,WRND_SOC)
##----- Sous-traitance -----#
#        # Issue 76137 - 2011-09-09 by CCC
#        #[M:SRW]SCOCST(I)  = arr([M:SDPD]SCOTOT * LCOEF,WRND_SOC)
#        [M:SRW]SCOCST(I)  = arr([M:SDPD]SCOCST * LCOEF,WRND_SOC)
#        [M:SRW]OVESCOCST(I) = arr([M:SDPD]OVESCOCST * LCOEF,WRND_SOC)
#
#        [M:SRW]INVDTACST(I) = arr([M:SDPD]INVDTACST * LCOEF,WRND_SOC)
#
##### Non absorbé ####
##----- Matière -----#
#        For J=0 To GACTMAT-1
#            [M:SRW]DEVMATCST(I*GACTMAT+J) = arr([M:SDPD]MATCST(J) * LCOEFDEV,WRND_SOC)
#        Next
#        [M:SRW]DEVOVEMATCST(I) = arr([M:SDPD]OVEMATCST * LCOEFDEV,WRND_SOC)
##----- Machine -----#
#        For J=0 To GACTMAC-1
#            [M:SRW]DEVMACCST(I*GACTMAC+J) = arr([M:SDPD]MACCST(J) * LCOEFDEV,WRND_SOC)
#        Next
#        [M:SRW]DEVOVEMACCST(I) = arr([M:SDPD]OVEMACCST * LCOEFDEV,WRND_SOC)
##----- Main d'oeuvre -----#
#        For J=0 To GACTLAB-1
#            [M:SRW]DEVLABCST(I*GACTLAB+J) = arr([M:SDPD]LABCST(J) * LCOEFDEV,WRND_SOC)
#        Next
#        [M:SRW]DEVOVELABCST(I) = arr([M:SDPD]OVELABCST * LCOEFDEV,WRND_SOC)
##----- Sous-traitance -----#
#        #[M:SRW]DEVSCOCST(I)  = arr([M:SDPD]SCOTOT * LCOEFDEV,WRND_SOC)
#        [M:SRW]DEVSCOCST(I)  = arr([M:SDPD]SCOCST * LCOEFDEV,WRND_SOC)
#        [M:SRW]DEVOVESCOCST(I) = arr([M:SDPD]OVESCOCST * LCOEFDEV,WRND_SOC)
#
#        [M:SRW]DEVINVDTACST(I) = arr([M:SDPD]INVDTACST * LCOEFDEV,WRND_SOC)
#
#        [M:SRW]AMTABS(I) = sigma(0,GACTMAT-1,[M:SRW]MATCST(I*GACTMAT+indcum))
#&                         +sigma(0,GACTMAC-1,[M:SRW]MACCST(I*GACTMAC+indcum))
#&                         +sigma(0,GACTLAB-1,[M:SRW]LABCST(I*GACTLAB+indcum))
#&                         +[M:SRW]SCOCST(I)
#&                         +[M:SRW]INVDTACST(I)
#&                         +[M:SRW]OVEMATCST(I)+[M:SRW]OVEMACCST(I)+[M:SRW]OVELABCST(I)+[M:SRW]OVESCOCST(I)
#        [M:SRW]AMTNABS(I) = sigma(0,GACTMAT-1,[M:SRW]DEVMATCST(I*GACTMAT+indcum))
#&                         +sigma(0,GACTMAC-1,[M:SRW]DEVMACCST(I*GACTMAC+indcum))
#&                         +sigma(0,GACTLAB-1,[M:SRW]DEVLABCST(I*GACTLAB+indcum))
#&                         +[M:SRW]DEVSCOCST(I)
#&                         +[M:SRW]DEVINVDTACST(I)
#&                         +[M:SRW]DEVOVEMATCST(I)+[M:SRW]DEVOVEMACCST(I)+[M:SRW]DEVOVELABCST(I)+[M:SRW]DEVOVESCOCST(I)
#    Next
#
#    If [M:SDPD]AMTTOT= 0
#        # Issue 96591 - 2013-11-18 by CCC : Tenir compte de LCTRIPT
#        If LCTRIPT([M:SRW]NBLIG-1)=2    # Si on n'absorbe rien Ã  cause du contrÃ´le de date
#            LCOEF = 0
#            LCOEFDEV = 1
#        Else
#            LCOEF = 1
#            LCOEFDEV = 0
#        Endif
#    Else
#        LCOEF = sum([M:SRW]AMTABS([M:SRW]NBLIG-1))/[M:SDPD]AMTTOT
#        LCOEFDEV = sum([M:SRW]AMTNABS([M:SRW]NBLIG-1))/[M:SDPD]AMTTOT
#    Endif
##----- Matière -----#
#    For J=0 To GACTMAT-1
#        [M:SRW]MATCST(([M:SRW]NBLIG-1)*GACTMAT+J) = arr(([M:SDPD]MATCST(J) - sigma(0,[M:SRW]NBLIG-2,[M:SRW]MATCST(indcum*GACTMAT+J)))* LCOEF,WRND_SOC)
#    Next
#    [M:SRW]OVEMATCST([M:SRW]NBLIG-1) = arr(([M:SDPD]OVEMATCST - sum([M:SRW]OVEMATCST))* LCOEF,WRND_SOC)
##----- Machine -----#
#    For J=0 To GACTMAC-1
#        [M:SRW]MACCST(([M:SRW]NBLIG-1)*GACTMAC+J) = arr(([M:SDPD]MACCST(J) - sigma(0,[M:SRW]NBLIG-2,[M:SRW]MACCST(indcum*GACTMAC+J))) * LCOEF,WRND_SOC)
#    Next
#    [M:SRW]OVEMACCST([M:SRW]NBLIG-1) = arr(([M:SDPD]OVEMACCST - sum([M:SRW]OVEMACCST)) * LCOEF,WRND_SOC)
##----- Main d'oeuvre -----#
#    For J=0 To GACTLAB-1
#        [M:SRW]LABCST(([M:SRW]NBLIG-1)*GACTLAB+J) = arr(([M:SDPD]LABCST(J) - sigma(0,[M:SRW]NBLIG-2,[M:SRW]LABCST(indcum*GACTLAB+J))) * LCOEF,WRND_SOC)
#    Next
#    [M:SRW]OVELABCST([M:SRW]NBLIG-1) = arr(([M:SDPD]OVELABCST - sum([M:SRW]OVELABCST)) * LCOEF,WRND_SOC)
##----- Sous-traitance -----#
#    #[M:SRW]SCOCST([M:SRW]NBLIG-1)  = arr([M:SDPD]SCOTOT * LCOEF,WRND_SOC)  - sum([M:SRW]SCOCST)
#    [M:SRW]SCOCST([M:SRW]NBLIG-1)  = arr(([M:SDPD]SCOCST - sum([M:SRW]SCOCST)) * LCOEF,WRND_SOC)
#    [M:SRW]OVESCOCST([M:SRW]NBLIG-1) = arr(([M:SDPD]OVESCOCST - sum([M:SRW]OVESCOCST)) * LCOEF,WRND_SOC)
#
#    [M:SRW]INVDTACST([M:SRW]NBLIG-1)  = arr(([M:SDPD]INVDTACST - sum([M:SRW]INVDTACST)) * LCOEF,WRND_SOC)
#
###### Non absorbé #####
##----- Matière -----#
#    For J=0 To GACTMAT-1
#        [M:SRW]DEVMATCST(([M:SRW]NBLIG-1)*GACTMAT+J) = arr([M:SDPD]MATCST(J)
#&                                                        - sigma(0,[M:SRW]NBLIG-1,[M:SRW]MATCST(indcum*GACTMAT+J))
#&                                                        - sigma(0,[M:SRW]NBLIG-2,[M:SRW]DEVMATCST(indcum*GACTMAT+J)),WRND_SOC)
#    Next
#    [M:SRW]DEVOVEMATCST([M:SRW]NBLIG-1) = arr([M:SDPD]OVEMATCST
#&                                           - sum([M:SRW]OVEMATCST)
#&                                           - sum([M:SRW]DEVOVEMATCST),WRND_SOC)
##----- Machine -----#
#    For J=0 To GACTMAC-1
#        [M:SRW]DEVMACCST(([M:SRW]NBLIG-1)*GACTMAC+J) = arr([M:SDPD]MACCST(J)
#&                                                        - sigma(0,[M:SRW]NBLIG-1,[M:SRW]MACCST(indcum*GACTMAC+J))
#&                                                        - sigma(0,[M:SRW]NBLIG-2,[M:SRW]DEVMACCST(indcum*GACTMAC+J)),WRND_SOC)
#    Next
#    [M:SRW]DEVOVEMACCST([M:SRW]NBLIG-1) = arr([M:SDPD]OVEMACCST
#&                                           - sum([M:SRW]OVEMACCST)
#&                                           - sum([M:SRW]DEVOVEMACCST),WRND_SOC)
##----- Main d'oeuvre -----#
#    For J=0 To GACTLAB-1
#        [M:SRW]DEVLABCST(([M:SRW]NBLIG-1)*GACTLAB+J) = arr([M:SDPD]LABCST(J)
#&                                                        - sigma(0,[M:SRW]NBLIG-1,[M:SRW]LABCST(indcum*GACTLAB+J))
#&                                                        - sigma(0,[M:SRW]NBLIG-2,[M:SRW]DEVLABCST(indcum*GACTLAB+J)),WRND_SOC)
#    Next
#    [M:SRW]DEVOVELABCST([M:SRW]NBLIG-1) = arr([M:SDPD]OVELABCST
#&                                           - sum([M:SRW]OVELABCST)
#&                                           - sum([M:SRW]DEVOVELABCST),WRND_SOC)
##----- Sous-traitance -----#
#    #[M:SRW]DEVSCOCST([M:SRW]NBLIG-1)  = arr([M:SDPD]SCOTOT * LCOEFDEV,WRND_SOC)  - sum([M:SRW]DEVSCOCST)
#    [M:SRW]DEVSCOCST([M:SRW]NBLIG-1)  = arr([M:SDPD]SCOCST
#&                                         - sum([M:SRW]SCOCST)
#&                                         - sum([M:SRW]DEVSCOCST),WRND_SOC)
#    [M:SRW]DEVOVESCOCST([M:SRW]NBLIG-1) = arr([M:SDPD]OVESCOCST
#&                                           - sum([M:SRW]OVESCOCST)
#&                                           - sum([M:SRW]DEVOVESCOCST),WRND_SOC)
#
#    [M:SRW]DEVINVDTACST([M:SRW]NBLIG-1)  = arr([M:SDPD]INVDTACST
#&                                            - sum([M:SRW]INVDTACST)
#&                                            - sum([M:SRW]DEVINVDTACST),WRND_SOC)
#
#    [M:SRW]AMTABS([M:SRW]NBLIG-1) = sigma(0,GACTMAT-1,[M:SRW]MATCST(([M:SRW]NBLIG-1)*GACTMAT+indcum))
#&                                  +sigma(0,GACTMAC-1,[M:SRW]MACCST(([M:SRW]NBLIG-1)*GACTMAC+indcum))
#&                                  +sigma(0,GACTLAB-1,[M:SRW]LABCST(([M:SRW]NBLIG-1)*GACTLAB+indcum))
#&                                  +[M:SRW]SCOCST([M:SRW]NBLIG-1)
#&                                  +[M:SRW]INVDTACST([M:SRW]NBLIG-1)
#&                                  +[M:SRW]OVEMATCST([M:SRW]NBLIG-1)+[M:SRW]OVEMACCST([M:SRW]NBLIG-1)+[M:SRW]OVELABCST([M:SRW]NBLIG-1)+[M:SRW]OVESCOCST([M:SRW]NBLIG-1)
#    [M:SRW]AMTNABS([M:SRW]NBLIG-1) = sigma(0,GACTMAT-1,[M:SRW]DEVMATCST(([M:SRW]NBLIG-1)*GACTMAT+indcum))
#&                                  +sigma(0,GACTMAC-1,[M:SRW]DEVMACCST(([M:SRW]NBLIG-1)*GACTMAC+indcum))
#&                                  +sigma(0,GACTLAB-1,[M:SRW]DEVLABCST(([M:SRW]NBLIG-1)*GACTLAB+indcum))
#&                                  +[M:SRW]DEVSCOCST([M:SRW]NBLIG-1)
#&                                  +[M:SRW]DEVINVDTACST([M:SRW]NBLIG-1)
#&                                  +[M:SRW]DEVOVEMATCST([M:SRW]NBLIG-1)+[M:SRW]DEVOVEMACCST([M:SRW]NBLIG-1)+[M:SRW]DEVOVELABCST([M:SRW]NBLIG-1)+[M:SRW]DEVOVESCOCST([M:SRW]NBLIG-1)
Return

#############################################################
# LCOEF : coefficient multiplicateur
# INDLIG     : indice de la ligne en cours
$SAVDETITV
    #------ Matière -----#
    For I=0 To GACTMAT-1
        [F:ITV]AMATCST(I) += sigma(0,[M:SRW]NBLIG-1,[M:SRW]MATCST(indcum*GACTMAT+I))*LCOEF
    Next
    [F:ITV]AOVEMATCST += sum([M:SRW]OVEMATCST)*LCOEF

    #------ Machine -----#
    For I=0 To GACTMAC-1
        [F:ITV]AMACCST(I) += sigma(0,[M:SRW]NBLIG-1,[M:SRW]MACCST(indcum*GACTMAC+I))*LCOEF
    Next
    [F:ITV]AOVEMACCST += sum([M:SRW]OVEMACCST)*LCOEF

    #------ Main d'oeuvre -----#
    For I=0 To GACTLAB-1
        [F:ITV]ALABCST(I) += sigma(0,[M:SRW]NBLIG-1,[M:SRW]LABCST(indcum*GACTLAB+I))*LCOEF
    Next
    [F:ITV]AOVELABCST += sum([M:SRW]OVELABCST)*LCOEF

    #------ Sous-traitance -----#
    [F:ITV]ASCOCST    += sum([M:SRW]SCOCST)*LCOEF
    [F:ITV]AOVESCOCST += sum([M:SRW]OVESCOCST)*LCOEF

    [F:ITV]AINVDTACST += sum([M:SRW]INVDTACST)*LCOEF

    If !clalev([F:ITV1]) : Local File ITMMVT [ITV1] : Endif
    [F:ITV1] = [F:ITV]
    Read [ITV1] =

    If dim([L]SRWCOR)=1 & [L]SRWCOR>0
       Gosub COR_SRW
    Else
      For I=0 To GACTMAT-1
          Call ECRTRACE("[F:ITV]AMATCST("+num$(I)+") +="+num$([F:ITV]AMATCST(I)-[F:ITV1]AMATCST(I)),0) From STKVAL
      Next
      Call ECRTRACE("[F:ITV]AOVEMATCST +="+num$([F:ITV]AOVEMATCST-[F:ITV1]AOVEMATCST),0) From STKVAL

      For I=0 To GACTMAC-1
          Call ECRTRACE("[F:ITV]AMACCST("+num$(I)+") +="+num$([F:ITV]AMACCST(I)-[F:ITV1]AMACCST(I)),0) From STKVAL
      Next
      Call ECRTRACE("[F:ITV]AOVEMACCST +="+num$([F:ITV]AOVEMACCST-[F:ITV1]AOVEMACCST),0) From STKVAL
      For I=0 To GACTLAB-1
          Call ECRTRACE("[F:ITV]ALABCST("+num$(I)+") +="+num$([F:ITV]ALABCST(I)-[F:ITV1]ALABCST(I)),0) From STKVAL
      Next
      Call ECRTRACE("[F:ITV]AOVELABCST +="+num$([F:ITV]AOVELABCST-[F:ITV1]AOVELABCST),0) From STKVAL

      Call ECRTRACE("[F:ITV]ASCOCST    +="+num$([F:ITV]ASCOCST-[F:ITV1]ASCOCST),0) From STKVAL
      Call ECRTRACE("[F:ITV]AOVESCOCST +="+num$([F:ITV]AOVESCOCST-[F:ITV1]AOVESCOCST),0) From STKVAL

      Call ECRTRACE("[F:ITV]AINVDTACST +="+num$([F:ITV]AINVDTACST-[F:ITV1]AINVDTACST),0) From STKVAL
    Endif
Return

#############################################################
# LCOEF : coefficient multiplicateur
# INDLIG     : indice de la ligne en cours
$SAVDETSTP
#---------- Matière ---------------#
    For J=0 To GACTMAT-1
        [F:STP]MATCST(J) += LCOEF * sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]MATCST(indcum*GACTMAT+J)
&                                                   *( [M:SRW]VCRTYP(INDLIG)=[M:SRW]VCRTYP(indcum)
&                                                   & [M:SRW]VCRNUM(INDLIG)=[M:SRW]VCRNUM(indcum)
&                                                   & [M:SRW]VCRLIN(INDLIG)=[M:SRW]VCRLIN(indcum)))
    Next
    [F:STP]OVEMATCST += LCOEF * sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]OVEMATCST(indcum)
&                                                   *( [M:SRW]VCRTYP(INDLIG)=[M:SRW]VCRTYP(indcum)
&                                                   & [M:SRW]VCRNUM(INDLIG)=[M:SRW]VCRNUM(indcum)
&                                                   & [M:SRW]VCRLIN(INDLIG)=[M:SRW]VCRLIN(indcum)))
#---------- Machine ---------------#
    For J=0 To GACTMAC-1
        [F:STP]MACCST(J) += LCOEF * sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]MACCST(indcum*GACTMAC+J)
&                                                   *( [M:SRW]VCRTYP(INDLIG)=[M:SRW]VCRTYP(indcum)
&                                                   & [M:SRW]VCRNUM(INDLIG)=[M:SRW]VCRNUM(indcum)
&                                                   & [M:SRW]VCRLIN(INDLIG)=[M:SRW]VCRLIN(indcum)))
    Next
    [F:STP]OVEMACCST += LCOEF * sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]OVEMACCST(indcum)
&                                                   *( [M:SRW]VCRTYP(INDLIG)=[M:SRW]VCRTYP(indcum)
&                                                   & [M:SRW]VCRNUM(INDLIG)=[M:SRW]VCRNUM(indcum)
&                                                   & [M:SRW]VCRLIN(INDLIG)=[M:SRW]VCRLIN(indcum)))
#---------- Main d'oeuvre ---------------#
    For J=0 To GACTLAB-1
        [F:STP]LABCST(J) += LCOEF * sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]LABCST(indcum*GACTLAB+J)
&                                                   *( [M:SRW]VCRTYP(INDLIG)=[M:SRW]VCRTYP(indcum)
&                                                   & [M:SRW]VCRNUM(INDLIG)=[M:SRW]VCRNUM(indcum)
&                                                   & [M:SRW]VCRLIN(INDLIG)=[M:SRW]VCRLIN(indcum)))
    Next
    [F:STP]OVELABCST += LCOEF * sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]OVELABCST(indcum)
&                                                   *( [M:SRW]VCRTYP(INDLIG)=[M:SRW]VCRTYP(indcum)
&                                                   & [M:SRW]VCRNUM(INDLIG)=[M:SRW]VCRNUM(indcum)
&                                                   & [M:SRW]VCRLIN(INDLIG)=[M:SRW]VCRLIN(indcum)))
#---------- Sous-traitance ---------------#
    [F:STP]SCOCST    += LCOEF * sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]SCOCST(indcum)
&                                                   *( [M:SRW]VCRTYP(INDLIG)=[M:SRW]VCRTYP(indcum)
&                                                   & [M:SRW]VCRNUM(INDLIG)=[M:SRW]VCRNUM(indcum)
&                                                   & [M:SRW]VCRLIN(INDLIG)=[M:SRW]VCRLIN(indcum)))
    [F:STP]OVESCOCST += LCOEF * sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]OVESCOCST(indcum)
&                                                   *( [M:SRW]VCRTYP(INDLIG)=[M:SRW]VCRTYP(indcum)
&                                                   & [M:SRW]VCRNUM(INDLIG)=[M:SRW]VCRNUM(indcum)
&                                                   & [M:SRW]VCRLIN(INDLIG)=[M:SRW]VCRLIN(indcum)))

    [F:STP]INVDTACST += LCOEF * sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]INVDTACST(indcum)
&                                                   *( [M:SRW]VCRTYP(INDLIG)=[M:SRW]VCRTYP(indcum)
&                                                   & [M:SRW]VCRNUM(INDLIG)=[M:SRW]VCRNUM(indcum)
&                                                   & [M:SRW]VCRLIN(INDLIG)=[M:SRW]VCRLIN(indcum)))

    If !clalev([F:STP1]) : Local File STOCOST [STP1] : Endif
    [F:STP1] = [F:STP]
    Read [STP1]STP0=[F:STP]ITMREF;[F:STP]STOFCY;[F:STP]CSTDAT;[F:STP]CSTTIM;[F:STP]CSTCOU

    If dim([L]SRWCOR)=1 & [L]SRWCOR>0
       Gosub COR_SRW
    Else
      For J=0 To GACTMAT-1
          Call ECRTRACE("[F:STP]MATCST("+num$(J)+") +="+num$([F:STP]MATCST(J)-[F:STP1]MATCST(J)),0) From STKVAL
      Next
      Call ECRTRACE("[F:STP]OVEMATCST +="+num$([F:STP]OVEMATCST-[F:STP1]OVEMATCST),0) From STKVAL

      For J=0 To GACTMAC-1
          Call ECRTRACE("[F:STP]MACCST("+num$(J)+") +="+num$([F:STP]MACCST(J)-[F:STP1]MACCST(J)),0) From STKVAL
      Next
      Call ECRTRACE("[F:STP]OVEMACCST +="+num$([F:STP]OVEMACCST-[F:STP1]OVEMACCST),0) From STKVAL

      For J=0 To GACTLAB-1
          Call ECRTRACE("[F:STP]LABCST("+num$(J)+") +="+num$([F:STP]LABCST(J)-[F:STP1]LABCST(J)),0) From STKVAL
      Next
      Call ECRTRACE("[F:STP]OVELABCST +="+num$([F:STP]OVELABCST-[F:STP1]OVELABCST),0) From STKVAL

      Call ECRTRACE("[F:STP]SCOCST +="+num$([F:STP]SCOCST-[F:STP1]SCOCST),0) From STKVAL
      Call ECRTRACE("[F:STP]OVESCOCST +="+num$([F:STP]OVESCOCST-[F:STP1]OVESCOCST),0) From STKVAL

      Call ECRTRACE("[F:STP]INVDTACST +="+num$([F:STP]INVDTACST-[F:STP1]INVDTACST),0) From STKVAL
    Endif
Return

#############################################################
# LCOEF : coefficient multiplicateur
# INDLIG     : indice de la ligne en cours
$SAVDETSLF
#---------- Matière ---------------#
    For J=0 To GACTMAT-1
        [F:SLF]AMATCST(J) += arr(LCOEF * sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]MATCST(indcum*GACTMAT+J)
&                                                   *( [M:SRW]LOT(INDLIG)=[M:SRW]LOT(indcum) & [M:SRW]SLO(INDLIG)=[M:SRW]SLO(indcum))), WRND_SOC)
    Next
#---------- Machine ---------------#
    For J=0 To GACTMAC-1
        [F:SLF]AMACCST(J) += arr(LCOEF * sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]MACCST(indcum*GACTMAC+J)
&                                                   *( [M:SRW]LOT(INDLIG)=[M:SRW]LOT(indcum) & [M:SRW]SLO(INDLIG)=[M:SRW]SLO(indcum))), WRND_SOC)
    Next
#---------- Main d'oeuvre ---------------#
    For J=0 To GACTLAB-1
        [F:SLF]ALABCST(J) += arr(LCOEF * sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]LABCST(indcum*GACTLAB+J)
&                                                   *( [M:SRW]LOT(INDLIG)=[M:SRW]LOT(indcum) & [M:SRW]SLO(INDLIG)=[M:SRW]SLO(indcum))), WRND_SOC)
    Next
#---------- Sous-traitance ---------------#
    [F:SLF]ASCOCST    += arr(LCOEF * sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]SCOCST(indcum)
&                                                   *( [M:SRW]LOT(INDLIG)=[M:SRW]LOT(indcum) & [M:SRW]SLO(INDLIG)=[M:SRW]SLO(indcum))), WRND_SOC)
    [F:SLF]AINVDTACST += arr(LCOEF * sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]INVDTACST(indcum)
&                                                   *( [M:SRW]LOT(INDLIG)=[M:SRW]LOT(indcum) & [M:SRW]SLO(INDLIG)=[M:SRW]SLO(indcum))), WRND_SOC)

    [F:SLF]AOVEMATCST += arr(LCOEF * sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]OVEMATCST(indcum)
&                                                   *( [M:SRW]LOT(INDLIG)=[M:SRW]LOT(indcum) & [M:SRW]SLO(INDLIG)=[M:SRW]SLO(indcum))), WRND_SOC)
    [F:SLF]AOVEMACCST += arr(LCOEF * sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]OVEMACCST(indcum)
&                                                   *( [M:SRW]LOT(INDLIG)=[M:SRW]LOT(indcum) & [M:SRW]SLO(INDLIG)=[M:SRW]SLO(indcum))), WRND_SOC)
    [F:SLF]AOVELABCST += arr(LCOEF * sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]OVELABCST(indcum)
&                                                   *( [M:SRW]LOT(INDLIG)=[M:SRW]LOT(indcum) & [M:SRW]SLO(INDLIG)=[M:SRW]SLO(indcum))), WRND_SOC)
    [F:SLF]AOVESCOCST += arr(LCOEF * sigma(INDLIG,[M:SRW]NBLIG-1,[M:SRW]OVESCOCST(indcum)
&                                                   *( [M:SRW]LOT(INDLIG)=[M:SRW]LOT(indcum) & [M:SRW]SLO(INDLIG)=[M:SRW]SLO(indcum))), WRND_SOC)

    # Gestion des écarts entre le détail et le total
    LTOTCST = sum([F:SLF]AMATCST)+sum([F:SLF]AMACCST)+sum([F:SLF]ALABCST)+[F:SLF]ASCOCST+[F:SLF]AINVDTACST
&            +[F:SLF]AOVEMATCST+[F:SLF]AOVEMACCST+[F:SLF]AOVELABCST+[F:SLF]AOVESCOCST
    If LTOTCST<>[F:SLF]AVCBASAMT & (dim([L]SRWCOR)<1 | [L]SRWCOR=0)
        If dim(LZONMAX)<=0 : Local Char LZONMAX(50) : Endif
        If dim(LVALMAX)<=0 : Local Decimal LVALMAX : Endif
        LZONMAX = "AMATCST("+num$(max(0,[F:ITM]BRDCOD-1))+")"
        LVALMAX = 0

        # Issue 81176 - 2012-03-29 by CCC : on va chercher la zone la plus importante pour lui mettre la différence.
        If LTOTCST=0
            LTOTCST=[F:SLF]AVCBASAMT
        Endif

        For J=0 To GACTMAT-1
            [F:SLF]AMATCST(J) = arr([F:SLF]AMATCST(J)/LTOTCST*[F:SLF]AVCBASAMT,WRND_SOC)
            If LVALMAX < abs([F:SLF]AMATCST(J))
                LVALMAX = abs([F:SLF]AMATCST(J))
                LZONMAX = "AMATCST("+num$(J)+")"
            Endif
        Next
        For J=0 To GACTMAC-1
            [F:SLF]AMACCST(J) = arr([F:SLF]AMACCST(J)/LTOTCST*[F:SLF]AVCBASAMT,WRND_SOC)
            If LVALMAX < abs([F:SLF]AMACCST(J))
                LVALMAX = abs([F:SLF]AMACCST(J))
                LZONMAX = "AMACCST("+num$(J)+")"
            Endif
        Next
        For J=0 To GACTLAB-1
            [F:SLF]ALABCST(J) = arr([F:SLF]ALABCST(J)/LTOTCST*[F:SLF]AVCBASAMT,WRND_SOC)
            If LVALMAX < abs([F:SLF]ALABCST(J))
                LVALMAX = abs([F:SLF]ALABCST(J))
                LZONMAX = "ALABCST("+num$(J)+")"
            Endif
        Next
        [F:SLF]ASCOCST = arr([F:SLF]ASCOCST/LTOTCST*[F:SLF]AVCBASAMT,WRND_SOC)
        If LVALMAX < abs([F:SLF]ASCOCST)
            LVALMAX = abs([F:SLF]ASCOCST)
            LZONMAX = "ASCOCST"
        Endif
        [F:SLF]AINVDTACST = arr([F:SLF]AINVDTACST/LTOTCST*[F:SLF]AVCBASAMT,WRND_SOC)
        If LVALMAX < abs([F:SLF]AINVDTACST)
            LVALMAX = abs([F:SLF]AINVDTACST)
            LZONMAX = "AINVDTACST"
        Endif

        [F:SLF]AOVEMATCST = arr([F:SLF]AOVEMATCST/LTOTCST*[F:SLF]AVCBASAMT,WRND_SOC)
        If LVALMAX < abs([F:SLF]AOVEMATCST)
            LVALMAX = abs([F:SLF]AOVEMATCST)
            LZONMAX = "AOVEMATCST"
        Endif
        [F:SLF]AOVEMACCST = arr([F:SLF]AOVEMACCST/LTOTCST*[F:SLF]AVCBASAMT,WRND_SOC)
        If LVALMAX < abs([F:SLF]AOVEMACCST)
            LVALMAX = abs([F:SLF]AOVEMACCST)
            LZONMAX = "AOVEMACCST"
        Endif
        [F:SLF]AOVELABCST = arr([F:SLF]AOVELABCST/LTOTCST*[F:SLF]AVCBASAMT,WRND_SOC)
        If LVALMAX < abs([F:SLF]AOVELABCST)
            LVALMAX = abs([F:SLF]AOVELABCST)
            LZONMAX = "AOVELABCST"
        Endif
        [F:SLF]AOVESCOCST = arr([F:SLF]AOVESCOCST/LTOTCST*[F:SLF]AVCBASAMT,WRND_SOC)
        If LVALMAX < abs([F:SLF]AOVESCOCST)
            LVALMAX = abs([F:SLF]AOVESCOCST)
            LZONMAX = "AOVESCOCST"
        Endif
        LTOTCST = sum([F:SLF]AMATCST)+sum([F:SLF]AMACCST)+sum([F:SLF]ALABCST)+[F:SLF]ASCOCST+[F:SLF]AINVDTACST
&               +[F:SLF]AOVEMATCST+[F:SLF]AOVEMACCST+[F:SLF]AOVELABCST+[F:SLF]AOVESCOCST
        Assign "[F:SLF]"+LZONMAX With evalue("[F:SLF]"+LZONMAX)+([F:SLF]AVCBASAMT-LTOTCST)
    Endif

    If !clalev([F:SLF1]) : Local File STOLOTFCY [SLF1] : Endif
    [F:SLF1] = [F:SLF]
    Read [SLF1]SLF0=[F:SLF]ITMREF;[F:SLF]LOT;[F:SLF]SLO;[F:SLF]STOFCY
    If dim([L]SRWCOR)=1 & [L]SRWCOR>0
      Gosub COR_SRW
    Else
      For J=0 To GACTMAT-1
          Call ECRTRACE("[F:SLF]AMATCST("+num$(J)+") +="+num$([F:SLF]AMATCST(J)-[F:SLF1]AMATCST(J)),0) From STKVAL
      Next
      Call ECRTRACE("[F:SLF]AOVEMATCST +="+num$([F:SLF]AOVEMATCST-[F:SLF1]AOVEMATCST),0) From STKVAL

      For J=0 To GACTMAC-1
          Call ECRTRACE("[F:SLF]AMACCST("+num$(J)+") +="+num$([F:SLF]AMACCST(J)-[F:SLF1]AMACCST(J)),0) From STKVAL
      Next
      Call ECRTRACE("[F:SLF]AOVEMACCST +="+num$([F:SLF]AOVEMACCST-[F:SLF1]AOVEMACCST),0) From STKVAL

      For J=0 To GACTLAB-1
          Call ECRTRACE("[F:SLF]ALABCST("+num$(J)+") +="+num$([F:SLF]ALABCST(J)-[F:SLF1]ALABCST(J)),0) From STKVAL
      Next
      Call ECRTRACE("[F:SLF]AOVELABCST +="+num$([F:SLF]AOVELABCST-[F:SLF1]AOVELABCST),0) From STKVAL

      Call ECRTRACE("[F:SLF]ASCOCST +="+num$([F:SLF]ASCOCST-[F:SLF1]ASCOCST),0) From STKVAL
      Call ECRTRACE("[F:SLF]AOVESCOCST +="+num$([F:SLF]AOVESCOCST-[F:SLF1]AOVESCOCST),0) From STKVAL

      Call ECRTRACE("[F:SLF]AINVDTACST +="+num$([F:SLF]AINVDTACST-[F:SLF1]AINVDTACST),0) From STKVAL
    Endif
Return

#############################################################
# PCOE : coefficient multiplicateur
# PIND : indice de la ligne en cours
# PORDVAL : 1=Ordre ; 2=Valo ; 3=Ordre & Valo; 4=Valo2; 5=Ordre+Valo2; 6=Valo+Valo2; 7=Ordre+Valo+Valo2
Subprog SAVDETSJV(PCOE, PIND, PORDVAL)
Value Decimal PCOE
Value Integer PIND
Value Integer PORDVAL
Local Integer I

Local Decimal LVAL(1+GACTMAT+GACTMAC+GACTLAB+1+1+4+1)
Local Decimal LVALDEV(1+GACTMAT+GACTMAC+GACTLAB+1+1+4+1)
Local Decimal LVALNUL(1+GACTMAT+GACTMAC+GACTLAB+1+1+4+1)

# Issue 88646 - 2013-03-28 by CCC : Utilisation de LOADVAR pour faire les arrondis
Call LOADVAR3(LVAL, "[M:SRW]", 0, "", "CST", PIND, PCOE, 0, GRNDVAL) From STKVALECR

Raz LVALNUL

#---- Valeurs d'ordre ----#
    If mod(PORDVAL,2)>=1
        Call LOADFIC("[F:SJV]", LVAL, "O", "CST", 1, 1) From STKVALECR
        [F:SJV]OMATTOT = sum([F:SJV]OMATCST)
        [F:SJV]OMACTOT = sum([F:SJV]OMACCST)
        [F:SJV]OLABTOT = sum([F:SJV]OLABCST)
#-------------------
# DELTA
#-------------------
        Call LOADFIC("[F:SJV]", LVAL, "DO", "CST", 1, 0) From STKVALECR
    Else
        Call LOADFIC("[F:SJV]", LVALNUL, "DO", "CST", 1, 0) From STKVALECR
    Endif
    [F:SJV]DOMATTOT    = sum([F:SJV]DOMATCST)
    [F:SJV]DOMACTOT    = sum([F:SJV]DOMACCST)
    [F:SJV]DOLABTOT    = sum([F:SJV]DOLABCST)

#---- Valeurs de valo ----#
    If mod(PORDVAL,4)>=2
        Call LOADFIC("[F:SJV]", LVAL, "V", "CST", 1, 1) From STKVALECR
        [F:SJV]VMATTOT = sum([F:SJV]VMATCST)
        [F:SJV]VMACTOT = sum([F:SJV]VMACCST)
        [F:SJV]VLABTOT = sum([F:SJV]VLABCST)
#-------------------
# DELTA
#-------------------
        Call LOADFIC("[F:SJV]", LVAL, "DV", "CST", 1, 0) From STKVALECR
    Else
        Call LOADFIC("[F:SJV]", LVALNUL, "DV", "CST", 1, 0) From STKVALECR
    Endif
    [F:SJV]DVMATTOT    = sum([F:SJV]DVMATCST)
    [F:SJV]DVMACTOT    = sum([F:SJV]DVMACCST)
    [F:SJV]DVLABTOT    = sum([F:SJV]DVLABCST)

#---- Valeurs de valo 2 ----#
    If GACTVLT2
        If mod(PORDVAL,8)>=4
            Call LOADFIC("[F:SJV]", LVAL, "V2", "CST", 1, 1) From STKVALECR
            [F:SJV]V2MATTOT     = sum([F:SJV]V2MATCST)
            [F:SJV]V2MACTOT     = sum([F:SJV]V2MACCST)
            [F:SJV]V2LABTOT     = sum([F:SJV]V2LABCST)
#-------------------
# DELTA 2
#-------------------
            Call LOADFIC("[F:SJV]", LVAL, "DV2", "CST", 1, 0) From STKVALECR
        Else
            Call LOADFIC("[F:SJV]", LVALNUL, "DV2", "CST", 1, 0) From STKVALECR
        Endif
        [F:SJV]DV2MATTOT    = sum([F:SJV]DV2MATCST)
        [F:SJV]DV2MACTOT    = sum([F:SJV]DV2MACCST)
        [F:SJV]DV2LABTOT    = sum([F:SJV]DV2LABCST)
    Endif

#-------------------
# Ecart non absorbé
#-------------------
    For I=0 To dim(LVAL)-1
        LVALDEV(I) = LVAL(I)
    Next
    Call LOADVAR3(LVALDEV, "[M:SRW]", 0, "DEV", "CST", PIND, PCOE, (mod(PORDVAL,4)<2), GRNDVAL) From STKVALECR
    Call LOADFIC("[F:SJV]", LVALDEV, "DEV", "CST", 1, 0) From STKVALECR
#    #---------- Matière ---------------#
#        For I=0 To GACTMAT-1
#            [F:SJV]DEVMATCST(I) = PCOE * ([M:SRW]DEVMATCST(PIND*GACTMAT+I)+(mod(PORDVAL,4)<2)*[M:SRW]MATCST(PIND*GACTMAT+I))
#        Next
#        [F:SJV]DEVOVEMAT    = PCOE * ([M:SRW]DEVOVEMATCST(PIND)+(mod(PORDVAL,4)<2)*[M:SRW]OVEMATCST(PIND))
#    #---------- Machine ---------------#
#        For I=0 To GACTMAC-1
#            [F:SJV]DEVMACCST(I) = PCOE * ([M:SRW]DEVMACCST(PIND*GACTMAC+I)+(mod(PORDVAL,4)<2)*[M:SRW]MACCST(PIND*GACTMAC+I))
#        Next
#        [F:SJV]DEVOVEMAC    = PCOE * ([M:SRW]DEVOVEMACCST(PIND)+(mod(PORDVAL,4)<2)*[M:SRW]OVEMACCST(PIND))
#    #---------- Main d'oeuvre ---------------#
#        For I=0 To GACTLAB-1
#            [F:SJV]DEVLABCST(I) = PCOE * ([M:SRW]DEVLABCST(PIND*GACTLAB+I)+(mod(PORDVAL,4)<2)*[M:SRW]LABCST(PIND*GACTLAB+I))
#        Next
#        [F:SJV]DEVOVELAB    = PCOE * ([M:SRW]DEVOVELABCST(PIND)+(mod(PORDVAL,4)<2)*[M:SRW]OVELABCST(PIND))
#    #---------- Sous-traitance ---------------#
#        [F:SJV]DEVSCOCST    = PCOE * ([M:SRW]DEVSCOCST(PIND)+(mod(PORDVAL,4)<2)*[M:SRW]SCOCST(PIND))
#        [F:SJV]DEVOVESCO    = PCOE * ([M:SRW]DEVOVESCOCST(PIND)+(mod(PORDVAL,4)<2)*[M:SRW]OVESCOCST(PIND))
#
#        [F:SJV]DEVINVDTA    = PCOE * ([M:SRW]DEVINVDTACST(PIND)+(mod(PORDVAL,4)<2)*[M:SRW]INVDTACST(PIND))

#-------------------
# Ecart non absorbé 2
#-------------------
    If GACTVLT2
        For I=0 To dim(LVAL)-1
            LVALDEV(I) = LVAL(I)
        Next
        Call LOADVAR3(LVALDEV, "[M:SRW]", 0, "DEV", "CST", PIND, PCOE, (mod(PORDVAL,8)<4), GRNDVAL) From STKVALECR
        Call LOADFIC("[F:SJV]", LVALDEV, "DEV", "2", 1, 0) From STKVALECR
#    #---------- Matière ---------------#
#        For I=0 To GACTMAT-1
#            [F:SJV]DEVMATCST2(I) = PCOE * ([M:SRW]DEVMATCST(PIND*GACTMAT+I)+(mod(PORDVAL,8)<4)*[M:SRW]MATCST(PIND*GACTMAT+I))
#        Next
#        [F:SJV]DEVOVEMAT2    = PCOE * ([M:SRW]DEVOVEMATCST(PIND)+(mod(PORDVAL,8)<4)*[M:SRW]OVEMATCST(PIND))
#    #---------- Machine ---------------#
#        For I=0 To GACTMAC-1
#            [F:SJV]DEVMACCST2(I) = PCOE * ([M:SRW]DEVMACCST(PIND*GACTMAC+I)+(mod(PORDVAL,8)<4)*[M:SRW]MACCST(PIND*GACTMAC+I))
#        Next
#        [F:SJV]DEVOVEMAC2    = PCOE * ([M:SRW]DEVOVEMACCST(PIND)+(mod(PORDVAL,8)<4)*[M:SRW]OVEMACCST(PIND))
#    #---------- Main d'oeuvre ---------------#
#        For I=0 To GACTLAB-1
#            [F:SJV]DEVLABCST2(I) = PCOE * ([M:SRW]DEVLABCST(PIND*GACTLAB+I)+(mod(PORDVAL,8)<4)*[M:SRW]LABCST(PIND))
#        Next
#        [F:SJV]DEVOVELAB2    = PCOE * ([M:SRW]DEVOVELABCST(PIND)+(mod(PORDVAL,8)<4)*[M:SRW]OVELABCST(PIND))
#    #---------- Sous-traitance ---------------#
#        [F:SJV]DEVSCOCST2    = PCOE * ([M:SRW]DEVSCOCST(PIND)+(mod(PORDVAL,8)<4)*[M:SRW]SCOCST(PIND))
#        [F:SJV]DEVOVESCO2    = PCOE * ([M:SRW]DEVOVESCOCST(PIND)+(mod(PORDVAL,8)<4)*[M:SRW]OVESCOCST(PIND))
#
#        [F:SJV]DEVINVDTA2    = PCOE * ([M:SRW]DEVINVDTACST(PIND)+(mod(PORDVAL,8)<4)*[M:SRW]INVDTACST(PIND))
    Endif
End


#######################################################################
# SAVSJO : enregistre les natures de FG pour chaque mvt
#######################################################################
# Le calcul se fait à partir des valeurs de [M:SDPD] * coefficient pour correspondre au mvt en cours d'écriture
#######################################################################
Subprog SAVSJO(PCOE)
Value Decimal PCOE
Local Integer I

    [F:SJO] = [F:STJ]    # Récupération de la clé
    For I=0 To [M:SDPD]NBONA-1
        If [M:SDPD]ONAAMT(I)<>0
            [F:SJO]OVENAT = [M:SDPD]OVENAT(I)
            [F:SJO]TYPCST = [M:SDPD]ONATYP(I)
            [F:SJO]ONAAMT = [M:SDPD]ONAAMT(I)*PCOE
            [F:SJO]CREDAT = date$
            [F:SJO]CREUSR = GUSER
            Write [SJO]
        Endif
    Next

End

