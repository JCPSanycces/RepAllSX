######################################################
## Intégration parametrage plan de travail workflow
######################################################
$PARAM_WRK
Local File =DOSSIER(D)+".AWRKTRN"   [AWW]
Local File =DOSSIER(D)+".AWRKTRND"  [AWD]

Read [AWW]AWW0 = NOMOBJ
If fstat = 0
  #for SCM deletion (typenr=-2 only in scm at the moment)
  If TYPENR=-2
      Gosub DEL_AWW
      Gosub FIN_OBJ From PATCH
  Else
      NEWOBJ = 0
      Gosub TR_PARAM
  Endif
Else
  # creation only if typenr <> - 2 (typenr=-2 only in scm at the moment)
  If TYPENR<>-2
      NEWOBJ = 1
      Raz [F:AWW]
      Gosub TR_PARAM
  Else
      Gosub FIN_OBJ From PATCH
  Endif
Endif

LogicClose File [AWW],[AWD]
#Close Local File [AWW],[AWD]
Return

#-------------------#
# deletion at the moment only for scm
#-------------------#
$DEL_AWW
Call DEBTRANS From GLOCK
Local Char CODE(250)
Local Char WDOS(GLONADS)
[L]WDOS = DOSSIER(D)
[L]CODE = [L]NOMOBJ
Trbegin [AWW]
     Gosub ANNULE_AWW From SUBAWW
     If GOK<1 : GOK = 0 : ER = 99 : ERFIC = "AWRKTRN"-NOMOBJ : Rollback : Return : Endif
     Delete [AWD] Where WRKTRN=NOMOBJ
     If fstat
         GOK = 0 : ER = 99 : ERFIC = "AWRKTRND"-NOMOBJ : Rollback : Return
     Endif
     Delete [AWW] Curr
     If fstat
           GOK = 0 : ER = 99 : ERFIC = "AWRKTRN"-NOMOBJ : Rollback : Return
     Endif
Commit
Local Char WTRAIT(GLONADC)
Gosub SET_PREF From SUBAWW
WTRAIT = PREF+[L]CODE
Call EFFACE_ADX("",DOSSIER(D),WTRAIT,OK) From ORDSYS
Call EFFACE(filpath("TRT",WTRAIT,"src",DOSSIER(D)),OK) From ORDSYS
#
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AWW",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),NOMOBJ),0) From GESECRAN
Return


#-------------------------------#
#
#-------------------------------#
$TR_PARAM
Call DEBTRANS From GLOCK
Trbegin [AWW],[AWD]
  NBZ = 0
  Repeat
      Gosub LIRE From PATCH
      Case TYPENR
          When 7 :  Break :  # Fin normale
          When 3 :
                  IDENT = CHAMP(2)
                  Case CHAMP(1)
                        When "AWW"   : Gosub AWW1
                        When "AWD"   : Gosub AWD1
                        When Default : ER = 31
                  Endcase
          When Default :   ER = 32
      Endcase
      If ER or !OKOBJ : Break : Endif
  Until 1=0
  If ER or !OKOBJ : Goto ABORT : Endif
Commit


If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AWW",[F:AWW]WRKTRN,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
# Dans l'appli X3 , on ne valide que les objets des modules Superviseur, tronc commun, développement
Gosub SAV_OPENI From PATCH
Call VALID([F:AWW]WRKTRN,DOSSIER(D),1,MOK) From SUBAWW
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
Gosub REST_OPENI From PATCH
Return


#------------------------------#
## READ parametrage plan de travail workflow
#------------------------------#
$AWW1
FICHIER = "AWRKTRN" : ABR = "AWW"
Repeat
    Gosub LIRE_ZONE From PATCH
    If ER : Break : Endif
    If DIME>0 & IND+1<=DIME
          OK = 1
          If OK
              Gosub AFF_ZONE From PATCH
              If GOK<1 : ER = 99 : Break : Endif
          Endif
    Endif
Until TYPENR=6
If ER : Return : Endif

If NEWOBJ
   # Patch not for scm - ISFULLMOD = 2 when SCM
   If [L]ISFULLMOD<>2
       Call FLDCRE("AWW") From OBJDIV
   Endif
   Write [AWW]
   If fstat
       Call LOG_ERROR_DETAILS(1, "AWW",num$([F:AWW]WRKTRN),"") From GLOCK
   Endif
Else
   # Patch not for scm - ISFULLMOD = 2 when SCM
   If [L]ISFULLMOD<>2
       Call FLDUPD("AWW") From OBJDIV
   Endif
   Rewrite [AWW]
   If fstat
       Call LOG_ERROR_DETAILS(2, "AWW",num$([F:AWW]WRKTRN),"") From GLOCK
   Endif
Endif
If fstat
    GOK = 0 : ER = 99 : ERFIC = "AWRKTRN"-[F:AWW]WRKTRN: Return
Endif
Delete [AWD] Where WRKTRN = [AWW]WRKTRN
If fstat
       Call LOG_ERROR_DETAILS(3, "AWD",num$([F:AWW]WRKTRN),"") From GLOCK
       GOK = 0 : ER = 99 : ERFIC = "AWRKTRND"-[AWW]WRKTRN
Endif
Return
#-------------------------#
#
#-------------------------#
$AWD1
FICHIER = "AWRKTRND" : ABR = "AWD"
Repeat
   Gosub LIRE_ZONE From PATCH
   If ER : Break : Endif
   If DIME>0 & IND+1<=DIME
        OK = 1
        If OK
            Gosub AFF_ZONE From PATCH
            If GOK<1 : ER = 99 : Break : Endif
        Endif
  Endif
Until TYPENR=6
If ER : Return : Endif
Write [AWD]
If fstat
       Call LOG_ERROR_DETAILS(1, "AWD",num$([F:AWD]WRKTRN),"") From GLOCK
       GOK = 0 : ER = 99 : ERFIC = "AWRKTRND"-[F:AWD]WRKTRN
Endif
Return

