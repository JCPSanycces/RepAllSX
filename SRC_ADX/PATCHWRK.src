#<AdxTL>@(#)11.0.0.0 $Revision$
######################################################
# Workflow model Integration
# ISFULLMOD = 2 when call is done from scm
######################################################
$MODELE_WRK
Local File =DOSSIER(D)+".AWRKLNK"   [AWM]
Local File =DOSSIER(D)+".AWRKTAB"   [AWK]


Read [AWM]AWM0 = NOMOBJ
If fstat = 0
  #for SCM deletion (typenr=-2 only in scm at the moment)
  If TYPENR=-2
      Gosub DEL_AWM
      Gosub FIN_OBJ From PATCH
  Else
      If [F:AWM]CODACT>="X" & !find([F:AWM]CODACT,ACTIV(1..NBACT))
            # specific Objet
            Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN
            OKSPE = 1
            Gosub FIN_OBJ From PATCH
      Else
            NEWOBJ = 0
            Gosub TR_MODELE
      Endif
  Endif
Else
  # creation only if typenr <> - 2 (typenr=-2 only in scm at the moment)
  If TYPENR<>-2
      NEWOBJ = 1
      Raz [F:AWM]
      Gosub TR_MODELE
  Else
      Gosub FIN_OBJ From PATCH
  Endif
Endif

LogicClose File [AWM],[AWK]
#Close Local File [AWM],[AWK]
Return
#-------------------#
# deletion at the moment only for scm
#-------------------#
$DEL_AWM
Call DEBTRANS From GLOCK
#
Trbegin [AWM]
  Delete [F:AWK] Where MODELE=NOMOBJ
  If fstat
        GOK = 0 : ER = 99 : ERFIC = "AWRKTAB"-NOMOBJ : Rollback : Return
  Endif
  Delete [F:AWM] Curr
  If fstat
        GOK = 0 : ER = 99 : ERFIC = "AWRKLNK"-NOMOBJ : Rollback : Return
  Endif
Commit
#
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AWM",NOMOBJ,"","A") From GOBJET : Endif
# record is deleted
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),NOMOBJ),0) From GESECRAN
Return

#-------------------#
# write or rewrite
#-------------------#
$TR_MODELE
Call DEBTRANS From GLOCK
#
Trbegin [AWM]
  NBZ = 0
  Repeat
       Gosub LIRE From PATCH
       Case TYPENR
            When 7,13 : Break : # Fin normale
            When 3 :
                        IDENT = CHAMP(2)
                        Case CHAMP(1)
                                When "AWM"   : Gosub AWM1
                                When "AWK"   : Gosub AWM3
                                When Default : ER = 31
                        Endcase
            When Default :  ER = 32
       Endcase
       If ER or !OKOBJ : Break : Endif
  Until 1=0
  If ER or !OKOBJ : Goto ABORT : Endif
Commit
#
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AWM",[F:AWM]MODELE,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Gosub SAV_OPENI From PATCH
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN
Gosub REST_OPENI From PATCH
Return

$ABORT
Rollback
Return

$RIEN
Resume

#-------------------------#
## read Workflow model AWM (HEAD)
#-------------------------#
$AWM1
FICHIER = "AWRKLNK" : ABR = "AWM"
Repeat
  Gosub LIRE_ZONE From PATCH
  If ER : Break : Endif
  If DIME>0 & IND+1<=DIME
      OK = 1
      # Patch not for scm - ISFULLMOD = 2 when SCM
      If !NEWOBJ & find(VARIA,"ENAFLG") and [L]ISFULLMOD<>2
          OK = 0
      Endif
      If OK
          Gosub AFF_ZONE From PATCH
          If GOK<1 : ER = 99 : Break : Endif
      Endif
  Endif
Until TYPENR=6
If ER : Return : Endif

MODOBJ = max(1,[F:AWM]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
     OKOBJ = 0 : Return
Endif
ACVOBJ = [F:AWM]CODACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
   Read [ACV]CODACT = ACVOBJ
   If fstat | [F:ACV]FLACT<>2
          OKOBJ = 0 : Return
   Endif
Endif
If NEWOBJ
   If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
        Call FLDCRE("AWM") From OBJDIV
   Endif
   Write [AWM]
   If fstat
        Call LOG_ERROR_DETAILS(1, "AWM",num$([F:AWM]MODELE),"") From GLOCK
   Endif
Else
   If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
        Call FLDUPD("AWM") From OBJDIV
   Endif
   Rewrite [AWM]
   If fstat
        Call LOG_ERROR_DETAILS(2, "AWM",num$([F:AWM]MODELE),"") From GLOCK
   Endif
Endif
If fstat
   GOK = 0 : ER = 99 : ERFIC = "AWRKLNK"-[F:AWM]MODELE : Return
Endif

Delete [AWK] Where MODELE=[F:AWM]MODELE
If fstat
          Call LOG_ERROR_DETAILS(3, "AWK",num$([F:AWM]MODELE),"") From GLOCK
          GOK = 0 : ER = 99 : ERFIC = "AWRKTAB"-[F:AWM]MODELE : Return
Endif
Return

#-------------------------#
## read workflow modele AWK (lines)
#-------------------------#
$AWM3
If clalev([F:AWK])=0
   Gosub FIN_FIC From PATCH
   Return
Endif
FICHIER = "AWRKTAB" : ABR = "AWK"
Repeat
   Gosub LIRE_ZONE From PATCH
   If ER : Break : Endif
   If DIME>0 & IND+1<=DIME
        Gosub AFF_ZONE From PATCH
        If GOK<1 : ER = 99 : Break : Endif
   Endif
Until TYPENR=6
If ER : Return : Endif
Write [AWK]
If fstat
   Call LOG_ERROR_DETAILS(1, "AWK",num$([F:AWK]MODELE),"") From GLOCK
   GOK = 0 : ER = 99 : ERFIC = "AWRKTAB"-[F:AWK]MODELE : Return
Endif
Return

######################################################
## Affectation workflow integration
######################################################
$AFFECT_WRK
Local File =DOSSIER(D)+".AWRKREG"   [AWR]
Local File =DOSSIER(D)+".AWRKREG"   [AWR2]
Local File =DOSSIER(D)+".ATEXTRA"   [AXXP]


Read [AWR]AWR1 = NOMOBJ;""
If fstat = 0
  #for SCM deletion (typenr=-2 only in scm at the moment)
  If TYPENR=-2
      Gosub DEL_AWR
      Gosub FIN_OBJ From PATCH
  Else
      NEWOBJ = 0
      Gosub TR_AFFECT
  Endif
Else
  # creation only if typenr <> - 2 (typenr=-2 only in scm at the moment)
  If TYPENR<>-2
      NEWOBJ = 1
      Raz [F:AWR]
      Gosub TR_AFFECT
  Else
      Gosub FIN_OBJ From PATCH
  Endif
Endif

LogicClose File [AWR],[AWR2],[AXXP]
#Close Local File [AWR],[AWR2]
Return

#-------------------#
# deletion at the moment only for scm
#-------------------#
$DEL_AWR
Call DEBTRANS From GLOCK
Trbegin [AWR]
  Delete [AXXP] Where CODFIC="AWRKREG" & IDENT1=[AWR]REGLE & IDENT2="" & ZONE="INTIT"
  If fstat
      GOK = 0 : ER = 99 : ERFIC = "ATEXTRA"-NOMOBJ : Rollback : Return
  Endif
  Delete [AWR] Curr
  If fstat
      GOK = 0 : ER = 99 : ERFIC = "AWRKREG"-NOMOBJ : Rollback : Return
  Endif
Commit
#
Local Integer WSTAT
Local Char    WFICANU(GDIMFIC)
Local Char    WPREF(4)
Call SET_PREF(NOMOBJ,WPREF) From SUBAWR
WFICANU = filpath("TRT",WPREF+NOMOBJ,"src",DOSSIER(D))
# delete of TRT source file
If filinfo(WFICANU,0)>=0
     Call EFFACE(WFICANU,WSTAT) From ORDSYS
Endif
# delete of adx file- compile file
Call EFFACE_ADX("",DOSSIER(D),WPREF+NOMOBJ,STAT) From ORDSYS
#
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AWR",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),NOMOBJ),0) From GESECRAN
Return


#-------------------#
# write or rewrite
#-------------------#
$TR_AFFECT
Call DEBTRANS From GLOCK

Trbegin [AWR]
   NBZ = 0
   Repeat
      Gosub LIRE From PATCH
      Case TYPENR
          When 7 : Break : # Fin normale
          When 3 : # Variable
                  IDENT = CHAMP(2)
                  Case CHAMP(1)
                        When "AWR"   : Gosub AWR1
                        When Default : ER = 31
                  Endcase
          When Default :  ER = 32
      Endcase
      If ER or !OKOBJ : Break : Endif
  Until 1=0
  If ER or !OKOBJ : Goto ABORT : Endif
Commit

#
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AWR",[F:AWR]REGLE,[F:AWR]CPY,string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
# Validation  in X3 application only module SUPERVISEUR, TRONC COMMUN, DÉVELOPPEMENT
Gosub SAV_OPENI From PATCH
Call VALID([F:AWR]REGLE,DOSSIER(D),1,MOK) From SUBAWR
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN
Gosub REST_OPENI From PATCH
Return

#------------------------------#
## Read regle affectation workflow
#------------------------------#
$AWR1
FICHIER = "AWRKREG" : ABR = "AWR"
Repeat
  Gosub LIRE_ZONE From PATCH
  If ER : Break : Endif
  If DIME>0 & IND+1<=DIME
      ID2 = ""
      Gosub AFF_ZONE From PATCH
      If GOK<1 : ER = 99 : Break : Endif
  Endif
Until TYPENR=6
If ER : Return : Endif

If [L]ISFULLMOD=2 : #call by scm
  Local Integer NEWRULE
  Read [AWR2]AWR1 = [F:AWR]REGLE;[F:AWR]CPY
  If fstat
      NEWRULE = 1
  Else
      NEWRULE = 0
  Endif
  [F:AWR2]=[F:AWR]
  If NEWRULE
        Write [AWR2]
        If fstat
                Call LOG_ERROR_DETAILS(1, "AWR",num$([F:AWR]REGLE),"") From GLOCK
        Endif
  Else
        Rewrite [AWR2]
        If fstat
                Call LOG_ERROR_DETAILS(2, "AWR",num$([F:AWR]REGLE),"") From GLOCK
        Endif
  Endif
  If fstat
        GOK = 0 : ER = 99 : ERFIC = "AWRKREG"-[F:AWR]REGLE-[F:AWR]CPY : Return
  Endif
Else
  If NEWOBJ
      If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
            Call FLDCRE("AWR") From OBJDIV
      Endif
      Write [AWR]
      If fstat
            Call LOG_ERROR_DETAILS(1, "AWR",num$([F:AWR]REGLE),"") From GLOCK
      Endif
  Else
      If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
            Call FLDUPD("AWR") From OBJDIV
      Endif
      Rewrite [AWR]
      If fstat
            Call LOG_ERROR_DETAILS(2, "AWR",num$([F:AWR]REGLE),"") From GLOCK
      Endif
  Endif
  If fstat
        GOK = 0 : ER = 99 : ERFIC = "AWRKREG"-NOMOBJ : Return
  Endif
Endif
Return

######################################################
## Intégration regle workflow
######################################################
$REGLE_WRK
Local File =DOSSIER(D)+".AWRKPAR"   [AWA]
Local File =DOSSIER(D)+".AWRKPARH"  [AWH]
Local File =DOSSIER(D)+".AWRKPARC"  [AWC]
Local File =DOSSIER(D)+".AWRKPARF"  [AWF]
Local File =DOSSIER(D)+".ATEXTRA"   [AXXP]

Read [AWA]AWA0 = NOMOBJ
If fstat = 0
  #for SCM deletion (typenr=-2 only in scm at the moment)
  If TYPENR=-2
      Gosub DEL_AWA
      Gosub FIN_OBJ From PATCH
  Else
      NEWOBJ = 0
      Gosub TR_REGLES
  Endif
Else
  # creation only if typenr <> - 2 (typenr=-2 only in scm at the moment)
  If TYPENR<>-2
      NEWOBJ = 1
      Raz [F:AWA]
      Gosub TR_REGLES
  Else
      Gosub FIN_OBJ From PATCH
  Endif
Endif

LogicClose File [AWA],[AWH],[AWC],[AWF], [AXXP]
#Close Local File [AWA],[AWH],[AWC],[AWF]
Return

#-------------------#
# deletion at the moment only for scm
#-------------------#
$DEL_AWA
Call DEBTRANS From GLOCK
Trbegin [AWA]
    Delete [AWF] Where CODE=[L]NOMOBJ
    If fstat
            GOK = 0 : ER = 99 : ERFIC = "AWRKPARF"-[L]NOMOBJ : Rollback :  Return
    Endif
    Delete [AWH] Where CODE=[L]NOMOBJ
    If fstat
            GOK = 0 : ER = 99 : ERFIC = "AWRKPARH"-[L]NOMOBJ : Rollback :  Return
    Endif
    Delete [AWC] Where CODE=[L]NOMOBJ
    If fstat
            GOK = 0 : ER = 99 : ERFIC = "AWRKPARC"-[L]NOMOBJ : Rollback :  Return
    Endif
    Delete [AXXP] Where CODFIC="AWRKPAR" & IDENT1=[L]NOMOBJ & ZONE="INTIT"
    If fstat
            GOK = 0 : ER = 99 : ERFIC = "ATEXTRA"-[L]NOMOBJ : Rollback :  Return
    Endif
    Delete [AWA] Curr
    If fstat
            GOK = 0 : ER = 99 : ERFIC = "AWRKPAR"-[L]NOMOBJ : Rollback :  Return
    Endif
Commit
#
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AWA",[L]NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN
#
Local Integer WSTAT
Local Char    WFICANU(GDIMFIC)
Local Char    WPREF(4)
Call SET_PREF([L]NOMOBJ,WPREF) From SUBAWA
WFICANU = filpath("TRT",WPREF+[L]NOMOBJ,"src",DOSSIER(D))
# delete of TRT source file
If filinfo(WFICANU,0)>=0
    Call EFFACE(WFICANU,WSTAT) From ORDSYS
Endif
# delete of adx file
Call EFFACE_ADX("",DOSSIER(D),WPREF+[L]NOMOBJ,WSTAT) From ORDSYS
Return
#-------------------------------#
#
#-------------------------------#
$TR_REGLES
Call DEBTRANS From GLOCK
Trbegin [AWA],[AWC],[AWF],[AWH]
  NBZ = 0
  Repeat
      Gosub LIRE From PATCH
      Case TYPENR
            When 7 : Break : # Fin normale
            When 3 :
                    IDENT = CHAMP(2)
                    Case CHAMP(1)
                          When "AWA"   : Gosub AWA1
                          When "AWC"   : Gosub AWC1
                          When "AWF"   : Gosub AWF1
                          When "AWH"   : Gosub AWH1
                          When Default : ER = 31
                    Endcase
            When Default :  ER = 32
      Endcase
      If ER or !OKOBJ : Break : Endif
  Until 1=0
  If ER or !OKOBJ : Goto ABORT : Endif

Commit
#
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AWA",[F:AWA]CODE,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Gosub SAV_OPENI From PATCH
# Generation of the process WMKxxx
If GPRODUIT<>0 | APPLI<>GDOSX3
      Call VALID([F:AWA]CODE,DOSSIER(D),0,MOK) From AWRKGEN
Endif
Gosub REST_OPENI From PATCH
Return

#----------------------------#
## read workflow model
#----------------------------#
$AWA1
FICHIER = "AWRKPAR" : ABR = "AWA"
Repeat
   Gosub LIRE_ZONE From PATCH
   If ER : Break : Endif
   If DIME>0 & IND+1<=DIME
      OK = 1
      # Patch not for scm - ISFULLMOD = 2 when SCM
      If !NEWOBJ & find(VARIA,"ENAFLG") and  [L]ISFULLMOD<>2
            OK = 0
      Endif
      If OK
            Gosub AFF_ZONE From PATCH
            If GOK<1 : ER = 99 : Break : Endif
      Endif
   Endif
Until TYPENR=6
If ER : Return : Endif

If NEWOBJ
   # Patch not for scm - ISFULLMOD = 2 when SCM
   If [L]ISFULLMOD<>2
       Call FLDCRE("AWA") From OBJDIV
   Endif
   Write [AWA]
   If fstat
       Call LOG_ERROR_DETAILS(1, "AWA",num$([F:AWA]CODE),"") From GLOCK
   Endif
Else
   If [L]ISFULLMOD<>2
       Call FLDUPD("AWA") From OBJDIV
   Endif
   Rewrite [AWA]
   If fstat
       Call LOG_ERROR_DETAILS(2, "AWA",num$([F:AWA]CODE),"") From GLOCK
   Endif
Endif
If fstat
       GOK = 0 : ER = 99 : ERFIC = "AWRKPAR"-[F:AWA]CODE: Return
Endif
Delete [AWF] Where CODE = [AWA]CODE
If fstat
        Call LOG_ERROR_DETAILS(3, "AWF",num$([F:AWA]CODE),"") From GLOCK
        GOK = 0 : ER = 99 : ERFIC = "AWRKPARF"-[AWA]CODE
Endif
Delete [AWH] Where CODE = [AWA]CODE
If fstat
        Call LOG_ERROR_DETAILS(3, "AWH",num$([F:AWA]CODE),"") From GLOCK
        GOK = 0 : ER = 99 : ERFIC = "AWRKPARH"-[AWA]CODE
Endif
Delete [AWC] Where CODE = [AWA]CODE
If fstat
        Call LOG_ERROR_DETAILS(3, "AWC",num$([F:AWA]CODE),"") From GLOCK
        GOK = 0 : ER = 99 : ERFIC = "AWRKPARC"-[AWA]CODE
Endif
Return

