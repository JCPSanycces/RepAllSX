########################################################################################################################

$ACTION
    Case ACTION
        When "EXEC"    : Gosub EXEC
    Endcase
Return

$EXEC
    Local Integer PCODGSTPER : PCODGSTPER = val(PARAM(1))
    Local Char PCPY(GLONCPY) : PCPY = PARAM(2)


    Local Integer NBPAR : Raz NBPAR
    Local Char PARNAM(20)(1..7), PARVAL(50)(1..7)

    NBPAR += 1 : PARNAM(NBPAR) = "CODGSTPER"  : PARVAL(NBPAR) = num$( PCODGSTPER )
    NBPAR += 1 : PARNAM(NBPAR) = "GSTWRKSHT"  : PARVAL(NBPAR) = "1"
    NBPAR += 1 : PARNAM(NBPAR) = "GSTDTL"     : PARVAL(NBPAR) = "2"
    NBPAR += 1 : PARNAM(NBPAR) = "BAS"        : PARVAL(NBPAR) = "1"
    NBPAR += 1 : PARNAM(NBPAR) = "CPY"        : PARVAL(NBPAR) = PCPY
    NBPAR += 1 : PARNAM(NBPAR) = "SUMCPY"     : PARVAL(NBPAR) = "2"
    NBPAR += 1 : PARNAM(NBPAR) = "SUMGRP"     : PARVAL(NBPAR) = "1"

    Call ETATN( "GSTCLCWRKSHT", "GSTCLCWRKSHT", PARNAM, PARVAL ) From ETAT
#    Call ETAT( "GSTCLCWRKSHT", "GSTCLCWRKSHT", "", 0, "", PARNAM, PARVAL ) From AIMP3
Return

