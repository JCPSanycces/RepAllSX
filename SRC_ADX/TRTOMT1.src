#<AdxTL>@(#)4.0.0.0 $Revision$
################################################################################################################
# Saisie de la description d'une étape d'un assistant X3                  Module CRM          03 novembre 2000 #
################################################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When Default
Endcase
Return


$OUVRE
Global Integer ISDIRTY
ISDIRTY = 0
Return

$DEFBOUT
Return

$SETBOUT
If ISDIRTY
    ETABOU(GSPE1) = 1
Else
    ETABOU(GSPE1) = 0
Endif
Return

$OUVRE_BOITE
Return

$DEBUT
Return

$AV_CHOIX
Return

AP_CHOIX
Return

$AVANT_BOUTON
Return

$FINSAI
Raz [M:OMT0]
Raz [M:OMT1]
Kill ISDIRTY
Return

$FIN
Return

$ABANDON
Return

$APRES_MODIF
ISDIRTY = 1
Return

$BOUTON
Case BOUT
    When "a"
        Gosub ONOK
    When Default
Endcase
Return

$ONMENU
Return

#########################################################
# Sous-programmes
#########################################################
#########################################################
$ONOK

Call DEBTRANS From GLOCK
Trbegin [WIS]
Readlock [WIS]WIS0 = [M:WIZ0]WIZNUM;GISTENUM
#Il s'agit d'un nouvel enregistrement
If fstat
    [F:WIS]WIZNUM = [M:WIZ0]WIZNUM
    [F:WIS]STENUM = GISTENUM
    [F:WIS]STEDES = [M:WIZ3]STEDES
    Write [WIS]
    If fstat
        GMESSAGE = mess(100,141,1) #Erreur création
        GERR = 1
        Unlock [WIS]
        Rollback
        End
    Else
        Commit
        Unlock [WIS]
    Endif
# Il s'agit d'une modification
Else
    [F:WIS]WIZNUM = [M:WIZ0]WIZNUM
    [F:WIS]STENUM = GISTENUM
    [F:WIS]STEDES = [M:WIZ3]STEDES
    Rewrite [WIS]
    If fstat
        GMESSAGE = mess(101,141,1) #Erreur modification
        GERR = 1
        Unlock [WIS]
        Rollback 
        End
    Else
        Commit
        Unlock [WIS]
    Endif
Endif

ISDIRTY = 0
Return





