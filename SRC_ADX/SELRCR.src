#<AdxTL>@(#)7.0.0.0 $Revision$
$ACTION
  Case ACTION
    When "SEL_TABLE" : Gosub SEL_TABLE
  Endcase
Return

$SEL_TABLE
  Case TABLE
    When "SELINVNUM" : Gosub SELINVNUM
    When "SELRCRNUM" : Gosub SELRCRNUM
    When "SELINVTYP" : Gosub SELINVTYP
  Endcase
Return


#########################################################################################################################################################
$SELINVNUM

## The selection option for the invoice number are filtered to allow only the following:
## (1) Select customer invoices if recurring invoice type (RCRTYP) = 1 and select supplier invoices if recurring invoice type (RCRTYP) = 2
## (2) Supplier invoice status (STA) must be either 'To Confirm' or 'Validated'. Customer invoice status (STA) must be either 'Not Posted' or 'Posted'.
## (3) Invoice category (INVTYP) must be 'Invoice', all other types (i.e. credit memo) are not allowed
## (4) Invoice number cannot have any reference or link (RCRNUM) to another recurring invoice record
## (5) Invoice site (FCY) must match the recurring invoice site
## (6) Business partner must be of type (BPSTYP) 'Normal'
## (7) For AP Recurring, the module must be of type (ORIMOD) 'AR/AP Accounting'. This will exclude purchase invoices. For AR Recurring, the module must
##     be of type (ORIMOD) 'AR/AP Accounting'. This will exclude sales invoices.

  If PARAM(2) = "1" ##RCRTYP=1 Customer invoices
    CRITERE = "[F:SIH1]STA <> 2 & [F:SIH1]INVTYP = 1 & [F:SIH1]RCRNUM = '' & [F:SIH1]ORIMOD = 3"
    CRITERE -= "& [F:SIH1]FCY = '" + PARAM(1) + "'"

    If !clalev([F:SIH1])   Local File SINVOICE   [SIH1]  : Endif
    If !clalev([F:BPC])    Local File BPCUSTOMER [BPC]  : Endif

    Link [SIH1] With [BPC]BPC0 = [SIH1]BPR As [PIHX] Where [BPC]BPCTYP = 1
    Default File [PIHX]
    START = "[F:SIH1]NUM"
    OBJET=""
    TIT(0) = mess(207,198,1)
    NBCOL  = 0
    NBCOL+=1 : COL(NBCOL) = "[SIH1]NUM"
    Call TEXTFIC("SINVOICE","NUM",1,TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "[SIH1]FCY"
    Call TEXTFIC("SINVOICE","FCY",1,TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "[SIH1]BPR"
    Call TEXTFIC("SINVOICE","BPR",1,TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "[SIH1]ACCDAT"
    Call TEXTFIC("SINVOICE","ACCDAT",1,TIT(NBCOL)) From OBJDIV
  Elsif PARAM(2) = "2" ##RCRTYP=2 Supplier invoices
    CRITERE = "[F:PIH1]STA <> 1 & [F:PIH1]INVTYP = 1 & [F:PIH1]RCRNUM = '' & [F:PIH1]ORIMOD = 3"
    CRITERE -= "& [F:PIH1]FCY = '" + PARAM(1) + "'"

    If !clalev([F:PIH1])   Local File PINVOICE   [PIH1]  : Endif
    If !clalev([F:BPS])    Local File BPSUPPLIER [BPS]  : Endif

    Link [PIH1] With [BPS]BPS0 = [PIH1]BPR As [PIHX] Where [BPS]BPSTYP = 1
    Default File [PIHX]
    START = "[F:PIH1]NUM"
    OBJET=""
    TIT(0) = mess(207,198,1)
    NBCOL  = 0

    NBCOL+=1 : COL(NBCOL) = "[PIH1]NUM"
    Call TEXTFIC("PINVOICE","NUM",1,TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "[PIH1]FCY"
    Call TEXTFIC("PINVOICE","FCY",1,TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "[PIH1]BPR"
    Call TEXTFIC("PINVOICE","BPR",1,TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "[PIH1]ACCDAT"
    Call TEXTFIC("PINVOICE","ACCDAT",1,TIT(NBCOL)) From OBJDIV
  Endif

  DEFPAG=1

Return
######################################################################################################
$SELRCRNUM

If PARAM(1) = "1"
  CRITERE(1)="RCRTYP=1"
Else
  CRITERE(1)="RCRTYP=2"
Endif

If PARAM(2) <> ""
  GFCY = PARAM(2)
  CRITERE(1) = CRITERE(1) - "& FCY=GFCY"
Endif

If PARAM(3) <> ""
  GCPY = PARAM(3)
  CRITERE(1) = CRITERE(1) - "& CPY=GCPY"
Endif

If PARAM(4) = "2"
  CRITERE(1)= CRITERE(1) - "& RCRSTA=2"
Endif

OBJET="RCR"
START="RCRNUM"

Return
######################################################################################################
$SELINVTYP

CRITERE(1)="INVTYP=1"

If val(PARAM(1)) = 1                    # Customer invoice type
    OBJET="TSV"
    START="SIVTYP"
Else
    OBJET="TPV"                          # Supplier invoice type
    START="PIVTYP"
Endif

Return
