#<AdxTL>@(#)2.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","RECUPBLM","UTIRECBLM",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE
Endcase
Return

$OUVRE
If dim(DOSSIER)<1
 Local Char DOSSIER(GLONADP)
 DOSSIER = nomap
Endif
If clalev([F:CMM])=0  : Local File =DOSSIER+".GCOMMIT"       [CMM] : Endif
If clalev([F:CMD])=0  : Local File =DOSSIER+".GCOMMITD"      [CMD] : Endif
If clalev([F:FIY])=0  : Local File =DOSSIER+".FISCALYEAR"    [FIY] : Endif
If clalev([F:PER])=0  : Local File =DOSSIER+".PERIOD"        [PER] : Endif
If clalev([F:FCY])=0  : Local File =DOSSIER+".FACILITY"      [FCY] : Endif
If clalev([F:CPY])=0  : Local File =DOSSIER+".COMPANY"       [CPY] : Endif
If clalev([F:GAC])=0  : Local File =DOSSIER+".GACCOUNT"      [GAC] : Endif
If clalev([F:BLM])=0  : Local File =DOSSIER+".BLACMM"        [BLM] : Endif
If clalev([F:TCU])=0  : Local File =DOSSIER+".TABCUR"        [TCU] : Endif
If clalev([F:TUN])=0  : Local File =DOSSIER+".TABUNIT"       [TUN] : Endif
If clalev([F:CCE])=0  : Local File =DOSSIER+".CACCE"         [CCE] : Endif
If clalev([F:FGR])=0  : Local File =DOSSIER+".FACGROUP"      [FGR] : Endif
If clalev([F:GCM])=0  : Local File =DOSSIER+".GACM"          [GCM] : Endif
If clalev([F:LED])=0  : Local File =DOSSIER+".GLED"          [LED] : Endif

Return

$INIT
Gosub OUVRE
TMP = 1
Return

$INIT_DIA
[M:DIA]SOCIETE = GDEFSOC
Call SETMAINREF([M:DIA]SOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Call DEFEXE([M:DIA]SOCIETE,GTYPANA,[M:DIA]EXERCICE) From CPTSUB
Call DATEXE([M:DIA]SOCIETE,GTYPANA,[M:DIA]EXERCICE,[M:DIA]DATDEB,[M:DIA]DATFIN) From CPTSUB
Return

$EXEC
Call RECUPBLM([M:DIA]SOCIETE,[M:DIA]TOUSITE,[M:DIA]SITE,[M:DIA]LEDTYP,
& [M:DIA]EXERCICE,[M:DIA]DEVISE,[M:DIA]BALANA,[M:DIA]COMPTE,GSERVEUR,0)
TRA = 1
Return

##########################################################################################################
$INISOC
Local Integer LNBSOC : LNBSOC=nbrecord([F:CPY])
GDIMSOC=LNBSOC+20
Global Char    GSOC(GLONCPY)(1..GDIMSOC)
Global Char    GDEVSOC(GLONCUR)(1..GDIMSOC)
Global Char    GLEGSOC(GLONADI)(1..GDIMSOC)
Global Char    GGCMSOC(GLONGCM)(1..GDIMSOC)
Return

##########################################################################################################
Subprog RECUPBLM2(DOSSIER,SOCIETE,TOUSITE,SITE,LEDTYP,EXERCICE,DEVISE,BALANA,COMPTE,BATCH,DIRECT)
Value Char    DOSSIER
Value Char    SOCIETE
Value Integer TOUSITE
Value Char    SITE
Value Integer LEDTYP
Value Integer EXERCICE
Value Char    DEVISE
Value Integer BALANA
Value Char    COMPTE
Value Integer BATCH
Value Integer DIRECT    : # Paramètres de récup non saisis

If clalev([F:CPY])=0 : Local File =DOSSIER+".COMPANY"       [CPY] : Endif
If clalev([F:FCY])=0 : Local File =DOSSIER+".FACILITY"      [FCY] : Endif
If clalev([F:GCM])=0 : Local File =DOSSIER+".GACM"          [GCM] : Endif

Local Integer ISOC
ISOC   = find(SOCIETE,GSOC(1..GNBSOC))
If !ISOC
 Gosub INISOC
Endif

Call LEC_CPY(SOCIETE) From CPTLEC
Local Integer IGCM
IGCM   = find([F:CPY]ACM,GGCM(1..GGCMNBR))
If !IGCM
 If GNBSOC<>nbrecord([F:CPY]) : Gosub INISOC : Endif
 Call GLOBVAR From SETGLBGCM
Endif

Goto RECUP

##########################################################################################################
Subprog RECUPBLM(SOCIETE,TOUSITE,SITE,LEDTYP,EXERCICE,DEVISE,BALANA,COMPTE,BATCH,DIRECT)
Value Char    SOCIETE
Value Integer TOUSITE
Value Char    SITE
Value Integer LEDTYP
Value Integer EXERCICE
Value Char    DEVISE
Value Integer BALANA
Value Char    COMPTE
Value Integer BATCH
Value Integer DIRECT    : # Paramètres de récup non saisis

Local Char DOSSIER(GLONADP)
DOSSIER=nomap

$RECUP
Gosub OUVRE

# Indice de travail
Local Integer MAXPER, MAXDEV
MAXPER=func AFNC.ACTIV("PER")
MAXDEV = nbrecord([TCU])

# Variable pour le filtre standard
Local Char   FILTECT(250)(0..4)
Local Integer IFILE

# Variable générale
Local Integer ISOC               # Indice de société sous GSOC
Local Date    DATDEB , DATFIN    # Date début et fin d'exercice

# Variable commune de travails
Local Char    DEVBAL(GLONCUR) , SITBAL(GLONFCY)

Local Integer TEST            # Variable qui permet d'ajouter des éléments dans la trace.
Local Integer OK              # Flag pour le controle de mono-société.
Local Integer ANOM            # Nombre d'anomalies rencontrées
Local Integer I,J,K
Local Decimal EXE, PER

# 211209 : Pour les indices d'axes correpondants aux axes du référentiel
Local Integer INDDIE1,INDDIE2,INDDIE3,INDDIE4,INDDIE5,INDDIE6,INDDIE7,INDDIE8,INDDIE9
Local Char    MESSA(80)                        # Message d'erreur
Local Integer STAT                             # Statut d'erreur

######################### Trace détaillée si TEST=1
TEST  = 0

# Issue X3-107415 by MRDAB
#-- Vérification d'équilibre : Pas de critère sur compte
# account criteria handled on the screen and from the rest of the system COMPTE is passed empty.
#If BALANA<>2 : COMPTE = "" :  Endif
# Issue X3-107415 end

If !(BATCH | DIRECT)
 If BALANA=2
  Call OUVRE_TRACE(mess(73,116,1)) From LECFIC        # Récupération balance analytique
 Else
  Call OUVRE_TRACE(mess(74,116,1)) From LECFIC        # Vérification balance analytique
 Endif
Endif

If !TEST & BALANA=2 & !DIRECT
 Call MONOCPY(SOCIETE, OK) From AX3MONO # <JFL>
 If !OK : Goto FIN : Endif
Endif

GSOCIETE = [L]SOCIETE
Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV
If SOCIETE<>[F:FIY]CPY | [L]LEDTYP<>[F:FIY]LEDTYP | EXERCICE<>[F:FIY]FIYNUM
 Read [FIY]FIY0 = SOCIETE;[L]LEDTYP;EXERCICE
 If fstat
  Call ECR_TRACE(SOCIETE-num$(EXERCICE)-mess(52,116,1),1) From GESECRAN     # Exercice incorrect
  ANOM = 1 : Goto FIN
 Endif
Endif
DATDEB = [F:FIY]FIYSTR
DATFIN = [F:FIY]FIYEND
ISOC = find(SOCIETE,GSOC(1..GNBSOC))

Call LEC_CPY(SOCIETE) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC
Gosub BUILD_INDDIE

If BALANA<>2
 Gosub TSTBAL
Else
 Gosub RECBAL
Endif

$FIN
If BALANA=2 & !DIRECT
 Call MULTICPY(SOCIETE) From AX3MONO # <JFL>
Endif
If !(BATCH | DIRECT)
 Call FERME_TRACE From LECFIC
Endif
End


$BUILD_INDDIE
Gosub DECLARE_GLOBAL From SUBCMM
Call INI_GLOBAL(SOCIETE,STAT,MESSA) From SUBCMM
Call LEC_LED([F:GCM]LED([L]LEDTYP-1)) From CPTLEC
If !fstat
 For I=0 To [F:LED]DIENBR-1
  J=find([F:LED]DIE(I),GENGAXE(1..20))
  If J
   Assign "INDDIE"+num$(I+1) With J-1
  Endif
 Next
Endif
Return

############################################################################################################
#-- Resynchronisation de la balance
############################################################################################################
$RECBAL

# Variable pour le filtre de pagination (gestion snapshot too old)
Local Char    FILTPAG(250)(0..4)
Local Integer IFILP
Local Char    CPTDEB(GLONGAC),TRSDEB(GLONBPR),CCEDEB(GLONCCE)(1..9)
Local Char    CPTCUR(GLONGAC),TRSCUR(GLONBPR),CCECUR(GLONCCE)(1..9)
Local Char    TRSCUR2(GLONBPR)
Local Integer FLCCE(1..9), RGCLE

# Variable pour le filtre de RAZ balance
Local Char    FILTBAL(250)(0..4)
Local Integer IFILTA

#-- Variable pour la re-synchronisation des montants
Local Decimal ENG1(1..MAXDEV,0..MAXPER) , PRP1(1..MAXDEV,0..MAXPER)       # Montant Ligne engagés/pré-engégés (devise transaction)
Local Decimal ENG2(1..MAXDEV,0..MAXPER) , PRP2(1..MAXDEV,0..MAXPER)       # Montant Ligne engagés/pré-engégés (devise référentiel)
Local Decimal CENG1(1..MAXDEV,0..MAXPER) , CPRP1(1..MAXDEV,0..MAXPER)     # Cumuls Lignes Tiers engagés/pré-engégés (devise transaction)
Local Decimal CENG2(1..MAXDEV,0..MAXPER) , CPRP2(1..MAXDEV,0..MAXPER)     # Cumuls Lignes Tiers engagés/pré-engégés (devise référentiel)
Local Integer SNSCMM

#-- Stockage du nombre & intitulé de devises parcourues (Qty Lignes + Qty Lignes Tiers)
Local Integer NBDEV, CNBDEV
Local Char    TBDEV(GLONCUR)(1..MAXDEV),CTBDEV(GLONCUR)(1..MAXDEV)

#-- Variable pour stocker les autres valeurs
Local Integer BALFIY
Local Char    BALCPY(GLONCPY), BALFCY(GLONFCY)
Local Char    BALACC(GLONGAC), BALBPR(GLONBPR), BALCUR(GLONCUR)

Local Char    BALSEC1(GLONCCE) , BALSEC2(GLONCCE) , BALSEC3(GLONCCE)
Local Char    BALSEC4(GLONCCE) , BALSEC5(GLONCCE) , BALSEC6(GLONCCE)
Local Char    BALSEC7(GLONCCE) , BALSEC8(GLONCCE) , BALSEC9(GLONCCE)

#-- Paramètres d'optimisation des boucles pour éviter le vieux snapshot too old
Local Integer NBECR, TOTECR, ECRMAX  : ECRMAX = 10000     # Nombre pièces à re-synchroniser
Local Integer NBCPT, TOTCPT, CPTMAX  : CPTMAX = 200       # Nombres comptes re-synchroniser
Local Integer STOP

Local Integer NBAXI                # Nombre d'axe pour le référentiel
Local Integer FLSOC,FLSIT,FLDEV    # Flag de travail
Local Integer IDEV

#-- Information sur le nombres d'axes à gérer

Call INDLED([F:GCM]LED([L]LEDTYP-1),"",I,J) From CPTDIV
NBAXI = GLEDDIENBR(I)
If NBAXI = 0 : Return : Endif  # Pas d'axes...

#-- Entête fichier Trace
Call LEC_CPY(SOCIETE) From CPTLEC
Call ECR_TRACE(mess(79,116,1),0) From GESECRAN                                    # Récupération balance analytique
Call ECR_TRACE(mess(2,116,1)-SOCIETE,0) From GESECRAN                             # Société
Call ECR_TRACE(mess(3,116,1)-num$(EXERCICE),0) From GESECRAN                      # Exercice
If TOUSITE=2
 Call ECR_TRACE(mess(4,116,1),0) From GESECRAN                                    # Tous sites
Elsif SITE<>""
 Call ECR_TRACE(mess(5,116,1)-SITE,0) From GESECRAN                               # Site
Endif
If DEVISE<>""
 Call ECR_TRACE(mess(55,116,1)-DEVISE,0) From GESECRAN                            # Devise
Endif
If COMPTE<>""
 Call ECR_TRACE(mess(76,116,1)-COMPTE,0) From GESECRAN                            # Nature
Endif

#-- Début récupération
Call ECR_TRACE(mess(49,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

#-- Remise à zéro
Call ECR_TRACE(mess(149,124,1),0) From GESECRAN
Gosub RAZBAL

#-- Information sur la devise
If DEVISE=""
 FLDEV = 0
Else
 FLDEV = 1
Endif

#-- Récupération par site
If TOUSITE=2 or SITE=""
 If TOUSITE=2
  FLSOC = 1 : FLSIT = 1
 Else
  FLSOC = 1 : FLSIT = 0
 Endif
 For [FCY]FCY0 Where LEGCPY=SOCIETE & FINFLG=2
  SITE = [F:FCY]FCY
  Gosub BALSIT
 Next
Else
 FLSOC = 0 : FLSIT = 1
 Gosub BALSIT
Endif
Call ECR_TRACE(mess(50,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN    # Fin récupération
Return


$BALSIT
Raz FILTECT, IFILE
Call ADDCRIT(FILTECT,IFILE,"LEDTYP",'[F:CMD]LEDTYP('+num$([L]LEDTYP-1)+')='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"CPY",'[F:CMD]CPY="'+SOCIETE+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"FCY",'[F:CMD]FCYLIN="'+SITE+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:CMD]ACCDAT>=['+format$(GFMD,DATDEB)+']'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:CMD]ACCDAT<=['+format$(GFMD,DATFIN)+']'," & ") From GOBJSUB
If COMPTE<>""
 Call ADDCRIT(FILTECT,IFILE,"ACC",'[F:CMD]ACC('+num$([L]LEDTYP-1)+')="'+COMPTE+'"'," & ") From GOBJSUB
Endif
If DEVISE<>""
 Call ADDCRIT(FILTECT,IFILE,"CUR",'[F:CMD]CUR="'+DEVISE+'"'," & ") From GOBJSUB
Endif

Case NBAXI
 When 1
  Filter [CMD]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA([L]LEDTYP-1);ACC([L]LEDTYP-1);BPRACC
& ;CCE(INDDIE1);NUM;LIN
  RGCLE = 7
 When 2
  Filter [CMD]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA([L]LEDTYP-1);ACC([L]LEDTYP-1);BPRACC
& ;CCE(INDDIE1);CCE(INDDIE2);NUM;LIN
  RGCLE = 8
 When 3
  Filter [CMD]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA([L]LEDTYP-1);ACC([L]LEDTYP-1);BPRACC
& ;CCE(INDDIE1);CCE(INDDIE2);CCE(INDDIE3);NUM;LIN
  RGCLE = 9
 When 4
  Filter [CMD]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA([L]LEDTYP-1);ACC([L]LEDTYP-1);BPRACC
& ;CCE(INDDIE1);CCE(INDDIE2);CCE(INDDIE3);CCE(INDDIE4);NUM;LIN
  RGCLE = 10
 When 5
  Filter [CMD]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA([L]LEDTYP-1);ACC([L]LEDTYP-1);BPRACC
& ;CCE(INDDIE1);CCE(INDDIE2);CCE(INDDIE3);CCE(INDDIE4);CCE(INDDIE5);NUM;LIN
  RGCLE = 11
 When 6
  Filter [CMD]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA([L]LEDTYP-1);ACC([L]LEDTYP-1);BPRACC
& ;CCE(INDDIE1);CCE(INDDIE2);CCE(INDDIE3);CCE(INDDIE4);CCE(INDDIE5);CCE(INDDIE6);NUM;LIN
  RGCLE = 12
 When 7
  Filter [CMD]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA([L]LEDTYP-1);ACC([L]LEDTYP-1);BPRACC
& ;CCE(INDDIE1);CCE(INDDIE2);CCE(INDDIE3);CCE(INDDIE4);CCE(INDDIE5);CCE(INDDIE6);CCE(INDDIE7);NUM;LIN
  RGCLE = 13
 When 8
  Filter [CMD]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA([L]LEDTYP-1);ACC([L]LEDTYP-1);BPRACC
& ;CCE(INDDIE1);CCE(INDDIE2);CCE(INDDIE3);CCE(INDDIE4);CCE(INDDIE5);CCE(INDDIE6);CCE(INDDIE7);CCE(INDDIE8);NUM;LIN
  RGCLE = 14
 When 9
  Filter [CMD]
& Order By Key CLE=LEDTYP;CPY;FCYLIN;COA([L]LEDTYP-1);ACC([L]LEDTYP-1);BPRACC
& ;CCE(INDDIE1);CCE(INDDIE2);CCE(INDDIE3);CCE(INDDIE4);CCE(INDDIE5);CCE(INDDIE6);CCE(INDDIE7);CCE(INDDIE8);CCE(INDDIE9);NUM;LIN
  RGCLE = 15
Endcase

TOTECR = 0
TOTCPT = 0
CPTDEB = ""
TRSDEB = ""
For I=1 To 9
 Raz CCEDEB(I)
 Raz FLCCE(I)
Next

#RecuBAL: RAZREP

#-- Link GACCOUNT & GCOMMIT
Link [CMD] With [GAC]GAC0~=[F:CMD]COA([L]LEDTYP-1);[F:CMD]ACC([L]LEDTYP-1), [CMM]CMM0~=[F:CMD]NUM
& As [LNK]
& Where evalue(FILTECT)

#-- Boucle optimisée pour éviter le snapshot too old tout en utilisant les index
Gosub SET_FIRST From TRTFIRST
$BOUCLE_BAL
NBECR  = 0
NBCPT  = 0
STOP = 0
Raz FILTPAG, IFILP

J=NBAXI
While J>0
 If FLCCE(J)
  Call ADDCRIT(FILTPAG,IFILP,"ACC",'[F:CMD]ACC('+num$([L]LEDTYP-1)+')="'+CPTDEB+'"'," & ") From GOBJSUB
  Call ADDCRIT(FILTPAG,IFILP,"BPR",'[F:CMD]BPRACC="'+TRSDEB+'"'," & ") From GOBJSUB
  For I=1 To J-2
   Call ADDCRIT(FILTPAG,IFILP,"CCE",'[F:CMD]CCE('+num$(evalue("INDDIE"+num$(I)))+')="'+CCEDEB(I)+'"'," & ") From GOBJSUB
  Next
  Call ADDCRIT(FILTPAG,IFILP,"CCE",'[F:CMD]CCE('+num$(evalue("INDDIE"+num$(I)))+')>"'+CCEDEB(I)+'"'," & ") From GOBJSUB
  Break
 Endif
 J-=1
Wend
If J=0
 If TRSDEB<>""
  Call ADDCRIT(FILTPAG,IFILP,"ACC",'[F:CMD]ACC('+num$([L]LEDTYP-1)+')="'+CPTDEB+'"'," & ") From GOBJSUB
  Call ADDCRIT(FILTPAG,IFILP,"BPR",'[F:CMD]BPRACC>"'+TRSDEB+'"'," & ") From GOBJSUB
 Elsif CPTDEB<>""
  Call ADDCRIT(FILTPAG,IFILP,"ACC",'[F:CMD]ACC('+num$([L]LEDTYP-1)+')>"'+CPTDEB+'"'," & ") From GOBJSUB
 Endif
Endif

If FILTPAG="" : FILTPAG="1=1" : Endif

#-- Ligne de pièces analytique
For [LNK]CLE(5) Where evalue(FILTPAG) : # Société + site + compte
 BALACC = [F:GAC]ACC
 If TRSDEB="" & [F:GAC]SAC=2
  Gosub RAZCOL
 Endif

 For [LNK]CLE(6)
  If NBCPT>=CPTMAX or NBECR>=ECRMAX
   STOP = 1
   CPTDEB = CPTCUR
   TRSDEB = TRSCUR
   For I=1 To NBAXI
    Assign "CCEDEB("+num$(I)+")" With evalue("CCECUR("+num$(I)+")")
   Next
   FLCCE(NBAXI)=1
   Break 2
  Endif
  CPTCUR = [F:CMD]ACC([L]LEDTYP-1)
  TRSCUR = [F:CMD]BPRACC
  If [F:GAC]SAC=2
   TRSCUR2 = [F:CMD]BPRACC
  Else
   TRSCUR2 = ""
  Endif

  Gosub BALCPT
  If [F:GAC]SAC=2
   Gosub CUMCOL
  Endif
  NBCPT += 1
 Next
 If [F:GAC]SAC=2
  Gosub BALCOL
 Endif
Next
TOTCPT += NBCPT
TOTECR += NBECR
If TEST : Call ECR_TRACE(time$-"break"-num$(TOTCPT)-num$(TOTECR),0) From GESECRAN : Endif
If STOP
 Goto BOUCLE_BAL
Else
 J=NBAXI
 While J>1
  If FLCCE(J)
   FLCCE(J) = 0
   FLCCE(J-1) = 1
   Goto BOUCLE_BAL
  Endif
  J-=1
 Wend
 If FLCCE(1)
  FLCCE(1) = 0
  Goto BOUCLE_BAL
 Elsif TRSDEB<>""
  TRSDEB = ""
  Goto BOUCLE_BAL
 Endif
Endif
Gosub UNSET_FIRST From TRTFIRST
Filter [CMD]
Return

$BALCPT
For [LNK]CLE(RGCLE)
 Raz ENG1, ENG2
 Raz PRP1, PRP2
 Raz NBDEV, TBDEV

 For [LNK]CLE
  NBECR += 1
  If !FLDEV | DEVISE=[F:CMM]CUR
   IDEV = find([F:CMM]CUR,TBDEV(1..NBDEV))
   If !IDEV : NBDEV += 1 : TBDEV(NBDEV) = [F:CMM]CUR : IDEV = NBDEV : Endif
   Gosub CUMCPT
  Endif
  For I=1 To NBAXI
   Assign "CCECUR("+num$(I)+")" With evalue("[F:CMD]CCE("+num$(evalue("INDDIE"+num$(I)))+")")
  Next
 Next
 If NBDEV
  Gosub MAJCPT
 Endif
Next
Return

$CUMCPT
Call GETPERSOC(SOCIETE,[L]LEDTYP,[F:CMD]ACCDAT,EXE,PER) From CPTSUB
If [F:CMM]SNS = 1
 SNSCMM = +1
Else
 SNSCMM = -1
Endif
If [F:CMM]TYP=1
 PRP1(IDEV,[L]PER)  += [F:CMD]AMTCUR*SNSCMM
 PRP2(IDEV,[L]PER)  += [F:CMD]AMTLED([L]LEDTYP-1)*SNSCMM
Else
 ENG1(IDEV,[L]PER)  += [F:CMD]AMTCUR*SNSCMM
 ENG2(IDEV,[L]PER)  += [F:CMD]AMTLED([L]LEDTYP-1)*SNSCMM
Endif
Return

$MAJCPT
Call DEBTRANS From GLOCK
Gosub TR2
Return

$TR2
GOK = 1
Trbegin [BLM]
BALCPY = SOCIETE
BALACC = CPTCUR
BALBPR = TRSCUR2
BALFIY = EXERCICE

For I=1 To NBAXI
 Assign "BALSEC"+num$(I) With evalue("[F:CMD]CCE("+num$(evalue("INDDIE"+num$(I)))+")")
Next

If TEST : Call ECR_TRACE(time$-"blm"-SITE-BALACC-BALSEC1-BALSEC2-BALSEC3,0) From GESECRAN : Endif

Gosub CREBAL
If GOK<1 : Goto AB_TR2 : Endif

Commit
Return

############################################################################################################
#-- Ré écriture de la Balance
############################################################################################################
$CREBAL
For IDEV=1 To NBDEV
 If DEVISE="" or DEVISE=TBDEV(IDEV)
  BALCUR = TBDEV(IDEV)
  # MAJ Société
  If FLSOC
   BALFCY = ""
   Gosub MAJBAL
   If GOK<1 : Return : Endif
   If BALBPR<>""
    BALBPR=""
    Gosub MAJBAL
    If GOK<1 : Return : Endif
   Endif
  Endif
  BALBPR = TRSCUR2
  # MAJ Site
  If FLSIT
   BALFCY = [F:CMD]FCYLIN
   Gosub MAJBAL
   If GOK<1 : Return : Endif
   If BALBPR<>""
    BALBPR=""
    Gosub MAJBAL
    If GOK<1 : Return : Endif
   Endif
  Endif
 Endif
Next IDEV
Return

$MAJBAL
If BALACC<>""
 Readlock [BLM]BLM0 = [L]LEDTYP;BALCPY;BALFCY;BALFIY;BALACC;BALBPR;BALSEC1;BALSEC2;BALSEC3;BALSEC4;BALSEC5;BALSEC6;BALSEC7;BALSEC8;BALSEC9;BALCUR
 If fstat
  Raz [F:BLM]
  [F:BLM]LEDTYP = [L]LEDTYP
  [F:BLM]CPY    = BALCPY
  [F:BLM]FCY    = BALFCY
  [F:BLM]FIY    = BALFIY
  [F:BLM]ACC    = BALACC
  [F:BLM]BPR    = BALBPR
  [F:BLM]CCE1   = BALSEC1
  [F:BLM]CCE2   = BALSEC2
  [F:BLM]CCE3   = BALSEC3
  [F:BLM]CCE4   = BALSEC4
  [F:BLM]CCE5   = BALSEC5
  [F:BLM]CCE6   = BALSEC6
  [F:BLM]CCE7   = BALSEC7
  [F:BLM]CCE8   = BALSEC8
  [F:BLM]CCE9   = BALSEC9
  [F:BLM]CUR    = BALCUR
  [F:BLM]ACCNUM = uniqid([F:BLM])
  [F:BLM]LED    = [F:CMM]LED([L]LEDTYP-1)
  [F:BLM]COA    = [F:CMD]COA([L]LEDTYP-1)
  [F:BLM]CURLED = [F:CMD]CURLED([L]LEDTYP-1)
  For I=1 To NBAXI
   Assign "[F:BLM]DIE("+num$(I-1)+")"  With evalue("[F:CMD]DIE("+num$(evalue("INDDIE"+num$(I)))+")")
  Next
  Gosub CALBAL
  Write [BLM]
 Else
  Gosub CALBAL
  Rewrite [BLM]
 Endif
 If fstat
  GOK=0 : Call FSTA("BLM") From GLOCK : Return
 Endif
Endif
Return

$CALBAL
For K=0 To MAXPER-1
 [F:BLM]CMM(K)       += ENG1(IDEV,K)
 [F:BLM]CMMPRP(K)    += PRP1(IDEV,K)
 [F:BLM]CMMLED(K)    += ENG2(IDEV,K)
 [F:BLM]CMMPRPLED(K) += PRP2(IDEV,K)
Next K
Return

$AB_TR2
$AB_TR22
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif


############################################################################################################
#- Collectif
############################################################################################################
######################################################
$RAZCOL
If TEST : Call ECR_TRACE("raz collectif"-[F:GAC]ACC,0) From GESECRAN : Endif
Raz CENG1, CENG2
Raz CPRP1, CPRP2
Raz CNBDEV, CTBDEV
Return

######################################################
$CUMCOL
For IDEV=1 To NBDEV
 JDEV = find(TBDEV(IDEV),CTBDEV(1..CNBDEV))
 If !JDEV : CNBDEV += 1 : CTBDEV(CNBDEV) = TBDEV(IDEV) : JDEV = CNBDEV : Endif
 For K=0 To MAXPER-1
  CENG1(JDEV,K) += ENG1(IDEV,K)
  CPRP1(JDEV,K) += PRP1(IDEV,K)
  CENG2(JDEV,K) += ENG2(IDEV,K)
  CPRP2(JDEV,K) += PRP2(IDEV,K)
 Next K
Next IDEV
Return

######################################################
$BALCOL
If TEST : Call ECR_TRACE("maj collectif"-[F:GAC]ACC,0) From GESECRAN : Endif
Call DEBTRANS From GLOCK
Gosub TR22
Return

$TR22
GOK = 1
NBDEV = CNBDEV
For IDEV=1 To NBDEV
 TBDEV(IDEV) = CTBDEV(IDEV)
 For K=0 To MAXPER-1
  ENG1(IDEV,K) = CENG1(IDEV,K)
  PRP1(IDEV,K) = CPRP1(IDEV,K)
  ENG2(IDEV,K) = CENG2(IDEV,K)
  PRP2(IDEV,K) = CPRP2(IDEV,K)
 Next K
Next IDEV
If NBDEV
 Trbegin [BLM]
 BALCPY = SOCIETE
 BALACC = CPTCUR
 BALBPR = ""
 BALFIY = EXERCICE
 For I=1 To NBAXI
  Assign "BALSEC"+num$(I) With evalue("[F:CMD]CCE("+num$(evalue("INDDIE"+num$(I)))+")")
 Next
 If TEST : Call ECR_TRACE(time$-"blm"-SITE-BALACC-BALSEC1-BALSEC2-BALSEC3,0) From GESECRAN : Endif
 Gosub CREBAL
 If GOK<1 : Goto AB_TR22 : Endif
 Commit
Endif
Return


#########################################################################################################
## Vérification de la balance
#########################################################################################################
$TSTBAL
ANOM = 0

#-- Entête fichier Trace
Call LEC_CPY(SOCIETE) From CPTLEC
Call ECR_TRACE(mess(74,116,1),0) From GESECRAN                                     # Vérification balance analytique
Call ECR_TRACE(mess(2,116,1)-SOCIETE,0) From GESECRAN                              # Société
Call ECR_TRACE(mess(3,116,1)-num$(EXERCICE),0) From GESECRAN                       # Exercice
If TOUSITE=2
 Call ECR_TRACE(mess(4,116,1),0) From GESECRAN                                     # Tous sites
Elsif SITE<>""
 Call ECR_TRACE(mess(5,116,1)-SITE,0) From GESECRAN                                # Site
Endif
If DEVISE<>""
 Call ECR_TRACE(mess(55,116,1)-DEVISE,0) From GESECRAN                             # Devise
Endif
If COMPTE<>""
 Call ECR_TRACE(mess(76,116,1)-COMPTE,0) From GESECRAN                             # Nature
Endif
Call ECR_TRACE(mess(70,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN    # Début vérification
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Gosub VERIF
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(71,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN    # Fin Vérification
If ANOM
 Call ECR_TRACE(num$(ANOM)-mess(7,116,1),0) From GESECRAN                          # anomalies
Else
 Call ECR_TRACE(mess(8,116,1),0) From GESECRAN                                     # Aucune anomalie
Endif
Return

$VERIF
Local Integer NBCUR, NBSIT
Local Integer FLG1, FLG2

Local Integer  MAXSIT , MAXBAL
MAXSIT = 5
# Ajout du filtre sur les sites financiers
Link [FGR] With [FCY]FCY0=[F:FGR]FCY
& As [LFGR]
& Where [FGR]CPY=SOCIETE & [FCY]FINFLG=2

For [LFGR]FGR0
 MAXSIT += 1
Next
MAXBAL = MAXPER

Local Char    TBCUR(GLONCUR)(1..MAXDEV)
Local Char    TBSIT(GLONFCY)(1..MAXSIT)
Local Char    TIERS(GLONBPR)

# Montants transaction
Local Decimal BALENG(0..MAXPER) , BALPRP(0..MAXPER)
Local Decimal COLENG(0..MAXPER) , COLPRP(0..MAXPER)
Local Decimal GLENG(1..MAXDEV,0..MAXPER) , GLPRP(1..MAXDEV,0..MAXPER)
Local Decimal SOCENG(1..MAXDEV,0..MAXBAL) , SOCPRP(1..MAXDEV,0..MAXBAL)
Local Decimal SITENG(1..MAXSIT,1..MAXDEV,0..MAXBAL) , SITPRP(1..MAXSIT,1..MAXDEV,0..MAXBAL)

# Montant Référentiel
Local Decimal BALENGLED(0..MAXPER) , BALPRPLED(0..MAXPER)
Local Decimal COLENGLED(0..MAXPER) , COLPRPLED(0..MAXPER)
Local Decimal GLENGLED(1..MAXDEV,0..MAXPER) , GLPRPLED(1..MAXDEV,0..MAXPER)
Local Decimal SOCENGLED(1..MAXDEV,0..MAXBAL) , SOCPRPLED(1..MAXDEV,0..MAXBAL)
Local Decimal SITENGLED(1..MAXSIT,1..MAXDEV,0..MAXBAL) , SITPRPLED(1..MAXSIT,1..MAXDEV,0..MAXBAL)

Local Integer P

Gosub VERECT
Return

###############################################
## Vérif balance - grand-livre
###############################################

## Phase 1, écritures

$VERECT
Raz FILTECT, IFILE
Call ADDCRIT(FILTECT,IFILE,"LEDTYP",'[F:CMD]LEDTYP('+num$([L]LEDTYP-1)+')='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"CPY",'[F:CMD]CPY="'+SOCIETE+'"'," & ") From GOBJSUB
If TOUSITE<>2 & SITE<>""
 Call ADDCRIT(FILTECT,IFILE,"FCYLIN",'[F:CMD]FCYLIN="'+SITE+'"'," & ") From GOBJSUB
Endif
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:CMD]ACCDAT>=['+format$(GFMD,DATDEB)+']'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:CMD]ACCDAT<=['+format$(GFMD,DATFIN)+']'," & ") From GOBJSUB

If COMPTE<>""
 Call ADDCRIT(FILTECT,IFILE,"ACC",'[F:CMD]ACC('+num$([L]LEDTYP-1)+')="'+COMPTE+'"'," & ") From GOBJSUB
Endif
If DEVISE<>""
 Call ADDCRIT(FILTECT,IFILE,"CUR",'[F:CMD]CUR="'+DEVISE+'"'," & ") From GOBJSUB
Endif

NBCUR = 0
NBSIT = 0

Filter [BLM]

#-- Link GACCOUNT & GCOMMIT
Link [CMD] With [GAC]GAC0~=[F:CMD]COA([L]LEDTYP-1);[F:CMD]ACC([L]LEDTYP-1), [CMM]CMM0~=[F:CMD]NUM
& As [LNK]
& Where evalue(FILTECT)
& Order By Key CLE = [F:CMD]ACC([L]LEDTYP-1);[F:CMD]BPRACC;[F:CMD]FCYLIN;[F:CMD]ACCDAT;[F:CMD]NUM;[F:CMD]LIN

Gosub SET_FIRST From TRTFIRST
For [LNK]CLE(1)   : # Compte
 COMPTE = [F:CMD]ACC([L]LEDTYP-1)
 Raz SITENG, SITPRP, SITENGLED, SITPRPLED
 For [LNK]CLE(2)  : # Tiers
  TIERS = [F:CMD]BPRACC
  If [F:GAC]SAC<>2 : TIERS="" : Endif
  Raz SOCENG, SOCPRP, SOCENGLED,SOCPRPLED
  For [LNK]CLE(3) : # Site
   Raz GLENG, GLPRP, GLENGLED, GLPRPLED
   SITBAL = [F:CMD]FCYLIN
   For [LNK]CLE   : # Détail
    K = find([F:CMD]CUR,TBCUR(1..NBCUR))
    If !K
     NBCUR += 1 : K = NBCUR
     TBCUR(NBCUR) = [F:CMD]CUR
    Endif
    #If [F:CMM]ACCDAT=[F:CMD]ACCDAT
    # [L]PER = [F:CMM]PER
    #Else
     Call GETPERSOC(SOCIETE,LEDTYP,[F:CMD]ACCDAT,EXE,PER) From CPTSUB
    #Endif
    If [F:CMM]TYP=1
     GLPRP(K,PER)    += [F:CMD]AMTCUR
     GLPRPLED(K,PER) += [F:CMD]AMTLED(LEDTYP-1)
    Else
     GLENG(K,PER)    += [F:CMD]AMTCUR
     GLENGLED(K,PER) += [F:CMD]AMTLED(LEDTYP-1)
    Endif
   Next
   # Vérif pour 1 compte  1 tiers et 1 site
   Gosub VER_BPR_SIT
   For P=0 To MAXPER-1
    For K=1 To NBCUR
     SOCENG(K,P)    += GLENG(K,P)
     SOCPRP(K,P)    += GLPRP(K,P)
     SOCENGLED(K,P) += GLENGLED(K,P)
     SOCPRPLED(K,P) += GLPRPLED(K,P)
    Next K
   Next P
   J = find(SITBAL,TBSIT(1..NBSIT))
   If !J
    NBSIT += 1 : J = NBSIT
    TBSIT(NBSIT) = SITBAL
   Endif
   For P=0 To MAXPER-1
    For K=1 To NBCUR
     SITENG(J,K,P)    += GLENG(K,P)
     SITPRP(J,K,P)    += GLPRP(K,P)
     SITENGLED(J,K,P) += GLENGLED(K,P)
     SITPRPLED(J,K,P) += GLPRPLED(K,P)
    Next K
   Next P
  Next
  # Vérif pour 1 compte  1 tiers et société
  If TOUSITE=2 : Gosub VER_BPR_SOC : Endif
 Next
 # Vérif pour 1 compte collectif, société et site
 # Issue X3-76025 by MRDAB - false positives
# If [F:GAC]SAC=2
  Gosub VER_CPT
# Endif
 # Issue X3-76025 end
Next
Gosub UNSET_FIRST From TRTFIRST
Filter [CMD]
Return

###############################################
## Sous-programmes d'erreurs
###############################################
$VER_BPR_SIT
# Issue X3-76025 by MRDAB - false positives
#If TIERS="" & [F:GAC]SAC=2 : Return : Endif
If TIERS="" : Return : Endif
# Issue X3-76025 end
If TEST : Call ECR_TRACE(time$-"VER_BPR_SIT"-SITBAL-COMPTE-TIERS,0) From GESECRAN : Endif
For K=1 To NBCUR
 DEVBAL = TBCUR(K)
 POIERR = 1  :# bug 7889 : controle bloquant en devise société
 # If DEVBAL<>[F:GCM]CUR(LEDTYP-1) : POIERR=0 : Endif

 Raz BALENG, BALPRP, BALENGLED, BALPRPLED
 For [BLM]BLM0 Where [F:BLM]LEDTYP=[L]LEDTYP & [F:BLM]CPY=SOCIETE & [F:BLM]FCY=SITBAL & [F:BLM]FIY=EXERCICE & [F:BLM]ACC=COMPTE & [F:BLM]BPR=TIERS & [F:BLM]CUR=DEVBAL
  For P=1 To MAXPER-1
   BALENG(P)     += [F:BLM]CMM(P)
   BALPRP(P)     += [F:BLM]CMMPRP(P)
   BALENGLED(P)  += [F:BLM]CMMLED(P)
   BALPRPLED(P)  += [F:BLM]CMMPRPLED(P)
  Next P
 Next

 For P=1 To MAXPER-1

  # Montant Transaction et Montant référentiel
  Raz FLG1, FLG2
  If BALENG(P)<>GLENG(K,P) | BALPRP(P)<>GLPRP(K,P)             : FLG1=1 : Endif
  If BALENGLED(P)<>GLENGLED(K,P) | BALPRPLED(P)<>GLPRPLED(K,P) : FLG2=1 : Endif

  If FLG1 or FLG2
   Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
   Call ECR_TRACE(mess(58,116,1)-DEVBAL-SITBAL-COMPTE-TIERS,POIERR) From GESECRAN            #  Erreur
   Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                       #  Période

   If FLG1
    Call LEC_TCU(DEVBAL) From CPTLEC
    Call ECR_TRACE(format$("K:30X",mess(60,116,1))
&                 +format$("N:"+[F:TCU]CURFMT1,BALENG(P))+" "+DEVBAL+"   "
&                 +format$("N:"+[F:TCU]CURFMT1,BALPRP(P))+" "+DEVBAL,0) From GESECRAN    #  Balance
    Call ECR_TRACE(format$("K:30X",mess(61,116,1))
&                 +format$("N:"+[F:TCU]CURFMT1,GLENG(K,P))+" "+DEVBAL+"   "
&                 +format$("N:"+[F:TCU]CURFMT1,GLPRP(K,P))+" "+DEVBAL,0) From GESECRAN       #  Grand Livre
    ANOM += 1
   Endif

   If FLG2
    Call LEC_TCU([F:GCM]CUR(LEDTYP-1)) From CPTLEC
    Call ECR_TRACE(format$("K:30X",mess(60,116,1)-left$(mess(153,116,1),11))
&                 +format$("N:"+[F:TCU]CURFMT1,BALENG(P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                 +format$("N:"+[F:TCU]CURFMT1,BALPRP(P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Balance Référentiel

    Call ECR_TRACE(format$("K:30X",mess(61,116,1)-left$(mess(153,116,1),11))
&                 +format$("N:"+[F:TCU]CURFMT1,GLENGLED(K,P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                 +format$("N:"+[F:TCU]CURFMT1,GLPRPLED(K,P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Grand Livre Référentiel

    ANOM += 1
   Endif
  Endif
 Next P
Next K
Return

$VER_BPR_SOC
# Issue X3-76025 by MRDAB - false positives
#If TIERS="" & [F:GAC]SAC=2 : Return : Endif
If TIERS="" : Return : Endif
# Issue X3-76025 end
If TEST : Call ECR_TRACE(time$-"VER_BPR_SOC"-COMPTE-TIERS,0) From GESECRAN : Endif
For K=1 To NBCUR
 DEVBAL = TBCUR(K)
 POIERR = 1  :# bug 7889 : controle bloquant en devise société
# If DEVBAL<>[F:GCM]CUR(LEDTYP-1) : POIERR=0 : Endif
 Raz BALENG, BALPRP, BALENGLED, BALPRPLED
 For [BLM]BLM0 Where [F:BLM]LEDTYP=[L]LEDTYP & [F:BLM]CPY=SOCIETE & [F:BLM]FCY="" & [F:BLM]FIY=EXERCICE & [F:BLM]ACC=COMPTE & [F:BLM]BPR=TIERS & [F:BLM]CUR=DEVBAL
  For P=1 To MAXPER-1
   BALENG(P)     += [F:BLM]CMM(P)
   BALPRP(P)     += [F:BLM]CMMPRP(P)
   BALENGLED(P)  += [F:BLM]CMMLED(P)
   BALPRPLED(P)  += [F:BLM]CMMPRPLED(P)
  Next P
 Next

 For P=1 To MAXPER-1

  # Montant Transaction et Montant référentiel
  Raz FLG1, FLG2
  If BALENG(P)<>SOCENG(K,P) | BALPRP(P)<>SOCPRP(K,P)             : FLG1=1 : Endif
  If BALENGLED(P)<>SOCENGLED(K,P) | BALPRPLED(P)<>SOCPRPLED(K,P) : FLG2=1 : Endif

  If FLG1 or FLG2
   Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
   Call ECR_TRACE(mess(58,116,1)-DEVBAL-SOCIETE-COMPTE-TIERS,POIERR) From GESECRAN            #  Erreur
   Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                        #  Période

   If FLG1
    Call LEC_TCU(DEVBAL) From CPTLEC
    Call ECR_TRACE(format$("K:30X",mess(60,116,1))
&                 +format$("N:"+[F:TCU]CURFMT1,BALENG(P))+" "+DEVBAL+"   "
&                 +format$("N:"+[F:TCU]CURFMT1,BALPRP(P))+" "+DEVBAL,0) From GESECRAN         #  Balance
    Call ECR_TRACE(format$("K:30X",mess(61,116,1))
&                 +format$("N:"+[F:TCU]CURFMT1,SOCENG(K,P))+" "+DEVBAL+"   "
&                 +format$("N:"+[F:TCU]CURFMT1,SOCPRP(K,P))+" "+DEVBAL,0) From GESECRAN       #  Grand Livre
    ANOM += 1
   Endif

   If FLG2
    Call LEC_TCU([F:GCM]CUR(LEDTYP-1)) From CPTLEC
    Call ECR_TRACE(format$("K:30X",mess(60,116,1)-left$(mess(153,116,1),11))
&                 +format$("N:"+[F:TCU]CURFMT1,BALENGLED(P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                 +format$("N:"+[F:TCU]CURFMT1,BALPRPLED(P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Balance Référentiel

    Call ECR_TRACE(format$("K:30X",mess(61,116,1)-left$(mess(153,116,1),11))
&                 +format$("N:"+[F:TCU]CURFMT1,SOCENGLED(K,P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                 +format$("N:"+[F:TCU]CURFMT1,SOCPRPLED(K,P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Grand Livre Référentiel

    ANOM += 1
   Endif
  Endif
 Next P
Next K
Return


$VER_CPT
If TEST : Call ECR_TRACE(time$-"VER_CPT"-COMPTE,0) From GESECRAN : Endif
For K=1 To NBCUR
 DEVBAL = TBCUR(K)
 POIERR = 1  :# bug 7889 : controle bloquant en devise société
# If DEVBAL<>[F:GCM]CUR(LEDTYP-1) : POIERR=0 : Endif

 Raz SOCENG, SOCPRP, SOCENGLED, SOCPRPLED
 For J=1 To NBSIT
  SITBAL = TBSIT(J)
  Raz BALENG, BALPRP, BALENGLED, BALPRPLED
  For [BLM]BLM0 Where [F:BLM]LEDTYP=[L]LEDTYP & [F:BLM]CPY=SOCIETE & [F:BLM]FCY=SITBAL & [F:BLM]FIY=EXERCICE & [F:BLM]ACC=COMPTE & [F:BLM]BPR="" & [F:BLM]CUR=DEVBAL
   For P=1 To MAXPER-1
    BALENG(P)     += [F:BLM]CMM(P)
    BALPRP(P)     += [F:BLM]CMMPRP(P)
    BALENGLED(P)  += [F:BLM]CMMLED(P)
    BALPRPLED(P)  += [F:BLM]CMMPRPLED(P)
   Next P
  Next

  For P=1 To MAXPER-1
   SOCENG(K,P)    += SITENG(J,K,P)
   SOCPRP(K,P)    += SITPRP(J,K,P)
   SOCENGLED(K,P) += SITENGLED(J,K,P)
   SOCPRPLED(K,P) += SITPRPLED(J,K,P)

   # Montant Transaction et Montant référentiel
   Raz FLG1, FLG2
   If BALENG(P)<>SITENG(J,K,P) | BALPRP(P)<>SITPRP(J,K,P)             : FLG1=1 : Endif
   If BALENGLED(P)<>SITENGLED(J,K,P) | BALPRPLED(P)<>SITPRPLED(J,K,P) : FLG2=1 : Endif

   If FLG1 or FLG2
    Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
    Call ECR_TRACE(mess(58,116,1)-DEVBAL-SITBAL-COMPTE-TIERS,POIERR) From GESECRAN            #  Erreur
    Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                 -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                        #  Période

    If FLG1
     Call LEC_TCU(DEVBAL) From CPTLEC
     Call ECR_TRACE(format$("K:30X",mess(60,116,1))
&                  +format$("N:"+[F:TCU]CURFMT1,BALENG(P))+" "+DEVBAL+"   "
&                  +format$("N:"+[F:TCU]CURFMT1,BALPRP(P))+" "+DEVBAL,0) From GESECRAN    #  Balance
     Call ECR_TRACE(format$("K:30X",mess(61,116,1))
&                  +format$("N:"+[F:TCU]CURFMT1,SITENG(J,K,P))+" "+DEVBAL+"   "
&                  +format$("N:"+[F:TCU]CURFMT1,SITPRP(J,K,P))+" "+DEVBAL,0) From GESECRAN       #  Grand Livre
     ANOM += 1
    Endif

    If FLG2
     Call LEC_TCU([F:GCM]CUR(LEDTYP-1)) From CPTLEC
     Call ECR_TRACE(format$("K:30X",mess(60,116,1)-left$(mess(153,116,1),11))
&                  +format$("N:"+[F:TCU]CURFMT1,BALENGLED(P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                  +format$("N:"+[F:TCU]CURFMT1,BALPRPLED(P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Balance Référentiel

     Call ECR_TRACE(format$("K:30X",mess(61,116,1)-left$(mess(153,116,1),11))
&                  +format$("N:"+[F:TCU]CURFMT1,SITENGLED(J,K,P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                  +format$("N:"+[F:TCU]CURFMT1,SITPRPLED(J,K,P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Grand Livre Référentiel

     ANOM += 1
    Endif
   Endif
  Next P
 Next J
 If TOUSITE=2   :# 17783

  Raz BALENG, BALPRP, BALENGLED, BALPRPLED
  For [BLM]BLM0 Where [F:BLM]LEDTYP=[L]LEDTYP & [F:BLM]CPY=SOCIETE & [F:BLM]FCY="" & [F:BLM]FIY=EXERCICE & [F:BLM]ACC=COMPTE & [F:BLM]BPR="" & [F:BLM]CUR=DEVBAL
   For P=1 To MAXPER-1
    BALENG(P)     += [F:BLM]CMM(P)
    BALPRP(P)     += [F:BLM]CMMPRP(P)
    BALENGLED(P)  += [F:BLM]CMMLED(P)
    BALPRPLED(P)  += [F:BLM]CMMPRPLED(P)
   Next P
  Next

  For P=1 To MAXPER-1

   # Montant Transaction et Montant référentiel
   Raz FLG1, FLG2
   If BALENG(P)<>SOCENG(K,P) | BALPRP(P)<>SOCPRP(K,P)             : FLG1=1 : Endif
   If BALENGLED(P)<>SOCENGLED(K,P) | BALPRPLED(P)<>SOCPRPLED(K,P) : FLG2=1 : Endif

   If FLG1 or FLG2
    Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
    Call ECR_TRACE(mess(58,116,1)-DEVBAL-SOCIETE-COMPTE-TIERS,POIERR) From GESECRAN            #  Erreur
    Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                 -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                        #  Période

    If FLG1
     Call LEC_TCU(DEVBAL) From CPTLEC
     Call ECR_TRACE(format$("K:30X",mess(60,116,1))
&                  +format$("N:"+[F:TCU]CURFMT1,BALENG(P))+" "+DEVBAL+"   "
&                  +format$("N:"+[F:TCU]CURFMT1,BALPRP(P))+" "+DEVBAL,0) From GESECRAN         #  Balance
     Call ECR_TRACE(format$("K:30X",mess(61,116,1))
&                  +format$("N:"+[F:TCU]CURFMT1,SOCENG(K,P))+" "+DEVBAL+"   "
&                  +format$("N:"+[F:TCU]CURFMT1,SOCPRP(K,P))+" "+DEVBAL,0) From GESECRAN       #  Grand Livre
     ANOM += 1
    Endif

    If FLG2
     Call LEC_TCU([F:GCM]CUR(LEDTYP-1)) From CPTLEC
     Call ECR_TRACE(format$("K:30X",mess(60,116,1)-left$(mess(153,116,1),11))
&                  +format$("N:"+[F:TCU]CURFMT1,BALENGLED(P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                  +format$("N:"+[F:TCU]CURFMT1,BALPRPLED(P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Balance Référentiel

     Call ECR_TRACE(format$("K:30X",mess(61,116,1)-left$(mess(153,116,1),11))
&                  +format$("N:"+[F:TCU]CURFMT1,SOCENGLED(K,P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                  +format$("N:"+[F:TCU]CURFMT1,SOCPRPLED(K,P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Grand Livre Référentiel
     ANOM += 1
    Endif
   Endif
  Next P
 Endif
Next K
Return

########################################
$RAZBAL
Raz FILTBAL, IFILTA
Call ADDCRIT(FILTBAL,IFILTA,"LEDTYP",'LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTBAL,IFILTA,"CPY",'CPY="'+SOCIETE+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTBAL,IFILTA,"FIY",'FIY='+num$(EXERCICE)," & ") From GOBJSUB
If COMPTE<>""
 Call ADDCRIT(FILTBAL,IFILTA,"ACC",' ACC="'+COMPTE+'"'," & ") From GOBJSUB
Endif
If DEVISE<>""
 Call ADDCRIT(FILTBAL,IFILTA,"CUR",' CUR="'+DEVISE+'"'," & ") From GOBJSUB
Endif

If TOUSITE=2
 For [FCY]FCY0 Where LEGCPY=SOCIETE & FINFLG=2
  SITBAL = [F:FCY]FCY
  Call DEBTRANS From GLOCK
  Gosub TR1
 Next
 SITBAL = ""
 Call DEBTRANS From GLOCK
 Gosub TR1
Else
 If SITE<>""
  SITBAL = SITE
 Else
  SITBAL = ""
 Endif
 Call DEBTRANS From GLOCK
 Gosub TR1
Endif
Return

$TR1
If TEST : Call ECR_TRACE(time$-"raz n"-SITBAL,0) From GESECRAN : Endif
GOK = 1
Trbegin [BLM]
Delete [BLM] Where evalue(FILTBAL) & FCY=SITBAL
If fstat=1
 GOK = -1 : GLOCK = "$BLACMM" : Goto ROLL_TR1
Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$ACCOUNT_AVAILABILITY
# Issue X3-107415 by MRDAB
If VALEUR = 2
  Actzo [M:DIA]COMPTE
Else
  Effzo [M:DIA]COMPTE
  Diszo [M:DIA]COMPTE
Endif

Affzo [M:DIA]COMPTE
# Issue X3-107415 end

Return

###################################################################################
###################################################################################
###################    Etiquette du masque          ###############################
###################################################################################
###################################################################################
########################################
Subprog AM_SOCIETE(VALEUR)
Variable Char VALEUR
GSOCIETE = VALEUR
Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Filter [FIY] Where CPY=VALEUR & LEDTYP=GTYPANA & FIYSTA=2
Read [FIY]FIY0 First
Filter [FIY]
[M]EXERCICE = [F:FIY]FIYNUM
[M]DATDEB   = [F:FIY]FIYSTR
[M]DATFIN   = [F:FIY]FIYEND
If !GIMPORT
 Affzo EXERCICE, DATDEB, DATFIN
Endif
End

########################################
Subprog AS_TOUSITE(VALEUR)
Variable Integer  VALEUR
Call INIALLFCY(VALEUR,[M]SOCIETE) From CPTTRT
End

Subprog AS_SITE(VALEUR)
Variable Char VALEUR
If [M]TOUSITE = 2 : VALEUR = "" : mkstat = 1 : End : Endif
End

########################################
Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Call LEDTYP_CHOICE([M:DIA]SOCIETE,5) From CPTDIV
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Char LED(GLONLED),DEV(GLONCUR)
Local Integer ILED
Call LECLED([M:DIA]SOCIETE,VALEUR,LED,DEV) From CPTDIV
ILED = find(LED,GLED(1..GLEDNBR))
If !ILED : End : Endif
[M:DIA]COA = GLEDCOA(ILED)
End

########################################
Subprog AS_EXERCICE(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 Filter [FIY] Where CPY=[M]SOCIETE & LEDTYP=GTYPANA & FIYSTA=2
 Read [FIY]FIY0 First
 Filter [FIY]
 VALEUR = [F:FIY]FIYNUM
 [M]DATDEB = [F:FIY]FIYSTR
 [M]DATFIN = [F:FIY]FIYEND
Endif
End

Subprog C_EXERCICE(VALEUR)
Variable Decimal VALEUR
Read [FIY]FIY0 = [M]SOCIETE;GTYPANA;VALEUR
If fstat
 GMESSAGE = mess(52,116,1) : mkstat = 2 : End    # Exercice incorrect
Endif
If [F:FIY]FIYSTA=1
 GMESSAGE=mess(20,101,1) : mkstat=2 : End : # Exercice non ouvert
Elsif [F:FIY]FIYSTA>2
 Local Integer OK
 OK = 1 : Call AVERTIR(mess(21,101,1),OK) From GESECRAN : # Exercice clôturé
 If OK<>2 : mkstat = 2 : End : Endif
Endif
[M]DATDEB = [F:FIY]FIYSTR
[M]DATFIN = [F:FIY]FIYEND
End

########################################
Subprog AM_BALANA(VALEUR)
Variable Integer VALEUR

# Issue X3-107415 By MRDAB
Gosub ACCOUNT_AVAILABILITY
# Issue X3-107415 end

End
########################################
Subprog D_BALANA(VALEUR)
Variable Integer VALEUR

# Issue X3-107415 by MRDAB
Gosub ACCOUNT_AVAILABILITY
# Issue X3-107415 end
End

