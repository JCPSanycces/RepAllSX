#<AdxTL>@(#)7.0.0.0 $Revision$
GBIDC2 = "ATABTAB"
GBIDC1 = ""
Call S_TAB_CHAR(GBIDC1,GBIDC2,"SELFLDTAB3","LNKSUB","") From GACTION
End

#------------------------------#
$ACTION
Case ACTION
 When "SEL_LISTE"
  Case LISTE
   When "SELTABLNK"  : Gosub S_TABLNK   : # Sélection d'une table liée à une autre
   When "SELTABLIS"  : Gosub S_TABLIS   : # Sélection d'une table parmi une liste de tables
   When "SELINDTAB"  : Gosub S_INDTAB   : # Sélection d'un index d'une table
   When "SELINDTAB2" : Gosub S_INDTAB2  : # Sélection d'un index d'une table (y compris index optimisation)
   When "SELFLDLNK"  : Gosub S_FLDLNK   : # Sélection d'un champ parmi les tables liées
  Endcase
 When "SEL_TABLE"
  Case TABLE
   When "SELFLDTAB1" : Gosub S_FLDTAB1  : # Sélection d'un champ parmi une table (sans AXX)
   When "SELFLDTAB2" : Gosub S_FLDTAB2  : # Sélection d'un champ parmi une liste de tables (sans AXX)
   When "SELFLDTAB3" : Gosub S_FLDTAB3  : # Sélection d'un champ parmi une table (avec AXX)
   When "SELFLDTAB6"  : Gosub S_FLDTAB6 : # sélection champ sans AXX, date , datetime, clob, blob
   When "SELCRITFLD" : Gosub S_CRITFLD  : # Sélection d'un champ pour critère (sans AXX)
   When "SELFLDMSK"  : Gosub S_FLDMSK   : # Sélection d'un champ d'un écran
   When "ASELLNK"    : Gosub S_ASELLNK
   When "ASELLNK2"   : Gosub S_ASELLNK2
   When "ASELLNK3"   : Gosub S_ASELLNK3
  Endcase
 When "FIN_TABLE"
  Case TABLE
   When "SELFLDTAB2"   : Gosub F_FLDTAB2
   When "SELCRITFLD"   : Gosub F_CRITFLD
   When "ASELLNK"      : Gosub F_ASELLNK
  Endcase
Endcase
Return

#------------------------------#
$S_TABLNK
Local Char    TEXTE(GLONDES)(1..dim(TEX),1..2)
Local Integer K
If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
Raz NBTEX
For [ATZ]CODZONE Where CODFIC=PARAM(1) & LIEN<>""
 K = 1
 If [F:ATZ]CODACT<>""
  Read [ACV]CODACT=[F:ATZ]CODACT
  If fstat | [F:ACV]FLACT<>2
   K = 0
  Endif
 Endif
 If K & !find([F:ATZ]LIEN,TEX(1..NBTEX)) & NBTEX<dim(TEX)
  NBTEX += 1
  Read [ATB]CODFIC = [F:ATZ]LIEN
  Call TEXTE([F:ATB]INTITFIC,TEXTE(NBTEX,2)) From OBJDIV
  TEX(NBTEX)   = [F:ATB]CODFIC
 Endif
Next
TIT    = mess(91,126,1) : # Choix d'une table liée
TIT(1) = mess(37,100,1) : # Code
TIT(2) = mess(30,109,1) : # Intitulé
Return

#------------------------------#
$S_INDTAB
Local Char TEXTE(120)(1..dim(TEX),1..3)
If clalev([F:ATI])=0 : Local File ATABIND [ATI] : Endif
Raz NBTEX
For [ATI] Where CODFIC=PARAM(1)
 If NBTEX<dim(TEX)
  NBTEX += 1
  TEXTE(NBTEX,2) = [F:ATI]DESCRIPT
  TEXTE(NBTEX,3) = string$([F:ATI]HOMONYM=1,mess(15,139,1)) : # Sans homonymes
  TEX(NBTEX)     = [F:ATI]CODIND
 Endif
Next
TIT    = mess(159,123,1) : # Choix d'une clé
TIT(1) = mess(37,100,1)  : # Code
TIT(2) = mess(188,139,1) : # Description
Return

#------------------------------#
$S_INDTAB2
Local Char TEXTE(120)(1..dim(TEX),1..3)
If clalev([F:ATI])=0 : Local File ATABIND [ATI] : Endif
If clalev([F:ANX])=0 : Local File AINDEX  [ANX] : Endif
Raz NBTEX
If PARAM(1)="" : Return : Endif
For [ATI] Where CODFIC=PARAM(1)
 If NBTEX<dim(TEX)
  NBTEX += 1
  TEXTE(NBTEX,2) = [F:ATI]DESCRIPT
  TEXTE(NBTEX,3) = string$([F:ATI]HOMONYM=1,mess(15,139,1)) : # Sans homonymes
  TEX(NBTEX)     = [F:ATI]CODIND
 Endif
Next
For [ANX]ANX1 Where TABLE=PARAM(1) & FLACT=2
 If NBTEX<dim(TEX)
  NBTEX += 1
  TEXTE(NBTEX,2) = [F:ANX]DESCRIPT
  TEXTE(NBTEX,3) = mess(187,139,1) : # Index spécifique
  TEX(NBTEX)     = [F:ANX]CODIND
 Endif
Next
TIT    = mess(159,123,1) : # Choix d'une clé
TIT(1) = mess(37,100,1)  : # Code
TIT(2) = mess(188,139,1) : # Description
Return

#------------------------------#
$S_FLDLNK
Local Char TEXTE(GLONDES)(1..dim(TEX),1..2)
Local Integer K
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
Raz NBTEX
For [ATZ]LIEN Where CODFIC=PARAM(1) & LIEN=PARAM(2)
 K = 1
 If [F:ATZ]CODACT<>""
  Read [ACV]CODACT=[F:ATZ]CODACT
  If fstat | [F:ACV]FLACT<>2
   K = 0
  Endif
 Endif
 If K & NBTEX<dim(TEX)
  NBTEX += 1
  Call TEXTE([F:ATZ]NOCOURT,TEXTE(NBTEX,2)) From OBJDIV
  TEX(NBTEX)   = [F:ATZ]CODZONE
 Endif
Next
TIT    = mess(49,105,1)  : # Choix zone
TIT(1) = mess(37,100,1)  : # Code
TIT(2) = mess(30,109,1)  : # Intitulé
Return

#------------------------------#
$S_TABLIS
Local Char    TABLE(GLONATB) , ABREV(GLONABR)
Local Char    TEXTE(GLONDES)(1..dim(TEX),1..3)
Local Char    WPARAM(20)
Local Integer WDIME
If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
WDIME = evalue('dim('+PARAM(1)+')')
For I=0 To WDIME-1
 WPARAM = PARAM(1)+'('+num$(I)+')'
 TABLE = evalue(WPARAM)
 If TABLE="" : Break : Endif
 NBTEX += 1
 Read [ATB]CODFIC = TABLE
 Call TEXTE([F:ATB]INTITFIC,TEXTE(NBTEX,3)) From OBJDIV
 WPARAM = PARAM(2)+'('+num$(I)+')'
 ABREV = evalue(WPARAM)
 If ABREV=""
  ABREV = [F:ATB]ABRFIC
 Endif
 TEX(NBTEX)     = TABLE
 TEXTE(NBTEX,2) = ABREV
Next I
TIT    = mess(151,123,1) : # Choix d'une table
TIT(1) = mess(37,100,1)  : # Code
TIT(2) = mess(180,115,1) : # Abréviation
TIT(3) = mess(30,109,1)  : # Intitulé
Return

#------------------------------#
$S_FLDTAB1
OBJET = "ATZ"
OPTIONS = "|"
If PARAM(1)<>""
 CRITERE  = 'CODFIC = "'+PARAM(1)+'"'
 ORDRE = 'CODZONE'
Else
 CRITERE = '1=1'
 ORDRE = 'CODFIC;CODZONE'
Endif
CRITERE += '& [F:ATY]TYPTYP<9 & find(CODTYP,"AXX","AX1","AX2","AX3")=0'
CRITERE += '& ([F:ATZ]CODACT="" | [F:ACV]FLACT=2)'
START = 'CODZONE'
Return

#------------------------------#
$S_FLDTAB2
Local Char    CRITERE(250)(0..2)
Local Char    WPARAM(20), WVALZON(255), WABR(GLONABR)
Local Integer WDIME , ICRITERE
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
If clalev([F:ATI])=0 : Local File ATABIND [ATI] : Endif
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
WDIME = evalue('dim('+PARAM(1)+')')
For I=0 To WDIME-1
 WPARAM = PARAM(1)+'('+num$(I)+')'
 If evalue(WPARAM)<>""
  If CRITERE=""
   CRITERE = "("
  Elsif CRITERE<>""
   CRITERE -= "|"
  Endif
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'CODFIC="'+evalue(WPARAM)+'"',"") From GOBJSUB
  If CRITERE="" : Break : Endif
 Endif
Next I
If CRITERE<>""
 CRITERE -= ")"
Endif
Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:ATY]TYPTYP<9',"&") From GOBJSUB
Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'find(CODTYP,"AXX","AX1","AX2","AX3")=0',"&") From GOBJSUB
Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:ATZ]CODACT="" | [F:ACV]FLACT=2)',"&") From GOBJSUB
OBJET = "ATZ"
START = "CODFIC"
OPTIONS = "|"
WVALZON = VALEUR
VALEUR = ""
Return

#------------------------------#
$S_FLDTAB6
OBJET = "ATZ"
OPTIONS = "|"
If PARAM(1)<>""
 CRITERE  = 'CODFIC = "'+PARAM(1)+'"'
 ORDRE = 'CODZONE'
Else
 CRITERE = '1=1'
 ORDRE = 'CODFIC;CODZONE'
Endif
CRITERE += '& [F:ATY]TYPTYP<8 & find(CODTYP,"AXX","AX1","AX2","AX3")=0'
CRITERE += '& ([F:ATZ]CODACT="" | [F:ACV]FLACT=2)'
START = 'CODZONE'
Return


#------------#
$F_FLDTAB2
If VALEUR<>""
 VALEUR = WVALZON
 If dim(PARAM)>1 & PARAM(2)<>""
  I = evalue('find("'+[F:ATZ]CODFIC+'",'+PARAM(1)+'(0..'+num$(WDIME-1)+'))')
  If I : WABR = evalue(PARAM(2)+"("+num$(I-1)+")") : Endif
 Endif
 If WABR=""
  Read [ATB]CODFIC = [F:ATZ]CODFIC
  WABR = [F:ATB]ABRFIC
 Endif
 If VALEUR<>"" : VALEUR += ";" : Endif
 VALEUR += "[F:"+WABR+"]"+[F:ATZ]CODZONE
Else
 VALEUR = WVALZON
Endif
mkstat = 2
Return

#------------------------------#
$S_FLDTAB3
OBJET = "ATZ"
OPTIONS = "|"
ORDRE = "CODZONE"
CRITERE  = 'CODFIC = "'+PARAM(1)+'"'
CRITERE += '& ([F:ATZ]CODACT="" | [F:ACV]FLACT=2)'
START = 'CODZONE'
Return

#------------------------------#
$S_FLDMSK
OBJET = "AMZ"
OPTIONS = "|"
ORDRE = "CODZON"
CRITERE  = 'CODMSK = "'+PARAM(1)+'"'
CRITERE += '& [F:ATY]TYPTYP<9 & find(CODTYP,"AXX","AX1","AX2","AX3")=0'
START = 'CODZON'
Return

#------------------------------#
$S_CRITFLD
Local Char WVALZON(255)
If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
If clalev([F:ATI])=0 : Local File ATABIND [ATI] : Endif
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
OBJET = "ATZ"
OPTIONS = "|"
ORDRE = "CODZONE"
CRITERE  = 'CODFIC = "'+PARAM(1)+'"'
CRITERE += '& [F:ATY]TYPTYP<9 & find(CODTYP,"AXX","AX1","AX2","AX3")=0'
CRITERE += '& ([F:ATZ]CODACT="" | [F:ACV]FLACT=2)'
START = 'CODZONE'
WVALZON = VALEUR
VALEUR = ""
Return

#-----------#
$F_CRITFLD
If VALEUR<>""
 VALEUR = WVALZON
 Read [ATB]CODFIC = [F:ATZ]CODFIC
 VALEUR += "[F:"+[F:ATB]ABRFIC+"]"+[F:ATZ]CODZONE
Endif
mkstat = 2
Return

#------------------------------------------------------------------#
# Sous-programmes contrôles de liens saisis
#------------------------------------------------------------------#

Subprog CONTROLE(TABLE,EXPR)
Value    Char TABLE
Variable Char EXPR()
Local Char    IND(20)
OPT = 1
IND = ""
Goto CONTROL

#------------------------------------------------------------------#
Subprog CONTROLE_IND(TABLE,IND,EXPR)
Value    Char    TABLE   : # Table lue
Value    Char    IND     : # Index de la table lue
Variable Char    EXPR()
Local Integer OPT
OPT = 1
Goto CONTROL

#------------------------------------------------------------------#
Subprog CONTROLE_ABR(TAB,ABR,ORI,TABLE,IND,OPT,EXPR)
Value    Char    TAB()   : # Tables liées utilisées dans l'expression
Value    Char    ABR()   : # Abréviation des tables liées utilisées dans l'expression
Value    Char    ORI     : # Table des champs utilisée dans l'expression
Value    Char    TABLE   : # Table lue
Value    Char    IND     : # Index de la table lue
Value    Integer OPT     : # 1->0,1 2->0,n 3->1,1 4->1,n
Variable Char    EXPR()

#------------#
$CONTROL
If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ATI])=0 : Local File ATABIND [ATI] : Endif
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
EXPR = toupper(EXPR)
Local Char    CHAINE(250) , CHAMP(30) , ABREV(10)
Local Integer NBCLE , NBCMP
Local Integer I , J , K , OK
OK = 1
NBCLE = 0
If IND<>""
 Read [ATI]CODIND = TABLE;IND
Else
 Read [ATI]NUMLIG(2) = TABLE;1
Endif
CHAINE = [F:ATI]DESCRIPT
Repeat
 NBCLE += 1
 I = instr(1,CHAINE,"+")
 J = instr(1,CHAINE,"-")
 If    I & J  : I = min(I,J)
 Elsif J & !I : I = J
 Endif
 If I : CHAINE = right$(CHAINE,I+1) : Else : CHAINE = "" : Endif
Until CHAINE = ""
NBCMP = 0
CHAINE = EXPR
Repeat
 NBCMP += 1
 I = instr(1,CHAINE,";")
 If I
  CHAMP  = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CHAMP  = CHAINE
  CHAINE = ""
 Endif
 If left$(CHAMP,3)<>"[F]" & left$(CHAMP,1)="[" & !instr(1,CHAMP,"/")
  I = instr(1,CHAMP,"]")
  If I=0 : OK = 0 : Break : Endif
  ABREV = seg$(CHAMP,2,I-1)
  CHAMP = right$(CHAMP,I+1)
  If left$(ABREV,2) = "F:"
   ABREV = right$(ABREV,3)
  Endif
  If !find(ABREV,"L","V")
   If dim([L]ABR)>0
    I = find(ABREV,[L]ABR)
    If I
     Read [ATB]CODFIC = [L]TAB(I-1)
    Else
     GMESSAGE = ABREV-":"-mess(124,124,1) : # Table inexistante
     OK = 0 : Break
    Endif
   Else
    Read [ATB]ABRFIC = ABREV
   Endif
   If fstat
    GMESSAGE = ABREV-":"-mess(124,124,1) : # Table inexistante
    OK = 0 : Break
   Endif
   I = instr(1,CHAMP,"(")
   If I : CHAMP = left$(CHAMP,I-1) : Endif
   Read [ATZ]CODZONE = [F:ATB]CODFIC;CHAMP
   If fstat
    GMESSAGE = "[F:"+ABREV+"]"+CHAMP-":"-mess(41,100,1) : # Champ inexistant
    OK = 0 : Break
   Else
    K = 1
    If [F:ATZ]CODACT<>""
     Read [ACV]CODACT=[F:ATZ]CODACT
     If fstat | [F:ACV]FLACT<>2
      K = 0
     Endif
    Endif
    If !K
     GMESSAGE = "[F:"+ABREV+"]"+CHAMP-":"-[F:ATZ]CODACT-mess(24,176,1) : # Code activité inactif
     OK = 0 : Break
    Endif
   Endif
  Endif
 Elsif dim([L]TAB)>0 | (dim([L]ORI)>0 & ORI<>"")
  I = instr(1,CHAMP,"]")
  If I : CHAMP = right$(CHAMP,I+1) : Endif
  I = instr(1,CHAMP,"(")
  If I : CHAMP = right$(CHAMP,I-1) : Endif
  If format$("KTv2:A9u",CHAMP)=CHAMP & evalue("dim([V]"+CHAMP+")")<0
   K = 0
   If ORI<>""
    Read [ATB]CODFIC = ORI
    Read [ATZ]CODZONE = ORI;CHAMP
    If !fstat
     K = 1
     If [F:ATZ]CODACT<>""
      Read [ACV]CODACT=[F:ATZ]CODACT
      If fstat | [F:ACV]FLACT<>2
       K = 0
      Endif
     Endif
    Endif
    If !K
     GMESSAGE = "[F:"+ORI+"]"+CHAMP-":"-mess(41,100,1) : # Champ inexistant
     OK = 0 : Break
    Endif
   Else
    For I=0 To dim([L]TAB)-1
     If [L]TAB(I)<>""
      Read [ATB]CODFIC = [L]TAB(I)
      Read [ATZ]CODZONE = [L]TAB(I);CHAMP
      If !fstat
       K = 1
       If [F:ATZ]CODACT<>""
        Read [ACV]CODACT=[F:ATZ]CODACT
        If fstat | [F:ACV]FLACT<>2
         K = 0
        Endif
       Endif
      Endif
     Endif
    Next I
    If !K
     GMESSAGE = CHAMP-":"-mess(41,100,1) : # Champ inexistant
     OK = 0 : Break
    Endif
   Endif
  Endif
 Endif
Until CHAINE=""
If !OK
 If GMESSAGE = "" : GMESSAGE = mess(101,123,1) : Endif : # Expression de lien incorrecte
 mkstat = 2 : End
Endif
If (find(OPT,1,3) & NBCMP<>NBCLE) | (find(OPT,2,4) & NBCMP>NBCLE)
 GMESSAGE = mess(101,123,1) : # Expression de lien incorrecte
 mkstat = 2 : End
Endif
End

#------------------------------------------------------------------#
# Contrôle de l'existence d'un champ
#------------------------------------------------------------------#

#---------------------------------------------#
Subprog CONTROLE_FLD(TAB,ABR,FLD)
Value    Char    TAB()
Value    Char    ABR()
Value    Char    FLD
If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ATI])=0 : Local File ATABIND [ATI] : Endif
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
Local Char ZONE(GLONAVA) , ABREV(GLONABR) , CHAINE(30)
Local Integer I , J , K
CHAINE = toupper(FLD)
I = instr(1,CHAINE,"[")
J = instr(1,CHAINE,"]")
Raz ZONE , ABREV
If I & J
 K = instr(1,CHAINE,":")
 If K
  ABREV = seg$(CHAINE,K+1,J-1)
 Else
  ABREV = seg$(CHAINE,I+1,J-1)
 Endif
 CHAINE = right$(CHAINE,J+1)
Endif
K = instr(1,CHAINE,"(")
If K
 ZONE = left$(CHAINE,K-1)
Else
 ZONE = CHAINE
Endif
If ABREV="" | ABREV="F"
 If TAB<>""
  Filter [ATZ] Where CODZONE=ZONE & find(CODFIC,TAB)<>0
  Read [ATZ] First
  Filter [ATZ]
 Else
  Filter [ATZ] Where CODZONE=ZONE
  Read [ATZ] First
  Filter [ATZ]
 Endif
Elsif ABR=""
 Read [ATB]ABRFIC = ABREV
 If fstat
  GMESSAGE = ABREV-":"-mess(124,124,1) : # Table inexistante
  mkstat = 2 : End
 Else
  Filter [ATZ] Where CODZONE=ZONE & CODFIC=[F:ATB]CODFIC
  Read [ATZ] First
  Filter [ATZ]
 Endif
Else
 K = find(ABREV,ABR)
 If K
  Filter [ATZ] Where CODZONE=ZONE & CODFIC=TAB(K-1)
  Read [ATZ] First
  Filter [ATZ]
 Else
  GMESSAGE = ABREV-":"-mess(93,139,1) : # Table non référencée
  mkstat = 2 : End
 Endif
Endif
If fstat
 GMESSAGE = ""
 If ABREV<>""
  GMESSAGE = "["+ABREV+"]"
 Endif
 GMESSAGE += ZONE-":"-mess(22,124,1) : # Zone inexistante
 mkstat = 2 : End
Endif
K = 1
If [F:ATZ]CODACT<>""
 Read [ACV]CODACT=[F:ATZ]CODACT
 If fstat | [F:ACV]FLACT<>2
  K = 0
 Endif
Endif
If !K
 GMESSAGE = ""
 If ABREV<>""
  GMESSAGE = "["+ABREV+"]"
 Endif
 GMESSAGE += ZONE-":"-[F:ATZ]CODACT-mess(24,176,1) : # Code activité inactif
 mkstat = 2 : End
Endif
End

#---------------------------------------------------------------#
# Action CTLINDTAB2
#---------------------------------------------------------------#

Subprog CTLINDTAB2(VALEUR,NOMFIC)
Value Char VALEUR, NOMFIC
Local Integer OK , K
If VALEUR="" or NOMFIC="" : End : Endif

If clalev([M:ATB4])>0 & clalev([M:ATB3])>0
 OK = find(VALEUR,[M:ATB3]CODIND)
Else
 If clalev([F:ATI])=0 : Local File ATABIND [ATI] : Endif
 If clalev([F:ANX])=0 : Local File AINDEX  [ANX] : Endif
 OK = 0
 For [ATI] Where CODFIC=[L]NOMFIC
  If VALEUR=[F:ATI]CODIND
   OK = 1 : Break
  Endif
 Next
 If !OK
  For [ANX]ANX1 Where TABLE=[L]NOMFIC & FLACT=2
   If VALEUR=[F:ANX]CODIND
    OK = 1 : Break
   Endif
  Next
 Endif
Endif
If !OK
 GMESSAGE = VALEUR-":"-mess(6,114,1) : # Clé inexistante
 mkstat = 2
Endif
End

Funprog CTLINDTAB2_SYR(AINSTANCE,APRONAME, AVALUE, NOMFIC)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char NOMFIC

Local Integer OK , K, L_STA
If AVALUE="" or NOMFIC="" : End 0 : Endif

If clalev([F:ATI])=0 : Local File ATABIND [ATI] : Endif
If clalev([F:ANX])=0 : Local File AINDEX  [ANX] : Endif
OK = 0
For [ATI] Where CODFIC=[L]NOMFIC
 If AVALUE=[F:ATI]CODIND
  OK = 1 : Break
 Endif
Next
If !OK
 For [ANX]ANX1 Where TABLE=[L]NOMFIC & FLACT=2
  If AVALUE=[F:ANX]CODIND
   OK = 1 : Break
  Endif
 Next
Endif
If !OK
 L_STA = fmet AINSTANCE.ASETERROR(APRONAME,AVALUE-":"-mess(6,114,1),[V]CST_AERROR) # Clé inexistante
 End [V]CST_AERROR
Endif

End 0

#------------------------------------------------------------------#
# Sous-programmes utilisés dans les actions sur type de donnée LNK
#------------------------------------------------------------------#

Subprog AS_LNK(VALEUR)
Variable Char    VALEUR()
GBOUT1 = mess(16,125,1)  : # Tables
GBOUT2 = mess(159,123,1) : # index
GBOUT3 = mess(149,123,1) : # Champs
End

#--------------------------------#
Subprog B1_LNK(VALEUR,NB,LISTBL)
Variable Char    VALEUR()
Value    Integer NB
Variable Char    LISTBL()(1..)
Local Integer I
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "LNKB1"
PARMSK(1) = num$(NB)
For I=1 To NB
 PARMSK(I+1) = LISTBL(I)
Next I
Call S_TAB_CHAR(VALEUR,PARMSK,"ASELLNK","LNKSUB","") From GACTION
GACTION = SAVACT
End

$S_ASELLNK
Local Char    CRITERE(250)(0..2), WPARAM(20)
Local Integer ICRITERE
For I=2 To val(PARAM(1))+1
 WPARAM = PARAM(I)
 If WPARAM<>""
  If CRITERE=""
   CRITERE = "("
  Elsif CRITERE<>""
   CRITERE -= "|"
  Endif
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'CODFIC="'+WPARAM+'"',"") From GOBJSUB
  If CRITERE="" : Break : Endif
 Endif
Next I
If CRITERE<>""
 CRITERE -= ")"
Endif
If filinfo(filpath("FIL","AVIEWFLD","fde"),0)<0
 OBJET = "ATB"
 Return
Endif
Local Char    SELFMT(30)(0..16)
If clalev([ATX])=0 : Local File ATEXTE [ATX] : Endif
Local File AVIEWTAB [AVT]
Link [AVT] With
& [ATX]NUMERO=GLANGUE;[F:AVT]INTITFIC
& As [AVT_]
NBCOL = 0
For ZON="CODFIC","INTITFIC","ABRFIC","COMFIC","CODACT","MODULE"
 Case ZON
  When "MODULE"
   NBCOL += 1
   COL(NBCOL) = "mess([F:AVT]MODULE,14,1)"
   COLTYP(NBCOL) = 40
   Call TITZON("AVIEWTAB",ZON,TIT(NBCOL)) From CONTOBJ
  When "INTITFIC"
   NBCOL += 1
   COL(NBCOL) = "[F:ATX]TEXTE"
   COLTYP(NBCOL) = 40
   Call TITZON("AVIEWTAB",ZON,TIT(NBCOL)) From CONTOBJ
  When Default
   NBCOL += 1
   COL(NBCOL) = "[F:AVT]"+ZON
   COLTYP(NBCOL) = evalue("type([F:AVT]"+ZON+")")
   Call TITZON("AVIEWTAB",ZON,TIT(NBCOL)) From CONTOBJ
 Endcase
Next ZON
TIT = mess(142,139,1) : # Sélection d'une table ou d'une vue
Default File [AVT_]
DEFPAG = 1
START = "CODFIC"
Return

$F_ASELLNK
If VALEUR<> ""
 Local Char    NEWTAB(GLONATB)
 Gosub OUVFIC_VUE
 NEWTAB = VALEUR
 Gosub DECODE_LNK
 Read [ATB]CODFIC = NEWTAB
 ABREV = [F:ATB]ABRFIC
 If CLE=""
  Read [ATI]NUMLIG(2) = NEWTAB;1
  CLE = [F:ATI]CODIND
 Endif
 Gosub CODE_LNK
Endif
Return

$OUVFIC_VUE
 If find(GFONCTION,"GESALH","GESALT")
& and filinfo(filpath("FIL","AVIEWTAB","fde"),0)>0
& and filinfo(filpath("FIL","AVIEWFLD","fde"),0)>0
& and filinfo(filpath("FIL","AVIEWIND","fde"),0)>0
  If clalev([F:ATB])=0 : Local File AVIEWTAB  [ATB]  : Endif
  If clalev([F:AVWF])=0 : Local File AVIEWFLD [AVWF] : Endif
  If clalev([F:ATI])=0 : Local File AVIEWIND  [ATI]  : Endif
 Else
  If clalev([F:ATB])=0 : Local File ATABLE   [ATB]  : Endif
  If clalev([F:AVWF])=0 : Local File ATABZON [AVWF] : Endif
  If clalev([F:ATI])=0 : Local File ATABIND  [ATI]  : Endif
 Endif
Return

#--------------------------------#
Subprog B2_LNK(VALEUR)
Variable Char    VALEUR()
Gosub OUVFIC_VUE
Gosub DECODE_LNK
Local Char  CRITERE(250)(1..3)
If ABREV="" or TABLE="" : End : Endif
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "LNKB1"
PARMSK(1) = "(CODFIC ='"+TABLE+"')"
Call S_TAB_CHAR(CLE,PARMSK,"ASELLNK2","LNKSUB","") From GACTION
GACTION = SAVACT
If CLE = ""
 Filter [ATI] Where CODFIC = TABLE
 Read [ATI]First
 Filter [ATI]
 CLE = [F:ATI]CODIND
Endif
Gosub CODE_LNK
End

$S_ASELLNK2
Local Char    CRITERE(250)(0..2), WPARAM(20)
CRITERE(0) = PARAM(1)
If filinfo(filpath("FIL","AVIEWFLD","fde"),0)<0
 OBJET = "ATI"
 Return
Endif
NBCOL = 0
For ZON="CODIND","CODFIC","DESCRIPT","CODACT","NUMLIG"
 Case ZON
  When Default
   NBCOL += 1
   COL(NBCOL) = "[F:ATI]"+ZON
   COLTYP(NBCOL) = evalue("type([F:ATI]"+ZON+")")
   Call TITZON("AVIEWIND",ZON,TIT(NBCOL)) From CONTOBJ
 Endcase
Next ZON
TIT = mess(159,123,1) : # index
Default File [ATI]
DEFPAG = 1
Return

#--------------------------------#
Subprog B3_LNK(VALEUR,NB,LISTBL)
Variable Char    VALEUR()
Value    Integer NB
Variable Char    LISTBL()(1..)
Local Integer I , NBTBL , ICRITERE
Local Char    NEWCHAMP(30) , TBTBL(GLONATB)(1..30) , CRITERE(250)(1..3) , SEP(1)
Gosub OUVFIC_VUE
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif
Link [AVWF] With
& [ATX]NUMERO=GLANGUE;NOCOURT,
& [ACV]CODACT=[F:AVWF]CODACT,
& [ATY]CODTYP=[F:AVWF]CODTYP
& As [VVD_]
Gosub DECODE_LNK
NBTBL = 0
For I=1 To NB
 If LISTBL(I)<>TABLE & !find(LISTBL(I),TBTBL(1..NBTBL)) & NBTBL<dim(TBTBL)
  NBTBL += 1
  TBTBL(NBTBL) = LISTBL(I)
 Endif
Next I
Raz CRITERE , ICRITERE , SEP
Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'(',"&") From GOBJSUB
If TABLE<>""
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'CODFIC="'+TABLE+'"',"") From GOBJSUB
 SEP = "|"
Endif
For I=1 To NBTBL
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'CODFIC="'+TBTBL(I)+'"',SEP) From GOBJSUB
 If SEP="" : SEP = "|" : Endif
Next I
Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",')',"") From GOBJSUB
If SEP="" : CRITERE = "1=1" : Endif
Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:AVWF]CODACT="" | [F:ACV]FLACT=2)',"&") From GOBJSUB
#### GACTION SEL TABLE
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "LNKB1"
For I=1 To 3
 PARMSK(I) = CRITERE(I)
Next I
Call S_TAB_CHAR(NEWCHAMP,PARMSK,"ASELLNK3","LNKSUB","") From GACTION
GACTION = SAVACT
If  NEWCHAMP <> ""
 Read [ATB]CODFIC = [F:AVWF]CODFIC
 If NEWCHAMP<>""
  For I=1 To NBCHP+1
   If CHAMP(I)=""
    CHAMP(I) = "[F:"+[F:ATB]ABRFIC+"]"+[F:AVWF]CODZONE
    Break
   Endif
  Next I
  Gosub CODE_LNK
 Endif
Endif
End

$S_ASELLNK3
Local Char    CRITERE(250)(0..2), WPARAM(20)
Local Integer ICRITERE
For I=1 To 3
 CRITERE(I-1) = PARAM(I)
Next I
If filinfo(filpath("FIL","AVIEWFLD","fde"),0)<0
 OBJET = "ATB"
 Return
Endif
NBCOL = 0
For ZON="CODFIC","CODZONE","NOCOURT","CODTYP","LONG","DIME","NUMLIG"
 Case ZON
  When "NOCOURT"
   NBCOL += 1
   COL(NBCOL) = "[F:ATX]TEXTE"
   COLTYP(NBCOL) = 40
   Call TITZON("AVIEWFLD",ZON,TIT(NBCOL)) From CONTOBJ
  When Default
   NBCOL += 1
   COL(NBCOL) = "[F:AVWF]"+ZON
   COLTYP(NBCOL) = evalue("type([F:AVWF]"+ZON+")")
   Call TITZON("AVIEWFLD",ZON,TIT(NBCOL)) From CONTOBJ
   If ZON =" DIME" : SELEXP(NBCOL) = "max([F:AVWF]DIME,[F:ACV]DIME)" : Endif
   If ZON = "LONG" : FMTCOL(NBCOL) = "N+z:5F" : Endif
 Endcase
Next ZON
TIT = mess(280,139,1) : # Sélection d'un champ d'une table ou d'une vue
Default File [VVD_]
DEFPAG = 1
Return

#--------------------------------#
Subprog C_LNK(VALEUR)
Variable Char    VALEUR()
Local Integer OK , K ,KO
Local Char    ABR(GLONABR) , MESSA(80) , CHP(50)
If VALEUR="" : End : Endif
Gosub OUVFIC_VUE
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
VALEUR = toupper(VALEUR)
OK = 1
Gosub DECODE_LNK
If ABREV="" or TABLE="" or CLE=""
 If TABLE="" & ABREV<>""
  MESSA = ABREV-":"-mess(124,124,1) : # Table inexistante
 Endif
 Gosub CODE_LNK
 OK = 0
Elsif STRICT & NBLEC
 OK = 0
Else
 Gosub CODE_LNK
 For I=1 To NBCHP
  If CHAMP(I)=""
   OK = 0 : Break
  Else
   If left$(CHAMP(I),1)="["
    K = instr(1,CHAMP(I),"]")
    If K
     CHAINE = seg$(CHAMP(I),2,K-1)
     If instr(1,CHAINE,"/")
      ABR = ""
     Else
      If left$(CHAINE,2)="F:"
       ABR = right$(CHAINE,3)
      Else
       ABR = CHAINE
      Endif
      CHP = right$(CHAMP(I),K+1)
      If GFONCTION="GESALH" & dim([M:ALH1]NBLIG)>0
       KO = 1
       For II=0 To [M:ALH1]NBLIG-1
        Read [ATB]CODFIC = [M:ALH1]TBL(II)
        If [F:ATB]ABRFIC = ABR
         KO = 0
         Break
        Endif
       Next II
       If KO = 1
        Read [ATB]ABRFIC = ABR
       Endif
      Else
       Read [ATB]ABRFIC = ABR
      Endif
      If fstat
       MESSA = ABR-":"-mess(124,124,1) : OK = 0 : Break : # Table inexistante
      Endif
      K = instr(1,CHP,"(")
      If K : CHP = left$(CHP,K-1) : Endif
      Read [AVWF]CODZONE = [F:ATB]CODFIC;CHP
      If fstat
       MESSA = CHP-":"-mess(41,100,1) : OK = 0 : Break : # Champ inexistant
      Else
       K = 1
       If [F:AVWF]CODACT<>""
        Read [ACV]CODACT=[F:AVWF]CODACT
        If fstat | [F:ACV]FLACT<>2
         K = 0
        Endif
       Endif
       If !K
        MESSA = CHP-":"-[F:AVWF]CODACT-mess(24,176,1) : OK = 0 : Break : # Code activité inactif
       Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Next I
Endif
If !OK
 GMESSAGE = mess(101,123,1) : # Expression de lien incorrecte
 If MESSA<>"" : GMESSAGE += "\"+MESSA : Endif
 mkstat = 2 : End
Endif
End

#------------------#
$DECODE_LNK
Local Integer I , J , K , NBCHP , STRICT , NBLEC
Local Char    CHAINE(250) , CH1(250) , CH2(250) , TABLE(GLONATB)
Local Char    ABREV(GLONABR) , CLE(GLONANX) , CHAMP(50)(1..30)
I = instr(1,VALEUR,"=")
STRICT = 0
If I
 If mid$(VALEUR,I-1,1)="~"
  STRICT = 1
  CH1 = vireblc(left$(VALEUR,I-2),2)
  CH2 = vireblc(right$(VALEUR,I+1),2)
 Else
  CH1 = vireblc(left$(VALEUR,I-1),2)
  CH2 = vireblc(right$(VALEUR,I+1),2)
 Endif
Else
 CH1 = vireblc(VALEUR,2)
 CH2 = ""
Endif
If left$(CH1,1)="["
 J = instr(1,CH1,"]")
 If J
  CHAINE = seg$(CH1,2,J-1)
  If instr(1,CHAINE,"/")
   ABREV = ""
  Else
   If left$(CHAINE,2)="F:"
    ABREV = right$(CHAINE,3)
   Else
    ABREV = CHAINE
   Endif
   CLE = right$(CH1,J+1)
  Endif
 Endif
Endif
NBLEC = 0
I = instr(1,CLE,"(")
If I
 NBLEC = val(right$(CLE,I+1))
 CLE = left$(CLE,I-1)
Endif
NBCHP = 0
Repeat
 If NBCHP>=dim(CHAMP)
  Break
 Endif
 NBCHP += 1
 J = instr(1,CH2,";")
 If J
  CHAMP(NBCHP) = vireblc(left$(CH2,J-1),2)
  CH2 = right$(CH2,J+1)
 Else
  CHAMP(NBCHP) = vireblc(CH2,2)
  CH2 = ""
 Endif
Until CH2=""
Read [ATB]ABRFIC = ABREV
If !fstat : TABLE = [F:ATB]CODFIC : Else : TABLE = "" : Endif
If TABLE<>"" & CLE<>""
 Read [ATI]CODIND = TABLE;CLE
 If fstat : CLE = "" : Endif
Endif
If TABLE<>"" & CLE = ""
 Read [ATI]NUMLIG(2) = TABLE;1
 CLE = [F:ATI]CODIND
Endif
Return

#------------#
$CODE_LNK
Read [ATB]ABRFIC = ABREV
If !fstat
 Read [ATI]CODIND = [F:ATB]CODFIC;CLE
 If !fstat
  CHAINE = [F:ATI]DESCRIPT
  NBCHP = 0
  Repeat
   NBCHP += 1
   I = instr(1,CHAINE,"+")
   J = instr(1,CHAINE,"-")
   If    I & J  : I = min(I,J)
   Elsif J & !I : I = J
   Endif
   If I
    CHAINE = right$(CHAINE,I+1)
   Else
    CHAINE = ""
   Endif
  Until CHAINE = ""
 Endif
Endif
VALEUR = "[F:"+ABREV+"]"+CLE
If NBLEC<>0
 VALEUR += "("+num$(NBLEC)+")"
Endif
If STRICT
 VALEUR += " ~= "
Else
 VALEUR += " = "
Endif
If NBLEC<>0
 NBCHP = NBLEC
Endif
For K=1 To NBCHP
 If K<>1
  VALEUR += " ; "
 Endif
 VALEUR += CHAMP(K)
Next K
Return

#---------------------------------------#
Subprog SETCLE(NBCLE,CLE,CHAINE)
Variable Integer NBCLE
Variable Char    CLE()(1..)
Value    Char    CHAINE
Local Integer I , J
Raz CLE, NBCLE
While CHAINE<>""
 I = instr(1,CHAINE,"+")
 J = instr(1,CHAINE,"-")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 NBCLE += 1
 If I
  CLE(NBCLE) = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
Wend
End

#---------------------------------------#
Subprog SETCLEORDER(NBCLE,CLE,ORD,CHAINE)
Variable Integer NBCLE
Variable Char    CLE()(1..)
Variable Char    ORD()(1..)
Value    Char    CHAINE
Local Integer I , J
Raz CLE, NBCLE
While CHAINE<>""
 I = instr(1,CHAINE,"+")
 J = instr(1,CHAINE,"-")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 NBCLE += 1
 If I
  CLE(NBCLE) = left$(CHAINE,I-1)
  If mid$(CHAINE,I,1) = "+"
   ORD(NBCLE+1) = " asc"
  Elsif mid$(CHAINE,I,1) = "-"
   ORD(NBCLE+1) = " desc"
  Endif
  CHAINE = right$(CHAINE,I+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
Wend
If ORD(1)="" and CLE(1)=""
 Dela 1,1 CLE,ORD
 NBCLE -=1
Endif
End

