#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMTACT0B 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone EXTQTY
mkstat = 0
zoncou = "EXTQTY"
indice = 0
WNUM = [M]EXTQTY
If varmode([M]EXTQTY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EXTQTY" : Gosub ACTION From =IMPTRT
 Endif
 If [M]EXTQTY<0
  mkstat = 1 : GMESSAGE = mess(180,141,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "EXTQTY" : GZNUM = 32576 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>[M]EXTQTY or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_EXTQTY([M]EXTQTY) From SUBPJTAC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "EXTQTY" : GZNUM = 32576 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone RMNQTY
mkstat = 0
zoncou = "RMNQTY"
indice = 0
WNUM = [M]RMNQTY
If varmode([M]RMNQTY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "RMNQTY" : Gosub ACTION From =IMPTRT
 Endif
 If [M]RMNQTY<0
  mkstat = 1 : GMESSAGE = mess(180,141,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "RMNQTY" : GZNUM = 42118 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>[M]RMNQTY or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_RMNQTY([M]RMNQTY) From SUBPJTAC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "RMNQTY" : GZNUM = 42118 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone OPEUOM2
mkstat = 0
zoncou = "OPEUOM2"
indice = 0
WCHAR = [M]OPEUOM2
If varmode([M]OPEUOM2,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPEUOM2" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]OPEUOM2,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "OPEUOM2" : GZNUM = 2685 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("TUN","B",[M]OPEUOM2,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "OPEUOM2" : GZNUM = 2685 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]OPEUOM2 or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_OPEUOM2([M]OPEUOM2) From SUBPJTAC
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "OPEUOM2" : GZNUM = 2685 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone OPECST
mkstat = 0
zoncou = "OPECST"
indice = 0
SAVACT = GACTION : GACTION = "INIDEV"
GACTION = SAVACT
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PJTAC0B]CUR,GDEVISE(1..GNBDEV)),1))
If mkstat=1 : Raz [M]OPECST : Endif

## Zone OPECST2
mkstat = 0
zoncou = "OPECST2"
indice = 0
SAVACT = GACTION : GACTION = "INIDEV"
GACTION = SAVACT
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:PJTAC0B]CUR,GDEVISE(1..GNBDEV)),1))
If mkstat=1 : Raz [M]OPECST2 : Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMTACT0B"
Return

