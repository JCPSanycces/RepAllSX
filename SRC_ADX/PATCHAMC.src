#<AdxTL>@(#)1.0.0.0 $Revision$


######################################################
## Intégration d'un mot clé d'aide
######################################################

$MOTCLE
K = instr(1,NOMOBJ,"~")
If K
 [L]TYPS = left$(NOMOBJ,K-1)
 [L]CODS = right$(NOMOBJ,K+1)
Else
 Gosub FIN_OBJ From PATCH
 Return
Endif
Call ECR_TRACE(mess(33,115,1)-":"-TYPOBJ-NOMOBJ-INTITOBJ,0) From GESECRAN

Local File =DOSSIER(D)+".AMOTCLE" [AMC]
#Local File =DOSSIER(D)+".ATABLE"  [ATB]
Local File =DOSSIER(D)+".ASHW"    [ASW]
Local File =DOSSIER(D)+".ACLASSE" [ACLA]
#Local File =DOSSIER(D)+".AMSK"    [AMK]

#Local File =DOSSIER(D)+".ATABZON"    [ATZ]
Local File =DOSSIER(D)+".ASHWSEC"    [ASWS]
Local File =DOSSIER(D)+".ASHWBLC"    [ASWB]
Local File =DOSSIER(D)+".ASHWEXPPRO" [ASWR]
Local File =DOSSIER(D)+".ACLAFLD"    [ACLAF]
#Local File =DOSSIER(D)+".AMSKZON"    [AMZ]

Local Integer WMODAMC
Local Char WACTIV(GLONACV)
Local Char WBLC(20)
Local Char WREP(GLONASW)
Local Char WACTBLC (GLONACV), WACTSEC(GLONACV)

If TYPENR=2 :#SCM deletion
 Call DEBTRANS From GLOCK
 Gosub TR_AMC
Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_AMC
 Endif
 Gosub FIN_OBJ From PATCH
Endif

#Close Local File [AMC],[ATB],[ASW],[ACLA],[AMK]
Close Local File [AMC],[ASW],[ACLA]
#Close Local File [ATZ],[ASWS],[ASWB],[ASWR],[ACLAF],[AMZ]
Close Local File [ASWS],[ASWB],[ASWR],[ACLAF]
Return

$TR_AMC
Trbegin [AMC]
 # suppresion des enreg non protégés par un code activité
 Gosub SUPP_AMC
 If ER : Goto ABORT : Endif
 NBZ = 0
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # La transaction
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "AMC"   : Gosub AMC1
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
If [L]ISOKSPOTTING=2
 Local Char AMC_CLE1(250),AMC_CLE2(50)(0..3)
 [L]AMC_CLE1= [F:AMC]IDENT1  : [L]AMC_CLE2(0)=num$([F:AMC]TYPZON)
 Call TRACE_COR_PATCH("AMC", [L]AMC_CLE1, [L]AMC_CLE2, "C") From GOBJET
Endif
If val([L]TYPS)=2
  Local Char NAMF(250)
  NAMF=filpath("ECR",[L]CODS,"msk",APPLI)
  # Issue 87267 - 2013-01-21 by VPO : invalidation ecran s'il n'existe pas
  #If filinfo(NAMF,7)>0
  Openo NAMF,0 Using [DIFM]
  Openo Using [DIFM]
  #Endif
Endif
Return

$DEL_AMC
Trbegin [AMC]
 Delete [AMC] Where TYPZON=[L]TYPS  and IDENT1=[L]CODS
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "AMOTCLE"-[L]TYPS+"~"+[L]CODS: Return
 Endif
Commit
Local Char WWCLE2(250)(0..16): WWCLE2(0) = [L]TYPS

If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AMC",[L]CODS,WWCLE2,"A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

$ABORT
Rollback
Return


## Lecture des mots clés d'aide
$AMC1
FICHIER = "AMOTCLE" : ABR = "AMC"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
# si on trouve un enreg c'est qu'il protégé par un code activité alors on arrete
Look [AMC]AMC0 = [F:AMC]TYPZON ;[F:AMC]IDENT1 ;[F:AMC]IDENT2
If !fstat
 Return
Endif

Case [F:AMC]TYPZON
  When 1 : Read [ATB]CODFIC=[F:AMC]IDENT1
           WMODAMC=[F:ATB]MODULE
  When 2 : Read [AMK]CODMSK=[F:AMC]IDENT1
           WMODAMC=[F:AMK]MODULE
  When 3 : Read [ACLA]ACLA0=[F:AMC]IDENT1
           WMODAMC=[F:ACLA]MODULE
  When 4 : Read [ASW]ASW0=[F:AMC]IDENT1
           WMODAMC=[F:ASW]MODULE
Endcase

MODOBJ = max(1,WMODAMC)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
Write [AMC]
If fstat
  GOK = 0 : ER = 99 : : ERFIC = "AMOTCLE"-num$([F:AMC]TYPZON)+"~"+[F:AMC]IDENT1+"~"+[F:AMC]IDENT1 : Return
Endif
Return

$SUPP_AMC
For [AMC]AMC0(2) Where TYPZON=val([L]TYPS) & IDENT1=[L]CODS
  OK = 1
  WACTIV=""
  Case [F:AMC]TYPZON
    When 1 : Read [ATB]CODFIC=[F:AMC]IDENT1
             WACTIV=[F:ATB]CODACT
    When 2 : Read [AMK]CODMSK=[F:AMC]IDENT1
             WACTIV=[F:AMK]CODACT
    When 3 : Read [ACLA]ACLA0=[F:AMC]IDENT1
             WACTIV=[F:ACLA]CODACT
    When 4 : Read [ASW]ASW0=[F:AMC]IDENT1
             WACTIV=[F:ASW]CODACT
  Endcase
  If WACTIV>="X" & !find(WACTIV,ACTIV(1..NBACT))
    OK = 0
  Endif
  If OK
    For [AMC]AMC0
      WACTIV=""
      Case [F:AMC]TYPZON
        When 1 : Read [ATZ]CODZONE=[F:AMC]IDENT1;[F:AMC]IDENT2
                 WACTIV=[F:ATZ]CODACT
        When 2 : Read [AMZ]CODE=[F:AMC]IDENT1;[F:AMC]IDENT2
                 WACTIV=[F:AMZ]CODACT
        When 3 : Read [ACLAF]ACLAF0=[F:AMC]IDENT1;[F:AMC]IDENT2
                 WACTIV=[F:ACLAF]ACTFLD
        When 4 : Read [ASWR]ASWR0=[F:AMC]IDENT1;[F:AMC]IDENT2
                 WREP=[F:AMC]IDENT1
                 WBLC=[F:ASWR]BLCPRO
                 Gosub FIND_ACTBLCSEC
                 If WACTBLC>="X" & !find(WACTBLC,ACTIV(1..NBACT)) : # Specific
                   WACTIV = WACTBLC
                 Elsif WACTSEC>="X" & !find(WACTSEC,ACTIV(1..NBACT)) : # Specific
                   WACTIV = WACTSEC
                 Else
                   WACTIV=""
                 Endif
      Endcase
      If WACTIV>="X" & !find(WACTIV,ACTIV(1..NBACT))
        OK = 0
      Endif
      If OK
        Delete [AMC]AMC0 Curr
        If fstat
          GOK = 0 : ER = 99 : ERFIC = "AMOTCLE"-num$([F:AMC]TYPZON)+"~"+[F:AMC]IDENT1+"~"+[F:AMC]IDENT2 : Break
        Endif
      Endif
    Next
  Endif
Next
If ER : Return : Endif
Return

#--------------------------------------------#
# Find actvity code for a bloc/section (WBLC)
#--------------------------------------------#
$FIND_ACTBLCSEC
Raz WACTBLC, WACTSEC
Read [ASWB]ASWB0=WREP;WBLC
If !fstat
  WACTBLC=[F:ASWB]ACTBLC
  Read [ASWS]ASWS0=WREP;[F:ASWB]SECBLC
  If !fstat
    WACTSEC=[F:ASWS]ACTSEC
  Endif
Endif
Return

