##########################################################################################################
## Etiquette ajoutée par le superviseur (écran MAI3) 26/01/2005 11:17:38 (SDE)
######################################################################################
Subprog C_QURNUM(VALEUR)
Variable Char    VALEUR()

Local Integer I

  I = 0
  If VALEUR <> "" Then
    If [M:MAI3]MASTERSEL = 1 Then
      If nolign  > 1 Then
        #On n'a pas de selection tiers
        GMESSAGE = mess(197,177,1) #Aucune sélection maître. Vous ne pouvez saisir qu'un seul ciblage.
        GERR = 1
        mkstat = 2
      Endif
    Endif
    Read [MQR] MQR0 = VALEUR
    If fstat Then
      GMESSAGE = mess(83,123,1) #Valeur incorrect.
      GERR = 1
      mkstat = 2
    Else
      If [M:MAI3]MASTERSEL = 1 Then
        If [F:MQR]TGR <> "CONTACTCRM" and [F:MQR]TGR <> "LEAD" Then
          GMESSAGE = mess(83,123,1) #Valeur incorrect.
          GERR = 1
          mkstat = 2
        Endif          
      Else
        If [F:MQR]TGR <> "CONTACTCRM" Then
          GMESSAGE = mess(83,123,1) #Valeur incorrect.
          GERR = 1
          mkstat = 2
        Endif
      Endif
    Endif
    #Vérifie que ce ciblage n'a pas déjà été saisie dans le tableau
    For I = 0 To dim ([M:MAI3]QURNUM) - 1
      If I <> nolign - 1 Then
        If [M:MAI3]QURNUM(I) = VALEUR and [M:MAI3]QURNUM(I) <> "" Then
          mkstat = 2
          #Ce ciblage a déjà été saisi en ligne n°NNN
          GMESSAGE = mess(745,182,1) + num$(I+1)
          GERR = 2
          Break
        Endif
      Endif
    Next    
  Endif
End

##########################################################################################################
Subprog AM_QURNUM(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    [M:MAI3]QURNAM(nolign-1) = ""
  Else
    Read [MQR] MQR0 = VALEUR
    If fstat Then
      [M:MAI3]QURNAM(nolign-1) = ""
    Else
      [M:MAI3]QURNAM(nolign-1) = [F:MQR]QURNAM
    Endif
  Endif
  If VALEUR <> "" Then
    #On enregistre la nouvelle relation
    Read [MOG] MOG0 = VALEUR;GSZOPGNUM;"CONTACTCRM"
    If fstat Then
      Call DEBTRANS From GLOCK
      Trbegin [MOG]
      [F:MOG]MKGQUR = VALEUR
      [F:MOG]OPGNUM = GSZOPGNUM
      [F:MOG]TGR = "CONTACTCRM"
      Write [MOG]
      If fstat Then
        Rollback
        #Erreur lors de l'enregistrement du ciblage marketing.
        GMESSAGE = mess(580,196,1)
        GERR = 1
        End  # FGR 29/03/2010 : X3SUIVI62472 : et pas Return
      Else
        Commit
      Endif
    Endif
  Endif
  [M:MAI3]QURNUM(nolign - 1) = VALEUR
  Affzo [M:MAI3]QURNUM(nolign-1), QURNAM(nolign-1)
End

######################################################################################
Subprog IB_QURNUM
End
