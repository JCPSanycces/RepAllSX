#<AdxTL>@(#)7.0.0.0 $Revision$
# GA 09/2011 suite FQ 75475
# UTI75475: correction des intitulés évalués dans le paramétrage des conditions prédéfinies (BI)

Local Char WDOSSIER(30)
WDOSSIER=nomap
Call SAIDOS(WDOSSIER,"UTI75475 - Mise à jour de l'objet AII") From SAIDOS
If WDOSSIER=GDOSX3
  If filinfo(filpath("FIL","ADOSSIER","fde",WDOSSIER),0)>1
    Call OUVRE_TRACE("UTI75475: BI maj des conditions préfinies [F:AII]INTEVAL") From LECFIC

    Local File =WDOSSIER+".ADOSSIER" [ADS]
    For [ADS] DOSSIER Where DOSSIER<>GDOSX3
      Call EXE_UTI75475([F:ADS]DOSSIER)
    Next
    Close Local File [ADS]

    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Else
  Call OUVRE_TRACE("UTI75475: BI maj des conditions préfinies [F:AII]INTEVAL") From LECFIC

  Call EXE_UTI75475(WDOSSIER)

  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

End

Subprog EXE_UTI75475(WDOSSIER)
Value Char    WDOSSIER
#-----

If filinfo(filpath("FIL","ABICOND","fde",WDOSSIER),0)>1
    Call ECR_TIME("UTI75475 : Start folder's process"-WDOSSIER) From DOSSUB
    Gosub OPEN_FILES
    
    Gosub AII_INTEVAL
    
    Gosub CLOSE_FILES

Else
    Call ECR_TRACE("UTI75475: No BI on Folder"-WDOSSIER,0) From GESECRAN
Endif    

End

$OPEN_FILES
Local File =WDOSSIER+".ABICOND"      [AII] 
Return

$CLOSE_FILES
Close Local File [AII]
Return



$AII_INTEVAL
Local Char WINTEVAL(250)
Local Integer W_FIN, W_DEB

# Catégorie        => mess(655,197,1)
# Ligne de produit => mess(14,188,1)
# Fin              => mess(105,148,1)
# Début            => mess(104,148,1)

W_FIN=0
W_DEB=0

Trbegin [AII]

Filter [AII] Where pat(INTEVAL,"*Fin :*") Order By Key AII2
For [AII]
    WINTEVAL = [AII]INTEVAL

    Case WINTEVAL
       When 'mess(1,206,1)-"Fin :"'
            [AII]INTEVAL   ='mess(1,206,1)-mess(105,148,1)-":"'
       When 'mess(2,206,1)-"Fin :"'
            [AII]INTEVAL   ='mess(2,206,1)-mess(105,148,1)-":"'
       When 'mess(3,206,1)-"Fin :"'
            [AII]INTEVAL   ='mess(3,206,1)-mess(105,148,1)-":"'
       When 'mess(4,206,1)-"Fin :"'
            [AII]INTEVAL   ='mess(4,206,1)-mess(105,148,1)-":"'
       When 'mess(5,206,1)-"Fin :"'
            [AII]INTEVAL   ='mess(5,206,1)-mess(105,148,1)-":"'

       When 'mess(63,198,1)-"Fin :"'
            [AII]INTEVAL   ='mess(63,198,1)-mess(105,148,1)-":"'
       When 'mess(63,198,1)-"-"-"Catégorie Fin :"'
            [AII]INTEVAL   ='mess(63,198,1)-"-"-mess(655,197,1)-mess(105,148,1)-":"'
       When 'mess(63,198,1)-"-"-"Ligne de produit Fin :"'
            [AII]INTEVAL   ='mess(63,198,1)-"-"-mess(14,188,1)-mess(105,148,1)-":"'

       When 'mess(63,198,1)-"-"-mess(1,206,1)-"Fin :"'
            [AII]INTEVAL   ='mess(63,198,1)-"-"-mess(1,206,1)-mess(105,148,1)-":"'
       When 'mess(63,198,1)-"-"-mess(2,206,1)-"Fin :"'
            [AII]INTEVAL   ='mess(63,198,1)-"-"-mess(2,206,1)-mess(105,148,1)-":"'
       When 'mess(63,198,1)-"-"-mess(3,206,1)-"Fin :"'
            [AII]INTEVAL   ='mess(63,198,1)-"-"-mess(3,206,1)-mess(105,148,1)-":"'
       When 'mess(63,198,1)-"-"-mess(4,206,1)-"Fin :"'
            [AII]INTEVAL   ='mess(63,198,1)-"-"-mess(4,206,1)-mess(105,148,1)-":"'
       When 'mess(63,198,1)-"-"-mess(5,206,1)-"Fin :"'
            [AII]INTEVAL   ='mess(63,198,1)-"-"-mess(5,206,1)-mess(105,148,1)-":"'


       When 'mess(35,197,1)-"Fin :"'
            [AII]INTEVAL   ='mess(35,197,1)-mess(105,148,1)-":"'
       When 'mess(35,197,1)-"-"-"Catégorie Fin :"'
            [AII]INTEVAL   ='mess(35,197,1)-"-"-mess(655,197,1)-mess(105,148,1)-":"'
       When 'mess(35,197,1)-"-"-"Ligne de produit Fin :"'
            [AII]INTEVAL   ='mess(35,197,1)-"-"-mess(14,188,1)-mess(105,148,1)-":"'

       When 'mess(35,197,1)-"-"-mess(1,206,1)-"Fin :"'
            [AII]INTEVAL   ='mess(35,197,1)-"-"-mess(1,206,1)-mess(105,148,1)-":"'
       When 'mess(35,197,1)-"-"-mess(2,206,1)-"Fin :"'
            [AII]INTEVAL   ='mess(35,197,1)-"-"-mess(2,206,1)-mess(105,148,1)-":"'
       When 'mess(35,197,1)-"-"-mess(3,206,1)-"Fin :"'
            [AII]INTEVAL   ='mess(35,197,1)-"-"-mess(3,206,1)-mess(105,148,1)-":"'
       When 'mess(35,197,1)-"-"-mess(4,206,1)-"Fin :"'
            [AII]INTEVAL   ='mess(35,197,1)-"-"-mess(4,206,1)-mess(105,148,1)-":"'
       When 'mess(35,197,1)-"-"-mess(5,206,1)-"Fin :"'
            [AII]INTEVAL   ='mess(35,197,1)-"-"-mess(5,206,1)-mess(105,148,1)-":"'

       When Default :
            Call ECR_TRACE([AII]ABM-[AII]CODABF-[AII]COD-[AII]INTEVAL,1) From GESECRAN

    Endcase

    W_FIN+=1
    [AII]INTVALTEX =[AII]INTEVAL
    [AII]UPDUSR=GUSER
    [AII]UPDDAT=date$
    Rewrite [AII]

Next
Filter [AII]

Filter [AII] Where pat(INTEVAL,"*Début :*") Order By Key AII2
For [AII]

    WINTEVAL = [AII]INTEVAL

    Case WINTEVAL
       When 'mess(1,206,1)-"Début :"'
            [AII]INTEVAL   ='mess(1,206,1)-mess(104,148,1)-":"'
       When 'mess(2,206,1)-"Début :"'
            [AII]INTEVAL   ='mess(2,206,1)-mess(104,148,1)-":"'
       When 'mess(3,206,1)-"Début :"'
            [AII]INTEVAL   ='mess(3,206,1)-mess(104,148,1)-":"'
       When 'mess(4,206,1)-"Début :"'
            [AII]INTEVAL   ='mess(4,206,1)-mess(104,148,1)-":"'
       When 'mess(5,206,1)-"Début :"'
            [AII]INTEVAL   ='mess(5,206,1)-mess(104,148,1)-":"'

       When 'mess(63,198,1)-"Début :"'
            [AII]INTEVAL   ='mess(63,198,1)-mess(104,148,1)-":"'
       When 'mess(63,198,1)-"-"-"Catégorie Début :"'
            [AII]INTEVAL   ='mess(63,198,1)-"-"-mess(655,197,1)-mess(104,148,1)-":"'
       When 'mess(63,198,1)-"-"-"Ligne de produit Début :"'
            [AII]INTEVAL   ='mess(63,198,1)-"-"-mess(14,188,1)-mess(104,148,1)-":"'

       When 'mess(63,198,1)-"-"-mess(1,206,1)-"Début :"'
            [AII]INTEVAL   ='mess(63,198,1)-"-"-mess(1,206,1)-mess(104,148,1)-":"'
       When 'mess(63,198,1)-"-"-mess(2,206,1)-"Début :"'
            [AII]INTEVAL   ='mess(63,198,1)-"-"-mess(2,206,1)-mess(104,148,1)-":"'
       When 'mess(63,198,1)-"-"-mess(3,206,1)-"Début :"'
            [AII]INTEVAL   ='mess(63,198,1)-"-"-mess(3,206,1)-mess(104,148,1)-":"'
       When 'mess(63,198,1)-"-"-mess(4,206,1)-"Début :"'
            [AII]INTEVAL   ='mess(63,198,1)-"-"-mess(4,206,1)-mess(104,148,1)-":"'
       When 'mess(63,198,1)-"-"-mess(5,206,1)-"Début :"'
            [AII]INTEVAL   ='mess(63,198,1)-"-"-mess(5,206,1)-mess(104,148,1)-":"'


       When 'mess(35,197,1)-"Début :"'
            [AII]INTEVAL   ='mess(35,197,1)-mess(104,148,1)-":"'
       When 'mess(35,197,1)-"-"-"Catégorie Début :"'
            [AII]INTEVAL   ='mess(35,197,1)-"-"-mess(655,197,1)-mess(104,148,1)-":"'
       When 'mess(35,197,1)-"-"-"Ligne de produit Début :"'
            [AII]INTEVAL   ='mess(35,197,1)-"-"-mess(14,188,1)-mess(104,148,1)-":"'

       When 'mess(35,197,1)-"-"-mess(1,206,1)-"Début :"'
            [AII]INTEVAL   ='mess(35,197,1)-"-"-mess(1,206,1)-mess(104,148,1)-":"'
       When 'mess(35,197,1)-"-"-mess(2,206,1)-"Début :"'
            [AII]INTEVAL   ='mess(35,197,1)-"-"-mess(2,206,1)-mess(104,148,1)-":"'
       When 'mess(35,197,1)-"-"-mess(3,206,1)-"Début :"'
            [AII]INTEVAL   ='mess(35,197,1)-"-"-mess(3,206,1)-mess(104,148,1)-":"'
       When 'mess(35,197,1)-"-"-mess(4,206,1)-"Début :"'
            [AII]INTEVAL   ='mess(35,197,1)-"-"-mess(4,206,1)-mess(104,148,1)-":"'
       When 'mess(35,197,1)-"-"-mess(5,206,1)-"Début :"'
            [AII]INTEVAL   ='mess(35,197,1)-"-"-mess(5,206,1)-mess(104,148,1)-":"'

       When Default :
            Call ECR_TRACE([AII]ABM-[AII]CODABF-[AII]COD-[AII]INTEVAL,1) From GESECRAN

    Endcase
 
    W_DEB+=1
    [AII]INTVALTEX =[AII]INTEVAL
    [AII]UPDUSR=GUSER
    [AII]UPDDAT=date$
    Rewrite [AII]

Next
Filter [AII]

If W_DEB+W_FIN>0
   Call ECR_TRACE("Nombre de maj réalisées sur ABICOND="+num$(W_DEB)-"+"-num$(W_FIN),0) From GESECRAN
Endif

Rollback

Return





####################
# Appel par un EXE #
####################
Subprog PATCH(APPLI)
Value Char    APPLI
#If APPLI=GDOSX3  End : Endif
Call EXE_UTI75475(APPLI)
End




