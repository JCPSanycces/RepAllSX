##########################################################################
# Module Comptabilité/GDD
# Traitements divers lié à la Gestion des dépenses
##########################################################################
# Issue X3-101289 - 2018-10-09 by MDJ : Operational budget line revision : approved amount don't be updated
# Issue X3-112104 - 2018-10-09 by CBO : error line 85 when fixing X3-107197
# Issue X3-107197 - 2018-09-12 by CBO : PARAMETER AND ACTIVITY CODE
#**
#* Operating Budget (BUO)
#* GDD (acronym of french term 'Gestion Des Dépenses') is the historical name
#* for Operating budgets (now BUO)
#*
#* This source gathers different subprog ang Gosubs dedicated to BUO's functions
#*
#*!


Subprog LEC_ENV(ENVELOP)
Value Char ENVELOP
fstat = 0
If [F:ENV]ENV<>ENVELOP
 Read [ENV]ENV0 = ENVELOP
Endif
End

##########################################################################
# Test de la saisie des paramètres d'approbation
##########################################################################
#**
#* Test during the input of the approbation's parameters
#*!
Subprog VERF_PARAM(PARAM, VALEUR, OK)
Value Char PARAM
Value Char VALEUR
Variable Integer OK
If PARAM<>"GDDAPPENV" & PARAM<>"GDDAPPBUD" & PARAM<>"GDDAPPLIG"
 #Erreur dans le code paramètre
 GMESSAGE = mess(204, 196, 2)
 GERR = 1
 OK = 0
 End
Endif
If dim([M:ADWP]NBVAR)
 Local Char ENV,BUD,LIG,VAL1,VAL2
 For I=0 To [M:ADWP]NBVAR-1
  If [M:ADWP]PARAM(I)<>PARAM
   Case [M:ADWP]PARAM(I)
    When "GDDAPPENV"
     VENV=[M:ADWP]VALEUR(I)
    When "GDDAPPBUD"
     VBUD=[M:ADWP]VALEUR(I)
    When "GDDAPPLIG"
     VLIG=[M:ADWP]VALEUR(I)
   Endcase
  Endif
 Next
 Case PARAM
  When "GDDAPPENV"
     VAL1=VBUD : VAL2=VLIG
    When "GDDAPPBUD"
     VAL1=VENV : VAL2=VLIG
    When "GDDAPPLIG"
     VAL1=VENV : VAL2=VBUD
   Endcase
 If VAL1=mess(1,1,1) & VAL2=mess(1,1,1) & VALEUR="1"
  #Au moins un des paramètres de gestion d'approbation doit être à Oui
  GMESSAGE=mess(100,108,1)
  mkstat=2
  GERR=1
  OK=0
  End
 Endif
Endif
OK=1
End

#-------------#
# Utilitaires #
#-------------#

Subprog SETGLBAPP(SOCIETE,APPNIV)
Value Char SOCIETE()
Variable Char APPNIV()
Local Char APPENV,APPBUD,APPLIG
If func AFNC.ACTIV("GDD")   # Issue X3-107197 X3-112104
  Call PARAM(SOCIETE,"GDDAPPENV",APPENV) From ADOVAL
  Call PARAM(SOCIETE,"GDDAPPBUD",APPBUD) From ADOVAL
  Call PARAM(SOCIETE,"GDDAPPLIG",APPLIG) From ADOVAL
Endif   # Issue X3-107197
APPNIV= APPENV+APPBUD+APPLIG
End

Subprog GETAPPNIV(ENVELOPPE,APPNIV)
Value Char ENVELOPPE
Variable Char APPNIV()
Local Integer ISOC, ISITE
Call LECTURE("ENV",ENVELOPPE,"") From CONTOBJ
ISOC   = find([F:ENV]FCY,GSOC(1..GNBSOC))
If !ISOC
 ISITE = find([F:ENV]FCY,GSITE(1..GNBSITE))
 If !ISITE : End : Endif
 ISOC = find(GSOCSITE(ISITE),GSOC(1..GNBSOC))
 If !ISOC : End : Endif
Endif
Call SETGLBAPP(GSOC(ISOC),APPNIV) From TRTGDD
End

#---------------------------------------------------------------------#
# Récupération du nombre et de la liste des délégués d'un utilisateur
# en fonction de la nature du workflow et d'une option
# 1 non on sort
# 2 si option 'Tous' (seulement le premier rang)
# 3 si option 'Cascade' (délégués de délégués)
# 4 Premier libre : le premier utilisateur libre devient le destinataire principal
# il n'y a plus de délégation
#---------------------------------------------------------------------#
Subprog GETUSRDELEG(NATURE,USRDEP,OPTION,NBRDEL,ALLDEL)
Value Char NATURE
Value Char USRDEP
Value Integer OPTION
Variable Integer NBRDEL
Variable Char ALLDEL()(1..)

If !clalev([AWU]) : Local File AWRKUSR [AWU] : Endif
Local Integer NBDR1 : NBDR1=0
Local Char DELEG_R1(GLONAUS)(1..10)
Local Integer NBDR2 : NBDR2=0
Local Char DELEG_R2(GLONAUS)(1..20)
Local Integer NBDR3 : NBDR3=0
Local Char DELEG_R3(GLONAUS)(1..30)
Local Integer NBDR4 : NBDR4=0
Local Char DELEG_R4(GLONAUS)(1..40)

If [L]NATURE<>""
 Filter [AWU] Where NATURE=[L]NATURE
Endif

# Un délégué exceptionnel compte au premier rang et sans tenir compte des options
For [AWU]AWU0 Where USER=USRDEP & TYPDEL=3
 If !find([F:AWU]USRDEL,ALLDEL(1..NBRDEL))
  NBDR1+=1
  NBRDEL+=1
  DELEG_R1(NBDR1)=[F:AWU]USRDEL
  ALLDEL(NBRDEL)=[F:AWU]USRDEL
 Endif
Next

# OPTION => option de délégué
# 1 non on sort
# 4 Premier libre : le premier utilisateur libre devient le destinataire principal
# il n'y a plus de délégation
If OPTION=1 | OPTION=4 : End : Endif
# 2 si option 'Tous' (seulement le premier rang)
# 3 si option 'Cascade' (délégués de délégués)

# Rang1
For [AWU]AWU0 Where USER=USRDEP & [F:AWU]TYPDEL=2
 If (date$>=[F:AWU]VLYSTR & date$<=[F:AWU]VLYEND) | [F:AWU]VLYSTR=[0/0/0]
  If !find([F:AWU]USRDEL,ALLDEL(1..NBRDEL))
   NBDR1+=1
   NBRDEL+=1
   DELEG_R1(NBDR1)=[F:AWU]USRDEL
   ALLDEL(NBRDEL)=[F:AWU]USRDEL
  Endif
 Endif
Next

If OPTION=2
 If [L]NATURE<>""
  Filter [AWU]
 Endif
 End
Endif

# Rang2
For I=1 To NBDR1
 For [AWU]AWU0 Where USER=DELEG_R1(I) & TYPDEL=2
  If (date$>=[F:AWU]VLYSTR & date$<=[F:AWU]VLYEND) | [F:AWU]VLYSTR=[0/0/0]
   If !find([F:AWU]USRDEL,ALLDEL(1..NBRDEL))
    NBDR2+=1
    NBRDEL+=1
    DELEG_R2(NBDR2)=[F:AWU]USRDEL
    ALLDEL(NBRDEL)=[F:AWU]USRDEL
   Endif
  Endif
 Next
Next

# Rang3
For I=1 To NBDR2
 For [AWU]AWU0 Where USER=DELEG_R2(I) & TYPDEL=2
  If (date$>=[F:AWU]VLYSTR & date$<=[F:AWU]VLYEND) | [F:AWU]VLYSTR=[0/0/0]
   If !find([F:AWU]USRDEL,ALLDEL(1..NBRDEL))
    NBDR3+=1
    NBRDEL+=1
    DELEG_R3(NBDR3)=[F:AWU]USRDEL
    ALLDEL(NBRDEL)=[F:AWU]USRDEL
   Endif
  Endif
 Next
Next

# Rang4
For I=1 To NBDR3
 For [AWU]AWU0 Where USER=DELEG_R3(I) & TYPDEL=2
  If (date$>=[F:AWU]VLYSTR & date$<=[F:AWU]VLYEND) | [F:AWU]VLYSTR=[0/0/0]
   If !find([F:AWU]USRDEL,ALLDEL(1..NBRDEL))
    NBDR4+=1
    NBRDEL+=1
    DELEG_R4(NBDR4)=[F:AWU]USRDEL
    ALLDEL(NBRDEL)=[F:AWU]USRDEL
   Endif
  Endif
 Next
Next

# Rang5
For I=1 To NBDR4
 For [AWU]AWU0 Where USER=DELEG_R4(I) & TYPDEL=2
  If (date$>=[F:AWU]VLYSTR & date$<=[F:AWU]VLYEND) | [F:AWU]VLYSTR=[0/0/0]
   If !find([F:AWU]USRDEL,ALLDEL(1..NBRDEL))
    NBRDEL+=1
    ALLDEL(NBRDEL)=[F:AWU]USRDEL
   Endif
  Endif
 Next
Next

If [L]NATURE<>""
 Filter [AWU]
Endif
End

$ABANDON
Rollback
Return

#-------------------------------------------------------------------------------------------#
#  A partir des tableaux d'axes et sections liés, récupération des informations
# des budgets opérationnels : Entité, Enveloppe, 3ème section, type d'enveloppe
# & budget associé.
# Le flague Ok indique s'il l'on est dans le cadre des budgets opérationnels ou non.
# Le site passé en paramètre alimente ou non le site retour FCYBUD en fonction du
# niveau du budget
#---------------------------------------------------------------------------------
Subprog GETBUOINF(TBDIE,TBCCE,FCY,BUDCOD,CCE1,N1,CCE2,N2,CCE3,N3,OK,YEAFLG,FCYBUD)
Value Char TBDIE()(1..)
Value Char TBCCE()(1..)
Value Char FCY()
Variable Char BUDCOD()
Variable Char CCE1()
Variable Integer N1
Variable Char CCE2()
Variable Integer N2
Variable Char CCE3()
Variable Integer N3
Variable Integer OK
Variable Integer YEAFLG
Variable Char FCYBUD

If !clalev([F:DIE]) : Local File GDIE [DIE]      : Endif
If !clalev([F:ENV]) : Local File ENVELOPPE [ENV] : Endif
If !clalev([F:BUP]) : Local File BUDPAR [BUP]    : Endif
If !clalev([F:BUT]) : Local File BUDTYP [BUT]    : Endif

OK = 0
FCYBUD = FCY
For I=1 To dim(TBDIE)
 If TBDIE(I)<>"" & TBCCE(I)<>""
  Read [DIE]DIE0 = TBDIE(I)
  If !fstat
   If [F:DIE]ENT=2 : N1 = I : Endif
   If [F:DIE]ENV=2 : N2 = I : Endif
  Else
   OK=0 : Break : End
  Endif
 Endif
Next I
If N1 & N2
 CCE1=TBCCE(N1)
 CCE2=TBCCE(N2)
 Read [ENV]ENV0 = CCE2
 If !fstat
  OK = 1
  BUDCOD = [F:ENV]BUD
  Read [BUP]BUP0 = BUDCOD
  If !fstat & [F:BUP]DIE(2)<>""
   N3 = find([F:BUP]DIE(2),TBDIE)
   If N3=0
    OK = 0
   Else
    CCE3 = TBCCE(N3)
   Endif
  Endif
  Read [BUT]BUT0 = [F:ENV]BUDTYP
  If !fstat
   YEAFLG=[F:BUT]YEAFLG
  Endif
  #Si paramétrage budget niveau société le champ site doit être vide
  If [F:BUP]LEV=1
   FCYBUD=""
  Endif
 Endif
Endif
End


#-----------------------------------------------------------------------------#
# Etiquette appelée depuis la/les pièce(s) automatique(s) PTHx
#-----
# Gestion des FAR et AAR Demande création sur N / extourne sur N+1
# AVANT report des engagements :
# -Date de commande sur N et enveloppe sur N
# -CMM :on désengage sur N (pas de problème)
# -BUD :on désengage sur N (pas de problème)
# Pour l'extourne, on va:
# -CMM : engager sur N+1
# -BUD : engager sur N+1
#  => donc :
#    - il faut bloquer si l'enveloppe N+1 (issue de la reconduction de lenveloppe N)
#      n'existe pas
#    - il faut donc remplacer dans la pièce l’enveloppe de N par l’enveloppe de N+1.
#      Donc on change la valeur de la section enveloppe dans les masques de la pièce
#      comptable.
#
# Etiquette appelée depuis la pièce automatique CCA
#-----------------------------------------------------------------------------#
$VERIFBUO
If !func AFNC.ACTIV("GDD") : Return : Endif
# Issue 122510 - 2017-04-19 by RMA : On simulation we don't have the reversal
If [M:HAE1]RVSDAT = [0/0/0] : Return : Endif
#Usefull variables
Local Integer TYPLEDGDD
Local Char LEDGDD(GLONLED), ENVDIE(GLONDIE), ENTDIE(GLONENT), COAGDD(GLONCOA), ACCGDD(GLONGAC)
Local Integer ENVDIENUM1, ENTDIENUM1
Local Integer ENVDIENUM2, ENTDIENUM2
Local Integer ENVDIENUM3, ENTDIENUM3
Local Integer INDENV, INDENT, INDCCE3
Local Integer COANUM
Local Decimal PERIODE, ENVFIY,EXERCICE

Local Decimal ENVFIYSTR, ENVFIYEND
Local Char FIYINFO(20)
Local Char ERRMSG(250)

#Usefull tabs
If !clalev([ENV])  : Local File ENVELOPPE  [ENV] : Endif
If !clalev([ENV2]) : Local File ENVELOPPE  [ENV2]: Endif
If !clalev([BUT])  : Local File BUDTYP     [BUT] : Endif

If !clalev([FIY])  : Local File FISCALYEAR [FIY] : Endif

Call GETLEDGDD([M:HAE0]CPY,TYPLEDGDD,LEDGDD)
Call GETPERSOC([M:HAE0]CPY,TYPLEDGDD,[M:HAE1]RVSDAT,EXERCICE,PERIODE) From CPTSUB
Call LECPLAN([M:HAE0]CPY,TYPLEDGDD,COAGDD) From CPTDIV

Raz ENVDIE,ENTDIE,ENVDIENUM1,ENTDIENUM1,ENVDIENUM2,ENTDIENUM2

Call GETENVDIE(LEDGDD,ENVDIE)
If ENVDIE="" : Return : Endif
Call GETENTDIE(LEDGDD,ENTDIE)
If ENTDIE="" : Return : Endif

Call GETGDDINDDIE([M:HAE0]CPY,"",INDENV,INDENT,INDCCE3) From TRTGDD

# Fiscal year title
If [F:FIY]CPY<>[M:HAE0]CPY or [F:FIY]LEDTYP<>TYPLEDGDD or [F:FIY]FIYNUM<>EXERCICE
 Read [FIY]FIY0 = [M:HAE0]CPY;TYPLEDGDD;EXERCICE
Endif
If !fstat
 If [F:FIY]DESSHO<>""
  FIYINFO  = num$(EXERCICE)-":"-[F:FIY]DESSHO
 Else
  FIYINFO  = num$(EXERCICE)
 Endif
Endif

#--------------------------------------#
# Pour le masque de la pièce comptable #
#--------------------------------------#
ENVDIENUM1 = find(ENVDIE,[M:HAE2]DIE(0..dim([M:HAE2]DIE)-1))
ENTDIENUM1 = find(ENTDIE,[M:HAE2]DIE(0..dim([M:HAE2]DIE)-1))
COANUM = find(COAGDD,[M:HAE2]COA(0..dim([M:HAE2]COA)-1))

If ENVDIENUM1 & ENTDIENUM1
 For I=0 To [M:HAE2]NBLIG-1
  Read [ENV]ENV0 = evalue("[M:HAE2]CCE"+num$(ENVDIENUM1)+"("+num$(I)+")")
  If !fstat
   Call GETEXE([M:HAE0]CPY,TYPLEDGDD,[F:ENV]REASTR,ENVFIYSTR) From CPTSUB
   Call GETEXE([M:HAE0]CPY,TYPLEDGDD,[F:ENV]REAEND,ENVFIYEND) From CPTSUB

   Call LECTURE("BUT",[F:ENV]BUDTYP,"") From CONTOBJ
   If [F:BUT]YEAFLG=1
    #====================
    # Enveloppe Annuelle
    #====================
    # Vérifier la cohérence entre la date passée et la date de l'enveloppe*
    Call GETEXE([M:HAE0]CPY,TYPLEDGDD,[F:ENV]REASTR,ENVFIY) From CPTSUB
    If EXERCICE > ENVFIY
     Filter [ENV2] Where ENVORG=[F:ENV]ENV
     Read [ENV2]ENV0 First
     Filter [ENV2]
     If ! fstat
      # L'enveloppe a été reconduite et son enveloppe
      # de réception est [F:ENV2]ENV
      ACCGDD = evalue("[M:HAE2]ACC"+num$(COANUM)+"("+num$(I)+")")

      # Existe-t-il une ligne budgétaire correspondant au besoin ici ?
      If !clalev([BUD2]) : Local File BUD [BUD2] : Endif
      Filter [BUD2] Where evalue('CCE'+num$(INDENV))=[F:ENV2]ENV
&      & evalue('CCE'+num$(INDENT))=evalue("[M:HAE2]CCE"+num$(ENTDIENUM1)+"("+num$(I)+")")
&      & ACC=evalue("[M:HAE2]ACC"+num$(COANUM)+"("+num$(I)+")") & (STA=3 | STA=4) & LEDTYP=TYPLEDGDD
&      & CPY=[M:HAE0]CPY & FIY=EXERCICE & (FCY=[M:HAE2]FCYLIN(I) | FCY="")
      Look [BUD2] First
      Filter [BUD2]
      If fstat
       # Aucune ligne budgétaire appropriée et approuvée dans l'enveloppe de reception XXXXX
       Call ECR_TRACE(mess(260,108,1)-[F:ENV2]ENV,1) From GESECRAN
       GOK = 0 : STAT = 20 : Break
      Endif
      # Changement de la section enveloppe sur N pour son enveloppe de reception sur N+1
      Assign ("[M:HAE2]CCE"+num$(ENVDIENUM1)+"("+num$(I)+")") With [F:ENV2]ENV

      #Cas d'une cmd receptionné totalement et facturée totalement sur N
      # puis retour partiel sur N et génération d'avoir avec extourne sur N+1
      # comme il n'y a pas de maj de l'engagement dans ce cas, le retour n'est pas
      # mis à jour dans cpteng, il faut donc prendre ici la main pour affecter
      # l'enveloppe N+1 au retour. Ceci afin de pouvoir saisir un avoir sur N+1
      # manuellement et le valider.
      If GFONCTION="FUNPNH"
       #LE parcours dans FUNPNH se fait sur PWE1
       If !clalev([F:PWR2]) : Local File PWRKPND [PWR2] : Endif
       If !clalev([F:POQ])  : Local File PORDERQ [POQ]  : Endif
       For [PWR2]PWR0 Where PRONUM=[F:PWE1]PRONUM & PNHNUM=[F:PWE1]PNHNUM
        Read [POQ]POQ0=[F:PWR2]POHNUM;[F:PWR2]POPLIN;[F:PWR2]POQSEQ
        If !fstat
         If [F:POQ]QTYPUU=[F:POQ]INVQTYPUU
          If !clalev([F:CAL]) : Local File CPTANALIN [CAL] : Endif
           Readlock [CAL]CAL0="PND";0;[F:PWR2]PNHNUM;[F:PWR2]PNDLIN;0;"";1
           If !fstat
            INDENVCAL = find(ENVDIE,[F:CAL]DIE(0..dim([F:CAL]DIE)-1))
            If INDENVCAL & [F:CAL]CCE(INDENVCAL-1)=[F:ENV]ENV
             [F:CAL]CCE(INDENVCAL-1)=[F:ENV2]ENV
             Rewrite [CAL]
             If fstat:  Call FSTA("CAL") From GLOCK : GOK=0 : Break : Endif
            Endif
           Endif
         Endif
        Endif
       Next
       If GOK=0 : Break : Endif
      Endif

     Else
      # L'enveloppe $1$ n'a pas été reconduite
      ERRMSG = mess(261,108,1)
      Call DYNAMIC(ERRMSG,"$1$",[F:ENV]ENV) From TEXTE
      Call ECR_TRACE(ERRMSG,1) From GESECRAN
      GOK = 0 : STAT = 20 : Break
     Endif
    Endif :# EXERCICE <> ENVFIY

   Else

    #==========================
    # Enveloppe Pluri-Annuelle
    #==========================
    #Vérification que l'enveloppe a bien été définie sur l'exercice en cours et qu'elle a des LB approuvées sur ce dernier.
    If EXERCICE>ENVFIYEND
     #Exercice budgétaire $1$ inexistant sur l'enveloppe
     ERRMSG = mess(272,108,1)-[F:ENV]ENV
     Call DYNAMIC(ERRMSG,"$1$",FIYINFO) From TEXTE
     Call ECR_TRACE(ERRMSG,1) From GESECRAN
     GOK=0 : STAT = 20 : Break
  Else
   If !clalev([ENF]) : Local File ENVFIY [ENF] : Endif
     Filter [ENF] Where ENV=[F:ENV]ENV & FIYNUM=EXERCICE & STAFIY=3
     Look [ENF] First
     Filter [ENF]
     If fstat
      #Exercice budgétaire $1$ inexistant sur l'enveloppe
      ERRMSG = mess(272,108,1)-[F:ENV]ENV
      Call DYNAMIC(ERRMSG,"$1$",FIYINFO) From TEXTE
      Call ECR_TRACE(ERRMSG,1) From GESECRAN
      GOK = 0 : STAT = 20 : Break
     Endif
     If !clalev([BUD2]) : Local File BUD [BUD2] : Endif
     Filter [BUD2] Where evalue('CCE'+num$(INDENV))=[F:ENV]ENV
&     & evalue('CCE'+num$(INDENT))=evalue("[M:HAE2]CCE"+num$(ENTDIENUM1)+"("+num$(I)+")")
&     & ACC=evalue("[M:HAE2]ACC"+num$(COANUM)+"("+num$(I)+")") & (STA=3 | STA=4) & LEDTYP=TYPLEDGDD
&     & CPY=[M:HAE0]CPY & FIY=EXERCICE & (FCY=[M:HAE2]FCYLIN(I) | FCY="")
     Look [BUD2] First
     Filter [BUD2]
     If fstat
      # Enveloppe $1$ : aucune ligne budgétaire appropriée et approuvée sur l'exercice
      ERRMSG = mess(273,108,1)-FIYINFO
      Call DYNAMIC(ERRMSG,"$1$",[F:ENV]ENV) From TEXTE
      Call ECR_TRACE(ERRMSG,1) From GESECRAN
      GOK = 0 : STAT = 20 : Break
     Endif
    Endif
   Endif :#Annuelle/Pluri-Annuelle
  Endif :# Read [ENV]
 Next
 If GOK=0 : Return : Endif
Endif


#-----------------------------------------#
#Pour le masque de ventilation analytique #
#-----------------------------------------#
ENVDIENUM2 = find(ENVDIE,[M:VTL]DIE(0..dim([M:VTL]DIE)-1))
ENTDIENUM2 = find(ENTDIE,[M:VTL]DIE(0..dim([M:VTL]DIE)-1))


If ENVDIENUM2 & ENTDIENUM2 & dim([M:VTL]BAS)
 X=find(LEDGDD,[M:VTL]LED(0..dim([M:VTL]LED)-1))
 ACCGDD=[M:VTL]ACC(X-1)

 For I=0 To [M:VTL]BAS-1
  Read [ENV]ENV0 = evalue("[M:VTL]CCE"+num$(ENVDIENUM2)+"("+num$(I)+")")
  If !fstat
   Call LECTURE("BUT",[F:ENV]BUDTYP,"") From CONTOBJ
   If [F:BUT]YEAFLG=1 :# ssi Annuelle
    # Vérifier la cohérence entre la date passée et la date de l'enveloppe*
    Call GETEXE([M:HAE0]CPY,TYPLEDGDD,[F:ENV]REASTR,ENVFIY) From CPTSUB
    If EXERCICE > ENVFIY
     Filter [ENV2] Where ENVORG=[F:ENV]ENV
     Read [ENV2]ENV0 First
     Filter [ENV2]
     If ! fstat
      # L'enveloppe a été reconduie et son enveloppe de réception est [F:ENV2]ENV
      #04/10/10 Mais ?! existe-t-il une ligne budgétaire correspondant au besoin ici
      If !clalev([BUD2]) : Local File BUD [BUD2] : Endif
      Filter [BUD2] Where evalue('CCE'+num$(INDENV))=[F:ENV2]ENV
&      & evalue('CCE'+num$(INDENT))=evalue("[M:VTL]CCE"+num$(ENTDIENUM2)+"("+num$(I)+")")
&      & ACC=[L]ACCGDD & (STA=3 | STA=4) & LEDTYP=TYPLEDGDD & CPY=[M:HAE0]CPY & FIY=EXERCICE
&      & (FCY=[M:VTL]FCY | FCY="")
      Look [BUD2] First
      Filter [BUD2]
      If fstat
       # Aucune ligne budgétaire appropriée et approuvée dans l'enveloppe de reception XXXXX
       Call ECR_TRACE(mess(260,108,1)-[F:ENV2]ENV,1) From GESECRAN
       GOK = 0 : STAT = 20 : Break
      Endif
      Assign ("[M:VTL]CCE"+num$(ENVDIENUM2)+"("+num$(I)+")") With [F:ENV2]ENV
     Else
      # L'enveloppe $1$ n'a pas été reconduite
      ERRMSG = mess(261,108,1)
      Call DYNAMIC(ERRMSG,"$1$",[F:ENV]ENV) From TEXTE
      Call ECR_TRACE(ERRMSG,1) From GESECRAN
      GOK = 0 : STAT = 20 : Break
     Endif

    Endif :# EXERCICE <> ENVFIY

   Else

    #==========================
    # Enveloppe Pluri-Annuelle
    #==========================
    Call GETEXE([M:HAE0]CPY,TYPLEDGDD,[F:ENV]REASTR,ENVFIYSTR) From CPTSUB
    Call GETEXE([M:HAE0]CPY,TYPLEDGDD,[F:ENV]REAEND,ENVFIYEND) From CPTSUB

    #Vérification que l'enveloppe a bien été définie sur l'exercice en cours et qu'elle a des LB approuvées sur ce dernier.
    If EXERCICE>ENVFIYEND
     #Exercice budgétaire $1$ inexistant sur l'enveloppe
     ERRMSG = mess(272,108,1)-[F:ENV]ENV
     Call DYNAMIC(ERRMSG,"$1$",FIYINFO) From TEXTE
     Call ECR_TRACE(ERRMSG,1) From GESECRAN
     GOK=0 : STAT = 20 : Break
  Else
     # Existe-t-il une ligne budgétaire correspondant au besoin ici ?
     If !clalev([ENF]) : Local File ENVFIY [ENF] : Endif
     Filter [ENF] Where ENV=[F:ENV]ENV & FIYNUM=EXERCICE & STAFIY=3
     Look [ENF] First
     Filter [ENF]
     If fstat
      #Exercice budgétaire $1$ inexistant sur l'enveloppe
      ERRMSG = mess(272,108,1)-[F:ENV]ENV
      Call DYNAMIC(ERRMSG,"$1$",FIYINFO) From TEXTE
      Call ECR_TRACE(ERRMSG,1) From GESECRAN
      GOK=0 : STAT = 20 : Break
     Endif
     If !clalev([BUD2]) : Local File BUD [BUD2] : Endif
     Filter [BUD2] Where evalue('CCE'+num$(INDENV))=[F:ENV]ENV
&     & evalue('CCE'+num$(INDENT))=evalue("[M:VTL]CCE"+num$(ENTDIENUM2)+"("+num$(I)+")")
&     & ACC=ACCGDD & (STA=3 | STA=4) & LEDTYP=TYPLEDGDD & CPY=[M:HAE0]CPY
&     & FIY=EXERCICE & (FCY=[M:VTL]FCYLIN(I) | FCY="")
     Look [BUD2] First
     Filter [BUD2]
     If fstat
      # Enveloppe $1$ : aucune ligne budgétaire appropriée et approuvée sur l'exercice
      ERRMSG = mess(273,108,1)-FIYINFO
      Call DYNAMIC(ERRMSG,"$1$",[F:ENV]ENV) From TEXTE
      Call ECR_TRACE(ERRMSG,1) From GESECRAN
      GOK = 0 : STAT = 20 : Break
     Endif
    Endif
   Endif :#Annuelle/Pluri-Annuelle
  Endif :# Read [ENV]
 Next
 If GOK=0 : Return : Endif
Endif


#----------------------------------------------#
# Pour le masque de ventilation analytique VT2 #
#-----------------------------------------#
ENVDIENUM3 = find(ENVDIE,[M:VT2]TBDIE(0..dim([M:VT2]TBDIE)-1))
ENTDIENUM3 = find(ENTDIE,[M:VT2]TBDIE(0..dim([M:VT2]TBDIE)-1))

If ENVDIENUM3 & ENTDIENUM3 & dim([M:VT2]PTVENT)
 Local Libelle X
 Local Char ENVCUR(GLONENV),ENTCUR(GLONENT)

# In [M:VT2], the fields with index 0 are empty
 For I=0 To [M:VT2]PTVENT
  ENVCUR = evalue("[M:VT2]TBCCE"+num$(ENVDIENUM3)+"("+num$(I)+")")
  ENTCUR = evalue("[M:VT2]TBCCE"+num$(ENTDIENUM3)+"("+num$(I)+")")
  If ENVCUR <> ""
   Read [ENV]ENV0 = ENVCUR
   If !fstat
    Raz ACCGDD
#------------------------------------------------#
    #  Recherche du compte analytique
    For X=0 To [M:HAE2]NBLIG-1
     If I>= [M:HAE2]PTV(X) & I<=[M:HAE2]PTF(X)
      ACCGDD = evalue("[M:HAE2]ACC"+num$(TYPLEDGDD)+"("+num$(X)+")")
      Break
     Endif
    Next
    If ACCGDD="" : Break : Endif
    #------------------------------------------------#
    Call LECTURE("BUT",[F:ENV]BUDTYP,"") From CONTOBJ
    If [F:BUT]YEAFLG=1 :# ssi Annuelle
     # Vérifier la cohérence entre la date passée et la date de l'enveloppe*
     Call GETEXE([M:HAE0]CPY,TYPLEDGDD,[F:ENV]REASTR,ENVFIY) From CPTSUB
     If EXERCICE > ENVFIY
      Filter [ENV2] Where ENVORG=ENVCUR
      Read [ENV2]ENV0 First
      Filter [ENV2]
      If !fstat
       # L'enveloppe a été reconduite et son enveloppe de réception est [F:ENV2]ENV
       #04/10/10 Mais ?! existe-t-il une ligne budgétaire correspondant au besoin ici
       If !clalev([BUD2]) : Local File BUD [BUD2] : Endif
       Filter [BUD2] Where evalue('CCE'+num$(INDENV))=[F:ENV2]ENV
&       & evalue('CCE'+num$(INDENT))=ENTCUR & (STA=3 | STA=4) & ACC=ACCGDD
&       & LEDTYP=TYPLEDGDD & CPY=[M:HAE0]CPY & FIY=EXERCICE & (FCY=[M:HAE2]FCYLIN(X) | FCY="")
       Look [BUD2] First
       Filter [BUD2]
       If fstat
        # Aucune ligne budgétaire appropriée et approuvée dans l'enveloppe de réception XXXXX
        Call ECR_TRACE(mess(260,108,1)-[F:ENV2]ENV-"compte"-ACCGDD,1) From GESECRAN
        GOK = 0 : STAT = 20 : Break
       Endif
       Assign ("[M:VT2]TBCCE"+num$(ENVDIENUM3)+"("+num$(I)+")") With [F:ENV2]ENV
      Else
       # L'enveloppe $1$ n'a pas été reconduite
       ERRMSG = mess(261,108,1)
       Call DYNAMIC(ERRMSG,"$1$",[F:ENV]ENV) From TEXTE
       Call ECR_TRACE(ERRMSG,1) From GESECRAN
       GOK = 0 : STAT = 20 : Break
      Endif
     Endif :# EXERCICE <> ENVFIY

    Else

     #==========================
     # Enveloppe Pluri-Annuelle
     #==========================
     Call GETEXE([M:HAE0]CPY,TYPLEDGDD,[F:ENV]REASTR,ENVFIYSTR) From CPTSUB
     Call GETEXE([M:HAE0]CPY,TYPLEDGDD,[F:ENV]REAEND,ENVFIYEND) From CPTSUB

     #Vérification que l'enveloppe ait bien été définie sur l'exercice en cours et qu'elle des LB approuvées sur ce dernier.
     If EXERCICE>ENVFIYEND
      #Exercice budgétaire $1$ inexistant sur l'enveloppe
      ERRMSG = mess(272,108,1)-[F:ENV]ENV
      Call DYNAMIC(ERRMSG,"$1$",FIYINFO) From TEXTE
      Call ECR_TRACE(ERRMSG,1) From GESECRAN
      GOK=0 : STAT = 20 : Break
     Else
      # Existe-t-il une ligne budgétaire correspondant au besoin ici ?
      If !clalev([ENF]) : Local File ENVFIY [ENF] : Endif
      Filter [ENF] Where ENV=ENVCUR & FIYNUM=EXERCICE & STAFIY=3
      Look [ENF] First
      Filter [ENF]
      If fstat
       #Exercice budgétaire $1$ inexistant sur l'enveloppe
       ERRMSG = mess(272,108,1)-[F:ENV]ENV
       Call DYNAMIC(ERRMSG,"$1$",FIYINFO) From TEXTE
       Call ECR_TRACE(ERRMSG,1) From GESECRAN
       GOK = 0 : STAT = 20 : Break
      Endif
      If !clalev([BUD2]) : Local File BUD [BUD2] : Endif
      Filter [BUD2] Where evalue('CCE'+num$(INDENV))=ENVCUR
&      & evalue('CCE'+num$(INDENT))=ENTCUR & (STA=3 | STA=4) & ACC=ACCGDD & LEDTYP=TYPLEDGDD
&      & CPY=[M:HAE0]CPY & FIY=EXERCICE & (FCY=[M:HAE2]FCYLIN(X) | FCY="")
      Look [BUD2] First
      Filter [BUD2]
      If fstat
       # Enveloppe $1$ : aucune ligne budgétaire appropriée et approuvée sur l'exercice
       ERRMSG = mess(273,108,1)-FIYINFO
       Call DYNAMIC(ERRMSG,"$1$",[F:ENV]ENV) From TEXTE
       Call ECR_TRACE(ERRMSG,1) From GESECRAN
       GOK = 0 : STAT = 20 : Break
      Endif
     Endif
    Endif :#Annuelle/Pluri-Annuelle
   Endif :# Read [ENV]
  Endif
 Next
 If GOK=0 : Return : Endif
Endif
Return


#----------------------------------------------------------------
# Subprog appelé depuis les Traitements FUNPTH & FUNPNH
#----------------------------------------------------------------
# Gestion des FAR/AAR Demande création sur N / extourne sur N+1
# APRES report des engagements :
# -Date de commande sur N et enveloppe sur N+1 !!
#  =>il est nécessaire d'intervenir en cours de traitement FUNPxH
#    pour éviter un contrôle bloquant sur l'incohérence de date
#    entre la commande et l'enveloppe
# -CMM :on doit désengager sur N+1 puisque le report à eu lieu
# -BUD :on doit désengager sur N pour garde une cohérence budgétaire
# Pour l'extourne, on va:
# -CMM : engager sur N+1
# -BUD : engager sur N+1
#----------------------------------------------------------------
# Donc ici on remet l'enveloppe N à la place de l'enveloppe N+1
# dans le cas de la FAR ou AAR apres report
# Il faudra reprendre la main dans CPTENG pour appliquer les bonnes
# lignes d'engagement et imputations budgétaires
#----------------------------------------------------------------
Subprog BUOENV_SWITCH(CAS,CPY,DAT,TBDIE,TBCCE,TRACE)
Value Integer CAS
Value Char CPY()
Value Date DAT
Value Char TBDIE()(1..)
Variable Char TBCCE()(1..)
Variable Integer TRACE

#CAS: origine de l'appel
#1=>FUNPTH Facture à recevoir
#2=>FUNPNH Avoir à recevoir

If !func AFNC.ACTIV("GDD") : End : Endif

#Usefull variables
Local Integer TYPLEDGDD
Local Char LEDGDD(GLONLED), ENVDIE(GLONDIE), ENTDIE(GLONENT), COAGDD(GLONCOA),MESSA(250)
Local Integer ENVDIENUM, ENTDIENUM
Local Decimal PERIODE, ENVFIY,EXERCICE
Local Char FIYINFO(GLONSHO+6)

#Usefull tabs
If !clalev([ENV])  : Local File ENVELOPPE [ENV] : Endif
If !clalev([ENV2]) : Local File ENVELOPPE [ENV2]: Endif
If !clalev([BUT])  : Local File BUDTYP    [BUT] : Endif

Call GETLEDGDD([L]CPY,TYPLEDGDD,LEDGDD)

#-------------------------------------------------------------------------------------------
# 85831 Cas où la FAR est générée d'un mois sur l'autre :
# Commande est sur N avec une enveloppe sur N. Réception sur N. L'enveloppe est reconduite en N+1.
# La FAR de fin d'exercice est générée avec l'extourne => il faut changer l'enveloppe
# Puis en Janvier N+1 on génère la FAR sur le mois suivant => il ne faut pas changer l'enveloppe
#-------------------------------------------------------------------------------------------
If [M:DIA]ACCDAT<>[0/0/0] & [M:DIA]EXTOURNE<>[0/0/0]
 Local Decimal EXO1, EXO2
 Call GETPERSOC([L]CPY,TYPLEDGDD,[M:DIA]ACCDAT,EXO1,PERIODE) From CPTSUB
 Call GETPERSOC([L]CPY,TYPLEDGDD,[M:DIA]EXTOURNE,EXO2,PERIODE) From CPTSUB
 If EXO1=EXO2 : End : Endif
Endif

Call GETPERSOC([L]CPY,TYPLEDGDD,[L]DAT,EXERCICE,PERIODE) From CPTSUB
Call LECPLAN([L]CPY,TYPLEDGDD,COAGDD) From CPTDIV

#Intitulé exercice
Read [FIY]FIY0 = [L]CPY;TYPLEDGDD;EXERCICE
If !fstat
 If [F:FIY]DESSHO<>""
  [L]FIYINFO  = num$(EXERCICE)-":"-[F:FIY]DESSHO
 Else
  [L]FIYINFO  = num$(EXERCICE)
 Endif
Endif

Call GETENVDIE(LEDGDD,ENVDIE)
If ENVDIE="" : End : Endif
Call GETENTDIE(LEDGDD,ENTDIE)
If ENTDIE="" : End : Endif

ENVDIENUM = find(ENVDIE,TBDIE(1..dim(TBDIE)))
ENTDIENUM = find(ENTDIE,TBDIE(1..dim(TBDIE)))

If ENVDIENUM & ENTDIENUM
 Read [ENV]ENV0 = TBCCE(ENVDIENUM)
 If !fstat
  Call LECTURE("BUT",[F:ENV]BUDTYP,"") From CONTOBJ
  If [F:BUT]YEAFLG=1 :# ssi Annuelle
   # Vérifier la cohérence entre la date passée et la date de l'enveloppe*
   Call GETEXE([L]CPY,TYPLEDGDD,[F:ENV]REASTR,ENVFIY) From CPTSUB
   #
   If EXERCICE < ENVFIY
    If [F:ENV]ENVORG <> ""
     Read [ENV2]ENV0 = [F:ENV]ENVORG
     If !fstat & DAT>=[F:ENV2]REASTR & DAT<=[F:ENV2]REAEND
      # L'enveloppe possède bien une enveloppe d'origine
      # et donc l'enveloppe de réception est [F:ENV]ENVORG ou [F:ENV2]ENV
      TBCCE(ENVDIENUM) = [F:ENV2]ENV
     Else
      # L'enveloppe $1$ n'a pas d'enveloppe d'origine sur l'exercice $2$
      MESSA=mess(262,108,1)
      Call DYNAMIC(MESSA,"$1$",[F:ENV]ENV) From TEXTE
      Call DYNAMIC(MESSA,"$2$",[L]FIYINFO) From TEXTE
      If TRACE=2
       Call ECR_TRACE (MESSA,1) From GESECRAN
      Endif
      End
     Endif
    Endif
   Endif
  Endif
 Endif
Endif
End


Subprog GETLEDGDD(SOCIETE,TYPLEDGDD,LEDGDD)
Value Char SOCIETE
Variable Integer TYPLEDGDD
Variable Char LEDGDD
#-----------------------------------------------------------------#
# Renvoie LE référentiel flagué Budget opérationnel de la société #
#-----------------------------------------------------------------#
If !clalev([F:LED]) : Local File GLED [LED] : Endif
Local Char    MODELE(GLONGCM)
Local Integer IGCM, IREF
Call SETGCM(SOCIETE,MODELE) From CPTDIV
IGCM   = find(MODELE,GGCM(1..GGCMNBR))
If !IGCM
 Call GLOBVAR From SETGLBGCM
 IGCM   = find(MODELE,GGCM(1..GGCMNBR))
Endif
TYPLEDGDD=0
LEDGDD=""
If IGCM
 For IREF=1 To len(mess(0,2644,1))
  Read [LED]LED0 = evalue("GLED"+num$(IREF)+"("+num$(IGCM)+")")
  If !fstat & [F:LED]GDD=2
   TYPLEDGDD = IREF
   LEDGDD = [F:LED]LED : Break
  Endif
 Next
Endif
End

#------------------------------------------------------------------#
# Renvoie l'axe flagué Enveloppe du référentiel passé en paramètre
#------------------------------------------------------------------#
Subprog GETENVDIE(LEDGER,ENVDIE)
Value Char LEDGER
Variable Char ENVDIE
If !clalev([F:DIE]) : Local File GDIE [DIE] : Endif
If !clalev([F:LED]) : Local File GLED [LED] : Endif
ENVDIE=""
Call LEC_LED(LEDGER) From CPTLEC
For I=0 To [F:LED]DIENBR-1
 Read [DIE]DIE0 = [F:LED]DIE(I)
 If !fstat & [F:DIE]ENV=2
  ENVDIE=[F:DIE]DIE : Break
 Endif
Next
End

#---------------------------------------------------------------#
## Renvoie l'axe flagué Entité du référentiel passé en paramètre
#---------------------------------------------------------------#
Subprog GETENTDIE(LEDGER,ENTDIE)
Value Char LEDGER
Variable Char ENTDIE
ENTDIE=""
If !clalev([F:DIE]) : Local File GDIE [DIE] : Endif
If !clalev([F:LED]) : Local File GLED [LED] : Endif
Call LEC_LED(LEDGER) From CPTLEC
For I=0 To [F:LED]DIENBR-1
 Read [DIE]DIE0 = [F:LED]DIE(I)
 If !fstat & [F:DIE]ENT=2
  ENTDIE=[F:DIE]DIE : Break
 Endif
Next
End

#---------------------------------------------------------------#
## Get the index of the envelopp dimension, entity dimension
#  and third dimension for the operating budgets
#---------------------------------------------------------------#
Subprog GETGDDINDDIE(CPY,DIECCE3,INDENV,INDENT,INDCCE3)
Value    Char    CPY
Value    Char    DIECCE3()
Variable Integer INDENV
Variable Integer INDENT
Variable Integer INDCCE3

Local Char    LEDCOD(GLONLED)
Local Integer TYPCOD

If !clalev([F:DIE]) : Local File GDIE [DIE] : Endif
If !clalev([F:LED]) : Local File GLED [LED] : Endif

INDENV = 0
INDENT = 0
INDCCE3 = 0

Call GETLEDGDD(CPY,TYPCOD,LEDCOD)
Call LEC_LED(LEDCOD) From CPTLEC

For I=0 To [F:LED]DIENBR-1
 Read [DIE]DIE0 = [F:LED]DIE(I)
 If !fstat
  If [F:DIE]ENV=2 : INDENV = I+1 : Endif
  If [F:DIE]ENT=2 : INDENT = I+1 : Endif
  If DIECCE3<>"" & [F:DIE]DIE=DIECCE3 : INDCCE3=I+1 : Endif
 Endif
Next
End

###################################################################################################
## Actions d'approbation appelée depuis L'enveloppe ou le budget exercice ou la ligne budgétaire ##
###################################################################################################

#------------------------#
# Soumission Approbation #
#------------------------#
Subprog APPROBAT(NIVEAU,ENV,EXE,NUMERO,MGFMOD)
Value Integer NIVEAU
Value Char    ENV
Value Integer EXE
Value Integer NUMERO
Value Integer MGFMOD :#Nouveau paramètre permettant de savoir d'où l'on appel ce sousprog (depuis les objets '2' ou depuis la fonction de soumission '1')
# Si appel de la fonction Approbation à partir de la gestion des enveloppes, GCHKAPP existe
# Elle permet de repasser dans le SETBOUT de la gestion des enveloppes
Case NIVEAU
 When 1 : Call APPENV(ENV,MGFMOD)
          If dim(GCHKAPP)>0 : GCHKAPP=1 : mkstat=4 : Endif
 When 2 : Call APPBUD(ENV,EXE,MGFMOD)
          If dim(GCHKAPP)>0 : GCHKAPP=1 : mkstat=4 : Endif
When 3 : Call APPLIG(NUMERO,MGFMOD,ENV)
Endcase
End

#---------------------------------------#
# Soumission Approbation de l'enveloppe #
#---------------------------------------#
Subprog APPENV(ENVELOPPE,MGFMOD)
Value Char    ENVELOPPE()
Value Integer MGFMOD
Local Integer REPONSE
Local Integer INDENV, INDENT, INDCCE3

If !clalev([ENV]) : Local File ENVELOPPE [ENV] : Endif
If !clalev([BUD]) : Local File BUD       [BUD] : Endif
If !clalev([ENF]) : Local File ENVFIY    [ENF] : Endif
#Parmètrage approbation
Local Char APPNIV(3)
Call GETAPPNIV(ENVELOPPE,APPNIV)

 #Cas ou on est dans la gestion des enveloppes
 #comme il n'y a pas de rafraichissement il faut interdire de faire deux fois la manip ici
 If MGFMOD=2
  Read [ENV]ENV0 = ENVELOPPE
  If !fstat
   If [F:ENV]STA=2
    #Objet déjà soumis pour approbation
    Call MESSAGE(mess(228,108,1)) From GESECRAN
    End
   Endif
  Endif
 Endif

Trbegin [ENV]
 Readlock [ENV]ENV0 = ENVELOPPE
 If fstat=1
  GOK=-1 : GLOCK="$ENV"-ENVELOPPE
 Elsif !fstat & [F:ENV]STA=1
  [F:ENV]STA=2
  Rewrite [ENV]
  If fstat
   GOK=0 : Call FSTA("ENV") From GLOCK
  Endif
 Endif
 If   GOK<0
  Gosub ABANDON
  Call ROLL From GLOCK
  If !GROLL : Call APPENV(ENVELOPPE,MGFMOD) : Endif
 Elsif !GOK : Goto ABANDON
 Endif
 Unlock [ENV]
Commit

Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD

#Passage du status des budgets et des lignes budgétaires à "à approuver" selon le paramètrage
If APPNIV="212" | APPNIV="211"
 For [ENF]ENF0 Where ENV=ENVELOPPE & STAFIY=1
  Trbegin [ENF]
   Readlock [ENF]ENF0=[F:ENF]ENV;[F:ENF]FIYNUM
   If fstat=1
    GOK=-1 : GLOCK="$ENF"-[F:ENF]ENV-[F:ENF]FIYNUM
   Elsif !fstat
    [F:ENF]STAFIY=2
    Rewrite [ENF]
    If fstat
     GOK=0 : Call FSTA("enf") From GLOCK
    Endif
   Endif
   If   GOK<0
    Gosub ABANDON
    Call ROLL From GLOCK
    If !GROLL : Call APPENV(ENVELOPPE,MGFMOD) : Endif
   Elsif !GOK : Goto ABANDON
   Endif
   Unlock [BUD]
  Commit
  If APPNIV="211"
   For [BUD]BUD0 Where evalue('CCE'+num$(INDENV))=ENVELOPPE & FIY=[F:ENF]FIYNUM & STA=1
    Trbegin [BUD]
     Readlock [BUD]BUD1=[F:BUD]ACCNUM
     If fstat=1
      GOK=-1 : GLOCK="$BUD"-[F:BUD]ACCNUM
     Elsif !fstat
      [F:BUD]STA=2
      Rewrite [BUD]
      If fstat
       GOK=0 : Call FSTA("BUD") From GLOCK
      Endif
     Endif
     If   GOK<0
      Gosub ABANDON
      Call ROLL From GLOCK
      If !GROLL : Call APPENV(ENVELOPPE,MGFMOD) : Endif
     Elsif !GOK : Goto ABANDON
     Endif
     Unlock [BUD]
    Commit
   Next
  Endif
 Next
Endif

#Création de l'approbation table BUDAPP
Local File BUDAPP [BOA]
Trbegin [BOA]
 Local Integer STAT
 Local Char NUMAPP
 Call NUMERO("BOA","",date$,"",[L]NUMAPP,STAT) From SUBANM
 [F:BOA]NUM    = [L]NUMAPP
 [F:BOA]TYP    = 1
 [F:BOA]ENV    = ENVELOPPE
 [F:BOA]PRJ    = [F:ENV]PRJ
 [F:BOA]STA    = 2
 [F:BOA]AMT    = [F:ENV]AMTENV
 [F:BOA]CUR    = [F:ENV]CURENV
 [F:BOA]DMDDAT = date$
 [F:BOA]CREDAT = date$
 [F:BOA]CREUSR = GUSER
 Write [BOA]
 If fstat
  GOK=0 : Call FSTA("BOA") From GLOCK
 Endif
 If   GOK<0 : Goto ABANDON
 Elsif !GOK : Goto ABANDON
 Endif
Commit
Call WORKFLOW(1,"APP","","") From AWRK
End

#-------------------------------------------#
# Soumission Approbation du budget exercice #
#-------------------------------------------#
Subprog APPBUD(ENVELOPPE,EXERCICE,MGFMOD)
Value Char    ENVELOPPE()
Value Integer EXERCICE
Value Integer MGFMOD
Local Integer OK
Local Integer INDENV, INDENT, INDCCE3

If !clalev([ENV]) : Local File ENVELOPPE [ENV] : Endif
If !clalev([BUD]) : Local File BUD       [BUD] : Endif
If !clalev([ENF]) : Local File ENVFIY    [ENF] : Endif
# Contrôle :
# Le demande d'approbation du budget exercice ne peut être déclenchée que s'il appartient à
# une Enveloppe budgétaire "approuvée" ou s'il n'y a pas d'approbation gérée au niveau Enveloppe
Local Char APPNIV(3)
Call GETAPPNIV(ENVELOPPE,APPNIV)
OK=0

 #Cas ou on est dans le tableau des lignes et que l'on sousmet pour approbation
 #comme il n'y a pas de rafraichissement il faut interdire de faire deux fois la manip ici
 If MGFMOD=2
  Read [ENF]ENF0 = ENVELOPPE;EXERCICE
  If !fstat
   If [F:ENF]STAFIY=2
    #Objet déjà soumis pour approbation
    Call MESSAGE(mess(228,108,1)) From GESECRAN
    End
   Endif
  Endif
 Endif

Case APPNIV
 When "122","121" : OK=1
 When "221","222" : If [F:ENV]STA=3 : OK=1 : Endif
 When Default
  #L'approbation du budget exercice ne peut être faite avec ce paramètrage
  GMESSAGE=mess(125,108,1)
  End
Endcase

If OK | MGFMOD=1
 Trbegin [ENF]
  #Passage du status du budget exercice à "à approuver"
  Readlock [ENF]ENF0 = ENVELOPPE;EXERCICE
  If fstat=1
   GOK=-1 : GLOCK="$ENF"-ENVELOPPE-EXERCICE
  Elsif !fstat & [F:ENF]STAFIY=1
   [F:ENF]STAFIY=2
   Rewrite [ENF]
   If fstat
    GOK=0 : Call FSTA("ENF") From GLOCK
   Endif
   If   GOK<0 : Goto ABANDON
   Elsif !GOK : Goto ABANDON
   Endif
   #Cas ou on est dans le tableau des lignes et que l'on soumet pour approbation
   #comme il n'y a pas de rafraichissement il faut griser les zones et changer ici le statut
   If MGFMOD=2
    [M:ENV1]STAFIY(nolign-1)=2
    Affzo [M:ENV1]STAFIY(nolign-1)
    Gosub GRIZ_TAB_BUD From SUBENV
   Endif
  Endif
  Unlock [ENF]
 Commit
 #passage du status de la ligne budgétaire à "à approuver" selon le paramètrage
 If APPNIV="121" | APPNIV="221"
  Call LEC_ENV(ENVELOPPE) From CPTLEC
  Call GETGDDINDDIE([F:ENV]ENVELOPPE,"",INDENV,INDENT,INDCCE3) From TRTGDD
  For [BUD]BUD0 Where evalue('CCE'+num$(INDENV))=ENVELOPPE & FIY=EXERCICE & STA=1
   Trbegin [BUD]
    Readlock [BUD]BUD1=[F:BUD]ACCNUM
    If fstat=1
     GOK=-1 : GLOCK="$BUD"-[F:BUD]ACCNUM
    Elsif !fstat
     [F:BUD]STA=2
     Rewrite [BUD]
     If fstat
      GOK=0 : Call FSTA("BUD") From GLOCK
     Endif
    Endif
    If   GOK<0
     Gosub ABANDON
     Call ROLL From GLOCK
     If !GROLL : Call APPBUD(ENVELOPPE,EXERCICE,MGFMOD) : Endif
    Elsif !GOK : Goto ABANDON
    Endif
    Unlock [BUD]
   Commit
  Next
 Endif

 #Workflow
 Call LECTURE("ENV",ENVELOPPE,"") From CONTOBJ

 #Création de l'approbation table BUDAPP
 Local File BUDAPP [BOA]
 Trbegin [BOA]
  Local Integer STAT
  Local Char NUMAPP
  Call NUMERO("BOA","",date$,"",[L]NUMAPP,STAT) From SUBANM
  [F:BOA]NUM    = [L]NUMAPP
  [F:BOA]TYP    = 2
  [F:BOA]ENV    = ENVELOPPE
  [F:BOA]PRJ    = [F:ENV]PRJ
  [F:BOA]STA    = 2
  [F:BOA]FIY    = EXERCICE
  [F:BOA]CUR    = [F:ENV]CURENV
  [F:BOA]AMT    = [F:ENF]AMTBUDFIY
  [F:BOA]DMDDAT = date$
  [F:BOA]CREDAT = date$
  [F:BOA]CREUSR = GUSER
  Write [BOA]
  If fstat
   GOK=0 : Call FSTA("BOA") From GLOCK
  Endif
  If   GOK<0 : Goto ABANDON
  Elsif !GOK : Goto ABANDON
  Endif
 Commit
 Call WORKFLOW(1,"APP","","") From AWRK
Else
 #L'enveloppe doit être approuvée pour approuvée ce budget exercice
 Call MESSAGE(mess(126,108,1)) From GESECRAN
Endif
End

#-----------------------------------------------#
# Soumission Approbation de la ligne budgétaire #
#-----------------------------------------------#
Subprog APPLIG(ACCNUM,MGFMOD,ENV)
Value Integer ACCNUM
Value Integer MGFMOD
Value Char    ENV

Read [BUD]BUD1=ACCNUM
If !fstat
 Local Integer OK,REPONSE,EXERCICE,DEBAPP
 If !clalev([ENV]) : Local File ENVELOPPE [ENV] : Endif
 If !clalev([BUD]) : Local File BUD       [BUD] : Endif
 If !clalev([ENF]) : Local File ENVFIY    [ENF] : Endif
 Local Char APPNIV(3),ENVELOPPE
 ENVELOPPE = ENV
 EXERCICE  = [F:BUD]FIY

 #Cas ou on est dans le tableau des lignes et que l'on sousmet pour approbation
 #comme il n'y a pas de rafraichissement il faut interdire de faire deux fois la manip ici
 If MGFMOD=2
  Read [BUD]BUD1=ACCNUM
  If !fstat
   If [F:BUD]STA=2
    #Objet déjà soumis pour approbation
    Call MESSAGE(mess(228,108,1)) From GESECRAN
    End
   Endif
  Endif
 Endif

 Call GETAPPNIV(ENVELOPPE,APPNIV)

 #Paramètre de bébrayage en fonction de l'utilisateur
 Local Integer DEBAPP
 Local Char PARDEBAPP
 If func AFNC.ACTIV("GDD")   # Issue X3-107197
  Call PARAMUTIL("GDDDEBAPP",PARDEBAPP,"","") From SUBAUS
 Endif   # Issue X3-107197
 DEBAPP=val(PARDEBAPP)

 Call LECTURE("ENF",ENVELOPPE,num$(EXERCICE)) From CONTOBJ
 OK=0
 Case APPNIV
  When "112" : OK=1
  When "122","222","212" : If [F:ENF]STAFIY=3 : OK=1 : Endif
  When Default
   #L'approbation de la ligne budgétaire ne peut être faite avec ce paramètrage
   Call MESSAGE(mess(127,108,1)) From GESECRAN
   End
 Endcase
 If OK | MGFMOD=1 | DEBAPP=2
  Trbegin [BUD]
   Readlock [BUD]BUD1=ACCNUM
   If fstat=1
    GOK=-1 : GLOCK="$BUD"-ACCNUM
   Elsif !fstat & [F:BUD]STA=1
    [F:BUD]STA=2
    Rewrite [BUD]
    If fstat
     GOK=0 : Call FSTA("BUD") From GLOCK
    Endif
    #Cas ou on est dans le tableau des lignes et que l'on sousmet pour approbation
    #comme il n'y a pas de rafraichissement il faut griser les zones et changer ici le statut
    If MGFMOD=2
     [M:BUDL]STA(nolign-1)=2
     Affzo [M:BUDL]STA(nolign-1)
     Gosub GESAFFZON From TRTBUL
    Endif
   Endif
   If   GOK<0
    Gosub ABANDON
    Call ROLL From GLOCK
    If !GROLL : Call APPLIG(ACCNUM,MGFMOD,ENVELOPPE) : Endif
   Elsif !GOK : Goto ABANDON
   Endif
   Unlock [BUD]
  Commit

  #Workflow
  Call LECTURE("ENV",ENVELOPPE,"") From CONTOBJ

  #Création de l'approbation table BUDAPP
  Local File BUDAPP [BOA]
  Trbegin [BOA]
   Local Integer STAT
   Local Char NUMAPP
   Call NUMERO("BOA","",date$,"",[L]NUMAPP,STAT) From SUBANM
   [F:BOA]NUM    = [L]NUMAPP
   [F:BOA]TYP    = 3
   [F:BOA]ENV    = ENVELOPPE
   [F:BOA]PRJ    = [F:ENV]PRJ
   [F:BOA]STA    = 2
   [F:BOA]FIY    = EXERCICE
   [F:BOA]ACCNUM = [F:BUD]ACCNUM
   [F:BOA]ACC    = [F:BUD]ACC
   [F:BOA]COA    = [F:BUD]COA
   [F:BOA]CUR    = [F:ENV]CURENV
   [F:BOA]AMT    = [F:BUD]AMT(0)
   [F:BOA]DMDDAT = date$
   [F:BOA]CREDAT = date$
   [F:BOA]CREUSR = GUSER
   Write [BOA]
   If fstat
    GOK=0 : Call FSTA("BOA") From GLOCK
   Endif
   If   GOK<0 : Goto ABANDON
   Elsif !GOK : Goto ABANDON
   Endif
  Commit
  Call WORKFLOW(1,"APP","","") From AWRK

 Else
  #Le budget exercice doit être approuvée pour approuvée la ligne budgétaire
  Call MESSAGE(mess(128,108,1)) From GESECRAN
 Endif
Endif
End

####################################################################################################


#-------------------------------------------------#
# Validation Approbation new avec table BUDAPP    #
#-------------------------------------------------#
Subprog VALAPPRO(NIVEAU,NUMAPP)
Value    Integer NIVEAU
Value    Char    NUMAPP

#nb: La transaction est lancée par le workflow

If !clalev([BOA]) : Local File BUDAPP     [BOA] : Endif
If !clalev([BAD]) : Local File BUDAPPDET  [BAD] : Endif
If !clalev([ENV]) : Local File ENVELOPPE  [ENV] : Endif
If !clalev([BUD]) : Local File BUD        [BUD] : Endif
If !clalev([ENF]) : Local File ENVFIY     [ENF] : Endif

Call LECTURE("BOA",NUMAPP,"") From CONTOBJ
Case NIVEAU
 When 1 :# Enveloppe
  Call VALAPPENV([F:BOA]ENV,[F:BOA]AMTAPP)
 When 2 :# Budget exercice
  Call VALAPPBUD([F:BOA]ENV,[F:BOA]FIY,[F:BOA]AMTAPP)
 When 3 :# Lignes budgétaires
  Call VALAPPLIG([F:BOA]ACCNUM,[F:BOA]AMTAPP,[F:BOA]ENV)
 When 4 :# Multiples
  Filter [BAD] Where NUMAPP=[L]NUMAPP
   For [BAD]BAD0
    Case [F:BAD]TYP
     When 1
      Call LECTURE("ENV",[F:BAD]ENV,"") From CONTOBJ
      If [F:ENV]STA=2 : Call VALAPPENV([F:BAD]ENV,0) : Endif
     When 2
      Read [ENF]ENF0 = [F:BAD]ENV;[F:BAD]FIY
      If !fstat & [F:ENF]STAFIY=2 : Call VALAPPBUD([F:BAD]ENV,[F:BAD]FIY,0) : Endif
     When 3
      Read [BUD]BUD1=[F:BAD]ACCNUM
      If !fstat & [F:BUD]STA=2 : Call VALAPPLIG([F:BAD]ACCNUM,0,[F:BAD]ENV) : Endif
    Endcase
   Next
  Filter [BAD]
Endcase

#Mise à jour de la table des approbation
Readlock [BOA]BOA0 = NUMAPP
If !fstat
 [F:BOA]STA = 3
 [F:BOA]UPDUSR = GUSER
 [F:BOA]UPDDAT = date$
 Rewrite [BOA]
 If fstat
  GOK=0 : Call FSTA("BOA") From GLOCK
 Endif
Endif
End

#----------------------------#
# Approbation de l'enveloppe #
#----------------------------#
Subprog VALAPPENV(ENVELOPPE,MONTANT)
Value Char    ENVELOPPE()
Value Decimal MONTANT
Local Char APPNIV(3)
Local Integer INDENV, INDENT, INDCCE3

Call GETAPPNIV(ENVELOPPE,APPNIV)
Case APPNIV
 When "211"
  Call VAL_ENV(ENVELOPPE,MONTANT)
  Gosub VAL_BUD_ENV
  Gosub VAL_LIG_ENV
 When "212"
  Call VAL_ENV(ENVELOPPE,MONTANT)
  Gosub VAL_BUD_ENV
 When "221","222"
  Call VAL_ENV(ENVELOPPE,MONTANT)
 When Default
  #Le paramètrage ne permet pas de valider l'enveloppe de cette manière
  Call MESSAGE(mess(129,108,1)) From GESECRAN
Endcase
End

Subprog VAL_ENV(ENVELOPPE,MONTANT)
Value Char    ENVELOPPE()
Value Decimal MONTANT

Readlock [ENV]ENV0 = ENVELOPPE
If fstat=1
 GOK=-1 : GLOCK="$ENV"-ENVELOPPE
Elsif !fstat
 If [F:ENV]AMTENV<>0 | [F:ENV]EXTBUD=2
  [F:ENV]STA=3
  If MONTANT<>0
   [F:ENV]AMTAPP=MONTANT
   [F:ENV]AMTENV=MONTANT
  Else
   [F:ENV]AMTAPP=[F:ENV]AMTENV
  Endif
  [F:ENV]APPDAT=date$
  Rewrite [ENV]
  If fstat
   GOK=0 : Call FSTA("ENV") From GLOCK
  Endif
 Else
  #Enveloppe non-approuvée car montant nul
  Call MESSAGE([F:ENV]ENV-mess(169,108,1)) From GESECRAN
 Endif
Endif
If   GOK<0
 Gosub ABANDON
 Call ROLL From GLOCK
 If !GROLL : Call VAL_ENV(ENVELOPPE,MONTANT) : Endif
Elsif !GOK : Goto ABANDON
Endif
Unlock [ENV]
End

$VAL_BUD_ENV
For [ENF]ENF0 Where ENV=[F:ENV]ENV
 If [F:ENF]AMTBUDFIY<>0 | [F:ENV]EXTBUD=2
  Readlock [ENF]ENF0=[F:ENF]ENV;[F:ENF]FIYNUM
  If fstat=1
    GOK=-1 : GLOCK="$ENF"-[F:ENV]ENV-[F:ENF]FIYNUM
  Elsif !fstat
   [F:ENF]STAFIY=3
   [F:ENF]AMTAPPFIY=[F:ENF]AMTBUDFIY
   [F:ENF]APPDATFIY=date$
   Rewrite [ENF]
   If fstat
    GOK=0 : Call FSTA("ENF") From GLOCK
   Endif
  Endif
  If   GOK<0
   Gosub ABANDON
   Call ROLL From GLOCK
   If !GROLL : Goto VAL_BUD_ENV : Endif
  Elsif !GOK : Goto ABANDON
  Endif
 Else
  #Budget non-approuvé car montant nul
  Call MESSAGE([F:ENV]ENV+";"+num$([F:ENF]FIYNUM)-mess(170,108,1)) From GESECRAN
 Endif
Next
Return

$VAL_LIG_ENV
Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD
For [BUD]BUD0 Where evalue('CCE'+num$(INDENV))=[F:ENV]ENV
 If [F:BUD]AMT(0)<>0 | [F:ENV]EXTBUD=2
  Readlock [BUD]BUD1=[F:BUD]ACCNUM
  If fstat=1
   GOK=-1 : GLOCK="$BUD"-[F:BUD]ACCNUM
  Elsif !fstat
   [F:BUD]STA=3
   [F:BUD]AMTAPP=[F:BUD]AMT(0)
   [F:BUD]APPDAT=date$
   Rewrite [BUD]
   If fstat
    GOK=0 : Call FSTA("BUD") From GLOCK
   Endif
  Endif
  If   GOK<0
   Gosub ABANDON
   Call ROLL From GLOCK
   If !GROLL : Goto VAL_LIG_ENV : Endif
  Elsif !GOK : Goto ABANDON
  Endif
  Unlock [BUD]
 Else
  #Ligne non-approuvée car montant nul
  Call MESSAGE(evalue('[F:BUD]CCE'+num$(INDENV))+";"+num$([F:BUD]FIY)+";"+[F:BUD]ACC-mess(171,108,1)) From GESECRAN
 Endif
Next
Return

#--------------------------------#
# Approbation du budget exercice #
#--------------------------------#
Subprog VALAPPBUD(ENVELOPPE,EXERCICE,MONTANT)
Value Char    ENVELOPPE()
Value Decimal MONTANT
Value Integer EXERCICE
Local Char APPNIV(3)
Local Integer INDENV, INDENT, INDCCE3

Call GETAPPNIV(ENVELOPPE,APPNIV)
Case APPNIV
 When "121","221"
  Call VAL_BUD(ENVELOPPE,EXERCICE,MONTANT)
  Gosub VAL_LIG_BUD
 When "122","222"
  Call VAL_BUD(ENVELOPPE,EXERCICE,MONTANT)
 When Default
  #Le paramètrage ne permet pas de valider le budget exercice de cette manière
  Call MESSAGE(mess(130,108,1)) From GESECRAN
Endcase
End

Subprog VAL_BUD(ENVELOPPE,EXERCICE,MONTANT)
Value Char    ENVELOPPE()
Value Decimal MONTANT
Value Integer EXERCICE

Readlock [ENF]ENF0=ENVELOPPE;EXERCICE
If fstat=1
 GOK=-1 : GLOCK="$ENF"-[F:ENV]ENV-[F:ENF]FIYNUM
Elsif !fstat
 If [F:ENF]AMTBUDFIY<>0 | [F:ENV]EXTBUD=2
  [F:ENF]STAFIY=3
  If MONTANT<>0
   [F:ENF]AMTAPPFIY=MONTANT
   [F:ENF]AMTBUDFIY=MONTANT
  Else
   [F:ENF]AMTAPPFIY=[F:ENF]AMTBUDFIY
  Endif
  [F:ENF]APPDATFIY=date$
  Rewrite [ENF]
  If fstat
   GOK=0 : Call FSTA("ENF") From GLOCK
  Endif
 Else
  #Budget non-approuvé car montant nul
  Call MESSAGE([F:ENV]ENV+";"+num$([F:ENF]FIYNUM)-mess(170,108,1)) From GESECRAN
 Endif
Endif
If GOK<0
 Gosub ABANDON
 Call ROLL From GLOCK
 If !GROLL : Call VAL_BUD(ENVELOPPE,EXERCICE,MONTANT) : Endif
Elsif !GOK : Goto ABANDON
Endif
Unlock [ENF]
End

$VAL_LIG_BUD
Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD
For [BUD]BUD0 Where evalue('CCE'+num$(INDENV))=[F:ENV]ENV & FIY=EXERCICE
 If [F:BUD]AMT(0)<>0 | [F:ENV]EXTBUD=2
  Readlock [BUD]BUD1=[F:BUD]ACCNUM
  If fstat=1
    GOK=-1 : GLOCK="$BUD"-[F:BUD]ACCNUM
  Elsif !fstat
   [F:BUD]STA=3
   [F:BUD]AMTAPP=[F:BUD]AMT(0)
   [F:BUD]APPDAT=date$
   Rewrite [BUD]
   If fstat
    GOK=0 : Call FSTA("BUD") From GLOCK
   Endif
  Endif
  If   GOK<0
   Gosub ABANDON
   Call ROLL From GLOCK
   If !GROLL : Goto VAL_LIG_BUD : Endif
  Elsif !GOK : Goto ABANDON
  Endif
  Unlock [BUD]
 Else
  #Ligne non-approuvée car montant nul
   Call MESSAGE([F:ENV]ENV+";"+[F:BUD]FIY+";"+[F:BUD]ACC-mess(171,108,1)) From GESECRAN
 Endif
Next
Return

#------------------------------------#
# Approbation de la ligne budgétaire #
#------------------------------------#
Subprog VALAPPLIG(ACCNUM,MONTANT,ENV)
Value Integer ACCNUM
Value Decimal MONTANT
Value Char    ENV

Readlock [BUD]BUD1=ACCNUM
If fstat=1
 GOK=-1 : GLOCK="$BUD"-[F:BUD]ACCNUM
Elsif !fstat
 Call LEC_ENV(ENV) From CPTLEC
 If [F:BUD]AMT(0)<>0 | [F:ENV]EXTBUD=2
  [F:BUD]STA=3
  If MONTANT<>0
   [F:BUD]AMT(0)=MONTANT
   [F:BUD]AMTAPP=MONTANT
  Else
   [F:BUD]AMTAPP=[F:BUD]AMT(0)
  Endif
  [F:BUD]APPDAT=date$
  Rewrite [BUD]
  If fstat
   GOK=0 : Call FSTA("BUD") From GLOCK
  Endif
 Else
  #Ligne non-approuvée car montant nul
  Call MESSAGE(ENV+";"+[F:BUD]FIY+";"+[F:BUD]ACC-mess(171,108,1)) From GESECRAN
 Endif
Endif
If GOK<0
 Gosub ABANDON
 Call ROLL From GLOCK
 If !GROLL : Call VALAPPLIG(ACCNUM,MONTANT,ENV) : Endif
Elsif !GOK : Goto ABANDON
Endif
Unlock [BUD]
End

####################################################################################################

#---------------------------------#
# Refus Approbation via BUDAPP #
#---------------------------------#
Subprog REFAPPRO(NIVEAU,NUMAPP)
Value    Integer NIVEAU
Value    Char    NUMAPP

#nb: La transaction est lancée par le workflow

If !clalev([BOA]) : Local File BUDAPP     [BOA] : Endif
If !clalev([BAD]) : Local File BUDAPPDET  [BAD] : Endif
If !clalev([ENV]) : Local File ENVELOPPE  [ENV] : Endif
If !clalev([BUD]) : Local File BUD        [BUD] : Endif
If !clalev([ENF]) : Local File ENVFIY     [ENF] : Endif

Call LECTURE("BOA",NUMAPP,"") From CONTOBJ
Case NIVEAU
 When 1
  Call REFAPPENV([F:BOA]ENV)
 When 2
  Call REFAPPBUD([F:BOA]ENV,[F:BOA]FIY)
 When 3
  Call REFAPPLIG([F:BOA]ACCNUM)
 When 4 :# Multiples
  Filter [BAD] Where NUMAPP=[L]NUMAPP
   For [BAD]BAD0
    Case [F:BAD]TYP
     When 1
      Call LECTURE("ENV",[F:BAD]ENV,"") From CONTOBJ
      If [F:ENV]STA=2 : Call REFAPPENV([F:BAD]ENV) : Endif
     When 2
      Read [ENF]ENF0 = [F:BAD]ENV;[F:BAD]FIY
      If !fstat & [F:ENF]STAFIY=2 : Call REFAPPBUD([F:BAD]ENV,[F:BAD]FIY) : Endif
     When 3
      Read [BUD]BUD1=[F:BAD]ACCNUM
      If !fstat & [F:BUD]STA=2 : Call REFAPPLIG([F:BAD]ACCNUM) : Endif
    Endcase
   Next
  Filter [BAD]
Endcase

#Mise à jour de la table des approbation
Readlock [BOA]BOA0 = NUMAPP
If !fstat
 [F:BOA]STA = 1
 [F:BOA]UPDUSR = GUSER
 [F:BOA]UPDDAT = date$
 Rewrite [BOA]
 If fstat
  GOK=0 : Call FSTA("BOA") From GLOCK
 Endif
Endif
End

#------------------------------------#
# Refus d'Approbation de l'enveloppe #
#------------------------------------#
Subprog REFAPPENV(ENVELOPPE)
Value Char    ENVELOPPE()
Local Char APPNIV(3)
Local Integer INDENV, INDENT, INDCCE3
Gosub REF_ENV
Gosub REF_BUD_ENV
Gosub REF_LIG_ENV
End

$REF_ENV
Readlock [ENV]ENV0 = ENVELOPPE
If fstat=1
 GOK=-1 : GLOCK="$ENV"-ENVELOPPE
Elsif !fstat & [F:ENV]STA=2
 [F:ENV]STA=1
 Rewrite [ENV]
 If fstat
  GOK=0 : Call FSTA("ENV") From GLOCK
 Endif
Endif
If GOK<0
 Gosub ABANDON
 Call ROLL From GLOCK
 If !GROLL : Goto REF_ENV : Endif
Elsif !GOK : Goto ABANDON
Endif
Unlock [ENV]
Return

$REF_BUD_ENV
For [ENF]ENF0 Where ENV=[F:ENV]ENV
 Readlock [ENF]ENF0=[F:ENF]ENV;[F:ENF]FIYNUM
 If fstat=1
  GOK=-1 : GLOCK="$ENF"-[F:ENV]ENV-[F:ENF]FIYNUM
 Elsif !fstat & [F:ENF]STAFIY=2
  [F:ENF]STAFIY=1
  Rewrite [ENF]
  If fstat
   GOK=0 : Call FSTA("ENF") From GLOCK
  Endif
 Endif
 If   GOK<0
  Gosub ABANDON
  Call ROLL From GLOCK
  If !GROLL : Goto REF_BUD_ENV : Endif
 Elsif !GOK : Goto ABANDON
 Endif
 Unlock [ENF]
Next
Return

$REF_LIG_ENV
Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD
For [BUD]BUD0 Where evalue('CCE'+num$(INDENV))=[F:ENV]ENV
 Readlock [BUD]BUD1=[F:BUD]ACCNUM
 If fstat=1
  GOK=-1 : GLOCK="$BUD"-[F:BUD]ACCNUM
 Elsif !fstat & [F:BUD]STA=2
  [F:BUD]STA=1
  Rewrite [BUD]
  If fstat
   GOK=0 : Call FSTA("BUD") From GLOCK
  Endif
 Endif
 If GOK<0
  Gosub ABANDON
  Call ROLL From GLOCK
  If !GROLL : Goto REF_LIG_ENV : Endif
 Elsif !GOK : Goto ABANDON
 Endif
 Unlock [BUD]
Next
Return

#----------------------------------------#
# Refus d'Approbation du budget exercice #
#----------------------------------------#
Subprog REFAPPBUD(ENVELOPPE,EXERCICE)
Value Char    ENVELOPPE()
Value Integer EXERCICE
Local Char APPNIV(3)
Local Integer INDENV, INDENT, INDCCE3
Gosub REF_BUD
Gosub REF_LIG_BUD
End

$REF_BUD
Readlock [ENF]ENF0=ENVELOPPE;EXERCICE
If fstat=1
 GOK=-1 : GLOCK="$ENF"-[F:ENV]ENV-[F:ENF]FIYNUM
Elsif !fstat & [F:ENF]STAFIY=2
 [F:ENF]STAFIY=1
 Rewrite [ENF]
 If fstat
  GOK=0 : Call FSTA("ENF") From GLOCK
 Endif
Endif
If GOK<0
 Gosub ABANDON
 Call ROLL From GLOCK
 If !GROLL : Goto REF_BUD : Endif
Elsif !GOK : Goto ABANDON
Endif
Unlock [ENF]
Return

$REF_LIG_BUD
Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD
For [BUD]BUD0 Where evalue('CCE'+num$(INDENV))=[F:ENV]ENV & FIY=EXERCICE
 Readlock [BUD]BUD1=[F:BUD]ACCNUM
 If fstat=1
  GOK=-1 : GLOCK="$BUD"-[F:BUD]ACCNUM
 Elsif !fstat & [F:BUD]STA=2
  [F:BUD]STA=1
  Rewrite [BUD]
  If fstat
   GOK=0 : Call FSTA("BUD") From GLOCK
  Endif
 Endif
 If GOK<0
  Gosub ABANDON
  Call ROLL From GLOCK
  If !GROLL : Goto REF_LIG_BUD : Endif
 Elsif !GOK : Goto ABANDON
 Endif
 Unlock [BUD]
Next
Return

#--------------------------------------------#
# Refus d'Approbation de la ligne budgétaire #
#--------------------------------------------#
Subprog REFAPPLIG(ACCNUM)
Value Integer ACCNUM

Readlock [BUD]BUD1=ACCNUM
If fstat=1
 GOK=-1 : GLOCK="$BUD"-[F:BUD]ACCNUM
Elsif !fstat & [F:BUD]STA=2
 [F:BUD]STA=1
 Rewrite [BUD]
 If fstat
  GOK=0 : Call FSTA("BUD") From GLOCK
 Endif
Endif
If GOK<0
 Gosub ABANDON
 Call ROLL From GLOCK
 If !GROLL : Call REFAPPLIG(ACCNUM) : Endif
Elsif !GOK : Goto ABANDON
Endif
Unlock [BUD]
End

####################################################################################################


############################################################################################################
## Actions de demande de révision appelée depuis L'enveloppe ou le budget exercice ou la ligne budgétaire ##
############################################################################################################

#---------------------#
# Demande de révision #
#---------------------#
Subprog REVISION(NIVEAU,NUMREV)
Value    Integer NIVEAU
Value    Char    NUMREV
If !clalev([ENV]) : Local File ENVELOPPE  [ENV] : Endif
If !clalev([BUD]) : Local File BUD        [BUD] : Endif
If !clalev([ENF]) : Local File ENVFIY     [ENF] : Endif
If !clalev([BRV]) : Local File BUDREV     [BRV] : Endif
Call LECTURE("BRV",NUMREV,"") From CONTOBJ
Case NIVEAU
 When 1 : Call WORKFLOW(1,"RVE","","") From AWRK
 When 2 : Call WORKFLOW(1,"RVB","","") From AWRK
 When 3 : Call WORKFLOW(1,"RVL","","") From AWRK
Endcase
End

##################################################
#---------------------#
# Validation révision #
#---------------------#
Subprog VALREV(NIVEAU,NUMREV)
Value    Integer NIVEAU
Value    Char    NUMREV

If !clalev([ENV]) : Local File ENVELOPPE  [ENV] : Endif
If !clalev([BUD]) : Local File BUD        [BUD] : Endif
If !clalev([ENF]) : Local File ENVFIY     [ENF] : Endif
If !clalev([BRV]) : Local File BUDREV     [BRV] : Endif
If !clalev([BVD]) : Local File BUDREVDET  [BVD] : Endif
Call LECTURE("BRV",NUMREV,"") From CONTOBJ
Case NIVEAU
 When 1 : Call VALREV_ENV([F:BRV]ENV,[F:BRV]AMTASK)
 When 2 : Call VALREV_BUD([F:BRV]ENV,[F:BRV]FIY,[F:BRV]AMTASK,[F:BRV]AMTPRS,[F:BRV]AMTRAL)
 When 3 : Call VALREV_LIG([F:BRV]ENV,[F:BRV]FIY,[F:BRV]ACCNUM,[F:BRV]AMTASK,[F:BRV]AMTPRS,[F:BRV]AMTRAL)
 When 4 :# Multiples
  Filter [BVD] Where NUMREV=[L]NUMREV
   For [BVD]BVD0
    Case [F:BVD]TYP
     When 1 : Call VALREV_ENV([F:BVD]ENV,[F:BVD]AMTASK)
     When 2 : Call VALREV_BUD([F:BVD]ENV,[F:BVD]FIY,[F:BVD]AMTASK,[F:BVD]AMTPRS,[F:BVD]AMTRAL)
     When 3 : Call VALREV_LIG([F:BVD]ENV,[F:BVD]FIY,[F:BVD]ACCNUM,[F:BVD]AMTASK,[F:BVD]AMTPRS,[F:BVD]AMTRAL)
    Endcase
   Next
  Filter [BVD]
Endcase

#Mise à jour de la table des révisions
If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR_VALREV
Else
 Gosub MJ_VALREV
Endif
End

$TR_VALREV
Trbegin [BRV]
 Gosub MJ_VALREV
 If GOK=-1 : Goto ROLL_VALREV
 Elsif GOK<1 : Goto AB_VALREV
 Endif
Commit
Return

$AB_VALREV
Rollback
Return

$ROLL_VALREV
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_VALREV : Endif

$MJ_VALREV
Readlock [BRV]BRV0 = NUMREV
If !fstat
 If [F:BRV]STA<>3
  [F:BRV]STA=3
  [F:BRV]UPDUSR = GUSER
  [F:BRV]UPDDAT = date$
  Rewrite [BRV]
  If fstat
   GOK=0 : Call FSTA("BRV") From GLOCK
  Endif
 Endif
Endif
Return

#-------------------------#
# Révision de l'enveloppe #
#-------------------------#
Subprog VALREV_ENV(ENVELOPPE,MONTANT)
Value Char    ENVELOPPE
Value Decimal MONTANT

Readlock [ENV]ENV0 = ENVELOPPE
If !fstat
 [F:ENV]AMTENV=MONTANT
 [F:ENV]REVDAT=date$
 Rewrite [ENV]
 If fstat
  GOK=0 : Call FSTA("ENV") From GLOCK
 Endif
Endif
If GOK<0
 Gosub ABANDON
 Call ROLL From GLOCK
 If !GROLL : Call VALREV_ENV(ENVELOPPE,MONTANT) : Endif
Elsif !GOK : Goto ABANDON
Unlock [ENV]
Endif
End

#-----------------------------#
# Révision du budget exercice #
#-----------------------------#
Subprog VALREV_BUD(ENVELOPPE,EXERCICE,MONTANT,RESERVE,RALLONGE)
Value Char    ENVELOPPE
Value Integer EXERCICE
Value Decimal MONTANT     :# Nouveau Montant accordé
Value Decimal RESERVE     :# Partie du montant accordé puisé dans la réserve du niveau supérieur
Value Decimal RALLONGE    :# Partie du montant accordé ayant était ajouté au niveau supérieur

Readlock [ENF]ENF0 = ENVELOPPE;EXERCICE
If !fstat
 [F:ENF]AMTBUDFIY=MONTANT
 [F:ENF]REVDATFIY=date$
 Rewrite [ENF]
 If fstat
  GOK=0 : Call FSTA("ENF") From GLOCK
 Endif

 If RALLONGE<>0 | RESERVE<>0
  Readlock [ENV]ENV0 = ENVELOPPE
  If !fstat
   [F:ENV]AMTENV+=RALLONGE
   [F:ENV]AMTRES-=RESERVE
   [F:ENV]REVDAT=date$
   Rewrite [ENV]
   If fstat
    GOK=0 : Call FSTA("ENV") From GLOCK
   Endif
  Endif
 Endif
Endif

If GOK<0
 Gosub ABANDON
 Call ROLL From GLOCK
 If !GROLL : Call VALREV_BUD(ENVELOPPE,EXERCICE,MONTANT,RESERVE,RALLONGE) : Endif
Elsif !GOK : Goto ABANDON
Endif
Unlock [ENF],[ENV],[BRV]
End

#---------------------------------#
# Révision de la ligne budgétaire #
#---------------------------------#
Subprog VALREV_LIG(ENVELOPPE,EXERCICE,ACCNUM,MONTANT,RESERVE,RALLONGE)
Value Char    ENVELOPPE
Value Integer EXERCICE
Value Integer ACCNUM
Value Decimal MONTANT
Value Decimal RESERVE
Value Decimal RALLONGE

Readlock [BUD]BUD1 = ACCNUM
If !fstat
 [F:BUD]AMT(0)=MONTANT
 #X3-101289 [F:BUD]AMTAPP=MONTANT #YYFIN_118713 : update approuved amount on budget lines
 [F:BUD]REVDAT=date$
 Rewrite [BUD]
 If fstat
  GOK=0 : Call FSTA("BUD") From GLOCK
 Endif

 If RALLONGE<>0 | RESERVE<>0
  Readlock [ENF]ENF0 = ENVELOPPE;EXERCICE
  If !fstat
   [F:ENF]AMTBUDFIY+=RALLONGE
   [F:ENF]AMTRESFIY-=RESERVE
   [F:ENF]REVDATFIY=date$
   Rewrite [ENF]
   If fstat
    GOK=0 : Call FSTA("ENF") From GLOCK
   Endif
  Endif
 Endif
Endif

If GOK<0
 Gosub ABANDON
 Call ROLL From GLOCK
 If !GROLL : Call VALREV_LIG(ENVELOPPE,EXERCICE,ACCNUM,MONTANT,RESERVE,RALLONGE) : Endif
Elsif !GOK : Goto ABANDON
Endif
Unlock [BUD],[ENF],[BRV]
End

#----------------#
# Refus révision #
#----------------#
Subprog REFREV(NIVEAU,NUMREV)
Value    Integer NIVEAU
Value    Char    NUMREV
#Nouveau status de la révision
Readlock [BRV]BRV0 = NUMREV
[F:BRV]STA=1
[F:BRV]UPDUSR = GUSER
[F:BRV]UPDDAT = date$
Rewrite [BRV]
If fstat
 GOK=0 : Call FSTA("BRV") From GLOCK
Endif
End

