#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Data Class EDIBPRPAR                                                        #
# Manages main class EDIBPRPAR (this) and child class EDIBPRPARD              #
# Author : RBA + JUCON                                                        #
###############################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"              : Gosub AREAD_AFTER  #SAM 110811
        When "AINSERT_CONTROL_AFTER"    : Gosub AINSERT_CONTROL_AFTER
        When "AUPDATE_CONTROL_AFTER"    : Gosub AUPDATE_CONTROL_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_VALIDATE"             : Gosub MET_VALIDATE
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "BPATYP"      # : Gosub BPATYP
      Case [L]ARULE
        When "INIT"      : Gosub BPATYP_INIT
        When "PROPAGATE" : Gosub BPATYP_PROPAGATE
      Endcase
    When "BPANUM"      # : Gosub BPANUM
      Case [L]ARULE
        When "CONTROL"   : Gosub BPANUM_CONTROL
        When "PROPAGATE" : Gosub BPANUM_PROPAGATE
      Endcase
    When "BPAADD"      # : Gosub BPAADD
      Case [L]ARULE
        When "CONTROL"   : Gosub BPAADD_CONTROL
        When "PROPAGATE" : Gosub BPAADD_PROPAGATE
      Endcase
    When "PARCOD"      # : Gosub PARCOD
      Case [L]ARULE
        When "CONTROL"   : Gosub PARCOD_CONTROL
        When "PROPAGATE" : Gosub PARCOD_PROPAGATE
      Endcase
    When "PARTYP"      # : Gosub PARTYP
      Case [L]ARULE
        When "INIT"      : Gosub PARTYP_INIT
        When "CONTROL"   : Gosub PARTYP_CONTROL   #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
        When "PROPAGATE" : Gosub PARTYP_PROPAGATE
      Endcase
    When "STA"         # : Gosub STA
      Case [L]ARULE
        When "INIT"      : Gosub STA_INIT
      Endcase
    When "PUBENT"      # : Gosub PUBENT       #SAM 112148
      Case [L]ARULE
        When "INIT"      : Gosub PUBENT_INIT
        When "PROPAGATE" : Gosub PUBENT_PROPAGATE
      Endcase
    When "PUBENTCH"      # : X3-74782 Chorus new fields (JUCON 06/02/2018)
      Case [L]ARULE
        When "INIT"      : Gosub PUBENTCH_INIT
        When "PROPAGATE" : Gosub PUBENTCH_PROPAGATE
      Endcase            # : X3-74782 Chorus new fields (JUCON 06/02/2018)
    When "LOCODE"      # : Gosub LOCODE       #SAM 110811
      Case [L]ARULE
        When "PROPAGATE" : Gosub LOCODE_PROPAGATE
      Endcase
    When "GLN"         # : Gosub GLN          #SAM 110811
      Case [L]ARULE
        When "PROPAGATE" : Gosub GLN_PROPAGATE
      Endcase
    When "DUNS"        # : Gosub DUNS         #SAM 110811
      Case [L]ARULE
        When "PROPAGATE" : Gosub DUNS_PROPAGATE
      Endcase
    When "IDTYPE"      # : Gosub IDTYPE       #SAM 110811
      Case [L]ARULE
        When "INIT"      : Gosub IDTYPE_INIT
        When "PROPAGATE" : Gosub IDTYPE_PROPAGATE
      Endcase
    When "EXCEDICOD"   # : Gosub EXCEDICOD
      Case [L]ARULE
        When "PROPAGATE" : Gosub EXCEDICOD_PROPAGATE
      Endcase
  Endcase
Return

###################################################################

$STA_INIT
  this.STA = 1
Return

###################################################################

$BPATYP_INIT
  this.BPATYP = 1
Return

$BPATYP_PROPAGATE
  this.BPATYP = 1
Return

###################################################################

$BPANUM_CONTROL
  If this.BPANUM <> ""
    this.BPANUM = func EDILIBA.FORMATVAL("BPANUM", this.BPANUM)
  Endif
Return

$BPANUM_PROPAGATE
  Local Integer WOK
  Local Char WERR (250)
  Local Char WBPRNAM(35)
  Local Char WBPAADD(5)

  WOK = func EDILIBB.GET_BPRNAMADD(this.BPANUM, WBPRNAM, WBPAADD)
  this.BPRNAM = WBPRNAM
  this.BPAADD = WBPAADD

  this.VALID  = [V]CST_ANO
  this.EXCEDICOD = ""

  ASTATUS = fmet this.ADELETEERROR("BPAADD")
  ASTATUS = fmet this.ADELETEERROR("PARCOD")
  WOK = func CONTROL_EXIST(this)
  If WOK = [V]CST_ATRUE
    WERR = mess(7,123,1)+"."-mess(22,100,1)  ## Creation not possible. Record already exists
    ASTATUS = fmet this.ASETERROR("BPANUM",WERR,[V]CST_AERROR)
  Endif

Return

####################################################################

$BPAADD_CONTROL
  If this.BPAADD <> ""
    this.BPAADD = func EDILIBA.FORMATVAL("BPAADD", this.BPAADD)
    If this.BPANUM <> ""
      Local File BPADDRESS [BPA]
      Read [BPA]BPA0 = 1;this.BPANUM;this.BPAADD
      If fstat
        ASTATUS = fmet this.ASETERROR("BPAADD", mess(33,101,1), [V]CST_AERROR)
      Endif
      LogicClose File [BPA]
    Endif
  Endif
Return

$BPAADD_PROPAGATE
  Local Integer WOK
  Local Char WERR (250)
  Local Char WBPADES(30)

  WOK = func EDILIBB.GET_BPADES(this.BPATYP, this.BPANUM, this.BPAADD, WBPADES)
  this.BPADES = WBPADES
  this.VALID = [V]CST_ANO
  this.EXCEDICOD = ""

  ASTATUS = fmet this.ADELETEERROR("BPANUM")
  ASTATUS = fmet this.ADELETEERROR("PARCOD")
  WOK = func CONTROL_EXIST(this)
  If WOK = [V]CST_ATRUE
    WERR = mess(7,123,1)+"."-mess(22,100,1)  ## Creation not possible. Record already exists
    ASTATUS = fmet this.ASETERROR("BPAADD",WERR,[V]CST_AERROR)
  Endif
Return

####################################################################

#Init SAM 112148 XML signature
$PUBENT_INIT
#  If func AFNC.ACTIV("KSP")>0  X3-74782 Chorus new fields (JUCON 06/02/2018)
  If func AFNC.ACTIV("KSP")>0 and this.BPANUM<>""
    this.PUBENT=1
    Local Integer WSEQ, I

    If this.C_EBPD=null
      For I=1 To 4
        WSEQ = fmet this.ADDLINE("C_EBPD",[V]CST_ALASTPOS)
        this.C_EBPD(WSEQ).CENROL=I
        this.C_EBPD(WSEQ).CODE=""
        this.C_EBPD(WSEQ).DES=""
      Next
    Endif
  Endif
Return

$PUBENT_PROPAGATE
  If func AFNC.ACTIV("KSP")>0 #X3-74782 Chorus new fields (JUCON 06/02/2018)
    Call DELETELINES(this,"C_EBPD") From EDILIBA
    Local Integer WSEQ, I
    For I=1 To 4
      WSEQ = fmet this.ADDLINE("C_EBPD",[V]CST_ALASTPOS)
      this.C_EBPD(WSEQ).CENROL=I
      this.C_EBPD(WSEQ).CODE=""
      this.C_EBPD(WSEQ).DES=""
    Next
  Endif
Return
#End SAM 112148

####################################################################
#Init X3-74782 Chorus new fields (JUCON 06/02/2018)
$PUBENTCH_INIT
   If func AFNC.ACTIV("KFR")>0 and this.BPANUM<>""
    this.PUBENTCH=1
    this.CHBPCSERCOD=""
    this.CHBPCSERNAM=""
    this.CHENGNUMENG=""
  Endif
Return

$PUBENTCH_PROPAGATE
  If func AFNC.ACTIV("KFR")>0 and this.BPANUM<>""
    If this.PUBENTCH=1
      this.CHBPCSERCOD=""
      this.CHBPCSERNAM=""
      this.CHENGNUMENG=""
    Endif
  Endif
Return
#End X3-74782 Chorus new fields (JUCON 06/02/2018)

####################################################################

$PARCOD_CONTROL
Return

$PARCOD_PROPAGATE
  Local Integer WOK
  Local Char WERR (250)

  this.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.PARCOD,"PARDES")
  this.PARTYP = fmet this.ACTX.ACACHE.EPR.AGETVALNUM(this.PARCOD,"PARTYP")
  this.VALID = [V]CST_ANO
  this.EXCEDICOD = ""

  WOK = func CONTROL_EXIST(this)
  ASTATUS = fmet this.ADELETEERROR("BPANUM")
  ASTATUS = fmet this.ADELETEERROR("BPAADD")
  If WOK = [V]CST_ATRUE
    WERR = mess(7,123,1)+"."-mess(22,100,1)  ## Creation not possible. Record already exists
    ASTATUS = fmet this.ASETERROR("PARCOD",WERR,[V]CST_AERROR)
  Endif
Return

####################################################################

$PARTYP_INIT
  this.PARTYP = 2
Return

$PARTYP_CONTROL #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
  Local Char WERR (250)
#  WERR = "Type de partenaire interdit"
  WERR = mess(216,2006,1)
  If this.PARTYP <> 2 #controle tiers-société
    ASTATUS = fmet this.ASETERROR("PARCOD",WERR,[V]CST_AERROR)
  Endif
Return

$PARTYP_PROPAGATE
#  this.PARTYP = 2 #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
Return

####################################################################

#Init SAM 110811 - Control for idenfification ID type
$LOCODE_PROPAGATE
  If this.LOCODE <> "" and this.IDTYPE = 2 # and this.EXCEDICOD="" #110811 US6
    this.EXCEDICOD = this.LOCODE
  Endif
Return

####################################################################

$GLN_PROPAGATE
  If this.GLN <> "" and this.IDTYPE = 3 # and this.EXCEDICOD="" #110811 US6
    this.EXCEDICOD = this.GLN
  Endif
Return

####################################################################

$DUNS_PROPAGATE
  If this.DUNS <> "" and this.IDTYPE = 4 # and this.EXCEDICOD="" #110811 US6
    this.EXCEDICOD = this.DUNS
  Endif
Return

####################################################################

$IDTYPE_INIT
  this.IDTYPE = 6
Return

$IDTYPE_PROPAGATE
  Local Char WERR(250)
  Local File BPARTNER [BPR]
  ASTATUS = fmet this.ASETERROR("EXCEDICOD",WERR,[V]CST_AYES)
  this.EXCEDICOD=""
  Read[BPR]BPR0=this.BPANUM
  If !fstat
    Case this.IDTYPE
      When 1: #Fiscal code is the CRN of the Company
              this.EXCEDICOD=[F:BPR]CRN
              If [F:BPR]CRN=""
                WERR=mess(153,2006,1) #Company tax ID number is empty
              Endif
      When 2: #Local code
              If this.LOCODE<>""
                this.EXCEDICOD=this.LOCODE
              Else
                WERR=mess(72,108,1) : # null value
              Endif
      When 3: #GLN
              If this.GLN<>""
                this.EXCEDICOD=this.GLN
              Else
                WERR=mess(72,108,1) : # null value
              Endif
      When 4: #DUNS
              If this.DUNS<>""
                this.EXCEDICOD=this.DUNS
              Else
                WERR=mess(72,108,1) : # null value
              Endif
      When 5: # EU Tax code
              this.EXCEDICOD=[F:BPR]EECNUM
              If [F:BPR]EECNUM=""
                WERR=mess(157,196,1) #The EU ID number is blank
              Endif
    Endcase
  Endif
  LogicClose File [BPR]
  If WERR<>""
    ASTATUS = fmet this.ASETERROR("EXCEDICOD",WERR,[V]CST_AWARNING)
  Endif
Return

####################################################################

$EXCEDICOD_PROPAGATE
  Local Integer WOK
  Local Char WERR (250)

  this.VALID = [V]CST_ANO

  If this.EXCEDICOD <> ""
    Local Integer WFOUND : WFOUND = [V]CST_AFALSE
    #EDI code is unique for a BPATYP+BPANUM+PARCOD
    Local File EDIBPRPAR [EBP]
    Filter [EBP] Where EXCEDICOD = this.EXCEDICOD and PARCOD = this.PARCOD and not(BPATYP = this.BPATYP and BPANUM = this.BPANUM)
    For [EBP]
      WOK = [V]CST_ATRUE
      Break
    Next
    If WOK = [V]CST_ATRUE
      this.VALID = [V]CST_ANO
      WERR = mess(158,2006,1)+":"-[EBP]BPANUM-[EBP]BPAADD-[EBP]PARCOD   #Setup is already used to another EDI partner by BP
      ASTATUS = fmet this.ASETERROR("EXCEDICOD",WERR,[V]CST_AERROR)
    Endif
    Filter [EBP]
    LogicClose File [EBP]
  Endif
Return

####################################################################

#init SAM 110811
#********************************************************************
# Method AINSERT_CONTROL_AFTER
#********************************************************************
#*
#*!
$AREAD_AFTER
  Local File BPARTNER [BPR]

  Read[BPR]BPR0=this.BPANUM
  If !fstat
    Case this.IDTYPE
      When 1: #Fiscal code is the CRN of the Company
              this.EXCEDICOD=[F:BPR]CRN
      When 5: # EU Tax code
              this.EXCEDICOD=[F:BPR]EECNUM
    Endcase
  Endif
  LogicClose File [BPR]
Return
#End 110811

#********************************************************************
# Method AINSERT_CONTROL_AFTER
#********************************************************************
#*
#*!
$AINSERT_CONTROL_AFTER
  Local Integer WOK
  WOK = fmet this.MET_VALIDATE()
  ASTATUS = WOK
Return

#********************************************************************
# Method AUPDATE_CONTROL_AFTER
#********************************************************************
#*
#*!
$AUPDATE_CONTROL_AFTER
  Local Integer WOK
  WOK = fmet this.MET_VALIDATE()
  ASTATUS = WOK
Return

#********************************************************************
# Method MET_VALIDATE
#********************************************************************
#*
#*!
$MET_VALIDATE
 #VALID flag managment
  Local Integer WOK
  Local Char WERR(250)

  If this.EXCEDICOD = ""
    this.VALID = [V]CST_ANO
    #WERR = "Setup is not complete"
    WERR = mess(81,2006,1)
    ASTATUS = fmet this.ASETERROR("EXCEDICOD",WERR,[V]CST_AWARNING)
  Else
    WOK = func CONTROL_EXIST(this)
    If WOK = [V]CST_ATRUE and [L]ARULE = "AINSERT_CONTROL_AFTER"
      this.VALID = [V]CST_ANO
      WERR = mess(7,123,1)+"."-mess(22,100,1)  ## Creation not possible. Record already exists
      ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
    Else
      Local Integer WFOUND : WFOUND = [V]CST_AFALSE
      #EDI code is unique for a BPATYP+BPANUM+PARCOD
      Local File EDIBPRPAR [EBP]
      WOK = [V]CST_AFALSE
      Filter [EBP] Where EXCEDICOD = this.EXCEDICOD and PARCOD = this.PARCOD and BPATYP = this.BPATYP  and BPANUM <> this.BPANUM
      For [EBP]
        WOK = [V]CST_ATRUE
        Break
      Next
      If WOK = [V]CST_ATRUE
        this.VALID = [V]CST_ANO
        WERR = mess(191,2006,1) #"Setup is already used to another EDI partner by BP"# :"-[EBP]BPANUM-[EBP]BPAADD-[EBP]PARCOD
        ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
      Else
        this.VALID = [V]CST_AYES
      Endif
      Filter [EBP]
      LogicClose File [EBP]
    Endif
  Endif

  If func AFNC.ACTIV("KSP")>0 ##X3-101424 JUCON 19/07/2018
    If this.PUBENT = 2
      Local Integer I
     # INI SAM 112149
      For I=1 To maxtab(this.C_EBPD)
        If this.C_EBPD(I).AORDER<4 and this.C_EBPD(I).ASTALIN<>16
          If  this.C_EBPD(I).CODE=""
            this.VALID = [V]CST_ANO
            WERR = mess(81,2006,1)  # Setup is not complete
            ASTATUS = fmet this.C_EBPD(I).ASETERROR("CODE",WERR,[V]CST_AWARNING)
          Endif
          If this.C_EBPD(I).CODE<>"" and this.C_EBPD(I).DES=""
            this.VALID = [V]CST_ANO
            WERR = mess(81,2006,1)  # Setup is not complete
            ASTATUS = fmet this.C_EBPD(I).ASETERROR("DES",WERR,[V]CST_AWARNING)
          Endif
        Endif
      Next
      # END SAM 112149
    Endif
  Endif

  If func AFNC.ACTIV("KFR")>0  ##X3-101424 JUCON 19/07/2018
  # INI X3-74782 Chorus new fields (JUCON 06/02/2018)
    If this.PUBENTCH = 2
      If this.CHBPCSERCOD=""
        this.VALID = [V]CST_ANO
        WERR = mess(81,2006,1)  # Setup is not complete
        ASTATUS = fmet this.ASETERROR("CHBPCSERCOD",WERR,[V]CST_AWARNING)
      Endif
      If this.CHBPCSERNAM=""
        this.VALID = [V]CST_ANO
        WERR = mess(81,2006,1)  # Setup is not complete
        ASTATUS = fmet this.ASETERROR("CHBPCSERNAM",WERR,[V]CST_AWARNING)
      Endif
    Endif
  # END X3-74782 Chorus new fields (JUCON 06/02/2018)
  Endif

  If this.VALID = [V]CST_AYES
    ARET_VALUE = [V]CST_AOK
  Else
    ARET_VALUE = [V]CST_AERROR
  Endif

Return

#********************************************************************
# Funprog CONTROL_EXIST
#********************************************************************
#
#* Set default values
#* @param WOBJECT
#* @return [V]CST_ATRUE/[V]CST_AFALSE
#*!
Funprog CONTROL_EXIST(WOBJECT)
Variable Instance WOBJECT Using OBJECT

  Local Integer WOK : WOK = [V]CST_AFALSE
  If WOBJECT.BPANUM <> "" and WOBJECT.BPAADD <> "" and WOBJECT.PARCOD <> ""
    Local File EDIBPRPAR [EBP]
    Read [EBP]EBP0=WOBJECT.BPATYP;WOBJECT.BPANUM;WOBJECT.BPAADD;WOBJECT.PARCOD
    If fstat = [V]CST_AOK
      WOK = [V]CST_ATRUE
    Endif
    LogicClose File [EBP]
  Endif
End WOK

Return

