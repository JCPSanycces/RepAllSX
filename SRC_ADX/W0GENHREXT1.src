#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque GENHREXT1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone DTANBR
mkstat = 0
zoncou = "DTANBR"
indice = 0
status = 1
zoncou = "DTANBR"
If varmode([M]DTANBR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DTANBR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]DTANBR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]DTANBR = nolign
   status = 75
   Call SAI_DTANBR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone FLTNBR
mkstat = 0
zoncou = "FLTNBR"
indice = 0
status = 1
zoncou = "FLTNBR"
If varmode([M]FLTNBR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLTNBR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]FLTNBR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]FLTNBR = nolign
   status = 75
   Call SAI_FLTNBR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_DTANBR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone DTANBR
mkstat = 0
zoncou = "DTANBR"

## Zone DTALVL
mkstat = 0
zoncou = "DTALVL"
IMPENT = [M]DTALVL(indice)
If varinit([M]DTALVL,indice)=0
 IMPENT = 1
Endif
If varmode([M]DTALVL,indice)=0
 [M]DTALVL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DTALVL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DTALVL(indice)
 Endif
Endif
[M]DTALVL(indice) = IMPENT

## Zone DTATBL
mkstat = 0
zoncou = "DTATBL"
If varmode([M]DTATBL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DTATBL" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ATB","!",[M]DTATBL(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "DTATBL" : GZNUM = 1176 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone DTATBLABR
mkstat = 0
zoncou = "DTATBLABR"
If varmode([M]DTATBLABR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DTATBLABR" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DTALNKCLC
mkstat = 0
zoncou = "DTALNKCLC"
If varmode([M]DTALNKCLC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DTALNKCLC" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DTAORGABR
mkstat = 0
zoncou = "DTAORGABR"
If varmode([M]DTAORGABR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DTAORGABR" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DTANBR
mkstat = 0
zoncou = "DTANBR"

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_FLTNBR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone FLTNBR
mkstat = 0
zoncou = "FLTNBR"

## Zone FLTDTALVL
mkstat = 0
zoncou = "FLTDTALVL"
IMPENT = [M]FLTDTALVL(indice)
If varinit([M]FLTDTALVL,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLTDTALVL,indice)=0
 [M]FLTDTALVL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLTDTALVL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLTDTALVL(indice)
 Endif
Endif
[M]FLTDTALVL(indice) = IMPENT

## Zone FLTDTACLC1
mkstat = 0
zoncou = "FLTDTACLC1"
If varmode([M]FLTDTACLC1,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLTDTACLC1" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone FLTDTACLC2
mkstat = 0
zoncou = "FLTDTACLC2"
If varmode([M]FLTDTACLC2,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLTDTACLC2" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone FLTDTACLC3
mkstat = 0
zoncou = "FLTDTACLC3"
If varmode([M]FLTDTACLC3,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLTDTACLC3" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone FLTNBR
mkstat = 0
zoncou = "FLTNBR"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "GENHREXT1"
Return

