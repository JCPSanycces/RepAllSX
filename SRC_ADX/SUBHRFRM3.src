#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Modification :
#     SEGAY - 05/05/14 - US2690 - 92876 Accounting
######################################################################################

Subprog VALPAI(MODPAI,FRMNUM,TRACE,FIN)
Value Char       MODPAI
Value Char       FRMNUM
Value Integer    TRACE
Variable Integer FIN
Local Integer    STAT
Local Char       PCEAUTO(10), MESSA(80), IDENT(20)(1..2)
Local Shortint   NUMPAY

Local Integer FLGCPR

# 92876 US2690 - recherche des plans à traiter pour le bulletin
Local Char PLGEN(GLONCOA), PLANA(GLONCOA)
Local Libelle TYPGEN, TYPANA
Local Char WCPY(GLONCPY)
Local Char WCPY2(GLONCPY)
Local Char WSAVGSOC(GLONCPY)
Local Char WACM(GLONGCM)
Local Integer NBLED         : # Nombre de référentiels
Local Char    CODLED(GLONLED)(1..len(mess(0,2644,1))) : # Référentiels (en 1:général principal, en 2:analytique principal)
Local Char WDIE(GLONDIE)(0..[V]GOPTCANA-1)
Local Char WCCE(GLONCCE)(0..[V]GOPTCANA-1)
Local Char WLSTDIE(GLONDIE)(1..[V]GOPTCANA)
Local Integer WNBRDIE,I,J
Local Integer WNBPLAN
Local Char WTPLAN(GLONCOA)(1..len(mess(0,2644,1)))

Local Integer WTREFTYP(1..10)
Local Integer WTOBLIG(1..[V]GOPTCANA)
Raz WCPY2
# END 92876 US2690
# On génère une pièce comptable par bordereau de règlement

If !clalev([F:ADI]) : Local File ATABDIV  [ADI] : Endif
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
If !clalev([F:HRPYE]) : Local File HRPAYTMP   [HRPYE] : Endif
#If !clalev([F:PYE]) : Local File PAYTMP   [PYE] : Endif
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
If !clalev([F:HRSTL]) : Local File HRSTLPAY   [HRSTL] : Endif
#If !clalev([F:STL]) : Local File STLPAY   [STL] : Endif
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END
If !clalev([F:CPT]) : Local File EMPLOCPT [CPT] : Endif

# (C) PROSPER 22/07/10 - Prise en compte d'infos comptables au contrat
If !clalev([F:CPR]) : Local File EMPLOCTRCPT [CPR] : Endif

Call DEBTRANS From GLOCK
Gosub TR_ANNUL
If GOK>0
 Gosub TR1
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 If GOK>0
  Gosub TR2
  If GOK<0   : Goto ROLL_TR2
 #  Elsif !GOK : Goto AB_TR2
 # 92876 US2690
  Elsif !GOK : Gosub AB_TR2

  Endif

#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
  Raz [F:HRSTL]
  [F:HRSTL]NUMFRM=[L]FRMNUM
  Call WORKFLOW(1,"VRG","","") From AWRK
  Raz [F:HRSTL]
#  Raz [F:STL]
#  [F:STL]NUMFRM=[L]FRMNUM
#  Call WORKFLOW(1,"VRG","","") From AWRK
#  Raz [F:STL]
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END

 Endif
Endif
End

######################### Effacement du fichier PAYTMP #########################

$TR_ANNUL
GOK = 1
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
Trbegin [HRPYE]
 Delete [HRPYE] Where 1=1
#Trbegin [PYE]
# Delete [PYE] Where 1=1
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END
 #62135
 #If fstat=1
 # GLOCK = "PAYE"-"" : Goto ROLL_TR_ANNUL
 #Elsif fstat>5
 # Call RSTA("PYE","") From GLOCK : Goto AB_TR_ANNUL
 #Endif
 If fstat=1 | fstat>5
  GOK=-1 : GLOCK = "PAYE"-"" : Goto ROLL_TR_ANNUL
 Endif
 # fin 62135
Commit
Return

$AB_TR_ANNUL
Rollback
Return

$ROLL_TR_ANNUL
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ANNUL : Endif
Return

######################### Mise à jour du fichier PAYTMP #########################

$TR1
GOK = 1
[L]NUMPAY=-1
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
Trbegin[HRPYE]
 Raz [F:HRPYE]
 Filter [HRSTL] Where NUMFRM=[L]FRMNUM
  For [HRSTL]STL0
   [F:HRPYE]       = [F:HRSTL]
   Read [CPT]CPT0=[F:HRSTL]REFNUM
   If !fstat
     [F:HRPYE]       = [F:CPT]
     # 92876 US2690
     Raz WDIE # 92876 US2690
     Raz WCCE # 92876 US2690
     For I=0 To [V]GOPTCANA-1
       WDIE(I)=[F:CPT]DIE(I)
       WCCE(I)=[F:CPT]CCE(I)
     Next
#Trbegin[PYE]
# Raz [F:PYE]
# Filter [STL] Where NUMFRM=[L]FRMNUM
#  For [STL]STL0
#   [F:PYE]       = [F:STL]
#   Read [CPT]CPT0=[F:STL]REFNUM
#   If !fstat
#     [F:PYE]       = [F:CPT]
#     # 92876 US2690
#     Raz WDIE # 92876 US2690
#     Raz WCCE # 92876 US2690
#     For I=0 To [V]GOPTCANA-1
#       WDIE(I)=[F:CPT]DIE(I)
#       WCCE(I)=[F:CPT]CCE(I)
#     Next
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END
   Endif
   # END 92876 US2690
   # (C) PROSPER - 22/07/10 - Infos comptables au contrat
   #                          arbitraitement on prends le dernier chrono
   #                          de ce contrat - Vu DBA 22/07/10
   #                          A voir si un filtre sur CTRDAT<=[STL]PYRDAT
   #                          serait intéressant ... ?

#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
   Filter [F:CPR] Where [F:CPR]REFNUM = [F:HRSTL]REFNUM
&      & [F:CPR]CTRNUM = [F:HRSTL]CTRNUM
&      & [F:CPR]CTRDAT <= [F:HRSTL]PYRDAT : # 92876 US2690 idem controle CTRNUM of SUBFRM
#   Filter [F:CPR] Where [F:CPR]REFNUM = [F:STL]REFNUM
#&      & [F:CPR]CTRNUM = [F:STL]CTRNUM
#&      & [F:CPR]CTRDAT <= [F:STL]PYRDAT : # 92876 US2690 idem controle CTRNUM of SUBFRM
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END
   Read [F:CPR]CPR0 Last
   If fstat <= 2
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
       [F:HRPYE] = [F:CPR]
#       [F:PYE] = [F:CPR]
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END
       # 92876 US2690
       Raz WDIE # 92876 US2690
       Raz WCCE # 92876 US2690
       For I=0 To [V]GOPTCANA-1
         WDIE(I)=[F:CPR]DIE(I)
         WCCE(I)=[F:CPR]CCE(I)
       Next
       # END 92876 US2690

       # Cas particulier - Cf DBA document de spécifications ; si les infos
       # comptables au contrat sont définies mais que le compte individuel
       # ne l'est pas, alors celui du salarié fait foi ...

       If [F:CPR]BPR = ""
           # Non défini, on reprends celui de [CPT]
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
           [F:HRPYE]BPR = [F:CPT]BPR
#           [F:PYE]BPR = [F:CPT]BPR
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END
       Endif
   Endif
   Filter [F:CPR]
   # 92876 US2690
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
   WCPY=func DIVPAYE.GETSOC([HRSTL]FCY)
#   WCPY=func DIVPAYE.GETSOC([STL]FCY)
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END
   If WCPY<>WCPY2
     Call SETMAINREF(WCPY,TYPGEN,TYPANA) From CPTDIV
     Call SETREF(WCPY,NBLED,CODLED) From CPTDIV
     Call LECMAINPLAN(1,WCPY,PLGEN) From CPTDIV
     Call LECMAINPLAN(2,WCPY,PLANA) From CPTDIV
     WCPY2=WCPY
   Endif
   #TODO que fait-on quand on a PLGEN et PLANA
   # Faut-il créer 2 enregistrements en rajoutant LEDTYP dans la clé de PAYTMP
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
   Raz [F:HRPYE]DIE
   Raz [F:HRPYE]CCE
   [F:HRPYE]COA=PLGEN
   [F:HRPYE]LEDTYP=TYPGEN
   [F:HRPYE]LED=CODLED(TYPGEN)
#   Raz [F:PYE]DIE
#   Raz [F:PYE]CCE
#   [F:PYE]COA=PLGEN
#   [F:PYE]LEDTYP=TYPGEN
#   [F:PYE]LED=CODLED(TYPGEN)
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END
#   Call GETLSTAXE(WCPY,TYPGEN,WNBRDIE,WLSTDIE) From CPTDIV
   WSAVGSOC=GSOCIETE
   GSOCIETE=WCPY
   Call SETGCM(WCPY,WACM) From CPTDIV
   Call SETPLAN2(WACM,WNBPLAN,WTPLAN,WTREFTYP,WNBRDIE,WLSTDIE,WTOBLIG) From CPTDIV
   GSOCIETE=WSAVGSOC

   J=0
   If WNBRDIE > 0
      For I=0 To [V]GOPTCANA-1
         If find(WDIE(I),WLSTDIE(1..WNBRDIE))
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
            [F:HRPYE]DIE(J)=WDIE(I)
            [F:HRPYE]CCE(J)=WCCE(I)
#            [F:PYE]DIE(J)=WDIE(I)
#            [F:PYE]CCE(J)=WCCE(I)
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END
            J+=1
         Endif
      Next
   Endif

   # END 92876 US2690
#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- START
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- START
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
Read [ADI]CODE=10365;[F:HRSTL]TYPPAY
#   Read [ADI]CODE=10365;[F:HRSTL]TYPPAY
#MIPEA - 2017-06-14- US X3-11264 ST X3-25377- END
#   Read [ADI]CODE=365;[F:STL]TYPPAY
#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- END
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
   [F:HRPYE]NUMPAY = [F:ADI]N1
   Case [L]NUMPAY
    When -1               : [L]NUMPAY=[F:HRPYE]NUMPAY
    When 0, [F:HRPYE]NUMPAY
    When Default          : [F:HRPYE]NUMPAY=0
   Endcase
   If dim([F:HRPYE]UPDDAT)>0 : [F:HRPYE]UPDDAT = date$ : Endif
   If dim([F:HRPYE]UPDUSR)>0 : [F:HRPYE]UPDUSR = GUSER : Endif
   If dim([F:HRPYE]UPDTIM)>0 : [F:HRPYE]UPDTIM = time  : Endif
   Write [HRPYE]
   If fstat
    GOK=0 : Call FSTA("HRPYE") From GLOCK : Break
   Endif
  Next
 Filter [HRSTL]
#   [F:PYE]NUMPAY = [F:ADI]N1
#   Case [L]NUMPAY
#    When -1               : [L]NUMPAY=[F:PYE]NUMPAY
#    When 0, [F:PYE]NUMPAY
#    When Default          : [F:PYE]NUMPAY=0
#   Endcase
#   If dim([F:PYE]UPDDAT)>0 : [F:PYE]UPDDAT = date$ : Endif
#   If dim([F:PYE]UPDUSR)>0 : [F:PYE]UPDUSR = GUSER : Endif
#   If dim([F:PYE]UPDTIM)>0 : [F:PYE]UPDTIM = time  : Endif
#   Write [PYE]
#   If fstat
#    GOK=0 : Call FSTA("PYE") From GLOCK : Break
#   Endif
#  Next
# Filter [STL]
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

######################### Comptabilisation des écritures #########################

$TR2
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
Trbegin [HRPYE]
#Trbegin [PYE]
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END
#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- START
Read [ADI]CODE=10387;MODPAI
#Read [ADI]CODE=387;MODPAI
#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- END
If fstat
 # Bordereau de règlement non validé
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
 Call ECR_TRACE(mess(67,100,1)-num$([F:HRPYE]NUMFRM),0) From GESECRAN
# Call ECR_TRACE(mess(67,100,1)-num$([F:PYE]NUMFRM),0) From GESECRAN
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END
 # Absence des informations comptables
#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- START
 Call ECR_TRACE([F:HRPYE]REFNUM-" : "-mess(27,10703,1),1) From GESECRAN
# Call ECR_TRACE([F:PYE]REFNUM-" : "-mess(27,703,1),1) From GESECRAN
#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- END
 FIN = 1
Else
 If find([L]NUMPAY,7) : # Notes de frais=7
#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- START
  Filter [ADI] Where NUMTAB=10553 & N1=[L]NUMPAY & A1=[L]MODPAI
#  Filter [ADI] Where NUMTAB=553 & N1=[L]NUMPAY & A1=[L]MODPAI
#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- END
  Read [ADI]CODE First
  Filter [ADI]
  If fstat
   # Bordereau de règlement non validé
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
   Call ECR_TRACE(mess(67,100,1)-num$([F:HRPYE]NUMFRM),0) From GESECRAN
#   Call ECR_TRACE(mess(67,100,1)-num$([F:PYE]NUMFRM),0) From GESECRAN
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END
   # Absence des informations comptables
#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- START
   Call ECR_TRACE([F:PYE]REFNUM-" : "-mess(27,10703,1),1) From GESECRAN
#   Call ECR_TRACE([F:PYE]REFNUM-" : "-mess(27,703,1),1) From GESECRAN
#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- END
   FIN = 1
  Else
   [L]PCEAUTO=[F:ADI]A2
  Endif
 Else
  PCEAUTO = [F:ADI]A1
 Endif
Endif

If ![L]FIN
 If PCEAUTO=""
  # Bordereau de règlement non validé
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
  Call ECR_TRACE(mess(67,100,1)-num$([F:HRPYE]NUMFRM),0) From GESECRAN
#  Call ECR_TRACE(mess(67,100,1)-num$([F:PYE]NUMFRM),0) From GESECRAN
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END
  # Pièce automatique inexistante
  Call ECR_TRACE(mess(39,114,1),1) From GESECRAN
  FIN=1
  Commit
  Return
 Endif
 Gosub OUVRE_CPTAUTO From DIVPAYE
 If 1=2 # 92876 US2690 Obsolète open mask in OUVRE_CPTAUTO
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
#  Local Mask HRGACCENT0 [HRHAE0]
#  If [L]TRACE=2
#   If !clalev([M:HRHAE0]) : Local Mask HRGACCENT0 [HRHAE0] : Endif
#   If !clalev([M:HRHAE1]) : Local Mask HRGACCENT1 [HRHAE1] : Endif
#   If !clalev([M:HRHAE2]) : Local Mask HRGACCENT2 [HRHAE2] : Endif
#   If !clalev([M:VTL])  : Local Mask VENTILE  [VTL]  : Endif
#   If !clalev([M:VT2])  : Local Mask VENTILE2 [VT2]  : Endif
#   If !clalev([M:HRHAEF]) : Local Mask HRGACCENTFMT [HRHAEF] : Endif :# 92876 US2690
#   If !clalev([M:HRHAEW]) : Local Mask HRGACCENTW   [HRHAEW] : Endif :# 92876 US2690
#
#   Default Mask [VT2]
#   Default Mask [VTL]
#   Default Mask [HRHAE2]
#   Default Mask [HRHAE1]
#   Default Mask [HRHAE0]
#   Default Mask [HRHAEF]   :# 92876 US2690
#   Default Mask [HRHAEW]   :# 92876 US2690
  Local Mask GACCENT0 [HAE0]
  If [L]TRACE=2
   If !clalev([M:HAE0]) : Local Mask GACCENT0 [HAE0] : Endif
   If !clalev([M:HAE1]) : Local Mask GACCENT1 [HAE1] : Endif
   If !clalev([M:HAE2]) : Local Mask GACCENT2 [HAE2] : Endif
   If !clalev([M:VTL])  : Local Mask VENTILE  [VTL]  : Endif
   If !clalev([M:VT2])  : Local Mask VENTILE2 [VT2]  : Endif
   If !clalev([M:HAEF]) : Local Mask GACCENTFMT [HAEF] : Endif :# 92876 US2690
   If !clalev([M:HAEW]) : Local Mask GACCENTW   [HAEW] : Endif :# 92876 US2690

   Default Mask [VT2]
   Default Mask [VTL]
   Default Mask [HAE2]
   Default Mask [HAE1]
   Default Mask [HAE0]
   Default Mask [HAEF]   :# 92876 US2690
   Default Mask [HAEW]   :# 92876 US2690
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END

  Endif
 Endif

 IDENT(1) = [L]FRMNUM

 #78418
 [V]GPE = 0
 GPOINT = "VALPCE_REGLEMENT" : Gosub ENTREE From EXEFNC
 If [V]GPE = 0
  Call VALPCE([L]PCEAUTO,IDENT,STAT,MESSA) From CPTAUTO
  If STAT
   # Bordereau de règlement non validé
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
   Call ECR_TRACE(mess(67,100,1)-num$([F:HRPYE]NUMFRM),0) From GESECRAN
#   Call ECR_TRACE(mess(67,100,1)-num$([F:PYE]NUMFRM),0) From GESECRAN
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END

   #86552 : N° ligne ici n'est pas significatif -> toujours le dernier !
   #Ligne n°
   #Call ECR_TRACE(mess(61,100,1)-num$([F:PYE]NUMLIG)-" "-MESSA,1) From GESECRAN
   Call ECR_TRACE(space$(3)+MESSA,1) From GESECRAN

   FIN = 1
   If GOK<=0 : Return : Endif
  Endif

 Endif
Endif

If !FIN
 # Création pièce NUM
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
 Call ECR_TRACE(mess(40,107,1)-[M:HAE0]TYP-MESSA,0) From GESECRAN
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END
 # Bordereau de règlement validé
#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- START
 Call ECR_TRACE(mess(28,10703,1)-num$([F:HRPYE]NUMFRM),0) From GESECRAN
# Call ECR_TRACE(mess(28,703,1)-num$([F:PYE]NUMFRM),0) From GESECRAN
#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- END
Endif

If [L]TRACE=2 & ![L]FIN
 Call TRACE_PIECE(1) From CPTBATCH
Endif

Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif
Return

######################### Contrôles du bordereau #########################

Subprog VERIF_BORDEREAU(NUMERO,FIN,TRA)
Value    Char    NUMERO
Variable Integer FIN
Variable Integer TRA
Local Char SYMBOLE(30)

If !clalev([F:ADI]) : Local File ATABDIV  [ADI] : Endif
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
If !clalev([F:HRSTL]) : Local File STLPAY   [HRSTL] : Endif
#If !clalev([F:STL]) : Local File STLPAY   [STL] : Endif
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END
If !clalev([F:CPT]) : Local File EMPLOCPT [CPT] : Endif

#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- START
SYMBOLE="HRFRM"+NUMERO
#SYMBOLE="FRM"+NUMERO
#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- END
Lock =SYMBOLE

If fstat
 # Modification en cours sur un autre poste
 If !GSERVEUR & TRA=-1
  Call ERREUR(NUMERO-":"-mess(10,100,1)) From GESECRAN
 Else
  Call ECR_TRACE(NUMERO-":"-mess(10,100,1),1) From GESECRAN
  TRA = 1
 Endif
 FIN = 1
 End
Endif

#JASMI - 2017-03-09 - START
#Read [FRM]FRM0=NUMERO
Read [HRFRM]FRM0=NUMERO
#JASMI - 2017-03-09 - END

#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- START
Case [F:HRFRM]STA
 When 1
  Call ECR_TRACE(mess(23,10703,1),1) From GESECRAN : #Bordereau non édité
  TRA = 1 : FIN = 1 : Unlock =SYMBOLE
  End
 When 3
  Call ECR_TRACE(mess(24,10703,1),1) From GESECRAN : #Bordereau déjà validé
  TRA = 1 : FIN = 1 : Unlock =SYMBOLE
  End
Endcase
#Case [F:FRM]STA
# When 1
#  Call ECR_TRACE(mess(23,703,1),1) From GESECRAN : #Bordereau non édité
#  TRA = 1 : FIN = 1 : Unlock =SYMBOLE
#  End
# When 3
#  Call ECR_TRACE(mess(24,703,1),1) From GESECRAN : #Bordereau déjà validé
#  TRA = 1 : FIN = 1 : Unlock =SYMBOLE
#  End
#Endcase
#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- END

#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- START
#JASMI - 2017-03-09 - START
#Read [ADI]CODE=10387;[F:FRM]MODPAY
Read [ADI]CODE=10387;[F:HRFRM]MODPAY
#JASMI - 2017-03-09 - END
#Read [ADI]CODE=387;[F:FRM]MODPAY
#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- END

#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
For [HRSTL]STL0 Where NUMFRM=NUMERO
 If [F:HRSTL]BIDNUM="" & ([F:ADI]N1=3 | [F:ADI]N1=4) : #Virement
#For [STL]STL0 Where NUMFRM=NUMERO
# If [F:STL]BIDNUM="" & ([F:ADI]N1=3 | [F:ADI]N1=4) : #Virement
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END
  # Ligne N° xxx : Ligne sans rib dans le bordereau
#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- START
  Call ECR_TRACE(mess(61,100,1)-" "-format$("N:4#",[F:HRSTL]NUMLIG)-" : "-mess(22,10703,1),1) From GESECRAN
#  Call ECR_TRACE(mess(61,100,1)-" "-format$("N:4#",[F:STL]NUMLIG)-" : "-mess(22,703,1),1) From GESECRAN
#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- END
  TRA = 1
 Endif
 Read [CPT]CPT0=[F:HRSTL]REFNUM
 If fstat
  # Absence des informations comptables pour le matricule xxxxxx
#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- START
  Call ECR_TRACE(mess(31,10703,1)-[F:HRSTL]REFNUM,1) From GESECRAN
#  Call ECR_TRACE(mess(31,703,1)-[F:STL]REFNUM,1) From GESECRAN
#MIPEA - 2017-03-07- US X3-11264 ST X3-25377- END
  TRA = 1
 Endif
Next

#76297 : PE pour ajouter d'autres contrôles
[V]GPE = 0
GPOINT = "VERIF_SPE" : Gosub ENTREE From EXEFNC
#
If TRA=1 : FIN=1 : Unlock =SYMBOLE : Endif
End

