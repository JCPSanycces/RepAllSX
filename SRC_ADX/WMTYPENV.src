#<AdxTL>@(#)0.0.0.0 $Revision$Class Envelope
# Supervisor
## ATY-ATYPE ## ENV
# 2018-11-09 07:14:13 643

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,ENV,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char ENV
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File ENVELOPPE [ENV]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".ENVELOPPE" [ENV]
Endif

Default File [F:ENV]
Read [F:ENV]ENV0 = [L]ENV
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]ENV)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]ENV)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


