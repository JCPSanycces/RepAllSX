####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EMPLOID_PASDET
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_PASCRY From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT
Gosub INIT_PASNUM From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT
Gosub INIT_PASDTE From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT
Gosub INIT_PLCISS From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT
Gosub INIT_ISSAUZ From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT
Gosub INIT_EXPDAT From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT
Gosub INIT_ETRPITTYP From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT
Gosub INIT_ETRPITDAT From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT
Gosub INIT_ETRPITEXPDAT From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT
Gosub INIT_ESSUIDPAS From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT
Gosub INIT_PASDATNEW From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT
Gosub INIT_PASDATAMD From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT
Gosub AINIT From WMC0EMPLOID_PASDET : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EMPLOID_PASDET
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EMPLOID_PASDET
Gosub LNKPRO_PASCRY From WMC1EMPLOID_PASDET : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



