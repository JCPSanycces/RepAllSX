End


########################################################################
# Pour execution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

# mettre a jour uniquement dossier X3
If APPLI<>GDOSX3 : End : Endif

Call EXE_UTIINDFIX2018R3 (APPLI)  
End

########################################################################
########################################################################


Subprog EXE_UTIINDFIX2018R3(LDOSSIER)
Value Char LDOSSIER

#----- Variables locales -----#
Local Char     WMSG(80)
Local Char     WTRT(80)
Local Char     PARAM(250)
#-----
Call ECR_TRACE("UTIINDFIX2018R03: update the archive  for Folder "+LDOSSIER,0) From GESECRAN
WTRT= "WSATBPAXSATFR"
If filinfo(filpath("TRT",WTRT,"adx",0),0)<0 
    # Traitement a virer car en adx n existe pas
    System PARAM=adxmac(0)+'@archive -d'-LDOSSIER-'-t'-'-e "'+WTRT+'"' 
Endif

WTRT= "W*"
# Traitements supprimés
System PARAM=adxmac(0)+'@archive -d'-LDOSSIER-'-t'-'-e "'+WTRT+'"' 
# Traitements ajout
System PARAM=adxmac(0)+'@archive -d'-LDOSSIER-'-t'-'-c "'+WTRT+'"' 


#----- Fin du traitement -----#
$FIN_UTIINDFIX2018R3
WMSG ="UTIINDFIX2018R03: end of Update APATCH"
Call ECR_TRACE(WMSG,0) From GESECRAN

End




