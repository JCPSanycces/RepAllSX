#<AdxTL>@(#)0.0.0.0 $Revision$Class Employee
# Supervisor
## CRUD-CLASSE ## EMPLOID
# 2018-11-06 07:05:43 657

Gosub TEST From WMCR_EMPLOID : End

############################################################################################
## C : Subprog AINSERT(INSTANCE)
## D : Subprog ADELETE(INSTANCE)
## R : Subprog AREAD(INSTANCE,REFNUM)
## U : Subprog AUPDATE(INSTANCE)
############################################################################################
# EMPLOID : EMPLOID
# EMPLOIDSA : EMPLOID EMPLOIDSA
# EMPLOIDUKI : EMPLOID EMPLOIDUKI
# EMPLORIB : EMPLOID EMPLORIB
# EMPLOCHD : EMPLOID EMPLOCHD
# EMPLOJNT : EMPLOID EMPLOJNT
# EMPLOEXM : EMPLOID EMPLOEXM
# EMPLOTRY : EMPLOID EMPLOTRY
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet EMPLOID._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1,A_N2,A_S2,A_N3,A_S3,A_N4,A_S4,A_N5,A_S5,A_N6,A_S6,A_N7,A_S7,A_N8,A_S8
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = EMPLOID.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(EMPLOID.ACTX.AFOLDER,nomap,"")>0
 Local File EMPLOID [ID]
 Local File EMPLOIDSA [ESA]
 Local File EMPLOIDUKI [IDUKI]
 Local File EMPLORIB [RIB]
 Local File EMPLOCHD [CHD]
 Local File EMPLOJNT [JNT]
 Local File EMPLOEXM [EXM]
 Local File EMPLOTRY [TRY]
Else
 Local File =EMPLOID.ACTX.AFOLDER+".EMPLOID" [ID]
 Local File =EMPLOID.ACTX.AFOLDER+".EMPLOIDSA" [ESA]
 Local File =EMPLOID.ACTX.AFOLDER+".EMPLOIDUKI" [IDUKI]
 Local File =EMPLOID.ACTX.AFOLDER+".EMPLORIB" [RIB]
 Local File =EMPLOID.ACTX.AFOLDER+".EMPLOCHD" [CHD]
 Local File =EMPLOID.ACTX.AFOLDER+".EMPLOJNT" [JNT]
 Local File =EMPLOID.ACTX.AFOLDER+".EMPLOEXM" [EXM]
 Local File =EMPLOID.ACTX.AFOLDER+".EMPLOTRY" [TRY]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [ID] With
& [ESA]ESA0 = [F:ID]REFNUM,
& [IDUKI]IDUKI0 = [F:ID]REFNUM,
& [RIB]RIB0 = [F:ID]REFNUM,
& [CHD]CHD0 = [F:ID]REFNUM,
& [JNT]JNT0 = [F:ID]REFNUM,
& [EXM]EXM0 = [F:ID]REFNUM,
& [TRY]TRY0 = [F:ID]REFNUM
& As [LNK_]
Return

############################################################################################
### EMPLOID(WID)
############################################################################################
Funprog  _MAJSQL_EMPLOID(WID)
Variable Instance WID Using C_EMPLOID
Local Integer ASTATUS,A_I,A_J
Default File [F:ID]
If WID.ASTALIN=[V]CST_ANEW
 Call INICRE(WID) From ASYRSUB
 SetInstance [F:ID] With WID
 For [L]A_J=1 to 3
  For [L]A_I=1 To maxtab(WID.PASDET)
   If WID.PASDET([L]A_I)<>null & !find(WID.PASDET([L]A_I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & WID.PASDET([L]A_I).AORDER=[L]A_J
    [F:ID]PASCRY([L]A_J-1) = WID.PASDET([L]A_I).PASCRY
    [F:ID]PASNUM([L]A_J-1) = WID.PASDET([L]A_I).PASNUM
    [F:ID]PASDTE([L]A_J-1) = WID.PASDET([L]A_I).PASDTE
    [F:ID]PLCISS([L]A_J-1) = WID.PASDET([L]A_I).PLCISS
    [F:ID]ISSAUZ([L]A_J-1) = WID.PASDET([L]A_I).ISSAUZ
    [F:ID]EXPDAT([L]A_J-1) = WID.PASDET([L]A_I).EXPDAT
    [F:ID]ETRPITTYP([L]A_J-1) = WID.PASDET([L]A_I).ETRPITTYP
    [F:ID]ETRPITDAT([L]A_J-1) = WID.PASDET([L]A_I).ETRPITDAT
    [F:ID]ETRPITEXPDAT([L]A_J-1) = WID.PASDET([L]A_I).ETRPITEXPDAT
    [F:ID]ESSUIDPAS([L]A_J-1) = WID.PASDET([L]A_I).ESSUIDPAS
    [F:ID]PASDATNEW([L]A_J-1) = WID.PASDET([L]A_I).PASDATNEW
    [F:ID]PASDATAMD([L]A_J-1) = WID.PASDET([L]A_I).PASDATAMD
    Break
   Endif
  Next
 Next
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 For [L]A_J=1 to 3
  For [L]A_I=1 To maxtab(WID.PERCNT)
   If WID.PERCNT([L]A_I)<>null & !find(WID.PERCNT([L]A_I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & WID.PERCNT([L]A_I).AORDER=[L]A_J
    [F:ID]NAMCNT([L]A_J-1) = WID.PERCNT([L]A_I).NAMCNT
    [F:ID]SRNCNT([L]A_J-1) = WID.PERCNT([L]A_I).SRNCNT
    [F:ID]CRYCNT([L]A_J-1) = WID.PERCNT([L]A_I).CRYCNT
    [F:ID]TELCNT([L]A_J-1) = WID.PERCNT([L]A_I).TELCNT
    [F:ID]MOBCNT([L]A_J-1) = WID.PERCNT([L]A_I).MOBCNT
    [F:ID]EMLCNT([L]A_J-1) = WID.PERCNT([L]A_I).EMLCNT
    [F:ID]ESSUIDCNT([L]A_J-1) = WID.PERCNT([L]A_I).ESSUIDCNT
    Break
   Endif
  Next
 Next
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 Write [F:ID]
 If fstat
  Call FSTA("ID",WID,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WID.updTick = [F:ID]updTick
Elsif WID.ASTALIN=[V]CST_ALL or WID.ASTALIN=[V]CST_AUPD
 Call INIUPD(WID) From ASYRSUB
 SetInstance [F:ID] With WID
 For [L]A_J=1 to 3
  For [L]A_I=1 To maxtab(WID.PASDET)
   If WID.PASDET([L]A_I)<>null & !find(WID.PASDET([L]A_I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & WID.PASDET([L]A_I).AORDER=[L]A_J
    [F:ID]PASCRY([L]A_J-1) = WID.PASDET([L]A_I).PASCRY
    [F:ID]PASNUM([L]A_J-1) = WID.PASDET([L]A_I).PASNUM
    [F:ID]PASDTE([L]A_J-1) = WID.PASDET([L]A_I).PASDTE
    [F:ID]PLCISS([L]A_J-1) = WID.PASDET([L]A_I).PLCISS
    [F:ID]ISSAUZ([L]A_J-1) = WID.PASDET([L]A_I).ISSAUZ
    [F:ID]EXPDAT([L]A_J-1) = WID.PASDET([L]A_I).EXPDAT
    [F:ID]ETRPITTYP([L]A_J-1) = WID.PASDET([L]A_I).ETRPITTYP
    [F:ID]ETRPITDAT([L]A_J-1) = WID.PASDET([L]A_I).ETRPITDAT
    [F:ID]ETRPITEXPDAT([L]A_J-1) = WID.PASDET([L]A_I).ETRPITEXPDAT
    [F:ID]ESSUIDPAS([L]A_J-1) = WID.PASDET([L]A_I).ESSUIDPAS
    [F:ID]PASDATNEW([L]A_J-1) = WID.PASDET([L]A_I).PASDATNEW
    [F:ID]PASDATAMD([L]A_J-1) = WID.PASDET([L]A_I).PASDATAMD
    Break
   Endif
  Next
 Next
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 For [L]A_J=1 to 3
  For [L]A_I=1 To maxtab(WID.PERCNT)
   If WID.PERCNT([L]A_I)<>null & !find(WID.PERCNT([L]A_I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & WID.PERCNT([L]A_I).AORDER=[L]A_J
    [F:ID]NAMCNT([L]A_J-1) = WID.PERCNT([L]A_I).NAMCNT
    [F:ID]SRNCNT([L]A_J-1) = WID.PERCNT([L]A_I).SRNCNT
    [F:ID]CRYCNT([L]A_J-1) = WID.PERCNT([L]A_I).CRYCNT
    [F:ID]TELCNT([L]A_J-1) = WID.PERCNT([L]A_I).TELCNT
    [F:ID]MOBCNT([L]A_J-1) = WID.PERCNT([L]A_I).MOBCNT
    [F:ID]EMLCNT([L]A_J-1) = WID.PERCNT([L]A_I).EMLCNT
    [F:ID]ESSUIDCNT([L]A_J-1) = WID.PERCNT([L]A_I).ESSUIDCNT
    Break
   Endif
  Next
 Next
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WID,"EMPLOID")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:ID]ID0 = [F:ID]REFNUM
 If fstat
  Call FSTA("ID",WID,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WID.updTick = [F:ID]updTick
Elsif WID.ASTALIN=[V]CST_ADEL
 SetInstance [F:ID] With WID
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WID,"EMPLOID")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:ID]ID0 = [F:ID]REFNUM
 If fstat
  Call FSTA("ID",WID,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK

############################################################################################
### EMPLOIDSA(WESA)
############################################################################################
Funprog  _MAJSQL_EMPLOIDSA(WESA)
Variable Instance WESA Using C_EMPLOIDSA
Local Integer ASTATUS,A_I,A_J
Default File [F:ESA]
If WESA.ASTALIN=[V]CST_ANEW
 Call INICRE(WESA) From ASYRSUB
 SetInstance [F:ESA] With WESA
 For [L]A_J=1 to 3
  For [L]A_I=1 To maxtab(WESA.EMPADR)
   If WESA.EMPADR([L]A_I)<>null & !find(WESA.EMPADR([L]A_I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & WESA.EMPADR([L]A_I).AORDER=[L]A_J
    [F:ESA]ADDPRI([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPRI
    [F:ESA]ADDTYP([L]A_J-1) = WESA.EMPADR([L]A_I).ADDTYP
    [F:ESA]ADDSRVTYP([L]A_J-1) = WESA.EMPADR([L]A_I).ADDSRVTYP
    [F:ESA]ADDPOSOTH([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSOTH
    [F:ESA]ADDPOSNUM([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSNUM
    [F:ESA]ADDPOSNAM([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSNAM
    [F:ESA]ADDPOSAGN([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSAGN
    [F:ESA]ADDPOSCOF([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSCOF
    [F:ESA]ADDPOSINM([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSINM
    [F:ESA]ADDCPX([L]A_J-1) = WESA.EMPADR([L]A_I).ADDCPX
    [F:ESA]ADDSTRNUM([L]A_J-1) = WESA.EMPADR([L]A_I).ADDSTRNUM
    [F:ESA]ADDSTRNAM([L]A_J-1) = WESA.EMPADR([L]A_I).ADDSTRNAM
    [F:ESA]ADDSUB([L]A_J-1) = WESA.EMPADR([L]A_I).ADDSUB
    [F:ESA]ADDTWN([L]A_J-1) = WESA.EMPADR([L]A_I).ADDTWN
    [F:ESA]ADDPOSCDE([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSCDE
    [F:ESA]ADDCNTCDE([L]A_J-1) = WESA.EMPADR([L]A_I).ADDCNTCDE
    [F:ESA]ADDPRV([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPRV
    [F:ESA]ADDCOR([L]A_J-1) = WESA.EMPADR([L]A_I).ADDCOR
    [F:ESA]ADDSTA([L]A_J-1) = WESA.EMPADR([L]A_I).ADDSTA
    Break
   Endif
  Next
 Next
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 For [L]A_J=1 to 3
  For [L]A_I=1 To maxtab(WESA.PASDET)
   If WESA.PASDET([L]A_I)<>null & !find(WESA.PASDET([L]A_I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & WESA.PASDET([L]A_I).AORDER=[L]A_J
    [F:ESA]PASCRY([L]A_J-1) = WESA.PASDET([L]A_I).PASCRY
    [F:ESA]PASNUM([L]A_J-1) = WESA.PASDET([L]A_I).PASNUM
    [F:ESA]PASDTE([L]A_J-1) = WESA.PASDET([L]A_I).PASDTE
    [F:ESA]ESSUIDPAS([L]A_J-1) = WESA.PASDET([L]A_I).ESSUIDPAS
    Break
   Endif
  Next
 Next
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 For [L]A_J=1 to 3
  For [L]A_I=1 To maxtab(WESA.PERCNT)
   If WESA.PERCNT([L]A_I)<>null & !find(WESA.PERCNT([L]A_I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & WESA.PERCNT([L]A_I).AORDER=[L]A_J
    [F:ESA]CNTTYP([L]A_J-1) = WESA.PERCNT([L]A_I).CNTTYP
    [F:ESA]ESSUIDCNT([L]A_J-1) = WESA.PERCNT([L]A_I).ESSUIDCNT
    Break
   Endif
  Next
 Next
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 Write [F:ESA]
 If fstat
  Call FSTA("ESA",WESA,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WESA.updTick = [F:ESA]updTick
Elsif WESA.ASTALIN=[V]CST_ALL or WESA.ASTALIN=[V]CST_AUPD
 Call INIUPD(WESA) From ASYRSUB
 SetInstance [F:ESA] With WESA
 For [L]A_J=1 to 3
  For [L]A_I=1 To maxtab(WESA.EMPADR)
   If WESA.EMPADR([L]A_I)<>null & !find(WESA.EMPADR([L]A_I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & WESA.EMPADR([L]A_I).AORDER=[L]A_J
    [F:ESA]ADDPRI([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPRI
    [F:ESA]ADDTYP([L]A_J-1) = WESA.EMPADR([L]A_I).ADDTYP
    [F:ESA]ADDSRVTYP([L]A_J-1) = WESA.EMPADR([L]A_I).ADDSRVTYP
    [F:ESA]ADDPOSOTH([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSOTH
    [F:ESA]ADDPOSNUM([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSNUM
    [F:ESA]ADDPOSNAM([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSNAM
    [F:ESA]ADDPOSAGN([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSAGN
    [F:ESA]ADDPOSCOF([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSCOF
    [F:ESA]ADDPOSINM([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSINM
    [F:ESA]ADDCPX([L]A_J-1) = WESA.EMPADR([L]A_I).ADDCPX
    [F:ESA]ADDSTRNUM([L]A_J-1) = WESA.EMPADR([L]A_I).ADDSTRNUM
    [F:ESA]ADDSTRNAM([L]A_J-1) = WESA.EMPADR([L]A_I).ADDSTRNAM
    [F:ESA]ADDSUB([L]A_J-1) = WESA.EMPADR([L]A_I).ADDSUB
    [F:ESA]ADDTWN([L]A_J-1) = WESA.EMPADR([L]A_I).ADDTWN
    [F:ESA]ADDPOSCDE([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSCDE
    [F:ESA]ADDCNTCDE([L]A_J-1) = WESA.EMPADR([L]A_I).ADDCNTCDE
    [F:ESA]ADDPRV([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPRV
    [F:ESA]ADDCOR([L]A_J-1) = WESA.EMPADR([L]A_I).ADDCOR
    [F:ESA]ADDSTA([L]A_J-1) = WESA.EMPADR([L]A_I).ADDSTA
    Break
   Endif
  Next
 Next
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 For [L]A_J=1 to 3
  For [L]A_I=1 To maxtab(WESA.PASDET)
   If WESA.PASDET([L]A_I)<>null & !find(WESA.PASDET([L]A_I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & WESA.PASDET([L]A_I).AORDER=[L]A_J
    [F:ESA]PASCRY([L]A_J-1) = WESA.PASDET([L]A_I).PASCRY
    [F:ESA]PASNUM([L]A_J-1) = WESA.PASDET([L]A_I).PASNUM
    [F:ESA]PASDTE([L]A_J-1) = WESA.PASDET([L]A_I).PASDTE
    [F:ESA]ESSUIDPAS([L]A_J-1) = WESA.PASDET([L]A_I).ESSUIDPAS
    Break
   Endif
  Next
 Next
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 For [L]A_J=1 to 3
  For [L]A_I=1 To maxtab(WESA.PERCNT)
   If WESA.PERCNT([L]A_I)<>null & !find(WESA.PERCNT([L]A_I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & WESA.PERCNT([L]A_I).AORDER=[L]A_J
    [F:ESA]CNTTYP([L]A_J-1) = WESA.PERCNT([L]A_I).CNTTYP
    [F:ESA]ESSUIDCNT([L]A_J-1) = WESA.PERCNT([L]A_I).ESSUIDCNT
    Break
   Endif
  Next
 Next
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WESA,"EMPLOIDSA")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:ESA]ESA0 = [F:ESA]REFNUM
 If fstat
  Call FSTA("ESA",WESA,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WESA.updTick = [F:ESA]updTick
Elsif WESA.ASTALIN=[V]CST_ADEL
 SetInstance [F:ESA] With WESA
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WESA,"EMPLOIDSA")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:ESA]ESA0 = [F:ESA]REFNUM
 If fstat
  Call FSTA("ESA",WESA,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK

############################################################################################
### EMPLOIDUKI(WIDUKI)
############################################################################################
Funprog  _MAJSQL_EMPLOIDUKI(WIDUKI)
Variable Instance WIDUKI Using C_EMPLOIDUKI
Local Integer ASTATUS,A_I,A_J
Default File [F:IDUKI]
If WIDUKI.ASTALIN=[V]CST_ANEW
