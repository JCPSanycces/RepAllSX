#<AdxTL>@(#)7.0.0.0 $Revision$
$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "DEBUT"      : Gosub DEBUT
Endcase
Return
############################################################
$OUVRE
If PARAM(1) = ""
  FIN = 1
Else
  If clalev([F:TCT]) = 0 : Local File TABCTL   [TCT] : Endif
Endif
Return
############################################################
$DEBUT
Raz [M:VTCT]
#
Filter [TCT] Where TCT = PARAM(1)
&            Order By Key TCT0          
nolign = 0
For [TCT]
  If nolign < dim([M:VTCT]COD)-1
    nolign += 1
    [M:VTCT] = [F:TCT]    
    Case [F:TCT]TCTTYP
      When 1       : [M:VTCT]COD(nolign-1) = [F:TCT]ALPCOD
      When Default : [M:VTCT]COD(nolign-1) = num$([F:TCT]NUMCOD) 
    Endcase
  Endif
Next
Filter [TCT]
[M:VTCT]BASTAB = nolign
If [M:VTCT]TCT <> ""
  Affzo [M:VTCT]
Else
  FIN = 1
Endif
Return

########################################
Subprog AS_BASTAB
If [M]QSTNUM(nolign-1) = ""
  GBOUT1 = ""
Endif
End

