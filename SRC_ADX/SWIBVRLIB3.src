######################################################################################################
# Module        : ACCOUNTING
# Description   : - Suppliers invoices (EZAG) bank file generation
######################################################################################################
 # Updates :
 # Date       |Author|Version|Description
 # 2015-07-13 |Bader |U9     |CREECR_GT27/CREECR_GT37: don't create IBAN if IBAN prefix is not set
 # 2015-08-11 |Bader |U9     |HANDLE_BANK_FOR_CHARGES (new): check bank for charges outside of loop
 # 2015-08-14 |Bader |U9     |110303: MAJ_PAY*: don't reduce STA if already greater than 6
 # 2015-11-05 |Bader |U10    |11033: CONT_COMPT: allow ISR participant number with 9 digits (without “-“)
 # 2016-02-19 |DNE   |U10    |Bugfixing (SAM #114567)
 # 2016-05-17 |Bader |U11    |Bugfixing SAM 116590: write last 9 digits of BIDNUM instead of BVRNUM INTO COMPTEBAN/COMPTEBANF
#######################################################################################################
# 2016-01-14 DNE INSERT BEGIN ########################################################################
Call UPDATE_BVRNUM : End
# 2016-01-14 DNE INSERT END ##########################################################################



#*****************************************************************************************************
# EZAG: Routine de génération du fichier EZAG
#*****************************************************************************************************
Subprog EZAG()
    Local Integer REP
    Qstbox mess(22,3648,1)-chr$(13)+chr$(10)+mess(205,100,1) Titled mess(23,3648,1) Using [L]REP
    Case [L]REP
    When 1 :
        TFBFIL_ = [FRM]TFBFIL
        If TFBFIL_ <> ""
            Qstbox mess(260,107,1) + " " + TFBFIL_ + " ?" Using [L]REP  # Data already exists.\Do you want to overwrite it?
            Case [L]REP
                When 1 : Call REGOPAE()
            Endcase
        Else
            Call REGOPAE()
        Endif
   Endcase
End
#*****************************************************************************************************
Subprog REGOPAE()
Local Char XSLEG(GLONADI)
Local Integer TYPE_DTA

#---- Déclaration des variables utilisées ----#
Gosub DECLARATION_

#---- Initialisation des variables ----#
COMPTEBAN=""
Gosub HANDLE_BANK_FOR_CHARGE
If ERREUR = 1 : End : Endif

NOORDRE=0
COMPTEUR = -1

TFBFIL_ = [F:FRM]TFBFIL

#---- Ouverture des fichiers utilisés ----#
Gosub OUVRE_

#---- Ecriture de l'enregistrement de tête obligatoire 00 ----#
Gosub TRF_GT00
Gosub ECR_GT00
Gosub CREECR_GT00

Raz [L]XSLEG
Call GET_LEG([M:FRM0]CPY,[L]XSLEG) From SWILIB0

Filter [ZPYH] Where FRMNUM = [M:FRM0]FRMNUM     # leture des PAYMENTH correspondant au bordereau de remise
For [ZPYH]
    Call LEC_TPY_LEG([L]XSLEG,[M:FRM0]PAYTYP) From CPTLEC    # read payment entry type
    If fstat=0
       If [F:TPY]SWIPAYTYP = 3                   # EZAG payment
          Read [XTAM]TAM0 = [F:ZPYH]PAM;[L]XSLEG
# 2016-02-19 DNE INSERT BEGIN (SAM #114567)
          If fstat
              # Let's give a 2nd try for "All legislations".
              Read [XTAM]TAM0 = [F:ZPYH]PAM;""
          Endif
# 2016-02-19 DNE INSERT END
          If fstat = 0
             TYPE_DTA = [XTAM]TYP
             Case TYPE_DTA
                When 22
                    Gosub TRF_GT00
                    GT00_8="22"
                    Gosub ECR_GT00
                    Gosub CREECR_GT22
                When 24
                    Gosub TRF_GT00
                    GT00_8="24"
                    Gosub ECR_GT00
                    Gosub CREECR_GT24
                When 27
                    Gosub TRF_GT00
                    GT00_8="27"
                    If [F:ZPYH]SWISUP2=2
                        GT00_11="1"
                    Else
                        GT00_11="0"
                    Endif
                    Gosub ECR_GT00
                    Gosub CREECR_GT27
                When 28
                    Gosub TRF_GT00
                    GT00_8="28"
                    Gosub ECR_GT00
                    Gosub CREECR_GT28
                When 32
                    GERR= 1
                    GMESSAGE=func AFNC.MES1( mess(52,3648,1), "32")
                    End
                    Return
                When 34
                    Gosub TRF_GT00
                    GT00_8="34"
                    Gosub ECR_GT00
                    Gosub CREECR_GT34
                When 37
                    Gosub TRF_GT00
                    GT00_8="37"
                    Gosub ECR_GT00
                    Gosub CREECR_GT37
                When 38
                    GERR= 1
                    GMESSAGE=func AFNC.MES1( mess(52,3648,1), "38")
                    End
                    Return
            Endcase
          Endif
       Endif
    Else
       Infbox(func AFNC.MES1( mess(17,3648,1), [M:FRM0]PAYTYP)) # Error reading transaction $1$.
    Endif
Next
Filter [ZPYH]

Gosub TRF_GT00
GT00_8 = "97"
Gosub ECR_GT00
Gosub CREECR_GT97
Openo Using [FIC]
If GERRTRACE = 0
    Local Char XFILEXT(30)
    XFILEXT = [M:FRM0]BAN
    If !clalev([XBAN]) : Local File BANK [XBAN] : Endif
    Read [XBAN]BAN0 = [M:FRM0]BAN
    If !fstat and [F:XBAN]FILEXT <> ""
        XFILEXT = [F:XBAN]FILEXT
    Endif


    #Ok, alors on calcul le bon nom de fichier
    If REGENERATION<2
        Gosub CALCUL_COMPTEUR_
        If GBVRNUMERIC=2
            TFBFIL_ = left$([M:FRM0]PAYTYP, 2) + format$("N0:8", COMPTEUR_) + "." + XFILEXT
            TFBFIL2_ = left$([M:FRM0]PAYTYP, 2) + format$("N0:8", COMPTEUR_)
        Else
            TFBFIL_ = left$([M:FRM0]PAYTYP, 2) + format$("8X", COMPTEUR_) + "." + XFILEXT
            TFBFIL2_ = left$([M:FRM0]PAYTYP, 2) + format$("8X", COMPTEUR_)
        Endif
    Else
        TFBFIL2_ =left$(TFBFIL_, 10)
    Endif
    FICHIER = filpath("BQE",TFBFIL2_, XFILEXT )
    #On recopie le fichier temporaire dans le bon fichier

    #System "cp "+FICHIERTMP+" "+FICHIER
    Call COPIE(FICHIERTMP, FICHIER, STAT_) From ORDSYS

    #On met à jour les tables des paiements
    Gosub MAJ_PAYFRM2
    Gosub MAJ_PAYMENTH
    Infbox func AFNC.MES1( mess(55,149,1),FICHIER)  # The $1$ file has been sucessfully created
Else
    #On supprmie le fichier temporaire
    #System "rm " + FICHIERTMP
    Call EFFACE(FICHIERTMP, STAT_) From ORDSYS
    Errbox func AFNC.MES1( mess(46,3648,1),"EZAG") Titled mess(324,117,1) # The $1$ file is incorrect. Please correct the error and create the file again!
Endif
Gosub FERME_
End

$HANDLE_BANK_FOR_CHARGE
If BANK_FOR_CHARGE = ""                                # empty bank for charges not allowed
    Call ECR_TRACE(mess(53,3648,1),1) From GESECRAN    # The bank for charges is not properly configured. Please check parameter SWIPAYBAN.
    ERREUR = 1
Else
    If !clalev([F:XBAN]) : Local File BANK[XBAN]      : Endif
    Read [F:XBAN]BAN0 = BANK_FOR_CHARGE                # recherche de la banque
    If fstat = 0 Then
    # SAM 116590 2016-05-17 Bader
        COMPTEBANF = format$("K:9X",right$([F:XBAN]BIDNUM,len([F:XBAN]BIDNUM)-9+1)) # take account from BIDNUM taking the last 9 digits
#        COMPTEBANF=[F:XBAN]BVRNUM
#        Call CONT_COMPT(COMPTEBANF)
#        If mkstat<>0
#            Call ECR_TRACE(func AFNC.MES1( mess(39,3648,1), [F:XBAN]BVRNUM),1) From GESECRAN # The structure of the ISR customer number $1$ doesn't belong to a post office account!
#            ERREUR = 1
#        Endif
    # SAM 116590 2016-05-17 Bader END
    Else
        Call ECR_TRACE(func AFNC.MES1( mess(40,3648,1), BANK_FOR_CHARGE)+mess(53,3648,1),1) From GESECRAN # Error reading the bank $1$. The bank for charges is not properly configured.
                                                                                                          # Please check parameter SWIPAYBAN.
        ERREUR = 1
    Endif
Endif
Return

#-----------------------------------------------------------------------------------------------------
# DECLARATION: Déclaration des variables utilisées
#-----------------------------------------------------------------------------------------------------
$DECLARATION_
