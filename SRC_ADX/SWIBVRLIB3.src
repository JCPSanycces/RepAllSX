GT24_4="CHF"
GT24_5="CH"

GT24_6=space$(15)
GT24_7=space$(34)

#Remise en main propre
If [F:ZPYH]SWISUP1=2    # Personally
    GT24_8="1"
Else
    GT24_8= space$(1)
Endif

#Destinataire et destinataire finaux
#Actuellement on récupère l'adresse du RIB. Il est aussi possible de prendre l'adresse par défault
Read [F:XBID]BID0 = 1;[F:ZPYH]BPR;[ZPYH]BID
If fstat <> 0
    Call ECR_TRACE(func AFNC.MES1( mess(28,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the bank ID for the payment $1$.
Endif
Read [F:XBPA]BPA0(3) = 1;[F:ZPYH]BPR;[F:XBID]BPAADD        # lecture de l'adresse du tier
If fstat = 0 Then
    GT24_9=format$("K:35X",[F:XBPA]BPADES)
    GT24_10=space$(35)
    GT24_11=format$("K:35X",[F:XBPA]BPAADDLIG(0))
    GT24_12=format$("K<:10X",[F:XBPA]POSCOD)
    GT24_13=format$("K:25X",[F:XBPA]CTY)
    GT24_14=space$(35)
    GT24_15=space$(35)
    GT24_16=space$(35)
    GT24_17=space$(10)
    GT24_18=space$(25)
Else
    Call ECR_TRACE(func AFNC.MES2( mess(43,3648,1), [F:XBID]BPAADD, [F:ZPYH]BPR),1) From GESECRAN # Address $1$ for business partner $2$ not found!
Endif

#Communication. Actuellement on récupère les commentaires de la 1ère ligne de facture
GT24_19=space$(35)
GT24_20=space$(35)
GT24_21=space$(35)
GT24_22=space$(35)
Read [F:XPYD]PYD0=[F:ZPYH]NUM;1
If fstat = 0 Then
    If func SWILIB0.IS_SUPPLIER_INVOICE([F:XPYD]VCRTYP) and [F:XPYD]VCRNUM<>""
        Read [F:XPIH]PIH0 = [XPYD]VCRNUM         # lecture la facture PINVOICE
        If fstat = 0 Then
            GT24_19=format$("K:35X",[F:XPIH]DES(0))
            GT24_20=format$("K:35X",[F:XPIH]DES(1))
            GT24_21=format$("K:35X",[F:XPIH]DES(2))
        Else
            Call ECR_TRACE(func AFNC.MES1( mess(29,3648,1), [XPYD]VCRNUM), 1) From GESECRAN # Error reading the invoice $1$.
        Endif
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(30,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the payment details $1$.
Endif

GT24_23=space$(3)
GT24_24=space$(1)

#Donneur d'ordre, on récupère les informations de l'adresse du site
GT24_25=space$(35)
GT24_26=space$(35)
GT24_27=space$(35)
GT24_28=space$(10)
GT24_29=space$(25)

Read [F:XFCY]FCY0 = [F:ZPYH]FCY                                   # recherche du site
If fstat = 0
    Read [F:XBPA]BPA0(3) = TYP;[F:ZPYH]FCY;[F:XFCY]BPAADD        # recherche de l'adresse du site
    If fstat = 0 Then
        GT24_25=format$("K:35X",[F:XBPA]BPADES)
        GT24_27=format$("K:35X",[F:XBPA]BPAADDLIG(0))
        GT24_28=format$("K<:10X",[F:XBPA]POSCOD)
        GT24_29=format$("K:25X",[F:XBPA]CTY)
    Else
        Call ECR_TRACE(func AFNC.MES1( mess(24,2260,1), [F:ZPYH]FCY), 1) From GESECRAN # Address for site $1$ not found!
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(49,2260,1), [F:ZPYH]FCY), 1) From GESECRAN # Site $1$ cannot be found
Endif
GT24_30=space$(14)

#Ecriture de l'enregistrement
Wrseq GT24_1, GT24_2, GT24_3, GT24_4, GT24_5, GT24_6, GT24_7, GT24_8, GT24_9, GT24_10, GT24_11, GT24_12, GT24_13, GT24_14, GT24_15,
&GT24_16, GT24_17, GT24_18, GT24_19, GT24_20, GT24_21, GT24_22, GT24_23, GT24_24, GT24_25,GT24_26, GT24_27, GT24_28, GT24_29, GT24_30, Using [FIC]
Return

#-----------------------------
# Enregistrements de type 27
# Pmt clearing en CH
#-----------------------------
$CREECR_GT27
Local Integer ESP_
Local Char ZERO_(30)
ZERO_="0000000000"

GT27_1=format$("K:3X", [F:ZPYH]CUR)
GT27_2=format$("N0:13",100*[F:ZPYH]AMTCUR)
#Gestion du total
Gosub TOTAL_
GT27_3=space$(1)
GT27_4=format$("K:3X", [F:ZPYH]CUR)

Read [F:XBID]BID0 = 1;[F:ZPYH]BPR;[ZPYH]BID
If fstat = 0
    If [F:XBID]CRY = "CH" or [F:XBID]CRY = "LI"
        GT27_5=[F:XBID]CRY
    Else
        GT27_5="__"
        Call ECR_TRACE(func AFNC.MES2( mess(33,3648,1), [ZPYH]NUM, "27"),1) From GESECRAN # Payment type $2$: recipient must be located inside of Switzerland or Liechtenstein (payment: $1$)
    Endif
    NUMCLEAR = func SWILIB0.STRIP_ZEROS(left$([F:XBID]BIDNUM,5)) # delete leading zeros from clearing number
    Gosub INIT_IBACOD From SWIBVRLIB2
    If IBACOD <> ""
        GT27_6 = space$(15)
        GT27_7 = format$("K<:35X",IBACOD)
    Else
        If len(NUMCLEAR)>5
            GT27_6 = format$("K<:15X",NUMCLEAR)
        Else
            GT27_6 = space$(2)+NUMCLEAR+left$(ZERO_,6-len(NUMCLEAR))+space$(1)+space$(6)
        Endif
        If (NUMCLEAR="199" or NUMCLEAR="9000")
            GT27_7 = format$("K<:35X",left$([F:XBID]BVRNUM,2)+mid$([F:XBID]BVRNUM,4,6)+right$([F:XBID]BVRNUM,len([F:XBID]BVRNUM)))
        Else
            GT27_7 = format$("K<:35X",func SWILIB0.STRIP_ZEROS(right$([F:ZPYH]BID,6))) # take account from BIDNUM from position 6 following
        Endif
    Endif

    GT27_8=format$("K:35X",[F:XBID]PAB1)
    GT27_9=space$(35)
    GT27_10=format$("K:35X",[F:XBID]PAB2)
    ESP_=instr(1,[F:XBID]PAB3," ")
    If ESP_>=1
        GT27_11=format$("K<:10X", left$([F:XBID]PAB3,ESP_-1))
        GT27_12=format$("K:25X", right$([F:XBID]PAB3,ESP_+1))
    Else
        GT27_11 = space$(10)
        GT27_12 = format$("K:25X",[F:XBID]PAB3)
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(28,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the bank ID for the payment $1$.
Endif

#Adresse du bénéficiaire
Read [F:XBPA]BPA0(3) = 1;[F:ZPYH]BPR;[F:XBID]BPAADD        # lecture de l'adresse du tier
If fstat = 0 Then
    GT27_13=format$("K:35X",[F:XBPA]BPADES)
    GT27_14=space$(35)
    GT27_15=format$("K:35X",[F:XBPA]BPAADDLIG(0))
    GT27_16=format$("K<:10X",[F:XBPA]POSCOD)
    GT27_17=format$("K:25X",[F:XBPA]CTY)
Else
    Call ECR_TRACE(func AFNC.MES2( mess(43,3648,1), [F:XBID]BPAADD, [F:ZPYH]BPR),1) From GESECRAN # Address $1$ for business partner $2$ not found!
Endif


#Communication. Actuellement on récupère les commentaires de la 1ère ligne de facture
GT27_18=space$(35)
GT27_19=space$(35)
GT27_20=space$(35)
GT27_21=space$(35)
Read [F:XPYD]PYD0=[F:ZPYH]NUM;1
If fstat = 0 Then
    If func SWILIB0.IS_SUPPLIER_INVOICE([F:XPYD]VCRTYP) and [F:XPYD]VCRNUM<>""
        Read [F:XPIH]PIH0 = [XPYD]VCRNUM         # lecture la facture PINVOICE
        If fstat = 0 Then
            GT27_18=format$("K:35X",[F:XPIH]DES(0))
            GT27_19=format$("K:35X",[F:XPIH]DES(1))
            GT27_20=format$("K:35X",[F:XPIH]DES(2))
        Else
            Call ECR_TRACE(func AFNC.MES1( mess(29,3648,1), [XPYD]VCRNUM), 1) From GESECRAN # Error reading the invoice $1$.
        Endif
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(30,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the payment details $1$.
Endif

GT27_22=space$(3)
GT27_23=space$(1)

#Donneur d'ordre, on récupère les informations de l'adresse du site
GT27_24=space$(35)
GT27_25=space$(35)
GT27_26=space$(35)
GT27_27=space$(10)
GT27_28=space$(25)

Read [F:XFCY]FCY0 = [F:ZPYH]FCY                                   # recherche du site
If fstat = 0
    Read [F:XBPA]BPA0(3) = TYP;[F:ZPYH]FCY;[F:XFCY]BPAADD        # recherche de l'adresse du site
    If fstat = 0 Then
        GT27_24=format$("K:35X",[F:XBPA]BPADES)
        GT27_26=format$("K:35X",[F:XBPA]BPAADDLIG(0))
        GT27_27=format$("K<:10X",[F:XBPA]POSCOD)
        GT27_28=format$("K:25X",[F:XBPA]CTY)
    Else
        Call ECR_TRACE(func AFNC.MES1( mess(24,2260,1), [F:ZPYH]FCY), 1) From GESECRAN # Address for site $1$ not found!
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(49,2260,1), [F:ZPYH]FCY), 1) From GESECRAN # Site $1$ cannot be found
Endif
GT27_29=space$(14)

#Ecriture de l'enregistrement
Wrseq GT27_1, GT27_2, GT27_3, GT27_4, GT27_5, GT27_6, GT27_7, GT27_8, GT27_9, GT27_10, GT27_11, GT27_12, GT27_13, GT27_14, GT27_15,
&GT27_16, GT27_17, GT27_18, GT27_19, GT27_20, GT27_21, GT27_22, GT27_23, GT27_24, GT27_25,GT27_26, GT27_27, GT27_28, GT27_29, Using [FIC]
Return

#-----------------------------
# Enregistrements de type 28
# Pmt BVR
#-----------------------------
$CREECR_GT28
If [F:ZPYH]CUR <> "CHF" and [F:ZYPH]CUR <>"EUR"
    Call ECR_TRACE(func AFNC.MES1( mess(31,3648,1), [ZPYH]NUM, "CHF/EUR", "28"),1) From GESECRAN # The currency of the payment $1$ is not correct. $2$ required for type $3$.
Else
    GT28_1=format$("K:3X", [F:ZPYH]CUR)
    GT28_4=format$("K:3X", [F:ZPYH]CUR)
Endif
GT28_2=format$("N0:13",100*[F:ZPYH]AMTCUR)
#Gestion du total
Gosub TOTAL_
GT28_3=space$(1)
GT28_5="CH"
#lecture de la facture pour récupérer la ligne de codage
GT28_6=space$(2)
GT28_7=space$(9)
GT28_8=space$(27)

Read [F:XPYD]PYD0 = [ZPYH]NUM;1                  # recherche PAYMENTD
If fstat = 0 Then
    Read [F:XPIH]PIH0 = [XPYD]VCRNUM           # lecture PINVOICE
    If fstat = 0 Then
        CHAINE = ""
        CHAINE = [F:XPIH]BVRREFLINE                # recherche BVRREFLINE
        If CHAINE <> "" Then
            If len(CHAINE) = 53 and mid$(CHAINE,14,1) = ">" and mid$(CHAINE,42,2) = "+ " and right$(CHAINE,53) = ">"
                GT28_7 = format$("K:9X",seg$(CHAINE, 44, 52))
                GT28_8 = format$("K:27X",seg$(CHAINE, 15, 41))
            Endif

            If len(CHAINE) = 43 and mid$(CHAINE,4,1) = ">" and mid$(CHAINE,32,2) = "+ " and right$(CHAINE,43) = ">"
                GT28_7 = format$("K:9X",seg$(CHAINE, 34, 42))
                GT28_8 = format$("K:27X",seg$(CHAINE, 5, 31))
            Endif

            If len(CHAINE) = 41 and mid$(CHAINE,1,1) = "<" and mid$(CHAINE,17,2) = "> " and mid$(CHAINE,34,2) = "+ " and right$(CHAINE,41) = ">"
                GT28_6 = seg$(CHAINE, 2, 3)
                GT28_7 = format$("N0:9",seg$(CHAINE,36,40))
                GT28_8 = format$("N0:27",seg$(CHAINE, 19, 33))
            Endif

            If len(CHAINE) = 23 and mid$(CHAINE,16,2) = "+ " and right$(CHAINE,23) = ">"
               GT28_7 = format$("N0:9",seg$(CHAINE, 18, 22))
               GT28_8 = format$("N0:9",seg$(CHAINE, 1, 15))
            Endif

            If len(CHAINE) = 6 and right$(CHAINE,6) = ">"
               GT28_7 = format$("N0:9",seg$(CHAINE, 1, 5))
            Endif

            If len(CHAINE) = 42 and mid$(CHAINE,14,1) = ">" and mid$(CHAINE,31,2) = "+ " and right$(CHAINE,42) = ">"
               GT28_7 = seg$(CHAINE, 33, 41)
               GT28_8 = format$("N0:27",seg$(CHAINE, 15, 30))
            Endif

            If len(CHAINE) = 28 and mid$(CHAINE,17,2) = "+ " and right$(CHAINE,28) = ">"
               GT28_7 = seg$(CHAINE, 19, 27)
               GT28_8 = format$("N0:27",seg$(CHAINE, 1, 16))
            Endif

            If len(CHAINE) = 32 and mid$(CHAINE,4,1) = ">" and mid$(CHAINE,21,2) = "+ " and right$(CHAINE,32) = ">"
               GT28_7 = seg$(CHAINE, 23, 31)
               GT28_8 = format$("N0:27",seg$(CHAINE, 5, 20))
            Endif
        Endif
    Else
        Call ECR_TRACE(func AFNC.MES1( mess(29,3648,1), [XPYD]VCRNUM), 1) From GESECRAN # Error reading the invoice $1$.
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(30,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the payment details $1$.
Endif

#Donneur d'ordre, on récupère les informations de l'adresse du site
GT28_9=space$(35)

Read [F:XFCY]FCY0 = [F:ZPYH]FCY                                   # recherche du site
If fstat = 0
    GT28_9=format$("K:35X",[F:XFCY]FCYNAM)
Else
    Call ECR_TRACE(func AFNC.MES1( mess(49,2260,1), [F:ZPYH]FCY), 1) From GESECRAN # Site $1$ cannot be found
Endif

#Ecriture de l'enregistrement
Wrseq GT28_1, GT28_2, GT28_3, GT28_4, GT28_5, GT28_6, GT28_7, GT28_8, GT28_9, space$(250), space$(250),space$(55), Using [FIC]
Return

#-----------------------------
# Enregistrements de type 34
# Pmt mandat postal hors CH
#-----------------------------
$CREECR_GT34

GT34_1=format$("K:3X", [F:ZPYH]CUR)
GT34_2=format$("N0:13",100*[F:ZPYH]AMTCUR)

#Gestion du total
Gosub TOTAL_
GT34_3=space$(1)
GT34_4=format$("K:3X", [F:ZPYH]CUR)

#lecture de l'adresse du pmt afin de vérifier qu'il est hors CH
Read [F:XBID]BID0 = 1;[F:ZPYH]BPR;[ZPYH]BID
If fstat = 0
    If [F:XBID]CRY<>"CH" and [F:XBID]CRY<>"LI"
        GT34_5=[F:XBID]CRY
    Else
        Call ECR_TRACE(func AFNC.MES2( mess(51,3648,1), [ZPYH]NUM, "34"),1) From GESECRAN # Payment type $2$: recipient must be located outside of Switzerland or Liechtenstein (payment: $1$)
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(28,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the bank ID for the payment $1$.
Endif
GT34_6=space$(15)
GT34_7=space$(35)

#Destinataire et destinataire finaux

Read [F:XBPA]BPA0(3) = 1;[F:ZPYH]BPR;[F:XBID]BPAADD        # lecture de l'adresse du tier
If fstat = 0 Then
    GT34_8=format$("K:35X",[F:XBPA]BPADES)
    GT34_9=space$(35)
    GT34_10=format$("K:35X",[F:XBPA]BPAADDLIG(0))
    GT34_11=format$("K<:10X",[F:XBPA]POSCOD)
    GT34_12=format$("K:25X",[F:XBPA]CTY)
    GT34_13=space$(35)
    GT34_14=space$(35)
    GT34_15=space$(35)
    GT34_16=space$(10)
    GT34_17=space$(25)
Else
    Call ECR_TRACE(func AFNC.MES2( mess(43,3648,1), [F:XBID]BPAADD, [F:ZPYH]BPR),1) From GESECRAN # Address $1$ for business partner $2$ not found!
Endif

#Communication. Actuellement on récupère les commentaires de la 1ère ligne de facture
GT34_18=space$(35)
GT34_19=space$(35)
GT34_20=space$(35)
GT34_21=space$(35)
Read [F:XPYD]PYD0=[F:ZPYH]NUM;1
If fstat = 0 Then
    If func SWILIB0.IS_SUPPLIER_INVOICE([F:XPYD]VCRTYP) and [F:XPYD]VCRNUM<>""
        Read [F:XPIH]PIH0 = [XPYD]VCRNUM         # lecture la facture PINVOICE
        If fstat = 0 Then
            GT34_18=format$("K:35X",[F:XPIH]DES(0))
            GT34_19=format$("K:35X",[F:XPIH]DES(1))
            GT34_20=format$("K:35X",[F:XPIH]DES(2))
        Else
            Call ECR_TRACE(func AFNC.MES1( mess(29,3648,1), [XPYD]VCRNUM), 1) From GESECRAN # Error reading the invoice $1$.
        Endif
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(30,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the payment details $1$.
Endif

#Code de taxe
Case [F:ZPYH]SWISUP3
    When 3 : GT34_22="OUR"      # Applicant
    When 2 : GT34_22="BEN"      # Beneficiary
    When 1 : GT34_22=space$(3)  # Shared
    When Default : GT34_22=space$(3)
Endcase

GT34_23=space$(1)

#Donneur d'ordre, on récupère les informations de l'adresse du site
GT34_24=space$(35)
GT34_25=space$(35)
GT34_26=space$(35)
GT34_27=space$(10)
GT34_28=space$(25)

Read [F:XFCY]FCY0 = [F:ZPYH]FCY                                   # recherche du site
If fstat = 0
    Read [F:XBPA]BPA0(3) = TYP;[F:ZPYH]FCY;[F:XFCY]BPAADD        # recherche de l'adresse du site
    If fstat = 0 Then
        GT34_24=format$("K:35X",[F:XBPA]BPADES)
        GT34_26=format$("K:35X",[F:XBPA]BPAADDLIG(0))
        GT34_27=format$("K<:10X",[F:XBPA]POSCOD)
        GT34_28=format$("K:25X",[F:XBPA]CTY)
    Else
        Call ECR_TRACE(func AFNC.MES1( mess(24,2260,1), [F:ZPYH]FCY), 1) From GESECRAN # Address for site $1$ not found!
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(49,2260,1), [F:ZPYH]FCY), 1) From GESECRAN # Site $1$ cannot be found
Endif
GT34_29=space$(14)

#Ecriture de l'enregistrement
Wrseq GT34_1, GT34_2, GT34_3, GT34_4, GT34_5, GT34_6, GT34_7, GT34_8, GT34_9, GT34_10, GT34_11, GT34_12, GT34_13, GT34_14, GT34_15,
&GT34_16, GT34_17, GT34_18, GT34_19, GT34_20, GT34_21, GT34_22, GT34_23, GT34_24, GT34_25,GT34_26, GT34_27, GT34_28, GT34_29, Using [FIC]
Return

#-----------------------------
# Enregistrements de type 37
# Pmt bancaire internationaux
#-----------------------------
$CREECR_GT37
Local Integer ESP_
Local Char ZERO_(30)
ZERO_="0000000000"

GT37_1=format$("K:3X", [F:ZPYH]CUR)
GT37_2=format$("N0:13",100*[F:ZPYH]AMTCUR)
#Gestion du total
Gosub TOTAL_
GT37_3=space$(1)
GT37_4=format$("K:3X", [F:ZPYH]CUR)

#lecture de l'adresse du pmt afin de vérifier qu'il est hors CH
Read [F:XBID]BID0 = 1;[F:ZPYH]BPR;[ZPYH]BID
If fstat = 0
    If [F:XBID]CRY<>"CH" and [F:XBID]CRY<>"LI"
        GT37_5=[F:XBID]CRY
    Else
        GT37_5="__"
        Call ECR_TRACE(func AFNC.MES2( mess(51,3648,1), [ZPYH]NUM, "37"),1) From GESECRAN # Payment type $2$: recipient must be located outside of Switzerland or Liechtenstein (payment: $1$)
    Endif
    If [F:XBID]BICCOD<>""
        GT37_6=format$("K:15X",[F:XBID]BICCOD)
    Else
        GT37_6 = space$(15)  # we don't know the format of the clearing number (part of BIDNUM) of a foreign bank -> spaces
    Endif

    Gosub INIT_IBACOD From SWIBVRLIB2
    If IBACOD <> ""
       GT37_7 = format$("K<:35X",IBACOD)
    Else
       GT37_7=format$("K<:35X",[F:XBID]BIDNUM)
    Endif

    GT37_8=format$("K:35X",[F:XBID]PAB1)
    GT37_9=space$(35)
    GT37_10=format$("K:35X",[F:XBID]PAB2)
    ESP_=instr(1,[F:XBID]PAB3," ")
    If ESP_>=1
        GT37_11=format$("K<:10X", left$([F:XBID]PAB3,ESP_-1))
        GT37_12=format$("K:25X", right$([F:XBID]PAB3,ESP_+1))
    Else
        GT37_11 = space$(10)
        GT37_12 = format$("K:25X",[F:XBID]PAB3)
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(28,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the bank ID for the payment $1$.
Endif

#Adresse du bénéficiaire
Read [F:XBPA]BPA0(3) = 1;[F:ZPYH]BPR;[F:XBID]BPAADD        # lecture de l'adresse du tier
If fstat = 0 Then
    GT37_13=format$("K:35X",[F:XBPA]BPADES)
    GT37_14=space$(35)
    GT37_15=format$("K:35X",[F:XBPA]BPAADDLIG(0))
    GT37_16=format$("K<:10X",[F:XBPA]POSCOD)
    GT37_17=format$("K:25X",[F:XBPA]CTY)
Else
    Call ECR_TRACE(func AFNC.MES2( mess(43,3648,1), [F:XBID]BPAADD, [F:ZPYH]BPR),1) From GESECRAN # Address $1$ for business partner $2$ not found!
Endif


#Communication. Actuellement on récupère les commentaires de la 1ère ligne de facture
GT37_18=space$(35)
GT37_19=space$(35)
GT37_20=space$(35)
GT37_21=space$(35)
Read [F:XPYD]PYD0=[F:ZPYH]NUM;1
If fstat = 0 Then
    If func SWILIB0.IS_SUPPLIER_INVOICE([F:XPYD]VCRTYP) and [F:XPYD]VCRNUM<>""
        Read [F:XPIH]PIH0 = [XPYD]VCRNUM         # lecture la facture PINVOICE
        If fstat = 0 Then
            GT37_18=format$("K:35X",[F:XPIH]DES(0))
            GT37_19=format$("K:35X",[F:XPIH]DES(1))
            GT37_20=format$("K:35X",[F:XPIH]DES(2))
        Else
            Call ECR_TRACE(func AFNC.MES1( mess(29,3648,1), [XPYD]VCRNUM), 1) From GESECRAN # Error reading the invoice $1$.
        Endif
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(30,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the payment details $1$.
Endif

Case [F:ZPYH]SWISUP3
    When 3 : GT37_22="OUR"     # Applicant
    When 2 : GT37_22="BEN"     # Beneficiary
    When 1 : GT37_22=space$(3) # Shared
    When Default : GT37_22=space$(3)
Endcase

If [F:ZPYH]SWISUP1=3
    GT37_23="U"    # Urgent
Else
    GT37_23="N"    # None
Endif

#Donneur d'ordre, on récupère les informations de l'adresse du site
GT37_24=space$(35)
GT37_25=space$(35)
GT37_26=space$(35)
GT37_27=space$(10)
GT37_28=space$(25)

Read [F:XFCY]FCY0 = [F:ZPYH]FCY                                   # recherche du site
If fstat = 0
    Read [F:XBPA]BPA0(3) = TYP;[F:ZPYH]FCY;[F:XFCY]BPAADD        # recherche de l'adresse du site
    If fstat = 0 Then
        GT37_24=format$("K:35X",[F:XBPA]BPADES)
        GT37_26=format$("K:35X",[F:XBPA]BPAADDLIG(0))
        GT37_27=format$("K<:10X",[F:XBPA]POSCOD)
        GT37_28=format$("K:25X",[F:XBPA]CTY)
    Else
        Call ECR_TRACE(func AFNC.MES1( mess(24,2260,1), [F:ZPYH]FCY), 1) From GESECRAN # Address for site $1$ not found!
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(49,2260,1), [F:ZPYH]FCY), 1) From GESECRAN # Site $1$ cannot be found
Endif
GT37_29=space$(14)

#Ecriture de l'enregistrement
Wrseq GT37_1, GT37_2, GT37_3, GT37_4, GT37_5, GT37_6, GT37_7, GT37_8, GT37_9, GT37_10, GT37_11, GT37_12, GT37_13, GT37_14, GT37_15,
&GT37_16, GT37_17, GT37_18, GT37_19, GT37_20, GT37_21, GT37_22, GT37_23, GT37_24, GT37_25,GT37_26, GT37_27, GT37_28, GT37_29, Using [FIC]
Return

#-----------------------------
# Enregistrements de type937
# Enregistrement fianal
#-----------------------------
$CREECR_GT97

For I=0 To 14
    If CUR(I)<>""
        GT97(I) = format$("K:3X",CUR(I))+format$("N0:6",NBCUR(I))+format$("N0:13",TOTCUR(I))
    Else
        GT97(I) = string$(22,"0")
    Endif
Next

#Ecriture de l'enregistrement
Wrseq GT97(0), GT97(1), GT97(2), GT97(3), GT97(4), GT97(5), GT97(6), GT97(7), GT97(8), GT97(9), GT97(10), GT97(11), GT97(12), GT97(13), GT97(14),
&space$(250), space$(70), Using [FIC]

Return

#----------------------------------------------------------------------------
# Recherche d'un nouveau numéro de compteur pour constituer le nom du fichier
#----------------------------------------------------------------------------

$CALCUL_COMPTEUR_
    Local Char    VALEUR(50)
    Local Integer STAT

    Call NUMERO("SWIEZ","",datesyst,"",VALEUR,STAT) From SUBANM
    If STAT <> 0
       Errbox(mess(270,133,1)) # "No sequence number code found"
       COMPTEUR_ = "poste"
    Else
       COMPTEUR_ = VALEUR
    Endif
Return

#-----------------------------------------------------------------------------
# Màj des totaux pour l'enregistrement total en différentes monnaies
#-----------------------------------------------------------------------------
$TOTAL_

Local Integer TEMP_
TEMP_=100
#1: Recherche si la monnaie existe déjà dans la tables CUR
For I=0 To 14
    If CUR(I)= [F:ZPYH]CUR
        TEMP_=I
        Break
    Endif
Next
#2: On test si on a trouvé la monnaie si oui on stocke le montant, si non on
#   insère la monnaie dans le tableau et le montant ensuite
If TEMP_<>100
    TOTCUR(TEMP_) += [F:ZPYH]AMTCUR*100
    NBCUR(TEMP_) += 1
Else
    For I=0 To 14
        If CUR(I)=""
            CUR(I)= [F:ZPYH]CUR
            TOTCUR(I) += [F:ZPYH]AMTCUR*100
            NBCUR(I) += 1
            TEMP_=I
            Break
        Endif
    Next
    If TEMP_=100
        Call ECR_TRACE(func AFNC.MES1( mess(42,3648,1), [F:ZPYH]CUR),1) From GESECRAN # Amount can't be saved in $1$. The number of currencies used is greater than 15.
    Endif
Endif
Return

#--------------------------------------------------------
# Mise à jour de la table des bordereaux de remise PAYFRM
#--------------------------------------------------------

$MAJ_PAYFRM2
    Trbegin [FRM]
    [FRM]TFBDAT = date$
    [FRM]TFBFIL = TFBFIL_
#    [XFRM]STA = 6                   : # mise à jour du flag permettant de savoir que le fichier DTA a été créé
    [FRM]STA = max(6,[FRM]STA)     : # don't reduce STA if already greater than 6
    Rewrite [FRM]
    If fstat = 0
        Commit
    Else
        Rollback
    Endif
Return

#------------------------------------------------
# Mise à jour de la table des règlements PAYMENTH
#------------------------------------------------

$MAJ_PAYMENTH
     Filter [ZPYH] Where FRMNUM = [M:FRM0]FRMNUM
     For [ZPYH]
         Trbegin [ZPYH]
         [ZPYH]TFBDAT = date$
         [ZPYH]TFBFIL = TFBFIL_
         [ZPYH]STAFLG(5) = 2            : # mise à jour du flag permettant de savoir que le fichier OPAE a été créé
#         [ZPYH]STA = 6                  : # mise à jour prochaine opération : mise en banque
         [ZPYH]STA = max(6,[ZPYH]STA)   : # don't reduce STA if already greater than 6
         Rewrite [ZPYH]
         If fstat = 0
            Commit
         Else
            Rollback
         Endif
    Next
    Filter [ZPYH]
Return


######################################################################################################
#Programme de contrôle du compte bancaire
######################################################################################################
Subprog CONT_COMPT(ADH)
Variable Char ADH
Local Char SORT(30)
Local Char ENT(30)
If len(ADH)<5 or len(ADH)>11  #On test si la valeur est plus petite que 5 X ou plus grande que 11X
    mkstat=2 : GERR=1 : GMESSAGE = func AFNC.MES1( mess(37,3648,1), ADH) # The format of the ISR customer number $1$ is wrong.
Else
    If mid$(ADH,3,1)<>"-" or mid$(ADH,len(ADH)-1,1)<>"-"    #Sinon, on teste si les "-" sont mal placés
        If len (ADH)= 5 and instr(0,ADH,"-")=0  #Si oui, on test si le nombre de X = 5 et qu'il n'y a pas de "-" dans la chaîne
            ENT = left$(ADH,4)
            Call MODULOR(ENT,SORT) From SWILIB0
            If SORT <> right$(ADH,len(ADH))
                mkstat=2 : GERR=1 : GMESSAGE = func AFNC.MES1( mess(38,3648,1), ADH) # ISR customer number $1$ not valid. Check digit wrong!
            Else
                ADH = format$("K:5X",ADH)
            Endif
        Elsif len (ADH)= 9 and instr(0,ADH,"-")=0  #Si oui, on test si le nombre de X = 9 et qu'il n'y a pas de "-" dans la chaîne
            ENT = left$(ADH,8)
            Call MODULOR(ENT,SORT) From SWILIB0
            If SORT <> right$(ADH,len(ADH))
                mkstat=2 : GERR=1 : GMESSAGE = func AFNC.MES1( mess(38,3648,1), ADH) # ISR customer number $1$ not valid. Check digit wrong!
            Else
                ADH = format$("K:9X",ADH)
            Endif
        Else
            mkstat=2 : GERR=1 : GMESSAGE = func AFNC.MES1( mess(37,3648,1), ADH) # The format of the ISR customer number $1$ is wrong.
        Endif
    Else  #Sinon, on fait le test pour le format à 9#
        ENT = left$(ADH,2)+string$(6-(len(ADH)-5),"0")+mid$(ADH,4,len(ADH)-5)
        ADH=left$(ADH,2)+string$(6-(len(ADH)-5),"0")+mid$(ADH,4,len(ADH)-5)+right$(ADH,len(ADH))
        Call MODULOR(ENT,SORT) From SWILIB0
        If SORT <> right$(ADH,len(ADH))
            mkstat=2 : GERR=1 : GMESSAGE = func AFNC.MES1( mess(38,3648,1), ADH) # ISR customer number $1$ not valid. Check digit wrong!
        Endif
    Endif
Endif
End


# 2016-01-14 DNE INSERT BEGIN ########################################################################
######################################################################################################
# Check BVRNUM for correctness and format it according to "XX-XXXXXX-X" format.
######################################################################################################

Funprog CHECK_BVRNUM(ADH)
Variable Char ADH
    Local Char SORT(30)
    Local Char ENT(30)

    If len(ADH)<5 or len(ADH)>11  #On test si la valeur est plus petite que 5 X ou plus grande que 11X
        GMESSAGE = func AFNC.MES1( mess(37,3648,1), ADH) # The format of the ISR customer number $1$ is wrong.
        End 0 # Return error status
    Else
        If mid$(ADH,3,1)<>"-" or mid$(ADH,len(ADH)-1,1)<>"-"    #Sinon, on teste si les "-" sont mal placés
            If len (ADH)= 5 and instr(0,ADH,"-")=0  #Si oui, on test si le nombre de X = 5 et qu'il n'y a pas de "-" dans la chaîne
                ENT = left$(ADH,4)
                Call MODULOR( ENT, SORT ) From SWILIB0
                If SORT <> right$(ADH,len(ADH))
                    GMESSAGE = func AFNC.MES1( mess(38,3648,1), ADH) # ISR customer number $1$ not valid. Check digit wrong!
                    End 0 # Return error status
                Else
                    ADH = format$("K:5X",ADH)
                    GMESSAGE = func AFNC.MES1( mess(80,3648,1), ADH) # ISR customer number $1$ with 5 digits is not supported anymore.
                    End 0 # Return error status
                Endif
            Elsif len (ADH)= 9 and instr(0,ADH,"-")=0  #Si oui, on test si le nombre de X = 9 et qu'il n'y a pas de "-" dans la chaîne
                ENT = left$(ADH,8)
                Call MODULOR(ENT,SORT) From SWILIB0
                If SORT <> right$(ADH,len(ADH))
                    GMESSAGE = func AFNC.MES1( mess(38,3648,1), ADH) # ISR customer number $1$ not valid. Check digit wrong!
                    End 0 # Return error status
                Else
                    ADH = left$( ADH, 2 ) + "-" + mid$( ADH, 3, 6 ) +  "-" + right$( ADH, 9 )
                Endif
            Else
                GMESSAGE = func AFNC.MES1( mess(37,3648,1), ADH) # The format of the ISR customer number $1$ is wrong.
                End 0 # Return error status
            Endif
        Else  #Sinon, on fait le test pour le format à 9#
            ENT = left$(ADH,2)+string$(6-(len(ADH)-5),"0")+mid$(ADH,4,len(ADH)-5)
            Call MODULOR(ENT,SORT) From SWILIB0
            If SORT <> right$(ADH,len(ADH))
                GMESSAGE = func AFNC.MES1( mess(38,3648,1), ADH) # ISR customer number $1$ not valid. Check digit wrong!
                End 0 # Return error status
            Endif
            ADH = left$( ENT, 2 ) + "-" + mid$( ENT, 3, 6 ) +  "-" + SORT
        Endif
    Endif
End 1 # Return success status


Subprog C_BVRNUM(VALEUR)
Variable Char VALEUR()

    If ( VALEUR <> "" ) and ( not func CHECK_BVRNUM( VALEUR ) )
        mkstat=2
        GERR=1
    Endif
End


Subprog UPDATE_BVRNUM
    If !clalev([F:BAN]) : Local File BANK [BAN] : Endif
    If !clalev([F:BID]) : Local File BID  [BID] : Endif

    Local Char STRTMP(255)

    # Open X3 log file.
    If !GSERVEUR : Call OUVRE_TRACE( "UPDATE_BVRNUM" ) From LECFIC : Endif

    # Open transaction
    Trbegin [F:BAN], [F:BID]

    Call ECR_TRACE( "==== Update of table BANK ====", 0 ) From GESECRAN
    Filter [F:BAN] Where BVRNUM <> ""
    For [F:BAN]BAN0
         STRTMP = [F:BAN]BVRNUM
         If not func SWIBVRLIB3.CHECK_BVRNUM( [F:BAN]BVRNUM )
              Call ECR_TRACE( GMESSAGE - "Check BAN = '" + [F:BAN]BAN + "'." , 2 ) From GESECRAN
         Elsif STRTMP <> [F:BAN]BVRNUM
              Call ECR_TRACE( "Updating" - STRTMP - "with" - [F:BAN]BVRNUM, 0 ) From GESECRAN
              Rewrite [F:BAN]
         Endif
    Next
    Filter [F:BAN]

    Call ECR_TRACE( "==== Update of table BID ====", 0 ) From GESECRAN
    Filter [F:BID] Where BVRNUM <> ""
    For [F:BID]BID0
         STRTMP = [F:BID]BVRNUM
         If not func SWIBVRLIB3.CHECK_BVRNUM( [F:BID]BVRNUM )
              Call ECR_TRACE( GMESSAGE - "Check BPANUM = '" + [F:BID]BPANUM + "'." , 2 ) From GESECRAN
         Elsif STRTMP <> [F:BID]BVRNUM
              Call ECR_TRACE( "Updating" - STRTMP - "with" - [F:BID]BVRNUM, 0 ) From GESECRAN
              Rewrite [F:BID]
         Endif
    Next
    Filter [F:BID]

    # Commit transaction
    Commit

    # Close X3 log/trace file and show it on screen.
    If !GSERVEUR
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE From LECFIC
    Endif
End
# 2016-01-14 DNE INSERT END ##########################################################################


######################################################################################################
# Recherche du clearing bancaire
######################################################################################################
$RECHCB
   #Lecture du RIB pour retrouver le numéro de compte jaune
   Read [F:XBID]BID0=1;[F:ZPYH]BPR;[ZPYH]BID
   If fstat=0
       GT22_6=left$([F:XBID]BVRNUM,2)+mid$([F:XBID]BVRNUM,4,6)+right$([F:XBID]BVRNUM,len([F:XBID]BVRNUM))
       #Compte du bénéficaire final
       NUMCLEAR = func SWILIB0.STRIP_ZEROS(left$([F:XBID]BIDNUM,5)) # delete leading zeros from clearing number
       If (NUMCLEAR="199" or NUMCLEAR="9000")
           GT22_8=space$(35)
       Else
           If [F:XBID]IBAN <> ""                                  # if IBAN prefix specified -> create IBAN
              GT22_8=format$("K:35X",[XBID]IBAN + [XBID]BIDNUM)
           Else                                                   # if IBAN prefix not specified -> use account
              GT22_8=format$("K:35X",func SWILIB0.STRIP_ZEROS(right$([F:XBID]BIDNUM,6)))
           Endif
       Endif
   Else
       Call ECR_TRACE(func AFNC.MES1( mess(28,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the bank ID for the payment $1$.
   Endif
   GT22_7=space$(6)
Return

