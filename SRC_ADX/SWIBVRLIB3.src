#-----------------------------------------------------------------------------------------------------

#-----------------------------------------------------------------------------------------------------
# $OUVRE: Ouverture des fichiers nécessaires aux traitements
#-----------------------------------------------------------------------------------------------------
$OUVRE_
    If !clalev([F:XBID]) : Local File BID [XBID]      : Endif
    If !clalev([F:ZPYH]) : Local File PAYMENTH [ZPYH] : Endif
    If !clalev([F:XPYD]) : Local File PAYMENTD [XPYD] : Endif
    If !clalev([F:XBAN]) : Local File BANK[XBAN]      : Endif
    If !clalev([F:XFCY]) : Local File FACILITY[XFCY]  : Endif
    If !clalev([F:XPIH]) : Local File PINVOICE[XPIH]  : Endif
    If !clalev([F:XBPR]) : Local File BPARTNER[XBPR]  : Endif
    If !clalev([F:XBPA]) : Local File BPADDRESS[XBPA] : Endif
    If !clalev([F:XTAM]) : Local File TABPAM[XTAM]   : Endif
    If !clalev([F:SWIEZ]): Local File SWIEZAG[SWIEZ]   : Endif
    If !clalev([F:TPY])  : Local File TABPAYTYP [TPY]  : Endif

    If TFBFIL_ = ""
        #On emploie un fichier temporaire
        TFBFIL2TMP_= GUSER
    Else
        TFBFIL2TMP_ = left$(TFBFIL_, 10)
        REGENERATION=2
    Endif

    Local Char XFILEXT(30)
    XFILEXT = [M:FRM0]BAN
    Read [XBAN]BAN0 = [M:FRM0]BAN
    If !fstat and [F:XBAN]FILEXT <> ""
        XFILEXT = [F:XBAN]FILEXT
    Endif

    FICHIERTMP = filpath("BQE",TFBFIL2TMP_, XFILEXT)
    adxifs = ''
    adxium=50
    Openo FICHIERTMP,0 Using [FIC]
    Call OUVRE_TRACE(mess(29,160,1)) From LECFIC
Return
#-----------------------------------------------------------------------------------------------------

#-----------------------------------------------------------------------------------------------------
# $FERME: Fermeture des fichiers utilisés
#-----------------------------------------------------------------------------------------------------
$FERME_
    If clalev([F:ZPYH])  : Close Local File [ZPYH]  : Endif
    If clalev([F:XTAM])  : Close Local File [XTAM]  : Endif
    If clalev([F:XBID])  : Close Local File [XBID]  : Endif
    If clalev([F:XPYD])  : Close Local File [XPYD]  : Endif
    If clalev([F:XBAN])  : Close Local File [XBAN]  : Endif
    If clalev([F:SWIEZ]) : Close Local File [SWIEZ] : Endif
    If clalev([F:XFCY])  : Close Local File [XFCY]  : Endif
    If clalev([F:XPIH])  : Close Local File [XPIH]  : Endif
    If clalev([F:XBPR])  : Close Local File [XBPR]  : Endif
    If clalev([F:XBPA])  : Close Local File [XBPA]  : Endif

    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Return
#-----------------------------------------------------------------------------------------------------


#-----------------------------
#Enregistrement partie commune
#-----------------------------
$TRF_GT00

#Initialisation des variables
COMPTEUR += 1

#Renseignement des zones
GT00_1="036"
GT00_2=mid$([M:FRM0]EXEDAT,3,2)+mid$([M:FRM0]EXEDAT,5,2)+mid$([M:FRM0]EXEDAT,7,2)
GT00_3="00000"
GT00_4="1"

#Test du fichier du compte bancaire et du compte bancaire des frais
If COMPTEBAN=""
    Read [F:XBAN]BAN0 = [M:FRM0]BAN                # recherche de la banque
    If fstat = 0 Then
    # SAM 116590 2016-05-17 Bader
        COMPTEBAN = format$("K:9X",right$([F:XBAN]BIDNUM,len([F:XBAN]BIDNUM)-9+1)) # take account from BIDNUM taking the last 9 digits
#        COMPTEBAN=[F:XBAN]BVRNUM
#        Call CONT_COMPT(COMPTEBAN)
#        If mkstat<>0
#            Call ECR_TRACE(func AFNC.MES1( mess(39,3648,1), [F:XBAN]BVRNUM),1) From GESECRAN # The structure of the ISR customer number $1$ doesn't belong to a post office account!
#        Endif
    # SAM 116590 2016-05-17 Bader END
    Else
        Call ECR_TRACE(func AFNC.MES1( mess(40,3648,1), [M:FRM0]BAN),1) From GESECRAN # Error reading the bank $1$.
    Endif
Endif

GT00_5=COMPTEBAN
GT00_6=COMPTEBANF
#Calcul du numéro d'ordre on emploie un compteur remis à 0 chaque jour. Max
If NOORDRE=0
    Read [F:SWIEZ]SWIEZ0=[M:FRM0]EXEDAT
    If fstat=0
        If [F:SWIEZ]SEQNUM+1<=99
            NOORDRE=[F:SWIEZ]SEQNUM+1
            [F:SWIEZ]SEQNUM= [F:SWIEZ]SEQNUM+1
            Rewrite [F:SWIEZ]
        Else
            Call ECR_TRACE(mess(41,3648,1),1) From GESECRAN
        Endif
    Else
        #Pas d'info trouver alors on part de 1
        fstat=0
        NOORDRE=1
        [F:SWIEZ]DAT=[M:FRM0]EXEDAT
        [F:SWIEZ]SEQNUM=1
        Write [F:SWIEZ]
    Endif
Endif

GT00_7=format$("N0:2",NOORDRE)
GT00_8="00"
GT00_9=format$("N0:6",COMPTEUR)
GT00_10="00"
GT00_11="0"
GT00_12="0000"
Return


#-----------------------------
#Enregistrement de tête GT 00
#-----------------------------
$ECR_GT00
Wrseq GT00_1, GT00_2, GT00_3, GT00_4, format$("K:9X",GT00_5), format$("K:9X", GT00_6), GT00_7, GT00_8, GT00_9, GT00_10, GT00_11, GT00_12,  Using [FIC]
Return

#-----------------------------
#Enregistrement de tête GT 00
#-----------------------------
$CREECR_GT00
Wrseq space$(250), space$(250), space$(150), Using [FIC]
Return

#-----------------------------
# Enregistrements de type 22
# Pmt cpte jaune en CH
#-----------------------------
$CREECR_GT22
Local Integer ESP_
GT22_1=format$("K:3X", [F:ZPYH]CUR)
GT22_2=format$("N0:13",100*[F:ZPYH]AMTCUR)
#Gestion du total
Gosub TOTAL_
GT22_3=space$(1)
GT22_4=format$("K:3X", [F:ZPYH]CUR)
GT22_5="CH"

#Modif Pour accepter les BVR Rouge
#Lecture de la facture pour voir si une ligne de codage est présente cas BVR rouge
Read [F:XPYD]PYD0 = [F:ZPYH]NUM;1                # lecture PAYMENTHD pour retrouver la facture rattachée
If fstat = 0 Then
    If func SWILIB0.IS_SUPPLIER_INVOICE([F:XPYD]VCRTYP) and [F:XPYD]VCRNUM<>""
        Read [F:XPIH]PIH0 = [XPYD]VCRNUM         # lecture la facture PINVOICE
        If fstat = 0 Then
            BVRREFLINE_ = [F:XPIH]BVRREFLINE              # recherche du champ BVRREFLINE
            CHAINE = BVRREFLINE_
            If CHAINE<>"" Then
                If mid$(CHAINE, 28, 2) = "+ " and right$(CHAINE,39)=">"       # recherche des bouts de chaînes
                    #Lecture du RIB pour retrouver le numéro de compte jaune
                    Read [F:XBID]BID0=1;[F:ZPYH]BPR;[ZPYH]BID
                    If fstat=0
                        GT22_6=left$([F:XBID]BVRNUM,2)+mid$([F:XBID]BVRNUM,4,6)+right$([F:XBID]BVRNUM,len([F:XBID]BVRNUM))
                    Else
                        Call ECR_TRACE(func AFNC.MES1( mess(28,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the bank ID for the payment $1$.
                    Endif
                    GT22_7=space$(6)
                    GT22_8=format$("K<:35X",left$(CHAINE, 27))
                Elsif len(CHAINE)=10 and right$(CHAINE, 10) = ">"
                    GT22_6 =format$("K<:9X",left$(CHAINE,9))
                    GT22_7=space$(6)
                    GT22_8=space$(35)
                Else  # message d'erreur si les bouts de chaînes ne correspondent pas
                    Call ECR_TRACE(func AFNC.MES1( mess(49,3648,1), [XPYD]VCRNUM), 1) From GESECRAN # The structure of the ISR reference line does not correspond to 27 +9> or 9> for invoice $1$.
                Endif
                Read [F:XBID]BID0 = 1;[F:ZPYH]BPR;[ZPYH]BID
                If fstat <> 0
                    Call ECR_TRACE(func AFNC.MES1( mess(28,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the bank ID for the payment $1$.
                Endif
            Else  #La chaîne est vide, on lit le BID pour retrouver le numéro de clearing
               Gosub RECHCB
            Endif
        Else
            Call ECR_TRACE(func AFNC.MES1( mess(29,3648,1), [XPYD]VCRNUM), 1) From GESECRAN # Error reading the invoice $1$.
        Endif
    Else            #Pas de facture correspondant on lit donc le RIB
        #---- On est dans le cas d'un accompte, d'une note de frais, etc... ----#
        Gosub RECHCB
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(30,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the payment details $1$.
Endif

#Destinataire et destinataire finaux, pour cela il faut lire le BID de toute façon
NUMCLEAR = func SWILIB0.STRIP_ZEROS(left$([F:XBID]BIDNUM,5)) # delete leading zeros from clearing number
If (NUMCLEAR="199" or NUMCLEAR="9000")
    Read [F:XBPA]BPA0(3) = 1;[F:ZPYH]BPR;[F:XBID]BPAADD        # lecture de l'adresse du tiers
    If fstat = 0 Then
        GT22_9=format$("K:35X",[F:XBPA]BPADES)
        GT22_10=space$(35)
        GT22_11=format$("K:35X",[F:XBPA]BPAADDLIG(0))
        GT22_12=format$("K<:10X",[F:XBPA]POSCOD)
        GT22_13=format$("K:25X",[F:XBPA]CTY)
        GT22_14=space$(35)
        GT22_15=space$(35)
        GT22_16=space$(35)
        GT22_17=space$(10)
        GT22_18=space$(25)
    Else
        Call ECR_TRACE(func AFNC.MES2( mess(43,3648,1), [F:XBID]BPAADD, [F:ZPYH]BPR),1) From GESECRAN # Address $1$ for business partner $2$ not found!
    Endif
Else
    GT22_9=format$("K:35X",[F:XBID]PAB1)
    GT22_10=space$(35)
    GT22_11=format$("K:35X",[F:XBID]PAB2)
    ESP_=instr(1,[F:XBID]PAB3," ")
    If ESP_>=1
        GT22_12 = format$("K<:10X", left$([F:XBID]PAB3,ESP_-1))
        GT22_13 = format$("K:25X", right$([F:XBID]PAB3,ESP_+1))
    Else
        GT22_12 = space$(10)
        GT22_13 = format$("K:25X",[F:XBID]PAB3)
    Endif
    Read [F:XBPA]BPA0(3) = 1;[F:ZPYH]BPR;[F:XBID]BPAADD        # lecture de l'adresse du tier
    If fstat = 0 Then
        GT22_14=format$("K:35X",[F:XBPA]BPADES)
        GT22_15=space$(35)
        GT22_16=format$("K:35X",[F:XBPA]BPAADDLIG(0))
        GT22_17=format$("K<:10X",[F:XBPA]POSCOD)
        GT22_18=format$("K:25X",[F:XBPA]CTY)
    Else
        Call ECR_TRACE(func AFNC.MES2( mess(43,3648,1), [F:XBID]BPAADD, [F:ZPYH]BPR),1) From GESECRAN # Address $1$ for business partner $2$ not found!
    Endif
Endif

#Communication. Actuellement on récupère les commentaires de la 1ère ligne de facture
GT22_19=space$(35)
GT22_20=space$(35)
GT22_21=space$(35)
GT22_22=space$(35)
Read [F:XPYD]PYD0=[F:ZPYH]NUM;1
If fstat = 0 Then
    If func SWILIB0.IS_SUPPLIER_INVOICE([F:XPYD]VCRTYP) and [F:XPYD]VCRNUM<>""
        Read [F:XPIH]PIH0 = [XPYD]VCRNUM         # lecture la facture PINVOICE
        If fstat = 0 Then
            GT22_19=format$("K:35X",[F:XPIH]DES(0))
            GT22_20=format$("K:35X",[F:XPIH]DES(1))
            GT22_21=format$("K:35X",[F:XPIH]DES(2))
        Else
            Call ECR_TRACE(func AFNC.MES1( mess(29,3648,1), [XPYD]VCRNUM), 1) From GESECRAN # Error reading the invoice $1$.
        Endif
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(30,3648,1), [ZPYH]NUM), 1) From GESECRAN # Error reading the payment details $1$.
Endif

GT22_23=space$(3)
GT22_24=space$(1)

#Donneur d'ordre, on récupère les informations de l'adresse du site
GT22_25=space$(35)
GT22_26=space$(35)
GT22_27=space$(35)
GT22_28=space$(10)
GT22_29=space$(25)

Read [F:XFCY]FCY0 = [F:ZPYH]FCY                                   # recherche du site
If fstat = 0
    Read [F:XBPA]BPA0(3) = TYP;[F:ZPYH]FCY;[F:XFCY]BPAADD        # recherche de l'adresse du site
    If fstat = 0 Then
        GT22_25=format$("K:35X",[F:XBPA]BPADES)
        GT22_27=format$("K:35X",[F:XBPA]BPAADDLIG(0))
        GT22_28=format$("K<:10X",[F:XBPA]POSCOD)
        GT22_29=format$("K:25X",[F:XBPA]CTY)
    Else
        Call ECR_TRACE(func AFNC.MES1( mess(24,2260,1), [F:ZPYH]FCY), 1) From GESECRAN # Address for site $1$ not found!
    Endif
Else
    Call ECR_TRACE(func AFNC.MES1( mess(49,2260,1), [F:ZPYH]FCY), 1) From GESECRAN # Site $1$ cannot be found
Endif
GT22_30=space$(14)

#Ecriture de l'enregistrement
Wrseq GT22_1, GT22_2, GT22_3, GT22_4, GT22_5, GT22_6, GT22_7, GT22_8, GT22_9, GT22_10, GT22_11, GT22_12, GT22_13, GT22_14, GT22_15,
&GT22_16, GT22_17, GT22_18, GT22_19, GT22_20, GT22_21, GT22_22, GT22_23, GT22_24, GT22_25,GT22_26, GT22_27, GT22_28, GT22_29, GT22_30, Using [FIC]
Return

#-----------------------------
# Enregistrements de type 24
# Pmt mandat postal en CH
#-----------------------------
$CREECR_GT24
Local Integer ESP_
#Test monnaie

GT24_1=format$("K:3X", [F:ZPYH]CUR)
Read [F:XBAN]BAN0=[M:FRM0]BAN
If fstat <> 0
   If [F:ZPYH]CUR <> "CHF" and [F:ZYPH]CUR <>[F:XBAN]CUR
      Call ECR_TRACE(func AFNC.MES2( mess(44,3648,1), [F:ZYPH]CUR, [F:ZYPH]NUM),1) From GESECRAN # The currency $1$ is not allowed for the payment $2$.
   Endif
Endif
GT24_2=format$("N0:13",100*[F:ZPYH]AMTCUR)

#Gestion du total
Gosub TOTAL_
