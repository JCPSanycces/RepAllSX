#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion du fichier AFCTPRF
Call OBJET("AF1",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "DEB_PICK"    : Gosub DEB_PICK
 When "FIN_PICK"    : Gosub FIN_PICK
 When "PICKE"       : Gosub PICKING
 When "DEPICK"      : Gosub DEPICK
 When "SETBOUT"     : Gosub SETBOUT
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "ABANDON"     : Gosub ABANDON
 When "APRES_MOD"   : Gosub APRES_MOD
 When "AFFMASK"     : Gosub AFFMASK
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SEL_TABLE"   : Gosub SEL_TABLE

 When "INIT"        : TRA = 1 : TMP = 1
 When "EXEC"        : Gosub INIT From SUBAFP1

 When "FIN_ACTION"  : Gosub FIN_ACTION
Endcase
Return

$OUVRE
Gosub OUVFIC From SUBAFP
Local Integer OKPICK
Local Char    PROFIL(10)
If TUNNEL & CLE1<>""
 PROFIL = CLE1
Endif
Return

$AFFMASK
If TUNNEL & CLE1<>""
 Gosub REMPLIT From GOBJSUB
Endif
Return

$SETBOUT
Call VIREBOUT(CHAINE,"CDAH") From GOBJET
If PROFIL<>""
 [M]PRFCOD = PROFIL
 Affzo PRFCOD
 Grizo PRFCOD
 Call VIREBOUT(CHAINE,"<>09") From GOBJET
Endif
Return

$FILGAUCHE
If ILIS=1
 FILGAUSUP += '[F:AFC]TYPTRAIT<>2 & [F:AFC]MENU<>""'
Endif
Return

$LIENS
Gosub SETNOK From GOBJSUB
Return

$DEB_PICK
OKPICK = 0
Return

$FIN_PICK
If OKPICK
 Affzo 5
Endif
Return

$PICKING
If ([M]FCYGRUCOD1=2 & [M]FCYGRU1="") or !CLECUR
 OK = 0
Elsif !find([F:AFC]CODINT,[M]FNC1(0..[M]NBLIG-1))
 If [M]NBLIG>=dim([M]FNC1)-1
  OK = 0
 Else
    # Issue X3-74666 - 2018-01-31 by CCC : Don't allow to create profile with higher rights than current profile
    # Check if the function is authorized for current profile. If not => don't allow to pick it
    If func SUBAFP.IS_FUNCTION_AVAILABLE_FOR_PROFILE(GPROFIL,[F:AFC]CODINT)<>[V]CST_AYES
        OK=0
    Endif
 Endif
Endif

If OK=1
  Read [AFC]CODINT =
  NOL = min(nolign,max(1,[M]NBLIG-1))-1
  [M]NBLIG += 1
  Insa NOL,1,[M]NBLIG [M]NBLIG
  nolign += 1
  [M]FNC1(NOL)    = [F:AFC]CODINT
  [M]MODULE1(NOL) = [F:AFC]MODULE
  [M]MENU1(NOL)   = [F:AFC]MENU
  [M]COMBI(NOL)   = num$([F:AFC]MODULE)+[F:AFC]MENU+[F:AFC]CODINT
  Call TEXTE([F:AFC]NOM,[M]LIBFNC1(NOL)) From OBJDIV
  OKPICK = 1
Endif
Return

$DEPICK
NOL = find([F:AFC]CODINT,[M]FNC1(0..[M]NBLIG-1))-1
If NOL>=0
 Dela NOL,1,[M]NBLIG [M]NBLIG
 [M]NBLIG -= 1
 OKPICK = 1
Else
 OK = 0
Endif
Return

$APRES_MODIF
Case OBJLIS(ILIS)
 When "AF1"
  Case zoncou
   When "NBLIG"
    Case status
     When 65 : # Suppression ligne
      Read [AFC]MODULE=[M]MODULE1(nolign-1);[M]MENU1(nolign-1);[M]FNC1(nolign-1)
      Gosub DEPICK From WGOAF1
     When 68 : # Couper ligne
      For I=nolign To nolign1
       Read [AFC]MODULE=[M]MODULE1(I-1);[M]MENU1(I-1);[M]FNC1(I-1)
       Gosub DEPICK From WGOAF1
      Next I
    Endcase
  Endcase
Endcase
Return

$ABANDON
Gosub RAZPICK
Return

$RAZPICK
For I=0 To [M]NBLIG-1
 Read [AFC]CODINT = [M]FNC1(I)
 Gosub DEPICK From GOBJSUB
Next I
Return

$APRES_MOD
Gosub RAZPICK
[M]NBLIG = 0
Gosub RELIT From GOBJSUB
Gosub SETNOK From GOBJSUB
Return

# Bug 10283 : Passage en modif lors d'un ajout de fonctions via le bouton "Module"
$FIN_ACTION
If OK=1 & REP="" & [M:AFP1]NBLIG>0 : # On passe en modif
  REP = "M" : GREP = "M"
Endif
Return

########################################
$SEL_TABLE
Case TABLE
 When "FCYGRU" : Gosub SEL_FCYGRU
Endcase
Return

$SEL_FCYGRU
If [M]FCYGRUCOD1 = 1
   OBJET = "CPY"
Else
   OBJET = "FCY"
Endif
Return

################################################################################
#######    ECRAN AFP1     ######################################################
################################################################################
Subprog C_PRFCOD(VALEUR)
Variable Char    VALEUR()
Call LECTURE("AFT",VALEUR,"") From CONTOBJ
If [F:AFT]ALLFCT = 2 : mkstat = 2 : Endif

End

########################################
Subprog IB_FCYGRU1
If [M]FCYGRUCOD1 = 1
    GBOUT2=mess(68,104,1)    # Regroupement
    GBIDC1 = "AGF"
Else
    GBOUT2=mess(7,47,1)       # Site
    GBIDC1 = "FCY"
Endif

End
########################################
Subprog C_FCYGRU1(VALEUR)
Variable Char    VALEUR()

If [M:AFP1]FCYGRUCOD1 <> 2
    If VALEUR <> "" :  Call CONTROLE("AGF","",VALEUR,"",mkstat) From CONTOBJ : Endif
Else
   Call CONTROLE("FCY","",VALEUR,"",mkstat) From CONTOBJ
Endif

End

########################################
Subprog AS_OPT1(VALEUR)
Variable Integer VALEUR
If [M:AFP1]ACS1 <> 2 : mkstat = 1 : Endif
End

########################################
Subprog AM_FCYGRUCOD1(VALEUR)
Variable Integer VALEUR
Raz [M:AFP1]FCYGRU1
End

