#81085
Subprog D_INI(VALEUR)
#MIPEA - 2016-07-04 - REQ 114309 US131 - START
Variable Integer    VALEUR()
#Variable Char    VALEUR()
#MIPEA - 2016-07-04 - REQ 114309 US131 - END
If [M]ALLRPT=2 : Diszo [M]RPT    : Else : Actzo [M]RPT    : Endif
If [M]BAT=2    : Actzo BATDAT, BATTIM : Else : Diszo BATDAT, BATTIM : Endif
End
######################################################################################

#81084
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
#MIPEA - 2016-09-29 - X3PEOP-777 - START
  GCURLEG=VALEUR
#MIPEA - 2016-09-29 - X3PEOP-777 - END
  Call PARAM(GCURLEG,"GRURPTBUL",[M:VEF]GRURPTBUL) From ADOVAL
End
#end 81084

