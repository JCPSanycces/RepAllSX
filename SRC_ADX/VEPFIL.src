#MIPEA - 2016-07-04 - REQ 114309 US131 - END


#81085
######################################################
$DEBUT
Affzo [VEF]
Setmok [VEF] With 0
Call AFF_MEMO From DIVPAYE
Return

#-------------------------------------------------------------------------------
$EXEC
Local Integer I, K
Local Date    PYRDAT
Local Char    FICHIER(255), TBPAR(20)(1..50), TBVAL(20)(1..50), RPTBUL([V]GLONARP)
If !clalev([F:VEP]) : Local File VALEMP [VEP] : Endif

Repeat
 If [M:VEF]ALLRPT=2
  Filter [ARX] Where TYPCOD=1 & INTCOD=[M:VEF]GRURPTBUL & EXTCOD>[L]RPTBUL
  Read [ARX]ARX0 First
  Filter [ARX]
  If fstat : Break : Else [L]RPTBUL=[F:ARX]EXTCOD : Endif
 Elsif [L]RPTBUL=""
  [L]RPTBUL=[M:VEF]RPT
 Else
  Break
 Endif

 For I=1 To [V]GNBSITE
  If ([M:VEF]ALLCPY=2 | [M:VEF]CPY=[V]GSOCSITE(I))
&  & ([M:VEF]ALLFCY=2 | [M:VEF]FCY=[V]GSITE(I))

      If [M:VEF]DATPAYSTR<>[0/0/0] : [L]PYRDAT=[M:VEF]DATPAYSTR-1 : Endif :#81085
   Repeat
    Filter [VEP] Where PYRDAT>[L]PYRDAT & PYRDAT<=[M:VEF]DATPAYEND
&                    & FCY=[V]GSITE(I) & RPTBUL=[L]RPTBUL & STA=3
&         Order By Key CLE=PYRDAT
    Read [VEP] First
    Filter [VEP]
    If fstat : Break : Endif

    [L]PYRDAT =[F:VEP]PYRDAT
    [L]FICHIER=[V]GSITE(I)+"_"+format$("D:YYYY[-]MM[-]DD",[L]PYRDAT)+"_"+[L]RPTBUL
    [L]FICHIER=[M:VEF]FDR+"\"+[L]FICHIER+".pdf"
    If [M:VEF]FIL2=2
     K=0
    Elsif [F:AIM]PRTSRV=""
     Call EXISTE("#@"+[L]FICHIER,K) From ORDSYS
    Elsif instr(1,[F:AIM]PRTSRV,adxmac(-1))=1
     Call EXISTE([L]FICHIER,K) From ORDSYS
    Else : # impossible de vérifier donc on force le réarchivage
     K=0
    Endif
    If !K

     Raz [L]TBVAL, [L]TBPAR
     K+=1 : [L]TBPAR(K)="cpy"         : [L]TBVAL(K)=[V]GSOCSITE(I)
     K+=1 : [L]TBPAR(K)="fcydeb"      : [L]TBVAL(K)=[V]GSITE(I)
     K+=1 : [L]TBPAR(K)="fcyfin"      : [L]TBVAL(K)=[V]GSITE(I)
     K+=1 : [L]TBPAR(K)="datdeb"      : [L]TBVAL(K)=num$([L]PYRDAT)
     K+=1 : [L]TBPAR(K)="datfin"      : [L]TBVAL(K)=num$([L]PYRDAT)
     K+=1 : [L]TBPAR(K)="tri"         : [L]TBVAL(K)=num$([M:VEF]SRT)
     K+=1 : [L]TBPAR(K)="flgprn"      : [L]TBVAL(K)="1"
     K+=1 : [L]TBPAR(K)="txt"         : [L]TBVAL(K)=mess(182,10703,1) : # Duplicata
     K+=1 : [L]TBPAR(K)="impsim"      : [L]TBVAL(K)=num$([M:VEF]SHOPYR)
     K+=1 : [L]TBPAR(K)="impsel"      : [L]TBVAL(K)="1"
     K+=1 : [L]TBPAR(K)="archivage"   : [L]TBVAL(K)="2"
#     K+=1 : [L]TBPAR(K)="_ExportFile" : [L]TBVAL(K)=[L]FICHIER
     If [M:VEF]BAT=2
      Call ETATDIFF( [L]RPTBUL    ,[M:VEF]PRT   ,[V]GLANGUE,0,"",[L]TBPAR,[L]TBVAL
&                  , [M:VEF]BATDAT,[M:VEF]BATTIM
&                  ) From AIMP3
     Else
      Call ETAT([L]RPTBUL,[M:VEF]PRT,[V]GLANGUE,0,"",[L]TBPAR,[L]TBVAL) From AIMP3
     Endif

    Endif
   Until 0
  Endif
 Next
Until 0
Return

################################################################################
#
# Etiquettes de l'écran VEPFIL
#
################################################################################

$INIRPT
Local Char GRURPTBUL([V]GLONARX)
If clalev([M:VEF])
 [L]GRURPTBUL=[M:VEF]GRURPTBUL
Else
 Call PARAM(GCURLEG,"GRURPTBUL",[L]GRURPTBUL) From ADOVAL
Endif
If [L]GRURPTBUL=""
 If !clalev([F:ADP]) : Local File ADOPAR [ADP] : Endif
 Read [ADP]ADP1="GRURPTBUL"
 [V]GMESSAGE=mess(171,133,1)-": GRURPTBUL ("+func AFNC.TEXTE([F:ADP]NAM)+")"
 #           Paramètre non renseigné
 mkstat     =2
 Return
Endif
If !clalev([F:ARP]) : Local File AREPORT  [ARP] : Endif
If !clalev([F:ARX]) : Local File AREPORTX [ARX] : Endif
If !clalev([F:ACC]) : Local File ACCES    [ACC] : Endif
Return

########################################
Subprog C_BAT(VALEUR)
Variable Integer VALEUR

If [L]VALEUR=2 : Actzo [VEF] BATDAT, BATTIM
Else             Effzo [VEF] BATDAT, BATTIM : Diszo [VEF] BATDAT, BATTIM
Endif

End

########################################
Subprog AS_BATDAT(VALEUR)
Variable Date    VALEUR

If [M:VEF]BAT<2 : mkstat=1 : Elsif [L]VALEUR=[0/0/0] : [L]VALEUR=datesyst : Endif

End

########################################
Subprog AS_BATTIM(VALEUR)
Variable Char    VALEUR()

If    [M:VEF]BAT<2 : mkstat=1
Elsif [L]VALEUR="" : [L]VALEUR=left$(ctrans(time$,":",""),4)
Endif

End

########################################
Subprog C_ALLRPT(VALEUR)
Variable Integer VALEUR

If [L]VALEUR=2 : Effzo [VEF] RPT : Diszo [VEF] RPT
Else             Actzo [VEF] RPT
Endif

End

########################################
Subprog AS_RPT(VALEUR)
Variable Char    VALEUR()

If    [M:VEF]ALLRPT=2 : mkstat   =1
Elsif [L]VALEUR=""    : [L]VALEUR=[V]GNOMRPTBUL
Endif

End

########################################
$CHX_RPT
Gosub INIRPT
If mkstat
 Call ERREUR([V]GMESSAGE) From GESECRAN
 Raz [L]SENS, [V]GMESSAGE, status
 Return
Endif
#81084
#MIPEA - 2016-07-04 - REQ 114309 US131 - START
Link [ARP] With [ARX]ARX0(1)~=[L]GRURPTBUL;1;RPTCOD;[V]GLANGUE
&             , [ATX]NUMERO  =[V]GLANGUE;RPTDES
&             , [ACC]CODACC  =[V]GUSER;ACS
&            As [LNK]
&         Where [ARX]LAN=[V]GLANGUE or [ARX]LAN=""
#Link [ARP] With [ARX]ARX0(1)~=[L]GRURPTBUL;1;RPTCOD
#&             , [ATX]NUMERO  =[V]GLANGUE;RPTDES
#&             , [ACC]CODACC  =[V]GUSER;ACS
#&            As [LNK]
#&         Where [ARX]LAN=[V]GLANGUE or [ARX]LAN=""
#MIPEA - 2016-07-04 - REQ 114309 US131 - END
#end 81084
Default File [LNK]
Return

########################################
Subprog C_RPT(VALEUR)
Variable Char    VALEUR()
Local Integer ISPAYSLIPRPT

Gosub INIRPT
If mkstat : End : Endif

#81084
#Look [ARX]ARX0=[L]GRURPTBUL;1;[L]VALEUR;[V]GLANGUE
#If fstat
# Look [ARX]ARX0=[L]GRURPTBUL;1;[L]VALEUR;""    :#All language
# If fstat
# [V]GMESSAGE=mess(179,10703,1) : # L'édition n'est pas un bulletin de paie
# mkstat     =2
# Endif
#Endif
Filter [ARX] Where [ARX]INTCOD=[L]GRURPTBUL & [ARX]TYPCOD=1 & [ARX]EXTCOD=[L]VALEUR & ([ARX]LAN=[V]GLANGUE or LAN="")
Look [ARX]ARX0 First
Filter [ARX]
If fstat
  #Is it a payslip report ?
  ISPAYSLIPRPT=0
  If !clalev([F:ADW]) : Local File ADOVAL [ADW] : Endif
  Filter [ARX] Where EXTCOD=[L]VALEUR
  Read [ARX]ARX0 First
  Filter [ARX]
  If !fstat
    Filter [ADW] Where PARAM="GRURPTBUL" & VALEUR=[F:ARX]INTCOD
    Look [ADW]ADW0 First
    Filter [ADW]
    If !fstat : ISPAYSLIPRPT=1 : Endif
  Endif
  #
  If ISPAYSLIPRPT
    [V]GMESSAGE= [L]VALEUR-":"-mess(14,10712,1)-"["+GCURLEG+"]" : # Fiche inexistante pour la législation courante
  Else
    [V]GMESSAGE= mess(179,10703,1) : # L'édition n'est pas un bulletin de paie
  Endif
  mkstat=2
Endif
If mkstat : End : Endif
#end 81084
End

########################################
Subprog AS_PRT(VALEUR)
Variable Char    VALEUR()

If [L]VALEUR>"" : End : Endif

If [M:VEF]BAT=2 : Filter [AIM] Where PRTSRV>"" : Endif
For [AIM] Where PRT=4 & PRTFMT=29
 If [L]VALEUR="" : [L]VALEUR=[F:AIM]COD : Else [L]VALEUR="" : Break : Endif
Next
Filter [AIM]

End

########################################
$SEL_PRT
[L]OBJET  ="AIM"
[L]CRITERE="PRT=4 & PRTFMT=29"-string$([M:VEF]BAT=2 | [V]GBROWS,"& PRTSRV>''")
#[L]CRITERE="PRT=4 & PRTFMT=29"+string$([M:VEF]BAT=2," & PRTSRV>''") : # 41909
Filter [AIM] Where evalue([L]CRITERE)
If !rowcount([AIM]) : [L]CRITERE="" : Endif
Filter [AIM]
Return

########################################
Subprog C_PRT(VALEUR)
Variable Char    VALEUR()

Call LECTURE("AIM",[L]VALEUR,"") From CONTOBJ
If [F:AIM]PRT<>4 | [F:AIM]PRTFMT<>29
 [V]GMESSAGE=mess(180,10703,1)
 #           La sortie de l'imprimante n'est pas sous forme de fichier PDF
 mkstat     =2
Elsif ([M:VEF]BAT=2 | [V]GBROWS) & [F:AIM]PRTSRV=""
#Elsif [M:VEF]BAT=2 & [F:AIM]PRTSRV="" : # 41909
 [V]GMESSAGE=mess(90,150,1) : # Le serveur d'impression doit être renseigné
 mkstat     =2
Endif

End

########################################
Subprog IB_FDR

# 41909
If [F:AIM]PRTSRV="" | instr(1,[F:AIM]PRTSRV,adxmac(-1))<>1 : Raz [V]GBOUTS : Endif

End

########################################
Subprog C_FDR(VALEUR)
Variable Char    VALEUR()

Local Integer STAT

# 41909
If left$(VALEUR,2)="#@"
 [V]GMESSAGE="#@ :"-mess(127,100,1) : # Fonction impossible dans le contexte
 mkstat     =2
Elsif !instr(1,[L]VALEUR,"/") & !instr(1,[L]VALEUR,"\") & ([V]GBROWS | [M:VEF]BAT=2)
 [V]GMESSAGE=mess(160,100,1) : # Le chemin doit être indiqué en absolu
 mkstat     =2
Else
 If instr(1,[F:AIM]PRTSRV,adxmac(-1))=1
  Call EXISTE([L]VALEUR,[L]STAT) From ORDSYS
 Elsif [F:AIM]PRTSRV=""
  Call EXISTE("#@"+[L]VALEUR,[L]STAT) From ORDSYS
 Else
  [L]STAT=2 : # on peut pas vérifier l'existence du répertoire,
              # on fait confiance à l'utilisateur
 Endif
 Case [L]STAT
  When 2
  When 0       : mkstat=2 : [V]GMESSAGE=mess(9,141,1)     : # Répertoire inexistant
  When Default : mkstat=2 : [V]GMESSAGE=mess(181,10703,1) : # Répertoire incorrect
 Endcase
Endif
# fin 41909

End

################################################################################
#
# Appelé par TRT/ADOVAL (Valeurs paramètres)
#
################################################################################

Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM, VALEUR
Variable Integer OK
Case [L]PARAM
When "GRURPTBUL"
 If !clalev([F:ARX]) : Local File AREPORTX [ARX] : Endif
 Look [ARX]ARX0(1)=[L]VALEUR
 If fstat
  Call ERREUR(mess(178,10703,1)) From GESECRAN : # Code impression inexistant
  [L]OK=0
 Else
  [L]OK=1
 Endif
#81084
When "NOMRPTBUL"
  Call C_RPT(VALEUR)
  If mkstat
    [L]OK=0
  Else
    [L]OK=1
  Endif
#end 81084
Endcase

End
