#<AdxTL>@(#)11.0.0.0 $Revision$
##############################################################################
# FUNHDKTRS : Contient                                          CRM 28/10/03 #
#     - Le S/P de validation des transactions de saisie                      #
#     - Le traitement permettant de lancer manuellemnt le S/P de validation  #
#                            x = 1 pour parc client                          #
#                            x = 2 pour demandes                             #
#                            x = 3 pour interventions                        #
#                            x = 4 Plan de travail                           # FGR 06/11/2008 : Le 4-Plan de travail n'existe plus
#                            x = 5 Plan de support agenda                    #
#                         (menu local 3020)                                  #
##############################################################################
Local Integer OK
Local File    HDKTRS [HTR]
Local Mask    HDKTRS [DIA]

  Raz [M:DIA]
  Call DIALWIN(OK,mess(100, 196, 1), "IHDKTRS") From GESECRAN
  If OK = 2 Then
   Call OUVRE_TRACE(mess(100,196,1) - [M]LIB - [M]HTRNUM) From LECFIC
   Call VAL_HDKTRS([M]HTRTYP,[M]HTRNUM,nomap)
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE From LECFIC   
  Endif
  Close Local File [HTR]
  Close Local Mask [DIA]
End

##############################################################################
#-------------------------------------------#
# Actions sur champ de l'écran HDKTRS [DIA] #
#-------------------------------------------#
Subprog AV_LIB(VALEUR)
Variable Char    VALEUR()

  If [M]HTRTYP > 0 and [M]HTRTYP <= len(mess(0,3020,1)) Then
    VALEUR = mess([M]HTRTYP,3020,1)
  Else 
    VALEUR = mess(19,197,1)
  Endif
End

##############################################################################
Subprog AV_HTRDES(VALEUR)
Variable Char    VALEUR()

  If [M]HTRNUM <> "" and [M]HTRTYP > 0 and [M]HTRTYP <= len(mess(0,3020,1)) Then
    Read [HTR]HTR0=[M]HTRTYP;[M]HTRNUM 
    If fstat <> 0 Then 
      Raz [F:HTR] 
    Endif
    VALEUR = [F:HTR]HTRDES
  Endif
End

##################################################################################
# Traitement appelé par SUBMAC, SUBSRE, SUBITN
##################################################################################
$GENDOS
#----- Variable locales -----#
Local Char    FENETRE(GLONFEN)(0..2)
Local Char    ECRAN  (GLONAMK)(0..10)
Local Integer I, TOK(1..10)
#-----
  If clalev([F:HTR])<=0 Local File =APPLI+".HDKTRS"    [HTR] : Endif
  If clalev([F:HTV])<=0 Local File =APPLI+".HDKTRSVAL" [HTV] : Endif
  Local File =APPLI+".AWINDOW"   [AWI] : # Déjà ouvert en local, le réouvrir !
  Local File =APPLI+".AWINPAR"   [AWP] : # Déjà ouvert en local, le réouvrit !
  Local File =APPLI+".AWINBRO"   [AWB] : # Déjà ouvert en local, le réouvrir !
  Local File =APPLI+".AWINBOUT"  [AWT] : # Déjà ouvert en local, le réouvrir !
  #  If clalev([F:AMK])<=0 Local File =APPLI+".AMSK"      [AMK] : Endif
  #  If clalev([F:AMZ])<=0 Local File =APPLI+".AMSKZON"   [AMZ] : Endif
  #  If clalev([F:AMA])<=0 Local File =APPLI+".AMSKACT"   [AMA] : Endif
  #  If clalev([F:AMP])<=0 Local File =APPLI+".AMSKPAR"   [AMP] : Endif
  #  If clalev([F:ATY])<=0 Local File =APPLI+".ATYPE"     [ATY] : Endif
  #  If clalev([F:ACT])<=0 Local File =APPLI+".ACTION"    [ACT] : Endif
  #  If clalev([F:ATR])<=0 Local File =APPLI+".ACTPAR"    [ATR] : Endif
  #  If clalev([F:AAR])<=0 Local File =APPLI+".ACTCODPAR" [AAR] : Endif
  #  If clalev([F:ATB])<=0 Local File =APPLI+".ATABLE"    [ATB] : Endif
  #  If clalev([F:ATZ])<=0 Local File =APPLI+".ATABZON"   [ATZ] : Endif
  Local File =APPLI+".AMSK"      [AMK]
  Local File =APPLI+".AMSKZON"   [AMZ]
  Local File =APPLI+".AMSKACT"   [AMA]
  Local File =APPLI+".AMSKPAR"   [AMP]
  Local File =APPLI+".ATYPE"     [ATY]
  Local File =APPLI+".ACTION"    [ACT]
  Local File =APPLI+".ACTPAR"    [ATR]
  Local File =APPLI+".ACTCODPAR" [AAR]
  Local File =APPLI+".ATABLE"    [ATB]
  Local File =APPLI+".ATABZON"   [ATZ]
  Local File =APPLI+".ACTIV"     [ACV] : # Déjà ouvert en local, le réouvrir !
  Local File =APPLI+".AOBJET"    [AOB] : # Déjà ouvert en local, le réouvrir !
  #  If clalev([F:ATX])<=0 Local File =APPLI+".ATEXTE"    [ATX] : Endif
  #  If clalev([F:ADV])<=0 Local File =APPLI+".ATABTAB"   [ADV] : Endif
  Local File =APPLI+".ATEXTE"    [ATX]
  Local File =APPLI+".ATABTAB"   [ADV]
  #-----
  Raz TOK
  If TYP = 0 Then
    For I = 1 To 10
      If I = 4 Then
        TOK(I) = 0 # FGR 06/11/2008 X3SUIVI50234 : Le 4-Plan de travail n'existe plus
      Else
        TOK(I) = 1
      Endif
    Next I
  Elsif dim(GVALTRANS) > 10 and GVALTRANS(11) = 2 Then
    If TYP = 4 Then
      TOK(TYP) = 0 # FGR 06/11/2008 X3SUIVI50234 : Le 4-Plan de travail n'existe plus
    Else
      TOK(TYP) = 1
    Endif
  Else
    Raz FENETRE, ECRAN
    Case TYP
      When 1 : #----- Parc
        FENETRE(0) = "OMAC"
        ECRAN(0) = "MAC1"
        ECRAN(1) = "MAC3"
        ECRAN(2) = "MAC2"
        ECRAN(3) = "MAC4"
      When 2 : #----- Demandes de service
        FENETRE(0) = "OSRE"
        ECRAN(0) = "SRE0"
        ECRAN(1) = "SRE1"
        ECRAN(2) = "SRE7"
        ECRAN(3) = "SRE2"
        ECRAN(4) = "SRE8"
        ECRAN(5) = "SRE9"
      When 3 : #----- Interventions
        FENETRE(0) = "OITN"
        ECRAN(0) = "ITN1"
        ECRAN(1) = "ITN3"
        ECRAN(2) = "ITN7"
        ECRAN(3) = "ITN8"
        ECRAN(4) = "ITN4"
      #When 4 : #----- Plan de travail # FGR 06/11/2008 X3SUIVI50234 : Le 4-Plan de travail n'existe plus
      #  FENETRE(0) = "OHDK"
      #  ECRAN(0) = "HDK1"
      #  ECRAN(1) = "HDK2"
      When 5 : #----- Plan de travail support agenda
        FENETRE(0) = "OHDA"
        ECRAN(0) = "HDKAGD0"
        ECRAN(1) = "HDKAGD1"
        ECRAN(2) = "HDKAGD2"
        ECRAN(3) = "HDKAGD3"
    Endcase
    Raz I
    While FENETRE(I) <> "" and I < 2
      Read [AWI]AWI0=FENETRE(I)
      If fstat Then
        Raz [F:AWI]
      Endif
      If [F:AWI]UPDFLG = 1 Then
        TOK(TYP) = 1
        Break
      Endif
      I += 1
    Wend
    If TOK(TYP) <> 1 Then
      Raz I
      While ECRAN(I) <> "" and I < 10
        Read [AMK]CODMSK=ECRAN(I)
        If fstat Then
          Raz [F:AMK]
        Endif
        If [F:AMK]UPDFLG = 1 Then
          TOK(TYP) = 1
          Break
        Endif
        I += 1
      Wend
    Endif
  Endif
  #----- Appels des validations de transaction -----#
  If sum(TOK(1..10)) > 2 Then
    Call VAL_HDKTRS(0,"",APPLI) From FUNHDKTRS
  Else
    If TOK(1) = 1 Then
      Call VAL_HDKTRS(1,"",APPLI) From FUNHDKTRS
    Endif
    If TOK(2) = 1 Then
      Call VAL_HDKTRS(2,"",APPLI) From FUNHDKTRS
    Endif
    If TOK(3) = 1 Then
      Call VAL_HDKTRS(3,"",APPLI) From FUNHDKTRS
    Endif
    # FGR 06/11/2008 X3SUIVI50234 : Le 4-Plan de travail n'existe plus
    #If TOK(4) = 1 Then
    #  Call VAL_HDKTRS(4,"",APPLI) From FUNHDKTRS
    #Endif
    If TOK(5) = 1 Then
      Call VAL_HDKTRS(5,"",APPLI) From FUNHDKTRS
    Endif
  Endif
Return

##################################################################################
# Traitement appelé par SUBMAC, SUBSRE, SUBITN
##################################################################################
$GENPATCH
  If clalev([F:HTR])<=0 Local File =APPLI+".HDKTRS"    [HTR] : Endif
  If clalev([F:HTV])<=0 Local File =APPLI+".HDKTRSVAL" [HTV] : Endif
  Local File =APPLI+".AWINDOW"   [AWI] : # Déjà ouvert en local, le réouvrir !
  Local File =APPLI+".AWINPAR"   [AWP] : # Déjà ouvert en local, le réouvrir !
  #  If clalev([F:AMK])<=0 Local File =APPLI+".AMSK"      [AMK] : Endif
  #  If clalev([F:AMZ])<=0 Local File =APPLI+".AMSKZON"   [AMZ] : Endif
  #  If clalev([F:AMA])<=0 Local File =APPLI+".AMSKACT"   [AMA] : Endif
  #  If clalev([F:AMP])<=0 Local File =APPLI+".AMSKPAR"   [AMP] : Endif
  #  If clalev([F:ATY])<=0 Local File =APPLI+".ATYPE"     [ATY] : Endif
  #  If clalev([F:ACT])<=0 Local File =APPLI+".ACTION"    [ACT] : Endif
  #  If clalev([F:ATR])<=0 Local File =APPLI+".ACTPAR"    [ATR] : Endif
  #  If clalev([F:AAR])<=0 Local File =APPLI+".ACTCODPAR" [AAR] : Endif
  #  If clalev([F:ATB])<=0 Local File =APPLI+".ATABLE"    [ATB] : Endif
  #  If clalev([F:ATZ])<=0 Local File =APPLI+".ATABZON"   [ATZ] : Endif
  Local File =APPLI+".AMSK"      [AMK]
  Local File =APPLI+".AMSKZON"   [AMZ]
  Local File =APPLI+".AMSKACT"   [AMA]
  Local File =APPLI+".AMSKPAR"   [AMP]
  Local File =APPLI+".ATYPE"     [ATY]
  Local File =APPLI+".ACTION"    [ACT]
  Local File =APPLI+".ACTPAR"    [ATR]
  Local File =APPLI+".ACTCODPAR" [AAR]
  Local File =APPLI+".ATABLE"    [ATB]
  Local File =APPLI+".ATABZON"   [ATZ]
  Local File =APPLI+".ACTIV"     [ACV] : # Déjà ouvert en local, le réouvrir !
  Local File =APPLI+".AOBJET"    [AOB] : # Déjà ouvert en local, le réouvrir !
  #  If clalev([F:ATX])<=0 Local File =APPLI+".ATEXTE"    [ATX] : Endif
  #  If clalev([F:ADV])<=0 Local File =APPLI+".ATABTAB"   [ADV] : Endif
  Local File =APPLI+".ATEXTE"    [ATX]
  Local File =APPLI+".ATABTAB"   [ADV]
  #
  Call VAL_HDKTRS(TYP,"",APPLI) From FUNHDKTRS
Return

#========================================================================================
# FGR 16/11/2009 : X3SUIVI57491 (début)
#----------------------------------------------------------------------------------------
$DYN_TRTHDKTRS
Local Char SZWIN(GLONFEN)
Local Char SZABRFIC(GLONABR)
Local Char SZONGLET(250)

  SZABRFIC = 'HTR'
  # 1
  SZWIN = 'OCMA'
  SZONGLET = '"[CMA0]","[CMA1]","[CMA2]","[CMA3]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ1, IREQ1) From FUNSALTRS
  # 2
  SZWIN = 'OCMS'
  SZONGLET = '"[CMS0]","[CMS1]","[CMS2]","[CMS3]","[CMS4]","[CMS5]","[CMS6]","[DST]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ2, IREQ2) From FUNSALTRS
  # 3
  SZWIN = 'OCMI'
  SZONGLET = '"[CMI0]","[CMI1]","[CMI2]","[CMI3]","[CMI4]","[CMI5]","[DST]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ3, IREQ3) From FUNSALTRS
  # 5
  SZWIN = 'OCMD'
  SZONGLET = '"[CMD0]","[CMD1]","[CMD2]","[CMD3]","[CMD4]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ5, IREQ5) From FUNSALTRS
Return

#----------------------------------------------------------------------------------------
$GEN_TRTPURTRS
Local Char SZADXIFS
Local Char SZADXIRS
Local Integer IVALIDOK
Local Integer IEXIST
Local Char SZPROGNAME(GLONADC)
Local Char SZFULLSRC(250)
Local Char SZFULLADX(250)
Local Integer NI
# 20 lignes
#  5 colonnes :
#               (0) = Complément "Close Local Mask" et "Default Mask"
#               (1) = Listes des autres Mask à ouvrir
#               (2) = Complément affectation classe [F] dans classe [M]
Local Char SZREQ1(250)(20,5)
Local Char SZREQ2(250)(20,5)
Local Char SZREQ3(250)(20,5)
Local Char SZREQ5(250)(20,5)
Local Integer IREQ1
Local Integer IREQ2
Local Integer IREQ3
Local Integer IREQ5
  #------------------------------------------
  Raz SZREQ1
  Raz SZREQ2
  Raz SZREQ3
  Raz SZREQ5
  IREQ1 = 0
  IREQ2 = 0
  IREQ3 = 0
  IREQ5 = 0
  #------------------------------------------
  Gosub DYN_TRTHDKTRS
  #------------------------------------------
  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  #------------------------------------------
  SZPROGNAME = "WHDK" + num$(adxpid)
  SZFULLSRC = filpath("TRT", SZPROGNAME, "src", APPLI)
  SZFULLADX = filpath("TRT", SZPROGNAME, "adx", APPLI)
  #------------------------------------------
  #Ouverture du traitement à générer
  Openo SZFULLSRC, 0 Using [TRS_]
  #------------------------------------------
  #Génération du traitement
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%"  Using [TRS_]
  Wrseq "#Traitement généré pour les transactions HDK en masse"  Using [TRS_]
  Wrseq "$TRANSAC_HDK"  Using [TRS_]
  Wrseq '  Local Integer W_O'  Using [TRS_]
  # FGR 21/10/2011 : X3SUIVI77325 (début)
  Wrseq '  If clalev([F:ADS1])=0  Local File ADOSSIER [ADS1] : Endif'  Using [TRS_]
  Wrseq '  Read [ADS1]DOSSIER=APPLI : If fstat Then Raz [F:ADS1] : Endif'  Using [TRS_]
  # FGR 21/10/2011 : X3SUIVI77325 (fin)
  Wrseq '  Trbegin [HTR], [HTV]'  Using [TRS_]
  Wrseq '  Delete [HTR] Where [F:HTR]HTRTYP = 4'  Using [TRS_]
  Wrseq '  Delete [HTV] Where [F:HTV]HTRTYP = 4'  Using [TRS_]
  Wrseq '  Commit'  Using [TRS_]
  Wrseq '  For [HTR] Where' - CRITERES  Using [TRS_]
  Wrseq '    If [F:HTR]HTRTYP <> WTYP Then'  Using [TRS_]
  Wrseq '      Case WTYP'  Using [TRS_]
  Wrseq '        When 1 : Close Local Mask [CMA0],[CMA1],[CMA2],[CMA3]' + SZREQ1(0,0)  Using [TRS_]
  Wrseq '        When 2 : Close Local Mask [CMS0],[CMS1],[CMS2],[CMS3],[CMS4],[CMS5],[CMS6],[DST]' + SZREQ2(0,0)  Using [TRS_]
  Wrseq '        When 3 : Close Local Mask [CMI0],[CMI1],[CMI2],[CMI3],[CMI4],[CMI5],[DST]' + SZREQ3(0,0)  Using [TRS_]
  Wrseq '        When 5 : Close Local Mask [CMD0],[CMD1],[CMD2],[CMD3],[CMD4]' + SZREQ5(0,0)  Using [TRS_]
  Wrseq '        When Default'  Using [TRS_]
  Wrseq '      Endcase'  Using [TRS_]
  Wrseq '      Case [F:HTR]HTRTYP'  Using [TRS_]
  Wrseq '        When 1'  Using [TRS_]
  # FGR 21/10/2011 : X3SUIVI77325 (début)
  Wrseq '          Call VALIDDIRECT ("CMA0", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CMA1", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CMA2", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CMA3", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  # FGR 21/10/2011 : X3SUIVI77325 (fin)
  Wrseq '          Local Mask =APPLI+".CMA0" [CMA0],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CMA1" [CMA1],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CMA2" [CMA2],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CMA3" [CMA3]'  Using [TRS_]
  For NI = 0 To IREQ1-1
    Wrseq '                ' + SZREQ1(NI,1)  Using [TRS_]
  Next NI
  Wrseq '        When 2'  Using [TRS_]
  # FGR 21/10/2011 : X3SUIVI77325 (début)
  Wrseq '          Call VALIDDIRECT ("CMS0", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CMS1", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CMS2", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CMS3", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CMS4", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CMS5", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CMS6", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("DIESCRTRS", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  # FGR 21/10/2011 : X3SUIVI77325 (fin)
  Wrseq '          Local Mask =APPLI+".CMS0" [CMS0],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CMS1" [CMS1],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CMS2" [CMS2],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CMS3" [CMS3],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CMS4" [CMS4],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CMS5" [CMS5],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CMS6" [CMS6],'  Using [TRS_]
  Wrseq '&                    =APPLI+".DIESCRTRS" [DST]'  Using [TRS_]
  For NI = 0 To IREQ2-1
    Wrseq '                ' + SZREQ2(NI,1)  Using [TRS_]
  Next NI
  Wrseq '        When 3'  Using [TRS_]
  # FGR 21/10/2011 : X3SUIVI77325 (début)
  Wrseq '          Call VALIDDIRECT ("CMI0", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CMI1", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CMI2", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CMI3", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CMI4", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CMI5", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("DIESCRTRS", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  # FGR 21/10/2011 : X3SUIVI77325 (fin)
  Wrseq '          Local Mask =APPLI+".CMI0" [CMI0],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CMI1" [CMI1],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CMI2" [CMI2],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CMI3" [CMI3],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CMI4" [CMI4],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CMI5" [CMI5],'  Using [TRS_]
  Wrseq '&                    =APPLI+".DIESCRTRS" [DST]'  Using [TRS_]
  For NI = 0 To IREQ3-1
    Wrseq '                ' + SZREQ3(NI,1)  Using [TRS_]
  Next NI
  Wrseq '        When 5'  Using [TRS_]
  # FGR 21/10/2011 : X3SUIVI77325 (début)
  Wrseq '          Call VALIDDIRECT ("CMD0", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CMD1", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CMD2", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CMD3", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CMD4", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  # FGR 21/10/2011 : X3SUIVI77325 (fin)
  Wrseq '          Local Mask =APPLI+".CMD0" [CMD0],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CMD1" [CMD1],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CMD2" [CMD2],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CMD3" [CMD3],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CMD4" [CMD4]'  Using [TRS_]
  For NI = 0 To IREQ5-1
    Wrseq '                ' + SZREQ5(NI,1)  Using [TRS_]
  Next NI
  Wrseq '        When Default'  Using [TRS_]
  Wrseq '      Endcase'  Using [TRS_]
  Wrseq '      WTYP = [F:HTR]HTRTYP'  Using [TRS_]
  Wrseq '    Endif'  Using [TRS_]
  Wrseq '    WDIE_DTRTYP = [F:HTR]HTRTYP'  Using [TRS_]
  Wrseq '    ACTION = "OUVRE"'  Using [TRS_]
  Wrseq '    Gosub TRT_DIETRS From SUBDST'  Using [TRS_]
  Wrseq '    Call DEBTRANS From GLOCK'  Using [TRS_]
  Wrseq '    Trbegin [HTR]'  Using [TRS_]
  Wrseq '    Case [F:HTR]HTRTYP'  Using [TRS_]
  Wrseq '      When 1'  Using [TRS_]
  Wrseq '        [M:CMA0] = [F:HTR]'  Using [TRS_]
  Wrseq '        [M:CMA1] = [F:HTR]'  Using [TRS_]
  Wrseq '        [M:CMA2] = [F:HTR]'  Using [TRS_]
  Wrseq '        [M:CMA3] = [F:HTR]'  Using [TRS_]
  Wrseq '             ' + SZREQ1(0,2)  Using [TRS_]
  Wrseq '        Gosub LOADDATA From SUBCMAB'  Using [TRS_]
  Wrseq '        Gosub TRT_ECRAN From SUBCMA'  Using [TRS_]
  Wrseq '      When 2'  Using [TRS_]
  Wrseq '        [M:CMS0] = [F:HTR]'  Using [TRS_]
  Wrseq '        [M:CMS1] = [F:HTR]'  Using [TRS_]
  Wrseq '        [M:CMS2] = [F:HTR]'  Using [TRS_]
  Wrseq '        [M:CMS3] = [F:HTR]'  Using [TRS_]
  Wrseq '        [M:CMS4] = [F:HTR]'  Using [TRS_]
  Wrseq '        [M:CMS5] = [F:HTR]'  Using [TRS_]
  Wrseq '        [M:CMS6] = [F:HTR]'  Using [TRS_]
  Wrseq '             ' + SZREQ2(0,2)  Using [TRS_]
  Wrseq '        Gosub LOADDATA From SUBCMSB'  Using [TRS_]
  Wrseq '        Gosub TRT_ECRAN From SUBCMS'  Using [TRS_]
  Wrseq '      When 3'  Using [TRS_]
  Wrseq '        [M:CMI0] = [F:HTR]'  Using [TRS_]
  Wrseq '        [M:CMI1] = [F:HTR]'  Using [TRS_]
  Wrseq '        [M:CMI2] = [F:HTR]'  Using [TRS_]
  Wrseq '        [M:CMI3] = [F:HTR]'  Using [TRS_]
  Wrseq '        [M:CMI4] = [F:HTR]'  Using [TRS_]
  Wrseq '        [M:CMI5] = [F:HTR]'  Using [TRS_]
  Wrseq '             ' + SZREQ3(0,2)  Using [TRS_]
  Wrseq '        Gosub LOADDATA From SUBCMIB'  Using [TRS_]
  Wrseq '        Gosub TRT_ECRAN From SUBCMI'  Using [TRS_]
  Wrseq '      When 5'  Using [TRS_]
  Wrseq '        [M:CMD0] = [F:HTR]'  Using [TRS_]
  Wrseq '        [M:CMD1] = [F:HTR]'  Using [TRS_]
  Wrseq '        [M:CMD2] = [F:HTR]'  Using [TRS_]
  Wrseq '        [M:CMD3] = [F:HTR]'  Using [TRS_]
  Wrseq '        [M:CMD4] = [F:HTR]'  Using [TRS_]
  Wrseq '             ' + SZREQ5(0,2)  Using [TRS_]
  Wrseq '        Gosub LOADDATA From SUBCMDB'  Using [TRS_]
  Wrseq '        Gosub TRT_ECRAN From SUBCMD'  Using [TRS_]
  Wrseq '      When Default'  Using [TRS_]
  Wrseq '    Endcase'  Using [TRS_]
  Wrseq '    If GOK < 1 Then'  Using [TRS_]
  Wrseq '      Call ECR_TRACE(mess(21,123,1) - mess([F:HTR]HTRTYP,3020,1) - [F:HTR]HTRNUM,1) From GESECRAN'  Using [TRS_]
  Wrseq '      Rollback'  Using [TRS_]
  Wrseq '    Else'  Using [TRS_]
  Wrseq '      Call ECR_TRACE(mess(14,123,1) - mess([F:HTR]HTRTYP,3020,1) - [F:HTR]HTRNUM,0) From GESECRAN'  Using [TRS_]
  Wrseq '      Commit'  Using [TRS_]
  Wrseq '    Endif'  Using [TRS_]
  Wrseq '  Next'  Using [TRS_]
  Wrseq 'Return'  Using [TRS_]
  Wrseq ''  Using [TRS_]
  Openo Using [TRS_]
  #------------------------------------------
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
  #------------------------------------------
  IVALIDOK = 1
  Call VALID("TRT", SZPROGNAME, APPLI, IVALIDOK) From VALMSKSUB
  If !IVALIDOK Then
    #Erreur lors de la génération : on appelle l'ancien pour que ça fonctionne au moins en standard
    # Je ne l'efface pas. Ca permettrait de trouver ce qui ne va pas
    #IEXIST = 1
    #Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
    Call OLD_VAL_HDKTRS(TYP,NUM,APPLI)
    Return
  Endif
  #------------------------------------------
  Gosub TRANSAC_HDK From =APPLI + "." + SZPROGNAME
  #------------------------------------------
  # A mettre dans l'appelant
  IEXIST = 1
  Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
  IEXIST = 1
  Call EFFACE(SZFULLADX, IEXIST) From ORDSYS
Return
# FGR 16/11/2009 : X3SUIVI57491 (fin)
#========================================================================================

##############################################################################
# VAL_HDKTRS : S/P Validation en masse des transactions de saisie CRM        #
# -------------------------------------------------------------------------- #
# Subprog VAL_HDKTRS (TYP,NUM,APPLI)                                         #
#    TYP  : Type des transactions à valider (1n)                             #
#           0 = Toutes                                                       #
#           1 = Parc                                                         #
#           2 = Demandes de service                                          #
#           3 = Intervention                                                 #
#    NUM  : Code de la transaction à valider (3c)                            #
#           "" = Toutes                                                      #
#    APPLI: Nom de l'application à mettre à jour                             #
# -------------------------------------------------------------------------- #
# Table à partir de laquelle la validation est effectuée :                   #
#          [F:HTR]HDKTRS   Table des transactions                            #
# Le fichier trace doit être ouvert avant l'appel du sous-programme          #
##############################################################################
Subprog VAL_HDKTRS(TYP, NUM, APPLI)
Value  Integer  TYP
Value  Char     NUM
Value  Char     APPLI

Local  Integer  WTYP, OK
Local  Char     ACTION(20), CRITERES(50)
Local Char W_DIE_ABRFIC(3)

  WDIE_ABRFIC = "CRM"
  ACTION = "MASSE"
  Case TYP
    When 0       : CRITERES = "HTRTYP<>4"        # FGR 06/11/2008 X3SUIVI50234 : Le 4-Plan de travail n'existe plus
    When 1       : CRITERES = "HTRTYP=1"
    When 2       : CRITERES = "HTRTYP=2"
    When 3       : CRITERES = "HTRTYP=3"
    When 4       : CRITERES = "HTRTYP=4 and 0=1" # FGR 06/11/2008 X3SUIVI50234 : Le 4-Plan de travail n'existe plus
    When 5       : CRITERES = "HTRTYP=5"
    When Default : CRITERES = ""
  Endcase
  If NUM <> "" and CRITERES <> "" Then
    CRITERES += " and HTRNUM=NUM"
  Endif
  If clalev([F:HTR])<=0 Local File =APPLI+".HDKTRS"  [HTR] : Endif
  If clalev([F:HTV])<=0 Local File =APPLI+".HDKTRSVAL" [HTV] : Endif

  Gosub GEN_TRTPURTRS
End

#====================================
Subprog OLD_VAL_HDKTRS(TYP, NUM, APPLI)
Value  Integer  TYP
Value  Char     NUM
Value  Char     APPLI

Local  Integer  WTYP, OK
Local  Char     ACTION(20), CRITERES(50)
Local Char W_DIE_ABRFIC(3)
Local Integer W_O                                # FGR 21/10/2011 : X3SUIVI77325

  WDIE_ABRFIC = "CRM"
  ACTION = "MASSE"
  Case TYP
    When 0       : CRITERES = "HTRTYP<>4"        # FGR 06/11/2008 X3SUIVI50234 : Le 4-Plan de travail n'existe plus
    When 1       : CRITERES = "HTRTYP=1"
    When 2       : CRITERES = "HTRTYP=2"
    When 3       : CRITERES = "HTRTYP=3"
    When 4       : CRITERES = "HTRTYP=4 and 0=1" # FGR 06/11/2008 X3SUIVI50234 : Le 4-Plan de travail n'existe plus
    When 5       : CRITERES = "HTRTYP=5"
    When Default : CRITERES = ""
  Endcase
  If NUM <> "" and CRITERES <> "" Then
    CRITERES += " and HTRNUM=NUM"
  Endif
  If clalev([F:HTR])<=0 Local File =APPLI+".HDKTRS"  [HTR] : Endif
  If clalev([F:HTV])<=0 Local File =APPLI+".HDKTRSVAL" [HTV] : Endif
  # FGR 21/10/2011 : X3SUIVI77325 (début)
  If clalev([F:ADS1])=0  Local File ADOSSIER [ADS1] : Endif
  Read [ADS1]DOSSIER=APPLI : If fstat Then Raz [F:ADS1] : Endif
  # FGR 21/10/2011 : X3SUIVI77325 (fin)
  #
  # FGR 06/11/2008 X3SUIVI50234 : Le 4-Plan de travail n'existe plus
  Trbegin [HTR], [HTV]
  Delete [HTR] Where [F:HTR]HTRTYP = 4
  Delete [HTV] Where [F:HTV]HTRTYP = 4
  Commit
  #
  For [HTR] Where evalue(CRITERES)
    If [F:HTR]HTRTYP <> WTYP Then
      Case WTYP
        When 1 : Close Local Mask [CMA0], [CMA1], [CMA2], [CMA3]
        When 2 : Close Local Mask [CMS0], [CMS1], [CMS2], [CMS3], [CMS4], [CMS5], [CMS6],[DST]
        When 3 : Close Local Mask [CMI0], [CMI1], [CMI2], [CMI3], [CMI4], [CMI5],[DST]
        #When 4 : Close Local Mask [CMH0], [CMH1], [CMH2]               # FGR 06/11/2008 X3SUIVI50234 : Le 4-Plan de travail n'existe plus
        When 5 : Close Local Mask [CMD0], [CMD1], [CMD2],[CMD3],[CMD4]
        When Default
      Endcase
      #
      Case [F:HTR]HTRTYP
        When 1 
          # FGR 21/10/2011 : X3SUIVI77325 (début)
          Call VALIDDIRECT ("CMA0", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CMA1", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CMA2", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CMA3", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          # FGR 21/10/2011 : X3SUIVI77325 (fin)
          Local Mask =APPLI+".CMA0" [CMA0],
&                    =APPLI+".CMA1" [CMA1],
&                    =APPLI+".CMA2" [CMA2],
&                    =APPLI+".CMA3" [CMA3]
        When 2 
          # FGR 21/10/2011 : X3SUIVI77325 (début)
          Call VALIDDIRECT ("CMS0", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CMS1", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CMS2", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CMS3", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CMS4", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CMS5", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CMS6", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("DIESCRTRS", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          # FGR 21/10/2011 : X3SUIVI77325 (fin)
          Local Mask =APPLI+".CMS0" [CMS0],
&                    =APPLI+".CMS1" [CMS1],
&                    =APPLI+".CMS2" [CMS2],
&                    =APPLI+".CMS3" [CMS3],
&                    =APPLI+".CMS4" [CMS4],
&                    =APPLI+".CMS5" [CMS5],
&                    =APPLI+".CMS6" [CMS6],
&                    =APPLI+".DIESCRTRS" [DST]
        When 3 
          # FGR 21/10/2011 : X3SUIVI77325 (début)
          Call VALIDDIRECT ("CMI0", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CMI1", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CMI2", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CMI3", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CMI4", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CMI5", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("DIESCRTRS", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          # FGR 21/10/2011 : X3SUIVI77325 (fin)
          Local Mask =APPLI+".CMI0" [CMI0],
&                    =APPLI+".CMI1" [CMI1],
&                    =APPLI+".CMI2" [CMI2],
&                    =APPLI+".CMI3" [CMI3],
&                    =APPLI+".CMI4" [CMI4],
&                    =APPLI+".CMI5" [CMI5],
&                    =APPLI+".DIESCRTRS" [DST]
#        When 4 
#          Local Mask =APPLI+".CMH0" [CMH0], # FGR 06/11/2008 X3SUIVI50234 : Le 4-Plan de travail n'existe plus
#&                    =APPLI+".CMH1" [CMH1],
#&                    =APPLI+".CMH2" [CMH2]
        When 5 
          # FGR 21/10/2011 : X3SUIVI77325 (début)
          Call VALIDDIRECT ("CMD0", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CMD1", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CMD2", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CMD3", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CMD4", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          # FGR 21/10/2011 : X3SUIVI77325 (fin)
          Local Mask =APPLI+".CMD0" [CMD0],
&                    =APPLI+".CMD1" [CMD1],
&                    =APPLI+".CMD2" [CMD2],
&                    =APPLI+".CMD3" [CMD3],
&                    =APPLI+".CMD4" [CMD4]
        When Default
      Endcase
      WTYP = [F:HTR]HTRTYP
    Endif
    WDIE_DTRTYP = [F:HTR]HTRTYP
    ACTION = "OUVRE"
    Gosub TRT_DIETRS From SUBDST
    Call DEBTRANS From GLOCK
    Trbegin [HTR]
    Case [F:HTR]HTRTYP
      When 1 
        [M:CMA0] = [F:HTR]
        [M:CMA1] = [F:HTR]
        [M:CMA2] = [F:HTR]
        [M:CMA3] = [F:HTR]
        Gosub LOADDATA From SUBCMAB
        Gosub TRT_ECRAN From SUBCMA
      When 2 
        [M:CMS0] = [F:HTR]
        [M:CMS1] = [F:HTR]
        [M:CMS2] = [F:HTR]
        [M:CMS3] = [F:HTR]
        [M:CMS4] = [F:HTR]
        [M:CMS5] = [F:HTR]
        [M:CMS6] = [F:HTR]
        Gosub LOADDATA From SUBCMSB
        Gosub TRT_ECRAN From SUBCMS
      When 3 
        [M:CMI0] = [F:HTR]
        [M:CMI1] = [F:HTR]
        [M:CMI2] = [F:HTR]
        [M:CMI3] = [F:HTR]
        [M:CMI4] = [F:HTR]
        [M:CMI5] = [F:HTR]
        Gosub LOADDATA From SUBCMIB
        Gosub TRT_ECRAN From SUBCMI
#      When 4 
#        [M:CMH0] = [F:HTR]# FGR 06/11/2008 X3SUIVI50234 : Le 4-Plan de travail n'existe plus
#        [M:CMH1] = [F:HTR]
#        [M:CMH2] = [F:HTR]
#        Gosub LOADCMH From SUBCMHB
#        Gosub TRT_ECRAN From SUBCMH
      When 5 
        [M:CMD0] = [F:HTR]
        [M:CMD1] = [F:HTR]
        [M:CMD2] = [F:HTR]
        [M:CMD3] = [F:HTR]
        [M:CMD4] = [F:HTR]
        Gosub LOADDATA From SUBCMDB
        Gosub TRT_ECRAN From SUBCMD
      When Default
    Endcase
    If GOK < 1 Then
      Call ECR_TRACE(mess(21,123,1) - mess([F:HTR]HTRTYP,3020,1) - [F:HTR]HTRNUM,1) From GESECRAN
      Rollback
    Else
      Call ECR_TRACE(mess(14,123,1) - mess([F:HTR]HTRTYP,3020,1) - [F:HTR]HTRNUM,0) From GESECRAN
      Commit
    Endif
  Next
End
