$PASS_CLASSES_WORKFLOW_EMPESSSA_EMPADR
#The following steps must be followed to trigger the workflow for all employee related records
#Declare all variables - Standard no custom code needed
Gosub PASS_CLASSES_WORKFLOW_VARIABLES From ESS_WRKFLOW_FUNC

#---------------------------------------------------------------------------------------------------#
#Before creating possible workflow records - indicate any properties that must be excluded (SYSPROP - From (30)
#..


#Specify function variables
MAIN_CLASSCOD = "EMPLOIDSA"    #The main class that was used to create the ESSXXX Class
CLASSCOD      = "EMPESSSA" #The ESS Class where the change occurred
THISUSR       = this.ACTX.USER

#EMPESSSA
If this.EMPESSSA <> null
  #Getting paramater values
  #CLASSPARAMFNC = func ESS_WRKFLOW_FUNC.GET_CLASS_PARAMETERS(MAIN_CLASSCOD,CTABLE,CABR) #Manual assignment
  CTABLE  = "EMPLOIDSART"
  CABR    = "ESAR"
  If this.EMPESSSA.EMPADR <> null
    For COLLECTION_IND = 1 To maxtab(this.EMPESSSA.EMPADR)
      If CLASSPARAMFNC = [V]CST_AOK and this.EMPESSSA.EMPADR(COLLECTION_IND) <> null
        #Specify the keys of the actual table - Char ALPKEY(250)(1..3),Integer INTKEY(1..3) ,Date DATKEY(1..3)
        Raz INTKEY,DATKEY,ALPKEY
        ALPKEY(0) = this.REFNUM
        INTKEY(0) = COLLECTION_IND

        #Test the status of the class and set WRK variable
        #This test must include the manual status added on class transfer
        If this.EMPESSSA.EMPADR(COLLECTION_IND).TCH_ADDSTA = "T"
          If this.EMPESSSA.EMPADR(COLLECTION_IND).ASTALIN = [V]CST_ANEWDEL
            WRK = "D"
          Else
            WRK = "M"
          Endif
        Endif

        #New lines created by the user
        If this.EMPESSSA.EMPADR(COLLECTION_IND).TCH_ADDSTA <> "T"
          If this.EMPESSSA.EMPADR(COLLECTION_IND).ASTALIN <> [V]CST_ANEWDEL
            If this.EMPESSSA.EMPADR(COLLECTION_IND).ASTALIN = [V]CST_ANEW
              WRK = "C"
            Endif
          Endif
        Endif
        If WRK <> ""
          #A Function per class must be added to ESS_WRKLOW_FUNC
          CLASS_WRKFLOW = func ESS_WRKFLOW_FUNC.GENESSWRKFLOW_ESSWRKSA(WRK,this,THISUSR,this.EMPESSSA,this.EMPESSSA.EMPADR(COLLECTION_IND),
&         CLASSCOD,CTABLE, CABR,CLASS_ERROR,SYSPROP,ALPKEY,INTKEY,DATKEY,CLEOBJ)
        Endif
      Endif
    Next
  Endif
Endif

Return

$PASS_CLASSES_WORKFLOW_EMPESSSA_PASDET
#The following steps must be followed to trigger the workflow for all employee related records
#Declare all variables - Standard no custom code needed
Gosub PASS_CLASSES_WORKFLOW_VARIABLES From ESS_WRKFLOW_FUNC

#---------------------------------------------------------------------------------------------------#
#Before creating possible workflow records - indicate any properties that must be excluded (SYSPROP - From (30)
#..
SYSPROP(30) = "ESSUIDPAS"

#Specify function variables
MAIN_CLASSCOD = "EMPLOIDSA"    #The main class that was used to create the ESSXXX Class
CLASSCOD      = "EMPESSSA" #The ESS Class where the change occurred
THISUSR       = this.ACTX.USER

#EMPESSSA
If this.EMPESSSA <> null
  #Getting paramater values
  #CLASSPARAMFNC = func ESS_WRKFLOW_FUNC.GET_CLASS_PARAMETERS(MAIN_CLASSCOD,CTABLE,CABR) #Manual assignment
  CTABLE  = "EMPLOIDSPAS"
  CABR    = "ESAR"
  If this.EMPESSSA.PASDET <> null
    #Count all the records
    For COLLECTION_IND = 1 To maxtab(this.EMPESSSA.PASDET)
      If this.EMPESSSA.PASDET(COLLECTION_IND)<>null & find(this.EMPESSSA.PASDET(COLLECTION_IND).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        COLCOUNT+=1
      Endif
    Next
    For COLLECTION_IND = 1 To maxtab(this.EMPESSSA.PASDET)
      If CLASSPARAMFNC = [V]CST_AOK and this.EMPESSSA.PASDET(COLLECTION_IND) <> null
        #Specify the keys of the actual table - Char ALPKEY(250)(1..3),Integer INTKEY(1..3) ,Date DATKEY(1..3)
        Raz INTKEY,DATKEY,ALPKEY
        ALPKEY(0) = this.REFNUM
        INTKEY(0) = COLLECTION_IND

        #Test the status of the class and set WRK variable
        #This test must include the manual status added on class transfer
        If this.EMPESSSA.PASDET(COLLECTION_IND).TCH_PASSTA = "T"
          If this.EMPESSSA.PASDET(COLLECTION_IND).ASTALIN = [V]CST_ANEWDEL
            WRK = "D"
          Else
            WRK = "M"
          Endif
        Endif

        #New lines created by the user
        If this.EMPESSSA.PASDET(COLLECTION_IND).TCH_PASSTA <> "T"
          If this.EMPESSSA.PASDET(COLLECTION_IND).ASTALIN <> [V]CST_ANEWDEL
            If this.EMPESSSA.PASDET(COLLECTION_IND).ASTALIN = [V]CST_ANEW
              WRK = "C"
            Endif
          Endif
        Endif
        If WRK <> ""
          INTKEY(1)= COLCOUNT
          #A Function per class must be added to ESS_WRKLOW_FUNC
          CLASS_WRKFLOW = func ESS_WRKFLOW_FUNC.GENESSWRKFLOW_ESSWRKSA_PASDET(WRK,this,THISUSR,this.EMPESSSA,this.EMPESSSA.PASDET(COLLECTION_IND),
&         CLASSCOD,CTABLE, CABR,CLASS_ERROR,SYSPROP,ALPKEY,INTKEY,DATKEY,CLEOBJ)
        Endif
      Endif
    Next
  Endif
Endif
Return

