#<AdxTL>@(#)0.0.0.0 $Revision$
##################################################
## Conversion et arrondi d'unités (GEODE)       ##
##################################################

#**
#* CNVUOM -
#*
#* @param UOMORG - Unit of measure Origin
#* @param UOMDES - Unit of measure destination (converting origin to destination UOM)
#* @param QTY    - Quantity
#* ASTATUS Funprog  - [V]CST_AOK, [V]CST_AERROR
#*!
Funprog CNVUOM(MY_INSTANCE,UOMORG,UOMDES,QTY)
Value Instance MY_INSTANCE Using C_OBJECT
Value    Char    UOMORG()
Value    Char    UOMDES()
Variable Decimal QTY

Local Integer ASTATUS

Gosub CNV
If QTY<>0
 QTY = arr(QTY*COEF,10^(-GUNTDEC(I)))
Endif
End [L]ASTATUS

Funprog CNVUOM2(MY_INSTANCE,UOMORG,UOMDES,QTY)
Value Instance MY_INSTANCE Using C_OBJECT
Value    Char    UOMORG()
Value    Char    UOMDES()
Variable Decimal QTY

Local Integer ASTATUS

Gosub CNV
If [L]ASTATUS = [V]CST_AOK & [L]QTY<>0
 [L]UOMDEC = fmet MY_INSTANCE.ACTX.ACACHE.ATUN.AGETVALNUM([L]UOMDES,"UOMDEC")
 QTY = -int(-[L]QTY*[L]COEF*10^[L]UOMDEC)*10^(-[L]UOMDEC)
Endif
End [L]ASTATUS

$CNV
STAT = 0
If QTY=0 : Return : Endif
Local Instance MY_TABCOEFF Using C_TABCOEFF
[L]ASTATUS = [V]CST_AOK

Local Decimal COEF

If UOMDES=UOMORG
  COEF = 1
Else
  MY_TABCOEFF = NewInstance C_TABCOEFF AllocGroup null
  [L]ASTATUS = fmet MY_TABCOEFF.AREAD(UOMORG,UOMDES)
  If [L]ASTATUS = [V]CST_AOK
    [L]COEF = MY_TABCOEFF.COEUOM
  Else
    FreeGroup MY_TABCOEFF
    [L]ASTATUS = fmet MY_TABCOEFF.AREAD(UOMDES,UOMORG)
    [L]COEF = MY_TABCOEFF.COEUOM
  Endif
Endif
Return
