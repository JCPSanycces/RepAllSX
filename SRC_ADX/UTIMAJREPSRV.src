#<AdxTL>@(#)10.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Create directory for batch server: GBATCHDIR
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Create directory SRV on main folder") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJ
End

#-------------------#
$MAJ

Local Char    APPLI(GDIMFIC) , VOLUME(1)
Local Char    MACHINE(GDIMFIC)
Local Char NEWREP(GDIMFIC),REPERT(GDIMFIC)
Local Integer I , ERREUR

# cas ou on arrive de INSTALL ou MAJX3
Local Integer LEVEL,ISINIT
While adxpno(LEVEL) <> ""
 If instr(1,adxpno(LEVEL),"INSTALL")>0 | instr(1,adxpno(LEVEL),"MAJX3") : ISINIT=1 : Break : Endif
 LEVEL += 1
Wend

If ISINIT & dim(GSILCREREP)<0
 I=1
 Global Integer GSILCREREP
Endif
Local File ADOSSIER [ADS_]

If dim(GBATCHDIR)<0
 Gosub SETBATCHDIRECTORY From GLOBVAR
Endif

# Create folder
Read [ADS_]DOSSIER=GDOSX3
If !fstat
 MACHINE = adxmac(0)
 APPLI  = [F:ADS_]DOSSIER
 VOLUME = [F:ADS_]VOLUME
 Call CREREP(filpath(GBATCHDIR,"","",APPLI,VOLUME,MACHINE),ERREUR) From DOSAPL
 Call CREREP(filpath(GBATCHDIR+"/tmp","","",APPLI,VOLUME,MACHINE),ERREUR) From DOSAPL
 Call CREREP(filpath(GBATCHDIR+"/TRA","","",APPLI,VOLUME,MACHINE),ERREUR) From DOSAPL
 Call CREREP(filpath(GBATCHDIR+"/job","","",APPLI,VOLUME,MACHINE),ERREUR) From DOSAPL
Endif

Close Local File [ADS_]

If I & ISINIT
 Kill GSILCREREP
Endif

Onerrgo ERR_VOL
NEWREP=filpath(GBATCHDIR,"","",GDOSX3)
Call MACHINE(NEWREP,MACHINE,REPERT) From ORDSYS
REPERT=ctrans(REPERT,"\","/")
#REPERT="TRA/../../"+GDOSX3+"/"+GBATCHDIR
Local File =[L]DOSSIER+".AVOLUME" [AVL_]
# Create record
Trbegin [AVL_]
 Read [AVL_]CODE=GBATCHDIR
 If fstat
  Raz [AVL_]
  [F:AVL_]VOLUME=GBATCHDIR
  [F:AVL_]ROOT = REPERT
  Write [AVL_]
  If fstat
   Call ERREUR("AVOLUME",1) From DOSDIC
  Endif
 Elsif [F:AVL_]ROOT<>REPERT
  [F:AVL_]ROOT = REPERT
  Rewrite [AVL_]
  If fstat
   Call ERREUR("AVOLUME",2) From DOSDIC
  Endif
 Endif
Commit
Close Local File [AVL_]
Onerrgo
Return



$ERR_VOL
Resume

