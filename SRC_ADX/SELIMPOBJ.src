#<AdxTL>@(#)11.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
GFLAG = "ZZMB*"
Call TRAITE_CHAR(VALEUR,PARAM,"","SELIMPOBJ","",6,"XYSELIMPOBJ") From GTRAITE
End

#######################################################
$ACTION
Case ACTION
 When "SEL_TABLE"
  Case GACTION
   When "GIMPOBJ" : Gosub SEL_IMP
   When "GEXPOBJ" : Gosub SEL_EXP
  Endcase
 When "VERF_TABLE" : Gosub VERF_TABLE
 When "FIN_TABLE"  : Gosub FIN_TABLE
 When Default
Endcase
Return

#######################################################
$SEL_IMP
If GFLAG=""
 OK = 0
Else
 CRITERE = ""
 CAR = "*?#!"
 For I=1 To len(CAR)
  If instr(1,GFLAG,mid$(CAR,I,1))
   OBJET = "AOE"
   CRITERE = 'pat(EXT,"'+GFLAG+'")'
   CRITERE += '& ENAFLG=2 & IMPORT=2'
   Break
  Endif
 Next I
 If OBJET=""
  GBIDC1 = GFLAG
  OK = 0
 Endif
Endif
Return

#######################################################
$SEL_EXP
If GFLAG=""
 OK = 0
Else
 CRITERE = ""
 CAR = "*?#!"
 For I=1 To len(CAR)
  If instr(1,GFLAG,mid$(CAR,I,1))
   OBJET = "AOE"
   CRITERE = 'pat(EXT,"'+GFLAG+'")'
   CRITERE += '& ENAFLG=2 & EXPORT=2'
   Break
  Endif
 Next I
 If OBJET=""
  GBIDC1 = GFLAG
  OK = 0
 Endif
Endif
Return

#######################################################
$VERF_TABLE
GBIDC1 = [F:AOE]EXT
Return

#######################################################
$FIN_TABLE
If GSTATUT=7
 GBIDC1 = "***"
Endif
Return
