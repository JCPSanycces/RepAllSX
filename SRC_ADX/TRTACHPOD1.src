#<AdxTL>@(#)10.0.0.0 $Revision$
#############################################################################
# TRTACHPOD1    Traitements liés aux demandes de livraison     Module Achat #
# ------------------------------------------------------------------------- #
# Sous-programmes :                                                         #
# Call                                                                      #
#   - MAJ_POD         : Gestion auto des DL à partir des plans (masque POM) #
#   - CTL_PERIODE_POD : Contrôle de la période de réception    (masque POM) #
#   - CTL_PERIODE_POD1: Contrôle de la période de réception    (masque PMG) #
#   - CRE_POQSEQ      : Splittage de lignes inter-site avec création DL     #
#   - RECH_CONTRAT    : Recherche et contrôle de contrat                    #
# Gosub                                                                     #
#   - MGT_POD1        : Gestion auto des DL à partir des plans (masque PMG) #
#############################################################################

#############################################################################
# MGT_POD1  : S/P de gestion des DL à partir du plan de travail             #
#           de l'approvisionneur                                            #
# ------------------------------------------------------------------------- #
# Gosub MGT_POD1                                                            #
#     Les paramètres sont passés par l'écran PURMGT [PMG]                   #
#     ---------------- A l'appel du sous-programme --------------------     #
#     MAJCOD   : Code mise à jour                                           #
#                  C = Création d'une ou plusieurs DL planifiées ou fermes  #
#                  M = Modification d'une DL planifiée ou ferme             #
#                  A = Suppression  d'une DL planifiée ou ferme             #
#                  S = Solde d'une DL ferme                                 #
#     MAJTYP   : Statut encours                                             #
#                  P = Obtention d'un ordre planifié (POP)                  #
#                  F = Obtention d'un ordre ferme    (POF)                  #
#     ERRCOD   : Code erreur (si<>0 contrôle stricte du statut encours)     #
#     RGRFLG   : Code regroupement des lignes à traiter                     #
#                0-1 = Non (1 ligne = 1 demande de livraison)               #
#                  2 = Oui (1 regroupement  = 1 demande de livraison)       #
#     MSGFLG   : Code affichage message de temporisation                    #
#                0-1 = Non                                                  #
#                  2 = Oui ("Mise à jour demande de livraison en cours ..") #
#     TRAFLG   : Code fichier trace                                         #
#                0-1 = Non                                                  #
#                  2 = Oui écriture des messages dans un fichier trace      #
#     WRCPDAT  : Période de réception                                       #
#                sous forme JJMMAA JJMMAAAA SSSAA SSSAAAA MMAA MMAAAA       #
#     CAD      : Cadencement (déduit après analyse de WRCPDAT)              #
#                  1 = Jour      2 = Semaine       3 = Mois                 #
#     YEA      : Année de la semaine de réception                           #
#     MON      : Mois de la période de réception                            #
#     WEE      : Semaine de la période de réception                         #
#     WDATDEB  : Date début de la période de réception                      #
#     WDATFIN  : Date  fin  de la période de réception                      #
#     USEPLC   : Lieu de consommation                                       #
#     NBLIG    : Nombre de lignes à traiter (par défaut 1)                  #
#                  si création de 1 à 50                                    #
#                  si modification ou suppression 1                         #
#     Tableau des lignes à traiter                                          #
#     WIPTYP()  WIPSTA()  WIPNUM()  ITMREF()  ORIFCY()  STOFCY()            #
#     VCRTYP()  VCRNUM()  VCRLIN()  VCRSEQ()  ENDDAT()  STU()               #
#     EXTSTUQTY()         PUU()     EXTPUUQTY()         ERRLIN()            #
#     ---------------- Au retour du sous-programme --------------------     #
#     ERRCOD  : Code erreur au retour du S/P                                #
#                0 = OK pas d'erreur                                        #
#                1 = xxxxxxxxxx Période de réception incorrecte !           #
#                2 = Module Stocks Affectation des compteurs non trouvée !  #
#                3 = Compteur en-cours incorrect ou non défini (max 15 car) #
#                4 = La structure par défaut des tarifs n'existe pas !      #
#                5 = Code mise à jour incorrect !                           #
#                6 = xxx Problème lors de la récupération du compteur       #
#                7 = 2 xxxxxxxxxx Problème de mise à jour des encours       #
#                8 = xxx xxxxxxxx Problème à la lecture de l'article-site ! #
#                9 = xx/xx/xx Date inférieure à la date du jour.            #
#               10 = Type d'ordre non traité !                              #
#               11 = xxxxxxxx Le contrat n'existe pas !                     #
#               12 = xxxxxxxx 99 Ligne article contrat introuvable !        #
#               13 = xxxxxxxx 99 99 Ligne demande livraison introuvable !   #
#               14 = Erreur S/P ventes à la création d'une ligne article    #
#               15 = Erreur S/P ventes à la création d'une ligne DL         #
#               16 = Erreur S/P ventes à la modification d'une ligne DL     #
#               17 = Erreur S/P ventes au solde d'une ligne DL            . #
#               18 = Erreur S/P ventes à la suppression d'une ligne DL      #
#               19 = Erreur S/P ventes au contrôle modification d'une DL    #
#               20 = Erreur S/P ventes au contrôle solde d'une ligne DL     #
#               21 = Erreur S/P ventes au contrôle suppression d'une DL     #
#               22 = Erreur S/P ventes au contrôle de la modif de la qté    #
#               23 = xxxxxxxx 99 99 Commande soldée. Modification interdite #
#               24 = xxxxxxxx 99 99 Ligne commande soldée. Modification ... #
#               25 = xxxxxxxx 99 99 Vous ne pouvez pas solder une ligne ... #
#               26 = xxxxxxxx 99 99 Vous ne pouvez pas modifier l'état .... #
#               27 = Paramétrage règles signature inexistant pour la soc... #
#               28 = La référence article est nécessaire                    #
#               29 = xxxxxxxx : Code article inexistant                     #
#               30 = xxxxxxxx : Article inactif                             #
#               31 = xxxxxxxx : Article non géré en stock                   #
#               32 = xxxxxxxx xxxxxxx L'article est en litige               #
#               33 = La qté est inférieure à la qté minimum. 999,99 xxx     #
#               34 = La qté saisie ne peut être inférieure à la qté cons... #
#               35 = Statut incompatible avec période de réception demandée #
#               37 = $PORDER  xxxxxxx Modification en cours sur un autre .. #
#                    $PORDERC xxxxxxx 999 Modification en cours sur un .... #
#               38 = Contrat xxxxx Site d'expédition différent ! (xxx<>xxx) #
#               40 = xxxxxxxxx Le contrat n'existe pas !                    #
#               41 = xxxxxxxxx Erreur à la valorisation de la ligne !       #
#               42 = xxxxxxxxxxxxxxxxxxxxxxxxxx Erreur de budget !          #
#               43 = $PREQUIS  xxxxxxx Modification en cours sur un autre.. #
#               44 = $PREQUISD xxxxxxx xxxx Modification en cours sur un... #
#               45 = Une erreur s'est produite en màj de l'ordre de fabri.. #
#               46 = Erreur à la mise à jour des demandes d'achat !         #
#               99 = Erreurs diverses                                       #
#     ERRLIN(): Code erreur ligne au retour du S/P (indicé de 0 à 49)       #
#                0 = OK pas d'erreur, ligne traitée                         #
#                1 = Erreur ligne non traitée                               #
#     GMESSAGE: Contient le texte de l'erreur (ERRCOD=1-46)                 #
#                      ou de la dernière erreur recontrée (ERRCOD=99)       #
#############################################################################
Subprog MAJ_POD
#----- Message pour patienter -----#
If [M:POM]MSGFLG=2 Call TEMPON(mess(237,197,1)) From GESECRAN : Endif
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
[M:POM]ERRCOD=0
If [M:POM]NBLIG=0 [M:POM]NBLIG=1 : Endif
If [M:POM]NBLIG>dim([M:POM]WIPTYP) [M:POM]NBLIG=dim([M:POM]WIPTYP) : Endif
For I=0 To [M:POM]NBLIG-1 : [M:POM]ERRLIN(I)=1 : Next I
#----- Ouverture du nouveau masque écran -----#
If clalev([M:PMG])=0 Local Mask PURMGT [PMG] : Endif
[M:PMG]=[M:POM]
Gosub MGT_POD1
[M:POM]=[M:PMG]
#----- Effacement message -----#
If [M:POM]MSGFLG=2 Call TEMPOFF From GESECRAN : Endif
#----- Fermeture et lecture du fichier trace si nécessaire -----#
If GPURTRACE=2
  Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
  GPURTRACE=0 : GTRACE=""
Elsif GPURTRACE=1
  Call FERME_TRACE From LECFIC
  GPURTRACE=0 : GTRACE=""
Endif
#----- Restauration variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
End


$MGT_POD1
If dim(I_DEPART)<1
  #----- Si aucun numéro de contrat renseigné, c'est fini ! -----#
  If max([M:PMG]POCNUM(0..[M:PMG]NBLIG-1))=""  Return : Endif
  Local Integer I_DEPART : I_DEPART=0
  #----- Tri des lignes du tableau -----#
  If [M:PMG]RGRFLG>1 & [M:PMG]NBLIG>1
    Sorta [M:PMG]NBLIG [M:PMG]NBLIG Order By [M:PMG]POCNUM(indice),
&                                            [M:PMG]BPRNUM(indice),
&                                            [M:PMG]STOFCY(indice),
&                                            [M:PMG]ITMREF(indice),
&                                            [M:PMG]ENDDAT(indice)
  Endif
  While [M:PMG]POCNUM(I_DEPART)=""  I_DEPART+=1 : Wend
Endif
#-----
Local Libelle  WIPSTAFLG
Local Integer  I, J, K, RETOUR, OUVFICFLG, WPOQSEQ, WSEQPREC, WSEQSUIV, WDELTA, STAT
Local Shortint WCADPREC, WCADSUIV, WSTA, WLINNBR, SAVNOLIGN
Local Decimal  MT, QTY, WEARQTY, WORDQTYPUU, ORIQTYPUU, WTOTORD, WTTVORD, WMT1, WMT2, WMT3, WQT1
Local Char     SYMBOL2(30), SYMBOL3(30), SYMBOL4(30), CLEFIC(35), WMSG(80), WCUR(GLONCUR)
Local Char     WPOHFCY(GLONFCY), WBPSNUM(GLONBPS), WDATE(10)
Local Char     WBPCNUM(GLONBPC), UNIVEN(GLONUOM)
Local Shortint TARFLG,    PRIFLG,     SIGN
Local Integer  WPOPSEQ1,  WPOPSEQ2,   WPOPSEQ
Local Char     VAT(GLONVAT)(3), WMAJCOD(1)
Local Char     TPLAN  (GLONCOA)(1..10)
Local Char     TCOMPTE(GLONGAC)(1..10)
Local Integer  WBETFCY, WBETCPY, WDME
Local Char     WPURFCY(GLONFCY), WSALFCY(GLONFCY), WSHIFCY(GLONFCY), WINVFCY(GLONFCY)
Local Char     WBPSORD(GLONBPS), WBPCORD(GLONBPC), WBPCINV(GLONBPC)
Local Char     ID1(20)(1..1), ID2(20)(1..3)
Local Decimal  WCLCAMT(1..7)                    # 08.2010 66914
#-----
Local Decimal  QTEUA, SAV_QTEUA
#----- Variables locales pour le point d'entrée MAJDL -----#
Local Libelle  TYPMAJ
Local Char     FICHIER(GLONATB), ABRFIC(3)
# Issue X3-55891 - 2018-09-28 by SR : Déclinaison par site
Local Integer WITMBPS, WRETOUR
Local  Integer  SAV_GIMPORT          : SAV_GIMPORT=GIMPORT
#-----
Raz GMESSAGE, GSOC_ACTIVE
SAVNOLIGN=nolign : nolign=1
#----- Si code erreur renseigné le code statut demandé ne doit pas être changé -----#
If [M:PMG]ERRCOD<>0 WIPSTAFLG=1 Else WIPSTAFLG=0 : Endif
#----- Ouverture fichier trace si nécessaire -----#
# Issue X3-55891 - 2018-09-28 by SR : Oucrir la trace comme dans TRTACHPOH1
#If [M:PMG]TRAFLG=2
#  If GTRACE=""
#    Call OUVRE_TRACE(mess(238,197,1)) From LECFIC : GPURTRACE=1
#  Endif
#Endif
#----- Ouverture fichier trace si nécessaire -----#
If ([M:PMG]TRAFLG=2 & GTRACE="") | ([M:PMG]MAJCOD="C" & GTRACE="")
  Call OUVRE_TRACE(mess(238,197,1)) From LECFIC : GPURTRACE=1
Endif
# End issue X3-55891
#----- Ouverture tables si nécessaire -----#
If !clalev([F:POH])   Local File PORDER     [POH]  : Endif
If !clalev([F:POC])   Local File PORDERC    [POC]  : Endif
If !clalev([F:POP])   Local File PORDERP    [POP]  : Endif
If !clalev([F:CAL])   Local File CPTANALIN  [CAL]  : Endif
If !clalev([F:PO1])   Local File PORDERP    [PO1]  : Endif
If !clalev([F:PO2])   Local File PORDERP    [PO2]  : Endif
If !clalev([F:POQ])   Local File PORDERQ    [POQ]  : Endif
If !clalev([F:BPS])   Local File BPSUPPLIER [BPS]  : Endif
If !clalev([F:BPR])   Local File BPARTNER   [BPR]  : Endif
If !clalev([F:BPR2])  Local File BPARTNER   [BPR2] : Endif
If !clalev([F:BPA])   Local File BPADDRESS  [BPA]  : Endif
If !clalev([F:MVS])   Local File BPSUPPMVT  [MVS]  : Endif
If !clalev([F:ITM])   Local File ITMMASTER  [ITM]  : Endif
If !clalev([F:ITP])   Local File ITMBPS     [ITP]  : Endif
If !clalev([F:ITS])   Local File ITMSALES   [ITS]  : Endif
If !clalev([F:ITV])   Local File ITMMVT     [ITV]  : Endif
If !clalev([F:ITF])   Local File ITMFACILIT [ITF]  : Endif
If !clalev([F:FCY])   Local File FACILITY   [FCY]  : Endif
If !clalev([F:PSH])   Local File PREQUIS    [PSH]  : Endif
If !clalev([F:PSD])   Local File PREQUISD   [PSD]  : Endif
If !clalev([F:PSO])   Local File PREQUISO   [PSO]  : Endif
If !clalev([F:ORD])   Local File ORDERS     [ORD]  : Endif
If !clalev([F:TCU])   Local File TABCUR     [TCU]  : Endif
If !clalev([F:TUN])   Local File TABUNIT    [TUN]  : Endif
If !clalev([F:TCA])   Local File TABCOUAFF  [TCA]  : Endif
If !clalev([F:ITG])   Local File ITMCATEG   [ITG]  : Endif
If !clalev([F:TCY])   Local File TABCOUNTRY [TCY]  : Endif
If !clalev([F:TCO])   Local File TABCOEFF   [TCO]  : Endif
If !clalev([F:TUV])   Local File TABUNAVAIL [TUV]  : Endif
If !clalev([F:PPK])   Local File PPRICLINK  [PPK]  : Endif
If !clalev([F:PPC])   Local File PPRICCONF  [PPC]  : Endif
If !clalev([F:PER])   Local File PERIOD     [PER]  : Endif
If !clalev([F:CAC])   Local File GACCCODE   [CAC]  : Endif
If !clalev([F:GAG])   Local File GAUTACEF   [GAG]  : Endif
If !clalev([F:GAD])   Local File GAUTACED   [GAD]  : Endif
If !clalev([F:GAC])   Local File GACCOUNT   [GAC]  : Endif
If !clalev([F:TB0])   Local File PORDER     [TB0]  : Endif
If !clalev([F:TB1])   Local File PORDERQ    [TB1]  : Endif
If !clalev([F:TB2])   Local File CPTANALIN  [TB2]  : Endif
# Issue X3-105399 - 2018-08-24 by SR
If !clalev([F:STCF])  Local File COSTSTCF  [STCF]  : Endif
If !clalev([F:ITPF])  Local File ITMBPSFCY [ITPF]  : Endif # Issue X3-55891 - 2018-09-28 by SR
#----- Ouverture fichiers pour inter-sites / inter-sociétés -----#
If GMODU(5)=2 : # Si module Ventes présent
  If !clalev([F:BPC])  Local File BPCUSTOMER [BPC] : Endif
  If !clalev([F:ITS])  Local File ITMSALES   [ITS] : Endif
  If !clalev([F:BPD])  Local File BPDLVCUST  [BPD] : Endif
Endif
If GMODU(2)=1 : # Compta
  Local File BALANA, BUD, BUDPAR
Endif
#----- Ouverture masques si nécessaire -----#
If GMODU(5)=2
  If !clalev([M:SORW]) Local Mask SORW      [SORW] : Endif
Endif
#-----
If !clalev([M:ORDK])   Local Mask ORDK      [ORDK] : Endif
If !clalev([M:SBCK])   Local Mask SBCK      [SBCK] : Endif
#----- contrôle que la structure tarif par défaut existe -----#
STAT=0
If !clalev([F:PRS])  Local File PRICSTRUCT [PRS] : OUVFICFLG=1 : Endif
Read [PRS] PRS0=2;""
If fstat
  GMESSAGE=mess(81,199,1) : Call ECR_TRACE(1)
  [M:PMG]ERRCOD=4  : Goto FIN_MAJ_POD1
Endif
If OUVFICFLG=1 Close Local File [PRS] : Raz OUVFICFLG : Endif
#----- Chargement des paramètres par défaut de la gestion tarif -----#
Raz GPLISTC
Call COLREM("C",2,"") From TRTPRICE
Call TYPREM(2,"")     From TRTPRICE
Call TARIFCHGT(6)     From TRTPRICE
#----- Appel du point d'entrée PECBESOINS pour conversion qtés en unité physique -----#
Local Char     ABREV(4) : [L]ABREV="PMG"
Local Shortint TRAIT    : [L]TRAIT=6
Local Decimal  RMNQTY
For I=0 To [M:PMG]NBLIG-1
  If [M:PMG]EXTSTUQTY(I)=0
    Call PCAL_QTY ([M:PMG]EXTPUUQTY(I),[M:PMG]PUU(I),[L]RMNQTY,
&           [M:PMG]STU(I),[M:PMG]ITMREF(I),[M:PMG]BPRNUM(I),1,GBIDD1) From TRTACHQTE1
  Else
    [L]RMNQTY=[M:PMG]EXTSTUQTY(I)
  Endif
  #-----
  Gosub POINT_PECBESOINS From TRTACHMGT1
  #-----
  [M:PMG]EXTSTUQTY(I)=[L]RMNQTY
  Call PCAL_QTY ([M:PMG]EXTSTUQTY(I),[M:PMG]STU(I),[M:PMG]EXTPUUQTY(I),
&           [M:PMG]PUU(I),[M:PMG]ITMREF(I),[M:PMG]BPRNUM(I),1,GBIDD1) From TRTACHQTE1
Next I
#----- Vérification si transformation d'une POP de DA en POP/POF de DL -----#
If [M:PMG]MAJCOD="M" & [M:PMG]WIPNUM(I_DEPART)<>"" & [M:PMG]NBLIG=1
  Read [ORD] ORD0=[M:PMG]WIPTYP(I_DEPART);[M:PMG]WIPNUM(I_DEPART);[M:PMG]ITMREF(I_DEPART)
  If !fstat & [F:ORD]ABBFIL<>"POC"
    [M:PMG]MAJCOD="C" : # C'est une création que l'on veut faire et non une modif !
  #----- Vérification si changement de contrat -----#
  Elsif !fstat & [F:ORD]VCRNUM<>[M:PMG]POCNUM(I_DEPART)
    [M:PMG]MAJCOD="C" : # C'est une création que l'on veut faire et non une modif !
  Endif
Endif
# Issue X3-55891 - 2018-10-01 by SR : Pour avoir tous les messages dans la trace
GIMPORT = 1
#----- Sélection du traitement demandé -----#
Default Mask [PMG]
[L]WMAJCOD=[M:PMG]MAJCOD
Case [M:PMG]MAJCOD
  When "C"     : Gosub CREATION_POD1
  When "M"     : Gosub MODIFICATION_POD1
  When "A"     : Gosub SUPPRESSION_POD1
  When "S"     : Gosub SOLDE_POD1
  When Default : GMESSAGE=mess(227,197,1) : Call ECR_TRACE(1) : [M:PMG]ERRCOD=5
Endcase
$FIN_MAJ_POD1
#----- Déblocage logique entête cde si nécessaire -----#
If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
#----- Déblocage logique ligne article contrat si nécessaire -----#
If SYMBOL3<>"" Unlock=SYMBOL3 : Raz SYMBOL3 : Endif
#----- Déblocage logique DA si nécessaire -----#
If SYMBOL4<>"" Unlock=SYMBOL4 : Raz SYMBOL4 : Endif
nolign=SAVNOLIGN
# Issue X3-55891 - 2018-09-28 by SR : Déclinaison par site
GIMPORT=SAV_GIMPORT
Return


#################################################################
# Création de demandes de livraison à partir d'une ou plusieurs #
#                   "POS", "POP", "TRS" ou "TRP"                #
#################################################################
$CREATION_POD1
#----- Variables locales -----#
Local Char     WSTOFCY(GLONFCY), WPOHNUM(GLONPOH)
Local Char     WITMREF(GLONITM)
Local Integer  WPOPLIN,   MAXLIGNE
Local Libelle  WVCRTYPORI         (0..[M:PMG]NBLIG)
Local Char     WVCRNUMORI(GLONVCR)(0..[M:PMG]NBLIG)
Local Integer  WVCRLINORI         (0..[M:PMG]NBLIG)
Local Integer  WVCRSEQORI         (0..[M:PMG]NBLIG)
# Issue X3-61613 - 2017-10-27 by SR : Ne pas casser la boucle I en création de ligne de contrat
Local Integer  WI
# Issue X3-105399 - 2018-08-24 by SR
Local Decimal WCPRAMT,WCPRAMTDEV
Local Integer STAT
#----- Traitement période de réception prévue uniquement si regroupement à oui -----#
If [M:PMG]RGRFLG>1
  Gosub CTL_PERIODE : # Contrôle et chargement des zones date
  If mkstat Call ECR_TRACE(1) : mkstat=0 : Return : Endif
Endif
#----- Récupération nombre de lignes maxi d'une commande ouverte -----#
If clalev([F:ACV])=0 Local File ACTIV [ACV] : OUVFICFLG=1 : Endif
Read [ACV] CODACT="PCA" : If fstat Raz [F:ACV] : [F:ACV]DIME=20 : Endif
MAXLIGNE=[F:ACV]DIME
If OUVFICFLG=1 Close Local File [ACV] : Raz OUVFICFLG : Endif
#-----
Call DEBTRANS From GLOCK
$TR_CREATION
#----- Effacement des buffers commande ouverte -----#
GOK=1 : Raz [F:POH], [F:POC], [F:POQ]
Raz WMSG, GMESSAGE
Raz WSTOFCY, WBPSNUM, WBPCNUM, WPOHNUM, WITMREF, WPOPLIN, WPOQSEQ
Raz WPURFCY, WBPSORD
For I=I_DEPART To [M:PMG]NBLIG-1 : [M:PMG]ERRLIN(I)=1 : Next I
Trbegin ADOVAL
  #----- Suppression ou consommation des lignes DL prises en compte -----#
  For I=I_DEPART To [M:PMG]NBLIG-1
    If find([M:PMG]WIPTYP(I),2,7) & [M:PMG]WIPSTA(I)<3 & [M:PMG]WIPNUM(I)<>"" &
&      [M:PMG]VCRNUM(I)<>""
      Gosub CONSOMMATION_LIGNE_POQ1 : If GOK<1 Break : Endif
    Endif
  Next I
  [M:PMG]MAJCOD="C"
  If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
  If SYMBOL3<>"" Unlock=SYMBOL3 : Raz SYMBOL3 : Endif
  If GOK=-1 Goto ROLL_CREATION  : Endif
  If GOK=0  Goto AB_CREATION    : Endif
  #----- Boucle de lecture des lignes de besoins pris en compte (TRS-TRP-POS-POP) -----#
  Raz [F:POH], [F:POC], [F:POQ]
  Raz WMSG, WSTOFCY, WBPSNUM, WBPCNUM, WPOHNUM, WITMREF, WPOPLIN, WPOQSEQ
  For I=I_DEPART To [M:PMG]NBLIG-1
    #----- Traitement des "TRS" "TRP" "TRF" "POS" "POP" "POF" uniquement -----#
    If (!find([M:PMG]WIPTYP(I),2,7) | [M:PMG]WIPSTA(I)>3) & [M:PMG]WIPNUM(I)<>""
      GMESSAGE=mess(219,197,1) : # Type d'ordre non traité !
      Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE : Goto SUITE_CREATION
    Endif
    #----- Test si ligne chargée et pas de regroupement ou rupture -----#
    If [F:POQ]ITMREF<>""
      If [M:PMG]RGRFLG<2 |
&        [F:POQ]ITMREF<>[M:PMG]ITMREF(I) |
&        [F:POQ]PRHFCY<>[M:PMG]STOFCY(I) |
&        [F:POQ]POHNUM<>[M:PMG]POCNUM(I)
        Gosub CREATION_LIGNE_POQ : Raz [F:POQ]
        If GOK<1 Break : Endif
        If GMESSAGE<>""
          Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE
        Endif
      Endif
      #----- Rupture sur ligne article contrat -----#
      If [F:POC]ITMREF<>[M:PMG]ITMREF(I) |
&        [F:POC]PRHFCY<>[M:PMG]STOFCY(I) |
&        [F:POC]POHNUM<>[M:PMG]POCNUM(I)
        Gosub MAJ_ENTETE_POC : Raz [F:POC]
        If SYMBOL3<>"" Unlock=SYMBOL3 : Raz SYMBOL3 : Endif
        If GOK<1 Break : Endif
        If GMESSAGE<>""
          Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE
        Endif
      Endif
      #----- Rupture sur numéro de contrat ----#
      If [F:POH]POHNUM<>[M:PMG]POCNUM(I)
        Gosub MAJ_ENTETE_POH : Raz [F:POH]
        If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
        If GOK<1 Break : Endif
        If GMESSAGE<>""
          Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE
        Endif
      Endif
    Endif
    #----- Vérification existence du contrat valide -----#
    If [M:PMG]POCNUM(I)<>WPOHNUM
      Read [POH] POH0=[M:PMG]POCNUM(I)
      If fstat  Raz [F:POH] : Endif
      If [F:POH]POHNUM="" : # XXXXXXXXXXX Le contrat n'existe pas !
        GMESSAGE=[M:PMG]POCNUM(I)-mess(354,197,1)
        Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE : Goto SUITE_CREATION
      Elsif [F:POH]STRDAT>date$ | [F:POH]ENDDAT<date$ | [F:POH]CLEFLG=2
        Raz [F:POH]       : # XXXXXXXXXXX Le contrat n'est pas valide !
        GMESSAGE=[M:PMG]POCNUM(I)-mess(609,197,1)
        Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE : Goto SUITE_CREATION
      Endif
      #----- Contrôle et chargement variables inter-sites -----#
      If [L]WPURFCY<>[F:POH]POHFCY | [L]WBPSORD<>[F:POH]BPSNUM
        [L]WPURFCY=[F:POH]POHFCY
        [L]WBPSORD=[F:POH]BPSNUM
      Endif
      #-----
      WPOHFCY=[F:POH]POHFCY
      WBPSNUM=[F:POH]BPSNUM
      Gosub CHARG_PARAM
      Raz [F:POH]
      If GMESSAGE<>""
        Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE : Goto SUITE_CREATION
      Endif
    Endif
    If  [M:PMG]POCNUM(I)<>WPOHNUM | [M:PMG]ITMREF(I)<>WITMREF | [M:PMG]STOFCY(I)<>WSTOFCY
      WPOHNUM   =[M:PMG]POCNUM(I)
      WITMREF   =[M:PMG]ITMREF(I)
      WSTOFCY   =[M:PMG]STOFCY(I)
      Raz [F:POC]
    Endif
    #----- Contrôle validité des champs -----#
    Call CONTROLE_ZONES(I,WBPSNUM)
    If GMESSAGE<>""
      [M:PMG]ERRCOD=0 : GOK=1
       Gosub ECR_NON_TRAITEE :  Goto SUITE_CREATION
    Endif
    #----- Si nouveau contrat, lecture de l'entête -----#
    If [F:POH]POHNUM=""
      Read [POH] POH0=WPOHNUM
      If fstat : # XXXXXXXXXXX Le contrat n'existe pas !
        Raz [F:POH] : GMESSAGE=WPOHNUM-mess(354,197,1)
        Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE : Goto SUITE_CREATION
      Endif
      #----- Blocage logique de l'entête de commande -----#
      SYMBOL2="POH"+WPOHNUM
      Lock=SYMBOL2
      If fstat
        Raz [F:POH] : GMESSAGE="$PORDER"-WPOHNUM-mess(10,100,1)
        Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE : Goto SUITE_CREATION
      Endif
      WTOTORD=[F:POH]TOTORD
      WTTVORD=[F:POH]TTVORD
      WLINNBR=[F:POH]LINNBR
    Endif
    #----- Contrôle existence de la ligne article contrat -----#
    If [F:POC]POHNUM=""
      Read [POC] POC1=[F:POH]POHNUM;[M:PMG]ITMREF(I);[M:PMG]STOFCY(I)
      If fstat
        If [F:POH]BETFCY<>2 | [F:POH]BETCPY=2
          If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
          GMESSAGE=[F:POH]POHNUM-[M:PMG]ITMREF(I)-[M:PMG]STOFCY(I)-mess(354,197,1)
          Raz [F:POH], [F:POC] : # XXXXXXXXXXX XXXXXXXXXX XXX Le contrat n'existe pas !
          Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE : Goto SUITE_CREATION
        Else
          # Issue X3-55891 - 2018-09-28 by SR : Déclinaison pas site
          # Contrôler les blocages pour la triplette Article/Fournisseur/Site
          # En Intersite
          Raz WRETOUR, WITMBPS
          Call CTRL_DOUFLG(2,[M:PMG]ITMREF(I),[F:POH]BPSNUM,[M:PMG]STOFCY(I),WITMBPS,WRETOUR) From TRTACHCTL1
          If WRETOUR <> 0 Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE : Goto SUITE_CREATION : Endif
          # End issue X3-55891
          Gosub CREATION_POC : If GOK<1  Break : Endif : # Création si nécessaire
          If GMESSAGE<>""
            If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
            Raz [F:POH]
            Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE : Goto SUITE_CREATION
          Endif
        Endif
      Endif
      #----- Blocage logique de la ligne article contrat -----#
      SYMBOL3="POC"+num$([F:POC]POPLIN)+"\"+[F:POC]POHNUM
      Lock=SYMBOL3
      If fstat
        If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
        Raz [F:POH], [F:POC]
        GMESSAGE="$PORDERC"-[F:POC]POHNUM-num$([F:POC]POPLIN)-mess(10,100,1)
        Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE : Goto SUITE_CREATION
      Endif
      WORDQTYPUU=[F:POC]ORDQTYPUU
      WEARQTY   =[F:POC]EARQTY
    Endif
    #----- Nouvelle ligne demande de livraison -----#
    If [F:POQ]ITMREF=""
      #--- Chargement des zones date à partir des lignes si pas de regroupement ---#
      If [M:PMG]RGRFLG<2
        [M:PMG]WRCPDAT=format$(GFMDAT4,[M:PMG]ENDDAT(I)) : WDATE=[M:PMG]WRCPDAT
        [M:PMG]CAD=1
        Gosub LENDAT8 From SUBPODA : # Cadencement jour
        Gosub CHARG_DATE_JOUR From TRTACHPOD1
      Endif
      Gosub RECH_POQSEQ : # Recherche no séquence (WPOQSEQ)
      #----- Contrôle dates de validité de la ligne contrat -----#
      If GMESSAGE="" & [M:PMG]WDATFIN<[F:POC]STRDAT
        GMESSAGE =[F:POC]POHNUM-[F:POC]ITMREF-mess(78,194,1)
        GMESSAGE-="("-format$("D:"+GFMDAT4,[M:PMG]WDATFIN)-"<"-format$("D:"+GFMDAT4,[F:POC]STRDAT)-")"
      Endif
      If GMESSAGE="" & [M:PMG]WDATFIN>[F:POC]ENDDAT
        GMESSAGE =[F:POC]POHNUM-[F:POC]ITMREF-mess(67,194,1)
        GMESSAGE-="("-format$("D:"+GFMDAT4,[M:PMG]WDATFIN)-">"-format$("D:"+GFMDAT4,[F:POC]ENDDAT)-")"
      Endif
      #-----
      If GMESSAGE<>""
        If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
        If SYMBOL3<>"" Unlock=SYMBOL3 : Raz SYMBOL3 : Endif
        Raz [F:POH], [F:POQ]
        Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE :  Goto SUITE_CREATION
      Endif
      Gosub AJUST_CADENCE_STATUT From TRTACHPOD1
      If GMESSAGE<>""
        If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
        If SYMBOL3<>"" Unlock=SYMBOL3 : Raz SYMBOL3 : Endif
        Raz [F:POH], [F:POQ]
        Call ECR_TRACE(1) : Gosub ECR_NON_TRAITEE :  Goto SUITE_CREATION
      Endif
      [F:POQ]POHNUM   =[F:POH]POHNUM
      [F:POQ]POPLIN   =[F:POC]POPLIN
      [F:POQ]POQSEQ   =WPOQSEQ
      [F:POQ]POHFCY   =[F:POH]POHFCY
      [F:POQ]POHTYP   =2
      [F:POQ]ORDDAT   =[F:POH]ORDDAT
      [F:POQ]BPSNUM   =[F:POH]BPSNUM
      [F:POQ]BPSINV   =[F:POH]BPSINV
      [F:POQ]ITMREF   =[M:PMG]ITMREF(I)
      [F:POQ]PUU      =[F:POC]PUU
      [F:POQ]STU      =[M:PMG]STU(I)
      [F:POQ]UOM      =[F:POC]PUU
      [F:POQ]UOMFLG   =1
      [F:POQ]UOMPUUCOE=1
      [F:POQ]QTYSTU   =[M:PMG]EXTSTUQTY(I)
      If [M:PMG]WIPNUM(I)<>"" [F:POQ]RETQTYSTU=[M:PMG]EXTSTUQTY(I) : Endif
      [F:POQ]EXTRCPDAT=[M:PMG]WDATFIN
      [F:POQ]PRHFCY   =[M:PMG]STOFCY(I)
      #----- Chargement adresse de réception -----#
      If [F:POC]PRHFCY<>[F:POQ]PRHFCY
        If [F:FCY]FCY<>[F:POQ]PRHFCY
          Read [FCY] FCY0=[F:POQ]PRHFCY : If fstat Raz [F:FCY] : Endif
        Endif
        [F:POQ]FCYADD =[F:FCY]BPAADD
      Else
        [F:POQ]FCYADD =[F:POC]FCYADD
      Endif
      #-----
      If [M:PMG]USEPLC<>""
        [F:POQ]USEPLC =[M:PMG]USEPLC
      Else
       [F:POQ]USEPLC  =[F:POC]USEPLC
      Endif
      If [F:POH]BETFCY=2 & [F:POH]BETCPY<>2
        [F:POQ]WIPTYP =7
      Else
        [F:POQ]WIPTYP =2
      Endif
      [F:POQ]WIPSTA   =WSTA
      [F:POQ]RCPCLEFLG=1
      [F:POQ]LINCLEFLG=1
      [F:POQ]LININVFLG=1
      [F:POQ]LINPRNFLG=1
      [F:POQ]FBUFLG   =1
      [F:POQ]ORI      =1
      [F:POQ]CAD      =[M:PMG]CAD
      [F:POQ]YEA      =[M:PMG]YEA
      [F:POQ]MON      =[M:PMG]MON
      [F:POQ]WEE      =[M:PMG]WEE
      If [F:POQ]EXTRCPDAT<date$
        [F:POQ]LINSTA =2
      Else
        [F:POQ]LINSTA =1
      Endif
      [F:POQ]DEMRCPDAT=[M:PMG]WDATDEB
      [F:POQ]DEMENDDAT=[M:PMG]WDATFIN
      #----- Chargement type d'achat -----#
      [F:POQ]LINPURTYP=[F:POC]LINPURTYP
      #----- Si contrat sous-traitance -----#
      If [M:PMG]WIPTYP(I)=4 & [M:PMG]WIPSTA(I)=1
         Raz [M:SBCK]
         [M:SBCK]MAJCOD="G"
         [M:SBCK]WIPNUM=[M:PMG]WIPNUM(I)
         [M:SBCK]ITMREF=[M:PMG]ITMREF(I)
         Call MAJ_SBC From SBCLIB
         [F:POQ]ITMREFORI(NOL)=[M:SBCK]ITMREFORI : # Chargement article lancé (fini)
         [F:POQ]VCRLINORI(NOL)=[M:SBCK]VCRLINORI : # Chargement numéro d'opération
         [F:POQ]VCRNUMORI(NOL)=[M:SBCK]VCRNUMORI : # Chargement numéro d'OF
         [F:POQ]VCRSEQORI(NOL)=[M:SBCK]VCRSEQORI : # Chargement fraction
         [F:POQ]VCRTYPORI(NOL)=[M:SBCK]VCRTYPORI
      Endif
      #-----
      [F:POQ]CREUSR=GUSER
      [F:POQ]CREDAT=date$
    #----- Cumul des qtés et maj date de réception -----#
    Else
      [F:POQ]QTYSTU+=[M:PMG]EXTSTUQTY(I)
      If [M:PMG]WIPNUM(I)<>"" [F:POQ]RETQTYSTU+=[M:PMG]EXTSTUQTY(I) : Endif
    Endif
    #----- Mise à jour des ordres TRS-TRP-POS-POP (Consommation) -----#
    If [M:PMG]WIPNUM(I)<>"" & [M:PMG]ERRLIN(I)<>9 : # Ligne supprimée ou consommée
      Read [ORD] ORD0=[M:PMG]WIPTYP(I);[M:PMG]WIPNUM(I);[M:PMG]ITMREF(I)
      If fstat
        Raz [F:ORD]
      Else
        Gosub POINT_ORDLEC From TRTACHMGT1 : # Appel point d'entrée ORDLEC
      Endif
      WVCRTYPORI(I) = [F:ORD]VCRTYPORI
      WVCRNUMORI(I) = [F:ORD]VCRNUMORI
      WVCRLINORI(I) = [F:ORD]VCRLINORI
      WVCRSEQORI(I) = [F:ORD]VCRSEQORI
      [M:ORDK]=[F:ORD]
      [M:ORDK]MAJCOD  = "M"
      [M:ORDK]WIPTYP  = [M:PMG]WIPTYP(I)
      [M:ORDK]WIPNUM  = [M:PMG]WIPNUM(I)
      [M:ORDK]ITMREF  = [M:PMG]ITMREF(I)
      [M:ORDK]EXTQTY -= [M:PMG]EXTSTUQTY(I)
      If left$([M:ORDK]ABBFIL,1)<>"P"  [M:ORDK]ABBFIL="PUR" : Endif
      Call WIP From TRTWIP
      If GOK<1
        WMSG =num$([M:PMG]WIPTYP(I))
        WMSG-=[M:PMG]WIPNUM(I)-[M:PMG]ITMREF(I)-mess(92,197,1) : # Problème en maj encours
        [M:PMG]ERRCOD=7 : Break
      Endif
      #----- Mise à jour demandes d'achat entête, ligne et fichier liens -----#
      If [F:ORD]WIPTYP=2 & [F:ORD]WIPSTA=2 & [F:ORD]ABBFIL="PSD"
        CLEFIC=[F:ORD]VCRNUM
        SYMBOL4="PSH"+CLEFIC : Lock=SYMBOL4
        #----- Si entête DA bloquée logiquement --> Abandon -----#
        If fstat
          WMSG="$PREQUIS"-CLEFIC-mess(10,100,1) : # $PREQUIS xxxxx Modification en c...
          [M:PMG]ERRCOD=43 : GOK=0 : Raz SYMBOL4 : Break
        Endif
        #----- Lecture de l'entête DA avec blocage physique -----#
        WMSG=mess(12,100,1)-"PREQUIS"-CLEFIC : # Erreur d'accès sur le fichier ...
        Readlock [PSH] PSH0=CLEFIC
        If fstat=1  GOK=-1 : GLOCK="$PREQUIS"-CLEFIC            : Break
        Elsif fstat GOK=0  : Call RSTA("PSH",CLEFIC) From GLOCK : Break
        Endif
        CLEFIC+=" "+num$([F:ORD]VCRLIN)
        WMSG=mess(12,100,1)-"PREQUISD"-CLEFIC : # Erreur d'accès sur le fichier ...
        Readlock [PSD] PSD0=[F:ORD]VCRNUM;[F:ORD]VCRLIN
        If fstat=1  GOK=-1 : GLOCK="$PREQUISD"-CLEFIC           : Break
        Elsif fstat GOK=0  : Call RSTA("PSD",CLEFIC) From GLOCK : Break
        Endif
        If [M:PMG]EXTSTUQTY(I)>[F:PSD]QTYSTU-[F:PSD]ORDQTYSTU
          WQT1=[F:PSD]QTYSTU-[F:PSD]ORDQTYSTU
        Else
          WQT1=[M:PMG]EXTSTUQTY(I)
        Endif
        If WQT1<0  Raz WQT1 : Endif
        #----- Si indicateur de signature  modifié  --> Abandon ----#
        #If [F:PSD]LINAPPFLG<3
        #  WMSG="$PREQUISD"-CLEFIC-mess(10,100,1) : # $PREQUISD xxxxx xxx Modification ...
        #  [M:PMG]ERRCOD=44 : GOK=0 : Break
        #Endif
        #----- Avertissement si ligne DA non signée (on ne devrait pas ?) -----#
        If [F:PSD]LINAPPFLG<3
          GMESSAGE=CLEFIC-mess(224,194,1) : Call ECR_TRACE(0) : Raz GMESSAGE
        Endif
        #----- Chargement et écriture fichier lien demande-commande -----#
        Raz [F:PSO]
        [F:PSO]PSHNUM=[F:PSD]PSHNUM
        [F:PSO]PSDLIN=[F:PSD]PSDLIN
        [F:PSO]POHNUM=[F:POQ]POHNUM
        [F:PSO]POPLIN=[F:POQ]POPLIN
        [F:PSO]POQSEQ=[F:POQ]POQSEQ
        [F:PSO]PUU   =[F:PSD]PUU
        [F:PSO]QTYSTU=WQT1
        [F:PSO]STU   =[F:POQ]STU
        #--- Conversion qté avec le coef. utilisé lors de la création de la DA ---#
        GBIDD1=[F:PSD]QTYPUU/[F:PSD]QTYSTU
        [F:PSO]QTYPUU=[F:PSO]QTYSTU*GBIDD1
        Call QTEARR([F:PSO]QTYPUU,[F:PSO]PUU) From TRTDIV
        CLEFIC=[F:PSD]PSHNUM-num$([F:PSD]PSDLIN)-[F:POQ]POHNUM-
&              num$([F:POQ]POPLIN)-num$([F:POQ]POPLIN)
        WMSG=mess(13,100,1)-"PREQUISO"-CLEFIC : # Erreur d'écriture sur le fichier ...
        Write [PSO]
        If fstat GOK=0 : Call FSTA("PSO") From GLOCK : Break : Endif
        #----- Mise à jour ligne DA : Quantités commandées en UA et US -----#
        [F:PSD]ORDQTYPUU+=[F:PSO]QTYPUU
        [F:PSD]ORDQTYSTU+=[F:PSO]QTYSTU
        #----- Si ligne DA complètement commandée : Màj flags solde & cde -----#
        If [F:PSD]QTYSTU<=[F:PSD]ORDQTYSTU
          If [F:PSD]LINCLEFLG<>2 [F:PSD]LINCLEFLG=2
                                 [F:PSH]CLELINNBR+=1 : Endif
          If [F:PSD]LINORDFLG<>2 [F:PSD]LINORDFLG=2
                                 [F:PSH]ORDLINNBR+=1 : Endif
        Endif
        CLEFIC=[F:ORD]VCRNUM-num$([F:ORD]VCRLIN)
        WMSG=mess(13,100,1)-"PREQUISD"-CLEFIC : # Erreur d'écriture sur le fichier ...
        Rewrite [PSD]
        If fstat GOK=0 : Call FSTA("PSD") From GLOCK : Break : Endif
        Call TRTMAJCMM([F:PSD]PSHNUM,[F:PSD]PSDLIN,0,-1,1,"PSD3",2,GBIDI1) From TRTACHDIV1
        If GOK<1  Break : Endif
        #----- Mise à jour entête DA : Indicateurs commande et solde -----#
        If [F:PSH]LINNBR<=[F:PSH]ORDLINNBR [F:PSH]ORDFLG=2 : Endif
        If [F:PSH]LINNBR<=[F:PSH]CLELINNBR [F:PSH]CLEFLG=2 : Endif
        CLEFIC=[F:ORD]VCRNUM
        WMSG=mess(13,100,1)-"PREQUIS"-CLEFIC : # Erreur d'écriture sur le fichier ...
        Rewrite [PSH]
        If fstat GOK=0 : Call FSTA("PSH") From GLOCK : Break : Endif
        Unlock=SYMBOL4 : Raz SYMBOL4
      Endif
      #----- Mise à jour opération sous-traitance et SCF -----#
      If [F:ORD]WIPTYP=4 & [F:ORD]WIPSTA=1 & GMODU(8)=2
        [M:SBCK]MAJCOD = "C"
        [M:SBCK]WIPNUM = [F:ORD]WIPNUM
        [M:SBCK]ITMREF = [F:ORD]ITMREF
        [M:SBCK]VCRNUM = [F:POQ]POHNUM
        [M:SBCK]VCRLIN = [F:POQ]POPLIN
        [M:SBCK]VCRSEQ = [F:POQ]POQSEQ
        [M:SBCK]BPSNUM = [F:POQ]BPSNUM
        [M:SBCK]ORDQTY = [M:PMG]EXTSTUQTY(I)
        [M:SBCK]ORDDAT = [F:POQ]EXTRCPDAT-[F:POQ]OFS
        [M:SBCK]RCPDAT = [F:POQ]EXTRCPDAT
        Call CONVERT2([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                     [F:POQ]LINAMT,[M:SBCK]EXTPRI,STAT) From TRTDEV
        [M:SBCK]EXTPRI = arr([M:SBCK]EXTPRI/[M:PMG]EXTSTUQTY(I),10^-GDECPRI)
        [M:SBCK]OFS    = [F:POQ]OFS
        [M:SBCK]MSGFLG = 1                        # llc 03.01 (inutile après tout)
        [M:SBCK]CLEFLG = [F:POQ]LINCLEFLG         # 03.02 13517
        Call MAJ_SBC From SBCLIB
        If [M:SBCK]CODRET<>0
          WMSG=mess(96,193,1) : [M:PMG]ERRCOD=45 : GOK=0 : Break
        Endif
      Endif
      #----- Mise à jour des ordres TPS-TPP (Consommation) -----#
      If [M:PMG]WIPTYP(I)=7
        Read [ORD] ORD0=8;[M:PMG]WIPNUM(I);[M:PMG]ITMREF(I)
        If !fstat
          Gosub POINT_ORDLEC From TRTACHMGT1 : # Appel point d'entrée ORDLEC
          [M:ORDK]=[F:ORD]
          [M:ORDK]MAJCOD  = "M"
          [M:ORDK]WIPTYP  = 8
          [M:ORDK]WIPNUM  = [M:PMG]WIPNUM(I)
          [M:ORDK]ITMREF  = [M:PMG]ITMREF(I)
          [M:ORDK]EXTQTY -= [M:PMG]EXTSTUQTY(I)
          If left$([M:ORDK]ABBFIL,1)<>"P"  [M:ORDK]ABBFIL="PUR" : Endif
          Call WIP From TRTWIP
          If GOK<1
            WMSG ="8"
            WMSG-=[M:PMG]WIPNUM(I)-[M:PMG]ITMREF(I)-mess(92,197,1) : # Problème en maj encours
            [M:PMG]ERRCOD=7 : Break
          Endif
        Else
          Raz [F:ORD]
        Endif
      Endif
    Endif
    Raz WMSG
    #----- Indicateur ligne traitée et chargement No et ligne DL -----#
    [M:PMG]ERRLIN(I)=0
    [M:PMG]VCRNUM(I)=[F:POQ]POHNUM
    [M:PMG]VCRLIN(I)=[F:POQ]POPLIN
    [M:PMG]VCRSEQ(I)=[F:POQ]POQSEQ
$SUITE_CREATION
  Next I
  If GOK=-1 Goto ROLL_CREATION : Endif
  If GOK=0  Goto AB_CREATION   : Endif
  If [F:POQ]ITMREF<>""
    Gosub CREATION_LIGNE_POQ : Raz [F:POQ]
    If GMESSAGE<>""  Call ECR_TRACE(1) : Endif
    If GOK=-1 Goto ROLL_CREATION : Endif
    If GOK=0  Goto AB_CREATION   : Endif
    Gosub MAJ_ENTETE_POC : Raz [F:POC]
    If SYMBOL3<>""  Unlock=SYMBOL3 : Raz SYMBOL3 : Endif
    If GMESSAGE<>""  Call ECR_TRACE(1) : Endif
    If GOK=-1 Goto ROLL_CREATION : Endif
    If GOK=0  Goto AB_CREATION   : Endif
    Gosub MAJ_ENTETE_POH : Raz [F:POH]
    If SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
    If GMESSAGE<>""  Call ECR_TRACE(1) : Endif
    If GOK=-1 Goto ROLL_CREATION : Endif
    If GOK=0  Goto AB_CREATION   : Endif
  Endif
Commit
Return
$ROLL_CREATION
Rollback : Call ROLL From GLOCK
If GROLL
  Gosub AB_TRANSACTION_MSG
  Return
Else
  Goto TR_CREATION
Endif
$AB_CREATION
Rollback
Gosub AB_TRANSACTION_MSG
Return


#--------------------------------------#
# Création d'une ligne article contrat #
#--------------------------------------#
$CREATION_POC
Raz GMESSAGE
[M:PMG]ORIFCY(I)=[F:POH]STOFCY
#----- Contrôle de l'existence de l'article-vente -----#
Call CONTROLE("ITS","",[M:PMG]ITMREF(I),"",mkstat) From CONTOBJ
If mkstat Raz mkstat : Return : Endif
#----- Contrôle de l'existence de l'article-site d'expédition -----#
Look [ITF] ITF0=[M:PMG]ITMREF(I);[M:PMG]ORIFCY(I)
If fstat GMESSAGE=[M:PMG]ITMREF(I)-[M:PMG]ORIFCY(I)-mess(248,197,1) : Return : Endif
#----- Contrôle de l'existence de l'article-site de réception -----#
Look [ITF] ITF0=[M:PMG]ITMREF(I);[M:PMG]STOFCY(I)
If fstat GMESSAGE=[M:PMG]ITMREF(I)-[M:PMG]STOFCY(I)-mess(248,197,1) : Return : Endif
#----- Récupération du dernier numéro de ligne utilisé -----#
Filter [POC] Where POHNUM=WPOHNUM
Read [POC] POC0 Last
If fstat Raz [F:POC] : Endif
Filter [POC]
WPOPLIN=[F:POC]POPLIN+1
Raz [F:POC]
# Issue X3-55891 - 2018-09-28 by SR : Déclinaison par site
Raz [F:ITP], [F:ITPF]
[F:POC]POHNUM=[F:POH]POHNUM
[F:POC]CPY   =[F:POH]CPY
[F:POC]POPLIN=WPOPLIN
[F:POC]POHFCY=[F:POH]POHFCY
[F:POC]BPSNUM=[F:POH]BPSNUM
[F:POC]ITMREF=[M:PMG]ITMREF(I)
#----- Lecture si nécessaire du BPARTNER -----#
If [F:BPR]BPRNUM<>[F:POH]BPSNUM
  Read [BPR] BPR0=[F:POH]BPSNUM
  If fstat  Raz [F:BPR] : [F:BPR]LAN=GLANGUE : Endif
Endif
#----- Lecture si nécessaire de l'article ITMMASTER -----#
If [F:ITM]ITMREF<>[M:PMG]ITMREF(I)
  Read [ITM] ITM0=[M:PMG]ITMREF(I)
  If fstat : # XXXXXXXXXXXXXXX Code article inexistant
    Raz [F:ITM] : GMESSAGE=[M:PMG]ITMREF(I)-":"-mess(134,100,1) : Return
  Endif
Endif
#----- Chargement des désignations article -----#
#Call CHARGE_ITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,[F:POC]ITMDES) From TRTX3
#If [F:POC]ITMDES="" [F:POC]ITMDES=[F:ITM]ITMDES1 : Endif
Call CHARGE_DEFITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,[F:POC]ITMDES, "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
#[F:POC]ITMDES1=[F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[F:POC]ITMDES1, "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
#----- Récupération de la référence article chez le fournisseur -----#
If [F:ITP]ITMREF<>[M:PMG]ITMREF(I) | [F:ITP]BPSNUM<>[F:POH]BPSNUM
  Read [ITP] ITP0=[M:PMG]ITMREF(I);[F:POH]BPSNUM
  If fstat Raz [F:ITP] : Endif
Endif
[F:POC]ITMREFBPS=[F:ITP]ITMREFBPS
[F:POC]STRDAT=[F:POH]STRDAT
[F:POC]ENDDAT=[F:POH]ENDDAT
#----- Lecture si nécessaire du BPSUPPLIER -----#
If [F:BPS]BPSNUM<>[F:POH]BPSNUM
  Read [BPS] BPS0=[F:POH]BPSNUM
  If fstat
    Raz [F:BPS] : GMESSAGE=[F:POH]BPSNUM-":"-mess(136,100,1) : Return
  Endif
Endif
#----- Test si dépassement nombre de ligne maximum -----#
If ([F:BPS]SEVLIN=1 & [F:POH]LINNBR>0) | [F:POH]LINNBR>=MAXLIGNE
  GMESSAGE=mess(252,197,1) : Return : # Nombre maximum de ligne par commande atteint !
Endif
#----- Chargement des informations douanières -----#
[F:POC]EECICT2= [F:BPS]EECICT : # Incoterm
If GACTDEB=2
  If [F:BPR2]BPRNUM<>[F:BPS]BPSINV
    Read [BPR2] BPR0=[F:BPS]BPSINV : If fstat  Raz [F:BPR2] : Endif
  Endif
  [F:POC]EECNUM2=[F:BPR2]EECNUM : # Identification CEE
  [F:POC]EECLOC2=[F:BPS]EECLOC  : # Lieu de transport CEE
Endif
#----- Récupération du 1er code tarif actif et de type normal -----#
Filter [PPC] Where PLISTC=[F:BPS]PLISTC & PLIENAFLG=2 & PLITYP=1
Read [PPC] PPC1 First : If fstat Raz [F:PPC] : Endif
Filter [PPC]
[F:POC]PLI=[F:PPC]PLI
#----- Chargement des horizons -----#
[F:POC]FRTHOR=[F:ITM]FRTHOR
[F:POC]FRTHORUOM=[F:ITM]FRTHORUOM
[F:POC]FIMHOR=[F:ITM]FIMHOR
Case [F:ITM]FIMHORUOM
  When 2 : [F:POC]FIMHOR=7*int([F:ITM]FIMHOR/5)+mod([F:ITM]FIMHOR,5)
  When 3 : [F:POC]FIMHOR*=7
  When 4 : [F:POC]FIMHOR*=14
  When 5 : [F:POC]FIMHOR*=30
Endcase
#-----
[F:POC]PRHFCY=[M:PMG]STOFCY(I)
[F:POC]STOFCY=[M:PMG]ORIFCY(I)
[F:POC]USEPLC=[M:PMG]USEPLC
#----- Chargement adresse de réception par défaut -----#
If [F:FCY]FCY<>[F:POC]PRHFCY
  Read [FCY] FCY0=[F:POC]PRHFCY : If fstat Raz [F:FCY] : Endif
Endif
[F:POC]FCYADD=[F:FCY]BPAADD
#----- Chargement unité d'achat qui doit également être une unité de vente -----#
If [F:ITP]PUU<>"" [F:POC]PUU=[F:ITP]PUU Else [F:POC]PUU=[F:ITM]PUU : Endif
If GMODU(5)=2
  Call CONTSAUIMP([F:ITP]PUU,[M:PMG]ITMREF(I),WBPCNUM,UNIVEN) From TRTVENCTL
  If UNIVEN=""
    Call CONTSAUIMP([F:ITM]PUU,[M:PMG]ITMREF(I),WBPCNUM,UNIVEN) From TRTVENCTL
    If UNIVEN=""
      GMESSAGE=[F:ITM]PUU-mess(242,197,1) : Return
    Endif
  Endif
  [F:POC]PUU=UNIVEN
Endif
#-----
[F:POC]STU=[M:PMG]STU(I)
[F:POC]BETFCY=2
#----- Chargement comptes et type d'achat -----#
For J=1 To 10
  [F:POC]COA(J-1)=GCOA(J)
Next J
#-----
[F:TB0]=[F:POH]
[F:TB1]=[F:POH]
[F:TB1]=[F:POC]
[F:TB1]LINPURTYP=max([F:POC]LINPURTYP,1)
#----- Chargement table liée PORDERP pour la pièce auto PORD -----#
Raz [F:POP]
[F:POP]=[F:POH]
[F:POP]=[F:POC]
Call ALIVATCOD(2,[F:POH]BPSNUM,[F:ITM]ITMREF,"POP",0) From TRTX3
#----- Chargement pseudo fichier lignes comptables CPTANALIN [TB2] -----#
Raz [F:TB2]
[F:TB2]ABRFIC="POP"
[F:TB2]VCRNUM=[F:POH]POHNUM
[F:TB2]VCRLIN=[F:POC]POPLIN
[F:TB2]ANALIG=1
# Issue X3-61613 - 2017-10-27 by SR : Ne pas utiliser I afin de ne pas casser l'indice du besoin en cours de traitement
For WI=1 To max(GNBCOA,2)
  [F:TB2]LED(WI-1)=GLEDSOC(WI)
  [F:TB2]COA(WI-1)=GCOA(WI)
  [F:TB2]ACC(WI-1)=[F:POC]LINACC(WI-1)
Next WI
For WI=1 To max(GNBDIE,GOPTCANA)
  [F:TB2]DIE(WI-1)=GDIE(WI)
Next WI
#-----
Raz ID1,ID2
Call COMPTE("PORD",1,ID1,ID2,TPLAN,TCOMPTE,STAT,WMSG) From TRTACHCDE1
If STAT
  Raz TPLAN, TCOMPTE
Else
  For J=1 To 10
    If TPLAN(J)<>""
     #K=find(TPLAN(J),[F:POC]COA(0..9))
      K=find([F:GAD]LEDTYP(J-1),GTYPLED(1..GNBTYPLED))
      If K  [F:POC]LINACC(K-1)=TCOMPTE(J) : Endif
    Endif
  Next J
Endif
#----- Récupération compte général pour init type d'achat -----#
Call LECPLAN(GSOCIETE,GTYPGEN,GBIDC2) From CPTDIV
K=find(GBIDC2,[F:POC]COA(0..9))
If K
  If [F:GAC]COA<>GBIDC2 | [F:GAC]ACC<>[F:POC]LINACC(K-1)
    Read [GAC] GAC0=GBIDC2;[F:POC]LINACC(K-1) : If fstat  Raz [F:GAC] : Endif
  Endif
  If [F:GAC]VATIPT=5
    [F:POC]LINPURTYP=3
  Elsif [F:GAC]VATIPT=4
    [F:POC]LINPURTYP=2
  Else
    [F:POC]LINPURTYP=1
  Endif
Else
  [F:POC]LINPURTYP=1
Endif

#----- Récupération prix de valorisation -----#
If [F:POC]PLI<>""
  [F:POH]TOTVLT-=[F:POC]AMTVLT
  GPUU=[F:POC]PUU : Call RECH_TARIF ("PMG",0) From TRTACHTAR1
  [F:POC]AMTVLT=[F:POC]EXTQTYPUU*[F:POC]PRIVLT
  Call ARRDEV([F:POC]AMTVLT,[F:POH]CUR) From TRTDIV
  [F:POH]TOTVLT+=[F:POC]AMTVLT
Endif
#-----
[F:POC]CREUSR=GUSER
[F:POC]CREDAT=date$
#----- Reprise du texte article si nécessaire -----#
If [F:ITP]TEX<>""
  [F:POC]TEX=[F:ITP]TEX
Else
  [F:POC]TEX=[F:ITM]PURTEX
Endif
#-----
CLEFIC=[F:POC]POHNUM-num$([F:POC]POPLIN)
WMSG=mess(13,100,1)-"PORDERC"-CLEFIC : # Erreur d'écriture sur le fichier ...
Write [POC]
If fstat GOK=0 : Call FSTA("POC") From GLOCK : Return : Endif
Raz WMSG
#----- Message : Ligne contrat XXXXXXXXXXXXXXX 99999999 créée ! -----#
GMESSAGE=mess(243,197,1)-CLEFIC-mess(224,197,1) : Call ECR_TRACE(0) : Raz GMESSAGE
WLINNBR+=1
#----- Appel du S/P ventes pour création de la ligne article contrat (SORDERC) -----#
If [F:POH]SALFCY<>""
  Raz [M:SORW]
  [M:SORW]MAJCOD    = "C"
  [M:SORW]SOHNUM    = [F:POH]OCNNUM
  [M:SORW]STOFCY    = [M:PMG]ORIFCY(I)
  [M:SORW]SOPLIN    = [F:POC]POPLIN
  [M:SORW]ITMREF    = [F:POC]ITMREF
  [M:SORW]VLYDATITM = [F:POC]ENDDAT
  [M:SORW]EXTQTY    = [F:POC]EXTQTYPUU
  [M:SORW]SAU       = [F:POC]PUU
  [M:SORW]USEPLC    = [F:POC]USEPLC
  [M:SORW]BPCORD    = [F:POH]BPCORD
  [M:SORW]PRHFCY    = [F:POC]PRHFCY
  # 95742 : PJT en inter société/inter site : (LD:21/04/16)
  # Le PJT transite uniquement en intersite
  If [F:POH]BETCPY=1
      [M:SORW]PJT=[F:POC]PJT
  Endif
  # 95742 : PJT en inter société/inter site : (LD:21/04/16)
  Call MAJ_SOC From TRTVENMSIT
  If GOK<1 WMSG=GMESSAGE : [M:PMG]ERRCOD=14 : Raz GMESSAGE : Return : Endif
Endif
Gosub MAJ_ENTETE_POH
Return


#----------------------------#
# Création d'une ligne de DL #
#----------------------------#
$CREATION_LIGNE_POQ
#------ Lecture si nécessaire de l'ITMMASTER, ITMFACILIT et ITMBPS -----#
If [F:ITM]ITMREF<>[F:POQ]ITMREF
  Read [ITM] ITM0=[F:POQ]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITF]ITMREF<>[F:POQ]ITMREF | [F:ITF]STOFCY<>[F:POQ]PRHFCY
  Read [ITF] ITF0=[F:POQ]ITMREF;[F:POQ]PRHFCY
  If fstat
    Raz [F:ITF] : [F:ITF]OFS=[F:ITM]OFS : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD
  Endif
Endif
# Issue X3-55891 - 2018-09-28 by SR : Déclinaison par site
#If [F:ITP]ITMREF<>[F:POQ]ITMREF | [F:ITP]BPSNUM<>[F:POQ]BPSNUM
#  Read [ITP] ITP0=[F:POQ]ITMREF;[F:POQ]BPSNUM
#  If fstat
#    Raz [F:ITP] : [F:ITP]PUU=[F:ITM]PUU
#  Elsif [F:ITP]DOUFLG=2
#    GMESSAGE=[F:POQ]ITMREF-[F:POQ]BPSNUM-mess(8,194,1) : Call ECR_TRACE(0)
#    Raz GMESSAGE
#  Endif
#Endif
Raz WRETOUR, WITMBPS
# Intersite
If [F:POH]BETFCY = 2 & [F:POH]BETCPY <> 2
  Call CTRL_DOUFLG(2,[F:POQ]ITMREF,[F:POH]BPSNUM,[F:POQ]PRHFCY,WITMBPS,WRETOUR) From TRTACHCTL1
Else
  Call CTRL_DOUFLG(1,[F:POQ]ITMREF,[F:POH]BPSNUM,[F:POQ]PRHFCY,WITMBPS,WRETOUR) From TRTACHCTL1
Endif
If WRETOUR <> 0
     GOK = 0
     If WRETOUR =1 : [M:PMG]ERRCOD=32
     Else          : [M:PMG]ERRCOD=28
     Endif
     Return
Endif
# End issue X3-55891
#----- Lecture si nécessaire du BPARTNER -----#
If [F:BPR]BPRNUM<>[F:POQ]BPSNUM
  Read [BPR] BPR0=[F:POQ]BPSNUM
  If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
Endif
#----- Lecture si nécessaire du BPSUPPLIER -----#
If [F:BPS]BPSNUM<>[F:POQ]BPSNUM
  Read [BPS] BPS0=[F:POQ]BPSNUM
  If fstat Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
Endif
#----- Chargement des paramètres de la gestion tarif -----#
If GPLISTC<>[F:BPS]PLISTC
  GPLISTC=[F:BPS]PLISTC
  Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
  Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
  Call TARIFCHGT(6)                From TRTPRICE
Endif
#----- Chargement du site d'expédition -----#
If [F:POH]BETFCY=2
  If [F:POH]BETCPY=2
    [F:POQ]LINSTOFCY=[F:POH]STOFCY : # Inter-sociétés
  Else
    [F:POQ]LINSTOFCY=[F:POC]STOFCY : # Inter-sites, intra-société
  Endif
Endif
#----- Calcul qté commandée en UA -----#
Call PCAL_QTY([F:POQ]QTYSTU,[F:POQ]STU,[F:POQ]QTYPUU,[F:POQ]PUU,
&             [F:POQ]ITMREF,[F:POQ]BPSNUM,3,GBIDD1) From TRTACHQTE1
QTEUA=[F:POQ]QTYSTU*GBIDD1
#----- Appel au point d'entrée permettant de choisir l'arrondi de la qté UA -----#
SAV_QTEUA=QTEUA
Gosub POINT_PURQTYRND From SUBPOHB
[F:POQ]QTYPUU=QTEUA
#----- Recalcul quantité US après arrondi éventuel de l'UA -----#
Call PCAL_QTY([F:POQ]QTYPUU,[F:POQ]PUU,[F:POQ]QTYSTU,[F:POQ]STU,
&             [F:POQ]ITMREF,[F:POQ]BPSNUM,1,GBIDD1) From TRTACHQTE1
#----- Si qté US inférieure au besoin pris en compte, ajuster qtés à la hausse -----#
If [F:POQ]QTYSTU<[F:POQ]RETQTYSTU
  QTEARR=arr(SAV_QTEUA,10^-WNBDEC)
  If QTEARR>=SAV_QTEUA-10^-(WNBDEC+3)
    [F:POQ]QTYPUU=QTEARR
  Else
    [F:POQ]QTYPUU=QTEARR+10^-WNBDEC
  Endif
  Call PCAL_QTY([F:POQ]QTYPUU,[F:POQ]PUU,[F:POQ]QTYSTU,[F:POQ]STU,
&               [F:POQ]ITMREF,[F:POQ]BPSNUM,1,GBIDD1) From TRTACHQTE1
Endif
#-----
[F:POQ]QTYUOM   =[F:POQ]QTYPUU
[F:POQ]OFS      =[F:ITF]OFS
# Issue X3-43057 - 2017-06-26 by MUARN : landed cost / services
[F:POQ]NETCUR = [F:POH]CUR
[F:POQ]CPRCOE = 1
[F:POQ]CPRAMT = 0
Raz [F:POQ]STCNUM
[F:POQ]CPRCUR = GLOCALDEV
[F:POQ]ITMKND = 1
If [F:ITM]SCSFLG = 2 : [F:POQ]ITMKND = 3 : Endif
# Issue X3-105399 - 2018-08-24 by SR : Initialiser les données Landed Costs
Call RECH_COST([F:POQ]PRHFCY,[F:POQ]BPSNUM, [F:POQ]ITMREF, [F:POQ]CPRCOE, WCPRAMT, [F:POQ]STCNUM) From STCLIB
If GLOCALDEV <> GSYSCUR
   Call CONVERT2(GSYSCUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                WCPRAMT,WCPRAMTDEV,STAT) From TRTDEV
   [F:POQ]CPRAMT=arr(WCPRAMTDEV,10^-GDECPRI)
Else
   [F:POQ]CPRAMT = WCPRAMT
Endif
If [F:POQ]CPRCOE=0 [F:POQ]CPRCOE=1 Endif
# End issue X3-105399
#----- Calcul qté besoins pris en UA -----#
If [M:PMG]MAJCOD="C"
  Call PCAL_QTY([F:POQ]RETQTYSTU,[F:POQ]STU,[F:POQ]RETQTYPUU,[F:POQ]PUU,
&               [F:POQ]ITMREF,[F:POQ]BPSNUM,1,GBIDD1) From TRTACHQTE1
Endif
#----- Màj du fichier lien commande-demande avec nouvelle référence commande -----#
Update [PSO] Where POHNUM="TRTACHPOD1" & POPLIN=adxuid(1)    & POQSEQ=max(I-1,I_DEPART)
&            With  POHNUM=[F:POQ]POHNUM, POPLIN=[F:POQ]POPLIN, POQSEQ=[F:POQ]POQSEQ
If fstat=1
  GLOCK="$PREQUISO"-"TRTACHPOD1"-num$(adxuid(1))-num$(max(I-1,I_DEPART))
  GOK=-1 : WMSG=mess(356,197,1) : [M:PMG]ERRCOD=46 : Return
Elsif fstat
  Call RSTA("PSO","TRTACHPOD1"-num$(adxuid(1))-num$(max(I-1,I_DEPART))) From GLOCK
  GOK=0  : WMSG=mess(356,197,1) : [M:PMG]ERRCOD=46 : Return
Endif
#---------------------------------------------------------------------#
# Appel du S/P ventes pour création de la ligne quantité (SORDERQ) et #
# récupération du numéro de séquence ventes pour maj dans le PORDERQ  #
#---------------------------------------------------------------------#
If [F:POH]SALFCY<>""
  Raz [M:SORW]
  [M:SORW]MAJCOD    = "C"
  [M:SORW]SOHNUM    = [F:POH]OCNNUM
  [M:SORW]SALFCY    = [F:POH]SALFCY
  [M:SORW]BPCORD    = [F:POH]BPCORD
  [M:SORW]STOFCY    = [F:POQ]LINSTOFCY
  [M:SORW]PRHFCY    = [F:POQ]PRHFCY
  [M:SORW]VLYDATCON = [F:POH]ENDDAT
  [M:SORW]POHNUM    = [F:POH]POHNUM
  [M:SORW]SOPLIN    = [F:POC]POPLIN
  [M:SORW]ITMREF    = [F:POC]ITMREF
  [M:SORW]VLYDATITM = [F:POC]ENDDAT
  [M:SORW]EXTQTY    = [F:POC]EXTQTYPUU
  [M:SORW]SAU       = [F:POC]PUU
  [M:SORW]POPLIN    = [F:POC]POPLIN
  [M:SORW]DEMDLVDAT = [F:POQ]DEMRCPDAT
  [M:SORW]QTY       = [F:POQ]QTYPUU
  [M:SORW]DEMSTA    = [F:POQ]WIPSTA
  [M:SORW]USEPLC    = [F:POQ]USEPLC
  [M:SORW]CAD       = [F:POQ]CAD
  If [F:POQ]CAD=1
    [M:SORW]DLVDAY  = val(left$(num$([F:POQ]DEMRCPDAT),2))
    [M:SORW]MON     = [F:POQ]MON
    [M:SORW]YEA     = [F:POQ]YEA
  Elsif [F:POQ]CAD=2
    [M:SORW]WEE     = [F:POQ]WEE
    [M:SORW]YEA     = [F:POQ]YEA
  Else
    [M:SORW]MON     = [F:POQ]MON
    [M:SORW]YEA     = [F:POQ]YEA
  Endif
  [M:SORW]POQSEQ    = [F:POQ]POQSEQ
  [M:SORW]SOQSTA    = [F:POQ]LINSTA
  # 95742 : PJT en inter société/inter site : (LD:21/04/16)
  # Le PJT transite uniquement en intersite
  If [F:POH]BETCPY=1
      [M:SORW]PJT=[F:POC]PJT
  Endif
  # 95742 : PJT en inter société/inter site : (LD:21/04/16)
  Call MAJ_SOQ From TRTVENMSIT
  If GOK<1 : WMSG=GMESSAGE : [M:PMG]ERRCOD=15 : Raz GMESSAGE : Return : Endif
  [F:POQ]LINOCNNUM=[F:POH]OCNNUM
  [F:POQ]OCNLIN=[M:SORW]SOPLIN
  [F:POQ]OCNSEQ=[M:SORW]SOQSEQ
Endif
#----- Création de l'encours "TRP" "TRF" "POP" ou "POF" -----#
If [F:ITF]STOMGTCOD>1
  Call NUMERO(GWIP,[F:POQ]PRHFCY,date$,"",[F:POQ]WIPNUM,RETOUR) From SUBANM
  If GOK<0
    WMSG=GWIP-mess(60,199,1) : [M:PMG]ERRCOD=6 : Return
  Elsif GOK<1 | RETOUR<>0
    WMSG=GWIP-mess(60,199,1) : [M:PMG]ERRCOD=6 : GOK=0 : Return
  Endif
  [M:ORDK]MAJCOD    = "C"
  [M:ORDK]WIPTYP    = [F:POQ]WIPTYP
  [M:ORDK]WIPSTA    = [F:POQ]WIPSTA
  [M:ORDK]WIPNUM    = [F:POQ]WIPNUM
  [M:ORDK]ITMREF    = [F:POQ]ITMREF
  If [F:POQ]WIPTYP=7
    [M:ORDK]ORIFCY  = [F:POQ]LINSTOFCY
  Else
    [M:ORDK]ORIFCY  = [F:POQ]POHFCY
  Endif
  [M:ORDK]STOFCY    = [F:POQ]PRHFCY
  # Issue 71069 - 2016-06-14 by SR : PJT
  #[M:ORDK]PJT       = ""
  [M:ORDK]PJT       = [F:POC]PJT
  [M:ORDK]BPRNUM    = [F:POQ]BPSNUM
  [M:ORDK]STRDAT    = [F:POQ]DEMRCPDAT
  [M:ORDK]ENDDAT    = [F:POQ]DEMENDDAT
  [M:ORDK]VCRTYP    = 14
  [M:ORDK]VCRNUM    = [F:POQ]POHNUM
  [M:ORDK]VCRLIN    = [F:POQ]POPLIN
  [M:ORDK]VCRSEQ    = [F:POQ]POQSEQ
  [M:ORDK]EXTQTY    = [F:POQ]QTYSTU
  [M:ORDK]CPLQTY    = 0
  [M:ORDK]ALLQTY    = 0
  [M:ORDK]SHTQTY    = 0
  [M:ORDK]FMI       = 1
  [M:ORDK]MRPMES    = 1
  # Issue 71276 - 2015-02-27 by SR : Versions
  If dim([M:ORDK]ECCVALMAJ)> 0
    [M:ORDK]ECCVALMAJ = [F:POQ]ECCVALMAJ
    [M:ORDK]ECCVALMIN = [F:POQ]ECCVALMIN
  Endif
  # End issue 71276
  If [F:POQ]WIPTYP=7
    If I-1<[M:PMG]NBLIG & I-1>=0 & WVCRNUMORI(I-1)<>""
      [M:ORDK]VCRTYPORI = WVCRTYPORI(I-1)
      [M:ORDK]VCRNUMORI = WVCRNUMORI(I-1)
      [M:ORDK]VCRLINORI = WVCRLINORI(I-1)
      [M:ORDK]VCRSEQORI = WVCRSEQORI(I-1)
    Else
      [M:ORDK]VCRTYPORI = 2
      If [F:POH]SALFCY<>""
        [M:ORDK]VCRNUMORI = [F:POQ]LINOCNNUM
        [M:ORDK]VCRLINORI = [F:POQ]OCNLIN
        [M:ORDK]VCRSEQORI = [F:POQ]OCNSEQ
      Else
        [M:ORDK]VCRNUMORI = ""
        [M:ORDK]VCRLINORI = 0
        [M:ORDK]VCRSEQORI = 0
      Endif
    Endif
  Else
    [M:ORDK]VCRTYPORI = 0
    [M:ORDK]VCRNUMORI = ""
    [M:ORDK]VCRLINORI = 0
    [M:ORDK]VCRSEQORI = 0
  Endif
  [M:ORDK]BOMALT    = 0
  [M:ORDK]ORI       = 1
  [M:ORDK]ABBFIL    = "POC"
  Call WIP From TRTWIP
  If GOK<1
    WMSG="2"-[F:POQ]WIPNUM-[F:POQ]ITMREF-mess(92,197,1) : # Problème en maj des encours
    [M:PMG]ERRCOD=7 : Return
  Endif

  # V6 Affectations
  If [F:POQ]WIPSTA = 1 : Gosub MAJ_MTO_POQ  From PURMTOLIB : Endif

Endif
#-----
[F:POQ]CMMTAX=max(GPURCMMTAX,1) : # Indicateur Type d'engagement
#----- Si demande ferme et non soldée -----#
If [F:POQ]WIPSTA=1 & [F:POQ]LINSTA<>3
  #----- Mise qté cdée article-site, budget et montants HT et TTC ligne -----#
  PRIFLG=2 : SIGN=+1 : Gosub MAJ_ITV_BUDGET
  If GOK<1 Return : Endif
Endif
#----- Ecriture ligne DL -----#
CLEFIC=[F:POQ]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)
WMSG=mess(13,100,1)-"PORDERQ"-CLEFIC : # Erreur d'écriture sur le fichier ...
[F:POQ]POQLNK=mid$("00000000",1,8-len(num$([F:POQ]POPLIN)))+num$([F:POQ]POPLIN)
&            +mid$("00000000",1,8-len(num$([F:POQ]POQSEQ)))+num$([F:POQ]POQSEQ)
If [F:ITP]ITMREF<>[F:POQ]ITMREF | [F:ITP]BPSNUM<>[F:POQ]BPSNUM
  Read [ITP] ITP0=[F:POQ]ITMREF;[F:POQ]BPSNUM : If fstat Raz [F:ITP] : Endif
Endif
[F:POQ]ITMREFBPS=[F:ITP]ITMREFBPS
[F:POQ]LINTYP=1 : # Ligne classique (indépendante)
#--------------------------------------------------------------#
# Point d'entrée MAJDL pour alimentation de zones spécifiques  #
# ------------------------------------------------------------ #
# Variables utilisables par le point d'entrée                  #
#                                                              #
# TYPMAJ  : Type de mise à jour (1 = création DL)              #
# FICHIER : Nom de la table qui va être écrite "PORDERQ"       #
# ABRFIC  : Abréviation de la table qui va être écrite "POQ"   #
# La  classe  [F:POQ] est modifiable avant le Write ou Rewrite #
#--------------------------------------------------------------#
TYPMAJ=1 : Gosub POINT_MAJDL From TRTACHPOD1
#-----
Write [POQ]
If fstat GOK=0 : Call FSTA("POQ") From GLOCK : Return : Endif
Raz WMSG
#----- Message : Demande de livraison XXXXXXXXXXXXXXX 9999999 9999999 créée ! -----#
GMESSAGE=mess(244,197,1)-CLEFIC-mess(224,197,1) : Call ECR_TRACE(0) : Raz GMESSAGE
#----- Mise à jour qtés cdées et avance-retard pour ligne article contrat -----#
If [F:POQ]WIPSTA=1
  WORDQTYPUU+=[F:POQ]QTYPUU
  If [F:POQ]LINSTA=2
    WEARQTY+=[F:POQ]QTYPUU
  Endif
Endif
#----- Màj cumul montants pour entête commande -----#
WTOTORD+=[F:POQ]LINAMT
WTTVORD+=[F:POQ]LINATIAMT
Return


#---------------------------------------------------------------#
# Mise à jour qté cdée article-site et budget (engagement)      #
#             uniquement si ligne DL ferme et non soldée        #
# ------------------------------------------------------------- #
# SIGN   : Sens de la mise à jour (+1 ou -1)                    #
# PRIFLG : 0 = [F:POP] chargé  et pas de calcul montants        #
#          1 = Lecture [F:POP] et pas de calcul montants        #
#          2 = Calcul montants avec lecture ou création [F:POP] #
#              + màj montants HT et TTC ligne DL                #
#---------------------------------------------------------------#
$MAJ_ITV_BUDGET
If PRIFLG=2 & ([F:POH]BETFCY<>2 | [F:POH]BETCPY=2)
  Gosub CALPOD From SUBPODA
  If GOK<1 : # Erreur à la valorisation de la ligne !
    WMSG=[F:POQ]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)-mess(355,197,1)
    [M:PMG]ERRCOD=41 : Return
  Endif
Endif
#----- Màj quantité commandée dans l'article-site si article géré en stock -----#
If [F:POQ]WIPNUM<>""
  Call LECITV([F:POQ]PRHFCY,[F:POQ]ITMREF,"",RETOUR) From STKLIB
  If GOK<1
    WMSG=[F:POQ]PRHFCY-[F:POQ]ITMREF-mess(247,197,1) : # Problème lecture article-site
    [M:PMG]ERRCOD=8 : Return
  Endif
  If RETOUR>2 Infbox "ERREUR LECTIV : Site ou article non renseigné !" : Endif
  If RETOUR<2
    [F:ITV]ORDSTO+=([F:POQ]QTYSTU*SIGN)
    CLEFIC=[F:ITV]ITMREF-[F:ITV]STOFCY
    WMSG=mess(13,100,1)-"ITMMVT"-CLEFIC : # Erreur d'écriture sur le fichier ...
    Rewrite [ITV]
    If fstat GOK=0 : Call FSTA("ITV") From GLOCK : Return : Endif
  Endif
Endif
#----- Màj budget (engagement) si présence module comptabilité -----#
If GMODU(2)=2 & ([F:POH]BETFCY<>2 | [F:POH]BETCPY=2)
  If PRIFLG=1
    Filter [POP] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN &
&                      POPDAT>=[F:POQ]DEMRCPDAT
    Read [POP] POP1 First
    If fstat : Raz [F:POP] : Endif
    Filter [POP]
  Endif
  If [M:PMG]MAJCOD="C" | [M:PMG]MAJCOD="A"
    GBIDC2="POQ"  : # Création ou suppression ligne commande (DL)
  Elsif [M:PMG]MAJCOD="S"
    GBIDC2="POQ2" : # Solde ligne de commande (DL)
  Else
    GBIDC2="POQ1" : # Modification ligne commande (DL)
  Endif
  Call TRTMAJCMM([F:POQ]POHNUM,[F:POQ]POPLIN,[F:POQ]POQSEQ,SIGN,2,GBIDC2,2,GBIDI1) From TRTACHDIV1
  If GOK<1
    WMSG=GMESSAGE : Raz GMESSAGE : # Erreur budget
    [M:PMG]ERRCOD=42 : Return
  Endif
Endif
Raz WMSG
Return


#-------------------------------------#
# Mise à jour de l'entête de commande #
#-------------------------------------#
$MAJ_ENTETE_POH
#----- Lecture avec blocage physique de la ligne article contrat -----#
CLEFIC=[F:POH]POHNUM
WMSG=mess(12,100,1)-"PORDER"-CLEFIC : # Erreur d'accès sur le fichier ...
Readlock [POH] POH0=CLEFIC
If fstat=1
  GOK=-1 : GLOCK="$PORDER"-CLEFIC : Return
Elsif fstat
  GOK=0 : Call RSTA("POH",CLEFIC) From GLOCK : Return
Endif
#----- Mise à jour nombre de ligne -----#
[F:POH]LINNBR=WLINNBR
#----- Mise à jour de l'en commande dans mvts fournisseurs -----#
If [F:POH]BETFCY<>2 | [F:POH]BETCPY=2
  GBIDD1=WTOTORD-[F:POH]TOTORD
  GBIDD2=WTTVORD-[F:POH]TTVORD
  Call MAJENC_BPS([F:POH]BPSNUM,3,[F:POH]POHFCY,[F:POH]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                 [F:POH]POHNUM,GBIDD1,GBIDD2,WTTVORD) From TRTBPMVT
  If GOK<1 WMSG=[F:POH]BPSNUM-GFINRSP-mess(95,197,1) : Return : Endif
Endif
#----- Mise à jour des indicateurs soldée, réceptionnée, facturée -----#
If [F:POH]RCPNBR=0    [F:POH]RCPFLG=1 Else [F:POH]RCPFLG=2 : Endif
If [F:POH]INVNBR=0    [F:POH]INVFLG=1 Else [F:POH]INVFLG=2 : Endif
If [F:POH]CLELINNBR=0 [F:POH]CLEFLG=1 : Endif
If [F:POH]POHTYP<>2
  #----- Si commande classique -----#
  If [F:POH]CLELINNBR>=[F:POH]LINNBR [F:POH]CLEFLG=2 Else [F:POH]CLEFLG=1 : Endif
  If [F:POH]RCPLINNBR>=[F:POH]LINNBR [F:POH]RCPFLG=3 : Endif
  If [F:POH]INVLINNBR>=[F:POH]LINNBR [F:POH]INVFLG=3 : Endif
Endif
#----- Mise à jour total HT et TTC commande -----#
If [F:POH]BETFCY<>2 | [F:POH]BETCPY=2
  [F:POH]TOTORD=WTOTORD
  [F:POH]TTVORD=WTTVORD
Endif
#----- Mise a jour date et opérateur dernière modification -----#
[F:POH]UPDUSR=GUSER
[F:POH]UPDDAT=date$
#----- Ecriture entête contrat -----#
WMSG=mess(13,100,1)-"PORDER"-CLEFIC : # Erreur d'écriture sur le fichier ...
Rewrite [POH]
If fstat GOK=0 : Call FSTA("POH") From GLOCK : Return : Endif
Raz WMSG
#----- Message : Commande XXXXXXXXXXXXXXX modifiée ! -----#
GMESSAGE=mess(98,197,1)-[F:POH]POHNUM-mess(223,197,1) : Call ECR_TRACE(0) : Raz GMESSAGE
#----- Déblocage logique de l'entête de commande -----#
If SYMBOL2>"" Unlock=SYMBOL2: Raz SYMBOL2: Endif
Return


#------------------------------------------#
# Mise à jour entête ligne article contrat #
#------------------------------------------#
$MAJ_ENTETE_POC
#----- Lecture avec blocage physique de la ligne article contrat -----#
CLEFIC=[F:POC]POHNUM-num$([F:POC]POPLIN)
WMSG=mess(12,100,1)-"PORDERC"-CLEFIC : # Erreur d'accès sur le fichier ...
Readlock [POC] Curr
If fstat=1
  GOK=-1 : GLOCK="$PORDERC"-CLEFIC : Return
Elsif fstat
  GOK=0  : Call RSTA("POC",CLEFIC) From GLOCK : Return
Endif
#----- Mise à jour qtés commandées UA US et avance-retard -----#
[F:POC]ORDQTYPUU=WORDQTYPUU
Call PCAL_QTY(WORDQTYPUU,[F:POC]PUU,[F:POC]ORDQTYSTU,[F:POC]STU,
&             [F:POC]ITMREF,[F:POC]BPSNUM,1,GBIDD1) From TRTACHQTE1
[F:POC]EARQTY   =WEARQTY
[F:POC]EARDAT   =date$
[F:POC]DLVREQNUM+=1
#----- Mise a jour date et opérateur dernière modification -----#
[F:POC]UPDUSR=GUSER
[F:POC]UPDDAT=date$
#----- Réécriture de la ligne article contrat -----#
WMSG=mess(13,100,1)-"PORDERC"-CLEFIC : # Erreur d'écriture sur le fichier ...
Rewrite [POC]
If fstat GOK=0  : Call FSTA("POC") From GLOCK : Return : Endif
Raz WMSG
#----- Message : Ligne contrat XXXXXXXXXXXXXXX 99999999 modifiée ! -----#
GMESSAGE=mess(243,197,1)-CLEFIC-mess(223,197,1) : Call ECR_TRACE(0) : Raz GMESSAGE
#----- Déblocage logique de la ligne article contrat -----#
If SYMBOL3<>"" Unlock=SYMBOL3 : Raz SYMBOL3 : Endif
Return


#########################################################################
# Modification d'une demande de livraison à partir d'une "POP" ou "POF" #
#########################################################################
$MODIFICATION_POD1
#----- Traitement période de réception prévue uniquement si zone renseignée -----#
If [M:PMG]WRCPDAT<>""
  Gosub CTL_PERIODE : # Contrôle et chargement des zones date
  If mkstat Call ECR_TRACE(1) : mkstat=0 : Return : Endif
Endif
I=I_DEPART : Gosub CONTROLE : If [M:PMG]ERRCOD<>0 Return : Endif
Call CONTROLE_ZONES (I_DEPART,WBPSNUM)
If GMESSAGE<>"" Call ECR_TRACE(1)  : Return : Endif
#---- Chargement des zones date à partir du PORDERQ si WRCPDAT pas renseigné ----#
If [M:PMG]WRCPDAT=""
  [M:PMG]CAD    =[F:POQ]CAD
  [M:PMG]YEA    =[F:POQ]YEA
  [M:PMG]MON    =[F:POQ]MON
  [M:PMG]WEE    =[F:POQ]WEE
  [M:PMG]WDATDEB=[F:POQ]DEMRCPDAT
  [M:PMG]WDATFIN=[F:POQ]DEMENDDAT
Endif
#----- Début transaction de modification -----#
Call DEBTRANS From GLOCK
$TR_MODIFICATION
GOK=1 : Raz WMSG, GMESSAGE
Trbegin ADOVAL
  #----- Contrôle et chargement variables inter-sites -----#
  If [L]WPURFCY<>[F:POH]POHFCY | [L]WBPSORD<>[F:POH]BPSNUM
    [L]WPURFCY=[F:POH]POHFCY
    [L]WBPSORD=[F:POH]BPSNUM
  Endif
  #----- Relecture BPARTNER fournisseur -----#
  If [F:BPR]BPRNUM<>[F:POQ]BPSNUM
    Read [BPR] BPR0=[F:POQ]BPSNUM
    If fstat Raz [F:BPR] : Endif
  Endif
  #----- Lecture si nécessaire du BPSUPPLIER -----#
  If [F:BPS]BPSNUM<>[F:POQ]BPSNUM
    Read [BPS] BPS0=[F:POQ]BPSNUM
    If fstat Raz [F:BPS] : Endif
  Endif
  #----- Chargement des paramètres de la gestion tarif -----#
  If GPLISTC<>[F:BPS]PLISTC
    GPLISTC=[F:BPS]PLISTC
    Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
    Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
    Call TARIFCHGT(6)                From TRTPRICE
  Endif
  #----- Si date modifiée alors suppression et recréation de la ligne DL -----#
  If [M:PMG]WDATFIN<>[F:POQ]DEMENDDAT
    #----- Relecture ligne DL -----#
    Read [POQ] POQ0=[M:PMG]VCRNUM(I);[M:PMG]VCRLIN(I);[M:PMG]VCRSEQ(I)
    If fstat
      WMSG=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))-mess(250,197,1)
      [M:PMG]ERRCOD=13 : Goto AB_MODIFICATION
    Endif
    #----- Sauvegarde du buffer ligne DL -----#
    If clalev([F:POQB])<=0 Local File PORDERQ [POQB] : Endif
    [F:POQB]=[F:POQ]
    [M:PMG]MAJCOD="A"
    #---- Lecture de l'ordre à consommer/supprimer pour récup infos origine -----#
    If [F:POQ]WIPNUM<>""
      Read [ORD] ORD0=[F:POQ]WIPTYP;[F:POQ]WIPNUM;[F:POQ]ITMREF
      If fstat  Raz [F:ORD] : Endif
      WVCRTYPORI(I) = [F:ORD]VCRTYPORI
      WVCRNUMORI(I) = [F:ORD]VCRNUMORI
      WVCRLINORI(I) = [F:ORD]VCRLINORI
      WVCRSEQORI(I) = [F:ORD]VCRSEQORI
    Endif
    #-----
    I=I_DEPART : Gosub SUPPRESSION_LIGNE_POQ
    If GOK=-1 Goto ROLL_MODIFICATION : Endif
    If GOK=0  Goto AB_MODIFICATION   : Endif
    [M:PMG]ERRLIN(I)=1
    #----- Restitution du buffer ligne DL -----#
    [F:POQ]=[F:POQB] : Close Local File [POQB]
    #----- Recréation de la ligne DL -----#
    [M:PMG]MAJCOD="M"
    #----- recherche du no de séquence (WPOQSEQ) -----#
    Gosub RECH_POQSEQ
    If GMESSAGE<>""
      If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
      WMSG=GMESSAGE : Goto AB_MODIFICATION
    Endif
    Gosub AJUST_CADENCE_STATUT
    If GMESSAGE<>""
      If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
      WMSG=GMESSAGE : Goto AB_MODIFICATION
    Endif
    #----- Chargement nouvelles valeurs -----#
    [F:POQ]POQSEQ   =WPOQSEQ
    [F:POQ]QTYPUU   =[M:PMG]EXTPUUQTY(I)
    [F:POQ]QTYSTU   =[M:PMG]EXTSTUQTY(I)
    [F:POQ]EXTRCPDAT=[M:PMG]WDATFIN
    If [M:PMG]USEPLC<>""
      [F:POQ]USEPLC =[M:PMG]USEPLC
    Endif
    [F:POQ]WIPSTA   =WSTA
    [F:POQ]CAD      =[M:PMG]CAD
    [F:POQ]YEA      =[M:PMG]YEA
    [F:POQ]MON      =[M:PMG]MON
    [F:POQ]WEE      =[M:PMG]WEE
    If [F:POQ]EXTRCPDAT<date$
      [F:POQ]LINSTA =2
    Else
      [F:POQ]LINSTA =1
    Endif
    [F:POQ]DEMRCPDAT=[M:PMG]WDATDEB
    [F:POQ]DEMENDDAT=[M:PMG]WDATFIN
    [F:POQ]CREUSR   =GUSER
    [F:POQ]CREDAT   =date$
    #----- Lecture de la ligne article contrat -----#
    Read [POC] POC1=[F:POH]POHNUM;[M:PMG]ITMREF(I);[M:PMG]STOFCY(I)
    If fstat
      WMSG=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-mess(249,197,1)
      [M:PMG]ERRCOD=12 : GOK=0 : Goto AB_MODIFICATION
    Endif
    #----- Blocage logique de la ligne article contrat -----#
    SYMBOL3="POC"+num$([F:POC]POPLIN)+"\"+[F:POC]POHNUM
    Lock=SYMBOL3
    If fstat
      WMSG="$PORDERC"-[F:POC]POHNUM-num$([F:POC]POPLIN)-mess(10,100,1)
      [M:PMG]ERRCOD=37 : GOK=0 : Goto AB_MODIFICATION
    Endif
    WORDQTYPUU=[F:POC]ORDQTYPUU
    WEARQTY   =[F:POC]EARQTY
    #-----
    Gosub CREATION_LIGNE_POQ
    If GOK=-1 Goto ROLL_MODIFICATION : Endif
    If GOK=0  Goto AB_MODIFICATION   : Endif
    # Issue 78979 - 2012-01-02 by MUARN : maj des liens poq
    Gosub MAJ_LIENS_POQ
    If GOK=-1 Goto ROLL_MODIFICATION : Endif
    If GOK=0  Goto AB_MODIFICATION   : Endif
    Gosub MAJ_ENTETE_POC
    If SYMBOL3<>"" Unlock=SYMBOL3 : Raz SYMBOL3 : Endif
    If GOK=-1 Goto ROLL_MODIFICATION : Endif
    If GOK=0  Goto AB_MODIFICATION   : Endif
    Gosub MAJ_ENTETE_POH
    If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
    If GOK=-1 Goto ROLL_MODIFICATION : Endif
    If GOK=0  Goto AB_MODIFICATION   : Endif
    [M:PMG]MAJCOD="M"
    [M:PMG]ERRLIN(I)=0
    Goto FIN_MODIFICATION
  Endif
  #----- Réajustement statut si nécessaire -----#
  If [M:PMG]MAJTYP="P" WSTA=2 Else WSTA=1 : Endif
  If [M:PMG]CAD>1 & WSTA=1
    If WIPSTAFLG=0
      GMESSAGE=mess(246,197,1) : Call ECR_TRACE(0) : Raz GMESSAGE : WSTA=2
    Else
      WMSG=mess(267,197,1) : GOK=0 : [M:PMG]ERRCOD=35 : Goto AB_MODIFICATION
    Endif
  Endif
  #----- Lecture avec blocage physique de la ligne article contrat à modifier -----#
  CLEFIC=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))
  WMSG=mess(12,100,1)-"PORDERC"-CLEFIC : # Erreur d'accès sur le fichier ...
  Readlock [POC] POC0=[M:PMG]VCRNUM(I);[M:PMG]VCRLIN(I)
  If fstat=1
    GOK=-1 : GLOCK="$PORDERC"-CLEFIC
    Goto ROLL_MODIFICATION
  Elsif fstat
    GOK=0  : Call RSTA("POC",CLEFIC) From GLOCK
    Goto AB_MODIFICATION
  Endif
  Raz WMSG
  #----- Lecture avec blocage physique de la ligne de DL à modifier -----#
  CLEFIC=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))
  WMSG=mess(12,100,1)-"PORDERQ"-CLEFIC : # Erreur d'accès sur le fichier ...
  Readlock [POQ] POQ0=[M:PMG]VCRNUM(I);[M:PMG]VCRLIN(I);[M:PMG]VCRSEQ(I)
  If fstat=1
    GOK=-1 : GLOCK="$PORDERQ"-CLEFIC
    Goto ROLL_MODIFICATION
  Elsif fstat
    GOK=0  : Call RSTA("POQ",CLEFIC) From GLOCK
    Goto AB_MODIFICATION
  Endif
  Raz WMSG
  #----- Soustraction anciennes valeurs de la DL sur la ligne article contrat -----#
  If [F:POQ]WIPSTA=1
    [F:POC]ORDQTYPUU-=[F:POQ]QTYPUU
    [F:POC]ORDQTYSTU-=[F:POQ]QTYSTU
    If [F:POQ]LINSTA=2
      [F:POC]EARQTY-=[F:POQ]QTYPUU
    Endif
  Endif
  #----- Si demande ferme et non soldée -----#
  If [F:POQ]WIPSTA=1 & [F:POQ]LINSTA<>3
    #----- Mise qté cdée article-site, et budget -----#
    PRIFLG=1 : SIGN=-1 : Gosub MAJ_ITV_BUDGET
    If GOK=-1 Goto ROLL_MODIFICATION : Endif
    If GOK=0  Goto AB_MODIFICATION   : Endif
    #----- Soustraction anciennes valeurs montants sur entête contrat -----#
    WTOTORD-=[F:POQ]LINAMT
    WTTVORD-=[F:POQ]LINATIAMT
  Endif
  #----- Sauvegarde quantité avant modification -----#
  ORIQTYPUU=[F:POQ]QTYPUU
  #----- Chargement des valeurs modifiées -----#
  [F:POQ]QTYPUU   =[M:PMG]EXTPUUQTY(I)
  [F:POQ]QTYSTU   =[M:PMG]EXTSTUQTY(I)
  [F:POQ]EXTRCPDAT=[M:PMG]WDATFIN
  If [M:PMG]USEPLC<>""
    [F:POQ]USEPLC =[M:PMG]USEPLC
  Endif
  [F:POQ]WIPSTA   =WSTA
  [F:POQ]CAD      =[M:PMG]CAD
  [F:POQ]YEA      =[M:PMG]YEA
  [F:POQ]MON      =[M:PMG]MON
  [F:POQ]WEE      =[M:PMG]WEE
  If [F:POQ]EXTRCPDAT<date$
    [F:POQ]LINSTA =2
  Else
    [F:POQ]LINSTA =1
  Endif
  [F:POQ]DEMRCPDAT=[M:PMG]WDATDEB
  [F:POQ]DEMENDDAT=[M:PMG]WDATFIN
  [F:POQ]UPDUSR   =GUSER
  [F:POQ]UPDDAT   =date$
  #----- Calcul qté en unité de commande -----#
  If [F:POQ]UOMPUUCOE<>0
    [F:POQ]QTYUOM=[F:POQ]QTYPUU/[F:POQ]UOMPUUCOE
    Call QTEARR([F:POQ]QTYUOM,[F:POQ]UOM) From TRTDIV
  Else
    [F:POQ]QTYUOM=[F:POQ]QTYPUU
  Endif
  #----- Modification de l'encours "TR" ou "PO" -----#
  If [F:POQ]WIPNUM<>""
    Read [ORD] ORD0=[F:POQ]WIPTYP;[F:POQ]WIPNUM;[F:POQ]ITMREF
    If fstat  Raz [F:ORD] : Endif
    [M:ORDK]          = [F:ORD]
    [M:ORDK]MAJCOD    = "M"
    [M:ORDK]WIPTYP    = [F:POQ]WIPTYP
    [M:ORDK]WIPSTA    = [F:POQ]WIPSTA
    [M:ORDK]WIPNUM    = [F:POQ]WIPNUM
    [M:ORDK]ITMREF    = [F:POQ]ITMREF
    [M:ORDK]STOFCY    = [F:POQ]PRHFCY
    [M:ORDK]PJT       = ""
    [M:ORDK]BPRNUM    = [F:POQ]BPSNUM
    [M:ORDK]STRDAT    = [F:POQ]DEMRCPDAT
    [M:ORDK]ENDDAT    = [F:POQ]DEMENDDAT
    [M:ORDK]VCRTYP    = 14
    [M:ORDK]VCRNUM    = [F:POQ]POHNUM
    [M:ORDK]VCRLIN    = [F:POQ]POPLIN
    [M:ORDK]VCRSEQ    = [F:POQ]POQSEQ
    [M:ORDK]EXTQTY    = [F:POQ]QTYSTU
    [M:ORDK]CPLQTY    = 0
    [M:ORDK]ALLQTY    = 0
    [M:ORDK]SHTQTY    = 0
    [M:ORDK]FMI       = 1
    [M:ORDK]MRPMES    = 1
    # Issue 71276 - 2015-02-27 by SR : Versions
    If dim([M:ORDK]ECCVALMAJ)> 0
     [M:ORDK]ECCVALMAJ = [F:POQ]ECCVALMAJ
     [M:ORDK]ECCVALMIN = [F:POQ]ECCVALMIN
    Endif
    # End issue 71276
    #----- Chargement infos origine si erreur lecture sur l'ordre à modifier -----#
    If [F:ORD]WIPNUM=""
      If [F:POQ]WIPTYP=7
        [M:ORDK]ORIFCY    = [F:POQ]LINSTOFCY
        [M:ORDK]VCRTYPORI = 2
        [M:ORDK]VCRNUMORI = [F:POQ]LINOCNNUM
        [M:ORDK]VCRLINORI = [F:POQ]OCNLIN
        [M:ORDK]VCRSEQORI = [F:POQ]OCNSEQ
      Else
        [M:ORDK]ORIFCY    = [F:POQ]POHFCY
        [M:ORDK]VCRTYPORI = 0
        [M:ORDK]VCRNUMORI = ""
        [M:ORDK]VCRLINORI = 0
        [M:ORDK]VCRSEQORI = 0
      Endif
    Endif
    #-----
    [M:ORDK]BOMALT    = 0
    [M:ORDK]ORI       = 1
    [M:ORDK]ABBFIL    = "POC"
    Call WIP From TRTWIP
    If GOK<1
      WMSG =num$([F:POQ]WIPTYP)
      WMSG-=[F:POQ]WIPNUM-[F:POQ]ITMREF-mess(92,197,1) : # Problème en maj des encours
      [M:PMG]ERRCOD=7
      Goto AB_MODIFICATION
    Endif

    # v6 affectations
    Gosub MAJ_MTO_POQ From PURMTOLIB

  Endif
  #----- Si demande ferme et non soldée -----#
  If [F:POQ]WIPSTA=1 & [F:POQ]LINSTA<>3
    #----- Mise qté cdée article-site, budget et montants HT et TTC ligne -----#
    PRIFLG=2 : SIGN=+1 : Gosub MAJ_ITV_BUDGET
    If GOK=-1 Goto ROLL_MODIFICATION : Endif
    If GOK=0  Goto AB_MODIFICATION   : Endif
    #----- Addition nouvelles valeurs montants sur entête contrat -----#
    WTOTORD+=[F:POQ]LINAMT
    WTTVORD+=[F:POQ]LINATIAMT
  Else
    Raz [F:POQ]LINAMT, [F:POQ]LINATI, [F:POQ]LINATIAMT
  Endif
  #--------------------------------------------------------------#
  # Point d'entrée MAJDL pour alimentation de zones spécifiques  #
  # ------------------------------------------------------------ #
  # Variables utilisables par le point d'entrée                  #
  #                                                              #
  # TYPMAJ  : Type de mise à jour (2 = modification DL)          #
  # FICHIER : Nom de la table qui va être écrite "PORDERQ"       #
  # ABRFIC  : Abréviation de la table qui va être écrite "POQ"   #
  # La  classe  [F:POQ] est modifiable avant le Write ou Rewrite #
  #--------------------------------------------------------------#
  TYPMAJ=2 : Gosub POINT_MAJDL From TRTACHPOD1
  #----- Réécriture de la ligne de DL -----#
  CLEFIC=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))
  WMSG=mess(13,100,1)-"PORDERQ"-CLEFIC : # Erreur d'écriture sur le fichier ...
  Rewrite [POQ]
  If fstat
    GOK=0  : Call FSTA("POQ") From GLOCK
    Goto AB_MODIFICATION
  Endif
  Raz WMSG
  #----- Mise à jour qtés commandées UA US et avance-retard -----#
  If [F:POQ]WIPSTA=1
    [F:POC]ORDQTYPUU+=[F:POQ]QTYPUU
    [F:POC]ORDQTYSTU+=[F:POQ]QTYSTU
    If [F:POQ]LINSTA=2
      [F:POC]EARQTY+=[F:POQ]QTYPUU
    Endif
  Endif
  [F:POC]EARDAT=date$
  [F:POC]DLVREQNUM+=1
  #----- Mise a jour date et opérateur dernière modification -----#
  [F:POC]UPDUSR=GUSER
  [F:POC]UPDDAT=date$
  #----- Réécriture de la ligne article contrat -----#
  CLEFIC=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))
  WMSG=mess(13,100,1)-"PORDERC"-CLEFIC : # Erreur d'écriture sur le fichier ...
  Rewrite [POC]
  If fstat GOK=0  : Call FSTA("POC") From GLOCK : Goto AB_MODIFICATION : Endif
  Raz WMSG
  #----- Mise à jour entête contrat -----#
  Gosub MAJ_ENTETE_POH
  If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
  If GOK=-1 Goto ROLL_MODIFICATION : Endif
  If GOK=0  Goto AB_MODIFICATION   : Endif
  #----- Message : Ligne contrat XXXXXXXXXXXXXXX 99999999 modifiée ! -----#
  CLEFIC=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))
  GMESSAGE=mess(243,197,1)-CLEFIC-mess(223,197,1) : Call ECR_TRACE(0) : Raz GMESSAGE
  [M:PMG]ERRLIN(I)=0
  #----- Appel du S/P ventes pour modification de la ligne quantité (SORDERQ) -----#
  If [F:POH]SALFCY<>""
    Raz [M:SORW]
    [M:SORW]MAJCOD   = "M"
    [M:SORW]SOHNUM   = [F:POQ]LINOCNNUM
    [M:SORW]SOPLIN   = [F:POQ]OCNLIN
    [M:SORW]SOQSEQ   = [F:POQ]OCNSEQ
    [M:SORW]QTY      = [F:POQ]QTYPUU-ORIQTYPUU
    [M:SORW]DEMSTA   = [F:POQ]WIPSTA
    [M:SORW]USEPLC   = [F:POQ]USEPLC
    [M:SORW]SOQSTA   = [F:POQ]LINSTA
    Call MAJ_SOQ From TRTVENMSIT
    If GOK<1 : WMSG=GMESSAGE : [M:PMG]ERRCOD=16 : Raz GMESSAGE : Endif
    If GOK=-1 Goto ROLL_MODIFICATION : Endif
    If GOK=0  Goto AB_MODIFICATION   : Endif
  Endif
  #-----
$FIN_MODIFICATION
  #----- Déblocage logique de l'entête commande -----#
  If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
  #----- Déblocage logique de la ligne article contrat -----#
  If SYMBOL3<>"" Unlock=SYMBOL3 : Raz SYMBOL3 : Endif
Commit
Return

$MAJ_LIENS_POQ
# Issue 78979 - 2012-01-03 by MUARN : Mise à jour lien facture non réceptionnée avec POQ
If !clalev([F:PID])   Local File PINVOICED     [PID]  : Endif
Update [PID] Where POHNUM=[M:PMG]VCRNUM(I) & POPLIN=[M:PMG]VCRLIN(I) & POQSEQ=[M:PMG]VCRSEQ(I)
&              With  POHNUM=[F:POQ]POHNUM,   POPLIN=[F:POQ]POPLIN,      POQSEQ=[F:POQ]POQSEQ
If fstat
  Call RSTA("PID",[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))) From GLOCK
  GOK=0
Endif
Return

$ROLL_MODIFICATION
Rollback : Call ROLL From GLOCK
If GROLL
  Gosub AB_TRANSACTION_MSG
  Return
Else
  Goto TR_MODIFICATION
Endif
$AB_MODIFICATION
Rollback
Gosub AB_TRANSACTION_MSG
Return


########################################################################
# Suppression d'une demande de livraison à partir d'une "POP" ou "POF" #
########################################################################
$SUPPRESSION_POD1
Call DEBTRANS From GLOCK
$TR_SUPPRESSION
GOK=1 : Raz WMSG
Trbegin ADOVAL
  I=I_DEPART : Gosub SUPPRESSION_LIGNE_POQ
  If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
  If SYMBOL3<>"" Unlock=SYMBOL3 : Raz SYMBOL3 : Endif
  If GOK=-1 Goto ROLL_SUPPRESSION : Endif
  If GOK=0  Goto AB_SUPPRESSION   : Endif
  [M:PMG]ERRLIN(I)=0
Commit
Return
$ROLL_SUPPRESSION
Rollback : Call ROLL From GLOCK
If GROLL
  Gosub AB_TRANSACTION_MSG
  Return
Else
  Goto TR_SUPPRESSION
Endif
$AB_SUPPRESSION
Rollback
Gosub AB_TRANSACTION_MSG
Return


#-----------------------------------------------#
# Consommation d'une ligne demande de livraison #
#-----------------------------------------------#
$CONSOMMATION_LIGNE_POQ1
#----- Lecture encours -----#
Read [ORD] ORD0=[M:PMG]WIPTYP(I);[M:PMG]WIPNUM(I);[M:PMG]ITMREF(I)
If fstat Raz [F:ORD] : Endif
If [F:ORD]ABBFIL<>"POC" Return : Endif : # Ce n'est pas une PO/TR de DL
#----- Lecture ligne DL à consommer -----#
Read [POQ] POQ0=[M:PMG]VCRNUM(I);[M:PMG]VCRLIN(I);[M:PMG]VCRSEQ(I)
If fstat
  WMSG=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))-mess(250,197,1)
  GOK=0 : [M:PMG]ERRCOD=13 : Return
Endif
[M:PMG]WIPTYP(I)=[F:POQ]WIPTYP
[M:PMG]WIPSTA(I)=[F:POQ]WIPSTA
[M:PMG]WIPNUM(I)=[F:POQ]WIPNUM
[M:PMG]PUU(I)   =[F:POQ]PUU
#---- Lecture de l'ordre à consommer/supprimer pour récup infos pièce origine -----#
If [F:POQ]WIPNUM<>""
  Read [ORD] ORD0=[F:POQ]WIPTYP;[F:POQ]WIPNUM;[F:POQ]ITMREF
  If fstat  Raz [F:ORD] : Endif
  WVCRTYPORI(I) = [F:ORD]VCRTYPORI
  WVCRNUMORI(I) = [F:ORD]VCRNUMORI
  WVCRLINORI(I) = [F:ORD]VCRLINORI
  WVCRSEQORI(I) = [F:ORD]VCRSEQORI
Endif
#----- Calcul quantité en UA ou US -----#
If [M:PMG]EXTSTUQTY(I)=0
  Call PCAL_QTY ([M:PMG]EXTPUUQTY(I),[M:PMG]PUU(I),[M:PMG]EXTSTUQTY(I),
&           [M:PMG]STU(I),[M:PMG]ITMREF(I),[F:POQ]BPSNUM,1,GBIDD1) From TRTACHQTE1
Else
  Call PCAL_QTY ([M:PMG]EXTSTUQTY(I),[M:PMG]STU(I),[M:PMG]EXTPUUQTY(I),
&           [M:PMG]PUU(I),[M:PMG]ITMREF(I),[F:POQ]BPSNUM,1,GBIDD1) From TRTACHQTE1
Endif
#----- Test si prise en compte totale alors suppression ligne DL -----#
If [M:PMG]EXTSTUQTY(I)>=[F:POQ]QTYSTU
  [M:PMG]MAJCOD="A" : Gosub SUPPRESSION_LIGNE_POQ : Return
Endif
#----- Prise en compte partielle alors consommation ligne DL -----#
[M:PMG]MAJCOD="M"
Gosub CONTROLE : If [M:PMG]ERRCOD<>0 GOK=0 : Return : Endif
#----- Contrôle et chargement variables inter-sites -----#
If [L]WPURFCY<>[F:POQ]POHFCY | [L]WBPSORD<>[F:POQ]BPSNUM
  [L]WPURFCY=[F:POQ]POHFCY
  [L]WBPSORD=[F:POQ]BPSNUM
Endif
#----- Relecture BPARTNER fournisseur -----#
If [F:BPR]BPRNUM<>[F:POQ]BPSNUM
  Read [BPR] BPR0=[F:POQ]BPSNUM
  If fstat Raz [F:BPR] : Endif
Endif
#----- Lecture si nécessaire du BPSUPPLIER -----#
If [F:BPS]BPSNUM<>[F:POQ]BPSNUM
  Read [BPS] BPS0=[F:POQ]BPSNUM
  If fstat Raz [F:BPS] : Endif
Endif
#----- Chargement des paramètres de la gestion tarif -----#
If GPLISTC<>[F:BPS]PLISTC
  GPLISTC=[F:BPS]PLISTC
  Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
  Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
  Call TARIFCHGT(6)                From TRTPRICE
Endif
#----- Lecture avec blocage physique de la ligne article contrat à consommer -----#
CLEFIC=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))
WMSG=mess(12,100,1)-"PORDERC"-CLEFIC : # Erreur d'accès sur le fichier ...
Readlock [POC] POC0=[M:PMG]VCRNUM(I);[M:PMG]VCRLIN(I)
If fstat=1
  GOK=-1 : GLOCK="$PORDERC"-CLEFIC
  Return
Elsif fstat
  GOK=0  : Call RSTA("POC",CLEFIC) From GLOCK
  Return
Endif
Raz WMSG
#----- Lecture avec blocage physique de la ligne de DL à consommer -----#
CLEFIC=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))
WMSG=mess(12,100,1)-"PORDERQ"-CLEFIC : # Erreur d'accès sur le fichier ...
Readlock [POQ] POQ0=[M:PMG]VCRNUM(I);[M:PMG]VCRLIN(I);[M:PMG]VCRSEQ(I)
If fstat=1
  GOK=-1 : GLOCK="$PORDERQ"-CLEFIC
  Return
Elsif fstat
  GOK=0  : Call RSTA("POQ",CLEFIC) From GLOCK
  Return
Endif
Raz WMSG
#----- Si demande ferme et non soldée -----#
If [F:POQ]WIPSTA=1 & [F:POQ]LINSTA<>3
  #----- Mise qté cdée article-site et budget -----#
  PRIFLG=1 : SIGN=-1 : Gosub MAJ_ITV_BUDGET
  If GOK<1 Return : Endif
  #----- Soustraction anciennes valeurs montants sur entête contrat -----#
  Raz WMT1, WMT2, WMT3
  If [F:POQ]QTYSTU<>0
    WMT1=[F:POQ]LINAMT*[M:PMG]EXTSTUQTY(I)/[F:POQ]QTYSTU
    WMT2=[F:POQ]LINATIAMT*[M:PMG]EXTSTUQTY(I)/[F:POQ]QTYSTU
    WMT3=[F:POQ]LINATI*[M:PMG]EXTSTUQTY(I)/[F:POQ]QTYSTU
    WTOTORD-=WMT1
    WTTVORD-=WMT2
    Gosub MAJ_ENTETE_POH
    If GOK<1 Return : Endif
  Endif
Endif
#----- Chargement des valeurs modifiées -----#
[F:POQ]QTYPUU   -=[M:PMG]EXTPUUQTY(I)
[F:POQ]QTYSTU   -=[M:PMG]EXTSTUQTY(I)
[F:POQ]RETQTYPUU-=[M:PMG]EXTPUUQTY(I)
[F:POQ]RETQTYSTU-=[M:PMG]EXTSTUQTY(I)
If [F:POQ]RETQTYPUU<0 Raz [F:POQ]RETQTYPUU : Endif
If [F:POQ]RETQTYSTU<0 Raz [F:POQ]RETQTYSTU : Endif
[F:POQ]UPDUSR =GUSER
[F:POQ]UPDDAT =date$
#----- Calcul qté en unité de commande -----#
If [F:POQ]UOMPUUCOE<>0
  [F:POQ]QTYUOM=[F:POQ]QTYPUU/[F:POQ]UOMPUUCOE
  Call QTEARR([F:POQ]QTYUOM,[F:POQ]UOM) From TRTDIV
Else
  [F:POQ]QTYUOM=[F:POQ]QTYPUU
Endif
#----- Si demande ferme et non soldée -----#
If [F:POQ]WIPSTA=1 & [F:POQ]LINSTA<>3
  [F:POQ]LINAMT   -=WMT1
  [F:POQ]LINATIAMT-=WMT2
  [F:POQ]LINATI   -=WMT3
  #----- Mise qté cdée article-site et budget -----#
  PRIFLG=1 : SIGN=+1 : Gosub MAJ_ITV_BUDGET
  If GOK<1 Return : Endif
Endif
#----- Consommation de l'encours "PO/TR" -----#
If [F:POQ]WIPNUM<>""
  Raz [M:ORDK]
  [M:ORDK]          = [F:ORD]
  [M:ORDK]MAJCOD    = "M"
  [M:ORDK]WIPTYP    = [F:POQ]WIPTYP
  [M:ORDK]WIPSTA    = [F:POQ]WIPSTA
  [M:ORDK]WIPNUM    = [F:POQ]WIPNUM
  [M:ORDK]ITMREF    = [F:POQ]ITMREF
  [M:ORDK]STOFCY    = [F:POQ]PRHFCY
  [M:ORDK]PJT       = ""
  [M:ORDK]BPRNUM    = [F:POQ]BPSNUM
  [M:ORDK]STRDAT    = [F:POQ]DEMRCPDAT
  [M:ORDK]ENDDAT    = [F:POQ]DEMENDDAT
  [M:ORDK]VCRTYP    = 14
  [M:ORDK]VCRNUM    = [F:POQ]POHNUM
  [M:ORDK]VCRLIN    = [F:POQ]POPLIN
  [M:ORDK]VCRSEQ    = [F:POQ]POQSEQ
  [M:ORDK]EXTQTY    = [F:POQ]QTYSTU
  [M:ORDK]CPLQTY    = 0
  [M:ORDK]ALLQTY    = 0
  [M:ORDK]SHTQTY    = 0
  [M:ORDK]FMI       = 1
  [M:ORDK]MRPMES    = 1
  # Issue 71276 - 2015-02-27 by SR : Versions
  If dim([M:ORDK]ECCVALMAJ)> 0
     [M:ORDK]ECCVALMAJ = [F:POQ]ECCVALMAJ
     [M:ORDK]ECCVALMIN = [F:POQ]ECCVALMIN
  Endif
  # End issue 71276
  #----- Chargement infos origine si erreur lecture sur l'ordre à modifier -----#
  If [F:ORD]WIPNUM=""
    If [F:POQ]WIPTYP=7
      [M:ORDK]ORIFCY    = [F:POQ]LINSTOFCY
      [M:ORDK]VCRTYPORI = 2
      [M:ORDK]VCRNUMORI = [F:POQ]LINOCNNUM
      [M:ORDK]VCRLINORI = [F:POQ]OCNLIN
      [M:ORDK]VCRSEQORI = [F:POQ]OCNSEQ
    Else
      [M:ORDK]ORIFCY    = [F:POQ]POHFCY
      [M:ORDK]VCRTYPORI = 0
      [M:ORDK]VCRNUMORI = ""
      [M:ORDK]VCRLINORI = 0
      [M:ORDK]VCRSEQORI = 0
    Endif
  Endif
  #-----
  [M:ORDK]BOMALT    = 0
  [M:ORDK]ORI       = 1
  [M:ORDK]ABBFIL    = "POC"
  Call WIP From TRTWIP
  If GOK<1
    WMSG="2"-[F:POQ]WIPNUM-[F:POQ]ITMREF-mess(92,197,1) : # Problème en maj des encours
    [M:PMG]ERRCOD=7
    Return
  Endif
Endif
#--------------------------------------------------------------#
# Point d'entrée MAJDL pour alimentation de zones spécifiques  #
# ------------------------------------------------------------ #
# Variables utilisables par le point d'entrée                  #
#                                                              #
# TYPMAJ  : Type de mise à jour (3 = consommation DL)          #
# FICHIER : Nom de la table qui va être écrite "PORDERQ"       #
# ABRFIC  : Abréviation de la table qui va être écrite "POQ"   #
# La  classe  [F:POQ] est modifiable avant le Write ou Rewrite #
#--------------------------------------------------------------#
TYPMAJ=3 : Gosub POINT_MAJDL From TRTACHPOD1
#----- Réécriture de la ligne de DL -----#
CLEFIC=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))
WMSG=mess(13,100,1)-"PORDERQ"-CLEFIC : # Erreur d'écriture sur le fichier ...
Rewrite [POQ]
If fstat
  GOK=0  : Call FSTA("POQ") From GLOCK
  Return
Endif
Raz WMSG
#----- Mise à jour qtés commandées UA US et avance-retard -----#
If [F:POQ]WIPSTA=1
  [F:POC]ORDQTYPUU-=[M:PMG]EXTPUUQTY(I)
  [F:POC]ORDQTYSTU-=[M:PMG]EXTSTUQTY(I)
  If [F:POQ]LINSTA=2
    [F:POC]EARQTY-=[M:PMG]EXTPUUQTY(I)
  Endif
Endif
[F:POC]EARDAT=date$
[F:POC]DLVREQNUM+=1
#----- Mise a jour date et opérateur dernière modification -----#
[F:POC]UPDUSR=GUSER
[F:POC]UPDDAT=date$
#----- Réécriture de la ligne article contrat -----#
WMSG=mess(13,100,1)-"PORDERC"-CLEFIC : # Erreur d'écriture sur le fichier ...
Rewrite [POC]
If fstat GOK=0  : Call FSTA("POC") From GLOCK : Return : Endif
Raz WMSG
#----- Message : Ligne contrat XXXXXXXXXXXXXXX 99999999 modifiée ! -----#
GMESSAGE=mess(243,197,1)-CLEFIC-mess(223,197,1) : Call ECR_TRACE(0) : Raz GMESSAGE
#----- Appel du S/P ventes pour modification de la ligne quantité (SORDERQ) -----#
If [F:POQ]OCNLIN<>0
  Raz [M:SORW]
  [M:SORW]MAJCOD   = "M"
  [M:SORW]SOHNUM   = [F:POQ]LINOCNNUM
  [M:SORW]SOPLIN   = [F:POQ]OCNLIN
  [M:SORW]SOQSEQ   = [F:POQ]OCNSEQ
  [M:SORW]QTY      = -[M:PMG]EXTPUUQTY(I)
  [M:SORW]DEMSTA   = [F:POQ]WIPSTA
  [M:SORW]USEPLC   = [F:POQ]USEPLC
  [M:SORW]SOQSTA   = [F:POQ]LINSTA
  Call MAJ_SOQ From TRTVENMSIT
  If GOK<1 : WMSG=GMESSAGE : [M:PMG]ERRCOD=16 : Raz GMESSAGE : Return : Endif
Endif
#-----
[M:PMG]ERRLIN(I)=9
Return


#----------------------------------------------#
# Suppression d'une ligne demande de livraison #
#----------------------------------------------#
$SUPPRESSION_LIGNE_POQ
Gosub CONTROLE : If [M:PMG]ERRCOD<>0 : GOK = 0 : Return : Endif
#----- Appel du S/P ventes pour suppression de la ligne quantité (SORDERQ) -----#
If [F:POQ]OCNLIN<>0
  Raz [M:SORW]
  [M:SORW]MAJCOD   = "A"
  [M:SORW]SOHNUM   = [F:POQ]LINOCNNUM
  [M:SORW]SOPLIN   = [F:POQ]OCNLIN
  [M:SORW]SOQSEQ   = [F:POQ]OCNSEQ
  Call MAJ_SOQ From TRTVENMSIT
  If GOK<1 : WMSG=GMESSAGE : [M:PMG]ERRCOD=18 : Raz GMESSAGE : Return : Endif
Endif
#----- Mise à jour des ordres TRS-TRP-POP-POF (Suppression) -----#
If [F:POQ]WIPNUM<>""

  # V6 Affectations
  Gosub SUP_MTO_POQ From PURMTOLIB

  [M:ORDK]MAJCOD = "A"
  [M:ORDK]WIPTYP = [F:POQ]WIPTYP
  [M:ORDK]WIPNUM = [F:POQ]WIPNUM
  [M:ORDK]ITMREF = [F:POQ]ITMREF
  Call WIP From TRTWIP
  If GOK<1
    WMSG =num$([F:POQ]WIPTYP)
    WMSG-=[F:POQ]WIPNUM-[F:POQ]ITMREF-mess(92,197,1) : # Problème en maj encours
    [M:PMG]ERRCOD=7 : Return
  Endif
Endif
#----- Lecture avec blocage physique de la ligne article contrat -----#
CLEFIC=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))
WMSG=mess(12,100,1)-"PORDERC"-CLEFIC : # Erreur d'accès sur le fichier ...
Readlock [POC] POC0=[M:PMG]VCRNUM(I);[M:PMG]VCRLIN(I)
If fstat=1
  GOK=-1 : GLOCK="$PORDERC"-CLEFIC
  Return
Elsif fstat
  GOK=0  : Call RSTA("POC",CLEFIC) From GLOCK
  Return
Endif
Raz WMSG
#----- Si demande ferme et non soldée -----#
If [F:POQ]WIPSTA=1 & [F:POQ]LINSTA<>3
  #----- Mise qté cdée article-site et budget -----#
  PRIFLG=1 : SIGN=-1 : Gosub MAJ_ITV_BUDGET
  If GOK<1 Return : Endif
  #----- Soustraction anciennes valeurs montants sur entête contrat -----#
  If [F:POQ]QTYPUU<>0 & ([F:POQ]RCPQTYPUU<>0 | [F:POQ]INVQTYPUU<>0)
    If [F:POQ]INVQTYPUU>[F:POQ]RCPQTYPUU
      #----- Si article facturé avant réception ou jamais réceptionné -----#
      WTOTORD-=[F:POQ]LINAMT   *max([F:POQ]QTYPUU-[F:POQ]INVQTYPUU,0)/[F:POQ]QTYPUU
      WTTVORD-=[F:POQ]LINATIAMT*max([F:POQ]QTYPUU-[F:POQ]INVQTYPUU,0)/[F:POQ]QTYPUU
    Else
      #----- La réception partielle est permise pour l'inter-sites avec flux auto -----#
      WTOTORD-=[F:POQ]LINAMT   *max([F:POQ]QTYPUU-[F:POQ]RCPQTYPUU,0)/[F:POQ]QTYPUU
      WTTVORD-=[F:POQ]LINATIAMT*max([F:POQ]QTYPUU-[F:POQ]RCPQTYPUU,0)/[F:POQ]QTYPUU
    Endif
  Else
    WTOTORD-=[F:POQ]LINAMT
    WTTVORD-=[F:POQ]LINATIAMT
  Endif
  Gosub MAJ_ENTETE_POH
  If GOK<1 Return : Endif
Endif
#----- Mise à jour DA et fichier lien si nécessaire -----#
If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
#-----
If [L]WMAJCOD="A"
  #----- Lecture du fichier lien commande-demande à supprimer -----#
  For [PSO]PSO1 Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POQSEQ=[F:POQ]POQSEQ
    Gosub MAJ_LIGNE_DA From SUBPOHB : If GOK<1  Break : Endif
  Next
  If SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
  If GOK=1
    #----- Suppression des enregistrements lien -----#
    CLEFIC=[F:POQ]POHNUM-num$([F:POQ]POPLIN)
    Delete [PSO] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POQSEQ=[F:POQ]POQSEQ
    If fstat=1
      GOK=-1 : GLOCK="$PREQUISO"-CLEFIC
    Elsif fstat
      GOK=0  : Call RSTA("PSO",CLEFIC) From GLOCK
    Endif
  Endif
Else
  #----- Màj du fichier lien commande-demande avec nouvelle référence commande -----#
  Update [PSO] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POQSEQ=[F:POQ]POQSEQ
&              With  POHNUM="TRTACHPOD1",   POPLIN=adxuid(1),      POQSEQ=I
  If fstat=1
    GLOCK="$PREQUISO"-[F:POQ]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)
    GOK=-1
  Elsif fstat
    Call RSTA("PSO",[F:POQ]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)) From GLOCK
    GOK=0
  Endif
Endif
#-----
If GOK<1
  WMSG=mess(356,197,1) : # Erreur à la mise à jour des demandes d'achat !
  [M:PMG]ERRCOD=46
  Return
Endif
#----- Mise à jour qtés cdées et avance-retard pour ligne article contrat -----#
If [F:POQ]WIPSTA=1
  [F:POC]ORDQTYPUU-=[F:POQ]QTYPUU
  If [F:POQ]LINSTA=2
    [F:POC]EARQTY-=[F:POQ]QTYPUU
  Endif
Endif
#----- Mise à jour date avance-retard et nombre de prog DL -----#
[F:POC]EARDAT=date$
[F:POC]DLVREQNUM+=1
#----- Mise a jour date et opérateur dernière modification -----#
[F:POC]UPDUSR=GUSER
[F:POC]UPDDAT=date$
#----- Réécriture de la ligne article contrat -----#
CLEFIC=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))
WMSG=mess(13,100,1)-"PORDERC"-CLEFIC : # Erreur d'écriture sur le fichier ...
Rewrite [POC]
If fstat GOK=0  : Call FSTA("POC") From GLOCK : Return : Endif
Raz WMSG
#----- Message : Ligne contrat XXXXXXXXXXXXXXX 99999999 modifiée ! -----#
GMESSAGE=mess(243,197,1)-CLEFIC-mess(223,197,1) : Call ECR_TRACE(0) : Raz GMESSAGE
#----- Suppression de la ligne de DL -----#
CLEFIC=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))
WMSG=mess(12,100,1)-"PORDERQ"-CLEFIC : # Erreur d'accès sur le fichier ...
Delete [POQ] Where POHNUM=[M:PMG]VCRNUM(I) & POPLIN=[M:PMG]VCRLIN(I) &
&                  POQSEQ=[M:PMG]VCRSEQ(I)
If fstat=1
  GOK=-1 : GLOCK="$PORDERQ"-CLEFIC
  Return
Elsif fstat
  GOK=0  : Call RSTA("POQ",CLEFIC) From GLOCK
  Return
Endif
Raz WMSG
#---- Message : Demande de livraison XXXXXXXXXXXXXXX 9999999 9999999 supprimée ! ----#
GMESSAGE=mess(244,197,1)-CLEFIC-mess(170,197,1) : Call ECR_TRACE(0) : Raz GMESSAGE
[M:PMG]ERRLIN(I)=9
#----- Déblocage logique de la ligne article contrat -----#
If SYMBOL3<>"" Unlock=SYMBOL3 : Raz SYMBOL3 : Endif
Return


##########################################
# Solde d'une demande de livraison ferme #
##########################################
$SOLDE_POD1
I=I_DEPART : Gosub CONTROLE : If [M:PMG]ERRCOD<>0 Return : Endif
Call DEBTRANS From GLOCK
$TR_SOLDE
GOK=1 : Raz WMSG
Trbegin ADOVAL
  #----- Appel du S/P ventes pour solde de la ligne quantité (SORDERQ) -----#
  If [F:POQ]OCNLIN<>0
    Raz [M:SORW]
    [M:SORW]MAJCOD   = "S"
    [M:SORW]SOHNUM   = [F:POQ]LINOCNNUM
    [M:SORW]SOPLIN   = [F:POQ]OCNLIN
    [M:SORW]SOQSEQ   = [F:POQ]OCNSEQ
    Call MAJ_SOQ From TRTVENMSIT
    If GOK<1 : WMSG=GMESSAGE : [M:PMG]ERRCOD=17 : Raz GMESSAGE : Endif
    If GOK=-1 Goto ROLL_SOLDE : Endif
    If GOK=0  Goto AB_SOLDE   : Endif
  Endif
  #----- Mise à jour des ordres TRS-TRP-POS-POP (Suppression) -----#
  If [F:POQ]WIPNUM<>""

    # V6 Affectations
    Gosub SUP_MTO_POQ From PURMTOLIB

    [M:ORDK]MAJCOD = "A"
    [M:ORDK]WIPTYP = [F:POQ]WIPTYP
    [M:ORDK]WIPNUM = [F:POQ]WIPNUM
    [M:ORDK]ITMREF = [F:POQ]ITMREF
    Call WIP From TRTWIP
    If GOK<1
      WMSG =num$([F:POQ]WIPTYP)
      WMSG-=[F:POQ]WIPNUM-[F:POQ]ITMREF-mess(92,197,1) : # Problème en maj encours
      [M:PMG]ERRCOD=7 : Goto AB_SOLDE
    Endif
  Endif
  #----- Lecture avec blocage physique de la ligne article contrat -----#
  CLEFIC=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))
  WMSG=mess(12,100,1)-"PORDERC"-CLEFIC : # Erreur d'accès sur le fichier ...
  Readlock [POC] POC0=[M:PMG]VCRNUM(I);[M:PMG]VCRLIN(I)
  If fstat=1
    GOK=-1 : GLOCK="$PORDERC"-CLEFIC
    Goto ROLL_SOLDE
  Elsif fstat
    GOK=0  : Call RSTA("POC",CLEFIC) From GLOCK
    Goto AB_SOLDE
  Endif
  Raz WMSG
  #----- Lecture avec blocage physique de la ligne DL -----#
  CLEFIC=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))
  WMSG=mess(12,100,1)-"PORDERQ"-CLEFIC : # Erreur d'accès sur le fichier ...
  Readlock [POQ] POQ0=[M:PMG]VCRNUM(I);[M:PMG]VCRLIN(I);[M:PMG]VCRSEQ(I)
  If fstat=1
    GOK=-1 : GLOCK="$PORDERQ"-CLEFIC
    Goto ROLL_SOLDE
  Elsif fstat
    GOK=0  : Call RSTA("POQ",CLEFIC) From GLOCK
    Goto AB_SOLDE
  Endif
  Raz WMSG
  #----- Si demande ferme et non soldée -----#
  If [F:POQ]WIPSTA=1 & [F:POQ]LINSTA<>3
    #----- Mise qté cdée article-site et budget -----#
    PRIFLG=1 : SIGN=-1 : Gosub MAJ_ITV_BUDGET
    If GOK=-1 Goto ROLL_SOLDE : Endif
    If GOK=0  Goto AB_SOLDE   : Endif
    #----- Soustraction anciennes valeurs montants sur entête contrat -----#
    If [F:POQ]QTYPUU<>0 & ([F:POQ]RCPQTYPUU<>0 | [F:POQ]INVQTYPUU<>0)
      If [F:POQ]INVQTYPUU>[F:POQ]RCPQTYPUU
        #----- Si article facturé avant réception ou jamais réceptionné -----#
        WTOTORD-=[F:POQ]LINAMT   *max([F:POQ]QTYPUU-[F:POQ]INVQTYPUU,0)/[F:POQ]QTYPUU
        WTTVORD-=[F:POQ]LINATIAMT*max([F:POQ]QTYPUU-[F:POQ]INVQTYPUU,0)/[F:POQ]QTYPUU
      Else
        #----- La réception partielle est permise pour l'inter-sites avec flux auto -----#
        WTOTORD-=[F:POQ]LINAMT   *max([F:POQ]QTYPUU-[F:POQ]RCPQTYPUU,0)/[F:POQ]QTYPUU
        WTTVORD-=[F:POQ]LINATIAMT*max([F:POQ]QTYPUU-[F:POQ]RCPQTYPUU,0)/[F:POQ]QTYPUU
      Endif
    Else
      WTOTORD-=[F:POQ]LINAMT
      WTTVORD-=[F:POQ]LINATIAMT
    Endif
    Gosub MAJ_ENTETE_POH
    If GOK<1 Goto AB_SOLDE : Endif
  Endif
  Raz WMSG
  #----- Mise à jour qtés avance-retard pour ligne article contrat -----#
  If [F:POQ]WIPSTA=1 & [F:POQ]LINSTA=2
    [F:POC]EARQTY-=[F:POQ]QTYPUU
  Endif
  #----- Mise à jour date avance-retard et nombre de prog DL -----#
  [F:POC]EARDAT=date$
  [F:POC]DLVREQNUM+=1
  #----- Mise a jour date et opérateur dernière modification -----#
  [F:POC]UPDUSR=GUSER
  [F:POC]UPDDAT=date$
  #----- Réécriture de la ligne article contrat -----#
  CLEFIC=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))
  WMSG=mess(13,100,1)-"PORDERC"-CLEFIC : # Erreur d'écriture sur le fichier ...
  Rewrite [POC]
  If fstat GOK=0  : Call FSTA("POC") From GLOCK : Goto AB_SOLDE : Endif
  Raz WMSG
  #----- Message : Ligne contrat XXXXXXXXXXXXXXX 99999999 modifiée ! -----#
  GMESSAGE=mess(243,197,1)-CLEFIC-mess(224,197,1) : Call ECR_TRACE(0) : Raz GMESSAGE
  #----- Modification de la ligne de DL -----#
  [F:POQ]LINSTA=3 : [F:POQ]LINCLEFLG=2
  #--------------------------------------------------------------#
  # Point d'entrée MAJDL pour alimentation de zones spécifiques  #
  # ------------------------------------------------------------ #
  # Variables utilisables par le point d'entrée                  #
  #                                                              #
  # TYPMAJ  : Type de mise à jour (4 = solde DL)                 #
  # FICHIER : Nom de la table qui va être écrite "PORDERQ"       #
  # ABRFIC  : Abréviation de la table qui va être écrite "POQ"   #
  # La  classe  [F:POQ] est modifiable avant le Write ou Rewrite #
  #--------------------------------------------------------------#
  TYPMAJ=4 : Gosub POINT_MAJDL From TRTACHPOD1
  #-----
  CLEFIC=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))
  WMSG=mess(12,100,1)-"PORDERQ"-CLEFIC : # Erreur d'accès sur le fichier ...
  Rewrite [POQ]
  If fstat
    GOK=0 : Call FSTA("POQ") From GLOCK
    Goto AB_SOLDE
  Endif
  Raz WMSG
  #---- Message : Demande de livraison XXXXXXXXXXXXXXX 9999999 9999999 soldée ! ----#
  GMESSAGE=mess(244,197,1)-CLEFIC-mess(263,197,1) : Call ECR_TRACE(0) : Raz GMESSAGE
  [M:PMG]ERRLIN(I)=0
  #----- Déblocage logique de l'entête de commande -----#
  If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
  #----- Déblocage logique de la ligne article contrat -----#
  If SYMBOL3<>"" Unlock=SYMBOL3 : Raz SYMBOL3 : Endif
Commit
Return
$ROLL_SOLDE
Rollback : Call ROLL From GLOCK
If GROLL
  Gosub AB_TRANSACTION_MSG
  Return
Else
  Goto TR_SOLDE
Endif
$AB_SOLDE
Rollback
Gosub AB_TRANSACTION_MSG
Return


#---------------------------------------------#
# Messages en cas d'abandon de la transaction #
#---------------------------------------------#
$AB_TRANSACTION_MSG
If WMSG<>"" GMESSAGE=WMSG : Call ECR_TRACE(1) : Endif
WMSG=GMESSAGE
GMESSAGE=mess(157,199,1)  : Call ECR_TRACE(1) : # Transaction abandonnée
GMESSAGE=WMSG : Raz WMSG
If [M:PMG]ERRCOD=0 [M:PMG]ERRCOD=99 : Endif
Return


#---------------------------------------------------------------------#
# Contrôles avant modification,suppression ou solde d'une ligne de DL #
#---------------------------------------------------------------------#
$CONTROLE
#----- Lecture entête commande -----#
Read [POH] POH0=[M:PMG]VCRNUM(I)
If fstat
  GMESSAGE=[M:PMG]VCRNUM(I)-mess(354,197,1) : Call ECR_TRACE(1)
  [M:PMG]ERRCOD=11 : Return
Endif
WBPSNUM=[F:POH]BPSNUM
WTOTORD=[F:POH]TOTORD
WTTVORD=[F:POH]TTVORD
#----- Lecture ligne article contrat -----#
Read [POC] POC0=[M:PMG]VCRNUM(I);[M:PMG]VCRLIN(I)
If fstat
  GMESSAGE=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-mess(249,197,1) : Call ECR_TRACE(1)
  [M:PMG]ERRCOD=12 : Return
Endif
#----- Lecture ligne DL -----#
Read [POQ] POQ0=[M:PMG]VCRNUM(I);[M:PMG]VCRLIN(I);[M:PMG]VCRSEQ(I)
If fstat
  GMESSAGE=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))-mess(250,197,1)
  Call ECR_TRACE(1)
  [M:PMG]ERRCOD=13 : Return
Endif
[M:PMG]WIPTYP(I)=[F:POQ]WIPTYP
[M:PMG]WIPSTA(I)=[F:POQ]WIPSTA
[M:PMG]WIPNUM(I)=[F:POQ]WIPNUM
[M:PMG]ITMREF(I)=[F:POQ]ITMREF
#----- Si statut non renseigné alors pas de changement -----#
If [M:PMG]MAJTYP=""
  If [F:POQ]WIPSTA=1 [M:PMG]MAJTYP="F" Else [M:PMG]MAJTYP="P" : Endif
Endif
#----- Modification interdite si commande soldée -----#
If ([M:PMG]MAJCOD="M" | [M:PMG]MAJCOD="S") & [F:POH]CLEFLG=2
  GMESSAGE=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))-mess(47,194,1)
  Call ECR_TRACE(1) : [M:PMG]ERRCOD=23 : # Commande soldée
  Return
Endif
#----- Modif ou suppression interdite si ligne soldée -----#
If [F:POQ]LINSTA=3
  GMESSAGE=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))-mess(32,194,1)
  Call ECR_TRACE(1) : [M:PMG]ERRCOD=24 : # Ligne DL soldée
  Return
Endif
#----- Solde d'une ligne impossible si cadencement semaine ou mois -----#
If [M:PMG]MAJCOD="S" & [F:POQ]CAD<>1
  GMESSAGE=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))-mess(92,194,1)
  Call ECR_TRACE(1) : [M:PMG]ERRCOD=25 : # Cadencement mois ou semaine
  Return
Endif
#----- Solde d'une ligne impossible si déja réceptionnée -----#
If [M:PMG]MAJCOD="S" & [F:POQ]PTHNUM<>""
  GMESSAGE=[M:PMG]VCRNUM(I)-num$([M:PMG]VCRLIN(I))-num$([M:PMG]VCRSEQ(I))-mess(93,194,1)
  Call ECR_TRACE(1) : [M:PMG]ERRCOD=26 : # Réception existe
  Return
Endif
#-----
If [F:POH]SALFCY<>""
  #----- Contrôles supplémentaires ventes si modif d'une ligne DL -----#
  If [M:PMG]MAJCOD="M"
    Raz [M:SORW]
    [M:SORW]MAJCOD   = "M"
    [M:SORW]SOHNUM   = [F:POQ]LINOCNNUM
    [M:SORW]SOPLIN   = [F:POQ]OCNLIN
    [M:SORW]SOQSEQ   = [F:POQ]OCNSEQ
    Call CTL_MAJ_SOQ From TRTVENMSIT
    If [M:SORW]ERRCOD<>0
      Call ECR_TRACE(1) : [M:PMG]ERRCOD=19 : Return
    Endif
  #----- Contrôles supplémentaires ventes si solde d'une ligne DL -----#
  Elsif [M:PMG]MAJCOD="S"
    Raz [M:SORW]
    [M:SORW]MAJCOD   = "S"
    [M:SORW]SOHNUM   = [F:POQ]LINOCNNUM
    [M:SORW]SOPLIN   = [F:POQ]OCNLIN
    [M:SORW]SOQSEQ   = [F:POQ]OCNSEQ
    Call CTL_MAJ_SOQ From TRTVENMSIT
    If [M:SORW]ERRCOD<>0
      Call ECR_TRACE(1) : [M:PMG]ERRCOD=20 : Return
    Endif
  #----- Contrôles supplémentaires ventes si suppression d'une ligne DL -----#
  Elsif [M:PMG]MAJCOD="A"
    Raz [M:SORW]
    [M:SORW]MAJCOD   = "A"
    [M:SORW]SOHNUM   = [F:POQ]LINOCNNUM
    [M:SORW]SOPLIN   = [F:POQ]OCNLIN
    [M:SORW]SOQSEQ   = [F:POQ]OCNSEQ
    Call CTL_MAJ_SOQ From TRTVENMSIT
    If [M:SORW]ERRCOD<>0
      Call ECR_TRACE(1) : [M:PMG]ERRCOD=21 : Return
    Endif
  Endif
Endif
#----- Blocage logique de l'entête commande -----#
SYMBOL2="POH"+[M:PMG]VCRNUM(I)
Lock=SYMBOL2
If fstat
  GMESSAGE="$PORDER"-[M:PMG]VCRNUM(I)-mess(10,100,1) : Call ECR_TRACE(1)
  [M:PMG]ERRCOD=37 : Return
Endif
#----- Chargement des paramètres -----#
WPOHFCY=[F:POH]POHFCY
Gosub CHARG_PARAM
If GMESSAGE<>"" Call ECR_TRACE(1) : Return : Endif
Return


#---------------------------#
# Chargement des paramètres #
#---------------------------#
$CHARG_PARAM
Raz GMESSAGE
Call DEFSITE(WPOHFCY) From TRTACHDEF1
Call GLOBVAR(WPOHFCY) From WWGLOBACH
If GMODU(2)=2
  Call GLOBVAR(GFINRSP) From WWGLOBBUD
Endif
Call DEFBUD("POH",WPOHFCY) From TRTACHDEF1
Call DEFRCPFCY(WPOHFCY)    From TRTACHDEF1
Call GETCPY(WPOHFCY,"",0,"") From TRTX3CPT  : If GFINRSP="" GFINRSP=WPOHFCY : Endif
#----- Lecture des affectations compteur si changement société -----#
If GSOC_UPDFLG
  If dim(OK)<1  Local Integer OK : Endif
  #------ Compteur des encours article ------#
  Call LECTCA(7,OK) From SUBTCA
  If fstat | !OK
    GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1) : [M:PMG]ERRCOD=2 : Return
  Endif
  GWIP=[F:TCA]CODNUM(8)
  #----- Contrôle longueur compteur pas supérieure à 15 caractères -----#
  #Call CTRCPT(GWIP,25,OK) From STKLIB
  #If OK<>0
  #  GMESSAGE=mess(222,199,1) : [M:PMG]ERRCOD=3 : Return
  #Endif
Endif
#-----
Return


#---------------------------------------#
# Ecriture du message ligne non traitée #
#---------------------------------------#
$ECR_NON_TRAITEE
WMSG=GMESSAGE
GMESSAGE=num$([M:PMG]WIPTYP(I))-[M:PMG]WIPNUM(I)-[M:PMG]ITMREF(I)-mess(225,197,1)
Call ECR_TRACE(1) : # 9 XXXXXXX XXXXXXX Ligne non traitée !
If [M:PMG]ERRCOD=0 [M:PMG]ERRCOD=99 : Endif
GMESSAGE=WMSG
Return


#-----------------------------------------#
# Ecriture du fichier trace si nécessaire #
#-----------------------------------------#
Subprog ECR_TRACE (TRAIT)
Value Integer TRAIT
# Issue X3-55891 - 2018-09-28 by SR : si création on force la trace puisqu'on a forcé son ouverture
If ([M:PMG]TRAFLG=2 | [M:PMG]MAJCOD="C")  & GMESSAGE<>""
  Call ECR_TRACE(GMESSAGE,TRAIT) From GESECRAN
  If GPURTRACE=1 GPURTRACE=2 : Endif
Endif
End


#---------------------------------------------#
# Contrôles zones en création ou modification #
#---------------------------------------------#
Subprog CONTROLE_ZONES (NOL,WBPSNUM)
Value Integer NOL
Value Char    WBPSNUM
Local Integer WOK
Local Libelle WLEC_POH, WLEC_POC
# Issue X3-55891 - 2018-09-28 by SR : Déclinaison par site
Local Integer WITMBPS, WRETOUR
Raz GMESSAGE
#----- Valeur par défaut des zones à contrôler -----#
If [M:PMG]MAJCOD<>"C" : # En modification
  [M:PMG]ITMREF(NOL)=[F:POQ]ITMREF
  [M:PMG]STU(NOL)   =[F:POQ]STU
  If [M:PMG]STOFCY(NOL)=""      [M:PMG]STOFCY(NOL)=[F:POQ]PRHFCY    : Endif
  If [M:PMG]PUU(NOL)   =""      [M:PMG]PUU(NOL)   =[F:POQ]PUU       : Endif
  If [M:PMG]ENDDAT(NOL)=[0/0/0] [M:PMG]ENDDAT(NOL)=[F:POQ]EXTRCPDAT : Endif
  If [M:PMG]EXTPUUQTY(NOL)=0 & [M:PMG]EXTSTUQTY(NOL)=0
    [M:PMG]EXTSTUQTY(NOL)=[F:POQ]QTYSTU
  Endif
  # Issue X3-55891 - 2018-10-05 by SR : Se positionner sur la bonne entête si besoin
  If [F:POH]POHNUM<>[F:POQ]POCNUM
      Read [POH] POH0=[F:POQ]POCNUM
      If fstat :  Raz [F:POH] : Endif
  Endif
Else                  : # En création
  If [M:PMG]ITMREF(NOL)=""       : # La référence article est nécessaire en création
    mkstat=1 : GMESSAGE=mess(107,194,1) : [M:PMG]ERRCOD=28 : End
  Endif
  If [M:PMG]STOFCY(NOL)<>""
    #----- Le site de réception doit être un dépôt -----#
    Read [FCY] FCY0=[M:PMG]STOFCY(NOL)
    If fstat
      Raz [F:FCY] : GMESSAGE=[M:PMG]STOFCY(NOL)-mess(14,14,1) : [M:PMG]ERRCOD=99 : End
    Endif
    If [F:FCY]WRHFLG<>2
      GMESSAGE=[M:PMG]STOFCY(NOL)-mess(58,199,1) : [M:PMG]ERRCOD=99 : End
    Endif
  Endif
  If [F:ITM]ITMREF<>[M:PMG]ITMREF(NOL)
    Read [ITM] ITM0=[M:PMG]ITMREF(NOL)
    If fstat
      Raz [F:ITM] : mkstat=1     : # Code article inexistant
      GMESSAGE=[M:PMG]ITMREF(NOL)-":"-mess(134,100,1) : [M:PMG]ERRCOD=29 : End
    Endif
  Endif
  # FQ 71491 GA 02/2011 test en cours: autoriser article non géré en stock
  #Call CONTROLE("ITM","I",[M:PMG]ITMREF(NOL),"",mkstat) From CONTOBJ
  #If mkstat                      : # Article non géré en stock
  #  [M:PMG]ERRCOD=30 : End
  #ELS
  If [F:ITM]ITMSTA<>1 & [F:ITM]ITMSTA<>3
    GMESSAGE=[M:PMG]ITMREF(NOL)-":"-mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")"
    mkstat=1 : [M:PMG]ERRCOD=30 : End
  Endif
  If [M:PMG]STU(NOL)<>[F:ITM]STU : # Unité de stock incorrecte !
    mkstat=1 : GMESSAGE=[M:PMG]STU(NOL)-mess(228,197,1)-"("+[F:ITM]STU+")"
    [M:PMG]ERRCOD=31 : End
  Endif
  If [M:PMG]PUU(NOL)="" [M:PMG]PUU(NOL)=[F:ITM]PUU : Endif
  #----- Contrôle site d'expédition dans le cas d'une TRx -----#
  If [M:PMG]WIPTYP(NOL)=7 & [M:PMG]WIPNUM(NOL)<>""
    #----- Recherche du site d'origine de la TRx (site d'expédition) -----#
    If [F:ORD]WIPTYP<>[M:PMG]WIPTYP(NOL) |
&      [F:ORD]WIPNUM<>[M:PMG]WIPNUM(NOL) |
&      [F:ORD]ITMREF<>[M:PMG]ITMREF(NOL)
      Read [ORD] ORD0=[M:PMG]WIPTYP(NOL);[M:PMG]WIPNUM(NOL);[M:PMG]ITMREF(NOL)
      If fstat  Raz [F:ORD] : Endif
    Endif
    If [F:ORD]ORIFCY<>""
      [M:PMG]ORIFCY(NOL)=[F:ORD]ORIFCY : # Site mal chargé par le programme appelant !
    Endif
    #-----
    Raz WLEC_POH, WLEC_POC
    If [F:POC]POHNUM<>[M:PMG]POCNUM(NOL) |
&      [F:POC]ITMREF<>[M:PMG]ITMREF(NOL) |
&      [F:POC]PRHFCY<>[M:PMG]STOFCY(NOL)
      Read [POC] POC1=[M:PMG]POCNUM(NOL);[M:PMG]ITMREF(NOL);[M:PMG]STOFCY(NOL)
      If !fstat  WLEC_POC=1  Else  Raz [F:POC] : Endif
    Endif
    If [F:POC]POHNUM<>""
      If [F:POC]STOFCY<>[M:PMG]ORIFCY(NOL)
        GMESSAGE =mess(92,198,1)-[F:POC]POHNUM-[F:POC]ITMREF-mess(284,194,1)
        GMESSAGE-="("+[F:POC]STOFCY+"<>"+[M:PMG]ORIFCY(NOL)+")"
        mkstat=1 : [M:PMG]ERRCOD=38 : End
      Endif
    Else
      If [F:POH]POHNUM<>[M:PMG]POCNUM(NOL)
        Read [POH] POH0=[M:PMG]POCNUM(NOL)
        If !fstat  WLEC_POH=1  Else  Raz [F:POH] : Endif
      Endif
      If [F:POH]POHNUM<>""
        If [F:POH]STOFCY<>[M:PMG]ORIFCY(NOL)
          GMESSAGE =mess(198,192,1)-[F:POH]POHNUM-mess(284,194,1)
          GMESSAGE-="("+[F:POH]STOFCY+"<>"+[M:PMG]ORIFCY(NOL)+")"
          mkstat=1 : [M:PMG]ERRCOD=38 : End
        Endif
      Endif
    Endif
    If WLEC_POH  Raz [F:POH] : Endif
    If WLEC_POC  Raz [F:POC] : Endif
  Endif
Endif
#----- Calcul quantité en UA ou US -----#
If [M:PMG]EXTSTUQTY(NOL)=0
  Call PCAL_QTY ([M:PMG]EXTPUUQTY(NOL),[M:PMG]PUU(NOL),[M:PMG]EXTSTUQTY(NOL),
&           [M:PMG]STU(NOL),[M:PMG]ITMREF(NOL),WBPSNUM,1,GBIDD1) From TRTACHQTE1
Else
  Call PCAL_QTY ([M:PMG]EXTSTUQTY(NOL),[M:PMG]STU(NOL),[M:PMG]EXTPUUQTY(NOL),
&           [M:PMG]PUU(NOL),[M:PMG]ITMREF(NOL),WBPSNUM,1,GBIDD1) From TRTACHQTE1
Endif
#----- Contrôle article-fournisseur -----#
If [M:PMG]MAJCOD="M"
  If [F:ITP]ITMREF<>[M:PMG]ITMREF(NOL) | [F:ITP]BPSNUM<>WBPSNUM
    # Issue X3-55891 - 2018-09-28 by SR : Déclinaison pas site
#    Read [ITP] ITP0=[M:PMG]ITMREF(NOL);WBPSNUM
#    If fstat
#      Raz [F:ITP]
#    Elsif [F:ITP]DOUFLG=3 : # Article douteux pour ce fournisseur !
#      mkstat=1 : GMESSAGE=[M:PMG]ITMREF(NOL)-WBPSNUM-mess(9,194,1)
#      [M:PMG]ERRCOD=32 : End
#    Endif
     Raz WITMBPS, WRETOUR
     # Intersite
     If [F:POH]BETFCY = 2 & [F:POF]BETCPY <> 2
        Call CTRL_DOUFLG(2,[M:PMG]ITMREF(NOL),WBPSNUM,[M:PMG]STOFCY(NOL),WITMBPS,WRETOUR) From TRTACHCTL1
     Else
        Call CTRL_DOUFLG(1,[M:PMG]ITMREF(NOL),WBPSNUM,[M:PMG]STOFCY(NOL),WITMBPS,WRETOUR) From TRTACHCTL1
     Endif
     If WRETOUR <> 0
       mkstat=1
       [M:PMG]ERRCOD=32
       End
     Endif
  Endif
  Call PCAL_QTY ([F:ITP]PURMINQTY,[F:ITP]PUU,GBIDD1,[M:PMG]STU(NOL),
&                [M:PMG]ITMREF(NOL),WBPSNUM,1,GBIDD2) From TRTACHQTE1
  #----- Test qté inférieure à qté minimum d'achat -----#
  #VPO 15/10/10 17730/59532 contrôle selon paramètre
  If GPOHMINQTY=0 : GPOHMINQTY=1 : Endif
  #If [M:PMG]EXTSTUQTY(NOL)<GBIDD1
  If [M:PMG]EXTSTUQTY(NOL)<GBIDD1 & GPOHMINQTY<3
     GMESSAGE=mess(14,194,1)-num$(GBIDD1)-[M:PMG]STU(NOL)
     If GPOHMINQTY=1
         mkstat=1 : [M:PMG]ERRCOD=33 : End
     Else : #GPOHMINQTY=2
          WOK=2
          Call AVERTIR (GMESSAGE, WOK)From GESECRAN
          If WOK=1
              Raz GMESSAGE
              mkstat=1 : [M:PMG]ERRCOD=33 : End
          Endif
          Raz GMESSAGE
     Endif
  Endif
  #----- Contrôles supplémentaires ventes pour quantité -----#
  If [F:POH]SALFCY<>""
    Raz [M:SORW]
    [M:SORW]MAJCOD   = "Q"
    [M:SORW]SOHNUM   = [F:POQ]LINOCNNUM
    [M:SORW]SOPLIN   = [F:POQ]OCNLIN
    [M:SORW]SOQSEQ   = [F:POQ]OCNSEQ
    [M:SORW]QTY      = [M:PMG]EXTPUUQTY(NOL)
    Call CTL_MAJ_SOQ From TRTVENMSIT
    If [M:SORW]ERRCOD<>0
      mkstat=1 : [M:PMG]ERRCOD=22 : End
    Endif
  Endif
Endif
#----- Contrôle quantité totale commandée supérieure à la quantité prévue -----#
Local Decimal WEXTQTYPUU, WRTNQTYPUU, WRCPQTYPUU, WCUMQTE
Local Char    WPOHNUM(GLONPOH)
Local Integer WPOPLIN
If !clalev([F:POCB])  Local File PORDERC [POCB] : Endif
If [M:PMG]MAJCOD="M"
  Read [POCB] POC0=[M:PMG]VCRNUM(NOL);[M:PMG]VCRLIN(NOL)
  If fstat  Raz [F:POCB] : Endif
  WCUMQTE=-[F:POQ]QTYPUU : # Quantité avant modif
Else
  Read [POCB] POC1=[M:PMG]POCNUM(NOL);[M:PMG]ITMREF(NOL);[M:PMG]STOFCY(NOL)
  If fstat  Raz [F:POCB] : Endif
  WCUMQTE=0
Endif
WEXTQTYPUU=[F:POCB]EXTQTYPUU  : WRTNQTYPUU=[F:POCB]RTNQTYPUU : WRCPQTYPUU=[F:POCB]RCPQTYPUU
WPOHNUM   =[F:POCB]POHNUM     : WPOPLIN   =[F:POCB]POPLIN
If WEXTQTYPUU<>0
  If !clalev([F:POQB])  Local File PORDERQ [POQB] : Endif
  For [POQB] POQ0 Where POHNUM=WPOHNUM & POPLIN=WPOPLIN & LINSTA<>3
    WCUMQTE+=[F:POQB]QTYPUU
  Next
  WCUMQTE+=[M:PMG]EXTPUUQTY(NOL)
  WCUMQTE+=WRCPQTYPUU
  WCUMQTE-=WRTNQTYPUU
  #----- La quantité est supérieure à la quantité globale -----#
  If [M:PMG]EXTPUUQTY(NOL)>WEXTQTYPUU
    GMESSAGE=mess(70,194,1)-"("+num$([M:PMG]EXTPUUQTY(NOL))-">"-num$(WEXTQTYPUU)
    GMESSAGE-=[M:PMG]PUU(NOL)+")"
  #----- La quantité totale commandée est supérieure à la quantité prévue -----#
  Elsif WCUMQTE>WEXTQTYPUU
    GMESSAGE=mess(91,194,1)-"("+num$(WCUMQTE)-">"-num$(WEXTQTYPUU)-[M:PMG]PUU(NOL)+")"
  Endif
  #----- Affichage des messages -----#
  If GMESSAGE<>""
    If GPOCQTY=2
      mkstat=1 : [M:PMG]ERRCOD=99 : End : # Contrôle bloquant
    Else
      Call ECR_TRACE(0) : Raz GMESSAGE  : # Contrôle non bloquant
    Endif
  Endif
Endif
End


#############################################################################
# CRE_POQSEQ : S/P de splittage de ligne en inter-site         HN  08/04/02 #
# Demande 13667                                                             #
# ------------------------------------------------------------------------- #
# Subprog CRE_POQSEQ                                                        #
#     ---------------- A l'appel du sous-programme --------------------     #
#     WPOHNUM    : No du contrat d'achat                                    #
#     WPOPLIN    : No de la ligne contrat-article d'achat                   #
#     WPOQSEQ    : No de séquence de la DL d'achat                          #
#     WSOQSEQ    : Nouveau No de séquence de la DL de vente                 #
#     WSDDQTY    : Quantité livrée par les ventes                           #
#     ---------------- Au retour du sous-programme --------------------     #
#     GOK      : Code erreur au retour du S/P                               #
#                1 = Ok pas d'erreur (mise à jour effectuée)                #
#               -1 = Enregistrement bloqué                                  #
#                0 = Erreur à la lecture/écriture                           #
#     GMESSAGE : Libellé du message erreur ou ""                            #
#############################################################################
Subprog CRE_POQSEQ(WPOHNUM,WPOPLIN,WPOQSEQ,WSOQSEQ,WSDDQTY)
Value   Char    WPOHNUM
Value   Integer WPOPLIN
Value   Integer WPOQSEQ
Value   Integer WSOQSEQ
Value   Decimal WSDDQTY
#----- Variables locales -----#
Local   Decimal WQTY, WQTYPUU, WQTYSTU, WRETQTYPUU, WRETQTYSTU
Local   Decimal WLINAMT, WLINATIAMT, WLINATI
Local   Libelle WFLG_FUSION
#----- Variables locales pour le point d'entrée MAJDL -----#
Local   Libelle TYPMAJ
Local   Char    FICHIER(GLONATB), ABRFIC(3)
#-----
Raz GMESSAGE
#-----
If !clalev([F:POH])   Local File PORDER    [POH] : Endif
If !clalev([F:POC])   Local File PORDERC   [POC] : Endif
If !clalev([F:POQ])   Local File PORDERQ   [POQ] : Endif
If !clalev([F:POQW])  Local File PORDERQ  [POQW] : Endif
If !clalev([F:POP])   Local File PORDERP   [POP] : Endif
If !clalev([F:TCA])   Local File TABCOUAFF [TCA] : Endif
If !clalev([F:ORD])   Local File ORDERS    [ORD] : Endif
If !clalev([F:TCO])   Local File TABCOEFF  [TCO] : Endif
#----- Masque paramètres encours -----#
If !clalev([M:ORDK])  Local Mask ORDK     [ORDK] : Endif
#----- Chargement et contrôle du compteur des encours -----#
If GWIP=""
  Read [TCA] TCA0=7
  If fstat
    GOK=0 : GMESSAGE=mess(58,105,1)-mess(8,14,1)-mess(250,199,1) : End
  Else
    GWIP=[F:TCA]CODNUM(8)
  Endif
Endif
#----- Si DL à créer existe, c'est une fusion -----#
Look [POQ] POQ0=WPOHNUM;WPOPLIN;WSOQSEQ
If fstat  WFLG_FUSION=0  Else  WFLG_FUSION=1 : Endif
#----- Lecture du PORDERQ d'origine -----#
Readlock [POQ] POQ0=WPOHNUM;WPOPLIN;WPOQSEQ
If fstat=1
  GOK=-1 : GLOCK="$PORDERQ"-WPOHNUM-num$(WPOPLIN)-num$(WPOQSEQ) : End
Elsif fstat
  GOK=0  : Call RSTA("POQ",WPOHNUM-num$(WPOPLIN)-num$(WPOQSEQ)) From GLOCK : End
Endif
#----- Lecture ligne article contrat pour date avance-retard -----#
Read [POC] POC0=WPOHNUM;WPOPLIN
If fstat  Raz [F:POC] : [F:POC]EARDAT=date$  : Endif
#----- Lecture entête pour arrondi avec devise -----#
Read [POH] POH0=WPOHNUM
If fstat  Raz [F:POH] : [F:POH]CUR=GLOCALDEV : Endif
#----- Calcul de la quantité de la DL a créer -----#
WQTY=[F:POQ]QTYPUU-WSDDQTY
If WQTY<=0  End : Endif
#----- Si fusion, désengagement de la DL à splitter -----#
If WFLG_FUSION
  Call TRTMAJCMM([F:POQ]POHNUM,[F:POQ]POPLIN,[F:POQ]POQSEQ,-1,2,"POQ1",0,GBIDI1) From TRTACHDIV1
Endif
#-----
WQTYPUU   =[F:POQ]QTYPUU
WQTYSTU   =[F:POQ]QTYSTU
WRETQTYPUU=[F:POQ]RETQTYPUU
WRETQTYSTU=[F:POQ]RETQTYSTU
WLINAMT   =[F:POQ]LINAMT
WLINATIAMT=[F:POQ]LINATIAMT
WLINATI   =[F:POQ]LINATI
#----- Mise à jour de la DL d'origine -----#
[F:POQ]QTYUOM=WSDDQTY
[F:POQ]QTYPUU=WSDDQTY
Call PCAL_QTY([F:POQ]QTYPUU,[F:POQ]PUU,[F:POQ]QTYSTU,[F:POQ]STU,[F:POQ]ITMREF,
&             [F:POQ]BPSNUM,1,GBIDD2) From TRTACHQTE1
#----- Mise à jour quantités besoins pris en compte -----#
If [F:POQ]RETQTYPUU>WSDDQTY
  [F:POQ]RETQTYPUU=[F:POQ]QTYPUU
  [F:POQ]RETQTYSTU=[F:POQ]QTYSTU
Endif
#----- Mise à jour des montants ligne HT et TTC -----#
[F:POQ]LINAMT   =WLINAMT   *[F:POQ]QTYPUU/WQTYPUU
Call ARRDEV([F:POQ]LINAMT,   [F:POH]CUR) From TRTDIV
[F:POQ]LINATIAMT=WLINATIAMT*[F:POQ]QTYPUU/WQTYPUU
Call ARRDEV([F:POQ]LINATIAMT,[F:POH]CUR) From TRTDIV
[F:POQ]LINATI   =WLINATI   *[F:POQ]QTYPUU/WQTYPUU
Call ARRDEV([F:POQ]LINATI   ,[F:POH]CUR) From TRTDIV
#--------------------------------------------------------------#
# Point d'entrée MAJDL pour alimentation de zones spécifiques  #
# ------------------------------------------------------------ #
# Variables utilisables par le point d'entrée                  #
#                                                              #
# TYPMAJ  : Type de mise à jour                                #
#             5 = éclatement DL (modification ancienne DL)     #
# FICHIER : Nom de la table qui va être écrite "PORDERQ"       #
# ABRFIC  : Abréviation de la table qui va être écrite "POQ"   #
# La  classe  [F:POQ] est modifiable avant le Write ou Rewrite #
#--------------------------------------------------------------#
TYPMAJ=5 : Gosub POINT_MAJDL From TRTACHPOD1
#-----
Rewrite [POQ]
If fstat
  GOK=0 : GMESSAGE=mess(149,192,1)-"PORDERQ:"-WPOHNUM-num$(WPOPLIN)-num$(WPOQSEQ) : End
Endif
#----- Modification de l'encours -----#
Read [ORD] ORD0=[F:POQ]WIPTYP;[F:POQ]WIPNUM;[F:POQ]ITMREF
If fstat  Raz [F:ORD] : Endif
Raz [M:ORDK]
[M:ORDK]          = [F:ORD]
[M:ORDK]MAJCOD    = "M"
[M:ORDK]WIPTYP    = [F:POQ]WIPTYP
[M:ORDK]WIPSTA    = 1
[M:ORDK]WIPNUM    = [F:POQ]WIPNUM
[M:ORDK]ITMREF    = [F:POQ]ITMREF
[M:ORDK]STOFCY    = [F:POQ]PRHFCY
[M:ORDK]PJT       = ""
[M:ORDK]BPRNUM    = [F:POQ]BPSNUM
[M:ORDK]STRDAT    = [F:POQ]ORDDAT
[M:ORDK]ENDDAT    = [F:POQ]EXTRCPDAT
[M:ORDK]VCRTYP    = 14
[M:ORDK]VCRNUM    = [F:POQ]POHNUM
[M:ORDK]VCRLIN    = [F:POQ]POPLIN
[M:ORDK]VCRSEQ    = [F:POQ]POQSEQ
[M:ORDK]EXTQTY    = [F:POQ]QTYSTU
[M:ORDK]CPLQTY    = 0
[M:ORDK]ALLQTY    = 0
[M:ORDK]SHTQTY    = 0
[M:ORDK]FMI       = 1
[M:ORDK]MRPMES    = 1
 # Issue 71276 - 2015-02-27 by SR : Versions
If dim([M:ORDK]ECCVALMAJ)> 0
  [M:ORDK]ECCVALMAJ = [F:POQ]ECCVALMAJ
  [M:ORDK]ECCVALMIN = [F:POQ]ECCVALMIN
Endif
# End Issue 71276
#----- Chargement infos origine si erreur lecture sur l'ordre à modifier -----#
If [F:ORD]WIPNUM=""
  If [F:POQ]WIPTYP=7
    [M:ORDK]ORIFCY    = [F:POQ]LINSTOFCY
    [M:ORDK]VCRTYPORI = 2
    [M:ORDK]VCRNUMORI = [F:POQ]LINOCNNUM
    [M:ORDK]VCRLINORI = [F:POQ]OCNLIN
    [M:ORDK]VCRSEQORI = [F:POQ]OCNSEQ
  Else
    [M:ORDK]ORIFCY    = [F:POQ]POHFCY
    [M:ORDK]VCRTYPORI = 0
    [M:ORDK]VCRNUMORI = ""
    [M:ORDK]VCRLINORI = 0
    [M:ORDK]VCRSEQORI = 0
  Endif
Endif
#-----
[M:ORDK]BOMALT = 0
[M:ORDK]ORI    = 1
[M:ORDK]ABBFIL = "POC"
Call WIP From TRTWIP
If GOK<1  GMESSAGE=mess(13,100,1)-"ORDERS:"-[F:POQ]WIPNUM : End : Endif
#----- Si fusion, réengagement de la DL correspondant à la livraison -----#
If WFLG_FUSION
Call TRTMAJCMM([F:POQ]POHNUM,[F:POQ]POPLIN,[F:POQ]POQSEQ,+1,2,"POQ1",0,GBIDI1) From TRTACHDIV1
  Gosub FUSION
Else
  Gosub SPLITTAGE
Endif
#-----
End

#--------------------------------------------------------------------#
#   Création ligne supplémentaire pour cde ouverte, POQ est chargé   #
# ------------------------------------------------------------------ #
# On est dans le cas de l'inter-sites et on crée une ligne qui       #
#    correspond au reste du POQ non livré par les ventes.            #
# le no de séquence est obligatoirement le même que celui des ventes #
#--------------------------------------------------------------------#
$SPLITTAGE
#-----
[F:POQ]POQSEQ = WSOQSEQ     : # Numéro de séquence         de la DL d'achat
[F:POQ]OCNSEQ = WSOQSEQ     : # Nouveau numéro de séquence de la DL vente
[F:POQ]POQLNK = mid$("00000000",1,8-len(num$([F:POQ]POPLIN)))+num$([F:POQ]POPLIN)
&             + mid$("00000000",1,8-len(num$([F:POQ]POQSEQ)))+num$([F:POQ]POQSEQ)
#-----
[F:POQ]QTYUOM = WQTY
[F:POQ]QTYPUU = WQTY
Call PCAL_QTY([F:POQ]QTYPUU,[F:POQ]PUU,[F:POQ]QTYSTU,[F:POQ]STU,[F:POQ]ITMREF,
&             [F:POQ]BPSNUM,1,GBIDD2) From TRTACHQTE1
[F:POQ]RCPQTYPUU = 0
[F:POQ]RCPQTYSTU = 0
[F:POQ]INVQTYSTU = 0
[F:POQ]INVQTYSTU = 0
#----- Mise à jour qtés besoins pris en compte -----#
[F:POQ]RETQTYPUU=WRETQTYPUU-[F:POQ]RETQTYPUU
[F:POQ]RETQTYSTU=WRETQTYSTU-[F:POQ]RETQTYSTU
#-----
If [F:POQ]DEMRCPDAT<[F:POC]EARDAT
  [F:POQ]LINSTA  = 2 : # ligne retard
Else
  [F:POQ]LINSTA  = 1 : # ligne attente
Endif
#-----
[F:POQ]LINRCPNBR = 0
[F:POQ]LININVNBR = 0
[F:POQ]INVRCPNBR = 0
[F:POQ]RCPCLEFLG = 1
[F:POQ]LINCLEFLG = 1
[F:POQ]LININVFLG = 1
[F:POQ]LINPRNFLG = 1
#----- Mise à jour des montants ligne HT et TTC -----#
[F:POQ]LINAMT    = WLINAMT   -[F:POQ]LINAMT
[F:POQ]LINATIAMT = WLINATIAMT-[F:POQ]LINATIAMT
[F:POQ]LINATI    = WLINATI   -[F:POQ]LINATI
#----- Création de l'encours -----#
Raz [F:POQ]WIPNUM
Call NUMERO(GWIP,[F:POQ]PRHFCY,date$,"",[F:POQ]WIPNUM,GBIDI1) From SUBANM
If GOK<0
  Return
Elsif GOK<1 | GBIDI1<>0
  GOK=0 : GMESSAGE=GWIP-mess(60,199,1) : Return
Endif
[M:ORDK]MAJCOD   = "C"
[M:ORDK]WIPTYP   = [F:POQ]WIPTYP
[M:ORDK]WIPSTA   = 1
[M:ORDK]WIPNUM   = [F:POQ]WIPNUM
[M:ORDK]ITMREF   = [F:POQ]ITMREF
[M:ORDK]STOFCY   = [F:POQ]PRHFCY
[M:ORDK]PJT      = ""
[M:ORDK]BPRNUM   = [F:POQ]BPSNUM
[M:ORDK]STRDAT   = [F:POQ]ORDDAT
[M:ORDK]ENDDAT   = [F:POQ]EXTRCPDAT
[M:ORDK]VCRTYP   = 14
[M:ORDK]VCRNUM   = [F:POQ]POHNUM
[M:ORDK]VCRLIN   = [F:POQ]POPLIN
[M:ORDK]VCRSEQ   = [F:POQ]POQSEQ
[M:ORDK]EXTQTY   = [F:POQ]QTYSTU
[M:ORDK]CPLQTY   = 0
[M:ORDK]ALLQTY   = 0
[M:ORDK]SHTQTY   = 0
[M:ORDK]FMI      = 1
[M:ORDK]MRPMES   = 1
# Issue 71276 - 2015-02-27 by SR : Versions
If dim([M:ORDK]ECCVALMAJ)> 0
   [M:ORDK]ECCVALMAJ = [F:POQ]ECCVALMAJ
   [M:ORDK]ECCVALMIN = [F:POQ]ECCVALMIN
Endif
# End issue 71276
[M:ORDK]BOMALT   = 0
[M:ORDK]ORI      = 1
[M:ORDK]ABBFIL   = "POC"
Call WIP From TRTWIP
If GOK<1  GMESSAGE=mess(13,100,1)-"ORDERS:"-[F:POQ]WIPNUM : Return : Endif
[F:POQ]PTHNUM    = ""
[F:POQ]PTDLIN    = 0
[F:POQ]EXPNUM    = 0
#-----
[F:POQ]CREUSR=GUSER
[F:POQ]CREDAT=date$
#--------------------------------------------------------------#
# Point d'entrée MAJDL pour alimentation de zones spécifiques  #
# ------------------------------------------------------------ #
# Variables utilisables par le point d'entrée                  #
#                                                              #
# TYPMAJ  : Type de mise à jour                                #
#             6 = éclatement DL (création nouvelle DL)         #
# FICHIER : Nom de la table qui va être écrite "PORDERQ"       #
# ABRFIC  : Abréviation de la table qui va être écrite "POQ"   #
# La  classe  [F:POQ] est modifiable avant le Write ou Rewrite #
#--------------------------------------------------------------#
TYPMAJ=6 : Gosub POINT_MAJDL From TRTACHPOD1
#-----
Write [POQ]
If fstat
  GOK=0
  GMESSAGE=mess(149,192,1)-"PORDERQ:"-[F:POQ]POHNUM-num$([F:POQ]POPLIN)
  GMESSAGE-=num$([F:POQ]POQSEQ)
Endif
Return

#----------------------------------------------------------#
# Ajout à une DL déjà existante le reliquat de la quantité #
#----------------------------------------------------------#
$FUSION
[F:POQW]=[F:POQ]
#-----
[F:POQW]QTYUOM = WQTY
[F:POQW]QTYPUU = WQTY
Call PCAL_QTY([F:POQW]QTYPUU,[F:POQW]PUU,[F:POQW]QTYSTU,[F:POQW]STU,[F:POQW]ITMREF,
&             [F:POQW]BPSNUM,1,GBIDD2) From TRTACHQTE1
#----- Mise à jour qtés besoins pris en compte -----#
[F:POQW]RETQTYPUU=WRETQTYPUU-[F:POQW]RETQTYPUU
[F:POQW]RETQTYSTU=WRETQTYSTU-[F:POQW]RETQTYSTU
#----- Mise à jour des montants ligne HT et TTC -----#
[F:POQW]LINAMT    = WLINAMT   -[F:POQW]LINAMT
[F:POQW]LINATIAMT = WLINATIAMT-[F:POQW]LINATIAMT
[F:POQW]LINATI    = WLINATI   -[F:POQW]LINATI
#----- Lecture de la DL qui va recevoir le reliquat de quantité -----#
Readlock [POQ] POQ0=WPOHNUM;WPOPLIN;WSOQSEQ
If fstat=1
  GOK=-1 : GLOCK="$PORDERQ"-WPOHNUM-num$(WPOPLIN)-num$(WSOQSEQ) : Return
Elsif fstat
  GOK=0  : Call RSTA("POQ",WPOHNUM-num$(WPOPLIN)-num$(WSOQSEQ)) From GLOCK : Return
Endif
#----- Désengagement de la DL avant fusion -----#
Call TRTMAJCMM([F:POQ]POHNUM,[F:POQ]POPLIN,[F:POQ]POQSEQ,-1,2,"POQ1",0,GBIDI1) From TRTACHDIV1
#-----
[F:POQ]QTYUOM   +=[F:POQW]QTYUOM
[F:POQ]QTYPUU   +=[F:POQW]QTYPUU
[F:POQ]QTYSTU   +=[F:POQW]QTYSTU
[F:POQ]RETQTYPUU+=[F:POQW]RETQTYPUU
[F:POQ]RETQTYSTU+=[F:POQW]RETQTYSTU
[F:POQ]LINAMT   +=[F:POQW]LINAMT
[F:POQ]LINATIAMT+=[F:POQW]LINATIAMT
[F:POQ]LINATI   +=[F:POQW]LINATI
#--------------------------------------------------------------#
# Point d'entrée MAJDL pour alimentation de zones spécifiques  #
# ------------------------------------------------------------ #
# Variables utilisables par le point d'entrée                  #
#                                                              #
# TYPMAJ  : Type de mise à jour                                #
#             6 = éclatement DL (création nouvelle DL)         #
# FICHIER : Nom de la table qui va être écrite "PORDERQ"       #
# ABRFIC  : Abréviation de la table qui va être écrite "POQ"   #
# La  classe  [F:POQ] est modifiable avant le Write ou Rewrite #
#--------------------------------------------------------------#
TYPMAJ=6 : Gosub POINT_MAJDL From TRTACHPOD1
#-----
Rewrite [POQ]
If fstat
  GOK=0 : GMESSAGE=mess(149,192,1)-"PORDERQ:"-WPOHNUM-num$(WPOPLIN)-num$(WPOQSEQ) : Return
Endif
#----- Modification de l'encours -----#
Read [ORD] ORD0=[F:POQ]WIPTYP;[F:POQ]WIPNUM;[F:POQ]ITMREF
If fstat  Raz [F:ORD] : Endif
Raz [M:ORDK]
[M:ORDK]          = [F:ORD]
[M:ORDK]MAJCOD    = "M"
[M:ORDK]WIPTYP    = [F:POQ]WIPTYP
[M:ORDK]WIPSTA    = 1
[M:ORDK]WIPNUM    = [F:POQ]WIPNUM
[M:ORDK]ITMREF    = [F:POQ]ITMREF
[M:ORDK]STOFCY    = [F:POQ]PRHFCY
[M:ORDK]PJT       = ""
[M:ORDK]BPRNUM    = [F:POQ]BPSNUM
[M:ORDK]STRDAT    = [F:POQ]ORDDAT
[M:ORDK]ENDDAT    = [F:POQ]EXTRCPDAT
[M:ORDK]VCRTYP    = 14
[M:ORDK]VCRNUM    = [F:POQ]POHNUM
[M:ORDK]VCRLIN    = [F:POQ]POPLIN
[M:ORDK]VCRSEQ    = [F:POQ]POQSEQ
[M:ORDK]EXTQTY    = [F:POQ]QTYSTU
[M:ORDK]CPLQTY    = 0
[M:ORDK]ALLQTY    = 0
[M:ORDK]SHTQTY    = 0
[M:ORDK]FMI       = 1
[M:ORDK]MRPMES    = 1
 # Issue 71276 - 2015-02-27 by SR : Versions
If dim([M:ORDK]ECCVALMAJ)> 0
   [M:ORDK]ECCVALMAJ = [F:POQ]ECCVALMAJ
   [M:ORDK]ECCVALMIN = [F:POQ]ECCVALMIN
Endif
# End issue 71276
#----- Chargement infos origine si erreur lecture sur l'ordre à modifier -----#
If [F:ORD]WIPNUM=""
  If [F:POQ]WIPTYP=7
    [M:ORDK]ORIFCY    = [F:POQ]LINSTOFCY
    [M:ORDK]VCRTYPORI = 2
    [M:ORDK]VCRNUMORI = [F:POQ]LINOCNNUM
    [M:ORDK]VCRLINORI = [F:POQ]OCNLIN
    [M:ORDK]VCRSEQORI = [F:POQ]OCNSEQ
  Else
    [M:ORDK]ORIFCY    = [F:POQ]POHFCY
    [M:ORDK]VCRTYPORI = 0
    [M:ORDK]VCRNUMORI = ""
    [M:ORDK]VCRLINORI = 0
    [M:ORDK]VCRSEQORI = 0
  Endif
Endif
#-----
[M:ORDK]BOMALT = 0
[M:ORDK]ORI    = 1
[M:ORDK]ABBFIL = "POC"
Call WIP From TRTWIP
If GOK<1  GMESSAGE=mess(13,100,1)-"ORDERS:"-[F:POQ]WIPNUM : Return : Endif
#----- Réengagement de la DL après fusion -----#
Call TRTMAJCMM([F:POQ]POHNUM,[F:POQ]POPLIN,[F:POQ]POQSEQ,+1,2,"POQ1",0,GBIDI1) From TRTACHDIV1
#-----
Return


##########################################################################
# CTL_PERIODE_POD : S/P de contrôle de la période de réception           #
# ---------------------------------------------------------------------- #
# Subprog CTL_PERIODE_POD  From TRTACHPOD1                               #
#   Les paramètres sont passés par l'écran PODMGT [POM]                  #
# Subprog CTL_PERIODE_POD1 From TRTACHPOD1                               #
#   Les paramètres sont passés par l'écran PURMGT [PMG]                  #
#     ----------------- A l'appel du sous-programme -------------------- #
#     WRCPDAT : Période de réception à contrôler                         #
#               saisie sous les formes suivantes JJ-MM-AA, AA-SSS, AA-MM #
#     ----------------- Au retour du sous-programme -------------------- #
#   Le contrôle est bon                                                  #
#     ERRCOD  : Code erreur au retour du S/P (0 = Ok pas d'erreur)       #
#     CAD     : Cadencement (1=Jour, 2=Semaine, 3=Mois)                  #
#     YEA     : Année                                                    #
#     MON     : Mois                                                     #
#     WEE     : Semaine                                                  #
#     WDATDEB : Date début de la période (JJMMAA)                        #
#     WDATFIN : Date fin   de la période (JJMMAA)                        #
#   Le contrôle détecte une erreur                                       #
#     ERRCOD  : Code erreur au retour du S/P (différent de zéro)         #
#               1 = XXXXXXXXXX Période de réception incorrecte !         #
#               9 = JJMMAA Date inférieure à la date du jour             #
#     GMESSAGE: Contient le texte de l'erreur                            #
#     mkstat  : L'indicateur est positionné à 2                          #
##########################################################################
Subprog CTL_PERIODE_POD
Local Char WDATE(10)
#----- Ouverture du nouveau masque écran -----#
If clalev([M:PMG])=0 Local Mask PURMGT [PMG] : Endif
[M:PMG]=[M:POM]
Gosub CTL_PERIODE
[M:POM]=[M:PMG]
End

Subprog CTL_PERIODE_POD1
Gosub CTL_PERIODE
End

#-------------------------------------#
# Contrôle de la période de réception #
#-------------------------------------#
$CTL_PERIODE
Raz GMESSAGE, mkstat, [M:PMG]ERRCOD
#----- Vérification zone période de réception prévue -----#
For I=1 To len([M:PMG]WRCPDAT)
  If ascii(mid$([M:PMG]WRCPDAT,I,1))>47 & ascii(mid$([M:PMG]WRCPDAT,I,1))<58
    WDATE+=mid$([M:PMG]WRCPDAT,I,1)
  Endif
Next I
Case len(WDATE)
  When 4 : Gosub LENDAT4 From SUBPODA : # Cadencement mois
  When 5 : Gosub LENDAT5 From SUBPODA : # Cadencement semaine
  When 6 : Gosub LENDAT6 From SUBPODA : # Cadencement jour ou mois
  When 7 : Gosub LENDAT7 From SUBPODA : # Cadencement semaine
  When 8 : Gosub LENDAT8 From SUBPODA : # Cadencement jour
  When Default [M:PMG]CAD=0
Endcase
If [M:PMG]CAD=0 : # XXXXXXXXXX Période de réception incorrecte !
  GMESSAGE=[M:PMG]WRCPDAT-mess(245,197,1)
  [M:PMG]ERRCOD=1 : mkstat=2 : Return
Endif
#----- Calcul date de réception prévue -----#
If [M:PMG]CAD=1
  Gosub CHARG_DATE_JOUR
Elsif [M]CAD=2
  [M]YEA     = val(right$(WDATE,5))
  [M]WEE     = val(left$(WDATE,3))
  [M]WDATDEB = aweek([M]WEE,[M]YEA)
  [M]WDATFIN = aweek([M]WEE,[M]YEA)+6
Else
  [M]YEA     = val(right$(WDATE,4))
  [M]MON     = val(left$(WDATE,2))
  [M]WDATDEB = gdat$(1,[M]MON,[M]YEA) : # Premier jour du mois
  [M]WDATFIN = eomonth([M]WDATDEB)    : # Dernier jour du mois
  [M]WEE     = week([M]WDATDEB)       : # 1ère semaine du mois
  If dayn([M]WDATDEB)>4
    [M]WEE+=1
    If [M]WEE=53 : # On regarde si 4ème jour semaine est sur année suivante
      If year(aweek([M]WEE,[M]YEA)+3)<>[M]YEA [M]WEE=1 : Endif
    Elsif [M]WEE=0
      [M]WEE=1
    Endif
    [M]WDATDEB = aweek([M]WEE,[M]YEA) : # 1er jour mois = 1er jour semaine
  Endif
Endif
#----- La date fin de période ne doit pas être inférieure à date du jour -----#
If [M]WDATFIN<date$
  GMESSAGE=num$([M]WDATFIN)-mess(65,194,1)
  [M:PMG]ERRCOD=9 : mkstat=2 : Return
Endif
Return

#---------------------------------------------------------------------#
# Chargement des zones date si la date de référence est une date jour #
#---------------------------------------------------------------------#
$CHARG_DATE_JOUR
#-----------------------------------------#
# GFMDAT="YY/MM/DD" et WDATE="AAAA-MM-JJ" #
#-----------------------------------------#
If left$(GFMDAT,2)="YY"
  [M]YEA     = val(left$(WDATE,4))
  [M]MON     = val(mid$(WDATE,6,2))
  [M]WDATDEB = gdat$(val(right$(WDATE,9)),[M]MON,[M]YEA)
#-----------------------------------------#
# GFMDAT="MM/DD/YY" et WDATE="MM-JJ-AAAA" #
#-----------------------------------------#
Elsif left$(GFMDAT,2)="MM" & right$(GFMDAT,len(GFMDAT)-1)="YY"
  [M]YEA     = val(right$(WDATE,7))
  [M]MON     = val(left$(WDATE,2))
  [M]WDATDEB = gdat$(val(mid$(WDATE,4,2)),[M]MON,[M]YEA)
#--------------------#
# WDATE="JJ-MM-AAAA" #
#--------------------#
Else
  [M]YEA     = val(right$(WDATE,7))
  [M]MON     = val(mid$(WDATE,4,2))
  [M]WDATDEB = gdat$(val(left$(WDATE,2)),[M]MON,[M]YEA)
Endif
[M]WDATFIN = [M]WDATDEB
[M]WEE     = week([M]WDATDEB)
If [M]WEE=53   : # On regarde si 4ème jour semaine est sur année suivante
  If year(aweek([M]WEE,[M]YEA)+3)<>[M]YEA [M]WEE=1 : Endif
Elsif [M]WEE=0 : # On regarde si 4ème jour semaine est sur année précédente
  If dayn(aweek([M]WEE,[M]YEA)+3)<4 [M]WEE=01 Else [M]WEE=53 : Endif
Endif
Return


#----------------------------------------------------------------#
# Recherche du numéro de séquence à affecter à la nouvelle ligne #
#----------------------------------------------------------------#
$RECH_POQSEQ
Raz WSEQPREC, WSEQSUIV, WCADPREC, WCADSUIV, WDELTA, WPOQSEQ, GMESSAGE
#-----
Local Integer WSTART, WSUPPL, WFLAG
Local Integer WDELTA_JOUR, WDELTA_SEQ
Local Date    WDATDEB1, WDATDEB2, WDATFIN2
#-----
Gosub POINT_SEQDEMDLV From TRTX3 : # Point d'entrée permettant d'ajuster le pas du séquencement
#-----
If !clalev([F:POQB])  Local File PORDERQ [POQB] : Endif
#If !clalev([F:POQC])  Local File PORDERQ [POQC] : Endif
#Columns [POQB] (POQSEQ, EXTRCPDAT, CAD, DEMRCPDAT)
#-----
Raz WSTART, WSUPPL, WDATDEB1, WDATDEB2, WDATFIN2, WFLAG
#----- Recherche de la DL précédente -----#
Filter [POQB] Where POHNUM=[F:POC]POHNUM & POPLIN=[F:POC]POPLIN &
&                   EXTRCPDAT<=[M:PMG]WDATFIN
Read [POQB] POQ0 Last
Filter [POQB]
If !fstat
  WSEQPREC=[F:POQB]POQSEQ
  WCADPREC=[F:POQB]CAD
  WSTART  =[F:POQB]POQSEQ
  WDATDEB2=[F:POQB]DEMRCPDAT
  While [F:POQB]DEMRCPDAT=WDATDEB2
    Read [POQB] POQ0 Prev
    If !fstat
      If [F:POQB]DEMRCPDAT=WDATDEB2  WSTART=[F:POQB]POQSEQ : Endif
    Else
      Raz [F:POQB]
    Endif
  Wend
Else
  WDATDEB2=min(date$-1,[M:PMG]WDATDEB)
Endif
WDATDEB1=WDATDEB2
#----- Si valeur maxi pas d'insertion possible -----#
If WSEQPREC=99999999 GMESSAGE=mess(122,199,1) : Return : Endif
#----- Recherche de la DL suivante -----#
Filter [POQB] Where POHNUM=[F:POC]POHNUM & POPLIN=[F:POC]POPLIN &
&                   EXTRCPDAT>[M:PMG]WDATFIN
Read [POQB] POQ0 First
Filter [POQB]
If !fstat
  WSEQSUIV=[F:POQB]POQSEQ
  WCADSUIV=[F:POQB]CAD
  WDATFIN2=[F:POQB]DEMRCPDAT
  #----- Si la date est identique, il faut repousser la numérotation -----#
  If [F:POQB]DEMRCPDAT=[M:PMG]WDATDEB
    WSUPPL=STEP2
  Endif
  #-----
  WDELTA_JOUR=WDATFIN2-WDATDEB2
  WDELTA_SEQ =WSEQSUIV-WSEQPREC
  #----- L'intervalle dispo n'est pas suffisant pour la numérotation optimisée -----#
  If WSEQSUIV-(WSTART+WSUPPL)<WDELTA_JOUR*STEP1 | WDELTA_SEQ<STEP2*2
    #----- Toutes les DL postérieures sont-elles supprimables ? -----#
    Raz mkstat
    For [POQB] POQ0 Where POHNUM=[F:POC]POHNUM
&                       & POPLIN=[F:POC]POPLIN
&                       & EXTRCPDAT>[M:PMG]WDATFIN
&                   With Stability
      If [F:POQB]LINSTA=3 | [F:POQB]INVQTYPUU<>0 | [F:POQB]INVQTYSTU<>0
        mkstat=1 : Break
      Endif
      If [F:POH]BETFCY=2 & [F:POH]SALFCY<>""
        Raz [M:SORW]
        [M:SORW]MAJCOD = "A"
        [M:SORW]SOHNUM = [F:POQB]LINOCNNUM
        [M:SORW]SOPLIN = [F:POQB]OCNLIN
        [M:SORW]SOQSEQ = [F:POQB]OCNSEQ
        Call CTL_MAJ_SOQ From TRTVENMSIT
        If GMESSAGE<>"" mkstat=1 : Break : Endif
      Endif
    Next
    If !mkstat
      WPOQSEQ=WSEQPREC-mod(WSEQPREC,STEP2)+WSUPPL
      For [POQB] POQ0 Where POHNUM=[F:POC]POHNUM
&                         & POPLIN=[F:POC]POPLIN
&                         & EXTRCPDAT>[M:PMG]WDATFIN
&                     With Stability
        CLEFIC=[F:POQB]POHNUM-num$([F:POQB]POPLIN)-num$([F:POQB]POQSEQ)
        GMESSAGE=mess(12,100,1)-"PORDERQ"-CLEFIC : # Erreur d'accès sur le fichier ...
        Readlock [POQB] Curr
        If fstat=1
          GOK=-1 : GLOCK="$PORDERQ"-CLEFIC : Break
        Elsif fstat
          GOK=0  : Call RSTA("POQ",CLEFIC) From GLOCK : Break
        Endif
        WDELTA_JOUR=[F:POQB]DEMRCPDAT-WDATDEB2
        If WDELTA_JOUR>0
          WPOQSEQ =max(WSTART+(WDELTA_JOUR*STEP1),WPOQSEQ+STEP2)
          WDATDEB2=[F:POQB]DEMRCPDAT
          WSTART  =WPOQSEQ
        Else
          WPOQSEQ+=STEP2
        Endif
        #----- Mise à jour encours avec nouvelle séquence -----#
        CLEFIC=num$([F:POQB]WIPTYP)-[F:POQB]WIPNUM-[F:POQB]ITMREF
        GMESSAGE=mess(13,100,1)-"ORDERS"-CLEFIC : # Erreur d'écriture sur le fichier ...
        Update [ORD] Where WIPTYP=[F:POQB]WIPTYP & WIPNUM=[F:POQB]WIPNUM & ITMREF=[F:POQB]ITMREF
&                    With  VCRSEQ=WPOQSEQ
        If fstat=1
          GLOCK="$ORDERS"-CLEFIC : GOK=-1 : Break
        Elsif fstat
          Call RSTA("ORD",CLEFIC) From GLOCK : GOK=0 : Break
        Endif
        #----- Mise à jour fichier liens demande-commande -----#
        CLEFIC=[F:POQB]POHNUM-num$([F:POQB]POPLIN)-num$([F:POQB]POQSEQ)
        GMESSAGE=mess(13,100,1)-"PREQUISO"-CLEFIC : # Erreur d'écriture sur le fichier ...
        Update [PSO] Where POHNUM=[F:POQB]POHNUM & POPLIN=[F:POQB]POPLIN & POQSEQ=[F:POQB]POQSEQ
&                    With  POQSEQ=WPOQSEQ
        If fstat=1
          GLOCK="$PREQUISO"-CLEFIC : GOK=-1 : Break
        Elsif fstat
          Call RSTA("PSO",CLEFIC) From GLOCK  : GOK=0 : Break
        Endif
        #----- Chargement nouvelle séquence -----#
        [F:POQB]POQSEQ=WPOQSEQ
        [F:POQB]POQLNK= mid$("00000000",1,8-len(num$([F:POQB]POPLIN)))+num$([F:POQB]POPLIN)
&                      +mid$("00000000",1,8-len(num$([F:POQB]POQSEQ)))+num$([F:POQB]POQSEQ)
        #----- Suppression ligne quantité (SORDERQ) -----#
        If [F:POH]SALFCY<>"" & [F:POQB]OCNLIN<>0
          Raz [M:SORW]
          [M:SORW]MAJCOD   = "A"
          [M:SORW]SOHNUM   = [F:POQB]LINOCNNUM
          [M:SORW]SOPLIN   = [F:POQB]OCNLIN
          [M:SORW]SOQSEQ   = [F:POQB]OCNSEQ
          Call MAJ_SOQ From TRTVENMSIT : If GOK<1  Break : Endif
          #----- Recréation ligne quantité avec nouvelle séquence (SORDERQ) -----#
          Raz [M:SORW]
          [M:SORW]MAJCOD   ="C"
          [M:SORW]SOHNUM   =[F:POH]OCNNUM
          [M:SORW]SALFCY   =[F:POH]SALFCY
          [M:SORW]BPCORD   =[F:POH]BPCORD
          [M:SORW]STOFCY   =[F:POQB]LINSTOFCY
          [M:SORW]PRHFCY   =[F:POQB]PRHFCY
          [M:SORW]VLYDATCON=[F:POH]ENDDAT
          [M:SORW]POHNUM   =[F:POH]POHNUM
          [M:SORW]SOPLIN   =[F:POC]POPLIN
          [M:SORW]ITMREF   =[F:POC]ITMREF
          [M:SORW]VLYDATITM=[F:POC]ENDDAT
          [M:SORW]EXTQTY   =[F:POC]EXTQTYPUU
          [M:SORW]SAU      =[F:POC]PUU
          [M:SORW]POPLIN   =[F:POC]POPLIN
          [M:SORW]DEMDLVDAT=[F:POQB]DEMRCPDAT
          [M:SORW]QTY      =[F:POQB]QTYPUU
          [M:SORW]DEMSTA   =[F:POQB]WIPSTA
          [M:SORW]USEPLC   =[F:POQB]USEPLC
          [M:SORW]CAD      =[F:POQB]CAD
          If [F:POQB]CAD=1
            [M:SORW]DLVDAY =val(left$(num$([F:POQB]DEMRCPDAT),2))
            [M:SORW]MON    =[F:POQB]MON
            [M:SORW]YEA    =[F:POQB]YEA
          Elsif [F:POQB]CAD=2
            [M:SORW]WEE    =[F:POQB]WEE
            [M:SORW]YEA    =[F:POQB]YEA
          Else
            [M:SORW]MON    =[F:POQB]MON
            [M:SORW]YEA    =[F:POQB]YEA
          Endif
          [M:SORW]POQSEQ   =[F:POQB]POQSEQ
          [M:SORW]SOQSTA   =[F:POQB]LINSTA
          # 95742 : PJT en inter société/inter site : (LD:21/04/16)
          # Le PJT transite uniquement en intersite
          If [F:POH]BETCPY=1
              [M:SORW]PJT=[F:POC]PJT
          Endif
          # 95742 : PJT en inter société/inter site : (LD:21/04/16)
          Call MAJ_SOQ From TRTVENMSIT : If GOK<1  Break : Endif
          [F:POQB]LINOCNNUM=[F:POH]OCNNUM
          [F:POQB]OCNLIN=[M:SORW]SOPLIN
          [F:POQB]OCNSEQ=[M:SORW]SOQSEQ
        Endif
        #----- Réécriture ligne DL avec nouvelle séquence -----#
        CLEFIC=[F:POQB]POHNUM-num$([F:POQB]POPLIN)-num$([F:POQB]POQSEQ)
        GMESSAGE=mess(13,100,1)-"PORDERQ"-CLEFIC : # Erreur d'écriture sur le fichier ...
        Rewrite [POQB]
        If fstat  GOK=0 : Call FSTA("POQ") From GLOCK : Break : Endif
        #-----
        Raz GMESSAGE
      Next
      If GOK<1  Return : Endif
    Else
      Raz mkstat, GMESSAGE : WFLAG=1
    Endif
  Endif
Endif
#----- Attribution du numéro de séquence pour nouvelle ligne -----#
If !WSEQPREC & !WSEQSUIV  WPOQSEQ=1000 : Return : Endif
WDELTA_JOUR=[M:PMG]WDATDEB-WDATDEB1
If !WFLAG
  #----- Numérotation optimisée -----#
  If WDELTA_JOUR>0
    WPOQSEQ=max(WSTART+(WDELTA_JOUR*STEP1),WSEQPREC-mod(WSEQPREC,STEP2)+STEP2)
  Else
    WPOQSEQ=WSEQPREC-mod(WSEQPREC,STEP2)+STEP2
  Endif
Else
  #----- Numérotation minimale -----#
  WDELTA=int(WDELTA_SEQ/max(WDELTA_JOUR+1,2))
  If WDELTA=0  GMESSAGE=mess(122,199,1) : Return : Endif
  If WDELTA_JOUR>0
    WPOQSEQ=WSEQPREC+(WDELTA_JOUR*WDELTA)
  Else
    WPOQSEQ=WSEQPREC+min(STEP2,WDELTA)
  Endif
Endif
Return


#------------------------------------------------------------------#
# Réajustement cadence et statut de la ligne à créer si nécessaire #
#------------------------------------------------------------------#
$AJUST_CADENCE_STATUT
Raz WSTA, GMESSAGE
If WCADPREC=0 WCADPREC=1 : Endif
If WCADSUIV=0 WCADSUIV=3 : Endif
If [M:PMG]CAD<WCADPREC [M:PMG]CAD=WCADPREC : WSTA=9 : Endif
If [M:PMG]CAD>WCADSUIV [M:PMG]CAD=WCADSUIV : WSTA=9 : Endif
#----- Si modif du cadencement alors réajustement des dates début et fin -----#
If WSTA=9
  If [M:PMG]CAD=1    : # Cadencement jour
    [M:PMG]WDATDEB = [M:PMG]WDATFIN         : # Date début égale à date fin
  Elsif [M:PMG]CAD=2 : # Cadencement semaine
    [M:PMG]WDATDEB = aweek([M]WEE,[M]YEA)   : # Premier jour de la semaine
    [M:PMG]WDATFIN = aweek([M]WEE,[M]YEA)+6 : # Dernier jour de la semaine
  Else               : # Cadencement mois
    [M:PMG]WDATDEB = gdat$(1,[M]MON,[M]YEA) : # Premier jour du mois
    [M:PMG]WDATFIN = eomonth([M]WDATDEB)    : # Dernier jour du mois
  Endif
Endif
#----- Réajustement statut si nécessaire -----#
If [M:PMG]MAJTYP="P" WSTA=2 Else WSTA=1 : Endif
If [M:PMG]CAD>1 & WSTA=1
  If WIPSTAFLG=0
    GMESSAGE=mess(246,197,1) : Call ECR_TRACE(0) : Raz GMESSAGE : WSTA=2
  Else
    GMESSAGE=mess(267,197,1)
  Endif
Endif
Return


#########################################################################
# RECH_CONTRAT : S/P de contrôle recherche de contrat                   #
# --------------------------------------------------------------------- #
# Subprog RECH_CONTRAT                                                  #
# --------------------------------------------------------------------- #
# Pre-requis les classes suivantes doivent être ouvertes                #
#    Local File PORDER     [POHB] : Endif                               #
#    Local File PORDERC    [POCB] : Endif                               #
# Paramètres en entrée                                                  #
# Pour rechercher un contrat et le contrôler                            #
#    WTRAIT       1 = recherche contrat classique                       #
#                 2 = recherche contrat inter-site                      #
#    WCLE       : Clé de départ                                         #
#    WSTOFCY    : Site demandeur      (obligatoire) site de réception   #
#    WLINSTOFCY : Site approvisionneur(obligatoire) site d'expé         #
#    WITMREF    : Référence article   (obligatoire)                     #
# Pour contrôler un contrat                                             #
#    WVCRNUM    : Numéro de contrat   (obligatoire)                     #
#    WITMREF    : Référence article   (obligatoire)                     #
#    WBPSNUM    : Numéro de fournisseur                                 #
# --------------------------------------------------------------------- #
# En sortie les zones suivantes sont renseigné                          #
#    WVCRNUM    : Numéro de contrat                                     #
#    WVCRLIN    : Numéro de lig de contrat                              #
#    WSALFCY    : Site de vente                                         #
#    WBPSNUM    : Fournisseur                                           #
#    WBPCORD    : Numéro de client                                      #
#    WSTRDAT    : Date début                                            #
#    WENDDAT    : Date fin                                              #
#    WPUU       : Unité d'achat                                         #
#    WPLC       : Lieu conso                                            #
#    WRET       : Code retour GMESSAGE chargé                           #
#########################################################################
Subprog RECH_CONTRAT(WTRAIT,WCLE,WSTOFCY,WLINSTOFCY, WITMREF,
&                    WVCRNUM,WVCRLIN,WSALFCY,WBPSNUM,WBPCORD,WSTRDAT,WENDDAT,
&                    WPUU,WPLC,WRET)
Value    Integer WTRAIT
Value    Char    WCLE
Value    Char    WSTOFCY
Value    Char    WLINSTOFCY
Value    Char    WITMREF
#Value    Char    LABR    # FQ 71491 GA 02/2011 ctrl des sources
Variable Char    WVCRNUM
Variable Integer WVCRLIN
Variable Char    WSALFCY
Variable Char    WBPSNUM
Variable Char    WBPCORD
Variable Date    WSTRDAT
Variable Date    WENDDAT
Variable Char    WPUU
Variable Char    WPLC
Variable Integer WRET
#----- Variables locales -----#
Local    Char    WBETCRIT(255)
Local    Integer I, MAXLIGNE
Local    Libelle OUVFICFLG
#----- Ouverture classes fichiers si nécessaire -----#
If !clalev([F:POHB])  Local File PORDER     [POHB] : Endif
If !clalev([F:POCB])  Local File PORDERC    [POCB] : Endif
If !clalev([F:BPR])   Local File BPARTNER   [BPR]  : Endif
If !clalev([F:BPR2])  Local File BPARTNER   [BPR2] : Endif
If !clalev([F:BPD])   Local File BPDLVCUST  [BPD]  : Endif
If !clalev([F:ITM])   Local File ITMMASTER  [ITM]  : Endif
If !clalev([F:ITM])   Local File ITMMASTER  [ITM]  : Endif
If !clalev([F:ITP])   Local File ITMBPS     [ITP]  : Endif
#-----
Raz [F:POHB], [F:POCB], WRET
#----- Filtre pour recherche d'une ligne de contrat -----#
WBETCRIT='STRDAT<=date$ & ENDDAT>=date$'
If WTRAIT=2
  WBETCRIT+=' & BETFCY=2'
Endif
If WITMREF<>""
  WBETCRIT+=' & ITMREF=WITMREF'
Endif
If WCLE<>""
  WBETCRIT+=' & POHNUM>WCLE'
Endif
If WSTOFCY<>""
  WBETCRIT+=' & PRHFCY=WSTOFCY'
Endif
If WLINSTOFCY<>""
  WBETCRIT+=' & STOFCY=WLINSTOFCY'
Endif
#----- Recherche d'une ligne de contrat -----#
Filter [POCB] Where evalue (WBETCRIT)
Read [POCB] POC2 First
Filter [POCB]
If fstat  Raz [F:POCB] : Endif
#----- Un ligne de contrat a été trouvée -----#
If [F:POCB]POHNUM<>""
  WVCRLIN   =[F:POCB]POPLIN
  WLINSTOFCY=[F:POCB]STOFCY
  WVCRNUM   =[F:POCB]POHNUM
  #----- Lecture du contrat -----#
  Read [POHB] POH0=[F:POCB]POHNUM
  If fstat  Raz [F:POHB] : WRET=1 : Gosub ERR_COD : End : Endif
#----- Aucune ligne trouvée, recherche d'un contrat -----#
Else
  #----- Récupération nombre de lignes maxi d'une commande ouverte -----# Bug 26036
  If !clalev([F:ACV])  Local File ACTIV [ACV] : OUVFICFLG=1 : Endif
  Read [ACV] CODACT="PCA" : If fstat Raz [F:ACV] : [F:ACV]DIME=20 : Endif
  MAXLIGNE=[F:ACV]DIME
  If OUVFICFLG=1  Close Local File [ACV] : Raz OUVFICFLG : Endif
  #-----
  WBETCRIT='POHTYP=2 & STRDAT<=date$ & ENDDAT>=date$ & CLEFLG<>2 & LINNBR<MAXLIGNE'
  If WTRAIT=2
    WBETCRIT+=' & BETFCY=2'
  Endif
  If WSTOFCY<>""
    WBETCRIT+=' & RCPFCY=WSTOFCY'
  Endif
  If WLINSTOFCY<>""
      WBETCRIT+=' & STOFCY=WLINSTOFCY'
  Endif
  If WCLE<>""
    WBETCRIT+=" & POHNUM>WCLE"
  Endif
  Filter [POHB] Where evalue(WBETCRIT)
  Read [POHB] POH0 First
  Filter [POHB]
  If fstat  Raz [F:POHB] : WRET=2 : Gosub ERR_COD : End : Endif
Endif
WVCRNUM=[F:POHB]POHNUM
#----- Vérification si le contrat est soldé ? -----#
If [F:POHB]CLEFLG=2  WRET=3 : Gosub ERR_COD : End : Endif
#----- Vérifications spécifiques au contrat inter-sites -----#
If [F:POHB]BETFCY=2
  Read [BPR] BPR0=[F:POHB]BPSNUM : If fstat  Raz [F:BPR] : Endif
  If [F:POHB]BPCORD<>""
    Read [BPR2] BPR0=[F:POHB]BPCORD : If fstat  Raz [F:BPR2] : Endif
  Endif
  If [F:POHB]SALFCY<>"" &
&   ([F:POHB]SALFCY<>[F:BPR]FCY     |
&    [F:POHB]BPCORD<>[F:BPR2]BPRNUM |
&    [F:POHB]BPSNUM<>[F:BPR]BPRNUM)
    WRET=4 : Gosub ERR_COD : End
  Endif
Endif
#-----
WSALFCY=[F:POHB]SALFCY
WBPCORD=[F:POHB]BPCORD
WBPSNUM=[F:POHB]BPSNUM
If [F:POCB]POPLIN<>0
  WVCRLIN = [F:POCB]POPLIN
  WSTRDAT = [F:POCB]STRDAT
  WENDDAT = [F:POCB]ENDDAT
  WPUU    = [F:POCB]PUU
  WPLC    = [F:POCB]USEPLC
Else
  WSTRDAT = [F:POHB]STRDAT
  WENDDAT = [F:POHB]ENDDAT
  Raz WPLC
  #----- Lecture si nécessaire de l'article ITMMASTER -----#
  If [F:ITM]ITMREF<>WITMREF
    Read [ITM] ITM0=WITMREF : If fstat  Raz [F:ITM] : Endif
  Endif
  #----- Récupération de la référence article chez le fournisseur -----#
  If [F:ITP]ITMREF<>WITMREF | [F:ITP]BPSNUM<>[F:POH]BPSNUM
    Read [ITP] ITP0=WITMREF;[F:POH]BPSNUM : If fstat  Raz [F:ITP] : Endif
  Endif
  #----
  If [F:ITP]PUU<>""  WPUU=[F:ITP]PUU  Else  WPUU=[F:ITM]PUU : Endif
Endif
End

#----------------------------------------------------------------------#
#                       Traitement des erreurs                         #
# -------------------------------------------------------------------- #
#  1 = xxxxxxxxxxxxxxx Le contrat n'existe pas !                       #
#  2 = Aucun contrat trouvé !                                          #
#  3 = Commande xxxxxxxxxxxxxxx soldée !                               #
#  4 = xxxxxxxxxxxxxxx Inter-sites : contrat non valide !              #
#----------------------------------------------------------------------#
$ERR_COD
Case WRET
  When  1 : GMESSAGE=[F:POCB]POHNUM-mess(354,197,1)
  When  2 : GMESSAGE=mess(283,194,1)
  When  3 : GMESSAGE=mess(98,197,1)-[F:POHB]POHNUM-mess(263,197,1)
  When  4 : GMESSAGE=[F:POHB]POHNUM-mess(310,194,1)
Endcase
Raz WVCRLIN, WSALFCY, WBPSNUM, WBPCORD, WSTRDAT, WENDDAT, WPUU, WPLC
Return


#################################################################
# Appel du point d'entrée MAJDL depuis :                        #
#     - le traitement TRTACHPOD1 (DL classiques et inter-sites) #
#     - les traitements SUBPTHA et SUBPTHB                      #
# ------------------------------------------------------------- #
# Point d'entrée MAJDL pour alimentation de zones spécifiques   #
# ------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                   #
#                                                               #
# TYPMAJ  : Type de mise à jour                                 #
#             1 = création DL                                   #
#             2 = modification DL                               #
#             3 = consommation DL                               #
#             4 = solde DL                                      #
#             5 = éclatement DL (modification ancienne DL)      #
#             6 = éclatement DL (création nouvelle DL)          #
#             7 = réception DL                                  #
# FICHIER : Nom de la table qui va être écrite "PORDERQ"        #
# ABRFIC  : Abréviation de la table qui va être écrite "POQ"    #
#           ou "POQW"                                           #
# La classe [F:POQ] ou [F:POQW] est modifiable avant le Write   #
#                                               ou le Rewrite   #
#################################################################
$POINT_MAJDL
FICHIER="PORDERQ"
If ABRFIC<>"POQW"  ABRFIC="POQ" : Endif
GPOINT="MAJDL" : Gosub ENTREE From EXEFNC
Return

