#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CLF1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone TYPCLD
mkstat = 0
zoncou = "TYPCLD"
indice = 0
IMPENT = [M]TYPCLD
If varinit([M]TYPCLD,indice)=0
 IMPENT = 1
Endif
[M]TYPCLD = IMPENT

## Zone PERIOD
mkstat = 0
zoncou = "PERIOD"
indice = 0
If varinit([M]PERIOD,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]PERIOD,"10702","") From SUBADI
 GACTION = SAVACT
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
WNUM = [M]NBLIG
If varmode([M]NBLIG,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBLIG From SUBCLF
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBLIG : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  If !mkstat
   If WNUM<>[M]NBLIG or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_NBLIG From SUBCLF
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "NBLIG" : GZNUM = 0 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone LEV
mkstat = 0
zoncou = "LEV"
IMPENT = [M]LEV(indice)
If varinit([M]LEV,indice)=0
 IMPENT = 1
Endif
If varmode([M]LEV,indice)=0
 [M]LEV(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "LEV" : Gosub ACTION From =IMPTRT
  IMPENT = [M]LEV(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "LEV" : GZNUM = 5230 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_LEV(IMPENT) From SUBCLF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "LEV" : GZNUM = 5230 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]LEV(indice) = IMPENT

## Zone POP
mkstat = 0
zoncou = "POP"
WCHAR = [M]POP(indice)
If varmode([M]POP,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_POP([M]POP(indice)) From SUBCLF
 GACTION = SAVACT
 If mkstat=1 : Raz [M]POP(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "POP" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]POP(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTPOP"
   Call CONTPOP([M]POP(indice),"") From SUBPOP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("POP","",[M]POP(indice),"",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "STD"
     Call C_POP([M]POP(indice)) From SUBCLF
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      If WCHAR<>[M]POP(indice) or IMPMOD
       SAVACT = GACTION : GACTION = "STD"
       Call AM_POP([M]POP(indice)) From SUBCLF
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
WCHAR = [M]LEG(indice)
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG(indice),"909","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]LEG,indice)=0
  SAVACT = GACTION : GACTION = "STD"
  Call AS_LEG([M]LEG(indice)) From SUBCLF
  GACTION = SAVACT
  If mkstat=1 : Raz [M]LEG(indice) : Endif
