# Supervisor
## CRUD-CLASSE ## EMPLOCHD
# 2018-11-06 07:06:02 343

Gosub TEST From WMCR_EMPLOCHD : End

############################################################################################
## C : Subprog AINSERT(INSTANCE)
## D : Subprog ADELETE(INSTANCE)
## R : Subprog AREAD(INSTANCE,REFNUM,NUMLIG)
## U : Subprog AUPDATE(INSTANCE)
############################################################################################
# EMPLOCHD : EMPLOCHD
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet EMPLOCHD._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = EMPLOCHD.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(EMPLOCHD.ACTX.AFOLDER,nomap,"")>0
 Local File EMPLOCHD [CHD]
 Local File EMPLOCHD [AAA_]
Else
 Local File =EMPLOCHD.ACTX.AFOLDER+".EMPLOCHD" [CHD]
 Local File =EMPLOCHD.ACTX.AFOLDER+".EMPLOCHD" [AAA_]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCHD.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [CHD] With
& [AAA_]CHD0 = REFNUM+NUMLIG
& As [LNK_]
Return

############################################################################################
### EMPLOCHD(WCHD)
############################################################################################
Funprog  _MAJSQL_EMPLOCHD(WCHD)
Variable Instance WCHD Using C_EMPLOCHD
Local Integer ASTATUS,A_I,A_J
Default File [F:CHD]
If WCHD.ASTALIN=[V]CST_ANEW
 Call INICRE(WCHD) From ASYRSUB
 SetInstance [F:CHD] With WCHD
 Write [F:CHD]
 If fstat
  Call FSTA("CHD",WCHD,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WCHD.updTick = [F:CHD]updTick
Elsif WCHD.ASTALIN=[V]CST_ALL or WCHD.ASTALIN=[V]CST_AUPD
 Call INIUPD(WCHD) From ASYRSUB
 SetInstance [F:CHD] With WCHD
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WCHD,"EMPLOCHD")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:CHD]CHD0 = [F:CHD]REFNUM;[F:CHD]NUMLIG
 If fstat
  Call FSTA("CHD",WCHD,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WCHD.updTick = [F:CHD]updTick
Elsif WCHD.ASTALIN=[V]CST_ADEL
 SetInstance [F:CHD] With WCHD
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WCHD,"EMPLOCHD")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:CHD]CHD0 = [F:CHD]REFNUM;[F:CHD]NUMLIG
 If fstat
  Call FSTA("CHD",WCHD,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK



