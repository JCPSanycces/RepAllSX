#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* BALAGEEOY report LAW LME (french)
#*
#* US : X3-17765
#*
#
# CBO   23.11.2017 X3-59739    DATEVT replaces PAYDAT (case when PAYDAT is empty)
#
#
#
#*
#*
#* BALAGEEOY   [BGY]
#* CODBLK :
#* only one enreg :
#* = 1   Synthèse
#*
#* n enreg for each case : corresponding to the calculated amount :
#* = 20  Delay 0 day   (A posted)
#* = 30  Delay 30 days (A posted)
#* = 40  Delay 60 days (A posted)
#* = 50  Delay 90 days (A posted)
#* = 60  Delay more 90 days (A posted)
#* = 100 FIY
#* = 200 Excluded (B)
#* = 300 Not posted (A not posted)
#* = 400 multi BPR
#* When FLGTOTPURSAL  = [V]CST_AYES, it is for FIY too
#*
#*
#* Petit résumé / Little summary
#*
#* 3 cas principaux / 3 main cases :
#*
#*
#* factures comptabilisées : traitement par la table HISTODUD
#* Invoices posted : processing by table HISTODUD
#*
#* sub-pro : from TRAIT_GAS to INSERT_BGY
#*  CALC_TTC_ALL_DUD
#*  CALCUL_HT_GAS
#*
#* factures achats/ventes non comptabilisées : traitement par les tables SINVOICE et PINVOICE
#* Unposted purchases / sales invoices: processing by SINVOICE and PINVOICE tables
#*
#*  sub-pro : from TRAIT_INVOICE_NOT_POSTED, TRAIT_XINV to INSERT_BGY_XINV
#*  ->     W_TOTAL_HT_AMOUNT et W_TOTAL_TTC_AMOUNT sont obtenus directement
#*  ->     [F:XIH]AMTNOTL et [F:XIH]AMTATIL sont stockés en base
#*
#* Dispatch the HT amount on each dud :
#* -> loop on GACCDUDATE
#*    SYNTHESE_AND_DETAIL_XINV
#*    PREPARE_INSERT_BGY_XINV
#*    INSERT_BGY_XINV
#*
#* factures tiers clients/fournisseurs non comptabilisées : traitement par les tables SINVOICE et PINVOICE
#* Invoices third-party customers / suppliers not posted : processing by SINVOICE and PINVOICE tables
#*
#*  sous-pro : de TRAIT_INVOICE_NOT_POSTED, TRAIT_XINV à INSERT_BGY_XINV
#*  ->     W_TOTAL_HT_AMOUNT et W_TOTAL_TTC_AMOUNT doivent être calculés (boucle sur GACCDUDATE)
#*  ->     [F:XIH]AMTNOTL et [F:XIH]AMTATIL sont à 0
#*  ->     prorata done in TRAIT_XINV_DUD
#*
#* Dispatch the HT amount on each dud :
#* -> loop on GACCDUDATE (if more than one)
#*    TRAIT_XINV_DUD
#*    SYNTHESE_AND_DETAIL_XINV
#*    PREPARE_INSERT_BGY_XINV
#*    INSERT_BGY_XINV
#*
#*
#*!

Local Char PARAM(10)(1..3) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AIMP1","AIMP1",4,"") From GTRAITE
End

$ACTION
Case ACTION
 When "OUVRE"   : Gosub OUVRE  From CPTRPT
 When "INIPAR"  : Gosub INIPAR From CPTRPT
 When "INIPAR2" : Gosub INIPAR From CPTRPT : # X3-22084
 When "CONT1"   : Gosub CONT1
Endcase
Return

$CONT1
  # X3-22084
  If [M]PARCOD(nolign-1) = "societe"
   Local Integer K
   K = find("societe",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
   Read [CPY]CPY0 = [M:RPT]VALINT1(K-1)
   If !fstat and [F:CPY]CPYLEGFLG<>2
    GMESSAGE = mess(130,121,1)
    mkstat=2
    Return
   Endif
  Endif

  # X3-22084
  Case [M]PARCOD(nolign-1)
   When "grpacol","grpbcol"
    If [F:LED]COA = ""
     Local Integer K
     K = find("societe",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
     Read [CPY]CPY0 = [M:RPT]VALINT1(K-1)
     Read [GCM]GCM0 = [F:CPY]ACM
     Read [LED]LED0 = [F:GCM]LED([F:GCM]GENLEDTYP-1)
    Endif
   When "borne1"
    Gosub CHECK_BORNES
   When "borne2"
    Gosub CHECK_BORNES
   When "borne3"
    Gosub CHECK_BORNES
   When "borne4"
    Gosub CHECK_BORNES
  Endcase
  If mkstat=2 : Return : Endif
Return

$CHECK_BORNES
  # X3-22084
  Local Integer I, K
  Local Integer BORNE1, BORNE2, BORNE3, BORNE4
  Raz BORNE1,BORNE2,BORNE3,BORNE4
  K = find("borne1",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
  BORNE1 = val([M:RPT]VALINT1(K-1))
  K = find("borne2",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
  BORNE2 = val([M:RPT]VALINT1(K-1))
  K = find("borne3",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
  BORNE3 = val([M:RPT]VALINT1(K-1))
  K = find("borne4",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
  BORNE4 = val([M:RPT]VALINT1(K-1))

  # Controls if intervals of days are entered in the ascending order
  For I=2 To 4
    If evalue("BORNE"+num$(I))<=evalue("BORNE"+num$(I-1))
      GMESSAGE = mess(207,104,1)
      mkstat=2
      Break
    Endif
  Next I
Return

####################################################
## Etats BALAGEEOY
####################################################
Subprog IMPRIME(NBPAR, PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Char PTYP(50), PNUM(50)
Local Date PSTRDAT, PENDDAT
####################################################
## Vérif paramètres
####################################################
  GOK = 1
  Call IMPRIME(NBPAR, PARAMETRE) From CPTRPT
  If GOK < 1
    End
  Endif

  Call TEMPON("O") From GESECRAN

  Gosub LOAD_PARAM

  Gosub OUVFIC

####################################################
## Affectation du no de requête
####################################################
  PARAM = num$(NUMREQ)
  Call SETPARAM("numedt", NBPAR, PARAMETRE, PARAM) From ETAT

####################################################
## Effacement table temporaire
####################################################

  Call DEBTRANS From GLOCK
  Gosub DEL_ENREG

  Gosub SET_CRITERES

# Boucle CPY ____________________________________________________________________________

  For [CPY]CPY0 Where CPY = SOCIETE

    Gosub TRAIT_CPY

  Next

  Call TEMPOFF From GESECRAN

End

#**
#* Read parameters
#*!
$LOAD_PARAM

Local Integer WNBRDUD1, WNBRDUD2
Local Decimal WAMTNOTDUD1, WAMTNOTDUD2, WAMTNOTDUD3, WAMTNOTDUD4, WAMTNOTDUD5, WAMTNOTDUDTOT
Local Decimal WAMTNOTINV
Local Integer WNBRDUDEXD
Local Decimal WAMTNOTDUDEXD

Local Char    PARAM(30) , ETAT(GLONARP)
Local Integer NUMREQ , LIGNE, SV_DUDLIG, WB_BLOCA, WB_BLOCB, WBSALES
Local Integer I , J , WCASE_SEL, WBLOCK_NUM, WMULTITIERS, WNB_DAYS, WCD_BLK,
&             WBOOL_CALC_TOT_TTC_DUD, WNB_DUD_OK, WIND_DUD_OK, W_IS_OK, W_ONE_SENS, WNB_XIH_OK
Local Tinyint WLEDTYPGEN, WLEDTYPANA, WLEDTYPIAS
Local Decimal WPRORATA_DUD

Local Decimal W_TOTAL_TTC_AMOUNT, W_ONE_TTC_AMOUNT
Local Decimal W_TOTAL_HT_AMOUNT, WCURRND, WDUD_HT_AMOUNT, WDUD_HT_AMOUNT_NOT_PAID, WDUD_CUMUL_HT_AMOUNT

Local Char WLEDCOD(30), WLEDCUR(GLONCUR)

Local Char    SOCIETE(GLONCPY), SITDEB(GLONFCY), SITFIN(GLONFCY)
Local Char    COLADEB(GLONSAC), COLAFIN(GLONSAC), GRPACOL(GLONGSC)
Local Char    COLBDEB(GLONSAC), COLBFIN(GLONSAC), GRPBCOL(GLONGSC)
Local Char    TIERSDEB(GLONBPR), TIERSFIN(GLONBPR)
Local Integer BORNE1, BORNE2, BORNE3, BORNE4

Local Integer SENS_CRIT
Local Date    WFIYSTR, WFIYEND
Local Integer DETLATPAY, DETTOTPURSAL, DETDOUBTFUL, DETMULTIBP

Local Integer WFLGTOTPURSAL
Local Integer WNUMFIY       : # Number of the fiscal year
Local Date    WSTRDATFIY    : # Start date of the fiscal year
Local Date    WENDDATFIY    : # End date of the fiscal year

Local Clbfile SEL_CRIT, SEL_COLTOT, SEL_COLA, SEL_COLB
Local Clbfile SEL_CRIT_XINV, SEL_COLTOT_XINV, SEL_COLA_XINV, SEL_COLB_XINV
Local Clbfile SEL_CRIT_YEAR

Local Char    X3PRF(GLONAPM) , X3FCT(GLONAFC)
Local Char    SVG_FLGEVT(50), ERRMES(250), WCOA(GLONCOA), WACC(GLONGAC)


  Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) : NUMREQ = val(PARAM)
  Call GETPARAM("X3ETA",NBPAR,PARAMETRE,PARAM)

  J = instr(1, PARAM, ".")
  If J
    PARAM = left$(PARAM, J - 1)
  Endif
  ETAT = PARAM

  Call GETPARAM("societe", NBPAR, PARAMETRE, SOCIETE)
  Call GETPARAM("sitedeb", NBPAR, PARAMETRE, SITDEB)
  Call GETPARAM("sitefin", NBPAR, PARAMETRE, SITFIN)

  Call GETPARAM("coladeb", NBPAR,PARAMETRE, COLADEB)
  Call GETPARAM("colafin", NBPAR, PARAMETRE, COLAFIN)
  Call GETPARAM("grpacol", NBPAR, PARAMETRE, GRPACOL)

  Call GETPARAM("colbdeb", NBPAR, PARAMETRE, COLBDEB)
  Call GETPARAM("colbfin", NBPAR, PARAMETRE, COLBFIN)
  Call GETPARAM("grpbcol", NBPAR, PARAMETRE, GRPBCOL)

  Call GETPARAM("tiersdeb", NBPAR, PARAMETRE, TIERSDEB)
  Call GETPARAM("tiersfin", NBPAR, PARAMETRE, TIERSFIN)

  Call GETPARAM("borne1", NBPAR, PARAMETRE, PARAM)
  BORNE1      = val(PARAM)
  Call GETPARAM("borne2", NBPAR, PARAMETRE, PARAM)
  BORNE2      = val(PARAM)
  Call GETPARAM("borne3", NBPAR, PARAMETRE, PARAM)
  BORNE3      = val(PARAM)
  Call GETPARAM("borne4", NBPAR, PARAMETRE, PARAM)
  BORNE4      = val(PARAM)

  Call GETPARAM("datref", NBPAR, PARAMETRE, PARAM)
  WFIYEND   = PARAM

  Call GETPARAM("sens", NBPAR, PARAMETRE, PARAM)
  SENS_CRIT  = val(PARAM)

  Call GETPARAM("detlatpay",NBPAR,PARAMETRE,PARAM)
  DETLATPAY      = val(PARAM)
  Call GETPARAM("dettotpursal",NBPAR,PARAMETRE,PARAM)
  DETTOTPURSAL      = val(PARAM)
  Call GETPARAM("detdoubtful",NBPAR,PARAMETRE,PARAM)
  DETDOUBTFUL      = val(PARAM)
  Call GETPARAM("detmultibp",NBPAR,PARAMETRE,PARAM)
  DETMULTIBP      = val(PARAM)

  Call GETPARAM("X3PRF",NBPAR,PARAMETRE,X3PRF)
  Call GETPARAM("X3FCT",NBPAR,PARAMETRE,X3FCT)

Return

#*
#* prepare the selected datas for :
# SEL_CRIT for HISTODUD
# SEL_CRIT_XINV for S/PINVOICE
# SEL_CRIT_YEAR for sum of HT amounts (Year)
#*
$SET_CRITERES

  Raz SEL_CRIT, SEL_COLTOT, SEL_COLA, SEL_COLB, SEL_CRIT_YEAR
  Raz SEL_CRIT_XINV, SEL_COLTOT_XINV, SEL_COLA_XINV, SEL_COLB_XINV

  Call ADDCRIT(SEL_CRIT, '[HDU]CPY = "' + SOCIETE + '"')
  Call ADDCRIT(SEL_CRIT_XINV, '[XIH]CPY = "' + SOCIETE + '"')

  If SITDEB <> ""
    Call ADDCRIT(SEL_CRIT, '[HDU]FCY >= "' + SITDEB + '"')
    Call ADDCRIT(SEL_CRIT_XINV, '[XIH]FCY >= "' + SITDEB + '"')
  Endif
  If SITFIN <> ""
    Call ADDCRIT(SEL_CRIT, '[HDU]FCY <= "' + SITFIN + '"')
    Call ADDCRIT(SEL_CRIT_XINV, '[XIH]FCY <= "' + SITFIN + '"')
  Endif

  If TIERSDEB <> ""
    Call ADDCRIT(SEL_CRIT, '[HDU]BPR >= "' + TIERSDEB + '"')
    Call ADDCRIT(SEL_CRIT_XINV, '[XIH]BPR >= "' + TIERSDEB + '"')
  Endif
  If TIERSFIN <> ""
    Call ADDCRIT(SEL_CRIT, '[HDU]BPR <= "' + TIERSFIN + '"')
    Call ADDCRIT(SEL_CRIT_XINV, '[XIH]BPR <= "' + TIERSFIN + '"')
  Endif

  If COLADEB <> ""
    Call ADDCRIT(SEL_CRIT_YEAR, "[DAE]SAC >= '" + COLADEB + "'")
  Endif
  If COLAFIN <> ""
    Call ADDCRIT(SEL_CRIT_YEAR, "[DAE]SAC <= '" + COLAFIN + "'")
  Endif
  If TIERSDEB <> ""
    Call ADDCRIT(SEL_CRIT_YEAR, "[DAE]BPR >= '" + TIERSDEB + "'")
  Endif
  If TIERSFIN <> ""
    Call ADDCRIT(SEL_CRIT_YEAR, "[DAE]BPR <= '" + TIERSFIN + "'")
  Endif
  If SITDEB <> ""
    Call ADDCRIT(SEL_CRIT_YEAR, "[DAE]FCYLIN >= '" + SITDEB + "'")
  Endif
  If SITFIN <> ""
    Call ADDCRIT(SEL_CRIT_YEAR, "[DAE]FCYLIN <= '" + SITFIN + "'")
  Endif

  If SEL_CRIT_YEAR = ""
    SEL_CRIT_YEAR = "1=1"
  Endif
  # Collective accounts :

  # A block_________________________________________________

  If (COLADEB <> "" or COLAFIN <> "" or GRPACOL <> "")
    WB_BLOCA = 1
  Else
    WB_BLOCA = 0
  Endif

  If COLADEB <> ""
    SEL_COLA = '([HDU]SAC >= "' + COLADEB + '"'
    SEL_COLA_XINV = '([XIH]BPRSAC >= "' + COLADEB + '"'
  Endif

  If COLAFIN = ""
    If SEL_COLA <> ""
      SEL_COLA += ")"
      SEL_COLA_XINV += ")"
    Endif
  Else
    If SEL_COLA = ""
      SEL_COLA = '([HDU]SAC <= "' + COLAFIN + '")'
      SEL_COLA_XINV = '([XIH]BPRSAC <= "' + COLAFIN + '")'
    Else
      SEL_COLA -= 'and [HDU]SAC <= "' + COLAFIN + '")'
      SEL_COLA_XINV -= 'and [XIH]BPRSAC <= "' + COLAFIN + '")'
    Endif
  Endif

  # B block_________________________________________________

  If (COLBDEB <> "" or COLBFIN <> "" or GRPBCOL <> "")
    WB_BLOCB = 1
  Else
    WB_BLOCB = 0
  Endif

  If COLBDEB <> ""
    SEL_COLB = '([HDU]SAC >= "' + COLBDEB + '"'
    SEL_COLB_XINV = '([XIH]BPRSAC >= "' + COLBDEB + '"'
  Endif

  If COLBFIN = ""
    If SEL_COLB <> ""
      SEL_COLB += ")"
      SEL_COLB_XINV += ")"
    Endif
  Else
    If SEL_COLB = ""
      SEL_COLB = '([F:HDU]SAC <= "' + COLBFIN + '")'
      SEL_COLB_XINV = '([XIH]BPRSAC <= "' + COLBFIN + '")'
    Else
      SEL_COLB -= 'and [F:HDU]SAC <= "' + COLBFIN + '")'
      SEL_COLB_XINV -= 'and [XIH]BPRSAC <= "' + COLBFIN + '")'
    Endif
  Endif

Return

$INIT_SYNTHESE

Raz WNBRDUD1, WNBRDUD2
Raz WAMTNOTDUD1, WAMTNOTDUD2, WAMTNOTDUD3, WAMTNOTDUD4, WAMTNOTDUD5, WAMTNOTDUDTOT
Raz WAMTNOTINV, WNBRDUDEXD, WAMTNOTDUDEXD

Return

$TRAIT_CPY

  ASTATUS = func FINACM_SYRA.GET_MAINLEDTYP(GACTX, [F:CPY]CPY, WLEDTYPGEN, WLEDTYPANA, WLEDTYPIAS, ERRMES)
  ASTATUS = func FINACM_SYRA.GET_LEDCUR(GACTX, [F:CPY]CPY, WLEDTYPGEN, WLEDCOD, WLEDCUR, ERRMES)

  Call LEC_TCU(WLEDCUR) From CPTLEC
  WCURRND = [F:TCU]CURRND
  Call LEC_LED(WLEDCOD) From CPTLEC
  Filter [FIY] Where CPY = [F:CPY]CPY and LEDTYP = WLEDTYPGEN and FIYEND = WFIYEND
  Read [FIY]FIY0 First
  Filter [FIY]
  WFIYSTR = [F:FIY]FIYSTR
  WCOA = fmet GACTX.ACACHE.LED.AGETVALCHAR(WLEDCOD, "LEDCOA")

  # Search of the start date of the fiscal year + the end date ofthe fiscal year
  ASTATUS = func FINPER_SYRA.GET_FIY(GACTX, [F:CPY]CPY, WLEDTYPGEN, [F:FIY]FIYSTR, WNUMFIY, ERRMES)
  ASTATUS = func FINPER_SYRA.GET_FIYDATES(GACTX, [F:CPY]CPY, WLEDTYPGEN, WNUMFIY, WSTRDATFIY, WENDDATFIY, ERRMES)

  Gosub INIT_SYNTHESE

  Call CAL_AMTNOTINV([F:CPY]CPY, GRPACOL, SEL_CRIT_YEAR,
&                    X3PRF, X3FCT,
&                    WSTRDATFIY, WENDDATFIY, WNUMFIY, WLEDTYPGEN,
&                    WAMTNOTINV)

  If SENS_CRIT = 2
    WAMTNOTINV = -WAMTNOTINV
  Endif

####################################################
## Parcours des écritures
####################################################

  GOK = 1
  LIGNE = 0
  Call DEBTRANS From GLOCK
  Trbegin [BGY]

#CHECK FILE_DECLARE HISTODUD [HD2]

# ____________________________________________________________________________________________________
# Enregs in HISTODUD, GACCENTRY (posted or NOT)
# We must find records using the following links

  # 3° parameter : SEL COLa
  If SEL_COLA <> ""
    WCASE_SEL = 3
    SEL_COLTOT = SEL_CRIT
    Call ADDCRIT(SEL_COLTOT, SEL_COLA)

    Link [HDU] With
&            [HAE]HAE0   ~= [F:HDU]TYP; [F:HDU]NUM,
&            [GTES]GTE1(2)= [F:HAE]TYP; [F:CPY]LEG,
&            [GTE]GTE0   ~= [F:GTES]TYP; [F:GTES]LEG,
&            [BPR]BPR0   ~= [F:HDU]BPR,
&            [ACC]CODACC ~= GUSER; [F:BPR]ACS,
&            [AFF]AFF0   ~= [F:HDU]FCY; X3PRF; X3FCT
&     As [LNK]
&     Where evalue(SEL_COLTOT) and
&          [F:HDU]TYPDUD = 2 and [F:HDU]DATEVT <= [L]WFIYEND and
&          [HAE]CAT = 1 and [F:GTE]PER = 1

    Gosub TRAIT_GAS
    If GOK = 0
      Rollback
      Return
    Endif
  Endif

  # 4° parameter : SEL GRPaCOL
  If GRPACOL <> ""
    WCASE_SEL = 4
    SEL_COLTOT = SEL_CRIT
    If SEL_COLTOT = ""
      SEL_COLTOT = "1=1"
    Endif

    Link [HDU] With
&            [HAE]HAE0   ~= [F:HDU]TYP; [F:HDU]NUM,
&            [GTES]GTE1(2)= [F:HAE]TYP; [F:CPY]LEG,
&            [GTE]GTE0   ~= [F:GTES]TYP; [F:GTES]LEG,
&            [GSC]GSC1   ~= [F:LED]COA; GRPACOL; [F:HDU]SAC,
&            [BPR]BPR0   ~= [F:HDU]BPR,
&            [ACC]CODACC ~= GUSER; [F:BPR]ACS,
&            [AFF]AFF0   ~= [F:HDU]FCY; X3PRF; X3FCT
&     As [LNK]
&     Where evalue(SEL_COLTOT) and
&          [F:HDU]TYPDUD = 2 and [F:HDU]DATEVT <= [L]WFIYEND and
&          [HAE]CAT=1 and [F:GTE]PER=1

    Gosub TRAIT_GAS
    If GOK = 0
      Rollback
      Return
    Endif
  Endif

  # 5° parameter : SEL COLb
  If SEL_COLB <> ""
    WCASE_SEL = 5
    SEL_COLTOT = SEL_CRIT
    Call ADDCRIT(SEL_COLTOT, SEL_COLB)

    Link [HDU] With
&            [HAE]HAE0   ~= [F:HDU]TYP; [F:HDU]NUM,
&            [GTES]GTE1(2)= [F:HAE]TYP; [F:CPY]LEG,
&            [GTE]GTE0   ~= [F:GTES]TYP; [F:GTES]LEG,
&            [BPR]BPR0   ~= [F:HDU]BPR,
&            [ACC]CODACC ~= GUSER; [F:BPR]ACS,
&            [AFF]AFF0   ~= [F:HDU]FCY; X3PRF; X3FCT
&     As [LNK]
&     Where evalue(SEL_COLTOT) and
&          [F:HDU]TYPDUD = 2 and [F:HDU]DATEVT <= [L]WFIYEND and
&          [HAE]CAT=1 and [F:GTE]PER=1

    Gosub TRAIT_GAS
    If GOK = 0
      Rollback
      Return
    Endif
  Endif

  # 6° parameter : SEL GRPbCOL
  If GRPBCOL <> ""
    WCASE_SEL = 6
    SEL_COLTOT = SEL_CRIT
    If SEL_COLTOT = ""
      SEL_COLTOT = "1=1"
    Endif

    Link [HDU] With
&            [HAE]HAE0   ~= [F:HDU]TYP; [F:HDU]NUM,
&            [GTES]GTE1(2)= [F:HAE]TYP; [F:CPY]LEG,
&            [GTE]GTE0   ~=[F:GTES]TYP; [F:GTES]LEG,
&            [GSC]GSC1   ~= [F:LED]COA; GRPBCOL; [F:HDU]SAC,
&            [BPR]BPR0   ~= [F:HDU]BPR,
&            [ACC]CODACC ~= GUSER; [F:BPR]ACS,
&            [AFF]AFF0   ~= [F:HDU]FCY; X3PRF; X3FCT
&     As [LNK]
&     Where evalue(SEL_COLTOT) and
&          [F:HDU]TYPDUD = 2 and [F:HDU]DATEVT <= [L]WFIYEND and
&          [HAE]CAT=1 and [F:GTE]PER=1

    Gosub TRAIT_GAS
    If GOK = 0
      Rollback
      Return
    Endif
  Endif

# ____________________________________________________________________________________________________
# No enreg in GACCENTRY when invoice is not validated (posted)
# We must find records using SINVOICE or PINVOICE

# X3-26273

  # SINVOICE ______________________________

  If clalev([F:XIH])
    Close File [XIH]
  Endif
  Local File SINVOICE [XIH]
  WBSALES = 1

  Gosub TRAIT_INVOICE_NOT_POSTED
  If GOK = 0
    Rollback
    Return
  Endif

  # PINVOICE ______________________________

  If clalev([F:XIH])
    Close File [XIH]
  Endif
  Local File PINVOICE [XIH]
  WBSALES = 0

  Gosub TRAIT_INVOICE_NOT_POSTED

  If clalev([F:XIH])
    Close File [XIH]
  Endif
  If GOK = 0
    Rollback
    Return
  Endif

# ____________________________________________________________________________________________________

  # write the final synthese record
  If GOK
    Gosub INSERT_BGY_SYNTHESE
  Endif

  If GOK
    Commit
  Else
    Rollback
  Endif

Return

#**
#* SINVOICE and PINVOICE parth of developpement ___________________________________________________________
#*!
$TRAIT_INVOICE_NOT_POSTED

  # 3B° parameter : SEL COLa for SINVOICE (ventes) not posted
  If SEL_COLA <> ""
    WCASE_SEL = 3
    WBLOCK_NUM = 3                          # A block (selected but not posted)
    SEL_COLTOT = SEL_CRIT_XINV
    Call ADDCRIT(SEL_COLTOT, SEL_COLA_XINV)

    Link [XIH] With
&            [GTES]GTE1(2) = [F:XIH]GTE; [F:CPY]LEG,
&            [GTE]GTE0    ~= [F:GTES]TYP; [F:GTES]LEG,
&            [BPR]BPR0    ~= [F:XIH]BPR,
&            [ACC]CODACC  ~= GUSER; [F:BPR]ACS,
&            [AFF]AFF0    ~= [F:XIH]FCY; X3PRF; X3FCT
&     As [LNK]
&     Where evalue(SEL_COLTOT) and
&          [F:XIH]STA < 3 and
&          [F:XIH]INVTYP <> 5 and
&          [F:XIH]ACCDAT <= [L]WFIYEND and
&          [F:GTE]PER = 1

    Gosub TRAIT_XINV
    If GOK = 0
#      Rollback # X3-36073
      Return
    Endif
  Endif

  # 4B° parameter : SEL GRPaCOL for SINVOICE (ventes) not posted
  If GRPACOL <> ""
    WCASE_SEL = 4
    WBLOCK_NUM = 3                          # A block (selected but not posted)
    SEL_COLTOT = SEL_CRIT_XINV
    If SEL_COLTOT = ""
      SEL_COLTOT = "1=1"
    Endif

    Link [XIH] With
&            [GTES]GTE1(2) = [F:XIH]GTE; [F:CPY]LEG,
&            [GTE]GTE0    ~= [F:GTES]TYP; [F:GTES]LEG,
&            [GSC]GSC1    ~= [F:LED]COA; GRPACOL; [F:XIH]BPRSAC,
&            [BPR]BPR0    ~= [F:XIH]BPR,
&            [ACC]CODACC  ~= GUSER; [F:BPR]ACS,
&            [AFF]AFF0    ~= [F:XIH]FCY; X3PRF; X3FCT
&     As [LNK]
&     Where evalue(SEL_COLTOT) and
&          [F:XIH]STA < 3 and
&          [F:XIH]INVTYP <> 5 and
&          [F:XIH]ACCDAT <= [L]WFIYEND and
&          [F:GTE]PER = 1

    Gosub TRAIT_XINV
    If GOK = 0
#      Rollback # X3-36073
      Return
    Endif
  Endif

  # 5B° parameter : SEL COLb for SINVOICE (ventes) not posted
  If SEL_COLB <> ""
    WCASE_SEL = 5
    WBLOCK_NUM = 3                          # B block (selected but not posted)
    SEL_COLTOT = SEL_CRIT_XINV
    Call ADDCRIT(SEL_COLTOT, SEL_COLB_XINV)

    Link [XIH] With
&            [GTES]GTE1(2) = [F:XIH]GTE; [F:CPY]LEG,
&            [GTE]GTE0    ~= [F:GTES]TYP; [F:GTES]LEG,
&            [BPR]BPR0    ~= [F:XIH]BPR,
&            [ACC]CODACC  ~= GUSER; [F:BPR]ACS,
&            [AFF]AFF0    ~= [F:XIH]FCY; X3PRF; X3FCT
&     As [LNK]
&     Where evalue(SEL_COLTOT) and
&          [F:XIH]STA < 3 and
&          [F:XIH]INVTYP <> 5 and
&          [F:XIH]ACCDAT <= [L]WFIYEND and
&          [F:GTE]PER = 1

    Gosub TRAIT_XINV
    If GOK = 0
#      Rollback # X3-36073
      Return
    Endif
  Endif

  # 6B° parameter : SEL GRPbCOL for SINVOICE (ventes) not posted
  If GRPBCOL <> ""
    WCASE_SEL = 6
    WBLOCK_NUM = 3                          # B block (selected but not posted)
    SEL_COLTOT = SEL_CRIT_XINV
    If SEL_COLTOT = ""
      SEL_COLTOT = "1=1"
    Endif

    Link [XIH] With
&            [GTES]GTE1(2) = [F:XIH]GTE; [F:CPY]LEG,
&            [GTE]GTE0    ~= [F:GTES]TYP; [F:GTES]LEG,
&            [GSC]GSC1    ~= [F:LED]COA; GRPBCOL; [F:XIH]BPRSAC,
&            [BPR]BPR0    ~= [F:XIH]BPR,
&            [ACC]CODACC  ~= GUSER; [F:BPR]ACS,
&            [AFF]AFF0    ~= [F:XIH]FCY; X3PRF; X3FCT
&     As [LNK]
&     Where evalue(SEL_COLTOT) and
&          [F:XIH]STA < 3 and
&          [F:XIH]INVTYP <> 5 and
&          [F:XIH]ACCDAT <= [L]WFIYEND and
&          [F:GTE]PER = 1

    Gosub TRAIT_XINV
    If GOK = 0
#      Rollback # X3-36073
      Return
    Endif
  Endif

Return

# point avec CSB le 21-02-2017
#De ce que je vois, la valeur de SNS dans SINVOICE est en phase avec la valeur de SNS dans GACCDUDATE.
#Par contre, la valeur de SNS dans PINVOICE n’est pas en phase avec la valeur de SNS dans GACCDUDATE.
#Ils sont de signe inverse. Quand SNS de PIH vaut 1 (facture fournisseur par ex), il vaut -1 dans GACCDUDATE.

#Pour moi, le montant dans AMTNOTL, tu dois le prendre tel quel. Il est >0 ou <0 (rare) (ex : FCASN17VEN00000017 GESSIH dans GX3APP)
#Et après, suivant que c’est du côté client ou fournisseur, que c’est une facture ou un avoir et suivant
#le sens de présentation choisi dans BALAGEEOY, ce montant sera ou non x-1

#Pour les factures Achats/Ventes, vu le constat fait juste plus haut, si tu prends SNS de SIH/PIH :
#- Pour les factures GESSIH/Ventes, tu prends AMTNOTL directement et tu appliques l’algo plus bas en
#regardant le SNS de SINVOICE (comme il est idem à celui de GACCDUDATE).
#- Pour les factures GESPIH/Achats, tu prends AMTNOTL directement et soit tu prends le SNS de GACCDUDATE pour
#appliquer l’algo plus bas ; soit tu utilises le SNS de PINVOICE en ayant pris soin au préalable de l’avoir multiplier par -1 (pour le ‘transformer’/’aligner’ à la même valeur que SNS de GACCDUDATE)
# et tu lui appliques ensuite l’algo ci-dessous.

$TRAIT_XINV

  If WBSALES
    For [F:LNK]SIH0 Nohint
      Gosub TRAIT_XINV_DETAIL
      If GOK = 0
        Break
      Endif
    Next
  Else
    For [F:LNK]PIH0 Nohint
      Gosub TRAIT_XINV_DETAIL
      If GOK = 0
        Break
      Endif
    Next
  Endif

Return

$TRAIT_XINV_DETAIL

  WNB_XIH_OK = 0
  WDUD_CUMUL_HT_AMOUNT = 0
  # HT amount of SINVOICE
  If [F:XIH]ORIMOD = 5 or [F:XIH]ORIMOD = 6

    W_TOTAL_HT_AMOUNT = func F_SENS([F:XIH]AMTNOTL, [F:XIH]SNS, SENS_CRIT, [F:XIH]ORIMOD)
    W_TOTAL_TTC_AMOUNT = func F_SENS([F:XIH]AMTATIL, [F:XIH]SNS, SENS_CRIT, [F:XIH]ORIMOD)

  Else # tiers

    # Sum the TTC amount of all duds
    W_TOTAL_TTC_AMOUNT = 0
    Filter [DUD] Where TYP = [F:XIH]GTE and NUM = [F:XIH]NUM #and DUDDAT <= [L]WFIYEND
    For [DUD]DUD0
      W_TOTAL_TTC_AMOUNT += func F_SENS([F:DUD]AMTLOC, [F:DUD]SNS, SENS_CRIT, [F:XIH]ORIMOD)
      WNB_XIH_OK += 1
    Next
    Filter [DUD]

    # Calc the HT amount of all duds
    If [F:XIH]AMTATI
      W_TOTAL_HT_AMOUNT = arr(W_TOTAL_TTC_AMOUNT * abs((1 - (([F:XIH]AMTATI - [F:XIH]AMTNOT) / [F:XIH]AMTATI))), WCURRND)
    Else
      W_TOTAL_HT_AMOUNT = 0
    Endif
  Endif

  If W_TOTAL_HT_AMOUNT
    WIND_DUD_OK = 0
    WDUD_CUMUL_HT_AMOUNT = 0
    WDUD_HT_AMOUNT = 0

    If [F:XIH]ORIMOD = 5 or [F:XIH]ORIMOD = 6

      # Dispatch the HT amount on each dud
      Filter [DUD] Where TYP = [F:XIH]GTE and NUM = [F:XIH]NUM
      For [DUD]DUD0

        # write the precedent record
        If WDUD_HT_AMOUNT

          Call LEC_SAC([F:DUD]SAC, WCOA)
          WACC = [F:GAC]ACC
          WAMTNOTDUDEXD += WDUD_HT_AMOUNT
          [F:BGY]AMTNOT = WDUD_HT_AMOUNT
          [F:BGY]AMTNOTDUD = WDUD_HT_AMOUNT
          Gosub INSERT_BGY_XINV
          If GOK = 0
            WDUD_HT_AMOUNT = 0
            Break
          Endif

        Endif
        WDUD_HT_AMOUNT = 0

        # calculs the current record
        WDUD_HT_AMOUNT = arr(W_TOTAL_HT_AMOUNT * func F_SENS([F:DUD]AMTLOC, [F:DUD]SNS, SENS_CRIT, [F:XIH]ORIMOD) / W_TOTAL_TTC_AMOUNT, WCURRND)
        WDUD_CUMUL_HT_AMOUNT += WDUD_HT_AMOUNT
        Gosub SYNTHESE_AND_DETAIL_XINV

      Next
      Filter [DUD]

      # arrounds the last DUD amount and writes it
      If WDUD_HT_AMOUNT
        WDUD_CUMUL_HT_AMOUNT -= WDUD_HT_AMOUNT # sub the value we want to arround

        WDUD_HT_AMOUNT = W_TOTAL_HT_AMOUNT - WDUD_CUMUL_HT_AMOUNT
        [F:BGY]AMTNOT = WDUD_HT_AMOUNT
        [F:BGY]AMTNOTDUD = WDUD_HT_AMOUNT
        [F:BGY]AMTNOTDUDEXD = WDUD_HT_AMOUNT
        WAMTNOTDUDEXD += WDUD_HT_AMOUNT
        Gosub INSERT_BGY_XINV
        If GOK = 0
          Return
        Endif
      Endif

    Else # tiers

      If WNB_XIH_OK = 1 # doesn't need to re-read
        Gosub TRAIT_XINV_DUD
        If GOK = 0
          Return
        Endif

      Else

        # Dispatch the HT amount on each dud
        Filter [DUD] Where TYP = [F:XIH]GTE and NUM = [F:XIH]NUM
        For [DUD]DUD0

          Gosub TRAIT_XINV_DUD
          If GOK = 0
            Break
          Endif

        Next
        Filter [DUD]
      Endif
    Endif
  Endif

Return

$TRAIT_XINV_DUD

  # gestion des écarts (delta sur le dernier) / Management of deviations (delta on last)
  WIND_DUD_OK += 1

  Call LEC_SAC([F:DUD]SAC, WCOA)
  WACC = [F:GAC]ACC
  If WIND_DUD_OK = WNB_XIH_OK
    WDUD_HT_AMOUNT = W_TOTAL_HT_AMOUNT - WDUD_CUMUL_HT_AMOUNT
  Else
    If W_TOTAL_TTC_AMOUNT
      WDUD_HT_AMOUNT = arr(W_TOTAL_HT_AMOUNT * func F_SENS([F:DUD]AMTLOC, [F:DUD]SNS, SENS_CRIT, [F:XIH]ORIMOD) / W_TOTAL_TTC_AMOUNT, WCURRND)
    Else
      WDUD_HT_AMOUNT = arr(func F_SENS([F:DUD]AMTLOC, [F:DUD]SNS, SENS_CRIT, [F:XIH]ORIMOD), WCURRND)
    Endif
    WDUD_CUMUL_HT_AMOUNT += WDUD_HT_AMOUNT
  Endif

  Gosub SYNTHESE_AND_DETAIL_XINV
  WAMTNOTDUDEXD += WDUD_HT_AMOUNT
  Gosub INSERT_BGY_XINV

Return

$SYNTHESE_AND_DETAIL_XINV

  WNBRDUDEXD += 1
  WNB_DAYS = WFIYEND - [F:DUD]DUDDAT

  If WBLOCK_NUM = 2                         # B block (selected)

    WCD_BLK = 200
    Gosub PREPARE_INSERT_BGY_XINV

  Elsif WBLOCK_NUM = 3                      # B block (B block with A selection but non posted)

    WCD_BLK = 300
    Gosub PREPARE_INSERT_BGY_XINV

  Endif

Return

#**
#* Journal entry parth of developpement ___________________________________________________________
#*!
$TRAIT_GAS

  Columns [LNK] ([HDU]TYP,[HDU]NUM,[HDU]FCY,[HDU]SAC,[HDU]BPR,[HDU]DUDSTA,
&                [HDU]ACCNUM,[HDU]DUDLIG,[HDU]DUDDAT,[HDU]BPRPAY, [HAE]ACCDAT, [HAE]FCY)

  For [F:LNK]HDU3(1) Nohint

    # 1st item of GAS => must calculate the TTC sum of items and the HT amount of GAS
    WNB_DUD_OK = 0
    W_IS_OK = 0

    Gosub CALC_TTC_ALL_DUD
    If W_IS_OK
      Call CALCUL_HT_GAS(WLEDTYPGEN, [F:HDU]TYP, [F:HDU]NUM, [F:CPY]CPY,
&                        WSTRDATFIY, WENDDATFIY, WNUMFIY,
&                        W_TOTAL_HT_AMOUNT, WMULTITIERS, WFLGTOTPURSAL)

      If WMULTITIERS = [V]CST_AYES
        W_IS_OK = 0
        If DETMULTIBP
          Gosub INSERT_BGY_MULTI_BPR
        Endif
      Endif

      If W_IS_OK
        Call LEC_SAC([F:HD2]SAC, WCOA)
        WACC = [F:GAC]ACC
      Endif
    Endif

    # all items of GAS => calculate each dud's amount
    If W_IS_OK
      WIND_DUD_OK = 0
      WDUD_CUMUL_HT_AMOUNT = 0
      For [F:LNK]HDU3(2) Nohint

        W_IS_OK = 1
        Gosub CALC_TTC_ONE_DUD
        If W_IS_OK

          # HT amount calcul ______________________________________________________________________
          Gosub CTL_GOOD_DUDDAT
          If W_IS_OK

            # X3-27160
            # All is paid (use cases 7 and 10)
            # X3-59739
            If [F:HD2]DATEVT <= WFIYEND and [F:HD2]FLGCLE = 2 and WFLGTOTPURSAL = [V]CST_AYES
              If DETTOTPURSAL and (WCASE_SEL = 3 or WCASE_SEL = 4)  # A block (Dud payd)
                WBLOCK_NUM = 4
                WCD_BLK = 100
                Gosub CALC_BGY_DUD
                Gosub INSERT_BGY
                If GOK = 0
                  Break 2
                Endif
              Endif
            Else
              Gosub CALC_BGY_DUD

              If WBLOCK_NUM = 1 and (DETLATPAY or (DETTOTPURSAL and [F:HAE]ACCDAT >= WFIYSTR)) # A block (posted)
                Gosub INSERT_BGY
                If GOK = 0
                  Break 2
                Endif
              Elsif (WBLOCK_NUM = 2 or WBLOCK_NUM = 3) and DETDOUBTFUL  # B block (with B selection and A selection but non posted)
                Gosub INSERT_BGY
                If GOK = 0
                  Break 2
                Endif
              Endif
            Endif
          Endif

        Endif
      Next
    Endif
  Next

  Filter [F:LNK]
  Columns [LNK]

Return

# calculate the TTC sum of items of GAS
$CALC_TTC_ALL_DUD

  Raz WBLOCK_NUM
  WBOOL_CALC_TOT_TTC_DUD = 1 # calc CALCUL_HT_GAS and total TTC DUD
  SV_DUDLIG = 0
  W_ONE_TTC_AMOUNT = 0
  W_TOTAL_TTC_AMOUNT = 0
  Filter [HD2] Where ACCNUM = [HDU]ACCNUM and ([F:HD2]DATEVT <= [L]WFIYEND or FLGCLE = 3)

  # find the last and good HISTODUD for a DUD (by [HD2]DUDLIG)
  # It's only this one that we must sum in W_TOTAL_TTC_AMOUNT
  For [HD2]HDU3 With Nohint

    # A change TYPDUD is done : it's no more an invoice
    If [F:HD2]TYPDUD <> 2
      W_IS_OK = 0
      W_TOTAL_TTC_AMOUNT = 0
      Break
    Endif

    If SV_DUDLIG <> 0 and SV_DUDLIG <> [HD2]DUDLIG

      If W_IS_OK
        W_TOTAL_TTC_AMOUNT += W_ONE_TTC_AMOUNT * W_ONE_SENS
        W_IS_OK = 0
      Endif
    Endif
    SV_DUDLIG = [HD2]DUDLIG

    Gosub VERIFY_IF_DUD_OK # Controls and gives the good record of HISTODUD
    If W_IS_OK
      W_ONE_TTC_AMOUNT = [F:HD2]AMTLOC
      W_ONE_SENS = [F:HD2]SNS
    Endif
  Next

  If W_IS_OK
    W_TOTAL_TTC_AMOUNT += W_ONE_TTC_AMOUNT * W_ONE_SENS
  Endif
  Filter [HD2]
  W_TOTAL_TTC_AMOUNT = abs(W_TOTAL_TTC_AMOUNT)

Return

$CALC_TTC_ONE_DUD

  WBOOL_CALC_TOT_TTC_DUD = 0 # Traitment

  Filter [HD2] Where ACCNUM = [HDU]ACCNUM and DUDLIG = [HDU]DUDLIG and
&              ([F:HD2]DATEVT <= [L]WFIYEND or FLGCLE = 3) # FLGCLE = 3 : annulé
  For [HD2]HDU3 Nohint

    # A change is done : it's no more an invoice
    If [F:HD2]TYPDUD <> 2
      W_IS_OK = 0
      W_TOTAL_TTC_AMOUNT = 0
      Break
    Endif

    Gosub VERIFY_IF_DUD_OK # Control and gives the good record of HISTODUD
  Next
  Filter [HD2]

Return

$VERIFY_IF_DUD_OK

# FLGCLE =
# = 1 non rêglé ou partiellement
# = 2 définitif avec AMTLOC = AMTPAY
# = 3 supprimée (annulée)
# = 4 rêglé temporairement

  # Echéances validées... 1ère étape
  If W_IS_OK = 0
    # An Ok line is found
    If ([F:HD2]FLGCLE = 1 or [F:HD2]FLGCLE = 2 or [F:HD2]FLGCLE = 4) and
&     [F:HD2]DATEVT <= [L]WFIYEND  and SVG_FLGEVT = ""

      # control if criters are always Ok
      Gosub ARE_CRITERIAS_ALWAYS_OK

      If W_IS_OK
        LIGNE += 1
        If WBOOL_CALC_TOT_TTC_DUD
          WNB_DUD_OK += 1
        Endif
        Raz [F:BGY]
        [F:BGY]USR    = GUSER
        [F:BGY]NUMREQ = NUMREQ
        PTYP = [F:HD2]TYP
        PNUM = [F:HD2]NUM
        PCPY = [F:HD2]CPY
      Endif
    Else
      # memo if paiement is cancelled
      SVG_FLGEVT = [F:HD2]FLGEVT
    Endif


  Elsif W_IS_OK
    # Echéances annulées (annulation comptable ou suppression réel)
    If [F:HD2]FLGCLE = 3
      W_IS_OK = 0
      LIGNE -= 1
      If WBOOL_CALC_TOT_TTC_DUD
        WNB_DUD_OK -= 1
      Endif

    # Echéances avec changement de critère(s)
    Elsif ([F:HD2]SAC <> [F:HDU]SAC or [F:HD2]BPR <> [F:HDU]BPR) and
&          [F:HD2]DATEVT <= [L]WFIYEND

      # Si l'échéance modifiée fait partie de la sélection de l'édition, il faut la garder et la mettre à jour.
      # select A block or B block  if DUDSTA <> 2
      If ([F:HD2]FLGCLE = 1 or [F:HD2]FLGCLE = 2 or [F:HD2]FLGCLE = 4)

        # controf if criters are always Ok
        Gosub ARE_CRITERIAS_ALWAYS_OK
        If W_IS_OK = 0
          LIGNE -= 1
          If WBOOL_CALC_TOT_TTC_DUD
            WNB_DUD_OK -= 1
          Endif
        Endif

      Else
        LIGNE -= 1
        W_IS_OK = 0
        If WBOOL_CALC_TOT_TTC_DUD
          WNB_DUD_OK -= 1
        Endif
      Endif

    Else
    # Modification simple d'échéances avant règlements

      Gosub SET_BLOCK_NUM

      If [F:HD2]DATEVT <= [L]WFIYEND
        # si réglement (enreg précédent) annulé et maintenant paiement partiel, alors le réglement n'est plus annulé
        If SVG_FLGEVT <> "" and [F:HD2]TMPCUR <> 0
          Raz SVG_FLGEVT
        Endif
      Else
        # Canceled paiement
        SVG_FLGEVT = [F:HD2]FLGEVT
      Endif
    Endif
  Endif
#_________________________________________________________________________________________
# Explication de Sandrine :
#La zone FLGEVT dans HISTODUD vaut « A » quand le règlement d’une échéance a été annulé.
# Que ce soit un règlement partiel ou total.
# Cela ne veut pas dire que l’échéance est annulée.
#Cela veut dire qu’on avait payé totalement ou partiellement
# l’échéance et que ce paiement a été annulé.
# L’opération de délettrage, qui a lieu après annulation du règlement,
# ne génère pas d’enregistrement dans HISTODUD.

#Concernant le traitement RPTDHU, je pense que c’est peut-être pour ne pas prendre en compte
# une échéance dont le règlement aurait été annulé après la date de référence.
# Quand tu annules un règlement tu peux préciser la date à laquelle tu l’annules et
# cette date met à jour datevt dans HISTODUD. Il faudrait faire un cas concret pour comprendre.
#
#Je mets Christine en copie car cette zone FLGEVT a été ajoutée suite à la fiche SAM 62055
# et Christine était dans la boucle.
#@Christine :  Il faudrait peut-être prévoir un test avec une échéance dont le règlement est annulé.

#_________________________________________________________________________________________
Return

$SET_BLOCK_NUM

# -> séparation faite sur la partie B (2 et 3) par comptabilisé ou non
# fonctionnement : bloc A non comptabilisé en block 3
#                  bloc B comptabilisé en block 2
#                  bloc B non comptabilisé en block 3

  If WCASE_SEL = 3 or WCASE_SEL = 4
    If [F:HD2]DUDSTA = 2
      WBLOCK_NUM = 1
    Else
      WBLOCK_NUM = 3
    Endif
  Else
    If [F:HD2]DUDSTA = 2
      WBLOCK_NUM = 2
    Else
      WBLOCK_NUM = 3
    Endif
  Endif


# -> séparation faite sur la partie B (2 et 3) par l'origine de sélection (Bloc A ou B)
# fonctionnement : bloc A non comptabilisé en block 3
#                  bloc B comptabilisé ou non en block 2
#  If WCASE_SEL = 3 or WCASE_SEL = 4
#    If [F:HD2]DUDSTA = 2
#      WBLOCK_NUM = 1
#    Else
#      WBLOCK_NUM = 3
#    Endif
#  Else
#    WBLOCK_NUM = 2
#  Endif

Return

# Controls SAC (and gives the good block) and BPR
# if changes between 2 dud
$ARE_CRITERIAS_ALWAYS_OK

  W_IS_OK = 0
  If [F:HD2]SAC = [F:HDU]SAC

    W_IS_OK = 1
    Gosub SET_BLOCK_NUM

  Else

    # We mustn't find if SAC changes from A block to B (or contrary)
    # because when we'll trait for B block, we will find it
    If WCASE_SEL = 3 or WCASE_SEL = 4
      If WB_BLOCA
        If (COLADEB = "" or [F:HD2]SAC >= COLADEB) and (COLAFIN = "" or [F:HD2]SAC <= COLAFIN) and
&          (func GRPAB_CTL([F:HD2]SAC, WCOA, GRPACOL) = [V]CST_ATRUE)

          W_IS_OK = 1
          Gosub SET_BLOCK_NUM
        Endif
      Endif
    Else
      If WB_BLOCB
        If (COLBDEB = "" or [F:HD2]SAC >= COLBDEB) and (COLBFIN = "" or [F:HD2]SAC <= COLBFIN) and
&          (func GRPAB_CTL([F:HD2]SAC, WCOA, GRPBCOL) = [V]CST_ATRUE)

          W_IS_OK = 1
          Gosub SET_BLOCK_NUM
        Endif
      Endif
    Endif
  Endif

  If W_IS_OK and [F:HD2]BPR <> [F:HDU]BPR

    If (TIERSDEB <> "" and [HD2]BPR < TIERSDEB) or
&      (TIERSFIN <> "" and [HD2]BPR > TIERSFIN)
      W_IS_OK = 0
    Endif
  Endif

Return

#* Gives if the record is good.
#* That's depends of :
#* ACCDAT, DUDDAT, PAYDAT, FLGCLE (if closed) and FIY parameter
#*
$CTL_GOOD_DUDDAT

 # X3-59739 PAYDAT replaced by DATEVT
  # Invoice ACCDAT
  If [F:HAE]ACCDAT < WFIYSTR # Last year

    If [F:HD2]DUDDAT < WFIYSTR
      If [F:HD2]DATEVT <= WFIYEND and  [F:HD2]FLGCLE = 2
        W_IS_OK = 0                                         # Use case 1
        Return
      Endif
    Elsif [F:HD2]DUDDAT <= WFIYEND

      If [F:HD2]DATEVT <= WFIYEND and [F:HD2]FLGCLE = 2
        W_IS_OK = 0                                           # Use case A
        Return
      Endif
    Else

      If [F:HD2]DATEVT <= WFIYEND and [F:HD2]FLGCLE = 2
        W_IS_OK = 0                                           # Use case 4
        Return
      Endif

    Endif

  Elsif [F:HAE]ACCDAT <= WFIYEND # current year (= parameter)

#    If [F:HD2]DUDDAT <= WFIYEND
#
#      If [F:HD2]PAYDAT <> [00/00/00] and [F:HD2]PAYDAT <= WFIYEND and [F:HD2]FLGCLE = 2
#        W_IS_OK = 0                                          # Use case 7 : Ok if DETTOTPURSAL
#        Return
#      Endif
#    Else
#
#      If [F:HD2]PAYDAT <> [00/00/00] and [F:HD2]PAYDAT <= WFIYEND and [F:HD2]FLGCLE = 2
#        W_IS_OK = 0                                          # Use case 10 : Ok if DETTOTPURSAL
#        Return
#      Endif
#    Endif
  Else  # next year
    W_IS_OK = 0
  Endif

Return

$CALC_BGY_DUD

  If WNB_DUD_OK = 1 or W_TOTAL_TTC_AMOUNT = 0     # Only one DUD or amount = 0
    If [F:HD2]AMTLOC > 0
      WPRORATA_DUD = 1
    Else
      WPRORATA_DUD = -1
    Endif
  Else
    WPRORATA_DUD = [F:HD2]AMTLOC / W_TOTAL_TTC_AMOUNT
  Endif

  WDUD_HT_AMOUNT = abs(W_TOTAL_HT_AMOUNT) * WPRORATA_DUD

  WDUD_HT_AMOUNT = arr(WDUD_HT_AMOUNT, WCURRND)

  # gestion des écarts (delta sur le dernier)
  WIND_DUD_OK += 1
  WDUD_HT_AMOUNT = func F_SENS(WDUD_HT_AMOUNT, [F:HD2]SNS, SENS_CRIT, 0)
  If WNB_DUD_OK > 1 and WIND_DUD_OK = WNB_DUD_OK
    WDUD_HT_AMOUNT = W_TOTAL_HT_AMOUNT - WDUD_CUMUL_HT_AMOUNT
  Else
    WDUD_CUMUL_HT_AMOUNT += WDUD_HT_AMOUNT
  Endif
  WDUD_HT_AMOUNT_NOT_PAID = WDUD_HT_AMOUNT # X3-22235

  # 2° DUD payment prorata (if not complete)
  If [F:HD2]PAYLOC <> 0
    If [F:HD2]AMTLOC = [F:HD2]PAYLOC
      WDUD_HT_AMOUNT = 0
    Else
      WDUD_HT_AMOUNT = WDUD_HT_AMOUNT * (abs(([F:HD2]AMTLOC - [F:HD2]PAYLOC) / [F:HD2]AMTLOC))
      WDUD_HT_AMOUNT = arr(WDUD_HT_AMOUNT, WCURRND)
    Endif
  Endif

  If WBLOCK_NUM = 4 # All is paid : it's for FLGTOTPURSAL sub-report
    Return
  Endif

  # in what detail box (late's day):
  WNB_DAYS = WFIYEND - [F:HD2]DUDDAT

# For A block :
#       results must go in AA CC
#       or results must go in BB, DD1... DDTOT
# For B block :
#       results must go in FF GG
  If WBLOCK_NUM = 1                          # A block (A selection and posted)

    If WNB_DAYS > BORNE4                  # > 90
      WNBRDUD2 += 1
      WAMTNOTDUD5   += WDUD_HT_AMOUNT
      WAMTNOTDUDTOT += WDUD_HT_AMOUNT
      WCD_BLK = 60
    Elsif WNB_DAYS > BORNE3               # > 60
      WNBRDUD2 += 1
      WAMTNOTDUD4   += WDUD_HT_AMOUNT
      WAMTNOTDUDTOT += WDUD_HT_AMOUNT
      WCD_BLK = 50
    Elsif WNB_DAYS > BORNE2               # > 30
      WNBRDUD2 += 1
      WAMTNOTDUD3   += WDUD_HT_AMOUNT
      WAMTNOTDUDTOT += WDUD_HT_AMOUNT
      WCD_BLK = 40
    Elsif WNB_DAYS > BORNE1               # > 0
      WNBRDUD2 += 1
      WAMTNOTDUD2   += WDUD_HT_AMOUNT
      WAMTNOTDUDTOT += WDUD_HT_AMOUNT
      WCD_BLK = 30
    Else                                 # 0 Day
      WNBRDUD1 += 1
      WAMTNOTDUD1 += WDUD_HT_AMOUNT
      WCD_BLK = 20
    Endif

  Elsif WBLOCK_NUM = 2                          # B block (selected)

    WNBRDUDEXD += 1
    WAMTNOTDUDEXD += WDUD_HT_AMOUNT
    WCD_BLK = 200

  Elsif WBLOCK_NUM = 3                         # B block (B block with A selection but non posted)

    WNBRDUDEXD += 1
    WAMTNOTDUDEXD += WDUD_HT_AMOUNT
    WCD_BLK = 300

  Endif

Return

$INSERT_BGY

  Raz [F:BGY]

  [F:BGY]USR    = GUSER
  [F:BGY]NUMREQ = NUMREQ
  [F:BGY]CODBLK = WCD_BLK

  # X3-27160
  # for Total purch. & sales detail (A) sub-report or All is paid : it's for FLGTOTPURSAL sub-report
  If (((WCD_BLK >= 20 and WCD_BLK <= 60) and [F:HAE]ACCDAT >= WFIYSTR) or WCD_BLK = 100)  and WFLGTOTPURSAL = [V]CST_AYES
    [F:BGY]FLGTOTPURSAL = [V]CST_AYES
  Else
    [F:BGY]FLGTOTPURSAL = [V]CST_ANO
  Endif

  [F:BGY]CPY = [F:HD2]CPY
  [F:BGY]CURLED = WLEDCUR

  [F:BGY]BPR = [F:HD2]BPR
  [F:BGY]COA = WCOA
  [F:BGY]ACC = WACC
  [F:BGY]TYP = [F:HD2]TYP
  [F:BGY]NUM = [F:HD2]NUM
  [F:BGY]DUDLIG = [F:HD2]DUDLIG # X3-36073
  [F:BGY]ACCDAT = [F:HAE]ACCDAT
  [F:BGY]FCY = [F:HD2]FCY
  [F:BGY]AMTTAX = func F_SENS(([F:HD2]AMTLOC - [F:HD2]PAYLOC), [F:HD2]SNS, SENS_CRIT, 0)
  [F:BGY]AMTNOT = WDUD_HT_AMOUNT
  [F:BGY]AMTTAXDUD = func F_SENS([F:HD2]AMTLOC, [F:HD2]SNS, SENS_CRIT, 0) # X3-22235
  [F:BGY]AMTNOTDUD = WDUD_HT_AMOUNT_NOT_PAID # X3-22235
  [F:BGY]DUDDAT = [F:HD2]DUDDAT
  [F:BGY]NBRDAYWAI = WNB_DAYS

  # inutile mais informatif:
  If WCD_BLK = 20
    [F:BGY]AMTNOTDUD1 = WDUD_HT_AMOUNT
  Elsif WCD_BLK = 30
    [F:BGY]AMTNOTDUD2 = WDUD_HT_AMOUNT
  Elsif WCD_BLK = 40
    [F:BGY]AMTNOTDUD3 = WDUD_HT_AMOUNT
  Elsif WCD_BLK = 50
    [F:BGY]AMTNOTDUD4 = WDUD_HT_AMOUNT
  Elsif WCD_BLK = 60
    [F:BGY]AMTNOTDUD5 = WDUD_HT_AMOUNT

  Elsif WCD_BLK = 200 or  WCD_BLK = 300
    [F:BGY]AMTNOTDUDEXD = WDUD_HT_AMOUNT

#  Elsif WCD_BLK = 100 # nothing special

  Endif

  Write [BGY]
  If fstat
    GOK = 0
    Call FSTA("BGY") From GLOCK
  Endif

Return

$PREPARE_INSERT_BGY_XINV

  If DETDOUBTFUL = 0
    Return
  Endif

  Raz [F:BGY]

  [F:BGY]USR    = GUSER
  [F:BGY]NUMREQ = NUMREQ
  [F:BGY]CODBLK = WCD_BLK

  [F:BGY]CPY = [F:XIH]CPY
  [F:BGY]CURLED = WLEDCUR

  [F:BGY]BPR = [F:XIH]BPR
  [F:BGY]COA = WCOA
  [F:BGY]ACC = WACC
  [F:BGY]TYP = [F:XIH]GTE
  [F:BGY]NUM = [F:XIH]NUM
  [F:BGY]DUDLIG = [F:DUD]DUDLIG # X3-36073
  [F:BGY]ACCDAT = [F:XIH]ACCDAT
  [F:BGY]FCY = [F:XIH]FCY

  [F:BGY]AMTTAX = func F_SENS([F:DUD]AMTLOC, [F:XIH]SNS, SENS_CRIT, [F:XIH]ORIMOD)
  [F:BGY]AMTNOT = WDUD_HT_AMOUNT
  [F:BGY]AMTTAXDUD = [F:BGY]AMTTAX # ISSUE X3-22235
  [F:BGY]AMTNOTDUD = [F:BGY]AMTNOT # ISSUE X3-22235

  [F:BGY]DUDDAT = [F:DUD]DUDDAT
  [F:BGY]NBRDAYWAI = WNB_DAYS

  # inutile mais informatif:
  If WCD_BLK = 200 or  WCD_BLK = 300
    [F:BGY]AMTNOTDUDEXD = WDUD_HT_AMOUNT
  Endif
Return

$INSERT_BGY_XINV

  If DETDOUBTFUL = 0
    Return
  Endif

  [F:BGY]FLGTOTPURSAL = [V]CST_ANO # X3-27160
  Write [BGY]
  If fstat
    GOK = 0
    Call FSTA("BGY") From GLOCK
  Endif

Return

$INSERT_BGY_SYNTHESE

  Raz [F:BGY]

  [F:BGY]USR     = GUSER
  [F:BGY]NUMREQ  = NUMREQ
  [F:BGY]CODBLK = 1
  [F:BGY]FLGTOTPURSAL = [V]CST_ANO # X3-27160
  [F:BGY]CPY = [F:CPY]CPY
  [F:BGY]CURLED = WLEDCUR

  [F:BGY]AMTNOTINV = WAMTNOTINV

  # A block
  [F:BGY]ACCDAT = WFIYEND
  [F:BGY]NBRDUD1 = WNBRDUD1
  [F:BGY]NBRDUD2 = WNBRDUD2
  [F:BGY]AMTNOTDUD1 = WAMTNOTDUD1
  [F:BGY]AMTNOTDUD2 = WAMTNOTDUD2
  [F:BGY]AMTNOTDUD3 = WAMTNOTDUD3
  [F:BGY]AMTNOTDUD4 = WAMTNOTDUD4
  [F:BGY]AMTNOTDUD5 = WAMTNOTDUD5
  [F:BGY]AMTNOTDUDTOT = WAMTNOTDUDTOT

  # B block
  [F:BGY]NBRDUDEXD = WNBRDUDEXD
  [F:BGY]AMTNOTDUDEXD = WAMTNOTDUDEXD

  Write [BGY]
  If fstat
    GOK = 0
    Call FSTA("BGY") From GLOCK
  Endif

Return

$INSERT_BGY_MULTI_BPR

  Raz [F:BGY]

  [F:BGY]USR    = GUSER
  [F:BGY]NUMREQ = NUMREQ
  [F:BGY]CODBLK = 400

  [F:BGY]FLGTOTPURSAL = [V]CST_ANO

  [F:BGY]CPY = [F:HD2]CPY
  [F:BGY]CURLED = WLEDCUR

  [F:BGY]TYP = [F:HD2]TYP
  [F:BGY]NUM = [F:HD2]NUM
  [F:BGY]DUDLIG = [F:HD2]DUDLIG # X3-36073
  [F:BGY]ACCDAT = [F:HAE]ACCDAT
  [F:BGY]FCY = [F:HAE]FCY

  If SENS_CRIT = 2
    [F:BGY]AMTNOT = -W_TOTAL_HT_AMOUNT
  Else
    [F:BGY]AMTNOT = W_TOTAL_HT_AMOUNT
  Endif

  Write [BGY]
  # fstat = 3 = duplicate : it's a mean to write just one time a multi-bpr
  If fstat <> 0 and fstat <> 3
    GOK = 0
    Call FSTA("BGY") From GLOCK
  Endif

Return

$DEL_ENREG

  GOK = 1
  Trbegin [BGY]
  Delete [BGY] Where USR = GUSER
  Commit

Return

$OUVFIC

  If clalev([F:BGY])=0 : Local File BALAGEEOY   [BGY] : Endif

  If clalev([F:HAE])=0 : Local File GACCENTRY   [HAE] : Endif
  If clalev([F:DAE])=0 : Local File GACCENTRYD  [DAE] : Endif
  If clalev([F:HDU])=0 : Local File HISTODUD    [HDU] : Endif
  If clalev([F:HD2])=0 : Local File HISTODUD    [HD2] : Endif
  If clalev([F:CPY])=0 : Local File COMPANY     [CPY] : Endif
  If clalev([F:FCY])=0 : Local File FACILITY    [FCY] : Endif
  If clalev([F:FGR])=0 : Local File FACGROUP    [FGR] : Endif
  If clalev([F:GSC])=0 : Local File GRPSAC      [GSC] : Endif
  If clalev([F:BPR])=0 : Local File BPARTNER    [BPR] : Endif
  If clalev([F:ACC])=0 : Local File ACCES       [ACC] : Endif
  If clalev([F:AFF])=0 : Local File AFCTFCY     [AFF] : Endif
  If clalev([F:LED])=0 : Local File GLED        [LED] : Endif
  If clalev([F:GCM])=0 : Local File GACM        [GCM] : Endif
  If clalev([F:FIY])=0 : Local File FISCALYEAR  [FIY] : Endif

  If clalev([F:DUD])=0 :  Local File GACCDUDATE [DUD] : Endif
  If clalev([F:GAC])=0 :  Local File GACCOUNT   [GAC] : Endif
  If clalev([F:TCU])=0 :  Local File TABCUR     [TCU] : Endif

  If clalev([F:GTES])=0 : Local File LEGGTESEL  [GTES] : Endif : #View that select the right TYP(multi lég) for a defined LEG
  If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE]  : Endif

Return

#**
#* making the clause Where
#*
#* @param CRITERE
#* @param SUBCRIT
#*!
Subprog ADDCRIT(CRITERE, SUBCRIT)
Variable Clbfile    CRITERE
Value    Clbfile    SUBCRIT

  If CRITERE <> ""
    CRITERE -= "and"
  Endif
  CRITERE -= SUBCRIT

End

#**
#* retrieve the param's value
#*
#* @param PARAM
#* @param NBPAR
#* @param PARAMETRE
#* @param VALEUR
#*!
Subprog GETPARAM(PARAM, NBPAR, PARAMETRE, VALEUR)
Value    Char    PARAM()
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR()

Local Integer L

  Call GETPARAM(PARAM, NBPAR, PARAMETRE, VALEUR) From ETAT
  L = len(PARAM)
  If right$(PARAM,L-2) = "deb"
    If VALEUR = string$(len(VALEUR)," ")
      VALEUR = ""
    Endif
  Elsif right$(PARAM,L-2) = "fin"
    If VALEUR = string$(len(VALEUR),"z")
      VALEUR = ""
    Endif
  Endif

End

#**
#* Give the - tax amount of a GAS
#*
#* @param PGENLEDTYP
#* @param PTYP
#* @param PNUM
#* @param PCPY
#* @param PSTRDATFIY
#* @param PENDDATFIY
#* @param PNUMFIY
#* @param RMTT_TOTAL    : - tax amount of GAC
#* @param RMULTITIERS   : Yes/no if multi bpr
#* @param RFLGTOTPURSAL : Yes/no if GAS in fiscal year
#*!
Subprog CALCUL_HT_GAS(PGENLEDTYP, PTYP, PNUM, PCPY,
&                     PSTRDATFIY, PENDDATFIY, PNUMFIY,
&                     RMTT_TOTAL, RMULTITIERS, RFLGTOTPURSAL)
Value Integer PGENLEDTYP
Value Char PTYP(), PNUM(), PCPY()
Value Date PSTRDATFIY, PENDDATFIY
Value Integer PNUMFIY
Variable Decimal RMTT_TOTAL
Variable Integer RMULTITIERS, RFLGTOTPURSAL

Local Integer WNBBPR

  # Multitiers : si + d'1 ligne avec BPR renseigné.
  WNBBPR = 0
  Link [DAE] With [GAC]GAC0~=[F:DAE]COA; [F:DAE]ACC
&   As [DAX] Where [F:DAE]TYP = PTYP and [F:DAE]NUM = PNUM and [F:DAE]LEDTYP = PGENLEDTYP

  RMTT_TOTAL = 0
  RMULTITIERS = [V]CST_ANO
  RFLGTOTPURSAL = [V]CST_ANO

  For [DAX]DAE0

    If [F:GAC]FLGVAT = 2
      RMTT_TOTAL += [F:DAE]AMTLED * [F:DAE]SNS
    Endif

    If [F:DAE]BPR <> ""
      WNBBPR += 1
    Endif
    If [F:DAE]ACCDAT >= PSTRDATFIY and [F:DAE]ACCDAT <= PENDDATFIY and [F:DAE]FIY = PNUMFIY
      RFLGTOTPURSAL = [V]CST_AYES
    Endif

  Next

  # The excluding tax amount has the oppposite sign
  RMTT_TOTAL = -RMTT_TOTAL

  If WNBBPR > 1
    RMULTITIERS = [V]CST_AYES
  Endif
End

#**
#* gives the good sign to the amount for printing
#*
#* @param PAMOUNT
#* @param PSENS
#* @param PSENS_CRIT
#* @param PMODULE
#*!
Funprog F_SENS(PAMOUNT, PSENS, PSENS_CRIT, PMODULE)
Value Decimal PAMOUNT
Value Integer PSENS, PSENS_CRIT, PMODULE

  # PINVOICE.SNS is different for purchase
  If PMODULE = 6
    PSENS = -PSENS
  Endif

  If (PSENS = 1 and PSENS_CRIT = 1) or (PSENS <> 1 and PSENS_CRIT = 2)
    End PAMOUNT
  Endif

End (-PAMOUNT)

#**
#* Read code of collective account
#*
#* @param PSAC
#* @param PPLAN
#*!
Subprog LEC_SAC(PSAC, PPLAN)
Value Char PSAC()
Value Char PPLAN()

  fstat = 0

  If [F:GAC]COA <> PPLAN or [F:GAC]ACCSHO <> PSAC
    Read [GAC]GAC1 = PPLAN; PSAC
  Endif

End

#**
#* Read if group of collective account exists
#*
#*
#* @param PSAC
#* @param PPLAN
#* @param PGRP
#*!
Funprog LEC_GSC(PSAC, PPLAN, PGRP)
Value Char PSAC()
Value Char PPLAN()
Value Char PGRP()

  fstat = 0

  If [F:GSC]COA = PPLAN and [F:GSC]GRU = PGRP and [F:GSC]SAC = PSAC
    End [V]CST_ATRUE
  Endif

  Read[GSC]GSC1 = PPLAN; PGRP; PSAC
  If fstat = 0
    End [V]CST_ATRUE
  Endif

End [V]CST_AFALSE

#**
#* Return if group of collective account exists
#*
#* @param PSAC
#* @param PPLAN
#* @param PGRP
#*!
Funprog GRPAB_CTL(PSAC, PPLAN, PGRP)
Value Char PSAC()
Value Char PPLAN()
Value Char PGRP()

  If PGRP = ""
    End [V]CST_ATRUE
  Endif

End func LEC_GSC(PSAC, PPLAN, PGRP)

#**
#* Returns the HT amount of year (A block) - Summary report - Case EE
#*
#* @param CPY
#* @param GRPSAC
#* @param SEL_CRIT_YEAR
#* @param X3PRF
#* @param X3FCT
#* @param STRDATFIY
#* @param ENDDATFIY
#* @param NUMFIY
#* @param LEDTYPGEN
#* @param AMTNOTINV
#*!
Subprog CAL_AMTNOTINV(PCPY, PGRPSAC, PSEL_CRIT_YEAR, PX3PRF, PX3FCT,
&                     PSTRDATFIY, PENDDATFIY, PNUMFIY, PLEDTYPGEN,
&                     R_AMTNOTINV)
Value    Char    PCPY()
Value    Char    PGRPSAC()
Value Clbfile    PSEL_CRIT_YEAR
Value    Char    PX3PRF()
Value    Char    PX3FCT()

Value Date    PSTRDATFIY
Value Date    PENDDATFIY
Value Integer PNUMFIY
Value Tinyint PLEDTYPGEN

Variable Decimal R_AMTNOTINV

Local Integer MULBPR       : # Flag to indicate if the journal entry contains more than one line with bpartner<>""
Local Decimal AMT_EE       : # Tax excluded amount by journal entry

  # Define the Link
  If PGRPSAC=""
    Link [DAE] With
&   [GAC]GAC0     ~= [F:DAE]COA; [F:DAE]ACC,
&   [HAE]HAE0     ~= [F:DAE]TYP; [F:DAE]NUM,
&   [GTES]GTE1(2)  = [F:DAE]TYP; [F:CPY]LEG,
&   [GTE]GTE0     ~= [F:GTES]TYP; [F:GTES]LEG,
&   [AFF]AFF0     ~= [DAE]FCYLIN; PX3PRF; PX3FCT
&   As [LNK]
&   Where [DAE]CPY = PCPY and [DAE]LEDTYP = PLEDTYPGEN and
&         [DAE]ACCDAT >= PSTRDATFIY and [DAE]ACCDAT <= PENDDATFIY and
&         [DAE]FIY = PNUMFIY and
&         [HAE]CAT = 1 and [F:GTE]PER = 1 and evalue(PSEL_CRIT_YEAR) and [HAE]TYPDUD = 2

  Else

    Link [DAE] With
&   [GAC]GAC0     ~= [F:DAE]COA; [F:DAE]ACC,
&   [HAE]HAE0     ~= [F:DAE]TYP; [F:DAE]NUM,
&   [GSC]GSC1     ~= [F:DAE]COA; PGRPSAC; [F:DAE]SAC,
&   [GTES]GTE1(2)  = [F:DAE]TYP; [F:CPY]LEG,
&   [GTE]GTE0     ~= [F:GTES]TYP; [F:GTES]LEG,
&   [AFF]AFF0     ~= [DAE]FCYLIN; PX3PRF; PX3FCT
&   As [LNK]
&   Where [DAE]CPY = PCPY and [DAE]LEDTYP = PLEDTYPGEN and
&         [DAE]ACCDAT >= PSTRDATFIY and [DAE]ACCDAT <= PENDDATFIY and
&         [DAE]FIY = PNUMFIY and
&         [HAE]CAT = 1 and [F:GTE]PER = 1 and evalue(PSEL_CRIT_YEAR) and [HAE]TYPDUD=2

  Endif

  # Loop on the journal entries
  Columns [HAE](TYP,NUM)
  Columns [DAE](TYP,NUM,LIN,LEDTYP)

  Raz R_AMTNOTINV

  If clalev([F:DAE_E])=0  : Local File GACCENTRYD [DAE_E]  : Endif
  If clalev([F:GAC_E])=0  : Local File GACCOUNT   [GAC_E]  : Endif

  For [LNK]DAE0(2)
    Call AMT_TAX_EXCLUD([F:DAE]TYP, [F:DAE]NUM, PLEDTYPGEN, AMT_EE, MULBPR)
    If MULBPR = [V]CST_AFALSE
      R_AMTNOTINV -= AMT_EE : # The excluding tax amount has the oppposite sign
    Endif
  Next

  Columns [HAE]
  Columns [DAE]

End

#**
#* Calculation of the tax excluded amount of the invoices of fiscal year
#*
#* @param PTYP
#* @param PNUM
#* @param PLEDTYPGEN
#* @param AMT_EE      tax excluded amount of the journal entry
#* @param MULBPR      boolean if multi partner
#*!
Subprog AMT_TAX_EXCLUD(PTYP, PNUM, PLEDTYPGEN, AMT_EE, MULBPR)
Value    Char    PTYP
Value    Char    PNUM
Value    Tinyint PLEDTYPGEN
Variable Decimal AMT_EE
Variable Integer MULBPR

Local Integer NBRBPR

  MULBPR = [V]CST_AFALSE
  NBRBPR = 0
  Raz AMT_EE

  Link [DAE_E] With [GAC_E]GAC0 ~= [F:DAE_E]COA; [F:DAE_E]ACC
&   As [LNK_E]
&   Where [DAE_E]TYP=PTYP and [DAE_E]NUM = PNUM and [DAE_E]LEDTYP = PLEDTYPGEN

  For [LNK_E]
    # Journal entry with many lines with BPR<>"" => do not take into account this journal entry
    If [F:DAE_E]BPR <> ""
      NBRBPR += 1
    Endif
    # Calculation of the tax excluded amount of the journal entry
    If [F:GAC_E]FLGVAT = 2
      AMT_EE += [F:DAE_E]AMTLED*[F:DAE_E]SNS
    Endif
  Next

  If NBRBPR > 1
    MULBPR = [V]CST_ATRUE
  Endif

End

