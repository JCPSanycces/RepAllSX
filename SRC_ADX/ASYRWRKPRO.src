#**
#* Funprog HANDLER_PUT_DATA()
#*!
Funprog HANDLER_PUT_DATA(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO

Local Integer   ERROR : ERROR = [V]CST_AOK
Local Integer   COUNT
Local Char       PROPATH(250),PROINS(250),PRONAME(250)

Local Char       PRGREP(30)
Local Instance REP      Using C_AREPENT
Local Instance WREP Using OBJECT:# for ENABLE_BUTTONS
Local Instance UPD(1..) Using C_ADELTA
Local Instance ULN(1..) Using C_ADELTALIN : # Uncommitted lines of collection by the serveur
Local Integer   NBC
Local Clbfile    WCLOB

ERROR = func ASYRDELSYS.SEARCH_WORKING_COPY(ACTX,ASWK,ARCV,PSYR.WRKUID,COUNT)
If ERROR = [V]CST_AOK
 ERROR = func GET_PROPERTY(ACTX,ASWK,COUNT,ARCV,[L]PROPATH,[L]PROINS,[L]PRONAME)
 If ERROR = [V]CST_AOK
  If evalue("dim("+[L]PROINS+"."+[L]PRONAME+")") < 0
   ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(2,149,1))
   End ERROR
  Endif

   # Load the representation's description :
   PRGREP = func SUBASW.PREFIX_TRT+ASWK(COUNT).REPRES : # WMREP
   Call DESCRIPTION_REPRESENTATION(REP,ASWK(COUNT).REPNAM) From =PRGREP

   # Load representation's parameters
   Call SET_REP_PARAMETERS(ASWK(COUNT).DATCLA,ARCV) From ASYRMAIN

   #Enable buttons :
   WREP = ASWK(COUNT).DATCLA

   ERROR=func BUTTONS(ACTX,ASWK,ARCV,PSYR,ASND,JSON,REP,WREP,UPD,COUNT)
   #Gosub ENABLE_BUTTONS From ASYREDT

   ASWK(COUNT).DATCLA.setAccessorEnabled = 1
   Call SET_SYSSNAPSHOT(ASWK(COUNT).DATCLA,1) From ASYRDELSYS

   Case evalue("type("+[L]PROPATH+")")
    When 522 :# it's a BLOB
     Gosub SET_CONTENT_TYPE
     Assign [L]PROPATH With ARCV.JSON
    When 523 :# it's a CLOB
     If instr(1,PSYR.CNTTYP,"text") > 0
      NBC = strDecode( ARCV.JSON, WCLOB, GUTF8 )
      Gosub SET_CONTENT_TYPE
      Assign [L]PROPATH With WCLOB
     Else
      ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_UNSUPPORTED_MEDIA,mess(35,149,1))
      Call SET_SYSSNAPSHOT(ASWK(COUNT).DATCLA,0) From ASYRDELSYS
      ASWK(COUNT).DATCLA.setAccessorEnabled = 0
      End ERROR
     Endif
    Endcase

   # Load changes set to the representation while setting the LOB :
   Call LOAD_DELTA(ASWK(COUNT).DATCLA,REP,UPD,ULN) From ASYRDELSRV
   Call SET_SYSSNAPSHOT(ASWK(COUNT).DATCLA,0) From ASYRDELSYS
   ASWK(COUNT).DATCLA.setAccessorEnabled = 0
   #Genereate the answer to be sent to the client :
   Call DETAIL_JSON(REP,ASWK(COUNT).DATCLA,ASWK(COUNT),PSYR,UPD,ASND.DATA) From ASYRDATDEL

   ASND.URL      = PSYR.PREFIX+'/'+PSYR.URLUPD+"('"+num$(ASWK(COUNT).TRCKID)+"')"+PSYR.URLREP+ASWK(COUNT).REPRES+".$edit"
   ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+"."+ASWK(COUNT).REPRES+".$edit"

 Endif
Endif

End ERROR

$SET_CONTENT_TYPE
Local Integer ASTATUS
 # Issue 2075 : $contentType =
[L]ASTATUS = evalue('fmet '+[L]PROINS+'.ASETATTRIBUTE("'+[L]PRONAME+'","$contentType","'+PSYR.CNTTYP+ '")'  )
# $filename =
 For I=1 To maxtab(WREP._APARAMURL)
   If WREP._APARAMURL(I).PAR="x-file-name"
    [L]ASTATUS = evalue('fmet '+[L]PROINS+'.ASETATTRIBUTE("'+[L]PRONAME+'","$filename","'+WREP._APARAMURL(I).VPR+ '")'  )
   Break
  Endif
 Next I
Return

#**
#* Funprog HANDLER_DELETE_DATA()
#*!
Funprog HANDLER_DELETE_DATA(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO

Local Integer   ERROR : ERROR = [V]CST_AOK
Local Char       ENT_TYPE(10) : ENT_TYPE=CST_AURLBLOB
Local Char       KEYS(250) : KEYS = PSYR.SELREP
Local Integer   COUNT
Local Char       PROPATH(250),PROINS(250),PRONAME(250)

Local Clbfile EMPTY_CLOB(1)
Local Blbfile EMPTY_BLOB(1)

ERROR = func ASYRDELSYS.SEARCH_WORKING_COPY(ACTX,ASWK,ARCV,PSYR.WRKUID,COUNT)
If ERROR = [V]CST_AOK
 ERROR = func GET_PROPERTY(ACTX,ASWK,COUNT,ARCV,[L]PROPATH,[L]PROINS,[L]PRONAME)
 If ERROR = [V]CST_AOK
  If evalue("dim("+[L]PROINS+"."+[L]PRONAME+")") < 0
   ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(2,149,1))
   End ERROR
  Endif
  Case evalue("type("+[L]PROPATH+")")
  When 522:# it's a BLOB
   Assign [L]PROPATH With EMPTY_BLOB
  when 523 :# it's a CLOB
   Assign [L]PROPATH With EMPTY_CLOB
  Endcase
 Endif
Endif
End ERROR

#**
#* Funprog HANDLER_GET_DATA()
#*!
Funprog HANDLER_GET_DATA(ACTX,ASWK,ARCV,PSYR,ASNB)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASNB Using C_ASYRSNDBLB

Local Integer   ERROR : ERROR = [V]CST_AOK
Local Char       ENT_TYPE(10) : ENT_TYPE=CST_AURLBLOB
Local Char       KEYS(250) : KEYS = PSYR.SELREP
Local Integer   COUNT,WNBC
Local Char       PROPATH(250),PROINS(250),PRONAME(250)
Local Clbfile EMPTY_CLOB(1)
Local Blbfile EMPTY_BLOB(1)
Local Char _ISLOADED(30)

ERROR = func ASYRDELSYS.SEARCH_WORKING_COPY(ACTX,ASWK,ARCV,PSYR.WRKUID,COUNT)
If ERROR = [V]CST_AOK
 ERROR = func GET_PROPERTY(ACTX,ASWK,COUNT,ARCV,[L]PROPATH,[L]PROINS,[L]PRONAME)
 If ERROR = [V]CST_AOK
   Case evalue("type("+[L]PROPATH+")")
   When 522:# it's a BLOB
    #106394 voir si on peut faire qq chose
    #_ISLOADED=evalue('fmet '+[L]PROINS+'.AGETATTRIBUTE("'+[L]PRONAME+'","$isLoaded")'  )
    ASNB.DATA = evalue([L]PROPATH)
    #If _ISLOADED<>"true"
    # Assign [L]PROPATH With EMPTY_BLOB
    # ERROR=evalue('fmet '+[L]PROINS+'.ASETATTRIBUTE("'+[L]PRONAME+'","$isLoaded","false")'  )
    #Endif
   When 523 :# it's a CLOB
    #_ISLOADED=evalue('fmet '+[L]PROINS+'.AGETATTRIBUTE("'+[L]PRONAME+'","$isLoaded")'  )
    WNBC = strEncode(evalue([L]PROPATH), ASNB.DATA, GUTF8 )
    #If _ISLOADED<>"true"
    # Assign [L]PROPATH With EMPTY_CLOB
    # ERROR=evalue('fmet '+[L]PROINS+'.ASETATTRIBUTE("'+[L]PRONAME+'","$isLoaded","false")'  )
    #Endif
   Endcase
   ASNB.CONTTYPE = evalue('fmet '+[L]PROINS+'.AGETATTRIBUTE("'+[L]PRONAME+'","$contentType")'  )
 Endif
Endif
End ERROR

#**
#* GET_PROPERTY
#*
#* @param ACTX
#* @param ASWK
#* @param COUNT
#* @param ARCV
#* @param PROPATH
#*!
Funprog GET_PROPERTY(ACTX,ASWK,COUNT,ARCV,PROPATH,PROINS,PRONAME)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Value Integer COUNT
Variable Instance ARCV Using C_ASYRRCV
Variable Char PROPATH
Variable Char PROINS
Variable Char PRONAME

Local Integer  ERROR : ERROR = [V]CST_AOK
Local Integer  AE,AP,AI,AR
Local Uuident UUID
Local Char      SELECTOR(250),ITEM(250)
Local Integer FOUND
Local Char ARRAY(250)(0..)
Local Char SEP(1) : SEP ="."

[L]PROPATH = "ASWK(COUNT).DATCLA"
For AE = 2 To maxtab(ARCV.ENTITIES)
 If left$(ARCV.ENTITIES(AE),1) <> "$"
  Raz SELECTOR
  [L]PROINS    = [L]PROPATH
  [L]PRONAME = ARCV.ENTITIES(AE)
  AP = instr(1,ARCV.ENTITIES(AE),'(')
  If AP
   PRONAME = left$(ARCV.ENTITIES(AE),AP-1)
   SELECTOR = seg$(ARCV.ENTITIES(AE),AP+2,len(ARCV.ENTITIES(AE))-2)
  Endif
  AR = find(PRONAME,ASWK(COUNT).METCLA.PRO(1..).PRO)
  If AR>0
   Call SPLIT(ARRAY,ASWK(COUNT).METCLA.PRO(AR).PTH,SEP) From ASYRSUB
   PRONAME = ARRAY(maxtab(ARRAY))
  Endif
  PROPATH += '.' + [L]PRONAME
  If evalue("dim("+PROPATH+")") <=0
   End func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(45,149,1),PROPATH))
  Endif
  If len(SELECTOR)
   # it's an object :
   ERROR = func ASYRMAIN.SET_UUID(SELECTOR,UUID)
   If ERROR <> [V]CST_AOK
    End func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(19,149,1))
   Endif
   FOUND =  evalue("find(UUID,"+PROPATH+"(1..maxtab("+PROPATH+")).AUUID)")
   If FOUND
     PROPATH = PROPATH+"("+num$(FOUND)+")"
   Else
    End func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(46,149,1))
   Endif
  Endif
 Endif
Next AE
End [L]ERROR

Funprog BUTTONS(ACTX,ASYRWRK,ARCV,PSYR,ASND,JSON,REP,WREP,UPD,COUNT)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASYRWRK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO
Variable Instance REP      Using C_AREPENT
Variable Instance WREP Using OBJECT
Variable Instance UPD(1..) Using C_ADELTA
Value Integer COUNT

Local Instance ASWK Using C_ASYRWRK
Local Integer   ERROR : ERROR = [V]CST_AOK

ASWK=ASYRWRK(COUNT)
Gosub ENABLE_BUTTONS From ASYREDT

End [L]ERROR
