#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion du masque GENTDS
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TDSGENE","DTDSGENE",3,"") From GTRAITE
End

$ACTION
OK=1
Case ACTION
 When "SEL_LISTE"   :
  Case COUZON
   When "GRP" : Gosub S_GRP
  Endcase
#CHECK IGNORE_BEGIN
 When "S10" :   If func TRTDADSU.EXIST("TRTDADSUSPE") : Gosub LIGNE_S10   From TRTDADSUSPE : Endif
 When "S20" :   If func TRTDADSU.EXIST("TRTDADSUSPE") : Gosub LIGNE_S20   From TRTDADSUSPE : Endif
 When "S70_0" : If func TRTDADSU.EXIST("TRTDADSUSPE") : Gosub LIGNE_S70_0 From TRTDADSUSPE : Endif
 When "S70_1" : If func TRTDADSU.EXIST("TRTDADSUSPE") : Gosub LIGNE_S70_1 From TRTDADSUSPE : Endif
 When "S80" :   If func TRTDADSU.EXIST("TRTDADSUSPE") : Gosub LIGNE_S80   From TRTDADSUSPE : Endif
 When "S90" :   If func TRTDADSU.EXIST("TRTDADSUSPE") : Gosub LIGNE_S90   From TRTDADSUSPE : Endif
#CHECK IGNORE_END
Endcase
Return

$OUVRE
Gosub OUVFIC
Gosub DECLARATION
Gosub AFFECTATION
Return

Funprog EXIST(TRT)
Value Char TRT
Local Integer FLG
Call EXISTE_ADX("","",TRT,FLG) From ORDSYS
End FLG

#########################################
$OUVFIC
If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif
If clalev([F:CPY2])=0 : Local File COMPANY   [CPY2] : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif
If clalev([F:ADI])=0  : Local File ATABDIV    [ADI] : Endif

If clalev([F:FCS])=0  : Local File FACILITY   [FCS] : Endif # site siège
If clalev([F:FCD])=0  : Local File FACILITY   [FCD] : Endif # site destinataire du CRE
If clalev([F:FCX])=0  : Local File FACILITY   [FCX] : Endif # site expéditeur (déclarant)
If clalev([F:BPA])=0  : Local File BPADDRESS  [BPA] : Endif # S80
If clalev([F:BPS])=0  : Local File BPADDRESS  [BPS] : Endif # adresse site siège
If clalev([F:BPD])=0  : Local File BPADDRESS  [BPD] : Endif # adresse principale du destinataire du CRE
If clalev([F:BPX])=0  : Local File BPADDRESS  [BPX] : Endif # adresse expéditeur / déclarant / émetteur

If clalev([F:CNT])=0  : Local File CONTACT    [CNT] : Endif
If clalev([F:AIS])=0  : Local File CONTACTCRM [AIS] : Endif # contact site siège
If clalev([F:AID])=0  : Local File CONTACTCRM [AID] : Endif # contact destinataire du CRE
If clalev([F:AIX])=0  : Local File CONTACTCRM [AIX] : Endif # contact expéditeur

If clalev([F:FTD])=0  : Local File FILTDS     [FTD] Order By NUMREC : Endif
If clalev([F:HLN])=0  : Local File HONLIN     [HLN] : Endif # lignes d'honoraires
If clalev([F:HLN2])=0  : Local File HONLIN    [HLN2]: Endif # lignes d'honoraires
If clalev([F:PRV])=0  : Local File HONPRV     [PRV] : Endif # Prestataires d'honoraires
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY] : Endif # Exercices
If clalev([F:TCY])=0  : Local File TABCOUNTRY [TCY] : Endif # Pays
If clalev([F:PRM])=0  : Local File PRMDADSU   [PRM] : Endif # paramétrage DADS-U
If clalev([F:EDU])=0  : Local File EDTDADSU   [EDU] : Endif # Edition fichier DADSU
Return

#########################################
$DECLARATION
Local Char TIT (50)
Local Char RESULTAT (100)
Local Integer I, OK, FIN, N, N2, NUMLIN
Local Char ZONE (250)

#Variables pour les totaux finaux
Local Integer NBLIG

#Divers
Local Integer STAT

N = len(mess(0,615,1))               : # 615 : Types d'honoraires
Local Decimal AMTHON(1..N)           : # Totaux par ligne honoraire
Local Decimal TOTAMTHON              : # Total par prestataire
Local Decimal AMTVAT                 : # montant TVA des droits d'auteur
Local Char    FIYEND(8)
Local Char    PAYS(250)
Local Char    SOC(GLONCPY)
Return

#########################################
$AFFECTATION
NBLIG=0
[M:DIA]NBRUB=0
[M:DIA]NBST20=0
Return

#########################################
$EXEC
Gosub OUVRE
If clalev([F:FTD])=0 : Local File FILTDS   [F:FTD] : Endif
# Génération du fichier DADS-U
TIT=mess(63,122,1)
Call OUVRE_TRACE(TIT) From LECFIC
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70," "),0) From GESECRAN
Call NUMERO("DAS","",date$,"",[M:DIA]REFSND,STAT) From SUBANM
If STAT <> 0
 Call ERREUR("DAS"-mess(60,199,1)) From GESECRAN # "Problème lors de la récupération du compteur"
 Call ECR_TRACE("DAS"-mess(60,199,1),1) From GESECRAN
 FIN=1
 Return
Endif
Onerrgo ERREUR
Read [FCY]FCY0=[M:DIA]SENFCY
Read [CPY]CPY0=[F:FCY]LEGCPY
Read [PRM]PRM0=[F:CPY]CPY
# Erreur lors de la lecture de la table de paramétrage DADS-U
If fstat : Call ECR_TRACE(mess(120,104,1),1) From GESECRAN : Return : Endif
# Numéro de requête
Call ECR_TRACE(mess(62,122,1)-[M:DIA]REFSND, 0) From GESECRAN
Call ECR_TRACE("", 0) From GESECRAN

Gosub OUVRE_FICHIER
If FIN=1 : Return : Endif

[M:DIA]NBRUB=0

Gosub EXEC2

Call ECR_TRACE("",0) From GESECRAN
If GERRTRACE=0
 # "Aucune erreur n'a été détectée dans le fichier DADS-U généré !"
 Call ECR_TRACE(mess(60,122,1),0) From GESECRAN
Else
 # "Des erreurs sont survenues pendant la génération du fichier DADS-U. Ce dernier n'a pas été généré."
 Call ECR_TRACE(mess(61,122,2),1) From GESECRAN
Endif
Gosub FERME_FICHIER

Onerrgo
Return

$EXEC2
# boucle sur chaque société
If [M:DIA]ALLCPY=2
 Gosub LIGNE_S10
 If GERRTRACE : Return : Endif
 For [CPY] Where CPYLEGFLG=2
  SOC = [F:CPY]CPY
  Gosub LIGNE_S20
  SOC = [F:CPY]CPY
  Gosub LIGNE_S70
  SOC = [F:CPY]CPY
  For [FCY]FCY0 Where LEGCPY=SOC & DADFLG=2
   Gosub LIGNE_S80
  Next
 Next
Else
 NUMLIN = 0
 Gosub LIGNE_S10
 For N2=0 To [M:DIA]NBLIG-1
  SOC = [M:DIA]CPY(N2)
  Read [CPY]CPY0=SOC
  Gosub LIGNE_S20
  Gosub LIGNE_S70
  For [FCY]FCY0 Where LEGCPY=SOC & DADFLG=2
   Gosub LIGNE_S80
  Next
 Next
Endif
Gosub LIGNE_S90
Return

#########################################
$OUVRE_FICHIER
If filinfo(FICHIER,0)>=0
 OK=2
 # Fichier existant, souhaitez-vous l'écraser ?
 Call OUINON(mess(127,105,1),OK) From GESECRAN
# Traitement interrompu par l'utilisateur
 If OK=1 : Call ECR_TRACE(mess(121,104,1),0) From GESECRAN : FIN=1 : Return : Endif
Endif
Openo FICDON,0 Using [FIC]
Iomode adxifs "," Using [FIC] # séparateur de champs
Iomode adxirs chr$(13)+chr$(10) Using [FIC] # séparateur d'enregistrements
Iomode adxium GASCII Using [FIC] # charset
Return

$INTERP
 ERR=0
 OK=0
 Gosub INTERPRETE
 If [F:FTD]NUMREC="S70.G05.00.002" and RESULTAT>"3112"+num$([M:DIA]YEA)
  RESULTAT = gdat$(31, 12, [M:DIA]YEA)
 Endif
 If !ERR
  Gosub VERIF_FORMULE
# si non conditionnel OU ((conditionnel OU facultatif) ET non vide)  alors on l'écrit dans le fichier
  If [F:FTD]FLGREC=1 or [F:FTD]VALNUL=2 or (([F:FTD]FLGREC=2 or [F:FTD]FLGREC=3) and (([F:FTD]TYPREC=1 and RESULTAT<>"") or ([F:FTD]TYPREC=2 and RESULTAT<>"" and RESULTAT<>"0")))
      Wrseq [F:FTD]NUMREC+",'"+RESULTAT+"'" Using [FIC]
      [L]NUMLIN += 1
      Trbegin [EDU]
       [F:EDU]REFSND  = [M:DIA]REFSND
       [F:EDU]GRP     = [M:DIA]GRP
       [F:EDU]NUMLIN  = [L]NUMLIN
       [F:EDU]NUMREC  = [F:FTD]NUMREC
       [F:EDU]VALDADS = RESULTAT
       Write [EDU]
      Commit
   If GTEST : Call ECR_TRACE([F:FTD]NUMREC+",'"+RESULTAT+"'",0) From GESECRAN : Endif
   If [F:FTD]CTLLNG=2 & len(RESULTAT)<>[F:FTD]LNGREC # longueur fixe de N caractères
# Enregistrement # : la longueur de la valeur doit être exactement égale à # caractères
    Call ECR_TRACE(func AFNC.MES(func AFNC.MES(mess(64,122,1), [F:FTD]NUMREC), num$([F:FTD]LNGREC)),1) From GESECRAN
   Elsif [F:FTD]CTLLNG=1 & len(RESULTAT)>[F:FTD]LNGREC # longueur variable inférieure ou égale à N caractères
# Enregistrement # : la longueur de la valeur doit être inférieure ou égale à # caractères
    Call ECR_TRACE(func AFNC.MES(func AFNC.MES(mess(65,122,1), [F:FTD]NUMREC), num$([F:FTD]LNGREC)),1) From GESECRAN
   Endif
   If [FTD]FLGREC=1 & [FTD]VALNUL=1 & (RESULTAT="" | RESULTAT="0")
    Gosub ECRIT_TRACE
   Endif
   [M:DIA]NBRUB+=1
   If [F:FTD]NUMREC="S20.G01.00.001"
    [M:DIA]NBST20 += 1
   Endif
   OK=1
  Endif
 Endif
Return

#########################################
#Erreur
$ECRIT_TRACE
If left$([F:FTD]NUMREC,3)="S70" or left$([F:FTD]NUMREC,3)="S80"
 # Site : XXX : Valeur non renseignée : # "#"
 Call ECR_TRACE("-"-mess(3,45,1)-":"-[F:FCY]FCY-":"-func AFNC.MES(func AFNC.MES(mess(66,122,1), [F:FTD]NUMREC), [F:FTD]DESREC),1) From GESECRAN
Else
 # Valeur non renseignée : # "#"
 Call ECR_TRACE(func AFNC.MES(func AFNC.MES(mess(66,122,1), [F:FTD]NUMREC), [F:FTD]DESREC),1) From GESECRAN
Endif
Return

#########################################
$LIGNE_S10
# lecture du paramétrage DADS-U de la société
Read [FCD]FCY0=[F:PRM]DENFCY : If fstat : Raz [FCD] : Endif
Read [FCS]FCY0=[F:PRM]MAIFCY : If fstat : Raz [FCS] : Endif
Read [FCX]FCY0=[F:PRM]DCLFCY : If fstat : Raz [FCX] : Endif

Read [AID]AIN0=[F:PRM]DENCNT    : If fstat : Raz [AID] : Endif
Read [AIS]AIN0=[F:PRM]MAIFCYCNT : If fstat : Raz [AIS] : Endif
Read [AIX]AIN0=[F:PRM]DCLFCYCNT : If fstat : Raz [AIX] : Endif

Read [BPD]BPA0=3;[F:FCD]FCY;[F:PRM]DENADD    : If fstat : Raz [BPD] : Endif
Read [BPS]BPA0=3;[F:FCS]FCY;[F:PRM]MAIFCYADD : If fstat : Raz [BPS] : Endif
Read [BPX]BPA0=3;[F:FCX]FCY;[F:PRM]DCLFCYADD : If fstat : Raz [BPX] : Endif

Read [CNT]CNT0=3;[F:FCD]FCY;[F:AID]CNTNUM
[F:AID]CNTETS = [F:CNT]TEL
[F:AID]CNTFAX = [F:CNT]FAX
[F:AID]CNTEMA = [F:CNT]WEB

Read [CNT]CNT0=3;[F:FCS]FCY;[F:AIS]CNTNUM
[F:AIS]CNTETS = [F:CNT]TEL
[F:AIS]CNTFAX = [F:CNT]FAX
[F:AIS]CNTEMA = [F:CNT]WEB

Read [CNT]CNT0=3;[F:FCX]FCY;[F:AIX]CNTNUM
[F:AIX]CNTETS = [F:CNT]TEL
[F:AIX]CNTFAX = [F:CNT]FAX
[F:AIX]CNTEMA = [F:CNT]WEB

ACTION="S10" : Gosub ACTION : If OK=0 : Return : Endif
Read [CPY]CPY0=SOC
For [FTD] Where GRP=[M:DIA]GRP and XPSRES<>"" and left$(NUMREC,len("S10.G01.00"))="S10.G01.00"
 Gosub INTERP
Next
For [FTD] Where GRP=[M:DIA]GRP and XPSRES<>"" and (left$(NUMREC,len("S10.G01.01"))="S10.G01.01" or left$(NUMREC,len("S10.G01.05"))="S10.G01.05")
 Gosub INTERP
Next
Return

#########################################
$LIGNE_S20
# structures S20
# établissement siège = site principal de la société
ACTION="S20" : Gosub ACTION : If OK=0 : Return : Endif

Call ECR_TRACE(mess(26,113,1)-SOC,0) From GESECRAN # Société

# lecture du paramétrage de la société
Read [PRM]PRM0=SOC

Read [FCD]FCY0=[F:PRM]DENFCY : If fstat : Raz [FCD] : Endif
Read [FCS]FCY0=[F:PRM]MAIFCY : If fstat : Raz [FCS] : Endif
Read [FCX]FCY0=[F:PRM]DCLFCY : If fstat : Raz [FCX] : Endif

Read [BPD]BPA0=3;[F:FCD]FCY;[F:PRM]DENADD    : If fstat : Raz [BPD] : Endif
Read [BPS]BPA0=3;[F:FCS]FCY;[F:PRM]MAIFCYADD : If fstat : Raz [BPS] : Endif
Read [BPX]BPA0=3;[F:FCX]FCY;[F:PRM]DCLFCYADD : If fstat : Raz [BPX] : Endif

Read [AID]AIN0=[F:PRM]DENCNT    : If fstat : Raz [AID] : Endif
Read [AIS]AIN0=[F:PRM]MAIFCYCNT : If fstat : Raz [AIS] : Endif
Read [AIX]AIN0=[F:PRM]DCLFCYCNT : If fstat : Raz [AIX] : Endif

Read [CNT]CNT0=3;[F:FCD]FCY;[F:AID]CNTNUM
[F:AID]CNTETS = [F:CNT]TEL
[F:AID]CNTFAX = [F:CNT]FAX
[F:AID]CNTEMA = [F:CNT]WEB

Read [CNT]CNT0=3;[F:FCS]FCY;[F:AIS]CNTNUM
[F:AIS]CNTETS = [F:CNT]TEL
[F:AIS]CNTFAX = [F:CNT]FAX
[F:AIS]CNTEMA = [F:CNT]WEB

Read [CNT]CNT0=3;[F:FCX]FCY;[F:AIX]CNTNUM
[F:AIX]CNTETS = [F:CNT]TEL
[F:AIX]CNTFAX = [F:CNT]FAX
[F:AIX]CNTEMA = [F:CNT]WEB

For [FTD] Where GRP=[M:DIA]GRP and XPSRES<>"" and left$(NUMREC,len("S20"))="S20" and left$(NUMREC,len("S20.G05"))<>"S20.G05"
 Gosub INTERP
Next
# Traitement du sous-groupe S20.G05.00 Declaration de resultats
# Présent uniquement si le NIC de l'établissement déposant la déclaration de résultats de l'entreprise est différent
# du NIC du siège indiqué en S20.G01.00.008.
For [FTD] Where GRP=[M:DIA]GRP and XPSRES<>"" and left$(NUMREC,len("S20.G05"))="S20.G05" and [F:PRM]MAICRN<>[F:PRM]DCLCRN
 Gosub INTERP
Next
Return

#########################################
$LIGNE_S70
Read [CPY]CPY0=SOC
Call CONVERT(GSYSCUR,[F:CPY]ACCCUR,[F:CPY]ACCCUR,1,date$,PLANCHER1,PLANCHER,OK) From TRTDEV
For [FCY]FCY0 Where LEGCPY=SOC & DADFLG=2
  NN=0
  Filter [HLN] Where year(DAT)=[M:DIA]YEA & CPY=SOC & DADFCY=[F:FCY]FCY & AMTLOC<>0
  For [HLN]HLN1(2) : # Par site DADSU et prestataire
   Raz AMTHON, AMTVAT, TOTAMTHON
   For [HLN]HLN1
    If [F:HLN]HON=12
     AMTVAT += [F:HLN]AMTLOC
    Else
     AMTHON([F:HLN]HON) += [F:HLN]AMTLOC
    Endif
    TOTAMTHON += [F:HLN]AMTLOC

    Filter [FIY] Where CPY=[F:FCY]LEGCPY and year(FIYEND)=[M:DIA]YEA # CPY+FIYNUM
    Read [FIY] First
    [L]FIYEND=num$(day([F:FIY]FIYEND))+string$(2-len(num$(month([F:FIY]FIYEND))), '0')+num$(month([F:FIY]FIYEND))+num$(year([F:FIY]FIYEND))
    NN+=1
   Next
   If TOTAMTHON>=PLANCHER1
    Gosub LIGNE_S70_0
    Gosub LIGNE_S70_1
   Endif
  Next
  Filter [HLN]
Next
Return

# lignes S70.G01.00.*
$LIGNE_S70_0
# il faut lire le bon enregistrement de la table PRV
# établissement émetteur [M:DIA]SENFCY
ACTION="S70_0" : Gosub ACTION : If OK=0 : Return : Endif
Read [PRV]PRV0=[HLN]PRVNUM
Read [TCY]TCY0=[F:PRV]CRYCOD
PAYS=""
If [F:TCY]ISO<>"FR" and [F:TCY]ISO<>""
 Call LECTEXTRA(PAYS,"TABCOUNTRY","CRYDES",[F:TCY]ISO,"") From ATEXTRA
Endif
For [FTD] Where GRP=[M:DIA]GRP and XPSRES<>"" and (left$(NUMREC,len("S70.G05.00"))="S70.G05.00" or left$(NUMREC,len("S70.G10.00"))="S70.G10.00")
 Gosub INTERP
Next
Return

#########################################
# lignes S70.G10.*
$LIGNE_S70_1
# il faut lire le bon enregistrement de la table PRV
# établissement émetteur [M:DIA]SENFCY
ACTION="S70_1" : Gosub ACTION : If OK=0 : Return : Endif
Read [PRV]PRV0=[HLN]PRVNUM
Read [TCY]TCY0=[F:PRV]CRYCOD
PAYS=""
If [F:TCY]ISO<>"FR" and [F:TCY]ISO<>""
 Call LECTEXTRA(PAYS,"TABCOUNTRY","CRYDES",[F:TCY]ISO,"") From ATEXTRA
Endif

# traitement du sous-groupe S70.G10.05 Avantages en nature (valeur 10 du menu 615)
N=10
If AMTHON(N)>0
 For [FTD] Where GRP=[M:DIA]GRP and XPSRES<>"" and left$(NUMREC,len("S70.G10.05"))="S70.G10.05"
  #Call ECR_TRACE("$LIGNE_S70_1 boucle 1 : "+[F:FTD]NUMREC, 0) From GESECRAN
  Gosub INTERP
 Next
Endif

# traitement du sous-groupe S70.G10.10 Prise en charge des indemnités (valeur 9 du menu 615)
N=9
If AMTHON(N)>0
 For [FTD] Where GRP=[M:DIA]GRP and XPSRES<>"" and left$(NUMREC,len("S70.G10.10"))="S70.G10.10"
  #Call ECR_TRACE("$LIGNE_S70_1 boucle 2 : "+[F:FTD]NUMREC, 0) From GESECRAN
  Gosub INTERP
 Next
Endif

# traitement du sous-groupe S70.G10.15 Rémunérations
For N=1,2,3,4,5,6,7,8,11
 If AMTHON(N)>0
  For [FTD] Where GRP=[M:DIA]GRP and XPSRES<>"" and left$(NUMREC,len("S70.G10.15"))="S70.G10.15"
   #Call ECR_TRACE("$LIGNE_S70_1 boucle 3 : "+[F:FTD]NUMREC, 0) From GESECRAN
   Gosub INTERP
  Next
 Endif
Next
Return

#########################################
$LIGNE_S80
ACTION="S80" : Gosub ACTION : If OK=0 : Return : Endif
Read [BPA]BPA0=3;[FCY]FCY
Read [TCY]TCY0=[F:BPA]CRY
PAYS=""
If [F:PRV]CRYCOD<>"FR"
 Call LECTEXTRA(PAYS,"TABCOUNTRY","CRYDES",[F:PRV]CRYCOD,"") From ATEXTRA
Endif
For [FTD] Where GRP=[M:DIA]GRP and XPSRES<>"" and left$(NUMREC,len("S80"))="S80"
 Gosub INTERP
Next
Return

#########################################
$LIGNE_S90
ACTION="S90" : Gosub ACTION : If OK=0 : Return : Endif
[M:DIA]NBRUB+=2 # on ajoute les 2 dernières rubriques
For [FTD] Where GRP=[M:DIA]GRP and XPSRES<>"" and left$(NUMREC,len("S90"))="S90"
 Gosub INTERP
Next
Return

#########################################
$FERME_FICHIER
Openo Using [FIC]
If [M]TYPEXP=1
 Call COPCLI(FICDON,FICHIER,STAT) From ORDSYS
 If STAT=1
  # Fichier non copié sur le poste client
  Call ERREUR(mess(164,141,1)) From GESECRAN
  FIN=1 : Return
 Elsif STAT>1
  # Fichier inexistant
  Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
  FIN=1 : Return
 Endif
Endif
Return

#########################################
$VERIF_FORMULE
If RESULTAT <>"" & RESULTAT<>"0"
 # si l'enreg est de type numérique on arrondit à l'entier le plus proche
 If [F:FTD]TYPREC<>2
  # si l'enreg est de type date on enlève les /
  If [F:FTD]TYPREC=3
   If RESULTAT="00/00/0000"
    RESULTAT=""
   Endif
  Endif
 Endif
 # adaptation de la longueur
 If len(RESULTAT)>=[F:FTD]LNGREC
  RESULTAT=left$(RESULTAT,[F:FTD]LNGREC)
 Endif
Endif
Return

$INTERPRETE
RESULTAT = toupper(ctrans(num$(evalue([F:FTD]XPSRES))))
Return

#########################################
$ERREUR
# ....traitement....ligne....
Call ECR_TRACE([F:FTD]NUMREC-":"-errm-":"-errmes$(errn)-"("+mess(19,123,1)-errp-mess(17,104,1)-num$(errl)+")",1) From GESECRAN
ERR=1
Resume

######################################################################################

$S_GRP
Local Char DES(100)
If clalev([F:FTD])=0 : Local File FILTDS   [F:FTD] : Endif
# Choix du groupe de paramétrage
TIT(0) = mess(67,122,1)
NBTEX = 0
For [FTD]FTD1(1)
 [L]DES=[F:FTD]DES
 NBTEX += 1
 TEX(NBTEX) = [F:FTD]GRP
 If len([L]DES)=0
  TEXTE(NBTEX) = TEX(NBTEX)
 Else
  TEXTE(NBTEX) = TEX(NBTEX)-"-"-[L]DES
 Endif
Next
Filter [FTD]
Return

# formatage d'un nombre avec une virgule (pas de point décimal !) et exactement 2 chiffres après la virgule
Funprog FORMAT_AMT(AMT)
Value Decimal AMT
Local Char D(2)
If AMT=0 : End 0 : Endif
# récupération des 2 premiers chiffres de la partie décimale
D = left$(right$(num$(AMT-int(AMT)), 3), 2)
End num$(int(AMT))+"."+D+string$(max(0, 2-len(D)), "0")
