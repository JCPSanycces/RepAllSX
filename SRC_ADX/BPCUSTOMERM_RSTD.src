#<AdxTL>@(#)9.0.0.0 $Revision$
# Classe BPCUSTOMERM
#######################################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
        When "AREAD_AFTER"        :  Gosub AREAD_AFTER
        When "AQUERY_TRANS_AFTER" :  Gosub AQUERY_TRANS_AFTER
        When Default
    Endcase
   When "BPC.BPA"
    Case [L]AEVENT
        When "AREAD_AFTER"        :  Gosub AREAD_AFTER_BPA
        When Default
    Endcase
   When Default
Endcase
Return
#######################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]CURPTH
   When ""
      Case [L]AMETHOD
        When Default
      Endcase
    When Default
  Endcase
Return
#######################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return
#######################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "ROSTCTLPAR"
      Case [L]ARULE
        When "GET"
          Local Integer IOSTCTL

          IOSTCTL = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"OSTCTL")
          this.ROSTCTLPAR = IOSTCTL
        When Default
      Endcase
    When "ROSTCTLLEV"
      Case [L]ARULE
        When "GET"
          this.ROSTCTLLEV = "(" + mess(this.ROSTCTLPAR,286,1) + ")"
        When Default
      Endcase
    When Default
  Endcase
Return


#######################################################################################
$AREAD_AFTER
Local Integer IERROR
Local Char SCUR(GLONCUR)
Local Shortint IOSTCTL #Local Integer IOSTCTL #Local TINYINT IOSTCTL #
Local Decimal NOSTAUZ
Local Decimal NOST
Local Decimal NCDTISR
Local Date DCDTISRDAT
Local Decimal NORDMINAMT
Local Integer ILINE
Local Char SVCPY(GLONCPY)

  # ---------------------------------------------------------------------------------------
  IERROR = func BPCUSTOMER_PROG.LOAD_OST(this.BPC.BPCNUM, this.BPC.ACTX, "", "", SCUR, IOSTCTL, NOSTAUZ, NOST, NCDTISR, DCDTISRDAT, NORDMINAMT)
  If IERROR <> 0 Then
    # Traiter le cas de l'erreur ici FLORENT ICI
  Endif
  # -----------------------------
  this.ROSTCUR = SCUR
  this.ROSTCTL = IOSTCTL
  this.ROSTAUZ = NOSTAUZ
  this.ROST = NOST
  # ---------------------------------------------------------------------------------------
  # Vu avec Cyrille : à faire dans touts les cas
  # Si paramètre "OSTCTL" = 2-Société
  Raz SVCPY
  Local File BPCUSTMVT [MVC]
  Filter [F:MVC] Where [F:MVC]BPCNUM = this.BPC.BPCNUM
  For [MVC]MVC1
    If SVCPY <> [F:MVC]CPY Then
      SVCPY = [F:MVC]CPY
      IERROR = func BPCUSTOMER_PROG.LOAD_OST(this.BPC.BPCNUM, this.BPC.ACTX, [F:MVC]CPY, "", SCUR, IOSTCTL, NOSTAUZ, NOST, NCDTISR, DCDTISRDAT, NORDMINAMT)
      If IERROR = 0 Then
        If NOST <> 0 Then
          ILINE = fmet this.ADDLINE("OSTCLTCPY", [V]CST_AFIRSTPOS)
          this.OSTCLTCPY(ILINE).ROSTCPY = [F:MVC]CPY
          this.OSTCLTCPY(ILINE).ROSTCPYAUZ = NOST
          this.OSTCLTCPY(ILINE).ROSTCPYCUR = this.ROSTCUR
        Endif
      Endif
    Endif
  Next
  Filter [F:MVC]
  # ---------------------------------------------------------------------------------------
Return

#######################################################################################
$AQUERY_TRANS_AFTER
  Local File BPADDRESS [BPA]
  Read [F:BPA]BPA0=1;this.BPC.BPCNUM;this.BPC.BPAADD
  If !fstat
   this.RPOSCOD =  [F:BPA]POSCOD
  Endif
Return

#######################################################################################
$AREAD_AFTER_BPA
  # Affichage de l'adresse par défaut
  # Solution valable uniquement parce qu'on est en consultation
  # On détourne la propriété BPA.BPAADDFLG
  # -------------------------------------------------------------
  If this.APARENT = null Then
    Return
  Endif
  # -------------------------------------------------------------
  If this.BPAADD = this.APARENT.BPAADD Then
    this.BPAADDFLG = CST_AYES
  Else
    this.BPAADDFLG = CST_ANO
  Endif
Return

