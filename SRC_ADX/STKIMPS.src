#<AdxTL>@(#)8.0.0.0 $Revision$
########################################################################
# Traitement STKIMPS - Librairie des composants de màj stock      V140 #
#                      Import sortie                          MBT 2003 #
########################################################################
# Etiquette appelée par Gosub depuis le STKIMP                         #
#                                                                      #
# SORTIES     : Traitement de l'import des sorties de stock            #
#                                                                      #
########################################################################


$SORTIES
If GSTK_TRACE=2 & GSTK_ACTION<>"IMP_ZONE"
  GSTK_ACT=GSTK_ACTION : GSTK_PGM="STKIMPS" : Gosub TRACE_DETAILLEE From STKIMP
Endif
Case GSTK_ACTION
  When "OUVRE"       : Gosub OUVRE
  When "RAZCRE"      : Gosub RAZCRE
  When "SAIMSK"      : Gosub SAIMSK
  When "IMP_ZONE"    : Gosub IMP_ZONE
  When "RUPT_LIGDOC" : Gosub RUPT_LIGDOC
  When "VALID"       : Gosub VALID
  When "IMP_FERME"   : Gosub IMP_FERME
Endcase
Return


#-----------------------------------------#
# Début import : définition des variables #
#-----------------------------------------#
$OUVRE
#----- Variables globales -----#
Global Integer  GSTK_NBLIG              : # Nbre lignes document
Global Libelle  GSTK_ERR                : # Indicateur d'erreur
Global Char     GSTK_TRSCOD(GLONADI)    : # Code mouvement
Global Char     GSTK_ENTCOD(GLONGAU)    : # Code pièce auto
#----- Variables locales -----#
Local  Char     WSTK_ITMREF(GLONITM), WSTK_STOFCY(GLONFCY)
Local  Libelle  WSTK_FLAG
Local  Char     WSTK_FILTRE(250),  WSTK_FILTRA(250)
Local  Char     WSTK_FILTRE2(250), WSTK_FILTRA2(250)
Local  Decimal  WSTK_STOCOU   (dim([M:SOW]WSTOCOU))
Local  Decimal  WSTK_CUMWIPQTY(dim([M:SOW]WSTOCOU))
Local  Decimal  WSTK_CUMWIPQTA(dim([M:SOW]WSTOCOU))
Local  Shortint WSTK_I, WSTK_J, WSTK_K
Local  Integer  WSTK_NBR
Local  Integer  WSTK_WSTOSEQ, WSTK_WRET
Local  Char     WSTK_ABRMSK(10), WSTK_ANA(10)
Local  Char     WSTK_ABRTTR(5)
Local  Char     WSTK_PCU(GLONUOM)
Local  Shortint WSTK_DECPCU, WSTK_DECSTU
Local  Decimal  WSTK_QTYPCU, WSTK_QTYSTU, WSTK_QTYSTUACT, WSTK_PCUSTUCOE
Local  Decimal  WSTK_QTY,    WSTK_QTYACT, WSTK_QTY2
Local  Decimal  WSTK_ALLQTY, WSTK_ALLQTYACT
#----- Chargement abréviation du masque des lignes du document -----#
[L]WSTK_ABRMSK=mid$(GSTK_BASTAB,4,instr(1,GSTK_BASTAB,"]")-4)
#----- Principaux contrôles sur le modèle -----#
If find("[F:STJ]QTYPCU(0)",[M:AOE2]ZONMSK1) &
& !find("[F:STJ]PCU(0)",[M:AOE2]ZONMSK1)
  [L]WSTK_WRET=1 : Gosub TRT_ERREUR : Return : # Qté en UC sans l'UC !
Endif
If find("[F:STJ]ACTQTY(0)",[M:AOE2]ZONMSK1) &
& !find("[F:STJ]LOT(0)",[M:AOE2]ZONMSK1)    &
& !find("[F:STJ]POT(0)",[M:AOE2]ZONMSK1)    &
& !find("[F:STJ]ACT(0)",[M:AOE2]ZONMSK1)
  [L]WSTK_WRET=2 : Gosub TRT_ERREUR : Return : # Qté en Uactive et ni lot, ni titre !
Endif

#                                                            # hcb 71276 deb
# controle parametrage du stojou

#  L'import ne tient pas compte des versions de la table STOJOU. Les versions dépendent du lot
If find("[F:STJ]ECCVALMAJ(0)",[M:AOE2]ZONMSK1)
  [L]WSTK_WRET=10 : Gosub TRT_ERREUR : Return
Endif
If find("[F:STJ]ECCVALMIN(0)",[M:AOE2]ZONMSK1)
  [L]WSTK_WRET=10 : Gosub TRT_ERREUR : Return
Endif

#                                                            # hcb 71276 fin




#----- Ouverture fichiers si nécessaire -----#

If !clalev([F:STJ])  Local File STOJOU    [STJ] : Endif
If !clalev([F:STO])  Local File STOCK     [STO] : Endif
If !clalev([F:TUN])  Local File TABUNIT   [TUN] : Endif
If !clalev([F:TCO])  Local File TABCOEFF  [TCO] : Endif
If !clalev([F:STL])  Local File STOLOT    [STL] : Endif
If !clalev([F:LPN])  Local File LPN       [LPN] : Endif                      # hcb X3-85853
Return


#-----------------------------#
# Nouveau document à importer #
#-----------------------------#
$RAZCRE
Raz GSTK_NBLIG, GSTK_ERR
Raz [L]WSTK_STOCOU, [L]WSTK_CUMWIPQTY, [L]WSTK_CUMWIPQTA, [L]WSTK_NBR
Return


#---------------------------------------------#
# Chargement masque écran des sorties STOSORW #
#---------------------------------------------#
$SAIMSK
#----- Nouvelle ligne de document -----#
If !GSTK_NBLIG
  #----- Si article non géré en stock c'est fini ! -----#
  If [F:ITF]STOMGTCOD<2  Return : Endif
  #-----
  GSTK_NBLIG=evalue(GSTK_BASTAB)
  [L]WSTK_ITMREF=[F:ITM]ITMREF
  [L]WSTK_STOFCY=[F:ITF]STOFCY
  #----- Lien détail stock et ligne de document -----#
  Call STKWSTOSEQ ([L]WSTK_ABRMSK,GSTK_NBLIG-1,GSTK_NBLIG,1,[L]WSTK_WSTOSEQ,
&                  [L]WSTK_WRET) From STKECR
  If [L]WSTK_WRET  Return : Endif
  #----- Lecture de la règle de gestion -----#
  Call LECSRU ([L]WSTK_STOFCY,[F:ITM]TCLCOD,GSTK_TRSTYP,GSTK_TRSCOD,"",
&              [L]WSTK_WRET) From STKLIB
  If [L]WSTK_WRET  Return : Endif
  #----- Lecture unité de stock pour nbre de décimales -----#
  If [F:TUN]UOM<>[F:ITM]STU
    Read [F:TUN] TUN0=[F:ITM]STU : If fstat  Raz [F:TUN] : Endif
  Endif
  [L]WSTK_DECSTU=[F:TUN]UOMDEC
Endif
#----- Gestion des quantités -----#
Raz [L]WSTK_QTYPCU, [L]WSTK_QTYSTU,    [L]WSTK_QTYSTUACT
Raz [L]WSTK_PCU,    [L]WSTK_PCUSTUCOE, [L]WSTK_DECPCU
#----- Toutes les quantités sont forcément positives -----#
[F:STJ]QTYPCU=abs([F:STJ]QTYPCU)
[F:STJ]QTYSTU=abs([F:STJ]QTYSTU)
[F:STJ]ACTQTY=abs([F:STJ]ACTQTY)

#----- Traitement de la quantité en unité de conditionnement -----#
If find("[F:STJ]QTYPCU(0)",[M:AOE2]ZONMSK1)
  [L]WSTK_QTYPCU=[F:STJ]QTYPCU
  [L]WSTK_PCU   =[F:STJ]PCU
  #----- Lecture unité de conditionnement pour nbre de décimales -----#
  If [F:TUN]UOM<>[F:STJ]PCU
    Read [F:TUN] TUN0=[F:STJ]PCU : If fstat  Raz [F:TUN] : Endif
  Endif
  [L]WSTK_DECPCU=[F:TUN]UOMDEC
  #-----
  If !find("[F:STJ]QTYSTU(0)",[M:AOE2]ZONMSK1)
    If find("[F:STJ]PCUSTUCOE(0)",[M:AOE2]ZONMSK1)
      [L]WSTK_PCUSTUCOE=[F:STJ]PCUSTUCOE
    Else
      Read [TCO] TCO0=[F:STJ]PCU;[F:ITM]STU
      If !fstat
        If [F:TCO]COEUOM=0  [F:TCO]COEUOM=1 : Endif
        [L]WSTK_PCUSTUCOE=[F:TCO]COEUOM
      Else
        Read [TCO] TCO0=[F:ITM]STU;[F:STJ]PCU
        If fstat  Raz [F:TCO] : Endif
        If [F:TCO]COEUOM=0  [F:TCO]COEUOM=1 : Endif
        [L]WSTK_PCUSTUCOE=arr(1/[F:TCO]COEUOM,10^-6)
      Endif
    Endif
    [L]WSTK_QTYSTU=arr([L]WSTK_QTYPCU*[L]WSTK_PCUSTUCOE,10^-[L]WSTK_DECSTU)
  Endif
Endif
#----- Traitement de la quantité en unité de stock -----#
If find("[F:STJ]QTYSTU(0)",[M:AOE2]ZONMSK1)
  [L]WSTK_QTYSTU=[F:STJ]QTYSTU
  If !find("[F:STJ]QTYPCU(0)",[M:AOE2]ZONMSK1)
    [L]WSTK_QTYPCU   =[F:STJ]QTYSTU
    [L]WSTK_PCU      =[F:ITM]STU
    [L]WSTK_PCUSTUCOE=1
    [L]WSTK_DECPCU   =[L]WSTK_DECSTU
  Endif
Endif
#----- Traitement de la quantité en unité active de stock -----#
If find("[F:STJ]ACTQTY(0)",[M:AOE2]ZONMSK1)
  [L]WSTK_QTYSTUACT=[F:STJ]ACTQTY
  If !find("[F:STJ]QTYPCU(0)",[M:AOE2]ZONMSK1) & !find("[F:STJ]QTYSTU(0)",[M:AOE2]ZONMSK1)
    [L]WSTK_PCU      =[F:ITM]STU
    [L]WSTK_PCUSTUCOE=1
    [L]WSTK_DECPCU   =[L]WSTK_DECSTU
    If [F:ITF]STOMGTCOD=3
      If find("[F:STJ]LOT(0)",[M:AOE2]ZONMSK1)
        If [F:STL]ITMREF<>[F:ITM]ITMREF | [F:STL]LOT<>[F:STJ]LOT | [F:STL]SLO<>[F:STJ]SLO
          Read [STL] STL0=[F:ITM]ITMREF;[F:STJ]LOT;[F:STJ]SLO
          If fstat  Raz [F:STL] : Endif
        Endif
        If [F:STL]POT=0  [F:STL]POT=100 : Endif
        [L]WSTK_QTYSTU=arr([L]WSTK_QTYSTUACT*100/[F:STL]POT,10^-[L]WSTK_DECSTU)
        [L]WSTK_QTYPCU=arr([L]WSTK_QTYSTU/[L]WSTK_PCUSTUCOE,10^-[L]WSTK_DECPCU)
      Else
        If !find("[F:STJ]POT(0)",[M:AOE2]ZONMSK1) | [F:STJ]POT=0  [F:STJ]POT=100 : Endif
        [L]WSTK_QTYSTU=arr([L]WSTK_QTYSTUACT*100/[F:STJ]POT,10^-[L]WSTK_DECSTU)
        [L]WSTK_QTYPCU=arr([L]WSTK_QTYSTU/[L]WSTK_PCUSTUCOE,10^-[L]WSTK_DECPCU)
      Endif
    Elsif [F:ITF]STOMGTCOD=4
      If find("[F:STJ]LOT(0)",[M:AOE2]ZONMSK1)
        If [F:STL]ITMREF<>[F:ITM]ITMREF | [F:STL]LOT<>[F:STJ]LOT | [F:STL]SLO<>[F:STJ]SLO
          Read [STL] STL0=[F:ITM]ITMREF;[F:STJ]LOT;[F:STJ]SLO
          If fstat  Raz [F:STL] : Endif
        Endif
        If [F:STL]ACT=0  [F:STL]ACT=1 : Endif
        [L]WSTK_QTYSTU=arr([L]WSTK_QTYSTUACT/[F:STL]ACT,10^-[L]WSTK_DECSTU)
        [L]WSTK_QTYPCU=arr([L]WSTK_QTYSTU/[L]WSTK_PCUSTUCOE,10^-[L]WSTK_DECPCU)
      Else
        If !find("[F:STJ]ACT(0)",[M:AOE2]ZONMSK1) | [F:STJ]ACT=0  [F:STJ]ACT=1 : Endif
        [L]WSTK_QTYSTU=arr([L]WSTK_QTYSTUACT/[F:STJ]ACT,10^-[L]WSTK_DECSTU)
        [L]WSTK_QTYPCU=arr([L]WSTK_QTYSTU/[L]WSTK_PCUSTUCOE,10^-[L]WSTK_DECPCU)
      Endif
    Else
      [L]WSTK_QTYSTU=[L]WSTK_QTYSTUACT
      [L]WSTK_QTYPCU=arr([L]WSTK_QTYSTU/[L]WSTK_PCUSTUCOE,10^-[L]WSTK_DECPCU)
    Endif
  Endif
Endif
If WSTK_QTYSTU=0
  [L]WSTK_WRET=3 : Gosub TRT_ERREUR : mkstat=1 : Return : # Quantité nulle !
Endif

#----- Constitution du filtre -----#
[L]WSTK_FILTRE="1=1"
[L]WSTK_FILTRA='ITMREF="'+[L]WSTK_ITMREF+'" & STOFCY="'+[L]WSTK_STOFCY+'"'
Raz [L]WSTK_FLAG
#----- Article géré en numéro de série entrée/sortie, ce numéro doit être renseigné ----#
If [F:ITM]SERMGTCOD=3
  If find("[F:STJ]SERNUM(0)",[M:AOE2]ZONMSK1) & [F:STJ]SERNUM<>""
    #----- Filtre sur numéro de série, autres caractéristiques ignorées -----#
    [L]WSTK_FLAG=1
    [L]WSTK_FILTRE-="& SERNUM=[F:STJ]SERNUM"
    [L]WSTK_FILTRA-='& SERNUM="'+[F:STJ]SERNUM+'"'
  Else
    #----- Article géré en no de série : Son no de série doit être renseigné -----#
    [L]WSTK_FLAG=2
    [L]WSTK_FILTRA=[L]WSTK_ITMREF-mess(155,193,1)-mess(431,182,1)
  Endif
  #                                                                               # hcb 110327 deb
#----- Article géré en serie globale : La serie doit être renseigné ! -----#
Elsif [F:ITM]SERMGTCOD = 4 & (!find("[F:STJ]SERDEB(0)"   ,[M:AOE2]ZONMSK1) | [F:STJ]SERDEB="")
  [L]WSTK_FLAG=2
  [L]WSTK_FILTRA=[L]WSTK_ITMREF-mess(612,197,1)
#                                                                                # hcb 110327 fin
#----- Article géré en lot : Le lot doit être renseigné ! -----#
Elsif [F:ITM]LOTMGTCOD>2 & (!find("[F:STJ]LOT(0)"   ,[M:AOE2]ZONMSK1) | [F:STJ]LOT="")
  [L]WSTK_FLAG=2
  [L]WSTK_FILTRA=[L]WSTK_ITMREF-mess(612,197,1)
#----- Article géré en sous-lot : Le sous-lot doit être renseigné ! -----#
Elsif [F:ITM]LOTMGTCOD>3 & (!find("[F:STJ]SLO(0)",[M:AOE2]ZONMSK1) | [F:STJ]SLO="")
  [L]WSTK_FLAG=2
  [L]WSTK_FILTRA=[L]WSTK_ITMREF-mess(613,197,1)
#----- Article géré par emplacement : L'emplacement doit être renseigné ! -----#
Elsif [F:ITF]LOCMGTCOD>1 & (!find("[F:STJ]LOC(0)",[M:AOE2]ZONMSK1) | [F:STJ]LOC="")
  [L]WSTK_FLAG=2
  [L]WSTK_FILTRA=[L]WSTK_ITMREF-mess(614,197,1)
#----- Filtre en fonction des caractéristiques renseignées -----#
Else
  If find("[F:STJ]LOT(0)",[M:AOE2]ZONMSK1) & [F:ITM]LOTMGTCOD>1 & [F:STJ]LOT<>""
    [L]WSTK_FLAG=1
    [L]WSTK_FILTRE-="& LOT=[F:STJ]LOT"
    [L]WSTK_FILTRA-='& LOT="'+[F:STJ]LOT+'"'
  Endif
  If find("[F:STJ]SLO(0)",[M:AOE2]ZONMSK1) & [F:ITM]LOTMGTCOD>3 & [F:STJ]SLO<>""
    [L]WSTK_FLAG=1
    [L]WSTK_FILTRE-="& SLO=[F:STJ]SLO"
    [L]WSTK_FILTRA-='& SLO="'+[F:STJ]SLO+'"'
  Endif
  If find("[F:STJ]BPSLOT(0)",[M:AOE2]ZONMSK1) & [F:ITM]LOTMGTCOD>1 & [F:STJ]BPSLOT<>""
    [L]WSTK_FILTRE-="& BPSLOT=[F:STJ]BPSLOT"
    [L]WSTK_FILTRA-='& BPSLOT="'+[F:STJ]BPSLOT+'"'
  Endif
  If find("[F:STJ]PALNUM(0)",[M:AOE2]ZONMSK1) & [F:STJ]PALNUM<>""
    [L]WSTK_FILTRE-="& PALNUM=[F:STJ]PALNUM"
    [L]WSTK_FILTRA-='& PALNUM="'+[F:STJ]PALNUM+'"'
  Endif
  If find("[F:STJ]CTRNUM(0)",[M:AOE2]ZONMSK1) & [F:STJ]CTRNUM<>""
    [L]WSTK_FILTRE-="& CTRNUM=[F:STJ]CTRNUM"
    [L]WSTK_FILTRA-='& CTRNUM="'+[F:STJ]CTRNUM+'"'
  Endif
  If find("[F:STJ]STA(0)",[M:AOE2]ZONMSK1) & [F:STJ]STA<>""
    [L]WSTK_FILTRE-="& STA=[F:STJ]STA"
    [L]WSTK_FILTRA-='& STA="'+[F:STJ]STA+'"'
  Endif
  If find("[F:STJ]LOC(0)",[M:AOE2]ZONMSK1) & [F:ITF]LOCMGTCOD>1 & [F:STJ]LOC<>""
    [L]WSTK_FLAG=1
    [L]WSTK_FILTRE-="& LOC=[F:STJ]LOC"
    [L]WSTK_FILTRA-='& LOC="'+[F:STJ]LOC+'"'
  Endif
  If find("[F:STJ]PCU(0)",[M:AOE2]ZONMSK1) & [F:STJ]PCU<>""
    [L]WSTK_FILTRE-="& PCU=[F:STJ]PCU"
    [L]WSTK_FILTRA-='& PCU="'+[F:STJ]PCU+'"'
  Endif
  If find("[F:STJ]PCUSTUCOE(0)",[M:AOE2]ZONMSK1) & [F:STJ]PCUSTUCOE<>0
    [L]WSTK_FILTRE-="& PCUSTUCOE=[F:STJ]PCUSTUCOE"
    [L]WSTK_FILTRA-='& PCUSTUCOE='+num$([F:STJ]PCUSTUCOE)
  Endif
  If find("[F:STJ]OWNER(0)",[M:AOE2]ZONMSK1) & [F:STJ]OWNER<>""
    [L]WSTK_FILTRE-="& OWNER=[F:STJ]OWNER"
    [L]WSTK_FILTRA-='& OWNER="'+[F:STJ]OWNER+'"'
  Endif

  If find("[F:STJ]STOFLD1(0)",[M:AOE2]ZONMSK1) & [F:STJ]STOFLD1<>""
    [L]WSTK_FILTRE+="&STOFLD1=[F:STJ]STOFLD1"
    [L]WSTK_FILTRA+='&STOFLD1="'+[F:STJ]STOFLD1+'"'
  Endif
  If find("[F:STJ]STOFLD2(0)",[M:AOE2]ZONMSK1) & [F:STJ]STOFLD2<>""
    [L]WSTK_FILTRE+="&STOFLD2=[F:STJ]STOFLD2"
    [L]WSTK_FILTRA+='&STOFLD2="'+[F:STJ]STOFLD2+'"'
  Endif
#                                                                                           # hcb x3-85853 deb
  If find("[F:STJ]LPNNUM(0)",[M:AOE2]ZONMSK1) & [F:ITF]LPNMGTCOD = 2 & [F:STJ]LPNNUM<>""
    [L]WSTK_FLAG=1
    [L]WSTK_FILTRE-="& LPNNUM=[F:STJ]LPNNUM"
    [L]WSTK_FILTRA-='& LPNNUM="'+[F:STJ]LPNNUM+'"'
  Endif
#                                                                                           # hcb x3-85853 fin

  [L]WSTK_FILTRE2=[L]WSTK_FILTRE
  [L]WSTK_FILTRA2=[L]WSTK_FILTRA
  If find("[F:STJ]SERNUM(0)",[M:AOE2]ZONMSK1) & [F:ITM]SERMGTCOD>1 & [F:STJ]SERNUM<>""
    [L]WSTK_FLAG=1
    [L]WSTK_FILTRE-="& SERNUM=[F:STJ]SERNUM"
    [L]WSTK_FILTRA-='& SERNUM="'+[F:STJ]SERNUM+'"'
  Endif
Endif
#----- Trace du filtre permettant de sélectionner les lignes de stock à sortir -----#
If GSTK_TRACE=2
  If [L]WSTK_FLAG<2
    GSTK_MESS=mess(302,198,1)-":"-[L]WSTK_FILTRA
    Call ECR_TRACE(GSTK_MESS,0) From GESECRAN
    If len([L]WSTK_FILTRA)>97-len(mess(302,198,1))
      GSTK_MESS=right$([L]WSTK_FILTRA,98-len(mess(302,198,1)))
      Call ECR_TRACE(GSTK_MESS,0) From GESECRAN
    Endif
  Else
    GSTK_MESS=[L]WSTK_FILTRA
    Call ECR_TRACE(GSTK_MESS,1) From GESECRAN
    GSTK_ERR=1
  Endif
  Call ECR_TRACE(mess(45,196,1)-num$([L]WSTK_QTYPCU)-[L]WSTK_PCU,0) From GESECRAN
Elsif [L]WSTK_FLAG=2
  GSTK_MESS=[L]WSTK_FILTRA
  Call ECR_TRACE(GSTK_MESS,1) From GESECRAN
  GSTK_ERR=1
Endif
#-----
[L]WSTK_I=[M:SOW]NBLIG
[L]WSTK_QTY=[L]WSTK_QTYSTU
Raz [L]WSTK_WRET

WSERSOR=0
$LOOP_SER
If [L]WSTK_FLAG<2
  Filter [STO] Where ITMREF=[L]WSTK_ITMREF
&                  & STOFCY=[L]WSTK_STOFCY
&                  & evalue([L]WSTK_FILTRE)
  If [F:STJ]SERNUM<>""
    WSEROK =0
    For [STO] STO5
      WSEROK=1
      Gosub TRT_STOCK : If [L]WSTK_QTY=0 | [L]WSTK_WRET<>0  Break : Endif
    Next
    If [F:ITM]SERMGTCOD=2 & WSEROK=0
      [L]WSTK_FILTRE=[L]WSTK_FILTRE2
      [L]WSTK_FILTRA=[L]WSTK_FILTRA2
      WSERSOR=1
      Filter [STO]
      Goto LOOP_SER
    Else
      WSEROK=0
    Endif
  Elsif [F:STJ]LOT="" & [F:STJ]PALNUM<>""
    For [STO] STO1
      Gosub TRT_STOCK : If [L]WSTK_QTY=0 | [L]WSTK_WRET<>0  Break : Endif
    Next
  Else
    For [STO] STO3
      Gosub TRT_STOCK : If [L]WSTK_QTY=0 | [L]WSTK_WRET<>0  Break : Endif
    Next
  Endif
  Filter [STO]
Endif

# Génération d'un mouvement en attente
If [L]WSTK_QTY > 0 & [F:ITM]NEGSTO = 2
   Gosub TRT_STOCK_ATT
Endif

If [L]WSTK_FLAG<2 & [L]WSTK_WRET=0 & [L]WSTK_QTY=0
  [M:SOW]NBLIG=[L]WSTK_I
#  #----- Traitement des sections analytiques -----#
  Raz [L]WSTK_ANA
  Case [L]WSTK_ABRMSK
    When "SDH1"        : [L]WSTK_ANA="STKLIV"
    When "SIH4"        : [L]WSTK_ANA="STKFAC"
    When "PNH1"        : [L]WSTK_ANA="STKPRT"
#   When "SMO1"        : [L]WSTK_ANA="STKSODD"                         # hcb 107042
    When "SMO1"        : [L]WSTK_ANA="STJSOR"                          # hcb 107042
    When "MTK3", "MBM" : [L]WSTK_ANA="STKSOF"
  Endcase
  #----- Valeurs par défaut -----#
  If [L]WSTK_ANA<>""
    Call STKINISEC([L]WSTK_WSTOSEQ,[L]WSTK_ANA,"SOW") From STKECR
  Endif
  #----- Chargement des valeurs si elles sont importées -----#
  [L]WSTK_K=sigma([L]WSTK_J=0,[M:SOW]NBLIG2-1,
&                ([L]WSTK_J)*([M:SOW]WSTOSEQ2([L]WSTK_J)=[L]WSTK_WSTOSEQ))
  If [L]WSTK_K=0
    [L]WSTK_K=[M:SOW]NBLIG2
 # Else                     # hcb 122163
 # [L]WSTK_K-=1             # hcb 122163

  Endif

  For [L]WSTK_J=1 To GNBDIE
    # FGR 15/01/2010 : X3SUIVI60986
    #If find("[F:STJ]CCE([L]WSTK_J-1)",[M:AOE2]ZONMSK1) & dim([M:SOW]CCE([L]WSTK_J-1))>0
    If find("[F:STJ]CCE([L]WSTK_J-1)",[M:AOE2]ZONMSK1) & evalue("dim([M:SOW]CCE"+num$([L]WSTK_J)+"("+num$([L]WSTK_K)+"))") > 0
      Assign "[M:SOW]CCE"+num$([L]WSTK_J)+"("+num$([L]WSTK_K)+")" With [F:STJ]CCE([L]WSTK_J-1)
    Endif
  Next [L]WSTK_J
  [M:SOW]WSTOSEQ2([L]WSTK_K)=[L]WSTK_WSTOSEQ
  If [L]WSTK_K<=[M:SOW]NBLIG2  [M:SOW]NBLIG2+=1 : Endif
Else
  #----- Le stock doit impérativement être trouvé si no série ou lot ou emplacement -----#
  If [L]WSTK_FLAG=1 & [L]WSTK_WRET=0  [L]WSTK_WRET=4 : Endif
  #----- Erreur bloquante -----#
  If [L]WSTK_WRET
    Gosub TRT_ERREUR : mkstat=1 : Return
  #----- Stock à sortir non trouvé, le stock à sortir déterminé ultérieurement -----#
  Elsif GTRACE<>"" & [L]WSTK_FLAG=0
    Call ECR_TRACE(mess(560,197,1),0) From GESECRAN
  Endif
Endif

Return

#---------------------------------#
# Traitement d'une ligne de stock #
#---------------------------------#
$TRT_STOCK
Local    Integer  J, WRET, WNBSERIE, WOK                         # hcb 110327
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)              # hcb 110327
If [F:STO]CUNLOKFLG=2    Return : Endif : # En cours d'inventaire
Raz GPE                         # hcb 85114
GPOINT = "TRTSTOQ"              # hcb 85114
Gosub  ENTREE From EXEFNC       # hcb 85114
If GPE =  0                     # hcb 85114
   If [F:STO]QLYCTLDEM<>""  Return : Endif : # Demande d'analyse en cours
Endif                           # hcb 85114
Raz [L]WSTK_ALLQTY, [L]WSTK_ALLQTYACT
#----- Traitements spécifiques -----#
Case [L]WSTK_ABRMSK
  When "SDH1"
    #----- Pour les livraisons, voir si allocations sur commande -----#
    If clalev([M:SDH1]) & [M:SDH1]XSOHNUM([M:SDH1]NBLIG-1)<>""
      Call RECALLSTO([F:STO]STOFCY,[F:STO]STOCOU,2,[M:SDH1]XSOHNUM([M:SDH1]NBLIG-1),
&                    [M:SDH1]SOPLIN([M:SDH1]NBLIG-1),[M:SDH1]SOQSEQ([M:SDH1]NBLIG-1),
&                    [L]WSTK_ALLQTY,[L]WSTK_ALLQTYACT) From STKSOR
    Endif
    #-----
  When "SIH4"
  When "PNH1"
  When "SMO1"
  When "MTK3", "MBM"
    # Issue 75369 - 2011-07-27 by CCC : recherche alloc sur OF
    If clalev([M:MBM]) & [M:MBM]MFGNUM([M:MBM]NBLIG-1)<>""
      Call RECALLSTO([F:STO]STOFCY,[F:STO]STOCOU,10,[M:MBM]MFGNUM([M:MBM]NBLIG-1),
&                    [M:MBM]MFGLIN([M:MBM]NBLIG-1),[M:MBM]BOMSEQ([M:MBM]NBLIG-1),
&                    [L]WSTK_ALLQTY,[L]WSTK_ALLQTYACT) From STKSOR
    Endif
Endcase
#-----
If [F:STO]QTYSTU-[F:STO]CUMALLQTY-[F:STO]CUMWIPQTY+[L]WSTK_ALLQTY<=0
  Return : # Pas de disponible
Endif
[L]WSTK_QTY2=[F:STO]QTYSTU-[F:STO]CUMALLQTY-[F:STO]CUMWIPQTY+[L]WSTK_ALLQTY
[L]WSTK_J=find([F:STO]STOCOU,[L]WSTK_STOCOU(0..[L]WSTK_NBR-1))
If [L]WSTK_J
  [L]WSTK_QTY2-=[L]WSTK_CUMWIPQTY([L]WSTK_J-1)
Endif
If WSTK_QTY2<=0  Return : Endif : # Pas de disponible
If WSTK_QTY2>[L]WSTK_QTY  [L]WSTK_QTY2=[L]WSTK_QTY : Endif
[L]WSTK_QTYACT=arr([L]WSTK_QTY2*[F:STO]QTYSTUACT/[F:STO]QTYSTU,10^-[L]WSTK_DECSTU)
If [L]WSTK_J
  [L]WSTK_CUMWIPQTY([L]WSTK_J-1)+=[L]WSTK_QTY2
  [L]WSTK_CUMWIPQTA([L]WSTK_J-1)+=[L]WSTK_QTYACT
Else
  If [L]WSTK_NBR>=dim([L]WSTK_STOCOU)  [L]WSTK_WRET=5 : Return : Endif
  [L]WSTK_STOCOU   ([L]WSTK_NBR)=[F:STO]STOCOU
  [L]WSTK_CUMWIPQTY([L]WSTK_NBR)=[L]WSTK_QTY2
  [L]WSTK_CUMWIPQTA([L]WSTK_NBR)=[L]WSTK_QTYACT
Endif
[M:SOW]WSTOSEQ   ([L]WSTK_I)=[L]WSTK_WSTOSEQ
[M:SOW]WSTOCOU   ([L]WSTK_I)=[F:STO]STOCOU
[M:SOW]WQTYSTU   ([L]WSTK_I)=[L]WSTK_QTY2
[M:SOW]WQTYSTUACT([L]WSTK_I)=[L]WSTK_QTYACT
[M:SOW]WALLSTU   ([L]WSTK_I)=[L]WSTK_ALLQTY
[M:SOW]WALLSTUACT([L]WSTK_I)=[L]WSTK_ALLQTYACT
Raz [M:SOW]WSERNUM([L]WSTK_I), [M:SOW]WLOT([L]WSTK_I), [M:SOW]WSLO   ([L]WSTK_I),
&   [M:SOW]WSTA   ([L]WSTK_I), [M:SOW]WLOC([L]WSTK_I), [M:SOW]WPLFSTO([L]WSTK_I)
If [F:STJ]SERNUM<>"" & [F:ITM]SERMGTCOD=2 & WSERSOR=1
  [M:SOW]WSERNUM([L]WSTK_I)=[F:STJ]SERNUM
#--- Bug 72574
Elsif [F:STO]SERNUM<>"" & [F:ITM]SERMGTCOD=2
  [M:SOW]WSERNUM([L]WSTK_I)=[F:STO]SERNUM
#---
Endif
#                                                        # hcb 110327 deb
If [F:STJ]SERDEB<>"" & [F:ITM]SERMGTCOD=4
   [M:SOW]WSERNUM([L]WSTK_I)=[F:STJ]SERDEB
   WNBSERIE = [M:SOW]WQTYSTU([L]WSTK_I)
   WNUMDEB  = [M:SOW]WSERNUM([L]WSTK_I)
   WNUMFIN  = [M:SOW]WSERNUM([L]WSTK_I)
   Read [STS]STS0=[F:ITM]ITMREF;WNUMFIN
   If fstat
      GMESSAGE=WNUMFIN-":"-mess(43,196,1)  # Numéro de série inexistant
      GOK=0
      [L]WSTK_WRET=9
   Elsif [F:STS]ISSDAT<>[0/0/0]
         GMESSAGE=WNUMFIN-":"-mess(37,184,1)  # N° de série sorti par une autre piece
         GOK=0
         [L]WSTK_WRET=9
   Elsif [F:STS]STOCOU<>[M:SOW]WSTOCOU ([L]WSTK_I)
         GMESSAGE=WNUMFIN-":"-mess(447,184,1) # N° de série lié à une autre ligne de stock
         GOK=0
         [L]WSTK_WRET=9
   Endif
   If  [L]WSTK_WRET <> 9 & WNBSERIE > 1
      For J=2 To WNBSERIE
          Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
          If WRET=0
             Read [STS]STS0=[F:ITM]ITMREF;WNUMFIN
             If fstat
                   GMESSAGE=WNUMFIN-":"-mess(43,196,1)  # Numéro de série inexistant
                   GOK=0
                   [L]WSTK_WRET=9
             Elsif [F:STS]ISSDAT<>[0/0/0]
                   GMESSAGE=WNUMFIN-":"-mess(37,184,1)  # N° de série sorti par une autre piece
                   GOK=0
                   [L]WSTK_WRET=9
             Elsif [F:STS]STOCOU<>[M:SOW]WSTOCOU ([L]WSTK_I)
                   GMESSAGE=WNUMFIN-":"-mess(447,184,1) # N° de série lié à une autre ligne de stock
                   GOK=0
                   [L]WSTK_WRET=9
             Endif
          Else
             GMESSAGE=WNUMDEB-":"-mess(476,197,1)   # Erreur sur incrémentation des numéros de série
             GOK=0
             [L]WSTK_WRET=9
          Endif
          If [L]WSTK_WRET=9
             Break
          Endif
      Next
   Endif
   If [L]WSTK_WRET <> 9
      Call VERIF_DESYNCHRO_SERIE([F:ITM]ITMREF,[F:STO]STOCOU,[F:STO]QTYSTUACT,WOK) From STKLIB
      If WOK = 2
         GMESSAGE=num$([F:STO]STOCOU)-":"-mess(302,199,1) # Désynchronisation des numéros de série (Stock / Séries)
         GOK=0
         [L]WSTK_WRET=9
      Endif
   Endif
   If [L]WSTK_WRET=9
      Gosub TRT_ERREUR
      Raz [L]WSTK_WRET
      Return
   Endif
Endif
#                                                        # hcb 110327 fin
[L]WSTK_I+=1
[L]WSTK_QTY-=[L]WSTK_QTY2

#--- Issue 112802
## hcb 100261 deb
#[F:STO]CUMWIPQTY += [L]WSTK_QTY2
#[F:STO]CUMWIPQTA += [L]WSTK_QTYACT
#Rewrite [STO]
#If fstat
#  GMESSAGE-=(mess(13,100,1)-" : "-"STOLOT")
#  GOK=0
#  [L]WSTK_WRET=9 : Gosub TRT_ERREUR : Return
#Endif
# hcb 100261 fin
If [L]WSTK_QTYACT-[L]WSTK_ALLQTYACT>0
  [F:STO]CUMWIPQTY += [L]WSTK_QTY2-[L]WSTK_ALLQTY
  [F:STO]CUMWIPQTA += [L]WSTK_QTYACT-[L]WSTK_ALLQTYACT
  Rewrite [STO]
  If fstat
    GMESSAGE-=(mess(13,100,1)-" : "-"STOLOT")
    GOK=0
    [L]WSTK_WRET=9 : Gosub TRT_ERREUR : Return
  Endif
Endif
#--- End issue 112802

Return

#--------------------------------------------#
# Traitement d'une ligne de stock en attente #
#--------------------------------------------#
$TRT_STOCK_ATT
Raz [L]WSTK_ALLQTY, [L]WSTK_ALLQTYACT
#----- Traitements spécifiques -----#
Case [L]WSTK_ABRMSK
  When "SDH1"
  When "SIH4"
  When "PNH1"
  When "SMO1"
  When "MTK3", "MBM"
Endcase
#-----
[L]WSTK_QTY2  =[L]WSTK_QTY
[L]WSTK_QTYACT=[L]WSTK_QTY
[M:SOW]WSTOSEQ   ([L]WSTK_I)=[L]WSTK_WSTOSEQ
[M:SOW]WSTOCOU   ([L]WSTK_I)=0
[M:SOW]WQTYSTU   ([L]WSTK_I)=[L]WSTK_QTY2
[M:SOW]WQTYSTUACT([L]WSTK_I)=[L]WSTK_QTYACT
[M:SOW]WALLSTU   ([L]WSTK_I)=0
[M:SOW]WALLSTUACT([L]WSTK_I)=0
[M:SOW]WSERNUM([L]WSTK_I)=[F:STJ]SERNUM
[M:SOW]WLOT([L]WSTK_I)   =[F:STJ]LOT
[M:SOW]WSLO([L]WSTK_I)   =[F:STJ]SLO
[M:SOW]WSTA([L]WSTK_I)   =[F:STJ]STA
[M:SOW]WLOC([L]WSTK_I)   =[F:STJ]LOC
[M:SOW]WLPNNUM([L]WSTK_I)   =[F:STJ]LPNNUM                                # hcb X3-85853
Raz [M:SOW]WPLFSTO([L]WSTK_I)
[L]WSTK_I+=1
[L]WSTK_QTY-=[L]WSTK_QTY2
Return

#-----------------------------------------#
# Equivalent à la saisie d'un champ fiche #
# --------------------------------------- #
# IMPFIC : Abréviation du fichier         #
# IMPMSK : Nom de l'écran en cours        #
# IMPZON : Nom du champ en cours          #
# IMPMOD : Déclenche l'Après_modif        #
# OK     : Conditionne IMP_ZONE standard  #
#                                         #
# Nota : Jamais appelé pour l'instant !   #
# le chargement des champs est fait dans  #
# l'étiquette $SAIMSK ci-dessus           #
#-----------------------------------------#
$IMP_ZONE
#--- Bug 65601
#If find("[F:STJ]"+IMPZON+"("+num$(indice)+")",[M:AOE2]ZONMSK1)
#  If GSTK_TRACE=2
#    GSTK_ACT="IMP_ZONE("+IMPZON+")" : GSTK_PGM="STKIMPS"
#    Gosub TRACE_DETAILLEE From STKIMP
#  Endif
#  If evalue("[M:SOR]"+IMPZON+"("+num$(indice)+")")<>evalue("[F:STJ]"+IMPZON+"("+num$(indice)+")")
#    Assign "[M:SOR]"+IMPZON+"("+num$(indice)+")" With evalue("[F:STJ]"+IMPZON+"("+num$(indice)+")")
#    IMPMOD=1
#  Endif
#  OK=0
#Endif
Case IMPZON
  When "LOC"
    If find("[F:STJ]LOC(0)",[M:AOE2]ZONMSK1)
      If GSTK_TRACE=2
        GSTK_ACT="IMP_ZONE(LOC)" : GSTK_PGM="STKIMPS"
        Gosub TRACE_DETAILLEE From STKIMP
      Endif
      If [M:SOR]LOC(indice)<>[F:STJ]LOC
        [M:SOR]LOC(indice)=[F:STJ]LOC : IMPMOD=1
      Endif
      OK=0
      If !find("[F:STJ]WRH(0)",[M:AOE2]ZONMSK1)
        If [F:STJ]LOC<>""
          If dim([M:SOR]WRH)>0 [M:SOR]WRH(indice)="" Endif
        Endif
      Endif
    Endif
    #                                                 # hcb 110327 deb
 When "SERNUM"
    If [F:ITM]SERMGTCOD = 4
       If find("[F:STJ]SERDEB(0)",[M:AOE2]ZONMSK1)
          If GSTK_TRACE=2
             GSTK_ACT="IMP_ZONE(SERDEB)" : GSTK_PGM="STKIMPS"
             Gosub TRACE_DETAILLEE From STKIMP
          Endif
          If [M:SOR]SERNUM(indice)<>[F:STJ]SERDEB
             [M:SOR]SERNUM(indice)=[F:STJ]SERDEB : IMPMOD=1
          Endif
          OK=0
       Endif
    Else
       If find("[F:STJ]SERNUM(0)",[M:AOE2]ZONMSK1)
          If GSTK_TRACE=2
             GSTK_ACT="IMP_ZONE(SERNUM)" : GSTK_PGM="STKIMPS"
             Gosub TRACE_DETAILLEE From STKIMP
          Endif
          If [M:SOR]SERNUM(indice)<>[F:STJ]SERNUM
             [M:SOR]SERNUM(indice)=[F:STJ]SERNUM : IMPMOD=1
          Endif
          OK=0
       Endif
    Endif
#                                                 # hcb 110327 fin
  When Default
    If find("[F:STJ]"+IMPZON+"("+num$(indice)+")",[M:AOE2]ZONMSK1)
      If GSTK_TRACE=2
        GSTK_ACT="IMP_ZONE("+IMPZON+")" : GSTK_PGM="STKIMPS"
        Gosub TRACE_DETAILLEE From STKIMP
      Endif
      If evalue("[M:SOR]"+IMPZON+"("+num$(indice)+")")<>evalue("[F:STJ]"+IMPZON+"("+num$(indice)+")")
        Assign "[M:SOR]"+IMPZON+"("+num$(indice)+")" With evalue("[F:STJ]"+IMPZON+"("+num$(indice)+")")
        IMPMOD=1
      Endif
      OK=0
    Endif
Endcase
#---
Return


#----------------------------------------------#
# Avant transaction de màj du document importé #
# Si erreur OK=0                               #
#----------------------------------------------#
$VALID
Return


#------------#
# Fin import #
#------------#
$IMP_FERME
#                                                                # 113323 deb
If GERRTRACE <> 0
   Local Char  WPARAM(250)(1..20)
   Raz WPARAM(1)
   Raz WPARAM(2)
   Call TRAITE_NUM(GBIDD1,WPARAM,"","FUNSTOWIPW","",1,"XYFUNSTOWIPW") From GTRAITE
Endif
#                                                                # 113323 fin

If dim(GSTK_NBLIG)>0 Kill GSTK_NBLIG, GSTK_ERR, GSTK_TRSCOD, GSTK_ENTCOD : Endif
If dim(GSTK_MESS)>0  Kill GSTK_MESS,  GSTK_PGM, GSTK_ACT                 : Endif
Return


#------------------------------------#
#    Rupture sur ligne de document   #
# ---------------------------------- #
# Si GSTK_NBLIG>0 un STOJOU a été lu #
#------------------------------------#
$RUPT_LIGDOC
If !GSTK_NBLIG
  Case [L]WSTK_ABRMSK
    When "SDH1"
      #----- Cas spécial des livraisons avec numéro de commande -----#
      If clalev([M:SDH1]) & [M:SDH1]XSOHNUM([M:SDH1]NBLIG-1)<>""
        If [F:SOQ]SOHNUM<>[M:SDH1]XSOHNUM([M:SDH1]NBLIG-1) |
&          [F:SOQ]SOPLIN<>[M:SDH1]SOPLIN ([M:SDH1]NBLIG-1) |
&          [F:SOQ]SOQSEQ<>[M:SDH1]SOQSEQ ([M:SDH1]NBLIG-1)
          Read [SOQ] SOQ0=[M:SDH1]XSOHNUM([M:SDH1]NBLIG-1);
&                         [M:SDH1]SOPLIN ([M:SDH1]NBLIG-1);
&                         [M:SDH1]SOQSEQ ([M:SDH1]NBLIG-1)
          If fstat  Raz [F:SOQ] : Endif
        Endif
        If [F:SOQ]ALLTYP=2 & [F:SOQ]ALLQTY<>0
          #----- Chargement STOSORW à partir des allocations -----#
          [M:ALP]TRSTYP    = [M:SDH0]TRSTYP
          [M:ALP]TRSCOD    = [M:SDH0]TRSCOD
          [M:ALP]VCRTYP    = 2
          [M:ALP]VCRNUM    = [F:SOQ]SOHNUM
          [M:ALP]VCRLIN    = [F:SOQ]SOPLIN
          [M:ALP]VCRSEQ    = [F:SOQ]SOQSEQ
          [M:ALP]STOFCY    = [M:SDH0]STOFCY
          [M:ALP]ITMREF    = [F:SOQ]ITMREF
          [M:ALP]QTY       = [M:SDH1]QTYSTU([M:SDH1]NBLIG-1)
#                                                                  # hcb 71276 deb
          If dim([M:SDH1]ECCVALMAJ) > 0
             [M:ALP]ECCVALMAJ = [M:SDH1]ECCVALMAJ(NBLIG-1)
          Endif
#                                                                  # hcb 71276 fin
          [M:ALP]TYPQTY    = 2
          [M:ALP]STA       = [F:SOQ]STA
          [M:ALP]PECSCOLOC = 1
          [M:ALP]BESDAT    = [M:SDH1]SHIDAT
          [M:ALP]DLVDAT    = [M:SDH1]DLVDAT
          [M:ALP]WRH       = ""
          If GSTK_TRACE=2
            GSTK_ACT="ALLSTOSORW" : GSTK_PGM="STKSOR" : Gosub TRACE_DETAILLEE From STKIMP
          Endif
          Call ALLSTOSORW("SDH1",[M:SDH1]NBLIG-1,[M:SDH1]NBLIG,0,1,0,[L]WSTK_WRET) From STKSOR
          If [L]WSTK_WRET
            #----- Erreur à la récupération des allocations de la ligne commande -----#
            [L]WSTK_WRET=6 : Gosub TRT_ERREUR : Return
          Elsif [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT=0
            #----- La quantité allouée n'est pas livrable ! -----#
            GMESSAGE=[F:SOQ]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&                    format$(GFMD,[F:SOQ]SHIDAT)+"\"+mess(156,191,1)
            [L]WSTK_WRET=7 : Gosub TRT_ERREUR : Return
          Elsif [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT<>[M:SDH1]QTYSTU([M:SDH1]NBLIG-1)
            #----- La quantité allouée est différente de la quantité à livrer ! -----#
            GMESSAGE=[F:SOQ]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&                    format$(GFMD,[F:SOQ]SHIDAT)+"\"+mess(255,192,1)
            [L]WSTK_WRET=8 : Gosub TRT_ERREUR : Return
          Endif
        Endif
      Endif
      #-----
    When "SIH4"
    When "PNH1"
    When "SMO1"
    When "MTK3", "MBM"
  Endcase
# Dem 39147
#Endif
  #-----
  If !GSTK_ERR
    Raz GSTK_PGM
    Case [L]WSTK_ABRMSK
      When "SDH1"        : Gosub AAPRES_NBLIG From SUBSDH  : GSTK_PGM="SUBSDH"
      When "SIH4"        : Gosub AAPRES_NBLIG From SUBSIH  : GSTK_PGM="SUBSIH"
      When "PNH1"        : Gosub AAPRES_NBLIG From SUBPNH  : GSTK_PGM="SUBPNH"
      When "SMO1"        : Gosub AAPRES_NBLIG From SUBSMO  : GSTK_PGM="SUBSMO"
      When "MTK3", "MBM" : Gosub AAPRES_NBMAT From SUBMTK3 : GSTK_PGM="SUBMTK3"
    Endcase
    If GSTK_TRACE=2 & GSTK_PGM<>""
      GSTK_ACT="AAPRES_NBLIG" : Gosub TRACE_DETAILLEE From STKIMP
    Endif
  Endif
# Dem 39147
Endif
Raz GSTK_NBLIG, GSTK_ERR
Return


#---------------------------------------------------------------------------------#
#                            Traitement des erreurs                               #
# ------------------------------------------------------------------------------- #
#  1 = Modèle d'import erroné : L'unité de conditionnement doit être paramétrée ! #
#  2 = Modèle d'import erroné : Le lot ou le titre doivent être paramétrés !      #
#  3 = La quantité est nulle, la ligne ne sera pas enregistrée                    #
#  4 = Stock à sortir non trouvé ou insuffisant !                                 #
#  5 = [L]WSTK_STOCOU(xxx) Tableau plein !                                        #
#  6 = Erreur à l'appel de ALLSTOSORW                                             #
#  7 = La quantité allouée n'est pas livrable !                                   #
#  8 = La quantité allouée est différente de la quantité à livrer !               #
#---------------------------------------------------------------------------------#
$TRT_ERREUR
Case [L]WSTK_WRET
  When  1 : GMESSAGE=mess(558,197,1)
  When  2 : GMESSAGE=mess(559,197,1)
  When  3 : GMESSAGE=[F:ITM]ITMREF-mess(6,194,1)
  When  4 : GMESSAGE=[F:ITM]ITMREF-mess(560,197,1)
  When  5 : GMESSAGE="[L]WSTK_STOCOU("+num$([L]WSTK_NBR)+")"-mess(53,184,1)
  When  10 : GMESSAGE=mess(214,133,1)-" : "-mess(435,184,1)                # hcb 71276
Endcase
If GTRACE<>""
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Else
  Call ERREUR(GMESSAGE)      From GESECRAN
Endif
[L]OK=0 : GOK=0 : GSTK_ERR=1
Return

