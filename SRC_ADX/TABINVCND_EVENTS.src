#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------- EVENTS : HEADER
$AREAD_AFTER
  #--GET_FBDDAYFLG
  Gosub GET_FBDDAYFLG_FROM_FILE
Return
#-----------------------
$GET_FBDDAYFLG_FROM_FILE
  this.FBDDAYFLGMON = [F:INVCND]INVFBDDAYFLG(0)
  this.FBDDAYFLGTUE = [F:INVCND]INVFBDDAYFLG(1)
  this.FBDDAYFLGWED = [F:INVCND]INVFBDDAYFLG(2)
  this.FBDDAYFLGTHU = [F:INVCND]INVFBDDAYFLG(3)
  this.FBDDAYFLGFRI = [F:INVCND]INVFBDDAYFLG(4)
  this.FBDDAYFLGSAT = [F:INVCND]INVFBDDAYFLG(5)
  this.FBDDAYFLGSUN = [F:INVCND]INVFBDDAYFLG(6)
Return
#-----------------------
$SET_FBDDAYFLG_TO_FILE
  [F:INVCND]INVFBDDAYFLG(0) = this.FBDDAYFLGMON
  [F:INVCND]INVFBDDAYFLG(1) = this.FBDDAYFLGTUE
  [F:INVCND]INVFBDDAYFLG(2) = this.FBDDAYFLGWED
  [F:INVCND]INVFBDDAYFLG(3) = this.FBDDAYFLGTHU
  [F:INVCND]INVFBDDAYFLG(4) = this.FBDDAYFLGFRI
  [F:INVCND]INVFBDDAYFLG(5) = this.FBDDAYFLGSAT
  [F:INVCND]INVFBDDAYFLG(6) = this.FBDDAYFLGSUN
Return
#-----------------------
$ACONTROL
Local Integer W,TROUVE
  If    this.INVCNDTYP=2
    Gosub ACONTROL_INVCNDTYP_EQ_2
  Elsif this.INVCNDTYP=3
    Gosub ACONTROL_INVCNDTYP_EQ_3
    #--INVDAY has to be equal to 0 if INVMETH<4 (Month)
    If this.PERINV>0 and this.PERINV<4 and this.INVDAY>0
      [L]ASTATUS = fmet this.ASETERROR("INVDAY",func AFNC.MES1(mess(441,192,1),"'"+mess(4,2231,1)+"'")+"."-mess(442,192,1)+":'"+mess(this.PERINV,2231,1)+"'",[V]CST_AERROR)
    Endif
    If this.INVDAY>31
      [L]ASTATUS = fmet this.ASETERROR("INVDAY",func AFNC.MES1(mess(443,192,1),"31"),[V]CST_AERROR)
    Endif
    #--In case of "Periodicity" type invoice mode only "header" properties are fillable
    W=0 : TROUVE=0
    TROUVE = sigma(1,maxtab(this.INVCNDLIN),
&        (indcum)*(this.INVCNDLIN(indcum)<>null and find(this.INVCNDLIN(indcum).ASTALIN,[V]CST_ALL,[V]CST_AUPD,[V]CST_ANEW)>0))
&			      	*(W=0 and sigma(W=1,1,1))
      #--No existing and not modified collection line or one having been added
      #--There are only lines deleted or inserted and deleted afterward
    If TROUVE=1
      [L]ASTATUS = fmet this.ASETERROR("",func AFNC.MES1(mess(444,192,1),"'"+mess(3,2420,1)+"'"),[V]CST_AERROR)
    Endif
  Else

  Endif

  #--All excluded days are all checked ?
  If sum(this.FBDDAYFLGMON, this.FBDDAYFLGTUE, this.FBDDAYFLGWED, this.FBDDAYFLGTHU,
&        this.FBDDAYFLGFRI, this.FBDDAYFLGSAT, this.FBDDAYFLGSUN)>13 #(2*7)-1
    [L]ASTATUS = fmet this.ASETERROR("",mess(64,187,1),[V]CST_AERROR)   # Tous les jours sont exclus!
  Endif
Return
#-----------------------
$ACONTROL_INVCNDTYP_EQ_2
Local Decimal WTOTPERCENTAGE
Local Char    WCURRENCY(GLONCUR)
Local Integer WILINE,WCURRENCY_DIFF_FOUND,WNOMINAMT_FOUND,WATLIST_ONELINE

  #--Controls when "Fixed percent" invoice scheduling type
  #--No values for the following properties :
  #--FREQINV, PERINV, INVMETH, INVDAY
  #--Have to be empty
  If this.FREQINV>0
    [L]ASTATUS = fmet this.ASETERROR("FREQINV",func AFNC.MES1(mess(445,192,1),"'"+mess(2,2420,1)+"'"),[V]CST_AERROR)
  Endif
  If this.PERINV>0
    [L]ASTATUS = fmet this.ASETERROR("PERINV" ,func AFNC.MES1(mess(445,192,1),"'"+mess(2,2420,1)+"'"),[V]CST_AERROR)
    this.PERINV=0 #--Have to do this
  Endif
  If this.INVDAY>0
    [L]ASTATUS = fmet this.ASETERROR("INVDAY" ,func AFNC.MES1(mess(445,192,1),"'"+mess(2,2420,1)+"'"),[V]CST_AERROR)
  Endif
  If this.INVMETH>0
    [L]ASTATUS = fmet this.ASETERROR("INVMETH",func AFNC.MES1(mess(445,192,1),"'"+mess(2,2420,1)+"'"),[V]CST_AERROR)
    this.INVMETH=0 #--Have to do this
  Endif
  #--
  #--Total percentage has to be equal to 100%
  #--If filled, must be the same value
  WTOTPERCENTAGE=0
  WCURRENCY = "" : WCURRENCY_DIFF_FOUND = 0
  WATLIST_ONELINE = 0
  For WILINE=1 To maxtab(this.INVCNDLIN)
    If this.INVCNDLIN(WILINE)<>null and find(this.INVCNDLIN(WILINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      WTOTPERCENTAGE += this.INVCNDLIN(WILINE).INVPERCENT
      WATLIST_ONELINE = 1
      If this.INVCNDLIN(WILINE).MINAMTNOT>0 and WCURRENCY<>this.INVCNDLIN(WILINE).MINAMTNOTCUR
        If WCURRENCY<>""
          WCURRENCY_DIFF_FOUND = 1
        Else
          WCURRENCY = this.INVCNDLIN(WILINE).MINAMTNOTCUR
        Endif
      Elsif this.INVCNDLIN(WILINE).MINAMTNOT=0
        WNOMINAMT_FOUND = 1
      Endif
    Endif
  Next
  If WTOTPERCENTAGE<>100
    [L]ASTATUS = fmet this.ASETERROR("",func AFNC.MES1(mess(446,192,1),"100")+"<>"+num$(WTOTPERCENTAGE),[V]CST_AERROR)
  Endif
  #--
  If WATLIST_ONELINE=1
    If WCURRENCY_DIFF_FOUND = 1
      [L]ASTATUS = fmet this.ASETERROR("MINAMTNOTCUR",mess(447,192,1),[V]CST_AERROR)
    Endif
    #--
    If WNOMINAMT_FOUND < 1
      [L]ASTATUS = fmet this.ASETERROR("MINAMTNOT",mess(448,192,1),[V]CST_AERROR)
    Endif
  Endif
  #--
Return
#-----------------------
$ACONTROL_INVCNDTYP_EQ_3
  #--Controls when "Periodicity" invoice scheduling type
  #--Only one collection line
  #--Mandatory
  If this.FREQINV=0
    [L]ASTATUS = fmet this.ASETERROR("FREQINV",func AFNC.MES1(mess(449,192,1),"'"+mess(3,2420,1)+"'"),[V]CST_AERROR)
  Endif
  If this.PERINV=0
    [L]ASTATUS = fmet this.ASETERROR("PERINV" ,func AFNC.MES1(mess(449,192,1),"'"+mess(3,2420,1)+"'"),[V]CST_AERROR)
  Endif
  If this.INVMETH=0
    [L]ASTATUS = fmet this.ASETERROR("INVMETH",func AFNC.MES1(mess(449,192,1),"'"+mess(3,2420,1)+"'"),[V]CST_AERROR)
  Endif
  #--
Return
#-----------------------
$AINSERT_BEFORE
  Gosub SET_FBDDAYFLG_TO_FILE
  #--Copying the header common properties to each line
  Gosub COPY_FROM_H_TO_LINE
Return
#-----------------------
$COPY_FROM_H_TO_LINE
#Local Integer ILINE
#  #--Copying the header common properties to each line
#  For ILINE=1 To maxtab(this.INVCNDLIN)
#    If this.INVCNDLIN(ILINE)<>null
#      If find(this.INVCNDLIN(ILINE).ASTALIN,CST_ANEWDEL,CST_ADEL)=0
#        #--
#      Endif
#    Endif
#  Next
Return
#-----------------------
$AUPDATE_BEFORE
  Gosub SET_FBDDAYFLG_TO_FILE
  #--Copying the header common properties to each line
  Gosub COPY_FROM_H_TO_LINE
Return
#----------------------- EVENTS : COLLECTIONS
$INVCNDLIN_ACONTROL
  #--The line has to have the same values for the key
  If this.INVCND<>this.APARENT.INVCND or this.LEG<>this.APARENT.LEG
    [L]ASTATUS = this.ASETERROR("INVCNDLIN",func AFNC.MES1(mess(450,192,1),num$(this.INVCNDLIN))-":"+mess(451,192),[V]CST_AERROR)
  Endif

Return
#-----------------------
$INVCNDLIN_AREAD_AFTER
  #--To prevent using the subclass TABINVCND stand alone
  this.HASRIGHTHEAD=[V]CST_AYES
Return
#-----------------------
$INVCNDLIN_ADDLINE_BEFORE
  If this.INVCNDTYP=3 and maxtab(this.INVCNDLIN)>1
    #--Message...
    #--"Adding line forbiden in case of 'Periodicity' invoice term type"
    [L]ASTATUS = fmet this.ASETERROR("INVCNDLIN", func AFNC.MES1(mess(452,192,1),"'"+mess(3,2420,1)+"'"),[V]CST_AERROR)
  Endif
Return
#-----------------------
$INVCNDLIN_ADDLINE_AFTER
Local Decimal WTOTPERCENT
Local Integer ILINE
Local Tinyint WFOUND_UPDLINE

  # To initialize properties of the header
  #INVCND+LEG
  this.INVCND    = this.APARENT.INVCND
  this.LEG       = this.APARENT.LEG
  #INVCNDTYP
  this.INVCNDTYP = this.APARENT.INVCNDTYP
  #--Copying all other properties from the header to the new line

  #--
  this.INVMONTHEND = 1 #--"Non"
  this.INVCNDLIN   = max(this.APARENT.INVCNDLIN(1..maxtab(this.APARENT.INVCNDLIN)).INVCNDLIN)+1
  If this.INVCNDLIN=0
    this.INVCNDLIN += 1
  Endif

  WFOUND_UPDLINE = [V]CST_AFALSE
  #--Sum(%lines)=100%
  For ILINE= 1 To maxtab(this.APARENT.INVCNDLIN)
    If this.APARENT.INVCNDLIN(ILINE)<>null and find(this.APARENT.INVCNDLIN(ILINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      If this.APARENT.INVCNDLIN(ILINE).INVPERCENT<>0.0
        WTOTPERCENT += this.APARENT.INVCNDLIN(ILINE).INVPERCENT
      Endif
      If this.APARENT.INVCNDLIN(ILINE).ASTALIN=[V]CST_AUPD
        WFOUND_UPDLINE = [V]CST_ATRUE
      Endif
    Else
      WFOUND_UPDLINE = [V]CST_ATRUE
    Endif
  Next
  #--Only in case there are updated lines
  #--If no such lines, we are in creation mode and this is done elsewhere
  If WFOUND_UPDLINE=[V]CST_ATRUE and WTOTPERCENT>0 and WTOTPERCENT<100
    this.INVPERCENT = 100-WTOTPERCENT #--this should trigger the propagate
    #--As I'm trying not to abuse of propagates, I do the call
  Endif

  #--To prevent using the subclass TABINVCND stand alone
  this.HASRIGHTHEAD=[V]CST_AYES
Return
#-----------------------

