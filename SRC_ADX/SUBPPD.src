#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion du fichier PRESP
#########################################################################
# SUBPPD : Gestion des réponses d'appel d'offre             SR 15/02/98 #
# --------------------------------------------------------------------- #
# Traitements des actions "Gosub"                                       #
# Traitements sur champ "Call" de l'objet "PPD"                         #
#########################################################################

$ACTION
Case ACTION
 When "FILTRE"     : Gosub FILTRE
 When "AV_IMPRIME" : Gosub AV_IMPRIME
 When "SETBOUT"    : Gosub SETBOUT
 When "OUVRE"      : Gosub OUVRE
 When "FERME"      : Gosub FERME
 When "RAZCRE"     : Gosub RAZCRE
 When "RAZDUP"     : Gosub RAZDUP
 When "VERIF_CRE"  : Gosub VERIF
 When "AVANT_MOD"  : Gosub AVANT_MOD
 When "VERIF_MOD"  : Gosub VERIF
 When "INICRE"     : Gosub INICRE
 When "INIMOD"     : Gosub INICRE
 When "APRES_CRE"  : Gosub APRES_CRE
 When "APRES_MOD"  : Gosub APRES_CRE
 When "INICRE_LIG" : Gosub INICRE_LIG
 When "CREATION"   : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "LIENS"      : Gosub LIENS
 When "DEFLIG"     : Gosub DEFLIG
 When "APRES_CHOI" : Gosub APRES_CHOI
 When "ABANDON"    : Gosub ABANDON
 When "VERF_ANU"   : Gosub VERF_ANU
 When "ANNULE"     : Gosub ANNULE
 When DEFAULT
Endcase
Return


############################################################################
#                        ACTIONS de l'objet PPD                            #
############################################################################

$SETBOUT
#----- Si on vient de la transformation en tarif on interdit tout sauf tableau -----#
If GFONC1<>"GESPPD" & GWEBSERV<>1
  Call VIREBOUT(CHAINE,"CMDALH1") From GOBJET : Return
Endif
#----- Objet à 3 éléments de clé : ajout de la touche suppression si autorisé -----#
If CLECUR & !GHISTO  CHAINE+="A" : Endif
#----- Si suppression non autorisée, grisage du bouton -----#
If GREP<>"C"
  GBIDC2="S" : Gosub AUTORIS_OPT From CONTX3
  If !GBIDI2  Call VIREBOUT(CHAINE,"A") From GOBJET : Endif
Endif
Return

########################################################################
$DEFLIG
Default File [PPD]
Default Mask [PPD2]
CRIT = 'PQHNUM = "'+ [M:PPD0]PQHNUM+'" & BPSNUM = "' + [M:PPD0]BPSNUM+
&      '" & num$(PQDLIN) = "' + num$([M:PPD0]PQDLIN) +'"'
FICLIG = "PRESPD" : ABLIG = "PPD"
ZONLIG = "PPDLIN"
RETURN

########################################################################
$FILTRE
Default File [PPH]
# Si l'objet est appelé par programme                     : # En attente
If GFLTBPS <> "" : # (positionnée avant le call OBJET)    : # En attente
  FILTSUP = "BPSNUM=GFLTBPS"                              : # En attente
Endif                                                     : # En attente
If GFLTPQH <> "" : # (positionnée avant le call OBJET)    : # En attente
  FILTSUP = "PQHNUM=GFLTPQH"                              : # En attente
Endif                                                     : # En attente
Return

########################################################################
$AV_IMPRIME
Return

########################################################################
$OUVRE
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
Gosub DECLARE From TABLEAUX
GFCY = GFCYDEF(6)
Call GETFCYDEF(GFCY,"[F:FCY]PURFLG=2") From TRTX3
Call GETDEV(GFCY)     From DEVSUB
Call GLOBVAR(GFCY)    From WWGLOBACH
#-----
GPLISTC="néant" : # Pour forcer l'affichage des entêtes de colonne si structure=""
Call COLREM("C",2,"") From TRTPRICE
Call TYPREM(2,"")     From TRTPRICE
#-----
Global Char GPQH_SYMBOL(30)
GORITITCOL=1
Return

########################################################################
$FERME
Call IMPSCR From ATRTX3 : # Pour impression hard copy d'écran
#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
#-----
If GFONC1="GESPPD"
  Raz GFONC1, GORITITCOL
Endif
If dim(GPQH_SYMBOL)>0
  If GPQH_SYMBOL<>""  Unlock=GPQH_SYMBOL : Endif
  Kill GPQH_SYMBOL
Endif
Return

########################################################################
$RAZCRE
#------------------------------------------------------# 
# Valeurs par défaut et initialisations avant création # 
#------------------------------------------------------# 
Actzo [PPD0]1-99
GFCY = GFCYDEF(6)
Call GETFCYDEF(GFCY,"[F:FCY]PURFLG=2") From TRTX3
[M:PPD0]PQHFCY = GFCY
If GNBAUZ=1 & GFCY<>""  Diszo [PPD0]PQHFCY : Endif
[M:PPD1]RSPDAT = date$
Affzo [PPD0]1-99
Return

########################################################################
$RAZDUP
Actzo [PPD0]PQHNUM, PQDLIN
#--------------------------------------------------------------------#
# Effacement entête : PRIFLG,PRILINNBR                               #
# Effacement lignes prix : ORDFLG,CREFLG,UPDFLG,PRIFLG               #
#--------------------------------------------------------------------#
Local Shortint I
Raz [M:PPD1]PRIFLG
For I=0 To [M:PPD2]NBLIG-1
    Raz [M:PPD2]CREFLG(I),[M:PPD2]UPDFLG(I),[M:PPD2]ORDFLG(I), [M:PPD2]PRIFLG
Next I
Return

########################################################################
$AVANT_MOD
#----- Déblocage logique d'une entête précédente si nécessaire -----#
If GPQH_SYMBOL<>"" & GPQH_SYMBOL<>"PQH"+[M:PPD0]PQHNUM
  Unlock=GPQH_SYMBOL : Raz GPQH_SYMBOL
Endif
#----- Si entête appel d'offre bloquée logiquement --> Abandon -----#
Lock="PQH"+[M:PPD0]PQHNUM
If fstat
  Call ERREUR("$PQUOTAT"-[M:PPD0]PQHNUM-mess(10,100,1)) From GESECRAN : mkstat=1 : OK=0 : End
Else
  GPQH_SYMBOL="PQH"+[M:PPD0]PQHNUM
Endif
Return

########################################################################
$VERIF
#------------------------------------------------------------#
# Vérifications en fin de saisie de création ou modification #
#------------------------------------------------------------#
If [M:PPD2]NBLIG = 0
   GERR  = 1 : GMESSAGE =mess(61,199,1)
   OK = 0
Endif
#----- Vérification si deux lignes identiques -----#
If [M:PPD2]NBLIG<2 Return : Endif
Local Shortint I, J, K, FLAG
For I=0 To [M:PPD2]NBLIG-2
  For J=I+1 To [M:PPD2]NBLIG-1
    If [M:PPD2]PUU(I)      =[M:PPD2]PUU(J)       & 
&      [M:PPD2]MINQTY(I)   =[M:PPD2]MINQTY(J)    &
&      [M:PPD2]MAXQTY(I)   =[M:PPD2]MAXQTY(J)    &
&      [M:PPD2]LTI(I)      =[M:PPD2]LTI(J)       &
&      [M:PPD2]RCPDAT(I)   =[M:PPD2]RCPDAT(J)    &
&      [M:PPD2]CUR(I)      =[M:PPD2]CUR(J)       &
&      [M:PPD2]PRIDIV(I)   =[M:PPD2]PRIDIV(J)    &
&      [M:PPD2]PRI(I)      =[M:PPD2]PRI(J)       &
&      [M:PPD2]PLISTRDAT(I)=[M:PPD2]PLISTRDAT(J) &
&      [M:PPD2]PLIENDDAT(I)=[M:PPD2]PLIENDDAT(J)
      FLAG=0
      For K=1 To 9
        If evalue("dim([M:PPD2]DISCRGVAL"+num$(K)+"(0))")>0
          If evalue("[M:PPD2]DISCRGVAL"+num$(K)+"(I)")<>
&            evalue("[M:PPD2]DISCRGVAL"+num$(K)+"(J)")
            FLAG=1 
          Endif
        Endif
        If FLAG=1 Break : Endif
      Next K
      If FLAG=0 FLAG=99 : Break 2 : Endif
    Endif
  Next J
Next I
If FLAG=99
  GMESSAGE=mess(18,197,1)-num$(I+1)+"   "+mess(18,197,1)-num$(J+1)+"\"
  GMESSAGE+=mess(248,199,1)
  GERR = 1
  OK=0
Endif
Return

########################################################################
$INICRE
[F:PPH]LINNBR = [M:PPD2]NBLIG
[F:PPH]CPY    = GSOCIETE
If GREP = "C" | GREP = "D"
   [F:PPH]PRIFLG = 1
   [F:PPH]PRILINNBR = 0
Endif
Return

########################################################################
$INICRE_LIG
[F:PPD]PQHNUM = [F:PPH]PQHNUM
[F:PPD]BPSNUM = [F:PPH]BPSNUM
[F:PPD]PQHFCY = [F:PPH]PQHFCY
[F:PPD]PQDLIN = [F:PPH]PQDLIN
[F:PPD]ITMREF = [F:PPH]ITMREF
[F:PPD]ORDFLG = 1
[F:PPD]PRIFLG = 1
[F:PPD]CPY    = GSOCIETE
Return

########################################################################
$CREATION
Gosub CREATION From TABLEAUX : If GOK<1  Return : Endif
#----- Màj nbre de réponses sur entête de la demande d'appel d'offre -----#
Readlock [PQH] PQH0=[M:PPD0]PQHNUM
If fstat=1
  GOK=-1 : GLOCK="$PQUOTAT"-[M:PPD0]PQHNUM            : Return
Elsif fstat
  GOK=0  : Call RSTA("PQH",[M:PPD0]PQHNUM) From GLOCK : Return
Endif
[F:PQH]RSPNBR += 1
Rewrite [PQH]
If fstat  GOK=0 : Call FSTA("PQH") From GLOCK : Return : Endif
#----- Màj nbre de réponses sur ligne article appel d'offre -----#
Readlock [PQD] PQD0=[M:PPD0]PQHNUM;[M:PPD0]PQDLIN
If fstat=1
  # FGR 19/01/2010 : X3SUIVI60986
  #GOK=-1 : GLOCK="$PQUOTATD"-[M:PPD0]PQHNUM-num$([M:PPD0]PDQLIN)           : Return
  GOK=-1 : GLOCK="$PQUOTATD"-[M:PPD0]PQHNUM-num$([M:PPD0]PQDLIN)           : Return
Elsif fstat
  GOK=0  : Call RSTA("PQD",[M:PPD0]PQHNUM+num$([M:PPD0]PQDLIN)) From GLOCK : Return
Endif
[F:PQD]LINRSPNBR += 1
Rewrite [PQD]
If fstat  GOK=0 : Call FSTA("PQD") From GLOCK : Return : Endif
#----- Màj nbre de réponse sur ligne fournisseur appel d'offre -----#
Readlock [PQF] PQF0=[M:PPD0]PQHNUM;[M:PPD0]BPSNUM
If fstat=1
  GOK=-1 : GLOCK="$PQUOTATF"-[M:PPD0]PQHNUM-[M:PPD0]BPSNUM           : Return
Elsif fstat
  GOK=0  : Call RSTA("PQF",[M:PPD0]PQHNUM+[M:PPD0]BPSNUM) From GLOCK : Return
Endif
[F:PQF]RSPNBR += 1
Rewrite [PQF]
If fstat  GOK=0 : Call FSTA("PQF") From GLOCK : Return : Endif
#----- Màj si nécessaire de la référence article chez le fournisseur -----#
Gosub MAJ_ITMBPS
If GPQH_SYMBOL<>""  Unlock=GPQH_SYMBOL : Raz GPQH_SYMBOL : Endif
Return

########################################################################
$MODIF
Gosub MODIF From TABLEAUX : If GOK<1 : Return : Endif
#----- Màj si nécessaire de la référence article chez le fournisseur -----#
Gosub MAJ_ITMBPS
If GPQH_SYMBOL<>""  Unlock=GPQH_SYMBOL : Raz GPQH_SYMBOL : Endif
Return

#-------------------------------------------------------------------------------#
# Màj article-fournisseur si celui-ci existe et que les infos ont été modifiées #
#-------------------------------------------------------------------------------#
$MAJ_ITMBPS
If [F:ITP]ITMREF<>[M:PPD1]ITMREF | [F:ITP]BPSNUM<>[M:PPD0]BPSNUM
  Read [ITP] ITP0=[M:PPD1]ITMREF;[M:PPD0]BPSNUM
  If fstat  Raz [F:ITP] : Return : Endif
Endif
If [F:ITP]ITMREFBPS<>[M:PPD1]ITMREFBPS |
&  [F:ITP]ITMDESBPS<>[M:PPD1]ITMDESBPS |
&  [F:ITP]EANCODBPS<>[M:PPD1]EANCODBPS
  Readlock [ITP] ITP0=[M:PPD1]ITMREF;[M:PPD0]BPSNUM
  If fstat=1
    GOK=-1 : GLOCK="$ITMBPS"-[M:PPD1]ITMREF-[M:PPD0]BPSNUM             : Return
  Elsif fstat
    GOK=0  : Call RSTA("ITP",[M:PPD1]ITMREF+[M:PPD0]BPSNUM) From GLOCK : Return
  Endif
  [F:ITP]ITMREFBPS=[M:PPD1]ITMREFBPS
  [F:ITP]ITMDESBPS=[M:PPD1]ITMDESBPS
  [F:ITP]EANCODBPS=[M:PPD1]EANCODBPS
  Rewrite [ITP]
  If fstat  GOK=0 : Call FSTA("ITP") From GLOCK : Return : Endif
Endif
Return

########################################################################
$LIENS
If GFCY<>[F:PPH]PQHFCY
  GFCY=[F:PPH]PQHFCY
  Call GETDEV (GFCY) From DEVSUB
  Call GLOBVAR(GFCY) From WWGLOBACH
Endif
Diszo [PPD0]PQHFCY, PQHNUM, PQDLIN
If [F:BPR]BPRNUM<>[F:PPH]BPSNUM
  Read [BPR] BPR0=[F:PPH]BPSNUM
  If fstat Raz [F:BPR] : [F:BPR]CUR=GCUR : Endif
Endif
If [F:BPS]BPSNUM<>[F:PPH]BPSNUM
  Read [BPS] BPS0=[F:PPH]BPSNUM
  If fstat Raz [F:BPS] : [F:BPS]CUR=GCUR : Endif
Endif
[M:PPD0]BPSNAM = [F:BPS]BPSNAM
If GPLISTC<>[F:PPH]PLISTC 
  GPLISTC=[F:PPH]PLISTC
  Call COLREM("C",2,[F:PPH]PLISTC) From TRTPRICE
  Call TYPREM(2,[F:PPH]PLISTC)     From TRTPRICE
  #----- Affichage entêtes de colonne variables -----#
  If !GIMPORT
    Local Char BASPAG(10) : BASPAG="NBLIG" : Gosub TIT_COL From W1PPD2
  Endif
Endif
Call FMTREM("PPD2",[F:BPS]CUR) From TRTPRICE
Gosub LIENS From TABLEAUX
#----- Chargement zones entête appel d'offre -----#
If [F:PQH]PQHNUM<>[F:PPH]PQHNUM
  Read [PQH] PQH0=[F:PPH]PQHNUM : If fstat Raz [F:PQH] : Endif
Endif
[M:PPD1]PQHREF=[F:PQH]PQHREF
[M:PPD1]PQHDAT=[F:PQH]PQHDAT
[M:PPD1]RSPDEA=[F:PQH]RSPDEA
[M:PPD1]REQUSR=[F:PQH]REQUSR
#----- Chargement zones ligne article appel d'offre -----#
If [F:PQD]PQHNUM<>[F:PPH]PQHNUM | [F:PQD]PQDLIN<>[F:PPH]PQDLIN
  Read [PQD] PQD0=[F:PPH]PQHNUM;[F:PPH]PQDLIN : If fstat Raz [F:PQD] : Endif
Endif
[M:PPD1]ITMREF=[F:PQD]ITMREF
[M:PPD1]ITMDES=[F:PQD]ITMDES
[M:PPD1]PQDPJT=[F:PQD]PQDPJT
[M:PPD1]PUU   =[F:PQD]PUU
[M:PPD1]QTYPUU=[F:PQD]QTYPUU
[M:PPD1]LTI   =[F:PQD]LTI
[M:PPD1]RCPDAT=[F:PQD]RCPDAT
#----- Affichage des 2 onglets -----#
If !GIMPORT
  Affzo [PPD1]1-99 : Affzo [PPD2]1-99
Endif
Return 

########################################################################
$APRES_CHOI
If REPONSE=GSTAANU
  Gosub VERF_ANU
  REPONSE=0
Endif
Return

########################################################################
$ABANDON
If GPQH_SYMBOL<>""  Unlock=GPQH_SYMBOL : Raz GPQH_SYMBOL : Endif
Return

########################################################################
$VERF_ANU
#----- Contrôle qu'aucune ligne n'a été transformée en commande -----#
OK=1
For I=1 To [M:PPD2]NBLIG
  If [M:PPD2]ORDFLG(I-1)=2 
    GERR=1 : GMESSAGE=mess(44,194,1) : OK=0 : Break
  Elsif  [M:PPD2]PRIFLG(I-1)=2
    GERR=1 : GMESSAGE=mess(192,194,1): OK=0 : Break
  Endif
Next I
If OK=0 Return : Endif : # Fin pas de suppression
#----- Variables locales -----#
Local Char WBPSNUM(GLONBPS), WPQHNUM(GLONPQH)
Local Integer WPQDLIN
WBPSNUM = [M:PPD0]BPSNUM 
WPQHNUM = [M:PPD0]PQHNUM 
WPQDLIN = [M:PPD0]PQDLIN 
#----- Confirmation de la suppression -----#
OK=1 : Call OUINON(mess(23,115,1)-WBPSNUM-WPQHNUM-num$(WPQDLIN),OK) From GESECRAN  
If OK=1 OK=0 : Return : Endif 
#----- Début de la transaction de suppression de la réponse -----#
Call DEBTRANS From GLOCK
$TR_ANNUL
GOK=1
Trbegin [PPH]
  Readlock [PPH] PPH0=[M:PPD0]BPSNUM;[M:PPD0]PQHNUM;[M:PPD0]PQDLIN
  If fstat=1
    GOK=-1 : GLOCK="$PRESP"-[M:PPD0]BPSNUM-[M:PPD0]PQHNUM : Goto TR_ROLL
  Elsif fstat
    GOK=0  : Call RSTA("PPH",[M:PPD0]BPSNUM-[M:PPD0]PQHNUM) From GLOCK : Goto AB_ANNUL
  Endif
# #----- Suppression de l'entête de la réponse (PRESP) -----#
  Delete [PPH]
  If fstat GOK=0 : Goto AB_ANNUL : Endif
# #----- Suppression des lignes (PRESPD) et màj PQUOTAT, PQUOTATD, PQUOTATF -----#
  Gosub ANNULE
  If GOK<0 Goto TR_ROLL  : Endif
  If GOK=0 Goto AB_ANNUL : Endif
Commit
CLECUR = 0
Effzo [PPD0] : Effzo [PPD1] : Effzo [PPD2]
Goto FIN_ANNUL

$TR_ROLL
Rollback
Call ROLL From GLOCK
If GROLL Goto FIN_ANNUL Else Goto TR_ANNUL : Endif

$AB_ANNUL
Rollback

$FIN_ANNUL
OK=0
Return

########################################################################
$ANNULE
Gosub ANNULE From TABLEAUX
If GOK < 1 : Return : ENDIF

Readlock [PQH] PQH0=[M:PPD0]PQHNUM
If fstat=1  GOK=-1 : GLOCK = "$PQUOTAT"-[M:PPD0]PQHNUM          : Return
Elsif fstat GOK=0  : Call RSTA("PQH",[M:PPD0]PQHNUM) From GLOCK : Return
Endif
[F:PQH]RSPNBR -= 1
Rewrite [PQH]
If fstat GOK=0 : Call FSTA("PQH") From GLOCK : Return : Endif

Readlock [PQD] PQD0=[M:PPD0]PQHNUM;[M:PPD0]PQDLIN
If fstat=1  GOK=-1 : GLOCK ="$PQUOTATD"-[M:PPD0]PQHNUM-num$([M:PPD0]PQDLIN) : Return
Elsif fstat GOK=0  : Call RSTA("PQD",[M:PPD0]PQHNUM+num$([M:PPD0]PQDLIN)) From GLOCK : Return
Endif
[F:PQD]LINRSPNBR -= 1
Rewrite [PQD]
If fstat GOK=0 : Call FSTA("PQD") From GLOCK : Return : Endif

Readlock [PQF] PQF0=[M:PPD0]PQHNUM;[M:PPD0]BPSNUM
If fstat=1  GOK=-1 : GLOCK = "$PQUOTATF"-[M:PPD0]PQHNUM-[M:PPD0]BPSNUM         : Return
Elsif fstat GOK=0  : Call RSTA("PQF",[M:PPD0]PQHNUM+[M:PPD0]BPSNUM) From GLOCK : Return
Endif
[F:PQF]RSPNBR -= 1
Rewrite [PQF]
If fstat GOK=0 : Call FSTA("PQF") From GLOCK : Return : Endif
Return

########################################################################
$APRES_CRE
Gosub LIENS From TABLEAUX
Diszo [PPD0]PQHFCY : Affzo [PPD0]PQHFCY
Return


########################################################################
#          ACTIONS sur champs des écrans PPD0, PPD1 et PPD2            #
########################################################################

Subprog AS_PQHFCY(VALEUR)
#----------------------#
# Avant saisie du site #
#----------------------#
Variable Char    VALEUR()
If GREP<>"C" & GREP<>"D"  mkstat=2 : End : Endif
End

Subprog AM_PQHFCY(VALEUR)
#---------------------#
# Après-modif du site #
#---------------------#
Variable Char    VALEUR()
If GFCY<>VALEUR
  GFCY=VALEUR : Call GLOBVAR(GFCY) From WWGLOBACH
Endif
End

Subprog IB_BPSNUM
#-------------#
# Init bouton #
#-------------#
Raz GBOUT2, GBOUT3
GBOUT1=mess(457,198,1) : # Fournisseurs
If GREP="C" | GREP="D"
  GBOUT2=mess(8,31,1) : # Sélection (SELPPDBPS fournisseurs PPD)
Else
  GBOUT3=mess(8,31,1) : # Sélection (SELOBJET)
Endif
End

Subprog C_BPSNUM(VALEUR)
#------------------------------------------------------------------#
# Contrôle fournisseur : Il doit exister au moins un appel d'offre #
#------------------------------------------------------------------#
Variable Char    VALEUR()
[M:PPD0]BPSNUM=VALEUR
#----- Valeur obligatoire -----#
If VALEUR = "" : mkstat = 1 : End : Endif
#----- En modification vérification existence d'une réponse -----#
If GREP <> "C" & GREP <> "D"
  Filter [PPH] Where BPSNUM = VALEUR
  Look [PPH] PPH0 First
  If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : Filter [PPH] : End : Endif
  Filter [PPH]
#----- En création ou duplication vérification existence d'une demande -----#
Else
  Filter [PQF] Where PQHFCY = [M:PPD0]PQHFCY & BPSNUM = VALEUR
  Look [PQF] PQF1 First
  If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : Filter [PQF] : End : Endif
  Filter [PQF]
Endif
#----- Vérification existence du fournisseur et du business partner -----#
Read [BPS] BPS0 = VALEUR
If fstat Raz [F:BPS] : GMESSAGE = mess(23,100,1) : mkstat = 1 : End : Endif
[M:PPD0]BPSNAM = [F:BPS]BPSNAM
[M:PPD1]PLISTC = [F:BPS]PLISTC
Read [BPR] BPR0 = VALEUR
If fstat Raz [F:BPR] : GMESSAGE = mess(23,100,1) : mkstat = 1 : End : Endif
End


Subprog AM_BPSNUM(VALEUR)
#-------------------------#
# Après modif fournisseur #
#-------------------------#
Variable Char    VALEUR()
#----- Chargement libellés et formats colonnes tarif -----#
If GPLISTC<>[F:BPS]PLISTC
   GPLISTC=[F:BPS]PLISTC
   Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
   Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
#  #----- Affichage entêtes de colonne variables -----#
   If !GIMPORT
      Local Char BASPAG(10) : BASPAG="NBLIG" : Gosub TIT_COL From W1PPD2
   Endif
Endif
Call FMTREM("PPD2",[F:BPS]CUR) From TRTPRICE
#----- Lecture appel d'offre entête si création ou duplication -----#
If GREP="C" | GREP="D"
  If [M:PPD0]PQHNUM <>""
    Read [PQH] PQH0 = [M:PPD0]PQHNUM
    If fstat Raz [F:PQH] : Endif
    [M:PPD1]PQHDAT = [F:PQH]PQHDAT
    [M:PPD1]RSPDEA = [F:PQH]RSPDEA
    [M:PPD1]REQUSR = [F:PQH]REQUSR
    Raz [M:PPD0]PQDLIN
    Affzo [PPD1]1-99
  Endif
Endif
End

Subprog AS_PQHNUM(VALEUR)
#-----------------------------------#
# Avant saisie champ numéro d'appel #
#-----------------------------------#
Variable Char     VALEUR
If GREP<>"C" & GREP<>"D"
  mkstat = 2
Endif
End

Subprog IB_PQHNUM
#-------------#
# Init bouton #
#-------------#
Raz GBOUT2, GBOUT3
#GBOUT2=mess(8,31,1) : # Sélection
End

Subprog C_PQHNUM(VALEUR)
#-----------------------------------------------------------------------#
# Contrôle No appel d'offre : Il doit exister au moins un appel d'offre #
#-----------------------------------------------------------------------#
Variable Char    VALEUR()
#----- Valeur obligatoire -----#
If VALEUR = "" : mkstat = 1 : End : Endif
#----- Lecture appel d'offre entête -----#
Read [PQH] PQH0=VALEUR
If fstat  Raz [F:PQH] : GMESSAGE=mess(23,100,1) : mkstat=1 : End : Endif
#----- En modification vérification existence d'une réponse -----#
If GREP <> "C" & GREP <> "D"
  Filter [PPH] Where BPSNUM = [M:PPD0]BPSNUM & PQHNUM = VALEUR
  Look [PPH] PPH0 First
  If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : Filter [PPH] : End : Endif
  Filter [PPH]
#----- En création ou duplication vérification existence d'une demande -----#
Else
  Filter [PQF] Where PQHNUM = VALEUR & BPSNUM = [M:PPD0]BPSNUM
  Look [PQF] PQF0 First
  If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : Filter [PQF] : End : Endif
  Filter [PQF]
Endif
#----- Déblocage logique d'une entête précédente si nécessaire -----#
If GPQH_SYMBOL<>"" & GPQH_SYMBOL<>"PQH"+VALEUR
  Unlock=GPQH_SYMBOL : Raz GPQH_SYMBOL
Endif
#----- Si entête appel d'offre bloquée logiquement --> Abandon -----#
If GPQH_SYMBOL=""
  Lock="PQH"+VALEUR
  If fstat
    GMESSAGE="$PQUOTAT"-VALEUR-mess(10,100,1) : mkstat=1 : End
  Else
    GPQH_SYMBOL="PQH"+VALEUR
  Endif
Endif
End

Subprog AM_PQHNUM(VALEUR)
#------------------------------#
# Après modif No appel d'offre #
#------------------------------#
Variable Char    VALEUR()
If [F:PQH]PQHNUM <> VALEUR
  Read [PQH] PQH0 = VALEUR
  If fstat Raz [F:PQH] : Endif
Endif
[M:PPD1]PQHREF = [F:PQH]PQHREF
[M:PPD1]PQHDAT = [F:PQH]PQHDAT
[M:PPD1]RSPDEA = [F:PQH]RSPDEA
[M:PPD1]REQUSR = [F:PQH]REQUSR
Raz [M:PPD0]PQDLIN
Affzo [PPD1]1-99
End

Subprog AS_PQDLIN(VALEUR)
#--------------#
# Avant saisie #
#--------------#
Variable Decimal  VALEUR
If GREP<>"C" & GREP<>"D"
  mkstat = 2
Endif
End

Subprog C_PQDLIN(VALEUR)
#---------------------------------#
# Contrôle No ligne appel d'offre #
#---------------------------------#
Variable Decimal VALEUR()
#----- Valeur obligatoire -----#
If VALEUR = 0 : mkstat = 1 : End : Endif
#----- Controle existence de la ligne de demande -----#
Read [PQD] PQD0 = [M:PPD0]PQHNUM;VALEUR
If fstat Raz [F:PQD] : GMESSAGE = mess(23,100,1) : mkstat = 1 : End : Endif
#----- Contrôle existence de la ligne de réponse -----#
Filter [PPH] Where BPSNUM = [M:PPD0]BPSNUM & PQHNUM = [M:PPD0]PQHNUM
&                     & PQDLIN = VALEUR
Read [PPH] PPH0 First
Filter [PPH]
#----- En modif la ligne de réponse doit exister -----#
If GREP <> "C" & GREP <> "D"
  If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : End : Endif
  End
Endif
#----- En création ou duplication la ligne de réponse ne doit pas exister -----#
If !fstat  : GMESSAGE = mess(22,100,1) : mkstat = 1 : End : Endif
End

Subprog AM_PQDLIN(VALEUR)
#------------------------------------#
# Après modif No ligne appel d'offre #
#------------------------------------#
Variable Decimal VALEUR()
[M:PPD1]ITMREF = [F:PQD]ITMREF
[M:PPD1]ITMDES = [F:PQD]ITMDES
[M:PPD1]PQDPJT = [F:PQD]PQDPJT
[M:PPD1]PUU    = [F:PQD]PUU
[M:PPD1]QTYPUU = [F:PQD]QTYPUU
[M:PPD1]LTI    = [F:PQD]LTI
[M:PPD1]RCPDAT = [F:PQD]RCPDAT
#----- Lecture de l'article-fournisseur si nécessaire -----#
If [F:ITP]ITMREF<>[M:PPD1]ITMREF | [F:ITP]BPSNUM<>[M:PPD0]BPSNUM
  Read [ITP] ITP0=[M:PPD1]ITMREF;[M:PPD0]BPSNUM
  If fstat  Raz [F:ITP] : Endif
Endif
[M:PPD1]ITMREFBPS = [F:ITP]ITMREFBPS
[M:PPD1]ITMDESBPS = [F:ITP]ITMDESBPS
Affzo [PPD1]5-10
End

Subprog C_QTYPUU(VALEUR)
#-------------------------#
# Contrôle de la quantité #
#-------------------------#
Variable Decimal VALEUR
If VALEUR = 0 : mkstat = 1 : End : Endif
End

########################################
Subprog AS_RCPDAT(VALEUR)
Variable Date    VALEUR
If GMODIF <> 2 : mkstat = 2 : End : Endif
If [M:PPD2]LTI(nolign-1) <> 0 : mkstat = 2 : End : Endif
End

########################################
#date de fin de validité ne doit pas être < à la date de début de val
Subprog C_PLIENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:PPD2]PLISTRDAT(nolign-1) : mkstat = 1 : End : Endif
End

########################################
Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()
Call FMTREM("PPD2",VALEUR) From TRTPRICE
End

########################################
Subprog C_NBLIG
GMODIF = 2
If GREP = "C" | GREP = "D" : End : Endif
Case status
 When 68,83                       : # Annulation multiple
  For I = nolign-1 To nolign1-1
      If [M:PPD2]ORDFLG(I) = 2
         GMESSAGE = mess(44,194,1)
         GMODIF = 1
         mkstat = 1
      Elsif [M:PPD2]PRIFLG(I) = 2
         GMESSAGE = mess(192,194,1)
         GMODIF = 1
         mkstat = 1
      Endif
  Next I
 When 65                          : # Annulation ligne
  If [M:PPD2]ORDFLG(nolign-1) = 2
     GMESSAGE = mess(44,194,1)
     GMODIF = 1
     mkstat = 1
  Elsif [M:PPD2]PRIFLG(nolign-1) = 2
     GMESSAGE = mess(192,194,1)
     GMODIF = 1
     mkstat = 1
  Endif
 When 75                          : # Modification
  If [M:PPD2]ORDFLG(nolign-1) = 2
     GMESSAGE = mess(44,194,1)
     GMODIF = 1
     mkstat = 1
  Elsif [M:PPD2]PRIFLG(nolign-1) = 2
     GMESSAGE = mess(192,194,1)
     GMODIF = 1
     mkstat = 1
  Endif
  When 73,82                      : # Insersion
  If dim([M:PPD2]PRIREN)<[M:PPD2]NBLIG+2
     GMESSAGE=mess(122,199,1) : mkstat=2
  Endif
 When Default
Endcase
End

########################################
Subprog C_MAXQTY(VALEUR)
Variable Decimal VALEUR
If VALEUR<[M:PPD2]MINQTY(nolign-1)  mkstat=1 : End : Endif
End

########################################
Subprog C_PRIDIV(VALEUR)
Variable Decimal VALEUR
If VALEUR=0  mkstat=1 : End : Endif
End

Subprog C_PRIREN(VALEUR)
#--------------------------------------------------#
# Selon paramètre général le motif est obligatoire #
#--------------------------------------------------#
Variable Decimal VALEUR
If GPURREN=2 & VALEUR=0  mkstat=1 : End : Endif
End

Subprog C_ITMREFBPS(VALEUR)
#-----------------------------------------------------------------#
# Contrôle que la réf chez le fournisseur n'est pas déjà utilisée #
#-----------------------------------------------------------------#
Variable Char    VALEUR()
#----- Si l'enregistrement n'existe pas, on ne fait rien car pas de création -----#
Read [ITP] ITP0=[M:PPD1]ITMREF;[M:PPD0]BPSNUM
If fstat
  Raz [F:ITP]
  If VALEUR=""  End : Endif
Endif
#----- La référence de l'article chez le fournisseur est obligatoire ! -----#
If VALEUR="" & (GITMBPS=1 | [G:ITP]keyuniq(2)=1)
  GMESSAGE=mess(165,194,1) : VALEUR=[M:PPD1]ITMREFBPS : mkstat=1 : End
Endif
#----- Cette référence est déjà utilisée chez ce fournisseur pour un autre article -----€
If [G:ITP]keyuniq(2)=1 : # Clé secondaire IPT2 sans homonyme !
  Read [ITP] ITP2=[M:PPD0]BPSNUM;VALEUR
  If !fstat & [F:ITP]ITMREF<>[M:PPD1]ITMREF
    GMESSAGE=mess(63,194,1) : mkstat=1 : End
  Endif
Endif
End

########################################
Subprog AVANT_NBLIG
If dim([M:PPD2]PRIREN)<nolign+1
  GERR=1 : GMESSAGE=mess(122,199,1) : mkstat=1 : Endif
If status<>65 & status<>68 & status<>83
  If !varinit([M:PPD2]PRIREN,nolign-1)
    [M:PPD2]PRIREN(nolign-1) = 1
  Endif
  If !varinit([M:PPD2]PUU,nolign-1)
    [M:PPD2]PUU(nolign-1) = [F:PQD]PUU
  Endif
  If !varinit([M:PPD2]CUR,nolign-1)
    [M:PPD2]CUR(nolign-1) = [F:BPS]CUR
  Endif
  If !varinit([M:PPD2]PRIDIV,nolign-1)
    [M:PPD2]PRIDIV(nolign-1) = 1
  Endif
  If !varinit([M:PPD2]PLISTRDAT,nolign-1)
    [M:PPD2]PLISTRDAT(nolign-1) = date$
  Endif
  If !varinit([M:PPD2]PLIENDDAT,nolign-1)
    [M:PPD2]PLIENDDAT(nolign-1) = date$ + 365
  Endif
Endif
End

