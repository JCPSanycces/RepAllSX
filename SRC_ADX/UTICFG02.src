#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTICFG02 : Purge CFGHIS et CFGHISHEA          # Issue 105560 GA 03/2015
##########################################################################

Call MAJ_UTICFG02
End

##################################
Subprog MAJ_UTICFG02
Local Char DOSSIER(30) : DOSSIER=nomap
#Call SAIDOS(DOSSIER,"") From SAIDOS
If [L]DOSSIER<>""
   If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
   Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

   Call EXE_UTICFG02([L]DOSSIER)
Endif
End
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
  # Specific Tool !!!!
  #Call MAJ_UTICFG02(APPLI)
End


##################################
Subprog EXE_UTICFG02(DOSSIER)
Value Char DOSSIER

Local Integer LRET

Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTICFG02 : Rectification des fiches corrigées par la scrum team YYMFG") From LECFIC
Call ECR_TRACE("UTICFG02 : Début traitement du dossier "+DOSSIER,0) From GESECRAN

  Gosub TRT_CFH

$FIN_UTICFG02
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC

End

######## Tables with CFGVCRNUM
# CFGHIS
# CFGHISHEA
#
# ITMBPC
# ITMBPS
# ITMCOST
# ITMFACILIT
# ITMMASTER
# ITMMVT
# ITMSALES
#
# BOM
# ROUTING


$TRT_CFH

Local File =DOSSIER+".ITMMASTER" [ITM]
Local File =DOSSIER+".BOM"       [BOH]
Local File =DOSSIER+".ROUTING"   [ROH]
Local File =DOSSIER+".CFGHIS"    [CFH]
Local File =DOSSIER+".CFGHISHEA" [CHH]
Local Shortint STAT : STAT=0
Local Integer  WSIMFLG,WCPT : WCPT=0
Local Integer  WNOTFOUND,WNOBOH,WNOROH
Local Char     WCFGVCRNUM(GLONVCR)

WSIMFLG=2
If !GBATCH
   Call OUINON(mess(6,115,1)-"?"-nomap,WSIMFLG) From GESECRAN
Endif

Trbegin [CFH]
Call ECR_TRACE(" ",0) From GESECRAN
If WSIMFLG=2
   Call ECR_TRACE("Liste des historiques de configuration CFH/CHH à purger"-mess(6,115,1),0) From GESECRAN
Else
   Call ECR_TRACE("Purge des historiques de configuration CFH/CHH",0) From GESECRAN
Endif
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(" ",0) From GESECRAN

For [CHH]
    WNOTFOUND = 0 : WNOBOH=1 : WNOROH=1
    WCFGVCRNUM=[F:CHH]CFGVCRNUM
    #
    Look [F:ITM]ITM4(1)=WCFGVCRNUM
    If fstat
       Call ECR_TRACE("Aucun article pour la configuration"-WCFGVCRNUM,-1) From GESECRAN
       WNOTFOUND+=1
    Elsif WSIMFLG=2
       Call ECR_TRACE("Article présent pour la configuration"-WCFGVCRNUM,0) From GESECRAN
    Endif
    #
    Filter [F:BOH] Where CFGVCRNUM=WCFGVCRNUM
    For [F:BOH]
        If WNOTFOUND=0
           Call ECR_TRACE("Nomenclature présente pour la configuration"-WCFGVCRNUM,0) From GESECRAN
        Endif
        WNOBOH=0
       Break
    Next
    WNOTFOUND+=WNOBOH
    Filter [F:BOH]
    #
    Filter [F:ROH] Where CFGVCRNUM=WCFGVCRNUM
    For [F:ROH]
       If WNOTFOUND+WNOBOH=0
           Call ECR_TRACE("Gamme présente pour la configuration"-WCFGVCRNUM,0) From GESECRAN
        Endif
        WNOROH=0
       Break
    Next
    WNOTFOUND+=WNOROH
    Filter [F:ROH]
    #
    If WNOTFOUND  # Rien trouvé, on peut purger cette configuration
       Delete [CFH] Where CFGVCRNUM=WCFGVCRNUM
       WCPT+=adxdlrec
       Delete [CHH] Curr
       WCPT+=adxdlrec
    Endif
Next

Filter [CFH]

If WSIMFLG=2
   Rollback
   Call ECR_TRACE("Mode simulation: Rollback !!!"-num$(WCPT),0) From GESECRAN
Else
   Call ECR_TRACE("Mode réel: Commit !!!"-num$(WCPT),0) From GESECRAN
   Commit
Endif


Close Local File [CHH]
Close Local File [CFH]
Return
