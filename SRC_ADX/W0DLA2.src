   [M]CPYCTY = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CPYCTY" : GZNUM = 0 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]CPYCTY or IMPMOD
     SAVACT = GACTION : GACTION = "VILCONT"
     PARAM(1) = [M]CPYCRY
     PARAM(2) = [M]CPYPOSCOD
     PARAM(3) = ""
     Local Char    VALEUR(250)
     VALEUR = [M]CPYCTY
     Call S_AFF_CHAR(VALEUR,PARAM,"VILCONT","SUBPOS","") From GACTION
     [M]CPYCTY = VALEUR
     [M]CPYPOSCOD = PARAM(2)
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "CPYCTY" : GZNUM = 0 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      SAVACT = GACTION : GACTION = "AFFPOSCOD"
      GACTION = SAVACT
      If !mkstat & !GIMPORT : Affzo [M]CPYPOSCOD : Endif
      If mkstat : GERR = 1 : GZONE = "CPYCTY" : GZNUM = 0 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

