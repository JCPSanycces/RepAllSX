   IMPMOD = 0 : IMPZON = "CPYPOSCOD" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "POSCNTOBL"
  PARAM(1) = [M]CPYCRY
  PARAM(2) = "0"
  Local Char    VALEUR(250)
  VALEUR = [M]CPYPOSCOD
  Call S_AFF_CHAR(VALEUR,PARAM,"POSCNTOBL","SUBPOS","") From GACTION
  [M]CPYPOSCOD = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CPYPOSCOD" : GZNUM = 16059 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]CPYPOSCOD or IMPMOD
    SAVACT = GACTION : GACTION = "CPCONT"
    PARAM(1) = [M]CPYCRY
    PARAM(2) = [M]CPYCTY
    PARAM(3) = ""
    Local Char    VALEUR(250)
    VALEUR = [M]CPYPOSCOD
    Call S_AFF_CHAR(VALEUR,PARAM,"CPCONT","SUBPOS","") From GACTION
    [M]CPYPOSCOD = VALEUR
    [M]CPYCTY = PARAM(2)
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CPYPOSCOD" : GZNUM = 16059 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone CPYCTY
