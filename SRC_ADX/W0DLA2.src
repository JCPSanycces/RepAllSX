#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DLA2 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CPY
mkstat = 0
zoncou = "CPY"
indice = 0
WCHAR = [M]CPY
If varmode([M]CPY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPY" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "ACONTCPY"
 Call CONTSOC([M]CPY) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("CPY","!A",[M]CPY,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTCPYLEG"
   Call CONTCPYLEG([M]CPY,GCURLEG) From TRTX3
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]CPY or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_CPY([M]CPY) From SUBDLA
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone CPYTEL
mkstat = 0
zoncou = "CPYTEL"
indice = 0
WCHAR = [M]CPYTEL
SAVACT = GACTION : GACTION = "FMTTELPAY"
Call FMTTELPAY([M]CPYCRY) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]CPYTEL : Endif
If !mkstat
 If varmode([M]CPYTEL,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "CPYTEL" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "ACNTTEL"
  Call CONTTEL([M]CPYTEL,[M]CPYCRY) From CONTNUM
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CPYTEL" : GZNUM = 289 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]CPYTEL or IMPMOD
    SAVACT = GACTION : GACTION = "ACNTTELMOD"
    Call CONTTELMOD([M]CPYTEL,[M]CPYCRY) From CONTNUM
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CPYTEL" : GZNUM = 289 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone CPYADDLIG
mkstat = 0
zoncou = "CPYADDLIG"
For indice=0 To 2
 SAVACT = GACTION : GACTION = "FMTADRPAY"
 Call FMTADRPAY("") From TRTDIV
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CPYADDLIG(indice) : Endif
 If !mkstat
  If varmode([M]CPYADDLIG,indice)=0
   If !mkstat
    IMPMOD = 0 : IMPZON = "CPYADDLIG" : Gosub ACTION From =IMPTRT
   Endif
  Endif
 Endif
 mkstat = 0
Next indice
If mkstat : End : Endif

## Zone CPYPOSCOD
mkstat = 0
zoncou = "CPYPOSCOD"
indice = 0
WCHAR = [M]CPYPOSCOD
SAVACT = GACTION : GACTION = "FMTPOSPAY"
