#<AdxTL>@(#)2.0.0.0 $Revision$
#########################################################################
#  SIXTPT : pour traitements de bascule Integrale --> X3                #
#########################################################################
#                                                                       #
# Subprog SIXTPT                                                        #
#     Création des conditions de paiement                               #
#                                                                       #
#                                                                       #
# --------------------------------------------------------------------- #
# PRE-REQUIS :                                                          #
# --------------------------------------------------------------------- #
#     1 - Migrations précédentes :                                      #
#     2 - Mise à jour de la table diverse 3 : Mode de règlement         #
#                                                                       #
#                                                                       #
#                                                                       #
#########################################################################
# Sous l'Intégrale, Mode de règlement et Condition de paiement sont sous une seule table MOD_RGL
#
# La table MOD_RGL est composé de 2 champs :
#      - CLE_RGL => 2 caractères qui va correspondre au mode de règlement X3
#      - NUM_ORD => 2 alphanumériques 
#    
#
#
#########################################################################
#
#########################################################################
# Supp...
If !clalev([F:TPT])  : Local File TABPAYTERM   [TPT]   : Endif  # Condition de paiement
If !clalev([F:XMR])  : Local File XIMODRGL     [XMR]   : Endif  # Mode de règlement

Trbegin [TPT], [XMR]
Delete [TPT]  Where 1=1
Update [XMR] Where 1=1 With FLGREP=1
Commit 
End
Gosub SI_CONTEXT From SIXFONCTION

Global Integer X_NB
Call OUVRE_BOITE("XIMODRGL",nbrecord([XMR])) From GESECRAN
Raz X_NB
Call EXEC
Call FERME_BOITE From GESECRAN
Kill X_NB
End

#########################################################################
Subprog EXEC

Local Integer WOUV_TRACE
If GTRACE = ""
 Call OUVRE_TRACE("SIXTPT : Process translation file from INTEGRALE to X3") From LECFIC
 WOUV_TRACE=1
Endif

Onerrgo TRT_ERR

#----  Migration des condition de paiement : TABPAYTERM  ------#
Call ECR_TIME("SIXTPT : "+SI_MES(75)-"TABPAYTERM") From DOSSUB
Call SI_TABPAYTERM
If GOK<>1 : Goto FIN_TPT : Endif

$FIN_TPT
Onerrgo 
If WOUV_TRACE=1
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

$TRT_ERR
Call ECR_TRACE(errp-"("-num$(errl)-") :"-errmes$(errn)-errm, 1) From GESECRAN
Resume


######################################################################################
## Traitement des conditions de paiements
######################################################################################
Subprog SI_TABPAYTERM
Variable Char CUR()

Local Integer STOP, NB
Local Char    LREPRISE(50), LRERISE2(50)

Local Decimal PRC
    
## Tables Intégrale
If !clalev([F:XMR])  : Local File =SI_DOSSIER+".XIMODRGL"      [XMR]  : Endif  # Mode de règlements

## Tables X3
If !clalev([F:TPT])  : Local File =SI_DOSSIER+".TABPAYTERM"   [TPT]  : Endif  # Condition de paiements
If !clalev([F:AXX])  : Local File =SI_DOSSIER+".ATEXTRA"      [AXX]  : Endif  # Textes

SI_SUBPRG = "SIXTPT"
SI_TABLE  = "XIMODRGL"
Gosub SI_CRITSUP From SIXFONCTION

$LOOP_TPT
Raz NB

If STOP=1
 CRITERE = "((CLERGL='"+LREPRISE+"' & NUMORD>'"+LREPRISE2+"') or CLERGL>'"+LREPRISE+"')"
 STOP=0
Else
 CRITERE="1=1"
Endif

Call DEBTRANS From GLOCK
Trbegin [TPT]

# Traitement des comptes généraux
For [XMR] Where FLGREP<>2 & NUMORD<>"~"
&             & evalue(CRITERE)
&             & evalue(SI_CRITERE)
 
 GOK = 1
 Call AFFBOITE([F:XMR]CLERGL+num$([F:XMR]NUMORD)) From SUBSIM

 # creation condition de paiement (TABPAYTERM)
 Gosub CRE_TPT
 If GOK<=0 : Break :  Endif

 Readlock [XMR] Curr
 [F:XMR]FLGREP = 2
 Rewrite [XMR]

 # NB alimenté dans CRE_TPT
 If NB>1000
  LREPRISE  = [F:XMR]CLERGL
  LREPRISE2 = [F:XMR]NUMORD
  STOP      = 1
  Break
 Endif
Next

If GOK>0
 If SI_SIMU<>2
  Commit
 Else
  Rollback
 Endif
 If STOP
  Goto LOOP_TPT
 Endif
Else
 Rollback
Endif
End

##################################################################
$CRE_TPT
Raz [F:TPT]

# recuperation et controle code compte
If !func SIXFONCTION.SI_CTL("PTE",[F:XMR]X3CLE,"XIMODRGL ("+[F:XMR]CLERGL+num$([F:XMR]NUMORD)+")")
 GOK=0 : Return
Else
 Look [TPT]TPT0 = [F:XMR]X3CLE;1
 If !fstat : Return : Endif
Endif

#[F:TPT]PTE    = [F:XMR]CLERGL+num$([F:XMR]NUMORD)
[F:TPT]PTE    = [F:XMR]X3CLE

# Intitulé : Modif de ATEXTRA
#-------------------------------------------------
Call MAJTEXTRA ([F:XMR]LIBRGL,"TABPAYTERM","DESAXX",[F:TPT]PTE,"") From ATEXTRA
#Call MAJTEXTRA ([F:XMR]LIBRGL,"TABPAYTERM","SHOAXX",[F:TPT]PTE,"") From ATEXTRA

# Condition de paiement de remplacement
#-------------------------------------------------
# Intégrale permet de choisir si le remplacement s'effectue si le montant est inférieur ou supérieur.
# X3 le remplacement ne s'effectue que si le montant est inférieur !!
If [F:XMR]SENCPR = "<"
 [F:TPT]DUDMINAMT = [F:XMR]MNTCPR
 [F:TPT]RPLPTE    = [F:XMR]RGLRPC
Endif 

# Dates et utilisateurs
#-------------------------------------------------
[F:TPT]CREDAT   = date$      # date création    
[F:TPT]CREUSR   = GUSER      # operateur création
[F:TPT]UPDDAT   = date$      # date modification
[F:TPT]UPDUSR   = GUSER      # operateur modification

Raz PRC
For I=1 To [F:XMR]NBRECH
 [F:TPT]PTELIN = I
  
 # Mode de règlement
 #-------------------------------------------------
 [F:TPT]PAM = func SIXFONCTION.SI_COR2("XIMODRGL",[F:XMR]CLERGL,"~","3","")

 # % Echéance & % TVA
 #-------------------------------------------------
 #If PRC+arr(100/[F:XMR]NBRECH,0.01)>100 #DdM43690
 If PRC+arr(100/[F:XMR]NBRECH,0.01)>100 or I=[F:XMR]NBRECH
  [F:TPT]DUDPRC = 100-PRC    
 Else
  [F:TPT]DUDPRC = arr(100/[F:XMR]NBRECH,0.01)
 Endif
 PRC += [F:TPT]DUDPRC
 [F:TPT]VATPRC = [F:TPT]DUDPRC       # % TVA

 # Calcul des jours
 #-------------------------------------------------
 # Mois & jours
 If I=1
  If !mod([F:XMR]NBRJOUECH,30)
   [F:TPT]NBRMON = [F:XMR]NBRJOUECH
  Else
   [F:TPT]NBRMON = int([F:XMR]NBRJOUECH/30)
   [F:TPT]NBRDAY = [F:XMR]NBRJOUECH-[F:TPT]NBRMON*30
  Endif
 Else
  # Intégrale : Décalage date de base => Nb de jour s'écoulant entre chaque échéance
  [F:TPT]NBRDAY += [F:XMR]DLRDATBAS 
 Endif

 # Net / Fin de mois / Décade / Quinzaine
 Case [F:XMR]NETFINMOI
  When "F" : [F:TPT]ENDMONFLG = 2 
  When "D" : [F:TPT]DAYMON(0) = 10
             [F:TPT]DAYMON(1) = 20
             [F:TPT]DAYMON(2) = 30
  When "Q" : [F:TPT]DAYMON(0) = 15
             [F:TPT]DAYMON(1) = 30
 Endcase


 # Intégrale : Jour limite - Jour report 
 #   Jour limite le 25 et report le 10 => Pièce entre le 25 et le 9 du mois suivant aura comme date de base le 10 du mois suivant.
 #   Option non reprise
 #-------------------------------------------------
  

 # Données initialiées par défaut
 #-------------------------------------------------
 [F:TPT]PAMTYP = 1                    # Type de règlement inititalisé à "Echéance".  (2-Acompte & 3-Retenue sur Garantie)


 SI_TABLE = "TABPAYTERM"
 Gosub SI_BEFWRI From SIXFONCTION

 Write [TPT]
 If fstat
  # Condition de paiement... : ... (...) Erreur d'écriture 
  Call ECR_TRACE(SI_MES(202)-[F:TPT]PTE-"("+[F:XMR]CLERGL+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0 : Break
 Else
  NB+=1
 Endif
Next

Return



