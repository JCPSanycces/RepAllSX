#<AdxTL>@(#)0.0.0.0 $Revision$ objet LED
Raz GPILOBJ
Call OBJET("LED",GBIDC1,GBIDC2) From GOBJET
End


$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "LIENS"      : Gosub LIENS
 When "VERIF_CRE"  : Gosub VERIF_CRE
 When "INICRE"     : Gosub INICRE
 When "RAZCRE"     : Gosub RAZCRE
 When "INIMOD"     : Gosub INIMOD
 When "APRES_CRE"  : Gosub APRES_CRE
 When "APRES_MOD"  : Gosub APRES_MOD
 When "CREATION"   : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "ANNULE"     : Gosub ANNULE
 When "AP_CHANGE"  : Gosub AP_CHANGE
 When "AP_ANNULE"  : Gosub AP_ANNULE
 When "VERIF_MOD"  : Gosub VERIF_MOD
 When "FERME"      : Gosub FERME
Endcase
Return

$OUVRE
If clalev([F:COA])=0 : Local File GCOA      [COA] : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
If clalev([F:GCM])=0 : Local File GACM      [GCM] : Endif
#JASMI - 2016-12-05 - JIRA X3-11928 - START
#If clalev([F:HAE])=0 : Local File GACCENTRY [HAE] : Endif
If filinfo(filpath("FIL","GACCENTRY","fde",0),0)<0
  If clalev([F:HAE])=0 : Local File GACCTMP   [HAE] : Endif
Else
  If clalev([F:HAE])=0 : Local File GACCENTRY [HAE] : Endif
Endif
#JASMI - 2016-12-05 - JIRA X3-11928 - END
If clalev([F:DIE])=0 : Local File GDIE      [DIE] : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

# Vérification des modifications des données
Local Integer FLMOD, FLDIE, NBCPY, NBLED, NBGCM
Local Char    TBCPY(GLONCPY)(1..GNBSOC+10)
Global Integer INTNONE: INTNONE = -1
Global Char CHARNONE(4): CHARNONE = "None"
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
If dim(GFLGMOG)>0 : Kill GFLGMOG : Endif
Return

$LIENS
Call LECTEXTRA([M]DESTRA,"GLED","DESTRA",[M]LED,"") From ATEXTRA
Call LECTEXTRA([M]SHOTRA,"GLED","SHOTRA",[M]LED,"") From ATEXTRA
Call SETCHAMPAXE
Call SETLEDTYPE(INTNONE, CHARNONE)
Call C_BAL([M]BAL)
Call C_EQLRANANA([M]EQLRANANA)
Call C_ENDVCR([M]ENDVCR)
GCURLEG = [F:LED]LEG
Return

$RAZCRE
Affzo [M] #65117
Call SETCHAMPAXE
Call SETLEDTYPE(INTNONE, CHARNONE)
Return

Subprog SETCHAMPAXE
# Grizage des lignes d'axes qui ne serviront pas (les 9-[M]DIENBR)
# garder le grizage si on rappelait SETCHAMPAXE au contrôle et avantsaisie sur DIENB
# si Chp DIEDACOBY / DIEIPT déjà coché.
Variable Integer NBAXE, I
If [M]ANA = 2
 If [M]DIEIPT = 2
  Actzo DIEIPT
  Effzo [M]DIEDACOBY
  Grizo [M]DIEDACOBY
 Elsif [M]DIEDACOBY = 2
  Actzo DIEDACOBY
  Effzo [M]DIEIPT
  Grizo [M]DIEIPT
 Else Actzo DIEDACOBY,DIEIPT
 Endif
 Actzo DIENBR
 Actzo BUD, CMM
 If dim([M:LED1]GDD)>0    : Actzo [M:LED1]GDD    : Endif
 If dim([M:LED1]PJMFLG)>0 : Actzo [M:LED1]PJMFLG : Endif
Else
 If [M]DIEIPT = 2 : Effzo [M]DIEDACOBY : Grizo [M]DIEDACOBY
 Elsif [M]DIEDACOBY = 2 : Effzo [M]DIEIPT : Grizo [M]DIEIPT
 Else
 Effzo DIEDACOBY,DIEIPT
 Grizo DIEDACOBY,DIEIPT
 Endif
 Effzo BUD, CMM, DIENBR
 Grizo BUD, CMM, DIENBR
 If dim([M:LED1]GDD)>0    : Effzo [M:LED1]GDD    : Grizo [M:LED1]GDD    : Endif
 If dim([M:LED1]PJMFLG)>0 : Effzo [M:LED1]PJMFLG : Grizo [M:LED1]PJMFLG : Endif
Endif
NBAXE=[M]DIENBR
For I=0 To NBAXE
 Actzo DIE(I)
Next I
If NBAXE>0 & NBAXE<9
 For I=1 To 9
  If I>=NBAXE
   Effzo [M] DIE(I)
   Grizo [M] DIE(I)
  Endif
 Next I
Elsif NBAXE=0
 Effzo [M] DIE, DIEDACOBY, DIEIPT
 Grizo [M] DIE, DIEDACOBY, DIEIPT
Endif
End

Subprog SETLEDTYPE(GEN, LEG)
#Issue 21158 – 2017-03-27  by MADOR - As an accountant I want to export correctly
#the data regarding taxonomy codes
Variable Integer GEN
Variable Char LEG

Local Integer ACTUALGEN  : [L] ACTUALGEN = 0
Local Char ACTUALLEG(10) : Raz ACTUALLEG

If func AFNC.ACTIV("KPO")
    If GEN = INTNONE
        ACTUALGEN = [M:LED1]GEN
    Else
        ACTUALGEN = GEN
    Endif

    If LEG = CHARNONE
        If func AFNC.ACTIV("LEG")
            ACTUALLEG = [M:LED1]LEG
        Else
            ACTUALLEG = GDOSLEG #In case of mono-legislation, this will get the folder legislation
        Endif
    Else
        ACTUALLEG = LEG
    Endif

    If (ACTUALLEG <> "" and ACTUALLEG <> "POR") or ACTUALGEN = 1
&          or !func AFNC.ACTIV("SAFT")
        [M:LED1]LEDTYPE = 1
        Affzo [M:LED1]LEDTYPE
        Chgfmt [M:LED1]LEDTYPE With "-K:10"

    Else
        Chgfmt [M:LED1]LEDTYPE With "K:10"
        If [M:LED1]LEDTYPE = 1
            [M:LED1]LEDTYPE = 2
            Affzo [M:LED1]LEDTYPE
        Endif
    Endif
Endif
#Issue end
End

$VERIF_CRE
If func AFNC.ACTIV("GDD")
    Gosub VERIF_GDD
    If OK=0 : Return : Endif
Endif
If func AFNC.ACTIV("PJM")
    Gosub VERIF_PJM
    If OK=0 : Return : Endif
Endif
Return

$VERIF_GDD
Local Integer OKENT, OKENV : OKENT=0 : OKENV=0
If [M]GDD=2
 For I=0 To [M]DIENBR-1
  Call LECTURE("DIE",[M]DIE(I),"") From CONTOBJ
  If [F:DIE]ENT=2 : OKENT=1 : Endif
  If [F:DIE]ENV=2 : OKENV=1 : Endif
 Next
 If !OKENT | !OKENV
  #Si le référentiel est flagué gestion des dépenses, il doit contenir un axe flagué entité et un axe flagué enveloppe
  GMESSAGE=mess(146,108,1)
  OK=0
 Endif
Endif
Return

# control that at leat one Dimension type is flagged "Project Management" or "Cost type"
$VERIF_PJM
Local Integer OKPJM, OKPCC : OKPJM=0 : OKPCC=0
If [M:LED1]PJMFLG=2
 For I=0 To [M:LED1]DIENBR-1
  Call LECTURE("DIE",[M:LED1]DIE(I),"") From CONTOBJ
  If [F:DIE]PCCFLG=2 : OKPCC=1  : Endif
  If [F:DIE]PJMFLG=2 : OKPJM=1  : Endif
  If OKPJM=1 or OKPCC=1 : Break : Endif
 Next
 If !OKPJM and !OKPCC
  # Référentiel coché ' Gestion à l’affaire' : au moins un axe doit être coché 'Gestion à l’affaire' ou 'Nature de dépense'
  GMESSAGE=mess(174,104,1)
  OK=0
 Endif
Endif
Return

$VERIF_MOD
# On ne peut pas changer le code plan ou les axes si mouvementé
Raz FLMOD, FLDIE
If [M:LED1]COA<>[F:LED]COA : FLMOD = 1 : Endif
If [M:LED1]DIENBR<[F:LED]DIENBR : FLDIE = 1 : Endif
For I=0 To [F:LED]DIENBR-1
 If [M:LED1]DIE(I)<>[F:LED]DIE(I) : FLDIE = 1 : Endif
Next I
If FLMOD | FLDIE
 For [CPY]
  Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
  If find([F:LED]LED,[F:GCM]LED)
   NBCPY += 1
   TBCPY(NBCPY) = [F:CPY]CPY
  Endif
 Next
 For I=1 To NBCPY
  Filter [HAE] Where CPY=TBCPY(I)
  Read [HAE] First
  Filter [HAE]
  If fstat<=2
   OK = 0 : Break
  Endif
 Next I
 If !OK
  GMESSAGE = mess(183,105,1)
  # Modification du plan comptable ou des axes impossible
  [M:LED1]COA = [F:LED]COA
  [M:LED1]DIENBR = max([M:LED1]DIENBR,[F:LED]DIENBR)
  For I=0 To [F:LED]DIENBR-1
   [M:LED1]DIE(I) = [F:LED]DIE(I)
  Next I
  Affzo [LED1]COA,DIENBR,DIE
  Return
 Endif
 If func AFNC.ACTIV("GDD")
  Gosub VERIF_GDD
 Endif
Endif

# On ne peut pas changer certaines informations d'un référentiel étant un "Référentiel Générale principale"
FLMOD = 0
If [M:LED1]GEN<>[F:LED]GEN & [M:LED1]GEN<>2
 FLMOD = 1
Elsif [M:LED1]BAL<>[F:LED]BAL & [M:LED1]BAL<>2
 FLMOD = 2
Elsif [M:LED1]FCYBAL<>[F:LED]FCYBAL & [M:LED1]FCYBAL<>2
 FLMOD = 3
Elsif [M:LED1]MTCFLG<>[F:LED]MTCFLG & [M:LED1]MTCFLG<>2
 FLMOD = 4
Elsif [M:LED1]MTCFLG<>[F:LED]MTCFLG & [M:LED1]MTCFLG<>2
 FLMOD = 5
Endif

If FLMOD
 OK = 1
 For [GCM]
  If [F:GCM]LED([F:GCM]GENLEDTYP-1)=[F:LED]LED
   Case num$(FLMOD)
    When "1" :
     # Changement "Général" impossible
     OK = 0 : GMESSAGE = mess(187,105,1)
    When "2" :
     # Changement "Equilibre"  impossible
     OK = 0 : GMESSAGE = mess(188,105,1)
    When "3" :
     # Changement "Equilibre par site" impossible
     OK = 0 : GMESSAGE = mess(189,105,1)
    When "4" :
     # Changement "Lettrage"  impossible
     OK = 0 : GMESSAGE = mess(190,105,1)
    When "5" : OK = 0 : GMESSAGE = mess(187,105,1)
     # Changement "Lettrage impossible"  impossible
     OK = 0 : GMESSAGE = mess(194,105,1)
   Endcase
   If !OK : Break : Endif
  Endif
 Next
 If !OK : Return : Endif
Endif

# On ne peut pas changer certaines informations d'un référentiel étant un "Référentiel Analytique principale"
FLMOD = 0
If [M:LED1]ANA<>[F:LED]ANA & [M:LED1]ANA<>2
 For [GCM]
  If [F:GCM]LED([F:GCM]ANALEDTYP-1)=[F:LED]LED
   # Changement "Analytique" impossible
   OK = 0 : GMESSAGE = mess(192,105,1) : Break
  Endif
 Next
 If !OK : Return : Endif
Endif

If func AFNC.ACTIV("PJM")
  Gosub VERIF_PJM
  If !OK : Return : Endif
Endif

#Demande 61806 : Mettre à jour la fiche société...
# Lock des sociétés avant la transaction
If !FLDIE
 If [M:LED1]DIENBR<>[F:LED]DIENBR
  FLDIE = 1
 Else
  For I=0 To max([F:LED]DIENBR,[M:LED1]DIENBR)-1
   If [M:LED1]DIE(I)<>[F:LED]DIE(I) : FLDIE = 1 : Endif
  Next I
 Endif
 If FLDIE
  For [CPY]
   Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
   If find([F:LED]LED,[F:GCM]LED)
    NBCPY += 1
    TBCPY(NBCPY) = [F:CPY]CPY
   Endif
  Next
 Endif
Endif

If NBCPY
 Local Char    TSYMBOLE(50)(1..NBCPY)
 Local Integer NBLOCK : Raz NBLOCK
 For I=1 To NBCPY
  NBLOCK+=1
  TSYMBOLE(NBLOCK) = "CPY"+TBCPY(NBCPY)
  Lock =TSYMBOLE(NBLOCK) With lockwait=0
  If fstat
   # Modification impossible ... Société ...  La fiche est utilisée par un autre utilisateur
   OK=0 : GMESSAGE=mess(9,123,1)-"\"-mess(2,45,1)-TBCPY(NBCPY)-":"-mess(98,126,1) : Return
  Endif
 Next
Endif
# Fin de la demande 61806
Return

$INICRE
$INIMOD
If dim([F:LED]DES)>0
 [F:LED]DES = [M:LED1]DESTRA
Endif
If func AFNC.ACTIV("LEG")=0 : [F:LED]LEG = GDOSLEG(1) : Endif
Return

$APRES_CRE
Call GLOBVAR From SETGLBLED
Gosub RELIT From GOBJSUB
Return

$APRES_MOD
Call GLOBVAR From SETGLBLED
Gosub RELIT From GOBJSUB

#Demande 61806 : Mettre à jour la fiche société...
# Lock des sociétés avant la transaction
If dim(TSYMBOLE)>0
 For I=1 To NBLOCK
  Unlock =TSYMBOLE(I)
 Next
Endif
Return

$AP_CHANGE
#Class[M] à éviter car $AP_CHANGE peut être appelé d'un utilitaire externe ACHANGE
#Call CHGTEXTRA("GLED","DESTRA",[M]LED,"",NCODE,"") From ATEXTRA
#Call CHGTEXTRA("GLED","SHOTRA",[M]LED,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("GLED","DESTRA",OCODE,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("GLED","SHOTRA",OCODE,"",NCODE,"") From ATEXTRA
Call GLOBVAR From SETGLBLED
Read [F:LED]LED0 = NCODE
Return

$AP_ANNULE
Call GLOBVAR From SETGLBLED
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif

#Demande 61806 : Mettre à jour la fiche société.
If NBCPY
 For I=1 To NBCPY
  Raz FLDIE
  Read [CPY]CPY0 = TBCPY(I)
  If !fstat
   For J=0 To [F:LED]DIENBR-1
    If !find([F:LED]DIE(J),[F:CPY]DIE(0..dim([F:CPY]DIE)-1))
     K=find("",[F:CPY]DIE(0..dim([F:CPY]DIE)-1))
     [F:CPY]DIE(K-1) = [F:LED]DIE(J)
     FLDIE = 1
    Endif
   Next J
   If FLDIE
    Rewrite [CPY]
    If fstat
     GOK=0 : Call FSTA("CPY") From GLOCK : Break
    Endif
   Endif
  Endif
 Next I
 If !GOK : Return : Endif
Endif
# Fin de la demande 61806
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GLED","DESTRA",CLECUR1,"","GLED","DESTRA",[M]LED,"")  From ATEXTRA
 Call DUPTEXTRA("GLED","SHOTRA",CLECUR1,"","GLED","SHOTRA",[M]LED,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESTRA,"GLED","DESTRA",[M]LED,"") From ATEXTRA
Call MAJTEXTRA([M]SHOTRA,"GLED","SHOTRA",[M]LED,"") From ATEXTRA
Return

$ANNULE
Call SUPTEXTRA("GLED","DESTRA",[M]LED,"") From ATEXTRA
Call SUPTEXTRA("GLED","SHOTRA",[M]LED,"") From ATEXTRA
Return

############################################################################
#  Etiquette du mask LED1
############################################################################
Subprog AP_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG= VALEUR
Call SETLEDTYPE(INTNONE, VALEUR)
End

Subprog C_GEN(VALEUR)
Variable Integer VALEUR
# Pour un référentiel, "Général" ou/et "Analytique" doit être flagué
If [M]GEN<>VALEUR & VALEUR<>2 : [M]ANA=2 : Affzo [M]ANA : Endif
End

Subprog C_ANA(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
 Actzo DIENBR, DIEDACOBY, DIEIPT
 Actzo BUD, CMM
 If dim([M:LED1]GDD)>0    : Actzo [M:LED1]GDD    : Endif
 If dim([M:LED1]PJMFLG)>0 : Actzo [M:LED1]PJMFLG : Endif
Else
 Effzo BUD, CMM, DIENBR, DIEDACOBY, DIEIPT
 Grizo BUD, CMM, DIENBR, DIEDACOBY, DIEIPT
 If dim([M:LED1]GDD)>0    : Effzo [M:LED1]GDD    : Grizo [M:LED1]GDD    : Endif
 If dim([M:LED1]PJMFLG)>0 : Effzo [M:LED1]PJMFLG : Grizo [M:LED1]PJMFLG : Endif
 # Pour un référentiel, "Général" ou/et "Analytique" doit être flagué
 If [M]ANA<>VALEUR : [M]GEN=2 : Affzo [M]GEN : Endif
Endif
End

Subprog C_COA(VALEUR)
Variable Char    VALEUR()
Call LECTURE("COA",VALEUR,"") From CONTOBJ
If ([M]ANA=2 & [F:COA]ANATRK<>2) or ([M]GEN=2 & [F:COA]GENTRK<>2)
 GMESSAGE=mess(93,102,1) # Plan de compte incompatible
 mkstat=2 : End
Endif
End

Subprog AV_DIENBR(VALEUR)
Variable Decimal VALEUR
If !([M]ANA=2 or [M]CMM=2)  : # Référentiel Analytique ou Engagement
 VALEUR = 0 : Grizo DIENBR
Else
 Actzo DIENBR
Endif
Call SETCHAMPAXE
End

Subprog C_DIENBR(VALEUR)
Variable Decimal VALEUR
If clalev([F:DIE]) = 0 : Local File GDIE  [DIE] : Endif
If VALEUR>nbrecord([DIE])
 # Nombre maximum d'axes analytiques
 GMESSAGE = mess(1,103,1)+" = "+num$(nbrecord([DIE]))
 [M]DIENBR=nbrecord([DIE])
 Affzo [M]DIENBR
 mkstat = 1 : End
Elsif [M]ANA = 2 & VALEUR = 0
 # Au moins un axe doit être renseigné
 GMESSAGE = mess(135,107,1)
 mkstat = 2 : End
Else
 [M]DIENBR=VALEUR
 Call SETCHAMPAXE
Endif
End

Subprog AS_DIE(VALEUR)
Variable Char VALEUR
Call SETCHAMPAXE
End

Subprog C_DIE(VALEUR)
Variable Char    VALEUR()
Local Integer I
For I=0 To [M]DIENBR-1
 If [M]DIE(I)=VALEUR & indice<>I & VALEUR<>""
  # Axe déjà défini
  GMESSAGE = mess(80,105,1)
  mkstat = 1 : End
 Endif
Next
If func AFNC.ACTIV("GDD") & [M]GDD=2
 Call LECTURE("DIE",VALEUR,"") From CONTOBJ
 If [F:DIE]ENT=2
  For I=0 To [M]DIENBR-1
   If I<>indice
    Call LECTURE("DIE",[M]DIE(I),"") From CONTOBJ
    If [F:DIE]ENT=2
     #On ne peut définir ici qu'un seul axe flagué entité
     GMESSAGE=mess(237,108,1)
     mkstat=1 : Break : End
    Endif
   Endif
  Next
 Elsif [F:DIE]ENV=2
  For I=0 To [M]DIENBR-1
   If I<>indice
    Call LECTURE("DIE",[M]DIE(I),"") From CONTOBJ
    If [F:DIE]ENV=2
     #On ne peut définir ici qu'un seul axe flagué enveloppe
     GMESSAGE=mess(238,108,1)
     mkstat=1 : Break : End
    Endif
   Endif
  Next
 Endif
Endif

If func AFNC.ACTIV("PJM")
  If [M:LED1]PJMFLG=2
    Call LECTURE("DIE",VALEUR,"") From CONTOBJ
    If [F:DIE]PJMFLG=2
      For I=0 To [M:LED1]DIENBR-1
        If I<>indice
          Call LECTURE("DIE",[M:LED1]DIE(I),"") From CONTOBJ
          If [F:DIE]PJMFLG=2
            # Un seul axe peut être coché 'Gestion à l'affaire' par référentiel.
            GMESSAGE=mess(178,104,1)
            mkstat=1 : Break
          Endif
        Endif
      Next
    Elsif [F:DIE]PCCFLG=2
      For I=0 To [M:LED1]DIENBR-1
        If I<>indice
          Call LECTURE("DIE",[M:LED1]DIE(I),"") From CONTOBJ
          If [F:DIE]PCCFLG=2
            # Un seul axe peut être coché 'Nature de dépense' par référentiel.
            GMESSAGE= mess(172,104,1)
            mkstat=1 : Break
          Endif
        Endif
      Next
    Endif
  Endif
  If mkstat=1 : End : Endif
Endif
End

Subprog AS_DIEDACOBY(VALEUR)
Variable Integer VALEUR
If [M]DIENBR=0
  VALEUR = 1 : mkstat = 2 : End
Endif
End

Subprog D_DIEDACOBY(VALEUR)
Variable Integer VALEUR
If [M]ANA=2 & [M]GEN=2
 VALEUR = 1
Elsif [M]ANA=2 & [M]GEN<>2
 VALEUR = 2
Endif
End

Subprog C_DIEDACOBY(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
 Effzo [M]DIEIPT
 Grizo [M]DIEIPT
Else
 Actzo [M]DIEIPT
Endif
End

Subprog AS_DIEIPT(VALEUR)
Variable Integer VALEUR
If [M]DIENBR=0 | [M]DIEDACOBY=2
 VALEUR = 1 : mkstat = 2 : End
Endif
End

Subprog C_DIEIPT(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
 Effzo [M]DIEDACOBY
 Grizo [M]DIEDACOBY
Else
 Actzo [M]DIEDACOBY
Endif
End

Subprog C_BAL(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]EQLRANANA=2 : Affzo EQLRANANA : Grizo EQLRANANA
 Actzo [M]ENDVCR, ACCVCR
 Actzo [M]FCYBAL
Else
 Actzo EQLRANANA
 [M]FCYBAL=1 : Affzo FCYBAL : Grizo FCYBAL
Endif
End

Subprog C_EQLRANANA(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Actzo ENDVCR
Else
 Effzo ENDVCR
 Grizo ENDVCR
Endif
End

Subprog C_ENDVCR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Actzo ACCVCR
Else
 Effzo ACCVCR
 Grizo ACCVCR
Endif
End
######################################################################################
## Section automatically added (screen LED1) 03/21/2017 12:24:06 (MADOR)
######################################################################################
Subprog AM_GEN(VALEUR)
#Issue 21158 – 2017-03-27  by MADOR - As an accountant I want to export correctly
#the data regarding taxonomy codes
Variable Integer VALEUR
Call SETLEDTYPE(VALEUR, CHARNONE)
#Issue end
End

Subprog AS_LEDTYPE(VALEUR)
#Issue 21158 – 2017-03-27  by MADOR - As an accountant I want to export correctly
#the data regarding taxonomy codes
Variable Integer VALEUR
GMENLOC(1) = 1
#Issue end
End


######################################################################################

