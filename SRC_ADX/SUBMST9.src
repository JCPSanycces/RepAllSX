##########################################################################################################
#gestion de l'écran MST9
##########################################################################################################

##########################################################################################################
Subprog AS_NBADR
If GMST9_NOCHGLIGNE=1
    GMST9_NOCHGLIGNE=0
    nolign=[M:MST9]XNOLIGN
    Affzo [M:MST9]NBADRSEL(nolign-1)
    End
Endif
If GMST9_IN_MODIF=0
    If [M:MST9]CODADR(nolign-1)=""
        End
    Endif
    Local Integer ILIGNE
    Local Integer NOLIGNSAVE
    NOLIGNSAVE=nolign
    ILIGNE=0
    While ILIGNE<=[M:MST9]NBADR
        If [M:MST9]NBADRSEL(ILIGNE)<>""
            NBADRSEL(ILIGNE)=""
        Endif
        ILIGNE=ILIGNE+1
    Wend
    nolign=NOLIGNSAVE
    [M:MST9]NBADRSEL(nolign - 1) = "->"
    [M:MST9]XCODADR=[M:MST9]CODADR(nolign-1)
    [M:MST9]XMGTBPD=[M:MST9]MGTBPD(nolign-1)
    [M:MST9]XBPADEF=[M:MST9]BPADEF(nolign-1)

    [M:MST9]XNOLIGN=nolign
    
    Gosub AFFFICHE_ADR_SEC From TRTMST9
    nolign=NOLIGNSAVE
    Affzo [M:MST9]1-99
Endif
    

End


##########################################################################################################
Subprog AM_XREPNUMBPC(VALEUR)
Variable Char    VALEUR()
End

##########################################################################################################
Subprog AM_XREPNUMBPD(VALEUR)
Variable Char    VALEUR()
End


##########################################################################################################
Subprog AM_REPNUMBPC(VALEUR)
Variable Char    VALEUR()
[M:MST9]MANASSBPC(nolign-1)=1
End

##########################################################################################################
Subprog AM_REPMSSBPC(VALEUR)
Variable Char    VALEUR()
[M:MST9]MANASSBPC(nolign-1)=1
End

##########################################################################################################
Subprog C_ITMBPC(VALEUR)
Variable Char    VALEUR()

If VALEUR = "" : End : Endif
Local Integer INUM_ADI
INUM_ADI = 19 + GFAMCIA

Read [ADI] CODE = INUM_ADI;VALEUR
If fstat
    #Valeur incorrect.
    GMESSAGE = mess(83, 123, 1) 
    GERR = 1
    mkstat = 2
    End
Endif

End

##########################################################################################################
Subprog AM_ITMBPC(VALEUR)
Variable Char    VALEUR()
[M:MST9]MANASSBPC(nolign-1)=1
Local Integer INUM_ADI
INUM_ADI= 19 + GFAMCIA

If VALEUR = ""
    [M:MST9]LIBITMBPC(nolign-1) = ""
Else
    Call GET_LIB(INUM_ADI, VALEUR, [M:MST9]LIBITMBPC(nolign-1)) From CRM_UTIL
Endif

Affzo [M:MST9]LIBITMBPC(nolign-1)

End

