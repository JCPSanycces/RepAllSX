##########################################################################################################
Subprog AM_XSECNUM(VALEUR)
Variable Char    VALEUR()
Local Integer ILIGNE
ILIGNE=0
Local Integer INUM_ADI
INUM_ADI= 19 + GFAMCIA

If dim([F:MST]MARSCTREP)>0
    If dim([M:MST9]XREPNUMBPC)>0 
        If [M:MST9]XREPNUMBPC(0)=""
            [M:MST9]XREPNUMBPC(0)=[F:MST]MARSCTREP(0)
        Endif
    Endif

    If dim([M:MST9]XREPNUMBPD)>0
        If [M:MST9]XREPNUMBPD(0)=""
            [M:MST9]XREPNUMBPD(0)=[F:MST]MARSCTREP(0)
        Endif
    Endif
Endif

If dim([F:MST]MARSCTREP)>1
    If dim([M:MST9]XREPNUMBPC)>1 
        If [M:MST9]XREPNUMBPC(1)=""
            [M:MST9]XREPNUMBPC(1)=[F:MST]MARSCTREP(1)
        Endif
    Endif

    If dim([M:MST9]XREPNUMBPD)>1
        If [M:MST9]XREPNUMBPD(1)=""
            [M:MST9]XREPNUMBPD(1)=[F:MST]MARSCTREP(1)
        Endif
    Endif
Endif

If [M:MST9]NBADR=0
    Filter [MRS] Where [F:MRS]MARSCTNUM = VALEUR Order By [F:MRS]SCTREPSEC Asc

    For [MRS] MRS1
        If ILIGNE>= dim([M:MST9]SCTREPSEC) - 1 : Break : Endif
        [M:MST9]REPNUMBPC(ILIGNE) = [F:MRS]SCTREPSEC
        [M:MST9]REPMSSBPC(ILIGNE) = [F:MRS]SCTREPMSS
        [M:MST9]ITMBPC(ILIGNE) = [F:MRS]SCTREPITM

        #Affiche le libellé en clair de la famille de produit.
        If [M:MST9]ITMBPC(ILIGNE) = ""
            [M:MST9]LIBITMBPC(ILIGNE) = ""
        Else
            Call GET_LIB(INUM_ADI, [M:MST9]ITMBPC(ILIGNE), [M:MST9]LIBITMBPC(ILIGNE)) From CRM_UTIL
        Endif
        [M:MST9]MANASSBPC(ILIGNE)=0
        ILIGNE= ILIGNE+1
    Next
    Filter [MRS]
    [M:MST9]NBADR = ILIGNE
Endif

Affzo [M:MST9]1-99

End


######################################################################################

