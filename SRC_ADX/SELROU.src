#<AdxTL>@(#)9.0.0.0 $Revision$

#######################################################
# Subprog SELROU(ITM,ALT)  Sélection des entetes gammes
# ramène la référence article plutôt que le n° d'alt
#######################################################
Local Char ITM
Local Integer ALT
Call SELROU(ITM,ALT)
End

Subprog SELROU(ITM,ALT)
Variable Char    ITM
Value    Decimal ALT
Local Integer RELIT

Onerrgo ERREUR From CONTROLE
If clalev([F:ROH])=0
 Local File ROUTING[ROH]
Endif
Onerrgo
If GERREUR : GERREUR=0 : End : Endif
Call SELNUM("ROU","",ALT,"") From SELOBJ
If [F:ROH]ITMREF <> ""
 ITM = [F:ROH]ITMREF
Endif
End

# modélisation de l'action sélection table
$ACTION
Case ACTION
 When "SEL_TABLE"   Gosub SELTABLE
 When "VERF_TABLE"  Gosub VERFTABLE
 When "FIN_TABLE"   Gosub FINTABLE
Endcase
Return

$SELTABLE

#Case TABLE
# When "SELROU"
#Endcase
If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ]  : Endif
If clalev([F:ROH]) = 0 : Local File ROUTING    [ROH]  : Endif
If clalev ([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif  # FGR 02/10/2009 : X3SUIVI58337

# FGR 02/10/2009 : X3SUIVI58337
Link [ROH] With [AXX]AXX0="ROUTING";"ROUDESAXX";GLANGUE;[F:ROH]IDENT1;[F:ROH]FCY As [NEW]

START = "ITMREF"
# param1 = référence ; param2 = alternative
TIT(0) = mess(63,198,1)  # Gamme
NBCOL += 1 : COL(NBCOL) = "ITMREF"
Call TEXTFIC("ROUTING","ITMREF",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ROUALT"
Call TEXTFIC("ROUTING","ROUALT",2,TIT(NBCOL)) From OBJDIV
# FGR 02/10/2009 : X3SUIVI58337
#NBCOL += 1 : COL(NBCOL) = "ROUDES"
#Call TEXTFIC("ROUTING","ROUDES",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
Call TEXTFIC("ROUTING","ROUDESAXX",2,TIT(NBCOL)) From OBJDIV
#
# FGR 02/10/2009 : X3SUIVI58337
#Default File [ROH]
Default File [NEW]

# 119185 mm 11.2016
DEFPAG=1
ORDRE = 'ITMREF;ROUALT'
Return

$VERFTABLE
# affecter aussi l'alternative ou laisser vide ?

# PARAM(2) contient le code de la zone que l'on doit alimenter avec le n° alternative sélectionné
If PARAM(2)<>"" Then
  If evalue("dim([M:ITF5]"+PARAM(2)+")")>=0 Then
    Assign "[M:ITF5]"+PARAM(2) With [F:ROH]ROUALT
  Endif
Endif

Return

$FINTABLE
Return

