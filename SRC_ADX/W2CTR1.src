Onevent BEFORE_INPUT Call AS_MATREMP(zc) From W2CTR1
Onevent AFTER_CHANGE Gosub AMM_MATREMP From W2CTR1
Return

Subprog AS_MATREMP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(44843,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_MATREMP(zc) From W2CTR1
Onkey   2 Titled GBOUTS Call S_MATREMP(zc) From W2CTR1
Onkey 144 Titled GBOUTP Call P_MATREMP(zc) From W2CTR1
Onkey 146 Titled GBOUTA Call SA_MATREMP(zc) From W2CTR1
Gosub _AFF
End

Subprog C_MATREMP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTEMP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTEMP"
 PARMSK(1) = ""
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = ""
 PARMSK(6) = func TOOLSHRLEG.LEGWRK
 Call S_LIS_CHAR(VALEUR,PARMSK,"","DIVPAYE","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "MATREMP" : GZNUM = 46590 : Endif
Endif
If !mkstat
 ## Action DROITEMP
 Call DROIT(VALEUR,"","","") From DIVPAYE
 If mkstat : GERR = 1 : GZONE = "MATREMP" : GZNUM = 46590 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("EML","!",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "MATREMP" : GZNUM = 46590 : Endif
  If !mkstat
   ## Action STD
   Call C_MATREMP(VALEUR) From SUBCTR
   If mkstat : GERR = 1 : GZONE = "MATREMP" : GZNUM = 46590 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_MATREMP
Call AM_MATREMP(zc)
If !mkstat & GOBJET
 zoncou = "MATREMP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_MATREMP(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZMATREMP)")>indice
 [M]MATREMP(indice) = VALEUR
 Affzo ZMATREMP(indice)
Endif
Gosub _AFF
End

Subprog S_MATREMP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELEMLLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMLLEG"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AS_MATREMP" : PROGSUB = "SUBCTR" : PROGSPE = "SPECTR" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = func TOOLSHRLEG.LEGWRK
 PARMSK(2) = ""
 PARMSK(3) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"SELEMLLEG","TOOLSHRLEG","") From GACTION
 ACTION = "BS_MATREMP" : PROGSUB = "SUBCTR" : PROGSPE = "SPECTR" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_MATREMP(VALEUR)
Variable Char    VALEUR()
Call OBJET("EML",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_MATREMP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "EML"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_MATREMP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("EML",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

