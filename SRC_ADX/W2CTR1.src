Subprog AS_AGNMIDWRK(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(46228,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_AGNMIDWRK(zc) From W2CTR1
Onkey   2 Titled GBOUTS Call S_AGNMIDWRK(zc) From W2CTR1
Onkey 144 Titled GBOUTP Call P_AGNMIDWRK(zc) From W2CTR1
Onkey 146 Titled GBOUTA Call SA_AGNMIDWRK(zc) From W2CTR1
Gosub _AFF
End

Subprog C_AGNMIDWRK(VALEUR)
Variable Char    VALEUR()
## Action CONTOBJN
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "CONTOBJN"
Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "AGNMIDWRK" : GZNUM = 47301 : Endif
If !mkstat
 ## Action CONTORG
 Call CONTORG(VALEUR) From SUBORG
 If mkstat : GERR = 1 : GZONE = "AGNMIDWRK" : GZNUM = 47301 : Endif
Endif
Gosub _AFF
End

