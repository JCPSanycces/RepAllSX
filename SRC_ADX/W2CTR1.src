Onevent BEFORE_INPUT Call AS_OFOCOD(zc) From W2CTR1
Onevent AFTER_CHANGE Gosub AMM_OFOCOD From W2CTR1
Return

Subprog AS_OFOCOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_OFOCOD(zc) From W2CTR1
Onkey 144 Titled GBOUTP Call P_OFOCOD(zc) From W2CTR1
Onkey 146 Titled GBOUTA Call SA_OFOCOD(zc) From W2CTR1
Gosub _AFF
End

Subprog C_OFOCOD(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("HRSOFO1","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "OFOCOD" : GZNUM = 55243 : Endif
Gosub _AFF
End

$AMM_OFOCOD
Call AM_OFOCOD(zc)
If !mkstat & GOBJET
 zoncou = "OFOCOD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_OFOCOD(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZOFOCOD)")>indice
 [M]OFOCOD(indice) = VALEUR
 Affzo ZOFOCOD(indice)
Endif
Gosub _AFF
End

Subprog S_OFOCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "HRSOFO1"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_OFOCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HRSOFO1"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_OFOCOD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("HRSOFO1",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZOFOCOD
Onevent BEFORE_AREA Gosub AV_ZOFOCOD From W2CTR1
Return

$AV_ZOFOCOD
If clalev([F:HROFO])=0 : Local File HRSOFOCOD [HROFO] : Endif
Call LECTURE("HRSOFO1",num$([M]OFOCOD(indice)),"") From CONTOBJ
zc = [F:HROFO]OFOTIT
Gosub _AFF
Return

