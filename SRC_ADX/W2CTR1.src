Subprog D_CATQLF(VALEUR)
Variable Char    VALEUR()
If varinit([M]CATQLF,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10605","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_CATQLF(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"10605") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CATQLF(zc) From W2CTR1
Onkey   2 Titled GBOUTS Call S_CATQLF(zc) From W2CTR1
Onkey 144 Titled GBOUTP Call P_CATQLF(zc) From W2CTR1
Onkey 146 Titled GBOUTA Call SA_CATQLF(zc) From W2CTR1
Gosub _AFF
End

Subprog C_CATQLF(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"10605","") From SUBADI
If mkstat : GERR = 1 : GZONE = "CATQLF" : GZNUM = 46510 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"10605",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CATQLF" : GZNUM = 46510 : Endif
Endif
Gosub _AFF
End

$AMM_CATQLF
Call AM_CATQLF(zc)
If !mkstat & GOBJET
 zoncou = "CATQLF" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CATQLF(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCATQLF)")>indice
 [M]CATQLF(indice) = VALEUR
 Affzo ZCATQLF(indice)
Endif
Gosub _AFF
End

Subprog S_CATQLF(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADILEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADILEG"
 PARMSK(1) = "10605"
 PARMSK(2) = GCURLEG
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADILEG","SELTABCPT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CATQLF(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"10605") From GOBJET
Gosub _AFF
End

Subprog SA_CATQLF(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "10605"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CATQLF(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "10605"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCATQLF
Onevent BEFORE_AREA Gosub AV_ZCATQLF From W2CTR1
Return

$AV_ZCATQLF
Call LECTEXTRA(zc,"ATABDIV","LNGDES","10605",num$([M]CATQLF(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_QLF
Onevent BEFORE_INPUT Call AS_QLF(zc) From W2CTR1
Return

Subprog AS_QLF(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_QLF(VALEUR) From SUBCTR
If mkstat=2
 [M]QLF(INDIC) = VALEUR
 Affzo QLF(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

$ON_STAEMP
Onevent BEFORE_INPUT Call AS_STAEMP(zc) From W2CTR1
Onevent AFTER_CHANGE Gosub AMM_STAEMP From W2CTR1
Onevent INIT_AREA Call D_STAEMP(zc) From W2CTR1
Return

Subprog D_STAEMP(VALEUR)
Variable Integer VALEUR
If varinit([M]STAEMP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_STAEMP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_STAEMP(VALEUR) From SUBCTR
If mkstat=2
 [M]STAEMP(INDIC) = VALEUR
 Affzo STAEMP(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_STAEMP
