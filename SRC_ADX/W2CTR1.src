#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_CTRTYP
Onevent CONTROL Call C_CTRTYP(zc) From W2CTR1
Onevent INIT_AREA Call D_CTRTYP(zc) From W2CTR1
Onevent BEFORE_INPUT Call AS_CTRTYP(zc) From W2CTR1
Return

Subprog D_CTRTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]CTRTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_CTRTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_CTRTYP(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CTRTYP" : GZNUM = 23203 : Endif
If !mkstat
 ## Action STD
 Call C_CTRTYP(VALEUR) From SUBCTR
 If mkstat : GERR = 1 : GZONE = "CTRTYP" : GZNUM = 23203 : Endif
Endif
Gosub _AFF
End

$ON_CDDGRD
Onevent BEFORE_INPUT Call AS_CDDGRD(zc) From W2CTR1
Onevent CONTROL Call C_CDDGRD(zc) From W2CTR1
Onevent AFTER_CHANGE Gosub AMM_CDDGRD From W2CTR1
Return

Subprog AS_CDDGRD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(55836,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action DEFHRRPL
Call DEFHRRPL(VALEUR,GCURLEG,GSOCIETE) From SUBHRRPL
If mkstat=2
 [M]CDDGRD(INDIC) = VALEUR
 Affzo CDDGRD(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_CDDGRD(zc) From W2CTR1
Onkey   2 Titled GBOUTS Call S_CDDGRD(zc) From W2CTR1
Onkey 144 Titled GBOUTP Call P_CDDGRD(zc) From W2CTR1
Onkey 146 Titled GBOUTA Call SA_CDDGRD(zc) From W2CTR1
Gosub _AFF
End

Subprog C_CDDGRD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CDDGRD" : GZNUM = 2675 : Endif
If !mkstat
 ## Action CONTHRRPL
 Call CONTHRRPL(VALEUR,GCURLEG,GSOCIETE) From SUBHRRPL
 If mkstat : GERR = 1 : GZONE = "CDDGRD" : GZNUM = 2675 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CDDGRD" : GZNUM = 2675 : Endif
  If !mkstat
   ## Action STD
   Call C_CDDGRD(VALEUR) From SUBCTR
   If mkstat : GERR = 1 : GZONE = "CDDGRD" : GZNUM = 2675 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CDDGRD
Call AM_CDDGRD(zc)
If !mkstat & GOBJET
 zoncou = "CDDGRD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CDDGRD(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CDDGRD(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "CDDGRD" : GZNUM = 2675 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZCDDGRD)")>indice
 [M]CDDGRD(indice) = VALEUR
 Affzo ZCDDGRD(indice)
Endif
Gosub _AFF
End

Subprog S_CDDGRD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRRPL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRRPL"
 PARMSK(1) = GCURLEG
 PARMSK(2) = GSOCIETE
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRRPL","SUBHRRPL","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CDDGRD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNHRRPL
 Call TUNHRRPL(VALEUR,GCURLEG,GSOCIETE) From SUBHRRPL
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_CDDGRD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HRRPL"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CDDGRD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("HRRPL",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCDDGRD
Onevent BEFORE_AREA Gosub AV_ZCDDGRD From W2CTR1
Return

$AV_ZCDDGRD
Call LECTEXTRA(zc,"HRRPLREN","DESAXX",num$([M]CDDGRD(indice)),"") From ATEXTRA
Gosub _AFF
Return

