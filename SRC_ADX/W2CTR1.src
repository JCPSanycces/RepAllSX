Subprog AS_STRCAE(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_STRCAE(VALEUR) From SUBCTR
If mkstat=2
 [M]STRCAE(INDIC) = VALEUR
 Affzo STRCAE(INDIC) : mkstat = 2
Endif
If !mkstat
 ## Action SUBCTRLEG
 Call BEFORE_ENTRY(VALEUR) From SUBCTRLEG
 If mkstat=2
  [M]STRCAE(INDIC) = VALEUR
  Affzo STRCAE(INDIC) : mkstat = 2
 Endif
Endif
Gosub _AFF
End

