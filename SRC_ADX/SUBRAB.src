#<AdxTL>@(#)1.0.0.0 $Revision$
#################################################################################
#LS Saisie des paramètres et affichage écritures du rapprochement bancaire
# Mai 1998
#
# Issue X3-63558 - 2017-11-13 by BEFOU : Bank statement reconciliation
#                                    - No message when we don't display all statement lines
#
#################################################################################

Local Char PARAM(10)(1..2), VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"FRAPBAN","SUBRAB","DRAPBAN",4,"") From GTRAITE
End

######################################################################
## Action du programme principal
######################################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "SORTIE"      : Gosub SORTIE
 When "AB2_NBLIG"   : Gosub AV_B2_NBLIG
 When "BB2_NBLIG"   : Gosub AP_B2_NBLIG
 When "EXEC"
  If !GSERVEUR & GTRACE<>"" : Call FERME_TRACE From LECFIC : TRA = 1 : FIN = 1 : Endif
 When Default
  Case BOITE
   When "DRAPBAN"   : Gosub PARAM
   When Default     : Gosub BOITE
  Endcase
Endcase
Return

######################################################################
## Actions de la fenêtre critères
######################################################################
$PARAM
Case ACTION
 When "DEBUT"
  Affzo
  GOK = 1
 When "END"
  FIN = 1
  GOK = 0   : # Pour s'arrêter
Endcase
Return

######################################################################
## Actions de la fenêtre principale
######################################################################
$BOITE
Case ACTION
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "AP_CHOIX"    : Gosub AP_CHOIX
 When "ENR"         : Gosub ENREGISTRE
 When "END"         : Gosub FIN
 When "ABA"         : Gosub ABANDON
 When "BOUTON"      : Gosub BOUTON
 When "MEN"         : Gosub MENU_BOUTON
Endcase
Return

##############################################
## Traitement
##############################################

$INIT
If clalev([F:RBK])=0  : Local File RELBANK    [RBK]  : Endif
If clalev([F:BAN])=0  : Local File BANK       [BAN]  : Endif
If clalev([F:BAL])=0  : Local File BALANCE    [BAL]  : Endif
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:RBKF])=0 : Local File RELBANK    [RBKF] : Endif
If clalev([F:ADI])=0  : Local File ATABDIV    [ADI]  : Endif
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE]  : Endif
If clalev([F:DAE])=0  : Local File GACCENTRYD [DAE]  : Endif
If clalev([F:ACV])=0  : Local File ACTIV      [ACV]  : Endif
If clalev([F:PAN])=0  : Local File PAYACCNUM  [PAN]  : Endif

# GRNA 18/07/2011
Gosub OUVRE_CHN From CHKLIB

Local Char    CHAINE(30) , SYMBCHK(20)
Local Integer OK
Local Mask RAPBAN0 [RB0], RAPBAN1 [SAI1]
Return

$CONTROLE
If GOK=0 : FIN=1 : Return : Endif
SYMBCHK ="AUTCHK"+"\"+[M]BAN
Lock =SYMBCHK
If fstat
 GERR = 1 : GMESSAGE = mess(23,120,1) : #Compte en cours de pointage
 SAI = 1
 Return
Endif
GREPORT1 = "RAPPROCHK"
GREPORT2 = "RAPPRODBL"
Return

$SORTIE
Gosub DEVERROU
Return

##############################################
## Fenêtre
##############################################
$DEBUT
Local Libelle RAPPCE, RAPPREC, CTRCIB, RAPDBL, RAPMT, RAPMTOPT, KIAOK
Local Char    VERTYP(GLONGTE), VERNUM(GLONVCR), LPTG2(5), PNBJR(4), PBKOCC(2), LPTG2(5), AUXCHK(5)
Local Integer OKVAL, MAXLIG, NOL, COK, I, J, APOINTER, RECHOK, STAT
Local Decimal MTREL, MTECR
Local Integer PBLOCK
Local Integer CALL_PT : Raz CALL_PT
If dim(GNBENTREE)>0 & GNBENTREE>0 & find("SUBRAB",GENTSTD(1..GNBENTREE))
 CALL_PT=1
Endif

Local Mask RAPBAN2 [RB2] : # Proposition automatique
Local Mask RAPBAN3 [RB3] : # Criteres de tri
Local Mask RAPBAN4 [RB4] : # Fenêtre de recherche

Default Mask [SAI1]
Raz [M]
KIAOK = (dim([M]BANDAT)>0)
MAXLIG = dim([M]CHK)
GOK = 1
Call TEMPON("R") From GESECRAN
Gosub CALC_SOLDE
nolign = 0
Gosub CHARGE_RBK
If GOK : Gosub CHARGE_ECR : Endif
If FIN = 1 : Call TEMPOFF From GESECRAN : Return : Endif
[M]NBLIG = nolign
If sum([M:RB3]ORDRE(0..dim([M:RB3]ORDRE)-1))=0
 Call LECMEMO("STD","[M:RB3]","tri") From GMEMO
Endif
Gosub TRI
Call TEMPOFF From GESECRAN
Grizo 5
Affzo
If [M]NBLIG = 0
 GERR = 2 : GMESSAGE = mess(20,124,1) : #Tableau vide
Endif
Return

$SETBOUT
Raz ETABOU
ETABOU(GBFIN) = 1
If [M]NBLIG=0 : [L]OK=0 : Return : Endif
Call VIREBOUT(CHMEN,"POUS") From GOBJET
If find(2,[M:SAI1]CHX(0..[M:SAI1]NBLIG-1))
 REP = "M"
 CHMEN += "P"         : # Degrise pointage si sélection/Grise pointage si pas de sélection
 ETABOU(GABAN) = 1    : # Degrise abandon si sélection
Else
 If REP = "M"
  ETABOU(GABAN) = 0   : # Grise Abandon si pas de sélection
 Endif
 REP = ""
 CHMEN += "O"
Endif
# Dégrise Enreg si code pointage ou modif VALDAT ou BANDAT
If sum([M:SAI1]CHK(0..[M:SAI1]NBLIG-1))<>""
 ETABOU(GENRE) = 1
 ETABOU(GEDIT) = 1
Endif
If sum([M:SAI1]CHGDAT(0..[M:SAI1]NBLIG-1))<>0
 ETABOU(GABAN) = 1
 ETABOU(GENRE) = 1
Endif
CHMEN += "US"
Gosub SET_BOUT_SPE From GSAISIE
Return

$FIN
Trbegin [HAE]
Call DELOCK("HAE") From GLOCK
Commit
# Close the mask to charge the STD memo each time
Close Local Mask [RB3]
Return

$ABANDON
If sum([M]CHX(0..[M]NBLIG-1))>[M]NBLIG
 For I=0 To [M:SAI1]NBLIG-1
  If [M:SAI1]CHX(I)=2        : # Abandon de la sélection en cours, pas du pointage
   [M:SAI1]CHX(I) = 1
   Affzo [M:SAI1]CHX(I)
  Endif
 Next I
 [M:SAI1]CHKBLC = 0
 Affzo [M:SAI1]CHKBLC
Else
 Effzo 15
 GOK = 1
 Call TEMPON("R") From GESECRAN
 Gosub CALC_SOLDE
 nolign = 0
 Gosub CHARGE_RBK
 If GOK : Gosub CHARGE_ECR : Endif
 If FIN = 1 : Call TEMPOFF From GESECRAN : Return : Endif
 [M:SAI1]NBLIG = nolign
 Gosub TRI
 Call TEMPOFF From GESECRAN
 Affzo
Endif
Return

$AP_CHOIX
If find(REPONSE,GSTAESC,GSTAEND)
 If !pat(sum([M]CHK(0..[M]NBLIG-1)),"") | sum([M]CHGDAT(0..[M]NBLIG-1))<>0
  REP = "M"
 Endif
Endif
Return

$ENREGISTRE
Call TEMPON("V") From GESECRAN
Call DEBTRANS From GLOCK
Gosub TR1
Gosub RELIT
Call TEMPOFF From GESECRAN
OK = 1
Return

$RELIT
Effzo [M]
Gosub CALC_SOLDE
nolign = 0
Gosub CHARGE_RBK
If GOK : Gosub CHARGE_ECR : Endif
If FIN = 1 : Call TEMPOFF From GESECRAN : Return : Endif
[M]NBLIG = nolign
Gosub TRI
Grizo 5
Affzo
If [M]NBLIG = 0
 GERR = 2 : GMESSAGE = mess(20,124,1) : #Tableau vide
Endif
Return

$BOUTON
Case BOUT
 When "P" : Gosub POINT
 When "O" : If RECHOK=2 : Gosub AUTO  : Endif
 When "U" : If RECHOK=2 : Gosub TRI   : Endif
Endcase
Return

$MENU_BOUTON
Case BOUT
 When "S" : If RECHOK=2 : Gosub RECHERCHE : Else : SUIZON = "NBLIG("+num$(nolign-1)+")" : Endif
Endcase
Return

#####################################
# BOUTON TRI
#####################################
$TRI
Local Char    CRIT1(20), CRIT2(20), CRIT3(20), CRIT4(20), CRIT5(20)
Default Mask [SAI1]
For J=1 To 5
 I = find(J,[M:RB3]ORDRE(0..[M:RB3]NBLIG-1))
 If I=1 & [M:RB3]TRI(I-1)=1 : Assign "CRIT"+num$(J) With "AMTBNQ([S]INDICE)"  : Endif
 If I=1 & [M:RB3]TRI(I-1)=2 : Assign "CRIT"+num$(J) With "AMTBNQT([S]INDICE)" : Endif
 If I=2 & [M:RB3]TRI(I-1)=1 : Assign "CRIT"+num$(J) With "ACCDAT([S]INDICE)"  : Endif
 If I=2 & [M:RB3]TRI(I-1)=2 : Assign "CRIT"+num$(J) With "ACCDATT([S]INDICE)" : Endif
 If I=3 & [M:RB3]TRI(I-1)=1 : Assign "CRIT"+num$(J) With "BANCIB([S]INDICE)"  : Endif
 If I=3 & [M:RB3]TRI(I-1)=2 : Assign "CRIT"+num$(J) With "BANCIBT([S]INDICE)" : Endif
 If I=4 & [M:RB3]TRI(I-1)=1 : Assign "CRIT"+num$(J) With "REFC([S]INDICE)"    : Endif
 If I=4 & [M:RB3]TRI(I-1)=2 : Assign "CRIT"+num$(J) With "REFCT([S]INDICE)"   : Endif
 If I=5 & [M:RB3]TRI(I-1)=1 : Assign "CRIT"+num$(J) With "DES([S]INDICE)"     : Endif
 If I=5 & [M:RB3]TRI(I-1)=2 : Assign "CRIT"+num$(J) With "DEST([S]INDICE)"    : Endif
Next J

If CRIT1="" & CRIT2="" & CRIT3="" & CRIT4="" & CRIT5="" : Return : Endif
If CRIT1="" : CRIT1 = "1=1" : Endif
If CRIT2="" : CRIT2 = "1=1" : Endif
If CRIT3="" : CRIT3 = "1=1" : Endif
If CRIT4="" : CRIT4 = "1=1" : Endif
If CRIT5="" : CRIT5 = "1=1" : Endif

Sorta NBLIG NBLIG Order By evalue(CRIT1),evalue(CRIT2),evalue(CRIT3),evalue(CRIT4),evalue(CRIT5)
Affzo 15

Return

#######################################
# BOUTON RECHERCHE
#######################################
$RECHERCHE
Local Integer NOL,NOLG,SAVNOL,TROUVE,OK
Gosub RECH
If nolign=0 : nolign=SAVNOL : Endif
SUIZON = "NBLIG("+num$(nolign-1)+")"
Return

$RECH
SAVNOL = nolign
NOL = nolign
NOLG = nolign
TROUVE = 0
nolign = 0
Default Mask [SAI1]
If [M:RB4]MTRECH <> 0
 Repeat
  NOLG += nolign
  nolign = find([M:RB4]MTRECH,[M:SAI1]AMTBNQ(NOLG..[M:SAI1]NBLIG-1))
  If nolign<>0 : Call TEST_DAT(nolign+NOLG-1,TROUVE) : Endif
 Until nolign=0 or TROUVE
 If TROUVE
  nolign += NOLG
 Else
  nolign =0
  NOLG = 0
  Repeat
   NOLG += nolign
   nolign = find([M:RB4]MTRECH,[M:SAI1]AMTBNQ(NOLG..NOL-1))
   If nolign<>0 : Call TEST_DAT(nolign+NOLG,TROUVE) : Endif
  Until nolign=0 or TROUVE
  If nolign=0 : nolign = NOL : Else : nolign +=NOLG : Endif
 Endif
Endif
If [M:RB4]BANCIB <> ""
 Repeat
  NOLG += nolign
  nolign = find([M:RB4]BANCIB,[M:SAI1]BANCIB(NOLG..[M:SAI1]NBLIG-1))
  If nolign<>0 : Call TEST_DAT(nolign+NOLG,TROUVE) : Endif
 Until nolign=0 or TROUVE
 If TROUVE
  nolign +=NOLG
 Else
  nolign =0
  NOLG = 0
  Repeat
   NOLG += nolign
   nolign = find([M:RB4]BANCIB,[M:SAI1]BANCIB(NOLG..NOL-1))
   If nolign<>0 : Call TEST_DAT(nolign+NOLG,TROUVE) : Endif
  Until nolign=0 or TROUVE
  If nolign=0 : nolign = NOL : Else : nolign +=NOLG : Endif
 Endif
Endif
If [M:RB4]REFC <> ""
 Repeat
  NOLG += nolign
  nolign = find([M:RB4]REFC,[M:SAI1]REFC(NOLG..[M:SAI1]NBLIG-1))
  If nolign<>0 : Call TEST_DAT(nolign+NOLG,TROUVE) : Endif
 Until nolign=0 or TROUVE
 If TROUVE
  nolign +=NOLG
 Else
  nolign =0
  NOLG = 0
  Repeat
   NOLG += nolign
   nolign = find([M:RB4]REFC,[M:SAI1]REFC(NOLG..NOL-1))
   If nolign<>0 : Call TEST_DAT(nolign+NOLG,TROUVE) : Endif
  Until nolign=0 or TROUVE
  If nolign=0 : nolign = NOL : Else : nolign +=NOLG : Endif
 Endif
Endif
Return

Subprog TEST_DAT(NOL,TROUVE)
Value Integer NOL
Variable Integer TROUVE
If ([M:RB4]DATDEB<>[0/0/0] & [M:SAI1]ACCDAT(NOL-1)>=[M:RB4]DATDEB) | [M:RB4]DATDEB=[0/0/0]
 TROUVE = 1
Endif
If ([M:RB4]DATFIN<>[0/0/0] & [M:SAI1]ACCDAT(NOL-1)<=[M:RB4]DATFIN & TROUVE = 1) |
&  ([M:RB4]DATFIN=[0/0/0] & TROUVE=1)
 TROUVE = 1
Else
 TROUVE = 0
Endif
End

########################################
# ETIQUETTES + MENUS BOUTON DROIT SOURIS
########################################
Subprog D_SNSBLB2(VALEUR)
Variable Char    VALEUR()
If [M]SNSBLB=1
 VALEUR = left$(mess(1,610,1),1) : # D
Else
 VALEUR = left$(mess(2,610,1),1) : # C
Endif
End

Subprog D_SNSBLC2(VALEUR)
Variable Char    VALEUR()
If [M]SNSBLC=1
 VALEUR = left$(mess(1,610,1),1) : # D
Else
 VALEUR = left$(mess(2,610,1),1) : # C
Endif
End

Subprog AV_CHX(VALEUR)
Variable Integer    VALEUR()
Gosub COULEUR
End

$COULEUR
If [M]RBKNUM(nolign-1)<>"" & ([M]CHK(nolign-1) = "" | [M]CHK(nolign-1) >"_") #Rouge
 Chgstl [M]NBLIG(nolign-1) With "BACKRED"
Else
 Chgstl [M]NBLIG(nolign-1) With ""
Endif
If [M]CHK(nolign-1)<>"" & [M]CHK(nolign-1)<"_"
 Chgstl [M]NBLIG(nolign-1) With "MTC3"
Endif
Return

Subprog IB_NBLIG
If nolign>0 & [M]RBKNUM(nolign-1)<>""
 GBOUT2 = ""
Else
 GBOUT2 = mess(25,110,1)  : # Pièce
Endif
End

$AV_B2_NBLIG
GCONSULT = 1
Local Integer K
K = instr(1,[M]REFB(nolign-1)," ")
GFLAG   = ""
GSCHEMA = ""
GBIDC1  = left$([M]REFB(nolign-1),K-1)
GBIDC2  = vireblc(mid$([M]REFB(nolign-1),K+1,GLONVCR),2)
Return

$AP_B2_NBLIG
GCONSULT = 0
Return

$ACT
Case ACT
 When "BOUTON"          : Gosub BOUTON
Endcase
Return


#############################################
## Sous-programmes
#############################################

#############################################
#    CALC_SOLDE
# we calculate the number of lines allocated to statements:

$CALC_SOLDE
[M:SAI1]BAN    = [M:RB0]BAN
[M:SAI1]BANACC = [M:RB0]BANACC
[M:SAI1]BANBPR = [M:RB0]BANBPR
Read [BAN]BAN0 = [M]BAN
If !fstat
 [M:SAI1]LPTG   = [F:BAN]CHKCOD
 [M:SAI1]CUR    = [F:BAN]CUR
 [M:SAI1]CPY    = [F:BAN]CPY
 [M:SAI1]FCY    = [F:BAN]FCY
Endif
Call SETCUR(1,[F:BAN]CPY,[M]CURLED) From CPTDIV
Call SOLDEBAL([M]CUR,[M]CPY,[M]FCY,[M]BANACC,[M]BANBPR,[M]SNSBLC,[M:RB0]DATACE,[M]BLC) From SUBCHK
Call PARAM([M]CPY,"SNSBNQ",[M]SNSBNQ) From ADOVAL
Call PARAM([M]CPY,"PRCRBKOCC",PBKOCC) From ADOVAL
Read [ACV]CODACT="RBK"
[M]PRCRBKOCC = (val(PBKOCC)/100)*[F:ACV]DIME
Call PARAM([M]CPY,"MAXNBRDAY",PNBJR) From ADOVAL
[M]NBJR = val(PNBJR)
Call SOLDEBANKD([M]BAN,[M:RB0]DATRBK,[M]SNSBNQ,[M]BLB,[M]SNSBLB) From SUBRAB # 5 param
Return
#############################################
# SOLDEBANK
Subprog SOLDEBANK(CBAN,SNSBNQ,BLB,SNSBLB) #4 Param
Value Char CBAN(), SNSBNQ()
Variable Integer SNSBLB
Variable Decimal BLB
Local File RELBANK [RBK3]
#Recherche du solde bancaire
Filter [RBK3] Where BAN=CBAN & RECTYP=3 Order By Key CLE=OPEDAT
Read [RBK3]CLE Last
If fstat<=2
 BLB    = [F:RBK3]AMTCUR
 If ([F:RBK3]SNS = 1 & val(SNSBNQ) = 1)  : SNSBLB = 1 : Endif
 If ([F:RBK3]SNS = -1 & val(SNSBNQ) = 1) : SNSBLB = 2 : Endif
 If ([F:RBK3]SNS = 1 & val(SNSBNQ) = 2)  : SNSBLB = 2 : Endif
 If ([F:RBK3]SNS = -1 & val(SNSBNQ) = 2) : SNSBLB = 1 : Endif
Else
 BLB    = 0
 SNSBLB = 1
Endif
Filter [RBK3]
End

Subprog SOLDEBANKD(CBAN,RDAT,SNSBNQ,BLB,SNSBLB) #5 Param
Value Char CBAN(), SNSBNQ()
Value Date RDAT
Variable Integer SNSBLB
Variable Decimal BLB
Local File RELBANK [RBK3]
Local File RELBANK [RBK4]
Local Integer SENS
#Recherche du solde bancaire
# Recherche du relevé bancaire
Filter [RBK3] Where BAN=CBAN & RECTYP=1 and OPEDAT<=[L]RDAT Order By Key CLE=OPEDAT
Read [RBK3]CLE Last
If !fstat
 # Initialisation du solde par l'ancien solde du relevé
 Read [RBK4] =CBAN;[F:RBK3]RBKNUM;1;1
 If !fstat
  BLB = [F:RBK4]AMTCUR*[F:RBK4]SNS
  # Prise en compte des lignes du relevés
  Filter [RBK3] Where BAN=CBAN & RBKNUM=[F:RBK4]RBKNUM & RECTYP=2 & OPEDAT<=[L]RDAT
  For [RBK3]
   BLB += [F:RBK3]AMTCUR*[F:RBK3]SNS
  Next
  If (BLB>=0 & val(SNSBNQ) = 1) : SNSBLB = 1 : Endif
  If (BLB< 0 & val(SNSBNQ) = 1) : SNSBLB = 2 : Endif
  If (BLB>=0 & val(SNSBNQ) = 2) : SNSBLB = 2 : Endif
  If (BLB< 0 & val(SNSBNQ) = 2) : SNSBLB = 1 : Endif
  BLB = abs(BLB)
 Else
  BLB = 0 : SNSBLB = 1
 Endif
Else
 BLB = 0 : SNSBLB = 1
Endif
Filter [RBK3]
End

$CHARGE_RBK
For [RBK]RBK1 Where BAN=[M]BAN & RECTYP=2 & OPEDAT<=[M:RB0]DATRBK & CHK=""
# Issue X3-63558 - 2017-11-21 by BEFOU : previously on the end of the function
  If nolign >= MAXLIG  # Issue X3-63558 number of lines strictly superior than the activity code RBK size
    GERR=1 : GOK=0 : GMESSAGE = mess(26,100,1) #Tableau plein
    Break
  Else
    If nolign >= [M]PRCRBKOCC  #Taux de remplissage maximum des lignes banques atteint
      # Issue X3-63558 - 2017-11-13 by BEFOU : Adding a message before the PRCRBKOCC break
      GERR=1 : GMESSAGE = mess(00023,00015,1) - mess(26,100,1)
      Break
    Endif
  Endif
  [M]CHX(nolign) = 1
  Raz [M]ACCNUM(nolign), [M]AMTLED(nolign)
  [M]RBKNUM(nolign) = [F:RBK]RBKNUM
  [M]RBKLIN(nolign) = [F:RBK]RBKLIN
  [M]ACCDAT(nolign) = [F:RBK]OPEDAT
  [M]ACCDATT(nolign)= -nday([F:RBK]OPEDAT)
  [M]BANCIB(nolign) = [F:RBK]BANCIB
  [M]BANCIBT(nolign)= -val([F:RBK]BANCIB)
  [M]DES(nolign)    = [F:RBK]DES
  I = 1
  While I<=len([F:RBK]DES)
    CAR = mid$([F:RBK]DES,I,1)
      If 256-ascii(CAR)>0 : [M]DEST(nolign) += chr$(256-ascii(CAR)) : Endif
      I +=1
  Wend
  If len([F:RBK]DES)=0
    [M]DEST(nolign) = chr$(256-1)
  Endif
  If ([F:RBK]SNS=1 & val([M]SNSBNQ)=1) | ([F:RBK]SNS=-1 & val([M]SNSBNQ)=2)
    [M]SNS(nolign)   = 1
    [M]SNS2(nolign)  = left$(mess(1,610,1),1) : # D
  Endif
  If ([F:RBK]SNS=-1 & val([M]SNSBNQ)=1) | ([F:RBK]SNS=1 & val([M]SNSBNQ)=2)
    [M]SNS(nolign)   = 2
    [M]SNS2(nolign)  = left$(mess(2,610,1),1) : # C
  Endif

  If [F:RBK]CUR=[M]CUR
    [M]AMTBNQ(nolign) = [F:RBK]AMTCUR
    Raz [M]AMTCUR(nolign), BANCUR(nolign)
  Else
    [M]BANCUR(nolign) = [F:RBK]CUR
    [M]AMTCUR(nolign) = [F:RBK]AMTCUR
    Call CONVERT([M]BANCUR(nolign),[M]CUR,[M]CURLED,1,[M]ACCDAT(nolign),[M]AMTCUR(nolign),
&              [M]AMTBNQ(nolign),STAT) From TRTDEV
  Endif

  [M]AMTBNQT(nolign)= -[M]AMTBNQ(nolign) :#Pour tri descendant
  [M]REFC(nolign)   = [F:RBK]ENTNUM
  If [M]REFC(nolign) = "0" : [M]REFC(nolign) = "" : Endif
  I = 1
  While I<=len([M]REFC(nolign))
    CAR = mid$([M]REFC(nolign),I,1)
    If 256-ascii(CAR)>0 : [M]REFCT(nolign) += chr$(256-ascii(CAR)) : Endif
    I +=1
  Wend
  If len([M]REFC(nolign))=0
    [M]REFCT(nolign) = chr$(256-1)
  Endif
  [M]REFB(nolign)   = [F:RBK]REF
  [M]VALDAT(nolign) = [F:RBK]VALDAT
  [M]INDCOM(nolign) = [F:RBK]INDCOM
  [M]RENREJ(nolign) = [F:RBK]RENREJ
  [M]FRMNUM(nolign) = ""
  nolign +=1
Next
Return

$CHARGE_ECR
PBLOCK = 0
For [DAE]DAE1 Where LEDTYP = GTYPGEN & CPY = [M]CPY & ACC = [M]BANACC &
&                   BPR = [M]BANBPR & ACCDAT <= [M:RB0]DATACE & CHK = ""
  If ([F:DAE]BPR = "" | [F:DAE]BPR = [M]BANBPR) & ([M]FCY = "" | [M]FCY = [F:DAE]FCYLIN)
  # Issue X3-63558 - 2017-11-21 by BEFOU : previously on the end of the function
    If nolign >= MAXLIG
      GERR = 1 : GOK = 0 : GMESSAGE = mess(26,100,1) #Tableau plein
      Break
    Endif
    OK = 1
    Read [HAE]HAE0 = [F:DAE]TYP; [F:DAE]NUM
    If fstat : OK = 0 : Endif
    If [F:HAE]CAT <> 1 | [F:HAE]FLGREP = 2 : OK = 0 : Endif
    # Ne pas afficher les pièces d'écart de conversion
    If [F:HAE]REFINT = "CNVEC" : OK = 0 : Endif
    #Issue 74113 – 2018-01-31 by MADOR - Adjustments driven from the FIFRC automatic journal
    If left$([F:HAE]REFINT, 4) = "FIFO" : OK = 0 : Endif
    #Issue end
    If [F:DAE]CUR <> [M]CUR & [F:DAE]CUR <> [F:BAN]OLDCUR : OK = 0 : Endif
    Gosub VERROU
  Else
    OK = 0
  Endif
  If OK
    [M]CHX(nolign) = 1
    Raz [M]RBKLIN(nolign),[M]RBKNUM(nolign)
    [M]ACCNUM(nolign)  = [F:DAE]ACCNUM
    [M]ACCDAT(nolign)  = [F:HAE]ACCDAT
    [M]ACCDATT(nolign) = -nday([F:HAE]ACCDAT)
    [M]BANCIB(nolign)  = [F:HAE]BANCIB
    [M]BANCIBT(nolign) = -val([F:HAE]BANCIB)
    [M]DES(nolign)     = [F:DAE]DES
    I = 1
    While I<=len([F:DAE]DES)
      CAR = mid$([F:DAE]DES,I,1)
      If 256-ascii(CAR)>0 : [M]DEST(nolign) += chr$(256-ascii(CAR)) : Endif
      I +=1
    Wend
    If len([F:DAE]DES)=0
      [M]DEST(nolign) = chr$(256-1)
    Endif
    If [F:DAE]SNS=1
      [M]SNS(nolign)    = 1
      [M]SNS2(nolign)   = left$(mess(1,610,1),1) : # D
    Endif
    If [F:DAE]SNS=-1
      [M]SNS(nolign)    = 2
      [M]SNS2(nolign)   = left$(mess(2,610,1),1) : # C
    Endif
  # devise de la piece<>devise banque. Ce cas ne doit pas se produire
  # sauf dans le cas où le compte de banque est passé à l'Euro
    Case [F:DAE]CUR
      When [M]CUR         :
        [M]AMTBNQ(nolign) = [F:DAE]AMTCUR
      When [F:BAN]OLDCUR  :
        [M]BANCUR(nolign) = [F:DAE]CUR
        [M]AMTCUR(nolign) = [F:DAE]AMTCUR
        Call CONVERT([M]BANCUR(nolign),[M]CUR,[M]CURLED,1,[M]ACCDAT(nolign),[M]AMTCUR(nolign),
&                [M]AMTBNQ(nolign),STAT) From TRTDEV
      When Default        :
        [M]AMTBNQ(nolign) = 0
    Endcase

    [M]AMTBNQT(nolign) = -[M]AMTBNQ(nolign)
    [M]REFC(nolign)    = [F:HAE]REF
    I = 1
    While I<=len([F:HAE]REF)
      CAR = mid$([F:HAE]REF,I,1)
      If 256-ascii(CAR)>0 : [M]REFCT(nolign) += chr$(256-ascii(CAR)) : Endif
      I +=1
    Wend
    If len([F:HAE]REF)=0
      [M]REFCT(nolign) = chr$(256-1)
    Endif
    [M]REFB(nolign)    = [F:HAE]TYP+" "+[F:DAE]NUM
    If [F:DAE]AMTFLG <> 0
      [M]AMTLED(nolign) = [F:DAE]AMTLED1
    Else
      [M]AMTLED(nolign) = [F:DAE]AMTLED
    Endif
    [M]VALDAT(nolign)  = [F:HAE]VALDAT
    If KIAOK : [M]BANDAT(nolign) = [F:HAE]BANDAT : Endif
    [M]INDCOM(nolign)  = 0
    [M]RENREJ(nolign)  = ""
    Filter [PAN] Where ACCNUM=[F:DAE]ACCNUM & CPTBAN=2 & TYPNUM=1
    Read [PAN]PAN0 First
    If !fstat
      [M]FRMNUM(nolign) = [F:PAN]NUM
    Else
      [M]FRMNUM(nolign) = ""
    Endif
    nolign +=1
  Endif
Next
Return

$VERROU
#Pièce en cours de modif sur autre poste
If [F:DAE]TYP=VERTYP & [F:DAE]NUM=VERNUM
 OK = 0
 Return
Endif
Lock = "HAE"+[F:DAE]NUM+"\"+[F:DAE]TYP
If fstat
# En web on ne peut pas faire de message dans la boucle
# Call ERREUR(mess(11,105,1)-[F:DAE]NUM-[F:DAE]TYP-":"-mess(60,100,1)) From GESECRAN
 #Numéro de pièce xxxxxxxx : Enregistrement verrouillé
 If PBLOCK=0
  OK=2
  Call AVERTIR(mess(139,121,1),OK) From GESECRAN
  # Des échéances sont en cours de visualisation et n'ont pu être chargées
  If OK=2 : # OK poursuivre
   PBLOCK = 1
  Else # Annuler
   PBLOCK = 2
   FIN = 1
   Call OUVRE_TRACE(mess(15,120,1)) From LECFIC
   Call ECR_TRACE(mess(11,105,1)-[F:DAE]NUM-[F:DAE]TYP-":"-mess(60,100,1),1) From GESECRAN
  Endif
 Elsif PBLOCK = 2
  Call ECR_TRACE(mess(11,105,1)-[F:DAE]NUM-[F:DAE]TYP-":"-mess(60,100,1),1) From GESECRAN
 Endif
 OK = 0
 VERTYP = [F:DAE]TYP
 VERNUM = [F:DAE]NUM
Endif
Return

$DEVERROU
Unlock =SYMBCHK
Return

$TR1
GOK=1
Trbegin [DAE], [HAE], [RBK], [BAN]
 Readlock [BAN]BAN0=[M]BAN
 If fstat=1
  GOK = -1 : GLOCK="$BANK"-[M]BAN : Goto ROLL_TR1
 Elsif fstat
  GOK = 0 : Call RSTA("BAN",[M]BAN) From GLOCK : Goto AB_TR1
 Endif
 LPTG2 = [F:BAN]CHKCOD
 For I=0 To [M]NBLIG-1
  If [M]CHK(I)<>"" & [M]CHK(I)<"_" : #Ligne pointée et non marquée doublon
   Call CHK_LETTRE(LPTG2) From SUBRAB
   CHKAUX = [M]CHK(I)
   For J=I To [M]NBLIG-1
    If [M]CHK(J)=CHKAUX
     Case [M]ACCNUM(J)
      When 0
       Readlock [RBK]RBK0=[M]BAN;[M]RBKNUM(J);2;[M]RBKLIN(J)
       GCLE = [M]BAN-num$([M]RBKNUM(J))-num$(2)-num$([M]RBKLIN(J))
       If fstat=1
         GOK = -1 : GLOCK="$RELBANK"-GCLE : Break 2
       Elsif fstat
        GOK = 0 : Call RSTA("RBK",GCLE) From GLOCK : Break 2
       Else
        [F:RBK]CHK = LPTG2
        [F:RBK]DATCHK = date$
        [F:RBK]VALDAT = [M]VALDAT(J)
        Gosub PE_BEFWRIRBK
        Rewrite [RBK]
        If fstat
         GOK = 0 : Call FSTA("RBK") From GLOCK : Break 2
        Endif
       Endif
      When Default
       GCLE = num$([M]ACCNUM(J))
       Readlock [DAE]DAE2=[M]ACCNUM(J)
       If fstat=1
        GOK = -1 : GLOCK="$GACCENTRYD"-GCLE : Break 2
       Elsif fstat
        GOK = 0 : Call RSTA("DAE",GCLE) From GLOCK : Break 2
       Else
        [F:DAE]CHK    = LPTG2
        [F:DAE]CHKDAT = date$
        Gosub PE_BEFWRIDAE
        Rewrite [DAE]
        If fstat
          GOK = 0 : Call FSTA("DAE") From GLOCK : Break 2
        Endif
        If [M]CHGDAT(J)=1
         GCLE = [F:DAE]TYP-[F:DAE]NUM
         Readlock [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
         If fstat=1
          GOK = -1 : GLOCK = "$GACCENTRY"-GCLE : Break 2
         Elsif fstat
          GOK = 0 : Call RSTA("HAE",GCLE) From GLOCK
         Elsif !fstat
          [F:HAE]VALDAT = [M]VALDAT(J)
          If KIAOK : [F:HAE]BANDAT = [M]BANDAT(J) : Endif
          Rewrite [HAE]
          If fstat
            GOK = 0 : Call FSTA("HAE") From GLOCK : Break 2
          Endif
         Endif
        Endif
        # GRNA 18/07/2011
        Gosub CLEAR_CHN From CHKLIB
        If GOK<1 : Break 2 : Endif
       Endif
     Endcase
     [M]CHK(J)=""
     [M]CHGDAT(J)=0
    Endif
   Next J
  Elsif [M]CHGDAT(I)=1  : # VALDAT et/ou BANDAT a été modifiée
   Case [M]ACCNUM(I)
    When 0
     GCLE = [M]BAN-num$([M]RBKNUM(I))-num$(2)-num$([M]RBKLIN(I))
     Readlock [RBK]RBK0=[M]BAN;[M]RBKNUM(I);2;[M]RBKLIN(I)
     If fstat=1
      GOK = -1 : GLOCK="$RELBANK"-GCLE : Break 2
     Elsif fstat
      GOK = 0 : Call RSTA("RBK",GCLE) From GLOCK : Break 2
     Else
      [F:RBK]VALDAT = [M]VALDAT(I)
      Gosub PE_BEFWRIRBK
      Rewrite [RBK]
      If fstat
       GOK = 0 : Call FSTA("RBK") From GLOCK : Break 2
      Endif
     Endif
    When Default
     Read [DAE]DAE2=[M]ACCNUM(I)
     If !fstat
      GCLE = [F:DAE]TYP-[F:DAE]NUM
      Readlock [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
      If fstat=1
       GOK = -1 : GLOCK = "$GACCENTRY"-GCLE : Break 2
      Elsif fstat
       GOK = 0 : Call RSTA("HAE",GCLE) From GLOCK
      Elsif !fstat
       [F:HAE]VALDAT = [M]VALDAT(I)
       If KIAOK : [F:HAE]BANDAT = [M]BANDAT(I) : Endif
       Rewrite [HAE]
       If fstat
        GOK = 0 : Call FSTA("HAE") From GLOCK : Break 2
       Endif
       # GRNA 18/07/2011
       Gosub CLEAR_CHN From CHKLIB
       If GOK<1 : Break 2 : Endif
      Endif
     Endif
   Endcase
   [M]CHGDAT(I)=0
  Endif
 Next I
 [M]LPTG = LPTG2
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 [F:BAN]CHKCOD = [M]LPTG
 Rewrite [BAN]
 If fstat
  GOK = 0 : Call FSTA("BAN") From GLOCK : Goto AB_TR1
 Endif
Commit
OKVAL = 2
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

$AB_TR1
Rollback
Return

$PE_BEFWRIRBK
If CALL_PT : GPOINT = "BEFWRIRBK" : Gosub ENTREE From EXEFNC : Endif
Return

$PE_BEFWRIDAE
If CALL_PT : GPOINT = "BEFWRIDAE" : Gosub ENTREE From EXEFNC : Endif
Return

###########################
#BOUTON POINTAGE/DEPOINTAGE (* sur une ligne pointée => Dépointe toutes les lignes du même code)
###########################

$POINT
NOL = nolign
Gosub VERIF_PTG
If COK
 LPTG2 = [M:SAI1]LPTG
 Call CHK_LETTRE(LPTG2) From SUBRAB
 [M:SAI1]LPTG = LPTG2
Endif
If COK : [M:SAI1]CHKBLC = 0 : Endif
If COK | APOINTER : Gosub EXEC_PTG : Endif
SUIZON = "CHX("+num$(NOL-1)+")"
Return

$VERIF_PTG
Raz MTREL, MTECR
For I=0 To [M:SAI1]NBLIG - 1
 If [M:SAI1]CHX(I)=2 & [M:SAI1]CHK(I)<>"" & [M:SAI1]CHK(I)<"_" : APOINTER = 1 : Endif
 If [M:SAI1]CHX(I)=2 & ([M:SAI1]CHK(I)="" | [M:SAI1]CHK(I)>"_")
  If [M:SAI1]ACCNUM(I)=0
   If ([M:SAI1]SNS(I)=1 & val([M:SAI1]SNSBNQ)=1) | ([M:SAI1]SNS(I)=2 & val([M:SAI1]SNSBNQ)=2)
    MTREL += [M:SAI1]AMTBNQ(I)
   Endif
   If ([M:SAI1]SNS(I)=1 & val([M:SAI1]SNSBNQ)=2) | ([M:SAI1]SNS(I)=2 & val([M:SAI1]SNSBNQ)=1)
    MTREL -= [M:SAI1]AMTBNQ(I)
   Endif
   COK = 1
  Else
   If [M:SAI1]SNS(I)=1 : MTECR += [M:SAI1]AMTBNQ(I)
   Else  MTECR -= [M:SAI1]AMTBNQ(I)
   Endif
   COK = 1
  Endif
 Endif
Next I
If MTECR <> MTREL
 GERR = 1 : GMESSAGE = mess(20,120,1)+"\"+mess(21,120,1)-left$(mess(1+(MTREL<0),610,1),1)+" "+
&  format$("N3:11.2",abs(MTREL))+"\"+mess(22,120,1)-
&  left$(mess(1+(MTECR<0),610,1),1)+format$("N3:11.2",abs(MTECR))
 # Rapprochement incorrect Total sélection relevé =   Total sélection écriture =
 COK = 0
Endif
Return

Subprog CHK_LETTRE(LETTRE)
Variable Char LETTRE()
Local Integer LG, LG_MAX, I, J
Local Char A(3), Z(3)
A = "Aa0" : Z = "Zz9"
LG = len(LETTRE)
LG_MAX = type(LETTRE) - 10
If LG=0 : #La zone CHKCOD de BANK est vide
 LETTRE = string$(LG_MAX,left$(A,1))
Else
 Local Char T(LG_MAX)
 Raz T
 For I=1 To LG
  J = ascii(mid$(LETTRE,I,1))
  If J>64 & J<91     : T +="1" : #Majuscule
  Elsif J>96 & J<123 : T +="2" : #Minuscule
  Else                 T +="3" : #Autre
  Endif
 Next I
 For I=LG To 1 Step -1
  ALPHA = mid$(LETTRE,I,1)
  If ALPHA <>mid$(Z,val(mid$(T,I,1)),1)
   LETTRE = left$(LETTRE,I-1)+chr$(ascii(ALPHA)+1)
   For J=I+1 To LG
    LETTRE += mid$(A,val(mid$(T,J,1)),1)
   Next J
   LG = 0
   Break
  Endif
 Next I
 If LG
  LETTRE = ""
  For J=1 To LG
   LETTRE +=mid$(A,val(mid$(T,J,1)),1)
  Next J
 Endif
Endif
End

$EXEC_PTG
For I=0 To [M:SAI1]NBLIG-1
 If [M:SAI1]CHX(I)=2 & ([M:SAI1]CHK(I)="" | [M:SAI1]CHK(I)>"_") & COK
  [M:SAI1]CHX(I) = 1
  [M:SAI1]CHK(I) = [M:SAI1]LPTG
  Call AFFLIG(I) From SUBRAB
 Elsif [M:SAI1]CHX(I)=2 : #On dépointe une ligne déjà pointée
  AUXCHK = [M:SAI1]CHK(I)
  If AUXCHK<>""
   For J=0 To [M:SAI1]NBLIG-1
    If [M:SAI1]CHK(J)=AUXCHK
     [M:SAI1]CHK(J)=""
     [M:SAI1]CHX(J)=1
     Call AFFLIG(J) From SUBRAB
    Endif
   Next J
  Endif
 Endif
Next I
Return

Subprog AFFLIG(LG)
Value Integer LG
Default Mask [M:SAI1]
Affzo CHX(LG),REFC(LG),ACCDAT(LG),BANCIB(LG),DES(LG),SNS2(LG),AMTBNQ(LG),CHK(LG),
& REFB(LG),AMTLED(LG),VALDAT(LG),INDCOM(LG),RENREJ(LG)
End

#####################################
# BOUTON PROPOSITION
# LPTG1 pointe les doublons
#####################################
$AUTO
Local Integer L, M, SBQ, PHASE4, B
Local Decimal MTR
Local Char R(50)(4), E(50)(2), LPTG1(4)

[L] = [M:RB2]
Default Mask [SAI1]
Call TEMPON("C") From GESECRAN
If [M:RB2]RAPPCE=2 & [M]NBLIG : Gosub PHASE1 : Gosub PHASE4 : Endif
If [M:RB2]RAPDBL=2            : Gosub PHASE2 : Endif
If [M:RB2]RAPMT=2 & [M]NBLIG  : Gosub PHASE3 : Endif
Call TEMPOFF From GESECRAN
Affzo 15
Return

$PHASE1
#Association 1 ligne relevé pour X lignes écritures même si marquage doublon
#Recherche du no remise/no chq dans les écritures(libellé/référence ecr)
#Recherche réf ecriture(refc) dans relevé(nochq/libellé/référence bq:refb)
PHASE4 = 0
For I=0 To [M]NBLIG-1
 If [M]CHK(I)>"_" : [M]CHK(I) = "" : Endif  : #On vire le pointage doublon
Next I
For I=0 To [M]NBLIG-1
 If [M]ACCNUM(I)=0 & [M]CHK(I)=""           : #C'est un relevé
  If val([M]SNSBNQ)=1
   MTR = ([M]AMTBNQ(I)*(([M]SNS(I)=1)-([M]SNS(I)=2)))
  Else
   MTR = ([M]AMTBNQ(I)*(([M]SNS(I)=1)-([M]SNS(I)=2)) *(-1))
  Endif
  If [M:RB2]CTRCIB=2 : Call LECTURE("ADI",[M]BANCIB(I),"306") From CONTOBJ : Endif
  Gosub POSE_PRIORITE
  Gosub EGAL_PRIORITE
  #On cherche une somme de priorité = au montant de la ligne relevé
  If L=0
   MT = 0 : K = 0
   If val([M]SNSBNQ) = 1 : SBQ = [M]SNS(I)
   Elsif [M]SNS(I) = 1 : SBQ = 2
   Elsif [M]SNS(I) = 2 : SBQ = 1
   Endif
   For J=0 To [M]NBLIG-1
    If [M]P(J) & (([M]SNS(J)=SBQ & [M]AMTBNQ(J)>0 & MT+[M]AMTBNQ(J)<=[M]AMTBNQ(I)) |
&   ([M]SNS(J)<>SBQ & [M]AMTBNQ(J)<0 & MT-[M]AMTBNQ(J)<=[M]AMTBNQ(I)))
     MT += abs([M]AMTBNQ(J)) : [M]P(K) = J : K += 1
     If MT = [M]AMTBNQ(I)
      LPTG2 = [M]LPTG
      Call CHK_LETTRE(LPTG2) From SUBRAB
      [M]LPTG = LPTG2 : [M]CHK(I) = LPTG2 : L = 1
      For J=0 To K-1
       [M]CHK([M]P(J)) = LPTG2
      Next J
      Break
     Endif
    Endif
   Next J
  Endif
 Endif
Next I
Return

$POSE_PRIORITE
#On met sur chaque écriture une priorité de 6 à 1
Raz [M]P,L
R(1) = vireblc(toupper(ctrans([M]REFC(I))),4) : #entnum(no chq)
R(2) = vireblc(toupper(ctrans([M]REFB(I))),4) : #référence
R(3) = vireblc(toupper(ctrans([M]DES(I))),4)
R(0) = R(1) : Call RAPPREC(R(0),[M:RB2]RAPPREC) From SUBRAB2
For J = 0 To [M]NBLIG-1
 #Contrôle sur le cib de l'écriture et sur le nb de jours tolérés entre 2 dates
 If ([M:RB2]CTRCIB=1) |
&   ([M:RB2]CTRCIB=2 & [M]BANCIB(I)<>"" & [M]BANCIB(I)=[M]BANCIB(J) &
&   max([M]ACCDAT(I),[M]ACCDAT(J))-min([M]ACCDAT(I),[M]ACCDAT(J))<=[F:ADI]N1) |
&  ([M:RB2]CTRCIB=2 & ([M]BANCIB(J)="" | [M]BANCIB(I)="") &
&  (max([M]ACCDAT(I),[M]ACCDAT(J))-min([M]ACCDAT(I),[M]ACCDAT(J))<=[M]NBJR))
  If [M]ACCNUM(J)<>0 & [M]CHK(J)=""
   E(0) = vireblc(toupper(ctrans([M]REFC(J))),4) : #référence
   E(1) = vireblc(toupper(ctrans([M]DES(J))),4)
   K = 0
   If R(1)<>"" & len(E(0)) >= len(R(1)) & pat(E(0),"*"+R(1)+"*") : K = 6
   Elsif E(0)<>"" & len(R(1))>len(E(0)) & pat(R(1),"*"+E(0)+"*") : K = 5
   Elsif R(2)<>"" & len(E(0))>=len(R(2)) & pat(E(0),"*"+R(2)+"*") : K = 4
   Elsif E(0)<>"" & len(R(2))>len(E(0)) & pat(R(2),"*"+E(0)+"*") : K = 3
   Elsif E(0)<>"" & pat(R(3),"*"+E(0)+"*") : K = 2
   Elsif R(0)<>"" & pat(E(1),"*"+R(0)+"*") : K = 1
   Endif
   If K : [M]P(J) = K : Endif
  Endif
 Endif
Next J
Return

$EGAL_PRIORITE
#Pour chaque priorité on cherche une égalité en montant avec MTR
For J=max([M]P(0..[M]NBLIG-1)) To 1 Step -1
 M = -1
 Repeat
  L = find(J,[M]P(M+1..[M]NBLIG-1))
  If L
   If MTR=[M]AMTBNQ(L+M) * (([M]SNS(L+M)=1)-([M]SNS(L+M)=2))
    LPTG2 = [M]LPTG
    Call CHK_LETTRE(LPTG2) From SUBRAB
    [M]LPTG = LPTG2
    If !PHASE4 : [M]CHK(I) = LPTG2 : Endif
    [M]CHK(L+M) = LPTG2
    Break 2
   Endif
   M +=L
  Endif
 Until L=0
 L = 0
Next J

#On cherche une égalité entre la somme de toutes priorités et MTR
If L=0 & MTR=sigma(0,[M]NBLIG-1,([M]P(indcum)<>0) * [M]AMTBNQ(indcum) *
&           (([M]SNS(indcum)=1)-([M]SNS(indcum)=2)))
 LPTG2 = [M]LPTG
 Call CHK_LETTRE(LPTG2) From SUBRAB
 [M]LPTG = LPTG2
 If !PHASE4 : [M]CHK(I) = LPTG2 : Endif
 L = 1
 For J=0 To [M]NBLIG-1
  If [M]P(J) : [M]CHK(J) = LPTG2 : Endif
 Next J
Endif
Return

$PHASE2
#Marquage doublons
LPTG1=""
For I=0 To [M]NBLIG-1
 If [M]ACCNUM(I)=0 & [M]CHK(I)=""    : #Relevé
  J = I : K = 1 : L = 0
  While K<>0
   K = find([M]AMTBNQ(I),[M]AMTBNQ(J+1..[M]NBLIG-1))
   If K<>0 & [M]SNS(I)=[M]SNS(J+K) & [M]ACCNUM(J+K)=0 & [M]CHK(J+K)=""
    Gosub PHASE2_BIS
   Endif
   J +=K
  Wend
 Elsif [M]ACCNUM(I)<>0 & [M]CHK(I)="" : #Ecriture
  J = I : K = 1 : L = 0
  While K<>0
   K = find([M]AMTBNQ(I),[M]AMTBNQ(J+1..[M]NBLIG-1))
   If K<>0 & [M]SNS(I)=[M]SNS(J+K) & [M]ACCNUM(J+K)<>0 & [M]CHK(J+K)=""
    Gosub PHASE2_BIS
   Endif
   J +=K
  Wend
  J = I : K = 1
  While K<>0
   K = find(-[M]AMTBNQ(I),[M]AMTBNQ(J+1..[M]NBLIG-1))
   If K<>0 & [M]SNS(I)<>[M]SNS(J+K) & [M]ACCNUM(J+K)<>0 & [M]CHK(J+K)=""
    Gosub PHASE2_BIS
   Endif
   J +=K
  Wend
 Endif
Next I
Return

$PHASE2_BIS
If L=0
 L = 1
 Call CHK_LETTRE(LPTG1) From SUBRAB
 [M]CHK(I)   = "_"+LPTG1
Endif
[M]CHK(J+K) = "_"+LPTG1
Return

$PHASE3
#Rapprochement par montant sans critère pièce.On ne rapproche pas les doublons
For I=0 To [M]NBLIG-1
 If [M]ACCNUM(I)=0  :#Relevé
  K = 1 : J = -1
  If val([M]SNSBNQ) = 1 : SBQ = [M]SNS(I)
  Elsif [M]SNS(I) = 1 : SBQ = 2
  Elsif [M]SNS(I) = 2 : SBQ = 1
  Endif
  If [M:RB2]CTRCIB=2 : Call LECTURE("ADI",[M]BANCIB(I),"306") From CONTOBJ : Endif
  While [M]CHK(I)="" & K<>0
   K = find([M]AMTBNQ(I), [M]AMTBNQ(J+1..[M]NBLIG-1))
   If K<>0 & [M]ACCNUM(J+K)<>0 & [M]CHK(J+K)="" & SBQ=[M]SNS(J+K) &
&    (([M:RB2]CTRCIB=1) |
&    ([M:RB2]CTRCIB=2 & [M]BANCIB(I)<>"" & [M]BANCIB(I)=[M]BANCIB(J+K) &
&    max([M]ACCDAT(I),[M]ACCDAT(J+K))-min([M]ACCDAT(I),[M]ACCDAT(J+K))<=[F:ADI]N1) |
&   ([M:RB2]CTRCIB=2 & ([M]BANCIB(J+K)="" | [M]BANCIB(I)="") &
&   (max([M]ACCDAT(I),[M]ACCDAT(J+K))-min([M]ACCDAT(I),[M]ACCDAT(J+K))<=[M]NBJR)))
    LPTG2 = [M]LPTG
    Call CHK_LETTRE(LPTG2) From SUBRAB
    [M]LPTG = LPTG2 : [M]CHK(I) = LPTG2 : [M]CHK(J+K) = LPTG2
   Endif
   J+=K
  Wend
  K = 1 : J = -1
  While [M]CHK(I)="" & K<>0
   K = find(-[M]AMTBNQ(I), [M]AMTBNQ(J+1..[M]NBLIG-1))
   If K<>0 & [M]ACCNUM(J+K)<>0 & [M]CHK(J+K)="" & SBQ<>[M]SNS(J+K) & (([M:RB2]CTRCIB=1) |
&    ([M:RB2]CTRCIB=2 & [M]BANCIB(I)<>"" & [M]BANCIB(I)=[M]BANCIB(J+K) &
&    max([M]ACCDAT(I),[M]ACCDAT(J+K))-min([M]ACCDAT(I),[M]ACCDAT(J+K))<=[F:ADI]N1) |
&   ([M:RB2]CTRCIB=2 & ([M]BANCIB(J+K)="" | [M]BANCIB(I)="") &
&   (max([M]ACCDAT(I),[M]ACCDAT(J+K))-min([M]ACCDAT(I),[M]ACCDAT(J+K))<=[M]NBJR)))
    LPTG2 = [M]LPTG
    Call CHK_LETTRE(LPTG2) From SUBRAB
    [M]LPTG = LPTG2 : [M]CHK(I) = LPTG2 : [M]CHK(J+K) = LPTG2
   Endif
   J+=K
  Wend
  If [M]CHK(I)="" & [M:RB2]RAPMTOPT=2
   K = 0 : MT = 0
   For J=0 To [M]NBLIG-1
    If [M]CHK(J)="" & [M]ACCNUM(J)<>0 & (([M:RB2]CTRCIB=1) |
&    ([M:RB2]CTRCIB=2 & [M]BANCIB(I)<>"" & [M]BANCIB(I)=[M]BANCIB(J) &
&    max([M]ACCDAT(I),[M]ACCDAT(J))-min([M]ACCDAT(I),[M]ACCDAT(J))<=[F:ADI]N1) |
&   ([M:RB2]CTRCIB=2 & ([M]BANCIB(J)="" | [M]BANCIB(I)="") &
&   (max([M]ACCDAT(I),[M]ACCDAT(J+K))-min([M]ACCDAT(I),[M]ACCDAT(J+K))<=[M]NBJR))) &
&    ((SBQ=[M]SNS(J) & [M]AMTBNQ(J)>0 & MT+[M]AMTBNQ(J)<=[M]AMTBNQ(I)) |
&    (SBQ<>[M]SNS(J) & [M]AMTBNQ(J)<0 & MT-[M]AMTBNQ(J)<=[M]AMTBNQ(I)))
     MT +=abs([M]AMTBNQ(J)) : [M]P(K) = J : K +=1
     If MT = [M]AMTBNQ(I)
      LPTG2 = [M]LPTG
      Call CHK_LETTRE(LPTG2) From SUBRAB
      [M]LPTG = LPTG2 : [M]CHK(I) = LPTG2
      For J=0 To K-1 : [M]CHK([M]P(J)) = LPTG2 : Next J
      Break
     Endif
    Endif
   Next J
  Endif
 Endif
Next I
Return

$PHASE4
#Association Y lignes relevé ayant mêmes caractéristiques(entnum,desig,ref)
#pour X lignes écritures
PHASE4 = 1
Raz [M]R
B = 1  : #Code pointage des lignes relevé identiques
For I=0 To [M]NBLIG-1
 L = 0
 If [M]CHK(I)="" & [M]R(I)=0 & [M]ACCNUM(I)=0 : #Ligne de relevé non pointé
  MTR = 0
  For J=I+1 To [M]NBLIG-1
   If [M]R(J)=0 & [M]ACCNUM(J)=0 &
&                 [M]REFC(I)=[M]REFC(J) & [M]DES(I)=[M]DES(J) &
&                 [M]REFB(I)=[M]REFB(J) & [M]CHK(J)="" &
&                ([M:RB2]CTRCIB=1 | ([M:RB2]CTRCIB=2 &
&                ([M]BANCIB(I)=[M]BANCIB(J) | [M]BANCIB(J)="")))
    [M]R(J) = B
    L = 1
    If val([M]SNSBNQ)=1
     MTR +=[M]AMTBNQ(J) * (([M]SNS(J)=1) - ([M]SNS(J)=2))
    Else MTR +=[M]AMTBNQ(J) * (([M]SNS(J)=1) - ([M]SNS(J)=2)) * (-1)
    Endif
   Endif
  Next J
 Endif
 If L   : #Plusieurs relevés ont les mêmes caractéristiques
  [M]R(I) = B
  If val([M]SNSBNQ)=1
   MTR +=[M]AMTBNQ(I) * (([M]SNS(I)=1) - ([M]SNS(I)=2))
  Else MTR +=[M]AMTBNQ(I) * (([M]SNS(I)=1) - ([M]SNS(I)=2)) * (-1)
  Endif
  If MTR >0 : SBQ = 1 : Else : SBQ = 2 : Endif
  MTR = abs(MTR)
  Gosub POSE_PRIORITE
  Gosub EGAL_PRIORITE
  #On cherche une somme de priorité = au montant des lignes relevé
  If L=0
   MT = 0 : K = 0
   For J=0 To [M]NBLIG-1
    If [M]P(J) & (([M]SNS(J)=SBQ & [M]AMTBNQ(J)>0 & MT+[M]AMTBNQ(J)<=MTR) |
&   ([M]SNS(J)<>SBQ & [M]AMTBNQ(J)<0 & MT-[M]AMTBNQ(J)<=MTR))
     MT +=abs([M]AMTBNQ(J)) : [M]P(K) = J : K +=1
     If MT = [M]AMTBNQ(I)
      LPTG2 = [M]LPTG
      Call CHK_LETTRE(LPTG2) From SUBRAB
      [M]LPTG = LPTG2 : L = 1
      For J=0 To K-1
       [M]CHK([M]P(J)) = LPTG2
      Next J
      Break
     Endif
    Endif
   Next J
  Endif
  If L<>0
   For J=1 To [M]NBLIG-1
    If [M]R(J)=[M]R(I) : [M]CHK(J) = LPTG2 : Endif
   Next J
  Endif
  B +=1
 Endif
Next I
Return

$SOLDE_POINTAGE
If [M]ACCNUM(NOL)=0 & ([M]CHK(NOL)="" | [M]CHK(NOL)>"_")
 #Relevé bancaire
 If ([M]SNS(NOL)=1 & val([M]SNSBNQ)=1) |
&   ([M]SNS(NOL)=2 & val([M]SNSBNQ)=2)
  Case OPE
   When 0 : [M]CHKBLC -= [M]AMTBNQ(NOL)
   When 1 : [M]CHKBLC += [M]AMTBNQ(NOL)
  Endcase
 Endif
 If ([M]SNS(NOL)=1 & val([M]SNSBNQ)=2) |
&   ([M]SNS(NOL)=2 & val([M]SNSBNQ)=1)
  Case OPE
   When 0 : [M]CHKBLC +=[M]AMTBNQ(NOL)
   When 1 : [M]CHKBLC -=[M]AMTBNQ(NOL)
  Endcase
 Endif
Elsif [M]ACCNUM(NOL)<>0 & ([M]CHK(NOL)="" | [M]CHK(NOL)>"_")
 #Ecriture
 If [M]SNS(NOL)=1
  Case OPE
   When 0 : [M]CHKBLC += [M]AMTBNQ(NOL)
   When 1 : [M]CHKBLC -= [M]AMTBNQ(NOL)
  Endcase
 Else
  Case OPE
   When 0 : [M]CHKBLC -= [M]AMTBNQ(NOL)
   When 1 : [M]CHKBLC += [M]AMTBNQ(NOL)
  Endcase
 Endif
Endif
Return

Subprog B1_NBLIG
# Select button
Local Integer VALEUR
If [M]CHX(nolign-1) = 1
 VALEUR = 2
Else
 VALEUR = 1
Endif
Call TRT_CHX(VALEUR)
Affzo [M]CHX(nolign-1)
mkstat = 4 : # To trigger the action "after modif" in order to set REP with "M"
End

$APRES_MODIF
NOL = nolign-1
Case COUZON
 When "VALDAT", "BANDAT"
   [M]CHGDAT(NOL) = 1
Endcase
Return

Subprog AM_CHX(VALEUR)
Variable Integer VALEUR
Call TRT_CHX(VALEUR)
End

Subprog TRT_CHX(VALEUR)
Variable Integer VALEUR
Local Integer NOL, OPE
NOL = nolign-1
If NOL<0 : End : Endif
If VALEUR=2 : # Select
 OPE = 1
Else
 OPE = 0
Endif
Gosub SOLDE_POINTAGE
[M]CHX(NOL) = VALEUR
Affzo [M]CHKBLC
End

