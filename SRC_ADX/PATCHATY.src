#<AdxTL>@(#)6.0.0.0 $Revision$
###################################################
## Intégration d'un type
###################################################
$ATYPE
Local File =DOSSIER(D)+".ATYPE"       [ATY2]
Local File =DOSSIER(D)+".ATYPERUL"    [ATYR2]
Local File =DOSSIER(D)+".ATYPERPAR"   [ATYRP2]
Local File =DOSSIER(D)+".ATYPELNK"    [ATYL2]
Local File =DOSSIER(D)+".ATYPELPAR"   [ATYLP2]
Local Integer B,J

Local Integer NRUL, NLNK
Local Char    TBRUL(200)(1..)
Local Char    TBLNK(200)(1..)
Local Char    OLDACT(GLONACT)

FICHIER = "ATYPE" : ABR = "ATY"
Read [ATY]CODTYP = NOMOBJ
If fstat = 0
  #for SCM deletion (typenr=-2 only in scm at the moment)
  If TYPENR=-2
      Gosub DEL_ATY
      Gosub FIN_OBJ From PATCH
  Else
      # Patch not for scm - ISFULLMOD = 2 when SCM
      If [L]ISFULLMOD<>2
          # specific objet ? only on not scm mode and only on header
          If dim([F:ATY]CODACT)>0 & [F:ATY]CODACT>="X" & !find([F:ATY]CODACT,ACTIV(1..NBACT))
              # specific Objet
              Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN
              OKSPE = 1
              Gosub FIN_OBJ From PATCH
          Else
              NEWOBJ = 0
              [F:ATY2]=[F:ATY]
              Gosub TR_ATY
          Endif
      Else
          #ISFULLMOD = 2 when SCM always rewrite no test about spe activity code.
          NEWOBJ = 0
          [F:ATY2]=[F:ATY]
          Gosub TR_ATY
      Endif
  Endif
Else
  # creation only if typenr <> - 2 (typenr=-2 only in scm at the moment)
  If TYPENR<>-2
      NEWOBJ = 1
      Raz [F:ATY]
      Gosub TR_ATY
  Else
      Gosub FIN_OBJ From PATCH
  Endif
Endif
$FIN_ATYPE
LogicClose File [ATY2],[ATYR2],[ATYRP2],[ATYL2],[ATYLP2]
Return
#-------------------#
# deletion at the moment only for scm
#-------------------#
$DEL_ATY
Call DEBTRANS From GLOCK
Trbegin [ATY]
 Delete [ATYRP2] Where CODTYP=NOMOBJ
 Delete [ATYR2]  Where CODTYP=NOMOBJ
 Delete [ATYL2]  Where CODTYP=NOMOBJ
 Delete [ATYLP2] Where CODTYP=NOMOBJ
 Delete [ATY] Curr
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ATYPE"-NOMOBJ : Rollback : Return
 Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ATY",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

#-------------------#
#-------------------#
$TR_ATY
Call DEBTRANS From GLOCK
Trbegin [ATY],[ATYR],[ATYRP],[ATYL],[ATYLP]

 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Le fichier
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "ATY"   : Gosub ATY1
     When "ATYR"  : Gosub ATY2
     When "ATYRP" : Gosub ATY3
     When "ATYL"  : Gosub ATY4
     When "ATYLP" : Gosub ATY5
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif

## removal of excess rules

 For [ATYR] Where CODTYP=NOMOBJ
  If !find(num$([F:ATYR]TYPRUL)+"~"+[F:ATYR]TRTRUL+"~"+[F:ATYR]PRGRUL,TBRUL(1..NRUL))
&  & ([F:ATYR]ACTRUL<"X" or find([F:ATYR]ACTRUL,ACTIV(1..NBACT)))
   Delete [ATYRP] Where CODTYP=NOMOBJ & TYPRUL=[F:ATYR]TYPRUL & TRTRUL=[F:ATYR]TRTRUL & PRGRUL=[F:ATYR]PRGRUL
   Delete [ATYR]
  Endif
 Next

## removal of excess links

 For [ATYL] Where CODTYP=NOMOBJ
  If !find([F:ATYL]CODLNK,TBLNK(1..NLNK))
&  & ([F:ATYL]ACTLNK<"X" or find([F:ATYL]ACTLNK,ACTIV(1..NBACT)))
   Delete [ATYLP] Where CODTYP=NOMOBJ & CODLNK=[F:ATYL]CODLNK
   Delete [ATYL]
  Endif
 Next

Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ATY",[F:ATY]CODTYP,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif

If dim(ISTYPMOD)>0 & !find(NOMOBJ,CDTYPMOD(1..dim(CDTYPMOD))) & ISTYPMOD<dim(CDTYPMOD)
 ISTYPMOD += 1
 CDTYPMOD(ISTYPMOD) = NOMOBJ
Endif

# 119695: si patch SCM, on valide toujours
If GPRODUIT<>0 | APPLI<>GDOSX3 | find([F:ATY]MODULE,1,9,10) | (dim([L]ISFULLMOD)>0 & [L]ISFULLMOD = 2)
 Local Integer OK
 Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
 Call VALCTRLREF(NOMOBJ,APPLI,0,0,OK) From AVALACTLREF
Endif

Return

$ATY1
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
MODOBJ = max(1,[F:ATY]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
If NEWOBJ
   If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
        Call FLDCRE("ATY") From OBJDIV
   Endif
   Gosub VERF_ATY
   Write [ATY]
   If fstat
        Call LOG_ERROR_DETAILS(1, "ATY",num$([F:ATY]CODTYP),"") From GLOCK
   Endif
Else
  If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
        Call FLDUPD("ATY") From OBJDIV
  Endif
  Gosub VERF_ATY
  Rewrite [ATY]
  If fstat
        Call LOG_ERROR_DETAILS(2, "ATY",num$([F:ATY]CODTYP),"") From GLOCK
  Endif
Endif
If fstat
    GOK = 0 : ER = 99 : ERFIC = "ATYPE"-NOMOBJ : Return
Endif
Return

#---------------------------------------------------#
## Rules
#---------------------------------------------------#

$ATY2
Local Integer TYPRUL
Local Char TRTRUL(30),PRGRUL(30)
NRUL += 1 : TBRUL(NRUL) = IDENT
K = instr(1,IDENT,"~")
If K
  [L]TYPRUL = val(left$(IDENT,K-1))
  IDENT = right$(IDENT,K+1)
  K = instr(1,IDENT,"~")
  If K
    [L]TRTRUL = left$(IDENT,K-1)
    [L]PRGRUL = right$(IDENT,K+1)
  Else
   Gosub FIN_OBJ From PATCH
   Return
  Endif
Else
 Gosub FIN_OBJ From PATCH
 Return
Endif
FICHIER = "ATYPERUL" : ABR = "ATYR"
Read [ATYR]ATYR0 = NOMOBJ;[L]TYPRUL;[L]TRTRUL;[L]PRGRUL
If fstat
 OLDACT = ""
 Raz [F:ATYR]
Elsif [F:ATYR]ACTRUL>="X" & !find([F:ATYR]ACTRUL,ACTIV(1..NBACT)) : # Specific
 OLDACT = [F:ATYR]ACTRUL
 Gosub FIN_FIC From PATCH
 Return
Else
  OLDACT = [F:ATYR]ACTRUL
Endif
Raz [F:ATYRP]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif

Delete [ATYRP2] Where CODTYP=NOMOBJ & TYPRUL=[F:ATYR]TYPRUL & TRTRUL=[F:ATYR]TRTRUL & PRGRUL=[F:ATYR]PRGRUL
Delete [ATYR2] Where CODTYP=NOMOBJ & TYPRUL=[F:ATYR]TYPRUL & TRTRUL=[F:ATYR]TRTRUL & PRGRUL=[F:ATYR]PRGRUL
Write [ATYR]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ATYPERUL"-NOMOBJ-num$([L]TYPRUL)-[L]TRTRUL-[L]PRGRUL : Return
Endif

Return

#---------------------------------------------------#
## Rules parameters
#---------------------------------------------------#

$ATY3
FICHIER = "ATYPERPAR" : ABR = "ATYRP"
If OLDACT>="X" & !find(OLDACT,ACTIV(1..NBACT)) : # Specific
 Gosub FIN_FIC From PATCH
 Return
Endif
Raz [F:ATYRP]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
Write [ATYRP]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ATYPERPAR"-NOMOBJ-num$([L]TYPRUL)-[L]TRTRUL-[L]PRGRUL-[F:ATYRP]PARCOD : Return
Endif
Return

#---------------------------------------------------#
## Links
#---------------------------------------------------#

$ATY4
NLNK += 1 : TBLNK(NLNK) = IDENT
FICHIER = "ATYPELNK" : ABR = "ATYL"
Read [ATYL]ATYL0 = NOMOBJ;IDENT
If fstat
 OLDACT = ""
 Raz [F:ATYL]
Elsif [F:ATYL]ACTLNK>="X" & !find([F:ATYL]ACTLNK,ACTIV(1..NBACT)) : # Specific
 OLDACT = [F:ATYL]ACTLNK
 Gosub FIN_FIC From PATCH
 Return
Else
  OLDACT = [F:ATYL]ACTLNK
Endif
Raz [F:ATYLP]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif

Delete [ATYLP2] Where CODTYP=NOMOBJ & CODLNK=[F:ATYL]CODLNK
Delete [ATYL2] Where CODTYP=NOMOBJ & CODLNK=[F:ATYL]CODLNK
Write [ATYL]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ATYPELNK"-NOMOBJ-[F:ATYL]CODLNK : Return
Endif

Return

#---------------------------------------------------#
## Links parameters
#---------------------------------------------------#

$ATY5
FICHIER = "ATYPELPAR" : ABR = "ATYLP"
If OLDACT>="X" & !find(OLDACT,ACTIV(1..NBACT)) : # Specific
 Gosub FIN_FIC From PATCH
 Return
Endif
Raz [F:ATYLP]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
Write [ATYLP]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ATYPELPAR"-NOMOBJ-[F:ATYLP]CODLNK-[F:ATYLP]PARCOD : Return
Endif
Return


$ABORT
Rollback
Return

$VERF_ATY
# On vire les actions qui n'existent pas
I = 0
While I<=[F:ATY]NBTYP-1
 Read [ACT]ACTION = [F:ATY]ACTION(I)
 If fstat
  Dela I,1,[F:ATY]NBTYP [F:ATY]ACTION,[F:ATY]ACTTYP,[F:ATY]EXEACT
  [F:ATY]NBTYP -= 1
 Else
  I += 1
 Endif
Wend
Return

# On vire les liens si l'objet associé au type de données n'existe pas
Subprog VIRE_LIEN(DOSSIER,TYP)
Value Char DOSSIER
Value Char TYP()(1..)
Local File =DOSSIER+".ATYPE"  [ATY]
Local File =DOSSIER+".AOBJET" [AOB]
For I=1 To dim(TYP)
 If TYP(I)<>""
  Trbegin [ATY]
   Readlock [ATY]CODTYP=TYP(I)
   If !fstat & [F:ATY]OBJLIEN<>""
    Read [AOB]ABREV = [F:ATY]OBJLIEN
    If fstat
     [F:ATY]OBJLIEN = ""
     [F:ATY]FICLIEN = ""
     Rewrite [ATY]
    Endif
   Endif
  Commit
 Endif
Next I
LogicClose File [ATY] , [AOB]
End

