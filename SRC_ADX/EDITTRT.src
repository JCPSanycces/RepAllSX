#<AdxTL>@(#)6.0.0.0 $Revision$
###########################################################################################################
# Reports LETTRETRT, LETTRETRTBLANC, TRAITE
###########################################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call IMPRIME(NBPAR,PARAMETRE) From TRSRPT : # Pour vérif de la banque
If GOK<1 : End : Endif

Call EXEC(NBPAR,PARAMETRE)

End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Gosub OUVRE
If GERREUR : GERREUR=0 : End : Endif
Gosub DECLARE

[L]CRITERE = "STA<>9 & STAFLG(8)<>2 & AMTCUR>0 & EDTNUM=0 & SNS=1"
# Traite émise non remise en banque, d'un montant positif, non éditée
[L]FILT    = "1=1"
For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "__REQUETE": [L]NUMREQ1 = val([L]VALEUR)
   When "etat"     : [L]ETAT = [L]VALEUR
   When "societe"  : If [L]VALEUR<>""
                      [L]CRITERE -= "& CPY='"+[L]VALEUR+"'"
                     Endif
   When "sitedeb"  : [L]CRITERE -= "& FCY>='"+[L]VALEUR+"'"
   When "sitefin"  : [L]CRITERE -= "& FCY<='"+[L]VALEUR+"'"
   When "bank"     : If [L]VALEUR<>""
                      [L]CRITERE -= "& BAN='"+[L]VALEUR+"'"
                      [L]BANK = [L]VALEUR
                     Endif
   When "datedeb"
    [L]DTE=gdat$(val(right$([L]VALEUR,7)),val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
    [L]CRITERE -= "& ACCDAT>=["+format$(GFMD,[L]DTE)+"]"
   When "datefin"
    [L]DTE=gdat$(val(right$([L]VALEUR,7)),val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
    [L]CRITERE -= "& ACCDAT<=["+format$(GFMD,[L]DTE)+"]"
   When "codedt"   : [L]EDIT = [L]VALEUR
   When "lotdeb"   : [L]VALEUR = vireblc([L]VALEUR,2)
                     If [L]VALEUR<>""
                      [L]CRITERE -= '& PAYLOT>="'+[L]VALEUR+'"'
                     Endif
   When "lotfin"   : If [L]VALEUR<"zzzzzzzzzz"
                      [L]CRITERE -= '& PAYLOT<="'+[L]VALEUR+'"'
                     Endif
   When "regdeb"   : [L]CRITERE -= "& NUM>='"+[L]VALEUR+"'"
                     [L]FILT    -= "& CLEA1>='"+[L]VALEUR+"'"
   When "regfin"   : [L]CRITERE -= "& NUM<='"+[L]VALEUR+"'"
                     [L]FILT    -= "& CLEA1<='"+[L]VALEUR+"'"
   When "numedt"   : If [L]VALEUR<>"0"
                      [L]NUMREQ2 = val([L]VALEUR)
                      [L]PARAMETRE(I) = "numedt="+[L]VALEUR
                     Else
                      [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ1)
                     Endif
   When "bordeb"   : [L]VALEUR = vireblc([L]VALEUR,2)
                     If [L]VALEUR<>""
                      [L]CRITERE -= '& FRMNUM>="'+[L]VALEUR+'"'
                     Endif
   When "borfin"   : If [L]VALEUR<"zzzzzzzzzz"
                      [L]CRITERE -= '& FRMNUM<="'+[L]VALEUR+'"'
                     Endif
   When "X3FCT"    : [L]FONCTION = [L]VALEUR
  Endcase
 Endif
Next

If [L]NUMREQ2=0 : # Pas de réédition
 Filter [PYH] Where evalue([L]CRITERE)
 Raz [L]WNUMLIG
 For [PYH]PYH0
# Vérif autorisation par site
  OKSITE = 1
  If FONCTION<>""
   Read [AFF]AFF0 = [F:PYH]FCY;GPROFIL;FONCTION
   If fstat : OKSITE = 0 : Endif
  Endif
  If OKSITE
   Call DEBTRANS From GLOCK
   Gosub TR1
  Endif
 Next
 Call MESSAGE(mess(38,114,1)-num$([L]NUMREQ1)) From GESECRAN : # Requête numéro xxxxx
 Filter [PYH]
Else             : # Réédition
 Filter [ARM] Where  NUMREQ=[L]NUMREQ2 & evalue([L]FILT) & CLEA4<>'GACCDENCOD' & CLEA4<>'GTYPACCENT'
 Read [ARM] First
 If [F:ARM]RPTCOD <> [L]ETAT: # ou fstat<>0->aucun réglt sélectionnés n'appartient à la requête
  # Impossible de rééditer les règlements par la requête yyy
  Call ERREUR(mess(19,121,1)-num$([L]NUMREQ2)) From GESECRAN
  Filter [ARM]
  GOK=0
  End
 Endif
 For [ARM]ARM0
  Call DEBTRANS From GLOCK
  OK = 1
  Gosub TR2
  If OK=0 : Break : Endif
 Next
 Filter [ARM]
Endif

Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE) From ETAT
If SOCIETE<>"?????"
 Read [CPY]CPY0 = SOCIETE
 If fstat
  # Société incorrecte
  Call ECR_TRACE(mess(81,116,1),1) From GESECRAN
  GOK = 0 : End
 Endif
 If [F:CPY]CPYLEGFLG<>2
  NBSOC = 0
  For [FGR]FGR0 Where CPY=SOCIETE
   Read [FCY]FCY0 = [F:FGR]FCY
   If !find([F:FCY]LEGCPY,TBSOC(1..NBSOC))
    NBSOC += 1
    TBSOC(NBSOC) = [F:FCY]LEGCPY
   Endif
  Next
 Else
  NBSOC = 1
  TBSOC(1) = SOCIETE
 Endif
Endif

#Multi-leg
If [L]NUMREQ2=0
 [L]NUMREQ=[L]NUMREQ1
 K = WNUMLIG
 Gosub TRT_CDA_GTE From RPTLEG
Endif
End

$TR1
GOK = 1
Trbegin [ARM], [PYH]
 Call LEC_TPY_LEG(GCURLEG,[F:PYH]PAYTYP) From CPTLEC
 Call LEC_TED([F:TPY]LEG,[F:TPY]CODEDT) From CPTLEC
 If [F:TED]TRT = [L]EDIT
  WNUMLIG += 1
  Raz [F:ARM]
  Gosub ADRESSE
  [F:ARM]USR     = GUSER
  [F:ARM]RPTCOD  = [L]ETAT
  [F:ARM]NUMREQ  = [L]NUMREQ1
  [F:ARM]NUMLIG  = [L]WNUMLIG
  [F:ARM]CLEA1   = [F:PYH]NUM
  [F:ARM]CREDAT  = date$
  Write [F:ARM]
  If fstat : GOK = 0 :Call FSTA("ARM") From GLOCK : Goto AB_TR1 : Endif
  Readlock [F:PYH]PYH0 Curr
  If fstat = 1
   GOK = -1 : GLOCK = "$PAYMENTH"-[F:PYH]NUM : Goto ROLL_TR1
  Elsif fstat
   GOK = 0 : Call RSTA("PYH",[F:PYH]NUM) From GLOCK : Goto AB_TR1
  Endif
  [F:PYH]EDTNUM =  [L]NUMREQ1
  Rewrite [PYH]
  If fstat
   GOK = 0 : Call FSTA("PYH") From GLOCK : Goto AB_TR1
  Endif
 Endif
Commit
Return

$ADRESSE
# Recherche de l'adresse du fournisseur
# Si pays du site <> pays du founisseur, on éditera le pays du site sur la traite
# Sur la lettre traite l'adresse du fournisseur est obligatoire

# Si l'adresse détail de PAYMENTH est vide on récupère le code adresse qui est obligatoire
# On prend l'adresse du règlement mais si elle est vide,
# on prend l'adresse par défaut du tiers ou du compte.

I=0
For J=0 To dim([F:PYH]BPAADDLIG)-1
 If vireblc([F:PYH]BPAADDLIG(J),2)<>"" : I=1 : Break : Endif
Next J
If [F:PYH]POSCOD <> "" or [F:PYH]CTY <> "" or [F:PYH]CRYNAM <> "" : I=1 : Endif
If I : Raz [F:ARM]CLEN1, [F:ARM]CLEA3
Elsif [F:PYH]BPR<>""
 [F:ARM]CLEN1=1
 [F:ARM]CLEA3=[F:PYH]BPR
 [F:ARM]CLEA2 = [F:PYH]BPAINV : Return
Endif

Raz [F:ARM]CLEA2
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1
Endif

$AB_TR1
Rollback
Return

$TR2
GOK = 1
Trbegin [ARM]
 Readlock [PYH]PYH0=[F:ARM]CLEA1
 If [F:PYH]BAN=[L]BANK
  If fstat = 1
   GOK = -1 : GLOCK = "$PAYMENTH"-[F:ARM]CLEA1 : Goto ROLL_TR2
  Elsif fstat
   GOK = 0 : Call RSTA("PYH",[F:ARM]CLEA1) From GLOCK : Goto AB_TR2
  Endif
# Vérif autorisation par site
  OKSITE = 1
  If FONCTION<>""
   Read [AFF]AFF0 = [F:PYH]FCY;GPROFIL;FONCTION
   If fstat : OKSITE = 0 : Endif
  Endif
  If OKSITE
   Gosub ADRESSE
   Rewrite [ARM]
   If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR2 : Endif
  Endif
 Endif
Commit
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2
Endif

$AB_TR2
Rollback
Return

$DECLARE
Local File PAYMENTH [PYH], AREPORTM [ARM], TABPAYTYP [TPY],
& BPADDRESS [BPA], BPARTNER [BPR], BPCUSTOMER [BPC], BPSUPPLIER [BPS], GACCOUNT [GAC], AFCTFCY [AFF],
& FACGROUP [FGR], COMPANY [CPY], FACILITY [FCY], GACCDENCOD [CDA], GTYPACCENT [GTE], TABCODEDT [TED]
Return

$OUVRE
Local Date DTE
Local Integer I, J, NUMREQ, NUMREQ1, NUMREQ2, WNUMLIG, OKSITE
Local Char CRITERE(255), FILT(100), ETAT(GLONARP), PARAM(30), VALEUR(30), EDIT(3)
Local Char FONCTION(10), BANK(GLONBAN)
#
Local Char SOCIETE(GLONCPY)
Local Integer NBSOC
Local Char    TBSOC(GLONCPY)(1..GNBSOC)
Local Integer K
Return
