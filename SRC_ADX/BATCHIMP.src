#<AdxTL>@(#)2.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
Call IMPRIME
End

Subprog IMPRIME
Onerrgo ERREUR From REQUETES

Local Integer NBPAR , I , J , K , L , J1
Local Char    PARAMETRE(250)(1..100)
Local Char    SERVEUR(30)
Local Char    ETAT(GLONARP)
Local Char    P1(15)(1..80) , P2(15)(1..80)

Local File AREPORT [ARP]

Local Integer NBSEG , L , NUMREQ, NBPAR
Local Char    VALSEG(30)(0..100) , PARAM(80) , TEXTE(80)
Local Char    FICSEG(250)
Local Char    VALDEB(80) , VALFIN(80)

Call LEC_PARAM(P1,P2) From REQUETES
Call GETPAR(P1,P2,SERVEUR,NBPAR,PARAMETRE)

Call ECR_TRACE(mess(15,135,1)-": |"+SERVEUR,0) From GESECRAN : # Serveur d'impression

L = 0
NBSEG = 0
For I=1 To NBPAR
 If left$(PARAMETRE(I),6)="X3ETA="
  ETAT = right$(PARAMETRE(I),7)
 Endif
 K = instr(1,PARAMETRE(I),"=")
 If K
  PARAM = left$(PARAMETRE(I),K-1)
  TEXTE = right$(PARAMETRE(I),K+1)
  Case PARAM
   When "X3SEG"  : NBSEG = val(TEXTE)
   When "X3SEGV" : VALSEG(L) = TEXTE : L += 1
  Endcase
 Endif
Next I

Read [ARP]ARP0 = ETAT

If [F:ARP]PARSEG<>"" & NBSEG<>0
 K = 0
 For J=1 To NBPAR
  If left$(PARAMETRE(J),len([F:ARP]PARSEG)+1)=[F:ARP]PARSEG+"="
   K = J
  Endif
  If left$(PARAMETRE(J),12)="_ExportFile="
   FICSEG = right$(PARAMETRE(J),14)
   J1 = instr(1,FICSEG,".")
  Endif
 Next J
 VALDEB = right$(PARAMETRE(K),len([F:ARP]PARSEG)+2)
 VALFIN = right$(PARAMETRE(K+1),len([F:ARP]PARSEG)+2)
 If VALDEB="" : VALDEB = "  "         : Endif
 If VALFIN="" : VALFIN = "zzzzzzzzzz" : Endif
Endif

For I=0 To NBSEG

 If NBSEG<>0
  If I=0
   PARAMETRE(K) = [F:ARP]PARSEG+"="+VALDEB
  Else
   PARAMETRE(K) = [F:ARP]PARSEG+"="+VALSEG(I-1)
  Endif
  If I=NBSEG
   PARAMETRE(K+1) = left$(PARAMETRE(K+1),len([F:ARP]PARSEG)+1)+VALFIN
  Else
   PARAMETRE(K+1) = left$(PARAMETRE(K+1),len([F:ARP]PARSEG)+1)
&                  +left$(VALSEG(I),len(VALSEG(I))-1)
&                  +chr$(ascii(mid$(VALSEG(I),len(VALSEG(I)),1))-1)+"zzz"
  Endif
  For J=1 To NBPAR
   If left$(PARAMETRE(J),10)="__REQUETE="
    NUMREQ = uniqid([ARP])
    PARAMETRE(J) = "__REQUETE="+num$(NUMREQ)
   Endif
   If left$(PARAMETRE(J),12)="_ExportFile="
    If J1
     PARAMETRE(J) = "_ExportFile="+chr$(1)+left$(FICSEG,J1-1)+format$("N0:2#",I+1)+right$(FICSEG,J1)
    Else
     PARAMETRE(J) = "_ExportFile="+chr$(1)+FICSEG+format$("N0:2#",I+1)
    Endif
   Endif
  Next J
 Endif

# Traitement d'init

 If [F:ARP]TRTINI<>"" & filinfo(filpath("TRT",[F:ARP]TRTINI,"adx"),0)>=0
  GOK = 1
  Call IMPRIME(NBPAR,PARAMETRE) From =[F:ARP]TRTINI
  If GOK<1 : Break : Endif
 Endif
 
 For J=1 To NBPAR
  If left$(PARAMETRE(J),6)="X3ETA="
   ETAT = right$(PARAMETRE(J),7)
   Call ECR_TRACE(mess(17,135,1)-":"-ETAT,0) From GESECRAN : # Etat
  Elsif left$(PARAMETRE(J),13)="_PrinterName="
   Call ECR_TRACE(mess(16,135,1)-": |"+right$(PARAMETRE(J),15),0) From GESECRAN
  Elsif left$(PARAMETRE(J),1)<>"_" & left$(PARAMETRE(J),2)<>"X3"
   Call ECR_TRACE("|"+PARAMETRE(J),0) From GESECRAN
  Endif
 Next J

 Call ECR_TRACE("",0) From GESECRAN 
 Call PARAMPRINT(PARAMETRE,NBPAR) From ETAT    : # Ajout de Chr(1) devant les parametres
 Report SERVEUR With PARAMETRE(1..NBPAR)
Next I
Onerrgo
End

Subprog GETPAR(P1,P2,SERVEUR,NBPAR,PARAMETRE)
Variable Char    P1()(1..)
Variable Char    P2()(1..)
Variable Char    SERVEUR()
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Local Integer I , J
Local Char    TEXTE(15)
SERVEUR = P1(1)+P1(2)
NBPAR = 0
J = 1 : I = 3
While J<=2
 While I<=dim(P1)
  Case J
   When 1 : TEXTE = P1(I)
   When 2 : TEXTE = P2(I)
  Endcase
  If left$(TEXTE,1)="@"
   NBPAR += 1
   PARAMETRE(NBPAR) = right$(TEXTE,2)
  Elsif TEXTE<>""
   PARAMETRE(NBPAR) += TEXTE
  Endif
  I += 1
 Wend
 J += 1 : I = 1
Wend
#For I=1 To NBPAR
# PARAMETRE(I) = vireblc(PARAMETRE(I),2)
#Next I
End

Subprog PARAM(DOSSIER,UTILIS,P1,P2,OK) 
Value    Char    DOSSIER 
Value    Char    UTILIS
Variable Char    P1()(1..) 
Variable Char    P2()(1..) 
Variable Integer OK
Call PARAM(DOSSIER,UTILIS,P1,P2,OK) From ETAT
End
