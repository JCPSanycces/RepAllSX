#<AdxTL>@(#)4.0.0.0 $Revision$
################################################################################################
# UTIIND10   Moulinette                                                                        #
# - Validation des écrans avec bloc graphique xsl suite à moulinette UTIMAJASUASP              #
################################################################################################
  Local Integer OK
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Moulinette UTIIND10") From LECFIC
  If nomap<>GDOSX3
    Call MAJ_UTIIND10(nomap)
  Else
    Call OUINON("Exécuter cette moulinette sur l'ensemble des dossiers de la solution",OK) From GESECRAN
    If OK<>2 : End : Endif
    If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
    For [ADS]
      If filinfo(filpath("FIL","ADOVAL","fde",[F:ADS]DOSSIER),0)>0
        Call MAJ_UTIIND10([F:ADS]DOSSIER)
      Endif
    Next
  Endif
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
End

Subprog MAJ_UTIIND10(DOSSIER)
Value Char DOSSIER

  Local Integer COMPTEUR, I

  Call ECR_TRACE("UTIIND10 : Process Start on : "+DOSSIER,0) From GESECRAN
  Call VSCRXSL(DOSSIER)

End

Subprog VSCRXSL(APPLI)
Value Char APPLI
Local File =APPLI+".AURL" [AUR]
Local File =APPLI+".AMSK" [AM1K]
Local Char LISTSCR(20)(1..500)
Local Integer NBSCR,MOK,I

Filter [AUR] Where TYPURL=2
For [AUR]
  Gosub FINDSCREEN
Next
Filter [AUR]

For I=1 To NBSCR
  Call VALID(LISTSCR(I),APPLI,1,GLANGUE,0,MOK) From VALMSK
Next I
  Call ECR_TRACE("UTIIND10 : "+num$(NBSCR)+" masks processed",0) From GESECRAN
End


$FINDSCREEN
Filter [AM1K] Where find([F:AUR]CODURL,BLOCLIEN1(0..14)) or find([F:AUR]CODURL,BLOCLIEN2(0..14))
&                or find([F:AUR]CODURL,BLOCLIEN3(0..14))

For [AM1K]
   If !find([F:AM1K]CODMSK,LISTSCR(1..NBSCR))
     NBSCR+=1
     LISTSCR(NBSCR)=[F:AM1K]CODMSK
   Endif
Next
Filter [AM1K]
Return

########################################################################
# Pour exécution automatique en gestion de patch                       #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI
  Call MAJ_UTIIND10(APPLI)
End

#######################################################################
# Pour exécution depuis DOSMAJ (validation dossier)
#######################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
  Call MAJ_UTIIND10(APPLI)
End
