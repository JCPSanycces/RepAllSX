#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
#######################################################################################
$SUPPLIERS
Local Char LASBPSNUM : [L]LASBPSNUM  = ''

Case [L]SAFTTYPE
  When 8
    Gosub SUPP_COM_DT
  When Default
    Filter [F:BPS]
    For [F:BPS]BPS0
      Gosub SUPPLIER
    Next
Endcase

Return
#######################################################################################
#######################################################################################
$SUPP_COM_DT
Gosub DECLARE_TABLES  From SAFTGENPORMG
Gosub DEC_COMDT_CRITS From SAFTGENPORMG
Gosub ALIM_CRITER     From SAFTGENPORMG

#All
If [M:SAFT]EVRDOCTYP =2
  For [F:BPS]
    Link [F:PTDK2] With [F:PTPNH]PNH0~=[F:PTDK2]DOCNUM As [MGT3]
&   Where [F:PTPNH]CFMFLG=2 & [F:PTPNH]RTNDAT>=[L]STRDATE & [F:PTPNH]RTNDAT<=[L]ENDDATE & [F:PTPNH]CPY =[L]SOC &
&   evalue(CRITPNH) & [F:PTDK2]ATDTCOD='' & [F:PTPNH]BPSNUM = [F:BPS]BPSNUM
    Read [MGT3] First
    If !fstat
      Gosub SUPPLIER : Close File [MGT3]
      Goto  SEGUINTE
    Endif
    Close File [MGT3]

    Link [F:PTDK2] With [F:PTSGH]SGH0~=[F:PTDK2]DOCNUM, [F:PTFCY]FCY0=[F:PTSGH]STOFCY As [MGT3]
&   Where [F:PTSGH]CFMFLG=2 & [F:PTSGH]IPTDAT>=[L]STRDATE & [F:PTSGH]IPTDAT<=[L]ENDDATE & [F:PTFCY]LEGCPY=[L]SOC &
&   [F:PTSGH]BPSNUM=[F:BPS]BPSNUM & find([F:PTSGH]BETFCYCOD,4,5) & [F:PTDK2]ATDTCOD='' & evalue([L]CRITSGH)
    Read [MGT3] First
    If !fstat
      Gosub SUPPLIER : Close File [MGT3]
      Goto  SEGUINTE
    Endif
    Close File [MGT3]

    Link [F:PTDK2] With [F:PTTNH]TNH0~=[F:PTDK2]DOCNUM  As [MGT5]
&   Where [F:PTTNH]CFMFLG=2 & [F:PTTNH]TRNDAT>=[L]STRDATE & [F:PTTNH]TRNDAT<=[L]ENDDATE & [F:PTTNH]CPY=[L]SOC &
&   evalue([L]CRITTNH) & [F:PTDK2]ATDTCOD='' & [F:PTTNH]BPRNUM=[F:BPS]BPSNUM & [F:PTTNH]BPCBPS=2
    Read [F:MGT5] First
    If !fstat
      Gosub SUPPLIER : Close File [MGT5]
      Goto  SEGUINTE
    Endif
    Close File [MGT5]

    $SEGUINTE
  Next
Endif

If [M:SAFT]EVRDOCTYP <> 2 & find([M:SAFT]DOCTYP,7,8)
Link [F:PTDK2] With [F:PTSGH]SGH0~=[F:PTDK2]DOCNUM, [F:PTFCY]FCY0=[F:PTSGH]STOFCY, [F:BPS]BPS0~=[F:PTSGH]BPSNUM As [MGT3]
& Where [F:PTSGH]CFMFLG=2 & [F:PTSGH]IPTDAT>=[L]STRDATE & [F:PTSGH]IPTDAT<=[L]ENDDATE & [F:PTFCY]LEGCPY=[L]SOC &
& [F:PTDK2]ATDTCOD='' & evalue([L]CRITSGH) Order By [F:BPS]BPSNUM

Local Char LASBPSNUM : [L]LASBPSNUM = ""

For [F:MGT3]
  If [F:TNH]BPCBPS=2
    If [L]LASBPSNUM <> [F:BPS]BPSNUM
      Gosub SUPPLIER
    Endif
    [L]LASBPSNUM = [F:BPS]BPSNUM
  Endif
Next

Close File [F:MGT3]
Endif

If [M:SAFT]EVRDOCTYP <> 2 & [M:SAFT]DOCTYP = 9
Link [F:PTDK2] With [F:PTPNH]PNH0~=[F:PTDK2]DOCNUM ,[F:PTFCY]FCY0=[F:PTPNH]PNHFCY, [F:BPS]BPS0~=[F:PTPNH]BPSNUM As [MGT4]
& Where [F:PTPNH]CFMFLG=2 & [F:PTPNH]RTNDAT>=[L]STRDATE & [F:PTPNH]RTNDAT<=[L]ENDDATE & [F:PTFCY]LEGCPY=[L]SOC &
& [F:PTDK2]ATDTCOD='' & evalue([L]CRITPNH) Order By [F:BPS]BPSNUM

[L]LASBPSNUM = ""

For [F:MGT4]
  If [L]LASBPSNUM <> [F:BPS]BPSNUM
    Gosub SUPPLIER
  Endif
  [L]LASBPSNUM = [F:BPS]BPSNUM
Next
Close File [F:MGT4]
Endif

If [M:SAFT]EVRDOCTYP <> 2 & [M:SAFT]DOCTYP = 10
Link [F:PTDK2] With [F:PTTNH]TNH0~=[F:PTDK2]DOCNUM, [F:PTFCY]FCY0=[F:PTTNH]FCY, [F:BPS]BPS0~=[F:PTTNH]BPRNUM  As [MGT5]
&   Where [F:PTTNH]CFMFLG=2 & [F:PTTNH]TRNDAT>=[L]STRDATE & [F:PTTNH]TRNDAT<=[L]ENDDATE & [F:PTTNH]CPY=[L]SOC &
&   evalue([L]CRITTNH) & [F:PTDK2]ATDTCOD='' & [F:PTTNH]BPCBPS=2 Order By [F:BPS]BPSNUM
For [F:MGT5]
  If [F:PTTNH]BPCBPS=2
    If [L]LASBPSNUM <> [F:BPS]BPSNUM
      Gosub SUPPLIER
    Endif
    [L]LASBPSNUM = [F:BPS]BPSNUM
  Endif
Next
Endif

Return
#######################################################################################
#######################################################################################
$SUPPLIER

#Entry point used to exclude an supplier from export
[L]EXCSUP    = 0
GPOINT  = "SAFTPTSUP" : Gosub ENTREE From EXEFNC
If [L]EXCSUP = 1 : Goto NEXTSUP : Endif

#BP
Read [F:BPR]BPR0 = [F:BPS]BPSNUM
If fstat : Raz [F:BPR] : Endif

#Country
If [F:TCY]CRY <> [F:BPR]CRY
   Read [F:TCY]TCY0 = [F:BPR]CRY
   If fstat : Raz [F:TCY] : Endif
Endif

#Address
Read [F:ADC]BPA0 = 1;[F:BPS]BPSINV;[F:BPS]BPAINV
If fstat : Raz [F:ADC] : Endif
If [F:ADC]CRY <> "" & [F:BPR]CRY <> [F:ADC]CRY
  Filter [F:ADC] Where [F:ADC]BPATYP = 1 & [F:ADC]BPANUM = [F:BPS]BPSNUM & [F:ADC]BPAADDFLG = 2 & [F:BPR]CRY = [F:ADC]CRY
  Read [F:ADC] First
  If fstat
    Filter [F:ADC]
    Filter [F:ADC] Where [F:ADC]BPATYP = 1 & [F:ADC]BPANUM = [F:BPS]BPSNUM & [F:BPR]CRY = [F:ADC]CRY
    Read [F:ADC] First
    If fstat
      Raz [F:ADC]
    Endif
  Endif
  Filter [F:ADC]
Endif

#Accounting code
Filter [F:CAC] Where ACCCOD = [F:BPS]ACCCOD & TYP = 3 & COA = [L]COA
Read [F:CAC] First
If fstat : Raz [F:CAC] : Endif
Filter [F:CAC]

#Contact
If [F:BPS]CNTNAM <> ""
  Read [F:AIN]AIN0 = [F:BPS]CNTNAM
  If fstat : Raz [F:AIN] : Endif
Else
  Filter [F:CNT] Where BPATYP = 1 & BPANUM = [F:BPS]BPSNUM
  Read [F:CNT] First
  If !fstat
    Read [F:AIN]AIN0 = [F:CNT]CCNCRM
    If fstat : Raz [F:AIN] : Endif
  Else
    Raz [F:AIN]
  Endif
  Filter [F:CNT]
Endif

#ALIM_SUPPL
Gosub RAZ_SUT From SAFTGENPOR
[L]SUTSUPPLID = [F:BPS]BPSNUM
#If [F:CAC]ACC(0) = "" | find([L]SAFTTYPE,2,5)
#  [L]SUTACCOUID = 'Desconhecido'
#Else
  [L]SUTACCOUID = [F:CAC]ACC
#Endif
If [L]SUTACCOUID = "" : [L]SUTACCOUID = "Desconhecido" : Endif

SUTSUPTAXID = func SAFTGENPORTG.GETEECNUM([F:BPR]EECNUM)#t9
If [L]SUTSUPTAXID = "" & [F:TCY]EECFLG <> 2
  [L]SUTSUPTAXID = "999999990"
Endif

[L]SUTCOMPANAM = [F:BPS]BPSNAM
If [L]SUTCOMPANAM = "" : [L]SUTCOMPANAM = "Desconhecido" : Endif
[L]SUTCONTACT   = [F:AIN]CNTFULNAM
[L]SUTIBILNUM = ""
[L]SUTISTRENAM = ""
[L]SUTIADDRDET = vireblc([F:ADC]BPAADDLIG(0) + " " + [F:ADC]BPAADDLIG(1) + " " + [F:ADC]BPAADDLIG(2), 2)
If [L]SUTIADDRDET = "" : [L]SUTIADDRDET = "Desconhecido" : Endif
[L]SUTICITY      = vireblc([F:ADC]CTY,2)
If [L]SUTICITY   = "" : [L]SUTICITY         = "Desconhecido" : Endif
[L]SUTIPOSTCOD = vireblc([F:ADC]POSCOD,2)
If [L]SUTIPOSTCOD = "" : [L]SUTIPOSTCOD = "0000-000" : Endif
[L]SUTIREGION    = vireblc([F:ADC]SAT,2)
If [L]SUTIREGION    = "" : [L]SUTIREGION    = "Desconhecido" : Endif
[L]SUTICOUNTRY   = vireblc([F:ADC]CRY,2)
If [L]SUTICOUNTRY   = "" : [L]SUTICOUNTRY   = "PT" : Endif
[L]SUTTELEPHONE = [F:ADC]TEL
[L]SUTFAX       = [F:ADC]FAX
[L]SUTEMAIL   = [F:ADC]WEB
[L]SUTSELFBILIN = 0
If [L]SUTICOUNTRY <> "PT" & [L]SAFTTYPE = 8 : Return : Endif

If len([L]SUTIPOSTCOD) = 7
  [L]SUTIPOSTCOD = format$("K:4#[-]3#", [L]SUTIPOSTCOD)
Endif

Gosub WRITE_SUPP
$NEXTSUP

Return
#######################################################################################
#######################################################################################
$WRITE_SUPP

Wrseq '<Supplier>' Using [SAFT]
AUXTAGNAM = 'SupplierID'           : AUXTAGVAL = [L]SUTSUPPLID : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'AccountID'            : AUXTAGVAL = [L]SUTACCOUID : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'SupplierTaxID'        : AUXTAGVAL = [L]SUTSUPTAXID : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'CompanyName'          : AUXTAGVAL = [L]SUTCOMPANAM : Gosub WRITETAG From SAFTGENPORTG
If [L]SUTCONTACT <> "" : AUXTAGNAM = 'Contact'              : AUXTAGVAL = [L]SUTCONTACT   : Gosub WRITETAG From SAFTGENPORTG : Endif
Wrseq '<BillingAddress>' Using [SAFT]
#AUXTAGNAM = 'BuildingNumber'       : AUXTAGVAL = SUTIBILNUM : Gosub WRITETAG from SAFTGENPORTG
#AUXTAGNAM = 'StreetName'           : AUXTAGVAL = SUTISTRENAM : Gosub WRITETAG from SAFTGENPORTG
AUXTAGNAM = 'AddressDetail'        : AUXTAGVAL = [L]SUTIADDRDET : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'City'                 : AUXTAGVAL = [L]SUTICITY      : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'PostalCode'           : AUXTAGVAL = [L]SUTIPOSTCOD : Gosub WRITETAG From SAFTGENPORTG
If [L]SUTIREGION <> "" : AUXTAGNAM = 'Region'                    : AUXTAGVAL = [L]SUTIREGION    : Gosub WRITETAG From SAFTGENPORTG : Endif
AUXTAGNAM = 'Country'              : AUXTAGVAL = [L]SUTICOUNTRY   : Gosub WRITETAG From SAFTGENPORTG
Wrseq '</BillingAddress>' Using [SAFT]
If [L]SUTTELEPHONE<>"" : AUXTAGNAM = 'Telephone' : AUXTAGVAL = [L]SUTTELEPHONE : Gosub WRITETAG From SAFTGENPORTG : Endif
If [L]SUTFAX<>""       : AUXTAGNAM = 'Fax'       : AUXTAGVAL = [L]SUTFAX       : Gosub WRITETAG From SAFTGENPORTG : Endif
If [L]SUTEMAIL<>""   : AUXTAGNAM = 'Website'   : AUXTAGVAL = [L]SUTEMAIL   : Gosub WRITETAG From SAFTGENPORTG : Endif
AUXTAGNAM = 'SelfBillingIndicator' : AUXTAGVAL = num$([L]SUTSELFBILIN) : Gosub WRITETAG From SAFTGENPORTG
Wrseq '</Supplier>' Using [SAFT]
[L]RECSWRI += 1

Return
#######################################################################################
#######################################################################################

