## fermeture de l'enregistrement
#Openo
#CATUA X3-67237.eo

#                        Génération fichier GUIDE CALIBRAGE / CALIGUIDE
CALIGUIDEFILE = func OPTLIB.FILNAM(GFCY,"ilcgd",0)
adxium = GUTF8      # 44767 mm 08.09
adxifs = ";"
adxirs = chr$(10)
# OUVERTURE du fichier en écriture
Openo CALIGUIDEFILE,0
For I = 0 To 7 Step 1
    If TABCGD (I) = "" : Break : Endif
       For [CGD]CGD0 Where CGD = TABCGD(I)

        # lecture de l unite pour recuperation decimale

            If clalev([F:TUN]) = 0 : Local File TABUNIT [TUN] : Endif
            If [F:TUN]UOM <> [F:CGD]CGDWEU
               Read [TUN]TUN0 = [F:CGD]CGDWEU
            Endif

            # 03.09 mm - libellé traduisible
            Call LECTEXTRA (WGUIDE,"CALIGUIDES","CGDDESAXX",[F:CGD]CGD,"") From ATEXTRA
            Call CHANGE_CHAR(WGUIDE)

               # écriture le l'enregistrement
               Wrseq [F:CGD]CGD;WGUIDE;[F:CGD]CGDLIG;[F:CGD]CGDWGG;[F:CGD]CGDWEU;
&                    [F:CGD]CGDNBR;[F:CGD]CGDTYP;mess([F:CGD]CGDTYP,2325,1);
&                    [F:CGD]CGDTOL;[F:TUN]UOMDEC
       Next
Next I
# fermeture de l'enregistrement
Openo
#X3-67271.so
#                        Génération fichier OF PLAN PESEE / MFGHEAD MFGITM

PLANPESE = func OPTLIB.FILNAM(GFCY,"ilmwg",0)
adxium = GUTF8      # 44767 mm 08.09
adxifs = ";"
adxirs = chr$(10)
Local Char    CRITERE (255)
Local Char    CRITERE1(255)
Local Char    CRITERE2(255)
Local Char    FORMULE1(255)
Local Char    WMFGNUM(GLONVCR)
Local Integer WMFGLIN
Local Char    WITMDES(GLONDES)        # FGR 30/06/2009 : X3SUIVI56189

Local Shortint EXPITM                 #X3-85848 - added parameter to indicate if items are extracted

Local Decimal WQTYPREVUE
WQTYPREVUE = 0

Raz NUMOF
# Ouverture du fichier en écriture
#X3-85848.n Openo PLANPESE,0
Openo PLANPESE,0 Using [WORD]      #X3-85848 - Open using an abbrev as we call XTRACT_NUMOF

Gosub MFG_FILTER1
If CRITERE1 = "" CRITERE1 = "1=1" Endif
If CRITERE2 = "" CRITERE2 = "1=1" Endif
If FORMULE1 = "" FORMULE1 = "1=1" Endif

# 42003 mm 07.07
If GSCA1ITMREF <>""
    Link [MFI] With [F:MFG]MFG0=[F:MFI]MFGNUM,
&   [F:MFM]MFM0 = [F:MFI]MFGNUM;[F:MFI]MFGLIN
&   As [MFIX]
&   Where evalue(CRITERE2) & evalue(CRITERE1) & evalue(FORMULE1) & [F:MFM]ITMREF=GSCA1ITMREF
&   Order By Key MFI0
Else
    Link [MFI] With [F:MFG]MFG0=[F:MFI]MFGNUM   As [MFIX]
&   Where evalue(CRITERE2) & evalue(CRITERE1) & evalue(FORMULE1)
&   Order By Key MFI0
Endif

For [MFIX]
    # OF vérouillé ? - 86709 mm 01.2013
    # Si OF verrouillé : modification de l'OF en cours sur un autre poste, l'éliminer de la liste
    If (func MFGLIB.CHKMFGLOCK( [F:MFG]MFGNUM ,0 )) : Goto NXT1 : Endif

#X3-85848.sn - Added below block to make sure the 1st order has items to extract
    If NUMOF = ""
      NUMOF = [F:MFG]MFGNUM
      EXPITM = 0
      Call XTRACT_NUMOF([F:MFG]MFGNUM,NUMMAT,EXPITM)
      If EXPITM = 0
         NUMOF = ""
         Goto NXT1
      Endif
    Endif
#X3-85848.en - End of added block

    If [F:MFG]WGGSTA = 0  [F:MFG]WGGSTA = 1              Endif

    If GSCA1ITMREF <>""
        If WMFGNUM = [F:MFM]MFGNUM & WMFGLIN = [F:MFM]MFGLIN : Goto NXT1 : Endif
        WMFGNUM = [F:MFM]MFGNUM
        WMFGLIN = [F:MFM]MFGLIN
    Endif
    Read [ITM]ITM0=[F:MFI]ITMREF

    #  libellé traduisible
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,WITMDES,"[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    Call CHANGE_CHAR(WITMDES)

    Call CAL_POIDS ([F:MFI]ITMREF,[F:MFI]UOMEXTQTY,WQTYPREVUE)

       # écriture le l'enregistrement
# Added 0;"" to below - FGR 30/06/2009 : X3SUIVI56189 + 56403 mm 07.09
#X3-85848.n - added abbrev used for the order
    Wrseq [F:MFG]MFGNUM;[F:MFI]ITMREF;WITMDES;[F:MFI]LOT;[F:MFI]UOMEXTQTY;
&         [F:MFI]UOM;[F:MFG]WGGSTA;mess([F:MFG]WGGSTA,2321,1);[F:MFG]STRDAT;
&         [F:MFG]MFGPIO;mess([F:MFG]MFGPIO,365,1);WQTYPREVUE;[F:ITM]WEU;
&         0;""
&         Using [WORD]
$NXT1
Next

# fermeture de l'enregistrement

#X3-85848.o - Removed blanket file close     Openo
Openo Using [WORD]     #X3-85848.n - Added specific file close for the orders

adxium = SAVIUM        # 44767 mm 08.09

End

#################################################################################################
# Génération  Scalespha / mat / hsh /  suivant un numero d OF                                   #
#################################################################################################
#                        Génération fichier PHASES / MFGMAT                                     #
#                        Génération fichier COMPOSANTS / MFGMAT                                 #
#                        Génération fichier ISM / HANDLING                                      #
#   (  sert à rien)      Génération fichier INSTRUCTIONS / HANDLINGR                            #
#################################################################################################
#X3-85848 - Added NUMITM to parameters to check if any item was extracted
Subprog XTRACT_NUMOF(NUMOF,NUMMAT,EXPITM)
Value    Char    NUMOF
Value    Char    NUMMAT
Variable    Shortint EXPITM      #X3-85848 - new parameter to indicate if an item was extracted or not
Local    Char    MATFLT1(255) # 48952 mm 11.09 - MATFLT1 zone de filtres supplémentaires
Local    Char    MATFLT2(255) # SMO : pour pesee matiere
Local    Integer SAVIUM : SAVIUM = adxium
Local    Integer WNUMOPE     # 63294 mm 03.10
Local    Integer WGGBOX   # mm 01.11
# mm 05.11
Local    Integer WENCOURSPESEE : WENCOURSPESEE = 0
# Issue 80839 - 2012-03-19 by SR
Local    Char    FORMULE1(255)


Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218

COMPOSANTS = func OPTLIB.FILNAM(GFCY,"ilmat",0)
PHASES     = func OPTLIB.FILNAM(GFCY,"ilpha",0)
FICHISM    = func OPTLIB.FILNAM(GFCY,"ilhsh",0)

adxium = GUTF8     # 44767 mm 08.09
adxifs = ";"
adxirs = chr$(10)

# sr 05.02 L'of sélectionné est -il déjà en cours de pesée ailleurs ?
#          Si OUI
#          Si NON on le passe à en cours de pesée
Read [F:MFG]MFG0 = NUMOF
If fstat : Raz [F:MFG] : Endif
# nécessaire en cas de pesée par article, pour réaliser 2 pesées concurrentes sur le même OF:
# on vérifie qu'il existe au moins une matière de l'OF en cours de pesée
If NUMMAT  <> "null"
   Case [F:MFG]WGGFLG :
   When 4 :
      WWGGBOX = 1
      Filter [MFM] Where MFGNUM=[F:MFG]MFGNUM & MATSTA < 3 & CPNTYP <> 5 & WGGSTA < 3 & PKC = 2
      For [MFM]
        WWGGBOX = [F:MFM]WGGBOX
        If  WWGGBOX = 2 : Break :Endif
      Next
      Filter [MFM]
      If  WWGGBOX = 2  : Goto DEB_XTRACT_NUMOF : Endif
    When 8 :
      WENCOURSPESEE = 1 : Goto DEB_XTRACT_NUMOF
    Endcase
Endif
#
If [F:MFG]WGGFLG <> 3
   # on vide les fichiers (il faudra interpréter cela dans la DLL)
   Openo COMPOSANTS,0 : Openo
   Openo PHASES,0     : Openo
   Openo FICHISM,0    : Openo
   End
Else
    Call DEBTRANS From GLOCK
    Trbegin [MFG]
    # mm 05.11 - pesée par article
    If NUMMAT  <> "null"
       Call MAJ_FICHIERS ("MFG", 8, 0, NUMOF, "", 0, 0) From SCALEXCHAN
    Else
       Call MAJ_FICHIERS ("MFG", 4, 0, NUMOF, "", 0, 0) From SCALEXCHAN
    Endif
    If GOK = 1 :  Commit
    Else       : Rollback
    Endif
Endif

$DEB_XTRACT_NUMOF
Local Shortint OP_LOOP            : Raz OP_LOOP          #X3-85848 - Loop Counter
Local Shortint OP_EXT       (999) : Raz OP_EXT           #X3-85848 - Array for items extracted at each operation
Local Char     OP_CRIT      (50)  : Raz OP_CRIT          #X3-85848 - Criteria to include/exclude excipient items

Local Shortint T_BOMOPE     (100) : Raz T_BOMOPE
Local Shortint T_WGGSTA     (100) : Raz T_WGGSTA
Local Shortint T_MFGPIO     (100) : Raz T_MFGPIO
Local Date     T_RETDAT     (100) : Raz T_RETDAT
Local Decimal  T_WRETQTY    (100) : Raz T_WRETQTY        # pour pesee matiere - quantité restante
Local Decimal  T_WALLQTY    (100) : Raz T_WALLQTY        # pour pesee matiere - quantité allouée
Local Char     T_WITMWEU(10)(100) : Raz T_WITMWEU
Local Char     T_ISM (8)    (200) : Raz T_ISM

# Ouverture du fichier en écriture
Openo COMPOSANTS,0

Local Char    WCHAIN, WSPECHAR,WITM        # 03.09 mm - libellé traduisible
Local Integer I
Local Integer Y
Local Integer WACCES        : WACCES     = 0
Local Decimal WQTYPREVUE    : WQTYPREVUE = 0
Local Decimal WQTYRESTAN    : WQTYRESTAN = 0
Local Decimal WQTYCONSOM    : WQTYCONSOM = 0
Local Decimal WQTEDISPO     : WQTEDISPO  = 0     # pour la pesee matiere : colonne qtedispo
Local Decimal WALLQTY       : WALLQTY    = 0     # pour pesee matiere - quantité allouée
Local Char    DEPOT(GLONWRH): DEPOT      = ""    # pour calcul qté dispo : depot
Local Char    LOC(GLONEMP)  : LOC        = ""    # emplacement
Local Integer WSTATUT       : WSTATUT    = 0     # statut matière autorisé, d'après la lecture de TABSTRORUL
Local Decimal WQTYDOSE
Local Decimal WQTYPEC       : WQTYPEC    = 0     # 93535 - Qté PEC pour calcul Excipient de fin de phase
Local Decimal WTOLPOS       : WTOLPOS    = 0     # 115726 mm 04.2016
Local Decimal WTOLNEG       : WTOLNEG    = 0     # 115726 mm 04.2016
Local Decimal WCTNTHETAR                         #CATUA X3-30163.n
Local Char    WCTNWEU(3)                         #CATUA X3-30163.n


If clalev([F:AUS])  <= 0 : Local File AUTILIS    [AUS]  : Endif
If clalev([F:BOD])  <= 0 : Local File BOMD       [BOD]  : Endif
If clalev([F:SBOD]) <= 0 : Local File BOMD       [SBOD] : Endif
If clalev([F:SITM]) <= 0 : Local File ITMMASTER  [SITM] : Endif
If GWRHACT=2
   If clalev([F:SBX])  <= 0 : Local File STATIONBOX [SBX]  : Endif
   If clalev([F:WRH])  <= 0 : Local File WAREHOUSE  [WRH]  : Endif
Endif
If clalev([F:FCY])  <= 0 : Local File FACILITY   [FCY]  : Endif
If clalev([F:ITV])  <= 0 : Local File ITMMVT     [ITV]  : Endif
If clalev([F:WGG])  <= 0 : Local File WEIGHING   [WGG]  : Endif     # 93535
If clalev([F:CTN])  <= 0 : Local File CONTAINERS [CTN]  : Endif #CATUA X3-30163.n

# Lecture AUTILIS pour connaitre la valeur de ALLACS
  Read [AUS]CODUSR = GUSER
  If fstat : Raz [F:AUS] : Endif

# lecture du dépôt associé au box
  Call LEC_WRH(DEPOT,LOC)

# 48952 mm 11.09
# point d'entrée  pour permettre de filtrer les matières d'OF
Raz MATFLT1
GPOINT = "MATSELFLT" : Gosub ENTREE From EXEFNC
If MATFLT1 = "" : MATFLT1 = "1=1" : Endif

# le filtre est différent selon que l'on soit en pesée par OF ou en pesée par matière
Raz MATFLT2
If NUMMAT  <> "null"
   MATFLT2 = "ITMREF = '"+NUMMAT+"'"
   MATFLT2 += " & MATSTA <3 "
   MATFLT2 += " & PKC = 2 "
   MATFLT2 += " & WGGBOX = 1"
Else
   MATFLT2 = " MATSTA < 4"
   MATFLT2 += "& PKC  >  1  "
Endif

#X3-85848: Issue reported was that excipient items were being extracted even if regular items
#X3-85848: were not (which is not correct).  To resolve; added a loop to first look at the
#X3-85848: regular items and set an array to say "item extracted" - the array is at the operation
#X3-85848: number level. If the item fails the control access check; the array entry is reset.
#X3-85848: The second loop only looks for the excipient items and only extracts if an item has
#X3-85848: been extracted for the same operation number.  This accomodates partial weighing where
#X3-85848: the regular items are weighed "today" and the excipient items "tomorrow".
For OP_LOOP = 1 To 2                            #X3-85848.n
   OP_CRIT = "1=1"                              #X3-85848.n

   If NUMMAT = "null"                           #X3-85848.n
      If OP_LOOP = 1                            #X3-85848.n
         OP_CRIT = "(PKC <> 4 and PKC <> 5)"    #X3-85848.n
      Else                                      #X3-85848.n
         OP_CRIT = "(PKC = 4 or PKC = 5)"       #X3-85848.n
      Endif                                     #X3-85848.n
   Endif                                        #X3-85848.n

#X3-85848.n - Added &  evalue(OP_CRIT) to below
For [MFM]MFM0 Where MFGFCY = GSCA1MFGFCY   &
&                   MFGNUM = NUMOF         &
&                   CPNTYP <> 5            &
&                   evalue(OP_CRIT)        &
&                   evalue(MATFLT1)        &
&                   evalue(MATFLT2)

    # OF vérouillé ? - 86709 mm 01.2013
    # Si OF verrouillé : modification de l'OF en cours sur un autre poste, l'éliminer de la liste
    If (func MFGLIB.CHKMFGLOCK( [F:MFM]MFGNUM ,0 ))
       # 93179 mm 10.2013 - Si OF verrouillé par ailleurs, modifier la valeur du flag
       # WGGFLG = 4 ( en cours de pesée) -> 3 ( plan de pesée)
       If [F:MFG]WGGFLG = 4 : Call MAJ_FICHIERS ("MFG",3,0,[F:MFM]MFGNUM,"",0,0) From SCALEXCHAN : Endif
       Goto NEXT_MFM
     Endif

#X3-85848.sn
# If we are looking at regular items set the array for this operation #
# otherwise ignore an excipient item if no regaulr items were extracted at this operation #
    If OP_LOOP = 1
       OP_EXT([MFM]BOMOPE) = 1
    Elsif OP_LOOP = 2 and OP_EXT([MFM]BOMOPE) = 0
       Goto NEXT_MFM
    Endif
#X3-85848.en

    # controle acces
    Gosub CTL_ACCES

#X3-85848.sn
# If we are looking at regular items but we don't have access to it, reset the array for this operation #
    If OP_LOOP = 1 and WACCES <> 0
       OP_EXT([MFM]BOMOPE) = 0
    Endif
#X3-85848.en

    If WACCES <> 0 : Goto NEXT_MFM : Endif

    # 63294 mm 03.10
    # PE pour permettre de substituer le n° d’opération par un n° de phase ajouté en spécifique.
    WNUMOPE = [F:MFM]BOMOPE
    GPOINT = "RPLOPE" : Gosub ENTREE From EXEFNC

    # si existe :
    # Lecture ITMMASTER
    Read [ITM]ITM0 = [F:MFM]ITMREF
    If fstat : Raz [F:ITM] : Endif
    # Lecture ITMFACILIT
    Read [ITF]ITF0 = [F:MFM]ITMREF;[F:MFM]MFGFCY
    If fstat : Raz [F:ITF] : Endif

    Call CAL_POIDS ([F:ITM]ITMREF,[F:MFM]RETQTY,WQTYPREVUE)

    Call CAL_POIDS ([F:ITM]ITMREF,[F:MFM]RETQTY-[F:MFM]USEQTY,WQTYRESTAN)

    Call CAL_POIDS ([F:ITM]ITMREF,[F:MFM]ALLQTY,WALLQTY)  # qté allouée avant d'entrer dans la Cdp

    # Les composants pesés sont passés avec une quantite restante à zero c'est la
    # quantite consommée qui sert pour le calcul de l excipient
    If [F:MFM]WGGSTA > 2  | [F:MFM]MATSTA = 3 : WQTYRESTAN = 0 : Endif

    # calcul quantite consommée
    Gosub CAL_QTYCONSOMME
    Call CAL_POIDS ([F:ITM]ITMREF,WQTYCONSOM,WQTYCONSOM)


   # lecture de la règle de gestion
    Call LEC_SRU(WSTATUT)
    If WSTATUT<>0
       Read [F:ITV]ITV0 = [F:MFM]ITMREF;[F:MFM]MFGFCY
       If fstat : Raz [F:ITV] : Endif
       Read [F:ITG]ITG0 = [F:MFM]MFGFCY;[F:ITM]TCLCOD
       If fstat
          Read [ITG] ITG1=[F:ITM]TCLCOD;"" : If fstat  Raz [F:ITG] : Endif
       Endif
       # calcul de la quantité disponible
       #--- TS 106217 & GH 120426
       #Call STODISPO("",[F:MFM]MFGFCY,[F:MFM]ITMREF,"*","*",0,WSTATUT,"" ,"",DEPOT,WQTEDISPO) From STKLIB
       Call STODISPO("",[F:MFM]MFGFCY,[F:MFM]ITMREF,"*","*",0,WSTATUT,"" ,"",DEPOT,
&                    string$([F:SRU]ORDVER=2,[F:MFM]ECCVALMAJ),
&                    WQTEDISPO) From STKLIB
       #---
       Call CAL_POIDS ([F:ITM]ITMREF,WQTEDISPO,WQTEDISPO)
    Else
       WQTEDISPO = 0
    Endif

    # lecture de l unite pour recuperation decimale
    If clalev([F:TUN]) = 0 : Local File TABUNIT [TUN] : Endif
    If [F:TUN]UOM <> [F:ITM]WEU
       Read [TUN]TUN0 = [F:ITM]WEU
    Endif

    # 05.10 mm - lecture nomenclature pour récupération du % de tolérance
    Read [F:MFI]MFI0 = [F:MFM]MFGNUM; [F:MFM]MFGLIN
    If fstat : Raz [F:MFI] : Endif

    Read [BOD]BOD0 = [F:MFI]ITMREF;[F:MFI]BOMALT;[F:MFM]BOMSEQ;[F:MFM]ITMREF;2
    # 77887 mm 11.11 - Cas d'un composant fantôme : récupération de la tolérance de ses composants
    If fstat=5
        # 111842 mm 12.2015
        # Ghost 's research in BOM
        Call CHECK_LIST_COMP([MFI]ITMREF,[F:MFI]BOMALT, [F:MFM]RETDAT,0)
    Elsif fstat : Raz [F:BOD] : Endif

    # 93535 mm 10.2013
    WQTYPEC    = 0
    If [F:MFM]STOMGTCOD = 3
      For [WGG]WGG0 Where MFGNUM = [F:MFM]MFGNUM &
&                     ITMREF = [F:MFM]ITMREF &
&                     BOMOPE = [F:MFM]BOMOPE &
&                     BOMSEQ = [F:MFM]BOMSEQ
        # 93536 mm 01.2014 -  pesée non annulée, partielle ou complète
        If [F:WGG]CCLWGGOPT = 0  & find ([F:WGG]WEIFLG,2,3)
           WQTYPEC +=  [F:WGG]WEIWEI
        Endif
      Next
    Endif


   # 105569 mm 02.2015
   # PE pour modifier en spécifique la quantité WQTYCONSOM.
   # Utile en cas de changement d'emplacement car les qté qui ont déjà changé d'emplacement
   # n'ont pas encore été consommées, contrairement au standard.
    GPOINT  = "MODIFQTE" : Gosub ENTREE From EXEFNC

   # 03.09 mm - libellé traduisible
   # Call LECTEXTRA (WITM,"ITMMASTER","DES1AXX",[F:ITM]ITMREF,"") From ATEXTRA
   Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,WITM,"[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
   Call CHANGE_CHAR(WITM)

   # 115726 mm 04.2016
   # EP to change the values of [F:BOD]ITMTOLPOS/ ITMTOLNEG by specific values
   WTOLPOS = [F:BOD]ITMTOLPOS
   WTOLNEG = [F:BOD]ITMTOLNEG
   GPOINT ="RPLDATSTD" : Gosub ENTREE From EXEFNC

   # sr 03.05 test pour doses
   # dans la réalité, on récuperera le nombre de pesées(à initialiser à 1 ou 0) sur l'enregistrement MFO
   # on divisera la quantité prévue par ce nombre de pesée pour connaître la quantité de la dose
   # Si le nombre de pesée = 0 ou 1 alors WQTYDOSE = 0 (on ne gère pas les doses)
   # pour l'instant on l'initialise à 0
   # POUR L'instant on ne descend pas cette zone (a rajouter à la fin si besoin)
    WQTYDOSE = 0

   #            écriture le l'enregistrement COMPOSANTS
   #            ecriture le l'enregistrement COMPOSANTS
   # sr 07.05 Pour LYOCENTRE
   # selon presence ou non de la zone REDMODFLG de ITF il faudra rajouter ou non cette zone en dernier
   # SMO : pour pesee matiere : ajout de la qte dispo ( a 0 car uniquement necessaire pour l'ecran de selection compo )
    If dim([F:ITMF]REDMODFLG) > 0
        If [F:ITF]REDMODFLG = 0  : [F:ITF]REDMODFLG = 1 : Endif
        Wrseq NUMOF;WNUMOPE;[F:MFM]ITMREF;WITM;
&             WQTYPREVUE;WQTYRESTAN ;WQTYCONSOM;
&             [F:ITM]WEU;[F:ITM]STU;[F:MFM]PKC;mess([F:MFM]PKC,2328,1);
&             [F:MFM]STOMGTCOD;mess([F:MFM]STOMGTCOD,215,1);
&             [F:MFM]DEFPOT;[F:ITM]NEGSTO;mess([F:ITM]NEGSTO,1,1);
&             [F:ITF]MFGSHTCOD;mess([F:ITF]MFGSHTCOD,1,1);[F:ITF]ISM;
&             [F:MFM]MFGLIN;[F:MFM]BOMSEQ;[F:TUN]UOMDEC;
&             WTOLPOS;WTOLNEG;WQTEDISPO;WALLQTY;WQTYPEC;[F:ITF]REDMODFLG; #CATUA X3-30163.n
#X3-85848 - set parameter to show we extracted at least 1 item
        EXPITM = 1
    Else
        Wrseq NUMOF;WNUMOPE;[F:MFM]ITMREF;WITM;
&             WQTYPREVUE;WQTYRESTAN ;WQTYCONSOM;
&             [F:ITM]WEU;[F:ITM]STU;[F:MFM]PKC;mess([F:MFM]PKC,2328,1);
&             [F:MFM]STOMGTCOD;mess([F:MFM]STOMGTCOD,215,1);
&             [F:MFM]DEFPOT;[F:ITM]NEGSTO;mess([F:ITM]NEGSTO,1,1);
&             [F:ITF]MFGSHTCOD;mess([F:ITF]MFGSHTCOD,1,1);[F:ITF]ISM;
&             [F:MFM]MFGLIN;[F:MFM]BOMSEQ;[F:TUN]UOMDEC;
&             WTOLPOS;WTOLNEG;WQTEDISPO;WALLQTY;WQTYPEC; #CATUA X3-30163.n
#X3-85848 - set parameter to show we extracted at least 1 item
        EXPITM = 1
    Endif
    # fin test sr

    #CATUA X3-30163.sn
    #Save container and tare fields
    #Should only work with V12 and higher
    Raz WCTNTHETAR, WCTNWEU
    If [F:MFM]CTN<>""
      Read [F:CTN]CTN0 = [F:MFM]CTN
      If !fstat
        WCTNTHETAR = [F:CTN]CTNTHETAR
        WCTNWEU = [F:CTN]CTNWEU
      Endif
    Endif
    Wrseq [F:MFM]CTN; WCTNTHETAR; WCTNWEU
    #CATUA X3-30163.en

    # mise en table de la fiche ism
    For Y = 0 To 199 Step 1
       If T_ISM (Y) = "" T_ISM (Y) = [F:ITF]ISM
       Break
       Endif
       If T_ISM (Y) =    [F:ITF]ISM
       Break
       Endif
    Next Y

    # mise en table de la phase
    For I = 0 To 99 Step 1
      If T_BOMOPE(I) = 0   T_BOMOPE (I)        = WNUMOPE
                           T_WGGSTA (I)        = [F:MFM]WGGSTA
                           If T_WGGSTA(I) = 0 : T_WGGSTA(I) = 1 : Endif
                           T_RETDAT (I)        = [F:MFM]RETDAT
                           T_MFGPIO (I)        = [F:MFM]MFGPIO
                           T_WRETQTY(I)        = ([F:MFM]RETQTY*[F:ITM]ITMWEI)-([F:MFM]USEQTY*[F:ITM]ITMWEI)
                           T_WALLQTY(I)        = [F:MFM]ALLQTY*[F:ITM]ITMWEI
                           T_WITMWEU(I)        = [F:ITM]WEU
                           Break
       Endif
       If T_BOMOPE (I) =    WNUMOPE
          If [F:MFM]WGGSTA <  T_WGGSTA (I) : T_WGGSTA (I) = [F:MFM]WGGSTA :  Endif
          If T_WGGSTA(I) = 0 : T_WGGSTA(I) = 1 : Endif
          Break
       Endif
    Next I
$NEXT_MFM
Next

Next   #X3-85848.n - End of added loop


For I = 0 To 99 Step 1
    If T_BOMOPE (I) = 0  & NUMMAT = "null" : Break : Endif
    If  WENCOURSPESEE = 1 & NUMMAT <> "null"
       Openo PHASES,0
       Wrseq NUMOF : Break
     Endif
Next I
If  WENCOURSPESEE = 1 & NUMMAT <> "null" : Goto CLOSE_FILE : Endif
# sr 11.04 trier par ordre croissant des numéros de phase
# Sorta T_BOMOPE Asc
Sorta T_BOMOPE,T_WGGSTA, T_RETDAT, T_MFGPIO, T_WRETQTY(I),  T_WALLQTY(I),   T_WITMWEU(I) Order By T_BOMOPE(indice)

# fermeture de l'enregistrement
Openo

# Ouverture du fichier en écriture

Openo PHASES,0
Local Integer I

For I = 0 To 99 Step 1
   If T_BOMOPE (I) <> 0
    # écriture de l'enregistrement PHASES
    Wrseq NUMOF;T_BOMOPE(I);T_WGGSTA (I);mess(T_WGGSTA(I),2322,1);
&              T_RETDAT (I);T_MFGPIO (I);mess(T_MFGPIO(I),365,1);
&              T_WRETQTY(I);T_WALLQTY(I);T_WITMWEU(I)
   Endif
Next I

# fermeture de l'enregistrement

Openo

# Ouverture du fichier en écriture

Openo FICHISM,0
Local Char     T_PCN (10)    (8)
Local Char     T_TXC (10)    (4)

Local Integer Y
Local Integer I

# Sorta 200 T_ISM

For Y = 0 To 199 Step 1
        # If T_ISM (Y) =  "" : Goto NEXT_Y : Endif
        If T_ISM (Y) =  "" : Break : Endif

        # écriture de l'enregistrement FICHISM
        # Lecture HANDLING
        Read [HSH]HSH0 = T_ISM(Y)
        If fstat : Raz [F:HSH] : Endif
        Raz T_PCN
        Raz T_TXC

        For I = 0 To 7 Step 1
           # sr 12.11 Demande 78351
           #If [F:HSH]PCN (I) =  "" : Break : Endif
           If [F:HSH]PCN (I) = "" : Goto NEXT_PCN : Endif
           # Lecture ATABDIV (precaution emploi  381)
           Call GET_SHOLIB(381, [F:HSH]PCN(I), T_PCN(I)) From MFGLIB
        $NEXT_PCN
        Next I

        For I = 0 To 3 Step 1
           # sr 12.11 Demande 78351
           #If [F:HSH]TXC (I) =  "" : Break : Endif
           If [F:HSH]TXC (I) =  "" : Goto NEXT_TXC : Endif
           # Lecture ATABDIV (code toxicite 382)
           Call GET_SHOLIB(382, [F:HSH]TXC(I), T_TXC(I)) From MFGLIB
        $NEXT_TXC
        Next I

        # 01.06 selon presence ou non de la zone MANREDFLG de HSH il faudra rajouter ou non cette zone en dernier
        If dim([F:HSH]MANREDFLG) > 0
           If [F:HSH]MANREDFLG = 0  : [F:HSH]MANREDFLG = 1 : Endif

            Wrseq T_ISM(Y); [F:HSH]LOTSEV;mess([F:HSH]LOTSEV,1,1);
&                           [F:HSH]PLACTL;mess([F:HSH]PLACTL,1,1);
&                           [F:HSH]PCK;mess([F:HSH]PCK,2323,1);
&                           [F:HSH]CLECTNAUT;
&                           [F:HSH]WEIMOD;mess([F:HSH]WEIMOD,2319,1);
&                           [F:HSH]OBL;
&                           [F:HSH]PCN(0);T_PCN(0);
&                           [F:HSH]PCN(1);T_PCN(1);
&                           [F:HSH]PCN(2);T_PCN(2);
&                           [F:HSH]PCN(3);T_PCN(3);
&                           [F:HSH]PCN(4);T_PCN(4);
&                           [F:HSH]PCN(5);T_PCN(5);
&                           [F:HSH]PCN(6);T_PCN(6);
&                           [F:HSH]PCN(7);T_PCN(7);
&                           [F:HSH]TXC(0);T_TXC(0);
&                           [F:HSH]TXC(1);T_TXC(1);
&                           [F:HSH]TXC(2);T_TXC(2);
&                           [F:HSH]TXC(3);T_TXC(3);
&                           [F:HSH]LBECTS;
&                           [F:HSH]SVRITMWEI;
&                           [F:HSH]MANREDFLG
        Else
            Wrseq T_ISM(Y); [F:HSH]LOTSEV;mess([F:HSH]LOTSEV,1,1);
&                           [F:HSH]PLACTL;mess([F:HSH]PLACTL,1,1);
&                           [F:HSH]PCK;mess([F:HSH]PCK,2323,1);
&                           [F:HSH]CLECTNAUT;
&                           [F:HSH]WEIMOD;mess([F:HSH]WEIMOD,2319,1);
&                           [F:HSH]OBL;
&                           [F:HSH]PCN(0);T_PCN(0);
&                           [F:HSH]PCN(1);T_PCN(1);
&                           [F:HSH]PCN(2);T_PCN(2);
&                           [F:HSH]PCN(3);T_PCN(3);
&                           [F:HSH]PCN(4);T_PCN(4);
&                           [F:HSH]PCN(5);T_PCN(5);
&                           [F:HSH]PCN(6);T_PCN(6);
&                           [F:HSH]PCN(7);T_PCN(7);
&                           [F:HSH]TXC(0);T_TXC(0);
&                           [F:HSH]TXC(1);T_TXC(1);
&                           [F:HSH]TXC(2);T_TXC(2);
&                           [F:HSH]TXC(3);T_TXC(3);
&                           [F:HSH]LBECTS;
&                           [F:HSH]SVRITMWEI
        Endif
$NEXT_Y
Next Y

$CLOSE_FILE
# fermeture de l'enregistrement
Openo
adxium = SAVIUM

End

###########################################################################
# 111842 mm 12.2015
# Reading recursive BOM
###########################################################################
Subprog CHECK_LIST_COMP(LITM, LALT, LDAT, LEVEL )
Value Char LITM
Value Integer LALT
Value Date LDAT
Value Integer LEVEL

Local Integer OK : OK = 1


# ghost 's research in this BOM
# reading links (except CPNTYP=6 or 7)
For [SBOD] Where ITMREF = LITM & BOMALT = LALT & BOMALTTYP = 2&
&                   (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= LDAT)) &
&                   (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= LDAT)) &
&                   CPNTYP < 6


     # read Article
     Read [F:SITM]ITM0=[F:SBOD]CPNITMREF
     If ! fstat
       If ([F:SITM]PHAFLG = 2)
          For [BOD] Where ITMREF=[F:SITM]ITMREF & BOMALT=[F:MFI]BOMALT & BOMALTTYP =2
              If [F:BOD]CPNITMREF = [F:MFM]ITMREF
                 Read [BOD]BOD0 First
                 If fstat : Raz [F:BOD] : Endif
                 Break 2
              Endif
           Next
           OK  = 0 : Break
       Endif
    Endif

Next

# ghost 's components reading
If OK = 0
  LEVEL +=1
  Call  CHECK_LIST_COMP( [F:SITM]ITMREF, [F:MFI]BOMALT,[MFM]RETDAT,LEVEL)
Endif

If LEVEL>0 : LEVEL -=1 : Endif
If LEVEL= 0 & ([F:BOD]CPNITMREF = [F:MFM]ITMREF)
   End
Endif

End


###########################################################################
# Pesée par article exclusivement
# test si tentative accès concurrent sur le même couple matière/phase de l'OF
###########################################################################
Subprog  CHECK_WEIGHING(RESULT)
Value Integer RESULT
Local Integer SAVIUM : SAVIUM = adxium


# Chargement du fichier X3ScalesSto.csv avec un seul élément
ALLOCATIONS = func OPTLIB.FILNAM(GFCY,"ilsto",0)

adxium = GUTF8
adxifs = ";"
adxirs = chr$(10)

# Ouverture du fichier en écriture
Openo ALLOCATIONS,0

# si même pesée déjà en cours sur un autre poste
If RESULT = 1
  Wrseq "PESEE EN COURS"
Else
  Wrseq "PESEE POSSIBLE"
Endif

# fermeture de l'enregistrement
Openo
adxium = SAVIUM

End

###########################################################################
# Lecture de la règle de gestion à utiliser
###########################################################################
Subprog LEC_SRU(WSTATUT)
Variable Integer WSTATUT
Local Integer WRET : WRET=0

#lecture transaction à utiliser
Read [F:BTS]BTS0 = 61;GWEITRSNUM
If fstat : Raz [F:BTS] : Endif
# Lecture de la règle de gestion à utiliser
Call LECSRU([F:MFM]MFGFCY,[F:ITM]TCLCOD,6,[F:BTS]TRSCODS,"",WRET) From STKLIB
If WRET<>0
  Raz [F:SRU]
  WSTATUT = 0
Else
  WSTATUT = [F:SRU]AUZSTA
Endif

End

###########################################################################
# Lecture du dépôt associé au box
###########################################################################
Subprog LEC_WRH(WDEPOT,WLOC)
Variable Char WDEPOT
Variable Char WLOC

If GSCA1MFGFCY <>[F:FCY]FCY
  Read [FCY]FCY0=GSCA1MFGFCY
  If fstat : Raz [F:FCY] : End : Endif
Endif

# Lecture STATIONBOX pour pesee matiere
# recuperation du depot/emplacement s'ils existent
Read [F:SBX]SBX0=GSCA1BOX;GSCA1MFGFCY
If !fstat
  # gestion des dépôts au niveau de l'appli. et sur le site courant
  If (GWRHACT = 2 & [F:FCY]WRHGES = 2)
    WDEPOT = [F:SBX]WRH
    WLOC   = [F:SBX]LOC
  Endif
  If GWRHACT = 1 |(GWRHACT = 2 & [F:FCY]WRHGES =1)
    WLOC   = [F:SBX]LOC
  Endif
Else
  Raz [F:SBX]
Endif

End

###########################################################################
# DesAllocation total composant
###########################################################################
Subprog DES_ALLOCATION_A (NUMOF , NUMCOMPOSANT, LLIN, LSEQ)
Value    Char    NUMOF
Value    Char    NUMCOMPOSANT
Value    Integer LLIN
Value    Integer LSEQ

Local    Integer WRET : WRET=0
Local    Decimal QTYBESOIN  : QTYBESOIN=0

# des-Allocation composant
Call ALLOC_MAT ("A",1,NUMOF,2,1,WRET,NUMCOMPOSANT,LLIN,LSEQ,QTYBESOIN) From MFGALL

End

###########################################################################
# DesAllocation du reste à peser composant
###########################################################################
Subprog DES_ALLOCATION_R (NUMOF , NUMCOMPOSANT, LLIN, LSEQ)
Value    Char    NUMOF
Value    Char    NUMCOMPOSANT
Value    Integer LLIN
Value    Integer LSEQ

Local    Integer WRET : WRET=0
Local    Decimal QTYBESOIN  : QTYBESOIN=0
# des-Allocation composant
Call ALLOC_MAT ("R",1,NUMOF,2,1,WRET,NUMCOMPOSANT,LLIN,LSEQ,QTYBESOIN) From MFGALL

End


###########################################################################
# Allocation composant
# Génération  Scalessto suivant composant
# En 1.4.0 il faudra vérifier que les allocs de l'OF sont compatibles avec les règles de gestion suivi
#           si on doit allouer alors tenir compte des règles de gestion suivi
#           N'extraire que des lots compatibles avec les règles de gestion suivi
###########################################################################
# llc 03.02 ajout date
Subprog XTRACT_ALLOCATION (NUMOF , NUMCOMPOSANT, QTYBESOIN, LLIN, LSEQ,LALL,LDAT)
Value    Char    NUMOF
Value    Char    NUMCOMPOSANT
Value    Decimal QTYBESOIN
Value    Integer LLIN
Value    Integer LSEQ
Value    Integer LALL
Value    Date    LDAT

Local    Integer WRET : WRET=0
Local    Char    DEPOT(GLONWRH)     : DEPOT      = ""
Local    Char    LOC(GLONEMP)       : LOC        = ""    # emplacement - mm 01.11
Local    Integer WPATLOC            : WPATLOC    = 0     # mm 01.11
# Issue 80989 - 2012-03-22 by SR
Local    Decimal WALLQTY,WALLQTYSHT
# 92824 mm 09.2013
Local    Integer WLOTINVALIDE         : WLOTINVALIDE = 0 # WLOTINVALIDE = 1-> lot périmé
                                                         # WLOTINVALIDE = 2-> mélange lot interdit
                                                         # WLOTINVALIDE = 3-> lot non consommable

# 41612 mm 06.07
If clalev([F:STA]) = 0 : Local File STOALL [STA] : Endif
If clalev([F:STO]) = 0 : Local File STOCK [STO] : Endif

# lecture du dépôt/emplacement associés au box
Call LEC_WRH(DEPOT,LOC)
If LOC<>""
  If instr(1,LOC,"*")<>0
  # l'emplacement du box comporte le caractère "*"
     WPATLOC =1
  Endif
Endif

# lecture article-site
Read [F:ITF]ITF0 = NUMCOMPOSANT;GSCA1MFGFCY
If fstat : Raz [F:ITF] : Endif

Link [STA] With [F:STO]STO0 = [F:STA]STOFCY;[F:STA]STOCOU As [LOTX]
& Where [F:STA]VCRNUM=NUMOF and [F:STA]ITMREF=NUMCOMPOSANT and [F:STA]VCRLIN=LLIN and [F:STA]VCRSEQ =LSEQ
& and [F:STA]ALLTYP = 2
& Order By Key STA0
For [LOTX]
    WRET = func STKLIB.CTRLOTPER([F:STA]ITMREF, [F:STO]LOT, [F:STO]SLO, date$)
    If WRET=1
        # 92824 mm 09.2013 - Si allocation sur un lot périmé, il faut avertir qu'on désalloue
        WLOTINVALIDE = 1
        # Si la matière a été allouée sur un lot périmé, il faut la désallouer
        WRET = 0
        Call ALLOC_MAT ("A",1,NUMOF,2,1,WRET,NUMCOMPOSANT,LLIN,LSEQ,QTYBESOIN) From MFGALL
    Endif

        # si ni le dépôt ni l'emplacement ne sont alimentés dans le box ,on peut allouer n'importe où, donc rien à désallouer
    # l'article doit être géré en emplacement pour qu'un empl. soit obligatoirement précisé sur ses lignes de stock
    If ( DEPOT <> "" | LOC <> "" ) & [F:ITF]LOCMGTCOD = 2
      If GPRIALL  = 2 # Priorité au box de pesée
          # on gère les dépôts dans l'appli + au niveau du site
          If GWRHACT = 2 & [F:FCY]WRHGES = 2
            # si la matière a été allouée sur un dépôt/emplacement différent du ceux du box de pesée
            # il faut la désallouer
            Case WPATLOC
              When 0 :  # allocation sur un dépôt différent de celui du box
                        If DEPOT <> [F:STO]WRH
                          Call SUP_ALLOC (NUMOF,LLIN,LSEQ,NUMCOMPOSANT,[F:STA]STOFCY,[F:STA]STOCOU,[F:STA]SEQ)
                        Else
                          # si emplacement précisé dans le box, vérifier qu'il correspond à celui de la ligne de stock
                          If LOC <> "" &  LOC <> [F:STO]LOC
                            Call SUP_ALLOC (NUMOF,LLIN,LSEQ,NUMCOMPOSANT,[F:STA]STOFCY,[F:STA]STOCOU,[F:STA]SEQ)
                          Endif
                        Endif
              When 1 :  If DEPOT <> [F:STO]WRH
                          Call SUP_ALLOC (NUMOF,LLIN,LSEQ,NUMCOMPOSANT,[F:STA]STOFCY,[F:STA]STOCOU,[F:STA]SEQ)
                        Else
                          If LOC <> "" & !pat([F:STO]LOC,LOC)
                            Call SUP_ALLOC (NUMOF,LLIN,LSEQ,NUMCOMPOSANT,[F:STA]STOFCY,[F:STA]STOCOU,[F:STA]SEQ)
                          Endif
                        Endif
            Endcase
          Endif

         # pas de gestion dépôt au niveau de l'appli ou du site
         # si les allocations ne sont pas faites sur l'emplacement du box, on désalloue
          If GWRHACT = 1 |(GWRHACT = 2 & [F:FCY]WRHGES =1)
            Case WPATLOC
              When 0 : If LOC <> [F:STO]LOC
                            Call SUP_ALLOC (NUMOF,LLIN,LSEQ,NUMCOMPOSANT,[F:STA]STOFCY,[F:STA]STOCOU,[F:STA]SEQ)
                       Endif
              When 1 : If !pat([F:STO]LOC,LOC)
                            Call SUP_ALLOC (NUMOF,LLIN,LSEQ,NUMCOMPOSANT,[F:STA]STOFCY,[F:STA]STOCOU,[F:STA]SEQ)
                       Endif
            Endcase
          Endif
      Endif
    Endif
Next

# relecture de [MFM] car on ne pointe plus forcément sur l'enregistrement de départ(cf.MAJMFGHEAD From MFGLIB )
If NUMCOMPOSANT <> [F:MFM]ITMREF | LSEQ <>[F:MFM]BOMSEQ
  Read [MFM]MFM0=NUMOF;LLIN;LSEQ;NUMCOMPOSANT
  If fstat : Raz [MFM] : Endif
Endif

# Pas d'allocations auto, mais
# on ne doit pas arriver dans la centrale avec du stock alloué en global
If GALLAUT = 1
  If  [F:MFM]ALLSTA > 1 & [F:MFM]ALLSTA < 4
    # si une matière est allouée globale, il faut la désallouer
    Call ALLOC_MAT ("A",1,NUMOF,2,1,WRET,NUMCOMPOSANT,LLIN,LSEQ,QTYBESOIN) From MFGALL
  Endif
Else
  # Création d'allocations détaillées en automatique
  Case GPRIALL
    When 1 : If  (![F:MFM]ALLQTY & LALL = 2 & WLOTINVALIDE = 0)|([F:MFM]ALLSTA > 1 & [F:MFM]ALLSTA < 4)
    # Issue number 80889- 2012-03-20 by SR : on force l'allocation si allocs globales
    # Priorité aux alloc OF : création d'allocation auto seulement si la matière
    # ne possède aucune allocation en arrivant dans la Cdp
                Call ALLOC_MAT ("C",1,NUMOF,2,1,WRET,NUMCOMPOSANT,LLIN,LSEQ,QTYBESOIN) From MFGALL
             Endif
    When 2 : If  LALL = 2
    # Priorité aux alloc du box de pesée : pas de restriction à l'allocation auto
                Call ALLOC_MAT ("C",1,NUMOF,2,1,WRET,NUMCOMPOSANT,LLIN,LSEQ,QTYBESOIN) From MFGALL
             Endif
  Endcase
Endif

# Issue 80989 - 2012-03-22 by SR :Si l'allocation ne sera pas consommable, il faut désallouer
If [F:MFM]ALLSTA <> 1
    Read [F:BTS]BTS0 = 61;GWEITRSNUM
    If fstat : Raz [F:BTS] : Endif
    Call CTLALL([F:MFM]MFGFCY,10,NUMOF,LLIN,LSEQ,6,[F:BTS]TRSCODS,
&                       "",1,WALLQTY,WALLQTYSHT,WRET) From STKALL
    If WALLQTYSHT <> 0
      Call ALLOC_MAT ("A",1,NUMOF,2,1,WRET,NUMCOMPOSANT,LLIN,LSEQ,QTYBESOIN) From MFGALL
      # 92824 mm 09.2013 - Si allocation non consommable, il faut avertir qu'on désalloue
      WLOTINVALIDE = 3
    Endif
Endif

# Issue 83006 - 2012-06-19 by MM: ajout des 2 paramètres DEPOT et LOC
Call EXTRACTION_LOT(NUMOF , NUMCOMPOSANT, QTYBESOIN, LLIN, LSEQ,LALL,LDAT,WPATLOC,DEPOT,LOC,WLOTINVALIDE)

End

###########################################################################
Subprog EXTRACTION_LOT(NUMOF , NUMCOMPOSANT, QTYBESOIN, LLIN, LSEQ,LALL,LDAT,WPATLOC,DEPOT,LOC,WLOTINVALIDE)
Value    Char    NUMOF
Value    Char    NUMCOMPOSANT
Value    Decimal QTYBESOIN
Value    Integer LLIN
Value    Integer LSEQ
Value    Integer LALL
Value    Date    LDAT
Value    Integer WPATLOC
Value    Char    DEPOT
Value    Char    LOC
Value    Integer WLOTINVALIDE : WLOTINVALIDE = 0   # 92824 mm 09.2013

Local    Integer WRET : WRET=0
# sr 05.02 contrôle sur les x premiers caratères
Local    Char    WLOT(GLENLOT), WFILTRE_LOT(GLENLOT)
Local    Integer WLOT_KO
Local    Char    WCRITSTO(240)
Local    Integer SAVIUM : SAVIUM = adxium
Local    Char    WLOC  # mm 06.10 - intitulé traduisible

# CATUA X3-30176.sn Component Sequence Control
Local Shortint LCHKOUTSEQ
Local Char     LITMNXTSEQ

Call CHECK_OUTOFSEQ(NUMOF,LLIN,LSEQ,LCHKOUTSEQ,LITMNXTSEQ) From SCALEXCHAN
# CATUA X3-30176.en

# Gestion mélange des lots sr 03.02
# Lire la fiche ISM associée à l'article
# Si mélange des lots est autorisée : Rien
# Si mélange lot non autorisé :
#    1 : Si les allocations générées sont multi lots, on désalloue
#    2 : Si le mélange lot est interdit pour la matière et qu'un suivi existe déjà et que le lot
#        sorti n'est pas le lot alloué, on désalloue
#    3 : Si le mélange lot est interdit sur l'OF et qu'un suivi existe et que le lot sorti n'est
#        pas le lot alloué on désalloue

#lecture transaction à utiliser
Read [F:BTS]BTS0 = 61;GWEITRSNUM
If fstat : Raz [F:BTS] : Endif

# 94920 mm 01.2014 - Repositionnement sur l'article courant
# lecture article
Read [F:ITM]ITM0 = NUMCOMPOSANT
If fstat : Raz [F:ITM] : Endif

# Lecture de la règle de gestion à utiliser
Call LECSRU([F:STO]STOFCY,[F:ITM]TCLCOD,6,[F:BTS]TRSCODS,"",WRET)
&           From STKLIB
If WRET<>0 : Raz [F:SRU]: Endif
# Stockage dans WCRITSTO des statuts/sous-statuts autorisés
Call CTRL_STATUT("[F:STO]","",WCRITSTO) From STKALL

# lecture article-site
Read [F:ITF]ITF0 = NUMCOMPOSANT;GSCA1MFGFCY
If fstat : Raz [F:ITF] : Endif

#--- Lecture catégorie article/site
Read [ITG]ITG1=[F:ITM]TCLCOD;GSCA1MFGFCY
If fstat
      Read [ITG]ITG1=[F:ITM]TCLCOD;""
      If fstat
         Raz [F:ITG]
      Endif
Endif
Read [F:TRU]TRU0 = [F:ITG]ALLRULMFG
If fstat : Raz [F:TRU] : Endif

# lecture ism pour code mélange lots
Read [HSH]HSH0=[F:ITF]ISM
If fstat Raz[F:HSH] : Endif

# si mélange lot interdit
# les allocations sont-elles multi-lots ou existe-t-il déjà un suivi portant sur un autre lot ?
# sr 05.02 On ne travaille que sur les x premiers caractères (x = GLENLOT)
# sr 05.05 en 140 on travaille sur le lot en assumant que le discriminant est le sous-lot
If [F:HSH]LOTSEV > 1
    WLOT_KO = 1
    Raz WFILTRE_LOT
    Raz WLOT
    # llc 05.02 Performances
    Filter [STA] Where  ITMREF=NUMCOMPOSANT & VCRTYP=10 & ALLTYP=2 & VCRNUM = NUMOF & VCRLIN = LLIN & VCRSEQ = LSEQ
&                Order By Key STA2
    For [STA]
        Read [STO]STO0 = [F:STA]STOFCY;[F:STA]STOCOU
        If fstat : Raz [F:STO] : Endif
        If WLOT = "" : WLOT = [F:STO]LOT: Endif
        If WLOT <> [F:STO]LOT
                   WLOT_KO = 2
                   Break
        Endif
    Next
    Filter [F:STA]
    Case [F:HSH]LOTSEV
            When 2 :   Filter [F:STJ] Where  STOFCY = GSCA1MFGFCY & ITMREF = NUMCOMPOSANT &
&                      TRSTYP = 6 & VCRTYP = 12 & VCRTYPORI = 10 & VCRNUMORI = NUMOF &
&                      VCRLINORI = LLIN &  REGFLG =  1


           When 3  :   Filter [F:STJ] Where  STOFCY = GSCA1MFGFCY & ITMREF = NUMCOMPOSANT &
&                      TRSTYP = 6 & VCRTYP = 12 & VCRTYPORI = 10 & VCRNUMORI = NUMOF &
&                      REGFLG =  1

    Endcase
    For [F:STJ]STJ0 With Nohint
            If [F:HSH]LOTSEV = 2
                Read [F:MKM]MKM0 = [F:STJ]VCRNUM;[F:STJ]VCRLIN
                If fstat : Raz [F:STJ] : Endif
                If [F:MKM]BOMSEQ <> LSEQ : Goto NEXTSTJ : Endif
            Endif

            If WFILTRE_LOT = "" : WFILTRE_LOT = [F:STJ]LOT : Endif
            If WLOT <> [F:STJ]LOT
               WLOT_KO = 2
               Break
            Endif
$NEXTSTJ
    Next
    Filter [F:STJ]
    If WLOT_KO = 2
        # des-Allocation composant
        Call ALLOC_MAT ("A",1,NUMOF,2,1,WRET,NUMCOMPOSANT,LLIN,LSEQ,QTYBESOIN) From MFGALL
        WLOTINVALIDE = 2    # 92824 mm 08.2013
    Endif
Endif

# ouverture  masque invisible ALLSCALSTO  (tableau de 300 positions)

If clalev([M:ASSW])  <= 0 : Local Mask ALLSCALSTO   [ASSW]  : Endif


Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218

ALLOCATIONS = func OPTLIB.FILNAM(GFCY,"ilsto",0)

adxium = GUTF8        # 44767 mm 08.09
adxifs = ";"
adxirs = chr$(10)


Raz  [M:ASSW]

Local Decimal  WDISPONIBLE
Local Decimal  WALLOUE
Local Decimal  WQTETOT
Local Decimal  WRST_DISPO
Local Decimal  WINIT_QTY

Local Char     WCHAIN, WSPECHAR, WSTASHO
Local Char     WTKS     # libellé traduisible

# Ouverture du fichier en écriture
Openo ALLOCATIONS,0 Using [ILS] # mm 01.2013

# Lecture ITMMASTER
    Read [ITM]ITM0=NUMCOMPOSANT
    If fstat Raz[F:ITM] : Endif

#Récupération du ou des lots
If WFILTRE_LOT  <> ""
          Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO
&                    As [LNK]
&                    Where ITMREF = NUMCOMPOSANT  & LOT = WFILTRE_LOT & [F:SLF]STOFCY = GSCA1MFGFCY
&                    Order By Key STL0 Asc
Else
    Case [F:TRU]LOTMGT
        When 1 : # Par lot
          Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO
&                    As [LNK]
&                    Where ITMREF = NUMCOMPOSANT & [F:SLF]STOFCY = GSCA1MFGFCY
&                    Order By Key STL0 Asc
        When 2 : # FIFO
          Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO
&                    As [LNK]
&                    Where ITMREF = NUMCOMPOSANT & [F:SLF]STOFCY = GSCA1MFGFCY
&                    Order By Key STL1 Asc
        When 3 : # FEFO
          Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO
&                    As [LNK]
&                    Where ITMREF = NUMCOMPOSANT & [F:SLF]STOFCY = GSCA1MFGFCY
&                    Order By Key STL2 Asc
        When 4 : # LIFO
          Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO
&                    As [LNK]
&                    Where ITMREF = NUMCOMPOSANT & [F:SLF]STOFCY = GSCA1MFGFCY
&                    Order By Key STL1 Desc
        When Default :
          Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO
&                    As [LNK]
&                    Where ITMREF = NUMCOMPOSANT & [F:SLF]STOFCY = GSCA1MFGFCY
&                    Order By Key STL0 Asc
    Endcase
    Raz [F:STL],[F:SLF]
Endif

#Lecture des lots non nuls et non périmés a date livraison + marge

nolign = 1

For [LNK]
  If sum([F:SLF]AAACUMQTY,[F:SLF]QQQCUMQTY,[F:SLF]RRRCUMQTY) <> 0
    # 92824 mm 02.2014
    Case [F:SRU]SHLLOT
     When 1          : If [F:STL]SHLDAT = [0/0/0] | [F:STL]SHLDAT >= date$
                              Gosub LEC_STOCKS
                       Endif
     When 2          : If [F:STL]DLUDAT = [0/0/0] | [F:STL]DLUDAT >= date$
                             Gosub LEC_STOCKS
                       Endif
     When 3          : Gosub LEC_STOCKS
   Endcase
  Endif
Next
Filter [STL]
Filter [SLF]

[M:ASSW]NBLIG = nolign

# deuxieme boucle pour remplir le disponible et l alloue par rapport au sta

# llc 05.02 Performances
Filter [STA] Where  ITMREF=NUMCOMPOSANT & VCRTYP=10 & ALLTYP=2 & VCRNUM = NUMOF & VCRLIN = LLIN & VCRSEQ = LSEQ
&            Order By Key STA2
For [STA]

    # recherche de la ligne tableau correspondante
    IOK = 0
    For WI = 0 To [M:ASSW]NBLIG -1
        If [M:ASSW]STOCOU(WI) = [F:STA]STOCOU : IOK = 1 : Break : Endif
    Next WI

    If !IOK : Goto NEXT_STA : Endif

    # point d'entrée  pour permettre de court-circuiter la MAJ de [M:ASSW] - 105569 mm 02.2015
    #-> utile en cas de changement d'emplacement
    # Mettre GPE = 0 pour ne pas prendre en compte la ligne
    GPE = 1
    GPOINT = "MAJ_ASSW" : Gosub ENTREE From EXEFNC
    If GPE = 1
      [M:ASSW]XPECFLG(WI)           = 1
      [M:ASSW]DISPONIBLE (WI)     += [F:STA]QTYSTU
      [M:ASSW]ALLOUE     (WI)     += [F:STA]QTYSTU
      [M:ASSW]SEQ        (WI)     =  [F:STA]SEQ
      # on enlève de la qté totale, la qté allouée pour cette MP
      # si cette qté est égale à 0 c'est que tout est alloué pour cette MP et que donc cette ligne de stock
      # doit être consommée en priorité
      [M:ASSW]WRST_DISPO (WI)     =  [M:ASSW]QTETOT (WI) - [F:STA]QTYSTU
      If [M:ASSW]WRST_DISPO (WI) < 0
         [M:ASSW]WRST_DISPO (WI) = 0
      Endif
      # sr 11.04 proposer en dernier les lignes de stock allouées par ailleurs
      # toute la ligne de stock n'est pas allouée pour cette MP
      If [M:ASSW]WRST_DISPO (WI) = 0
         [M:ASSW]WMULTI (WI)     = 0
      Else
          # le disponible à ce moment là correspond au réel dispo + qté allouée pour cette MP
          # si ce disponible = qté totale cela veut dire que ce qui n'est pas alloué pour cette MP n'est pas non plus
          # alloué sur une autre MP
          If [M:ASSW]DISPONIBLE(WI) = [M:ASSW]QTETOT (WI)
                [M:ASSW]WMULTI (WI) = 1
          Else
          # il y a de l'alloué par ailleurs
                [M:ASSW]WMULTI (WI) = 2
          Endif
      Endif
      # fin sr 11.04
    Endif
$NEXT_STA
Next

Filter [STA]

# si magasin avancé non rensigné, les lignes allouées ont déjà été récupérées
If DEPOT<>"" | LOC <>""
  # boucle alternative aux boucles 1 & 2, utilisée en cas de priorité aux allocations de l'OF
  # ou Alloc auto autorisées ( cad cas où on peut avoir des allocations sur un emplacement ou
  # un dépôt non conforme au box de pesée)
  If (GPRIALL = 1 |GALLAUT =2)
    Gosub ALLOC_OF
  Endif
Endif

# troisième boucle pour éliminer les lignes non dispos
# de la fin au début, c'est plus simple pour supprimer ...
For WI = [M:ASSW]NBLIG - 1 To 0 Step -1
    If [M:ASSW]DISPONIBLE (WI)<= 0        # 52389 mm 02.09 - on n'affiche pas les quantités dispo < 0...
        Dela WI,1 [M:ASSW]NBLIG
        [M:ASSW]NBLIG -= 1
   Endif
Next WI

# tri pour afficher les lignes allouées en début de tableau
# sr 11.04 ajout de WMULTI
# sr 02.02 en mineur, on garde la date de péremption ou  la date de création selon le mode de destockage
Case [F:TRU]LOTMGT
  When 1 :
        Sorta [M:ASSW]NBLIG [M:ASSW]NBLIG Order By [M:ASSW]XPECFLG(indice),[M:ASSW]WMULTI(indice),
&             [M:ASSW]WRST_DISPO(indice), [M:ASSW]WFIRST_ISS(indice)
  When 2 :
        Sorta [M:ASSW]NBLIG [M:ASSW]NBLIG Order By [M:ASSW]XPECFLG(indice),[M:ASSW]WMULTI(indice),
&             [M:ASSW]WRST_DISPO(indice), [M:ASSW]WFIRST_ISS(indice),[M:ASSW]LOTCREDAT(indice)
  When 3 :
        Sorta [M:ASSW]NBLIG [M:ASSW]NBLIG Order By [M:ASSW]XPECFLG(indice),[M:ASSW]WMULTI(indice),
&             [M:ASSW]WRST_DISPO(indice),[M:ASSW]WFIRST_ISS(indice),[M:ASSW]SHLDAT(indice)
  When 4 :
        Sorta [M:ASSW]NBLIG [M:ASSW]NBLIG Order By [M:ASSW]XPECFLG(indice),[M:ASSW]WMULTI(indice),
&             [M:ASSW]WRST_DISPO(indice),[M:ASSW]WFIRST_ISS(indice)
  When Default :
        Sorta [M:ASSW]NBLIG [M:ASSW]NBLIG Order By [M:ASSW]XPECFLG(indice),[M:ASSW]WMULTI(indice)
Endcase

# si pas de ligne disponible on ecrit sto avec seulement le composant
If [M:ASSW]NBLIG = 0
     Wrseq NUMCOMPOSANT Using [ILS]  # mm 01.2013
     Openo  Using [ILS] # mm 01.2013
     End
Endif

# derniere boucle pour ecrire le fichier sto
For WI = 0 To [M:ASSW]NBLIG -1

    # Lecture STOLOT
    Read [STL]STL0=NUMCOMPOSANT;[M:ASSW]LOT (WI); [M:ASSW]SLO (WI)
    If fstat Raz[F:STL] : Endif
    Read [SLF]SLF0=NUMCOMPOSANT;[M:ASSW]LOT (WI); [M:ASSW]SLO (WI); GSCA1MFGFCY
    If fstat Raz[F:SLF] : Endif

    # Lecture TABSTASTO
    Read [TST]TST0=[M:ASSW]STA (WI)
    If fstat Raz[F:TST] : Endif

# sr 02.03 on prend l'intitulé court
#    WCHAIN         = [F:TST]STADES
    Call GET_ATEXTRA("TABSTASTO","STASHOAXX",GLANGUE,WCHAIN) From TRTX3TEX
#    [F:TST]STADES  = WCHAIN
    WSTASHO=WCHAIN
    Call CHANGE_CHAR(WSTASHO)

    WDISPONIBLE = [M:ASSW]DISPONIBLE (WI)
    WALLOUE     = [M:ASSW]ALLOUE     (WI)
    WQTETOT     = [M:ASSW]QTETOT     (WI)
    WRST_DISPO  = [M:ASSW]WRST_DISPO (WI)
    WINIT_QTY   = [M:ASSW]WINIT_QTY  (WI)

    Call CAL_POIDS (NUMCOMPOSANT,WDISPONIBLE,WDISPONIBLE)
    Call CAL_POIDS (NUMCOMPOSANT,WALLOUE,WALLOUE)
    Call CAL_POIDS (NUMCOMPOSANT,WQTETOT,WQTETOT)
    Call CAL_POIDS (NUMCOMPOSANT,WRST_DISPO,WRST_DISPO)
    Call CAL_POIDS (NUMCOMPOSANT,WINIT_QTY,WINIT_QTY)

    Raz[F:TKS]
    Raz[F:TGT]
          For [TKS]TKS0 Where TKSEMP = [M:ASSW]LOC (WI)      &
&                             TKSITM =  NUMCOMPOSANT

              For [TGT]TGT0 Where TGTTKS = [F:TKS]TKS  &
&                                 STI    = GSCA1STI &
&                                 BOX    = GSCA1BOX
                  Break
              Next
              Break
          Next

#           06.10 mm - libellé traduisible
            Call LECTEXTRA (WTKS,"TANKS","CGDDESAXX",[F:TKS]TKS,[F:TKS]FCY) From ATEXTRA
#           écriture le l'enregistrement ALLOCATION

    # CATUA X3-30176.sn
    If LCHKOUTSEQ = 1
        Wrseq NUMCOMPOSANT;[M:ASSW]LOT (WI);[M:ASSW]SLO (WI);[M:ASSW]LOC (WI);WLOC;
&             WDISPONIBLE;WALLOUE;WQTETOT;[F:ITM]WEU;[F:STL]SHLDAT;
&             [M:ASSW]STA(WI);WSTASHO;[F:STL]POT;
&             [F:TKS]TKS;WTKS;[F:TGT]TGTGTS;[M:ASSW]STOCOU(WI);[M:ASSW]SEQ(WI);
&             WRST_DISPO;WINIT_QTY;WLOTINVALIDE;LCHKOUTSEQ;LITMNXTSEQ  Using [ILS]
    # CATUA X3-30176.en
    Else
        Wrseq NUMCOMPOSANT;[M:ASSW]LOT (WI);[M:ASSW]SLO (WI);[M:ASSW]LOC (WI);WLOC;
&             WDISPONIBLE;WALLOUE;WQTETOT;[F:ITM]WEU;[F:STL]SHLDAT;
&             [M:ASSW]STA(WI);WSTASHO;[F:STL]POT;
&             [F:TKS]TKS;WTKS;[F:TGT]TGTGTS;[M:ASSW]STOCOU(WI);[M:ASSW]SEQ(WI);
&             WRST_DISPO;WINIT_QTY;WLOTINVALIDE  Using [ILS]
    Endif


$NEXT_WI
Next WI

# fermeture de l'enregistrement

Openo  Using [ILS] # mm 01.2013
adxium = SAVIUM

End


###########################################################################
# lignes non trouvées parmi les lignes éligibles puisque non conforme à l'emplacement du box
# en cas de priorité aux allocations de l'OF : on récupère les lignes allouées quelque soit leur dépôt/l'emplacement
# idem en cas d'allocation auto où on alloue en fonction des règles d'allocations OF
##########################################################################
$ALLOC_OF
  nolign = [M:ASSW]NBLIG

  Link [STA] With [F:STO]STO0 = [F:STA]STOFCY;[F:STA]STOCOU As [ALLX]
& Where [F:STA]VCRNUM=NUMOF and [F:STA]ITMREF=NUMCOMPOSANT and [F:STA]VCRLIN=LLIN and [F:STA]VCRSEQ =LSEQ
& and [F:STA]ALLTYP = 2
& Order By Key STA0

  For [ALLX]
    # si les lignes de stock allouées depuis l 'OF sont sur l'emplacement du box, on les a déjà récupérées
    If [F:STO]WRH = DEPOT
      If LOC =""
        Goto NEXT_I
      Else
        Case WPATLOC
          When 0 :  If  LOC = [F:STO]LOC
                     Goto NEXT_I
                    Endif
          When 1 :  If (pat([F:STO]LOC,LOC) =1)
                     Goto NEXT_I
                    Endif
        Endcase
      Endif
    Endif
    [M:ASSW]XPECFLG    (nolign-1)   = 1
    [M:ASSW]DISPONIBLE (nolign-1)   =  [F:STO]QTYSTU - [F:STO]CUMALLQTY
    [M:ASSW]QTETOT     (nolign-1)   =  [F:STO]QTYSTU
    [M:ASSW]LOT        (nolign-1)   =  [F:STO]LOT
    [M:ASSW]SLO        (nolign-1)   =  [F:STO]SLO
    [M:ASSW]LOC        (nolign-1)   =  [F:STO]LOC
    [M:ASSW]STOCOU     (nolign-1)   =  [F:STO]STOCOU
    [M:ASSW]STA        (nolign-1)   =  [F:STO]STA
    [M:ASSW]STU        (nolign-1)   =  [F:ITM]STU
    [M:ASSW]LOTCREDAT  (nolign-1)   =  [F:STL]LOTCREDAT
    [M:ASSW]SHLDAT     (nolign-1)   =  [F:STL]SHLDAT
    [M:ASSW]WINIT_QTY  (nolign-1)   =  [F:STO]QTYSTU  # sera éventuellement réajustée plus bas
    If [F:STO]LASISSDAT <> [0/0/0]
      [M:ASSW]WFIRST_ISS(nolign-1) = 1
      Gosub FIND_INIT_QTY
    Else
      [M:ASSW]WFIRST_ISS(nolign-1) = 2
    Endif

    # Récupération intitulé type emplacement
    Read [TLO]TLO0=[F:STO]STOFCY;[STO]LOCTYP
    If !fstat
      Call LECTEXTRA (WLOC,"TABLOCTYP","DESAXX",[F:TLO]STOFCY,[F:TLO]LOCTYP) From ATEXTRA
    Endif
    # point d'entrée  pour permettre de court-circuiter la MAJ de [M:ASSW] - 105569 mm 02.2015
    #-> utile en cas de changement d'emplacement
    # Mettre GPE = 0 pour ne pas prendre en compte la ligne
    GPE = 1
    GPOINT = "MAJ_ASSW" : Gosub ENTREE From EXEFNC
    If GPE = 1
      [M:ASSW]DISPONIBLE (nolign-1)      += [F:STA]QTYSTU
      [M:ASSW]ALLOUE     (nolign-1)      += [F:STA]QTYSTU
      [M:ASSW]SEQ        (nolign-1)       =  [F:STA]SEQ
      [M:ASSW]WRST_DISPO (nolign-1)       =  [M:ASSW]QTETOT (nolign-1) - [F:STA]QTYSTU
      If [M:ASSW]WRST_DISPO  (nolign-1) < 0
         [M:ASSW]WRST_DISPO  (nolign-1)   = 0
      Endif
      If [M:ASSW]WRST_DISPO (nolign-1)= 0
         [M:ASSW]WMULTI (nolign-1)    = 0
      Else
        If [M:ASSW]DISPONIBLE(nolign-1)= [M:ASSW]QTETOT (nolign-1)
            [M:ASSW]WMULTI (nolign-1) = 1
        Else
            [M:ASSW]WMULTI (nolign-1) = 2
        Endif
      Endif
    Endif
    nolign += 1
 $NEXT_I
 Next

[M:ASSW]NBLIG =  nolign

Return
###########################################################################
# premiere boucle pour remplir le disponible par rapport au sto avec contrôle statuts
###########################################################################
$LEC_STOCKS
Local    Char    CRITERE(255)       : CRITERE    = ""
Local    Char    CRITERE1(255)      : CRITERE1   = ""
If clalev([F:TLO])  <= 0 : Local File TABLOCTYP  [TLO]  : Endif

# Préparation du filtre sur le magasin avancé
Gosub  SBX_FILTER
# si l'article-site n'est pas géré en emplacement : la totalité des lignes de stock est proposée
If [F:ITF]LOCMGTCOD < 2 : Raz CRITERE1 : Endif
If CRITERE1 = "" : CRITERE1 = "1=1" : Endif

For [STO]STO3 Where STOFCY = GSCA1MFGFCY   &
&                   ITMREF =  NUMCOMPOSANT &
&                   LOT    =  [F:STL]LOT   &
&                   SLO    =  [F:STL]SLO   &
&                   LOCCAT <= 1            &
&                   evalue(CRITERE1)

       If ([F:STO]CUNLOKFLG<> 2& [F:STO]QLYCTLDEM="" & evalue(WCRITSTO))
          #point d'entrée  pour permettre des filtres supplémentaires
          # Mettre GPE = 0 pour ne pas prendre en compte la ligne
          GPE = 1
          GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
          If GPE = 1
              [M:ASSW]XPECFLG    (nolign-1)   = 2
              [M:ASSW]DISPONIBLE (nolign-1)   =  [F:STO]QTYSTU - [F:STO]CUMALLQTY
              [M:ASSW]QTETOT     (nolign-1)   =  [F:STO]QTYSTU
              [M:ASSW]LOT        (nolign-1)   =  [F:STO]LOT
              [M:ASSW]SLO        (nolign-1)   =  [F:STO]SLO
              [M:ASSW]LOC        (nolign-1)   =  [F:STO]LOC
              [M:ASSW]STOCOU     (nolign-1)   =  [F:STO]STOCOU
              [M:ASSW]STA        (nolign-1)   =  [F:STO]STA
              [M:ASSW]STU        (nolign-1)   =  [F:ITM]STU
              [M:ASSW]LOTCREDAT  (nolign-1)   =  [F:STL]LOTCREDAT
              [M:ASSW]SHLDAT     (nolign-1)   =  [F:STL]SHLDAT
              [M:ASSW]WINIT_QTY  (nolign-1)   =  [F:STO]QTYSTU  # sera éventuellement réajustée plus bas
              If [F:STO]LASISSDAT <> [0/0/0]
                 [M:ASSW]WFIRST_ISS(nolign-1) = 1
                  Gosub FIND_INIT_QTY
              Else
                 [M:ASSW]WFIRST_ISS(nolign-1) = 2
              Endif

              # Récupération intitulé type emplacement
              Read [TLO]TLO0=[F:STO]STOFCY;[STO]LOCTYP
              If !fstat
                Call LECTEXTRA (WLOC,"TABLOCTYP","DESAXX",[F:TLO]STOFCY,[F:TLO]LOCTYP) From ATEXTRA
              Endif
              nolign += 1
         Endif
       Endif
  $NEXT_ENR
  Next

Return

#########################################################################
# mm 01.11
# suppression d'une allocation non conforme au dépôt/empl.,
# diminution de la quantité allouée de la matière et mise à jour de l'encours associé
#########################################################################
Subprog SUP_ALLOC(NUMOF,LLIN,LSEQNOM,NUMCOMPOSANT,LFCY,LSTOCOU,LSEQSTA )
Value    Char    NUMOF
Value    Integer LLIN
Value    Integer LSEQNOM
Value    Char    NUMCOMPOSANT
Value    Char    LFCY
Value    Integer LSTOCOU
Value    Integer LSEQSTA

Local    Decimal WQTYSTUACT_STA, WQTYSTU_STA
Local    Integer WRET : WRET = 0
Local    Date    WDAT
Local    Integer VCRTYP : VCRTYP = 10
Local    Char    WBPR(GLONBPR)
Local    Char    WADD(GLONADD)
Local    Integer WSCO(GLONSCO)

If clalev([M:ORDK])= 0 : Local Mask ORDK   [ORDK] : Endif
If clalev([F:STA1]) = 0 : Local File STOALL [STA1] : Endif

Call DEBTRANS From GLOCK
Trbegin [STA],[MFM]


WQTYSTUACT_STA = [F:STA]QTYSTUACT
WQTYSTU_STA    = [F:STA]QTYSTU
#Suppression de l'allocation non conforme au dépôt/empl.du box
Call SUPALL(LFCY,NUMCOMPOSANT,LSTOCOU,LSEQSTA,WRET) From STKALL
If WRET <> 0 : GOK = 0 : Gosub AB_TRT1 : End : Endif

# lecture matière
Readlock [MFM]MFM0=NUMOF;LLIN;LSEQNOM;NUMCOMPOSANT
If fstat=1
   GOK=-1 : GLOCK="$MFGMAT"-NUMCOMPOSANT :Gosub AB_TRT1 : End
Elsif fstat
   GOK=0  : Call RSTA("MFM",NUMCOMPOSANT) From GLOCK
   Gosub AB_TRT1 : End
Endif

# Relire [F:STA] pour savoir si on doit créer une allocation de rupture ou la modifier
Filter [STA1] Where STOFCY =LFCY & ITMREF = NUMCOMPOSANT & STOCOU= 0 & VCRNUM=NUMOF
&              Order By Key STA0
  Read [STA1] First
Filter [STA1] # résolution gel d'écran ? mm 02.2013
  If !fstat
    # modification de l'allocation de rupture
    Call MODALL(LFCY,NUMCOMPOSANT,0,[F:STA1]SEQ,WQTYSTUACT_STA,WRET) From STKALL
  Else
    # création d'une allocation de rupture
    WALL=4
    WDAT=[0/0/0]
     #--- TS 106217 ajout paramètre LECC (avant dernier)
     Call CREALL (WALL,LFCY,NUMCOMPOSANT,0,WDAT,0,WQTYSTUACT_STA,
&                 VCRTYP,NUMOF,LLIN,LSEQNOM,"",[F:MFM]RETDAT,
&                 "","","","","","",0,0,"","",WBPR,
&                 WADD,WSCO,"",WRET) From STKALL
  Endif
If WRET<>0:  GOK=0 : Gosub AB_TRT1 : End : Endif   # résolution gel d'écran ?  mm 02.2013

# lecture article
Read [F:ITM]ITM0 = NUMCOMPOSANT
If fstat : Raz [F:ITM] : Endif

#diminution de la quantité allouée de la matière
If [F:ITM]STOMGTCOD = 3
   [F:MFM]ALLQTY -= WQTYSTUACT_STA
   [F:MFM]SHTQTY += WQTYSTUACT_STA
Else
   [F:MFM]ALLQTY -= WQTYSTU_STA
   [F:MFM]SHTQTY += WQTYSTU_STA
Endif
If [F:MFM]ALLQTY < 0 : [F:MFM]ALLQTY = 0 : Endif
If [F:MFM]SHTQTY < 0 : [F:MFM]SHTQTY = 0 : Endif

# maj statut allocation
If [F:MFM]ALLQTY = 0 & [F:MFM]SHTQTY = 0
   [F:MFM]ALLSTA = 1
Else
   [F:MFM]ALLSTA    = 5
   # si rupture, maj statut allocation
   If [F:MFM]SHTQTY <> 0 : [F:MFM]ALLSTA -= 1 : Endif
Endif

Rewrite [F:MFM]
If fstat
  GOK = 0 : Call FSTA("MFM") From GLOCK : Gosub AB_TRT1 : End
Endif

# mise à jour de l'encours associé
Readlock [F:ORD]ORD0 = 6;[F:MFM]WIPNUM;[F:MFM]ITMREF
If fstat=1
  GOK=-1 : GLOCK="$ORDERS"-NUMCOMPOSANT :Gosub AB_TRT1 : End
Elsif fstat
  GOK=0  : Call RSTA("ORD",NUMCOMPOSANT) From GLOCK
  Gosub AB_TRT1 : End
Endif
# mise à jour de l'encours
Call UPDATE_MFX("M", [F:ORD]PJT, [F:ORD]BOMALT, 0) From MFGLIBM

# v6 affectations
Gosub MAJ_MTO_MFM From MFGMTOLIB

Gosub MAJMFGHEAD From MFGLIB

Rewrite [MFG]
If fstat=1  GOK=-1: LRET = 1 : GLOCK="$MFGHEAD"-LMFGNUM              : Gosub AB_TRT1 : End
Elsif fstat GOK=0 : LRET = 1 : Call RSTA("MFG", LMFGNUM) From GLOCK  : Gosub AB_TRT1 : End : Endif

Commit

End

#########################################################################
# recherche de la quantité initiale de la ligne de stock
# on appliquera le % solde emballage à cette quantité sur la dernière pesée d'une MP si emballage fournisseur
# pour savoir si la ligne doit être soldée automatiquement (mouvement MAJ_FINCONTENANT)
$FIND_INIT_QTY
Filter [F:STJ] Where STOFCY = [F:STO]STOFCY & UPDCOD = 2 & ITMREF = [F:STO]ITMREF & LOT = [F:STO]LOT &
&                    SLO = [F:STO]SLO & SERNUM = [F:STO]SERNUM & PCU = [F:STO]PCU & PCUSTUCOE = [F:STO]PCUSTUCOE &
&                    LOC = [F:STO]LOC & STA = [F:STO]STA & PALNUM = [F:STO]PALNUM & CTRNUM = [F:STO]CTRNUM &
&                    STOFLD1 = [F:STO]STOFLD1 & STOFLD2 = [F:STO]STOFLD2 &
&                    QLYCTLDEM = [F:STO]QLYCTLDEM & OWNER = [F:STO]OWNER & REGFLG <> 2 & QTYSTU > 0
Read [F:STJ]STJ0 First
Filter [F:STJ]    # mm 02.2013
If !fstat [M:ASSW]WINIT_QTY(nolign-1) = [F:STJ]QTYSTU : Endif
Return



##########################################################################
# Maj Allocation de la pesée   /lecture ScalesAll
###########################################################################
Subprog MAJ_ALLOCATIONS (LCODE)
Value Char LCODE

Local Char    NUMOF          (GLONVCR)  # 57505 mm 08.09
Local Char    WFIL           (06)
Local Char    F_NUMOF        (GLONVCR)  # 57505 mm 08.09
Local Char    NUMCOMPOSANT   (20)
Local Char    F_NUMCOMPOSANT (20)
Local Integer LSEQ
Local Integer F_LSEQ
Local Integer LLIN
Local Integer F_LLIN
Local Integer WRET : WRET=0

# pour les allocs
Local Integer I, WOPT, WWIN, WSTOCOU
Local Decimal WALLQTY, WSHTQTY, WQTUSTUACT
Local Date    WDTE
Local Char    WSTA, WLOC, WLOT, WSLO


Raz  F_NUMOF
Raz  F_NUMCOMPOSANT
Raz  F_LSEQ
Raz  F_LLIN

# ouverture wgg pour buffer parametre document allocation
If clalev([F:WGG])  <= 0 : Local File WEIGHING   [WGG]  : Endif

If clalev([M:ASSW]) = 0 : Local Mask ALLSCALSTO   [ASSW]  : Endif
If clalev([M:ALP])  = 0 : Local Mask ALLPAR       [ALP]   : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER    [ITM]   : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT   [ITF]   : Endif
If clalev([F:ITV])  = 0 : Local File ITMMVT       [ITV]   : Endif
If clalev([F:ITG])  = 0 : Local File ITMCATEG     [ITG]   : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT       [MFM]   : Endif
If clalev([F:STO])  = 0 : Local File STOCK        [STO]   : Endif
If clalev([F:STL])  = 0 : Local File STOLOT       [STL]   : Endif
If clalev([F:SLF])  = 0 : Local File STOLOTFCY    [SLF]   : Endif
If clalev([F:STA])  = 0 : Local File STOALL       [STA]   : Endif

Local Char ALLFILE (200)

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218

# transfert fichiers allocation du client vers le serveur
Call CSV2ILFIL(GFCY,"ilall","X3ScalesAll") From OPTLIB

ALLFILE = func OPTLIB.FILNAM(GFCY,"ilall",0)
adxifs = ";"
adxirs = chr$(10)

# Ouverture du fichier en Lecture
 Openi ALLFILE Using [ALLF]

Raz  [M:ASSW]

nolign = 0
Repeat
    nolign += 1
    # 50271 mm 10.08 - récupération de STOCOU
    Rdseq F_NUMCOMPOSANT,[M:ASSW]LOT(nolign-1),[M:ASSW]SLO(nolign-1),[M:ASSW]LOC(nolign-1),
&    [M:ASSW]ALLOUE(nolign-1),[M:ASSW]WEU(nolign-1),[M:ASSW]STOCOU(nolign-1),[M:ASSW]STU(nolign-1),
&    F_LLIN,F_LSEQ,F_NUMOF,WFIL
&    Using [ALLF]
    If NUMOF = ""
        NUMOF        =  F_NUMOF
        NUMCOMPOSANT =  F_NUMCOMPOSANT
        LSEQ         =  F_LSEQ
        LLIN         =  F_LLIN
    Endif

Until fstat <> 0

# fermeture de l'enregistrement
Openi

# document allocation

If LCODE =  "38" Goto EDI_ALLOC : Endif

[M:ASSW]NBLIG = nolign -1

# boucle pour éliminer les lignes alloue a 0
For WI = [M:ASSW]NBLIG - 1 To 0 Step -1
    If [M:ASSW]ALLOUE (WI)= 0
        Dela WI,1 [M:ASSW]NBLIG
        [M:ASSW]NBLIG -= 1
   Endif
Next I

# boucle pour calculer l alloué en unite de poids

 For WI = 0 To [M:ASSW]NBLIG -1
     Call CAL_QUANTITE (NUMCOMPOSANT,[M:ASSW]ALLOUE(WI),[M:ASSW]ALLOUE(WI))
 Next WI

# maj des allocations
Gosub MAJ_ALLOCS

# llc 03.02
Read [MFM]MFM0=NUMOF;LLIN;LSEQ;NUMCOMPOSANT
If fstat : Raz [MFM] : Endif

# transfert des nouvelles allocations
# 87563 mm 02.2013 - qtybesoin peut-être différente de celle prévue dans la nomenclature dans le cas
# d'un excipient ( par définition)
If  (find([F:MFM]PKC,4,5,6,7,10))
  Call XTRACT_ALLOCATION (NUMOF , NUMCOMPOSANT,WALLQTY, LLIN, LSEQ,1,[F:MFM]RETDAT)   From SCALEXCHAN
Else
  Call XTRACT_ALLOCATION (NUMOF , NUMCOMPOSANT,0, LLIN, LSEQ,1,[F:MFM]RETDAT)   From SCALEXCHAN
Endif
Call TRF_STO  From SCALEXCHAN


# document allocation
If LCODE <> "34" End : Endif

$EDI_ALLOC

Local Char    NOMETA
Local Integer TYPETA

Raz [F:WGG]
[F:WGG]MFGNUM    = NUMOF
[F:WGG]MFGLIN    = LLIN
[F:WGG]BOMSEQ    = LSEQ
[F:WGG]ITMREF    = NUMCOMPOSANT
#Document allocation
NOMETA = GWEIRPTALL
TYPETA = 1

Gosub PESE_IMPRESSION

End

###########################################################################
$MAJ_ALLOCS
# transaction
Call DEBTRANS From GLOCK

$TRT_VMODALL
GOK = 1
Trbegin [STA]

# lecture de l'article
If [F:ITM]ITMREF <> NUMCOMPOSANT
    Read [ITM]ITM0=NUMCOMPOSANT
    If fstat = 1
        GOK = -1
        GLOCK = "$ITMMASTER"-NUMCOMPOSANT
        Goto ROLL_TRT
    Elsif fstat
       GOK = 0
       Call RSTA ("ITM",NUMCOMPOSANT) From GLOCK
       Goto AB_TRT
    Endif
Endif
If [F:ITF]ITMREF <> NUMCOMPOSANT | [F:ITF]STOFCY <> GSCA1MFGFCY
    Read [ITF]ITF0=NUMCOMPOSANT;GSCA1MFGFCY
    If fstat : Raz [F:ITF] : Endif
Endif

# lecture matière
Read [MFM]MFM0=NUMOF;LLIN;LSEQ;NUMCOMPOSANT
If fstat : Raz [MFM] : Endif

WSHTQTY = 0
WALLQTY = 0

Call DELALL (10, NUMOF, LLIN, LSEQ,
&            NUMCOMPOSANT, WOPT, WALLQTY, WSHTQTY, WRET) From STKALL
If WRET <> 0 : GOK = 0 : Goto AB_TRT : Endif

WALLQTY = 0
WSHTQTY = 0
# boucle pour maj-allocations
For I = 0 To [M:ASSW]NBLIG-1
    If [M:ASSW]ALLOUE(I) = 0 : Goto NEXT_ALL : Endif

    # lecture stock
    Read [F:STO]STO0 = GSCA1MFGFCY;[M:ASSW]STOCOU(I)
    If fstat : Raz [F:STO] : Endif
    WLOT    = [F:STO]LOT
    WSLO    = [F:STO]SLO
    WSTOCOU = [F:STO]STOCOU
    WSTA    = [F:STO]STA
    WLOC    = [F:STO]LOC

    # lecture lot
    Read [F:STL]STL0 = NUMCOMPOSANT;WLOT;WSLO
    If fstat : Raz [F:STL] : Endif
    Read [F:SLF]SLF0 = NUMCOMPOSANT;WLOT;WSLO;GSCA1MFGFCY
    If fstat : Raz [F:SLF] : Endif

    If [F:ITF]STOMGTCOD = 3
       If [F:STL]POT = 0 : [F:STL]POT = 100 : Endif
       WQTYSTUACT  = ([M:ASSW]ALLOUE (I) * [F:STL]POT) / 100
       Call QTEARR(WQTYSTUACT, [F:ITM]STU) From TRTDIV
    Else
       WQTYSTUACT  = [M:ASSW]ALLOUE (I)
    Endif

    WDTE = [0/0/0]
    #--- TS 106217 ajout paramètre LECC (avant dernier)
    Call CREALL(2,GSCA1MFGFCY,NUMCOMPOSANT, WSTOCOU,WDTE,
&                 [M:ASSW]ALLOUE(I),WQTYSTUACT,10,
&                 NUMOF,LLIN,LSEQ,"",[F:MFM]RETDAT,
&                 "","","","","","",0,0,"","","","",1,"",WRET) From STKALL
    If WRET<>0
       GOK = 0 : Goto AB_TRT
    Endif

    WALLQTY    += WQTYSTUACT

$NEXT_ALL
Next I

Gosub MAJ_MAT

Commit

Return

#------------------------------------------------------------------------------#
# mise à jour OF
$MAJ_MAT
# 87563 mm 02.2013
If (!find([F:MFM]PKC,4,5,6,7,10))
  # si quantité allouée manuellement < besoin, génération auto d'une rupture
  If WALLQTY <> 0 & (WALLQTY < ([F:MFM]RETQTY- [F:MFM]USEQTY))
      Gosub GEN_SHT
      If WRET : Return : Endif
  Endif

  # si pas de quantité allouée manuellement
  If WALLQTY = 0
      Gosub GEN_SHT
      If WRET : Return : Endif
  Endif
Endif

Call MAJALLMAT(NUMOF, LLIN, LSEQ, NUMCOMPOSANT, WALLQTY, WSHTQTY, 2, WRET) From MFGALL
If WRET <> 0 : GOK = 0 : Goto AB_TRT : Endif

Return

#------------------------------------------------------------------------------#
# génération rupture
$GEN_SHT
Local Integer WALL    : WALL = 4
Local Char    WFCY    : WFCY = GSCA1MFGFCY
Local Char    WITM    : WITM = NUMCOMPOSANT
Local Decimal WCHR    : WCHR = 0
Local Date    WDAT    : WDAT = [0/0/0]
Local Decimal WCLE    : WCLE = 0
Local Decimal WQTY    : WQTY = 0
Local Decimal WQTP
Local Char    WLOT    : WLOT = ""
Local Char    WSLO    : WSLO = ""
Local Char    WSTA    : WSTA = ""
Local Char    WSER(GLONSER) : WSER = ""
Local Char    WWRH(GLONWRH) : WWRH = ""
Local Decimal WWALLQTY  # 121455 mm 02.2017
Local Decimal WWALLQTP  # 121455 mm 02.2017

WQTP = [F:MFM]RETQTY - (WALLQTY +[F:MFM]USEQTY) # 121455 mm 02.2017

Local Integer WTYP    : WTYP = 10
Local Char    WNUM    : WNUM = NUMOF
Local Decimal WLIN    : WLIN = LLIN
Local Decimal WSEQ    : WSEQ = LSEQ
Local Char    WLOC    : WLOC = [F:MFM]LOC
Local Char    WPRE    : WPRENUM = ""
Local Date    WDTE    : WDTE = [F:MFM]RETDAT

#--- TS 106217 ajout paramètre LECC (avant dernier)
Call CREALL(WALL, WFCY, WITM, WCHR, WDAT, WQTY, WQTP, WTYP, WNUM, WLIN, WSEQ,  WPRE,
&           WDTE,WLOT,WSLO,WSTA,WLOC,WSER,WWRH,WWALLQTY,WWALLQTP,"","","","",1,"",WRET) From STKALL
If WRET <> 0 : GOK = 0 : Goto AB_TRT : Endif

WSHTQTY = WQTP

Return

#------------------------------------------------------------------------------#
# rollback
$ROLL_TRT
Rollback
Call ROLL From GLOCK
If GROLL
    Return
Else
    Goto TRT_VMODALL
Endif

#------------------------------------------------------------------------------#
# abandon
$AB_TRT
Rollback
Return



########################################################################
# generation recipient : / fiche ism / composant choisi
########################################################################
#                        fichier HANDLINGR/CONTAINERS

Subprog XTRACT_CONTAINERS (NUMISM)
Value    Char    NUMISM
Local    Char    WCHAIN
Local    Char    WSPECHAR
Local    Char    WCTN                     # 03.09 mm - Libellé traduisible
Local    Integer SAVIUM : SAVIUM = adxium


Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
CONTAINERS = func OPTLIB.FILNAM(GFCY,"ilctn",0)

adxium = GUTF8        # 44767 mm 08.09
adxifs = ";"
adxirs = chr$(10)

Local Decimal WQTYTAR
WQTYTAR = 0

# Ouverture du fichier en écriture

Openo CONTAINERS,0
#Local Integer Y
Local Char WISM(8) : Raz WISM
# 116332  mm 06.2016
# point d'entrée  pour permettre de court-circuiter le chargement des récipients standards
WISM = NUMISM
GPOINT ="RPLISM" : Gosub ENTREE From EXEFNC

# Lecture HANDLINGR
          For [HSR]HSR0  Where HSH = WISM
# Lecture CONTAINERS
              Read [CTN]CTN0=[F:HSR]CTN
              If fstat Raz[F:CTN] : Endif
              # sr 06.02 FI N° 28 Prise en compte du format étiquette de la fiche ISM détail
              If [F:HSR]LBEFMT <> ""
                 [F:CTN]CTNLBEFMT = [F:HSR]LBEFMT
              Endif

              # 03.09 mm - Libellé traduisible
              Call LECTEXTRA (WCTN,"CONTAINERS","CTNDESAXX",[F:CTN]CTN,"") From ATEXTRA
              Call CHANGE_CHAR(WCTN)

              Call CAL_CONVERT ([F:HSR]WEU,[F:CTN]CTNWEU,[F:CTN]CTNTHETAR,WQTYTAR)

              Wrseq NUMISM;[F:HSR]CTN;[F:HSR]WEU;[F:HSR]WEIMAW;
&             WCTN;[F:CTN]CTNTYP;mess([F:CTN]CTNTYP,2318,1);
&             WQTYTAR;[F:CTN]CTNPRCTOL;[F:CTN]CTNUGD;
&             [F:CTN]CTNLBEFMT;[F:CTN]CTNMODTAR;[F:CTN]CTNSAIMAN   # mm 04.07 ajout de l'indicateur tare modifiable
                                                                   # mm 10.07 ajout de l'indicateur saisie poids
          Next

# fermeture de l'enregistrement

Openo
adxium = SAVIUM

End



