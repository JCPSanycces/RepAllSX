########################################################################
#                        fichier TRACE
# si premier caractere = < ou > c est un message d erreur
# on ne transfert que le fichier trace si il y a erreur  GERRTRACE <> 0
# si on veut garder la trace  , il faut ouvrir un fichier sequentiel
# ecrire les erreurs , le transferer et le supprimer , et ne pas supprimer
# le fichier trace GTRACE
Subprog TRF_TRA

Local Char    PATH (70)
Local Char    NOMFIC (250)
Local Integer STA
Local Integer SAVIUM : SAVIUM = adxium

PATH = filpath("TRA",GTRACE,"tra")
NOMFIC = GTRACE
adxium = GUTF8          # 44767 mm 08.09
Call FERME_TRACE From LECFIC

# si le fichier trace GTRACE n est pas de type erreur on rend nul le contenu

If GERRTRACE =  0
   Openo PATH,0
   Openo
Endif

# GH 24/11/2014 dem 103835
#Callui RETOUR="" With     "UIAction="+chr$(1)+"GetFileAlways",
#&                         "UIRemoteFile="+ chr$(1) +PATH,
#&                         "UILocalDir="+ chr$(1) +"UserTemp",
#&                         "UILocalFile="+ chr$(1) +"X3ScalesTra.csv"
Call FIL2CSV(NOMFIC,"tra",PATH,"X3ScalesTra") From OPTLIB

# apres transfert on supprime le fichier

NOMFIC = PATH
STA = 1
GTRACE = ""
Call EFFACE(NOMFIC,STA) From ORDSYS

# on en ouvre un autre

TIT = mess(25,2324,1)
TRA=0
Call OUVRE_TRACE(TIT) From LECFIC
adxium = SAVIUM

End

