###########################################################################
#  Henri Combet                        S C A L E X C H A N     GPAO  2001 #
# Echanges entre le serveur et le poste graphique de pesée     GPAO  2001 #
# sr Modélisation et nouveaux stocks 1.4.0                     GPAO  2004 #
###########################################################################
# XTRACT_INITIAL      Génération Scalespar / sle / cgd / mwg / tco entré menu
# XTRACT_NUMOF        Génération Scalespha / mat / hsh  suivant NUMOF
# XTRACT_ALLOCATION   Génération Scalessto , allocation du composant
# XTRACT_CONTAINERS   Génération Scalesctn , suivant NUMISM
# MAJ_FICHIERS        Mise à jour fichier MFGHEAD MFGMAT SCALES
# MAJ_CALIBRAT        MISE a jour historique etalonnage
# WIN_PROCEDURE       Saisie procedure de box
# TRF_PAR             Transfert  Scalesbox
# TRF_SLE             Transfert  Scalessle
# TRF_CGD             Transfert  Scalescgd
# TRF_MWG             Transfert  Scalesmwg
# TRF_PHA             Transfert  Scalespha
# TRF_MAT             Transfert  Scalesmat
# TRF_HSH             Transfert  Scaleshsh
# TRF_STO             Transfert  Scalessto
# TRF_CTN             Transfert  Scalesctn
# TRF_TCO             Transfert  Scalestco
# CTL_ACCES           Controle acces peseur
# CAL_POIDS           Calcul poids à partir  quantite  stock
# CAL_QUANTITE        Calcul quantite  stock à partir  poids
# MAJ_ALLOCATIONS     Allocation de la pesée   /lecture ScalesAll
# MAJ_WEIGHING_SUIVI  Ecriture pesee WEIGHING + SUIVI /lecture ScalesWgg
# MAJ_SOLDE_MATIERE   solde d'une matiere / lecture ScalesWgg
# DES_ALLOCATION_A    desallocation total d un composant
# DES_ALLOCATION_R    desallocation reste à peser d un composant
# CAL_QTYCONSOMME     calcul quantitée consommée
# CAL_CONVERT         Conversion de la tare du recipent en unite de la fiche ISM
# MAJ_FINCONTENANT    mouvement de consommation pour une fin de contenant
# MAJ_CONTENANT       mouvement d'inventaire pour un réajustement de contenant en + ou en -
###########################################################################



# CODIFICATION des fichiers d'échanges
#     les fichiers sont générés sur le serveur puis copiés sur le client
#     le format sur le serveur est le suivant:
#         xxx_usr.ilyyy
#         ou
#            xxx = site
#            usr = code utilisateur X3
#            il  = constante (ilog)
#            yyy = abréviation de la table concernée
#     le format sur le client est le suivant:
#         X3ScalesXxx.csv
#         ou
#             X3Scales = constante
#             Xxx      = abreviation de la table concernée
#             csv      = constante (extension fichiers compatibles excel
#                        avec séparateur ";")
#
#      Abreviation des tables :
#
#                    PARAMETRES + PROCEDURES DE VIDE      :  box
#                    BALANCE  / SCALES                    :  sle
#                    GUIDE CALIBRAGE / CALIGUIDES         :  cgd
#                    OF du PLAN de PESEE                  :  mwg
#                    PHASES                               :  pha
#                    COMPOSANTS du fichier PHASES         :  mat
#                    ISM du fichier COMPOSANTS            :  hsh
#                    ALLOCATION du composant              :  sto
#                    table des COEFFICIENTS               :  tco
###########################################################################

###########################################################################
# Génération  Scalesbox / sle / cgd / mwg    entré dans le menu
###########################################################################
#X3-85848.n - Added below parameter NUMMAT as we now call XTRACT_NUMOF from here
Subprog XTRACT_INITIAL(NUMOF,NUMMAT)
Variable    Char    NUMOF
Value       Char    NUMMAT
Local       Char    WCHAIN, WSPECHAR
Local       Integer I
Local       Char    WSEP, WSEP2, WSEP3     # 83201 mm 10.2014
Local Integer SAVIUM : SAVIUM = adxium

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218

#                                 génération fichier COEFFICIENTS
COEFFILE = func OPTLIB.FILNAM(GFCY,"iltco",0)
adxium = GUTF8      # 44767 mm 08.09
adxifs = ";"
adxirs = chr$(10)

# Ouverture du fichier en écriture
Openo COEFFILE,0

For [TCO]
    # écriture le l'enregistrement
    # mise en majuscules des unités pour ignorer les différences majuscules/minuscules - 60825 mm 12.09
    Wrseq toupper([F:TCO]UOM1);toupper([F:TCO]UOM2);[F:TCO]COEUOM
Next

# fermeture de l'enregistrement
Openo

#                                 génération fichier BALANCE / SCALES
SCALEFILE = func OPTLIB.FILNAM(GFCY,"ilsle",0)
adxium = GUTF8      # 44767 mm 08.09
adxifs = ";"
adxirs = chr$(10)
Local Char TABCGD (8) (8)
Local Char WPILOTE (30)
Local Integer I
Local Char WLIEU,WBOX,WBALANCE,WGUIDE        # 03.09 mm - Libellé traduisible
Local Char WUSERID(5)
Local Char WRAZ(4), WTARE(4)                 # 114545 mm 09.2016
WRAZ ="" : WTARE=""

# Ouverture du fichier en écriture
Openo SCALEFILE,0
For [SLE]SLE1 Where FCY = GSCA1MFGFCY   &
&                   STI = GSCA1STI &
&                   BOX = GSCA1BOX &
&                   SRVCOD <> 2

If [F:SLE]CGD <> ""
   For I = 0 To 7 Step 1
       If TABCGD (I) = [F:SLE]CGD                 : Break : Endif
       If TABCGD (I) = "" TABCGD (I) = [F:SLE]CGD : Break : Endif
   Next I
Endif

# 114545 mm 09.2016 - reading MODSCALE table
If [F:SLE]MODSCALE<>""
  Read [F:MODL]MOD1 = [F:SLE]MODSCALE
  If !fstat
    WRAZ = num$([F:MODL]RAZERO)
    WTARE= num$([F:MODL]TARE)
  Endif
Endif

# Lecture ATABDIV (pilote  380)
Call GET_SHOLIB(380, [F:SLE]PILNAM, WPILOTE) From MFGLIB

# 03.09 mm - Libellé traduisible
Call LECTEXTRA (WBALANCE,"SCALES","DESAXX",[F:SLE]SLE,[F:SLE]FCY) From ATEXTRA
Call CHANGE_CHAR(WBALANCE)

# sr 01.03
# gerer le fait que le séparateur peut être la virgule
WSEP = mid$(mess(0,2326,1),[F:SLE]SEP,1)
If WSEP = "," : WSEP = "V" : Endif

    # écriture de l'enregistrement
    Wrseq [F:SLE]SLE;WBALANCE;[F:SLE]CAG;WPILOTE;[F:SLE]ITGNBR;[F:SLE]DECNBR;
&         [F:SLE]SEP;WSEP;[F:SLE]WEICNG;
&         [F:SLE]WEU;[F:SLE]MINRGE;[F:SLE]MAXRGE;[F:SLE]MAXTAR;[F:SLE]TOL;
&         [F:SLE]CBTCOD;mess([F:SLE]CBTCOD,2317,1);[F:SLE]CGD;
&         [F:SLE]NBRDAY;[F:SLE]NBRWGG;[F:SLE]AVACOD;mess([F:SLE]AVACOD,2331,1);
&         [F:SLE]LASCBTDAT;[F:SLE]NBRWGGCBT;[F:SLE]CBTLBE;
&         [F:SLE]BAURAT;[F:SLE]PRY;[F:SLE]STPBYT;[F:SLE]SYZBYT;[F:SLE]TEMIND;
&         [F:SLE]SERIALNUM;WRAZ;WTARE

Next

# fermeture de l'enregistrement
Openo

Call XTRACT_PARAM(0)

