Subprog WIN_PROCEDURE(FICTEC,MFGNUM,LOPE,LITM,LTYP,LOBY,L,WTRT)
Value Char     FICTEC          # numero procedure
Value Char     MFGNUM          # numero of
Value Integer  LOPE            # numero operation
Value Char     LITM            # article
Value Shortint LTYP            # type procedure
Value Shortint LOBY            # obligatoire / facultative
Value Integer  L
Value Integer  WTRT
Local Char WPARAM(GLONVCR)(1..7) , WVALEUR(10)
Local Char SAVACT(20)

If clalev([F:QLC])<= 0 : Local File QLYCRD    [QLC] : Endif
If clalev([F:QLQ])<= 0 : Local File QLYCRDQST [QLQ] : Endif
If clalev([F:MWA])<= 0 : Local File MWMCRDASW [MWA] : Endif
If clalev([F:TCT])<= 0 : Local File TABCTL    [TCT] : Endif

WPARAM(1) = FICTEC
WPARAM(2) = MFGNUM
WPARAM(3) = num$(LOPE)
WPARAM(4) = LITM
WPARAM(5) = date$
WPARAM(6) = num$(L)
WPARAM(7) = num$(LOBY)
SAVACT = GACTION : GACTION = "SAIPROCRD"
Call TRAITE_CHAR(WVALEUR,WPARAM,"IQLYCRD","CRDLIB","",4,"") From GTRAITE
GACTION = SAVACT
#
End

##############################################################
$APRES_MODIF
ETABOU(GVALI) = 1
Call SETBOUT(ETABOU) From GESECRAN
Return

###########################################################################
#             Resultat calibrage    maj  CALIBRAT /CBT
###########################################################################
Subprog MAJ_CALIBRAT (LCODE)
Value Char LCODE

Local Decimal  WSEQ

Local Char     F_SLE       (08)
Local Char     SAV_SLE     (08)
Local Char     F_WEU       (3)
Local Decimal  F_WEIWEI
Local Decimal  F_CGDWGG
Local Decimal  F_MAXDEV
Local Char     F_CGD       (08)
Local Integer  F_CGDLIG
Local Shortint F_CGDTYP
Local Shortint F_CGDNUM
Local Char    WFIL         (06)

Local Char CBTFILE (200)

If clalev([F:SLE])  <= 0 : Local File SCALES     [SLE]  : Endif
If clalev([F:CBT])  <= 0 : Local File CALIBRAT   [CBT]  : Endif

# transfert fichiers etalonnage du client vers le serveur
Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Call CSV2ILFIL(GFCY,"ilcbt","X3ScalesCbt") From OPTLIB

Call DEBTRANS From GLOCK
Trbegin [CBT]

CBTFILE = func OPTLIB.FILNAM(GFCY,"ilcbt",0)

adxifs = ";"
adxirs = chr$(10)

# Ouverture du fichier X3ScalesCbt en lecture

Openi CBTFILE Using [CBTF]

# Lecture fichier X3ScalesCbt
Repeat

Rdseq F_SLE,F_WEU,F_WEIWEI,F_CGDWGG,F_MAXDEV,
&     F_CGD,F_CGDLIG,F_CGDTYP,F_CGDNUM,WFIL
&     Using [CBTF]

If fstat = 1 Goto FIN_CBT : Endif
If fstat = 5 Goto FIN_CBT : Endif
# Ecriture mouvement etalonnage
SAV_SLE = F_SLE
  Filter [CBT] Where FCY    = GSCA1MFGFCY  &
&                    SLE    = F_SLE            &
&                    CBTDAT = date$
&              Order By Key CBT0
  Read [CBT] First
    If fstat = 0  WSEQ =[F:CBT]MVTSEQ-1
       Else       WSEQ = 9999
    Endif
  Raz [F:CBT]
  [F:CBT]FCY       = GSCA1MFGFCY
  [F:CBT]SLE       = F_SLE
  [F:CBT]CBTDAT    = date$
  [F:CBT]MVTSEQ    = WSEQ
  [F:CBT]STI       = GSCA1STI
  [F:CBT]BOX       = GSCA1BOX
  [F:CBT]CGDWEU    = F_WEU
  [F:CBT]WEIWEI    = F_WEIWEI
  [F:CBT]CGDWGG    = F_CGDWGG
  [F:CBT]MAXDEV    = F_MAXDEV
  If LCODE = "40" [F:CBT]CBTRES    = 1 Endif
  If LCODE = "41" [F:CBT]CBTRES    = 2 Endif
  If LCODE = "42" [F:CBT]CBTRES    = 2 Endif
  [F:CBT]CGD       = F_CGD
  [F:CBT]CGDLIG    = F_CGDLIG
  [F:CBT]CGDTYP    = F_CGDTYP
  [F:CBT]CGDNUM    = F_CGDNUM
  [F:CBT]LBEPRNCOD = 1
  [F:CBT]EXCNUM    = val(LCODE)
  [F:CBT]CREDAT    = date$
  [F:CBT]CRETIM    = mid$(time$,1,2)+mid$(time$,4,2)
  [F:CBT]CREUSR    = GUSER
  [F:CBT]EXPNUM    = 0
  [F:CBT]UPDUSR    = ""
  [F:CBT]UPDDAT    = [0/0/0]
Write [CBT]
    If fstat GOK = 0 : Call FSTA("CBT") From GLOCK : Endif
  Filter [CBT]

# retour lecture X3ScalesCbt

Until fstat <> 0


$FIN_CBT
# fermeture de l'enregistrement
Openi

# mise a jour balance si calibrage OK

Local Char    NOMETA
Local Integer TYPETA

If LCODE = "40"
     Readlock [F:SLE]SLE0 = SAV_SLE;GSCA1MFGFCY
           If fstat=1     GOK=-1 : GLOCK="$SCALES"-SAV_SLE :Gosub AB_TRT : End
                 Elsif fstat GOK=0  : Call RSTA("SLE",SAV_SLE) From GLOCK
           Gosub AB_TRT
           End
           Endif

     [F:SLE]NBRWGGCBT  = 0
     [F:SLE]LASCBTDAT  = date$

     Rewrite [F:SLE]
          If fstat
               GOK = 0 : Call FSTA("SLE") From GLOCK : Gosub AB_TRT : End
          Endif
#Document calibrage
NOMETA = [F:SLE]CBTLBE
TYPETA = 5
Gosub ETI_CALIBRAGE

Endif

# etalonnage KO sur balance n'ayant pas besoin d'être etalonnée
# on force le nombre de pesee à 9999 ou la date de dernier etalonnage à 0
# suivant le code etalonnage

If LCODE = "42"
     Readlock [F:SLE]SLE0 = SAV_SLE;GSCA1MFGFCY
           If fstat=1     GOK=-1 : GLOCK="$SCALES"-SAV_SLE :Gosub AB_TRT : End
                 Elsif fstat GOK=0  : Call RSTA("SLE",SAV_SLE) From GLOCK
           Gosub AB_TRT
           End
           Endif
# mise a jour balance si calibrage OK

    If [F:SLE]CBTCOD = 3 [F:SLE]NBRWGGCBT  = 9999    Endif
    If [F:SLE]CBTCOD = 2 [F:SLE]LASCBTDAT  = [0/0/0] Endif
    If [F:SLE]CBTCOD = 4 [F:SLE]NBRWGGCBT  = 9999
                         [F:SLE]LASCBTDAT  = [0/0/0] Endif

     Rewrite [F:SLE]
          If fstat
               GOK = 0 : Call FSTA("SLE") From GLOCK : Gosub AB_TRT : End
          Endif
Endif

Commit

End

###########################################################################
#             Pesee    maj  WEIGHING /WGG   + SUIVI
###########################################################################
Subprog MAJ_WEIGHING_SUIVI (LCODE,PESEE_ART)
Value Char LCODE
Value Integer  PESEE_ART    # si PESEE_ART = 2, on est en pesée par article, si = 0, on est en pesée par OF ou en farication
Local Decimal  WSEQ
Local Char WMFGTRKNUM
Local Integer OK, STAT, I, J
Local Date WDAT
Local Decimal  F_WEIWEI_US
Local Decimal  F_WEI_US        # 55296 mm 05.09
Local Decimal  LQTA, LSHT
Local Integer  LNBR, LNBJ, LRET
Local Integer  WRET            # 50603 mm 11.08

Local Char     F_MFGNUM       (GLONVCR)
Local Shortint F_BOMOPE
Local Char     F_ITMREF       (GLONITM)    # mm 05.08
Local Integer  F_MFGLIN
Local Integer  F_BOMSEQ
Local Char     F_EXTSLE       (08)
Local Char     F_USESLE       (08)
Local Shortint F_CBTCOD
Local Char     F_EXTCTN       (08)
Local Char     F_USECTN       (08)
Local Decimal  F_CTNTAR
Local Shortint F_MLTITM
Local Char     F_MAT1         (GLONITM)
Local Shortint F_CONNEC
Local Char     F_TKS          (08)
Local Char     F_TGTGTS       (08)
Local Shortint F_PKC
Local Char     F_CTN          (08)        # CATUA X3-30163 container field in weighing
Local Char     F_LOT          (GLONLOT)   # 57505 mm 08.09
Local Char     F_SLO          (GLONSLO)   # 98779 mm 08.2014
Local Char     F_LOC          (10)
Local Char     F_STA          (03)
Local Decimal  F_DEFPOT
Local Decimal  F_POT
Local Char     F_STU          (3)
Local Char     F_WEU          (3)
Local Decimal  F_WEIWEI
Local Decimal  F_WEI
Local Decimal  F_EXC                      # 116324 mm 08.2016
Local Char     F_ISM          (8)
Local Shortint F_WGGOPT
Local Char     WFIL           (06)
Local Decimal  F_STOCOU
Local Integer  F_SEQ
Local Char     F_PROCEDURE    (8)
Local Char     F_CONTENU_ISM  (7)
Local Char     F_FORMAT_CTN   (7)
#--- Spécifique pesée --------------------------------------------------#
Local Char     SVG_LCODE
Local Char LSEC(GLONCCE)            # 38659 - JOBRO

WDAT = date$

If clalev([M:ASSW]) <= 0 : Local Mask ALLSCALSTO [ASSW] : Endif
If clalev([M:MTMK]) <= 0 : Local Mask MTMK       [MTMK] : Endif
If clalev([M:ORDK]) <= 0 : Local Mask ORDK       [ORDK] : Endif
If clalev([M:ALP])  <= 0 : Local Mask ALLPAR     [ALP]  : Endif
If clalev([M:SOW])  <= 0 : Local Mask STOSORW    [SOW]  : Endif
If clalev([M:STW])  <= 0 : Local Mask STOWORK    [STW]  : Endif
# Issue 83009 - 2012-06-19 by SR
#If clalev([M:ST2])  <= 0 : Local Mask STOWORK2   [ST2]  : Endif     # 41440 mm 03.08
If clalev([M:ST2])  <= 0 : Local Mask STOWORK    [ST2]  : Endif     # 41440 mm 03.08
If !clalev([M:SVW]) : Local Mask STOVALWORK [SVW] : Endif
If clalev([F:STO])  <= 0 : Local File STOCK      [STO]  : Endif
If clalev([F:STA])  <= 0 : Local File STOALL     [STA]  : Endif
If clalev([F:BTS])  <= 0 : Local File BENCHTRS   [BTS]  : Endif
If clalev([F:WGG])  <= 0 : Local File WEIGHING   [WGG]  : Endif
If clalev([F:TCA])  <= 0 : Local File TABCOUAFF  [TCA]  : Endif
If clalev([F:MKM])  <= 0 : Local File MFGMATTRK  [MKM]  : Endif
If clalev([F:MFG])  <= 0 : Local File MFGHEAD    [MFG]  : Endif
If clalev([F:MTK])  <= 0 : Local File MFGHEADTRK [MTK]  : Endif
If clalev([F:MFI])  <= 0 : Local File MFGITM     [MFI]  : Endif
If clalev([F:CAL])  <= 0 : Local File CPTANALIN  [CAL]  : Endif
If clalev([F:MFM2])  <= 0 : Local File MFGMAT     [MFM2]  : Endif  #X3-66324 JOBRO
#--- Spécifique pesée --------------------------------------------------#
SVG_LCODE = LCODE
GPOINT="MAJ_LCODE"
Gosub ENTREE From EXEFNC

# lecture BTS suivant transaction du parametre GWEITRSNUM
Read [F:BTS]BTS0 = 61;GWEITRSNUM
If fstat : Call ERREUR(mess(23,2324,1)) From GESECRAN : OK=0 : End : Endif

Local Char WGGFILE (200)
Raz [M:ST2]    # 41440 mm 03.08
# 50603 mm 11.08
Raz [M:ST2] NBLIG
Raz [M:STW]
Raz [M:STW]NBLIG

# transfert fichiers pesee du client vers le serveur
Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Call CSV2ILFIL(GFCY,"ilwgg","X3ScalesWgg") From OPTLIB

WGGFILE = func OPTLIB.FILNAM(GFCY,"ilwgg",0)

adxifs = ";"
adxirs = chr$(10)

# Ouverture du fichier X3ScalesWgg en lecture
Openi WGGFILE Using [WGGF]

Raz  [M:ASSW]

# Lecture fichier X3ScalesWgg
Repeat

Rdseq F_MFGNUM,F_BOMOPE,F_ITMREF,F_MFGLIN,F_BOMSEQ,F_EXTSLE,F_USESLE,F_CBTCOD,F_CONNEC,
&     F_EXTCTN,F_USECTN,F_CTNTAR,F_MLTITM, F_MAT1,F_TKS,F_TGTGTS,F_PKC,F_LOT,F_SLO,F_LOC,F_STA,
&     F_DEFPOT,F_POT,F_STU,F_WEU,F_WEIWEI,F_WEI,F_EXC,F_ISM,F_WGGOPT,F_STOCOU,F_SEQ,
&     F_CONTENU_ISM,F_FORMAT_CTN,F_PROCEDURE,WFIL
&     Using [WGGF]

If fstat = 1 Goto FIN_WGG : Endif
If fstat = 5 Goto FIN_WGG : Endif

    Raz GSTOCOU : GSTOCOU= F_STOCOU         # 55296 mm 05.09

    # Calcul unite de poids en unite de stock
    Call CAL_QUANTITE (F_ITMREF,F_WEIWEI_US,F_WEIWEI)

    # sr 04.04 première chose : La DLL ne s'est-elle pas fait leurrer sur la quantité dispo ?
    # on revérifie
#   12.06 a priori cela ne marche pas demande 38689
#    Read [F:STO]STO0 = GSCA1MFGFCY;F_STOCOU

    Read [F:STO]STO0 = GSCA1MFGFCY;F_STOCOU
    If fstat : Raz [F:STO] : Endif    # mm 07.2014 [F:STO] instead of [F:ST0]

    Read [F:STA]STA0 = GSCA1MFGFCY;F_ITMREF;F_STOCOU;F_SEQ
    If fstat : Raz [F:STA] : Endif

    # sr 23.04 la DLL ne fait plus rien si poids pesé > au dispo : on le détecte ici seulement
    # on fait un redressement à ce moment là pour le delta entre qté pesée et qté dispo
    # on passe le poids pesé
    If ([F:STO]QTYSTU - [F:STO]CUMALLQTY) + [F:STA]QTYSTU < F_WEIWEI_US
        Call MAJ_CONTENANT(F_MFGNUM,F_ITMREF,F_LOT,F_SLO,F_WEIWEI,F_WGGOPT,F_MFGLIN,F_BOMSEQ,1)
    Endif

#--- Spécifique pesée --------------------------------------------------#
If find(LCODE,"27","28","29","30","31")
    #Récupération du compteur suivi
    Call LECTCA(8,OK) From SUBTCA
    If OK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : End : Endif
    GCODNUM    = [F:TCA]CODNUM(2)   # compteur suivi
    GMANCOU    = [F:TCA]MANCOU(2)
    If GTRACE = ""
            TIT = mess(25,2324,1)
            TRA=0
            Call OUVRE_TRACE(TIT) From LECFIC
            Call ECR_TRACE(" ",0) From GESECRAN
            Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
            Call ECR_TRACE(" ",0) From GESECRAN
    Endif
#--- Spécifique pesée --------------------------------------------------#
Endif

Call DEBTRANS From GLOCK
Trbegin [MKM]

#Lecture matière OF
Read [F:MFM]MFM0 = F_MFGNUM;F_MFGLIN;F_BOMSEQ;F_ITMREF
If fstat : GOK = 0 : Call RSTA("MFM",F_MFGNUM+num$(F_MFGLIN)) From GLOCK : Gosub AB_TRT : End : Endif
#--- Spécifique pesée --------------------------------------------------#
If find(LCODE,"27","28","29","30","31")
   Call NUMERO(GCODNUM,GSCA1MFGFCY,WDAT,"",WMFGTRKNUM,STAT) From SUBANM
   If STAT
      WMSGSUI = mess(60,199,1)+" :"-GCODNUM-num$([L]STAT)
      TRA = 1
      Call ECR_TRACE(WMSGSUI,1) From GESECRAN
      Call ERREUR(mess(60,199,1)-GCODNUM-num$([L]STAT)) From GESECRAN : GOK = 0 :Gosub AB_TRT : End
   Endif
    # 50603 mm 11.09 - sauvegarde des info de [STO] en cas de mouvement de redressement en emb. interne
    # cas où on a consommé plus que la quantité disponible
    If ([F:STO]QTYSTU - [F:STO]CUMALLQTY) + [F:STA]QTYSTU < F_WEIWEI_US
        nolign = 1    # 56365 mm 07.09
        Transmask [M:STW] To [M:ST2] # X3-36381 JUSYN - 05/12/17 Performance improvement Transmask [M:ST2] = [M:STW]
    Elsif ([F:STO]QTYSTU - [F:STO]CUMALLQTY) + [F:STA]QTYSTU = F_WEIWEI_US
        # on a consommé exactement le disponible mais on souhaite qd même garder l'emb.
        Call ADDSTOWORKLIN("C", "E", [F:STO]STOFCY, [F:STO]STOCOU,  F_WEIWEI_US, F_WEIWEI_US,"","", WRET) From STKINT     # hcb 110327
        # Issue number 80916 - 2012-03-20 by SR : Lignes replacées après l'appel à ADDSTOWORLIN sinon perdues
        [M:STW]STOFCY     = [F:STO]STOFCY       # Site
        [M:STW]TRSTYP     = 13                  # Type mouvement (M.704) on met inventaire
        [M:STW]VCRTYP     = 10                  # Type pièce (M.701) on met OF
        [M:STW]VCRNUM     = WMFGTRKNUM          # Numéro pièce
        [M:STW]VCRLIN     = 0                   # Numero ligne pièce
        [M:STW]ITMREF     = F_ITMREF             # Article
        [M:STW]MVTDES     = mess(40,2324,1)     # Désignation mouvement
        [M:STW]PJT        = ""                  # Affaire
        [M:STW]TRSFAM     = [F:BTS]TRSFAM       # Famille mouvement
        [M:STW]IPTDAT     = date$               # Date imputation
        [M:STW]TRSCOD     = [F:BTS]TRSCODS      # Code mouvement
        [M:STW]TRAFLG     = 0
        nolign = 1    # 56365 mm 07.09
        Transmask [M:STW] To [M:ST2] # X3-36381 JUSYN - 05/12/17 Performance improvement Transmask [M:ST2] = [M:STW]
        If clalev([M:SVW])
            Raz [M:SVW]
            [M:SVW]NBLIG=[M:STW]NBLIG
        Endif
        Gosub ALIVALWORK From STKVALMAJ
    Endif
#--- Spécifique pesée --------------------------------------------------#
Endif

# actualisation de l ecran de travail MTMK
Raz [M:MTMK]
[M:MTMK]TYPTRT    = 4
[M:MTMK]MFGTRKNUM = WMFGTRKNUM
[M:MTMK]MATTRKLIN = 1
[M:MTMK]WSTOSEQ   = [M:MTMK]MATTRKLIN
[M:MTMK]MFGNUM    = F_MFGNUM
[M:MTMK]MFGLIN    = F_MFGLIN
[M:MTMK]ITMREF    = F_ITMREF
# sr 12.11 # sr 12.11 :Demande 78848 : On en a besoin pour calculer les qtés consommées
[M:MTMK]OPENUM    = F_BOMOPE
[M:MTMK]IPTDAT    = date$
[M:MTMK]BOMSEQ    = F_BOMSEQ
[M:MTMK]LOTPREF   = F_LOT
[M:MTMK]LOCPREF   = F_LOC
[M:MTMK]STAPREF   = F_STA
[M:MTMK]STOCODMAN = 1
If LCODE = "27" [M:MTMK]CLEFLG = 1 Endif
If LCODE = "28" [M:MTMK]CLEFLG = 1 Endif
If LCODE = "29" [M:MTMK]CLEFLG = 2 Endif
If LCODE = "30" [M:MTMK]CLEFLG = 2 Endif
If LCODE = "31" [M:MTMK]CLEFLG = 2 Endif
[M:MTMK]MFGFCY    = GSCA1MFGFCY

# 114287 mm 02.2016 : physical quantities
[M:MTMK]USEQTY  = F_WEIWEI_US
#---
[M:MTMK]WLINUM    = 1
[M:MTMK]FICFLG    = 2
[M:MTMK]ITMREF    = F_ITMREF
[M:MTMK]TRSCODS   = [F:BTS]TRSCODS
[M:MTMK]TRSFAM    = [F:BTS]TRSFAMS
[M:MTMK]ENTCOD    = [F:BTS]ENTCODS
[M:MTMK]STU       = F_STU  # CCC (23/03/09) Bug 53746

# 55296 mm 05.09 - Recherche du nouveau STOCOU
# Calcul du poidsAPeser en unite de stock
Call CAL_QUANTITE (F_ITMREF,F_WEI_US,F_WEI)

# 114287 mm 02.2016 : physical quantities
[M:MTMK]ALLQTY  = F_WEI_US
#---
[M:MTMK]PCU =  [F:STO]PCU
[M:MTMK]QTYSTU = [F:STO]QTYSTU
#

F_CTN = [F:MFM]CTN  # CATUA X3-30163 container field in weighing

#38659 - JOBRO
Call GETSOC([M:MTMK]MFGFCY) From DEVSUB
Call GETCPY([M:MTMK]MFGFCY,"",0,"") From TRTX3CPT
#38659 - JOBRO
Read [CAL] CAL0="MFM";0;[F:MFM]MFGNUM;[F:MFM]MFGLIN;[F:MFM]BOMSEQ;[F:MFM]ITMREF;1
If !fstat
    For I=1 To max(GNBDIE,GOPTCANA)
        J=find([F:CAL]DIE(I-1),GDIE(1..GNBDIE))
        If J
          Assign "[M:MTMK]CCE"+num$(J) With [F:CAL]CCE(I-1)
        Endif
    Next I
Endif
#38659 - JOBRO
For I=1 To max(GNBDIE,GOPTCANA)
    If evalue("[M:MTMK]CCE"+num$(I))=""
        Raz LSEC
        Call INIT_CCE(LSEC,I,"MKM","",0) From TRTX3CPT
        Assign "[M:MTMK]CCE"+num$(I) With LSEC
    Endif
Next I
#38659 - JOBRO
Raz LQTA,LSHT,LNBR,LNBJ,LRET

#--- Spécifique pesée --------------------------------------------------#
If find(LCODE,"27","28","29","30","31")

   Raz [M:SOW]

   [M:ALP]TRSTYP     = 6
   [M:ALP]TRSCOD     = [M:MTMK]TRSCODS
   [M:ALP]VCRTYP     = 10
   [M:ALP]VCRNUM     = [M:MTMK]MFGNUM
   [M:ALP]VCRLIN     = [M:MTMK]MFGLIN
   [M:ALP]VCRSEQ     = [M:MTMK]BOMSEQ
   [M:ALP]STOFCY     = [M:MTMK]MFGFCY
   [M:ALP]ITMREF     = [M:MTMK]ITMREF
   [M:ALP]QTY        = [M:MTMK]USEQTY
   [M:ALP]STA        = [M:MTMK]STAPREF
   [M:ALP]LOT        = [M:MTMK]LOTPREF
   [M:ALP]LOC        = [M:MTMK]LOCPREF
   [M:ALP]PCU        = [F:ITM]STU
   [M:ALP]PCUSTUCOE  = 1
   # 114287 mm 02.2016 : physical quantities
   [M:ALP]TYPQTY     = 1
   #---
   [M:ALP]BESDAT     = [M:MTMK]IPTDAT
   [M:ALP]STOLOC     = [M:MTMK]LOCPREF
   If dim([M:MTMK]WRH)>0 [M:ALP]WRH=[M:MTMK]WRH Endif
   Raz LRET
   WRUP = [F:ITM]NEGSTO - 1
   Call  SCASTOSORW("",[M:MTMK]MATTRKLIN,0,F_STOCOU,F_SEQ,LRET) From STKSOR
   If LRET <> 0 :GOK = 0 : Gosub AB_TRT : End: Endif

   # si qrticle titré, remettre la quantité en unité active
   #--- 114287 mm 02.2016 - Moving the conversion physically-> Active
   If [F:MFM]STOMGTCOD = 3
      If F_POT = 0 : F_POT = 100 : Endif
      [M:MTMK]USEQTY  = (F_WEIWEI_US * F_POT) / 100
      Call QTEARR([M:MTMK]USEQTY, F_STU) From TRTDIV
   Else
      [M:MTMK]USEQTY  = F_WEIWEI_US
   Endif

   # si article titré, remettre la quantité en unité active
   #--- 114287 mm 02.2016 - Moving the conversion physically-> Active
   If [F:MFM]STOMGTCOD = 3
      If F_POT = 0 : F_POT = 100 : Endif
      [M:MTMK]ALLQTY  = (F_WEI_US * F_POT) / 100
      Call QTEARR([M:MTMK]ALLQTY, F_STU) From TRTDIV
   Else
      [M:MTMK]ALLQTY  = F_WEI_US
   Endif
#--- Spécifique pesée --------------------------------------------------#
Endif

# Mise jour fichier WEIGHING

  Filter [WGG] Where MFGNUM    = F_MFGNUM &
&                    BOMOPE    = F_BOMOPE &
&                    ITMREF    = F_ITMREF &
&                    MFGLIN    = F_MFGLIN &
&                    BOMSEQ    = F_BOMSEQ &
&                    CBTDAT    = date$
&              Order By Key WGG0
  Read [WGG] First
  Filter [WGG]  # mm 02.2013
    If fstat = 0  WSEQ =[F:WGG]MVTSEQ-1
       Else       WSEQ = 9999
    Endif
  Raz [F:WGG]

  [F:WGG]CBTDAT    = date$
  [F:WGG]MVTSEQ    = WSEQ
  [F:WGG]EXCNUM    = val(LCODE)
  [F:WGG]STI       = GSCA1STI
  [F:WGG]BOX       = GSCA1BOX
  [F:WGG]FCY       = GSCA1MFGFCY
  [F:WGG]LBEPRNCOD = 2
  [F:WGG]RCLCOD    = 1
  [F:WGG]RCLDAT    = [0/0/0]
  [F:WGG]RCLUSR    = ""         # Issue number 82926- 2012-06-14 by SR
  Raz [F:WGG]RCLTIM
  [F:WGG]ENGCOD    = 1          # mm 05.11
  [F:WGG]ENGDAT    = [0/0/0]    # mm 05.11
  [F:WGG]ENGUSR    = ""         # Issue number 82926- 2012-06-14 by SR
  Raz [F:WGG]ENGTIM
  [F:WGG]EXPNUM    = 0
  [F:WGG]CCLWGGOPT = 0
  [F:WGG]CREDAT    = date$
  [F:WGG]CRETIM    = mid$(time$,1,2)+mid$(time$,4,2)
  [F:WGG]CREUSR    = GUSER
  [F:WGG]UPDUSR    = ""
  [F:WGG]CCLUSR    = ""
  [F:WGG]UPDDAT    = [0/0/0]
  [F:WGG]CCLDAT    = [0/0/0]

#code 27 = Etiquette pesée partielle
#code 28 = Etiquette pesée partielle
#code 29 = Etiquette pesée complete
#code 30 = Etiquette pesée complete
#code 31 = Etiquette pesée complete

  [F:WGG]WEIFLG    = 3
  If LCODE = "27"  [F:WGG]WEIFLG    = 2 Endif
  If LCODE = "28"  [F:WGG]WEIFLG    = 2 Endif


  [F:WGG]MFGNUM    = F_MFGNUM
  [F:WGG]BOMOPE    = F_BOMOPE
  [F:WGG]ITMREF    = F_ITMREF
  [F:WGG]MFGLIN    = F_MFGLIN
  [F:WGG]BOMSEQ    = F_BOMSEQ
  [F:WGG]EXTSLE    = F_EXTSLE
  [F:WGG]USESLE    = F_USESLE
  [F:WGG]EXTCTN    = F_EXTCTN
  [F:WGG]USECTN    = F_USECTN
  [F:WGG]CTNTAR    = F_CTNTAR
  [F:WGG]TKS       = F_TKS
  [F:WGG]TGTGTS    = F_TGTGTS
  [F:WGG]PKC       = F_PKC
  [F:WGG]CTN       = F_CTN  # CATUA X3-30163 container field in weighing
  [F:WGG]LOT       = F_LOT
  [F:WGG]SLO       = F_SLO
  [F:WGG]LOC       = F_LOC
  [F:WGG]STOCOU    = F_STOCOU
  [F:WGG]STA       = F_STA
  [F:WGG]DEFPOT    = F_DEFPOT
  [F:WGG]POT       = F_POT
  [F:WGG]STU       = F_STU
  [F:WGG]WEU       = F_WEU
  [F:WGG]WEIWEI    = F_WEIWEI
  [F:WGG]WEI       = F_WEI
  [F:WGG]EXC       = F_EXC            # 116324 mm 08.2016
  [F:WGG]ISM       = F_ISM
  [F:WGG]WGGOPT    = F_WGGOPT

  [F:WGG]MFGTRKNUM = [M:MTMK]MFGTRKNUM
  [F:WGG]CLEFLG    = [M:MTMK]CLEFLG
  [F:WGG]TRSNUM    = GWEITRSNUM
  [F:WGG]WEICREUSR = GWEIUSER         #CATUA X3-67237.sn

  # mm 10.11 - Pesée multi-articles
  # oui/non : pas le même code selon qu'on soit en C ou en langage X3
  If  F_MLTITM = 1
    [F:WGG]MLTITMFLG = 2
  Else
    [F:WGG]MLTITMFLG = 1
  Endif

 # 77830 mm 11.11 - balance connectée oui/non
  If  F_CONNEC = 1
    [F:WGG]CONNECFLG = 2
  Else
    [F:WGG]CONNECFLG = 1
  Endif

# lecture Ordre fabrication -articles
  Read [MFI]MFI0=F_MFGNUM;F_MFGLIN
  If fstat Raz[F:MFI] : Endif

  [F:WGG]ITMREFMNU = [F:MFI]ITMREF
  [F:WGG]UOMEXTQTY = [F:MFI]UOMEXTQTY
  [F:WGG]UOM       = [F:MFI]UOM

  # mm 01.08 - point d'entrée permettant de renseigner des zones spécifiques dans [WGG]
  GPOINT = "WGGMAJ" : Gosub  ENTREE From EXEFNC
  If GOK=0 :  Gosub AB_TRT : End : Endif

# ecriture historique
Write [WGG]
If fstat
       WMSGSUI = mess(157,199,1)+" : "+ "WGG"
       TRA = 1
       Call ECR_TRACE(WMSGSUI,1) From GESECRAN
       GOK = 0 : Call FSTA("WGG") From GLOCK : Gosub AB_TRT : End
Endif

If clalev([F:MWGG]) <= 0 : Local File WEIGHING   [MWGG] : Endif
# mm 10.11 - mise à jour du n° de suivi précédant si la pesée courante et précédante ont été réalisées
# en contexte multi-articles cumulé

# mm 10.12 - APCPRD 1596 : la première matière pesée ne doit JAMAIS avoir de n° de suivi précedant
If F_MAT1 <> F_ITMREF
 If  F_MLTITM = 1
  Filter [WGG] Where MFGNUM    = F_MFGNUM &
&                    BOMOPE    = F_BOMOPE &
&                    MFGLIN    = F_MFGLIN &
&                    CBTDAT    = date$    &
&                    find(WEIFLG,2,3)<>0  &
&                    CCLDAT    = [0/0/0]  &
&                    MFGTRKNUM <> [M:MTMK]MFGTRKNUM
&              Order By BOMSEQ Desc ; MVTSEQ Asc
     Read [F:WGG] First
   Filter [WGG]  # mm 02.2013
     If !fstat
       If [F:WGG]MLTITMFLG = 2
         Readlock [F:MWGG]WGG0 = F_MFGNUM;F_BOMOPE;F_ITMREF;F_MFGLIN;F_BOMSEQ;date$;WSEQ
         If fstat=1
            WMSGSUI = mess(157,199,1)+" : "+ "WGG"
            TRA = 1
            Call ECR_TRACE(WMSGSUI,1) From GESECRAN
            GOK=-1 : GLOCK="$WGG"-F_MFGNUM :Gosub AB_TRT : End
         Elsif fstat
             WMSGSUI = mess(157,199,1)+" : "+ "WGG"
             TRA = 1
             Call ECR_TRACE(WMSGSUI,1) From GESECRAN
             GOK=0  : Call RSTA("WGG",F_MFGNUM) From GLOCK
             Gosub AB_TRT : End
         Endif

         # récupération du n° de suivi précédant
         [F:MWGG]TRKNUMPRV = [F:WGG]MFGTRKNUM

         Rewrite [F:MWGG]
         If fstat
           GOK = 0
           WMSGSUI = mess(157,199,1)+" : "+ "WGG"
           TRA = 1
           Call ECR_TRACE(WMSGSUI,1) From GESECRAN
           Call FSTA("WGG") From GLOCK : Gosub AB_TRT : End
         Endif
       Endif
     Endif
 Endif
Endif
# sr 12.11 Demande 79720 (APCPRD-743) Se repositionner sur le bon WGG pour l'impression des étiquettes
Read [F:WGG]WGG0 = F_MFGNUM;F_BOMOPE;F_ITMREF;F_MFGLIN;F_BOMSEQ;date$;WSEQ

# mise a jour balance si code calibrage > 1

If F_CBTCOD > 1
     Readlock [F:SLE]SLE0 = F_USESLE;GSCA1MFGFCY
     If fstat=1
                WMSGSUI = mess(157,199,1)+" : "+ "SLE"
                TRA = 1
                Call ECR_TRACE(WMSGSUI,1) From GESECRAN
                GOK=-1 : GLOCK="$SCALES"-F_USESLE :Gosub AB_TRT : End
     Elsif fstat
               WMSGSUI = mess(157,199,1)+" : "+ "SLE"
               TRA = 1
               Call ECR_TRACE(WMSGSUI,1) From GESECRAN
               GOK=0  : Call RSTA("SLE",F_USESLE) From GLOCK
               Gosub AB_TRT
               End
     Endif

     [F:SLE]NBRWGGCBT  += 1

     Rewrite [F:SLE]
     If fstat
        GOK = 0
        WMSGSUI = mess(157,199,1)+" : "+ "SLE"
        TRA = 1
        Call ECR_TRACE(WMSGSUI,1) From GESECRAN
        Call FSTA("SLE") From GLOCK : Gosub AB_TRT : End
     Endif
Endif

# maj MFGHEAD MFGMAT
# mm 12.10 - on remet [MFM]WGGBOX à 1
# 85521 mm 10.12 - Gérer WGGBOX pour la pesée par OF + 86183
#If find (LCODE, "27","28")
#  Call MAJ_FICHIERS ("MFM",0,1,F_MFGNUM,F_ITMREF,F_MFGLIN,F_BOMSEQ)
#Endif


If LCODE = "29"
# cas particulier de la pesée par article
   Call MAJ_FICHIERS ("MFM",3,1,F_MFGNUM,F_ITMREF,F_MFGLIN,F_BOMSEQ)
   If GOK < 1
          WMSGSUI = mess(157,199,1)+" : "+ "MFM" + LCODE
          TRA = 1
          Call ECR_TRACE(WMSGSUI,1) From GESECRAN
          Gosub AB_TRT :  End
  Endif
Endif
If LCODE = "30"
   Call MAJ_FICHIERS ("MFM",3,1,F_MFGNUM,F_ITMREF,F_MFGLIN,F_BOMSEQ)
   If GOK < 1
          WMSGSUI = mess(157,199,1)+" : "+ "MFM" + LCODE
          TRA = 1
          Call ECR_TRACE(WMSGSUI,1) From GESECRAN
          Gosub AB_TRT :  End
   Endif
Endif
If LCODE = "31"
   Call MAJ_FICHIERS ("MFM",3,1,F_MFGNUM,F_ITMREF,F_MFGLIN,F_BOMSEQ)
   If GOK < 1
          WMSGSUI = mess(157,199,1)+" : "+ "MFM" + LCODE
          TRA = 1
          Call ECR_TRACE(WMSGSUI,1) From GESECRAN
          Gosub AB_TRT :  End
   Endif
   #X3-66324.sn JOBRO
   # We may not be done with the work order.  Could be the case where the weigher
   # does not have access to materials that still need to be weighed
   Filter [F:MFM2] Where MFGNUM=F_MFGNUM and PKC>1 and WGGSTA=1
   Read [F:MFM2] First
   If fstat=0
      Call MAJ_FICHIERS ("MFG",3,0,F_MFGNUM,"",0,0) # put order back on plan
   Else
   #X3-66324.en
      Call MAJ_FICHIERS ("MFG",5,8,F_MFGNUM,"",0,0)  # complete the order
   Endif  #X3-66324
   Filter [F:MFM2]  #X3-66324
   If GOK < 1
          WMSGSUI = mess(157,199,1)+" : "+ "MFG" + LCODE
          TRA = 1
          Call ECR_TRACE(WMSGSUI,1) From GESECRAN
          Gosub AB_TRT :  End
   Endif
Endif

#--- Spécifique pesée --------------------------------------------------#
# maj suivi
#Gosub MAJ_SUIVI
Case LCODE
 When "27","28","29","30","31" : Gosub MAJ_SUIVI
 When Default        : GPOINT="TRT_LCODE"
                       Gosub ENTREE From EXEFNC
                       If LCODE="88"
                          Gosub CHG_EMP
                          If GOK<1 Gosub AB_TRT : End Endif
                       Endif
Endcase

# Exemple de séquence à écrire dans le PE pour faire du
# changement d'emplacement suite à une pesée
#      Local Decimal LQTY, LSHT
#      Local Integer LNBR, LNBJ, LRET
#      Raz [M:STW]
#      [M:STW]STOFCY    = GSCA1MFGFCY
#      [M:STW]TRSTYP    = 7            : Changement emplacement
#      [M:STW]ITMREF    = F_ITMREF
#      [M:STW]LOCENT    = Emplacement destination
#      [M:STW]CUR       = GLOCALDEV
#      [M:STW]IPTDAT    = date$
#      [M:STW]PRIORDH   = 0
#      [M:STW]PIOQTY    = 3
#      [M:STW]VCRTYP    = 10           : OF
#      [M:STW]VCRNUM    = F_MFGNUM
#      [M:STW]VCRLIN    = F_MFGLIN
#      [M:STW]SEQ       = F_SEQ
#      [M:STW]STOCOU(0) = F_STOCOU
#      LQTY             = F_WEIWEI_US
#      Call ALISTOWORK(11,0,LQTY,LSHT,LNBR,LNBJ,LRET) From STKINT
#      # Mise à jour des stock
#      If LRET=0
#         Call MAJ_STOCK From STKMAJ
#      Endif
#      If LRET<>0 | GOK<1
#         GOK=0
#      Endif

#--- Fin spécifique pesée ----------------------------------------------#

If GOK < 1 : End : Endif

# edition etiquette de pesée

If LCODE = "27" Gosub ETI_PESEE : Endif
If LCODE = "28" Gosub ETI_PESEE : Endif
If LCODE = "29" Gosub ETI_PESEE : Endif
If LCODE = "30" Gosub ETI_PESEE : Endif
If LCODE = "31" Gosub ETI_PESEE : Endif



Local Char    NOMETA
Local Integer TYPETA

#document fin phase
If LCODE = "30"
   NOMETA = GWEIRPTOPE
   TYPETA = 3
   Gosub PESE_IMPRESSION : Endif

#document fin phase + fin of
If LCODE  = "31"
   NOMETA = GWEIRPTOPE
   TYPETA = 3
   Gosub PESE_IMPRESSION
   NOMETA = GWEIRPTOF
   TYPETA = 4
   Gosub PESE_IMPRESSION : Endif

# saisie procedure de vide
# desactivée le 12 11 01 à la demande de EP
#If LCODE = "30" Gosub SAI_PROCEDURE Endif
#If LCODE = "31" Gosub SAI_PROCEDURE Endif

# retour lecture X3ScalesWgg
Until fstat <> 0


$FIN_WGG
# fermeture de l'enregistrement
Openi

#--- Spécifique pesée --------------------------------------------------#
# On restitue le LCODE origine pour reboucler sur la pesée
If !find(LCODE,"27","28","29","30","31")
   LCODE = SVG_LCODE
Endif

End


#####################################
#--- Spécifique pesée --------------------------------------------------#
$CHG_EMP


   Local Decimal LQTY, LSHT
   Local Integer LNBR, LNBJ, LRET
   Raz [M:STW]
   [M:STW]STOFCY    = GSCA1MFGFCY
   [M:STW]TRSTYP    = 7            : # Changement d'emplacement
   [M:STW]ITMREF    = F_ITMREF
   [M:STW]LOCENT    = "WEI1"
   [M:STW]CUR       = GLOCALDEV
   [M:STW]IPTDAT    = date$
   [M:STW]PRIORDH   = 0
   [M:STW]PIOQTY    = 3
   [M:STW]VCRTYP    = 10           : # OF
   [M:STW]VCRNUM    = F_MFGNUM
   [M:STW]VCRLIN    = F_MFGLIN
   [M:STW]SEQ       = F_SEQ
   [M:STW]STOCOU(0) = F_STOCOU
   LQTY             = F_WEIWEI_US
   Call ALISTOWORK(11,0,LQTY,LSHT,LNBR,LNBJ,LRET) From STKINT
   # Mise à jour des stock
   If LRET=0
      Call MAJ_STOCK From STKMAJ
   Endif
   If LRET<>0 | GOK<1
      GOK=0 : Return
   Else
      Commit
   Endif
Return
#####################################



########################################################################
# Mise jour fichier suivi
########################################################################
$MAJ_SUIVI
Local Integer WFICFLG
Local Integer I,OK,WOK, WLIN, STAT, LRET, WRETOUR, WRET
Local Date WDAT
Local Char WMFGNUM(GLONVCR),WWMFGNUM(GLONVCR),WMFGTRKNUM(GLONVCR),TIT(80),WMSGSUI(80)
Local Char WNUMTEX (12)
Local Decimal WWQTY, WALLQTY,WSHTQTY,WWALLQTY,WWSHTQTY, WRMNQTY
#

Call CRE_MKM("",0) From MTKAUTLIB
If GOK < 1
   WMSGSUI = mess(157,199,1)+" : "+ "MKM"
   TRA = 1
   Call ECR_TRACE(WMSGSUI,1) From GESECRAN
   Gosub AB_TRT :  Return
Endif
Gosub MAJ_ENTOF
Gosub CRE_ENTETE

If [F:MFM]PKC = 10 & [F:MFM]MFMTRKFLG = 5
    Call SOLDE_RECTIF([F:MFM]MFGNUM,LCODE)
Endif

# 89312 mm 03.2013
If find(LCODE,"27","28")
  # 55296 mm 04.09
  Gosub RELOAD_LOT
Endif

Return

############################################
$MAJ_ENTOF
#Maj entête d'OF
Readlock [F:MFG]MFG0 = [M:MTMK]MFGNUM
If fstat=1  GOK=-1
   WMSGSUI = mess(157,199,1)+" : "+ "MFG"
   TRA = 1
   Call ECR_TRACE(WMSGSUI,1) From GESECRAN
   GLOCK="$MFGHEAD"-num$([M:MTMK]MFGNUM)
   Return
Elsif fstat
   WMSGSUI = mess(157,199,1)+" : "+ "MFG"
   TRA = 1
   Call ECR_TRACE(WMSGSUI,1) From GESECRAN
   GOK=0  : Call RSTA("MFG",num$([M:MTMK]MFGNUM)) From GLOCK
   Return
Endif

#si matiere à soldé + 1 dans matclenbr

If [M:MTMK]CLEFLG = 2
   [F:MFG]MATCLENBR += 1 : Endif

If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
&  [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
&  [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
   [F:MFG]MFGTRKFLG = 5
    # CCC (10/01/08) DM 44021
#   [F:MFG]TRKLAST   = date$
Else
   [F:MFG]MFGTRKFLG = 4
    # CCC (10/01/08) DM 44021
#   Raz [F:MFG]TRKLAST
Endif
# CCC (10/01/08) DM 44021
If [F:MFG]TRKLAST<date$
   [F:MFG]TRKLAST   = date$
Endif
If [F:MFG]TRKLASTC<date$
   [F:MFG]TRKLASTC  = date$
Endif
If [F:MFG]TRKFIRST>date$ | [F:MFG]TRKFIRST = "00/00/00"
    [F:MFG]TRKFIRST = date$
Endif
If [F:MFG]TRKFIRSTC>date$ | [F:MFG]TRKFIRSTC = "00/00/00"
    [F:MFG]TRKFIRSTC = date$
Endif
Rewrite [F:MFG]
If fstat
   WMSGSUI = mess(157,199,1)+" : "+ "MFG"
   TRA = 1
   Call ECR_TRACE(WMSGSUI,1) From GESECRAN
   GOK = 0 : Call FSTA("MFG") From GLOCK : Return
Endif
#----- MISE à jour statistiques entête OF -----#
Call VALSTA("MFG",1) From SUBPS2
If GOK < 1
   WMSGSUI = mess(157,199,1)+" : "+ "SAT"
   TRA = 1
   Call ECR_TRACE(WMSGSUI,1) From GESECRAN
   Return
Endif
Return

############################################################
#Création entête de suivi
$CRE_ENTETE
If GOK = 1
    Raz [F:MTK]
    Read [F:MFG] = [M:MTMK]MFGNUM
       If !fstat : [F:MTK] = [F:MFG] : Endif

    [F:MTK]MFGFCY    = GSCA1MFGFCY
    [F:MTK]MFGTRKNUM = [M:MTMK]MFGTRKNUM
    [F:MTK]MFGTRKDAT = date$
    [F:MTK]CREDAT    = date$
    [F:MTK]CREUSR    = GUSER
    [F:MTK]EXPNUM    = [C]EXPORT
    Raz [F:MTK]UPDUSR
    Raz [F:MTK]UPDDAT
    [F:MTK]OPETRKFLG = 1
    [F:MTK]ITMTRKFLG = 1
    [F:MTK]MATTRKFLG = 2
    [F:MTK]NBRMAT    = 1
    # 49504 mm 10.08 : PE pour gérer des zones spécifiques
    GPOINT="CRE_MTK": Gosub ENTREE From EXEFNC

    Write [F:MTK]
    If fstat : GOK = 0 : Call FSTA("MTK") From GLOCK : Endif
Endif
If GOK < 1
     WMSGSUI = mess(157,199,1)+" : "+ "MTK"
     TRA = 1
     Call ECR_TRACE(WMSGSUI,1) From GESECRAN
     Rollback
Else
    Commit
    WMSGSUI = mess(79,190,1)+" : "+[F:MTK]MFGTRKNUM
Endif

Return

#################################################################
# on vient de solder le QSP, faut-il solder en même temps des matières de rectif ?
Subprog SOLDE_RECTIF(LMFGNUM,LCODE)
Value    Char       LMFGNUM
Value    Char       LCODE

Local Integer WNBSOLDE, WNBLIG
Local Char    NOMETA
Local Integer TYPETA

Raz WNBSOLDE, WNBLIG
If !clalev([F:MFM1]) : Local File MFGMAT [MFM1] : Endif
Filter [F:MFM1] Where MFGNUM = LMFGNUM & CPNTYP <> 5
For [F:MFM1]
    If [F:MFM1]MATSTA <> 4    : WNBLIG +=1 : Endif
    If [F:MFM1]MFMTRKFLG >= 5 : WNBSOLDE +=1
    Else
       If find([F:MFM1]PKC,8,9) & [F:MFM1]BOMOPE <> 900
           F_ITMREF = [F:MFM1]ITMREF
           F_MFGLIN = [F:MFM1]MFGLIN
           F_BOMSEQ = [F:MFM1]BOMSEQ
           Call MAJ_SOLDE_MATIERE_BIS (LMFGNUM,[F:MFM1]MFGLIN,[F:MFM1]BOMSEQ,[F:MFM1]ITMREF,"43")  From SCALEXCHAN
           WNBSOLDE += 1
       Endif
    Endif
Next
Filter [F:MFM1]
# Il faut passer l'OF à fin de pesée
If WNBSOLDE = WNBLIG
    NOMETA = GWEIRPTOPE
    TYPETA = 3
    Gosub PESE_IMPRESSION
    NOMETA = GWEIRPTOF
    TYPETA = 4
    Gosub PESE_IMPRESSION

   Call DEBTRANS From GLOCK
   Trbegin [MFG]
   Call MAJ_FICHIERS ("MFG",5,8,LMFGNUM,"",0,0)
   If GOK < 1 : Rollback
   Else       : Commit
   Endif
Endif
End

#######################################################################
# recherche du chrono de stock + rechargement des lignes de stock éligibles
$RELOAD_LOT
Local    Integer I
Local    Integer WRET : WRET=0
# sr 05.02 contrôle sur les x premiers caratères
Local    Char    WLOT(GLENLOT), WFILTRE_LOT(GLENLOT)
Local    Integer WLOT_KO
Local    Char    WCRITSTO(240)
Local    Char    DEPOT(GLONWRH): DEPOT      = ""    # pour calcul qté dispo : depot
Local    Char    LOC(GLONEMP)  : LOC        = ""    # emplacement
Local    Integer WPATLOC       : WPATLOC    = 0     # mm 01.11
Local    Integer SAVIUM : SAVIUM = adxium
Local    Integer WLOTINVALIDE  : WLOTINVALIDE = 0   # 92824 mm 09.2013

adxium = GASCII

# lecture du dépôt associé au box
Call LEC_WRH(DEPOT,LOC)
If LOC<>""
  If instr(1,LOC,"*")<>0
  # l'emplacement du box comporte le caractère "*"
     WPATLOC =1
  Endif
Endif

Read [MFM]MFM0=F_MFGNUM;F_MFGLIN;F_BOMSEQ;F_ITMREF
If fstat : Raz [F:MFM] : Return : Endif

Read [STO]STO0(1) = GSCA1MFGFCY
If fstat : Raz [F:STO] : Endif

#  extraction des lots + rechargement du fichier Scalessto.csv
# Issue 83006 - 2012-06-19 by MM: ajout des 2 paramètres DEPOT et LOC
Call EXTRACTION_LOT(F_MFGNUM,F_ITMREF,0,F_MFGLIN,F_BOMSEQ,2,[F:MFM]RETDAT,WPATLOC,DEPOT,LOC,WLOTINVALIDE)
Call TRF_STO

Return

########################################################################
# Edition etiquette de pesée
########################################################################
$ETI_PESEE

Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
Local Char NOMETA_RPT,NOMETA
Local Integer TYPETA
Local Date CURDATE
Local Char WPRN
Local Char PRNOUT

PRNOUT = ""

# SPE-PR-054 Ré-impression étiquettes

CURDATE = date$

NOMETA      = GWEIRPTETI
NOMETA_RPT  = F_CONTENU_ISM
NOMETA_RPT += F_FORMAT_CTN
# si rien de spécial paramétré on prend NOMETA
If NOMETA_RPT = "" & NOMETA <> ""
   NOMETA_RPT = NOMETA
Endif
TYPETA      = 2

If NOMETA = "" Return : Endif

Call IMPRESSION2(NOMETA,NOMETA_RPT,TYPETA,PRNOUT)

Call DEBTRANS From GLOCK
Trbegin [WGG]
Readlock [F:WGG]WGG0 = F_MFGNUM;F_BOMOPE;F_ITMREF;F_MFGLIN;F_BOMSEQ;CURDATE;WSEQ
If fstat=1     GOK=-1 : GLOCK="$WGG"-F_MFGNUM : Goto AB_ETIPESEE
Elsif fstat GOK=0  : Call RSTA("WGG",F_MFGNUM) From GLOCK : Goto AB_ETIPESEE
Endif

#flag etiquette pesée à imprimée
[F:WGG]LBEPRNCOD = 3

Rewrite [F:WGG]
If fstat : Goto AB_ETIPESEE
Else
   Commit
Endif
# sr 12.04 demande 37308 point d'entrée permettant d'effectuer un traitement supplémentaire
#par exemple, lancer une impression
GPOINT = "CUSTRTSUP" : Gosub  ENTREE From EXEFNC

Return

$AB_ETIPESEE
Rollback
Return


###########################################################################
$PESE_IMPRESSION
###########################################################################

Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
If NOMETA = "" Return : Endif

Call IMPRESSION(NOMETA,"",TYPETA)

Return

########################################################################
# Edition etiquette de calibrage
########################################################################
$ETI_CALIBRAGE

Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)

If NOMETA = "" Return : Endif

Call IMPRESSION(NOMETA,"",TYPETA)

Readlock [F:CBT]CBT0 = GSCA1MFGFCY;SAV_SLE;date$;WSEQ
  If fstat=1     GOK=-1 : GLOCK="$CBT" - SAV_SLE : Return
               Elsif fstat GOK=0  : Call RSTA("CBT",SAV_SLE) From GLOCK
               Return
  Endif

#flag etiquette calibrage à imprimée
[F:CBT]LBEPRNCOD = 3

  Rewrite [F:CBT]
         If fstat
               GOK = 0 : Call FSTA("CBT") From GLOCK : Return
         Endif

Return

########################################################################
# Saisie procedure de vide
########################################################################
# si F_procedure renseigne  , alors execution et type obligatoire      #

$SAI_PROCEDURE
Local Shortint LTYP
LTYPE = 0
If F_PROCEDURE = "" Return : Endif
If LCODE = "30" LTYPE = 3 Endif
If LCODE = "31" LTYPE = 2 Endif
Call WIN_PROCEDURE(F_PROCEDURE,F_MFGNUM,F_BOMOPE,F_ITM,LTYP,2,0,1)  # mm 06.11

Return


###########################################################################
#             Solde d'une matière  WEIGHING /WGG
###########################################################################
Subprog MAJ_SOLDE_MATIERE (LCODE)
Value Char LCODE
Local Decimal  WSEQ
Local Integer OK, STAT, WAUTO, WMATCLENBR

Local Date WDAT


Local Char     F_MFGNUM       (GLONVCR)
Local Shortint F_BOMOPE
Local Char     F_ITMREF       (GLONITM)    # mm 05.08
Local Integer  F_MFGLIN
Local Integer  F_BOMSEQ
Local Char     F_EXTSLE       (08)
Local Char     F_USESLE       (08)
Local Shortint F_CBTCOD
Local Char     F_EXTCTN       (08)
Local Char     F_USECTN       (08)
Local Decimal  F_CTNTAR
Local Shortint F_MLTITM                   # sr 12.11 Demande 78887
Local Shortint F_CONNEC                   # sr 12.11 Demande 78887
Local Char     F_TKS          (08)
Local Char     F_TGTGTS       (08)
Local Shortint F_PKC
Local Char     F_LOT          (GLONLOT)     # 57505 mm 08.09
Local Char     F_SLO          (GLONSLO)     # sr 12.11 Demande 78887 + mm 98779 08.2014
Local Char     F_LOC          (10)
Local Char     F_STA          (03)
Local Decimal  F_DEFPOT
Local Decimal  F_POT
Local Char     F_STU          (3)
Local Char     F_WEU          (3)
Local Decimal  F_WEIWEI
Local Decimal  F_WEI
Local Char     F_ISM          (8)
Local Shortint F_WGGOPT
Local Char     WFIL           (06)
Local Decimal  F_STOCOU
Local Integer  F_SEQ
Local Char     F_PROCEDURE    (8)
Local Char     F_CONTENU_ISM  (7)
Local Char     F_FORMAT_CTN   (7)

WDAT = date$

If clalev([M:ORDK]) <= 0 : Local Mask ORDK       [ORDK] : Endif


If clalev([F:WGG])  <= 0 : Local File WEIGHING   [WGG]  : Endif
If clalev([F:TCA])  <= 0 : Local File TABCOUAFF  [TCA]  : Endif
If clalev([F:MFM])  <= 0 : Local File MFGMAT     [MFM]  : Endif
If clalev([F:MFG])  <= 0 : Local File MFGHEAD    [MFG]  : Endif
If clalev([F:MTK])  <= 0 : Local File MFGHEADTRK [MTK]  : Endif
If clalev([F:MFI])  <= 0 : Local File MFGITM     [MFI]  : Endif


Local Char WGGFILE (200)

# transfert fichiers pesee du client vers le serveur
Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Call CSV2ILFIL(GFCY,"ilwgg","X3ScalesWgg") From OPTLIB

WGGFILE = func OPTLIB.FILNAM(GFCY,"ilwgg",0)

adxifs = ";"
adxirs = chr$(10)

# Ouverture du fichier X3ScalesWgg en lecture

Openi WGGFILE Using [WGGF]




# Lecture fichier X3ScalesWgg
Repeat
Call ECR_TRACE("***lecture de X3ScalesWgg*** " ,0)From GESECRAN
# sr 12.11 Demande 78887
#Rdseq F_MFGNUM,F_BOMOPE,F_ITMREF,F_MFGLIN,F_BOMSEQ,F_EXTSLE,F_USESLE,F_CBTCOD,
#&     F_EXTCTN,F_USECTN,F_CTNTAR,F_TKS,F_TGTGTS,F_PKC,F_LOT,F_LOC,F_STA,
#&     F_DEFPOT,F_POT,F_STU,F_WEU,F_WEIWEI,F_WEI,F_ISM,F_WGGOPT,F_STOCOU,F_SEQ,
#&     F_CONTENU_ISM,F_FORMAT_CTN,F_PROCEDURE,WFIL
#&     Using [WGGF]

Rdseq F_MFGNUM,F_BOMOPE,F_ITMREF,F_MFGLIN,F_BOMSEQ,F_EXTSLE,F_USESLE,F_CBTCOD,F_CONNEC,
&     F_EXTCTN,F_USECTN,F_CTNTAR,F_MLTITM,F_TKS,F_TGTGTS,F_PKC,F_LOT,F_SLO,F_LOC,F_STA,
&     F_DEFPOT,F_POT,F_STU,F_WEU,F_WEIWEI,F_WEI,F_ISM,F_WGGOPT,F_STOCOU,F_SEQ,
&     F_CONTENU_ISM,F_FORMAT_CTN,F_PROCEDURE,WFIL
&     Using [WGGF]

If fstat = 1 Goto FIN_WGGSOLDE : Endif
If fstat = 5 Goto FIN_WGGSOLDE : Endif


Call DEBTRANS From GLOCK
Trbegin [MFM]
Gosub SOLDE_UNE_MATIERE


If GOK <= 0 : Gosub AB_TRT : Break
Else        : Commit
Endif

If [F:MFM]PKC = 10 & [F:MFM]MFMTRKFLG = 5
    Call SOLDE_RECTIF([F:MFM]MFGNUM,LCODE)
Endif

Local Char    NOMETA
Local Integer TYPETA

#document fin phase
If LCODE = "44"
   NOMETA = GWEIRPTOPE
   TYPETA = 3
   Gosub PESE_IMPRESSION : Endif

#document fin phase + fin of
If LCODE = "45"
   NOMETA = GWEIRPTOPE
   TYPETA = 3
   Gosub PESE_IMPRESSION
   NOMETA = GWEIRPTOF
   TYPETA = 4
   Gosub PESE_IMPRESSION : Endif

# saisie procedure de vide
# desactivée le 12 11 01 à la demande de EP
#If LCODE = "44" Gosub SAI_PROCEDURE Endif
#If LCODE = "45" Gosub SAI_PROCEDURE Endif

# retour lecture X3ScalesWgg

Until fstat <> 0


$FIN_WGGSOLDE
# fermeture de l'enregistrement
Openi

End


##############################################################
$SOLDE_UNE_MATIERE


#Lecture matière OF avec lock
Readlock [F:MFM]MFM0 = F_MFGNUM;F_MFGLIN;F_BOMSEQ;F_ITMREF

If fstat=1  GOK=-1 : GLOCK="$MFGMAT"-F_MFGNUM - F_ITMREF : Return
Elsif fstat GOK=0  : Call RSTA("MFM",F_MFGNUM - F_ITMREF) From GLOCK : Return
Endif

MEMSTA = [F:MFM]MATSTA

Gosub SOLDE_MAT From FUNMFGS

If GOK < 1 : Return : Endif
If [F:MFM]MFGLIN <> 0
    Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
    If fstat : GOK=0: Call RSTA("MFI",num$([F:MFM]MFGLIN)) From GLOCK : Return : Endif
Else
    Filter [F:MFI] Where MFGNUM = [F:MFM]MFGNUM
    Read [F:MFI]MFI0 First
    If fstat : GOK=0: Call RSTA("MFI",num$([F:MFM]MFGLIN)) From GLOCK : Return : Endif
    Filter [F:MFI]
Endif
If [F:MFM]MATSTA = 3
    Call UPDATE_MFX("A", [F:MFI]PJT,[F:MFI]BOMALT, 0) From MFGLIBM
Else
    Call UPDATE_MFX("C", [F:MFI]PJT,[F:MFI]BOMALT, 0) From MFGLIBM
Endif
Rewrite [F:MFM]
If fstat
   GOK = 0 : Call FSTA("MFM") From GLOCK
   Return
Endif

#----------------------- Maj  Entête OF ------------------------------------#
Readlock [F:MFG]MFG0 = [F:MFM]MFGNUM
If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-[F:MFM]MFGNUM : Return
Elsif fstat GOK=0  : Call RSTA("MFG",[F:MFM]MFGNUM) From GLOCK : Return
Endif
[F:MFG]MATCLENBR = WMATCLENBR
If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
&  [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
&  [F:MFG]MATCLENBR = [F:MFG]MATLINNBR : [F:MFG]MFGTRKFLG = 5
Else                                   : [F:MFG]MFGTRKFLG = 4
Endif
If [F:MFM]MATSTA < 3 : Gosub MAJMFG  From SUBMFS3 : Endif
Rewrite [F:MFG]
If fstat
   GOK = 0 : Call FSTA("MFG") From GLOCK
   Return
Endif


# Mise jour fichier WEIGHING

  Filter [WGG] Where MFGNUM    = F_MFGNUM &
&                    BOMOPE    = F_BOMOPE &
&                    ITMREF    = F_ITMREF &
&                    MFGLIN    = F_MFGLIN &
&                    BOMSEQ    = F_BOMSEQ &
&                    CBTDAT    = date$
&              Order By Key WGG0
  Read [WGG] First
  Filter [WGG]      # mm 02.2013
    If fstat = 0  WSEQ =[F:WGG]MVTSEQ-1
       Else       WSEQ = 9999
    Endif
  Raz [F:WGG]

  [F:WGG]CBTDAT    = date$
  [F:WGG]MVTSEQ    = WSEQ
  [F:WGG]EXCNUM    = val(LCODE)
  [F:WGG]STI       = GSCA1STI
  [F:WGG]BOX       = GSCA1BOX
  [F:WGG]FCY       = GSCA1MFGFCY
  [F:WGG]LBEPRNCOD = 2
  [F:WGG]RCLCOD    = 1
  [F:WGG]RCLDAT    = [0/0/0]
  [F:WGG]RCLUSR    = ""         # Issue number 82926- 2012-06-14 by SR
  Raz [F:WGG]RCLTIM
  [F:WGG]ENGCOD    = 1            # mm 05.11
  [F:WGG]ENGDAT    = [0/0/0]      # mm 05.11
  [F:WGG]ENGUSR    = ""         # Issue number 82926- 2012-06-14 by SR
  Raz [F:WGG]ENGTIM
  [F:WGG]EXPNUM    = 0
  [F:WGG]CCLWGGOPT = 0
  [F:WGG]CREDAT    = date$
  [F:WGG]CRETIM    = mid$(time$,1,2)+mid$(time$,4,2)
  [F:WGG]CREUSR    = GUSER
  [F:WGG]UPDUSR    = ""
  [F:WGG]CCLUSR    = ""
  [F:WGG]UPDDAT    = [0/0/0]
  [F:WGG]CCLDAT    = [0/0/0]

#code 43 = Etiquette pesée complete
#code 44 = Etiquette pesée complete
#code 45 = Etiquette pesée complete

  [F:WGG]WEIFLG    = 3

  [F:WGG]MFGNUM    = F_MFGNUM
  [F:WGG]BOMOPE    = F_BOMOPE
  [F:WGG]ITMREF    = F_ITMREF
  [F:WGG]MFGLIN    = F_MFGLIN
  [F:WGG]BOMSEQ    = F_BOMSEQ
  [F:WGG]EXTSLE    = F_EXTSLE
  [F:WGG]USESLE    = F_USESLE
  [F:WGG]EXTCTN    = F_EXTCTN
  [F:WGG]USECTN    = F_USECTN
  [F:WGG]CTNTAR    = F_CTNTAR
  [F:WGG]TKS       = F_TKS
  [F:WGG]TGTGTS    = F_TGTGTS
  [F:WGG]PKC       = F_PKC
  [F:WGG]WGGOPT    = F_WGGOPT

  [F:WGG]CLEFLG    = 2

  [F:WGG]ITMREFMNU = [F:MFI]ITMREF
  [F:WGG]UOMEXTQTY = [F:MFI]UOMEXTQTY
  [F:WGG]UOM       = [F:MFI]UOM

 # mm 01.08 - point d'entrée permettant de renseigner des zones spécifiques dans [WGG]
  GPOINT = "WGGMAJ" : Gosub  ENTREE From EXEFNC
  If GOK = 0 : Return : Endif

# ecriture historique
Write [WGG]
If fstat GOK = 0 : Call FSTA("WGG") From GLOCK : Return: Endif

If LCODE = "43"
   Call MAJ_FICHIERS ("MFM",3,0,F_MFGNUM,F_ITMREF,F_MFGLIN,F_BOMSEQ)
   If GOK < 1 : Return : Endif

Endif
If LCODE = "44"
   Call MAJ_FICHIERS ("MFM",3,0,F_MFGNUM,F_ITMREF,F_MFGLIN,F_BOMSEQ)
   If GOK < 1 : Return : Endif

Endif
If LCODE = "45"
   Call MAJ_FICHIERS ("MFM",3,0,F_MFGNUM,F_ITMREF,F_MFGLIN,F_BOMSEQ)
   If GOK < 1 : Return : Endif

   Call MAJ_FICHIERS ("MFG",5,8,F_MFGNUM,"",0,0)
   If GOK < 1 : Return : Endif

Endif
Call ECR_TRACE("Fin SOLDE_MAT",0) From GESECRAN
Return



########################################################################
Subprog MAJ_SOLDE_MATIERE_BIS (LMFGNUM,LMFGLIN,LBOMSEQ,LITMREF,LCODE)
Value Char     LMFGNUM
Value Integer  LMFGLIN
Value Integer  LBOMSEQ
Value Char     LITMREF
Value Char     LCODE          # FQ 48773 ctrl des sources: paramètre absent

Local Decimal  WSEQ
Local Integer  OK, STAT, WAUTO, WMATCLENBR

Local Char     F_MFGNUM       (GLONVCR)
Local Char     F_ITMREF       (GLONITM)    # mm 05.08
Local Integer  F_MFGLIN
Local Integer  F_BOMSEQ
Local Integer  F_BOMOPE
Local Char     F_EXTSLE       (08)
Local Char     F_USESLE       (08)
Local Shortint F_CBTCOD
Local Char     F_EXTCTN       (08)
Local Char     F_USECTN       (08)
Local Decimal  F_CTNTAR
Local Shortint F_MLTITM                   # sr 12.11 Demande 78887
Local Shortint F_CONNEC                   # sr 12.11 Demande 78887
Local Char     F_TKS          (08)
Local Char     F_TGTGTS       (08)
Local Shortint F_PKC
Local Char     F_CTN          (08)        # CATUA X3-30163 container field in weighing
Local Char     F_LOT          (GLONLOT)     # 57505 mm 08.09
Local Char     F_SLO          (GLONSLO)     # sr 12.11 Demande 78887 + mm 98779 08.2014
Local Char     F_LOC          (10)
Local Char     F_STA          (03)
Local Decimal  F_DEFPOT
Local Decimal  F_POT
Local Char     F_STU          (3)
Local Char     F_WEU          (3)
Local Decimal  F_WEIWEI
Local Decimal  F_WEI
Local Char     F_ISM          (8)
Local Shortint F_WGGOPT
Local Char     WFIL           (06)
Local Decimal  F_STOCOU
Local Integer  F_SEQ
Local Char     F_PROCEDURE    (8)
Local Char     F_CONTENU_ISM  (7)
Local Char     F_FORMAT_CTN   (7)
Local Integer  MEMSTA

WDAT = date$

If clalev([M:ORDK]) <= 0 : Local Mask ORDK       [ORDK] : Endif


If clalev([F:WGG])  <= 0 : Local File WEIGHING   [WGG]  : Endif
If clalev([F:TCA])  <= 0 : Local File TABCOUAFF  [TCA]  : Endif
If clalev([F:MFM])  <= 0 : Local File MFGMAT     [MFM]  : Endif
If clalev([F:MFG])  <= 0 : Local File MFGHEAD    [MFG]  : Endif
If clalev([F:MTK])  <= 0 : Local File MFGHEADTRK [MTK]  : Endif
If clalev([F:MFI])  <= 0 : Local File MFGITM     [MFI]  : Endif

Read [F:MFM]MFM0 = LMFGNUM;LMFGLIN;LBOMSEQ;LITMREF
If fstat : Raz [F:MFM] : End : Endif
F_MFGNUM    = LMFGNUM
F_MFGLIN    = LMFGLIN
F_BOMSEQ    = LBOMSEQ
F_ITMREF    = LITMREF
F_BOMOPE    = [F:MFM]BOMOPE
F_PKC       = [F:MFM]PKC

Call DEBTRANS From GLOCK
Trbegin [MFM]

Gosub SOLDE_UNE_MATIERE

If GOK <= 0 : Gosub AB_TRT
Else        : Commit
Endif
End


########################################################################
# Mise jour fichier MFGHEAD MFGMAT SCALES
########################################################################
Subprog MAJ_FICHIERS (FICH,VAL1,VAL2,LNUM,LITM,LLIN,LSEQ)
Value    Char     FICH
Value    Integer  VAL1
Value    Integer  VAL2
Value    Char     LNUM
Value    Char     LITM
Value    Integer  LLIN
Value    Integer  LSEQ

If FICH = "MFG" Gosub MAJ_MFG : Endif

If FICH = "MFM" Gosub MAJ_MFM : Endif

If FICH = "SLE" Gosub MAJ_SLE : Endif

End

########################################################################
# Mise à jour fichier SCALES
########################################################################
$MAJ_SLE
# val1 correspond au code de mise à jour de la balance
#                           10 choix pour la pesee
#                           11 validation de la pesee
#                           19 fin de pesage
#                           20 choix pour l etalonnage
#                           28 fin etalonnage KO
#                           29 fin etalonnage OK
# lnum correspond au numero de balance
      Readlock [F:SLE]SLE0 = LNUM;GSCA1MFGFCY
         If fstat=1     GOK=-1 : GLOCK="$SCALES"-LNUM : Return
               Elsif fstat GOK=0  : Call RSTA("SLE",LNUM) From GLOCK
            Return
         Endif
         If VAL1 = 10 [F:SLE]AVACOD  = 3
                      [F:SLE]USRUSR  = GUSER
         Endif
         If VAL1 = 11 [F:SLE]NBRWGGCBT+= 1
         Endif
         If VAL1 = 19 [F:SLE]AVACOD  = 2
                      [F:SLE]USRUSR  = ""
         Endif
         If VAL1 = 20 [F:SLE]AVACOD  = 4
                      [F:SLE]USRUSR  = GUSER
         Endif
         If VAL1 = 28 [F:SLE]AVACOD  = 5
                      [F:SLE]USRUSR  = ""
         Endif
         If VAL1 = 29 [F:SLE]AVACOD  = 2
                      [F:SLE]USRUSR  = ""
                      [F:SLE]LASCBTDAT = date$
                      [F:SLE]NBRWGGCBT = 0
         Endif
      Rewrite [F:SLE]
         If fstat
               GOK = 0 : Call FSTA("SLE") From GLOCK : Return
         Endif
Return

########################################################################
# Mise à jour fichier MFGHEAD
########################################################################
$MAJ_MFG
Local Integer WRECONCIL_OK
# val1 correspond à la nouvelle valeur de WGGFLG
#                           0 On ne veut pas toucher
#                           1 non
#                           2 a peser
#                           3 plan de peser
#                           4 en cours de peser
#                           5 fin pesée peser
#                           6 Réconcilié         :#DT-29/06/2010
#                           7 Engagé             :#DT-29/06/2010
#                           8 En cours de pesée par article  - mm 05.11
# val2 correspond à la nouvelle valeur de WGGSTA
#                           0 On ne veut pas toucher
#                           1 non pese
#                           2 pesee en box
#                           3 fin pesee en box
#                           4 pesee en fabrication
#                           5 en fabrication
#                           6 fin pesee en fabrication
#                           7 en reconciliation
#                           8 fin pesee totale
#                           9 ordre bloquee en pesee
#                          10 ordre bloquee en réconciliation    :#DT-29/06/2010
#                          11 ordre bloquee en engagement        :#DT-29/06/2010
# lnum correspond au numero d OF
#   Call DEBTRANS From GLOCK
#   Trbegin [MFG]

      Readlock [F:MFG]MFG0 = LNUM
         If fstat=1     GOK=-1 : GLOCK="$MFGHEAD"-LNUM : Return
               Elsif fstat GOK=0  : Call RSTA("MFG",LNUM) From GLOCK
            Return
         Endif
         # 01.06 demande 34354
         If VAL1  > 0 [F:MFG]WGGFLG  = VAL1 : Endif
         If VAL2  > 0 [F:MFG]WGGSTA  = VAL2 : Endif
         # sr 10.03 si l'OF passe à "fin de pesée", vérifier si toutes les matières pesées en centrale sont réconciliées.
         # si oui alors statut de l'OF = Réconcilié"
         If [F:MFG]WGGFLG = 5
            Call CTR_RECONCIL([F:MFG]MFGNUM,WRECONCIL_OK)
            If WRECONCIL_OK
                [F:MFG]WGGFLG  = 6
                [F:MFG]WGGSTA  = 8
            Endif
         Endif
         Rewrite [F:MFG]
         If fstat
               GOK = 0 : Call FSTA("MFG") From GLOCK : Return
         Endif

#   Commit

Return


#######################################################################
# lorsque l'OF passe à "fin de pesée", si des matières pesées en centrale existent et si elles sont toutes réconciliées
# l'OF passera à "réconcilié" et "fin de pesée totale"
Subprog CTR_RECONCIL(LMFGNUM,LRECONCIL_OK)
Value    Char    LMFGNUM
Variable Integer LRECONCIL_OK
Local    Integer WNBR

LRECONCIL_OK = 1
Raz WNBR
If clalev ([F:MFM1]) <= 0 : Local File MFGMAT [MFM1] : Endif
For [MFM1]MFM0 Where MFGNUM = LMFGNUM     &
&                    MATSTA <> 4          &
&                    CPNTYP <> 5          &
&                    find([F:MFM1]PKC,2,4,6)
    WNBR +=1
    If [F:MFM1]WGGSTA <> 5 :  LRECONCIL_OK = 0 : Break : Endif
Next

If WNBR = 0 : LRECONCIL_OK = 0  : Endif
End

########################################################################
# Mise à jour fichier MFGMAT
########################################################################
$MAJ_MFM
# val1 correspond à la nouvelle valeur de WGGSTA
#                           0 On ne veut pas toucher
#                           1 non pesee
#                           2 en cours de peser
#                           3 article pesee
#                           4 en reconciliation
#                           5 reconcilie
# val2 correspond à la valeur de WGGBOX = en cours de pesée (box)
#                           0 On ne veut pas toucher
#                           1 non
#                           2 oui
# lnum correspond au numero d OF

      Readlock [MFM]MFM0=LNUM;LLIN;LSEQ;LITM
           If fstat=1     GOK=-1 : GLOCK="$MFGMAT"-LNUM : Return
               Elsif fstat GOK=0  : Call RSTA("MFM",LNUM) From GLOCK
            Return
         Endif
         If VAL1  > 0 [F:MFM]WGGSTA  = VAL1 : Endif
         If VAL2  > 0 [F:MFM]WGGBOX  = VAL2 : Endif
         Rewrite [F:MFM]
         If fstat
               GOK = 0 : Call FSTA("MFM") From GLOCK : Return
         Endif
Return


########################################################################
# Préparation du filtre sur le magasin avancé
########################################################################
$SBX_FILTER
Raz CRITERE

If DEPOT<> ""
   CRITERE = "WRH='"+DEPOT+"'"
   Gosub LOAD_CRITERE1
Endif


If LOC <> ""
# y-a-t'il un caractère "*" dans l'emplacement du box ?
  If !instr(1,LOC,"*")
    CRITERE = "LOC='"+LOC+"'"
  Else
    CRITERE= "pat([F:STO]LOC,'"+LOC+"')<>0"
  Endif
  Gosub LOAD_CRITERE1
Endif

Return

########################################################################
# Préparation du filtre1 la table MFGHEAD
########################################################################
$MFG_FILTER1
Raz CRITERE
Raz FORMULE1

# critères dynamiques, dépendant des paramètres
If GSCA1MFGFCY <> ""
   CRITERE = "[F:MFG]MFGFCY=GSCA1MFGFCY"           # filtre site
   Gosub LOAD_CRITERE1
   CRITERE = "[F:MFI]MFGFCY=GSCA1MFGFCY"           # filtre site
   Gosub LOAD_CRITERE2
Endif
If GSCA1DATESTR <> [0/0/0]
   CRITERE = "[F:MFG]STRDAT >= GSCA1DATESTR"        # date début OF
   Gosub LOAD_CRITERE1
Endif
If GSCA1DATEEND <> [0/0/0]
   CRITERE = "[F:MFG]STRDAT <= GSCA1DATEEND"
   Gosub LOAD_CRITERE1
Endif

If GSCA1NUMSTR <> ""
   CRITERE = "[F:MFG]MFGNUM >= GSCA1NUMSTR"        # Numéro OF debut
   Gosub LOAD_CRITERE1
   CRITERE = "[F:MFI]MFGNUM >= GSCA1NUMSTR"        # Numéro OF debut
   Gosub LOAD_CRITERE2
Endif
If GSCA1NUMEND <> ""
   CRITERE = "[F:MFG]MFGNUM <= GSCA1NUMEND"
   Gosub LOAD_CRITERE1
   CRITERE = "[F:MFI]MFGNUM <= GSCA1NUMEND"
   Gosub LOAD_CRITERE2
Endif

CRITERE = "[F:MFG]WGGFLG=3"                       # filtre plan de pesée
Gosub LOAD_CRITERE1
CRITERE = "[F:MFG]WGGSTA<8"                       # filtre situation
Gosub LOAD_CRITERE2
# Issue 80845 - 2012-03-19 by SR
CRITERE = "[F:MFG]MFGSTA = 1"                     # statut ferme
Gosub LOAD_CRITERE2
# Issue 80839 - 2012-03-19 by SR
Gosub LOAD_FORMULE1
Return

########################################################################
$LOAD_CRITERE1
 If CRITERE1 <> ""
      CRITERE1 += "&"
  Endif
  CRITERE1 += CRITERE

Return

########################################################################
$LOAD_CRITERE2
 If CRITERE2 <> ""
      CRITERE2 += "&"
  Endif
  CRITERE2 += CRITERE

Return

########################################################################
# Issue 80839 - 2012-03-19 by SR
$LOAD_FORMULE1
Raz FORMULE1
# analyse présence formule de sélection
If GSCA1FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=12;GSCA1FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif
Return

########################################################################
# controle acces
########################################################################
$CTL_ACCES
WACCES = 0

# si AUS/ALLACS = 2 tous les acces sont autorisés
 If [F:AUS]ALLACS = 2                       Goto FIN_CTLACCES
 Endif

# lecture article site pour connaitre la fiche ISM
    Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
    If fstat Raz[F:ITF] : Endif
 If [F:ITF]ISM    = ""                      Goto FIN_CTLACCES
 Endif
 If [F:ITF]WGRACS = ""                      Goto FIN_CTLACCES
 Endif

# lecture ism pour code controle peseur
    Read [HSH]HSH0=[F:ITF]ISM
    If fstat Raz[F:HSH] : Endif
 If [F:HSH]PLACTL = 0                       Goto FIN_CTLACCES
 Endif

# lecture acces
    Look [ACC]CODACC= GUSER;[F:ITF]WGRACS
    If fstat WACCES = 9 : Endif

$FIN_CTLACCES
Return


############################################################################
# création d'un mouvmement de régul de type consommation matière
# avec désignation "Fin de contenant" associé à un OF bidon (un OF par mois)
# ce mouvement est créé sur la dernière pesée d'une MP si emballage interne et selon CLECTNAUT
############################################################################
Subprog MAJ_FINCONTENANT(WMFGNUM,WITMREF,WLOT,WSLO,WSEQSTA,WQTY,WOPT,WLIN,WSEQNOM)
Value    Char    WMFGNUM
Value    Char    WITMREF
Value    Char    WLOT
Value    Char    WSLO
Value    Decimal WSEQSTA
Value    Decimal WQTY
Value    Decimal WOPT
Value    Decimal WLIN
Value    Decimal WSEQNOM
Local    Date    WDATE, DDEBMONTH
Local    Char    WFCY
Local    Integer STAT
Local    Char    WVCRNUM
Local    Decimal WQTYSTU, WPOT, WDEFPOT,WQTYSTUACT_STA,WQTYSTU_STA
Local    Integer WOPE, WWSEQ, WMOD, WPKC, OK
Local    Char    WLOC,WSTA, WSTU, WISM, WCTN #  X3-30163 container field in weighing
Local    Integer WRET, LRET
Local    Integer MEMSTA

If clalev([M:ORDK]) <= 0 : Local Mask ORDK       [ORDK] : Endif

If clalev([F:TCA])  <= 0 : Local File TABCOUAFF  [TCA]  : Endif
If clalev([F:WGG])  <= 0 : Local File WEIGHING   [WGG]  : Endif
If clalev([F:BTS])  <= 0 : Local File BENCHTRS   [BTS]  : Endif
If clalev([F:STO])  <= 0 : Local File STOCK      [STO]  : Endif
If clalev([F:STJ])  <= 0 : Local File STOJOU     [STJ]  : Endif
If clalev([F:STL])  <= 0 : Local File STOLOT     [STL]  : Endif
If clalev([F:SLF])  <= 0 : Local File STOLOTFCY  [SLF]  : Endif
If clalev([F:ITM])  <= 0 : Local File ITMMASTER  [ITM]  : Endif
If clalev([F:ITF])  <= 0 : Local File ITMFACILIT [ITF]  : Endif
If clalev([F:ORD])  <= 0 : Local File ORDERS     [ORD]  : Endif
If clalev([F:STA])  <= 0 : Local File STOALL     [STA]  : Endif

If !clalev([STW]) : Local Mask STOWORK [STW] : Endif
If !clalev([M:SVW]) : Local Mask STOVALWORK [SVW] : Endif

# lecture BTS suivant transaction du parametre GWEITRSNUM
Read [F:BTS]BTS0 = 61;GWEITRSNUM
If fstat : Call ERREUR(mess(23,2324,1)) From GESECRAN : OK=0 : End : Endif

# lecture article
Read [F:ITM]ITM0 = WITMREF
If fstat : Raz [F:ITM] : Endif
WDEFPOT = [F:ITM]DEFPOT
WSTU    = [F:ITM]STU

# lecture entête d'OF pour récupération du site
Read [F:MFG]MFG0 =  WMFGNUM
If fstat : Raz [F:MFG] : Endif
WFCY  = [F:MFG]MFGFCY

# lecture matiere OF pour récupération la phase
Read [F:MFM]MFM0 =  WMFGNUM;WLIN;WSEQNOM;WITMREF
If fstat : Raz [F:MFM] : Endif
WOPE = [F:MFM]BOMOPE
MEMSTA = [F:MFM]ALLSTA # mémo statut
WPKC   = [F:MFM]PKC
WCTN   = [F:MFM]CTN # CATUA X3-30163 container field in weighing

# lecture article-site
Read [F:ITF]ITF0 = WITMREF;WFCY
If fstat : Raz [F:ITF] : Endif
WISM = [F:ITF]ISM

# lecture de la ligne de lot
Read [F:STL]STL0 = WITMREF;WLOT;WSLO
If fstat : Raz [F:STL] : Endif
Read [F:SLF]SLF0 = WITMREF;WLOT;WSLO;WFCY
If fstat : Raz [F:SLF] : Endif
WPOT = [F:STL]POT

# lecture stock
# 54065 mm 03.09
Read [F:STO]STO0 = WFCY;GSTOCOU
If fstat : Raz [F:STO] : End : Endif
WSTA = [F:STO]STA
WLOC = [F:STO]LOC

#Récupération du compteur des OF
Call LECTCA(8,OK) From SUBTCA
If OK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : End : Endif
GCODNUM    = [F:TCA]CODNUM(0)   # compteur OF
GMANCOU    = [F:TCA]MANCOU(0)

# 41440 mm 03.08
Call GETCPY (WFCY,"",0,"") From TRTX3CPT
#contrôle que la période est ouverte
#si pas ok non plus alors message d'erreur et on ne peut créer le mouvement
GMESSAGE = ""
WDATE = date$
Call STKCTRIPT(WDATE, WFCY, "1") From STKLIB
If GMESSAGE <> "" : End : Endif

# Calcul unite de poid en unite de stoc

Call CAL_QUANTITE (WITMREF,WQTYSTU,WQTY)
If WQTYSTU = 0 : End : Endif

#Calcul de la première date du mois
DDEBMONTH = date$ - (day(date$) - 1)

Call DEBTRANS From GLOCK
Trbegin [STO]

# 101268 mm 08.2014 - Improved performance
#y a t il déjà un mouvement de fin de contenant pour le mois en cours ?
Filter [F:STJ] Where STOFCY = WFCY &
&              find(TRSTYP,6,13)<>0 &
&              find(MVTDES,mess(36,2324,1),mess(40,2324,1))<>0 &
&              IPTDAT > DDEBMONTH
    Read [F:STJ]First With Nohint
Filter [F:STJ]      # mm 02.2013
If !fstat
    WVCRNUM = [F:STJ]VCRNUM
Else
    Call NUMERO(GCODNUM,WFCY,WDATE,"",WVCRNUM,STAT) From SUBANM
    If STAT :  Call ERREUR(mess(60,199,1)-GCODNUM-num$([L]STAT)) From GESECRAN : GOK = 0 :Gosub AB_TRT : End : Endif
Endif

# Mise jour fichier WEIGHING

Filter [WGG] Where MFGNUM    = WMFGNUM &
&                  BOMOPE    = WOPE &
&                  ITMREF    = WITMREF &
&                  MFGLIN    = WLIN &
&                  BOMSEQ    = WSEQNOM &
&                  CBTDAT    = date$
&             Order By Key WGG0
  Read [WGG] First
Filter [WGG]    # mm 02.2013
    If fstat = 0  WWSEQ =[F:WGG]MVTSEQ-1
       Else       WWSEQ = 9999
    Endif
  Raz [F:WGG]

  [F:WGG]CBTDAT    = date$
  [F:WGG]MVTSEQ    = WWSEQ
  [F:WGG]EXCNUM    = 36
  [F:WGG]STI       = GSCA1STI
  [F:WGG]BOX       = GSCA1BOX
  [F:WGG]FCY       = WFCY
  [F:WGG]LBEPRNCOD = 1
  [F:WGG]RCLCOD    = 1
  [F:WGG]RCLDAT    = [0/0/0]
  [F:WGG]RCLUSR    = ""         # Issue number 82926- 2012-06-14 by SR
  Raz [F:WGG]RCLTIM
  [F:WGG]ENGCOD    = 1          # mm 05.11
  [F:WGG]ENGDAT    = [0/0/0]    # mm 05.11
  [F:WGG]ENGUSR    = ""         # Issue number 82926- 2012-06-14 by SR
  Raz [F:WGG]ENGTIM
  [F:WGG]EXPNUM    = 0
  [F:WGG]CCLWGGOPT = 0
  [F:WGG]CREDAT    = date$
  [F:WGG]CRETIM    = mid$(time$,1,2)+mid$(time$,4,2)
  [F:WGG]CREUSR    = GUSER
  [F:WGG]UPDUSR    = ""
  [F:WGG]CCLUSR    = ""
  [F:WGG]UPDDAT    = [0/0/0]
  [F:WGG]CCLDAT    = [0/0/0]
  [F:WGG]WEIFLG    = 4

  [F:WGG]MFGNUM    = WMFGNUM
  [F:WGG]BOMOPE    = WOPE
  [F:WGG]ITMREF    = WITMREF
  [F:WGG]MFGLIN    = WLIN
  [F:WGG]BOMSEQ    = WSEQNOM
  [F:WGG]LOT       = WLOT
  [F:WGG]SLO       = WSLO
  [F:WGG]LOC       = WLOC
  [F:WGG]STOCOU    = GSTOCOU
  [F:WGG]STA       = WSTA
  [F:WGG]DEFPOT    = WDEFPOT
  [F:WGG]POT       = WPOT
  [F:WGG]STU       = WSTU
  [F:WGG]WEU       = [F:ITM]WEU
  [F:WGG]WEIWEI    = WQTY * -1
  [F:WGG]WEI       = WQTY * -1
  [F:WGG]ISM       = WISM
  [F:WGG]WGGOPT    = WOPT
  [F:WGG]PKC       = WPKC
  [F:WGG]CTN       = WCTN # CATUA X3-30163 container field in weighing
  [F:WGG]MFGTRKNUM = WVCRNUM

  [F:WGG]TRSNUM    = GWEITRSNUM
  [F:WGG]WEICREUSR = GWEIUSER         #CATUA X3-67237.sn

# lecture Ordre fabrication-articles
  Read [MFI]MFI0=WMFGNUM;WLIN
  If fstat Raz[F:MFI] : Endif

  [F:WGG]ITMREFMNU = [F:MFI]ITMREF
  [F:WGG]UOMEXTQTY = [F:MFI]UOMEXTQTY
  [F:WGG]UOM       = [F:MFI]UOM

  # mm 01.08 - point d'entrée permettant de renseigner des zones spécifiques dans [WGG]
  GPOINT = "WGGMAJ" : Gosub  ENTREE From EXEFNC
  If GOK = 0 :  Gosub AB_TRT : End: Endif

# ecriture historique
Write [WGG]
If fstat GOK = 0 : Call FSTA("WGG") From GLOCK : Gosub AB_TRT : End: Endif

Call ADDSTOWORKLIN("C", "S", WFCY, GSTOCOU,
&                  WQTYSTU, WQTYSTU,"","", WRET) From STKINT  # hcb 110327
If WRET <> 0 : Gosub AB_TRT : End : Endif

# Issue number 80916 - 2012-03-20 by SR : Lignes replacées après l'appel à ADDSTOWORLIN sinon perdues
[M:STW]STOFCY     = [F:STO]STOFCY       # Site
# 02.07 demande 39524 changer le type de mouvement: sortie diverse au lieu de conso matière à cause de la valo
[M:STW]TRSTYP     = 2                   # Type mouvement (M.704) Sortie diverse
[M:STW]VCRTYP     = 12                  # Type pièce (M.701)
[M:STW]VCRNUM     = WVCRNUM             # Numéro pièce
[M:STW]VCRLIN     = 0                   # Numero ligne pièce
[M:STW]ITMREF     = WITMREF             # Article
[M:STW]MVTDES     = mess(40,2324,1)     # Désignation mouvement
[M:STW]PJT        = ""                  # Affaire
[M:STW]TRSFAM     = [F:BTS]TRSFAM       # Famille mouvement
[M:STW]IPTDAT     = date$               # Date imputation
[M:STW]TRSCOD     = [F:BTS]TRSCODS      # Code mouvement
[M:STW]TRAFLG     = 0

Gosub ALIVALWORK From STKVALMAJ
If LRET <> 0 : Gosub AB_TRT : End : Endif

# mise à jour du stock
Call MAJ_STOCK From STKMAJ

If WRET <> 0 | GOK < 1 : Rollback
Else                   : Commit
Endif

End


############################################################################
# création d'un mouvement d'inventaire
# spécifique redressement emballage : le mouvement peut être en + ou en  - selon WSENS
# si mouvement en -, il faut supprimer l'allocation restante
# dans tous les cas il faut s'assurer que le stock n'a pas évolué depuis l'extraction vers la centrale
# si wsens = 1 le poids passé est le poids pesé: il faut calculer le redressement
# si wsens = 2 il faut calculer la quantité maxi à redresser en - selon le stock disponible maintenant
############################################################################
Subprog MAJ_CONTENANT(WMFGNUM,WITMREF,WLOT,WSLO,WQTY,WOPT,WLIN,WSEQNOM,WSENS)
Value    Char    WMFGNUM
Value    Char    WITMREF
Value    Char    WLOT
Value    Char    WSLO
Value    Decimal WQTY
Value    Decimal WOPT
Value    Decimal WLIN
Value    Decimal WSEQNOM
Value    Integer WSENS        # 1 = en + selon <> entre poids pesé et quantité dispo
                              # 2 = en - selon quantité restant disponible après le suivi
                              # 3 = redressement en + de 0.001 sur emballage interne dernière pesée
                              # 4 = en - sur dernière pesée en emballage fournisseur poids prevu - poids pesée
                              # 5 = en - avec désallocation préalable (si pesée à 0 d'un emballage intialement alloué)
                              # pour 2 et 5 : on doit réajuster du maximum possible  : en effet le disponible connu de la
                              # DLL n'est peut-être plus le disponible réel (si alloc pour un autre OF entre temps)
                              # 2 = selon le paramètre REDMODFLG, on redresse tout ce qui reste ou tout ce qui reste alloué
Local    Char    WFCY
Local    Char    WVCRNUM
Local    Decimal WQTYSTU, WPOT, WDEFPOT, WQTYSTUACT,WSTOCOU,WQTY_PESE
Local    Integer WOPE, WWSEQ, WMOD, WPKC
Local    Char    WLOC,WSTA, WSTU, WISM, WCTN # CATUA X3-30163 container field in weighing
Local    Integer WRET
Local    Date    WDATE, DDEBMONTH
Local    Integer OK, STAT
Local    Decimal WQTYSTUACT_STA,WQTYSTU_STA
Local    Integer MEMSTA
Local    Integer LRET

If clalev([F:TCA])  <= 0 : Local File TABCOUAFF  [TCA]  : Endif
If clalev([F:WGG])  <= 0 : Local File WEIGHING   [WGG]  : Endif
If clalev([F:STO])  <= 0 : Local File STOCK      [STO]  : Endif
If clalev([F:STL])  <= 0 : Local File STOLOT     [STL]  : Endif
If clalev([F:SLF])  <= 0 : Local File STOLOTFCY  [SLF]  : Endif
If clalev([F:ITM])  <= 0 : Local File ITMMASTER  [ITM]  : Endif
If clalev([F:ITF])  <= 0 : Local File ITMFACILIT [ITF]  : Endif
If clalev([F:BTS])  <= 0 : Local File BENCHTRS   [BTS]  : Endif
If clalev([F:STA])  <= 0 : Local File STOALL     [STA]  : Endif

If !clalev([STW]) : Local Mask STOWORK [STW] : Endif
# Issue 83009 - 2012-06-19 by SR
#If clalev([M:ST2])  <= 0 : Local Mask STOWORK2   [ST2]  : Endif     # 41440 mm 03.08
If clalev([M:ST2])  <= 0 : Local Mask STOWORK    [ST2]  : Endif     # 41440 mm 03.08
If !clalev([M:SVW]) : Local Mask STOVALWORK [SVW] : Endif

# lecture BTS suivant transaction du parametre GWEITRSNUM
Read [F:BTS]BTS0 = 61;GWEITRSNUM
If fstat : Call ERREUR(mess(23,2324,1)) From GESECRAN : OK=0 : End : Endif

# lecture article
Read [F:ITM]ITM0 = WITMREF
If fstat : Raz [F:ITM] : Endif
WDEFPOT = [F:ITM]DEFPOT
WSTU    = [F:ITM]STU

# lecture entête d'OF pour récupération du site
Read [F:MFG]MFG0 =  WMFGNUM
If fstat : Raz [F:MFG] : Endif
WFCY  = [F:MFG]MFGFCY

# lecture matiere OF pour récupération la phase
Read [F:MFM]MFM0 =  WMFGNUM;WLIN;WSEQNOM;WITMREF
If fstat : Raz [F:MFM] : Endif
WOPE = [F:MFM]BOMOPE
WPKC   = [F:MFM]PKC
WCTN   = [F:MFM]CTN # CATUA X3-30163 container field in weighing

# lecture article-site
Read [F:ITF]ITF0 = WITMREF;WFCY
If fstat : Raz [F:ITF] : Endif
WISM = [F:ITF]ISM
# lecture de la ligne de lot
Read [F:STL]STL0 = WITMREF;WLOT;WSLO
If fstat : Raz [F:STL] : End : Endif
Read [F:SLF]SLF0 = WITMREF;WLOT;WSLO;WFCY
If fstat : Raz [F:SLF] : End : Endif
WPOT = [F:STL]POT

# 41440 mm 03.08
# Comme l'enregistrement sur [F:STO] a été supprimé, utilisation des info sauvegardées dans [M:ST2]
If WSENS=3
    WSTOCOU = [M:ST2]STOCOU
    WLOC    = [M:ST2]LOC
    WSTA    = [M:ST2]STA
Else
    # 54065 mm 03.09 + 55296 mm 05.09
    # lecture de la ligne de stock à modifier
    Read [F:STO]STO0=WFCY;GSTOCOU
    If fstat : Raz [F:STO] : Endif
    WSTOCOU = [F:STO]STOCOU
    WLOC    = [F:STO]LOC
    WSTA    = [F:STO]STA
Endif

If WSENS = 1
          # Calcul unite de poid en unite de stoc
          Call CAL_QUANTITE (WITMREF,WQTY_PESE,WQTY)
          WQTYSTU = WQTY_PESE - (([F:STO]QTYSTU - [F:STO]CUMALLQTY) + [F:STA]QTYSTU)
         # Calcul unite de stock en unite de poids  pour MAJ WEIGHING
          Call CAL_POIDS(WITMREF,WQTYSTU,WQTY)
Endif

Case WSENS
     When 4 :
        # Calcul unite de poid en unite de stoc
          Call CAL_QUANTITE (WITMREF,WQTYSTU,WQTY)
          # sr 12.03 si le delta convertit en US = 0 on ne fait rien
          If WQTYSTU = 0 : End : Endif
     When 3   :
        # dans le cas d'un mouvement sur emballage interne sur dernière pesée d'une MP
        # la quantité passée ne nous importe pas
        # on calcule ici la quantité à ajouter selon la décimalisation de l'unité de poids
        # 1 0,1 0,01 0,001 selon la décimalisation de l'US (on s'arrête à 0,001)
        # lecture de l'unité
        If clalev([F:TUN]) = 0 : Local File TABUNIT [TUN] : Endif
        If [F:ITM]STU <> ""
         Read [TUN]TUN0 = [F:ITM]STU
         If fstat : Raz [F:TUN] : Endif
        Endif
        Case [F:TUN]UOMDEC
              When 0       : WQTYSTU = 1
              When 1       : WQTYSTU = 0.1
              When 1       : WQTYSTU = 0.01
              When Default : WQTYSTU = 0.001
         Endcase
         Call CAL_POIDS(WITMREF,WQTYSTU,WQTY)
         # sr 12.03 si le delta convertit en US = 0 on ne fait rien
         If WQTYSTU = 0 : End : Endif
Endcase

#Récupération du compteur des OF
Call LECTCA(8,OK) From SUBTCA
If OK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : End : Endif
GCODNUM    = [F:TCA]CODNUM(0)   # compteur OF
GMANCOU    = [F:TCA]MANCOU(0)

# 41440 mm 03.08
Call GETCPY (WFCY,"",0,"") From TRTX3CPT
#contrôle que la période est ouverte
#si pas ok non plus alors message d'erreur et on ne peut créer le mouvement
GMESSAGE = ""
WDATE = date$
Call STKCTRIPT(WDATE, WFCY, "1") From STKLIB
If GMESSAGE <> "" : End : Endif

#Calcul de la première date du mois
DDEBMONTH = date$ - (day(date$) - 1)

#Appel du traitement de création d'un mouvement d'inventaire et de mise à jour WGG
Call DEBTRANS From GLOCK
Trbegin [STO],[MFM],[ORD],[WGG]

# 101268 mm 08.2014 - Improved performance
#y a t il déjà un mouvement de fin de contenant pour le mois en cours ?
Filter [F:STJ] Where STOFCY = WFCY &
&              find(TRSTYP,6,13)<>0 &
&              find(MVTDES,mess(36,2324,1),mess(40,2324,1))<>0 &
&              IPTDAT > DDEBMONTH
    Read [F:STJ]First With Nohint
Filter [F:STJ]    # mm 02.2013
If !fstat
    WVCRNUM = [F:STJ]VCRNUM
Else
    Call NUMERO(GCODNUM,WFCY,WDATE,"",WVCRNUM,STAT) From SUBANM
    If STAT : Call ERREUR(mess(60,199,1)-GCODNUM-num$([L]STAT)) From GESECRAN : GOK = 0 :Gosub AB_TRT : End : Endif
Endif

# si inventaire en - et matière pas soldée
#Suppression de l'allocation restante, diminution de la quantité allouée de la matière
#mise à jour de l'encours associé
If  find(WSENS,2,5)
    Read [F:STA]STA0 = WFCY;WITMREF;WSTOCOU;GSEQSTA        # 55296 mm 06.09
    If fstat : Raz [F:STA]
    Else
        WQTYSTUACT_STA = [F:STA]QTYSTUACT
        WQTYSTU_STA    = [F:STA]QTYSTU
        Raz    WRET
        Call SUPALL([F:STA]STOFCY,[F:STA]ITMREF,WSTOCOU,GSEQSTA,WRET)
&               From STKALL
        If WRET <> 0 : GOK = 0 : Gosub AB_TRT1 : End : Endif

        Readlock [F:MFM]MFM0 Curr
        If fstat=1     GOK=-1 : GLOCK="$MFGMAT"-WITMREF :Gosub AB_TRT1 : End
        Elsif fstat GOK=0  : Call RSTA("MFM",WITMREF) From GLOCK
               Gosub AB_TRT1
               End
        Endif
        If [F:STA]ALLTYP = 2
          # 58697 mm  11.09
          If [F:ITM]STOMGTCOD = 3
            [F:MFM]ALLQTY -= WQTYSTUACT_STA
          Else
            [F:MFM]ALLQTY -= WQTYSTU_STA
          Endif
        Else
            [F:MFM]SHTQTY -= WQTYSTUACT_STA
        Endif
        If [F:MFM]ALLQTY < 0 : [F:MFM]ALLQTY = 0 : Endif
        If [F:MFM]SHTQTY < 0 : [F:MFM]SHTQTY = 0 : Endif
        Rewrite [F:MFM]
        If fstat
           GOK = 0 : Call FSTA("MFM") From GLOCK : Gosub AB_TRT1 : End
        Endif

        Readlock [F:ORD]ORD0 = 6;[F:MFM]WIPNUM;[F:MFM]ITMREF
        If fstat=1     GOK=-1 : GLOCK="$ORDERS"-WITMREF :Gosub AB_TRT1 : End
        Elsif fstat GOK=0  : Call RSTA("ORD",WITMREF) From GLOCK
               Gosub AB_TRT1
               End
        Endif
        [F:ORD]ALLQTY = [F:MFM]ALLQTY
        [F:ORD]SHTQTY = [F:MFM]SHTQTY
        Rewrite [F:ORD]
        If fstat
           GOK = 0 : Call FSTA("ORD") From GLOCK : Gosub AB_TRT1 : End
        Endif
     Endif
     Readlock [F:STO]STO0 =  WFCY;WSTOCOU
     If fstat=1     GOK=-1 : GLOCK="$STOCK"-WITMREF :Gosub AB_TRT1 : End
     Elsif fstat GOK=0  : Call RSTA("STO",WITMREF) From GLOCK
           Gosub AB_TRT1
           End
     Endif

     # la quantité à redresser en - est la quantité disponible à ce moment là
     # quantité dipsonible = qté totale - somme des allocs
     # sr 07.05 Pour LYOCENTRE: A DEVELOPPER COMME SUIT :
     # Si redressement à l'allocation, la quantite a redresser est la difference entre l'alloue et le consomme
     # c'est -a-dire WQTYSTU_STA qui est la quantite qu'on a desalloue precedemment
     # sr 07.05
     If dim([F:ITF]REDMODFLG) > 0 & [F:ITF]REDMODFLG = 2
        WQTYSTU = WQTYSTU_STA
        # CALCUL unite de stock en unite de poids  pour MAJ WEIGHING
        Call CAL_POIDS(WITMREF,WQTYSTU,WQTY)
     Else
        WQTYSTU = [F:STO]QTYSTU - [F:STO]CUMALLQTY
        # Calcul unite de stock en unite de poids  pour MAJ WEIGHING
        Call CAL_POIDS(WITMREF,WQTYSTU,WQTY)
     Endif
#     WQTYSTU = [F:STO]QTYSTU - [F:STO]CUMALLQTY
#     Call CAL_POIDS(WITMREF,WQTYSTU,WQTY)
Endif

# mm 11.10 - Pas de mouvement d'inventaire si REDNEG = 1 (non)
If GREDNEG=1 & find (WSENS,2,4) : Goto FIN_TRT1 : Endif

# Mise jour fichier WEIGHING

Filter [WGG] Where MFGNUM    = WMFGNUM &
&                  BOMOPE    = WOPE &
&                  ITMREF    = WITMREF &
&                  MFGLIN    = WLIN &
&                  BOMSEQ    = WSEQNOM &
&                  CBTDAT    = date$
&             Order By Key WGG0
  Read [WGG] First
Filter [WGG]      # mm 02.2013
    If fstat = 0  WWSEQ =[F:WGG]MVTSEQ-1
       Else       WWSEQ = 9999
    Endif
  Raz [F:WGG]

  [F:WGG]CBTDAT    = date$
  [F:WGG]MVTSEQ    = WWSEQ
  [F:WGG]EXCNUM    = 39
  [F:WGG]STI       = GSCA1STI
  [F:WGG]BOX       = GSCA1BOX
  [F:WGG]FCY       = WFCY
  [F:WGG]LBEPRNCOD = 1
  [F:WGG]RCLCOD    = 1
  [F:WGG]RCLDAT    = [0/0/0]
  [F:WGG]RCLUSR    = ""         # Issue number 82926- 2012-06-14 by SR
  Raz [F:WGG]RCLTIM
  [F:WGG]ENGCOD    = 1          # mm 05.11
  [F:WGG]ENGDAT    = [0/0/0]    # mm 05.11
  [F:WGG]ENGUSR    = ""         # Issue number 82926- 2012-06-14 by SR
  Raz [F:WGG]ENGTIM
  [F:WGG]EXPNUM    = 0
  [F:WGG]CCLWGGOPT = 0
  [F:WGG]CREDAT    = date$
  [F:WGG]CRETIM    = mid$(time$,1,2)+mid$(time$,4,2)
  [F:WGG]CREUSR    = GUSER
  [F:WGG]UPDUSR    = ""
  [F:WGG]CCLUSR    = ""
  [F:WGG]UPDDAT    = [0/0/0]
  [F:WGG]CCLDAT    = [0/0/0]
  [F:WGG]WEIFLG    = 5

  [F:WGG]MFGNUM    = WMFGNUM
  [F:WGG]BOMOPE    = WOPE
  [F:WGG]ITMREF    = WITMREF
  [F:WGG]MFGLIN    = WLIN
  [F:WGG]BOMSEQ    = WSEQNOM
  [F:WGG]LOT       = WLOT
  [F:WGG]SLO       = WSLO
  [F:WGG]LOC       = WLOC
  [F:WGG]STOCOU    = WSTOCOU
  [F:WGG]STA       = WSTA
  [F:WGG]DEFPOT    = WDEFPOT
  [F:WGG]POT       = WPOT
  [F:WGG]STU       = WSTU
  [F:WGG]WEU       = [F:ITM]WEU
  Case WSENS
    When 1,3 :
      [F:WGG]WEIWEI    = WQTY
      [F:WGG]WEI       = WQTY
    When 2,4,5 :
      [F:WGG]WEIWEI    = WQTY * (-1)
      [F:WGG]WEI       = WQTY * (-1)
  Endcase
  [F:WGG]ISM       = WISM
  [F:WGG]WGGOPT    = WOPT
  [F:WGG]PKC       = WPKC
  [F:WGG]CTN       = WCTN # CATUA X3-30163 container field in weighing
  [F:WGG]MFGTRKNUM = WVCRNUM

  [F:WGG]TRSNUM    = GWEITRSNUM
  [F:WGG]WEICREUSR = GWEIUSER         #CATUA X3-67237.sn

# lecture Ordre fabrication-articles
  Read [MFI]MFI0=WMFGNUM;WLIN
  If fstat Raz[F:MFI] : Endif

  [F:WGG]ITMREFMNU = [F:MFI]ITMREF
  [F:WGG]UOMEXTQTY = [F:MFI]UOMEXTQTY
  [F:WGG]UOM       = [F:MFI]UOM

  # mm 01.08 - point d'entrée permettant de renseigner des zones spécifiques dans [WGG]
  GPOINT = "WGGMAJ" : Gosub  ENTREE From EXEFNC
  If GOK = 0 : Gosub AB_TRT : End: Endif

# ecriture historique
Write [WGG]
If fstat GOK = 0 : Call FSTA("WGG") From GLOCK : Gosub AB_TRT : End: Endif

If [F:MFM]STOMGTCOD = 3
   If WPOT = 0 : WPOT = 100 : Endif
   WQTYSTUACT  = (WQTYSTU * WPOT) / 100
Else
   WQTYSTUACT  = WQTYSTU
Endif

# chargement des lignes à sortir
Raz [STW]
Raz [M:STW]NBLIG

# WQTYSTU en unité physique
Case WSENS
    When 1     :  Call ADDSTOWORKLIN("C", "E", [F:STO]STOFCY, [F:STO]STOCOU,
&                  WQTYSTU, WQTYSTU,"","", WRET) From STKINT   # hcb 110327
                   If WRET <> 0 : Gosub AB_TRT : End : Endif


    When 2,4,5 :  Call ADDSTOWORKLIN("C", "S", [F:STO]STOFCY, [F:STO]STOCOU,
&                  WQTYSTU, WQTYSTU,"","", WRET) From STKINT   # hcb 110327
                   If WRET <> 0 : Gosub AB_TRT : End : Endif

   When 3      :   # 41440 mm 03.08
                  # restauration de l'enregistrement (supprimé auparavant puisque qté =0)
                  Raz [F:STO]        # 55296 mm 05.09
                  nolign = 1         # 56365 mm 07.09
                  [F:STO] = [M:ST2]
                  [F:STO]QTYPCU     = 0
                  [F:STO]QTYSTU     = 0
                  [F:STO]QTYSTUACT  = 0
                  Write [STO]
                  If fstat
                      GOK=0  : Call FSTA("STO") From GLOCK
                      Gosub AB_TRT : End
                  Endif
                  Call ADDSTOWORKLIN("C", "E", WFCY, WSTOCOU, WQTYSTU, WQTYSTU,"","",
&                  WRET) From STKINT       # hcb 110327
                   If WRET <> 0 : Gosub AB_TRT : End : Endif

Endcase
Raz [M:ST2]       # 50603 mm 12.08

# Issue number 80916 - 2012-03-20 by SR : Lignes replacées après l'appel à ADDSTOWORLIN sinon perdues
[M:STW]STOFCY     = [F:STO]STOFCY       # Site
[M:STW]TRSTYP     = 13                  # Type mouvement (M.704) on met inventaire
[M:STW]VCRTYP     = 10                  # Type pièce (M.701) on met OF
[M:STW]VCRNUM     = WVCRNUM             # Numéro pièce
[M:STW]VCRLIN     = 0                   # Numero ligne pièce
[M:STW]ITMREF     = WITMREF             # Article
[M:STW]MVTDES     = mess(40,2324,1)     # Désignation mouvement
[M:STW]PJT        = ""                  # Affaire
[M:STW]TRSFAM     = [F:BTS]TRSFAM       # Famille mouvement
[M:STW]IPTDAT     = date$               # Date imputation
[M:STW]TRSCOD     = [F:BTS]TRSCODS      # Code mouvement
[M:STW]TRAFLG     = 0

If clalev([M:SVW])
    Raz [M:SVW]
    # Valorisation nulle
    [M:SVW]NBLIG=[M:STW]NBLIG
Endif
Gosub ALIVALWORK From STKVALMAJ

# mise à jour du stock
Call MAJ_STOCK From STKMAJ

$FIN_TRT1
If WRET <> 0 | GOK < 1 : Rollback
Else                   : Commit
Endif

End

#------------------------------------------------------------------------------#
# abandon
$AB_TRT1
Rollback
Return

########################################################################
# calcul du poids à partir de la quantite en unite de stock  #
# Entrée  WART     : Article                                 #
#         WQTYSTU  : Quantite en unité de stock              #
# Sortie  WQTYWEI  : Poids                                   #
########################################################################
Subprog CAL_POIDS(WART,WQTYSTU,WQTYWEI)
Value Char WART
Value Decimal WQTYSTU
Variable Decimal WQTYWEI

WQTYWEI = 0

If WART = "" End Endif
If clalev([F:ITM]) = 0 Local File ITMMASTER [ITM]:Endif
If [F:ITM]ITMREF <> WART
   Read [ITM] ITM0=WART
   If fstat : Raz [F:ITM] : End : Endif
Endif

WQTYWEI = WQTYSTU*[F:ITM]ITMWEI

# lecture de l'unité
If clalev([F:TUN]) = 0 : Local File TABUNIT [TUN] : Endif
If [F:ITM]WEU <> ""
 If [F:TUN]UOM <> [F:ITM]WEU
    Read [TUN]TUN0 = [F:ITM]WEU
 Else
    fstat = 0
 Endif
Endif
# Arrondi de la quantité selon nb de décimales :
If WQTYWEI <> 0 & fstat = 0
 Case [F:TUN]UOMDEC
  When 0 : WQTYWEI = arr(WQTYWEI,1)
  When 1 : WQTYWEI = arr(WQTYWEI,0.1)
  When 2 : WQTYWEI = arr(WQTYWEI,0.01)
  When 3 : WQTYWEI = arr(WQTYWEI,0.001)
  When 4 : WQTYWEI = arr(WQTYWEI,0.0001)
  When 5 : WQTYWEI = arr(WQTYWEI,0.00001)
  When 6 : WQTYWEI = arr(WQTYWEI,0.000001)
 Endcase
Endif

End

# CATUA X3-30176.sn Component Sequence Control
########################################################################
# Checks if component sequence control flag is turned on and           #
#   verifies if selected component is out of sequence                  #
# Input  WMFGNUM : WO number                                           #
#        WMFGLIN : WO line number                                      #
#        WSEQ: BOM sequence number for the selected component          #
#                                                                      #
# Output  WCHKOUTSEQ = 1 (Component is out of sequence)                #
#         WITMNXTSEQ = ITMREF (Next avail component based on sequence) #
########################################################################
Subprog CHECK_OUTOFSEQ(WMFGNUM,WMFGLIN,WSEQ,WCHKOUTSEQ,WITMNXTSEQ)
Value Char WMFGNUM
Value Integer WMFGLIN
Value Integer WSEQ
Variable Shortint WCHKOUTSEQ
Variable Char WITMNXTSEQ

  Raz WCHKOUTSEQ, WITMNXTSEQ

  If WSEQ<>0 & dim([F:ITF]COMSEQCON)>0
    #Check Workorder-Product table to retrieve parent product
    Read [F:MFI]MFI0 = WMFGNUM;WMFGLIN
    If !fstat
      #Check Product-Site table to retrieve sequence control flag
      Read [F:ITF]ITF0 = [F:MFI]ITMREF;GSCA1MFGFCY
      If !fstat
        If [F:ITF]COMSEQCON=2
          #Check next available sequence # and compare against selected component's sequence #
          Filter [F:MFM] Where MFGNUM=WMFGNUM & MFGLIN=WMFGLIN & find(WGGSTA,1,2) & PKC<>1 Order By Key MFM0

          Read [F:MFM] First
          If !fstat
            If WSEQ<>[F:MFM]BOMSEQ
              WCHKOUTSEQ = 1
              WITMNXTSEQ = [F:MFM]ITMREF
            Endif
          Endif
          Filter [F:MFM]
        Endif
      Endif
    Endif
  Endif
End
# CATUA X3-30176.en

########################################################################
# calcul du poids à partir de la quantite en unite de stock  #
# Entrée  WART     : Article                                 #
#         WQTYWEI  : Poids                                   #
# Sortie  WQTYSTU  : Quantite en unité de stock              #
########################################################################
Subprog CAL_QUANTITE(WART,WQTYSTU,WQTYWEI)
Value Char WART
Variable Decimal WQTYSTU
Value Decimal WQTYWEI

Raz WQTYSTU

If WART = "" End Endif
If clalev([F:ITM]) = 0 Local File ITMMASTER [ITM]:Endif
If [F:ITM]ITMREF <> WART
   Read [ITM] ITM0=WART
   If fstat : Raz [F:ITM] : End : Endif
Endif

WQTYSTU = WQTYWEI/[F:ITM]ITMWEI

# lecture de l'unité
If clalev([F:TUN]) = 0 : Local File TABUNIT [TUN] : Endif
If [F:ITM]STU <> ""                         # llc 03.02 (STU et pas WEU)
 If [F:TUN]UOM <> [F:ITM]STU                # llc 03.02 (STU et pas WEU)
    Read [TUN]TUN0 = [F:ITM]STU             # llc 03.02 (STU et pas WEU)
 Endif
Endif
# Arrondi de la quantité selon nb de décimales :
If WQTYSTU <> 0 & fstat = 0
 Case [F:TUN]UOMDEC
  When 0 : WQTYSTU = arr(WQTYSTU,1)
  When 1 : WQTYSTU = arr(WQTYSTU,0.1)
  When 2 : WQTYSTU = arr(WQTYSTU,0.01)
  When 3 : WQTYSTU = arr(WQTYSTU,0.001)
  When 4 : WQTYSTU = arr(WQTYSTU,0.0001)
  When 5 : WQTYSTU = arr(WQTYSTU,0.00001)
  When 6 : WQTYSTU = arr(WQTYSTU,0.000001)
 Endcase
Endif

End

########################################################################
# calcul  quantite consommee                                           #
########################################################################

$CAL_QTYCONSOMME
WQTYCONSOM = 0
If clalev([F:MKM]) = 0 : Local File MFGMATTRK [MKM] : Endif
If clalev([F:STL]) = 0 : Local File STOLOT    [STL] : Endif
If clalev([F:SLF]) = 0 : Local File STOLOTFCY [SLF] : Endif

# seulement sur les composantas à titre
# sr 12.11 :Demande 78848  non , pour tout le monde à cause du calcul du QSP
# If [F:MFM]STOMGTCOD <>  3                  Goto FIN_QTYCONSO
# Endif

For [MKM]MKM1 Where MFGFCY = GSCA1MFGFCY   &
&                   MFGNUM = NUMOF          &
&                   MFGLIN = [F:MFM]MFGLIN  &
&                   ITMREF = [F:MFM]ITMREF  &
&                   BOMSEQ = [F:MFM]BOMSEQ  &
&                   OPENUM = WNUMOPE                     # 63294 mm 03.10
# sr 12.11 :Demande 78848
If [F:MFM]STOMGTCOD = 3
    # Lecture STOLOT rechercher le titre
        Read [STL]STL0(2)=[F:MKM]ITMREF;[F:MKM]LOTPREF
        If fstat : Raz [F:STL] : Endif

       If [F:STL]POT = 0 : [F:STL]POT = 100 : Endif
       [F:MKM]USEQTY  = ([F:MKM]USEQTY / [F:STL]POT) * 100
Endif

# cummul quantitée consommée
# sr 12.11 :Demande 78848  : différencier suivi de réintégration
If [F:MKM]MATTYP <3
    WQTYCONSOM += [F:MKM]USEQTY
Else
    WQTYCONSOM -= [F:MKM]USEQTY
Endif

Next

$FIN_QTYCONSO
Return

########################################################################
# Conversion de la tare du recipent en unite de la fiche ISM      #
# Entrée  WEU     : Unite de poids fiche ISM                      #
#         WCTNWEU : Unite de poids de la tare du recipient        #
#         WCTNTAR : Poids de la tare en CTNWEU                    #
# Sortie  WQTYTAR : Poids de la tare en WEU                       #
########################################################################
Subprog CAL_CONVERT(WEU,WCTNWEU,WCTNTAR,WQTYTAR)
Value Char        WEU
Value Char        WCTNWEU
Value Decimal     WCTNTAR
Variable Decimal  WQTYTAR

Raz WQTYTAR
If WEU = WCTNWEU
   WQTYTAR = WCTNTAR
   End
   Endif
If clalev([F:TCO]) = 0 Local File TABCOEFF [TCO] : Endif
Read [TCO] TCO0=WEU;WCTNWEU
   If fstat : Raz [F:TCO] : End : Endif

WQTYTAR = WCTNTAR/[F:TCO]COEUOM

End

#########################################################################
## Remplacé par CHANGE_CHAR
#########################################################################
# Enlève un caractère d'une chaine
# alimenter la variable WCHAIN et le caractère WSPECHAR

$REMOVE_CHAR
Local Integer J

J = instr(0,WCHAIN, WSPECHAR)
While (J > 0)
    WCHAIN = left$(WCHAIN,J-1)+right$(WCHAIN,J+1)
    J = instr(0, WCHAIN, WSPECHAR) : # GH 05/06/2014 bug 99910 # J = instr(0, WCHAIN, ",")
Wend

Return

########################################################################
## Sous-programme créé le 05/06/2014 suite au bug 99910
## Remplace $REMOVE_CHAR

Subprog CHANGE_CHAR(CHAINE)
Variable Char CHAINE()

CHAINE=ctrans(CHAINE,",;","")
End

#########################################################################
# POUR GERER LES IMPRESSIONS !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
# sr 12.02 deux nouveaux paramètres:
# LETAT_RPT permettant de connaître le nom de l'état Crystal report à lancer
# (pour les étiquettes de pesée)
#  Si = "" on prend celui défini dans le dictionnaire des états
# LTYPETA : permet de connaître le type d'état à lancer pour aller éventulellement
#           récupérer l'imprimante associée dans la fiche BOX
#########################################################################
Subprog IMPRESSION(LETAT,LETAT_RPT,LTYPETA)
Value Char    LETAT
Value Char    LETAT_RPT
Value Integer LTYPETA

Local Char PRNOUT

Call IMPRESSION2(LETAT,LETAT_RPT,LTYPETA,PRNOUT)

End

#########################################################################
Subprog IMPRESSION2(LETAT,LETAT_RPT,LTYPETA,PRNS)
Value Char    LETAT
Value Char    LETAT_RPT
Value Integer LTYPETA
Variable Char PRNS

Local Char WPRN
Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)

If clalev([F:ARP])=0 : Local File AREPORT    [ARP] : Endif

# 90424 mm 12.2013 - personnalisation du nom de l'état d'édition des étiquettes de pesées
If LETAT_RPT <>""
  LETAT =  LETAT_RPT
Endif

Read [ARP]ARP0 = LETAT
If fstat : End : Endif
# imprimante du dictionnaire des états
WPRN = [F:ARP]PRTNAM
# imprimante du box
Gosub IMPRIMANTE
If WPRN = ""
    # si on a rien on va voir dans le fichier destinations par users
    If clalev([F:AIA])  <= 0 : Local File APRTAUS    [AIA]  : Endif
    Filter [F:AIA] Where USR = GUSER & RPTCOD = LETAT
    Read [AIA]AIA0 First
    If fstat Raz [F:AIA] : Endif
    WPRN = [F:AIA]PRT
    Filter [F:AIA]
    # si toujours rien on prend l'imprimante par défaut de l'utilisateur
    If WPRN = ""
        If clalev([F:AUS])  <= 0 : Local File AUTILIS    [AUS]  : Endif
        Read [AUS]CODUSR = GUSER
        If fstat Raz[F:AUS] : Endif
        WPRN = [F:AUS]PRTDEF(0)
    Endif
Endif
# si on n'a toujours pas d'imprimante on ne fait rien
If WPRN <> ""
    Raz GBIDI1
    Call ETAT(LETAT,WPRN,"",0,"",TBPAR,TBVAL) From AIMP3
    PRNS = WPRN
Endif
End


#########################################################################
$IMPRIMANTE

Read [F:SBX]SBX0 = GSCA1BOX;GSCA1MFGFCY
If fstat : Raz [F:SBX] : Endif

####################################
# selon le type d'état :           #
# 1 = allocs                       #
# 2 = Etiquettes de pesée          #
# 3 = Fin de phase                 #
# 4 = Fin d'OF                     #
# 5 = calibrage                    #
####################################

Case LTYPETA
     When 1 : If [F:SBX]PRTALL <> ""
                 WPRN  = [F:SBX]PRTALL
              Endif
     When 2 : If [F:SBX]PRTETI <> ""
                 WPRN  = [F:SBX]PRTETI
              Endif
     When 3 : If [F:SBX]PRTPHA <> ""
                 WPRN  = [F:SBX]PRTPHA
              Endif
     When 4 : If [F:SBX]PRTOF <> ""
                 WPRN  = [F:SBX]PRTOF
              Endif
     When 5 : If [F:SBX]PRTCBT <> ""
                 WPRN  = [F:SBX]PRTCBT
              Endif
Endcase
Return

# ############################################################################################# #
# Génération fichier OF PLAN PESEE / MFGHEAD MFGITM                   SMO                       #
# renvoie la liste de tous les OFs pour la matiere selectionnee                                 #
# Exclusivement utilisé en pesée par article                                                    #
# ############################################################################################# #
Subprog XTRACT_PSEMAT_OF(NUMMAT)
    Variable    Char    NUMMAT
    Local       Char    WCHAIN, WSPECHAR
    Local       Integer I
    Local       Integer SAVIUM              : SAVIUM = adxium
    Local       Char    CRITERE (255)
    Local       Char    CRITERE1(255)
    Local       Char    CRITERE2(255)
    Local       Char    FORMULE1(255)
    Local       Char    WMFGNUM(GLONVCR)
    Local       Integer WMFGLIN
    Local       Char    WITMDES(GLONDES)
    Local       Decimal WQTYPREVUE          : WQTYPREVUE = 0
    Local       Decimal WITMWEI             : WITMWEI    = 0
    Local       Char    WITMWEU(10)         : WITMWEU    = ""
    Local       Decimal TOTAPESER           : TOTAPESER  = 0
    Local       Integer WWGGBOX
    If clalev([F:SMFM]) <= 0 : Local File MFGMAT     [SMFM] : Endif

    Call FIND_GFCYDEF(8) From TRTX3
    # fichier OFs du plan de pesee
    PLANPESE = func OPTLIB.FILNAM(GFCY,"ilmwg",0)

    adxium = GUTF8 : adxifs = ";" : adxirs = chr$(10)

    # Ouverture du fichier en écriture
    Openo PLANPESE,0
    If NUMMAT = "" : End : Endif

    Read [F:ITM]ITM0 = NUMMAT
    If !fstat
        WITMWEI = [F:ITM]ITMWEI
        WITMWEU = [F:ITM]WEU
    Else
        Raz [F:ITM] : End
    Endif

    Gosub FILTER_OF
    If CRITERE1 = "" CRITERE1 = "1=1" Endif
    If CRITERE2 = "" CRITERE2 = "1=1" Endif
    If FORMULE1 = "" FORMULE1 = "1=1" Endif
    Link [MFI] With [F:MFG]MFG0 = [F:MFI]MFGNUM,
&           [F:MFM]MFM0 = [F:MFI]MFGNUM; [F:MFI]MFGLIN
&           As [MFIX]
&           Where  evalue(CRITERE1) & evalue(CRITERE2) & evalue(FORMULE1) &
&           [F:MFM]ITMREF = NUMMAT
&           Order By Key MFI0

    For [MFIX]

       # OF vérouillé ? - 86709 mm 01.2013
       # Si OF verrouillé : modification de l'OF en cours sur un autre poste, l'éliminer de la liste
       If (func MFGLIB.CHKMFGLOCK( [F:MFG]MFGNUM ,0 )) : Goto NXT_ENR : Endif

       # même composant pls fois dans la même phase
       If NUMMAT <> ""
          If WMFGNUM = [F:MFM]MFGNUM & WMFGLIN = [F:MFM]MFGLIN : Goto NXT_ENR: Endif
          WMFGNUM = [F:MFM]MFGNUM
          WMFGLIN = [F:MFM]MFGLIN
       Endif

       # OF en cours de pesée  : OF verrouillé ou il y a
       # VRAIMENT une matière de l'OF en cours de pesée par matière ?
       If [F:MFG]WGGFLG = 4
          WWGGBOX = 1
          Filter [SMFM] Where MFGNUM=[MFM]MFGNUM & MATSTA < 3 & CPNTYP <> 5 & WGGSTA < 3 & PKC = 2
          For [SMFM]
              WWGGBOX = [F:SMFM]WGGBOX
              If  WWGGBOX = 2 : Break :Endif
          Next
          Filter [SMFM]
          If  WWGGBOX = 1  : Goto NXT_ENR  : Endif
       Endif

       If [F:MFI]ITMREF <> [F:ITM]ITMREF
          Read [ITM]ITM0 = [F:MFI]ITMREF
          If fstat : Raz [F:ITM] : Endif
       Endif

       Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,WITMDES,"[F:ITM]") From TRTX3 : # chargement libellé traduisible
       Call CHANGE_CHAR(WITMDES)

       Call CAL_POIDS ([F:MFI]ITMREF,[F:MFI]UOMEXTQTY,WQTYPREVUE)                           : # calcul du poids à partir de la quantite en unite de stock

       # calcul du champ 'total a peser' pour pesee matiere
       TOTAPESER = 0
       Filter [F:XMFM] Where ITMREF = NUMMAT & MFGNUM = [F:MFG]MFGNUM
       For [F:XMFM]
          TOTAPESER += ([XMFM]RETQTY*WITMWEI)-([XMFM]USEQTY*WITMWEI)
       Next
       Filter [F:XMFM]
       #Call CAL_POIDS ([F:ITM]ITMREF,TOTAPESER,TOTAPESER)    # mm 03.11

       # écriture le l'enregistrement
        Wrseq [F:MFG]MFGNUM;[F:MFI]ITMREF;WITMDES;[F:MFI]LOT;[F:MFI]UOMEXTQTY;
&               [F:MFI]UOM;[F:MFG]WGGSTA;mess([F:MFG]WGGSTA,2321,1);[F:MFG]STRDAT;
&               [F:MFG]MFGPIO;mess([F:MFG]MFGPIO,365,1);WQTYPREVUE;[F:ITM]WEU;
&               TOTAPESER;WITMWEU
    $NXT_ENR
    Next
    # fermeture de l'enregistrement
    Openo : adxium = SAVIUM

    Call TRF_MWG  From SCALEXCHAN

End

#CATUA X3-67237.sn
# ############################################################################################# #
Subprog XTRACT_PARAM(LOGIN_STA)
Value Integer LOGIN_STA
#Login Status =  0  No login screen, initialize login status value
#Login Status =  1  Prompt login screen, returns a valid User ID
#Login Status = -1  Prompt login screen, returns an invalid blank User ID

Local Integer   SAVIUM : SAVIUM = adxium
Local Char      WSEP, WSEP2, WSEP3, WLIEU, WBOX

Call FIND_GFCYDEF(8) From TRTX3
PARAMFILE = func OPTLIB.FILNAM(GFCY,"ilbox",0)
adxium = GUTF8
adxifs = ";"
adxirs = chr$(10)

Openo PARAMFILE,0

# LECTURE STATION
Read [STX]STX0=GSCA1STI
If fstat Raz[F:STX] : Endif
# Lecture STATIONBOX
Read [SBX]SBX0=GSCA1BOX;GSCA1MFGFCY
If fstat Raz[F:SBX] : Endif
# Lecture TABCUTCAB
Read [CUT]CUT0=GSCA1MFGFCY
If fstat  : Raz [F:CUT] : Endif

# Lecture STATION
Call LECTEXTRA (WLIEU,"STATION","STXDESAXX",[F:STX]STI,"") From ATEXTRA
Call CHANGE_CHAR(WLIEU)

# Lecture STATIONBOX
Call LECTEXTRA (WBOX,"STATIONBOX","DESAXX",[F:SBX]BOX,[F:SBX]FCY) From ATEXTRA
Call CHANGE_CHAR(WBOX)

# Découpage du CAB en recontrole
If GCUTCAB = 2
    # écriture le l'enregistrement
    # sr 05.02 On récupère la valeur du paramètre LENLOT pour contrôle mélange lots
    # mm 03.10 - modification du recontrôle OF
    Wrseq date$;GLANGUE;GUSER;nomap;
&         WLIEU;WBOX;[F:SBX]BOXOPGPCR;[F:SBX]BOXOPGFLG;
&                                  [F:SBX]WOREPYPCR;[F:SBX]WOREPYFLG;
&                                  [F:SBX]PHAEPYPCR;[F:SBX]PHAEPYFLG;
&                                   GPRTWEI;mess(GPRTWEI,1,1);
&                                   GUPDSTO;mess(GUPDSTO,2368,1);
&                                   GITMCTL;mess(GITMCTL,2393,1);
&                                   GCUVCTL;mess(GCUVCTL,2392,1);
&                                   GPRIALL;mess(GPRIALL,2397,1);
&                                   [F:SBX]WRH;[F:SBX]LOC;
&                                   GALLAUT;mess(GALLAUT,1,1);
&                                   GLENLOT;
&                                   GREDNEG;
&                                   2;mess(2,2322,1);
&                                   3;mess(3,2322,1);
&                                   2;mess(2,2321,1);
&                                   3;mess(3,2321,1);
&                                  [F:SBX]MATEPYPCR;[F:SBX]MATEPYFLG;
&                                   GLISMAT;GAPTOPW;GPOSTOL;GCUTCAB;mess(GCUTCAB,1,1);

    If [F:CUT]TYPCAB = 1
       WSEP =[F:CUT]ITMSET : If WSEP = "," : WSEP = "V" : Endif
                             If WSEP = ";" : WSEP = "P" : Endif
       WSEP2 = [F:CUT]LOTSET :  If WSEP2 = "," : WSEP2 = "V" : Endif
                                If WSEP2 = ";" : WSEP2 = "P" : Endif
       WSEP3 = [F:CUT]SLOSET :  If WSEP3 = "," : WSEP3 = "V" : Endif
                                If WSEP3 = ";" : WSEP3 = "P" : Endif
       Wrseq [F:CUT]TYPCAB;[F:CUT]SUPBLC;[F:CUT]NUMITM;WSEP;
&      [F:CUT]NUMLOT;WSEP2;[F:CUT]NUMSLO;WSEP3;0;0;0;0;0;0;   #CATUA X3-67237.n
    Else
        Wrseq [F:CUT]TYPCAB;[F:CUT]SUPBLC;0;"";0;"";0;"";
&       [F:CUT]ITMLON;[F:CUT]ITMDEB;[F:CUT]LOTLON;[F:CUT]LOTDEB;
&       [F:CUT]SLOLON;[F:CUT]SLODEB;   #CATUA X3-67237.n
    Endif
Else
     Wrseq date$;GLANGUE;GUSER;nomap;
&         WLIEU;WBOX;[F:SBX]BOXOPGPCR;[F:SBX]BOXOPGFLG;
&                                  [F:SBX]WOREPYPCR;[F:SBX]WOREPYFLG;
&                                  [F:SBX]PHAEPYPCR;[F:SBX]PHAEPYFLG;
&                                   GPRTWEI;mess(GPRTWEI,1,1);
&                                   GUPDSTO;mess(GUPDSTO,2368,1);
&                                   GITMCTL;mess(GITMCTL,2393,1);
&                                   GCUVCTL;mess(GCUVCTL,2392,1);
&                                   GPRIALL;mess(GPRIALL,2397,1);
&                                   [F:SBX]WRH;[F:SBX]LOC;
&                                   GALLAUT;mess(GALLAUT,1,1);
&                                   GLENLOT;
&                                   GREDNEG;
&                                   2;mess(2,2322,1);
&                                   3;mess(3,2322,1);
&                                   2;mess(2,2321,1);
&                                   3;mess(3,2321,1);
&                                  [F:SBX]MATEPYPCR;[F:SBX]MATEPYFLG;
&                                   GLISMAT;GAPTOPW;GPOSTOL;GCUTCAB;mess(GCUTCAB,1,1);     #CATUA X3-67237.n
Endif

#CATUA X3-67237.sn
#Save username pwd flags and login status value
#Should only work with V12 and higher
Wrseq [F:SBX]STAAUZ;[F:SBX]MATAUZ;LOGIN_STA
#CATUA X3-67237.en

Openo

If LOGIN_STA<>0
  adxium = SAVIUM
  Call TRF_PAR  From SCALEXCHAN
Endif

End
#CATUA X3-67237.en


# ############################################################################################# #
# PRÉPARATION DU FILTRE SUR LES OF POUR LA PESEE MATIERE                      SMO               #
# ############################################################################################# #
$FILTER_OF
    Raz CRITERE
    Raz FORMULE1

    # filtre sur MFGHEAD
    # critères dynamiques, dépendant des paramètres
    If GSCA1MFGFCY <> ""
        CRITERE = "[F:MFG]MFGFCY=GSCA1MFGFCY"               # filtre site
        Gosub LOAD_CRITERE1
        CRITERE = "[F:MFI]MFGFCY=GSCA1MFGFCY"
        Gosub LOAD_CRITERE2
    Endif
    If GSCA1DATESTR <> [0/0/0]
        CRITERE = "[F:MFG]STRDAT >= GSCA1DATESTR"           # date début OF
        Gosub LOAD_CRITERE1
    Endif
    If GSCA1DATEEND <> [0/0/0]
        CRITERE = "[F:MFG]STRDAT <= GSCA1DATEEND"
        Gosub LOAD_CRITERE1
    Endif

    If GSCA1NUMSTR <> ""
       CRITERE = "[F:MFG]MFGNUM >= GSCA1NUMSTR"            # Numéro OF debut
       Gosub LOAD_CRITERE1
       CRITERE = "[F:MFI]MFGNUM >= GSCA1NUMSTR"            # Numéro OF debut
       Gosub LOAD_CRITERE2
    Endif
    If GSCA1NUMEND <> ""
      CRITERE = "[F:MFG]MFGNUM <= GSCA1NUMEND"
      Gosub LOAD_CRITERE1
      CRITERE = "[F:MFI]MFGNUM <= GSCA1NUMEND"
      Gosub LOAD_CRITERE2
    Endif


    CRITERE = "[F:MFG]WGGSTA<8"                             # filtre situation
    Gosub LOAD_CRITERE2

    # mm 12.10 - en pesée par matière , on a redescendu au niveau de [MFM] le verrouillage de la matière avec WGGBOX
    CRITERE = "([F:MFG]WGGFLG= 3 | [F:MFG]WGGFLG= 4 )"      # OF inclus dans le plan de pesée
    Gosub LOAD_CRITERE2                                     # ou en cours de pesée

    # Issue 80845 - 2012-03-19 by SR
    CRITERE = "[F:MFG]MFGSTA = 1"                           # statut ferme
    Gosub LOAD_CRITERE2

    # filtre sur MFGMAT
    CRITERE ="[F:MFM]MATSTA < 3"                            # matiere en attente ou en cours(s'il existe un suivi, matiere en cours)
    Gosub LOAD_CRITERE2

    CRITERE = "[F:MFM]WGGBOX=1"                             # on ne veut pas des matières qui sont physiquement
    Gosub LOAD_CRITERE2                                     #en cours de pesée en box, cad WGGBOX = 2

    CRITERE ="[F:MFM]CPNTYP <> 5"                           # type composant <> texte
    Gosub LOAD_CRITERE2

    CRITERE = "[F:MFM]PKC =  2"                             # composant pesé en centrale
    Gosub LOAD_CRITERE2

    # Issue 80839 - 2012-03-19 by SR
    Gosub LOAD_FORMULE1
Return

# ############################################################################################# #
# Génération fichier MATIERE / MFGMAT                                         SMO               #
# renvoie la liste de toutes les matieres  présentes dans les OFs du plan de pesée              #
# Exclusivement utilisé en pesée par article                                                    #
# ############################################################################################# #
Subprog XTRACT_PSEMAT_MAT(NUMMAT)

    Variable    Char    NUMMAT                  # APCPRD 2372 - mm 10.12
    Local Char    WCHAIN, WSPECHAR, WITM        # 03.09 mm - libellé traduisible
    Local Char    NUMOF
    Local Integer I, Y,LRET
    Local Integer WACCES        : WACCES     = 0
    Local Decimal WQTYPREVUE    : WQTYPREVUE = 0
    Local Decimal WQTYRESTAN    : WQTYRESTAN = 0
    Local Decimal WQTYCONSOM    : WQTYCONSOM = 0
    Local Decimal WQTEDISPO     : WQTEDISPO  = 0     # pour la pesee matiere : colonne qtedispo
    Local Char    DEPOT(GLONWRH): DEPOT      = ""    # pour calcul qté dispo : depot
    Local Char    LOC(GLONEMP)  : LOC        = ""    # emplacement
    Local Integer WSTATUT       : WSTATUT    = 0     # statut matière autorisé, d'après la lecture de TABSTRORUL
    Local Decimal WQTYDOSE
    Local Integer WNUMOPE  # 63294 mm 03.10
    Local Integer WWGGBOX  # mm 01.11
    Local Integer SAVIUM        : SAVIUM = adxium
    Local Char    CRITERE (255)
    Local Char    CRITERE1(255)
    Local Char    CRITERE2(255)
    Local Char    FORMULE1(255)
    Local Decimal WQTYPEC       : WQTYPEC    = 0     # 93535 mm 10.2013
    Local Decimal WTOLPOS       : WTOLPOS    = 0     # 115726 mm 04.2016
    Local Decimal WTOLNEG       : WTOLNEG    = 0     # 115726 mm 04.2016
    Local Decimal WCTNTHETAR                         #CATUA X3-30163.n
    Local Char    WCTNWEU(3)                         #CATUA X3-30163.n

    If clalev([F:BOD])  <= 0 : Local File BOMD       [BOD]  : Endif
    If clalev([F:SMFM]) <= 0 : Local File MFGMAT     [SMFM] : Endif
    If clalev([F:FCY])  <= 0 : Local File FACILITY   [FCY]  : Endif
    If clalev([F:ITV])  <= 0 : Local File ITMMVT     [ITV]  : Endif
    If clalev([F:TUN])  <= 0 : Local File TABUNIT    [TUN]  : Endif
    If clalev([F:CTN])  <= 0 : Local File CONTAINERS [CTN]  : Endif #CATUA X3-30163.n

    Call FIND_GFCYDEF(8) From TRTX3
    COMPOSANTS = func OPTLIB.FILNAM(GFCY,"ilmat",0)

    # Ouverture du fichier en écriture
    Openo COMPOSANTS, 0
    adxium = GUTF8
    # Lecture AUTILIS pour connaitre la valeur de ALLACS
    Read [AUS]CODUSR = GUSER
    If fstat : Raz [F:AUS] : Endif

    # lecture du dépôt associé au box
    Call LEC_WRH(DEPOT,LOC)

    # Récupération des Matieres                                              #
    # il faut pouvoir peser des matieres sur des phases <> en                #
    # simultanee. on controlera donc la valeur du flag WGGBOX                #
    # sur MFGMAT pour pouvoir ou non selectionner un couple phase/matière    #
    Gosub FILTER_MAT
    If CRITERE1 = "" CRITERE1 = "1=1" Endif
    If CRITERE2 = "" CRITERE2 = "1=1" Endif
    If FORMULE1 = "" FORMULE1 = "1=1" Endif

    # APCPRD 2372 - mm 10.12
    # Issue 80839 - 2012-03-19 by SR
    If NUMMAT <>""
     Link [F:MFM] With [F:MFG]MFG0 = [F:MFM]MFGNUM,
&        [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
&    As [XMFM]
&    Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(FORMULE1) & [F:MFM]ITMREF = NUMMAT
&    Order By Key MFM0
    Else
      Link [F:MFM] With [F:MFG]MFG0 = [F:MFM]MFGNUM,
&        [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
&     As [XMFM]
&     Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(FORMULE1)
&     Order By Key MFM0
    Endif

    For [XMFM]MFM0

        # OF vérouillé ? - 86709 mm 01.2013
        # Si OF verrouillé : modification de l'OF en cours sur un autre poste, l'éliminer de la liste
        If (func MFGLIB.CHKMFGLOCK( [F:MFG]MFGNUM ,0 )) : Goto NEXT_MFM_PSE : Endif

        # controle acces
        Gosub CTL_ACCES
        If WACCES <> 0 : Goto NEXT_MFM_PSE : Endif

        # OF en cours de pesée  : OF verrouillé ou il y a
        #  une matière de l'OF en cours de pesée par matière ?
        If [F:MFG]WGGFLG = 4
         # Pose pb de perf : à optimiser
          Filter [SMFM] Where MFGNUM=[F:MFM]MFGNUM & MATSTA < 3 & CPNTYP <> 5 & WGGSTA < 3 & PKC = 2 & WGGBOX = 2
          Look [SMFM]MFM0 First
          Filter [SMFM]
          If fstat > 2 : Goto NEXT_MFM_PSE : Endif
        Endif

        # 63294 mm 03.10
        # PE pour permettre de substituer le n° d’opération par un n° de phase ajouté en spécifique.
        WNUMOPE = [F:MFM]BOMOPE
        GPOINT = "RPLOPE" : Gosub ENTREE From EXEFNC

        # si existe :
        # Lecture ITMMASTER
        # mm 03.13 - performances
        If [F:ITM]ITMREF <> [F:MFM]ITMREF
          Read [ITM]ITM0 = [F:MFM]ITMREF
           If fstat : Raz [F:ITM] : Endif
        Endif

        # Lecture ITMFACILIT
        # mm 03.13 - performances
        If  [F:ITF]ITMREF <> [F:MFM]ITMREF | [F:ITF]STOFCY <> [F:MFM]MFGFCY
          Read [ITF]ITF0 = [F:MFM]ITMREF; [F:MFM]MFGFCY
          If fstat : Raz [F:ITF] : Endif
        Endif

        Call CAL_POIDS ([F:ITM]ITMREF,[F:MFM]RETQTY,WQTYPREVUE)
        Call CAL_POIDS ([F:ITM]ITMREF,[F:MFM]RETQTY-[F:MFM]USEQTY,WQTYRESTAN)

        # calcul quantite consommée
        Gosub CAL_QTYCONSOMME
        Call CAL_POIDS ([F:ITM]ITMREF,WQTYCONSOM,WQTYCONSOM)

        # lecture de la règle de gestion
        Call LEC_SRU(WSTATUT)
        If WSTATUT<>0
          # pour le calcul quantité dispo
          # mm 03.13 - performances
          If [F:ITV]ITMREF <> [F:MFM]ITMREF | [F:ITV]STOFCY <> [F:MFM]MFGFCY
             Read [F:ITV]ITV0 = [F:MFM]ITMREF;[F:MFM]MFGFCY
             If fstat : Raz [F:ITV] : Endif
          Endif
          If [F:ITG]STOFCY <> [F:MFM]MFGFCY | [F:ITG]TCLCOD <> [F:ITM]TCLCOD
             Read [F:ITG]ITG0 = [F:MFM]MFGFCY;[F:ITM]TCLCOD
             If fstat
               Read [ITG] ITG1=[F:ITM]TCLCOD;"" : If fstat  Raz [F:ITG] : Endif
             Endif
          Endif
          # calcul quantité dispo
          #--- TS 106217 & GH 120426
          #Call STODISPO("",[F:MFM]MFGFCY,[F:MFM]ITMREF,"*","*",0,WSTATUT,"" ,"",DEPOT,WQTEDISPO) From STKLIB
          Call STODISPO("",[F:MFM]MFGFCY,[F:MFM]ITMREF,"*","*",0,WSTATUT,"" ,"",DEPOT,
&                       string$([F:SRU]ORDVER=2,[F:MFM]ECCVALMAJ),
&                       WQTEDISPO) From STKLIB
          #---
        Else
          WQTEDISPO = 0
        Endif

        Call CAL_POIDS ([F:ITM]ITMREF,WQTEDISPO,WQTEDISPO)

        # lecture de l unite pour recuperation decimale
        If [F:TUN]UOM <> [F:ITM]WEU
            Read [TUN]TUN0 = [F:ITM]WEU
        Endif

        # 05.10 mm - lecture nomenclature pour récupération du % de tolérance
        # Issue 80839 - 2012-03-19 by SR dans le link
#        Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
#        If fstat : Raz [F:MFI] : Endif

        Read [BOD]BOD0 = [F:MFI]ITMREF;[F:MFI]BOMALT;[F:MFM]BOMSEQ;[F:MFM]ITMREF;2
        If fstat : Raz [F:BOD] : Endif

        # 03.09 mm - libellé traduisible
        # Call LECTEXTRA (WITM,"ITMMASTER","DES1AXX",[F:ITM]ITMREF,"") From ATEXTRA
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,WITM,"[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
        Call CHANGE_CHAR(WITM)

        # 115726 mm 04.2016
        # EP to change the values of [F:BOD]ITMTOLPOS/ ITMTOLNEG by specific values
        WTOLPOS = [F:BOD]ITMTOLPOS
        WTOLNEG = [F:BOD]ITMTOLNEG
        GPOINT ="RPLDATSTD" : Gosub ENTREE From EXEFNC

        # sr 03.05 test pour doses
        # dans la réalité, on récuperera le nombre de pesées(à initialiser à 1 ou 0) sur l'enregistrement MFO
        # on divisera la quantité prévue par ce nombre de pesée pour connaître la quantité de la dose
        # Si le nombre de pesée = 0 ou 1 alors WQTYDOSE = 0 (on ne gère pas les doses)
        # pour l'instant on l'initialise à 0
        # POUR L'instant on ne descend pas cette zone (a rajouter à la fin si besoin)
        #WQTYDOSE = 0

        # écriture le l'enregistrement COMPOSANTS
        # sr 07.05 Pour LYOCENTRE
        # selon presence ou non de la zone REDMODFLG de ITF il faudra rajouter ou non cette zone en dernier

        If dim([F:ITF]REDMODFLG) > 0
            If [F:ITF]REDMODFLG = 0  : [F:ITF]REDMODFLG = 1 : Endif
            Wrseq  [F:MFM]MFGNUM;WNUMOPE;[F:MFM]ITMREF;WITM;
&                   WQTYPREVUE;WQTYRESTAN ;WQTYCONSOM;
&                   [F:ITM]WEU;[F:ITM]STU;[F:MFM]PKC;mess([F:MFM]PKC,2328,1);
&                   [F:MFM]STOMGTCOD;mess([F:MFM]STOMGTCOD,215,1);
&                   [F:MFM]DEFPOT;[F:ITM]NEGSTO;mess([F:ITM]NEGSTO,1,1);
&                   [F:ITF]MFGSHTCOD;mess([F:ITF]MFGSHTCOD,1,1);[F:ITF]ISM;
&                   [F:MFM]MFGLIN;[F:MFM]BOMSEQ;[F:TUN]UOMDEC;
&                   WTOLPOS;WTOLNEG;WQTEDISPO;WQTYPEC;[F:ITF]REDMODFLG; #CATUA X3-30163.n
        Else
            Wrseq  [F:MFM]MFGNUM;WNUMOPE;[F:MFM]ITMREF;WITM;
&                   WQTYPREVUE;WQTYRESTAN ;WQTYCONSOM;
&                   [F:ITM]WEU;[F:ITM]STU;[F:MFM]PKC;mess([F:MFM]PKC,2328,1);
&                   [F:MFM]STOMGTCOD;mess([F:MFM]STOMGTCOD,215,1);
&                   [F:MFM]DEFPOT;[F:ITM]NEGSTO;mess([F:ITM]NEGSTO,1,1);
&                   [F:ITF]MFGSHTCOD;mess([F:ITF]MFGSHTCOD,1,1);[F:ITF]ISM;
&                   [F:MFM]MFGLIN;[F:MFM]BOMSEQ;[F:TUN]UOMDEC;
&                   WTOLPOS;WTOLNEG;WQTEDISPO;WQTYPEC; #CATUA X3-30163.n
        Endif : # fin test sr

        #CATUA X3-30163.sn
        #Save container and tare fields
        #Should only work with V12 and higher
        Raz WCTNTHETAR, WCTNWEU
        If [F:MFM]CTN<>""
          Read [F:CTN]CTN0 = [F:MFM]CTN
          If !fstat
            WCTNTHETAR = [F:CTN]CTNTHETAR
            WCTNWEU = [F:CTN]CTNWEU
          Endif
        Endif
        Wrseq [F:MFM]CTN; WCTNTHETAR; WCTNWEU
        #CATUA X3-30163.en

    $NEXT_MFM_PSE
    Next

    Openo : # fermeture de l'enregistrement
    adxium = SAVIUM

    Call TRF_MAT  From SCALEXCHAN

End

# ############################################################################################# #
# PRÉPARATION DU FILTRE SUR LES MATIERES - PESEE PAR MATIERE                                    #
# ############################################################################################# #
$FILTER_MAT
 Raz CRITERE
 Raz FORMULE1

 # Filtre sur MFGHEAD
 # critères dynamiques, dépendant des paramètres
 If GSCA1MFGFCY <> ""
    # mm 10.12 APCPRD 2376
   CRITERE = "[F:MFG]MFGFCY=GSCA1MFGFCY"                # filtre site
   Gosub LOAD_CRITERE1
 Endif

 If GSCA1DATESTR <> [0/0/0]
   CRITERE = "[F:MFG]STRDAT >= GSCA1DATESTR"           # date début OF
   Gosub LOAD_CRITERE1
 Endif
 If GSCA1DATEEND <> [0/0/0]
    CRITERE = "[F:MFG]STRDAT <= GSCA1DATEEND"
    Gosub LOAD_CRITERE1
 Endif

 If GSCA1NUMSTR <> ""
    CRITERE = "[F:MFG]MFGNUM >= GSCA1NUMSTR"            # Numéro OF debut
    Gosub LOAD_CRITERE1
 Endif
 If GSCA1NUMEND <> ""
   CRITERE = "[F:MFG]MFGNUM <= GSCA1NUMEND"
   Gosub LOAD_CRITERE1
 Endif

 # mm 10.12 APCPRD 2376
 CRITERE = "[F:MFG]MFGSTA = 1"                           # OF ferme exclusivement
 Gosub LOAD_CRITERE1

 CRITERE = "[F:MFG]WGGSTA<8"                             # filtre situation
 Gosub LOAD_CRITERE1

 CRITERE = "find([F:MFG]WGGFLG,3,4)<>0"                  # OF inclus dans le plan de pesée
 Gosub LOAD_CRITERE1                                     # ou en cours de pesée

# Filtre sur MFGMAT
 CRITERE ="[F:MFM]MATSTA < 3"                            # matiere en attente ou en cours(s'il existe un suivi, matiere en cours)
 Gosub LOAD_CRITERE2

 # mm 12.10 - en pesée par matière , on a redescendu au niveau de [MFM] le verrouillage de la matière avec WGGBOX
 CRITERE ="[F:MFM]WGGBOX = 1"                            # matiere pas physiquement en train d'être pesée
 Gosub LOAD_CRITERE2

 CRITERE ="[F:MFM]CPNTYP <> 5"                           # type composant <> texte
 Gosub LOAD_CRITERE2

 CRITERE = "[F:MFM]PKC =  2"                             # composant pesé en centrale
 Gosub LOAD_CRITERE2

 # Issue 80839 - 2012-03-19 by SR
 Gosub LOAD_FORMULE1

Return

