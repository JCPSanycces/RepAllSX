#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "IMPORT"      : Gosub IMPORT
Endcase
Return

$IMPORT
Case IMPFIC
 When "GSC"
  GBIDC1 = [F:GSC]COA
  If GREP="M" & find([F:GSC]SAC,[M:GSC1]SAC(0..[M:GSC1]NBRSAC-1))
   nolign = find([F:GSC]SAC,[M]SAC(0..[M:GSC1]NBRSAC-1))
  Else
   [M:GSC1]NBRSAC += 1
   nolign = [M:GSC1]NBRSAC
  Endif
Endcase
Return

