Call FMTECR("CONSAWW2","TIMENV","",GBIDC1)
Infbox GBIDC1
End

##########################################################################################
# Permet de rÃĐcupÃĐrer le format d'un champ utilisÃĐ dans un ÃĐcran
##########################################################################################

Subprog FMTECR(ECRAN,ZONE,CODTYP,FORMAT)
Value Char ECRAN , ZONE , CODTYP
Variable Char FORMAT
If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
Local Integer  LGMAX
Local Decimal  LONG
Local Char     TYPFMT(10) , OPTFMT(10) , CHFMT(30) , NUMFMT(10)
#Dbgaff
If ECRAN<>[F:AMZ]CODMSK & ZONE<>[F:AMZ]CODZON
 Read [AMZ]CODE=ECRAN;ZONE
Endif
If [L]CODTYP=""
 Read [ATY]CODTYP=[F:AMZ]CODTYP
Elsif [ATY]CODTYP<>[L]CODTYP
 Read [ATY]CODTYP=[L]CODTYP
Endif
If [F:ATY]LNGTYP<>0
 LONG = [F:ATY]LNGTYP
Else
 LONG = [F:AMZ]LONG
Endif
If [F:AMZ]OPTLNG>0
 LGMAX = [F:AMZ]OPTLNG
Else
 LGMAX = LONG
Endif
If [F:AMZ]NOLIB<>0 | [F:ATY]NOLIB<>0
 FORMAT = "N+:3#"
Elsif [F:ATY]TYPTYP=9
 FORMAT = "KP:10X"
Else
 Call FORMA(LGMAX,[F:ATY]TYPTYP,LONG,0,[F:AMZ]OPTSAI+[F:ATY]OPTION,[F:ATY]FORTYP,[L]TYPFMT,OPTFMT,CHFMT,NUMFMT) From SUBFMT
 If TYPFMT="D" or TYPFMT='="D'
  If !instr(1,OPTFMT,"z") : OPTFMT += "z" : Endif
  If !instr(1,OPTFMT,"Z") : OPTFMT += "Z" : Endif
#  CHFMT = GFMDAT4
 Elsif TYPFMT="N" & left$([F:ATY]FORTYP,1)="="
  If right$(CHFMT,len(CHFMT))="#" : CHFMT = left$(CHFMT,len(CHFMT)-1) : Endif
  CHFMT = "15F"
 Endif
 K = instr(1,CHFMT,"F")
 If K & instr(1,CHFMT,".")
  CHFMT = left$(CHFMT,K-1)+"#"+right$(CHFMT,K+1) 
 Endif
 FORMAT = TYPFMT+OPTFMT+":"+CHFMT
 If left$(FORMAT,1)="="
  Onerrgo RIEN
  FORMAT = evalue(right$(FORMAT,2))
  Onerrgo
 Endif
Endif
End

$RIEN
Resume

######################################################################################
## SUBFMT   Calcul d'un format Adonix
######################################################################################
Subprog  FORMA(MAXLNG,TYP,LONG,NOLIB,OPTSAI,FORFMT,TYPFMT,OPTFMT,CHFMT,NUMFMT)
Value    Integer MAXLNG
Value    Integer TYP
Value    Decimal LONG
Value    Integer NOLIB
Value    Char    OPTSAI
Value    Char    FORFMT
Variable Char    TYPFMT()
Variable Char    OPTFMT()
Variable Char    CHFMT()
Variable Char    NUMFMT()

Local Integer L1 , L2
Local Char    CARFMT(1)

Case TYP

 When 1 : # LibellÃĐ

  NUMFMT = "302" : # Entier long pour que Ã§a marche
  CHFMT  = num$(LONG)+"X"
  Gosub OPTLIB
  TYPFMT = "LA"+num$(NOLIB)

 When 7 : # Alpha

  TYPFMT = "K"
  NUMFMT = "306"
  Gosub OPTCAR
  If FORFMT<>"" & left$(FORFMT,1)<>"="
   CHFMT = FORFMT
  Elsif LONG>MAXLNG
   CHFMT = num$(MAXLNG)+CARFMT+">"+num$(LONG-MAXLNG)+CARFMT
  Else
   CHFMT = num$(LONG)+CARFMT
  Endif
    
 When 2,3,4,5,6 : # NumÃĐrique

  NUMFMT = "303"
  TYPFMT = "N"
  Gosub OPTNUM
  CHFMT  = num$(LONG)+CARFMT

 When 8 : # Date

  NUMFMT = "307"
  TYPFMT = "D"
  Gosub OPTDAT
  L2 = 1
  For L1=1 To 7
   If instr(1,OPTSAI,num$(L1))
    L2 = L1 : Break
   Endif
  Next L1
  Case L2
   When 1 : CHFMT = GFMDAT
   When 2 : CHFMT = GFMDAT4
   When 3 : CHFMT = "DD[ ]MMM[ ]YYYY"
   When 4 : CHFMT = "DD[ ]MMMMMMMM[ ]YYYY" : OPTFMT += "<"
   When 5 : CHFMT = GFMJOU
   When 6 : CHFMT = GFMMOI
   When 7 : CHFMT = "MM[/]YYYY"
  Endcase
 
 When 11 : # Uuid

  TYPFMT = "K"
  NUMFMT = "306"
  CHFMT  = "36X"

 When 12 : # Datetime

  TYPFMT = "K"
  NUMFMT = "306"
  CHFMT  = "20X"
Endcase

End

#######################################################################
## DÃĐcodage des options et du caractÃĻre de saisie
#######################################################################
$OPTCAR
OPTFMT = ""
If instr(1,OPTSAI,"C")
 CARFMT = "c"
Elsif instr(1,OPTSAI,"A")
 If instr(1,OPTSAI,"#") : CARFMT = "B" : Else : CARFMT = "A" : Endif
Elsif instr(1,OPTSAI,"#")
 CARFMT = "#"
Else
 CARFMT = "X"
Endif
If    instr(1,OPTSAI,"T") : OPTFMT += "T"            : # TokenisÃĐ
Elsif instr(1,OPTSAI,"D") : OPTFMT += "TD"           : # Token interdites
Endif
If    instr(1,OPTSAI,"1") : OPTFMT += "1"  : Endif   : # Au moins 1 caractÃĻre
If    instr(1,OPTSAI,"z") : OPTFMT += "z"  : Endif   : # Commentaires non affichÃĐs
If    instr(1,OPTSAI,"=") : OPTFMT += "="            : # CentrÃĐ
Elsif instr(1,OPTSAI,"<") : OPTFMT += "<"            : # CadrÃĐ Ã  gauche
Elsif instr(1,OPTSAI,">") : OPTFMT += ">"            : # CadrÃĐ Ã  droite
Endif
If    instr(1,OPTSAI,"U") : OPTFMT += "U" : Endif    : # Format fichier
If    instr(1,OPTSAI,"W") : OPTFMT += "W" : Endif    : # Non creusÃĐ
If    instr(1,OPTSAI,"X") : OPTFMT += "X" : Endif    : # Saisie masquÃĐe
If    instr(1,OPTSAI,"c") : OPTFMT += "c" : Endif    : # ColorisÃĐ
Return

$OPTNUM
OPTFMT = ""
If instr(1,OPTSAI,"F")                               : # Flottant
 CARFMT = "F"
Else
 CARFMT ="#"
Endif
If instr(1,OPTSAI,"+") : OPTFMT += "+" : Endif       : # Nb > 0
If instr(1,OPTSAI,"z") : OPTFMT += "z" : Endif       : # ZÃĐro non affichÃĐ
If instr(1,OPTSAI,"0") : OPTFMT += "0" : Endif       : # PaddÃĐ avec des 0
If instr(1,OPTSAI,"3") : OPTFMT += "3" : Endif       : # SÃĐparateur de 3 chiffres
If instr(1,OPTSAI,"W") : OPTFMT += "W" : Endif       : # Non creusÃĐ
If instr(1,OPTSAI,"-") : OPTFMT += "-" : Endif       : # Signe aprÃĻs
If instr(1,OPTSAI,"c") : OPTFMT += "c" : Endif       : # ColorisÃĐ
Return

$OPTDAT
OPTFMT = ""
If instr(1,OPTSAI,"z") : OPTFMT += "z" : Endif       : # Commentaires non affichÃĐs
If instr(1,OPTSAI,"Z") : OPTFMT += "Z" : Endif       : # Date nulle autorisÃĐe
If instr(1,OPTSAI,"W") : OPTFMT += "W" : Endif       : # Non creusÃĐ
If instr(1,OPTSAI,"c") : OPTFMT += "c" : Endif       : # ColorisÃĐ
Return

$OPTLIB
OPTFMT = ""
If instr(1,OPTSAI,"W") : OPTFMT += "W" : Endif       : # Non creusÃĐ
If instr(1,OPTSAI,"c") : OPTFMT += "c" : Endif       : # ColorisÃĐ
Return



