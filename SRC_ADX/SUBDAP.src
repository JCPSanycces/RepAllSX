#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion objet DAP
######################################################################################
Raz GPILOBJ
GBIDC1="200800000272"
GBIDC2="2009~ASN999999~20090101~1~1"
Call OBJET_CHAR(GBIDC1,"DAP",GBIDC2) From GOBJET
End


## Etiquette ajoutée par le superviseur (Objet DAP) 23/06/2009 17:34:23 (DBA)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "FILTRE"      : Gosub FILTRE
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "VERF_ANU"    : Gosub VERF_ANU
 When "DEFTRANS"    : Gosub DEFTRANS From SUBDAE
 When "STATUT"      : Gosub STATUT From SUBDAE
Endcase
Return

$OUVRE
GFLAG="1"
Gosub OUVRE From SUBDAE
If clalev([F:DAE2])=0 : Local File DADEMP    [DAE2] : Endif
If clalev([F:DAP2])=0 : Local File DADEMP3   [DAP2] : Endif
If clalev([F:DPP2])=0 : Local File DADEMP32  [DPP2] : Endif
If clalev([F:DAQ2])=0 : Local File DADEMP12  [DAQ2] : Endif

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

###################################
$SETBOUT    #pour désactiver le bouton nouveau & chgt clé
Call VIREBOUT (CHAINE,"CH") From GOBJET
If REP<>"" | [F:HRDAE]FLGNEWSAL=2
 Call VIREBOUT (CHAINE,"G") From GOBJET
Endif
#Objet à 4 éléments de clé : ajout du btn suppression après que GOBJET l'ait viré !
If CLECUR & VERROU : CHAINE+="A" : Endif
If GREP=""
 CHMEN += "1"
Elsif GREP="M" | GREP="D"
 CHMEN=""
Endif
Gosub SET_BOUT_SPE From GSAISIE
Return

###################################
$EXEBOUT
Case BOUT
 When "G"
  # Pas de lectcure si la création s'est mal passée...
  If !GOK : Return : Endif
  # Unlock la fiche qui était à l'écran quand on a fait "NOUVEAU"
  If VERROU : Gosub DEVERROU From GOBJET : Endif
 Gosub RAFFRAICHIR From GOBJSUB
 Gosub RELIT From GOBJSUB
Endcase
Return

###################################
$LIENS
# Multi_leg & multi_société
Call LECTURE("FCY",[M:DAP1]ETRFCY,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
GSOCIETE=[F:CPY]CPY
GCURLEG=[F:CPY]LEG

#The read is in the object
[M:DAP1]NAM=[F:HRDAE]NAM
[M:DAP1]SRN=[F:HRDAE]SRN
Gosub CHARGE_EVT
Gosub CHARGE_PERIODE
Return

###################################
$CHARGE_EVT
# Tableau des evénements
nolign=0
For [DPE]DPE1 Where YEAEMPDDS=[M:DAP1]YEAEMPDDS & EMPDDS=[M:DAP1]EMPDDS
&  & ETRDAT=[M:DAP1]ETRDAT & CTRNUM=[M:DAP1]CTRNUM & TYPDAE=[M:DAP1]TYPDAE & REFCTR=[M:DAP1]REFCTR
 nolign += 1
 [M:DAP1]=[F:DPE]
Next
[M:DAP1]NBRDP1 = nolign
Return

###################################
$CHARGE_PERIODE
Effzo [M:DAP1]20
# Tableau des périodes
nolign=0
For [DPP]DPP0 Where YEAEMPDDS=[M:DAP1]YEAEMPDDS & EMPDDS=[M:DAP1]EMPDDS
&  & ETRDAT=[M:DAP1]ETRDAT & CTRNUM=[M:DAP1]CTRNUM & TYPDAE=[M:DAP1]TYPDAE & REFCTR=[M:DAP1]REFCTR
 nolign += 1
 [M:DAP1]STRDATCTR(nolign-1)=[F:DPP]STRDATCTR
 [M:DAP1]ENDDATCTR(nolign-1)=[F:DPP]ENDDATCTR
Next
[M:DAP1]NBRDP2 = nolign
Return

###################################
$INICRE
$INIMOD
Gosub SAUVE_EVT
Return

###################################
$SAUVE_EVT
Delete [DPE] Where YEAEMPDDS=[M:DAP1]YEAEMPDDS & EMPDDS=[M:DAP1]EMPDDS
&  & ETRDAT=[M:DAP1]ETRDAT & CTRNUM=[M:DAP1]CTRNUM & TYPDAE=[M:DAP1]TYPDAE
&  & REFCTR=[M:DAP1]REFCTR
If fstat=1
 GOK =-1 : GLOCK = "$DADEMP31" : Return
Endif
For nolign=1 To [M:DAP1]NBRDP1
 [F:DPE]=[M:DAP1]
 [F:DPE]NUMLIG=nolign
 Write [DPE]
 If fstat<>0
  GOK = 0 : Call FSTA("DPE") From GLOCK : Break
 Endif
Next
Return

###################################
$FILTRE
If find("DAE",GPILCOD(1..GPILOBJ))
 If FILTSUP<>"" : FILTSUP += " & " : Endif
 FILTSUP -= "YEAEMPDDS='"+[F:HRDAE]YEAEMPDDS+"'"
 FILTSUP -= "& EMPDDS='"+[F:HRDAE]EMPDDS+"'"
 FILTSUP -= "& CTRNUM='"+[F:HRDAE]CTRNUM+"'"
 FILTSUP -= "& ETRDAT=["+format$("D:"+GFMDAT4,[F:HRDAE]ETRDAT)+"]"
 FILTSUP -= "& TYPDAE="+num$([F:HRDAE]TYPDAE)
Else
 If GUSRACS<>2
  If FILTSUP<>"" : FILTSUP += " & " : Endif
  FILTSUP -= '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
  FILTSUP -= "& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))"
 Else
  FILTSUP ="1=1"
 Endif
 If [L]ANCOUR<>""
  FILTSUP -= "& [F:DAP]YEAEMPDDS='"+[L]ANCOUR+"'"
 Endif
Endif
Return

###################################
$FILGAUCHE
If find("DAE",GPILCOD(1..GPILOBJ))
 If FILGAUSUP<>"" : FILGAUSUP += " & " : Endif
 FILGAUSUP -= "YEAEMPDDS='"+[F:HRDAE]YEAEMPDDS+"'"
 FILGAUSUP -= "& EMPDDS='"+[F:HRDAE]EMPDDS+"'"
 FILGAUSUP -= "& CTRNUM='"+[F:HRDAE]CTRNUM+"'"
 FILGAUSUP -= "& ETRDAT=["+format$("D:"+GFMDAT4,[F:HRDAE]ETRDAT)+"]"
 FILGAUSUP -= "& TYPDAE="+num$([F:HRDAE]TYPDAE)
Else
 If [L]ANCOUR<>""
  If FILGAUSUP<>"" : FILGAUSUP += " & " : Endif
  FILGAUCHE = "[F:DAP]YEAEMPDDS='"+[L]ANCOUR+"'"
 Else
  FILGAUCHE = ""
 Endif
Endif
Return

###################################
$VERF_ANU
Trbegin [DAP],[DPE],[DPP]
 Delete [DAP] Where YEAEMPDDS=[M:DAP1]YEAEMPDDS & EMPDDS=[M:DAP1]EMPDDS
& & ETRDAT=[M:DAP1]ETRDAT & CTRNUM=[M:DAP1]CTRNUM & TYPDAE=[M:DAP1]TYPDAE
& & REFCTR=[M:DAP1]REFCTR
 If fstat = 1  : # enreg locké
  GLOCK = "$DADEMP3" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [DPE] Where YEAEMPDDS=[M:DAP1]YEAEMPDDS & EMPDDS=[M:DAP1]EMPDDS
& & ETRDAT=[M:DAP1]ETRDAT & CTRNUM=[M:DAP1]CTRNUM & TYPDAE=[M:DAP1]TYPDAE
& & REFCTR=[M:DAP1]REFCTR
 If fstat = 1  : # enreg locké
  GLOCK = "$DADEMP31" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [DPP] Where YEAEMPDDS=[M:DAP1]YEAEMPDDS & EMPDDS=[M:DAP1]EMPDDS
& & ETRDAT=[M:DAP1]ETRDAT & CTRNUM=[M:DAP1]CTRNUM & TYPDAE=[M:DAP1]TYPDAE
& & REFCTR=[M:DAP1]REFCTR
 If fstat = 1  : # enreg locké
  GLOCK = "$DADEMP32" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
Commit
Effzo
OK = 0 :# pour ne pas passer dans la suppression standard
Return

###################################
$ROLL_ANN
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto VERF_ANU : Endif

###################################
$AB_ANN
Rollback
Return

###################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

######################################################################################
## Etiquettes écran
######################################################################################
Subprog IB_NBRDP2
If ![M]NBRDP2
 GBOUT1=""
Else
 GBOUT1="Périodes"
Endif
End

Subprog B1_NBRDP2
Local Char MATRI (GLONEML)
Local Char CLE2 (250)
MATRI=[M:DAP1]EMPDDS
CLE2=[M:DAP1]YEAEMPDDS+"~"+[M:DAP1]CTRNUM+"~"+num$([M:DAP1]ETRDAT)+"~"+num$([M:DAP1]TYPDAE)+"~"+[M:DAP1]REFCTR+"~"+num$([M]STRDATCTR(nolign-1))
Call OBJET_CHAR(MATRI,"HRDPP",CLE2) From GOBJET
Gosub CHARGE_PERIODE
Affzo [M:DAP1]20
End


Subprog C_EVECTRDAT(VALEUR)
Variable Date    VALEUR
#La date doit être comprise dans la période d'activité S41
If VALEUR<[M]ETRDAT | VALEUR>[M]XITDAT
 #Valeur non autorisée
 GMESSAGE=mess(100,10703,1)
 mkstat=2 : End
Endif
End
