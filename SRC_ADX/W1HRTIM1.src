#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRTIM1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:47"
A_USER  = "DOC"
A_STAMP = "20181109230447"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRTIM1 [HRTIM1]
Gosub HORODAT
Local Inpbox "HRTIM1" From GFONCTION At A_STAMP With A_WINDPREV Mask [HRTIM1] As [SIM_]
Grizo [HRTIM1]5
Grizo [HRTIM1]10
Grizo [HRTIM1]15
Grizo [HRTIM1]30
Grizo [HRTIM1]40
Grizo [HRTIM1]50
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [HRTIM1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=36 : Y1(0)=1 : Y2(0)=25
X1(1)=37 : X2(1)=81 : Y1(1)=1 : Y2(1)=9
X1(2)=37 : X2(2)=81 : Y1(2)=10 : Y2(2)=19
X1(3)=82 : X2(3)=103 : Y1(3)=10 : Y2(3)=19
X1(4)=37 : X2(4)=81 : Y1(4)=20 : Y2(4)=25
X1(5)=1 : X2(5)=36 : Y1(5)=26 : Y2(5)=28
Return

$ON_DAYDAC
Onevent AFTER_CHANGE Gosub AMM_DAYDAC From W1HRTIM1
Onevent INIT_AREA Call D_DAYDAC(zc) From W1HRTIM1
Onevent BEFORE_INPUT Call AS_DAYDAC(zc) From W1HRTIM1
Return

Subprog D_DAYDAC(VALEUR)
Variable Integer VALEUR
If varinit([M]DAYDAC,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_DAYDAC(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_DAYDAC
Call AM_DAYDAC(zc)
If !mkstat & GOBJET
 zoncou = "DAYDAC" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DAYDAC(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_DAYDAC(VALEUR) From SUBHRTIM
If mkstat : GERR = 1 : GZONE = "DAYDAC" : GZNUM = 436 : Endif
Gosub _AFF
End

