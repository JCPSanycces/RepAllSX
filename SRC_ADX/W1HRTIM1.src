Onevent CONTROL Call C_CODDDS(zc) From W1HRTIM1
Onevent BEFORE_INPUT Call AS_CODDDS(zc) From W1HRTIM1
Onevent AFTER_CHANGE Gosub AMM_CODDDS From W1HRTIM1
Return

Subprog D_CODDDS(VALEUR)
Variable Char    VALEUR()
If varinit([M]CODDDS,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10344","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_CODDDS(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"10344") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CODDDS(zc) From W1HRTIM1
Onkey   2 Titled GBOUTS Call S_CODDDS(zc) From W1HRTIM1
Onkey 144 Titled GBOUTP Call P_CODDDS(zc) From W1HRTIM1
Onkey 146 Titled GBOUTA Call SA_CODDDS(zc) From W1HRTIM1
Gosub _AFF
End

Subprog C_CODDDS(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"10344","") From SUBADI
If mkstat : GERR = 1 : GZONE = "CODDDS" : GZNUM = 16531 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"10344",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CODDDS" : GZNUM = 16531 : Endif
Endif
Gosub _AFF
End

$AMM_CODDDS
Call AM_CODDDS(zc)
If !mkstat & GOBJET
 zoncou = "CODDDS" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CODDDS(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCODDDS)")>indice
 [M]CODDDS(indice) = VALEUR
 Affzo ZCODDDS(indice)
Endif
Gosub _AFF
End

Subprog S_CODDDS(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "10344"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CODDDS(VALEUR)
