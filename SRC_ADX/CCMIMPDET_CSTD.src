#<AdxTL>@(#)0.0.0.0 $Revision$
# Class CCMIMPDET - this is a common script used on all detail impact analysis

$METHODS
  Case CURPTH
    When ""
      Case ACTION
        When "VALIDATE_LINE" : Gosub VALIDATE_LINE
        When "AUPDATE_CONTROL_AFTER"
          Gosub VALIDATE
      Endcase
  Endcase
Return

# Validate plan line, check Action ID, Actioner, and Complete date are valid
$VALIDATE
  Local Integer LOCSTATUS
  LOCSTATUS = fmet this.VALIDATE_LINE()
  If (LOCSTATUS = CST_AFALSE)
        ASTATUS = fmet this.ASETERROR ("", mess(57,2038,1), CST_AERROR)
  Endif

Return


# --------------------------------------------------
# Custom Method: Check the Planning properties are populated ...
$VALIDATE_LINE
  ARET_VALUE = CST_AFALSE
  If (this.ACTIONID = "" and this.ACTIONER = "" and this.COMPLETEDATE = AVOID.ADATE)
    ARET_VALUE = CST_ATRUE
  Elsif (this.ACTIONID <> "" and this.ACTIONER <> "" and this.COMPLETEDATE <> AVOID.ADATE)
     ARET_VALUE = CST_ATRUE
  Endif

Return

# --------------------------------------------------

$PROPERTIES

  Local Char PROPERTYACTION(50)
  PROPERTYACTION = CURPRO +"." +ACTION

  Case PROPERTYACTION
    When "LINESTATUS.PROPAGATE"
      Gosub UPDATE_START_END_DATES
  Endcase

Return

# --------------------------------------------------
# Update Action START and END dates,
# If Line Status is 1 (Pending) then reset Start and End dates,
# If Line Status is 2 (In-progress) then set Start date to today's date and reset End date,
# If Line Status is 3 (Completed) then set Start date to today's date (if not set) and End date to today's date ...
$UPDATE_START_END_DATES

  If (this.LINESTATUS = 1)
    this.STARTDATE = AVOID.ADATE
    this.ENDDATE   = AVOID.ADATE
  Elsif (this.LINESTATUS = 2)
    this.STARTDATE = date$
    this.ENDDATE = AVOID.ADATE
  Else
    If (this.STARTDATE = AVOID.ADATE)
      this.STARTDATE = date$
    Endif
    this.ENDDATE = date$
  Endif

Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

