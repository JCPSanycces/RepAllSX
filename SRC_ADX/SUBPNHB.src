#<AdxTL>@(#)12.0.0.0 $Revision$
#############################################################################
# SUBPNHB : Gestion des retours d'achat                        MBT 02/12/99 #
# ------------------------------------------------------------------------- #
# Traitements complémentaires de l'objet "PNH"                              #
# Les traitements sur champ "Call"     se trouvent dans le SUBPNH           #
# Les actions "Gosub" de l'objet "PNH" se trouvent dans le SUBPNHA          #
# ------------------------------------------------------------------------- #
# Les étiquettes appelées par Gosub                                         #
#   - PICKE_RCP         : Sélection par picking d'une ligne de réception    #
#   - DEPICK_RCP        : Désélection par picking d'une ligne de réception  #
#   - TEST_MAXLIN       : Test si tableau arrivé au maxi + chargement NOL   #
#   - CAL_QTEMAX        : Calcul qté maxi à retourner en US                 #
#   - PREP_INIT_CCE     : Préparation des sections analytiques              #
#   - INIT_COMPTES_LIGNE: Récupération compte, nature et type d'achat       #
#   - APRES_STOSOR      : Appelé en fin d'action SAISTOSOR                  #
# Les sous-programmes appelés par Call                                      #
#   - CHARG_LIG_RET     : Chargement d'une ligne de réception               #
# ------------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Saisie de fenêtre GSAISIE)                      #
#   - SAIPNHCOM    : Fenêtre de saisie des compléments                      #
#############################################################################


$ACTION
##################################################################
# Actions sur la saisie de fenêtre (GSAISIE)                     #
# -------------------------------------------------------------- #
# SAIPNHCOM  : Fenêtre de saisie des compléments                 #
##################################################################
Case ACTION
 When "OUVRE"
  #--------------------------------------------------------------#
  # Avant la définition des boutons et l'ouverture de la fenêtre #
  #--------------------------------------------------------------#
  Case GACTION
  Endcase
 When "TITRE"
  #-------------------------------------------#
  # Titre juste avant ouverture de la fenêtre #
  #-------------------------------------------#
  Case GACTION
   When "SAIPNHCOM"  : TIT=mess(47,195,1)
  Endcase
 When "DEBUT"
  #---------------------------------#
  # Après l'ouverture de la fenêtre #
  #---------------------------------#
  Case GACTION
   When "SAIPNHCOM"  : Gosub DEB_SAIPNHCOM
  Endcase
 When "OK"
  #--------------------------------#
  # Après l'exécution du bouton OK #
  #--------------------------------#
  Case GACTION
   When "SAIPNHCOM"  : Gosub OK_SAIPNHCOM
  Endcase
 When "ABA"
  #-------------------------------------#
  # Après l'exécution du bouton ABANDON #
  #-------------------------------------#
  Case GACTION
   When "SAIPNHCOM"  : Gosub ABA_SAIPNHCOM
  Endcase
 When "APRES_MODIF"
  #------------------------------------#
  # Après chaque modification de champ #
  #------------------------------------#
  Case GACTION
   When "SAIPNHCOM"  : REP="M"
  Endcase
 When "SETBOUT"
  #-------------------------------------#
  # Avant grisage/dégrisage des boutons #
  #-------------------------------------#
  Case GACTION
  Endcase
 When "FINSAI"
  #------------------------------------------#
  # Avant de revenir à la fenêtre précédente #
  #------------------------------------------#
  Case GACTION
  Endcase
 When Default
Endcase
Return


###########################################################
# SAIPNHCOM : Saisie des compléments retours fournisseurs #
# ------------------------------------------------------- #
# Pas de paramètre                                        #
###########################################################
#-----------------------------------------------------#
# Après l'ouverture de la fenêtre compléments retours #
#-----------------------------------------------------#
$DEB_SAIPNHCOM
Local Libelle FLGSAI : FLGSAI=1
[M:PNH2]=[M:PNHC]
#----- Si modif non autorisée, désactivation de la saisie par grisage -----#
If GCONSULT>0
  Diszo [PNH2]1-99 : Raz FLGSAI
Elsif GREP<>"C"
  GBIDC2="M" : Gosub AUTORIS_OPT From CONTX3
  If !GBIDI2 | !GPNH_VERROU  Diszo [PNH2]1-99 : Raz FLGSAI : Endif
  # FGR 18/07/2014 : X3SUIVI91606 (début)
  If FLGSAI <> 1 Then
    FLGSAI = 1      # Seul ce bloc est saisissable.
    Actzo [PNH2]13
  Endif
  # FGR 18/07/2014 : X3SUIVI91606 (fin)
Endif

# BRBAN 29/11/2014 SAM #93745
Gosub PNH_ADD_MNG From PORLEGLIB

Affzo [PNH2]1-99
Return
#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK_SAIPNHCOM
If FLGSAI<>0  [M:PNHC]=[M:PNH2] : Endif
FIN=1
Return
#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
$ABA_SAIPNHCOM
[M:PNH2]=[M:PNHC] : Raz REP
Affzo [PNH2]1-99
Return


#------------------------------------#
# Sélection d'une ligne de réception #
#------------------------------------#
$PICKE_RCP
WNUM=[F:PTD]PTHNUM : WLIN=[F:PTD]PTDLIN
Read [PTD] PTD0=WNUM;WLIN     : If fstat Raz [F:PTD] : Endif
Read [PTH] PTH0=[F:PTD]PTHNUM : If fstat Raz [F:PTH] : Endif
Read [FCY] FCY0=[F:PTD]PRHFCY : If fstat Raz [F:FCY] : Endif
Read [ITM] ITM0=[F:PTD]ITMREF : If fstat Raz [F:ITM] : Endif
If [F:PTH]PTHNUM="" & [F:FCY]FCY="" & [F:ITM]ITMREF=""
  Call RSTA("XPTD",WNUM-num$(WLIN)) From GLOCK
  OK=0 : Return
Endif
If !evalue(FILGAUSUP)  OK=0 : Return : Endif
If [F:PTD]LINTYP=2
  Gosub TEST_MAXLIN_SST
Else
  Gosub TEST_MAXLIN
Endif
If mkstat OK=0 : Return : Endif
#----- Vérif qu'il n'y a pas déjà un retour non validé sur cette ligne réception -----#
Raz WINDICE
For [PNX] Where [F:PNDB]PNHNUM<>[M:PNH1]PNHNUM
&             & [F:PNDB]PTHNUM=[F:PTD]PTHNUM
&             & [F:PNDB]PTDLIN=[F:PTD]PTDLIN
&             & [F:PNHB]CFMFLG=1
  WINDICE=1 : Break
Next
If WINDICE =1
  OK=0 : GMESSAGE=mess(211,194,1) : GERR=1 : Return
Endif

# Issue 71069 - 2013-08-23 by MUARN : PJT
#Code affaire à la ligne (Partie : rajout paramètre société pour contrôle documents mono-affaire)
#--Contrôles sur le code affaire de la commande à l'origine du bon de préparation
If [M:PNH1]NBLIG<1 & [M:PNH1]PJTH = "" & GPJTSNGDOC = 2
   [M:PNH1]PJTH = [F:PTD]PJT
   If func TRTPJT.IS_PJT_AVAILABLE([F:PTD]PJT, "[M:PNH1]PJTH", SWPJTMSG) = G_NON Then
      Call PJT_ADD_MSG([F:PTD]PJT, SWPJTMSG) From TRTPJT
      OK = 0 : GERR = 1
      GMESSAGE = SWPJTMSG
      Raz [M:PNH1]PJTH
      Return
   Endif
   Affzo [PNH1]PJTH
Else
   If func TRTPJT.IS_PJT_AVAILABLE([F:PTD]PJT, "[M:PNH1]PJT", SWPJTMSG) = G_NON Then
      Call PJT_ADD_MSG([F:PTD]PJT, SWPJTMSG) From TRTPJT
      OK = 0 : GERR = 1
      GMESSAGE = SWPJTMSG
      Return
   Endif
Endif

#----- Si qté maxi à retourner nulle alors pas de prise en compte -----#
[M:PNH1]ITMREF(NOL)=[F:PTD]ITMREF
[M:PNH1]PTHNUM(NOL)=[F:PTD]PTHNUM
[M:PNH1]PTDLIN(NOL)=[F:PTD]PTDLIN
Gosub CAL_QTEMAX
If [M:PNH1]MAXQTYSTU(NOL)=0
  Raz [M:PNH1]ITMREF(NOL), [M:PNH1]PTHNUM(NOL), [M:PNH1]PTDLIN(NOL)
  OK=0 : GMESSAGE=mess(197,194,1) : GERR=1 : Return
Endif
#----- Lecture article si nécessaire -----#
If [F:ITM]ITMREF<>[F:PTD]ITMREF
  Read [ITM] ITM0=[F:PTD]ITMREF
  If fstat Raz [F:ITM] : Endif
Endif
#------- Test si même fournisseur -----#
If [M:PNH1]BPSNUM="" | [M:PNH1]BPSNUM<>[M:PCRW]WBPSNUM
  WPICK=9
  [M:PNH1]BPSNUM=[F:PTH]BPSNUM
  Call AM_BPSNUM([M:PNH1]BPSNUM) From SUBPNH : # Chargement zones fournisseur
  Affzo [PNH1]5,10
Elsif [F:PTH]BPSNUM<>[M:PNH1]BPSNUM
  OK=0 : GMESSAGE=mess(195,194,1)-[M:PNH1]BPSNUM : GERR=1 : Return
Endif
#----- Particularité pour sous-traitance -----#
If [F:PTD]LINTYP=2
  WLIN   =[F:PTD]PTDLIN
  WVCRTYPORI=[F:PTD]VCRTYPORI
  WVCRNUMORI=[F:PTD]VCRNUMORI
  Raz OK
  For [PTD] PTD0 Where PTHNUM   =WNUM
&                    & PTDLIN  >=WLIN
&                    & VCRTYPORI=WVCRTYPORI
&                    & VCRNUMORI=WVCRNUMORI
    If [F:PTD]LINTYP<3 & OK  Break : Endif
    If [F:PTD]LINTYP=2
      WQTYSTU=[M:PNH1]MAXQTYSTU(NOL)
      OK=1
    Else
      Gosub TEST_MAXLIN : If mkstat  Break : Endif
      Read [FCY] FCY0=[F:PTD]PRHFCY : If fstat Raz [F:FCY] : Endif
      Read [ITM] ITM0=[F:PTD]ITMREF : If fstat Raz [F:ITM] : Endif
      [M:PNH1]ITMREF(NOL)=[F:PTD]ITMREF
      [M:PNH1]PTHNUM(NOL)=[F:PTD]PTHNUM
      [M:PNH1]PTDLIN(NOL)=[F:PTD]PTDLIN
      #If [F:PTD]LIKQTYCOE<>0
      #  [M:PNH1]MAXQTYSTU(NOL)=WQTYSTU*[F:PTD]LIKQTYCOE : # Calcul qté à partir du produit fini !
      #  Call QTEARR([M:PNH1]MAXQTYSTU(NOL),[F:PTD]STU) From TRTDIV
      #Else
      #  [M:PNH1]MAXQTYSTU(NOL)=[F:PTD]QTYPUU
      #Endif
      Gosub CAL_QTEMAX
    Endif
    Call CHARG_LIG_RET(NOL,[M:PNH1]NBLIG) From SUBPNHB
    If !mkstat
      status=0 : nolign=NOL+1 : Call LINNUM("PNDLIN") From TABLEAUX
      [M:PNH1]NBLIG+=1 : Call APRES_NBLIG From SUBPNH
      If [M:PNH1]LINTYP(NOL)=2
        Gosub DETAIL_STOCK
      Else
        [M:PNH1]WSTOFLG(NOL)=2 : # Pas géré en stock, jamais de saisie détail
      Endif
    Else
      Break
    Endif
  Next
  OK=1
#----- Lignes classiques (autres que sous-traitance) -----#
Else
  Call CHARG_LIG_RET(NOL,[M:PNH1]NBLIG) From SUBPNHB
  If !mkstat
    status=0 : nolign=NOL+1 : Call LINNUM("PNDLIN") From TABLEAUX
    [M:PNH1]NBLIG+=1 : Call APRES_NBLIG From SUBPNH
    Gosub DETAIL_STOCK
  Endif
Endif
If mkstat  OK=0 : Return : Endif
Return


#-------------------------------------------------------------------#
# Réf.article en rouge si nécessité de préciser le détail du retour #
#-------------------------------------------------------------------#
$DETAIL_STOCK
If [F:PTD]STOMGTCOD>1
  #----- Relecture transaction si nécessaire -----#
  If [F:PTR]PTRTYP<>7 | [F:PTR]PTRNUM<>GPTRNUM
    Read [PTR] PTR0=7;GPTRNUM : If fstat Raz [F:PTR] : Endif
  Endif
  #-----
  Call OUVSOR ("PNH1",NOL,[M:PNH1]NBLIG,[M:PNH1]WSTOSEQ(NOL),[F:PTR]STKFLG,WRET) From STKSOR
  If WRET=0
    [M:PNH1]WSTOFLG(NOL)=1 : # Détail stock OK !
    [M:PNH1]QTYSTUACT(NOL)=sigma(I=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTUACT(I)*
&                                ([M:SOW]WSTOSEQ(I)=[M:PNH1]WSTOSEQ(NOL)))
  Else
    [M:PNH1]WSTOFLG(NOL)=0 : # Nécessité de saisir manuellement le détail stock
    [M:PNH1]QTYSTUACT(NOL)=[M:PNH1]QTYSTU(NOL)
  Endif
Else
  [M:PNH1]WSTOFLG(NOL)=2   : # Pas géré en stock, jamais de saisie détail
Endif
Return


#--------------------------------------#
# Déselection d'une ligne de réception #
#--------------------------------------#
$DEPICK_RCP
WNUM=[F:PTD]PTHNUM : WLIN=[F:PTD]PTDLIN
Read [PTD] PTD0=WNUM;WLIN     : If fstat Raz [F:PTD] : Endif
Read [PTH] PTH0=[F:PTD]PTHNUM : If fstat Raz [F:PTH] : Endif
Read [FCY] FCY0=[F:POQ]POHFCY : If fstat Raz [F:FCY] : Endif
Read [ITM] ITM0=[F:PTD]ITMREF : If fstat Raz [F:ITM] : Endif
If [F:PTH]PTHNUM="" & [F:FCY]FCY="" & [F:ITM]ITMREF=""
  Call RSTA("XPTD",WNUM-num$(WLIN)) From GLOCK
  OK=0 : Return
Endif
#----- Particularité pour sous-traitance -----#
If [F:PTD]LINTYP=2
  WVCRTYPORI=[F:PTD]VCRTYPORI
  WVCRNUMORI=[F:PTD]VCRNUMORI
  Raz OK
  For [PTD] PTD0 Where PTHNUM   =WNUM
&                    & PTDLIN  >=WLIN
&                    & VCRTYPORI=WVCRTYPORI
&                    & VCRNUMORI=WVCRNUMORI
    If [F:PTD]LINTYP<3 & OK  Break : Endif
    If [F:PTD]LINTYP=2   OK=1      : Endif
    Gosub RECHSUP_LIG_RCP : # Recherche et suppression ligne
  Next
  OK=1
#----- Lignes classiques (autres que sous-traitance) -----#
Else
  Gosub RECHSUP_LIG_RCP   : # Recherche et suppression ligne
Endif
Return


#--------------------------------------------------------------#
# Recherche et suppression de la ligne de réception "dépickée" #
#--------------------------------------------------------------#
$RECHSUP_LIG_RCP
Raz J
While J<[M:PNH1]NBLIG
  K=find([F:PTD]PTHNUM,[M:PNH1]PTHNUM(J..[M:PNH1]NBLIG-1))
  I=J+(K-1)
  If K=0
    J=[M:PNH1]NBLIG
  Elsif [M:PNH1]PTDLIN(I)=[F:PTD]PTDLIN : # & [M:PNH1]CREFLG(I)=0
    nolign=I+1 : status=65
    Call AVANT_NBLIG From SUBPNH
    #----- Nettoyage de l'écran de travail STOSORW -----#
    If [M:PNH1]STOMGTCOD(I)>1 & [M:PNH1]LINTYP(I)<3
      Call DELSTOSORW(I,I,"PNH1",[M:PNH1]PNHFCY,WRET) From STKSOR
    Endif
    #-----
    Dela I,1,[M:PNH1]NBLIG-1 [M:PNH1]NBLIG : [M:PNH1]NBLIG-=1
    J+=K : K=0
  Else
    J+=K : K=0
  Endif
Wend
Return


#----------------------------------------------#
# Test si tableau des lignes arrivé au maximum #
#----------------------------------------------#
$TEST_MAXLIN
GBIDI2=2 : Gosub TRT_MAXLIN
Return
#----- Prévoir 3 lignes de plus pour la sous-traitance -----#
$TEST_MAXLIN_SST
GBIDI2=5 : Gosub TRT_MAXLIN
Return
#-----
$TRT_MAXLIN
Raz mkstat
If [M:PNH1]NBLIG>dim([M:PNH1]ITMREF)-GBIDI2
  GMESSAGE=mess(26,100,1) : GERR=1
  mkstat=1 : Return
Endif
NOL=[M:PNH1]NBLIG : nolign=NOL+1
status=73 : Call INSERE("PNDLIN") From TABLEAUX
Return


###################################################################
# CHARG_LIG_RET : S/P chargement d'une ligne de retour            #
#                 calcul de la quantité à retourner               #
# --------------------------------------------------------------- #
# Subprog CHARG_LIG_RET (NOL,NBMAX)                               #
#    NOL    : Numéro de la ligne en cours (nolign-1)              #
#    NBMAX  : Nombre de lignes déja présentes dans le tableau     #
#                                                                 #
# Attention : Les champs ITMREF(NOL), PTHNUM(NOL), PTDLIN(NOL)    #
#                        doivent être préalablement chargés       #
###################################################################
Subprog CHARG_LIG_RET (NOL,NBMAX)
Value Shortint NOL
Value Shortint NBMAX
#------ Variables locales ------#
Local Char     VAT(GLONVAT)(3)
Local Integer I, J, WRET
#----- Si retour directe -----#
If [M:PNH1]PTHNUM(NOL)=""
  Call INIZONSOR("PNH1",[M:PNH1]ITMREF(NOL),[M:PNH1]PNHFCY,NOL,11,[M:PNH1]TRSCOD,"") From STKECR
  If mkstat  End : Endif
Else
  If [F:ITM]ITMREF<>[M:PNH1]ITMREF(NOL)
    Read [ITM] ITM0=[M:PNH1]ITMREF(NOL) : If fstat  Raz [F:ITM] : Endif
  Endif
  If [F:ITM]STOMGTCOD>1
    [M:PNH1]WSTOSAI(NOL)="00000000000"
  Else
    [M:PNH1]WSTOSAI(NOL)="00022222222"
  Endif
Endif
#----- Lecture du BPARTNER si nécessaire-----#
If [F:BPR]BPRNUM<>[M:PNH1]BPSNUM
  Read [BPR] BPR0=[M:PNH1]BPSNUM
  If fstat  Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
Endif
#----- Lecture du BPSUPPLIER si nécessaire-----#
If [F:BPS]BPSNUM<>[M:PNH1]BPSNUM
  Read [BPS] BPS0=[M:PNH1]BPSNUM
  If fstat  Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
Endif
#----- Lecture article si nécessaire (il doit être déjà lu par le INIZONSOR) -----#
If [F:ITM]ITMREF<>[M:PNH1]ITMREF(NOL)
  Read [ITM] ITM0=[M:PNH1]ITMREF(NOL) : If fstat  Raz [F:ITM] : Endif
Endif
#----- Lecture article-fournisseur si nécessaire -----#
If [F:ITP]ITMREF<>[M:PNH1]ITMREF(NOL) | [F:ITP]BPSNUM<>[M:PNH1]BPSNUM
  Read [ITP] ITP0=[M:PNH1]ITMREF(NOL);[M:PNH1]BPSNUM
  If fstat  Raz [F:ITP] : Endif
Endif
#----- Lecture article-site si nécessaire -----#
If [F:ITF]ITMREF<>[M:PNH1]ITMREF(NOL) | [F:ITF]STOFCY<>[M:PNH1]PNHFCY
  Read [ITF] ITF0=[M:PNH1]ITMREF(NOL);[M:PNH1]PNHFCY
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
#----- Initialisation de l'emplacement par défaut -----#
If [F:ITF]STOMGTCOD>1 & dim([M:PNH1]LOC)>0
  Call STKINIEMPS([M:PNH1]LOC(NOL)) From STKLOC
Endif
#----- Récupération des valeurs de la réception -----#
If [M:PNH1]PTHNUM(NOL)<>""
  #----- Lecture entête et ligne de réception si nécessaire -----#
  If [F:PTH]PTHNUM<>[M:PNH1]PTHNUM(NOL)
    Read [PTH] PTH0=[M:PNH1]PTHNUM(NOL)
    If fstat  Raz [F:PTH] : Endif
  Endif
  If [F:PTD]PTHNUM<>[M:PNH1]PTHNUM(NOL) | [F:PTD]PTDLIN<>[M:PNH1]PTDLIN(NOL)
    Read [PTD] PTD0=[M:PNH1]PTHNUM(NOL);[M:PNH1]PTDLIN(NOL)
    If fstat  Raz [F:PTD] : Endif
  Endif
  #-----
  If [F:PTH]BETFCY=2 & [F:PTD]SDHNUM<>""
    [M:PNH1]BPSNDE(NOL)=[F:PTD]SDHNUM : # Si inter-sites récup no livraison
  Else
    [M:PNH1]BPSNDE(NOL)=[F:PTH]BPSNDE : # Autrement no BL fou de l'entête réception
  Endif
  # Issue 71069 - 2016-06-14 by MUARN : PJT entête
  # Issue 71069-53 - 2016-08-25 by MUARN : import PJT
  If ([M:PNH1]NBLIG = 0 & GPJTSNGDOC = 1) | (GIMPORT & [M:PNH1]NBLIG=1  & GPJTSNGDOC = 1)
    [M:PNH1]PJTH = [F:PTH]PJTH
    If !GIMPORT : Affzo [M:PNH1]PJTH : Endif
  Endif
  #----- Récupération des valeurs de la ligne de réception par transclasse -----#
  nolign=NOL+1 : [M:PNH1]=[F:PTD]
  #----- Ne pas reprendre les quantités facturées de la ligne de réception -----#
  Raz [M:PNH1]INVQTYPUU(NOL), [M:PNH1]INVQTYSTU(NOL) : # Bug 71110
  #----- Chargement comptes et sections analytiques -----#
  Call CHARG_ACCCCE(NOL,"[M:PNH1]LINACC","","[M:PNH1]CCE","PTD",0,
&                        [F:PTD]PTHNUM,[F:PTD]PTDLIN,0,"") From TRTX3CPT
  #----- Récupération des familles statistiques article -----#
  If dim([M:PNH1]TSICOD1(NOL))>0 [M:PNH1]TSICOD1(NOL)=[F:PTD]TSICOD(0) : Endif
  If dim([M:PNH1]TSICOD2(NOL))>0 [M:PNH1]TSICOD2(NOL)=[F:PTD]TSICOD(1) : Endif
  If dim([M:PNH1]TSICOD3(NOL))>0 [M:PNH1]TSICOD3(NOL)=[F:PTD]TSICOD(2) : Endif
  If dim([M:PNH1]TSICOD4(NOL))>0 [M:PNH1]TSICOD4(NOL)=[F:PTD]TSICOD(3) : Endif
  If dim([M:PNH1]TSICOD5(NOL))>0 [M:PNH1]TSICOD5(NOL)=[F:PTD]TSICOD(4) : Endif
  #----- Récupération des codes taxe -----#
  [M:PNH1]VAT1(NOL)=[F:PTD]VAT(0)
  [M:PNH1]VAT2(NOL)=[F:PTD]VAT(1)
  [M:PNH1]VAT3(NOL)=[F:PTD]VAT(2)
  #----- Vérif si coefficient UC-US bien renseigné -----#
  If [M:PNH1]UOMSTUCOE(NOL)=0
    If [M:PNH1]QTYUOM(NOL)<>0 & [M:PNH1]QTYSTU(NOL)<>0
      [M:PNH1]UOMSTUCOE(NOL)=arr([M:PNH1]QTYSTU(NOL)/[M:PNH1]QTYUOM(NOL),10^-6)
    Else
      Call PCAL_QTY([M:PNH1]QTYUOM(NOL),[M:PNH1]UOM(NOL),GBIDD1,[M:PNH1]STU(NOL),
&           [M:PNH1]ITMREF(NOL),[M:PNH1]BPSNUM,1,[M:PNH1]UOMSTUCOE(NOL)) From TRTACHQTE1
    Endif
  Endif
  #-----
  If [M:PNH1]ORICRY(NOL)=""  [M:PNH1]ORICRY(NOL)=[F:BPR]CRY : Endif
  If [F:PTD]LININVFLG=2 [M:PNH1]AVOFLG(NOL)=2 Else [M:PNH1]AVOFLG(NOL)=1 : Endif
  If [F:PTD]SDHNUM<>""
    [M:PNH1]LINAUTFLG(NOL)=2
  Else
    [M:PNH1]LINAUTFLG(NOL)=1
  Endif
  #-----
  If [M:PNH1]LINCAT(NOL)=2
    Call INIZONSOR("PNH1",[M:PNH1]ITMREF(NOL),[M:PNH1]PNHFCY,NOL,32,[M:PNH1]TRSCOD,"") From STKECR
  Elsif [M:PNH1]LINTYP(NOL)<3
    Call INIZONSOR("PNH1",[M:PNH1]ITMREF(NOL),[M:PNH1]PNHFCY,NOL,11,[M:PNH1]TRSCOD,"") From STKECR
  Endif
  #----- Chargement des infos complémentaires à partir de la réception -----#
  If [M:PNH1]NBLIG=0 | !sigma(J=0,[M:PNH1]NBLIG-1,([M:PNH1]PTHNUM(J)<>"" & J<>NOL))
    #----- Ecran complément -----#
    [M:PNHC]BPTNUM=[F:PTH]BPTNUM
    [M:PNHC]MDL   =[F:PTH]MDL
    [M:PNHC]BPSINV=[F:PTH]BPSINV
    [M:PNHC]BPAINV=[F:PTH]BPAINV
    [M:PNHC]BPRPAY=[F:PTH]BPRPAY
    [M:PNHC]BPAPAY=[F:PTH]BPAPAY
    #----- Ecran informations douanières -----#
    [M:PCEY]EECICT=[F:PTH]EECICT    : # Incoterm
    [M:PCEY]ICTCTY=[F:PTH]ICTCTY    : # Ville incoterm
    [M:PCEY]FFWNUM=[F:PTH]FFWNUM    : # Transitaire
    [M:PCEY]FFWADD=[F:PTH]FFWADD    : # Adresse transitaire
    If GACTDEB=2
      [M:PCEY]EECLOC=[F:PTH]EECLOC  : # Lieu de transport CEE
      [M:PCEY]EECTRN=[F:PTH]EECTRN  : # Mode de transport CEE
      [M:PCEY]EECNUM=[F:PTH]EECNUM  : # Identification CEE
    Endif
    #----- Chargement des sections analytiques entête -----#
    # Issue 90239 - 2013-06-03 by SR
    If dim([M:PNH1]DIE)>0
      For I=1 To max(GNBDIE,GOPTCANA)
        J=find([F:PTH]DIE(I-1),[M:PNH1]DIE)
        If J & [F:PTH]CCE(I-1)<>""  [M:PNH1]CCE(J-1)=[F:PTH]CCE(I-1) : Endif
      Next I
    Endif
    #-----
  Endif
#----- Chargement des valeurs dans le cas d'un retour direct -----#
Else
  [M:PNH1]LINTYP(NOL)=1
  [M:PNH1]LINCAT(NOL)=1
  [M:PNH1]LINAUTFLG(NOL)=1
  Raz [M:PNH1]PTDLIN(NOL), [M:PNH1]BPSNDE(NOL)
  # Issue 112754 - 2016-12-05 by SR : Services
  [M:PNH1]ITMKND(NOL) = 1
  If [F:ITM]SCSFLG = 2 : [M:PNH1]ITMKND(NOL) = 3 : Endif
  # End issue 112754
  #----- Chargement des familles statistiques de l'article -----#
  If dim([M:PNH1]TSICOD1(NOL))>0 [M:PNH1]TSICOD1(NOL)=[F:ITM]TSICOD(0) : Endif
  If dim([M:PNH1]TSICOD2(NOL))>0 [M:PNH1]TSICOD2(NOL)=[F:ITM]TSICOD(1) : Endif
  If dim([M:PNH1]TSICOD3(NOL))>0 [M:PNH1]TSICOD3(NOL)=[F:ITM]TSICOD(2) : Endif
  If dim([M:PNH1]TSICOD4(NOL))>0 [M:PNH1]TSICOD4(NOL)=[F:ITM]TSICOD(3) : Endif
  If dim([M:PNH1]TSICOD5(NOL))>0 [M:PNH1]TSICOD5(NOL)=[F:ITM]TSICOD(4) : Endif
  #----- Chargement des codes taxe -----#
  Call ALIVATCOD(2,[M:PNH1]BPSNUM,[M:PNH1]ITMREF(NOL),"PNH1",NOL) From TRTX3
  #----- Chargement unités et coefficients -----#
  [M:PNH1]STU(NOL)=[F:ITM]STU
  If [F:ITP]ITMREF=[M:PNH1]ITMREF(NOL) & [F:ITP]BPSNUM=[M:PNH1]BPSNUM
    [M:PNH1]UOM(NOL)      =[F:ITP]PUU
    [M:PNH1]PUU(NOL)      =[F:ITP]PUU
    [M:PNH1]UOMSTUCOE(NOL)=[F:ITP]PUUSTUCOE
    [M:PNH1]UOMPUUCOE(NOL)=1
  Else
    [M:PNH1]UOM(NOL)      =[F:ITM]PUU
    [M:PNH1]PUU(NOL)      =[F:ITM]PUU
    [M:PNH1]UOMSTUCOE(NOL)=[F:ITM]PUUSTUCOE
    [M:PNH1]UOMPUUCOE(NOL)=1
  Endif
  #-----
  [M:PNH1]AVOFLG(NOL)=1
  [M:PNH1]NETCUR(NOL)=GCUR
  [M:PNH1]ORICRY(NOL)=[F:BPR]CRY
  #----- Chargement coefficient majoration pour DEB -----#
  If GACTDEB=2
    If [F:BPS]BPSNUM<>[M:PNH1]BPSNUM
      Read [BPS] BPS0=[M:PNH1]BPSNUM : If fstat  Raz [F:BPS] : Endif
    Endif
    If [F:ITP]ITMREF<>[M:PNH1]ITMREF(NOL) | [F:ITP]BPSNUM<>[M:PNH1]BPSNUM
      Read [ITP] ITP0=[M:PNH1]ITMREF(NOL);[M:PNH1]BPSNUM : If fstat  Raz [F:ITP] : Endif
    Endif
    If [F:ITP]EECINCRAT<>0
      [M:PNH1]EECINCRAT(NOL)=[F:ITP]EECINCRAT
    Else
      [M:PNH1]EECINCRAT(NOL)=[F:BPS]EECINCRAT
    Endif
  Endif
  #----- Chargement du site d'expédition si retour direct inter-sites -----#
  If [M:PNH1]BETFCY=2
    [M:PNH1]LINSTOFCY(NOL)=GSTOFCY
    #----- Si article géré en stock, l'article-site d'expédition doit exister -----#
    If [F:ITF]STOMGTCOD>1
      If [M:PNH1]LINSTOFCY(NOL)<>""
        Read [ITF] ITF0=[M:PNH1]ITMREF(NOL);[M:PNH1]LINSTOFCY(NOL)
        If fstat  Raz [F:ITF], [M:PNH1]LINSTOFCY(NOL) : Endif
      Endif
      #----- Le site d'expédition n'a pas été trouvé -----#
      If [M:PNH1]LINSTOFCY(NOL)=""
        #----- Recherche à partir des article-sites -----#
        If [M:PNH1]BETCPY<>2
          Filter [ITFY] Where [F:ITF]ITMREF=[M:PNH1]ITMREF(NOL)
&                           & [F:FCY]LEGCPY=GSOCIETE
&                           & [F:FCY]FCY  <>[M:PNH1]PNHFCY
        Else
          Filter [ITFY] Where [F:ITF]ITMREF=[M:PNH1]ITMREF(NOL)
&                           & [F:FCY]LEGCPY=GCPY
&                           & [F:FCY]FCY  <>[M:PNH1]PNHFCY
        Endif
        Read [ITFY] ITF0 First
        If !fstat  [M:PNH1]LINSTOFCY(NOL)=[F:FCY]FCY  Else  Raz [F:ITF], [F:FCY] : Endif
        Filter [ITFY]
      Endif
    Endif
  Endif
  #----- Alimentation de la province de sortie et du pays expéditeur -----#
  If [M:PNH1]POHNUM(NOL)<>""
    If [F:POH]POHNUM<>[M:PNH1]POHNUM(NOL)
      Read [POH] POH0=[M:PNH1]POHNUM(NOL) : If fstat  Raz [F:POH] : Endif
    Endif
    #----- Récupération type de commande -----#
    [M:PNH1]POHTYP(NOL)=[F:POH]POHTYP
    #-----
    If [F:POH]BPOCRY<>"" | [F:POH]BPOCTY<>""
      If dim([M:PNH1]SATISS)>0  [M:PNH1]SATISS(NOL)=[F:POH]BPOSAT : Endif
      [M:PNH1]BPOCRY(NOL)=[F:POH]BPOCRY
    Else
      #----- Lecture de l'adresse d'expédition si nécessaire -----#
      If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:POH]BPSNUM | [F:BPA]BPAADD<>[F:POH]BPOADD
        Read [BPA] BPA0=1;[F:POH]BPSNUM;[F:POH]BPOADD
        If fstat  Raz [F:BPA] : Endif
      Endif
      #-----
      If dim([M:PNH1]SATISS)>0  [M:PNH1]SATISS(NOL)=[F:BPA]SAT : Endif
      [M:PNH1]BPOCRY(NOL)=[F:BPA]CRY
    Endif
  Else
    #----- Lecture de l'adresse d'expédition si nécessaire -----#
    If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[M:PNH1]BPSNUM | [F:BPA]BPAADD<>[F:BPS]BPAADD
      Read [BPA] BPA0=1;[M:PNH1]BPSNUM;[F:BPS]BPAADD
      If fstat  Raz [F:BPA] : Endif
    Endif
    #-----
    If dim([M:PNH1]SATISS)>0  [M:PNH1]SATISS(NOL)=[F:BPA]SAT : Endif
    [M:PNH1]BPOCRY(NOL)=[F:BPA]CRY
  Endif
Endif
#----- Chargement des désignations article si nécessaire -----#
If [M:PNH1]ITMDES(NOL)=""
  #Call CHARGE_ITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,[M:PNH1]ITMDES(NOL)) From TRTX3
  #If [M:PNH1]ITMDES(NOL)="" [M:PNH1]ITMDES(NOL)=[F:ITM]ITMDES1 : Endif
  Call CHARGE_DEFITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,[M:PNH1]ITMDES(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
Endif
If [M:PNH1]ITMDES1(NOL)=""
  #[M:PNH1]ITMDES1(NOL)=[F:ITM]ITMDES1
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PNH1]ITMDES1(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
Endif
#----- Récupération des valeurs de l'article -----#
If [M:PNH1]LINTYP(NOL)<>3
  If [M:PNHC]WEU=""  [M:PNHC]WEU=[F:ITM]WEU : Endif
  [M:PNH1]WEU(NOL)      =[F:ITM]WEU
  [M:PNH1]UNTWEI(NOL)   =[F:ITM]ITMWEI*[M:PNH1]UOMSTUCOE(NOL)
  Call QTEARR ([M:PNH1]UNTWEI(NOL),[M:PNH1]WEU(NOL)) From TRTDIV
Else
  Raz [M:PNH1]WEU(NOL), [M:PNH1]UNTWEI(NOL)
Endif
#----- Chargement autres zones -----#
[M:PNH1]STOMGTCOD(NOL)=[F:ITF]STOMGTCOD
[M:PNH1]BPSNAM=[F:BPR]BPRNAM
If [M:PNH1]UOM(NOL)=[M:PNH1]PUU(NOL)
  [M:PNH1]UOMFLG(NOL)=1
Else
  [M:PNH1]UOMFLG(NOL)=2
Endif
[M:PNH1]ORDFLG(NOL)=1
Raz [M:PNH1]LINTEX(NOL)
#----- Calcul qtés maxi -----#
If [M:PNH1]MAXQTYSTU(NOL)=0 Gosub CAL_QTEMAX : Endif
#----- Initialisation des quantités -----#
If [M:PNH1]PTHNUM(NOL)<>""
  [M:PNH1]QTYSTU(NOL)=[M:PNH1]MAXQTYSTU(NOL)
Else
  [M:PNH1]QTYSTU(NOL)=0
Endif
Call PCAL_QTY([M:PNH1]QTYSTU(NOL),[M:PNH1]STU(NOL),[M:PNH1]QTYPUU(NOL),[M:PNH1]PUU(NOL),
&             [M:PNH1]ITMREF(NOL),[M:PNH1]BPSNUM,1,GBIDD3) From TRTACHQTE1
[M:PNH1]QTYUOM(NOL)=[M:PNH1]QTYSTU(NOL)/[M:PNH1]UOMSTUCOE(NOL)
Call QTEARR([M:PNH1]QTYUOM(NOL),[M:PNH1]UOM(NOL)) From TRTDIV
#----- Recherche tarif si nécessaire -----#
If [M:PNH1]PTHNUM(NOL)="" | ([M:PNH1]GROPRI(NOL)=0 & [M:PNH1]PRIREN(NOL)=0 & [M:PNH1]NETPRI(NOL)=0)
  Call INI_TARIF(NOL) From SUBPNH
Endif
#----- Initialisation comptes, type d'achat et sections analytiques si nécessaire -----#
If [M:PNH1]LINACC1(NOL)="" & [M:PNH1]LINACC2(NOL)="" & [M:PNH1]LINACC3(NOL)=""
  Call INIT_COMPTES_LIGNE(NOL)
Endif
If [M:PNH1]LINPURTYP(NOL)=0
  Call D_LINPURTYP([M:PNH1]LINPURTYP(NOL)) From SUBPNH
Endif
# Issue 90239 - 2013-06-03 by SR
If dim([M:PNH1]DIE)>0
  GBIDI2=0 : Gosub PREP_INIT_CCE
Endif
#----- Vérification si coefficient UC-US est modifiable -----#
Call CTLUOM([M:PNH1]ITMREF(NOL),1,[M:PNH1]BPSNUM,[M:PNH1]UOM(NOL),GBIDD1,
&            GBIDC2,GBIDC3,GBIDI2) From STKACT
If mkstat  Raz mkstat : GBIDI2=1 : Endif
If GBIDI2=1
  Diszo [PNH1]UOMSTUCOE(NOL)
  [M:PNH1]WSTOSAI(NOL)=left$([M:PNH1]WSTOSAI(NOL),2)+"2"+right$([M:PNH1]WSTOSAI(NOL),4)
Else
  Actzo [PNH1]UOMSTUCOE(NOL)
  [M:PNH1]WSTOSAI(NOL)=left$([M:PNH1]WSTOSAI(NOL),2)+"0"+right$([M:PNH1]WSTOSAI(NOL),4)
Endif
#----- Affichage de la ligne -----#
Affzo [PNH1]ITMDES(NOL), ITMDES1(NOL), BPSNDE(NOL), RTNREN(NOL), UOM(NOL), QTYUOM(NOL),
&           PUU(NOL), UOMSTUCOE(NOL), STU(NOL), QTYSTU(NOL), STA(NOL)
If dim([M:PNH1]LOC)    >0  Affzo [PNH1]LOC(NOL)     : Endif
If dim([M:PNH1]BPSLOT) >0  Affzo [PNH1]BPSLOT(NOL)  : Endif
If dim([M:PNH1]LOT)    >0  Affzo [PNH1]LOT(NOL)     : Endif
If dim([M:PNH1]SLO)    >0  Affzo [PNH1]SLO(NOL)     : Endif
If dim([M:PNH1]SERNUM) >0  Affzo [PNH1]SERNUM(NOL)  : Endif
If dim([M:PNH1]SERNUMF)>0  Affzo [PNH1]SERNUMF(NOL) : Endif
# GA 09/2006 LINACC(NOL), LINCNA(NOL),  remplacées par AFFICH_LINACC From SUBPNH

# Issue 82411 - 2012-05-25 by MUARN : famille mouvement selon transaction
If [F:PTR]PTRTYP<>7 | [F:PTR]PTRNUM<>GPTRNUM : # Relecture transaction si nécessaire
   Read [PTR] PTR0=7;GPTRNUM : If fstat Raz [F:PTR] : Endif
Endif
[M:PNH1]TRSFAM(NOL)=[F:PTR]TRSFAMDEF
# Issue 112754 - 2016-12-05 by SR : Services
Affzo [PNH1]MVTDES(NOL), ORDFLG(NOL), AVOFLG(NOL), POHFCY(NOL), POPLIN(NOL), PJT(NOL),
&           GROPRI(NOL), NETPRI(NOL), LINAMT(NOL), NETCUR(NOL),
&           LINPURTYP(NOL), TRSFAM(NOL), VAT1(NOL), VAT2(NOL), VAT3(NOL), WEU(NOL),
&           UNTWEI(NOL),ORICRY(NOL), ITMKND(NOL)
Gosub AFFICH_LINACC From SUBPNH
If GACTDEB=2  Affzo [PNH1]EECINCRAT(NOL) : Endif
#----- Lecture des mvts de stock et stockage dans écran STOSORW -----#
# Issue 82340 - 2012-08-30 by SR :en Import on ne le fait que si les mvt de stock ne sont pas importés
If (!GIMPORT | GPNH_STJ <> 2) & ([F:ITF]STOMGTCOD>1 & [M:PNH1]LINTYP(NOL)<3)
  WRET=0 : Gosub CHARG_ALLPAR From SUBPNH
  Call STJSTOSORW ("PNH1",NOL,[M:PNH1]NBLIG,WRET) From STKSOR
  If WRET  mkstat=1 : End : Endif
Endif
#-----
[M:PNH1]PREQTYPUU(NOL)=[M:PNH1]QTYPUU(NOL)
#----- Si pas picking et article sous-traité, chargement du service et matières fournies -----#
If !GPNH_PICK & [M:PNH1]LINTYP(NOL)=2  Gosub CHARG_LIG_SUPPLEMENT From SUBPNHB : Endif
End


#--------------------------------------------------------#
#         Calcul quantités maximum à retourner           #
# ------------------------------------------------------ #
# [M:PNH1]MAXQTYSTU(NOL) : Qté maximum à retourner en US #
# Si l'article est géré en stock tout est "retournable"  #
#    par défaut, c'est la règle de gestion qui indiquera #
#    ce qui peut réellement être retourné et la quantité #
#    réellement disponible de l'article-site             #
# Si l'article n'est pas géré en stock la quantité       #
#    "retournable" est fonction du paramètre PRTNQTY     #
#     (1=qtés en A, 2=qtés en A+R).                      #
# Nota : La qté "retournable" c'est la qté réceptionnée  #
#    diminuée de la quantité déjà retournée.             #
#--------------------------------------------------------#
$CAL_QTEMAX
Raz [M:PNH1]MAXQTYSTU(NOL)
#----- Lecture article si nécessaire -----#
If [F:ITM]ITMREF<>[M:PNH1]ITMREF(NOL)
  Read [ITM] ITM0=[M:PNH1]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
Endif
#----- Lecture article-site si nécessaire -----#
If [F:ITF]ITMREF<>[M:PNH1]ITMREF(NOL) | [F:ITF]STOFCY<>[M:PNH1]PNHFCY
  Read [ITF] ITF0=[M:PNH1]ITMREF(NOL);[M:PNH1]PNHFCY
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
#-----
[M:PNH1]STOMGTCOD(NOL)=[F:ITF]STOMGTCOD
#----- Lecture ligne réception sur laquelle porte le retour si nécessaire -----#
If [M:PNH1]PTHNUM(NOL)<>""
  If [M:PNH1]PTHNUM(NOL)<>[F:PTD]PTHNUM | [M:PNH1]PTDLIN(NOL)<>[F:PTD]PTDLIN
    Read [PTD] PTD0=[M:PNH1]PTHNUM(NOL);[M:PNH1]PTDLIN(NOL)
    If fstat Raz [F:PTD] : Endif
  Endif
  If [M:PNH1]STOMGTCOD(NOL)<2
    #--- Issue 93230 by TS
    #If GPRTNQTY=2
    If GPRTNQTY=2 | [F:PTD]LINTYP>2
    #---
      [M:PNH1]MAXQTYSTU(NOL)=[F:PTD]QTYSTU-[F:PTD]RTNQTYSTU
    Else
      [M:PNH1]MAXQTYSTU(NOL)=[F:PTD]RRRQTYSTU-[F:PTD]RTNQTYSTU
    Endif
  Else
    [M:PNH1]MAXQTYSTU(NOL)=[F:PTD]QTYSTU-[F:PTD]RTNQTYSTU
  Endif
Elsif [M:PNH1]STOMGTCOD(NOL)>1
  If [F:ITV]ITMREF<>[M:PNH1]ITMREF(NOL) | [F:ITV]STOFCY<>[M:PNH1]PNHFCY
    Read [ITV] ITV0=[M:PNH1]ITMREF(NOL);[M:PNH1]PNHFCY
    If fstat  Raz [F:ITV] : Endif
  Endif
  Call STODISTOT ("",1,[F:SRU]AUZSTA,"",[M:PNH1]MAXQTYSTU(NOL)) From STKLIB
  #--- Bug 81051 : si la ligne existe déjà, il faut ajouter la quantité
  # déjà alloué au disponible (normalement tout est alloué, pas de rupture)
  If [M:PNH1]CREFLG(nolign-1)<>0
     [M:PNH1]MAXQTYSTU(NOL) += [M:PNH1]QTYSTU(NOL)
  Endif
  #---
Else
  [M:PNH1]MAXQTYSTU(NOL)=99999999999.999
Endif
#-----
If [M:PNH1]MAXQTYSTU(NOL)<0  Raz [M:PNH1]MAXQTYSTU(NOL) : Endif
Return


########################################################################
# INIT_COMPTES_LIGNE : S/P d'initialisation               MBT 14/09/06 #
#                des comptes d'une ligne de commande                   #
# -------------------------------------------------------------------- #
# Subprog INIT_COMPTES_LIGNE (NOL)                                     #
#   NOL    : Indice de la ligne de commande à traiter (nolign-1)       #
########################################################################
Subprog INIT_COMPTES_LIGNE (NOL)
Value    Shortint NOL
#-----
Local    Shortint I
#----- Chargement de comptes avec "" pour désactiver l'action d'init -----#
For I=1 To 10
  If evalue("dim([M:PNH1]LINACC"+num$(I)+")")>0
    Assign "[M:PNH1]LINACC"+num$(I)+"(NOL)" With ""
  Endif
Next I
#----- Si ligne vide, pas la peine d'initialiser ! -----#
If [M:PNH1]ITMREF(NOL)=""  End : Endif
#-----
Local    Char     ID1(20)(1..1), ID2(20)(1..3)
Local    Shortint J, LIG, SAVNOLIGN : SAVNOLIGN=nolign
Local    Integer  STA
Local    Char     TPLAN  (GLONCOA)(1..10)
Local    Char     TCOMPTE(GLONGAC)(1..10)
Local    Char     WMESSAGE(80)
#-----
If !clalev([F:GAD])  Local File GAUTACED [GAD] : Endif
Local File PORDER [TB0], PORDERQ [TB1], CPTANALIN [TB2]
nolign=NOL+1
#-----
[F:TB0]=[M:PNH1]
[F:TB0]INVFCY=GFINRSP : # Prendre site financier de la société comme site facturation
[F:TB1]=[M:PNH1]
For I=0 To dim([F:TB0]INVDTALIN1)-1 : [F:TB0]INVDTALIN1(I)=GINVDTALIN(I) : Next I
If [F:TB1]LINPURTYP=0  [F:TB1]LINPURTYP=1 : Endif
#----- Chargement table liée PORDERP pour la pièce auto PORD -----#
If !GIMPORT
  [F:POP]=[M:PNH1]
  [F:POP]VAT(0)=[M:PNH1]VAT1(NOL)
  [F:POP]VAT(1)=[M:PNH1]VAT2(NOL)
  [F:POP]VAT(2)=[M:PNH1]VAT3(NOL)
Endif
#----- Chargement pseudo fichier lignes comptables CPTANALIN [TB2] -----#
Raz [F:TB2]
[F:TB2]ABRFIC="POP"
[F:TB2]VCRNUM=[M:PNH1]POHNUM(NOL)
[F:TB2]VCRLIN=[M:PNH1]POPLIN(NOL)
[F:TB2]VCRSEQ=[M:PNH1]POQSEQ(NOL)
[F:TB2]ANALIG=1
For I=1 To max(GNBCOA,2)
  J=GTYPLED(I)
  If J
    [F:TB2]LED(J-1)=GLEDSOC(I)
    [F:TB2]COA(J-1)=GCOA(I)
    [F:TB2]ACC(J-1)=evalue("[M:PNH1]LINACC"+num$(I)+"(NOL)")
  Endif
Next I
For I=1 To max(GNBDIE,GOPTCANA)
  [F:TB2]DIE(I-1)=GDIE(I)
  If evalue("dim([M:PNH1]CCE"+num$(I)+")")>0
    [F:TB2]CCE(I-1)=evalue("[M:PNH1]CCE"+num$(I)+"(NOL)")
  Endif
Next I
#-----
ID1(1)=[M:PNH1]POHNUM(NOL)
ID2(1)=[M:PNH1]POHNUM(NOL)
ID2(2)=num$([M:PNH1]POPLIN(NOL))
ID2(3)=num$([M:PNH1]POQSEQ(NOL))
If [M:PNH1]POHNUM(NOL)=""  Raz ID1,ID2 : Endif
#-----
Call COMPTE("PORD",1,ID1,ID2,TPLAN,TCOMPTE,STA,WMESSAGE) From TRTACHCDE1
If STA
  Raz TPLAN, TCOMPTE
Else
  For I=1 To 10
    If TPLAN(I)<>""
     #J=find(TPLAN(I),GCOA(1..GNBCOA))
      J=find([F:GAD]LEDTYP(I-1),GTYPLED(1..GNBTYPLED))
      If J
        Assign "[M:PNH1]LINACC"+num$(J)+"(NOL)" With TCOMPTE(I)
      Endif
    Endif
  Next I
Endif
#-----
Close Local File [TB0], [TB1], [TB2]
nolign=SAVNOLIGN
End


$PREP_INIT_CCE
#-----------------------------------------------------------------------------#
# Préparation des sections analytiques                                        #
# --------------------------------------------------------------------------- #
# Si l'axe est suivi en analytique et que la section correspondante est vide  #
#    il faut forcer l'initialisation grâce au Raz                             #
# Si l'axe n'est pas suivi en analytique                                      #
#    il faut "mettre  à blanc" la section correspondante                      #
# --------------------------------------------------------------------------- #
# NOL contient l'indice de la ligne en cours                                  #
# [M:PNH1]LINACC1-10(NOL) contient les comptes                                #
# GBIDI2 : 0 = Pas d'affichage des sections analytiques                       #
#          1 = Affichage des sections analytiques                             #
#-----------------------------------------------------------------------------#
If dim(I)<1    Local Integer I             : Endif
If dim(WCCE)<1 Local Char    WCCE(GLONCCE) : Endif
#----- Pas de section si pas de suivi analytique sur l'axe concerné -----#
For I=1 To GNBDIE
  WCCE=evalue("[M:PNH1]CCE"+num$(I)+"(NOL)")
  Raz mkstat
  Call SAIS_CCE(WCCE,I,"[M:PNH1]LINACC","") From TRTX3CPT
  If mkstat
    Assign "[M:PNH1]CCE"+num$(I)+"(NOL)" With ""
    Raz mkstat
  Elsif evalue("[M:PNH1]CCE"+num$(I)+"(NOL)")=""
    #----- Raz pour forcer l'initialisation -----#
    Case I
      When  1 : Raz [M:PNH1]CCE1 (NOL)
      When  2 : Raz [M:PNH1]CCE2 (NOL)
      When  3 : Raz [M:PNH1]CCE3 (NOL)
      When  4 : Raz [M:PNH1]CCE4 (NOL)
      When  5 : Raz [M:PNH1]CCE5 (NOL)
      When  6 : Raz [M:PNH1]CCE6 (NOL)
      When  7 : Raz [M:PNH1]CCE7 (NOL)
      When  8 : Raz [M:PNH1]CCE8 (NOL)
      When  9 : Raz [M:PNH1]CCE9 (NOL)
      When 10 : Raz [M:PNH1]CCE10(NOL)
      When 11 : Raz [M:PNH1]CCE11(NOL)
      When 12 : Raz [M:PNH1]CCE12(NOL)
      When 13 : Raz [M:PNH1]CCE13(NOL)
      When 14 : Raz [M:PNH1]CCE14(NOL)
      When 15 : Raz [M:PNH1]CCE15(NOL)
      When 16 : Raz [M:PNH1]CCE16(NOL)
      When 17 : Raz [M:PNH1]CCE17(NOL)
      When 18 : Raz [M:PNH1]CCE18(NOL)
      When 19 : Raz [M:PNH1]CCE19(NOL)
      When 20 : Raz [M:PNH1]CCE20(NOL)
    Endcase
  Endif
Next I
#----- Affichage des sections analytiques -----#
If GBIDI2=1
  Gosub AFFICH_CCE From SUBPNH
Endif
Return


#------------------------------------------------------------------#
#                 Appelé en début d'action SAISTOSOR               #
# ---------------------------------------------------------------- #
# Chargement du masque STOSOR [SOR] Bloc 1 et 2                    #
#                                                                  #
# Alimenter : WSTOSEQ     Lien avec ligne de document              #
#             TRSTYP      Type mouvement                           #
#             TRSCOD      Code mouvement                           #
#             TRFFCY      Site destination (si trf inter-sites)    #
#             VCRTYP      Type de pièce (8=Retours fournisseurs)   #
#             VCRNUM      Numéro pièce                             #
#             VCRLIN      Numéro ligne pièce                       #
#             MVTDES      Désignation du mouvement                 #
#             STU         Unité stock                              #
#             PCU         Unité pièce (conditionnement)            #
#             PCUSTUCOE   Coef UC-US                               #
#             SORQTY      Quantité à sortir                        #
#             SORQTYACT   Quantité à sortir (UA)                   #
#             RETDAT      Date du besoin                           #
#             DLVDAT      Date de livraison                        #
#             PECINTLOC   Prise en compte emp interne              #
#             PECPLFLOC   Prise en compte emp attente de rangement #
#                         (M1) Normalement, mettre à 2             #
#             PECSCOLOC   Prise en compte emp sous-traitant        #
#                         Mettre à 2 si suivi OF                   #
#             STOLOC      Emplacement poste de charge              #
#                         A renseigner si suivi OF                 #
#             XLOT        Lot du filtre allocation (exclusif)      #
#             XLOC        Emplacement du filtre allocation         #
#                         (préférentiel par ligne de règle d'alloc)#
#             XSTA        Statuts du filtre allocation (exclusif)  #
#                         sous la forme "A1*,A20"                  #
#             GLOALLQTY   Mettre 0 (qté allouée en global)         #
#             PECOWNER    Filtre propriétaire du stock             #
#--- Issue 110327
#             VCRTYPORI      Type de pièce origine (6=Réception)   #
#             VCRNUMORI      Numéro pièce origine                  #
#             VCRLINORI      Numéro ligne pièce origine            #
#---
#------------------------------------------------------------------#
# ATTENTION: voir aussi CHARG_ALLPAR (SUBPNH) et INIZONSOR         #
#------------------------------------------------------------------#
$CHARGE_STOSOR

#----- Relecture transaction si nécessaire -----#
If [F:PTR]PTRTYP<>7 | [F:PTR]PTRNUM<>GPTRNUM
  Read [PTR] PTR0=7;GPTRNUM : If fstat Raz [F:PTR] : Endif
Endif
[M:SOR]CCECODS   = GSTODIE
#-----
[M:SOR]WSTOSEQ   = [M:PNH1]WSTOSEQ(LNOL)
If dim([M:PNH1]LINCAT)>0 & [M:PNH1]LINCAT(LNOL)= 2 : # GA 09/2006
   [M:SOR]TRSTYP = 32                : # Type mouvement (M.704): retour matière pour sous-traitance
   [M:SOR]PECOWNER = [M:PNH1]LINSTOFCY(LNOL)  : # Site propriétaire du stock
Else
   [M:SOR]TRSTYP = 11
Endif
[M:SOR]TRSCOD    = [M:PNH1]TRSCOD
[M:SOR]BPRNUM    = [M:PNH1]BPSNUM
[M:SOR]CUR       = [M:PNH1]NETCUR(LNOL)
If [M:PNH1]BETFCY=2
  [M:SOR]TRFFCY = [M:PNH1]LINSTOFCY(LNOL)
  [M:SOR]BETCPY = [M:PNH1]BETCPY
Else
  [M:SOR]TRFFCY = ""
  [M:SOR]BETCPY = 1
Endif
[M:SOR]VCRTYP    = 8
[M:SOR]VCRNUM    = [M:PNH1]PNHNUM
[M:SOR]VCRLIN    = [M:PNH1]PNDLIN(LNOL)
#--- Issue 110327
If [M:PNH1]PTHNUM(LNOL)<>""
  [M:SOR]VCRTYPORI = 6
  [M:SOR]VCRNUMORI = [M:PNH1]PTHNUM(LNOL)
  [M:SOR]VCRLINORI = [M:PNH1]PTDLIN(LNOL)
Endif
#---
[M:SOR]MVTDES    = [M:PNH1]MVTDES(LNOL)
[M:SOR]STU       = [M:PNH1]STU(LNOL)
[M:SOR]PCU       = [M:PNH1]UOM(LNOL)
[M:SOR]PCUSTUCOE = [M:PNH1]UOMSTUCOE(LNOL)
[M:SOR]SORQTY    = [M:PNH1]QTYSTU(LNOL)
[M:SOR]SORQTYACT = [M:PNH1]QTYSTU(LNOL)
[M:SOR]RETDAT    = [M:PNH1]RTNDAT
[M:SOR]DLVDAT    = [M:PNH1]RTNDAT
[M:SOR]PECINTLOC = 2
[M:SOR]PECPLFLOC = 2
[M:SOR]PECSCOLOC = 1
[M:SOR]STOLOC    = ""
[M:SOR]XLOT      = ""
[M:SOR]XLOC      = ""
[M:SOR]XSTA      = ""
[M:SOR]PECQLYCTL = 1
[M:SOR]GLOALLQTY = 0
If dim([M:PNH1]WRH)>0 [M:SOR]XWRH=[M:PNH1]WRH(LNOL) Endif
#----- Traitement particulier pour la qté en unité active -----#
If [F:ITM]ITMREF<>[M:PNH1]ITMREF(LNOL)
  Read [ITM] ITM0=[M:PNH1]ITMREF(LNOL) : If fstat  Raz [F:ITM] : Endif
Endif
If find([M:PNH1]STOMGTCOD(LNOL),3,4)
  If sum([M:SOR]QTYSTU)=[M:SOR]SORQTY
    [M:SOR]SORQTYACT=sum([M:SOR]QTYSTUACT)
  Else
    If sum([M:SOR]QTYSTU)<[M:SOR]SORQTY
      [M:SOR]SORQTYACT=sum([M:SOR]QTYSTUACT)
      Case [M:PNH1]STOMGTCOD(LNOL)
        When 3 : [M:SOR]SORQTYACT+=([M:SOR]SORQTY-sum([M:SOR]QTYSTU))*[F:ITM]DEFPOT/100
        When 4 : [M:SOR]SORQTYACT+=([M:SOR]SORQTY-sum([M:SOR]QTYSTU))*[F:ITM]DEFACT
      Endcase
    Else
      Case [M:PNH1]STOMGTCOD(NOL)
        When 3 : [M:SOR]SORQTYACT =[M:SOR]SORQTY*[F:ITM]DEFPOT/100
        When 4 : [M:SOR]SORQTYACT =[M:SOR]SORQTY*[F:ITM]DEFACT
      Endcase
    Endif
  Endif
Endif
[M:PNH1]QTYSTUACT(LNOL)=[M:SOR]SORQTYACT
Return


#------------------------------------------------------------------#
#                  Appelé en fin d'action SAISTOSOR                #
# ---------------------------------------------------------------- #
# LNOL indice de la ligne en cours                                 #
# WGENR=1 si on a enregistré la saisie du détail stock             #
# La classe écran [M:SOR] est en ligne                             #
#   [M:SOR]NBLIG     contient le nombre de ligne de stock traité   #
#   [M:SOR]SORQTY    contient la quantité US qui était à sortir    #
#   [M:SOR]SORQTYACT contient la quantité en UA qui était à sortir #
#   [M:SOR]PECQTY    contient la quantité US sortie                #
#   [M:SOR]PECQTYACT contient la quantité en UA sortie             #
#   [M:SOR]SHTQTY    contient la quantité US sortie manquante      #
#------------------------------------------------------------------#
$APRES_STOSOR
If WGENR<>1  : Affzo [PNH1]ITMREF(LNOL) : Return : Endif
If [M:PNH1]QTYSTU(LNOL)<>[M:SOR]PECQTY+[M:SOR]SHTQTY
  #----- Calcul et affichage des quantités en UC et UA -----#
  [M:PNH1]QTYSTUACT(LNOL)=[M:SOR]PECQTYACT
  [M:PNH1]QTYSTU(LNOL)=[M:SOR]PECQTY+[M:SOR]SHTQTY
  [M:PNH1]QTYUOM(LNOL)=[M:PNH1]QTYSTU(LNOL)/[M:PNH1]UOMSTUCOE(LNOL)
  Call QTEARR([M:PNH1]QTYUOM(LNOL),[M:PNH1]UOM(LNOL)) From TRTDIV
  [M:PNH1]QTYPUU(LNOL)=[M:PNH1]QTYUOM(LNOL)*[M:PNH1]UOMPUUCOE(LNOL)
  Call QTEARR([M:PNH1]QTYPUU(LNOL),[M:PNH1]PUU(LNOL)) From TRTDIV
  Affzo [PNH1]QTYUOM(LNOL), QTYPUU(LNOL)
  Affzo [PNH1]QTYSTU(LNOL) # Issue 81918 - 2012-05-23 by MUARN : ligne retour à 0
  #----- Calcul et affichage du montant ligne si nécessaire -----#
  If [M:PNH1]NETPRI(LNOL)<>0
    [M:PNH1]LINAMT(LNOL)=[M:PNH1]NETPRI(LNOL)*[M:PNH1]QTYUOM(LNOL)
    Call ARRDEV([M:PNH1]LINAMT(LNOL),[M:PNH1]NETCUR(LNOL)) From TRTDIV
    Affzo [PNH1]LINAMT(LNOL)
  Endif
Endif
[M:PNH1]WSTOFLG(LNOL)=1
#-----
If [M:PNH1]LINTYP(LNOL)=2
  Call CALCUL_COMPOSANTS(LNOL) From SUBPNHB
  Affzo [PNH1]15
Else
  Affzo [PNH1]ITMREF(LNOL), STA(LNOL)
  If dim([M:PNH1]LOC)    >0  Affzo [PNH1]LOC(LNOL)     : Endif
  If dim([M:PNH1]BPSLOT) >0  Affzo [PNH1]BPSLOT(LNOL)  : Endif
  If dim([M:PNH1]LOT)    >0  Affzo [PNH1]LOT(LNOL)     : Endif
  If dim([M:PNH1]SLO)    >0  Affzo [PNH1]SLO(LNOL)     : Endif
  If dim([M:PNH1]SERNUM) >0  Affzo [PNH1]SERNUM(LNOL)  : Endif
  If dim([M:PNH1]SERNUMF)>0  Affzo [PNH1]SERNUMF(LNOL) : Endif
  Affzo [PNH1]MVTDES(LNOL)
Endif
Return


$CHARGE_STOSOM
#------------------------------------------------------------------#
# Chargement paramètres dans masque STOSOM pour modif des sorties  #
# Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOSOMA  #
#------------------------------------------------------------------#
# ATTENTION: voir aussi CHARG_ALLPAR (SUBPNH) et INIZONSOR         #
#------------------------------------------------------------------#
If dim([M:PNH1]LINCAT)>0 & [M:PNH1]LINCAT(LNOL)= 2 : # GA 09/2006
   [M:SOM]TRSTYP = 32                : # Type mouvement (M.704): retour matière pour sous-traitance
   [M:SOM]PECOWNER = [M:PNH1]LINSTOFCY(LNOL)  : # Site propriétaire du stock
Else
   [M:SOM]TRSTYP = 11
Endif
[M:SOM]TRSCOD   = [M:PNH1]TRSCOD
If [M:PNH1]BETFCY=2
  [M:SOM]TRFFCY = [M:PNH1]LINSTOFCY(LNOL)
  [M:SOM]BETCPY = [M:PNH1]BETCPY
Else
   [M:SOM]TRFFCY = ""
   [M:SOM]BETCPY = 1
Endif
[M:SOM]VCRTYP    = 8
[M:SOM]VCRNUM    = [M:PNH1]PNHNUM
[M:SOM]VCRLIN    = [M:PNH1]PNDLIN(LNOL)
#--- Issue 110327
If [M:PNH1]PTHNUM(LNOL)<>""
  [M:SOM]VCRTYPORI = 6
  [M:SOM]VCRNUMORI = [M:PNH1]PTHNUM(LNOL)
  [M:SOM]VCRLINORI = [M:PNH1]PTDLIN(LNOL)
Endif
#---
[M:SOM]STU       = [M:PNH1]STU(LNOL)
[M:SOM]PCU       = [M:PNH1]UOM(LNOL)
[M:SOM]PCUSTUCOE = [M:PNH1]UOMSTUCOE(LNOL)
[M:SOM]SORQTY    = [M:PNH1]QTYSTU(LNOL)
[M:SOM]SORQTYACT = [M:PNH1]QTYSTU(LNOL)
[M:SOM]DLVDAT    = [M:PNH1]RTNDAT
[M:SOM]PECINTLOC = 2
[M:SOM]PECPLFLOC = 2
[M:SOM]PECSCOLOC = 1
[M:SOM]PECQLYCTL = 1
[M:SOM]STOLOC    = ""
[M:SOM]XLOT      = ""
[M:SOM]XLOC      = ""
[M:SOM]XSTA      = ""
If dim([M:PNH1]WRH)>0 [M:SOM]XWRH=[M:PNH1]WRH(LNOL) Endif
#----- Traitement particulier pour la qté en unité active -----#
If [F:ITM]ITMREF<>[M:PNH1]ITMREF(LNOL)
  Read [ITM] ITM0=[M:PNH1]ITMREF(LNOL) : If fstat  Raz [F:ITM] : Endif
Endif
If find([M:PNH1]STOMGTCOD(LNOL),3,4)
  Case [M:PNH1]STOMGTCOD(LNOL)
    When 3 : [M:SOM]SORQTYACT =[M:SOM]SORQTY*[F:ITM]DEFPOT/100
    When 4 : [M:SOM]SORQTYACT =[M:SOM]SORQTY*[F:ITM]DEFACT
  Endcase
Endif
[M:PNH1]QTYSTUACT(LNOL)=[M:SOM]SORQTYACT
Return


$APRES_STOSOM
#------------------------------------------------------------------#
# Mise à jour complémentaires après enregistrement                 #
# - Recalcul des quantités sorties US, UC de la ligne de document  #
# - Réalimentation des zones dépendant de la quantité, etc ...     #
#                                                                  #
#   [M:SOM]NBLIG     contient le nombre de ligne de stock traité   #
#   [M:SOM]SORQTY    contient la quantité US qui était à sortir    #
#   [M:SOM]SORQTYACT contient la quantité en UA qui était à sortir #
#   [M:SOM]PECQTY    contient la quantité US sortie                #
#   [M:SOM]PECQTYACT contient la quantité en UA sortie             #
#   [M:SOM]SHTQTY    contient la quantité manquante                #
#------------------------------------------------------------------#
If WGENR<>1  Return : Endif
#----- Désactivé car contrôle effectué dans le composant de modif des sorties -----#
#If [M:SOM]SORQTY<>[M:SOM]PECQTY
#  GMESSAGE=mess(23,184,1) : GERR=1 : GOK=0 : Return : # Modif qté totale interdite !
#Endif
Return


#---------------------------------------------------------------------#
# Chargement lignes service et matières fournies par le sous-traitant #
#---------------------------------------------------------------------#
$CHARG_LIG_SUPPLEMENT
Local  Char     WNUM(GLONVCR), WVCRNUMORI(GLONVCR)
Local  Integer  WLIN, WVCRTYPORI, SAVNOLIGN, SAVNBLIG
#-----
SAVNBLIG =[M:PNH1]NBLIG
SAVNOLIGN=nolign
#-----
If [F:PTD]PTHNUM<>[M:PNH1]PTHNUM(NOL) |
&  [F:PTD]PTDLIN<>[M:PNH1]PTDLIN(NOL)
  Read [PTD] PTD0=[M:PNH1]PTHNUM(NOL);[M:PNH1]PTDLIN(NOL)
  If fstat  Call ERREUR(mess(384,194,1)) From GESECRAN : Return : Endif
Endif
#-----
WNUM      =[F:PTD]PTHNUM
WLIN      =[F:PTD]PTDLIN
WVCRTYPORI=[F:PTD]VCRTYPORI
WVCRNUMORI=[F:PTD]VCRNUMORI
#-----
Raz [M:PNH1]NBCRELIG
For [PTD] PTD0 Where PTHNUM   =WNUM
&                  & PTDLIN   >WLIN
&                  & VCRTYPORI=WVCRTYPORI
&                  & VCRNUMORI=WVCRNUMORI
  If [F:PTD]LINTYP<2  Break : Endif
  nolign+=1 : NOL+=1
  status=73 : Call INSERE("PNDLIN") From TABLEAUX  : If mkstat  Break : Endif
  If dim([M:PNH1]ITMREF)<[M:PNH1]NBLIG+2  mkstat=1 : Break : Endif
  Insa NOL,1,[M:PNH1]NBLIG [M:PNH1]NBLIG : [M:PNH1]NBLIG+=1
  [M:PNH1]NBCRELIG+=1
  [M:PNH1]PTHNUM(NOL)=[F:PTD]PTHNUM
  [M:PNH1]PTDLIN(NOL)=[F:PTD]PTDLIN
  [M:PNH1]ITMREF(NOL)=[F:PTD]ITMREF
  Read [FCY] FCY0=[F:PTD]PRHFCY : If fstat Raz [F:FCY] : Endif
  Read [ITM] ITM0=[F:PTD]ITMREF : If fstat Raz [F:ITM] : Endif
  #If [F:PTD]LIKQTYCOE<>0
  #  [M:PNH1]MAXQTYSTU(NOL)=[M:PNH1]MAXQTYSTU(SAVNOLIGN-1)*[F:PTD]LIKQTYCOE
  #  Call QTEARR([M:PNH1]MAXQTYSTU(NOL),[F:PTD]STU) From TRTDIV
  #Else
  #  [M:PNH1]MAXQTYSTU(NOL)=[F:PTD]QTYPUU
  #Endif
  Gosub CAL_QTEMAX
  Call CHARG_LIG_RET(NOL,[M:PNH1]NBLIG) From SUBPNHB
  If !mkstat
    status=0 : nolign=NOL+1 : Call LINNUM("PNDLIN") From TABLEAUX
    [M:PNH1]NBLIG+=1 : Call APRES_NBLIG From SUBPNH
    [M:PNH1]WSTOFLG(NOL)=2 : # Pas géré en stock, jamais de saisie détail
  Else
    Break
  Endif
Next
#-----
[M:PNH1]PCLFLG=9 : # Pour marquage ligne cde "pickée" !
[M:PNH1]NBLIG=SAVNBLIG
nolign=SAVNOLIGN
NOL=nolign-1
GMODIF=1
Affzo [PNH1]PTHNUM(NOL), PTDLIN(NOL)
Return


################################################################
# Si modif quantité du composé, répercution sur les composants #
# ------------------------------------------------------------ #
# NOL = Indice de la ligne de réception en cours de traitement #
################################################################
Subprog CALCUL_COMPOSANTS (NOL)
Value Shortint NOL
#-----
Local Integer I
#----- Répercussion indicateurs réintégration en commande et attente d'avoir -----#
I=NOL+1
While [M:PNH1]LINTYP(I)>2 & I<[M:PNH1]NBLIG
  #-----
  If [M:PNH1]ORDFLG(I)<>[M:PNH1]ORDFLG(NOL)
    [M:PNH1]ORDFLG(I)=[M:PNH1]ORDFLG(NOL)
    [M:PNH1]UPDFLG(I)=1
    # Issue 102707 - 2014-09-18 by MUARN : erreur nom zone
    If !GIMPORT  Affzo [PNH1]ORDFLG(I) : Endif
  Endif
  #-----
  If [M:PNH1]AVOFLG(I)<>[M:PNH1]AVOFLG(NOL)
    [M:PNH1]AVOFLG(I)=[M:PNH1]AVOFLG(NOL)
    [M:PNH1]UPDFLG(I)=1
    If !GIMPORT  Affzo [PNH1]AVOFLG(I) : Endif
  Endif
  #-----
  # Issue 71069 - 2016-04-13 by MUARN : PJT
  [M:PNH1]PJT(I) = [M:PNH1]PJT(NOL)
  I+=1
Wend
#----- Répercussion de la quantité si modification -----#
If [M:PNH1]PREQTYPUU(NOL)<>[M:PNH1]QTYPUU(NOL)
  Local Decimal WQTE
  I=NOL+1
  While [M:PNH1]LINTYP(I)>2 & I<[M:PNH1]NBLIG
    #If [M:PNH1]LIKQTYCOE(I)<>0
      #WQTE=[M:PNH1]QTYSTU(NOL)*[M:PNH1]LIKQTYCOE(I)
      #If [M:PNH1]UOMSTUCOE(I)<>0
      #  WQTE=WQTE/[M:PNH1]UOMSTUCOE(I)
      #Endif
      If [M:PNH1]PREQTYPUU(NOL)<>0
        WQTE=[M:PNH1]QTYUOM(I)*[M:PNH1]QTYPUU(NOL)/[M:PNH1]PREQTYPUU(NOL)
      Elsif [M:PNH1]LIKQTYCOE(I)<>0
        WQTE=[M:PNH1]QTYSTU(NOL)*[M:PNH1]LIKQTYCOE(I)
        If [M:PNH1]UOMSTUCOE(I)<>0
          WQTE=WQTE/[M:PNH1]UOMSTUCOE(I)
        Endif
      Else
        WQTE=[M:PNH1]QTYUOM(I)
      Endif
      #-----
      #Call QTEARR(WQTE,[M:PNH1]UOM(I)) From TRTDIV
      If [F:TUN]UOM<>[M:PNH1]UOM(I)
        Read [TUN] TUN0=[M:PNH1]UOM(I)
        If fstat  Raz [F:TCU] : Endif
      Endif
      WQTE=arr(WQTE,10^-max([F:TUN]UOMDEC,1))
      #-----
      nolign=I+1 : status=75
      Call AVANT_NBLIG     From SUBPNH
      Call AM_QTYUOM(WQTE) From SUBPNH
      [M:PNH1]QTYUOM(I)=WQTE
      [M:PNH1]LINFLG(I)=2
      Call APRES_NBLIG     From SUBPNH
      [M:PNH1]UPDFLG(I)=1
    #Endif
    I+=1
  Wend
  nolign=NOL+1
  [M:PNH1]PREQTYPUU(NOL)=[M:PNH1]QTYPUU(NOL)
Endif
End

