#<AdxTL>@(#)0.0.0.0 $Revision$Class Bank import type codes
# Supervisor
## CRUD-CLASSE ## BSIIMPTC
# 2018-08-16 22:22:47 554


############################################################################################
### Subprog AUPDATE
############################################################################################
Subprog AUPDATE(BSIIMPTC,ASTATUS)
Variable Instance BSIIMPTC Using R_BSIIMPTC
Variable Integer ASTATUS

If BSIIMPTC = null : End : Endif

Gosub AVARIABLES From WMR00BSIIMPTC
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If fmet BSIIMPTC.ACTX.AGETAFCRIGHT(BSIIMPTC,"BSIIMPORT",[V]CST_ATRUE)>=[V]CST_AERROR : [L]ASTATUS=[V]CST_AERROR : Goto AUPDATE_END : Endif
If fmet BSIIMPTC.ACTX.AGETAFCRIGHTU(BSIIMPTC,"BSIIMPORT",[L]A_STRSITE,[V]CST_ATRUE)>=[V]CST_AERROR
 [L]ASTATUS=[V]CST_AERROR : Goto AUPDATE_END
Endif

Gosub AREPCONTROL_AUPDATE
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If !adxlog
 Gosub AUPDATE_TR_BSIIMPTC
Else
 Gosub AUPDATE_BSIIMPTC
Endif
If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_END : Return : Endif

Gosub _AUPDATE_AFTER
[L]A_I = BSIIMPTC.freeSnapshot
BSIIMPTC.snapshotEnabled = 1
$AUPDATE_END
End

#-----------------------------------------------------#
$AREPCONTROL_AUPDATE
BSIIMPTC.ASTALIN = [V]CST_AUPD
BSIIMPTC.BSITC.ASTALIN = [V]CST_AUPD
[L]A_ASTALIN = BSIIMPTC.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Gosub AUPDATE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]A_ASTALIN = BSIIMPTC.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return


$AUPDATE_CONTROL
Gosub _AUPDATE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet BSIIMPTC._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet BSIIMPTC._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet BSIIMPTC._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AUPDATE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_BEFORE
If BSIIMPTC.BSITC.ASTALIN = [V]CST_ANEWDEL : Return : Endif
BSIIMPTC.BSITC.ASTALIN = [V]CST_AUPD
If [V]CST_ASTALIN(BSIIMPTC.BSITC.ASTALIN)<>""
 [L]A_ASTALIN = BSIIMPTC.BSITC.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.BSITC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
For A_N2=1 To maxtab(BSIIMPTC.BSITC.LINES) : # BSIITCD -- 2
 If BSIIMPTC.BSITC.LINES(A_N2) <> null
& and BSIIMPTC.BSITC.LINES(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If BSIIMPTC.BSITC.LINES(A_N2).ASTALIN<>[V]CST_ANEW & BSIIMPTC.BSITC.ASTALIN=[V]CST_ADEL
   BSIIMPTC.BSITC.LINES(A_N2).ASTALIN = [V]CST_ADEL
  Endif
  If BSIIMPTC.BSITC.LINES(A_N2).ASTALIN=[V]CST_ANEW & find(BSIIMPTC.BSITC.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
   BSIIMPTC.BSITC.LINES(A_N2).ASTALIN = [V]CST_ANEWDEL
  Endif
  If [V]CST_ASTALIN(BSIIMPTC.BSITC.LINES(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = BSIIMPTC.BSITC.LINES(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.BSITC.LINES(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_AFTER
For A_N2=1 To maxtab(BSIIMPTC.BSITC.LINES) : # BSIITCD -- 2
 If BSIIMPTC.BSITC.LINES(A_N2) <> null
& and BSIIMPTC.BSITC.LINES(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If [V]CST_ASTALIN(BSIIMPTC.BSITC.LINES(A_N2).ASTALIN)<>""
   [L]A_ASTALIN = BSIIMPTC.BSITC.LINES(A_N2).ASTALIN
   [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.BSITC.LINES(A_N2).ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

If [V]CST_ASTALIN(BSIIMPTC.BSITC.ASTALIN)<>""
 [L]A_ASTALIN = BSIIMPTC.BSITC.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.BSITC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
Return

#-----------------------------------------------------#
$AUPDATE_TR_BSIIMPTC
Trbegin [F:BSITC]
 Gosub AUPDATE_BSIIMPTC
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
$_AUPDATE_AFTER
If find(BSIIMPTC.BSITC.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 BSIIMPTC.BSITC.ASTALIN = [V]CST_ALL
Endif
Local Integer ASTATUS2
For A_N2=1 To maxtab(BSIIMPTC.BSITC.LINES)
 If BSIIMPTC.BSITC.LINES(A_N2) <> null
  If BSIIMPTC.BSITC.LINES(A_N2).ASTALIN=[V]CST_ADEL or BSIIMPTC.BSITC.LINES(A_N2).ASTALIN=[V]CST_ANEWDEL
   FreeInstance BSIIMPTC.BSITC.LINES(A_N2)
   BSIIMPTC.BSITC.LINES(A_N2) = null
  Elsif BSIIMPTC.BSITC.LINES(A_N2).ASTALIN <> [V]CST_ALL
   BSIIMPTC.BSITC.LINES(A_N2).ASTALIN = [V]CST_ALL
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Return

#-----------------------------------------------------#
$AUPDATE_BSIIMPTC
[L]A_ASTALIN = BSIIMPTC.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.BSITC._AUPDATE)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]A_ASTALIN = BSIIMPTC.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet BSIIMPTC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AUPDATE_ABORT
Rollback
$_AUPDATE_ABORT
If BSIIMPTC.snapshotEnabled=1
 [L]A_RETIK = BSIIMPTC.revertUpdTick
Endif
Local Integer ASTATUS2
For A_N2=1 To maxtab(BSIIMPTC.BSITC.LINES)
 If BSIIMPTC.BSITC.LINES(A_N2) <> null
  If BSIIMPTC.BSITC.LINES(A_N2).ASTALIN=[V]CST_ANEWDEL
   BSIIMPTC.BSITC.LINES(A_N2).ASTALIN = [V]CST_ANEW
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2

[L]ASTATUS = max(fmet BSIIMPTC.ACTION("AUPDATE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#



