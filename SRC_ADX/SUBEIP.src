#********************************************************************
# Funprog DEL_TRK
#********************************************************************
#
#* Delete old TRK
#* @param WNUMBATCH
#* @param WCATTYP
#* @param WOLDDOCID
#* @param WERR
#* @return WOK : [V]CST_AOK / [V]CST_AERROR
#*!
Funprog DEL_TRK(WNUMBATCH, WCATTYP, WOLDDOCID, WERR)
Value Char WNUMBATCH
Value Integer WCATTYP
Value Char WOLDDOCID
Variable Char WERR

  Local Integer WOK : WOK = [V]CST_AOK
  Local Integer WNB : WNB = 0
#  Local Char LAN(3) : LAN="FRA" #GLANGUE # Issue 116335- 2016-04-29 by RBA : txt
  Local Char LAN(3) : If dim(GLANGUE)>0 : LAN=GLANGUE : Elsif dim(GACTX.LAN)>0 : LAN=GACTX.LAN : Else LAN="ENG" : Endif# Issue 116335- 2016-04-29 by RBA : txt
  Local Char WTXT(100) : Call TEXTELAN(53363,WTXT,LAN) From OBJDIV # Issue 116335- 2016-04-29 by RBA : txt
  If WNUMBATCH <> "" and  WOLDDOCID <> ""
    ##################################################
    If WOK = [V]CST_AOK
      If clalev([F:EDK]) = 0 : Local File EDITRKDOC [EDK] : Endif
      Filter [EDK] Where NUMBATCH = WNUMBATCH and DOCID = WOLDDOCID and CATTYP = WCATTYP and (FLGUPD = 1 or FLGUPD = 0) Order By NUMLIN Desc #CATTYP
      For [EDK]
        Delete [EDK]
        If !fstat
          WNB = WNB + 1
#          WERR = WERR + "/" + "Tracking document deletion succeded" # Issue 116335- 2016-04-29 by RBA : txt
          WERR = WERR + "/" + WTXT-"("+mess(53,123,1)+")"-mess(7,2007,1) # Issue 116335- 2016-04-29 by RBA : txt
        Else
          WOK = [V]CST_AERROR
#          WERR = WERR + "/" + "Tracking document deletion failed" # Issue 116335- 2016-04-29 by RBA : txt
          WERR = WERR + "/" + WTXT-"("+mess(53,123,1)+")"-mess(9,2007,1) # Issue 116335- 2016-04-29 by RBA : txt
        Endif
        Break
      Next
      Close File [EDK]
    Endif
    If WNB = 0
      WOK = [V]CST_AERROR
#      WERR = WERR + "/" + "Tracking document deletion failed (not found)" # Issue 116335- 2016-04-29 by RBA : txt
      WERR = WERR + "/" + WTXT-"("+mess(53,123,1)+")"-mess(9,2007,1) # Issue 116335- 2016-04-29 by RBA : txt
    Endif
  Else
#    WERR = "Tracking document deletion - Missing parameter ("+WNUMBATCH+"~"+WOLDDOCID+")" # Issue 116335- 2016-04-29 by RBA : txt
    WERR = WERR + "/" + WTXT-"("+mess(53,123,1)+")"-mess(9,2007,1) # Issue 116335- 2016-04-29 by RBA : txt
    WOK = [V]CST_AERROR
  Endif
End WOK

