  Local Integer WOK : WOK = [V]CST_AOK
  Local Integer WNB : WNB = 0
  If WNUMBATCH <> "" and  WOLDDOCID <> ""
    ##################################################
    If WOK = [V]CST_AOK
      If clalev([F:ESTC]) = 0 : Local File EDISTOC [ESTC] : Endif
      Filter [ESTC] Where NUMBATCH = WNUMBATCH and KEYDOC = WOLDDOCID
      For [ESTC]
        Delete [ESTC]
        If !fstat
          WNB = WNB + 1
        Endif
      Next
      Close File [ESTC]
    Endif

    ##################################################
    If WOK = [V]CST_AOK
      If clalev([F:ESTJ]) = 0 : Local File EDISTOJ [ESTJ] : Endif
      Filter [ESTJ] Where NUMBATCH = WNUMBATCH and KEYDOC = WOLDDOCID Order By SORT Desc
      For [ESTJ]
        Delete [ESTJ]
        If !fstat
          WNB = WNB + 1
        Endif
      Next
      Close File [ESTJ]
    Endif

    ##################################################
    If WOK = [V]CST_AOK
      If clalev([F:ESTU]) = 0 : Local File EDISTOU [ESTU] : Endif
      Filter [ESTU] Where NUMBATCH = WNUMBATCH and KEYDOC = WOLDDOCID Order By SORT Desc
      For [ESTU]
        Delete [ESTU]
        If !fstat
          WNB = WNB + 1
        Endif
      Next
      Close File [ESTU]
    Endif

    ##################################################
    If WOK = [V]CST_AOK
      If clalev([F:ESTE]) = 0 : Local File EDISTOE [ESTE] : Endif
      Filter [ESTE] Where NUMBATCH = WNUMBATCH and KEYDOC = WOLDDOCID Order By SORT Desc
      For [ESTE]
        Delete [ESTE]
        If !fstat
          WNB = WNB + 1
        Endif
      Next
      Close File [ESTE]
    Endif

    ##################################################
    If WOK = [V]CST_AOK
      If clalev([F:ESTF]) = 0 : Local File EDISTOF [ESTF] : Endif
      Filter [ESTF] Where NUMBATCH = WNUMBATCH and KEYDOC = WOLDDOCID Order By SORT Desc
      For [ESTF]
        Delete [ESTF]
        If !fstat
          WNB = WNB + 1
        Endif
      Next
      Close File [ESTF]
    Endif

    ##################################################
    If WOK = [V]CST_AOK
      If clalev([F:EST]) = 0 : Local File EDISTO [EST]  : Endif
#      Delete [EST]EST0 = WNUMBATCH;WOLDDOCID
      Filter [EST] Where NUMBATCH = WNUMBATCH and KEYDOC = WOLDDOCID
      For [EST]
        Delete [EST]
        If !fstat
          WNB = WNB + 1
        Endif
      Next
      Close File [EST]
    Endif

    ##################################################
    If WNB > 0
#      WERR = "Temporary storage record deletion"-WNUMBATCH+"~"+WOLDDOCID-"succeded"# Issue 116335- 2016-04-29 by RBA : txt
      WERR = mess(18,2007,1)-"("+mess(53,123,1)+")"-WNUMBATCH+"~"+WOLDDOCID-mess(7,2007,1)# Issue 116335- 2016-04-29 by RBA : txt
    Else
#      WERR = "Temporary storage record deletion"-WNUMBATCH+"~"+WOLDDOCID-"failed"# Issue 116335- 2016-04-29 by RBA : txt
      WERR = mess(18,2007,1)-"("+mess(53,123,1)+")"-WNUMBATCH+"~"+WOLDDOCID-mess(9,2007,1)# Issue 116335- 2016-04-29 by RBA : txt
      WOK = [V]CST_AERROR
    Endif
  Else
#    WERR = "Temporary storage record deletion - Missing parameter ("+WNUMBATCH+"~"+WOLDDOCID+")"# Issue 116335- 2016-04-29 by RBA : txt
      WERR = mess(18,2007,1)-"("+mess(53,123,1)+")"-WNUMBATCH+"~"+WOLDDOCID-mess(9,2007,1)# Issue 116335- 2016-04-29 by RBA : txt
    WOK = [V]CST_AERROR
  Endif
End WOK

