###############################################################

#********************************************************************
# Funprog COPY_SAS
#********************************************************************
#
#* Copy old SAS to new SAS
#* @param WNUMBATCH
#* @param WCATTYP
#* @param WOLDDOCID
#* @param WNEWDOCID
#* @param WERR
#* @return WOK : [V]CST_AOK / [V]CST_AERROR
#*!
Funprog COPY_SAS(WNUMBATCH, WCATTYP, WOLDDOCID, WNEWDOCID, WSTEP, WERR)
Value Char WNUMBATCH
Value Integer WCATTYP
Value Char WOLDDOCID
Value Char WNEWDOCID
Value Integer WSTEP
Variable Char WERR

  Local Integer WOK : WOK = [V]CST_AOK

  If WNUMBATCH <> "" and  WOLDDOCID <> "" and WNEWDOCID <> ""
    ##################################################
    If WOK = [V]CST_AOK
      If clalev([F:EST])  = 0 : Local File EDISTO [EST]  : Endif
      Read [EST]EST0 = WNUMBATCH;WOLDDOCID
      If !fstat
        If clalev([F:ESTCOPY])  = 0 : Local File EDISTO [ESTCOPY]  : Endif
        Trbegin [ESTCOPY]
        [ESTCOPY]          = [EST]
        [ESTCOPY]KEYDOC    = WNEWDOCID
        [ESTCOPY]EXTKEYDOC = WOLDDOCID
        Write [ESTCOPY]
        If !fstat
          Commit
        Else
          #pb
          WOK = [V]CST_AERROR
          Rollback
        Endif
        Close File [ESTCOPY]
      Else
        #pb
        WOK = [V]CST_AERROR
      Endif
      Close File [EST]
    Endif

    ##################################################
    If WOK = [V]CST_AOK
      If clalev([F:ESTF]) = 0 : Local File EDISTOF [ESTF] : Endif
      Filter [ESTF] Where NUMBATCH = WNUMBATCH and KEYDOC = WOLDDOCID
      For [ESTF]
        If clalev([F:ESTFCOPY])  = 0 : Local File EDISTOF [ESTFCOPY]  : Endif
        Trbegin [ESTFCOPY]
        [ESTFCOPY]       = [ESTF]
        [ESTFCOPY]KEYDOC = WNEWDOCID
        Write [ESTFCOPY]
        If !fstat
          Commit
        Else
          #pb
          WOK = [V]CST_AERROR
          Rollback
        Endif
        Close File [ESTFCOPY]
      Next
      Close File [ESTF]
    Endif

    ##################################################
    If WOK = [V]CST_AOK
      If clalev([F:ESTE]) = 0 : Local File EDISTOE [ESTE] : Endif
      Filter [ESTE] Where NUMBATCH = WNUMBATCH and KEYDOC = WOLDDOCID
      For [ESTE]
        If clalev([F:ESTECOPY])  = 0 : Local File EDISTOE [ESTECOPY]  : Endif
        Trbegin [ESTECOPY]
        [ESTECOPY]       = [ESTE]
        [ESTECOPY]KEYDOC = WNEWDOCID
        Write [ESTECOPY]
        If !fstat
          Commit
        Else
          #pb
          WOK = [V]CST_AERROR
          Rollback
        Endif
        Close File [ESTECOPY]
      Next
      Close File [ESTE]
    Endif

    ##################################################
    If WOK = [V]CST_AOK
      If clalev([F:ESTU]) = 0 : Local File EDISTOU [ESTU] : Endif
      Filter [ESTU] Where NUMBATCH = WNUMBATCH and KEYDOC = WOLDDOCID
      For [ESTU]
        If clalev([F:ESTUCOPY])  = 0 : Local File EDISTOU [ESTUCOPY]  : Endif
        Trbegin [ESTUCOPY]
        [ESTUCOPY]       = [ESTU]
        [ESTUCOPY]KEYDOC = WNEWDOCID
        Write [ESTUCOPY]
        If !fstat
          Commit
        Else
          #pb
          WOK = [V]CST_AERROR
          Rollback
        Endif
        Close File [ESTUCOPY]
      Next
      Close File [ESTU]
    Endif

    ##################################################
    If WOK = [V]CST_AOK
      If clalev([F:ESTJ]) = 0 : Local File EDISTOJ [ESTJ] : Endif
      Filter [ESTJ] Where NUMBATCH = WNUMBATCH and KEYDOC = WOLDDOCID
      For [ESTJ]
        If clalev([F:ESTJCOPY])  = 0 : Local File EDISTOJ [ESTJCOPY]  : Endif
        Trbegin [ESTJCOPY]
        [ESTJCOPY]       = [ESTJ]
        [ESTJCOPY]KEYDOC = WNEWDOCID
        Write [ESTJCOPY]
        If !fstat
          Commit
        Else
          #pb
          WOK = [V]CST_AERROR
          Rollback
        Endif
        Close File [ESTJCOPY]
      Next
      Close File [ESTJ]
    Endif

    ##################################################
    If WOK = [V]CST_AOK
      If clalev([F:ESTC]) = 0 : Local File EDISTOC [ESTC] : Endif
      Filter [ESTC] Where NUMBATCH = WNUMBATCH and KEYDOC = WOLDDOCID
      For [ESTC]
        If clalev([F:ESTCCOPY])  = 0 : Local File EDISTOC [ESTCCOPY]  : Endif
        Trbegin [ESTCCOPY]
        [ESTCCOPY]       = [ESTC]
        [ESTCCOPY]KEYDOC = WNEWDOCID
        Write [ESTCCOPY]
        If !fstat
          Commit
        Else
          #pb
          WOK = [V]CST_AERROR
          Rollback
        Endif
        Close File [ESTCCOPY]
      Next
      Close File [ESTC]
    Endif

    If WOK = [V]CST_AOK
#      WERR = "Temporary storage record copy succeeded" # Issue 116335- 2016-04-29 by RBA : txt
      WERR = mess(18,2007,1)-":"-mess(7,2007,1) # Issue 116335- 2016-04-29 by RBA : txt
      Local Instance WMYEDISTO Using C_EDISTO
      WMYEDISTO = NewInstance C_EDISTO AllocGroup null
      WOK = fmet WMYEDISTO.AREAD(WNUMBATCH, WNEWDOCID)
      If WOK = [V]CST_AOK
        WSTEP = WSTEP + 1
        WOK = fmet WMYEDISTO.MET_LOG_INSERT_EVENT(datetime$, WSTEP, [V]CST_AINFO, 21, WOLDDOCID+"->"+WNEWDOCID)
        WSTEP = WSTEP + 1 #RBA
        WOK = fmet WMYEDISTO.MET_LOG_INSERT_EVENT(datetime$, WSTEP, [V]CST_AINFO, 11, mess(3,2003,1)) #Terminated
        WMYEDISTO.STA = 3
        WOK = fmet WMYEDISTO.AUPDATE()
      Else
        #
      Endif
      FreeGroup WMYEDISTO : WMYEDISTO = null
    Else
#      WERR = "Temporary storage record copy failed" # Issue 116335- 2016-04-29 by RBA : txt
      WERR = mess(18,2007,1)-":"-mess(9,2007,1) # Issue 116335- 2016-04-29 by RBA : txt
       #ajouter une ligne event et modifier le status terminated SAS + TRK
      Local Instance WMYEDISTO Using C_EDISTO
      WMYEDISTO = NewInstance C_EDISTO AllocGroup null
      WOK = fmet WMYEDISTO.AREAD(WNUMBATCH, WOLDDOCID)
      If WOK = [V]CST_AOK
        WSTEP = WSTEP + 1
        WOK = fmet WMYEDISTO.MET_LOG_INSERT_EVENT(datetime$, WSTEP, [V]CST_AERROR, 21, WOLDDOCID+"->"+WNEWDOCID)
        WSTEP = WSTEP + 1 #RBA
        WOK = fmet WMYEDISTO.MET_LOG_INSERT_EVENT(datetime$, WSTEP, [V]CST_AERROR, 11, mess(4,2003,1)) #Error
        WMYEDISTO.STA = 4
        WOK = fmet WMYEDISTO.AUPDATE()
      Else
        #
      Endif
      FreeGroup WMYEDISTO : WMYEDISTO = null
    Endif

  Else
#    WERR = "Temporary storage record - Missing parameter" # Issue 116335- 2016-04-29 by RBA : txt
    WERR = mess(18,2007,1)-":"-mess(9,2007,1) # Issue 116335- 2016-04-29 by RBA : txt
    Local Instance WMYEDISTO Using C_EDISTO
    WMYEDISTO = NewInstance C_EDISTO AllocGroup null
    WOK = fmet WMYEDISTO.AREAD(WNUMBATCH, WOLDDOCID)
    If WOK = [V]CST_AOK
      WSTEP = WSTEP + 1
      WOK = fmet WMYEDISTO.MET_LOG_INSERT_EVENT(datetime$, WSTEP, [V]CST_AERROR, 21, WOLDDOCID+"->"+WNEWDOCID)
      WSTEP = WSTEP + 1 #RBA
      WOK = fmet WMYEDISTO.MET_LOG_INSERT_EVENT(datetime$, WSTEP, [V]CST_AINFO, 11, mess(4,2003,1)) #Error
      WMYEDISTO.STA = 4
      WOK = fmet WMYEDISTO.AUPDATE()
    Else
      #
    Endif
    FreeGroup WMYEDISTO : WMYEDISTO = null
    WOK = [V]CST_AERROR
  Endif
End WOK

######################################################################################

#********************************************************************
# Funprog COPY_TRK
#********************************************************************
#
#* Copy old TRK to new TRK
#* @param WNUMBATCH
#* @param WCATTYP
#* @param WOLDDOCID
#* @param WNEWDOCID
#* @param WERR
#* @return WOK : [V]CST_AOK / [V]CST_AERROR
#*!
Funprog COPY_TRK(WNUMBATCH, WCATTYP, WOLDDOCID, WNEWDOCID, WERR)
Value Char WNUMBATCH
Value Integer WCATTYP
Value Char WOLDDOCID
Value Char WNEWDOCID
Variable Char WERR
#Dbgaff
  Local Integer WOK : WOK = [V]CST_AOK
  Local Integer WFOUND : WFOUND = 0
#  Local Char LAN(3) : LAN="FRA" #GLANGUE # Issue 116335- 2016-04-29 by RBA : txt
  Local Char LAN(3) : If dim(GLANGUE)>0 : LAN=GLANGUE : Elsif dim(GACTX.LAN)>0 : LAN=GACTX.LAN : Else LAN="ENG" : Endif# Issue 116335- 2016-04-29 by RBA : txt
  Local Char WTXT(100) : Call TEXTELAN(53363,WTXT,LAN) From OBJDIV # Issue 116335- 2016-04-29 by RBA : txt
     #tracking table
  ##################################################
  If WOK = [V]CST_AOK

    If clalev([F:EDK]) = 0 : Local File EDITRKDOC [EDK] : Endif
    Filter [EDK] Where NUMBATCH = WNUMBATCH and DOCID = WOLDDOCID and CATTYP = WCATTYP and (FLGUPD = 1 or FLGUPD = 0) Order By NUMLIN Desc
    For [EDK]
      WFOUND = WFOUND + 1
      If clalev([F:EDKCOPY]) = 0 : Local File EDITRKDOC [EDKCOPY] : Endif
      Trbegin [EDKCOPY]
      [EDKCOPY]       = [EDK]
      [EDKCOPY]DOCID  = WNEWDOCID
      [EDKCOPY]FLGUPD = 2
      [EDKCOPY]TRKSTA = 3  #status
      Write [EDKCOPY]
      If !fstat
        Commit
#        WERR = "Tracking document copy succeeded" # Issue 116335- 2016-04-29 by RBA : txt
        WERR = WTXT-":"-mess(7,2007,1) # Issue 116335- 2016-04-29 by RBA : txt
      Else
        #pb
        WOK = [V]CST_AERROR
#        WERR = "Tracking document copy failed" # Issue 116335- 2016-04-29 by RBA : txt
        WERR = WTXT-":"-mess(9,2007,1) # Issue 116335- 2016-04-29 by RBA : txt
        Rollback
      Endif
      Close File [EDKCOPY]
      Break
    Next

    If WFOUND = 0
      WOK = [V]CST_AERROR
#      WERR = "Tracking document copy failed (not found)"# Issue 116335- 2016-04-29 by RBA : txt
      WERR = WTXT-":"-mess(9,2007,1)# Issue 116335- 2016-04-29 by RBA : txt
    Endif
    Close File [EDK]
  Endif
End WOK


Funprog UPD_TRKSTA_TRK(WNUMBATCH, WCATTYP, WOLDDOCID, WERR)
Value Char WNUMBATCH
Value Integer WCATTYP
Value Char WOLDDOCID
Variable Char WERR
#Dbgaff
  Local Integer WOK : WOK = [V]CST_AOK
  Local Integer WFOUND : WFOUND = 0
#  Local Char LAN(3) : LAN="FRA" #GLANGUE # Issue 116335- 2016-04-29 by RBA : txt
  Local Char LAN(3) : If dim(GLANGUE)>0 : LAN=GLANGUE : Elsif dim(GACTX.LAN)>0 : LAN=GACTX.LAN : Else LAN="ENG" : Endif# Issue 116335- 2016-04-29 by RBA : txt
  Local Char WTXT(100) : Call TEXTELAN(53363,WTXT,LAN) From OBJDIV # Issue 116335- 2016-04-29 by RBA : txt
     #tracking table
  ##################################################
  If WOK = [V]CST_AOK

    If clalev([F:EDK]) = 0 : Local File EDITRKDOC [EDK] : Endif
    Filter [EDK] Where NUMBATCH = WNUMBATCH and DOCID = WOLDDOCID and CATTYP = WCATTYP and (FLGUPD = 1 or FLGUPD = 0) Order By NUMLIN Desc
    For [EDK]
      Trbegin [EDK]
      WFOUND = WFOUND + 1
      [EDK]TRKSTA = 3  #status
      Rewrite [EDK]
      If !fstat
        Commit
#        WERR = "Tracking document copy succeeded" # Issue 116335- 2016-04-29 by RBA : txt
        WERR = WTXT-":"-"update status done"#mess(7,2007,1) # Issue 116335- 2016-04-29 by RBA : txt
      Else
        #pb
        WOK = [V]CST_AERROR
#        WERR = "Tracking document copy failed" # Issue 116335- 2016-04-29 by RBA : txt
        WERR = WTXT-":"-"update status failed" #mess(9,2007,1) # Issue 116335- 2016-04-29 by RBA : txt
        Rollback
      Endif
      Break
    Next

    If WFOUND = 0
      WOK = [V]CST_AERROR
#      WERR = "Tracking document copy failed (not found)"# Issue 116335- 2016-04-29 by RBA : txt
      WERR = WTXT-":"-"update status failed" #mess(9,2007,1)# Issue 116335- 2016-04-29 by RBA : txt
    Endif
    Close File [EDK]
  Endif
End WOK


