# Gestion du masque EDIIMP

######################################################################################
## Etiquette ajoutée par le superviseur (écran EDIIMP) 25/03/2015 11:02:45 (RBA)
######################################################################################
$ACTION
 Case ACTION
  When "INIT_DIA"     : Gosub INIT_DIA
  When "EXEC"         : Gosub EXEC
  When "LIENS"        : Gosub LIENS
  When "LIENS_LIG"    : Gosub LIENS_LIG
  When Default
 Endcase
Return

$LIENS
#  [M:DIA]NBLIG = nolign-1
Return

$LIENS_LIG
  [M:DIA]NBLIG = nolign-1
Return
######################################################################################

$INIT_DIA
  Gosub OUVRE From GIMPOBJ
#  Local Integer WIMPSTA
#  Local Char WERRMSG(255)
Return

######################################################################################

$EXEC
  Local Char    WNUMBATCH(20) : WNUMBATCH = [M:DIA]NUMBATCH  #Num lot
  Local Integer WCATTYP       : WCATTYP   = [M:DIA]CATTYP    #Category type
  Local Char    WEXT(100)     : WEXT      = [M:DIA]EXT       #Modele import
  Local Integer WSTEP : WSTEP = [M:DIA]FLOSTEP

#  Local Integer WTEST         : WTEST     =[M:DIA]TEST       #test flag doesn't work
  Local Char    WTAB_FILE(250)(1..)
  Local Integer WTAB_IMPSTA(1..)
  Local Char    WFILE(250)
  Local Char    WNEWDOCID(20)
  Local Char    WTAB_NEWDOCID(20)(1..)

  Local Char    WERRMSG(255)
  Local Integer WIMPSTA


  Local Integer I

  #process the document list
  For I = 0 To [M:DIA]NBLIG+1
    If [M:DIA]FIL(I)<> ""
      WFILE = [M:DIA]PATH+"/"+[M:DIA]FIL(I)
      WTAB_FILE(I+1) = WFILE
#      Call ECR_TRACE("Processing file ("+num$(I+1)+") : "+WFILE,0) From GESECRAN
      Gosub IMPORT_DOC
      WTAB_NEWDOCID(I+1) = WNEWDOCID
      WTAB_IMPSTA(I+1)   = WIMPSTA
#      Call ECR_TRACE("Import Status file ("+num$(I+1)+") : "+WFILE,0) From GESECRAN
      Raz WIMPSTA
    Endif
  Next I

  Local Integer WSTEP

  #update SAS/TRK of document list
  For I = 1 To maxtab(WTAB_NEWDOCID)
    If WTAB_IMPSTA(I) = 0
      WNEWDOCID = WTAB_NEWDOCID(I)
      WFILE     = WTAB_FILE(I)
      WSTEP = [M:DIA]FLOSTEP
      Gosub IMPORT_DOC_END
    Endif
  Next I
Return

######################################################################################

$IMPORT_DOC
  Raz [M:IMP2]
  Raz [M:AOE0], [M:AOE1], [M:AOE2]
  Raz WERRMSG

  Call CHARGE_MODELE(WEXT,WIMPSTA) From GIMPOBJ
  If WIMPSTA #erreur chargement modele
    Call ERR_IMPORT(WIMPSTA,WERRMSG) From GIMPOBJ
    Call ECR_TRACE(mess(6,123,1)-" : "-WERRMSG,1) From GESECRAN
    Return
  Endif

  If [F:AOE]OBJ<>""
    Read [AOB_]ABREV = [F:AOE]OBJ
    If fstat #erreur obj
      WIMPSTA = 18
      Call ERR_IMPORT(WIMPSTA,WERRMSG) From GIMPOBJ
      Call ECR_TRACE(mess(6,123,1)-" : "-WERRMSG,1) From GESECRAN
      Return
    Endif
  Endif

  [M:IMP2]MODIMP = WEXT
  [M:IMP2]NOMIMP = WFILE
  [M:IMP2]TYPEXP = 2
#  [M:IMP2]TEST = 2 #doesn't work
#  [M:IMP2]TEST = WTEST #doesn't work

  Call IMPORTSIL([M:IMP2]MODIMP,[M:IMP2]NOMIMP) From GIMPOBJ
  WIMPSTA   = [M:IMP2]STAT
  WNEWDOCID = GCLE #X3 created document key recovered bu IMPORTSIL if IMPORTSIL concern only 1 document ! (else, the last one of the list...)

  If WIMPSTA #erreur status import en echec
    Call ERR_IMPORT(WIMPSTA,WERRMSG) From GIMPOBJ
    Call ECR_TRACE(mess(6,123,1)-" : "-WERRMSG,1) From GESECRAN
  Endif

  If GOK < 1 #erreur transaction
    WIMPSTA = 11
    Call ECR_TRACE(mess(6,123,1)-"("+num$(WIMPSTA)+")",1) From GESECRAN
  Endif

  Raz mkstat
  GOK=1
  OK=1
  Raz GERR
  Raz GMESSAGE
  Raz WERRMSG
Return

###############################################################


$IMPORT_DOC_END
  Local Char    WOLDDOCID(20)
  Local Integer WOK
  Local Integer WFOUND_OK : WFOUND_OK = 0

  Local File EDISTOU [ESTU]
  Filter [ESTU] Where [ESTU]NUMBATCH = WNUMBATCH and left$([ESTU]CODE, 7) = "PHYFILE" and [ESTU]DOCKEY = func GET_FILENAME(WFILE)
  For [ESTU]
    WOLDDOCID = [ESTU]KEYDOC
    WFOUND_OK = 1
    Break
  Next
  Close File [ESTU]

  If WFOUND_OK = 1 and WOLDDOCID <> ""
    Local Char WERR_TAB(250)(1..)
    Local Integer J
    WOK = func SUBEIP.DUPLICATE_SAS(WNUMBATCH, WCATTYP, WOLDDOCID, WNEWDOCID, WERR_TAB(), WSTEP)
    If WOK <> [V]CST_AOK
#      Call ECR_TRACE("Launching receipt process"-WNUMBATCH-"(external reference :"-WOLDDOCID+") : failed",1) From GESECRAN  # Issue 116335- 2016-04-29 by RBA : txt
      Call ECR_TRACE(mess(41,2007,1)-WNUMBATCH-"("+mess(6,772,1)-":"-WOLDDOCID+") :"-mess(9,2007,1),1) From GESECRAN # Issue 116335- 2016-04-29 by RBA : txt
      For J = 1 To maxtab(WERR_TAB)
        Call ECR_TRACE(""+WERR_TAB(J),1) From GESECRAN
      Next J
    Else
#      Call ECR_TRACE("Launching receipt process"-WNUMBATCH-"(external reference :"-WOLDDOCID+") -> (X3 reference :"-WNEWDOCID+") : succeeded",0) From GESECRAN # Issue 116335- 2016-04-29 by RBA : txt
      Call ECR_TRACE(mess(41,2007,1)-WNUMBATCH-"("+mess(6,772,1)-":"-WOLDDOCID+") -> ("+mess(6,3701,1)-" :"-WNEWDOCID+") :"-mess(7,2007,1),0) From GESECRAN # Issue 116335- 2016-04-29 by RBA : txt
  #    For J = 1 To maxtab(WERR_TAB)
  #      Call ECR_TRACE(""+WERR_TAB(J),0) From GESECRAN
  #    Next J
    Endif
  Else
#    Call ECR_TRACE("Launching receipt process"-WNUMBATCH-"(external reference :"-WOLDDOCID+") : failed",1) From GESECRAN # Issue 116335- 2016-04-29 by RBA : txt
    Call ECR_TRACE(mess(41,2007,1)-WNUMBATCH-"("+mess(6,772,1)-":"-WOLDDOCID+") :"-mess(9,2007,1),1) From GESECRAN # Issue 116335- 2016-04-29 by RBA : txt
  Endif
  WFOUND_OK = 0
  Raz WOLDDOCID
Return



Funprog GET_FILENAME(WFILE)
Value Char WFILE()
  Local Char WFILENAME(250)
  Local Integer I
  For I = len(WFILE) To 1 Step -1
    If mid$(WFILE, I, 1) = "/" or mid$(WFILE, I, 1) = "\"
      WFILENAME = right$(WFILE, I+1)
      Break
    Endif
  Next I
End WFILENAME

Funprog GET_WKEYDOC_TAB(WNUMBATCH, WFILE, WKEYDOC_TAB)
Value Char WNUMBATCH()
Value Char WFILE()
Variable Char WKEYDOC_TAB()(1..)
Local Char WFILENAME(250)

  Local Integer WOK : WOK = [V]CST_AERROR
  Local Integer I, J, K
  I = 0
  WFILENAME = func GET_FILENAME(WFILE)
  If WFILENAME <> ""
    Local Char WTMP_KEYDOC_TAB(20)(1..)
    Local File EDISTOU [ESTU]
    Filter [ESTU] Where [ESTU]NUMBATCH = WNUMBATCH and left$([ESTU]CODE, 7) = "PHYFILE" and [ESTU]DOCKEY = WFILENAME
    For [ESTU]
      I = I + 1
      WTMP_KEYDOC_TAB(I) = [ESTU]KEYDOC
    Next
    Close File [ESTU]
    Local Integer WFOUND : WFOUND= 0
    K = 0
    For I = 1 To maxtab(WTMP_KEYDOC_TAB)
    #creer WKEYDOC_TAB sans doublons
      WFOUND = 0
      For J = 1 To maxtab(WKEYDOC_TAB)
        If WTMP_KEYDOC_TAB(I) = WKEYDOC_TAB(J)
          WFOUND = 1
          Break 1
        Endif
      Next J
      If WFOUND = 0
        K = K + 1
        WKEYDOC_TAB(K) = WTMP_KEYDOC_TAB(I)
      Endif
    Next I
  Endif
  If I > 0
    WOK = [V]CST_AOK
  Endif
End WOK



#********************************************************************
# Funprog DUPLICATE_SAS
#********************************************************************
#
#* Copy old SAS to new SAS and old TRK to new TRK, and delete old SAS and TRK
#* @param WNUMBATCH
#* @param WCATTYP
#* @param WOLDDOCID
#* @param WNEWDOCID
#* @param WERR_TAB
#* @return WOK : [V]CST_AOK / [V]CST_AERROR
#*!
Funprog DUPLICATE_SAS(WNUMBATCH, WCATTYP, WOLDDOCID, WNEWDOCID, WERR_TAB, WSTEP)
Value Char WNUMBATCH()
Value Integer WCATTYP
Value Char WOLDDOCID()
Value Char WNEWDOCID()
Variable Char WERR_TAB()(1..)
Value Integer WSTEP

  Local Integer WOK
  Local Char WSTRERR(250)

  WOK = func SUBEIP.COPY_SAS(WNUMBATCH, WCATTYP, WOLDDOCID, WNEWDOCID, WSTEP, WSTRERR)
  WERR_TAB(1) = WSTRERR
  If WOK = [V]CST_AOK
    WOK =  func SUBEIP.COPY_TRK(WNUMBATCH, WCATTYP, WOLDDOCID, WNEWDOCID, WSTRERR)
    WERR_TAB(2) = WSTRERR
    If WOK = [V]CST_AOK
      WOK =  func SUBEIP.DEL_TRK(WNUMBATCH, WCATTYP, WOLDDOCID, WSTRERR)
      WERR_TAB(3) = WSTRERR
      If WOK = [V]CST_AOK
        WOK = func SUBEIP.DEL_SAS(WNUMBATCH, WCATTYP, WOLDDOCID, WSTRERR)
        WERR_TAB(4) = WSTRERR
      Endif
    Endif
  Endif

End WOK


