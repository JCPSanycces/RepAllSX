End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ADOCTRA2) 15/01/2008 16:06:13 (VPO)
######################################################################################
Subprog AM_EXCMOD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    Actzo [M]MODTOEXC
Else
    Grizo [M]MODTOEXC
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ADOCTRA2) 24/06/2010 09:05:32 (JPGA)
######################################################################################
Subprog AM_ALLPRIO(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    Grizo [M]PRIOTRA
Else
    Actzo [M]PRIOTRA
Endif
End
######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran ADOCTRA4) 16/10/2012 11:49:01 (JPGA)
######################################################################################
Subprog AV_ALLCREGRP(VALEUR)
Variable Integer VALEUR
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  #Le modèle "Traitement Standard-Boite de dialogue" ne permet pas chgfmt en INIT_DIA : on le fait donc en Avant-zone de champ
  Call AFFMASK_GROUPE("[M:TRA4]ALLCREGRP") From AGENLIBA
End
