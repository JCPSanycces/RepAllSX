#<AdxTL>@(#)8.0.0.0 $Revision$
Close Local Mask
Call ADOCTRA(nomap)
End

########################################################################
Subprog ADOCTRA(APPLI)
Value Char APPLI
Local Char PARAM(30)(1..2)
Call SAISIE_CHAR(APPLI,PARAM,"ADOCTRA","ADOCTRA","") From GSAISIE
End


######################################################################################
# Gestion des masques ADOCTRA
####################
$ACTION
If GACTION="ADOCTRA7"
    Case ACTION
     When "DEBUT"        : Gosub DEBUT7
     When "SETBOUT"      : Gosub SETBOUT7
     When "RAF"          : Gosub RAF7
     When "EDI"          : Gosub EDIT7
     When "TERMINE"      : Gosub FIN
     When Default
    Endcase
Elsif GACTION="ADOCTRA6"
    Case ACTION
     When "DEBUT"        : Gosub DEBUT6
     When "SETBOUT"      : Gosub SETBOUT6
     When "RAF"          : Gosub RAF6
     When "EDI"          : Gosub EDIT6
     When "TERMINE"      : Gosub FIN
     When Default
    Endcase
Elsif GACTION="ADOCTRA5"
    Case ACTION
     When "INIT"         : Gosub INIT5
     When "DEBUT"        : Gosub DEBUT5
     When "SETBOUT"      : Gosub SETBOUT5
     When "RAF"          : Gosub RAF5
     When "EDI"          : Gosub EDIT5
     When "TERMINE"      : Gosub FIN
     When Default
    Endcase
Elsif GACTION="ADOCTRA4"
    Case ACTION
     When "INIT"         : Gosub INIT45
     When "INIT_DIA"     : Gosub INIT_DIA45
     When "EXEC"         : Gosub EXEC45
     When "SORTIE"       : Gosub TERMINE45
     When "TERMINE"      : Gosub FIN
     When Default
    Endcase
Else
    Case ACTION
     When "DEBUT"        : Gosub DEBUT
     When "SETBOUT"      : Gosub SETBOUT
     When "RAF"          : Gosub RAF
     When "BOUTON"       : Gosub BOUTON
     When "TERMINE"      : Gosub FIN
     When "EDI"          : Gosub EDIT
     When Default
    Endcase
Endif
Return

####################
$FIN
# cg mai 2013 en fct d ou on vient et ce qu on fait il faut
# remettre blanc dans code iso var
If dim(GISO_COD_LAN) >=0
    GISO_COD_LAN = ""
Endif
Return

####################
$DEBUT7
$RAF7
Raz [M:TRA7]
[M:TRA7]ALLTYP=1
[M:TRA7]TYP=PARAM(1)
If PARAM(1)=""
    [M:TRA7]ALLTYP=2
Endif
[M:TRA7]ALLMOD=1
If PARAM(2)="-1"
    [M:TRA7]ALLMOD=2
Else
 [M:TRA7]MODULE=val(PARAM(2))
Endif
Local Integer ERR
Call TEMPON("L") From GESECRAN
Call CHARGE_TRA7([M:TRA0]LAN,ERR)
Call TEMPOFF From GESECRAN
Affzo [M:TRA7]
Return

#########
$SETBOUT7
Call VIREBOUT(CHMEN,"I=") From GOBJET

If [M:TRA0]LAN<>"" & [M:TRA0]LANREF<>"" & [M:TRA0]LAN<>[M:TRA0]LANREF
    CHBOU += "=" : # Raffraîchir
    If [M:TRA7]NBDOC>0
        CHBOU += "I" : # Impression
    Endif
Endif

Gosub SET_BOUT_SPE From GSAISIE
Return

####################
$EDIT7
    Local Char WLIBEL(250) : Raz WLIBEL
    Local Integer WNOLIBEL : Raz WNOLIBEL
    Local Integer OUVREAFC,OUVREATX
    If clalev([F:AFCW])=0 : Local File AFONCTION [AFCW] : OUVREAFC=1 : Endif
    If clalev([F:ATXW])=0 : Local File ATEXTE    [ATXW] : OUVREATX=1 : Endif
          WNOLIBEL= 0
          Read [F:AFCW]CODINT = "ADOCTRA7"
          If [S]fstat = 0
            WNOLIBEL = [F:AFCW]LIBMENU
            Read [F:ATXW]NUMERO=GLANGUE;WNOLIBEL
            If [S]fstat = 0
               WLIBEL= [F:ATXW]TEXTE
            Endif
          Endif
          If WLIBEL="" : WLIBEL="ADOCTRA" : Endif
    If OUVREAFC : Close File [AFCW] :  Endif
    If OUVREATX : Close File [ATXW] :  Endif

    Local Char TABMSK(GLONAMK)(1)
    Local Char TABABR(GLONABR)(1)
    #on les mets dans ce sens pour avoir les info regroupées
    TABMSK(0)="ADOCTRA7" : TABABR(0)="TRA7"
    Call PRTSCR(TABMSK,TABABR,WLIBEL,0,0) From ATRTX3
    Call IMPSCR From ATRTX3
Return

####################
$DEBUT6
$RAF6
Raz [M:TRA6]
[M:TRA6]ALLTYP=1
[M:TRA6]TYP=PARAM(1)
If PARAM(1)=""
    [M:TRA6]ALLTYP=2
Endif
[M:TRA6]ALLMOD=1
If PARAM(2)="-1"
    [M:TRA6]ALLMOD=2
Else
 [M:TRA6]MODULE=val(PARAM(2))
Endif
Local Integer ERR
Call TEMPON("L") From GESECRAN
Call CHARGE_TRA6([M:TRA0]LAN,ERR)
Call TEMPOFF From GESECRAN
Affzo [M:TRA6]
Return

#########
$SETBOUT6
Call VIREBOUT(CHMEN,"I=") From GOBJET

If [M:TRA0]LAN<>"" & [M:TRA0]LANREF<>"" & [M:TRA0]LAN<>[M:TRA0]LANREF
    CHBOU += "=" : # Raffraîchir
    If [M:TRA6]NBDOC>0
        CHBOU += "I" : # Impression
    Endif
Endif

Gosub SET_BOUT_SPE From GSAISIE
Return

####################
$EDIT6
    Local Char WLIBEL(250) : Raz WLIBEL
    Local Integer WNOLIBEL : Raz WNOLIBEL
    Local Integer OUVREAFC,OUVREATX
    If clalev([F:AFCW])=0 : Local File AFONCTION [AFCW] : OUVREAFC=1 : Endif
    If clalev([F:ATXW])=0 : Local File ATEXTE    [ATXW] : OUVREATX=1 : Endif
          WNOLIBEL= 0
          Read [F:AFCW]CODINT = "ADOCTRA6"
          If [S]fstat = 0
            WNOLIBEL = [F:AFCW]LIBMENU
            Read [F:ATXW]NUMERO=GLANGUE;WNOLIBEL
            If [S]fstat = 0
               WLIBEL= [F:ATXW]TEXTE
            Endif
          Endif
          If WLIBEL="" : WLIBEL="ADOCTRA" : Endif
    If OUVREAFC : Close File [AFCW] :  Endif
    If OUVREATX : Close File [ATXW] :  Endif

    Local Char TABMSK(GLONAMK)(1)
    Local Char TABABR(GLONABR)(1)
    #on les mets dans ce sens pour avoir les info regroupées
    TABMSK(0)="ADOCTRA6" : TABABR(0)="TRA6"
    Call PRTSCR(TABMSK,TABABR,WLIBEL,0,0) From ATRTX3
    Call IMPSCR From ATRTX3
Return


####################
$INIT5
If [M:TRA0]LANREF=[M:TRA0]LAN
    GERR = 1
    GMESSAGE = mess(54,176,1)
    FIN=1
    Return
Endif
Return
####################
$DEBUT5
$RAF5
Raz [M:TRA5]
Local Integer ERR
Call TEMPON("L") From GESECRAN
Call CHARGE_TRA5([M:TRA0]LAN,ERR)
Call TEMPOFF From GESECRAN
Affzo [M:TRA5]
Return

#########
$SETBOUT5
Call VIREBOUT(CHMEN,"I=") From GOBJET

If [M:TRA0]LAN<>"" & [M:TRA0]LANREF<>"" & [M:TRA0]LAN<>[M:TRA0]LANREF
    CHBOU += "=" : # Raffraîchir
    If [M:TRA5]NBTAB5>0
        CHBOU += "I" : # Impression
    Endif
Endif

Gosub SET_BOUT_SPE From GSAISIE
Return


####################
$EDIT5
    Local Char WLIBEL(250) : Raz WLIBEL
    Local Integer WNOLIBEL : Raz WNOLIBEL
    Local Integer OUVREAFC,OUVREATX
    If clalev([F:AFCW])=0 : Local File AFONCTION [AFCW] : OUVREAFC=1 : Endif
    If clalev([F:ATXW])=0 : Local File ATEXTE    [ATXW] : OUVREATX=1 : Endif
          WNOLIBEL= 0
          Read [F:AFCW]CODINT = "ADOCTRA"
          If [S]fstat = 0
            WNOLIBEL = [F:AFCW]LIBMENU
            Read [F:ATXW]NUMERO=GLANGUE;WNOLIBEL
            If [S]fstat = 0
               WLIBEL= [F:ATXW]TEXTE
            Endif
          Endif
          If WLIBEL="" : WLIBEL="ADOCTRA" : Endif
    If OUVREAFC : Close File [AFCW] :  Endif
    If OUVREATX : Close File [ATXW] :  Endif

    Local Char TABMSK(GLONAMK)(2)
    Local Char TABABR(GLONABR)(2)
    #on les mets dans ce sens pour avoir les info regroupées
    TABMSK(0)="ADOCTRA0" : TABABR(0)="TRA0"
    TABMSK(1)="ADOCTRA5" : TABABR(1)="TRA5"
    Call PRTSCR(TABMSK,TABABR,WLIBEL,0,0) From ATRTX3
    Call IMPSCR From ATRTX3
Return


####################
$INIT45
If [M:TRA0]LANREF=[M:TRA0]LAN
    GERR = 1
    GMESSAGE = mess(54,176,1)
    FIN=1
Endif
Return

####################
$INIT_DIA45
Raz [M:TRA4]
[M:TRA4]LAN=[M:TRA0]LAN
P_TYPDOC=PARAM(1)
P_CODDOC=PARAM(2)

# JPGA 09/04/2010 Bug-51883 : Appel à la procédure de recherche du Répertoire html ou xml d'extraction
Call INIT_REPERT_LAN([M:TRA4]REPERT, "xml") From AGENLIBA
# JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
Call INIT_ALLCREGRP("[M:TRA4]ALLCREGRP") From AGENLIBA
Return

####################
$EXEC45
# Traduction de documentations
TRA = 1
Call OUVRE_TRACE(mess(65,176,1))  From LECFIC
Call ECR_TRACE(mess(66,176,1)-":"-[M:TRA0]LAN-"-"-mess(67,176,1)-":"-[M:TRA0]LANREF,0) From GESECRAN
Call ECR_TRACE(string$(80,"*"),0) From GESECRAN
Call ECR_TRACE("",0)              From GESECRAN

[M:TRA4]LAN=[M:TRA0]LAN
V_LAN=[M:TRA0]LAN
V_LANREF=[M:TRA0]LANREF
If P_TYPDOC="" and P_CODDOC=""
    # on traite n doc et n champs
    Gosub TRAITE_N_DOC
    Gosub TRAITE_N_FLD
Elsif P_TYPDOC="" and P_CODDOC<>""
    # une aide sur champ
    Call TEMPON("") From GESECRAN
    V_TYPDOC=P_TYPDOC
    V_CODDOC=P_CODDOC
    Gosub TRAITE_UN_FLD
    Call TEMPOFF From GESECRAN
Else
    # une documentation
    Call TEMPON("") From GESECRAN
    V_TYPDOC=P_TYPDOC
    V_CODDOC=P_CODDOC
    Gosub TRAITE_UNE_DOC
    Call TEMPOFF From GESECRAN
Endif
Call ECR_TRACE("",0) From GESECRAN
Call FERME_TRACE From LECFIC
Return

####################
$TRAITE_N_DOC
Local Integer ERR,I,COUNT
Local Integer INTERRUPT : INTERRUPT=1

COUNT=0
For nolign=1 To [M:TRA2]NBDOC
  If [M:TRA2]PROFLG(nolign-1)=2
     COUNT+=1
  Endif
Next nolign

Call OUVRE_BOITE(mess(6,100,1),COUNT) From GESECRAN
COUNT=0
For nolign=1 To [M:TRA2]NBDOC
  I=nolign-1
  If [M:TRA2]PROFLG(nolign-1)=2
     COUNT+=1
     Call AFF_BOITE([M:TRA2]DOCTYP(I)-"/"-[M:TRA2]COD(I),COUNT,INTERRUPT ) From GESECRAN
     V_TYPDOC=[M:TRA2]DOCTYP(I)
     V_CODDOC=[M:TRA2]COD(I)
     Gosub TRAITE_UNE_DOC
  Endif
Next nolign

Call FERME_BOITE From GESECRAN
Return

####################
$TRAITE_UNE_DOC
   Call ECR_TRACE(string$(20,"*"),0) From GESECRAN
   Call ECR_TRACE("* ADO"+":"+V_LAN+"~"+V_TYPDOC+"~"+V_CODDOC,0) From GESECRAN

   #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
   If func AGENLIBA.TEST_GROUPE_OK("ADO", V_LAN, V_TYPDOC, V_CODDOC, "[M:TRA4]ALLCREGRP")
     Call TRAITE_GENE_COPIE(V_LAN, V_LANREF, V_TYPDOC, V_CODDOC,    "[M:TRA4]ALLCREGRP")
     Call TRAITE_EXTRACTION(V_LAN, V_LANREF, V_TYPDOC, V_CODDOC,    "[M:TRA4]ALLCREGRP")
   Endif
Return

Subprog TRAITE_GENE_COPIE(V_LAN, V_LANREF, V_TYPDOC, V_CODDOC, VALLCREGRP)
Value Char    V_LAN, V_LANREF, V_TYPDOC, V_CODDOC, VALLCREGRP
# V_LAN      = Langue de Traduction             . Exemple : V_LAN
# V_LANREF   = Langue de Référence              . Exemple : V_LANREF
# V_TYPDOC   = Type de Documentation            . Exemple : V_TYPDOC
# V_CODDOC   = Code Documentation               . Exemple : V_CODDOC
# VALLCREGRP = Zone contenant la zone ALLCREGRP . Exemple : "[M:TRA4]ALLCREGRP" ou "[V]V_ALLCREGRP"

   ## 1 - Génération dans la langue
   GABREV = ""
   Local Mask AGENDOC [DIA]
   Raz [M:DIA]
   [M:DIA]LAN = V_LAN
   #JPGA 25/03/2010 BUG-63570 : Génération Adocument ne se fait pas et renvoit un message en Espagnol. ALLLAN doit être initialisé
   [M:DIA]ALLLAN  = 1
   [M:DIA]ALLTYP  = 1
   [M:DIA]TYPEDOC = V_TYPDOC
   [M:DIA]FUNDEB  = V_CODDOC
   [M:DIA]FUNFIN  = V_CODDOC
   [M:DIA]GENDOC = 2 : # Toutes
   [M:DIA]GENFIN = 1 : # Non
   # JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
   Call TRANS_ALLCREGRP("[M:DIA]ALLCREGRP", VALLCREGRP) From AGENLIBA
   Call AGENADO From AGENADO
   Close Mask [DIA]

   ##2 - Copie
   Local Mask AGENLIB [DIA]
   Raz [M:DIA]
   [M:DIA]LANREF = V_LANREF
   [M:DIA]LAN = V_LAN
   [M:DIA]ALLTYP  = 1
   [M:DIA]TYP = V_TYPDOC
   [M:DIA]ALLCOD  = 1
   [M:DIA]CODDEB  = V_CODDOC
   [M:DIA]CODFIN  = V_CODDOC
   [M:DIA]HLPFIL  = 2
   [M:DIA]HLPLNKFLD = 2
   [M:DIA]HLPFLD  = 1
   # JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
   Call TRANS_ALLCREGRP("[M:DIA]ALLCREGRP", VALLCREGRP) From AGENLIBA
   Gosub EXEC From AGENLIBA
   Close Mask [DIA]
End

Subprog TRAITE_EXTRACTION(V_LAN, V_LANREF, V_TYPDOC, V_CODDOC, VALLCREGRP)
Value Char    V_LAN, V_LANREF, V_TYPDOC, V_CODDOC, VALLCREGRP
# V_LAN      = Langue de Traduction             . Exemple : V_LAN
# V_LANREF   = Langue de Référence              . Exemple : V_LANREF
# V_TYPDOC   = Type de Documentation            . Exemple : V_TYPDOC
# V_CODDOC   = Code Documentation               . Exemple : V_CODDOC
# VALLCREGRP = Zone contenant la zone ALLCREGRP . Exemple : "[M:TRA4]ALLCREGRP" ou "[V]V_ALLCREGRP"

   ## 3 - Extraction
   Local Mask ADOCEXT [DIA]
   Gosub INIT_DIA_ADOCTRA  From ADOCEXT

   ##VPO 05/12/07 BUG44457 special trad type=AD,AM,FI
   #If find(V_TYPDOC,"AD","FI","AM")<>0
   #[M:DIA]HLPFIL  = 2
   #Else
   #[M:DIA]HLPFIL  = 1
   #Endif
   #VPO 06/10/08 on extrait tous les fichiers liés à traduire
   [M:DIA]HLPFIL  = 2    :  [M:DIA]HLPLNKFLD = 2  :  [M:DIA]HLPFLD  = 1
   # JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
   Call TRANS_ALLCREGRP("[M:DIA]ALLCREGRP", VALLCREGRP) From AGENLIBA
   Gosub EXEC From ADOCEXT
   Close Mask [DIA]
End

####################
$TRAITE_N_FLD
Local Integer ERR,I,COUNT
Local Integer INTERRUPT : INTERRUPT=1

COUNT=0
For nolign=1 To [M:TRA3]NBFLD
  If [M:TRA3]PROFLG(nolign-1)=2
     COUNT+=1
  Endif
Next nolign

Call OUVRE_BOITE(mess(6,100,1),COUNT) From GESECRAN
COUNT=0
For nolign=1 To [M:TRA3]NBFLD
  I=nolign-1
  If [M:TRA3]PROFLG(nolign-1)=2
     COUNT+=1
     Call AFF_BOITE([M:TRA3]MOTCLE(I),COUNT,INTERRUPT ) From GESECRAN
     V_TYPDOC=""
     V_CODDOC=[M:TRA3]MOTCLE(I)
     Gosub TRAITE_UN_FLD
  Endif
Next nolign

Call FERME_BOITE From GESECRAN
Return

####################
$TRAITE_UN_FLD
   #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
   If func AGENLIBA.TEST_GROUPE_OK("ADZ", V_LAN, "", V_CODDOC, "[M:TRA4]ALLCREGRP")
     Call TRAITE_COPIE_FLD     (V_LAN, V_LANREF   , V_CODDOC, "[M:TRA4]ALLCREGRP")
     Call TRAITE_EXTRACTION_FLD(V_LAN, V_LANREF   , V_CODDOC, "[M:TRA4]ALLCREGRP")
   Endif
Return

Subprog TRAITE_COPIE_FLD(V_LAN, V_LANREF, V_CODDOC, VALLCREGRP)
Value Char    V_LAN, V_LANREF, V_CODDOC, VALLCREGRP
# V_LAN       = Langue de Traduction             . Exemple : V_LAN
# V_LANREF    = Langue de Référence              . Exemple : V_LANREF
# V_CODDOC    = Code Documentation               . Exemple : V_CODDOC
# VALLCREGRP  = Zone contenant la zone ALLCREGRP . Exemple : "[M:TRA4]ALLCREGRP" ou "[V]V_ALLCREGRP"

   ##1 - Copie
   Local Mask AGENLIB [DIA]
   Raz [M:DIA]
   [M:DIA]LANREF = V_LANREF
   [M:DIA]LAN = V_LAN
   [M:DIA]ALLTYP  = 1
   [M:DIA]TYP = ""
   [M:DIA]ALLCOD  = 1
   [M:DIA]CODDEB  = ""
   [M:DIA]CODFIN  = ""
   [M:DIA]HLPFIL  = 1
   [M:DIA]HLPLNKFLD = 1
   [M:DIA]HLPFLD  = 2
   [M:DIA]FLDDEB  = V_CODDOC
   [M:DIA]FLDFIN  = V_CODDOC

   # JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
   Call TRANS_ALLCREGRP("[M:DIA]ALLCREGRP", VALLCREGRP) From AGENLIBA
   Gosub EXEC From AGENLIBA
   Close Mask [DIA]
End

Subprog TRAITE_EXTRACTION_FLD(V_LAN, V_LANREF, V_CODDOC, VALLCREGRP)
Value Char    V_LAN, V_LANREF, V_CODDOC, VALLCREGRP
# V_LAN       = Langue de Traduction             . Exemple : V_LAN
# V_LANREF    = Langue de Référence              . Exemple : V_LANREF
# V_CODDOC    = Code Documentation               . Exemple : V_CODDOC
# VALLCREGRP  = Zone contenant la zone ALLCREGRP . Exemple : "[M:TRA4]ALLCREGRP" ou "[V]V_ALLCREGRP"

   ## 2 - Extraction
   Local Mask ADOCEXT [DIA]
   Gosub INITFLD_DIA_ADOCTRA  From ADOCEXT
   # JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
   Call TRANS_ALLCREGRP("[M:DIA]ALLCREGRP", VALLCREGRP) From AGENLIBA
   Gosub EXEC From ADOCEXT
   Close Mask [DIA]
End


####################
$TERMINE45
Default Mask [M:TRA0]
#Gosub ACTUALISER
Return

####################
$DEBUT
Raz [M:TRA0]
Raz [M:TRA1]
Raz [M:TRA2]
Raz [M:TRA3]
#JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
Call AFFMASK_GROUPE("[M:TRA2]CREGRP") From AGENLIBA
Call AFFMASK_GROUPE("[M:TRA3]CREGRP") From AGENLIBA

Local Char    WLANREF(250)
Call PARAMUTIL("LANREF",WLANREF,"","") From SUBAUS
[M:TRA0]LANREF=WLANREF
If [M:TRA0]LANREF="" : [M:TRA0]LANREF=GLANDEF : Endif
Affzo [M:TRA0]LANREF

Local Char    WLANTRA(250)
Call PARAMUTIL("LANTRA",WLANTRA,"","") From SUBAUS
[M:TRA0]LAN=WLANTRA
If [M:TRA0]LAN="" : [M:TRA0]LAN=GLANGUE : Endif
If [M:TRA0]LAN=[M:TRA0]LANREF : [M:TRA0]LAN="ENG" : Endif
Affzo [M:TRA0]LAN

# TCH 30/05/2012 DM-78020 : Faire disparaitre "Prise en compte des traductions 140 importées" et ne plus en tenir compte car n'a plus d'utilité
## VPO 11/02/08 BUG45674 correct test sur sophia_gaillard
#If GSOPHIA |
#& filinfo(filpath("","sophia_gaillard","",adxmother(1)),0)>0 |
#& filinfo(filpath("","sophia_gaillard","",adxmother(0)),0)>0
# [M:TRA0]TRA140=2
# Affzo [M:TRA0]TRA140
# #saisissable
# Chgfmt [M:TRA0]TRA140 With "LA:1X"
#Else
# [M:TRA0]TRA140=1
# Affzo [M:TRA0]TRA140
# #invisible
# Chgfmt [M:TRA0]TRA140 With "-K:1X"
#Endif

### supp car trop long
###If [M:TRA0]LAN<>"" : Gosub ACTUALISER : Endif

$AFFDEBUT
# JPGA - 03-03-2009 - BUG-52997 : Ne pas permettre la saisie à vide dy TYPE de doc et initialiser ALLTYP à TRUE.
[M:TRA2]ALLTYP=2
Effzo [M:TRA2]TYP
Grizo [M:TRA2]TYP
[M:TRA2]ALLMOD=2
Effzo [M:TRA2]MODULE
Grizo [M:TRA2]MODULE
[M:TRA2]EXCMOD=1
Effzo [M:TRA2]MODTOEXC
Grizo [M:TRA2]MODTOEXC
#JPGA 03/06/2010 BUG-64550: Implémentation Priorisation de documentation pour la Traduction. Affichage Priorité dans Plan de travail
[M:TRA2]ALLPRIO=2
Effzo [M:TRA2]PRIOTRA
Grizo [M:TRA2]PRIOTRA
[M:TRA3]ALLPRIO=2
Effzo [M:TRA3]PRIOTRA
Grizo [M:TRA3]PRIOTRA
[M:TRA3]ALLMOD=2
Effzo [M:TRA3]MODULE
Grizo [M:TRA3]MODULE
[M:TRA3]EXCMOD=1
Effzo [M:TRA3]MODTOEXC
Grizo [M:TRA3]MODTOEXC

Call AM_ALLTYP([M:TRA2]ALLTYP)
Call AM_ALLCOD([M:TRA2]ALLCOD)
Call AM_ALLFLD([M:TRA3]ALLFLD)

Affzo [M:TRA1]
Affzo [M:TRA2]
Affzo [M:TRA3]

Return

####################
$BOUTON
Case BOUT
   When "A" : Gosub ACTUALISER
   When "R" : Gosub RECHERCHER_DOC
   When "V" : Gosub RECHERCHER_FLD
Endcase
Return

#########
$SETBOUT
Call VIREBOUT(CHMEN,"ADIRVE") From GOBJET

If [M:TRA0]LAN<>""
    CHMEN += "A" : # Actualiser
    CHBOU += "=" : # Raffraîchir
    CHMEN += "D" : # Actualiser
    If [M:TRA1]NBTAB3>0 | [M:TRA2]NBDOC>0 | [M:TRA3]NBFLD>0
        CHBOU += "I" : # Impression
    Endif
    CHMEN += "R" : # Recherche des documentations
    CHMEN += "V" : # Recherche des aides sur champs

    NODOC=find(2,[M:TRA2]PROFLG(0..[M:TRA2]NBDOC-1))
    If NODOC<>0
       CHMEN+="E" : # Traiter
    Else
        NOFLD=find(2,[M:TRA3]PROFLG(0..[M:TRA3]NBFLD-1))
        If NOFLD<>0
           CHMEN+="E" : # Traiter
        Endif
    Endif
Endif

Gosub SET_BOUT_SPE From GSAISIE
Return


####################
$EDIT
    Local Char WLIBEL(250) : Raz WLIBEL
    Local Integer WNOLIBEL : Raz WNOLIBEL
    Local Integer OUVREAFC,OUVREATX
    If clalev([F:AFCW])=0 : Local File AFONCTION [AFCW] : OUVREAFC=1 : Endif
    If clalev([F:ATXW])=0 : Local File ATEXTE    [ATXW] : OUVREATX=1 : Endif
          WNOLIBEL= 0
          Read [F:AFCW]CODINT = "ADOCTRA"
          If [S]fstat = 0
            WNOLIBEL = [F:AFCW]LIBMENU
            Read [F:ATXW]NUMERO=GLANGUE;WNOLIBEL
            If [S]fstat = 0
               WLIBEL= [F:ATXW]TEXTE
            Endif
          Endif
          If WLIBEL="" : WLIBEL="ADOCTRA" : Endif
    If OUVREAFC : Close File [AFCW] :  Endif
    If OUVREATX : Close File [ATXW] :  Endif

    Local Char TABMSK(GLONAMK)(4)
    Local Char TABABR(GLONABR)(4)
    #on les mets dans ce sens pour avoir les info regroupées
    TABMSK(0)="ADOCTRA0" : TABABR(0)="TRA0"
    TABMSK(1)="ADOCTRA1" : TABABR(1)="TRA1"
    TABMSK(2)="ADOCTRA2" : TABABR(2)="TRA2"
    TABMSK(3)="ADOCTRA3" : TABABR(3)="TRA3"
    Call PRTSCR(TABMSK,TABABR,WLIBEL,0,0) From ATRTX3
    Call IMPSCR From ATRTX3
Return

####################
$RAF
$ACTUALISER
Local Integer ERR
Call TEMPON("L") From GESECRAN
Call CHARGE_TRA1([M:TRA0]LAN,ERR)
Call TEMPOFF From GESECRAN
Affzo [M:TRA1]
Return

$RECHERCHER_DOC
Local Integer ERR
Call TEMPON("L") From GESECRAN
Call CHARGE_TRA2(ERR)
Affzo [M:TRA2]
Call TEMPOFF From GESECRAN
Return

$RECHERCHER_FLD
Local Integer ERR
Call TEMPON("L") From GESECRAN
Call CHARGE_TRA3(ERR)
Affzo [M:TRA3]
Call TEMPOFF From GESECRAN
Return

###################################################################################################
###################################################################################################
$ERR_SQL_TRA
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ERREUR(GMESSAGE) From GESECRAN
ERR=1
End


###################################################################################################
# CHARGE_TRA7 : Bouton du détails des Documentations traduites dans l'onglet ADOCTRA7
###################################################################################################
Subprog CHARGE_TRA7(CLAN,ERR)
Variable Char  CLAN()
Variable Integer ERR

If [M:TRA0]LANREF=CLAN
    Call ERREUR(mess(63,176,1)) From GESECRAN
    End
Endif

Local Integer V_MAXLIG : V_MAXLIG=1000
Local Char REF_TIT(100), DOC_ANOMALIE(10)
Local Date REF_VLDDAT, LAN_VLDDAT
Local Integer DOC_EXIST, DOC_ERR, DOC_INVALID, NB_VLD, NB_VLDTOT, NB_VLDREF, NB_VLDREFTOT
Local Char SQLREQ (250) (3)
Local Char VAPPREFOLD(30) : Raz VAPPREFOLD
Local Integer VMODULE

If clalev([AMZ2])=0 : Local File AMSKZON [AMZ2] : Endif
# Issue 75246/7 - 2012-06-29 by VPO : mot clé d'aide
If clalev([AMC2])=0  : Local File AMOTCLE [AMC2] : Endif
Read [AMZ2]CODE="ADOCTRA7";"DOCTYP"
If [S]fstat = 0
    V_MAXLIG=[AMZ2]DIME
Endif

Gosub SET_FIRST From TRTFIRST
Onerrgo ERR_SQL_TRA

If clalev([ZDO1])<>0 : Close File [ZDO1]  : Endif
If clalev([ZDO1])=0 : Local File ADOCUMENT [ZDO1] : Endif

#JPGA 14/04/2011 BUG-71587: Pas de traduction pour las DOCS de type MC qui sont Crées/Gérées Manuellement par l'Industrialisation
Gosub DOC_INTRADUISIBLES

#JPGA 03/06/2010 BUG-64550: Implémentation Priorisation de documentation pour la Traduction. Affichage Priorité dans Plan de travail
Raz SQLREQ
SQLREQ(0) = "SELECT DISTINCT A.TYP_0,A.COD_0,'"+nomap+"' FROM "+nomap+".ADOCUMENT A"
SQLREQ(0) -= "WHERE A.LAN_0='"+[M:TRA0]LANREF+"' AND A.TYP_0 NOT IN ("+[L]DOC_NONTRA+")"
SQLREQ(0) -=string$( [M:TRA7]ALLTYP=1,"AND A.TYP_0='"+[M:TRA7]TYP+"'" )
If GDOSX3<>nomap
  SQLREQ(0) -= "UNION"
  SQLREQ(1) -= "SELECT DISTINCT B.TYP_0,B.COD_0,'"+GDOSX3+"' FROM "+GDOSX3+".ADOCUMENT B"
  SQLREQ(1) -= "WHERE B.LAN_0='"+[M:TRA0]LANREF+"' AND B.TYP_0 NOT IN ("+[L]DOC_NONTRA+")"
  SQLREQ(1) -=string$( [M:TRA7]ALLTYP=1,"AND B.TYP_0='"+[M:TRA7]TYP+"'" )
  SQLREQ(2) -= "AND NOT EXISTS (SELECT 'X' FROM "+nomap+".ADOCUMENT A WHERE A.LAN_0=B.LAN_0 AND A.TYP_0=B.TYP_0 AND A.COD_0=B.COD_0)"
Endif
SQLREQ(2) -="ORDER BY 1,2"

For (Char VTYP(10),Char VCOD(30),Char VAPPREF(30)) From num$((GTYPDBA*2)+1)  Sql SQLREQ  As [ZDO0]
    # on boucle sur TYP+COD pour la langue de ref
    If VAPPREFOLD<>[ZDO0]VAPPREF
        If clalev([ZDO2])<>0 : Close File [ZDO2] : Endif
        If clalev([ZDO2])=0  : Local File =[ZDO0]VAPPREF+".ADOCUMENT" [ZDO2] : Endif
        If clalev([ZDZ2])<>0 : Close File [ZDZ2]  : Endif
        If clalev([ZDZ2])=0  : Local File =[ZDO0]VAPPREF+".ADOCFLD"   [ZDZ2] : Endif
    Endif
    # on recupere le module
    Read [ZDO2]ADO0=[M:TRA0]LANREF;[ZDO0]VTYP;[ZDO0]VCOD
    VMODULE = [ZDO2]MODULE

    DOC_EXIST=1 : DOC_ERR=0 : DOC_INVALID=0 : DOC_ANOMALIE="" : REF_TIT="" : REF_VLDDAT = [0/0/0] : LAN_VLDDAT = [0/0/0]
    If [M:TRA7]ALLMOD=1 & [M:TRA7]MODULE<>VMODULE
        # on ne prend pas la doc car pas le bon module
        DOC_ERR=8
    Else
        Call RECHERCHE_VALIDATION(CLAN, REF_TIT, REF_VLDDAT, LAN_VLDDAT, DOC_INVALID, DOC_EXIST, DOC_ANOMALIE, DOC_ERR)
        If DOC_INVALID
           DOC_ERR=9
        Endif
    Endif

    If DOC_ERR<=0
        [M:TRA7]NBDOC +=1
        [M:TRA7]DOCTYP([M:TRA7]NBDOC-1)  =[ZDO0]VTYP
        [M:TRA7]COD([M:TRA7]NBDOC-1)     =[ZDO0]VCOD
        [M:TRA7]TIT([M:TRA7]NBDOC-1)     =REF_TIT
        [M:TRA7]MODULE2([M:TRA7]NBDOC-1) =VMODULE
        [M:TRA7]CREDAT([M:TRA7]NBDOC-1)  =[ZDO2]CREDAT
        [M:TRA7]TRADAT([M:TRA7]NBDOC-1)  =[ZDO1]UPDDAT
        [M:TRA7]FLDDOC([M:TRA7]NBDOC-1)  =0
        # Issue 75246/7 - 2012-06-29 by VPO : mot clé d'aide
#        Link [AMZ2] With [ZDO2]ADO0(3)=[M:TRA0]LANREF;[ZDO0]VTYP;[ZDO0]VCOD, [ZDZ2]ADZ0(1)=[M:TRA0]LANREF As [AZZ]
#&                  Where [AMZ2]CODMSK=[ZDO2]MSK and [AMZ2]MOTCLE=[ZDZ2]MOTCLE
#&               Order By MOTCLE

        Link [AMC2] With [ZDO2]ADO0(3)=[M:TRA0]LANREF;[ZDO0]VTYP;[ZDO0]VCOD, [ZDZ2]ADZ0(1)=[M:TRA0]LANREF As [AZZ]
&                  Where [AMC2]TYPZON=2 & [AMC2]IDENT1=[ZDO2]MSK & [AMC2]MOTCLE=[ZDZ2]MOTCLE
&               Order By [AMC2]MOTCLE

        For [AZZ]
           [M:TRA7]FLDDOC([M:TRA7]NBDOC-1)+=1
        Next
        If ![ZDO2]PRIO
           [M:TRA7]PRIO([M:TRA7]NBDOC-1) =1
        Else
           [M:TRA7]PRIO([M:TRA7]NBDOC-1) =[ZDO2]PRIO
        Endif
        [M:TRA7]ANOMALIE([M:TRA7]NBDOC-1)=DOC_ANOMALIE
    Endif

    VAPPREFOLD=[ZDO0]VAPPREF
Next ZDO0

[M:TRA7]TOTAL = [M:TRA7]NBDOC

If clalev([ZDO1])<>0 : Close File [ZDO1] : Endif
If clalev([ZDO2])<>0 : Close File [ZDO2] : Endif

Sorta [M:TRA7]NBDOC [M:TRA7]NBDOC
Gosub UNSET_FIRST From TRTFIRST
Onerrgo
End


###################################################################################################
# CHARGE_TRA6 : Bouton du détails des Documentation non validées dans l'onglet ADOCTRA6
###################################################################################################
Subprog CHARGE_TRA6(CLAN,ERR)
Variable Char  CLAN()
Variable Integer ERR

If [M:TRA0]LANREF=CLAN
    Call ERREUR(mess(63,176,1)) From GESECRAN
    End
Endif

Local Integer V_MAXLIG : V_MAXLIG=1000
If clalev([AMZ2])=0 : Local File AMSKZON [AMZ2] : Endif
# Issue 75246/7 - 2012-06-29 by VPO : mot clé d'aide
If clalev([AMC2])=0  : Local File AMOTCLE [AMC2] : Endif
Read [AMZ2]CODE="ADOCTRA6";"DOCTYP"
If [S]fstat = 0
    V_MAXLIG=[AMZ2]DIME
Endif


Gosub SET_FIRST From TRTFIRST

Onerrgo ERR_SQL_TRA

If clalev([ZDO1])<>0 : Close File [ZDO1] : Endif
If clalev([ZDO1])=0 : Local File ADOCUMENT [ZDO1] : Endif

#JPGA 14/04/2011 BUG-71587: Pas de traduction pour las DOCS de type MC qui sont Crées/Gérées Manuellement par l'Industrialisation
Gosub DOC_INTRADUISIBLES

Local Char SQLREQ (250) (3) : Raz SQLREQ
SQLREQ(0) = "SELECT DISTINCT A.TYP_0,A.COD_0,'"+nomap+"' FROM "+nomap+".ADOCUMENT A"
SQLREQ(0) -= "WHERE A.LAN_0='"+[M:TRA0]LANREF+"' AND A.TYP_0 NOT IN ("+[L]DOC_NONTRA+")"
SQLREQ(0) -=string$( [M:TRA6]ALLTYP=1,"AND A.TYP_0='"+[M:TRA6]TYP+"'" )
If GDOSX3<>nomap
SQLREQ(0) -= "UNION"
SQLREQ(1) -= "SELECT DISTINCT B.TYP_0,B.COD_0,'"+GDOSX3+"' FROM "+GDOSX3+".ADOCUMENT B"
SQLREQ(1) -= "WHERE B.LAN_0='"+[M:TRA0]LANREF+"' AND B.TYP_0 NOT IN ("+[L]DOC_NONTRA+")"
SQLREQ(1) -=string$( [M:TRA6]ALLTYP=1,"AND B.TYP_0='"+[M:TRA6]TYP+"'" )
SQLREQ(2) -= "AND NOT EXISTS (SELECT 'X' FROM "+nomap+".ADOCUMENT A WHERE A.LAN_0=B.LAN_0 AND A.TYP_0=B.TYP_0 AND A.COD_0=B.COD_0)"
Endif
SQLREQ(2) -="ORDER BY 1,2"

Local Char REF_TIT(100)
Local Char VAPPREFOLD(30) : Raz VAPPREFOLD
Local Integer VMODULE
For (Char VTYP(10),Char VCOD(30),Char VAPPREF(30)) From num$((GTYPDBA*2)+1) Sql SQLREQ
&        As [ZDO0]
    # on boucle sur TYP+COD pour la langue de ref
    If VAPPREFOLD<>[ZDO0]VAPPREF
        If clalev([ZDO2])<>0 : Close File [ZDO2] : Endif
        If clalev([ZDO2])=0 : Local File =[ZDO0]VAPPREF+".ADOCUMENT" [ZDO2] : Endif
    Endif
    # on recupere le module
    Read [ZDO2]ADO0=[M:TRA0]LANREF;[ZDO0]VTYP;[ZDO0]VCOD
    VMODULE = [ZDO2]MODULE

    VLDREF=1
    REF_TIT=""
    DOC_ERR=0

    If [M:TRA6]ALLMOD=1 & [M:TRA6]MODULE<>VMODULE
        # on ne prend pas la doc car pas le bon module
        DOC_ERR=-1
    Endif

    If DOC_ERR=0
        #On boucle ensuite sur les paragraphes de la langue de ref
        For [ZDO2] Where LAN=[M:TRA0]LANREF and TYP=[ZDO0]VTYP and COD=[ZDO0]VCOD
            If [ZDO2]PAR="TIT" : REF_TIT=[ZDO2]TIT : Endif
            #la doc n'est pas validée si un paragraphe n'est pas valide
            If [ZDO2]VLDDAT=[0/0/0] or [ZDO2]VLDFLG<>2
                VLDREF=-1 : Break
            Endif
        Next ZDO2
        If VLDREF=-1
            If [M:TRA6]NBDOC >= V_MAXLIG
                Call MESSAGE(mess(41,176,1)+":"-mess(56,176,1)-num$(V_MAXLIG)) From GESECRAN
                Break
            Endif
            [M:TRA6]NBDOC +=1
            [M:TRA6]DOCTYP([M:TRA6]NBDOC-1)=[ZDO0]VTYP
            [M:TRA6]COD([M:TRA6]NBDOC-1)=[ZDO0]VCOD
            [M:TRA6]TIT([M:TRA6]NBDOC-1)=REF_TIT
            #JPGA 03/06/2010 BUG-64550: Implémentation Priorisation de documentation pour la Traduction. Affichage Priorité dans Plan de travail
            If ![ZDO2]PRIO
               [M:TRA6]PRIO([M:TRA6]NBDOC-1)     = 1
            Else
               [M:TRA6]PRIO([M:TRA6]NBDOC-1)     = [ZDO2]PRIO
            Endif
        Endif
    Endif
    VAPPREFOLD=[ZDO0]VAPPREF
Next ZDO0
[M:TRA6]TOTAL = [M:TRA6]NBDOC

If clalev([ZDO1])<>0 : Close File [ZDO1] : Endif
If clalev([ZDO2])<>0 : Close File [ZDO2] : Endif

Sorta [M:TRA6]NBDOC [M:TRA6]NBDOC

Gosub UNSET_FIRST From TRTFIRST

Onerrgo

End


###################################################################################################
# CHARGE_TRA5 : Bouton Détail pas module dans l'onglet ADOCTRA5
###################################################################################################
Subprog CHARGE_TRA5(CLAN,ERR)
Variable Char  CLAN()
Variable Integer ERR

If [M:TRA0]LANREF=CLAN
    Call ERREUR(mess(63,176,1)) From GESECRAN
    End
Endif

Local Char REF_TIT(100), DOC_ANOMALIE(10)
Local Date REF_VLDDAT, LAN_VLDDAT
Local Integer DOC_EXIST, DOC_ERR, DOC_INVALID
Local Char SQLREQ (250) (3)
Local Char VAPPREFOLD(30)
Local Integer VMODULE

Gosub SET_FIRST From TRTFIRST

Raz [M:TRA5]
Onerrgo ERR_SQL_TRA

If clalev([ZDO1])<>0 : Close File [ZDO1] : Endif
If clalev([ZDO1])=0 : Local File ADOCUMENT [ZDO1] : Endif

#JPGA 14/04/2011 BUG-71587: Pas de traduction pour las DOCS de type MC qui sont Crées/Gérées Manuellement par l'Industrialisation
Gosub DOC_INTRADUISIBLES

Raz SQLREQ
SQLREQ(0) = "SELECT DISTINCT A.TYP_0,A.COD_0,'"+nomap+"' FROM "+nomap+".ADOCUMENT A"
SQLREQ(0) -= "WHERE A.LAN_0='"+[M:TRA0]LANREF+"' AND A.TYP_0 NOT IN ("+[L]DOC_NONTRA+")"
If GDOSX3<>nomap
  SQLREQ(0) -= "UNION"
  SQLREQ(1) -= "SELECT DISTINCT B.TYP_0,B.COD_0,'"+GDOSX3+"' FROM "+GDOSX3+".ADOCUMENT B"
  SQLREQ(1) -= "WHERE B.LAN_0='"+[M:TRA0]LANREF+"' AND B.TYP_0 NOT IN ("+[L]DOC_NONTRA+")"
  SQLREQ(2) -= "AND NOT EXISTS (SELECT 'X' FROM "+nomap+".ADOCUMENT A WHERE A.LAN_0=B.LAN_0 AND A.TYP_0=B.TYP_0 AND A.COD_0=B.COD_0)"
Endif
SQLREQ(2) -="ORDER BY 1,2"

Raz VAPPREFOLD
For (Char VTYP(10),Char VCOD(30),Char VAPPREF(30)) From num$((GTYPDBA*2)+1)  Sql SQLREQ  As [ZDO0]
    # on boucle sur TYP+COD pour la langue de ref
    If VAPPREFOLD<>[ZDO0]VAPPREF
        If clalev([ZDO2])<>0 : Close File [ZDO2] : Endif
        If clalev([ZDO2])=0 : Local File =[ZDO0]VAPPREF+".ADOCUMENT" [ZDO2] : Endif
    Endif
    # on recupere le module
    Read [ZDO2]ADO0=[M:TRA0]LANREF;[ZDO0]VTYP;[ZDO0]VCOD
    VMODULE = [ZDO2]MODULE

    DOC_EXIST=1 : DOC_ERR=0 : DOC_INVALID=0 : DOC_ANOMALIE="" : REF_TIT="" : REF_VLDDAT = [0/0/0] : LAN_VLDDAT = [0/0/0]
    I=0
    For I=0 To [M:TRA5]NBTAB5-1
        If [M:TRA5]TYPDOC(I)=[ZDO0]VTYP & [M:TRA5]MODULE(I)=VMODULE : Break : Endif
    Next I
    If I=[M:TRA5]NBTAB5
        [M:TRA5]TYPDOC(I)=[ZDO0]VTYP
        [M:TRA5]MODULE (I)=VMODULE
        [M:TRA5]NBTAB5+=1
        # on fait un for car il peut y avoir des doc en plus
        For [ZDO1]ADO0(3) Where LAN=CLAN and TYP=[ZDO0]VTYP
            If [ZDO1]MODULE=VMODULE
                [M:TRA5]TOTLAN(I)+=1
            Endif
        Next ZDO1
    Endif
    [M:TRA5]TOTLANREF(I)+=1

    VLDREF=1
    OKTRAD=1
    ATRAD=0
    DOC_ERR=0

    Call RECHERCHE_VALIDATION(CLAN, REF_TIT, REF_VLDDAT, LAN_VLDDAT, DOC_INVALID, DOC_EXIST, DOC_ANOMALIE, DOC_ERR)
    If DOC_INVALID
       VLDREF-=1
       OKTRAD-=1
    Endif
    If DOC_ERR>0
        ATRAD+=1
       OKTRAD-=1
    Endif
    [M:TRA5]VLDLANREF(I)+=VLDREF
    [M:TRA5]NUMTRA(I)+=OKTRAD
    [M:TRA5]NUMFORTRA(I)+=ATRAD
    VAPPREFOLD=[ZDO0]VAPPREF
Next ZDO0

If clalev([ZDO1])<>0 : Close File [ZDO1] : Endif
If clalev([ZDO2])<>0 : Close File [ZDO2] : Endif

Sorta [M:TRA5]NBTAB5 [M:TRA5]NBTAB5

Gosub UNSET_FIRST From TRTFIRST
Onerrgo
End


###################################################################################################
# CHARGE_TRA1 : Avancement de la Traduction dans l'onglet ADOCTRA1
###################################################################################################
Subprog CHARGE_TRA1(CLAN,ERR)
Variable Char  CLAN()
Variable Integer ERR

If [M:TRA0]LANREF=CLAN
    Call ERREUR(mess(63,176,1)) From GESECRAN
    End
Endif

Local Char V_FLDTXTORI (250)
Local Char W_FLDTXTLAN (250)
Local Char VAPPREFOLD(30) : Raz VAPPREFOLD
Local Integer VMODULE
Local Char REF_TIT(100), DOC_ANOMALIE(10)
Local Date REF_VLDDAT, LAN_VLDDAT
Local Integer DOC_EXIST, DOC_INVALID, WDOC3ERR

Gosub SET_FIRST From TRTFIRST

Raz [M:TRA1]
Onerrgo ERR_SQL_TRA

WTOTREF3=0
WTOTLAN3=0
WVLDREF3=0
WOKTRADDOC3=0
WATRADDOC3=0
WDOC3ERR=0

WTOTLAN1=0
WTOTREF1=0
WVLDLAN1=0
WVLDREF1=0
WOKTRADDOC1=0
WATRADDOC1=0

############################################
# on recherche toutes les infos sur les doc
############################################
If clalev([ZDO1])<>0 : Close File [ZDO1] : Endif
If clalev([ZDO1])=0 : Local File ADOCUMENT [ZDO1] : Endif

#JPGA 14/04/2011 BUG-71587: Pas de traduction pour las DOCS de type MC qui sont Crées/Gérées Manuellement par l'Industrialisation
Gosub DOC_INTRADUISIBLES

Local Char SQLREQ (250) (3) : Raz SQLREQ
SQLREQ(0) = "SELECT DISTINCT A.TYP_0,A.COD_0,'"+nomap+"' FROM "+nomap+".ADOCUMENT A"
SQLREQ(0) -= "WHERE A.LAN_0='"+[M:TRA0]LANREF+"' AND A.TYP_0 NOT IN ("+[L]DOC_NONTRA+")"
If GDOSX3<>nomap
  SQLREQ(0) -= "UNION"
  SQLREQ(1) -= "SELECT DISTINCT B.TYP_0,B.COD_0,'"+GDOSX3+"' FROM "+GDOSX3+".ADOCUMENT B"
  SQLREQ(1) -= "WHERE B.LAN_0='"+[M:TRA0]LANREF+"' AND B.TYP_0 NOT IN ("+[L]DOC_NONTRA+")"
  SQLREQ(2) -= "AND NOT EXISTS (SELECT 'X' FROM "+nomap+".ADOCUMENT A WHERE A.LAN_0=B.LAN_0 AND A.TYP_0=B.TYP_0 AND A.COD_0=B.COD_0)"
Endif
SQLREQ(2) -="ORDER BY 1,2"

For (Char VTYP(10),Char VCOD(30),Char VAPPREF(30)) From num$((GTYPDBA*2)+1)  Sql SQLREQ  As [ZDO0]
    # on boucle sur TYP+COD pour la langue de ref
    If VAPPREFOLD<>[ZDO0]VAPPREF
        If clalev([ZDO2])<>0 : Close File [ZDO2] : Endif
        If clalev([ZDO2])=0 : Local File =[ZDO0]VAPPREF+".ADOCUMENT" [ZDO2] : Endif
    Endif

    DOC_EXIST=1 : DOC_INVALID=0 : DOC_ANOMALIE="" : REF_TIT="" : REF_VLDDAT = [0/0/0] : LAN_VLDDAT = [0/0/0]
    I=0
    For I=0 To [M:TRA1]NBTAB3-1
        If [M:TRA1]TYPDOC(I)=[ZDO0]VTYP : Break : Endif
    Next I
    WTOTREF3=0
    WTOTLAN3=0
    WVLDREF3=0
    WOKTRADDOC3=0
    WATRADDOC3=0

    If I=[M:TRA1]NBTAB3
        [M:TRA1]TYPDOC(I)=[ZDO0]VTYP
        [M:TRA1]NBTAB3+=1
        # on fait un for car il peut y avoir des doc en plus
        For [ZDO1]ADO0(3) Where LAN=CLAN and TYP=[ZDO0]VTYP
            WTOTLAN3+=1
            WTOTLAN1+=1
            WVLDLAN1+=1
        Next ZDO1
        #la doc n'est pas valide si un paragraphe n'est pas valide
        For [ZDO1]ADO0(3) Where LAN=CLAN and TYP=[ZDO0]VTYP and (VLDDAT=[0/0/0] or VLDFLG<>2 )
            WVLDLAN1-=1
        Next ZDO1
    Endif

    ###
    WDOC3ERR=0
    WTOTREF1+=1
    WTOTREF3+=1
    WVLDREF1+=1
    WVLDREF3+=1
    WOKTRADDOC3+=1
    WOKTRADDOC1+=1
    Call RECHERCHE_VALIDATION(CLAN, REF_TIT, REF_VLDDAT, LAN_VLDDAT, DOC_INVALID, DOC_EXIST, DOC_ANOMALIE, WDOC3ERR)
    If DOC_INVALID
       WVLDREF3-=1
       WVLDREF1-=1
       WOKTRADDOC3-=1
       WOKTRADDOC1-=1
    Endif
    If WDOC3ERR>0
        WATRADDOC3+=1
        WATRADDOC1+=1
        WOKTRADDOC3-=1
        WOKTRADDOC1-=1
    Endif
    [M:TRA1]TOTLANREF(I)+=WTOTREF3
    [M:TRA1]TOTLAN(I)+=WTOTLAN3
    [M:TRA1]VLDLANREF(I)+=WVLDREF3
    [M:TRA1]NUMTRA(I)+=WOKTRADDOC3
    [M:TRA1]NUMFORTRA(I)+=WATRADDOC3
    VAPPREFOLD=[ZDO0]VAPPREF
Next ZDO0

If clalev([ZDO1])<>0 : Close File [ZDO1] : Endif
If clalev([ZDO2])<>0 : Close File [ZDO2] : Endif

Sorta [M:TRA1]NBTAB3 [M:TRA1]NBTAB3

###############################################
# on recherche toutes les infos sur les champs
###############################################
If clalev([ZDZ2])<>0 : Close File [ZDZ2] : Endif
If clalev([ZDZ2])=0 : Local File ADOCFLD [ZDZ2] : Endif
If clalev([ZDZ3])<>0 : Close File [ZDZ3] : Endif
If clalev([ZDZ3])=0 : Local File =GDOSX3+".ADOCFLD" [ZDZ3] : Endif

WTOTLANFLD=0
WTOTREFFLD=0
WATRADFLD1=0
WOKTRADFLD1=0
WDOCERRFLD=0

Raz SQLREQ
SQLREQ(0) = "SELECT DISTINCT A.MOTCLE_0,'"+nomap+"' FROM "+nomap+".ADOCFLD A"
SQLREQ(0) -= "WHERE A.LAN_0='"+[M:TRA0]LANREF+"'"
If GDOSX3<>nomap
  SQLREQ(0) -= "UNION"
  SQLREQ(1) -= "SELECT DISTINCT B.MOTCLE_0,'"+GDOSX3+"' FROM "+GDOSX3+".ADOCFLD B"
  SQLREQ(1) -= "WHERE B.LAN_0='"+[M:TRA0]LANREF+"'"
  SQLREQ(2) -= "AND NOT EXISTS (SELECT 'X' FROM "+nomap+".ADOCFLD A WHERE A.LAN_0=B.LAN_0 AND A.MOTCLE_0=B.MOTCLE_0)"
Endif
SQLREQ(2) -="ORDER BY 1"

Raz VAPPREFOLD
For (Char VMOT(30),Char VAPPREF(30)) From num$((GTYPDBA*2)+1)  Sql SQLREQ  As [ZDZ0]
    # on boucle sur MOTCLE pour la langue de ref
    If VAPPREFOLD<>[ZDZ0]VAPPREF
        If clalev([ZDZ1])<>0 : Close File [ZDZ1] : Endif
        If clalev([ZDZ1])=0 : Local File =[ZDZ0]VAPPREF+".ADOCFLD" [ZDZ1] : Endif
    Endif
    Read [ZDZ1]ADZ0=[M:TRA0]LANREF;[ZDZ0]VMOT
    WTOTREFFLD+=1
    WOKTRADFLD1+=1
    WDOCERRFLD=0
    WDATORIFLD=[0/0/0]
    If [ZDZ1]UPDDAT=[0/0/0]
        WDATORIFLD=[ZDZ1]CREDAT
    Else
        WDATORIFLD=[ZDZ1]UPDDAT
    Endif
    Raz [ZDZ2]
    Read [ZDZ2]ADZ0=CLAN;[ZDZ1]MOTCLE
    If fstat<>0
        Raz [ZDZ3]
        Read [ZDZ3]ADZ0=CLAN;[ZDZ1]MOTCLE
        If fstat<>0
            WDOCERRFLD=1
            Raz [ZDZ2]
        Else
            [ZDZ2]=[ZDZ3]
        Endif
    Endif
    If [ZDZ2]MOTCLE<>""
        Setlob V_FLDTXTORI With [ZDZ1]TEXTE
        Setlob W_FLDTXTLAN With [ZDZ2]TEXTE
        # TCH 30/05/2012 DM-78020 : Faire disparaitre "Prise en compte des traductions 140 importées" et ne plus en tenir compte car n'a plus d'utilité
        #If [M:TRA0]TRA140=2 & [ZDZ2]CREDAT=[01/01/2000] : WDOCERRFLD=0
        If WDATORIFLD>[ZDZ2]CREDAT or (V_FLDTXTORI<>"" and W_FLDTXTLAN="") : WDOCERRFLD=1 : Endif
    Endif
    If WDOCERRFLD<>0
        WATRADFLD1+=1
        WOKTRADFLD1-=1
    Endif
    VAPPREFOLD=[ZDZ0]VAPPREF
Next ZDZ0

Raz SQLREQ
SQLREQ(0) = "SELECT DISTINCT A.MOTCLE_0,'"+nomap+"' FROM "+nomap+".ADOCFLD A"
SQLREQ(0) -= "WHERE A.LAN_0='"+CLAN+"'"
If GDOSX3<>nomap
  SQLREQ(0) -= "UNION"
  SQLREQ(1) -= "SELECT DISTINCT B.MOTCLE_0,'"+GDOSX3+"' FROM "+GDOSX3+".ADOCFLD B"
  SQLREQ(1) -= "WHERE B.LAN_0='"+CLAN+"'"
  SQLREQ(2) -= "AND NOT EXISTS (SELECT 'X' FROM "+nomap+".ADOCFLD A WHERE A.LAN_0=B.LAN_0 AND A.MOTCLE_0=B.MOTCLE_0)"
Endif
SQLREQ(2) -="ORDER BY 1"

Raz VAPPREFOLD
For (Char VMOT(30),Char VAPPREF(30)) From num$((GTYPDBA*2)+1)  Sql SQLREQ  As [ZDZ0]
    WTOTLANFLD+=1
Next ZDZ0

If clalev([ZDZ1])<>0 : Close File [ZDZ1] : Endif
If clalev([ZDZ2])<>0 : Close File [ZDZ2] : Endif
If clalev([ZDZ3])<>0 : Close File [ZDZ3] : Endif

#####################################
## on remplit les infos sur les doc
[M:TRA1]RCALANREF1=[M:TRA0]LANREF
[M:TRA1]RCAVALREF1=format$("N:10",WVLDREF1)-"/"-format$("N:10",WTOTREF1)
[M:TRA1]RCALAN1=CLAN
[M:TRA1]RCAVALLAN1=format$("N:10",WVLDLAN1)-"/"-format$("N:10",WTOTLAN1)

#####################################
## on remplit les infos sur les champs
[M:TRA1]RCALANREF2=[M:TRA0]LANREF
[M:TRA1]RCAVALREF2=WTOTREFFLD
[M:TRA1]RCALAN2=CLAN
[M:TRA1]RCAVALLAN2=WTOTLANFLD

#####################################
# on remplit le tableau 1
#####################################
[M:TRA1]INTIT1(0) =mess(58,176,1) : #Traduites
[M:TRA1]VALDOC1(0)=WOKTRADDOC1
[M:TRA1]VALFLD1(0)=WOKTRADFLD1
[M:TRA1]INTIT1(1) =mess(57,176,1) : #A traduire
[M:TRA1]VALDOC1(1)=WATRADDOC1
[M:TRA1]VALFLD1(1)=WATRADFLD1
[M:TRA1]NBTAB1    = 2

#on recopie le tableau 1
[M:TRA1]INTIT2(0) =[M:TRA1]INTIT1(0)
[M:TRA1]VALDOC(0) =[M:TRA1]VALDOC1(0)
[M:TRA1]VALFLD(0) =[M:TRA1]VALFLD1(0)
[M:TRA1]INTIT2(1) =[M:TRA1]INTIT1(1)
[M:TRA1]VALDOC(1) =[M:TRA1]VALDOC1(1)
[M:TRA1]VALFLD(1) =[M:TRA1]VALFLD1(1)
[M:TRA1]NBTAB2    =[M:TRA1]NBTAB1

Gosub UNSET_FIRST From TRTFIRST
Onerrgo
End

###################################################################################################
# CHARGE_TRA2 : Recherche des Documentations dans l'onglet ADOCTRA2
###################################################################################################
Subprog CHARGE_TRA2(ERR)
Variable Integer ERR

If [M:TRA0]LANREF=[M:TRA0]LAN
    Call ERREUR(mess(63,176,1)) From GESECRAN
    End
Endif
Local Integer V_MAXLIG : V_MAXLIG=500
Local Integer VMODULE, VPRIOTRA
Local Integer V_ALLTYP, V_ALLCOD, V_ALLMOD, V_MODULE, V_EXCMOD, V_MODTOEXC, V_ALLPRIO, V_PRIOTRA
Local Char V_TYP, V_CODDEB, V_CODFIN
Local Char REF_TIT(100), DOC_ANOMALIE(10)
Local Date REF_VLDDAT, LAN_VLDDAT
Local Integer DOC_EXIST, DOC_ERR, DOC_INVALID, NB_VLD, NB_VLDTOT, NB_VLDREF, NB_VLDREFTOT
Local Char EV(200),  SQLREQ (250) (3)
Local Char VAPPREFOLD(30) : Raz VAPPREFOLD

V_ALLTYP=[M:TRA2]ALLTYP
V_TYP   =[M:TRA2]TYP

V_ALLMOD=[M:TRA2]ALLMOD
V_MODULE=[M:TRA2]MODULE
V_EXCMOD=[M:TRA2]EXCMOD
V_MODTOEXC=[M:TRA2]MODTOEXC
V_ALLPRIO=[M:TRA2]ALLPRIO
V_PRIOTRA=[M:TRA2]PRIOTRA

V_ALLCOD=[M:TRA2]ALLCOD
V_CODDEB=[M:TRA2]CODDEB
V_CODFIN=[M:TRA2]CODFIN
Raz [M:TRA2]

[M:TRA2]ALLTYP=V_ALLTYP
[M:TRA2]ALLCOD=V_ALLCOD
[M:TRA2]TYP   =V_TYP
[M:TRA2]CODDEB=V_CODDEB
[M:TRA2]CODFIN=V_CODFIN
[M:TRA2]ALLMOD=V_ALLMOD
[M:TRA2]MODULE=V_MODULE
[M:TRA2]EXCMOD=V_EXCMOD
[M:TRA2]MODTOEXC=V_MODTOEXC
[M:TRA2]ALLPRIO=V_ALLPRIO
[M:TRA2]PRIOTRA=V_PRIOTRA

Onerrgo ERR_SQL_TRA

If clalev([ZDO1])<>0 : Close File [ZDO1] : Endif
If clalev([ZDO1])=0 : Local File ADOCUMENT [ZDO1] : Endif

#JPGA 14/04/2011 BUG-71587: Pas de traduction pour las DOCS de type MC qui sont Crées/Gérées Manuellement par l'Industrialisation
Gosub DOC_INTRADUISIBLES

Raz SQLREQ
SQLREQ(0) = "SELECT DISTINCT A.TYP_0,A.COD_0,'"+nomap+"' FROM "+nomap+".ADOCUMENT A"
SQLREQ(0) -= "WHERE A.LAN_0='"+[M:TRA0]LANREF+"' AND A.TYP_0 NOT IN ("+[L]DOC_NONTRA+")"
EV =string$( [M:TRA2]ALLTYP=1,"AND A.TYP_0='"+[M:TRA2]TYP+"'" )
EV-=string$( [M:TRA2]ALLCOD=1,"AND A.COD_0>='"+[M:TRA2]CODDEB+string$([M:TRA2]CODDEB=""," ")+"' AND A.COD_0<='"+[M:TRA2]CODFIN+string$([M:TRA2]CODFIN=""," ")+"'" )
##EV-=string$( [M:TRA2]ALLMOD=1,"AND A.MODULE_0="+num$([M:TRA2]MODULE) )
SQLREQ(0) -= EV
If GDOSX3<>nomap
  SQLREQ(0) -= "UNION"
  SQLREQ(1) -= "SELECT DISTINCT B.TYP_0,B.COD_0,'"+GDOSX3+"' FROM "+GDOSX3+".ADOCUMENT B"
  SQLREQ(1) -= "WHERE B.LAN_0='"+[M:TRA0]LANREF+"' AND B.TYP_0 NOT IN ("+[L]DOC_NONTRA+")"
  EV =string$( [M:TRA2]ALLTYP=1,"AND B.TYP_0='"+[M:TRA2]TYP+"'" )
  EV-=string$( [M:TRA2]ALLCOD=1,"AND B.COD_0>='"+[M:TRA2]CODDEB+string$([M:TRA2]CODDEB=""," ")+"' AND B.COD_0<='"+[M:TRA2]CODFIN+string$([M:TRA2]CODFIN=""," ")+"'" )
  ##EV-=string$( [M:TRA2]ALLMOD=1,"AND B.MODULE_0="+num$([M:TRA2]MODULE) )
  SQLREQ(1) -= EV
  SQLREQ(2) -= "AND NOT EXISTS (SELECT 'X' FROM "+nomap+".ADOCUMENT A WHERE A.LAN_0=B.LAN_0 AND A.TYP_0=B.TYP_0 AND A.COD_0=B.COD_0)"
Endif
SQLREQ(2) -="ORDER BY 1,2"

For (Char VTYP(10),Char VCOD(30),Char VAPPREF(30)) From num$((GTYPDBA*2)+1)  Sql SQLREQ  As [ZDO0]
    # on boucle sur TYP+COD pour la langue de ref
    If VAPPREFOLD<>[ZDO0]VAPPREF
        If clalev([ZDO2])<>0 : Close File [ZDO2] : Endif
        If clalev([ZDO2])=0 : Local File =[ZDO0]VAPPREF+".ADOCUMENT" [ZDO2] : Endif
    Endif

    DOC_EXIST=1 : DOC_ERR=0 : DOC_INVALID=0 : DOC_ANOMALIE="" : REF_TIT="" : REF_VLDDAT = [0/0/0] : LAN_VLDDAT = [0/0/0]
    Raz NB_VLD, NB_VLDTOT, NB_VLDREF, NB_VLDREFTOT

    # on recupere le module
    Read [ZDO2]ADO0=[M:TRA0]LANREF;[ZDO0]VTYP;[ZDO0]VCOD
    VMODULE = [ZDO2]MODULE
    If [M:TRA2]ALLMOD=1 & [M:TRA2]MODULE<>VMODULE        # on ne prend pas la doc car pas le bon module
        DOC_ERR=-1
    Elsif [M:TRA2]EXCMOD=2 & [M:TRA2]MODTOEXC=VMODULE    # on ne prend pas la doc car pas module a exclure
        DOC_ERR=-2
    Endif
    #JPGA 03/06/2010 BUG-64550: Implémentation Priorisation de documentation pour la Traduction. Affichage Priorité dans Plan de travail
    If ![ZDO2]PRIO
        VPRIOTRA=1
    Else
        VPRIOTRA=[ZDO2]PRIO
    Endif
    If [M:TRA2]ALLPRIO=1 & [M:TRA2]PRIOTRA<>VPRIOTRA     # on ne prend pas la doc car pas le bonne priorité de traduction
        DOC_ERR=-3
    Endif

    If DOC_ERR=0
       Call RECHERCHE_VALIDATION([M:TRA0]LAN, REF_TIT, REF_VLDDAT, LAN_VLDDAT, DOC_INVALID, DOC_EXIST, DOC_ANOMALIE, DOC_ERR)
    Endif
    If DOC_ERR>0
        If [M:TRA2]NBDOC >= V_MAXLIG
            #Call MESSAGE(mess(41,176,1)+":"-mess(60,176,1)) From GESECRAN
            Call MESSAGE(mess(41,176,1)+":"-mess(59,176,1)) From GESECRAN
            Break
        Endif
        [M:TRA2]NBDOC +=1
        [M:TRA2]DOCTYP([M:TRA2]NBDOC-1)   = [ZDO0]VTYP
        [M:TRA2]COD([M:TRA2]NBDOC-1)      = [ZDO0]VCOD
        [M:TRA2]TIT([M:TRA2]NBDOC-1)      = REF_TIT
        [M:TRA2]VLDDATREF([M:TRA2]NBDOC-1)= REF_VLDDAT
        [M:TRA2]VLDDAT([M:TRA2]NBDOC-1)   = LAN_VLDDAT
        [M:TRA2]EXIST([M:TRA2]NBDOC-1)    = DOC_EXIST
        #JPGA 03/06/2010 BUG-64550: Implémentation Priorisation de documentation pour la Traduction. Affichage Priorité dans Plan de travail
        If ![ZDO2]PRIO
           [M:TRA2]PRIO([M:TRA2]NBDOC-1)  = 1
        Else
           [M:TRA2]PRIO([M:TRA2]NBDOC-1)  = [ZDO2]PRIO
        Endif
        #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
        Call ALIMENT_GROUPE("ADO", [M:TRA0]LAN, [ZDO0]VTYP, [ZDO0]VCOD, "[M:TRA2]CREGRP([M:TRA2]NBDOC-1)")  From AGENLIBA

        Filter [ZDO2] Where LAN=[M:TRA0]LANREF & TYP=[ZDO0]VTYP & COD=[ZDO0]VCOD & VLDDAT=REF_VLDDAT   # Recherche Nb paragraphes de même date de validité
        NB_VLDREF    = rowcount([ZDO2])
        Filter [ZDO2] Where LAN=[M:TRA0]LANREF & TYP=[ZDO0]VTYP & COD=[ZDO0]VCOD
        NB_VLDREFTOT = rowcount([ZDO2])
        Filter [ZDO2]
        Filter [ZDO1] Where LAN=[M:TRA0]LAN & TYP=[ZDO0]VTYP & COD=[ZDO0]VCOD & VLDDAT=LAN_VLDDAT      # Recherche Nb paragraphes de même date de validité
        NB_VLD       = rowcount([ZDO1])
        Filter [ZDO1] Where LAN=[M:TRA0]LAN & TYP=[ZDO0]VTYP & COD=[ZDO0]VCOD
        NB_VLDTOT    = rowcount([ZDO1])
        Filter [ZDO1]
        Case DOC_ERR
           When 1       : # Documentation dont 1 ou plusieurs paragraphes sont inexistants dans la langue de traduction
             If NB_VLDREF <> NB_VLDREFTOT
                [M:TRA2]ANOMALIE([M:TRA2]NBDOC-1)=func AFNC.MES3 (mess(101,176,1),[M:TRA0]LANREF,num$(NB_VLDREF),num$(NB_VLDREFTOT))
             Elsif NB_VLDTOT <> NB_VLDREFTOT
                [M:TRA2]ANOMALIE([M:TRA2]NBDOC-1)=func AFNC.MES3 (mess(102,176,1),[M:TRA0]LANREF,num$(NB_VLDREFTOT),[M:TRA0]LAN)-"("+num$(NB_VLDTOT)+")"
             Endif
           When 2       : # Documentation dont 1 ou plusierus paragraphes sont sans date de validité ou de flag de validité désactivé
             If [ZDO1]VLDFLG<>2
                [M:TRA2]ANOMALIE([M:TRA2]NBDOC-1)=func AFNC.MES1 (mess(103,176,1),[M:TRA0]LAN)
             Else
                [M:TRA2]ANOMALIE([M:TRA2]NBDOC-1)=func AFNC.MES3 (mess(101,176,1),[M:TRA0]LAN,num$(NB_VLD),num$(NB_VLDTOT))
             Endif
           When 3       : # Documentation normale à traduire
        Endcase
    Endif
    VAPPREFOLD=[ZDO0]VAPPREF
Next ZDO0

If clalev([ZDO1])<>0 : Close File [ZDO1] : Endif
If clalev([ZDO2])<>0 : Close File [ZDO2] : Endif
Onerrgo
End

Subprog RECHERCHE_VALIDATION(CLAN, REF_TIT, REF_VLDDAT, LAN_VLDDAT, DOC_INVALID, DOC_EXIST, DOC_ANOMALIE, DOC_ERR)
Variable Char    CLAN(), REF_TIT(), DOC_ANOMALIE()
Variable Date    REF_VLDDAT, LAN_VLDDAT
Variable Integer DOC_INVALID, DOC_EXIST, DOC_ERR

Local Char ICONE_VIDE : [L]ICONE_VIDE=""
Local Char ICONE_AVER : [L]ICONE_AVER="151"

   #Boucle sur les paragraphes de la langue de ref
   For [ZDO2] Where LAN=[M:TRA0]LANREF and TYP=[ZDO0]VTYP and COD=[ZDO0]VCOD
      # Intitulé et Date de Validité pris en comptes sur le paragraphe TIT
      If [ZDO2]PAR="TIT" : REF_TIT=[ZDO2]TIT : REF_VLDDAT=[ZDO2]VLDDAT : Endif

      #on ne traite pas la doc si un paragraphe n'est pas valide
      If [ZDO2]VLDDAT=[0/0/0] or [ZDO2]VLDFLG<>2
         DOC_INVALID=1 : DOC_ERR=0 : Break
      Endif

      If DOC_ERR>=0
         Raz [ZDO1]
         Read [ZDO1]ADO0=CLAN;[ZDO2]TYP;[ZDO2]COD;[ZDO2]LEV;[ZDO2]SUBLEV
         If fstat<>0
               If DOC_ERR=0 : DOC_ERR=1 : Endif
         Else
            DOC_EXIST=2
            If [ZDO1]VLDDAT<>[0/0/0] : LAN_VLDDAT = [ZDO1]VLDDAT : Endif
            If [ZDO1]VLDDAT=[0/0/0] or [ZDO1]VLDFLG<>2
               If DOC_ERR=0 : DOC_ERR=2 : Endif
            # TCH 30/05/2012 DM-78020 : Faire disparaitre "Prise en compte des traductions 140 importées" et ne plus en tenir compte car n'a plus d'utilité
            #Elsif [M:TRA0]TRA140=2 & [ZDO1]VLDDAT=[01/01/2000] & [ZDO1]VLDFLG=2
            #   DOC_ERR=-9
            Elsif [ZDO1]VLDDAT<[ZDO2]VLDDAT
               If DOC_ERR=0 : DOC_ERR=3 : Endif
               #JPGA 13/12/2011 BUG-78568: Prise en compte Traduction ENG vers FRA
            Elsif [ZDO1]VLDDAT>[ZDO2]VLDDAT
               DOC_ANOMALIE=[L]ICONE_AVER
            Endif
         Endif
      Endif
   Next ZDO2
End

######################################################################################
######################################################################################
Subprog AM_LANREF(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M:TRA0]LAN
    GERR = 1
    GMESSAGE = mess(54,176,1)
    mkstat=2
Else
    If VALEUR<>[M]LANREF
        Raz [M:TRA1]
        Raz [M:TRA2]
        Raz [M:TRA3]
        #on ne fait plus la lecture car trop long sur X3DIAM
        #Local Integer ERR
        #Call TEMPON("L") From GESECRAN
        #Call CHARGE_TRA1([M:TRA0]LAN,ERR)
        #Call TEMPOFF From GESECRAN
        Gosub AFFDEBUT
        [M:TRA0]LANREF=VALEUR
    Endif
Endif
End



###################################################################################################
######################################################################################
Subprog AM_LAN(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M:TRA0]LANREF
    GERR = 1
    GMESSAGE = mess(54,176,1)
    mkstat=2
Else
    If VALEUR<>[M]LAN
        Raz [M:TRA1]
        Raz [M:TRA2]
        Raz [M:TRA3]
        #on ne fait plus la lecture car trop long sur X3DIAM
        #Local Integer ERR
        #Call TEMPON("L") From GESECRAN
        #Call CHARGE_TRA1([M:TRA0]LAN,ERR)
        #Call TEMPOFF From GESECRAN
        Gosub AFFDEBUT
        [M:TRA0]LAN=VALEUR
    Endif
Endif
End

###################################################################################################
######################################################################################

Subprog AM_ALLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M:TRA2]TYP = "" : Affzo [M:TRA2]TYP : Grizo [M:TRA2]TYP
Else
 Actzo [M:TRA2]TYP
Endif
End

Subprog C_TYP(VALEUR)
Variable Char    VALEUR()
#JPGA 14/04/2011 BUG-71587: Pas de traduction pour las DOCS de type MC qui sont Crées/Gérées Manuellement par l'Industrialisation
Gosub DOC_INTRADUISIBLES

If instr(0,[L]DOC_NONTRA,"'"+VALEUR+"'")<>0
    GMESSAGE=mess(81,176,1)-[L]DOC_NONTRA
    GERR=1
    [S]mkstat=2
Endif

# JPGA - 03-03-2009 - BUG-52997 : Ne pas permettre la saisie à vide dy TYPE de doc et initialiser ALLTYP à TRUE.
If VALEUR=""
    [M:TRA2]ALLTYP = 2 : Affzo [M:TRA2]TYP,ALLTYP : Grizo [M:TRA2]TYP
Endif
End


Subprog AM_ALLMOD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    Grizo [M]MODULE
    Actzo [M]EXCMOD
Else
    Actzo [M]MODULE
    Effzo [M]EXCMOD
    Effzo [M]MODTOEXC
    Grizo [M]EXCMOD
    Grizo [M]MODTOEXC
Endif
End


Subprog AM_ALLCOD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M:TRA2]CODDEB = "" : Affzo [M:TRA2]CODDEB : Grizo [M:TRA2]CODDEB
 [M:TRA2]CODFIN = "" : Affzo [M:TRA2]CODFIN : Grizo [M:TRA2]CODFIN
Else
 Actzo [M:TRA2]CODDEB
 Actzo [M:TRA2]CODFIN
Endif
End

Subprog AM_CODDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" and [M:TRA2]CODFIN=""
    [M:TRA2]CODFIN=VALEUR : Affzo [M:TRA2]CODFIN
Endif
End

Subprog AS_CODFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   VALEUR=[M:TRA2]CODDEB
   If VALEUR=""
       VALEUR="Z"
   Endif
Endif
End

###################################################################################################
######################################################################################

Subprog AS_NBDOC
GBOUT1 = mess(202,124,1) : # Oui à tout le reste
GBOUT2 = mess(203,124,1) : # Non à tout le reste
End

Subprog B1_NBDOC
For I=nolign To [M:TRA2]NBDOC
  [M:TRA2]PROFLG(I-1)=2
Next I
Affzo [M:TRA2]10
#gerer les boutons de fenetre + bouton contextuel
mkstat=4
End

Subprog B2_NBDOC
For I=nolign To [M:TRA2]NBDOC
  [M:TRA2]PROFLG(I-1)=1
Next I
Affzo [M:TRA2]10
#gerer les boutons de fenetre + bouton contextuel
mkstat=4
End

###################################################################################################
# CHARGE_TRA3 : Recherche des Aides sur champs dans l'onglet ADOCTRA3
###################################################################################################
Subprog CHARGE_TRA3(ERR)
Variable Integer ERR

If [M:TRA0]LANREF=[M:TRA0]LAN
    Call ERREUR(mess(63,176,1)) From GESECRAN
    End
Endif


Local Integer V_MAXLIG : V_MAXLIG=500
Local Integer V_ALLFLD, V_ALLMOD, V_MODULE, V_EXCMOD, V_MODTOEXC, V_ALLPRIO, V_PRIOTRA
Local Char V_FLDDEB, V_FLDFIN
Local Char V_TXTORI (250)
Local Char V_TXTFLD (250)

V_ALLMOD=[M:TRA3]ALLMOD
V_MODULE=[M:TRA3]MODULE
V_EXCMOD=[M:TRA3]EXCMOD
V_MODTOEXC=[M:TRA3]MODTOEXC
V_ALLPRIO=[M:TRA3]ALLPRIO
V_PRIOTRA=[M:TRA3]PRIOTRA

V_ALLFLD=[M:TRA3]ALLFLD
V_FLDDEB=[M:TRA3]FLDDEB
V_FLDFIN=[M:TRA3]FLDFIN
Raz [M:TRA3]
[M:TRA3]ALLMOD=V_ALLMOD
[M:TRA3]MODULE=V_MODULE
[M:TRA3]EXCMOD=V_EXCMOD
[M:TRA3]MODTOEXC=V_MODTOEXC

[M:TRA3]ALLFLD=V_ALLFLD
[M:TRA3]FLDDEB=V_FLDDEB
[M:TRA3]FLDFIN=V_FLDFIN
[M:TRA3]ALLPRIO=V_ALLPRIO
[M:TRA3]PRIOTRA=V_PRIOTRA

Onerrgo ERR_SQL_TRA
Local Integer DOC_EXIST
Local Char EV(200)

If clalev([ZDZ2])<>0 : Close File [ZDZ2] : Endif
If clalev([ZDZ2])=0 : Local File ADOCFLD [ZDZ2] : Endif
If clalev([ZDZ3])<>0 : Close File [ZDZ3] : Endif
If clalev([ZDZ3])=0 : Local File =GDOSX3+".ADOCFLD" [ZDZ3] : Endif


Local Char SQLREQ (250) (3) : Raz SQLREQ
SQLREQ(0) = "SELECT DISTINCT A.MOTCLE_0,'"+nomap+"' FROM "+nomap+".ADOCFLD A"
SQLREQ(0) -= "WHERE A.LAN_0='"+[M:TRA0]LANREF+"'"
EV= string$( [M:TRA3]ALLFLD=1,"AND A.MOTCLE_0>='"+[M:TRA3]FLDDEB+string$([M:TRA3]FLDDEB=""," ")+"' AND A.MOTCLE_0<='"+[M:TRA3]FLDFIN+string$([M:TRA3]FLDFIN=""," ")+"'")
EV-=string$( [M:TRA3]ALLMOD=1,"AND A.MODULE_0="+num$([M:TRA3]MODULE) )
EV-=string$( [M:TRA3]ALLPRIO=1,"AND ( A.PRIO_0="+num$([M:TRA3]PRIOTRA)+string$([M:TRA3]PRIOTRA=1," OR A.PRIO_0=0")-")" )
EV-=string$( [M:TRA3]EXCMOD=2,"AND A.MODULE_0<>"+num$([M:TRA3]MODTOEXC) )
SQLREQ(0) -= EV
If GDOSX3<>nomap
SQLREQ(0) -= "UNION"
SQLREQ(1) -= "SELECT DISTINCT B.MOTCLE_0,'"+GDOSX3+"' FROM "+GDOSX3+".ADOCFLD B"
SQLREQ(1) -= "WHERE B.LAN_0='"+[M:TRA0]LANREF+"'"
EV= string$( [M:TRA3]ALLFLD=1,"AND B.MOTCLE_0>='"+[M:TRA3]FLDDEB+string$([M:TRA3]FLDDEB=""," ")+"' AND B.MOTCLE_0<='"+[M:TRA3]FLDFIN+string$([M:TRA3]FLDFIN=""," ")+"'")
EV-=string$( [M:TRA3]ALLMOD=1,"AND B.MODULE_0="+num$([M:TRA3]MODULE) )
EV-=string$( [M:TRA3]ALLPRIO=1,"AND ( B.PRIO_0="+num$([M:TRA3]PRIOTRA)+string$([M:TRA3]PRIOTRA=1," OR B.PRIO_0=0")-")" )
EV-=string$( [M:TRA3]EXCMOD=2,"AND B.MODULE_0<>"+num$([M:TRA3]MODTOEXC) )
SQLREQ(1) -= EV
SQLREQ(2) -= "AND NOT EXISTS (SELECT 'X' FROM "+nomap+".ADOCFLD A WHERE A.LAN_0=B.LAN_0 AND A.MOTCLE_0=B.MOTCLE_0)"
Endif
SQLREQ(2) -="ORDER BY 1"

Local Char VAPPREFOLD(30) : Raz VAPPREFOLD
For (Char VMOT(30),Char VAPPREF(30)) From num$((GTYPDBA*2)+1) Sql SQLREQ
&        As [ZDZ0]
    # on boucle sur MOTCLE pour la langue de ref
    If VAPPREFOLD<>[ZDZ0]VAPPREF
        If clalev([ZDZ1])<>0 : Close File [ZDZ1] : Endif
        If clalev([ZDZ1])=0 : Local File =[ZDZ0]VAPPREF+".ADOCFLD" [ZDZ1] : Endif
    Endif
    Read [ZDZ1]ADZ0=[M:TRA0]LANREF;[ZDZ0]VMOT

    DOC_EXIST=1
    DOC_ERR=0
    DATORI=[0/0/0]

    If [ZDZ1]UPDDAT=[0/0/0]
        DATORI=[ZDZ1]CREDAT
    Else
        DATORI=[ZDZ1]UPDDAT
    Endif
    Raz [ZDZ2]
    Read [ZDZ2]ADZ0=[M:TRA0]LAN;[ZDZ1]MOTCLE
    If fstat<>0
        Raz [ZDZ3]
        Read [ZDZ3]ADZ0=[M:TRA0]LAN;[ZDZ1]MOTCLE
        If fstat<>0
            DOC_ERR=1
            Raz [ZDZ2]
        Else
            [ZDZ2]=[ZDZ3]
        Endif
    Endif
    If [ZDZ2]MOTCLE<>""
        DOC_EXIST=2
        Setlob V_TXTORI With [ZDZ1]TEXTE
        Setlob V_TXTFLD With [ZDZ2]TEXTE
        # TCH 30/05/2012 DM-78020 : Faire disparaitre "Prise en compte des traductions 140 importées" et ne plus en tenir compte car n'a plus d'utilité
        #If [M:TRA0]TRA140=2 & [ZDZ2]CREDAT=[01/01/2000] : DOC_ERR=0
        If DATORI>[ZDZ2]CREDAT or (V_TXTORI<>"" and V_TXTFLD="") : DOC_ERR=1 : Endif
    Endif
    If DOC_ERR<>0
        If [M:TRA3]NBFLD >= V_MAXLIG
            #Call MESSAGE(mess(42,176,1)+":"-mess(60,176,1)) From GESECRAN
            Call MESSAGE(mess(42,176,1)+":"-mess(59,176,1)) From GESECRAN
            Break
        Endif
        [M:TRA3]NBFLD +=1
        [M:TRA3]MOTCLE([M:TRA3]NBFLD-1)   = [ZDZ1]MOTCLE
        [M:TRA3]VLDDATREF([M:TRA3]NBFLD-1)= DATORI
        [M:TRA3]VLDDAT([M:TRA3]NBFLD-1)   = [ZDZ2]CREDAT
        [M:TRA3]EXIST([M:TRA3]NBFLD-1)    = DOC_EXIST
        #JPGA 03/06/2010 BUG-64550: Implémentation Priorisation de documentation pour la Traduction. Affichage Priorité dans Plan de travail
        If ![ZDZ1]PRIO
           [M:TRA3]PRIO([M:TRA3]NBFLD-1)  = 1
        Else
           [M:TRA3]PRIO([M:TRA3]NBFLD-1)  = [ZDZ1]PRIO
        Endif
        #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
        Call ALIMENT_GROUPE("ADZ", [M:TRA0]LAN, "", [ZDZ1]MOTCLE, "[M:TRA3]CREGRP([M:TRA3]NBFLD-1)")  From AGENLIBA
    Endif
    VAPPREFOLD=[ZDZ0]VAPPREF
Next ADZ

If clalev([ZDZ1])<>0 : Close File [ZDZ1] : Endif
If clalev([ZDZ2])<>0 : Close File [ZDZ2] : Endif
If clalev([ZDZ3])<>0 : Close File [ZDZ3] : Endif

Onerrgo
End

######################################################################################
Subprog AM_ALLFLD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M:TRA3]FLDDEB = "" : Affzo [M:TRA3]FLDDEB : Grizo [M:TRA3]FLDDEB
 [M:TRA3]FLDFIN = "" : Affzo [M:TRA3]FLDFIN : Grizo [M:TRA3]FLDFIN
Else
 Actzo [M:TRA3]FLDDEB
 Actzo [M:TRA3]FLDFIN
Endif
End

Subprog AM_FLDDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" and [M:TRA3]FLDFIN=""
    [M:TRA3]FLDFIN=VALEUR : Affzo [M:TRA3]FLDFIN
Endif
End

Subprog AS_FLDFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   VALEUR=[M:TRA3]FLDDEB
   If VALEUR=""
       VALEUR="Z"
   Endif
Endif
End

Subprog AS_NBFLD
GBOUT1 = mess(202,124,1) : # Oui à tout le reste
GBOUT2 = mess(203,124,1) : # Non à tout le reste
End

Subprog B1_NBFLD
For I=nolign To [M:TRA3]NBFLD
  [M:TRA3]PROFLG(I-1)=2
Next I
Affzo [M:TRA3]10
#gerer les boutons de fenetre + bouton contextuel
mkstat=4
End

Subprog B2_NBFLD
For I=nolign To [M:TRA3]NBFLD
  [M:TRA3]PROFLG(I-1)=1
Next I
Affzo [M:TRA3]10
#gerer les boutons de fenetre + bouton contextuel
mkstat=4
End


######################################################################################
Subprog AM_PROFLG(VALEUR)
Variable Integer VALEUR
#Infbox "AM_PROFLG PROFLG="+num$([M]PROFLG(nolign-1))+ "VALEUR="+num$(VALEUR)
[M]PROFLG(nolign-1)=VALEUR
Affzo [M]PROFLG(nolign-1)
End

