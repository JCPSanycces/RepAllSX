###################################################################################################
#JPGA 14/04/2011 BUG-71587: Pas de traduction pour las DOCS de type MC qui sont Crées/Gérées Manuellement par l'Industrialisation
#JPGA 14/04/2011 BUG-72366: Pas de traduction du Plan de Paye PLA qui est propre à chaque pays
#VPO 25/01/08 45494 pas de trad sur APM,ATB,ATY,AML
#VPO 23/06/08 39766 pas de trad sur les ATD
#JPGA 17/08/2009 BUG-56703 pas de trad sur les AT3
$DOC_INTRADUISIBLES
   If dim([L]DOC_NONTRA)<0
      Local Char DOC_NONTRA(100)

      [L]DOC_NONTRA="'APM','ATD','AT3','ATB','AML','ATY','PLA','MC'"
   Endif
Return
