#JOJAC - 2016-06-22 - REQ114309 US267 - START
Subprog AS_ADDPRI(VALEUR)
Variable Decimal VALEUR
Local Integer AC
Local Integer PRNR

  If VALEUR=0
    PRNR=1
    For AC=0 To dim([M:CTR4]ADDPRI)-1
      If [M:CTR4]ADDPRI(AC)=PRNR
        PRNR+=1
      Endif
    Next
    VALEUR=PRNR
  Endif
End

######################################################################################
## FLIP 21/11/2013 - This section determines the default values of address type according
## to what's already been chosen
######################################################################################
Subprog AM_ADDPRI(VALEUR)
Variable Decimal VALEUR
Local    Integer TYP1, TYP2, TYP3

  If [M:CTR4]ADDTYP(nolign-1) = 0
    If !find(1,[M:CTR4]ADDTYP) Then [M:CTR4]ADDTYP(nolign-1)=1 : End : Endif
    If !find(2,[M:CTR4]ADDTYP) Then [M:CTR4]ADDTYP(nolign-1)=2 : End : Endif
    If !find(3,[M:CTR4]ADDTYP) Then [M:CTR4]ADDTYP(nolign-1)=3 : End : Endif
  Endif

# JASMI - 2015-01-12 - Requirement 104630 US 3276 - START
  If VALEUR < 1 or VALEUR > 3 Then
    GMESSAGE=mess(83,123,1)
    mkstat=2
  Endif
# JASMI - 2015-01-12 - Requirement 104630 US 3276 - END

End

######################################################################################
## FLIP 22/11/2013 - This section disable adr serv type if not postal address
######################################################################################
Subprog AV_ADDSRVTYP(VALEUR)
Variable Integer VALEUR

#JASMI - 2015-11-27 - Req 112521 - START
#  If [M:EMP1]ADDTYP(nolign-1)<>2
## JASMI - 2015-01-12 - Requirement 104630 US 3276 - START
#    [M:EMP1]ADDSRVTYP(nolign-1)=0
## JASMI - 2015-01-12 - Requirement 104630 US 3276 - END
#    Grizo [M:EMP1]ADDSRVTYP(nolign-1)
#  Else
## JASMI - 2015-01-12 - Requirement 104630 US 3276 - START
#    [M:EMP1]ADDSRVTYP(nolign-1)=1
## JASMI - 2015-01-12 - Requirement 104630 US 3276 - END
#    Actzo [M:EMP1]ADDSRVTYP(nolign-1)
#  Endif
#
## JASMI - 2015-01-12 - Requirement 104630 US 3276 - START
#  Call ENABLE_DISABLE_FOR_POSTAL_ADDRESS([M:EMP1]ADDSRVTYP(nolign-1))
## JASMI - 2015-01-12 - Requirement 104630 US 3276 - END
  If [M:CTR4]ADDTYP(nolign-1)<>2
    VALEUR=0
    Grizo [M:CTR4]ADDSRVTYP(nolign-1)
  Else
    Actzo [M:CTR4]ADDSRVTYP(nolign-1)
  Endif

  Call ENABLE_DISABLE_FOR_POSTAL_ADDRESS(VALEUR)
#JASMI - 2015-11-27 - Req 112521 - END

End

######################################################################################
## FLIP 22/11/2013 - This section toggles the mandatory indictor according to postal type
######################################################################################
Subprog C_ADDPOSCDE(VALEUR)
Variable Char    VALEUR()
# JASMI - 2015-01-12 - Requirement 104630 US 3276 - START
  If [M:CTR4]ADDTYP(nolign-1)<>2 or [M:CTR4]ADDSRVTYP(nolign-1)<>4 Then
    If VALEUR="" Then
      mkstat = 1 : GMESSAGE = mess(10,123,1)
    Endif
  Endif
# JASMI - 2015-01-12 - Requirement 104630 US 3276 - END
#ADNGO - 2018-07-19 - X3-92894 - START
If ([CTR4]ADDCNTCDE<>"" and [CTR4]ADDCNTCDE='ZA') and len(VALEUR)<>4 Then
  GMESSAGE=mess(51,11706,1)
  mkstat=2
Endif
#ADNGO - 2018-07-19 - X3-92894 - END
End

Subprog C_ADDSTRNAM(VALEUR)
Variable Char    VALEUR()
# JASMI - 2015-01-12 - Requirement 104630 US 3276 - START
  If [M:CTR4]ADDTYP(nolign-1)<>2 Then
    If VALEUR ="" Then
      GMESSAGE = mess(10,123,1)
      mkstat=2
    Endif
  Endif
# JASMI - 2015-01-12 - Requirement 104630 US 3276 - END
End

######################################################################################
## FLIP 20/11/2013 - This section ensure that only one address can be flagged as
## correspondence address
######################################################################################
Subprog C_ADDCOR(VALEUR)
Variable Integer VALEUR
Local    Integer ADDCNT

  If VALEUR=2
    For ADDCNT=0 To dim([M:CTR4]ADDPRI)-1
      If ADDCNT<>nolign-1
        [M:CTR4]ADDCOR(ADDCNT)=1
        Affzo [M:CTR4]ADDCOR(ADDCNT)
# JASMI - 2015-01-12 - Requirement 104630 US 3276 - START
      Else
        [M:CTR4]ADDSTA([L]ADDCNT)=2
        Affzo [M:CTR4]ADDSTA([L]ADDCNT)
# JASMI - 2015-01-12 - Requirement 104630 US 3276 - START
      Endif
    Next
  Endif
End

Subprog AS_ADDCNTCDE(VALEUR)
Variable Char    VALEUR()

  If VALEUR=""
    VALEUR="ZA"
  Endif
End

Subprog ENABLE_DISABLE_FOR_POSTAL_ADDRESS(VALEUR)
Variable Integer VALEUR

  Actzo [M:CTR4]ADDPOSOTH(nolign-1)
  Actzo [M:CTR4]ADDPOSNUM(nolign-1)
  Actzo [M:CTR4]ADDPOSNAM(nolign-1)
  Actzo [M:CTR4]ADDPOSAGN(nolign-1)
  Actzo [M:CTR4]ADDPOSCOF(nolign-1)
  Actzo [M:CTR4]ADDPOSINM(nolign-1)
  Actzo [M:CTR4]ADDCPX(nolign-1)
  Actzo [M:CTR4]ADDSTRNUM(nolign-1)
  Actzo [M:CTR4]ADDSTRNAM(nolign-1)
  Actzo [M:CTR4]ADDSUB(nolign-1)
  Actzo [M:CTR4]ADDTWN(nolign-1)
  Actzo [M:CTR4]ADDPOSCDE(nolign-1)
  Actzo [M:CTR4]ADDCNTCDE(nolign-1)

#JASMI - 2015-11-27 - Req 112521 - START
#  If VALEUR = 0 or VALEUR = 5 Then
#    Grizo [M:EMP1]ADDPOSOTH(nolign-1) #: Effzo [M:EMP1]ADDPOSOTH(nolign-1)
#    Grizo [M:EMP1]ADDPOSNAM(nolign-1) #: Effzo [M:EMP1]ADDPOSNAM(nolign-1)
#    Grizo [M:EMP1]ADDPOSAGN(nolign-1) #: Effzo [M:EMP1]ADDPOSAGN(nolign-1)
#    Grizo [M:EMP1]ADDPOSCOF(nolign-1) #: Effzo [M:EMP1]ADDPOSCOF(nolign-1)
#    Grizo [M:EMP1]ADDPOSINM(nolign-1) #: Effzo [M:EMP1]ADDPOSINM(nolign-1)
#  Else
#    If VALEUR = 4 Then
#      Grizo [M:EMP1]ADDPOSOTH(nolign-1) #: Effzo [M:EMP1]ADDPOSOTH(nolign-1)
#      Grizo [M:EMP1]ADDPOSNUM(nolign-1) #: Effzo [M:EMP1]ADDPOSNUM(nolign-1)
#      Grizo [M:EMP1]ADDPOSNAM(nolign-1) #: Effzo [M:EMP1]ADDPOSNAM(nolign-1)
#      Grizo [M:EMP1]ADDPOSAGN(nolign-1) #: Effzo [M:EMP1]ADDPOSAGN(nolign-1)
#      Grizo [M:EMP1]ADDPOSCOF(nolign-1) #: Effzo [M:EMP1]ADDPOSCOF(nolign-1)
#      Grizo [M:EMP1]ADDPOSINM(nolign-1) #: Effzo [M:EMP1]ADDPOSINM(nolign-1)
#      Grizo [M:EMP1]ADDCPX(nolign-1)    #: Effzo [M:EMP1]ADDCPX(nolign-1)
#      Grizo [M:EMP1]ADDSTRNUM(nolign-1) #: Effzo [M:EMP1]ADDSTRNUM(nolign-1)
#      Grizo [M:EMP1]ADDSTRNAM(nolign-1) #: Effzo [M:EMP1]ADDSTRNAM(nolign-1)
#      Grizo [M:EMP1]ADDSUB(nolign-1)    #: Effzo [M:EMP1]ADDSUB(nolign-1)
#      Grizo [M:EMP1]ADDTWN(nolign-1)    #: Effzo [M:EMP1]ADDTWN(nolign-1)
#      Grizo [M:EMP1]ADDPOSCDE(nolign-1) #: Effzo [M:EMP1]ADDPOSCDE(nolign-1)
#      Grizo [M:EMP1]ADDCNTCDE(nolign-1) #: Effzo [M:EMP1]ADDCNTCDE(nolign-1)
#    Else
#      Grizo [M:EMP1]ADDCPX(nolign-1)    #: Effzo [M:EMP1]ADDCPX(nolign-1)
#      Grizo [M:EMP1]ADDSTRNUM(nolign-1) #: Effzo [M:EMP1]ADDSTRNUM(nolign-1)
#      Grizo [M:EMP1]ADDSTRNAM(nolign-1) #: Effzo [M:EMP1]ADDSTRNAM(nolign-1)
#      Grizo [M:EMP1]ADDSUB(nolign-1)    #: Effzo [M:EMP1]ADDSUB(nolign-1)
#    Endif
#  Endif
  If VALEUR = 0 or VALEUR = 5 Then
    Grizo [M:CTR4]ADDPOSOTH(nolign-1) : Raz [M:CTR4]ADDPOSOTH(nolign-1)
    Grizo [M:CTR4]ADDPOSNAM(nolign-1) : Raz [M:CTR4]ADDPOSNAM(nolign-1)
    Grizo [M:CTR4]ADDPOSAGN(nolign-1) : Raz [M:CTR4]ADDPOSAGN(nolign-1)
    Grizo [M:CTR4]ADDPOSCOF(nolign-1) : Raz [M:CTR4]ADDPOSCOF(nolign-1)
    Grizo [M:CTR4]ADDPOSINM(nolign-1) : Raz [M:CTR4]ADDPOSINM(nolign-1)
