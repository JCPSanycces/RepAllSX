#FRLAA - 2015-03-23 - REQUIREMENT 104631 US 3507 - START
#Need information from table before deleting record
#JASMI - 2016-06-02 - REQ 114309 - START
#If func AFNC.ACTIV("FKSQS")>0 & func DIVPAYE.EXISTE_KXX("SUBHRACSA")
#ADNGO - 2017-07-11 - X3-11712 - START
#If func AFNC.ACTIV("FKZQS") & func DIVPAYE.IS_KZA(GCURLEG) & func DIVPAYE.EXISTE_KXX("SUBHRACSA")
If func AFNC.ACTIV("FKSQS") & func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) & func DIVPAYE.EXISTE_KXX("SUBHRACSA")
#ADNGO - 2017-07-11 - X3-11712 - END
#JASMI - 2016-06-02 - REQ 114309 - END
  #ADNGO - 2017-07-11 - X3-11712 - START
  #Gosub CREAT_MODHISTCTR From SUBHRACSA
  Call MODIF_CTR_CHECK(STAT) From SUBHRACSA
  If STAT = -1
    GOK = 0
    Return
  Elsif STAT > 0
    Gosub CREAT_MODHISTCTR From SUBHRACSA
  Endif
  #ADNGO - 2017-07-11 - X3-11712 - END
Endif
#FRLAA - 2015-03-23 - REQUIREMENT 104631 US 3507 - END

Delete [CTRSA] Where CTRNUM = [M]CTRNUM & REFNUM = [M]REFNUM & CTRDAT = [M]CTRDAT
If fstat = 1
  GOK = -1
  GLOCK = "$CTRSA" - [M]CTRNUM - [M]REFNUM - [M]CTRDAT
  Return
Elsif fstat>5
  GOK = 0
  Call RSTA("CTRSA", [M]REFNUM - [M]CTRNUM - [M]CTRDAT) From GLOCK
  Return
Endif

  #FRLAA and JASMI - 2015-02-19 - Requirement 104592 US 3261 - START
#  If func AFNC.ACTIV("KZA")>0
#  # JASMI - 2014/06/03 - Requirement 95019 US 2743 - START
#    Call SET_IRP5_END_DATE([M:CTR0]ETRFCY)
#  # JASMI - 2014/06/03 - Requirement 95019 US 2743 - END
#  Endif
  #FRLAA and JASMI - 2015-02-19 - Requirement 104592 US 3261 - END

[F:CTRSA] = [M:CTR0]
[F:CTRSA] = [M:CTR5]
[F:CTRSA] = [M:CTR1]#FRLAA - 2015-03-25 - REQUIREMENT 104631 US 3195
#JOJAC - 2016-07-13 - REQ114309 - START
[F:CTRSA] = [M:CTR4]
#JOJAC - 2016-07-13 - REQ114309 - END

Write [CTRSA]
If fstat
  GOK = 0 : Return
Endif

#ADNGO - 2017-05-18 - JIRA X3-12050 - START
#JASMI - 2015-11-27 - Reg 112521 - START
#Gosub CREATE_TAX_RECORD
#JASMI - 2015-11-13 - END
  If clalev([F:HRPEOH]) = 0 : Local File HRPEOHEA [HRPEOH] : Endif
  Filter [F:HRPEOH] Where [F:HRPEOH]PERCOD = [M:CTR1]PERCOD & [F:HRPEOH]FLGENA=2
  Read [HRPEOH]HRPEOH0  First

  Filter [F:HRPEOH]
  If !fstat

    If ([M:CTR0]CTRDAT<=[F:HRPEOH]CYCENDDAT and ([M:CTR8]XITDAT >= [F:HRPEOH]CYCSTRDAT | [M:CTR8]XITDAT=[0/0/0]))
       Gosub CREATE_TAX_RECORD
    Endif
  Endif
#ADNGO - 2017-05-18 - JIRA X3-12050 - END
Return

#JASMI - 2015-11-13 - START
$CREATE_TAX_RECORD
Local Integer THISTAXYEAR
Local Date DTAXSTR, DTAXEND

If clalev([F:HRPEOH]) = 0 : Local File HRPEOHEA [HRPEOH] : Endif

Filter [F:HRPEOH] Where [F:HRPEOH]PERCOD = [M:CTR1]PERCOD & [F:HRPEOH]FLGENA=2
Read [HRPEOH]HRPEOH0  First
If !fstat
  DTAXSTR=gdat$([F:HRPEOH]CYCSTRDAT)
  DTAXEND=gdat$([F:HRPEOH]CYCENDDAT)
Else
End
Endif
Filter [F:HRPEOH]


 [L]THISTAXYEAR=year(DTAXEND)


  Filter [F:ETR]
  Filter [F:ETR] Where REFNUM=[M:CTR0]REFNUM and CTRNUM=[M:CTR0]CTRNUM and TAXYEA=THISTAXYEAR


  Read [F:ETR]ETR0 Last


  If fstat
    Raz [F:ETR]
    [F:ETR]=[M:CTR0]
    [F:ETR]TAXYEA=THISTAXYEAR
    [F:ETR]=[M:CTR5]

    Write [F:ETR]
  Else
    [F:ETR]=[M:CTR5]

    Rewrite [F:ETR]
  Endif
  If fstat
    GOK=0
  Endif
#ADNGO - 2017-05-18 - JIRA X3-12050 - START
#delete all future tax records if applicable
Filter [F:ETR]
Filter [F:ETR] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and TAXYEA > THISTAXYEAR

If rowcount([F:ETR]) > 1 Then
Delete [F:ETR] Where CTRNUM = [M]CTRNUM & REFNUM = [M]REFNUM and TAXYEA > THISTAXYEAR
Endif
#ADNGO - 2017-05-18 - JIRA X3-12050 - END
Return
#JASMI - 2015-11-27 - Reg 112521 - END

$ANNULE
Local Integer THISTAXYEAR
Local Date DTAXSTR, DTAXEND

If clalev([F:HRPEOH]) = 0 : Local File HRPEOHEA [HRPEOH] : Endif

Filter [F:HRPEOH] Where [F:HRPEOH]PERCOD = [M:CTR1]PERCOD & [F:HRPEOH]FLGENA=2
#LIPET - 2018-09-19 - X3-106452 - START
#Read First
Read [F:HRPEOH] First
#LIPET - 2018-09-19 - X3-106452 - END
If !fstat
  DTAXSTR=gdat$([F:HRPEOH]CYCSTRDAT)
  DTAXEND=gdat$([F:HRPEOH]CYCENDDAT)
Else
End
Endif
Filter [F:HRPEOH]


[L]THISTAXYEAR=year(DTAXEND)


##FRLAA & JASMI - 2015-06-08 - REQUIREMENT 104630 US 3682 - START
