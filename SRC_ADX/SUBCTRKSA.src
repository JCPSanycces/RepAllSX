    If VALEUR = 4 Then
       #MAPAD 2015-05-26 - Requirement 113638  US 4202  - START
#      Grizo [M:EMP1]ADDPOSOTH(nolign-1) : Raz [M:EMP1]ADDPOSOTH(nolign-1)
