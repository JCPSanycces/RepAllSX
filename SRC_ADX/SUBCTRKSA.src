#If func AFNC.ACTIV("FKSQS")>0 & func DIVPAYE.EXISTE_KXX("SUBHRACSA")
If func AFNC.ACTIV("FKZQS") & func DIVPAYE.IS_KZA(GCURLEG) & func DIVPAYE.EXISTE_KXX("SUBHRACSA")
#JASMI - 2016-06-02 - REQ 114309 - END
  Gosub MODIF_CTR From SUBHRACSA
Endif
#FRLAA - 2015-07-08 - REQUIREMENT 104631 US 3777 - END

#JOJAC - 2016-06-22 REQ114309 US267 - START
 #If func AFNC.ACTIV("KZA")>0
 If func DIVPAYE.IS_KZA(GCURLEG)
  Local Integer ADDCNT
  Local Integer PSTADD, RESADD, WRKADD, DEFCNT

    [L]PSTADD=0 : [L]RESADD=0 : [L]WRKADD=0 : [L]DEFCNT=0

    For [L]ADDCNT=0 To dim([M:CTR4]ADDPRI)-1
      #Case [M:EMP1]ADDTYP([L]ADDCNT)
      Case [M:CTR4]ADDTYP([L]ADDCNT)
       When 1 : [L]RESADD=+1
       When 2 : [L]PSTADD=+1
       When 3 : [L]WRKADD=+1
      Endcase
      If [M:CTR4]ADDCOR([L]ADDCNT) = 2 Then
        [L]DEFCNT=+1
      Endif
    Next

    If ([L]RESADD<>1) or ([L]PSTADD<>1) or ([L]WRKADD<>1) Then
      GMESSAGE = mess(27,11662,1)
      mkstat=2
      Return
    Endif
    If ([L]DEFCNT<>1) Then
      GMESSAGE = mess(28,11662,1)
      mkstat=2
      Return
    Endif
Endif
#JOJAC - 2016-06-22 REQ114309 US267 - END

Return

