#FRLAA - 2015-05-21 - REQUIREMENT 108198 US 3582 - START
 Delete [CTRSA] Where CTRNUM = [M]CTRNUM & REFNUM = [M]REFNUM & CTRDAT = [M]CTRDAT
 If fstat=1 | fstat>5
  GOK=0 : Call RSTA("CTRSA",[M:CTR0]CTRNUM-num$([M:CTR0]CTRDAT)) From GLOCK : Return
 Endif
#FRLAA - 2015-05-21 - REQUIREMENT 108198 US 3582 - END

