  #  If [M:CTR8]XITDAT <> [0/0/0] and [M:CTR8]XITGRD <> ""
  #    Chgfmt [M:CTR8]FINTAXCLC With "LA:11656"
  #    If VALEUR<> 2
  #      [M:CTR8]FINTAXCLC=0
  #      Grizo [M:CTR8]FINTAXCLC
  #    Else
  #      [M:CTR8]FINTAXCLC=1
  #      Actzo [M:CTR8]FINTAXCLC
  #    Endif
  #  Else
  #    Chgfmt [M:CTR8]FINTAXCLC With "-LA:11656"
  #  Endif
  #  Affzo [M:CTR8]FINTAXCLC
 # Endif
      #ADNGO - 2017-05-24 - JIRA X3-12050 - START
      If VALEUR = 1 and [M:CTR8]XITFNL = 2 Then
          Call REINSTATEDEMP(VPERCOD)
      Endif
      #ADNGO - 2017-05-24 - JIRA X3-12050 - END
    #FRLAA - 2015-03-31 - Requirement 104590 US 3260 - START
      If VALEUR = 2 and [M:CTR8]XITDAT <> [0/0/0]
        #JOJAC - 2016-12-06 - START
        #Call MANAGE_TAX_DATES([M:CTR8]XITDAT,VPARAM,VSITE)
        #ADNGO - 2017-05-24 - JIRA X3-12050 - START
        #Call MANAGE_TAX_DATES([M:CTR8]XITDAT,VPARAM,VSITE,VPERCOD)
        Call SET_TAXENDDAT([M:CTR8]XITDAT,VPERCOD)
        #ADNGO - 2017-05-24 - JIRA X3-12050 - END
        #JOJAC - 2016-12-06 - END
      Endif
    #FRLAA - 2015-04-01 - Requirement 104590 US 3260 - END

    #FRLAA - 2015-03-31 - Requirement 104590 US 3260 - START

      #If VALEUR <> 2 Then PARAMDATE = [00/00/00] : Else PARAMDATE = [M:CTR8]XITDAT : Endif#FRLAA  - 2015-05-21 - Requirement 104590 US 3260
      #If PARAMDATE <> [00/00/00] : GERR = 2 : GMESSAGE = mess(18, 11706, 1) - PARAMDATE : Endif
      #Call MANAGE_TAX_DATES(PARAMDATE,VPARAM,VSITE) #FRLAA  - 2015-05-21 - Requirement 104590 US 3260
      #Call MANAGE_TAX_DATES([M:CTR8]XITDAT,VPARAM,VSITE)
    #FRLAA - 2015-04-01 - Requirement 104590 US 3260 - END
 # Endif
End
#ADNGO - 2017-05-24 - JIRA X3-12050 - START
Subprog REINSTATEDEMP(VPERCOD)
#Variable Char VSITE
Variable Char VPERCOD
Local Char STAXSTR(9), STAXEND(9) : STAXSTR  = "TAXSTRDAT" : STAXEND = "TAXENDDAT"
Local Date DTAXSTR, DTAXEND,PRVDTAXSTR,PRVDTAXEND
Local Char TMP_TAXSTRDAT(30), TMP_TAXENDDAT(30)


#  #Getting the Tax start and end date - Parameter
#  Call PARAM(VSITE, STAXSTR, TMP_TAXSTRDAT) From ADOVAL
#  If TMP_TAXSTRDAT = "" Then : TMP_TAXSTRDAT = "00000000" : Endif
#  DTAXSTR = gdat$(TMP_TAXSTRDAT)
#
#  Call PARAM(VSITE, STAXEND, TMP_TAXENDDAT) From ADOVAL
#  If TMP_TAXENDDAT = "" Then : TMP_TAXENDDAT = "00000000" : Endif
#  DTAXEND = gdat$(TMP_TAXENDDAT)
#
  If !clalev([F:HRPEOH]) : Local File HRPEOHEA [HRPEOH] : Endif

  Filter [F:HRPEOH] Where [F:HRPEOH]PERCOD = VPERCOD & [F:HRPEOH]FLGENA=2
  #LIPET - 2018-09-19 - X3-106452 - START
  #Read First
  Read [F:HRPEOH] First
  #LIPET - 2018-09-19 - X3-106452 - END
  If !fstat
    DTAXSTR=gdat$([F:HRPEOH]CYCSTRDAT)
    DTAXEND=gdat$([F:HRPEOH]CYCENDDAT)
  Else
    DTAXSTR = gdat$("00000000")
    DTAXEND=gdat$("00000000")
  Endif
  Filter [F:HRPEOH]

Local Char VPERCOD (6) : VPERCOD = [M:CTR1]PERCOD

If [M:CTR8]XITDAT <> [00/00/00] Then
If [M:CTR8]XITDAT < DTAXSTR  Then
GMESSAGE ="You are attempting to reinstate an employee that was terminated in a previous tax year. Please note: In order to do this you need to change your tax cycle parameters to the previous tax ye"
&  + "ar. This may have an impact on statutory reporting."
mkstat=1
Else
Call SET_ALLDAT([M:CTR0]CTRDAT,VPERCOD)
End
Endif
Endif


#ADNGO - 2017-05-30 - X3-12050 - START
  #[M:CTR5]IRPENDDAT = DTAXEND : Affzo [M:CTR5]IRPENDDAT
#ADNGO - 2017-05-23 - X3-12050 - END



#ADNGO - 2017-05-23 - X3-12050 - START
# If [M:CTR8]XITDAT <> [00/00/00] Then
# If [M:CTR8]XITDAT < DTAXSTR  Then
#
#GMESSAGE ="You are attempting to reinstate an employee that was terminated in a previous tax year. Please note: In order to do this you need to change your tax cycle parameters to the previous tax
# ye"
#&  + "ar. This may have an impact on statutory reporting."
#mkstat=1
#End
#Endif
#Endif
#ADNGO - 2017-05-23 - X3-12050 - END
End
#ADNGO - 2017-05-24 - JIRA X3-12050 - END
# JASMI - 2014/03/10 - Requirement 93909 US 2439
# Adding fields to CTR5 for SA localization

Subprog C_TAXDMDAMT(VALEUR)
Variable Decimal VALEUR

  If [M:CTR5]TAXSTA=7
    If VALEUR=0
      mkstat = 1 : GMESSAGE = mess(10,123,1)
    Endif
  Endif

End

# JASMI - 2014/03/19 - Requirement 93909 US 2439
# New business rule - Warn the user when changing the Deemed Remuneration amount
Subprog AM_TAXDMDAMT(VALEUR)
Variable Decimal VALEUR
Local Integer VOK
  If [M:CTR5]TAXDMDAMT <> 0
    Call OUINON (mess(10,11662,1)+".\"+mess(152,123,1), VOK) From GESECRAN
    If VOK=1
      VALEUR = [M:CTR5]TAXDMDAMT
    Endif
  Endif
End
# JASMI - 2014/03/19 - Requirement 93909 US 2439
# End

Subprog C_TAXDIRPRC(VALEUR)
Variable Decimal VALEUR

  If [M:CTR5]TAXSTA=2 or [M:CTR5]TAXSTA=6 or [M:CTR5]TAXSTA=20
    If VALEUR=0
      mkstat = 1 : GMESSAGE = mess(10,123,1)
    Endif
  Endif

  If VALEUR<0
    mkstat = 1 : GMESSAGE = mess(5,11662,1)
  Endif
  # JASMI - 2014/04/29 - Changed from 0.4 to 2.2 - START
  #If VALEUR>=1
  If VALEUR>50
  # JASMI - 2014/04/29 - Changed from 0.4 to 2.2 - END
    mkstat = 1 : GMESSAGE = mess(83,123,1)
  Endif

End

Subprog C_TAXDIRAMT(VALEUR)
Variable Decimal VALEUR

  If [M:CTR5]TAXSTA=16 or [M:CTR5]TAXSTA=17
    If VALEUR=0
      mkstat = 1 : GMESSAGE = mess(10,123,1)
    Endif
  Endif

  If VALEUR<0
    mkstat = 1 : GMESSAGE = mess(5,11662,1)
  Endif

End

Subprog C_TAXDIRNUM(VALEUR)
Variable Char    VALEUR()

  If [M:CTR5]TAXSTA=2 or [M:CTR5]TAXSTA=6 or [M:CTR5]TAXSTA=7 or [M:CTR5]TAXSTA=16 or [M:CTR5]TAXSTA=17
    If VALEUR=""
      mkstat = 1 : GMESSAGE = mess(10,123,1)
    Endif
  Endif

End

Subprog AM_TAXSTA(VALEUR)
Variable Integer VALEUR

# JASMI - 2014/04/08 - Requirement 93909 US 2439 - Start
  Call ENABLE_DISABLE_BASED_ON_TAX_STATUS(VALEUR)
  Call SET_UIF_BASED_ON_TAX_STATUS(VALEUR)
# JASMI - 2014/04/08 - Requirement 93909 US 2439 - End

  If VALEUR=18 or VALEUR=19 or VALEUR=20 or VALEUR=21 Then
     [M:CTR5]UIFSTA =  6
     If  VALEUR=20 Then
       Actzo [M:CTR5]TAXDIRPRC
       Actzo [M:CTR5]TAXDIRNUM
     Endif
  Endif

  Affzo [M:CTR5]50

End

# JASMI - 2014/04/08 - Requirement 93909 US 2439 - Start
Subprog ENABLE_DISABLE_BASED_ON_TAX_STATUS(VALEUR)
Variable Integer VALEUR

 If VALEUR=20 Then
       Actzo [M:CTR5]TAXDIRPRC
       Actzo [M:CTR5]TAXDIRNUM
       Affzo [M:CTR5]50
       End
  Endif

#ADNGO - 2017-07-27 - X3-46793 - START
#  If VALEUR=4 or VALEUR=5 or VALEUR=6 or VALEUR=7
#    Actzo [M:CTR5]TAXDMDAMT
#  Else
#    Grizo [M:CTR5]TAXDMDAMT
#    Effzo [M:CTR5]TAXDMDAMT
#  Endif
  If func DIVPAYE.IS_KZA(GCURLEG) and GMOIPAY >=gdat$(01,3,2017)
      Grizo [M:CTR5]TAXDMDAMT
      Effzo [M:CTR5]TAXDMDAMT
  Else
    If VALEUR=4 or VALEUR=5 or VALEUR=6 or VALEUR=7
      Actzo [M:CTR5]TAXDMDAMT
    Else
      Grizo [M:CTR5]TAXDMDAMT
      Effzo [M:CTR5]TAXDMDAMT
    Endif
  Endif
#ADNGO - 2017-07-27 - X3-46793 - END

  If VALEUR=2 or VALEUR=6 or VALEUR=7 or VALEUR=16 or VALEUR=17
    Actzo [M:CTR5]TAXDIRNUM
  Else
    Grizo [M:CTR5]TAXDIRNUM
    Effzo [M:CTR5]TAXDIRNUM
  Endif

  If VALEUR=2 or VALEUR=6
    Actzo [M:CTR5]TAXDIRPRC
  Else
    Grizo [M:CTR5]TAXDIRPRC
    Effzo [M:CTR5]TAXDIRPRC
  Endif

  If VALEUR=16 or VALEUR=17
    Actzo [M:CTR5]TAXDIRAMT
  Else
    Grizo [M:CTR5]TAXDIRAMT
    Effzo [M:CTR5]TAXDIRAMT
  Endif

  Affzo [M:CTR5]50

End

Subprog SET_UIF_BASED_ON_TAX_STATUS(VALEUR)
Variable Integer VALEUR

  If VALEUR=8 or VALEUR=13
    [M:CTR5]UIFSTA = 6
    Grizo [M:CTR5]UIFSTA
  Else
    If VALEUR=14 or VALEUR=15
      [M:CTR5]UIFSTA = 7
      Grizo [M:CTR5]UIFSTA
    Else
      [M:CTR5]UIFSTA = 1
      Actzo [M:CTR5]UIFSTA
    Endif
  Endif

  Affzo [M:CTR5]55

End
# JASMI - 2014/04/08 - Requirement 93909 US 2439 - End

