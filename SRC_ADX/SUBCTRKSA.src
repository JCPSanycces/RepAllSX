#FRLAA - 2015-04-14 - Requirement 104631 US 3487 - START
Subprog AM_POT(VALEUR)
Variable Char    VALEUR()

#JOJAC - 2016-06-02 - REQ114309 US2150 - START (GX3APP)
#If  func AFNC.ACTIV("FKZQS")>0
If  func AFNC.ACTIV("FKZQS")>0 & GCURLEG = 'ZAF'
#JOJAC - 2016-06-02 - REQ114309 US215 - END (GX3APP)
  If clalev([F:PSA]) = 0 : Local File POSTEKSA    [PSA]         : Endif
  Read [F:PSA]PSA0 = VALEUR
  If !fstat
    [M:CTR1]OCPLEV    = [F:PSA]OCPLEV     :     Affzo [M:CTR1]OCPLEV
    [M:CTR1]EQUEMPTYP = [F:PSA]EQUEMPTYP  :     Affzo [M:CTR1]EQUEMPTYP
    [M:CTR1]OFOCOD    = [F:PSA]OFOCOD     :     Affzo [M:CTR1]OFOCOD
  Endif
Endif
End
