# JASMI - 2014/07/28 - US 2848 - START
Subprog AM_TYPJOB(VALEUR)
Variable Integer VALEUR
  If [M:CTR1]TYPJOB = 7 Then
    [M:CTR5]NONQLFEMP = 2
    Affzo [M:CTR5]NONQLFEMP
  Endif
End
# JASMI - 2014/07/28 - US 2848 - END
#FRLAA - 2015-04-17 - Requirement 104631 US 3487 - START
Subprog AM_JOBPOT(VALEUR)
Variable Char    VALEUR()
If [M:CTR1]POT = "" # only override values if no position is selected
  If clalev([F:JSA]) = 0 : Local File JOBTYPKSA    [JSA]         : Endif
  Read [F:JSA]JSA0 = VALEUR
  If !fstat
    [M:CTR1]OCPLEV    = [F:JSA]OCPLEV     :     Affzo [M:CTR1]OCPLEV
    [M:CTR1]EQUEMPTYP = [F:JSA]EQUEMPTYP  :     Affzo [M:CTR1]EQUEMPTYP
    #[M:CTR1]OFOCOD    = [F:JSA]OFOCOD     :     Affzo [M:CTR1]OFOCOD
  Endif
Endif
End
#FRLAA - 2015-04-17 - Requirement 104631 US 3487 - END

