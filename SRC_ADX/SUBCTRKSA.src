# JASMI - 2015-01-12 - Requirement 104630 US 3276 - END

#MAPAD 2015-05-26 - Requirement 113638  US 4202  - START
Subprog C_DEFAULTRES(VALEUR)
Variable Integer VALEUR, RESIND, LINENUM

RESIND = 0

  If VALEUR = 4
    For I=0 To [M:CTR4]ADDTYP
      If [M:CTR4]ADDTYP(I) = 1
        LINENUM =  I
        RESIND = 1
      Endif
    Next

    If RESIND = 0
      GERR=1
      GMESSAGE=mess(50 ,11662,1)

      [M:CTR4]ADDTYP(nolign - 1) = 1
      Affzo [M:CTR4]ADDTYP(nolign-1)

      [M:CTR4]ADDSRVTYP(nolign - 1) = 0
      Affzo [M:CTR4]ADDSRVTYP(nolign-1)

    Else
      [M:CTR4]ADDPOSOTH(nolign - 1) = [M:CTR4]ADDPOSOTH(LINENUM)
      [M:CTR4]ADDPOSNUM(nolign - 1) = [M:CTR4]ADDPOSNUM(LINENUM)
      [M:CTR4]ADDPOSNAM(nolign - 1) = [M:CTR4]ADDPOSNAM(LINENUM)
      [M:CTR4]ADDPOSAGN(nolign - 1) = [M:CTR4]ADDPOSAGN(LINENUM)
      [M:CTR4]ADDCPX(nolign - 1)    = [M:CTR4]ADDCPX(LINENUM)
      [M:CTR4]ADDSTRNUM(nolign - 1) = [M:CTR4]ADDSTRNUM(LINENUM)
      [M:CTR4]ADDSTRNAM(nolign - 1) = [M:CTR4]ADDSTRNAM(LINENUM)
      [M:CTR4]ADDSUB(nolign - 1)    = [M:CTR4]ADDSUB(LINENUM)
      [M:CTR4]ADDTWN(nolign - 1)    = [M:CTR4]ADDTWN(LINENUM)
      [M:CTR4]ADDPOSCDE(nolign - 1) = [M:CTR4]ADDPOSCDE(LINENUM)
      [M:CTR4]ADDCNTCDE(nolign - 1) = [M:CTR4]ADDCNTCDE(LINENUM)
      [M:CTR4]ADDPRV(nolign - 1)    = [M:CTR4]ADDPRV(LINENUM)
      [M:CTR4]ADDPOSCOF(nolign - 1) = [M:CTR4]ADDPOSCOF(LINENUM)
      [M:CTR4]ADDPOSINM(nolign - 1) = [M:CTR4]ADDPOSINM(LINENUM)
      [M:CTR4]ADDSTA(nolign - 1)    = [M:CTR4]ADDSTA(LINENUM)

      Affzo [M:CTR4]ADDPOSOTH(nolign - 1)
      Affzo [M:CTR4]ADDPOSNUM(nolign - 1)
      Affzo [M:CTR4]ADDPOSNAM(nolign - 1)
      Affzo [M:CTR4]ADDPOSAGN(nolign - 1)
      Affzo [M:CTR4]ADDCPX(nolign - 1)
      Affzo [M:CTR4]ADDSTRNUM(nolign - 1)
      Affzo [M:CTR4]ADDSTRNAM(nolign - 1)
      Affzo [M:CTR4]ADDSUB(nolign - 1)
      Affzo [M:CTR4]ADDTWN(nolign - 1)
      Affzo [M:CTR4]ADDPOSCDE(nolign - 1)
      Affzo [M:CTR4]ADDCNTCDE(nolign - 1)
      Affzo [M:CTR4]ADDPRV(nolign - 1)
      Affzo [M:CTR4]ADDPOSCOF(nolign - 1)
      Affzo [M:CTR4]ADDPOSINM(nolign - 1)
      Affzo [M:CTR4]ADDSTA(nolign - 1)

      Grizo [M:CTR4]ADDPOSOTH(nolign-1)
      Grizo [M:CTR4]ADDPOSNUM(nolign-1)
      Grizo [M:CTR4]ADDPOSNAM(nolign-1)
      Grizo [M:CTR4]ADDPOSAGN(nolign-1)
      Grizo [M:CTR4]ADDCPX(nolign-1)
      Grizo [M:CTR4]ADDSTRNUM(nolign-1)
      Grizo [M:CTR4]ADDSTRNAM(nolign-1)
      Grizo [M:CTR4]ADDSUB(nolign-1)
      Grizo [M:CTR4]ADDTWN(nolign-1)
      Grizo [M:CTR4]ADDPOSCDE(nolign-1)
      Grizo [M:CTR4]ADDCNTCDE(nolign-1)
      Grizo [M:CTR4]ADDPRV(nolign-1)
      Grizo [M:CTR4]ADDPOSCOF(nolign-1)
      Grizo [M:CTR4]ADDPOSINM(nolign-1)

    Endif
  Endif
End
#MAPAD 20/01/2016 - Requirement 113638  US 4202   - END

#JOJAC - 2016-06-22 - REQ114309 US267 - END

#JOJAC - 2016-07-11 - START
Subprog C_ADDPOSNAM(VALEUR)
Variable Char    VALEUR()
  If [M:CTR4]ADDTYP(nolign-1)=2 Then
    If find([M:CTR4]ADDSRVTYP(nolign-1), 1, 2, 3) > 0 Then
      If VALEUR = "" Then
        GMESSAGE=mess(10,123,1)
        mkstat=2
      Endif
    Endif
  Endif
End

Subprog C_ADDTWN(VALEUR)
Variable Char    VALEUR()
  If [M:CTR4]ADDTYP(nolign-1)=2 Then
    If [M:CTR4]ADDSRVTYP(nolign-1)=5 Then
      If VALEUR="" & [M:CTR4]ADDSUB(nolign-1)="" Then
        GMESSAGE = mess(26,11662,1)
        mkstat=2
      Endif
    Endif
  Else
    If VALEUR="" & [M:CTR4]ADDSUB(nolign-1)="" Then
      GMESSAGE = mess(26,11662,1)
      mkstat=2
    Endif
  Endif
End
######################################################################################
######################################################################################
## Section automatically added (screen MAT1) 01/12/2015 13:23:52 (JASMI)
######################################################################################
Subprog AM_ADDSRVTYP(VALEUR)
Variable Integer VALEUR
  Call ENABLE_DISABLE_FOR_POSTAL_ADDRESS(VALEUR)
End

Subprog AM_ADDPOSCOF(VALEUR)
Variable Integer VALEUR
  If VALEUR=1 Then
    Grizo [M:CTR4]ADDPOSINM(nolign-1)
    Effzo [M:CTR4]ADDPOSINM(nolign-1)
  Else
    Actzo [M:CTR4]ADDPOSINM(nolign-1)
  Endif
End

Subprog AP_ADDTYP(VALEUR)
Variable Integer VALEUR

If VALEUR <> 2
      [M:CTR4]ADDSRVTYP = 0 : Affzo [M:CTR4]ADDSRVTYP  : Grizo [M:CTR4]ADDSRVTYP
      Else
      Actzo [M:CTR4]ADDSRVTYP
Endif

   If VALEUR = 1 | VALEUR = 3
    Grizo [M:CTR4]ADDPOSOTH
    Grizo [M:CTR4]ADDPOSNAM
    Grizo [M:CTR4]ADDPOSAGN
    Grizo [M:CTR4]ADDPOSCOF
    Grizo [M:CTR4]ADDPOSINM
   Endif
End

Subprog SET_TAXENDDAT(VALEUR, VPERCOD)
  Variable Date VALEUR
  #Variable Char VSITE
  Variable Char VPERCOD
  Local Char PREPAYREF(30) : PREPAYREF = ""
  #Local Char STAXSTR(9), STAXEND(9) : STAXSTR  = "TAXSTRDAT" : STAXEND = "TAXENDDAT"
  Local Date DTAXSTR, DTAXEND,PRVDTAXSTR,PRVDTAXEND
  #Local Char TMP_TAXSTRDAT(30), TMP_TAXENDDAT(30)
  Local Integer THISTAXYEAR



  #Getting the Tax start and end date - Parameter
#  Call PARAM(VSITE, STAXSTR, TMP_TAXSTRDAT) From ADOVAL
#  If TMP_TAXSTRDAT = "" Then : TMP_TAXSTRDAT = "00000000" : Endif
#  DTAXSTR = gdat$(TMP_TAXSTRDAT)
#
#  Call PARAM(VSITE, STAXEND, TMP_TAXENDDAT) From ADOVAL
#  If TMP_TAXENDDAT = "" Then : TMP_TAXENDDAT = "00000000" : Endif
#  DTAXEND = gdat$(TMP_TAXENDDAT)

If clalev([F:HRPEOH]) = 0 : Local File HRPEOHEA [HRPEOH] : Endif

Filter [F:HRPEOH] Where [F:HRPEOH]PERCOD = VPERCOD & [F:HRPEOH]FLGENA=2
#LIPET - 2018-09-19 - X3-106452 - START
#Read First
Read [F:HRPEOH] First
#LIPET - 2018-09-19 - X3-106452 - END
If !fstat
  DTAXSTR=gdat$([F:HRPEOH]CYCSTRDAT)
  DTAXEND=gdat$([F:HRPEOH]CYCENDDAT)
Else
  DTAXSTR = gdat$("00000000")
  DTAXEND=gdat$("00000000")
Endif
Filter [F:HRPEOH]


If VALEUR <> [00/00/00] Then
If VALEUR < DTAXSTR  Then
GERR = 1
GMESSAGE ="You are attempting to terminate an employee in a previous tax year. Please note: In order to do this you need to change your tax cycle parameters to the previous tax year. This may have an"
&  + " impact on statutory reporting."
End
Endif
Endif


#  Local Date VPARAMDATE : VPARAMDATE = VALEUR
#  If VPARAMDATE > DTAXEND | VPARAMDATE = [0/0/0] | VPARAMDATE < DTAXSTR
#    VPARAMDATE = DTAXEND
#  Endif


  Local Date VPARAMDATE : VPARAMDATE = VALEUR
  If VPARAMDATE = [0/0/0] | VPARAMDATE < DTAXSTR
    If [M:CTR0]CTRDAT > DTAXEND
       While  [M:CTR0]CTRDAT > DTAXEND
         DTAXEND = addmonth(DTAXEND,12)
       Wend
     VPARAMDATE = DTAXEND
    Else
     VPARAMDATE = DTAXEND
    Endif
  Elsif VPARAMDATE > DTAXEND
      VPARAMDATE = DTAXEND
  Endif




  #If func AFNC.ACTIV("KZA") > 0 # Changed 2015/04/14 activity codes on PAYINDV7 If func AFNC.ACTIV("KZA") > 0
  If func DIVPAYE.IS_KZA(GCURLEG) # Changed 2015/04/14 activity codes on PAYINDV7 If func AFNC.ACTIV("KZA") > 0
    [M:CTR5]IRPENDDAT = VPARAMDATE
     Affzo [M:CTR5]IRPENDDAT
  #Elsif func AFNC.ACTIV("KAQ") > 0
  Elsif func DIVPAYE.IS_AFRICA_LEG(GCURLEG)
    [M:CTR5]TAXENDDAT = VPARAMDATE
    Affzo [M:CTR5]TAXENDDAT
  Endif
#  Elsif func AFNC.ACTIV("KJO") > 0
#    [M:CTR5]TAXENDDATMID = VPARAMDATE
#    Affzo [M:CTR5]TAXENDDATMID
#  Endif

  Affzo [M:CTR8]XITDAT


End

Subprog SET_ALLDAT(VALEUR, VPERCOD)
  Variable Date VALEUR
  Variable Char VPARAM
  #Variable Char VSITE
  Variable Char VPERCOD
  Local Char PREPAYREF(30) : PREPAYREF = ""
  #Local Char STAXSTR(9), STAXEND(9) : STAXSTR  = "TAXSTRDAT" : STAXEND = "TAXENDDAT"
  Local Date DTAXSTR, DTAXEND
  #Local Char TMP_TAXSTRDAT(30), TMP_TAXENDDAT(30)

  #Getting the Tax start and end date - Parameter
#  Call PARAM(VSITE, STAXSTR, TMP_TAXSTRDAT) From ADOVAL
#  If TMP_TAXSTRDAT = "" Then : TMP_TAXSTRDAT = "00000000" : Endif
#  DTAXSTR = gdat$(TMP_TAXSTRDAT)
#
#  Call PARAM(VSITE, STAXEND, TMP_TAXENDDAT) From ADOVAL
#  If TMP_TAXENDDAT = "" Then : TMP_TAXENDDAT = "00000000" : Endif
#  DTAXEND = gdat$(TMP_TAXENDDAT)

If clalev([F:HRPEOH]) = 0 : Local File HRPEOHEA [HRPEOH] : Endif

Filter [F:HRPEOH] Where [F:HRPEOH]PERCOD = VPERCOD & [F:HRPEOH]FLGENA=2
#LIPET - 2018-09-19 - X3-106452 - START
#Read First
Read [F:HRPEOH] First
#LIPET - 2018-09-19 - X3-106452 - END
If !fstat
  DTAXSTR=gdat$([F:HRPEOH]CYCSTRDAT)
  DTAXEND=gdat$([F:HRPEOH]CYCENDDAT)
Else
End
Endif
Filter [F:HRPEOH]

  #If func AFNC.ACTIV("KZA") > 0 # Changed 2015/04/14 activity codes on PAYINDV7 If func AFNC.ACTIV("KZA") > 0
  If func DIVPAYE.IS_KZA(GCURLEG)
    If VALEUR < DTAXSTR

      [M:CTR5]IRPSTRDAT = DTAXSTR
    Else
     If VALEUR > DTAXEND Then
        [M:CTR5]IRPSTRDAT =  VALEUR

        While  VALEUR > DTAXEND
          DTAXEND = addmonth(DTAXEND,12)
        Wend
         If [M:CTR8]XITFNL = 2 and [M:CTR8]XITDAT <= DTAXEND Then
            DTAXEND = [M:CTR8]XITDAT
         Endif
      Else

        If clalev([F:CTR5])=0 : Local File EMPLOCTR[CTR5] : Endif
        If clalev([F:CTRSA5])=0 : Local File EMPLOCTRSA[CTRSA5] : Endif


        Filter [CTR5] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM
        Read [CTR5]CTR1 Last

        Filter [CTRSA5] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM
        Read [CTRSA5]CTRSA1 Last

      #  Filter [CTR5]
        If !fstat
          If [F:CTR5]XITFNL = 2 Then
             [M:CTR5]IRPSTRDAT = VALEUR
          Else
              If [CTRSA5]IRPSTRDAT < DTAXSTR Then
                 [M:CTR5]IRPSTRDAT = VALEUR
              Else
                 [M:CTR5]IRPSTRDAT = [CTRSA5]IRPSTRDAT
              Endif
          Endif
         Else
          [M:CTR5]IRPSTRDAT = VALEUR
        Endif
     Endif
    Endif
    [M:CTR5]IRPENDDAT = DTAXEND
    Affzo [M:CTR5]IRPSTRDAT
    Affzo [M:CTR5]IRPENDDAT
    GERR = 2  : GMESSAGE = "SET_ALLDAT : " + mess(19, 11706, 1) - [M:CTR5]IRPSTRDAT - " to " - [M:CTR5]IRPENDDAT

  Elsif func DIVPAYE.IS_AFRICA_LEG(GCURLEG)
       If VALEUR < DTAXSTR
        [M:CTR5]TAXSTRDAT = DTAXSTR
      Else

      If VALEUR > DTAXEND Then
        [M:CTR5]TAXSTRDAT =  VALEUR

        While  VALEUR > DTAXEND
          DTAXEND = addmonth(DTAXEND,12)
        Wend
      Else
        If clalev([F:CTR5])=0 : Local File EMPLOCTR[CTR5] : Endif
        If clalev([F:CTRAFR5])=0 : Local File EMPLOCTRAFR[CTRAFR5] : Endif

        Filter [CTR5] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM
        Read [CTR5]CTR1 Last

        Filter [CTRAFR5] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM
        Read [CTRAFR5]CTRAFR1 Last

      #  Filter [CTR5]
        If !fstat
          If [F:CTR5]XITFNL = 2 Then
             [M:CTR5]TAXSTRDAT = VALEUR
          Else

              If [CTRAFR5]TAXSTRDAT < DTAXSTR Then
                 [M:CTR5]TAXSTRDAT = VALEUR
              Else
                 [M:CTR5]TAXSTRDAT = [CTRAFR5]TAXSTRDAT
              Endif

          Endif
         Else
          [M:CTR5]TAXSTRDAT = VALEUR
        Endif
     Endif
   Endif
      [M:CTR5]TAXENDDAT = DTAXEND
      Affzo [M:CTR5]TAXSTRDAT
      Affzo [M:CTR5]TAXENDDAT
      GERR = 2  : GMESSAGE = "SET_ALLDAT : " + mess(19, 11706, 1) - [M:CTR5]TAXSTRDAT - " to " - [M:CTR5]TAXENDDAT
Endif
#Elsif func AFNC.ACTIV("KJO") > 0
#      If VALEUR < DTAXSTR
#        [M:CTR5]TAXSTRDATMID = DTAXSTR
#      Else
#        If clalev([F:CTR5])=0 : Local File EMPLOCTR[CTR5] : Endif
#        If clalev([F:CTRMID5])=0 : Local File EMPLOCTRMID[CTRMID5] : Endif
#
#
#        Filter [CTRMID5] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM
#        Read [CTRMID5]CTRMID1 Last
#
#        Filter [CTR5] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM
#        Read [CTR5]CTR1 Last
#
#
#      #  Filter [CTR5]
#        If !fstat
#          If [F:CTR5]XITFNL = 2 Then
#             [M:CTR5]TAXSTRDATMID = VALEUR
#          Else
#             [M:CTR5]TAXSTRDATMID = [CTRMID5]TAXSTRDATMID
#          Endif
#         Else
#          [M:CTR5]TAXSTRDATMID = VALEUR
#        Endif
#     Endif
#      [M:CTR5]TAXENDDATMID = DTAXEND
#      Affzo [M:CTR5]TAXSTRDATMID
#      Affzo [M:CTR5]TAXENDDATMID
#      GERR = 2  : GMESSAGE = "SET_ALLDAT : " + mess(19, 11706, 1) - [M:CTR5]TAXSTRDATMID - " to " - [M:CTR5]TAXENDDATMID
#
#  Endif
End

Subprog VERIF_TAXENDDAT(VALEUR, VPERCOD)
  Variable Date VALEUR
  #Variable Char VSITE
  Variable Char VPERCOD
  Local Char PREPAYREF(30) : PREPAYREF = ""
  #Local Char STAXSTR(9), STAXEND(9) : STAXSTR  = "TAXSTRDAT" : STAXEND = "TAXENDDAT"
  Local Date DTAXSTR, DTAXEND
  #Local Char TMP_TAXSTRDAT(30), TMP_TAXENDDAT(30)

  #Getting the Tax start and end date - Parameter
#  Call PARAM(VSITE, STAXSTR, TMP_TAXSTRDAT) From ADOVAL
#  If TMP_TAXSTRDAT = "" Then : TMP_TAXSTRDAT = "00000000" : Endif
#  DTAXSTR = gdat$(TMP_TAXSTRDAT)
#
#  Call PARAM(VSITE, STAXEND, TMP_TAXENDDAT) From ADOVAL
#  If TMP_TAXENDDAT = "" Then : TMP_TAXENDDAT = "00000000" : Endif
#  DTAXEND = gdat$(TMP_TAXENDDAT)

If clalev([F:HRPEOH]) = 0 : Local File HRPEOHEA [HRPEOH] : Endif

Filter [F:HRPEOH] Where [F:HRPEOH]PERCOD = VPERCOD & [F:HRPEOH]FLGENA=2
#LIPET - 2018-09-19 - X3-106452 - START
#Read First
Read [F:HRPEOH] First
#LIPET - 2018-09-19 - X3-106452 - END
If !fstat
  DTAXSTR=gdat$([F:HRPEOH]CYCSTRDAT)
  DTAXEND=gdat$([F:HRPEOH]CYCENDDAT)
Else
  DTAXSTR = gdat$("00000000")
  DTAXEND=gdat$("00000000")
Endif
Filter [F:HRPEOH]

  #Verify against action and fields needed
  If VALEUR > DTAXEND
    GERR = 3  : GMESSAGE = "VERIF_TAXENDDAT : " + mess(14, 11706, 1)
  Elsif VALEUR < DTAXSTR
    GERR = 3  : GMESSAGE = "VERIF_TAXENDDAT : " + mess(15, 11706, 1)
  Endif

End

Subprog VERIF_TAXSTRDAT(VALEUR, VPERCOD)
  Variable Date VALEUR
  #Variable Char VSITE
  Variable Char VPERCOD
  Local Char PREPAYREF(30) : PREPAYREF = ""
  L#ocal Char STAXSTR(9), STAXEND(9) : STAXSTR  = "TAXSTRDAT" : STAXEND = "TAXENDDAT"
  Local Date DTAXSTR, DTAXEND
  #Local Char TMP_TAXSTRDAT(30), TMP_TAXENDDAT(30)



  #Getting the Tax start and end date - Parameter
#  Call PARAM(VSITE, STAXSTR, TMP_TAXSTRDAT) From ADOVAL
#  If TMP_TAXSTRDAT = "" Then : TMP_TAXSTRDAT = "00000000" : Endif
#  DTAXSTR = gdat$(TMP_TAXSTRDAT)
#
#  Call PARAM(VSITE, STAXEND, TMP_TAXENDDAT) From ADOVAL
#  If TMP_TAXENDDAT = "" Then : TMP_TAXENDDAT = "00000000" : Endif
#  DTAXEND = gdat$(TMP_TAXENDDAT)

If clalev([F:HRPEOH]) = 0 : Local File HRPEOHEA [HRPEOH] : Endif

Filter [F:HRPEOH] Where [F:HRPEOH]PERCOD = VPERCOD & [F:HRPEOH]FLGENA=2
#LIPET - 2018-09-19 - X3-106452 - START
#Read First
Read [F:HRPEOH] First
#LIPET - 2018-09-19 - X3-106452 - END
If !fstat
  DTAXSTR=gdat$([F:HRPEOH]CYCSTRDAT)
  DTAXEND=gdat$([F:HRPEOH]CYCENDDAT)
Else
  DTAXSTR = gdat$("00000000")
  DTAXEND=gdat$("00000000")
Endif
Filter [F:HRPEOH]


  #Verify against action and fields needed
  If VALEUR < DTAXSTR
    GERR =  3 : GMESSAGE = "VERIF_TAXSTRDAT : " + mess(6, 11706, 1)
  Elsif VALEUR > DTAXEND
    GERR = 3  : GMESSAGE = "VERIF_TAXSTRDAT : " + mess(8, 11706, 1)
  Endif

End

