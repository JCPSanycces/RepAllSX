If func AFNC.ACTIV("FKZQS") & func DIVPAYE.IS_KZA(GCURLEG)
#JASMI - 2016-06-02 - REQ 114309 - END
   Delete [HRAFRCL] Where CTRNUM = [M]CTRNUM & REFNUM = [M]REFNUM & CTRDAT = [M]CTRDAT
   If fstat=1 | fstat>5
    GOK=0 : Call RSTA("HRAFRCL",[M:CTR0]CTRNUM-num$([M:CTR0]CTRDAT)) From GLOCK : Return
   Endif
Endif


 Delete [ETR] Where CTRNUM = [M]CTRNUM & REFNUM = [M]REFNUM &  TAXYEA=THISTAXYEAR
 If fstat=1 | fstat>5
  GOK=0 : Call RSTA("ETR",[M:CTR0]CTRNUM) From GLOCK : Return
 Endif
#JASMI - 2016-04-06 - ISSUE 115628 - START

Return

$FILTRE
#JOJAC - 2016-06-09 - REQ114309 US215 - START
If !func DIVPAYE.IS_KZA(GCURLEG) : Return : Endif
#JOJAC - 2016-06-09 - REQ114309 US215 - END
    If clalev([F:CTRSA]) = 0 : Local File EMPLOCTRSA    [CTRSA]         : Endif
    If [F:HRCTR]REFNUM <> [F:CTRSA]REFNUM or [F:HRCTR]CTRNUM <> [F:CTRSA]CTRNUM or [F:HRCTR]CTRDAT <> [F:CTRSA]CTRDAT
      If dim([M]CTRNUM)>0 & dim([M]REFNUM)>0 & dim([M]CTRDAT)>0 Then
        Read [CTRSA]CTRSA0 = [M]REFNUM; [M]CTRNUM; [M]CTRDAT
      Endif
    Endif

Return

