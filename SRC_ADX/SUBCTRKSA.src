#      Grizo [M:EMP1]ADDPOSNAM(nolign-1) : Raz [M:EMP1]ADDPOSNAM(nolign-1)
#      Grizo [M:EMP1]ADDPOSAGN(nolign-1) : Raz [M:EMP1]ADDPOSAGN(nolign-1)
#      Grizo [M:EMP1]ADDPOSCOF(nolign-1) : Raz [M:EMP1]ADDPOSCOF(nolign-1)
#      Grizo [M:EMP1]ADDPOSINM(nolign-1) : Raz [M:EMP1]ADDPOSINM(nolign-1)
#      Grizo [M:EMP1]ADDCPX(nolign-1)    : Raz [M:EMP1]ADDCPX(nolign-1)
#      Grizo [M:EMP1]ADDSTRNUM(nolign-1) : Raz [M:EMP1]ADDSTRNUM(nolign-1)
#      Grizo [M:EMP1]ADDSTRNAM(nolign-1) : Raz [M:EMP1]ADDSTRNAM(nolign-1)
#      Grizo [M:EMP1]ADDSUB(nolign-1)    : Raz [M:EMP1]ADDSUB(nolign-1)
#      Grizo [M:EMP1]ADDTWN(nolign-1)    : Raz [M:EMP1]ADDTWN(nolign-1)
#      Grizo [M:EMP1]ADDPOSCDE(nolign-1) : Raz [M:EMP1]ADDPOSCDE(nolign-1)
#      Grizo [M:EMP1]ADDCNTCDE(nolign-1) : Raz [M:EMP1]ADDCNTCDE(nolign-1)

       Call C_DEFAULTRES(VALEUR)
       #MAPAD 20/01/2016 - Requirement 113638  US 4202   - END
    Else
      Grizo [M:CTR4]ADDCPX(nolign-1)    : Raz [M:CTR4]ADDCPX(nolign-1)
      Grizo [M:CTR4]ADDSTRNUM(nolign-1) : Raz [M:CTR4]ADDSTRNUM(nolign-1)
      Grizo [M:CTR4]ADDSTRNAM(nolign-1) : Raz [M:CTR4]ADDSTRNAM(nolign-1)
      Grizo [M:CTR4]ADDSUB(nolign-1)    : Raz [M:CTR4]ADDSUB(nolign-1)
    Endif
  Endif
#JASMI - 2015-11-27 - Req 112521 - END

End

