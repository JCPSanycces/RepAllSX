#      If dim([M:CTR5]CUM9)>0    Chgfmt [M:CTR5]CUM9       With "-"+"Nz:9.2"       :     Raz [M:CTR5]CUM9    :   Endif
#JOJAC - 2016-07-13 - REQ114309 - END

#FRLAA 2015-08-17 - REQUIREMENT 109427 - US 3711 - END
      Chgtbk [M:CTR5]35         With ""   #Cumuls
      Affzo [M:CTR5]35
#JASMI - 2016-06-02 - REQ 114309 - START
#    Endif
#JASMI - 2016-06-02 - REQ 114309 - END
# JASMI - 2014/03/24 - REQUIREMENT 95019 US 2547
# End

#JOJAC - 2016-06-02 - REQ114309 US2150 - START (GX3APP)
#Consider moving this to SUBCTRLEG
If GCURLEG = 'ZAF' & func AFNC.ACTIV("EQM")
 If dim([M:CTR1]EQUEMPTYP)>0    : Chgfmt [M:CTR1]EQUEMPTYP   With "LA:11671" : Endif
 If dim([M:CTR1]OCPLEV)>0    : Chgfmt [M:CTR1]OCPLEV   With "LA:11670" : Endif
 If dim([M:CTR1]OFOCOD)>0    : Chgfmt [M:CTR1]OFOCOD   With "K:15" : Endif
Endif

If GCURLEG <> 'ZAF' | !func AFNC.ACTIV("EQM")
 If dim([M:CTR1]EQUEMPTYP)>0    : Chgfmt [M:CTR1]EQUEMPTYP   With "-LA:11671" : Endif
 If dim([M:CTR1]OCPLEV)>0    : Chgfmt [M:CTR1]OCPLEV   With "-LA:11670" : Endif
 If dim([M:CTR1]OFOCOD)>0    : Chgfmt [M:CTR1]OFOCOD   With "-K:15" : Endif
Endif
#JOJAC - 2016-06-02 - REQ114309 US2150 - END

Return

#FRLAA - 2015-03-23 - REQUIREMENT 105849 US 3486 - START
#FRLAA - 2015-03-31 - Requirement 104590 US 3260 - START
#FRLAA - 2015-05-21 - REQUIREMENT 108198 US 3582 - START
#JOJAC - 2016-12-06 - START
#Subprog MANAGE_TAX_DATES(VALEUR, VPARAM, VSITE)
Subprog MANAGE_TAX_DATES(VALEUR, VPARAM, VSITE,VPERCOD)
#JOJAC - 2016-12-06 - END
  Variable Date VALEUR
  Variable Char VPARAM
  Variable Char VSITE
  Variable Char VPERCOD
  Local Char PREPAYREF : PREPAYREF = ""
  Local Char STAXSTR(9), STAXEND(9) : STAXSTR  = "TAXSTRDAT" : STAXEND = "TAXENDDAT"
  Local Date DTAXSTR, DTAXEND
  Local Char TMP_TAXSTRDAT, TMP_TAXENDDAT

#JASMI - 2015-09-22 - Localization for Angola - START
#JASMI - 2016-02-16 - Issue 114547 - START
#  If func AFNC.ACTIV("KAO")>0
#JASMI - 2016-06-02 - REQ 114309 - START
#  If func AFNC.ACTIV("KAO")>0 or func AFNC.ACTIV("KMA")>0
  If func DIVPAYE.IS_KAO_LEG(GCURLEG) or func DIVPAYE.IS_KMA_LEG(GCURLEG)
#JASMI - 2016-06-02 - REQ 114309 - END
#JASMI - 2016-02-16 - Issue 114547 - END
    End
  Endif
#JASMI - 2015-09-22 - Localization for Angola - END


#JOJAC - 2016/12/05 - START
#Getting the Tax start and end date - Parameter
#  Call PARAM(VSITE, STAXSTR, TMP_TAXSTRDAT) From ADOVAL
#  If TMP_TAXSTRDAT = "" Then : TMP_TAXSTRDAT = "00000000" : Endif
#
#  DTAXSTR = gdat$(TMP_TAXSTRDAT)
#
##If GUSER = 'JOJAC' : dbgmode=1 : Dbgaff : Endif
#  Call PARAM(VSITE, STAXEND, TMP_TAXENDDAT) From ADOVAL
#  If TMP_TAXENDDAT = "" Then : TMP_TAXENDDAT = "00000000" : Endif
#  DTAXEND = gdat$(TMP_TAXENDDAT)

If clalev([F:HRPEOH]) = 0 : Local File HRPEOHEA [HRPEOH] : Endif

Filter [F:HRPEOH] Where [F:HRPEOH]PERCOD = VPERCOD & [F:HRPEOH]FLGENA=2
#LIPET - 2018-09-19 - X3-106452 - START
#Read First
Read [F:HRPEOH] First
#LIPET - 2018-09-19 - X3-106452 - END
If !fstat
  DTAXSTR=gdat$([F:HRPEOH]CYCSTRDAT)
  DTAXEND=gdat$([F:HRPEOH]CYCENDDAT)
Else
  DTAXSTR = gdat$("00000000")
  DTAXEND=gdat$("00000000")
Endif
Filter [F:HRPEOH]
#JOJAC - 2016/12/05 - END



  #Verify against action and fields needed (VPARAM)
  If VPARAM = "VERIF_TAXSTRDAT"
    If VALEUR < DTAXSTR
      GERR =  3 : GMESSAGE = mess(6, 11706, 1)
    Elsif VALEUR > DTAXEND
      GERR = 3  : GMESSAGE = mess(8, 11706, 1)
    Endif
  #FRLAA and JASMI - 2015-07-29 - REQUIREMENT 109427 - US 3711 - START
#  Elsif VPARAM = "VERIF_SITE"
#    Filter [CTR] Where CTRNUM = [M:CTR0]CTRNUM & REFNUM = [M:CTR0]REFNUM & CTRDAT = [M:CTR0]CTRDAT
#    Read [CTR] First
#    If !fstat
#      If [F:CTR]ETRFCY <> ""
#        If clalev([F:FCYSA]) = 0 : Local File HRFACILITYSA    [FCYSA]
#          Filter [FCYSA] Where FCY = [F:CTR]ETRFCY
#          Read [FCYSA] First
#          If !fstat
#            PREPAYREF = [F:FCYSA]PAYREFNUM
#            Filter [FCYSA] Where FCY = VSITE
#            Read [FCYSA] First
#            If !fstat
#              If [F:FCYSA]PAYREFNUM <> PREPAYREF
#                GERR = 3  : GMESSAGE = mess(20, 11706, 1)
#              Endif
#            Endif
#          Endif
#        Endif
#      Endif
#   Endif
  #FRLAA and JASMI - 2015-07-29 - REQUIREMENT 109427 - US 3711 - END
  Elsif VPARAM = "VERIF_TAXENDDAT"
    If VALEUR > DTAXEND
      GERR = 3  : GMESSAGE = mess(14, 11706, 1)
    Elsif VALEUR < DTAXSTR
      GERR = 3  : GMESSAGE = mess(15, 11706, 1)
    Endif

  Elsif VPARAM = "SET_TAXENDDAT"
  Local Date VPARAMDATE : VPARAMDATE = VALEUR
    #FRLAA - 2015/05/19 - TBC - START
    If VPARAMDATE > DTAXEND | VPARAMDATE = [0/0/0] | VPARAMDATE < DTAXSTR
      VPARAMDATE = DTAXEND
    Endif
    #FRLAA - 2015/05/19 - TBC - END
#JASMI - 2016-06-02 - REQ 114309 - START
#    If func AFNC.ACTIV("KZA") > 0 # Changed 2015/04/14 activity codes on PAYINDV7 If func AFNC.ACTIV("KZA") > 0
    If func DIVPAYE.IS_KZA(GCURLEG)
#JASMI - 2016-06-02 - REQ 114309 - END
      [M:CTR5]IRPENDDAT = VPARAMDATE
      Affzo [M:CTR5]IRPENDDAT
#JASMI - 2016-06-02 - REQ 114309 - START
#    Elsif func AFNC.ACTIV("KAQ") > 0
    Elsif func DIVPAYE.IS_AFRICA_LEG(GCURLEG)
#JASMI - 2016-06-02 - REQ 114309 - END
      [M:CTR5]TAXENDDAT = VPARAMDATE
      Affzo [M:CTR5]TAXENDDAT
    Endif
    Affzo [M:CTR8]XITDAT
   #Affzo [M:CTR8]XITFNL
   #[M:CTR8]XITFNL = 2
   #GERR = 2 :
   #GMESSAGE = mess(18, 11706, 1) - VPARAMDATE
  Elsif VPARAM = "SET_ALLDAT"
#JASMI - 2016-06-02 - REQ 114309 - START
#    If func AFNC.ACTIV("KZA") > 0 # Changed 2015/04/14 activity codes on PAYINDV7 If func AFNC.ACTIV("KZA") > 0
    If func DIVPAYE.IS_KZA(GCURLEG)
#JASMI - 2016-06-02 - REQ 114309 - END
    #If [M:CTR8]XITFNL = 2 Then
      If VALEUR < DTAXSTR
        [M:CTR5]IRPSTRDAT = DTAXSTR
      Else
        [M:CTR5]IRPSTRDAT = VALEUR
      Endif
      [M:CTR5]IRPENDDAT = DTAXEND
      Affzo [M:CTR5]IRPSTRDAT
      Affzo [M:CTR5]IRPENDDAT
#MIPEA - 2016-11-02 - X3PEOP-1594 - START
      If  GREP <> "C"
#MIPEA - 2016-11-02 - X3PEOP-1594 - END
        GERR = 2  : GMESSAGE = mess(19, 11706, 1) - [M:CTR5]IRPSTRDAT - " to " - [M:CTR5]IRPENDDAT
#MIPEA - 2016-11-02 - X3PEOP-1594 - START
      Endif
    #Endif
#MIPEA - 2016-11-02 - X3PEOP-1594 - END
#JASMI - 2016-06-02 - REQ 114309 - START
#    Elsif func AFNC.ACTIV("KAQ") > 0
    Elsif func DIVPAYE.IS_AFRICA_LEG(GCURLEG)
#JASMI - 2016-06-02 - REQ 114309 - END
      If VALEUR < DTAXSTR
        [M:CTR5]TAXSTRDAT = DTAXSTR
      Else
        [M:CTR5]TAXSTRDAT = VALEUR
      Endif
      [M:CTR5]TAXENDDAT = DTAXEND
      Affzo [M:CTR5]TAXSTRDAT
      Affzo [M:CTR5]TAXENDDAT
#MIPEA - 2016-11-03 - X3PEOP-1594 - START
      If  GREP <> "C"
#MIPEA - 2016-11-03 - X3PEOP-1594 - END
      GERR = 2  : GMESSAGE = mess(19, 11706, 1) - [M:CTR5]TAXSTRDAT - " to " - [M:CTR5]TAXENDDAT
#MIPEA - 2016-11-03 - X3PEOP-1594 - START
      Endif
#MIPEA - 2016-11-03 - X3PEOP-1594 - END
    Endif

  Endif

 End
#FRLAA - 2015-05-21 - REQUIREMENT 108198 US 3582 - END
#FRLAA - 2015-03-31 - REQUIREMENT 105849 US 3486 - END
#FRLAA - 2015-03-31 - Requirement 104590 US 3260 - END

#FRLAA  - 2015-04-02 - Requirement 104590 US 3297 - START
Subprog SET_EMPCTRSA(VREFNUM, VCTRNUM, VCTRDAT, VAVTCTRDAT)
Value Char VREFNUM(), VCTRNUM()
Value Date VCTRDAT, VAVTCTRDAT

#JASMI - 2016-06-02 - REQ 114309 - START
# If func AFNC.ACTIV("KZA")>0 # RSA Only # Changed 2015/04/14 activity codes on PAYINDV7 If func AFNC.ACTIV("KZA") > 0
 If func DIVPAYE.IS_KZA(GCURLEG)
#JASMI - 2016-06-02 - REQ 114309 - END
  If !clalev([F:CTRSA1]) : Local File EMPLOCTRSA [CTRSA1] : Endif
  If !clalev([F:CTRSA2]) : Local File EMPLOCTRSA [CTRSA2] : Endif
  Read [F:CTRSA1]CTRSA0 = VREFNUM ; VCTRNUM ; VCTRDAT
    If !fstat # Create
      Delete [F:CTRSA2] Where CTRNUM = VCTRNUM & REFNUM = VREFNUM & CTRDAT = VAVTCTRDAT
      If fstat = 1
        GOK = -1
        GLOCK = "$EMPLOCTRSA" - VCTRNUM - VREFNUM - VCTRDAT
        Return
      Elsif fstat>5
        GOK = 0
        Call RSTA("CTRSA", VREFNUM - VCTRNUM - VCTRDAT) From GLOCK
        Return
      Endif
      [F:CTRSA2]=[F:CTRSA1]
      [F:CTRSA2]CTRDAT = VAVTCTRDAT
      Write [F:CTRSA2]
      If fstat
        GOK = 0 : Call FSTA("CTRSA") From GLOCK
      Endif
    Endif
#JASMI - 2016-06-02 - REQ 114309 - START
# Elsif func AFNC.ACTIV("KAQ")>0   # Africa only
 Elsif func DIVPAYE.IS_AFRICA_LEG(GCURLEG)
#JASMI - 2016-06-02 - REQ 114309 - END
  If !clalev([F:CTRAFR1]) : Local File EMPLOCTRAFR [CTRAFR1] : Endif
  If !clalev([F:CTRAFR2]) : Local File EMPLOCTRAFR [CTRAFR2] : Endif
  Read [F:CTRAFR1]CTRAFR0 = VREFNUM ; VCTRNUM ; VCTRDAT
    If !fstat # Create
      Delete [F:CTRAFR2] Where CTRNUM = VCTRNUM & REFNUM = VREFNUM & CTRDAT = VAVTCTRDAT
      If fstat = 1
        GOK = -1
        GLOCK = "$EMPLOCTRAFR" - VCTRNUM - VREFNUM - VCTRDAT
        Return
      Elsif fstat>5
        GOK = 0
        Call RSTA("CTRAFR", VREFNUM - VCTRNUM - VCTRDAT) From GLOCK
        Return
      Endif
      [F:CTRAFR2]=[F:CTRAFR1]
      [F:CTRAFR2]CTRDAT = VAVTCTRDAT
      Write [F:CTRAFR2]
      If fstat
        GOK = 0 : Call FSTA("CTRAFR") From GLOCK
      Endif
    Endif
#LIPET - 2018-10-05 - X3-110779 - START
Elsif func DIVPAYE.IS_MIDDLEEAST_LEG(GCURLEG)  # Middel east only
If !clalev([F:CTRMID1]) : Local File EMPLOCTRMID [CTRMID1] : Endif
If !clalev([F:CTRMID2]) : Local File EMPLOCTRMID [CTRMID2] : Endif
Read [F:CTRMID1]CTRMID0 = VREFNUM ; VCTRNUM ; VCTRDAT
  If !fstat # Create
    Delete [F:CTRMID2] Where CTRNUM = VCTRNUM & REFNUM = VREFNUM & CTRDAT = VAVTCTRDAT
    If fstat = 1
      GOK = -1
      GLOCK = "$EMPLOCTRMID" - VCTRNUM - VREFNUM - VCTRDAT
      Return
    Elsif fstat>5
      GOK = 0
      Call RSTA("CTRMID", VREFNUM - VCTRNUM - VCTRDAT) From GLOCK
      Return
    Endif
    [F:CTRMID2]=[F:CTRMID1]
    [F:CTRMID2]CTRDAT = VAVTCTRDAT
    Write [F:CTRMID2]
    If fstat
      GOK = 0 : Call FSTA("CTRMID") From GLOCK
    Endif
  Endif
#LIPET - 2018-10-05 - X3-110779 - END
 Endif

End
#FRLAA  - 2015-04-07 - Requirement 104590 US 3297 - END

#FRLAA - 2015-05-21 - REQUIREMENT 108198 US 3582 - START
Subprog AM_XITDAT(VALEUR)
Variable Date VALEUR
Local Char VPARAM(20) : VPARAM = "SET_TAXENDDAT"
Local Char VSITE(5)   : VSITE = [M:CTR0]ETRFCY
#JOJAC - 2016-12-06 - START
Local Char VPERCOD (6) : VPERCOD = [M:CTR1]PERCOD
#JOJAC - 2016-12-06 - END
If VALEUR = [00/00/00] | [M:CTR8]XITFNL = 2
  #JOJAC - 2016-12-06 - START
  #Call MANAGE_TAX_DATES([M:CTR8]XITDAT,VPARAM,VSITE)
  #ADNGO - 2017-05-24  - START
  #Call MANAGE_TAX_DATES(VALEUR,VPARAM,VSITE,VPERCOD)
  Call SET_TAXENDDAT(VALEUR,VPERCOD)
  #ADNGO - 2017-05-24  - END
  #JOJAC - 2016-12-06 - END
Endif
End
#FRLAA - 2015-05-21 - REQUIREMENT 108198 US 3582 - END


Subprog AM_XITFNL(VALEUR)
Variable Integer VALEUR
Local Char VPARAM(20) : VPARAM = "SET_TAXENDDAT"
Local Char VSITE(5)   : VSITE = [M:CTR0]ETRFCY
#JOJAC - 2016-12-06 - START
Local Char VPERCOD (6) : VPERCOD = [M:CTR1]PERCOD
#JOJAC - 2016-12-06 - END
Local Date PARAMDATE # #FRLAA - 2015-05-21 - REQUIREMENT 108198 US 3582

#JASMI - 2016-06-02 - REQ 114309 - START
#  If func AFNC.ACTIV("KZA")>0 #FRLAA and JASMI - 2015-07-28 - REQUIREMENT 109427 - US 3711 ## Comment
 # If func DIVPAYE.IS_KZA(GCURLEG)
