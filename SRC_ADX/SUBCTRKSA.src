# JASMI - 2014/06/04 - Requirement 95019 US 2743 - START
#FRLAA and JASMI - 2015-07-29 - REQUIREMENT 109427 - US 3711 - START
#Subprog AM_ETRFCY(VALEUR)
#Variable Char VALEUR
Subprog AM_ETRFCY(VALEUR,ISOK)
Variable Char VALEUR
Variable Integer ISOK : ISOK = 2
Local Char SOC
#FRLAA and JASMI - 2015-07-29 - REQUIREMENT 109427 - US 3711 - END
#Local Char VPARAM(20) : VPARAM = "VERIF_SITE" #FRLAA and JASMI - 2015-07-29 - REQUIREMENT 109427 - US 3711 - ##Comment
#FRLAA and JASMI - 2015-07-29 - REQUIREMENT 109427 - US 3711 - START
#JOJAC - 2016-07-21 - REQ114309 - START
Variable Date VDATE : VDATE = [M:CTR0]CTRDAT
Local Char VPARAM(20) : VPARAM = "SET_ALLDAT"
Local Char VSITE(5)   : VSITE = VALEUR
#JOJAC - 2016-07-21 - REQ114309 - END
#JOJAC - 2016-12-06 - START
Local Char VPERCOD (6) : VPERCOD = [M:CTR1]PERCOD
#JOJAC - 2016-12-06 - END

  SOC =""
  If clalev([F:CTR1])=0 : Local File EMPLOCTR[CTR1] : Endif
  Filter [CTR1] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & CTRDAT<[M]CTRDAT
  Read [CTR1]CTR1 Last
  Filter [CTR1]
  If !fstat
    Call LECTURE("FCY",[F:CTR1]ETRFCY,"") From CONTOBJ
    SOC = [F:FCY]LEGCPY
    Call LECTURE("FCY",VALEUR,"") From CONTOBJ
    If [F:FCY]LEGCPY<>SOC
      GMESSAGE = mess(40,11662,1)
      ISOK=1
      End
    Endif
 Endif
#FRLAA and JASMI - 2015-07-29 - REQUIREMENT 109427 - US 3711 - END

#FRLAA and JASMI - 2015-02-19 - Requirement 104592 US 3261 - START
#JOJAC - 2016-06-02 - REQ114309 US2150 - START (GX3APP)
  #If func AFNC.ACTIV("KZA")>0
   If GCURLEG   = 'ZAF'
#JOJAC - 2016-06-02 - REQ114309 US2150 - START (GX3APP)
#    Call SET_IRP5_START_DATE([M:CTR0]CTRDAT, VALEUR)
#    Call SET_IRP5_END_DATE(VALEUR)
  # JASMI - 2014/07/28 - US 2848 - START
  # JASMI - 2015/01/14 - Requirement 104590 US 3260 - START
  #  If [M:CTR5]SICSUBCLS=0 | [M:CTR5]SEZCOD=0 Then
    If [M:CTR5]SICSUBCLS=0 | [M:CTR5]SEZCOD="" Then
  # JASMI - 2015/01/14 - Requirement 104590 US 3260 - END
#FRLAA and JASMI - 2015-07-29 - REQUIREMENT 109427 - US 3711 - START
#      If clalev([F:FCYSA]) = 0 : Local File HRFACILITYSA    [FCYSA]         : Endif
#
#      Read [FCYSA]FCYSA0 = VALEUR
#      If !fstat
#        If [M:CTR5]SICSUBCLS = 0  Then
#          If [F:FCYSA]SICSUBCLS <> 0 Then
#            [M:CTR5]SICSUBCLS = [F:FCYSA]SICSUBCLS
#            Affzo [M:CTR5]SICSUBCLS
#          Endif
#        Endif
#        If [M:CTR5]SEZCOD = ""  Then
#          If [F:FCYSA]SEZCOD <> "" Then
#            [M:CTR5]SEZCOD = [F:FCYSA]SEZCOD
#            Affzo [M:CTR5]SEZCOD
#          Endif
#        Endif
#      Endif
      If [M:CTR5]SICSUBCLS = 0 or [M:CTR5]SEZCOD = ""  Then
        Call LECTURE("FCY",VALEUR,"") From CONTOBJ
        If clalev([F:CPYKSA]) = 0 : Local File HRCOMPANYKSA [CPYKSA] : Endif
        Read [F:CPYKSA]CPYKSA0 = [F:FCY]LEGCPY
        If !fstat
          If [F:CPYKSA]SICSUBCLS <> 0 Then
            [M:CTR5]SICSUBCLS = [F:CPYKSA]SICSUBCLS
            Affzo [M:CTR5]SICSUBCLS
          Endif
          If [F:CPYKSA]SEZCOD <> "" Then
            [M:CTR5]SEZCOD = [F:CPYKSA]SEZCOD
            Affzo [M:CTR5]SEZCOD
          Endif
        Endif
      Endif
#FRLAA and JASMI - 2015-07-29 - REQUIREMENT 109427 - US 3711 - END
    Endif
  # JASMI - 2014/07/28 - US 2848 - END
  Endif
  #FRLAA and JASMI - 2015-02-19 - Requirement 104592 US 3261 - END

#JOJAC - REQ114309 - 2016-07-21 - START
    #JOJAC - 2016-12-06 - END
    #Call MANAGE_TAX_DATES([M:CTR8]XITDAT,VPARAM,VSITE)
    #Call MANAGE_TAX_DATES([M:CTR8]XITDAT,VPARAM,VSITE,VPERCOD)
    #JOJAC - 2016-12-06 - END
#JOJAC - REQ114309 - 2016-07-21 - START

End
