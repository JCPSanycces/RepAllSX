$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "RAZCRE"        : Gosub RAZCRE
 When "LIENS"         : Gosub LIENS
 When "STYLE"         : Gosub STYLE
 When "MODIF"         : Gosub MODIF
 When "CREATION"      : Gosub CREATION
 When "OUVRE_BOITE"   : Gosub OUVRE_BOITE #FRLAA and JASMI - 2015-07-28 - Requirement 109427 - US 3711 - START
 When "FILTRE"        : Gosub FILTRE
 When "ANNULE"        : Gosub ANNULE
 When "VERIF_MOD"     : Gosub VERIF_MOD #FRLAA - 2015-07-08 - REQUIREMENT 104631 US 3777 - START
 When "VERIF_CRE"     : Gosub VERIF_CRE #JASMI - 2016-11-04
Endcase
Return

