# JASMI - 2014/06/03 - Requirement 95019 US 2743 - START
Subprog AM_CTRDAT(VALEUR)
Variable Date VALEUR
Local Char VPARAM(20) : VPARAM = "SET_ALLDAT"
Local Char VSITE(5)   : VSITE = [M:CTR0]ETRFCY
#JOJAC - 2016-12-06 - START
Local Char VPERCOD (6) : VPERCOD = [M:CTR1]PERCOD
#JOJAC - 2016-12-06 - END

Local Date NVALEUR : NVALEUR = VALEUR #FRLAA - 2015-07-29 - REQUIREMENT 109427 - US 3711
##FRLAA and JASMI - 2015-02-19 - Requirement 104592 US 3261 - START
#  If func AFNC.ACTIV("KZA")>0
#    Call SET_IRP5_START_DATE(VALEUR, [M:CTR0]ETRFCY)
#    Call SET_IRP5_END_DATE([M:CTR0]ETRFCY)
#  Endif
##FRLAA and JASMI - 2015-02-19 - Requirement 104592 US 3261 - END

#JASMI - 2015-09-22 - Localization for Angola - START
#JASMI - 2016-06-02 - REQ 114309 - START
#$If func AFNC.ACTIV("KAO")>0
If func DIVPAYE.IS_KAO_LEG(GCURLEG)
#JASMI - 2016-06-02 - REQ 114309 - end
  End
Endif
#JASMI - 2015-09-22 - Localization for Angola - END

#FRLAA - 2015-07-29 - REQUIREMENT 109427 - US 3711 - START
#Defaulting the new contract tax start date to the precious contract - No broken period
If clalev([F:CTR1])=0 : Local File EMPLOCTR[CTR1] : Endif
Filter [CTR1] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & CTRDAT<VALEUR
Read [CTR1]CTR1 Last
Filter [CTR1]
If !fstat
  If [F:CTR1]XITDAT <> [00/00/00] and (VALEUR-[F:CTR1]XITDAT=1)
  #JOJAC - 2016-06-02 - REQ114309 US2150 - START (GX3APP)
    #If func AFNC.ACTIV("KZA")>0
    If GCURLEG = 'ZAF'
  #JOJAC - 2016-06-02 - REQ114309 US2150 - END
      Read [CTRSA]CTRSA0 = [F:CTR1]REFNUM;[F:CTR1]CTRNUM;[F:CTR1]CTRDAT
      If !fstat
        If [F:CTRSA]IRPSTRDAT <> [00/00/00] : NVALEUR = [F:CTRSA]IRPSTRDAT : Endif
      Endif
    Endif
    #JOJAC - 2016-06-02 - REQ114309 US2150 - START (GX3APP)
    #If func AFNC.ACTIV("KAQ")>0
#JASMI - 2016-06-02 - REQ 114309 - START
#    If func AFNC.ACTIV("KAQ")>0 & GCURLEG = 'ZAF'
    If func DIVPAYE.IS_AFRICA_LEG(GCURLEG)
#JASMI - 2016-06-02 - REQ 114309 - end
    #JOJAC - 2016-06-02 - REQ114309 US2150 - END
      Read [CTRAFR]CTRAFR0 = [F:CTR1]REFNUM;[F:CTR1]CTRNUM;[F:CTR1]CTRDAT
      If !fstat
        If [F:CTRAFR]TAXSTRDAT <> [00/00/00] : NVALEUR = [F:CTRAFR]TAXSTRDAT : Endif
      Endif
    Endif
  #JOJAC - 2017-01-04 - START
  #Elsif [F:CTR1]XITDAT = [00/00/00]
  #  End
  #JOJAC - 2017-01-04 - END
  Endif
Endif
#FRLAA - 2015-07-29 - REQUIREMENT 109427 - US 3711 - END


#FRLAA - 2015-03-31 - Requirement 104590 US 3260 - START
#FRLAA - 2015-08-06 - REQUIREMENT 109427 - US 3711 - START
  #Call MANAGE_TAX_DATES(VALEUR,VPARAM,VSITE)
  #JOJAC - 2016-07-21 - REQ114309 - START
  #Call MANAGE_TAX_DATES(NVALEUR,VPARAM,VSITE)
  #If [M:CTR0]ETRFCY <> "" &  [M:CTR1]PERCOD <> ""
    #JOJAC - 2016-12-06 - END
    #Call MANAGE_TAX_DATES([M:CTR8]XITDAT,VPARAM,VSITE)
    #ADNGO - 2017-05-24 - JIRA X3-12050 - START
    #Call MANAGE_TAX_DATES([M:CTR8]XITDAT,VPARAM,VSITE,VPERCOD)
    Call SET_ALLDAT(VALEUR,VPERCOD)
    #ADNGO - 2017-05-24 - JIRA X3-12050 - END
  #JOJAC - 2016-12-06 - END
  #Endif
  #JOJAC - 2016-07-21 - REQ114309 - END

 #FRLAA - 2015-08-06 - REQUIREMENT 109427 - US 3711 - END
 #FRLAA - 2015-04-01 - Requirement 104590 US 3260 - END

# JASMI - 2014/06/03 - Requirement 95019 US 2743 - END

#JOJAC - 2016-06-02 - REQ114309 US2150 - 2016-02-25 - REQUIREMENT 113637 - US 4208 - END
If [M]CTRDAT <> [00/00/00]
#MIPEA - 2016-11-02 - X3PEOP-1594 - END
  If VALEUR <> [M]CTRDAT & GREP <> "C"
  #If VALEUR <> [M]CTRDAT
#MIPEA - 2016-11-02 - X3PEOP-1594 - END
   Call ERREUR(mess(49, 11662, 1)) From GESECRAN
   mkstat=2
   Affzo [M:CTR0]
   End
  Endif
Endif
#JOJAC - 2016-06-02 - REQ114309 US2150 - 2016-02-25 - REQUIREMENT 113637 - US 4208 - END
End
