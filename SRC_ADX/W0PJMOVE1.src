#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMOVE1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone ICO
mkstat = 0
zoncou = "ICO"
If varinit([M]ICO,indice)=0
 [M]ICO(indice) = "Folder.gif"
Endif

## Zone EXPFLG
mkstat = 0
zoncou = "EXPFLG"
If varinit([M]EXPFLG,indice)=0
 [M]EXPFLG(indice) = 1
Endif

## Zone PBUIMP
mkstat = 0
zoncou = "PBUIMP"
IMPENT = [M]PBUIMP(indice)
If varinit([M]PBUIMP,indice)=0
 IMPENT = 1
Endif
[M]PBUIMP(indice) = IMPENT

## Zone TASTYP
mkstat = 0
zoncou = "TASTYP"
IMPENT = [M]TASTYP(indice)
If varinit([M]TASTYP,indice)=0
 IMPENT = 1
Endif
[M]TASTYP(indice) = IMPENT

## Zone PIMTYP
mkstat = 0
zoncou = "PIMTYP"
IMPENT = [M]PIMTYP(indice)
If varinit([M]PIMTYP,indice)=0
 IMPENT = 1
Endif
[M]PIMTYP(indice) = IMPENT

## Zone PSDLVL
mkstat = 0
zoncou = "PSDLVL"
IMPENT = [M]PSDLVL(indice)
If varinit([M]PSDLVL,indice)=0
 IMPENT = 1
Endif
[M]PSDLVL(indice) = IMPENT

## Zone PIMSTA
mkstat = 0
zoncou = "PIMSTA"
IMPENT = [M]PIMSTA(indice)
If varinit([M]PIMSTA,indice)=0
 IMPENT = 1
Endif
[M]PIMSTA(indice) = IMPENT

## Zone AOB
mkstat = 0
zoncou = "AOB"
IMPENT = [M]AOB(indice)
If varinit([M]AOB,indice)=0
 IMPENT = ""
Endif
[M]AOB(indice) = IMPENT

## Zone AVADATSTA
mkstat = 0
zoncou = "AVADATSTA"
IMPENT = [M]AVADATSTA(indice)
If varinit([M]AVADATSTA,indice)=0
 IMPENT = 1
Endif
[M]AVADATSTA(indice) = IMPENT

## Zone CMT13
mkstat = 0
zoncou = "CMT13"
SAVACT = GACTION : GACTION = "INIDEV"
GACTION = SAVACT
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M:POV1]CMT14(nolign-1),GDEVISE(1..GNBDEV)),1))
If mkstat=1 : Raz [M]CMT13(indice) : Endif

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMOVE1"
Return

