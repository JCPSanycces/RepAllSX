Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_FCY(zc) From W1TRNDOCC
Onkey   2 Titled GBOUTS Call S_FCY(zc) From W1TRNDOCC
Onkey 144 Titled GBOUTP Call P_FCY(zc) From W1TRNDOCC
Onkey 146 Titled GBOUTA Call SA_FCY(zc) From W1TRNDOCC
Gosub _AFF
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
## Action ACONTFCY
Call CONTSITE(VALEUR) From SUBAGF
If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("FCY","!",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
Endif
Gosub _AFF
End

