Local Char    MESSA(250) , WREVIEW(50), WONHOLD(50)
MESSA = "Confirm Text on hold" : # Confirm text on hold
WONHOLD ="On Hold"
WREVIEW =""

# plus de confirmation demande de jamie
#Call OUINON(MESSA,OK) From GESECRAN
#If OK<>2 : End : Endif

WINDICE= nolign
# sur la ligne a traduire
[M:ANT]DOUBLON (nolign)   = WONHOLD
Gosub UPDAT_CODEV From ATXTTRAD
Affzo [M:ANT]15
End

####################################################################
Subprog B4_BASPAG
Local Integer OK ,WINDICE
Local Char    MESSA(250) , WREVIEW(50), WONHOLD(50)
MESSA = "Confirm Clear comment" : # Confirm text on hold
WONHOLD =""
WREVIEW =""
# plus de confirmation demande de jamie
#Call OUINON(MESSA,OK) From GESECRAN
#If OK<>2 : End : Endif

WINDICE= nolign
# sur la ligne a traduire
[M:ANT]DOUBLON (nolign)   = ""
Gosub UPDAT_CODEV From ATXTTRAD
Affzo [M:ANT]15
End


