#<AdxTL>@(#)0.0.0.0 $Revision$ Traduction textes
#-------------------------------------------------------------------------------------------------------#
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"ATXTTRAD","ATXTTRAD","",3,"") From GTRAITE
End

#########################################################################################################
#               TEXTES a TRADUIRE                                                               cg
#########################################################################################################
$ACTION

#--- Actions liées au traitement standard

Case ACTION
 When "EXEC" : Gosub EXEC
Endcase

#--- Actions liées à la fenêtre de saisie

Case ACTION
 When "SETBOUT"    : Gosub SETBOUT
 When "BOUTON"     : Gosub EXEBOUT
 When "OUVRE"      : Gosub OUVRE
 When "DEBUT"      : Gosub DEBUT
 When "APRES_MODIF": Gosub APRES_MODIF
 When "ENR"        : Gosub MODIF
 When "ABA"        : Gosub ABANDON
 When "END"        : Gosub ABORT
 When "FIN"        : Gosub FIN
Endcase
Return

############################################################
$EXEC
TRA = 1
Return

############################################################
$OUVRE
Gosub DEFVAR From ATRANSLATION
Local Char    WMSG(100)

If clalev([F:TXT1])=0 : Local File ATEXTE [ATX1] : Endif
If clalev([F:TXT2])=0 : Local File ATEXTE [ATX2] : Endif

If clalev([F:ART])=0 : Local File AREFTXT [ART] : Endif

Call OUVRE_TRACE("") From LECFIC

#-----------------------------
# prog spe a chaque produit opdadx sur indusprd.....
# test si ca marche ou pas la remontée ..
#-----------------------------
Local Integer WOK
WOK = 0

Call EXISTE_ADX ("","","ATRANSLATIONB",WOK) From ORDSYS
If WOK = 1
   WOK =0
   WNBRFOLDER= 0
   Call OUVRE_FIC (GFOLDER_INDUS,GFOLDER_VERSION,GFOLDER_PRODUIT,WNBRFOLDER,WOK) From ATRANSLATIONB
Endif


Return

############################################################
$SETBOUT
If [M]BASPAG<1
 ETABOU(GENRE) = 0
 ETABOU(GABAN) = 0
Endif
Return

############################################################
$EXEBOUT
Local Char WAPPLI(30)
Case BOUT
 When "R" :
  If [M]LAN<>"" and [M]LANREF<>""
   Call AFF_TAB
  Endif
 When "I" :
  # affichage du nombre d'enreg dans toutes les langues du dossier
  Call AFF_NBELEMENTS
Endcase
Return

############################################################
$APRES_MODIF
If COUZON="TEXTE"
 REP = "M"
Endif
Return

############################################################
$MODIF
If find(2,[M]CHG(0..[M]BASPAG-1))<>0
 Gosub TXT_MAJ
Endif
REP = ""
Return

############################################################
$ABANDON
REP = ""
Return

############################################################
$ABORT
REP = ""
Return

############################################################
$DEBUT
Raz [M:ANT]
# Langue de traduction (dans laquelle on va enregistrer les textes)
[M:ANT]LAN    = GLANTRAD
Affzo [M:ANT]LAN
# Langue de référence la langue de connexion
[M:ANT]LANREF = GLANREF
Affzo [M:ANT]LANREF

# numero texte debut selection
# dans le cas ou la langue de traduction est le FRA  : ce numéro = 50000
# on ne traduit que le spécifique en FRA
#
[M:ANT]STRNUM=0 : Affzo [M:ANT]STRNUM
[M:ANT]TRAFLG=2 : Affzo [M:ANT]TRAFLG
[M:ANT]USEFLG=2 : Affzo [M:ANT]USEFLG

Return

############################################################
$FIN
Close Local File [ATX1]
Close Local File [ATX2]

Close Local File [ART]
#
Call FERME_TRACE From LECFIC
Call IMPSCR From ATRTX3
Return

############################################################
$COP_ECRAN
Call PRTSCR("ATXTTRAD","","",0,0) From ATRTX3
Return

###########################################################
$TXT_MAJ
Local Char MESSAGE(250)
Local Integer ASTATUS
Trbegin [ATX1], [ATX2]
GOK = 1
For I = 1 To [M:ANT]BASPAG-1 Step 2
   If [M:ANT]TEXTE(I)<>[M:ANT]TEXTEOLD(I)
       # autorisé sur FRA uniquement ls textes sup à 50000 (spécif)
       If [M]LAN = GFRA
            #115210/6
            If [M:ANT]NUMERO(I-1) >= GMAXTXTSTD & [M:ANT]NUMERO(I-1)<GNEWTXTSTD
            Gosub BOUCLE_TEXT
            If GOK <> 1 : Break : Endif
            Endif
        Else
            Gosub BOUCLE_TEXT
            If GOK <> 1 : Break : Endif
        Endif
   Endif
Next I

#
If GOK=1
 Commit
Else
 Rollback
Endif

#----------------------------
# mise a jour des envir indus en interne
# apres le commit dans le dossier en cours car cette partie se lance depusi indusprd
If GOK <> 0
  If WNBRFOLDER <> 0
        Local Integer WOK
        WOK = 0
        Local Char WTRACE
        Raz WTRACE
        Call EXISTE_ADX ("","","ATRANSLATIONB",WOK) From ORDSYS
        If WOK = 1
            # on boucle idem sur le tableau
            For I = 1 To [M:ANT]BASPAG-1 Step 2
               If [M:ANT]TEXTE(I)<>[M:ANT]TEXTEOLD(I)
                   # autorisé sur autre lan que fra
                   If [M]LAN <> GFRA
                        #115210/6
                        If [M:ANT]NUMERO(I-1) < GMAXTXTSTD | [M:ANT]NUMERO(I-1)> GNEWTXTSTD
                            # si tout est ok alors là on met a jour les autres envri..
                            # a faire apres le commit.... sur indusprd
                            WOK = 0
                            Call MAJ_TRADTEX([M:ANT]NUMERO(I-1),[M]LAN,GFOLDER_INDUS,GFOLDER_VERSION,GFOLDER_PRODUIT,WNBRFOLDER,WTRACE,WOK) From ATRANSLATIONB
                         Endif
                   Endif
               Endif
            Next I

         Endif
    Endif
Endif

Effzo [M:ANT]15
[M:ANT]FLG = 0
Return


############################################################
$BOUCLE_TEXT

Read [ATX1]NUMERO = [M:ANT]LANREF;[M:ANT]NUMERO(I-1)
If fstat
    Call RSTA("ATX",[M:ANT]LANREF-num$([M:ANT]NUMERO(I-1))) From GLOCK
    GOK = 0
Else
    Readlock [ATX2]NUMERO = [M:ANT]LAN;[M:ANT]NUMERO(I-1)
    If fstat=1
       Call RSTA("ATX",[M:ANT]LANREF-num$([M:ANT]NUMERO(I-1))) From GLOCK
       GOK = 0
    Elsif fstat=0
       [F:ATX2]CLEREC = left$(vireblc(toupper(ctrans([M:ANT]TEXTE(I))),4),20)  #cn 290102 maj de clerec
       [F:ATX2]TEXTE  = [M:ANT]TEXTE(I)
       If [F:ATX2]LANORI <> [F:ATX2]LAN
           [F:ATX2]LANORI  = ""
       Endif
       Call FLDUPD("ATX2") From OBJDIV
       Rewrite [ATX2]
       If fstat
            Call  FSTA("ATX") From GLOCK
            GOK = 0
       Endif
       #115210
       If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" & ([F:ATX2]NUMERO<GMAXTXTSTD | [F:ATX2]NUMERO>GNEWTXTSTD)
         ASTATUS = func ATXTSVC.UPDATE_ONETEXT_CHAR(GPRODUIT, [F:ATX2]NUMERO, [F:ATX2]LAN, [F:ATX2]TEXTE,[F:ATX2]COMMENT,[F:ATX2]LANORI,MESSAGE)
         If ASTATUS<>[V]CST_AOK
          GMESSAGE=MESSAGE : GOK=0
         Endif
       Endif
    Else
       [F:ATX2]       = [F:ATX1]
       [F:ATX2]LAN    = [M:ANT]LAN
       [F:ATX2]CLEREC = left$(vireblc(toupper(ctrans([M:ANT]TEXTE(I))),4),20)  #cn 290102 maj de clerec
       [F:ATX2]TEXTE  = [M:ANT]TEXTE(I)
       [F:ATX2]LANORI  = ""
       Call FLDCRE("ATX2") From OBJDIV
       Write [ATX2]
       If fstat
            Call  FSTA("ATX") From GLOCK
            GOK = 0
       Endif
       #115210
       If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" & ([F:ATX2]NUMERO<GMAXTXTSTD | [F:ATX2]NUMERO>GNEWTXTSTD)
         ASTATUS = func ATXTSVC.TRANSLATE_ONETEXT_CHAR(GPRODUIT, [F:ATX2]NUMERO, [F:ATX2]LAN, [F:ATX2]TEXTE,[F:ATX2]COMMENT,MESSAGE)
         If ASTATUS<>[V]CST_AOK
          GMESSAGE=MESSAGE : GOK=0
         Endif
       Endif
    Endif
    If GOK <> 0
       Gosub MAJ_TRACE
    Endif
Endif

Return

############################################################
$MAJ_TRACE
WMSG = format$("N>:8",[F:ATX1]NUMERO)-format$("K:3X",[F:ATX1]LAN)-
&      format$("K:80X",[F:ATX1]TEXTE)-format$("K:80X",[F:ATX1]COMMENT)
Call ECR_TRACE(WMSG,0) From GESECRAN
WMSG = format$("N>:8",[F:ATX2]NUMERO)-format$("K:3X",[F:ATX2]LAN)-
&      format$("K:80X",[F:ATX2]TEXTE)-format$("K:80X",[F:ATX2]COMMENT)
Call ECR_TRACE(WMSG,0) From GESECRAN
Return

############################################################
$UPDAT_CODEV
Local Char MESSAGE(250)
Local Integer ASTATUS
# mise a jour commenatrei OK reiew sur les textes co dev avant trad
# ce commentaire sera remis a blanc lors de la trad via la fct dédiée
# idem avec le comment 'On Hold'
# idem avec le clear comment
Trbegin [ATX2]

Read [ATX1]NUMERO = [M:ANT]LANREF;[M:ANT]NUMERO(WINDICE-1)
If fstat = 0
    Readlock [ATX2]NUMERO = [M:ANT]LAN;[M:ANT]NUMERO(WINDICE-1)
    If fstat=1
       Call RSTA("ATX2",[M:ANT]LANREF-num$([M:ANT]NUMERO(WINDICE-1))) From GLOCK
       GOK = 0
    Elsif fstat=0
       If WREVIEW <> ""
           [F:ATX2]COMMENT  = WREVIEW
       Elsif WONHOLD <> ""
           [F:ATX2]COMMENT  = WONHOLD
       Else
           [F:ATX2]COMMENT  = ""
       Endif
       # on ne met pas volontairement le lanori a blanc car tjs pas traduit
       # trad se fera +tard
       Call FLDUPD("ATX2") From OBJDIV
       Rewrite [ATX2]
       If fstat
            Call  FSTA("ATX2") From GLOCK
            GOK = 0
       Endif
       #115210
       If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" & ([F:ATX2]NUMERO<GMAXTXTSTD | [F:ATX2]NUMERO>GNEWTXTSTD)
         ASTATUS = func ATXTSVC.UPDATE_ONETEXT_CHAR(GPRODUIT, [F:ATX2]NUMERO, [F:ATX2]LAN, [F:ATX2]TEXTE,[F:ATX2]COMMENT,[F:ATX2]LANORI,MESSAGE)
         If ASTATUS<>[V]CST_AOK
          GMESSAGE=MESSAGE : GOK=0
         Endif
       Endif
    Else
       [F:ATX2]         = [F:ATX1]
       [F:ATX2]LAN      = [M:ANT]LAN
       [F:ATX2]LANORI   = [M:ANT]LANREF
       If WREVIEW <> ""
           [F:ATX2]COMMENT  = WREVIEW
       Elsif WONHOLD <> ""
           [F:ATX2]COMMENT  = WONHOLD
       Else
           [F:ATX2]COMMENT  = ""
       Endif
       Call FLDCRE("ATX2") From OBJDIV
       Write [ATX2]
       If fstat
            Call  FSTA("ATX2") From GLOCK
            GOK = 0
       Endif
       #115210
       If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" & ([F:ATX2]NUMERO<GMAXTXTSTD | [F:ATX2]NUMERO>GNEWTXTSTD)
         ASTATUS = func ATXTSVC.UPDATE_ONETEXT_CHAR(GPRODUIT, [F:ATX2]NUMERO, [F:ATX2]LAN, [F:ATX2]TEXTE,[F:ATX2]COMMENT,[F:ATX2]LANORI,MESSAGE)
         If ASTATUS<>[V]CST_AOK
          GMESSAGE=MESSAGE : GOK=0
         Endif
       Endif
    Endif
    If GOK <> 0
       Gosub MAJ_TRACE
    Endif
Endif
Commit

Return

############################################################
$LECT_ART
    GERR=0
    Read [ART] First
    If fstat=0
        If [F:ART]UPDDAT<>date$
            Call MESSAGE(mess(230,100,1)-format$("D:DD[/]MM[/]YYYY",[F:ART]UPDDAT)) From GESECRAN
            GERR=2
        Endif
    Elsif fstat=4 or fstat=5
        Call MESSAGE(mess(229,100,1)) From GESECRAN
        GERR=2
    Else
        Call  FSTA("ATX") From GLOCK
        GERR=1
    Endif
Return
####################################################################################################
###################### SUBPROG     #################################################################
####################################################################################################

#####################################################################################################
#############################################################
Subprog AFF_NBELEMENTS

Local File ATEXTE [ZZZC]
Local File ADOSSIER [ZZZA]

# recherche du nbre de texte en fra
Local Integer WNBR_TRANSLATE (0..15)
Local Integer WNBR_USED (0..15)

Local Char WLAN (3)(0..dim([F:ZZZA]LAN))
Local Integer WNBR_LAN, WINDICE

Local Clbfile WCLOB (4)
Local Integer WNUM

Raz WCLOB

Read [ZZZA]DOSSIER =nomap
If fstat <> 0
    WCLOB = "no Texts"
    Goto FIN_AFF_TEXT
Endif


# lecture fiche dossier pour recup table des langue
For WINDICE=0 To [F:ZZZA]NBRLAN-1
     WLAN (WINDICE) = [F:ZZZA]LAN (WINDICE)
Next WINDICE
WNBR_LAN = [F:ZZZA]NBRLAN

Raz WNBR_TRANSLATE
WCLOB = " ------ Number of texts which exist in ATEXTE "+chr$(13)

#   remplissage de la table des langues
For WINDICE = 0 To WNBR_LAN-1
    If WLAN (WINDICE) <> ""
        #115210/6
        Filter [ZZZC] Where LAN =  WLAN (WINDICE) and (NUMERO < GMAXTXTSTD | NUMERO>GNEWTXTSTD) and LANORI = ""
        WNBR_TRANSLATE (WINDICE) = rowcount ([F:ZZZC])
        Filter [ZZZC]
        WCLOB += " in "+WLAN (WINDICE)+ ": "+num$(WNBR_TRANSLATE(WINDICE))+chr$(13)
    Endif
Next WINDICE

# on recherche que les textes qui sont definis dans areftxt
# mais on les compte une seul fois. attention a la cle de ce fichier
# le problème qu on a ce n'est pas parce qu un texte est traduit qu il est forcement utilisé.
# il faudrait parcourir toute la table pour chaque langue... tres long en temps
# ex : si 100 textes existent en FRA et 80 en ENG.
# si on a en fait que 50 textes fra vraiment utilisés
# logiquement il reste 20 textes a traduire en eng mais sur ces 20 textes restant a traduire
# combien sont vraiment utiles ?
# pas d autres choix que de parcourir toute la table sur chaque langue

# on va faire uniquement par rapport à la langue de ref.
# cg octobre 2011 ne suffit pas chef de produit veulent dans toutes les langues
WINDICE =0
WNBR_USED (WINDICE)= rowcount ([F:ART])
If WNBR_USED (WINDICE) <> 0
    Raz WNBR_USED
    # table des ref non vide
    WNUM = 0
    Repeat
       Filter [ART] Where TXTNUM >= WNUM
       Read [ART] First
       If fstat = 0
            WNUM= [F:ART]TXTNUM
            If WNUM < GMAXTXTSTD | WNUM>GNEWTXTSTD :#115210/6
               # on boucle sur atexte pour chaque langue
               For WINDICE = 0 To WNBR_LAN-1
                  If WLAN (WINDICE) <> ""
                     Read [ZZZC]NUMERO=WLAN(WINDICE);[F:ART]TXTNUM
                     If fstat = 0
                        If [F:ZZZC]LANORI = ""
                            WNBR_USED (WINDICE) +=1
                        Endif
                     Endif
                  Endif
                Next WINDICE
                WNUM+=1
             Else
                WNUM = GMAXTXTSTD
             Endif
       Else
             WNUM = GMAXTXTSTD
       Endif
       Filter [ART]
    Until WNUM = GMAXTXTSTD

    WCLOB += " ------ Number of texts which are used and exist in ATEXTE "+chr$(13)
    For WINDICE = 0 To WNBR_LAN-1
        WCLOB += " in "+WLAN (WINDICE)+ ": "+num$(WNBR_USED(WINDICE))+chr$(13)
    Next WINDICE

Endif


$FIN_AFF_TEXT

Call AFFMES(WCLOB) From GESECRAN

Close Local File

End

#####################################################################################################
Subprog AFF_TAB
Local Integer I : I = 0

If [M:ANT]USEFLG = 2
    Gosub LECT_ART
Endif
Effzo [M:ANT]15

Local Char WFILTER1 (250)
Local Char WFILTER2 (250)
Local Integer W_BREAK, W_CONTINUE


Call TEMPON ("L") From GESECRAN
# trafld --> textes non traduits
# attention aux co-dev les textes existent aussi
If [M:ANT]TRAFLG=2

     WFILTER1 ="LAN = [M:ANT]LANREF  & NUMERO >= [M:ANT]STRNUM  &  TEXTE <>''"
     WFILTER2 ="(LANORI= '' or LANORI = [M:ANT]LANREF)"

     Filter [ATX1] Where evalue (WFILTER1) and evalue (WFILTER2)  Order By Key NUMERO
     W_CONTINUE= 0
     For [ATX1]
       If [M:ANT]USEFLG=2
             Read [ART]ART0=[F:ATX1]NUMERO
             If fstat = 0
                W_CONTINUE= 0
             Else
                W_CONTINUE= 1
             Endif
       Else
            W_CONTINUE= 0
       Endif
       If W_CONTINUE=0
          Read [ATX2]NUMERO=[M:ANT]LAN;[F:ATX1]NUMERO
          If fstat
               Raz [F:ATX2]
               [F:ATX2]TEXTE  = "?"
               Gosub AFF_ATX1_ATX2
               If W_BREAK = 1
                    Break
               Endif
          Else
            # cas du cod-dev le texte existe
               If [F:ATX2]LANORI=[F:ATX1]LAN
                   Gosub AFF_ATX1_ATX2
                   If W_BREAK = 1
                        Break
                   Endif
               Endif
          Endif
       Endif
     Next
     Filter [ATX1]
Elsif [M:ANT]UPDFLG = 2
    # Textes modifiés par rapport à la langue de ref.
      # cg nov 2016 ajout credat car upddat peux etre vide 
    WFILTER1 ='LAN=[M:ANT]LANREF & NUMERO >= [M:ANT]STRNUM & (UPDDAT>= [M:ANT]UPDFLGDAT | (UPDDAT= [0/0/0] and CREDAT>= [M:ANT]UPDFLGDAT))'
    WFILTER2 ="(LANORI= '' or LANORI = [M:ANT]LANREF)"
    W_CONTINUE= 0

    Filter [ATX1] Where evalue (WFILTER1) and evalue (WFILTER2)  Order By Key NUMERO
    For [ATX1]
       If [M:ANT]USEFLG=2
             Read [ART]ART0=[F:ATX1]NUMERO
             If fstat = 0
                W_CONTINUE= 0
             Else
                W_CONTINUE= 1
             Endif
       Else
            W_CONTINUE= 0
       Endif
       If W_CONTINUE=0
           Read [ATX2]NUMERO=[M:ANT]LAN;[F:ATX1]NUMERO
           If fstat
                Raz [F:ATX2]
                [F:ATX2]TEXTE   = "?"
           Endif
           Gosub AFF_ATX1_ATX2
           If W_BREAK = 1
                    Break
           Endif
       Endif
    Next
    Filter [ATX1]
Else
    WFILTER1 ="LAN=[M:ANT]LAN & NUMERO>= [M:ANT]STRNUM & UPDDAT>= [M:ANT]CHGFLGDAT"
    WFILTER2 ="(LANORI= '' or LANORI = [M:ANT]LAN)"

    Filter [ATX2] Where evalue (WFILTER1) and evalue (WFILTER2)  Order By Key NUMERO
    W_CONTINUE= 0

    For [ATX2]
       If [M:ANT]USEFLG=2
             Read [ART]ART0=[F:ATX2]NUMERO
             If fstat = 0
                W_CONTINUE= 0
             Else
                W_CONTINUE= 1
             Endif
       Else
            W_CONTINUE= 0
       Endif
       If W_CONTINUE=0
           Read [ATX1]NUMERO = [M:ANT]LANREF;[F:ATX2]NUMERO
           If fstat = 0
              Gosub AFF_ATX1_ATX2
               If W_BREAK = 1
                    Break
               Endif
           Endif
       Endif
    Next
    Filter [ATX2]
Endif



#
[M:ANT]BASPAG = I
nolign        = I

Affzo [M:ANT]15
Call TEMPOFF From GESECRAN
End



##################################################

$AFF_ATX1_ATX2
W_BREAK = 0
If I < dim([M:ANT]TEXTE)-2
    # ligne 1
    [M:ANT]NUMERO(I)     = [F:ATX1]NUMERO
    [M:ANT]TEXTE(I)      = [F:ATX1]TEXTE
    If dim([F:ATX1]CREDAT)>0
          [M:ANT]UPDDAT(I)     = [F:ATX1]CREDAT
          If [F:ATX1]UPDDAT > [F:ATX1]CREDAT
              [M:ANT]UPDDAT(I)     = [F:ATX1]UPDDAT
          Endif
    Else
         [M:ANT]UPDDAT(I)     = [F:ATX1]UPDDAT
    Endif
    If dim([F:ATX1]CREUSR)>0
         [M:ANT]CREUSR(I)     = [F:ATX1]CREUSR
    Endif
    [M:ANT]LONG (I)      = [F:ATX1]LONG
    [M:ANT]DOUBLON (I)   = [F:ATX1]COMMENT
    [M:ANT]LANORI (I)    = [F:ATX1]LANORI

    # ligne 2
    [M:ANT]TEXTE(I+1)    = [F:ATX2]TEXTE
    [M:ANT]TEXTEOLD(I+1) = [F:ATX2]TEXTE
    [M:ANT]UPDDAT(I+1)   = [F:ATX2]UPDDAT
    [M:ANT]DOUBLON (I+1) = [F:ATX2]COMMENT
    [M:ANT]LANORI (I+1)  = [F:ATX2]LANORI
    [M:ANT]ICO (I+1)     = ""
    #
    I += 2
    [M:ANT]BASPAG = I
Else
    Infbox mess(26,100,1)
    W_BREAK = 1
Endif

Return




####################################################################################################
###################### ETIQUETTES  CHAMPS       ####################################################
####################################################################################################
Subprog C_LAN(VALEUR)
Variable Char    VALEUR()
[M:ANT]STRNUM = 0
If VALEUR = [M]LANREF
      mkstat = 2
Else
    If VALEUR = GFRA
      # on ne peut traduire en FRA que le spécifique
      [M:ANT]STRNUM = GMAXTXTSTD
      Affzo [M:ANT]STRNUM
    Endif
Endif

End

############################################################
Subprog AM_TRAFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
      [M:ANT]UPDFLG = 1
      [M:ANT]UPDFLGDAT = [0/0/0]
      [M:ANT]CHGFLG = 1
      [M:ANT]CHGFLGDAT = [0/0/0]
      Affzo [M:ANT]UPDFLG
      Affzo [M:ANT]CHGFLG
      Affzo [M:ANT]UPDFLGDAT
      Affzo [M:ANT]CHGFLGDAT
Endif
[M:ANT]FLG = 0
Effzo [M:ANT]15
End

############################################################
Subprog AS_UPDFLGDAT(VALEUR)
Variable Date     VALEUR
If [M:ANT]UPDFLG = 1
      mkstat = 2
Endif
End

############################################################
Subprog AM_UPDFLGDAT(VALEUR)
Variable Date    VALEUR
[M:ANT]FLG = 0
Effzo [M:ANT]15
End

############################################################
Subprog AM_UPDFLG(VALEUR)
Variable Integer VALEUR
[M:ANT]FLG = 0
If VALEUR = 2
    [M:ANT]TRAFLG = 1
    [M:ANT]CHGFLG = 1
    [M:ANT]CHGFLGDAT = [0/0/0]

    Affzo [M:ANT]TRAFLG
    Affzo [M:ANT]CHGFLG
    Affzo [M:ANT]CHGFLGDAT
Endif
Effzo [M:ANT]15
End

############################################################
Subprog AS_CHGFLGDAT(VALEUR)
Variable Date    VALEUR
If [M:ANT]CHGFLG = 1
  mkstat = 2
Endif
End

############################################################
Subprog AM_CHGFLGDAT(VALEUR)
Variable Date    VALEUR
[M:ANT]FLG = 0
Effzo [M:ANT]15
End


############################################################
Subprog AM_CHGFLG(VALEUR)
Variable Integer VALEUR
[M:ANT]FLG = 0
If VALEUR = 2
    [M:ANT]TRAFLG = 1
    [M:ANT]UPDFLG = 1
    [M:ANT]UPDFLGDAT = [0/0/0]

    Affzo [M:ANT]TRAFLG
    Affzo [M:ANT]UPDFLG
    Affzo [M:ANT]UPDFLGDAT
Endif
Effzo [M:ANT]15

End

############################################################
Subprog AS_BASPAG
If [M:ANT]FLG = 0
  [M:ANT]FLG = 1
Endif
End

############################################################
Subprog AS_TEXTE(VALEUR)
Variable Char    VALEUR()
If mod(nolign,2) = 1
  mkstat = 2
  End
Endif
#GBOUT1 = mess(51,115,1)
End

############################################################
Subprog C_TEXTE(VALEUR)
Variable Char    VALEUR()
End

############################################################
Subprog AV_CHG(VALEUR)
Variable Integer VALEUR
If mod(nolign,2) = 0
  If [M:ANT]TEXTE(nolign-1) <> [M:ANT]TEXTEOLD(nolign-1)
    VALEUR = 2
  Else
    VALEUR = 1
  Endif
Else
  VALEUR = 0
Endif
End

########################################
Subprog C_LANREF(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog AM_STRNUM(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0
    [M]STRNUM = VALEUR
Endif
End
####################################################################
Subprog AP_USEFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    Gosub LECT_ART
Endif
End
####################################################################
Subprog AM_USEFLG(VALEUR)
Variable Integer VALEUR
[M:ANT]FLG = 0
Effzo [M:ANT]15
End
####################################################################
Subprog C_USEFLG(VALEUR)
Variable Integer VALEUR
End


####################################################################
Subprog IB_BASPAG

If [M]NUMERO (nolign-1)=0
    Raz GBOUT1
    Raz GBOUT2
    Raz GBOUT3
    Raz GBOUT4
Else
    Raz GBOUT2
    Raz GBOUT3
    Raz GBOUT4
    If GADONIX = 2 and GPRODUIT = 0
        If mod(nolign,2) = 1
            If [M]LAN = GFRA
              # sur la ligne a traduire et si lanori = lanref
              If [M:ANT]LANORI (nolign) = [M]LANREF and [M:ANT]DOUBLON (nolign) <> "OK Review"
                 # cas des textes co dev pour les valider en interne seulement
                 GBOUT2 = "Text Review"  : # Texte revue ok
                 GBOUT3 = "Text On Hold" : # Texte en attente de renseignement
              Endif
              # sur la ligne a traduire et si lanori = lanref
              If [M:ANT]LANORI (nolign) = [M]LANREF and ([M:ANT]DOUBLON (nolign) = "OK Review" or [M:ANT]DOUBLON (nolign) = "On Hold")
                 # cas des textes co dev pour les valider en interne seulement
                 GBOUT4 = "Clear comment"  : # Clear commentaire
              Endif
            Endif
        Endif
    Endif
Endif
End

####################################################################
Subprog B2_BASPAG
Local Integer OK ,WINDICE
Local Char    MESSA(250) , WREVIEW(50), WONHOLD(50)
MESSA = "Confirm Text review" : # Confirm text review
WREVIEW ="OK Review"
WONHOLD =""
# plus de confirmation demande de jamie
#Call OUINON(MESSA,OK) From GESECRAN
#If OK<>2 : End : Endif

WINDICE= nolign
# sur la ligne a traduire
[M:ANT]DOUBLON (nolign)   = WREVIEW
Gosub UPDAT_CODEV From ATXTTRAD
Affzo [M:ANT]15
End
####################################################################
Subprog B3_BASPAG
