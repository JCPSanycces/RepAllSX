$ON_NAMCNT
Onevent BEFORE_INPUT Call AS_NAMCNT(zc) From W3CTR4
Return

Subprog AS_NAMCNT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
If !GWEBSERV
 ## Action SAIPAYS
 Call SAIPAYS([M]MIDCNTCDE) From TRTDIV
 If mkstat=2
  [M]NAMCNT(INDIC) = VALEUR
  Affzo NAMCNT(INDIC) : mkstat = 2
 Endif
Endif
Gosub _AFF
End

