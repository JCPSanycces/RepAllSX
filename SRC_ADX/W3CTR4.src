#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR4 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_ADDCOR
Onevent CONTROL Call C_ADDCOR(zc) From W3CTR4
Onevent INIT_AREA Call D_ADDCOR(zc) From W3CTR4
Onevent BEFORE_INPUT Call AS_ADDCOR(zc) From W3CTR4
Return

Subprog D_ADDCOR(VALEUR)
Variable Integer VALEUR
If varinit([M]ADDCOR,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_ADDCOR(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_ADDCOR(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_ADDCOR(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "ADDCOR" : GZNUM = 55097 : Endif
Gosub _AFF
End

$ON_AFRTYP
Onevent INIT_AREA Call D_AFRTYP(zc) From W3CTR4
Onevent BEFORE_INPUT Call AS_AFRTYP(zc) From W3CTR4
Return

Subprog D_AFRTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]AFRTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_AFRTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_AFRCNTCDE
Onevent CONTROL Call C_AFRCNTCDE(zc) From W3CTR4
Onevent BEFORE_INPUT Call AS_AFRCNTCDE(zc) From W3CTR4
Onevent AFTER_CHANGE Gosub AMM_AFRCNTCDE From W3CTR4
Onevent INIT_AREA Call D_AFRCNTCDE(zc) From W3CTR4
Return

Subprog D_AFRCNTCDE(VALEUR)
Variable Char    VALEUR()
If varinit([M]AFRCNTCDE,indice)=0
 VALEUR = GPAYS
Endif
Gosub _AFF
End

Subprog AS_AFRCNTCDE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_AFRCNTCDE(zc) From W3CTR4
Onkey 144 Titled GBOUTP Call P_AFRCNTCDE(zc) From W3CTR4
Onkey 146 Titled GBOUTA Call SA_AFRCNTCDE(zc) From W3CTR4
Gosub _AFF
End

Subprog C_AFRCNTCDE(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("TCY","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "AFRCNTCDE" : GZNUM = 235 : Endif
Gosub _AFF
End

$AMM_AFRCNTCDE
Call AM_AFRCNTCDE(zc)
If !mkstat & GOBJET
 zoncou = "AFRCNTCDE" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_AFRCNTCDE(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZAFRCNTCDE)")>indice
 [M]AFRCNTCDE(indice) = VALEUR
 Affzo ZAFRCNTCDE(indice)
Endif
Gosub _AFF
End

Subprog S_AFRCNTCDE(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TCY"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_AFRCNTCDE(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TCY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_AFRCNTCDE(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZAFRCNTCDE
Onevent BEFORE_AREA Gosub AV_ZAFRCNTCDE From W3CTR4
Return

$AV_ZAFRCNTCDE
Call LECTEXTRA(zc,"TABCOUNTRY","CRYDES",num$([M]AFRCNTCDE(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_AFRPRV
Onevent BEFORE_AREA Gosub AV_AFRPRV From W3CTR4
Onevent BEFORE_INPUT Call AS_AFRPRV(zc) From W3CTR4
Onevent CONTROL Call C_AFRPRV(zc) From W3CTR4
Return

Subprog IB_AFRPRV(VALEUR)
Variable Char    VALEUR()
## Action INISAT
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "INISAT"
PARMSK(1) = AFRCNTCDE
PARMSK(2) = ""
Call S_AFF_CHAR(VALEUR,PARMSK,"INISAT","TRTDIV","") From GACTION
GACTION = SAVACT
Gosub _AFF
End

$AV_AFRPRV
If !GWEBSERV
 ## Action FMTSAT
 Call FMTSATPAY(AFRCNTCDE,"") From TRTDIV
Endif
If GFMT<>""
 Chgfmt [M]AFRPRV(indice) With "K:"+GFMT
Else
 Chgfmt [M]AFRPRV(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog AS_AFRPRV(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(31745,GBOUT2) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_AFRPRV(VALEUR)
If  GWEBSERV
 ## Action SAISAT
 Call SAISAT(AFRCNTCDE,"") From TRTDIV
 If mkstat=2
  [M]AFRPRV(INDIC) = VALEUR
  Affzo AFRPRV(INDIC) : mkstat = 2
 Endif
Endif
Onkey 130 Titled GBOUT2 Call B2_AFRPRV(zc) From W3CTR4
Onkey   2 Titled GBOUTS Call S_AFRPRV(zc) From W3CTR4
Gosub _AFF
End

Subprog C_AFRPRV(VALEUR)
Variable Char    VALEUR()
## Action CTLSAT
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "CTLSAT"
PARMSK(1) = AFRCNTCDE
PARMSK(2) = ""
Call S_AFF_CHAR(VALEUR,PARMSK,"CTLSAT","TRTDIV","") From GACTION
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "AFRPRV" : GZNUM = 55096 : Endif
If !mkstat
 ## Action STD
 Call C_AFRPRV(VALEUR) From SUBCTR
 If mkstat : GERR = 1 : GZONE = "AFRPRV" : GZNUM = 55096 : Endif
Endif
Gosub _AFF
End

Subprog S_AFRPRV(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELSAT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELSAT"
 PARMSK(1) = AFRCNTCDE
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELSAT","TRTDIV","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B2_AFRPRV(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNSAT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "TUNSAT"
 PARMSK(1) = AFRCNTCDE
 PARMSK(2) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"TUNSAT","TRTDIV","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_AFRSTA
Onevent INIT_AREA Call D_AFRSTA(zc) From W3CTR4
