Subprog C_FILDAT(VALEUR)
Variable Date    VALEUR
  If VALEUR <> [0/0/0]
    If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
    Filter [HRCTR] Where CTRNUM = [M:HRLTA1]CTRNUM
    Read [HRCTR] First
    Filter [HRCTR]
    If [HRCTR]CTRDAT > VALEUR
      mkstat = 2
      Call ERREUR(mess(00158,10702,1)) From GESECRAN
    Endif
  Endif
End

