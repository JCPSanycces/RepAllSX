#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$

Local Char PARAM(20)(1) , VALEUR(20)
End
# Mask management CONSLTA1
$ACTION
  Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "LECTURE"     : Gosub LECTURE
    When "FERME"       : Gosub FERME
    When Default
  Endcase
Return

$OUVRE
  If !clalev([F:DEMCONGE])  : Local File DEMCONGE   [DCG]  : Endif
  If !clalev([F:ACCRU]) : Local File HRLVEACCRU    [ACCRU] : Endif
  If !clalev([F:HRHEA]) : Local File HRLVESUBHEA  [HRHEA] : Endif
  If !clalev([F:TIM]) : Local File TIMCOD [TIM] : Endif

  If !clalev([F:HRCTR]) : Local File EMPLOCTR  [HRCTR] : Endif
  Raz [M:HRLTA1]

  Call KILL_GLM_GLOBALS From SUBHRBAL
Return

$LECTURE
  Global Integer BALANCE_GRID_ROWS, TRANSACTION_GRID_ROWS, TRANSACTION_SUB_GRID_ROWS, SYSTEM_TRANSACTIONS_GRID_ROWS
  Global Char GLMCYCLESTR(250)
  Global Date GLMCYCLE
  [M:HRLTA2]LVEACTONLY = 2
  [M:HRLTA3]LVEACTONL = 2
  [M:HRLTA3]LVECYCLEO = 2
  [M:HRLTA4]LVEACTONL4 = 2
  [M:HRLTA4]LVECYCLEO4 = 2

  Gosub GET_SYSTEM_TRANSACTIONS
  Gosub GET_BALANCES
Return

$FERME
  #Destroy Global variables
  If dim(BALANCE_GRID_ROWS) > 0
    Kill BALANCE_GRID_ROWS
  Endif
  If dim(TRANSACTION_GRID_ROWS) > 0
    Kill TRANSACTION_GRID_ROWS
  Endif
  If dim(TRANSACTION_SUB_GRID_ROWS) > 0
    Kill TRANSACTION_SUB_GRID_ROWS
  Endif
  If dim(SYSTEM_TRANSACTIONS_GRID_ROWS) > 0
    Kill SYSTEM_TRANSACTIONS_GRID_ROWS
  Endif
Return

######################################################################################
## Section automatically added (screen CONSLTA1) 06/12/2017 06:58:56 (SAVAN)
######################################################################################
Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
End

Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
  If !clalev([F:HRCTR2]) : Local File EMPLOCTR [HRCTR2] : Endif
  If !clalev([F:HREMP]) : Local File EMPLOID [HREMP] : Endif
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif

  Filter [HRCTR2] Where CTRNUM=VALEUR
  Read [HRCTR2] First
  Filter [HRCTR2]

  Filter [FCY] Where FCY = [HRCTR2]ETRFCY
  Read [FCY] First
  Filter [FCY]
  Filter [CPY] Where CPY= [FCY]LEGCPY
  Read [CPY] First
  Filter [CPY]
  GCURLEG = [CPY]LEG
  [M:HRLTA1]LEG = GCURLEG

  Filter [HREMP] Where [HREMP]REFNUM = [F:HRCTR2]REFNUM
  Read [HREMP] First
  Filter [HREMP]
  [M:HRLTA1]FIRSTNAME = [HREMP]SRN
  [M:HRLTA1]LASTNAME = [HREMP]NAM

  Affzo [M:HRLTA1]
End

Subprog AS_DATPYR(VALEUR)
Variable Date    VALEUR
End

Subprog C_DATPYR(VALEUR)
Variable Date    VALEUR
End

Subprog AM_DATPYR(VALEUR)
Variable Date    VALEUR
End


$GET_BALANCES
  If ([M:HRLTA1]CTRNUM = "")
    Return
  Endif

  Local Integer N, L, M, BROWS, ST, FOUND, ROW, TRNROWS, SKIP, FOUND, SUBTYPEACTIVE, CYCLEUNIT, X, ALLN, LOOPM
  Local Char ALLSUBTYPES(100)(0..,0..9)
  Local Char FINALVALS(100)(0..,0..9)
  Local Char ALLNATURES(100)(0..)
  Local Char ALLSUBTYPESFOUND(100)(0..)
  Local Char LVESTARR(100)(0..)
  Local Char NEVENTARR(100)(0..)
  Local Char TESTING(250)
  Global Char CARFUTBALS(GLONHRLST)(0..,0..10)
  Global Integer H
  H=0

  Local Date STARTDATE,ENDDATEARR, ENDDATE, CYCLESTRDAT, CYCLEENDDATE, LASTACCRUAL, EXTRACTIONSTARTDATE, EXTRACTIONENDDATE, QUERYSTARTDATE, QUERYENDDATE, SENIORITYDATE,COMPDATLTA
  Local Decimal BALANCE, ACCRUAL, TOTALTAKENINCYCLE, PLANNED, FUTUREPENDING, HISTORYPENDING
  N = 0: M = 0: LOOPM = 0: L = 1: ALLN = 1: ST = 1: BROWS = 0: TRNROWS = 0: ROW = 1:

  If !clalev([F:ACCRU]) : Local File HRLVEACCRU [ACCRU] : Endif
  If !clalev([TIM])     : Local File TIMCOD [TIM]       : Endif
  If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR]   : Endif
  If !clalev([F:DCGSP]) : Local File DEMSPLITS [DCGSP]  : Endif

  Filter [F:HRCTR] Where [F:HRCTR]CTRNUM = [M:HRLTA1]CTRNUM
& and [F:HRCTR]CTRDAT <= [M:HRLTA1]FILDAT and ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=[M:HRLTA1]FILDAT)

  Read [HRCTR] First
  SENIORITYDATE = [F:HRCTR]DATANC
  Filter [HRCTR]
  Call GET_LEAVE_SUB_TYPES([M:HRLTA1]CTRNUM, [M:HRLTA1]FILDAT,"", FINALVALS) From SUBHRBAL
  L = 0
  For ROW = 0 To maxtab(FINALVALS)
    If (FINALVALS(ROW,1) <> "")
      L += 1
    Endif
  Next

  Filter [F:TIM]
  For ROW = 1 To L
    #FRLAA X3-112532 2018-10-15 START
    #TODO: Change the check to GFONCTION=ESSHRTLA
    If dim(FROM_ESSHRLTA)>0
      [L]INCL_SUBTYPE = 2
      Read [TIM]TIM0 = [M:HRLTA1]LEG;FINALVALS(ROW-1,3)
      If !fstat
        If [F:TIM]DSPSLD <>2 :Goto NEXTREC : Endif
      Endif
    Endif
    #FRLAA X3-112532 2018-10-15 END

    Local Integer GOFURBALLS,LINKED
    ENDDATE = [0/0/0]
    STARTDATE = [0/0/0]
    Call GET_LEAVE_SUB_TYPE_STR_DATE([M:HRLTA1]CTRNUM,[M:HRLTA1]FILDAT,FINALVALS(ROW-1,1),COMPDATLTA,LINKED) From SUBHRBAL
    STARTDATE=COMPDATLTA
    Filter [F:ACCRU]
    Filter [F:ACCRU] Where [F:ACCRU]CTR = [M:HRLTA1]CTRNUM and [F:ACCRU]LVEACCLST = FINALVALS(ROW-1,1) and ([F:ACCRU]LVEACCTYP = "Accrual")
&   and [F:ACCRU]LVEACCDAT >= COMPDATLTA Order By [F:ACCRU]LVEACCDAT
    GOFURBALLS = 2
    Read [F:ACCRU] Last
    If fstat = 0
      If [ACCRU]LVEACCDAT >= [M:HRLTA1]FILDAT
        GOFURBALLS = 1
      Endif
    Endif
    Filter [ACCRU]

    If (GOFURBALLS = 1)
      Call GET_BALANCE([M:HRLTA1]CTRNUM, FINALVALS(ROW-1,1), [M:HRLTA1]FILDAT, BALANCE, ACCRUAL, TOTALTAKENINCYCLE, 0, GCURLEG) From SUBHRBAL
    Else
      Local Char FUTBALS(250)(0..,0..10)
      Call GET_BALANCE_FCST([M:HRLTA1]CTRNUM, FINALVALS(ROW-1,3), FINALVALS(ROW-1,1), [M:HRLTA1]FILDAT, FUTBALS, BALANCE, ACCRUAL, TOTALTAKENINCYCLE,0,STARTDATE,ENDDATE,GCURLEG,CARFUTBALS) From
&     SUBHRBAL
    Endif

    Filter [HRHEA] Where [F:HRHEA]COD = FINALVALS(ROW-1,1)
    Read [HRHEA] First

    CYCLEUNIT = [HRHEA]CYCLENU
    CYCLELENGHT = [HRHEA]CYCLEN

    PLANNED = 0
    FUTUREPENDING = 0
    HISTORYPENDING = 0
    TOTALTAKENINCYCLE = 0

    Call GET_CYCLE_START_DATE_EXTRACTION([M:HRLTA1]CTRNUM, FINALVALS(ROW-1,1), [M:HRLTA1]FILDAT, STARTDATE, ENDDATE, 0, GCURLEG)

#PEVAN - 2018-10-10 - X3-111790 - START
    Link [DCG] With [DCGSP]DCGSP1=[DCG]UID As [SPLITS]
&   Where [F:DCG]CTRNUM = [M:HRLTA1]CTRNUM and [F:DCG]TIM = FINALVALS(ROW-1,3)
&     and [DCG]UID > 0 and ([DCG]STA = 3 or [DCG]STA = 7 or [DCG]STA = 5)
&     and [DCGSP]LVEDAT >= [M:HRLTA1]FILDAT and [DCGSP]LVEDAT <= ENDDATE

    Columns [SPLITS] ([F:DCGSP]LVESUBTYP, [F:DCGSP]LVESUBBAL)
    For [SPLITS]
      If [DCGSP]LVESUBTYP = FINALVALS(ROW-1, 1) and [DCGSP]LVESUBBAL > 0
        PLANNED += [DCGSP]LVESUBBAL
      Endif
    Next
    Columns [SPLITS]

    Link [DCG] With [DCGSP]DCGSP1=[DCG]UID As [SPLITS]
&   Where [F:DCG]CTRNUM = [M:HRLTA1]CTRNUM and [F:DCG]TIM = FINALVALS(ROW-1,3)
&     and [DCG]UID > 0 and ([DCG]STA = 1 or [DCG]STA = 2)
&     and [DCGSP]LVEDAT > [M:HRLTA1]FILDAT and [DCGSP]LVEDAT < ENDDATE

    Columns [SPLITS] ([F:DCGSP]LVESUBTYP, [F:DCGSP]LVESUBBAL)
    For [SPLITS]
      If [DCGSP]LVESUBTYP = FINALVALS(ROW-1, 1) and [DCGSP]LVESUBBAL > 0
        FUTUREPENDING += [DCGSP]LVESUBBAL
      Endif
    Next
    Columns [SPLITS]

    Link [DCG] With [DCGSP]DCGSP1=[DCG]UID As [SPLITS]
&   Where [F:DCG]CTRNUM = [M:HRLTA1]CTRNUM and [F:DCG]TIM = FINALVALS(ROW-1,3)
&     and ([DCG]STA =1 or [DCG]STA = 2)
&     and [DCGSP]LVEDAT < [M:HRLTA1]FILDAT and [DCGSP]LVEDAT >= STARTDATE

    Columns [SPLITS] ([F:DCGSP]LVESUBTYP, [F:DCGSP]LVESUBBAL)
    For [SPLITS]
      If [DCGSP]LVESUBTYP = FINALVALS(ROW-1, 1) and [DCGSP]LVESUBBAL > 0
        HISTORYPENDING += [DCGSP]LVESUBBAL
      Endif
    Next
    Columns [SPLITS]

    Link [DCG] With [DCGSP]DCGSP1=[DCG]UID As [SPLITS]
&   Where [F:DCG]CTRNUM = [M:HRLTA1]CTRNUM and [F:DCG]TIM = FINALVALS(ROW-1,3)
&     and ([DCG]STA = 1 | [DCG]STA = 2 | [DCG]STA = 3 or [DCG]STA = 5 or [DCG]STA = 7)
&     and ([DCGSP]LVEDAT >= STARTDATE and [DCGSP]LVEDAT <= ENDDATE)

    Columns [SPLITS] ([F:DCGSP]LVESUBTYP, [F:DCGSP]LVESUBBAL)
    For [SPLITS]
      If [DCGSP]LVESUBTYP = FINALVALS(ROW-1, 1) and [DCGSP]LVESUBBAL > 0
        TOTALTAKENINCYCLE += [DCGSP]LVESUBBAL
      Endif
    Next

    Columns [SPLITS]
#    Filter [DCG] Where [F:DCG]CTRNUM = [M:HRLTA1]CTRNUM
#&   and [DCG]UID > 0 and ([DCG]STA = 3 or [DCG]STA = 7 or [DCG]STA = 5)
#&   and [F:DCG]STRDAT >= [M:HRLTA1]FILDAT and [F:DCG]STRDAT <= ENDDATE
#
#    For [DCG]
#      For X = 1 To dim([DCG]LVESUBTYP)
#        If [DCG]LVESUBTYP(X-1) <> "" and [DCG]LVESUBTYP(X-1) = FINALVALS(ROW-1, 1) and [DCG]LVESUBBAL(X-1) > 0
#          If [F:DCG]ENDDAT > ENDDATE
#            Local Decimal NRDAYS, NRHOURS
#            Call VALORIS_L([F:DCG]STRDAT, ENDDATE, [M:HRLTA1]REFNUM1, FINALVALS(ROW-1,3), NRDAYS, NRHOURS, [HRCTR]ETRFCY, [M:HRLTA1]CTRNUM, 0, GCURLEG, [0/0/0]) From SUBACCRUAL
#            PLANNED += NRDAYS
#          Else
#            PLANNED += [DCG]LVESUBBAL(X-1)
#          Endif
#        Endif
#      Next
#    Next
#    Filter [DCG]
#
#    Filter [DCG] Where [F:DCG]CTRNUM = [M:HRLTA1]CTRNUM and [DCG]UID > 0 and [F:DCG]TIM = FINALVALS(ROW-1,3)
#&   and ([DCG]STA = 1 or [DCG]STA = 2) and [F:DCG]STRDAT > [M:HRLTA1]FILDAT and [F:DCG]STRDAT < ENDDATE
#    For [DCG]
#      For X = 1 To dim([DCG]LVESUBTYP)
#        If [DCG]LVESUBTYP(X-1) <> "" and [DCG]LVESUBTYP(X-1) = FINALVALS(ROW-1, 1) and [DCG]LVESUBBAL(X-1) > 0
#          FUTUREPENDING += [DCG]LVESUBBAL(X-1)
#        Endif
#      Next
#    Next
#    Filter [DCG]
#
#    Filter [DCG] Where [F:DCG]CTRNUM = [M:HRLTA1]CTRNUM and [DCG]UID > 0 and [F:DCG]TIM = FINALVALS(ROW-1,3) and ([DCG]STA =1 or [DCG]STA = 2)
#&   and [F:DCG]STRDAT < [M:HRLTA1]FILDAT and [F:DCG]STRDAT >= STARTDATE
#    For [DCG]
#      For X = 1 To dim([DCG]LVESUBTYP)
#        If [DCG]LVESUBTYP(X-1) <> "" and [DCG]LVESUBTYP(X-1) = FINALVALS(ROW-1, 1) and [DCG]LVESUBBAL(X-1) > 0
#          HISTORYPENDING += [DCG]LVESUBBAL(X-1)
#        Endif
#      Next
#    Next
#    Filter [DCG]
#
#    Local Decimal NRDAYS, NRHOURS
#    Filter [DCG] Where [F:DCG]CTRNUM = [M:HRLTA1]CTRNUM and [DCG]UID > 0 and ([DCG]STA = 1 | [DCG]STA = 2 | [DCG]STA = 3 or [DCG]STA = 5 or [DCG]STA = 7) and ([F:DCG]STRDAT >= STARTDATE and [F:DCG]
#&   STRDAT <= ENDDATE)
#    For [DCG]
#      For X = 1 To dim([DCG]LVESUBTYP)
#        If [DCG]LVESUBTYP(X-1) <> "" and [DCG]LVESUBTYP(X-1) = FINALVALS(ROW-1, 1) and [DCG]LVESUBBAL(X-1) > 0
#          If [F:DCG]ENDDAT > ENDDATE
#            Local Decimal NRDAYS, NRHOURS
#            Call VALORIS_L([F:DCG]STRDAT, ENDDATE, [M:HRLTA1]REFNUM1, FINALVALS(ROW-1,3), NRDAYS, NRHOURS, [HRCTR]ETRFCY, [M:HRLTA1]CTRNUM, 0, GCURLEG, [0/0/0]) From SUBACCRUAL
#            TOTALTAKENINCYCLE += NRDAYS
#          Else
#            TOTALTAKENINCYCLE += [DCG]LVESUBBAL(X-1)
#          Endif
#        Endif
#      Next
#    Next
#    Filter [DCG]
#
#    Filter [DCG] Where [F:DCG]CTRNUM = [M:HRLTA1]CTRNUM and [DCG]UID > 0 and ([DCG]STA = 1 | [DCG]STA = 2 | [DCG]STA = 3 or [DCG]STA = 5 or [DCG]STA = 7) and ([F:DCG]ENDDAT < ENDDATE and [F:DCG]
#&   STRDAT < STARTDATE)
#    For [DCG]
#      For X = 1 To dim([DCG]LVESUBTYP)
#        If [DCG]LVESUBTYP(X-1) <> "" and [DCG]LVESUBTYP(X-1) = FINALVALS(ROW-1, 1) and [DCG]LVESUBBAL(X-1) > 0
#          Local Decimal NRDAYS, NRHOURS
#          Call VALORIS_L(STARTDATE, [F:DCG]ENDDAT, [M:HRLTA1]REFNUM1, FINALVALS(ROW-1,3), NRDAYS, NRHOURS, [HRCTR]ETRFCY, [M:HRLTA1]CTRNUM, 0, GCURLEG, [0/0/0]) From SUBACCRUAL
#          TOTALTAKENINCYCLE += NRDAYS
#        Endif
#      Next
#    Next
#    Filter [DCG]
#PEVAN - 2018-10-10 - X3-111790 - END

    If ENDDATE <> [0/0/0]
    Else
      If STARTDATE <> [0/0/0]
        If CYCLEUNIT = 1
          ENDDATE = addmonth(STARTDATE, CYCLELENGHT*12)
        Else
          ENDDATE = addmonth(STARTDATE, CYCLELENGHT)
        Endif
        ENDDATE = ENDDATE - 1
      Endif
    Endif

    SUBTYPEACTIVE = 0

    If ([M:HRLTA2]LVEACTONLY = 2)
      If STARTDATE = [0/0/0]
        SUBTYPEACTIVE = 0
      Else
        If [M:HRLTA1]FILDAT >= STARTDATE & [M:HRLTA1]FILDAT <= ENDDATE
          ACTIVE = 1
          SUBTYPEACTIVE = 1
        Else
          SUBTYPEACTIVE = 0
        Endif
      Endif
    Endif


     If (SUBTYPEACTIVE = 1 or [M:HRLTA2]LVEACTONLY = 1)
      BROWS += 1
      [M:HRLTA2]LVEACCTIM(BROWS-1) = FINALVALS(ROW-1,3)
      Call LECTEXTRA([M:HRLTA2]LVETIMDES(BROWS-1), "TIMCOD", "DES", GCURLEG, FINALVALS(ROW-1,3)) From ATEXTRA
      [M:HRLTA2]LVEACCLST(BROWS-1) = FINALVALS(ROW-1,1)
      Call LECTEXTRA([M:HRLTA2]LVELSTDES(BROWS-1), "HRLVESUBHEA", "DES", GCURLEG, FINALVALS(ROW-1,1)) From ATEXTRA
      If [HRHEA]LVEDISONL = 1
        [M:HRLTA2]LVEENTITL(BROWS-1) = val([HRHEA]ENTCAL)
        [M:HRLTA2]LVEBALANC(BROWS-1) = BALANCE
      Else
        Raz [M:HRLTA2]LVEENTITL(BROWS-1)
        Raz [M:HRLTA2]LVEBALANC(BROWS-1)
      Endif
      [M:HRLTA2]LVETAKCYC(BROWS-1) = TOTALTAKENINCYCLE
      If STARTDATE <> [0/0/0]
        [M:HRLTA2]CYCSTRCAL(BROWS-1) = format$("DD2", STARTDATE)
      Else
        Effzo [M:HRLTA2]CYCSTRCAL(BROWS-1)
      Endif
      If ENDDATE <> [0/0/0]
        [M:HRLTA2]LVEACCEXP(BROWS-1) = ENDDATE
      Else
        Effzo [M:HRLTA2]LVEACCEXP(BROWS-1)
      Endif
      [M:HRLTA2]CYCLEN(BROWS-1) = CYCLELENGHT
      [M:HRLTA2]CYCLENU(BROWS-1) = CYCLEUNIT
      [M:HRLTA2]LVEPLANNE(BROWS-1) = PLANNED
      [M:HRLTA2]LVEFUTPEN(BROWS-1) = FUTUREPENDING
      [M:HRLTA2]LVEHISPEN(BROWS-1) = HISTORYPENDING
    Endif

    $NEXTREC
  Next
  Filter [ACCRU]
  Local Integer IJ
  Local Date CARFUTDAT,SCNDAT
  For ROW = 1 To BROWS
    For IJ = 0 To maxtab(CARFUTBALS)
    Call CONVERT_TO_DATE(CARFUTBALS(IJ,4), CARFUTDAT) From SUBHRBAL
    Call CONVERT_TO_DATE_SCR([M:HRLTA2]CYCSTRCAL(ROW-1), SCNDAT) From SUBHRBAL
      If CARFUTBALS(IJ,2) <> "" and CARFUTBALS(IJ,2) = [M:HRLTA2]LVEACCLST(ROW-1) and (CARFUTDAT>SCNDAT)
        [M:HRLTA2]LVEBALANC(ROW-1) += val(CARFUTBALS(IJ,5))
      Endif
    Next
  Next


  [M:HRLTA2]NBLIG = BROWS
  BALANCE_GRID_ROWS = BROWS
  Affzo [M:HRLTA2]

  Filter [DCG] Where [F:DCG]CTRNUM = [M:HRLTA1]CTRNUM and [DCG]UID > 0

  For [DCG]
    If [DCG]UID > 0
      [M:HRLTA3]LVEACCTIM(TRNROWS) = [DCG]TIM
      Call LECTEXTRA([M:HRLTA3]LVETRADES(TRNROWS), "TIMCOD", "DES", GCURLEG, [DCG]TIM) From ATEXTRA
      [M:HRLTA3]LVESTSTAK(TRNROWS) = [DCG]NBRDAY
      [M:HRLTA3]STRDAT(TRNROWS) = [DCG]STRDAT
      [M:HRLTA3]LVEENDDAT(TRNROWS) = [DCG]ENDDAT
      [M:HRLTA3]LVERSN(TRNROWS) = [DCG]LVERSN
      [M:HRLTA3]LVESEQ(TRNROWS) = [DCG]LVESEQ
      [M:HRLTA3]LVENOT(TRNROWS) = [DCG]LVENOT
      [M:HRLTA3]DRNAM(TRNROWS) = [DCG]DRNAM
      [M:HRLTA3]PRTNAM(TRNROWS) = [DCG]PRTNAM
      [M:HRLTA3]STA(TRNROWS) = [DCG]STA
      If ([DCG]STA = 3 | [DCG]STA = 5 | [DCG]STA = 7) and [DCG]STRDAT > [M:HRLTA1]FILDAT
        [M:HRLTA3]LVEPLANNE(TRNROWS) = 2
      Endif
      If ([DCG]STA = 1 | [DCG]STA = 2)
        [M:HRLTA3]LVEPENDIN(TRNROWS) = 2
      Endif
      [M:HRLTA3]UID(TRNROWS) = [DCG]UID
      TRNROWS += 1
    Endif

  Next
  Filter [DCG]
  If (TRNROWS > 0)
    [M:HRLTA3]NBLIG31 = TRNROWS
    Affzo [M:HRLTA3]
    TRANSACTION_GRID_ROWS = TRNROWS
  Else
    [M:HRLTA3]NBLIG31 = 1
    Affzo [M:HRLTA3]
    [M:HRLTA3]NBLIG31 = 0
    [M:HRLTA3]NBLIG32 = 0
    Affzo [M:HRLTA3]
  Endif
Return

$GET_SYSTEM_TRANSACTIONS
  If [M:HRLTA1]CTRNUM = "" : Return :Endif

  Local Integer N,L, SKIP, COUNTER, ACTIVEST
  Local Decimal AMOUNT
  Local Char TKN_LST(10)(0..9,0..9), FNLTST(100)(0..,0..9)
  Local Date CYCLESTRDAT, CYCLEENDDATE, EXTRACTIONSTARTDATE, EXTRACTIONENDDATE, QUERYSTARTDATE, QUERYENDDATE
  N = 0
  COUNTER = 0

  If !clalev([F:ACCRU])  : Local File HRLVEACCRU [ACCRU] : Endif
  If !clalev([F:VALEMP]) : Local File VALEMP [VALEMP]    : Endif
  If !clalev([F:HRHEA])  : Local File HRLVESUBHEA [HRHEA]: Endif
  If !clalev([F:HRCTRGB]): Local File EMPLOCTR [HRCTRGB] : Endif

  Filter [VALEMP] Where [VALEMP]CTRNUM = [M:HRLTA1]CTRNUM and [VALEMP]ENDDAT <= [M:HRLTA1]FILDAT Order By [VALEMP]PYRDAT
  Read [VALEMP] Last
  If rowcount([VALEMP]) = 0
    [M:HRLTA1]DATPYR = [0/0/0]
    Affzo [M:HRLTA1]DATPYR
  Else
    [M:HRLTA1]DATPYR = [VALEMP]ENDDAT
  Endif
  Filter [VALEMP]

  Filter [ACCRU] Where [ACCRU]CTR = [M:HRLTA1]CTRNUM and [ACCRU]LVEACCDAT <= [M:HRLTA1]FILDAT and ([ACCRU]LVEACT <> 1 or [M:HRLTA4]LVEACTONL4 = 1) and [ACCRU]LVEACCAMT <> "0" Order By [F:ACCRU]
& LVEACCDAT
  Read [ACCRU] Last
  If rowcount([ACCRU]) = 0
    [M:HRLTA1]DATLVE = [0/0/0]
    Affzo [M:HRLTA1]DATLVE
  Else
    [M:HRLTA1]DATLVE = [F:ACCRU]LVEACCDAT
  Endif
  Filter [ACCRU]

  Local Date COMPDATLTAACCCR,STARTDATEACCR,GLMCYCLEGB
  Local Integer LINKED
  Filter [HRCTRGB] Where [F:HRCTRGB]CTRNUM=[M:HRLTA1]CTRNUM and [F:HRCTRGB]CTRDAT <= [M:HRLTA1]FILDAT and ([F:HRCTRGB]XITDAT = [0/0/0] or [F:HRCTRGB]XITDAT >= [M:HRLTA1]FILDAT)
  Read [HRCTRGB] First
  Filter [HRCTRGB]

  GCURLEG=func DIVPAYE_SOA.GET_LEG_CTR([F:HRCTRGB]REFNUM,[F:HRCTRGB]CTRNUM,[F:HRCTRGB]CTRDAT,1)
  GLMCYCLEGB = func SUBHRBAL.GET_GLM_CYCLE([F:HRCTRGB]CTRNUM,[F:HRCTRGB]CTRDAT)

  For [ACCRU] Where [ACCRU]CTR = [M:HRLTA1]CTRNUM and ([ACCRU]LVEACCDAT <= [M:HRLTA1]FILDAT or [M:HRLTA4]LVECYCLEO4 = 1)
    Filter [TIM] Where COD = [ACCRU]LVEACCTIM
    Read [TIM] First
    Filter [TIM]

    If ([TIM]LVEENHANCE = 2) #Enhanced Leave Event is active on the Nature of Event
      If [F:ACCRU]LVEACCTYP <> "Linking"
        [M:HRLTA4]LVESUBTYP(COUNTER) = [ACCRU]LVEACCLST
        Call LECTEXTRA([M:HRLTA4]LVEPAYDES(COUNTER), "HRLVESUBHEA", "DES", GCURLEG, [ACCRU]LVEACCLST) From ATEXTRA
        [M:HRLTA4]LVEACCAMT(COUNTER) = val([ACCRU]LVEACCAMT)
        [M:HRLTA4]LVEACCTIM(COUNTER) = [ACCRU]LVEACCTIM
        [M:HRLTA4]ACCFRM(COUNTER) = [ACCRU]ACCFRM
        [M:HRLTA4]LVEACCTYP(COUNTER) = [ACCRU]LVEACCTYP
        [M:HRLTA4]LVEACCDAT(COUNTER) = [ACCRU]LVEACCDAT
        [M:HRLTA4]SYSDAT(COUNTER) = [ACCRU]SYSDAT
        COUNTER += 1
      Endif
    Endif
  Next
  Filter [ACCRU]

  [M:HRLTA4]NBLIG4 = COUNTER
  SYSTEM_TRANSACTIONS_GRID_ROWS = COUNTER
  Affzo [M:HRLTA4]
  Affzo [M:HRLTA1]
Return

