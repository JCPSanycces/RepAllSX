######################################################################################
## Section automatically added (screen CONSLTA3) 08/23/2017 13:13:43 (PEVAN)
######################################################################################
Subprog AP_NBLIG31
  Local Integer ROWNUM, COUNTER
  Local Char LSTDESCRIPTION(50)

  If nolign > [M:HRLTA3]NBLIG31
    [M:HRLTA3]NBLIG31 = TRANSACTION_GRID_ROWS
    End
  Endif

  If clalev([HRLSTH]) = 0 : Local File HRLVESUBHEA [HRLSTH] : Endif
  Filter [DCG]
  Filter [DCG] Where [DCG]UID = [M:HRLTA3]UID(nolign - 1)

  Read [DCG] First
  COUNTER = 0

  For ROWNUM = 1 To 10
    If ([M:HRLTA3]LVESUBTYP(ROWNUM - 1) <> "")
      Raz [M:HRLTA3]LVESUBTYP(ROWNUM - 1)
      Raz [M:HRLTA3]LVETRADES(ROWNUM - 1)
      Raz [M:HRLTA3]NBRDAY(ROWNUM - 1)
      Raz [M:HRLTA3]NBRHOU(ROWNUM - 1)
      Raz [M:HRLTA3]LVESUBRATE(ROWNUM - 1)
    Endif
  Next
  Affzo [M:HRLTA3]30
  For ROWNUM = 1 To dim([DCG]LVESUBTYP)
    If [DCG]LVESUBTYP(ROWNUM - 1) <> ""
      [M:HRLTA3]LVESUBTYP(ROWNUM - 1) = [DCG]LVESUBTYP(ROWNUM - 1)
      Call LECTEXTRA(LSTDESCRIPTION,"HRLVESUBHEA","DES",GCURLEG,[DCG]LVESUBTYP(ROWNUM - 1)) From ATEXTRA
      [M:HRLTA3]DES(ROWNUM - 1) = LSTDESCRIPTION
      [M:HRLTA3]NBRDAY(ROWNUM - 1) = [DCG]LVESUBBAL(ROWNUM - 1)
      If [DCG]LVESUBBAL(ROWNUM - 1) > 0 and [DCG]NBRDAY > 0
        [M:HRLTA3]NBRHOU(ROWNUM - 1) = ([DCG]LVESUBBAL(ROWNUM - 1)/[DCG]NBRDAY)*[DCG]NBRHOU
      Endif
      If ([DCG]LVESUBBAL(ROWNUM - 1) > 0 and [DCG]LVESUBRAT <> 99 and [DCG]LVESUBRAT <> 0) ##99 is the not applicable option
        Filter [HRLSTH] Where [HRLSTH]COD = [DCG]LVESUBTYP(ROWNUM - 1)
        Read [HRLSTH] First
          [M:HRLTA3]LVESUBRATE(ROWNUM - 1) = [HRLSTH]LVEPAYDES([DCG]LVESUBRAT-1)
        Filter [HRLSTH]
      Endif
      COUNTER += 1
    Endif
  Next
  [M:HRLTA3]NBLIG32 = COUNTER
  TRANSACTION_SUB_GRID_ROWS = COUNTER
  Affzo [M:HRLTA3]30
  Filter [DCG]
End

Subprog AP_NBLIG32
  If nolign > [M:HRLTA3]NBLIG32
    [M:HRLTA3]NBLIG32 = TRANSACTION_SUB_GRID_ROWS
    End
  Endif
End

$GET_SOA_BALANCES
  Local Integer N, L, M, BROWS, ST, FOUND, ROW, TRNROWS, SKIP, FOUND, SUBTYPEACTIVE, CYCLEUNIT, X, ALLN, LOOPM
  Local Char ALLSUBTYPES(100)(0..,0..9)
  Local Char FINALVALS(100)(0..,0..9)
  Local Char ALLNATURES(100)(0..)
  Local Char ALLSUBTYPESFOUND(100)(0..)
  Local Char LVESTARR(100)(0..)
  Local Char NEVENTARR(100)(0..)
  Local Char TESTING(250)
  Local Date STARTDATE, ENDDATE, CYCLESTRDAT, CYCLEENDDATE, LASTACCRUAL, EXTRACTIONSTARTDATE, EXTRACTIONENDDATE, QUERYSTARTDATE, QUERYENDDATE, SENIORITYDATE
  Local Decimal BALANCE, ACCRUAL, TOTALTAKENINCYCLE, PLANNED, FUTUREPENDING, HISTORYPENDING
  N = 0: M = 0: LOOPM = 0: L = 1: ALLN = 1: ST = 1: BROWS = 0: TRNROWS = 0: ROW = 1:

  If !clalev([F:HRHEA]) : Local File HRLVESUBHEA [HRHEA] : Endif
  If !clalev([F:ACCRU]) : Local File HRLVEACCRU [ACCRU] : Endif
  If !clalev([TIM]) : Local File TIMCOD [TIM] Endif
  If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
  Filter [HRCTR] Where CTRNUM = CURRENT_CTR
  Read [HRCTR] First
    SENIORITYDATE = [F:HRCTR]DATANC
  Filter [HRCTR]

  Filter [F:ACCRU] Where [F:ACCRU]CTR = CURRENT_CTR and [F:ACCRU]LVEACCTYP = "Linking" Order By [F:ACCRU]LVEACCTIM #and LVEACCDAT >= [M:HRLTA1]FILDAT

  For [F:ACCRU]
    FOUND = find([F:ACCRU]LVEACCLST, ALLSUBTYPESFOUND)
    If (FOUND = 0)
      ALLSUBTYPESFOUND(L) = [F:ACCRU]LVEACCLST
      ALLSUBTYPES(L,1) = [F:ACCRU]LVEACCLST
      ALLSUBTYPES(L,3) = [F:ACCRU]LVEACCTIM
      FOUND = find([F:ACCRU]LVEACCTIM, ALLNATURES)
      If (FOUND = 0)
        ALLNATURES(ALLN) = [F:ACCRU]LVEACCTIM
        ALLN += 1
      Endif
      Filter [F:TIM] Where [F:TIM]COD = [F:ACCRU]LVEACCTIM
      Read [F:TIM] First
      For M = 1 To dim([TIM]LVESUBTYP)
        If ([F:TIM]LVESUBTYP(M-1) <> "" and [F:TIM]LVESUBTYP(M-1) = [F:ACCRU]LVEACCLST)
          ALLSUBTYPES(L,2) = num$([F:TIM]LVESUBPRI(M-1))
        Endif
      Next
      L += 1
    Endif
  Next

  L = 0
  For ROW = 1 To maxtab(ALLSUBTYPES)
    If (ALLSUBTYPES(ROW,1) <> "")
      L += 1
    Endif
  Next
## SORT NATURE OF EVENTS ALPHABETIC
  If ALLN > 1
    For M = 2 To ALLN

      Local Integer ALLNSWAPPEDAROUND
      Local Char TEMPNATUREOFEVENT(250)
      Repeat
        ALLNSWAPPEDAROUND = 0
        If (ALLNATURES(M-1) > ALLNATURES(M))
          TEMPNATUREOFEVENT = ALLNATURES(M-1)
          ALLNATURES(M-1) = ALLNATURES(M)
          ALLNATURES(M) = TEMPNATUREOFEVENT
          ALLNSWAPPEDAROUND = 1
        Endif
      Until ALLNSWAPPEDAROUND = 0
    Next
  Endif
## SORT LEAVE SUB TYPES WITHIN NATURE OF EVENTS BASED ON THE PRIORITY
  L = 1
  For LOOPM = 1 To ALLN
    Local Char TEMPALLSUBTYPES(100)(0..,0..9)
    For ROW = 1 To maxtab(ALLSUBTYPES)
      If (ALLSUBTYPES(ROW,1) <> "" and ALLSUBTYPES(ROW,3) = ALLNATURES(LOOPM))
        TEMPALLSUBTYPES(ROW,1) = ALLSUBTYPES(ROW,1)
        TEMPALLSUBTYPES(ROW,2) = ALLSUBTYPES(ROW,2)
        TEMPALLSUBTYPES(ROW,3) = ALLSUBTYPES(ROW,3)
      Endif
    Next

    Local Integer SWAPPEDAROUND
    Local Char TEMPSUBTYPE(250)
    Local Integer TEMPPRIORITY
    Local Char TEMPTIM(250)
    Repeat
      SWAPPEDAROUND = 0
      For M = 2 To maxtab(TEMPALLSUBTYPES)
        If TEMPALLSUBTYPES(M-1,1) <> "" and TEMPALLSUBTYPES(M,1) <> ""
          If val(TEMPALLSUBTYPES(M-1,2)) > val(TEMPALLSUBTYPES(M,2))
            SWAPPEDAROUND = 1
            TEMPSUBTYPE = TEMPALLSUBTYPES(M-1,1)
            TEMPPRIORITY = val(TEMPALLSUBTYPES(M-1,2))
            TEMPTIM = TEMPALLSUBTYPES(M-1,3)
            TEMPALLSUBTYPES(M-1,1) = TEMPALLSUBTYPES(M,1)
            TEMPALLSUBTYPES(M-1,2) = TEMPALLSUBTYPES(M,2)
            TEMPALLSUBTYPES(M-1,3) = TEMPALLSUBTYPES(M,3)
            TEMPALLSUBTYPES(M,1) = TEMPSUBTYPE
            TEMPALLSUBTYPES(M,2) = num$(TEMPPRIORITY)
            TEMPALLSUBTYPES(M,3) = TEMPTIM
          Endif
        Endif
      Next
    Until SWAPPEDAROUND = 0
    For M = 1 To maxtab(TEMPALLSUBTYPES)
      If (TEMPALLSUBTYPES(M,1) <> "")
        FINALVALS(L,1) = TEMPALLSUBTYPES(M,1)
        FINALVALS(L,2) = TEMPALLSUBTYPES(M,2)
        FINALVALS(L,3) = TEMPALLSUBTYPES(M,3)
        L += 1
      Endif
    Next
  Next

  L = 0

  For ROW = 0 To maxtab(FINALVALS)

    If (FINALVALS(ROW,1) <> "")
      L += 1
    Endif
  Next

  For ROW = 1 To L
    Local Integer GOFURBALLS:
    ENDDATE = [0/0/0]
    STARTDATE = [0/0/0]

    Call GET_CYCLE_START_DATE_EXTRACTION(CURRENT_CTR, FINALVALS(ROW,1), LVEFILTER, STARTDATE, ENDDATE, 1, VGURLEG) From SUBHRBAL
    Filter [ACCRU] Where [ACCRU]CTR = CURRENT_CTR and [ACCRU]LVEACCLST = FINALVALS(ROW,1) Order By [ACCRU]LVEACCDAT
    Read [ACCRU] Last
    If fstat = 0
      If [ACCRU]LVEACCDAT < LVEFILTER
        GOFURBALLS = 1
      Else
        GOFURBALLS = 2
      Endif
    Else
      GOFURBALLS = 1
    Endif
    Filter [ACCRU]

    If (GOFURBALLS = 2)
      Call GET_BALANCE(CURRENT_CTR, FINALVALS(ROW,1), LVEFILTER, BALANCE, ACCRUAL, TOTALTAKENINCYCLE, 1, VGURLEG) From SUBHRBAL
    Else
      Local Char FUTBALS(250)(0..,0..10)
      Call GET_BALANCE_FCST(CURRENT_CTR, FINALVALS(ROW,3), FINALVALS(ROW,1), LVEFILTER, FUTBALS, BALANCE, ACCRUAL, TOTALTAKENINCYCLE,1,[0/0/0],[0/0/0]) From SUBHRBAL
    Endif

    Filter [HRHEA] Where [F:HRHEA]COD = FINALVALS(ROW,1)
    Read [HRHEA] First

    CYCLEUNIT = [HRHEA]CYCLENU
    CYCLELENGHT = [HRHEA]CYCLEN

    PLANNED = 0
    FUTUREPENDING = 0
    HISTORYPENDING = 0

    Filter [DCG] Where [F:DCG]CTRNUM = CURRENT_CTR and [DCG]UID > 0 and ([DCG]STA = 3 or [DCG]STA = 7 or [DCG]STA = 5) and [F:DCG]STRDAT >= LVEFILTER
    For [DCG]
      For X = 1 To dim([DCG]LVESUBTYP)
        If [DCG]LVESUBTYP(X-1) <> "" and [DCG]LVESUBTYP(X-1) = FINALVALS(ROW, 1) and [DCG]LVESUBBAL(X-1) > 0
          PLANNED += [DCG]LVESUBBAL(X-1)
        Endif
      Next
    Next
    Filter [DCG]

    Filter [DCG] Where [F:DCG]CTRNUM = CURRENT_CTR and [DCG]UID > 0 and [F:DCG]TIM = FINALVALS(ROW,3) and ([DCG]STA = 1 or [DCG]STA = 2) and [F:DCG]STRDAT  > LVEFILTER
    For [DCG]
      For X = 1 To dim([DCG]LVESUBTYP)
        If [DCG]LVESUBTYP(X-1) <> "" and [DCG]LVESUBTYP(X-1) = FINALVALS(ROW, 1) and [DCG]LVESUBBAL(X-1) > 0
          FUTUREPENDING += [DCG]LVESUBBAL(X-1)
        Endif
      Next
    Next
    Filter [DCG]

    Filter [DCG] Where [F:DCG]CTRNUM = CURRENT_CTR and [DCG]UID > 0 and [F:DCG]TIM = FINALVALS(ROW,3) and ([DCG]STA =1 or [DCG]STA = 2) and [F:DCG]STRDAT < LVEFILTER
    For [DCG]
      For X = 1 To dim([DCG]LVESUBTYP)
        If [DCG]LVESUBTYP(X-1) <> "" and [DCG]LVESUBTYP(X-1) = FINALVALS(ROW, 1) and [DCG]LVESUBBAL(X-1) > 0
          HISTORYPENDING += [DCG]LVESUBBAL(X-1)
        Endif
      Next
    Next
    Filter [DCG]

    If ENDDATE <> [0/0/0]
    Else
      If STARTDATE <> [0/0/0]
        If CYCLEUNIT = 1
          ENDDATE = addmonth(STARTDATE, CYCLELENGHT*12)
        Else
          ENDDATE = addmonth(STARTDATE, CYCLELENGHT)
        Endif
        ENDDATE = ENDDATE - 1
      Endif
    Endif

    If STARTDATE <> [0/0/0]
      If STARTDATE < SENIORITYDATE
        STARTDATE = SENIORITYDATE
      Endif
    Endif

    SUBTYPEACTIVE = 0
    If (SOA_LVEACTONLY = 2)
      Call EMPLOYEE_SUB_TYPE_CHECK(CURRENT_CTR, FINALVALS(ROW,1), SUBTYPEACTIVE) From SUBHRBAL
      If STARTDATE = [0/0/0]
        SUBTYPEACTIVE = 0
      Endif
    Endif

    If (SUBTYPEACTIVE = 1 or SOA_LVEACTONLY = 1)
      #For each new nature of event a new class must be created within the contract.
      #The first iteration of the loop will see CURR_NATURE_EVENT = AVOID.ACHAR
      #Check the value of CURR_NATURE_EVENT
      If (FINALVALS(ROW,3) <> AVOID.ACHAR and CURR_NATURE_EVENT <> FINALVALS(ROW,3))
        CURR_NATURE_EVENT = FINALVALS(ROW,3)
        #First possible iteration
        #Add new collection in CONSLTAESS
        If COLLECTIONNAME = "CTRLTAESS"
          CONSLTAESS_INDEX = fmet this.CTRLTAESS(CTRLTAESS_INDEX).ADDLINE("CONSLTAESS",[V]CST_ALASTPOS)
        Else
          CONSLTAESS_INDEX = fmet this.CTRLTAESSDAT(CTRLTAESS_INDEX).ADDLINE("CONSLTAESS",[V]CST_ALASTPOS)
        Endif

      Endif
      If CONSLTAESS_INDEX <> [V]CST_ANOTDEFINED and FINALVALS(ROW,3) <> AVOID.ACHAR
        If COLLECTIONNAME = "CTRLTAESS"
          #Add data in CONLTAESS
          this.CTRLTAESS(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCTIM = FINALVALS(ROW,3)
          #Create new collection LVEACCDET
          LVEACCDET_INDEX = fmet this.CTRLTAESS(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).ADDLINE("LVEACCDET",[V]CST_ALASTPOS)
        Else
          #Add data in CONLTAESS
          this.CTRLTAESSDAT(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCTIM = FINALVALS(ROW,3)
          #Create new collection LVEACCDET
          LVEACCDET_INDEX = fmet this.CTRLTAESSDAT(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).ADDLINE("LVEACCDET",[V]CST_ALASTPOS)
        Endif

        #Add data in collection LVEACCDET
        If LVEACCDET_INDEX <> [V]CST_ANOTDEFINED
          If COLLECTIONNAME = "CTRLTAESS"
            this.CTRLTAESS(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEACCLST = FINALVALS(ROW,1)
            If [HRHEA]LVEDISONL = 1
              this.CTRLTAESS(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEENTITL = val([HRHEA]ENTCAL)
              this.CTRLTAESS(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEBALANC = BALANCE
            Endif
            this.CTRLTAESS(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVETAKCYC = TOTALTAKENINCYCLE
            If STARTDATE <> [0/0/0]
              this.CTRLTAESS(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).CYCSTRCAL = format$("DD2", STARTDATE)
            Endif
            If ENDDATE <> [0/0/0]
              this.CTRLTAESS(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEACCEXP = ENDDATE
            Endif
            this.CTRLTAESS(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).CYCLEN    = CYCLELENGHT
            this.CTRLTAESS(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).CYCLENU   = CYCLEUNIT
            this.CTRLTAESS(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEPLANNE = PLANNED
            this.CTRLTAESS(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEFUTPEN = FUTUREPENDING
            this.CTRLTAESS(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEHISPEN = HISTORYPENDING
          Else
            this.CTRLTAESSDAT(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEACCLST = FINALVALS(ROW,1)
            If [HRHEA]LVEDISONL = 1
              this.CTRLTAESSDAT(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEENTITL = val([HRHEA]ENTCAL)
              this.CTRLTAESSDAT(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEBALANC = BALANCE
            Endif
            this.CTRLTAESSDAT(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVETAKCYC = TOTALTAKENINCYCLE
            If STARTDATE <> [0/0/0]
              this.CTRLTAESSDAT(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).CYCSTRCAL = format$("DD2", STARTDATE)
            Endif
            If ENDDATE <> [0/0/0]
              this.CTRLTAESSDAT(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEACCEXP = ENDDATE
            Endif
            this.CTRLTAESSDAT(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).CYCLEN    = CYCLELENGHT
            this.CTRLTAESSDAT(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).CYCLENU   = CYCLEUNIT
            this.CTRLTAESSDAT(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEPLANNE = PLANNED
            this.CTRLTAESSDAT(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEFUTPEN = FUTUREPENDING
            this.CTRLTAESSDAT(CTRLTAESS_INDEX).CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEHISPEN = HISTORYPENDING

          Endif
        Endif
      Endif
    Endif
    Filter [DCG]
  Next
  Filter [ACCRU]
Return

Funprog GET_SOA_BALANCES_FUNC(CURRENT_CTR,CURRENT_REFNUM,CURRENT_CTRDAT,STRUCTURE,LVEFILTER,VGURLEG,SOA_LVEACTONLY,PNATEVENT)
  Value Char CURRENT_CTR,CURRENT_REFNUM,VGURLEG
  Value Date CURRENT_CTRDAT,LVEFILTER
  Value Integer SOA_LVEACTONLY
  Value Char PNATEVENT
  Local Char CURR_NATURE_EVENT(GLONTPS)
  Local Integer CONSLTAESS_INDEX
  Local Integer N, L, M, BROWS, ST, FOUND, ROW, TRNROWS, SKIP, FOUND, SUBTYPEACTIVE, CYCLEUNIT, X, ALLN, LOOPM
  Local Char ALLSUBTYPES(100)(0..,0..9)
  Local Char FINALVALS(100)(0..,0..9)
  Local Char ALLNATURES(100)(0..)
  Local Char ALLSUBTYPESFOUND(100)(0..)
  Local Char LVESTARR(100)(0..)
  Local Char NEVENTARR(100)(0..)
  Local Char TESTING(250)
  Local Date STARTDATE, ENDDATE, CYCLESTRDAT, CYCLEENDDATE, LASTACCRUAL, EXTRACTIONSTARTDATE, EXTRACTIONENDDATE, QUERYSTARTDATE, QUERYENDDATE, SENIORITYDATE
  Local Decimal BALANCE, ACCRUAL, TOTALTAKENINCYCLE, PLANNED, FUTUREPENDING, HISTORYPENDING
  N = 0: M = 0: LOOPM = 0: L = 1: ALLN = 1: ST = 1: BROWS = 0: TRNROWS = 0: ROW = 1:

  STRUCTURE.REFNUM      = CURRENT_REFNUM
  STRUCTURE.CTRNUM      = CURRENT_CTR
  STRUCTURE.CTRDAT      = CURRENT_CTRDAT
  STRUCTURE.TCH_BALDAT  = LVEFILTER

  Local File ATEXTRA [AXX1]
  If !clalev([F:HRHEA]) : Local File HRLVESUBHEA [HRHEA] : Endif
  If !clalev([F:ACCRU]) : Local File HRLVEACCRU [ACCRU] : Endif
  If !clalev([TIM]) : Local File TIMCOD [TIM] Endif
  If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
  Filter [HRCTR] Where CTRNUM = CURRENT_CTR
  Read [HRCTR] First
    SENIORITYDATE = [F:HRCTR]DATANC
  Filter [HRCTR]
  If PNATEVENT = AVOID.ACHAR
    Filter [F:ACCRU] Where [F:ACCRU]CTR = CURRENT_CTR and [F:ACCRU]LVEACCTYP = "Linking" Order By [F:ACCRU]LVEACCTIM #and LVEACCDAT >= [M:HRLTA1]FILDAT
  Else
    Filter [F:ACCRU] Where [F:ACCRU]CTR = CURRENT_CTR and [F:ACCRU]LVEACCTYP = "Linking" and  [F:ACCRU]LVEACCTIM = PNATEVENT Order By [F:ACCRU]LVEACCTIM #and LVEACCDAT >= [M:HRLTA1]FILDAT
  Endif

  For [F:ACCRU]
    FOUND = find([F:ACCRU]LVEACCLST, ALLSUBTYPESFOUND)
    If (FOUND = 0)
      ALLSUBTYPESFOUND(L) = [F:ACCRU]LVEACCLST
      ALLSUBTYPES(L,1) = [F:ACCRU]LVEACCLST
      ALLSUBTYPES(L,3) = [F:ACCRU]LVEACCTIM
      FOUND = find([F:ACCRU]LVEACCTIM, ALLNATURES)
      If (FOUND = 0)
        ALLNATURES(ALLN) = [F:ACCRU]LVEACCTIM
        ALLN += 1
      Endif
      Filter [F:TIM] Where [F:TIM]COD = [F:ACCRU]LVEACCTIM
      Read [F:TIM] First
      Filter [F:TIM]
      For M = 1 To dim([TIM]LVESUBTYP)
        If ([F:TIM]LVESUBTYP(M-1) <> "" and [F:TIM]LVESUBTYP(M-1) = [F:ACCRU]LVEACCLST)
          ALLSUBTYPES(L,2) = num$([F:TIM]LVESUBPRI(M-1))
        Endif
      Next
      L += 1
    Endif
  Next

  L = 0
  For ROW = 1 To maxtab(ALLSUBTYPES)
    If (ALLSUBTYPES(ROW,1) <> "")
      L += 1
    Endif
  Next
## SORT NATURE OF EVENTS ALPHABETIC
  If ALLN > 1
    For M = 2 To ALLN

      Local Integer ALLNSWAPPEDAROUND
      Local Char TEMPNATUREOFEVENT(250)
      Repeat
        ALLNSWAPPEDAROUND = 0
        If (ALLNATURES(M-1) > ALLNATURES(M))
          TEMPNATUREOFEVENT = ALLNATURES(M-1)
          ALLNATURES(M-1) = ALLNATURES(M)
          ALLNATURES(M) = TEMPNATUREOFEVENT
          ALLNSWAPPEDAROUND = 1
        Endif
      Until ALLNSWAPPEDAROUND = 0
    Next
  Endif
## SORT LEAVE SUB TYPES WITHIN NATURE OF EVENTS BASED ON THE PRIORITY
  L = 1
  For LOOPM = 1 To ALLN
    Local Char TEMPALLSUBTYPES(100)(0..,0..9)
    For ROW = 1 To maxtab(ALLSUBTYPES)
      If (ALLSUBTYPES(ROW,1) <> "" and ALLSUBTYPES(ROW,3) = ALLNATURES(LOOPM))
        TEMPALLSUBTYPES(ROW,1) = ALLSUBTYPES(ROW,1)
        TEMPALLSUBTYPES(ROW,2) = ALLSUBTYPES(ROW,2)
        TEMPALLSUBTYPES(ROW,3) = ALLSUBTYPES(ROW,3)
      Endif
    Next

    Local Integer SWAPPEDAROUND
    Local Char TEMPSUBTYPE(250)
    Local Integer TEMPPRIORITY
    Local Char TEMPTIM(250)
    Repeat
      SWAPPEDAROUND = 0
      For M = 2 To maxtab(TEMPALLSUBTYPES)
        If TEMPALLSUBTYPES(M-1,1) <> "" and TEMPALLSUBTYPES(M,1) <> ""
          If val(TEMPALLSUBTYPES(M-1,2)) > val(TEMPALLSUBTYPES(M,2))
            SWAPPEDAROUND = 1
            TEMPSUBTYPE = TEMPALLSUBTYPES(M-1,1)
            TEMPPRIORITY = val(TEMPALLSUBTYPES(M-1,2))
            TEMPTIM = TEMPALLSUBTYPES(M-1,3)
            TEMPALLSUBTYPES(M-1,1) = TEMPALLSUBTYPES(M,1)
            TEMPALLSUBTYPES(M-1,2) = TEMPALLSUBTYPES(M,2)
            TEMPALLSUBTYPES(M-1,3) = TEMPALLSUBTYPES(M,3)
            TEMPALLSUBTYPES(M,1) = TEMPSUBTYPE
            TEMPALLSUBTYPES(M,2) = num$(TEMPPRIORITY)
            TEMPALLSUBTYPES(M,3) = TEMPTIM
          Endif
        Endif
      Next
    Until SWAPPEDAROUND = 0
    For M = 1 To maxtab(TEMPALLSUBTYPES)
      If (TEMPALLSUBTYPES(M,1) <> "")
        FINALVALS(L,1) = TEMPALLSUBTYPES(M,1)
        FINALVALS(L,2) = TEMPALLSUBTYPES(M,2)
        FINALVALS(L,3) = TEMPALLSUBTYPES(M,3)
        L += 1
      Endif
    Next
  Next

  L = 0

  For ROW = 0 To maxtab(FINALVALS)

    If (FINALVALS(ROW,1) <> "")
      L += 1
    Endif
  Next

  For ROW = 1 To L
    Local Integer GOFURBALLS:
    ENDDATE = [0/0/0]
    STARTDATE = [0/0/0]

    Call GET_CYCLE_START_DATE_EXTRACTION(CURRENT_CTR, FINALVALS(ROW,1), LVEFILTER, STARTDATE, ENDDATE, 1, VGURLEG) From SUBHRBAL
    Filter [ACCRU] Where [ACCRU]CTR = CURRENT_CTR and [ACCRU]LVEACCLST = FINALVALS(ROW,1) Order By [ACCRU]LVEACCDAT
    Read [ACCRU] Last
    If fstat = 0
      If [ACCRU]LVEACCDAT < LVEFILTER
        GOFURBALLS = 1
      Else
        GOFURBALLS = 2
      Endif
    Else
      GOFURBALLS = 1
    Endif
    Filter [ACCRU]

    If (GOFURBALLS = 2)
      Call GET_BALANCE(CURRENT_CTR, FINALVALS(ROW,1), LVEFILTER, BALANCE, ACCRUAL, TOTALTAKENINCYCLE, 1, VGURLEG) From SUBHRBAL
    Else
      Local Char FUTBALS(250)(0..,0..10)
      Call GET_BALANCE_FCST(CURRENT_CTR, FINALVALS(ROW,3), FINALVALS(ROW,1), LVEFILTER, FUTBALS, BALANCE, ACCRUAL, TOTALTAKENINCYCLE,1,[0/0/0],[0/0/0]) From SUBHRBAL
    Endif


    Filter [HRHEA] Where [F:HRHEA]COD = FINALVALS(ROW,1)
    Read [HRHEA] First

    CYCLEUNIT = [HRHEA]CYCLENU
    CYCLELENGHT = [HRHEA]CYCLEN

    PLANNED = 0
    FUTUREPENDING = 0
    HISTORYPENDING = 0

    Filter [DCG] Where [F:DCG]CTRNUM = CURRENT_CTR and [DCG]UID > 0 and ([DCG]STA = 3 or [DCG]STA = 7 or [DCG]STA = 5) and [F:DCG]STRDAT >= LVEFILTER
    For [DCG]
      For X = 1 To dim([DCG]LVESUBTYP)
        If [DCG]LVESUBTYP(X-1) <> "" and [DCG]LVESUBTYP(X-1) = FINALVALS(ROW, 1) and [DCG]LVESUBBAL(X-1) > 0
          PLANNED += [DCG]LVESUBBAL(X-1)
        Endif
      Next
    Next
    Filter [DCG]

    Filter [DCG] Where [F:DCG]CTRNUM = CURRENT_CTR and [DCG]UID > 0 and [F:DCG]TIM = FINALVALS(ROW,3) and ([DCG]STA = 1 or [DCG]STA = 2) and [F:DCG]STRDAT  > LVEFILTER
    For [DCG]
      For X = 1 To dim([DCG]LVESUBTYP)
        If [DCG]LVESUBTYP(X-1) <> "" and [DCG]LVESUBTYP(X-1) = FINALVALS(ROW, 1) and [DCG]LVESUBBAL(X-1) > 0
          FUTUREPENDING += [DCG]LVESUBBAL(X-1)
        Endif
      Next
    Next
    Filter [DCG]

    Filter [DCG] Where [F:DCG]CTRNUM = CURRENT_CTR and [DCG]UID > 0 and [F:DCG]TIM = FINALVALS(ROW,3) and ([DCG]STA =1 or [DCG]STA = 2) and [F:DCG]STRDAT < LVEFILTER
    For [DCG]
      For X = 1 To dim([DCG]LVESUBTYP)
        If [DCG]LVESUBTYP(X-1) <> "" and [DCG]LVESUBTYP(X-1) = FINALVALS(ROW, 1) and [DCG]LVESUBBAL(X-1) > 0
          HISTORYPENDING += [DCG]LVESUBBAL(X-1)
        Endif
      Next
    Next
    Filter [DCG]

    If ENDDATE <> [0/0/0]
#      ENDDATE = ENDDATE - 1
    Else
      If STARTDATE <> [0/0/0]
        If CYCLEUNIT = 1
          ENDDATE = addmonth(STARTDATE, CYCLELENGHT*12)
        Else
          ENDDATE = addmonth(STARTDATE, CYCLELENGHT)
        Endif
        ENDDATE = ENDDATE - 1
      Endif
    Endif

    If STARTDATE <> [0/0/0]
      If STARTDATE < SENIORITYDATE
        STARTDATE = SENIORITYDATE
      Endif
    Endif

    SUBTYPEACTIVE = 0
    If (SOA_LVEACTONLY = 2)
      Call EMPLOYEE_SUB_TYPE_CHECK(CURRENT_CTR, FINALVALS(ROW,1), SUBTYPEACTIVE) From SUBHRBAL
      If STARTDATE = [0/0/0]
        SUBTYPEACTIVE = 0
      Endif
    Endif

    If (SUBTYPEACTIVE = 1 or SOA_LVEACTONLY = 1)
      #For each new nature of event a new class must be created within the contract.
      #The first iteration of the loop will see CURR_NATURE_EVENT = AVOID.ACHAR
      #Check the value of CURR_NATURE_EVENT
      If (FINALVALS(ROW,3) <> AVOID.ACHAR and CURR_NATURE_EVENT <> FINALVALS(ROW,3))
        CURR_NATURE_EVENT = FINALVALS(ROW,3)
        #First possible iteration
        #Add new collection in STRUCUTRE
        CONSLTAESS_INDEX = fmet STRUCTURE.ADDLINE("CONSLTAESS",[V]CST_ALASTPOS)
      Endif
      If CONSLTAESS_INDEX <> [V]CST_ANOTDEFINED and FINALVALS(ROW,3) <> AVOID.ACHAR
        #Add data in CONLTAESS
        STRUCTURE.CONSLTAESS(CONSLTAESS_INDEX).LVEACCTIM = FINALVALS(ROW,3)
        STRUCTURE.CONSLTAESS(CONSLTAESS_INDEX).LEG = VGURLEG
        Read [AXX1]AXX0 = "TIMCOD";"DES";STRUCTURE.ACTX.LAN;VGURLEG;FINALVALS(ROW,3)
        If fstat = [V]CST_AOK
          STRUCTURE.CONSLTAESS(CONSLTAESS_INDEX).LVETIMDESC = [F:AXX1]TEXTE

        Endif
        #Create new collection LVEACCDET
        LVEACCDET_INDEX = fmet STRUCTURE.CONSLTAESS(CONSLTAESS_INDEX).ADDLINE("LVEACCDET",[V]CST_ALASTPOS)

        #Add data in collection LVEACCDET
        If LVEACCDET_INDEX <> [V]CST_ANOTDEFINED
          STRUCTURE.CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEACCLST = FINALVALS(ROW,1)
          Read [AXX1]AXX0 = "HRLVESUBHEA";"DES";STRUCTURE.ACTX.LAN;VGURLEG;FINALVALS(ROW,1)
          If fstat = [V]CST_AOK
            STRUCTURE.CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVELSTDES = [F:AXX1]TEXTE
          Endif

          If [HRHEA]LVEDISONL = 1
            STRUCTURE.CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEENTITL = val([HRHEA]ENTCAL)
            STRUCTURE.CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEBALANC = BALANCE
          Endif
          STRUCTURE.CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVETAKCYC = TOTALTAKENINCYCLE
          If STARTDATE <> [0/0/0]
            STRUCTURE.CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).CYCSTRCAL = format$("DD2", STARTDATE)
          Endif
          If ENDDATE <> [0/0/0]
            STRUCTURE.CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEACCEXP = ENDDATE
          Endif
          STRUCTURE.CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).CYCLEN    = CYCLELENGHT
          STRUCTURE.CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).CYCLENU   = CYCLEUNIT
          STRUCTURE.CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEPLANNE = PLANNED
          STRUCTURE.CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEFUTPEN = FUTUREPENDING
          STRUCTURE.CONSLTAESS(CONSLTAESS_INDEX).LVEACCDET(LVEACCDET_INDEX).LVEHISPEN = HISTORYPENDING
        Endif
      Endif
    Endif
    Filter [DCG]
  Next
  Filter [ACCRU]
End CONSLTAESS_INDEX

######################################################################################

######################################################################################
## Section automatically added (screen CONSLTA1) 06/15/2018 07:55:01 (PEVAN)
######################################################################################
Subprog AM_REFNUM1(VALEUR)
Variable Char    VALEUR()
  If !clalev([F:CTRY]) : Local File EMPLOCTR [F:CTRY] : Endif

  Filter [F:CTRY] Where [F:CTRY]REFNUM = VALEUR
  Read [CTRY] Last
  If !fstat
    [M:HRLTA1]CTRNUM = [F:CTRY]CTRNUM
    Filter [F:CTRY]
    Call C_CTRNUM([M:HRLTA1]CTRNUM)
  Endif
End


######################################################################################

Subprog GET_CYCLE_START_DATE_EXTRACTION(VCTRNUMBER, LVESUBTYPE, FILTERINGDATE, CYCLESTARTDATE, CYCLEENDDATE,RF_IS_SOA,STR_GCURLEG)
Value Integer RF_IS_SOA
Value Char STR_GCURLEG
Value Char VCTRNUMBER
Value Char LVESUBTYPE
Value Date FILTERINGDATE
Variable Date CYCLESTARTDATE
Variable Date CYCLEENDDATE

  Local Date CTR_DATE
  Local Date CTR_DATE_PREV
  Local Date CTR_DATE_NEXT
  Local Date CTR_XITDAT
  Local Date CTR_XITDAT_NEXT

  Local Integer GRAR, NUMCTR

  Local Char CTRNUMBER(GLONHRCTR) : [L]CTRNUMBER =  VCTRNUMBER

  If dim(GCTRNUM)<0
    Global Char GCTRNUM(GLONHRCTR)
    GCTRNUM = CTRNUMBER
    Gosub POPULATE_CTRARRAY From SUBHRBAL
  Else
    If GCTRNUM <> CTRNUMBER
      If dim(GCTRARRAY)>0
        Raz GCTRARRAY
        Gosub POPULATE_CTRARRAY From SUBHRBAL
        GCTRNUM = CTRNUMBER
      Endif
    Endif
  Endif

  For GRAR = 1 To maxtab(GCTRARRAY)
    If GCTRARRAY(GRAR,1) = [0/0/0] : Break : Endif
    [L]NUMCTR += 1
    If GCTRARRAY(GRAR,1) <= FILTERINGDATE and (GCTRARRAY(GRAR,2) = [0/0/0] or GCTRARRAY(GRAR,2)>= FILTERINGDATE)
      If GCTRARRAY(GRAR,1) > [L]CTR_DATE_PREV #Will always be true in the first loop
        [L]CTR_DATE = GCTRARRAY(GRAR,1)
        [L]CTR_XITDAT = GCTRARRAY(GRAR,2)
      Endif
    Endif
  Next

  Local Char GLMCYCLESTR(250)
  Local Date GLMCYCLE,COMPDATCCHK
  Local Integer LINKED

  Call GET_LEAVE_SUB_TYPE_STR_DATE(CTRNUMBER,FILTERINGDATE,LVESUBTYPE,COMPDATCCHK,LINKED) From SUBHRBAL
  GLMCYCLE = func SUBHRBAL.GET_GLM_CYCLE(CTRNUMBER,[L]CTR_DATE)

  If (CTRNUMBER = "" | LVESUBTYPE = "" | FILTERINGDATE = [0/0/0])
    End
  Endif
  If dim(VARDAT)=0
    Local Date VARDAT
  Endif
  Local Date CCYCLDAT, CHECKD, LASTACCRUAL, ACCDAT, FILTERDATE
  Local Integer COUNTER, RCOUNTACCR
  Local Date CYCARRSTR(0..)
  Local Date CYCARREND(0..)

  If clalev([F:HRLSTHBA]) = 0: Local File HRLVESUBHEA [HRLSTHBA]: Endif
  If clalev([F:HRPEOBAL]) = 0 : Local File HRPEODET [HRPEOBAL] : Endif

  If RF_IS_SOA
    If clalev([F:HRLSTH]) = 0: Local File HRLVESUBHEA [HRLSTH]: Endif
    Read [HRLSTH]HRLST0=STR_GCURLEG;LVESUBTYPE
  Else
    If GFONCTION = "CONSLTA" | GFONCTION = "GESHRLAF" | GFONCTION = "GESDCG" | GFONCTION = "SAIWRKMAN"
      If clalev([F:HRLSTH]) = 0: Local File HRLVESUBHEA [HRLSTH]: Endif
      Read [HRLSTH]HRLST0=GCURLEG;LVESUBTYPE
    Endif
  Endif

  Filter [HRLSTHBA] Where [F:HRLSTHBA]COD = LVESUBTYPE
  Read [HRLSTHBA] First
  If parse(evalue([F:HRLSTHBA]CYCSTRCAL), 0) <> 10 & parse(evalue([F:HRLSTHBA]CYCSTRCAL), 0) <> 0

    If COMPDATCCHK<>GLMCYCLE
      VARDAT = CYCLESTARTDATE
    Else
      VARDAT = GLMCYCLE
    Endif
  Else
    VARDAT = evalue([F:HRLSTHBA]CYCSTRCAL)
  Endif
  If parse(evalue([F:HRLSTHBA]CYCSTRCAL), 0) <> 10 & parse(evalue([F:HRLSTHBA]CYCSTRCAL), 0) <> 0
    ACCDAT =GLMCYCLE
  Else
    ACCDAT = evalue([F:HRLSTHBA]CYCSTRCAL)
  Endif
  If ACCDAT=[0/0/0]
    ACCDAT=VARDAT
  Endif
  If ([TIM]COD="SSP" | [TIM]COD="SMP" | [TIM]COD="SPP")
   Filter [ACCRU] Where [ACCRU]LVEACCLST =LVESUBTYPE and [ACCRU]CTR=CTRNUMBER Order By [ACCRU]LVEACCDAT
    Read [ACCRU] Last
    Filter [ACCRU]
    CYCSTRDAT=[ACCRU]LVEACCDAT
  Endif
  Local Integer CYCLETRACE
  FILTERDATE = FILTERINGDATE
  CHECKD = FILTERINGDATE

  Gosub CYCLE_CHECK From SUBDCGGLM

  For COUNTER = 0 To maxtab(CYCARR)
    If CYCARR(COUNTER, 1) <> [0/0/0]
      If (FILTERINGDATE >= CYCARR(COUNTER, 1) and FILTERINGDATE < CYCARR(COUNTER, 2)) | (FILTERINGDATE<=CYCARR(COUNTER, 1))
        CYCLESTARTDATE = CYCARR(COUNTER, 1)
        If CYCLEENDDATE<>[0/0/0]
          CYCLEENDDATE = CYCLEENDDATE
        Else
          CYCLEENDDATE = CYCARR(COUNTER, 2)
        Endif
        Break
      Endif
    Endif
  Next

  If ([HRLSTHBA]LVEACCOPT = 1 | [HRLSTHBA]LVEACCOPT = 3 | [HRLSTHBA]LVEACCOPT = 4 | [HRLSTHBA]LVEACCOPT = 5 |[HRLSTHBA]LVEACCOPT = 2) & CYCLESTARTDATE <> [0/0/0]
    Filter [HRPEOBAL]
    Filter [HRPEOBAL] Where [HRPEOBAL]PERCOD = [HRCTR]PERCOD & [HRPEOBAL]PERSTR(1) <= CYCLEENDDATE & [HRPEOBAL]PEREND(1) >= CYCLEENDDATE
    Read [HRPEOBAL] First
      If !fstat
        CYCLEENDDATE = [HRPEOBAL]PERSTR(1) - 1
        If FILTERINGDATE > CYCLEENDDATE
          For COUNTER = 0 To maxtab(CYCARR)
            If CYCARR(COUNTER, 1) <> [0/0/0] and [HRPEOBAL]PEREND(1) >= CYCARR(COUNTER, 1) and [HRPEOBAL]PEREND(1) < CYCARR(COUNTER, 2)
              CYCLEENDDATE = CYCARR(COUNTER, 2)
              Break
            Endif
          Next
          Local Date LCYCLESTARTDATE, LCYCLEENDDATE
          LCYCLESTARTDATE = CYCLESTARTDATE
          LCYCLEENDDATE = CYCLEENDDATE
          Call GET_EXTRACTION_START_DATE(CTRNUMBER, FILTERINGDATE, LCYCLESTARTDATE, LCYCLEENDDATE, CYCLESTARTDATE, CYCLEENDDATE) From SUBHRBAL
        Endif
      Endif
    Filter [HRPEOBAL]
  Else
    If CYCLEENDDATE <> [0/0/0]
      CYCLEENDDATE = CYCLEENDDATE - 1
    Endif
  Endif

  If [L]NUMCTR > 1 #Multi Contract Same Chrono exists
    For GRAR = 1 To maxtab(GCTRARRAY)
      If GCTRARRAY(GRAR,1) = [0/0/0] : Break : Endif
      If ([L]CTR_DATE_PREV = [0/0/0] | GCTRARRAY(GRAR,1) > [L]CTR_DATE_PREV | (GCTRARRAY(GRAR,1) < [L]CTR_DATE_PREV & GCTRARRAY(GRAR,1) > CYCLESTARTDATE)) and GCTRARRAY(GRAR,1) < [L]CTR_DATE
        [L]CTR_DATE_PREV = GCTRARRAY(GRAR,1)
      Endif
      If ([L]CTR_DATE_NEXT = [0/0/0] | GCTRARRAY(GRAR,1) < [L]CTR_DATE_NEXT | (GCTRARRAY(GRAR,1) > [L]CTR_DATE_NEXT & GCTRARRAY(GRAR,1) < CYCLEENDDATE)) and GCTRARRAY(GRAR,1) > [L]CTR_DATE
        [L]CTR_DATE_NEXT = GCTRARRAY(GRAR,1)
        [L]CTR_XITDAT_NEXT = GCTRARRAY(GRAR,2)
      Endif
    Next

    Filter [ACCRU] Where [ACCRU]LVEACCLST=LVESUBTYPE and [ACCRU]CTR=CTRNUMBER and [ACCRU]CTRDAT=[L]CTR_DATE_PREV and [ACCRU]LVEACCTYP = 'Linking'
    If rowcount([ACCRU]) >= 1 #Previous contract was also linked to this sub type
      If [L]CTR_DATE_PREV < CYCLESTARTDATE
        If parse(evalue([F:HRLSTHBA]CYCSTRCAL), 0) <> 10 & parse(evalue([F:HRLSTHBA]CYCSTRCAL), 0) <> 0
          If [L]CTR_DATE_PREV < evalue([F:HRLSTHBA]CYCSTRCAL)
            CYCLESTARTDATE = evalue([F:HRLSTHBA]CYCSTRCAL)
          Else
            CYCLESTARTDATE = [L]CTR_DATE_PREV
          Endif
        Endif
      Endif
    Else
      If COMPDATCCHK>CYCLESTARTDATE
       CYCLESTARTDATE = COMPDATCCHK
      Endif
    Endif
    Filter [ACCRU]

    Filter [ACCRU] Where [ACCRU]LVEACCLST=LVESUBTYPE and [ACCRU]CTR=CTRNUMBER and [ACCRU]CTRDAT=[L]CTR_DATE_NEXT and [ACCRU]LVEACCTYP = 'Linking'
    If rowcount([ACCRU]) >= 1 #Next contract is also linked to this sub type
      If [L]CTR_XITDAT_NEXT<> [0/0/0] and [L]CTR_XITDAT_NEXT < [L]CYCLEENDDATE
        [L]CYCLEENDDATE = [L]CTR_XITDAT_NEXT
      Endif
    Elsif [L]CTR_XITDAT <> [0/0/0] and [L]CTR_XITDAT < CYCLEENDDATE
      CYCLEENDDATE = [L]CTR_XITDAT
    Endif
    Filter [ACCRU]
  Else
    #NOT multiple contracts same chrono
    If COMPDATCCHK>CYCLESTARTDATE
     CYCLESTARTDATE = COMPDATCCHK
    Endif
    If [L]CTR_XITDAT <> [0/0/0] and [L]CTR_XITDAT < CYCLEENDDATE
      CYCLEENDDATE = [L]CTR_XITDAT
    Endif
  Endif

  Filter [HRLSTHBA]
End


#FRLAA X3-112532 2018-10-15 START
$GET_ESSLTA_TOTALS
#Variables declared in ESSHRLTA

Return

$SET_ESSLTA_TOTALS
