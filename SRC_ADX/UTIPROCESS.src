#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################
# UTIPROCESS          Utilitaire installation  process                   #
#                                                                        #
# ---------------------------------------------------------------------- #
# Initialisation des nouvelles zones a partir des anciennes valeurs      #
##########################################################################

Call MAJ_UTIPROCESS
End


Subprog MAJ_UTIPROCESS
Local Char DOSSIER(30) : DOSSIER=nomap
Call OUVRE_TRACE("UTIPROCESS: New Process function setup") From LECFIC
Call TEMPON("O") From GESECRAN
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>"" Call EXE_UTIPROCESS(DOSSIER) : Endif
Call FERME_TRACE From LECFIC
Call TEMPOFF     From GESECRAN
Call LEC_TRACE From LECFIC
End

Subprog EXE_UTIPROCESS(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTIPROCESS: Process Start on : "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:BOD])  =0  Local File =DOSSIER+".BOMD"       [BOD] : Endif
If clalev([F:ITM])  =0  Local File =DOSSIER+".ITMMASTER"  [ITM] : Endif

Local Integer NBBOD : NBBOD = 0

Call DEBTRANS From GLOCK
Trbegin [BOD]

For [BOD]
    GOK = 1  
    Readlock [BOD]BOD0 Curr
    If fstat
        Call ECR_TRACE("File BOMD, Error ="-num$(fstat),1) From GESECRAN
    Else
        If [F:BOD]BOMUOM=""
            Read [ITM]ITM0=[F:BOD]CPNITMREF
            If fstat
                Call ECR_TRACE("File ITMMASTER"-[F:BOD]CPNITMREF-", Error ="-num$(fstat),1) From GESECRAN    # 03.06 35443
            Else
                [F:BOD]BOMUOM = [F:ITM]STU
                [F:BOD]BOMSTUCOE =1
                [F:BOD]BOMQTY = [F:BOD]LIKQTY 
                NBBOD += 1    
            Endif
            Rewrite [BOD]  
        Endif
    Endif
Next
Commit
Filter [BOD]
Close Local File [BOD]
Close Local File [ITM]

Call ECR_TRACE("UTIPROCESS : "+num$(NBBOD)+" records processed",0) From GESECRAN
End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(8) <> 2 : End : Endif
Call EXE_UTIPROCESS(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
 
# Module 8 = Tronc commun
If [F:ADS]MODULE(8) <> 2 : End : Endif
Call EXE_UTIPROCESS(APPLI)
End
