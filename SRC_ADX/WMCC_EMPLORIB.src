#<AdxTL>@(#)0.0.0.0 $Revision$Class Bank ID statement
# Supervisor
## CRUD-CLASSE ## EMPLORIB
# 2018-11-06 07:06:26 493


############################################################################################
### Subprog _AINSERT
############################################################################################
Subprog _AINSERT(EMPLORIB,ASTATUS)
Variable Instance EMPLORIB Using C_EMPLORIB
Variable Integer ASTATUS

If EMPLORIB = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLORIB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_EMPLORIB

End

#-----------------------------------------------------#

############################################################################################
### Subprog AINSERT
############################################################################################
Subprog AINSERT(EMPLORIB,ASTATUS)
Variable Instance EMPLORIB Using C_EMPLORIB
Variable Integer ASTATUS

If EMPLORIB = null : End : Endif

Gosub AVARIABLES From WMC00EMPLORIB
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

If !adxlog
 Gosub AINSERT_TR_EMPLORIB
Else
 Gosub AINSERT_EMPLORIB
Endif

Gosub _AINSERT_AFTER
[L]A_I = EMPLORIB.freeSnapshot
EMPLORIB.snapshotEnabled = 1
$AINSERT_END
End

#-----------------------------------------------------#

$AINSERT_CONTROL
Gosub _AINSERT_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLORIB._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLORIB._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLORIB._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AINSERT_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_BEFORE
If EMPLORIB.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLORIB.ASTALIN = [V]CST_ANEW
[L]ASTATUS = max([L]ASTATUS,fmet EMPLORIB.ACTION("AINSERT_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet EMPLORIB.ACTION("AINSERT_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_TR_EMPLORIB
Trbegin [F:RIB]
 Gosub AINSERT_EMPLORIB
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AINSERT_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AINSERT_EMPLORIB
Raz [F:RIB]
[L]ASTATUS = max([L]ASTATUS,fmet EMPLORIB.ACTION("AINSERT_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLORIB._MAJSQL_EMPLORIB(EMPLORIB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EMPLORIB.ACTION("AINSERT_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_ABORT
Rollback
$_AINSERT_ABORT
If EMPLORIB.snapshotEnabled=1
 [L]A_RETIK = EMPLORIB.revertUpdTick
Endif
[L]ASTATUS = max(fmet EMPLORIB.ACTION("AINSERT_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AINSERT_AFTER
If find(EMPLORIB.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EMPLORIB.ASTALIN = [V]CST_ALL
Endif
Return



