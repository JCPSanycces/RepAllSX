#######################################################################
# Transcoding caracters utf8 -> ascii (bank file)
#######################################################################
Subprog TRANS(STRING)
Variable Char STRING
Local Char UTF8_CAR(255)
Local Char ASCII_CAR(255)
UTF8_CAR   = "ĄĆĘŁŃÓŚŹŻąćęłńóśźż"
ASCII_CAR  = chr$(164)+chr$(143)+chr$(168)+chr$(157)+chr$(227)+chr$(224)+chr$(151)+chr$(141)
ASCII_CAR += chr$(189)+chr$(165)+chr$(134)+chr$(169)+chr$(136)+chr$(228)+chr$(162)+chr$(152)
ASCII_CAR += chr$(171)+chr$(190)
STRING = ctrans(STRING,UTF8_CAR,ASCII_CAR)
End


