#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog TVA(TVA,SPSTAT)
Value Char TVA()
Variable Integer SPSTAT


Local Char NIP_ENTRY(15),NIP(15),NIP_C(1) : NIP = ""
Local Integer NIP_LENGTH: NIP_LENGTH = 0
Local Char NIP_COMMENT(255)
Local Integer NIP_OK: NIP_OK = 0
Local Integer NIP_CHECKSUM : NIP_CHECKSUM = 0
Local Integer NIP_POL_LENGTH : NIP_POL_LENGTH = 10
Local Integer NIP_W(NIP_POL_LENGTH)

Local Integer A

NIP_ENTRY = TVA
NIP_LENGTH = len(NIP_ENTRY)
NIP_W(1)=6 : NIP_W(2)=5 : NIP_W(3)=7 : NIP_W(4)=2 : NIP_W(5)=3 
NIP_W(6)=4 : NIP_W(7)=5 : NIP_W(8)=6 : NIP_W(9)=7

SPSTAT=0

For A=1 To NIP_LENGTH
 NIP_C = mid$(NIP_ENTRY,A,1)

 Case NIP_C
  When "1","2","3","4","5","6","7","8","9","0" : NIP_OK = 0 :  NIP += NIP_C
  When "-" : NIP_OK=0
  When Default : NIP_OK = 1
 Endcase
Next

 If NIP_OK = 1
#  NIP_COMMENT = "Unavalaible char(s) in NIP field" : Call ECR_TRACE(NIP_COMMENT, 0) From GESECRAN 
  SPSTAT=1
 Endif

If len(NIP) <> NIP_POL_LENGTH
# NIP_COMMENT = "Wrong length of NIP. It should be "+num$(NIP_POL_LENGTH) + " chars" : Call ECR_TRACE(NIP_COMMENT, 0) From GESECRAN 
 SPSTAT=1
Endif

If len(NIP) > 0 & SPSTAT=0
For A=1 To len(NIP)-1
 NIP_CHECKSUM += val(mid$(NIP,A,1))*NIP_W(A)
Next
Endif

If SPSTAT = 0
 If mod(NIP_CHECKSUM,11) <> val(mid$(NIP,NIP_POL_LENGTH,1))
  SPSTAT=1 # When ID IS not VALID
 Endif
Endif

End
