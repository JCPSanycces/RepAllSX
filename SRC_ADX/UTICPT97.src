#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTICPT97 - VNEXT   UTI process                                    Module CPT   #
#            correction utility
#
# Issue X3-83028 - 2018-05-18 by CBO : Add a parameter to modify or not purchase order
#
##########################################################################


Local Char WDOSSIER(30) : WDOSSIER = nomap
  Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

  If WDOSSIER <> ""
    If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
    If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTICPT97(WDOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif

  Close Local File

End

##########################################################################
Subprog MAJ_UTICPT97(DOSSIER)
Value Char DOSSIER()

  If (func DOSSUB.ISHISTFOLD(DOSSIER))
    Call ECR_TRACE("UTICPT97 : Not to perform on archive folder : " + DOSSIER, 0) From GESECRAN
    End
  Endif

  Call ECR_TRACE("UTICPT97 : Start of process on : " + DOSSIER, 0) From GESECRAN

  #----- Ouverture des fichiers -----#
  If clalev([F:ADW])  =0  Local File =DOSSIER+".ADOVAL"   [ADW] : Endif

  Call DEBTRANS From GLOCK

  Trbegin [ADW]
  Read [ADW]ADW1="CMMPERCTL";"" ;""
  If fstat
    Raz [ADW]
    [F:ADW]CMP = ""
    [F:ADW]FCY = ""
    [F:ADW]PARAM = "CMMPERCTL"
    [F:ADW]VALEUR = "1" # No
    Write [F:ADW]
  Endif

  If !fstat
    Call ECR_TRACE("Write of default value parameter CMMPERCTL - OK  " + DOSSIER, 0) From GESECRAN
  Else
    Call ECR_TRACE("Write of default value parameter CMMPERCTL - Not OK  " + DOSSIER, 1) From GESECRAN
  Endif

  Commit

  Close Local File [ADW]

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI()

  If APPLI = GDOSX3
    End
  Endif

  If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif

  If [F:ADS]MODULE(2) <> 2 : End : Endif                                 : # 2 module compta

  Call MAJ_UTICPT97(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI()

  If APPLI = GDOSX3
    End
  Endif

  If [F:ADS]MODULE(2) <> 2 : End : Endif                                 : # 2 module compta

  Call MAJ_UTICPT97(APPLI)
End

