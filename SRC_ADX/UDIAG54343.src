##################################################################################
# UDIAG54343 01/12/2009 FQ54343
#                                                                      
# MWA - Diagnostic de retraitement nécessaire avant passage du patch
#       contenant la maintenance relative à la fiche FQ5349477
#
#
#   Liste des conditions nécessitant un retraitement des données
#   
#   1°) Des biens d'une même concession appartiennent à plus d'un site financier.
#       
#
##################################################################################
 
 # Passage en test
 Call OUVRE_TRACE("UDIAG: 54343 Diagnostic") From LECFIC
 Call DIAG
 Call LEC_TRACE() From LECFIC

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog DIAG

  Local Char    LAPPLI
  Local Integer BERROR

  BERROR = 0

  # A executer depuis le dossier racine.
  If ( nomap <> GDOSX3 ) Then
    Call ECR_TRACE("UDIAG: Conncession diagnostic must be run from the root folder ",1) From GESECRAN    
    End
  Endif

  # Ouverture des dossiers
  If !clalev([F:ADS])  : Local File =nomap+".ADOSSIER" [ADS]  : Endif

  #>>>>>>>
  For [ADS]

    LAPPLI = [F:ADS]DOSSIER
    If filinfo(filpath("FIL","FACILITY"  ,"fde",LAPPLI),0)<=0 or
&      filinfo(filpath("FIL","FXDASSETS" ,"fde",LAPPLI),0)<=0 
       # Tables n'existent pas 
    Else

      #-----
      Call ECR_TRACE("UDIAG: Diagnostic for Folder "+LAPPLI,0) From GESECRAN

      If !clalev([F:CCN])  : Local File =LAPPLI+".CONCESSION" [CCN]  : Endif
      If !clalev([F:FAS])  : Local File =LAPPLI+".FXDASSETS"  [FAS]  : Endif

      Gosub DIAG_DOSSIER

      If clalev([CCN]) : Close File [CCN] : Endif
      If clalev([FAS]) : Close File [FAS] : Endif
    Endif
    
  Next
  #<<<<<<<<

  If (BERROR) Then
    Call ECR_TRACE("UDIAG: !!!!! Fixed assets in different facilities       !!!!!",1) From GESECRAN
    Call ECR_TRACE("UDIAG: !!!!! for the same concession  has been detected !!!!!",1) From GESECRAN
    Call ECR_TRACE("UDIAG: !!!!! Please read carefully the Product News     !!!!!",1) From GESECRAN
    Call ECR_TRACE("UDIAG: !!!!! Before performing the PATCH                !!!!!",1) From GESECRAN
  Else
    Call ECR_TRACE("UDIAG: !!!!! Patch can be performed. !!!!! ",0) From GESECRAN
  Endif
  
End

########################################################################


#===============================
$DIAG_DOSSIER

  Local Integer BFIRST
  Local Char    LFCY(GLONFCY)

  # >>>>>>>>>>>>>>>>
  For [CCN] 
    BFIRST = 1
    LFCY   = ""
    Call ECR_TRACE("UDIAG - Concession"-[F:CCN]CCNREF - "Company"- [F:CCN]CPY , 0) From GESECRAN
    For [FAS]FAS1 Where CPY=[F:CCN]CPY and CCNREF = [F:CCN]CCNREF
      If (BFIRST) Then
        BFIRST = 0
        LFCY   = [F:FAS]FCY
        Call ECR_TRACE("DIAG - "-"Facility"-[F:FAS]FCY, 0) From GESECRAN
      Else
        If ( [F:FAS]FCY <> LFCY ) Then
          Call ECR_TRACE("UDIAG - "-" !!!!! More than one facility for the concession : Facility 2 is" - [F:FAS]FCY, 1) From GESECRAN
          BERROR = 1
          Break  
        Endif   
      Endif
    Next
  Next
  # <<<<<<<<<<<<<<<<<
 

Return
#######################################################################



