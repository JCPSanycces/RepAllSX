#<AdxTL>@(#)0.0.0.0 $Revision$ 
############################################################################
#          List for Control DPO in company
# can be executed in batch mode
###########################################################################
# ALISTDPOCPY
# ----------------------------------------------------------------------- #
# Action  : ADPOCPY
# Screen  : ALISTDPOCPY  [ALDPO]
# Windows : ALISTDPOCPY
#################################################################################
End
#################################################################################
#----------------------------------------------------------------------#
# ACTIONS standard process (GTRAITE)                         #
#----------------------------------------------------------------------#

$ACTION
  Case ACTION
    When "OUVRE_BATCH"  : Gosub INIT
    When "INIT"         : Gosub INIT
    When "INIT_DIA"     : Gosub INIT_DIA
    When "CONTROLE"     : Gosub CONTROLE
    When "EXEC"         : Gosub EXEC
    When "TERMINE"      : Gosub TERMINE
  Endcase

Return

#################################################################################
$INIT
  #--------- variables declaration
  Local Integer WEECFLG
  Local Char WCRY
  Local Char WMESSAGE(GDIMFIC)
  Local Char WCRYNAME(GDIMFIC)
  Local Char WDOSSIER(GDIMFIC)

  Local Char WCNTNAME1(GDIMFIC)
  Local Char WCNTNAME2(GDIMFIC)
  Local Integer WNBDPO
  # if geode set 1 else set 2
  Local Integer WCASE_CONTACT

  #
  Local Integer WSAVIUM
  Local Char    WSAVIFS(10) , WSAVIRS(5)
  #--------- initialisations
  [L]WSAVIFS= adxifs
  [L]WSAVIRS= adxirs
  [L]WSAVIUM= adxium

  WDOSSIER = nomap
  #  open files

  Local File =WDOSSIER+".COMPANY"     [ZCPY]
  Local File =WDOSSIER+".TABCOUNTRY"  [ZTCY]

  # caution contact and contactcrm are not available for geode
  # to test the existance of those files
  # contatc for x3 or x3 people - contatc2 for geode
  If filinfo(filpath("FIL","CONTACT","fde",WDOSSIER),0)<=0
      If filinfo(filpath("FIL","CONTACT2","fde",WDOSSIER),0)<=0
            Call  MESSAGE(mess(27,150,1)) From GESECRAN
            FIN= 1
      Else
            Local File =WDOSSIER+".CONTACT2"     [ZCNT]
            WCASE_CONTACT = 1
      Endif
  Elsif filinfo(filpath("FIL","CONTACTCRM","fde",WDOSSIER),0)<=0
      If filinfo(filpath("FIL","CONTACT2","fde",WDOSSIER),0)<=0
            Call  MESSAGE(mess(27,150,1)) From GESECRAN
            FIN= 1
      Else
            Local File =WDOSSIER+".CONTACT2"     [ZCNT]
            WCASE_CONTACT = 1
      Endif
  Else
      Local File =WDOSSIER+".CONTACT"     [ZCNT]
      Local File =WDOSSIER+".CONTACTCRM"  [ZAIN]
      WCASE_CONTACT = 2
  Endif

Return

#################################################################################
$INIT_DIA
    Raz [M:ALDPO]
    # at the moment this field is not used , only in hidden mode
    [M:ALDPO]CHECK = 2
Return

#################################################################################
$TERMINE
    adxifs =[L]WSAVIFS
    adxirs =[L]WSAVIRS
    adxium =[L]WSAVIUM
Return

#################################################################################
$CONTROLE
  Raz GMESSAGE
  If [M:ALDPO]CHECK <> 2
          FIN=1
  Endif
Return

#################################################################################
$EXEC
If !GSERVEUR
    Call OUVRE_TRACE(mess(12,155,1)) From LECFIC
Endif

#Call   ECR_TRACE("List of company in folder : "+WDOSSIER,0) From GESECRAN
Call   ECR_TRACE(mess(5,155,1)-WDOSSIER,0) From GESECRAN
Call   ECR_TRACE("===================================================",0) From GESECRAN

Link [F:ZCPY] With [F:ZTCY]TCY0~=[F:ZCPY]CRY  As [ZLIS]  Order By [F:ZTCY]EECFLG;[F:ZCPY]CRY;[F:ZCPY]CPY

WEECFLG = 0

For [ZLIS]
    If WEECFLG <> [F:ZTCY]EECFLG
        WEECFLG = [F:ZTCY]EECFLG
        Raz WCRY
        If WEECFLG <> 2
            Call ECR_TRACE(" ",0) From GESECRAN
            #"Companies within europe  "
            Call ECR_TRACE(mess(2,155,1),0) From GESECRAN
        Else
            Call ECR_TRACE(" ",0) From GESECRAN
            #"Companies in europe  "
            Call ECR_TRACE(mess(3,155,1),0) From GESECRAN
        Endif
    Endif
    If WCRY <> [F:ZCPY]CRY
        WCRY = [F:ZCPY]CRY
        Raz WCRYNAME
        Call LECTEXTRA(WCRYNAME,"TABCOUNTRY","CRYDES",WCRY,"") From ATEXTRA
        Call ECR_TRACE(" ",0) From GESECRAN
       # Call ECR_TRACE(format$ ("K:5X", " ")+"Country :"-WCRY-WCRYNAME,0) From GESECRAN
        Call ECR_TRACE(format$ ("K:5X", " ")+mess(4,155,1)-WCRY-WCRYNAME,0) From GESECRAN
        #Call ECR_TRACE(format$ ("K:10X", " ")+"Company code    Company name     Data protection officer",0) From GESECRAN
        Call ECR_TRACE(format$ ("K:10X", " ")+format$ ("K:36X",mess(6,155,1)+"  "+mess(7,155,1))+format$ ("K:1X"," ")+mess(8,155,1),0) From GESECRAN
        Call ECR_TRACE(format$ ("K:10X", " ")+"========================================================",0) From GESECRAN
    Endif

    Raz WCNTNAME1
    Raz WCNTNAME2
    WNBDPO = 0
    Raz WMESSAGE
    #
    WMESSAGE = format$ ("K:10X", " ")+format$ ("K:5X",num$([F:ZCPY]CPY))+format$ ("K:1X", " ")+format$ ("K:30X",num$([F:ZCPY]CPYNAM))
    # case x3 or x3 people
    If WCASE_CONTACT = 2
        Filter [ZCNT] Where BPATYP=2 and BPANUM=[F:ZCPY]CPY
        If rowcount([ZCNT]) = 0
            WNBDPO = 0
        Else
            WNBDPO = 0
            For [ZCNT]
                Read [ZAIN]AIN0 = [F:ZCNT]CCNCRM
                If fstat = 0
                      If [F:ZCNT]DPO = 2
                         WNBDPO+=1
                         If WNBDPO = 1
                            WCNTNAME1 = [F:ZAIN]CNTLNA
                            WCNTNAME2 = [F:ZAIN]CNTFNA
                         Endif
                      Endif
                 Else
                      If [F:ZCNT]DPO = 2
                         WNBDPO+=1
                         If WNBDPO = 1
                            WCNTNAME1 = num$([F:ZCNT]CCNCRM)
                            #"name not found!"
                            WCNTNAME2 = mess(9,155,1)
                         Endif
                      Endif
                 Endif
             Next
        Endif
        Filter [ZCNT]
    Elsif WCASE_CONTACT = 1
        Filter [ZCNT] Where CNTTYP=7 and CNTNUM=[F:ZCPY]CPY
        If rowcount([ZCNT]) = 0
            WNBDPO = 0
        Else
            WNBDPO = 0
            For [ZCNT]
                If [F:ZCNT]DPO = 2
                         WNBDPO+=1
                         If WNBDPO = 1
                            WCNTNAME1 = [F:ZCNT]CNTLNA
                            WCNTNAME2 = [F:ZCNT]CNTFNA
                         Endif
                 Endif
             Next
        Endif
        Filter [ZCNT]
    Else
        WNBDPO = 0
    Endif

    If WNBDPO =1
        WMESSAGE +=format$ ("K:1X", " ")+format$ ("K:60X",WCNTNAME1-WCNTNAME2)
    Elsif WNBDPO = 0
       #(none)
        WMESSAGE +=format$ ("K:1X", " ")+format$ ("K:60X",mess(10,155,1))
    Else
     #"(error more than one???)"
        WMESSAGE +=format$ ("K:1X", " ")+format$ ("K:60X",mess(11,155,1))
    Endif
    Call ECR_TRACE(WMESSAGE,0) From GESECRAN
Next

Call ECR_TRACE(" ",0) From GESECRAN

$FINEXE
If !GSERVEUR
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Endif
Return




