#If fstat : Filter [VEP] : Filter [CTR] : Return : Endif
#If fstat : Filter [VEP] : Filter [HRCTR] : Return : Endif
If rowcount([F:VEP])<=0 : Filter [VEP] : Filter [HRCTR] : Return : Endif
#JAVAN - 2018-08-23 - X3-105321 - END
#ADNGO - 2017-07-10 - X3-11712 - END
#FRLAA - 2015-07-01 - REQUIREMENT 104631 US 3687 - END

#FRLAA - 2015-06-05 - REQUIREMENT 104631 US 3688 - START
nolign = 0
For [VEP]VEP0
  #ADNGO - 2017-07-10 - X3-11712 - START
  #Filter [HSP] Where CTRNUM = [F:CTR]CTRNUM & EMP = [F:CTR]REFNUM & BUL = [F:VEP]BUL & (TYP = 6 & RUB =  "EQUITY_MTD") Order By Key  HSP0 = DAT Desc#= DAT Desc
  Filter [HSP] Where CTRNUM = [F:HRCTR]CTRNUM & EMP = [F:HRCTR]REFNUM & BUL = [F:VEP]BUL & (TYP = 6 & RUB =  "EQUITY_MTD") Order By Key  HSP0 = DAT Desc#= DAT Desc
  #ADNGO - 2017-07-10 - X3-11712 - END
  For [F:HSP]HSP0
    nolign += 1
    [M:HRAC2] = [F:HSP]
    If nolign = dim([M:HRAC2]DAT) : Break : Endif
  Next
Next
Assign "[M:HRAC2]LIGNUM" With nolign
Filter [HSP]

nolign = 0
For [VEP]VEP0
  #ADNGO - 2017-07-10 - X3-11712 - START
  #Filter [HSP] Where CTRNUM = [F:CTR]CTRNUM & EMP = [F:CTR]REFNUM & BUL = [F:VEP]BUL  & AMT > 0 & TYP = 1 & RUB =  "EQ_REM" Order By Key  HSP0 = DAT Desc #= DAT Desc
  Filter [HSP] Where CTRNUM = [F:HRCTR]CTRNUM & EMP = [F:HRCTR]REFNUM & BUL = [F:VEP]BUL  & AMT > 0 & TYP = 1 & RUB =  "EQ_REM" Order By Key  HSP0 = DAT Desc #= DAT Desc
  #ADNGO - 2017-07-10 - X3-11712 - END
  For [F:HSP]HSP0
    nolign += 1
    [M:HRAC2]DATREM(nolign-1) = [F:HSP]DAT
    [M:HRAC2]AMTREM(nolign-1) = [F:HSP]AMT
    If nolign = dim([M:HRAC2]DATREM) : Break : Endif
  Next
Next
Assign "[M:HRAC2]LIGNUMREM" With nolign
Filter [HSP]


nolign = 0
For [VEP]VEP0
  #ADNGO - 2017-07-10 - X3-11712 - START
  #Filter [HSP] Where CTRNUM = [F:CTR]CTRNUM & EMP = [F:CTR]REFNUM & BUL = [F:VEP]BUL & TYP = 6 & RUB =  "EQUITY_REM" Order By Key  HSP0 = DAT Desc #= DAT Desc
  Filter [HSP] Where CTRNUM = [F:HRCTR]CTRNUM & EMP = [F:HRCTR]REFNUM & BUL = [F:VEP]BUL & TYP = 6 & RUB =  "EQUITY_REM" Order By Key  HSP0 = DAT Desc #= DAT Desc
  #ADNGO - 2017-07-10 - X3-11712 - END
  For [F:HSP]HSP0
    nolign += 1
    [M:HRAC2]DATTOT(nolign-1) = [F:HSP]DAT
    [M:HRAC2]AMTTOT(nolign-1) = [F:HSP]AMT
    If nolign = dim([M:HRAC2]DATTOT) : Break : Endif
  Next
Next
Assign "[M:HRAC2]LIGNUMTOT" With nolign
Filter [HSP]
#ADNGO - 2017-07-10 - X3-11712 - START
#Filter [CTR]
Filter [HRCTR]
#ADNGO - 2017-07-10 - X3-11712 - END
Filter [HRAFRCL]
#JAVAN - 2018-08-23 - X3-105321 - START
Filter [VEP]
#JAVAN - 2018-08-23 - X3-105321 - END

Affzo [M:HRAC0]
Affzo [M:HRAC1]

Return

$CHARGE
  MA=5
  Gosub SETMASK From =WINPROG
  [M:HRAC1] = [F:HRAFRCL]
Return
#LIMAS - 2017-08-21 - X3-52772 - START
$CLE_GAUCHE
  FILTSUP = "FLGVAR <> 2 & FLGRET<>2"
Return
#LIMAS - 2017-08-21 - X3-52772 - END
$STYLE
Local Integer I
For I = 1 To [M:HRAC1]LIGNUM
  If [M:HRAC1]CRETYP(I-1) = "A"
    Diszo [M:HRAC1]PYRMON(I-1)
  Else
    Actzo [M:HRAC1]PYRMON(I)
  Endif
Next

Return

$VERIF_MOD
  #Check that there is a comment for each changed or newly created record
  Local Integer J : J = 0
  Local Integer ADDCNT
  For [L]ADDCNT=0 To [M:HRAC1]LIGNUM-1
    J = 0
    If [M:HRAC1]PYRMON(ADDCNT) <> [00/00/0000]
      Filter [HRAFRCL] Where REFNUM = [M:HRAC0]REFNUM & CTRNUM = [M:HRAC0]CTRNUM & CTRDAT = [M:HRAC0]CTRDAT & PYRMON = [M:HRAC1]PYRMON(ADDCNT)
      Read [HRAFRCL] First
#JASMI - 2017-06-06 - START
Filter [HRAFRCL]
#JASMI - 2017-06-06 - END
      If !fstat
        #Check for changes on all fields
        If [F:HRAFRCL]PYRMON      <>    [M:HRAC1]PYRMON(ADDCNT)     : J+=1        : Endif
        If [F:HRAFRCL]FCY         <>    [M:HRAC1]FCY(ADDCNT)        : J+=1        : Endif
        If [F:HRAFRCL]CPY         <>    [M:HRAC1]CPY(ADDCNT)        : J+=1        : Endif
        If [F:HRAFRCL]OCPLEV      <>    [M:HRAC1]OCPLEV(ADDCNT)     : J+=1        : Endif
        If [F:HRAFRCL]OFOCOD      <>    [M:HRAC1]OFOCOD(ADDCNT)     : J+=1        : Endif
        If [F:HRAFRCL]EQUEMPTYP   <>    [M:HRAC1]EQUEMPTYP(ADDCNT)  : J+=1        : Endif
        If [F:HRAFRCL]OCPBEFVAL   <>    [M:HRAC1]OCPBEFVAL(ADDCNT)  : J+=1        : Endif
        If [F:HRAFRCL]OCPAFTVAL   <>    [M:HRAC1]OCPAFTVAL(ADDCNT)  : J+=1        : Endif
        If [F:HRAFRCL]RCEGRP      <>    [M:HRAC1]RCEGRP(ADDCNT)     : J+=1        : Endif
        If [F:HRAFRCL]SEX         <>    [M:HRAC1]SEX(ADDCNT)        : J+=1        : Endif
        If [F:HRAFRCL]PRV         <>    [M:HRAC1]PRV(ADDCNT)        : J+=1        : Endif
        If [F:HRAFRCL]STG         <>    [M:HRAC1]STG(ADDCNT)        : J+=1        : Endif
        If [F:HRAFRCL]HDCFLG      <>    [M:HRAC1]HDCFLG(ADDCNT)     : J+=1        : Endif

        If J > 0
          #Found change - check comments
            If [M:HRAC1]CHGCMT(ADDCNT) = ""
              GERR = 2 : GMESSAGE = mess(00025,00145,1) + " on line " + num$([L]ADDCNT+1) : mkstat = 2 : OK = 0 : Return
            Endif
        Endif
      Else
        #New manually entered record
        #Check that comment field is completed for the current record
        If [M:HRAC1]CHGCMT(ADDCNT) = ""
          GERR = 2 : GMESSAGE = mess(00025,00145,1) + " on line " + num$([L]ADDCNT+1) : mkstat = 2 : OK = 0 : Return
        Endif
      Endif
    Endif
  Next
Return

$CREATION
$MODIF
#FRLAA - 2015-07-07 - REQUIREMENT 104631 US 3777 - START
Local Integer ADDCNT
Filter [F:HRAFRCL]
Delete [F:HRAFRCL] Where [F:HRAFRCL]REFNUM=[M:HRAC0]REFNUM & [F:HRAFRCL]CTRNUM=[M:HRAC0]CTRNUM & [F:HRAFRCL]CTRDAT=[M:HRAC0]CTRDAT
If fstat=1 | fstat>5
  GOK=0 : Call RSTA("HRAFRCL",[M:HRAC0]REFNUM) From GLOCK : Return
Endif

If dim([F:HRAFRCL]REFNUM)> 0
Filter [F:HRAFRCL]
Delete [F:HRAFRCL] Where [F:HRAFRCL]REFNUM=[M:HRAC0]REFNUM & [F:HRAFRCL]CTRNUM=[M:HRAC0]CTRNUM & [F:HRAFRCL]CTRDAT=[M:HRAC0]CTRDAT
If fstat=1 | fstat>5
  GOK=0 : Call RSTA("HRAFRCL",[M:HRAC0]REFNUM) From GLOCK : Return
Endif
Endif

For nolign = 1 To [M:HRAC1]LIGNUM
  Raz [F:HRAFRCL]
  [F:HRAFRCL] = [M:HRAC0]
  [F:HRAFRCL] = [M:HRAC1]
  Write [F:HRAFRCL]
  If fstat
    GOK=0 : Call FSTA("HRAFRCL") From GLOCK : Break
  Endif
Next

Return

$MODIF_EMP
Local Integer J : J = 0
Local Char FRMTAB(10)
Local Char FRMSCR(10)
Local Char TBLCPY(10)
Local Integer BEFVAL(4)
Local Integer AFTVAL(4)
Local Integer READOK(1) : READOK = 0
Local Integer ADDCNT
Local Integer ADDCNTTBL
Local Char SATPRV(35)
Local Integer YESNO
#ADNGO - 2017-07-10 - X3-11712 - START
#If (func AFNC.ACTIV("KFR")>0 & func AFNC.ACTIV("KPO")>0) : Return : Endif
#If func AFNC.ACTIV("KZA")=0 : Return : Endif # For RSA only for now, will revisit for other countries when needed.
If (func DIVPAYE.IS_KFR_LEG(GCURLEG) & func DIVPAYE.IS_KPO_LEG(GCURLEG)) : Return : Endif
If !func DIVPAYE.IS_KZA(GCURLEG) : Return : Endif
#ADNGO - 2017-07-10 - X3-11712 - END
#Checking for possible changes
If clalev([F:ID])=0    : Local File EMPLOID         [ID]     : Endif
Filter [ID] Where REFNUM = [M:EMP0]REFNUM
Read [ID] First
#JASMI - 2017-06-06 - START
Filter [ID]
#JASMI - 2017-06-06 - END
If !fstat
  If [M:EMP2]SEX          <> [F:ID]SEX            : J+=1    : Endif
Else
  #new employee - no modif checks needed - let creation continue
  Return
Endif

If clalev([F:ESA])=0    : Local File EMPLOIDSA    [ESA]   : Endif
Filter [ESA] Where REFNUM = [M:EMP0]REFNUM
Read [ESA] First
#JASMI - 2017-06-06 - START
Filter [ESA]
#JASMI - 2017-06-06 - END
If !fstat
  If [M:EMP5]RCEGRP     <> [F:ESA]RCEGRP        : J+=1    : Endif
Endif
#ADNGO - 2017-07-10 - X3-11712 - START
#If func AFNC.ACTIV("KZA")>0
If func DIVPAYE.IS_KZA(GCURLEG)
#ADNGO - 2017-07-10 - X3-11712 - END
  Read [ESA] First
    If !fstat
    #JOJAC - 2016-06-22 - REQ114309 US267 - START
      #For [L]ADDCNT=0 To dim([M:EMP1]ADDTYP)-1
      #If [M:EMP1]ADDTYP([L]ADDCNT) = 3
      #SATPRV = [M:EMP1]ADDPRV([L]ADDCNT)
      For [L]ADDCNT=0 To dim([M:CTR4]ADDTYP)-1
      If [M:CTR4]ADDTYP([L]ADDCNT) = 3
      SATPRV = [M:CTR4]ADDPRV([L]ADDCNT)
    #JOJAC - 2016-06-22 - REQ114309 US267 - START
            For [L]ADDCNTTBL=0 To dim([F:ESA]ADDTYP)-1
              If [F:ESA]ADDTYP([L]ADDCNTTBL) = 3
                If SATPRV <> [F:ESA]ADDPRV([L]ADDCNTTBL)
                  J+=1
                Endif
              Endif
            Next
          Endif
        Next
    Endif
Endif
#ADNGO - 2017-07-10 - X3-11712 - START
#If func AFNC.ACTIV("KAQ")>0
If func DIVPAYE.IS_AFRICA_LEG(GCURLEG)
#ADNGO - 2017-07-10 - X3-11712 - END
If clalev([F:EAF])=0    : Local File EMPLOIDAFR         [EAF]     : Endif
Filter [EAF] Where REFNUM = [M:EMP0]REFNUM
  Read [EAF] First
#JASMI - 2017-06-06 - START
Filter [EAF]
#JASMI - 2017-06-06 - END
    If !fstat
      For [L]ADDCNT=0 To dim([M:EMP1]AFRTYP)-1
        If [M:EMP1]AFRTYP([L]ADDCNT) = 1
          SATPRV = [M:EMP1]AFRPRV([L]ADDCNT)
            For [L]ADDCNTTBL=0 To dim([F:EAF]AFRTYP)-1
              If [F:EAF]AFRTYP([L]ADDCNTTBL) = 1
                If SATPRV <> [F:EAF]AFRPRV([L]ADDCNTTBL)
                  J+=1
                Endif
              Endif
            Next
          Endif
        Next
    Endif
Endif

If clalev([F:AD])=0    : Local File EMPLOAD       [AD]    : Endif
Filter [AD] Where REFNUM = [M:EMP0]REFNUM
Read [AD] First
#JASMI - 2017-06-06 - START
Filter [AD]
#JASMI - 2017-06-06 - END
If !fstat
  If [M:EMP3]STG        <> [F:AD]STG        : J+=1        : Endif
  If [M:EMP3]FLGHDC     <> [F:AD]FLGHDC     : J+=1        : Endif
Endif

If J > 0
  YESNO = 2
  Call OUINON("Changes made will influence the classification history, do you wish to continue and apply the changes for this month?"-format$("D:"+GFMDAT,[V]GMOIPAY), YESNO) From GESECRAN
  If YESNO = 1
    GERR = 1 : GMESSAGE = mess(00090,09139,1)
    GOK = 0 : Return
  Endif
Endif

Return
