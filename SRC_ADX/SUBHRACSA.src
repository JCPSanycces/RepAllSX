$ACTION
Case ACTION
  When "OUVRE"          : Gosub OUVRE
  When "LIENS"          : Gosub LIENS
  When "VERIF_MOD"      : Gosub VERIF_MOD
  When "CREATION"       : Gosub CREATION
  When "MODIF"          : Gosub MODIF
  When "STYLE"          : Gosub STYLE
  When "CLE_GAUCHE"     : Gosub CLE_GAUCHE #LIMAS - 2017-08-21 - X3-52772
 When Default
Endcase
Return


$OUVRE
  If clalev([F:HRAFRCL])=0    : Local File HRAFRCLASS    [HRAFRCL]         : Endif
  If clalev([F:ID])=0         : Local File EMPLOID       [ID]              : Endif
  If clalev([F:HSP])=0        : Local File HISTOPAYE     [HSP]             : Endif
  If clalev([F:VEP])=0        : Local File VALEMP        [VEP]             : Endif
  #ADNGO - 2017-07-10 - X3-11712 -START
  #If clalev([F:CTR])=0        : Local File EMPLOCTR      [CTR]             : Endif
  If clalev([F:HRCTR])=0        : Local File EMPLOCTR      [HRCTR]             : Endif
  #ADNGO - 2017-07-10 - X3-11712 -END
Return

$LIENS
#FRLAA - 2015-07-01 - REQUIREMENT 104631 US 3687 - START
If clalev([F:ID]) = 0 : Local File EMPLOID    [ID]         : Endif
#ADNGO - 2017-07-10 - X3-11712 - START
#Read [ID]ID0 = [F:CTR]REFNUM
Read [ID]ID0 = [F:HRCTR]REFNUM
#ADNGO - 2017-07-10 - X3-11712 - END
If !fstat
  [M:HRAC0]SRN = [F:ID]NAM-[F:ID]SRN
Endif

#ADNGO - 2017-07-10 - X3-11712 - START
#JAVAN - 2018-08-23 - X3-105321 - START
#  If !clalev([F:HRCTR2]) : Local File EMPLOCTR [HRCTR2] : Endif
  If !clalev([F:FCY2]) : Local File FACILITY [FCY2]  : Endif
#    Filter  [HRCTR2] Where CTRNUM=[M:HRAC0]CTRNUM
#    Read [HRCTR2] First
#    Filter [HRCTR2]
#    Read [FCY2]FCY0 = [F:HRCTR2]ETRFCY
    Read [FCY2]FCY0 = [F:HRCTR]ETRFCY
    If !fstat
    GCURLEG = [F:FCY2]LEG
    [M:HRAC0]LEG = GCURLEG
    Affzo [M:HRAC0]LEG
    Endif
#JAVAN - 2018-08-23 - X3-105321 - END
#ADNGO - 2017-07-10 - X3-11712 - END

#ADNGO - 2017-07-10 - X3-11712 - START
#Filter [HRAFRCL] Where REFNUM = [F:CTR]REFNUM & CTRNUM = [F:CTR]CTRNUM & CTRDAT = [F:CTR]CTRDAT Order By Key HRAFRCL2  = PYRMON Desc
Filter [HRAFRCL] Where REFNUM = [F:HRCTR]REFNUM & CTRNUM = [F:HRCTR]CTRNUM & CTRDAT = [F:HRCTR]CTRDAT Order By Key HRAFRCL2  = PYRMON Desc
#ADNGO - 2017-07-10 - X3-11712 - END
#FRLAA - 2015-07-01 - REQUIREMENT 104631 US 3687 - END
nolign = 0
For [HRAFRCL]HRAFRCL2
  nolign += 1
  [M:HRAC1] = [F:HRAFRCL]
  If nolign = dim([M:HRAC1]PYRMON) : Break : Endif
Next

Assign "[M:HRAC1]LIGNUM" With nolign
Filter [HRAFRCL]

#FRLAA - 2015-07-01 - REQUIREMENT 104631 US 3687 - START
#ADNGO - 2017-07-10 - X3-11712 - START
#Filter [VEP] Where CTRNUM = [F:CTR]CTRNUM & EMP = [F:CTR]REFNUM & CTRDAT = [F:CTR]CTRDAT
Filter [VEP] Where CTRNUM = [F:HRCTR]CTRNUM & EMP = [F:HRCTR]REFNUM & CTRDAT = [F:HRCTR]CTRDAT
#ADNGO - 2017-07-10 - X3-11712 - END
