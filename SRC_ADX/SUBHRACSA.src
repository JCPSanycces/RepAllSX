#If func AFNC.ACTIV("KAQ")>0
If func DIVPAYE.IS_AFRICA_LEG(GCURLEG)
#ADNGO - 2017-07-10 - X3-11712 - END
If clalev([F:EAF])=0    : Local File EMPLOIDAFR         [EAF]     : Endif
Filter [EAF] Where REFNUM = [M:EMP0]REFNUM
  Read [EAF] First
