Subprog MODIF_EMP_CHECK(STAT)
Variable Integer STAT : STAT = 0
Local Integer J : J = 0
Local Char FRMTAB(10)
Local Char FRMSCR(10)
Local Char TBLCPY(10)
Local Integer BEFVAL(4)
Local Integer AFTVAL(4)
