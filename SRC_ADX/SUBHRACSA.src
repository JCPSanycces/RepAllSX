######################################################################################
#ADNGO - 2017-07-10 - X3-11712 - START
#FRLAA - 2016-12-14 - 120081 - START
Funprog CHECK_CTRDAT_PAYMON(VCTRMOI,VMOIPAY,VREFNUM,VCTRNUM,VCTRDAT)
Value Date VCTRMOI,VMOIPAY,VCTRDAT
Value Char VREFNUM,VCTRNUM
Local Integer WRET
Local File HRAFRCLASS    [HRAFRCL2]

Filter [HRAFRCL2] Where REFNUM = VREFNUM & CTRNUM = VCTRNUM & CTRDAT = VCTRDAT
If rowcount([HRAFRCL2]) > 0 and VMOIPAY < VCTRMOI
  WRET = 1
Endif
End WRET

$CTRDAT_ERRMSG
GMESSAGE = "Changes to the classification history not allowed in period(s) prior to the contract start date"- num$(MREFNUM)-num$(MCTRNUM)

Return
#FRLAA - 2016-12-14 - 120081 - END
#ADNGO - 2017-07-10 - X3-11712 - END
