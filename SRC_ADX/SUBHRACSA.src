#Filter [CTRSA] Where REFNUM = [M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM & CTRDAT = [M:CTR0]CTRDAT
#Read [CTRSA] First
#If !fstat
#  If [M:CTR1]OCPLEV     <> [F:CTRSA]OCPLEV      : J+=1 :  Endif
#  If func AFNC.ACTIV("SDM")>0
#    If [M:CTR1]OFOCOD     <> [F:CTRSA]OFOCOD      : J+=1 :  Endif
#  Endif
#  If func AFNC.ACTIV("EQM")>0
#    If [M:CTR1]EQUEMPTYP  <> [F:CTRSA]EQUEMPTYP   : J+=1 :  Endif
#  Endif
#Endif
If clalev([F:CTRSA1])=0    : Local File EMPLOCTRSA    [CTRSA1]         : Endif
If clalev([F:CTR1])  =0    : Local File EMPLOCTR      [CTR1]           : Endif

Filter [CTR1]
Filter [CTR1] Where REFNUM = [M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM & CTRDAT = [M:CTR0]CTRDAT
Read [CTR1] First
#ADNGO - 2017-07-10 - X3-11712 - START
Filter [CTR1]
#ADNGO - 2017-07-10 - X3-11712 - END
#Check if contract exists ( New contract )
If !fstat
  If [M:CTR0]ETRFCY     <> [F:CTR1]ETRFCY        : J+=1 :  Endif
  #If [M:CTR0]CPY        <> [F:CTR]XITFNL        : J+=1 :  Endif
Else
  Return
Endif

Filter [CTRSA1]
Filter [CTRSA1] Where REFNUM = [M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM & CTRDAT = [M:CTR0]CTRDAT
Read [CTRSA1] First
If !fstat
  If [M:CTR1]OCPLEV     <> [F:CTRSA1]OCPLEV      : J+=1 :  Endif
  If func AFNC.ACTIV("SDM")>0
    If [M:CTR1]OFOCOD     <> [F:CTRSA1]OFOCOD      : J+=1 :  Endif
  Endif
  If func AFNC.ACTIV("EQM")>0
    If [M:CTR1]EQUEMPTYP  <> [F:CTRSA1]EQUEMPTYP   : J+=1 :  Endif
  Endif
Endif
#JASMI - 2015-11-27 - Reg 112521 - END

#Check if changes were made - (J)
# New contract
# Existing contract with no data in EMPLOCTRSA
If J > 0
  YESNO = 2
  Call OUINON("Changes made will influence the classification history, do you wish to continue and apply the changes for this month?"-format$("D:"+GFMDAT,[V]GMOIPAY), YESNO) From GESECRAN
  If YESNO = 1
    GERR = 1 : GMESSAGE = mess(00090,09139,1)
    GOK = 0 : Return
  Endif
Endif

Return
#ADNGO - 2017-07-10 - X3-11712 - START
Subprog MODIF_CTR_CHECK(STAT)
Variable Integer STAT : STAT = 0
Local Integer J : J = 0
Local Integer YESNO
#ADNGO - 2017-07-10 - X3-11712 - START
#If (func AFNC.ACTIV("KFR")>0 & func AFNC.ACTIV("KPO")>0) : End : Endif
#If func AFNC.ACTIV("KZA")=0 : End : Endif # For RSA only for now, will revisit for other countries when needed.
If (func DIVPAYE.IS_KFR_LEG(GCURLEG) & func DIVPAYE.IS_KPO_LEG(GCURLEG)) : End : Endif
If !func DIVPAYE.IS_KZA(GCURLEG) : End : Endif
#ADNGO - 2017-07-10 - X3-11712 - END
If [M:CTR0]FLGRET = 2 or [M:CTR0]FLGVAR = 2 : End : Endif  #FRLAA X3PEOP-2027 - 2016-09-19
#If [V]GMOIPAY < [M:CTR0]CTRDAT : End : Endif #FRLAA - 2016-11-29 - 120081

If clalev([F:CTRSA1])=0    : Local File EMPLOCTRSA    [CTRSA1]         : Endif
If clalev([F:CTR1])  =0    : Local File EMPLOCTR      [CTR1]           : Endif

Filter [CTR1]
Filter [CTR1] Where REFNUM = [M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM & CTRDAT = [M:CTR0]CTRDAT
Read [CTR1] First
Filter [CTR1]
#Check if contract exists ( New contract )
If !fstat
  If [M:CTR0]ETRFCY     <> [F:CTR1]ETRFCY        : J+=1 :  Endif
  #If [M:CTR0]CPY        <> [F:CTR]XITFNL        : J+=1 :  Endif
Else
  End
Endif

Filter [CTRSA1]
Filter [CTRSA1] Where REFNUM = [M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM & CTRDAT = [M:CTR0]CTRDAT
Read [CTRSA1] First
Filter [CTRSA1]
If !fstat
  If [M:CTR1]OCPLEV     <> [F:CTRSA1]OCPLEV      : J+=1 :  Endif
  If func AFNC.ACTIV("SDM")>0
    If [M:CTR1]OFOCOD     <> [F:CTRSA1]OFOCOD      : J+=1 :  Endif
  Endif
  If func AFNC.ACTIV("EQM")>0
    If [M:CTR1]EQUEMPTYP  <> [F:CTRSA1]EQUEMPTYP   : J+=1 :  Endif
  Endif
Else
  J+=1
Endif

STAT=J

If STAT > 0
  #FRLAA - 2016-12-14 - 120081 - START
  #Check to make sure that the change will not apply before the first entry on the classificaiton table, only in the case of a new record
  Local Date CTRMOI
  CTRMOI = gdat$(1,month([M:CTR0]CTRDAT),year([M:CTR0]CTRDAT))

  If func SUBHRACSA.CHECK_CTRDAT_PAYMON(CTRMOI, [V]GMOIPAY, [M:CTR0]REFNUM, [M:CTR0]CTRNUM, [M:CTR0]CTRDAT) = 1
    Local Char MREFNUM(GLONMAT), MCTRNUM(GLONCTR)
    MREFNUM = [F:CTR1]REFNUM
    MCTRNUM = [F:CTR1]CTRNUM
    Gosub CTRDAT_ERRMSG
    STAT = -1
    End
  Endif
Endif
#FRLAA - 2016-12-14 - 120081 - END

End
#ADNGO - 2017-07-10 - X3-11712 - END

$CREAT_MODHISTCTR
Local Integer J : J = 0
Local Integer NEWOK, NEWCTR : NEWOK = 1 : NEWCTR = 0
Local Integer NEWSAOK : NEWSAOK = 1
Local Char CHGCMT(30)
Local Char FRMTAB(10)
Local Char FRMSCR(10)
Local Integer BEFVAL(4) : BEFVAL = 0
Local Integer AFTVAL(4) : AFTVAL = 0
Local Integer ADDCNT
#ADNGO - 2017-07-10 - X3-11712 - START
#If (func AFNC.ACTIV("KFR")>0 & func AFNC.ACTIV("KPO")>0) : Return : Endif
#If func AFNC.ACTIV("KZA")=0 : Return : Endif # For RSA only for now, will revisit for other countries when needed.
If (func DIVPAYE.IS_KFR_LEG(GCURLEG) & func DIVPAYE.IS_KPO_LEG(GCURLEG)) : Return : Endif
If !func DIVPAYE.IS_KZA(GCURLEG) : Return : Endif # For RSA only for now, will revisit for other countries when needed.
#ADNGO - 2017-07-10 - X3-11712 - END
#If [M:CTR0]XITFNL = 2 : Return : Endif
#ADNGO - 2017-07-10 - X3-11712 - START
If [M:CTR0]FLGVAR = 2 or [M:CTR0]FLGRET = 2 : Return : Endif #FRLAA X3PEOP-2027 - 2016-09-19
#ADNGO - 2017-07-10 - X3-11712 - END

If clalev([F:HRAFRCL])=0    : Local File HRAFRCLASS    [HRAFRCL]         : Endif
Filter [HRAFRCL] Where REFNUM = [M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM & CTRDAT = [M:CTR0]CTRDAT &  PYRMON < [V]GMOIPAY Order By Key HRAFRCL2  = PYRMON Desc
Read [HRAFRCL] First
#JASMI - 2017-06-06 - START
Filter [HRAFRCL]
#JASMI - 2017-06-06 - END
If !fstat
  BEFVAL = [F:HRAFRCL]OCPLEV
#ADNGO - 2017-07-10 - X3-11712 - START
#FRLAA - 2016-11-29 - 120081 - START
Else
  Filter [HRAFRCL] Where REFNUM = [M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM & CTRDAT = [M:CTR0]CTRDAT &  PYRMON = [V]GMOIPAY
  Read [HRAFRCL] First
  Filter [HRAFRCL]
  If !fstat
    BEFVAL = [F:HRAFRCL]OCPLEV
  Endif
#FRLAA - 2016-11-29 - 120081 - END
#ADNGO - 2017-07-10 - X3-11712 - END
Endif

#Checking new record - using contract start vs paymon
Filter [HRAFRCL] Where REFNUM = [M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM & CTRDAT = [M:CTR0]CTRDAT
Read [HRAFRCL] First
#JASMI - 2017-06-06 - START
Filter [HRAFRCL]
#JASMI - 2017-06-06 - END
If !fstat
  NEWCTR = 0
Else
  #Checking if there was a previous contract with no break in service
#JASMI - 2015-11-27 - Reg 112521 - START
#  If clalev([F:CTRSA])=0    : Local File EMPLOCTRSA    [CTRSA]         : Endif
#  If clalev([F:CTR])  =0    : Local File EMPLOCTR      [CTR]           : Endif
#
#  Filter [CTR] Where REFNUM = [M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM & CTRDAT < [M:CTR0]CTRDAT
#  For [CTR]CTR0
#    If ([M:CTR0]CTRDAT-[F:CTR]XITDAT= 1)
#      Filter [CTRSA] Where REFNUM = [F:CTR]REFNUM & CTRNUM = [F:CTR]CTRNUM & CTRDAT = [F:CTR]CTRDAT
#      Read [CTRSA] First
#      If !fstat
#        BEFVAL = [F:CTRSA]OCPLEV
#        Break
#      Endif
#    Endif
#  Next
  If clalev([F:CTRSA1])=0    : Local File EMPLOCTRSA    [CTRSA1]         : Endif
  If clalev([F:CTR1])  =0    : Local File EMPLOCTR      [CTR1]           : Endif

  Filter [CTR1]
  Filter [CTR1] Where REFNUM = [M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM & CTRDAT < [M:CTR0]CTRDAT
  For [CTR1]CTR0
    If ([M:CTR0]CTRDAT-[F:CTR1]XITDAT= 1)
      Filter [CTRSA1]
      Filter [CTRSA1] Where REFNUM = [F:CTR1]REFNUM & CTRNUM = [F:CTR1]CTRNUM & CTRDAT = [F:CTR1]CTRDAT
      Read [CTRSA1] First
      If !fstat
        BEFVAL = [F:CTRSA1]OCPLEV
        Break
      Endif
    Endif
  Next
#JASMI - 2015-11-27 - Reg 112521 - END
  NEWCTR = 1
Endif

#Keeping current values"
Filter [HRAFRCL] Where REFNUM = [M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM & CTRDAT = [M:CTR0]CTRDAT & PYRMON=[V]GMOIPAY
Read [HRAFRCL] First
If !fstat
  CHGCMT = [F:HRAFRCL]CHGCMT
Endif

Filter [HRAFRCL]
Delete [HRAFRCL] Where REFNUM = [M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM & CTRDAT = [M:CTR0]CTRDAT & PYRMON=[V]GMOIPAY
If fstat=1
  GOK = -1
  GLOCK = "$HRAFRCLASS"-[CTR0]REFNUM -[CTR0]CTRNUM - [CTR0]CTRDAT - [V]GMOIPAY
  Return
Elsif fstat>5
  GOK = 0
  Call RSTA("CTRSA",[CTR0]REFNUM - [CTR0]CTRNUM - [CTR0]CTRDAT) From GLOCK
  Return
Endif
#ADNGO - 2017-07-10 - X3-11712 - START
Raz [F:HRAFRCL] #FRLAA - 2016-11-29 - 120081
#ADNGO - 2017-07-10 - X3-11712 - END
If  NEWCTR = 1
  [F:HRAFRCL]PYRMON       = gdat$(1,month([M:CTR0]CTRDAT),year([M:CTR0]CTRDAT))
Else
  [F:HRAFRCL]PYRMON       = [V]GMOIPAY
Endif
[F:HRAFRCL]CTRNUM       = [M:CTR0]CTRNUM
[F:HRAFRCL]REFNUM       = [M:CTR0]REFNUM
[F:HRAFRCL]CTRDAT       = [M:CTR0]CTRDAT
[F:HRAFRCL]XITDAT       = [M:CTR0]XITDAT
[F:HRAFRCL]XITFNL       = [M:CTR8]XITFNL
[F:HRAFRCL]FCY          = [M:CTR0]ETRFCY
[F:HRAFRCL]CPY          = [M:CTR0]CPY
[F:HRAFRCL]OCPLEV       = [M:CTR1]OCPLEV
#ADNGO - 2017-08-07 - START
If func AFNC.ACTIV("FKZSD")>0
#ADNGO - 2017-08-07 - END
  [F:HRAFRCL]OFOCOD       = [M:CTR1]OFOCOD
#ADNGO - 2017-08-07 - START
Endif
#ADNGO - 2017-08-07 - END
[F:HRAFRCL]CHGCMT       = CHGCMT
If func AFNC.ACTIV("EQM")>0
  [F:HRAFRCL]EQUEMPTYP    = [M:CTR1]EQUEMPTYP
Endif


If BEFVAL = 0 : [F:HRAFRCL]OCPBEFVAL = [M:CTR1]OCPLEV : Else [F:HRAFRCL]OCPBEFVAL = BEFVAL : Endif
[F:HRAFRCL]OCPAFTVAL    = [M:CTR1]OCPLEV
If clalev([ID])=0    : Local File EMPLOID    [ID]         : Endif
Filter [ID] Where REFNUM = [M:CTR0]REFNUM
Read [ID] First
#JASMI - 2017-06-06 - START
Filter [ID]
#JASMI - 2017-06-06 - END
If !fstat
  [F:HRAFRCL]SEX          = [F:ID]SEX
Endif

If clalev([ESA])=0    : Local File EMPLOIDSA    [ESA]         : Endif
Filter [ESA] Where REFNUM = [M:CTR0]REFNUM
Read [ESA] First
#JASMI - 2017-06-06 - START
Filter [ESA]
#JASMI - 2017-06-06 - END
If !fstat
  [F:HRAFRCL]RCEGRP       = [F:ESA]RCEGRP
  #ADNGO - 2017-07-10 - X3-11712 - START
  #If func AFNC.ACTIV("KZA")>0
  If func DIVPAYE.IS_KZA(GCURLEG)
  #ADNGO - 2017-07-10 - X3-11712 - END
    For [L]ADDCNT=0 To dim([F:ESA]ADDTYP)-1
      If [F:ESA]ADDTYP([L]ADDCNT) = 3
        [F:HRAFRCL]PRV = [F:ESA]ADDPRV([L]ADDCNT)
      Endif
    Next
  Endif
Endif

If clalev([F:AD])=0    : Local File EMPLOAD    [AD]         : Endif
Filter [AD] Where REFNUM = [M:CTR0]REFNUM
Read [AD] First
#JASMI - 2017-06-06 - START
Filter [AD]
#JASMI - 2017-06-06 - END
If !fstat
  [F:HRAFRCL]STG    = [F:AD]STG
  [F:HRAFRCL]HDCFLG = [F:AD]FLGHDC
Endif

[F:HRAFRCL]CRETYP    = "A" # Auto generated transaction
Write [HRAFRCL]
If fstat
  GOK = 0 : Return
Endif
Return



$CREAT_MODHISTEMP
Local Integer READOK,OCPBEFVAL,OCPAFTVAL
Local Char CHGCMT(30)
#ADNGO - 2017-07-10 - X3-11712 - START
Local Char SATPRV(35) #FRLAA - 119465 - 2016-10-27
Local Integer ADDCNT,ADDCNTTBL #FRLAA - 119465 - 2016-10-27
#ADNGO - 2017-07-10 - X3-11712 - END
#ADNGO - 2017-07-10 - X3-11712 - START
#If (func AFNC.ACTIV("KFR")>0 & func AFNC.ACTIV("KPO")>0) : Return : Endif # PAIEV6
#If func AFNC.ACTIV("KZA")=0 : Return : Endif # For RSA only for now, will revisit for other countries when needed.
If (func DIVPAYE.IS_KFR_LEG(GCURLEG) & func DIVPAYE.IS_KPO_LEG(GCURLEG)) : Return : Endif # PAIEV6
If !func DIVPAYE.IS_KZA(GCURLEG) : Return : Endif # For RSA only for now, will revisit for other countries when needed.
#ADNGO - 2017-07-10 - X3-11712 - END
#Updating all active contracts only - XITFNL Status
#JASMI - 2015-11-27 - Reg 112521 - START
#If clalev([F:CTR])=0    : Local File EMPLOCTR   [CTR]     : Endif
#Filter [CTR] Where REFNUM=[M:EMP0]REFNUM
#For [CTR]CTR0
#  CHGCMT = ""
#  READOK = 0
#  OCPBEFVAL = 0
#  OCPAFTVAL = 0
#  If [F:CTR]XITFNL <> 2
#    #Checking if the the contract exist in EMPLOCTRSA
#    If clalev([F:CTRSA])=0      : Local File EMPLOCTRSA    [CTRSA]           : Endif
#    Filter [CTRSA] Where CTRNUM = [F:CTR]CTRNUM & REFNUM = [F:CTR]REFNUM & CTRDAT = [F:CTR]CTRDAT
#    Read [CTRSA] First
#    If !fstat
#      READOK = 1
#      OCPBEFVAL = [F:CTRSA]OCPLEV
#      OCPAFTVAL=  [F:CTRSA]OCPLEV
#    Endif
#
#    If clalev([F:HRAFRCL])=0    : Local File HRAFRCLASS    [HRAFRCL]         : Endif
#    Filter [HRAFRCL] Where PYRMON=[V]GMOIPAY & CTRNUM = [F:CTR]CTRNUM & REFNUM = [F:CTR]REFNUM & CTRDAT = [F:CTR]CTRDAT
#    Read [HRAFRCL] First
#    If !fstat
#      #Record already exist and need to keep some field values
#      #Setting default values for occupation level changes
#      OCPBEFVAL = [F:HRAFRCL]OCPBEFVAL
#      OCPAFTVAL=  [F:HRAFRCL]OCPAFTVAL
#      CHGCMT = [F:HRAFRCL]CHGCMT
#    Endif
#
#    Filter [HRAFRCL]
#    Delete [HRAFRCL] Where REFNUM = [F:CTR]REFNUM & CTRNUM = [F:CTR]CTRNUM & CTRDAT = [F:CTR]CTRDAT & PYRMON=[V]GMOIPAY
#    If fstat=1
#      GOK = -1
#      GLOCK = "$HRAFRCLASS"-[CTR0]REFNUM - [CTR0]CTRNUM -  [CTR0]CTRDAT - [V]GMOIPAY
#      Return
#    Elsif fstat>5
#      GOK = 0
#      Call RSTA("CTRSA",[CTR0]REFNUM - [CTR0]CTRNUM - [CTR0]CTRDAT) From GLOCK
#      Return
#    Endif
#
#    [F:HRAFRCL]PYRMON       = [V]GMOIPAY
#    [F:HRAFRCL]CTRNUM       = [F:CTR]CTRNUM
#    [F:HRAFRCL]REFNUM       = [F:CTR]REFNUM
#    [F:HRAFRCL]CTRDAT       = [F:CTR]CTRDAT
#    [F:HRAFRCL]XITDAT       = [F:CTR]XITDAT
#    [F:HRAFRCL]XITFNL       = [F:CTR]XITFNL
#    [F:HRAFRCL]FCY          = [F:CTR]ETRFCY
#    [F:HRAFRCL]OCPBEFVAL    = OCPBEFVAL
#    [F:HRAFRCL]OCPAFTVAL    = OCPAFTVAL
#    If READOK = 1
#      [F:HRAFRCL]OCPLEV       = [F:CTRSA]OCPLEV
#      [F:HRAFRCL]OFOCOD       = [F:CTRSA]OFOCOD
#      [F:HRAFRCL]EQUEMPTYP    = [F:CTRSA]EQUEMPTYP
#    Endif
#    [F:HRAFRCL]STG          = [M:EMP3]STG
#    [F:HRAFRCL]HDCFLG       = [M:EMP3]FLGHDC
#    [F:HRAFRCL]RCEGRP       = [M:EMP5]RCEGRP
#    [F:HRAFRCL]SEX          = [M:EMP2]SEX
#    [F:HRAFRCL]PRV          = SATPRV
#    [F:HRAFRCL]CHGCMT       = CHGCMT
#
#    #Get company linking
#    If clalev([F:FCY])=0    : Local File FACILITY    [FCY]         : Endif
#    Filter [FCY] Where FCY = [F:CTR]ETRFCY
#    Read [FCY] First
#    If !fstat
#      [F:HRAFRCL]CPY          = [F:FCY]LEGCPY
#    Endif
#
#    [F:HRAFRCL]CRETYP    = "A" # Auto generated transaction
#    Write [HRAFRCL]
#    If fstat
#      GOK=0 : Return
#    Endif
#  Endif
#Next
If clalev([F:CTR1])=0    : Local File EMPLOCTR   [CTR1]     : Endif
Filter [CTR1]
#ADNGO - 2017-07-10 - X3-11712 - START
#FRLAA X3PEOP-2027 - 2016-09-19 - START
#Filter [CTR1] Where REFNUM=[M:EMP0]REFNUM
Filter [CTR1] Where REFNUM=[M:EMP0]REFNUM and FLGVAR <> 2 and FLGRET <> 2
#FRLAA X3PEOP-2027 - 2016-09-19 - END
#ADNGO - 2017-07-10 - X3-11712 - END
For [CTR1]CTR0
  #ADNGO - 2017-07-10 - X3-11712 - START
  #CHGCMT = ""
  #READOK = 0
  #OCPBEFVAL = 0
  #OCPAFTVAL = 0
  Local Date CTRMOI
  CTRMOI = gdat$(1,month([F:CTR1]CTRDAT),year([F:CTR1]CTRDAT))

  If func SUBHRACSA.CHECK_CTRDAT_PAYMON(CTRMOI, [V]GMOIPAY, [F:CTR1]REFNUM, [F:CTR1]CTRNUM, [F:CTR1]CTRDAT) = 1
    Local Char MREFNUM(GLONEML), MCTRNUM(GLONHRCTR)
    MREFNUM = [F:CTR1]REFNUM
    MCTRNUM = [F:CTR1]CTRNUM
    Gosub CTRDAT_ERRMSG
  Else
    CHGCMT = ""
    READOK = 0
    OCPBEFVAL = 0
    OCPAFTVAL = 0
  #ADNGO - 2017-07-10 - X3-11712 - END
  #ADNGO - 2017-07-10 - X3-11712 - START
  #If [F:CTR1]XITFNL <> 2 #FRLAA Change 2016-07-07
  #ADNGO - 2017-07-10 - X3-11712 - END
    #Checking if the the contract exist in EMPLOCTRSA
    If clalev([F:CTRSA1])=0      : Local File EMPLOCTRSA    [CTRSA1]           : Endif
    Filter [CTRSA1]
    Filter [CTRSA1] Where CTRNUM = [F:CTR1]CTRNUM & REFNUM = [F:CTR1]REFNUM & CTRDAT = [F:CTR1]CTRDAT
    Read [CTRSA1] First
    #ADNGO - 2017-07-10 - X3-11712 - START
    Filter [CTR1]
    #ADNGO - 2017-07-10 - X3-11712 - END
    If !fstat
      READOK = 1
      OCPBEFVAL = [F:CTRSA1]OCPLEV
      OCPAFTVAL=  [F:CTRSA1]OCPLEV
    Endif
    #ADNGO - 2017-07-10 - X3-11712 - START
     #FRLAA - 119465 - 2016-10-27 - START
     #ADNGO - 2017-07-10 - X3-11712 - START
      #If func AFNC.ACTIV("KZA")>0
      If func DIVPAYE.IS_KZA(GCURLEG)
      #ADNGO - 2017-07-10 - X3-11712 - END
        If clalev([F:ESA])=0    : Local File EMPLOIDSA    [ESA]   : Endif
        Filter [ESA] Where REFNUM = [M:EMP0]REFNUM
        Read [ESA] First
        If !fstat
          For [L]ADDCNT=0 To dim([M:EMP1]ADDTYP)-1
            If [M:EMP1]ADDTYP([L]ADDCNT) = 3
              SATPRV = [M:EMP1]ADDPRV([L]ADDCNT)
                For [L]ADDCNTTBL=0 To dim([F:ESA]ADDTYP)-1
                  If [F:ESA]ADDTYP([L]ADDCNTTBL) = 3
                    If SATPRV <> [F:ESA]ADDPRV([L]ADDCNTTBL)
                      J+=1
                    Endif
                  Endif
                Next
              Endif
            Next
        Endif
      Endif
      Filter [ESA]
     #FRLAA - 119465 - 2016-10-27 - END
    #ADNGO - 2017-07-10 - X3-11712 - END
    If clalev([F:HRAFRCL])=0    : Local File HRAFRCLASS    [HRAFRCL]         : Endif
    Filter [HRAFRCL] Where PYRMON=[V]GMOIPAY & CTRNUM = [F:CTR1]CTRNUM & REFNUM = [F:CTR1]REFNUM & CTRDAT = [F:CTR1]CTRDAT
    Read [HRAFRCL] First
    If !fstat
      #Record already exist and need to keep some field values
      #Setting default values for occupation level changes
      OCPBEFVAL = [F:HRAFRCL]OCPBEFVAL
      OCPAFTVAL=  [F:HRAFRCL]OCPAFTVAL
      CHGCMT = [F:HRAFRCL]CHGCMT
    Endif

    Filter [HRAFRCL]
    Delete [HRAFRCL] Where REFNUM = [F:CTR1]REFNUM & CTRNUM = [F:CTR1]CTRNUM & CTRDAT = [F:CTR1]CTRDAT & PYRMON=[V]GMOIPAY
    If fstat=1
      GOK = -1
      GLOCK = "$HRAFRCLASS"-[CTR0]REFNUM - [CTR0]CTRNUM -  [CTR0]CTRDAT - [V]GMOIPAY
      #ADNGO - 2017-07-10 - X3-11712 - START
      Filter [CTR1]
      #ADNGO - 2017-07-10 - X3-11712 - END
      Return
    Elsif fstat>5
      GOK = 0
      Call RSTA("CTRSA",[CTR0]REFNUM - [CTR0]CTRNUM - [CTR0]CTRDAT) From GLOCK
      #ADNGO - 2017-07-10 - X3-11712 - START
      Filter [CTR1]
      #ADNGO - 2017-07-10 - X3-11712 - END
      Return
    Endif

    [F:HRAFRCL]PYRMON       = [V]GMOIPAY
    [F:HRAFRCL]CTRNUM       = [F:CTR1]CTRNUM
    [F:HRAFRCL]REFNUM       = [F:CTR1]REFNUM
    [F:HRAFRCL]CTRDAT       = [F:CTR1]CTRDAT
    [F:HRAFRCL]XITDAT       = [F:CTR1]XITDAT
    [F:HRAFRCL]XITFNL       = [F:CTR1]XITFNL
    [F:HRAFRCL]FCY          = [F:CTR1]ETRFCY
    [F:HRAFRCL]OCPBEFVAL    = OCPBEFVAL
    [F:HRAFRCL]OCPAFTVAL    = OCPAFTVAL
    If READOK = 1
      [F:HRAFRCL]OCPLEV       = [F:CTRSA1]OCPLEV
      [F:HRAFRCL]OFOCOD       = [F:CTRSA1]OFOCOD
      [F:HRAFRCL]EQUEMPTYP    = [F:CTRSA1]EQUEMPTYP
    Endif
    [F:HRAFRCL]STG          = [M:EMP3]STG
    [F:HRAFRCL]HDCFLG       = [M:EMP3]FLGHDC
    [F:HRAFRCL]RCEGRP       = [M:EMP5]RCEGRP
    [F:HRAFRCL]SEX          = [M:EMP2]SEX
    [F:HRAFRCL]PRV          = SATPRV
    [F:HRAFRCL]CHGCMT       = CHGCMT

    #Get company linking
    If clalev([F:FCY])=0    : Local File FACILITY    [FCY]         : Endif
    Filter [FCY] Where FCY = [F:CTR1]ETRFCY
    Read [FCY] First
#JASMI - 2017-06-06 - START
Filter [FCY]
#JASMI - 2017-06-06 - END
    If !fstat
      [F:HRAFRCL]CPY          = [F:FCY]LEGCPY
    Endif

    [F:HRAFRCL]CRETYP    = "A" # Auto generated transaction
    Write [HRAFRCL]
    If fstat
      #ADNGO - 2017-07-10 - X3-11712 - START
      Filter [CTR1]
      #ADNGO - 2017-07-10 - X3-11712 - END
      GOK=0 : Return
    Endif
  Endif
Next
#JASMI - 2015-11-27 - Reg 112521 - END
#ADNGO - 2017-07-10 - X3-11712 - START
Filter [CTR1]
#ADNGO - 2017-07-10 - X3-11712 - END
Return

##FRLAA & JASMI - 2015-06-08 - REQUIREMENT 104630 US 3682 - START
