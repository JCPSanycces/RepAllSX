  #ADNGO - 2017-07-10 - X3-11712 - END
    If !fstat
      For [L]ADDCNT=0 To dim([M:EMP1]AFRTYP)-1
        If [M:EMP1]AFRTYP([L]ADDCNT) = 1
          SATPRV = [M:EMP1]AFRPRV([L]ADDCNT)
            For [L]ADDCNTTBL=0 To dim([F:EAF]AFRTYP)-1
              If [F:EAF]AFRTYP([L]ADDCNTTBL) = 1
                If SATPRV <> [F:EAF]AFRPRV([L]ADDCNTTBL)
                  J+=1
                Endif
              Endif
            Next
          Endif
        Next
    Endif
Endif

If clalev([F:AD])=0    : Local File EMPLOAD       [AD]    : Endif
Filter [AD] Where REFNUM = [M:EMP0]REFNUM
Read [AD] First
#ADNGO - 2017-07-10 - X3-11712 - START
Filter [AD]
#ADNGO - 2017-07-10 - X3-11712 - END
