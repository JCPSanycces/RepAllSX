#<AdxTL>@(#)2.0.0.0 $Revision$
Call IMPORTATION("SIRHRIB") From GIMPOBJ
End
################################################################################################

$ACTION
Case ACTION
 When "IMP_OUVRE"     : Gosub IMP_OUVRE
 When "AP_IMPORT"     : Gosub AP_IMPORT
 When "IMP_VERIF_CRE" : Gosub VERIF
 When "IMP_VERIF_MOD" : Gosub VERIF
Endcase
Return

$IMP_OUVRE
If clalev([F:ID])=0   : Local File EMPLOID  [ID]   : Endif
If clalev([F:RIB2])=0 : Local File EMPLORIB [RIB2] : Endif
If clalev([F:FCY])=0  : Local File FACILITY [FCY]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY  [CPY]  : Endif
If clalev([F:ADI])=0  : Local File ATABDIV  [ADI]  : Endif
Return

$AP_IMPORT
# On importe toujours le premier rib.
[F:RIB]NUMLIG = 1
Read [RIB2]RIB0=[F:RIB]REFNUM;1
If !fstat
 [F:RIB]TYPPAY = [F:RIB2]TYPPAY
 [F:RIB]MODSTL = [F:RIB2]MODSTL
 [F:RIB]CPYBAN = [F:RIB2]CPYBAN
 [F:RIB]BIDCRY = [F:RIB2]BIDCRY
 [F:RIB]IBAN   = [F:RIB2]IBAN
 [F:RIB]CUR    = [F:RIB2]CUR
Else
 Filter [ADI] Where NUMTAB=10387 & DEFVAL=2
 Read [ADI]CODE First
 If !fstat
  [F:RIB]MODSTL = [F:ADI]CODE
 Else
  Filter [ADI] Where NUMTAB=10387
  Read [ADI]CODE First
  [F:RIB]MODSTL = [F:ADI]CODE
 Endif
 Filter [ADI]
 Call LECTURE("EML",[F:RIB]REFNUM,"") From CONTOBJ
 Read [FCY]FCY0=[F:ID]FCY
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 [F:RIB]CUR    = [F:CPY]ACCCUR
 [F:RIB]BIDCRY = GPAYS
Endif
[F:RIB]PAYPCT=100
Return

$VERIF
Call LECTURE("EML",[F:RIB]REFNUM,"") From CONTOBJ
If fstat
 # Matricule inexistant
 Call TRACE(2,mess(83,10702,1)-":"-[F:RIB]REFNUM) From SUBIMPOBJ
 OK = 0 :  Return
Endif
Return

