#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################
# SUBMCL : Transactions Plan des fiches techniques         sr 05.05   #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:BTS]BENCHTRS Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                                                                     #
#                                                                     #
# Génération      écran  de saisie à partir de l'écran MTKBENCHT      #
#                                                                     #
# Nom des écrans de base générés : WTxyyyz                            #
#                                 x = 51 pour plan global             #
#                                 x = 52 pour plan de travail         #
#                                 x = 53 pour regroupements           #
#                                 x = 60 pour suivi des temps         #
#                                 x = 61 pour suivi des matières      #
#                                 x = 63 pour suivi des réintégrations#
#                                 x = 65 pour pilotage                #
#                                 x = 66 pour fiches techniques       #
#                                                                     #
#                                 yyy = nom de la transaction         #
#                                                                     #
#                                 z = numéro d'ordre de l'écran       #
#                                                                     #
#######################################################################


$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE  
 When "FILTRE"   : Gosub FILTRE
 When "EFFMASK"  : [M]BTSTYP = 66
 When "RAZCRE"   : Gosub RAZCRE
 When "SETBOUT"  : Gosub SETBOUT
 When "EXEBOUT"  : Gosub EXEBOUT
 When "LIENS"    : Gosub LIENS
 When "INICRE"   : Gosub INICRE
 When "INIMOD"   : Gosub INICRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "CREATION" : Gosub TRT_ECRAN
 When "MODIF"    : Gosub TRT_ECRAN
 When "ANNULE"   : Delete [AXX] Where CODFIC="BENCHTRS" & IDENT1=num$([F:BTS]BTSTYP) & IDENT2=[F:BTS]BTSNUM
                   Gosub TRT_ECRAN
 When Default
Endcase
Return

######################################################################################
#-------------------------------------------------------#
# Définir le dossier pour la génération des écrans      #
#-------------------------------------------------------#
$OUVRE
Local Char     LIBEL(30) , MASKREF(GLONAMK)
Local Integer  ER
Local Integer  J,K
Local Char     MFROM(GLONAMK)
Local Char     MTO(GLONAMK)
Local Char     WNOMMSK(GLONAMK)
Local Decimal  RANG
Local Shortint WNUM
Local Shortint WFLGMSK
Local Char     WMODU(3) : WMODU="T"

#--- Lignes suivantes à activer si besoin
#If GUSER <> "SR" Infbox "en cours de mise au point... !!!"
#   OK = 0
#    Return 
#Endif    
MASKREF = "MTKBENCHT"

If clalev ([F:AMZ]) <= 0  : Local File AMSKZON [AMZ] : Endif
If clalev ([F:AMK])  = 0  : Local File AMSK    [AMK] : Endif
If clalev ([F:AMA])  = 0  : Local File AMSKACT [AMA] : Endif
If clalev ([F:AMP])  = 0  : Local File AMSKPAR [AMP] : Endif
If clalev ([F:ADS])  = 0  : Local File ADOSSIER[ADS] : Endif

Return

######################################################################################
#-----------------------------------------------------------------------#
# Ne traiter que les transactions du plan des fiches techniques         #
#-----------------------------------------------------------------------#
$FILTRE
FILTSUP="BTSTYP=66"
Return

######################################################################################
$RAZCRE
Raz  [M:MCL1], [M:MCL2]

[M:MCL1]OFFLG   = 2
[M:MCL1]GAMFLG  = 2
[M:MCL1]TECMODSAI = 3
[M:MCL1]MATRICULE = 1
[M:MCL1]CRIT1 = 1
[M:MCL1]CRIT2 = 2
Gosub PE_MFGTRS From SUBMFX
If !GIMPORT
    Affzo [M:MCL1]
Endif

Return

######################################################################################
#------------------------------------------#  
# Désactivation bouton validation et copie #  
#------------------------------------------#  
$SETBOUT
If GREP <>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif 
Call VIREBOUT(CHAINE,"H") From GOBJET
Return

######################################################################################
$EXEBOUT
Case REP  
  When "1" : Call DEBTRANS From GLOCK  
             Trbegin ADOVAL  
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
  When Default  
Endcase  
Return

######################################################################################
$LIENS
Actzo [M:MCL1]

Gosub PE_MFGTRS From SUBMFX

# chargement champs paramétrés
[M]NBRFLD = 0
Gosub CHARGE_CHAMP 
Raz [M]DAC
For NOL=0 To [F:BTS]NBRFLD-1 
    K = find([F:BTS]FLD(NOL),[M]FLD(0..[M]NBRFLD)) 
    If K 
      [M]DAC(K-1) = [F:BTS]DAC(NOL) 
     Endif
Next NOL
Gosub TRI

Return

######################################################################################
######################################################################################
# Etiquettes gestion paramétrage affichage
$CHARGE_CHAMP
# dans quel bloc se situe le tableau ?
Read [AMZ]CODE = MASKREF;"NBLIG"
If fstat=0 : J=[F:AMZ]NUMBLOC : Else J=0 : Endif

For [AMZ]CODZON Where CODMSK=MASKREF
    OK = 1
    If [F:AMZ]CODTYP="ABS" | [F:AMZ]SAIAFF=3 | (J & [F:AMZ]NUMBLOC<>J) 
        OK = 0
    Endif
    If OK & !find([F:AMZ]CODZON,[M]FLD(0..[M]NBRFLD-1))
        NOL = [M]NBRFLD
        [M]FLD(NOL) = [F:AMZ]CODZON
        Gosub LIBEL 
        [M]NBRFLD += 1 
    Endif 
Next 
Return 

######################################################################################
$LIBEL
If [F:AMZ]INTEVAL <> ""
    Onerrgo ERRLIB
    ER = 0
    [M]INTIT(NOL) = evalue([F:AMZ]INTEVAL)
    If ER
        [M]INTIT(NOL) = [F:AMZ]INTEVAL
    Endif
    Onerrgo
Else
    Call TEXTE([F:AMZ]INTIT,LIBEL) From OBJDIV
    [M]INTIT(NOL) = LIBEL
Endif
Return

######################################################################################
$ERRLIB
ER = errn
Resume

######################################################################################
$TRI
For NOL=0 To [M]NBRFLD-1
 If [M]DAC(NOL)=0 : [M]DAC(NOL) = 9999 : Endif
Next NOL
Sorta [M]NBRFLD [M]NBRFLD Order By [M]DAC(indice)
For NOL=0 To [M]NBRFLD-1
 If [M]DAC(NOL)=9999 : [M]DAC(NOL) = 0 : Endif
Next NOL
Return

#---------------------------#
# Chargement avant le Write #
#---------------------------#
$INICRE
Gosub CHARGE_ATEXTRA From SUBMCL
Gosub PE_MFGTRS From SUBMFX
Return

#----------------------------------------#
# Création ou modif du texte traductible #
#----------------------------------------#
$CHARGE_ATEXTRA
Call MAJTEXTRA([M:MCL0]DESAXX,"BENCHTRS","DESAXX",num$([M:MCL0]BTSTYP),[M:MCL0]BTSNUM) From ATEXTRA
[F:BTS]BTSDES   =GLANGUE+"~"+[M:MCL0]DESAXX
[F:BTS]BTSTYPCAR=num$([F:BTS]BTSTYP)
Return

#################################################
$APRES_MODIF
Gosub PE_MFGTRS From SUBMFX
Return

######################################################################################
$TRT_ECRAN
If dim(APPLI)<0 Local Char APPLI : Endif
If dim(WMODU)<0 Local Char WMODU(3) :  WMODU = "T" : Endif
If APPLI=""    APPLI=nomap       : Endif
If WMODU="T"   WMODU="T"+format$("N0:2",[M:MCL0]BTSTYP) : Endif

#---------------- Noms fenêtres et traitement ---------#
Local Char     WINREF1(GLONFEN) : WINREF1="IMBT"
Local Char     NOMWIN1(GLONFEN) : NOMWIN1="WIMBT"+[M:MCL0]BTSNUM
Local Char     NOMTRT1(GLONADC) : NOMTRT1="WGIMBT"+[M:MCL0]BTSNUM
Local Char     NOMMSKENT(GLONAMK)    # Nom du masque d'entête de la fenêtre

If clalev([F:AMK2])=0 : Local File =APPLI+".AMSK"    [AMK2] : Endif
If clalev([F:AMZ2])=0 : Local File =APPLI+".AMSKZON" [AMZ2] : Endif
If clalev([F:AMA2])=0 : Local File =APPLI+".AMSKACT" [AMA2] : Endif
If clalev([F:AMP2])=0 : Local File =APPLI+".AMSKPAR" [AMP2] : Endif
If clalev([F:ADS])=0  : Local File  ADOSSIER [ADS] : Endif
Local Integer  I, NOL
Local Integer  IZON
Local Char     TZONE(GLONAVA)(200)
Local Integer  TMOD(200)
Local Char     TINT(1)(200)
Local Char     TTAB(1)(1)
Local Char     TFLD(1)(1)
Local Integer  OPT1, OPT2, OPT3, RETOUR
Local Integer  TBLOC(15)

# voir si il faut bloquer la validation ...
#If !find(ACTION,"ANNULE","MASSE")
#    If [M:MCL1]OFFLG = 1 & [M:MCL1]BOMFLG = 1    
#        Call ERREUR(mess(25,190,1)) From GESECRAN
#       Return
#    Endif 
#Endif


MFROM ="MTKBENCHT"

MTO   = "WT"+num$([M:MCL0]BTSTYP)+[M:MCL0]BTSNUM+"1"

If ACTION <> "ANNULE"
        Gosub TR1
        If GOK=1  
                Call VALID(MTO,APPLI,1,GLANGUE,1,OK) From VALMSK
        Endif
Endif
If ACTION="ANNULE" :  Call DELMSK(MTO, APPLI) From MSKDIV : Gosub TRT_SUP_FEN : Return Else Gosub TRT_GEN_FEN : Endif

Return

##########################################################################
$TR1

GOK = 1
Call DELMSK(MTO,APPLI) From MSKDIV
Read [AMK]CODMSK = MFROM
[F:AMK2] = [F:AMK]
[F:AMK2]CODMSK = MTO
[F:AMK2]MDL = 1                # !!
NCOL = 0
NCOL = find(1,[F:AMK2]TYPBLOC(0..DIM([F:AMK]TYPBLOC)-1))
If NCOL
        For J = 1 To 9
           K = instr(1,[F:AMK2]OPTION(NCOL-1),num$(J))
           If K
               [F:AMK2]OPTION(NCOL-1) = left$([F:AMK2]OPTION(NCOL-1),K-1) + 
&                                       right$([F:AMK2]OPTION(NCOL-1),K+1)
           Endif
        Next J
        If [F:BTS]NBRCOL > 0 # Gestion des colonnes fixes
            [F:AMK2]OPTION(NCOL-1) += num$([F:BTS]NBRCOL)
        Endif
        [F:AMK2]ACTBLOC(NCOL-1) = ""
        [F:AMK2]NBLIGT(NCOL-1)  = [F:BTS]NBRLIG
Endif
#     [F:AMK2]TRTAUTO = MTO
Write [AMK2]
If fstat
       GOK=0 : Call FSTA("AMK2") From GLOCK : Return
Endif

Read [AMZ]CODE = MFROM;"NBLIG"
If fstat=0 : J=[F:AMZ]NUMBLOC : Else J=0 : Endif
For [AMZ]CODZON Where CODMSK=MFROM
         NOL = find([F:AMZ]CODZON,[F:BTS]FLD(0..[F:BTS]NBRFLD-1))
         OK = 0
         If NOL & [F:BTS]DAC(NOL-1)<>0
             OK = 1 : RANG = [F:BTS]DAC(NOL-1)
         Endif
         If [F:AMZ]CODTYP="ABS"
             OK = 1 : RANG = 0
         Elsif [F:AMZ]SAIAFF=3 | (J & [F:AMZ]NUMBLOC<>J)
             OK = 1 : RANG = [F:AMZ]NOZONE
         Endif
         [F:AMZ2] = [F:AMZ]
         [F:AMZ2]CODMSK = MTO
         [F:AMZ2]NOZONE = RANG
         If [F:AMZ]CODTYP="ABS"
             [F:AMZ2]SAIAFF = 1
         Elsif !OK | [F:AMZ]SAIAFF=3  |
&             (find([F:AMZ2]CODZON,"EMPNUM","WEMPNUM","EMPDES")&[F:BTS]MATRICULE=3) 
                   [F:AMZ2]SAIAFF = 3
                   [F:AMZ2]TUNNEL = 1
                   [F:AMZ2]LIEN   = 1
         Else
             [F:AMZ2]SAIAFF = [F:AMZ]SAIAFF
         Endif
         Gosub PE_MFGTRS From SUBMFX
         If [F:AMZ2]SAIAFF=3 & [F:AMZ2]OPTFOR<>"" & left$([F:AMZ2]OPTFOR,1)<>"-"
             [F:AMZ2]OPTFOR = "-"+[F:AMZ2]OPTFOR
         Endif
         Write [AMZ2]
         If fstat
             GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
         Endif
Next

If GOK < 1 : Return : Endif
For [AMA] Where TYPAFF=1 & CODAFF=MFROM
         [F:AMA2] = [F:AMA]
         [F:AMA2]CODAFF = MTO
         Write [AMA2]
         If fstat
             GOK=0 : Call FSTA("AMA2") From GLOCK : Break
         Endif
Next
If     GOK < 0 : Return : Endif
For [AMP] Where TYPAFF=1 & CODAFF=MFROM
         [F:AMP2] = [F:AMP]
         [F:AMP2]CODAFF = MTO
         Write [AMP2]
         If fstat
             GOK=0 : Call FSTA("AMP2") From GLOCK : Break
         Endif
Next
If     GOK < 0 : Return : Endif

Return

##########################################################################
#-------------------------------------------------------------------------#
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
$TRT_SUP_FEN
#----- Suppression ----#
Call DELWIN(NOMWIN1,APPLI) From MSKDIV
Return

##########################################################################
#-------------------------------------------------------------------------#
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
$TRT_GEN_FEN
If clalev([F:AWI])=0 Local File =APPLI+".AWINDOW" [AWI] : Endif : # Si appel par le FUNMFGTRS
If clalev([F:AWP])=0 Local File =APPLI+".AWINPAR" [AWP] : Endif : # Si appel par le FUNMFGTRS
If clalev([F:AWB])=0 Local File =APPLI+".AWINBRO"  [AWB] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWT])=0 Local File =APPLI+".AWINBOUT" [AWT] : Endif : # Si appel par le FUNSTKTRS

#----- Suppression fenêtre -----#
Gosub TRT_SUP_FEN 
If [M:MCL0]ENAFLG=1 : Return : Endif

#----- Génération fenêtre pour suivi si transaction active -----#
Delete [AWI] Where WIN=NOMWIN1
If fstat=1  GOK=-1 : GLOCK="$AWINDOW"-NOMWIN1
Elsif fstat GOK=0  : Call RSTA ("AWI",NOMWIN1) From GLOCK
Endif
Delete [AWP] Where WIN=NOMWIN1
If fstat=1  GOK=-1 : GLOCK="$AWINPAR"-NOMWIN1
Elsif fstat GOK=0  : Call RSTA ("AWP",NOMWIN1) From GLOCK
Endif

Read [AWI] AWI0=WINREF1
If !fstat
  [F:AWI]WIN       = NOMWIN1
  WNOMMSK=MTO
  [F:AWI]NOMMSK(0) = WNOMMSK
  [F:AWI]ACS       = [M:MCL0]ACSCOD
  If dim([F:AWI]LIBEL)>0
      Call LECTEXTRA([F:AWI]LIBEL,"BENCHTRS","DESAXX",num$([M:MCL0]BTSTYP),[M:MCL0]BTSNUM) From ATEXTRA
  Endif
  [F:AWI]ENAFLG    = 2
  [F:AWI]TRN       = [M:MCL0]BTSNUM
  [F:AWI]MDL = 1                # !!

  # Issue 79269 - New entry Point to Hide/Show Specific Tab
  Gosub PE_MFGTRSWIN From SUBMFX 
  
  Write [AWI]
  If fstat GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
  For [AWP] AWP0 Where WIN=WINREF1
    [F:AWP]WIN = NOMWIN1
    Write [AWP]
    If fstat GOK=0 : Call FSTA("AWP") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif
  For [AWB] AWB0 Where WIN=WINREF1
    [F:AWB]WIN = NOMWIN1
    Write [AWB]
    If fstat GOK=0 : Call FSTA("AWB") From GLOCK : Break : Endif
  Next
  For [AWT] AWT0 Where WIN=WINREF1
    [F:AWT]WIN = NOMWIN1
    Write [AWT]
    If fstat GOK=0 : Call FSTA("AWT") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif

Endif
Call VALID(NOMWIN1,APPLI,1,OK) From VALWIN

Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran MCL0) 04/01/2005 16:07:42 (SR)
######################################################################################
Subprog AS_BTSNUM(VALEUR)
Variable Char    VALEUR()
[M:MCL0]BTSTYP = 66
End

Subprog AM_BTSNUM(VALEUR)
Variable Char    VALEUR()
Local Integer OK , I, NOL
Local Char    LIBEL(30) , MASKREF(GLONAMK)
Local Integer INC : INC = 0
Local Integer NBFLD

MASKREF="MTKBENCHT"
If GREP = "C" | [M:MCL2]NBRFLD = 0
    [M]NBRFLD = 0
    Gosub CHARGE_CHAMP
Endif

# activation par défaut des champs si tableau vide (création)
OK = max([M:MCL2]DAC(0..[M:MCL2]NBRFLD - 1))
If !OK  
    For I = 0 To [M:MCL2]NBRFLD-1
        INC += 5
        [M:MCL2]DAC(I) = INC
    Next I
Endif
If !GIMPORT : Affzo [M:MCL2]10 : Endif
End

Subprog AV_ENAFLG(VALEUR)
Variable Integer VALEUR
If GREP<>"C" & VALEUR=0 VALEUR=2 : Endif
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran MCL2) 06/01/2005 14:37:40 (SR)
######################################################################################
##########################################################################
## Etiquette ajoutée par le superviseur 17/09/2003 11:31:22 (MM)
##########################################################################
Subprog AS_NBRFLD
Raz GBOUT1, GBOUT2, GBOUT3
If [M:MCL2]FLD(nolign-1) <> "" 
    GBOUT1 = mess(306,198,1) 
    GBOUT2 = mess(396,198,1)
    GBOUT3 = mess(385,198,1)
Endif
End

Subprog B1_NBRFLD
Local Integer I
If [M:MCL2]DAC(nolign-1) = 0
    [M:MCL2]DAC(nolign-1) = max([M:MCL2]DAC(0..[M:MCL2]NBRFLD - 1)) + 5
    If !GIMPORT : Affzo [M:MCL2]10 : Endif
Else
    For I = 0 To [M:MCL2]NBRFLD - 1
        If [M:MCL2]DAC(I) > [M:MCL2]DAC(nolign-1) 
            [M:MCL2]DAC(I) -= 5        
        Endif
    Next I
    [M:MCL2]DAC(nolign-1) = 0
    If !GIMPORT : Affzo [M:MCL2]10 : Endif
Endif
mkstat = 4
End

Subprog B2_NBRFLD
Gosub TRI    
If !GIMPORT : Affzo [M:MCL2]10 : Endif
End

Subprog B3_NBRFLD
Local Integer I, NOL
Local Integer INC : INC = 0
Gosub TRI    
For I = 0 To [M:MCL2]NBRFLD - 1
    If [M:MCL2]DAC(I) = 0 : Break : Endif
    INC += 5
    [M:MCL2]DAC(I) = INC
Next I
If !GIMPORT : Affzo [M:MCL2]10 : Endif
End


######################################################################################


#########################################################################
# Pour éxécution validation transaction en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(7)<>2 End Endif

# Validation transactions depuis génération des patchs
Call GENPATCH(66,APPLI) From FUNMFGTRS

End

###########################################################################
# Pour éxécution validation transaction par gestion de dossier            #
#                                       par l'utilitaire de revalidation  #                                          
#      à partir du dictionnaire des types de transaction (ATN)            #
###########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI

# Génération transactions à partir du dico des types de transaction
Call GENDOS(66,APPLI) From FUNMFGTRS

End
##########################################################################

########################################################
# Pour exécution de la copie en masse depuis le menu : #
# Utilitaires - Dictionnaire - Copie transactions      #
########################################################
$TRTCOP
Local Integer MODULE    : MODULE=8
Local Integer TYP       : TYP=66
Local Char    CODTAB(GLONTRS) : CODTAB=TABLE
#-----
Gosub OUVRE_COPTRS From SELTRS
Gosub EXEC_COPTRS  From SELTRS
Gosub FERME_COPTRS From SELTRS
Return


######################################################################################
## Etiquette ajoutée par le superviseur (écran MCL1) 03/05/2005 10:12:13 (SR)
######################################################################################
Subprog C_CRIT2(VALEUR)
Variable Integer VALEUR
If VALEUR = [M:MCL1]CRIT1 : GMESSAGE = mess(144,193,1) : mkstat = 1 : End : Endif
End


######################################################################################

