#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR3 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone PSNTYP
mkstat = 0
zoncou = "PSNTYP"
indice = 0
IMPENT = [M]PSNTYP
If varinit([M]PSNTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]PSNTYP,indice)=0
 [M]PSNTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PSNTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PSNTYP(indice)
 Endif
Endif
[M]PSNTYP = IMPENT

## Zone TYPCAC
mkstat = 0
zoncou = "TYPCAC"
indice = 0
IMPENT = [M]TYPCAC
If varinit([M]TYPCAC,indice)=0
 IMPENT = 3
Endif
If varmode([M]TYPCAC,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_TYPCAC(IMPENT) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]TYPCAC(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TYPCAC" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TYPCAC(indice)
 Endif
Endif
[M]TYPCAC = IMPENT

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone STACTR
mkstat = 0
zoncou = "STACTR"
indice = 0
IMPENT = [M]STACTR
WNUM = IMPENT
If varinit([M]STACTR,indice)=0
 IMPENT = 1
Endif
If varmode([M]STACTR,indice)=0
 [M]STACTR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "STACTR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]STACTR(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_STACTR(IMPENT) From SUBCTR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "STACTR" : GZNUM = 46622 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]STACTR = IMPENT

## Zone CALPAY
mkstat = 0
zoncou = "CALPAY"
indice = 0
IMPENT = [M]CALPAY
If varinit([M]CALPAY,indice)=0
 IMPENT = 1
Endif
If varmode([M]CALPAY,indice)=0
 [M]CALPAY(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CALPAY" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CALPAY(indice)
 Endif
Endif
[M]CALPAY = IMPENT

## Zone OBJCTR
mkstat = 0
zoncou = "OBJCTR"
indice = 0
If varmode([M]OBJCTR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OBJCTR" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone LIEU
mkstat = 0
zoncou = "LIEU"
indice = 0
If varmode([M]LIEU,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LIEU" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone NBRPSN
mkstat = 0
zoncou = "NBRPSN"
indice = 0
status = 1
zoncou = "NBRPSN"
If varmode([M]NBRPSN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRPSN" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRPSN
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRPSN = nolign
   status = 75
   Call SAI_NBRPSN(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBRPSN From SUBCTR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBRPSN" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_NBRPSN(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRPSN
mkstat = 0
zoncou = "NBRPSN"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBRPSN From SUBCTR
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBRPSN" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PSNSTRDAT
mkstat = 0
zoncou = "PSNSTRDAT"
If varmode([M]PSNSTRDAT,indice)=0
 SAVACT = GACTION : GACTION = "SUBCTRLEG"
 Call BEFORE_ENTRY([M]PSNSTRDAT(indice)) From SUBCTRLEG
 GACTION = SAVACT
 If mkstat=1 : Raz [M]PSNSTRDAT(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "PSNSTRDAT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_PSNSTRDAT([M]PSNSTRDAT(indice)) From SUBCTR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PSNSTRDAT" : GZNUM = 1805 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone PSNENDDAT
mkstat = 0
zoncou = "PSNENDDAT"
If varmode([M]PSNENDDAT,indice)=0
 SAVACT = GACTION : GACTION = "SUBCTRLEG"
 Call BEFORE_ENTRY([M]PSNENDDAT(indice)) From SUBCTRLEG
 GACTION = SAVACT
 If mkstat=1 : Raz [M]PSNENDDAT(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "PSNENDDAT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "DATDEBFIN"
  Call DATDEBFIN([M]PSNENDDAT(indice),[M]PSNSTRDAT(nolign-1)) From EXEFNC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PSNENDDAT" : GZNUM = 1806 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_PSNENDDAT([M]PSNENDDAT(indice)) From SUBCTR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PSNENDDAT" : GZNUM = 1806 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone NBRDAY
mkstat = 0
zoncou = "NBRDAY"
SAVACT = GACTION : GACTION = "STD"
Call AV_NBRDAY([M]NBRDAY(indice)) From SUBCTR
GACTION = SAVACT
If mkstat=1 : Raz [M]NBRDAY(indice) : Endif

## Zone PSNSTRTIM
mkstat = 0
zoncou = "PSNSTRTIM"
If varmode([M]PSNSTRTIM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PSNSTRTIM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone PSNENDTIM
mkstat = 0
zoncou = "PSNENDTIM"
If varmode([M]PSNENDTIM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PSNENDTIM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone NBRTIM
mkstat = 0
zoncou = "NBRTIM"
If varmode([M]NBRTIM,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBRTIM([M]NBRTIM(indice)) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBRTIM(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRTIM" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If [M]NBRTIM(indice)<0
   mkstat = 1 : GMESSAGE = mess(180,141,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "NBRTIM" : GZNUM = 14433 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_NBRTIM([M]NBRTIM(indice)) From SUBCTR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NBRTIM" : GZNUM = 14433 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone NBRCAC
mkstat = 0
zoncou = "NBRCAC"
If varmode([M]NBRCAC,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBRCAC([M]NBRCAC(indice)) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBRCAC(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRCAC" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBRCAC([M]NBRCAC(indice)) From SUBCTR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBRCAC" : GZNUM = 46960 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone AMTCRG
mkstat = 0
zoncou = "AMTCRG"
If varmode([M]AMTCRG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "AMTCRG" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone AMTCRGEXO
mkstat = 0
zoncou = "AMTCRGEXO"
If varmode([M]AMTCRGEXO,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "AMTCRGEXO" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone AMTBUD
mkstat = 0
zoncou = "AMTBUD"
If varmode([M]AMTBUD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "AMTBUD" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_AMTBUD([M]AMTBUD(indice)) From SUBCTR
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "AMTBUD" : GZNUM = 5443 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone NBRPSN
mkstat = 0
zoncou = "NBRPSN"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CTR3"
Return

