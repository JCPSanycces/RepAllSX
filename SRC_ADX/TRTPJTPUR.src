End
###################################################################################################
#                                                                                                 #
# TRTPJTPUR :     TRAITEMENTS LIES au PJT dans les ACHATS                                         #
#                                                                                                 #
###################################################################################################
####################################################################################################
$ACTION
  Case PJTACTION
     When "PJT_AFTER_MODIFY"        : Gosub PJT_AFTER_MODIFY
     When "PJTSNGDOC"               : Gosub PJTSNGDOC # Issue 71069 - 2016-06-20 by MUARN : simuler multi-affaire
     When Default
  Endcase
Return

####################################################################################################
$PJT_AFTER_MODIFY
# Issue X3-3807 - 2017-10-23 by MUARN : Update project dimension /mise à jour axe analityque après modif PJT
Local Integer WPJMDIENUM        : # N° de l'axe géré à l'affaire/Number of dimension type managed by project
Local Char    WCCEZON           : # Nom du champ de la section à initialiser/Dimension field name
Local Char    WVALPJT(GLONPJT)
# End issue X3-3807

  If ZONDET <> "" Then
    # Si ZONDET est alimenté : c'est qu'on est sur l'entête.
    If func TRTPJT.GET_PARAM_PJTSNGDOC(SITE) = G_OUI Then
      Global Char GPJTACTMOD(GLONDES)

      GPJTACTMOD = "1"
    Endif

    # Issue X3-3807 - 2017-10-23 by MUARN : Update project dimension /mise à jour axe analityque après modif PJT
    # Code activité PJM actif et il existe un axe géré à l'affaire
    # Active activity code PJM and a dimension type is managed by project
    If func ASYRFNC.ACTIV("PJM") & GPJMDIE <> ""
      # Récupérer le n° de l'axe/Search for the dimension type number
      WPJMDIENUM=find(GPJMDIE,GDIE(1..GNBDIE))
      # Issue X3-3807 - 2017-10-23 by MUARN : Update project dimension /mise à jour axe analityque après modif PJT
      # Alimenter [M]PJT avec la nouvelle valeur zc car l'initialisation des sections INISEC utilise [M]PJT
      # [M]PJT is loaded with the new value zc because dimension initialization INISEC uses [M]PJT
      WVALPJT = evalue ("[M:"+CODMSK+"]"+FLDNAM)
      Assign "[M:"+CODMSK+"]"+FLDNAM With AZC
      Case CODMSK
        When "POH1"
          If dim([M:POH3]NBFAC) > 0
            For I=0 To [M:POH3]NBFAC-1
              If [M:POH3]DSP(I) = ""
                WCCEZON = "[M:POH3]PFICCE"+num$(WPJMDIENUM)+"(I)"
                nolign = I + 1
                Read [PFI] PFI0=[M:POH3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
                Call INIT_CCE(WSECTION,WPJMDIENUM,"POV","[M:POH3]ACC",I) From TRTX3CPT
                Assign WCCEZON With WSECTION
              Endif
            Next I
            If !GIMPORT : Affzo [M:POH3]5 : Endif
          Endif

        When "PTH0"
          If dim([M:PTH2]NBFAC) > 0
            For I=0 To [M:PTH2]NBFAC-1
              If [M:PTH2]DSP(I) = ""
                WCCEZON = "[M:PTH2]PFICCE"+num$(WPJMDIENUM)+"(I)"
                nolign = I + 1
                Read [PFI] PFI0=[M:PTH2]INVDTA(I) : If fstat Raz [F:PFI] : Endif
                Call INIT_CCE(WSECTION,WPJMDIENUM,"PTV","[M:PTH2]ACC",I) From TRTX3CPT
                Assign WCCEZON With WSECTION
              Endif
            Next I
          Endif
          If !GIMPORT : Affzo [M:PTH2]5 : Endif
        When "PIH1"
          If dim([M:PIH4]NBFAC) > 0
            For I=0 To [M:PIH4]NBFAC-1
              If [M:PIH4]DSP(I) = ""
                WCCEZON = "[M:PIH4]PFICCE"+num$(WPJMDIENUM)+"(I)"
                nolign = I + 1
                Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [F:PFI] : Endif
                Call INIT_CCE(WSECTION,WPJMDIENUM,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
                Assign WCCEZON With WSECTION
              Endif
            Next I
          Endif
          If !GIMPORT : Affzo [M:PIH4]5 : Endif
        When Default
      Endcase
      # Réalimenter [M]DPJT avec l'ancienne valeur
      # [M]DPJT is reloaded with the old value
      Assign "[M:"+CODMSK+"]"+FLDNAM With WVALPJT
    Endif
    # End issue X3-3807

  Endif
  # ----------------------------------------------------
  If ZONHEAD <> "" Then
    # Si ZONHEAD est alimenté : c'est qu'on est sur le détail
    Global Char GPJTACTMOD(GLONDES)
  Endif

  # Issue X3-3807 - 2017-10-23 by MUARN : Update project dimension /mise à jour axe analityque après modif PJT
  If ZONDET = "" and ZONHEAD = "" Then
    If func ASYRFNC.ACTIV("PJM") & GPJMDIE <> ""
      # Récupérer le n° de l'axe/Search for the dimension type number
      WPJMDIENUM=find(GPJMDIE,GDIE(1..GNBDIE))
      # Alimenter [M]PJT avec la nouvelle valeur zc car l'initialisation des sections INISEC utilise [M]PJT
      # [M]PJT is loaded with the new value zc because dimension initialization INISEC uses [M]PJT
      WVALPJT = evalue ("[M:"+CODMSK+"]"+FLDNAM)
      Assign "[M:"+CODMSK+"]"+FLDNAM With AZC
      Case CODMSK
        When "POC1"
          # Open order
          If dim([M:POC3]NBFAC) > 0
            For I=0 To [M:POC3]NBFAC-1
              If [M:POC3]DSP(I) = ""
                WCCEZON = "[M:POC3]PFICCE"+num$(WPJMDIENUM)+"(I)"
                nolign = I + 1
                Read [PFI] PFI0=[M:POC3]INVDTA(I) : If fstat Raz [F:PFI] : Endif
                Call INIT_CCE(WSECTION,WPJMDIENUM,"POCV","[M:POC3]ACC",I) From TRTX3CPT
                Assign WCCEZON With WSECTION
              Endif
            Next I
            If !GIMPORT : Affzo [M:POC3]5 : Endif
          Endif
        When "SCO1"
          # subcontract order
          # matières
          If dim([M:SCO2]NBLIG) > 0
            For I = 0 To [M:SCO2]NBLIG - 1
              WCCEZON = "[M:SCO2]CCE"+num$(WPJMDIENUM)+"(I)"
              nolign = I + 1
              Read [ITM] ITM0=[M:SCO2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
              Call INIT_CCE(WSECTION,WPJMDIENUM,"SCM","",I) From TRTX3CPT
              Assign WCCEZON With WSECTION
            Next I
            If !GIMPORT : Affzo [M:SCO2]5 : Endif
          Endif
          # service
          If dim([M:SCO3]NBDIE)>0
            # Retrouver l'indice de l'axe / It is necessary to find the dimension type indice
            WI=find(GPJMDIE,[M:SCO3]DIE(0..[M:SCO3]NBDIE-1))
            If WI>0
              WCCEZON = "[M:SCO3]CCE"+"([L]WI-1)"
              Assign WCCEZON With ""
              Call INISEC([L]WSECTION,"SCS",GPJMDIE) From SUBCDE
              Assign WCCEZON With [L]WSECTION
              If !GIMPORT : Affzo [M:SCO3]30 : Endif
            Endif
          Endif
        When "POI1"
          # Buyer plan
          If FLDNAM = "PJT"
            WCCEZON = "[M:POI1]CCE"+num$(WPJMDIENUM)+"(nolign-1)"
            #nolign = I + 1
            Call INIT_CCE(WSECTION,WPJMDIENUM,"POID","[M:POI1]LINACC",nolign-1) From TRTX3CPT
            Assign WCCEZON With WSECTION
          Endif
        When Default
      Endcase

      # Réalimenter [M]PJT avec l'ancienne valeur pour que le répercussion entête ligne fonctionne
      # [M]PJT is reloaded with the old value in order that repercussion header line works
      Assign "[M:"+CODMSK+"]"+FLDNAM With WVALPJT

    Endif
  Endif
  # End issue X3-3807
Return

####################################################################################################
#
##################################################################################################
#                                                                                                #
# Etiquettes appelées par SUBPPC : Paramétrage des tarifs achat                                  #
#                                                                                                #
#  Création temporaire dans AMSKPAR des données pour le type de données PJT (pour masque de base)#
#                                                                                                #
#  $CRE_AMP_ATY_PJT      : Déclaration des paramètres des actions et appel au étiquettes         #
#  $CRE_AMP_PJT_COMMUN   : Création des paramètres communs à ts les chps de type de données PJT  #
#  $CRE_AMP_PJTNUM       : Création des paramètres propres au chp PJTNUM (Code affaire seul)     #
#  $CRE_AMP_PJT          : Création des paramètres propres au chp PJT (Code affaire complet)     #
#  $CRE_AMP_WRITE        : Création de l'enregistrement dans AMSKPAR                             #
#                                                                                                #
#  Suppression dans AMSKPAR des données pour le type de données PJT                              #
#                                                                                                #
#  $SUP_AMP_PJT          : Suppression des enregistrements dans AMSKPAR                          #
#                                                                                                #
#  Suppression dans AMSKACT des données pour le type de données PJT                              #
#                                                                                                #
#  $SUP_AMA_PJT          : Suppression des enregistrements dans AMSKACT                          #
#                                                                                                #
#  Controle en saisie du paramétrage des tarifs :                                                #
#                                                                                                #
#  Ctrl en saisie des champs critères :                                                          #
#  $CTL_FLD_PJT          : PJT et PJTNUM de PPRICLINK sont exclusifs                             #                                                                                                #
#                                                                                                #
##################################################################################################

#  Déclaration des paramètres des actions et appel au étiquettes
$CRE_AMP_ATY_PJT

# Tableau des paramètres des actions du type de données PJT
Local Char WCODPAR(GLONAAR) (0..20)
WCODPAR(0)  = "CODMSK"        : # Ecran
WCODPAR(1)  = "FLDNAM"        : # Nom zone courante
WCODPAR(2)  = "NOLIG"         : # N° de la ligne courante
WCODPAR(3)  = "MODULE"        : # Module
WCODPAR(4)  = "BOOCRM"        : # Booléen CRM
WCODPAR(5)  = "BOOPRP"        : # Booléen PRP
WCODPAR(6)  = "BOOPRPBUD"     : # Booléen PRP Budget
WCODPAR(7)  = "BOOPRPTAC5"    : # Booléen PRP Taches MO
WCODPAR(8)  = "BOOPRPTAC6"    : # Booléen PRP Taches MAC
WCODPAR(9)  = "BOOPRPTAC7"    : # Booléen PRP Taches Mixte
WCODPAR(10) = "USEDISPRP"     : # Autoriser affaires inactives
WCODPAR(11) = "USEDISBUD"     : # Autoriser budgets inactifs
WCODPAR(12) = "USEDISTAC"     : # Autoriser taches inactives
WCODPAR(13) = "SITE"          : # Site
WCODPAR(14) = "BPR"           : # Tiers
WCODPAR(15) = "INTERLOC"      : # Interlocuteur
WCODPAR(16) = "ZONHEAD"       : # Zone entête
WCODPAR(17) = "ZONDET"        : # Zone détail
WCODPAR(18) = "SOCIETE"       : # Société

Local Integer WIND_FLD

Case [F:PPC]FLD(I-1)
     When "PJTNUM"     :
        Gosub CRE_AMP_PJT_COMMUN
        Gosub CRE_AMP_PJTNUM
     When "PJT"        :
        Gosub CRE_AMP_PJT_COMMUN
        Gosub CRE_AMP_PJT
    When Default
Endcase

Return

# ---------------------------------------------------------------------------------
#  Création des paramètres qui sont communs à ts les champs de type de données PJT
#  --> PJT : Code affaire complet et PJTNUM : Code affaire sans lot budgétaire
$CRE_AMP_PJT_COMMUN

[F:AMP]CODPAR = WCODPAR(0)      : # Ecran
[F:AMP]VALPAR = '"'+MFROM+'"'
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(1)      : # Nom zone courante
[F:AMP]VALPAR = '"CRIT'+num$(I)+'"'
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(2)      : # N° de la ligne courante
[F:AMP]VALPAR = "nolign-1"
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(3)      : # Module
[F:AMP]VALPAR = "6"
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(4)      : # Booléen CRM
[F:AMP]VALPAR = "[V]CST_AYES"
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(5)      : # Booléen PRP
[F:AMP]VALPAR = "[V]CST_AYES"
Gosub CRE_AMP_WRITE

[F:AMP]CODPAR = WCODPAR(10)     : # Autoriser affaires inactives
[F:AMP]VALPAR = "G_NON"
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(11)     : # Autoriser budgets inactifs
[F:AMP]VALPAR = "G_NON"
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(12)     : # Autoriser taches inactives
[F:AMP]VALPAR = "G_NON"
Gosub CRE_AMP_WRITE

[F:AMP]CODPAR = WCODPAR(13)     : # Site
[F:AMP]VALPAR = '""'
# Si le site d'achat est paramétré comme critère de tarif, on l'utilise comme filtre pour le code affaire
WIND_FLD=find("POHFCY",[F:PPC]FLD(0..dim([F:PPC]FLD)-1))
If WIND_FLD
   [F:AMP]VALPAR = "[M]CRIT"+num$(WIND_FLD)+"(nolign-1)"
Endif
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(14)     : # Tiers
[F:AMP]VALPAR = '""'
# Si le fournisseur est paramétré comme critère de tarif, on l'utilise comme filtre pour le code affaire
WIND_FLD=find("BPSNUM",[F:PPC]FLD(0..dim([F:PPC]FLD)-1))
If WIND_FLD
   [F:AMP]VALPAR = "[M]CRIT"+num$(WIND_FLD)+"(nolign-1)"
Endif
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(15)     : # Interlocuteur
[F:AMP]VALPAR = '""'
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(16)     : # Zone entête
[F:AMP]VALPAR = '""'
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(17)     : # Zone détail
[F:AMP]VALPAR = '""'
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(18)     : # Société
[F:AMP]VALPAR = '""'
# Si la société est paramétrée comme critère de tarif, on l'utilise comme filtre pour le code affaire
WIND_FLD=find("CPY",[F:PPC]FLD(0..dim([F:PPC]FLD)-1))
If WIND_FLD
   [F:AMP]VALPAR = "[M]CRIT"+num$(WIND_FLD)+"(nolign-1)"
Endif
Gosub CRE_AMP_WRITE
Return

# ---------------------------------------------------------------------------------------------
#  Création des paramètres qui sont propres au champ PJTNUM : Code affaire sans lot budgétaire
$CRE_AMP_PJTNUM


[F:AMP]CODPAR = WCODPAR(6)      : # Booléen PRP Budget
[F:AMP]VALPAR = "[V]CST_ANO"
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(7)      : # Booléen PRP Taches MO
[F:AMP]VALPAR = "[V]CST_ANO"
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(8)      : # Booléen PRP Taches MAC
[F:AMP]VALPAR = "[V]CST_ANO"
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(9)      : # Booléen PRP Taches Mixte
[F:AMP]VALPAR = "[V]CST_ANO"
Gosub CRE_AMP_WRITE

Return

# ---------------------------------------------------------------------------------------------
#  Création des paramètres qui sont propres au champ PJT : Code affaire complet
$CRE_AMP_PJT

[F:AMP]CODPAR = WCODPAR(6)      : # Booléen PRP Budget
[F:AMP]VALPAR = "[V]CST_AYES"
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(7)      : # Booléen PRP Taches MO
[F:AMP]VALPAR = "[V]CST_ANO"
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(8)      : # Booléen PRP Taches MAC
[F:AMP]VALPAR = "[V]CST_AYES"
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR(9)      : # Booléen PRP Taches Mixte
[F:AMP]VALPAR = "[V]CST_AYES"
Gosub CRE_AMP_WRITE

Return

#  Création de l'enregistrement dans AMSKPAR
$CRE_AMP_WRITE
[F:AMP]TYPAFF = 1
[F:AMP]CODAFF = MFROM
[F:AMP]CODZON = "CRIT"+num$(I)
Write [AMP]
If fstat
   GOK = 0 : Call FSTA("AMP") From GLOCK : Return
Endif
Return

# ---------------------------------------------------------------------------------------------
# Suppression des paramètres dans AMSKPAR
$SUP_AMP_PJT
Local Integer WIND_PJT

For WIND_PJT=0 To dim(WCODPAR)-1
    If WCODPAR(WIND_PJT)="" Break Endif
    Delete [F:AMP] Where TYPAFF=1 & CODAFF=MFROM & CODZON="CRIT"+num$(I) & CODPAR=WCODPAR(WIND_PJT)
Next

Return

# ---------------------------------------------------------------------------------------------
# Suppression des actions dans AMSKACT
$SUP_AMA_PJT
# Suppression des actions qui se trouvent sur l'écran PPLW pour les chps CRIT1 à CRIT5
# et qui seront remplacées par les actions du type de données PJT

# Sur tous les champs critère :
# Suppression de l'action IB_
Update [AMA] Where ACTION="STD" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=1
&                    With CODAFF="PPLW_"
# Suppression de l'action AS_
Update [AMA] Where ACTION="STD" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=4
&                    With CODAFF="PPLW_"
# Suppression de l'action C_
Update [AMA] Where ACTION="STD" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=5
&                    With CODAFF="PPLW_"
# Suppression de l'action B1_
Update [AMA] Where ACTION="GOBJETC" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=9
&                    With CODAFF="PPLW_"

# Sur le 1er champ critère CRIT1
If I=1
  # Suppression des boutons B2 à B4
  Update [AMA] Where ACTION="STD" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=10
&                      With CODAFF="PPLW_"
  Update [AMA] Where ACTION="STD" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=11
&                      With CODAFF="PPLW_"
  Update [AMA] Where ACTION="STD" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=12
&                      With CODAFF="PPLW_"
  # Suppression des boutons B5 à B8
  Update [AMA] Where ACTION="STD" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=15
&                      With CODAFF="PPLW_"
  Update [AMA] Where ACTION="STD" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=16
&                      With CODAFF="PPLW_"
  Update [AMA] Where ACTION="STD" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=17
&                      With CODAFF="PPLW_"
  Update [AMA] Where ACTION="STD" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=18
&                      With CODAFF="PPLW_"
Endif
Return

# Vérification exclusivité entre les champs PJT et PJTNUM
$C_FLD_PJT
Local Integer WI

If [M:PPC1]FIL(NOL)="PPRICLINK" & find(VALEUR, "PJT", "PJTNUM")
  For WI=0 To [M:PPC1]BASTAB-1
    If WI<>NOL & (([M:PPC1]FIL(WI)="PPRICLINK" & [M:PPC1]FLD(WI)="PJT"    & VALEUR="PJTNUM") |
&                 ([M:PPC1]FIL(WI)="PPRICLINK" & [M:PPC1]FLD(WI)="PJTNUM" & VALEUR="PJT"))
      GMESSAGE=[M:PPC1]FIL(WI)+":"+[M:PPC1]FLD(WI)+"\"+[M:PPC1]FIL(NOL)+":"+VALEUR-"\"-mess(587,199,1)
      mkstat=2 : Break
    Endif
  Next
Endif

Return

# Issue 71069 - 2016-06-20 by MUARN : simuler multi-affaire
####################################################################################################
$PJTSNGDOC
  IPJTSNGDOC = [V]CST_ANO
Return

# Issue X3-3807 - 2017-10-11 by MUARN : Update project dimension /mise à jour axe analityque après modif PJT
# ---------------------------------------------------------------------------------------------
# Alimentation des paramètres nécessaires/Supply of necessary parameters
# ---------------------------------------------------------------------------------------------
# Le type de données PJT a atteint la limite du nbre de parameter/Data type PJT has readched the limit of the number of parameters
$GET_PARAM_CCEH

# WPJT_INIT_CCEH  : # Flag init section à l'entête (1 Non/2 Oui)/Flag for init header dimension (1 No/2 Yes)

# WPJT_INIT_CCED  : # Flag init section à la ligne (1 Non/2 Oui)/Flag for init line dimension (1 No/2 Yes)

# WCCEBASTAB      : # Nom de la variable bas de tableau des sections/Grid variable dimension name
#   Or
# WCCEFIC         : # Nom du fichier des sections/Dimension file name

# WCCESECDEF      : # Section par défaut/Default dimension

# Cas particulier ZONDET ZONHEAD sont à blc/Particular case ZONDET ZONHEAD are not empty
# Mettre WPJT_INIT_CCED = 2 si on veut initialiser les sections à la ligne et alimenter SBASTAB
# Put WPJT_INIT_CCED = 2 if we want to initialize sections on the lines and and fed SBASTAB

Case CODMSK
  When "POH1"
    # Orders
    WPJT_INIT_CCEH = 2
    WCCEBASTAB = "[M:POH1]NBAXE"
    WCCESECDEF = "POH"
  When "POI1"
    # Buyer plan
    WPJT_INIT_CCEH = 2
    WCCEBASTAB = "[M:POI1]NBAXE"
    WCCESECDEF = "POI"
  When "POC1"
    # Open order
    WPJT_INIT_CCEH = 2
    WPJT_INIT_CCED = 1
    WCCEBASTAB = "[M:POC1]NBAXE"
    WCCESECDEF = "POH"
  When "POC2PWP"
    # Open order
    # For Price lines From Open order
    WPJT_INIT_CCEH = 2
    WPJT_INIT_CCED = 1
    WCCEFIC    = "[F:PWP]"
    WCCESECDEF = "POC"
  When "PTH0"
    # Receipt
    WPJT_INIT_CCEH = 2
    WCCEBASTAB = "[M:PTH0]NBAXE"
    WCCESECDEF = "PTH"
  When "PIH1"
    # Invoices
    WPJT_INIT_CCEH = 2
    WCCEBASTAB = "[M:PIH1]NBAXE"
    WCCESECDEF = "PIH"
  When "PNH1"
    # Returns
    WPJT_INIT_CCEH = 2
    WCCEBASTAB = "[M:PNH1]NBAXE"
    WCCESECDEF = "PNH"
  When "SCO1"
    # subcontract order
    WPJT_INIT_CCEH = 2
    WCCEBASTAB = "[M:SCO1]NBDIE"
    WCCESECDEF = "SCI"
  When Default
Endcase

Return

# ---------------------------------------------------------------------------------------------
# Alimentation des paramètres nécessaires/Supply of necessary parameters
# ---------------------------------------------------------------------------------------------
# Le type de données PJT a atteint la limite du nbre de parameter/Data type PJT has readched the limit of the number of parameters
$GET_PARAM_CCED

# WPJT_INIT_CCED  : # Flag init section à la ligne (1 Non/2 Oui)/Flag for init line dimension (1 No/2 Yes)

# WCCESECDEF      : # Section par défaut/Default dimension

Case WCCEMSK
  When "PSH1"
    # Quotes
    WPJT_INIT_CCED = 2
    WCCESECDEF = "PSD"
  When "POH2"
    # Orders
    WPJT_INIT_CCED = 2
    WCCESECDEF = "POP"
  When "POH3"
    # Orders
    WPJT_INIT_CCED = 2
    WCCESECDEF = "POV"
  When "POI1"
    # Buyer plan
    WPJT_INIT_CCED = 2
    WCCESECDEF = "POID"
  When "POC2"
    # Open order
    # For Price lines From Product button when entry of project code
    WPJT_INIT_CCED = 2
    WCCESECDEF = "POC"
  When "PTH1"
    # Receipt
    WPJT_INIT_CCED = 2
    WCCESECDEF = "PTD"
  When "PIH3"
    # Invoices
    WPJT_INIT_CCED = 2
    WCCESECDEF = "PID"
  When "PNH1"
    # Returns
    WPJT_INIT_CCED = 2
    WCCESECDEF = "PND"
  When Default
Endcase

Return
# End issue X3-3807

