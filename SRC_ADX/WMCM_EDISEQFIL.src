#<AdxTL>@(#)0.0.0.0 $Revision$Class Sequential file
# Supervisor
## ACLA-CLASSE ## EDISEQFIL
# 2018-11-06 07:05:05 491

#-------------------------------------------------------#
$METHODS
$EVENTS
Case [L]AEVENT
 When "ADDLINE_AFTER"
  Case [L]CURPTH
   When "ESFD"
    [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGCOD","$namProParent","MSGCOD")
    this.MSGCOD = this.APARENT.MSGCOD
    [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGREL","$namProParent","MSGREL")
    this.MSGREL = this.APARENT.MSGREL
    [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGFILNOR","$namProParent","MSGFILNOR")
    this.MSGFILNOR = this.APARENT.MSGFILNOR
   When "ESFF"
    [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGCOD","$namProParent","MSGCOD")
    this.MSGCOD = this.APARENT.MSGCOD
    [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGREL","$namProParent","MSGREL")
    this.MSGREL = this.APARENT.MSGREL
    [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGFILNOR","$namProParent","MSGFILNOR")
    this.MSGFILNOR = this.APARENT.MSGFILNOR
   When Default
  Endcase
 When Default
Endcase
Return

#-------------------------------------------------------#
$PROPERTIES
Local Integer ALINE
Case [L]CURPRO
 When "MSGCOD" : Gosub PRO_MSGCOD
 When "MSGREL" : Gosub PRO_MSGREL
 When "MSGFILNOR" : Gosub PRO_MSGFILNOR
Endcase
Return

#-------------------------------------------------------#
$PRO_MSGCOD
Case [L]ARULE
 When "PROPAGATE"
  For ALINE=1 to maxtab(this.ESFD)
   If this.ESFD([L]ALINE)<>null
    this.ESFD([L]ALINE).MSGCOD = this.MSGCOD
   Endif
  Next
  For ALINE=1 to maxtab(this.ESFF)
   If this.ESFF([L]ALINE)<>null
    this.ESFF([L]ALINE).MSGCOD = this.MSGCOD
   Endif
  Next
Endcase
Return

#-------------------------------------------------------#
$PRO_MSGREL
Case [L]ARULE
 When "PROPAGATE"
  For ALINE=1 to maxtab(this.ESFD)
   If this.ESFD([L]ALINE)<>null
    this.ESFD([L]ALINE).MSGREL = this.MSGREL
   Endif
  Next
  For ALINE=1 to maxtab(this.ESFF)
   If this.ESFF([L]ALINE)<>null
    this.ESFF([L]ALINE).MSGREL = this.MSGREL
   Endif
  Next
Endcase
Return

#-------------------------------------------------------#
$PRO_MSGFILNOR
Case [L]ARULE
 When "PROPAGATE"
  For ALINE=1 to maxtab(this.ESFD)
   If this.ESFD([L]ALINE)<>null
    this.ESFD([L]ALINE).MSGFILNOR = this.MSGFILNOR
   Endif
  Next
  For ALINE=1 to maxtab(this.ESFF)
   If this.ESFF([L]ALINE)<>null
    this.ESFF([L]ALINE).MSGFILNOR = this.MSGFILNOR
   Endif
  Next
Endcase
Return



