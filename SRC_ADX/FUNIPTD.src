#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","FUNIPTD","IIPTD",3,"") From GTRAITE
End

#########################################################################
#                                                                       #
#     UTILITAIRE de MODIFICATION de la DATE D'IMPUTATION                #
#     des MOUVEMENTS de STOCK                                           #
#                                                                       #
#     - Traitement : FUNIPTD                                            #
#     - Action     : SAIIPTD  (Traitement standard)                     #
#                                                                       #
#########################################################################
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "INIT"    : Gosub INIT
 When "EXEC"    : Gosub EXEC
 When "TERMINE" : Gosub TERMINE
 When Default
Endcase
Return

#--------------------------------------------------
$INIT
If !clalev([F:PER])   : Local File =GTABCPT+"PERIOD" [PER] : Endif
If !clalev([F:STJ])   : Local File STOJOU     [STJ]  : Endif
If !clalev([F:STJ1])  : Local File STOJOU     [STJ1] : Endif
If !clalev([F:STJ2])  : Local File STOJOU     [STJ2] : Endif
If !clalev([F:STR])   : Local File STOTRK     [STR]  : Endif
If !clalev([F:SJV])   : Local File STOJOUVAL  [SJV]  : Endif
If !clalev([F:ITM])   : Local File ITMMASTER  [ITM]  : Endif
If !clalev([F:ITH])   : Local File ITMMVTHIS  [ITH]  : Endif
If !clalev([F:ITH1])  : Local File ITMMVTHIS  [ITH1] : Endif
If !clalev([F:MWI])   : Local File WIPCOST    [MWI]  : Endif
If !clalev([F:SMH])   : Local File SMVTH      [SMH]  : Endif
If !clalev([F:SMD])   : Local File SMVTD      [SMD]  : Endif
If GMODU(6)=2
  If !clalev([F:PTH]) : Local File PRECEIPT   [PTH]  : Endif
  If !clalev([F:PTD]) : Local File PRECEIPTD  [PTD]  : Endif
  If !clalev([F:POH]) : Local File PORDER     [POH]  : Endif
Endif
If GMODU(5)=2
  If !clalev([F:SRH]) : Local File SRETURN    [SRH]  : Endif
  If !clalev([F:SRD]) : Local File SRETURND   [SRD]  : Endif
Endif
If GMODU(8)=2
  If !clalev([F:MTK]) : Local File MFGHEADTRK [MTK]  : Endif
  If !clalev([F:MKI]) : Local File MFGITMTRK  [MKI]  : Endif
  If !clalev([F:MKM]) : Local File MFGMATTRK  [MKM]  : Endif
  If !clalev([F:MKO]) : Local File MFGOPETRK  [MKO]  : Endif
  If !clalev([F:MFG]) : Local File MFGHEAD    [MFG]  : Endif
Endif

# Pour annulation pièce comptable ANUPCE
If GMODU(2)=2
  If clalev([F:BAL])=0 : Local File BALANCE    [BAL] : Endif
  If clalev([F:BLA])=0 : Local File BALANA     [BLA] : Endif
  If clalev([F:BLQ])=0 : Local File BLAQTY     [BLQ] : Endif
  If clalev([F:TVD])=0 : Local File TRCVCRDOC  [TVD] : Endif
Endif
If GMODU(6)=2
  If clalev([F:PIH])=0 : Local File PINVOICE   [PIH] : Endif
  If clalev([F:PID])=0 : Local File PINVOICED  [PID] : Endif
Endif
If GMODU(3)=2
   If clalev([F:PYD])=0 : Local File PAYMENTD   [PYD] : Endif
Endif
If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:MVS])=0 : Local File BPSUPPMVT  [MVS] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:TCH])=0 : Local File TABCHANGE  [TCH] : Endif
If clalev([F:ACV])=0 : Local File ACTIV      [ACV] : Endif
If GMODU(2)=2
  Local File GACCENTRY [HAE] , GACCENTRYD [DAE], GACCENTRYA [DAA] , GACCENTRYD [DAE0]
  Local File GACCENTRY [HAE2]
Endif
#If GIAS
# If clalev([F:BIA])=0 : Local File BALANCEIAS [BIA]   : Endif
# Local File GACEIAS [HIA], GACEIASD [DIA]
#Endif
Return

#--------------------------------------------------
$EXEC
Local Integer LRET

Call OUVRE_TRACE(mess(105,196,1)) From LECFIC

WMSG = mess(105,196,1)
Call ECR_TRACE(WMSG,0) From GESECRAN
Call ECR_TRACE(mess(174,100,1),-1) From GESECRAN
Call PRTSCR("IPTD","","",0,1) From ATRTX3
Call ECR_TRACE(mess(51,9010,1),-1) From GESECRAN

Call MAJ_IPTDAT([M:DIA]VCRTYP,[M:DIA]VCRNUM,[M:DIA]NEWDAT,LRET)

Return

#--------------------------------------------------
$TERMINE
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
Call IMPSCR      From ATRTX3

Return

#--------------------------------------------------
# Traitement de changement de la date d'imputation
#--------------------------------------------------
# LRET =  0         Ok
# LRET =  1 .. 89   Erreur
# LRET = 99         Non traité --> suivant
#--------------------------------------------------
Subprog MAJ_IPTDAT(LTYP,LNUM,LDAT,LRET)
Value    Integer LTYP
Value    Char    LNUM
Value    Date    LDAT
Variable Integer LRET

Local    Char    WSTOFCY(GLONFCY)
Local    Char    WITM(GLONITM)
Local    Decimal WPRI
Local    Date    WIPTDAT
Local    Date    WPERSTR
Local    Decimal LEXE, LPER
Local    Decimal WQTY, WAMT, WEVA
Local    Integer LLIN, WMVT
Local    Integer WSEQ, WSEQ1, WSEQ2
Local    Char    WMESS(80)
Raz LRET

Gosub INIT

Trbegin [STJ]

Case LTYP
 When  6      : Gosub TRT6
 When 13      : Gosub TRT13
 When 15      : Gosub TRT15
 When 19      : Gosub TRT19
 When Default
Endcase

If LRET=0
#X3-59820.n - Modified below from mess(2,786,1) to mess(2,795,1) (2,786 was changed to read "Accounting date")
   WMESS=mess(2,795,1)-":"-mess(219,190,1)-format$("DD2",WIPTDAT)-"-"-
&        mess(220,190,1)-format$("DD2",LDAT)
   Call ECR_TRACE(WMESS,0) From GESECRAN
   Commit
Else
   Rollback
   If LRET<>99
      Call ECR_TRACE(WMESS,1) From GESECRAN
   Endif
Endif

End

#----------------------
# Réceptions
#----------------------
$TRT6
WMESS="*---"-mess(117,198,1)-LNUM
Call ECR_TRACE(WMESS,0) From GESECRAN
Readlock [PTH]PTH0=LNUM
If fstat
   WMESS=mess(60,9151,1)-"PRECEIPT : "-LNUM
   LRET= 1 : Return
# Pas de traitement des réceptions inter-sites
Elsif [F:PTH]BETFCY=2
   LRET=99 : Return
Endif

WSTOFCY = [F:PTH]PRHFCY
WIPTDAT = [F:PTH]RCPDAT

#--- Issue 94281
Filter [STJ] Where STOFCY=WSTOFCY & VCRTYP=LTYP & VCRNUM=LNUM
&            Order By Key STJ1
For [STJ]
  WIPTDAT=[F:STJ]IPTDAT : Break
Next
Filter [STJ]
#---

For [PTD] Where PTHNUM=LNUM
   LLIN=[F:PTD]PTDLIN
   WITM=[F:PTD]ITMREF
   # Maj ITMMVTHIS si nécessaire
   Gosub MAJ_ITH
   If LRET Break Endif
   # Traitement des mouvements de stock de la ligne
   Gosub TRT_STJ
   If LRET Break Endif
Next
If LRET Return Endif

Update [PTD] Where PTHNUM=LNUM With RCPDAT=LDAT
If fstat
   WMESS=mess(143,7774,1)-"PRECEIPTD : "-LNUM
   LRET=21 : Return
Endif

[F:PTH]RCPDAT = LDAT
Rewrite [PTH]
If fstat
   WMESS=mess(143,7774,1)-"PRECEIPT : "-LNUM
   LRET=11 : Return
Endif

Return

#----------------------
# Retours clients
#----------------------
$TRT13
WMESS="*---"-mess(458,198,1)-LNUM
Call ECR_TRACE(WMESS,0) From GESECRAN
Readlock [SRH]SRH0=LNUM
If fstat
   WMESS=mess(60,9151,1)-"SRETURN : "-LNUM
   LRET=2 : Return
# Pas de traitement des retour de prêt ou inter-sites
Elsif [F:SRH]LNDRTN=2 | [F:SRH]BETFCY=2
   LRET=99 : Return
Endif

WSTOFCY = [F:SRH]STOFCY
WIPTDAT = [F:SRH]RTNDAT
For [SRD] Where SRHNUM=LNUM
   LLIN=[F:SRD]SRDLIN
   WITM=[F:SRD]ITMREF
   # Maj ITMMVTHIS si nécessaire
   Gosub MAJ_ITH
   If LRET Break Endif
   # Traitement des mouvements de stock de la ligne
   Gosub TRT_STJ
   If LRET Break Endif
Next
If LRET Return Endif

Update [SRD] Where SRHNUM=LNUM With RTNDAT=LDAT
If fstat
   WMESS=mess(143,7774,1)-"SRETURND : "-LNUM
   LRET=22 : Return
Endif

[F:SRH]RTNDAT = LDAT
Rewrite [SRH]
If fstat
   WMESS=mess(143,7774,1)-"SRETURN : "-LNUM
   LRET=12 : Return
Endif

Return

#---------------------------
# Déclaration de production
#---------------------------
$TRT15
WMESS="*---"-mess(404,198,1)-LNUM
Call ECR_TRACE(WMESS,0) From GESECRAN
Readlock [MTK]MTK0=LNUM
If fstat
   WMESS=mess(60,9151,1)-"MFGHEADTRK : "-LNUM
   LRET=3 : Return
Endif

WSTOFCY = [F:MTK]MFGFCY
WIPTDAT = [F:MTK]MFGTRKDAT
# Articles fabriqués
For [MKI] Where MFGTRKNUM=LNUM
   LLIN=[F:MKI]ITMTRKLIN
   WITM=[F:MKI]ITMREF
   # Maj ITMMVTHIS si nécessaire
   Gosub MAJ_ITH
   If LRET Break Endif
   # Traitement des mouvements de stock de la ligne
   Gosub TRT_STJ
   If LRET Break Endif
Next
If LRET Return Endif

Update [MKI] Where MFGTRKNUM=LNUM With IPTDAT=LDAT
If fstat
   WMESS=mess(143,7774,1)-"MFGITMTRK : "-LNUM
   LRET=23 : Return
Endif

# On modifie LTYP pour traiter les conso matières
LTYP=12
#Matières consommées
For [MKM] Where MFGTRKNUM=LNUM
   LLIN=[F:MKM]MATTRKLIN
   WITM=[F:MKM]MFMITMREF
   # Maj ITMMVTHIS si nécessaire
   Gosub MAJ_ITH
   If LRET Break Endif
   # Traitement des mouvements de stock de la ligne
   Gosub TRT_STJ
   If LRET Break Endif
Next
If LRET Return Endif

Update [MKM] Where MFGTRKNUM=LNUM With IPTDAT=LDAT
If fstat
   WMESS=mess(143,7774,1)-"MFGMATTRK : "-LNUM
   LRET=24 : Return
Endif

# Maj date opérations
Update [MKO] Where MFGTRKNUM=LNUM With IPTDAT=LDAT
If fstat
   WMESS=mess(143,7774,1)-"MFGOPETRK : "-LNUM
   LRET=25 : Return
Endif

[F:MTK]MFGTRKDAT = LDAT
Rewrite [MTK]
If fstat
   WMESS=mess(143,7774,1)-"MFGHEADTRK : "-LNUM
   LRET=13 : Return
Endif

# Maj date WIPCOST
Update [MWI] Where MFGTRKNUM=LNUM With TXNDAT=LDAT
If fstat
   WMESS=mess(143,7774,1)-"WIPCOST : "-LNUM
   LRET=26 : Return
Endif

Return

#----------------------
# Entrées diverses
#----------------------
$TRT19
WMESS="*---"-mess(1,704,1)-LNUM
Call ECR_TRACE(WMESS,0) From GESECRAN
Readlock [SMH]SMH0=LTYP;LNUM
If fstat
   WMESS=mess(60,9151,1)-"SMVTH : "-LNUM
   LRET=4 : Return
Endif

WSTOFCY = [F:SMH]STOFCY
WIPTDAT = [F:SMH]IPTDAT
For [SMD] Where VCRTYP=LTYP & VCRNUM=LNUM
   LLIN=[F:SMD]VCRLIN
   WITM=[F:SMD]ITMREF
   # Maj ITMMVTHIS si nécessaire
   Gosub MAJ_ITH
   If LRET Break Endif
   # Traitement des mouvements de stock de la ligne
   Gosub TRT_STJ
   If LRET Break Endif
Next
If LRET Return Endif

[F:SMH]IPTDAT = LDAT
Rewrite [SMH]
If fstat
   WMESS=mess(143,7774,1)-"SMVTH : "-LNUM
   LRET=14 : Return
Endif

Return

#------------------------------------------------
# Traitement des mouvements de stock de la ligne
#------------------------------------------------
$TRT_STJ
# Lecture article pour savoir si gestion traçabilité
#MAE, bg 91067, lecture déplacé dans MAJ_ITH
#Read [ITM]ITM0=WITM

Filter [STJ2] Where STOFCY=WSTOFCY & VCRTYP=LTYP & VCRNUM=LNUM & VCRLIN=LLIN
&             Order By Key STJX=GTE;NUMVCR
For [STJ2]STJX
   # Le mouvement est comptabilisé
   If [F:STJ2]NUMVCR<>""
      # Annulation pièce comptable de stock
      Call ANUPCE([F:STJ2]GTE,[F:STJ2]NUMVCR) From ANUBIS
      If GOK<=0
         WMESS=mess(7,21,1)-mess(53,197,1)-mess(145,117,1)-[F:STJ2]NUMVCR
         LRET=41 : Break
      Else
         # Maj des mouvements de stock de cette pièce comptable
         Update [STJ] Where GTE=[F:STJ2]GTE & NUMVCR=[F:STJ2]NUMVCR
&                     With  GTE="",NUMVCR="",AGGIFAFLG=1, ACCDAT=[0/0/0]
         If fstat
            WMESS=mess(143,7774,1)-"STOJOU : "-mess(53,197,1)-mess(145,117,1)-[F:STJ2]NUMVCR
            LRET=42 : Break
         Else
            WMESS=mess(145,117,1)-[F:STJ2]NUMVCR-mess(2,2723,1)
            Call ECR_TRACE(WMESS,0) From GESECRAN
         Endif
      Endif
   Endif
Next
If LRET Goto TRT_STJEND Endif

# Maj de la nouvelle date d'imputation et svg de l'ancienne
#Update [STJ] Where STOFCY=WSTOFCY & VCRTYP=LTYP & VCRNUM=LNUM & VCRLIN=LLIN
#&            With  IPTDAT=LDAT, USRFLD4=WIPTDAT
#If fstat
#   WMESS=mess(143,7774,1)-"STOJOU : "-num$(LTYP)-LNUM
#   LRET=51 : Goto TRT_STJEND
#Endif

# Maj de la nouvelle date d'imputation et svg de l'ancienne
Filter [STJ] Where STOFCY=WSTOFCY & VCRTYP=LTYP & VCRNUM=LNUM & VCRLIN=LLIN
&            Order By ITMREF;IPTDAT;MVTSEQ Desc
For [STJ]
   # Sauvegarde no séquence
   WSEQ = [F:STJ]MVTSEQ
   # Recherche no de séquence pour la nouvelle date
   Columns [STJ1] (MVTSEQ)
   Filter [STJ1] Where STOFCY=[F:STJ]STOFCY
&                    & UPDCOD=1
&                    & ITMREF=[F:STJ]ITMREF
&                    & IPTDAT=LDAT
   WSEQ1=99999999
   Read [STJ1]STJ0 First
   If !fstat [L]WSEQ1=[F:STJ1]MVTSEQ-1 Endif
   Filter [STJ1] Where STOFCY=[F:STJ]STOFCY
&                    & UPDCOD=2
&                    & ITMREF=[F:STJ]ITMREF
&                    & IPTDAT=LDAT
   WSEQ2=99999999
   Read [STJ1]STJ0 First
   If !fstat [L]WSEQ2=[F:STJ1]MVTSEQ-1 Endif
   Filter [STJ1]
   Columns [STJ1]
   [F:STJ]MVTSEQ  = min(WSEQ1,WSEQ2)
   [F:STJ]IPTDAT  = LDAT
   [F:STJ]USRFLD4 = WIPTDAT
   Rewrite [STJ]
   If fstat
      WMESS=mess(143,7774,1)-"STOJOU : "-num$(LTYP)-LNUM-[F:STJ]ITMREF
      LRET=51 : Break
   Endif
   # Maj date et no séquence si traçabilité détaillée
   # Si traçabilité agrégé date et no séq ne sont pas des critères d'agrégation
   # --> pas de maj
   If [F:ITM]TRKCOD=2
      Update [STR] Where ITMREF=[F:STJ]ITMREF & LOT=[F:STJ]LOT & SLO=[F:STJ]SLO
&                        & IPTDAT=WIPTDAT & MVTSEQ=WSEQ & STOFCY=[F:STJ]STOFCY
&                  With  IPTDAT=[F:STJ]IPTDAT, MVTSEQ=[F:STJ]MVTSEQ
      If fstat
         WMESS=mess(143,7774,1)-"STOTRK : "-num$(LTYP)-LNUM-[F:STJ]ITMREF
         LRET=52 : Break
      Endif
   Endif
   If GACTDECCST
      Update [SJV] Where ITMREF=[F:STJ]ITMREF & STOFCY=[F:STJ]STOFCY & UPDCOD=[F:STJ]UPDCOD
&                        & IPTDAT=WIPTDAT & MVTSEQ=WSEQ
&                  With  IPTDAT=[F:STJ]IPTDAT, MVTSEQ=[F:STJ]MVTSEQ
      If fstat
         WMESS=mess(143,7774,1)-"STOJOUVAL : "-num$(LTYP)-LNUM-[F:STJ]ITMREF
         LRET=53 : Break
      Endif
   Endif
Next

$TRT_STJEND
Filter [STJ]
Filter [STJ2]

Return

#-----------------------------
# Maj ITMMVTHIS si nécessaire
#-----------------------------
$MAJ_ITH
Call GETSOC(WSTOFCY) From DEVSUB
# Récupération période date imputation
Call GETPERSOC(GSOCIETE,GTYPGEN,WIPTDAT,LEXE,LPER) From CPTSUB
WPERSTR = [F:PER]PERSTR
# Récupération période nouvelle date
Call GETPERSOC(GSOCIETE,GTYPGEN,LDAT,LEXE,LPER) From CPTSUB
#Les deux date sont dans la même période, pas de maj
If [F:PER]PERSTR=WPERSTR : Return : Endif

#lecture de l'article pour savoir si il est géré en stock
Read [ITM]ITM0=WITM
#MAE, bg 91067, si l'article n'est pas géré en stock, pas de maj
If [F:ITM]STOMGTCOD = 1 : Return : Endif

Raz WQTY, WAMT, WPRI, WEVA, WMVT
# hcb 74673 rajout WITM
For [STJ]STJ1 Where STOFCY=WSTOFCY & VCRTYP=LTYP & VCRNUM=LNUM
&                 & VCRLIN=LLIN & REGFLG=1 & UPDCOD=2 & ITMREF = WITM
   WQTY += abs([F:STJ]ACTQTY)
   WAMT += [F:STJ]AMTVAL
   WPRI  = [F:STJ]PRIORD
   WEVA += [F:STJ]AMTDEV
   WMVT  = 1
Next

# Maj des cumuls de la période pour l'ancienne date d'imputation
Readlock [ITH]ITH0=WITM;WSTOFCY;WPERSTR
If !fstat
   # Décrémentation des cumuls mensuels et annuels pour la période à traiter
   Case LTYP
    When 6, 15, 19 : [F:ITH]YEARCPQTY -= WQTY
                     [F:ITH]YEARCPAMT -= WAMT
                     [F:ITH]YEARCPMVT -= 1
                     [F:ITH]MONRCPQTY -= WQTY
                     [F:ITH]MONRCPAMT -= WAMT
                     [F:ITH]MONRCPMVT -= 1
    When 12        : [F:ITH]YEAISSQTY -= WQTY
                     [F:ITH]YEAISSAMT -= WAMT
                     [F:ITH]YEAISSMVT -= WMVT
                     [F:ITH]MONISSQTY -= WQTY
                     [F:ITH]MONISSAMT -= WAMT
                     [F:ITH]MONISSMVT -= WMVT
    When 13        : [F:ITH]YEAISSQTY += WQTY
                     [F:ITH]YEAISSAMT += WAMT
                     [F:ITH]MONISSQTY += WQTY
                     [F:ITH]MONISSAMT += WAMT
   Endcase
   [F:ITH]AMTDEV -= WEVA
   # Réécriture du cumul article-site à traiter
   Rewrite [ITH]
   If fstat
      WMESS=mess(143,7774,1)-"ITMMVTHIS : "-WITM-WSTOFCY-WPERSTR
      LRET=62 : Return
   Endif
# Il n'existe pas et on ne traite pas des sorties matières
Elsif LTYP<>12
   WMESS=mess(60,9151,1)-"ITMMVTHIS : "-WITM-WSTOFCY-WPERSTR
   LRET=61 : Return
Endif

# Lecture de la période pour la nouvelle date d'imputation
Read [ITH]ITH0=WITM;WSTOFCY;[F:PER]PERSTR
If fstat
   # Création du cumul article-site à traiter
   Raz [F:ITH]
   [F:ITH]ITMREF = WITM
   [F:ITH]STOFCY = WSTOFCY
   [F:ITH]PERSTR = [F:PER]PERSTR
   [F:ITH]PEREND = [F:PER]PEREND
   [F:ITH]FIYNUM = [F:PER]FIYNUM
   [F:ITH]PERNUM = [F:PER]PERNUM
   [F:ITH]CREDAT = date$
   [F:ITH]CREUSR = GUSER
   [F:ITH]EXPNUM = [C]EXPORT
   # Lecture période précédente pour initialisation cumuls annuels
   # et dates, prix, pièce dernier mouvement
   Filter [ITH1] Where ITMREF=WITM & STOFCY=WSTOFCY
&                    & FIYNUM=[F:PER]FIYNUM & PERSTR<[F:PER]PERSTR
   Read [ITH1]ITH0 Last
   Filter [ITH1]
   If !fstat
      [F:ITH]YEARCPQTY = [F:ITH1]YEARCPQTY
      [F:ITH]YEARCPAMT = [F:ITH1]YEARCPAMT
      [F:ITH]YEARCPMVT = [F:ITH1]YEARCPMVT
      [F:ITH]YEAISSQTY = [F:ITH1]YEAISSQTY
      [F:ITH]YEAISSAMT = [F:ITH1]YEAISSAMT
      [F:ITH]YEAISSMVT = [F:ITH1]YEAISSMVT
      [F:ITH]LASRCPDAT = [F:ITH1]LASRCPDAT
      [F:ITH]LASRCPPRI = [F:ITH1]LASRCPPRI
      [F:ITH]VCRTYP    = [F:ITH1]VCRTYP
      [F:ITH]VCRNUM    = [F:ITH1]VCRNUM
      [F:ITH]VCRLIN    = [F:ITH1]VCRLIN
      [F:ITH]LASPURDAT = [F:ITH1]LASPURDAT
      [F:ITH]LASPURPRI = [F:ITH1]LASPURPRI
   Endif
   Write [ITH]
   If fstat
      WMESS=mess(143,7774,1)-"ITMMVTHIS : "-WITM-WSTOFCY-[F:PER]PERSTR
      LRET=63 : Return
   Endif
Endif

# Maj des cumuls de la période pour la nouvelle date d'imputation
Readlock [ITH]ITH0=WITM;WSTOFCY;[F:PER]PERSTR
If !fstat
   # Incrémentation des cumuls mensuels et annuels pour la période à traiter
   Case LTYP
    When 6, 15, 19 : [F:ITH]YEARCPQTY += WQTY
                     [F:ITH]YEARCPAMT += WAMT
                     [F:ITH]YEARCPMVT += 1
                     [F:ITH]MONRCPQTY += WQTY
                     [F:ITH]MONRCPAMT += WAMT
                     [F:ITH]MONRCPMVT += 1
                     If LDAT>[F:ITH]LASRCPDAT
                        [F:ITH]LASRCPDAT = LDAT
                        [F:ITH]LASRCPPRI = WPRI
                        [F:ITH]VCRTYP    = LTYP
                        [F:ITH]VCRNUM    = LNUM
                        [F:ITH]VCRLIN    = LLIN
                     Endif
                     # Réception non nulle
                     If LTYP=6 & WPRI<>0
                        If LDAT>[F:ITH]LASPURDAT
                           [F:ITH]LASPURDAT = LDAT
                           [F:ITH]LASPURPRI = WPRI
                        Endif
                     Endif
    When 12        : [F:ITH]YEAISSQTY += WQTY
                     [F:ITH]YEAISSAMT += WAMT
                     [F:ITH]YEAISSMVT += WMVT
                     [F:ITH]MONISSQTY += WQTY
                     [F:ITH]MONISSAMT += WAMT
                     [F:ITH]MONISSMVT += WMVT
                     If LDAT>[F:ITH]LASISSDAT
                        [F:ITH]LASISSDAT = LDAT
                     Endif
    When 13        : [F:ITH]YEAISSQTY -= WQTY
                     [F:ITH]YEAISSAMT -= WAMT
                     [F:ITH]MONISSQTY -= WQTY
                     [F:ITH]MONISSAMT -= WAMT
   Endcase
   [F:ITH]AMTDEV += WEVA
   # Réécriture du cumul article-site à traiter
   Rewrite [ITH]
   If fstat
      WMESS=mess(143,7774,1)-"ITMMVTHIS : "-WITM-WSTOFCY-[F:PER]PERSTR
      LRET=62 : Return
   Endif

   # Incrémentation des cumuls annuels pour les périodes suivantes
   # du même exercice et jusqu'à la période de l'ancienne date d'imputation
   For [ITH1]ITH0 Where ITMREF=[F:ITH]ITMREF & STOFCY=[F:ITH]STOFCY
&                     & PERSTR>[F:ITH]PERSTR & PERSTR<WPERSTR
&                     & FIYNUM=[F:PER]FIYNUM
      Case LTYP
       When 6, 15, 19 : [F:ITH1]YEARCPQTY += WQTY
                        [F:ITH1]YEARCPAMT += WAMT
                        [F:ITH1]YEARCPMVT += 1
       When 12        : [F:ITH1]YEAISSQTY += WQTY
                        [F:ITH1]YEAISSAMT += WAMT
                        [F:ITH1]YEAISSMVT += WMVT
       When 13        : [F:ITH1]YEAISSQTY -= WQTY
                        [F:ITH1]YEAISSAMT -= WAMT
      Endcase
      Rewrite [ITH1]
      If fstat
         WMESS=mess(143,7774,1)-"ITMMVTHIS : "-WITM-WSTOFCY-[F:ITH1]PERSTR
         LRET=62 : Break
      Endif
   Next
   If LRET Return Endif
Else
   WMESS=mess(60,9151,1)-"ITMMVTHIS : "-WITM-WSTOFCY-[F:PER]PERSTR
   LRET=61 : Return
Endif

Return

#########################################################################
# Actions sur zones                                                     #
#########################################################################
Subprog AS_VCRTYP(VALEUR)
Variable Integer VALEUR
Local Integer I
For I=1 To len(mess(0,701,1))
  If !find(I,6,13,15,19)
    GMENLOC(I)=1
  Endif
Next I
If GMODU(5)<>2 : GMENLOC(13)=1 : Endif
If GMODU(6)<>2 : GMENLOC(6) =1 : Endif
If GMODU(8)<>2 : GMENLOC(15)=1 : Endif
End

Subprog AM_VCRTYP(VALEUR)
Variable Integer VALEUR
End

Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()
#--- Bug 89167
Local Integer WCPT
Local Char    WSTOFCY
#---
#--- Lecture pièce
Case [M]VCRTYP
 When  6 : Read [PTH]PTH0=VALEUR
           If fstat
             mkstat=2 : Call RSTA("PTH",VALEUR) From GLOCK
           Elsif [F:PTH]BETFCY=2
             mkstat=2 : GMESSAGE=mess(10,2236,1)
           Else
             #--- Bug 89167
             WSTOFCY=[F:PTH]PRHFCY
             Gosub VERIF_CPT
             If WCPT=1
               mkstat=2 : GMESSAGE=mess(412,184,1)
             Endif
             #---
             [M]IPTDAT=[F:PTH]RCPDAT
             #--- Issue 94281
             Filter [STJ] Where STOFCY=WSTOFCY & VCRTYP=[M:DIA]VCRTYP & VCRNUM=VALEUR
&            Order By Key STJ1
             For [STJ]
               [M]IPTDAT=[F:STJ]IPTDAT : Break
             Next
             Filter [STJ]
             #---
             [M]NEWDAT=[M]IPTDAT
           Endif
 When 13 : Read [SRH]SRH0=VALEUR
           If fstat
             mkstat=2 : Call RSTA("SRH",VALEUR) From GLOCK
           Else
             #--- Bug 89167
             WSTOFCY=[F:SRH]STOFCY
             Gosub VERIF_CPT
             If WCPT=1
               mkstat=2 : GMESSAGE=mess(412,184,1)
             Endif
             #---
             [M]IPTDAT=[F:SRH]RTNDAT
             [M]NEWDAT=[M]IPTDAT
           Endif
 When 15 : Read [MTK]MTK0=VALEUR
           If fstat
             mkstat=2 : Call RSTA("MTK",VALEUR) From GLOCK
           Else
             #--- Bug 89167
             WSTOFCY=[F:MTK]MFGFCY
             Gosub VERIF_CPT
             If WCPT=1
               mkstat=2 : GMESSAGE=mess(412,184,1)
             Else
               Gosub VERIF_CPT2
               If WCPT=1
                 mkstat=2 : GMESSAGE=mess(412,184,1)
               Endif
             Endif
             #---
             [M]IPTDAT=[F:MTK]MFGTRKDAT
             [M]NEWDAT=[M]IPTDAT
           Endif
 When 19 : Read [SMH]SMH0=19;VALEUR
           If fstat
             mkstat=2 : Call RSTA("SMH","19"-VALEUR) From GLOCK
           Else
             #--- Bug 89167
             WSTOFCY=[F:SMH]STOFCY
             Gosub VERIF_CPT
             If WCPT=1
               mkstat=2 : GMESSAGE=mess(412,184,1)
             Endif
             #---
             [M]IPTDAT=[F:SMH]IPTDAT
             [M]NEWDAT=[M]IPTDAT
           Endif
Endcase
End

#--- Bug 89167
$VERIF_CPT
WCPT=0
Filter [STJ] Where STOFCY=WSTOFCY & VCRTYP=[M:DIA]VCRTYP & VCRNUM=VALEUR & NUMVCR<>""
&            Order By Key STJ1
For [STJ]
  WCPT=1 : Break
Next
Filter [STJ]
Return

$VERIF_CPT2
WCPT=0
Filter [MWI] Where MFGTRKNUM=VALEUR & JOUNUM<>""
&            Order By Key MWI1
For [MWI]
  WCPT=1 : Break
Next
Filter [MWI]
Return
#---

Subprog AM_VCRNUM(VALEUR)
Variable Char    VALEUR()
End

Subprog C_NEWDAT(VALEUR)
Variable Date    VALEUR
If VALEUR >= [M]IPTDAT
   Call ERREUR(mess(1,104,1)) From GESECRAN : mkstat=2
Endif
#--- Contrôle date par rapport à pièce origine
Case [M]VCRTYP
 When  6 : For [PTD] Where PTHNUM=[M]VCRNUM
              If [F:PTD]POHNUM<>"" & [F:POH]POHNUM<>[F:PTD]POHNUM
                 Read [POH]POH0=[F:PTD]POHNUM
                 If [F:POH]ORDDAT>VALEUR
                    Call ERREUR(mess(32,192,1)) From GESECRAN
                    mkstat=2 : Break
                 Endif
              Endif
           Next
 When 15 : If [F:MTK]MFGNUM<>"" & [F:MFG]MFGNUM<>[F:MTK]MFGNUM
              Read [MFG]MFG0=[F:MTK]MFGNUM
              If [F:MFG]STRDAT>VALEUR
                 Call ERREUR(mess(1,104,1)) From GESECRAN
                 mkstat=2
              Endif
           Endif
Endcase
End

