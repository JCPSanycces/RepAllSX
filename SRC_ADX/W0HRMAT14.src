#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT14 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBREXN0
mkstat = 0
zoncou = "NBREXN0"
indice = 0
status = 1
zoncou = "NBREXN0"
If varmode([M]NBREXN0,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBREXN0 From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBREXN0 : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBREXN0" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBREXN0
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBREXN0 = nolign
   status = 75
   Call SAI_NBREXN0(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_NBREXN0 From SUBEML2
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NBREXN0" : GZNUM = 0 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone WEXSDAT
mkstat = 0
zoncou = "WEXSDAT"
indice = 0
If varmode([M]WEXSDAT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_WEXSDAT([M]WEXSDAT) From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz [M]WEXSDAT : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "WEXSDAT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If [M]WEXSDAT=[0/0/0]
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "WEXSDAT" : GZNUM = 212 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_WEXSDAT([M]WEXSDAT) From SUBEML2
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "WEXSDAT" : GZNUM = 212 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone WNBREXN
mkstat = 0
zoncou = "WNBREXN"
indice = 0
status = 1
zoncou = "WNBREXN"
If varmode([M]WNBREXN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WNBREXN" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]WNBREXN
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]WNBREXN = nolign
   status = 75
   Call SAI_WNBREXN(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_WNBREXN From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WNBREXN" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone WCAT
mkstat = 0
zoncou = "WCAT"
indice = 0
IMPENT = [M]WCAT
WNUM = IMPENT
If varinit([M]WCAT,indice)=0
 IMPENT = 1
Endif
If varmode([M]WCAT,indice)=0
 Call INICOMBO(10554) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_WCAT(IMPENT) From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,10554,1))))
 Endif
 [M]WCAT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "WCAT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]WCAT(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "WCAT" : GZNUM = 25354 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WNUM<>IMPENT or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_WCAT(IMPENT) From SUBEML2
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "WCAT" : GZNUM = 25354 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif
[M]WCAT = IMPENT

## Zone WBKT
mkstat = 0
zoncou = "WBKT"
indice = 0
IMPENT = [M]WBKT
WNUM = IMPENT
If varinit([M]WBKT,indice)=0
 IMPENT = 1
Endif
If varmode([M]WBKT,indice)=0
 [M]WBKT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "WBKT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]WBKT(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_WBKT(IMPENT) From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WBKT" : GZNUM = 47611 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]WBKT = IMPENT

####################################
## Bloc liste 5
####################################
IMPTBL = 0

## Zone WADD14
mkstat = 0
zoncou = "WADD14"
indice = 0
IMPENT = [M]WADD14
If varinit([M]WADD14,indice)=0
 IMPENT = 1
Endif
If varmode([M]WADD14,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_WADD14(IMPENT) From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]WADD14(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "WADD14" : Gosub ACTION From =IMPTRT
  IMPENT = [M]WADD14(indice)
 Endif
 If !mkstat
  If IMPENT=0
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "WADD14" : GZNUM = 16730 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]WADD14 = IMPENT

####################################
## Bloc tableau 6
####################################
IMPTBL = 1

indice = 0
status = 1
zoncou = "NBREXN"
If !mkstat
 NBLIG = [M]NBREXN
 For nolign=1 To NBLIG
  indice = nolign-1
  [M]NBREXN = nolign
  status = 75
  Call SAI_NBREXN(IMPFIC,ACTION,IMPTRT)
  If mkstat : Break : Endif
 Next nolign
 If mkstat : End : Endif
 indice = 0
Endif

####################################
## Bloc liste 7
####################################
IMPTBL = 0

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBREXN0(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBREXN0
mkstat = 0
zoncou = "NBREXN0"
SAVACT = GACTION : GACTION = "STD"
Call C_NBREXN0 From SUBEML2
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "NBREXN0" : GZNUM = 0 : Endif
Gosub AFF From GSAISIE
If mkstat : End : Endif

## Zone NBREXN0
mkstat = 0
zoncou = "NBREXN0"

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_WNBREXN(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone WNBREXN
mkstat = 0
zoncou = "WNBREXN"
SAVACT = GACTION : GACTION = "STD"
Call C_WNBREXN From SUBEML2
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "WNBREXN" : GZNUM = 0 : Endif
Gosub AFF From GSAISIE
If mkstat : End : Endif

## Zone WEXSVAR
mkstat = 0
zoncou = "WEXSVAR"
WCHAR = [M]WEXSVAR(indice)
If varmode([M]WEXSVAR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WEXSVAR" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]WEXSVAR(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "WEXSVAR" : GZNUM = 124 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTVRA"
  Call CONTVRA([M]WEXSVAR(indice)) From SUBVRA
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WEXSVAR" : GZNUM = 124 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]WEXSVAR(indice)
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]WEXSVAR(indice) = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "WEXSVAR" : GZNUM = 124 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTUNI"
    Call UNICITE2([M]WEXSVAR(indice),[M]WNBREXN,[M]WEXSVAR) From OBJDIV
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "WEXSVAR" : GZNUM = 124 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "CONTMULSEL"
     Call CONTMULSEL([M]WEXSVAR(indice),[M:EMP0]REFNUM,"VRA",GCURLEG) From TOOLSHRLEG
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "WEXSVAR" : GZNUM = 124 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      If WCHAR<>[M]WEXSVAR(indice) or IMPMOD
       SAVACT = GACTION : GACTION = "STD"
       Call AM_WEXSVAR([M]WEXSVAR(indice)) From SUBEML2
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "WEXSVAR" : GZNUM = 124 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone WEXSAMT
mkstat = 0
zoncou = "WEXSAMT"
WNUM = [M]WEXSAMT(indice)
SAVACT = GACTION : GACTION = "FMTFM2DEV"
Call FMTFM2DEV([V]GCURSHR) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]WEXSAMT(indice) : Endif
If !mkstat
 If varmode([M]WEXSAMT,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "WEXSAMT" : Gosub ACTION From =IMPTRT
  Endif
  If [M]WEXSAMT(indice)=0
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "WEXSAMT" : GZNUM = 3603 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If [M]WEXSAMT(indice)<0
    mkstat = 1 : GMESSAGE = mess(180,141,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "WEXSAMT" : GZNUM = 3603 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WNUM<>[M]WEXSAMT(indice) or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_WEXSAMT([M]WEXSAMT(indice)) From SUBEML2
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "WEXSAMT" : GZNUM = 3603 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone WNBREXN
mkstat = 0
zoncou = "WNBREXN"
status = 71
SAVACT = GACTION : GACTION = "STD"
Call APRES_WNBREXN From SUBEML2
GACTION = SAVACT

End

####################################
## Bloc tableau 6
####################################
Subprog SAI_NBREXN(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1


## Zone EXSAMT
mkstat = 0
zoncou = "EXSAMT"
SAVACT = GACTION : GACTION = "FMTFM2DEV"
Call FMTFM2DEV([V]GCURSHR) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]EXSAMT(indice) : Endif


End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "HRMAT14"
Return

