#<AdxTL>@(#)0.0.0.0 $Revision$ Contrôles divers salarié
#MIPEA SOURCE REMERGE
######################################################################################
# Modification :
#     SEGAY - 01/07/11 - FQ71093 -
# Performances lectures subordonnés EMPSBD (ESB)
#     SEGAY - 11/10/11 - FQ76996 -
#   Si on a pas de flux désigné et si il n’y a pas de flux DEFAULT,
#   cela signifie qu’il n’y a pas de gestion des flux et que seules habilitations classiques sont utilisées.
#     SEGAY - 28/10/11 - FQ77414
#       Performances lectures subordonnés EMPSBD (ESB) dans GETSUBORDONNESFLUX
#       link avec EMPSBD et test sur GSUPER et existence de flux avec l'appel
#       CHECK_SUBORD_OKF (test sur les chefs des flux sans relevture du contrat)
#    FQ86831 - US1205 - limit 127 for GAUTSRV
#    MABOS - 08/08/13 - FQ91298 - US1835 - Technical Review
######################################################################################

$ACTION
Case [V]GACTION
When "SELFCYCPY"
 Case [L]ACTION
  When "SEL_TABLE" : Gosub  SEL_FCY
  When "CHX_TABLE" : If dim([L]CHXLNK)=1 : Default File [LNK] : Endif
  When "FIN_TABLE" : Gosub FIN_FCY       :#90510
 Endcase
When "CONTEMP"
 Case ACTION
  When "SEL_LISTE"    : Gosub SEL_EMP
 Endcase
When "SELCTREMP"
 Case ACTION
  When "SEL_LISTE"    : Gosub SEL_CTREMP
 Endcase

When "SELBAN"
 Case ACTION
  When "SEL_TABLE" : Gosub SEL_BAN
  When "FIN_TABLE" : Gosub FIN_BAN
 Endcase
When "SELMNLEMP"
 Case ACTION
  When "SEL_LISTE"    : Gosub SEL_MNLEMP
  When "FIN_LISTE"    : Gosub FIN_MNLEMP
 Endcase
Endcase

#When "SELTIMLEG"
# Case ACTION
#   When "SEL_TABLE"    : Gosub S_TIMLEG
# Endcase

#When "SELTIM"
# Case ACTION
#  When "SEL_LISTE" :
#    Case LISTE
#      When "SELTIM"   : Gosub SELTIM
#    Endcase
# Endcase
#Endcase

Return

#############################################################################
# Initialisation des valeurs paramètre par user
#############################################################################
Funprog INIPARUSR(PARAM,USR,SITE)
Value Char PARAM
Value Char USR
Value Char SITE
Local Char VALEUR(255)
If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
Call PARAMUTIL(PARAM,VALEUR,USR,SITE) From SUBAUS
# Si elles sont vides, on va rechercher celles de son Responsable RH
If VALEUR="" | val(VALEUR)=0
  Read [F:AUS]CODUSR=GUSER
  If !fstat & [F:AUS]CHEF(3)<>""
   Call PARAMUTIL(PARAM,VALEUR,[F:AUS]CHEF(3),SITE) From SUBAUS
  Endif
  If VALEUR="" | val(VALEUR)=0 : VALEUR="000000" : Endif    :#pour les dates
Endif
End VALEUR

#############################################################################
# Initialisation des valeurs paramètre (dates) par user
##**[DBA]10/09/14 Landing page can't use globales variables
#############################################################################
Funprog SYRINIDATUSR(PARAM)
Value Char PARAM
Local Date VALEUR
Local Integer ASTATUS

If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif

VALEUR=fmet GACTX.APARAM.AGETUSERVALDATE(PARAM)
# Si elles sont vides, on va rechercher celles de son Responsable RH
If VALEUR=[0/0/0]
  Read [F:AUS]CODUSR=GACTX.USER
  If !fstat & [F:AUS]CHEF(3)<>""
   VALEUR=gdat$(func ADP_TOOL.GET_PARAM_USER(GACTX.AFOLDER,[F:AUS]CHEF(3),PARAM))
  Endif
Endif
End VALEUR

#############################################################################
## Contrôle d'accès à un salarié
## Linked to the data type EML
#############################################################################
#**
#*
#* US1835 91298 08/08/2013 add 2 parameters
#* @param VALEUR
#* @param CRIT1
#* @param ALLLEG : 1 no test leg
#* @param SAL : code employee # VALEUR, test leg list of employee and GCURLEG
#*!
Subprog DROIT(VALEUR,CRIT1,ALLLEG,SAL)
Variable Char VALEUR()
Value Char CRIT1()
Value Char ALLLEG()
Value Char SAL()

Local Char CRITERE(250)
If clalev([F:ID])=0    : Local File EMPLOID    [ID]   : Endif
If clalev([F:ACC])=0   : Local File ACCES      [ACC]  : Endif
If clalev([F:CTRW])=0  : Local File EMPLOCTR   [CTRW] : Endif

If VALEUR="" : End : Endif

## Existence

If [F:ID]REFNUM <> VALEUR : # 71801
 Call LECTURE("EML",VALEUR,"") From CONTOBJ
 If fstat
  GMESSAGE = mess(23,100,1) : #  Fiche inexistante
  mkstat = 2 : End
 Endif
Endif


## Code d'accès

If [F:ID]CODACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:ID]CODACS
 If fstat or [F:ACC]EXEC<>2
  GMESSAGE = [F:ID]REFNUM-":"-mess(31,10702,1) : # Vous n'avez pas les droits pour ce salarié
  mkstat = 2 : End
 Endif
Endif

If [F:ID]FLGMULCTR<>2
 Filter [CTRW] Where REFNUM=VALEUR
 Read [CTRW]CTR1 Last
 Filter [CTRW]
 If !fstat
  ## Autorisations par site
  If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
   If !find([F:CTRW]ETRFCY,GUSRFCY(1..GNBAUZ))
    GMESSAGE = [F:CTRW]ETRFCY-":"-mess(32,10702,1) : # Vous n'avez pas accès à ce site
    mkstat = 2 : End
   Endif
  Endif

  ## Autorisations par service
  #MABOS-01/02/13-FQ86831-US1205 - limit 127 for GAUTSRV
  #If GUSRACS<>2 & !find([F:CTRW]ETRSRV,GAUTSRV(1..GNBSERV))
  If !(func AUTSRV([F:CTRW]ETRSRV)) Then
   GMESSAGE = [F:CTRW]ETRSRV-":"-mess(73,10702,1) : # Vous n'avez pas accès à ce service
   mkstat = 2 : End
  Endif
 Endif
Else      : # / 71801
 If GUSRACS <> 2 | GNBAUZ <> GNBSITE
 # We verify that there is one authorised contract
  I = -1
  Filter [F:CTRW] Where REFNUM = [F:ID]REFNUM
  For [F:CTRW]
  #MABOS-01/02/13-FQ86831-US1205 - limit 127 for GAUTSRV
  #If ( GUSRFCY = "\" | find([F:CTRW]ETRFCY,GUSRFCY) )
  #&    &( GUSRACS = 2   | find([F:CTRW]ETRSRV,GAUTSRV) )
   If ( GUSRFCY = "\" | find([F:CTRW]ETRFCY,GUSRFCY) )
&    & ( func AUTSRV([F:CTRW]ETRSRV ) )
    I=1
    Break
   Else
    I=0
   Endif
  Next
  Filter [F:CTRW]
  If !I
   GMESSAGE  = mess(8,123,1) : # Accès impossible à cette fiche
   mkstat = 2
   End
  Endif
 Endif
 # 71801 /
Endif

# Control if the current legislation is manage for this employee
#If (GFONCTION="GESCTR" & maskcou ="CTR0") | (GFONCTION="GESECP" & maskcou ="ECP0")
#&   | (GFONCTION="GESEVA" & maskcou ="EVA6") | (GFONCTION="GESEVA" & maskcou ="EVA0" & GREP="C" & func SUBEVA.FGET_LEGCTL(2)="")
#&   | (GFONCTION='GESHRATS') | (GFONCTION='GESMAL')| (GFONCTION='GESTAT')| (GFONCTION='GESDLA')
#* US1835 91298 08/08/2013 add 2 parameters
If val(ALLLEG)
#MABOS-07/06/13-add 'GESHRATS'
  End
Endif
If GCURLEG<>""
 If clalev([F:ILEG])=0 : Local File EMPLOLEG [ILEG] : Endif

 CRITERE="1=1"
 # In this case,we want to filter the employees whose only contracts are in the good legislation (not the main site)
 If CRIT1="CTR" Then
  CRITERE="CTRDAT<>[31/12/2040]"
 Endif
 # if (GFONCTION="GESEML" & maskcou ="HRMAT3") Then
 If [L]SAL <> "" Then
  Local Char    LISTLEG(5)(1..10), CRIT(250)
  Local Integer NBLEG
#  Call LIST_LEG_EML([M:EMP0]REFNUM, "", 2, LISTLEG, NBLEG, CRIT) From TOOLSHRLEG
  Call LIST_LEG_EML([L]SAL, "", 2, LISTLEG, NBLEG, CRIT) From TOOLSHRLEG
  If GCURLEG<>"" and !find(GCURLEG, LISTLEG) Then
    NBLEG += 1
    LISTLEG(NBLEG)=GCURLEG
  Endif

  If clalev([F:ILEG])=0 : Local File EMPLOLEG [ILEG] : Endif
  CRITERE-="& find([F:ILEG]LEGID,LISTLEG)>0 & [F:ILEG]ENAFLG=2 & [F:ILEG]FLGNEWSAL<>2"
 Else
  CRITERE-="& LEGID=GCURLEG"
 Endif

 Filter [ILEG]Where REFNUM=VALEUR & evalue(CRITERE)
 Read [ILEG]First
 Filter [ILEG]
 If fstat
   GMESSAGE = [L]VALEUR-":"-mess(14,10712,1) : # Fiche inexistante pour la législation courante
   mkstat = 2
   End
 Endif
Endif
End


################################################################################
## Accès à un salarié dans les traitements
################################################################################
Subprog CONTROLE(MATRI,DATMAT,CTR,CRI,OK,FLG)
Value    Char    MATRI()
Value    Date    DATMAT
Value    Char    CRI()
Value    Char    CTR()
Variable Integer OK
Value    Integer FLG

OK = 1
If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif

If clalev([F:ID])=0
 Local File EMPLOID [ID]
# Read[F:ID]ID0=MATRI
# If fstat : OK=0 : End : Endif
Endif
# Segay 28/09/12 US 830 81491
# Because in the selection box selects if you do nothing, the records relating to the selection are emptied
If [F:ID]REFNUM=""
   Read[F:ID]ID0=MATRI
   If fstat : OK=0 : End : Endif
Endif
## Flag actif
If [F:ID]ENAFLG<>2 & FLG=1
 OK = 0 : End
Endif

# Code d'accès
If [F:ID]CODACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:ID]CODACS
 If fstat or [F:ACC]EXEC<>2
  OK = 0 : End
 Endif
Endif

# Lecture EMPLOCTR
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif : # 71093
# FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
  If CTR<>''
   Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & (CTRDAT<=DATMAT | (FLGRET=2 & RETDATEFF<=DATMAT))
   Else
   Filter [HRCTR] Where REFNUM=MATRI & (CTRDAT<=DATMAT | (FLGRET=2 & RETDATEFF<=DATMAT))
  Endif
Read [HRCTR]CTR1 Last
  If fstat : Raz [F:HRCTR] : Endif
   Filter [HRCTR]

# Critère libre
  If CRI<>""
  Gosub OUVRE From WPDEFTABLE
  Gosub LECEMP From WPDEFTABLE

  If !evalue(CRI)
  OK = 0 :  End
  Endif
 Endif


# Droits par sites
If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 If !find([F:HRCTR]ETRFCY,GUSRFCY(1..GNBAUZ))
  OK = 0 : End
 Endif
Endif

# Droits par service
# MABOS-01/02/13-FQ86831-US1205 - limit 127 for GAUTSRV
#If GUSRACS<>2 & !find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV))
If !(func AUTSRV([F:HRCTR]ETRSRV)) Then
 OK = 0 : End
Endif

# Control if the current legislation is manage for this employee
If GCURLEG<>""
 If clalev([F:ILEG])=0 : Local File EMPLOLEG [ILEG] : Endif
 Filter [ILEG]Where REFNUM=MATRI & LEGID=GCURLEG
 Read [ILEG]First
 Filter [ILEG]
 If fstat
   OK=0 : End
 Endif
Endif
End


################################################################################
## Présence d'un salarié à une période donnée
################################################################################
Subprog PRESEMP(MATRI,DATDEB,DATFIN,OK)
Value    Char    MATRI()
Value    Date    DATDEB
Value    Date    DATFIN
Variable Integer OK

Local    Char    CTR (GLONHRCTR)
Call PRESEMPCTR(MATRI,DATDEB,DATFIN,CTR,OK)
End

################################################################################
## Présence d'un salarié à une période donnée pour un contrat
################################################################################
Subprog PRESEMPCTR(MATRI,DATDEB,DATFIN,CTR,OK)
Value    Char    MATRI()
Value    Date    DATDEB
Value    Date    DATFIN
Value    Char    CTR
Variable Integer OK

Local Char CRITCTR (50)
If CTR<>""
 CRITCTR="CTRNUM='"+CTR+"'"
Else
 CRITCTR="1=1"
Endif

If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
OK = 0
# FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
For [HRCTR] Where REFNUM=MATRI & evalue(CRITCTR) & (CTRDAT<=DATFIN | (FLGRET=2 & RETDATEFF<=DATFIN)) & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>DATDEB)
 OK = 1 : Break
Next
End

################################################################################
## Contrôle si GREFNUM supérieur hierarchique du salarié selon les flux métiers
## On contrôle en cascade sur contrat, salarié , service , site
##
## - GREFNUM vide : retour  ? , contrôles des droits et pas des flux métiers
##       non vide : retour ok , si GREFNUM = REF ; on est chef de soi-même
##
## - CTR     vide : retour ok , si trouvé pour au moins 1 contrat
##
## - FLUX    vide : retour ok , si trouvé sur au moins 1 flux (au bon niv. d'interlocuteur)
##       non vide : retour ok , si présent dans le flux ou flux demandé inexistant
##
## - DAT     vide : contrôle à date du jour
##     31/12/9999 : Recherche sur tous contrats passés/présents/futurs
##
## - Super profil : Pas de ctrl des flux
##
## - Droits       : pas ok si les droit accès , site et services ne sont pas accordés
##
## - Contrats     : pas ok si aucun valide à la date demandée
##
## - mkstat       : inchangé = Utilisateur connecté à des droits de chef
##                  2        = Utilisateur connecté non autorisé
##
################################################################################
#-----------------------------------------------------------
# SEGAY 01/07/11 DEM 71093
# Performances lectures subordonnés EMPSBD (ESB)
#-----------------------------------------------------------
Subprog CHECK_SUBORD(REF,CTR,FLUX,DAT)
Value    Char    REF()
Value    Char    CTR()
Value    Char    FLUX()
Value    Date    DAT

Local Integer ISCHEF
Local Integer OK,OKF
Local Char    CRIT (250)
Local Integer CREAGLOB

If clalev([F:CTR2])=0 : Local File EMPLOCTR [CTR2] : Endif
If clalev([F:FJH]) =0 : Local File FLXJOB   [FJH]  : Endif
If clalev([F:ID])  =0 : Local File EMPLOID  [ID]   : Endif
If clalev([F:ACC]) =0 : Local File ACCES    [ACC]  : Endif
If !clalev([F:ESB])  : Local File EMPSBD [ESB]    : Endif

If dim(GDONOTCLOSE) > 0
 CREAGLOB = 0
Else
 Global Integer GDONOTCLOSE
 Global Char    GSVFLUX (GLONFJH)
 Global Integer GTTYPMGR(len(mess(0,50,1)))
 CREAGLOB = 1
Endif

#4 LIGNES ci-dessous pour le ISCHEF de TRTPREPAY
If clalev([F:WCTR]) = 0 : Local File EMPLOCTR [WCTR] : Endif
If clalev([F:WAD])  = 0 : Local File EMPLOAD  [WAD]  : Endif
If clalev([F:WSRV]) = 0 : Local File SERVICE  [WSRV] : Endif
If clalev([F:WFCY]) = 0 : Local File FACILITY [WFCY] : Endif
# LIGNE ci-dessous pour le GET_TTYPMGR de TRTPREPAY
If clalev([F:WFJR]) = 0 : Local File FLXJOBRSP [WFJR] : Endif

If CREAGLOB
 Link [WCTR]
&      With  [WAD]AD0=[F:WCTR]REFNUM
&      As    [WLNK]
Endif

Read [F:ID]ID0 = [L]REF

If DAT = [00/00/0000]                       : # date par défaut
 DAT = date$
Endif

CRIT = "[F:CTR2]REFNUM="-"'"+[L]REF+"'"
If [L]CTR <> ""
 CRIT -= "& [F:CTR2]CTRNUM="-"'"+[L]CTR+"'"
Endif
If [L]DAT <> [31/12/9999]
 # FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
 CRIT -= "& ([F:CTR2]CTRDAT<="+"["+num$([L]DAT)+"] | ([F:CTR2]FLGRET=2 & [F:CTR2]RETDATEFF<="+"["+num$([L]DAT)+"]))"
 CRIT -= "& ([F:CTR2]XITDAT=[0/0/0] | [F:CTR2]XITDAT>="+"["+num$([L]DAT)+"])"
Endif

Raz OKF
If GPROFIL = GSUPER
 OKF = 1
Endif

If [L]FLUX <> [F:FJH]COD
 Read [F:FJH]FJH0 = [L]FLUX
 If fstat : [L]FLUX = "DEFAULT" : Endif
Endif
If [L]FLUX = ""
 [L]FLUX = "DEFAULT"
Endif

If [L]FLUX <> [F:FJH]COD
 Read [F:FJH]FJH0 = [L]FLUX
 If fstat : OKF = 1 : Endif                 : # flux demandé inexistant
Endif

OK=-1

Filter [CTR2] Where evalue(CRIT)

For [F:CTR2]CTR0
 Call CONTROLE(REF,DAT,CTR,"",OK,1)

 If GREFNUM = "" | GREFNUM = [L]REF         : # Chef de soi-même (aux droits près)
  OKF = 1
 Endif
 If OK & !OKF
  Read [F:ESB]ESB1(4) = GREFNUM;[F:CTR2]REFNUM;[F:CTR2]CTRNUM;[F:CTR2]CTRDAT
  If !fstat
    For [F:FJH] Where ([F:FJH]COD = [L]FLUX | [L]FLUX = "")
       If [F:FJH]COD <> GSVFLUX               : # si c'est le même on ne recherche pas à chaque contrat
        Call GET_TTYPMGR([F:FJH]COD,GTTYPMGR) From TRTPREPAY
       Endif
       GSVFLUX = [F:FJH]COD
       ISCHEF = func DIVPAYE.ISCHEF(GREFNUM,GTTYPMGR,[L]REF,[F:CTR2]CTRNUM,[F:CTR2]CTRDAT,"1234")
       If ISCHEF
        OKF = 1
        Break
       Endif
    Next
  Endif
 Endif
 If OK & OKF                                : # on est bon pour le contrat et le flux
  Break
 Endif
Next
Filter [F:CTR2]

If CREAGLOB
 Kill [V]GDONOTCLOSE , [V]GSVFLUX , [V]GTTYPMGR
Endif

If OK=-1 & !OKF & GREFNUM <> "" & GREFNUM <> [L]REF
 GMESSAGE = [L]REF-":"-mess(158,10702,1)      : # Pas de contrat valide sur la période
 mkstat = 2 : End                           : # pas possible de se prononcer sur la hierarchie
Endif

If !OK | !OKF
 GMESSAGE = [L]REF-":"-mess(31,10702,1)       : # Vous n'avez pas les droits pour ce salarié
 mkstat = 2 : End
Endif
End

#-----------------------------------------------------------
# SEGAY 01/07/11 DEM 71093 77414
# Performances lectures subordonnés EMPSBD (ESB)
# Appeler depuis CHECKSUBORDONNESFLUX de PORMAT
# Les tests sur les flux sont fait en amont et GSUPER
# On n'a pas besoin de boucler sur le contrat comme dans CHECK_SUBORD
#-----------------------------------------------------------
Subprog CHECK_SUBORD_OKF(REF,CTR,FLUX,DAT,OKF)
Value    Char    REF()
Value    Char    CTR()
Value    Char    FLUX()
Value    Date    DAT
Value    Integer OKF

Local Integer ISCHEF
Local Integer OK
Local Char    CRIT (250)
Local Integer CREAGLOB

If clalev([F:FJH]) =0 : Local File FLXJOB   [FJH]  : Endif
If clalev([F:ID])  =0 : Local File EMPLOID  [ID]   : Endif
If clalev([F:ACC]) =0 : Local File ACCES    [ACC]  : Endif
If !clalev([F:ESB])  : Local File EMPSBD [ESB]    : Endif

If dim(GDONOTCLOSE) > 0
 CREAGLOB = 0
Else
 Global Integer GDONOTCLOSE
 Global Char    GSVFLUX (GLONFJH)
 Global Integer GTTYPMGR(len(mess(0,50,1)))
 CREAGLOB = 1
Endif

#4 LIGNES ci-dessous pour le ISCHEF de TRTPREPAY
If clalev([F:WCTR]) = 0 : Local File EMPLOCTR [WCTR] : Endif
If clalev([F:WAD])  = 0 : Local File EMPLOAD  [WAD]  : Endif
If clalev([F:WSRV]) = 0 : Local File SERVICE  [WSRV] : Endif
If clalev([F:WFCY]) = 0 : Local File FACILITY [WFCY] : Endif
# LIGNE ci-dessous pour le GET_TTYPMGR de TRTPREPAY
If clalev([F:WFJR]) = 0 : Local File FLXJOBRSP [WFJR] : Endif

If CREAGLOB
 Link [WCTR]
&      With  [WAD]AD0=[F:WCTR]REFNUM
&      As    [WLNK]
Endif

Read [F:ID]ID0 = [L]REF

OK=-1

Call CONTROLE(REF,DAT,CTR,"",OK,1) From DIVPAYE

If GREFNUM = "" | GREFNUM = [L]REF         : # Chef de soi-même (aux droits près)
  OKF = 1
Endif
If OK & !OKF
  Read [F:ESB]ESB1(4) = GREFNUM;[L]REF;[L]CTR;[L]DAT
  If !fstat
    For [F:FJH] Where ([F:FJH]COD = [L]FLUX | [L]FLUX = "")
       If [F:FJH]COD <> GSVFLUX               : # si c'est le même on ne recherche pas à chaque contrat
        Call GET_TTYPMGR([F:FJH]COD,GTTYPMGR) From TRTPREPAY
       Endif
       GSVFLUX = [F:FJH]COD
       ISCHEF = func DIVPAYE.ISCHEF(GREFNUM,GTTYPMGR,[L]REF,[L]CTR,[L]DAT,"1234")
       If ISCHEF
        OKF = 1
        Break
       Endif
    Next
  Endif
Endif

If CREAGLOB
 Kill [V]GDONOTCLOSE , [V]GSVFLUX , [V]GTTYPMGR
Endif

If OK=-1 & !OKF & GREFNUM <> "" & GREFNUM <> [L]REF
 GMESSAGE = [L]REF-":"-mess(158,10702,1)      : # Pas de contrat valide sur la période
 mkstat = 2 : End                           : # pas possible de se prononcer sur la hierarchie
Endif

If !OK | !OKF
 GMESSAGE = [L]REF-":"-mess(31,10702,1)       : # Vous n'avez pas les droits pour ce salarié
 mkstat = 2 : End
Endif
End

################################################################################
## Initialisations pour les appels de CHECK_SUBORD from DIVPAYE
##
## Si on doit enchaîner les appels dans une boucle sur les contrats par exemple
## l'appel de INIT_CHECK_SUBORD avant la boucle permet d'optimiser les perfs.
## Remonter l'appel de l'init le plus haut possible dans la pile des traitements
## exécutés.
##
## Si on veut se débarrasser des globales à la fin du trt qui appelle l'init
## faire
##  avant l'appel    Local Integer CREAGLOB
#   en fin de trt    If CREAGLOB :  Kill GDONOTCLOSE , GSVFLUX , GTTYPMGR : Endif
##
################################################################################
#-----------------------------------------------------------
# SEGAY 01/07/11 DEM 71093
# Performances lectures subordonnés EMPSBD (ESB)
#-----------------------------------------------------------
$INIT_CHECK_SUBORD

#4 LIGNES ci-dessous pour le CHECK_SUBORD de DIVPAYE
If !clalev([F:CTR2]) : Local File EMPLOCTR [CTR2] : Endif
If !clalev([F:FJH])  : Local File FLXJOB   [FJH]  : Endif
If !clalev([F:ID])   : Local File EMPLOID  [ID]   : Endif
If !clalev([F:ACC])  : Local File ACCES    [ACC]  : Endif

#4 LIGNES ci-dessous pour le ISCHEF de TRTPREPAY
If clalev([F:WCTR]) = 0 : Local File EMPLOCTR [WCTR] : Endif
If clalev([F:WAD])  = 0 : Local File EMPLOAD  [WAD]  : Endif
If clalev([F:WSRV]) = 0 : Local File SERVICE  [WSRV] : Endif
If clalev([F:WFCY]) = 0 : Local File FACILITY [WFCY] : Endif
# LIGNE ci-dessous pour le GET_TTYPMGR de TRTPREPAY
If clalev([F:WFJR]) = 0 : Local File FLXJOBRSP [WFJR] : Endif
If clalev([F:WESB]) = 0 : Local File EMPSBD [WESB] : Endif

If dim(GDONOTCLOSE) < 0
 Global Integer GDONOTCLOSE
 Global Char    GSVFLUX (GLONFJH)
 Global Integer GTTYPMGR(len(mess(0,50,1)))
 If dim(CREAGLOB)>0 : CREAGLOB = 1 : Endif
Endif
Return

#-----------------------------------------------------------
# SEGAY 01/07/11 DEM 71093
# Performances lectures subordonnés EMPSBD (ESB)
# Détermine si un matricule (MGR) est dans la liste des
# chefs pour une série de fonction (TTYPMGR) et à un niveau
# donné ; plusieurs niveaux sont cumulables
# 1 : contrat, 2 : salarié, 3 : service, 4 : site
#-----------------------------------------------------------
Funprog ISCHEF(MGR, TTYPMGR, MATRI, CTR, CTRDAT, NIVEAU)
Value Char MGR()
Value Integer TTYPMGR()
Value Char MATRI(), CTR()
Value Date CTRDAT
Value Char NIVEAU()

Local Integer ISCHEF
Local Integer L_NIVEAU
Local Integer L_I
Local Integer INDEX

Raz [L]ISCHEF

If clalev([F:WESB]) = 0 : Local File EMPSBD [WESB] : Endif

L_I=0

While TTYPMGR(L_I)<>0 & ![L]ISCHEF
  INDEX = TTYPMGR(L_I)
  L_I+=1

  If instr(1, [L]NIVEAU, "1") > 0
    L_NIVEAU=1
    If [L]CTR <> ""
      Read [F:WESB]ESB1=[L]MGR;[L]MATRI;[L]CTR;[L]CTRDAT;[L]L_NIVEAU;[L]INDEX
    Else
      # FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
      Filter [F:WESB] Where [F:WESB]CHEF=[L]MGR & [F:WESB]REFNUM=[L]MATRI & ([F:WESB]CTRDAT<=[L]CTRDAT | ([F:WESB]FLGRET=2 & [F:WESB]RETDATEFF<=[L]CTRDAT))
&                           & [F:WESB]NIVEAU=[L]L_NIVEAU & [F:WESB]RANG=[L]INDEX
&      Order By Key CLE=[F:WESB]CHEF;[F:WESB]REFNUM;[F:WESB]CTRDAT;[F:WESB]NIVEAU;[F:WESB]RANG
      Read [F:WESB] Last
    Endif
    If !(fstat > 2) Then
      [L]ISCHEF=1
    Endif
  Endif
  Filter [F:WESB]
  If ![L]ISCHEF & instr(1, [L]NIVEAU, "2") > 0
    L_NIVEAU=2
    If [L]CTR <> ""
      Read [F:WESB]ESB1=[L]MGR;[L]MATRI;[L]CTR;[L]CTRDAT;[L]L_NIVEAU;[L]INDEX
    Else
      # FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
      Filter [F:WESB] Where [F:WESB]CHEF=[L]MGR & [F:WESB]REFNUM=[L]MATRI & ([F:WESB]CTRDAT<=[L]CTRDAT | ([F:WESB]FLGRET=2 & [F:WESB]RETDATEFF<=[L]CTRDAT))
&                           & [F:WESB]NIVEAU=[L]L_NIVEAU & [F:WESB]RANG=[L]INDEX
&      Order By Key CLE=[F:WESB]CHEF;[F:WESB]REFNUM;[F:WESB]CTRDAT;[F:WESB]NIVEAU;[F:WESB]RANG
      Read [F:WESB] Last
    Endif
    If !(fstat > 2) Then
      [L]ISCHEF=1
    Endif
  Endif
  Filter [F:WESB]
  If ![L]ISCHEF & instr(1, [L]NIVEAU, "3") > 0
    L_NIVEAU=3
    If [L]CTR <> ""
      Read [F:WESB]ESB1=[L]MGR;[L]MATRI;[L]CTR;[L]CTRDAT;[L]L_NIVEAU;[L]INDEX
    Else
      # FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
      Filter [F:WESB] Where [F:WESB]CHEF=[L]MGR & [F:WESB]REFNUM=[L]MATRI & ([F:WESB]CTRDAT<=[L]CTRDAT | ([F:WESB]FLGRET=2 & [F:WESB]RETDATEFF<=[L]CTRDAT))
&                           & [F:WESB]NIVEAU=[L]L_NIVEAU & [F:WESB]RANG=[L]INDEX
&      Order By Key CLE=[F:WESB]CHEF;[F:WESB]REFNUM;[F:WESB]CTRDAT;[F:WESB]NIVEAU;[F:WESB]RANG
      Read [F:WESB] Last
    Endif
    If !(fstat > 2) Then
      [L]ISCHEF=1
    Endif
  Endif
  Filter [F:WESB]
  If ![L]ISCHEF & instr(1, [L]NIVEAU, "4") > 0
    L_NIVEAU=4
    If [L]CTR <> ""
      Read [F:WESB]ESB1=[L]MGR;[L]MATRI;[L]CTR;[L]CTRDAT;[L]L_NIVEAU;[L]INDEX
    Else
      # FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
      Filter [F:WESB] Where [F:WESB]CHEF=[L]MGR & [F:WESB]REFNUM=[L]MATRI & ([F:WESB]CTRDAT<=[L]CTRDAT | ([F:WESB]FLGRET=2 & [F:WESB]RETDATEFF<=[L]CTRDAT))
&                           & [F:WESB]NIVEAU=[L]L_NIVEAU & [F:WESB]RANG=[L]INDEX
&      Order By Key CLE=[F:WESB]CHEF;[F:WESB]REFNUM;[F:WESB]CTRDAT;[F:WESB]NIVEAU;[F:WESB]RANG
      Read [F:WESB] Last
    Endif
    If !(fstat > 2) Then
      [L]ISCHEF=1
    Endif
  Endif
  Filter [F:WESB]
Wend

$FINISH
# Fermeture
If dim([V]GDONOTCLOSE) < 1
 Close Local File [WESB]
Endif
End [L]ISCHEF

