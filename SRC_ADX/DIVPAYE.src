#MIPEA - 2016-11-14 - X3PEOP-1200- START
## PEVAN - 2018-05-02 - X3-86069 - START
#Funprog CUMRESET(DATPREC,DATFIN,INICUM,MATRI,BULLETIN,CTR,PERCOD,PERYEA,PERNUM,PERCODPREC,PERYEAPREC,PERNUMPREC)
Funprog CUMRESET(DATPREC,DATFIN,INICUM,MATRI,BULLETIN,CTR,PERCOD,PERYEA,PERNUM,PERCODPREC,PERYEAPREC,PERNUMPREC,PERIODICITY)
## PEVAN - 2018-05-02 - X3-86069 - END
Value Date DATPREC,DATFIN
Value Char INICUM,MATRI,BULLETIN,CTR,PERCOD,PERCODPREC
Value Shortint PERYEA,PERNUM,PERYEAPREC,PERNUMPREC
Value Char PERIODICITY
Local Integer RESETSTATUS
#MIPEA - 2017-06-28 - X3PEOP-1200- START
Local Integer EOSTR1,SOSTR1
#MIPEA - 2017-06-28 - X3PEOP-1200- END

[L]RESETSTATUS=0

If clalev([F:HRPEOD])=0 : Local File HRPEODET [HRPEOD] : Endif
If clalev([F:HRPEOD2])=0 : Local File HRPEODET [HRPEOD2] : Endif
#MIPEA - 2017-06-28 - X3PEOP-1200- START
If clalev([F:HRPEOH])=0 : Local File HRPEOHEA [HRPEOH] : Endif
#MIPEA - 2017-06-28 - X3PEOP-1200- END

#MIPEA - 2018-04-11 - X3-86069- START
Local Integer TAXMONPREC, TAXMONCUR

Read [HRPEOD]HRPEOD0 = PERCODPREC;PERYEAPREC;PERNUMPREC
[L]TAXMONPREC = [F:HRPEOD]TAXMON

Read [HRPEOD]HRPEOD0 = PERCOD;PERYEA;PERNUM
[L]TAXMONCUR = [F:HRPEOD]TAXMON
#MIPEA - 2018-04-11 - X3-86069- END

If month(DATPREC)<month(DATFIN)
  J = month(DATPREC)+1
Else
  J = month(DATPREC)
Endif

K = month(DATFIN)+12*(year(DATFIN)-year(DATPREC))

Filter [F:HRPEOD] Where PERCOD=[L]PERCOD & PERYEA=[L]PERYEA & PERNUM=[L]PERNUM
Read [F:HRPEOD]HRPEOD0 = [L]PERCOD;[L]PERYEA;[L]PERNUM
Filter [F:HRPEOD]

Read [F:HRPEOH]HRPEOH0 = [L]PERYEA;[L]PERCOD

#MIPEA - 2017-06-28 - X3PEOP-1200- START
EOSTR1 = eomonth([F:HRPEOD]PERSTR(1))-[F:HRPEOD]PERSTR(1)
SOSTR1 = [F:HRPEOD]PEREND(1)-gdat$(1,month([F:HRPEOD]PEREND(1)),year([F:HRPEOD]PEREND(1)))
#MIPEA - 2017-06-28 - X3PEOP-1200- END

If [L]PERNUM=1
  Filter [F:HRPEOD2] Where PERCOD=[L]PERCOD & PERYEA=([L]PERYEA-1)
  Read [F:HRPEOD2]HRPEOD0 Last
  Filter [F:HRPEOD2]
Else
  Read [F:HRPEOD2]HRPEOD0 = [L]PERCOD;[L]PERYEA;([L]PERNUM-1)
Endif
#If GUSER="MIPEA":Infbox INICUM:Endif
#MIPEA - 2017-06-28 - X3PEOP-1200- START
If (EOSTR1>SOSTR1) & ([F:HRPEOH]PAYFRQ=6) & ([F:HRPEOD]PEREND(1)<>eomonth([F:HRPEOD]PEREND(1)))
  J-=1 : K-=1
Endif
#MIPEA - 2017-06-28 - X3PEOP-1200- END
If INICUM <> "XXXXXXXXXXXX"
  If K>=J & instr(1,seg$(INICUM,J,K),"O")
    #If GUSER="MIPEA":Infbox "IN NORMAL":Endif
    If (([F:HRPEOD]TAXMON <> [F:HRPEOD2]TAXMON) & [F:HRPEOD]PERMON = 1) & (([L]PERCOD <> [L]PERCODPREC) or ([L]PERYEA <> [L]PERYEAPREC) or ([L]PERNUM <> [L]PERNUMPREC))
    #If GUSER="MIPEA":Infbox "CLEAR NORMAL":Endif
      [L]RESETSTATUS=1
#MIPEA - 2018-04-11 - X3-86069- START
    Elsif (([L]PERCOD <> [L]PERCODPREC) or ([L]PERYEA <> [L]PERYEAPREC))
      [L]RESETSTATUS=1
#MIPEA - 2018-04-11 - X3-86069- END
#MIPEA - 2018-04-11 - X3-86069- START
    Elsif (([L]TAXMONCUR <> [L]TAXMONPREC) & (PERIODICITY<>"9"))
      [L]RESETSTATUS=1
#MIPEA - 2018-04-11 - X3-86069- END
    Else
      [L]RESETSTATUS=0
    Endif
  Endif
Else
    If (([L]PERCOD <> [L]PERCODPREC) or ([L]PERYEA <> [L]PERYEAPREC) or ([L]PERNUM <> [L]PERNUMPREC))
    #If GUSER="MIPEA":Infbox "CLEAR MF":Endif
      [L]RESETSTATUS=1
    Else
      [L]RESETSTATUS=0
    Endif
Endif

End [L]RESETSTATUS
#MIPEA - 2016-11-14 - X3PEOP-1200- END

