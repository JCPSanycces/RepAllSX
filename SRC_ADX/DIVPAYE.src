#SEGAY 25/10/12 US 940 81085
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
#DBA : 91298
#If dim([M]LEG)>0 & VALEUR<>""
#ADNGO - 2017-06-07 - X3-11585 - START - Gave an error on function FUNEMLPAY
  If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
#ADNGO - 2017-06-07 - X3-11585 - END
#LIMAS - 2018-01-18 - X3-72057 - START - Gave an error on function GESEPAGPP
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
#LIMAS - 2018-01-18 - X3-72057 - END
If dim([M]LEG)>0
#
 Read [F:FCY]FCY0=VALEUR
 If !fstat
  Read [F:CPY]CPY0=[F:FCY]LEGCPY
  If !fstat
   If [M]LEG<>[F:CPY]LEG
    [M]LEG=[F:CPY]LEG
    #Call INIT_BYLEG([M]LEG) :#MABOS-25/01/2013
    GCURLEG = [M]LEG
    Call INIT_BYLEG(GCURLEG)
   Endif
   #DBA : 91298
   #[M]LEG=[F:CPY]LEG : Diszo [M]LEG : Affzo [M]LEG,ZLEG
   #SBA on remonte car réini uniquement si changement de leg
   #GCURLEG = [M]LEG
   #Call INIT_BYLEG(GCURLEG)
   Affzo [M]
   #
  Endif
 Endif
Endif
