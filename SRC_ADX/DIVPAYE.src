#86255
#Grise la zone LEG si une société (Attention cas particulier des groupes sociétés multi-leg !)
#Pas tous les trt de masse contiennent la zone FCY
######################################################
Subprog AFF_MEMO
#MABOS-08/08/13-FQ91298-US1835-Technical Review
#If dim([M]LEG)>0
# GCURLEG=[M]LEG
# If dim([M]FCY)>0
#  Call GRISE_LEG([M]CPY,[M]FCY) From DIVPAYE
# Else
#  Call GRISE_LEG([M]CPY,"") From DIVPAYE
# Endif
## Gosub GRISE :#Déplacer car si pas de leg, il faut qd même passer dans GRISE
#Endif
#Gosub GRISE :#si pas de Leg, il faut qd même y passer.
Call AFF_MEMO2(1)

#ATTENTION, lorsque la LEG n'est pas obligatoire
#et que la leg du mémo ="", ceci affecte LEG avec GLEGFIL
# Donc qd LEG non obligatoire, ne pas utiliser ce Subprog
# et initialiser GCURLEG avant le chargement du mémo
#If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
#If GLEGFIL<>"" & GCURLEG="" : GCURLEG = GLEGFIL : Endif
Call INI_LEG
#end MABOS-08/08/13-FQ91298-US1835-Technical Review
End

Subprog INI_LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
If GLEGFIL<>"" & GCURLEG="" : GCURLEG = GLEGFIL : Endif
If dim([M]LEG)>0
 [M]LEG=GCURLEG
Endif
End

#**#####################################################################################
#* Rafraichir écran suite appel mémo
#* @param LEG_MODIF Leg modifiable : 0:no - 1:yes
#*!
Subprog AFF_MEMO2(LEG_MODIF)
Value Integer LEG_MODIF
If dim([M]LEG)>0 & [L]LEG_MODIF
 GCURLEG=[M]LEG
 Actzo [M]LEG
 If dim([M]FCY)>0
  Call GRISE_LEG([M]CPY,[M]FCY) From DIVPAYE
 Elsif dim([M]CPY)>0
  Call GRISE_LEG([M]CPY,"") From DIVPAYE
 Endif
Endif
Gosub GRISE
End

#**#####################################################################################
#* surcharge de init_byleg,
#* Utilisable que sur du standard
#* @param Valeur
#* @param CHP : nom du champ
#* @param TRT : nom du traitement
#*!
Subprog SPE_INITBYLEG_CHAR(VALEUR,CHP,TRT)
Variable Char VALEUR
Value Char CHP,TRT
  Gosub INI_SPE_INITBYLEG
  Case CHP
    When "FCY":  Call AM_FCY(VALEUR)
    When "LEG":  Call AM_LEG(VALEUR)
    When "CPY":  Call AM_CPY(VALEUR)
    When Default :
      # do nothing
  Endcase
  Gosub EXE_SPE_INITBYLEG
End
################################################################################
Subprog SPE_INITBYLEG_INT(VALEUR,CHP,TRT)
Variable Integer VALEUR
Value Char CHP,TRT

Gosub INI_SPE_INITBYLEG
Case CHP
    When "ALLCPY":  Call AM_ALLCPY(VALEUR)
    When Default :
      # do nothing
  Endcase
 Gosub EXE_SPE_INITBYLEG
 End

################################################################################
$INI_SPE_INITBYLEG
If dim([M]LEG)>0
    Local Char OLD_LEG(5)
    OLD_LEG=[M]LEG
 Endif

Return

################################################################################
$EXE_SPE_INITBYLEG
    If(dim([M]LEG)>0 and  (OLD_LEG<>[M]LEG))
      Call INIT_BYLEG([M]LEG) From =TRT
 Endif
Return

#MABOS-called by IMPORTEVA
#------------------------------------------------------------------------------------------------
#            Search the good record [CTRNUM] for IMPORT in TIMEMP
#------------------------------------------------------------------------------------------------
Subprog SEARCH_CTR(WREFNUM, WCTRNUM, WCTRDAT, WDAT1, WDAT2, WMESS)
Variable Char WREFNUM(), WCTRNUM()
Variable Date WCTRDAT
Value Date WDAT1, WDAT2
Variable Char WMESS()
Local Integer NBCTR
Local Char    CTRNUM(20), CRITDAT(250)

If !([L]WCTRNUM<>"" and [L]WCTRDAT<>[0/0/0])  Then
# Au moins CTRNUM ou CTRDAT non renseigné

#Filter [CTR] Where REFNUM=[L]WREFNUM & CTRDAT<=[L]DAT1
#&                & (XITDAT=[0/0/0] | XITDAT>=[L]DAT2)
#&     Order By Key CLE=CTRDAT Desc
#Read [CTR] First

#MABOS-10/07/13-FQ89268-US1728-test date
#         Filter [CTR] Where REFNUM=[L]WREFNUM
#&     & ( ([L]WCTRNUM <>"" & CTRNUM=[L]WCTRNUM) | [L]WCTRNUM ="" )
#&     & (  ( [L]WCTRDAT<>[0/0/0] & CTRDAT=[L]WCTRDAT)
#&        | ( [L]WCTRDAT =[0/0/0] & CTRDAT<=[L]WDAT1 & (XITDAT=[0/0/0] | XITDAT>=[L]WDAT2)))
   [L]CRITDAT="1=1"
   # FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
   If WDAT1<>[0/0/0] Then CRITDAT -= "& (CTRDAT<=[L]WDAT1 | (FLGRET=2 & RETDATEFF<=[L]WDAT1))" : Endif
   If WDAT2<>[0/0/0] Then CRITDAT -= "& (XITDAT=[0/0/0] | XITDAT>=[L]WDAT2)" : Endif

      Filter [HRCTR] Where REFNUM=[L]WREFNUM
&     & ( ([L]WCTRNUM <>"" & CTRNUM=[L]WCTRNUM) | [L]WCTRNUM ="" )
&     & (  ( [L]WCTRDAT<>[0/0/0] & CTRDAT=[L]WCTRDAT)
&        | ( [L]WCTRDAT =[0/0/0] & evalue([L]CRITDAT) ))
&     Order By Key CLE=CTRDAT Desc
#end MABOS-10/07/13-FQ89268-US1728

    [L]NBCTR=rowcount([F:HRCTR])
    If [L]NBCTR= 1
        # OK trouvé
    Elsif [L]NBCTR <1
        [L]WMESS=mess(26,10701,1) : # Contrat inexistant
    Elsif [L]WCTRNUM <>""
        # Ok : plusieurs CTRDAT pour un seul CTRNUM
    Elsif [L]WCTRDAT<>[0/0/0]
        # + [L]NBCTR > 1 - <-> Pls CTRNUM differents
         [L]WMESS=mess(19,10715,1)+"."-mess(20,10715,1) : ## Le salarié a plusieurs contrats simultanés -'Vous devez précisez le contrat concerné dans le fichier
    Else : # [L]NBCTR > 1
        [L]CTRNUM=""
        For [HRCTR]
          If [L]CTRNUM="" Then
            [L]CTRNUM=[F:HRCTR]CTRNUM
          Elsif  [L]CTRNUM<>[F:HRCTR]CTRNUM
            [L]WMESS=mess(19,10715,1)+"."-mess(20,10715,1) : # Le salarié a plusieurs contrats simultanés -'Vous devez précisez le contrat concerné dans le fichier
            Break
          Endif
        Next
    Endif
    If [L]WMESS=""
        Read [HRCTR] First
        If fstat
          [L]WMESS=mess(26,10701,1) : # Contrat inexistant
        Else
          If [L]WCTRNUM = ""     Then [L]WCTRNUM=[F:HRCTR]CTRNUM : Endif
#          If [L]WCTRDAT =[0/0/0] Then [L]WCTRDAT=[F:HRCTR]CTRDAT : Endif :# on ne le fait que dans le traitement appelant si besoin

        Endif
    Endif
    Filter [HRCTR]
Endif


If [L]WMESS="" & [L]WCTRNUM<>"" and [L]WCTRDAT<>[0/0/0]  Then
# CTRNUM et CTRDAT renseignés
   Read [F:HRCTR]CTR0=[L]WREFNUM;[L]WCTRNUM;[L]WCTRDAT
   If fstat
    [L]WMESS=mess(26,10701,1) : # Contrat inexistant
   Else
     #MABOS-10/07/13-FQ89268-US1728-test date
     #If  [F:HRCTR]CTRDAT<=[L]WDAT1  & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=[L]WDAT2) Then
     If  ( [L]WDAT1 = [0/0/0] | ([F:HRCTR]CTRDAT<=[L]WDAT1  | ([F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<=[L]WDAT1) ) )
&         & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=[L]WDAT2) Then

# Date ok
     Else
       [L]WMESS=mess(138,10701,1) : # Contrat incompatible avec l'événement
     Endif
   Endif
Endif

If  [L]WMESS<> ""
  [L]WMESS = [L]WREFNUM+"/"+[L]WCTRNUM+"/"+format$("D:"+GFMDAT4,[L]WCTRDAT)-[L]WMESS
#  Call TRACE(2,[L]WMESS) From SUBIMPOBJ
  [V]GOK=0
Endif

End
# end MABOS-22/05/13-FQ89268-US1612

#90133
#** Fonction qui passe à 1 les zones ML de type 1 d'un écran si celles-ci contiennent 0.
#*  En paramètre on passe le code de l'écran à traiter.
#*!
Subprog INI_ML1(AMKNAME)
Value Char AMKNAME

  If AMKNAME="" : End : Endif

  If !clalev([F:AMZ]) : Local File AMSKZON [AMZ] : Endif

  Filter [AMZ] Where CODMSK=AMKNAME & CODTYP="M" & NOLIB=1
  For [F:AMZ]CODE
    If evalue("dim([M:"+AMKNAME+"]"+[F:AMZ]CODZON+")")>=0 & evalue("[M:"+AMKNAME+"]"+[F:AMZ]CODZON)=0
      Assign("[M:"+AMKNAME+"]"+[F:AMZ]CODZON) With 1
    Endif
  Next
End
#end 90133

##################################################
# FQ81085 - 17/12/13 - Actions INIMNL et SELMNLEMP
Subprog INIMNL(FCYORG,PARAM,ZONE)
Value    Char    FCYORG
Value    Char    PARAM
Value    Char    ZONE
Local    Char    NUMLIB(10)

  If dim(GNOLIB)<0 Then Global   Integer GNOLIB : Endif

  If FCYORG="" Then
    If PARAM="CIVIL" Then
      If ZONE="CIVA" Then
        If clalev([F:ID2])=0  : Local File EMPLOID [ID2]   : Endif
        Read [F:ID2]ID0=[M]REFNUM(nolign-1)
        If !fstat Then
          FCYORG=[F:ID2]FCYORI
        Endif
      Endif
      If ZONE="CIVCTRA" Then
        If dim([M]ETRFCY)>0 Then
          FCYORG=[M]ETRFCY(nolign-1)
        Else
          If clalev([F:CTR2])=0 : Local File EMPLOCTR [CTR2] : Endif
          Read [F:CTR2]CTR0=[M]REFNUM(nolign-1);[M]CTRNUM(nolign-1);[M]CTRDAT(nolign-1)
          If !fstat Then
            FCYORG=[F:CTR2]ETRFCY
          Endif
        Endif
      Endif
    Endif
    If PARAM="SITFAM" Then
      If dim([M]FCYORI)>0 Then
        FCYORG=[M]FCYORI(nolign-1)
      Else
        If clalev([F:ID2])=0  : Local File EMPLOID [ID2]   : Endif
        Read [F:ID2]ID0=[M]REFNUM(nolign-1)
        If !fstat Then
          FCYORG=[F:ID2]FCYORI
        Endif
      Endif
    Endif
  Endif
  Call PARAM(FCYORG,PARAM,NUMLIB) From ADOVAL
  GNOLIB=val(NUMLIB)
End

$SEL_MNLEMP
Local Integer NOL , CHAP
Local Char    CRITERE(100)
Local Char    TEX(10)(0..200) , TEXTE(200)(0..200)

  If clalev([F:AST])=0 : Local File APLSTD [AST] : Endif
  CHAP = val(PARAM(1))
  NOL = nolign-1
  If dim([M]TXT)>0
   VALEUR = num$([M]TXT(NOL))
  Endif
  CRITERE = "LANCHP="+num$(CHAP)
  CRITERE += ' & LAN="'+GLANGUE+'"'
  CRITERE += " & LANNUM<>0"
  Raz NBTEX
  For [AST]CLE Where evalue(CRITERE)
   If NBTEX+1>dim(TEX)-1 : Break : Endif
   NBTEX +=1
   TEX(NBTEX)   = num$([F:AST]LANNUM)
   TEXTE(NBTEX) = [F:AST]LANMES
  Next AST
  If clalev([F:AST7])=0 : Local File APLSTD  [AST7] : Endif
  If CHAP<100
    Read [AST7]CLE = 0;CHAP;GLANGUE
  Else
    Read [AST7]CLE = 200;CHAP-200;GLANGUE
  Endif
  If !fstat
    TIT = [F:AST7]LANMES
  Else
    TIT = mess(0,CHAP,1)
  Endif
Return

$FIN_MNLEMP

  If val(VALEUR)>0 Then
    Local    Char    NUMLIB(10)
    If dim([M:GEN]SITFAM)>0 Then
      Call PARAM([F:ID]FCYORI,"SITFAM",NUMLIB) From ADOVAL
      If NUMLIB=PARAM(1) Then
        [M:GEN]SITFAM(nolign-1)=val(VALEUR)
        # FQ81085 - 25/11/13 - On ne grise le conjoint que si on est leg FRA
        If GCURLEG="FRA" & val(VALEUR)=1 Then
           If dim([M:GEN]JNTNAM)>0    Then Effzo [M:GEN]JNTNAM(nolign-1)    : Grizo [M:GEN]JNTNAM(nolign-1)     : Endif
           If dim([M:GEN]JNTREFNUM)>0 Then Effzo [M:GEN]JNTREFNUM(nolign-1) : Grizo [M:GEN]JNTREFNUM(nolign-1)  : Endif
           If dim([M:GEN]JNTTEL)>0    Then Effzo [M:GEN]JNTTEL(nolign-1)    : Grizo [M:GEN]JNTTEL(nolign-1)     : Endif
        Else
         If dim([M:GEN]JNTNAM)>0    Then Actzo [M:GEN]JNTNAM(nolign-1)    : Endif
         If dim([M:GEN]JNTREFNUM)>0 Then Actzo [M:GEN]JNTREFNUM(nolign-1) : Endif
         If dim([M:GEN]JNTTEL)>0    Then Actzo [M:GEN]JNTTEL(nolign-1)    : Endif
        Endif
      Endif
    Endif
    If dim([M:GEN]CIV)>0 Then
      Call PARAM([F:ID]FCYORI,"CIVIL",NUMLIB) From ADOVAL
      If NUMLIB=PARAM(1) Then [M:GEN]CIV(nolign-1)=val(VALEUR) : Endif
    Endif
    VALEUR=mess(val(VALEUR),GNOLIB,1)
  Endif
Return
# fin FQ81085

##################################################

##################################################
Subprog CONTSAIMNL(VALEUR,PARAM,ZONE)
Variable Char    VALEUR
Value    Char    PARAM
Value    Char    ZONE
Local    Integer OKENR

  OKENR=0
  If mess(0,GNOLIB,1)<>"" Then
    For I=1 To len(mess(0,GNOLIB,1))
      If mess(I,GNOLIB,1)=VALEUR Then
        OKENR=1
        If PARAM="SITFAM" Then [M]SITFAM(nolign-1)=I : Endif
        If PARAM="CIVIL"  Then
          If ZONE="CIVA"    Then [M]CIV(nolign-1)=I    : Endif
          If ZONE="CIVCTRA" Then [M]CIVCTR(nolign-1)=I : Endif
        Endif
        Break
      Endif
    Next
  Else
    OKENR=1
  Endif
  If OKENR=0 Then mkstat=2 : Endif
End

