#JOJAC - 2016-07-25 - REQ114309 - START
Subprog CTRDAT_STR_END(MATRI,CTR,DATREF,STRDAT,ENDDAT)
Value    Char MATRI(), CTR()
Value    Date DATREF
Variable Date STRDAT, ENDDAT

  If clalev([F:CTRT])=0 : Local File EMPLOCTR [CTRT] : Endif

  If !GPAYE or dim([F:CTRT]FLGCREBUL) <= 0 : End : Endif

  STRDAT=DATREF : ENDDAT=DATREF

  Filter [F:CTRT] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATREF & FLGCREBUL=2
  Read [F:CTRT] Last
  Filter [F:CTRT]
  If !fstat Then
    STRDAT=[F:CTRT]CTRDAT
    # FQ91472 US2912 SEGAY
    Read [F:CTRT] Next
    If fstat | (!fstat & [F:CTRT]REFNUM=MATRI & [F:CTRT]CTRNUM=CTR & [F:CTRT]FLGCREBUL=2) Then
       End
    Endif
    # END FQ91472 US2912 SEGAY
  Endif

  Filter [F:CTRT] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT>=DATREF & FLGCREBUL<>2
  Read [F:CTRT] Last
  Filter [F:CTRT]
  If !fstat Then
    ENDDAT=[F:CTRT]CTRDAT
  Endif
End
#JOJAC - 2016-07-25 - REQ114309 - END

#LIPET - 2016-10-27 - X3PEOP-1244 -START
Subprog VERIF_FILTRE_TIM(FILTRE,POP,REFNUM,CTRNUM,RET)
Value    Char    FILTRE(),POP(),REFNUM(),CTRNUM()
Variable Integer RET
Local    Char    MATRI(GLONEML),CTR(GLONHRCTR)
Local    Date    DATMAT

  RET=0

  # Lecture des enregistrements des tables EMPLOxxx pour évaluation de [F:TIM]FILTRE
  Gosub OUVRE From WPDEFTABLE
  If clalev([F:HRPOP])=0  : Local File POPUL    [HRPOP]  : Endif
  If clalev([F:HRPOA])=0  : Local File POPULA   [HRPOA]  : Endif
  If clalev([F:HRCTR2])=0 : Local File EMPLOCTR [HRCTR2] : Endif

  MATRI  = [L]REFNUM
  DATMAT = date$

  If [L]CTRNUM<>"" Then
    If [F:HRCTR]REFNUM<>REFNUM | [F:HRCTR]CTRNUM<>[L]CTRNUM Then
      Filter [F:HRCTR2] Where REFNUM=[L]REFNUM & CTRNUM=[L]CTRNUM & (XITDAT=[0/0/0] or XITDAT>date$) Order By CTRDAT
      Read [F:HRCTR2] Last
      Filter [F:HRCTR2]
      CTR = [F:HRCTR2]CTRNUM
    Else
      CTR = [F:HRCTR]CTRNUM
    Endif

    Gosub LECEMP From DEFTABLE
    # Vérification du filtre
    If FILTRE<>"" & !evalue(FILTRE) Then
      RET=1 : End
    Endif
  Else
    # FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
    Filter [F:HRCTR2] Where REFNUM=[L]REFNUM & ((FLGRET<>2 & CTRDAT<=date$) | (FLGRET=2 & RETDATEFF<=date$)) & (XITDAT=[0/0/0] or XITDAT>date$) Order By CTRDAT
    For [F:HRCTR2]
      CTR = [F:HRCTR2]CTRNUM
      Gosub LECEMP From DEFTABLE
      # Vérification du filtre : si sur un contrat, il n'est pas vérifié, on sort
      If FILTRE<>"" & !evalue(FILTRE) Then
        RET=1 : Break
      Endif
    Next
    Filter [F:HRCTR2]
  Endif

  If RET=1 Then End : Endif

  # Vérification de la population
  If POP<>"" Then
    Read [F:HRPOA]POA0=POP;REFNUM
    If fstat Then
      RET=1
    Endif
    Filter [F:HRPOA]
    # Evaluation de la règle d'appartenance de la population
    If RET=1 Then
      Read [F:HRPOP]POP0=POP
      If !fstat & [F:HRPOP]CRI<>"" Then
        If evalue([F:HRPOP]CRI) Then RET=0 : Endif
      Endif
    Endif
  Endif
End

