#If func AFNC.ACTIV("KSA")>0 Then
If func DIVPAYE.IS_KSA_LEG(GCURLEG)
#JOJAC - 2016-07-19 - REQ114309 - END
  If NATCON = "FT" or NATCON = "PE" Then
