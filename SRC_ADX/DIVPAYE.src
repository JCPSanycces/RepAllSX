Value Shortint THISPERYEA
Local Date RETURNDATE

  RETURNDATE=[0/0/0]

  If clalev([F:HRPEOH7])=0 : Local File HRPEOHEA [HRPEOH7] : Endif

  Read [HRPEOH7]HRPEOH0 = THISPERYEA; THISPERCOD
  If !fstat
    RETURNDATE=[HRPEOH7]CYCENDDAT
  Endif

End RETURNDATE

Funprog TAXMON(THISPERCOD,THISPERYEA,THISPERNUM)
Value Char THISPERCOD
Value Shortint THISPERYEA, THISPERNUM
Local Shortint RETURNVALUE

  RETURNVALUE=0

  If clalev([F:HRPEOD7])=0 : Local File HRPEODET [HRPEOD7] : Endif

  Read [HRPEOD7]HRPEOD0 = THISPERCOD; THISPERYEA; THISPERNUM
  If !fstat
    RETURNVALUE=[HRPEOD7]TAXMON
  Endif

End RETURNVALUE
#JASMI - 2016-11-24 - END

#JOJAC - 2016/11/29 - START
Funprog TAXYEA(THISLEG)
Value Char THISLEG
Local Date STR2
Local Shortint THISYEAR
Local Shortint RETURNVALUE
Local Shortint PERMONTH
Local Shortint PERYEA


#Infbox VALEUR

RETURNVALUE = 0

[L]STR2 = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
[L]PERMONTH = month([L]STR2)
[L]PERYEA = year([L]STR2)

If THISLEG = "ZAF"
  Case [L]PERMONTH
   When 3  : RETURNVALUE = [L]PERYEA+1
   When 4  : RETURNVALUE = [L]PERYEA+1
   When 5  : RETURNVALUE = [L]PERYEA+1
   When 6  : RETURNVALUE = [L]PERYEA+1
   When 7  : RETURNVALUE = [L]PERYEA+1
   When 8  : RETURNVALUE = [L]PERYEA+1
   When 9  : RETURNVALUE = [L]PERYEA+1
   When 10 : RETURNVALUE = [L]PERYEA+1
   When 11 : RETURNVALUE = [L]PERYEA+1
   When 12 : RETURNVALUE = [L]PERYEA+1
   When 1  : RETURNVALUE = [L]PERYEA
   When 2 : RETURNVALUE = [L]PERYEA
  Endcase
Elsif THISLEG = "BRI"
  Case [L]PERMONTH
   When 4  : RETURNVALUE = [L]PERYEA
   When 5  : RETURNVALUE = [L]PERYEA
   When 6  : RETURNVALUE = [L]PERYEA
   When 7  : RETURNVALUE = [L]PERYEA
   When 8  : RETURNVALUE = [L]PERYEA
   When 9  : RETURNVALUE = [L]PERYEA
   When 10  : RETURNVALUE = [L]PERYEA
   When 11 : RETURNVALUE = [L]PERYEA
   When 12 : RETURNVALUE = [L]PERYEA
   When 1 : RETURNVALUE = [L]PERYEA-1
   When 2  : RETURNVALUE = [L]PERYEA-1
   When 3 : RETURNVALUE = [L]PERYEA-1
  Endcase
Else
  RETURNVALUE =  [L]PERYEA
Endif

End RETURNVALUE
#JOJAC - 2016/11/29 - END

