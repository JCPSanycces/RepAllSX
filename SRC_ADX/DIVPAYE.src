Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
#SEGAY 25/10/12 US 940 81085
#If [M]LEG<>VALEUR
If GCURLEG<>VALEUR :#MABOS-30/07/13
   Call INIT_BYLEG(VALEUR) :#MABOS-25/01/2013
Endif
GCURLEG=VALEUR
End

#SEGAY 25/10/12 US 940 81085
Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
Local    Integer I, J, K
Local    Char    LIS_CPY(GLONCPY)(0..100), LIS_LEG(5)(0..100)

  If VALEUR="" Then End : Endif

  I=0 : Call CALC_GRPCPY([M]CPY, LIS_CPY, I) From TOOLSVAR
  If I>0 Then : # C'est un groupe de sociétés
    J=0
    For K=0 To I-1
      Call LECTURE("CPY", LIS_CPY(K), "") From CONTOBJ
      If !find([F:CPY]LEG, LIS_LEG)Then
        LIS_LEG(J)=[F:CPY]LEG
        J+=1
      Endif
    Next
    J-=1
    If !find(VALEUR,LIS_LEG(0..J)) Then
      GMESSAGE=mess(93,10720,1)-[M]CPY : # Cette législation ne fait pas partie des législations du groupe de sociétés
      mkstat=2
    Endif
  Endif

End

#SEGAY 25/10/12 US 940 81085
Subprog INIT_BYLEG(VALEUR)
Value Char VALEUR
  Case maskcou
      When  "1"           : #Ajout bug compilation
 #    When "GENDEM"       : Call INIT_BYLEG From GENDEM

#     When "GENUPDSUICAR" : Call INIT_BYLEG(VALEUR) From GENUPDSUICAR : #MABOS-14/02/13
#     When "GENUPDEMP"    : Call INIT_BYLEG From GENUPDEMP :# MABOS-05/08/13-Code technical
                           # - doesn't work well if in comments- LEG no affect
#     When "GENCSI"       : Call INIT_BYLEG From GENCSI
#     When "TRTGENCTR"    : Call INIT_BYLEG(VALEUR) From TRTGENCTR
#     When "TRTGENCTR"    : Call AM_LEG(VALEUR) From ="W1"+maskcou
#     When "VALHAB"       : Call INIT_BYLEG(VALEUR) From VALHAB : # MABOS-13/02/13-FQ81085-US1330
#     When "VALCPC"       : Call INIT_BYLEG(VALEUR) From VALCPC : # MABOS-13/02/13-FQ81085-US1331
#     When "GENCEV"       : Call INIT_BYLEG(VALEUR) From GENCEV  : # MABOS-22/02/13-FQ81085-US1332
    # When "RECPRF"       : Call INIT_BYLEG(VALEUR) From RECPRF : # SBR-22/03/13-FQ81085-US1438
    # When "RECCPC"       : Call INIT_BYLEG(VALEUR) From RECCPC : # MABOS-26/03/13-FQ81085-US1437
#     When "CEVREL"       : Call INIT_BYLEG(VALEUR) From GENCEV  : Infbox "on passe" # MABOS-26/03/13-FQ81085-US1437
#     When "CEVSTAT"      : Call INIT_BYLEG(VALEUR) From GENCEV : Infbox 'on passe' :# MABOS-26/03/13-FQ81085-US1437
#     When "CONSRJO1"     : Call INIT_BYLEG(VALEUR) From CNSRJOSTD : # MABOS-26/06/13-FQ90539-US1737
#     When "CREUSR"       : Call INIT_BYLEG(VALEUR) From CREUSR : # FQ81085 US1330 1751 - 28/06/13
     #DBA : Démarrage d'un truc plus générique sans casser l'existant pour l'instant...
     When Default
        #question mabos-30/7/2013- FCY est avant la leg, on ne doit pas la réinit.
        #dans le cas des groupes de soc multi-leg, la leg peut ête donnée par le site. Donc on le conserve.
# MABOS-05/08/13-pour généraliser avec GENUPDEMP
#        If dim([M]ALLFCY)>0
#         [M]ALLFCY=2 : Effzo FCY : Diszo FCY
#        Endif
# end MABOS-05/08/13-pour généraliser avec GENUPDEMP-GENEMP
        If dim([M]ALLSRV)>0
         [M]ALLSRV=2 : Effzo SRV : Diszo SRV
        Endif
        If dim([M]ALLPRF)>0
         [M]ALLPRF=2 : Effzo PRF : Diszo PRF
         # Pas de leg = pas de profil !
         If VALEUR='' : Diszo ALLPRF : Else  : Actzo ALLPRF : Endif
        Endif
        #ADNGO - 2017-11-22 - X3-29552 - START
        If GFONCTION="GESPLF":End:Endif
        #ADNGO - 2017-11-22 - X3-29552 - END
        If dim([M]ALLPOT)>0
         [M]ALLPOT=2 : Effzo POT : Diszo POT
        Elsif dim([M]POT)>0
            Effzo POT : # cas ou pas de case tous
        Endif
        If dim([M]ALLJOBPOT)>0
         [M]ALLJOBPOT=2 : Effzo JOBPOT : Diszo JOBPOT
         Elsif dim([M]JOBPOT)>0
            Effzo JOBPOT : # cas ou pas de case tous
        Endif
        #ADNGO - 2017-08-02 - X3-36330 - START
        #JOJAC - 2017-05-09 - X3-28695 - START
        #LIPET - 08-03-2017 - X3-28695 - START
#        If dim([M]ALLEXTPER)>0
#         [M]ALLEXTPER=2 : Effzo PERCOD : Diszo PERCOD
#        Endif
#        If dim([M]ALLPERCOD)>0
#         [M]ALLPERCOD=2 : Effzo PERNUM : Diszo PERNUM
#        Endif
        #LIPET - 08-03-2017 - X3-28695 - END
        #JOJAC - 2017-05-09 - X3-28695 - END
        If dim([M]ALLEXTPER)>0
         [M]ALLEXTPER=2 : Effzo PERCOD : Diszo PERCOD
        Endif
        If dim([M]ALLPERCOD)>0
         [M]ALLPERCOD=2 : Effzo PERNUM : Diszo PERNUM
        Endif
        #ADNGO - 2017-08-02 - X3-36330 - END
        If dim([M]MATDEB)>0  : Effzo MATDEB  : Endif
        If dim([M]MATFIN)>0  : Effzo MATFIN  : Endif
        If dim([M]CTRDEB)>0  : Effzo CTRDEB  : Endif
        If dim([M]CTRFIN)>0  : Effzo CTRFIN  : Endif
        If dim([M]POP)>0     : Effzo POP     : Endif
        If dim([M]CRITERE)>0 : Effzo CRITERE : Endif
        If dim([M]CRI)>0     : Effzo CRI     : Endif
        # Pas sure qu'il faille RAZ les dates, surtout en paie, car génératement initialisées en fonction du mois de paie courant !
        # D'autant que des dates c'ets valide pour n'importe quelles legs :)
        #If dim([M]DATDEB)>0 : Effzo DATDEB  : Endif
        #If dim([M]DATFIN)>0 : Effzo DATFIN  : Endif
        If dim([M]SMH)>0     : Effzo [M]SMH     : Endif
        If dim([M]SVR)>0     : Effzo [M]SVR     : Endif
        If dim([M]PRFSUP)>0
         Effzo PRFSUP
         # Pas de leg = pas de profil !
         If VALEUR='' : Diszo PRFSUP : Else : Actzo PRFSUP : Endif
        Endif
        If dim([M]NBRRUB)>0 | dim([M]NBRCUM)>0   : Effzo [M]20     : Endif
        If dim([M]ALLMGR)>0
         [M]ALLMGR=2
         Effzo [M]MGR
         If dim([M]SRN1)>0 : Effzo [M]SRN1: Endif
         Grizo [M]MGR
        Endif
        If dim([M]ALLPPH)>0 : [M]ALLPPH=2 : Effzo [M]PPHNUM : Grizo [M]PPHNUM    : Endif
        If dim([M]BANRGL)>0 : Effzo [M]BANRGL    : Endif
        # Ajout de session/ stage / valcsi
        If dim([M]STG)>0 : Effzo [M]STG : Endif
        If dim([M]MAJCSI)>0 : [M]MAJCSI=2 : Endif
        If dim([M]FLGFRC)>0 : [M]FLGFRC=1 : Endif
        If dim([M]ALLSES)>0
          # SBA si session présence de stage en théorie.
         [M]ALLSES=2 : Effzo [M]SES : Diszo [M]SES
         Effzo [M]DATDEB,DATFIN
        Endif
        If dim([M]COMPTEUR)>0
          Effzo [M]COMPTEUR
        Endif
        Affzo [M]
  Endcase
End

#SEGAY 25/10/12 US 940 81085
Subprog GRISE_LEG(PCPY,PFCY)
Value Char PCPY()
Value Char PFCY()
Local    Integer I, K, DIFF_LEG
Local    Char    LEG(GLONADI), LIS_CPY(GLONCPY)(0..100)
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif

#MABOS-08/08/13-FQ91298-US1835-Technical Review
If dim([M]LEG)>0
  If PFCY<>"" Then
     # A site -> leg is grayed
     Diszo [M]LEG : Affzo [M]LEG, ZLEG
     End
  Endif
  If PCPY<>"" Then
    I=0 : Call CALC_GRPCPY(PCPY, LIS_CPY, I) From TOOLSVAR
    If I>0 Then : # C'est une société ou un groupe de sociétés
      [L]LEG="" : DIFF_LEG=1
      For K=0 To I-1
        Call LECTURE("CPY", LIS_CPY(K), "") From CONTOBJ
        If [L]LEG="" Then [L]LEG=[F:CPY]LEG : Endif
        If [L]LEG<>[F:CPY]LEG Then
          DIFF_LEG=2 : Break
        Endif
      Next

      If DIFF_LEG=1 Then : # Toutes les sociétés du groupe ont la même leg
        Diszo [M]LEG : Affzo [M]LEG, ZLEG
      Else               : # Les sociétés du groupe ont des legs différentes
        Actzo [M]LEG : Affzo [M]LEG, ZLEG
      Endif
    Endif
  Endif
Endif
End

$SEL_FCY_OLD
#90510
If GCURLEG<>GLEGFIL
 Gosub SAVE_GLEGFIL From TOOLSHRLEG
 GLEGFIL=GCURLEG
Endif
[L]OBJET="FCY"
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
Call LECTURE("CPY",[L]PARAM(1),"") From CONTOBJ
If !fstat
 If [F:CPY]CPYLEGFLG=2
  [L]CRITERE(1)="LEGCPY='"+[L]PARAM(1)+"'"
  If [V]GUSRFCY(1)<>"\"
   [L]CRITERE(1)-="& find(FCY,[V]GUSRFCY(1..[V]GNBAUZ))"
  Endif
 Else
  If !clalev([F:FGR]) : Local File FACGROUP [FGR] : Endif
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  If [V]GUSRFCY(1)="\"
   Link [FGR] With [FCY]FCY0=FCY As [LNK] Where CPY=[L]PARAM(1)
  Else
   Link [FGR] With [FCY]FCY0=FCY
&               As [LNK]
&            Where CPY=[L]PARAM(1) & find(FCY,[V]GUSRFCY(1..[V]GNBAUZ))
  Endif
  Local Libelle CHXLNK
 Endif
Endif
Return

# FQ91298 - 28/09/13 - Pour ne conserver que l'action SELFCYCPY et supprimer SELFCYLEGH
$SEL_FCY

  Gosub SAVE_GLEGFIL From TOOLSHRLEG
  Gosub SAVE_GCURLEG From TOOLSHRLEG

  [L]OBJET="FCY"
  DEFPAG=1
  EXPSTART="[F:FCY]FCY>='"+VALEUR+"'"
  If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif


  Call LECTURE("CPY",[L]PARAM(1),"") From CONTOBJ

  If !fstat
    Local Integer I
    Local Char    LIS_CPY(GLONCPY)(0..100), CRITERE1(250)
    I=0 : Call CALC_GRPCPY(PARAM(1), LIS_CPY, I) From TOOLSVAR
    If I>0 Then
      If(dim(GW_STRTMP)<0)
        Global Char GW_STRTMP(GLONCPY)(0..I-1)
      Else
        If(dim(GW_STRTMP)<>I)
          Global Char GW_STRTMP(GLONCPY)(0..I-1)
        Else
          Raz GW_STRTMP
        Endif
      Endif
      For K=0 To I-1
        GW_STRTMP(K)=LIS_CPY(K)
      Next
      [L]CRITERE(1) = "(find(LEGCPY,GW_STRTMP)>0)"
    Else
      [L]CRITERE(1) = "LEGCPY='"+PARAM(1)+"'"
    Endif
    If [V]GUSRFCY(1)<>"\"
      [L]CRITERE(1)-="& find(FCY,[V]GUSRFCY(1..[V]GNBAUZ))"
    Endif
  Endif
  If PARAM(2)<>"" Then GCURLEG=PARAM(2) : Endif
  If dim(GCURLEG2)>0 & GCURLEG2<>"" Then
    GCURLEG=GCURLEG2
  Endif
  GLEGFIL=GCURLEG


Return

#90510
$FIN_FCY
Gosub RESTAURE_GLEGFIL From TOOLSHRLEG
Gosub RESTAURE_GCURLEG From TOOLSHRLEG
Return

