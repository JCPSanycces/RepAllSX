################################################################################
## Sélection d'un no de bulletin de paye
################################################################################
Subprog SELBUL(MATRI,DAT,CTR,DATCTR,BULLETIN)
Value    Char MATRI()
Value    Date DAT
Value    Char CTR ()
Value    Date DATCTR
Variable Char BULLETIN()

Local Integer NBBUL , NUMBUL
Local Char    TBBUL(GLONVCR)(0..100) , LIBBUL(80)(0..100), CRITVEP(250)
If clalev([F:VEP])=0 : Local File VALEMP   [VEP] : Endif
NBBUL = 0

CRITVEP='1'
If CTR<>""    : CRITVEP-="& CTRNUM ='"+CTR+"'" : Endif
If DATCTR<>[0/0/0] : CRITVEP-="& CTRDAT =["+format$(GFMD,DATCTR)+"]" : Endif

#86255
If clalev([F:CPY2])=0    : Local File COMPANY    [CPY2]   : Endif
If clalev([F:FCY])=0    : Local File FACILITY   [FCY]   : Endif
## PEVAN - 2018-05-02 - X3-89459 - START
Link [VEP] With
&   [FCY]FCY0 = [F:VEP]FCY
& , [CPY2]CPY0 = [F:FCY]LEGCPY
&   As [LNK]
&   Order By Key CLE=[F:VEP]EMP;[F:VEP]CTRNUM;[F:VEP]CTRDAT
#&   Order By Key CLE=[F:VEP]EMP;[F:VEP]CTRNUM;[F:HRCTR]CTRDAT
## PEVAN - 2018-05-02 - X3-89459 - END

For [LNK] Where EMP=MATRI & PYRDAT=DAT & evalue(CRITVEP) & [F:CPY2]LEG=GCURLEG
 NBBUL += 1
 TBBUL(NBBUL)  = [F:VEP]BUL
 LIBBUL(NBBUL) = [F:VEP]BUL-format$(GFMDAT4,[F:VEP]PYRDAT)-[F:FCY]FCY-[F:FCY]FCYNAM
Next
If NBBUL=0
 BULLETIN = ""
Elsif NBBUL=1
 BULLETIN = TBBUL(1)
Else
 Call SAITEX(NBBUL,LIBBUL,NUMBUL,mess(152,10702,1)) From GESECRAN : # Choix du bulletin
 If NUMBUL=0
  BULLETIN = ""
 Else
  BULLETIN = TBBUL(NUMBUL)
 Endif
Endif
End


################################################################################
## Sélection d'un no de contrat
################################################################################
#**
#* Selection  no of contract for multicontrat, with parameter LEG
#Subprog SELCTRMLEG(MATRI,DAT1,DAT2,PLEG,CTRNUMERO) from TOOLSHRLEG
#*!
Subprog SELCTR(MATRI,DAT1,DAT2,CTRNUMERO)
Value    Char MATRI
Value    Date DAT1, DAT2
Variable Char CTRNUMERO()
Local Integer NBCTR , NUMCTR
Local Char    TBCTR(GLONVCR)(0..100) , LIBCTR(130)(0..100)
Local Char    TBLEG(GLONADI)(0..100) , TBSOC(GLONCPY)(0..100)
Local Date    TBDAT(0..100)
Local Char    DESSRV(GLONDES)

If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
If clalev([F:CPY])=0   : Local File COMPANY  [CPY]   : Endif
If clalev([F:FCY])=0   : Local File FACILITY [FCY]   : Endif
If clalev([F:SRV])=0   : Local File SERVICE  [SRV]   : Endif
If clalev([F:ID])=0    : Local File EMPLOID  [ID]    : Endif : # 71796
If clalev([F:ACC])=0   : Local File ACCES    [ACC]   : Endif : # 71796

#  SEGAY - 81085 - 30/05/12 Filter on legislation GLEGFIL
Local Char MLEG(20)
Local Integer OKLEG
MLEG=""
If GLEGFIL<>"" Then
  MLEG=GLEGFIL
Endif
If dim(GCURLEG)>0 Then
  MLEG=GCURLEG
Endif
# END 81085

#JASMI - 2017-10-16 - X3-56191 - START
Filter [HRCTR]
#JASMI - 2017-10-16 - X3-56191 - END

#If GFONCTION="GESHRATS" Then MLEG="" :Endif :#MABOS-04/06/13-FQ81084-US1641

#JASMI - 2017-10-16 - X3-56191 - START
Filter [HRCTR]
#JASMI - 2017-10-16 - X3-56191 - END

# FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
#ADNGO - 2017-09-19 - X3-56067 - START
#For [HRCTR]CTR0 Where REFNUM=MATRI & (CTRDAT<=DAT1 | (FLGRET=2 & RETDATEFF<=DAT1)) & (XITDAT=[0/0/0] | XITDAT>=DAT2)
#JASMI - 2017-11-30 - X3-64091 - START
#For [HRCTR]CTR0 Where REFNUM=MATRI & (CTRDAT<=DAT1 | (FLGRET=2 & RETDATEFF<=DAT1)) & (XITDAT=[0/0/0] | XITDAT<=DAT2)
For [HRCTR]CTR0 Where REFNUM=MATRI & (CTRDAT<=DAT1 | (FLGRET=2 & RETDATEFF<=DAT1)) & (XITDAT=[0/0/0] | XITDAT>=DAT2)
#JASMI - 2017-11-30 - X3-64091 - END
#ADNGO - 2017-09-19 - X3-56067 - END
 Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
 Call LECTURE("SRV",[F:HRCTR]ETRSRV,"") From CONTOBJ
#  SEGAY - 81085 - 30/05/12 Filter on legislation GLEGFIL
 OKLEG=1
 If MLEG <> "" Then
   OKLEG = find([F:FCY]LEG,MLEG,'')
 Endif
# END - 81085
# / 71796
 If GUSRACS<>2
  Read [ID]ID0=[F:HRCTR]REFNUM
  If !fstat
   If [F:ID]CODACS <> ""
    Read [F:ACC]CODACC = GUSER;[F:ID]CODACS
   Endif
  Endif
 Endif
 If OKLEG #  SEGAY - 81085 - 30/05/12 Filter on legislation GLEGFIL
 #MABOS-01/02/13-FQ86831-US1205 - limit 127 for GAUTSRV
 #If GUSRACS = 2 | ( !fstat & ([F:ID]CODACS="" or [F:ACC]CONSUL=2) & find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV)) )
 If GUSRACS = 2 | ( !fstat & ([F:ID]CODACS="" or [F:ACC]CONSUL=2) & (func AUTSRV([F:HRCTR]ETRSRV)))
   NBCTR += 1
   TBCTR(NBCTR)  = [F:HRCTR]CTRNUM
#  SEGAY 16/05/12 To manage translated texts (data type AX3 & AX1)
#   LIBCTR(NBCTR) = [F:HRCTR]CTRNUM-mess(40,101,1)-format$(GFMD,[F:HRCTR]CTRDAT)-"-"-mess(12,105,1)
#&                 -[F:FCY]FCY-[F:FCY]FCYNAM-"-"-mess(44,10702,1)-[F:HRCTR]ETRSRV-[F:SRV]DES
   Call LECTEXTRA(DESSRV,"SERVICE","DES",[F:HRCTR]ETRSRV,"") From ATEXTRA
   LIBCTR(NBCTR) = [F:HRCTR]CTRNUM-mess(40,101,1)-format$(GFMD,[F:HRCTR]CTRDAT)-"-"-mess(12,105,1)
&                 -[F:FCY]FCY-[F:FCY]FCYNAM-"-"-mess(44,10702,1)-[F:HRCTR]ETRSRV-DESSRV
&                 -"-"-mess(15,10712,1)-num$([F:FCY]LEG)
   Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
   TBLEG(NBCTR)=[F:CPY]LEG
   TBSOC(NBCTR)=[F:CPY]CPY
   # FQ81085 - US1554 - 13/05/13
   TBDAT(NBCTR)=[F:HRCTR]CTRDAT
  Endif
 #Endif
# 71796 /
 Endif
Next
If NBCTR=0
 GMESSAGE  = mess(158,10702,1) : # Pas de contrat valide sur la période
 CTRNUMERO = ""
 GCURLEG = "" : GSOCIETE=""
Elsif NBCTR=1
 CTRNUMERO = TBCTR(1)
 GCURLEG = TBLEG(1) : GSOCIETE=TBSOC(1)
 # FQ81085 - US1554 - 13/05/13
 Read [F:HRCTR]CTR0=MATRI;CTRNUMERO;TBDAT(1)
Else
 Call SAITEX(NBCTR,LIBCTR,NUMCTR,mess(151,10702,1)) From GESECRAN : # Choix du contrat

 If NUMCTR=0
  CTRNUMERO = ""
  GCURLEG = "" : GSOCIETE=""
 Else
  CTRNUMERO = TBCTR(NUMCTR)
  GCURLEG = TBLEG(NUMCTR) : GSOCIETE=TBSOC(NUMCTR) :  #GSOCIETE=TBSOC(NBCTR)- #   MABOS-31/07/13 - Bug 91545
 Endif
Endif
End

$OUVRE_SELCTRDAT
Local Integer NBDAT , NUMCTR
Local Char    LIBCTR(250)(0..100)
Local Date    TBDAT(0..100)
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
If clalev([F:FCY])=0   : Local File FACILITY [FCY]   : Endif
If clalev([F:SRV])=0   : Local File SERVICE  [SRV]   : Endif
If clalev([F:ID])=0    : Local File EMPLOID  [ID]    : Endif
If clalev([F:ACC])=0   : Local File ACCES    [ACC]   : Endif
Return

$FILTER_SELCTRDAT
Local Char VCRITXITDAT(250)
Local Char DESSRV(GLONDES)

If CRITERE=""  Then CRITERE="1=1"  : Endif
VCRITXITDAT="(XITDAT=[0/0/0] | XITDAT>=DATMAX"
If WEEKP=2
VCRITXITDAT-="| (XITDAT>=DATMAX-7 & XITDAT<=DATMAX)"
Endif
If XITNOTDEF
VCRITXITDAT-="| (XITDAT<DATMAX & XITFNL<2)"
Endif
VCRITXITDAT+=")"
For [HRCTR]CTR0 Where REFNUM=MATRI & CTRNUM=CTR & evalue(VCRITXITDAT) & evalue(CRITERE)

 Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
 Call LECTURE("SRV",[F:HRCTR]ETRSRV,"") From CONTOBJ
 If GUSRACS<>2
  Read [ID]ID0=[F:HRCTR]REFNUM
  If !fstat
   If [F:ID]CODACS <> ""
    Read [F:ACC]CODACC = GUSER;[F:ID]CODACS
   Endif
  Endif
 Endif
 #MABOS-01/02/13-FQ86831-US1205 - limit 127 for GAUTSRV
 #If GUSRACS = 2 | ( !fstat & ([F:ID]CODACS="" or [F:ACC]CONSUL=2) & find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV)) )
 If GUSRACS = 2 | ( !fstat & ([F:ID]CODACS="" or [F:ACC]CONSUL=2) & (func AUTSRV([F:HRCTR]ETRSRV))  )

   NBDAT += 1
   TBDAT(NBDAT)  = [F:HRCTR]CTRDAT
   Call LECTEXTRA([L]DESSRV,"SERVICE","DES",[F:HRCTR]ETRSRV,"") From ATEXTRA
   LIBCTR(NBDAT) = [F:HRCTR]CTRNUM-mess(40,101,1)-format$(GFMD,[F:HRCTR]CTRDAT)-"-"-mess(12,105,1)
&                 -[F:FCY]FCY-[F:FCY]FCYNAM-"-"-mess(44,10702,1)-[F:HRCTR]ETRSRV-[L]DESSRV
  Endif
Next
Return

################################################################################
## Sélection d'une date de contrat
################################################################################
Subprog SELCTRDAT(DAT,MATRI,CTR,DATMAX,CRITERE)
Variable Date    DAT
Value    Char    MATRI
Value    Char    CTR
Value    Date    DATMAX
Value    Char    CRITERE
Local    Integer WEEKP, XITNOTDEF


XITNOTDEF=0
WEEKP=1
If CRITERE="XITNOTDEF=1" : XITNOTDEF=1 : CRITERE="" : Endif
Gosub OUVRE_SELCTRDAT
Gosub FILTER_SELCTRDAT
If NBDAT=0
 GMESSAGE  = mess(158,10702,1) : # Pas de contrat valide sur la période
 DAT = [0/0/0]
Elsif NBDAT=1
 DAT = TBDAT(1)
Else
 Call SAITEX(NBDAT,LIBCTR,NUMCTR,mess(151,10702,1)) From GESECRAN : # Choix du contrat
 If NUMCTR=0
#  DAT = [0/0/0]
 Else
  DAT = TBDAT(NUMCTR)
 Endif
Endif
End

################################################################################
## Sélection d'une date de contrat
################################################################################
Subprog SELCTRDATC(DAT,MATRI,CTR,DATMAX,CRITERE)
Variable Char    DAT
Value    Char    MATRI
Value    Char    CTR
Value    Date    DATMAX
Value    Char    CRITERE
Local    Integer WEEKP, XITNOTDEF

XITNOTDEF=0

If DATMAX<>[0/0/0] Then
  WEEKP=2
  Gosub OUVRE_SELCTRDAT
  Gosub FILTER_SELCTRDAT
  If NBDAT=0
    GMESSAGE  = mess(158,10702,1) : # Pas de contrat valide sur la période
    DAT = [0/0/0]
  Elsif NBDAT=1
    Read [HRCTR]CTR0=MATRI;CTR;TBDAT(1)
    If !fstat Then
      DAT = mess(94,100,1)-format$("D:DD[/]MM[/]YY",TBDAT(1))-mess(95,100,1) : # Du ... au ...
      If [F:HRCTR]XITDAT<>[0/0/0] Then
        DAT -= format$("D:DD[/]MM[/]YY",[F:HRCTR]XITDAT)
      Endif
    Endif
  Else
    Call SAITEX(NBDAT,LIBCTR,NUMCTR,mess(151,10702,1)) From GESECRAN : # Choix du contrat
    If NUMCTR=0
      DAT = ""
    Else
      Read [HRCTR]CTR0=MATRI;CTR;TBDAT(NUMCTR)
      If !fstat Then
        DAT = mess(94,100,1)-format$("D:DD[/]MM[/]YY",TBDAT(NUMCTR))-mess(95,100,1)
        If [F:HRCTR]XITDAT<>[0/0/0] Then
          DAT -= format$("D:DD[/]MM[/]YY",[F:HRCTR]XITDAT)
        Endif
      Endif
    Endif
  Endif
Endif
End


################################################################################
## Sélection d'un no de contrat pour le formateur
## SYMEU V6.1 Module Formation - Formateur interne
################################################################################
Subprog SELCTRFOR(MATRI,DAT1,DAT2,CTRNUMERO)
Value    Char MATRI
Value    Date DAT1, DAT2
Variable Char CTRNUMERO()
Local Integer NBCTR , NUMCTR
Local Char    TBCTR(GLONVCR)(0..100) , LIBCTR(130)(0..100)
Local Char    DESSRV(GLONDES)

If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
If clalev([F:FCY])=0   : Local File FACILITY [FCY]   : Endif
If clalev([F:SRV])=0   : Local File SERVICE  [SRV]   : Endif
If clalev([F:TRN])=0   : Local File TRAINER  [TRN]   : Endif

# FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
For [HRCTR]CTR0 Where REFNUM=MATRI & (CTRDAT<=DAT1 | (FLGRET=2 & RETDATEFF<=DAT1)) & (XITDAT=[0/0/0] | XITDAT>=DAT2)
 # vérification que le contrat existe pour le salarié dans la table des formateurs
 Read [F:TRN]TRN1 = MATRI;[F:HRCTR]CTRNUM
 If !fstat and [F:TRN]ENAFLG = 2 Then
   Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
   Call LECTURE("SRV",[F:HRCTR]ETRSRV,"") From CONTOBJ
   NBCTR += 1
   TBCTR(NBCTR)  = [F:HRCTR]CTRNUM
   Call LECTEXTRA(DESSRV,"SERVICE","DES",[F:HRCTR]ETRSRV,"") From ATEXTRA
   LIBCTR(NBCTR) = [F:HRCTR]CTRNUM-mess(40,101,1)-format$(GFMD,[F:HRCTR]CTRDAT)-"-"-mess(12,105,1)
&                 -[F:FCY]FCY-[F:FCY]FCYNAM-"-"-mess(44,10702,1)-[F:HRCTR]ETRSRV-DESSRV

  Endif
Next
If NBCTR=0
 GMESSAGE  = mess(158,10702,1) : # Pas de contrat valide sur la période
 CTRNUMERO = ""
Elsif NBCTR=1
 CTRNUMERO = TBCTR(1)
Else
 Call SAITEX(NBCTR,LIBCTR,NUMCTR,mess(151,10702,1)) From GESECRAN : # Choix du contrat
 If NUMCTR=0
  CTRNUMERO = ""
 Else
  CTRNUMERO = TBCTR(NUMCTR)
 Endif
Endif
End

################################################################################
## Cherche le no de contrat d'un salarié mono contrat en fonction d'une date
################################################################################

Subprog CHERCHE_CTR(MATRI,DAT,CTR)
Value    Char MATRI
Value    Date DAT
Variable Char CTR
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
If clalev([F:CPY])=0   : Local File COMPANY  [CPY]   : Endif
If clalev([F:FCY])=0   : Local File FACILITY [FCY]   : Endif

 # FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
#MIPEA - 2016-08-02 - REQ 114309 US102 - START
Link [HRCTR] With
&    [FCY]FCY0=[F:HRCTR]ETRFCY,
&    [CPY]CPY0=[F:FCY]LEGCPY
& As [LNK]
& Where REFNUM=MATRI & (CTRDAT<=DAT | (FLGRET=2 & RETDATEFF<=DAT)) & (GCURLEG="" | [CPY]LEG=GCURLEG) & (XITDAT=[0/0/0] | XITDAT>=DAT) Order By Key CLE=REFNUM;CTRDAT Desc

#Link [HRCTR] With
#&    [FCY]FCY0=[F:HRCTR]ETRFCY,
#&    [CPY]CPY0=[F:FCY]LEGCPY
#& As [LNK]
#& Where REFNUM=MATRI & (CTRDAT<=DAT | (FLGRET=2 & RETDATEFF<=DAT)) & (GCURLEG="" | [CPY]LEG=GCURLEG) Order By Key CLE=REFNUM;CTRDAT Desc
#MIPEA - 2016-08-02 - REQ 114309 US102 - END
For [LNK]CLE
 CTR = [F:HRCTR]CTRNUM
 Break
Next

#Filter [HRCTR] Where REFNUM=MATRI & CTRDAT<=DAT
#Read [HRCTR]CTR1 Last
#Filter [HRCTR]
#If !fstat
# CTR = [F:HRCTR]CTRNUM
#Endif
End

Subprog CHERCHE_CTRPER(MATRI,DAT1,DAT2,CTR)
Value    Char MATRI
Value    Date DAT1,DAT2
Variable Char CTR
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
# FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
Filter [HRCTR] Where REFNUM=MATRI & (CTRDAT<=DAT2 | (FLGRET=2 & RETDATEFF<=DAT2)) & (XITDAT=[0/0/0] | XITDAT>=DAT1)
Read [HRCTR]CTR1 Last
Filter [HRCTR]
If !fstat
 CTR = [F:HRCTR]CTRNUM
Endif
End

##################################################
# Linked in data type HRCTR
##################################################
Subprog CONTCTR(AZC,EMP)
Value    Char    AZC
Value    Char    EMP

Local    Date    DATC
Local Integer OK
OK=1

If [L]AZC="" : End : Endif

If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif

If [F:HRCTR]REFNUM = EMP & [F:HRCTR]CTRNUM = AZC
 DATC = [F:HRCTR]CTRDAT
Endif

Filter [HRCTR] Where CTRNUM=AZC
Read [HRCTR]CTR0 First
Filter [HRCTR]
If fstat
 GMESSAGE = mess(26,10701,1) : # Contrat inexistant
 mkstat = 2 : End
Endif
If EMP<>""
 Filter [HRCTR] Where REFNUM=EMP & CTRNUM=AZC
 Read [HRCTR]CTR0 Last
 Filter [HRCTR]
 If fstat
  GMESSAGE = mess(62,10701,1)-EMP :# Ce contrat est rattaché au salarié
  mkstat = 2 : End
 Endif
Endif

Call CONTROLE([F:HRCTR]REFNUM,[F:HRCTR]CTRDAT,AZC,"",OK,1)
If !OK
 GMESSAGE  = mess(8,123,1) : # Accès impossible à cette fiche
 mkstat = 2 : End
Endif

If [L]DATC <> [0/0/0]
 Read [F:HRCTR]CTR0 = EMP;AZC;DATC
Endif

End

################################################################################
## 68250
## Indique si le matricule en paramètre est interlocuteur connu au niveau donné
## renvoie 0 = NON
##         1 = OUI
################################################################################
Funprog IS_CNT_AT_LEVEL(REF,LEVELS)
Value    Char    REF()
Value    Char    LEVELS()

Local Integer TTYPMGR(len(mess(0,50,1)))
Local Integer NBTTYPMGR
Local Integer OKMGR

TTYPMGR(0) = val(LEVELS) : # pour le moment 1 seul niveau...
NBTTYPMGR = (len(mess(0,50,1)))

If clalev([F:CTRW]) =0 : Local File EMPLOCTR [CTRW] : Endif
If clalev([F:IDW])  =0 : Local File EMPLOID  [IDW]   : Endif
If clalev([F:ADW])  =0 : Local File EMPLOAD  [ADW]   : Endif
If clalev([F:SRVW]) =0 : Local File SERVICE  [SRVW]  : Endif
If clalev([F:SITW]) =0 : Local File FACILITY [SITW]  : Endif

OKMGR = 0

If TTYPMGR(0) > NBTTYPMGR : End 0 : Endif

# FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
Link [CTRW] With [IDW]ID0      =  [CTRW]REFNUM
&              , [ADW]AD0      =  [CTRW]REFNUM
&              , [SITW]FCY0    =  [CTRW]ETRFCY
&              , [SRVW]SRV0    =  [CTRW]ETRSRV
&             As [LNK]
&          Where [F:IDW]ENAFLG = 2
&              & ([F:CTRW]CTRDAT<=date$ | ([F:CTRW]FLGRET=2 & [F:CTRW]RETDATEFF<=date$))
&              & ([F:CTRW]XITDAT=[0/0/0] | [F:CTRW]XITDAT>=date$)

Columns [LNK]([CTRW]CTRNUM,[CTRW]REFNUM,[CTRW]CTRDAT,[CTRW]XITDAT
&             ,[CTRW]ETRFCY,[CTRW]ETRSRV,[CTRW]CHEFCTR
&             ,[IDW]ENAFLG,[ADW],[SITW],[SRVW])

For [LNK]

# chef au niveau contrat
 OKMGR = ([F:CTRW]CHEFCTR(TTYPMGR(0))=[L]REF)
 # pour le moment 1 seul niveau...
 # OK = sigma(0, [L]NBTTYPMGR-1, [F:CTRW]CHEFCTR([L]TTYPMGR(indcum)-1)=[L]MGR)
 If OKMGR : Break : Endif

# chef au niveau salarié
 OKMGR = ([F:ADW]CHEF(TTYPMGR(0))=[L]REF)
 If OKMGR : Break : Endif

# chef au niveau service
 OKMGR = ([F:SRVW]CHEF(TTYPMGR(0))=[L]REF)
 If OKMGR : Break : Endif

# chef au niveau site
 OKMGR = ([F:SITW]CHEF(TTYPMGR(0))=[L]REF)
 If OKMGR : Break : Endif

Next
Columns [LNK]

End OKMGR

#**
#* Recherche du compteur DIF restant du collaborateur
#*
#* @param MATRI
#* @param CONTRAT
#* @param DATDEB
#* @param SOLDE
#*!
Subprog SOLDE_DIF (MATRI,CONTRAT,DATDEB,SOLDE)
Value    Char    MATRI ()
Value    Date    DATDEB
Value    Char    CONTRAT
Variable Decimal SOLDE
Local    Char    PARVAL(30)
Local    Char    DIFACQ(GLONCUM), DIFPRIS(GLONCUM), EVTDIF(GLONCUM)
Local    Decimal MTDIF(0..3)
Local    Date    DATPAY
Local    Char    CRITTIP(255),CRITTIG(255)
If clalev([F:TIP])=0  : Local File TIMEMP    [TIP]  : Endif
If clalev([F:TIM])=0  : Local File TIMCOD    [TIM]  : Endif
#MIPEA - 2017-02-09- X3-12033- START
If GMODU(4)=15
#If GMODU(4)=2
#MIPEA - 2017-02-09- X3-12033- END
 If clalev([F:TIG])=0  : Local File TIMREGUL  [TIG]  : Endif
Endif
If GPAYE=1
 If clalev([F:HSP])=0  : Local File HISTOPAYE [HSP] : Endif
 If clalev([F:VEP])=0  : Local File VALEMP    [VEP] : Endif
Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Local Char CURRLEG(GLONADI)

Raz DATPAY
SOLDE = 0
Raz MTDIF(0), MTDIF(1)
If GPAYE and DATDEB > [0/0/0]
# On lit les heures DIF restantes dans l'historique de paie  pour le dernier bulletin de la valeur salarié < DATDEB
  Raz CURRLEG
  Filter [VEP] Where EMP=MATRI & CTRNUM=CONTRAT & PYRDAT<=DATDEB
  Read [VEP]VEP0 Last
  Filter [VEP]
  If !fstat
   If dim([F:CPY]LEG)>0
     Call LECTURE("FCY",[F:VEP]FCY,"") From CONTOBJ
     Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
     [L]CURRLEG=[F:CPY]LEG
   Endif
   Call PARAM([L]CURRLEG,"BULCUM15",PARVAL) From ADOVAL : DIFACQ  = PARVAL #H_DIF_ACQU
   Call PARAM([L]CURRLEG,"BULCUM16",PARVAL) From ADOVAL : DIFPRIS = PARVAL #H_DIF_PRIS
   DATPAY=[VEP]PYRDAT
   Read [HSP]HSP3=[F:VEP]BUL;DIFACQ;6
   If !fstat : MTDIF(0) = [F:HSP]AMT : Endif
   Read[HSP]HSP3=[F:VEP]BUL;DIFPRIS;6
   If !fstat : MTDIF(1) = [F:HSP]AMT : Endif
  Endif

  Call PARAM("","EVTDIF",PARVAL) From ADOVAL    : EVTDIF    = PARVAL
  If [L]DATPAY > [0/0/0]
    CRITTIP = "TIM="+"'"+EVTDIF+"'" -"& REFNUM="+"'"+MATRI+"'" -"& ((DATPYR>["+format$(GFMD,[L]DATPAY)+"]" -"& DATPYR<=["+format$(GFMD,[L]DATDEB)+"])"-"| (STRDAT>["+format$(GFMD,[L]DATPAY)+"]"-
& "& STRDAT<=["+format$(GFMD,[L]DATDEB)+"]))"
    CRITTIP -= "& CTRNUM="+"'"+CONTRAT+"'"
  Else
    CRITTIP = "TIM="+"'"+EVTDIF+"'" -"& REFNUM="+"'"+MATRI+"'" -"& ((DATPYR<=["+format$(GFMD,[L]DATDEB)+"])"-"| (STRDAT<=["+format$(GFMD,[L]DATDEB)+"]))"
    CRITTIP -= "& CTRNUM="+"'"+CONTRAT+"'"
  Endif
# On lit les heures DIF prises dans le temps passé entre la date du dernier bulletin et DATDEB
  Filter [TIP] Where evalue(CRITTIP)
&    Order By Key TIP2
  For [TIP]
    Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
    If [F:TIM]CATTIM=1
     MTDIF(1) += [F:TIP]NBRHOU
    Endif
  Next
  Filter [TIP]
# On lit les heures DIF prises dans la régularisation des temps entre la date du dernier bulletin et DATDEB
#MIPEA - 2017-02-09- X3-12033- START
  If GMODU(4)=15
  #If GMODU(4)=2
#MIPEA - 2017-02-09- X3-12033- END
    CRITTIG = "TIM="+"'"+EVTDIF+"'" -"& REFNUM="+"'"+MATRI+"'" -"& ((DATPYR<=["+format$(GFMD,[L]DATDEB)+"])"-"| (STRDAT<=["+format$(GFMD,[L]DATDEB)+"]))"
    CRITTIG -= "& CTRNUM="+"'"+CONTRAT+"'"
    CRITTIG -= "& FLGBUL = 0"
    Filter [TIG] Where evalue(CRITTIG)
&    Order By Key TIG2
    For [TIG]
      Call LECTURE("TIM",[F:TIG]TIM,"") From CONTOBJ
      If [F:TIM]CATTIM=1
       MTDIF(1) += [F:TIG]NBRHOU
      Endif
    Next
    Filter [TIG]
  Endif
  SOLDE = max(0,MTDIF(0)-MTDIF(1))
 Endif
End
#SEGAY 11/10/12 DEM 84301 81491 US 813
# In SUBSTY but no exist because TPS no exist
#** V7 : Waiting Update Facility **#
#*********************************#
Subprog CONVERTHM(VALEUR,NBHEURE)
Value Char VALEUR ()
Variable Decimal NBHEURE
Local Integer HH, MM
Call CONTHM(VALEUR) From OBJDIV
HH = val(left$(VALEUR,2))
MM = val(right$(VALEUR,3))
NBHEURE = ((HH*60)+MM)/60
End

#------------------------------------------------------------------------------------------------
# => Sert à savoir quel type de responsable est pris en compte en tant que manager opérationnel
#    d'un salarié
#------------------------------------------------------------------------------------------------
#sba ajout pour geseva
Subprog GET_TTYPMGR(FLUX, TTYPMGR)
Value Char FLUX()
Variable Integer TTYPMGR()

Raz [L]TTYPMGR

If clalev([F:WFJR]) = 0 : Local File FLXJOBRSP [WFJR] : Endif

Local Integer I
Raz [L]I

For [F:WFJR]FJR0 Where [F:WFJR]COD = [L]FLUX
&                        & [F:WFJR]TYP = 1
    [L]TTYPMGR([L]I) = [F:WFJR]TYPMGR
    [L]I += 1
Next

If dim([V]GDONOTCLOSE) < 1
 Close Local File [WFJR]
Endif

End

Subprog VEPSYMBOLE (SYMB, ABREV)
Variable Char SYMB ()
Value Char ABREV()
# When "TB1"
#  Default File [TB1]
# When "ODP"
#  Default File [ODP]
Case ABREV
 When Default
  Default File [VEP]
Endcase
SYMB = "VEP"+format$("D:"+GFMDAT4,[F]PYRDAT)+"\"+[F]CTRNUM+format$("D:"+GFMDAT4,[F]CTRDAT)
End

#MABOS-22/04/13-FQ86015-US1531
# add lines in traces with criteria filled in masse processings
# WABRMASK : mask abreviation
# WMASK    : mask name
Subprog LIB_CRIT(WABRMASK,WMASK)
Value Char WMASK,WABRMASK
Local Integer WNBTRACE
Local Char WTRACE(255)(1..50)
Local Char WFLD(30), WEXP(250)
Local Char WGDTRACE(255), LIB(250), LIBPREC(250)

If clalev([F:AMZW])=0 : Local File AMSKZON [AMZW] :Endif
[L]LIB=""
For [AMZW]CODZON Where CODMSK=WMASK & SAIAFF<3 & CODTYP<>"ABS"
# Pour tous les champs déclarés visibles dans le dico des champs de l'écran
  [L]WFLD=[F:AMZW]CODZON
  [L]WEXP="dim("+WABRMASK+[L]WFLD+")>0 "
  If evalue([L]WEXP)
  If evalue("varmode("+WABRMASK+[L]WFLD+")") <3
    # champ visible dans l'écran affiché
    [L]LIBPREC=[L]LIB
    [L]LIB=func TOOLSHRLEG.LIB_FIELD(WMASK,[L]WFLD)

    [L]WEXP-="& "
    Case  evalue("type("+WABRMASK+[L]WFLD+")")
     When 1,2,4,5,6,7,9
         [L]WEXP+= "num$("+WABRMASK+[L]WFLD +")<>'0'"
     When 3
         [L]WEXP+= WABRMASK+[L]WFLD +"<> [0/0/0]"
     When Default
         [L]WEXP+= WABRMASK+[L]WFLD +"<>''"
    Endcase

    If evalue([L]WEXP) Then :# Il y a une valeur

      If [AMZW]CODTYP<>"M" & [AMZW]CODTYP<>"MM" : # Ce n'est pas un Menu local
        Gosub ADD_LIB_SEP
      Endif
      Case  evalue("type("+WABRMASK+[L]WFLD+")")
       When 1,2,4,5,6,7,9 : # nunmérique
            If [AMZW]CODTYP="M" | [AMZW]CODTYP="MM" : # Menu local

               If ([F:AMZW]NOLIB=1 & evalue(WABRMASK+[L]WFLD)<2 )
&               | ( [F:AMZW]NOLIB>1 & evalue("varmode("+WABRMASK+[L]WFLD+")") <> 0)
                   # Menu local "Oui/Non" : NON  ou
                   # Autre menu local non saisissable (car valeur affichée pas toujours OK)
                   # on ne trace pas
               Else
                  Gosub ADD_LIB_SEP
                  If [F:AMZW]NOLIB> 1 : # Menu local autre que "Oui/Non"
                     WTRACE(WNBTRACE)-= mess(evalue(WABRMASK+[L]WFLD),[F:AMZW]NOLIB,1)
                  Endif
               Endif
            Else : # pas menu local
               WTRACE(WNBTRACE)-= num$(evalue(WABRMASK+[L]WFLD))
            Endif
       When 3   :# date
            WTRACE(WNBTRACE)-= format$(GFMD,evalue(WABRMASK+[L]WFLD))
       When Default : # Alpha
            WTRACE(WNBTRACE)-= evalue(WABRMASK+[L]WFLD)
      Endcase
      If evalue("dim("+WABRMASK+"Z"+[L]WFLD+")>0")
        WTRACE(WNBTRACE)-= "-"-evalue(WABRMASK+"Z"+[L]WFLD)
      Endif

    Else :# Il n'y a pas de valeur
      If [L]LIB ="" # cas 2ème valeur de bornes
        If instr(1,WTRACE(WNBTRACE),[L]LIBPREC)=1
         # 1ère valeur renseignée , 2ème valeur vide
         WTRACE(WNBTRACE)-="->" : # <=> A partir de borne 1
        Endif
      Endif
    Endif
 #

Endif
  Endif
Next
Filter [AMZW]

If [L]WNBTRACE>0

Call ECR_TRACE(mess(14,103,1),0) From GESECRAN : #  Critères
For I= 1 To [L]WNBTRACE
  If [L]WTRACE(I)<>""
     Call ECR_TRACE(space$(3)+[L]WTRACE(I),0) From GESECRAN
  Endif
Next

Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

End

$ADD_LIB_SEP
  If [L]LIB ="" :# cas deuxième valeur d'une borne
    If instr(1,WTRACE(WNBTRACE),[L]LIBPREC)<>1 :# pas de valeur dans la première valeur de borne
      WNBTRACE += 1
      WTRACE(WNBTRACE)=[L]LIBPREC
      If [F:AMZW]NOLIB<> 1 :WTRACE(WNBTRACE)-= ":" :Endif :# Menu local autre que "Oui/Non"
    Endif
    WTRACE(WNBTRACE)-="->"
  Else
    WNBTRACE += 1
    WTRACE(WNBTRACE)=[L]LIB
    If [F:AMZW]NOLIB<> 1 :  WTRACE(WNBTRACE)-=":" : Endif # Menu local autre que "Oui/Non"
  Endif
Return
#end MABOS-22/04/13-FQ86015-US1531

#DLE : Function to manage group of company by leg
Subprog C_GRPCPYLEG(AZC,VLEG)
Variable Char    AZC()
Value Char VLEG
Local Integer I, K, OK
Local Char LIS_CPY(GLONCPY)(0..100)

If AZC="" : End : Endif

If GNBLEG = 1 : VLEG = GDOSLEG : Endif
If VLEG="" and GLEGFIL<>"" : VLEG = GLEGFIL : Endif

[L]I=0 : Call CALC_GRPCPY(AZC, [L]LIS_CPY, [L]I) From TOOLSVAR


If VLEG="" and [L]LIS_CPY(0)<>"" : End  :Endif # Exist one company

If !clalev([F:WCPY]) : Local File COMPANY [WCPY] : Endif
[L]OK=0
For K=0 To I-1
  Filter [WCPY] Where LEG=[L]VLEG & CPY=[L]LIS_CPY([L]K)
  Look [WCPY] First
  Filter [WCPY]
  If !fstat
    [L]OK=1 : Break
  Endif
Next K
If !OK
  mkstat=2
  GMESSAGE=AZC-mess(170,187,1)-'"'+VLEG-'"'
Endif
Close Local File [WCPY]
End
#end DLE
# FQ61463 - SEGAY 29/07/2013 - Homogénéisation nom prénom
#**
#* Display Name Surnam in screen, read ID3(EMPLOID)
#*
#* @param MAT code of Matricule
#* @param P_MSK mask with []
#* @param P_ZONE1 name field1 NAM
#* @param P_ZONE2 name field2 SRN
#* @param P_ISLIG is table row
#* @param P_NUMLIG number line
#*!
Subprog UPD_NAMSRN(MAT,P_MSK,P_ZONE1,P_ZONE2,P_ISLIG,P_NUMLIG)
Value Char MAT
Value Char P_MSK
Value Char P_ZONE1
Value Char P_ZONE2
Value Integer P_ISLIG
Value Integer P_NUMLIG
Local Char WFIELD1(50)
Local Char WPARAMETRE(50)
Local Integer WDIMPARAM
If !clalev([F:ID3])  : Local File EMPLOID   [ID3]  : Endif # FQ61463 - SEGAY 29/07/2013 - Homogénéisation nom prénom

For WPARAMETRE=P_ZONE1,P_ZONE2
  If WPARAMETRE <> ""
    WDIMPARAM=0
    If evalue("dim("+P_MSK+WPARAMETRE+")")>0 Then
      WDIMPARAM = evalue("dim("+P_MSK+WPARAMETRE+")")
    Endif
    If WPARAMETRE <> "" & WDIMPARAM > 0 Then
      If P_ISLIG
        WFIELD1 = P_MSK+WPARAMETRE+"("+num$(P_NUMLIG)+")"
      Else
        WFIELD1 = P_MSK+WPARAMETRE
      Endif
      Read [ID3]ID0=MAT
      If !fstat and MAT<>"" Then
        If WPARAMETRE=P_ZONE1 Then
          Assign WFIELD1 With [F:ID3]NAM
        Else
          Assign WFIELD1 With [F:ID3]SRN
        Endif
      Else
        Effzo = WFIELD1
      Endif
      Affzo = WFIELD1
    Endif
  Endif
Next
End

Subprog UPD_NAMSRN_OLD(MAT,P_MSK,P_ZONE1,P_ZONE2,P_ISLIG,P_NUMLIG)
Value Char MAT
Value Char P_MSK
Value Char P_ZONE1
Value Char P_ZONE2
Value Integer P_ISLIG
Value Integer P_NUMLIG
Local Char WFIELD1(50)
Local Char WFIELD2(50)

If P_ZONE1 <> "" & evalue("dim("+P_MSK+P_ZONE1+")")>0
  If P_ISLIG
    WFIELD1 = P_MSK+P_ZONE1+"("+num$(P_NUMLIG)+")"
  Else
    WFIELD1 = P_MSK+P_ZONE1
  Endif
Endif
If P_ZONE2 <> "" & evalue("dim("+P_MSK+P_ZONE2+")")>0
  If P_ISLIG
    WFIELD2 = P_MSK+P_ZONE2+"("+num$(P_NUMLIG)+")"
  Else
    WFIELD2 = P_MSK+P_ZONE2
  Endif
Endif

Read [ID3]ID0=MAT
If !fstat and MAT<>"" Then
  If P_ZONE1 <> "" & evalue("dim("+P_MSK+P_ZONE1+")")>0
    Assign WFIELD1 With [F:ID3]NAM
  Endif
  If P_ZONE2 <> "" & evalue("dim("+P_MSK+P_ZONE2+")")>0
    Assign WFIELD2 With [F:ID3]SRN
  Endif
Else
  If P_ZONE1 <> "" & evalue("dim("+P_MSK+P_ZONE1+")")>0
     Effzo = WFIELD1
  Endif
  If P_ZONE2 <> "" & evalue("dim("+P_MSK+P_ZONE2+")")>0
     Effzo = WFIELD2
  Endif
Endif
If P_ZONE1 <> "" & evalue("dim("+P_MSK+P_ZONE1+")")>0
   Affzo = WFIELD1
Endif
If P_ZONE2 <> "" & evalue("dim("+P_MSK+P_ZONE2+")")>0
   Affzo = WFIELD2
Endif

End
#############################################################################
#86255: Sélection d'une banque par législation/société
$SEL_BAN
OBJET="BAN"
If !clalev([F:BAN]) : Local File BANK [BAN] : Endif
If PARAM(2)<>""
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:BAN]CPY="'+PARAM(2)+'"',"&") From GOBJSUB
Elsif PARAM(1)<>""
 If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
 Local Integer J
  Filter [CPY] Where LEG=PARAM(1) & CPYLEGFLG=2
 If dim(GWSOC)<0 : Global Char GWSOC(GLONCPY)(0..rowcount([CPY])) : Endif
 [L]J=0
 For [CPY]CPY0
   GWSOC([L]J)=[F:CPY]CPY
   [L]J+=1
 Next
 Filter [CPY]
 Call ADDCRIT(CRITERE,ICRITERE,"","(find([F:BAN]CPY,GWSOC)>0)","&") From GOBJSUB
Endif
Return

$FIN_BAN
If dim(GWSOC)>=0 : Kill GWSOC : Endif
Return

