#LIPET - 2017-11-13 - X3-65677 - START
Subprog SEL_CTR(MATRI,DAT,CTR)
Value    Char MATRI
Value    Date DAT
Variable Char CTR
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
If clalev([F:CPY])=0   : Local File COMPANY  [CPY]   : Endif
If clalev([F:FCY])=0   : Local File FACILITY [FCY]   : Endif

 # FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF

Link [HRCTR] With
&    [FCY]FCY0=[F:HRCTR]ETRFCY,
&    [CPY]CPY0=[F:FCY]LEGCPY
& As [LNK]
& Where REFNUM=MATRI & (CTRDAT<=DAT | (FLGRET=2 & RETDATEFF<=DAT)) & (XITDAT=[0/0/0] | XITDAT>=DAT) Order By Key CLE=REFNUM;CTRDAT Desc #LIPET: Link will not take account of legislation
#& Where REFNUM=MATRI & (CTRDAT<=DAT | (FLGRET=2 & RETDATEFF<=DAT)) & (GCURLEG="" | [CPY]LEG=GCURLEG) & (XITDAT=[0/0/0] | XITDAT>=DAT) Order By Key CLE=REFNUM;CTRDAT Desc
For [LNK]CLE
 CTR = [F:HRCTR]CTRNUM
 Break
Next

End
#LIPET - 2017-11-13 - X3-65677 - END

#PEVAN - 2018-04-13 - X3-86866 - START
Funprog ADDPERIOD(PERIODCODE,PERIODSTART,AMT,STREND)
Value Char PERIODCODE   #PERCOD
Value Date PERIODSTART  #PERSTR
Value Integer AMT       #Amount of periods to add/subtract
Value Integer STREND    #The return date indicator: 1 = Return the start date, 2 = Return the end date

  Local Date RDATE     #Return value

  Local Integer CURPERNUM

  If clalev([F:HRPEODHR])=0 : Local File HRPEODET [HRPEODHR] : Endif
  If clalev([F:HRPEODH1])=0 : Local File HRPEODET [HRPEODH1] : Endif
  If clalev([F:HRPEODH2])=0 : Local File HRPEODET [HRPEODH2] : Endif
  Filter [F:HRPEODHR] Where [F:HRPEODHR]PERCOD=PERIODCODE & [F:HRPEODHR]PERSTR(1)=PERIODSTART

  If rowcount([F:HRPEODHR])=0
    End RDATE
  Endif

  Read [F:HRPEODHR] First

  If AMT = 0
    If STREND = 2
      RDATE = [F:HRPEODHR]PEREND(1)
    Else
      RDATE = [F:HRPEODHR]PERSTR(1)
    Endif
    End RDATE
  Endif

  CURPERNUM = [F:HRPEODHR]PERNUM

  If AMT > 0
    Filter [F:HRPEODH1] Where [F:HRPEODH1]PERCOD=PERIODCODE & [F:HRPEODH1]PERYEA=[F:HRPEODHR]PERYEA Order By [F:HRPEODH1]PERNUM
    Read [F:HRPEODH1] Last
    Filter [F:HRPEODH1]
    If [F:HRPEODH1]PERNUM >= CURPERNUM + AMT
      Filter [F:HRPEODH2] Where [F:HRPEODH2]PERCOD=PERIODCODE & [F:HRPEODH2]PERYEA=[F:HRPEODHR]PERYEA & [F:HRPEODH2]PERNUM = (CURPERNUM + AMT)
      Read [F:HRPEODH2] First
      If STREND = 2
        RDATE = [F:HRPEODH2]PEREND(1)
      Else
        RDATE = [F:HRPEODH2]PERSTR(1)
      Endif
    Else
      Local Integer STOP : STOP = 0
      Local Integer YEARCNT : YEARCNT = 0
      Local Integer REMAINAMT : REMAINAMT = AMT
      REMAINAMT -= [F:HRPEODH1]PERNUM - CURPERNUM
      While STOP = 0
        YEARCNT += 1
        Filter [F:HRPEODH2] Where [F:HRPEODH2]PERCOD=PERIODCODE & [F:HRPEODH2]PERYEA=([F:HRPEODHR]PERYEA+YEARCNT) Order By [F:HRPEODH2]PERNUM
        If rowcount([F:HRPEODH2]) = 0
          RDATE = [0/0/0]
          End RDATE
        Endif
        Read [F:HRPEODH2] Last
        Filter [F:HRPEODH2]
        REMAINAMT -= [F:HRPEODH2]PERNUM
        If REMAINAMT < 0
          STOP = 1
          REMAINAMT = [F:HRPEODH2]PERNUM - (REMAINAMT * -1)
        Endif
      Wend
      Filter [F:HRPEODH1] Where [F:HRPEODH1]PERCOD=PERIODCODE & [F:HRPEODH1]PERYEA=([F:HRPEODHR]PERYEA+YEARCNT) & [F:HRPEODH1]PERNUM = REMAINAMT
      Read [F:HRPEODH1] First
      If STREND = 2
        RDATE = [F:HRPEODH1]PEREND(1)
      Else
        RDATE = [F:HRPEODH1]PERSTR(1)
      Endif
    Endif
  Else
    Local Integer PAMT : PAMT = AMT * (-1)
    If CURPERNUM - PAMT >= 1
      Filter [F:HRPEODH2] Where [F:HRPEODH2]PERCOD=PERIODCODE & [F:HRPEODH2]PERYEA=[F:HRPEODHR]PERYEA & [F:HRPEODH2]PERNUM = (CURPERNUM - PAMT)
      Read [F:HRPEODH2] First
      If STREND = 2
        RDATE = [F:HRPEODH2]PEREND(1)
      Else
        RDATE = [F:HRPEODH2]PERSTR(1)
      Endif
    Else
      Local Integer STOP : STOP = 0
      Local Integer YEARCNT : YEARCNT = 0
      Local Integer REMAINAMT : REMAINAMT = PAMT
      REMAINAMT -= CURPERNUM
      While STOP = 0
        YEARCNT += 1
        Filter [F:HRPEODH2] Where [F:HRPEODH2]PERCOD=PERIODCODE & [F:HRPEODH2]PERYEA=([F:HRPEODHR]PERYEA-YEARCNT) Order By [F:HRPEODH2]PERNUM
        If rowcount([F:HRPEODH2]) = 0
          RDATE = [0/0/0]
          End RDATE
        Endif
        Read [F:HRPEODH2] Last
        Filter [F:HRPEODH2]
        REMAINAMT -= [F:HRPEODH2]PERNUM
        If REMAINAMT < 0
          STOP = 1
          REMAINAMT = REMAINAMT * -1
        Endif
      Wend
      Filter [F:HRPEODH1] Where [F:HRPEODH1]PERCOD=PERIODCODE & [F:HRPEODH1]PERYEA=([F:HRPEODHR]PERYEA-YEARCNT) & [F:HRPEODH1]PERNUM = REMAINAMT
      Read [F:HRPEODH1] First
      If STREND = 2
        RDATE = [F:HRPEODH1]PEREND(1)
      Else
        RDATE = [F:HRPEODH1]PERSTR(1)
      Endif
    Endif
  Endif
End RDATE
