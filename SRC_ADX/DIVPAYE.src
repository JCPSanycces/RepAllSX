   [M]ALLFCY=2 : Affzo ALLFCY : Diszo ALLFCY
  Endif
 Else
  Actzo CPY #,ALLFCY
  If dim([M]ALLFCY)>0 : Actzo ALLFCY : Endif
 Endif
Endif

If dim([M]ALLFCY)>0
 If [M]ALLFCY=2 : Diszo FCY : Else : Actzo FCY : Endif
Endif
