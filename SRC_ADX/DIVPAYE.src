    LOCITM(5) = 1
    LOCITM(6) = 1
#    LOCITM(7) = 1
#    LOCITM(8) = 1
#    LOCITM(9) = 1
#    LOCITM(10) = 1
    LOCITM(11) = 1
    For I=1 To 11
      GMENLOC(I)= LOCITM(I)
    Next
  Endif
  #LIMAS - 2017-07-27 - X3-35355 - END

#ADNGO - 2017-08-22 - X3-53120 - START
  If func DIVPAYE.IS_KNA_LEG(GCURLEG)
    Local Integer LOCITM(1..11) #number of items in Local menu 11707
    LOCITM(7) = 1
    LOCITM(8) = 1
    LOCITM(9) = 1
    LOCITM(10) = 1
    For I=1 To 11
      GMENLOC(I)= LOCITM(I)
    Next
  Endif
#ADNGO - 2017-08-22 - X3-53120 - END
Endif
End
