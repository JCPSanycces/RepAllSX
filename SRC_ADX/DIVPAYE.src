Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 Grizo ALLCPY
 Actzo CPY, ALLFCY
 mkstat = 1
 End
Endif
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo CPY,FCY : Diszo CPY,FCY
 [M]ALLFCY=2 : Affzo ALLFCY : Diszo ALLFCY
Else
 Actzo [M]CPY,ALLFCY
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
If [M]ALLCPY=2 : mkstat = 1  : End : Endif
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Local    Integer I, K, DIFF_LEG
Local    Char    LEG(GLONADI), LIS_CPY(GLONCPY)(0..100)
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
#DBA : 91298
Local Integer W_SETLEG
#If VALEUR<>"" Then
If GNBLEG = 1
  GCURLEG = GDOSLEG
Elsif dim([M]LEG)>0
#
 I=0 : Call CALC_GRPCPY(VALEUR, LIS_CPY, I) From TOOLSVAR
 If I>0              : # C'est une société ou un groupe de sociétés
  [L]LEG="" : DIFF_LEG=1
  For K=0 To I-1
   Call LECTURE("CPY", LIS_CPY(K), "") From CONTOBJ
   If [L]LEG="" Then [L]LEG=[F:CPY]LEG : Endif
   If [L]LEG<>[F:CPY]LEG Then
     DIFF_LEG=2 : Break
   Endif
  Next
  #If dim([M]LEG)>0
  If DIFF_LEG=1 Then : # Toutes les sociétés du groupe ont la même leg
   If [M]LEG<>[L]LEG
    [M]LEG=[L]LEG
    #DBA : 91298
    #Call INIT_BYLEG([M]LEG) :#MABOS-25/01/2013
    W_SETLEG=1
   Endif
   Diszo [M]LEG
   #DBA : 91298
   #Affzo [M]LEG, ZLEG
   #GCURLEG=[L]LEG
   #
  Else               : # Les sociétés du groupe ont des legs différentes
   If [M]LEG<>GLEGFIL
    [M]LEG=GLEGFIL
    #DBA : 91298
    #Call INIT_BYLEG([M]LEG) :#MABOS-25/01/2013
    W_SETLEG=1
   Endif
   Actzo [M]LEG
   #DBA : 91298
   #Affzo [M]LEG, ZLEG
   #GCURLEG=GLEGFIL
   #
  Endif
  #DBA : 91298
  GCURLEG=[M]LEG
  If W_SETLEG=1
    Call INIT_BYLEG(GCURLEG)
  Endif
  Affzo [M]
  #
 Endif
 Call AM_CPY_INIFCY

#MAPAD - 2016-02-25 - Req 114309 - START
 If (dim([M]DATDEB)>0)
 Call CLEAR_RANGE From TRTEMP1
 Endif
#MAPAD - 2016-02-25 - Req 114309 - END
Endif

#JOJAC - 2016-05-04 - REQ114309 US86 - START
If dim([M:DIA]ALLSRV)>0
If [M:DIA]ALLSRV <> 2 : [M:DIA]ALLSRV = 2 : Raz [M:DIA]SRV : Affzo [M:DIA]ALLSRV : Affzo [M:DIA]SRV : Endif
Endif
If dim([M:DIA]ALLPRF) > 0
If [M:DIA]ALLPRF <> 2 : [M:DIA]ALLPRF = 2 : Raz [M:DIA]PRF : Affzo [M:DIA]ALLPRF : Affzo [M:DIA]PRF : Endif
Endif
If dim([M:DIA]ALLPOT) > 0
If [M:DIA]ALLPOT <> 2 : [M:DIA]ALLPOT = 2 : Raz [M:DIA]POT : Affzo [M:DIA]ALLPOT :  Affzo [M:DIA]POT : Endif
Endif
If dim([M:DIA]ALLJOBPOT) > 0
If [M:DIA]ALLJOBPOT <> 2 : [M:DIA]ALLJOBPOT = 2 : Raz [M:DIA]JOBPOT : Affzo [M:DIA]ALLJOBPOT : Affzo [M:DIA]JOBPOT Endif
Endif

#JOJAC - 2016-05-04 - REQ114309 US86 - END

End

Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR
#DBA : 91298
#If dim([M]LEG)>0 & VALEUR=2 Then
# If [M]LEG<>GLEGFIL
#   [M]LEG=GLEGFIL
#   GCURLEG = [M]LEG
#   Call INIT_BYLEG([M]LEG) :#MABOS-25/01/2013
# Endif
# Actzo [M]LEG : Affzo [M]LEG, ZLEG
#Endif
#on ne réinitialise les champs que sur changements de leg
Local Integer W_SETLEG
If VALEUR=2
 If GNBLEG = 1
  GCURLEG = GDOSLEG
 Elsif dim([M]LEG)>0
  If [M]LEG<>GLEGFIL
   [M]LEG=GLEGFIL
   W_SETLEG=1
  Endif
  GCURLEG=[M]LEG
  Actzo [M]LEG
 Endif
 If W_SETLEG=1 : Call INIT_BYLEG(GCURLEG) : Endif
  Affzo [M]
Endif
#

#JOJAC - 2016-05-04 - REQ114309 US86 - START
If dim([M:DIA]ALLSRV)>0
If [M:DIA]ALLSRV <> 2 : [M:DIA]ALLSRV = 2 : Raz [M:DIA]SRV : Affzo [M:DIA]ALLSRV : Affzo [M:DIA]SRV : Endif
Endif
If dim([M:DIA]ALLPRF) > 0
If [M:DIA]ALLPRF <> 2 : [M:DIA]ALLPRF = 2 : Raz [M:DIA]PRF : Affzo [M:DIA]ALLPRF : Affzo [M:DIA]PRF : Endif
Endif
If dim([M:DIA]ALLPOT) > 0
If [M:DIA]ALLPOT <> 2 : [M:DIA]ALLPOT = 2 : Raz [M:DIA]POT : Affzo [M:DIA]ALLPOT :  Affzo [M:DIA]POT : Endif
Endif
If dim([M:DIA]ALLJOBPOT) > 0
If [M:DIA]ALLJOBPOT <> 2 : [M:DIA]ALLJOBPOT = 2 : Raz [M:DIA]JOBPOT : Affzo [M:DIA]ALLJOBPOT : Affzo [M:DIA]JOBPOT Endif
Endif
#JOJAC - 2016-05-04 - REQ114309 US86 - END

End

