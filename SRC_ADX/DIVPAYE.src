Subprog MANAGE_LOCALISATIONNEW(FEN,NAMFIC)
Value Char FEN(),NAMFIC()
 If func TRTLEGSHOWHIDE.GENERATE_FILES(FEN)
    Gosub INI_TABSPE_FIELDS From TRTLEGSHOWHIDE
    Onerrgo IGNORE_ERR
    Gosub INI_TABSPE_FIELDSTOHIDE From =NAMFIC
    Gosub INI_TABSPE_FIELDSTOSHOW From =NAMFIC
    Onerrgo
    Call MANAGE_LOCALISATION_SHOW(FEN,FLDTOHIDE,FLDTOSHOW) From TRTLEGSHOWHIDE
    Gosub KILL_VAR_ARRAY From TRTLEGSHOWHIDE
  Endif
End

