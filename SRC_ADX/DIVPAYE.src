If dim([M]ALLEXTPER)>0
  If [M]ALLEXTPER=2 : Diszo PERCOD : Else : Actzo PERCOD : Endif
Endif
If dim([M]ALLPERCOD)>0
  If [M]ALLPERCOD=2 : Diszo PERNUM : Else : Actzo PERNUM : Endif
Endif
#JOJAC - 2017-01-16 - END


#81085
If dim([M]TYPEXP)>0
 If [M]TYPEXP<>2
  If dim([M]FIL)>0    :  Diszo FIL    : Endif
  If dim([M]FILNAM)>0 :  Diszo FILNAM : Endif
 Endif
Endif
Return

Subprog C_MATFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]MATDEB
#Borne incorrecte
 GMESSAGE = mess(28,10702,1)
 mkstat = 2 : End
Endif
End

Subprog C_CTRFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]CTRDEB
#Borne incorrecte
 GMESSAGE = mess(28,10702,1)
 mkstat = 2 : End
Endif
End

###################################################################
## CONTEMP ACTION
## Linked to the data type EML
###################################################################
$SEL_EMP_OLD
NBTEX = 0
If VALEUR="" : Return : Endif
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
Read [F:ID]ID0 = VALEUR
If !fstat : Return : Endif
If GREP="C" & GFONCTION="GESEML"
  Return
Endif
For [F:ID]ID1 Where left$(NAM,len(VALEUR))=VALEUR
 NBTEX += 1
 TEXTE(NBTEX) = [F:ID]NAM-[F:ID]SRN-"("+[F:ID]REFNUM+")"

 If NBTEX>=dim(TEX)-1 : Break : Endif
Next
Return

#US1840 81085 01/08/2013 Selection DISPLAY columns and title
# Idem SELEMP from SELMAT
$SEL_EMP
NBTEX = 0
If VALEUR="" : Return : Endif
If clalev([F:ID])=0     : Local File EMPLOID   [ID]     : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR  [HRCTR]  : Endif
If clalev([F:ECT])=0    : Local File EMPCTR    [ECT]    : Endif
If clalev([F:FCY])=0    : Local File FACILITY  [FCY]    : Endif
If clalev([F:ACC])=0    : Local File ACCES     [ACC]    : Endif

Local Char    SOC([V]GLONCPY) , SIT([V]GLONFCY) , SER([V]GLONSRV) , PRO([V]GLONPRF), CRIT1(250)
Local Integer FLG    :#   0=All employees ; 1=only payroll employee ; 2=only time management employee
Local Char    LEG ([V]GLONADI)
Local Integer I, K
Local Char    LIS_CPY(GLONCPY)(0..100)
#Local Integer HASTOCHECK : HASTOCHECK=1


Local Integer I
SOC = PARAM(1)
SIT = PARAM(2)
SER = PARAM(3)
PRO = PARAM(4)
FLG = val(PARAM(5))
LEG = PARAM(6)

Local Char    TEX(80)(1..100), TEXTE(30)(1..100,1..5)
TIT(0)=mess(46,10702,1)                 : # Sélection salarié
Call TEXTE(47145,TIT(1)) From OBJDIV    : # Nom-Prénom
Call TEXTE(10793,TIT(2)) From OBJDIV    : # Matricule
Call TEXTE(1343,TIT(3))  From OBJDIV    : # Société
Call TEXTE(1344,TIT(4))  From OBJDIV    : # Site
Call TEXTE(26213,TIT(5)) From OBJDIV    : # Législation

NBCOL=5

If clalev([F:ILEG])=0 : Local File EMPLOLEG [ILEG] : Endif
Link [ILEG] With [ACC]CODACC=GUSER;[F:ID]CODACS
&   As [LEMP]
&   Order By Key CLE1= NAM;REFNUM;CTRNUM
CRIT1 = '[F:ILEG]ENAFLG=2 & ([F:ILEG]CODACS="" or [F:ACC]EXEC=2)'

If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 CRIT1 -= "& find([F:ILEG]ETRFCY,GUSRFCY(1..GNBAUZ))"
Endif

If GUSRACS<>2
 CRIT1 -= "& find([F:ILEG]ETRSRV,GAUTSRV(1..GNBSERV))"
Endif

If SOC<>""
# CRIT1 -= '& [F:ILEG]LEGCPY="'+SOC+'"'
  I=0 : Call CALC_GRPCPY(SOC, LIS_CPY, I) From TOOLSVAR
  If I>0 Then
    CRIT1 -= "& find([F:ILEG]LEGCPY,"
    For K=0 To I-1
      CRIT1 += "'"+LIS_CPY(K)+"'"
      If K<I-1 Then CRIT1 += "," : Endif
    Next
    CRIT1 += ")>0"
  Endif
Endif

If SIT<>""
# CRIT1 -= '& [F:ILEG]ETRFCY="'+SIT+'"'
 CRIT1 -= '& [F:ILEG]FCYID="'+SIT+'"'
Endif

If SER<>""
 CRIT1 -= '& [F:ILEG]ETRSRV="'+SER+'"'
Endif

If PRO<>""
 CRIT1 -= '& [F:ILEG]PROPRF="'+PRO+'"'
Endif

If LEG<>""
 CRIT1 -= "& [F:ILEG]LEGID='"+LEG+"'"
Endif

If FLG=1
 CRIT1 -= "& [F:ILEG]FLGPAY=2"
Endif

If FLG=2
 CRIT1 -= "& [F:ILEG]FLGTPS=2"
Endif

If SOC="" & SIT="" & SER="" & PRO="" & LEG="" & GLEGFIL<>"" Then
  CRIT1 -= "& [F:ILEG]LEGID='"+GLEGFIL+"'"
#  HASTOCHECK=2
Endif

Read [F:ID]ID0 = VALEUR
If !fstat : Return : Endif
If GREP="C" & GFONCTION="GESEML"
  Return
Endif
For [LEMP]CLE1(2) Where left$(NAM,len(VALEUR))=VALEUR & [F:ILEG]FLGNEWSAL <> 2 & evalue(CRIT1)

   NBTEX += 1
   TEX(NBTEX)     = [F:ILEG]REFNUM
   TEXTE(NBTEX,1) = [F:ILEG]NAM-[F:ILEG]SRN
   TEXTE(NBTEX,2) = [F:ILEG]REFNUM
   TEXTE(NBTEX,3) = [F:ILEG]LEGCPY
   TEXTE(NBTEX,4) = [F:ILEG]FCYID
   TEXTE(NBTEX,5) = [F:ILEG]LEGID

   If NBTEX>=dim(TEX)-1 : Break : Endif
Next

Return

###################################################################
$SEL_CTREMP
Local Char CRITERE3(250) :#MABOS-01/02/13-FQ86831-US1205 - limit 127 for GAUTSRV
Local Date DATREF
If clalev([F:ID])=0    : Local File EMPLOID  [ID]    : Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
If clalev([F:ACC])=0   : Local File ACCES    [ACC]   : Endif
If clalev([F:SRV])=0   : Local File SERVICE [SRV]    : Endif : #MABOS-01/02/13-FQ86831-US1205 - limit 127 for GAUTSRV
If clalev([F:ACCS])=0  : Local File ACCES   [ACCS]   : Endif : #MABOS-01/02/13-FQ86831-US1205 - limit 127 for GAUTSRV

NBTEX = 0
If PARAM(2)<>[0/0/0] Then DATREF=PARAM(2) : Else DATREF=date$ : Endif
Filter [F:HRCTR]
If PARAM(1)=""
 # MABON 11/01/13 - Ajout filtre sur dates d'entrée/sortie
For [HRCTR]CTR0(2)
&    Where (CTRDAT<=DATREF | (FLGRET=2 & RETDATEFF<=DATREF)) & (XITDAT=[0/0/0] | XITDAT>=DATREF)
  Read [ID]ID0=[F:HRCTR]REFNUM
  If !fstat
   If GUSRACS<>2 & [F:ID]CODACS <> ""
    Read [F:ACC]CODACC = GUSER;[F:ID]CODACS
   Endif
   # MABOS-01/02/13-FQ86831-US1205 - limit 127 for GAUTSRV
   #If GUSRACS = 2 | ( ([F:ID]CODACS="" | [F:ACC]CONSUL=2) & find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV)) )
   If GUSRACS = 2 | ( ([F:ID]CODACS="" | [F:ACC]CONSUL=2) & (func AUTSRV([F:HRCTR]ETRSRV)) )
    NBTEX += 1
    TEX(NBTEX) = [F:HRCTR]CTRNUM
    TEXTE(NBTEX) = [F:ID]NAM-[F:ID]SRN-"("+[F:HRCTR]REFNUM+")"-mess(156,10702,1)-[F:HRCTR]CTRNUM-[F:HRCTR]JOB-[F:HRCTR]ETRFCY-[F:HRCTR]ETRSRV
    If NBTEX>=dim(TEX)-1 : Break : Endif
   Endif
  Endif
 Next
Else
 # MABON 11/01/13 - REFNUM=PARAM(1) au lieu de CTRNUM + Ajout filtre sur dates d'entrée/sortie
# For [HRCTR]CTR0(2) Where CTRNUM=PARAM(1)
#&                     & find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV))
#MABOS-01/02/13-FQ86831-US1205 - limit 127 for GAUTSRV
# For [HRCTR]CTR0(2) Where REFNUM=PARAM(1)
#&                       & find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV))
#&                       & (CTRDAT<=DATREF | (FLGRET=2 & RETDATEFF<=DATREF)) & (XITDAT=[0/0/0] | XITDAT>=DATREF)
##&                     & CTRDAT<=date$ & (XITDAT=[0/0/0] | XITDAT>=date$)
  CRITERE3 = "1=1"
  If GUSRACS<>2
    CRITERE3 -= '& ([F:SRV]CODACC="" or [F:ACCS]EXEC=2)'
  Endif
  Link [HRCTR] With
&                [SRV]SRV0=ETRSRV
&              , [ACCS]CODACC=GUSER;[F:SRV]CODACC
&             As [LCTR]
&          Where REFNUM=PARAM(1) & evalue(CRITERE3)
&                & (CTRDAT<=DATREF | (FLGRET=2 & RETDATEFF<=DATREF)) & (XITDAT=[0/0/0] | XITDAT>=DATREF)

For [LCTR]CTR0(2)
 #End #MABOS-01/02/13-FQ86831-US1205 - limit 127 for GAUTSRV
  If GUSRACS<>2
   Read [ID]ID0=[F:HRCTR]REFNUM
    If !fstat
     If [F:ID]CODACS <> ""
      Read [F:ACC]CODACC = GUSER;[F:ID]CODACS
     Endif
    Endif
   Endif
   If GUSRACS = 2 | ( !fstat & ([F:ID]CODACS="" or [F:ACC]CONSUL=2))
    NBTEX += 1
    TEX(NBTEX) = [F:HRCTR]CTRNUM
    TEXTE(NBTEX) = [F:ID]NAM-[F:ID]SRN-mess(156,10702,1)-[F:HRCTR]CTRNUM-[F:HRCTR]JOB-mess(12,105,1)-[F:HRCTR]ETRFCY-mess(44,10702,1)-[F:HRCTR]ETRSRV
    If NBTEX>=dim(TEX)-1 : Break : Endif
   Endif
 Next
 If NBTEX=0
  For [ID]ID1 Where left$(NAM,len(PARAM(1)))=PARAM(1) or left$(REFNUM,len(PARAM(1)))=PARAM(1)
   # MABON 11/01/13 - Ajout filtre sur dates d'entrée/sortie
   For [HRCTR]CTR0(2) Where REFNUM=[F:ID]REFNUM
&                           & (CTRDAT<=DATREF | (FLGRET=2 & RETDATEFF<=DATREF)) & (XITDAT=[0/0/0] | XITDAT>=DATREF)
    If GUSRACS<>2 & [F:ID]CODACS <> ""
     Read [F:ACC]CODACC = GUSER;[F:ID]CODACS
    Endif
    #MABOS-01/02/13-FQ86831-US1205 - limit 127 for GAUTSRV
    #If GUSRACS= 2 | ( ([F:ID]CODACS="" or [F:ACC]CONSUL=2) & find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV)) )
    If GUSRACS= 2 | ( ([F:ID]CODACS="" or [F:ACC]CONSUL=2) & func AUTSERV([F:HRCTR]ETRSRV) )
     NBTEX += 1
     TEX(NBTEX) = [F:HRCTR]CTRNUM
     TEXTE(NBTEX) = [F:ID]NAM-[F:ID]SRN-mess(156,10702,1)-[F:HRCTR]CTRNUM-[F:HRCTR]JOB-mess(12,105,1)-[F:HRCTR]ETRFCY-mess(44,10702,1)-[F:HRCTR]ETRSRV
     If NBTEX>=dim(TEX)-1 : Break 2 : Endif
    Endif
   Next
  Next
 Endif
Endif
Return

############################################################
# MABOS-01/02/13-FQ86831-US1205 - limit 127 for GAUTSRV
# GUSER is authorized to use the service ?
# SERV : Code Service
# WOK : Result : 0 = No Authorized   / 1 : Authorized

Funprog AUTSRV(SERV)
Value Char SERV
Local Integer WOK
[L]WOK = 1
If [L]SERV = "" Then End [L]WOK :Endif
If GUSRACS =  2 Then End [L]WOK :Endif
# GUSRACS <> 2
[L]WOK = 0
If clalev([F:SRVS])=0 : Local File SERVICE  [SRVS] : Endif
If clalev([F:ACCS])=0 : Local File ACCES   [ACCS] : Endif
Read [F:SRVS]SRV0=[L]SERV
If !fstat Then
 If [F:SRVS]CODACC <> ""
  Read [F:ACCS]CODACC = GUSER;[F:SRVS]CODACC
 Endif
If !fstat & ( [F:SRVS]CODACC="" or [F:ACCS]EXEC=2 ) Then
 [L]WOK = 1
 Endif
Endif
End [L]WOK

########################################
# Donne la société d'un site
Funprog GETSOC(SITE)
Value Char SITE()

Local Shortint I

I=find([L]SITE,[V]GSITE(1..[V]GNBSITE))
If I : End [V]GSOCSITE(I) : Endif

If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
Read [FCY]FCY0=[L]SITE
If !fstat : End [F:FCY]LEGCPY : Else End "" : Endif
End ""

########################################
# Dit qui locke le symbole
Subprog QUILOCKE (SYMBOLE,TYP)
Value Char SYMBOLE()
Value Integer TYP

Local Char MACLCK(50), USRLCK(50)

Call QUILOCKE([L]SYMBOLE,[L]MACLCK,[L]USRLCK) From OBJDIV
Case [L]TYP
When 1 : # Fiche
 If [L]USRLCK>"" : [V]GMESSAGE=mess(101,126,1)+"\"+[L]USRLCK+"\"+[L]MACLCK
 Else              [V]GMESSAGE=mess(98,126,1)
 Endif
When 2 : # Opération
 [V]GMESSAGE=mess(30,100,1)
 If [L]USRLCK>"" : [V]GMESSAGE-=":\"+[L]USRLCK+"\"+[L]MACLCK : Endif
Endcase

End

################################################################################
# Donne l'email d'un salarié en fonction de EMPLOAD ou de ADOVALAUS
Funprog GETEML(REFNUM)
Value Char REFNUM ()

If !clalev([F:AD]) : Local File EMPLOAD [AD] : Endif

Read [AD]AD0 = REFNUM
If !fstat & [F:AD]PFLEML>"" : End [F:AD]PFLEML : Endif

If !clalev([F:ADU]) : Local File ADOVALAUS [ADU] : Endif

Filter [ADU] Where PARAM="REFNUM" & VALEUR=[L]REFNUM
Read [ADU]ADU1 First
Filter [ADU]
If fstat : End "" : Endif

If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif

Read [AUS]CODUSR=[F:ADU]CODUSR
If fstat : End "" : Else End [F:AUS]ADDEML : Endif
End ""

#JOJAC - START (GESCTR)
Subprog GET_ALLEVT(FCY,PARAM,TABRES,NBRES)
Value Char FCY()
Variable Char PARAM()
Variable Char TABRES()()
Variable Integer NBRES

Local Char VALPARAM(250)
Local Integer WRES
Case PARAM
  When  "BIL" : VALPARAM="EVABIL"
  When  "PRO" : VALPARAM="EVAPRO"
  When  "YEA" : VALPARAM="EVAYEA"
  When Default: VALPARAM=PARAM
Endcase
Call PARAM(FCY,VALPARAM,VALPARAM)From ADOVAL
If VALPARAM<>""
  NBRES=func SPLIT(TABRES,VALPARAM,";")
Endif
End
#JOJAC - END

#LIPET - START
Funprog SPLIT(ARRAY,TEXT,SEP)
Variable Char ARRAY()(0..)
Variable Char TEXT
Value Char SEP
Local Integer RES
RES=func ASYRSUB.SPLIT(ARRAY,TEXT,SEP)

End RES
#LIPET - END
################################################################################
