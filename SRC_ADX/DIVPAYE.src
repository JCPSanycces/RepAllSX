#JOJAC - START (SUBCTR)
# JASMI - 2014/05/06 - Requirement 95799 US 2641 - START
# Local Menu 312 - Show only items for LEGISLATION
Subprog DISPLAY_ML312()
Raz GMENLOC

Local Shortint KSAACT, KFRACT, KPOACT, KMIEAACT
Local Integer  I
#FRLAA - 2016-06-07 - REQUIREMENT 114309 US 211 - START
#JOJAC - 2016-07-19 - REQ114309 - START
#[L]KSAACT = func AFNC.ACTIV("KSA")
#[L]KFRACT = func AFNC.ACTIV("KFR")
#[L]KPOACT = func AFNC.ACTIV("KPO")
#[L]KMIEAACT = func AFNC.ACTIV("KMIEA") #FRLAA 2015-05-27 - Requirement 105483 US 3571

[L]KSAACT = func DIVPAYE.IS_KSA_LEG(GCURLEG)
[L]KFRACT = func DIVPAYE.IS_KFR_LEG(GCURLEG)
[L]KPOACT = func DIVPAYE.IS_KPO_LEG(GCURLEG)
[L]KMIEAACT = func DIVPAYE.IS_MIDDLEEAST_LEG(GCURLEG)
#JOJAC - 2016-07-19 - REQ114309 - End

#For [L]I = 1 To 18
For [L]I = 1 To 19 #FRLAA 2015-05-27 - Requirement 105483 US 3571
  Case [L]I
    When 3,6,7,9,13
      If KMIEAACT & !KFRACT & !KPOACT    : GMENLOC(I) = 1 : Endif
    When 4
      If !KSAACT & !KFRACT              : GMENLOC(I) = 1 : Endif
    When 14
      If !KSAACT & !KFRACT & !KMIEAACT  : GMENLOC(I) = 1 : Endif
    When 8, 15
      If !KFRACT                        : GMENLOC(I) = 1 : Endif
    When 11
      If !KFRACT & !KPOACT              : GMENLOC(I) = 1 : Endif
    When 16
      If !KSAACT & !KMIEAACT            : GMENLOC(I) = 1 : Endif
    When 18
      If !KSAACT                        : GMENLOC(I) = 1 : Endif
    When 17
      If !KSAACT & !KMIEAACT            : GMENLOC(I) = 1 : Endif
     When 19,20,21,22,23,24
      If !KMIEAACT                      : GMENLOC(I) = 1 : Endif #DEHEN - 2016-05-05 - Requirement 114362 - US 3 - START
  Endcase
Next
#FRLAA 2015-05-27 - Requirement 105483 US 3571 - END

#For [L]I = 1 To 18
#  Case [L]I
#    When 4, 14
#      If !KSAACT & !KFRACT : GMENLOC(I) = 1 : Endif
#    When 8, 15
#      If !KFRACT           : GMENLOC(I) = 1 : Endif
#    When 11
#      If !KFRACT & !KPOACT : GMENLOC(I) = 1 : Endif
#    When 16, 17, 18
#      If !KSAACT           : GMENLOC(I) = 1 : Endif
#  Endcase
#Next


#If !func AFNC.ACTIV("KSA") Then
#  GMENLOC(16)=1
#  GMENLOC(17)=1
#  GMENLOC(18)=1
#Endif
#
#If !func AFNC.ACTIV("KFR") & !func AFNC.ACTIV("KPO") Then
#  GMENLOC(8)=1
#  GMENLOC(11)=1
#  GMENLOC(15)=1
#Endif
#
##BRBAN - 2014/05/06 US261 for KPO
#If func AFNC.ACTIV("KPO")>0
#  GMENLOC(11)=0
#  GMENLOC(4) =1
#  GMENLOC(14)=1
#Endif
End
# JASMI - 2014/05/06 - Requirement 95799 US 2641 - END

# JASMI - 2014/05/15 - Requirement 95799 US 2641 - START
# Local Menu 810 - Show only items for LEGISLATION
Subprog DISPLAY_ML810()
Raz GMENLOC

#JASMI - 2018-01-09 - X3-69867 - START
#Local Shortint KSAACT, KFRACT, KPOACT, KMEAACT #FRLAA 2015-05-27 - REQUIREMENT 105483 US 3571
Local Shortint KSAACT, KFRACT, KPOACT, KMEAACT, KUKACT
#JASMI - 2018-01-09 - X3-69867 - END
Local Integer  I
#ADNGO - 2017-12-06 - X3-60300 - START
#[L]KSAACT = func AFNC.ACTIV("KSA")
#JASMI - 2018-01-09 - X3-69867 - START
#[L]KSAACT = func DIVPAYE.IS_AFRICA_LEG(GCURLEG)
[L]KSAACT = func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
[L]KUKACT = func DIVPAYE.IS_BRI_LEG(GCURLEG)
#JASMI - 2018-01-09 - X3-69867 - END
#[L]KFRACT = func AFNC.ACTIV("KFR")
[L]KFRACT = func DIVPAYE.IS_KFR_LEG(GCURLEG)
# Issue 110164 - 2016-01-14 by BRBAN : need the same configuration for ANG leg.
#[L]KPOACT = func AFNC.ACTIV("KPOAO")
[L]KPOACT = func DIVPAYE.IS_KPO_LEG(GCURLEG) #| func DIVPAYE.IS_KAO_LEG(GCURLEG)
#[L]KMEAACT = func AFNC.ACTIV("KMIEA") #FRLAA 2015-05-26 - REQUIREMENT 105483 US 3571
[L]KMEAACT = func DIVPAYE.IS_MIDDLEEAST_LEG(GCURLEG) #FRLAA 2015-05-26 - REQUIREMENT 105483 US 3571
#ADNGO - 2017-12-06 - X3-60300 - END

# Issue 114888 - 2016-02-29 by BRBAN : DNATYPMOD field should have all options available for Portugal/Angola.
If [L]KPOACT>0  : End : Endif

# JASMI - 2014/06/27 - Added new item for SA - START
#For [L]I = 1 To 9
For [L]I = 1 To 10
# JASMI - 2014/06/27 - Added new item for SA - END
  Case [L]I
    When 1  #FRLAA 2015-05-27 - REQUIREMENT 105483 US 3571 - START
     If !KFRACT & KMEAACT# & !KPOACT :
      GMENLOC(I) = 1
     Endif
    When 3
     If !KFRACT & KMEAACT  #& !KPOACT :
      GMENLOC(I) = 1
     Endif
  #FRLAA 2015-05-27 - REQUIREMENT 105483 US 3571 - END
    When 2, 4, 5
      If !KFRACT #& !KPOACT
        GMENLOC(I) = 1
      Endif
    When 6
      If !KFRACT           : GMENLOC(I) = 1 : Endif
# JASMI - 2014/06/27 - Added new item for SA - START
#    When 7, 8, 9
    When 7, 8, 9, 10
# JASMI - 2014/06/27 - Added new item for SA - END
      #If !KSAACT            : GMENLOC(I) = 1 : Endif
#JASMI - 2018-01-09 - X3-69867 - START
#      If (!KSAACT & !KMEAACT) #[L]KPOACT :
      If (![L]KSAACT & ![L]KMEAACT & ![L]KUKACT) #[L]KPOACT :
#JASMI - 2018-01-09 - X3-69867 - END
        GMENLOC(I) = 1
      Endif #FRLAA 2015-05-27 - REQUIREMENT 105483 US 3571
  Endcase
Next

#If !func AFNC.ACTIV("KSA") Then
#  GMENLOC(7)=1
#  GMENLOC(8)=1
#  GMENLOC(9)=1
#Endif
#
#If !func AFNC.ACTIV("KFR") & !func AFNC.ACTIV("KPO") Then
#  GMENLOC(2)=1
#  GMENLOC(4)=1
#  GMENLOC(5)=1
#  GMENLOC(6)=1
#Endif

End
