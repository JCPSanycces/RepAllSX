 # Pas de leg = pas de profil !
 If dim([M]LEG)>0 & [M]LEG="": [M]ALLPRF=2 : Diszo ALLPRF : Else : Actzo ALLPRF : Endif
 If [M]ALLPRF=2 : Diszo PRF : Else : Actzo PRF : Affzo ZPRF : Endif :#92410 - Affichage du libellé du profil
Endif
If dim([M]ALLPOT)>0
 If [M]ALLPOT=2 : Diszo POT : Else : Actzo POT : Endif
Endif
If dim([M]ALLJOBPOT)>0
 If [M]ALLJOBPOT=2 : Diszo JOBPOT : Else : Actzo JOBPOT : Endif
Endif

