#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# EMHRMAJ90_DT UTI process                                      PAY Module
#              Migration To U12 - Vnext version
#
# ==>  Update Data Types on screens and tables for custom/protected fields
#
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  # Check Payroll Module
  If [F:ADS]MODULE(14)<>2 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("EMHRMAJ90_DT") From LECFIC
  Call ECR_TRACE("EMHRMAJ90_DT: Update Data Types on screens and tables for custom/protected fields",0) From GESECRAN

  Call MAJ_EMHRMAJ90_DT(WDOSSIER)

  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

Subprog  MAJ_EMHRMAJ90_DT(LDOSSIER)
Value Char LDOSSIER

  Local Char NEWDTARRAY(GLONATB)(1..)
  Local Char OLDDTARRAY(GLONATB)(1..)
  Local Char TABLEARRAY(GLONATB)(1..)
  Local Char DTCOLUMN(GLONATB)(1..)
  Local Integer NBRTAB, NBRDAT, I, J

  Onerrgo CYCLECHECKERROR
  Call ECR_TRACE("EMHRMAJ90_DT: Update Data Types on screens and tables for custom/protected fields",0) From GESECRAN

  Gosub ADD_DATA_TYPES
  Gosub UPDATE_TABLES
  Gosub UPDATE_SCREENS
  Gosub UPDATE_CLASSES
  Gosub ADD_TABLES
  Gosub UPDATE_DATA_TYPES_IN_DATA

End

$CYCLECHECKERROR
  Call ECR_TRACE("Error in EMHRMAJ90_DT: " + num$(errn)-errmes$(errn)-errm, -1) From GESECRAN
Resume

$ADD_DATA_TYPES

  I  = 0
  I += 1 :  NEWDTARRAY(I) = "HRBAN" : OLDDTARRAY(I) = "BAN"
  I += 1 :  NEWDTARRAY(I) = "HRCAI" : OLDDTARRAY(I) = "CAI"
  I += 1 :  NEWDTARRAY(I) = "HRCLC" : OLDDTARRAY(I) = "CLC"
  I += 1 :  NEWDTARRAY(I) = "HRCOT" : OLDDTARRAY(I) = "COT"
  I += 1 :  NEWDTARRAY(I) = "HRCTR" : OLDDTARRAY(I) = "CTR"
  I += 1 :  NEWDTARRAY(I) = "HRENT" : OLDDTARRAY(I) = "ENT"
  I += 1 :  NEWDTARRAY(I) = "HRFRM" : OLDDTARRAY(I) = "FRM"
  I += 1 :  NEWDTARRAY(I) = "HRPPH" : OLDDTARRAY(I) = "PPH"
  I += 1 :  NEWDTARRAY(I) = "HRREP" : OLDDTARRAY(I) = "REP"
  I += 1 :  NEWDTARRAY(I) = "HRSES" : OLDDTARRAY(I) = "SES"
  I += 1 :  NEWDTARRAY(I) = "FCY"   : OLDDTARRAY(I) = "SIT"
  I += 1 :  NEWDTARRAY(I) = "HRTES" : OLDDTARRAY(I) = "TES"
  I += 1 :  NEWDTARRAY(I) = "HRTRN" : OLDDTARRAY(I) = "TRN"
  I += 1 :  NEWDTARRAY(I) = "EML"   : OLDDTARRAY(I) = "MAT"

  [L]NBRTAB = I

Return

$ADD_TABLES
##
##  Add tables here that references ATY (Data Type), to update the values to V12.
##  Define the table name in TABLEARRAY
##  Define the ATY Column in DTCOLUMN
##
  I  = 0
  I += 1 :  TABLEARRAY(I) = "AGDPRSETTING" : DTCOLUMN(I) = "CODATY"

  [L]NBRDAT = I

Return

$UPDATE_TABLES
  If clalev([YTAB])=0  : Local File =LDOSSIER+".ATABZON" [YTAB]  : Endif
  Local Integer UPDATEROWS

  For [L]I = 1 To [L]NBRTAB
    UPDATEROWS = 0
    Update [F:YTAB] Where [F:YTAB]CODTYP = [L]OLDDTARRAY(I) With [F:YTAB]CODTYP = [L]NEWDTARRAY(I)
    UPDATEROWS = [S]adxuprec
    Call ECR_TRACE("EMHRMAJ90_DT: Updating tables with data type" - [L]OLDDTARRAY(I) - " to " - [L]NEWDTARRAY(I),0) From GESECRAN
    Call ECR_TRACE("EMHRMAJ90_DT: Rows updated: " - num$(UPDATEROWS),0) From GESECRAN
  Next
  Close File [F:YTAB]
Return

$UPDATE_SCREENS
  If clalev([YATB])=0  : Local File =LDOSSIER+".AMSKZON" [YATB]  : Endif
  Local Integer UPDATEROWS

  For [L]I = 1 To [L]NBRTAB
    UPDATEROWS = 0
    Update [F:YATB] Where [F:YATB]CODTYP = [L]OLDDTARRAY(I) With [F:YATB]CODTYP = [L]NEWDTARRAY(I)
    UPDATEROWS = [S]adxuprec
    Call ECR_TRACE("EMHRMAJ90_DT: Updating screens with data type" - [L]OLDDTARRAY(I) - " to " - [L]NEWDTARRAY(I),0) From GESECRAN
    Call ECR_TRACE("EMHRMAJ90_DT: Rows updated: " - num$(UPDATEROWS),0) From GESECRAN
  Next
  Close File [F:YATB]
Return

$UPDATE_CLASSES
  If clalev([WCLAF])=0 : Local File =LDOSSIER + ".ACLAFLD" [WCLAF] : Endif
  Local Integer UPDATEROWS

  For [L]I = 1 To [L]NBRTAB
    UPDATEROWS = 0
    Update [F:WCLAF] Where [F:WCLAF]CODTYP = [L]OLDDTARRAY(I) With [F:WCLAF]CODTYP = [L]NEWDTARRAY(I)
    UPDATEROWS = [S]adxuprec
    Call ECR_TRACE("EMHRMAJ90_DT: Updating classes with data type" - [L]OLDDTARRAY(I) - " to " - [L]NEWDTARRAY(I),0) From GESECRAN
    Call ECR_TRACE("EMHRMAJ90_DT: Rows updated: " - num$(UPDATEROWS),0) From GESECRAN
  Next
  Close File [F:WCLAF]
Return

$UPDATE_DATA_TYPES_IN_DATA
  For [L]J = 1 To [L]NBRDAT
    Local Char TABLENAME (250)
    TABLENAME = TABLEARRAY([L]J)
    If filinfo(filpath("FIL",TABLENAME,"fde",LDOSSIER),0)>0
      If clalev([WWWW])=0 : Local File =LDOSSIER +"."+ TABLENAME [WWWW] : Endif

      For [L]I = 1 To [L]NBRTAB
        Filter [F:WWWW]
        For [F:WWWW] Where evalue('[F:WWWW]CODATY = "'+[L]OLDDTARRAY(I)+'"')
          Assign '[F:WWWW]'+[L]DTCOLUMN(J) With [L]NEWDTARRAY(I)
          Rewrite [F:WWWW]
          If !fstat
            Call ECR_TRACE("EMHRMAJ90_DT: Successfully updated column:" + [L]DTCOLUMN(J) + ", on table:" + TABLENAME,0) From GESECRAN
          Else
            Call ECR_TRACE("EMHRMAJ90_DT: Could not update column:" + [L]DTCOLUMN(J) + ", on table:" + TABLENAME+". fstat = " + num$(fstat),0) From GESECRAN
          Endif
        Next
      Next

      Close Local File [F:WWWW]
    Else
      Call ECR_TRACE("EMHRMAJ90_DT: Table not found to update data type data: " - TABLENAME,0) From GESECRAN
    Endif
  Next
Return

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT90 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif
If [F:ADS]MODULE(14)<>2 : End : Endif
Call MAJ_EMHRMAJ90_DT(APPLI)
End

#######################################################################
# To execute during DOSMAJ90 process (validation of folder)
# call by DOSMAJ90
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(14)<>2 : End : Endif
Call MAJ_EMHRMAJ90_DT(APPLI)
End

