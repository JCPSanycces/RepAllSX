#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################
# UTITC06   Table TABBOMALT les désignations deviennent        Module TC #
#           traduisibles                                                 #
##########################################################################
# FGR 15/09/2009 : X3SUIVI57824
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  # Issue 108760 - 2015-08-07 by MAE :
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    # Issue 108760 - 2015-08-07 by MAE :
    #Read [ADS]DOSSIER=[L]DOSSIER
    #If fstat THEN
    #  Raz [F:ADS]
    #Endif
    If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTITC06(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC06(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Char WOBJET(GLONAOB)
Local Char WCHAINE(250)

  IERR = 0
  Call ECR_TRACE("UTITC06: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table TABBOMALT
  #
  If filinfo(filpath("FIL", "ATEXTRA", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".ATEXTRA" [AXX]
  #
  If filinfo(filpath("FIL", "TABBOMALT", "fde", SZAPPLI), 0) > 0 Then
    Local File =SZAPPLI + ".TABBOMALT" [TBO]
    If dim([F:TBO]TBODES) > 0 or dim([F:TBO]TBOSHO) > 0  Then
      Trbegin [TBO], [AXX]
      For [TBO]TBO0
        IUPDATE = 0
        If dim([F:TBO]TBODES) > 0 Then
          If [F:TBO]TBODES <> "" Then
            Call MAJTEXTRA([F:TBO]TBODES, "TABBOMALT", "TBODESAXX", num$([F:TBO]BOMALTTYP), num$([F:TBO]BOMALT)) From ATEXTRA
            If GOK < 1 Then
              Call ECR_TRACE("File ATEXTRA TABBOMALT-TBODESAXX" - num$([F:TBO]BOMALTTYP) - num$([F:TBO]BOMALT) + ",Error =" - num$(fstat), 1) From GESECRAN
              GOK = 1
              IERR = 1
              Break
            Endif
            IUPDATE = 1
            [F:TBO]TBODES = ""
          Else
            Call LECTEXTRA(WCHAINE, "TABBOMALT", "TBODESAXX", num$([F:TBO]BOMALTTYP), num$([F:TBO]BOMALT)) From ATEXTRA
            If WCHAINE = "" Then
              Call MAJTEXTRA(WCHAINE, "TABBOMALT", "TBODESAXX", num$([F:TBO]BOMALTTYP), num$([F:TBO]BOMALT)) From ATEXTRA
            Endif
          Endif
        Endif
        If dim([F:TBO]TBOSHO) > 0  Then
          If [F:TBO]TBOSHO <> "" Then
            Call MAJTEXTRA([F:TBO]TBOSHO, "TABBOMALT", "TBOSHOAXX", num$([F:TBO]BOMALTTYP), num$([F:TBO]BOMALT)) From ATEXTRA
            If GOK < 1 Then
              Call ECR_TRACE("File ATEXTRA TABBOMALT-TBOSHOAXX" - num$([F:TBO]BOMALTTYP) - num$([F:TBO]BOMALT) + ",Error =" - num$(fstat), 1) From GESECRAN
              GOK = 1
              IERR = 1
              Break
            Endif
            IUPDATE = 1
            [F:TBO]TBOSHO = ""
          Else
            Call LECTEXTRA(WCHAINE, "TABBOMALT", "TBOSHOAXX", num$([F:TBO]BOMALTTYP), num$([F:TBO]BOMALT)) From ATEXTRA
            If WCHAINE = "" Then
              Call MAJTEXTRA(WCHAINE, "TABBOMALT", "TBOSHOAXX", num$([F:TBO]BOMALTTYP), num$([F:TBO]BOMALT)) From ATEXTRA
            Endif
          Endif
        Endif
        If IUPDATE = 1 Then
          Rewrite [TBO]
        Endif
      Next
      If IERR = 0 Then
        Commit
      Else
        Rollback
      Endif
    Endif
    Close Local File [TBO]
  Endif
  Close Local File [AXX]
  #
  If IERR = 0 Then
    If clalev([F:AOB]) = 0 : Local File =SZAPPLI + ".AOBJET"  [AOB] : Endif
    WOBJET = "TBO"
    Read [AOB]ABREV=WOBJET
    If !fstat Then
      Call MAJ_SEL(SZAPPLI, WOBJET) From PATCHAOB
      #
      If [F:AOB]TYPGES <> 4 Then
        # Pas de fenêtre pour les browsers
        Call VALID("O" + WOBJET, SZAPPLI, 1, IERR) From VALWIN
        If IERR <> 1 Then
          Call ECR_TRACE("Erreur revalidation fenêtre O" + WOBJET, 1) From GESECRAN
        Endif
      Endif
      #
      Call VALID (WOBJET, SZAPPLI, 1, IERR) From VALOBJ
      If IERR <> 1 Then
        Call ECR_TRACE("Erreur revalidation objet" - WOBJET, 1) From GESECRAN
      Endif
    Endif
  Endif
  #
  Call ECR_TRACE("UTITC06 : records processed", 0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  #Read [ADS]DOSSIER=APPLI
  #If fstat THEN
  #  Raz [F:ADS]
  #Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"TABBOMALT") : End : Endif
  Call MAJ_UTITC06(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If func DOSVUE.ISVIEW(APPLI,"TABBOMALT") : End : Endif
  Call MAJ_UTITC06(APPLI)
End

