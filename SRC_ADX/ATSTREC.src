#<AdxTL>@(#)9.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ATSTREC","ATSTREC",3,"") From GTRAITE
End

#----------------------------------------#
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "CONTROLE"    : Gosub CONTROLE
 When "TERMINE"     : Gosub TERMINE
Endcase
Return

#----------------------------------------#
$INIT
Return

#----------------------------------------#
$INIT_DIA
Raz [M:ATST]
[M:ATST]DOSSIER = nomap
If GUSER="MB"
 [M:ATST]TYPEXP = 2
 [M:ATST]VOLFIL = "[TMP]/atstsav.txt"
Endif
Return

#----------------------------------------#
$CONTROLE
Local Integer STAT , TRACE , NBCOP , OKCTL , OGSERVEUR
Local Char    FICPAT(255) , URL(50) , FICCLI(255) , TEXTE(200) , MESSAGE(200) , USR(GLONAUS)
Local Date    DATDEB , DATFIN
Local Char    TBCOP(GLONATB)(1..1000) , DOSPAT(GLONADS)
FICPAT = [M:ATST]FICPAT
Call TEMPON("L") From GESECRAN
If [M:ATST]TYPEXP=1
 FICCLI = [M:ATST]FICPAT
 Call SET_FICNAM(FICCLI,FICPAT,URL) From ORDSYS
 Call COPSRV(FICCLI,FICPAT,STAT) From ORDSYS
 If STAT : FIN = 1 : Return : Endif
Else
 FICCLI = ""
Endif
[L]TRACE = ([M:ATST]TRACE=2)
Call PARAM([L]FICPAT,[L]DOSPAT,[L]DATDEB,[L]DATFIN,[L]USR,[L]NBCOP,[L]TBCOP,[L]MESSAGE)
Call TEMPOFF From GESECRAN
If MESSAGE<>""
 Call ERREUR(MESSAGE) From GESECRAN
 FIN = 1 : Return
Endif
If [L]USR<>GUSER
 # Vous devez vous connecter "$1$" pour intégrer ce patch
 Call ERREUR(func AFNC.MES1(mess(253,115,1),[L]USR)) From GESECRAN
 FIN = 1 : Return
Endif
# Intégration des enregistrements créés par $1$ dans $4$ du $2$ au $3$
OK = 1
Call OUINON(func AFNC.MES4(mess(247,115,1),[L]USR,format$(GFMD,DATDEB),format$(GFMD,DATFIN),[L]DOSPAT),OK) From GESECRAN
If OK<>2 : FIN = 1 : Return : Endif
OKCTL = ([M:ATST]CTLLNK=2)
Return

#----------------------------------------#
$EXEC
If !GSERVEUR
 Call TEMPON("V") From GESECRAN
 # Récupération des données stables
 Call OUVRE_TRACE(mess(252,115,1)) From LECFIC
Endif

Call ECR_TRACE(func AFNC.MES3(mess(248,115,1),[L]USR,format$(GFMD,[L]DATDEB),format$(GFMD,[L]DATFIN)),0) From GESECRAN
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Call RAZDON([M:ATST]DOSSIER,[L]DATDEB,[L]DATFIN,[L]USR,NBCOP,TBCOP,[L]TRACE)
Call ECR_TRACE(func AFNC.MES4(mess(247,115,1),[L]USR,format$(GFMD,DATDEB),format$(GFMD,DATFIN),[L]DOSPAT),0) From GESECRAN
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN

If !GSERVEUR :  # 112386  issue about Trace in patch
 GSERVEUR=1
 Call PATCH(FICPAT,FICCLI,2,1,[M:ATST]DOSSIER,TEXTE) From PATCH
 GSERVEUR=0
Else
 Call PATCH(FICPAT,FICCLI,2,1,[M:ATST]DOSSIER,TEXTE) From PATCH
Endif

If OKCTL
 # Contrôle des liens
 Call ECR_TRACE(mess(71,125,1),0) From GESECRAN
 Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
 Call CONTROL_LINKS([M:ATST]DOSSIER,1,NBCOP,TBCOP) From ADOSCOPDAT
Endif


If !GSERVEUR
 Call FERME_TRACE From LECFIC
 Call TEMPOFF From GESECRAN
Endif

Return

#----------------------#
$TERMINE
If [L]TRACE=1
 TRA = 1
Endif
Return

#-------------------------------------------------------------------------#
Subprog  PARAM(FICPAT,DOSPAT,DATDEB,DATFIN,USR,NBCOP,TBCOP,MESSAGE)
Value    Char FICPAT
Variable Char DOSPAT
Variable Date DATDEB , DATFIN
Variable Char USR
Variable Integer NBCOP
Variable Char    TBCOP()(1..)
Variable Char    MESSAGE
Local Char    CHAMP(255)(1..50)
Local Integer I , K , L , M , TYPENR
Local Integer TYPENR , NB , NOCT , SAVIUM
Local Libelle BUFFER(1..1000)
Local Char    CHAINE(80) , SAVIFS(2) , SAVIRS(2)
Local Blbfile BLOB(10)
If clalev([F:ATB2])=0 : Local File ATABLE [ATB2] : Endif
If FICPAT=""
 # Fichier inexistant
 MESSAGE = mess(101,100,1)
 End
Endif
NBCOP = 0
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = ","
adxirs = chr$(10)
adxium = GUTF8
Openi FICPAT
Raz CHAMP, TYPENR
Rdseq TYPENR,CHAMP
While fstat=0 & TYPENR<>8
 If NBCOP>=dim(TBCOP)
  Call ERREUR(mess(26,100,1)) From GESECRAN : # Tableau plein
  Break
 Endif
 Case TYPENR
  When 1 : # Entête
   Call DELIMITE(CHAMP) From PATCH
   If fstat or TYPENR<>1
    # Critères indéterminés
    MESSAGE = mess(245,115,1)
    Break
   Endif
   COMMENT = CHAMP(1)
   K = instr(1,COMMENT," + ")
   If K
    L = instr(K+1,COMMENT," + ")
    If L
     M =  instr(L+1,COMMENT," + ")
     If M
      [L]DOSPAT = left$(COMMENT,K-1)
      CHAINE = seg$(COMMENT,K+3,L-1)
      [L]DATDEB = right$(CHAINE,7)+mid$(CHAINE,4,2)+left$(CHAINE,2)
      CHAINE = seg$(COMMENT,L+3,M-1)
      [L]DATFIN = right$(CHAINE,7)+mid$(CHAINE,4,2)+left$(CHAINE,2)
      [L]USR = right$(COMMENT,M+3)
     Endif
    Endif
   Endif
   If !K or !L or !M
    # Critères indéterminés
    MESSAGE = mess(245,115,1)
    Break
   Endif
   If [L]USR=""
    # Utilisateur impossible à définir
    MESSAGE = mess(246,115,1)
    Break
   Endif
  When 2
   If left$(ctrans(CHAMP(1),'"',''),1)='~'
    Read [ATB2]ABRFIC=right$(ctrans(CHAMP(1),'"',''),2)
    If !fstat & !find([F:ATB2]CODFIC,TBCOP(1..NBCOP))
     NBCOP += 1
     TBCOP(NBCOP) = [F:ATB2]CODFIC
    Endif
   Endif
   If find(CHAMP(1),"TRT")
    Repeat
     Rdseq CHAMP(1)
    Until fstat or CHAMP(1)=string$(10,"*")
   Elsif find(CHAMP(1),"ADX","ELT","BIA","ELX")
    Gosub CH_FIC
   Elsif CHAMP(1)="ETA"
    Gosub CH_ETA
   Elsif CHAMP(1)="TAB"
    Repeat
     Raz CHAMP, TYPENR
     Rdseq TYPENR,CHAMP
     If TYPENR=3
      Gosub CH_FIC
     Endif
    Until TYPENR<>3
   Endif
  When 22,24,23,25 : # Blob , Clob
   Rdseq NOCT
   If find(TYPENR,24,25)
    Getseq 1,BLOB Sized NOCT
   Else
    Repeat
     NB = dim(BUFFER)
     If NOCT>NB
      Getseq NB , BUFFER
      NOCT -= NB
     Else
      Getseq NOCT , BUFFER
      NOCT = 0
     Endif
    Until NOCT=0
   Endif
   Repeat
    Rdseq CHAINE
   Until fstat or CHAINE=string$(10,"*")
   If fstat
    Break
   Endif
 Endcase
 Raz CHAMP, TYPENR
 Rdseq TYPENR,CHAMP
Wend
Openi
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
End

#--------------------#
$CH_ETA
Repeat
 Rdseq TYPENR,CHAMP
 If TYPENR=3
  Gosub CH_FIC
 Endif
Until TYPENR=7 or fstat
Return

#-------------#
$CH_FIC
Rdseq NOCT
Repeat
 NB = dim(BUFFER)
 If NOCT>NB
  Getseq NB , BUFFER
  NOCT -= NB
 Else
  Getseq NOCT , BUFFER
  NOCT = 0
 Endif
Until NOCT=0
Repeat
 Rdseq CHAINE
Until fstat or CHAINE=string$(10,"*")
Return

#----------------------------------------------------------------#
Subprog RAZDON(DOSSIER,DATDEB,DATFIN,USR,NBCOP,TBCOP,TRACE)
Value Char    DOSSIER
Value Date    DATDEB
Value Date    DATFIN
Value Char    USR
Value Integer TRACE
Value Integer NBCOP
Value Char    TBCOP()(1..)

Local Integer  ER , NBREPU
Local Datetime DATTIM1 , DATTIM2
Local Char     CRITERE(250) , CHAINE(250)
Local Char     ABROBJ(10) , CLEOBJ(255) , INTOBJ(80) , ME(80)

If DOSSIER="" : DOSSIER = nomap : Endif

Local File ADOSSIER [ADS]
Read [ADS]DOSSIER=DOSSIER
If fstat : End : Endif

If DOSSIER=nomap
 Local File ATABLE [ATB] , ATABLE [ATB2], ATABZON [ATZ2]
Else
 Local File =DOSSIER+".ATABLE" [ATB] , =DOSSIER+".ATABLE" [ATB2] , =DOSSIER+".ATABZON" [ATZ2]
Endif

DATTIM1  = gdatetime$(format$("D:YYYY[-]MM[-]DD",DATDEB))
DATTIM2  = gdatetime$(format$("D:YYYY[-]MM[-]DD",DATFIN+1))
CRITERE  = '(CREDATTIM>=gdatetime$("'+num$(DATTIM1)+'")&CREDATTIM<=gdatetime$("'+num$(DATTIM2)+'"))'
CRITERE += '&CREUSR="'+USR+'"'

Gosub SET_TABLE From ATRIFIL

For [ATB2] Where TYPFIC<>3
 If !find([F:ATB2]CODFIC,[L]TB_VIR(1..[L]NB_VIR)) & find([F:ATB2]CODFIC,TBCOP(1..NBCOP))
  [L]ABROBJ = [F:ATB2]ABRFIC
  [L]CLEOBJ = CRITERE
  Gosub DIVERS
 Endif
Next ATB2

End

#----------------------------------------#
$DIVERS
ER = 0
Onerrgo ERRFIC
Read [ATB]ABRFIC = ABROBJ
If !fstat
 #114186
 Read [ATZ2]CODZONE=[F:ATB]CODFIC;"CREDATTIM"
 If fstat
  # Table non gérée
  ER=1
 Elsif [F:ATZ2]NUMLIG>254
  # Table non gérée
  ER=2
 Endif
 If !ER
  Read [ATZ2]CODZONE=[F:ATB]CODFIC;"CREUSR"
  If fstat
   # Table non gérée
   ER=1
  Elsif [F:ATZ2]NUMLIG>254
   # Table non gérée
   ER=2
  Endif
 Endif
 If !ER
  Local File =DOSSIER+"."+[F:ATB]CODFIC [DIV]
  If ER
   # Erreur d'accès sur un fichier
  Elsif dim([F:DIV]CREDATTIM)<=0 or dim([F:DIV]CREUSR)<=0
   # Horodatage non géré
   Close Local File [DIV]
  Else
   FICHIER = [F:ATB]CODFIC
   Gosub EPURE
   If ER
    # Table
    Call TRACE(mess(56,123,1)-[F:ATB]CODFIC-":"-ME-errmes$(ER),1) From GESECRAN
   Endif
   Close Local File [DIV]
  Endif
 Elsif ER=2 & TRACE
   # 114186 Table non gérée
   Call ECR_TRACE(mess(93,123,1)-":"-mess(251,115,1)-[F:ATB]CODFIC,-1) From GESECRAN
 Endif
Endif
Onerrgo
Return

#------------------#
$ERRFIC
ER = errn
ME = errm
Resume

#----------------------------------------#
$EPURE
[L]NBREPU = 0
Trbegin [DIV]
 For [F] Where evalue([L]CLEOBJ)
  [L]NBREPU += 1
  Delete [F] Curr
 Next
 If TRACE & [L]NBREPU
  # Epuration de la table
  Call ECR_TRACE(mess(30,133,1)-[F:ATB]CODFIC-":"-num$([L]NBREPU),0) From GESECRAN
 Endif
Commit
Return

#----------------------------------------#
Subprog AS_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [M]VOLFIL, [M]FICPAT
 Grizo [M]VOLFIL
Else
 Actzo [M]VOLFIL
Endif
End

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat = 2 : End
Endif
If VALEUR=1
 Raz [M]VOLFIL, [M]FICPAT
 Grizo [M]VOLFIL
Else
 Actzo [M]VOLFIL
Endif
Affzo [M]VOLFIL
End

Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
If [M]TYPEXP=2
 ASTATUS = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FICPAT,E_TYPE_FOLDER,GMESSAGE)
 If ASTATUS<>CST_AOK
  ASTATUS = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FICPAT,E_TYPE_FILEREAD,GMESSAGE)
  If ASTATUS<>CST_AOK : mkstat = 1 : End : Endif
 Endif
Else
 ASTATUS = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FICPAT,E_TYPE_FILEREAD,GMESSAGE)
 If ASTATUS<>CST_AOK : mkstat = 1 : End : Endif
Endif
End

