   Endif
  Endif
 Next 
Endif

##########################################################################
# Initialisation Standard
#  - Imputation Taxe : "DEDUCTIBLE" pour les comptes 4456
#  - Imputation Taxe : "COLLECTEE" pour les comptes 4457
##########################################################################
Filter [GAC] Where COA=[L]COAGEN

Update [GAC] Where FLGVAT>1 & VATIPT=0 & left$([F:GAC]ACC,4)="4456" With VATIPT=3
If fstat : Gosub ERR_TVA : Endif

Update [GAC] Where FLGVAT>1 & VATIPT=0 & left$([F:GAC]ACC,4)="4457" With VATIPT=1
If fstat : Gosub ERR_TVA : Endif

##########################################################################
# Information avant initialisation "forcé"
##########################################################################
If TEST=1
 Local Integer NBT,NBR,NBN
 Raz NBT,NBR,NBN
 For [GAC] Where COA=[L]COAGEN & FLGVAT>1
  # Compte ... : Imputation "Collectée"
  If [F:GAC]VATIPT=0 : Call ECR_TRACE(mess(30,105,1)-[F:GAC]ACC-":"-mess(23,117,1)-mess(1,609,1),0) From GESECRAN : Endif
  NBT+=1
  If [F:GAC]VAT<>"" 
   NBR+=1
  Else 
   # Compte ... : Taxe...
   Call ECR_TRACE(mess(30,105,1)-[F:GAC]ACC-mess(39,105,1)-"GEXETAX",0) From GESECRAN
   NBN+=1
  Endif
 Next
 Call ECR_TRACE("Compte soumis : "-num$(NBT)-"* Initialisation Intégrale "-num$(NBR)-"* initialisation GEXETAX "-num$(NBN),0) From GESECRAN
Endif 

##########################################################################
# Initialisation "forcé"
#  - Imputation => "COLLECTEE"
#  - Taxe       =>  GEXETAX
##########################################################################
Update [GAC] Where FLGVAT>1 & [F:GAC]VATIPT=0 With [F:GAC]VATIPT=1
If fstat : Gosub ERR_TVA : Endif

Update [GAC] Where FLGVAT>1 & [F:GAC]VAT="" With [F:GAC]VAT=GEXETAX
If fstat : Gosub ERR_TVA : Endif

$AB_TVA
If GOK>0
 If SI_SIMU<>2
  Commit
 Else
  Rollback
 Endif
Else
 Rollback
Endif

Filter [GAC]
Call TEMPOFF From GESECRAN
End

$ERR_TVA
# Compte : Erreur de réecriture 
Call ECR_TRACE(mess(45,102,1)-mess(27,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
GOK = 0
Return









