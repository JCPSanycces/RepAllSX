#<AdxTL>@(#)0.0.0.0 $Revision$

End 
######################################################################################
#  SIXGAC : pour traitements de bascule Integrale --> X3                             #
######################################################################################
#                                                                                    #
# Subprog SIXGAC                                                                     #
#     Plan de comptes sera livrées vie le dossier de référence                       #
#      1ère passe pour supprimer les comptes normaux/collectifs inutilisée           #
#      2ème passe pour créer ou mettre à jour les comptes                            #                        
#                                                                                    #
#     Création des natures comptables (si compte est suivi en analytique)            #
#                                                                                    #
#                                                                                    #
#                                                                                    #
#     Création des comptes auxiliaires en tant que TIERS DIVERS                      #
#         (Avec MAJ Adresses et RIB)                                                 #
#                                                                                    #
#                                                                                    #
# ---------------------------------------------------------------------------------- #
# PRE-REQUIS :                                                                       #
# ---------------------------------------------------------------------------------- #
#                                                                                    #
#     1 - Migrations précédentes : TIERS                                                 #
#                                                                                    #
#####################################################################################

# Supp...
If !clalev([F:BPA])  : Local File BPADDRESS  [BPA] : Endif   # Adresses
If !clalev([F:BID])  : Local File BID        [BID] : Endif   # Relevé Identité Bancaire
If !clalev([F:GAC])  : Local File GACCOUNT   [GAC] : Endif   # Compte
If !clalev([F:BPR])  : Local File BPARTNER   [BPR] : Endif   # Tiers

If !clalev([F:XPCG]) : Local File XIPLACBGNR [XPCG] : Endif  # Comptes généraux Intégrale
If !clalev([F:XPCA]) : Local File XIPLACBAUX [XPCA] : Endif  # Comptes auxiliaires

Trbegin [BPA], [BID], [GAC],  [XPCG]
#Delete [GAC] Where 1=1
#Delete [BID] Where BPATYP=1 & CREUSR="CPECH"
#Delete [BPA] Where BPATYP=1 & CREUSR="CPECH"
#Delete [BPR] Where CREUSR="CPECH"
Update [XPCG] Where 1=1 With FLGREP=1
Update [XPCA] Where 1=1 With FLGREP=1
Update [GAC] Where 1=1 With [F:GAC]VATIPT=0 , [F:GAC]VAT=""
Commit 
# Fin Supp
End
Gosub SI_CONTEXT From SIXFONCTION
Global Integer X_NB
Call OUVRE_BOITE("XIPLACBGNR",nbrecord([XPCG])+nbrecord([XPCA])) From GESECRAN
Raz X_NB
Call EXEC
Call FERME_BOITE From GESECRAN
Kill X_NB

End
#########################################################################
Subprog EXEC

Local Integer WOUV_TRACE
If GTRACE = ""
 Call OUVRE_TRACE("SIXGAC : Process translation file from INTEGRALE to X3") From LECFIC
 WOUV_TRACE=1
Endif

Onerrgo TRT_ERR

#----  Migration des comptes : GACCOUNT ------#
Call ECR_TIME("SIXGAC : "+SI_MES(50)+" GACCOUNT") From DOSSUB

#---- Préparation du plan de compte
Call INIT
If GOK<>1 : Goto FIN_GAC : Endif

#---- Appartir des "Comptes Généraux" de l'Intégrale
Call SI_GACCOUNT_GE
If GOK<>1 : Goto FIN_GAC : Endif

#---- Initialisation des la TVA
Call INI_TVA
If GOK<>1 : Goto FIN_GAC : Endif

#---- Appartir des "Auxilaires Divers" de l'Intégrale ... => Création de TIERS DIVERS
Call SI_GACCOUNT_AX
If GOK<>1 : Goto FIN_GAC : Endif

#---- Mise à jour des codes comptables et des paramètres
Call EXEC From SIXCAC

If GOK<>1 : Goto FIN_GAC : Endif

$FIN_GAC
Onerrgo 
If WOUV_TRACE=1
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

$TRT_ERR
Call ECR_TRACE(errp-"("-num$(errl)-") :"-errmes$(errn)-errm, 1) From GESECRAN
Resume

#########################################################################
# Préparation du plan de compte
#########################################################################
Subprog INIT
Local Integer I

If clalev([F:GAC])  : Close Local File [GAC]  : Endif   # Comptes

If !clalev([F:COA])  : Local File =SI_DOSSIER+".GCOA"       [COA]  : Endif   # Comptes
If !clalev([F:GAC])  : Local File =SI_DOSSIER+".GACCOUNT"   [GAC]  : Endif   # Comptes
If !clalev([F:GAC2]) : Local File =SI_DOSSIER+".GACCOUNT"   [GAC2] : Endif   # Comptes
If !clalev([F:GAC3]) : Local File =SI_DOSSIER+".GACCOUNT"   [GAC3] : Endif   # Comptes

If !clalev([F:SPX])  : Local File =SI_DOSSIER+".SIPARX3"    [SPX]  : Endif   # Paramétrage Migration Intégrale 
Read [SPX] First

Local Char    COAGEN(GLONCOA), COAANA(GLONCOA)

Call LEC_COA(1,[F:SPX]CPY,[L]COAGEN) From SIXCPY
Call LEC_COA(2,[F:SPX]CPY,[L]COAANA) From SIXCPY

Call DEBTRANS From GLOCK
Trbegin [GAC]

#--- Adaptation de la longueur des comptes - code plan générale principale
Read [COA]COA0 = [L]COAGEN
#If [F:COA]FXDLEN = 2 #DdM58676
# Filter [GAC] Where COA=[L]COAGEN & len([F:GAC]ACC)<>[F:COA]ACCLEN
 Filter [GAC] Where COA=[L]COAGEN & len([F:GAC]ACC)<>GLONGAC
 For [GAC]
  [F:GAC2] = [F:GAC]
  [F:GAC2]ACC = left$([F:GAC]ACC+string$(GLONGAC,"0"),GLONGAC)

  Raz [F:GAC2]OTHCOA
  Raz [F:GAC2]DEFACC
  Raz [F:GAC2]SCRACC
  Raz [F:GAC2]OBYIPT
  Raz [F:GAC2]COANBR

  Read [GAC3]GAC0 = [L]COAGEN;[F:GAC2]ACC
  If fstat
   Write [GAC2]
   If fstat
    # Erreur d'écriture
    Call ECR_TRACE("GACCOUNT"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
    GOK = 0 : Goto FIN_INIT
   Endif
   Call DUPTEXTRA("GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC,"GACCOUNT","DESTRA",[F:GAC2]COA,[F:GAC2]ACC)  From ATEXTRA
   Call DUPTEXTRA("GACCOUNT","SHOTRA",[F:GAC]COA,[F:GAC]ACC,"GACCOUNT","SHOTRA",[F:GAC2]COA,[F:GAC2]ACC)  From ATEXTRA
  Endif
  Call SUPTEXTRA("GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
  Call SUPTEXTRA("GACCOUNT","SHOTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
  Delete [GAC] Curr
  If fstat
   # Erreur d'écriture
   Call ECR_TRACE("GACCOUNT - ACCLEN"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
   GOK = 0 : Goto FIN_INIT
  Endif
 Next
 Filter [GAC]
#Endif

#--- Adaptation de la longueur des comptes - code plan analytique principale
Read [COA]COA0 = [L]COAANA
#If [F:COA]FXDLEN = 2 #DdM58676
# Filter [GAC] Where COA=[L]COAANA & len([F:GAC]ACC)<>[F:COA]ACCLEN
 Filter [GAC] Where COA=[L]COAANA & len([F:GAC]ACC)<>GLONGAC

 For [GAC]
  [F:GAC2] = [F:GAC]
  [F:GAC2]ACC = left$([F:GAC]ACC+string$(GLONGAC,"0"),GLONGAC)
  Read [GAC3]GAC0 = [L]COAANA;[F:GAC2]ACC
  If fstat
   Write [GAC2]
   If fstat
    # Erreur d'écriture
    Call ECR_TRACE("GACCOUNT"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
    GOK = 0 : Goto FIN_INIT
   Endif
   Call DUPTEXTRA("GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC,"GACCOUNT","DESTRA",[F:GAC2]COA,[F:GAC2]ACC)  From ATEXTRA
   Call DUPTEXTRA("GACCOUNT","SHOTRA",[F:GAC]COA,[F:GAC]ACC,"GACCOUNT","SHOTRA",[F:GAC2]COA,[F:GAC2]ACC)  From ATEXTRA
  Endif
  Call SUPTEXTRA("GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
  Call SUPTEXTRA("GACCOUNT","SHOTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
  Delete [GAC] Curr
  If fstat
   # Erreur d'écriture
   Call ECR_TRACE("GACCOUNT - ACCLEN"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
   GOK = 0 : Goto FIN_INIT
  Endif
 Next
 Filter [GAC]
#Endif

#--- Suppression des codes d'appel
Update [GAC] With ACCSHO=""
If fstat
 # Erreur d'écriture
 Call ECR_TRACE("GACCOUNT - ACCSHO"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0 : Goto FIN_INIT
Endif

$FIN_INIT
If GOK>0
 #Demande 43756 : Pas de condition selon le flag "simulation"
 Commit
Else
 Rollback
Endif

If clalev([F:GAC])  : Close Local File [GAC]  : Endif   # Comptes
End

#########################################################################
# Création des comptes généraux
#########################################################################
Subprog SI_GACCOUNT_GE

Local Integer STOP, NB, LEXI, NBRAXE
Local Char LRERPISE(50), WACC(GLONGAC)

Local Integer SAC_BPC : Raz SAC_BPC       # Indicateur du nombre de collectif client
Local Integer SAC_BPS : Raz SAC_BPS       # Indicateur du nombre de collectif fournisseur
Local Integer SAC_DIV : Raz SAC_DIV       # Indicateur du nombre de collectif tiers divers

Local Char    COASTD(GLONCOA),COAGEN(GLONCOA), COAANA(GLONCOA), BIDON(GLONCAC)

If !clalev([F:XPCG]) : Local File =SI_DOSSIER+".XIPLACBGNR" [XPCG] : Endif   # Comptes généraux

If !clalev([F:COA])  : Local File =SI_DOSSIER+".GCOA"       [COA]  : Endif   # Code plan
If !clalev([F:CLS])  : Local File =SI_DOSSIER+".GACCCLS"    [CLS]  : Endif   # Classes de comptes

If !clalev([F:GAC])  : Local File =SI_DOSSIER+".GACCOUNT"   [GAC]  : Endif   # Comptes
If !clalev([F:GA2])  : Local File =SI_DOSSIER+".GACCOUNT"   [GA2]  : Endif   # Comptes
If !clalev([F:CAC])  : Local File =SI_DOSSIER+".GACCCODE"   [CAC]  : Endif   # Codes comptables
If !clalev([F:TUN])  : Local File =SI_DOSSIER+".TABUNIT"    [TUN]  : Endif   # Unités d'oeuvres
If !clalev([F:AXX])  : Local File =SI_DOSSIER+".ATEXTRA"    [AXX]  : Endif   # Textes traduisibles

If !clalev([F:SPX])  : Local File =SI_DOSSIER+".SIPARX3"    [SPX]  : Endif   # Paramétrage Migration Intégrale 
Read [SPX] First

Call LEC_COA(1,[F:SPX]CPY,[L]COAGEN) From SIXCPY
Call LEC_COA(2,[F:SPX]CPY,[L]COAANA) From SIXCPY

If [F:SPX]OPTANA=2 : Gosub DELETE_GAC : Endif
Call NBAXE(NBRAXE) From SIXCCE

SI_SUBPRG = "SIXGAC"
SI_TABLE  = "XIPLACBGNR"
Gosub SI_CRITSUP From SIXFONCTION

$LOOP_GAC_GE
Raz NB

If STOP=1
 CRITERE = "CPTGNR>'"+LREPRISE+"'"
 STOP=0
Else
 CRITERE="1=1"
Endif

Call DEBTRANS From GLOCK
Trbegin [GAC], [XPCG]

# Traitement des comptes généraux
For [XPCG] Where left$(CPTGNR,2)<>"$$" and FLGREP<>2
&             & evalue(CRITERE)
&             & evalue(SI_CRITERE)
 
 GOK = 1
 Call AFFBOITE([F:XPCG]CPTGNR) From SUBSIM

 # creation Compte Général (GACCOUNT)
 Read [COA]COA0 = [L]COAGEN
 Call INIACCFMT([F:COA]COA) From SETGLBCOA
 [L]COASTD = [L]COAGEN : Gosub CRE_GAC_GEN
 If GOK<=0 : Break :  Endif

 # creation Compte Analytique (GACCOUNT)
 If [XPCG]VTLANA="O" & [L]COAANA<>"" & [L]COAGEN<>[L]COAANA 
  Read [COA]COA0 = [L]COAANA
  Call INIACCFMT([F:COA]COA) From SETGLBCOA
  [L]COASTD = [L]COAANA : Gosub CRE_GAC_GEN
  If GOK<=0 : Break :  Endif
 Endif

 Readlock [XPCG] Curr
 [F:XPCG]FLGREP = 2
 Rewrite [XPCG]

 # NB alimenté dans CRE_GAC
 If NB>1000
  LREPRISE = [F:XPCG]CPTGNR
  STOP     = 1
  Break
 Endif
Next

#--- Mise à jour des codes d'appel
Filter [GAC] Where COA=[L]COAGEN & SAC=2 & ACCSHO=""
For [GAC]
 Readlock [GAC] Curr

 If [F:GAC]AUZBPR(0) = 2
  SAC_BPC+=1
  [F:GAC]ACCSHO = "C"+num$(SAC_BPC)
 Elsif [F:GAC]AUZBPR(1) = 2
  SAC_BPS+=1
  [F:GAC]ACCSHO = "F"+num$(SAC_BPS)
 Else
  SAC_DIV+=1
  [F:GAC]ACCSHO = "O"+num$(SAC_DIV)
 Endif
 Rewrite [GAC]
 If fstat
  # Compte... : ... (...) Erreur d'écriture 
  Call ECR_TRACE(mess(45,102,1)-[F:GAC]ACC-"/"-[F:GAC]ACCSHO-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0 : Break
 Endif
Next
Filter [GAC]

If GOK>0
 If SI_SIMU<>2
  Commit
 Else
  Rollback
 Endif
 If STOP
  Goto LOOP_GAC_GE
 Endif
Else
 Rollback
Endif
End

##################################################################
$CRE_GAC_GEN
# recuperation et controle code compte
If !func SIXFONCTION.SI_CTL("ACC",[F:XPCG]X3CLE,"XIPLACBGNR ("+[F:XPCG]CPTGNR+")")
 GOK=0 : Return
Else
 Raz LEXI
 Read [GAC]GAC0 = [L]COASTD;[F:XPCG]X3CLE
 If fstat
  # Gestion du complément à zéro
  # Option 1 : le compte Intégrale est inférieur au compte X3
  WACC = [F:XPCG]X3CLE
  For J=len(WACC) To GLONGAC
   WACC +="0"
   Read [F:GAC]GAC0 = [L]COASTD;WACC
   If !fstat : LEXI=1 : Break : Endif
  Next
  # Option 2 : le compte X3 est inférieur au compte Intégrale
  If !LEXI
   WACC = [F:XPCG]X3CLE
   For J=len(WACC) To 1 Step -1
    If right$(WACC,len(WACC))="0"
     WACC = left$(WACC,len(WACC)-1) 
     Read [F:GAC]GAC0 = [L]COASTD;WACC
     If !fstat : LEXI=1 : Break : Endif
    Endif
   Next
  Endif
  If !LEXI
   Raz [GAC]
   [F:GAC]COA = [L]COASTD
   [F:GAC]ACC = [F:XPCG]X3CLE
  Else
   If [F:COA]FXDLEN = 2
    WACC = left$(WACC+string$(GLONGAC,"0"),GLONGAC)
    [F:GAC]ACC=WACC
   Endif
  Endif
 Else
  WACC=[F:XPCG]X3CLE
  If [F:COA]FXDLEN = 2
   WACC = left$(WACC+string$(GLONGAC,"0"),GLONGAC)
  Endif
  [F:GAC]ACC = WACC
  LEXI = 1
 Endif
Endif

[F:GAC]ENAFLG=2

# Type de compte : Normal ou Collectif
#------------------------------------------------- Q : Pas de compte de Type CUMUL ? Que signifie "O" = Divers ?
#------------------------------------------------- Attribution du code d'appel
For I=0 To dim([F:GAC]AUZBPR)-1
 [F:GAC]AUZBPR(I) = 1
Next

Case [XPCG]TYPCLF
 When "N"
  [F:GAC]SAC = 1
  Raz [F:GAC]ACCSHO
 When "C"
  [F:GAC]SAC = 2
  [F:GAC]AUZBPR(0) = 2
  [F:GAC]AUZBPR(5) = 2
  SAC_BPC+=1
  [F:GAC]ACCSHO = "C"+num$(SAC_BPC)
 When "F"
  [F:GAC]SAC = 2
  [F:GAC]AUZBPR(1) = 2
  [F:GAC]AUZBPR(5) = 2
  SAC_BPS+=1
  [F:GAC]ACCSHO = "F"+num$(SAC_BPS)
 When "O"
  [F:GAC]SAC = 2
  [F:GAC]AUZBPR(5) = 2
  SAC_DIV+=1
  [F:GAC]ACCSHO = "O"+num$(SAC_DIV)
Endcase

# Intitulé de compte
#-------------------------------------------------
[F:GAC]DESSHO = [F:XPCG]LIBAPL
[F:GAC]DES    = [F:XPCG]ITTCPT
Call MAJTEXTRA([F:GAC]DES,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
Call MAJTEXTRA([F:GAC]DESSHO,"GACCOUNT","SHOTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA

# Classe par défaut
#-------------------------------------------------
Call CLASSE([F:GAC]COA,[F:GAC]ACC,BIDON) From SUBGAC
[F:GAC]CLSCOD = BIDON

# Flags
#-------------------------------------------------
If [XPCG]GESLTR = "O" : [F:GAC]MTC=2 : Endif  # Lettrage

# Gestion de TVA
#------------------------------------------------- Q : TVA CCE et Acompte ???
If [F:COA]TAXMGT=2
 Case [XPCG]TYPCPT
  When "H"     : [F:GAC]FLGVAT = 2 :  # Soumis
  When "V"     : [F:GAC]FLGVAT = 3 :  # TVA
  When Default : [F:GAC]FLGVAT = 1 :  # Non soumis
 Endcase
Endif

# Pour le reste de l'initialisation (Type d'imputation de taxe et Code Taxe), cf sous programme INI_TVA
#--------------------------------------------------------------------------------------------------------

# Compte suivi Analytiquement
#-------------------------------------------------
Case [L]COASTD
 When [L]COAGEN
  If [L]COAGEN<>[L]COAANA
   I = find([L]COAANA,[F:GAC]OTHCOA(0..[F:GAC]COANBR))
   If [XPCG]VTLANA="O"
    If !I
     [F:GAC]OTHCOA([F:GAC]COANBR) = [L]COAANA
     [F:GAC]DEFACC([F:GAC]COANBR) = [F:GAC]ACC
     [F:GAC]SCRACC([F:GAC]COANBR) = [F:GAC]ACC
     [F:GAC]OBYIPT([F:GAC]COANBR) = 2
     [F:GAC]COANBR += 1
    Else
     [F:GAC]DEFACC(I-1) = [F:GAC]ACC
     [F:GAC]SCRACC(I-1) = [F:GAC]ACC
     [F:GAC]OBYIPT(I-1) = 2
    Endif
   Else
    If I
     [F:GAC]OTHCOA(I-1) = [F:GAC]OTHCOA([F:GAC]COANBR-1)
     [F:GAC]DEFACC(I-1) = [F:GAC]DEFACC([F:GAC]COANBR-1)
     [F:GAC]SCRACC(I-1) = [F:GAC]SCRACC([F:GAC]COANBR-1)
     [F:GAC]OBYIPT(I-1) = [F:GAC]OBYIPT([F:GAC]COANBR-1)
     [F:GAC]COANBR-=1
     Raz [F:GAC]OTHCOA([F:GAC]COANBR)
     Raz [F:GAC]DEFACC([F:GAC]COANBR)
     Raz [F:GAC]SCRACC([F:GAC]COANBR)
     Raz [F:GAC]OBYIPT([F:GAC]COANBR)
    Endif
   Endif
  Endif
  If [L]COAGEN=[L]COAANA & [XPCG]VTLANA="O"
   Gosub INI_CNA
  Endif
 When [L]COAANA
  I = find([L]COAGEN,[F:GAC]OTHCOA(0..[F:GAC]COANBR))
  If !I
   [F:GAC]OTHCOA([F:GAC]COANBR) = [L]COAGEN
   [F:GAC]DEFACC([F:GAC]COANBR) = [F:GAC]ACC
   [F:GAC]SCRACC([F:GAC]COANBR) = [F:GAC]ACC
   [F:GAC]OBYIPT([F:GAC]COANBR) = 2
   [F:GAC]COANBR += 1
  Else
   [F:GAC]DEFACC(I-1) = [F:GAC]ACC
   [F:GAC]SCRACC(I-1) = [F:GAC]ACC
   [F:GAC]OBYIPT(I-1) = 2
  Endif
  Gosub INI_CNA
Endcase

# Dates et utilisateurs
#-------------------------------------------------
[F:GAC]CREDAT     = [F:XPCG]DATCRE    # date création    
If [F:GAC]CREDAT  = [0/0/0]
 [F:GAC]CREDAT    = date$
Endif
[F:GAC]CREUSR     = GUSER              
[F:GAC]UPDDAT     = date$             # date modification
[F:GAC]UPDUSR     = GUSER             # operateur modification


# Demande 46487
#-------------------------------------------------
Raz [F:GAC]CUR

# Contrôle du compte uniquement si création.
#--------------------------------------------------------------------------------------------------------
If !LEXI
 WACC= [F:GAC]ACC

 If vireblc(format$("K:"+GFMTACC,WACC),2)<>WACC
  # Compte ... (...) Format du compte incorrect
  Call ECR_TRACE(mess(45,102,1)-[F:GAC]ACC-"("+[F:XPCG]CPTGNR+")"-mess(4,113,1),1) From GESECRAN
  GOK = 0 : Return
 Endif

 Read [CLS]CLS0 = [F:COA]LEGCLS;[F:GAC]CLSCOD
 If [F:CLS]TYP=3
  # Compte ... (...)  Classe inutilisée
  Call ECR_TRACE(mess(45,102,1)-[F:GAC]ACC-"("+[F:XPCG]CPTGNR+")"-mess(5,113,1),1) From GESECRAN
  GOK = 0 : Return
 Endif

 If !GOK : Return : Endif

 # A REVOIR
 [F:GAC]ACC = WACC
Endif

# Maj
SI_TABLE = "GACCOUNT"
Gosub SI_BEFWRI From SIXFONCTION


If LEXI
 Rewrite [GAC]
Else
 Write [GAC]
Endif

If fstat
 # Compte... : ... (...) Erreur d'écriture 
 Call ECR_TRACE(mess(45,102,1)-[F:GAC]ACC-"("+[F:XPCG]CPTGNR+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0
Else
 NB+=1
Endif
Return

$INI_CNA
  [F:GAC]ENAFLG=2
  [F:GAC]BUDTRK=2
  [F:GAC]FLGUOM=2
  Filter [TUN] Where UOM = "UN"
  Read [TUN]TUN0 First
  If !fstat
   [F:GAC]UOM = [F:TUN]UOM
  Endif
  Filter [TUN]
  If [F:GAC]UOM = ""
   Read [TUN]TUN0 First
   If !fstat
    [F:GAC]UOM = [F:TUN]UOM
   Endif
  Endif
  If [F:GAC]UOM=""
   # Compte... : ... (...) Nature sans unité d'oeuvre
   Call ECR_TRACE(mess(45,102,1)-[F:GAC]ACC-"("+[F:XPCG]CPTGNR+")"-mess(23,103,1),1) From GESECRAN
   GOK = 0 : Return
  Endif
  [F:GAC]DSP=[F:XPCG]MDLVTL

  For I=1 To NBRAXE
   AXE = "AX"+num$(I)
   J = find(AXE,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
   If !J
    If [F:GAC]DACDIENBR<dim([F:GAC]DIE)
     [F:GAC]DIE([F:GAC]DACDIENBR)    = AXE
     [F:GAC]DACDIENBR += 1
    Endif
   Endif
  Next
Return
#########################################################################
$DELETE_GAC
Call DEBTRANS From GLOCK
Filter [GAC] Where !find([F:GAC]ACC,[F:SPX]ACCTMP,[F:SPX]ACCRNDCDT,[F:SPX]ACCRNDDEB)
For [GAC] 
 Filter [XPCG] Where X3CLE=[F:GAC]ACC
 Read [XPCG] First
 If fstat
  Trbegin [GAC]
  Readlock [GAC]GAC0 = [F:GAC]ACC
  If !fstat
   Delete [GAC] Curr
   If fstat
    # Compte ... (...) : Erreur d'effacement
    Call ECR_TRACE(mess(45,102,1)-[F:GAC]ACC-"("+[F:XPCG]CPTGNR+")"-mess(28,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
    GOK = 0
   Endif
  Endif
  If GOK>0
   If SI_SIMU<>2
    Commit
   Else
    Rollback
   Endif
  Endif
 Endif
Next
Filter [GAC]
Filter [XPCG]
Return

#########################################################################
# Création des comptes auxiliaires
#########################################################################
Subprog SI_GACCOUNT_AX

Local Integer STOP, NB, LEXI
Local Char LREPRISE(50)

If !clalev([F:XPCA]) : Local File =SI_DOSSIER+".XIPLACBAUX" [XPCA] : Endif  # Comptes auxiliaires
If !clalev([F:XPCD]) : Local File =SI_DOSSIER+".XIPLACXDOM" [XPCD] : Endif  # Domiciliations Comptes
If !clalev([F:BPR])  : Local File =SI_DOSSIER+".BPARTNER"   [BPR]  : Endif  # Tiers

If !clalev([F:BPA])  : Local File =SI_DOSSIER+".BPADDRESS"  [BPA] : Endif   # Adresses
If !clalev([F:BID])  : Local File =SI_DOSSIER+".BID"        [BID] : Endif   # Relevé Identité Bancaire
If !clalev([F:TCY])  : Local File =SI_DOSSIER+".TABCOUNTRY" [TCY] : Endif   # Pays
If !clalev([F:ABN])  : Local File =SI_DOSSIER+".ABANK"      [ABN] : Endif   # Banques (Guichets)
If !clalev([F:CAC])  : Local File =SI_DOSSIER+".GACCCODE"   [CAC] : Endif   # Codes comptables

SI_SUBPRG = "SIXGAC"
SI_TABLE  = "XIPLACBAUX"
Gosub SI_CRITSUP From SIXFONCTION


$LOOP_BPR
Raz NB

If STOP=1
 CRITERE = "CPTAUX>'"+LREPRISE+"'"
 STOP=0
Else
 CRITERE="1=1"
Endif

Call DEBTRANS From GLOCK
Trbegin [BPR], [BPA], [BID], [XPCA]

# Traitement des comptes auxiliaires
For [XPCA] Where left$(CPTAUX,2)<>"$$" and FLGREP<>2
&             & evalue(CRITERE)
&             & evalue(SI_CRITERE)

 GOK = 1

 Raz LEXI

 Call AFFBOITE([F:XPCA]CPTAUX) From SUBSIM

 # creation tiers (BPARTNER)
 Gosub CRE_BPR
 If GOK<=0 : Break :  Endif

 If !LEXI
  # creation adresse (BPADDRESS)
  Gosub CRE_BPA 
  If GOK<=0 : Break :  Endif

  # creation RIB (BID)
  Gosub CRE_BID
  If GOK<=0 : Break :  Endif
 Endif

 Readlock [XPCA] Curr
 [F:XPCA]FLGREP = 2
 Rewrite [XPCA]

 # NB alimenté dans CRE_BPR
 If NB>1000
  LREPRISE = [F:XPCA]CPTAUX
  STOP     = 1
  Break
 Endif
Next

If GOK>0
 If SI_SIMU<>2
  Commit
 Else
  Rollback
 Endif
 If STOP
  Goto LOOP_BPR
  Endif
Else
  Rollback
Endif
End

##################################################################
$CRE_BPR
Raz [F:BPR]

# recuperation et controle code compte
If !func SIXFONCTION.SI_CTL("BPRACC",[F:XPCA]X3CLE,"XIPLACBAUX ("+[F:XPCA]CPTAUX+")")
 GOK=0 : Return
Else
 [F:BPR]BPRNUM = [F:XPCA]X3CLE
Endif

Look [BPR]BPR0 = [F:BPR]BPRNUM
If !fstat : LEXI=1 : Return : Endif

# Intitulé du tiers
[F:BPR]BPRSHO = [F:XPCA]LIBAPL
[F:BPR]BPRNAM = [F:XPCA]ITT

# FLags
[F:BPR]BPRACC=2

# Code pays 
If [F:XPCA]CODPAY <> ""
 [F:BPR]CRY = func SIXFONCTION.SI_COR("XIPAY",[F:XPCA]CODPAY,"TABCOUNTRY",mess(45,102,1)-[F:BPR]BPRNUM-"("+[F:XPCA]CPTAUX+")")
Endif

# Code adresse
[F:BPR]BPAADD  = "001"

#---------------------------------------------
# Zone obligatoire sous la fiche TIERS
#---------------------------------------------
If [F:BPR]CRY="" : [F:BPR]CRY = GPAYS : Endif

#-- La langue & la devise : Lecture Pays pour initialiser
If [F:BPR]CRY<>"" &  [F:TCY]CRY<>[F:BPR]CRY
 Read [TCY]TCY0=[F:BPR]CRY
 If !fstat
  [F:BPR]LAN = [F:TCY]LAN
  [F:BPR]CUR = [F:TCY]CUR
 Else
  [F:BPR]LAN = GLANGUE
  [F:BPR]CUR = GSYSCUR
 Endif 
Else
 [F:BPR]LAN = GLANGUE
 [F:BPR]CUR = GSYSCUR
Endif  

# Dates et utilisateurs
#-------------------------------------------------
[F:BPR]CREDAT      = [F:XPCA]DATCRE    # date création    
If [F:BPR]CREDAT   = [0/0/0]
 [F:BPR]CREDAT   = date$
Endif
[F:BPR]CREUSR  = GUSER
[F:BPR]UPDDAT  = date$             # date modification
[F:BPR]UPDUSR  = GUSER             # operateur modification

# Données initialiées par défaut
#-------------------------------------------------
Call INITACCCOD([F:BPR]ACCCOD,[F:SPX]CPY,17) From SITSIG

SI_TABLE = "BPARTNER"
Gosub SI_BEFWRI From SIXFONCTION

Write [BPR]
If fstat
 # Tiers... : ... (...) Erreur d'écriture 
 Call ECR_TRACE(mess(31,105,1)-[F:BPR]BPRNUM-"("+[F:XPCA]CPTAUX+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0
Else
 NB+=1
Endif

Return


##################################################################
#  Creation BPADDRESS
##################################################################
$CRE_BPA
Local Char LBPAADD(3)

If dim([F:BPR]BPAADD) > 0   & [F:BPR]BPAADD<>""
   LBPAADD    = [F:BPR]BPAADD          # Adresse par défaut
Else
   LBPAADD    = "001"                  # Adresse par défaut
Endif

Raz LEXI
Look [BPA]BPA0 = 1;[F:BPR]BPRNUM;LBPAADD
If fstat <> 0
 Readlock [BPA]BPA0=1;[F:BPR]BPRNUM;LBPAADD
 If fstat
  Raz [F:BPA]
  Raz LEXI
 Else
  LEXI = 1
 Endif
 
 # Rubriques reprises de l'Integrale
 [F:BPA]BPAADDLIG (0) =  [F:XPCA]ADR1      # Ligne adresse 1
 [F:BPA]BPAADDLIG (1) =  [F:XPCA]ADR2      # Ligne adresse 2
 [F:BPA]BPAADDLIG (2) =  [F:XPCA]ADR3      # Ligne adresse 3
 [F:BPA]POSCOD        =  [F:XPCA]CODPST    # Code postal     
 [F:BPA]CTY           =  [F:XPCA]VIL       # Ville           
 [F:BPA]WEB           =  [F:XPCA]ADRMAI    # Adresse internet

 [F:BPA]CRY = [F:BPR]CRY     # Code pays 
 # Nom pays
 If [F:BPA]CRY <> "" 
  Call LECTEXTRA([F:BPA]CRYNAM,"TABCOUNTRY","CRYDES",[F:BPA]CRY,"") From ATEXTRA
 Endif

 # Rubriques reprises du client X3
 [F:BPA]BPATYP    = 1                      # Type entité
 [F:BPA]BPANUM    = [F:BPR]BPRNUM          # Entité
 [F:BPA]BPAADD    = LBPAADD                # Adresse 
 [F:BPA]CREDAT    = [F:BPR]CREDAT          # Date création
 [F:BPA]CREUSR    = [F:BPR]CREUSR          # Opérateur création
 [F:BPA]UPDDAT    = [F:BPR]UPDDAT          # Date modification
 [F:BPA]UPDUSR    = [F:BPR]UPDUSR          # Opérateur modification
 
 # Rubriques par defaut 
 [F:BPA]BPAADDFLG = 2                      # Par défaut
 [F:BPA]CRETIM    = time                   # Heure
 [F:BPA]UPDTIM    = time                   # Heure

 # Maj
 If LEXI
  [F:BPA]UPDDAT = date$ 
  [F:BPA]UPDUSR = GUSER  
  [F:BPA]UPDTIM = time                   # Heure
  Rewrite [BPA]
 Else
  SI_TABLE = "BPADDRESS"
  Gosub SI_BEFWRI From SIXFONCTION
  Write [BPA]
  If fstat
  # Adresse ... : ... (...) Erreur d'écriture 
   Call ECR_TRACE(mess(33,102,1)-[F:BPR]BPRNUM-"("+[F:XPCA]CPTAUX+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
   GOK = 0
  Endif
 Endif
Endif

Return

##################################################################
#  Creation RIB 
##################################################################
$CRE_BID
Local Char    BANQUE(GLONBID)

Raz LEXI

# Traitement des domiciliations bancaires  
For [XPCD] Where CPTAUX = [F:BPR]BPRNUM
 Raz [F:BID]BIDNUM
 [F:BID]BIDNUM += [F:XPCD]RIBCODBQE1
 [F:BID]BIDNUM += [F:XPCD]RIBGUI1
 [F:BID]BIDNUM += [F:XPCD]RIBNUMCPT1
 [F:BID]BIDNUM += [F:XPCD]RIBCLE1
    
 Look [BID]BID0 = 1;[F:BPR]BPRNUM;[F:BID]BIDNUM
 If fstat
  Readlock [BID]BID0=1;[F:BPR]BPRNUM;[F:BID]BIDNUM
  If fstat
   Raz [F:BID]
   Raz LEXI
  Else
   LEXI = 1
  Endif
  # Rubriques reprises domiciliation bancaire 
  Raz [F:BID]BIDNUM
  [F:BID]BIDNUM += [F:XPCD]RIBCODBQE1
  [F:BID]BIDNUM += [F:XPCD]RIBGUI1
  [F:BID]BIDNUM += [F:XPCD]RIBNUMCPT1
  [F:BID]BIDNUM += [F:XPCD]RIBCLE1
  [F:BID]BICCOD  = [F:XPCD]CODBIC     # Code BIC       

  # code pays 
  If [F:XPCD]CODPAY <> ""
   [F:BID]CRY = func SIXFONCTION.SI_COR("XIPAY",[F:XPCD]CODPAY,"TABCOUNTRY",mess(45,102,1)-[F:BPR]BPRNUM-"("+[F:XPCD]CPTAUX+")")
  Endif
  # lecture Pays pour controle RIB
  If [F:BID]CRY <> "" &  [F:TCY]CRY <> [F:BID]CRY
   Read [TCY]TCY0 = [F:BID]CRY
   If fstat
    Raz [F:TCY]
   Endif
  Endif 
  ## <PP> 1/ Variable VALEUR => Erreur
  ##      2/ [F:TCY]BANLNG est définie ssi le champ BIDCTL est flaguée => Lecture/contrôle de ABN ssi le champ
  ##         'Contrôle banque' est à 'Oui'.
  #BANQUE = left$(VALEUR,[F:TCY]BANLNG)
  #Read [ABN]ABN0 = [F:BID]CRY;BANQUE
  #If fstat
  # GMESSAGE = mess(173,133,1) : # Banque inexistante
  # Call ECR_TRACE(mess(145,197,1)-[F:BPC]BPCNUM-"("+[F:XCLT]CODCLT+")"-mess(173,133,1)-[F:TCY]CRY-BANQUE,1) From GESECRAN
  # If [F:TCY]BIDCTL=2
  #  GOK = 0
  #  Break
  # Else
  #  Raz [ABN]
  # Endif 
  #Endif
  If [F:TCY]BIDCTL=2
   BANQUE = left$([F:BID]BIDNUM,[F:TCY]BANLNG)
   Read [ABN]ABN0 = [F:BID]CRY;BANQUE
   If fstat
    # Tiers ... (...) Banque/guichet inexistants
    GOK = 0 : Call ECR_TRACE(mess(31,105,1)-[F:BPC]BPCNUM-"("+[F:XPCA]CPTAUX+")"-mess(173,133,1)-[F:TCY]CRY-BANQUE,1) From GESECRAN
    Break
   Endif
   # Rubriques reprises de la banque  X3
   [F:BID]PAB1      =  [F:ABN]PAB         # Domiciliation
  Endif

  # Rubriques reprises du client X3
  [F:BID]BPATYP    = 1                      # Type entité
  [F:BID]BPANUM    = [F:BPR]BPRNUM          # Entité

  If dim([F:BPR]BPAADD) > 0   
   [F:BID]BPAADD = [F:BPR]BPAADD          # Adresse par défaut
  Else
   [F:BID]BPAADD = "001"                  # Adresse par défaut
  Endif
  [F:BID]CREDAT    = [F:BPR]CREDAT          # Date création
  [F:BID]CREUSR    = [F:BPR]CREUSR          # Opérateur création
  [F:BID]UPDDAT    = [F:BPR]UPDDAT          # Date modification
  [F:BID]UPDUSR    = [F:BPR]UPDUSR          # Opérateur modification


  # Rubriques par defaut 
  [F:BID]CRETIM    = time                   # Heure
  [F:BID]UPDTIM    = time                   # Heure

  # Maj
  If LEXI
   [F:BID]UPDDAT = date$ 
   [F:BID]UPDUSR = GUSER 
   [F:BID]UPDTIM = time                     # Heure
   Rewrite [BID]
  Else
   SI_TABLE = "BID"
   Gosub SI_BEFWRI From SIXFONCTION
   Write [BID]
   If fstat
    # Relevés bancaires ... : ... (...) Erreur d'écriture 
    Call ECR_TRACE("mess(6,865,1)"-[F:BPR]BPRNUM-"("+[F:XPCD]CPTAUX+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
    GOK = 0 : Break
   Endif
  Endif
 Endif
Next
Return



#########################################################################
# Initialisation de la TVA
#########################################################################
#
# L'Intégrale possède 4 tables de codification pour la TVA
#
#    - CPT_TVA_ACH  (XICPTTAACH) : Compte TVA achat (ISDIV), code table AT
#    - CPT_TVA_VEN  (XICPTTAVEN) : Compte TVA vente (ISDIV), code table VT
#
#    - TVA_ACH  (XITVAACH) : TVA achat (ISTAB), code table AT
#    - TVA_VEN  (XITVAVEN) : TVA vente (ISTAB), code table VT
#
# Phase I  : 
#  Initalisation "Imputation de taxe" 
#    Si le compte est défini sous la table CPT_TVA_ACH, l'imputation de taxe sera de type de "Déduction Achat" (VATIPT=3)
#    Si le compte est défini sous la table CPT_TVA_VEN, l'imputation de taxe sera de type de "Collectée Vente" (VATIPT=1)
# Phase II :  
#  Initalisation "Code taxe" 
#  Recherche du code taxe intégrale via les tables comptes TVA de l'Intégrale.
#  Via ce code taxe, lecture du taux via les tables TVA de l'Intégrale.
#  Puis recherche du Code taxe X3 en rapport avec le Taux.
#
#########################################################################
Subprog INI_TVA

If !clalev([F:GAC])  : Local File =SI_DOSSIER+".GACCOUNT"    [GAC]  : Endif   # Comptes

If !clalev([F:XPCG]) : Local File =SI_DOSSIER+".XIPLACBGNR"  [XPCG] : Endif   # Comptes généraux
If !clalev([F:XCTA]) : Local File =SI_DOSSIER+".XICPTTAACH"  [XCTA] : Endif   # Compte TVA Achat
If !clalev([F:XCTV]) : Local File =SI_DOSSIER+".XICPTTAVEN"  [XCTV] : Endif   # Compte TVA Vente
If !clalev([F:XTA])  : Local File =SI_DOSSIER+".XITVAACH"    [XTA]  : Endif   # TVA Achat
If !clalev([F:XTV])  : Local File =SI_DOSSIER+".XITVAVEN"    [XTV]  : Endif   # TVA Vente

If !clalev([F:TVT])  : Local File =SI_DOSSIER+".TABVAT"      [TVT]  : Endif   # Tables de codes taxes
If !clalev([F:TRA])  : Local File =SI_DOSSIER+".TABRATVAT"   [TRA]  : Endif   # Tables de taux de taxes

If !clalev([F:XSOC]) : Local File =SI_DOSSIER+".XISOC"      [XSOC] : Endif   # Société Intégrale
If !clalev([F:XSO1]) : Local File =SI_DOSSIER+".XISOCDIV1"  [XSO1] : Endif   # Société Intégrale
If !clalev([F:XSO2]) : Local File =SI_DOSSIER+".XISOCDIV2"  [XSO2] : Endif   # Société Intégrale

If !clalev([F:SPX])  : Local File =SI_DOSSIER+".SIPARX3"    [SPX]  : Endif   # Paramétrage Migration Intégrale 

Read [XSOC]First
Read [XSO1]First
Read [XSO2]First


##############################
Local Integer TEST
Raz TEST
#If GUSER="CP" : TEST=1 : Endif
#############################

Local Integer REGTVA
Local Integer UPDOK
Local Char WACC1(GLONGAC), WACC2(GLONGAC)
Local Char WVAT(GLONVAT)
Local Char COAGEN(GLONCOA)

GOK=1

# Gestion de TVA
Call TEMPON(left$(mess(105,107,1),14)) From GESECRAN

Read [SPX] First
Call LEC_COA(1,[F:SPX]CPY,[L]COAGEN) From SIXCPY

Trbegin [GAC]
Filter [GAC] Where COA=[L]COAGEN

# Compte TVA sur Achats, Filtre le Pays
########################################
Filter [XCTA] Where CODPAY=[F:XSOC]CODPAY
For [XCTA]
 
 Raz UPDOK

 # Récupération du règime de TVA sur la fiche compte de l'Intégrale (sachant que pour une borne de compte, le régime est identique)
 Read [F:XPCG]IND0 = [F:XCTA]DUCPT
 If [XPCG]REGTVA="D" : [L]REGTVA = 1 : Endif    # DEBIT
 If [XPCG]REGTVA="E" : [L]REGTVA = 2 : Endif    # ENCAISSEMENT

 # Avec le code taxe Intégrale, récupératon du Taux (2 taux possibles).
 #  Récupération du plus récent taux... puis Recherche du code taxe X3 via ce taux.
 Read [XTA]IND0 = [F:XCTA]CODTVA;[F:XSOC]CODPAY
 If !fstat
  If  [F:XTA]DATCHGTAU<>[0/0/0]
   Link [TRA] With [F:TVT]TVT0=[F:TRA]VAT;[F:TRA]LEG  As [LNK]
&   Where [F:TVT]VATPAY=[L]REGTVA & [F:TRA]VATRAT=[F:XTA]TAUTVA2 & [F:TVT]VATVAC="FRA"
&   Order By Key CLE = [F:TRA]STRDAT Desc ;[F:TVT]VAT
  Else
   Link [TRA] With [F:TVT]TVT0=[F:TRA]VAT;[F:TRA]LEG  As [LNK]
&    Where [F:TVT]VATPAY=[L]REGTVA & [F:TRA]VATRAT=[F:XTA]TAUTVA1 & [F:TVT]VATVAC="FRA"
&    Order By Key CLE = [F:TRA]STRDAT Desc ;[F:TVT]VAT
  Endif
  
  Read [LNK] First
  If !fstat
   WACC1 = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XCTA]DUCPT,"GACCOUNT","")
   WACC2 = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XCTA]AUCPT,"GACCOUNT","")
   Update [GAC] Where ACC>=WACC1 and ACC<=WACC2 With [F:GAC]VATIPT=3, [F:GAC]VAT=[F:TRA]VAT
   If fstat
    Gosub ERR_TVA : Break
   Else
    UPDOK=1
    If  [F:XTA]DATCHGTAU<>[0/0/0]
     If [L]REGTVA = 1 & [F:XTA]CPTDDT2<>""
      WACC1 = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XTA]CPTDDT2,"GACCOUNT","")
      Update [GAC] Where ACC=WACC1 With [F:GAC]VATIPT=3, [F:GAC]VAT=[F:TRA]VAT
      If fstat :  Gosub ERR_TVA : Break : Endif
     Endif
     If [L]REGTVA = 2 & [F:XTA]CPTTVAENC2<>""
      WACC1 = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XTA]CPTTVAENC2,"GACCOUNT","")
      Update [GAC] Where ACC=WACC1 With [F:GAC]VATIPT=3, [F:GAC]VAT=[F:TRA]VAT
      If fstat : Gosub ERR_TVA : Break
      Endif
     Endif
    Else
     If [L]REGTVA = 1 & [F:XTA]CPTDDT1<>""
      WACC1 = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XTA]CPTDDT1,"GACCOUNT","")
      Update [GAC] Where ACC=WACC1 With [F:GAC]VATIPT=3, [F:GAC]VAT=[F:TRA]VAT
      If fstat :  Gosub ERR_TVA : Break : Endif
     Endif
     If [L]REGTVA = 2 & [F:XTA]CPTTVAENC1<>""
      WACC1 = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XTA]CPTTVAENC1,"GACCOUNT","")
      Update [GAC] Where ACC=WACC1 With [F:GAC]VATIPT=3, [F:GAC]VAT=[F:TRA]VAT
      If fstat : Gosub ERR_TVA : Break
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif

 If !UPDOK
  # Compte (Gestion de TVA)
  Call ECR_TRACE(mess(45,102,1)-"("+mess(458,200,1)+") : "-[F:XCTA]DUCPT-"-"-[F:XCTA]AUCPT,0) From GESECRAN
 Endif

Next
Filter [XCTA]
If GOK<>1 : Goto AB_TVA : Endif

 
# Même principe pour les Ventes
# Compte TVA sur Ventes, Filtre le Pays
########################################
Filter [XCTV] Where CODPAY=[F:XSOC]CODPAY
For [XCTV]

 # Gestion de TVA
 Call AFFBOITE(left$(mess(105,107,1),14)) From SUBSIM

 Raz UPDOK

 # Récupération du règime de TVA sur la fiche compte de l'Intégrale (sachant que pour une borne de compte, le régime est identique)
 Read [F:XPCG]IND0 = [F:XCTV]DUCPT
 If [XPCG]REGTVA="D" : [L]REGTVA = 1 : Endif
 If [XPCG]REGTVA="E" : [L]REGTVA = 2 : Endif

 # Avec le code taxe Intégrale, récupératon du Taux (2 taux possibles).
 #  Récupération du plus récent tôt... puis Recherche du code taxe X3 via ce taux.
 Read [XTV]IND0 = [F:XCTV]CODTVA;[F:XSOC]CODPAY
 If !fstat
  If  [F:XTV]CHGTAUTVA<>[0/0/0]
   Link [TRA] With [F:TVT]TVT0=[F:TRA]VAT;[F:TRA]LEG  As [LNK]
&   Where [F:TVT]VATPAY=[L]REGTVA & [F:TRA]VATRAT=[F:XTV]TAUTVA2 & [F:TVT]VATVAC="FRA"
&   Order By Key CLE = [F:TRA]STRDAT Desc ;[F:TVT]VAT
  Else
   Link [TRA] With [F:TVT]TVT0=[F:TRA]VAT;[F:TRA]LEG  As [LNK]
&   Where [F:TVT]VATPAY=[L]REGTVA & [F:TRA]VATRAT=[F:XTV]TAUTVA1 & [F:TVT]VATVAC="FRA"
&   Order By Key CLE = [F:TRA]STRDAT Desc ;[F:TVT]VAT
  Endif
  
  Read [LNK] First
  If !fstat
   WACC1 = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XCTV]DUCPT,"GACCOUNT","")
   WACC2 = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XCTV]AUCPT,"GACCOUNT","")
   Update [GAC] Where ACC>=WACC1 and ACC<=WACC2 With [F:GAC]VATIPT=1, [F:GAC]VAT=[F:TRA]VAT
   If fstat
    Gosub ERR_TVA : Break
   Else
    UPDOK=1
    If  [F:XTV]CHGTAUTVA<>[0/0/0]
     If [L]REGTVA = 1 & [F:XTV]CPTTVA2<>""
      WACC1 = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XTV]CPTTVA2,"GACCOUNT","")
      Update [GAC] Where ACC=WACC1 With [F:GAC]VATIPT=1, [F:GAC]VAT=[F:TRA]VAT
      If fstat :  Gosub ERR_TVA : Break : Endif
     Endif
     If [L]REGTVA = 2 & [F:XTV]CPTTVA1<>""
      WACC1 = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XTV]CPTTVA1,"GACCOUNT","")
      Update [GAC] Where ACC=WACC1 With [F:GAC]VATIPT=1, [F:GAC]VAT=[F:TRA]VAT
      If fstat : Gosub ERR_TVA : Break
      Endif
     Endif
    Else
     If [L]REGTVA = 1 & [F:XTV]CPTTVAENC2<>""
      WACC1 = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XTV]CPTTVAENC2,"GACCOUNT","")
      Update [GAC] Where ACC=WACC1 With [F:GAC]VATIPT=1, [F:GAC]VAT=[F:TRA]VAT
      If fstat :  Gosub ERR_TVA : Break : Endif
     Endif
     If [L]REGTVA = 2 & [F:XTV]CPTTVAENC1<>""
      WACC1 = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XTV]CPTTVAENC1,"GACCOUNT","")
      Update [GAC] Where ACC=WACC1 With [F:GAC]VATIPT=1, [F:GAC]VAT=[F:TRA]VAT
      If fstat : Gosub ERR_TVA : Break
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
 
 If !UPDOK
  # Compte (Gestion de TVA)
  Call ECR_TRACE(mess(45,102,1)-"("+mess(458,200,1)+") : "-[F:XCTV]DUCPT-"-"-[F:XCTV]AUCPT,0) From GESECRAN
 Endif

Next
Filter [XCTV]
If GOK<>1 : Goto AB_TVA : Endif

# Compte ACOMPTE sur Achats : CPTAPTACHASJ
########################################
If [F:XSO1]CPTAPTACHASJ<>""
 Read [F:XPCG]IND0 = [F:XSO1]CPTAPTACHASJ
 If [XPCG]REGTVA="D" : [L]REGTVA = 1 : Endif    # DEBIT
 If [XPCG]REGTVA="E" : [L]REGTVA = 2 : Endif    # ENCAISSEMENT
 Read [XTA]IND0 = [F:XSO1]CODTVAACH;[F:XSOC]CODPAY
 If !fstat
  If  [F:XTA]DATCHGTAU<>[0/0/0]
   Link [TRA] With [F:TVT]TVT0=[F:TRA]VAT;[F:TRA]LEG  As [LNK]
&   Where [F:TVT]VATPAY=[L]REGTVA & [F:TRA]VATRAT=[F:XTA]TAUTVA2 & [F:TVT]VATVAC="FRA"
&   Order By Key CLE = [F:TRA]STRDAT Desc ;[F:TVT]VAT
  Else
   Link [TRA] With [F:TVT]TVT0=[F:TRA]VAT;[F:TRA]LEG  As [LNK]
&    Where [F:TVT]VATPAY=[L]REGTVA & [F:TRA]VATRAT=[F:XTA]TAUTVA1 & [F:TVT]VATVAC="FRA"
&    Order By Key CLE = [F:TRA]STRDAT Desc ;[F:TVT]VAT
  Endif
  
  Read [LNK] First
  If !fstat
   WACC1 = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XSO1]CPTAPTACHASJ,"GACCOUNT","")
   Update [GAC] Where ACC=WACC1 With [F:GAC]FLGVAT=5, [F:GAC]VATIPT=3, [F:GAC]VAT=[F:TRA]VAT
   If fstat
    Gosub ERR_TVA
   Endif
  Endif
 Endif
Endif


