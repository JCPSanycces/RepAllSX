# Initialisation par défaut des comptes de ACHAT (commençant par 6).
##########################################################################
# Recherche du taux de type "Débit"
Raz WVAT
Read [XTA]IND0 = [F:XSO1]CODTVAACH;[F:XSOC]CODPAY
If !fstat
 If  [F:XTA]DATCHGTAU<>[0/0/0]
  Link [TRA] With [F:TVT]TVT0=[F:TRA]VAT;[F:TRA]LEG  As [LNK]
&   Where [F:TVT]VATPAY=1 & [F:TRA]VATRAT=[F:XTA]TAUTVA2 & [F:TVT]VATVAC="FRA"
&   Order By Key CLE = [F:TRA]STRDAT Desc ;[F:TVT]VAT
 Else
  Link [TRA] With [F:TVT]TVT0=[F:TRA]VAT;[F:TRA]LEG  As [LNK]
&   Where [F:TVT]VATPAY=1 & [F:TRA]VATRAT=[F:XTA]TAUTVA1 & [F:TVT]VATVAC="FRA"
&   Order By Key CLE = [F:TRA]STRDAT Desc ;[F:TVT]VAT
 Endif
  
 Read [LNK] First
 If !fstat : WVAT = [F:TRA]VAT :  Endif
Endif

If WVAT<>""
 Filter [XPCG] Where left$([F:XPCG]CPTGNR,1)="6" and [XPCG]REGTVA="D"

 For [XPCG]
  WACC1 = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XPCG]CPTGNR,"GACCOUNT","")
  Readlock [GAC]GAC0 = WACC1
  If !fstat and [F:GAC]VAT=""
   [F:GAC]VATIPT=1
   [F:GAC]VAT=WVAT
   Rewrite [GAC]
   If fstat
    Gosub ERR_TVA
   Endif
  Endif
 Next 
Endif
   
# Recherche du taux de type "Encaissement"
Raz WVAT
Read [XTA]IND0 = [F:XSO1]CODTVAACH;[F:XSOC]CODPAY
If !fstat
 If  [F:XTA]DATCHGTAU<>[0/0/0]
  Link [TRA] With [F:TVT]TVT0=[F:TRA]VAT;[F:TRA]LEG  As [LNK]
&   Where [F:TVT]VATPAY=2 & [F:TRA]VATRAT=[F:XTA]TAUTVA2 & [F:TVT]VATVAC="FRA"
&   Order By Key CLE = [F:TRA]STRDAT Desc ;[F:TVT]VAT
 Else
  Link [TRA] With [F:TVT]TVT0=[F:TRA]VAT;[F:TRA]LEG  As [LNK]
&   Where [F:TVT]VATPAY=2 & [F:TRA]VATRAT=[F:XTA]TAUTVA1 & [F:TVT]VATVAC="FRA"
&   Order By Key CLE = [F:TRA]STRDAT Desc ;[F:TVT]VAT
 Endif
  
 Read [LNK] First
 If !fstat : WVAT = [F:TRA]VAT :  Endif
Endif

If WVAT<>""
 Filter [XPCG] Where left$([F:XPCG]CPTGNR,1)="6" and [XPCG]REGTVA="E"

 For [XPCG]
  WACC1 = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XPCG]CPTGNR,"GACCOUNT","")
  Readlock [GAC]GAC0 = WACC1
  If !fstat and [F:GAC]VAT=""
   [F:GAC]VATIPT=1
   [F:GAC]VAT=WVAT
   Rewrite [GAC]
   If fstat
    Gosub ERR_TVA
   Endif
  Endif
 Next 
Endif

