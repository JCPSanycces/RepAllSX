#<AdxTL>@(#)11.0.0.0 $Revision$
###########################################################################
# TRTNETPSH     Traitement des widgets Netvibes pour les demandes d'achat #
# ----------------------------------------------------------------------- #
# Sous-programmes Web services :                                          #
#   - NV_PSHINI : Début de saisie des demandes d'achat                    #
#                 Initialisation du site à partir de l'utilisateur passé  #
#                 en paramètre                                            #
#   - NV_PSHLIN : Saisie d'une ligne de demande d'achat à partir d'une    #
#                 information article (code, référence interne, référence #
#                 fournisseur, désignation), renvoie :                    #
#                   - le complément des infos article                     #
#                   - le fournisseur par défaut                           #
#                   - l'unité et sa décimalisation                        #
#                   - la quantité par défaut modifiable                   #
#                   - le prix d'achat par défaut modifiable               #
#   - NV_PSHCRE : Fin de la saisie, création de la demande d'achat avec   #
#                 ses différentes lignes, renvoie le numéro de la demande #
#                 d'achat créée.                                          #
###########################################################################


#-----------#
# Pour test #
#-----------#
Local Char    WCODUSR(GLONAUS) : WCODUSR="MBT"
Local Char    WNOMUSR(GLONDES)
Local Char    WFCY   (GLONFCY)
Local Char    WFCYNAM(GLONDES)
Local Char    WMSG(250)
#-----
Call NV_PSHINI(WCODUSR,WNOMUSR,WFCY,WFCYNAM)
WMSG =" Utilisateur ="-[V]GUSER-"-"-WNOMUSR+"\"
WMSG+="Site d'achat ="-WFCY-"-"-WFCYNAM
Call MESSAGE(WMSG) From GESECRAN
#-----
Local Char    WPSHNUM(GLONVCR)
Local Integer WLINNBR          : WLINNBR=5
Local Date    WPRQDAT          : WPRQDAT=date$
Local Char    WPSHFCY(GLONFCY) : WPSHFCY=WFCY
#-----
Local Char    WITMDES(GLONDES)(1..5)
Local Char    WITMREF(GLONITM)(1..5)
Local Char    WBPSNUM(GLONBPS)(1..5)
Local Char    WBPSNAM(GLONNAM)(1..5)
Local Char    WPUU   (GLONUOM)(1..5)
Local Decimal WQTYPUU         (1..5)
Local Decimal WNETPRI         (1..5)
#----
Local Integer WNBDEC
Local Integer I
#-----
WITMREF(1)="CDROM"
WITMREF(2)="A-HN1"
WITMREF(3)="A-HN140"
WITMREF(4)="A-HNAV5"
WITMREF(5)="A-HNSERIE"
For I=1 To WLINNBR
  Call NV_PSHLIN(WITMDES(I),WITMREF(I),WBPSNUM(I),WBPSNAM(I),WPUU(I),WQTYPUU(I),WNBDEC,WNETPRI(I))
  WMSG ="---------------- Ligne"-num$(I)-"---------------"+"\"
  WMSG+="Article ="-WITMREF(I)-"-"-WITMDES(I)+"\"
  WMSG+="Fournisseur ="-WBPSNUM(I)-"-"-WBPSNAM(I)+"\"
  WMSG+="Quantité ="-num$(WQTYPUU(I))-WPUU(I)-"("+num$(WNBDEC)+")\"
  WMSG+="PU net ="-num$(WNETPRI(I))-[V]GCUR
  Call MESSAGE(WMSG) From GESECRAN
Next I
#-----
WBPSNUM(1)="AN001"
WQTYPUU(1)=100
WNETPRI(1)=1.25
#-----
Call NV_PSHCRE(WPSHNUM,WLINNBR,WPRQDAT,WPSHFCY,WITMDES,WITMREF,WBPSNUM,WBPSNAM,WPUU,WQTYPUU,WNETPRI)
WMSG ="Demande d'achat créée :"-WPSHNUM
Call MESSAGE(WMSG) From GESECRAN
#-----
End


#######################################################################
# NV_PSHINI : S/P Début de saisie des demandes d'achat   MBT 02/07/10 #
# ------------------------------------------------------------------- #
# Subprog NV_PSHINI (WCODUSR,WNOMUSR,WFCY,WFCYNAM)                    #
#   Initialisation :                                                  #
#       - du code demandeur                                           #
#       - de son nom                                                  #
#       - du site d'achat                                             #
#       - de la désignation du site                                   #
#   à partir de l'utilisateur passé en paramètre et pouvant être :    #
#       - un code utilisateur                                         #
#       - un login d'utilsateur                                       #
#       - un nom d'utilisateur                                        #
#       - une adresse email d'utilisateur                             #
# ------------------------------------------------------------------- #
#   WCODUSR : Code du demandeur                                       #
#   WNOMUSR : Nom du demandeur                                        #
#   WFCY    : Site d'achat de la demande                              #
#   WFCYNAM : Désignation du site                                     #
#######################################################################
Subprog NV_PSHINI(WCODUSR,WNOMUSR,WFCY,WFCYNAM)
Value    Char WCODUSR()
Variable Char WNOMUSR()
Variable Char WFCY()
Variable Char WFCYNAM()
#-----
If !clalev([F:AUS])  Local File AUTILIS   [AUS] : Endif
If !clalev([F:AME])  Local File AMETUTI   [AME] : Endif
If !clalev([F:AFT])  Local File AFCTFCT   [AFT] : Endif
If !clalev([F:FCY])  Local File FACILITY  [FCY] : Endif
If !clalev([F:TCA])  Local File TABCOUAFF [TCA] : Endif
#-----
Local Integer I
Local Integer WOK
#----- Traitement de l'utilisateur (demandeur) -----#
If pat(WCODUSR,"*@*")<>0
  #----- C'est une adresse email qui est passée par WCODUSR -----#
  Filter [AUS] Where ADDEML=WCODUSR
  Read [AUS] CODUSR First : If fstat  Raz [F:AUS] : Endif
  Filter [AUS]
Else
  #----- Est-ce un code utilisateur ? -----#
  Read [AUS] CODUSR=WCODUSR
  If fstat
    #----- Est-ce un login ? -----#
    Read [AUS] LOGIN=WCODUSR
    If fstat
      #----- Est-ce un nom d'utilisateur ?
      Filter [AUS] Where NOMUSR=WCODUSR
      Read [AUS] CODUSR First : If fstat  Raz [F:AUS] : Endif
      Filter [AUS]
    Endif
  Endif
Endif
#----- Si l'utilisateur n'a pas été trouvé, se rabattre sur GSUPER -----#
If [F:AUS]USR=""
  Read [AUS] CODUSR=GSUPER
  #----- Toujours pas trouvé, on jette l'éponge ! -----#
  If fstat
    Raz [F:AUS], WCODUSR, WFCY
    WNOMUSR="Unknown user ??????"
    WFCYNAM="Unknown facility ??"
    End
  Endif
Endif
#----- Chargement du code et du nom de l'utilisateur -----#
WCODUSR=[F:AUS]USR
WNOMUSR=[F:AUS]NOMUSR
#----- Lecture du profil fonction pour en déduire le site d'achat -----#
If [F:AUS]CODMET<>""
  Read [AME] AME0=[F:AUS]CODMET : If fstat  Raz [F:AME] : Endif
Else
  Raz [F:AME]
Endif
#----- Lecture du profil fonction via le code métier -----#
If [F:AME]PRFFCT<>""
  Read [AFT] AFT0=[F:AME]PRFFCT : If fstat  Raz [F:AFT] : Endif
#----- Lecture du profil fonction via l'utilisateur -----#
Else
  Read [AFT] AFT0=[F:AUS]PRFFCT : If fstat  Raz [F:AFT] : Endif
Endif
#----- Si le profil fonction n'a pas été trouvé, se rabattre sur GSUPER -----#
If [F:AFT]PRFCOD=""
  Read [AFT] AFT0=GSUPER : If fstat  Raz [F:AFT] : Endif
Endif
#----- Site par défaut d'achat du profil fonction -----#
WFCY=[F:AFT]FCYDEF(4)
If WFCY=""
  If [F:AFT]PRFCOD<>""
    #----- Premier site d'achat parmi les sites par défaut du profil fonction -----#
    For I=0 To dim([F:AFT]FCYDEF)-1
      If [F:AFT]FCYDEF(I)<>""
        Read [FCY] FCY0=[F:AFT]FCYDEF(I)
        If !fstat & [F:FCY]PURFLG=2
          WFCY=[F:AFT]FCYDEF(I) : Break
        Endif
      Endif
    Next I
    #-----
  Endif
  #----- Premier site d'achat par ordre alphabétique parmi tous les sites existants -----#
  If WFCY=""
    For [FCY] FCY0 Where PURFLG=2
      WFCY=[F:FCY]FCY : Break
    Next
  Endif
  #----- Si aucun site d'achat n'a été trouvé, on abandonne -----#
  If WFCY=""
    WFCYNAM="Uknown facility ??"
    End
  Endif
Endif
#----- Récupération du nom du site d'achat et de la société -----#
Read [FCY] FCY0=WFCY : If fstat  Raz [F:FCY] : Endif
WFCYNAM=[F:FCY]FCYNAM
#----- Chargement des globales user et site demande -----#
[V]GUSER=WCODUSR
[V]GFCY =WFCY
#----- Chargement des paramètres -----#
Gosub CHARG_PARAM
#-----
End


###################################################################################
# NV_PSHLIN : S/P Début de saisie dune ligne de demande d'achat      MBT 05/07/10 #
# ------------------------------------------------------------------------------- #
# Subprog NV_PSHLIN (WITMDES,WITMREF,WBPSNUM,WBPSNAM,WPUU,WQTYPUU,WNBDEC,WNETPRI) #
#   Initialisation :                                                              #
#       - des informations article (référence article et désignation)             #
#       - des informations fournisseur (code fournisseur et nom)                  #
#       - de l'unité d'achat et de son nombre de décimales                        #
#       - de la quantité minimum par défaut                                       #
#       - du prix unitaire net d'achat par défaut                                 #
#   à partir de l'article passé en paramètre et pouvant être :                    #
#       - une référence interne                                                   #
#       - une référence chez le fournisseur                                       #
#       - une désignation article                                                 #
#       - une partie de référence ou de désignation si caractère joker "%"        #
# ------------------------------------------------------------------------------- #
#   WITMDES : Désignation de l'article                                            #
#   WITMREF : Référence article interne                                           #
#   WBPSNUM : Code fournisseur                                                    #
#   WBPSNAM : Nom ou raison sociale du fournisseur                                #
#   WPUU    : Unité d'achat                                                       #
#   WQTYPUU : Quantité minimum d'achat                                            #
#   WNBDEC  : Nombre de décimale de l'unité d'achat                               #
#   WNETPRI : Prix unitaire net d'achat                                           #
###################################################################################
Subprog NV_PSHLIN(WITMDES,WITMREF,WBPSNUM,WBPSNAM,WPUU,WQTYPUU,WNBDEC,WNETPRI)
Variable Char    WITMDES()
Variable Char    WITMREF()
Variable Char    WBPSNUM()
Variable Char    WBPSNAM()
Variable Char    WPUU()
Variable Decimal WQTYPUU
Variable Integer WNBDEC
Variable Decimal WNETPRI
#-----
Local    Char    WTEXTE(50)
Local    Integer I
Local    Integer WRET
Local    Decimal WMT
#-----
If !clalev([F:ADI])  Local File ATABDIV    [ADI] : Endif
If !clalev([F:FCY])  Local File FACILITY   [FCY] : Endif
If !clalev([F:ITM])  Local File ITMMASTER  [ITM] : Endif
If !clalev([F:ITF])  Local File ITMFACILIT [ITF] : Endif
If !clalev([F:ITP])  Local File ITMBPS     [ITP] : Endif
If !clalev([F:ITS])  Local File ITMSALES   [ITS] : Endif
If !clalev([F:ITC])  Local File ITMCOST    [ITC] : Endif
If !clalev([F:BPR])  Local File BPARTNER   [BPR] : Endif
If !clalev([F:BPS])  Local File BPSUPPLIER [BPS] : Endif
If !clalev([F:BPA])  Local File BPADDRESS  [BPA] : Endif
If !clalev([F:TUN])  Local File TABUNIT    [TUN] : Endif
If !clalev([F:AXX])  Local File ATEXTRA    [AXX] : Endif
If !clalev([F:PSH])  Local File PREQUIS    [PSH] : Endif
If !clalev([F:PSD])  Local File PREQUISD   [PSD] : Endif
If !clalev([F:PPK])  Local File PPRICLINK  [PPK] : Endif
If !clalev([F:TVB])  Local File TABVACBPR  [TVB] : Endif : # 71937 : Multilégislation

#----- Traitement de la désignation article passée en paramètre -----#
Raz [F:ITM], [F:ITP]
If WITMDES<>""
  #----- Est-ce une référence interne complète ? -----#
  Read [ITM] ITM0=WITMDES
  If fstat
    #----- Est-ce une désignation article complète ? -----#
    Read [ITM] ITM1=WITMDES
    If fstat
      #----- Y a t-il un caractère joker ("%" = "*") ? -----#
      If pat(WITMDES,"*%*")<>0
        WTEXTE=ctrans(WITMDES,"%","*")
        #----- Est-ce une partie de la référence interne ? -----#
        Filter [ITM] Where pat(ITMREF,WTEXTE)<>0
        Read [ITM] ITM0 First
        If fstat
          #----- Est-ce une partie de la désignation article ? -----#
          Filter [ITM] Where pat(ITMDES1,WTEXTE)<>0
          Read [ITM] ITM1 First
          If fstat
            #----- Est-ce une partie de la référence chez le fournisseur ? -----#
            Filter [ITP] Where pat(ITMREFBPS,WTEXTE)<>0
            Read [ITP] First
            If fstat
              #----- Est-ce une partie de la désignation chez le fournisseur ? -----#
              Filter [ITP] Where pat(ITMDESBPS,WTEXTE)<>0
              Read [ITP] First : If fstat  Raz [F:ITP] : Endif
            Endif
            Filter [ITP]
            #-----
            If [F:ITP]ITMREF<>""
              Read [ITM] ITM0=[F:ITP]ITMREF : If fstat  Raz [F:ITM] : Endif
            Else
              Raz [F:ITM]
            Endif
            #-----
          Endif
        Endif
        Filter [ITM]
      Else
        #----- Est-ce une partie de la référence interne ? -----#
        Read [ITM] ITM0>=WITMDES
        If fstat
          #----- Est-ce une partie de la désignation article ? -----#
          Read [ITM] ITM1>=WITMDES
          If fstat
            #----- Est-ce une partie de la référence chez le fournisseur ? -----#
            Filter [ITP] Where pat(ITMREFBPS,WITMDES)<>0
            Read [ITP] First
            If fstat
              #----- Est-ce une partie de la désignation chez le fournisseur ? -----#
              Filter [ITP] Where pat(ITMDESBPS,WITMDES)<>0
              Read [ITP] First : If fstat  Raz [F:ITP] : Endif
            Endif
            Filter [ITP]
            #-----
            If [F:ITP]ITMREF<>""
              Read [ITM] ITM0=[F:ITP]ITMREF : If fstat  Raz [F:ITM] : Endif
            Else
              Raz [F:ITM]
            Endif
            #-----
          Endif
        Endif
      Endif
    Endif
  Endif
Endif
#----- Traitement de la référence article passée en paramètre -----#
If [F:ITM]ITMREF="" & WITMREF<>""
  #----- Est-ce une référence interne complète ? -----#
  Read [ITM] ITM0=WITMREF
  If fstat
    #----- Est-ce une désignation article complète ? -----#
    Read [ITM] ITM1=WITMREF
    If fstat
      #----- Y a t-il un caractère joker ("%" = "*") ? -----#
      If pat(WITMREF,"*%*")<>0
        WTEXTE=ctrans(WITMREF,"%","*")
        #----- Est-ce une partie de la référence interne ? -----#
        Filter [ITM] Where pat(ITMREF,WTEXTE)<>0
        Read [ITM] ITM0 First
        If fstat
          #----- Est-ce une partie de la désignation article ? -----#
          Filter [ITM] Where pat(ITMDES1,WTEXTE)<>0
          Read [ITM] ITM1 First
          If fstat
            #----- Est-ce une partie de la référence chez le fournisseur ? -----#
            Filter [ITP] Where pat(ITMREFBPS,WTEXTE)<>0
            Read [ITP] First
            If fstat
              #----- Est-ce une partie de la désignation chez le fournisseur ? -----#
              Filter [ITP] Where pat(ITMDESBPS,WTEXTE)<>0
              Read [ITP] First : If fstat  Raz [F:ITP] : Endif
            Endif
            Filter [ITP]
            #-----
            If [F:ITP]ITMREF<>""
              Read [ITM] ITM0=[F:ITP]ITMREF : If fstat  Raz [F:ITM] : Endif
            Else
              Raz [F:ITM]
            Endif
            #-----
          Endif
        Endif
        Filter [ITM]
      Else
        #----- Est-ce une partie de la référence interne ? -----#
        Read [ITM] ITM0>=WITMREF
        If fstat
          #----- Est-ce une partie de la désignation article ? -----#
          Read [ITM] ITM1>=WITMREF
          If fstat
            #----- Est-ce une partie de la référence chez le fournisseur ? -----#
            Filter [ITP] Where pat(ITMREFBPS,WITMREF)<>0
            Read [ITP] First
            If fstat
              #----- Est-ce une partie de la désignation chez le fournisseur ? -----#
              Filter [ITP] Where pat(ITMDESBPS,WITMREF)<>0
              Read [ITP] First : If fstat  Raz [F:ITP] : Endif
            Endif
            Filter [ITP]
            #-----
            If [F:ITP]ITMREF<>""
              Read [ITM] ITM0=[F:ITP]ITMREF : If fstat  Raz [F:ITM] : Endif
            Else
              Raz [F:ITM]
            Endif
            #-----
          Endif
        Endif
      Endif
    Endif
  Endif
Endif
#----- L'article n'a pas été trouvé, c'est fini ! -----#
If [F:ITM]ITMREF=""
  Raz WITMREF, WBPSNUM, WPUU, WQTYPUU, WNBDEC, WNETPRI
  WITMDES="Unknown item ??????"
  WBPSNAM="Unknown supplier ??"
  End
Endif
#----- Récupération référence article et désignation -----#
WITMREF=[F:ITM]ITMREF
Read [AXX] AXX0="ITMMASTER";"DES1AXX";GLANGUE;[F:ITM]ITMREF
If !fstat
  WITMDES=[F:AXX]TEXTE
Else
  WITMDES=[F:ITM]ITMDES1
Endif
#----- Si le fournisseur a été passé en paramètre -----#
If [F:ITP]ITMREF="" & WBPSNUM<>""
  Read [ITP] ITP0=WITMREF;WBPSNUM : If fstat  Raz [F:ITP] : Endif
Endif
#----- Recherche du fournisseur -----#
If [F:ITP]ITMREF=""
  For [ITP] ITP1 Where ITMREF=WITMREF & DOUFLG<>3
    Break
  Next
Endif
#----- Récupération nom du fournisseur, unité d'achat et quantité minimum -----#
If [F:ITP]ITMREF<>""
  WBPSNUM=[F:ITP]BPSNUM
  If [F:BPS]BPSNUM<>[F:ITP]BPSNUM
    Read [BPS] BPS0=[F:ITP]BPSNUM : If fstat  Raz [F:BPS] : Endif
  Endif
  WBPSNAM=[F:BPS]BPSNAM
  WPUU   =[F:ITP]PUU
  WQTYPUU=[F:ITP]PURMINQTY
Else
  Raz WBPSNUM, WBPSNAM, [F:BPS]
  WPUU   =[F:ITM]PUU
  WQTYPUU=0
Endif
#----- Récupération nbre de décimales de l'unité -----#
Read [TUN] TUN0=WPUU
If !fstat  WNBDEC=[F:TUN]UOMDEC  Else  WNBDEC=0 : Endif
#----- Lecture article-site -----#
If [F:ITF]ITMREF<>WITMREF | [F:ITF]STOFCY<>[V]GRCPFCY
  Read [ITF] ITF0=WITMREF;[V]GRCPFCY
  If fstat Raz [F:ITF] : [F:ITF]OFS=[F:ITM]OFS :
  #--- TS
  Raz WITMREF, WBPSNUM, WPUU, WQTYPUU, WNBDEC, WNETPRI
  WITMDES="Unknown item ??????"
  WBPSNAM="Unknown supplier ??"
  End
  #---
  Endif
Endif
#-----
Raz [F:PSH], [F:PSD]
[F:PSH]PSHFCY=[V]GFCY
[F:PSH]PRQDAT=date$
[F:PSH]REQUSR=[V]GUSER
[F:PSD]ITMREF=WITMREF
[F:PSD]BPSNUM=WBPSNUM
[F:PSD]QTYPUU=WQTYPUU
[F:PSD]PUU   =WPUU
[F:PSD]QTYPUU=WQTYPUU
#----- Chargement ligne et recherche tarif -----#
Gosub CHARG_LIGNE : WNETPRI=[F:PSD]NETPRI
#-----
End


################################################################################
# NV_PSHCRE : S/P Création de la demande d'achat                  MBT 06/07/10 #
# ---------------------------------------------------------------------------- #
# Subprog NV_PSHLIN (WPSHNUM,WLINNBR,WPRQDAT,WPSHFCY,WITMDES,WITMREF,WBPSNUM,  #
#                    WBPSNAM,WPUU,WQTYPUU,WNETPRI)                             #
# ---------------------------------------------------------------------------- #
#   WPSHNUM : Numéro de la demande d'achat crééé                               #
#   WLINNBR : Nombre de lignes à créer                                         #
#   WPRQDAT : Date de la demande                                               #
#   WPSHFCY : Site d'achat                                                     #
#   ------ Lignes --------------------------------                             #
#   WITMDES : Désignation de l'article                                         #
#   WITMREF : Référence article interne                                        #
#   WBPSNUM : Code fopurnisseur                                                #
#   WBPSNAM : Nom ou raison sociale du fournisseur                             #
#   WPUU    : Unité d'achat                                                    #
#   WQTYPUU : Quantité d'achat                                                 #
#   WNETPRI : Prix unitaire net d'achat                                        #
################################################################################
Subprog NV_PSHCRE(WPSHNUM,WLINNBR,WPRQDAT,WPSHFCY,WITMDES,WITMREF,WBPSNUM,WBPSNAM,WPUU,WQTYPUU,WNETPRI)
Variable Char    WPSHNUM()
Variable Integer WLINNBR
Variable Date    WPRQDAT
Variable Char    WPSHFCY()
Variable Char    WITMDES()(1..)
Variable Char    WITMREF()(1..)
Variable Char    WBPSNUM()(1..)
Variable Char    WBPSNAM()(1..)
Variable Char    WPUU   ()(1..)
Variable Decimal WQTYPUU  (1..)
Variable Decimal WNETPRI  (1..)
#-----
If WLINNBR=0  Raz WPSHNUM : End : Endif
#-----
Local    Integer I, J, K, L
Local    Integer WOK
Local    Integer WRET
Local    Integer WPSDLIN
Local    Char    WGRPDEB(GLONVCR)
Local    Decimal WMT
Local    Libelle WSTOMGTCOD
Local    Char    SECTION (GLONCCE)
Local    Char    TPLAN   (GLONCOA)(1..10)
Local    Char    TCOMPTE (GLONGAC)(1..10)
Local    Char    PLAN    (GLONCOA)
Local    Char    COMPTE  (GLONGAC)
Local    Char    ID1(20)(1..5), ID2(20)(1..5)
#----- Ouverture des tables et masques si nécessaire -----#
Gosub OUVRE From WOPSH
#-----
If !clalev([F:PSH])    Local File PREQUIS    [PSH] : Endif
If !clalev([F:GCM])    Local File GACM       [GCM] : Endif
If !clalev([M:ORDK])   Local Mask ORDK      [ORDK] : Endif
If !clalev([F:TB0])    Local File PREQUISD   [TB0] : Endif
If !clalev([F:TB2])    Local File CPTANALIN  [TB2] : Endif
If !clalev([F:ITC])    Local File ITMCOST    [ITC] : Endif
#----- Si module compta présent -----#
If GMODU(2)=2
  If !clalev([F:BLA])  Local File BALANA     [BLA] : Endif
  If !clalev([F:BUD])  Local File BUD        [BUD] : Endif
  If !clalev([F:BUP])  Local File BUDPAR     [BUP] : Endif
Endif
#----- Si module Ventes présent -----#
If GMODU(5)=2
  If !clalev([F:BPC])  Local File BPCUSTOMER [BPC] : Endif
  If !clalev([M:SORW]) Local Mask SORW      [SORW] : Endif
Endif
#----- Chargement des paramètres par défaut de la gestion tarif -----#
Raz GPLISTC
Call COLREM("C",2,"") From TRTPRICE
Call TYPREM(2,"")     From TRTPRICE
Call TARIFCHGT(6)     From TRTPRICE
#-----
Call DEBTRANS From GLOCK
#-----
$TR_CREATION
GOK=1
Raz [F:PSH], [F:PSD], GMESSAGE
#-----
Trbegin [PSH], [PSD]
  Gosub DEBUT_PSH
  If GOK=-1  Goto ROLL_CREATION : Endif
  If GOK=0   Goto AB_CREATION   : Endif
  For I=1 To WLINNBR
    Gosub CREATE_PSD : If GOK<1  Break : Endif
  Next I
  If GOK=1   Gosub CREATE_PSH   : Endif
  If GOK=-1  Goto ROLL_CREATION : Endif
  If GOK=0   Goto AB_CREATION   : Endif
Commit
#----- Envoi des messages groupe workflow signature -----#
If WGRPDEB<>""  Call ENVOI_GROUPE(WGRPDEB) From AWRK : WGRPDEB="" : Endif
#-----
WPSHNUM=[F:PSH]PSHNUM
#-----
End


$ROLL_CREATION
Rollback
#----- Suppression des message groupe workflow signature -----#
If WGRPDEB<>""  Call VIRE_GROUPE(WGRPDEB)  From AWRK : GOK=0 : WGRPDEB="" : Endif
#-----
Call ROLL From GLOCK
If !GROLL  Goto TR_CREATION : Endif
#-----
$AB_CREATION
Rollback
#----- Suppression des message groupe workflow signature -----#
If WGRPDEB<>""  Call VIRE_GROUPE(WGRPDEB)  From AWRK : GOK=0 : WGRPDEB="" : Endif
#-----
Raz WPSHNUM
#-----
End


#----------------------------#
# Début chargement entête DA #
#----------------------------#
$DEBUT_PSH
If [V]GFCY<>WPSHFCY
  [V]GFCY=WPSHFCY : Gosub CHARG_PARAM
Endif
[F:PSH]PSHFCY=WPSHFCY
[F:PSH]REQUSR=[V]GUSER
[F:PSH]CPY   =[V]GSOCIETE
[F:PSH]PRQDAT=WPRQDAT
[F:PSH]APPFLG=1
[F:PSH]ORDFLG=1
[F:PSH]CLEFLG=1
[F:PSH]PRNFLG=1
#----- Alimentation des codes axes -----#
For J=1 To max(GNBDIE,GOPTCANA)
  [F:PSH]DIE(J-1)=GDIE(J)
Next J
#-----
[F:PSH]CREUSR=[V]GUSER
[F:PSH]CREDAT=date$
[F:PSH]EXPNUM=[C]EXPORT
Call NUMERO(GCODNUM,[F:PSH]PSHFCY,[F:PSH]PRQDAT,"",[F:PSH]PSHNUM,WRET) From SUBANM
If GOK<1 | WRET<>0
  GMESSAGE=GCODNUM-mess(60,199,1) : GOK=0
Endif
Raz WPSDLIN
Return


#-------------------------------#
# Création de l'entête de la DA #
#-------------------------------#
$CREATE_PSH
#----- Mise à jour indicateur signée -----#
If [F:PSH]APPLINNBR=0 [F:PSH]APPFLG=1 Else [F:PSH]APPFLG=2 : Endif
If [F:PSH]LINNBR<=[F:PSH]APPLINNBR [F:PSH]APPFLG=3 : Endif
If GAPPPSH<2                       [F:PSH]APPFLG=4 : Endif
If [F:PSH]APPFLG=3
  Filter [PSD] Where PSHNUM=[F:PSH]PSHNUM & LINAPPFLG<>3
  Look [PSD] PSD0 First
  If !fstat  [F:PSH]APPFLG=5 : Endif
  Filter [PSD]
Elsif [F:PSH]APPFLG=1
  Filter [PSD] Where PSHNUM=[F:PSH]PSHNUM & LINAPPFLG>1
  Look [PSD] PSD0 First
  If !fstat  [F:PSH]APPFLG=2 : Endif
  Filter [PSD]
Endif
#-----
If GAPPPSH>1 & [F:PSH]CLEFLG<>2
  [F:PSH]APPFLG=0 : # Pour activation du workflow !
Endif
#----- Mise à jour des statistiques entête DA -----#
Call VALSTA("PSH",+1) From SUBPS2
If GOK<1
  GMESSAGE="PSH"-mess(226,197,1) : # Problème en maj des statistiques
  Return
Endif
#----- Ecriture entête DA -----#
GMESSAGE=mess(13,100,1)-"PREQUIS"-[F:PSH]PSHNUM : # Erreur d'écriture sur le fichier ...
Write [PSH]
If fstat GOK=0 : Call FSTA("PSH") From GLOCK : Return : Endif
Raz GMESSAGE
#----- Mise à jour du suivi workflow signature -----#
If GAPPPSH>1
  Call WORKPLUS(2,"PSH","C",[F:PSH]PSHNUM,"",0,1,0,WGRPDEB) From AWRK
  If GOK<1  Return : Endif
Endif
#----- Message : Demande d'achat XXXXXXXXXXXXXXX créée ! -----#
GMESSAGE=mess(222,197,1)-[F:PSH]PSHNUM-mess(224,197,1)
Return


#-------------------#
# Création ligne DA #
#-------------------#
$CREATE_PSD
Gosub CONTROLE : If !WOK  Return : Endif
WPSDLIN+=1000
[F:PSD]PSHNUM   =[F:PSH]PSHNUM
[F:PSD]PSHFCY   =[F:PSH]PSHFCY
[F:PSD]PSDLIN   =WPSDLIN
[F:PSD]ITMREF   =WITMREF(I)
[F:PSD]BPSNUM   =WBPSNUM(I)
[F:PSD]PUU      =WPUU(I)
[F:PSD]QTYPUU   =WQTYPUU(I)
[F:PSD]LINCLEFLG=1
[F:PSD]LINORDFLG=1
[F:PSD]ORI      =1
[F:PSD]FBUFLG   =1
[F:PSD]NETPRI   =WNETPRI(I)
[F:PSD]CREUSR   =[V]GUSER
[F:PSD]CREDAT   =date$
#----- Chargement ligne et recherche tarif -----#
Gosub CHARG_LIGNE
#----- Alimentation des codes taxe -----#
Call ALIVATCOD(2,[F:PSD]BPSNUM,[F:PSD]ITMREF,"PSD",0) From TRTX3
#----- Calcul du montant ligne HT -----#
[F:PSD]LINAMT=[F:PSD]NETPRI*[F:PSD]QTYPUU
Call ARRDEV([F:PSD]LINAMT,[F:PSD]CUR) From TRTDIV
WMT=[F:PSD]LINAMT
If [F:PSD]CUR<>GLOCALDEV
  Call CONVERT([F:PSD]CUR,GLOCALDEV,GLOCALDEV,[F:PSD]CHGTYP,datesyst,
&              [F:PSD]LINAMT,WMT,GBIDI1) From TRTDEV
Endif
#----- Calcul bases et montants taxes -----#
Call MAJ_CALTAX_LIG("PSD",0) From TRTACHDIV1
#----- Initialisation comptes et type d'achat -----#
[F:TB0]=[F:PSH] : [F:TB0]=[F:PSD]
#----- Chargement pseudo fichier lignes comptables CPTANALIN [TB2] -----#
Raz [F:TB2]
[F:TB2]ABRFIC="PSD"
[F:TB2]VCRNUM=[F:PSH]PSHNUM
[F:TB2]VCRLIN=[F:PSD]PSDLIN
[F:TB2]VCRSEQ=1
[F:TB2]ANALIG=1
For J=1 To max(GNBCOA,2)
  K=GTYPLED(J)
  If K
    [F:TB2]LED(K-1)=GLEDSOC(J)
    [F:TB2]COA(K-1)=GCOA(J)
  Endif
Next J
For J=1 To max(GNBDIE,GOPTCANA)
  [F:TB2]DIE(J-1)=GDIE(J)
Next J
#-----
Raz ID1,ID2
Call COMPTE("PQUIS",1,ID1,ID2,TPLAN,TCOMPTE,WRET,GMESSAGE) From CPTCOD
If WRET
  Raz TPLAN, TCOMPTE, GMESSAGE
  [F:PSD]LINPURTYP=1
Else
  #----- Récupération compte général -----#
  Call LECPLAN(GSOCIETE,GTYPGEN,PLAN) From CPTDIV
  K=find(PLAN,TPLAN(1..10))
  If K  COMPTE=TCOMPTE(K) : Endif
  If [F:GAC]COA<>PLAN | [F:GAC]ACC<>COMPTE
    Read [GAC] GAC0=PLAN;COMPTE : If fstat  Raz [F:GAC] : Endif
  Endif
  #----- Initialisation type d'achat -----#
  If [F:GAC]VATIPT=5
    [F:PSD]LINPURTYP=3
  Elsif [F:GAC]VATIPT=4
    [F:PSD]LINPURTYP=2
  Else
    [F:PSD]LINPURTYP=1
  Endif
Endif
#----- Ecriture des comptes et sections analytiques dans la table CPTANALIN -----#
Raz [F:CAL]
[F:CAL]ABRFIC="PSD"
[F:CAL]VCRNUM=[F:PSD]PSHNUM
[F:CAL]VCRLIN=[F:PSD]PSDLIN
[F:CAL]ANALIG=1
#----- Mise à jour des comptes -----#
For J=1 To 10
  K=GTYPLED(J)
  If K
    [F:CAL]LED(K-1)=GLEDSOC(J)
    [F:CAL]COA(K-1)=GCOA(J)
    L=find(GCOA(J),TPLAN(1..10))
    If L
      [F:CAL]ACC(K-1)=TCOMPTE(L)
    Else
      Raz [F:CAL]ACC(K-1)
    Endif
  Endif
Next J
#----- Initialisation des sections analytiques de la ligne -----#
For J=1 To max(GNBDIE,GOPTCANA)
  [F:CAL]DIE(J-1)=GDIE(J)
  Call INISEC(SECTION,"PSM",GDIE(J)) From SUBCDE
  [F:CAL]CCE(J-1)=SECTION
Next J
#-----
GMESSAGE=mess(13,100,1)-"CPTANALIN"-"PSD"-[F:PSD]PSHNUM-num$([F:PSD]PSDLIN)
Write [CAL]
If fstat  GOK=0 : Call FSTA("CAL") From GLOCK : Return : Endif
Raz GMESSAGE
#----- Création de l'encours "POP" -----#
If WSTOMGTCOD>1
  Call NUMERO(GWIP,[F:PSD]PRHFCY,[F:PSD]EXTORDDAT,"",[F:PSD]WIPNUM,WRET) From SUBANM
  If GOK<1 | WRET<>0
    GMESSAGE=GWIP-mess(60,199,1) : GOK=0 : Return
  Endif
  [M:ORDK]MAJCOD    = "C"
  [M:ORDK]WIPTYP    = 2
  [M:ORDK]WIPSTA    = 2
  [M:ORDK]WIPNUM    = [F:PSD]WIPNUM
  [M:ORDK]ITMREF    = [F:PSD]ITMREF
  [M:ORDK]ORIFCY    = [F:PSD]PSHFCY
  [M:ORDK]STOFCY    = [F:PSD]PRHFCY
  [M:ORDK]PJT       = [F:PSD]PJT
  [M:ORDK]BPRNUM    = [F:PSD]BPSNUM
  [M:ORDK]STRDAT    = [F:PSD]EXTORDDAT
  [M:ORDK]ENDDAT    = [F:PSD]EXTRCPDAT
  [M:ORDK]VCRTYP    = 14
  [M:ORDK]VCRNUM    = [F:PSD]PSHNUM
  [M:ORDK]VCRLIN    = [F:PSD]PSDLIN
  [M:ORDK]VCRSEQ    = 0
  [M:ORDK]EXTQTY    = [F:PSD]QTYSTU
  [M:ORDK]CPLQTY    = [F:PSD]ORDQTYSTU
  [M:ORDK]ALLQTY    = 0
  [M:ORDK]SHTQTY    = 0
  [M:ORDK]FMI       = 1
  [M:ORDK]MRPMES    = 1
  # Issue 71276 - 2015-02-27 by SR : Versions
  If dim([M:ORDK]ECCVALMAJ)> 0
    [M:ORDK]ECCVALMAJ = [F:PSD]ECCVALMAJ
    [M:ORDK]ECCVALMIN = [F:PSD]ECCVALMIN
  Endif
  # End issue 71276
  [M:ORDK]VCRTYPORI = 0
  [M:ORDK]VCRNUMORI = ""
  [M:ORDK]VCRLINORI = 0
  [M:ORDK]VCRSEQORI = 0
  [M:ORDK]BOMALT    = 0
  [M:ORDK]ORI       = 1
  [M:ORDK]ABBFIL    = "PSD"
  Call WIP From TRTWIP
  If GOK<1
    GMESSAGE="2"-[F:PSD]WIPNUM-[F:PSD]ITMREF-mess(92,197,1) : # Problème en maj des encours
    Return
  Endif
Endif
#----- Mise à jour indicateur budget dépassé -----#
If GMODU(2)=2 & GNBDIE>0 & GPURCMMPRP=2
  Call CTLBUD(WRET) From TRTACHPSH1
  If WRET<1
    [F:PSD]FBUFLG=2
  Else
    [F:PSD]FBUFLG=1
  Endif
Endif
#----- Mise à jour indicateur signature ligne -----#
If GAPPPSH>1
  If [F:PSD]LINCLEFLG<>2
    [F:PSD]LINAPPFLG=0 : # La màj du suivi et le workflow se fera à la création entête !
  Else
    [F:PSD]LINAPPFLG=1
  Endif
Else
  [F:PSD]LINAPPFLG=4
Endif
#----- Mise à jour du pré-engagement -----#
[F:PSD]CMMPRPTAX=max(GPURCMMTAX,1)
If GMODU(2)=2 & GPURCMMPRP=2 & (GAPPPSH<2 | GPSHCMMLEV=3)
  [F:TB0]=[F:PSH] : [F:TB0]=[F:PSD] : [F:TB2]=[F:CAL]
  Call TRTMAJCMM([F:PSD]PSHNUM,[F:PSD]PSDLIN,0,+1,1,"PSD",2,WRET) From TRTACHDIV1
  Raz GERR
  If WRET<>0
    If GMESSAGE=""
      If WRET=6  GMESSAGE=mess(93,197,1) Else GMESSAGE=mess(173,197,1) : Endif
    Endif
    GMESSAGE+="\"+mess(18,197,1)-num$([F:PSD]PSDLIN)
    If GBUDCTLPSH<>2
      GBUDCTLPSH=1 : GOK=1 : GERR=0 : Raz GMESSAGE
    Endif
  Endif
  If GOK<1  Return : Endif
Endif
#----- Mise à jour des statistiques ligne DA -----#
Call VALSTA("PSD",+1) From SUBPS2
If GOK<1
  GMESSAGE="PSD"-mess(226,197,1) : # Problème en maj des statistiques
  Return
Endif
#----- Ecriture ligne DA -----#
Write [PSD]
If fstat
  GMESSAGE=mess(13,100,1)-"PREQUISD"-[F:PSD]PSHNUM-num$([F:PSD]PSDLIN)
  GOK=0 : Call FSTA("PSD") From GLOCK : Return
Endif
#----- Message : Demande d'achat XXXXXXXXXXXXXXX 9999999 créée ! -----#
GMESSAGE=mess(222,197,1)-[F:PSD]PSHNUM-num$([F:PSD]PSDLIN)-mess(224,197,1)
#----- Mise à jour total HT et nbre de lignes créées,signées sur entête DA -----#
[F:PSH]TOTPRQ+=WMT
[F:PSH]LINNBR+=1
If [F:PSD]LINAPPFLG>2 [F:PSH]APPLINNBR+=1 : Endif
WITMDES(I)=[F:PSD]ITMDES
WBPSNAM(I)=[F:BPS]BPSNAM
WNETPRI(I)=[F:PSD]NETPRI
Return


#---------------------------------------------------------------#
# Chargement des paramètres en fonction du site d'achat [V]GFCY #
#---------------------------------------------------------------#
$CHARG_PARAM
#----- Chargement des paramètres -----#
Call DEFSITE([V]GFCY) From TRTACHDEF1
Call GLOBVAR([V]GFCY) From WWGLOBACH
If [V]GMODU(2)=2
  Call GLOBVAR(GFINRSP) From WWGLOBBUD
Endif
Call DEFBUD("PSH",[V]GFCY)   From TRTACHDEF1
Call DEFRCPFCY([V]GFCY)      From TRTACHDEF1
Call GETCPY([V]GFCY,"",0,"") From TRTX3CPT  : If GFINRSP=""  GFINRSP=[V]GFCY : Endif
#----- Lecture des affectations compteur -----#
Call LECTCA(6,WOK) From SUBTCA
If !fstat & WOK  GCODNUM=[F:TCA]CODNUM(1) : Endif
Call LECTCA(7,WOK) From SUBTCA
If !fstat & WOK  GWIP=[F:TCA]CODNUM(8) : Endif
#-----
Return


#--------------------------------------------------#
# Contrôle des valeurs transmises pour la ligne DA #
#--------------------------------------------------#
$CONTROLE
WOK=1
#----- La référence article est obligatoire -----#
If WITMREF(I)=""  WOK=0 : Return : Endif
If [F:ITM]ITMREF<>WITMREF(I)
  Read [ITM] ITM0=WITMREF(I)
  If fstat  Raz [F:ITM] : WOK=0 : Return : Endif
Endif
#----- contrôle référence article -----#
# Issue 112754 - 2016-09-27 by SR : Services
Call C_ITMREF("PSD",WITMREF(I)) From TRTACHCTL1
If mkstat | ([F:ITM]ITMSTA<>1 & [F:ITM]ITMSTA<>3)  WOK=0 : Return : Endif
#----- Contrôle site de réception -----#
Call C_PRHFCY ([V]GRCPFCY,WITMREF(I)) From TRTACHCTL1
If mkstat  WOK=0 : Return : Endif
#----- Contrôle unité d'achat -----#
Call PCOUOM(WPUU(I),WBPSNUM(I),WITMREF(I),3,5) From TRTACHCTL1
If mkstat  WOK=0 : Return  : Endif
#----- Contrôle fournisseur -----#
If WBPSNUM(I)<>""
  Call CONTROLE("BPS","ABC",WBPSNUM(I),"",mkstat) From CONTOBJ
  If mkstat  WOK=0 : Return : Endif
  Call CTLBPRCPY (WBPSNUM(I),WPSHFCY) From CONTX3
  If mkstat  WOK=0 : Return : Endif
  #---- Contrôle article-fournisseur -----#
  If [F:ITP]ITMREF<>WITMREF(I) | [F:ITP]BPSNUM<>WBPSNUM(I)
    Read [ITP] ITP0=WITMREF(I);WBPSNUM(I)
    If fstat
      Raz [F:ITP]
      # Issue 77999 - 2011-11-18 by VPO : référencement inutile si fournisseur de type Divers
      If [F:BPS]BPSNUM<>WBPSNUM(I)
        Read [BPS] BPS0=WBPSNUM(I) : If fstat Raz [F:BPS] : Endif
      Endif
      #----- Si fournisseur <> Divers -----#
      If [F:BPS]BPSTYP<>3
        #----- Si article non générique et article-fournisseur obligatoire -----#
        If [F:ITM]GENFLG<>2 & GITMBPS=1        : # Article-fournisseur obligatoire !
          WOK=0 : Return
        Endif
      Endif
    Elsif [F:ITP]DOUFLG=3 : # Article douteux pour ce fournisseur !
      WOK=0 : Return
    Endif
  Endif
Endif
#-----
Return


#-----------------------------------------------------------#
# Chargement de la ligne de DA et recherche tarif si besoin #
#-----------------------------------------------------------#
$CHARG_LIGNE
[F:PSD]EXTORDDAT=[F:PSH]PRQDAT
[F:PSD]PRHFCY   =[V]GRCPFCY
#----- Lecture article si nécessaire -----#
If [F:ITM]ITMREF<>[F:PSD]ITMREF
  Read [ITM] ITM0=[F:PSD]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
#-----
[F:PSD]STU=[F:ITM]STU
#----- Lecture aticle-site si nécessaire -----#
If [F:ITF]ITMREF<>[F:PSD]ITMREF | [F:ITF]STOFCY<>[F:PSD]PSHFCY
  Read [ITF] ITF0=[F:PSD]ITMREF;[F:PSD]PSHFCY : If fstat Raz [F:ITF] : Endif
Endif
#----- Calcul quantité en US -----#
Call PCAL_QTY ([F:PSD]QTYPUU,[F:PSD]PUU,[F:PSD]QTYSTU,[F:PSD]STU,
&              [F:PSD]ITMREF,[F:PSD]BPSNUM,1,GBIDD1) From TRTACHQTE1
#-----
If [F:ITF]ITMREF=""
  [F:PSD]EXTRCPDAT=[F:PSD]EXTORDDAT+[F:ITM]OFS
  [F:PSD]LINBUY   =[F:ITM]BUY
  WSTOMGTCOD      =[F:ITM]STOMGTCOD
Else
  [F:PSD]EXTRCPDAT=[F:PSD]EXTORDDAT+[F:ITF]OFS
  [F:PSD]LINBUY   =[F:ITF]BUY
  WSTOMGTCOD      =[F:ITF]STOMGTCOD
Endif
#----- Lecture des tables tiers fournisseurs -----#
If [F:PSD]BPSNUM<>""
  If [F:BPR]BPRNUM<>[F:PSD]BPSNUM
    Read [BPR] BPR0=[F:PSD]BPSNUM
    If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
  Endif
  If [F:BPS]BPSNUM<>[F:PSD]BPSNUM
    Read [BPS] BPS0=[F:PSD]BPSNUM
    If fstat Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
  Endif
  [F:PSD]CUR=[F:BPS]CUR
  If [F:ITP]ITMREF<>[F:PSD]ITMREF | [F:ITP]BPSNUM<>[F:PSD]BPSNUM
    Read [ITP] ITP0=[F:PSD]ITMREF;[F:PSD]BPSNUM
    If fstat  Raz [F:ITP] : Endif
  Endif
Else
  Raz [F:ITP], [F:BPS], [F:BPR]
Endif
#----- Récupération des liens texte article ou article-fournisseur -----#
If [F:ITP]TEX<>""
  [F:PSD]LINTEX=[F:ITP]TEX
Else
  [F:PSD]LINTEX=[F:ITM]PURTEX
Endif
#-----
If [F:PSD]BPSNUM<>""
  [F:PSD]CUR   =[F:BPS]CUR
  [F:PSD]CHGTYP=[F:BPS]CHGTYP
  Call INIT_REGIME([F:PSD]BPSNUM,[F:PSD]PSHFCY,"F",[F:PSD]VACBPR) From CPTSUB
Else
  [F:PSD]CUR   =[V]GLOCALDEV
  [F:PSD]CHGTYP=[V]GPURCHGTYP
  [F:PSD]VACBPR=[V]GPURVACBPR
Endif
#-----
# 71937 : Multilégislation
#If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>[F:PSD]VACBPR
#  Read [ADI] CODE=1;[F:PSD]VACBPR : If fstat Raz [F:ADI] : Endif
#Endif
#[F:PSD]VACTYP=[F:ADI]N1
Local Integer GRET
Call LEC_TVB_LEG(GCURLEG,[F:PSD]VACBPR,GRET) From TRTLECLEG
If GRET Raz [F:TVB] : Endif
[F:PSD]VACTYP=[F:TVB]REGVAC
# 71937 : Multilégislation

#-----
Call COURSITE([F:PSD]CUR,[F:PSD]PSHFCY,[F:PSD]CHGTYP,[F:PSH]PRQDAT,
&             [F:PSD]CHGCOE,WRET) From TRTDEV
#----- Chargement des désignations article -----#
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[F:PSD]ITMDES, "[F:ITM]") From TRTX3
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[F:PSD]ITMDES1,"[F:ITM]") From TRTX3
#----- Recherche tarif -----#
If [F:PSD]NETPRI=0
  If GPLISTC<>[F:BPS]PLISTC
    GPLISTC=[F:BPS]PLISTC
    Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
    Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
    Call TARIFCHGT(6)                From TRTPRICE
  Endif
  #----- Recherche tarif suivant le paramètre valorisation des lignes de DA -----#
  If GPSHVLT=2  Call RECH_TARIF("PSM",0) From TRTACHTAR1 : Endif
  #----- Si le prix unitaire net est nul prendre le prix standard suivant GPURPRICE -----#
  If ([F:PSD]NETPRI=0 & GPURPRICE=2) | GPSHVLT=1
    Call GETPRI([F:PSD]ITMREF,[F:PSD]ECCVALMAJ,[F:PSD]ECCVALMIN,[F:PSD]PRHFCY,[F:PSH]PRQDAT,1,"","",1,WMT,GBIDI1) From STKVAL
    If GBIDI1
      Raz [F:ITC]
    Else
      WMT=[F:ITC]VLTTOT
      If [F:PSD]CUR<>GLOCALDEV
        Call CONVERT2(GLOCALDEV,[F:PSD]CUR,GLOCALDEV,[F:PSD]CHGTYP,datesyst,
&                     [F:ITC]VLTTOT,WMT,GBIDI1) From TRTDEV
      Endif
      If [F:PSD]PUU<>[F:PSD]STU
        Call PCAL_QTY([F:PSD]QTYPUU,[F:PSD]PUU,GBIDD1,[F:PSD]STU,
&                     [F:PSD]ITMREF,[F:PSD]BPSNUM,1,GBIDD2) From TRTACHQTE1
        If GBIDD2=0 GBIDD2=1 : Endif
        WMT=WMT*GBIDD2
      Endif
      [F:PSD]GROPRI=arr(WMT,10^-GDECPRI)
      [F:PSD]NETPRI=[F:PSD]GROPRI
      [F:PSD]PRIREN=[V]GUPDPRIPUR
    Endif
  Endif
Endif
#-----
Return

