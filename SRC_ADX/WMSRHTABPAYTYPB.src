$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 7466: RES='Transactions de règlements'
   When 7981: RES='Transaction de règlement'
   When 26213: RES='Législation'
   When 71: RES='Code d'+"'"+'accès'
  Endcase
 When "ENG":
  Case _ID
   When 7466: RES='Payment types'
   When 7981: RES='Payment type'
   When 26213: RES='Legislation'
   When 71: RES='Access code'
  Endcase
 When "ITA":
  Case _ID
   When 7466: RES='Transazioni pagamenti/incassi'
   When 7981: RES='Transazione di pagamento'
   When 26213: RES='Legislazione'
   When 71: RES='Codice accesso'
  Endcase
 When "POR":
  Case _ID
   When 7466: RES='Transacções de pagamen.'
   When 7981: RES='Transação de pagamentos'
   When 26213: RES='Legislação'
   When 71: RES='Código acesso'
  Endcase
 When "SPA":
  Case _ID
   When 7466: RES='Transacciones de pagos'
   When 7981: RES='Transacción de pago'
   When 26213: RES='Legislación'
   When 71: RES='Cód. de acceso'
  Endcase
 When "BRI":
  Case _ID
   When 7466: RES='Payment Types'
   When 7981: RES='Payment Type'
   When 26213: RES='Legislation'
   When 71: RES='Access code'
  Endcase
 When "GER":
  Case _ID
   When 7466: RES='Zahlungsarten'
   When 7981: RES='Zahlungsart'
   When 26213: RES='Rechtsordnung'
   When 71: RES='Zugriffscode'
  Endcase
 When "POL":
  Case _ID
   When 7466: RES='Typy płatności'
   When 7981: RES='Typ rozliczenia'
   When 26213: RES='Legislacja'
   When 71: RES='Kod dostępu'
  Endcase
 When "CHI":
  Case _ID
   When 7466: RES='付款交易'
   When 7981: RES='付款交易'
   When 26213: RES='准则'
   When 71: RES='访问代码'
  Endcase
 When "ARB":
  Case _ID
   When 7466: RES='أنواع الدفع'
   When 7981: RES='نوع الدفعة'
   When 26213: RES='تشريعات'
   When 71: RES='رمز الدخول'
  Endcase
Endcase
Return
