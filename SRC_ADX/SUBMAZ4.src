##########################################################################################################
# Gestion du masque MAZ4
##########################################################################################################
##########################################################################################################
Subprog AS_TYP(VALEUR)
Variable Integer VALEUR

  GMENLOC(1) = 1
  GMENLOC(2) = 1
End

##########################################################################################################
Subprog AM_MXL(VALEUR)
Variable Char    VALEUR()

  [M:MAZ4]TPLFIL = VALEUR + "_" + GUSER + "_" + date$ + left$(time$,2) + mid$(time$,4,2)  + mid$(time$,7,2) + ".xml"
  Affzo [M:MAZ4]TPLFIL
  If [M:MAZ4]TPLVOL <> "" Then
    Call AM_TPLVOL([M:MAZ4]TPLVOL)
  Endif
End

##########################################################################################################
Subprog AM_TPLVOL(VALEUR)
Variable Char    VALEUR()

Local Char SREPFIL(250)
Local Char SFULLPATH(250)
Local Char SMESSAGE(250)

  Raz [M:MAZ4]TPLDIRFIL
  SREPFIL = "[" + VALEUR + "]/" + [M:MAZ4]TPLFIL
  # ----------------------------------
  Gosub ENUM_VOLFIL_TYPE From ASYRSTO
  mkstat = func ASYRSTO.CTL_VOLFIL(2, SREPFIL, SFULLPATH, E_TYPE_FILEWRITE, SMESSAGE)
  If mkstat Then
    GERR = 1
    If SMESSAGE <> "" Then
      GMESSAGE = SMESSAGE
    Endif
    If GMESSAGE = "" Then
      GMESSAGE = mess(35,126,1) - "(a)"
    Endif
    End
  Else
    [M:MAZ4]TPLDIRFIL = SFULLPATH
    Affzo [M:MAZ4]TPLDIRFIL
  Endif
End
