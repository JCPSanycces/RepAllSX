#<AdxTL>@(#)10.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour flag "Actif" à "Non" dans la table ALOGIN si session non active
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update enable flag on ALOGIN file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJALO
End

#-------------------#
$MAJALO

If func AFNC.ACTIVDOS(DOSSIER,"AUDIT")<=0
 Return
Elsif filinfo(filpath("FIL","ALOGIN","fde",DOSSIER),0)<=0
 Return
Elsif func ASESSIONS.ISMNGSESSIONS
 Return
Endif

Local Char    ORDSYS(250) , MESSA(250) , SID(10) , SCLI(8) , SDOS(50) , SUID(20) , STYP(2)
Local Integer I , NBSES , TRA , RW , DET , CON , NBCON , NBRW , MAXSES , LIG
MAXSES = 5000
Local Libelle TBTYP(1..MAXSES)
Local Char    TBUID(10)(1..MAXSES)

TRA = (GTRACE<>"")
DET = 1 : # Affichage des enregistrements avec utilisateur non connecté alors qu'ils sont flagués à Oui
RW  = 1 : # Mise à jour connecté à Non si utilisateur non connecté et flagué à Oui
CON = 1 : # Affichages des enregistrements avec utilisateur connecté

Local File =DOSSIER+".ALOGIN" [ALO]

If TRA
 Call ECR_TRACE(mess(81,125,1)-"ALOGIN:"-time$,0) From GESECRAN : # Mise à jour de la table ALOGIN
Endif

ORDSYS = 'psadx -it -b'-DOSSIER
Raz NBSES , TBUID , LIG
Local File (SID,SCLI,SDOS,SUID,STYP) From System ORDSYS As [SYS_]
For [SYS_]
 If LIG<2
  LIG += 1
 Elsif [F:SYS_]STYP=""
  # Dernière ligne
 Elsif NBSES>=dim(TBUID)
  If TRA
   Call ECR_TRACE(mess(6,948,1)-"("+num$(NBSES)+")",1) From GESECRAN : # Trop d'utilisateurs
  Endif
  NBSES = 0
  Break
 Else
  NBSES += 1
  TBUID(NBSES) = [F:SYS_]SID
  TBTYP(NBSES) = val([F:SYS_]STYP)
 Endif
Next SYS_

If NBSES=0
 Close Local File : Return
Endif

Raz NBCON , NBRW
Trbegin [ALO]
 For [ALO]ALO1 Where FLG=2
  I = find([F:ALO]ADOID,TBUID(1..NBSES))
  If !I
   If DET & TRA
    MESSA = "Date="+format$("D:",[F:ALO]DATCNX)
    MESSA -= "Time="+[F:ALO]HOUCNX
    MESSA -= "User="+[F:ALO]ADOUSR
    MESSA -= "Mac="+[F:ALO]ADRCLI
    MESSA -= "uid="+[F:ALO]ADOID
    Call ECR_TRACE(MESSA-"Not connected",-1) From GESECRAN
   Endif
   If RW
    NBRW += 1
    [F:ALO]FLG = 1
    Rewrite [ALO]
    If fstat & TRA
     Call ERREUR("ALOGIN"-[F:ALO]ADOID,2) From DOSDIC
    Endif
   Endif
  Elsif CON
   NBCON += 1
   MESSA = "Date="+format$("D:",[F:ALO]DATCNX)
   MESSA -= "Time="+[F:ALO]HOUCNX
   MESSA -= "User="+[F:ALO]ADOUSR
   MESSA -= "Mac="+[F:ALO]ADRCLI
   MESSA -= "uid="+[F:ALO]ADOID
   MESSA -= "("+mess(TBTYP(I),924,1)+")"
   Call ECR_TRACE(MESSA-"connected",0) From GESECRAN
  Endif
 Next ALO
Commit

If TRA
 If CON
  Call ECR_TRACE("nbses="+num$(NBSES)-"nbcon="+num$(NBCON),0) From GESECRAN
 Endif
 Call ECR_TRACE(num$(NBRW)-"updated records",0) From GESECRAN
Endif

Close Local File

Return

