## CRUD-CLASSE ## EMPLOID
# 2018-11-06 07:05:43 046


############################################################################################
### Subprog _ADELETE
############################################################################################
Subprog _ADELETE(EMPLOID,ASTATUS)
Variable Instance EMPLOID Using C_EMPLOID
Variable Integer ASTATUS

If EMPLOID = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLOID

[L]A_STRSITE = ""
[L]A_STRACC = ""
Local Instance ALNKDELTAB Using C_ALNKDELTAB
Gosub ADELETE_EMPLOID

End

############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(EMPLOID,ASTATUS)
Variable Instance EMPLOID Using C_EMPLOID
Variable Integer ASTATUS

If EMPLOID = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOID
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_EMPLOID
Else
 Gosub ADELETE_EMPLOID
Endif

$ADELETE_END
End


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(EMPLOID,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If EMPLOID.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLOID.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For [L]A_I=1 To maxtab(EMPLOID.PASDET)
 If EMPLOID.PASDET([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.PASDET([L]A_I).ACTION("ADELETE_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For [L]A_I=1 To maxtab(EMPLOID.PERCNT)
 If EMPLOID.PERCNT([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.PERCNT([L]A_I).ACTION("ADELETE_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
A_N2=1
If EMPLOID.EMPLOIDSA(A_N2) <> null
& and EMPLOID.EMPLOIDSA(A_N2).ASTALIN<>[V]CST_ANEWDEL
 If EMPLOID.EMPLOIDSA(A_N2).ASTALIN<>[V]CST_ANEW
  EMPLOID.EMPLOIDSA(A_N2).ASTALIN = [V]CST_ADEL
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2)._ADELETE_CONTROL_BEFORE)
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
  For [L]A_I=1 To maxtab(EMPLOID.EMPLOIDSA(A_N2).EMPADR)
   If EMPLOID.EMPLOIDSA(A_N2).EMPADR([L]A_I)<>null
    [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2).EMPADR([L]A_I).ACTION("ADELETE_CONTROL_BEFORE"))
    If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
   Endif
  Next
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
  For [L]A_I=1 To maxtab(EMPLOID.EMPLOIDSA(A_N2).PASDET)
   If EMPLOID.EMPLOIDSA(A_N2).PASDET([L]A_I)<>null
    [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2).PASDET([L]A_I).ACTION("ADELETE_CONTROL_BEFORE"))
    If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
   Endif
  Next
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
  For [L]A_I=1 To maxtab(EMPLOID.EMPLOIDSA(A_N2).PERCNT)
   If EMPLOID.EMPLOIDSA(A_N2).PERCNT([L]A_I)<>null
    [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2).PERCNT([L]A_I).ACTION("ADELETE_CONTROL_BEFORE"))
    If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
   Endif
  Next
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Endif
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
A_N2=1
If EMPLOID.EMPLOIDUKI(A_N2) <> null
& and EMPLOID.EMPLOIDUKI(A_N2).ASTALIN<>[V]CST_ANEWDEL
Endif
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EMPLOID.EMPLORIB) : # EMPLORIB -- 4
 If EMPLOID.EMPLORIB(A_N2) <> null
& and EMPLOID.EMPLORIB(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EMPLOID.EMPLORIB(A_N2).ASTALIN<>[V]CST_ANEW
   EMPLOID.EMPLORIB(A_N2).ASTALIN = [V]CST_ADEL
   [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLORIB(A_N2)._ADELETE_CONTROL_BEFORE)
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EMPLOID.EMPLOCHD) : # EMPLOCHD -- 5
 If EMPLOID.EMPLOCHD(A_N2) <> null
& and EMPLOID.EMPLOCHD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EMPLOID.EMPLOCHD(A_N2).ASTALIN<>[V]CST_ANEW
   EMPLOID.EMPLOCHD(A_N2).ASTALIN = [V]CST_ADEL
   [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOCHD(A_N2)._ADELETE_CONTROL_BEFORE)
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EMPLOID.EMPLOJNT) : # EMPLOJNT -- 6
 If EMPLOID.EMPLOJNT(A_N2) <> null
& and EMPLOID.EMPLOJNT(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EMPLOID.EMPLOJNT(A_N2).ASTALIN<>[V]CST_ANEW
   EMPLOID.EMPLOJNT(A_N2).ASTALIN = [V]CST_ADEL
   [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOJNT(A_N2)._ADELETE_CONTROL_BEFORE)
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EMPLOID.EMPLOEXM) : # EMPLOEXM -- 7
 If EMPLOID.EMPLOEXM(A_N2) <> null
& and EMPLOID.EMPLOEXM(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EMPLOID.EMPLOEXM(A_N2).ASTALIN<>[V]CST_ANEW
   EMPLOID.EMPLOEXM(A_N2).ASTALIN = [V]CST_ADEL
   [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOEXM(A_N2)._ADELETE_CONTROL_BEFORE)
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EMPLOID.EMPLOTRY) : # EMPLOTRY -- 8
 If EMPLOID.EMPLOTRY(A_N2) <> null
& and EMPLOID.EMPLOTRY(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EMPLOID.EMPLOTRY(A_N2).ASTALIN<>[V]CST_ANEW
   EMPLOID.EMPLOTRY(A_N2).ASTALIN = [V]CST_ADEL
   [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOTRY(A_N2)._ADELETE_CONTROL_BEFORE)
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER
A_N2=1
If EMPLOID.EMPLOIDSA(A_N2) <> null
& and EMPLOID.EMPLOIDSA(A_N2).ASTALIN<>[V]CST_ANEWDEL
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2)._ADELETE_CONTROL_AFTER)
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 For [L]A_I=1 To maxtab(EMPLOID.EMPLOIDSA(A_N2).EMPADR)
  If EMPLOID.EMPLOIDSA(A_N2).EMPADR([L]A_I)<>null
   [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2).EMPADR([L]A_I).ACTION("ADELETE_CONTROL_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Next
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 For [L]A_I=1 To maxtab(EMPLOID.EMPLOIDSA(A_N2).PASDET)
  If EMPLOID.EMPLOIDSA(A_N2).PASDET([L]A_I)<>null
   [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2).PASDET([L]A_I).ACTION("ADELETE_CONTROL_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Next
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 For [L]A_I=1 To maxtab(EMPLOID.EMPLOIDSA(A_N2).PERCNT)
  If EMPLOID.EMPLOIDSA(A_N2).PERCNT([L]A_I)<>null
   [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2).PERCNT([L]A_I).ACTION("ADELETE_CONTROL_AFTER"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Next
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
A_N2=1
If EMPLOID.EMPLOIDUKI(A_N2) <> null
& and EMPLOID.EMPLOIDUKI(A_N2).ASTALIN<>[V]CST_ANEWDEL
Endif
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EMPLOID.EMPLORIB) : # EMPLORIB -- 4
 If EMPLOID.EMPLORIB(A_N2) <> null
& and EMPLOID.EMPLORIB(A_N2).ASTALIN<>[V]CST_ANEWDEL
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLORIB(A_N2)._ADELETE_CONTROL_AFTER)
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EMPLOID.EMPLOCHD) : # EMPLOCHD -- 5
 If EMPLOID.EMPLOCHD(A_N2) <> null
& and EMPLOID.EMPLOCHD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOCHD(A_N2)._ADELETE_CONTROL_AFTER)
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EMPLOID.EMPLOJNT) : # EMPLOJNT -- 6
 If EMPLOID.EMPLOJNT(A_N2) <> null
& and EMPLOID.EMPLOJNT(A_N2).ASTALIN<>[V]CST_ANEWDEL
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOJNT(A_N2)._ADELETE_CONTROL_AFTER)
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EMPLOID.EMPLOEXM) : # EMPLOEXM -- 7
 If EMPLOID.EMPLOEXM(A_N2) <> null
& and EMPLOID.EMPLOEXM(A_N2).ASTALIN<>[V]CST_ANEWDEL
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOEXM(A_N2)._ADELETE_CONTROL_AFTER)
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EMPLOID.EMPLOTRY) : # EMPLOTRY -- 8
 If EMPLOID.EMPLOTRY(A_N2) <> null
& and EMPLOID.EMPLOTRY(A_N2).ASTALIN<>[V]CST_ANEWDEL
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOTRY(A_N2)._ADELETE_CONTROL_AFTER)
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

For [L]A_I=1 To maxtab(EMPLOID.PASDET)
 If EMPLOID.PASDET([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.PASDET([L]A_I).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For [L]A_I=1 To maxtab(EMPLOID.PERCNT)
 If EMPLOID.PERCNT([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.PERCNT([L]A_I).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_EMPLOID
Trbegin [F:ID]
 Gosub ADELETE_EMPLOID
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$ADELETE_EMPLOID
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

#-----------------------------------------------------#
A_N2=1
If EMPLOID.EMPLOIDSA(A_N2) <> null
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOIDSA(A_N2)._ADELETE)
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
A_N2=1
If EMPLOID.EMPLOIDUKI(A_N2) <> null
Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
For A_N2=1 To maxtab(EMPLOID.EMPLORIB)
 If EMPLOID.EMPLORIB(A_N2) <> null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLORIB(A_N2)._ADELETE)
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
For A_N2=1 To maxtab(EMPLOID.EMPLOCHD)
 If EMPLOID.EMPLOCHD(A_N2) <> null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOCHD(A_N2)._ADELETE)
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
For A_N2=1 To maxtab(EMPLOID.EMPLOJNT)
 If EMPLOID.EMPLOJNT(A_N2) <> null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOJNT(A_N2)._ADELETE)
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
For A_N2=1 To maxtab(EMPLOID.EMPLOEXM)
 If EMPLOID.EMPLOEXM(A_N2) <> null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOEXM(A_N2)._ADELETE)
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
For A_N2=1 To maxtab(EMPLOID.EMPLOTRY)
 If EMPLOID.EMPLOTRY(A_N2) <> null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.EMPLOTRY(A_N2)._ADELETE)
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

[L]ASTATUS = func ASYRSUB.DELETE_LINKS(EMPLOID,ALNKDELTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLOID._MAJSQL_EMPLOID(EMPLOID))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOID.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If EMPLOID.snapshotEnabled=1
 [L]A_RETIK = EMPLOID.revertUpdTick
Endif
[L]ASTATUS = max(fmet EMPLOID.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#

#-----------------------------------------------------#
$_ADELETE_AFTER
Return



