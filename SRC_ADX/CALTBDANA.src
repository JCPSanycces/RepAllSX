#<AdxTL>@(#)2.0.0.0 $Revision$
Raz GPILCOD, GBIDC1
Call OBJET("TXW",GBIDC1,GBIDC2) From GOBJET
End

####################################################################################
## Tableaux de bord : Traitement des fonctions de compta analytique
####################################################################################
$TRT_ANA
# Ouverture de la bonne balance

Case FONC
 When "NM"
  If BALANA<>1
   If clalev([F:BLA])>0 : Close Local File [BLA] : Endif
   Local File BALANA [BLA]
   BALANA = 1
  Endif
 When "EM","PM"
  If BALANA<>2
   If clalev([F:BLA])>0 : Close Local File [BLA] : Endif
   Local File BLACMM [BLA]
   BALANA = 2
  Endif
 When "NQ","EQ","PQ"
  If BALANA<>3
   If clalev([F:BLA])>0 : Close Local File [BLA] : Endif
   Local File BLAQTY [BLA]
   BALANA = 3
  Endif
 When "UM","UQ"
  If BALANA<>4
   If clalev([F:BLA])>0 : Close Local File [BLA] : Endif
   Local File BALDEM [BLA]
   BALANA = 4
  Endif
Endcase

# Décodage des arguments
Gosub SETREFANA From CALTBD
Gosub SETEXE From CALTBD
INAT  = 1
ISEC  = 2
FLAXE = 0
For I=1 To max(NARG,10) : # Nature + 9 sections
 Gosub SETARG
 If ER : Break : Endif
Next I
If BALANA=4
 For I=10 To max(NARG,20) : # Nature + 9 sections
  Gosub SETARG
  If ER : Break : Endif
 Next I
Endif
If ER : Return : Endif

# Boucle par société

For ISOC=1 To NBSOC
 Read [CPY]CPY0 = TSOC(ISOC)
 Read [GCM]GCM0 = [F:CPY]ACM
 Read [LED]LED0 = [F:GCM]LED(NUMREF-1)

 # Filtre sur la balance analytique

 Raz CRITERE
 ICRIT = 1
 Call ADDCRIT(CRITERE,ICRIT,'[BLA]LEDTYP='+num$(NUMREF)) From CALTBD
 Call ADDCRIT(CRITERE,ICRIT,'[BLA]CPY="'+TSOC(ISOC)+'"') From CALTBD
 If NBSITE=1
  Call ADDCRIT(CRITERE,ICRIT,'[BLA]FCY="'+TSITE(1)+'"') From CALTBD
 Else
  Call ADDCRIT(CRITERE,ICRIT,'find([BLA]FCY,TSITE(1..NBSITE))') From CALTBD
 Endif
 If TEDEB(ISOC)=TEFIN(ISOC)
  Call ADDCRIT(CRITERE,ICRIT,'[BLA]FIY='+num$(TEDEB(ISOC))) From CALTBD
 Else
  Call ADDCRIT(CRITERE,ICRIT,'[BLA]FIY>='+num$(TEDEB(ISOC))+' & [BLA]FIY<='+num$(TEFIN(ISOC))) From CALTBD
 Endif
 Case JOKER(INAT)
  When 0,1
   If BALANA<>4
    Call ADDJOK(CRITERE,ICRIT,'[BLA]ACC',ARG(INAT)) From CALTBD
   Else
    Call ADDJOK(CRITERE,ICRIT,'[BLA]DEBACC',ARG(INAT)) From CALTBD
    Call ADDJOK(CRITERE,ICRIT,'[BLA]CDTACC',ARG(INAT+10)) From CALTBD
   Endif
  When 2
   If BALANA<>4
    Call ADDCRIT(CRITERE,ICRIT,'[GYK]GRU="'+PYRGRP(INAT)+'"') From CALTBD
   Else
    Call ADDCRIT(CRITERE,ICRIT,'[GYK]GRU="'+PYRGRP(INAT)+'"') From CALTBD
    Call ADDCRIT(CRITERE,ICRIT,'[GYK]GRU="'+PYRGRP(INAT+10)+'"') From CALTBD
   Endif
  When 3
   If BALANA<>4
    Call ADDCRIT(CRITERE,ICRIT,'[BLA]ACC>="'+ARGDEB(INAT)+'"') From CALTBD
    Call ADDCRIT(CRITERE,ICRIT,'[BLA]ACC<="'+ARGFIN(INAT)+'"') From CALTBD
   Else
    Call ADDCRIT(CRITERE,ICRIT,'[BLA]DEBACC>="'+ARGDEB(INAT)+'"') From CALTBD
    Call ADDCRIT(CRITERE,ICRIT,'[BLA]DEBACC<="'+ARGFIN(INAT)+'"') From CALTBD
    Call ADDCRIT(CRITERE,ICRIT,'[BLA]CDTACC>="'+ARGDEB(INAT+10)+'"') From CALTBD
    Call ADDCRIT(CRITERE,ICRIT,'[BLA]CDTACC<="'+ARGFIN(INAT+10)+'"') From CALTBD
   Endif
  When 4
   If BALANA<>4
    Call ADDCRIT(CRITERE,ICRIT,'[BLA]ACC>="'+ARGDEB(INAT)+'"') From CALTBD
    Call ADDCRIT(CRITERE,ICRIT,'[BLA]ACC<="'+ARGFIN(INAT)+'"') From CALTBD
    Call ADDCRIT(CRITERE,ICRIT,'left$([BLA]ACC,'+num$(len(ARGEXC(INAT)))+')<>"'+ARGEXC(INAT)+'"') From CALTBD
   Else
    Call ADDCRIT(CRITERE,ICRIT,'[BLA]DEBACC>="'+ARGDEB(INAT)+'"') From CALTBD
    Call ADDCRIT(CRITERE,ICRIT,'[BLA]DEBACC<="'+ARGFIN(INAT)+'"') From CALTBD
    Call ADDCRIT(CRITERE,ICRIT,'left$([BLA]DEBACC,'+num$(len(ARGEXC(INAT)))+')<>"'+ARGEXC(INAT)+'"') From CALTBD
    Call ADDCRIT(CRITERE,ICRIT,'[BLA]CDTACC>="'+ARGDEB(INAT+10)+'"') From CALTBD
    Call ADDCRIT(CRITERE,ICRIT,'[BLA]CDTACC<="'+ARGFIN(INAT+10)+'"') From CALTBD
    Call ADDCRIT(CRITERE,ICRIT,'left$([BLA]CDTACC,'+num$(len(ARGEXC(INAT+10)))+')<>"'+ARGEXC(INAT+10)+'"') From CALTBD
   Endif
 Endcase
 If dim([BLA]BPR)>0 : Call ADDCRIT(CRITERE,ICRIT,'[BLA]BPR=""') From CALTBD : Endif
 For I=1 To 9
  If FLAXE
   K = 0
   For J=ISEC To ISEC+8
    If IAXE(J)=[F:LED]DIE(I-1)
     K = J : Break
    Endif
   Next J
  Else
   K = ISEC+(I-1)
  Endif
  If K
   Case JOKER(K)
    When 0,1
     If BALANA<>4
      Call ADDJOK(CRITERE,ICRIT,'[BLA]CCE'+num$(I),ARG(K)) From CALTBD
     Else
      Call ADDJOK(CRITERE,ICRIT,'[BLA]DEBCCE('+num$(I-1)+')',ARG(K)) From CALTBD
     Endif
    When 3
     If BALANA<>4
      Call ADDCRIT(CRITERE,ICRIT,'[BLA]CCE'+num$(I)+'>="'+ARGDEB(K)+'"') From CALTBD
      Call ADDCRIT(CRITERE,ICRIT,'[BLA]CCE'+num$(I)+'<="'+ARGFIN(K)+'"') From CALTBD
     Else
      Call ADDCRIT(CRITERE,ICRIT,'[BLA]DEBCCE('+num$(I-1)+')>="'+ARGDEB(K)+'"') From CALTBD
      Call ADDCRIT(CRITERE,ICRIT,'[BLA]DEBCCE('+num$(I-1)+')<="'+ARGFIN(K)+'"') From CALTBD
     Endif
    When 4
     If BALANA<>4
      Call ADDCRIT(CRITERE,ICRIT,'[BLA]CCE'+num$(I)+'>="'+ARGDEB(K)+'"') From CALTBD
      Call ADDCRIT(CRITERE,ICRIT,'[BLA]CCE'+num$(I)+'<="'+ARGFIN(K)+'"') From CALTBD
      Call ADDCRIT(CRITERE,ICRIT,'left$([BLA]CCE'+num$(I)+','+num$(len(ARGEXC(K)))+')<>"'+ARGEXC(K)+'"') From CALTBD
     Else
      Call ADDCRIT(CRITERE,ICRIT,'[BLA]DEBCCE('+num$(I-1)+')>="'+ARGDEB(K)+'"') From CALTBD
      Call ADDCRIT(CRITERE,ICRIT,'[BLA]DEBCCE('+num$(I-1)+')<="'+ARGFIN(K)+'"') From CALTBD
      Call ADDCRIT(CRITERE,ICRIT,'left$([BLA]DEBCCE('+num$(I-1)+'),'+num$(len(ARGEXC(K)))+')<>"'+ARGEXC(K)+'"') From CALTBD
     Endif
   Endcase
  Endif
 Next I
 If BALANA=4
  For I=1 To 9
   If FLAXE
    K = 0
    For J=ISEC+10 To ISEC+18
     #Sup suite Ctrl source CDTDIE n'existe pas ds LED mais ds BLADEM
     #If IAXE(J)=[F:LED]CDTDIE(I-1)
     If IAXE(J)=[F:LED]DIE(I-1)
      K = J : Break
     Endif
    Next J
   Else
    K = ISEC+10+(I-1)
   Endif
   If K
    Case JOKER(K)
     When 0,1
      Call ADDJOK(CRITERE,ICRIT,'[BLA]CDTCCE('+num$(I-1)+')',ARG(K)) From CALTBD
     When 3
      Call ADDCRIT(CRITERE,ICRIT,'[BLA]CDTCCE('+num$(I-1)+'>="'+ARGDEB(K)+')"') From CALTBD
      Call ADDCRIT(CRITERE,ICRIT,'[BLA]CDTCCE('+num$(I-1)+'<="'+ARGFIN(K)+')"') From CALTBD
     When 4
      Call ADDCRIT(CRITERE,ICRIT,'[BLA]CDTCCE('+num$(I-1)+'>="'+ARGDEB(K)+')"') From CALTBD
      Call ADDCRIT(CRITERE,ICRIT,'[BLA]CDTCCE('+num$(I-1)+'<="'+ARGFIN(K)+')"') From CALTBD
      Call ADDCRIT(CRITERE,ICRIT,'left$([BLA]CDTCCE('+num$(I-1)+'),'+num$(len(ARGEXC(K)))+')<>"'+ARGEXC(K)+'"') From CALTBD
    Endcase
   Endif
  Next I
 Endif
 If DEVSEL<>""
  Call ADDCRIT(CRITERE,ICRIT,'[BLA]CUR="'+toupper(DEVSEL)+'"') From CALTBD
 Endif
 K = 0
 For I=ISEC To ISEC+8 : If JOKER(I)=2 : K = I : Break : Endif : Next I
 If K
  Call ADDCRIT(CRITERE,ICRIT,'[CYK]GRU="'+PYRGRP(K)+'"') From CALTBD
 Endif
 If JOKER(INAT)=2
  Case K
   When 0
    Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]ACC
&                 , [GYK]GYK0 ~= PYRAMIDE(INAT);PYRNIV(INAT);[F:BLA]ACC   As [LBLA]
   When ISEC
    Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]ACC
&                 , [GYK]GYK0 ~= PYRAMIDE(INAT);PYRNIV(INAT);[F:BLA]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(K);PYRNIV(K);[F:BLA]CCE1  As [LBLA]
   When ISEC+1
    Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]ACC
&                 , [GYK]GYK0 ~= PYRAMIDE(INAT);PYRNIV(INAT);[F:BLA]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(K);PYRNIV(K);[F:BLA]CCE2  As [LBLA]
   When ISEC+2
    Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]ACC
&                 , [GYK]GYK0 ~= PYRAMIDE(INAT);PYRNIV(INAT);[F:BLA]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(K);PYRNIV(K);[F:BLA]CCE3  As [LBLA]
   When ISEC+3
    Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]ACC
&                 , [GYK]GYK0 ~= PYRAMIDE(INAT);PYRNIV(INAT);[F:BLA]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(K);PYRNIV(K);[F:BLA]CCE4  As [LBLA]
   When ISEC+4
    Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]ACC
&                 , [GYK]GYK0 ~= PYRAMIDE(INAT);PYRNIV(INAT);[F:BLA]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(K);PYRNIV(K);[F:BLA]CCE5  As [LBLA]
   When ISEC+5
    Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]ACC
&                 , [GYK]GYK0 ~= PYRAMIDE(INAT);PYRNIV(INAT);[F:BLA]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(K);PYRNIV(K);[F:BLA]CCE6  As [LBLA]
   When ISEC+6
    Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]ACC
&                 , [GYK]GYK0 ~= PYRAMIDE(INAT);PYRNIV(INAT);[F:BLA]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(K);PYRNIV(K);[F:BLA]CCE7  As [LBLA]
   When ISEC+7
    Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]ACC
&                 , [GYK]GYK0 ~= PYRAMIDE(INAT);PYRNIV(INAT);[F:BLA]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(K);PYRNIV(K);[F:BLA]CCE8  As [LBLA]
   When ISEC+8
    Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]ACC
&                 , [GYK]GYK0 ~= PYRAMIDE(INAT);PYRNIV(INAT);[F:BLA]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(K);PYRNIV(K);[F:BLA]CCE9  As [LBLA]
  Endcase
 Else
  Case K
   When 0
    If BALANA<>4 :
     Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]ACC As [LBLA]
    Else
     Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]DEBACC As [LBLA]
    Endif
   When ISEC
    Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(K);PYRNIV(K);[F:BLA]CCE1  As [LBLA]
   When ISEC+1
    Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(K);PYRNIV(K);[F:BLA]CCE2  As [LBLA]
   When ISEC+2
    Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(K);PYRNIV(K);[F:BLA]CCE3  As [LBLA]
   When ISEC+3
    Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(K);PYRNIV(K);[F:BLA]CCE4  As [LBLA]
   When ISEC+4
    Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(K);PYRNIV(K);[F:BLA]CCE5  As [LBLA]
   When ISEC+5
    Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(K);PYRNIV(K);[F:BLA]CCE6  As [LBLA]
   When ISEC+6
    Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(K);PYRNIV(K);[F:BLA]CCE7  As [LBLA]
   When ISEC+7
    Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(K);PYRNIV(K);[F:BLA]CCE8  As [LBLA]
   When ISEC+8
    Link [BLA] With [GAC]GAC0  = [F:BLA]COA;[F:BLA]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(K);PYRNIV(K);[F:BLA]CCE9  As [LBLA]
  Endcase
 Endif

 If BALANA<>4
  Filter [LBLA] Where evalue(CRITERE(1..ICRIT))
&  Order By Key CLE = [BLA]FCY;[BLA]ACC;[BLA]CCE1;[BLA]CCE2;[BLA]CCE3;[BLA]CCE4;[BLA]CCE5;
&                     [BLA]CCE6;[BLA]CCE7;[BLA]CCE8;[BLA]CCE9;[BLA]FIY;[BLA]CUR
 Else

  Filter [LBLA] Where evalue(CRITERE(1..ICRIT))
&  Order By Key CLE = [BLA]FCY;[BLA]DEBACC;[BLA]DEBCCE(0);[BLA]DEBCCE(1);[BLA]DEBCCE(2);[BLA]DEBCCE(3);[BLA]DEBCCE(4);
&                     [BLA]DEBCCE(5);[BLA]DEBCCE(6);[BLA]DEBCCE(7);[BLA]DEBCCE(8);[BLA]FIY;[BLA]CUR
 Endif

 # Parcours de la balance

 For [LBLA]CLE(1) With Nohint : # Site
  SITE  = [F:BLA]FCY
  ISITE = find(SITE,TSITE(1..NBSITE))
  If ISITE
   Gosub EVAL_INFSIT From CALTBD
   EDEB = TEDEB(ISOC)
   EFIN = TEFIN(ISOC)
   PDEB = TPDEB(ISOC)
   PFIN = TPFIN(ISOC)
   For [LBLA]CLE(2)   : # Nature
    If BALANA<>4 : NATURE  = [F:BLA]ACC : Else NATURE  = [F:BLA]DEBACC : Endif #CHECK IGNORE_LINE
    PLAN    = [F:BLA]COA
    If PLAN=""
     Read [CPY]CPY0 = [F:BLA]CPY
     Read [GCM]GCM0 = [F:CPY]ACM
     Read [LED]LED0 = [F:GCM]LED(NUMREF-1)
     PLAN           = [F:LED]COA
    Endif
    COMPTE  = NATURE     : Gosub EVAL_INFACC From CALTBD
    Case JOKER(INAT)
     When 0 : OK = (NATURE=ARG(INAT))
     When 1 : OK = pat(NATURE,ARG(INAT))
     When 2
      Read [GYK]GYK0 = PYRAMIDE(INAT);PYRNIV(INAT);NATURE
      OK = (fstat=0 & [F:GYK]GRU=PYRGRP(INAT))
     When 3 : OK = (NATURE>=ARGDEB(INAT) & NATURE<=ARGFIN(INAT))
     When 4 : OK = (NATURE>=ARGDEB(INAT) & NATURE<=ARGFIN(INAT)
&                 & left$(NATURE,len(ARGEXC(INAT)))<>ARGEXC(INAT))
    Endcase
    If OK
     Raz SIT_CPTDEB, SIT_CPTCDT
     For [LBLA]CLE(11)   : # Sections
      OK = 1
      For I=1 To [F:LED]DIENBR
       If BALANA<>4 : SECTION = evalue("[F:BLA]CCE"+num$(I)) : Else SECTION = evalue("[F:BLA]DEBCCE("+num$(I-1)+")") : Endif
       If FLAXE
        K = 0
        For J=ISEC To ISEC+8
         If IAXE(J)=[F:BLA]DIE(I-1) #CHECK IGNORE_LINE
          K = J : Break
         Endif                      #CHECK IGNORE_LINE
        Next J
       Else
        K = ISEC+(I-1)
       Endif
       If K
        Case JOKER(K)
         When 0 : OK *= (SECTION=ARG(K))
         When 1 : OK *= pat(SECTION,ARG(K))
         When 2
          Read [CYK]CYK0 = PYRAMIDE(K);PYRNIV(K);SECTION
          OK *= (fstat=0 & [F:CYK]GRU=PYRGRP(K))
         When 3 : OK *= (SECTION>=ARGDEB(K) & SECTION<=ARGFIN(K))
         When 4 : OK *= (SECTION>=ARGDEB(K) & SECTION<=ARGFIN(K)
&                      & left$(SECTION,len(ARGEXC(K)))<>ARGEXC(K))
        Endcase
       Endif
       If !OK : Break : Endif
      Next I
      If OK
       Raz MTDEB , MTCDT
       For [LBLA]CLE : # Exercice, devise
        EXE = [F:BLA]FIY
        If EXE>=EDEB & EXE<=EFIN
         Gosub SUM_ANA
         If GOK<1 : Break 3 : Endif
        Endif
       Next : # Exercice, devise
       If CREDIT=2 : Raz MTDEB : Endif
       If DEBIT=2  : Raz MTCDT : Endif
       If (DEBIT<>1 & CREDIT<>1) | (DEBIT=1 & abs(MTDEB)>=abs(MTCDT)) | (CREDIT=1 & abs(MTCDT)>=abs(MTDEB))
        SIT_DEB(ISITE)    += MTDEB
        SIT_CDT(ISITE)    += MTCDT
        SIT_CPTDEB(ISITE) += MTDEB
        SIT_CPTCDT(ISITE) += MTCDT
        If [L]DETCCE=2   : # Détail sections
         INDTXM += 1
         #CHECK IGNORE_BEGIN
         If BALANA<>4
          SECTION = [F:BLA]CCE1 : AXE = [F:BLA]DIE(0) : Gosub EVAL_INFCCE From CALTBD
         Else
          SECTION = [F:BLA]DEBCCE(0) : AXE = [F:BLA]DEBDIE(0) : Gosub EVAL_INFCCE From CALTBD
         Endif
         #CHECK IGNORE_END
         TYPMONT = 5
         Gosub ECR_ANA
        Endif
       Endif
      Endif
     Next   : # Sections
     MTDEB  = SIT_CPTDEB(ISITE)
     MTCDT  = SIT_CPTCDT(ISITE)
     If DETACC=2
      INDTXM += 1
      TYPMONT = 2
      Gosub ECR_TXM From CALTBD
      If GOK<1 : Break 2 : Endif
     Endif
     # Cas où la formule traitée = NM() -L1. Il faut mettre à jour SAI_DEB
     For I=1 To NBSITE
      If (SIT_CPTDEB(I)<>0 or SIT_CPTCDT(I)<>0)
       SAI_DEB += SIT_CPTDEB(I)-SIT_CPTCDT(I)
      Endif
     Next I
    Endif
   Next   : # Nature
  Endif
 Next : # Site
Next ISOC : # Société
Filter [BLA]
Return

$SUM_ANA
If EDEB=EFIN
 PERDEB = PDEB : PERFIN = PFIN
Elsif EXE=EDEB
 PERDEB = PDEB : PERFIN = PMAX
Elsif EXE=EFIN
 PERDEB = 1 : PERFIN = PFIN
Else
 PERDEB = 1 : PERFIN = PMAX
Endif
Case FONC
 When "NM" : # Réalisé
#CHECK FILE_DECLARE BALANA [BLA]
  If DEVPRN=[F:BLA]CUR
   MTDEB += arr(sum([F:BLA]DEB(PERDEB..PERFIN))*SIGN,AROPRN)
   MTCDT += arr(sum([F:BLA]CDT(PERDEB..PERFIN))*SIGN,AROPRN)
  Elsif DEVPRN=[F:BLA]CURLED & TYPCOURS=0
   MTDEB += arr(sum([F:BLA]DEBLED(PERDEB..PERFIN))*SIGN,AROPRN)
   MTCDT += arr(sum([F:BLA]CDTLED(PERDEB..PERFIN))*SIGN,AROPRN)
  Else
   If TYPCOURS=0 & DEVPRN<>[F:BLA]CURLED
    TYPCOURS = val(func AFNC.PARAM("CNSTYPCUR",[F:BLA]CPY))
   Endif
   Call CONVERT_TAB([F:BLA]CUR,DEVPRN,[F:BLA]CURLED,TYPCOURS,datesyst,[F:BLA]DEB,[F:BLA]DEB,STAT) From TRTDEV
   Call CONVERT_TAB([F:BLA]CUR,DEVPRN,[F:BLA]CURLED,TYPCOURS,datesyst,[F:BLA]CDT,[F:BLA]CDT,STAT) From TRTDEV
   MTDEB += arr(sum([F:BLA]DEB(PERDEB..PERFIN))*SIGN,AROPRN)
   MTCDT += arr(sum([F:BLA]CDT(PERDEB..PERFIN))*SIGN,AROPRN)
  Endif
 When "EM" : # Engagements
#CHECK FILE_DECLARE BLACMM [BLA]
  If DEVPRN=[F:BLA]CUR
   MTANA = arr(sum([F:BLA]CMM(PERDEB..PERFIN))*SIGN,AROPRN)
  Elsif DEVPRN=[F:BLA]CURLED & TYPCOURS=0
   MTANA = arr(sum([F:BLA]CMMLED(PERDEB..PERFIN))*SIGN,AROPRN)
  Else
   If TYPCOURS=0 & DEVPRN<>[F:BLA]CURLED
    TYPCOURS = val(func AFNC.PARAM("CNSTYPCUR",[F:BLA]CPY))
   Endif
   Call CONVERT_TAB([F:BLA]CUR,DEVPRN,[F:BLA]CURLED,TYPCOURS,datesyst,[F:BLA]CMM,[F:BLA]CMM,STAT) From TRTDEV
   MTANA = arr(sum([F:BLA]CMM(PERDEB..PERFIN))*SIGN,AROPRN)
  Endif
  If MTANA>0
   MTDEB += MTANA
  Else
   MTCDT -= MTANA
  Endif
 When "PM" : # Pré-engagements
  If DEVPRN=[F:BLA]CUR
   MTANA = arr(sum([F:BLA]CMMPRP(PERDEB..PERFIN))*SIGN,AROPRN)
  Elsif DEVPRN=[F:BLA]CURLED & TYPCOURS=0
   MTANA = arr(sum([F:BLA]CMMPRPLED(PERDEB..PERFIN))*SIGN,AROPRN)
  Else
   If TYPCOURS=0 & DEVPRN<>[F:BLA]CURLED
    TYPCOURS = val(func AFNC.PARAM("CNSTYPCUR",[F:BLA]CPY))
   Endif
   Call CONVERT_TAB([F:BLA]CUR,DEVPRN,[F:BLA]CURLED,TYPCOURS,datesyst,[F:BLA]CMMPRP,[F:BLA]CMMPRP,STAT) From TRTDEV
   MTANA = arr(sum([F:BLA]CMMPRP(PERDEB..PERFIN))*SIGN,AROPRN)
  Endif
  If MTANA>0
   MTDEB += MTANA
  Else
   MTCDT -= MTANA
  Endif
 When "UM" : # Russe
#CHECK FILE_DECLARE BALDEM [BLA]
  If DEVPRN=[F:BLA]CUR
   MTDEB += arr(sum([F:BLA]AMTCUR(PERDEB..PERFIN))*SIGN,AROPRN)
#   MTCDT += arr(sum([F:BLA]AMTCUR(PERDEB..PERFIN))*SIGN,AROPRN)
  Elsif DEVPRN=[F:BLA]CURLED & TYPCOURS=0
   MTDEB += arr(sum([F:BLA]AMTLED(PERDEB..PERFIN))*SIGN,AROPRN)
#   MTCDT += arr(sum([F:BLA]AMTLED(PERDEB..PERFIN))*SIGN,AROPRN)
  Else
   If TYPCOURS=0 & DEVPRN<>[F:BLA]CURLED
    TYPCOURS = val(func AFNC.PARAM("CNSTYPCUR",[F:BLA]CPY))
   Endif
   Call CONVERT_TAB([F:BLA]CUR,DEVPRN,[F:BLA]CURLED,TYPCOURS,datesyst,[F:BLA]AMTCUR,[F:BLA]AMTCUR,STAT) From TRTDEV
   MTDEB += arr(sum([F:BLA]AMTCUR(PERDEB..PERFIN))*SIGN,AROPRN)
#   MTCDT += arr(sum([F:BLA]AMTCUR(PERDEB..PERFIN))*SIGN,AROPRN)
  Endif
 When "UQ" : # Quantités Russe
  MTDEB += sum([F:BLA]QTY(PERDEB..PERFIN))*SIGN
 When "NQ" : # Quantités réalisées
#CHECK FILE_DECLARE BLAQTY [BLA]
# <JFL - 14/03/2007 - correction du bug 39861>
# le signe n'était pas pris en compte dans les formules calculant les quantités
  MTDEB += sum([F:BLA]QTY(PERDEB..PERFIN))*SIGN
 When "EQ" : # Quantités engagées
  MTDEB += sum([F:BLA]QTYCMM(PERDEB..PERFIN))*SIGN
 When "PQ" : # Quantités pré-engagées
  MTDEB += sum([F:BLA]QTYPRP(PERDEB..PERFIN))*SIGN
Endcase
Return

$SETARG
#
# L'argument peut être une variable
#
If func SUBTXSB.EXISTE(ARG(I))
 Call REPLACE(ARG(I),ARG(I)) From SUBTXSB
Endif
#
# Un argument vide est remplacé par "*"
#
If ARG(I)=""
 ARG(I) = "*"
Endif
#
# Un argument peut contenir un axe
#
K = instr(1,ARG(I),":")
If K
 FLAXE   = 1
 IAXE(I) = left$(ARG(I),K-1)
 ARG(I)  = right$(ARG(I),K+1)
 If func SUBTXSB.EXISTE(IAXE(I))
  Call REPLACE(IAXE(I),IAXE(I)) From SUBTXSB
 Endif
 Read [DIE]DIE0 = IAXE(I)
 If fstat
  ER = 3 : ERARG = IAXE(I)
  Return
 Endif
Endif
#
# Borne début-fin
#
K = instr(1,ARG(I),"..")
If K
 ARGDEB(I) = left$(ARG(I),K-1)
 ARGFIN(I) = right$(ARG(I),K+2)+chr$(255)
 JOKER(I)  = 3
 Return
Endif
#
# Exclusion
#
K = instr(1,ARG(I),"(")
If K
 ARGDEB(I) = left$(ARG(I),K-1)
 ARGFIN(I) = ARGDEB(I)+chr$(255)
 ARGEXC(I) = ARGDEB(I)+seg$(ARG(I),K+1,len(ARG(I))-1)
 JOKER(I)  = 4
 Return
Endif
#
# On peut l'exprimer sous forme pyramide.groupe
#
K = instr(1,ARG(I),".")
If K
 JOKER(I)    = 2
 PYRAMIDE(I) = left$(ARG(I),K-1)
 If func SUBTXSB.EXISTE(PYRAMIDE(I))
  Call REPLACE(PYRAMIDE(I),PYRAMIDE(I)) From SUBTXSB
 Endif
 PYRGRP(I)   = right$(ARG(I),K+1)
 If func SUBTXSB.EXISTE(PYRGRP(I))
  Call REPLACE(PYRGRP(I),PYRGRP(I)) From SUBTXSB
 Endif
 If I=INAT
  Read [GYM]GYM0 = PYRAMIDE(I)
  If fstat
   ER = 17 : ERARG = PYRAMIDE(I)
   Return
  Endif
  Read [GRY]GRY0(2) = PYRAMIDE(I);PYRGRP(I)
  If fstat
   ER = 17 : ERARG = PYRGRP(I)
   Return
  Endif
  PYRNIV(I)  = [F:GRY]LEV
 Else
  Read [CYM]CYM0 = PYRAMIDE(I)
  If fstat
   ER = 18 : ERARG = PYRAMIDE(I)
   Return
  Endif
  Read [CRY]CRY0(2) = PYRAMIDE(I);PYRGRP(I)
  If fstat
   ER = 18 : ERARG = PYRGRP(I)
   Return
  Endif
  PYRNIV(I)  = [F:CRY]LEV
 Endif
Elsif ARG(I)=vireblc(format$("K:80c",ARG(I)),2)
 JOKER(I) = 0
Else
 JOKER(I) = 1
Endif
# Pas de gestion des pyramides pour la balance Russe.
If BALANA=4 & JOKER(I)=2 : JOKER(I)=0 : Endif
Return

###############################################################################
## Ecriture
###############################################################################
$ECR_ANA
Raz [F:TXM]
[F:TXM]TXSNAM  = [M]TXSNAM
[F:TXM]VERSION = [M]VERSION
[F:TXM]LIG     = IL
[F:TXM]COL     = IC+1
[F:TXM]IND     = INDTXM
[F:TXM]AMTDEB  = num$(MTDEB)
[F:TXM]AMTCDT  = num$(MTCDT)
[F:TXM]AMTVAL  = num$(MTDEB - MTCDT)
[F:TXM]FCY     = SITE
[F:TXM]COA     = PLAN
[F:TXM]ACC     = NATURE
If BALANA<>4
[F:TXM]CCE1    = [F:BLA]CCE1
[F:TXM]CCE2    = [F:BLA]CCE2
[F:TXM]CCE3    = [F:BLA]CCE3
[F:TXM]CCE4    = [F:BLA]CCE4
[F:TXM]CCE5    = [F:BLA]CCE5
[F:TXM]CCE6    = [F:BLA]CCE6
[F:TXM]CCE7    = [F:BLA]CCE7
[F:TXM]CCE8    = [F:BLA]CCE8
[F:TXM]CCE9    = [F:BLA]CCE9
[F:TXM]DIE1    = [F:BLA]DIE(0)
[F:TXM]DIE2    = [F:BLA]DIE(1)
[F:TXM]DIE3    = [F:BLA]DIE(2)
[F:TXM]DIE4    = [F:BLA]DIE(3)
[F:TXM]DIE5    = [F:BLA]DIE(4)
[F:TXM]DIE6    = [F:BLA]DIE(5)
[F:TXM]DIE7    = [F:BLA]DIE(6)
[F:TXM]DIE8    = [F:BLA]DIE(7)
[F:TXM]DIE9    = [F:BLA]DIE(8)
Else
#CHECK IGNORE_BEGIN
[F:TXM]CCE1    = [F:BLA]DEBCCE(0)
[F:TXM]CCE2    = [F:BLA]DEBCCE(1)
[F:TXM]CCE3    = [F:BLA]DEBCCE(2)
[F:TXM]CCE4    = [F:BLA]DEBCCE(3)
[F:TXM]CCE5    = [F:BLA]DEBCCE(4)
[F:TXM]CCE6    = [F:BLA]DEBCCE(5)
[F:TXM]CCE7    = [F:BLA]DEBCCE(6)
[F:TXM]CCE8    = [F:BLA]DEBCCE(7)
[F:TXM]CCE9    = [F:BLA]DEBCCE(8)
[F:TXM]DIE1    = [F:BLA]DEBDIE(0)
[F:TXM]DIE2    = [F:BLA]DEBDIE(1)
[F:TXM]DIE3    = [F:BLA]DEBDIE(2)
[F:TXM]DIE4    = [F:BLA]DEBDIE(3)
[F:TXM]DIE5    = [F:BLA]DEBDIE(4)
[F:TXM]DIE6    = [F:BLA]DEBDIE(5)
[F:TXM]DIE7    = [F:BLA]DEBDIE(6)
[F:TXM]DIE8    = [F:BLA]DEBDIE(7)
[F:TXM]DIE9    = [F:BLA]DEBDIE(8)
#CHECK IGNORE_END
Endif
[F:TXM]FCYINF  = SITINF
[F:TXM]ACCINF  = CPTINF
[F:TXM]CCEINF  = CCEINF
[F:TXM]TYPAMT  = TYPMONT
Write [TXM]
If fstat
 GOK=0 : Call FSTA("TXM") From GLOCK
Endif
Return
