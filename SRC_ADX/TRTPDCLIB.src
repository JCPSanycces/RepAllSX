#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################################
# 09/07/12 PAYMENT DAYS IN CUSTOMER FUNCTION SAM #82280                     #
#                                                                           #
#############################################################################
# $INICRE/INIMOD                                                                   #
#       Pass the values in the screen (J1,J2,...J6) to the fields in the    #
#       in the table BPCUSTOMER DAYMON(0..5)                                #
# $LIENS                                                                    #
#       Pass the values in the table BPCUSTOMER DAYMON(0..5) to the fields  #
#       in the screen (J1,J2,...J6)                                         #
#############################################################################
$INICRE
$INIMOD
[F:BPC]DAYMON(0) = [M:BPC3]J1
[F:BPC]DAYMON(1) = [M:BPC3]J2
[F:BPC]DAYMON(2) = [M:BPC3]J3
[F:BPC]DAYMON(3) = [M:BPC3]J4
[F:BPC]DAYMON(4) = [M:BPC3]J5
[F:BPC]DAYMON(5) = [M:BPC3]J6
Return
$LIENS
[M:BPC3]J1 = [F:BPC]DAYMON(0)
[M:BPC3]J2 = [F:BPC]DAYMON(1)
[M:BPC3]J3 = [F:BPC]DAYMON(2)
[M:BPC3]J4 = [F:BPC]DAYMON(3)
[M:BPC3]J5 = [F:BPC]DAYMON(4)
[M:BPC3]J6 = [F:BPC]DAYMON(5)
Return

##################################################
Subprog CONTDAYMON(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0
 If VALEUR>30 and VALEUR<>99: mkstat=2: End: Endif
 Case zoncou
  When "J2": If VALEUR<=[M:BPC3]J1: mkstat=2: Endif
  When "J3": If VALEUR<=[M:BPC3]J2: mkstat=2: Endif
  When "J4": If VALEUR<=[M:BPC3]J3: mkstat=2: Endif
  When "J5": If VALEUR<=[M:BPC3]J4: mkstat=2: Endif
  When "J6": If VALEUR<=[M:BPC3]J5: mkstat=2: Endif
 Endcase
Endif
End

Subprog AMDAYMON(VALEUR)
Variable Decimal VALEUR
Local Integer NJ:  NJ=val(mid$(zoncou,2,1))
If (VALEUR=0 or VALEUR=99) and NJ<>6

 For X=NJ+1 To 6
   Assign "[M:BPC3]J"+num$(X) With 0
 Next
   Affzo [M:BPC3]J1 - J6
Endif
End
