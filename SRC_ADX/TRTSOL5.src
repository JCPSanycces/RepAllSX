#<AdxTL>@(#)11.0.0.0 $Revision$
##########################################################################################################
# Mots-clés existants                                                  Module CRM         12 octobre 2000
##########################################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When "MEN"          : Gosub ONMENU
 When "FIR"          : Gosub PREMIER
 When "PRE"          : Gosub PRECEDENT
 When "SUI"          : Gosub SUIVANT
 When "LAS"          : Gosub DERNIER
 When Default
Endcase
Return

##########################################################################################################
$OUVRE
#Global Char GSZSELKWD
Global Integer GKWDFOUND
Global Integer GIFIRKWD
#GSZSELKWD = ""
GKWDFOUND = 0
GIFIRKWD = 0

If !clalev([F:EKW]) : Local File EXKWORD [EKW] : Endif
Return

##########################################################################################################
$PREMIER
Local Integer I
I = 0

Raz [M:SOL5]

Filter [EKW] Where [F:EKW]KEYWRD >= "" Order By [F:EKW]KEYWRD Asc

For [EKW]
    If  I >= dim([M:SOL5]KEYWRD) - 1 : Break : Endif
    [M:SOL5]KEYWRD(I) = [F:EKW]KEYWRD
    I += 1
Next

Filter [EKW]

If I = 0
    GMESSAGE = mess(327, 196, 2)  #Aucun mot-clé n'est définie dans l'application.
    GERR = 2
    FIN = 1
    Return
Endif

GKWDFOUND = 1
[M:SOL5]NBKWD = I
Affzo [M:SOL5]1-99
Return

##########################################################################################################
$PRECEDENT
Local Integer I
Local Integer I2
Local Integer IFSTEP
Local Char SZFIRWORD
IFSTEP = 1
I = 0
I2 = 0
SZFIRWORD = [M:SOL5]KEYWRD(0)

If SZFIRWORD = "" : Return : Endif

Read [EKW] First
If [F:EKW]KEYWRD = SZFIRWORD
    Return
Endif

Raz [M:SOL5]

For I = 0 To dim([M:SOL5]KEYWRD) - 1
    If IFSTEP
        Read [EKW] EKW0 = SZFIRWORD
        If fstat
            Gosub PREMIER
            Return
        Else
            I2 = dim([M:SOL5]KEYWRD) - I
            I2 = I2 - 1
            [M:SOL5]KEYWRD(I2) = [F:EKW]KEYWRD
        Endif
        IFSTEP = 0
    Else
        Read [EKW] Prev
        If fstat
            Gosub PREMIER
            Return
        Else
            I2 = dim([M:SOL5]KEYWRD) - I
            I2 = I2 - 1
            [M:SOL5]KEYWRD(I2) = [F:EKW]KEYWRD
        Endif
    Endif
Next

GKWDFOUND = 1
[M:SOL5]NBKWD = I
Affzo [M:SOL5]1-99
Return

##########################################################################################################
$SUIVANT
Local Integer I
Local Integer Z
I = 0
Z = 0

If [M:SOL5]KEYWRD(0) = "" : Return : Endif

If nbrecord([EKW]) <= dim([M:SOL5]KEYWRD)
    Gosub PREMIER
    Return
Endif

I = 0 
For I = 0 To dim([M:SOL5]KEYWRD) - 1
    If  I >= dim([M:SOL5]KEYWRD) - 1 : Break : Endif
    If [M:SOL5]KEYWRD(I) = "" : Break : Endif
    Z += 1
Next

Z = Z - 1

Filter [EKW] Where [F:EKW]KEYWRD >= [M:SOL5]KEYWRD(Z) Order By [F:EKW]KEYWRD Asc

Raz [M:SOL5]

I = 0
For [EKW]
    If  I >= dim([M:SOL5]KEYWRD) - 1 : Break : Endif
    [M:SOL5]KEYWRD(I) = [F:EKW]KEYWRD
    I += 1
Next

Filter [EKW]

GKWDFOUND = 1
[M:SOL5]NBKWD = I
Affzo [M:SOL5]1-99
Return

##########################################################################################################
$DERNIER
Local Integer I
Local Integer I2
Local Integer IFSTEP
I = 0
I2 = 0
IFSTEP = 1

If [M:SOL5]KEYWRD(0) = "" : Return : Endif

If nbrecord([EKW]) <= dim([M:SOL5]KEYWRD)
    Gosub PREMIER
    Return
Endif

For I = 0 To dim([M:SOL5]KEYWRD) - 1
    If IFSTEP
        Read [EKW] Last
        If !fstat
            I2 = dim([M:SOL5]KEYWRD) - I
            I2 = I2 - 1
            [M:SOL5]KEYWRD(I2) = [F:EKW]KEYWRD
        Endif
        IFSTEP = 0
    Else
        Read [EKW] Prev
        If !fstat
            I2 = dim([M:SOL5]KEYWRD) - I
            I2 = I2 - 1
            [M:SOL5]KEYWRD(I2) = [F:EKW]KEYWRD
        Endif
    Endif
Next

GKWDFOUND = 1
[M:SOL5]NBKWD = I
Affzo [M:SOL5]1-99
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Gosub LOADKWD
#GSZSELKWD = [M:SOL5]KEYWRD(0)
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
If GKWDFOUND
    #Nettoie l'écran avant de partir.
    Raz [M:SOL5]
Endif
#Kill GSZSELKWD
Kill GKWDFOUND
Kill GIFIRKWD
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Case BOUT
    When "A"
        Gosub ONSELECT
    When Default
Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
#
# ONSELECT : Traitement du bouton Sélectionner.
# LOADKWD  : Chargement du tableau des mots-clés.
#
#########################################################

##########################################################################################################
# Traitement du bouton Sélectionner
#########################################################
$ONSELECT
VALEUR = [M:SOL5]KEYWRD(nolign - 1)
Affzo [M:SOL5]1-99
mkstat = 4
FIN = 1
Return

##########################################################################################################
$LOADKWD
Local Integer I
Local Char SZSTRDEB
I = 0
SZSTRDEB = left$(VALEUR, 1)

Raz [M:SOL5]

Filter [EKW] Where [F:EKW]KEYWRD >= SZSTRDEB Order By [F:EKW]KEYWRD Asc

For [EKW]
    If  I >= dim([M:SOL5]KEYWRD) - 1 : Break : Endif
    [M:SOL5]KEYWRD(I) = [F:EKW]KEYWRD
    I += 1
Next

Filter [EKW]

If I = 0
    GMESSAGE = mess(327, 196, 2)  #Aucun mot-clé n'est définie dans l'application.
    GERR = 2
    FIN = 1
    Return
Endif

GKWDFOUND = 1
[M:SOL5]NBKWD = I
Affzo [M:SOL5]1-99
Return

