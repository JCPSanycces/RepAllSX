#<AdxTL>@(#)5.0.0.0 $Revision$

##################################################################################
# UPROPLN 01/10/2008 FQ54311                                                                      
# MWA - Suppression des enregistrements de la table PROPLN sans correspondance  
#       dans la table PRPPLNH
##################################################################################

 If (1=0) Then
 # Passage en test
 Call OUVRE_TRACE("SYNCHRONISATION PROPLN en fonction de PROPLNH") From LECFIC
 Call PATCH(nomap)
 Call LEC_TRACE() From LECFIC
 Else
 # Passage en réel
 Call PATCH(nomap)
 Endif

End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(PAPPLI)
Value Char    PAPPLI
If filinfo(filpath("FIL","PROPLNH","fde",PAPPLI),0)<=0 or
&  filinfo(filpath("FIL","PROPLN" ,"fde",PAPPLI),0)<=0 
    End
Else
  Gosub MAJ_PROPLN
Endif

End
########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(PAPPLI)
  Value Char PAPPLI
  Gosub MAJ_PROPLN
End
#==========================================================
#######################################################################
$MAJ_PROPLN

 
  # A ne pas faire sur le dossier racine.
  If ( PAPPLI=adxmother(0) ) Then : Return : Endif


  If filinfo(filpath("FIL","PROPLNH","fde",PAPPLI),0)<=0 or
&    filinfo(filpath("FIL","PROPLN" ,"fde",PAPPLI),0)<=0 
     # Tables n'existent pas 
     Return
  Endif

  #-----
  Call ECR_TRACE("UPROPLN: Update RELEASE for Folder "+PAPPLI,0) From GESECRAN

  If  clalev([PPH])  : Close File [PPH]  : Endif
  Local File  =PAPPLI+".PROPLNH"  [PPH]  
  If  clalev([PPL])  : Close File [PPL]  : Endif
  Local File  =PAPPLI+".PROPLN"   [PPL]  
  If  clalev([PPL2]) : Close File [PPL2] : Endif
  Local File  =PAPPLI+".PROPLN"   [PPL2]  

  Local Char WPROPLN

  Trbegin [PPL]
  # >>>>>>>>>>>>>>>>
  For [PPL] PPL0(1) 
    WPROPLN = [F:PPL]PROPLN
    Filter [PPH] Where PROPLN=WPROPLN
    Read [PPH] First
    If (fstat) Then
      Delete [PPL2] Where PROPLN=WPROPLN
      If ( fstat ) Then
        Call ECR_TRACE("UPROPLN - "-"I/O error fstat = "-num$(fstat)-" When deleting"-WPROPLN, 1) From GESECRAN
      Else  
        Call ECR_TRACE("UPROPLN - Production plan "-WPROPLN-" doesn't exist, "-num$(adxdlrec)-"line(s) hes been deleted", 0) From GESECRAN  
      Endif
    Endif
    Filter [PPH] 
  Next
  # <<<<<<<<<<<<<<<<<<

 Commit

Return
#######################################################################




