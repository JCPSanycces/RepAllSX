#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion du fichier GVARGAU
Call OBJET("GVG",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "LIENS"       : Gosub LIENS
 When "OUVRE"       : Gosub OUVRE
 When "SETBOUT"     : Gosub SETBOUT
 When "VERIF_CRE"   : Gosub VERIF
 When "VERIF_MOD"   : Gosub VERIF
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF 
 When "VERF_ANU"    : Gosub VERF_ANU
 When "ANNULE"      : Gosub ANNULE
 When "AP_CHANGE"   : Gosub AP_CHANGE
Endcase
Return

$SETBOUT
If CLECUR=0 | REP="M" | VERROU=0
 Call VIREBOUT(CHAINE,"1") From GOBJET
Endif
Return

$OUVRE
If clalev([F:GVP])=0 : Local File GVARPARGAU [GVP] : Endif
If clalev([F:GVA])=0 : Local File GVARCODPAR [GVA] : Endif
Return

$VERIF
If !find(1,[M]ADRVAL(0..[M]NBPAR-1))
 ## La variable doit contenir un paramètre par adresse
 GMESSAGE = mess(162,105,1)
 GERR = 1 : OK = 0
 zonsui = "NBPAR"
 Return  
Endif
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
For nolign=1 To [M]NBPAR
 Raz [F:GVP]
 [F:GVP] = [M:GVG]
 [F:GVP]NOPAR = nolign
 Write [GVP]
 If fstat
  GOK=0 : Call FSTA("GVP") From GLOCK : Break
 Endif
Next nolign
Return

$MODIF
Delete [GVP] Where CODVAR = CLECUR1
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("GVP",CLECUR1) From GLOCK : Return
Endif
Gosub CREATION
Return

$LIENS
Call LECTEXTRA([M]DESTRA,"GVARGAU","DESTRA",[M]CODVAR,"") From ATEXTRA
nolign = 0
For I=0 To dim([M]ZINFO)-1
 Call TEXTE([M]INFO(I),[M]ZINFO(I)) From OBJDIV
Next I
For [GVP]GVP0 Where CODVAR=[F:GVG]CODVAR
 Read [GVA]GVA0 = [F:GVP]CODPAR
 nolign += 1
 [M:GVG] = [F:GVP]
 [M:GVG] = [F:GVA]
 Call LECTEXTRA([M]DESTRAPAR(nolign-1),"GVARCODPAR","DESTRA",[M]CODPAR(nolign-1),"") From ATEXTRA
Next
[M:GVG]NBPAR = nolign
Return

$ANNULE
Call SUPTEXTRA("GVARGAU","DESTRA",[M]CODVAR,"") From ATEXTRA
Return

$AP_CHANGE
Call CHGTEXTRA("GVARGAU","DESTRA",[M]CODVAR,"",NCODE,"") From ATEXTRA
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GVARGAU","DESTRA",CLECUR1,"","GVARGAU","DESTRA",[M]CODVAR,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESTRA,"GVARGAU","DESTRA",[M]CODVAR,"") From ATEXTRA
Return

$VERF_ANU
## On vérifie que la variable n'est pas défini dans une ligne de pièce auto...
Local File GAUTACEF [GAG]
If clalev([F:GAG])=0 : Local File GAUTACEF [GAG] : Endif

Local Char    MESSA2(50) 
Local Char    TVARIA(15)(1..10)
Local Integer I, STAT2, NBVAR

For [GAG]GAG0 Where FORCLC<>"" & instr(1,FORCLC,"V_")
 Raz TVARIA, NBVAR, STAT2, MESSA2
 Call CHARGE_VARIABLE([F:GAG]FORCLC,TVARIA,NBVAR,MESSA2,STAT2) From TRTVARPAR
 If !STAT2 & NBVAR
  For I=1 To NBVAR
   If TVARIA(I) = [F:GVG]CODVAR
    ## Variable définie dans la pièce automatique
    Call ERREUR(mess(163,105,1)-[F:GAG]COD-num$([F:GAG]LINNUM)-[F:GAG]FLD) From GESECRAN
    OK = 0 : Break 2
   Endif
  Next
 Endif
Next
Return

###############################################################################
##  Copie
###############################################################################
$TRTCOP
If [M]DOSORG=nomap 
 Local File GVARGAU    [GVG1]
 Local File GVARPARGAU [GVP1]
 Local File GVARCODPAR [GVA1]
 Local File ATEXTE     [ATX1] 
 Local File ATEXTRA  [AXX1] 
Else 
 Local File =[M]DOSORG+".GVARGAU" [GVG1]
 Local File =[M]DOSORG+".GVARPARGAU" [GVP1] 
 Local File =[M]DOSORG+".GVARCODPAR" [GVA1]
 Local File =[M]DOSORG+".ATEXTE"     [ATX1]  
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1] 
Endif 
If [M]DOSDES=nomap 
 Local File GVARGAU    [GVG2]
 Local File GVARPARGAU [GVP2]
 Local File GVARCODPAR [GVA2]
 Local File ATEXTE     [ATX2] 
 Local File ATEXTRA  [AXX2] 
Else 
 Local File =[M]DOSDES+".GVARGAU"    [GVG2]
 Local File =[M]DOSDES+".GVARPARGAU" [GVP2] 
 Local File =[M]DOSDES+".GVARCODPAR" [GVA2]
 Local File =[M]DOSDES+".ATEXTE"     [ATX2]  
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2] 
Endif 
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [GVG1], [GVP1], [GVG2], [GVP2], [GVA1], [GVA2], [ATX1], [ATX2]
Close Local File [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [GVG2] , [GVP2] , [GVA2], [ATX2]
 Delete [GVG2] Where CODVAR=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".GVARGAU" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("GVG2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [GVP2] Where CODVAR=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".GVARPARGAU" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("GVP2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [GVG1] Where CODVAR=TABLE
  [F:GVG2] = [F:GVG1]
  Call COPTEXTRA("GVARGAU","DESTRA",TABLE,"") From ATEXTRA
  Call COPTEXTRA("GVARGAU","SHOTRA",TABLE,"") From ATEXTRA
  If dim([F:GVG2]UPDUSR)>0 : [F:GVG2]UPDUSR = GUSER : Endif
  If dim([F:GVG2]UPDDAT)>0 : [F:GVG2]UPDDAT = date$ : Endif
  If GOK<1 : Break : Endif
  For I=0 To dim([F:GVG]INFO)-1
   Call COPTEXTE([F:GVG1]INFO(I),[F:GVG2]INFO(I)) From OBJDIV
   If GOK<1 : Break 2 : Endif
  Next I
  Write [GVG2]
  If fstat
   GOK = 0 : Call FSTA("GVG2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [GVP1] Where CODVAR=TABLE
  [F:GVP2] = [F:GVP1]
  If GOK<1 : Break : Endif
  Write [GVP2]
  If fstat
   GOK = 0 : Call FSTA("GVP2") From GLOCK : Break
  Endif
  Read [GVA1]GVA0 = [F:GVP1]CODPAR
  If !fstat
   Readlock [GVA2]GVA0 = [F:GVA1]CODPAR
   If fstat=1
    GOK=-1 : GLOCK = "$GVARCODPAR"-[F:GVP1]CODPAR : Break
   Elsif fstat
    [F:GVA2] = [F:GVA1]
    Call COPTEXTRA("GVARCODPAR","DESTRA",[F:GVA2]CODPAR,"") From ATEXTRA
    Write [GVA2]
   Else
    [F:GVA2] = [F:GVA1]
    Call COPTEXTRA("GVARCODPAR","DESTRA",[F:GVA2]CODPAR,"") From ATEXTRA
    Rewrite [GVA2]
   Endif
   If fstat
    GOK=0 : Call FSTA("GVA2") From GLOCK : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

##########################################################################
# Etiquettes du masque GVG1
##########################################################################

Subprog C_CODTRT(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
Local Integer OK
Call EXISTE_ADX("","",VALEUR,OK) From ORDSYS
If !OK
 # Traitement inexistant
 OK = 2 : Call AVERTIR(mess(90,123,1),OK) From GESECRAN
 If OK<>2 : mkstat = 2 : End : Endif
Endif
End

Subprog B1_SUBPRG(VALEUR)
Variable Char    VALEUR()
If [M]CODTRT<>"" & VALEUR<>""
 Call ETIQUETTE(VALEUR,[M]CODTRT,[M]NBPAR,"[M:GVG]CODPAR","[M:GVG]TYPPAR","[M:GVG]ADRVAL") From TRTTRT
Endif
End

Subprog C_CODPAR(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]CODPAR) From OBJDIV
End

Subprog AM_CODPAR(VALEUR)
Variable Char    VALEUR()
Read [GVA]GVA0 = VALEUR
If fstat
 Local Integer OK
 # Paramètre inexistant, création
 OK = 1 : Call OUINON(mess(24,124,1),OK) From GESECRAN
 If OK=2
  Call CRE_PAR(VALEUR) From SUBGVA
 Endif
 mkstat = 2 : End
Endif
End

Subprog AV_ZINTITPAR(VALEUR)
Variable Char    VALEUR()
If [M]CODPAR(nolign-1)<>""
 Call LECTURE("GVA",[M]CODPAR(nolign-1),"") From CONTOBJ
 [M]INTITPAR(indice) = [F:GVA]INTITPAR
 Call LECTEXTRA(VALEUR,"GVARCODPAR","DESTRA",[M]CODPAR(nolign-1),"") From ATEXTRA
 #Call TEXTE([F:GVA]INTITPAR,VALEUR) From OBJDIV
Endif
End

Subprog AV_TYPPAR(VALEUR)
Variable Integer VALEUR()
If [M]CODPAR(nolign-1)<>""
 Call LECTURE("GVA",[M]CODPAR(nolign-1),"") From CONTOBJ
 VALEUR = [F:GVA]TYPPAR
Endif
End

Subprog AS_ADRVAL(VALEUR)
Variable Integer VALEUR
Local Integer I
Gosub SETNOL
# La variable doit contenir un et un seul paramètre par adresse
I = find(1,[M]ADRVAL(0..NOL-1),[M]ADRVAL(NOL+1..dim([M]ADRVAL)-1))
If I
 VALEUR = 2 : mkstat = 2 : End
Endif
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

