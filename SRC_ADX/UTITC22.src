##########################################################################
# UTITC22   Table ROUTING les désignations deviennent          Module TC #
#           traduisibles                                                 #
##########################################################################
# FGR 07/10/2009 : X3SUIVI53694
##########################################################################
Local Char DOSSIER(30)

  If 0=1 Then
    DOSSIER = nomap
    # Issue 108760 - 2015-08-07 by MAE :
    #Call SAIDOS(DOSSIER,"") From SAIDOS
    Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
    If DOSSIER <> "" Then
      If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
      # Issue 108760 - 2015-08-07 by MAE :
      #Read [ADS]DOSSIER=[L]DOSSIER
      #If fstat THEN
      #  Raz [F:ADS]
      #Endif
      If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE("Correction") From LECFIC
      Call MAJ_UTITC22(DOSSIER)
      Call TEMPOFF     From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
  Else
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    For [ADS]DOSSIER
      If [F:ADS]DOSSIER <> "X3INDV6" and [F:ADS]DOSSIER <> "X3TESTV6" Then
        DOSSIER = [F:ADS]DOSSIER
        Call MAJ_UTITC22(DOSSIER)
      Endif
    Next
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC22(SZAPPLI)
Value Char SZAPPLI

Local Integer INB
Local Integer IERR

  INB = 0
  Call ECR_TRACE("UTITC22: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Revalidation de tous les écrans ayant ACS comme type de donnée, et non superviseur
  #
  Local File =SZAPPLI + ".AMSKZON" [AMZW]
  Local File =SZAPPLI + ".AMSK"    [AMKW]
  #
  Link [AMZW] With [AMKW]CODMSK=[F:AMZW]CODMSK As [NEWW]
  Filter [NEWW] Where [F:AMZW]CODTYP = "ACS" and [F:AMKW]MODULE <> 1 and [F:AMKW]MODULE <> 11
  For [NEWW]
    Call VALID([F:AMKW]CODMSK, SZAPPLI, [F:ADS]NBRLAN, [F:ADS]LAN, 1, IERR) From VALMSK
    Call ECR_TRACE("Valid Screen " - [F:AMKW]CODMSK-"/["+[F:AMKW]ABRMSK + "]", 0) From GESECRAN
    INB += 1
  Next
  Filter [NEWW]
  #
  Call ECR_TRACE("UTITC22 : records processed" - num$(INB), 0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS]DOSSIER=APPLI
  #If fstat THEN
  #  Raz [F:ADS]
  #Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"AMSKZON") : End : Endif
  # End MAE 108760
  Call MAJ_UTITC22(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If func DOSVUE.ISVIEW(APPLI,"AMSKZON") : End : Endif
  Call MAJ_UTITC22(APPLI)
End

