#<AdxTL>@(#)11.0.0.0 $Revision$
######################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

  Call EXEC(NBPAR,PARAMETRE)
End

######################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value Integer    NBPAR 
Variable Char    PARAMETRE()()

Local Integer IPERF
Local Integer IPBL    #Statut d'erreur
Local Integer INTR
Local Integer IMAX
Local Integer ICOUNT
Local Integer IAFFOK
Local Char SZMESS

  Gosub OUVRE 
  If GERREUR Then
    GERREUR = 0
    End
  Endif 
  Gosub DECLARE 
  [L]CRITERE  = "1=1"
  [L]CRITERE1 = "& 1=1"
  [L]CRITERE2 = "& 1=1"
  [L]CRITERE3 = "& 1=1"
  For I = 1 To NBPAR
    J = instr(1,[L]PARAMETRE(I),"=")
    If J Then
      [L]PARAM  = left$([L]PARAMETRE(I),J-1)
      [L]VALEUR = right$([L]PARAMETRE(I),J+1)
      Case [L]PARAM
        When "X3ETA"           : [L]ETAT = [L]VALEUR
        When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
        When "numedt"          : [L]PARAMETRE(I) = "numedt="  +num$([L]NUMREQ)
        When "fcydeb"          : [L]CRITERE  -= "& FCY>='"  +[L]VALEUR+"'"
        When "fcyfin"          : [L]CRITERE  -= "& FCY<='"  +[L]VALEUR+"'"
        When "datdeb"          : [L]DDATREF   =  gdat$(val(right$([L]VALEUR,7)), val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                                 [L]CRITERE1 -= "& CREDAT >=["+format$(GFMD,[L]DDATREF)+"]"
        When "datfin"          : [L]DDATREF   =  gdat$(val(right$([L]VALEUR,7)), val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                                 [L]CRITERE1 -= "& CREDAT <=["+format$(GFMD,[L]DDATREF)+"]"
        When "ori"            : Gosub SETORI
        When "orivcr"         : Gosub SETORIVCR
        When "cat"            : Gosub SETCAT
        When "itmref"         : Gosub SETITM
      Endcase
    Endif
  Next
  #Optimisation performances
  IPERF = 0
  IPBL = 0
  INTR = 0
  SZMESS = mess(460,182,1)  #Enregistrement des impressions
  If !GINTRA Then
    IMAX = nbrecord([F:FLY])
    ICOUNT = 0
    IAFFOK = 1
    Call OUVRE_BOITE(SZMESS, IMAX) From GESECRAN
  Endif
  ###################################################################
  # Enregistrement des impressions
  ###################################################################
  IPERF = 0
  IPBL = 0
  INTR = 0
  Filter [FLY] Where evalue([L]CRITERE + [L]CRITERE1 + [L]CRITERE2 + [L]CRITERE3) 
  For [FLY] 
    If IPERF = 0 Then
      Call DEBTRANS From GLOCK 
      Trbegin [FLY]
      INTR = 1
    Endif
    [F:FLY]CATRPTADI  = [L]ETAT
    [F:FLY]LASPRNDAT  = date$
    [F:FLY]LASPRNHOU = left$(time$, 2) + mid$(time$, 4, 2)
    [F:FLY]PRNFLG  = 2
    #Ajoute une impression dans l'historique des impressions
    Gosub ADDPRNHISTO
    Rewrite [FLY]   
    If fstat Then
      IPBL = 1
      #Erreur lors de l'enregistrement des impressions.
      GMESSAGE = mess(461,182,1)
      GERR = 1
      Rollback
      INTR = 0
      Break
    Else
      If IPERF >= 1000 Then
        Commit
        IPERF = 0
        INTR = 0
      Else
        IPERF += 1
      Endif
    Endif
    If !GINTRA Then
      ICOUNT += 1
      Call AFF_BOITE (SZMESS, ICOUNT, IAFFOK) From GESECRAN
    Endif
  Next 
  Filter [FLY]
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  If !GINTRA Then
    Call FERME_BOITE From GESECRAN
  Endif
End

########################################################################### 
$OUVRE 
  If !clalev([F:FLY]) : Local File WARFLYER [FLY] : Endif
Return 
 
###########################################################################
$DECLARE 
Local Char    CRITERE(255),CRITERE1(250),CRITERE2(250),CRITERE3(250)
Local Char    PARAM(30),VALEUR(30),ETAT(GLONARP),WNUM(GLONVCR),WFCY(GLONFCY),WREP(GLONREP),WCLI(GLONBPN),WAFF(GLONVCR),WINT(GLONAIN)
Local Integer WTYP, NUMREQ 
Local Date    WDAT    
Local Date DDATREF
Local Integer IORI
Return 
 
###########################################################################
$SETORI
  IORI = val([L]VALEUR)
Return

###########################################################################
$SETORIVCR
  If [L]VALEUR <> "" Then
    [L]CRITERE3 -= "& FLYORI=" + num$(IORI) + " & FLYORIVCR=" + '"' + [L]VALEUR + '"'
  Endif
Return

###########################################################################
$SETCAT
  If [L]VALEUR <> "" Then
    [L]CRITERE2 -= "& FLYCAT=" + '"' + [L]VALEUR + '"'
  Endif
Return

###########################################################################
$SETITM
  If [L]VALEUR <> "" Then
    [L]CRITERE2 -= "& ITMREF=" + '"' + [L]VALEUR + '"'
  Endif
Return


###########################################################################
# Ajout d'un historique d'impression
##################################################
$ADDPRNHISTO
Local Integer ITERHIST

  #Cherche la date la plus ancienne
  For ITERHIST = 0 To dim([F:FLY]PRNDAT)-1
    If [F:FLY]PRNDAT(ITERHIST) = [00/00/00] Then
      [F:FLY]PRNDAT(ITERHIST) = date$
      [F:FLY]PRNHOU(ITERHIST) = left$(time$, 2) + mid$(time$, 4, 2)
      Break
    Endif
    If ITERHIST = dim([F:FLY]PRNDAT)-1 Then
      [F:FLY]PRNDAT(ITERHIST) = date$
      [F:FLY]PRNHOU(ITERHIST) = left$(time$, 2) + mid$(time$, 4, 2)
      Break
    Endif
  Next
Return
