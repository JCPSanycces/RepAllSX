## Subprog GENTRANS
###########################################################

###########################################################
## Validation des écrans
###########################################################
Subprog GENMSK
Local Integer OK , LANCUR
Local Char    OBJET(GLONAMK) , APPLI(GLONADS)

APPLI = [F:ADS]DOSSIER

Local File =APPLI+".AMSK"     [AMK]
Local File =APPLI+".AMSKZON"  [AMZ]
Local File =APPLI+".AMSKACT"  [AMA]
Local File =APPLI+".AMSKPAR"  [AMP]
Local File =APPLI+".ATYPE"    [ATY]
Local File =APPLI+".ATEXTE"   [ATX]
Local File =APPLI+".ACTIV"    [ACV]
Local File =APPLI+".ACTION"   [ACT]
Local File =APPLI+".ACTPAR"   [ATR]
Local File =APPLI+".AOBJET"   [AOB]
Local File =APPLI+".ATABLE"   [ATB]
Local File =APPLI+".ATABZON"  [ATZ]
Local File =APPLI+".ACTL"     [ACL]
Local File =APPLI+".AURL"     [AUR]

If GINFO
 Call AFF_VLC(mess(31,125,1),"") From GESECRAN
# MAJ des écrans
Endif
Call ECR_TIME(mess(31,125,1)-APPLI) From DOSSUB

NOMBRE = 0

# A cause du snapshot too old

If GVALIDE(2)
 # Issue 85732 - 2012-11-19 by VPO : ne pas valider les écrans modèles
 # les écrans W* seront validés avec transactions (si sum(GVALIDE(2..4))=3)
 #GNBMSK = nbrecord([AMK])
 If sum(GVALIDE(2..4))=3
  Filter [AMK] Where MDL<>2 & left$(CODMSK,1)<>"W"
 Else
  Filter [AMK] Where MDL<>2
 Endif
 If GINFO
  GNBMSK = rowcount([AMK])
 Endif
Else
 Filter [AMK] Where UPDFLG=1 & MDL<>2 & left$(CODMSK,1)<>"W"
Endif
Read [AMK]CODMSK First
While fstat<=2
 OBJET = [F:AMK]CODMSK
 # Validation de l'écran
 # Call ECR_TRACE(mess(42,125,1)-[F:AMK]CODMSK,0) From GESECRAN
 NOMBRE += 1
 If GINFO
  # MAJ des écrans
  Call AFF_VLC(mess(31,125,1),OBJET-num$(NOMBRE)+"/"+num$(GNBMSK)) From GESECRAN
 Endif
 Call VALID(OBJET,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,1,OK) From VALMSK
 Read [AMK]CODMSK > OBJET
Wend
Filter [AMK]
End

###########################################################
## Subprog GENWIN
###########################################################
## Validation des fenêtres
###########################################################
Subprog GENWIN
Local Integer OK
Local Char    OBJET(GLONFEN) , APPLI(GLONADS)

APPLI = [F:ADS]DOSSIER

Local File =APPLI+".AWINDOW"   [AWI]
Local File =APPLI+".AWINDOW"   [AWI2]
Local File =APPLI+".AWINPAR"   [AWP]
Local File =APPLI+".AWINBRO"   [AWB]
Local File =APPLI+".AWINBOUT"  [AWT]
Local File =APPLI+".AOBJET"    [AOB]
Local File =APPLI+".AOBJTAB"   [AOT]
Local File =APPLI+".AOBJLST"   [AOL]
Local File =APPLI+".ATABZON"   [ATZ]
Local File =APPLI+".ATABLE"    [ATB]
Local File =APPLI+".ATABIND"   [ATI]
Local File =APPLI+".AINDEX"    [ANX]
Local File =APPLI+".ATYPE"     [ATY]
Local File =APPLI+".AMENLOC"   [AML]
Local File =APPLI+".ATEXTE"    [ATX]
Local File =APPLI+".AMSK"      [AMK]
Local File =APPLI+".AMSKZON"   [AMZ]
Local File =APPLI+".ACTIV"     [ACV]
Local File =APPLI+".ACTION"    [ACT]
Local File =APPLI+".ACTPAR"    [ATR]
Local File =APPLI+".ACTCODPAR" [AAR]
Local File =APPLI+".ACONSULT"  [ACN]

If GINFO
 Call AFF_VLC(mess(83,125,1),"") From GESECRAN
# MAJ des fenêtres
Endif
Call ECR_TIME(mess(83,125,1)-APPLI) From DOSSUB

NOMBRE = 0

# A cause du snapshot too old

If GVALIDE(4)
 # Issue 85732 - 2012-11-19 by VPO : ne pas valider les fenêtres modèles
 # les fenêtres W* seront validées avec transactions (si sum(GVALIDE(2..4))=3)
 #GNBWIN = nbrecord([AWI2])
 If sum(GVALIDE(2..4))=3
  Filter [AWI2] Where MDL<>2 & left$(WIN,1)<>"W"
 Else
  Filter [AWI2] Where MDL<>2
 Endif
 If GINFO
  GNBWIN = rowcount([AWI2])
 Endif
Else
 Filter [AWI2] Where UPDFLG=1 & MDL<>2 & left$(WIN,1)<>"W"
Endif
Read [AWI2]AWI0 First
While fstat<=2
 OBJET = [F:AWI2]WIN
 # Call ECR_TRACE(mess(84,125,1)-[F:AWI2]WIN,0) From GESECRAN
 # Validation de la fenêtre
 NOMBRE += 1
 If GINFO
  # MAJ des fenêtres
  Call AFF_VLC(mess(83,125,1),OBJET-num$(NOMBRE)+"/"+num$(GNBWIN)) From GESECRAN
 Endif
 Call VALID(OBJET,APPLI,1,OK) From VALWIN
 Read [AWI2]AWI0 > OBJET
Wend
Filter [AWI2]
End

###########################################################
## Subprog GENOBJ
###########################################################
## Validation des objets
###########################################################
Subprog GENOBJ
Local Integer OK
Local Char    OBJET(GLONAOB) , APPLI(GLONADS)

APPLI = [F:ADS]DOSSIER

Local File =APPLI+".AOBJET"   [AOB]
Local File =APPLI+".AOBJTAB"  [AOT]
Local File =APPLI+".AOBJLST"  [AOL]
Local File =APPLI+".AOBJLNK"  [AOK]
Local File =APPLI+".AWINDOW"  [AWI]
Local File =APPLI+".AWINBRO"  [AWB]
Local File =APPLI+".ATABLE"   [ATB]
Local File =APPLI+".ATABZON"  [ATZ]
Local File =APPLI+".ATABIND"  [ATI]
Local File =APPLI+".AINDEX"   [ANX]
Local File =APPLI+".ATYPE"    [ATY]
Local File =APPLI+".AMENLOC"  [AML]
Local File =APPLI+".ATEXTE"   [ATX]
Local File =APPLI+".AMSK"     [AMK]
Local File =APPLI+".AMSKZON"  [AMZ]
Local File =APPLI+".AMSKPAR"  [AMP]
Local File =APPLI+".ACTIV"    [ACV]
Local File =APPLI+".ATRANSAC" [ATN]
Local File =APPLI+".AOBJET"   [AOB2]

If GINFO
 Call AFF_VLC(mess(32,125,1),"") From GESECRAN
# MAJ des objets
Endif
Call ECR_TIME(mess(32,125,1)-APPLI) From DOSSUB

NOMBRE = 0

If GVALIDE(3)
 GNBAOB = nbrecord([AOB2])
Else
 Filter [AOB2] Where UPDFLG=1
Endif

# A cause du snapshot too old

Read [AOB2]ABREV First
While fstat<=2
 OBJET = [F:AOB2]ABREV
# Call ECR_TRACE(mess(43,125,1)-[F:AOB2]ABREV,0) From GESECRAN
# Validation de l'objet
 NOMBRE += 1
 If GINFO
  Call AFF_VLC(mess(32,125,1),OBJET-num$(NOMBRE)+"/"+num$(GNBAOB)) From GESECRAN
 Endif
 Call VALID(OBJET,APPLI,1,OK) From VALOBJ
 Read [AOB2]ABREV > OBJET
Wend
Filter [AOB2]
End

###########################################################
## Subprog GENCNS
###########################################################
## Validation des consultations
###########################################################
Subprog GENCNS
Local Integer OK
Local Char    OBJET(GLONACN) , APPLI(GLONADS)

APPLI = [F:ADS]DOSSIER

Local File =APPLI+".ACONSULT" [ACN]
Local File =APPLI+".ACONSULT" [ACN2]
Local File =APPLI+".AMSK"     [AMK]
Local File =APPLI+".ATABLE"   [ATB]
Local File =APPLI+".AWINDOW"  [AWI]
Local File =APPLI+".ACTIV"    [ACV]
Local File =APPLI+".ATEXTE"   [ATX]
Local File =APPLI+".AWINDOW"  [A_WI]

If GINFO
 Call AFF_VLC(mess(89,125,1),"") From GESECRAN
# MAJ des consultations
Endif
Call ECR_TIME(mess(89,125,1)-APPLI) From DOSSUB

NOMBRE = 0

# A cause du snapshot too old

If GVALIDE(5)
 GNBCNS = nbrecord([ACN])
Else
 Filter [ACN] Where UPDFLG=1
Endif
Read [ACN]ACN0 First
While fstat<=2
 OBJET = [F:ACN]COD
 Call ECR_TRACE(mess(90,125,1)-OBJET,0) From GESECRAN
# Validation de la consultation
 NOMBRE += 1
 If GINFO
  Call AFF_VLC(mess(89,125,1),OBJET-num$(NOMBRE)+"/"+num$(GNBCNS)) From GESECRAN
 Endif
 Call GENTRTSIL(APPLI,OBJET) From ACNTRT
 Read [ACN]ACN0 > OBJET
Wend
Filter [ACN]
End

############################################################
## Validation des transactions
############################################################
Subprog GENTRANS
Local Integer OK , OKTRT , TEST, NBVAL , I
Local Char    OBJET(GLONATN) , APPLI(GLONADS) , TEXTE(80)
Local Char    TBVAL(GLONATN)(1..) , TRTGEN(GLONADC+GLONADS+1)
APPLI = [F:ADS]DOSSIER
TEST = GSOPHIA

If GINFO
 Call AFF_VLC(mess(69,133,1),"") From GESECRAN
# Validation des transactions
Endif
Call ECR_TIME(mess(69,133,1)) From DOSSUB

Local File =APPLI+".ATRANSAC" [ATN2]
Local File =APPLI+".ATEXTE"   [ATX]
Local File =APPLI+".ATEXTRA"  [AXX]
Local File =APPLI+".ACTIV"    [ACV]
Local File =APPLI+".AWINDOW"  [A_WI]

If TEST
 Call ECR_TRACE("*****"-mess(194,124,1)-APPLI-"*****",0) From GESECRAN : # Mode test
 Call ECR_TRACE("Open files:"-sigma(0,[S]dbglong(11),string$(filelev(indcum+1)<>0,[S]fileabre(indcum+1)+",")),0) From GESECRAN
Endif

# Validation variables globales (WWGLOBxxx WWAGLOBxxx)
# Validation type de données (WWGLOBLON)
# Validation table, vue, liste de gauche par sociétés
# Validation style
NBVAL=0
NBVAL+=1 : TBVAL(NBVAL) = "COD"
NBVAL+=1 : TBVAL(NBVAL) = "GLOBTYP"
NBVAL+=1 : TBVAL(NBVAL) = "GLOBVAR"
NBVAL+=1 : TBVAL(NBVAL) = "ASY"
NBVAL+=1 : TBVAL(NBVAL) = "ABV"
NBVAL+=1 : TBVAL(NBVAL) = "ABI"
NBVAL+=1 : TBVAL(NBVAL) = "ABF"
NBVAL+=1 : TBVAL(NBVAL) = "ACST"
NBVAL+=1 : TBVAL(NBVAL) = "ACTX"


Call VALID_ALL_CLA_TECH(APPLI) From ACLAVALTECH

#il faut le bon ordre donné par la position dans le tableau
#For [ATN2]ATN0 Where find(COD,TBVAL(1..NBVAL))<>0
# Gosub VALTRANS
#Next
For I=1 To NBVAL
  Read [ATN2]ATN0=TBVAL(I)
  If !fstat
    Gosub VALTRANS
  Endif
Next I

If dim(GNBACLA)>0 & GNBACLA>0
 # Validation des classes données
 Call ECR_TIME(mess(200,125,1)-mess(254,125,1)) From DOSSUB : # Validation transaction
 If GINFO
  Call AFF_VLC(mess(200,125,1),mess(254,125,1)) From GESECRAN
 Endif
 Call GENDOS(APPLI) From SUBACLA
 GNBACLA=0
Endif

If dim(GNBASW)>0 & GNBASW>0
 # Validation des classes représentations
 Call ECR_TIME(mess(200,125,1)-mess(255,125,1)) From DOSSUB : # Validation transaction
 If GINFO
  Call AFF_VLC(mess(200,125,1),mess(255,125,1)) From GESECRAN
 Endif
 Call GENDOS(APPLI) From SUBASW
 GNBASW=0
Endif

# Validation des autres transactions
For [ATN2]ATN0 Where ENAFLG=2 & find(COD,TBVAL(1..NBVAL))=0
 If (GVALTRANS([F:ATN2]MODULE)=2 or sum(GVALIDE(2..4))=3)
  Gosub VALTRANS
 Endif
Next

Close Local File [ATN2] , [ATX] , [ACV]

End

#################################################################
$VALTRANS
OKTRT = 0
If [F:ATN2]CODTRT<>""
 Call EXISTE_ADX("",APPLI,[F:ATN2]CODTRT,OKTRT) From ORDSYS
 If OKTRT
  TRTGEN = APPLI+"."+[F:ATN2]CODTRT
 Else
  Call EXISTE_ADX("","",[F:ATN2]CODTRT,OKTRT) From ORDSYS
  If OKTRT
   TRTGEN = [F:ATN2]CODTRT
  Endif
 Endif
Endif
If !OKTRT : Return : Endif
Call TEXTE([F:ATN2]DES,TEXTE) From OBJDIV
Call ECR_TIME(mess(200,125,1)-[F:ATN2]COD-TEXTE) From DOSSUB : # Validation transaction
If GINFO
 Call AFF_VLC(mess(200,125,1),[F:ATN2]COD-TEXTE) From GESECRAN
Endif

# Appel de la validation directe des masques modèles si validation différée   -- Débrayé le 27/10/2011 CC
#If GVALIDDIFF=3  and [F:ATN2]OBJ<>""
#  Local Integer IMK,OKMK
#  Read [A_WI]AWI0="O"+[F:ATN2]OBJ
#  If fstat=0
#    If [F:A_WI]MSKENT<>""
#      Call VALIDDIRECT([F:A_WI]MSKENT,APPLI,1,GLANGUE,0,OKMK) From VALMSK
#    Endif
#    For IMK=1 To [F:A_WI]NBMSK
#      Call VALIDDIRECT([F:A_WI]NOMMSK(IMK-1),APPLI,1,GLANGUE,0,OKMK) From VALMSK
#    Next IMK
#  Endif
#Endif


Call GENDOS(APPLI) From =TRTGEN
If APPLI<>[F:ADS]DOSSIER
 Call ECR_TRACE(mess(198,125,1)-[F:ADS]DOSSIER,-1) From GESECRAN
 Read [ADS]DOSSIER = APPLI
Endif
Return

#################################################################
# Validation des objets et fenêtres liées aux législations
#################################################################
Subprog GENLEG
Local Char    APPLI(GLONADS) , CHAINE(250)
Local Integer ER , OK

If GINFO
 Call AFF_VLC(mess(214,125,1),"") From GESECRAN
# Validation multi-législations
Endif
Call ECR_TIME(mess(214,125,1)) From DOSSUB

APPLI = [F:ADS]DOSSIER

Local File =APPLI+".AOBJET"  [AOB_]
Local File =APPLI+".ATABLE"  [ATB_]
Local File =APPLI+".ATABZON" [ATZ_]
Local File =APPLI+".AMSKPAR" [AMP_]

Link [AOB_] With
& [ATB_]CODFIC~=[F:AOB_]NOMFIC
& As [LNK_]
For [LNK_]
 For [ATZ_] Where CODFIC=[ATB_]CODFIC
  If [F:ATZ_]CODTYP="ADI"
   Read [AMP_]CODPAR=2;[ATB_]CODFIC;[F:ATZ_]CODZONE;"ADI"
   If !fstat
    Raz CHAINE , ER
    Onerrgo ER
    CHAINE = num$(evalue([F:AMP_]VALPAR))
    Onerrgo ER
    If CHAINE="909" & !ER
     Call VALID_TRT(APPLI,0,"","","","","","","","",[F:AOB_]ABREV,[F:AOB_]ABREV,"","","","","","","","","","",[F:ADS]MODULE) From VALDICO
     Call VALFEN(APPLI,[F:AOB_]ABREV) From SUBAOB
     Break
    Endif
   Endif
  Endif
 Next ATZ_
Next LNK_
Close Local File
End

$ER
ER = errn
Resume

