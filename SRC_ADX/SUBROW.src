#<AdxTL>@(#)1.0.0.0 $Revision$
#############################################################
#                                                           #
# Traitement lié à l'objet "Cas d'emploi gammes "           #
#                                                           #
#     Objet : ROW                                           #
#                                               11/01   MM  #
#############################################################


$ACTION
Case ACTION
 When "SETBOUT"  : Gosub SETBOUT
 When "FILTRE"   : Gosub FILTRE    # GA 12/2008
 When "AFFMASK"  : Gosub AFFMASK   # GA 12/2008
 When "LIENS"    : Gosub LIENS
 When "FIN"      : Gosub FIN
 When Default
Endcase
Return

#############################################################
$SETBOUT
Call VIREBOUT(CHAINE,"CMADH") From GOBJET
Return

#############################################################
$AFFMASK
# Issue 110957 - 2015-09-29 by CCC
If dim([M:ROW]CRID)>0
   Diszo [M:ROW]CRID
Endif
If dim([M:ROW]TCRID)>0
   Diszo [M:ROW]TCRID
Endif

If [F:ROH]ITMREF<>""
   [M:ROW]=[F:ROH]
   If [M:ROW]ITMREF<>[F:ITF]ITMREF
      Read [ITF]ITF0=[F:ROH]ITMREF;[M:ROW]FCY
   Endif
   Gosub LIENS
   Affzo [M:ROW]
Endif
Return

######################################################################################
$FILTRE
If dim(GFLTROW)>0
  Default File [ROH]
  FILTSUP=GFLTROW
Endif
Return



#############################################################
# chargement des cas d'emploi
$LIENS
Local Integer WMAX  : WMAX = dim([M]TITMREF)-1 : # FQ 56411 GA 09/2009 avant 299
Local Char    CRITERE1(255)
Local Integer WCOUNT

# Issue 110957 - 2015-09-29 by CCC
If dim([M:ROW]CRID)>0
    [M:ROW]CRID = func TRTX3FNC.CCMID([M:ROW]ITMREF,"","")
    If dim([M:ROW]CRFLG)>0
       [M:ROW]CRFLG = string$([M:ROW]CRID<>"","151")
    Endif
Endif

nolign = 0
# 15720 09.02 MM
CRITERE1 = "(MFGROU=[M]ITMREF | CSTROU=[M]ITMREF | RCCROU=[M]ITMREF)"
Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF
& As [LIE]
& Where  STOFCY=[M:ROW]FCY & evalue(CRITERE1)

For [LIE]
    If nolign+1 >= WMAX : Break : Endif

    # recherche des articles fabriqués avec la gamme mère
    If [F:ITF]CSTROU = [M]ITMREF & ([F:ITF]CSTROUALT = [M]ROUALT |[F:ITF]CSTROUALT = 0)
      nolign +=1 : [M]TROUSE(nolign-1) = 2 : Gosub FILL_LINE: Endif

    If [F:ITF]MFGROU = [M]ITMREF & ([F:ITF]MFGROUALT = [M]ROUALT |[F:ITF]MFGROUALT = 0)
      nolign +=1 : [M]TROUSE(nolign-1) = 1 : Gosub FILL_LINE: Endif

    If [F:ITF]RCCROU = [M]ITMREF & ([F:ITF]RCCROUALT = [M]ROUALT |[F:ITF]RCCROUALT = 0)
      nolign +=1 : [M]TROUSE(nolign-1) = 3 : Gosub FILL_LINE: Endif

$NXTLIE
Next

Filter [LIE]
# 15720 09.02 MM

[M]NBLIG = nolign

Affzo 10
Raz CRITERE
Return

########################################
# 15720 09.02 MM
$FILL_LINE
    [M]TITMREF(nolign-1)  = [F:ITF]ITMREF
    #[M]TROUDES(nolign-1)  = [F:ITM]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M]TROUDES(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    [M]STU(nolign-1)      = [F:ITM]STU
    [M]MFGLOTQTY(nolign-1)= [F:ITF]MFGLOTQTY
    [M]REOMINQTY(nolign-1)= [F:ITF]REOMINQTY
    [M]MFGLTI(nolign-1)   = [F:ITF]MFGLTI
    [M]PLANNER(nolign-1)  = [F:ITF]PLANNER
    [M]TCLCOD(nolign-1)   = [F:ITM]TCLCOD
    [M]STDFLG(nolign-1)   = [F:ITM]STDFLG

    # Issue 110957 - 2015-09-29 by CCC
    If dim([M:ROW]TCRID)>0
       [M:ROW]TCRID(nolign-1) = func TRTX3FNC.CCMID([M:ROW]TITMREF(nolign-1),"","")
    Endif
    If dim([M:ROW]TCRFLG)>0
       [M:ROW]TCRFLG(nolign-1) = string$([M:ROW]TCRID(nolign-1)<>"","151")
    Endif
Return

########################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" : mkstat = 2 : End : Endif
Read [F:ROH]ROH1 Curr
If !fstat & [F:ROH]ITMREF = VALEUR
        [M]ROUALT = [F:ROH]ROUALT
        [M]FCY    = [F:ROH]FCY
Elsif   [M]ROUALT <> 0
        Read [F:ROH]ROH1 = [M]FCY;VALEUR;[M]ROUALT
        If !fstat
           [M]ROUALT = [F:ROH]ROUALT
           [M]FCY    = [F:ROH]FCY
        Endif
Else
        Raz [M]ROUALT
        Raz [M]FCY
Endif
# Issue 110957 - 2015-09-29 by CCC
If dim([M:ROW]CRID)=1
    [M:ROW]CRID = func TRTX3FNC.CCMID(VALEUR,"","")
    Affzo [M:ROW]CRID
    If dim([M:ROW]CRFLG)>0
       [M:ROW]CRFLG = string$([M:ROW]CRID<>"","151") : Affzo [M:ROW]CRFLG
    Endif
Endif
Effzo 20
End

########################################
Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()
#Diszo [M]FCY
End



########################################
Subprog AM_ROUALT(VALEUR)
Variable Decimal VALEUR
Effzo 20
End


########################################
Subprog AV_ITMUOM(VALEUR)
Variable Char    VALEUR()

If clalev ([ITM])=0 : Local File ITMMASTER [ITM] : Endif
If [M]ITMREF <> ""
   Read [ITM]ITM0=[M]ITMREF
   If ! fstat
      VALEUR=[F:ITM]STU
      [M]XMINUOM=VALEUR
      [M]XMAXUOM=VALEUR
      [M]XWORUOM=VALEUR
      If !GIMPORT : Affzo [M]XMINUOM, XMAXUOM, XWORUOM : Endif
   Endif
Endif
End



########################################
Subprog IB_NBLIG

GBOUT1 = mess(22,198,1)   # article
GBOUT2 = mess(4,198,1)    # article-site
GBOUT3 = mess(136,195,1)  # nomenclature production
# On ne peut pas aller dans les nomenclature des prod... si on en vient
If find("GESBODP", GNAVIG(1..GPILNAV)) or find("GESBOD", GNAVIG(1..GPILNAV)) Then
  GBOUT3=""
Endif
# Idem pour les articles
If find("GESITM", GNAVIG(1..GPILNAV)) Then
  GBOUT1=""
Endif
# Idem pour les articles-site
If find("GESITF", GNAVIG(1..GPILNAV)) Then
  GBOUT2=""
Endif

Global Char WROUALT
GBOMALT(0)=[M]ROUALT
WROUALT=num$([M]ROUALT)
End

########################################
$FIN
  If dim(WROUALT)>0 Then Kill WROUALT Endif
Return
