##############################################################################
# TRTFASISS2 - SORTIES                                                       ##
##############################################################################
#  Modification
# MWA   05.07.2018 X3-102683 : Side effect - Exceptionnal depreciation when disposal cancelation
# MWA   05.07.2018 X3-74074  : Exceptionnal depreciation when disposal cancelation
# MDJ   12.11.2014 FQ95754_7 : Si sortie bien classé pour vente: extourne EVTs & alim. champs ISSDAT/ISSAMT par défaut
# CBO   30.04.2013 FQ89830   : Création à partir de TRTFASISS (trop long)

#-------------------------------------------------------------------------------------#
# Récupération du DEPREC de la période courante dans les masques de travail du calcul #
#                                                                                     #
# Lors de l'appel à SIMULER_VALEUR_NETTE, si les masques [M:Pxxx] sont ouverts par le #
# programme appelant, il est possible de récupérer dans ces masques, pour chaque plan,#
# les enregistrements DEPREC pour une période donnée                                  #
#                                                                                     #
# Le résultat est stocké dans la classe [F:DEP] qui doit être ouverte avant l'appel   #
#-------------------------------------------------------------------------------------#
Subprog GET_DEPREC_FROM_MASK(PPLN, PPERENDDAT, CODERR)
Value    Integer PPLN
Value    Date    PPERENDDAT
Variable Integer CODERR

   CODERR = 0 : # OK
   # Récupération du masque du plan dans [M:DEP]
   Case PPLN
     When G301CPT  : Transmask [M:PCPT] To [M:DEP]
     When G301FIS  : Transmask [M:PFIS] To [M:DEP]
     When G301MIN  : Transmask [M:PMIN] To [M:DEP]
     When G301ORI  : Transmask [M:PORI] To [M:DEP]
     When G301R76  : Transmask [M:PR76] To [M:DEP]
     When G301IAS  : Transmask [M:PIAS] To [M:DEP]
     When G301TEC  : Transmask [M:PTEC] To [M:DEP]
     When G301RET  : Transmask [M:PRET] To [M:DEP]
     When G301SUB  : Transmask [M:PSUB] To [M:DEP]
     When G301LI1  : Transmask [M:PLI1] To [M:DEP]
     When G301LI2  : Transmask [M:PLI2] To [M:DEP]
     When G301LI3  : Transmask [M:PLI3] To [M:DEP]
     When G301LI4  : Transmask [M:PLI4] To [M:DEP]
     When G301LI5  : Transmask [M:PLI5] To [M:DEP]
     When G301LI6  : Transmask [M:PLI6] To [M:DEP]
   Endcase

   # Recherche de la ligne correspondant à la période courante
   L_PERC = find(PPERENDDAT,[M:DEP]PERENDDAT)
   If !L_PERC : CODERR = 1 : End : Endif
   nolign   = L_PERC
   [F:DEP] = [M:DEP]
End

#--------------------------------------------------------------#
# Alimentation des enregistrements de TPF1                     #
#--------------------------------------------------------------#

# FQ79623 : ajout du statut du bien PCMPSTA
Subprog MAJ_INFOS_SORTIE(PCLASSE,PMODIF,PACGBSEVAL,PIASBSEVAL,
&PVALNET,PDEVISE,PCTRL, PCMPSTA)

Value Char    PCLASSE     # Classe contenant les informations de sortie
Value Char    PMODIF      # Tâche à réaliser : Sortie ou Annulation de sortie
Value Decimal PACGBSEVAL  # Valeur Bilan PCG
Value Decimal PIASBSEVAL  # Valeur Bilan IAS
Value Decimal PVALNET     # Valeur Nette de référence
Value Char    PDEVISE     # Devise des montants
Value Integer PCTRL       # G_OUI si on est passé par CONTROLER
Value Shortint PCMPSTA    # Statut du bien (autonome, principal...)

  Local Char    CHAMP(50)
  Local Decimal MONTANT_ORIGINE
  Local Decimal MONTANT_ARRONDI
  Local Integer ENDVATREGDAT    : # Année de fin de régularisation
  Local Decimal RATIO_REGUL     : # Durée résiduelle de régul. TVA / Durée totale de régul. TVA
  Local Integer STAT

  # FQ79623
  Local Integer BPARMONTANT_STD

  Local    Decimal VALNETTE(1..G301MAX-1) : # Valeurs nettes pour chaque bien par plan
  Local    Date    SORREG  (0..G301MAX-1)
  Local    Date    SORREGT (0..G301MAX-1)
  Local    Date    SORREGI (0..G301MAX-1)
  Local    Integer CODERR

  If !clalev([F:WFAS]) : Local File FXDASSETS [WFAS] : Endif

  Case PMODIF
    When "SOR"
      ###################
      # SORTIE          #
      ###################
      Local Decimal RATVAT

     # Motif de sortie
      CHAMP=PCLASSE+"ISSTYP"    : Assign CHAMP With [M:FASS]ISSTYP

     # Règle de sortie
      CHAMP=PCLASSE+"ISSDATRUL" : Assign CHAMP With [M:FASS]ISSDATRUL

     # Coef. rééval. 76
      CHAMP=PCLASSE+"R76COE"    : Assign CHAMP With [M:FASS]R76COE

     # Date de sortie
      CHAMP=PCLASSE+"ISSDAT"    : Assign CHAMP With [M:FASS]ISSDAT

     # Date de sortie comptabilisée
     CHAMP=PCLASSE+"DATISSPST" : Assign CHAMP With [M:FASS]ISSDAT

     # Sortie prévisionnelle ?
      CHAMP=PCLASSE+"EXTISSFLG" : Assign CHAMP With [M:FASS]EXTISSFLG

     # Taux de TVA de sortie
      CHAMP=PCLASSE+"ISSVATRAT" : Assign CHAMP With [M:FASS]ISSVATRAT

     # Montant de sortie en devise société -> plan comptable (à ne pas modifier si on est passé par CONTROLER)
      If PCTRL = G_NON
      #----------
        CHAMP=PCLASSE+"ISSAMT(0)"
        Case [M:FASS]ISSAMTTYP

          When GVML_TVAUCUN           # Aucun montant
            MONTANT_ORIGINE = 0

          When GVML_TVSAISI           # Montant à saisir --->
            #FQ79623 : montant de sortie tout sur le bien principal
            BPARMONTANT_STD = 0

            # montant de sortie réparti sur les biens principaux
            If [M:FASS]TTPRINC = G_OUI
              # trt unitaire
              If ACTTYPGES=GTAMUNI
                If PCMPSTA = GVML_SBPRINC or PCMPSTA = GVML_SBAUTON
                  MONTANT_ORIGINE = [M:FASS]ISSAMT
                Else
                  MONTANT_ORIGINE = 0
                Endif
              # trt massif
              Else
                If PCMPSTA = GVML_SBPRINC or PCMPSTA = GVML_SBAUTON
                  If NBOBJLCK_PRIN = 1
                    # Il n'y a qu'un bien sorti, on porte le montant de sortie sur ce bien
                    MONTANT_ORIGINE=[M:FASS]ISSAMT
                  Else
                    BPARMONTANT_STD = 1
                  Endif
                Else
                  MONTANT_ORIGINE = 0
                Endif
              Endif
            Else
              BPARMONTANT_STD = 1
            Endif

            If BPARMONTANT_STD
              # FQ79623 : la modif de février NBOBJLCK += 1 sur les cpsts
              # rend caduque ce test. Il y avait de toute façon le pb des BPH liés
              #              If (NBOBJLCK + NBOBJLCK_CMP = 1) Then
              If (NBOBJLCK_PRIN + NBOBJLCK_CMP = 1) Then
                # Il n'y a qu'un bien sorti, on porte le montant de sortie sur ce bien
                MONTANT_ORIGINE=[M:FASS]ISSAMT
              Else
                Case [M:FASS]BRDTYP

                  When GVML_TRVNCPL       #    ---> Ventilé par plan
                    If !(TOTOBJAMT(0)=0)
                      MONTANT_ORIGINE=(PVALNET*[M:FASS]ISSAMT)/TOTOBJAMT(0)
                    Else
                      MONTANT_ORIGINE=0
                    Endif

                  When GVML_TRVBPCG       #    ---> Ventilé par valeur bilan PCG
                    If !(TOTOBJAMT(1)=0)
                      MONTANT_ORIGINE=(PACGBSEVAL*[M:FASS]ISSAMT)/TOTOBJAMT(1)
                    Endif

                  When GVML_TRVBIAS       #    ---> Ventilé par valeur bilan IAS
                    If !(TOTOBJAMT(2)=0)
                      MONTANT_ORIGINE=(PIASBSEVAL*[M:FASS]ISSAMT)/TOTOBJAMT(2)
                    Endif

                  When Default
                Endcase
              Endif
            Endif

          When GVML_TVVNCPL           # Valeur nette du plan
            MONTANT_ORIGINE = PVALNET

          When Default
        Endcase

        MONTANT_ARRONDI = MONTANT_ORIGINE
        If MONTANT_ORIGINE > 0
          Call GET_MNT_ARRONDI(MONTANT_ORIGINE, PDEVISE, MONTANT_ARRONDI) From GLOBIENS
        Endif
        Assign CHAMP With MONTANT_ARRONDI
      #----------
      Endif # Fin PCTRL = G_NON

     # Montant de sortie par plan : on détermine le montant à partir du montant de sortie du plan comptable
     # et de la devise du plan.
      Local Decimal L_ISSAMT
      Local Integer I_PLN

      CHAMP=PCLASSE+"ISSAMT([F:CNX]PLNCAA(I_PLN-1)-1)"

      For [CNX] Where CPY=evalue(PCLASSE+"CPY")
      #----------
        For I_PLN = 1 To [F:CNX]NBPLC
        #----------
          If [F:CNX]CUR<>PDEVISE
            Call CONVERT3(PDEVISE,
&                        [F:CNX]CUR,
&                        PDEVISE,
&                        [F:CNX]CURTYP,
&                        [M:FASS]ISSDAT,
&                        evalue(PCLASSE+"ISSAMT(0)"),
&                        L_ISSAMT,
&                        0,STAT) From CPTSUB
            Assign CHAMP With L_ISSAMT
          Else
            Assign CHAMP With evalue(PCLASSE+"ISSAMT(0)")
          Endif
        #----------
        Next I_PLN
      #----------
      Next # contexte suivant

     # Règle de calcul TVA
      CHAMP=PCLASSE+"PYBVATTYP"    : Assign CHAMP With [M:FASS]PYBVATTYP

      If [M:FASS]ISSTYP = GVML_TSVENTE
        RATVAT = evalue(PCLASSE+"ISSVATRAT")
      Else
        RATVAT = 0
      Endif

     # Montant de TVA due sur vente (à ne pas modifier si on est passé par CONTROLER)
     ##FQ-XXXXX  Fq-67621 à ne pas modifier s'il a été forcé (via l'écran BIC3)
      If PCTRL=G_NON #FQ-XXXXX and G_VATAMTFLG <> G_OUI
      #----------
        If !(RATVAT=0)
        #----------
          CHAMP=PCLASSE+"ISSVATAMT"
          MONTANT_ORIGINE=evalue (PCLASSE+"ISSAMT*RATVAT/100")
          MONTANT_ARRONDI=MONTANT_ORIGINE
          If MONTANT_ORIGINE>0
            Call GET_MNT_ARRONDI(MONTANT_ORIGINE,PDEVISE,MONTANT_ARRONDI) From GLOBIENS
          Endif
          Assign CHAMP With MONTANT_ARRONDI
        #----------
        Endif
      #----------
      Endif

     #-----------------------------------------
     # Calcul des montants relatifs à la sortie
     #-----------------------------------------
     #<FQ-54939
     Local    Date    SORREG  (0..G301MAX-1)
     Local    Date    SORREGT (0..G301MAX-1)
     Local    Date    SORREGI (0..G301MAX-1)
     Local    Integer CODERR
     #>FQ-54939
     Call CALCULER_VALEURS_SORTIE (PCLASSE, [M:FASS]ISSTYP, [M:FASS]ISSDAT, VALNETTE, SORREG, SORREGT, SORREGI, CODERR) From TRTFASISS
     Local Integer I_P
     For I_P = 1 To G301MAX-1
       G_TBSORREG  (I_P-1) = SORREG  (I_P-1)
       G_TBSORREGT (I_P-1) = SORREGT (I_P-1)
       G_TBSORREGI (I_P-1) = SORREGI (I_P-1)
     Next I_P

     #-----------------------------------------
     # A partir d'ici, la classe [F:WFAS] est alimentée par la calcul des montants au moment de la sortie

     # Reversement et déduction complémentaire de TVA (déterminés par le calcul)
      Assign PCLASSE+"ACGCPLDED" With [F:WFAS]ACGCPLDED
      Assign PCLASSE+"IASCPLDED" With [F:WFAS]IASCPLDED
      Assign PCLASSE+"ACGREVVAT" With [F:WFAS]ACGREVVAT
      Assign PCLASSE+"IASREVVAT" With [F:WFAS]IASREVVAT
      # FQ46680
     # Période de régularisation résiduelle et TVA transférable
      Assign PCLASSE+"VATRSD"     With year([F:WFAS]VATREGDAT) - year([M:FASS]ISSDAT) + [F:WFAS]THESLI - 1
      If ( evalue(PCLASSE+"VATRSD") < 0 ) Then : Assign PCLASSE+"VATRSD" With 0 : Endif
      Assign PCLASSE+"ISSVATTRF"  With [F:WFAS]ISSVATTRF
      Assign PCLASSE+"ISSVATTRFI" With [F:WFAS]ISSVATTRFI

     # Acheteur
      CHAMP=PCLASSE+"BUY" : Assign CHAMP With [M:FASS]BUY

     # Ne pas supprimer le rattachement à LEA si la sortie est prévisionnelle
     #Fq-68457 ou si type de sortie=contrat résilié
     # Référence contrat de location financement
      #Fq-68457 If [M:FASS]EXTISSFLG<>G_OUI
      If ( [M:FASS]EXTISSFLG<>G_OUI ) and ( [M:FASS]ISSTYP <> GVML_TSCRESI )
        CHAMP=PCLASSE+"LEAREFORI"
        If evalue("("+PCLASSE+"OWNTYP=GVML_TDLOCAT |"+PCLASSE+"OWNTYP=GVML_TDCBAIL) & ("+PCLASSE+"LEAREF<>'')")
          Assign CHAMP With evalue(PCLASSE+"LEAREF")
          CHAMP=PCLASSE+"LEAREF" : Assign CHAMP With ""
        Endif
      Endif
     # Facture de vente
      CHAMP=PCLASSE+"IVCSALISS" : Assign CHAMP With [M:FASS]IVCSALISS

     # Reprise de dérogatoire sur sortie FQ57971
      CHAMP=PCLASSE+"DERRVEISS" : Assign CHAMP With [F:WFAS]DERRVEISS

     # +/- values
      For N_I = 1 To G301MAX-1
        CHAMP=PCLASSE+"GAL("+num$(N_I-1)+")"       : Assign CHAMP With [F:WFAS]GAL(N_I-1)
        CHAMP=PCLASSE+"SHOGAL("+num$(N_I-1)+")"    : Assign CHAMP With [F:WFAS]SHOGAL(N_I-1)
        CHAMP=PCLASSE+"LNGGAL("+num$(N_I-1)+")"    : Assign CHAMP With [F:WFAS]LNGGAL(N_I-1)
        CHAMP=PCLASSE+"IMLRVEISS("+num$(N_I-1)+")" : Assign CHAMP With [F:WFAS]IMLRVEISS (N_I-1)
      Next N_I

    When "ANN"
      ########################
      # ANNULATION DE SORTIE #
      ########################
      CHAMP=PCLASSE+"ISSTYP"       : Assign CHAMP With 0
      CHAMP=PCLASSE+"ISSDATRUL"    : Assign CHAMP With 0
      CHAMP=PCLASSE+"R76COE"       : Assign CHAMP With 0
      CHAMP=PCLASSE+"ISSDAT"       : Assign CHAMP With [0/0/0]

      Local Integer N_PLN
      For N_PLN = 1 To G301MAX-1
        CHAMP=PCLASSE+"ISSAMT("+num$(N_PLN-1)+")"    : Assign CHAMP With 0
      Next

      # FQ 46680
      CHAMP=PCLASSE+"ISSVATTRF"    : Assign CHAMP With 0
      CHAMP=PCLASSE+"ISSVATTRFI"   : Assign CHAMP With 0
      MONTANT_ORIGINE = evalue(PCLASSE+"VATREGAMT") - evalue(PCLASSE+"ACGREVVAT")
      CHAMP=PCLASSE+"VATREGAMT"    : Assign CHAMP With MONTANT_ORIGINE
      MONTANT_ORIGINE = evalue(PCLASSE+"VATREGDED") - evalue(PCLASSE+"ACGCPLDED")
      CHAMP=PCLASSE+"VATREGDED"    : Assign CHAMP With MONTANT_ORIGINE
      MONTANT_ORIGINE = evalue(PCLASSE+"IASVATREG") - evalue(PCLASSE+"IASREVVAT")
      CHAMP=PCLASSE+"IASVATREG"    : Assign CHAMP With MONTANT_ORIGINE
      MONTANT_ORIGINE = evalue(PCLASSE+"VATREGDEDI") - evalue(PCLASSE+"IASCPLDED")
      CHAMP=PCLASSE+"VATREGDEDI"   : Assign CHAMP With MONTANT_ORIGINE

      CHAMP=PCLASSE+"PYBVATTYP"    : Assign CHAMP With 0
      CHAMP=PCLASSE+"ISSVATRAT"    : Assign CHAMP With 0
      CHAMP=PCLASSE+"ISSVATAMT"    : Assign CHAMP With 0
      CHAMP=PCLASSE+"EXTISSFLG"    : Assign CHAMP With 0
      CHAMP=PCLASSE+"ACGCPLDED"    : Assign CHAMP With 0
      CHAMP=PCLASSE+"IASCPLDED"    : Assign CHAMP With 0
      CHAMP=PCLASSE+"ACGREVVAT"    : Assign CHAMP With 0
      CHAMP=PCLASSE+"IASREVVAT"    : Assign CHAMP With 0
      CHAMP=PCLASSE+"DERRVEISS"    : Assign CHAMP With 0 : # FQ57971

      CHAMP=PCLASSE+"BUY"          : Assign CHAMP With ""
      CHAMP=PCLASSE+"IVCSALISS"    : Assign CHAMP With ""

      For N_I = 1 To G301MAX-1
        CHAMP=PCLASSE+"GAL("+num$(N_I-1)+")"       : Assign CHAMP With 0
        CHAMP=PCLASSE+"SHOGAL("+num$(N_I-1)+")"    : Assign CHAMP With 0
        CHAMP=PCLASSE+"LNGGAL("+num$(N_I-1)+")"    : Assign CHAMP With 0
        CHAMP=PCLASSE+"IMLRVEISS("+num$(N_I-1)+")" : Assign CHAMP With 0
      Next N_I
    When Default
  Endcase
End

#=====================================================================
# Unitaire/massif : Sortie des éléments physiques rattachés au bien
# Si création ou annulation de sortie prévisionnelle, aucun impact sur les éléments physiques
# FQ100398/16
$SORTIE_ELT_PHY


  If GPHY = G_NON # Issue 115092 put before
    Return
  Endif

Local Integer I, OK, RET, STA
Local Char TEXTE(255), TABLE(30)
Local Char TABLE(30)
Local Char WTREF(GLONPHY)(1..)
Local Char WTDES(30)(1..)


  #FQ86084 : tjrs [F:MAS1]
  TABLE="[F:MAS1]"

  If [M:FASS]EXTISSFLG = G_OUI
    Return
  Endif

  Local Instance PARAM_ISS  Using C_PHYELTISS
  PARAM_ISS = NewInstance  C_PHYELTISS AllocGroup null

  PARAM_ISS.PHY_FILTER = "AASREF = '" + evalue(TABLE + "AASREF") + "'"
  PARAM_ISS.TRT_CALLBACK = AVOID.ACHAR

  If [M:FASS]CCLISSFLG = [V]CST_ANO
    # sortie
    PARAM_ISS.ISSDAT = [M:FASS]ISSDAT
    PARAM_ISS.ISSTYPFAS = [M:FASS]ISSTYP

    If func PHYELT_C_MPR._ISSUE_PHYELT_POPULATION_FROM_FAS(PARAM_ISS) = [V]CST_AFALSE
      GMESSAGE = func FXDFCT_SYRA.GET_MAXMSG(PARAM_ISS)
      GOK = 0
    Endif
  Else
    # annulation de sortie

    If func PHYELT_C_MPR._CNL_ISSUE_PHYELT_POPULATION_FROM_FAS(PARAM_ISS) = [V]CST_AFALSE
      GMESSAGE = func FXDFCT_SYRA.GET_MAXMSG(PARAM_ISS)
      GOK = 0
    Endif
  Endif
  FreeGroup PARAM_ISS

  I = 1
  If ACTTYPGES=GTAMMAS Then # écriture de la trace en massif
    If ACTSILENCE <> G_OUI Then
      Local Char LIGNE(115)

      While WTREF(I) <> ""
        LIGNE = "    "
        LIGNE += WTREF(I)
        LIGNE += space$(20 - len(WTREF(I)))
        LIGNE += WTDES(I)
        LIGNE += space$(60 - len(WTDES(I)))
        Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LIGNE, 0, 1) From TRACEABX3
        I += 1
      Wend
    Else
      While WTREF(I) <> ""
        GT_OBJ_REF(I_OBJ) = "  " + WTREF(I)
        GT_OBJ_DES(I_OBJ) = "  " + WTDES(I)
        I_OBJ += 1
        I += 1
      Wend
    Endif

  Endif

Return


#####################################################################################################################
Funprog SBV_ISSUE_CHECK(PDATSOR, PAASREF)

Value Date     PDATSOR
Value Char     PAASREF
Local Integer  BRET

  B_RET = [V]CST_AOK
  Local Integer L_CNX
  Local Char    L_CPY(GLONCPY)
  Local Integer B_SBV : B_SBV = 0
  If !clalev([F:SBV]) : Local File DEPREC [SBV] : Endif
  Read [SBV]DEP0=PAASREF;G301SUB
  If fstat
    # X3-102683
    End B_RET
  Else
    B_SBV = 1
    #Infbox "Plan de subvention géré"
    # Fin de la période suivante
    L_CPY = [F:SBV]CPY
    L_CNX = [F:SBV]CNX
    If !(clalev([F:WFIS])) : Local File FISCYEAR [WFIS] : Endif
    Filter [WFIS] Where CPY=L_CPY & CNX=L_CNX & STAFIY=GVML_TECOURA
    Read [WFIS]FIY0 Last
    L_CURPERSTR = [F:WFIS]DATSTRPER([F:WFIS]INDCURPER-1)
    #Infbox "Debut  periode courante" - num$(L_CURPERSTR)
    Filter [WFIS]
  Endif
  Close File [SBV]

  If (B_SBV) Then
    If clalev([F:W26])  = 0 : Local File EFASISS     [W26]  : Endif
    Filter [W26] Where REF= PAASREF and DPRPLN = G301SUB and SNSEVE= GVML_TEACT and CURPERSTR < L_CURPERSTR
    Read[W26]EVE0 Last
    Filter [W26]
    If !fstat Then
      #Infbox "Annulation antérieure trouvée"
      Local Integer I_PER
      I_PER = find([F:W26]CURPERSTR,[F:WFIS]DATSTRPER)
      L_PERENDDAT = [F:WFIS]DATENDPER(I_PER)
      #Infbox "fin de periode suivante" - num$(L_PERENDDAT)
      If (L_PERENDDAT <> [0/0/0] and PDATSOR <= L_PERENDDAT) Then
        #Infbox "sortie impossible"
        B_RET = [V]CST_ANO
      Endif
    Endif
    Close File [W26]
  Endif
  Close File [WFIS]

End B_RET

#--------------------------------------------------------------#
# Correction de la ligne de compte-rendu du dernier bien sorti #
# dans le cas où le montant de sorti a été ajusté              #
#--------------------------------------------------------------#
# X3-104535
Subprog UPDATE_LAST_BCO(PNUMTRT,PCPY,PAASREF,PAASDES,PMESSAGE)
Value Integer PNUMTRT
Value Char    PCPY
Value Char    PAASREF
Value Char    PAASDES
Value Char    PMESSAGE()

  Local Char LIGNE(115)

  If !clalev([F:XTRA]) : Local File TRCABX3 [F:XTRA] : Endif
  Filter [XTRA] Where (NUMACT=GNUMTRACE(1) & CPY=PCPY & TRITRC=GTRC_CRACTIO)
  For [XTRA]

# FQ79623
#    If pat ([F:XTRA]MSG,"*"+PAASREF+"*")
    If pat ([F:XTRA]MSG,"* "+PAASREF+" *")
      LIGNE ="  "
      LIGNE+=PAASREF
      LIGNE+=space$(20-len(PAASREF))
      LIGNE+=" ! "
      LIGNE+=PMESSAGE
      LIGNE+=space$(115-len(PMESSAGE))
      [F:XTRA]MSG=LIGNE
      Rewrite [XTRA]
      If fstat
        # FQ83184 "TRTFASISS - Erreur réécriture XTRA"
        Call ECR_TRACE("TRTFASISS -"-mess(916, GML_MSGFAS, 1)-num$(fstat),1) From GESECRAN
      Endif
      Break
    Endif
  Next
  Filter [XTRA]
End

