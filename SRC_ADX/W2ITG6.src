#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ITG6 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_STCNUM
Onevent CONTROL Call C_STCNUM(zc) From W2ITG6
Onevent AFTER_CHANGE Gosub AMM_STCNUM From W2ITG6
Onevent BEFORE_INPUT Call AS_STCNUM(zc) From W2ITG6
Return

Subprog AS_STCNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(49730,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_STCNUM(zc) From W2ITG6
Onkey   2 Titled GBOUTS Call S_STCNUM(zc) From W2ITG6
Gosub _AFF
End

Subprog C_STCNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTVCR
 Call CONTVCR(VALEUR) From TRTDIV
 If mkstat : GERR = 1 : GZONE = "STCNUM" : GZNUM = 49730 : Endif
Endif
If !mkstat
 ## Action STD
 Call C_STCNUM(VALEUR) From SUBITG
 If mkstat : GERR = 1 : GZONE = "STCNUM" : GZNUM = 49730 : Endif
Endif
Gosub _AFF
End

$AMM_STCNUM
Call AM_STCNUM(zc)
If !mkstat & GOBJET
 zoncou = "STCNUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_STCNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_STCNUM(VALEUR) From SUBITG
If mkstat : GERR = 1 : GZONE = "STCNUM" : GZNUM = 49730 : Endif
Gosub _AFF
End

Subprog S_STCNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action VCRSEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "VCRSEL"
 PARMSK(1) = "STC"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"VCRSEL","TRTDIV","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_STCNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action VCRTUN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "VCRTUN"
 Call OBJET_CHAR(VALEUR,"STC","") From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$CHG_STY
Return


