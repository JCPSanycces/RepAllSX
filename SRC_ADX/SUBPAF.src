######################################################################################
## Section automatically added (Object PAF) 11/04/2015 09:52:26 (SINGO)
######################################################################################
$ACTION
#  Infbox ACTION
  Case ACTION
    When "OUVRE" Gosub OUVRE
    When "DEBUT" Gosub DEBUT
    When "OK" Gosub OK
#    When "APRES_MODIF" Gosub APRES_MODIF
    When Default
  Endcase
Return

######################################################################################
$OUVRE
  If !clalev ([PAF]) : Local File PJMAFF [PAF] : Endif
  If !clalev ([PAS]) : Local File PJMAUS [PAS] : Endif
Return

######################################################################################
$DEBUT
  Call DISPLAY_SCREEN()
Return

######################################################################################
$OK
  Local Instance MYPJM Using C_OPPOR
  Local Integer NI
  Local Integer MY_STATUS
  Local Integer INDEX
  Local Integer NE
  Local Char SPREKEY(GLONPIM)

  Raz SPREKEY
  # ---------------------------------------------------------------------------------------------
  # Sort the grid ordered by project and employee
  Sorta [M:PAF0]NBLIG [M:PAF0]NBLIG Order By [M:PAF0]OPPNUM([S]indice), [M:PAF0]PAFCLB([S]indice)
  # ---------------------------------------------------------------------------------------------
  For NI = 0 To [M:PAF0]NBLIG - 1
    If SPREKEY <> [M:PAF0]OPPNUM(NI) Then
      #-------------------------------------
      If SPREKEY <> "" Then
        Gosub UPDATE_MYPJM
      Endif
      #-------------------------------------
      SPREKEY = [M:PAF0]OPPNUM(NI)
      #-------------------------------------
      If MYPJM <> null
        FreeGroup MYPJM
      Endif
      MYPJM = NewInstance C_OPPOR AllocGroup null
      MYPJM.TCHTOREAD = "PJM"
      MY_STATUS = fmet MYPJM.AREAD([M:PAF0]OPPNUM(NI))
      If MY_STATUS >= [V]CST_AERROR
        Infbox func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(MYPJM)  #"Reading error"
        Break
      Endif
    Endif
    INDEX = find([M:PAF0]PAFCLB(NI),MYPJM.PJM(1).PAF(1..maxtab(MYPJM.PJM(1).PAF)).PAFCLB)
    If INDEX > 0 # Updating a line(s)
      Raz [F:PAF]
    Else # Adding a new line(s)
      INDEX = fmet MYPJM.PJM(1).ADDLINE("PAF", [V]CST_ALASTPOS)
      If INDEX = [V]CST_ANOTDEFINED Then
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(MYPJM)
        GOK = 0
        GERR = 1
        Break
      Endif
    Endif
    If INDEX > 0 Then
      nolign = NI + 1
      [F:PAF] = [M:PAF0]
      SetInstance MYPJM.PJM(1).PAF(INDEX) With [F:PAF]
    Endif
  Next NI
  If GERR = 0 Then
    If SPREKEY <> "" Then
      Gosub UPDATE_MYPJM
    Endif
  Endif
  If MYPJM <> null
    FreeGroup MYPJM
  Endif
  Call DISPLAY_SCREEN()
Return

######################################################################################
$UPDATE_MYPJM
Local Integer NE

  # Because this part has to be done 2 times, I created the $UPDATE_MYPJM
  #-------------------------------------
  # 1°) all not updated or created are the lines to be deleted in the collection.
  For NE = 1 To maxtab(MYPJM.PJM(1).PAF)
    If MYPJM.PJM(1).PAF(NE) <> null and find(MYPJM.PJM(1).PAF(NE).ASTALIN,[V]CST_ANEW,[V]CST_AUPD) = 0 Then
      [L]MY_STATUS = fmet MYPJM.PJM(1).ADELLINE("PAF",MYPJM.PJM(1).PAF(NE).AORDER)
      If [L]MY_STATUS >= [V]CST_AERROR Then
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(MYPJM)
        GOK = 0
        GERR = 1
        Break
      Endif
     Endif
  Next NE
  If GERR = 1 Then
    Return
  Endif
  #-------------------------------------
  # 2°) Update the project. Please note that this is always the global project which must be updated. Not only the PJM part (this was here MY_STATUS = fmet MYPJM.PJM(1).AUPDATE())
  MY_STATUS = fmet MYPJM.AUPDATE()
  If MY_STATUS >= [V]CST_AERROR
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(MYPJM) # Update error
    GOK = 0
    GERR = 1
    Return
  Endif
  #-------------------------------------
Return

######################################################################################
Subprog DISPLAY_SCREEN()
  Local File PJMAFF [PAF]
  nolign = 1
  For [PAF]
    [M:PAF0] = [F:PAF]
    [M:PAF0]UPDFLG(nolign-1) = 1
    nolign += 1
  Next
  [M:PAF0]NBLIG = nolign - 1
  Affzo [M:PAF0]1-99
End

######################################################################################
$APRES_MODIF
Return

######################################################################################

######################################################################################
## Section automatically added (screen PAF0) 01/19/2016 12:24:44 (SINGO)
######################################################################################
Subprog AM_PAFCLB(VALEUR)
Variable Char    VALEUR()
  Local Instance MYPAS Using C_PJMAUS
  Local Integer MY_STATUS
  MYPAS = NewInstance With C_PJMAUS
    MY_STATUS = fmet MYPAS.AREAD(VALEUR)
    If [L]MY_STATUS = [V]CST_AOK
      [M:PAF0]PAFNAM(nolign-1) = MYPAS.PAUSNAM
      [M:PAF0]PAFROL(nolign-1) = MYPAS.PAUSROL
    Endif
  FreeGroup MYPAS
  Affzo [M:PAF0]PAFNAM(nolign-1)
  Affzo [M:PAF0]PAFROL(nolign-1)
End


######################################################################################

