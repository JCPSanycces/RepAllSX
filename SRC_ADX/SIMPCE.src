#<AdxTL>@(#)11.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Char    TYP(1) , DATDEB(10) , DATFIN(10) , NUMDEB(20) , NUMFIN(20)
Local Char    SOC(GLONCPY) , SITDEB(GLONFCY) , SITFIN(GLONFCY)
Local Integer STAT , INVTYP, OK
Local Char    MESSA(50) , TRANSAC(10), FONCTION(10), WTRACE(250)
Local Date    DDEB , DFIN
Local Char    COMPTE(20) , NATURE(20)
Local Integer REFGEN , REFANA, INDREFGEN, INDREFANA
Local Char    COAGEN(GLONCOA) , COAANA(GLONCOA), NAMCOAGEN(20) , NAMCOAANA(20)

Local File GAUTACE [GAU], AFCTFCY [AFF], ACCES [ACS], BPARTNER [BPR]
Local File GACM [GCM] , COMPANY [CPY]

# Bug 11245 (CP :25/10/01)
If clalev([F:TPV])=0 : Local File TABPIVTYP [TPV] : Endif
If clalev([F:TSV])=0 : Local File TABSIVTYP [TSV] : Endif

Local Char    TZONE(10)(1..2) : # Table des zones à forcer (Ex: type de pièce)
Local Char    TVAL(10)(1..2)  : # Table des valeurs des zones à forcer

If clalev([M:HAE0])=0 : Local Mask GACCENT0 [HAE0]    : Endif
If clalev([M:HAE1])=0 : Local Mask GACCENT1 [HAE1]    : Endif
If clalev([M:HAE2])=0 : Local Mask GACCENT2 [HAE2]    : Endif
If clalev([M:VTL])=0  : Local Mask VENTILE  [VTL]     : Endif
If clalev([M:VT2])=0  : Local Mask VENTILE2 [VT2]     : Endif
If clalev([M:HAEF])=0 : Local Mask GACCENTFMT  [HAEF] : Endif
Default Mask [VTL]
Default Mask [HAE2]
Default Mask [HAE1]
Default Mask [HAE0]

Call GETPARAM("typ",NBPAR,PARAMETRE,TYP) From ETAT
Call GETPARAM("societe",NBPAR,PARAMETRE,SOC) From ETAT
Call GETPARAM("sitdeb",NBPAR,PARAMETRE,SITDEB) From ETAT
Call GETPARAM("sitfin",NBPAR,PARAMETRE,SITFIN) From ETAT
Call GETPARAM("datdeb",NBPAR,PARAMETRE,DATDEB) From ETAT
Call GETPARAM("datfin",NBPAR,PARAMETRE,DATFIN) From ETAT
Call GETPARAM("numdeb",NBPAR,PARAMETRE,NUMDEB) From ETAT
Call GETPARAM("numfin",NBPAR,PARAMETRE,NUMFIN) From ETAT
Call GETPARAM("X3FCT",NBPAR,PARAMETRE,FONCTION) From ETAT

DDEB = DATDEB
DFIN = DATFIN

If !GSERVEUR
 Call TEMPON("O") From GESECRAN
Endif

Call LECTURE("CPY",SOC,"") From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
REFGEN = [F:GCM]GENLEDTYP
REFANA = [F:GCM]ANALEDTYP
Call LECPLAN(SOC,REFGEN,COAGEN) From CPTDIV
Call LECPLAN(SOC,REFANA,COAANA) From CPTDIV

Call LECTEXTRA(NAMCOAGEN,"GCOA","SHOTRA",COAGEN,"") From ATEXTRA
Call LECTEXTRA(NAMCOAANA,"GCOA","SHOTRA",COAANA,"") From ATEXTRA
If COAGEN=COAANA : Raz NAMCOAANA : Endif

Call OUVRE_TRACE("") From LECFIC
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Call ECR_TRACE(mess(2,116,1)-":"-SOC,0) From GESECRAN
Call ECR_TRACE(mess(154,198,1)-":"-SITDEB-"-"-SITFIN,0) From GESECRAN
Call ECR_TRACE(mess(169,100,1)-":"-NUMDEB-"-"-NUMFIN,0) From GESECRAN
Call ECR_TRACE(mess(59,116,1)-":"-format$("D:"+GFMDAT,DDEB)-"-"-format$("D:"+GFMDAT,DFIN),0) From GESECRAN

Call ECR_TRACE(string$(80,"-"),0) From GESECRAN


Case TYP
 When "1"
  Local File SINVOICE [SIH]
  For [SIH] Where NUM>=NUMDEB and NUM<=NUMFIN & ACCDAT>=DDEB & ACCDAT<=DFIN & ORIMOD=3 & STA<3
&  & FCY>=SITDEB & FCY<=SITFIN & (CPY=SOC or SOC="")
   TIERS = [F:SIH]BPR
   SITE  = [F:SIH]FCY
   Gosub AUTORIS
   If OK
    INVTYP = [F:SIH]INVTYP
    Gosub TRANSAC From SUBBIC
    If TRANSAC<>""
    # Bug 11245 (CP :05/11/01)
     Raz TZONE, TVAL
     TZONE(1)="TYP" : TVAL(1)=[F:TSV]GTE
     TZONE(2)="JOU" : TVAL(2)=[F:TSV]JOU
     Call SIMPCE3(TRANSAC,[F:SIH]NUM,STAT,MESSA,TZONE,TVAL) From CPTAUTO
     Gosub TRACE_PIECE
    Endif
   Endif
  Next
 When "2"
  Local File PINVOICE [PIH]
  For [PIH] Where NUM>=NUMDEB and NUM<=NUMFIN & ACCDAT>=DDEB & ACCDAT<=DFIN & ORIMOD=3 & STA<3
&  & FCY>=SITDEB & FCY<=SITFIN & (CPY=SOC or SOC="")
   TIERS = [F:PIH]BPR
   SITE  = [F:PIH]FCY
   Gosub AUTORIS
   If OK
    INVTYP = [F:PIH]INVTYP
    Gosub TRANSAC From SUBBIS
    If TRANSAC<>""
    # Bug 11245 (CP :05/11/01)
     Raz TZONE, TVAL
     TZONE(1)="TYP" : TVAL(1)=[F:TPV]GTE
     TZONE(2)="JOU" : TVAL(2)=[F:TPV]JOU
     Call SIMPCE3(TRANSAC,[F:PIH]NUM,STAT,MESSA,TZONE,TVAL) From CPTAUTO
     Gosub TRACE_PIECE
    Endif
   Endif
  Next
Endcase

Call FERME_TRACE From LECFIC
If GTRACE<>""
 Call SETPARAM("nomfic",NBPAR,PARAMETRE,GTRACE) From ETAT
 Call IMPRIME(NBPAR,PARAMETRE) From LECFIC
Else
 GOK = 0
Endif
If !GSERVEUR
 Call TEMPOFF From GESECRAN
Endif
End

$AUTORIS
OK = 1
Call LECTURE("BPR",TIERS,"") From CONTOBJ
If [F:BPR]ACS<>""
 Read [ACS]CODACC = GUSER;[F:BPR]ACS
 If fstat or [F:ACS]CONSUL<>2
  OK = 0 : Return
 Endif
Endif
If FONCTION<>""
 Read [AFF]AFF0 = SITE;GPROFIL;FONCTION
 If fstat
  OK = 0 : Return
 Endif
Endif
Return

$TRACE_PIECE

WTRACE = mess(11,105,1)-":"-[M]TYP-[M]NUM+"      "+mess(14,105,1)-":"-format$("D:"+GFMDAT,[M]ACCDAT)
Call ECR_TRACE(WTRACE,0) From GESECRAN  # Numéro de pièce / Date comptable 

WTRACE = mess(88,105,1)-":"-TRANSAC
Call ECR_TRACE(WTRACE,0) From GESECRAN  # Pièce automatique

WTRACE = mess(12,105,1)-":"-[M]FCY+"    "+mess(13,105,1)-":"-[M]JOU+"    "+mess(18,105,1)-":"-[M]CUR
Call ECR_TRACE(WTRACE,0) From GESECRAN  # Site / Journal / Devise 

WTRACE = mess(17,105,1)-":"-[M]REF
Call ECR_TRACE(WTRACE,0) From GESECRAN  # Référence pièce


If STAT
 Call ECR_TRACE(mess(6,123,1)-":"-MESSA,1) From GESECRAN  : # Erreur
Else
 Call ECR_TRACE("",0) From GESECRAN
 WTRACE=format$("K:6X",mess(12,105,1))+" "+format$("K:15X",NAMCOAGEN)+" "+
&      format$("K:10X",mess(31,105,1))+" "+format$("K>:9X",mess(1,610,1))+" "+
&      format$("K>:9X",mess(2,610,1))+" "+format$("K:6X",mess(39,105,1))+" "+
&      format$("K:15X",NAMCOAANA)+format$("K:20X",mess(36,105,1))

 Call ECR_TRACE(WTRACE,0) From GESECRAN   #  Site / Compte / Tiers / Débit / Crédit / Taxe / Analytique / Libellé
 INDREFGEN = find(REFGEN,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
 INDREFANA = find(REFANA,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
 For K=0 To [M]NBLIG-1

  If INDREFGEN : COMPTE = evalue("[M]ACC"+num$(INDREFGEN)+"("+num$(K)+")") : Else Raz COMPTE : Endif
  If INDREFANA : NATURE = evalue("[M]ACC"+num$(INDREFANA)+"("+num$(K)+")") : Else Raz NATURE : Endif
  If COAGEN=COAANA : Raz NATURE : Endif
 
  WTRACE = format$("K:4X",[M]FCYLIN(K))+" "+format$("K:3X",[M]SAC1(K))+" "+
&                format$("K:12X",COMPTE)+" "+format$("K:10X",[M]BPR(K))+" "+
&                format$("Nz:6.2#",[M]DEB(K))+" "+format$("Nz:6.2#",[M]CDT(K))+" "+
&                format$("K:5X",[M]TAX(K))+" "+format$("K:12X",NATURE)+" "+
&                left$([M]DES(K),14)

  Call ECR_TRACE(WTRACE,0) From GESECRAN
 Next K
Endif
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Return


