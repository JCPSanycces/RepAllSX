#<AdxTL>@(#)2.0.0.0 $Revision$
$ACTION
Case ACTION
    When "EXP_ZONE" :        Gosub EXP_ZONE
Endcase
Return


###################################################################################
$EXP_ZONE
If EXPFIC="TSR" & GACTION="MESINT" : #interface MES
    If EXPZON="[F:TSR]SCADES"
        If [F:TSR]SCADES=""
            Call LECTEXTRA([F:TSR]SCADES,"TABSCA","SCADESAXX",num$([F:TSR]SCANUM),"") From ATEXTRA
        Endif
    Endif
Endif
Return




