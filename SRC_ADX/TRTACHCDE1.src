#######################################################
# Appel du point d'entrée UOMPSHPOH depuis :          #
#     - le traitement SUBPOHB (commandes classiques)  #
#     - le traitement SUBPOIA (plan de l'acheteur)    #
#     - le traitement TRTACHPOH1 (autres plans)       #
#######################################################
$POINT_UOMPSHPOH
If dim(WUOMFLG)<1  Local Libelle WUOMFLG : Endif
WUOMFLG=0
#--------------------------------------------------------------------#
# Point d'entrée UOMPSHPOH pour reprendre l'unité de la DA           #
# ------------------------------------------------------------------ #
# Variables utilisables par le point d'entrée :                      #
# Si TRAIT=1, les classes [M:POH0],[M:POH1],[M:POH2],[F:PSD],[F:PWO] #
# Si TRAIT>1, les classes [M:POI1], [F:PSD] et [F:PWO]               #
# NOL     : indice de la ligne en cours de chargement                #
# TRAIT   : Code traitement                                          #
#           1 = Prise en compte besoins depuis commandes classiques  #
#           2 = Prise en compte besoins depuis plan de l'acheteur    #
#           3 = Prise en compte besoins depuis les plans d'appro     #
# ------------------------------------------------------------------ #
# Variable modifiable par le point d'entrée :                        #
# WUOMFLG : Indicateur de modif des unités de la ligne de commande   #
#           0 = Pas de modif                                         #
#           1 = UC de la commande est reprise de la DA               #
#           2 = UA de la commande est reprise de la DA               #
#           3 = UC et UA de la commande sont reprises de la DA       #
#--------------------------------------------------------------------#
GPOINT="UOMPSHPOH" : Gosub ENTREE From EXEFNC
Case WUOMFLG
  When 1
    If TRAIT=1
      [M:POH2]UOM(NOL)=[F:PSD]PUU
      Call PCAL_QTY([M:POH2]QTYUOM(NOL),[M:POH2]UOM(NOL),GBIDD1,[M:POH2]PUU(NOL),
&                   [M:POH2]ITMREF(NOL),[M:POH0]BPSNUM,1,GCOEUOM) From TRTACHQTE1
      [M:POH2]UOMPUUCOE(NOL)=GCOEUOM
    Else
      [M:POI1]UOM(NOL)=[F:PSD]PUU
      Call PCAL_QTY([M:POI1]QTYUOM(NOL),[M:POI1]UOM(NOL),GBIDD1,[M:POI1]PUU(NOL),
&                   [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),1,GCOEUOM) From TRTACHQTE1
      [M:POI1]UOMPUUCOE(NOL)=GCOEUOM
    Endif
  When 2
    If TRAIT=1
      Call PCAL_QTY([M:POH2]QTYSTU(NOL),[M:POH2]STU(NOL),WPICQTYPUU,[F:PSD]PUU,
&                   [M:POH2]ITMREF(NOL),[M:POH0]BPSNUM,1,GBIDD2) From TRTACHQTE1
      [M:POH2]PUU(NOL)   =[F:PSD]PUU
      [F:PWO]PUU         =[F:PSD]PUU
      [M:POH2]QTYPUU(NOL)=WPICQTYPUU
      [F:PWO]QTYPUU      =WPICQTYPUU
    Else
      Call PCAL_QTY([M:POI1]QTYSTU(NOL),[M:POI1]STU(NOL),GBIDD1,[F:PSD]PUU,
&                   [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),1,GBIDD2) From TRTACHQTE1
      [M:POI1]PUU(NOL)   =[F:PSD]PUU
      [F:PWO]PUU         =[F:PSD]PUU
      [M:POI1]QTYPUU(NOL)=GBIDD1
      [F:PWO]QTYPUU      =GBIDD1
    Endif
  When 3
    If TRAIT=1
      [M:POH2]UOM(NOL)=[F:PSD]PUU
      [M:POH2]UOMPUUCOE(NOL)=1
      GCOEUOM=1
      Call PCAL_QTY([M:POH2]QTYSTU(NOL),[M:POH2]STU(NOL),WPICQTYPUU,[F:PSD]PUU,
&                   [M:POH2]ITMREF(NOL),[M:POH0]BPSNUM,1,GBIDD2) From TRTACHQTE1
      [M:POH2]PUU(NOL)   =[F:PSD]PUU
      [F:PWO]PUU         =[F:PSD]PUU
      [M:POH2]QTYPUU(NOL)=WPICQTYPUU
      [F:PWO]QTYPUU      =WPICQTYPUU
    Else
      [M:POI1]UOM(NOL)=[F:PSD]PUU
      [M:POI1]UOMPUUCOE(NOL)=1
      GCOEUOM=1
      Call PCAL_QTY([M:POI1]QTYSTU(NOL),[M:POI1]STU(NOL),GBIDD1,[F:PSD]PUU,
&                   [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),1,GBIDD2) From TRTACHQTE1
      [M:POI1]PUU(NOL)   =[F:PSD]PUU
      [F:PWO]PUU         =[F:PSD]PUU
      [M:POI1]QTYPUU(NOL)=GBIDD1
      [F:PWO]QTYPUU      =GBIDD1
    Endif
Endcase
If find(WUOMFLG,1,2,3)
  If ECLAT_PSH=1  ECLAT_PSH=9 : Endif
  If ECLAT_CCE=1  ECLAT_CCE=9 : Endif
  CCELIG=num$(I)
  If TRAIT=1
    If [M:POH2]UOM(NOL)=[M:POH2]PUU(NOL)
      [M:POH2]UOMFLG(NOL)=1
    Else
      [M:POH2]UOMFLG(NOL)=2
    Endif
  Else
    If [M:POI1]UOM(NOL)=[M:POI1]PUU(NOL)
      [M:POI1]UOMFLG(NOL)=1
    Else
      [M:POI1]UOMFLG(NOL)=2
    Endif
  Endif
Endif
Return

#---------------------------------------------------------------------#
# Point d'entrée GENPURORD pour alimentation de zones spécifiques     #
# ------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                         #
#                                                                     #
# CTMFLAG : Indicateur commande de contremarque (2=Oui)               #
# NUMSOH  : Numéro de la commande de vente en cours de traitement     #
# LINSOH  : Ligne  de la commande de vente en cours de traitement     #
# SEQSOH  : Séquence de la ligne cde de vente en cours de traitement  #
# FICHIER : Nom de la table qui va être écrite                        #
# ABRFIC  : Abréviation de la table qui va être écrite                #
# nolign  : Ligne du masque écran [M:POI1] en cours de chargement     #
# Les classes [F:SOH], [F:SOQ] et [F:SOP] sont disponibles            #
# La  classe  [F:POP] ou [F:POQ] est modifiable avant le Write        #
#---------------------------------------------------------------------#
$POINT_GENPURORD
If ABRFIC="POH"
  [V]GPOINT="GENPURORD" : Gosub ENTREE From EXEFNC
Else
  NUMSOH =[M:POH2]SOHNUM(nolign-1)
  LINSOH =[M:POH2]SOPLIN(nolign-1)
  SEQSOH =[M:POH2]SOQSEQ(nolign-1)
  If [M:POH2]SOHNUM(nolign-1)<>""
    CTMFLAG=2
    If [F:SOH]SOHNUM<>NUMSOH
      Read [SOH] SOH0=NUMSOH : If fstat  Raz [F:SOH] : Endif
    Endif
    If [F:SOP]SOHNUM<>NUMSOH | [F:SOP]SOPLIN<>LINSOH | [F:SOP]SOPSEQ<>SEQSOH
      Read [SOP] SOP0=NUMSOH;LINSOH;SEQSOH : If fstat  Raz [F:SOP] : Endif
    Endif
    If [F:SOQ]SOHNUM<>NUMSOH | [F:SOQ]SOPLIN<>LINSOH | [F:SOQ]SOQSEQ<>SEQSOH
      Read [SOQ] SOQ0=NUMSOH;LINSOH;SEQSOH : If fstat  Raz [F:SOQ] : Endif
    Endif
  Else
    CTMFLAG=1
  Endif
  Case ABRFIC
    When "POP" : FICHIER="PORDERP"
    When "POQ" : FICHIER="PORDERQ"
  Endcase
  SAVXZSNOL=nolign
  nolign=[M:POH2]POHLIN(SAVXZSNOL-1) : # Pour assurer la compatibilité !
  [V]GPOINT="GENPURORD" : Gosub ENTREE From EXEFNC
  nolign=SAVXZSNOL
Endif
Return

#----------------------------------------------------------#
# Point d'entrée GENCDESEL pour accepter la ligne courante #
# -------------------------------------------------------- #
# La variable OK permet d'accepter ou de refuser la ligne  #
#     0 = la ligne est refusée, on passe à la suivante     #
#     1 = la ligne de commande est acceptée                #
#----------------------------------------------------------#
$POINT_GENCDESEL
[V]GPOINT="GENCDESEL" : Gosub ENTREE From EXEFNC
Return

#-------------------------------------------------------------#
# Point d'entrée BEFREWFMI pour charger des valeurs avant     #
# réécriture de la ligne de commande de vente [F:SOQ]         #
# Appelé depuis le traitement SUBPOHA (contexte contremarque) #
#-------------------------------------------------------------#
$POINT_BEFREWFMI
[V]GPOINT="BEFREWFMI" : Gosub ENTREE From EXEFNC
Return

#VPO 02/07/09 bug 54983
#-----------------------------------------------------------------#
# Raz information contremarque achat     (suppression cde)        #
#-----------------------------------------------------------------#
# Entrée  LPOHNUM    : N° de commande achat                       #
#         LPOPLIN    : N° ligne                                   #
#         LPOQSEQ    : N° seq qte                                 #
# Sortie  LRET       : 0 Ok ; 1 Pb                                #
#-----------------------------------------------------------------#
Subprog RAZFMIPOH(LPOHNUM, LPOPLIN, LPOQSEQ , LRET)
Value    Char    LPOHNUM
Value    Integer LPOPLIN
Value    Integer LPOQSEQ
Variable Integer LRET    : LRET=0

If clalev([F:POQ]) = 0  : Local File PORDERQ [POQ]   : Endif

Readlock [POQ]POQ0 = LPOHNUM;LPOPLIN;LPOQSEQ
If fstat
   LRET=1 : Call RSTA("POQ", LPOHNUM-num$(LPOPLIN)-num$(LPOQSEQ)) From GLOCK : End
Endif

# maj orders 69408
If [F:POQ]WIPNUM <> ""
   If clalev ([F:ORD]) = 0  : Local File ORDERS [ORD]   : Endif

   # mise à jour encours
   Readlock [ORD]ORD0 = 2;[F:POQ]WIPNUM;[F:POQ]ITMREF
   If fstat : End : Endif

   [F:ORD]FMI = 1
   [F:ORD]BPRNUM = ""
   Raz [F:ORD]VCRTYPORI, [F:ORD]VCRNUMORI, [F:ORD]VCRLINORI, [F:ORD]VCRSEQORI

   Rewrite [ORD]
   If fstat : LRET=1 : Call FSTA("ORD") From GLOCK : Endif
Endif

# raz données contremarque
[F:POQ]ORI = 1
Raz [F:POQ]SOHNUM, [F:POQ]SOPLIN, [F:POQ]SOQSEQ

Rewrite [POQ]
If fstat : GOK = 0 : Endif
If fstat : LRET=1 : Call FSTA("POQ") From GLOCK : Endif
End

