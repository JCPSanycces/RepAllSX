#<AdxTL>@(#)2.0.0.0 $Revision$
###########################################################################
# TRTACHCDE1         Traitements liés aux commandes          Module ACHAT #
# ----------------------------------------------------------------------- #
# Sous-Programmes :                                                       #
#    - GENERE_CDE  : Génération des commandes                             #
#    - HISTO_CDE   : Historisation des modifications avec avenant         #
#    - ECLATE_LIG  : Eclatement d'une ligne de commande                   #
#    - RAZFMIPOH   : Suppression du lien avec cde de vente si contremarque#
# Gosub                                                                   #
#    - MAJ_ADRESSE : Modification de l'adresse du fournisseur             #
#    - MAJ_SOLDE   : Solde complet d'une commande                         #
# ----------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement standard GTRAITE)                  #
#    - TRTAUTPOH : Génération automatique de commandes de contremarque    #
#    - TRTGENPOH : Génération de commandes à partir du plan de l'acheteur #
#                                                                         #
# ACTIONS modélisation WEB (Saisie de fenêtre GSAISIE)                    #
#    - SAISPLQTY : Eclatement d'une ligne de commande                     #
#                                                                         #
# ACTIONS modélisation WEB (Traitement divers)                            #
#    - TRTCLEPOH : Solde complet d'une commande                           #
###########################################################################


$ACTION
Case ACTION
 When "OUVRE_BATCH"
  #-----------------------------------------------------------------------------#
  # Ouverture tables nécessaires aux contrôles de la boite de dialogue en BATCH #
  #-----------------------------------------------------------------------------#
  Case GACTION
   When "TRTAUTPOH"  : Gosub INIT_TRTAUTPOH
  Endcase
 When "OUVRE"
  #--------------------------------------------------------------#
  # Avant la définition des boutons et l'ouverture de la fenêtre #
  #--------------------------------------------------------------#
  Case GACTION
   When "SAISPLQTY"  : Gosub OUV_SAISPLQTY
  Endcase
 When "TITRE"
  #-------------------------------------------#
  # Titre juste avant ouverture de la fenêtre #
  #-------------------------------------------#
  Case GACTION
   When "SAISPLQTY"  : TIT=mess(34,195,1)
  Endcase
 When "INIT"
  #-----------------------------------------------#
  # Initialisations avant exécution du traitement #
  #-----------------------------------------------#
  Case GACTION
   When "TRTAUTPOH"  : Gosub INIT_TRTAUTPOH
   When "TRTGENPOH"  : Gosub INIT_TRTGENPOH
  Endcase
 When "DEBUT"
  #---------------------------------#
  # Après l'ouverture de la fenêtre #
  #---------------------------------#
  Case GACTION
   When "TRTAUTPOH"  : [M:DIA]PRTFLG=1 : Diszo [DIA]DOCNAM, PRTCOD : Affzo [DIA]1-99
   When "SAISPLQTY"  : Gosub DEB_SAISPLQTY
  Endcase
 When "SETBOUT"
  #-------------------------------------#
  # Avant grisage/dégrisage des boutons #
  #-------------------------------------#
  Case GACTION
   When "TRTAUTPOH" : If GHISTO
                        Diszo [DIA]1-99
                        Call VIREBOUT(CHBOU,"O")   From GOBJET
                        Call VIREBOUT(CHMEN,"MRE") From GOBJET
                      Endif
  Endcase
 When "OK"
  #--------------------------------#
  # Après l'exécution du bouton OK #
  #--------------------------------#
  Case GACTION
   When "TRTAUTPOH"  : GOK=1
   When "SAISPLQTY"  : Gosub OK_SAISPLQTY
  Endcase
 When "END"
  #-------------------------------#
  # Après exécution du bouton FIN #
  #-------------------------------#
  Case GACTION
   When "TRTAUTPOH"  : GOK=0
  Endcase
 When "CONTROLE"
  #----------------------------------------#
  # Contrôle avant exécution du traitement #
  #----------------------------------------#
  Case GACTION
   When "TRTAUTPOH"  : If GOK<1  FIN=1 : GOK=1 : Endif
  Endcase
 When "EXEC"
  #-------------------------#
  # Exécution du traitement #
  #-------------------------#
  Case GACTION
   When "TRTAUTPOH"  : Gosub EXEC_TRTAUTPOH
   When "TRTGENPOH"  : Gosub EXEC_TRTGENPOH
  Endcase
 When "TERMINE"
  #-----------------------------------#
  # Fin après exécution du traitement #
  #-----------------------------------#
  Case GACTION
   When "TRTAUTPOH"  : Gosub TERM_TRTAUTPOH
   When "TRTGENPOH"  : Gosub TERM_TRTGENPOH
  Endcase
 When "SORTIE"
  #----------------------#
  # Sortie du traitement #
  #----------------------#
  Case GACTION
   When "TRTGENPOH"  : Gosub SORT_TRTGENPOH
  Endcase
 When "ABA"
  #-------------------------------------#
  # Après l'exécution du bouton ABANDON #
  #-------------------------------------#
  Case GACTION
   When "SAISPLQTY"  : Gosub ABA_SAISPLQTY
  Endcase
 When "APRES_MODIF"
  #------------------------------------#
  # Après chaque modification de champ #
  #------------------------------------#
  Case GACTION
   When "SAISPLQTY"  : REP="M"
  Endcase
 When "FINSAI"
  #------------------------------------------#
  # Avant de revenir à la fenêtre précédente #
  #------------------------------------------#
  Case GACTION
   When "SAISPLQTY"  : Gosub FINSAI_SAISPLQTY
  Endcase
 When Default
Endcase
Return


###############################################################
# Action TRTAUTPOH : Génération des commandes de contremarque #
###############################################################
#------------------------------------------------------------#
# Initialisations avant exécution du traitement contremarque #
#------------------------------------------------------------#
$INIT_TRTAUTPOH
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
GOK=1
If GSERVEUR
  Onerrgo ERRBATCH : # En batch, il vaut mieux mettre onerrgo
Endif
Local Char  NUMCDE(GLONVCR) : NUMCDE = PARAM(1)
Raz GNUMCDE, GPLISTC, GPUU, GFCY
GCOEUOM = 1
If NUMCDE <> ""
  GNUMCDE = NUMCDE
  Raz GPLISTC
Else
  GORDCAT = 4
Endif
#--- cg le 22/06/99 si module ventes n'est pas present on ne gere pas de contremarque
If GMODU(5)<>2  GMESSAGE=mess(268,197,1) : GERR=1 : FIN=1 : Endif
Gosub OUVRE : # Ouverture fichiers et déclaration variables locales
TIT = mess(51,195,1)
#----- N° cde renseigné : On initialise la fenêtre de sélection sans la saisir -----#
If NUMCDE <> ""
  TYPPRG = 1
  If clalev([M:DIA])=0
    If clalev([F:AWI])=0  Local File AWINDOW [AWI] : Endif
    Read [AWI]AWI0 = BCRIT
    MASQUE = [F:AWI]NOMMSK(0)
    Close Local File [AWI]
    Local Mask =MASQUE [DIA]
  Endif
  Raz [M:DIA]
  [M:DIA]NUMDEB = GNUMCDE       : [M:DIA]NUMFIN = GNUMCDE
  [M:DIA]FCYDEB = [F:SOH]SALFCY : [M:DIA]FCYFIN = [F:SOH]SALFCY
  [M:DIA]BPCDEB = [F:SOH]BPCORD : [M:DIA]BPCFIN = [F:SOH]BPCORD
  [M:DIA]DATDEB = [F:SOH]ORDDAT : [M:DIA]DATFIN = [F:SOH]ORDDAT
  [M:DIA]PRTFLG = 1 : # Pas d'impression bon de commande d'achat
Else
  Local Mask POHW [DIA]
  Raz [M:DIA]
  Call LECMEMO("STD","[M:DIA]","pm3") From GMEMO
Endif
Return
#--------------------------------------------#
# Exécution du traitement de la contremarque #
#--------------------------------------------#
$EXEC_TRTAUTPOH
TRA=1
Gosub TRAITEMENT
If GMESSAGE<>""  GERR=1 : Endif
Return
#-----------------------------------#
# Fin après exécution du traitement #
#-----------------------------------#
$TERM_TRTAUTPOH
If GNUMCDE  = ""
  GPLISTC = ""
Endif
GNUMCDE = "" : GCOEUOM = 0 : GPUU = ""
#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
#-----
Return


###################
# Si erreur Batch #
###################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End


##########################################################################
# CONTREMARQUE(NUMCDE) : S/P de gestion de la contremarque   SR Avril 98 #
# ---------------------------------------------------------------------- #
# Subprog CONTREMARQUE (NUMCDE)                                          #
#   NUMCDE    : Numéro de la commande                                    #
# ---------------------------------------------------------------------- #
# Remplacé par l'action TRTAUTPOH                               MBT 2002 #
##########################################################################


#-----------------------------------------------------#
# Ouverture fichiers et déclaration variables locales #
#-----------------------------------------------------#
$OUVRE
Local Char    CRITERE(250), SECTION(GLONCCE)
Local Char    TIT(50), WMSG(100)
Local Char    WLEGCPY(GLONCPY)
Local Integer OK, NOL, STAT
Local Char    WVACBPR(3), VAT(GLONVAT)(3) : Raz VAT
Local Decimal WCLCAMT(1..7)
Local Char    SYMBOLE2(30), PARAM2(10)
Local Integer NBLOCK
Local Char    TABLOCK(GLONVCR)(func AFNC.ACTIV("POI"))
Local Integer I, J, K
Local Libelle LCKFLG
Local Integer POHCTMPUU : # VPO 14/10/10 68225 ajout param POHCTMPUU
#----- Variables locales pour le point d'entrée CONTREMARQ -----#
Local Char    NUMFOU(GLONBPS), NUMSOH(GLONSOH), DEVISE(GLONCUR), UNITE(GLONUOM)
Local Decimal PUNET
Local Integer LINSOH, SEQSOH, SAVXZSNOL, WCDTSTA, DEVISEFLAG, UNITEFLAG, DATEFLAG
#----- Variables locales pour le point d'entrée CTMFILTRE -----#
Local Char    SOHFILTRE(250), SOQFILTRE(250), SAVCRITERE(250)
#-----
If clalev([F:SOH])=0  Local File SORDER     [SOH]  : Endif
If clalev([F:SOP])=0  Local File SORDERP    [SOP]  : Endif
If clalev([F:SOQ])=0  Local File SORDERQ    [SOQ]  : Endif
If clalev([F:BPC])=0  Local File BPCUSTOMER [BPC]  : Endif
If clalev([F:FCY])=0  Local File FACILITY   [FCY]  : Endif
If clalev([F:POH])=0  Local File PORDER     [POH]  : Endif
If clalev([F:POP])=0  Local File PORDERP    [POP]  : Endif
If clalev([F:POQ])=0  Local File PORDERQ    [POQ]  : Endif
If clalev([F:PPK])=0  Local File PPRICLINK  [PPK]  : Endif
If clalev([F:BPR])=0  Local File BPARTNER   [BPR]  : Endif
If clalev([F:BPS])=0  Local File BPSUPPLIER [BPS]  : Endif
If clalev([F:BPA])=0  Local File BPADDRESS  [BPA]  : Endif
If clalev([F:MVS])=0  Local File BPSUPPMVT  [MVS]  : Endif
If clalev([F:ITM])=0  Local File ITMMASTER  [ITM]  : Endif
If clalev([F:ITP])=0  Local File ITMBPS     [ITP]  : Endif
If clalev([F:ITS])=0  Local File ITMSALES   [ITS]  : Endif
If clalev([F:ITF])=0  Local File ITMFACILIT [ITF]  : Endif
If clalev([F:ITV])=0  Local File ITMMVT     [ITV]  : Endif
If clalev([F:ORD])=0  Local File ORDERS     [ORD]  : Endif
If clalev([F:TCU])=0  Local File TABCUR     [TCU]  : Endif
If clalev([F:TCO])=0  Local File TABCOEFF   [TCO]  : Endif
If clalev([F:ADI])=0  Local File ATABDIV    [ADI]  : Endif
If clalev([F:GAC])=0  Local File GACCOUNT   [GAC]  : Endif
If clalev([F:CAL])=0  Local File CPTANALIN  [CAL]  : Endif
If GMODU(2) = 2
   If clalev([F:BUP])=0  Local File BUDPAR  [BUP]  : Endif
Endif
If !clalev([F:PER])   Local File PERIOD     [PER]  : Endif
If !clalev([M:ORDK])  Local Mask ORDK       [ORDK] : Endif
If !clalev([M:SBCK])  Local Mask SBCK       [SBCK] : Endif
# Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
If clalev([F:ITPF])=0  Local File ITMBPSFCY [ITPF]  : Endif
Local Char    WBPSNUM(GLONBPS)
Local Integer WITMBPS : WITMBPS = 0
Return

#------------#
# Traitement #
#------------#
$TRAITEMENT
If !GSERVEUR
  Call TEMPON("E") From GESECRAN
  #----- Ouverture fichier trace et écriture des sélections -----#
  Call OUVRE_TRACE(mess(14,197,1))  From LECFIC
  Call ECR_TRACE(" ",0)             From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call PRTSCR("POHW","DIA","",0,1)  From ATRTX3
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(" ",0)             From GESECRAN
Endif
#----- Constitution du filtre sur le fichier SORDER -----#
Raz CRITERE
CRITERE = "SOHCAT<>4 & ORDSTA<>2"
If [M:DIA]FCYDEB <> ""
   CRITERE -= ' & SALFCY >= "' +[M:DIA]FCYDEB+'"'
Endif
If [M:DIA]FCYFIN <> ""
   CRITERE -= ' & SALFCY <= "' +[M:DIA]FCYFIN+'"'
Endif
If [M:DIA]DATDEB <> [0/0/0]
   CRITERE -= ' & ORDDAT >= [' +format$(GFMD,[M:DIA]DATDEB)+']'
Endif
If [M:DIA]DATFIN <> [0/0/0]
   CRITERE -= ' & ORDDAT <= [' +format$(GFMD,[M:DIA]DATFIN)+']'
Endif
If [M:DIA]NUMDEB <> ""
   CRITERE -= ' & SOHNUM >= "' +[M:DIA]NUMDEB+'"'
Endif
If [M:DIA]NUMFIN <> ""
   CRITERE -= ' & SOHNUM <= "' +[M:DIA]NUMFIN+'"'
Endif
If [M:DIA]BPCDEB <> ""
   CRITERE -= ' & BPCORD >= "' +[M:DIA]BPCDEB+'"'
Endif
If [M:DIA]BPCFIN <> ""
   CRITERE -= ' & BPCORD <= "' +[M:DIA]BPCFIN+'"'
Endif
#-------------------------------------------------------------------------#
# Point d'entrée CTMFILTRE pour ajouter des filtres supplémentaires       #
# ----------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                             #
#                                                                         #
# CRITERE   : Filtre constitué par le traitement à partir de l'écran POHW #
# SOHFILTRE : Filtre supplémentaire sur l'entête commande vente           #
# SOQFILTRE : Filtre supplémentaire sur les lignes de commande vente      #
#-------------------------------------------------------------------------#
Raz SOHFILTRE, SOQFILTRE
SAVCRITERE=CRITERE
GPOINT="CTMFILTRE" : Gosub ENTREE From EXEFNC
If CRITERE<>SAVCRITERE
  WMSG="CRITERE"-mess(382,197,1)-CRITERE
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
If SOHFILTRE<>""
  WMSG="SOHFILTRE"-mess(382,197,1)-SOHFILTRE
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
If SOQFILTRE<>""
  WMSG="SOQFILTRE"-mess(382,197,1)-SOQFILTRE
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
If CRITERE<>SAVCRITERE | SOHFILTRE<>"" | SOQFILTRE<>""
  Call ECR_TRACE(" ",0)             From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(" ",0)             From GESECRAN
Endif
If CRITERE=""   CRITERE="1=1"   : Endif
If SOHFILTRE="" SOHFILTRE="1=1" : Endif
If SOQFILTRE="" SOQFILTRE="1=1" : Endif
#-----
If parse(CRITERE)
  Call ECR_TRACE("Filter error CRITERE",1)   From GESECRAN : CRITERE="1=1"
Endif
If parse(SOHFILTRE)
  Call ECR_TRACE("Filter error SOHFILTRE",1) From GESECRAN : SOHFILTRE="1=1"
Endif
If parse(SOQFILTRE)
  Call ECR_TRACE("Filter error SOQFILTRE",1) From GESECRAN : SOQFILTRE="1=1"
Endif

#------------------------------------------------------------------#
# Préparation des lignes de commande ACHAT. Pour cela on passe par #
#        le masque des commandes par article [M:POI1]              #
#------------------------------------------------------------------#
Local Mask POI1 [POI1]
Default Mask [POI1]
Raz [M:POI1], GFCY
[M:POI1]USR = GUSER
nolign=1

Filter [SOH] Where evalue(CRITERE) & evalue(SOHFILTRE)
For [SOH] With Nohint
    # Issue 85559 - 2012-12-03 by SR : Calcul de la quantité à prendre en compte
    Filter [SOQ] Where SOHNUM=[F:SOH]SOHNUM & find(FMI,2,3) & FMINUM="" & (QTYSTU-ALLQTYSTU-LPRQTYSTU-OPRQTYSTU-PREQTYSTU)>0
&                    & evalue(SOQFILTRE) & SOQSTA<>3
    Look [SOQ] SOQ0 First
    Filter [SOQ]
    If fstat  Goto SUITSOH : Endif

    Read [FCY] FCY0=[F:SOH]SALFCY
    If fstat
      Raz [F:FCY]
      WMSG=[F:SOH]SOHNUM-mess(67,197,1)-[F:SOH]SALFCY-mess(74,197,1)
      Call ECR_TRACE(WMSG,1) From GESECRAN
      Goto SUITSOH
    Elsif [F:FCY]PURFLG=2
      [M:POI1]POHFCY=[F:SOH]SALFCY
    Else
      WLEGCPY=[F:FCY]LEGCPY
      Filter [FCY] Where LEGCPY=WLEGCPY & PURFLG=2
      Read [FCY] FCY1 First
      Filter [FCY]
      If fstat
        Raz [F:FCY]
        WMSG=[F:SOH]SOHNUM-mess(67,197,1)-WLEGCPY-mess(74,197,1)
        Call ECR_TRACE(WMSG,1) From GESECRAN
        Goto SUITSOH
      Else
        [M:POI1]POHFCY=[F:FCY]FCY
      Endif
    Endif
    # Issue 119789 - 2016-11-18 by SR : Alimentation spécifique du site d'achat
    GPOINT="CTMPOHFCY" : Gosub ENTREE From EXEFNC
    #----- Lecture paramètres si nécessaire -----#
    If GFCY<>[M:POI1]POHFCY
      GFCY=[M:POI1]POHFCY
      Call GETCPY(GFCY,"",0,"") From TRTX3CPT  : If GFINRSP="" GFINRSP=GFCY : Endif
      Call DEFRCPFCY(GFCY)      From TRTACHDEF1
      Call GLOBVAR(GFCY)        From WWGLOBACH
      # VPO 14/10/10 68225 ajout param POHCTMPUU
      # Issue 71069 - 2016-06-13 by SR : US 180 : utilisation de PARAML moins couteux
      Call PARAML (GFCY,"POHCTMPUU",PARAM2) From ADOVAL  : POHCTMPUU=val(PARAM2)
      Call PARAML (GFCY,"DIRORDCTL",PARAM2) From ADOVAL  : GDIRORDCTL=val(PARAM2)
      # Issue 59217 - 2011-12-14 by MUARN : obligation tarif achat
      Call PARAML (GFCY,"PURCTLPRI0",PARAM2) From ADOVAL : GPURCTLPRI0=val(PARAM2)
      # Issue 71069 - 2016-06-10 by SR : US 180
      Call PARAML (GFCY,"PJTSNGDOC",PARAM2) From ADOVAL : GPJTSNGDOC=val(PARAM2)
      If dim([M:POI1]NBAXE)>0
        Raz [M:POI1]NBAXE : # Pour activer le chargement des sections d'entête
      Endif
    Endif
    #---- Vérification des droits d'accès au site de commande -----#
    If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE & !find(([M:POI1]POHFCY),GUSRFCY(1..GNBAUZ))
      WMSG=[F:SOH]SOHNUM-mess(67,197,1)-[M:POI1]POHFCY-mess(2,104,1)
      Call ECR_TRACE(WMSG,1) From GESECRAN
      Goto SUITSOH
     Endif
    #----- Initialisation des sections d'entête -----#
    If dim([M:POI1]NBAXE)>0 & [M:POI1]NBAXE=0
      Raz [F:POH] : [F:POH]=[F:SOH] : [F:POH]=[M:POI1]
      [M:POI1]NBAXE=GNBDIE
      For I=1 To GNBDIE
        [M:POI1]DIE(I-1)=GDIE(I)
        Call INISEC(SECTION,"POW",GDIE(I)) From SUBCDE
        [M:POI1]CCE(I-1)=SECTION
      Next I
    Endif
    #----- Vérification si commande bloquée -----#
    # Bug 48964 : Ctrl sur clt facture (et non sur clt commande)
    Call SDCDTSTA([F:SOH]SOHNUM,[F:SOH]BPCINV,[F:SOH]CHGTYP,0,[F:SOH]CUR,[F:SOH]ORDDAT,
&                 [F:SOH]UNL,1,WCDTSTA,GBIDD1,GBIDD2) From TRTVENCDT
    Case WCDTSTA
        When 2:    WMSG=[F:SOH]SOHNUM-mess(67,197,1)-mess(52,192,1)
                   Call ECR_TRACE(WMSG,1) From GESECRAN
                   Goto SUITSOH
        When 3:    If GDIRORDCTL<2
                     WMSG=[F:SOH]SOHNUM-mess(67,197,1)-mess(29,192,1)
                     Call ECR_TRACE(WMSG,1) From GESECRAN
                     Goto SUITSOH
                   Else
                     WMSG=[F:SOH]SOHNUM-mess(29,192,1)
                     Call ECR_TRACE(WMSG,0) From GESECRAN
                   Endif
    Endcase

    # TODAN-X3-25070 119459.sn. Check if the order is on hold and block the back-to-back order
    If [F:SOH]HLDCOD <> AVOID.ACHAR & [F:SOH]HLDSTA = [V]CST_AYES &
&      func MANHLDLIB.BLK_BACK_TO_BACK([F:SOH]HLDSTA, [F:SOH]HLDCOD) = [V]CST_AYES
      #----- Display the message for back to back not allow reason -----#
      WMSG = func AFNC.MES2(mess(583,194,1), [F:SOH]SOHNUM, [F:SOH]HLDCOD)
      Call ECR_TRACE(WMSG, 1) From GESECRAN
      Goto SUITSOH
    Endif
    # TODAN-X3-25070 119459.en

    #------------------------------------------------------------#
    # Point d'entrée CTMFILTRE1 pour exclure certaines commandes #
    # ---------------------------------------------------------- #
    # Variable utilisable par le point d'entrée                  #
    #                                                            #
    # WCDTSTA : Indicateur d'exclusion (0 = Pas d'exclusion)     #
    #------------------------------------------------------------#
    Raz WCDTSTA
    [V]GPOINT="CTMFILTRE1" : Gosub ENTREE From EXEFNC
    If WCDTSTA
      WMSG=[F:SOH]SOHNUM-mess(67,197,1)
      Call ECR_TRACE(WMSG,1) From GESECRAN
      Goto SUITSOH
    Endif
    #-----
    [M:POI1]ORDDAT = date$
    [M:POI1]BUY    = GUSER
    # Issue 85559 - 2012-12-03 by SR : Calcul de la quantité à prendre en compte
    Filter [SOQ] Where SOHNUM=[F:SOH]SOHNUM & find(FMI,2,3) & FMINUM="" & (QTYSTU-ALLQTYSTU-LPRQTYSTU-OPRQTYSTU-PREQTYSTU)>0
&                    & evalue(SOQFILTRE) & SOQSTA<>3
    For [SOQ]
        NOL = nolign-1
        Read [SOP] SOP0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
        #---------------------------------------------------------#
        # Point d'entrée CTMFILTSOQ pour exclure certaines lignes #
        # ------------------------------------------------------- #
        # Variable utilisable par le point d'entrée               #
        #                                                         #
        # WCDTSTA : Indicateur d'exclusion (0 = Pas d'exclusion)  #
        #---------------------------------------------------------#
        Raz WCDTSTA
        [V]GPOINT="CTMFILTSOQ" : Gosub ENTREE From EXEFNC
        If WCDTSTA  Goto SUITSOQ : Endif
        #-----
        [M:POI1]ORDFCY (NOL) = [M:POI1]POHFCY
        [M:POI1]SOHNUM (NOL) = [F:SOH]SOHNUM
        [M:POI1]SOPLIN (NOL) = [F:SOP]SOPLIN
        [M:POI1]SOQSEQ (NOL) = [F:SOQ]SOQSEQ
        [M:POI1]ITMREF (NOL) = [F:SOP]ITMREF
        # Issue 71276 - 2015-03-02 by SR : Versions
        If dim([M:POI1]ECCVALMAJ)>0
          [M:POI1]ECCVALMAJ(NOL)    = [F:SOQ]ECCVALMAJ
          [M:POI1]ECCVALMIN(NOL)    = [F:SOQ]ECCVALMIN
        Endif
        # End issue 71276

        # Issue 87283 - 2013-01-17 by MUARN : désignation traduite déplacé après alimentation fournisseur
        #[M:POI1]ITMDES (NOL) = [F:SOP]ITMDES
        #[M:POI1]ITMDES1(NOL) = [F:SOP]ITMDES1

        [M:POI1]PRHFCY (NOL) = [F:SOQ]STOFCY
        #-----  Alimentation de l'adresse du site de rcp -----#
        If [F:FCY]FCY<>[M:POI1]PRHFCY (NOL)
          Read [FCY] FCY0=[M:POI1]PRHFCY (NOL) : If fstat Raz [F:FCY] : Endif
        Endif
        [M:POI1]FCYADD (NOL) =[F:FCY]BPAADD
        #----- lecture article et contrôle si catégorie achetée -----#
        #Call LECTURE("ITM",[F:SOP]ITMREF,"") From CONTOBJ => pb en v150
        If [F:ITM]ITMREF<>[F:SOP]ITMREF
           Read [ITM]ITM0=[F:SOP]ITMREF
           If fstat : Raz [F:ITM] : Endif
        Endif
        If fstat | [F:ITM]PURFLG<>2
           WMSG=[F:SOH]SOHNUM+"/"+num$([F:SOP]SOPLIN)+"/"+num$([F:SOP]SOPSEQ)-
&               mess(67,197,1)-mess(70,197,1)
           Call ECR_TRACE(WMSG,1) From GESECRAN
           Goto SUITSOQ
        Endif
        # Issue 112754 - 2016-10-27 by SR : Services
        [M:POI1]ITMKND(NOL) = 1
        If [F:ITM]SCSFLG = 2 : [M:POI1]ITMKND(NOL) = 3 : Endif
        # End issue 112754
        #----- Contrôle si article avec DA obligatoire -----#
        If [F:ITM]PRQFLG=2
           WMSG=[F:SOH]SOHNUM+"/"+num$([F:SOP]SOPLIN)+"/"+num$([F:SOP]SOPSEQ)-
&               mess(67,197,1)-mess(164,194,1)
           Call ECR_TRACE(WMSG,1) From GESECRAN
           Goto SUITSOQ
        Endif
        # Issue 116944 - 2016-06-03 by SR
        #----- Contrôle statut de l'article -----#
        If [F:ITM]ITMSTA<>1 & [F:ITM]ITMSTA<>3
        WMSG=[F:SOH]SOHNUM+"/"+num$([F:SOP]SOPLIN)+"/"+num$([F:SOP]SOPSEQ)-
&           mess(67,197,1)- mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")"
           Call ECR_TRACE(WMSG,1) From GESECRAN
           Goto SUITSOQ
        Endif
        # End issue 116944
        #----------------------------------------------------------------#
        # Si contremarque directe, faut-il traiter la date de réception  #
        #      prévue comme pour une contremarque réceptionnée ?         #
        # DATEFLAG : 0 = Non (Valeur par défaut)                         #
        #            1 = Oui (Positionné par le point d'entrée)          #
        #----------------------------------------------------------------#
        Raz DATEFLAG
        If [F:SOQ]FMI=2
          SAVXZSNOL=NOL
          GPOINT="CTMDIRDAT" : Gosub ENTREE From EXEFNC
          NOL=SAVXZSNOL : nolign=SAVXZSNOL+1
        Endif
        #----------------------------------------------------------------#
        # Date de réception prévue :                                     #
        #    = Date de livraison chez le client si contremarque directe  #
        #    = Date d'expédition si contremarque réceptionnée            #
        #      ajustement avec le délai de préparation de l'article-site #
        #      et des indisponibilités du site de réception.             #
        #----------------------------------------------------------------#
        If [F:SOQ]FMI=2 & !DATEFLAG
          [M:POI1]RETRCPDAT(NOL) = [F:SOQ]EXTDLVDAT
        Else
          [M:POI1]RETRCPDAT(NOL) = [F:SOQ]SHIDAT
          If [F:FCY]FCY<>[F:SOQ]STOFCY
            Read [FCY] FCY0=[F:SOQ]STOFCY : If fstat Raz [F:FCY] : Endif
          Endif
          If [F:ITF]ITMREF<>[F:SOP]ITMREF | [F:ITF]STOFCY<>[F:SOQ]STOFCY
            Read [ITF] ITF0=[F:SOP]ITMREF;[F:SOQ]STOFCY : If fstat Raz [F:ITF] : Endif
          Endif
          If [F:ITM]OFS<>0  [M:POI1]OFS(NOL) = [F:ITM]OFS : Endif
          If [F:ITF]OFS<>0  [M:POI1]OFS(NOL) = [F:ITF]OFS : Endif
          #VPO 26/10/10 22933 on tient compte des jours ouvrés pour calcul date de recept selon delai preparation
          #[M:POI1]RETRCPDAT(NOL)-=[F:ITF]PRPLTI
          Call TRT_PRPLTI([M:POI1]RETRCPDAT(NOL),[F:ITF]PRPLTI) From TRTACHCDE1
          Call CTL_JOU2([M:POI1]RETRCPDAT(NOL),[M:POI1]ORDDAT,[M:POI1]OFS(NOL)) From TRTACHCDE1
          If (mkstat | GERR=2) & GMESSAGE<>""
            WMSG=mess(245,194,1)-[F:SOQ]STOFCY+"\"+GMESSAGE
            WMSG=format$("D:"+GFMDAT,[M:POI1]RETRCPDAT(NOL))-WMSG
            Call ECR_TRACE(WMSG,0) From GESECRAN
            Raz mkstat, GERR, GMESSAGE
          Endif
        Endif
        #---------------------------------------------------------------------#
        # Point d'entrée CONTREMARQ pour suggérer le fournisseur et le pu net #
        # ------------------------------------------------------------------- #
        # Variables utilisables par le point d'entrée                         #
        #                                                                     #
        # NUMSOH  : Numéro de la commande de vente en cours de traitement     #
        # LINSOH  : Ligne  de la commande de vente en cours de traitement     #
        # SEQSOH  : Séquence de la ligne cde de vente en cours de traitement  #
        # NOL     : Ligne du masque écran [M:POI1] en cours de chargement     #
        # Les classes [F:SOH], [F:SOQ] et [F:SOP] sont disponibles            #
        #                                                                     #
        # NUMFOU  : Numéro du fournisseur suggéré                             #
        # PUNET   : Prix unitaire net suggéré                                 #
        # UNITE   : Unité dans laquelle est exprimé le prix unitaire          #
        #           (Par défaut c'est l'UA de l'article-fournisseur)          #
        # UNITEFLAG  : Indicateur unité de commande                           #
        #              0 = Unité d'achat                                      #
        #              1 = Unité de vente si c'est une UC (valeur par défaut) #
        #              2 = Unité précisée dans UNITE si c'est une UC          #
        # DEVISE  : Devise dans laquelle est exprimé le prix unitaire         #
        #           (Par défaut c'est la devise du business partner)          #
        # DEVISEFLAG : Indicateur devise (2 --> DEVISE = devise commande)     #
        #---------------------------------------------------------------------#
        Raz NUMFOU, PUNET, UNITE, UNITEFLAG, DEVISE, DEVISEFLAG
        # VPO 14/10/10 68225 ajout param POHCTMPUU
        If POHCTMPUU=2
            UNITEFLAG=0 : # on travaille en unité d'achat
        Else
            UNITEFLAG=1 : # Valeur par défaut à partir de la version 140 !
        Endif
        NUMSOH=[F:SOH]SOHNUM
        LINSOH=[F:SOP]SOPLIN
        SEQSOH=[F:SOQ]SOQSEQ
        SAVXZSNOL=NOL
        GPOINT="CONTREMARQ" : Gosub ENTREE From EXEFNC
        NOL=SAVXZSNOL : nolign=SAVXZSNOL+1
        #----- Vérification existence devise -----#
        If [F:TCU]CUR<>DEVISE
          Read [TCU] TCU0=DEVISE : If fstat Raz [F:TCU], DEVISE : Endif
        Endif
        #----- Lecture article-site de commande si nécessaire -----#
        If [F:ITF]ITMREF<>[F:SOP]ITMREF | [F:ITF]STOFCY<>GFCY
           Read [ITF] ITF0=[F:SOP]ITMREF;GFCY : If fstat Raz [F:ITF] : Endif
        Endif
        #----- Chargement code acheteur de la ligne -----#
        If [F:ITM]BUY<>"" [M:POI1]LINBUY(NOL)=[F:ITM]BUY : Endif
        If [F:ITF]BUY<>"" [M:POI1]LINBUY(NOL)=[F:ITF]BUY : Endif
        If [M:POI1]LINBUY(NOL)=""  [M:POI1]LINBUY(NOL)=[M:POI1]BUY : Endif
        #-----
        [M:POI1]STOMGTCOD(NOL)=[F:SOQ]STOMGTCOD
        If dim([M:POI1]TSICOD1(NOL))>0 [M:POI1]TSICOD1(NOL)=[F:ITM]TSICOD(0) : Endif
        If dim([M:POI1]TSICOD2(NOL))>0 [M:POI1]TSICOD2(NOL)=[F:ITM]TSICOD(1) : Endif
        If dim([M:POI1]TSICOD3(NOL))>0 [M:POI1]TSICOD3(NOL)=[F:ITM]TSICOD(2) : Endif
        If dim([M:POI1]TSICOD4(NOL))>0 [M:POI1]TSICOD4(NOL)=[F:ITM]TSICOD(3) : Endif
        If dim([M:POI1]TSICOD5(NOL))>0 [M:POI1]TSICOD5(NOL)=[F:ITM]TSICOD(4) : Endif
        #----- Chargement valeurs ligne avec l'article-fournisseur ------#
        If NUMFOU<>""
           # Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
           #Read [ITP] ITP0=[F:SOP]ITMREF;NUMFOU
           #If fstat Raz [F:ITP] : Endif
           Raz WITMBPS
           Read [ITPF] ITPF0=[F:SOP]ITMREF;NUMFOU;[M:POI1]PRHFCY(NOL)
           If fstat
             Raz [F:ITPF]
             Read [ITP] ITP0=[F:SOP]ITMREF;NUMFOU
             If fstat
               Raz [F:ITP]
             Else
               WITMBPS=1
             Endif
           Else
             WITMBPS=2
             Read [ITP] ITP0=[F:SOP]ITMREF;NUMFOU
             If fstat Raz [F:ITP] : Endif
           Endif
           # End issue X3-55891
        Else
           #-----
           Filter [BPR] Where BPCFLG=2
           Read [BPR] BPR2(2)=2;[M:POI1]POHFCY
           If fstat  Raz [F:BPR] : Endif
           [G:BPR]currind=1 : [G:BPR]currlen=0 : # Réinitialisation clé par défaut
           Filter [BPR]
           GBIDI1=max([F:BPR]BETFCY,1)
           #-----
           # Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
           Raz [F:ITP], [F:ITPF], GBIDC3, WBPSNUM
           #----- Recherche fournisseur contremarque (litige non bloquant) -----#
           # Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
#           For [ITP] ITP1 Where ITMREF=[F:SOP]ITMREF & CTMBPSFLG=2
#              If [F:ITP]DOUFLG<3
#                Read [BPR] BPR0=[F:ITP]BPSNUM : If fstat  Raz [F:BPR] : Endif
#                If [F:BPR]BETFCY=GBIDI1
#                  If [F:BPR]BETFCY=1 | ([F:BPR]FCY<>[M:POI1]POHFCY & [F:BPR]FCY<>[F:SOH]STOFCY)
#                    Raz GBIDC3 : Break
#                  Endif
#                Else
#                  If GBIDC3=""  GBIDC3=[F:ITP]BPSNUM : Endif
#                Endif
#              Endif
#           Next
#           If GBIDC3<>""
#              Read [ITP] ITP0=[F:SOP]ITMREF;GBIDC3 : If fstat  Raz [F:ITP] : Endif
#           Endif
#           #----- Recherche fournisseur autre (litige non bloquant) -----#
#           If [F:ITP]BPSNUM=""
#              For [ITP] ITP1 Where ITMREF=[F:SOP]ITMREF & CTMBPSFLG<>2
#                 If [F:ITP]DOUFLG<3  Break : Endif
#              Next
#           Endif
           Call DEFBPSNUM([F:SOP]ITMREF,[M:POI1]POHFCY,[M:POI1]PRHFCY(NOL),[F:SOH]STOFCY,2,WBPSNUM,WITMBPS) From TRTACHDEF1
           # End issue X3-55891
        Endif

        # Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
        # Issue 87283 - 2013-01-17 by MUARN : désignation traduite déplacé après alimentation fournisseur
        #If [F:BPR]BPRNUM<>[F:ITP]BPSNUM
          #Read [BPR]BPR0=[F:ITP]BPSNUM
        If [F:BPR]BPRNUM<>WBPSNUM
           Read [BPR]BPR0=WBPSNUM
           If fstat : Raz [F:BPR] : Endif
        Endif
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:POI1]ITMDES1(NOL), "[F:ITM]") From TRTX3
        # Issue 96432 - 2014-02-04 by MUARN : ITMDES conservé des ventes si client et fournisseur même langue
        If [F:BPR]LAN = [F:SOH]LAN
          [M:POI1]ITMDES (NOL) = [F:SOP]ITMDES
        Else
          Call CHARGE_DEFITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,[M:POI1]ITMDES(NOL), "[F:ITM]") From TRTX3
        Endif

        #----- Erreur si article-fournisseur en litige bloquant -----#
        # Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
        #If [F:ITP]DOUFLG=3
        If (WITMBPS=1 & [F:ITP]DOUFLG=3) | (WITMBPS=2 & [F:ITPF]DOUFLG=3)
           WMSG =[F:SOH]SOHNUM+"/"+num$([F:SOP]SOPLIN)+"/"+num$([F:SOP]SOPSEQ)
           # Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
           #WMSG-=mess(67,197,1)-[F:ITP]ITMREF-[F:ITP]BPSNUM-mess(9,194,1)
           If WITMBPS=1
             WMSG-=mess(67,197,1)-[F:ITP]ITMREF-[F:ITP]BPSNUM-mess(9,194,1)
           Else
             WMSG-=mess(67,197,1)-[F:ITPF]ITMREF-[F:ITPF]BPSNUM-mess(9,194,1)
           Endif
           Call ECR_TRACE(WMSG,1) From GESECRAN
           Goto SUITSOQ
        Endif
        #-----
        # Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
        #If [F:ITP]BPSNUM<>""
        If WBPSNUM<>""
           Raz mkstat
           # Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
           #Call CTLBPRCPY([F:ITP]BPSNUM,[M:POI1]POHFCY) From CONTX3
           Call CTLBPRCPY(WBPSNUM,[M:POI1]POHFCY) From CONTX3
           If mkstat
             #----- Tiers non autorisé pour la société du site concerné -----#
             WMSG=[F:SOH]SOHNUM+"/"+num$([F:SOP]SOPLIN)+"/"+num$([F:SOP]SOPSEQ)-GMESSAGE
             Raz GMESSAGE, mkstat
             Call ECR_TRACE(WMSG,1) From GESECRAN
             Goto SUITSOQ
           Endif
           #----- Contrôle bloquant si fournisseur inactif, prospect ou encours bloqué -----#
           #----- Control blocking if inactive provider, prospect or blocked outstanding ---#
           # Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
           #If [F:BPS]BPSNUM<>[F:ITP]BPSNUM
             #Read [BPS] BPS0=[F:ITP]BPSNUM : If fstat  Raz [F:BPS] : Endif
           If [F:BPS]BPSNUM<>WBPSNUM
             Read [BPS] BPS0=WBPSNUM : If fstat  Raz [F:BPS] : Endif
           Endif
           # Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
           #Call CONTROLE("BPS","ABC",[F:ITP]BPSNUM,"",mkstat) From CONTOBJ
           Call CONTROLE("BPS","ABC",WBPSNUM,"",mkstat) From CONTOBJ
           If mkstat
             WMSG=[F:SOH]SOHNUM+"/"+num$([F:SOP]SOPLIN)+"/"+num$([F:SOP]SOPSEQ)-GMESSAGE
             Raz GMESSAGE, mkstat
             Call ECR_TRACE(WMSG,1) From GESECRAN
             Goto SUITSOQ
           Endif
           #----- Warning si fournisseur ou article-fournisseur en litige non bloquant -----#
           #----- Warning if supplier or supplier article in non-blocking dispute -----#
           If [F:BPS]DOUFLG=2
             WMSG =[F:SOH]SOHNUM+"/"+num$([F:SOP]SOPLIN)+"/"+num$([F:SOP]SOPSEQ)
             # Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
             #WMSG-=[F:ITP]BPSNUM-mess(4,194,1)
             WMSG-=WBPSNUM-mess(4,194,1)
             Call ECR_TRACE(WMSG,0) From GESECRAN
           Endif
           # Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
           #If [F:ITP]DOUFLG=2
           If (WITMBPS=1 & [F:ITP]DOUFLG=2) | (WITMBPS=2 & [F:ITPF]DOUFLG=2)
             WMSG =[F:SOH]SOHNUM+"/"+num$([F:SOP]SOPLIN)+"/"+num$([F:SOP]SOPSEQ)
             # Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
             #WMSG-=[F:ITP]ITMREF-[F:ITP]BPSNUM-mess(9,194,1)
             WMSG-=[F:SOP]ITMREF-WBPSNUM-mess(9,194,1)
             Call ECR_TRACE(WMSG,0) From GESECRAN
           Endif
           #-----
           # Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
           #[M:POI1]BPSNUM(NOL)   =[F:ITP]BPSNUM
           [M:POI1]BPSNUM(NOL)   =WBPSNUM
           #----- Contrôle et chargement des zones inter-sites -----#
           Local   Char     WPOHFCY(GLONFCY) : [L]WPOHFCY=[M:POI1]POHFCY
           # Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
           #Local   Char     WBPSNUM(GLONBPS) : [L]WBPSNUM=[M:POI1]BPSNUM(NOL)
           Local   Libelle  WORI             : [L]WORI=3
           Gosub CTRL_INTERSITE From SUBPOI
           If mkstat
             WMSG=[F:SOH]SOHNUM+"/"+num$([F:SOP]SOPLIN)+"/"+num$([F:SOP]SOPSEQ)-GMESSAGE
             Raz GMESSAGE, mkstat
             Call ECR_TRACE(WMSG,1) From GESECRAN
             Goto SUITSOQ
           Endif
           # Issue 71069 - 2016-06-10 by SR : US 180
           # Si une seule commande de vente et pas Inter société
           If [M:DIA]NUMDEB = [M:DIA]NUMFIN & NOL = 0 &  GPJTSNGDOC <> 2 & [M:POI1]BETCPY(NOL) <> 2
              [M:POI1]PJTH = [F:SOH]PJT
           Endif
           # End issue 71069
           If [M:POI1]SALFCY(NOL)<>"" & [F:SOQ]FMI<>3
             #-----------------------------------------------------------------------------#
             # Point d'entrée CTMDIRECT pour autoriser la contremarque directe inter-xxx   #
             #   WCTMFLAG : 0 = Pas de génération de commande de vente                     #
             #              1 = Génération de la commande de vente inter-sites ou sociétés #
             #-----------------------------------------------------------------------------#
             If dim(WCTMFLAG)<1  Local Libelle WCTMFLAG : Endif
             Raz WCTMFLAG
             GPOINT="CTMDIRECT" : Gosub ENTREE From EXEFNC
             If !WCTMFLAG
               Raz [M:POI1]SALFCY(NOL), [M:POI1]DME(NOL), [M:POI1]SOHCAT(NOL)
             Endif
             #-----
           Endif
           [M:POI1]PUU(NOL)      =[F:ITP]PUU
           If GACTDEB=2  [M:POI1]EECINCRAT(NOL)=[F:ITP]EECINCRAT : Endif
        Else
           #----- Erreur si pas d'enregistrement article-fournisseur -----#
           #----- Error if no article-supplier registration -----#
           WMSG=[F:SOH]SOHNUM+"/"+num$([F:SOP]SOPLIN)+"/"+num$([F:SOP]SOPSEQ)-
&               mess(67,197,1)-NUMFOU-mess(69,197,1)
           Call ECR_TRACE(WMSG,1) From GESECRAN
           Goto SUITSOQ
        Endif
        #-----
        If [F:ITP]QUAFLG>1 [M:POI1]QUAFLG(NOL)=2 Else [M:POI1]QUAFLG(NOL)=1 : Endif
        [M:POI1]STU(NOL)       = [F:ITM]STU
        # Issue 85559 - 2012-12-03 by SR : Calcul de la quantité à prendre en compte
        [M:POI1]QTYSTU(NOL)    = [F:SOQ]QTYSTU-[F:SOQ]ALLQTYSTU-[F:SOQ]LPRQTYSTU-[F:SOQ]OPRQTYSTU-[F:SOQ]PREQTYSTU
        [M:POI1]RETQTYSTU(NOL) = [F:SOQ]QTYSTU-[F:SOQ]ALLQTYSTU-[F:SOQ]LPRQTYSTU-[F:SOQ]OPRQTYSTU-[F:SOQ]PREQTYSTU
        # Issue 103546 - 2014-10-27 by MUARN : alimentation quantité mini de commande
        [M:POI1]PURMINQTY(NOL)=[F:ITP]PURMINQTY

        If [M:POI1]QTYSTU(NOL)< 0    : [M:POI1]QTYSTU(NOL)    = 0 : Endif
        If [M:POI1]RETQTYSTU(NOL)< 0 : [M:POI1]RETQTYSTU(NOL) = 0 : Endif
## VPO 14/10/10 68225 on autorise aussi unité de stock
##&         (find([F:SOP]SAU,[F:ITM]PCU) | [F:SOP]SAU=[F:ITP]PCU)
        If UNITEFLAG=1 & [F:SOP]SAU<>[F:ITP]PUU &
&         (find([F:SOP]SAU,[F:ITM]PCU) | [F:SOP]SAU=[F:ITP]PCU | [F:SOP]SAU=[F:ITM]STU)
          [M:POI1]UOM(NOL)   =[F:SOP]SAU
          # Issue 85559 - 2012-12-03 by SR : Calcul de la quantité à prendre en compte
          [M:POI1]QTYUOM(NOL)=[F:SOQ]QTY-[F:SOQ]ALLQTY-[F:SOQ]LPRQTY-[F:SOQ]OPRQTY-[F:SOQ]PREQTY
          If [M:POI1]QTYUOM(NOL) < 0 : [M:POI1]QTYUOM(NOL) = 0 : Endif
          Call PCAL_QTY([M:POI1]QTYSTU(NOL),[M:POI1]STU(NOL),
&                       [M:POI1]QTYPUU(NOL),[M:POI1]PUU(NOL),
&                       [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),1,GBIDD1)  From TRTACHQTE1
          #----- Calcul du coef UC-UA car le coef UV-US est modifiable dans les vtes -----#
          GCOEUOM=arr([M:POI1]QTYPUU(NOL)/[M:POI1]QTYUOM(NOL),10^-6)
          [M:POI1]UOMPUUCOE(NOL) = GCOEUOM
          #-----
          [M:POI1]UOMFLG(NOL)    = 2
        Elsif UNITEFLAG=2 & UNITE<>"" & UNITE<>[F:ITP]PUU &
&         (find(UNITE,[F:ITM]PCU) | UNITE=[F:ITP]PCU | UNITE=[F:ITM]STU)
          [M:POI1]UOM(NOL)   =UNITE
          Call PCAL_QTY([M:POI1]QTYSTU(NOL),[M:POI1]STU(NOL),
&                       [M:POI1]QTYUOM(NOL),[M:POI1]UOM(NOL),
&                       [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),1,GBIDD1) From TRTACHQTE1
          Call PCAL_QTY([M:POI1]QTYSTU(NOL),[M:POI1]STU(NOL),
&                       [M:POI1]QTYPUU(NOL),[M:POI1]PUU(NOL),
&                       [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),1,GBIDD1)  From TRTACHQTE1
          #----- Calcul du coef UC-UA -----#
          GCOEUOM=arr([M:POI1]QTYPUU(NOL)/[M:POI1]QTYUOM(NOL),10^-6)
          [M:POI1]UOMPUUCOE(NOL) = GCOEUOM
          #-----
          [M:POI1]UOMFLG(NOL)    = 2
        Else
          [M:POI1]UOM(NOL)=[F:ITP]PUU
          Call PCAL_QTY([M:POI1]QTYSTU(NOL),[M:POI1]STU(NOL),
&                       [M:POI1]QTYUOM(NOL),[M:POI1]UOM(NOL),
&                       [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),1,GBIDD1) From TRTACHQTE1
          [M:POI1]QTYPUU(NOL)    = [M:POI1]QTYUOM(NOL)
          [M:POI1]UOMPUUCOE(NOL) = 1
          [M:POI1]UOMFLG(NOL)    = 1
        Endif
        #----- Lecture business partner et fournisseur si nécessaire -----#
        If [F:BPR]BPRNUM<>[M:POI1]BPSNUM(NOL)
          Read [BPR] BPR0=[M:POI1]BPSNUM(NOL)
          If fstat  Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
        Endif
        If [F:BPS]BPSNUM<>[M:POI1]BPSNUM(NOL)
          Read [BPS] BPS0=[M:POI1]BPSNUM(NOL)
          If fstat  Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
        Endif
        #----- Chargement de la devise de commande -----#
        If DEVISE<>"" & DEVISEFLAG=2
           [M:POI1]CUR(NOL) = DEVISE
        Else
           [M:POI1]CUR(NOL) = [F:BPS]CUR
        Endif
        #-----
        [M:POI1]CHGTYP(NOL) = [F:BPS]CHGTYP
        [M:POI1]ORICRY(NOL) = [F:BPR]CRY
        Call COURSITE([M:POI1]CUR(NOL),GFCY,[M:POI1]CHGTYP(NOL),[M:POI1]ORDDAT,[M:POI1]CHGCOE(NOL),I) From TRTDEV
        If [F:ITM]ITMREF = "" : Read [ITM] ITM0 = [F:SOP]ITMREF : Endif
        Call INIT_REGIME([F:BPS]BPSNUM,[M:POI1]POHFCY,"F",WVACBPR) From CPTSUB
        Call ALIVATCOD(2,[M:POI1]BPSNUM(NOL),[M:POI1]ITMREF(NOL),"POI1",NOL) From TRTX3
        # Issue 71069 - 2016-05-24 by MUARN : PJT à la ligne côté ventes
        #[M:POI1]PJT(NOL) = [F:SOH]PJT
        # Issue 71069 - 2016-06-10 by SR : US 180 : Correction : Que si pas Inter soc
        If [M:POI1]BETCPY(NOL) <> 2
          [M:POI1]PJT(NOL) = [F:SOQ]PJT
        Endif
        # End issue 71069

        #----- Chargement paramètres et libellés colonnes tarif -----#
        If GPLISTC<>[F:BPS]PLISTC | nolign = 1
           GPLISTC=[F:BPS]PLISTC : Call TARIFCHGT(6) From TRTPRICE
           Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
        Endif
        #----- Chargement prix unitaire -----#
        If PUNET<>0
           If PUNET<0  Raz PUNET : Endif
           [M:POI1]GROPRI(NOL)=PUNET
           [M:POI1]PRIREN(NOL)=GDACMANPUR
           If UNITE<>""
              #--- Appel du S/P pour chargement du coefficient avec précision maxi ---#
              Call PCAL_QTY([M:POI1]QTYUOM(NOL),[M:POI1]UOM(NOL),GBIDD1,UNITE,
&                  [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),1,GBIDD2) From TRTACHQTE1
              #--- Conversion prix unitaire si unités différentes ---#
              [M:POI1]GROPRI(NOL)=arr(PUNET*GBIDD2,10^-GDECPRI)
           Endif
           If DEVISE<>"" & DEVISEFLAG<>2
              #--- Conversion prix unitaire si devises différentes ---#
              Call CONVERT2(DEVISE,[M:POI1]CUR(NOL),GLOCALDEV,[M:POI1]CHGTYP(NOL),
&                           [M:POI1]ORDDAT,[M:POI1]GROPRI(NOL),GBIDD1,STAT) From TRTDEV
              If STAT=0
                 [M:POI1]GROPRI(NOL)=arr(GBIDD1,10^-GDECPRI)
              Endif
           Endif
           [M:POI1]NETPRI(NOL)=[M:POI1]GROPRI(NOL)
        #----- Recherche tarif -----#
        Else
           GPUU = [M:POI1]PUU(NOL)
           Call RECH_TARIF ("POI",NOL) From TRTACHTAR1
        Endif
        #----- Si pas inter-sites intra-société, erreur si pas de tarif -----#
        If [M:POI1]BETFCY(NOL)<>2 | [M:POI1]BETCPY(NOL)=2
           # Issue 59217 - 2011-12-14 by MUARN : obligation tarif achat
#           If [M:POI1]GROPRI(NOL)=0 & [M:POI1]PRIREN(NOL)=0 & [M:POI1]NETPRI(NOL)=0
           If [M:POI1]GROPRI(NOL)=0 & [M:POI1]PRIREN(NOL)=0 & [M:POI1]NETPRI(NOL)=0 & GPURCTLPRI0 <> 2
           # fin Issue 59217 - 2011-12-14 by MUARN : obligation tarif achat
              WMSG =[F:SOH]SOHNUM+"/"+num$([F:SOP]SOPLIN)+"/"+num$([F:SOP]SOPSEQ)
              WMSG-=mess(67,197,1)-mess(84,197,1)
              Call ECR_TRACE(WMSG,1) From GESECRAN
              Goto SUITSOQ
           Endif
        Endif
        # Issue X3-83174 - 2018-03-22 by SR : En automatique, laisser faire l'import
        # La même chose est refaite en AP_GROPRI de SUBPOH
        #----- Initialisation des comptes et du type d'achat -----#
#        If [M:POI1]LINACC1(NOL)="" & [M:POI1]LINACC2(NOL)="" & [M:POI1]LINACC3(NOL)=""
#          Call INIT_COMPTES_LIGNE(NOL) From SUBPOI
#        Endif
#        If [M:POI1]LINPURTYP(NOL)=0
#          Call D_LINPURTYP([M:POI1]LINPURTYP(NOL)) From SUBPOI
#        Endif
#        #----- Initialisation des sections analytiques de la ligne -----#
#        For I=1 To GNBDIE
#          If evalue("dim([M:POI1]CCE"+num$(I)+"(NOL))")>0
#            Call INIT_CCE(SECTION,I,"POID","[M:POI1]LINACC",NOL) From TRTX3CPT
#            Assign "[M:POI1]CCE"+num$(I)+"(NOL)" With SECTION
#          Endif
#        Next I
        #-----
        # End issue X3-83174
        [M:POI1]LINTYP(NOL)=1
        [M:POI1]EXTRCPDAT(NOL)=[M:POI1]RETRCPDAT(NOL)
        [M:POI1]LINAMT(NOL)=[M:POI1]NETPRI(NOL)*[M:POI1]QTYUOM(NOL)
        Call ARRDEV([M:POI1]LINAMT(NOL),[M:POI1]CUR(NOL)) From TRTDIV
        Call ALICLCAMT2([M:POI1]ITMREF(NOL),[M:POI1]QTYUOM(NOL),NOL,"POI1",WCLCAMT) From TRTX3
        [M:POI1]CLCAMT1(NOL)=WCLCAMT(1)
        [M:POI1]CLCAMT2(NOL)=WCLCAMT(2)
        [M:POI1]CLCAMT3(NOL)=WCLCAMT(3)
        If dim([M:POI1]CLCAMT4)>0  [M:POI1]CLCAMT4(NOL)=WCLCAMT(4) : Endif
        If dim([M:POI1]CLCAMT5)>0  [M:POI1]CLCAMT5(NOL)=WCLCAMT(5) : Endif
        If dim([M:POI1]CLCAMT6)>0  [M:POI1]CLCAMT6(NOL)=WCLCAMT(6) : Endif
        If dim([M:POI1]CLCAMT7)>0  [M:POI1]CLCAMT7(NOL)=WCLCAMT(7) : Endif
        Call CLCTAXEMNT2([M:POI1]LINAMT(NOL),VAT,1,GSOCIETE,[M:POI1]ORDDAT,WCLCAMT,
&                        [M:POI1]LINATIAMT(NOL)) From TRTX3
        Call ARRDEV([M:POI1]LINATIAMT(NOL),[M:POI1]CUR(NOL)) From TRTDIV
        #----- Lock logique de l'entête de commande vente -----#
        If !find([F:SOH]SOHNUM,TABLOCK(0..NBLOCK))
          If NBLOCK>dim(TABLOCK)-2
            WMSG =[F:SOH]SOHNUM+"/"+num$([F:SOP]SOPLIN)+"/"+num$([F:SOP]SOPSEQ)
            WMSG-=mess(67,197,1)-"("+mess(53,184,1)+")"
            Call ECR_TRACE(WMSG,1) From GESECRAN
            Break 2
          Else
            SYMBOLE2="SOH"+[F:SOH]SOHNUM
            Lock=SYMBOLE2
            If fstat
              WMSG =[F:SOH]SOHNUM+"/"+num$([F:SOP]SOPLIN)+"/"+num$([F:SOP]SOPSEQ)
              WMSG-=mess(67,197,1)-mess(10,100,1)
              Call ECR_TRACE(WMSG,1) From GESECRAN
              LCKFLG=1
              Goto SUITSOQ
            Endif
            TABLOCK(NBLOCK)=[F:SOH]SOHNUM
            NBLOCK+=1
          Endif
        Endif
        If nolign>dim([M:POI1]ITMREF)-1
          Call ECR_TRACE("[M:POI1]"-mess(54,126,1),0) From GESECRAN : Break 2
        Endif
        nolign+=1
    $SUITSOQ
    Next
$SUITSOH
Next
Filter [SOH] : Filter [SOQ]
[M:POI1]NBLIG = nolign-1
If !GSERVEUR & LCKFLG=1 & [M:POI1]NBLIG<>0
  #----- Modification en cours sur un autre poste, Voulez-vous continuez ? -----#
  OK=2 : Call OUINON(mess(10,100,1)+","-mess(205,100,1),OK) From GESECRAN
  If OK=2  Raz LCKFLG : Endif
Else
  Raz LCKFLG
Endif
If [M:POI1]NBLIG<>0
  #----- Récupération des options d'impression -----#
  [M:POI1]PRTFLG=[M:DIA]PRTFLG
  [M:POI1]DOCNAM=[M:DIA]DOCNAM
  [M:POI1]PRTCOD=[M:DIA]PRTCOD
  [M:POI1]PRTSRV=[M:DIA]PRTSRV
  [M:POI1]PRTNAM=[M:DIA]PRTNAM
  # sr 08.11 demande 74804
  [M:POI1]PRTCOP=[M:DIA]PRTCOP

  #-----
  If LCKFLG=0
    #----- génération des commandes d'achat -----#
    Call GENERE_CDE("",3,1)
  Else
    #----- Transaction abandonnée (erreur ou conflit d'accès) -----#
    Call ECR_TRACE(mess(157,199,1),1) From GESECRAN
  Endif
Else
  #----- Génération des commandes Aucune ligne à traiter -----#
  Call ECR_TRACE(mess(14,197,1)-mess(71,197,1),0) From GESECRAN
Endif
#-- Suppression des locks logiques avant de lire la trace pour ne pas rester coincé --#
For I=0 To NBLOCK-1
  SYMBOLE2 = "SOH"+num$(TABLOCK(I))
  Unlock = SYMBOLE2
Next I
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call TEMPOFF From GESECRAN
Endif
Return

###############################################################################
# Action TRTGENPOH : Génération des commandes à partir du plan de l'acheteur  #
# --------------------------------------------------------------------------- #
#   PARAM(1) = USER   : Code de l'opérateur dont les commandes sont à générer #
#   PARAM(2) = TRAIT  : Code choix (3=sans question avec Trbegin-Commit)      #
#   PARAM(3) = TARGRP : Code traitement des tarifs groupés                    #
###############################################################################
#----------------------------------------------------#
# Avant exécution du traitement                      #
# Vérifications : Au moins une ligne,                #
#                 Fournisseur obligatoire, ...etc    #
#                 Recalcul tarif ligne si nécessaire #
#----------------------------------------------------#
$INIT_TRTGENPOH
Local Char     OPERATEUR(GLONAUS) : OPERATEUR=PARAM(1)
Local Integer  CHOIX        : CHOIX=val(PARAM(2))
Local Integer  TARGRP       : TARGRP=val(PARAM(3))
Gosub CTL_TRTGENPOH
If GERR=1 :  FIN=1 : OK=0 : Endif
TIT=mess(86,194,1)
Return

$CTL_TRTGENPOH
Local Shortint I, J
Local Integer WOK
If [M:POI1]NBLIG=0
  GMESSAGE=mess(61,199,1) : GERR=1 : OK=0 : FIN=1 : Return
Endif
For I=0 To [M:POI1]NBLIG-1
  If [M:POI1]BPSNUM(I)=""
    GMESSAGE=mess(131,194,1)-num$(I+1) : GERR=1
    Break
  Endif
  If [M:POI1]BETFCY(I)=2 & [M:POI1]LINSTOFCY(I)=""
    GMESSAGE=mess(311,194,1)-num$(I+1) : GERR=1
    Break
  Endif
  If [M:POI1]QTYPUU(I)<[M:POI1]PURMINQTY(I)
    Raz J, GBIDD1
    While J<[M:POI1]NBLIG
      K=find([M:POI1]ITMREF(I),[M:POI1]ITMREF(J..[M:POI1]NBLIG-1))
      If K=0
        J=[M:POI1]NBLIG
      Else
        If [M:POI1]BPSNUM(J+(K-1))=[M:POI1]BPSNUM(I)
          GBIDD1+=[M:POI1]QTYPUU(J+(K-1))
        Endif
        J+=K
      Endif
    Wend
    #VPO 15/10/10 17730/59532 contrôle selon paramètre
    If GPOHMINQTY=0 : GPOHMINQTY=1 : Endif
    #If GBIDD1<[M:POI1]PURMINQTY(I)
    If GBIDD1<[M:POI1]PURMINQTY(I) & GPOHMINQTY<3
      GMESSAGE =mess(18,197,1)-num$(I+1)
      GMESSAGE-=mess(14,194,1)-format$("N:15F",[M:POI1]PURMINQTY(I))
      GMESSAGE-=[M:POI1]PUU(I)
      If GPOHMINQTY=1
          GERR=1 : Break
      Else : #GPOHMINQTY=2
          #pour ne pas afficher 2 fois le message si meme article
          If I=0 | find([M:POI1]ITMREF(I),[M:POI1]ITMREF(0..I-1))=0
              WOK=2
              Call AVERTIR (GMESSAGE, WOK)From GESECRAN
              If WOK=1
                  Raz GMESSAGE
                  GERR=1 : Break
              Endif
          Endif
          Raz GMESSAGE
      Endif
    Endif
  Endif

  # Issue 59217 - 2014-10-17 by MUARN : obligation tarif achat
  #----- Contrôle tarif à zéro pour commande de contremarque (sauf inter-sites) -----#
  If [M:POI1]SOHNUM(I)<>"" & ([M:POI1]BETFCY(I)<>2 | [M:POI1]BETCPY(I)=2)
    If [M:POI1]GROPRI(I)=0 & [M:POI1]PRIREN(I)=0 & [M:POI1]NETPRI(I)=0 & GPURCTLPRI0 <> 2
     #----- Erreur si pas de tarif -----#
      GMESSAGE =[M:POI1]SOHNUM(I)+"/"+num$([M:POI1]SOPLIN(I))
      GMESSAGE+="/"+num$([M:POI1]SOQSEQ(I))-mess(67,197,1)-mess(84,197,1)
      GERR=1
      Break
    Endif
  Endif
Next I
If GERR=1 : Return : Endif
#----- Contrôle sections obligatoires -----#
Raz GMESSAGE
# Issue 80181 - 2012-02-23 by SR :  déjà fait en amont avec toutes les infos nécessaires
# exemple : si le référentiel n'autorise pas la saisie, il est normal que l'axe ne soit pas renseigné
#For I=0 To [M:POI1]NBLIG-1
#  For J=1 To GNBDIE
#    If evalue("[M:POI1]CCE"+num$(J)+"(I)")="" & GOBLDIE(J)=2 & GENVDIE(J)<>2
#      If GMESSAGE=""
#        GMESSAGE=mess(46,106,1)-GDIE(J) : GERR=1
#      Else
#        GMESSAGE-=GDIE(J)
#      Endif
#    Endif
#  Next J
#  If GERR=1
#    GMESSAGE-=mess(18,197,1)-num$(I)
#    Break
#  Endif
#Next I
#If GERR=1  Return : Endif
#-----
Gosub RECALCUL_TARLIG From SUBPOIA
Return
#-------------------------#
# Exécution du traitement #
#-------------------------#
$EXEC_TRTGENPOH
Call GENERE_CDE(OPERATEUR,CHOIX,TARGRP)
Return
#-----------------------------------#
# Fin après exécution du traitement #
#-----------------------------------#
$TERM_TRTGENPOH
TRA=1 : # Lecture de la trace
Return
#----------------------#
# Sortie du traitement #
#----------------------#
$SORT_TRTGENPOH
GPLIFLG=0 : OK=0
Return


##########################################################################
# GENERE_CDE : S/P de génération de commandes                SR Avril 98 #
# ---------------------------------------------------------------------- #
# Subprog GENERE_CDE (OPERATEUR,CHOIX,TARGRP)                            #
#   OPERATEUR : Code de l'opérateur dont les commandes par article       #
#               sont à générer                                           #
#   CHOIX     : 1 = Touche NON par défaut,  2 = Touche OUI par défaut    #
#               3 = Touche OUI par défaut, pas de question               #
#               4 = Touche OUI par défaut, pas de question et pas de     #
#                   Trbegin ni Commit (On vient des retours et on est    #
#                   Déjà dans une transaction de màj)                    #
#   TARGRP    : Traitement des tarifs groupés en fonction de GPURGRUDIS  #
#               1 = à la demande devient NON                             #
#               2 = à la demande devient OUI                             #
##########################################################################
Subprog GENERE_CDE (OPERATEUR,CHOIX,TARGRP)
Value  Char     OPERATEUR
Value  Integer  CHOIX
Value  Integer  TARGRP
Local  Integer  I, J, OK, WPOPLIN, STAT, SIGN, WCNTBUD, WSEVLIN, WSOHCAT
Local  Shortint MAXLIGNE, SAVNOLIGN, SAVNBLIG, WLINNBR, WFMI, WFMI2
Local  Char     WBPSNUM(GLONBPS), WMSG(100), WCUR(GLONCUR), WLINBUY(GLONAUS)
Local  Char     WORDFCY(GLONFCY), WPRHFCY(GLONFCY), WSTOFCY(GLONFCY), WSALFCY(GLONFCY)
Local  Char     WBPCADD(18), WBPCADD2(18), SAVFONC(GLONAFC), WSOHNUM(GLONSOH)
Local  Decimal  WORDNOT, WORDATI, MNT1, MNT2, MNT3
Local  Char     SECTION(GLONCCE)
Local  Char     ID1(20)(1..1), ID2(20)(1..3)
Local  Char     TPLAN   (GLONCOA)(1..10)
Local  Char     TCOMPTE (GLONGAC)(1..10)
Local  Char     PARAM2(10), SAVGREP(1), SYMBOLE2(30)
Local  Libelle  WSRTFLG, WFMIFLG, WSOHFLG, WRCPFLG
Local  Char     WGRPDEB(GLONVCR)
Local  Char     WNAMCRITSPE(250), WVALCRITSPE(250)
Local  Integer  NOL1
#----- Variables locales pour le point d'entrée GENPURORD -----#
Local Char      FICHIER(GLONATB), ABRFIC(3), NUMSOH(GLONSOH)
Local Integer   LINSOH, SEQSOH, SAVXZSNOL, CTMFLAG
# Issue 71069 - 2013-08-23 by SR : PJT
Local Char      WPJT(GLONPJT)
#------------------------------------------------------------------------#
# Point d'entrée GENCDEDCL pour déclaration de variables supplémentaires #
# ---------------------------------------------------------------------- #
# Ces variables supplémentaires pourront être utilisées par les          #
#     points d'entrée GENCDESEL et GENPURORD                             #
#------------------------------------------------------------------------#
[V]GPOINT="GENCDEDCL" : Gosub ENTREE From EXEFNC
#-----
Raz GBUDCTLPOH, GBUDCTLPOL, GPURCMM, GCNTBUD, GPURCMMDAT, GFCY
OK = CHOIX
SIGN = 1
If OK<3
  Call OUINON(mess(86,194,1),OK) From GESECRAN
  If OK=1  End : Endif
Endif
#----- Ouverture de la trace si plan de l'acheteur (commandes par article) -----#
If OPERATEUR<>"" & !clalev([M:PMG])
  Call TEMPON ("E") From GESECRAN
  Call OUVRE_TRACE(mess(14,197,1)) From LECFIC
Endif
#----------------------------------------------------------------------------------#
# Récupération de la valeur du code activité POH (nbre maximum lignes de commande) #
#----------------------------------------------------------------------------------#
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
Read [ACV] CODACT="POH" : If fstat  Raz [F:ACV] : [F:ACV]DIME=100 : Endif
MAXLIGNE=[F:ACV]DIME
Close Local File [ACV]
#-----
If !clalev([M:ORDK])  Local Mask ORDK       [ORDK] : Endif
If !clalev([M:SBCK])  Local Mask SBCK       [SBCK] : Endif
#-----
Default Mask [POI1]
#-----
If !clalev([F:TCA])   Local File TABCOUAFF  [TCA]  : Endif
If !clalev([F:ADI])   Local File ATABDIV    [ADI]  : Endif
If !clalev([F:GAC])   Local File GACCOUNT   [GAC]  : Endif
If !clalev([F:CAL])   Local File CPTANALIN  [CAL]  : Endif
If !clalev([F:BPA])   Local File BPADDRESS  [BPA]  : Endif
If !clalev([F:BPR2])  Local File BPARTNER   [BPR2] : Endif
#-----
Local File PORDER [TB0], PORDERQ [TB1], CPTANALIN [TB2]
#----- Point d'entrée permettant de choisir l'impression des commandes -----#
# Alimentation des champs suivants :                                        #
#   - [M:POI1]PRTFLG : Indicateur d'impression (1=Non, 2=Oui)               #
#   - [M:POI1]DOCNAM : Code de l'état (ex "BONCDE")                         #
#   - [M:POI1]PRTCOD : Destination (nom de l'imprimante)                    #
#---------------------------------------------------------------------------#
[V]GPOINT="PRINTPOH" : Gosub ENTREE From EXEFNC
#----- Choix impression des commandes si rien n'a été spécifié -----#
If [M:POI1]PRTFLG=0 & !clalev([M:DIA])
  If !clalev([F:AIM])  Local File APRINTER [AIM] : Endif
  Local Mask POHPRT [DIA]
  Raz [M:DIA] : [M:DIA]PRTFLG=2
  Call DIALWIN(OK,mess(370,194,1),"IPOHPRT") From GESECRAN
  If OK=2
    [M:POI1]=[M:DIA]
  Endif
  Close Local Mask [DIA]
Endif
#----- Ouverture tables et déclaration des variables pour impression bon commande -----#
Gosub INIT_ETAT From TRTX3ETA
#----------------------------------------#
#  Création des commandes entête-détail  #
#  Màj des différents fichiers associés  #
#----------------------------------------#
Raz WPOPLIN, WORDNOT, WORDATI, WORDFCY, WCUR, WBPSNUM, WLINBUY, WBPCADD, WPRHFCY,
&   WSOHCAT, WSTOFCY, WSALFCY, WSOHNUM, WFMI
#----- Chargement de la globale "filtre par acheteur" -----#
Call PARAM([M:POI1]ORDFCY(0),"BUYFLT",PARAM2) From ADOVAL : GBUYFLT=val(PARAM2)
#--------------------------------------------------------------#
# Point d'entrée SRTPURORD pour effectuer un tri spécifique    #
# ------------------------------------------------------------ #
# Variable utilisable par le point d'entrée                    #
#                                                              #
# WSRTFLG : Indicateur de tri (0=Tri à faire,  1=Tri effectué) #
# WFMIFLG : Indicateur de rupture sur client pour contremarque #
#           directe           (0=Rupture,  1=Pas de rupture)   #
# WSOHFLG : Indicateur de rupture sur commande de vente        #
#                             (0=Rupture,  1=Pas de rupture)   #
# WRCPFLG : Indicateur rupture sur site de réception           #
#                             (0=Rupture,  1=Pas de rupture)   #
# WNAMCRITSPE : Nom du champ contenant la rupture ou formule   #
#               concaténation de plusieurs champs de rupture   #
#--------------------------------------------------------------#
[L]WSRTFLG=0 : [L]WFMIFLG=0 : [L]WSOHFLG=1 : [L]WRCPFLG=1 : [L]WNAMCRITSPE="''"
GPOINT="SRTPURORD" : Gosub ENTREE From EXEFNC
Onerrgo ERRCRITSPE
nolign=1 : [L]WVALCRITSPE=evalue([L]WNAMCRITSPE)
Onerrgo
#----- Critères supplémentaires de rupture activés ! -----#
If [L]WNAMCRITSPE<>"''"
  Call ECR_TRACE(mess(402,194,1),0) From GESECRAN
  Call ECR_TRACE("WNAMCRITSPE ="-[L]WNAMCRITSPE,0) From GESECRAN
Endif
#----- Tri standard désactivé ! -----#
If [L]WSRTFLG
  Call ECR_TRACE(mess(401,194,1),0) From GESECRAN
Endif
#-----
If ![L]WSRTFLG
   If GBUYFLT=2
     If !sigma(I=0,[M:POI1]NBLIG-1,[M:POI1]SALFCY(I)<>"")
       If !sigma(I=0,[M:POI1]NBLIG-1,[M:POI1]SOHNUM(I)<>"")
        #---------------------------------------------#
        # Si filtre par acheteur et cde normale       #
        # ------------------------------------------- #
        # Tri du tableau sur le site de commande      #
        #                    la devise                #
        #                    le fournisseur           #
        #                    le code acheteur         #
        #                    la référence article     #
        #                 et la date de besoin        #
        #---------------------------------------------#
        # Issue 71069 - 2016-06-13 by SR : US 65 : Trier selon sur le PJT
        # Issue 71276 - 2015-03-02 by SR : Versions
          If dim([M:POI1]ECCVALMAJ)>0
            Sorta [M:POI1]NBLIG [M:POI1]NBLIG Order By [M:POI1]ORDFCY(indice),
&                                                  [M:POI1]CUR(indice),
&                                                  [M:POI1]BPSNUM(indice),
&                                                  [M:POI1]LINBUY(indice),
&                                                  [M:POI1]PJT(indice),
&                                                  [M:POI1]ITMREFORI(indice),
&                                                  [M:POI1]VCRTYPORI(indice),
&                                                  [M:POI1]VCRNUMORI(indice),
&                                                  [M:POI1]LINTYP(indice),
&                                                  [M:POI1]ITMREF(indice),
&                                                  [M:POI1]ECCVALMAJ(indice),
&                                                  [M:POI1]ECCVALMIN(indice),
&                                                  [M:POI1]RETRCPDAT(indice),
&                                                  [M:POI1]POILIN(indice)
          Else
            Sorta [M:POI1]NBLIG [M:POI1]NBLIG Order By [M:POI1]ORDFCY(indice),
&                                                  [M:POI1]CUR(indice),
&                                                  [M:POI1]BPSNUM(indice),
&                                                  [M:POI1]LINBUY(indice),
&                                                  [M:POI1]PJT(indice),
&                                                  [M:POI1]ITMREFORI(indice),
&                                                  [M:POI1]VCRTYPORI(indice),
&                                                  [M:POI1]VCRNUMORI(indice),
&                                                  [M:POI1]LINTYP(indice),
&                                                  [M:POI1]ITMREF(indice),
&                                                  [M:POI1]RETRCPDAT(indice),
&                                                  [M:POI1]POILIN(indice)
          Endif
          # End issue 71276
       Else
        #---------------------------------------------#
        # Si filtre par acheteur et contremarque      #
        # ------------------------------------------- #
        # Tri du tableau sur le site de commande      #
        #                    la devise                #
        #                    le fournisseur           #
        #                    le code acheteur         #
        #                    le numéro commande vente #
        #                 et la ligne  commande vente #
        #---------------------------------------------#
           Sorta [M:POI1]NBLIG [M:POI1]NBLIG Order By [M:POI1]ORDFCY(indice),
&                                                  [M:POI1]CUR(indice),
&                                                  [M:POI1]BPSNUM(indice),
&                                                  [M:POI1]LINBUY(indice),
&                                                  [M:POI1]ITMREFORI(indice),
&                                                  [M:POI1]VCRTYPORI(indice),
&                                                  [M:POI1]VCRNUMORI(indice),
&                                                  [M:POI1]LINTYP(indice),
&                                                  [M:POI1]SOHNUM(indice),
&                                                  [M:POI1]SOPLIN(indice),
&                                                  [M:POI1]POILIN(indice),
&                                                  [M:POI1]PJT(indice)
      Endif
     Elsif !sigma(I=0,[M:POI1]NBLIG-1,[M:POI1]SOHNUM(I)<>"")
      #------------------------------------------------------------#
      # Si filtre par acheteur et cde inter-sites avec automatisme #
      # ---------------------------------------------------------- #
      # Tri du tableau sur le site de commande                     #
      #                    la devise                               #
      #                    le fournisseur                          #
      #                    le code acheteur                        #
      #                    la catégorie commande vente à créer     #
      #                    l'indicateur livraison partielle        #
      #                    le site de réception                    #
      #                 et le site d'expédition                    #
      #------------------------------------------------------------#
        Sorta [M:POI1]NBLIG [M:POI1]NBLIG Order By [M:POI1]ORDFCY(indice),
&                                                [M:POI1]CUR(indice),
&                                                [M:POI1]BPSNUM(indice),
&                                                [M:POI1]LINBUY(indice),
&                                                [M:POI1]ITMREFORI(indice),
&                                                [M:POI1]VCRTYPORI(indice),
&                                                [M:POI1]VCRNUMORI(indice),
&                                                [M:POI1]LINTYP(indice),
&                                                [M:POI1]SOHCAT(indice),
&                                                [M:POI1]PJT(indice),
&                                                [M:POI1]DME(indice),
&                                                [M:POI1]PRHFCY(indice),
&                                                [M:POI1]LINSTOFCY(indice),
&                                                [M:POI1]POILIN(indice)
     Else
      #---------------------------------------------------------------------#
      # Si filtre par acheteur et contremarque inter-sites avec automatisme #
      # ------------------------------------------------------------------- #
      # Tri du tableau sur le site de commande                              #
      #                    la devise                                        #
      #                    le fournisseur                                   #
      #                    le code acheteur                                 #
      #                    le numéro commande vente                         #
      #                    la ligne  commande vente                         #
      #                    la catégorie commande vente à  créer             #
      #                    l'indicateur livraison parielle                  #
      #                    le site de réception                             #
      #                 et le site d'expédition                             #
      #---------------------------------------------------------------------#
       Sorta [M:POI1]NBLIG [M:POI1]NBLIG Order By [M:POI1]ORDFCY(indice),
&                                                [M:POI1]CUR(indice),
&                                                [M:POI1]BPSNUM(indice),
&                                                [M:POI1]LINBUY(indice),
&                                                [M:POI1]ITMREFORI(indice),
&                                                [M:POI1]VCRTYPORI(indice),
&                                                [M:POI1]VCRNUMORI(indice),
&                                                [M:POI1]LINTYP(indice),
&                                                [M:POI1]SOHNUM(indice),
&                                                [M:POI1]SOPLIN(indice),
&                                                [M:POI1]SOHCAT(indice),
&                                                [M:POI1]PJT(indice),
&                                                [M:POI1]DME(indice),
&                                                [M:POI1]PRHFCY(indice),
&                                                [M:POI1]LINSTOFCY(indice),
&                                                [M:POI1]POILIN(indice)
      Endif
   Elsif !sigma(I=0,[M:POI1]NBLIG-1,[M:POI1]SALFCY(I)<>"")
        If !sigma(I=0,[M:POI1]NBLIG-1,[M:POI1]SOHNUM(I)<>"")
      #-----------------------------------------------#
      # Si pas de filtre par acheteur et cde normale  #
      # --------------------------------------------- #
      # Tri du tableau sur le site de commande        #
      #                    la devise                  #
      #                    le fournisseur             #
      #                    la référence article       #
      #                 et la date de besoin          #
      #-----------------------------------------------#
      # Issue 71276 - 2015-03-02 by SR : Versions
      If dim([M:POI1]ECCVALMAJ)>0
         Sorta [M:POI1]NBLIG [M:POI1]NBLIG Order By [M:POI1]ORDFCY(indice),
&                                                [M:POI1]CUR(indice),
&                                                [M:POI1]BPSNUM(indice),
&                                                [M:POI1]PJT(indice),
&                                                [M:POI1]ITMREFORI(indice),
&                                                [M:POI1]VCRTYPORI(indice),
&                                                [M:POI1]VCRNUMORI(indice),
&                                                [M:POI1]LINTYP(indice),
&                                                [M:POI1]ITMREF(indice),
&                                                [M:POI1]ECCVALMAJ(indice),
&                                                [M:POI1]ECCVALMIN(indice),
&                                                [M:POI1]RETRCPDAT(indice),
&                                                [M:POI1]POILIN(indice)
      Else
         Sorta [M:POI1]NBLIG [M:POI1]NBLIG Order By [M:POI1]ORDFCY(indice),
&                                                [M:POI1]CUR(indice),
&                                                [M:POI1]BPSNUM(indice),
&                                                [M:POI1]PJT(indice),
&                                                [M:POI1]ITMREFORI(indice),
&                                                [M:POI1]VCRTYPORI(indice),
&                                                [M:POI1]VCRNUMORI(indice),
&                                                [M:POI1]LINTYP(indice),
&                                                [M:POI1]ITMREF(indice),
&                                                [M:POI1]RETRCPDAT(indice),
&                                                [M:POI1]POILIN(indice)
      Endif
      # End issue 71276
     Else
      #-----------------------------------------------#
      # Si pas de filtre par acheteur et contremarque #
      # --------------------------------------------- #
      # Tri du tableau sur le site de commande        #
      #                    la devise                  #
      #                    le fournisseur             #
      #                    le numéro commande vente   #
      #                 et la ligne  commande vente   #
      #-----------------------------------------------#
       Sorta [M:POI1]NBLIG [M:POI1]NBLIG Order By [M:POI1]ORDFCY(indice),
&                                                [M:POI1]CUR(indice),
&                                                [M:POI1]BPSNUM(indice),
&                                                [M:POI1]ITMREFORI(indice),
&                                                [M:POI1]VCRTYPORI(indice),
&                                                [M:POI1]VCRNUMORI(indice),
&                                                [M:POI1]LINTYP(indice),
&                                                [M:POI1]SOHNUM(indice),
&                                                [M:POI1]SOPLIN(indice),
&                                                [M:POI1]POILIN(indice),
&                                                [M:POI1]PJT(indice)
     Endif
   Elsif !sigma(I=0,[M:POI1]NBLIG-1,[M:POI1]SOHNUM(I)<>"")
    #-------------------------------------------------------------------#
    # Si pas de filtre par acheteur et cde inter-sites avec automatisme #
    # ----------------------------------------------------------------- #
    # Tri du tableau sur le site de commande                            #
    #                    la devise                                      #
    #                    le fournisseur                                 #
    #                    la catégorie commande vente à créer            #
    #                    l'indicateur livraison partielle               #
    #                    le site de réception                           #
    #                 et le site d'expédition                           #
    #-------------------------------------------------------------------#
     Sorta [M:POI1]NBLIG [M:POI1]NBLIG Order By [M:POI1]ORDFCY(indice),
&                                              [M:POI1]CUR(indice),
&                                              [M:POI1]BPSNUM(indice),
&                                              [M:POI1]ITMREFORI(indice),
&                                              [M:POI1]VCRTYPORI(indice),
&                                              [M:POI1]VCRNUMORI(indice),
&                                              [M:POI1]LINTYP(indice),
&                                              [M:POI1]SOHCAT(indice),
&                                              [M:POI1]PJT(indice),
&                                              [M:POI1]DME(indice),
&                                              [M:POI1]PRHFCY(indice),
&                                              [M:POI1]LINSTOFCY(indice),
&                                              [M:POI1]POILIN(indice)
    Else
    #----------------------------------------------------------------------------#
    # Si pas de filtre par acheteur et contremarque inter-sites avec automatisme #
    # -------------------------------------------------------------------------- #
    # Tri du tableau sur le site de commande                                     #
    #                    la devise                                               #
    #                    le fournisseur                                          #
    #                    le numéro commande vente                                #
    #                    la ligne  commande vente                                #
    #                    la catégorie commande vente à créer                     #
    #                    l'indicateur livraison partielle                        #
    #                    le site de réception                                    #
    #                 et le site d'expédition                                    #
    #----------------------------------------------------------------------------#
      Sorta [M:POI1]NBLIG [M:POI1]NBLIG Order By [M:POI1]ORDFCY(indice),
&                                              [M:POI1]CUR(indice),
&                                              [M:POI1]BPSNUM(indice),
&                                              [M:POI1]ITMREFORI(indice),
&                                              [M:POI1]VCRTYPORI(indice),
&                                              [M:POI1]VCRNUMORI(indice),
&                                              [M:POI1]LINTYP(indice),
&                                              [M:POI1]SOHNUM(indice),
&                                              [M:POI1]SOPLIN(indice),
&                                              [M:POI1]SOHCAT(indice),
&                                              [M:POI1]PJT(indice),
&                                              [M:POI1]DME(indice),
&                                              [M:POI1]PRHFCY(indice),
&                                              [M:POI1]LINSTOFCY(indice),
&                                              [M:POI1]POILIN(indice)
   Endif
 Endif
# End issue 71069/65
#-------------------------------#
# Traitement des tarifs groupés #
#-------------------------------#
SAVNBLIG=[M:POI1]NBLIG
Raz [M:POI1]GRPFLG, GPLISTC
For I=0 To SAVNBLIG-1
  If [M:POI1]SOHNUM(I)<>""
    Read [SOQ] SOQ0=[M:POI1]SOHNUM(I);[M:POI1]SOPLIN(I);[M:POI1]SOQSEQ(I)
    If fstat Raz [F:SOQ] : Endif
    WFMI2=[F:SOQ]FMI : WBPCADD2=[F:SOQ]BPCORD+[F:SOQ]BPAADD
  Else
    WFMI2=0 : WBPCADD2=""
  Endif
  #-----
  If [M:POI1]SALFCY(I)<>""
    If [M:POI1]SALFCY(I)<>WSALFCY
      Call PARAM([M:POI1]SALFCY(I),"LINBPD",GBIDC3) From ADOVAL
      GLINBPD=val(GBIDC3)
    Endif
  Else
    GLINBPD=2
  Endif
  #-----
  NOL1=I : nolign=I+1 : # Pour critère rupture spécial
  If [M:POI1]ORDFCY(I)   <>WORDFCY                                                 |
&    [M:POI1]CUR   (I)   <>WCUR                                                    |
&    [M:POI1]BPSNUM(I)   <>WBPSNUM                                                 |
&   ([M:POI1]LINBUY(I)   <>WLINBUY  & GBUYFLT=2)                                   |
&   ([M:POI1]SOHNUM(I)   <>WSOHNUM  & WSOHFLG=0)                                   |
&    [M:POI1]SOHCAT(I)   <>WSOHCAT                                                 |
&  (([M:POI1]PRHFCY(I)   <>WPRHFCY) & ([M:POI1]DME(I)=3 | GLINBPD<>2 | WRCPFLG=0)) |
&   ([M:POI1]LINSTOFCY(I)<>WSTOFCY  &  [M:POI1]DME(I)=3)                           |
&    (WSEVLIN=1 & [M:POI1]LINTYP(I)<3) | WLINNBR-2>MAXLIGNE                        |
&   (WFMI2=2 & WBPCADD2<>WBPCADD & WFMIFLG=0)                                      |
&   (WFMI2<>WFMI & WFMIFLG=0) | evalue(WNAMCRITSPE)<>WVALCRITSPE
    If WORDFCY=""
      WORDFCY=[M:POI1]ORDFCY(I)
      WCUR   =[M:POI1]CUR   (I)
      WBPSNUM=[M:POI1]BPSNUM(I)
      WLINBUY=[M:POI1]LINBUY(I)
      WSOHNUM=[M:POI1]SOHNUM(I)
      WSOHCAT=[M:POI1]SOHCAT(I)
      WPRHFCY=[M:POI1]PRHFCY(I)
      WSTOFCY=[M:POI1]LINSTOFCY(I)
      WSALFCY=[M:POI1]SALFCY(I)
      WBPCADD=WBPCADD2
      WFMI   =WFMI2
      nolign=I+1 : WVALCRITSPE=evalue(WNAMCRITSPE)
    Else
      If GPURGRUDIS=2 | (GPURGRUDIS=3 & TARGRP=2)
        [M:POI1]NBLIG=I : nolign=I : Call TAR_GROUPE("POI") From TRTACHTAR1
      Endif
      For J=I-WLINNBR To I-1  [M:POI1]GRPFLG(J)=1 : Next J
      WORDFCY=[M:POI1]ORDFCY(I)
      WCUR   =[M:POI1]CUR   (I)
      WBPSNUM=[M:POI1]BPSNUM(I)
      WLINBUY=[M:POI1]LINBUY(I)
      WSOHNUM=[M:POI1]SOHNUM(I)
      WSOHCAT=[M:POI1]SOHCAT(I)
      WPRHFCY=[M:POI1]PRHFCY(I)
      WSTOFCY=[M:POI1]LINSTOFCY(I)
      WSALFCY=[M:POI1]SALFCY(I)
      WBPCADD=WBPCADD2
      WFMI   =WFMI2
      nolign=I+1 : WVALCRITSPE=evalue(WNAMCRITSPE)
      Raz WLINNBR
    Endif
  Endif
  WLINNBR+=1
  #----- Si changement de site de commande alors rechargement des paramètres -----#
  If GFCY<>[M:POI1]ORDFCY(I)
    GFCY=[M:POI1]ORDFCY(I)
    Call GETCPY(GFCY,"",0,"") From TRTX3CPT  : If GFINRSP="" GFINRSP=GFCY : Endif
    Call PARAM(GFCY,"BUYFLT",PARAM2)    From ADOVAL : GBUYFLT=val(PARAM2)
    Call PARAM(GFCY,"PURGRUDIS",PARAM2) From ADOVAL : GPURGRUDIS=val(PARAM2)
  Endif
  #----- Lecture BPSUPPLIER si nécessaire -----#
  If [F:BPS]BPSNUM<>[M:POI1]BPSNUM(I)
    Read [BPS] BPS0=[M:POI1]BPSNUM(I) : If fstat Raz [F:BPS] : Endif
  Endif
  #----- Chargement paramètres tarif -----#
  If GPLISTC<>[F:BPS]PLISTC
    GPLISTC=[F:BPS]PLISTC : Call TARIFCHGT(6) From TRTPRICE
  Endif
  WSEVLIN=[F:BPS]SEVLIN
  Call GET_TWMCOD([M:POI1]BPSNUM(I),[M:POI1]ITMREF(I),[M:POI1]MATTOL(I)) From TWMLIB  # Set Matching Tolerance Code
Next I
[M:POI1]NBLIG=SAVNBLIG
If GPURGRUDIS=2 | (GPURGRUDIS=3 & TARGRP=2)
  nolign=I : Call TAR_GROUPE("POI") From TRTACHTAR1
Endif
For J=I-WLINNBR To I-1  [M:POI1]GRPFLG(J)=1 : Next J
Raz WORDFCY, WCUR, WBPSNUM, WLINBUY, WSEVLIN, GFCY, WBPCADD, WSOHNUM, WFMI
Raz WSOHCAT, WPRHFCY, WSTOFCY, WSALFCY, WGRPDEB
#----- Génération des commandes -----#
Gosub GENERE_POH From TRTACHCDE2
#-----
If SYMBOLE2<>""  Unlock=SYMBOLE2 : Raz SYMBOLE2 : Endif
#----- Impression des bons de commande si nécessaire -----#
If [M:POI1]PRTFLG=2 & [M:POI1]PRTCOD<>""
  Call PRINT_ETAT(1,WARP_NUMREQ,[M:POI1]PRTCOD) From TRTX3ETA
Endif
#-----
Call ECR_TRACE(mess(14,197,1)-mess(124,100,1),0) From GESECRAN
If clalev([M:PMG]) End : Endif : # C'est terminé si l'on vient des plans de travail
#----- Opérateur renseigné = Plan de l'acheteur -----#
If OPERATEUR<>""
  Call DEBTRANS From GLOCK
  Trbegin [POI]
    Delete [POI] Where USR=[M:POI1]USR
    If fstat=1
      GOK=-1 : GLOCK="$PORDITM"-[M:POI1]USR
    Elsif fstat
      GOK=0  : Call RSTA("POI",[M:POI1]USR) From GLOCK
    Endif
  Commit
  Gosub EFFAC_PWRKORDERS From SUBPOIA
  Effzo [POI1] : Actzo [POI1]POHFCY, BUY
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  If GBOITE="" Call LEC_TRACE From LECFIC : Endif
#----- Opérateur non renseigné = Contremarque ou Retour -----#
Else
  GCNTBUD = WCNTBUD
Endif
$FIN_GENERE
If [M:POI1]PRONUM<>0 & CHOIX<>4
  Gosub EFFAC_BADLIN_PWRKORDERS From SUBPOIA
Endif
End

#----- Erreur, critères supplémentaires de rupture ignorés ! -----#
$ERRCRITSPE
Call ECR_TRACE(mess(403,194,1),1)                From GESECRAN
Call ECR_TRACE("WNAMCRITSPE ="-[L]WNAMCRITSPE,1) From GESECRAN
[L]WNAMCRITSPE="''"
Resume

########################################################################
# HISTO_CDE : S/P d'historisation des changements si      MBT 13/01/98 #
#             modification avec avenant                                #
#----------------------------------------------------------------------#
# Subprog HISTO_CDE (ABREV1,ABREV2,TRAIT)                              #
#   ABREV1 : Abréviation du fichier à historiser                       #
#            "POH" = Entête commande                                   #
#            "POP", "POQ" ET "POC" = Ligne commande                    #
#   ABREV2 : Abréviation éventuelle du 2ème fichier ligne à historiser #
#            "POH" = entête commande                                   #
#            "POP", "POQ" ET "POC" = Ligne commande                    #
#   TRAIT  : Code traitement  ("M" = Modification,  "A" = Suppression) #
########################################################################
Subprog HISTO_CDE (ABREV1,ABREV2,TRAIT)
Value  Char     ABREV1
Value  Char     ABREV2
Value  Char     TRAIT
Case ABREV1
  When "POH"  : Gosub HISTO_POH
  When "POP"  : Gosub HISTO_POP
  When "POQ"  : Gosub HISTO_POQ
  When "POC"  : Gosub HISTO_POC
  When Default
Endcase
If GOK<1         End : Endif
If ABREV1=ABREV2 End : Endif
Case ABREV2
  When "POH"  : Gosub HISTO_POH
  When "POP"  : Gosub HISTO_POP
  When "POQ"  : Gosub HISTO_POQ
  When "POC"  : Gosub HISTO_POC
  When Default
Endcase
End
#----- Historisation entête commande PORDER --> UPORDER -----#
$HISTO_POH
If clalev([F:UOH])=0 Local File UPORDER  [UOH] : Endif
[F:UOH]=[F:POH] : [F:UOH]REVCOD=TRAIT
[F:UOH]CREDAT=date$ : [F:UOH]CREUSR=GUSER : [F:UOH]EXPNUM=[C]EXPORT
Write [UOH] : If fstat GOK=0 : Call FSTA("UOH") From GLOCK : Endif
Return
#----- Historisation ligne commande PORDERP --> UPORDERP -----#
$HISTO_POP
If clalev([F:UOP])=0 Local File UPORDERP [UOP] : Endif
Look [UOP] POP0=[F:POP]POHNUM;[F:POP]LINREVNUM;[F:POP]POPLIN;[F:POP]POPSEQ
If fstat
  [F:UOP]=[F:POP] : [F:UOP]REVCOD=TRAIT
  [F:UOP]CREDAT=date$ : [F:UOP]CREUSR=GUSER : [F:UOP]EXPNUM=[C]EXPORT
  Write [UOP] : If fstat GOK=0 : Call FSTA("UOP") From GLOCK : Endif
  If TRAIT<>"A"
    Read [CAL] CAL0="POP";0;[F:POP]POHNUM;[F:POP]POPLIN;[F:POP]POPSEQ;"";1
    If !fstat
      [F:CAL]ABRFIC="UOP"
      [F:CAL]CPLCLE=num$([F:UOP]LINREVNUM)
      Write [CAL] : If fstat GOK=0 : Call FSTA("CAL") From GLOCK : Endif
    Endif
  Endif
Endif
Return
#----- Historisation ligne commande PORDERQ --> UPORDERQ -----#
$HISTO_POQ
If clalev([F:UOQ])=0 Local File UPORDERQ [UOQ] : Endif
Look [UOQ] POQ0=[F:POQ]POHNUM;[F:POQ]LINREVNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ
If fstat
  [F:UOQ]=[F:POQ] : [F:UOQ]REVCOD=TRAIT
  [F:UOQ]CREDAT=date$ : [F:UOQ]CREUSR=GUSER : [F:UOQ]EXPNUM=[C]EXPORT
  Write [UOQ] : If fstat GOK=0 : Call FSTA("UOQ") From GLOCK : Endif
Endif
Return
#----- Historisation ligne commande PORDERC --> UPORDERC -----#
$HISTO_POC
If clalev([F:UOC])=0 Local File UPORDERC [UOC] : Endif
[F:UOC]=[F:POC] : [F:UOC]REVCOD=TRAIT
[F:UOC]CREDAT=date$ : [F:UOC]CREUSR=GUSER : [F:UOC]EXPNUM=[C]EXPORT
Write [UOC] : If fstat GOK=0 : Call FSTA("UOC") From GLOCK : Endif
Return


#########################################################################
# ECLATE_LIG : S/P d'éclatement d'une ligne de commande    MBT 22/01/98 #
#   ABMSK    : Abréviation du masque écran contenant les lignes         #
#   NOL      : Indice de la ligne à éclater (nolign-1 ou nolign-2)      #
#   ACHETEUR : Code acheteur                                            #
# --------------------------------------------------------------------- #
# Remplacé par l'action SAISPLQTY avec paramètre           MBT 04/12/00 #
#    PARAM(1) = ABREV  : Abréviation du masque contenant les lignes     #
#    PARAM(2) = NOLIG  : Indice de la ligne à éclater (nolign-1)        #
#    PARAM(3) =        : Code acheteur                                  #
#########################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_SAISPLQTY
#----- Variables locales -----#
Local Char     WABMSK(4)         : WABMSK=PARAM(1)
Local Shortint NOL               : NOL=val(PARAM(2))
Local Char     ACHETEUR(GLONAUS) : ACHETEUR=PARAM(3)
Local Shortint SAVNOLIGN         : SAVNOLIGN=nolign
Local Integer  OK : OK=1
Local Shortint NBDEC, I, J, K
Local Char     WUOM(GLONUOM)
Local Decimal  RETQTY
Local Libelle  WFLAG
Local    Decimal WQTEUS
#-----
If evalue("[M:"+WABMSK+"]ITMREF(NOL)=''") & NOL>0
  NOL-=1
Endif
#----- Si la référence aticle n'est pas renseignée, c'est fini ! -----#
If evalue("[M:"+WABMSK+"]ITMREF(NOL)=''")
  FIN=1 : Return
Endif
#----- Si ligne soldée, éclatement interdit -----#
If evalue("[M:"+WABMSK+"]LINCLEFLG(NOL)=2")
  GMESSAGE=mess(368,194,1) : GERR=1 : FIN=1 : Return
Endif
#----- Si des réceptions ou factures ont été effectuées, c'est fini ! -----#
If evalue("[M:"+WABMSK+"]LINRCPNBR(NOL)<>0") |
&  evalue("[M:"+WABMSK+"]RCPQTYSTU(NOL)<>0") |
&  evalue("[M:"+WABMSK+"]LININVNBR(NOL)<>0")
  GMESSAGE=mess(367,194,1) : GERR=1 : FIN=1 : Return
Endif
#----- Si des DA ont été prises en compte, éclatement interdit ! -----#
If evalue("[M:"+WABMSK+"]CREFLG(NOL)<>0")
  If !clalev([F:PSO])  Local File PREQUISO  [PSO] : Endif
  Filter [PSO] Where POHNUM=evalue("[M:"+left$(WABMSK,3)+"0]POHNUM")
&                  & POPLIN=evalue("[M:"+WABMSK+"]POPLIN(NOL)")
&                  & POQSEQ=1
  Read [PSO] PSO1 First
  Filter [PSO]
  If !fstat
    GMESSAGE=mess(346,194,1) : GERR=1 : FIN=1 : Return
  Endif
Endif
#----- Si ligne de contremarque ou lien avec ligne de vente, c'est fini ! -----#
If evalue("[M:"+WABMSK+"]SOHNUM(NOL)<>''")
  GMESSAGE=mess(116,194,1) : GERR=1 : FIN=1 : Return
Endif
#----- Il faut au minimum 10 lignes, autrement insertion (éclatement) impossible ! -----#
If evalue("dim([M:"+WABMSK+"]ITMREF)<[M:"+WABMSK+"]NBLIG+11")
  GMESSAGE=mess(122,199,1) : GERR=1 : FIN=1 : Return
Endif
#----- Une quantité sans décimale doit être supérieure à 1 -----#
If evalue("[M:"+WABMSK+"]QTYUOM(NOL)=1")
  WUOM=evalue("[M:"+WABMSK+"]UOM(NOL)")
  Call QTENBDEC(WUOM,NBDEC) From TRTDIV
  If NBDEC=0 GMESSAGE=mess(139,194,1) : GERR=1 : FIN=1 : Return : Endif
Endif
# Issue 77496 - 2011-11-04 by VPO : Commandes achat/vente inter-sociétés désynchronisées
If WABMSK="POH2"
  If [M:POH0]SALFCY<>""
    #-- Bug 73875 : Ctrl avec la qté en US et non avec la qté en UC
    #-- X3Suivi 77496 : Commandes achat/vente inter-sociétés désynchronisées --#
    Call C_QTY(2,[M:POH0]BPCORD, [M:POH2]ITMREF(NOL),[M:POH2]UOM(NOL),
&       [M:POH2]LINOCNNUM(NOL),[M:POH2]OCNLIN(NOL), [M:POH2]OCNLIN(NOL), WQTEUS) From TRTVENISOC
    If WQTEUS>0
      GMESSAGE=mess(74,187,1)-"\"-mess(311,192,1)
      GERR=1 : FIN=1 : Return
    Endif
  Endif
Endif

#----- On force le contrôle "AVANT_MOD" -----#
If GREVFLG=0
  Gosub AVANT_MOD From SUBPOHA : If OK=0 FIN=1 : Endif
Endif
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_SAISPLQTY
Raz [M:PSQ1]
#----- Chargement des zones dans le masque -----#
[M:PSQ1]ITMREF   =evalue("[M:"+WABMSK+"]ITMREF(NOL)")
[M:PSQ1]ITMDES   =evalue("[M:"+WABMSK+"]ITMDES(NOL)")
[M:PSQ1]RCPFCY   =evalue("[M:"+WABMSK+"]PRHFCY(NOL)")
[M:PSQ1]RCPADD   =evalue("[M:"+WABMSK+"]FCYADD(NOL)")
[M:PSQ1]RETRCPDAT=evalue("[M:"+WABMSK+"]RETRCPDAT(NOL)")
[M:PSQ1]RETQTYSTU=evalue("[M:"+WABMSK+"]RETQTYSTU(NOL)")
[M:PSQ1]RCPDAT   =evalue("[M:"+WABMSK+"]EXTRCPDAT(NOL)")
[M:PSQ1]STOMGTCOD=evalue("[M:"+WABMSK+"]STOMGTCOD(NOL)")
[M:PSQ1]BUY      =ACHETEUR
If clalev ([F:PTR])>0
   If [F:PTR]QTYSTUCOD=1                      [M:PSQ1]QTYFLG=3 : Endif
   If [F:PTR]QTYPUUCOD=1 | [F:PTR]QTYPUUCOD=2 [M:PSQ1]QTYFLG=2 : Endif
   If [F:PTR]QTYUOMCOD=1 | [F:PTR]QTYUOMCOD=2 [M:PSQ1]QTYFLG=1 : Endif
Endif
If [M:PSQ1]QTYFLG=0 [M:PSQ1]QTYFLG=2 : Endif
Case [M:PSQ1]QTYFLG
  When 1  : [M:PSQ1]TOTQTY=evalue("[M:"+WABMSK+"]QTYUOM(NOL)")
            [M:PSQ1]REMQTY=evalue("[M:"+WABMSK+"]QTYUOM(NOL)")
            [M:PSQ1]UOM   =evalue("[M:"+WABMSK+"]UOM(NOL)")
  When 2  : [M:PSQ1]TOTQTY=evalue("[M:"+WABMSK+"]QTYPUU(NOL)")
            [M:PSQ1]REMQTY=evalue("[M:"+WABMSK+"]QTYPUU(NOL)")
            [M:PSQ1]UOM   =evalue("[M:"+WABMSK+"]PUU(NOL)")
  When 1  : [M:PSQ1]TOTQTY=evalue("[M:"+WABMSK+"]QTYSTU(NOL)")
            [M:PSQ1]REMQTY=evalue("[M:"+WABMSK+"]QTYSTU(NOL)")
            [M:PSQ1]UOM   =evalue("[M:"+WABMSK+"]STU(NOL)")
Endcase
[M:PSQ1]NBLIG=0
#----- Affichage foreground -----#
Affzo [PSQ1]1-99
Return
#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK_SAISPLQTY
If [M:PSQ1]REMQTY<>0 GMESSAGE=mess(69,194,1) : GERR=1 : FIN=0 : Return : Endif
If [M:PSQ1]NBLIG>1
  Case WABMSK
    When "POH2"  : Gosub ECLATE_LIG_POH2 From SUBPOHB
  Endcase
Endif
FIN=1 : WFLAG=1
Return
#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
ABA_SAISPLQTY
Raz REP, WFLAG
Gosub DEB_SAISPLQTY
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_SAISPLQTY
If WFLAG  mkstat=4 : GREVFLG+=5 : Endif
nolign=SAVNOLIGN
Return


############################################################################
# Gosub MAJ_ADRESSE : Transaction de modification de l'adresse fournisseur #
#                     sur l'entête d'une commande d'achat (PORDER) après   #
#                     l'appui sur le bouton "Adresse"         MBT 06/01/98 #
# ------------------------------------------------------------------------ #
# L'action SAIADRBPR précède le Gosub MAJ_ADRESSE             MBT 29/11/00 #
# Attention la classe [F:POH] doit contenir la commande en cours et        #
#           la variable WTYPADR contient le type d'adresse                 #
#              1 = Adresse fournisseur commande                            #
#              2 = Adresse fournisseur expéditeur                          #
#           la variable WABREV contient l'abréviation écran                #
#         - Pour commande classique :                                      #
#              AD61 = Ecran [M:AD61] adresse fournisseur commande          #
#              AD62 = Ecran [M:AD62] adresse fournisseur expéditeur        #
#         - Pour contrat ou commande ouverte :                             #
#              AD63 = Ecran [M:AD63] adresse fournisseur commande          #
#              AD64 = Ecran [M:AD64] adresse fournisseur expéditeur        #
############################################################################
$MAJ_ADRESSE
Local Char    SAV_DEFMSK(255) : SAV_DEFMSK=dbgstr(1)
Local Libelle WADBFLG
#-----
Default Mask "["+WABREV+"]"
#-----
[L]WADBFLG=[M]ADBFLG
If [M]ADBFLG=0 & GACTSAD<>2  [M]BPAADD=[F:POH]BPAADD : Goto FIN_ADR : Endif
#----- Mide à jour de l'entête de commande -----#
Local Char     WCLE(GLONPOH) : [L]WCLE=[F:POH]POHNUM
Call DEBTRANS From GLOCK
$TR_ADR
GOK=1
Trbegin [POH]
  Readlock [POH] POH0=[L]WCLE
  If fstat=1
    GOK=-1 : GLOCK="$PORDER"-[L]WCLE             : Goto ROLL_ADR
  Elsif fstat
    GOK=0  : Call RSTA("POH",[L]WCLE) From GLOCK : Goto AB_ADR
  Endif
  If [L]WADBFLG<>2
    If [L]WADBFLG=1
      Case [L]WTYPADR
        When 1       : [F:POH]BPAADD=[M]BPAADD
        When 2       : [F:POH]BPOADD=[M]BPAADD
        When Default : [F:POH]BPAADD=[M]BPAADD
      Endcase
    Endif
    If GACTSAD=2 : # Stockage systématique de l'adresse !
      #----- Lecture BPARTNER si nécessaire -----#
      If [F:BPR]BPRNUM<>[F:POH]BPSNUM
        Read [BPR] BPR0=[F:POH]BPSNUM
        If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
      Endif
      #----- Lecture de l'adresse si nécessaire -----#
      Case [L]WTYPADR
        When 2
          If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:POH]BPSNUM | [F:BPA]BPAADD<>[F:POH]BPOADD
            Read [BPA] BPA0=1;[F:POH]BPSNUM;[F:POH]BPOADD
            If fstat  Raz [F:BPA] : Endif
          Endif
          #-----
          [F:POH]BPONAM(0)    = [F:BPR]BPRNAM(0)
          [F:POH]BPONAM(1)    = [F:BPR]BPRNAM(1)
          [F:POH]BPOADDLIG(0) = [F:BPA]BPAADDLIG(0)
          [F:POH]BPOADDLIG(1) = [F:BPA]BPAADDLIG(1)
          [F:POH]BPOADDLIG(2) = [F:BPA]BPAADDLIG(2)
          [F:POH]BPOCRY       = [F:BPA]CRY
          [F:POH]BPOCRYNAM    = [F:BPA]CRYNAM
          [F:POH]BPOSAT       = [F:BPA]SAT
          [F:POH]BPOPOSCOD    = [F:BPA]POSCOD
          [F:POH]BPOCTY       = [F:BPA]CTY
        When Default
          If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:POH]BPSNUM | [F:BPA]BPAADD<>[F:POH]BPAADD
            Read [BPA] BPA0=1;[F:POH]BPSNUM;[F:POH]BPAADD
            If fstat  Raz [F:BPA] : Endif
          Endif
          #-----
          [F:POH]BPRNAM(0)    = [F:BPR]BPRNAM(0)
          [F:POH]BPRNAM(1)    = [F:BPR]BPRNAM(1)
          [F:POH]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
          [F:POH]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
          [F:POH]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
          [F:POH]CRY          = [F:BPA]CRY
          [F:POH]CRYNAM       = [F:BPA]CRYNAM
          [F:POH]SAT          = [F:BPA]SAT
          [F:POH]POSCOD       = [F:BPA]POSCOD
          [F:POH]CTY          = [F:BPA]CTY
      Endcase
    Else
      Case [L]WTYPADR
        When 2
          Raz [F:POH]BPONAM,[F:POH]BPOADDLIG,[F:POH]BPOCRY,[F:POH]BPOCRYNAM,
&             [F:POH]BPOSAT,[F:POH]BPOPOSCOD,[F:POH]BPOCTY
        When Default
          Raz [F:POH]BPRNAM,[F:POH]BPAADDLIG,[F:POH]CRY,[F:POH]CRYNAM,
&             [F:POH]SAT,[F:POH]POSCOD,[F:POH]CTY
      Endcase
    Endif
  Else
    Case [L]WTYPADR
      When 1
        [F:POH]=[M]
      When 2
        [F:POH]BPOADD       = [M]BPAADD
        [F:POH]BPONAM(0)    = [M]BPRNAM(0)
        [F:POH]BPONAM(1)    = [M]BPRNAM(1)
        [F:POH]BPOADDLIG(0) = [M]BPAADDLIG(0)
        [F:POH]BPOADDLIG(1) = [M]BPAADDLIG(1)
        [F:POH]BPOADDLIG(2) = [M]BPAADDLIG(2)
        [F:POH]BPOCRY       = [M]CRY
        [F:POH]BPOCRYNAM    = [M]CRYNAM
        [F:POH]BPOSAT       = [M]SAT
        [F:POH]BPOPOSCOD    = [M]POSCOD
        [F:POH]BPOCTY       = [M]CTY
      When Default
        [F:POH]=[M]
    Endcase
  Endif
  Rewrite [POH]
  If fstat GOK=0 : Call FSTA("POH") From GLOCK : Goto AB_ADR : Endif
Commit
$FIN_ADR
Default Mask SAV_DEFMSK
Gosub DEVERROU From GOBJET : Gosub RELIT From GOBJET
Return
$ROLL_ADR
Rollback : Call ROLL From GLOCK
If GROLL   Goto FIN_ADR  Else  Goto TR_ADR : Endif
$AB_ADR
Rollback
Goto FIN_ADR


############################################################################
# Gosub MAJ_SOLDE: Transaction de solde complet d'une commande d'achats    #
#                  Après l'appui sur le bouton "Solde"        MBT 07/01/98 #
# ------------------------------------------------------------------------ #
# Remplacé par l'action TRTCLEPOH qui fait un Call MAJ_SOLDE  MBT 29/11/00 #
# Attention la classe [F:POH] doit contenir la commande à solder           #
############################################################################
Subprog MAJ_SOLDE
Local Char    WPOHNUM(GLONPOH) : [L]WPOHNUM=[F:POH]POHNUM
Local Integer WMSGFLG          : [L]WMSGFLG=1
Local Integer WRET
If [F:POH]BETFCY=2 & [F:POH]SALFCY<>""
  Gosub OUVERTURE_TRACE From SUBPOHA : [L]WMSGFLG=3
Endif
Call TRTPOHCLE([L]WPOHNUM,[L]WMSGFLG,[L]WRET) From TRTACHDIV1
End


#############################################################
# RECHERCHE_DA_TEX : Recherche du texte de la DA            #
#   WPRONUM = Numéro de process (adxuid(1))                 #
#   WCODFNC = Code fonction ("POI", "POH", "POD")           #
#   WLINNUM = Ligne de la commande ou du plan de l'acheteur #
#   WTEX    = Numéro de texte récupéré de la DA ou rien     #
#############################################################
Subprog RECHERCHE_DA_TEX(WPRONUM,WCODFNC,WLINNUM,WTEX)
Value    Integer WPRONUM
Value    Char    WCODFNC
Value    Integer WLINNUM
Variable Char    WTEX
#-----
Local    Libelle WCTEUR
Raz WTEX, WCTEUR
If !clalev([F:PWO]) Local File PWRKORDERS [PWO] : Endif
For [PWO] PWO0 Where PRONUM=WPRONUM & CODFNC=WCODFNC & LINNUM=WLINNUM
  If WCTEUR>1  Break : Endif
  WCTEUR+=1
Next
If WCTEUR=1
  If [F:PWO]WIPTYP=2 & [F:PWO]WIPSTA=2
    If !clalev([F:PSD])  Local File PREQUISD [PSD] : Endif
    Raz [F:PSD]
    If [F:PWO]PSDLIN=0
      Read [ORD] ORD0=[F:PWO]WIPTYP;[F:PWO]WIPNUM;[F:PWO]ITMREF
      If !fstat
        Read [PSD] PSD0=[F:ORD]VCRNUM;[F:ORD]VCRLIN
        If fstat  Raz [F:PSD] : Endif
      Endif
    Else
      Read [PSD] PSD0=[F:PWO]WIPNUM;[F:PWO]PSDLIN
      If fstat  Raz [F:PSD] : Endif
    Endif
    WTEX=[F:PSD]LINTEX
  Endif
Endif
End


#####################################################
# COMPTE : S/P Recherche des comptes                #
# ------------------------------------------------- #
# REFGAD  : Pièce automatique ("PORD")              #
# LIG     : Ligne de la pièce automatique           #
# IDENT1  : Clé de la table [F:TB0] (PORDER  [POH]) #
# IDENT2  : Cle de ta table [F:TB1] (PORDERQ [POQ]) #
# TPLAN   : Table des plans comptables              #
# TCOMPTE : Table des comptes                       #
# STA     : Code retour                             #
# WMESSAGE: Message retour                          #
#####################################################
Subprog COMPTE(REFGAD,LIG,IDENT1,IDENT2,TPLAN,TCOMPTE,STA,WMESSAGE)
Value    Char    REFGAD
Value    Integer LIG
Value    Char    IDENT1()(1..)
Value    Char    IDENT2()(1..)
Variable Char    TPLAN()(1..)
Variable Char    TCOMPTE()(1..)
Variable Integer STA
Variable Char    WMESSAGE
#-----
Onerrgo SANSRIEN
If !clalev([F:GAD])  Local File GAUTACED [GAD] : Endif
For [GAD] GAD0 Where COD=REFGAD
  If [F:GAD]FORCND<>""
    STA=evalue([F:GAD]FORCND)
    If STA
      LIG=[F:GAD]LINNUM : Break
    Endif
  Else
    LIG=[F:GAD]LINNUM : Break
  Endif
Next
If LIG=0  LIG=1 : Endif
Onerrgo
Call COMPTE(REFGAD,LIG,IDENT1,IDENT2,TPLAN,TCOMPTE,STA,WMESSAGE) From CPTCOD
If STA  Raz GMESSAGE : Endif
If [F:GAD]COD<>REFGAD | [F:GAD]LINNUM<>LIG
  Read [GAD] GAD0=REFGAD;LIG : If fstat  Raz [F:GAD] : Endif
Endif
End
$SANSRIEN
STA=0
Resume



##########################################################################
# TRT_PRPLTI : S/P de calcul d'une date avec jours ouverts de la semaine #
#            et décalage de cette date.                                  #
# on doit avoir [F:FCY] et [F:ITF]                                       #
# ---------------------------------------------------------------------- #
# Subprog TRT_PRPLTI(DATRCP,DELAI)                                       #
#   DATRCP  : Date de réception prévue à calculer                        #
#   DELAI   : Délai pour calcul de la date                           #
# -----------------------------------------------------------------------#
# En sortie du sous-programme :                                          #
#   DATRCP   : Date -délai réajustée à un jour de la semaine ouvert      #
##########################################################################
Subprog TRT_PRPLTI(DATRCP,DELAI)
Variable Date    DATRCP
Value    Decimal DELAI

Local Integer I

For I=1 To DELAI
    DATRCP-=1
    Call CTL_JOU(DATRCP,[F:FCY]UVYDAY,[F:FCY]UVYCOD,1) From CONTX3
Next I
End

##########################################################################
# CTL_JOU2 : S/P de contrôle d'une date avec jours ouverts de la semaine #
#            et décalage avant ou arrière de cette date.                 #
#            Le décalage arrière se fait jusqu'à une date mini et si     #
#            celle-ci est dépassée, le décalage repart en avant jusqu'au #
#            1er jour de la semaine ouvert.                              #
#            Le point dentrée EXTRCPDAT permet de modifier la date mini  #
# ---------------------------------------------------------------------- #
# Subprog CTL_JOU2(DATRCP,DATCDE,DELAI)                                  #
#   DATRCP  : Date de réception prévue à controler                       #
#   DATCDE  : Date de commande pour calcul de la date mini               #
#   DELAI   : Délai pour calcul de la date mini                          #
# -----------------------------------------------------------------------#
# En sortie du sous-programme :                                          #
#   DATRCP   : Date réajustée à un jour de la semaine ouvert             #
##########################################################################
Subprog CTL_JOU2(DATRCP,DATCDE,DELAI)
Variable Date    DATRCP
Value    Date    DATCDE
Value    Decimal DELAI
#---------------------------------------------------------------#
# Point d'entrée EXTRCPDAT pour modification de la date minimum #
#              servant au calcul de la date prévue de réception #
# ------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                   #
#    DATRCP : Date de réception prévue avant ajustement         #
#    DATCDE : Date de commande                                  #
#    DELAI  : Délai article ou article-site ou tarif            #
#                                                               #
# Variable modifiable par le point d'entrée :                   #
#    DATMIN : Date minimum de réception                         #
#                                                               #
# Nota : DATMIN est initialisée suivant paramètre GEXTRCPDAT :  #
#        1 = à date de commande                                 #
#        2 = à date de commande + délai article                 #
#---------------------------------------------------------------#
Local    Date    DATMIN : DATMIN=DATCDE+DELAI
If GEXTRCPDAT=1  DATMIN=DATCDE : Endif
GPOINT="EXTRCPDAT" : Gosub ENTREE From EXEFNC
#-----
Call CTL_JOU2(DATRCP,DATMIN,[F:FCY]UVYDAY,[F:FCY]UVYCOD,1) From CONTX3
End


#######################################################
# Appel du point d'entrée ECLBESOINS depuis :         #
#     - le traitement SUBPOHB (commandes classiques)  #
