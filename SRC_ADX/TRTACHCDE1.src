#     - le traitement TRTACHDIV1                                                           #
#         WTYPMAJ = 5 Engagement ligne DL ferme         avant SUBPOD (Gestion des DL)      #
#         WTYPMAJ = 6 Engagement ligne commande         avant TRTACHCDE1 (Gestion des cdes)#
#         WTYPMAJ = 7 Désengagement après facturation   avant TRTACHFAC1 (Validation fact) #
#         WTYPMAJ = 8 Pré-engagement ligne DA           avant SUBPSH1 (Gestion des DA)     #
#         WTYPMAJ = 9 Pré-engagement DA consommée       avant SUBPOHB (Consommation DA)    #
#     - le traitement FUNUTICMM (Resynchro)                                                #
#        WTYPMAJ = 10 Resynchronisation pré-engagement                                     #
