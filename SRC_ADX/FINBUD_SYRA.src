#<AdxTL>@(#)4.0.0.0 $Revision$
##############################################################################################################
# ROUTINES ABOUT BUDGET
##############################################################################################################
# UPD_BUD    : Updates BLACMM BLAQTY BUD tables
# CTL_BUDOVR : Controls if the budget is overrun
#
# Private routines :
# _UPD_BUD : Update BLACMM BLAQTY BUD tables
# _CTL_BUDOVR : Control if the budget is overrun
# GET_BUP : Returns the budget and the version of the final budgets parameterized in BUP* variables
# _IS_BUDOVR : Returns the type of the overrun
##############################################################################################################

#####################################################################################################################
## UPD_BUD
#####################################################################################################################
#**
#* Update the commitment and precommitment amounts in the budget table BUD<br>
#* Update the analytical commitment balance BLACMM<br>
#* Update the analytical balance in quantity BLAQTY<br>
#*
#* @param ACTX   Context
#* @param DAT    Date
#* @param SITE   Site
#* @param LEDTYP Ledger type
#* @param CUR    Currency of the amount of commitment
#* @param AMTCUR Amount in currency
#* @param AMTLED Amount in currency ledger
#* @param QTY    Quantity
#* @param ACC    Account
#* @param BPR    Business Partner
#* @param DIE    Array of the dimension types
#* @param CCE    Array of the dimensions matching the order of the dimensions types
#* @param SENS   1=Expense -1=Revenue
#* @param SIGN   1=Engage the amount of the commitment -1=Desengage amount of the commitment
#* @param CMMTYP 1=Precommitment 2=Commitment (ML 631)
#* @param CTLBUD 0=Do not activate the budget control when the balance is updated
#* @param ERRMES Error message
#*!
Funprog UPD_BUD(ACTX,DAT,SITE,LEDTYP,CUR,AMTCUR,AMTLED,QTY,ACC,BPR,DIE,CCE,SENS,SIGN,CMMTYP,CTLBUD,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Date    DAT         : # Date
Value    Char    SITE        : # Site
Value    Tinyint LEDTYP      : # Ledger type
Value    Char    CUR         : # Currency of the amount of commitment
Value    Decimal AMTCUR      : # Amount in currency
Value    Decimal AMTLED      : # Amount in currency ledger
Value    Decimal QTY         : # Quantity
Value    Char    ACC         : # Account
Value    Char    BPR         : # Business Partner
Value    Char    DIE()(1..)  : # Array of the dimension types
Value    Char    CCE()(1..)  : # Array of the dimensions matching the order of the dimensions types
Value    Integer SENS        : # 1=Expense -1=Revenue
Value    Integer SIGN        : # 1=Engage the amount of the commitment -1=Desengage amount of the commitment
Value    Tinyint CMMTYP      : # 1=Precommitment 2=Commitment <ML 631>
Value    Integer CTLBUD      : # 0=Do not activate the budget control when the balance is updated
Variable Char    ERRMES()    : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

[L]ASTATUS = func _UPD_BUD(ACTX,DAT,SITE,LEDTYP,CUR,AMTCUR,AMTLED,QTY,ACC,BPR,DIE,CCE,SENS,SIGN,CMMTYP,CTLBUD,ERRMES)

End [L]ASTATUS

#####################################################################################################################
## _UPD_BUD
#####################################################################################################################
#**
#* Update the commitment and precommitment amounts in the budget table BUD<br>
#* Update the analytical commitment balance BLACMM<br>
#* Update the analytical balance in quantity BLAQTY<br>
#*
#* @private
#*
#* @param ACTX   Context
#* @param DAT    Date
#* @param SITE   Site
#* @param LEDTYP Ledger type
#* @param CUR    Currency of the amount of commitment
#* @param AMTCUR Amount in currency
#* @param AMTLED Amount in currency ledger
#* @param QTY    Quantity
#* @param ACC    Account
#* @param BPR    Business Partner
#* @param DIE    Array of the dimension types
#* @param CCE    Array of the dimensions matching the order of the dimensions types
#* @param SENS   1=Expense -1=Revenue
#* @param SIGN   1=Engage the amount of the commitment -1=Desengage amount of the commitment
#* @param CMMTYP 1=Precommitment 2=Commitment (ML 631)
#* @param CTLBUD 0=Do not activate the budget control when the balance is updated
#* @param ERRMES Error message
#*!
Funprog _UPD_BUD(ACTX,DAT,SITE,LEDTYP,CUR,AMTCUR,AMTLED,QTY,ACC,BPR,DIE,CCE,SENS,SIGN,CMMTYP,CTLBUD,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Date    DAT         : # Date
Value    Char    SITE        : # Site
Value    Tinyint LEDTYP      : # Ledger type
Value    Char    CUR         : # Currency of the amount of commitment
Value    Decimal AMTCUR      : # Amount in currency
Value    Decimal AMTLED      : # Amount in currency ledger
Value    Decimal QTY         : # Quantity
Value    Char    ACC         : # Account
Value    Char    BPR         : # Business Partner
Value    Char    DIE()(1..)  : # Array of the dimension types
Value    Char    CCE()(1..)  : # Array of the dimensions matching the order of the dimensions types
Value    Integer SENS        : # 1=Expense -1=Revenue
Value    Integer SIGN        : # 1=Engage the amount of the commitment -1=Desengage amount of the commitment
Value    Tinyint CMMTYP      : # 1=Precommitment 2=Commitment <ML 631>
Value    Integer CTLBUD      : # 0=Do not activate the budget control when the balance is updated
Variable Char    ERRMES()    : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Gosub DECL_VAR_UPD
Gosub OPEN_FILE_UPD

I = fmet ACTX.ACACHE.AFCY.AGETINDEX(SITE)
If I = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = SITE-mess(15,104,1) : End [L]ASTATUS
Endif

COMPANY = fmet ACTX.ACACHE.AFCY.AGETVALCHAR(SITE,"LEGCPY")
I = fmet ACTX.ACACHE.ACPY.AGETINDEX(COMPANY)
If I = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = COMPANY-mess(16,104,1) : End [L]ASTATUS
Endif

[L]ASTATUS = func FINPER_SYRA.GET_PER(ACTX, COMPANY, LEDTYP, DAT, FIY, PERIOD, ERRMES)
If FIY=0 | PERIOD=0
 [L]ASTATUS = [V]CST_AERROR : ERRMES = num$(DAT)-mess(1,104,1) : End [L]ASTATUS
Endif

[L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(ACTX, COMPANY, LEDTYP, LEDCOD, LEDCUR, ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

[L]ASTATUS = func FINACC_SYRA.GET_LEDCOA(ACTX,COMPANY,LEDTYP,COA,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

Call LEC_GAC(ACC,COA) From CPTLEC
UOM = [F:GAC]UOM
BALBPR = BPR

## Control if there is budget overrun
If CTLBUD<>0 & SIGN = +1
 [L]ASTATUS = func CTL_BUDOVR(ACTX,DAT,SITE,LEDTYP,LEDCUR,ACC,DIE,CCE,AMTLED,QTY,CTLBUD,ERRMES)
 If [L]ASTATUS>=[V]CST_AERROR & CTLBUD=2 : End [L]ASTATUS: Endif
 [L]ASTATUS = [V]CST_AOK
Endif

## Updating operation budget
Call LEC_ACV("GDD", FLGGDD) From CPTLEC
If FLGGDD=1
 If adxtyp=33 | !clalev([F:ENV])  : Local File ENVELOPPE [ENV]  : Endif
 If adxtyp=33 | !clalev([F:ENF])  : Local File ENVFIY    [ENF]  : Endif
 Gosub UPD_GDD
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS: Endif
Endif

[L]ASTATUS = func FINCCE_SYRA.GET_DIELST(ACTX, COMPANY, LEDTYP, NBRDIE, LSTDIE, ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS: Endif

For I=1 To NBRDIE
 IDIE = find(LSTDIE(I),DIE(1..dim(DIE)))
 If IDIE
  Assign "BALDIE"+num$(I) With evalue("DIE("+num$(IDIE)+")")
  Assign "BALSEC"+num$(I) With evalue("CCE("+num$(IDIE)+")")
 Endif
Next

Gosub BAL_ANA_CMM : # Update analytical balance for account+business partner
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS: Endif
If BALBPR<>""
 BALBPR = ""
 Gosub BAL_ANA_CMM : # Update analytical balance for control (collectif)
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS: Endif
Endif
End [L]ASTATUS

########################################################################################################
$DECL_VAR_UPD
Local Char    COMPANY(GLONCPY)       : # Legal company of the site [L]SITE
Local Integer FIY                    : # Fiscal year of the [L]DAT parameter
Local Integer PERIOD                 : # Period of the [L]DAT parameter
Local Char    LEDCOD(GLONLED)        : # Ledger code of the ledger type LEDTYP
Local Char    LEDCUR(GLONCUR)        : # Currency of the ledger type LEDTYP
Local Char    COA(GLONCOA)           : # Chart of account for the ledger type LEDTYP and the company COMPANY
Local Char    UOM(GLONUOM)           : # Nonfinancial unit of the account
Local Integer FLGGDD                 : # =1 if the GDD activity code is set
Local Integer I, IDIE                : # Index
Local Char    LSTDIE(GLONDIE)(1..9)  : # List of the dimension codes of a ledger
Local Integer NBRDIE                 : # Number of dimensions of a ledger

## Dimension types and dimensions
Local Char    BALDIE1(GLONCCE), BALDIE2(GLONCCE), BALDIE3(GLONCCE), BALDIE4(GLONCCE), BALDIE5(GLONCCE)
Local Char    BALDIE6(GLONCCE), BALDIE7(GLONCCE), BALDIE8(GLONCCE), BALDIE9(GLONCCE)
Local Char    BALSEC1(GLONCCE), BALSEC2(GLONCCE), BALSEC3(GLONCCE), BALSEC4(GLONCCE), BALSEC5(GLONCCE)
Local Char    BALSEC6(GLONCCE), BALSEC7(GLONCCE), BALSEC8(GLONCCE), BALSEC9(GLONCCE)

Local Char BALFCY(GLONFCY)           : # Site used to udpate the balance
Local Char BALBPR(GLONBPR)           : # Business partner used to udpate the balance
Return

$DECL_VAR_GDD
Local Char    ENVELOP(GLONENV), ENTITY(GLONENT), DIMENSION3(GLONCCE)
Local Char    SITBUD(GLONFCY), BUDCOD(GLONBUP)
Local Integer DIEENV, DIEENT , DIE3 , OK, YEAFLG
Return

########################################################################################################
$OPEN_FILE_UPD
If adxtyp=33 | !clalev([F:ACV])  : Local File ACTIV     [ACV]  : Endif
If adxtyp=33 | !clalev([F:GAC])  : Local File GACCOUNT  [GAC]  : Endif
If adxtyp=33 | !clalev([F:BUD])  : Local File BUD       [BUD]  : Endif
If adxtyp=33 | !clalev([F:BLM])  : Local File BLACMM    [BLM]  : Endif
If adxtyp=33 | !clalev([F:BLQ])  : Local File BLAQTY    [BLQ]  : Endif
If adxtyp=33 | !clalev([F:LED])  : Local File GLED      [LED]  : Endif
Return

#####################################################################################################################
## CTL_BUDOVR
#####################################################################################################################
#**
#* controls if the budget is overrun<br>
#*
#* @param ACTX   Context
#* @param DAT    Date
#* @param SITE   Site
#* @param LEDTYP Ledger type
#* @param CUR    Currency
#* @param ACC    Account
#* @param DIE    Array of the dimension types
#* @param CCE    Array of the dimensions matching the order of the dimensions types
#* @param AMT    Amount in currency ledger
#* @param QTY    Quantity
#* @param CTLBUD 0=Do not activate the budget control when the balance is updated
#* @param ERRMES Error message
#*!
Funprog CTL_BUDOVR(ACTX,DAT,SITE,LEDTYP,CUR,ACC,DIE,CCE,AMT,QTY,CTLBUD,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Date    DAT         : # Date
Value    Char    SITE        : # Site
Value    Tinyint LEDTYP      : # Ledger type
Value    Char    CUR         : # Currency
Value    Char    ACC         : # Account
Value    Char    DIE()(1..)  : # Array of the dimension types
Value    Char    CCE()(1..)  : # Array of the dimensions matching the order of the dimensions types
Value    Decimal AMT         : # Amount in currency ledger
Value    Decimal QTY         : # Quantity
Value    Integer CTLBUD      : # 0=To not activate the budget control when the balance is updated
Variable Char    ERRMES()    : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

[L]ASTATUS = func _CTL_BUDOVR(ACTX,DAT,SITE,LEDTYP,CUR,ACC,DIE,CCE,AMT,QTY,CTLBUD,ERRMES)
End [L]ASTATUS

#####################################################################################################################
## _CTL_BUDOVR
#####################################################################################################################
#**
#* controls if the budget is overrun<br>
#*
#* @private
#*
#* @param ACTX   Context
#* @param DAT    Date
#* @param SITE   Site
#* @param LEDTYP Ledger type
#* @param CUR    Currency
#* @param ACC    Account
#* @param DIE    Array of the dimension types
#* @param CCE    Array of the dimensions matching the order of the dimensions types
#* @param AMT    Amount in currency ledger
#* @param QTY    Quantity
#* @param CTLBUD 0=Do not activate the budget control when the balance is updated
#* @param ERRMES Error message
#*!
Funprog _CTL_BUDOVR(ACTX,DAT,SITE,LEDTYP,CUR,ACC,DIE,CCE,AMT,QTY,CTLBUD,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Date    DAT         : # Date
Value    Char    SITE        : # Site
Value    Tinyint LEDTYP      : # Ledger type
Value    Char    CUR         : # Currency
Value    Char    ACC         : # Account
Value    Char    DIE()(1..)  : # Array of the dimension types
Value    Char    CCE()(1..)  : # Array of the dimensions matching the order of the dimensions types
Value    Decimal AMT         : # Amount in currency ledger
Value    Decimal QTY         : # Quantity
Value    Integer CTLBUD      : # 0=To not activate the budget control when the balance is updated
Variable Char    ERRMES()    : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Gosub DECL_VAR_CTL
Gosub OPEN_FILE_CTL
Gosub LOAD_PARAM

I = fmet ACTX.ACACHE.AFCY.AGETINDEX(SITE)
If I = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = mess(4,108,1)+"\"+mess(15,104,1)-SITE : End [L]ASTATUS
Endif

COMPANY = fmet ACTX.ACACHE.AFCY.AGETVALCHAR(SITE,"LEGCPY")
I = fmet ACTX.ACACHE.ACPY.AGETINDEX(COMPANY)
If I = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = mess(4,108,1)+"\"+mess(16,104,1)-COMPANY : End [L]ASTATUS
Endif

CURCPY = fmet ACTX.ACACHE.ACPY.AGETVALCHAR(COMPANY,"ACCCUR")

[L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(ACTX, COMPANY, LEDTYP, LEDCOD, LEDCUR, ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

[L]ASTATUS = func FINACC_SYRA.GET_LEDCOA(ACTX,COMPANY,LEDTYP,COA,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

# To declare the variables required in the entry point
Gosub BEFORE_POINT
If adxtyp=33
 GPOINT = "BEFACSBUD" : Gosub ENTREE From EXEFNC
Endif

Call LEC_ACV("GDD", FLGGDD) From CPTLEC
If FLGGDD=1
 Gosub VERF_GDD
 If [L]ASTATUS>=[V]CST_AERROR & CTLBUD=2 : End [L]ASTATUS: Endif
 [L]ASTATUS = [V]CST_AOK
Endif

For INDBUD=1 To NBRBUD
 OKB = 1
 If BUDGET(INDBUD)<>""
  Call LEC_BUP(BUDGET(INDBUD)) From CPTLEC
  If [F:BUP]GDDFLG<>[V]CST_AYES ## To exclude the budgets ticked operation budget from the standard control
   CURBUD = [F:BUP]CUR
   If !(DAT>=[F:BUP]VLYSTR & ([F:BUP]VLYEND=AVOID.ADATE | DAT<=[F:BUP]VLYEND))
    OKB = 0
   Endif

   # Check the period and the fiscal year exist depending on the typ of control
   If OKB
    Gosub BUDCTLTYP
    If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
   Endif

   # Check that account and dimension are ticked budget
   Call LEC_GAC(ACC,COA) From CPTLEC
   If [F:GAC]BUDTRK<>[V]CST_AYES : OKB = 0 : Endif
   If OKB
    For J=1 To dim([F:BUP]DIE)
     If [F:BUP]DIE(J-1)<>""
      K = find([F:BUP]DIE(J-1),DIE(1..dim(DIE)-1))
      If K
       If CCE(K) = ""
        OKB = 0 : Break
       Else
        Call LEC_CCE(CCE(K),DIE(K)) From CPTLEC
        If [F:CCE]BUDTRK<>[V]CST_AYES : OKB = 0 : Break : Endif
       Endif
      Else
       OKB = 0 : Break
      Endif
     Endif
    Next
   Endif

   If OKB
    If [F:BUP]LEV=1
     BUDFCY = ""
    Else
     BUDFCY = SITE
    Endif

    Gosub READ_BUD

    If OKB & (dim([L]BUDEXISTS)<0 | (dim([L]BUDEXISTS)>0 & [L]BUDEXISTS=1))

     OK2 = func _IS_BUDOVR(ACTX,AMT,QTY,CUR,LEDCUR,CURBUD,CURCPY,BUDTYPCUR,DAT,MTBUD,QTBUD,MTBLA,QTBLA,MTCMM
&                         ,QTCMM,MTPRP,QTPRP,BUDCMM,BUDPRE,BUDCTLAMT,BUDCTLQTY,BUDPRCAMT,BUDPRCQTY)

     # This entry point uses MESSA
     If adxtyp=33
      GPOINT = "AFTBUDCTL" : Gosub ENTREE From EXEFNC
     Endif

     Case OK2
      When 1
       NBRMES += 1
       If MESSA<>"" : MESSA += "\" : Endif
       MESSA += mess(LEDTYP,2644,1)-":"-mess(5,108,1)-BUDGET(INDBUD)-BUDVER(INDBUD)-BUDACC
       For I=1 To 9 : MESSA -= BUDCCE(I) : Next
       If CTLBUD=2 : [L]ASTATUS = [V]CST_AERROR  : Break : Endif
       If NBRMES>=6 : Break : Endif
      When 2
       NBRMES += 1
       If MESSA<>"" : MESSA += "\" : Endif
       MESSA += mess(LEDTYP,2644,1)-":"-mess(7,108,1)-BUDGET(INDBUD)-BUDVER(INDBUD)-BUDACC
       For I=1 To 9 : MESSA -= BUDCCE(I) : Next
       If CTLBUD=2 : [L]ASTATUS = [V]CST_AERROR  : Break : Endif
       If NBRMES>=3 : Break : Endif
      When 3
       NBRMES += 1
       If MESSA<>"" : MESSA += "\" : Endif
       MESSA += mess(LEDTYP,2644,1)-":"-mess(4,108,1)+"\"+mess(4,109,1)-CURBUD-"=>"-LEDCUR
       If CTLBUD=2 : [L]ASTATUS = [V]CST_AERROR  : Break : Endif
      When 4
       NBRMES += 1
       If MESSA<>"" : MESSA += "\" : Endif
       MESSA += mess(LEDTYP,2644,1)-":"-mess(4,108,1)+"\"+mess(4,109,1)-CUR-"=>"-LEDCUR
       If CTLBUD=2 : [L]ASTATUS = [V]CST_AERROR  : Break : Endif
     Endcase
    Endif
   Endif
  Endif
 Endif
Next

If MESSA<>""
 ERRMES += MESSA
 [L]ASTATUS=[V]CST_AERROR
Endif

If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
End [L]ASTATUS

################################################################################
## Variables declaration
################################################################################
$DECL_VAR_CTL
Local Integer I,J,K,I1,I2,I3,I4,I5,I6,I7,I8,I9,I10 : # Index
Local Char    COMPANY(GLONCPY)            : # Company
Local Char    CURCPY(GLONCUR)             : # Company currency
Local Char    LEDCOD(GLONLED)             : # Ledger code of the ledger type LEDTYP
Local Char    LEDCUR(GLONCUR)             : # Currency of the ledger type LEDTYP
Local Char    COA(GLONCOA)                : # Chart of account for the ledger type LEDTYP and the company COMPANY
Local Integer FLGGDD                      : # =1 if the GDD activity code is set
Local Integer OKB                         : # Indicates that the budget is not overrun
Local Integer STA                         : # Indicates the type of overrun in order to display the right message
Local Integer NBRMES                      : # Number of error messages
Local Char    MESSA(250)                  : # Error messages to store for each budget
Local Integer VALPARI                     : # Value of an integer parameter
Local Integer FIY                         : # Fiscal year of [L]DAT
Local Integer FIYSTR, FIYEND              : # First and last fiscal year of the validity dates of the budget
Local Integer PER                         : # Period of [L]DAT
Local Integer PERSTR, PEREND              : # First and last period of the validity dates of the budget
Local Integer PER1,PER2                   : # First and last period
Local Char    CURBUD(GLONCUR)             : # Budget currency
Local Char    BUDFCY(GLONFCY)             : # Facility to search in BUD table
Local Char    BUDACC(GLONGAC)             : # Account linked to the budget. Used to search in the BUD table
Local Char    GRUREF(max(GLONCYR,GLONGRY)): # Group code of the dimension or account
Local Char    BUDCCE(GLONCCE)(1..9)       : # Dimension linked to the budget. ([BUP]DIE)
Local Char    LEDBUDCCE(GLONCCE)(9)       : # Dimension linked to the budget. Used to search in the BUD table ([LED]DIE)

Local Decimal MTBUD,QTBUD
Local Decimal MTBLA, QTBLA, MTCMM, QTCMM, MTPRP, QTPRP
Local Decimal SIGN                         : # Analytical sign of the account
Local Char    CRITBLA(250)(0..2)           : # Criteria
Local Char    CRITPYR(250)(0..2)           : # Criteria
Local Integer IBLA, IPYR                   : # Criteria

Local Integer NBRBUD                       : # Number of budgets to control
Local Integer INDBUD                       : # Indice of  budgets to control
Local Tinyint BUDCTLAMT                    : # Control the amount O/N
Local Decimal BUDPRCAMT                    : # Tolerance percentage for amount
Local Tinyint BUDCTLQTY                    : # control the quantity O/N
Local Decimal BUDPRCQTY                    : # Tolerance percentage for quantity
Local Tinyint BUDCMM                       : # Commitment (AML 1)
Local Tinyint BUDPRE                       : # Pre commitment
Local Char    BUDGET(GLONBUP)(1..10)       : # Budget codes to control
Local Char    BUDVER(GLONBUV)(1..10)       : # Budget versions to control
Local Tinyint BUDTYPCUR                    : # Rate type

Local Integer SEP  : # Separator , already written in the Link
Local Integer STAT : # Status
Local Char    FILPROG(GLONADC) , FILSRC(250) , FILADX(250) : # Generation of the Link
Local Integer OKBUDCCE(1..9)  : # =1 : the dimension is not a pyramid or the dimension exists in the pyramid level
Local Integer NUMCCE(1..9)    : # Index of the dimension in the ledger (different from the index in BUDPAR table)
Local Char    ACCSIGN(GLONGAC): # Keep the account to search the sign
Local Char    PLAN(GLONCOA)   : # To use the SEARCH_SIGN function that uses the PLAN variable

Return

################################################################################
## Open the files
################################################################################
$OPEN_FILE_CTL
If adxtyp=33 | !clalev([F:BUP])  : Local File BUDPAR     [BUP]  : Endif
If adxtyp=33 | !clalev([F:GYK])  : Local File GACCPYMLIK [GYK]  : Endif
If adxtyp=33 | !clalev([F:GRY])  : Local File GACCGRUPYM [GRY]  : Endif
If adxtyp=33 | !clalev([F:CRY])  : Local File GCCEGRUPYM [CRY]  : Endif
If adxtyp=33 | !clalev([F:CYK])  : Local File GCCEPYMLIK [CYK]  : Endif
If adxtyp=33 | !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif
If adxtyp=33 | !clalev([F:COA])  : Local File GCOA       [COA]  : Endif
If adxtyp=33 | !clalev([F:CLS])  : Local File GACCCLS    [CLS]  : Endif
If adxtyp=33 | !clalev([F:ACV])  : Local File ACTIV      [ACV]  : Endif
If adxtyp=33 | !clalev([F:CCE])  : Local File CACCE      [CCE]  : Endif
If adxtyp=33 | !clalev([F:BUD])  : Local File BUD        [BUD]  : Endif
If adxtyp=33 | !clalev([F:BLA])  : Local File BALANA     [BLA]  : Endif
If adxtyp=33 | !clalev([F:BLQ])  : Local File BLAQTY     [BLQ]  : Endif
If adxtyp=33 | !clalev([F:BLM])  : Local File BLACMM     [BLM]  : Endif
If adxtyp=33 | !clalev([F:PER])  : Local File PERIOD     [PER]  : Endif
If adxtyp=33 | !clalev([F:LED])  : Local File GLED       [LED]  : Endif

If adxtyp=33 | !clalev([F:CYK1]) : Local File GCCEPYMLIK [CYK1] : Endif
If adxtyp=33 | !clalev([F:CYK2]) : Local File GCCEPYMLIK [CYK2] : Endif
If adxtyp=33 | !clalev([F:CYK3]) : Local File GCCEPYMLIK [CYK3] : Endif
If adxtyp=33 | !clalev([F:CYK4]) : Local File GCCEPYMLIK [CYK4] : Endif
If adxtyp=33 | !clalev([F:CYK5]) : Local File GCCEPYMLIK [CYK5] : Endif
If adxtyp=33 | !clalev([F:CYK6]) : Local File GCCEPYMLIK [CYK6] : Endif
If adxtyp=33 | !clalev([F:CYK7]) : Local File GCCEPYMLIK [CYK7] : Endif
If adxtyp=33 | !clalev([F:CYK8]) : Local File GCCEPYMLIK [CYK8] : Endif
If adxtyp=33 | !clalev([F:CYK9]) : Local File GCCEPYMLIK [CYK9] : Endif

Return

################################################################################
## Load the budgets to control and the value of the parameters
################################################################################
$LOAD_PARAM
Call GET_BUP(ACTX,SITE,BUDGET,BUDVER,NBRBUD)

VALPARI = fmet ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY,SITE,"BUDAMT")
BUDCTLAMT = (VALPARI=[V]CST_AYES)
If BUDCTLAMT
 BUDPRCAMT = fmet ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY,SITE,"BUDPRCAMT")
Endif

VALPARI = fmet ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY,SITE,"BUDQTY")
BUDCTLQTY = (VALPARI=[V]CST_AYES)
If BUDCTLQTY
 BUDPRCQTY = fmet ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY,SITE,"BUDPRCQTY")
Endif

VALPARI = fmet ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY,SITE,"BUDCMM")
BUDCMM = (VALPARI=[V]CST_AYES)

VALPARI = fmet ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY,SITE,"BUDCMMPRP")
BUDPRE = (VALPARI=[V]CST_AYES)

BUDTYPCUR = fmet ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY,SITE,"BUDTYPCUR")
If BUDTYPCUR=0 : BUDTYPCUR = 1 : Endif
Return

#####################################################################################################################
## GET_BUP
#####################################################################################################################
#**
#* Return the budget and the version of the BUPx parameters for the final budgets<br>
#*
#* @private
#*
#* @param ACTX   Context
#* @param SITE   Site
#* @param BUDGET Budget
#* @param BUDVER Version of the budget
#* @param NBRBUD Number of budget/version
#*!
Subprog GET_BUP(ACTX,SITE,BUDGET,BUDVER,NBRBUD)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     SITE()
Variable Char     BUDGET()(1..)
Variable Char     BUDVER()(1..)
Variable Integer  NBRBUD
Local Char    VALPAR(20) : # Value of a character parameter
Local Integer I

If adxtyp=33 | !clalev([F:BUV])  : Local File BUDVER     [BUV]  : Endif

Raz BUDGET, BUDVER, NBRBUD
For I=1 To 9
 VALPAR  = fmet ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFCY,SITE,"BUP"+num$(I))
 If VALPAR<>""
  Filter [BUV] Where BUD=VALPAR & CTL=[V]CST_AYES
  For [BUV]BUV0
   NBRBUD +=1
   BUDGET(NBRBUD) = [F:BUV]BUD
   BUDVER(NBRBUD) = [F:BUV]VER
  Next
  Filter [BUV]
 Endif
Next
End
################################################################################
$BEFORE_POINT
Local Integer GBUDNB
Local Char    GBUDGET(GLONBUP)(1..10)
Local Char    SOCIETE(GLONCPY)
Local Char    DEVISE(GLONCUR)
Local Char    PLAN(GLONCOA)
Local Char    COMPTE(GLONGAC)
Local Integer DIMANA
Call LEC_ACV("ANA",DIMANA) From CPTLEC
DIMANA = max(1,[F:ACV]DIME)
Local Char    TBDIE(GLONDIE)(1..DIMANA)
Local Char    TBCCE(GLONCCE)(1..DIMANA)
Local Decimal MONTANT
Local Decimal QUANTITE
GNBBUD = NBRBUD
For J = 1 To 10
 GBUDGET(J) = BUDGET(J)
Next
SOCIETE = COMPANY
DEVISE = CUR
PLAN=COA
COMPTE=ACC
For J=1 To DIMANA
 TBDIE(J)=DIE(J)
 TBCCE(J)=CCE(J)
Next
MONTANT=AMT
QUANTITE=QTY
Return

################################################################################
## Check the budget ticked opertaion budget
################################################################################
$VERF_GDD
Local Decimal AMTASK          : # Amount AMT asked converted in CURBUD currency
Local Decimal AMTREA          : # Amount realized (consumed)
Local Decimal AMTBUD          : # Amount budgeted
Local Decimal AMTASKMES       : # Amount asked ddisplayed in the message
Local Decimal AMTTOTMES       : # Total amount asked+realized displayed in the message
Local Integer STAT            : # status returned
Local Integer PERIOD          : # Period - fiscal year
Local Integer VALPARI         : # Value of parameter
Local Decimal RATE            : # Rate
Local Decimal LIMIT           : # Limit not to exceed.
Local Decimal LIMIT_INI       : # Initial limit not to exceed (Only takes into account the budget)
Local Decimal RMN_BUD         : # Remaining budget amount without reserve amount and consummed amount
Local Decimal RMN_RESBUD      : # Remaining budget amount with reserve amount
Local Decimal RMN_ENV         : # Remaining envelope amount without reserve amount and consummed amount
Local Decimal RMN_RESENV      : # Remaining envelope amount with reserve amount
Local Decimal RMN_BUD_INI     : # Budget amount without reserve amount
Local Decimal RMN_RESBUD_INI  : # Budget amount
Local Decimal RMN_ENV_INI     : # Envelope amount without reserve amount
Local Decimal RMN_RESENV_INI  : # Envelope amount

Gosub DECL_VAR_GDD
Call GET_BUOINF(DIE,CCE,SITE,BUDCOD,ENTITY,DIEENT,ENVELOP,DIEENV,DIMENSION3,DIE3,OK,YEAFLG,SITBUD) From FINBUO_SYRA
If !OK : Return : Endif

Call LEC_ENV(ENVELOP) From CPTLEC
Call CONVERT(ACTX,CUR,[F:ENV]CURENV,CURCPY,BUDTYPCUR,DAT,AMT,AMTASK,STAT) From TRTDEV_SYRA
If STAT
 If ERRMES<>"" : ERRMES += "\" : Endif
 ERRMES += mess(4,108,1)+"\"+mess(4,109,1)-CUR-"=>"-CURBUD
 [L]ASTATUS = [V]CST_AERROR : Return
Endif

[L]ASTATUS = func FINPER_SYRA.GET_PER(ACTX, COMPANY, LEDTYP, DAT, FIY, PERIOD, ERRMES)
If FIY=0 | PERIOD=0
 ERRMES = mess(4,108,1)+"\"+mess(1,104,1)
 [L]ASTATUS = [V]CST_AERROR : Return
Endif

Raz [F:BUD]
Call LEC_LED([L]LEDCOD) From CPTLEC
If DIEENT>0
 I = find(DIE(DIEENT),[F:LED]DIE(0..[F:LED]DIENBR-1))
 Assign "[F:BUD]CCE"+num$(I) With ENTITY
Endif
If DIEENV>0
 I = find(DIE(DIEENV),[F:LED]DIE(0..[F:LED]DIENBR-1))
 Assign "[F:BUD]CCE"+num$(I) With ENVELOP
Endif
If DIE3>0
 I = find(DIE(DIE3),[F:LED]DIE(0..[F:LED]DIENBR-1))
 Assign "[F:BUD]CCE"+num$(I) With DIMENSION3
Endif
[F:BUD]LEDTYP = [L]LEDTYP
[F:BUD]BUD    = [F:ENV]BUD
[F:BUD]CPY    = COMPANY
[F:BUD]FCY    = SITBUD
[F:BUD]FIY    = [L]FIY
[F:BUD]VER    = "1"
[F:BUD]ACC    = [L]ACC
Read [BUD]BUD0=
If fstat
 ERRMES = mess(178,108,1)-CCE(DIEENV)      : # Envelope
 ERRMES += "\"+mess(179,108,1)-CCE(DIEENT) : # Entity
 ERRMES += "\"+mess(180,108,1)-ACC         : # Account
 If DIE3<>0
  Local Char NAMDIE3(30)
  Call LECTEXTRA_SYR(AVOID.AINS,"", NAMDIE3,"GDIE","DESTRA",DIE(DIE3),"") From ATEXTRA
  ERRMES += "\"+NAMDIE3-CCE(DIE3)             : # dimension type 3 dimension 3
 Endif
 ERRMES += "\"+mess(176,108,1)
 [L]ASTATUS = [V]CST_AERROR : Return
Endif

AMTREA = [F:BUD]AMTREA+[F:BUD]AMTCMM+[F:BUD]AMTCMMPRP
AMTBUD = [F:BUD]AMT(0)

# No control if the envelope is off-budget
If [F:ENV]EXTBUD=[V]CST_AYES : Return : Endif

# Calculation of the remainig amount and the budget remaining amount
Gosub CAL_REMAINIG_AMT

Raz LIMIT, LIMIT_INI

# Control that depends on the user parameter
VALPARI = fmet ACTX.APARAM.AGETUSERVALNUM("GDDBUDDEP")
Case VALPARI
 When 1 : # No overrun / Pas de dépassement
  LIMIT     = [F:BUD]AMT(0)-AMTREA
  LIMIT_INI = [F:BUD]AMT(0)
  AMTASKMES = AMTASK
  AMTTOTMES = AMTASK+AMTREA
 When 2 : # Within the limits of the budget remaining to be allocated /Dans la limite du reste à ventiler budget * exercice
  LIMIT     = RMN_BUD
  LIMIT_INI = RMN_BUD_INI
  AMTASKMES = AMTASK
  AMTTOTMES = AMTASK+AMTREA
 When 3 : # Within the limits of the budget reserve/Dans la limite de la réserve budget * exercice
  LIMIT     = RMN_RESBUD
  LIMIT_INI = RMN_RESBUD_INI
  AMTASKMES = AMTASK
  AMTTOTMES = AMTASK+AMTREA
 When 4 : # Within the limits of the envelope remaining to be allocated/Dans la limite du reste à ventiler enveloppe
  LIMIT     = RMN_ENV
  LIMIT_INI = RMN_ENV_INI
  AMTASKMES = AMTASK
  AMTTOTMES = AMTASK+AMTREA
 When 5 : # Within the limits of the envelope reserve/Dans la limite de la réserve enveloppe
  LIMIT     = RMN_RESENV
  LIMIT_INI = RMN_RESENV_INI
  AMTASKMES = AMTASK
  AMTTOTMES = AMTASK+AMTREA
 When 6 : # Envelope overrun (%)/Dépassement dans la limite du seuil de tolérance /t à l'enveloppe tjrs
  Call LEC_ENV(CCE(DIEENV)) From CPTLEC
  AMTBUD = [F:ENV]AMTENV
  If [F:ENV]EXDPRC<>0
   RATE = [F:ENV]EXDPRC
  Else
   RATE = fmet ACTX.APARAM.AGETUSERVALNUM("GDDBUDPRC")
  Endif

  VALPARI = fmet ACTX.APARAM.AGETUSERVALNUM("GDDBUDCTL")
  Case VALPARI
   When 1 : # Line
    LIMIT     = sum([F:BUD]AMT) * (RATE/100)
    LIMIT_INI = LIMIT
   When 2 : # Fiscal year
    LIMIT = 0
    Read [ENF]ENF0=CCE(DIEENV);FIY
    If !fstat
     LIMIT = [F:ENF]AMTBUDFIY * (RATE/100)
    Endif
    LIMIT_INI = LIMIT
   When 3 : # Envelope
    LIMIT  = [F:ENV]AMTENV * (RATE/100)
   When Default
    ERRMES = mess(271,108,1)
    Call DYNAMIC(ERRMESS,"$1$","GDDBUDCTL") From TEXTE
    [L]ASTATUS = [V]CST_AERROR : Return
  Endcase
  LIMIT    += AMTBUD
  LIMIT_INI = LIMIT
  AMTASKMES = AMTASK
  AMTTOTMES = AMTASK+AMTREA
  AMTASK   += AMTREA
 When Default
  ERRMES = mess(271,108,1)
  Call DYNAMIC(ERRMES,"$1$","GDDBUDDEP") From TEXTE
  [L]ASTATUS = [V]CST_AERROR : Return
Endcase

If AMTASK>LIMIT
 ERRMES  = mess(178,108,1)-"/"-mess(179,108,1)-"/"-mess(180,108,1)
 ERRMES += "\"+CCE(DIEENV)-"/"-CCE(DIEENT)-"/"-ACC
 ERRMES += "\"+mess(177,108,1)-":"
 ERRMES += "\"+mess(224,108,1)-num$(AMTASKMES)-"+"-mess(225,108,1)-num$(AMTREA)
 ERRMES += "\"+"="-num$(AMTTOTMES)-mess(226,108,1)-num$(LIMIT_INI)
 [L]ASTATUS = [V]CST_AERROR : Return
Endif
Return

################################################################################
$CAL_REMAINIG_AMT
Read [ENF]ENF0=CCE(DIEENV);FIY
RMN_BUD    = [F:ENF]AMTBUDFIY-[F:ENF]AMTRESFIY-AMTREA
RMN_RESBUD = [F:ENF]AMTRESFIY+min(RMN_BUD,0)+max(RMN_BUD,0)
RMN_ENV    = [F:ENV]AMTENV-[F:ENV]AMTRES-AMTREA
RMN_RESENV = [F:ENV]AMTRES+min(RMN_ENV,0)+max(RMN_ENV,0)
#- The initial remaining amounts (before any entry)/ Les restes à ventiler budgétés au départ (avant ecritures)
RMN_BUD_INI    = [F:ENF]AMTBUDFIY-[F:ENF]AMTRESFIY
RMN_RESBUD_INI = [F:ENF]AMTBUDFIY
RMN_ENV_INI    = [F:ENV]AMTENV-[F:ENV]AMTRES
RMN_RESENV_INI = [F:ENV]AMTENV
Return

########################################################################################################
$BUDCTLTYP
Case [F:BUP]BUDCTL
  When 2,3 : # Annual control type, Period control type
   [L]ASTATUS = func FINPER_SYRA.GET_PER(ACTX, COMPANY, LEDTYP, DAT, FIY, PER, ERRMES)
   If FIY=0 | PER=0
    ERRMES = mess(4,108,1)+"\"+mess(1,104,1)
    [L]ASTATUS = [V]CST_AERROR : Return
   Endif
   FIYSTR = FIY
   FIYEND = FIY

  When 4   : # Sliding control typ
   [L]ASTATUS = func FINPER_SYRA.GET_PER(ACTX, COMPANY, LEDTYP, [F:BUP]VLYSTR, FIYSTR, PERSTR, ERRMES)
   If FIYSTR=0 | PERSTR=0
    For [PER]PER0 Where [F:PER]LEDTYP=[L]LEDTYP & CPY=COMPANY & PERSTR>=[F:BUP]VLYSTR & PEREND>=[F:BUP]VLYSTR
     FIYSTR = [F:PER]FIYNUM
     PERSTR = [F:PER]PERNUM
     Break
    Next
   Endif
   If [F:BUP]VLYEND<>[0/0/0]
    [L]ASTATUS = func FINPER_SYRA.GET_PER(ACTX, COMPANY, LEDTYP, [F:BUP]VLYEND, FIYEND, PEREND, ERRMES)
    If FIYEND=0 | PEREND=0
     For [PER]PER0 Where [F:PER]LEDTYP=[L]LEDTYP & CPY=COMPANY & PERSTR<=[F:BUP]VLYEND & PEREND<=[F:BUP]VLYEND
      FIYEND = [F:PER]FIYNUM
      PEREND = [F:PER]PERNUM
     Next
    Endif
   Else
    For [PER] PER0 Where [F:PER]LEDTYP=[L]LEDTYP & CPY=COMPANY & PERSTA=2
     FIYEND = [F:PER]FIYNUM
     PEREND = [F:PER]PERNUM
    Next
   Endif
   If FIYSTR=0 | PERSTR=0 | FIYEND=0 | PEREND=0
    ERRMES = mess(4,108,1)+"\"+mess(1,104,1)
    [L]ASTATUS = [V]CST_AERROR : Return
   Endif

  When 5   : # Accumulated control type
   [L]ASTATUS = func FINPER_SYRA.GET_PER(ACTX, COMPANY, LEDTYP, [F:BUP]VLYSTR, FIYSTR, PERSTR, ERRMES)
   If FIYSTR=0 | PERSTR=0
    For [PER]PER0 Where [F:PER]LEDTYP=[L]LEDTYP & CPY=COMPANY & PERSTR>=[F:BUP]VLYSTR & PEREND>=[F:BUP]VLYSTR
     FIYSTR = [F:PER]FIYNUM
     PERSTR = [F:PER]PERNUM
    Next
   Endif
   [L]ASTATUS = func FINPER_SYRA.GET_PER(ACTX, COMPANY, LEDTYP, DAT, FIYEND, PEREND, ERRMES)
   If FIYSTR=0 | PERSTR=0 | FIYEND=0 | PEREND=0
    ERRMES = mess(4,108,1)+"\"+mess(1,104,1)
    [L]ASTATUS = [V]CST_AERROR : Return
   Endif
 Endcase
 Return

########################################################################################################
$READ_BUD
# Read the account or the pyramid of accounts of the budget
Raz BUDACC
If [F:BUP]PYMACC=""
 BUDACC = ACC
Else
 Raz [F:GRY]
 Filter [GRY] Where [F:GRY]PYM=[F:BUP]PYMACC & pat([L]ACC,[F:GRY]ACC)<>0
 For [GRY]GRY0 : Break : Next
 Filter [GRY]
 If [F:GRY]GRU<>""
  GRUREF = [F:GRY]GRU
  Raz [F:GRY]
  Filter [GRY] Where PYM=[F:BUP]PYMACC & GRU=GRUREF & LEV=[F:BUP]PYMACCLEV
  For [GRY]GRY0 : Break : Next
  Filter [GRY]
  If [F:GRY]GRU<>""
   BUDACC = GRUREF
  Else
   Read [GYK]GYK0=[F:BUP]PYMACC;[F:BUP]PYMACCLEV;ACC
   If !fstat
    BUDACC = [F:GYK]GRU
   Else
    Raz [F:GYK]
    Filter [GYK] Where PYM=[F:BUP]PYMACC & LEV=[F:BUP]PYMACCLEV
    For [GYK]GYK0 : Break : Next
    Filter [GYK]
    If [F:GYK]GRU<>""
     BUDACC = [F:GYK]GRU
    Endif
   Endif
  Endif
 Endif
Endif

Raz BUDCCE
Raz OKBUDCCE

For J=1 To dim([F:BUP]DIE)
 If [F:BUP]DIE(J-1)="" : Break : Endif
 K = find([F:BUP]DIE(J-1),DIE(1..dim(DIE)-1))
 If K
  BUDCCE(J) = CCE(K)
 Endif
 If [F:BUP]PYMCCE(J-1)="" : # No pyramid for the dimension
  If K
   OKBUDCCE(J) = 1
  Endif
 Else                     : # A pyramid for the dimension
  Raz [F:CRY]
  Filter [CRY] Where PYM=[F:BUP]PYMCCE(J-1) & pat(BUDCCE(J),CCE)<>0
  For [CRY]CRY0 : Break : Next
  Filter [CRY]
  If [F:CRY]GRU<>""
   GRUREF = [F:CRY]GRU
   Raz [F:CRY]
   Filter [CRY] Where PYM=[F:BUP]PYMCCE(J-1) & GRU=GRUREF & LEV=[F:BUP]PYMCCELEV(J-1)
   For [CRY]CRY0 : Break : Next
   Filter [CRY]
   If [F:CRY]GRU<>""
    BUDCCE(J) = GRUREF
    OKBUDCCE(J) = 1
   Else
    If BUDCCE(J)<>""
     Read [CYK]CYK0 = [F:BUP]PYMCCE(J-1);[F:BUP]PYMCCELEV(J-1);BUDCCE(J)
     If !fstat
      BUDCCE(J) = [F:CYK]GRU
      OKBUDCCE(J) = 1
     Else
      Raz [F:CYK]
      Filter [CYK] Where PYM=[F:BUP]PYMCCE(J-1) & LEV=[F:BUP]PYMCCELEV(J-1)
      For [CYK]CYK0 : Break : Next
      If [F:CYK]GRU<>""
       BUDCCE(J) = [F:CYK]GRU
       OKBUDCCE(J) = 1
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
 Next

If BUDACC="" or sum(OKBUDCCE)<>[F:BUP]DIENBR
 OKB=0 : Return
Endif

# Sum the amounts of the budget [BUD] table
Raz MTBUD,QTBUD
OKB = 0
Gosub INIVAR_LEDBUDCCE
For J=FIYSTR To FIYEND
 Read [BUD]BUD0 = LEDTYP;BUDGET(INDBUD);COMPANY;BUDFCY;J;BUDVER(INDBUD);BUDACC;
&                        LEDBUDCCE(0);LEDBUDCCE(1);LEDBUDCCE(2);LEDBUDCCE(3);LEDBUDCCE(4);
&                        LEDBUDCCE(5);LEDBUDCCE(6);LEDBUDCCE(7);LEDBUDCCE(8)
 If fstat
  Raz [BUD]
 Else
  OKB = 1
 Endif
 # Set the BUDEXISTS variable to 1 to trigger the control of the budget existing
 If adxtyp=33
  GPOINT = "BUDCTL" : Gosub ENTREE From EXEFNC
 Endif

 Case [F:BUP]BUDCTL
  When 2   : # Annual control
   MTBUD += sum([F:BUD]AMT)
   QTBUD += sum([F:BUD]QTY)
  When 3   : # Period control
   MTBUD += [F:BUD]AMT(PER-1)
   QTBUD += [F:BUD]QTY(PER-1)
  When 4,5 : # Sliding and accumulated control
   If J=FIYSTR & J=FIYEND
    MTBUD += sum([F:BUD]AMT(PERSTR-1..PEREND-1))
    QTBUD += sum([F:BUD]QTY(PERSTR-1..PEREND-1))
   Elsif J=FIYSTR
    MTBUD += sum([F:BUD]AMT(PERSTR-1..dim([F:BUD]AMT)-1))
    QTBUD += sum([F:BUD]QTY(PERSTR-1..dim([F:BUD]QTY)-1))
   Elsif J=FIYEND
    MTBUD += sum([F:BUD]AMT(0..PEREND-1))
    QTBUD += sum([F:BUD]QTY(0..PEREND-1))
   Else
    MTBUD += sum([F:BUD]AMT(0..dim([F:BUD]AMT)-1))
    QTBUD += sum([F:BUD]QTY(0..dim([F:BUD]QTY)-1))
   Endif
 Endcase
Next

# Sum the quantities of the [BLA] table and the amounts of the budget [BUD] table
Raz MTBLA,QTBLA,MTCMM,QTCMM,MTPRP,QTPRP

If [F:BUP]PYMACC="" & [F:BUP]PYMCCE(0)="" & [F:BUP]PYMCCE(1)="" & [F:BUP]PYMCCE(2)=""
&                   & [F:BUP]PYMCCE(3)="" & [F:BUP]PYMCCE(4)="" & [F:BUP]PYMCCE(5)=""
&                   & [F:BUP]PYMCCE(6)="" & [F:BUP]PYMCCE(7)="" & [F:BUP]PYMCCE(8)=""

 Raz CRITBLA, IBLA
 Call ADDCRIT(ACTX,CRITBLA,IBLA,"LEDTYP",'LEDTYP='+num$([L]LEDTYP)," & ",[L]ASTATUS) From ASYRFNC
 Call ADDCRIT(ACTX,CRITBLA,IBLA,"CPY",'CPY="'+COMPANY+'"'," & ",[L]ASTATUS) From ASYRFNC
 Call ADDCRIT(ACTX,CRITBLA,IBLA,"FCY",'FCY="'+BUDFCY+'"'," & ",[L]ASTATUS) From ASYRFNC
 Call ADDCRIT(ACTX,CRITBLA,IBLA,"COA",'COA="'+[L]COA+'"'," & ",[L]ASTATUS) From ASYRFNC
 Call ADDCRIT(ACTX,CRITBLA,IBLA,"ACC",'ACC="'+BUDACC+'"'," & ",[L]ASTATUS) From ASYRFNC
 Call ADDCRIT(ACTX,CRITBLA,IBLA,"BPR",'BPR=""'," & ",[L]ASTATUS) From ASYRFNC
 For I=1 To 9
  If LEDBUDCCE(I-1)<>""
   Call ADDCRIT(ACTX,CRITBLA,IBLA,"CCE","CCE"+num$(I)+"='"+LEDBUDCCE(I-1)+"'"," & ",[L]ASTATUS) From ASYRFNC
  Endif
 Next

 # Analytical sign of the account BUDACC
 Call LEC_GAC(BUDACC,COA) From CPTLEC
 Call LEC_COA(COA) From CPTLEC
 Call LEC_CLS([F:COA]LEGCLS,[F:GAC]CLSCOD) From CPTLEC
 If [F:CLS]SNSANA=2 : SIGN = -1 : Else : SIGN = 1 : Endif

 # Loop the balances
 For J=FIYSTR To FIYEND
  # Amount of the analytical balance BALANA [BLA]
  Filter [BLA] Where evalue(CRITBLA) & FIY=J
  For [BLA]BLA0
   Case [F:BUP]BUDCTL
    When 2 : # Annual control
     MTBLA += SIGN*(sum([F:BLA]DEBLED)-sum([F:BLA]CDTLED)-[F:BLA]DEBLED(0)+[F:BLA]CDTLED(0))
    When 3 : # Period control
     MTBLA += SIGN*([F:BLA]DEBLED(PER)-[F:BLA]CDTLED(PER))
    When 4,5 : # Sliding and accumulated control
     If J=FIYSTR & J=FIYEND
      PER1 = PERSTR
      PER2 = PEREND
     Elsif J=FIYSTR
      PER1 = PERSTR
      PER2 = dim([F:BLA]DEBLED)-1
     Elsif J=FIYEND
      PER1 = 1
      PER2 = PEREND
     Else
      PER1 = 1
      PER2 = dim([F:BLA]DEBLED)-1
     Endif
     MTBLA += SIGN*(sum([F:BLA]DEBLED(PER1..PER2))-sum([F:BLA]CDTLED(PER1..PER2)))
   Endcase
  Next
  Filter [BLA]

  # Quantity of the analytical balance BLAQTY [BLQ]
  Filter [BLQ] Where evalue(CRITBLA) & FIY=J
  For [BLQ]BLQ0
   Case [F:BUP]BUDCTL
    When 2 : # Annual control
     QTBLA += SIGN*(sum([F:BLQ]QTY)-[F:BLQ]QTY(0))
     QTCMM += SIGN*(sum([F:BLQ]QTYCMM)-[F:BLQ]QTYCMM(0))
     QTPRP += SIGN*(sum([F:BLQ]QTYPRP)-[F:BLQ]QTYPRP(0))
    When 3 : # Period control
     QTBLA += SIGN*[F:BLQ]QTY(PER)
     QTCMM += SIGN*[F:BLQ]QTYCMM(PER)
     QTPRP += SIGN*[F:BLQ]QTYPRP(PER)
    When 4,5 : # Sliding and accumulated control
     If J=FIYSTR & J=FIYEND
      PER1 = PERSTR
      PER2 = PEREND
     Elsif J=FIYSTR
      PER1 = PERSTR
      PER2 = dim([F:BLQ]QTY)-1
     Elsif J=FIYEND
      PER1 = 1
      PER2 = PEREND
     Else
      PER1 = 1
      PER2 = dim([F:BLQ]QTY)-1
     Endif
     QTBLA += SIGN*sum([F:BLQ]QTY(PER1..PER2))
     QTCMM += SIGN*sum([F:BLQ]QTYCMM(PER1..PER2))
     QTPRP += SIGN*sum([F:BLQ]QTYPRP(PER1..PER2))
   Endcase
  Next
  Filter [BLQ]

  # Balance of commitment BLACMM [BLM]
  Filter [BLM] Where evalue(CRITBLA) & FIY=J
  For [BLM]BLM0
   Case [F:BUP]BUDCTL
    When 2 : # Annual control
     MTCMM += SIGN*(sum([F:BLM]CMMLED)-[F:BLM]CMMLED(0))
     MTPRP += SIGN*(sum([F:BLM]CMMPRPLED)-[F:BLM]CMMPRPLED(0))
    When 3 : # Period control
     MTCMM += SIGN*[F:BLM]CMMLED(PER)
     MTPRP += SIGN*[F:BLM]CMMPRPLED(PER)
    When 4,5 : # Sliding and accumulated control
     If J=FIYSTR & J=FIYEND
      PER1 = PERSTR
      PER2 = PEREND
     Elsif J=FIYSTR
      PER1 = PERSTR
      PER2 = dim([F:BLM]CMMLED)-1
     Elsif J=FIYEND
      PER1 = 1
      PER2 = PEREND
     Else
      PER1 = 1
      PER2 = dim([F:BLM]CMMLED)-1
     Endif
     MTCMM += SIGN*sum([F:BLM]CMMLED(PER1..PER2))
     MTPRP += SIGN*sum([F:BLM]CMMPRPLED(PER1..PER2))
   Endcase
  Next
  Filter [BLM]
 Next

Else

 Raz CRITPYR, IPYR
 Call ADDCRIT(ACTX,CRITPYR,IPYR,"LEDTYP",'LEDTYP='+num$([L]LEDTYP)," & ",[L]ASTATUS) From ASYRFNC
 Call ADDCRIT(ACTX,CRITPYR,IPYR,"CPY",'CPY="'+COMPANY+'"'," & ",[L]ASTATUS) From ASYRFNC
 Call ADDCRIT(ACTX,CRITPYR,IPYR,"FCY",'FCY="'+BUDFCY+'"'," & ",[L]ASTATUS) From ASYRFNC
 Call ADDCRIT(ACTX,CRITPYR,IPYR,"COA",'COA="'+[L]COA+'"'," & ",[L]ASTATUS) From ASYRFNC
 Call ADDCRIT(ACTX,CRITPYR,IPYR,"BPR",'BPR=""'," & ",[L]ASTATUS) From ASYRFNC
 Call ADDCRIT(ACTX,CRITPYR,IPYR,"FIY",'FIY>='+num$(FIYSTR)," & ",[L]ASTATUS) From ASYRFNC
 Call ADDCRIT(ACTX,CRITPYR,IPYR,"FIY",'FIY<='+num$(FIYEND)," & ",[L]ASTATUS) From ASYRFNC

 If [F:BUP]PYMACC=""
  Call ADDCRIT(ACTX,CRITPYR,IPYR,"ACC",'ACC="'+BUDACC+'"'," & ") From ASYRFNC
 Endif

 Gosub GENLNK From TRTVISBUD
 Gosub LIENS From =FILPROG

 # Analytical balance
 For [LBLA]CLE(1)
  ACCSIGN = [F:BLA]ACC
  PLAN = [F:BLA]COA
  Gosub SEARCH_SIGN From TRTVISBUD
  For [LBLA]CLE
   Case [F:BUP]BUDCTL
    When 2   : # Annual control
     MTBLA += SIGN*(sum([F:BLA]DEBLED)-sum([F:BLA]CDTLED)-[F:BLA]DEBLED(0)+[F:BLA]CDTLED(0))
    When 3   : # Period control
     MTBLA += SIGN*(sum([F:BLA]DEBLED(PER)-[F:BLA]CDTLED(PER)))
    When 4,5 : # Sliding and accumulated control
     If [F:BLA]FIY=FIYSTR & [F:BLA]FIY=FIYEND
      PER1 = PERSTR
      PER2 = PEREND
     Elsif [F:BLA]FIY=FIYSTR
      PER1 = PERSTR
      PER2 = dim([F:BLA]CDTLED)-1
     Elsif [F:BLA]FIY=FIYEND
      PER1 = 1
      PER2 = PEREND
     Else
      PER1 = 1
      PER2 = dim([F:BLA]CDTLED)-1
     Endif
      MTBLA += SIGN*(sum([F:BLA]DEBLED(PER1..PER2))-sum([F:BLA]CDTLED(PER1..PER2)))
   Endcase
  Next
 Next

 # Quantity balance
 For [LBLQ]CLE(1)
  ACCSIGN = [F:BLQ]ACC
  PLAN = [F:BLQ]COA
  Gosub SEARCH_SIGN From TRTVISBUD
  For [LBLQ]CLE
   Case [F:BUP]BUDCTL
    When 2   : # Annual control
     QTBLA += SIGN*(sum([F:BLQ]QTY)-[F:BLQ]QTY(0))
     QTCMM += SIGN*(sum([F:BLQ]QTYCMM)-[F:BLQ]QTYCMM(0))
     QTPRP += SIGN*(sum([F:BLQ]QTYPRP)-[F:BLQ]QTYPRP(0))
    When 3   : # Period control
     QTBLA += SIGN*sum([F:BLQ]QTY(PER))
     QTCMM += SIGN*sum([F:BLQ]QTYCMM(PER))
     QTPRP += SIGN*sum([F:BLQ]QTYPRP(PER))
    When 4,5 : # Sliding and accumulated control
     If [F:BLQ]FIY=FIYSTR & [F:BLQ]FIY=FIYEND
      PER1 = PERSTR
      PER2 = PEREND
     Elsif [F:BLQ]FIY=FIYSTR
      PER1 = PERSTR
      PER2 = dim([F:BLQ]QTY)-1
     Elsif [F:BLQ]FIY=FIYEND
      PER1 = 1
      PER2 = PEREND
     Else
      PER1 = 1
      PER2 = dim([F:BLQ]QTY)-1
     Endif
     QTBLA += SIGN*sum([F:BLQ]QTY(PER1..PER2))
     QTCMM += SIGN*sum([F:BLQ]QTYCMM(PER1..PER2))
     QTPRP += SIGN*sum([F:BLQ]QTYPRP(PER1..PER2))
   Endcase
  Next
 Next

 # Commitment and pre commitment balance
 For [LBLM]CLE(1)
  ACCSIGN = [F:BLM]ACC
  PLAN = [F:BLM]COA
  Gosub SEARCH_SIGN From TRTVISBUD
  For [LBLM]CLE
   Case [F:BUP]BUDCTL
    When 2   : # Annual control
     MTCMM += SIGN*(sum([F:BLM]CMMLED)-[F:BLM]CMMLED(0))
     MTPRP += SIGN*(sum([F:BLM]CMMPRPLED)-[F:BLM]CMMPRPLED(0))
    When 3   : # Period control
     MTCMM += SIGN*[F:BLM]CMMLED(PER)
     MTPRP += SIGN*[F:BLM]CMMPRPLED(PER)
    When 4,5 : # Sliding and accumulated control
     If [F:BLM]FIY=FIYSTR & [F:BLM]FIY=FIYEND
      PER1 = PERSTR
      PER2 = PEREND
     Elsif [F:BLM]FIY=FIYSTR
      PER1 = PERSTR
      PER2 = dim([F:BLM]CMMLED)-1
     Elsif [F:BLM]FIY=FIYEND
      PER1 = 1
      PER2 = PEREND
     Else
      PER1 = 1
      PER2 = dim([F:BLM]CMMLED)-1
     Endif
     MTCMM += SIGN*sum([F:BLM]CMMLED(PER1..PER2))
     MTPRP += SIGN*sum([F:BLM]CMMPRPLED(PER1..PER2))
   Endcase
  Next
 Next
 If FILSRC<>""
  Call EFFACE(FILSRC,STAT) From ORDSYS
  Call EFFACE(FILADX,STAT) From ORDSYS
 Endif
Endif
Return

#################################################################
$INIVAR_LEDBUDCCE
Call LEC_LED([L]LEDCOD) From CPTLEC
Raz LEDBUDCCE
For I=1 To dim([F:BUP]DIE)
 If [F:BUP]DIE(I-1)<>""
  J = find([F:BUP]DIE(I-1),[F:LED]DIE(0..[F:LED]DIENBR-1))
  If J : LEDBUDCCE(J-1) = BUDCCE(I) : NUMCCE(I) = J : Endif
 Endif
Next
Return

#####################################################################################################################
## _IS_BUDOVR
#####################################################################################################################
#**
#*
#*
#* @private
#* @param MONTANT
#* @param QUANTITE
#* @param DEVISE
#* @param DEVLED
#* @param DEVBUD
#* @param DEVCPY
#* @param TYPCOURS
#* @param DATCOURS
#* @param MTBUD
#* @param QTBUD
#* @param MTBLA
#* @param QTBLA
#* @param MTCMM
#* @param QTCMM
#* @param MTPRP
#* @param QTPRP
#* @param BUDCMM
#* @param BUDPRE
#* @param BUDCTLAMT
#* @param BUDCTLQTY
#* @param BUDPRCAMT
#* @param BUDPRCQTY
#*!
Funprog _IS_BUDOVR(ACTX,MONTANT,QUANTITE,DEVISE,DEVLED,DEVBUD,DEVCPY,TYPCOURS,DATCOURS,MTBUD,QTBUD,MTBLA,QTBLA
&                 ,MTCMM,QTCMM,MTPRP,QTPRP,BUDCMM,BUDPRE,BUDCTLAMT,BUDCTLQTY,BUDPRCAMT,BUDPRCQTY)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Decimal MONTANT    : # Amount asked
Value    Decimal QUANTITE   : # Quantity asked
Value    Char    DEVISE     : # Currency of the MONTANT variable
Value    Char    DEVLED     : # Ledger currency
Value    Char    DEVBUD     : # Currency of the budget
Value    Char    DEVCPY     : # Company currency
Value    Integer TYPCOURS   : # Currency rate type
Value    Date    DATCOURS   : # Date currency rate
Value    Decimal MTBUD      : # Budget amount
Value    Decimal QTBUD      : # Budget quantity
Value    Decimal MTBLA      : # Amount in the balance
Value    Decimal QTBLA      : # Quantity in the balance
Value    Decimal MTCMM      : # Commitment amount
Value    Decimal QTCMM      : # Commitment quantity
Value    Decimal MTPRP      : # Pre commitment amount
Value    Decimal QTPRP      : # Pre commitment quantity
Value    Tinyint BUDCMM     : # Commitment (AML 1)
Value    Tinyint BUDPRE     : # Pre commitment (AML 1)
Value    Decimal BUDCTLAMT  : # Control the amount O/N
Value    Tinyint BUDCTLQTY  : # control the quantity O/N
Value    Decimal BUDPRCAMT  : # Tolerance percentage for amount
Value    Decimal BUDPRCQTY  : # Tolerance percentage for quantity

Local Decimal MTREL , QTREL , MTNEW
Local Integer STAT

If adxtyp=33
 GPOINT = "BEFBUDCTL" : Gosub ENTREE From EXEFNC
Endif

# Convert the budget amount
Call CONVERT(ACTX,DEVBUD,DEVLED,DEVCPY,TYPCOURS,DATCOURS,MTBUD,MTBUD,STAT) From TRTDEV_SYRA
If STAT : End 3 : Endif
# Convert the asked amount
Call CONVERT(ACTX,DEVISE,DEVLED,DEVCPY,TYPCOURS,DATCOURS,MONTANT,MTNEW,STAT) From TRTDEV_SYRA
If STAT : End 4 : Endif

MTREL = MTBLA
QTREL = QTBLA
If BUDCMM
 MTREL += MTCMM
 QTREL += QTCMM
Endif

If BUDPRE
 MTREL += MTPRP
 QTREL += QTPRP
Endif

If BUDCTLAMT
 If MTREL+MTNEW>MTBUD*(1+BUDPRCAMT/100)
  End 1
 Endif
Endif

If BUDCTLQTY & [F:BUP]QTY=2
 If QTREL+QUANTITE>QTBUD*(1+BUDPRCQTY/100)
  End 2
 Endif
Endif
End 0

########################################################################################################
## Update pre commitment or commitment amount in the BUD table
########################################################################################################
$UPD_GDD
Gosub DECL_VAR_GDD
Call GET_BUOINF(DIE,CCE,SITE,BUDCOD,ENTITY,DIEENT,ENVELOP,DIEENV,DIMENSION3,DIE3,OK,YEAFLG,SITBUD) From FINBUO_SYRA
If !OK : Return : Endif

Raz [F:BUD]
Call LEC_LED([L]LEDCOD) From CPTLEC
If DIEENT>0
 I = find(DIE(DIEENT),[F:LED]DIE(0..[F:LED]DIENBR-1))
 Assign "[F:BUD]CCE"+num$(I) With ENTITY
Endif
If DIEENV>0
 I = find(DIE(DIEENV),[F:LED]DIE(0..[F:LED]DIENBR-1))
 Assign "[F:BUD]CCE"+num$(I) With ENVELOP
Endif
If DIE3>0
 I = find(DIE(DIE3),[F:LED]DIE(0..[F:LED]DIENBR-1))
 Assign "[F:BUD]CCE"+num$(I) With DIMENSION3
Endif
[F:BUD]LEDTYP = [L]LEDTYP
[F:BUD]BUD    = BUDCOD
[F:BUD]CPY    = COMPANY
[F:BUD]FCY    = SITBUD
[F:BUD]FIY    = [L]FIY
[F:BUD]VER    = "1"
[F:BUD]ACC    = [L]ACC
Read [BUD]BUD0=
If fstat=1
 Call RSTA("BUD",num$([F:BUD]ACCNUM),ACTX,[L]ASTATUS) From ASYRSUB : Return
Elsif fstat=0
 If CMMTYP=1      # Pre commitment
  [F:BUD]AMTCMMPRP += SIGN*SENS*AMTLED
 Elsif CMMTYP=2   # Commitment
  [F:BUD]AMTCMM    += SIGN*SENS*AMTLED
 Endif
 Rewrite [BUD]
 If fstat
  Call FSTA("BUD",ACTX,[L]ASTATUS) From ASYRSUB : Return
 Endif
Endif
Return

########################################################################################################
## Update BLACMM and BLAQTY tables
########################################################################################################
$BAL_ANA_CMM
BALFCY = ""
Gosub UPD_BLM
If QTY<>0
 Gosub UPD_BLQ
Endif
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

BALFCY = SITE
Gosub UPD_BLM
If QTY<>0
 Gosub UPD_BLQ
Endif
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

########################################################################################################
# Update analytical balance of commitment
$UPD_BLM
Readlock [BLM]BLM0 = LEDTYP;COMPANY;BALFCY;FIY;ACC;BALBPR;BALSEC1;BALSEC2;BALSEC3;BALSEC4;BALSEC5;BALSEC6;BALSEC7;BALSEC8;BALSEC9;CUR

If fstat=1
 Call RSTA("BLM",num$(LEDTYP)-COMPANY-BALFCY-num$(FIY)-ACC-BALBPR-BALSEC1-BALSEC2-BALSEC3-BALSEC4-
&          BALSEC5-BALSEC6-BALSEC7-BALSEC8-BALSEC9-CUR,ACTX,[L]ASTATUS) From ASYRSUB
 Return
Elsif fstat
 Raz [F:BLM]
 [F:BLM]LEDTYP  = LEDTYP
 [F:BLM]CPY     = COMPANY
 [F:BLM]FCY     = BALFCY
 [F:BLM]FIY     = FIY
 [F:BLM]BPR     = BALBPR
 [F:BLM]ACC     = ACC
 [F:BLM]CCE1    = BALSEC1
 [F:BLM]CCE2    = BALSEC2
 [F:BLM]CCE3    = BALSEC3
 [F:BLM]CCE4    = BALSEC4
 [F:BLM]CCE5    = BALSEC5
 [F:BLM]CCE6    = BALSEC6
 [F:BLM]CCE7    = BALSEC7
 [F:BLM]CCE8    = BALSEC8
 [F:BLM]CCE9    = BALSEC9
 [F:BLM]CUR     = CUR
 [F:BLM]ACCNUM  = uniqid([F:BLM])
 [F:BLM]LED     = LEDCOD
 [F:BLM]CURLED  = LEDCUR
 [F:BLM]COA     = COA
 For I=1 To dim([F:BLM]DIE)
  [F:BLM]DIE(I-1) = evalue("BALDIE"+num$(I))
 Next
 Gosub LOAD_BLM
 Write [BLM]
Else
 Gosub LOAD_BLM
 Rewrite [BLM]
Endif
If fstat
 Call FSTA("BLM",ACTX,[L]ASTATUS) From ASYRSUB : Return
Endif
Return

$LOAD_BLM
If CMMTYP=1 :# Pre commitment
 [F:BLM]CMMPRP(PERIOD)    += SIGN*SENS*AMTCUR
 [F:BLM]CMMPRPLED(PERIOD) += SIGN*SENS*AMTLED
Elsif CMMTYP=2 :# Commitment
 [F:BLM]CMM(PERIOD)    += SIGN*SENS*AMTCUR
 [F:BLM]CMMLED(PERIOD) += SIGN*SENS*AMTLED
Endif
Return


########################################################################################################
# Update analytical balance of quantity
$UPD_BLQ
Readlock [BLQ]BLQ0 = LEDTYP;COMPANY;BALFCY;FIY;ACC;BALBPR;BALSEC1;BALSEC2;BALSEC3;BALSEC4;BALSEC5;BALSEC6;BALSEC7;BALSEC8;BALSEC9;CUR

If fstat=1
 Call RSTA("BLQ",num$(LEDTYP)-COMPANY-BALFCY-num$(FIY)-ACC-BALBPR-BALSEC1-BALSEC2-BALSEC3-BALSEC4-
&          BALSEC5-BALSEC6-BALSEC7-BALSEC8-BALSEC9-CUR,ACTX,[L]ASTATUS) From ASYRSUB
 Return
Elsif fstat
 Raz [F:BLQ]
 [F:BLQ]LEDTYP  = LEDTYP
 [F:BLQ]CPY     = COMPANY
 [F:BLQ]FCY     = BALFCY
 [F:BLQ]FIY     = FIY
 [F:BLQ]BPR     = BALBPR
 [F:BLQ]ACC     = ACC
 [F:BLQ]CCE1    = BALSEC1
 [F:BLQ]CCE2    = BALSEC2
 [F:BLQ]CCE3    = BALSEC3
 [F:BLQ]CCE4    = BALSEC4
 [F:BLQ]CCE5    = BALSEC5
 [F:BLQ]CCE6    = BALSEC6
 [F:BLQ]CCE7    = BALSEC7
 [F:BLQ]CCE8    = BALSEC8
 [F:BLQ]CCE9    = BALSEC9
 [F:BLQ]CUR     = CUR
 [F:BLQ]ACCNUM  = uniqid([F:BLQ])
 [F:BLQ]LED     = LEDCOD
 [F:BLQ]COA     = COA
 [F:BLQ]UOM     = UOM
 For I=1 To dim([F:BLQ]DIE)
  [F:BLQ]DIE(I-1) = evalue("BALDIE"+num$(I))
 Next
 Gosub LOAD_BLQ
 Write [BLQ]
Else
 Gosub LOAD_BLQ
 Rewrite [BLQ]
Endif
If fstat
 Call FSTA("BLQ",ACTX,[L]ASTATUS) From ASYRSUB : Return
Endif
Return

$LOAD_BLQ
If CMMTYP=1    : # Pre commitment
 [F:BLQ]QTYPRP(PERIOD) += SIGN*SENS*QTY
Elsif CMMTYP=2 : # Commitment
 [F:BLQ]QTYCMM(PERIOD) += SIGN*SENS*QTY
Endif
Return

