#<AdxTL>@(#)2.0.0.0 $Revision$
#########################################################################################
# Routines d'écritures des segments EDI
# 
# Utilisation
# . début de programme : 
#     faire un Gosub DECLARE From FICEDI (variables des routines)
#
# . pour l'écriture du segment UNA :
#     faire un appel à ECRIT_UNA From FICEDI
#
# . écriture du segment UNB de début d'interchange :
#     alimenter GRPDEB et GRPFIN (groupes début et fin) avec la valeur 0, et CODSEG à "UNB"
#     faire un appel à ECRIT_GRP From FICEDI
#     au retour, remettre à blanc CODSEG, et alimenter SEGEXC(0) et (1) avec "UNA" et "UNB"
#
# . écriture des groupes de segments :
#     alimenter GRPDEB et GRPFIN, 
#     et faire un appel à ECRIT_GRP
# 
#########################################################################################
End


$ECRIT_GRP
For [EDM]EDM0(4) Where GRP>=GRPDEB & GRP<=GRPFIN & !find(SEG,SEGEXC) & (CODSEG="" | SEG=CODSEG)
 # Les conditions sont saisies au niveau de l'occurrence des groupes...
 If [F:EDM]GRPCND<>""
  Onerrgo ERR_EVAL : CAS=2
  COND = evalue([F:EDM]GRPCND)
 Else
  COND = 1
 Endif
 If COND
   For [EDM]EDM0(7)
    # ...et au niveau de l'occurrence des segments
    If [F:EDM]SEGCND<>""
      Onerrgo ERR_EVAL : CAS=2
      COND = evalue([F:EDM]SEGCND)
    Else
      COND = 1
    Endif
    If COND
      Gosub ECRIT_SEG
    Endif
   Next
 Endif
Next
Return

$ECRIT_SEG
Raz SEGMENT, COMPO, COMPOSITE, NBLIG
SEGMENT = [F:EDM]SEG
For [EDM]EDM0
  NBLIG += 1
  If [F:EDM]CPS=""
    Gosub ADDCPS
    Gosub TRTZONE
    COMPOSITE = ZONE
  Elsif [F:EDM]CPS=[F:EDM]DATA
    Gosub ADDCPS
    If [F:EDM]STA=6 : COMPO = [F:EDM]CPS : Endif
  Elsif [F:EDM]CPS<>COMPO
    Gosub TRTZONE
    COMPOSITE += ZONE + SEP(1)
  Endif
Next
If COMPOSITE<>""
  SEGMENT += SEP(2) + COMPOSITE
Endif
While find(right$(SEGMENT,len(SEGMENT)),SEP(1),SEP(2))
  SEGMENT = left$(SEGMENT,len(SEGMENT)-1)
Wend
SEGMENT += SEP(6)
Wrseq SEGMENT Using [TRA]
#Wrseq SEGMENT, Using [TRA]
NBSEG += 1 
Return

$ADDCPS
If NBLIG>1 : SEGMENT += SEP(2) : Endif
If COMPOSITE<>"" 
  While find(right$(COMPOSITE,len(COMPOSITE)),SEP(1),SEP(2))
    COMPOSITE = left$(COMPOSITE,len(COMPOSITE)-1)
  Wend
  SEGMENT += COMPOSITE
Endif
Raz COMPO, COMPOSITE
STACPS = [F:EDM]STA
Return

$TRTZONE
Raz ZONE
If [F:EDM]FRM<>""
 Onerrgo ERR_EVAL : CAS=1
 ZONE = num$(evalue([F:EDM]FRM))
 Case [F:EDM]SEG
  When "DTM" :   # Date
    If [F:EDM]DATA = "2380"
      Onerrgo ERR_EVAL : CAS=1
      ZONE = format$("YYYYMMDD",evalue([F:EDM]FRM))
    Endif
  When "MOA" :   # Montant monétaire
    If [F:EDM]DATA = "5004"
      If !instr(1,ZONE,SEP(3))   : # Séparateur de décimales
        ZONE = ctrans(ZONE,".",SEP(3))
        ZONE = ctrans(ZONE,",",SEP(3))
      Endif
    Endif
  When "NAD" :   # Adresse
    If [F:EDM]DATA = "3207"
      If ZONE<>""
        ZONE = vireblc(ZONE,2)
        Read [TCY]TCY0 = ZONE
        If !fstat & [F:TCY]ISO<>""
          ZONE = [F:TCY]ISO
        Endif
      Endif
    Endif
 Endcase
 # Caractères séparateurs
 If ZONE<>"" & [F:EDM]SEG<>"UNA" & [F:EDM]DATA<>"5004"
   Gosub CONV
 Endif
Endif
# Contrôles de présence et de longueur
If ZONE=""
  # 1,2 : obligatoire ou requis
  If find([F:EDM]STA,1,2) & find(STACPS,1,2) & find([F:EDM]SEGSTA,1,2) & find([F:EDM]GRPSTA,1,2)
    GOK=0 : STA=10 : Gosub TRTERR : Return
  Endif
Else
  If len(ZONE)>[F:EDM]LONG 
    GOK=0 : STA=11 : Gosub TRTERR : Return
  Endif
Endif
Return

$ECRIT_UNA
Raz SEGMENT, I
SEGMENT = "UNA"
For [EDM]EDM0 Where GRP=0 & SEG="UNA" & !find(left$(DATA,1),"C","S")
  Raz ZONE
  If [F:EDM]FRM<>""
    Onerrgo ERR_EVAL : CAS=1
    ZONE = num$(evalue([F:EDM]FRM))
  Endif
  If len(ZONE)<>1
    GOK=0 : STA=11 : Gosub TRTERR : Break
  Endif
  I+=1
  SEP(I) = ZONE
  SEGMENT += ZONE
Next
Wrseq SEGMENT Using [TRA]
Return

$CONV
ZONE = vireblc(ctrans(ZONE),2)
# Caractère de déblocage = SEP(4)
For CAR = SEP(4), SEP(1), SEP(2), SEP(3), SEP(6)
 POS = 0
 Repeat 
   POS = instr(POS+1,ZONE,CAR)
   If POS
     ZONE = left$(ZONE,POS-1)+SEP(4)+right$(ZONE,POS)
     POS += 1
   Endif
 Until POS=0
Next CAR
Return

$ERR_EVAL
Onerrgo
Case CAS
 When 1 : STA=20   :# erreur en évaluation de zone
 When 2 : STA=22   :# erreur en évaluation de condition
Endcase
GOK=0 : Gosub TRTERR
Resume

$TRTERR
Case STA
 When 0  : MESSA = "|"+FICHIER+"|"
 When 1  : MESSA = mess(102,117,1)                    : # Remise inexistante
 When 2  : MESSA = mess(103,117,1)+":"-[F:TPY]PAYTYP  : # Pas de remise à faire
 When 3  : MESSA = mess(104,117,1)-"NUMFIL"           : # Erreur sur compteur
 When 4  : MESSA = "|"+DIR_FICBAN-"|:"-mess(9,141,1)  : # Répertoire inexistant
 When 5  : MESSA = mess(35,110,1)                     : # Erreur transactionnelle
 When 6  : MESSA = mess(10,100,1)                     : # Modification en cours sur un autre poste
 When 7  : MESSA = MESSA-mess(147,197,1)              : # Siret inexistant
 When 8  : MESSA = MESSA-mess(27,199,1)               : # RIB inexistant

 When 9  : MESSA = MESSA-":"-mess(9,136,1)            : # Paramétrage inexistant
 When 10 :   # Groupe... Occurrence... Segment... Donnée : Donnée obligatoire
  MESSA = mess(5,136,1)-num$([F:EDM]GRP)-mess(11,136,1)-num$([F:EDM]OCC)-mess(4,136,1)
  MESSA -= [F:EDM]SEG-mess(10,136,1)-[F:EDM]DATA-":"-mess(6,136,1)

 When 11 :   # Groupe... Occurrence... Segment... Donnée : Longueur incorrecte
  MESSA = mess(5,136,1)-num$([F:EDM]GRP)-mess(11,136,1)-num$([F:EDM]OCC)-mess(4,136,1)
  MESSA -= [F:EDM]SEG-mess(10,136,1)-[F:EDM]DATA-mess(7,136,1)

 When 20 :   # Groupe... Occurrence... Segment... Donnée... : Expression incorrecte :
  MESSA = mess(5,136,1)-num$([F:EDM]GRP)-mess(11,136,1)-num$([F:EDM]OCC)-mess(4,136,1)-[F:EDM]SEG
  MESSA -= mess(10,136,1)-[F:EDM]DATA-":"-mess(37,124,1)-":"-errmes$(errn)

 When 22 :   # Groupe... Occurrence... Evaluation de la condition... : 
  MESSA = mess(5,136,1)-num$([F:EDM]GRP)-mess(11,136,1)-num$([F:EDM]OCC)-":"
  MESSA -= mess(4,75,1)-'"'+toupper([F:EDM]GRPCND)+'"'-"\"-mess(37,124,1)-":"-errmes$(errn)
Endcase
Call ECR_TRACE(MESSA,(STA<>0)) From GESECRAN
Raz STA, MESSA
Return

$DECLARE
If clalev([F:EDM])=0 : Local File EDIFRM     [EDM] : Endif

Local Integer I, NBSEG, NBLIG, STA, GRPDEB, GRPFIN, COND, STACPS, POS, CAS
Local Char    SEGMENT(250), COMPO(4), MESSA(200), ZONE(50), CODSEG(3), COMPOSITE(150), CAR(1)
Local Char    SEGEXC(3)(10), SEP(1)(1..6)
Return

