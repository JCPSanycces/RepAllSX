Subprog MAJ
Local Char DOSVAL(GLONADS) , DOSREF(GLONADS) , DOSCOP(GLONADS)
Local Char MESSA (80)
DOSVAL = [F:ADS]DOSSIER
DOSREF = [F:ADS]DOSREF
DOSCOP = [F:ADS]DOSCOP
Gosub MAJSUP
End  #106236.en
###################################
# Issue 108760 - 2015-06-23 by SR : Corrigé lors de la revue de code
#$AMAJSUP
#Return
###################################
$MAJSUP
MESSSA ="Object selection texct updates"
If GINFO
 Call AFF_VLC(mess(93,125,1),MESSA) From GESECRAN
Endif

Call ECR_TRACE(MESSA,0) From GESECRAN
Call PATCH([L]DOSVAL) From UTIMAJAOB01                : # Object selection text updates

If GINFO
 Call AFF_VLC("","") From GESECRAN
Endif
Return



