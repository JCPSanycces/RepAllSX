Subprog UTIMAJAOB01(DOSSIER)
Value Char DOSSIER
Call PATCH(DOSSIER) From UTIMAJAOB01
End

#                                                         # hcb X3-38470 deb


#-------------------------------------------------------#
# STKITG     : MAJ des catégories:                      #
#             -Init PCKFLG  dans ITMCATEG               #
# Paramètres E : LDOS   = Dossier                       #
#-------------------------------------------------------#
Subprog STKITG(LDOS)
Value Char LDOS
#

#Call ECR_TRACE("Start trace : ITMCATEG / PCKFLG" ,0) From GESECRAN
#------- ITMCATEG [ITG] : Catégories articles ---------------------
If filinfo(filpath("FIL","ITMCATEG","fde",LDOS),0)>0
   Local File =LDOS+".ITMCATEG"   [ITG]
   Trbegin [ITG]
   For [ITG]
       [F:ITG]PCKFLG = 2
       If [F:ITG]SALFLG <> 2 &  [F:ITG]DLVFLG <> 2
          [F:ITG]PCKFLG    = 1
          [F:ITG]PCKSTKFLG = 1
          Raz [F:ITG]PCK
          Raz [F:ITG]PCKCAP
       Endif
       Rewrite [ITG]
   Next
   Commit
Endif
End
#                                                         # hcb X3-38470 fin

