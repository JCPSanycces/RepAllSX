#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################################################
# HCM V8 :
# To manage the filter by GCURLEG on the main process    : Already done by DBA
# To manage the filter on new concept of population      : Not yet
###################################################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","EXTRACT","EXTRACT",4,"") From GTRAITE
End

$ACTION

Case ACTION
 When "INIT"        : Gosub INIT
 When "EXEC"        : Gosub EXEC
 When "SORTIE"      : Gosub SORTIE
 When "CONTROLE"    : Gosub CONTROLE
 When "DEBUT"       : Gosub DEBUT                 :#81085
 When "BOUTON"      : Gosub BOUTON From TRTAUT    :#81085
Endcase
Return

$INIT
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
TIT = mess(67,125,1) #: Extraction données
TMP = 1
#81085
Local Mask EXTRACT [DIA]
Raz [M:DIA]
GCURLEG=GLEGFIL
Call FILL_TOTALS(GCURLEG)
Call LECMEMO("STD","[M:DIA]","ecu") From GMEMO
Call AFF_MEMO From DIVPAYE


Return


$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#81085
######################################################
$DEBUT
Affzo [DIA]
Setmok [DIA] With 0
Call AFF_MEMO From DIVPAYE
Return

###################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP=1
 TRA=1
Endif
Return

################################################
$EXEC
Local Integer I, J , NBDAT , OKSAL , EXISTE
Local Date    TBDAT(1..500)
Local Decimal TBSAL(1..500)
Local Decimal TBSAL1(1..500)
Local Decimal TBSAL2(1..500)
Local Decimal TBRUB(1..500)
Local Decimal TBRUB1(1..500)
Local Decimal TBRUB2(1..500)
Local Char    TBCMT (80)(1..500)
Local Char    SALAIRE(GLONVRA)(0..2)
Local Char    RUBSAL (GLONRUB)(0..2)
Local Char    CRITSAL(250) , CRITPAY1(250), CRITPAY2(250), CRITPAY3(250)
Local Char    CTR(GLONHRCTR)
If clalev([F:CPY])=0  : Local File COMPANY   [CPY]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY  [FCY]  : Endif
If clalev([F:VLA])=0  : Local File VALEUR    [VLA]  : Endif
If clalev([F:VLA1])=0 : Local File VALEUR    [VLA1] : Endif
If clalev([F:ADW])=0  : Local File ADOVAL    [ADW]  : Endif
If clalev([F:HSP])=0  : Local File HISTOPAYE [HSP]  : Endif
If clalev([F:RUB])=0  : Local File RUBRIQUE  [RUB]  : Endif
If clalev([F:CUM])=0  : Local File CUMUL     [CUM]  : Endif
If clalev([F:HRPOA])=0  : Local File POPULA    [HRPOA]  : Endif
If clalev([F:VEP])=0  : Local File VALEMP    [VEP]  : Endif
If clalev([F:VEP1])=0 : Local File VALEMP    [VEP1] : Endif

Gosub OUVRE From WPDEFTABLE

CRITSAL = '[F:CPY]LEG="'+GCURLEG+'"'
CRITSAL -= '& [F:ID]ENAFLG=2' :#Salarié Actif
If [M:DIA]ALLCPY<>2  #société
 CRITSAL -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2  #site
 CRITSAL -= '& [F:HRCTR]ETRFCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]MATDEB<>"" #borne début matricule
 CRITSAL -= '& [F:ID]REFNUM>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITSAL -= '& [F:ID]REFNUM<="'+[M:DIA]MATFIN+'"'
Endif
If [M:DIA]ALLSRV<>2  #service
 CRITSAL -= '& [F:HRCTR]ETRSRV = "'+[M:DIA]SRV+'"'
Endif
If [M:DIA]ALLPRF<>2  #profil
 CRITSAL -= '& [F:HRCTR]PROPRF = "'+[M:DIA]PRF+'"'
Endif

CRITPAY3 = "1=1"
If [M:DIA]DATPAYSTR<>[0/0/0]
 CRITPAY3 -= "& [F:HSP]DAT>=["+format$(GFMD,[M:DIA]DATPAYSTR)+"]"
Endif
If [M:DIA]DATPAYEND<>[0/0/0]
 CRITPAY3 -= "& [F:HSP]DAT<=["+format$(GFMD,[M:DIA]DATPAYEND)+"]"
Endif
If [M:DIA]SAL=2
 Gosub SALAIRE
Endif
If sum([M:DIA]CUM(0..[M:DIA]NBCUM-1))>[M:DIA]NBCUM
 Gosub HISTO
Endif

Return

################################################################################
## Evolution des salaires
################################################################################
$SALAIRE
CRITPAY1 = "1=1"
If [M:DIA]DATPAYSTR<>[0/0/0]
 CRITPAY1 -= "& [F:VLA]DAT>=["+format$(GFMD,[M:DIA]DATPAYSTR)+"]"
Endif
If [M:DIA]DATPAYEND<>[0/0/0]
 CRITPAY1 -= "& [F:VLA]DAT<=["+format$(GFMD,[M:DIA]DATPAYEND)+"]"
Endif

CRITPAY2 = "1=1"
If [M:DIA]DATPAYSTR<>[0/0/0]
 CRITPAY2 -= "& [F:VLA1]DAT>=["+format$(GFMD,[M:DIA]DATPAYSTR)+"]"
Endif
If [M:DIA]DATPAYEND<>[0/0/0]
 CRITPAY2 -= "& [F:VLA1]DAT<=["+format$(GFMD,[M:DIA]DATPAYEND)+"]"
Endif

If [M:DIA]POP<>""
 Link [VLA] With
&   [ID]ID0 = [F:VLA]EMP
& , [VEP]VEP5 = [F:VLA]BUL
& , [HRCTR]CTR0(2) = [F:VEP]EMP;[F:VEP]CTRNUM;[F:VEP]CTRDAT
& , [FCY]FCY0 = [F:HRCTR]ETRFCY
& , [CPY]CPY0 = [F:FCY]LEGCPY
& , [HRPOA]POA0 = [M:DIA]POP;[F:ID]REFNUM
&   As [LVLA]
&   Where evalue(CRITSAL) & evalue(CRITPAY1) & [F:HRPOA]REFNUM<>""
&   Order By Key CLE = [F:VLA]TYP;[F:VLA]CPY;[F:VLA]FCY;[F:VLA]EMP;[F:HRCTR]CTRNUM

Else

 Link [VLA] With
&   [ID]ID0 = [F:VLA]EMP
& , [VEP]VEP5 = [F:VLA]BUL
& , [HRCTR]CTR0(2) = [F:VEP]EMP;[F:VEP]CTRNUM;[F:VEP]CTRDAT
& , [FCY]FCY0 = [F:HRCTR]ETRFCY
& , [CPY]CPY0 = [F:FCY]LEGCPY
&   As [LVLA]
&   Where evalue(CRITSAL) & evalue(CRITPAY1) & [F:VLA]EMP<>""
&   Order By Key CLE = [F:VLA]TYP;[F:VLA]CPY;[F:VLA]FCY;[F:VLA]EMP;[F:HRCTR]CTRNUM

Endif

#JASMI - 2017-10-15 - X3-59837 - START
Call PARAM(GCURLEG,"VARSAL" ,SALAIRE(0)) From ADOVAL
Call PARAM(GCURLEG,"VARSAL2",SALAIRE(1)) From ADOVAL
Call PARAM(GCURLEG,"VARSAL3",SALAIRE(2)) From ADOVAL
Call PARAM(GCURLEG,"RUBSAL" ,RUBSAL(0)) From ADOVAL
Call PARAM(GCURLEG,"RUBSAL2",RUBSAL(1)) From ADOVAL
Call PARAM(GCURLEG,"RUBSAL3",RUBSAL(2)) From ADOVAL
#JASMI - 2017-10-15 - X3-59837 - END

Link [VLA1] With
&  [VEP1]VEP5 = [F:VLA1]BUL
&   As [VVLA]
&   Where TYP=4 & CPY="" & FCY="" & evalue(CRITPAY2)

#JASMI - 2017-10-15 - X3-59837 - START
#Call PARAM([VLA1]LEG,"VARSAL" ,SALAIRE(0)) From ADOVAL
#Call PARAM([VLA1]LEG,"VARSAL2",SALAIRE(1)) From ADOVAL
#Call PARAM([VLA1]LEG,"VARSAL3",SALAIRE(2)) From ADOVAL
#Call PARAM([VLA1]LEG,"RUBSAL" ,RUBSAL(0)) From ADOVAL
#Call PARAM([VLA1]LEG,"RUBSAL2",RUBSAL(1)) From ADOVAL
#Call PARAM([VLA1]LEG,"RUBSAL3",RUBSAL(2)) From ADOVAL
#JASMI - 2017-10-15 - X3-59837 - END

Call DEBTRANS From GLOCK

#Boucle sur les contrats des employés
For [LVLA]CLE(5)
 OKSAL = 1
 Call CONTROLE([F:LVLA]EMP,datesyst,[F:HRCTR]CTRNUM,[M:DIA]CRI,OKSAL,1) From DIVPAYE
 If OKSAL
  NBDAT = 0
  Gosub RECUP
  #Boucle sur les paramètres
  For J=0 To 2
   If SALAIRE(J)<>"" :  Gosub VARSAL : Endif #Variables
   If RUBSAL (J)<>"" :  Gosub RUBSAL : Endif #Rubriques
  Next
  Gosub TRIER
  Gosub TR1
 Endif
Next
Return

#Récupération des lignes existantes
$RECUP
NBDAT=0 : Raz TBDAT : Raz TBSAL : Raz TBSAL1 : Raz TBSAL2 : Raz TBRUB : Raz TBRUB1 : Raz TBRUB2
Raz TBCMT
For [SAL]SAL0 Where REFNUM=[F:LVLA]EMP & CTRNUM=[F:HRCTR]CTRNUM & ([F:SAL]SALDAT<[M:DIA]DATPAYSTR | [F:SAL]SALDAT>[M:DIA]DATPAYEND)
 If (SALAIRE(0)<>"" & [F:SAL]SALVAL <>0) |
&   (SALAIRE(1)<>"" & [F:SAL]SALVAL1<>0) |
&   (SALAIRE(2)<>"" & [F:SAL]SALVAL2<>0) |
&   (RUBSAL (0)<>"" & [F:SAL]SALRUB <>0) |
&   (RUBSAL (1)<>"" & [F:SAL]SALRUB1<>0) |
&   (RUBSAL (2)<>"" & [F:SAL]SALRUB2<>0)
  NBDAT += 1
  TBDAT(NBDAT)  = [F:SAL]SALDAT
  TBSAL(NBDAT)  = [F:SAL]SALVAL
  TBSAL1(NBDAT) = [F:SAL]SALVAL1
  TBSAL2(NBDAT) = [F:SAL]SALVAL2
  TBRUB(NBDAT)  = [F:SAL]SALRUB
  TBRUB1(NBDAT) = [F:SAL]SALRUB1
  TBRUB2(NBDAT) = [F:SAL]SALRUB2
  TBCMT(NBDAT)  = [F:SAL]SALGRD
 Endif
Next
Return

$TRIER
Sorta NBDAT TBDAT,TBSAL,TBSAL1,TBSAL2,TBRUB,TBRUB1,TBRUB2,TBCMT  Order By TBDAT(indice+1)
I = 2
While I<=NBDAT
 If TBSAL(I)=TBSAL(I-1) & TBSAL1(I)=TBSAL1(I-1) & TBSAL2(I)=TBSAL2(I-1) &
&   TBRUB(I)=TBRUB(I-1) & TBRUB1(I)=TBRUB1(I-1) & TBRUB2(I)=TBRUB2(I-1) & TBCMT(I)=TBCMT(I-1)
  Dela I,1,NBDAT TBDAT,TBSAL, TBSAL1, TBSAL2,TBRUB, TBRUB1, TBRUB2, TBCMT
  NBDAT -= 1
 Else
  I += 1
 Endif
Wend
Return

########################################
$VARSAL
For [VVLA] Where [F:VLA1]EMP=[F:HRCTR]REFNUM & [F:VLA1]VARCOD=SALAIRE(J) & [F:VEP1]CTRNUM=[F:HRCTR]CTRNUM
 If [F:VLA1]VARVAL<>0
  K=find([F:VLA1]DAT,TBDAT(1..NBDAT))
  If !K
   NBDAT += 1
   TBDAT(NBDAT) = [F:VLA1]DAT
   Case J
    When 0 : TBSAL(NBDAT)  = [F:VLA1]VARVAL
    When 1 : TBSAL1(NBDAT) = [F:VLA1]VARVAL
    When 2 : TBSAL2(NBDAT) = [F:VLA1]VARVAL
   Endcase
  Else
   Case J
    When 0 : TBSAL(K)  = [F:VLA1]VARVAL
    When 1 : TBSAL1(K) = [F:VLA1]VARVAL
    When 2 : TBSAL2(K) = [F:VLA1]VARVAL
   Endcase
  Endif
 Endif
Next

Return


########################################
$RUBSAL
For [HSP]HSP1 Where EMP=[F:HRCTR]REFNUM & evalue(CRITPAY3) & RUB=RUBSAL(J) & (TYP=1 | TYP=7) & CTRNUM=[F:HRCTR]CTRNUM
 If [F:HSP]AMT<>0
  K=find([F:HSP]DAT,TBDAT(1..NBDAT))
  If !K
   NBDAT += 1
   TBDAT(NBDAT) = [F:HSP]DAT
   Case J
    When 0 : TBRUB(NBDAT)  = [F:HSP]AMT
    When 1 : TBRUB1(NBDAT) = [F:HSP]AMT
    When 2 : TBRUB2(NBDAT) = [F:HSP]AMT
   Endcase
   #mess(107,2281,1) : Avec régularisation
   If [F:HSP]TYP=7 : TBCMT(NBDAT) = mess(107,10935,1)  : Endif
  Else
   Case J
    When 0 : TBRUB(K)  += [F:HSP]AMT
    When 1 : TBRUB1(K) += [F:HSP]AMT
    When 2 : TBRUB2(K) += [F:HSP]AMT
   Endcase
   #mess(107,2281,1) : Avec régularisation
   If [F:HSP]TYP=7 : TBCMT(K) = mess(107,10935,1)  : Endif
  Endif
 Endif
Next
Return

########################################
$TR1
GOK = 1
Trbegin [SAL]
 Delete [SAL] Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM
 If fstat=1
  GOK = -1 : GLOCK = "$EMPLOSAL"-[F:HRCTR]REFNUM-[F:HRCTR]CTRNUM : Goto AB_TR
 Endif
 For I=1 To NBDAT
  Raz [F:SAL]
  [F:SAL]REFNUM  = [F:HRCTR]REFNUM
  [F:SAL]CTRNUM  = [F:HRCTR]CTRNUM
  [F:SAL]NUMLIG  = I
  [F:SAL]SALDAT  = TBDAT(I)
  [F:SAL]SALVAL  = TBSAL(I)
  [F:SAL]SALVAL1 = TBSAL1(I)
  [F:SAL]SALVAL2 = TBSAL2(I)
  [F:SAL]SALRUB  = TBRUB(I)
  [F:SAL]SALRUB1 = TBRUB1(I)
  [F:SAL]SALRUB2 = TBRUB2(I)
  [F:SAL]SALGRD  = TBCMT(I)
  [F:SAL]CREDAT  = date$
  [F:SAL]CREUSR  = GUSER
  [F:SAL]CRETIM  = time
  Write [SAL]
  If fstat
   GOK = 0 : Call FSTA("SAL") From GLOCK : Break
  Endif
 Next I
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR
 Endif
 Readlock [ID]ID0 = [F:ID]REFNUM
 If fstat=1
  GOK = -1 : GLOCK = "$EMPLOID"-[F:ID]REFNUM : Goto ROLL_TR1
 Elsif fstat
  GOK = 0 : Call RSTA("ID",[F:ID]REFNUM) From GLOCK : Goto AB_TR
 Endif
 [F:ID]NBRSAL = NBDAT
 Rewrite [ID]
 If fstat
  GOK = 0 : Call FSTA("ID") From GLOCK : Goto AB_TR
 Endif
Commit
Return

$AB_TR
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

################################################################################
## Récup historique
################################################################################
$HISTO

If [M:DIA]POP<>""
 Link [EPC] With
&   [ID]ID0 = [F:EPC]REFNUM
& , [HRCTR]CTR0(2) = [F:EPC]REFNUM;[F:EPC]CTRNUM
& , [FCY]FCY0 = [F:HRCTR]ETRFCY
& , [CPY]CPY0 = [F:FCY]LEGCPY
& , [HRPOA]POA0 = [M:DIA]POP;[F:ID]REFNUM
&   As [LEPC]
&   Where evalue(CRITSAL) & [F:HRPOA]REFNUM<>""
Else
 Link [EPC] With
&   [ID]ID0 = [F:EPC]REFNUM
& , [HRCTR]CTR0(2) = [F:EPC]REFNUM;[F:EPC]CTRNUM
& , [FCY]FCY0 = [F:HRCTR]ETRFCY
& , [CPY]CPY0 = [F:FCY]LEGCPY
&   As [LEPC]
&   Where evalue(CRITSAL)
Endif

If [M:DIA]POP<>""
 Link [HRCTR] With
&  [ID]ID0   = [F:HRCTR]REFNUM
&, [FCY]FCY0 = [F:HRCTR]ETRFCY
&, [CPY]CPY0 = [F:FCY]LEGCPY
&, [HRPOA]POA0 = [M:DIA]POP;[F:ID]REFNUM
&  As [LCTR]
&  Where evalue(CRITSAL) & [F:HRPOA]REFNUM<>""
Else
 Link [HRCTR] With
&  [ID]ID0   = [F:HRCTR]REFNUM
&, [FCY]FCY0 = [F:HRCTR]ETRFCY
&, [CPY]CPY0 = [F:FCY]LEGCPY
&  As [LCTR]
&  Where evalue(CRITSAL)
Endif


Call DEBTRANS From GLOCK
Gosub TR2

For I=0 To [M:DIA]NBCUM-1
  If [M:DIA]CUM(I)=2
    ## Parcours des rubriques de paie qui se déversent dans les cumuls clients
    Filter [RUB] Where CUMNUMADI=[M:DIA]CODCUM(I) and LEG=GCURLEG
    For [RUB]
      Call DEBTRANS From GLOCK
      Gosub TR3
    Next
    Filter [RUB]
    ## Parcours des cumuls de paie qui se déversent dans les cumuls clients
    Filter [CUM] Where CUMNUMADI=[M:DIA]CODCUM(I) and LEG=GCURLEG
    For [CUM]
      Call DEBTRANS From GLOCK
      Gosub TR4
    Next
    Filter [CUM]
  Endif
Next

### Parcours des rubriques de paie qui se déversent dans les cumuls clients
#For [RUB]RUB0 Where CUMNUMADI<>"" and LEG=GCURLEG
#  For I=0 To [M:DIA]NBCUM-1
#    If [M:DIA]CODCUM(I)=[F:RUB]CUMNUMADI
#     If [M:DIA]CUM(I)=2
#      Call DEBTRANS From GLOCK
#      Gosub TR3
#     Endif
#     Break
#    Endif
#  Next
#Next

## Parcours des cumuls de paie qui se déversent dans les cumuls clients
#For [CUM]CUM0 Where CUMNUM>1 and LEG=GCURLEG
# If [M:DIA]CUM([F:CUM]CUMNUM-2)=2
#  Call DEBTRANS From GLOCK
#  Gosub TR4
# Endif
#Next
Return

$TR2
## Raz table EMPLOCUM
GOK = 1
Trbegin [EPC]
 For [LEPC]EPC0
  OKSAL = 1
  Call CONTROLE([F:ID]REFNUM,datesyst,[F:HRCTR]CTRNUM,[M:DIA]CRI,OKSAL,1) From DIVPAYE
  If OKSAL
   Readlock [EPC] Curr
   If fstat=1
    GOK = -1 : GLOCK = "$EMPLOCUM"-[F:EPC]REFNUM-[F:EPC]CTRNUM : Break
   Endif
 #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 92 - START
# JASMI - 2014/03/27 - Requirement 95019 US 2547 - Start
#   If [M:DIA]CUM(0) = 2 : [F:EPC]CUM1 = 0 : Endif
#   If [M:DIA]CUM(1) = 2 : [F:EPC]CUM2 = 0 : Endif
#   If [M:DIA]CUM(2) = 2 : [F:EPC]CUM3 = 0 : Endif
#   If [M:DIA]CUM(3) = 2 : [F:EPC]CUM4 = 0 : Endif
#   If [M:DIA]CUM(4) = 2 : [F:EPC]CUM5 = 0 : Endif
#   If [M:DIA]CUM(5) = 2 : [F:EPC]CUM6 = 0 : Endif
#   If [M:DIA]CUM(6) = 2 : [F:EPC]CUM7 = 0 : Endif
#   If [M:DIA]CUM(7) = 2 : [F:EPC]CUM8 = 0 : Endif
#   If [M:DIA]CUM(8) = 2 : [F:EPC]CUM9 = 0 : Endif
   #If !LACT_KSA
   If !func DIVPAYE.IS_ZA_DEV()
     If [M:DIA]CUM(0) = 2 : [F:EPC]CUM1 = 0 : Endif
     If [M:DIA]CUM(1) = 2 : [F:EPC]CUM2 = 0 : Endif
     If [M:DIA]CUM(2) = 2 : [F:EPC]CUM3 = 0 : Endif
     If [M:DIA]CUM(3) = 2 : [F:EPC]CUM4 = 0 : Endif
     If [M:DIA]CUM(4) = 2 : [F:EPC]CUM5 = 0 : Endif
     If [M:DIA]CUM(5) = 2 : [F:EPC]CUM6 = 0 : Endif
     If [M:DIA]CUM(6) = 2 : [F:EPC]CUM7 = 0 : Endif
     If [M:DIA]CUM(7) = 2 : [F:EPC]CUM8 = 0 : Endif
     If [M:DIA]CUM(8) = 2 : [F:EPC]CUM9 = 0 : Endif
   Else
    If !func DIVPAYE.IS_KFR() & !func DIVPAYE.IS_KPO()
     #If !LACT_KFR & !LACT_KPO Then #Necessary for PAIEV6 folder where all activity codes are activated !
     #for South africa we want lines from 11 to 19
       If [M:DIA]CUM(0) = 2 : [F:EPC]CUM10 = 0 : Endif
       If [M:DIA]CUM(1) = 2 : [F:EPC]CUM11 = 0 : Endif
       If [M:DIA]CUM(2) = 2 : [F:EPC]CUM12 = 0 : Endif
       If [M:DIA]CUM(3) = 2 : [F:EPC]CUM13 = 0 : Endif
       If [M:DIA]CUM(4) = 2 : [F:EPC]CUM14 = 0 : Endif
       If [M:DIA]CUM(5) = 2 : [F:EPC]CUM15 = 0 : Endif
       If [M:DIA]CUM(6) = 2 : [F:EPC]CUM16 = 0 : Endif
       If [M:DIA]CUM(7) = 2 : [F:EPC]CUM17 = 0 : Endif
       If [M:DIA]CUM(8) = 2 : [F:EPC]CUM18 = 0 : Endif
     Else
       If [M:DIA]CUM(0) = 2 : [F:EPC]CUM1 = 0 : Endif
       If [M:DIA]CUM(1) = 2 : [F:EPC]CUM2 = 0 : Endif
       If [M:DIA]CUM(2) = 2 : [F:EPC]CUM3 = 0 : Endif
       If [M:DIA]CUM(3) = 2 : [F:EPC]CUM4 = 0 : Endif
       If [M:DIA]CUM(4) = 2 : [F:EPC]CUM5 = 0 : Endif
       If [M:DIA]CUM(5) = 2 : [F:EPC]CUM6 = 0 : Endif
       If [M:DIA]CUM(6) = 2 : [F:EPC]CUM7 = 0 : Endif
       If [M:DIA]CUM(7) = 2 : [F:EPC]CUM8 = 0 : Endif
       If [M:DIA]CUM(8) = 2 : [F:EPC]CUM9 = 0 : Endif
       If [M:DIA]CUM(9) = 2 : [F:EPC]CUM10 = 0 : Endif
       If [M:DIA]CUM(10) = 2 : [F:EPC]CUM11 = 0 : Endif
       If [M:DIA]CUM(11) = 2 : [F:EPC]CUM12 = 0 : Endif
       If [M:DIA]CUM(12) = 2 : [F:EPC]CUM13 = 0 : Endif
       If [M:DIA]CUM(13) = 2 : [F:EPC]CUM14 = 0 : Endif
       If [M:DIA]CUM(14) = 2 : [F:EPC]CUM15 = 0 : Endif
       If [M:DIA]CUM(15) = 2 : [F:EPC]CUM16 = 0 : Endif
       If [M:DIA]CUM(16) = 2 : [F:EPC]CUM17 = 0 : Endif
       If [M:DIA]CUM(17) = 2 : [F:EPC]CUM18 = 0 : Endif
     Endif
   Endif
# JASMI - 2014/03/27 - Requirement 95019 US 2547 - End
#FRLAA - 2016-04-12 - REQUIREMENT 114309 US 92 - END
  Rewrite [EPC]
   If fstat
    GOK = 0 : Call FSTA("EPC") From GLOCK : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR
 Endif
Commit
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

$TR3
GOK = 1
Trbegin [EPC]

 If [M:DIA]POP<>""
  Link [HSP] With
&   [ID]ID0   = [F:HSP]EMP
& , [HRCTR]CTR0(2) = [F:HSP]EMP;[F:HSP]CTRNUM
& , [FCY]FCY0 = [F:HRCTR]ETRFCY
& , [CPY]CPY0 = [F:FCY]LEGCPY
& , [HRPOA]POA0 = [M:DIA]POP;[F:ID]REFNUM
&   As [LHSP]
&   Where evalue(CRITSAL) & evalue(CRITPAY3) & [F:HSP]RUB=[F:RUB]COD & ([F:HSP]TYP=1 or [F:HSP]TYP=7) & [F:HRPOA]REFNUM<>""
&   Order By Key CLE = [F:HSP]EMP;[F:HRCTR]CTRNUM
 Else
  Link [HSP] With
&   [ID]ID0 = [F:HSP]EMP
& , [HRCTR]CTR0(2) = [F:HSP]EMP;[F:HSP]CTRNUM
& , [FCY]FCY0 = [F:HRCTR]ETRFCY
& , [CPY]CPY0 = [F:FCY]LEGCPY
&   As [LHSP]
&   Where evalue(CRITSAL) & evalue(CRITPAY3) & [F:HSP]RUB=[F:RUB]COD & ([F:HSP]TYP=1 or [F:HSP]TYP=7)
&   Order By Key CLE = [F:HSP]EMP;[F:HRCTR]CTRNUM
 Endif

 For [LHSP]CLE(2)
  OKSAL = 1
  Call CONTROLE([F:ID]REFNUM,datesyst,[F:HRCTR]CTRNUM,[M:DIA]CRI,OKSAL,1) From DIVPAYE
  If OKSAL
   Readlock [EPC]EPC0 = [F:HSP]EMP;[F:HRCTR]CTRNUM
   If fstat=1
    GOK = -1 : GLOCK = "$EMPLOCUM"-[F:HSP]EMP-[F:HRCTR]CTRNUM : Break
   Elsif fstat
    Raz [F:EPC]
    [F:EPC]REFNUM = [F:HSP]EMP
    [F:EPC]CTRNUM = [F:HRCTR]CTRNUM
    EXISTE = 0
   Else
    EXISTE = 1
   Endif
   For [LHSP]CLE
    #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 92 - START
    Case [F:RUB]CUMNUM
     When 2  : [F:EPC]CUM1 += [F:HSP]AMT
     When 3  : [F:EPC]CUM2 += [F:HSP]AMT
     When 4  : [F:EPC]CUM3 += [F:HSP]AMT
     When 5  : [F:EPC]CUM4 += [F:HSP]AMT
     When 6  : [F:EPC]CUM5 += [F:HSP]AMT
     When 7  : [F:EPC]CUM6 += [F:HSP]AMT
     When 8  : [F:EPC]CUM7 += [F:HSP]AMT
     When 9  : [F:EPC]CUM8 += [F:HSP]AMT
     When 10 : [F:EPC]CUM9 += [F:HSP]AMT
# JASMI - 2014/03/24 - Requirement 95019 US 2547 - Start
     When 11  : [F:EPC]CUM10 += [F:HSP]AMT
     When 12  : [F:EPC]CUM11 += [F:HSP]AMT
     When 13  : [F:EPC]CUM12 += [F:HSP]AMT
     When 14  : [F:EPC]CUM13 += [F:HSP]AMT
     When 15  : [F:EPC]CUM14 += [F:HSP]AMT
     When 16  : [F:EPC]CUM15 += [F:HSP]AMT
     When 17  : [F:EPC]CUM16 += [F:HSP]AMT
     When 18  : [F:EPC]CUM17 += [F:HSP]AMT
     When 19  : [F:EPC]CUM18 += [F:HSP]AMT
# JASMI - 2014/03/24 - Requirement 95019 US 2547 - End
    Endcase
     #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 92 - END

# For I=0 To 1
#   Assign ("[M:SDH1]REP"+num$(I+1)+"(nolign-1)")
#     With evalue("[M:SDH2]REP("+num$(I)+")")
# Next

    #Assign ("[F:EPC]CUM"+num$(I+1)) With evalue("[F:EPC]CUM"+num$(I+1)+"+[F:HSP]AMT") - FRLAA - 2016-04-12 - REQUIREMENT 114309 US 92 - Comment

#    Case [F:RUB]CUMNUM
#     When 2  : [F:EPC]CUM1 += [F:HSP]AMT
#     When 3  : [F:EPC]CUM2 += [F:HSP]AMT
#     When 4  : [F:EPC]CUM3 += [F:HSP]AMT
#     When 5  : [F:EPC]CUM4 += [F:HSP]AMT
#     When 6  : [F:EPC]CUM5 += [F:HSP]AMT
#     When 7  : [F:EPC]CUM6 += [F:HSP]AMT
#     When 8  : [F:EPC]CUM7 += [F:HSP]AMT
#     When 9  : [F:EPC]CUM8 += [F:HSP]AMT
#     When 10 : [F:EPC]CUM9 += [F:HSP]AMT
#    Endcase
   Next
   If EXISTE
    Rewrite [EPC]
   Else
    Write [EPC]
   Endif
   If fstat
    GOK = 0 : Call FSTA("EPC") From GLOCK : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR3
 Elsif !GOK : Goto AB_TR
 Endif
Commit
Return

$ROLL_TR3
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR3 : Endif

$TR4
GOK = 1
Trbegin [EPC]
 For [LCTR]
  OKSAL = 1
  Call CONTROLE([F:ID]REFNUM,datesyst,[F:HRCTR]CTRNUM,[M:DIA]CRI,OKSAL,1) From DIVPAYE
  If OKSAL
   Readlock [EPC]EPC0 = [F:ID]REFNUM;[F:HRCTR]CTRNUM
   If fstat=1
    GOK = -1 : GLOCK = "$EMPLOCUM"-[F:ID]REFNUM-[F:HRCTR]CTRNUM : Break
   Elsif fstat
    Raz [F:EPC]
    [F:EPC]REFNUM = [F:ID]REFNUM
    [F:EPC]CTRNUM = [F:HRCTR]CTRNUM
    EXISTE = 0
   Else
    EXISTE = 1
   Endif
   Filter [HSP] Where EMP=[F:ID]REFNUM & DAT<=[M:DIA]DATPAYEND & RUB=[F:CUM]CUMCOD & TYP=6 & CTRNUM=[F:HRCTR]CTRNUM
   Read [HSP]HSP1 Last
   Filter [HSP]
   If !fstat
   #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 92 - START
    Case [F:CUM]CUMNUM
     When 2  : [F:EPC]CUM1 = [F:HSP]AMT
     When 3  : [F:EPC]CUM2 = [F:HSP]AMT
     When 4  : [F:EPC]CUM3 = [F:HSP]AMT
     When 5  : [F:EPC]CUM4 = [F:HSP]AMT
     When 6  : [F:EPC]CUM5 = [F:HSP]AMT
     When 7  : [F:EPC]CUM6 = [F:HSP]AMT
     When 8  : [F:EPC]CUM7 = [F:HSP]AMT
     When 9  : [F:EPC]CUM8 = [F:HSP]AMT
     When 10 : [F:EPC]CUM9 = [F:HSP]AMT
# JASMI - 2014/03/24 - Requirement 95019 US 2547 - Start
     When 11  : [F:EPC]CUM10 += [F:HSP]AMT
     When 12  : [F:EPC]CUM11 += [F:HSP]AMT
     When 13  : [F:EPC]CUM12 += [F:HSP]AMT
     When 14  : [F:EPC]CUM13 += [F:HSP]AMT
     When 15  : [F:EPC]CUM14 += [F:HSP]AMT
     When 16  : [F:EPC]CUM15 += [F:HSP]AMT
     When 17  : [F:EPC]CUM16 += [F:HSP]AMT
     When 18  : [F:EPC]CUM17 += [F:HSP]AMT
     When 19  : [F:EPC]CUM18 += [F:HSP]AMT
# JASMI - 2014/03/24 - Requirement 95019 US 2547 - End
    Endcase
    #Assign ("[F:EPC]CUM"+num$(I+1)) With [F:HSP]AMT
    #FRLAA - 2016-04-12 - REQUIREMENT 114309 US 92 - END

    If EXISTE
     Rewrite [EPC]
    Else
     Write [EPC]
    Endif
    If fstat
     GOK = 0 : Call FSTA("EPC") From GLOCK : Break
    Endif
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR4
 Elsif !GOK : Goto AB_TR
 Endif
Commit
Return

$ROLL_TR4
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR4 : Endif

######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
Call FILL_TOTALS(VALEUR)
End

######################################################################################
Subprog FILL_TOTALS(VALEUR)
Variable Char    VALEUR()
Local Integer I
If clalev([ADI])=0 : Local File ATABDIV [ADI] : Endif
Filter [ADI] Where NUMTAB=10349 & LEG=GCURLEG
[M:DIA]NBCUM=rowcount([ADI])
I=0
For [ADI]CODE
 Call LECTEXTRA ([M:DIA]LIBCUM(I),"ATABDIV","LNGDES","10349",[ADI]CODE) From ATEXTRA
 [M:DIA]CODCUM(I) = [ADI]CODE
 [M:DIA]CUM(I)    = 1
 I+=1
Next
Filter [ADI]
Affzo [M:DIA]30
End

######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran EXTRACT) 03/01/2013 12:12:07 (DLE)
######################################################################################
Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR
  Call FILL_TOTALS(GCURLEG)

  If VALEUR=2
    Raz [M:DIA]SRV, PRF, MATDEB, MATFIN, POP
    [M:DIA]ALLSRV=2 : [M:DIA]ALLPRF=2
    Affzo [M:DIA]
  Endif
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
  Call FILL_TOTALS(GCURLEG)
  Raz [M:DIA]SRV, PRF, MATDEB, MATFIN, POP
  Affzo [M:DIA]

End


