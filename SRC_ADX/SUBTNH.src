######################################################################################
######################################################################################
Subprog AM_TNHTYP(VALEUR)
Variable Char    VALEUR()

If func AFNC.ACTIV('KPO')>0
  If func PORLEGLIB.DIGSIGN([M:TNH0]FCY,'')=1
    If clalev([F:TTN])=0 : Local File TABTNHTYP [F:TTN] : Endif
    Local Integer RET : [L]RET = 0
    Actzo  [M:TNH2]GLBDOCDAT,GLBDOCNUM,GLBDOCTYP,ATDTCOD,MANDOC,GLBDOC
    [M:TNH0]TNHTYP = VALEUR
    Call LEC_TTN_LEG([F:FCY]LEG,[M:TNH0]TNHTYP,[L]RET) From TRTLECLEG
    Call DIS_MANDOC(GFONCTION) From TRNDOC
  Else
    Diszo  [M:TNH2]GLBDOCDAT,GLBDOCNUM,GLBDOCTYP,ATDTCOD,MANDOC,GLBDOC
  Endif
Endif
#-
End
######################################################################################
######################################################################################
Subprog AM_GLBDOC(VALEUR)
Variable Integer VALEUR
Call  AM_GLBDOC(VALEUR) From TRNDOC
End


######################################################################################
######################################################################################
Subprog AS_BPCBPS(VALEUR)
Variable Integer VALEUR
If clalev([F:PTBPR])=0 : Local File BPARTNER [PTBPR] : Endif
Raz GMENLOC

For I=1 To  dim(GMENLOC)-1
  GMENLOC(I)=1
Next

Read [F:PTBPR]BPR0=[M:TNH0]BPRNUM
If [F:PTBPR]BPSFLG=2 & [F:PTBPR]BPCFLG=2
  GMENLOC(1)=0
  GMENLOC(2)=0
Elsif [F:PTBPR]BPSFLG=2
  GMENLOC(2)=0
Elsif [F:PTBPR]BPCFLG=2
  GMENLOC(1)=0
Endif

End
######################################################################################
######################################################################################
Subprog C_ETA(VALEUR)
Variable Char    VALEUR()
If VALEUR="0000" : End : Endif
If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([M:TNH0]FCY,'')=1
  If [M:TNH2]DPEDAT<>[0/0/0] & [M:TNH2]ARVDAT<>[0/0/0]
    If [M:TNH2]DPEDAT=[M:TNH2]ARVDAT & VALEUR<=[M:TNH2]ETD
       Call ERREUR(mess(98,7711,1)) From GESECRAN
       mkstat=2
    Endif
  Endif
Endif
End
######################################################################################
######################################################################################
Subprog C_NBLIG

If [M:TNH1]CFMFLG <> 3
  If [M:TNH1]NBLIG<>0
    Diszo [M:TNH0]5
    Actzo [M:TNH0]TNHNUM
    Actzo [M:TNH0]TRNDAT
  Else
    If find (GREP, "C", "D")
      Actzo [M:TNH0]5
    Endif
  Endif
Endif

End
######################################################################################
######################################################################################
Subprog C_TNHTYP(VALEUR)
Variable Char    VALEUR()

If func AFNC.ACTIV("KPO")>0
  If func PORLEGLIB.CTLDOCTYP(VALEUR,"TNH",GMESSAGE) = 1
    mkstat = 2 : End
  Endif
Endif

End
