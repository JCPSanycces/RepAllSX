######################################################################################
######################################################################################
## Section automatically added (screen TNH1) 07/30/2014 11:57:36 (RMA)
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

If [F:ITM]ITMREF <> VALEUR
  Read [F:ITM]ITM0 = VALEUR
  If fstat : Raz [F:ITM] : Endif
Endif

Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:TNH1]ITMDES(nolign-1), "[F:ITM]") From TRTX3
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:TNH1]ITMDES1(nolign-1), "[F:ITM]") From TRTX3

[M:TNH1]UOM(nolign-1) = [F:ITM]STU

End
######################################################################################
######################################################################################
##                                   TNH2 screen
######################################################################################
######################################################################################
## Section automatically added (screen STH2) 30-07-2014 17:21:23 (RMA)
######################################################################################
Subprog C_DPEDAT(VALEUR)
Variable Date    VALEUR
# BRBAN 01/09/2014 #93745
If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([M:TNH0]FCY,'')=1 & find([F:TTN]RECTYP,2,3)
  End
Endif
If VALEUR <> [0/0/0] Then
  If VALEUR < [M:TNH0]TRNDAT Then
    GMESSAGE = mess(399,192,1) - format$(GFMDAT, VALEUR) - "<" - format$(GFMDAT, [M:TNH0]TRNDAT)
    mkstat = 2
    End
  Endif
Endif
End

Subprog AM_DPEDAT(VALEUR)
Variable Date    VALEUR
  # FGR 04/07/2014 : X3SUIVI91606
  If VALEUR <> [0/0/0] Then
    If [M:TNH2]ARVDAT = [0/0/0] or ([M:TNH2]ARVDAT <> [0/0/0] and (VALEUR > [M:TNH2]ARVDAT or [M:TNH2]DPEDAT = [M:TNH2]ARVDAT)) Then
      [M:TNH2]ARVDAT = VALEUR
      Affzo [M:TNH2]ARVDAT
    Endif
  Endif
End

Subprog C_ARVDAT(VALEUR)
Variable Date    VALEUR
# BRBAN 01/09/2014 #93745
If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([M:TNH0]FCY,'')=1 & find([F:TTN]RECTYP,2,3)
  End
Endif

  # FGR 04/07/2014 : X3SUIVI91606
  If VALEUR <> [0/0/0] Then
    If [M:TNH2]DPEDAT <> [0/0/0] and VALEUR < [M:TNH2]DPEDAT Then
      GMESSAGE = mess(401,192,1) - format$(GFMDAT, [M:TNH2]DPEDAT) - ">" - format$(GFMDAT, VALEUR)
      mkstat = 2
      End
    Endif
  Endif
End
