######################################################################################
## Section automatically added (Object TNH) 25-07-2014 12:34:16 (RMA)
######################################################################################
## Object actions
######################################################################################
$ACTION

Case ACTION
  When "OUVRE"      : Gosub OUVRE      From SUBTNHA
  When "FILTRE"     : Gosub FILTRE     From SUBTNHA
  When "LIENS"      : Gosub LIENS      From SUBTNHA
  When "CREATION"   : Gosub CREATION   From SUBTNHA
  When "MODIF"      : Gosub MODIF      From SUBTNHA
  When "ANNULE"     : Gosub ANNULE     From SUBTNHA
  When "APRES_CRE"  : Gosub APRES_CRE  From SUBTNHA
  When "APRES_MOD"  : Gosub APRES_MOD  From SUBTNHA
  When "INICRE_LIG" : Gosub INICRE_LIG From SUBTNHA
  When "DEFLIG"     : Gosub DEFLIG     From SUBTNHA
  When "SETBOUT"    : Gosub SETBOUT    From SUBTNHA
  When "RAZCRE"     : Gosub RAZCRE     From SUBTNHA
  When "RAZDUP"     : Gosub RAZDUP     From SUBTNHA
  When "INICRE"     : Gosub INICRE     From SUBTNHA
  When "INIMOD"     : Gosub INIMOD     From SUBTNHA
  When "STATUT"     : Gosub STATUT     From SUBTNHA
  When "EXEBOUT"    : Gosub EXEBOUT    From SUBTNHA
  When "AVANTBOUT"  : Gosub AVANTBOUT  From SUBTNHA
  When "VERIF_CRE"  : Gosub VERIF_CRE  From SUBTNHA
  When "VERIF_MOD"  : Gosub VERIF_MOD  From SUBTNHA
  When Default
Endcase

Return
######################################################################################
######################################################################################
##                                  Field actions
######################################################################################
##                                   TNH0 screen
######################################################################################
######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
# BRBAN * 27-03-2015 * #107320
Local Char WTNHTYP(GLONTPN)
GFCY=VALEUR
# Chargement des globales référenciels, comptes et sections de la société
Gosub TNHTYP From TRTTNH1
If WTNHTYP<>"" : [M:TNH0]TNHTYP=WTNHTYP : Affzo [M:TNH0]TNHTYP : Endif

# Issue X3-3575 - 2016-09-22 by RICAR : Allow to change the ship from address on transportation notes
# Issue X3-3575
Filter [F:BPA2] Where [F:BPA2]BPATYP = 3 & [F:BPA2]BPANUM = VALEUR & [F:BPA2]BPAADDFLG = 2
Read [F:BPA2] First
If fstat
  Filter [F:BPA2]
  Filter [F:BPA2] Where [F:BPA2]BPATYP = 3 & [F:BPA2]BPANUM = VALEUR
  Read [F:BPA2] First
  If fstat
    Raz [F:BPA2]
  Endif
Endif
Filter [F:BPA2]

[M:TNH0]FCY = VALEUR
[M:TNH0]SHIFRMADD = [F:BPA2]BPAADD

Gosub CHARGE_SHIFRM_NEW_ADDRESS From SUBTNHB
# End issue X3-3575

If func AFNC.ACTIV('KPO')>0
  If func PORLEGLIB.DIGSIGN(VALEUR,'')=1
    Actzo  [M:TNH2]GLBDOCDAT,GLBDOCNUM,GLBDOCTYP,ATDTCOD,MANDOC,GLBDOC
    Call DIS_MANDOC(GFONCTION) From TRNDOC
  Else
    Diszo  [M:TNH2]GLBDOCDAT,GLBDOCNUM,GLBDOCTYP,ATDTCOD,MANDOC,GLBDOC
  Endif
Endif

End
######################################################################################
######################################################################################
Subprog AM_BPRNUM(VALEUR)
Variable Char    VALEUR()
If clalev([F:PTBPR])=0 : Local File BPARTNER [PTBPR] : Endif

Filter [F:BPA] Where [F:BPA]BPATYP = 1 & [F:BPA]BPANUM = VALEUR & [F:BPA]BPAADDFLG = 2
Read [F:BPA] First
If fstat
  Filter [F:BPA]
  Filter [F:BPA] Where [F:BPA]BPATYP = 1 & [F:BPA]BPANUM = VALEUR
  Read [F:BPA] First
  If fstat
    Raz [F:BPA]
  Endif
Endif
Filter [F:BPA]

[M:TNH0]BPRNUM = VALEUR
[M:TNH0]BPAADD = [F:BPA]BPAADD

Gosub CHARGE_NEW_ADDRESS From SUBTNHB

If func AFNC.ACTIV("KPO")
  Read [F:PTBPR]BPR0=[M:TNH0]BPRNUM
  If [F:PTBPR]BPSFLG=2
    [M:TNH0]BPCBPS = 2
  Elsif [F:PTBPR]BPCFLG=2
    [M:TNH0]BPCBPS = 1
  Endif
  Affzo [M:TNH0]BPCBPS
  # Issue 24522 - 2017-03-14 by MRDAB : GESTPM modification to include transport notes and move AP/AR to a new block
  Call ALI_PRTMOD("TNH0",11) From TRTX3
  If [M:TNH0]COPNBR=0 [M:TNH0]COPNBR=1 Endif
  # End issue 24522
Endif

End
######################################################################################
######################################################################################
Subprog AM_BPAADD(VALEUR)
Variable Char    VALEUR()

[M:TNH0]BPAADD = VALEUR
Gosub CHARGE_NEW_ADDRESS From SUBTNHB

End
