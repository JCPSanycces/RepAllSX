#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ENTSAL6 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:11"
A_USER  = "DOC"
A_STAMP = "20181109230411"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRUKI"
  If [M]NBRUKI=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ENTSAL6 [ENT6]
Gosub HORODAT
Local Inpbox "ENTSAL6" From GFONCTION At A_STAMP With A_WINDPREV Mask [ENT6] As [SIM_]
Grizo [ENT6]5
Grizo [ENT6]10
Grizo [ENT6]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [ENT6]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=128 : Y1(0)=1 : Y2(0)=13
X1(1)=1 : X2(1)=128 : Y1(1)=14 : Y2(1)=18
X1(2)=1 : X2(2)=128 : Y1(2)=19 : Y2(2)=23
Return

$ON_PRVFRM
Onevent CONTROL Call C_PRVFRM(zc) From W1ENTSAL6
Onevent INIT_AREA Call D_PRVFRM(zc) From W1ENTSAL6
Onevent BEFORE_INPUT Call AS_PRVFRM(zc) From W1ENTSAL6
Return

Subprog D_PRVFRM(VALEUR)
Variable Integer VALEUR
If varinit([M]PRVFRM,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_PRVFRM(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_PRVFRM(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_PRVFRM(VALEUR) From SUBHRENT
If mkstat : GERR = 1 : GZONE = "PRVFRM" : GZNUM = 1002051 : Endif
Gosub _AFF
End

