$ON_NICAT
Onevent CONTROL Call C_NICAT(zc) From W1ENTSAL6
Onevent BEFORE_INPUT Call AS_NICAT(zc) From W1ENTSAL6
Onevent AFTER_CHANGE Gosub AMM_NICAT From W1ENTSAL6
Return

Subprog AS_NICAT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1000625,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_NICAT(zc) From W1ENTSAL6
Onkey   2 Titled GBOUTS Call S_NICAT(zc) From W1ENTSAL6
Onkey 144 Titled GBOUTP Call P_NICAT(zc) From W1ENTSAL6
Onkey 146 Titled GBOUTA Call SA_NICAT(zc) From W1ENTSAL6
Gosub _AFF
End

Subprog C_NICAT(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("NIC","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "NICAT" : GZNUM = 1000625 : Endif
If !mkstat
 ## Action STD
 Call C_NICAT(VALEUR) From SUBHRENT
 If mkstat : GERR = 1 : GZONE = "NICAT" : GZNUM = 1000625 : Endif
Endif
Gosub _AFF
End

$AMM_NICAT
Call AM_NICAT(zc)
If !mkstat & GOBJET
 zoncou = "NICAT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_NICAT(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZNICAT)")>indice
 [M]NICAT(indice) = VALEUR
 Affzo ZNICAT(indice)
Endif
Gosub _AFF
End

Subprog S_NICAT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "NIC"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_NICAT(VALEUR)
Variable Char    VALEUR()
Call OBJET("NIC",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_NICAT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "NIC"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_NICAT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("NIC",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZNICAT
Onevent BEFORE_AREA Gosub AV_ZNICAT From W1ENTSAL6
Return

$AV_ZNICAT
If clalev([F:NIC])=0 : Local File NICDET [NIC] : Endif
Call LECTURE("NIC",num$([M]NICAT(indice)),"") From CONTOBJ
zc = [F:NIC]DES
Gosub _AFF
Return

