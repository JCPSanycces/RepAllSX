######################################################################################
## Etiquette ajoutée par le superviseur (Objet LPNOPE) 13/12/2017 09:27:23 (MAE)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE        From SUBLPNOPA
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE  From SUBLPNOPA

 When "FILTRE"       : Gosub FILTRE       From SUBLPNOPA
 When "LIENS"        : Gosub LIENS        From SUBLPNOPA
 When "DEFLIG"       : Gosub DEFLIG       From SUBLPNOPA
 When "LIENS_LIG"    : Gosub LIENS_LIG    From SUBLPNOPA

 When "SETBOUT"      : Gosub SETBOUT      From SUBLPNOPA
 When "EXEBOUT"      : Case BOUT
                            When "1" :Gosub TIROIR From SUBLPNOPP
                       Endcase

 When "RAZCRE"       : Gosub RAZCRE       From SUBLPNOPA
 When "RAZDUP"       : Gosub RAZDUP       From SUBLPNOPA
 When "CREATION"     : Gosub CREATION     From SUBLPNOPA
 When "VERIF_CRE"    : Gosub VERIF_CRE    From SUBLPNOPA
 When "VERIF_MOD"    : Gosub VERIF_MOD    From SUBLPNOPA
 When "INICRE"       : Gosub INICRE       From SUBLPNOPA
 When "INIMOD"       : Gosub INIMOD       From SUBLPNOPA
 When "INICRE_LIG"   : Gosub INICRE_LIG   From SUBLPNOPA
 When "VALLIG"       : Gosub VALLIG       From SUBLPNOPA
 When "APRES_CRE"    : Gosub APRES_CRE    From SUBLPNOPA
 When "MODIF"        : Gosub MODIF        From SUBLPNOPA
 When "AVANT_MOD"    : OK = 0     #pas de modification
 When "APRES_MOD"    : Gosub APRES_MOD    From SUBLPNOPA
 When "AB_CREATION"  : Gosub AB_CREATION  From SUBLPNOPA
 When "AB_MODIF"     : Gosub AB_MODIF     From SUBLPNOPA
 When "ABANDON"      : Gosub ABANDON      From SUBLPNOPA
 When "FIN"          : Gosub ABANDON      From SUBLPNOPA
 When "FERME"        : Gosub FERME        From SUBLPNOPA
 When "APRES_MODIF"  : Gosub APRES_MODIF  From SUBLPNOPA
 When "TIROIR"           : Gosub TIROIR       From SUBLPNOPP
 When "FILGAUCHE"        : Gosub FILGAUCHE    From SUBLPNOPP
 When "AP_FILGAUCHE"     : Gosub AP_FILGAUCHE From SUBLPNOPP
 When "DEB_PICK"         : Gosub DEB_PICK     From SUBLPNOPP
 When "PICKE"            : Gosub PICKE        From SUBLPNOPP
 When "DEPICK"           : Gosub DEPICK       From SUBLPNOPP
 When "FIN_PICK"         : Gosub FIN_PICK     From SUBLPNOPP
 When Default
Endcase
Return

$SET_NOL
    Local Integer NOL
    NOL = nolign-1
Return

#---------------------------------------------------------------------------#
#                                                                           #
#                                Ecran LPNO - En-tête                       #
#                                                                           #
#---------------------------------------------------------------------------#

########################################
Subprog D_VCRNUM(VALEUR)
Variable Char    VALEUR()
    [M:LPNO]VCRTYP = 29
End

########################################
Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()


#-- Il faut une valeur saisie ou retournée par un compteur sinon erreur
If (VALEUR="" &  GSTKCPT(14)="")
  mkstat = 2 : End
Endif
#-- Si on est en création , n° saisi vide et un compteur est présent on sort
If (GREP="C" & VALEUR="" &  GSTKCPT(14)<>"")
  End
Endif

#-- Si dernier lu non chargé, on vérifie l'existence du n° saisi
If [M:LPNO]VCRNUM="" & GREP<>"C"
  Look [F:SGH]SGH0=VALEUR
  If fstat
    GMESSAGE=mess(178,199,1) : mkstat=2 : End
  Endif
Endif

If VALEUR<>"" & GSTKCPTMAN(14)<>2
  Look [F:SGH]SGH0=VALEUR
  If fstat
    Raz VALEUR : End
  Endif
Endif

End

##########################################################################
Subprog AS_STOFCY(VALEUR)
Variable Char    VALEUR()
# Si ligne déjà saisie, plus d'accés au site de stock
If [M:LPNO]NBLIG<>0 mkstat=2 Endif
End

##########################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()

GFCY=VALEUR : Gosub CHARG_PARAM From SUBLPNOPA

[M:SGW]FCYDES = VALEUR

# Actzo ou Diszo du dépôt
[M:LPNO]STOFCY=VALEUR

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNOPE) 26/03/2018 06:52:24 (MAE)
######################################################################################
Subprog AM_LOCSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR <> AVOID.ACHAR and [M:LPNO]LOCEND= AVOID.ACHAR
  [M:LPNO]LOCEND = VALEUR
  Affzo [M:LPNO]LOCEND
Endif
End

Subprog AM_LOCTYPSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR <> AVOID.ACHAR and [M:LPNO]LOCTYPEND= AVOID.ACHAR
  [M:LPNO]LOCTYPEND = VALEUR
  Affzo [M:LPNO]LOCTYPEND
Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNOPE) 20/12/2017 09:39:37 (MAE)
######################################################################################
Subprog AM_LPNDESH(VALEUR)
Variable Char    VALEUR()
Local File STOCK      [STO1]
Local Integer NBROW

Read [LPN]LPN0 = VALEUR
If [F:LPN]LOC <> AVOID.ACHAR
  #lecture de l'emplacement pour rfécupérer le depot
  Read [STC]STC0 = [M:LPNO]STOFCY;[F:LPN]LOC
  #initialisation de l'emplacement et du dépot de dépose
  [M:LPNO]LOCDESH = [F:LPN]LOC
  [M:LPNO]LOCTYPDESH = [F:LPN]LOCTYP
  If dim([M:LPNO]WRHDESH)>0
    [M:LPNO]WRHDESH = [F:STC]WRH
  Endif
  If [LPN]LPNSTAT = 2
    Diszo [M:LPNO]LOCDESH
  Else
    Actzo [M:LPNO]LOCDESH
  Endif
Else
  Raz [M:LPNO]LOCDESH
  If dim([M:LPNO]WRHDESH)>0
    Raz [M:LPNO]WRHDESH
  Endif
  Actzo [M:LPNO]LOCDESH
Endif

Affzo [M:LPNO]
End
##########################################################################
Subprog C_LOCDESH(VALEUR)
Variable Char    VALEUR()

Local Shortint W_K

VALEUR = toupper(VALEUR)
If !find(VALEUR,"",[M:LPNO]LOCDESH)
  Read [STC]STC0=[M:LPNO]STOFCY;VALEUR
  If fstat
    GMESSAGE = mess(125,184,1)
    mkstat=2 : End
  Elsif [F:STC]LOCCAT >2
    GMESSAGE = mess(16,196,1)
    mkstat=2 : End
  Endif
Endif
If dim([M:LPNO]WRHDESH)>0
  [M:LPNO]WRHDESH = [F:STC]WRH
Endif
[M:LPNO]LOCTYPDESH = [F:STC]LOCTYP
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNOPE) 12/03/2018 15:17:40 (MAE)
######################################################################################
Subprog AS_MODOPELPN(VALEUR)
Variable Integer VALEUR
GMENLOC(4) = 1
Affzo [M:LPNO]MODOPELPN
If [M:LPNO]NBLIG > 0
  Diszo [M:LPNO]MODOPELPN
Else
  Actzo [M:LPNO]MODOPELPN
Endif
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNOPE) 26/01/2018 10:24:02 (MAE)
######################################################################################
Subprog AM_MODOPELPN(VALEUR)
Variable Integer VALEUR
If VALEUR <> 3
  Actzo [M:LPNO]LPNDESH
Else
  Raz [M:LPNO]LPNDESH
  Grizo [M:LPNO]LPNDESH
  Actzo [M:LPNO]LOCDESH
Endif
End


