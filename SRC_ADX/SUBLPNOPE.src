######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNOPE) 01/03/2018 13:43:46 (MAE)
######################################################################################
Subprog C_LOCDES(VALEUR)
Variable Char    VALEUR()
If VALEUR <> AVOID.ACHAR
  #controle de l'emplacement du LPN
  Call STKCTREMP([M:LPNO]WLOCSEQ,36,"",[M:LPNO]STOFCY,
&                          [F:STO]ITMREF,[F:STO]PCU,[F:STO]QTYPCU,
&                          [F:STO]STA,[M:LPNO]LOCTYPDES(nolign-1),VALEUR,"",
&                          0,mkstat,GBIDD1,"UQ",GFILLOCENT,"") From STKLOC
  If mkstat = 2 : End : Endif
Endif
End


######################################################################################


######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNOPE) 29/01/2018 10:17:00 (MAE)
######################################################################################
Subprog AM_LOCDES(VALEUR)
Variable Char    VALEUR()
#lecture de l'emplacement pour le type d'emplacement
If VALEUR <> AVOID.ACHAR
 If [M:LPNO]MODOPELPN <> 1
    [M:LPNO]FLGSEL(nolign-1) = 2
    Affzo [M:LPNO]FLGSEL(nolign-1)
  Endif
  Read [STC]STC0 = [M:LPNO]STOFCY;VALEUR
  If fstat
   GMESSAGE = mess(125,184,1)
   mkstat=2 : End
  Endif
  [M:LPNO]LOCTYPDES(nolign-1) = [F:STC]LOCTYP
  Affzo [M:LPNO]LOCTYPDES(nolign-1)
  If dim([M:LPNO]WRHDESH)>0
    [M:LPNO]WRHDES(nolign-1) = [F:STC]WRH
  Endif
Endif
End



######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNOPE) 12/03/2018 15:52:48 (MAE)
######################################################################################
Subprog AM_LPNNUMDES(VALEUR)
Variable Char    VALEUR()
If VALEUR <> AVOID.ACHAR
   If [M:LPNO]MODOPELPN <> 1
    [M:LPNO]FLGSEL(nolign-1) = 2
    Affzo [M:LPNO]FLGSEL(nolign-1)
  Endif
  Read [LPN]LPN0 = VALEUR
  [M:LPNO]LOCDES(nolign-1) = [F:LPN]LOC
  [M:LPNO]LOCTYPDES(nolign-1) = [F:LPN]LOCTYP
  If dim([M:LPNO]WRHDESH)>0
    [M:LPNO]WRHDES(nolign-1) = [F:LPN]WRH
  Endif
  Affzo [M:LPNO]LOCDES(nolign-1)
  If [F:LPN]LOC <> AVOID.ACHAR & [F:LPN]LPNSTAT = 2
      Diszo [M:LPNO]LOCDES(nolign-1)
      #controle de l'emplacement du LPN : s'il a du stock, il n'est pas modifiable
      Call STKCTREMP([M:LPNO]WLOCSEQ,36,"",[M:LPNO]STOFCY,
&                          [F:STO]ITMREF,[F:STO]PCU,[F:STO]QTYPCU,
&                          [F:STO]STA,[M:LPNO]LOCTYPDES(nolign-1),[M:LPNO]LOCDES(nolign-1),"",
&                          0,mkstat,GBIDD1,"UQ",GFILLOCENT,"") From STKLOC
  Else
    Actzo [M:LPNO]LOCDES(nolign-1)
    zonsui = [M:LPNO]LOCDES(nolign-1)
  Endif
Endif

End



######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNOPE) 16/03/2018 13:09:09 (MAE)
######################################################################################
Subprog AM_QTYPCU(VALEUR)
Variable Decimal VALEUR
Local Integer LRET
If VALEUR <> 0
  If [M:LPNO]MODOPELPN <> 1
    [M:LPNO]FLGSEL(nolign-1) = 2
    Affzo [M:LPNO]FLGSEL(nolign-1)
    Call AM_FLGSEL([M:LPNO]FLGSEL(nolign-1))
  Endif
  Call MAJQTY(1,VALEUR,LRET) From SUBLPNOPB
  If LRET
    mkstat=2 : End
  Endif
Endif
End


