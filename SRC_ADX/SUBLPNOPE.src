#---------------------------------------------------------------------------#

##########################################################################
Subprog AVANT_NBLIG
Local Integer LRET
Local Integer CTRIPTDAT
If [M:LPNO]ITMREF(nolign-1)<>""
  If GREP = "M"
    If CTRIPTDAT <> CST_AOK & [M:LPNO]IPTDAT < date$
        CTRIPTDAT = CST_AERROR
        # Attention ! la date d imputation est antérieure à la date du jour
        Call MESSAGE(mess(162,184,1)) From GESECRAN
    Endif
  Endif

  Call LECITM2( [M:LPNO]STOFCY, [M:LPNO]ITMREF(nolign-1), "", LRET ) From STKLIB

  # Si changement stock, lecture règle de gestion pour flux d'entrée
  Call LECSRU([M:LPNO]STOFCY,[F:ITM]TCLCOD,26,"","",LRET) From STKLIB
  If LRET<>0 mkstat=2 : End Endif
Endif

End

##########################################################################
Subprog IB_NBLIG
Local Integer LRET

If [M:LPNO]ITMREF(nolign-1)<>""
  Call LECITM2( [M:LPNO]STOFCY, [M:LPNO]ITMREF(nolign-1), "", LRET ) From STKLIB
  GOUVENT = 1
Endif

# Btn 4 = saisie serie globales         110327 #
GBOUT4 = mess(655,199,1)

# pas de saisie des series concernés si :
# l article ne gère pas les series globales
# pas de quantité qualifiée
If [F:ITM]SERMGTCOD <> 4 | [M:LPNO]QTYSTUDES (nolign-1)= 0 | [M:LPNO]WSTOCOU(nolign-1) = 0
   Raz GBOUT4
Endif
#pas de saisie changement contenant si :
#le mode n'est pas éclatement, la ligne non sélectionnée, pas de STOCOU, pas de quantité ou quntité égale à 1
If [M:LPNO]MODOPELPN <> 2 | [M:LPNO]FLGSEL(nolign-1) <> 2 | [M:LPNO]WSTOCOU (nolign-1)= 0 | [M:LPNO]QTYSTUDES (nolign-1)= 0 | [M:LPNO]QTYSTUDES (nolign-1)= 1
   Raz GBOUT1
Endif
If [M:LPNO]LPNNUMDES(nolign-1) = AVOID.ACHAR or [M:LPNO]LPNNUMDES(nolign-1) = "$"
  Raz GBOUT3
Endif
# Issue 106909 - 2018-09-20 by MAE : pas de consultation si création ou duplication
If GREP="C" or GREP="D"
  Raz GBOUT2,GBOUT3
Endif
End

##########################################################################
Subprog C_NBLIG
Local Integer LRET
Case status
  When 65     :                       # Suppression d'une ligne
    #suppression impossible si regroupement
    If [M:LPNO]MODOPELPN = 1
      GMESSAGE = mess(54,123,1)
      mkstat = 2
    Endif
    If [M:LPNO]CREFLG(nolign-1)=0
      Call DELSTOCHGW("LPNO", [M:LPNO]STOFCY, nolign-1, nolign-1,1, LRET) From SUBSCSB
    Else
      mkstat = 2
    Endif

  When 68, 83 :                       # Suppression d'un groupe de lignes
    #suppression impossible si regroupement
    If [M:LPNO]MODOPELPN = 1
      GMESSAGE = mess(54,123,1)
      mkstat = 2
    Endif
    For I=nolign-1 To nolign1-1
      If [M:LPNO]CREFLG(I)<>0
        mkstat=2 : Break
      Endif
    Next
    If !mkstat
      Call DELSTOCHGW("LPNO", [M:LPNO]STOFCY, nolign-1, nolign1-1,1, LRET) From SUBSCSB
    Endif

  When 75     :
    If [M:LPNO]CREFLG(nolign-1)<>0
      mkstat=2
    Endif
Endcase

If LRET : mkstat=2 : Endif

If find(status,73,75)
  If [M:SGW]NBLIG+sigma(0,[M:SGW]NBLIG-1,[M:SGW]WSTOSEQ(indcum)=[M:LPNO]WSTOSEQ(nolign-1))>=dim([M:SGW]WSTOSEQ)
    Call ERREUR(mess(36,184,1)) From GESECRAN
    mkstat=2 : End
  Endif
Endif

End

##########################################################################
Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR()
    If [F:ITM]SERMGTCOD=2 & VALEUR<>""
        Call STKCTRSER(VALEUR,[M:LPNO]ITMREF(nolign-1),nolign-1,[M:LPNO]NBLIG,
&                      [M:LPNO]WSTOSEQ(nolign-1),36,[M:LPNO]VCRTYP,
&                      [M:LPNO]VCRNUM,[M:LPNO]VCRLIN(nolign-1),0,"",0,0,0,"" )
&            From STKACT
    Endif
End


#########################################################################
Subprog APRES_NBLIG
Local Integer LRET
Local Decimal LQTY
Local Integer LSEQ
Local Char    PABR(GLONABR)
Local Integer PNOL
PABR = "LPNO"
LQTY = [M:LPNO]QTYSTUDES(nolign-1)
#suppression du STOCHGW et on le recréé (il est forcément déjà créé : soit en pcking, soit en insertion auto)
Call DELSTOCHGW("LPNO", [M:LPNO]STOFCY, nolign-1, nolign-1,1, LRET) From SUBSCSB
#en éclatement et en désaffectation, la ligne doit avoir été sélectionnée pr remplir le SGW
If [M:LPNO]MODOPELPN <>  1
  If [M:LPNO]FLGSEL(nolign-1) = 2
    Call STKWSTOSEQ ("LPNO", [M:LPNO]NBLIG-1, [M:LPNO]NBLIG, 2, LSEQ, LRET) From STKECR
    Call FILLCHGW("LPNO", nolign-1, 1, [M:LPNO]WSTOSEQ(nolign-1), [M:LPNO]STOFCY, LRET, LQTY) From SUBSCSB
  Endif
Else  # en regroupement, toutes les lignes sont mises dans SGW
    Call STKWSTOSEQ ("LPNO", [M:LPNO]NBLIG-1, [M:LPNO]NBLIG, 2, LSEQ, LRET) From STKECR
    Call FILLCHGW("LPNO", nolign-1, 1, [M:LPNO]WSTOSEQ(nolign-1), [M:LPNO]STOFCY, LRET, LQTY) From SUBSCSB
Endif

End



######################################################################################

Subprog B4_NBLIG
If [M:LPNO]MODOPELPN = 1
  #si regroupement,les numéros de série ne sont pas modifiables
  GOUVCHGS = 9
Else
  GOUVCHGS = 2
Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran LPNOPE) 08/03/2018 15:53:43 (MAE)
######################################################################################
#si le LPN et l'emplacement entête sont renseignés => affectattion de ceux de la ligne
#sinon si désaffectation=>affectation de l'emplacement avec celui d'origine
Subprog AM_FLGSEL(VALEUR)
Variable Integer VALEUR
Local Integer LRET
If VALEUR = 2
  #controles sur la ligne de stock
  If [F:STO]STOCOU <> [M:LPNO]WSTOCOU(nolign-1)
    Read [STO]STO0 = [M:LPNO]STOFCY;[M:LPNO]WSTOCOU(nolign-1)
  Endif
  # Ligne(s) de stock en controle qualité
  If [F:STO]QLYCTLDEM<>""
    GMESSAGE=mess(532,184,1)
    mkstat = 2: End
  Endif
  # Ligne(s) de stock en inventaire
  If [F:STO]CUNLOKFLG = 2
    GMESSAGE=mess(233,184,1)
    mkstat = 2  : End
  Endif
  #ligne de stock en cours de pesée
  Look [F:STA]STA0(3)=[F:STO]STOFCY;[F:STO]ITMREF;[F:STO]STOCOU
  [G:STA]currlen=0
  If !fstat
    # La ligne de stock est-elle en cours de pesée
    Call ALL_WEIGHING([F:STO]STOFCY,[F:STO]ITMREF,[F:STO]STOCOU,LRET) From STKALL
    If LRET<>0
      GMESSAGE=mess(533,184,1) # Ligne(s) de stock en cours de pesée
      mkstat = 2  : End
    Endif
  Endif
  If [M:LPNO]LPNDESH <> AVOID.ACHAR
    If [M:LPNO]LPNNUMDES(nolign-1) = AVOID.ACHAR
      [M:LPNO]LPNNUMDES(nolign-1) = [M:LPNO]LPNDESH
    Endif
    If [M:LPNO]LOCDES(nolign-1) = AVOID.ACHAR
      [M:LPNO]LOCDES(nolign-1) = [M:LPNO]LOCDESH
      [M:LPNO]LOCTYPDES(nolign-1) = [M:LPNO]LOCTYPDESH
    Endif
    If dim([M:LPNO]WRHDESH)> 0
      [M:LPNO]WRHDES(nolign-1) = [M:LPNO]WRHDESH
    Endif
  Else
     If [M:LPNO]MODOPELPN = 3
      If [M:LPNO]LOCDESH <> AVOID.ACHAR
        [M:LPNO]LOCDES(nolign-1) = [M:LPNO]LOCDESH
        [M:LPNO]LOCTYPDES(nolign-1) = [M:LPNO]LOCTYPDESH
        If dim([M:LPNO]WRHDESH)> 0
          [M:LPNO]WRHDES(nolign-1) = [M:LPNO]WRHDESH
        Endif
      Else
        [M:LPNO]LOCDES(nolign-1) = [F:STO]LOC
        [M:LPNO]LOCTYPDES(nolign-1) = [F:STO]LOCTYP
        If dim([M:LPNO]WRHDES(nolign-1))> 0
          [M:LPNO]WRHDES(nolign-1) = [F:STO]WRH
        Endif
      Endif
     Endif
 Endif
Elsif VALEUR = 1
  [M:LPNO]LPNNUMDES(nolign-1) = AVOID.ACHAR
  [M:LPNO]LOCDES(nolign-1) = AVOID.ACHAR
  [M:LPNO]LOCTYPDES(nolign-1) = AVOID.ACHAR
  If dim([M:LPNO]WRHDES(nolign-1))> 0
    [M:LPNO]WRHDES(nolign-1) = AVOID.ACHAR
  Endif
Endif
End


