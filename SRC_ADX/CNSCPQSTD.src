#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################
# CNSCPQSTD : Consultation des lignes retours    d'achat                #
# ECRAN 1   : CONSCPQ1                                                  #
# ECRAN 2   : CONSCPQ2                                                  #
# ECRAN CRIT: CRITCPQ                                                   #
#########################################################################
Local Char PARAM(20)(1..2)
PARAM(1) = "2204"
PARAM(2) = "GAL"
Call GCONSULT("CPQ","",PARAM) From GCONSULT
End

#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "AB2_NBLIG"  : Gosub AB2_NBLIG
  When "LECTURE"    : Gosub LECTURE
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "DEB_CRIT"   : Gosub DEB_CRIT
  When Default
Endcase
Return

############################################################
$AUTORIS
Return

###################################################################
# analyse paramères, initialisations, ouvertures et déclarations  #
###################################################################
$OUVRE
NAVIG="CONSCPQ"
Local Char    WFIL(250),WFIL1(250),WFIL2(250),WFIL3(250)
Local Char    DEBNUM(GLONPNH), FINNUM(GLONPNH)
Local Date    DEBDAT, FINDAT
Local Integer DEBLIN, FINLIN :# 69747

Gosub DEFCRIT
Return

# --------------------------------------------------------------------------#
# Analyse paramères, initialisations                                        #
# --------------------------------------------------------------------------#
$DEFCRIT
# Issue 81125 - 2012-03-29 by MUARN : consultation lignes
#If GNBAUZ=1 : PARAM(2)=GUSRFCY(1) : Endif
If GNBAUZ=1 : PARAM(3)=GUSRFCY(1) : Endif
For I = 1 To dim(PARAM)
  Case I
    When 1 :    : # Parametre article
      If PARAM(I) <> ""
        If [F:ITM]ITMREF <> PARAM(I) Read [ITM] ITM0 = PARAM(I)
                                     If fstat  Raz [F:ITM], PARAM(I) : Endif
        Endif
        [M:CPQ1]ITMREF = PARAM(I)
      Endif

    When 2 :    : # Parametre fournisseur
      If PARAM(I) <> ""
        If [F:BPS]BPSNUM <> PARAM(I) Read [BPS] BPS0 = PARAM(I)
                                     If fstat  Raz [F:BPS], PARAM(I) : Endif
        Endif
#US 71069/138  by RBA
#        [M:CPQ1]BPSNUM = PARAM(I)
        [M:CPQ1]BPSNUMDEB = PARAM(I)
        [M:CPQ1]BPSNUMFIN = PARAM(I)
#/US 71069/138  by RBA
      Endif
    When 3 :    : # Parametre Site
      If PARAM(I) <> ""
        If [F:FCY]FCY <> PARAM(I)    Read [FCY] FCY0 = PARAM(I)
                                     If fstat  Raz [F:FCY], PARAM(I) : Endif
        Endif
        If (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
          [M:CPQ1]PNHFCY = PARAM(I)
          [M:CPQ1]CPY = GSOCIETE
        Endif
      Endif
    When 4 :    : # Parametre PJT
      # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
      If PARAM(I) <> "" Then
        [M:CPQ1]PJTDEB = PARAM(I)
        [M:CPQ1]PJTFIN = PARAM(I)
        If find(GNAVIG(GPILNAV-0),"GESPJM") Then   # Note FGR : '-0' is not an error. This is true in this case.
          [M:CPQ1]PJTDSPALL = [V]CST_AYES
        Endif
      Endif
      # Issue Issue X3-15598 - 2017-02-23 by FGR : END
    When 5 :    : # Parametre DATBEG
      # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
      If PARAM(I) <> "" and PARAM(I) <> "000000" Then
        [M:CPQ1]RTNDATDEB = PARAM(I)
        [M:CPQ1]RTNDATDEB = gdat$(01,month([M:CPQ1]RTNDATDEB),year([M:CPQ1]RTNDATDEB))
      Endif
      # Issue Issue X3-15598 - 2017-02-23 by FGR : END
  Endcase
Next I
# validé oui
If !find([M:CPQ1]CFMFLGO,1,2) : [M:CPQ1]CFMFLGO= 2 : Endif
# validé non
If !find([M:CPQ1]CFMFLGN,1,2) : [M:CPQ1]CFMFLGN= 2 : Endif
# facturée oui
If !find([M:CPQ1]INVFLGO,1,2) : [M:CPQ1]INVFLGO= 2 : Endif
# facturée non
If !find([M:CPQ1]INVFLGN,1,2) : [M:CPQ1]INVFLGN= 2 : Endif
# comptabilisée oui
If !find([M:CCPQ]PSTFLGO,1,2) : [M:CCPQ]PSTFLGO= 2 : Endif
# comptabilisée non
If !find([M:CCPQ]PSTFLGN,1,2) : [M:CCPQ]PSTFLGN= 2 : Endif
# imprimée oui
If !find([M:CCPQ]PRNFLGO,1,2) : [M:CCPQ]PRNFLGO= 2 : Endif
# imprimée non
If !find([M:CCPQ]PRNFLGN,1,2) : [M:CCPQ]PRNFLGN= 2 : Endif
If !find([M:CCPQ]TRI,1,2)     : [M:CCPQ]TRI = 1   : Endif
#----- Initialisation dates début et fin -----#
Gosub INIT_DATES From TRTACHGRH1
# Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
#[M:CPQ1]RTNDATDEB=WDATDEB
If [M:CPQ1]RTNDATDEB = [0/0/0] Then
  [M:CPQ1]RTNDATDEB=WDATDEB
Endif
# Issue Issue X3-15598 - 2017-02-23 by FGR : END
[M:CPQ1]RTNDATFIN=WDATFIN
#----- Copie du masque 1 (CPQ1) vers l'écran critères (CCPQ) -----#
Gosub CRITENT From =PROGCNS
Return
############################################################
$DEB_CRIT
#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM","GESITF")
        If find(GNAVIG(GPILNAV-1),"GESITM")
            Diszo [M:CCPQ]ITMREF
        Elsif find(GNAVIG(GPILNAV-1),"GESITF")
            Diszo [M:CCPQ]ITMREF
            Diszo [M:CCPQ]PNHFCY
            Diszo [M:CCPQ]CPY
        Endif
        If dim([M:CCPQ]TSICOD) > 0
          For I = 0 To dim([M:CCPQ]TSICOD)-1
            Diszo [M:CCPQ]TSICOD(I)
          Next I
        Endif
    Endif
    #acces depuis clients ou fournisseurs
    If find(GNAVIG(GPILNAV-1),"GESBPS","GESBPC")
#        Diszo [M:CCPQ]BPSNUM
        Diszo [M:CCPQ]BPSNUMDEB : Diszo [M:CCPQ]BPSNUMFIN
        If dim([M:CCPQ]TSICOD) > 0
          For I = 0 To dim([M:CCPQ]TSICOD)-1
            Diszo [M:CCPQ]TSICOD(I)
          Next I
        Endif
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
    If find(GNAVIG(GPILNAV-1),"GESPJM","PJMACTBUD", "PJMACTTAS") Then
      Diszo [M:CCPQ]PJTDEB
      Diszo [M:CCPQ]PJTFIN
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : END
Endif

Return
############################################################
$LECTURE
Local   Decimal  WMNTORG(0..1), WMNTDES(0..1)
Local   Integer  SPSTAT


#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM")
        Diszo [M:CPQ1]ITMREF
    Elsif find(GNAVIG(GPILNAV-1),"GESITF")
        Diszo [M:CPQ1]ITMREF
        Diszo [M:CPQ1]PNHFCY
        Diszo [M:CPQ1]CPY
    Endif

    #acces depuis clients ou fournisseurs
    If find(GNAVIG(GPILNAV-1),"GESBPS","GESBPC")
#        Diszo [M:CPQ1]BPSNUM
        Diszo [M:CPQ1]BPSNUMDEB : Diszo [M:CPQ1]BPSNUMFIN
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
    If find(GNAVIG(GPILNAV-1),"GESPJM","PJMACTBUD", "PJMACTTAS") Then
      Diszo [M:CPQ1]PJTDEB
      Diszo [M:CPQ1]PJTFIN
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : END
Endif

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

Link [PND] With [PNH]PNH0=[PND]PNHNUM
&          As [LNK]


# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CCPQ]TRI
      When 1 : # tri par numéro
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) Order By Key PND0
      When 2 : # tri par date
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&                    Order By Key CLE=[F:PNH]RTNDAT;[F:PND]PNHNUM;[F:PND]PNDLIN :# 69747
#&                    Order By Key CLE=[F:PNH]RTNDAT;[F:PND]PNHNUM
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CCPQ]TRI
      When 1 : # tri par numéro
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) Order By Key PND0 Desc
      When 2 : # tri par date
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&                    Order By [F:PNH]RTNDAT Desc ;[F:PND]PNHNUM Desc;[F:PND]PNDLIN Desc :# 69747
#&                    Order By [F:PNH]RTNDAT Desc ;[F:PND]PNHNUM Desc
    Endcase
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CPQ2] : Endif

#-- lecture
$BOUCLE
For [LNK]

# Filtre sur la société
  If [M:CPQ1]CPY <> ""
      If [F:FCY]FCY <> [F:PNH]PNHFCY Read [FCY] FCY0 = [F:PNH]PNHFCY
                                     If fstat  Raz [F:FCY] : Endif
                                     Endif
      If [F:FCY]LEGCPY <> [M:CPQ1]CPY Goto SUIV : Endif
  Endif

  If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:CPQ2] : Endif
     NBLU = 2
  Endif
  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
     NOL    += 1
     If NOL=0
         #69747
         If CHGPAG=2
           If [F:PND]PNHNUM=FINNUM and [F:PND]PNDLIN<=FINLIN : NOL-=1 : Goto SUIV : Endif
         Endif
         #fin 69747
         DEBNUM = [F:PNH]PNHNUM
         DEBDAT = [F:PNH]RTNDAT
         DEBLIN = [F:PND]PNDLIN :# 69747
     Endif
     FINNUM = [F:PNH]PNHNUM
     FINDAT = [F:PNH]RTNDAT
     FINLIN = [F:PND]PNDLIN :# 69747
  Else
     If NOL <= 0 : RETOUR=2 : Break : Endif
     NOL    -= 1
     If NOL=MAXLIG-1
         #69747
         If CHGPAG=-2
           If [F:PND]PNHNUM=DEBNUM and [F:PND]PNDLIN>=DEBLIN : NOL+=1 : Goto SUIV : Endif
         Endif
         #fin 69747
         FINNUM = [F:PNH]PNHNUM
         FINDAT = [F:PNH]RTNDAT
         FINLIN = [F:PND]PNDLIN :# 69747
     Endif
     DEBNUM = [F:PNH]PNHNUM
     DEBDAT = [F:PNH]RTNDAT
     DEBLIN = [F:PND]PNDLIN :# 69747
  Endif

  nolign = NOL+1
  [M:CPQ2]=[F:PNH] : # trans classe sur PRETURN
  [M:CPQ2]=[F:PND] : # trans classe sur PRETURND

  #US 71069/13  PJT by RBA
  [M:CPQ2]PJT(nolign-1)       = [F:PND]PJT
  #/US 71069/13  PJT by RBA

  $SUIV
Next
Filter [LNK]
Return

############################################################
#    Préparation du filtre                                 #
############################################################
$LOAD_FILTER
WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"
WFIL3 = "1=1"

# Site de retour
If [M:CPQ1]PNHFCY <> ""
   WFIL += "&[F:PNH]PNHFCY=[M:CPQ1]PNHFCY"
Endif
# Autorisation site
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
   WFIL += "& find([F:PNH]PNHFCY,GUSRFCY(1..GNBAUZ))"
Endif
## Numéro de fournisseur
#If [M:CPQ1]BPSNUM <> ""
#   WFIL += "&[F:PNH]BPSNUM =[M:CPQ1]BPSNUM"
#Endif

# Numéro de fournisseur
If [M:CPQ1]BPSNUMDEB <> ""
   WFIL3 += "&[F:PNH]BPSNUM >=[M:CPQ1]BPSNUMDEB"
Endif
If [M:CPQ1]BPSNUMFIN <> ""
   WFIL3 += "&[F:PNH]BPSNUM <=[M:CPQ1]BPSNUMFIN"
Endif

# Article
If [M:CPQ1]ITMREF <> ""
   WFIL += "&[F:PND]ITMREF =[M:CPQ1]ITMREF"
Endif


#    Prise en compte des retours validés
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPQ1]CFMFLGO= 1
   WFIL1 += "&[F:PNH]CFMFLG<>2"
Endif

#    Prise en compte des retours non validés
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPQ1]CFMFLGN= 1
   WFIL1 += "&[F:PNH]CFMFLG=2"
Endif

#    Prise en compte des retours facturées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPQ1]INVFLGO= 1
   WFIL1 += "&[F:PNH]INVFLG<3"
Endif

#    Prise en compte des retours non facturées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPQ1]INVFLGN= 1
   WFIL1 += "&[F:PNH]INVFLG>2"
Endif

#    Prise en compte des retours comptabilisées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPQ]PSTFLGO= 1
   WFIL1 += "&[F:PNH]PSTFLG<>2"
Endif

#    Prise en compte des retours non comptabilisées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPQ]PSTFLGN= 1
   WFIL1 += "&[F:PNH]PSTFLG=2"
Endif

#    Prise en compte des retours    imprimées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPQ]PRNFLGO= 1
   WFIL1 += "&[F:PNH]PRNFLG<>2"
Endif

#    Prise en compte des retours    non imprimées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPQ]PRNFLGN= 1
   WFIL1 += "&[F:PNH]PRNFLG=2"
Endif


If [M:CCPQ]PNHNUMDEB <> ""
   WFIL += "&[F:PNH]PNHNUM>=[M:CCPQ]PNHNUMDEB"
Endif
If [M:CCPQ]PNHNUMFIN <> ""
   WFIL += "&[F:PNH]PNHNUM<=[M:CCPQ]PNHNUMFIN"
Endif

If [M:CCPQ]RTNDATDEB <> [0/0/0]
   WFIL += "&[F:PNH]RTNDAT>=[M:CCPQ]RTNDATDEB"
Endif
If [M:CCPQ]RTNDATFIN <> [0/0/0]
   WFIL += "&[F:PNH]RTNDAT<=[M:CCPQ]RTNDATFIN"
Endif

If dim([M:CCPQ]TSICOD) > 0
  For I = 0 To dim([M:CCPQ]TSICOD)-1
    If [M:CCPQ]TSICOD(I) <> ""
      If len(WFIL) > 200
        WFIL2 += "&[F:PND]TSICOD("+num$(I)+")='"+[M:CCPQ]TSICOD(I)+"'"
      Else
        WFIL += "&[F:PND]TSICOD("+num$(I)+")='"+[M:CCPQ]TSICOD(I)+"'"
      Endif
    Endif
  Next I
Endif

If dim([M:CCPQ]TSSCOD) > 0
  For I = 0 To dim([M:CCPQ]TSSCOD)-1
    If [M:CCPQ]TSSCOD(I) <> ""
      If len(WFIL) > 200
        WFIL1 += "&[F:PNH]TSSCOD("+num$(I)+")='"+[M:CCPQ]TSSCOD(I)+"'"
      Else
        WFIL += "&[F:PNH]TSSCOD("+num$(I)+")='"+[M:CCPQ]TSSCOD(I)+"'"
      Endif
    Endif
  Next I
Endif

# Issue X3-25731 - 2017-02-24 by FGR : BEGIN
##US 71069/13  PJT by RBA
#If [M:CCPQ]PJTDEB <> ""
#   WFIL3 += "&[F:PND]PJT>=[M:CCPQ]PJTDEB"
#Endif
#If [M:CCPQ]PJTFIN <> ""
#   WFIL3 += "&[F:PND]PJT<=[M:CCPQ]PJTFIN"
#Endif
##/US 71069/13  PJT by RBA
If dim([M:CCPQ]PJTDSPALL) >= 0 and [M:CCPQ]PJTDSPALL = [V]CST_AYES and [M:CCPQ]PJTDEB <> "" Then
  Local Char SPJT(GLONPIM)
  Local Char SBUDGET(GLONTAC)
  Local Char STASK(GLONPBU)
  Local Integer IRET

  IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:CCPQ]PJTDEB, SPJT, SBUDGET, STASK)
  WFIL1 += "&pat([F:PND]PJT,'" + SPJT + "*')<>0"
Else
  If [M:CCPQ]PJTDEB <> ""
     WFIL3 += "&[F:PND]PJT>=[M:CCPQ]PJTDEB"
  Endif
  If [M:CCPQ]PJTFIN <> ""
     WFIL3 += "&[F:PND]PJT<=[M:CCPQ]PJTFIN"
  Endif
Endif
# Issue X3-25731 - 2017-02-24 by FGR : END

Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CCPQ]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:PNH]PNHNUM>=DEBNUM"
       When 2 : # tri par date
           WFIL += "&([F:PNH]RTNDAT>DEBDAT | ([F:PNH]RTNDAT=DEBDAT & [F:PNH]PNHNUM>=DEBNUM))"
     Endcase
   When 2 : # suite
     Case [M:CCPQ]TRI
       When 1 : # tri par numéro
           #WFIL += "&[F:PNH]PNHNUM>FINNUM"
           WFIL += "&[F:PNH]PNHNUM>=FINNUM" :# 69747
       When 2 : # tri par date
           #WFIL += "&([F:PNH]RTNDAT>FINDAT | ([F:PNH]RTNDAT=FINDAT & [F:PNH]PNHNUM>FINNUM))"
           WFIL += "&([F:PNH]RTNDAT>FINDAT | ([F:PNH]RTNDAT=FINDAT & [F:PNH]PNHNUM>=FINNUM))" :# 69747
     Endcase
   When -2 : # retour
     Case [M:CCPQ]TRI
       When 1 : # tri par numéro
           #WFIL += "&[F:PNH]PNHNUM<DEBNUM"
           WFIL += "&[F:PNH]PNHNUM<=DEBNUM" :# 69747
       When 2 : # tri par date
           #WFIL += "&([F:PNH]RTNDAT<DEBDAT | ([F:PNH]RTNDAT=DEBDAT & [F:PNH]PNHNUM<DEBNUM))"
           WFIL += "&([F:PNH]RTNDAT<DEBDAT | ([F:PNH]RTNDAT=DEBDAT & [F:PNH]PNHNUM<=DEBNUM))" :# 69747
     Endcase
Endcase

Return


$AB2_NBLIG
Local Char    WOBJET(GLONAOB)
If [M:CPQ2]POHTYP(nolign-1) = 1
    WOBJET= "POH"
Endif
If [M:CPQ2]POHTYP(nolign-1) = 2
    WOBJET= "POC"
Endif
Return


############################################################################
#    Avant de fermer la fenetre critère et de revenir à fenetre principale #
############################################################################
$FIN_CRIT
Return


#############################################################
##     Etiquettes masques CONSPOH1 & CONSPOH2 & CRITPOH    ##
#############################################################

Subprog AV_CPY(VALEUR)
#----------------------#
# Avant zone           #
#----------------------#
Variable Char     VALEUR
If GNBAUZ=1 : Diszo [M]CPY, PNHFCY : Endif
End

Subprog C_CPY(VALEUR)
#-------------------------------#
# Contrôle de la société        #
#-------------------------------#
Variable Char     VALEUR
If VALEUR <> ""
  GLOCALDEV=[F:CPY]ACCCUR
Elsif [M]PNHFCY = ""
  GSOCIETE="" : GLOCALDEV=""
Endif
End

Subprog AM_CPY(VALEUR)
#-------------------------------#
# Après modif de la société     #
#-------------------------------#
Variable Char     VALEUR
Affzo ZCPY : # Utilisé par 2 écrans on ne précise pas la classe
Raz [M]PNHFCY, [M]ZPNHFCY
Affzo PNHFCY, ZPNHFCY : # Utilisé par 2 écrans on ne précise pas la classe
If VALEUR<>""  GSOCIETE=VALEUR : Endif
End

Subprog C_PNHFCY(VALEUR)
#------------------------------------------------#
# Chargement de la devise
#------------------------------------------------#
Variable Char    VALEUR()
If VALEUR <> ""
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE
Elsif [M]CPY = ""
    GSOCIETE="" : GLOCALDEV=""
Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif
End

#-------------------------------#
# Après modif du site           #
#-------------------------------#
Subprog AM_PNHFCY(VALEUR)
Variable Char     VALEUR
If VALEUR <> ""
  Affzo CPY, ZCPY : # Utilisé par 2 ecrans
Endif
End

#----------------------------#
# Initialisation  bouton     #
#----------------------------#
Subprog IB_NBLIG
Raz GBOUT1, GBOUT2, GBOUT3
If [M:CPQ2]NBLIG<>0
   If clalev([M:PQH1])=0
     GBOUT1=mess(192,198,1)-[M:CPQ2]PNHNUM(nolign-1) : # Retours
   Endif
   If [M:CPQ2]POHNUM(nolign-1)<>""
       If [M:CPQ2]POHTYP(nolign-1) = 1
            GBOUT2=mess(2,306,1)-[M:CPQ2]POHNUM(nolign-1) : # Commande fournisseur
       Endif
       If [M:CPQ2]POHTYP(nolign-1) = 2
             GBOUT2=mess(2,506,1)-[M:CPQ2]POHNUM(nolign-1) : # Commande ouverte
       Endif
    Endif
   If [M:CPQ2]PTHNUM(nolign-1)<>""
     GBOUT3=mess(117,198,1)-[M:CPQ2]PTHNUM(nolign-1) : # Réceptions
   Endif

Endif
End

#-------------------------------------#
# Après modification de la date début #
#-------------------------------------#
Subprog AM_RTNDATDEB(VALEUR)
Variable Date     VALEUR
#----- Recalcul date fin en fonction de la périodicité et du nbre de périodes -----#
If dim([M]PERCOD)>0
  Local Date WDATE
  Call CALDATPER([M]PERCOD,[M]PERNBR,"+",[M]RTNDATDEB,VALEUR,WDATE) From TRTX3DAT
  If WDATE<>[0/0/0]
    [M]RTNDATFIN=WDATE : Affzo RTNDATFIN
  Endif
Elsif VALEUR>[M]RTNDATFIN
  [M]RTNDATFIN=VALEUR
Endif
End

#-----------------------------------#
# Après modification de la date fin #
#-----------------------------------#
Subprog AM_RTNDATFIN(VALEUR)
Variable Date    VALEUR
If dim([M]PERCOD)<1  End : Endif
#----- Recalcul date début en fonction de la périodicité et du nbre de périodes -----#
Local Date WDATE
Call CALDATPER([M]PERCOD,[M]PERNBR,"-",[M]RTNDATFIN,VALEUR,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]RTNDATDEB=WDATE : Affzo RTNDATDEB
Endif
#-----
End

#---------------------------------------------------#
#      Controle du numéro de retour   fin           #
# ------------------------------------------------- #
Subprog C_PNHNUMFIN(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" & VALEUR<[M]PNHNUMDEB : mkstat = 1 : End : Endif
End


#########################################################################
# Pour exécution de la validation des consultations en gestion de patch #
#########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(5)<>2 End : Endif
Call VALGTC(APPLI,"CPQ") From SUBGTC
End

#US 71069/13  PJT by RBA
Subprog AS_PJTFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]PJTDEB
Endif
End

Subprog C_PJTFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]PJTDEB
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End
#/US 71069/13  PJT by RBA

