#<AdxTL>@(#)4.0.0.0 $Revision$
##############################################################################
# Pilotage des plans de suivi                    GPAO 150
##############################################################################
# ACTION = SAIBENPLT
##############################################################################
$ACTION
Case ACTION
    When "INIT"          : Gosub INIT
    When "SEL_LISTE"     : Gosub SEL_LISTE
    When "FIN_LISTE"     : Gosub FIN_LISTE
    When "CONTROLE"      : Gosub CONTROLE
    When "OUVRE"         : Gosub OUVRE
    When "TITRE"         : Gosub TIT
    When "DEBUT"         : Gosub DEBUT
    When "SETBOUT"       : Gosub SETBOUT
    When "AVANT_BOUTON"  : Gosub AVANTBOUT
    When "BOUTON"        : Gosub BOUTON
    When "ABA"           : Gosub ABA    
    When "FIN"           : Gosub FIN
    When "TERMINE"       : Gosub TERMINE
    When "BB1_NBLIG"     : Gosub BB1_NBLIG
    When Default         :   
Endcase
Return

###########################################################################
$INIT
Local Integer     OK
Raz GSTATUT
#--- Lignes suivantes à activer si besoin
#If GUSER <> "SR" Infbox "en cours de mise au point... !!!"
#   OK = 0
#    FIN = 1
#    Return 
#Endif    
Global Char    GMPLNUM(GLONTRS)
Return

###########################################################################
# selection de la transaction
$SEL_LISTE
# sr 10.05 demande 32570
Local Char     TABACS(10)(100)
Local Integer  NBACS
Local Char     TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char     TIT(30)
Local Integer  NBTEX

If clalev ([F:BTS])=0  : Local File BENCHTRS [BTS] : Endif
If clalev([F:ACC]) = 0 : Local File ACCES [ACC] : Endif 
CRITERE = "BTSTYP=65&ENAFLG=2"                                             
# sr 10.05 demande 32570
If GPROFIL <> GSUPER                             
    For [ACC]CODACC Where USR=GUSER
       If [F:ACC]EXEC=2 [L]TABACS(NBACS)=vireblc([F:ACC]CODACC,1) : NBACS +=1
       Endif
       If NBACS>99 Break : Endif
    Next
    CRITERE += "& (ACSCOD = ''  | find(ACSCOD,TABACS(0..99)))"
Endif
For [F:BTS] Where evalue(CRITERE)
    NBTEX+= 1
    TEX(NBTEX)   =[F:BTS]BTSNUM
    Call LECTEXTRA(TEXTE(NBTEX),"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
    TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
Next
TIT(0) = mess(3,126,1) # Choix transactions
Return

###########################################################################
$FIN_LISTE
If GSTATUT = 7  : GMPLNUM = "" : Return : Endif
GMPLNUM = TEX(CHOIX)
Return

###########################################################################
$CONTROLE
If clalev ([F:BTS]) <= 0  : Local File BENCHTRS [BTS] : Endif
Read [BTS]BTS0=65;GMPLNUM
If fstat  | [F:BTS]ENAFLG = 1 : FIN = 1 : Return : Endif

Return 

########################################################################################
$OUVRE
Global Char       SAV_GFONC1 : SAV_GFONC1 = GFONC1
GFONC1 = "FUNBENPLT"
#
Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218

Gosub OPEN_FILE
Gosub CHARG_PARAM
#
Local Integer TRA : TRA = 0

Gosub LECTURE_BTS

# substitution fenêtre
BOITE     = "WIMBP"+GMPLNUM
WMASQUE   = "WT65"+GMPLNUM+"1"

#MAE, le 31/01/08, GRP_SITE
GGRPFCY = [F:BTS]GFY       

Gosub CHANGE_AWI From BENCHLIB

Return

#########################################################################
$TIT
    Call LECTEXTRA(TIT,"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
    If !clalev([F:AWI]) : Local File AWINDOW : Endif
    Read [AWI]AWI0=BOITE
    Call TEXTE([F:AWI]DES,GBIDC1) From OBJDIV
    TIT = GBIDC1-[F:BTS]BTSNUM-":"-TIT
Return

####################################################################################
$DEBUT
Raz    [M:MBP]
[M:MBP]FCY = GFCY
[M:MBP]FILTDEF  = [F:BTS]FILTDEF
[M:MBP]CRIT1    = [F:BTS]CRIT1
# 15806 MM 05.05 : application memo STD
If filinfo(filpath("ETM",GUSER+"_"+GMPLNUM+"_"+"STD","mbp",0),0)>=0
    Call LECMEMO("STD","[M:MTB4]",GMPLNUM+"~mbp") From GMEMO
    [M:MBP] = [M:MTB4]
    Affzo [M:MBP]10
Endif


Return

#########################################################################
$SETBOUT
ETABOU(GSPE1) = 1                                     # recherche
ETABOU(GSPE2) = 1                                     # critères
ETABOU(GSPE3) = [F:BTS]MOLFLG - 1                     # Plan de suivi des temps
ETABOU(GSPE4) = [F:BTS]MILFLG - 1                     # Plan de production
ETABOU(GSPE5) = [F:BTS]MMLFLG - 1                     # Plan de consommation
ETABOU(GSPE6) = [F:BTS]MREFLG - 1                     # Plan de réintégration
ETABOU(GSPE7) = [F:BTS]MCLFLG - 1                     # Plan des fiches techniques
ETABOU(GSPE8) = 1                                     # Inclure
ETABOU(GSPE9) = 1                                     # Exclure
ETABOU(GABAN) = 1                                    
If [F:BTS]MFGMODFLT = 2
  ETABOU(GSPE3) = 0
  ETABOU(GSPE7) = 0
Elsif [F:BTS]MFGMODFLT = 3
  ETABOU(GSPE5) = 0  
  ETABOU(GSPE6) = 0  
Endif
Return

#########################################################################
$AVANTBOUT
Local Integer WORI
Raz [M:MTPK]


Case BOUT
    When "3" : WORI = 3 : Gosub CHARG_MTPK
    When "4" : WORI = 4 : Gosub CHARG_MTPK
    When "5" : WORI = 5 : Gosub CHARG_MTPK
    When "6" : WORI = 6 : Gosub CHARG_MTPK
    When "7" : WORI = 7 : Gosub CHARG_MTPK
Endcase
If find(BOUT,"3","4","5","6","7") & [M:MTPK]NBLIG = 0
            Call FERME_TRACE From LECFIC
            If TRA = 1 
                # Mettre GPOINT = "" pour inhiber l'action standard
                GPOINT = "AFFTRA"
                Gosub  ENTREE From EXEFNC 
                If GPOINT <> ""
                   Call LEC_TRACE From LECFIC 
                Endif
                TRA = 0
            Endif 
            GERR=1 : GMESSAGE=mess(219,193,1) 
            Return
Endif
Return

########################################################################
$BOUTON
Case BOUT
    When "1"       :     Gosub CHARG_MASK
    When "2"       :     If [M:MBP]REACT = 2 : Gosub CHARG_MASK : [M:MBP]REACT = 1 : Endif
    When "3","4","5","6","7" :     If GMESSAGE <> "" : Call ERREUR(GMESSAGE) From GESECRAN : Endif
                                   Call FERME_TRACE From LECFIC
                                   If TRA = 1 
                                      # demande 12362 ne pas afficher la trace 
                                      # Mettre GPOINT = "" pour inhiber l'action standard
                                      GPOINT = "AFFTRA"
                                      Gosub  ENTREE From EXEFNC 
                                      If GPOINT <> ""
                                         Call LEC_TRACE From LECFIC 
                                      Endif
                                   Endif 
                                   TRA = 0
                                   Gosub LECTURE_BTS : Gosub CHARG_MASK : [M:MBP]REACT = 1
    When "8"       :     Gosub INCLURE
    When "9"       :     Gosub EXCLURE
Endcase
Return

#########################################################################
$INCLURE
Local Integer I
For I = 0 To [M:MBP]NBLIG-1
    [M:MBP]PECFLG(I) = 2
Next
Affzo [M:MBP]15
Return

#########################################################################
$EXCLURE
Local Integer I
For I = 0 To [M:MBP]NBLIG-1
    [M:MBP]PECFLG(I) = 1
Next
Affzo [M:MBP]15
Return

#########################################################################
$AP_CHOIX
# interception de la touche return
If REPONSE = GSTARET
    Gosub CHARG_MASK
Endif
Return

#########################################################################
$PILOTAGE
Gosub LECTURE_BTS
Local Integer I

I = find([F:MFG]MFGNUM,[M:MBP]MFGNUM(0..[M:MBP]NBLIG-1))
If I
    [M:MBP]ALLSTA(I-1) = [F:MFG]ALLSTA
    [M:MBP]SCDFLG(I-1) = [F:MFG]SCDFLG
    [M:MBP]SCDMOD(I-1) = [F:MFG]SCDMOD
Endif
Affzo  [M:MBP]ALLSTA(I-1), SCDFLG(I-1), SCDMOD(I-1)
Return

########################################################################
$CHARG_MTPK
# chargement du buffer de travail
# si lancement du plan de production, on prend tout ce qui est coché
# si lancement du plan de suivi des temps on ne prend pas le OF matières seules
# si lancement du plan de consommation, on ne prend pas les of opérations seules
# si lancement du plan de réintégration, on ne prend pas les of opérations seules  ou les of en attente
# on controle de plus qu'au moins une matière a été suivie
# si lancement fiches techniques on ne prend pas les of matières seules et les of en attente, on vérifie qu'au moins
# un suivi opératoire a été fait et qu'il y a une fiche technique
Local Integer I,J
Raz I,J
Local Char TIT, WMESS(250)
TIT = mess(246,195,1)
TRA=0
Call OUVRE_TRACE(TIT) From LECFIC
Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
Call ECR_TRACE(" ",0) From GESECRAN 
Raz WMESS
Raz [M:MTPK]
For I = 0 To [M:MBP]NBLIG
    If [M:MBP]PECFLG(I) = 2
        If J > dim([M:MTPK]MFGNUM) - 2 : Break : Endif
        Read [F:MFG]MFG0 = [M:MBP]MFGNUM(I)
        If fstat : Raz [F:MFG] : Endif
        Case WORI
             When 3 : If [F:MFG]MFGMOD <> 2
                         [M:MTPK]MFGNUM(J) = [M:MBP]MFGNUM(I)
                         J+=1                       
                      Else  
                         WMESS = [F:MFG]MFGNUM+" : "+mess(240,193,1)
                         Gosub ECR_TRACE
                      Endif
             When 4 : [M:MTPK]MFGNUM(J) = [M:MBP]MFGNUM(I)
                      J+=1                       
             When 5 : If [F:MFG]MFGMOD <> 3
                         [M:MTPK]MFGNUM(J) = [M:MBP]MFGNUM(I)
                         J+=1              
                      Else
                          WMESS = [F:MFG]MFGNUM+" : "+mess(240,193,1)
                         Gosub ECR_TRACE
                      Endif           
             When 6 : If [F:MFG]MFGMOD <> 3 & [F:MFG]MFGTRKFLG > 3
                         Filter [F:MFM] Where MFGNUM = [F:MFG]MFGNUM & USEQTY <> 0
                         Look [F:MFM]MFM0 First
                         If !fstat
                             [M:MTPK]MFGNUM(J) = [M:MBP]MFGNUM(I)
                             J+=1                       
                         Else
                              WMESS = [F:MFG]MFGNUM+" : "+mess(241,193,1)
                               Gosub ECR_TRACE
                         Endif
                      Else  
                          If [F:MFG]MFGMOD = 3  
                              WMESS = [F:MFG]MFGNUM+" : "+mess(240,193,1)
                               Gosub ECR_TRACE
                          Else
                              WMESS = [F:MFG]MFGNUM+" : "+mess(241,193,1)
                              Gosub ECR_TRACE
                         Endif
                      Endif
             When 7 : If [F:MFG]MFGMOD <> 2 & [F:MFG]MFGTRKFLG > 3 
                         Filter [F:MKO] Where MFGNUM = [F:MFG]MFGNUM & TECCRD <> ""
                         Look [F:MKO]MKO0 First
                         If !fstat
                             [M:MTPK]MFGNUM(J) = [M:MBP]MFGNUM(I)
                             J+=1 
                         Else
                              WMESS = [F:MFG]MFGNUM+" : "+mess(242,193,1)
                              Gosub ECR_TRACE
                         Endif
                       Else
                          If [F:MFG]MFGMOD = 2  
                              WMESS = [F:MFG]MFGNUM+" : "+mess(240,193,1)
                              Gosub ECR_TRACE
                          Else
                              WMESS = [F:MFG]MFGNUM+" : "+mess(242,193,1)
                              Gosub ECR_TRACE
                         Endif
                      Endif
        Endcase
    Endif
Next  
WMESS = "---------------------------------------"
Call ECR_TRACE(WMESS,0) From GESECRAN
[M:MTPK]NBLIG = J
Return


$ECR_TRACE
If TRA = 0
    Call ECR_TRACE(mess(243,193,1),0) From GESECRAN
Endif
Call ECR_TRACE(WMESS,0) From GESECRAN
TRA = 1
Return



#######################################################################
$OPEN_FILE 
If clalev([M:MTPK])=0 : Local Mask MTPK      [MTPK] : Endif       # masque buffer clés des OF à traiter
If clalev([F:BTS])<=0 : Local File BENCHTRS  [BTS]  : Endif
If clalev([F:ITM])<=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITG])<=0 : Local File ITMCATEG   [ITG] : Endif
If clalev([F:ITF])<=0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITV])<=0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:MFG])<=0 : Local File MFGHEAD    [MFG] : Endif
If clalev([F:MFI])<=0 : Local File MFGITM     [MFI] : Endif
If clalev([F:MFM])<=0 : Local File MFGMAT     [MFM] : Endif
If clalev([F:MFO])<=0 : Local File MFGOPE     [MFO] : Endif
If clalev([F:MKO])<=0 : Local File MFGOPETRK  [MKO] : Endif
If clalev([F:TCA])<=0 : Local File TABCOUAFF  [TCA] : Endif 
If clalev([F:TFO])<=0 : Local File TABFOR     [TFO] : Endif
If clalev([F:SRU])<=0 : Local File TABSTORUL  [SRU] : Endif
If clalev([M:MTB4])=0 : Local Mask MTKBCRIT4 [MTB4] : Endif       # 15806 MM 05.05 : gestion memo STD


Return

######################################################################## 
$LECTURE_BTS
GFONC1 = "FUNBENPLT"
#----- Relecture transaction de saisie  -----#
If [F:BTS]BTSTYP <> 65 | [F:BTS]BTSNUM <> GMPLNUM
    Read [BTS]BTS0=65;GMPLNUM : If fstat Raz [F:BTS] : Endif
Endif
GFLAG   = [F:BTS]BTSNUM
Return

######################################################################## 
$CHARG_PARAM 
Call GETDEV(GFCY)     From DEVSUB # pour récupérer GSOCIETE

#----- Variables globales stock 
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return 

###############################################################
$CHARG_MASK
Local Char CRITERE2(255)
Local Char CRITERE(255)
# sr 09.01 CUSFLT zone de filtres supplémentaires demande 10405
Local Char CUSFLT(255)
Local Char FORMULE1(255)

CRITERE  = "1=1"
CRITERE2 = "1=1"
Raz FORMULE1
Local Integer WMAX : WMAX = dim([M:MBP]MFGNUM) - 2
Local Decimal LDIS
Local Integer STA
Local Integer OK

Effzo [M:MBP]15
[M:MBP]MOLTRS = [F:BTS]MOLTRS
[M:MBP]MILTRS = [F:BTS]MILTRS
[M:MBP]MMLTRS = [F:BTS]MMLTRS
[M:MBP]MRETRS = [F:BTS]MRETRS
[M:MBP]MCLTRS = [F:BTS]MCLTRS

CRITERE += "& MFGFCY = [M:MBP]FCY" 
If [M:MBP]WMFGNUMF <> ""
      CRITERE += "& MFGNUM >= [M:MBP]WMFGNUMD & MFGNUM <= [M:MBP]WMFGNUMF"
Endif
If [M:MBP]WROUNUMF <> ""
      CRITERE += "& ROUNUM >= [M:MBP]WROUNUMD & ROUNUM <= [M:MBP]WROUNUMF"
Endif
If [M:MBP]WROUALTF <> 0
      CRITERE += "& ROUALT >= [M:MBP]WROUALTD & ROUALT <= [M:MBP]WROUALTF"
Endif
Case [F:BTS]FILTDEF
     When 1 : CRITERE -= " & MFGTRKFLG <"+num$(5)
     When 2 : CRITERE -= " & MFGTRKFLG ="+num$(5)
     When 3 : CRITERE -= " & MFGTRKFLG <"+num$(6)
Endcase 
If [F:BTS]MFGMODFLT <> 4
    CRITERE -= " & MFGMOD = [F:BTS]MFGMODFLT"
Endif
If [M:MBP]ENDDATEND <> [0/0/0]
      CRITERE2 += "& ENDDAT >= [M:MBP]ENDDATSTR & ENDDAT <= [M:MBP]ENDDATEND"
Endif
If [M:MBP]WMFGPIOF <> 0 
      CRITERE2 -= "& MFGPIO >= [M:MBP]WMFGPIOD & MFGPIO <= [M:MBP]WMFGPIOF"
Endif 
# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
# sr 09.01 demande 10405
Raz CUSFLT  
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif
Gosub ANALYSE_FORMULE
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif

#
Filter [F:MFG] Where evalue(CRITERE) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1)
nolign = 0         
For [F:MFG]
      # FQ 72235 GA 03/2011 ajout PE et d'un test GPE idem FUNBENCHO(CUSSELENR)
      GPOINT = "CUSSELENR" : GPE=1 : Gosub ENTREE From EXEFNC
      If !GPE  : Goto NEXTMFG  : Endif

      #L'OF doit être complet
      If [F:MFG]TYPMOD = 1    : Goto NEXTMFG  : Endif
      #L'OF doit être ferme 
      If [F:MFG]MFGSTA <> 1   : Goto NEXTMFG : Endif
      #L'OF ne doit pas être suspendu 
      If [F:MFG]SUSFLG = 2    : Goto NEXTMFG : Endif
      #Selon paramètre général l'OF doit être alloué complètement
      If GMTKALLMGT = 2 & !find([F:MFG]ALLSTA,3,5) & [F:MFG]MATLINNBR <> 0 
         Goto NEXTMFG
      Endif
      #Selon paramètre général, l'OF doit être édité
      If  [F:MFG]MFGTRKFLG < 3 & GDOSFAB = 2 : Goto NEXTMFG : Endif
      mkstat = 0 
     # boucle d'analyse des matières bloquantes si rupture
      For [MFM]MFM0 Where MFGNUM = [F:MFG]MFGNUM       
               If [F:MFM]SHTQTY <> 0
                  Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
                  If !fstat & [F:ITF]MFGSHTCOD = 1 
                     mkstat = 1 
                     Break
                  Endif 
               Endif
      Next
      If mkstat = 1 : Goto NEXTMFG : Endif
      mkstat = 0
      If [M:MBP]PLANNER <> ""
         For [F:MFI] Where MFGNUM = [F:MFG]MFGNUM
             If [F:MFI]PLANNER <> "" & [F:MFI]PLANNER <> [M:MBP]PLANNER
                mkstat = 1
                Break
             Endif
         Next
         If mkstat = 1 : Goto NEXTMFG : Endif
      Endif  
      If nolign+1 > WMAX : Break : Endif
      nolign  += 1
      [M:MBP] = [F:MFG]  
      [M:MBP]RMNEXTQTY(nolign-1) = [F:MFG]EXTQTY - [F:MFG]CPLQTY
      If [M:MBP]RMNEXTQTY(nolign-1) < 0 : [M:MBP]RMNEXTQTY(nolign-1) = 0 : Endif
      Call QTEARR([M:MBP]RMNEXTQTY(nolign-1),[M:MBP]STU(nolign-1)) From TRTDIV    
      # FQ 64558 GA 05/2010 conserver les lignes sélectionnées si certaines ont été cochées
      If find([F:MFG]MFGNUM, [M:MTPK]MFGNUM(0..[M:MTPK]NBLIG-1))
         [M:MBP]PECFLG(nolign-1) = 2
      Else
         [M:MBP]PECFLG(nolign-1) = 1
      Endif

   $NEXTMFG
   Next
[M:MBP]NBLIG = nolign
Filter [F:MFG]
Case [M:MBP]CRIT1
     When 1  : Sorta [M:MBP]NBLIG [M:MBP]NBLIG Order By  [M:MBP]ENDDAT(indice),
&                                                        [M:MBP]MFGNUM(indice)
     When 2: : Sorta [M:MBP]NBLIG [M:MBP]NBLIG Order By  [M:MBP]MFGNUM(indice),
&                                                        [M:MBP]ENDDAT(indice)
Endcase

# FQ 72235 GA 03/2011 ajout PE
GPOINT = "LOAMSKMBP" : Gosub ENTREE From EXEFNC
Affzo [M:MBP]5,10,15

Return


##################################################
$ANALYSE_FORMULE
# analyse présence formule de sélection
If [M:MBP]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif      
Else
    Read [F:TFO]TFO0=22;[M:MBP]FORMULE
    If fstat 
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif  
    Else  
        If FORMULE1 = "" 
            FORMULE1  = [F:TFO]FORFOR                 
        Else
            FORMULE1 += "&" 
            FORMULE1 += [F:TFO]FORFOR                 
        Endif
    Endif
Endif

Return

################################################################################################
$TERMINE
Return

################################################################################################
$FIN
GFONC1 = SAV_GFONC1
Kill GMPLNUM
Call IMPSCR From ATRTX3
Return

################################################################################################
$ABA
Effzo [M:MBP]
Return

############################
$BB1_NBLIG
Gosub LECTURE_BTS
Gosub PILOTAGE
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran MTKBENPLT) 07/01/2005 08:27:04 (SR)
######################################################################################

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY : GFCY = VALEUR : Gosub CHARG_PARAM : Endif
End

##############################
Subprog AM_ENDDATSTR(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] : [M:MBP]ENDDATEND = VALEUR : Affzo [M:MBP]ENDDATEND : Endif
End

##############################
Subprog C_ENDDATEND(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:MBP]ENDDATSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End


##############################
Subprog AM_WMFGNUMD(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]WMFGNUMF = VALEUR
                  Affzo [M]WMFGNUMF
Endif
End

##############################
Subprog C_WMFGNUMF(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]WMFGNUMD : GMESSAGE = mess(44,199,1) : mkstat=2 : Endif
End


##############################
Subprog AM_WROUNUMD(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "": [M]WROUNUMF = VALEUR
                 Affzo [M]WROUNUMF
Endif   
End


##############################
Subprog C_WROUNUMF(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]WROUNUMD : GMESSAGE = mess(44,199,1) : mkstat=2 : Endif
End

##############################
Subprog AM_WROUALTD(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 : [M]WROUALTF = VALEUR
                 Affzo [M]WROUALTF
Endif
End

##############################
Subprog C_WROUALTF(VALEUR)
Variable Decimal VALEUR
If VALEUR < [M]WROUALTD : GMESSAGE = mess(44,199,1) : mkstat=2 : Endif
End

##############################
Subprog IB_NBLIG
Read [F:MFG]MFG0 = [M:MBP]MFGNUM(nolign-1)
# si OF opérations seules ou OF soldé pas de bouton disponibilité et allocations
# si OF matières seules, pas de bouton jalonnement
If [F:MFG]MFGMOD = 3 
    Raz GBOUT2, GBOUT3, GBOUT4
Elsif [F:MFG]MFGMOD = 2
    Raz GBOUT5
Endif
#pas de boutons disponibilités si plus rien à déclarer ou si toutes les matières sont soldées
If [M:MBP]RMNEXTQTY(nolign-1) = 0 | [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
    Raz GBOUT2, GBOUT3
Endif
End

##############################
Subprog AM_WMFGPIOD(VALEUR)
Variable Integer VALEUR
If VALEUR <> 0 : [M]WMFGPIOF = VALEUR
                  Affzo [M]WMFGPIOF
Endif
End

##############################
Subprog C_WMFGPIOF(VALEUR)
Variable Integer VALEUR
If VALEUR < [M]WMFGPIOD : GMESSAGE = mess(44,199,1) : mkstat=2 : Endif
End


