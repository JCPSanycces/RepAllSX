#<AdxTL>@(#)5.0.0.0 $Revision$
# TRTCAPVAR  
#  
# ACTION TRTCAPINC : derrière le bouton "Inclure" du masque TDUCAP2 (fenêtre FTDUCAP)
# ACTION TRTCAPEXC : derrière le bouton "Exclure" du masque TDUCAP2 (fenêtre FTDUCAP)
#
#########################################################
# Bouton "inclure"
Subprog TRTCAPINC
Local Integer I

  For I=0 To [M:TAP2]NBLIG
    If [M:TAP2]FMODIF(I) = 1 : [M:TAP2]FMODIF(I) =2 : Endif
  Next I
Affzo [M:TAP2]
End



#########################################################
# Bouton "exclure"
Subprog TRTCAPEXC
Local Integer I
If clalev([F:OPS]) = 0 : Local File OPERATIONS  [OPS] : Endif   


  For I=0 To [M:TAP2]NBLIG
    If [M:TAP2]FMODIF(I)=2 : [M:TAP2]FMODIF(I) =1 : Endif
    Read [OPS]OPS0 = [M:TAP2]OPSNUM(I)
    If fstat : Goto NXTOPS : Endif 
    If [F:OPS]EXTWSTNBR <>[M:TAP2]EXTWSTNBR(I) : [M:TAP2]EXTWSTNBR(I)=[F:OPS]EXTWSTNBR : Endif
    If [F:OPS]EXTLABNBR <>[M:TAP2]EXTLABNBR(I) : [M:TAP2]EXTLABNBR(I)=[F:OPS]EXTLABNBR : Endif
$NXTOPS
  Next I
Affzo [M:TAP2]


End
