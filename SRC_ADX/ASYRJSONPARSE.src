#<AdxTL>@(#)1.0.0.0 $Revision$
# creation:10/11/2011
#
# Public functions:
# Funprog PARSEJSON(ACTX,JSON,NODES,NODE)
#  ACTX(in)    : an instance of CONTEXT where unexpected errors will be stored
#  JSON (in)  : a JSON stream to parse
#  NODES (out): an array of C_ASYRJSO objects generated by PARSEJSON
#  NODE (out) : reference of the first node
#
# PARSEJSON returns 1 for SUCCESS or 0 for FAILURE
#
# The test suite of ASYRJONARSE is implemented in QLFSUP_ASYRJSONPARSE
#
# NODES TYPES:
#    1: object
#    2: array
#    3: string
#    4: number
#    5: word

Call TESTSUITE() From QLFSUP_ASYRJSONPARSE
End


#**
#* Description:This method parses a JSON text to produce an # an array of
#* C_ASYRJSO objects
#*
#* Funprog PARSEJSON(ACTX,JSON,NODES,NODE)
#* ACTX(in)   : an instance of CONTEXT where unexpected errors will be stored
#* JSON (in)  : a JSON stream to parse
#* NODES (out): an array of C_ASYRJSO objects generated by PARSEJSON
#* NODE (out) : reference of the first node
#*
#* PARSEJSON returns 1 for SUCCESS or 0 for FAILURE

#*!
Funprog PARSEJSON(ACTX,JSON,NODES,NODE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Clbfile JSON
Variable Instance  NODES(1..) Using C_ASYRJSO
Variable Instance  NODE   Using C_ASYRJSO : NODE=null
Local Instance  PNODE  Using C_ASYRJSO

If len(JSON) >0 & JSON <> "{}" & JSON <> "null"
 Gosub PARSEJSON_START

 Gosub NEWVALUE
Else
 Gosub PARSEJSON_NULL
Endif

$PARSEJSON_END
NODE = NODES(2)
$PARSEJSON_NULL
End [V]CST_AOK

$PARSEJSON_ERROR
Local Integer _STA
_STA = fmet ACTX.ASETERROR("",MESSAGE,[V]CST_AERROR) : # 4
NODE = null
#Free the memory allocated for NODES
If NBNODES
 FreeGroup  NODES(1)
 NODES(1)=null
Endif
End [V]CST_ASUCCESS


##
$PARSEJSON_START
Local Instance  FATHER Using C_ASYRJSO : FATHER=null
Local Integer POS         : POS=0
Local Char    CHR(1)      : CHR=" "
Local Char    ECHR(1)
Local Char    PROPERTY(50)
Local Integer TYP
Local Char    MESSAGE(250)
Local Integer I,J,L,POSESC
Local Clbfile STRING,SUBSTRING
Local Clbfile WSTRING
Local Integer NBNODES

POSESC = 0
NODE=null
Raz NODES,NBNODES
Return

#------------------------------------------------#
# NEXT:
#------------------------------------------------#
$NEXTCH
#If a ECHR parameter is provided, verify that it matches the current character.
If ECHR <> '' and ECHR <> CHR
  MESSAGE = "Expected '" + ECHR + "' instead of '" + CHR + "'" - "ascii:" + format$("N:2.0",ascii(CHR))
  Gosub PARSEJSON_ERROR
Else
 #Get the next character. When there are no more characters,
 #return the empty string.
 POS += 1 :  CHR = xgetchar( JSON, POS )
Endif
Return

#------------------------------------------------#
# Parse a value
#------------------------------------------------#
$NEWVALUE
While CHR <> '' and CHR <= ' ' : POS += 1 :  CHR = xgetchar( JSON, POS ) : Wend :#inline Gosub WHITE
Case CHR
 When "{": Gosub NEWOBJECT
 When "[": Gosub NEWARRAY
 When '"': Gosub NEWSTRING
 When '-': Gosub NEWNUMBER
 When Default
  If CHR >= '0' and CHR <= '9'
   Gosub NEWNUMBER
  Else
   Gosub NEWWORD
  Endif
 Endcase
Return

#------------------------------------------------#
# Parse a string value.
#------------------------------------------------#
$PARSESTRING
STRING = ""

# When parsing for string values, we must look for " and \ characters.
If CHR = '"'
 ECHR =''
  While 1
   ##**************************************************************************
   ##   Read a string :
   Raz WSTRING
   POS += 1
   I = instr(POS,JSON,'"')
   If POSESC >=0 & POSESC < I
    POSESC = instr(POS,JSON,'\')
    If POSESC = 0
     POSESC = -1 :# POSESC=-1 => do not search for ESC anymore !
    Else
     If I : I= min(I,POSESC) : Else : I = POSESC : Endif
    Endif
   Endif
   If I
    CHR = xgetchar( JSON, I )
    Append WSTRING,  mid$(JSON,POS ,I-POS )
    POS = I
    If CHR='"'
     Append STRING,WSTRING
     POS += 1 :  CHR = xgetchar( JSON, POS )
     Return
    Elsif CHR='\'
     Append STRING,WSTRING
     POS += 1 :  CHR = xgetchar( JSON, POS )
     Case CHR
      When '"'    :  Append STRING,'"'
      When "'"    :  Append STRING,"'"
      When '\'    :  Append STRING,'\'
      When 'n'    :  Append STRING,chr$(10)
      When 'r'    :  Append STRING,chr$(13)
      When 't'    :  Append STRING,chr$(9)
      When Default:  Return
     Endcase
    Endif
   Else :#CHR=''
    MESSAGE = "Bad string"
    Gosub PARSEJSON_ERROR
   Endif

 Wend
Endif
Return

#------------------------------------------------#
# ADDJSO
#------------------------------------------------#
$ADDJSO
NBNODES += 1
If NBNODES = 1
 NODES(1) = NewInstance C_ASYRJSO AllocGroup null
 NODES(1).CLB = NewInstance C_ASYRJSOCLB AllocGroup NODES(1)
Else
 NODES(NBNODES) = NewInstance C_ASYRJSO AllocGroup NODES(1)
 NODES(NBNODES).CLB = NODES(1).CLB
Endif

NODES(NBNODES).PRO = PROPERTY
NODES(NBNODES).NEX = null
NODES(NBNODES).SUB = null
NODES(NBNODES).TYP = TYP
NODES(NBNODES).FAT = FATHER

If FATHER <> null
 If null = FATHER.SUB
  FATHER.SUB = NODES(NBNODES)
 Else
  NODE.NEX   = NODES(NBNODES)
 Endif
Endif

NODE = NODES(NBNODES)
If TYP=1 or TYP=2
 #object or array: the new node becomes the current father:
 FATHER = NODE
 NODE   = null
Endif
PNODE = NODES(NBNODES)

Return

#**
#* ENDOBJECT
#*!
$ENDOBJECT
PROPERTY=""
If NODE = null
 NODE = FATHER
Else
 NODE = NODE.FAT
Endif
If NODE <> null : FATHER = NODE.FAT : Endif
PNODE=NODE
Return

#**
# Parse an object
#*!
$NEWOBJECT
TYP = 1 : Gosub ADDJSO

ECHR='{' : Gosub NEXTCH
While CHR <> '' and CHR <= ' ' : POS += 1 :  CHR = xgetchar( JSON, POS ) : Wend :#inline Gosub WHITE
If CHR = '}'
 ECHR='}' : Gosub NEXTCH
 Gosub ENDOBJECT
 Return
Else
 While CHR <> ''
  Gosub PARSESTRING
  PROPERTY = STRING
  While CHR <> '' and CHR <= ' ' : POS += 1 :  CHR = xgetchar( JSON, POS ) : Wend :#inline Gosub WHITE
  ECHR=':' : Gosub NEXTCH
  Gosub NEWVALUE
  While CHR <> '' and CHR <= ' ' : POS += 1 :  CHR = xgetchar( JSON, POS ) : Wend :#inline Gosub WHITE
  If CHR = '}'
   ECHR='}' : Gosub NEXTCH
   Gosub ENDOBJECT
   Return
  Endif
  ECHR=',' : Gosub NEXTCH
  While CHR <> '' and CHR <= ' ' : POS += 1 :  CHR = xgetchar( JSON, POS ) : Wend :#inline Gosub WHITE
 Wend
Endif
Return


#**
#* ENDARRAY
#*!
$ENDARRAY
If NODE = null
 NODE = FATHER
Else
 NODE = NODE.FAT
Endif
If NODE <> null : FATHER = NODE.FAT : Endif
PNODE=NODE
Return

#**
# Parse an array
#*!
$NEWARRAY
TYP = 2 : Gosub ADDJSO

PROPERTY=""

ECHR = '[': Gosub NEXTCH
While CHR <> '' and CHR <= ' ' : POS += 1 :  CHR = xgetchar( JSON, POS ) : Wend :#inline Gosub WHITE
If CHR = ']'
 ECHR = ']': Gosub NEXTCH
 Gosub ENDARRAY
 Return
Else
 While CHR <> ''
  Gosub NEWVALUE
  While CHR <> '' and CHR <= ' ' : POS += 1 :  CHR = xgetchar( JSON, POS ) : Wend :#inline Gosub WHITE
  If CHR = ']'
   ECHR = ']': Gosub NEXTCH
   Gosub ENDARRAY
   Return
  Endif
  ECHR=',': Gosub NEXTCH
  While CHR <> '' and CHR <= ' ' : POS += 1 :  CHR = xgetchar( JSON, POS ) : Wend :#inline Gosub WHITE
 Wend
Endif
Return

#**
# Parse a string
#*!
$NEWSTRING
TYP = 3 : Gosub ADDJSO
Gosub PARSESTRING

NODE.START = 1+len(NODE.CLB.CLB)
NODE.LENGTH = len(STRING)+2
Append NODE.CLB.CLB , '"'
Append NODE.CLB.CLB , STRING
Append NODE.CLB.CLB , '"'
Return

#**
# Parse a number
#*!
$NEWNUMBER
TYP = 4 : Gosub ADDJSO

STRING = ''

If CHR = '-'
 STRING = '-'
 ECHR='-': Gosub NEXTCH
Endif

While CHR >= '0' and CHR <= '9'
 STRING += CHR
 POS += 1 :  CHR = xgetchar( JSON, POS )
Wend

If CHR = '.'
 STRING += '.'
 While 1
  POS += 1 :  CHR = xgetchar( JSON, POS )
  If CHR <> '' and CHR >= '0' and CHR <= '9'
   STRING += CHR
  Else
   Break
  Endif
 Wend
Endif

If CHR = 'e' or CHR = 'E'
 STRING += CHR
 POS += 1 :  CHR = xgetchar( JSON, POS )

 If CHR = '-' or CHR = '+'
  STRING += CHR
  POS += 1 :  CHR = xgetchar( JSON, POS )
 Endif
 While CHR >= '0' and CHR <= '9'
  STRING += CHR
  POS += 1 :  CHR = xgetchar( JSON, POS )
 Wend
Endif
NODE.START = 1+len(NODE.CLB.CLB)
NODE.LENGTH = len(STRING)
Append NODE.CLB.CLB , STRING
Return

#------------------------------------------------#
# Parse a word
#------------------------------------------------#
$NEWWORD
TYP = 5: Gosub ADDJSO

Case CHR
When 't':
 ECHR='t': Gosub NEXTCH
 ECHR='r': Gosub NEXTCH
 ECHR='u': Gosub NEXTCH
 ECHR='e': Gosub NEXTCH
 NODE.START = 1+len(NODE.CLB.CLB)
 NODE.LENGTH = 4
 Append NODE.CLB.CLB , "true"
 Return
When 'f':
 ECHR='f': Gosub NEXTCH
 ECHR='a': Gosub NEXTCH
 ECHR='l': Gosub NEXTCH
 ECHR='s': Gosub NEXTCH
 ECHR='e': Gosub NEXTCH
 NODE.START = 1+len(NODE.CLB.CLB)
 NODE.LENGTH = 5
 Append NODE.CLB.CLB , "false"
 Return
When 'n':
 ECHR='n': Gosub NEXTCH
 ECHR='u': Gosub NEXTCH
 ECHR='l': Gosub NEXTCH
 ECHR='l': Gosub NEXTCH
 NODE.START = 1+len(NODE.CLB.CLB)
 NODE.LENGTH = 4
 Append NODE.CLB.CLB , "null"

 Return
Endcase
MESSAGE = "bad word"
Gosub PARSEJSON_ERROR
Return
