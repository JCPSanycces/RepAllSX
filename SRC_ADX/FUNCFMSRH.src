#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
########################### ##############################################
#                                                                       #
#     Customer returns validation                                       #
#                                                                       #
#########################################################################
#########################################################################
#########################################################################
# Model ACTIONS                                                         #
#########################################################################
$ACTION

Case ACTION
 When "OUVRE_BATCH" : Gosub INIT
 When "INIT"        : Gosub INIT
 When "DEBUT"       : Gosub DEBUT
 When "OK"          : Gosub OK
 When "END"         : Gosub ENDM
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When Default
Endcase

Return
#########################################################################
#########################################################################
$INIT

# In batch, better to set an onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Gosub OUVRE

Local Mask SRHCFM [DIA]

Raz [M:DIA]
GDLVTYP = 1

[M:DIA]STOFCY=GFCYDEF(3)
[M:DIA]RTNDAT=date$

Return
#########################################################################
#########################################################################
$DEBUT

Affzo [DIA]1-99

Return
#########################################################################
#########################################################################
$OK

GOK=1

Return
#########################################################################
#########################################################################
$ENDM

GOK=0 : FIN=1

Return
#########################################################################
#########################################################################
$CONTROLE

If GOK < 1  FIN=1 Else TMP=1  Endif

Return
#########################################################################
#########################################################################
$EXEC

If !GSERVEUR
# --> open trace
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("SRHCFM","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

# --> lecture des entêtes de livraison
Gosub SRHVAL

Return
#########################################################################
#########################################################################
$TERMINE

If !GSERVEUR
  # --> fermeture trace
  TRA = 1
  Call FERME_TRACE From LECFIC
Endif

Return
#########################################################################
#########################################################################
$OUVRE

Local  Char     CRITERE(250) , CRITERE1(250), SYMBOLE(50)
Local  Integer  WRET

If !clalev ([F:SRH]) : Local File SRETURN  [SRH] : Endif

TIT = mess(79,197,1)
GFCYDEF(0) = GFCYDEF(3)

Return
#########################################################################
#########################################################################
$SRHVAL

CRITERE  = "SRHCFMFLG<>2"
CRITERE1 = "1=1"
If [M:DIA]CPY    <> ""      : CRITERE  -= '& [F:SRH]CPY    = "' +[M:DIA]CPY   + '"'             : Endif
If [M:DIA]STOFCY <> ""      : CRITERE  -= '& [F:SRH]STOFCY = "' +[M:DIA]STOFCY+ '"'             : Endif
If [M:DIA]SRHTYP <> ""      : CRITERE  -= '& [F:SRH]SRHTYP = "' +[M:DIA]SRHTYP+ '"'             : Endif
If [M:DIA]RTNDAT <> [0/0/0] : CRITERE  -= '& [F:SRH]RTNDAT <=[' +format$(GFMD,[M:DIA]RTNDAT)+']': Endif
If [M:DIA]SRHNUMDEB <> ""   : CRITERE1 -= '& [F:SRH]SRHNUM >="' +[M:DIA]SRHNUMDEB+ '"'          : Endif
If [M:DIA]SRHNUMFIN <> ""   : CRITERE1 -= '& [F:SRH]SRHNUM <="' +[M:DIA]SRHNUMFIN+ '"'          : Endif
If [M:DIA]BPCORDDEB <> ""   : CRITERE1 -= '& [F:SRH]BPCORD >="' +[M:DIA]BPCORDDEB+ '"'          : Endif
If [M:DIA]BPCORDFIN <> ""   : CRITERE1 -= '& [F:SRH]BPCORD <="' +[M:DIA]BPCORDFIN+ '"'          : Endif

# Lecture des livraisons et traitement
For [F:SRH] Where (evalue(CRITERE)) & (evalue(CRITERE1))
  SYMBOLE = "SRH"+[F:SRH]SRHNUM
  Lock = SYMBOLE With lockwait=0
  If fstat=1
   # Modification en cours sur un autre poste
    Call ECR_TRACE([F:SRH]SRHNUM-mess(10,100,1),1) From GESECRAN
  Else
    Call VALIDATE([F:SRH]SRHNUM,WRET) From TRTVENRET1
    Unlock =SYMBOLE
  Endif
Next

Return
#########################################################################
#########################################################################
$ERRBATCH

Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN

End
#########################################################################
#########################################################################
# Field events                                                          #
#########################################################################
#########################################################################
Subprog D_CPY(VALEUR)
Variable Char    VALEUR()

## init avec societe du site stock par defaut
Call GETSOC (GFCYDEF(3)) From DEVSUB
VALEUR=GSOCIETE
[M:DIA]STOFCY=GFCYDEF(3)

End
#########################################################################
#########################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Local Char V_LEG(30)

GSOCIETE=VALEUR
Raz [M:DIA]STOFCY

Call GETLEG([F:CPY]CPY,"",[L]V_LEG) From TRTLECLEG
GCURLEG = [L]V_LEG

End
#########################################################################
#########################################################################
Subprog C_RTNDAT(VALEUR)
Variable Date    VALEUR

If VALEUR  > date$
   GMESSAGE = mess(60,192,1) : mkstat = 2
Endif

End
#########################################################################
#########################################################################
Subprog AM_SRHNUMDEB(VALEUR)
Variable Char    VALEUR()

If VALEUR <> "" : [M]SRHNUMFIN = VALEUR : Endif

End
#########################################################################
#########################################################################
Subprog AM_BPCORDDEB(VALEUR)
Variable Char    VALEUR()

If VALEUR <> "" : [M]BPCORDFIN = VALEUR : Endif

End
##########################################################################
##########################################################################
Subprog AS_SRHCAT(VALEUR)
Variable Integer VALEUR

GDLVTYP =[M:DIA]SRHCAT

End
###########################################################################

