#<AdxTL>@(#)9.0.0.0 $Revision$
##########################################################################
# UUMGTRTTRC14          Moulinette de Migration              Module TRC  #
##########################################################################
# From TRCMAJ30  : UPDITB   : new field LLCTYP                           #
##########################################################################
# Issues 80101 & 80102 & get VERSION number - GA 02/2012
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
If !GSERVEUR
  Call SAIDOS(WDOSSIER,"") From SAIDOS
Endif
If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 107271 - 2015-08-05 by CCC
  #Read [ADS]DOSSIER=[L]WDOSSIER : If fstat Raz [F:ADS] : Endif
  If !func DOSSUB.FILL_ADS(WDOSSIER): End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTTRC14") From LECFIC
  Endif

  #Call RAZ_UUMGTRTTRC14(WDOSSIER)
  Call MAJ_UUMGTRTTRC14(WDOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
  If APPLI=GDOSX3 : End : Endif
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 107271 - 2015-08-05 by CCC
  #Read [ADS]DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If !func DOSSUB.FILL_ADS(APPLI): End : Endif
  Call MAJ_UUMGTRTTRC14(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTTRC14(APPLI)
End

##########################################################################
Subprog MAJ_UUMGTRTTRC14(WDOSSIER)
Value Char WDOSSIER

adxftl=10
adxwrb=10
NEWMOTEUR=1

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 107271 - 2015-08-05 by CCC
#Read [ADS]DOSSIER=[L]WDOSSIER : If fstat Raz [F:ADS] : Endif
If !func DOSSUB.FILL_ADS(WDOSSIER): End : Endif

GOK=1
Gosub LOA_BOM From UUMGTRTTRC00

Gosub UPDITB
If GOK<=0
    Call ECR_TRACE("UUMGTRTTRC14 table ITMBOM Incorrectly Processed : Update ITB"-WDOSSIER,1) From GESECRAN
Endif
End
##########################################################################
Subprog RAZ_UUMGTRTTRC14(WDOSSIER)
Value Char WDOSSIER

Local Integer ERR

GOK=1

#1 - verifications
####################

If [F:ADS]MODULE(8)<>2 : End : Endif          : # N= no module

Local Char WNAMFICM
Call MIGTABNAME (WDOSSIER,"ITMBOM",WNAMFICM,ERR) From TRTMIG
If ERR : End : Endif

##2 - On vide les fichiers selon le cas
#######################################

If  filinfo(filpath("FIL","ITMBOM","fde",WDOSSIER),0)>0
& & filinfo(filpath("FIL",WNAMFICM,"fde",WDOSSIER),0)>0
  #Call ECR_TRACE("RAZ_UUMGTRTTRC14 Raz table ITMBOM"-WDOSSIER,0) From GESECRAN
  Call MIGTABRAZ (WDOSSIER,"ITMBOM",ERR) From TRTMIG
  Call MIGRAZKEY (WDOSSIER,"UUMGTRTTRC14",ERR) From TRTMIG
Endif

End

####################################################################################
$UPDITB
Local Integer ERR

GOK=1

##1 - verifications
####################

If [F:ADS]MODULE(8)<>2 : : # Module 9=Tronc commun
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC14",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

If filinfo(filpath("FIL","ITMBOM","fde",WDOSSIER),0) <=0
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC14",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

Call ECR_TRACE("UUMGTRTTRC14 Start trace : ITMBOM => BOMALTTYP" ,0) From GESECRAN

Local Char WNAMFICM
Call MIGTABNAME (WDOSSIER,"ITMBOM",WNAMFICM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC14",7,ERR) From TRTMIG : #7=Erreur
  Return
Endif

#----- Is old renamed file ok ?...  -----#
If filinfo(filpath("FIL",WNAMFICM,"fde",WDOSSIER),0) < 0
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC14",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif


##2 - Traitements en cours
####################

Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC14",2,ERR) From TRTMIG : #2=En cours

#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (WDOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC14",7,ERR) From TRTMIG : #7=Erreur
  Return : # End # 2015-11-09 by GH
Endif

###################

Call ECR_TIME("UUMGTRTTRC14 table ITMBOM Process : Update ITB") From DOSSUB
Call ECR_TRACE("UUMGTRTTRC14:Process Start on : "+WDOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (WDOSSIER,"ITMBOM",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:ITB])  = 0 : Local File =WDOSSIER+".ITMBOM"    [ITB]  : Endif   # Fichier X3 "Vide"
If clalev([F:ITBM]) = 0 : Local File =WDOSSIER+"."+WNAMFICM [ITBM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
Local Char WTAB_ITB (100) (adxwrb) : # Issue 112303 - 2015-11-09 by GH - not to do before MIG_OUVRE
Local Shortint WCPT_ITB

# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBCOMMIT, NBLUS
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30) # Issue 80101 ajout HINTSPE
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE

# Déclaration des variables communes de travail
Local Integer I, J

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (WDOSSIER,"UUMGTRTTRC14",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTTRC14" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_ITB00
Raz NB
# Clé ITB0=ITMREF+BOMALT (ancienne table)
If STOP = 1
 STOP = 2
 CRITERE = "[F:ITBM]ITMREF=TABMIGKEY(1) & [F:ITBM]BOMALT>"+TABMIGKEY(2)
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:ITBM]ITMREF>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [ITB]
GOK = 1

# Issue 78741 don't create ITB when BOMALT=0
For [ITBM] Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE) & BOMALT>0
  NBLUS += 1

  # PE pour exclure ligne
  If FILTRELIN
      ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto NEXT_ITB : Endif
  Endif

  #Raz [F:ITB]
  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_ITB
  Endif

  [F:ITB] = [F:ITBM]

  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_ITB
    If GOK<1 : Break : Endif
  Endif

  # --- alimentation des champs et écriture enreg
  If NEWMOTEUR
      Gosub ITB_STK : # pour stocker ref
      WriteB [F:ITB]
  Else
      Write [F:ITB]
  Endif
  If fstat
    If NEWMOTEUR & adxwrb>1
      Call ECR_TRACE("File ITMBOM, Error ="-num$(fstat),1) From GESECRAN
      Gosub ITB_ERRTRA : # pour afficher les ref
    Else
      Call ECR_TRACE("File ITMBOM(ITMREF/BOMALT)"-[F:ITB]ITMREF+"/"+num$([F:ITB]BOMALT)+", ERROR ="-num$(fstat),1) From GESECRAN
    Endif
    GOK=0 : Break
  Endif

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:ITBM]ITMREF
    TABMIGKEY(2) = num$([F:ITBM]BOMALT)
    STOP=1
    Break
  Endif
$NEXT_ITB
Next

$END_ITB
If GOK<1
  Rollback
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC14",7,ERR) From TRTMIG : #7=Erreur
Else
  If NEWMOTEUR & adxwrb>1
    Flush [F:ITB]
    If fstat
        Call ECR_TRACE("File ITMBOM, Error ="-num$(fstat),1) From GESECRAN
        Gosub ITB_ERRTRA : # pour afficher les ref
        GOK=0 : Goto END_ITB : #on part sur rollback
    Endif
  Endif
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  # Stocker les valeurs de ACLE1/ACLE2/STOP dans la table AMIGKEY.
  Call MIGSTKKEY (WDOSSIER,FLUX,NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto END_ITB
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (WDOSSIER,"UUMGTRTTRC14",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_ITB00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [ITB]
Close Local File [ITBM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (WDOSSIER,"ITMBOM",ERR) From TRTMIG
Call MIGTRTEND (WDOSSIER,"UUMGTRTTRC14") From TRTMIG
Call ECR_TIME("UUMGTRTTRC14:"+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
Return

#######################################################################
$ITB_STK
Call STK (WTAB_ITB,WCPT_ITB,[F:ITB]ITMREF+"/"+num$([F:ITB]BOMALT)) From TRTMIG
Return

#######################################################################
$ITB_ERRTRA
Call ERRTRA (WTAB_ITB,WCPT_ITB,"File ITMBOM(ITMREF/BOMALT)=") From TRTMIG
Return

##########################################################################
$RAZV6_ITB
Raz [F:ITB]LLCTYP  # V6 new field
Return

#######################################################################
# Code extrait de TRCMAJ30 - table ITMBOM
########################################################################
$MAJV6_ITB
### Issue 78741 cas impossible en principe
If [F:ITB]BOMALT<1
  [F:ITB]LLCTYP = 1
Else
  Case WBOMALTTYP([F:ITB]BOMALT)
        When 2,3:      [F:ITB]LLCTYP = 2
        When Default:  [F:ITB]LLCTYP = 1
  Endcase
Endif
#[F:ITB]UPDUSR=GUSER
#[F:ITB]UPDDAT=date$
Return
