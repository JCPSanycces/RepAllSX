#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion du fichier SELSSP
Call OBJET ("SSP", GBIDC1, GBIDC2) From GOBJET
End

##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "RAZCRE"       : Gosub RAZCRE
    When "LIENS"        : Gosub LIENS
    When "FERME"        : Gosub FERME
    When "SETBOUT"      : Gosub SETBOUT
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "CREATION"     : Gosub CREATION
    When "MODIF"        : Gosub MODIF
    When "ANNULE"       : Gosub ANNULE
    When "APRES_CRE"    : Gosub APRES_CRE
    When "APRES_MOD"    : Gosub APRES_MOD
    When "AV_ANNULE"    : Gosub AV_ANNULE
    When "AVANTBOUT"    : Gosub AVANTBOUT
    When "FILTRE"       : Gosub FILTRE
    When "FILGAUCHE"    : Gosub FILGAUCHE
    When default
  Endcase
Return

##########################################################################################################
$OUVRE
Return

##########################################################################################################
$FERME
Return

##########################################################################################################
$RAZCRE
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "FMGG" Then
      [M:SSP0]SPTTGR = [M:MGG0]TGR
    Elsif GNAVIG(GPILNAV-1) = "GESTGL" Then
      [M:SSP0]SPTTGR = [M:TGL0]TGRTAB
    Endif
  Endif
  [M:SSP1]SPTTYP = 1
  Actzo [M:SSP2]5
  Affzo [M:SSP0]1-99
  Affzo [M:SSP1]1-99
  Affzo [M:SSP2]1-99
Return

##########################################################################################################
$FILTRE
  If GPILNAV > 0 Then
    If type([M:MGG0]TGR) > 0 Then
      If GNAVIG(GPILNAV) = "GESSSP" Then
        Default File [SSP]
        FILTSUP = "[F:SSP]SPTTGR = [M:MGG0]TGR"
      Endif
    Endif
  Endif
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESTGL" Then
      If GNAVIG(GPILNAV) = "GESSSP" Then
        Default File [SSP]
        FILTSUP = "[F:SSP]SPTTGR = [M:TGL0]TGRTAB"
      Endif
    Endif
  Endif
Return

##########################################################################################################
$FILGAUCHE
  If GPILNAV > 0 Then
    If type([M:MGG0]TGR) > 0 Then
      If GNAVIG(GPILNAV) = "GESSSP" Then
        Default File [SSP]
        If currbox = "GAU_CHE" Then
          FILGAUCHE = "[F:SSP]SPTTGR = [M:MGG0]TGR"
        Endif
      Endif
    Endif
  Endif
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESTGL" Then
      If GNAVIG(GPILNAV) = "GESSSP" Then
        Default File [SSP]
        If currbox = "GAU_CHE" Then
          FILGAUCHE = "[F:SSP]SPTTGR = [M:TGL0]TGRTAB"
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$LIENS
  Gosub SETGRIZONE
  Call LOADSSPL([M:SSP0]SPTNUM) From SUBSSPB
  Affzo [M:SSP1]1-99
  Affzo [M:SSP2]1-99
Return

##########################################################################################################
$VERIF_CRE
  Call CHECKSSC(OK) From SUBSSPB
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$VERIF_MOD
  Call CHECKSSC(OK) From SUBSSPB
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$CREATION_MODIF
  # FGR 03/03/2009 : X3SUIVI52963 Texte traduisible
  Call MAJTEXTRA([M:SSP1]SPTNAMAXX, "SELSSP", "SPTNAMAXX", [M:SSP0]SPTNUM, "") From ATEXTRA
  #Enregistre une description des composants
  Gosub SAVESSPL From SUBSSPB
Return

##########################################################################################################
$CREATION
  Gosub CREATION_MODIF
Return

##########################################################################################################
$MODIF
  Gosub CREATION_MODIF
Return

##########################################################################################################
$ANNULE
  # FGR 03/03/2009 : X3SUIVI52963 Texte traduisible
  Call SUPTEXTRA("SELSSP", "SPTNAMAXX", [M:SSP0]SPTNUM, "") From ATEXTRA
Return

##########################################################################################################
$APRES_CRE
Return

##########################################################################################################
$APRES_MOD
Return

##########################################################################################################
$AV_ANNULE
Local Char SZNEWPRG(250)
Local Integer IEXIST

  Raz SZNEWPRG
  #Supprime le traitement associé au support
  If [M:SSP1]SPTTYP = 2 Then
    If [M:SSP1]SPTPRO <> "" Then
      #Suppression du SRC
      SZNEWPRG = filpath("TRT",[M:SSP1]SPTPRO,"src",nomap)
      IEXIST = 0
      Call EXISTE(SZNEWPRG, IEXIST) From ORDSYS
      If IEXIST Then
        #Suppression du traitement
        IEXIST = 1
        Call EFFACE(SZNEWPRG, IEXIST) From ORDSYS
      Endif
      #Suppression du ADX
      SZNEWPRG = filpath("TRT",[M:SSP1]SPTPRO,"adx",nomap)
      IEXIST = 0
      Call EXISTE(SZNEWPRG, IEXIST) From ORDSYS
      If IEXIST Then
        #Suppression du traitement
        IEXIST = 1
        Call EFFACE(SZNEWPRG, IEXIST) From ORDSYS
      Endif
    Endif
  Endif
Return

##########################################################################################################
$SETBOUT
  Case REP
    When ""
      If [M:SSP1]SPTTYP = 2 Then
        CHMEN += "I"
      Endif
    When "M", "C", "D"
      Call VIREBOUT(CHAINE,"B") From GOBJET    
    When Default
  Endcase
  If TUNNEL = 1 Then
    Call VIREBOUT(CHAINE,"B") From GOBJET
  Endif
  Call VIREBOUT(CHAINE,"H") From GOBJET    
Return

##########################################################################################################
$AVANTBOUT
  Case BOUT
    When "I"
      Call SETTRT([M:SSP1]SPTPRO) From SUBSSPB
    When Default
  Endcase
Return

##########################################################################################################
# Sous-programmes utilitaires
###############################################################################
$SETGRIZONE
  If [M:SSP1]SPTTYP = 3 Then
    #Tous
    Grizo [M:SSP2]5
  Else
    #Autres
    Actzo [M:SSP2]5
  Endif
Return

##########################################################################################################
Subprog SET_DENOM_DEF (SZSPTTGR)
Value Char SZSPTTGR # FGR 10/08/2009 : X3SUIVI57084

Local Char SZTEXTE(GLONDCO)

  #Donne une dénomination par défaut
  Read [TGL]TGL0=SZSPTTGR
  If fstat Then
    [M:SSP1]SPTNAMAXX = ""
  Else
    Call LECTEXTRA(SZTEXTE, "TGRLIS", "TGRNAMAXX", [F:TGL]TGRTAB, "") From ATEXTRA
    If [M:SSP1]SPTTYP = 3 Then
      [M:SSP1]SPTNAMAXX = SZTEXTE
    Else
      #Sélection sur : XXXXXX
      [M:SSP1]SPTNAMAXX = mess(747,196,1) - SZTEXTE
    Endif
  Endif
  Affzo [M:SSP1]SPTNAMAXX
End

##########################################################################################################
Subprog AM_SPTTYP(VALEUR)
Variable Integer VALEUR

Local Char SZTEXTE(GLONDCO)

  [M:SSP1]SPTTYP = VALEUR
  [M:SSP1]SPTPRO = ""
  Raz [M:SSP2]NBCPN
  Raz [M:SSP2]SPTLEV
  Raz [M:SSP2]SPTTAB
  Raz [M:SSP2]SPTKEY
  Raz [M:SSP2]SPTFLT
  Case [M:SSP1]SPTTYP
    When 1
      Actzo [M:SSP2]5
    When 2
      Actzo [M:SSP2]5
    When 3
      Grizo [M:SSP2]5
    When 4
      Actzo [M:SSP2]5
    When Default
  Endcase
  Call SET_DENOM_DEF([M:SSP0]SPTTGR)
  Affzo [M:SSP1]1-99
  Affzo [M:SSP2]1-99
End

##########################################################################################################
Subprog C_SPTTAB(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    Read [ATB]CODFIC=VALEUR
    If fstat Then
      #Le code de la table indiqué est incorrect. Saisie refusée.
      GMESSAGE = mess(573,196,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
  #Vérifie que l'on n'a pas saisie la table cible
  If VALEUR = [M:SSP0]SPTTGR Then
    mkstat = 2
    #Il s'agit de la table cible. Saisie refusée.
    GMESSAGE = mess(739,196,1) - mess(627,196,1)
    GERR = 1 
  Endif
  If GERR Then
    End
  Endif

  #Vérifie que l'on n'a pas saisie deux tables avec le même niveau.
Local Integer INOL
Local Integer Z
Local Integer IFOUND

  INOL = nolign-1
  IFOUND = 0
  For Z = 0 To dim([M:SSP2]SPTLEV)-1
    If Z <> INOL Then
      If VALEUR <> "" Then
        If [M:SSP2]SPTTAB(Z) = VALEUR Then
          IFOUND = 1
          Break
        Endif
      Endif
    Endif
  Next
  If IFOUND  Then
    mkstat = 2
    #Cette table a déjà été mentionnée dans le tableau. Saisie refusée.
    GMESSAGE = mess(690,196,1) - mess(627,196,1)
    GERR = 1
  Endif
End

##########################################################################################################
Subprog C_SPTKEY(VALEUR)
Variable Char    VALEUR()

Local Integer IINDEXF
Local Char SZVALEUR

  IINDEXF = 0
  SZVALEUR = VALEUR
  If VALEUR <> "" Then
    Read [ATZ]CODZONE=[M:SSP2]SPTTAB(nolign-1);VALEUR
    If fstat Then
      # XX n'est pas un champ de la table : YY
      GMESSAGE = VALEUR + mess(574,196,1) + [M:SSP2]SPTTAB(nolign-1)
      GERR = 1
      mkstat = 2
      End
    Endif
    #Si support de premier niveau, le champ doit être utilisé dans un index
    If [M:SSP1]SPTTYP = 4 or [M:SSP1]SPTTYP = 2 Then
      Filter [ATI] Where [F:ATI]CODFIC = [M:SSP2]SPTTAB(nolign-1) Order By [F:ATI]CODIND Asc
      IINDEXF = 0
      For [ATI]
        If instr(1, [F:ATI]DESCRIPT, SZVALEUR) Then
          IINDEXF = 1
          Break
        Endif
      Next
      Filter [ATI]
      If !IINDEXF Then
        #Ce champ ne comporte pas d'index associé permettant d'établir une relation avec la cible. Saisie refusée
        GMESSAGE = mess(695,196,1) - mess(627,196,1)
        GERR = 1
        mkstat = 2
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog C_SPTLEV(VALEUR)
Variable Decimal VALEUR

  If VALEUR = 0 Then
    #Le niveau doit être supérieur à zéro
    GMESSAGE = mess(687,196,1) - mess(688,196,1)
    GERR = 3
    mkstat = 2
    End
  Endif
  #Support de type Liaison de premier niveau
  #On interdit de saisir un niveau supérieur à 1
  If [M:SSP1]SPTTYP = 4 Then
    If VALEUR > 1 Then
      #Il s'agit d'un support de premier niveau. Les niveaux supérieurs à 1 sont interdits.
      GMESSAGE = mess(694,196,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
  #On interdit de saisir un niveau supérieur à 1
  If [M:SSP1]SPTTYP = 2 Then
    If VALEUR > 1 Then
      #Il s'agit d'un support de type Traitement.
      #Seules des tables liées directement à la cible peuvent être exploitée par le générateur de traitement.
      GMESSAGE = mess(737,196,1) - mess(738,196,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif

#Vérifie que l'on n'a pas saisie deux tables avec le même niveau.
Local Integer INOL
Local Integer Z
Local Integer IFOUND

  INOL = nolign-1
  IFOUND = 0
  For Z = 0 To dim([M:SSP2]SPTLEV)-1
    If Z <> INOL Then
      If [M:SSP2]SPTTAB(INOL) <> "" Then
        If [M:SSP2]SPTTAB(Z) = [M:SSP2]SPTTAB(INOL) Then
          If [M:SSP2]SPTLEV(Z) = VALEUR Then
            IFOUND = 1
            Break
          Endif
        Endif
      Endif
    Endif
  Next
  If IFOUND  Then
    mkstat = 2
    #Cette table a déjà été saisie sur le même niveau. Saisie refusée.
    GMESSAGE = mess(689,196,1) - mess(627,196,1)
    GERR = 1 
  Endif
End

##########################################################################################################
Subprog C_SPTTABPAE(VALEUR)
Variable Char    VALEUR()

Local Integer Z
Local Integer Z2
Local Integer ZNOL
Local Integer IFOUND
Local Integer ILEVEL

  ZNOL = nolign-1
  IFOUND  = 0
  ILEVEL = [M:SSP2]SPTLEV(nolign-1) - 1
  #Niveau 1
  If [M:SSP2]SPTLEV(nolign-1) = 1 Then
    If VALEUR <> [M:SSP0]SPTTGR Then
      mkstat = 2
      #Valeur incorrecte
      GMESSAGE = mess(83,123,1)
      GERR = 1
    Endif
  Endif
  #Niveau supérieur à 1
  If [M:SSP2]SPTLEV(nolign-1) > 1 Then
    For Z2 = 0 To [M:SSP2]NBCPN-1
      If [M:SSP2]SPTLEV(Z2) = ILEVEL Then
        If Z2 <> ZNOL Then
          #Vérifie si la valeur saisie est trouvée parmi les tables parents
          If VALEUR <> "" Then
            If [M:SSP2]SPTTAB(Z2) <> "" Then
              If [M:SSP2]SPTTAB(Z2) = VALEUR Then
                IFOUND = 1
              Endif
            Endif
          Endif
          If IFOUND Then
            Break
          Endif
        Endif
      Endif
    Next
    If !IFOUND Then
      mkstat = 2
      #Valeur incorrecte
      GMESSAGE = mess(83,123,1)
      GERR = 1
    Endif
  Endif
End

##########################################################################################################
Subprog AM_SPTLEV(VALEUR)
Variable Decimal VALEUR

  If VALEUR > 1 Then
    [M:SSP2]SPTTABPAE(nolign-1) = ""
    [M:SSP2]SPTKEYPAE(nolign-1) = ""
  Else
    If VALEUR = 0 Then
      [M:SSP2]SPTTABPAE(nolign-1) = ""
      [M:SSP2]SPTKEY(nolign-1) = ""
    Else
      If [M:SSP2]SPTTAB(nolign-1) = "" Then
        [M:SSP2]SPTTABPAE(nolign-1) = ""
      Else
        If [M:SSP2]SPTKEY(nolign-1) = "" Then
          [M:SSP2]SPTTABPAE(nolign-1) = ""
        Else
          [M:SSP2]SPTTABPAE(nolign-1) = [M:SSP0]SPTTGR
        Endif
      Endif
    Endif
  Endif
  [M:SSP2]SPTLEV(nolign-1) = VALEUR
  Affzo [M:SSP2]SPTLEV(nolign-1), SPTKEY(nolign-1), SPTTABPAE(nolign-1), SPTKEYPAE(nolign-1)
End

##########################################################################################################
Subprog AM_SPTTAB(VALEUR)
Variable Char    VALEUR()

  [M:SSP2]SPTTAB(nolign-1) = VALEUR
  If [M:SSP1]SPTTYP = 4 or [M:SSP1]SPTTYP = 2 Then
    #Renseigne la table et la clé parent.
    [M:SSP2]SPTTABPAE(nolign-1) = [M:SSP0]SPTTGR
    Read [TGL]TGL0=[M:SSP0]SPTTGR
    If fstat Then
      [M:SSP2]SPTKEYPAE(nolign-1) = ""
    Else
      [M:SSP2]SPTKEYPAE(nolign-1) = [F:TGL]TGRMAIKEY
    Endif
    [M:SSP2]SPTKEY(nolign-1) = ""
    [M:SSP2]SPTIDX(nolign-1) = ""
    [M:SSP2]SPTFLT(nolign-1) = ""
  Elsif [M:SSP1]SPTTYP = 1 Then
    If [M:SSP2]SPTLEV(nolign-1) = 1 Then
      #Renseigne la table et la clé parent.
      [M:SSP2]SPTTABPAE(nolign-1) = [M:SSP0]SPTTGR
      Read [TGL]TGL0=[M:SSP0]SPTTGR
      If fstat Then
        [M:SSP2]SPTKEYPAE(nolign-1) = ""
      Else
        [M:SSP2]SPTKEYPAE(nolign-1) = [F:TGL]TGRMAIKEY
      Endif
      [M:SSP2]SPTKEY(nolign-1) = ""
      [M:SSP2]SPTIDX(nolign-1) = ""
      [M:SSP2]SPTFLT(nolign-1) = ""
    Else
      [M:SSP2]SPTTABPAE(nolign-1) = ""
      [M:SSP2]SPTKEYPAE(nolign-1) = ""
    Endif
  Else
    If [M:SSP2]SPTLEV(nolign-1) > 1 Then
      [M:SSP2]SPTTABPAE(nolign-1) = ""
      [M:SSP2]SPTKEYPAE(nolign-1) = ""
    Else
      If [M:SSP2]SPTTAB(nolign-1) = "" Then
        [M:SSP2]SPTTABPAE(nolign-1) = ""
        [M:SSP2]SPTKEYPAE(nolign-1) = ""
      Else    
        If [M:SSP2]SPTKEY(nolign-1) = "" Then
          [M:SSP2]SPTTABPAE(nolign-1) = ""
          [M:SSP2]SPTKEYPAE(nolign-1) = ""
        Else
          [M:SSP2]SPTTABPAE(nolign-1) = [M:SSP0]SPTTGR
          [M:SSP2]SPTKEYPAE(nolign-1) = ""
        Endif
      Endif
    Endif
  Endif
  Affzo [M:SSP2]SPTTAB(nolign-1), SPTKEY(nolign-1), SPTTABPAE(nolign-1), SPTKEYPAE(nolign-1), SPTIDX(nolign-1), SPTFLT(nolign-1)
End

##########################################################################################################
Subprog AM_SPTKEY(VALEUR)
Variable Char    VALEUR()

Local Integer INBSCOL
Local Integer IMINSCOL
Local Integer ISCOLCTL

  IMINSCOL = 0
  INBSCOL = 0
  ISCOLCTL = 0
  [M:SSP2]SPTKEY(nolign-1) = VALEUR
  If [M:SSP1]SPTTYP = 4 or [M:SSP1]SPTTYP = 2 Then
    #Propose un index avec le moins de composantes possibles et le filtre associé si clé primaire unique.
    Filter [ATI] Where [F:ATI]CODFIC = [M:SSP2]SPTTAB(nolign-1) Order By [F:ATI]CODIND Asc
    [M:SSP2]SPTIDX(nolign-1) = ""
    [M:SSP2]SPTFLT(nolign-1) = ""
    For [ATI]
      If instr(1, [F:ATI]DESCRIPT, [M:SSP2]SPTKEY(nolign-1)) Then
        INBSCOL = 1
        IMINSCOL = 0
        While instr(INBSCOL, [F:ATI]DESCRIPT, '+')
          INBSCOL = instr(INBSCOL, [F:ATI]DESCRIPT, '+')
          IMINSCOL += 1
          INBSCOL += 1
        Wend
        If ISCOLCTL = 0 Then
          [M:SSP2]SPTIDX(nolign-1) = [F:ATI]CODIND
          ISCOLCTL = IMINSCOL
        Else
          If IMINSCOL < ISCOLCTL Then
            [M:SSP2]SPTIDX(nolign-1) = [F:ATI]CODIND
            ISCOLCTL = IMINSCOL
          Endif
        Endif
        If IMINSCOL = 0 Then
          Read [TGL]TGL0=[M:SSP0]SPTTGR
          If fstat Then
            [M:SSP2]SPTFLT(nolign-1) = ""
          Else
            Read [ATB]CODFIC=[M:SSP0]SPTTGR
            If fstat Then
              [M:SSP2]SPTFLT(nolign-1) = ""
            Else
              [M:SSP2]SPTFLT(nolign-1) = "[F:" + [F:ATB]ABRFIC + ']' + [F:TGL]TGRMAIKEY
            Endif
          Endif
        Else
          [M:SSP2]SPTFLT(nolign-1) = ""
        Endif
      Endif
    Next
    Filter [ATI]
  Else
    If [M:SSP2]SPTLEV(nolign-1) > 1 Then
      [M:SSP2]SPTTABPAE(nolign-1) = ""
    Else
      If [M:SSP2]SPTTAB(nolign-1) = "" Then
        [M:SSP2]SPTTABPAE(nolign-1) = ""
      Else
        If [M:SSP2]SPTKEY(nolign-1) = "" Then
          [M:SSP2]SPTTABPAE(nolign-1) = ""
        Else
          [M:SSP2]SPTTABPAE(nolign-1) = [M:SSP0]SPTTGR
        Endif
      Endif
    Endif
  Endif
  Affzo [M:SSP2]SPTTAB(nolign-1), SPTKEY(nolign-1), SPTTABPAE(nolign-1), SPTKEYPAE(nolign-1), SPTIDX(nolign-1), SPTFLT(nolign-1)
End

##########################################################################################################
Subprog AS_SPTLEV(VALEUR)
Variable Decimal VALEUR

  VALEUR = 1
End

##########################################################################################################
Subprog AS_SPTKEY(VALEUR)
Variable Char    VALEUR()

  If [M:SSP2]SPTLEV(nolign-1) < 1 Then
    VALEUR = ""
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog AS_SPTTABPAE(VALEUR)
Variable Char    VALEUR()

  If [M:SSP2]SPTLEV(nolign-1) < 1 Then
    VALEUR = ""
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog C_SPTKEYPAE(VALEUR)
Variable Char    VALEUR()
End

##########################################################################################################
Subprog C_SPTIDX(VALEUR)
Variable Char    VALEUR()

Local Integer IINDFOUND

  IINDFOUND = 0
  #Vérifie si l'index existe dans la description de la table.
  Filter [ATI] Where [F:ATI]CODFIC = [M:SSP2]SPTTAB(nolign-1) Order By [F:ATI]CODIND Asc
  For [ATI]
    If [F:ATI]CODIND = VALEUR Then
      IINDFOUND = 1
      Break
    Endif
  Next
  Filter [ATI]
  If !IINDFOUND Then
    #Cet index n'est pas défini dans la description de la table. Saisie refusée.
    GMESSAGE = mess(697,196,1) - mess(627,196,1)
    GERR = 1
    mkstat = 2
  Endif
  #Vérifie si l'index sélectionné contient bien le champs contenant le code cible
  Filter [ATI] Where [F:ATI]CODFIC = [M:SSP2]SPTTAB(nolign-1) Order By [F:ATI]CODIND Asc
  For [ATI]
    If [F:ATI]CODIND = VALEUR Then
      If !instr(1, [F:ATI]DESCRIPT, [M:SSP2]SPTKEY(nolign-1)) Then
        #Cet index ne contient pas le champ clé indiqué pour la table : 
        GMESSAGE = mess(698,196,1) - [M:SSP2]SPTTAB(nolign-1) + '.' - mess(627,196,1)
        GERR = 1
        mkstat = 2
        Break
      Endif
    Endif
  Next
  Filter [ATI]
End

##########################################################################################################
Subprog AM_SPTIDX(VALEUR)
Variable Char    VALEUR()

  [M:SSP2]SPTIDX(nolign-1) = VALEUR
  #Ajoute le description de lien dans le filtre en cas de clé unique
  Read [ATI]CODIND=[M:SSP2]SPTTAB(nolign-1);[M:SSP2]SPTIDX(nolign-1)
  If fstat Then
    [M:SSP2]SPTFLT(nolign-1) = ""
  Else
    If instr(1, [F:ATI]DESCRIPT, [M:SSP2]SPTKEY(nolign-1)) Then
      If instr(1, [F:ATI]DESCRIPT, '+') Then
        [M:SSP2]SPTFLT(nolign-1) = ""
      Else
        Read [TGL]TGL0=[M:SSP0]SPTTGR
        If fstat Then
          [M:SSP2]SPTFLT(nolign-1) = ""
        Else
          Read [ATB]CODFIC=[M:SSP0]SPTTGR
          If fstat Then
            [M:SSP2]SPTFLT(nolign-1) = ""
          Else
            [M:SSP2]SPTFLT(nolign-1) = "[F:" + [F:ATB]ABRFIC + ']' + [F:TGL]TGRMAIKEY
          Endif
        Endif
      Endif
    Else
      [M:SSP2]SPTFLT(nolign-1) = ""
    Endif
  Endif
  Affzo [M:SSP2]SPTIDX(nolign-1)
  Affzo [M:SSP2]SPTFLT(nolign-1)
End

##########################################################################################################
Subprog AS_SPTTYP(VALEUR)
Variable Integer VALEUR

  If GINTRA Then
    GMENLOC(2) = 1
  Endif
End

##########################################################################################################
Subprog AM_SPTTGR(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    [M:SSP1]SPTNAMAXX = ""
  Else
    Call SET_DENOM_DEF(VALEUR)
  Endif
  [M:SSP0]SPTTGR = VALEUR
  Affzo [M:SSP0]SPTTGR
  Affzo [M:SSP1]SPTNAMAXX
End

##########################################################################################################
Subprog AM_SPTTABPAE(VALEUR)
Variable Char    VALEUR()

  If [M:SSP1]SPTTYP = 1 Then
    If VALEUR = [M:SSP0]SPTTGR Then
      Read [TGL]TGL0=[M:SSP0]SPTTGR
      If fstat Then
        [M:SSP2]SPTKEYPAE(nolign-1) = ""
      Else
        [M:SSP2]SPTKEYPAE(nolign-1) = [F:TGL]TGRMAIKEY
      Endif
    Endif
  Endif
  [M:SSP2]SPTTABPAE(nolign-1) = VALEUR
  Affzo [M:SSP2]SPTTABPAE(nolign-1), SPTKEYPAE(nolign-1)
End

##########################################################################################################
Subprog AS_SPTIDX(VALEUR)
Variable Char    VALEUR()

  If [M:SSP1]SPTTYP <> 4 Then
    If [M:SSP1]SPTTYP <> 2 Then
      VALEUR = ""
      mkstat = 2
    Endif
  Endif
End

##########################################################################################################
Subprog C_SPTFLT(VALEUR)
Variable Char    VALEUR()

Local Char MSG(250)
Local Char SZVALEUR(250)

  MSG = ""
  #Support de premier niveau
  If [M:SSP1]SPTTYP = 4 or [M:SSP1]SPTTYP = 2 Then
    SZVALEUR = VALEUR
    Call ANALYSE(SZVALEUR,[M:SSP0]SPTTGR,MSG) From SUBTGLB
    If MSG <> "" Then
      GMESSAGE = MSG
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

##########################################################################################################
$TRTCOP
#-----------------------------------------------------------#
# Etiquette appelée depuis le traitement superviseur ACOPIE #
# --------------------------------------------------------- #
# Traitement de la copie d'un support de sélection          #
#-----------------------------------------------------------#

  If [M]DOSORG = nomap Then
    Local File SELSSP [SSP1]
    Local File SELSSPCPN  [SSC1]
    Local File ATEXTRA [AXX1]
  Else
    Local File =[M]DOSORG+".SELSSP" [SSP1]
    Local File =[M]DOSORG+".SELSSPCPN" [SSC1]
    Local File =[M]DOSORG+".ATEXTRA" [AXX1]
  Endif
  If [M]DOSDES = nomap Then
    Local File SELSSP [SSP2]
    Local File SELSSPCPN  [SSC2]
    Local File ATEXTRA [AXX2]
  Else
    Local File =[M]DOSDES+".SELSSP" [SSP2]
    Local File =[M]DOSDES+".SELSSPCPN" [SSC2]
    Local File =[M]DOSORG+".ATEXTRA" [AXX2]
  Endif
  OK = 1
  Look [SSP2]SSP0=TABLE
  If !fstat Then
    OK = 2
    Call AVERTIR([M]DOSDES-TABLE-mess(148,196,1),OK) From GESECRAN
    If OK <> 2 Then
      OK = 0
    Endif
  Endif
  If OK Then
    Call DEBTRANS From GLOCK
    Gosub TRT_COPIE
  Endif
  Close Local File [SSP1], [SSC1], [SSP2], [SSC2], [AXX1], [AXX2]
Return

##########################################################################################################
$TRT_COPIE
  #--------------------------------------------------#
  # Transaction de copie d'un support de sélection   #
  #--------------------------------------------------#
  GOK = 1
  Trbegin [SSP2]
  Delete [SSP2] Where SPTNUM=TABLE
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$" + [M]DOSDES+".SELSSP"-TABLE  
    Goto ROLL_COPIE
  Elsif fstat Then
    GOK = 0
    Call RSTA("SSP2",TABLE) From GLOCK   
    Goto AB_COPIE
  Endif
  Delete [SSC2] Where SPTNUM=TABLE
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$" + [M]DOSDES+".SELSSPCPN"-TABLE  
    Goto ROLL_COPIE
  Elsif fstat Then
    GOK = 0
    Call RSTA("SSC2",TABLE) From GLOCK   
    Goto AB_COPIE
  Endif
  If GOK = 1 Then
    Read [SSP1]SSP0=TABLE
    If !fstat Then
      [F:SSP2] = [F:SSP1]
      Write [SSP2]
      If fstat Then
        GOK = 0 
        Call FSTA("SSP2") From GLOCK
        Goto AB_COPIE
      Endif
      # FGR 03/03/2009 : X3SUIVI52963 Texte traduisible
      Call COPTEXTRA("SELSSP", "SPTNAMAXX", [M:SSP0]SPTNUM, "") From ATEXTRA
      If GOK = 0 Then
        Goto AB_COPIE
      Endif
    Endif
  Endif
  If GOK = 1 Then
    Filter [SSC1] Where [F:SSC1]SPTNUM= TABLE
    For [SSC1]
      [F:SSC2] = [F:SSC1]
      Write [SSC2]
      If fstat Then
        GOK = 0 
        Call FSTA("SSC2") From GLOCK  
        Goto AB_COPIE  
      Endif
    Next
    Filter [SSC1]
  Endif
  If GOK = 1 Then
    If [F:SSP1]SPTTYP = 2 Then
      If [F:SSP1]SPTPRO <> "" Then
        #On a un fichier traitement a copier
        Local Integer STAT
        Local Char    EXT(10)
        Local Char    FICORG(250) , FICDES(250) , SZFIC(250)
        Local Char    DOSORG(20) , DOSDES(20)
        Local Char    MACORG(40) , MACDES(40)

        Call MACHINE([M]DOSORG,MACORG,DOSORG) From ORDSYS
        Call MACHINE([M]DOSDES,MACDES,DOSDES) From ORDSYS
        Call PATHFIL(SZFIC,"TRT",[F:SSP1]SPTPRO,"LCKsrc",DOSDES,"",MACDES) From DOSCONT
        If filinfo(SZFIC,0) >= 0 Then
          Call ERREUR("|"+SZFIC-"|\"-mess(13,139,1)) From GESECRAN : # Traitement verrouillé
          GOK = 0
          Goto AB_COPIE
        Endif
        If GOK = 1 Then
          For EXT = "adx","src"
            Call PATHFIL(FICORG,"TRT",[F:SSP1]SPTPRO,EXT,DOSORG,"",MACORG) From DOSCONT
            If filinfo(FICORG,0) >= 0 Then
              Call PATHFIL(FICDES,"TRT",[F:SSP1]SPTPRO,EXT,DOSDES,"",MACDES) From DOSCONT
              If EXT = "adx" and filinfo(FICDES,0) >= 0 Then
                Call EFFACE(FICDES,STAT) From ORDSYS : # Pour copier les droits
              Endif
              Call COPIE(FICORG,FICDES,STAT) From ORDSYS
            Endif
          Next EXT
        Endif
      Endif
    Endif
  Endif
  Commit
Return

##########################################################################################################
#----- Abandon de la copie -----#
$AB_COPIE
  Rollback
Return

##########################################################################################################
#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
  Rollback
  Call ROLL From GLOCK
  If !GROLL Then
    Goto TRT_COPIE
  Endif 
Return
