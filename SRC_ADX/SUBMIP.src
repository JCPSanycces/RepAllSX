#<AdxTL>@(#)0.0.0.0 $Revision$
Call OBJET("MIP",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
  When "SETBOUT"  : Gosub SETBOUT
  When "OUVRE"    : Gosub OUVRE
  When "LIENS"    : Gosub LIENS
  When "FERME"      : Gosub FERME
  When "AP_CHANGE" : Gosub AP_CHANGE
  When "ANNULE"    : Gosub ANNULE
  When "CREATION"  : Gosub CREATION
  When "MODIF"     : Gosub MODIF
  When Default
Endcase

Return

$OUVRE
  If clalev ([F:MIP])=0 : Local File GRIMIP  [MIP] : Endif
  If clalev ([F:RIL])=0 : Local File GGRIMIP [RIL] : Endif

  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

Return

$SETBOUT
  If REP<>"" | !CLECUR | GHISTO=1
    Call VIREBOUT(CHAINE,"8") From GOBJET
  Endif

Return

$LIENS
  GCURLEG = [F:GRI]LEG
  If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
  Call LECTEXTRA([M]DES,"GRIMIP","DES",[M]COD,"") From ATEXTRA
  Call LECTEXTRA([M]DESSHO,"GRIMIP","DESSHO",[M]COD,"") From ATEXTRA

#JASMI - 2016-02-18 - Req 114309 - START
  Call DISPLAY_HIDE From SUBGRILEG
#JASMI - 2016-02-18 - Req 114309 - END

### JASMI busy testing
Call DISPLAY_AND_HIDE_FIELDS_AUTO("OMIP")# From DIVPAYE

Return

########################################
$CREATION
$MODIF
  Gosub TEXTRA
  If GOK<1 : Return : Endif

Return

########################################
# To manage translated texts (data type AX3 & AX1) in cretion and duplication
$TEXTRA
  If GREP="D"
   ## In duplication mode we want to keep all translated texts
    Call DUPTEXTRA("GRIMIP","DES",CLECUR1,"","GRIMIP","DES",[F:MIP]COD,"")  From ATEXTRA
    Call DUPTEXTRA("GRIMIP","DESSHO",CLECUR1,"","GRIMIP","DESSHO",[F:MIP]COD,"")  From ATEXTRA
  Endif
  Call MAJTEXTRA([M]DES,"GRIMIP","DES",[F:MIP]COD,"") From ATEXTRA
  Call MAJTEXTRA([M]DESSHO,"GRIMIP","DESSHO",[F:MIP]COD,"") From ATEXTRA

Return

########################################
# To change translated texts (data type AX3 & AX1) when you change the main code
$AP_CHANGE
  Call CHGTEXTRA("GRIMIP","DES",[L]OCODE,"",[L]NCODE,"") From ATEXTRA
  Call CHGTEXTRA("GRIMIP","DESSHO",[L]OCODE,"",[L]NCODE,"") From ATEXTRA

Return

########################################
# To delete translated texts (data type AX3 & AX1)
$ANNULE
  Call SUPTEXTRA("GRIMIP","DES",[L]CODE,"") From ATEXTRA
  Call SUPTEXTRA("GRIMIP","DESSHO",[L]CODE,"") From ATEXTRA

Return

$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif

Return
######################################################################################

Subprog AS_PIO(VALEUR)
Variable Integer  VALEUR
  If [M]VALMAX<>2 | [M]VALMIN<>2
   mkstat = 2 : End
  Endif

End

Subprog AS_CMPTYP(VALEUR)
Variable Integer VALEUR
  GMENLOC(4)=1

End

Subprog AS_COLTYP(VALEUR)
Variable Integer VALEUR
  GMENLOC(4)=1

End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
  GCURLEG=VALEUR

#JASMI - 2016-02-18 - Req 114309 - START
  Call DISPLAY_HIDE# From SUBGRILEG
#JASMI - 2016-02-18 - Req 114309 - END

End


######################################################################################

##############MIP TEST COPY FROM SUBGRILEG & DIVPAYE AS FROM CALLS ABOVE##############

#####Subprog DISPLAY_HIDE() originally from SUBGRILEG START

Subprog DISPLAY_HIDE()
#  If GCURLEG="FRA"|GCURLEG=""
#  #display all fields protected by KFR
#  Else
#  Endif
#  If GCURLEG="POR"|GCURLEG=""
#  #display all fields protected by KPO
#  Else
#  Endif
#  If GCURLEG="ZAF"|GCURLEG=""
#  #display all fields protected by KZA
#  Else
#  Endif
#  If GCURLEG="???"|GCURLEG=""
#  #display all fields protected by ???
#  Else
#  Endif
#  If func DIVPAYE.IS_AFRICA
#  #display all fields protected by KAQ
#  Else
#  Endif
#  If func DIVPAYE.IS_MIDDLEEAST
#  #display all fields protected by KMIEA
#  Else
#  Endif
#  If GCURLEG="FRA"|GCURLEG="POR"|GCURLEG=""
#  #display all fields protected by KFRPO
#  Else
#  Endif
  If dim([M:MIP0]CODACC)>0
    #If func DIVPAYE.IS_ZA_DEV
    If func IS_ZA_DEV
    #display all fields protected by KSA
      Chgfmt [M:MIP0]CODACC With "K:"+num$(GLONACS)+"X"
    Else
      Chgfmt [M:MIP0]CODACC With "-K:"+num$(GLONACS)+"X" : Raz [M:MIP0]CODACC
    Endif
  Endif

##########
#refresh all screens
  Affzo [M:MIP0]
##########

End

#####Subprog DISPLAY_HIDE() originally from SUBGRILEG END

#####3 Functions originally from DIVPAYE START

#JASMI - 2016-02-15 - Req 114309 - START
Funprog IS_AFRICA()
Local Integer RES
  RES=min(1,find(GCURLEG,'','ANG','BWA','GHA','KEN','LES','MAR','MOZ','NAM','NGA','SWZ','ZMB'))
End RES

Funprog IS_MIDDLEEAST()
Local Integer RES
  RES=min(1,find(GCURLEG,'','ARE','QAT','SAU'))
End RES

Funprog IS_ZA_DEV()
Local Integer RES
  If GCURLEG='ZAF'|GCURLEG='AUS'|func DIVPAYE.IS_AFRICA|func DIVPAYE.IS_MIDDLEEAST
    RES=1
  Else
    RES=0
  Endif
End RES
#JASMI - 2016-02-15 - Req 114309 - END

#####3 Functions originally from DIVPAYE END

#####Subprog DISPLAY_AND_HIDE_FIELDS_AUTO originally from DIVPAYE START

#JASMI - 2016-02-22 - Req 114309 - START
## display and gide fields depending on the current legislation (GCURLEG) ##
Subprog DISPLAY_AND_HIDE_FIELDS_AUTO(THIS_WINDOW)
Value Char THIS_WINDOW()

  If !clalev([F:AWIZZ]) : Local File AWINDOW [AWIZZ]  : Endif

  Read [F:AWIZZ]AWI0 = THIS_WINDOW
  If !fstat
    If [F:AWIZZ]MSKENT<>""
    #fields
      Call CHECK_FIELDS_FOR_SCREEN([F:AWIZZ]MSKENT)
    #blocks
      Call CHECK_BLOCKS_FOR_SCREEN([F:AWIZZ]MSKENT)
    Endif
    For I = 0 To [F:AWIZZ]NBMSK-1
    #fields
      Call CHECK_FIELDS_FOR_SCREEN([F:AWIZZ]NOMMSK(I))
    #blocks
      Call CHECK_BLOCKS_FOR_SCREEN([F:AWIZZ]NOMMSK(I))
    Next
  Endif

End

Subprog CHECK_FIELDS_FOR_SCREEN(THIS_SCREEN)
Value Char THIS_SCREEN()

  If !clalev([F:AMZZZ]) : Local File AMSKZON [AMZZZ]    : Endif

  Filter [F:AMZZZ] Where [F:AMZZZ]CODMSK=THIS_SCREEN
  For [F:AMZZZ]
    If (left$([F:AMZZZ]CODACT,1)="K"|left$([F:AMZZZ]CODACT,2)="FK")
      Call CHECK_ACTIVITY_CODE([F:AMZZZ]CODACT)
#      Infbox [F:AMZZZ]CODZON-[F:AMZZZ]CODACT
    Endif
  Next
  Filter [F:AWIZZ]

End

Subprog CHECK_BLOCKS_FOR_SCREEN(THIS_SCREEN)
Value Char THIS_SCREEN()

  If !clalev([F:AMKZZ]) : Local File AMSK [AMKZZ]     : Endif
  If !clalev([F:AMZZZ]) : Local File AMSKZON [AMZZZ]    : Endif

  Read [F:AMKZZ]CODMSK = THIS_SCREEN
  If !fstat
    For J = 0 To [F:AMKZZ]NBBLOC-1
      If (left$([F:AMKZZ]ACTBLOC(J),1)="K"|left$([F:AMKZZ]ACTBLOC(J),2)="FK")
        Call CHECK_ACTIVITY_CODE([F:AMKZZ]ACTBLOC(J))
#        Filter [F:AMZZZ] Where [F:AMZZZ]CODMSK=THIS_SCREEN & [F:AMZZZ]NUMBLOC=J+1
#        For [F:AMZZZ]
#          Infbox [F:AMZZZ]CODZON-[F:AMZZZ]CODACT
#        Next
#        Filter [F:AMZZZ]
      Endif
    Next
  Endif

End

Subprog CHECK_ACTIVITY_CODE(THIS_ACT)
Value Char THIS_ACT()

  If !clalev([F:ACVZZ]) : Local File ACTIV [ACVZZ]    : Endif
  If !clalev([F:ADIZZ]) : Local File ATABDIV [ADIZZ]    : Endif

  Read [F:ACVZZ]CODACT = THIS_ACT
  If !fstat
    If [F:ACVZZ]TYP=3
      Read [F:ADIZZ]CODE = 10302;THIS_ACT
      If !fstat
        If [F:ADIZZ]A1=GCURLEG | GCURLEG=""
          Infbox "is"-THIS_ACT
        Endif
      Endif
    Endif
    If [F:ACVZZ]TYP=1 & [F:ACVZZ]DEP=4
      Filter [F:ADIZZ] Where [F:ADIZZ]NUMTAB=10302
& &                          instr(1,[F:ACVZZ]ACTFOR,[F:ADIZZ]CODE)>0
      For [F:ADIZZ]
#        If instr(1,[F:ACVZZ]ACTFOR,THIS_ACT)
        If [F:ADIZZ]A1=GCURLEG | GCURLEG=""
          Infbox "is2"-THIS_ACT
        Endif
      Next
      Filter [F:ADIZZ]
      TMPSTR=[F:ACVZZ]ACTFOR
      While instr(1,TMPSTR,"K")>0
        TMPACT=right$(TMPSTR,instr(1,TMPSTR,"K"))
        If instr (1,TMPACT,"&|()")
          TMPACT=left$(TMPACT,instr (1,TMPACT,"&|()"))
        Endif
        Infbox TMPACT
        TMPSTR=right$(TMPSTR,instr(1,TMPSTR,"K")+len(TMPACT))
        Infbox TMPSTR
      Wend
    Endif
  Endif

End
#JASMI - 2016-02-22 - Req 114309 - END

#####Subprog DISPLAY_AND_HIDE_FIELDS_AUTO originally from DIVPAYE START

