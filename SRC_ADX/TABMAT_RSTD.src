# Classe TABMAT

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD_AFTER"  : Goto READ_AFTER
    Endcase
Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase

Case [L]CURPRO
  When "TMA.EMPTYP"   : Gosub EMPTYP  #114791.n
Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return



################################################################################################
$EMPTYP
  Case ACTION
    When "PROPAGATE"  : Gosub EMPTYP_PROPAGATE  #114791.n
  Endcase
Return

#114791.sn
################################################################################################
$EMPTYP_PROPAGATE
  Case this.EMPTYP
    When 2 #Detail team
      [L]ASTATUS = fmet this.ASETATTRIBUTE("SUMEMP", "$isDisabled", "true")
      [L]ASTATUS = fmet this.ASETATTRIBUTE("USR", "$isDisabled", "true")
      [L]ASTATUS = fmet this.ASETATTRIBUTE("CHGRAT", "$isDisabled", "true")
    When 3 #Summary team
      [L]ASTATUS = fmet this.ASETATTRIBUTE("SUMEMP", "$isDisabled", "false")
      [L]ASTATUS = fmet this.ASETATTRIBUTE("USR", "$isDisabled", "true")
    When Default
      [L]ASTATUS = fmet this.ASETATTRIBUTE("SUMEMP", "$isDisabled", "true")
      [L]ASTATUS = fmet this.ASETATTRIBUTE("USR", "$isDisabled", "false")
      [L]ASTATUS = fmet this.ASETATTRIBUTE("CHGRAT", "$isDisabled", "false")
  Endcase
Return

################################################################################################
$READ_AFTER
  Case this.TMA.EMPTYP
    When 2 #Detail team
      [L]ASTATUS = fmet this.TMA.ASETATTRIBUTE("SUMEMP", "$isDisabled", "true")
      [L]ASTATUS = fmet this.TMA.ASETATTRIBUTE("USR", "$isDisabled", "true")
      [L]ASTATUS = fmet this.TMA.ASETATTRIBUTE("CHGRAT", "$isDisabled", "true")
    When 3 #Summary team
      [L]ASTATUS = fmet this.TMA.ASETATTRIBUTE("SUMEMP", "$isDisabled", "false")
      [L]ASTATUS = fmet this.TMA.ASETATTRIBUTE("USR", "$isDisabled", "true")
    When Default
      [L]ASTATUS = fmet this.TMA.ASETATTRIBUTE("SUMEMP", "$isDisabled", "true")
      [L]ASTATUS = fmet this.TMA.ASETATTRIBUTE("USR", "$isDisabled", "false")
      [L]ASTATUS = fmet this.TMA.ASETATTRIBUTE("CHGRAT", "$isDisabled", "false")
  Endcase
Return
#114791.en

