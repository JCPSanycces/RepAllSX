#<AdxTL>@(#)0.0.0.0 $Revision$
#-----------------------------------------------------------------------#
# Vérification que l'article n'a pas fait l'objet d'une cde ouverte     #
#-----------------------------------------------------------------------#
$DIVPSHITM
Local Integer    WRET
Local Integer    WSTAT
Local Decimal    WCOEFF1,WCOEFF2,WCOEFF3
Local Char       WCUR(GLONCUR)
Local Integer    WDEC
Local File PRODERC [POC]
Filter [POC] Where ITMREF=this.ITMREF & STRDAT<=date$ & ENDDAT>=date$
Look [POC] POC2 First
Filter [POC]
If fstat=0
  GMESSAGE=mess(1,194,1) : WRET=[V]CST_AYES
  [L]ASTATUS = fmet this.ASETERROR ("BPSNUM", WMESSAGE, [V]CST_AYES)
  If [L]ASTATUS= [V]CST_ANO
    ARET_VALUE = [L]ASTATUS
    Return
  Endif
Endif
Return

#-------------------------------------------#
# INITIALISATION DU PRIX NET                #
# RéCUPéRATION DU PRIX STANDARD ARTICLE     #
#-------------------------------------------#
$_MET_CALNETPRI
Local File ITMCOST [ITC]
#
If this.PRHFCY = "" | this.ITMREF = "" : Return : Endif
If this.NETPRI <> 0 : Return : Endif
# not Syracused yet
#Call GETPRI(this.ITMREF,this.PRHFCY,this.PRQDAT,1,"","",1,WCOEFF3,WSTAT) From STKVAL
WSTAT = 0
If WSTAT = 0
  WCOEFF3 = [F:ITC]VLTTOT
  #-------------------------------------------------#
  # LE COUT STANDARD EST EN DEVISE SITE STOCKAGE    #
  # DONC LA DEVISE EST GCUR (MEME SOCIETE JURIDIQUE)#
  # plus de diviseur prix le 16 oct 98  cg          #
  #-------------------------------------------------#
  WCUR = fmet CTX.ACACHE.ACPY.AGETVALCHAR(this.CPY,"ACCCUR")
  WDEC = fmet CTX.ACACHE.ADEV.AGETVALCHAR(this.CUR,"DECNBR")
  If WCUR <> this.CUR
     Call CONVERT2(WCUR,this.CUR,WCUR,this.CHGTYP,datesyst,
&                  [F:ITC]VLTTOT,WCOEFF3,WSTAT) From TRTDEV
  Endif
  #------ Conversion si nécessaire à cause de l'unité ------#
  If this.PUU<>this.STU
    #----- Appel du S/P pour chargement du coefficient avec précision maxi -----#
    Call PCAL_QTY(this.QTYPUU,this.PUU,WCOEFF1,this.STU,
&                 this.ITMREF,this.BPSNUM,1,WCOEFF2) From TRTACHQTE1
    If WCOEFF2=0 WCOEFF2=1 : Endif
    WCOEFF3=WCOEFF3*ACOEFF2
  Endif
  this.NETPRI = arr(WCOEFF3,10^-WDEC)
  this.GROPRI = this.NETPRI
  #-------------------#
  # motif  prix brut  #
  #-------------------#
  If dim(this.PRIREN)>0
    this.PRIREN=fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "UPDPRIPUR")
  Endif
Endif
Return
