#<AdxTL>@(#)5.0.0.0 $Revision$
#-----------------------------------------------------#
# Retourne le nom du dossier X3 avec le nom de machine
#-----------------------------------------------------#

Funprog DOSX3(DOSSIER)
Value Char DOSSIER
Local Char    DOSX3(GLONADD)
Local Char    MACHINE(GLONAMC) , APPLI(GLONADS)
Local Integer ER
DOSX3 = ""
Onerrgo ERDOS
If DOSSIER="" or DOSSIER=nomap
 Local File ADOVAL [ADW_]
Else
 Local File =DOSSIER+".ADOVAL" [ADW_]
Endif
Read [ADW_]ADW0="";"";"SUPDOS"
If !fstat & [F:ADW_]VALEUR<>""
 DOSX3 = [F:ADW_]VALEUR
Endif
Close Local File [ADW_]
Onerrgo
If !ER & DOSX3<>""
 Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS
 If MACHINE<>""
  DOSX3 = MACHINE+"@"+DOSX3
 Endif
Endif
End DOSX3

$ERDOS
ER = errn
Resume

