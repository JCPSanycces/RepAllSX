#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT14 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:13:36"
A_USER  = "DOC"
A_STAMP = "20181109231336"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBREXN0"
  If [M]NBREXN0=0
  Endif
 When "WNBREXN"
  If [M]WNBREXN=0
  Endif
 When "NBREXN"
  If [M]NBREXN=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRMAT14 [EMPE]
Gosub HORODAT
Local Inpbox "HRMAT14" From GFONCTION At A_STAMP With A_WINDPREV Mask [EMPE] As [SIM_]
Grizo [EMPE]10
Grizo [EMPE]20
Grizo [EMPE]30
Grizo [EMPE]40
Grizo [EMPE]50
Grizo [EMPE]60
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [EMPE]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=20 : Y1(0)=1 : Y2(0)=23
X1(1)=21 : X2(1)=74 : Y1(1)=1 : Y2(1)=2
X1(2)=21 : X2(2)=74 : Y1(2)=3 : Y2(2)=18
X1(3)=21 : X2(3)=74 : Y1(3)=19 : Y2(3)=21
X1(4)=21 : X2(4)=74 : Y1(4)=22 : Y2(4)=23
X1(5)=1 : X2(5)=0 : Y1(5)=24 : Y2(5)=23
Return

$ON_NBREXN0
Onevent BEFORE_INPUT Call AS_NBREXN0 From W1HRMAT14
Onevent CONTROL Call C_NBREXN0 From W1HRMAT14
Return

Subprog AS_NBREXN0
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_NBREXN0 From SUBEML2
Gosub _AFF
End

Subprog C_NBREXN0
Local Decimal BASPAG
## Action STD
Call C_NBREXN0 From SUBEML2
If mkstat : GERR = 1 : GZONE = "NBREXN0" : GZNUM = 0 : Endif
Gosub _AFF
End

$ON_EXSDAT0
Onevent BEFORE_AREA Gosub AV_EXSDAT0 From W1HRMAT14
Return

$AV_EXSDAT0
Chgfmt [M]EXSDAT0(indice) With "DPzZ:"+GFMDAT4
Gosub _AFF
Return

$ON_WEXSDAT
Onevent BEFORE_INPUT Call AS_WEXSDAT(zc) From W1HRMAT14
Onevent CONTROL Call C_WEXSDAT(zc) From W1HRMAT14
Onevent BEFORE_AREA Gosub AV_WEXSDAT From W1HRMAT14
Return

$AV_WEXSDAT
Chgfmt [M]WEXSDAT(indice) With "D:"+GFMDAT4
Gosub _AFF
Return

Subprog AS_WEXSDAT(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_WEXSDAT(VALEUR) From SUBEML2
If mkstat=2
 [M]WEXSDAT(INDIC) = VALEUR
 Affzo WEXSDAT(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_WEXSDAT(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "WEXSDAT" : GZNUM = 212 : Endif
If !mkstat
 ## Action STD
 Call C_WEXSDAT(VALEUR) From SUBEML2
 If mkstat : GERR = 1 : GZONE = "WEXSDAT" : GZNUM = 212 : Endif
Endif
Gosub _AFF
End

$ON_WNBREXN
Onevent CONTROL Call C_WNBREXN From W1HRMAT14
Onevent AFTER_LINE Call APRES_WNBREXN From W1HRMAT14
Return

Subprog C_WNBREXN
Local Decimal BASPAG
## Action STD
Call C_WNBREXN From SUBEML2
If mkstat : GERR = 1 : GZONE = "WNBREXN" : GZNUM = 0 : Endif
Gosub _AFF
End

Subprog APRES_WNBREXN
Local Decimal BASPAG
## Action STD
Call APRES_WNBREXN From SUBEML2
If mkstat : End : Endif
Gosub _AFF
End

$ON_WEXSVAR
Onevent CONTROL Call C_WEXSVAR(zc) From W1HRMAT14
Onevent AFTER_CHANGE Gosub AMM_WEXSVAR From W1HRMAT14
Onevent BEFORE_INPUT Call AS_WEXSVAR(zc) From W1HRMAT14
Return

Subprog AS_WEXSVAR(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(124,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_WEXSVAR(zc) From W1HRMAT14
Onkey   2 Titled GBOUTS Call S_WEXSVAR(zc) From W1HRMAT14
Onkey 144 Titled GBOUTP Call P_WEXSVAR(zc) From W1HRMAT14
Onkey 146 Titled GBOUTA Call SA_WEXSVAR(zc) From W1HRMAT14
Gosub _AFF
End

Subprog C_WEXSVAR(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "WEXSVAR" : GZNUM = 124 : Endif
If !mkstat
 ## Action CONTVRA
 Call CONTVRA(VALEUR) From SUBVRA
 If mkstat : GERR = 1 : GZONE = "WEXSVAR" : GZNUM = 124 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WEXSVAR" : GZNUM = 124 : Endif
  If !mkstat
   ## Action CONTUNI
   Call UNICITE2(VALEUR,[M]WNBREXN,[M]WEXSVAR) From OBJDIV
   If mkstat : GERR = 1 : GZONE = "WEXSVAR" : GZNUM = 124 : Endif
   If !mkstat
    ## Action CONTMULSEL
    Call CONTMULSEL(VALEUR,[M:EMP0]REFNUM,"VRA",GCURLEG) From TOOLSHRLEG
    If mkstat : GERR = 1 : GZONE = "WEXSVAR" : GZNUM = 124 : Endif
   Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_WEXSVAR
Call AM_WEXSVAR(zc)
If !mkstat & GOBJET
 zoncou = "WEXSVAR" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WEXSVAR(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_WEXSVAR(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "WEXSVAR" : GZNUM = 124 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZWEXSVAR)")>indice
 [M]WEXSVAR(indice) = VALEUR
 Affzo ZWEXSVAR(indice)
Endif
Gosub _AFF
End

Subprog S_WEXSVAR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELMULLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELMULLEG"
 PARMSK(1) = [M:EMP0]REFNUM
 PARMSK(2) = "VRA"
 PARMSK(3) = "HRMAT14"
 PARMSK(4) = "WEXSVAR"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELMULLEG","TOOLSHRLEG","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_WEXSVAR(VALEUR)
Variable Char    VALEUR()
Call OBJET("VRA",VALEUR,num$(GCURLEG)) From GOBJET
Gosub _AFF
End

Subprog SA_WEXSVAR(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "VRA"
PARMSK(2) = num$(GCURLEG)
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_WEXSVAR(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = num$(GCURLEG)
Call VISU("VRA",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZWEXSVAR
Onevent BEFORE_AREA Gosub AV_ZWEXSVAR From W1HRMAT14
Return

$AV_ZWEXSVAR
Call LECTEXTRA(zc,"VARIA","DES",num$(GCURLEG),num$([M]WEXSVAR(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_WEXSAMT
Onevent BEFORE_AREA Gosub AV_WEXSAMT From W1HRMAT14
Onevent AFTER_CHANGE Gosub AMM_WEXSAMT From W1HRMAT14
Onevent CONTROL Call C_WEXSAMT(zc) From W1HRMAT14
Return

$AV_WEXSAMT
## Action FMTFM2DEV
Call FMTFM2DEV([V]GCURSHR) From TRTDIV
Chgfmt [M]WEXSAMT(indice) With "N+z3:"+GFMT
Gosub _AFF
Return

Subprog C_WEXSAMT(VALEUR)
Variable Decimal VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "WEXSAMT" : GZNUM = 3603 : Endif
Gosub _AFF
End

$AMM_WEXSAMT
Call AM_WEXSAMT(zc)
If !mkstat & GOBJET
 zoncou = "WEXSAMT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WEXSAMT(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_WEXSAMT(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "WEXSAMT" : GZNUM = 3603 : Endif
Gosub _AFF
End

$ON_WCAT
Onevent BEFORE_INPUT Call AS_WCAT(zc) From W1HRMAT14
Onevent AFTER_CHANGE Gosub AMM_WCAT From W1HRMAT14
Onevent INIT_AREA Call D_WCAT(zc) From W1HRMAT14
Onevent CONTROL Call C_WCAT(zc) From W1HRMAT14
Return

Subprog D_WCAT(VALEUR)
Variable Integer VALEUR
If varinit([M]WCAT,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_WCAT(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(10554) From COMBOS
## Action STD
Call AS_WCAT(VALEUR) From SUBEML2
If mkstat=2
 [M]WCAT(INDIC) = VALEUR
 Affzo WCAT(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,10554,1))))
Endif
If !mkstat
 Discombo 0 From WCAT(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From WCAT(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_WCAT(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$AMM_WCAT
Call AM_WCAT(zc)
If !mkstat & GOBJET
 zoncou = "WCAT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_WCAT(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_WCAT(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "WCAT" : GZNUM = 25354 : Endif
Gosub _AFF
End

