$ON_WADD14
Onevent BEFORE_INPUT Call AS_WADD14(zc) From W1HRMAT14
Onevent INIT_AREA Call D_WADD14(zc) From W1HRMAT14
Onevent CONTROL Call C_WADD14(zc) From W1HRMAT14
Return

Subprog D_WADD14(VALEUR)
Variable Integer VALEUR
If varinit([M]WADD14,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_WADD14(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_WADD14(VALEUR) From SUBEML2
If mkstat=2
 [M]WADD14(INDIC) = VALEUR
 Affzo WADD14(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_WADD14(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "WADD14" : GZNUM = 16730 : Endif
Gosub _AFF
End

$ON_EXSVAR
Return

