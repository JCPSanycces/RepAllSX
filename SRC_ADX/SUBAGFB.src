#<AdxTL>@(#)12.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("AGF",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "LIENS"       : Gosub LIENS
 When "OUVRE"       : Gosub OUVRE
 When "CREATION"    : Gosub CREATION
 When "AP_VERF_ANU" : Gosub AP_VERF_ANU
Endcase
Return

$LIENS
  # MHB 28/10/08 : ajout pyramide des regroupements
  Gosub FILL_PYRAMIDE
Return

$OUVRE
If clalev([F:ASB])=0 : Local File ABLBSYS    [ASB] : Endif
For I=1 To 3
 Call CHARGE_IMAGE(func DEFIMG(I)) From SUBGYM
Next IMG
Return

$CREATION
If GOK=1
 Read [CPY]CPY0 = [F:AGF]GRP
 If !fstat & dim([F:CPY]ACCCUR)>0 & dim(GCURSHR)>0
  [F:CPY]ACCCUR = GCURSHR
  Rewrite [CPY]
  If fstat
   GOK = 0 : Call FSTA("CPY") From GLOCK : Return
  Endif
 Endif
Endif
Return

Funprog DEFIMG(I)
Value Integer I
Case I
 When 1 : End "PYSITE"
 When 2 : End "PYSITEPR"
 When 3 : End "PYSTE"
Endcase
End

# MHB 28/10/08 : ajout pyramide des sites/sociétés de regroupement
$FILL_PYRAMIDE
Local Char WCPY

  If !clalev([M:FGRP]) Then Return Endif

  # Vider le XSL des composants
  Effzo [M:FGRP]5

  If !clalev([F:FCYP]) Then Local File FACILITY [FCYP] Endif
  If !clalev([F:CPYP]) Then Local File COMPANY  [CPYP] Endif
  If !clalev([F:FGRP]) Then Local File FACGROUP [FGRP] Endif
  If !clalev([F:AGCP]) Then Local File AGRPCPY  [AGCP] Endif

  If dim(L)<0 Then
    Local Integer L, WLEVEL, WLIGNE, WPLIGNE, GROUP_SOC
  Endif
  nolign  = 1
  L       = nolign -1
  WLEVEL  = 0 : WLIGNE  = 0 : WPLIGNE = 0
  WCPY    = [M:FGR0]GRP
  GROUP_SOC = G_NON

  Gosub LISTE_IMAGES
  If [M:FGR0]FLGCPY=2 Then
    GROUP_SOC = G_OUI
  Endif

  Gosub ADD_GRP
  WLEVEL += 1
  If [M:FGR0]FLGCPY=2 Then
    Gosub ADD_CPY
  Else
    Gosub ADD_FCY
  Endif

  [M:FGRP]NBLIG = L+1
  Affzo [M:FGRP]

  If clalev([F:FCYP]) Then Close Local File [FCYP] Endif
  If clalev([F:CPYP]) Then Close Local File [CPYP] Endif
  If clalev([F:FGRP]) Then Close Local File [FGRP] Endif
  If clalev([F:AGCP]) Then Close Local File [AGCP] Endif
Return

$LISTE_IMAGES
Local Char WICO_GRP(30), WICO_FCY(30), WICO_FCY_MAIN(30)

  If func CTL_FIC_IMAGE("head.gif")=2
    WICO_GRP = "head.gif"
  Else
    WICO_GRP = "mvt2.gif"
  Endif
  If func CTL_FIC_IMAGE("site.gif")=2
    WICO_FCY = "site.gif"
  Else
    WICO_FCY = "mvt2.gif"
  Endif
  If func CTL_FIC_IMAGE("societe.gif")=2
    WICO_FCY_MAIN = "societe.gif"
  Else
    WICO_FCY_MAIN = "mvt2.gif"
  Endif
Return

Funprog CTL_FIC_IMAGE(LNOMIMAGE)
Value Char LNOMIMAGE
Local Integer WOK : WOK=2
Local Char WREPERT(200),WDIRSEP

  Case GOS(1)
    When "dos"   : WDIRSEP = "\"
    When Default : WDIRSEP = "/"
  Endcase

  WREPERT=filpath(nomap+WDIRSEP+"RES","","","X3_PUB")
  If LNOMIMAGE<>"" & filinfo(WREPERT+WDIRSEP+LNOMIMAGE,0)<0
    WOK = 1
  Endif
End WOK

$ADD_GRP
  [M:FGRP]LIBL1(L)  = WCPY         : # Texte principal
  [M:FGRP]LIBL2(L)  = [M:FGR0]DES  : # info bulle
  [M:FGRP]IMG(L)    = WICO_GRP
  [M:FGRP]LIGNE(L)  = WLIGNE
  [M:FGRP]PARLIN(L) = -1
  [M:FGRP]LEV(L)    = WLEVEL
  [M:FGRP]GRPP(L)   = WCPY
  Gosub ADD_HNOM
Return

$ADD_CPY
Local Char    S_WCPY
Local Integer S_WPLIGNE

  S_WCPY = WCPY
  For [F:AGCP]AGC1 Where GRP=S_WCPY
    WLIGNE += 1
    L += 1
    [M:FGRP]LIBL1(L)  = [F:AGCP]CPY         : # Texte principal
    Read [F:CPYP]CPY0 = [F:AGCP]CPY
    If !fstat Then
      If [F:CPYP]CPYNAM<>"" Then
        [M:FGRP]LIBL2(L)  = [F:CPYP]CPYNAM  : # info bulle
      Else
        [M:FGRP]LIBL2(L)  = [F:CPYP]CPY     : # info bulle
      Endif
    Endif
    [M:FGRP]IMG(L)    = WICO_FCY_MAIN
    [M:FGRP]LIGNE(L)  = WLIGNE
    [M:FGRP]PARLIN(L) = WPLIGNE
    [M:FGRP]LEV(L)    = WLEVEL
    [M:FGRP]GRPP(L)   = [F:AGCP]CPY
    [M:FGRP]CPYP(L)   = [F:AGCP]CPY
    Gosub ADD_HNOM

    # On passe au niveau suivant, il faut donc incrémenter le WLEVEL, sauvegarder le WPLIGNE avant de l'affecter à la ligne
    # de la société en cours, et enfin affecter WCPY à la société en cours
    # Après appel de ADD_FCY, il faudra faire l'opération inverse
    WLEVEL  += 1
    S_WPLIGNE = WPLIGNE
    WPLIGNE = WLIGNE
    WCPY = [F:AGCP]CPY
    Gosub ADD_FCY
    WLEVEL  -= 1
    WPLIGNE = S_WPLIGNE
  Next
  WCPY = S_WCPY
Return

$ADD_FCY
  For [F:FGRP]FGR0 Where CPY=WCPY
    WLIGNE += 1
    L += 1
    [M:FGRP]LIBL1(L)  = [F:FGRP]FCY     : # info bulle
    Read [F:FCYP]FCY0 = [F:FGRP]FCY
    If !fstat Then
      If [F:FCYP]FCYNAM<>"" Then
        [M:FGRP]LIBL2(L)  = [F:FCYP]FCYNAM  : # info bulle
      Else
        [M:FGRP]LIBL2(L)  = [F:FGRP]FCY     : # info bulle
      Endif
    Endif
    [M:FGRP]IMG(L)    = WICO_FCY
    [M:FGRP]LIGNE(L)  = WLIGNE
    [M:FGRP]PARLIN(L) = WPLIGNE
    [M:FGRP]LEV(L)    = WLEVEL
    [M:FGRP]GRPP(L)   = WCPY
    [M:FGRP]FCYP(L)   = [F:FGRP]FCY
    Gosub ADD_HNOM
  Next
Return

$ADD_HNOM
  If GROUP_SOC=G_NON Then
    [M:FGRP]KEYC(L)      = num$([M:FGRP]LEV(L))+"-"+[M:FGRP]GRPP(L) +"-"+ [M:FGRP]FCYP(L)
  Else
    [M:FGRP]KEYC(L)      = num$([M:FGRP]LEV(L))+"-"+[M:FGRP]GRPP(L) +"-"+ [M:FGRP]CPYP(L) +"-"+ [M:FGRP]FCYP(L)
  Endif
  If [M:FGRP]PARLIN(L)<>-1
    [M:FGRP]PARKEY(L) = [M:FGRP]KEYC([M:FGRP]PARLIN(L))
  Else
    [M:FGRP]PARKEY(L) = ""
  Endif
  # Niveau plié/déplié
  If dim([M:FGRP]EXPFLG)>0
    If [M:FGRP]PARLIN(L) =-1
      [M:FGRP]EXPFLG(L) = 2
    Else
      # FQ65148 : le niveau sera présenté Plié avec la valeur 1, et non 0
#       [M:FGRP]EXPFLG(L) = 0
      [M:FGRP]EXPFLG(L) = 1
    Endif
  Endif
Return
# Fin modif MHB 28/10/08

$AP_VERF_ANU
Local Char CRIT(100), PCLE(GLONAVA)(1..16), CLE1(250), CLE2(250)
Local Integer I1, I2, NBCLE
If !clalev([F:ATZ0]) : Local File =APPLI+".ATABZON" [ATZ0] : Endif
If !clalev([F:ATI0]) : Local File =APPLI+".ATABIND" [ATI0] : Endif

For [ATZ0]CODTYP Where CODTYP="CFY"
 If filinfo(filpath("FIL",[F:ATZ0]CODFIC,"fde",APPLI),0)>0
  Raz CLE1, CLE2
  If clalev([F:ABC0])  : Close Local File [ABC0]                     : Endif
  If !clalev([F:ABC0]) : Local File =APPLI+"."+[F:ATZ0]CODFIC [ABC0] : Endif
  CRIT = [F:ATZ0]CODZONE+"='"+CODE+"'"
  Filter [ABC0] Where evalue(CRIT)
  Read [ABC0] First
  Filter [ABC0]
  If !fstat
   Filter [ATI0] Where CODFIC=[F:ATZ0]CODFIC and NUMLIG=1
   Read [ATI0]CODIND First
   Filter [ATI0]
   If !fstat
    CLE1  = [F:ATI0]DESCRIPT
    NBCLE = 0
    While CLE1<>""
     I1 = instr(1,CLE1,"+")
     I2 = instr(1,CLE1,"-")
     If I2
      If I1 : I1 = min(I1,I2) : Else : I1 = I2 : Endif
     Endif
     If I1
      CLE2 = left$(CLE1,I1-1)
      CLE1 = right$(CLE1,I1+1)
     Else
      CLE2 = CLE1
      CLE1 = ""
     Endif
     NBCLE += 1
     PCLE(NBCLE) = CLE2
    Wend
   Endif
   OKANU = 0
   GMESSAGE = mess(101,126,1)
   For I1=1 To NBCLE
    GMESSAGE -= num$(evalue("[F:ABC0]"+PCLE(I1)))
   Next
   GMESSAGE -= mess(198,133,1)-[F:ATZ0]CODFIC-"\"-mess(176,115,1)
   GERR = 1 : Break
   Return
  Endif
 Endif
Next
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran FGRP) 05/11/2008 10:40:37 (MABON)
######################################################################################
Subprog IB_NBLIG
  If nolign=1 Then
    GBOUT2=""
    GBOUT3=""
  Else
   # FQ61515 - MABON 12/01/10 - Le champ CPY a été renommé en CPYP
    If [M]CPYP(NOLIG(nolign-1))="" Then
      GBOUT2=""
    Else
      GBOUT3=""
    Endif
  Endif
End


######################################################################################
