#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion objet AWV
Raz GPILOBJ , GBIDC1 , GBIDC2 , GNBMASKOUV
GFLAG = ""
Call OBJET("AWV",GBIDC1,GBIDC2) From GOBJET
End

#----------------------------------------------------------#
$ACTION
Case ACTION
 When "AVANT_OUVRE" : Gosub AVANT_OUVRE
 When "OUVRE"       : Gosub OUVRE
 When "FILTRE"      : Gosub FILTRE
 When "LIENS0"      : Gosub LIENS0
 When "LIENS"       : Gosub LIENS
 When "LIENS2"      : Gosub LIENS2
 When "INICRE"      : Gosub INICRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "APRES_CHOI"  : Gosub APRES_CHOI
 When "SETBOUT"     : Gosub SETBOUT
 When "AFFMASK"     : Gosub AFFMASK
 When "DROIT"       : Gosub DROIT
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "GAUCHE"      : Gosub GAUCHE
Endcase
Return

#--------------------------#
$OUVRE_BOITE
Local Char BOXREG(10)
BOXREG = "GAU_CHE"+num$(find("AWR",OBJLIS(1..dim(OBJLIS)-1)))
Return

#--------------------------#
$DROIT
DROIT_MOD = 1
Read [AWR]AWR1 = [F:AWV_]REGLE;[F:AWV_]CPY
If fstat
 Read [AWR]AWR1 = [F:AWV_]REGLE;""
Endif
If !fstat & [F:AWR]ACS<>""
 Read [ACC]CODACC = GUSER;[F:AWR]ACS
 If fstat or [F:ACC]MODIF<>2
  DROIT_MOD = 0
 Endif
 If fstat or [F:ACC]CONSUL<>2
  GMESSAGE = mess(8,123,1) : # Accès impossible à cette fiche
  GERR = 1
  CLECUR = 0
 Endif
Endif
Gosub DEFAUT From =PROGOBJ
Return

#--------------------------#
$GAUCHE
Case currbox
 When BOXREG
  [F:AWV] = [F:AWR]
Endcase
Return

#--------------------------#
$AFFMASK
If TUNNEL
 Read [AWV]AWV0(1) = SAVCLE2
 If fstat
  Raz CLE1 , CLE2
  Effzo [M:AWV1]REGLE , CPY
 Else
  Read [AWV]AWV0(2) = SAVCLE2 ; SAVCLE1
  If fstat
   Read [AWV]AWV0(2) = SAVCLE2 ; ""
   If fstat
    Raz CLE1 , CLE2
    Effzo [M:AWV1]REGLE , CPY
   Endif
  Endif
 Endif
Endif
Return

#--------------------------#
$AVANT_OUVRE
Local Char    TYPFMT(20) , OPTFMT(20) , CHFMT(50) , NUMFMT(10)
Local Char    REGDEF(50)
Local Char    INTVAL(30) , AFFVAL(30)
Local Integer M , N , ER , DROIT_MOD
Local Char    TABLE(GLONATB) , ZONE(50)
If TUNNEL
 REGDEF = SAVCLE2
Else
 REGDEF = GFLAG
Endif
Return

#--------------------------#
$OUVRE
Return

#--------------------------#
$FILTRE
If dim(REGDEF)>0 & REGDEF<>""
 If FILTSUP<>""
  FILTSUP = "("+FILTSUP+")&"
 Endif
 If instr(1,REGDEF,"*") | instr(1,REGDEF,"?")
  FILTSUP += 'pat([F]REGLE,"'+REGDEF+'")=1'
 Else
  FILTSUP += 'REGLE = "'+REGDEF+'"'
 Endif
Endif
Return

#--------------------------#
$LIENS0
Read First
Read [AWR]AWR1 = [F]REGLE ; [F]CPY
If fstat
 Read [AWR]AWR1 = [F]REGLE ; ""
 If fstat
  For I=0 To dim([M]FMTCOL)-1
   [M]FMTCOL(I) = "-K:20X"
   [M]FMTLNK(I) = "-K:20X"
  Next I
  Return
 Endif
Endif
Gosub CHARGE_PAR
Gosub TITMASK From =WINPROG
Return

#--------------------------#
$LIENS
For I=0 To dim([F:AWV]VALREG)-1
 AFFVAL = [F:AWV]VALREG(I)
 Read [ATY]CODTYP = [M]TYPFLD(I)
 Call CHARGE(AFFVAL,[M]TYPFLD(I),[M]LIBFLD(I),[M]LNGFLD(I),INTVAL) From FMTVAR
 Assign "[M]INTVAL"+num$(I)+"("+num$(nolign-1)+")" With INTVAL
 Assign "[M]VAL"+num$(I)+"("+num$(nolign-1)+")" With AFFVAL
 Call LIEN(I)
Next I
For I=0 To dim([F:AWV]USER)-1
 Assign "[M]USR"+num$(I)+"("+num$(nolign-1)+")" With [F:AWV]USER(I)
Next I
For I=0 To [M]NBRUSR-1
 [M]AUSDEF(I) = [F:AWV]USRDEF(I)
Next I
[M]NBRAUS = [M]NBRUSR
Return

#--------------------------#
Subprog LIEN(COL)
Value Integer COL
Local Char VALEUR(30) , TEXTE(30) , CLE1(GLONID1)
If [M]FLNK(COL)="" : End : Endif
CLE1 = evalue("[M]VAL"+num$(COL)+"("+num$(nolign-1)+")")
If [M]TYPFLD(COL)="ADI"
 Local Integer CLE2
 If [M]LIBFLD(COL)<>0
  CLE2 = [M]LIBFLD(COL)
 Endif
Elsif [M]PARFLD(COL)<>""
 Case [M]SLNK(COL)
  When 1,2,3,4,5,6
   Local Integer CLE2
   CLE2 = val(evalue([M]PARFLD(COL)))
  When 8
   Local Date CLE2
   CLE2 = num$(evalue([M]PARFLD(COL)))
  When Default
   Local Char CLE2(GLONID2)
   CLE2 = num$(evalue([M]PARFLD(COL)))
 Endcase
Else
 Local Char CLE2(GLONID2)
 CLE2 = ""
Endif
Case COL
 When 0 : Default File [FF0_]
 When 1 : Default File [FF1_]
 When 2 : Default File [FF2_]
 When 3 : Default File [FF3_]
 When 4 : Default File [FF4_]
 When 5 : Default File [FF5_]
 When 6 : Default File [FF6_]
 When 7 : Default File [FF7_]
 When 8 : Default File [FF8_]
 When 9 : Default File [FF9_]
Endcase
If num$(CLE2)<>"" : Read [F] = CLE2 ; CLE1
Else              : Read [F] = CLE1
Endif
If !fstat & evalue("dim([F]"+[M]FLNK(COL)+")")>0
 VALEUR = num$(evalue("[F]"+[M]FLNK(COL)))
Endif
Case [M]DLNK(COL)
 When "ATX"
  Call TEXTE(val(VALEUR),[L]TEXTE) From OBJDIV
 When "AXX","AX1","AX2","AX3"
  If num$(CLE2)<>""
   Call LECTEXTRA([L]TEXTE,[M]TLNK(COL),[M]FLNK(COL),num$(CLE2),num$(CLE1)) From ATEXTRA
  Else
   Call LECTEXTRA([L]TEXTE,[M]TLNK(COL),[M]FLNK(COL),num$(CLE1),"") From ATEXTRA
  Endif
 When Default
  [L]TEXTE = VALEUR
Endcase
Assign "[M]LNK"+num$(COL)+"("+num$(nolign-1)+")" With [L]TEXTE
End

#--------------------------#
$LIENS2
Gosub CHANGE_COL
Call LECTEXTRA([M]INTIT,"AWRKREG","INTIT",[M]REGLE,[M]CPY) From ATEXTRA
If [M]INTIT=""
 Call LECTEXTRA([M]INTIT,"AWRKREG","INTIT",[M]REGLE,"") From ATEXTRA
Endif
Return

$CHARGE_PAR
For I=0 To dim([M]FMTCOL)-1
 If I<[F:AWR]NBRFLD & [F:AWR]OPEFLD(I)<>1
  [M]TYPFLD(I) = [F:AWR]TYPFLD(I)
  Read [ATY]CODTYP = [M]TYPFLD(I)
  If [F:ATY]TYPTYP=1
   [M]LNGFLD(I) = 20
  Elsif [F:ATY]LNGTYP<>0
   [M]LNGFLD(I) = [F:ATY]LNGTYP
  Else
   [M]LNGFLD(I) = [F:AWR]LNGFLD(I)
  Endif
  [M]LIBFLD(I) = [F:AWR]LIBFLD(I)
  [M]PARFLD(I) = [F:AWR]PARFLD(I)
  [M]DEFFLD(I) = [F:AWR]DEFFLD(I)
  [M]FMTCOL(I) = "K:20X"
  If [F:AWR]INTFLD(I)<>""
   ER = 0
   Onerrgo ERR
   [M]INTCOL(I) = evalue([F:AWR]INTFLD(I))
   Onerrgo
   If ER
    [M]INTCOL(I) = [F:AWR]INTFLD(I)
   Endif
  Else
   TABLE = ""
   ZONE = [F:AWR]EXPFLD(I)
   M = instr(1,ZONE,"[F:")
   If M
    M += 2
   Else
    M = instr(1,ZONE,"[")
   Endif
   N = instr(1,ZONE,"]")
   If M & N
    Read [ATB]ABRFIC = seg$(ZONE,M+1,N-1)
    If !fstat
     TABLE = [F:ATB]CODFIC
    Endif
    ZONE = right$(ZONE,N+1)
   Endif
   If TABLE=""
    TABLE = [F:AWR]TABFLD(I)
   Endif
   If TABLE<>""
    M = instr(1,ZONE,"(")
    If M
     ZONE = left$(ZONE,M-1)
    Endif
    Read [ATZ]CODZONE = TABLE;ZONE
    If !fstat
     Call TEXTE([F:ATZ]NOCOURT,[M]INTCOL(I)) From OBJDIV
    Endif
   Endif
  Endif
 Else
  [M]FMTCOL(I) = "-K:20X"
 Endif
Next I
Raz FLNK , TLNK , DLNK , SLNK
For I=0 To dim([M]FMTLNK)-1
 Case I
  When 0 : If clalev([F:FF0_])>0 : Close Local File [FF0_] : Endif
  When 1 : If clalev([F:FF1_])>0 : Close Local File [FF1_] : Endif
  When 2 : If clalev([F:FF2_])>0 : Close Local File [FF2_] : Endif
  When 3 : If clalev([F:FF3_])>0 : Close Local File [FF3_] : Endif
  When 4 : If clalev([F:FF4_])>0 : Close Local File [FF4_] : Endif
  When 5 : If clalev([F:FF5_])>0 : Close Local File [FF5_] : Endif
  When 6 : If clalev([F:FF6_])>0 : Close Local File [FF6_] : Endif
  When 7 : If clalev([F:FF7_])>0 : Close Local File [FF7_] : Endif
  When 8 : If clalev([F:FF8_])>0 : Close Local File [FF8_] : Endif
  When 8 : If clalev([F:FF9_])>0 : Close Local File [FF9_] : Endif
 Endcase
 If I>=[F:AWR]NBRFLD or [F:AWR]LNKFLD(I)<=1
  [M]FMTLNK(I) = "-K:20X"
 Else
  [M]FMTLNK(I) = "KP:30X"
  Read [ATY]CODTYP = [F:AWR]TYPFLD(I)
  If !fstat
   Read [AOB]ABREV=[F:ATY]OBJLIEN
   If !fstat
    Read [ATB]CODFIC=[F:AOB]NOMFIC
    If ! fstat
     Read [ATI]NUMLIG(1)=[F:AOB]NOMFIC
     M = instr(1,[F:ATI]DESCRIPT,"+")
     N = instr(1,[F:ATI]DESCRIPT,"-")
     If M & N
      M = min(M,N)
     Elsif N & !M
      M = N
     Endif
     If M
      Read [ATZ]CODZONE=[F:AOB]NOMFIC;left$([F:ATI]DESCRIPT,M-1)
      If !fstat
       Read [ATY]CODTYP = [F:ATZ]CODTYP
       If !fstat
        [M]SLNK(I) = [F:ATY]TYPTYP
       Endif
      Endif
     Endif
     [M]TLNK(I) = [F:AOB]NOMFIC
     Case I
      When 0 : Local File =[F:AOB]NOMFIC [FF0_]
      When 1 : Local File =[F:AOB]NOMFIC [FF1_]
      When 2 : Local File =[F:AOB]NOMFIC [FF2_]
      When 3 : Local File =[F:AOB]NOMFIC [FF3_]
      When 4 : Local File =[F:AOB]NOMFIC [FF4_]
      When 5 : Local File =[F:AOB]NOMFIC [FF5_]
      When 6 : Local File =[F:AOB]NOMFIC [FF6_]
      When 7 : Local File =[F:AOB]NOMFIC [FF7_]
      When 8 : Local File =[F:AOB]NOMFIC [FF8_]
      When 9 : Local File =[F:AOB]NOMFIC [FF9_]
     Endcase
     Case [F:AWR]LNKFLD(I)
      When 2 : [M]FLNK(I) = [F:ATB]INTIT
      When 3 : [M]FLNK(I) = [F:ATB]INTITC
     Endcase
     Read [ATZ]CODZONE=[F:AOB]NOMFIC;[M]FLNK(I)
     If !fstat
      [M]DLNK(I) = [F:ATZ]CODTYP
     Endif
    Endif
   Endif
  Endif
 Endif
Next I
[M]NBRUSR = [F:AWR]NBRUSR
Return

$ERR
ER = errn
Resume

$CHANGE_COL
For I=0 To dim([M]FMTUSR)-1
 If I<[M]NBRUSR
  [M]INTUSR(I) = mess(37,133,1)-num$(I+1) : # Utilisateur
  If dim([M]FLGFOR)>0 & [M]FLGFOR<>2
   [M]FMTUSR(I) = "K:"+num$(GLONAUS)+"B"
  Else
   [M]FMTUSR(I) = "KT:30X"
  Endif
 Else
  [M]FMTUSR(I) = "-K:30X"
 Endif
Next I
For I=0 To dim([M]FMTCOL)-1
 Case I
  When 0 : Chgfmt VAL0 With [M]FMTCOL(I) : Chgfmt LNK0 With [M]FMTLNK(I)
  When 1 : Chgfmt VAL1 With [M]FMTCOL(I) : Chgfmt LNK1 With [M]FMTLNK(I)
  When 2 : Chgfmt VAL2 With [M]FMTCOL(I) : Chgfmt LNK2 With [M]FMTLNK(I)
  When 3 : Chgfmt VAL3 With [M]FMTCOL(I) : Chgfmt LNK3 With [M]FMTLNK(I)
  When 4 : Chgfmt VAL4 With [M]FMTCOL(I) : Chgfmt LNK4 With [M]FMTLNK(I)
  When 5 : Chgfmt VAL5 With [M]FMTCOL(I) : Chgfmt LNK5 With [M]FMTLNK(I)
  When 6 : Chgfmt VAL6 With [M]FMTCOL(I) : Chgfmt LNK6 With [M]FMTLNK(I)
  When 7 : Chgfmt VAL7 With [M]FMTCOL(I) : Chgfmt LNK7 With [M]FMTLNK(I)
  When 8 : Chgfmt VAL8 With [M]FMTCOL(I) : Chgfmt LNK8 With [M]FMTLNK(I)
  When 9 : Chgfmt VAL9 With [M]FMTCOL(I) : Chgfmt LNK9 With [M]FMTLNK(I)
 Endcase
Next I
Chgfmt AUSDEF With [M]FMTUSR
For I=0 To dim([M]FMTUSR)-1
 Case I
  When 0 : Chgfmt USR0 With [M]FMTUSR(I)
  When 1 : Chgfmt USR1 With [M]FMTUSR(I)
  When 2 : Chgfmt USR2 With [M]FMTUSR(I)
  When 3 : Chgfmt USR3 With [M]FMTUSR(I)
  When 4 : Chgfmt USR4 With [M]FMTUSR(I)
  When 5 : Chgfmt USR5 With [M]FMTUSR(I)
  When 6 : Chgfmt USR6 With [M]FMTUSR(I)
  When 7 : Chgfmt USR7 With [M]FMTUSR(I)
  When 8 : Chgfmt USR8 With [M]FMTUSR(I)
  When 9 : Chgfmt USR9 With [M]FMTUSR(I)
 Endcase
Next I
Affzo
Return

#--------------------------#
$INICRE
For I=0 To dim([F:AWV]VALREG)-1
 [F:AWV]VALREG(I) = evalue("[M]INTVAL"+num$(I)+"("+num$(nolign-1)+")")
Next I
For I=0 To dim([F:AWV]USER)-1
 [F:AWV]USER(I) = evalue("[M]USR"+num$(I)+"("+num$(nolign-1)+")")
Next I
For I=0 To dim([F:AWV]USRDEF)-1
 [F:AWV]USRDEF(I) = [M]AUSDEF(I)
Next I
Return

#--------------------------#
$SETBOUT
Local Integer DROIT
If CLECUR & SUPPR & instr(1,STDBOUT,"S")
 CHAINE += "A" : # Pour rajouter le bouton Supprimer
Endif
If !DROIT_MOD
 Call VIREBOUT(CHAINE,"M") From GOBJET
Endif
Return

#--------------------------#
$APRES_MODIF
Case zoncou
 When "REGLE"
  Read [AWR]AWR1(1) = zc
  If fstat
   GMESSAGE = mess(104,75,1) : # Règle inexistante
   OK = 0 : Return
  Endif
  Read [AWR]AWR1 = zc ; [M]CPY
  If fstat
   Read [AWR]AWR1 = zc ; ""
   If !fstat
    [M]CPY = ""
    Affzo CPY
   Else
    Read [AWR]AWR1(1) = zc
    [M]CPY = [F:AWR]CPY
    Affzo CPY
   Endif
  Endif
  [M]REGLE = zc
  Effzo [M]15-20
  Gosub CHARGE_PAR
  Gosub CHANGE_COL
  Affzo
 When "CPY"
  Read [AWR]AWR1 = [M]REGLE ; zc
  If fstat
   Read [AWR]AWR1 = [M]REGLE ; ""
   If fstat : Return : Endif
  Endif
  Effzo [M]15-20
  Gosub CHARGE_PAR
  Gosub CHANGE_COL
  Affzo
 When "VAL0","VAL1","VAL2","VAL3","VAL4","VAL5","VAL6","VAL7","VAL8","VAL9"
  Assign "[M]"+zoncou+"("+num$(nolign-1)+")" With zc
  Call LIEN(val(right$(zoncou,4)))
 When "FLGFOR"
  [M]FLGFOR = zc
  Gosub CHANGE_COL
  Affzo
Endcase
Return

#--------------------------#
$APRES_CHOI
If REPONSE<>GSTAANU : Return : Endif
REPONSE = 0
If GCONF(1)=2
 Call AVERTIR(mess(28,100,1)-[M]REGLE-[M]CPY,OK) From GESECRAN : # Confirmation d'annulation
 If OK<>2 : Return : Endif
Endif
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1
 Gosub DEVERROU From GOBJET
 Gosub RELIT From GOBJSUB
Endif
Return

$TR1
Delete [AWV] Where REGLE=[M]REGLE & CPY=[M]CPY
If fstat=1
 GOK=-1 : GLOCK = "$AWRKREGVAL" : Goto ROLL_TR1
Elsif fstat>5
 GOK = 0 : Call FSTA("AWV") From GLOCK : Goto AB_TR1
Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#--------------------------------------------------------------------#
Subprog C_CPY(VALEUR)
Variable Char VALEUR
Local Integer OK
OK = 1
Read [AWR]AWR1 = [M]REGLE ; VALEUR
If fstat
 OK = 0
Else
 Read [AWM]AWM0 = [F:AWR]MODELE
 If !fstat & VALEUR<>"" & [F:AWM]FLDCPY="" & [F:AWM]FLDFCY=""
  OK = 0
 Endif
Endif
If !OK
 If VALEUR<>""
  Read [AWR]AWR1 = [M]REGLE ; ""
  If fstat
   GMESSAGE = [M]REGLE-":"-mess(178,75,1) : # Règle inexistante
   mkstat = 1 : End
  Else
   Read [AWM]AWM0 = [F:AWR]MODELE
   If ([F:AWM]FLDCPY="" & [F:AWM]FLDFCY="")
    GMESSAGE = [M]REGLE-mess(179,75,1) : # Il n'est pas possible de saisir une société avec cette règle
    mkstat = 1 : End
   Endif
  Endif
 Else
  GMESSAGE = [M]REGLE-VALEUR-":"-mess(178,75,1) : # Règle inexistante
  mkstat = 1 : End
 Endif
Endif
End

Subprog D_VAL0(VALEUR)
Variable Char    VALEU
If [M]DEFFLD(0)<>""
 Onerrgo RIEN
 VALEUR = evalue(DEFFLD(0))
 Onerrgo
Endif
End

$RIEN
Resume

