Subprog C_USR0(VALEUR)
Variable Char    VALEUR()
Gosub CTLAUS
End

Subprog C_USR1(VALEUR)
Variable Char    VALEUR()
Gosub CTLAUS
End

Subprog C_USR2(VALEUR)
Variable Char    VALEUR()
Gosub CTLAUS
End

Subprog C_USR3(VALEUR)
Variable Char    VALEUR()
Gosub CTLAUS
End

