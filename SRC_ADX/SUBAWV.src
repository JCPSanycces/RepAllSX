Variable Char    VALEUR()
Gosub CTLAUS
End

Subprog C_AUSDEF(VALEUR)
Variable Char    VALEUR()
Gosub CTLAUS
End

$CTLAUS
If VALEUR<>""
 If !func FORAUS(VALEUR,[M]FLGFOR)
  Call CONTSEL("AUS","",VALEUR,"",mkstat) From CONTOBJ
 Else
  VALEUR = format$("KTv2:255X",VALEUR)
  Local Integer E
  E = parse(VALEUR)
  If E
   GMESSAGE = mess(37,124,1)+"\"+errmes$(E) : # Expression incorrecte
   mkstat = 2 : End
  Endif
 Endif
Endif
Return

Funprog FORAUS(COD,FLG)
Value Char COD
Value Integer FLG
Local Integer OKFOR , ER , I
OKFOR = 0
If COD<>""
 If FLG=2
  If len(COD)>GLONAUS
   OKFOR = 1
  Elsif find(left$(COD,1),"'",'"')
   OKFOR = 1
  Else
   Onerrgo ERR
   I = evalue("dim("+COD+")")
   Onerrgo
   If !ER and I>0
    OKFOR = 1
   Endif
  Endif
 Endif
Endif
End OKFOR

Subprog AP_AUSDEF(VALEUR)
Variable Char    VALEUR()
# Bug 83998
Call LECTEXTRA([M]AUSNAM(nolign-1),"AUTILIS","INTUSR",VALEUR,"") From ATEXTRA
End

Subprog AM_FLGFOR(VALEUR)
Variable Integer VALEUR
Local Integer I , J , OK
If VALEUR<>1 : End : Endif
OK = 1
For I=1 To [M]NBRUSR
 If func FORAUS([M]AUSDEF(I-1),2)
  OK = 0 : Break
 Endif
Next I
For I=1 To [M]NBRLIG
 For J=1 To [M]NBRUSR
  CHAINE = evalue("[M]USR"+num$(J-1)+"("+num$(I-1)+")")
  If func FORAUS(CHAINE,2)
   OK = 0 : Break
  Endif
 Next J
Next I
If !OK
 GMESSAGE = mess(185,75,1) : # Il existe encore au moins une formule sur un champ utilisateur
 mkstat = 1 : End
Endif
End

Subprog C_NBRAUS
If nolign>[M]NBRUSR & !adxgtb
 mkstat = 1
Endif
End
