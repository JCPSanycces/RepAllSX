#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "OUVRE"   : Gosub OUVRE
 When "INIPAR"  : Gosub INIPAR
 When "INIPAR2" : Gosub INIPAR2
Endcase
Return

$OUVRE
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED       [LED] : Endif
If clalev([F:COA])=0 : Local File GCOA       [COA] : Endif
Return

$INIPAR
Local Char    SOCIETE(GLONCPY),SITE(GLONFCY)
Local Integer K, L
Local Libelle TYPLEDGEN, TYPLEDANA
Case [M]PARCOD(nolign-1)
 When "compte"
  Gosub SETSOC
  If SOCIETE<>""
   Call SETMAINREF(SOCIETE,TYPLEDGEN,TYPLEDANA) From CPTDIV
    Read [GCM]GCM0 = [F:CPY]ACM
    Read [LED]LED0 = [F:GCM]LED(TYPLEDANA-1)
    Read [COA]COA0 = [F:LED]COA
  Endif
Endcase
Return

$SETSOC
SOCIETE = ""
K = find("societe",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
L = find("site",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
If K
 SOCIETE = [M:RPT]VALINT1(K-1)
 Read [CPY]CPY0 = SOCIETE
 If [F:CPY]CPYLEGFLG<>2
  Read [FGR]FGR0(1) = SOCIETE
  Read [FCY]FCY0 = [F:FGR]FCY
  SOCIETE = [F:FCY]LEGCPY
  Read [CPY]CPY0 = SOCIETE
 Endif
Elsif L
 SITE = [M:RPT]VALINT1(L-1)
 Read [FCY]FCY0 = SITE
 SOCIETE = [F:FCY]LEGCPY
 Read [CPY]CPY0 = SOCIETE
Endif
Return

$INIPAR2
Case [M]PARCOD(nolign-1)
 When "compte" : Gosub INIPAR
Endcase
Return

###################################
#     Trt de l'état BUDREV        #
###################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)


If clalev([CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([FCY])=0 : Local File FACILITY [FCY] : Endif


####################################################
## Récup paramètres
####################################################
Local Integer TYPETAT
Local Char    PARAM(30) , ETAT(GLONARP), NOM_ETAT(GLONARP)
Local Integer NUMREQ , LIGNE
Local Integer K,I,J

Local Char    SOCIETE(GLONCPY) , SITE(GLONFCY)

Call GETPARAM("societe",NBPAR,PARAMETRE,[L]SOCIETE) From ETAT
Call GETPARAM("site",NBPAR,PARAMETRE,[L]SITE) From ETAT

If SOCIETE<>"" & SITE=""
 Local Integer SOC,J
 Local Char LISTFCY(GLONFCY)(1..200)
 Local Char LISTESITE(255)
 SOC=find(SOCIETE,GSOC(1..GNBSOC))
 If SOC
  J=1
  For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
   LISTFCY(J)=[F:FCY]FCY
   If LISTESITE<>"" : LISTESITE += "," : Endif
   LISTESITE += [F:FCY]FCY
   J+=1
  Next
  Call SETPARAM("liste_site",NBPAR,PARAMETRE,LISTESITE) From ETAT
 Endif
Endif
End

