Return


$LOADSMP

If !clalev([F:SMPLVE]) : Local File UKSMPLVE [SMPLVE] : Endif

#JOJAC - START
#Filter [SMPLVE] Where REFNUM = [M:DCG1]REFNUM and CTRNUM = [M:DCG1]CTRNUM and LIGNUM = DCGUKINBLIG+1
#Read [SMPLVE]First
Read [SMPLVE]SMPLVE1 = [M:DCG1]UID(nolign-1)
If !fstat
  [M:DCG1]SMPEVIREC = [SMPLVE]SMPEVIREC : Affzo [M:DCG1]SMPEVIREC
  [M:DCG1]SMPEXC    = [SMPLVE]SMPEXC    : Affzo [M:DCG1]SMPEXC
  [M:DCG1]SMPEXPDOB = [SMPLVE]SMPEXPDOB : Affzo [M:DCG1]SMPEXPDOB
  [M:DCG1]SMPLEADAT = [SMPLVE]SMPLEADAT : Affzo [M:DCG1]SMPLEADAT
  [M:DCG1]SMPACTDOB = [SMPLVE]SMPACTDOB : Affzo [M:DCG1]SMPACTDOB
  [M:DCG1]SMPEARDAT = [SMPLVE]SMPEARDAT : Affzo [M:DCG1]SMPEARDAT
  [M:DCG1]SMPRETDAT = [SMPLVE]SMPRETDAT : Affzo [M:DCG1]SMPRETDAT
  [M:DCG1]SMPQUADAT = [SMPLVE]SMPQUADAT : Affzo [M:DCG1]SMPQUADAT
  [M:DCG1]SMPEMPDAT = [SMPLVE]SMPEMPDAT : Affzo [M:DCG1]SMPEMPDAT
  [M:DCG1]SMPPRPSTR = [SMPLVE]SMPPRPSTR : Affzo [M:DCG1]SMPPRPSTR
  [M:DCG1]SMPPRPEND = [SMPLVE]SMPPRPEND : Affzo [M:DCG1]SMPPRPEND
  [M:DCG1]SMPEXPCON = [SMPLVE]SMPEXPCON : Affzo [M:DCG1]SMPEXPCON
  [M:DCG1]SMPWEEPER = [SMPLVE]SMPWEEPER : Affzo [M:DCG1]SMPWEEPER
  [M:DCG1]SMPEARLEA = [SMPLVE]SMPEARLEA : Affzo [M:DCG1]SMPEARLEA
  [M:DCG1]SMPLATRET = [SMPLVE]SMPLATRET : Affzo [M:DCG1]SMPLATRET
  [M:DCG1]SMPELI    = [SMPLVE]SMPELI    : Affzo [M:DCG1]SMPELI
  #[M:DCG1]SMPREA    = [SMPLVE]SMPREA    : Affzo [M:DCG1]SMPREA
  [M:DCG1]SMPPRO    = [SMPLVE]SMPPRO    : Affzo [M:DCG1]SMPPRO
  [M:DCG1]SMPQUADAT = [SMPLVE]SMPQUADAT : Affzo [M:DCG1]SMPQUADAT
Endif
#JOJAC - END

  #Affzo [M:DCG1]NBKIT
  #Affzo [M:DCG1]KITDAT

#If GUSER = 'JOJAC'
  Effzo [M:DCG1]NBKIT
  If !clalev([F:KIT]) : Local File SMPKIT [KIT] : Endif
  Raz [M:DCG1]NBKIT
  Local Integer LIGNUM : LIGNUM = 0
  For [KIT] Where REFNUM = [M:DCG1]REFNUM and CTRNUM = [M:DCG1]CTRNUM(nolign-1)
    [M:DCG1]KITDAT(LIGNUM) = [KIT]KITDAT
    LIGNUM +=1
  Next
  [M:DCG1]NBKIT = LIGNUM
  Affzo [M:DCG1]75
#Endif




###If !fstat
###  Filter [SMPLVE]
###  [M:DCG1]SMPEVIREC = [SMPLVE]SMPEVIREC : Affzo [M:DCG1]SMPEVIREC
