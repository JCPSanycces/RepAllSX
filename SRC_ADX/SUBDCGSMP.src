$LOADKIT
#TODO - LOADKIT
#Effzo [M:DCG1]NBKIT
#If !clalev([F:KIT]) : Local File SMPKIT [KIT] : Endif
#Raz [M:DCG1]NBKIT
#Local Integer LIGNUM : LIGNUM = 0
#For [KIT] Where REFNUM = [M:DCG1]REFNUM and CTRNUM = [M:DCG1]CTRNUM and LIGNUM = DCGUKINBLIG+1
#  [M:DCG1]KITDAT(LIGNUM) = [KIT]KITDAT
#  LIGNUM +=1
#Next
#Assign "[M:DCG1]NBKIT" With LIGNUM
