###  [M:DCG1]SMPREA    = [SMPLVE]SMPREA    : Affzo [M:DCG1]SMPREA
###  [M:DCG1]SMPPRO    = [SMPLVE]SMPPRO    : Affzo [M:DCG1]SMPPRO
###  [M:DCG1]SMPQUADAT = [SMPLVE]SMPQUADAT    : Affzo [M:DCG1]SMPQUADAT
####MASHI - 2017-09-08 X3-54387 START
###  [M:DCG1]SMPAWE    = [SMPLVE]SMPAWE    : Affzo [M:DCG1]SMPAWE
####MASHI - 2017-09-08 X3-54387 END
###Else
###  Effzo [M:DCG1]SMPEVIREC
###  Effzo [M:DCG1]SMPEXC
###  Effzo [M:DCG1]SMPEXPDOB
###  Effzo [M:DCG1]SMPLEADAT
###  Effzo [M:DCG1]SMPACTDOB
###  Effzo [M:DCG1]SMPEARDAT
###  Effzo [M:DCG1]SMPRETDAT
###  Effzo [M:DCG1]SMPQUADAT
###  Effzo [M:DCG1]SMPEMPDAT
###  Effzo [M:DCG1]SMPPRPSTR
###  Effzo [M:DCG1]SMPPRPEND
###  Effzo [M:DCG1]SMPEXPCON
###  Effzo [M:DCG1]SMPWEEPER
###  Effzo [M:DCG1]SMPEARLEA
###  Effzo [M:DCG1]SMPLATRET
###  Effzo [M:DCG1]SMPELI
###  Effzo [M:DCG1]SMPREA
###  Effzo [M:DCG1]SMPPRO
###  Effzo [M:DCG1]SMPQUADAT
####MASHI - 2017-09-08 X3-54387 START
###  Effzo [M:DCG1]SMPAWE
####MASHI - 2017-09-08 X3-54387 END
###
###Endif


[M:DCG1]SMPPRPDIS = num$([M:DCG1]SMPPRPSTR)+" - "+num$([M:DCG1]SMPPRPEND) : Affzo [M:DCG1]SMPPRPDIS

Return

Subprog C_SMPEXPDOB(VALEUR)
Variable Date    VALEUR
Local Integer SMP_MAWE

   SMP_MAWE   = func SUBDCGUKI.SETVARIABLE("SMP_MAWE",[M:DCG1]STRDAT(nolign-1))

  #If [M:DCG1]SMPEXPDOB <> VALEUR
    If VALEUR <> [0/0/0] and DCGUKINBLIG > -1
      Gosub FOUR_WEEK_BEFORE_EXPECTED
      Gosub EARLIEST_LEAVE_DATE
      Gosub QUALIFYING_WEEK_START

      Gosub SMP_RELEVANT_PERIOD
      Gosub LAST_EMPLOYMENT_START_DATE
      Gosub EXPECTED_WEEK

      SUBEAR = func SUBDCGUKI.AVERAGE_EARNING([M:DCG1]REFNUM,[M:DCG1]SMPPRPSTR,[M:DCG1]SMPPRPEND)
      If [M:DCG1]SMPAWE = 0
        [M:DCG1]SMPAWE = SUBEAR : Affzo [M:DCG1]SMPAWE
      Endif

      If [M:DCG1]SMPEMPDAT <> [0/0/0] and [M:DCG1]SMPAWE > [L]SMP_MAWE
        Call SMP_ELIGIBILITY([M:DCG1]SMPAWE,[M:DCG1]SMPEMPDAT,VALEUR,[M:DCG1]SMPEVIREC)
      Endif

    Endif
  #Endif


  If [M:DCG1]SMPLEADAT <> [0/0/0] and [M:DCG1]SMPAWE <> 0.00 and [M:DCG1]SMPAWE > [L]SMP_MAWE
    Call SMPCAL([M:DCG1]SMPLEADAT,[M:DCG1]SMPAWE)
  Endif

End

Subprog C_SMPLEADAT(VALEUR)
Variable Date    VALEUR

  #SMP Latest return date
  If VALEUR <> [0/0/0] and DCGUKINBLIG > -1
    Gosub SMP_LATEST_RETURN_DATE

    If VALEUR = [0/0/0]
      GERR = 1 :  GMESSAGE = mess(7,11828,1) : mkstat = 2 : End
    Endif

    If VALEUR < [M:DCG1]SMPEARLEA
      #MASHI - 2017-09-08 X3-47517 START
      If [M:DCG1]SMPACTDOB = [0/0/0] or [M:DCG1]SMPACTDOB >= [M:DCG1]SMPEARLEA
        GERR = 1 :  GMESSAGE = mess(2,11828,1) : mkstat = 2   : End
      Endif
      #MASHI - 2017-09-08 X3-47517 END
    Else
      If [M:DCG1]SMPACTDOB <> [0/0/0]
        If VALEUR > [M:DCG1]SMPACTDOB
          GERR = 1 : GMESSAGE = mess(3,11828,1) : mkstat = 2 : End
        Endif
      Endif
    Endif
  Endif

  #JOJAC - 2017-11-15 - X3-6780 - START
  SMP_MAWE   = func SUBDCGUKI.SETVARIABLE("SMP_MAWE",[M:DCG1]STRDAT(nolign-1))
  If VALEUR <> [0/0/0] #and [M:DCG1]SMPAWE <> 0.00 and [M:DCG1]SMPAWE > [L]SMP_MAWE
    Call SMPCAL(VALEUR,[M:DCG1]SMPAWE)
  Endif
  #JOJAC - 2017-11-15 - X3-6780 - END

   If [M:DCG1]SMPEMPDAT <> [0/0/0]# and [M:DCG1]SMPAWE > [L]SMP_MAWE
     Call SMP_ELIGIBILITY([M:DCG1]SMPAWE,[M:DCG1]SMPEMPDAT,VALEUR,[M:DCG1]SMPEVIREC)
   Endif

End

