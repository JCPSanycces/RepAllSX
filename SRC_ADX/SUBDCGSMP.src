Subprog C_SMPRETDAT(VALEUR)
Variable Date    VALEUR

  If VALEUR <> [0/0/0]
    If [M:DCG1]SMPEARDAT <> [0/0/0]
      If VALEUR < [M:DCG1]SMPEARDAT
        GERR = 1 :  GMESSAGE = mess(5,11828,1)  : mkstat = 2 : End  #: Affzo [M:DCG1]SMPEARDAT
      Endif
    Endif
    If VALEUR > [M:DCG1]SMPLATRET
      GERR = 1 :  GMESSAGE = mess(6,11828,1) : mkstat = 2 : End #: Affzo [M:DCG1]SMPEARDAT
    Endif

    #JOJAC - 2017-11-15 - X3-64100 - START
    SMP_MAWE   = func SUBDCGUKI.SETVARIABLE("SMP_MAWE",[M:DCG1]STRDAT(nolign-1))
    If [M:DCG1]SMPLEADAT <> [0/0/0] and [M:DCG1]SMPAWE <> 0.00 and [M:DCG1]SMPAWE > [L]SMP_MAWE
      Call SMPCAL([M:DCG1]SMPLEADAT,[M:DCG1]SMPAWE)
    Endif
    #JOJAC - 2017-11-15 - X3-64100 - END
  Endif

End

Subprog C_SMPAWE(VALEUR)
Variable Decimal VALEUR
Local Decimal SMP_MAWE

#  [L]SMP_MAWE   = func SUBDCGUKI.SETVARIABLE("SMP_MAWE",[M:DCG1]STRDAT(DCGUKINBLIG))
#  #If [M:DCG1]SMPAWE <> VALEUR
#    If VALEUR < [L]SMP_MAWE
#      [M:DCG1]SMPELI = 1 : Affzo [M:DCG1]SMPELI
#      #ANCOA 07/11/2017 - X3-60674 - START
#      [M:DCG1]SMPREA = "E" : Affzo [M:DCG1]SMPREA, ZSMPREA
#      #ANCOA 07/11/2017 - X3-60674 - END
#    Else
#      [M:DCG1]SMPELI = 2 : Affzo [M:DCG1]SMPELI
#      #ANCOA 07/11/2017 - X3-60674 - START
#      Raz [M:DCG1]SMPREA : Affzo [M:DCG1]SMPREA, ZSMPREA
#      #ANCOA 07/11/2017 - X3-60674 - END
#    Endif
#  #Endif
#  Affzo [M:DCG1]60 #Affzo description ADI set as long

  [M:DCG1]SMPAWE = VALEUR
  SMP_MAWE   = func SUBDCGUKI.SETVARIABLE("SMP_MAWE",[M:DCG1]STRDAT(nolign-1))
   If [M:DCG1]SMPEMPDAT <> [0/0/0]# and [M:DCG1]SMPAWE > [L]SMP_MAWE
     Call SMP_ELIGIBILITY([M:DCG1]SMPAWE,[M:DCG1]SMPEMPDAT,[M:DCG1]SMPQUADAT,[M:DCG1]SMPEVIREC)
   Endif

  SMP_MAWE   = func SUBDCGUKI.SETVARIABLE("SMP_MAWE",[M:DCG1]STRDAT(nolign-1))
  If [M:DCG1]SMPLEADAT <> [0/0/0]# and VALEUR <> 0.00 and VALEUR > [L]SMP_MAWE
    Call SMPCAL([M:DCG1]SMPLEADAT,VALEUR)
  Endif

  Affzo [M:DCG1]60

End


Subprog C_SMPEVIREC(VALEUR)
Variable Integer VALEUR

#  If VALEUR < 2
#    #Infbox mess(13,11828,1)
#    #[M:DCG1]SMPELI = 1  : Affzo [M:DCG1]SMPELI
#    #ANCOA 07/11/2017 - X3-60674 - START
#    [M:DCG1]SMPREA = "N" : Affzo [M:DCG1]SMPREA, ZSMPREA
#    #ANCOA 07/11/2017 - X3-60674 - END
#    #ANCOA 07/11/2017 - X3-62591 - START
#    [M:DCG1]SMPELI = 1  : Affzo [M:DCG1]SMPELI
#    #ANCOA 07/11/2017 - X3-62591 - END
#  Else
#    [M:DCG1]SMPELI = 2  : Affzo [M:DCG1]SMPELI
#    #ANCOA 07/11/2017 - X3-60674 - START
#    Raz [M:DCG1]SMPREA  : Affzo [M:DCG1]SMPREA, ZSMPREA
#    #ANCOA 07/11/2017 - X3-60674 - END
#  Endif


   #JOJAC - 2017-11-5 - X3-63824 - START
   SMP_MAWE   = func SUBDCGUKI.SETVARIABLE("SMP_MAWE",[M:DCG1]STRDAT(nolign-1))
   If [M:DCG1]SMPEMPDAT <> [0/0/0] and [M:DCG1]SMPAWE > [L]SMP_MAWE
     Call SMP_ELIGIBILITY([M:DCG1]SMPAWE,[M:DCG1]SMPEMPDAT,[M:DCG1]SMPEXPDOB,VALEUR)
   Endif
   #JOJAC - 2017-11-5 - X3-63824 - END

  #ANCOA - 14/11/2017 - X3-62580 - Start
   #Call SMPCAL([M:DCG1]SMPLEADAT,[M:DCG1]SMPAWE)
  #ANCOA - 14/11/2017 - X3-62580 - End
  #SMP_MAWE   = func SUBDCGUKI.SETVARIABLE("SMP_MAWE",[M:DCG1]STRDAT(nolign-1))
  If [M:DCG1]SMPLEADAT <> [0/0/0] and [M:DCG1]SMPAWE <> 0.00 and [M:DCG1]SMPAWE > [L]SMP_MAWE
    Call SMPCAL([M:DCG1]SMPLEADAT,[M:DCG1]SMPAWE)
  Endif
End


Subprog SHOWHIDESMP(ALT)
Value Char ALT

  If dim([M:DCG1]SXPCAT)    > 0 : Chgfmt [M:DCG1]SXPCAT          With ALT+"K:4X"        : Endif
  If dim([M:DCG1]SMPEVIREC) > 0 : Chgfmt [M:DCG1]SMPEVIREC       With ALT+"LA:1"        : Endif
  If dim([M:DCG1]SMPCAL)    > 0 : Chgfmt [M:DCG1]SMPCAL          With ALT+"LA:1"        : Endif
  If dim([M:DCG1]SMPLEADAT) > 0 : Chgfmt [M:DCG1]SMPLEADAT       With ALT+"D:"+GFMDAT4  : Endif
  If dim([M:DCG1]SMPEXC)    > 0 : Chgfmt [M:DCG1]SMPEXC          With ALT+"K:1X"        : Endif
  If dim([M:DCG1]SMPACTDOB) > 0 : Chgfmt [M:DCG1]SMPACTDOB       With ALT+"D:"+GFMDAT4  : Endif
  If dim([M:DCG1]SMPEXPDOB) > 0 : Chgfmt [M:DCG1]SMPEXPDOB       With ALT+"D:"+GFMDAT4  : Endif
  If dim([M:DCG1]SMPEARDAT) > 0 : Chgfmt [M:DCG1]SMPEARDAT       With "-D:"+GFMDAT4     : Endif
  If dim([M:DCG1]DISEARDAT) > 0 : Chgfmt [M:DCG1]DISEARDAT       With ALT+"D:"+GFMDAT4  : Endif
  If dim([M:DCG1]SMPRETDAT) > 0 : Chgfmt [M:DCG1]SMPRETDAT       With ALT+"D:"+GFMDAT4  : Endif
  If dim([M:DCG1]SMPQUADAT) > 0 : Chgfmt [M:DCG1]SMPQUADAT       With ALT+"D:"+GFMDAT4  : Endif
  If dim([M:DCG1]SMPEMPDAT) > 0 : Chgfmt [M:DCG1]SMPEMPDAT       With ALT+"D:"+GFMDAT4  : Endif
  If dim([M:DCG1]SMPEMPDAT) > 0 : Chgfmt [M:DCG1]SMPEMPDAT       With ALT+"D:"+GFMDAT4  : Endif
  If dim([M:DCG1]SMPPRPSTR) > 0 : Chgfmt [M:DCG1]SMPPRPSTR       With "-D:"+GFMDAT4     : Endif
  If dim([M:DCG1]SMPPRPEND) > 0 : Chgfmt [M:DCG1]SMPPRPEND       With "-D:"+GFMDAT4     : Endif
  If dim([M:DCG1]SMPWEEPER) > 0 : Chgfmt [M:DCG1]SMPWEEPER       With ALT+"D:"+GFMDAT4  : Endif
  If dim([M:DCG1]SMPEARLEA) > 0 : Chgfmt [M:DCG1]SMPEARLEA       With ALT+"D:"+GFMDAT4  : Endif
  If dim([M:DCG1]SMPLATRET) > 0 : Chgfmt [M:DCG1]SMPLATRET       With ALT+"D:"+GFMDAT4  : Endif
  If dim([M:DCG1]SMPELI)    > 0 : Chgfmt [M:DCG1]SMPELI          With ALT+"LA:1"        : Endif
  If dim([M:DCG1]SMPREA)    > 0 : Chgfmt [M:DCG1]SMPREA          With ALT+"K:30X"       : Endif
  If dim([M:DCG1]SMPPRO)    > 0 : Chgfmt [M:DCG1]SMPPRO          With ALT+"LA:1"        : Endif
  If dim([M:DCG1]SMPEXPCON) > 0 : Chgfmt [M:DCG1]SMPEXPCON       With "-D:"+GFMDAT4     : Endif
  If dim([M:DCG1]SMPPRPDIS) > 0 : Chgfmt [M:DCG1]SMPPRPDIS       With ALT+"K:30X"       : Endif
  If dim([M:DCG1]KITDAT)    > 0 : Chgfmt [M:DCG1]KITDAT          With ALT+"D:"+GFMDAT4  : Endif
  If dim([M:DCG1]NBKIT)     > 0 : Chgfmt [M:DCG1]NBKIT           With ALT+"K:20X"       : Endif
  If dim([M:DCG1]NBPAY)     > 0 : Chgfmt [M:DCG1]NBPAY           With ALT+"K:20X"       : Endif
#MASHI - 2017-09-08 X3-54387 START
#  Chgfmt [M:DCG1]SMPAWE          With ALT+"Nz:11.2"
  If dim([M:DCG1]SMPAWE) > 0    : Chgfmt [M:DCG1]SMPAWE          With ALT+"Nz:9.5"      : Endif
#MASHI - 2017-09-08 X3-54387 END

  If dim([M:DCG1]SMPWEKSTR)>0   : Chgfmt [M:DCG1]SMPWEKSTR With 'D:MM[/]DD[/]YYYY'      : Endif
  If dim([M:DCG1]SMPTAXYEA)>0   : Chgfmt [M:DCG1]SMPTAXYEA With 'Nz:4'                  : Endif
  If dim([M:DCG1]SMPTAXPER)>0   : Chgfmt [M:DCG1]SMPTAXPER With 'Nz:4'                  : Endif
  If dim([M:DCG1]SMPFREQUE)>0   : Chgfmt [M:DCG1]SMPFREQUE With 'K:1'                   : Endif
  If dim([M:DCG1]SMPRAT)>0      : Chgfmt [M:DCG1]SMPRAT    With 'K:9'                   : Endif
  If dim([M:DCG1]SMPAMT)>0      : Chgfmt [M:DCG1]SMPAMT    With 'Nz:11.2'               : Endif
#ALHAR - 2018-03-03 X3-77637 START
#  If dim([M:DCG1]SMPPAI)>0      : Chgfmt [M:DCG1]SMPPAI    With 'K:3'                   : Endif
  If dim([M:DCG1]SMPPAI)>0      : Chgfmt [M:DCG1]SMPPAI    With '-K:3'                   : Endif
#ALHAR - 2018-03-03 X3-77637 END

  If ALT = ""
    [M:DCG1]SMPELI = 2
    [M:DCG1]SMPPRO = 2
    Affzo [M:DCG1]SMPELI
    Affzo [M:DCG1]SMPPRO

  Endif
End

Funprog GETAWE(REFNUM,SMPPRPSTR,SMPPRPEND)
Value Char REFNUM
Value Date SMPPRPSTR,SMPPRPEND
Local Decimal SUBEAR, TOTEARN

If !clalev([F:HSP]) : Local File HISTOPAYE [HSP] : Endif
For [HSP] Where [HSP]EMP = REFNUM and [HSP]TYP = 6 and [HSP]DAT >= SMPPRPSTR and [HSP]DAT <= SMPPRPEND and [HSP]RUB = 'NAT_IN_MTD'
  TOTEARN += [HSP]AMT
Next
SUBEAR = TOTEARN / 2 *12 / 52
End SUBEAR

Funprog GETCTRDAT(EMPID, CTRNUMBER)
Value Char EMPID, CTRNUMBER
Local Date CDAT

  If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
  Filter [HRCTR] Where REFNUM = EMPID and CTRNUM = CTRNUMBER
  Read [HRCTR] First
  Filter [HRCTR]
  If !fstat
    CDAT = [HRCTR]CTRDAT
  Endif

End CDAT

Subprog GETCTR (FREQ,PERCODE,REFNUM)
Variable Char FREQ,PERCODE
Value Char REFNUM

  If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
  Filter [HRCTR] Where REFNUM = [M:DCG1]REFNUM and CTRNUM = [M:DCG1]CTRNUM(DCGUKINBLIG)
  Read [HRCTR] First
  Filter [HRCTR]
  If !fstat
    If !clalev([F:HRPEOH]) : Local File HRPEOHEA [HRPEOH] : Endif
    Filter [HRPEOH] Where PERCOD = [HRCTR]PERCOD
    Read [HRPEOH] First
    Filter [HRPEOH]
    If !fstat
      PERCODE = [HRCTR]PERCOD
  #MASHI - 2017-09-12 X3-47515 START
      Case  [HRPEOH]PAYFRQ
        When 1  # Weekly
          [L]FREQ = "W"
        When 2 # Bi-monthly
          [L]FREQ = "B"
        When 3 # Fortnightly
          [L]FREQ = "F"
        When 4 # 4 week
          [L]FREQ = "4"
        When 5 # Quarterly
          [L]FREQ = "Q"
        When 6 # Monthly
          [L]FREQ = "M"
        When 7 # Annual
          [L]FREQ = "A"
      Endcase
  #     Call LECTEXTRA(FREQ,"HRPEOHEA","PAYFRQ",PERCODE,'') From ATEXTRA
  #MASHI - 2017-09-12 X3-47515 START
    Endif
  Endif

End

Subprog SMPCAL(LVEDAT,AVGEARN)
Value Date LVEDAT
Value Decimal AVGEARN
Local Integer SMP_WKP_HR : SMP_WKP_HR = int(func SUBDCGUKI.SETVARIABLE("SMP_WKP_HR",[M:DCG1]STRDAT(nolign-1)))
Local Integer SMP_HR_PER : SMP_HR_PER = int(func SUBDCGUKI.SETVARIABLE("SMP_HR_PER",[M:DCG1]STRDAT(nolign-1)))
Local Integer SMP_WKP_SR : SMP_WKP_SR = int(func SUBDCGUKI.SETVARIABLE("SMP_WKP_SR",[M:DCG1]STRDAT(nolign-1)))
Local Integer SMP_SR_PER : SMP_SR_PER = int(func SUBDCGUKI.SETVARIABLE("SMP_SR_PER",[M:DCG1]STRDAT(nolign-1)))
Local Decimal SMP_SR_AMT : SMP_SR_AMT = func SUBDCGUKI.SETVARIABLE("SMP_SR_AMT",[M:DCG1]STRDAT(nolign-1))
Local Decimal SMP_SR_AMT : SMP_SR_AMT = func SUBDCGUKI.SETVARIABLE("SMP_SR_AMT",[M:DCG1]STRDAT(nolign-1))
Local Decimal SMP_MAWE   : SMP_MAWE   = func SUBDCGUKI.SETVARIABLE("SMP_MAWE",[M:DCG1]STRDAT(nolign-1))
Local Decimal TOTEARN
Local Decimal SUBEAR
Local Char FREQ, PERCODE

  Raz [M:DCG1]SMPWEKSTR
  Raz [M:DCG1]SMPTAXYEA
  Raz [M:DCG1]SMPTAXPER
  Raz [M:DCG1]SMPFREQUE
  Raz [M:DCG1]SMPRAT
  Raz [M:DCG1]SMPAMT
  Raz [M:DCG1]SMPPAI
  [M:DCG1]NBPAY = 0
  Affzo [M:DCG1]70

#  If [M:DCG1]SMPEVIREC < 2
#    Infbox mess(13,11828,1)
#      [M:DCG1]SMPELI = 1: Affzo [M:DCG1]SMPELI
#      #[M:DCG1]SSPSTA(nolign-1) = 1: Affzo [M:DCG1]SSPSTA(DCGUKINBLIG)
#      #[M:DCG1]SMPREA = mess(13,11828,1)
#      [M:DCG1]SMPREA = 13
#      Affzo [M:DCG1]SMPREA
#  Endif
#
#  If [M:DCG1]SMPLEADAT = [0/0/0]
#    mkstat = 2 : GERR = 1 :  GMESSAGE = mess(7,11828,1)
#  Endif

  Call GETCTR(FREQ,PERCODE,"") From SUBDCGSMP
  #SUBEAR = func SUBDCGUKI.AVERAGE_EARNING([M:DCG1]REFNUM,[M:DCG1]SMPPRPSTR,[M:DCG1]SMPPRPEND)

    #JOJAC - START
    #[M:DCG1]SMPAWE = SUBEAR : Affzo [M:DCG1]SMPAWE
    #JOJAC - END

    #JOJAC - START
    #If [M:DCG1]AVEERN(DCGUKINBLIG) > SMP_MAWE


  #ANCOA - 14/11/2017 - X3-62580 - Start
  #If Eligible for SMP is false then do not calculate the SMP payments
  #If GUSER = 'JOJAC' : Infbox 'SMPELI'-num$([M:DCG1]SMPELI) : Endif
  If [M:DCG1]SMPELI <> 2
    End
  Endif
  #ANCOA - 14/11/2017 - X3-62580 - End

    SMP_MAWE   = func SUBDCGUKI.SETVARIABLE("SMP_MAWE",[M:DCG1]STRDAT(nolign-1))

    #If [M:DCG1]SMPAWE > [L]SMP_MAWE
    If AVGEARN >= [L]SMP_MAWE

    #JOJAC - END
    Local Decimal WEEKEARN
  #MASHI - 2017-09-08 X3-54387 END
  ##### in these for loops add these values to the payments grid
    If !clalev([F:HRPEOD]) : Local File HRPEODET [HRPEOD] : Endif
    #JOJAC - 2017-10-30 - X3-60906 - START
    #Local Date PERDAT : PERDAT = [M:DCG1]SMPLEADAT + 1

    Local Date PERDAT# : PERDAT = [M:DCG1]SMPLEADAT
    PERDAT = [L]LVEDAT
    #JOJAC - 2017-10-30 - X3-60906 - END
    Local Integer LIGNUM : LIGNUM = 0

    Affzo [M:DCG1]SMPWEKSTR
    Affzo [M:DCG1]SMPTAXYEA
    Affzo [M:DCG1]SMPTAXPER
    Affzo [M:DCG1]SMPFREQUE
    Affzo [M:DCG1]SMPRAT
    Affzo [M:DCG1]SMPAMT
    Affzo [M:DCG1]SMPPAI

    For J = 1 To SMP_WKP_HR

      #JOJAC - 2017-11-15 - X3-64100 - START
      If [M:DCG1]SMPRETDAT <> [0/0/0]
        If PERDAT > [M:DCG1]SMPRETDAT : Break : Endif
      Endif
      #JOJAC - 2017-11-15 - X3-64100 - END

      #JOJAC - 2017-11-15 - X3-65025 - START
      #SAVAN - 2018/03/06 - merge - start
      If [M:DCG1]ENDDAT(nolign-1) <> [0/0/0]  and [M:DCG1]STA(nolign-1)=6
      #If [M:DCG1]ENDDAT(nolign-1) <> [0/0/0]
      #SAVAN - 2018/03/06 - merge - start
        If PERDAT > [M:DCG1]ENDDAT(nolign-1) and (PERDAT-[M:DCG1]ENDDAT(nolign-1))<=7
          Break
        Endif
      Endif
      #JOJAC - 2017-11-15 - X3-65025 - END

      #JOJAC - START
      #WEEKEARN = [M:DCG1]AVEERN(DCGUKINBLIG) / 100 * SMP_HR_PER
      WEEKEARN = [M:DCG1]SMPAWE / 100 * SMP_HR_PER
      #JOJAC - END
  #MASHI - 2017-09-06 X3-54945 START
  #    Filter [HRPEOD] Where PERCOD = PERCODE and PERSTR >= PERDAT and PEREND <= PERDAT
      Filter [HRPEOD] Where PERCOD = PERCODE and PERSTR(1) <= PERDAT and PEREND(1) >= PERDAT
  #MASHI - 2017-09-06 X3-54945 END
      Read [HRPEOD] First
      Filter [HRPEOD]
      If !fstat
        #get the tax year and period i month here
  #MASHI - 2017-09-06 X3-54945 START
  #      [M:DCG1]SMPTAXYEA(LIGNUM) = [HRPEOD]PERYEA
  #      [M:DCG1]SMPTAXPER(LIGNUM) = [HRPEOD]PERMON
  #      [M:DCG1]SMPFREQUE(LIGNUM) = [HRPEOD]FREQ
        [M:DCG1]SMPWEKSTR(LIGNUM) = [L]PERDAT
        [M:DCG1]SMPTAXYEA(LIGNUM) = [HRPEOD]PERYEA
        [M:DCG1]SMPTAXPER(LIGNUM) = [HRPEOD]PERNUM
        [M:DCG1]SMPFREQUE(LIGNUM) = [L]FREQ
  #MASHI - 2017-09-06 X3-54945 END
        [M:DCG1]SMPRAT(LIGNUM) = "Higher"
        [M:DCG1]SMPAMT(LIGNUM) = WEEKEARN
        [M:DCG1]SMPPAI(LIGNUM) = "No"
      Endif
      PERDAT = PERDAT +7
      LIGNUM += 1


    Next J

    For J = 1 To SMP_WKP_SR


      #JOJAC - 2017-11-15 - X3-64100 - START
      If [M:DCG1]SMPRETDAT <> [0/0/0]
        If PERDAT > [M:DCG1]SMPRETDAT : Break : Endif
      Endif
      #JOJAC - 2017-11-15 - X3-64100 - END

      #JOJAC - 2017-11-15 - X3-65025 - START
      If [M:DCG1]ENDDAT(nolign-1) <> [0/0/0]
        If PERDAT > [M:DCG1]ENDDAT(nolign-1) and (PERDAT-[M:DCG1]ENDDAT(nolign-1))<=7
          Break
        Endif
      Endif
      #JOJAC - 2017-11-15 - X3-65025 - END

      SMP_SR_AMT = func SUBDCGUKI.SETVARIABLE("SMP_SR_AMT",PERDAT)
      #WEEKEARN = SUBEAR / 100 * SMP_SR_PER
      WEEKEARN = [M:DCG1]SMPAWE / 100 * SMP_HR_PER
      Local Decimal SMP_AMT
      [L]SMP_AMT = ar2(min(SMP_SR_AMT,WEEKEARN))
      # or weekearn = SMP_SR_AMT
  #MASHI - 2017-09-06 X3-54945 START
  #    Filter [HRPEOD] Where PERCOD = PERCODE and PERSTR >= PERDAT and PEREND <= PERDAT
      Filter [HRPEOD] Where PERCOD = PERCODE and PERSTR(1) <= PERDAT and PEREND(1) >= PERDAT
  #MASHI - 2017-09-06 X3-54945 END
      Read [HRPEOD] First
      Filter [HRPEOD]
      If !fstat
        #get the tax year and period i month here
  #MASHI - 2017-09-06 X3-54945 START
  #      [M:DCG1]SMPTAXYEA(LIGNUM) = [HRPEOD]PERYEA
  #      [M:DCG1]SMPTAXPER(LIGNUM) = [HRPEOD]PERMON
  #      [M:DCG1]SMPFREQUE(LIGNUM) = [HRPEOD]FREQ
  #      [M:DCG1]SMPRAT(LIGNUM) = "Higher"
  #      [M:DCG1]SMPAMT(LIGNUM) = WEEKEARN

        [M:DCG1]SMPWEKSTR(LIGNUM) = [L]PERDAT
        [M:DCG1]SMPTAXYEA(LIGNUM) = [HRPEOD]PERYEA
        [M:DCG1]SMPTAXPER(LIGNUM) = [HRPEOD]PERNUM
        [M:DCG1]SMPFREQUE(LIGNUM) = [L]FREQ
        [M:DCG1]SMPRAT(LIGNUM) = "SMP"
        #[M:DCG1]SMPAMT(LIGNUM) = SMP_SR_AMT
        [M:DCG1]SMPAMT(LIGNUM) = [L]SMP_AMT
  #MASHI - 2017-09-06 X3-54945 END
        [M:DCG1]SMPPAI(LIGNUM) = "No"
      Endif

      PERDAT = PERDAT +7
      LIGNUM += 1



    Next J
    #Assign "[M:DCG1]NBPAY" With LIGNUM
    [M:DCG1]NBPAY = LIGNUM
    #Affzo [M:DCG1]NBPAY
  ##### in these for loops add these values to the payments grid
  Else
  #set reason here
      #[M:DCG1]SMPREA = mess(8,11828,1) : Affzo [M:DCG1]SMPREA
      #[M:DCG1]SMPREA = 8 : Affzo [M:DCG1]SMPREA
      [M:DCG1]SMPELI = 1 : Affzo [M:DCG1]SMPELI
      #[M:DCG1]SSPSTA(nolign-1) = 1: Affzo [M:DCG1]SSPSTA(nolign-1)
      #[M:DCG1]SSPSTAREA(nolign-1) = "E": Affzo [M:DCG1]SSPSTAREA(nolign-1)

  Endif
#Endif

  #[M:DCG1]NBPAY = LIGNUM
  Affzo [M:DCG1]70

  Grizo [M:DCG1]SMPWEKSTR
  Grizo [M:DCG1]SMPTAXYEA
  Grizo [M:DCG1]SMPTAXPER
  Grizo [M:DCG1]SMPFREQUE
  Grizo [M:DCG1]SMPRAT
  Grizo [M:DCG1]SMPAMT
  Grizo [M:DCG1]SMPPAI


End

#MASHI - 2017-09-08 X3-54202 START
Subprog AVANT_NBLIG
  Call SHOWHIDE(nolign-1) From SUBDCGUKI
  Local Char DES
###  Call LECTEXTRA([L]DES,"ATABDIV","LNGDES","10408",[M:DCG1]SSPSTAREA(nolign-1)) From ATEXTRA : Affzo [M:DCG1]SSPEXC
###  [M:DCG1]SMPEXC      = [L]DES                              : Affzo [M:DCG1]SMPEXC
###  [M:DCG1]SMPELI       = [M:DCG1]SSPSTA(nolign-1)           : Affzo [M:DCG1]SMPELI

  If clalev([SMPLVE])=0 : Local File UKSMPLVE [SMPLVE] : Endif
  Read [F:SMPLVE]SMPLVE1 =  [M:DCG1]UID(nolign-1)
  If !fstat
    [M:DCG1]SMPEVIREC = [SMPLVE]SMPEVIREC : Affzo [M:DCG1]SMPEVIREC
    [M:DCG1]SMPEXC    = [SMPLVE]SMPEXC    : Affzo [M:DCG1]SMPEXC
    [M:DCG1]SMPEXPDOB = [SMPLVE]SMPEXPDOB : Affzo [M:DCG1]SMPEXPDOB
    [M:DCG1]SMPLEADAT = [SMPLVE]SMPLEADAT : Affzo [M:DCG1]SMPLEADAT
    [M:DCG1]SMPACTDOB = [SMPLVE]SMPACTDOB : Affzo [M:DCG1]SMPACTDOB
    [M:DCG1]SMPEARDAT = [SMPLVE]SMPEARDAT : Affzo [M:DCG1]SMPEARDAT
    [M:DCG1]SMPRETDAT = [SMPLVE]SMPRETDAT : Affzo [M:DCG1]SMPRETDAT
    [M:DCG1]SMPQUADAT = [SMPLVE]SMPQUADAT : Affzo [M:DCG1]SMPQUADAT
    [M:DCG1]SMPEMPDAT = [SMPLVE]SMPEMPDAT : Affzo [M:DCG1]SMPEMPDAT
    [M:DCG1]SMPPRPSTR = [SMPLVE]SMPPRPSTR : Affzo [M:DCG1]SMPPRPSTR
    [M:DCG1]SMPPRPEND = [SMPLVE]SMPPRPEND : Affzo [M:DCG1]SMPPRPEND
    [M:DCG1]SMPEXPCON = [SMPLVE]SMPEXPCON : Affzo [M:DCG1]SMPEXPCON
    [M:DCG1]SMPWEEPER = [SMPLVE]SMPWEEPER : Affzo [M:DCG1]SMPWEEPER
    [M:DCG1]SMPEARLEA = [SMPLVE]SMPEARLEA : Affzo [M:DCG1]SMPEARLEA
    [M:DCG1]SMPLATRET = [SMPLVE]SMPLATRET : Affzo [M:DCG1]SMPLATRET
    [M:DCG1]SMPELI    = [SMPLVE]SMPELI    : Affzo [M:DCG1]SMPELI
    #[M:DCG1]SMPREA    = [SMPLVE]SMPREA    : Affzo [M:DCG1]SMPREA
    [M:DCG1]SMPPRO    = [SMPLVE]SMPPRO    : Affzo [M:DCG1]SMPPRO
    [M:DCG1]SMPQUADAT = [SMPLVE]SMPQUADAT : Affzo [M:DCG1]SMPQUADAT
    [M:DCG1]SMPAWE    = [SMPLVE]SMPAWE    : Affzo [M:DCG1]SMPAWE

  Endif

#If GUSER = 'JOJAC'
  Effzo [M:DCG1]NBKIT
  If !clalev([F:KIT]) : Local File SMPKIT [KIT] : Endif
  Raz [M:DCG1]NBKIT
  Local Integer LIGNUM : LIGNUM = 0
  For [KIT] Where REFNUM = [M:DCG1]REFNUM and CTRNUM = [M:DCG1]CTRNUM(nolign-1)
    [M:DCG1]KITDAT(LIGNUM) = [KIT]KITDAT
    LIGNUM +=1
  Next
  [M:DCG1]NBKIT = LIGNUM
  Affzo [M:DCG1]75
#Endif

  If [M:DCG1]SMPLEADAT <> [0/0/0]
    Call SMPCAL([M:DCG1]SMPLEADAT,[M:DCG1]SMPAWE)
  Endif

End
#MASHI - 2017-09-08 X3-54202 END

#MASHI - 2017-09-18 X3-47523 START
Subprog AM_TIM(VALEUR)
Variable Char    VALEUR()

  Gosub CHECKSAVESTATUS From SUBDCGSMP
  Gosub LOADSMP From SUBDCGSMP
  #[M:DCG1]AVEERN(nolign-1) = [M:DCG1]SMPAWE
  #Affzo [M:DCG1]AVEERN(nolign-1)
  #JOJAC - 2017-11-02 - START
  zonsui = "[M:DCG1]SMPACTDOB"
  #JOJAC - 2017-11-02 - END
  #SAVAN - 2018/02/27 - part of X3-78794 to block INSERT entries in DCG - start
  If clalev([DCG_BLK])=0 : Local File DEMCONGE [DCG_BLK] : Endif
  Filter [DCG_BLK] Where [DCG_BLK]STRDAT>[M:DCG1]STRDAT(nolign-1) and [DCG_BLK]TIM=VALEUR and [DCG_BLK]REFNUM = [M:DCG1]REFNUM and [DCG_BLK]CTRNUM = [M:DCG1]CTRNUM(nolign-1)
& and ([F:DCG_BLK]STA=1 | [F:DCG_BLK]STA=2 | [F:DCG_BLK]STA=3 ) and [DCG_BLK]UID>0
  Read [DCG_BLK] First
  If rowcount([DCG_BLK])<>0
   #SAVAN message that there is another transaction before --> Block and end
   #GMESSAGE = mess(2,11828,1)
   Call ERREUR(mess(20,11828,1)) From GESECRAN
   [V]GOK=0
   mkstat = 2
   End
  Endif
  Filter [DCG_BLK]
  #SAVAN - 2018/02/27 - part of X3-78794 to block INSERT entries in DCG - end
  If clalev([DCG_LSMP])=0 : Local File DEMCONGE [DCG_LSMP] : Endif
  Filter [DCG_LSMP] Where TIM = VALEUR and STRDAT > ([M:DCG1]STRDAT(nolign-1)-364) and ENDDAT < [M:DCG1]STRDAT(nolign-1) and REFNUM = [M:DCG1]REFNUM and CTRNUM = [M:DCG1]CTRNUM(nolign-1) and UID > 0
  Read [DCG_LSMP] First
  Filter [DCG_LSMP]
  If !fstat
    If clalev([SMPLVE])=0 : Local File UKSMPLVE [SMPLVE] : Endif
    Read [SMPLVE]SMPLVE1 = [DCG_LSMP]UID
    If !fstat
    #SAVAN - 2018/02/28- X3-78816 - Clear the fields once other transactions have been selected for new input - start
    [M:DCG1]SMPEVIREC = [SMPLVE]SMPEVIREC : Affzo [M:DCG1]SMPEVIREC
    [M:DCG1]SMPACTDOB = [SMPLVE]SMPACTDOB : Affzo [M:DCG1]SMPACTDOB
    [M:DCG1]SMPEXPDOB = [SMPLVE]SMPEXPDOB : Affzo [M:DCG1]SMPEXPDOB
    [M:DCG1]SMPLEADAT = [SMPLVE]SMPLEADAT : Affzo [M:DCG1]SMPLEADAT
    [M:DCG1]SMPRETDAT = [SMPLVE]SMPRETDAT : Affzo [M:DCG1]SMPRETDAT
    [M:DCG1]SMPAWE    = [SMPLVE]SMPAWE    : Affzo [M:DCG1]SMPAWE
#    [M:DCG1]SMPEVIREC = 1#[SMPLVE]SMPEVIREC : Affzo [M:DCG1]SMPEVIREC
#    Raz [M:DCG1]SMPACTDOB #[SMPLVE]SMPACTDOB : Affzo [M:DCG1]SMPACTDOB
#    Raz [M:DCG1]SMPEXPDOB #[SMPLVE]SMPEXPDOB : Affzo [M:DCG1]SMPEXPDOB
#    Raz [M:DCG1]SMPLEADAT #[SMPLVE]SMPLEADAT : Affzo [M:DCG1]SMPLEADAT
#    Raz [M:DCG1]SMPRETDAT #[SMPLVE]SMPRETDAT : Affzo [M:DCG1]SMPRETDAT
#    Raz [M:DCG1]SMPAWE    #[SMPLVE]SMPAWE    : Affzo [M:DCG1]SMPAWE
#    Affzo [M:DCG1]SMPEVIREC
#    Affzo [M:DCG1]SMPACTDOB
#    Affzo [M:DCG1]SMPEXPDOB
#    Affzo [M:DCG1]SMPLEADAT
#    Affzo [M:DCG1]SMPRETDAT
#    Affzo [M:DCG1]SMPAWE
    #SAVAN - 2018/02/28- X3-78816 - Clear the fields once other transactions have been selected for new input - end
   Endif
  Endif
#SAVAN - Clear entries - start - X3-78816
#       [M:DCG1]SMPEVIREC = 1#[SMPLVE]SMPEVIREC : Affzo [M:DCG1]SMPEVIREC
#    Raz [M:DCG1]SMPACTDOB #[SMPLVE]SMPACTDOB : Affzo [M:DCG1]SMPACTDOB
#    Raz [M:DCG1]SMPEXPDOB #[SMPLVE]SMPEXPDOB : Affzo [M:DCG1]SMPEXPDOB
#    Raz [M:DCG1]SMPLEADAT
#    Raz [M:DCG1]SMPRETDAT#[SMPLVE]SMPLEADAT : Affzo [M:DCG1]SMPLEADAT
    [M:DCG1]SMPRETDAT=[M:DCG1]ENDDAT(nolign-1)+1 #[SMPLVE]SMPRETDAT : Affzo [M:DCG1]SMPRETDAT
#    Raz [M:DCG1]SMPAWE    #[SMPLVE]SMPAWE    : Affzo [M:DCG1]SMPAWE
#    Affzo [M:DCG1]SMPEVIREC
#    Affzo [M:DCG1]SMPACTDOB
#    Affzo [M:DCG1]SMPEXPDOB
#    Affzo [M:DCG1]SMPLEADAT
    Affzo [M:DCG1]SMPRETDAT
#    Affzo [M:DCG1]SMPAWE
#SAVAN - Clear entries - end - X3-78816
  #JOJAC - 2017-11-27 - X3-64988 - START
  If [M:DCG1]SMPEXPDOB <> [0/0/0] and [M:DCG1]SMPLEADAT <> [0/0/0]
    Call C_SMPEXPDOB([M:DCG1]SMPEXPDOB)
    Call C_SMPLEADAT([M:DCG1]SMPLEADAT)
  Endif
  #JOJAC - 2017-11-27 - X3-64988 - END


End

$CHECKSAVESTATUS
Local Integer K

  For K = 0 To [M:DCG1]NBLIG
    If K <> nolign-1
      If [M:DCG1]UID(K) = 0 and [M:DCG1]SXPCAT(K) = 'SMP'
        #TODO
        Infbox "You have unsaved SMP transactions on the grid - please save grid before entering new SMP transactions"
        #mkstat = 2
      Endif
    Endif
  Next

Return
#MASHI - 2017-09-18 X3-47523 END

#LEGAL VARIABLES
#SMP_DTELD  - SMP Days to Earliest Leave Dat    = 77
#SMP_DTERD  - SMP Days to Earliest Return Date  = 14
#SMP_DTLSD  - SMP Days to Latest Start Date     = 182
#SMP_DTQW   - SMP Days to Qualifying Week       = 105
#SMP_HR_PER - SMP Higher Rate %                 = 90
#SMP_MAWE   - SMP Min Ave Earnings              = 113
#SMP_MAX_LW - SMP Max Leave Weeks               = 52
#SMP_PRA    - SMP Pregnancy Related Absense     = 28
#SMP_SR_AMT - SMP Standard Rate Amount          = 140.98
#SMP_SR_PER - SMP Standard Rate %               = 90
#SMP_WKP_HR - SMP Weeks Payable Higher Rate     = 6
#SMP_WKP_SR - SMP Weeks Payable Std Rate        = 33


$FOUR_WEEK_BEFORE_EXPECTED
Local Date MYDATE
 #4 week period before expected date
 #MASHI - 2017-09-08 X3-54449 START
 #JOJAC - 2017-10-06 - X3-15908 - START
 If dayn(VALEUR) <> 7
  MYDATE = VALEUR - dayn(VALEUR)  - 28
 Else
  MYDATE = VALEUR - 28
 Endif
 #MYDATE = VALEUR - 28
 #JOJAC - 2017-10-06 - X3-15908 - END
 #MASHI - 2017-09-08 X3-54449 END
 #[M:DCG1]SMPWEEPER = format$("D:DD2",MYDATE) : Affzo [M:DCG1]SMPWEEPER
 [M:DCG1]SMPWEEPER = MYDATE : Affzo [M:DCG1]SMPWEEPER
Return

$EARLIEST_LEAVE_DATE
Local Integer SMP_DTELD
Local Date EARDAT

 #Earliest leave date [SMPEARLEA]
 SMP_DTELD = int(func SUBDCGUKI.SETVARIABLE("SMP_DTELD",[M:DCG1]STRDAT(DCGUKINBLIG)))
 #SMP Days to earliest leave date
 #SMP_DTELD = 77
 #VALEUR = Expected date of birth
 #SMP_DTELD - SMP DAYS To EARLIEST LEAVE Date
 #Expected date of birth - SMP days to earliest leave date
 If dayn(VALEUR) <> 7
  EARDAT = VALEUR - dayn(VALEUR) - SMP_DTELD
 Else
   EARDAT = VALEUR - SMP_DTELD
 Endif

 [M:DCG1]SMPEARLEA = EARDAT : Affzo [M:DCG1]SMPEARLEA

Return


$QUALIFYING_WEEK_START
Local Date QUADAT
Local Integer SMP_DTQW, DANAM

  SMP_DTQW = int(func SUBDCGUKI.SETVARIABLE("SMP_DTQW",[M:DCG1]STRDAT(DCGUKINBLIG)))
  #VALEUR = Expexted date of birth
  #MP_DTQW = SMP Days to qualifying week
  #Expected date of birth - SMP Days to qualifying week
  QUADAT = VALEUR - SMP_DTQW
  DANAM = dayn(QUADAT)

  If [M:DCG1]SMPPRO < 1
    [M:DCG1]SMPPRO = 2: Affzo [M:DCG1]SMPPRO
  Endif

  While DANAM <> 7
    QUADAT = QUADAT -1
    DANAM = dayn(QUADAT)
  Wend

  [M:DCG1]SMPQUADAT = QUADAT
  Affzo [M:DCG1]SMPQUADAT

Return


Subprog SMP_ELIGIBILITY(AVGEARN,LSTEMPSTR,QUADAT,EVIREC)
Value Integer EVIREC
Value Decimal AVGEARN
Value Date LSTEMPSTR, QUADAT
Local Decimal SMP_MAWE

  #Average earnings above limit
  [L]SMP_MAWE   = func SUBDCGUKI.SETVARIABLE("SMP_MAWE",[M:DCG1]STRDAT(DCGUKINBLIG))
  #TODO - REMOVE SOURCE TO SET PARAMETER
  #If GUSER = 'JOJAC' : SMP_MAWE=113 : Endif

  #If [M:DCG1]SMPAWE < [L]SMP_MAWE
  If AVGEARN < [L]SMP_MAWE
    [M:DCG1]SMPELI = 1 : Affzo [M:DCG1]SMPELI
    #ANCOA 07/11/2017 - X3-60674 - START
    [M:DCG1]SMPREA = "E" : Affzo [M:DCG1]SMPREA, ZSMPREA
    End
    #ANCOA 07/11/2017 - X3-60674 - END
  Else
    [M:DCG1]SMPELI = 2 : Affzo [M:DCG1]SMPELI
    #ANCOA 07/11/2017 - X3-60674 - START
    Raz [M:DCG1]SMPREA : Affzo [M:DCG1]SMPREA, ZSMPREA
    #ANCOA 07/11/2017 - X3-60674 - END
  Endif
  #Affzo [M:DCG1]60

  #In service
  If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
  Filter [HRCTR] Where REFNUM = [M:DCG1]REFNUM and CTRNUM = [M:DCG1]CTRNUM
  Read [HRCTR] First
  Filter [HRCTR]
  If !fstat
    #If [HRCTR]CTRDAT < QUADAT-128
    #JOJAC - 2017-10-30 - X3-59159 - START
    #If [HRCTR]CTRDAT < [M:DCG1]SMPEMPDAT
    If [HRCTR]CTRDAT < LSTEMPSTR
    #If [HRCTR]CTRDAT < [M:DCG1]SMPQUADAT-128
    #JOJAC - 2017-10-30 - X3-59159 - END
      [M:DCG1]SMPELI = 2
      If [HRCTR]XITDAT <> [0/0/0]
        #If [HRCTR]XITDAT < QUADAT
          [M:DCG1]SMPELI = 1
          #[M:DCG1]SMPREA = mess(4,11828,1)
          #ANCOA 07/11/2017 - X3-60674 - START
          [M:DCG1]SMPREA = "M" : Affzo [M:DCG1]SMPREA, ZSMPREA
          Affzo [M:DCG1]SMPREA, ZSMPREA
          #ANCOA 07/11/2017 - X3-60674 - END
        #Endif
        End
      Endif
    Else
      [M:DCG1]SMPELI = 1      : Affzo [M:DCG1]SMPELI
      #[M:DCG1]SSPSTA(DCGUKINBLIG) = 1
      #[M:DCG1]SMPREA = mess(1,11828,1)
      #ANCOA 07/11/2017 - X3-60674 - START
      [M:DCG1]SMPREA = "M"    : Affzo [M:DCG1]SMPREA, ZSMPREA
      #ANCOA 07/11/2017 - X3-60674 - END
      End
    Endif
  Endif

    If EVIREC < 2
    #Infbox mess(13,11828,1)
    #[M:DCG1]SMPELI = 1  : Affzo [M:DCG1]SMPELI
    #ANCOA 07/11/2017 - X3-60674 - START
    [M:DCG1]SMPREA = "N" : Affzo [M:DCG1]SMPREA, ZSMPREA
    #ANCOA 07/11/2017 - X3-60674 - END
    #ANCOA 07/11/2017 - X3-62591 - START
    [M:DCG1]SMPELI = 1  : Affzo [M:DCG1]SMPELI
    #ANCOA 07/11/2017 - X3-62591 - END
    End
  Else
    [M:DCG1]SMPELI = 2  : Affzo [M:DCG1]SMPELI
    #ANCOA 07/11/2017 - X3-60674 - START
    Raz [M:DCG1]SMPREA  : Affzo [M:DCG1]SMPREA, ZSMPREA
    #ANCOA 07/11/2017 - X3-60674 - END
  Endif

End

$SMP_RELEVANT_PERIOD
Local Char VPERCOD
Local Date SUBRELPERSTR
Local Date SUBRELPEREND

  ##This is usually the 8 week period before the QW.
  If clalev([F:HRCTR9])=0 : Local File EMPLOCTR  [HRCTR9] : Endif
  #If clalev([F:HRPEOH9])=0 : Local File HRPEOHEA  [HRPEOH9] : Endif
  If clalev([F:HRPEOD9])=0 : Local File HRPEODET  [HRPEOD9] : Endif

  Filter [HRCTR9] Where CTRNUM = [M:DCG1]CTRNUM
  Read [HRCTR9] First
  Filter [HRCTR9]
  If !fstat
    [L]VPERCOD = [F:HRCTR9]PERCOD
  Endif

  #Filter [HRPEOD9] Where PERCOD = [L]VPERCOD and PYRDAT <= QUADAT + 6
  Filter [HRPEOD9] Where PERCOD = [L]VPERCOD and PYRDAT <= [M:DCG1]SMPQUADAT + 6
  Read [HRPEOD9] Last
  Filter [HRPEOD9]
  If !fstat
    [L]SUBRELPEREND = [F:HRPEOD9]PYRDAT
    [L]SUBRELPERSTR = ([F:HRPEOD9]PYRDAT - 56)+1

    #ALHAR - 2018-02-26 X3-78874 Start
    Filter [HRPEOD9] Where PERCOD = [L]VPERCOD and PYRDAT <= [L]SUBRELPERSTR
    Read [HRPEOD9] Last
    Filter [HRPEOD9]
    If !fstat
      [L]SUBRELPERSTR = [F:HRPEOD9]PYRDAT+1
    Endif
    #ALHAR - 2018-02-26 X3-78874 End

  Endif


  [M:DCG1]SMPPRPSTR = SUBRELPERSTR : Affzo [M:DCG1]SMPPRPSTR
  [M:DCG1]SMPPRPEND = SUBRELPEREND : Affzo [M:DCG1]SMPPRPEND
  #ANCOA - 2017-11-20 X3-64820 Start
  #JOJAC - 2017-11-23 - X3-65447 - START
  #[M:DCG1]SMPPRPDIS = num$([M:DCG1]SMPPRPSTR)+" - "+num$([M:DCG1]SMPPRPEND)
  [M:DCG1]SMPPRPDIS = format$("N0:2",num$(month([M:DCG1]SMPPRPSTR)))+"/"+format$("N0:2",num$(day([M:DCG1]SMPPRPSTR)))+"/"+num$(year([M:DCG1]SMPPRPSTR))+"-"+
&                     format$("N0:2",num$(month([M:DCG1]SMPPRPEND)))+"/"+format$("N0:2",num$(day([M:DCG1]SMPPRPEND)))+"/"+num$(year([M:DCG1]SMPPRPEND))
  Affzo [M:DCG1]SMPPRPDIS
  #ANCOA - 2017-11-20 X3-64820 End
  #JOJAC - 2017-11-23 - X3-65447 - END
Return

$SMP_RELEVANT_PERIOD_ACTDON
Local Date SUBRELPERSTR #: SUBRELPERSTR = QUADAT + 7 - 56
Local Date SUBRELPEREND #: SUBRELPEREND = QUADAT + 7 - 1

#ANCOA - 2017-11-20 X3-64820 Start
  If [L]SMPACTDOB < [M:DCG1]SMPQUADAT
#ANCOA - 2017-11-20 X3-64820 End
    If clalev([F:HRCTR9])=0 : Local File EMPLOCTR  [HRCTR9] : Endif
    If clalev([F:HRPEOD9])=0 : Local File HRPEODET  [HRPEOD9] : Endif

    Local Char VPERCOD
    Filter [HRCTR9] Where CTRNUM = [M:DCG1]CTRNUM
    Read [HRCTR9] First
    Filter [HRCTR9]
    If !fstat
      [L]VPERCOD = [F:HRCTR9]PERCOD
    Endif

#ANCOA - 2017-11-20 X3-64820 Start
    Filter [HRPEOD9] Where PERCOD = [L]VPERCOD and PYRDAT <= [L]SMPACTDOB + 1
#ANCOA - 2017-11-20 X3-64820 End
    Read [HRPEOD9] Last
    Filter [HRPEOD9]
    If !fstat
      [L]SUBRELPEREND = [F:HRPEOD9]PYRDAT
#MASHI - 2017-10-05 X3-58585 START
      [L]SUBRELPERSTR = ([F:HRPEOD9]PYRDAT - 56) + 1
#MASHI - 2017-10-05 X3-58585 END
    Endif

    [M:DCG1]SMPPRPSTR = SUBRELPERSTR : Affzo [M:DCG1]SMPPRPSTR
    [M:DCG1]SMPPRPEND = SUBRELPEREND : Affzo [M:DCG1]SMPPRPEND
    #ANCOA - 2017-11-20 X3-64820 Start
    [M:DCG1]SMPPRPDIS = num$([M:DCG1]SMPPRPSTR)+" - "+num$([M:DCG1]SMPPRPEND)
    Affzo [M:DCG1]SMPPRPDIS
    #ANCOA - 2017-11-20 X3-64820 End
  Endif
#MASHI - 2017-09-18 X3-47521 END
Return

$LAST_EMPLOYMENT_START_DATE
Local Date SUBLASDAT
Local Integer SUBLASD
Local Integer SMP_DTLSD

  SMP_DTLSD = int(func SUBDCGUKI.SETVARIABLE("SMP_DTLSD",[M:DCG1]STRDAT(DCGUKINBLIG)))
  #TODO - uncommetn
  #SMP_DTLSD = SMP Days to Latest Start Date
  SUBLASDAT = QUADAT
  SUBLASD = dayn(SUBLASDAT)

  While SUBLASD <> 6
    SUBLASDAT = SUBLASDAT +1
    SUBLASD = dayn(SUBLASDAT)
  Wend
  SUBLASDAT = SUBLASDAT - SMP_DTLSD +1
  SUBLASD = dayn(SUBLASDAT)

  While SUBLASD <> 6
    SUBLASDAT = SUBLASDAT +1
    SUBLASD = dayn(SUBLASDAT)
  Wend

  [M:DCG1]SMPEMPDAT = SUBLASDAT : Affzo [M:DCG1]SMPEMPDAT

Return

$EXPECTED_WEEK
Local Date EXPDAT
Local Integer EXPNAM


  EXPDAT = VALEUR
  EXPNAM = dayn(EXPDAT)
  While EXPNAM <> 7
    EXPDAT = EXPDAT -1
    EXPNAM = dayn(EXPDAT)
  Wend

  [M:DCG1]SMPEXPCON = EXPDAT : Affzo [M:DCG1]SMPEXPCON

Return

$SMP_LATEST_RETURN_DATE
Local Integer SMP_MAX_LW
Local Date LATDAT

  # SMP_MAX_LW = SMP Max Leave Weeks
  # VALEUR = SMP Leave date
  # SMP_MAX_LW = 52

  SMP_MAX_LW = int(func SUBDCGUKI.SETVARIABLE("SMP_MAX_LW",[M:DCG1]STRDAT(DCGUKINBLIG)))*7
  #TODO
  LATDAT = VALEUR + SMP_MAX_LW

  [M:DCG1]SMPLATRET = LATDAT : Affzo [M:DCG1]SMPLATRET

  If VALEUR < [M:DCG1]SMPQUADAT
    [M:DCG1]SMPELI = 1
    Affzo [M:DCG1]SMPELI
    #[M:DCG1]SSPSTA(DCGUKINBLIG) = 1
    #Affzo [M:DCG1]SSPSTA(DCGUKINBLIG)
    #[M:DCG1]SMPREA = mess(4,11828,1)
    #[M:DCG1]SMPREA = 4
    #ANCOA 07/11/2017 - X3-60674 - START
    Affzo [M:DCG1]SMPREA, ZSMPREA
    #ANCOA 07/11/2017 - X3-60674 - END
  Endif

Return

$EARLIEST_RETURN
Local Integer SMP_DTERD
Local Date EARDAT

  #VALEUR = Actual date of birth
  #SMP_DTERD = SMP Days to earliest return date
  #SMP_DTERD = 14
  SMP_DTERD =  int(func SUBDCGUKI.SETVARIABLE("SMP_DTERD",[M:DCG1]STRDAT(DCGUKINBLIG)))
  EARDAT = VALEUR + SMP_DTERD
  [M:DCG1]SMPEARDAT = EARDAT : Affzo [M:DCG1]SMPEARDAT

Return

Funprog SMP_SPLIT(DCG_ID, SUB_TYPE)
Value Integer DCG_ID
Value Char SUB_TYPE
Local Decimal RESULT_STAT
Local Integer SUB_TYPE_INDEX

  RESULT_STAT=1 #initialize to correct
  If clalev([F:DCG_T])=0      : Local File DEMCONGE    [DCG_T] : Endif

  #get entry of absense record
  Read [F:DCG_T]DCG2 = DCG_ID
  If fstat
    [L]RESULT_STAT=0
    End [L]RESULT_STAT
  Endif

  #check if sub type exist on entry and get index
  [L]SUB_TYPE_INDEX=find(SUB_TYPE,[F:DCG_T]LVESUBTYP(0..(dim([F:DCG_T]LVESUBTYP)-1)))
  If [L]SUB_TYPE_INDEX=0
    End [L]RESULT_STAT
  Endif

  Local Integer A : A=0
    If [F:DCG_T]LVESUBBAL([L]SUB_TYPE_INDEX-1) <> 0
      If [M:DCG1]SMPPRO = 1
        [F:DCG_T]LVESUBRAT([L]SUB_TYPE_INDEX-1)=2
        Assign "[M:DCG1]LVESUBRAT" + num$([L]SUB_TYPE_INDEX-1) + "(" + num$(GPARENT_NOLIGN) + ")" With 2
      Else
        [F:DCG_T]LVESUBRAT([L]SUB_TYPE_INDEX-1)=1
        Assign "[M:DCG1]LVESUBRAT" + num$([L]SUB_TYPE_INDEX-1) + "(" + num$(GPARENT_NOLIGN) + ")" With 1
      Endif
    Endif

    Rewrite [F:DCG_T]
    If fstat
      [L]RESULT_STAT=0
      End [L]RESULT_STAT
    Endif

End RESULT_STAT

$CLR_MSK_SMP

  If dim([M:DCG1]SXPCAT)>0    : Effzo [M:DCG1]SXPCAT     : Endif
  If dim([M:DCG1]SMPEVIREC)>0 : Effzo [M:DCG1]SMPEVIREC  : Endif
  If dim([M:DCG1]SMPCAL)>0    : Effzo [M:DCG1]SMPCAL     : Endif
  If dim([M:DCG1]SMPLEADAT)>0 : Effzo [M:DCG1]SMPLEADAT  : Endif
  If dim([M:DCG1]SMPEXC)>0    : Effzo [M:DCG1]SMPEXC     : Endif
  If dim([M:DCG1]SMPACTDOB)>0 : Effzo [M:DCG1]SMPACTDOB  : Endif
  If dim([M:DCG1]SMPEXPDOB)>0 : Effzo [M:DCG1]SMPEXPDOB  : Endif
  If dim([M:DCG1]SMPEARDAT)>0 : Effzo [M:DCG1]SMPEARDAT  : Endif
  If dim([M:DCG1]DISEARDAT)>0 : Effzo [M:DCG1]DISEARDAT  : Endif
  If dim([M:DCG1]SMPRETDAT)>0 : Effzo [M:DCG1]SMPRETDAT  : Endif
  If dim([M:DCG1]SMPQUADAT)>0 : Effzo [M:DCG1]SMPQUADAT  : Endif
  If dim([M:DCG1]SMPEMPDAT)>0 : Effzo [M:DCG1]SMPEMPDAT  : Endif
  If dim([M:DCG1]SMPEMPDAT)>0 : Effzo [M:DCG1]SMPEMPDAT  : Endif
  If dim([M:DCG1]SMPPRPSTR)>0 : Effzo [M:DCG1]SMPPRPSTR  : Endif
  If dim([M:DCG1]SMPPRPEND)>0 : Effzo [M:DCG1]SMPPRPEND  : Endif
  If dim([M:DCG1]SMPWEEPER)>0 : Effzo [M:DCG1]SMPWEEPER  : Endif
  If dim([M:DCG1]SMPEARLEA)>0 : Effzo [M:DCG1]SMPEARLEA  : Endif
  If dim([M:DCG1]SMPLATRET)>0 : Effzo [M:DCG1]SMPLATRET  : Endif
  If dim([M:DCG1]SMPELI)>0    : Effzo [M:DCG1]SMPELI     : Endif
  If dim([M:DCG1]SMPREA)>0    : Effzo [M:DCG1]SMPREA     : Endif
  If dim([M:DCG1]SMPPRO)>0    : Effzo [M:DCG1]SMPPRO     : Endif
  If dim([M:DCG1]SMPEXPCON)>0 : Effzo [M:DCG1]SMPEXPCON  : Endif
  If dim([M:DCG1]SMPPRPDIS)>0 : Effzo [M:DCG1]SMPPRPDIS  : Endif
  If dim([M:DCG1]KITDAT)>0    : Effzo [M:DCG1]KITDAT     : Endif
  If dim([M:DCG1]NBKIT)>0     : Effzo [M:DCG1]NBKIT      : Endif
  If dim([M:DCG1]NBPAY)>0     : Effzo [M:DCG1]NBPAY      : Endif
  If dim([M:DCG1]SMPAWE)>0    : Effzo [M:DCG1]SMPAWE     : Endif

  If dim([M:DCG1]SMPWEKSTR)>0 : Effzo [M:DCG1]SMPWEKSTR  : Endif
  If dim([M:DCG1]SMPTAXYEA)>0 : Effzo [M:DCG1]SMPTAXYEA  : Endif
  If dim([M:DCG1]SMPTAXPER)>0 : Effzo [M:DCG1]SMPTAXPER  : Endif
  If dim([M:DCG1]SMPFREQUE)>0 : Effzo [M:DCG1]SMPFREQUE  : Endif
  If dim([M:DCG1]SMPRAT)>0    : Effzo [M:DCG1]SMPRAT     : Endif
  If dim([M:DCG1]SMPAMT)>0    : Effzo [M:DCG1]SMPAMT     : Endif
  If dim([M:DCG1]SMPPAI)>0    : Effzo [M:DCG1]SMPPAI     : Endif


Return

