#<AdxTL>@(#)0.0.0.0 $Revision$ Déclaration Belge - Listing an
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","DCLCUSVATBEL","DCLCUSVATBEL",4,"XYDCLCUSVATBEL") From GTRAITE
End

$ACTION
Case ACTION
  When "OUVRE_BATCH" : Gosub OUVRE_BATCH

  When "INIT"        : Gosub INIT
  When "CONTROLE"    : Gosub CONTROLE
  When "EXEC"        : Gosub EXEC
  When "TERMINE"     : Gosub TERMINE
  When "SORTIE"      : Gosub SORTIE
  When "DEBUT"       : Gosub DEBUT
  When "OK"          : FIN = 1 : GOK = 1
  When "END"         : FIN = 1 : GOK = 0
Endcase
Return

$INIT
Gosub OPEN_FIL
Gosub DECLARE
Local Mask DCLCUSVATBEL [DIA]
Raz [M:DIA]
Call INI
Call LECMEMO("STD","[M:DIA]","dclcusbel") From GMEMO
Return

$OPEN_FIL
If !clalev([F:DLCB])   : Local File DCLCUSVATBE   [DLCB]   : Endif
If !clalev([F:DLCB1])  : Local File DCLCUSVATBE   [DLCB1]  : Endif
If !clalev([F:DLCBD])  : Local File DCLCUSVATBED  [DLCBD]  : Endif
If !clalev([F:DLCD1])  : Local File DCLCUSVATBED  [DLCBD1] : Endif
If !clalev([F:CPY])    : Local File COMPANY       [CPY]    : Endif
If !clalev([F:FCY])    : Local File FACILITY      [FCY]    : Endif
If !clalev([F:TCA])    : Local File TABCOUAFF     [TCA]    : Endif
If !clalev([F:GTE])    : Local File GTYPACCENT    [GTE]    : Endif
If !clalev([F:TVT])    : Local File TABVAT        [TVT]    : Endif
If !clalev([F:TVB])    : Local File TABVACBPR     [TVB]    : Endif
If !clalev([F:TRA])    : Local File TABRATVAT     [TRA]    : Endif
If !clalev([F:TCU])    : Local File TABCUR        [TCU]    : Endif
If !clalev([F:HAE])    : Local File GACCENTRY     [HAE]    : Endif
If !clalev([F:DAE])    : Local File GACCENTRYD    [DAE]    : Endif
If !clalev([F:SIH])    : Local File SINVOICE      [SIH]    : Endif
If !clalev([F:SIV])    : Local File SINVOICEV     [SIV]    : Endif
If !clalev([F:GAC])    : Local File GACCOUNT      [GAC]    : Endif
If !clalev([F:BPR])    : Local File BPARTNER      [BPR]    : Endif
If !clalev([F:BPC])    : Local File BPCUSTOMER    [BPC]    : Endif
If !clalev([F:BPA])    : Local File BPADDRESS     [BPA]    : Endif

If clalev([F:AOE])=0  : Local File AOBJEXT     [AOE]  : Endif
If clalev([F:AOD])=0  : Local File AOBJEXTD    [AOD]  : Endif
If clalev([F:AOR])=0  : Local File AOBJEXTR    [AOR]  : Endif
If clalev([F:ATB])=0  : Local File ATABLE      [ATB]  : Endif
If clalev([M:AOE0])=0 : Local Mask AOE0        [AOE0] : Endif
If clalev([M:AOE1])=0 : Local Mask AOE1        [AOE1] : Endif
If clalev([M:AOE2])=0 : Local Mask AOE2        [AOE2] : Endif
If clalev([M:EXP1])=0 : Local Mask EXPOBJ      [EXP1] : Endif : # to load the template
If clalev([M:EXP2])=0 : Local Mask EXPOBJ2     [EXP2] : Endif : # Ecran référence (export + export enchaîné)
Return

$DECLARE
Local Integer  I, STAT
Local Char     VALPAR(GLONADW)            : # To store the value of a parameter
Local Char     NUMIMP(8)                  : # Request number
Local Char     COMPTEUR(GLONANM)          : # Counter that assigns the request number
Local Integer  OKTCA
Global Integer GNUMRPT                    : # Request number used to print
#
Local Integer  NBTAX                      : # Number of tax codes defined with tax/debits
Filter [TVT] Where VATPAY=1 & VATTYP=1
NBTAX = rowcount([F:TVT])
Filter [TVT]
Local Char     TTAX(GLONVAT)(1..NBTAX)    : # List of the tax codes used when the tax is due /debits
#
Local Integer  NBTYP                      : # Number of document types (GTE) defined with tax/debits
Filter [GTE] Where VAT=2
NBTYP = rowcount([F:GTE])
Filter [GTE]
Local Char     TTYP(GLONGTE)(1..NBTYP)    : # List of of document types (GTE) defined with tax/debits
#
Local Char     OPT(1)                     : # Take into account the "1"=accounting date or "2"=source document date
Local Char     FILT(250),SPE_CRITERE(250) : # Criteria
Local Char     MESSAGE(250)               : # error message in case export fails
Local Integer  SAVGPARTRABTC              : # The value of the GPARTRABTC parameter is saved

# Declaration of Variables to Handle Loops Ruptures  (avoid the "snapshot" too old)
Local Integer STOP, NB
Local Char    FILTBPC(250), FILTFCY(250)
Local Char    SAVE_BPC(GLONBPC), SAVE_FCY(GLONFCY)
Local Char    AKEY(GLONBPR)
Local Date    DKEY
Local Integer IKEY

#  Declaration of Variables to write Header table
Local Integer MAXEEC : MAXEEC = 10000
Local Integer NBEEC, IEEC
Local Char    EEC(GLONEEC)(1..MAXEEC)
Local Decimal EECMTHT(1..MAXEEC)
Local Decimal EECMTTVA(1..MAXEEC)
Local Integer EECINVTYP(1..MAXEEC)
Local Integer EECTSD(1..MAXEEC)
Local Char    EECBPRNAM1(GLONNAM)(1..MAXEEC)
Local Char    EECBPRNAM2(GLONNAM)(1..MAXEEC)

# Miscellaneous variables
Local Char    BPC_TSD(GLONBPC)
Local Char    EECNUM_LIN(GLONEEC)
Local Decimal VTRAT
Local Integer TRACE_BPC
Local Integer TRACE_FCY
Local Char    BPRNAM1(GLONNAM)
Local Char    BPRNAM2(GLONNAM)

Return

######################################################################################
$DEBUT
Affzo [DIA]
If GBATCH : Call INI : Endif
Call GRISE
Setmok [DIA] With 0
Return

######################################################################################
$CONTROLE
If GOK<1 : FIN = 1 : Return : Endif

If GSERVEUR
 GSOCIETE = [M:DIA]CPY
 Call LEC_CPY([M:DIA]CPY) From CPTLEC
 GCURLEG = [F:CPY]LEG
 Call SETCUR(1,GSOCIETE,GLOCALDEV)From CPTDIV
Endif

Lock ="DCLCUSVATBEL\"+GSOCIETE With lockwait=0
If fstat
 GERR = 2 : GMESSAGE=mess(30,100,1)
 FIN = 1 : Return
Endif

Gosub READ_PARAM
If FIN=1 : Return : Endif

TMP = 1
Gosub TRABTC
Return

$TRABTC
# To not display the log file "MASQUE_TRACE" managed by the supervisor in GTRAITE
If GSERVEUR=1 & dim(GPARTRABTC)>0
 SAVGPARTRABTC = GPARTRABTC
 GPARTRABTC = 1
Endif
Return

######################################################################################
$READ_PARAM
# Request number
COMPTEUR = ""
Call LECTCA(2,OKTCA)From SUBTCA
If OKTCA : COMPTEUR= [F:TCA]CODNUM(16) : Endif
If COMPTEUR="" : COMPTEUR = "LISCS" : Endif
Call NUMERO(COMPTEUR,"",[0/0/0],"",NUMIMP,STAT) From SUBANM
If STAT
 Gosub MESSAGE From SUBANM
 Call ERREUR(mess(60,199,1)-"("+COMPTEUR+") : "-MESSA) From GESECRAN
 FIN = 1 : Return
Endif
GNUMRPT = val(NUMIMP)

Gosub LECPARAM_GTE
Gosub LECPARAM_TVT
Return

#############################################################################
$LECPARAM_GTE
# Load the list of the  document types (GTE) defined with tax on issue
Filter [GTE] Where LEG=GCURLEG | LEG="" Order By Key CLE=TYP Asc ; LEG Desc
Raz NBTYP, TTYP
For [GTE]CLE(1)
 If [F:GTE]VAT = 2
  NBTYP += 1
  TTYP(NBTYP) = [F:GTE]TYP
 Endif
Next
Filter [GTE]
Return

$LECPARAM_TVT
Call PARAML(GSOCIETE,"DEPEXETAX", VALPAR) From ADOVAL
# Load the list of the tax code used when the tax is due as soon as the invoice is issued
Filter [TVT] Where LEG=GCURLEG | LEG="" Order By Key CLE=VAT Asc ; LEG Desc
Raz NBTAX, TTAX
For [TVT]CLE(1)
 If [F:TVT]VATPAY = 1 & [F:TVT]VATTYP = 1 & [F:TVT]VAT<>VALPAR
  NBTAX += 1
  TTAX(NBTAX) = [F:TVT]VAT
 Endif
Next
Filter [TVT]
Return

######################################################################################
$EXEC
If GSERVEUR
 [M:DIA]TRCFLG = 2
 If dim(GPARTRABTC)>0
  GPARTRABTC = SAVGPARTRABTC
 Endif
Endif
If !GSERVEUR & [M:DIA]TRCFLG=2
 Call OUVRE_TRACE(mess(17,866,1)) From LECFIC
Endif
If [M:DIA]TRCFLG=2
 Call ECR_TRACE(mess(17,866,1),0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 ## Display the criteria in the log file
 Call ECR_TRACE(mess(14,103,1)-":",0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Call ECR_TRACE(mess(26,113,1)-":"-GSOCIETE,0) From GESECRAN
 Call ECR_TRACE(mess(38,114,1)-":"-num$(GNUMRPT),0) From GESECRAN
 Call ECR_TRACE(mess(14,119,1)-":"-format$(GFMDAT,[M:DIA]STRDAT)-mess(95,100,1)-format$(GFMDAT,[M:DIA]ENDDAT),0) From GESECRAN
 Call ECR_TRACE(mess(1,274,1)-":"-num$([M:DIA]TSD)-[M:DIA]CURLED,0) From GESECRAN
 Call ECR_TRACE(mess(55,100,1)-":"-mess([M:DIA]FLGFIL,1,1),0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

# Delete in the tables
Call DEBTRANS From GLOCK
Gosub TR_DELDLV
If GOK<1 : Return : Endif
# Run the declaration
Gosub DECLARATION

If GOK<1
 # If one error occurs in an actual declaration, all the records saved for the request in the DCLCUSVATBEL* tables must be deleted
 Call DEBTRANS From GLOCK
 Gosub TR_DELRQT
 If GOK<1 : Goto F_END : Endif
Endif

If GOK=1 & [M:DIA]FLGFIL=2
 # File generation
 # S'il n'y a pas de clients à lister, on crée quand même un enregistrement
 # dans les fichiers temporaires afin de pouvoir afficher les
 # critères sélectionnés (notamment dans une réimpression)
 Call PARAML(GSOCIETE, "BELCUSAOE", VALPAR) From ADOVAL
 If VALPAR=""
  Call ECR_TRACE("BELCUSAOE :"-mess(171,133,1),1) From GESECRAN
 Else
  Raz [M:EXP2]NOMEXP
  [M:EXP2] = [M:DIA]

  If [M:EXP2]TYPEXP=2
   [M:EXP2]NOMEXP = [M:DIA]FILDIRLOC
   If right$([M:EXP2]NOMEXP, len([M:EXP2]NOMEXP))<>"/" : [M:EXP2]NOMEXP += "/" : Endif
  Endif
  [M:EXP2]NOMEXP += "BEASSUJ_" + num$(GNUMRPT) + "_" + format$("DDMMYY",[M:DIA]STRDAT) + "-" + format$("DDMMYY",[M:DIA]ENDDAT)
  [M:EXP2]MODELE = VALPAR
  Filter [DLCB] Where NUMRPT = GNUMRPT
  If rowcount([DLCB])=0
   Call ECR_TRACE("0"-mess(82,141,1), 0) From GESECRAN
  Else
   Call EXPORTSIL From GEXPOBJ
   If [M:EXP2]STAT=0 and !GSERVEUR
    If [M:DIA]TYPEXP=1
     Call ECR_TRACE(mess(178,115,1)-[M:EXP2]NOMEXP, 0) From GESECRAN
    Else
     Call ECR_TRACE("|"+mess(14,9003,1)-[M:EXP2]NOMEXP, 0) From GESECRAN
    Endif
   Endif
  Endif
  Filter [DLCB]
 Endif
Endif

$F_END
If !GSERVEUR & [M:DIA]TRCFLG=2
 Call FERME_TRACE From LECFIC
Endif
Return

######################################################################################
# We begin to delete the simulations that matches the execution criteria
$TR_DELDLV
GOK = 1
Trbegin [DLCB],[DLCBD]

# Delete the company
Filter [DLCBD1] Where CPY=GSOCIETE & ACCDAT>=[M:DIA]STRDAT & ACCDAT<=[M:DIA]ENDDAT
For [DLCBD1]DLCBD0(2)
 Delete [DLCB] Where NUMRPT=[F:DLCBD1]NUMRPT
 If fstat=1 | fstat>5
  GOK = 0 : Call RSTA("DLCB",GSOCIETE-num$([F:DLCBD1]NUMRPT)) From GLOCK : Break
 Endif
 Delete [DLCBD] Where NUMRPT=[F:DLCBD1]NUMRPT
 If fstat=1 | fstat>5
  GOK = 0 : Call RSTA("DLCBD",GSOCIETE-num$([F:DLCBD1]NUMRPT)) From GLOCK : Break
 Endif
Next
If GOK<1 : Goto AB_TR_DELDLV : Endif

Commit
Return

$AB_TR_DELDLV
Rollback
Return

######################################################################################
$TR_DELRQT
Trbegin [DLCB],[DLCBD]
 Delete [DLCB] Where NUMRPT=GNUMRPT
 If fstat=1 | fstat>5
  GOK = 0 : Call RSTA("DLCB",num$(GNUMRPT)) From GLOCK : Goto AB_TR_DELDLV
 Endif
 Delete [DLCBD] Where NUMRPT=GNUMRPT
 If fstat=1 | fstat>5
  GOK = 0 : Call RSTA("DLCBD",num$(GNUMRPT)) From GLOCK : Goto AB_TR_DELDLV
 Endif
Commit
Return

######################################################################################
$DECLARATION

# Point d'entrée FILTRE_FCY
Raz [L]SPE_CRITERE
GPOINT = "FILTER_FCY" : Gosub ENTREE From EXEFNC
If [L]SPE_CRITERE="" : [L]SPE_CRITERE="1=1" : Endif

# Accounting date or  source document date ?
Call PARAML(GSOCIETE,"DCLVATDAT",OPT) From ADOVAL

# Customers who are "Subject to tax"
Link [BPC] With [F:BPR]BPR0~=[F:BPC]BPCNUM , [F:BPA]BPA0="1";[F:BPC]BPCNUM;[F:BPC]BPAADD
& As [LNK_B]
& Where [F:BPC]BELVATSUB=2

Raz [L]SAVE_BPC, [L]SAVE_FCY
Raz [L]AKEY, [L]DKEY, [L]IKEY
Raz [L]BPC_TSD, [L]TRACE_BPC, [L]TRACE_FCY

$LOOP_01
Raz NB

Call DEBTRANS From GLOCK
Trbegin [F:DLCB],[F:DLCBD]

If [L]BPC_TSD<>""
 # Next Customer, Raz Loop variables
 FILTBPC = "[F:BPC]BPCNUM>'"+[L]BPC_TSD+"'"
 Raz [L]BPC_TSD, [L]SAVE_FCY
 Raz [L]STOP
Elsif SAVE_BPC<>""
 FILTBPC = "[F:BPC]BPCNUM>='"+SAVE_BPC+"'"
Else
 FILTBPC="1=1"
Endif

If SAVE_FCY<>"" : FILTFCY = "[F:FCY]FCY>='"+SAVE_FCY+"'"    : Else  FILTFCY="1=1" : Endif

For [LNK_B]BPC0 Where evalue(FILTBPC)

 For [FCY]FCY1 Where LEGCPY=GSOCIETE & FINFLG=2 & evalue(SPE_CRITERE) & evalue(FILTFCY)
  Call CONTFCY([F:FCY]FCY) From CPTSUB
  If mkstat
   Raz GMESSAGE, mkstat
   If [M:DIA]TRCFLG=2 & ![L]TRACE_FCY : Call ECR_TRACE([F:FCY]FCY-":"-mess(63,133,1)-":"-mess(805,197,1),0) From GESECRAN : Endif
  Else
   Gosub TR_DCLCUSVAT
   If GOK<1 or STOP : Break 2 : Endif
  Endif
 Next
 [L]TRACE_FCY = 1

 # Save for the customer in the DCLCUSVATBE (Header table)
 # or Delete for the customer in the DCLCUSVATBED (Line table)
 For I=1 To [L]NBEEC
  If [M:DIA]TRCFLG=2 & ![L]TRACE_BPC : Call ECR_TRACE(mess(358,107,1)-[F:BPC]BPCNUM,0) From GESECRAN : [L]TRACE_BPC=1 : Endif
  If [L]EECMTHT(I)>=[M:DIA]TSD
   Gosub UPD_DCLCUSVATBE
   If GOK<1 : Break : Endif
  Else
   If [L]EECINVTYP(I)>0 & [M:DIA]TRCFLG=2
    # Message E
    Call ECR_TRACE(mess(78,117,1)-[F:BPC]BPCNUM-"("+[L]EEC(I)+"):"-mess(373,107,1),1) From GESECRAN
   Endif
   If ![L]EECINVTYP(I)
    [L]EECTSD(I) = 1
    [L]BPC_TSD = [F:BPC]BPCNUM
   Endif
  Endif
 Next

 If [L]BPC_TSD<>""
  If adxtrans : Commit : Endif
  Gosub TR_DELBPC
  If !GOK: Break : Endif
  Gosub RAZ_BPC
  STOP = 1 : Break
 Else
  Gosub RAZ_BPC
 Endif

Next
If GOK<=0 : Goto AB_TR_DLV : Endif
If adxtrans : Commit : Endif

If STOP
 SAVE_BPC = [F:BPC]BPCNUM
 SAVE_FCY = [F:FCY]FCY
 Goto LOOP_01
Endif
Return

$AB_TR_DLV
Rollback
Return

$RAZ_BPC
Raz [L]TRACE_BPC
Raz [L]NBEEC
Raz [L]EEC
Raz [L]EECMTHT
Raz [L]EECMTTVA
Raz [L]EECINVTYP
Raz [L]EECTSD
Return

######################################################################################
$TR_DELBPC
Trbegin [DLCBD]
  For I=1 To [L]NBEEC
   If [L]EECTSD(I)=1
    Delete [DLCBD] Where NUMRPT=GNUMRPT & BPR=[L]BPC_TSD & EECNUM=[L]EEC(I)
    If fstat=1 | fstat>5
     GOK = 0 : Call RSTA("DLCBD",num$(GNUMRPT)-[L]BPC_TSD-[L]EEC(I)) From GLOCK : Break
    Endif
   Endif
  Next
  If !GOK : Return : Endif
Commit
Return

######################################################################################
$TR_DCLCUSVAT
# Loop Key DAE5 : CPY+FCYLIN+LEDTYP+BPR+ACCDAT+ACCNUM
If STOP = 1
 STOP = 2
 FILT = "[F:DAE]CPY='"+GSOCIETE+"' & [F:DAE]FCYLIN='"+[F:FCY]FCY+"' & [F:DAE]LEDTYP="+num$(GTYPGEN)+
&          " & [F:DAE]BPR='"+AKEY+"' & [F:DAE]ACCDAT=["+format$(GFMD,DKEY)+"] & [F:DAE]ACCNUM>"+num$(IKEY)
Elsif STOP = 2
 STOP = 3
 FILT = "[F:DAE]CPY='"+GSOCIETE+"' & [F:DAE]FCYLIN='"+[F:FCY]FCY+"' & [F:DAE]LEDTYP="+num$(GTYPGEN)+
&          " & [F:DAE]BPR='"+AKEY+"' & [F:DAE]ACCDAT>["+format$(GFMD,DKEY)+"]"
Elsif STOP = 3
 STOP = 0
 FILT = "[F:DAE]CPY='"+GSOCIETE+"' & [F:DAE]FCYLIN='"+[F:FCY]FCY+"' & [F:DAE]LEDTYP="+num$(GTYPGEN)+
&          " & [F:DAE]BPR>'"+AKEY+"'"
Else
 FILT = "[F:DAE]CPY='"+GSOCIETE+"' & [F:DAE]FCYLIN='"+[F:FCY]FCY+"' & [F:DAE]LEDTYP="+num$(GTYPGEN)
Endif

If NBTYP+NBTAX<=50
 If OPT = "1"
  Link [DAE] With [HAE]HAE0~=[F:DAE]TYP;[F:DAE]NUM , [GAC]GAC0~=[F:DAE]COA;[F:DAE]ACC , [SIH]SIH0~=[F:DAE]NUM,
&  [SIV]SIV0=[F:DAE]NUM
&  As [LNK_E]
&  Where evalue(FILT) & find([DAE]TYP,TTYP(1..NBTYP))<>0
&&       [DAE]ACCDAT>=[M:DIA]STRDAT & [DAE]ACCDAT<=[M:DIA]ENDDAT
&&       find([F:DAE]TAX,TTAX(1..NBTAX))<>0
&&       [SIH]BPR=[F:BPC]BPCNUM
&&       [HAE]CAT=1
&    Order By Key DAE5
 Else
   Link [DAE] With [HAE]HAE0~=[F:DAE]TYP;[F:DAE]NUM , [GAC]GAC0~=[F:DAE]COA;[F:DAE]ACC , [SIH]SIH0~=[F:DAE]NUM,
&  [SIV]SIV0=[F:DAE]NUM
&  As [LNK_E]
&  Where evalue(FILT) & find([DAE]TYP,TTYP(1..NBTYP))<>0
&&       (([HAE]BPRDATVCR>=[M:DIA]STRDAT & [HAE]BPRDATVCR<=[M:DIA]ENDDAT) | ([HAE]BPRDATVCR=[0/0/0] & [DAE]ACCDAT>=[M:DIA]STRDAT & [DAE]ACCDAT<=[M:DIA]ENDDAT))
&&       find([F:DAE]TAX,TTAX(1..NBTAX))<>0
&&       [SIH]BPR=[F:BPC]BPCNUM
&&       [HAE]CAT=1
&    Order By Key DAE5
 Endif

Else

 If OPT = "1"
  Link [DAE] With [HAE]HAE0~=[F:DAE]TYP;[F:DAE]NUM , [GAC]GAC0~=[F:DAE]COA;[F:DAE]ACC , [SIH]SIH0~=[F:DAE]NUM,
&  [SIV]SIV0=[F:DAE]NUM
&  As [LNK_E]
&  Where evalue(FILT) & find([DAE]TYP,TTYP(1..NBTYP))
&&       [DAE]ACCDAT>=[M:DIA]STRDAT & [DAE]ACCDAT<=[M:DIA]ENDDAT
&&       find([F:DAE]TAX,TTAX(1..NBTAX))
&&       [SIH]BPR=[F:BPC]BPCNUM
&&       [HAE]CAT=1
&   Order By Key DAE5
 Else
   Link [DAE] With [HAE]HAE0~=[F:DAE]TYP;[F:DAE]NUM , [GAC]GAC0~=[F:DAE]COA;[F:DAE]ACC , [SIH]SIH0~=[F:DAE]NUM,
&  [SIV]SIV0=[F:DAE]NUM
&  As [LNK_E]
&  Where evalue(FILT) & find([DAE]TYP,TTYP(1..NBTYP))
&&       (([HAE]BPRDATVCR>=[M:DIA]STRDAT & [HAE]BPRDATVCR<=[M:DIA]ENDDAT) | ([HAE]BPRDATVCR=[0/0/0] & [DAE]ACCDAT>=[M:DIA]STRDAT & [DAE]ACCDAT<=[M:DIA]ENDDAT))
&&       find([F:DAE]TAX,TTAX(1..NBTAX))
&&       [SIH]BPR=[F:BPC]BPCNUM
&&       [HAE]CAT=1
&    Order By Key DAE5
 Endif
Endif

Gosub TR_DLV
If GOK<1 : Return : Endif
Return

######################################################################################
$TR_DLV
For [LNK_E]
 If ![L]TRACE_BPC & [M:DIA]TRCFLG=2 : Call ECR_TRACE (mess(358,107,1)-[F:BPC]BPCNUM,0) From GESECRAN : [L]TRACE_BPC=1 : Endif
 CTL_OK = 0
 Case [F:HAE]ORIMOD
  When 3
   If [F:BPR]EECNUM="" or ( [F:BPR]EECNUM<>"" &  left$([F:BPR]EECNUM,2)="BE")
    If [F:BPR]CRY="BE"
     Call LEC_TVT_LEG(GCURLEG,[F:DAE]TAX) From CPTLEC
     Call LEC_TVB(GCURLEG,[F:TVT]VATVAC) From CPTLEC
     If [F:TVB]REGVAC = 1 : CTL_OK=1 : Endif
     If [F:TVB]REGVAC = 4 : CTL_OK=1 : Gosub ECR_TRACE_D : Endif
    Endif
    [L]EECNUM_LIN = [F:BPR]EECNUM
    [L]BPRNAM1    = [F:BPR]BPRNAM(0)
    [L]BPRNAM2    = [F:BPR]BPRNAM(1)
   Endif
  When 5
   If [F:SIV]BPIEECNUM="" or ( [F:SIV]BPIEECNUM<>"" &  left$([F:SIV]BPIEECNUM,2)="BE")
    If [F:SIV]BPDCRY="BE"
     Call LEC_TVT_LEG(GCURLEG,[F:DAE]TAX) From CPTLEC
     Call LEC_TVB(GCURLEG,[F:TVT]VATVAC) From CPTLEC
     If [F:TVB]REGVAC = 1 : CTL_OK=1 : Endif
     If [F:TVB]REGVAC = 4 : CTL_OK=1 : Gosub ECR_TRACE_D : Endif
    Endif
    [L]EECNUM_LIN = [F:SIV]BPIEECNUM
    [L]BPRNAM1    = [F:SIH]BPRNAM(0)
    [L]BPRNAM2    = [F:SIH]BPRNAM(1)
   Endif
 Endcase

 If CTL_OK
  Gosub UPD_DCLCUSVATBED
  If GOK<1 : Break 1 : Endif

  NB+=1
  If NB>GMAXUPDTRS
   AKEY= [F:DAE]BPR
   DKEY= [F:DAE]ACCDAT
   IKEY= [F:DAE]ACCNUM
   STOP=1
   Break
  Endif
 Endif
Next
Return

######################################################################################
$UPD_DCLCUSVATBED

If find([F:GAC]VATIPT,1,2,7,8)<>0 & find([F:GAC]FLGVAT,2,3)<>0

 Raz [F:DLCBD]
 [F:DLCBD]CPY    = GSOCIETE
 [F:DLCBD]NUMRPT = GNUMRPT
 [F:DLCBD]BPR    = [F:BPR]BPRNUM

 If [L]EECNUM_LIN<>""
  [F:DLCBD]EECNUM =  [L]EECNUM_LIN
 Else
  [F:DLCBD]EECNUM =  "XXXXX"
 Endif

 [F:DLCBD]TYP       = [F:DAE]TYP
 [F:DLCBD]NUM       = [F:DAE]NUM
 [F:DLCBD]LIN       = [F:DAE]LIN
 [F:DLCBD]BPRNAM(0) = [L]BPRNAM1
 [F:DLCBD]BPRNAM(1) = [L]BPRNAM2
 If OPT="1" or (OPT="2" & [F:HAE]BPRDATVCR=[0/0/0])
  [F:DLCBD]ACCDAT = [F:HAE]ACCDAT
 Else
  [F:DLCBD]ACCDAT = [F:HAE]BPRDATVCR
 Endif
 [F:DLCBD]CUR    = GLOCALDEV

 Case [F:GAC]FLGVAT
  When 2 : # Compte soumis à TVA (base)
   [F:DLCBD]AMTNOT += [F:DAE]AMTLED*[F:DAE]SNS*-1
  When 3 : # Compte de TVA (montant)
   [F:DLCBD]AMTVAT += [F:DAE]AMTLED*[F:DAE]SNS*-1
 Endcase

 [F:DLCBD]VAT    = [F:DAE]TAX
 Gosub LECTAXD   :# Search the tax rate
 [F:DLCBD]VATRAT = [L]VTRAT

 Write [DLCBD]
 If fstat
  GOK=0 : Call FSTA("DLCBD") From GLOCK : Return
 Endif

 IEEC = find([F:DLCBD]EECNUM,[L]EEC(1..[L]NBEEC))
 If !IEEC
  [L]NBEEC+=1
  [L]IEEC = [L]NBEEC
  [L]EEC(IEEC) = [F:DLCBD]EECNUM
 Endif
 Case [F:GAC]FLGVAT
  When 2 : # Compte soumis à TVA (base)
   [L]EECMTHT(IEEC) += [F:DAE]AMTLED*[F:DAE]SNS*-1
  When 3 : # Compte de TVA (montant)
   [L]EECMTTVA(IEEC) += [F:DAE]AMTLED*[F:DAE]SNS*-1
 Endcase
 If [L]EECINVTYP(IEEC)=0 & ([F:SIH]INVTYP=2 or [F:SIH]INVTYP=4)
  [L]EECINVTYP(IEEC)=1
 Endif

 If [F:BPC]BPCTYP=2
  [L]EECBPRNAM1(IEEC) = [L]BPRNAM1
  [L]EECBPRNAM2(IEEC) = [L]BPRNAM2
 Endif

Elsif [M:DIA]TRCFLG=2
 # Message B
 Call ECR_TRACE(func AFNC.MES1(mess(371,107,1),[F:DAE]ACC)-mess(12,107,1)-[F:DAE]TYP-[F:DAE]NUM-mess(136,105,1)-num$([F:DAE]LIN),1) From GESECRAN
Endif
Return

$ECR_TRACE_D
If [M:DIA]TRCFLG=2
 # Message D
 Call ECR_TRACE(mess(372,107,1)-mess(12,107,1)-[F:DAE]TYP-[F:DAE]NUM-mess(136,105,1)-num$([F:DAE]LIN)-"-"-
&               mess(39,105,1)-[F:DAE]TAX-"("+[F:TVT]VATVAC+")",0) From GESECRAN
Endif
Return

######################################################################################
$UPD_DCLCUSVATBE

 Raz [F:DLCB]
 [F:DLCB]CPY    = GSOCIETE
 [F:DLCB]NUMRPT = GNUMRPT
 [F:DLCB]BPR    = [F:BPR]BPRNUM
 [F:DLCB]EECNUM = [L]EEC(I)

 If [F:BPC]BPCTYP<>2
  [F:DLCB]BPRNAM(0) = [F:BPR]BPRNAM(0)
  [F:DLCB]BPRNAM(1) = [F:BPR]BPRNAM(1)
 Else
  [F:DLCB]BPRNAM(0) = [L]EECBPRNAM1(I)
  [F:DLCB]BPRNAM(1) = [L]EECBPRNAM2(I)
 Endif

 [F:DLCB]CRY       = [F:BPR]CRY
 [F:DLCB]TEL       = [F:BPA]TEL

 [F:DLCB]STRDAT = [M:DIA]STRDAT
 [F:DLCB]ENDDAT = [M:DIA]ENDDAT

 [F:DLCB]CUR     = GLOCALDEV
 [F:DLCB]AMTNOT  = [L]EECMTHT(I)
 [F:DLCB]AMTVAT  = [L]EECMTTVA(I)

 Write [F:DLCB]
 If fstat
  GOK=0 : Call FSTA("DLCB") From GLOCK
 Endif

Return

########################################################################################################
$LECTAXD
VTRAT = 0
Call LEC_TVT_LEG(GCURLEG,[F:DAE]TAX) From CPTLEC
Filter [F:TRA] Where VAT=[F:DAE]TAX & CPY=GSOCIETE & STRDAT<=[F:DAE]ACCDAT & LEG=[F:TVT]LEG
Read [F:TRA]TRA0 Last
If !fstat
 [L]VTRAT= [F:TRA]VATRAT
Else
 Filter [F:TRA] Where VAT=[F:DAE]TAX & CPY="" & STRDAT<=[F:DAE]ACCDAT & LEG=[F:TVT]LEG
 Read [F:TRA]TRA0 Last
 If !fstat
  [L]VTRAT= [F:TRA]VATRAT
 Endif
Endif
Filter [TRA]
Return

######################################################################################
$TERMINE
Local Integer NBPAR1
Local Char    TBPAR1(20)(1..10) , TBVAL1(50)(1..10)
Local Char    NAM_PRT(GLONADP)

# Print the report if the declaration is run in simulation mode or in actual mode and no error occurs
If GOK=1
 Call PARAML([M:DIA]CPY, "BELCUSTSD", VALPAR) From ADOVAL
 If GSERVEUR=1
  # Batch
  NBPAR1 = 0
  NBPAR1 +=1 : TBPAR1(NBPAR1) = "numrpt"        : TBVAL1(NBPAR1) = num$(GNUMRPT)
  NBPAR1 +=1 : TBPAR1(NBPAR1) = "impselections" : TBVAL1(NBPAR1) = num$(1)
  Call PARAML([M:DIA]CPY, "VATRPTBAT", NAM_PRT) From ADOVAL
  Call ETAT("DCLCUSVATBEL1", NAM_PRT, "", 0, "", TBPAR1, TBVAL1) From AIMP3
 Else
  Call IMPRIME("DCLCUSVATBEL1", "DCLCUSVATBEL") From ETAT
 Endif
Endif

# Logfile
If !GSERVEUR & [M:DIA]TRCFLG=2
 TRA = 1
Else
 TRA = 0
Endif
Return

######################################################################################
$SORTIE
If dim(GNUMRPT)>0 : Kill GNUMRPT : Endif
# Unlock
Unlock ="DCLCUSVATBEL\"+GSOCIETE
Return

#############################################################################
## BATCH
#############################################################################
$OUVRE_BATCH
Gosub OPEN_FIL
Gosub DECLARE
Return

######################################################################################
## DCLCUSVATBEL screen
######################################################################################
Subprog GRISE
Actzo [DIA]
If [M:DIA]FLGFIL=1
 Grizo [DIA]TYPEXP, VOLFIL
Else
 Actzo [DIA]TYPEXP
 If [M:DIA]TYPEXP = 1 : Grizo [DIA]VOLFIL : Else Actzo [DIA]VOLFIL : Endif
Endif
Affzo [M:DIA]
End

Subprog INI
[M:DIA]FLGFIL = 2 : # File generation
If GBATCH : [M:DIA]TYPEXP = 2 : Else  : [M:DIA]TYPEXP = 1 : Endif
[M:DIA]TRCFLG = 2 : # Trace
End

######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
Local Char    VALPAR(GLONADW)
Local Decimal TSD
Local Integer STAT

## Check that the BELVAT parameter is set to Yes
Call CTLCPYLEGVAT(VALEUR,"BEL") From DCLVATSTD
If mkstat=2 : End : Endif

## Check that the BELCUSTSD parameter is set
Call PARAML(VALEUR, "BELCUSTSD", VALPAR) From ADOVAL
If VALPAR=""
 GMESSAGE ="BELCUSTSD :"-mess(171,133,1)
 mkstat=2 : End
Endif

Call LEC_CPY(VALEUR) From CPTLEC
GSOCIETE = VALEUR
GCURLEG = [F:CPY]LEG
Call SETCUR(1,GSOCIETE,GLOCALDEV)From CPTDIV # Run Call SETMAINREF([F:CPY]CPY,GTYPGEN,GTYPANA) From CPTDIV

[L]TSD = val(VALPAR)
If GLOCALDEV<>GCURSHR
 Call CONVERT(GCURSHR,GLOCALDEV,GLOCALDEV,GTYPCURSHR,[M:DIA]ENDDAT,[L]TSD,[L]TSD,STAT) From TRTDEV
 If STAT
  GMESSAGE = mess(16,114,1)-GCURSHR-"->"-GLOCALDEV-"("+format$("D:"+GFMDAT,[M:DIA]ENDDAT)-")"
  mkstat = 2 : End
 Endif
Endif
[M]TSD    = [L]TSD    : Affzo [M]TSD
[M]CURLED = GLOCALDEV : Affzo [M]CURLED
End

######################################################################################
Subprog D_STRDAT(VALEUR)
Variable Date    VALEUR
VALEUR = gdat$(1,1,year(date$)-1)
End

Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
[M]STRDAT=gdat$(1,1,year(VALEUR))
[M]ENDDAT=gdat$(31,12,year(VALEUR))
Affzo [M]STRDAT
Affzo [M]ENDDAT
Gosub TSD
End

######################################################################################
Subprog D_ENDDAT(VALEUR)
Variable Date    VALEUR
VALEUR = gdat$(31,12,year(date$)-1)
End

Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
[M]STRDAT=gdat$(1,1,year(VALEUR))
[M]ENDDAT=gdat$(31,12,year(VALEUR))
Affzo [M]STRDAT
Affzo [M]ENDDAT
Gosub TSD
End

######################################################################################
$TSD
Local Char    VALPAR(GLONADW)
Local Decimal TSD
Local Integer STAT

If GLOCALDEV<>GCURSHR
 Call PARAML(GSOCIETE, "BELCUSTSD", VALPAR) From ADOVAL
 [L]TSD = val(VALPAR)
 Call CONVERT(GCURSHR,GLOCALDEV,GLOCALDEV,GTYPCURSHR,[M:DIA]ENDDAT,[L]TSD,[L]TSD,STAT) From TRTDEV
 If STAT
  GMESSAGE = mess(16,114,1)-GCURSHR-"->"-GLOCALDEV-"("+format$("D:"+GFMDAT,[M:DIA]ENDDAT)-")"
  mkstat = 2 : Return
 Endif
 [M]TSD    = [L]TSD    : Affzo [M]TSD
Endif
Return
######################################################################################
Subprog C_FLGFIL(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Actzo [M:DIA]TYPEXP
 If [M:DIA]TYPEXP=2
  Actzo [M:DIA]VOLFIL
 Else
  Effzo [M:DIA]VOLFIL
  Grizo [M:DIA]VOLFIL
 Endif
Else
 Effzo [M:DIA]VOLFIL
 Grizo [M:DIA]TYPEXP,VOLFIL
Endif
Affzo [M:DIA]TYPEXP,VOLFIL
End

######################################################################################
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : mkstat = 2 : End
Endif

If VALEUR<>2
 Effzo [M:DIA]VOLFIL
 Grizo [M:DIA]VOLFIL
Else
 Actzo [M:DIA]VOLFIL
Endif
Affzo [M:DIA]VOLFIL
End

######################################################################################
Subprog AS_VOLFIL(VALEUR)
Variable Char    VALEUR()
Local Char FILNAM(GDIMFIC)
If VALEUR=""
 Call PARAML(GSOCIETE,"BELCUSFIL",FILNAM) From ADOVAL
 If FILNAM=""
  VALEUR = "["+GDIRDEC+"]"
 Else
  VALEUR = FILNAM
 Endif
Endif
End

######################################################################################
Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FILDIRLOC,E_TYPE_FOLDER,GMESSAGE)
End

######################################################################################
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK
OK=1
If PARAM="BELCUSFIL" and VALEUR<>""
 Local Char TMP(250)
 Gosub ENUM_VOLFIL_TYPE From ASYRSTO
 If func ASYRSTO.CTL_VOLFIL(2,VALEUR,TMP,E_TYPE_FOLDER,GMESSAGE)<>0
  OK = 0 : End
 Endif
Endif
End

