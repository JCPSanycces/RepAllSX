#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  Case ACTION
    When "SEL_TABLE" : Gosub SEL_TABLE
  Endcase
Return

$SEL_TABLE
  Case TABLE
    When "SELINDREF"  : Gosub SELINDREF
    When "SELINDREFO" : Gosub SELINDREFO
  Endcase
Return


######################################################################################################
$SELINDREF

  Case PARAM(1)
    When "1" : CRITERE(1)="INDTYP=3 | INDTYP=4" #Indirect Only
    When "2" : CRITERE(1)="INDTYP<>2 & INDTYP<>5" #Non-break
    When "3" : CRITERE(1)="INDTYP=2" #Break
  Endcase

  OBJET="INDREF"
  START="INDCOD"
Return

######################################################################################################
$SELINDREFO

  Local File SFTTXN [SFTXIND] #CT-1993
  Local File SFTINDREF [SFTIR]
  Local File ATEXTRA [AXX]
  Link [SFTXIND] With [SFTIR]SFTAG0 = [SFTXIND]INDREF, [AXX]AXX0 = "SFTINDREF";"INDESAXX";GLANGUE;INDREF;""  As [LNK] Where [SFTXIND]UTCENDDATTIM  = AVOID.ADATTIM
&                                              & [SFTXIND]FCY = PARAM(3) #CT-1993
  Default File [LNK]
  Local Char INDTYP(50)
  Case PARAM(1)
    When "1" : CRITERE = "(INDTYP = 3 | INDTYP = 4)" #Indirect Only
    When "2" : CRITERE = "(INDTYP<>2 & INDTYP<>5)" #Non-break
    When "3" : CRITERE = "INDTYP=2" #Break
  Endcase

  Local Integer EMPLIST(1..)
  EMPLIST(1) = val(PARAM(2))
  Call TEAM_LIST (val(PARAM(2)), "A", EMPLIST) From SFTLIB
  CRITERE += " & EMPNUM = " + num$(EMPLIST(1))

  OBJET=""
  START   = "INDREF"

  TIT(0) = mess(86,2422,1)
  NBCOL  = 0

  NBCOL+=1 : COL(NBCOL) = "INDREF"
  Call TEXTFIC("SFTXIND","INDREF",1,TIT(NBCOL)) From OBJDIV #CT-1993
  NBCOL+=1 : COL(NBCOL)="[F:AXX]TEXTE"
  Call TEXTFIC("SFTINDREF","INDESAXX",1,TIT(NBCOL)) From OBJDIV

  DEFPAG = 1

Return

