#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# ACTION - BEE123
# Issue X3-49093/4 - 2017-10-11 by SINGC
##########################################################################################################
$ACTION
  Case ACTION
    When "INIT_DIA"  :  Gosub INIT_DIA
    When "EXEC"      :  Gosub EXEC
    When "SEL_TABLE"   : Gosub SEL_TABLE
    When Default
  Endcase
Return

##########################################################################################################
$INIT_DIA
  [M:DIA]ALLCPY  = [V]CST_AYES
  [M:DIA]SIMUL   = [V]CST_ANO
  Affzo [M:DIA]1-99
  # -----------------------------
  NAVIG = GACTION
  GOK = 1
  # -----------------------------
Return

##########################################################################################################
$EXEC
Local Char CRITERE(250)(0..)
Local Char CRITERE_(250)
Local Char SBPRNUM(GLONBPR)(0..)
Local Char SLINE(250)
Local Char SEQNUM(20)
Local Char CPY(GLONCPY)
Local Char SCPY(GLONCPY)(0..)
Local Char SCPY_(GLONCPY)(0..)
Local Char SFCY_(GLONFCY)(0..)
Local Integer ICPY_FCY
Local Integer ICRITERE
Local Integer IRET
Local Integer NI
Local Integer NE
Local Integer NY
Local Integer NZ
Local Integer IMAXCPY
Local Decimal TOTAMTNOT
Local Clbfile FILE_CONTENT(4)
  # -----------------------------
  Local File COMPANY [CPY]
  Local File BPARTNER   [BPR]
  Local File PINVOICE   [PIH]
  # -----------------------------
  Link [PIH] With [BPR]BPR0=[F:PIH]BPR
&              As [NEW]
&              Order By [F:PIH]CPY;[F:PIH]BPR;[F:PIH]ACCDAT Asc
  # -----------------------------
  Raz CRITERE
  Raz ICRITERE
  # -----------------------------
  Call OUVRE_TRACE(mess(12,7720,1)) From LECFIC
  Call PRTSCR("BEE123", "DIA", "", 0, 1) From ATRTX3
  Call ECR_TRACE(string$(50,"-"), 0) From GESECRAN
  # -----------------------------
  # Set Criteria Values
  # -----------------------------
  CRITERE(ICRITERE) = "([F:PIH]INVTYP = 1 or [F:PIH]INVTYP = 4)"
  If [M:DIA]ALLCPY = [V]CST_ANO and [M:DIA]CPY <> AVOID.ACHAR Then
    ICRITERE +=1
    CRITERE(ICRITERE) -= "& [F:PIH]CPY = [M:DIA]CPY"
  Endif
  If [M:DIA]STRDAT <> AVOID.ADATE Then
    ICRITERE +=1
    CRITERE(ICRITERE) -= "& [F:PIH]ACCDAT >= [M:DIA]STRDAT"
  Endif
  If [M:DIA]ENDDAT <> AVOID.ADATE Then
    ICRITERE +=1
    CRITERE(ICRITERE) -= "& [F:PIH]ACCDAT <= [M:DIA]ENDDAT"
  Endif
  # -----------------------------
  If [M:DIA]CPY = AVOID.ACHAR Then
    Raz ICPY_FCY
    Raz SCPY
    Raz NE
    Raz SCPY_
    Raz SFCY_
    # -----------------------------
    Filter [NEW] Where evalue(CRITERE)
    For [NEW]
      ICPY_FCY += 1
      SCPY(ICPY_FCY) = [NEW]CPY
      If SCPY(ICPY_FCY) <> SCPY(ICPY_FCY-1) Then
        Read [CPY]CPY0 = SCPY(ICPY_FCY)
        If [F:CPY]LEG = "ZAF" Then
          NE += 1
          SCPY_(NE) = [NEW]CPY
          SFCY_(NE) = [NEW]FCY
        Endif
      Endif
    Next
    Filter [NEW]
    # -----------------------------
    IMAXCPY = maxtab(SCPY_)
    If IMAXCPY = 0 Then
      Call ECR_TRACE(mess(25,7720,1), -3) From GESECRAN
    Else
      Call ECR_TRACE(func AFNC.MES1(mess(23,7720,1), num$(IMAXCPY)), -3) From GESECRAN
      # -----------------------------
      For NE = 1 To IMAXCPY
        CPY = SCPY_(NE)
        Call ECR_TRACE(string$(50,"-"), 0) From GESECRAN
        # -----------------------------
        Gosub HEADER
        # -----------------------------
        If [M:DIA]SIMUL = [V]CST_AYES Then
          Call ECR_TRACE(SLINE, 0) From GESECRAN
        Else
          Call NUMERO("BEE", SFCY_(NE), date$, AVOID.ACHAR, SEQNUM, IRET) From SUBANM
          If IRET <> [V]CST_AOK Then
            Call ECR_TRACE(mess(945,182,1), 1) From GESECRAN
            Break
          Endif
          Openo filpath("tmp",SEQNUM,"csv")
          Wrseq SLINE
          FILE_CONTENT = SLINE + chr$(13) + chr$(10)
        Endif
        # -----------------------------
        Raz CRITERE_
        Raz NI
        Raz NY
        Raz NZ
        CRITERE_ = CRITERE - "& [F:PIH]CPY ='" + CPY + "'"
        # -----------------------------
        Filter [NEW] Where evalue(CRITERE_)
        For [NEW]
          NI += 1
          SBPRNUM(NI) = [NEW]BPR
          Raz TOTAMTNOT
          # -----------------------------
          Gosub LINES
          # -----------------------------
        Next
        Filter [NEW]
        # -----------------------------
        Gosub RETMES_WEBCALL
        # -----------------------------
      Next NE
    Endif
  Else # [M:DIA]CPY <> AVOID.ACHAR
    CPY = [M:DIA]CPY
    # -----------------------------
    Gosub HEADER
    # -----------------------------
    Filter [NEW] Where evalue(CRITERE)
    For [NEW]
      # -----------------------------
      If NI = 0 Then
        If [M:DIA]SIMUL = [V]CST_AYES Then
          Call ECR_TRACE(SLINE, 0) From GESECRAN
        Else
          Call NUMERO("BEE", [NEW]FCY, date$, AVOID.ACHAR, SEQNUM, IRET) From SUBANM
          If IRET <> [V]CST_AOK Then
            Call ECR_TRACE(mess(945,182,1), 0) From GESECRAN
            Break
          Endif
          Openo filpath("tmp",SEQNUM,"csv")
          Wrseq SLINE
          FILE_CONTENT = SLINE + chr$(13) + chr$(10)
        Endif
      Endif
      CRITERE_ = CRITERE
      NI += 1
      SBPRNUM(NI) = [NEW]BPR
      Raz TOTAMTNOT
      # -----------------------------
      Gosub LINES
      # -----------------------------
    Next
    Filter [NEW]
    # -----------------------------
    Gosub RETMES_WEBCALL
    # -----------------------------
  Endif
  # -----------------------------
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Return

##########################################################################################################
$HEADER
  Call ECR_TRACE(func AFNC.MES1(mess(22,7720,1), CPY), -2) From GESECRAN
  # -----------------------------
  SLINE  = "VATNumber"
  SLINE += "," + "RegistrationNumber"
  SLINE += "," + "Supplier"
  SLINE += "," + "TotalSpend"
  SLINE += "," + "EmpoweringSupplier"
  SLINE += "," + "Type"
  SLINE += "," + "Level"
  SLINE += "," + "51%BO"
  SLINE += "," + "30%BFO"
  SLINE += "," + "SDBeneficiary"
  SLINE += "," + "BO/QSE/EME"
  SLINE += "," + "FirstTimeSupplier"
  SLINE += "," + "DesignatedGroup"
  SLINE += "," + "CertificateExpiryDate"
Return

##########################################################################################################
$LINES
  If SBPRNUM(NI) <> SBPRNUM(NI-1) Then
    NY += 1
    If [F:BPR]VATNO = AVOID.ACHAR or [F:BPR]REGNUM = AVOID.ACHAR or [F:BPR]BPRNAM = AVOID.ACHAR Then
      NZ += 1
      SLINE = func AFNC.MES1(mess(13,7720,1), [NEW]BPR)
      If [F:BPR]VATNO = AVOID.ACHAR Then
        SLINE -= mess(14,7720,1)
      Endif
      If [F:BPR]REGNUM = AVOID.ACHAR Then
        SLINE -= mess(15,7720,1)
      Endif
      If [F:BPR]BPRNAM = AVOID.ACHAR Then
        SLINE -= mess(16,7720,1)
      Endif
      Call ECR_TRACE(SLINE, -1) From GESECRAN
    Else
      Call CALC_TOTAL_AMTNOT(CRITERE_, [NEW]BPR, TOTAMTNOT)
      If TOTAMTNOT = 0 Then
        NZ += 1
        SLINE = func AFNC.MES1(mess(13,7720,1), [NEW]BPR)
        SLINE -= mess(17,7720,1)
        Call ECR_TRACE(SLINE, -1) From GESECRAN
      Else
        SLINE  = [F:BPR]VATNO           # *10 digit numeric VAT number if Co. registered for VAT
        SLINE += "," + [F:BPR]REGNUM    # *12 digit Co. reg. no. YYYY/XXXXXX/XX; 13 digit SA ID no; IT no. ITxxxx/xxxx; 6 digit NPO no. xxx-xxx
        SLINE += "," + [F:BPR]BPRNAM(0) # *Supplier name
        SLINE += "," + num$(TOTAMTNOT)  # *Total spend excluding VAT
        SLINE += ","                    # Yes/No; Defauly Yes
        SLINE += ","                    # Generic/QSE/EME
        SLINE += ","                    # 0-8
        SLINE += ","                    # Yes/No
        SLINE += ","                    # Yes/No
        SLINE += ","                    # Yes/No
        SLINE += ","                    # Yes/No
        SLINE += ","                    # Yes/No
        SLINE += ","                    # Yes/No
        SLINE += ","                    # YYYY-MM-DD
        # -----------------------------
        If [M:DIA]SIMUL = [V]CST_AYES Then
          Call ECR_TRACE(SLINE, 0) From GESECRAN
        Else
          Wrseq SLINE
          FILE_CONTENT += SLINE + chr$(13) + chr$(10)
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$RETMES_WEBCALL
  If NZ <> 0 Then
    If NY = NZ Then
      Call ECR_TRACE(func AFNC.MES1(mess(21,7720,1), CPY), 0) From GESECRAN
    Else
      Call ECR_TRACE(func AFNC.MES2(mess(19,7720,1), num$(NY-NZ), CPY) - func AFNC.MES1(mess(20,7720,1), num$(NZ)), 0) From GESECRAN
    Endif
  Else
    If NY = 0 Then
      Call ECR_TRACE(func AFNC.MES1(mess(21,7720,1), CPY), 0) From GESECRAN
    Else
      Call ECR_TRACE(func AFNC.MES2(mess(19,7720,1), num$(NY), CPY), 0) From GESECRAN
    Endif
  Endif
  # -----------------------------
  If [M:DIA]SIMUL = [V]CST_ANO Then
    Openo
    If NY = NZ Then
      Call ECR_TRACE(mess(19,7720,1), -4) From GESECRAN
    Else
      Call BEE123_WEBCALL(FILE_CONTENT, CPY, IRET)
      If IRET <> 200 and IRET <> 0 Then
        Call ECR_TRACE(func AFNC.MES2(mess(18,7720,1), SEQNUM, num$(IRET)), 1) From GESECRAN
      Endif
    Endif
  Endif
Return

##########################################################################################################
$SEL_TABLE
  Case TABLE
    When "CPYSELZAF"     : Gosub SEL_CPYSELZAF
    When Default
  Endcase
Return

##########################################################################################################
$SEL_CPYSELZAF
# PARAM(1) : complementary filter

  # -----------------------------
  If !clalev ([F:CPY]) : Local File COMPANY [CPY] : Endif
  # -----------------------------
  CODFIC = "COMPANY"
  DEFPAG = 1
  SIZLIG = 120
  SIZCOL = 400
  CRITERE = "[F:CPY]LEG = 'ZAF'"
  START = "[F:CPY]CPY"
  ORDRE = "[F:CPY]CPY"
  # -----------------------------
  CRITERE -= "& [F:CPY]CPY>='" + VALEUR  + "'"
  If PARAM(1) <> AVOID.ACHAR Then
    CRITERE -= "& (" + PARAM(1) + ")"
  Endif
  # -----------------------------
  TIT = mess(87,106,1)
  Default File [CPY]
  # -----------------------------
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "CPY"        : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "CPYNAM"     : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "CPYSHO"     : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "LEG"        : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return

##########################################################################################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR

  If VALEUR <> AVOID.ADATE and [M:DIA]ENDDAT <> AVOID.ADATE and VALEUR > [M:DIA]ENDDAT Then
    GMESSAGE = mess(104,119,1)
    mkstat = 2
    End
  Endif
  # -----------------------------
  If VALEUR <> AVOID.ADATE and VALEUR > date$ Then
    GMESSAGE = mess(177,196,1)
    mkstat = 2
    End
  Endif
  # -----------------------------
  If VALEUR <> AVOID.ADATE and [M:DIA]ENDDAT = AVOID.ADATE Then
    [M:DIA]ENDDAT = VALEUR
  Endif
End

##########################################################################################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR

  If VALEUR <> AVOID.ADATE and VALEUR < [M:DIA]STRDAT and [M:DIA]STRDAT <> AVOID.ADATE
    GMESSAGE = mess(99,177,1)
    mkstat = 2
    End
  Endif
  # -----------------------------
  If VALEUR <> AVOID.ADATE and VALEUR > date$ Then
    GMESSAGE = mess(177,196,1)
    mkstat = 2
    End
  Endif
End

##########################################################################################################
Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR

  If VALEUR = [V]CST_AYES
    Grizo [M:DIA]CPY
  Else
    Actzo [M:DIA]CPY
  Endif
End

##########################################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()

  Local File COMPANY [CPY]
  # -----------------------------
  If VALEUR <> AVOID.ACHAR Then
    Read [CPY]CPY0 = VALEUR
    If [F:CPY]LEG <> "ZAF" Then
      GMESSAGE = mess(28,7720,1)
      mkstat = 2
    Endif
  Endif
End

##########################################################################################################
Subprog CALC_TOTAL_AMTNOT(CRITERE, SBPRNUM, DTOTAMT)
Value Char CRITERE
Value Char SBPRNUM
Variable Decimal DTOTAMT

  Local File PINVOICE [PIH]
  # -----------------------------
  Filter [PIH] Where evalue(CRITERE) & [PIH]BPR = SBPRNUM
  For [PIH]
    If [F:PIH]INVTYP = 1 Then
      DTOTAMT += [F:PIH]AMTNOT
    Else
      DTOTAMT -= [F:PIH]AMTNOT
    Endif
  Next
End

##########################################################################################################
Subprog BEE123_WEBCALL(FILE_CONTENT, SCPY, STATUSCODE)
Variable Clbfile FILE_CONTENT
Value Char SCPY
Variable Integer STATUSCODE
# -----------------------------
Local Clbfile RESHEAD(0)
Local Clbfile RESBODY(0)
Local Clbfile TXTDATA(4)
# -----------------------------
Local Char HEADERCOD(64)(10)
Local Char HEADERVAL(255)(10)
Local Char BEEREST(255)
Local Char BEEAUTH(255)
  # -----------------------------
  BEEREST = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVCPY, SCPY, "RSABEEREST")
  If BEEREST = AVOID.ACHAR Then
    Call ECR_TRACE(mess(26,7720,1), 1) From GESECRAN
    End
  Endif
  # -----------------------------
  BEEAUTH = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVCPY, SCPY, "RSABEEAUTH")
  If BEEAUTH = AVOID.ACHAR Then
    Call ECR_TRACE(mess(27,7720,1), 1) From GESECRAN
    End
  Endif
  # -----------------------------
  HEADERCOD(0) = "url"
  HEADERVAL(0) = BEEREST
  HEADERCOD(1) = "method"
  HEADERVAL(1) = "POST"
  HEADERCOD(2) = "Authorization"
  HEADERVAL(2) = "Basic" - BEEAUTH
  HEADERCOD(3) = "Accept"
  HEADERVAL(3) = "application/json"
  HEADERCOD(4) = "Content-Type"
  HEADERVAL(4) = "multipart/form-data; boundary=----WebKitFormBoundaryGtsGDIJM0GikQcCL"
  HEADERCOD(5) = "Cache-Control"
  HEADERVAL(5) = "no-cache"
  HEADERCOD(6) = "Accept-Encoding"
  HEADERVAL(6) = "gzip, deflate"
  HEADERCOD(7) = "Accept-Language"
  HEADERVAL(7) = "en-US,en;q=0.8"
  # -----------------------------
  TXTDATA += '------WebKitFormBoundaryGtsGDIJM0GikQcCL'+chr$(13)+chr$(10)
  TXTDATA += 'Content-Disposition: form-data; name="PreferentialProcurement"; filename="Preferential Procurement Import_Template v1.csv"'+chr$(13)+chr$(10)
  TXTDATA += 'Content-Type: application/vnd.ms-excel'+chr$(13)+chr$(10)
  TXTDATA += ''+chr$(13)+chr$(10)
  TXTDATA += FILE_CONTENT
  TXTDATA += ''+chr$(13)+chr$(10)
  TXTDATA += '------WebKitFormBoundaryGtsGDIJM0GikQcCL--'+chr$(13)+chr$(10)
  # -----------------------------
  STATUSCODE = func ASYRWEBSER.EXEC_HTTP(HEADERCOD, HEADERVAL, TXTDATA, RESHEAD, RESBODY)
End

