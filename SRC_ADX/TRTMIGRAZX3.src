#<AdxTL>@(#)6.0.0.0 $Revision$
############################################################################
# TRTMIGRAZX3      Préparation des tables de flux       Module Superviseur #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOS(DOSSIER,"") From SAIDOS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("TRTMIGRAZX3") From LECFIC
  Endif

  Call TRTMIGRAZX3(DOSSIER) 

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End

############################################################################
Subprog TRTMIGRAZX3(DOSSIER)
Value Char DOSSIER

Local Integer ERR : Raz ERR
Local Char WDOSVERS
Call VERSION(DOSSIER,WDOSVERS) From DOSSUB
Gosub DEF_VERSIONSX3 From TRTMIGTABX3


GOK=1
Call ECR_TIME("TRTMIGRAZX3 : Process Start on : "+DOSSIER) From DOSSUB

#Superviseur
Call MIGTABRAZ (DOSSIER,"ALSTRD",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"ALISTER",ERR) From TRTMIG

Call MIGTABRAZ (DOSSIER,"AWRKLOG",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"AWRKLOGIND",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"AWRKLOGMES",ERR) From TRTMIG

Call MIGTABRAZ (DOSSIER,"LABELPRN",ERR) From TRTMIG

Call MIGTABRAZ (DOSSIER,"PRTSCRWRK",ERR) From TRTMIG

Call MIGTABRAZ (DOSSIER,"ATMPTRA",ERR) From TRTMIG

#Comptabilité
If val(WDOSVERS)<GMIGX3VER60
 Call MIGTABRAZ (DOSSIER,"BALANCE",ERR) From TRTMIG
 Call MIGTABRAZ (DOSSIER,"BALANA",ERR) From TRTMIG
 Call MIGTABRAZ (DOSSIER,"GLCONSO",ERR) From TRTMIG
 Call MIGTABRAZ (DOSSIER,"BALCONSO",ERR) From TRTMIG
 Call MIGTABRAZ (DOSSIER,"GAJOUSTA",ERR) From TRTMIG
 Call MIGTABRAZ (DOSSIER,"FUP",ERR) From TRTMIG
 Call MIGTABRAZ (DOSSIER,"FUPTOT",ERR) From TRTMIG
 Call MIGTABRAZ (DOSSIER,"BATCH",ERR) From TRTMIG
 Call MIGTABRAZ (DOSSIER,"TMPEXPENSE",ERR) From TRTMIG
Endif

# Tables temporaires Achats - Issue 79596
Call MIGTABRAZ (DOSSIER,"PWRKSTT",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"PWRKORDERS",ERR) From TRTMIG

$FIN
Call ECR_TIME("TRTMIGRAZX3 : END.")  From DOSSUB
End

