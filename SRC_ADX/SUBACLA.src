[L]TBMET(1) = "INIT"
[L]TBMET(2) = "CONTROL"
[L]TBMET(3) = "ERREUR"
[L]TBMET(4) = "_ACONTROL"
[L]TBMET(5) = "_AINIT"
[L]TBMET(6) = "_AMANDATORY"
[L]TBMET(7) = "_AFORMAT"
[L]TBMET(8) = "_AOTHERS"
[L]TBMET(9) = "_ALOADATTRIBUTE"
[L]TBMET(10) = "LNKPRO"
[L]TBMET(11) = "_ALNKPRO"
[L]TBMET(12) = "_AERROR"
[L]TBMET(13) = "_CONTROL"
[L]TBMET(14) = "_ALOAD_KEYS"
[L]TBMET(15) = "_ADDTRT"
[L]TBMET(16) = "AINIT"
[L]TBMET(17) = "ACONTROL"
[L]TBMET(18) = "_ADELERRORS"
Return

$CLA_RESERVE_MB
