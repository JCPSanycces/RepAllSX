For nolign=1 To [M:ACLA2]NBMET
 Raz [F:ACLAM]
 [F:ACLAM]CODCLA  = [M:ACLA0]CODCLA
 [F:ACLAM]NOMET   = nolign
 [F:ACLAM]        = [M:ACLA2]
 Write [ACLAM]
 If fstat
  GOK = 0 : Call FSTA("ACLAM") From GLOCK : Break
 Endif
Next nolign
nolign=SAVNOLIGN
