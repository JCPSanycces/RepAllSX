If nomap="SUPERV"
 NBCLAMB += 1 : TBCLAMB(NBCLAMB) = "ACONTEXT"
 NBCLAMB += 1 : TBCLAMB(NBCLAMB) = "OBJECT"
 If !find(GUSER,"MB","CCL", "KUYAN") & 1=0
  NBCLAMB += 1 : TBCLAMB(NBCLAMB) = "TABCOUNTRY"
  NBCLAMB += 1 : TBCLAMB(NBCLAMB) = "ATABLE"
 Endif
Endif
Return

