For nolign=1 To [M:ACLA7]NBRPARDEF
 Raz [F:ACLPD]
 [F:ACLPD]CODCLA  = [M:ACLA0]CODCLA
 [F:ACLPD]        = [M:ACLA7]
 Write [F:ACLPD]
 If fstat
  GOK = 0 : Call FSTA("ACLPD") From GLOCK : Break
 Endif
Next nolign
nolign=SAVNOLIGN
