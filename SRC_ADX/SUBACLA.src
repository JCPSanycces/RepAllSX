$TRTCOP
Gosub OUVRE_COP
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ACLAS1], [ACLAF1], [ACLFP1], [ACLAM1], [ACLPD1], [ACLAT1], [ACLAK1], [ACLAO1], [ACLAC1], [ATX1] , [ACLAKP1] , [ACV1]
Close Local File [ACLAS2], [ACLAF2], [ACLFP2], [ACLAM2], [ACLPD2], [ACLAT2], [ACLAK2], [ACLAO2], [ACLAC2], [ATX2] , [ACLAKP2] , [ACV2] , [ADW2]
Return

$TR_COP
GOK = 1
Trbegin [ACLAS2]
 Delete [ACLAS2] Where CODCLA=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACLASSE" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ACLAS2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ACLAF2] Where CODCLA=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACLAFLD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ACLAF2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ACLFP2] Where CODCLA=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACLAPARFLD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ACLFP2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ACLAM2] Where CODCLA=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACLAMET" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ACLAM2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ACLPD2] Where CODCLA=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACLAPARDEF" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ACLPD2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ACLAT2] Where CODCLA=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACLAMETSTD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ACLAT2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ACLAK2] Where CODCLA=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACLALNK" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ACLAK2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ACLAO2] Where CODCLA=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACLAOPT" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ACLAO2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ACLAC2] Where CODCLA=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACLACOL" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ACLAC2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ACLAKP2] Where CODCLA=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACLAMAP" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ACLAKP2","") From GLOCK : Goto AB_TR_COP
 Endif

 Local Integer ISDOSX3DES
 Local  Char ADOSDES(GLONADS),MACDES(250)
 Read [ADW2]ADW0 = "";"";"SUPDOS"
 If !fstat
  Call MACHINE(DOSDES,MACDES,ADOSDES) From ORDSYS
  If ADOSDES=[F:ADW2]VALEUR
   ISDOSX3DES = 1
  Endif
 Endif

 For [ACLAS1] Where CODCLA=TABLE
  [F:ACLAS2] = [F:ACLAS1]
  Call COPTEXTE([F:ACLAS1]INTCLA,[F:ACLAS2]INTCLA) From OBJDIV
  If GOK<1 : Break : Endif

  If dim([F:ACLAS2]UPDUSR)>0 : [F:ACLAS2]UPDUSR = GUSER : Endif
  If dim([F:ACLAS2]UPDDAT)>0 : [F:ACLAS2]UPDDAT = date$ : Endif
  If dim([F:ACLAS2]UPDTIM)>0 : [F:ACLAS2]UPDTIM = time  : Endif
  Write [ACLAS2]
  If fstat
   GOK=0 : Call FSTA("ACLAS2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 For [ACLAF1] Where CODCLA=TABLE
  If [F:ACLAF1]ACTFLD<>""
   Read [ACV2]CODACT = [F:ACLAF1]ACTFLD
  Endif
  If [F:ACLAF1]ACTFLD="" or ISDOSX3DES or (!fstat and [ACV2]FLACT=2)
   [F:ACLAF2] = [F:ACLAF1]
   Call COPTEXTE([F:ACLAF1]INTFLD,[F:ACLAF2]INTFLD) From OBJDIV
   If GOK<1 : Break : Endif
   Call COPTEXTE([F:ACLAF1]INTSHTFLD,[F:ACLAF2]INTSHTFLD) From OBJDIV
   If GOK<1 : Break : Endif
 #  Call COPTEXTE([F:ACLAF1]INFBUL,[F:ACLAF2]INFBUL) From OBJDIV
 #  If GOK<1 : Break : Endif
   Write [ACLAF2]
   If fstat
    GOK=0 : Call FSTA("ACLAF2") From GLOCK : Break
   Endif
   For [ACLFP1] Where CODCLA=TABLE & FLDCLA=[ACLAF1]FLDCLA
    [F:ACLFP2] = [F:ACLFP1]
    Write [ACLFP2]
    If fstat
     GOK=0 : Call FSTA("ACLFP2") From GLOCK : Break 2
    Endif
   Next
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 For [ACLAO1] Where CODCLA=TABLE
  [F:ACLAO2] = [F:ACLAO1]
  Call COPTEXTE([F:ACLAO1]OPTLIB,[F:ACLAO2]OPTLIB) From OBJDIV
  Call COPTEXTE([F:ACLAO1]OPTERR,[F:ACLAO2]OPTERR) From OBJDIV
  If GOK<1 : Break : Endif
  Write [ACLAO2]
  If fstat
   GOK=0 : Call FSTA("ACLAO2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 For [ACLAC1] Where CODCLA=TABLE
  [F:ACLAC2] = [F:ACLAC1]
  Call COPTEXTE([F:ACLAC1]INTCOL,[F:ACLAC2]INTCOL) From OBJDIV
  Write [ACLAC2]
  If fstat
   GOK=0 : Call FSTA("ACLAC2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

# For [ACLFP1] Where CODCLA=TABLE
#  [F:ACLFP2] = [F:ACLFP1]
#  Write [ACLFP2]
#  If fstat
#   GOK=0 : Call FSTA("ACLFP2") From GLOCK : Break
#  Endif
# Next
# If   GOK<0 : Goto ROLL_TR_COP
# Elsif !GOK : Goto AB_TR_COP
# Endif

 For [ACLAM1] Where CODCLA=TABLE
  [F:ACLAM2] = [F:ACLAM1]
  Call COPTEXTE([F:ACLAM1]INTMET,[F:ACLAM2]INTMET) From OBJDIV
  If GOK<1 : Break : Endif
  Write [ACLAM2]
  If fstat
   GOK=0 : Call FSTA("ACLAM2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 For [ACLPD1] Where CODCLA=TABLE
  [F:ACLPD2] = [F:ACLPD1]
  Call COPTEXTE([F:ACLPD1]INTPAR,[F:ACLPD2]INTPAR) From OBJDIV
  If GOK<1 : Break : Endif
  Write [ACLPD2]
  If fstat
   GOK=0 : Call FSTA("ACLPD2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 For [ACLAT1] Where CODCLA=TABLE
  [F:ACLAT2] = [F:ACLAT1]
  Write [ACLAT2]
  If fstat
   GOK=0 : Call FSTA("ACLAT2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

 For [ACLAK1] Where CODCLA=TABLE
  If [F:ACLAK1]ACVLNK<>""
   Read [ACV2]CODACT = [F:ACLAK1]ACVLNK
  Endif
  If [F:ACLAK1]ACVLNK="" or ISDOSX3DES or (!fstat and [ACV2]FLACT=2)
   [F:ACLAK2] = [F:ACLAK1]
   Write [ACLAK2]
   If fstat
    GOK=0 : Call FSTA("ACLAK2") From GLOCK : Break
   Endif
   For [ACLAKP1]ACLAKP0 Where CODCLA=TABLE & REFLNK= [F:ACLAK1]REFLNK
    [F:ACLAKP2] = [F:ACLAKP1]
    Write [ACLAKP2]
    If fstat
     GOK=0 : Call FSTA("ACLAKP2") From GLOCK : Break 2
    Endif
   Next
  Else
   Delete [ACLFP2] Where CODCLA=[F:ACLAK1]CODCLA & FLDCLA=[F:ACLAK1]REFLNK
   Delete [ACLAF2] Where CODCLA=[F:ACLAK1]CODCLA & FLDCLA=[F:ACLAK1]REFLNK
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

# For [ACLAKP1] Where CODCLA=TABLE
#  [F:ACLAKP2] = [F:ACLAKP1]
#  Write [ACLAKP2]
#  If fstat
#   GOK=0 : Call FSTA("ACLAKP2") From GLOCK : Break
#  Endif
# Next
# If   GOK<0 : Goto ROLL_TR_COP
# Elsif !GOK : Goto AB_TR_COP
# Endif

Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

#####################################################################################################################
#####################################################################################################################
Subprog CHARGE_CLA_ATI_CLE(DOSSIER,ACLASSE,FLDCUR,TYPPAR,WCODPAR,WCODCUR,WTYPPAR,WFLDCLE,WINTITPAR,WTYPINTPAR,WADRVAL,
& WTYPKEY,WCODCLAPAR,WNUMPAR,WNOLIB,WLNG,WTYPAFF,WNBRPARALL)
Value Char    DOSSIER
Value Char    ACLASSE
Value Char    FLDCUR
Value Integer TYPPAR
Variable Char    WCODPAR()(0..)
Variable Char    WCODCUR()(0..)
Variable Integer WTYPPAR(0..)
Variable Char    WFLDCLE()(0..)
Variable Char    WINTITPAR()(0..)
Variable Integer WTYPINTPAR(0..)
Variable Integer WADRVAL(0..)
Variable Integer WTYPKEY(0..)
Variable Char    WCODCLAPAR()(0..)
Variable Integer WNUMPAR(0..)
Variable Integer WNOLIB(0..)
Variable Integer WLNG(0..)
Variable Integer WTYPAFF(0..)
Variable Integer WNBRPARALL

Local Char CHAINE(250)
Local Integer I,J,WNUM

Local File =[L]DOSSIER+".ACLASSE"     [ACLA]
If filinfo(filpath("FIL","AVIEWIND","fde",DOSSIER),0)<0
 Local File =[L]DOSSIER+".ATABIND" [ATI]
Else
 Local File =[L]DOSSIER+".AVIEWIND" [ATI]
Endif

Read [F:ACLA]ACLA0 = [L]ACLASSE
If !fstat &  find([F:ACLA]TYPCLA,2,5)>0
 If [F:ACLA]TYPCLA=2
  Read [ATI]CODIND = [F:ACLA]TABREF;[F:ACLA]INDREF
  If !fstat
   CHAINE = [F:ATI]DESCRIPT
  Endif
 Elsif [F:ACLA]TYPCLA=5
  CHAINE = vireblc([F:ACLA]KEYINT,4)
 Endif
 Call CHARGE_CLE([F:ACLA]TABREF,CHAINE,DOSSIER,ACLASSE,FLDCUR,TYPPAR,WCODPAR,WCODCUR,WTYPPAR,WFLDCLE,WINTITPAR,WTYPINTPAR,WADRVAL,WTYPKEY,WCODCLAPAR,WNUMPAR,WNOLIB,WLNG,WTYPAFF,WNBRPARALL)
Endif

#Close Local File [ACLA]
#Close Local File [ATI]

End


###################################################################################################################
# Same principle as CHARGE_CLA_ATI_CLE, but with one exception that the table and index are not
# taken from the database, but taken from the most up-to-date info from the screen.
###################################################################################################################
Subprog CHARGE_CLA_ATI_CLE_SCREEN(DOSSIER,ACLASSE,FLDCUR,TYPPAR,WCODPAR,WCODCUR,WTYPPAR,WFLDCLE,WINTITPAR,WTYPINTPAR,WADRVAL,
& WTYPKEY,WCODCLAPAR,WNUMPAR,WNOLIB,WLNG,WTYPAFF,WNBRPARALL)
Value Char    DOSSIER
Value Char    ACLASSE
Value Char    FLDCUR
Value Integer TYPPAR
Variable Char    WCODPAR()(0..)
Variable Char    WCODCUR()(0..)
Variable Integer WTYPPAR(0..)
Variable Char    WFLDCLE()(0..)
Variable Char    WINTITPAR()(0..)
Variable Integer WTYPINTPAR(0..)
Variable Integer WADRVAL(0..)
Variable Integer WTYPKEY(0..)
Variable Char    WCODCLAPAR()(0..)
Variable Integer WNUMPAR(0..)
Variable Integer WNOLIB(0..)
Variable Integer WLNG(0..)
Variable Integer WTYPAFF(0..)
Variable Integer WNBRPARALL

Local Char CHAINE(250)
Local Integer I,J,WNUM

Local File =[L]DOSSIER+".ACLASSE"     [ACLA]

If filinfo(filpath("FIL","AVIEWIND","fde",DOSSIER),0)<0
 Local File =[L]DOSSIER+".ATABIND" [ATI]
Else
 Local File =[L]DOSSIER+".AVIEWIND" [ATI]
Endif

Read [ACLA]ACLA0 = [L]ACLASSE
If !fstat &  find([ACLA]TYPCLA,2,5)>0
 If [ACLA]TYPCLA=2
  Read [ATI]CODIND = [M:ACLA1]WTABREF;[M:ACLA1]WINDREF
  If !fstat
   CHAINE = [ATI]DESCRIPT
  Endif
 Elsif [ACLA]TYPCLA=5
  CHAINE = vireblc([ACLA]KEYINT,4)
 Endif
 Call CHARGE_CLE([M:ACLA1]WTABREF,CHAINE,DOSSIER,ACLASSE,FLDCUR,TYPPAR,WCODPAR,WCODCUR,WTYPPAR,WFLDCLE,WINTITPAR,WTYPINTPAR,WADRVAL,WTYPKEY,WCODCLAPAR,WNUMPAR,WNOLIB,WLNG,WTYPAFF,WNBRPARALL)
Endif

#Close Local File [ACLA]
#Close Local File [ATI]

End

#####################################################################################################################
#####################################################################################################################
Subprog CHARGE_CLE(TABREF,DESCRIPT,DOSSIER,ACLASSE,FLDCUR,TYPPAR,WCODPAR,WCODCUR,WTYPPAR,WFLDCLE,WINTITPAR,WTYPINTPAR,
& WADRVAL,WTYPKEY,WCODCLAPAR,WNUMPAR,WNOLIB,WLNG,WTYPAFF,WNBRPARALL)
Value Char    TABREF
Value Char    DESCRIPT
Value Char    DOSSIER
Value Char    ACLASSE
Value Char    FLDCUR
Value Integer TYPPAR
Variable Char    WCODPAR()(0..)
Variable Char    WCODCUR()(0..)
Variable Integer WTYPPAR(0..)
Variable Char    WFLDCLE()(0..)
Variable Char    WINTITPAR()(0..)
Variable Integer WTYPINTPAR(0..)
Variable Integer WADRVAL(0..)
Variable Integer WTYPKEY(0..)
Variable Char    WCODCLAPAR()(0..)
Variable Integer WNUMPAR(0..)
Variable Integer WNOLIB(0..)
Variable Integer WLNG(0..)
Variable Integer WTYPAFF(0..)
Variable Integer WNBRPARALL

Local Char    CHAINE(250),WCODTYP(GLONATY)
Local Integer I,J,WNUM,K,WNOCOURT,NBFLD
Local Char     INDFLD(GLONAVA)(1..16)

Local File =[L]DOSSIER+".ATYPE"        [ATY]
Local File =[L]DOSSIER+".ACLAFLD"     [ACLAF]
If  filinfo(filpath("FIL","AVIEWFLD","fde",DOSSIER),0)<0
 Local File =[L]DOSSIER+".ATABZON" [ATZ]
Else
 Local File =[L]DOSSIER+".AVIEWFLD" [ATZ]
Endif

CHAINE = [L]DESCRIPT

Call SETCLE(NBFLD,INDFLD,CHAINE) From LNKSUB

For I=1 To [L]NBFLD
 Raz K,WCODTYP,WNOCOURT
 If [L]TABREF<>""
  Read [ATZ]CODZONE = [L]TABREF;[L]INDFLD(I)
  If !fstat # & !find(num$(TYPPAR)+"~"+[L]FLDCUR+"~2~"+left$(CHAINE,I-1),[L]WFLDCLE)
   WCODTYP = [F:ATZ]CODTYP
   WNOCOURT = [F:ATZ]NOCOURT
   K = 1
  Endif
 Else
  Read [ACLAF]ACLAF0 = [L]ACLASSE;[L]INDFLD(I)
  If !fstat # & !find(num$(TYPPAR)+"~"+[L]FLDCUR+"~2~"+left$(CHAINE,I-1),[L]WFLDCLE)
   WCODTYP = [F:ACLAF]CODTYP
   WNOCOURT = [F:ACLAF]INTFLD
   K = 1
  Endif
 Endif
 If K
  If [F:ATY]CODTYP<>WCODTYP
   Read [ATY]CODTYP = WCODTYP
   If fstat : Raz [F:ATY] : Endif
  Endif
  If [F:ATY]CODTYP<>""
   WNUM+=1
   [L]WCODPAR([L]WNBRPARALL) = [L]INDFLD(I)
   CHAINE = right$(CHAINE,I+1)
   [L]WCODCUR([L]WNBRPARALL) = [L]FLDCUR
 #  [L]WFLDCLE([L]WNBRPARALL) =  num$(TYPPAR)+"~"+[L]WCODCUR([L]WNBRPARALL)+"~2~"+[L]WCODPAR([L]WNBRPARALL)
   [L]WINTITPAR([L]WNBRPARALL) = func ASYRFNC.TEXTE(WNOCOURT)
   [L]WTYPINTPAR([L]WNBRPARALL) = [F:ATY]TYPTYP
   [L]WADRVAL([L]WNBRPARALL)    = 2
   [L]WTYPKEY([L]WNBRPARALL)    = 2
   [L]WCODCLAPAR([L]WNBRPARALL) = ""
   [L]WTYPPAR([L]WNBRPARALL)    = TYPPAR
   [L]WNUMPAR([L]WNBRPARALL)    = WNUM
   [L]WNBRPARALL+=1
  Endif
 Endif
Next
End

