$CRE_ACLAT
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
For nolign=1 To [M:ACLA5]NBMETSTD
 Raz [F:ACLAT]
 [F:ACLAT]CODCLA      = [M:ACLA0]CODCLA
 [F:ACLAT]NOMETSTD    = nolign
 [F:ACLAT]            = [M:ACLA5]
 Write [F:ACLAT]
 If fstat
  GOK = 0 : Call FSTA("ASMT") From GLOCK : Break
 Endif
Next nolign
nolign=SAVNOLIGN
Return

$CRE_ACLAK
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
If [M]TYPCLA=2 : # Persitante
 For nolign=1 To [M:ACLA3]NBRLNK
  Raz [F:ACLAK]
  [F:ACLAK] = [M:ACLA3]
  [F:ACLAK] = [M:ACLA0]
  [F:ACLAK]NUMLIG = nolign
  Write [ACLAK]
  If fstat
   GOK=0 : Call FSTA("ACLAK") From GLOCK : Break
  Endif
 Next
 For I=0 To [M:ACLA3]WNBRPROMAP-1
  [F:ACLAKP]CODCLA = [M:ACLA0]CODCLA
  [F:ACLAKP]REFLNK =  [M:ACLA3]WREFLNK(I)
  [F:ACLAKP]KEYMAP = [M:ACLA3]WKEYMAP(I)
  [F:ACLAKP]VALDEFMAP = [M:ACLA3]WVALDEFMAP(I)
  [F:ACLAKP]PROMAP = [M:ACLA3]WPROMAP(I)
  Write [F:ACLAKP]
  If fstat
   GOK=0 : Call FSTA("ACLAMAP") From GLOCK : Break
  Endif
 Next
Endif
nolign=SAVNOLIGN
Return

$CRE_ACLAO
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
If [M]TYPCLA=2 : # Persitante
 For nolign=1 To [M:ACLA4]NBROPT
  Raz [F:ACLAO]
  [F:ACLAO] = [M:ACLA0]
  [F:ACLAO] = [M:ACLA4]
  Write [ACLAO]
  If fstat
   GOK=0 : Call FSTA("ACLAO") From GLOCK : Break
  Endif
 Next
Endif
nolign=SAVNOLIGN
Return

