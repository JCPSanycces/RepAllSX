#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion objet ACLA
Raz GPILOBJ , GNBMASKOUV
GBIDC1 = "COMPANY"
Call OBJET("ACLA",GBIDC1,GBIDC2) From GOBJET
End

#--------------------------------#
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "LIENS"       : Gosub LIENS
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "ANNULE"      : Gosub ANNULE
 When "AP_ANNULE"   : Gosub AP_ANNULE
 When "VERF_ANU"    : Gosub VERF_ANU
 When "STYLE"       : Gosub STYLE
 When "RAZCRE"      : Gosub RAZCRE
 When "RAZDUP"      : Gosub RAZDUP
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "STATUT"      : Gosub STATUT
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "APRES_MOD" : Gosub APRES_MOD
 When "APRES_CRE" : Gosub APRES_CRE
 When "ABANDON" : Gosub ABANDON
 When "APRES_MODIF" : Gosub APRES_MODIF
Endcase
Return

#--------------------------------#
$ABANDON
GMODIFPAR=0
Return
#--------------------------------#
$OUVRE
If !clalev([ACLPD])  : Local File ACLAPARDEF [ACLPD]  : Endif
If !clalev([ACLA])  : Local File ACLASSE    [ACLA]  : Endif
If !clalev([ACLAF])  : Local File ACLAFLD    [ACLAF]  : Endif
If !clalev([ACLAO])  : Local File ACLAOPT    [ACLAO]  : Endif
If !clalev([ACLAC])  : Local File ACLACOL    [ACLAC]  : Endif
If !clalev([ACLAM])  : Local File ACLAMET    [ACLAM]  : Endif
If !clalev([ACLAT])  : Local File ACLAMETSTD [ACLAT]  : Endif
If !clalev([ACLFP])  : Local File ACLAPARFLD [ACLFP]  : Endif
If !clalev([ACLA8])  : Local File ACLASSE    [ACLA8]  : Endif
If !clalev([ACLK8])  : Local File ACLALNK    [ACLK8]  : Endif
If !clalev([ACLAKP])  : Local File ACLAMAP    [ACLAKP]  : Endif

If !clalev([ADI])    : Local File ATABDIV    [ADI]    : Endif
If !clalev([ASU])    : Local File ASUBPROG   [ASU]    : Endif
If !clalev([ASP])    : Local File ASUBPROGD  [ASP]    : Endif
If !clalev([ACL_])   : Local File ACTL       [ACL_]   : Endif
If !clalev([ASW])    : Local File ASHW       [ASW]    : Endif
If !clalev([ACLA2])  : Local File ACLASSE      [ACLA2]  : Endif
If !clalev([ACLAF2])  : Local File ACLAFLD      [ACLAF2]  : Endif
If !clalev([ATYP])   : Local File ATYPEPRO     [ATYP]     : Endif
If !clalev([ATY])     : Local File ATYPE       [ATY]     : Endif
If !clalev([ATY2])     : Local File ATYPE       [ATY2]     : Endif
If !clalev([ATYR])    : Local File ATYPERUL    [ATYR]    : Endif
If !clalev([ATYRP])    : Local File ATYPERPAR    [ATYRP]    : Endif
If !clalev([ACTX2])    : Local File ACONTEXT    [ACTX2]    : Endif
If !clalev([ACV])    : Local File ACTIV       [ACV]    : Endif
If !clalev([ASWK])    : Local File ASHWLNK       [ASWK]    : Endif
If !clalev([ACTX])     : Local File ACONTEXT   [ACTX]    : Endif
If !clalev([AML])     : Local File AMENLOC [AML] : Endif

Gosub OUVRE_ATAB From SUBACLA       #RBU-20150505 - SAM 108321

Local Char    MESSA(250) , VERSION(20)
Local Integer I,J,K,L,M,N
VERSION = func AFNC.PARTSEP(ver$(0),2," ")
If VERSION<"16r.200"
 GMESSAGE = GFONCTION-":"-mess(9,137,1)-"("+VERSION+")" : # Fonction non supportée
 OK = 0 : Return
Endif

Gosub SET_FLDSYS From SUBATB

Global Integer GMODIFPAR
GMODIFPAR = 0
Return

$APRES_MODIF
Case zoncou
 When "WTABREF" : Gosub OUVRE_ATAB
Endcase
Return

$APRES_MOD
Raz GBIDC1
For [ACLK8]ACLAK0(1) Where [ACLK8]CLALNK=[M]CODCLA : # 28 146
 If GBIDC1=""
  GBIDC1 = func AFNC.MES1(mess(28,146,1),[M]CODCLA)
 Endif
 GBIDC1 += " "+[ACLK8]CODCLA
Next
If GBIDC1<>""
 Call AVERTIR(GBIDC1,GBIDI1) From GESECRAN
Endif
# On affiche tout bien à la fin
Gosub RELIT
Return

$APRES_CRE
# On affiche tout bien à la fin
Gosub RELIT
Return

#--------------------------------#
$RELIT
# On affiche tout bien à la fin
  If !GIMPORT
    Gosub RELIT From GOBJSUB
  Else
    Gosub LIENS
  Endif
  If !GIMPORT
    Affzo [ACLA1]
    Affzo [ACLA2]
    Affzo [ACLA5]
    Affzo [ACLA6]
    Affzo [ACLA3]
    Affzo [ACLA4]
  Endif
Return

#--------------------------------#
$RAZDUP
Local Integer I
For I=0 To [M:ACLA1]NBRTRT
 If [M:ACLA1]TYPTRT(I)=1
  Dela I,1 [M:ACLA1]NBRTRT
  [M:ACLA1]NBRTRT -=1
  I-=1
 Endif
Next I
Affzo [M:ACLA1]20
Return

#--------------------------------#
$RAZCRE
# methodes standard
nolign = 0
For GBIDC1 ="C","R","U","D","P"
 nolign += 1
 [M:ACLA5]CODMETSTD(nolign-1) = GBIDC1
 Call LECTEXTRA([M]INTITMETSTD(nolign-1),"ATABDIV","LNGDES","921",GBIDC1) From ATEXTRA
Next
[M:ACLA5]NBMETSTD = nolign
Affzo [M:ACLA5]
Return

#--------------------------------#
$INICRE
$INIMOD
If !find([M]TYPCLA,1,2) or [M]FLGBUFFER=2 : Return : Endif
$ADDFLDSYS
# Rajout des champs Syracuse
Local Integer L,M,K
K = [M:ACLA6]NBRFLD
For I=1 To dim(FLDSYS)
 If FLDSYS(I)<>"" & !find(FLDSYS(I),[M:ACLA6]FLDCLA(0..[M:ACLA6]NBRFLD-1))
  [M:ACLA6]NBRFLD += 1
  [M:ACLA6]FLDCLA([M:ACLA6]NBRFLD-1) = FLDSYS(I)
  [M:ACLA6]CODTYP([M:ACLA6]NBRFLD-1)  = TYPFLD(I)
  If I = 1
   # + 500 : try best to make sure that the 5 system fields are at the end of the list
   [M:ACLA6]NUMFLD([M:ACLA6]NBRFLD-1)   = max([M:ACLA6]NUMFLD)+500
  Else
   [M:ACLA6]NUMFLD([M:ACLA6]NBRFLD-1)   = max([M:ACLA6]NUMFLD)+10
  Endif
  [M:ACLA6]FLDGRP([M:ACLA6]NBRFLD-1)    = ""
  [M:ACLA6]INTFLD([M:ACLA6]NBRFLD-1) = [L]INTFLD(I)
  [M:ACLA6]INTSHTFLD([M:ACLA6]NBRFLD-1) = [L]INTFLD(I)
  Call TEXTE([M:ACLA6]INTFLD([M:ACLA6]NBRFLD-1),[M:ACLA6]ZINTFLD([M:ACLA6]NBRFLD-1)) From OBJDIV
  Call TEXTE([M:ACLA6]INTSHTFLD([M:ACLA6]NBRFLD-1),[M:ACLA6]ZINTSHTFLD([M:ACLA6]NBRFLD-1)) From OBJDIV
  [M:ACLA6]OBLIG([M:ACLA6]NBRFLD-1)  = 1
  If FLDSYS(I)="CREUSR" : L=[M:ACLA6]NBRFLD-1 : Endif
  If FLDSYS(I)="UPDUSR" : M=[M:ACLA6]NBRFLD-1 : Endif

  Case TYPFLD(I)
   When "AUS"
    [M:ACLA8]WCODPAR([M:ACLA8]WNBRPARALL)    = "USR"
    [M:ACLA8]WFLDCLA([M:ACLA8]WNBRPARALL)    = FLDSYS(I)
    [M:ACLA8]WTYPKEY([M:ACLA8]WNBRPARALL)    = 2
    [M:ACLA8]WNUMPAR([M:ACLA8]WNBRPARALL)    = 1
    [M:ACLA8]WTYPPAR([M:ACLA8]WNBRPARALL)    = 1
    [M:ACLA8]WVALEUR([M:ACLA8]WNBRPARALL)    = FLDSYS(I)
    [M:ACLA8]WNBRPARALL += 1
  Endcase

 Endif
Next I
If K<>[M:ACLA6]NBRFLD
 Affzo [ACLA6]
 If L :   Chgstl [ACLA6]CODTYP(L) With "AMKACT" : Endif
 If M :   Chgstl [ACLA6]CODTYP(M) With "AMKACT" : Endif
Endif
Return

#--------------------------------#
$FILGAUCHE
Case currbox
 When "GAU_CHE2" : # Interfaces
  FILGAUSUP = '[F:ACLA]TYPCLA = 5'
 When "GAU_CHE3" : # Techniques
  FILGAUSUP = '[F:ACLA]TYPCLA = 3'
 When "GAU_CHE1" : # Persistantes
  FILGAUSUP = '[F:ACLA]TYPCLA = 2'
 When "GAU_CHE4" : # Systemes
  FILGAUSUP = '[F:ACLA]TYPCLA = 4'
 When "GAU_CHE"
  FILGAUSUP = ''
Endcase
Return

#--------------------------------#
$SETBOUT
Gosub CLA_RESERVE_MB

If GMODIFPAR>0
 Local Integer MES_OK
 Call OUINON(mess(192,143,1)+"\"+mess(231,143,1),MES_OK) From GESECRAN
 If MES_OK<>2
  GMODIFPAR =0
 Endif
Endif

# Désactiver la modification/suppression si c'est une classe SYSTEM
If ([M:ACLA1]TYPCLA=4 and GADONIX<>2) or find([M:ACLA0]CODCLA,TBCLAMB(1..NBCLAMB))
 Call VIREBOUT(CHAINE,"MA") From GOBJET
Elsif [M:ACLA0]CODCLA<>"" & GMODIFPAR=1
  If !VERROU : Gosub VERROU From GOBJET : Endif
  If !VERROU
   Call ERREUR(mess(10,100,1)) From GESECRAN : # Modification en cours sur un autre poste
  Else
    REP="M" : #Activation bouton enregistrer
    Grizo [M:ACLA0]CODCLA
  Endif
  GMODIFPAR=0
Endif

If CLECUR=0 or REP="M" or (!VERROU & (dim([L]MLOCK)<=0 or ![L]MLOCK)) or find([M:ACLA0]CODCLA,TBCLAMB(1..NBCLAMB))
 Call VIREBOUT(CHAINE,"V2") From GOBJET : # Validation, Copie
 If REP="M" :  CHMEN += "4" : Endif
Else
 CHMEN +="13"
 # menu "Test" should be activated only for persistant class
 If [M:ACLA1]TYPCLA = 2
  Local Char  MACHINE(GDIMFIC), APPLI(GDIMFIC),FICLCK(GDIMFIC), NOMTRT(30)
  Call MACHINE(nomap,MACHINE,APPLI) From ORDSYS
  NOMTRT = func APREFIXTRT.GET_PREFIX_CLA_CRUD+[M:ACLA0]CODCLA
  FICLCK = filpath("TRT",NOMTRT ,"src",APPLI,"",MACHINE)
  # check if trt WMLxxx exists
  If filinfo(FICLCK,0)>=0
   CHMEN += "5"
  Endif
 Endif
Endif

If CLECUR=0 | REP<>"" | [M:ACLA0]CODCLA=""
 Call VIREBOUT(CHAINE,"7") From GOBJET : # Classes liées (Arborescence)
Endif

If [M]TYPCLA=4 & GADONIX<>2
 Call VIREBOUT(CHAINE,"V") From GOBJET : # Validation
Endif

Return

#--------------------------------#
$STYLE
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
For nolign=1 To [M:ACLA6]NBRFLD
 If find([M:ACLA6]FLDCLA(nolign-1),[M:ACLA8]WFLDCLA(0..[M:ACLA8]WNBRPARALL-1))
  Chgstl [ACLA6]CODTYP(nolign-1) With "AMKACT"
  If [ACLA6]LOBTAB(nolign-1)<>""
   Chgstl [ACLA6]LOBTAB(nolign-1) With "AMKACT"
  Endif
  If [ACLA6]LOBFLD(nolign-1)<>""
   Chgstl [ACLA6]LOBFLD(nolign-1) With "AMKACT"
  Endif
  If [ACLA6]LOBCNT(nolign-1)<>""
   Chgstl [ACLA6]LOBCNT(nolign-1) With "AMKACT"
  Endif
 Else
  Chgstl [ACLA6]CODTYP(nolign-1) With ""
  Chgstl [ACLA6]LOBTAB(nolign-1) With ""
  Chgstl [ACLA6]LOBFLD(nolign-1) With ""
  Chgstl [ACLA6]LOBCNT(nolign-1) With ""
 Endif
Next nolign
nolign=SAVNOLIGN
Return

#--------------------------------#
$EXEBOUT
Case REP
 When "V"
  OK = 2
  Call OUINON(mess(47,140,1) -CLECUR1,OK) From GESECRAN : # Validation classe
  If OK<>2 : Return : Endif
  Call VALIDATION(0,nomap,CLECUR1)
Endcase
Return

#----------------------------------------#
$STATUT
Case BOUT
 When "1" : Call VALIDATION_ALL(nomap,[M:ACLA0]CODCLA)
 When "3" : Call VALIDATION(1,nomap,[M:ACLA0]CODCLA)
 When "4" : Gosub ADDFLDSYS
 When "5":
  adxmpr = adxmpr
  Onerrgo ERRTEST
  Gosub TEST From =func ACLAVALCRUD.GET_PREFIX_CLA_READ+[M:ACLA0]CODCLA
  Onerrgo
Endcase
Return

$ERRTEST
Call ERREUR(mess(7,21,1)) From GESECRAN
Resume

#----------------------------------------#
$VERIF_CRE
$VERIF_MOD
Gosub OUVRE_ATAB
Local Integer I,J
Local Char ERRMES(250)(1..),ERRMES2(250)
Local Integer ERRFLG (1..)
Local Integer MES_OK

Gosub VERIF_ACLA

Gosub VERIF_ACLAF

Gosub VERIF_ACLAK

Gosub VERIF_ACLAO

If maxtab([L]ERRMES)=1
 If [L]ERRFLG(1)=-1
   MES_OK=1
   Call AVERTIR([L]ERRMES(1),MES_OK) From GESECRAN
   If MES_OK<>2
     OK=0 : Return
   Endif
 Else
   Call ERREUR([L]ERRMES(1)) From GESECRAN
   OK=0 : Return
 Endif
Elsif maxtab([L]ERRMES)>1
 Call OUVRE_TRACE(mess(3,140,1)-[M]CODCLA) From LECFIC
 For I=1 To maxtab([L]ERRMES)
  Call ECR_TRACE([L]ERRMES(I),[L]ERRFLG(I)) From GESECRAN
 Next
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
 If find(1,[L]ERRFLG(1..maxtab([L]ERRFLG)))
   OK=0 : Return
 Endif
Endif
Return

#----------------------------------------#
$VERIF_ACLAF
Local Char    L_MES(250)
# 1 loop on each property and check
For I=0 To [M:ACLA6]NBRFLD-1

 If [M:ACLA6]INTFLD(I)=0
  # Propriété xxx Erreur zone "" : Zone obligatoire
  L_MES=mess(34,140,1)-[M:ACLA6]FLDCLA(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-mess(32,126,1)-'"'+func AMK_TOOL.GET_FIELD_LABEL("ACLA6","ZINTFLD")+'"'
  Call ERREUR(L_MES-":"-mess(10,123,1),1,[L]ERRMES,[L]ERRFLG) From SUBASW
 Endif
 If  [M:ACLA6]INTSHTFLD(I)=0
  # Propriété xxx Erreur zone "" : Zone obligatoire
  L_MES=mess(34,140,1)-[M:ACLA6]FLDCLA(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-mess(32,126,1)-'"'+func AMK_TOOL.GET_FIELD_LABEL("ACLA6","ZINTSHTFLD")+'"'
  Call ERREUR(L_MES-":"-mess(10,123,1),1,[L]ERRMES,[L]ERRFLG) From SUBASW
 Endif

 If [M:ACLA6]LNKCLA(I)<>"" & [M:ACLA6]FLDGRP(I) =""
  # Collection obligatoire pour un pointeur
  Call ERREUR(mess(63,140,1)-[M:ACLA6]FLDCLA(I)-"("+mess(3,40,1)-num$(I+1)+")",1,[L]ERRMES,[L]ERRFLG) From SUBASW
 Endif

 If find([M:ACLA6]FLDCLA(I), [M:ACLA2]CODMET)
  # Code déjà utilisé pour une méthode ou une opération
  Call ERREUR(mess(34,140,1)-[M:ACLA6]FLDCLA(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-mess(290,143,1),1,[L]ERRMES,[L]ERRFLG) From SUBASW
 Endif

 If find([M:ACLA6]FLDCLA(I), [M:ACLA1]CODCOL) and [M:ACLA6]LNKCLA(I)=""
  # Code déjà utilisé pour une propriété ou une collection.
  Call ERREUR(mess(144,143,1)-[M:ACLA6]FLDCLA(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-mess(146,143,1),1,[L]ERRMES,[L]ERRFLG) From SUBASW
 Endif

 If !find([M:ACLA6]FLDGRP(I),[M]CODCOL(0..[M]NBRCOL-1)) & [M:ACLA6]FLDGRP(I)<>""
  # Collection inexistante.
  Call ERREUR(mess(34,140,1)-[M:ACLA6]FLDCLA(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-mess(144,143,1)-":"-[M:ACLA6]FLDGRP(I),1,[L]ERRMES,[L]ERRFLG) From SUBASW
 Endif

 # check that :
 # a colleciton applied to an instance must have the same code of the instance
 # a collection can not be used both for instance and property
 If [M:ACLA6]LNKCLA(I)<>"" and [M:ACLA6]FLDGRP(I)<>"" and [M:ACLA6]FLDGRP(I)<>[M:ACLA6]FLDCLA(I)
  # Collection d'une propriété d'instance doit avoir le même code que le code de la propriété.
  Call ERREUR(mess(34,140,1)-[M:ACLA6]FLDCLA(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-mess(150,143,1),1,[L]ERRMES,[L]ERRFLG) From SUBASW
 Elsif [M:ACLA6]LNKCLA(I)="" and [M:ACLA6]FLDGRP(I)<>""
  For J = 0 To [M:ACLA6]NBRFLD-1
   If [M:ACLA6]LNKCLA(J)<>""
    If ([M:ACLA6]FLDGRP(I) = [M:ACLA6]FLDCLA(J)) or ([M:ACLA6]FLDGRP(I) = [M:ACLA6]FLDGRP(J))
     # Collection déjà utilisé pour une propriété d'instance.
     Call ERREUR(mess(34,140,1)-[M:ACLA6]FLDCLA(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-mess(151,143,1),1,[L]ERRMES,[L]ERRFLG) From SUBASW
    Endif
   Endif
  Next
 Endif

 #Check ATYPE & LOBTAB+LOBFLD
 If [M:ACLA6]CODTYP(I)<>""
   If !find([M]TYPCLA,3,4)
     Read [ATY]CODTYP=[M:ACLA6]CODTYP(I)
     If [F:ATY]TYPSELSYR=3 & [F:ATY]TYPPROSYR=""
        #Le prototype est obligatoire pour utiliser un type de données Rich media
        Call ERREUR(mess(34,140,1)-[M:ACLA6]FLDCLA(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-mess(249,143,1),1,[L]ERRMES,[L]ERRFLG) From SUBASW
     Elsif [F:ATY]TYPSELSYR=3 & [F:ATY]SUPFLG=2
       If [M:ACLA6]LOBTAB(I)="" | [M:ACLA6]LOBFLD(I)=""
        #La table et le champ du lob sont obligatoires pour un type de données Rich media avec gestion superviseur
        Call ERREUR(mess(34,140,1)-[M:ACLA6]FLDCLA(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-mess(180,143,1),1,[L]ERRMES,[L]ERRFLG) From SUBASW
       Endif
#     Elsif [F:ATY]TYPSELSYR=3 & [F:ATY]SUPFLG=1
#       For J=6 To 9
#        Read [ATYR]ATYR0=[M:ACLA6]CODTYP(I);J
#        If fstat
#          # Les règles $1$ \sont obligatoires pour le type "$2$" sans gestion superviseur
#          Call ERREUR(mess(34,140,1)-[M:ACLA6]FLDCLA(I)-":"-func AFNC.MES2(mess(163,143,1),
#&                     mess(6,7961,1)-mess(7,7961,1)-mess(8,7961,1)-mess(9,7961,1),
#&                     mess(3,7881,1)),1,[L]ERRMES,[L]ERRFLG) FROM SUBASW
#          OK = 0
#          Break 2
#        Endif
#       Next J
     Endif
     #106394
     If [F:ATY]TYPSELSYR=3 & [F:ATY]SUPFLG=2 & [M]TABREF<>"" & [M:ACLA6]LOBTAB(I)<>[M]TABREF
      Read [ATZ]CODZONE=[M]TABREF;[M:ACLA6]FLDCLA(I)
      If !fstat
        #La table indiquée est $2$ alors qu'il existe un champ de même nom dans la table $1$ associée à la classe
        Call ERREUR(mess(34,140,1)-[M:ACLA6]FLDCLA(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-func AFNC.MES2(mess(288,143,1),[M]TABREF,[M:ACLA6]LOBTAB(I)),1,[L]ERRMES,[L]ERRFLG) From SUBASW
      Endif
     Endif
   Endif
   # check TABCONT
   If [M:ACLA6]TABCONT(I)<>""
    If !func SUBACLA2.L_CHECK_PARAMETER([M:ACLA6]FLDCLA(I),[M:ACLA6]CODTYP(I),"TABCONT",[M:ACLA6]ACTFLD(I),[M:ACLA6]TABCONT(I),[F:ATY]TYPTYP ,2,[M:ACLA6]FLDGRP(I), [M:ACLA0]CODCLA, 1,ERRMES2)
     Call ERREUR(mess(34,140,1)-[M:ACLA6]FLDCLA(I)-"("+mess(3,40,1)-num$(I+1)+")"-":"-mess(66,00139,1)-ERRMES2,1,[L]ERRMES,[L]ERRFLG) From SUBASW
    Endif
   Endif

 Endif


Next

# 4 verify that each parameter/key related to the properties has a value NOT empty
Local Char L_PROPERTY(250)
Local Integer L_RES,L_NUM
For I=0 To [M:ACLA8]WNBRPARALL-1
 If [M:ACLA8]WTYPPAR(I)=1 & [M:ACLA8]WVALEUR(I)="" & [M:ACLA8]WISKEY(I)<>2 & [M:ACLA8]WCODPAR(I)<>"AFILTER"
  J = find([M:ACLA8]WFLDCLA(I), [M:ACLA6]FLDCLA)
  If J > 0
   L_RES = instr(1,L_PROPERTY,[M:ACLA8]WFLDCLA(I))
   If L_RES = 0
    L_PROPERTY+=[M:ACLA8]WFLDCLA(I)+"("+mess(3,40,1)-num$(J)+")"
    L_NUM+=1
    If L_NUM=10
     L_PROPERTY+="..." : Break
    Else
     L_PROPERTY+=", "
    Endif
   Endif
  Endif
 Endif
Next
If L_PROPERTY <> ""
 # Veuillez vérifier les paramètres et les clés liées aux propriétés(ou liens) suivantes: L_PROPERTY ils ne peuvent pas être vides
 Call ERREUR(func AFNC.MES1(mess(110,143,1), L_PROPERTY),-1,[L]ERRMES,[L]ERRFLG) From SUBASW
Endif

# 5 verify that each parameter/key related to the properties has a value that is coherent with the type
Local Char L_ERR_MSG(250), L_PARCOL(30)
For I=0 To [M:ACLA8]WNBRPARALL-1
 #If [M:ACLA8]WTYPPAR(I)=1 & [M:ACLA8]WISKEY(I)<>2 & [M:ACLA8]WCODPAR(I)<>"AFILTER"
 If [M:ACLA8]WTYPPAR(I)=1 & [M:ACLA8]WISKEY(I)<>2
  Raz L_ERR_MSG, L_PARCOL
  J = find([M:ACLA8]WFLDCLA(I), [M:ACLA6]FLDCLA)
  If J > 0
   L_PARCOL = [M:ACLA6]FLDGRP(J-1)
   If !func SUBACLA2.L_CHECK_PARAMETER([M:ACLA6]FLDCLA(J-1),[M:ACLA6]CODTYP(J-1),[M:ACLA8]WCODPAR(I),[M:ACLA6]ACTFLD(J-1) ,[M:ACLA8]WVALEUR(I), [M:ACLA8]WTYPINTPAR(I), [M:ACLA8]WADRVAL(I), L_PARCOL,
&                      [M:ACLA0]CODCLA, 1, L_ERR_MSG)
    If [M:ACLA8]WTYPKEY(I) = 2
     L_ERR_MSG = mess(34,140,1)-'"'+[M:ACLA8]WFLDCLA(I)-"("+mess(3,40,1)-num$(J)+")"+'"'-mess(51,140,1)-'"'+[M:ACLA8]WCODPAR(I)+'" : '+L_ERR_MSG
    Else
     L_ERR_MSG = mess(34,140,1)-'"'+[M:ACLA8]WFLDCLA(I)-"("+mess(3,40,1)-num$(J)+")"+'"'-mess(50,140,1)-'"'+[M:ACLA8]WCODPAR(I)+'" : '+L_ERR_MSG
    Endif
    Call ERREUR(L_ERR_MSG,-1,[L]ERRMES,[L]ERRFLG) From SUBASW
   Endif
  Endif
 Endif
Next
Return
#----------------------------------------#
$VERIF_ACLAO
Local Integer I
Local Char L_ERR_MSG(250)
# check options
For I=0 To [M:ACLA4]NBROPT-1
 If func SUBASW2.CONTROL_SDATA([M:ACLA4]OPTCND(I),L_ERR_MSG)=0
  Call ERREUR(mess(245,143,1)-[M:ACLA4]OPTCOD(I)-":"-L_ERR_MSG,1,[L]ERRMES,[L]ERRFLG) From SUBASW
 Endif
Next
Return
#----------------------------------------#
$VERIF_ACLAK
# 2 loop on each linked table and check
For I = 0 To [M:ACLA3]NBRLNK-1
 If [M:ACLA3]CLALNK(I)=[M:ACLA0]CODCLA and [M:ACLA3]FLGA(I) = 2
  Call ERREUR(func AMK_TOOL.GET_FIELD_LABEL("ACLA3", "REFLNK")-[M:ACLA3]REFLNK(I)+": "+func AMK_TOOL.GET_FIELD_LABEL("ACLA3", "FLGA")+": "+mess(153,143,1),1,[L]ERRMES,[L]ERRFLG) From SUBASW # Gestion
# par classe
 Else
  Read [ACLA]ACLA0 = [M:ACLA3]CLALNK(I)
  If fstat
   Call ERREUR(func AMK_TOOL.GET_FIELD_LABEL("ACLA3", "REFLNK")-[M:ACLA3]REFLNK(I)+": "+mess(4,140,1),1,[L]ERRMES,[L]ERRFLG) From SUBASW # Classe inexistante
  Elsif !find([F:ACLA]TYPCLA,2,5)>0 and [M:ACLA3]FLGA(I) = 2
   Call ERREUR(func AMK_TOOL.GET_FIELD_LABEL("ACLA3", "REFLNK")-[M:ACLA3]REFLNK(I)+": "+func AMK_TOOL.GET_FIELD_LABEL("ACLA3", "FLGA")+": "+mess(153,143,1),1,[L]ERRMES,[L]ERRFLG) From SUBASW # Gestion
# par classe
  Endif
 Endif
Next

# 3 verify that the properties required for the index key are created.
Local Char CHAINE (250)
[M:ACLA1]KEYINT = vireblc( [M:ACLA1]KEYINT,4)
CHAINE = [M:ACLA1]KEYINT
Gosub L_DEFCLE
Local Integer L_INDEX
For I=1 To NBCLE
 L_INDEX = find(CLE(I),[M]FLDCLA(0..[M]NBRFLD-1))
 If !L_INDEX
  Call ERREUR(func AFNC.MES1(mess(133,143,1), CLE(I)),1,[L]ERRMES,[L]ERRFLG) From SUBASW # Veuillez créer une propriété $1$ pour le clé du table principale avec le même type de donnée.
 Elsif [M:ACLA1]WTABREF <> ""
  Read [F:ATZ]CODZONE=[M:ACLA1]WTABREF;[L]CLE(I)
  Read [F:ATY]CODTYP = [F:ATZ]CODTYP
  Read [F:ATY2]CODTYP = [M:ACLA6]CODTYP(L_INDEX-1)
  If [F:ATY2]TYPTYP <> [F:ATY]TYPTYP
   Call ERREUR(func AFNC.MES1(mess(133,143,1), CLE(I)),1,[L]ERRMES,[L]ERRFLG) From SUBASW # Veuillez créer une propriété $1$ pour le clé du table principale avec le même type de donnée.
  Endif
 Endif
Next I
Return

#----------------------------------------#

$VERIF_ACLA
If [M]TYPCLA=5 & [M]KEYINT="":
 Call ERREUR(mess(1,7940,1)-":"-mess(10,123,1) ,1,[L]ERRMES,[L]ERRFLG) From SUBASW
Endif
If [M]INTCLA=0
 Call ERREUR(mess(30,109,1)-":"-mess(10,123,1) ,1,[L]ERRMES,[L]ERRFLG) From SUBASW
Endif
Return


#----------------VERIF_CRE/VERIF_MOD internal use only-------------------#
$L_DEFCLE
Local Integer NBCLE , K , L
Local Char    CLE(GLONAVA)(1..16)
NBCLE = 0
While CHAINE<>""
 K = instr(1,CHAINE,"+")
 L = instr(1,CHAINE,"-")
 If K & L
  K = min(K,L)
 Elsif L & !K
  K = L
 Endif
 NBCLE += 1
 If K
  CLE(NBCLE) = left$(CHAINE,K-1)
  CHAINE = right$(CHAINE,K+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
Wend
Return


#----------------------------------------#
Subprog PATCH(APPLI)
Value Char APPLI
Call GENDOS(APPLI)
End

#----------------------------------------#
Subprog GENDOS(APPLI)
Value Char APPLI
If clalev([F:AS3])=0     : Local File =APPLI+".ACLASSE"    [AS3]   : Endif
For [AS3] Where TYPCLA<>4 & FLGACTX <> 2 & CODCLA<>"AISNULL"
 Call VALIDATION(0,APPLI,[AS3]CODCLA)
Next AS3
End

#----------------------------------------#
Subprog VALIDATION(TEST,DOSSIER,CODCLA)
Value Integer TEST
Value Char    DOSSIER , CODCLA

If CODCLA="OBJECT" : End : Endif

Local Integer OK,TYPAGE,STAT

If DOSSIER=nomap
 Local File ACLASSE    [ACLA]
Else
 Local File =DOSSIER+".ACLASSE"    [ACLA]
Endif
Read [ACLA]ACLA0=CODCLA
If fstat : End : Endif

#Validation différée (à la volée)
If dim(GVALIDDIFF)>0 and GVALIDDIFF=3
  Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC), FICANU(GDIMFIC)
  Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

  If GTRACE<>""
    Call ECR_TRACE(mess(53,140,1)-CODCLA,0) From GESECRAN : # Validation différée de la classe
  Endif
#  FICANU = filpath("STC",func PREFIX_CLA+CODCLA,"stc",APPLI,"",MACHINE)
#  If filinfo(FICANU,0)>=0
#   Call EFFACE(FICANU,STAT) From ORDSYS
#  Endif
  #90822
  #Call EFFACE_STC(MACHINE,APPLI,func PREFIX_CLA+CODCLA,STAT) From ORDSYS
  Call INVALID_STC(MACHINE,APPLI,func PREFIX_CLA+CODCLA,STAT) From ORDSYS
  OK = pullObject(MACHINE,APPLI,func PREFIX_CLA+CODCLA )
  If [L]TEST & GTRACE<>""
   If OK<0
   Call ECR_TRACE(" -"-CODCLA-"INVALID_STC="+num$(STAT)-"PULLOBJECT="+num$(OK),-1) From GESECRAN
   Else
   Call ECR_TRACE(" -"-CODCLA-"INVALID_STC="+num$(STAT)-"PULLOBJECT="+num$(OK),0) From GESECRAN
   Endif
  Endif
Else
  If [ACLA]TYPCLA<>4
   Call VALIDATION([L]TEST,[L]CODCLA,[L]DOSSIER,0,1,0,[L]TYPAGE,[L]OK) From ACLAVAL
  Else
   Call VALIDATION([L]TEST,[L]CODCLA,[L]DOSSIER,0,0,[L]TYPAGE,[L]OK) From ACLAVALTECH
  Endif
Endif
Close Local File [ACLA]
End


#----------------------------------------#
Subprog VALIDATION_ALL(DOSSIER,CODREP)
Value Char DOSSIER
Value Char    CODREP
Local Integer OK ,I,TYPAGE
Local Char TBCLA(GLONACLA)(1..)

If DOSSIER=nomap
 If clalev([F:ACLA])=0 : Local File ACLASSE    [ACLA] : Endif
 If clalev([F:ACLAF])=0 : Local File ACLAFLD    [ACLAF] : Endif
Else
 If clalev([F:ACLA])=0 : Local File =DOSSIER+".ACLASSE"    [ACLA] : Endif
 If clalev([F:ACLAF])=0 : Local File =DOSSIER+".ACLAFLD"    [ACLAF] : Endif
Endif

Read [ACLA]ACLA0=CODCLA
If fstat : End : Endif

TBCLA(1) = [F:ACLA]CODCLA
For [ACLAF]ACLAF0 Where CODCLA=TBCLA(1) & [ACLAF]LNKCLA<>""
 If !find([ACLAF]LNKCLA,TBCLA)
  Call CHARGE_TBCLA(nomap,[ACLAF]LNKCLA,TBCLA) From SUBASW
 Endif
Next

Call OUVRE_TRACE(mess(1,140,1)-CODCLA) From LECFIC
For I=maxtab([L]TBCLA) To 1 Step -1
 #Call VALIDATION(0,[L]TBCLA(I),DOSSIER,0,1,0,[L]TYPAGE,OK) From ACLAVAL
 Call VALIDATION(0,DOSSIER,[L]TBCLA(I))
Next

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

End

#--------------------------------#
$LIENS
# case where ATB was closed by the jump in GESATB or GESAVW
If !clalev([F:ATB]) : Local File AVIEWTAB [ATB] : Endif
If !clalev([F:ATZ]) : Local File AVIEWFLD [ATZ] : Endif
If !clalev([F:ATI])  : Local File AVIEWIND [ATI] : Endif
If dim([F:ATB]ISTABLE)<0
 Gosub OUVRE_ATAB
Endif

# Entete Classe
Gosub LOAD_ACLA

# Méthodes
Gosub LOAD_ACLAM

# methodes standard
Gosub LOAD_ACLAT

# Proprietes
Gosub LOAD_ACLAF

# Mapping
Gosub LOAD_ACLAK

# Options
Gosub LOAD_ACLAO

Return

#--------------------------------#
$LOAD_ACLAK
If [M]TYPCLA=2 : # Persitante
 Local Integer SAVNOLIGN : SAVNOLIGN=nolign
 nolign = 0
 For [ACLAK]ACLAK1 Where CODCLA=[M]CODCLA
  nolign += 1
  [M:ACLA3] = [F:ACLAK]
  [M:ACLA3]REFLNKCUR = [F:ACLAK]REFLNK
  Gosub ADD_LNKCURMAP From SUBACLA2
#  For [F:ACLAKP]ACLAKP1 Where CODCLA=[M]CODCLA & REFLNK = [F:ACLAK]REFLNK
#   [M:ACLA3]WKEYMAP([M:ACLA3]WNBRPROMAP) = [F:ACLAKP]KEYMAP
#   [M:ACLA3]WPROMAP([M:ACLA3]WNBRPROMAP) = [F:ACLAKP]PROMAP
#   [M:ACLA3]WREFLNK([M:ACLA3]WNBRPROMAP) = [F:ACLAKP]REFLNK
#   [M:ACLA3]WNBRPROMAP += 1
#  Next
 Next
 [M:ACLA3]NBRLNK = nolign
 For I=0 To [M:ACLA3]WNBRPROMAP-1
  Read [F:ACLAKP]ACLAKP0 = [M]CODCLA;[M:ACLA3]WREFLNK(I);[M:ACLA3]WKEYMAP(I)
  If !fstat
   [M:ACLA3]WPROMAP(I) = [F:ACLAKP]PROMAP
   [M:ACLA3]WVALDEFMAP(I) = [F:ACLAKP]VALDEFMAP
  Endif
 Next
 Read [ATB]CODFIC = [M]TABREF
 [M]CONCATREF = format$("K:"+num$(GLONATB)+"X",[M]TABREF)+[F:ATB]ABRFIC
 For I=1 To [M]NBRLNK
  If [M]ABRLNK(I-1)<>""
   [M]CONCATLNK(I-1) = format$("K:"+num$(GLONATB)+"X",[M]TABLNK(I-1))+[M]ABRLNK(I-1)
  Else
   Read [ATB]CODFIC = [M]TABLNK(I-1)
   [M]CONCATLNK(I-1) = format$("K:"+num$(GLONATB)+"X",[M]TABLNK(I-1))+[F:ATB]ABRFIC
  Endif
 Next I
 nolign=SAVNOLIGN
Endif
Call AS_NBRLNK From SUBACLA2
$GRISE_ACLAK
If [M]TYPCLA=2 : # Persitante
 Actzo [M:ACLA3]
 Gosub GRISE_FLG
 Grizo [M:ACLA1]KEYINT
 If [M]FLGBUFFER=2
  Effzo [M:ACLA3]20
  Grizo [M:ACLA3]20
 Endif
Elsif [M]TYPCLA = 5
 Raz [M:ACLA1]WTABREF : Grizo [M:ACLA1]WTABREF
 Raz [M:ACLA1]WINDREF : Grizo [M:ACLA1]WINDREF
 Actzo [M:ACLA1]KEYINT
 Effzo [M:ACLA3]
 Grizo [M:ACLA3]
Else
 Effzo [M:ACLA3]
 Grizo [M:ACLA3]
 Raz [M:ACLA1]WTABREF : Grizo [M:ACLA1]WTABREF
 Raz [M:ACLA1]WINDREF : Grizo [M:ACLA1]WINDREF
 Effzo [M:ACLA1]KEYINT
 Grizo [M:ACLA1]KEYINT
Endif
Return

#--------------------------------#

$LOAD_ACLAO
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
If [M]TYPCLA=2 : # Persitante
 [M:ACLA4]NBROPT=0
 nolign = 0
 For [ACLAO] Where CODCLA=[M]CODCLA
  nolign += 1
  [M:ACLA4] = [F:ACLAO]
  Call TEXTE([M:ACLA4]OPTLIB(nolign-1),[M:ACLA4]AZOPTLIB(nolign-1)) From OBJDIV
  Call TEXTE([M:ACLA4]OPTERR(nolign-1),[M:ACLA4]AZOPTERR(nolign-1)) From OBJDIV
 Next
 [M:ACLA4]NBROPT=nolign
 nolign=SAVNOLIGN
Endif
$GRISE_ACLAO
If [M]TYPCLA=2
 Actzo [M:ACLA4]
Elsif find([M]TYPCLA,1,5)>0
 Actzo  [M:ACLA4]
 Effzo   [M:ACLA4]40
 Grizo   [M:ACLA4]40
 Effzo   [M:ACLA4]45
 Grizo   [M:ACLA4]45
Else
 Effzo [M:ACLA4]
 Grizo [M:ACLA4]
Endif
Return


#--------------------------------#
$LOAD_ACLA
[M:ACLA1]WTABREF =  [M:ACLA3]TABREF
[M:ACLA1]WINDREF =  [M:ACLA3]INDREF

Call TEXTE([M]INTCLA,[M:ACLA0]ZINTCLA) From OBJDIV

# RBU-20150505 - SAM 108321
If [M]TYPCLA=2
 Read [ATB]CODFIC = [M:ACLA1]WTABREF
 If !fstat
  If [F:ATB]ISTABLE=2
   [M]WINT = mess(56,123,1) : # table
   [M]ISTABLE = [F:ATB]ISTABLE
  Else
   [M]WINT = mess(77,139,1) : # Vue
   [M]ISTABLE = [F:ATB]ISTABLE
  Endif
 Endif
 Read [ATI]CODIND =  [M:ACLA3]TABREF;[M:ACLA3]INDREF
 If !fstat
  [M:ACLA3]AFFIND = [F:ATI]DESCRIPT
  [M:ACLA1]KEYINT = [F:ATI]DESCRIPT
 Endif
Elsif [M]TYPCLA=5
 [M]ISTABLE = 3 :# Interface
Endif

# Collections
Gosub LOAD_ACLAC
$GRISE_ACLA
If [M]TYPCLA<>2
 Raz [M:ACLA1]WTABREF : Grizo [M:ACLA1]WTABREF
 Raz [M:ACLA1]WINDREF : Grizo [M:ACLA1]WINDREF
 Raz [M:ACLA1]FLGSEARCH : Grizo [M:ACLA1]FLGSEARCH
Else
 Actzo [M:ACLA1]WTABREF
 Actzo [M:ACLA1]WINDREF
 Read [F:ATB]CODFIC = [M:ACLA1]WTABREF
 # RBU-20150505 - SAM 108321
 If instr(1,[F:ATB]CODFIC,mess(77,139,1))=0
  Actzo [M:ACLA1]FLGSEARCH
 Else
  Raz [M:ACLA1]FLGSEARCH : Grizo [M:ACLA1]FLGSEARCH
 Endif
Endif
If [M]TYPCLA=5
 Actzo [M:ACLA1]FLGTR
Elsif [M]TYPCLA=2
 [M:ACLA1]FLGTR =2
 Grizo [M:ACLA1]FLGTR
 Affzo [M:ACLA1]FLGTR
Else
 Grizo [M:ACLA1]FLGTR
Endif
If [M]FLGBUFFER=2
 Effzo [M:ACLA1]15
 Grizo [M:ACLA1]15
Else
 Actzo [M:ACLA1]15
 For I=0 To [M]NBRCOL-1
  If [M:ACLA1]MINCOL(I)= 3
   [M:ACLA1]FLGINSCOL(I)=1 : Affzo [M:ACLA1]FLGINSCOL(I): Grizo [M:ACLA1]FLGINSCOL(I)
   [M:ACLA1]FLGSUPCOL(I)=1 : Affzo [M:ACLA1]FLGSUPCOL(I) :Grizo [M:ACLA1]FLGSUPCOL(I)
   [M:ACLA1]FLGAPDCOL(I)=1 : Affzo [M:ACLA1]FLGAPDCOL(I) :Grizo [M:ACLA1]FLGAPDCOL(I)
   [M:ACLA1]FLGTRICOL(I)=1 : Affzo [M:ACLA1]FLGTRICOL(I) :Grizo [M:ACLA1]FLGTRICOL(I)
  Endif
 Next
Endif
Return


#------------------------------#
$LOAD_ACLAC
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
[M:ACLA1]NBRCOL = 0
nolign=0
For [ACLAC]ACLAC0 Where CODCLA=[M]CODCLA
  nolign+=1
 [M:ACLA1] = [F:ACLAC]
 Call TEXTE([M:ACLA1]INTCOL(nolign-1),[M:ACLA1]INTITCOL(nolign-1)) From OBJDIV
 If [M:ACLA1]ACTCOL(nolign-1)<>""
  Read [ACV]CODACT = [M:ACLA1]ACTCOL(nolign-1)
  If !fstat
   [M:ACLA1]MAXCOL(nolign-1) = [F:ACV]DIME
  Endif
 Endif
Next
[M:ACLA1]NBRCOL=nolign
nolign=SAVNOLIGN
Return


#------------------------------#
$LOAD_ACLAF
Local Integer I,J,K
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
nolign = 0
[M:ACLA8]WNBRPARALL = 0
For [ACLAF]ACLAF2 Where CODCLA=[M:ACLA0]CODCLA
 nolign += 1
 [M:ACLA6] = [F:ACLAF]
 Call TEXTE([F:ACLAF]INTFLD,[M:ACLA6]ZINTFLD(nolign-1)) From OBJDIV
 Call TEXTE([F:ACLAF]INTSHTFLD,[M:ACLA6]ZINTSHTFLD(nolign-1)) From OBJDIV
 Read [ATY]CODTYP = [F:ACLAF]CODTYP
 If !fstat
  [M:ACLA6]FLDCUR = [ACLAF]FLDCLA
  If [ACLAF]LOBTAB=""
   [M:ACLA6]CODTYPCUR = [ACLAF]CODTYP
  Else
   [M:ACLA6]CODTYPCUR  = [ACLAF]CODTYP + "." +[ACLAF]LOBTAB+"."+[ACLAF]LOBFLD
  Endif
  For [ACLFP] Where CODCLA=[M:ACLA0]CODCLA & TYPPAR=2 & TYPKEY=1 & FLDCLA=[F:ACLAF]FLDCLA
   [M:ACLA8]WCODTYP([M:ACLA8]WNBRPARALL)    = [F:ACLAF]CODTYP
   [M:ACLA8]WCODPAR([M:ACLA8]WNBRPARALL)    = [F:ACLFP]CODPAR
   [M:ACLA8]WFLDCLA([M:ACLA8]WNBRPARALL)    = [F:ACLFP]FLDCLA
   [M:ACLA8]WTYPINTPAR([M:ACLA8]WNBRPARALL) = [F:ACLFP]TYPINT
   [M:ACLA8]WTYPKEY([M:ACLA8]WNBRPARALL)    = [F:ACLFP]TYPKEY
   [M:ACLA8]WNUMPAR([M:ACLA8]WNBRPARALL)    = [F:ACLFP]NUMPAR
   [M:ACLA8]WTYPPAR([M:ACLA8]WNBRPARALL)    = [F:ACLFP]TYPPAR
   [M:ACLA8]WVALEUR([M:ACLA8]WNBRPARALL)    = [F:ACLFP]VALEUR
   [M:ACLA8]WISKEY([M:ACLA8]WNBRPARALL)     = 1
   [M:ACLA8]WNBRPARALL += 1
  Next
  Call L_LOAD_PARAM_ATY(nomap, [M:ACLA0]CODCLA, [F:ATY]CODTYP, [M:ACLA6]FLDCUR, 1, 1) From SUBACLA2
  If [ATY]CODCLA<>""
   Gosub L_LOAD_KEY From SUBACLA2
  Endif
  #97530
  J=0
  For I=0 To [M:ACLA8]WNBRPARALL-1
   If [M:ACLA8]WFLDCLA(I)=[M:ACLA6]FLDCUR & [M:ACLA8]WTYPKEY(I)=2  & [M:ACLA8]WCODTYP(I)=[M:ACLA6]CODTYPCUR
    J+=1
    K=I
   Endif
  Next
  If J=1 & [M:ACLA8]WVALEUR(K)=""
   [M:ACLA8]WVALEUR(K)= [M:ACLA6]FLDGRP(nolign-1)+string$([M:ACLA6]FLDGRP(nolign-1)<>"",".")+[M:ACLA6]FLDCUR
#    [M:ACLA6]VALCLE(0)=[M:ACLA8]WVALEUR(K)
#    Affzo [M:ACLA6]VALCLE(0)
  Endif
  #
  If [F:ATY]TYPSELSYR=3 & [F:ATY]SUPFLG=2
   Gosub L_LOAD_MEDIA From SUBACLA2
  Endif
  [M:ACLA6]FLDCUR=""
  [M:ACLA6]CODTYPCUR=""
 Endif
Next
[M:ACLA6]NBRFLD = nolign
nolign=SAVNOLIGN
Call AS_NBRFLD From SUBACLA2
Return


#------------------------------#
$LOAD_ACLAM
If [M:ACLA1]TYPCLA <> 4
 # Méthodes
 Local Integer SAVNOLIGN : SAVNOLIGN=nolign
 nolign = 0
 For [ACLAM]ACLAM0 Where CODCLA=[M]CODCLA
  nolign += 1
  [M:ACLA2] = [ACLAM]
  Call TEXTE([F:ACLAM]INTMET,[M:ACLA2]INTITMET(nolign-1)) From OBJDIV
 Next
 [M:ACLA2]NBMET = nolign
 nolign=SAVNOLIGN

 # parametres methodes
 [M:ACLA7]NBRPARDEF=0
 For [ACLPD] Where CODCLA=[M]CODCLA
  [M:ACLA7]CODE([M:ACLA7]NBRPARDEF)   = [ACLPD]CODE
  [M:ACLA7]CODPAR([M:ACLA7]NBRPARDEF) = [ACLPD]CODPAR
  [M:ACLA7]TYPINTPAR([M:ACLA7]NBRPARDEF) = [ACLPD]TYPINTPAR
  [M:ACLA7]MODPAR([M:ACLA7]NBRPARDEF) = [ACLPD]MODPAR
  [M:ACLA7]INTPAR([M:ACLA7]NBRPARDEF) = [ACLPD]INTPAR
  [M:ACLA7]CLAPAR([M:ACLA7]NBRPARDEF) = [ACLPD]CLAPAR
  [M:ACLA7]NOPAR([M:ACLA7]NBRPARDEF)  = [ACLPD]NOPAR
  [M:ACLA7]DIMPAR([M:ACLA7]NBRPARDEF) = [ACLPD]DIMPAR
  [M:ACLA7]TYPKEY([M:ACLA7]NBRPARDEF) = [ACLPD]TYPKEY
  [M:ACLA7]NBRPARDEF += 1
 Next
Endif
Call AS_NBMET From SUBACLA2
$GRISE_ACLAM
If [M]TYPCLA=4 or [M]FLGBUFFER=2
 Grizo [M:ACLA2]: # System
 Gosub L_CLEAN_METHOD From SUBACLA2
Else
 Actzo [M:ACLA2]
Endif
Return

#------------------------------#
$LOAD_ACLAT
If !find([M]TYPCLA,3,4)>0
 Local Integer SAVNOLIGN : SAVNOLIGN=nolign
 nolign = 0
 For I=0 To len(mess(0,7983,1))
  If find(I,1,2,7,10,6)>0 : # "C","R","U","D","P","T" (Duplicate-9 off)
   nolign += 1
   [M:ACLA5]CODMETSTD(nolign-1) = mid$(mess(0,7983,1),I,1)
   [M]INTITMETSTD(nolign-1) = mess(I,7983,1)
   Read [ACLAT]ACLAT0 = [F:ACLA]CODCLA;[M:ACLA5]CODMETSTD(nolign-1)
   If !fstat
    [M:ACLA5] = [ACLAT]
   Endif
  Endif
 Next
 [M:ACLA5]NBMETSTD = nolign
 nolign=SAVNOLIGN
 Affzo [M:ACLA5]
Endif
If [M:ACLA1]FLGBUFFER=2
 For I=0 To [M:ACLA5]NBMETSTD-1
  If [M:ACLA5]CODMETSTD(I)<>"R"
   [M:ACLA5]ACSMETSTD(I)= ""
   [M:ACLA5]ACTMETSTD(I) =""
   [M:ACLA5]ENAMETSTD(I) = 1
  Else
   [M:ACLA5]ENAMETSTD(I) = 2
  Endif
 Next
Endif
$GRISE_ACLAT
If find([M]TYPCLA,3,4)>0
 Effzo [M:ACLA5]
 Grizo [M:ACLA5]
Else
 Actzo [M:ACLA5]
Endif
Return

