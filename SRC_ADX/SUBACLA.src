$MODIF
Delete [ACLAO] Where CODCLA=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ACLAOPT"-CLECUR1 : Return
Endif
Delete [ACLAC] Where CODCLA=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ACLACOL"-CLECUR1 : Return
Endif
Delete [ACLAM] Where CODCLA=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ACLAMET"-CLECUR1 : Return
Endif
Delete [ACLAF] Where CODCLA=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ACLAFLD"-CLECUR1 : Return
Endif
Delete [ACLPD] Where CODCLA=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ACLAPARDEF"-CLECUR1 : Return
Endif
Delete [ACLAT] Where CODCLA=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ACLAMETSTD"-CLECUR1 : Return
Endif
Delete [ACLAK] Where CODCLA=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ACLALNK"-CLECUR1 : Return
Endif
Delete [ACLFP] Where CODCLA=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ACLAPARFLD"-CLECUR1 : Return
Endif
Delete [ACLPD] Where CODCLA=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ACLAPARDEF"-CLECUR1 : Return
Endif
Delete [ACLAKP] Where CODCLA=CLECUR1
