End TYPREF

#--------------------------------#
$SET_TYPSTR
Local Char    TYPSTR(GLONATY)(1..50) , LNKCLA(GLONACLA)(1..50)
Local Integer NBRTYS
NBRTYS = 1  : TYPSTR(NBRTYS) = "AXX" : LNKCLA(NBRTYS) = "ATEXTRA"
NBRTYS += 1 : TYPSTR(NBRTYS) = "AX1" : LNKCLA(NBRTYS) = "ATEXTRA"
NBRTYS += 1 : TYPSTR(NBRTYS) = "AX2" : LNKCLA(NBRTYS) = "ATEXTRA"
NBRTYS += 1 : TYPSTR(NBRTYS) = "AX3" : LNKCLA(NBRTYS) = "ATEXTRA"
NBRTYS += 1 : TYPSTR(NBRTYS) = "ATT" : LNKCLA(NBRTYS) = "ATEXTE"
NBRTYS += 1 : TYPSTR(NBRTYS) = "ADI" : LNKCLA(NBRTYS) = "ATABDIV"
For [ATY] Where TYPTYP=1 : # Menu local
 NBRTYS += 1
 TYPSTR(NBRTYS) = [F:ATY]CODTYP
 LNKCLA(NBRTYS) = "APLSTD"
Next ATY
Return

$GRISE_FLG
If !find([M]TYPCLA,2,5) : Return : Endif
Local Integer I
For I = 0 To [M:ACLA5]NBMETSTD-1
 If [M:ACLA5]ENAMETSTD(I) = 1
  # If a std method is deactivated, the corresponding operation for the main table should also be deactived in Mapping.
  Case [M:ACLA5]CODMETSTD(I)
   When "C" : Effzo [M:ACLA3]FLGCREF : Grizo [M:ACLA3]FLGCREF
   When "R" : Effzo [M:ACLA3]FLGRREF : Grizo [M:ACLA3]FLGRREF
   When "U" : Effzo [M:ACLA3]FLGUREF : Grizo [M:ACLA3]FLGUREF
   When "D" : Effzo [M:ACLA3]FLGDREF : Grizo [M:ACLA3]FLGDREF
  Endcase
 Elsif [M:ACLA5]ENAMETSTD(I) = 2
  # If a std method is activated, the corresponding operation for the main table should also be actived in Mapping.
  Case [M:ACLA5]CODMETSTD(I)
   When "C"  : Actzo [M:ACLA3]FLGCREF
   When "R"  : Actzo [M:ACLA3]FLGRREF
   When "U"  : Actzo [M:ACLA3]FLGUREF
   When "D"  : Actzo [M:ACLA3]FLGDREF
  Endcase
 Endif
Next
Return

#--------------------------------------------#
$SEL_TABLE
Case TABLE
 When "ASELSTR"    : OBJET = "ACLA"
Endcase
Return

$SEL_LISTE
Case LISTE
 When "ASELSTRSYS" : Gosub SEL_STRSYS
Endcase
Return

#--------------------------------------------#
$SEL_STRSYS
Local Char TEXTE(GLONDES)(1..200,1..3) , TIT(GLONDES)(0..3)
Gosub SET_TYPSTR
For I=1 To NBRTYS
 K = find(LNKCLA(I),TEX(1..NBTEX))
 If K
  TEXTE(K,3) += ","+TYPSTR(I)
 Else
  NBTEX += 1
  TEX(NBTEX) = LNKCLA(I)
  TEXTE(NBTEX,3) = TYPSTR(I)
  Read [ACLA]ACLA0 = TEX(NBTEX)
  If !fstat
   Call TEXTE([F:ACLA]INTCLA,TEXTE(NBTEX,2)) From OBJDIV
  Endif
 Endif
Next I
TIT(0) = mess(12,140,1) : # Liste des structures
TIT(1) = mess(3,140,1)  : # Structure
TIT(2) = mess(30,109,1) : # Intitulé
TIT(3) = mess(21,115,1) : # Type de données
Return

#--------------------------------------------#
$AP_ANNULE
Call DELETE_ALLSTC(APPLI,[L]CODE) From ACLAVALSUB
Return

#--------------------------------------------#
$VERF_ANU
Local Char L_ERR_MSG(250)
For [ASWK] Where [F:ASWK]CLALNK=[L]CODE & [F:ASWK]FLGSTDLNK<>2
   L_ERR_MSG = func AFNC.MES1(mess(212,143,1),[F:ASWK]CODREP)
   L_ERR_MSG += "\"+func AFNC.MES2( mess(209,143,1),[F:ASWK]CODLNK, mess([F:ASWK]AFFLNK,7965,1)-[F:ASWK]ANCLNK)
   L_ERR_MSG += "\"+mess(176,115,1)
   Call ERREUR(L_ERR_MSG) From GESECRAN
   OK = 0 :  Break
Next
If OK=0 : Return : Endif

If [M:ACLA1]TYPCLA = 4
 # C'est une classe Système, voulez-vous vraiment la supprimer ?
 OK = 2
 Call AVERTIR(mess(108,143,1),OK) From GESECRAN
 If OK=1 : OK = 0 :  Return : Endif
Endif

For [ASWK] Where [F:ASWK]CLALNK=[L]CODE & [F:ASWK]FLGSTDLNK=2
   L_ERR_MSG = func AFNC.MES1(mess(211,143,1),[L]CODE)
   Call MESSAGE(L_ERR_MSG) From GESECRAN
   Break
Next

Return

$OUVRE_ATAB
#If filinfo(filpath("FIL","AVIEWTAB","fde",nomap),0)<0
#& or filinfo(filpath("FIL","AVIEWFLD","fde",nomap),0)<0
#& or filinfo(filpath("FIL","AVIEWIND","fde",nomap),0)<0
