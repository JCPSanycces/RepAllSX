#<AdxTL>@(#)0.0.0.0 $Revision$ 
###########################################################################################
## Calcul nb de jours/heures entre 2 dates en f(calendrier)
###########################################################################################
Subprog VALORIS(DATDEB,DATFIN,MATRI,CODE,JOUR,HEURE,SITE,CTR)
Value    Date    DATDEB
Value    Date    DATFIN
Value    Char    MATRI ()
Value    Char    CODE ()
Variable Decimal JOUR
Variable Decimal HEURE
Value    Char    SITE ()
Value    Char    CTR()
Goto VALOR
################################################################################
Subprog VALORDET(DATDEB,DATFIN,MATRI,CODE,DJOUR,DHEURE,SITE,CTR,CDCG_LEG)
Value    Date    DATDEB
Value    Date    DATFIN
Value    Char    MATRI()
Value    Char    CODE ()
Variable Decimal DJOUR(1..)
Variable Decimal DHEURE(1..)
Value    Char    SITE ()
Value    Char    CTR()
Value    Char    CDCG_LEG()
Local Decimal JOUR , HEURE
Goto VALOR
################################################################################
$VALOR

Local Integer SOA_GOUVTABW            : Call GOUVTABW(SOA_GOUVTABW) From ESSGLOB_SOA
Local Char    SOA_GTPSPARINITCP (10)  : Call GTPSPARINITCP(SOA_GTPSPARINITCP) From ESSGLOB_SOA
Local Integer SOA_GTPSCREAGLOB        : Call GTPSCREAGLOB(SOA_GTPSCREAGLOB) From ESSGLOB_SOA
Local Char    SOA_GTPSPARCPA(GLONTPS) : Call GTPSPARCPA(SOA_GTPSPARCPA) From ESSGLOB_SOA
Local Char    SOA_GTPSPARCPE(GLONTPS) : Call GTPSPARCPE(SOA_GTPSPARCPE) From ESSGLOB_SOA

# These are from TRTTPS
Local Char    SOA_GTABCLE(50)(1..10000)
Local Decimal SOA_GTABJOUR(1..10000)
Local Decimal SOA_GTABHEURE(1..10000)
Local Integer SOA_GTABIND             : Call GTABIND(SOA_GTABIND) From ESSGLOB_SOA
Local Char    SOA_GMATRI(50)          : Call GMATRI(SOA_GMATRI) From ESSGLOB_SOA
Local Integer SOA_OPENED_TABLES
If dim(SOA_GOUVTABW)<0 or (dim(SOA_GOUVTABW)>0 and SOA_GOUVTABW=0)
  If dim(SOA_GOUVTABW)>0
    SOA_GOUVTABW=1
  Endif

    # decided to use clalev becuase of where this is being called
  Local Integer SOA_GTPS : Call GTPS(SOA_GTPS) From ESSGLOB_SOA
  If SOA_GTPS
    If clalev([F:PLE]) = 0 : Local File PLANEMP  [PLE] : Endif
  Endif

  If clalev([F:PLN])  = 0  :  Local File PLANTYP   [PLN]  :  Endif
  If clalev([F:WTY])  = 0  :  Local File TYPWEEK   [WTY]  :  Endif
  If clalev([F:HLY])  = 0  :  Local File HLYDAY    [HLY]  :  Endif
  If clalev([F:ADW])  = 0  :  Local File ADOVAL    [ADW]  :  Endif
  If clalev([F:TIM])  = 0  :  Local File TIMCOD    [TIM]  :  Endif   #already opened
  If clalev([F:AD])   = 0  :  Local File EMPLOAD   [AD]   :  Endif   #already opened
  If clalev([F:HRCTR])  = 0  :  Local File EMPLOCTR  [HRCTR]  :  Endif   #already opened
  If clalev([F:FCY])  = 0  :  Local File FACILITY  [FCY]  :  Endif   #already opened
  If clalev([F:HRCTR2]) = 0  :  Local File EMPLOCTR  [HRCTR2] :  Endif   #already opened
Endif

Local Integer ANNEE , SEMAINE , ANNCUR , SEMCUR
Local Char    SEMTYP(GLONSTY)
Local Date    DAT , DEBUT , FIN
Local Date    DEBCTR , FINCTR
Local Char    PLNCUR(GLONPLN)
Local Integer K , I, LTYPDAY, J
Local Decimal WJOUR , WHEURE, LNBRHOU, LNBRDAY
Local Decimal LNBRHOUFULL
Local Char    CPE(GLONTPS) , CPA(GLONTPS) , PARAM(10)
Local Integer TPS_COMPLET , DIFF_COMPL , FERIE
Local Integer OK
Local Integer WOKPLE
Local Integer VKILL : VKILL=0

If dim(SOA_GFERIE)<1    :   # This will always declare the variable now
 Global Integer SOA_GFERIE
 SOA_GFERIE=0 : VKILL=1
Endif

If dim(DJOUR)>0  : Raz DJOUR  : Endif
If dim(DHEURE)>0 : Raz DHEURE : Endif

If CODE=AVOID.ACHAR
 Local Char SOA_GTPSW(30) : Call GTPSW(SOA_GTPSW) From ESSGLOB_SOA

 Read [TIM]TIM0 = CDCG_LEG;SOA_GTPSW
Elsif [F:TIM]COD<>CODE
 Read [TIM]TIM0 = CDCG_LEG;[L]CODE
Endif

Local Integer VTYPDAY
If dim(PTYPDAY)>0
 VTYPDAY=PTYPDAY
Else
 VTYPDAY=[F:TIM]DAYTYP
Endif

If dim(SOA_GTPSCREAGLOB) > 0
  PARAM=SOA_GTPSPARINITCP
  CPA=SOA_GTPSPARCPA
  CPE=SOA_GTPSPARCPE
Else
  PARAM = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 1, "", "INITCP")
  CPA = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 1, "", "CPA")
  CPE = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 1, "", "CPE")
#  Call PARAM("","INITCP",PARAM) From ADOVAL
#  Call PARAM("","CPA",CPA) From ADOVAL
#  Call PARAM("","CPE",CPE) From ADOVAL
Endif

DIFF_COMPL = (val(PARAM)=2)
Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATFIN
Read [HRCTR]CTR1 Last
Filter [HRCTR]
If fstat<=2
 If dim([M]PYRDAT)>0
  TPS_COMPLET = (val(func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,[M]PYRDAT,"TYPJOB","HRCTR"))=1)
 Else
  TPS_COMPLET = ([F:HRCTR]TYPJOB=1)
 Endif
Else
 TPS_COMPLET = 1
Endif

# The leave screen does not have this variable PYRDAT so we have not fully completed the SOA code. ???
If dim([M]PYRDAT)>0
 Local Char SOA_ETRFCY
 SOA_ETRFCY = func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","HRCTR")
 Read [FCY]FCY0 = SOA_ERTFCY
 #Call LECTURE("FCY",func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,[M]PYRDAT,"ETRFCY","CTR"),"") From CONTOBJ
Else
 #Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
 Read [FCY]FCY0 = [F:HRCTR]ETRFCY
Endif
If [F:AD]REFNUM<>MATRI
 Read [AD]AD0 = MATRI
Endif


DAT = DATDEB
 #FRLAA - 2018-01-17 - X3-67633 - START
 Call DAT(DAT,ANNEE,SEMAINE,CTR,MATRI)
 #Call DAT(DAT,ANNEE,SEMAINE)
 #FRLAA - 2018-01-17 - X3-67633 - END

If SOA_GTPS
 Read [PLE]PLE0=MATRI;DATDEB;CTR
 If fstat
  Gosub SETSEM
  If SEMTYP=AVOID.ACHAR : End : Endif
 Endif
Else
 Gosub SETSEM
 If SEMTYP=AVOID.ACHAR : End : Endif
Endif
ANNCUR = ANNEE
SEMCUR = SEMAINE
Read [HLY]HLY0 = ANNEE;SITE;CDCG_LEG
If fstat
 Read [HLY]HLY0 = ANNEE;"";CDCG_LEG
Endif
If year(DATDEB)<>ANNEE
 Read [HLY]HLY0 = year(DATDEB);SITE;CDCG_LEG
 If fstat
  Read [HLY]HLY0 = year(DATDEB);"";CDCG_LEG
 Endif
Endif

#Entry point to be completed (SOA) in the future
#GPOINT = "AV_VALOR" : Gosub ENTREE From EXEFNC

#If OK : End : Endif

Raz JOUR,HEURE

For I=1 To (DATFIN-DATDEB)+1
 Raz LNBRHOU, LNBRDAY
 Raz LNBRHOUFULL
 #FRLAA - 2018-01-17 - X3-67633 - START
 Call DAT(DAT,ANNEE,SEMAINE,CTR,MATRI)
 #Call DAT(DAT,ANNEE,SEMAINE)
 #FRLAA - 2018-01-17 - X3-67633 - END
 If SOA_GTPS
  Read [PLE]PLE0 = MATRI;DAT;CTR
 Endif
 Raz WOKPLE
 If SOA_GTPS & !fstat
  LNBRHOU = [F:PLE]NBRHOU
  LNBRDAY = [F:PLE]NBRDAY
  LTYPDAY = [F:PLE]TYPDAY
  WOKPLE=1
 Else
  If SEMAINE<>SEMCUR or ANNEE<>ANNCUR or DAT>FINCTR
   Gosub SETSEM
   If SEMTYP=AVOID.ACHAR : Break : Endif
   ANNCUR = ANNEE
   SEMCUR = SEMAINE
  Endif


  K = DAT-DEBUT
  LNBRHOU = [F:WTY]NBRHRS1(K)
  LNBRDAY = [F:WTY]NBRDAY1(K)
  LTYPDAY = [F:WTY]TYPDAY(K)
 Endif
 LNBRHOUFULL=LNBRHOU
 If dim([L]AM)>0 & [L]AM=1
  LNBRDAY = LNBRDAY/2
  LNBRHOU = LNBRHOU/2
 Endif
 If ANNEE<>[F:HLY]YEA
  Read [HLY]HLY0 = ANNEE;SITE;CDCG_LEG
  If fstat
   Read [HLY]HLY0 = ANNEE;"";CDCG_LEG
  Endif
 Endif
 If year(DAT)<>ANNEE
  Read [HLY]HLY0 = year(DAT);SITE;CDCG_LEG
  If fstat
   Read [HLY]HLY0 = year(DAT);"";CDCG_LEG
  Endif
 Endif

FERIE = find(DAT,[F:HLY]HLYDAY(0..[F:HLY]NBRDAY-1))
Raz WJOUR,WHEURE

If dim(VPHI) > 0
  If VPHI = 1
    FERIE = find(DAT,[F:HLY]HLYDAY(0..[F:HLY]NBRDAY-1))
    Else
      Raz FERIE
  Endif
Endif


 Case [F:TIM]COD
  When CPE
   If !FERIE & LTYPDAY=2
    If !TPS_COMPLET or DIFF_COMPL=1
     WJOUR  = 1
     WHEURE = LNBRHOUFULL
     If (dim([L]AM)>0 & [L]AM=1) & DIFF_COMPL=1
      WJOUR  = LNBRDAY
      WHEURE = LNBRHOU
     Endif
    Else
     If LTYPDAY=2
      WJOUR  = LNBRDAY
      WHEURE = LNBRHOU
     Endif
    Endif
   Endif
  When CPA
   If !FERIE & LTYPDAY<=2
    If !TPS_COMPLET or DIFF_COMPL=1
     WJOUR  = 1
     WHEURE = LNBRHOUFULL
     If (dim([L]AM)>0 & [L]AM=1) & DIFF_COMPL=1
      WJOUR  = LNBRDAY
      WHEURE = LNBRHOU
     Endif
    Else
     WJOUR  = LNBRDAY
     WHEURE = LNBRHOU
    Endif
   Endif
  When Default
   Case VTYPDAY
    When 1
     If (!FERIE | SOA_GFERIE) or CODE=""
&       or WOKPLE
      If LTYPDAY<=2
       WJOUR  = LNBRDAY
       WHEURE = LNBRHOU
      Endif
     Endif
    When 2
     If (!FERIE | SOA_GFERIE) or CODE=AVOID.ACHAR or WOKPLE
      If LTYPDAY=2
       WJOUR  = LNBRDAY
       WHEURE = LNBRHOU
      Endif
     Endif
    When 3
     WJOUR = 1
     If (!FERIE | SOA_GFERIE) or CODE=AVOID.ACHAR or WOKPLE
      If LTYPDAY<=2
       WHEURE = LNBRHOU
      Endif
     Endif
   Endcase
 Endcase
 If dim(DJOUR)>0  : DJOUR(I)  = WJOUR  : Endif
 If dim(DHEURE)>0 : DHEURE(I) = WHEURE : Endif
 JOUR  += WJOUR
 HEURE += WHEURE
 DAT += 1
Next I

#SOA in future
#GPOINT = "AP_VALOR" : Gosub ENTREE From EXEFNC

#76055
If dim(PTYPDAY)>0
 If dim(SOA_GTABCLE)>0
    If SOA_GMATRI<>MATRI
       SOA_GMATRI=MATRI
       SOA_GTABIND=1
       Raz SOA_GTABCLE,SOA_GTABJOUR,SOA_GTABHEURE
    Endif
    If SOA_GMATRI=MATRI
       Local Char CLETABLE(50)
       If dim(SOA_GFERIE)<0
        CLETABLE= num$(DATDEB)+num$(DATFIN)+CODE+SITE+CTR+num$(PTYPDAY)
       Else
        CLETABLE= num$(DATDEB)+num$(DATFIN)+CODE+SITE+CTR+num$(PTYPDAY)+num$(SOA_GFERIE)
       Endif
       SOA_GTABCLE(SOA_GTABIND)=CLETABLE
       SOA_GTABJOUR(SOA_GTABIND)=JOUR
       SOA_GTABHEURE(SOA_GTABIND)=HEURE
       SOA_GTABIND+=1
    Endif
 Endif
Endif

If dim(SOA_GFERIE)>=0 & VKILL
 Kill SOA_GFERIE
Endif

End
################################################################################
$SETSEM

If clalev([F:HRCTR2]) = 0  :  Local File EMPLOCTR[HRCTR2] :  Endif   #already opened

If [F:HRCTR2]CTRNUM<>AVOID.ACHAR
  Local Char SCTRNUM : SCTRNUM=[F:HRCTR2]CTRNUM
  Local Char SREFNUM : SREFNUM=[F:HRCTR2]REFNUM
  Local Date SCTRDAT : SCTRDAT=[F:HRCTR2]CTRDAT
Endif

SEMTYP = ""

#these globals get set below
If dim(SOA_GTPSMAT) > 0
  If [F:HRCTR2]REFNUM=SOA_GTPSMAT & [L]CTR=SOA_GTPSCTR & [F:HRCTR2]CTRDAT=SOA_GTPSCTRDAT & [L]DAT=SOA_GTPSDAT
&  &  [L]ANNEE=SOA_GTPSANNCUR & [L]SEMAINE=SOA_GTPSSEMCUR & [F:WTY]COD=SOA_GTPSSEMTYP
    [L]FINCTR = SOA_GTPSFINCTR
    [L]PLNCUR = SOA_GTPSPLNCUR
    [L]DEBUT  = SOA_GTPSDEBUT
    [L]FIN    = SOA_GTPSFIN
    [L]SEMTYP = SOA_GTPSSEMTYP
    Return
  Endif
Endif
#END 76055

If PLNCUR=AVOID.ACHAR or [F:HRCTR]REFNUM<>MATRI or DEBCTR<>[F:HRCTR]CTRDAT or DAT>FINCTR
 Filter [F:HRCTR2] Where REFNUM=[L]MATRI & CTRNUM=[L]CTR & (CTRDAT<=[L]DAT | (FLGRET=2 & RETDATEFF<=[L]DAT))
 Read [F:HRCTR2]CTR1 Last
 Filter [F:HRCTR2]
 If dim([M]PYRDAT)>0 : #??? - PYRDAT does not exist in DEMCONGE screen
  PLNCUR = func SUBCTRRET_SOA.FIND_RETRO_FLD([L]MATRI,[L]CTR,[F:HRCTR2]CTRDAT,[M]PYRDAT,"PLNTYP","HRCTR2")
 Else
  PLNCUR = [F:HRCTR2]PLNTYP
 Endif
 DEBCTR = [F:HRCTR2]CTRDAT
 Filter [F:HRCTR2] Where REFNUM=[L]MATRI & CTRNUM=CTR & (CTRDAT>DEBCTR | (FLGRET=2 & RETDATEFF>DEBCTR))
 Read [F:HRCTR2]CTR1 First
 Filter [F:HRCTR2]
 If fstat>2
  FINCTR = [31/12/2999]
 Else
  FINCTR = [F:HRCTR2]CTRDAT-1
 Endif
Endif

If PLNCUR=AVOID.ACHAR : PLNCUR = SOA_GPLANNING : Endif
If PLNCUR=AVOID.ACHAR : Return : Endif

If [F:PLN]COD<>PLNCUR or [F:PLN]YEA<>ANNEE
 Read [PLN]PLN0 = ANNEE;PLNCUR;CDCG_LEG
Else
 fstat = 0
Endif
If !fstat
 SEMTYP = [F:PLN]WEKTYP(SEMAINE-1)
Endif

If SEMTYP=AVOID.ACHAR : Return : Endif

If [F:WTY]COD<>SEMTYP
 Read [WTY]WTY0 = CDCG_LEG;SEMTYP
Endif
#FRLAA 2018-01-17 - X3-67633 - START
#Pass addditonal paramters to set GFIRDAY
Call SEMAINE(ANNEE,SEMAINE,DEBUT,FIN,CTR,MATRI)
#Call SEMAINE(ANNEE,SEMAINE,DEBUT,FIN)
#FRLAA 2018-01-17 - X3-67633 - END

If dim(SOA_GTPSMAT) > 0
  SOA_GTPSMAT    =[F:HRCTR2]REFNUM
  SOA_GTPSCTR    =[L]CTR
  SOA_GTPSCTRDAT =[L]DEBCTR
  SOA_GTPSFINCTR =[L]FINCTR
  SOA_GTPSDAT    =[L]DAT
  SOA_GTPSANNCUR =[L]ANNEE
  SOA_GTPSSEMCUR =[L]SEMAINE
  SOA_GTPSSEMTYP =[F:WTY]COD
  SOA_GTPSPLNCUR =[L]PLNCUR
  SOA_GTPSDEBUT  =[L]DEBUT
  SOA_GTPSFIN    =[L]FIN
Endif

If dim(SCTRNUM)>0
  Read [F:HRCTR2]CTR0=SREFNUM;SCTRNUM;SCTRDAT
Endif

Return
################################################################################
#FRLAA - 2018-01-17 - X3-67633 - START
Subprog SEMAINE(ANNEE,SEMAINE,DEBUT,FIN,VCTR,VMATRI)
#Subprog SEMAINE(ANNEE,SEMAINE,DEBUT,FIN)
#FRLAA - 2018-01-17 - X3-67633 - END
Value Char VCTR,VMATRI
Value    Integer ANNEE
Value    Integer SEMAINE
Variable Date    DEBUT
Variable Date    FIN
Gosub DECAL
DEBUT = DECAL+aweek(SEMAINE,ANNEE)
FIN   = DECAL+aweek(SEMAINE,ANNEE)+6

End
################################################################################
#FRLAA - 2018-01-17 - X3-67633 - START
Subprog DAT(DAT,ANNEE,SEMAINE,VCTR,VMATRI)
Value Char VMATRI,VCTR
#Subprog DAT(DAT,ANNEE,SEMAINE)
#FRLAA - 2018-01-17 - X3-67633 - END
Value    Date    DAT
Variable Integer ANNEE
Variable Integer SEMAINE
Local Integer NBSEM
Gosub DECAL
SEMAINE = week(DAT-DECAL)
ANNEE   = year(DAT-DECAL)
NBSEM = 52
If aweek(52,ANNEE)+6<gdat$(28,12,ANNEE)
 NBSEM += 1
Endif
If SEMAINE=0 & ANNEE>0
 ANNEE  -= 1
 SEMAINE = week(gdat$(31,12,ANNEE))
Elsif SEMAINE>NBSEM
 ANNEE += 1
 SEMAINE = 1
Endif
End
################################################################################
$DECAL
#MIPEA - 2017-11-27- US X3-63170- START
#Local Libelle  SOA_GFIRDAY : Call GFIRDAY(SOA_GFIRDAY) From ESSGLOB_SOA : # First day of the week
#Call SET_GFIRDAY([F:HRCTR]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-27- US X3-63170- END

#FRLAA - 2017-12-05 - START
Local Libelle  SOA_GFIRDAY
Local Integer DECAL

#FRLAA - 2018-01-17 - X3-67633 - START
Local Char THISPERCOD(GLONHRPEO)
Local File EMPLOCTR [HRCTR8]
Filter [F:HRCTR8] Where [F:HRCTR8]REFNUM = VMATRI & [F:HRCTR8]CTRNUM = VCTR
Read [F:HRCTR8]CTR0(2) = VMATRI;VCTR
If fstat = [V]CST_AOK

  THISPERCOD = [F:HRCTR8]PERCOD
  Call SET_GFIRDAY(THISPERCOD,SOA_GFIRDAY) From SUBPLN_SOA # First day of the week
Endif
Filter [F:HRCTR8]
LogicClose File [HRCTR8]
#Call SET_GFIRDAY([F:HRCTR]PERCOD,SOA_GFIRDAY) From SUBPLN_SOA # First day of the week
#FRLAA - 2017-12-05 - END
#FRLAA - 2018-01-17 - X3-67633 - END

If SOA_GFIRDAY<5
 DECAL = SOA_GFIRDAY-1
Else
 DECAL = SOA_GFIRDAY-8
Endif

Return


#FRLAA - 2018-01-17 - X3-67633 - START
Subprog SET_GFIRDAY(VTHISPERCOD,RETVAL)
Value Char VTHISPERCOD
#Subprog SET_GFIRDAY(PERCOD,RETVAL)
#Value Char PERCOD
#FRLAA - 2018-01-17 - X3-67633 - END
Variable Libelle RETVAL

If clalev([HRPEOH8])=0 : Local File HRPEOHEA [HRPEOH8] : Endif
If clalev([F:HRPEOD8])=0 : Local File HRPEODET [HRPEOD8] : Endif

Link [HRPEOH8] With [F:HRPEOD8]HRPEOD0(1) = [HRPEOH8]PERCOD As [LNK] Where [HRPEOH8]PERCOD = VTHISPERCOD & [HRPEOH8]FLGENA=2

Read [LNK] First

If !fstat
  RETVAL = dayn([F:HRPEOD8]PERSTR(0))
Else

Endif

End


#####
################################################################################

