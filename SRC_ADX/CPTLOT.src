#<AdxTL>@(#)8.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
GERR = 0
Call TRAITE_CHAR(VALEUR,PARAM,"","CPTLOT","CPTLOT",4,"") From GTRAITE
End
#*X3-39795   MDJ  Manage ORIGIN and ORICOD fields in GL Entry
#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub FIN
 When "OUVRE_BATCH" : Gosub OUVFIC
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0
 When "DEBUT"       : Gosub DEBUT
Endcase
Return


##############################################################################
$DEBUT
Raz [M:DIA]INI : Affzo [DIA]
Setmok [DIA] With 0
Return

$OUVRE
Local Integer I, J, K, OK, NOL, NOLDEB, IND_LOT, MORT
Local Char    CRITERE(250)
Local Integer NBPCE, NBERR, NBLIGLOT
Local Integer STAT, STAECT
Local Char    SVGTIT(80)
Local Char    MESSA(250)
Local Char    SYMBOLE(50)
Local Char    LOTCUR(20)

Gosub OUVFIC

Local Mask SAICURLED [SCL], GACCENTFMT  [HAEF], GACCENTW  [HAEW]
Local Mask GACCENT0   [HAE0], GACCENT1   [HAE1]
&        , GACCENT2   [HAE2], VENTILE    [VTL], VENTILE2 [VT2]

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
# Dossier mono-leg on force GCURLEG à GDOSLEG
If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif

Local Integer INDREF
Local Integer MAXLIG , MAXVTL
MAXLIG = dim([M]SAC1)
MAXVTL = dim([M:VTL]AMT)
Local Decimal DEBLOC(MAXLIG) , CDTLOC(MAXLIG)
Local Decimal DEBRPT(MAXLIG) , CDTRPT(MAXLIG)
Local Decimal TMPLOC(MAXVTL) , TMPRPT(MAXVTL)
Local Decimal AROLOC , ARORPT

Local Mask CPTLOT [DIA]
TIT  = mess(21,107,1) : # Validation des lots
SVGTIT = TIT
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","cp6") From GMEMO
GSCHEMA = ""
Return

$OUVFIC
Local File GACCOUNT   [GAC], GAJOUSTA    [JST]
&        , COMPANY    [CPY], FACILITY    [FCY], FACGROUP [FGR]
&        , TABCUR     [TCU], TABCHANGE   [TCH]
&        , GDIAENTRY  [GDE], GDIAENTRYD  [GDD]
&        , TABACCLIK  [TCK]
&        , GTYPACCENT [GTE], CADSP       [DSP]
&        , GENTLOT    [LOT], GENTLOTH    [LOH]
&        , GENTLOTD   [LOD], GENTLOTA    [LOA]
&        , GACCTMP    [HAE]
&        , GACCTMPD   [DAE], GACCTMPA    [DAA]
&        , CACCE      [CCE]
&        , BALANCE    [BAL], BALANA      [BLA]
&        , AVALNUM    [AVN], ACODNUM     [ANM]
&        , FISCALYEAR [FIY], PERIOD      [PER]
&        , GJOURNAL   [JOU], TABUNIT     [TUN]
&        , GENTLOT    [LO2], GACCENTRY   [HA2]
&        , GACCDUDATE [DUD]
&        , BPCUSTOMER [BPC], BPSUPPLIER  [BPS], BPARTNER [BPR]
&        , GACCCODE   [CAC], GACM[GCM]
Return

##############################################################################
$CONTROLE
If GOK<1
 FIN = 1
Else
 TMP = 1
Endif

If FIN : Return : Endif
Call AVERTDGI([M:DIA]ALLCPY,[M:DIA]CPY,[M:DIA]CATLOT,SAI) From CPTDIV2
If SAI : Return : Endif

If [M:DIA]CATLOT<3
 Call PRESENCE(MORT) From CPTBATCH
 If MORT
  GERR = 1 : FIN = 1 : GMESSAGE = mess(49,134,1) : # La tâche comptable doit être démarrée
 Endif
Endif
If FIN : Return : Endif

Local Integer OK
If [M:DIA]ALLCPY=2 # toutes sociétés
 SOC=""
Else
 SOC=[M:DIA]CPY
Endif
Call LOCKCPY(SOC, OK) From AX3MONO
If !OK : Return : Endif
Return

##############################################################################
$EXEC
If GSERVEUR
 [M:DIA]TRC = 2
Endif
TIT = SVGTIT
If !GSERVEUR & [M:DIA]TRC=2
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
TIT -= "("+mess([M:DIA]CATLOT,639,1) : # Réel/simul
If [M:DIA]CATLOT=1
 TIT -= mess([M:DIA]STALOT,617,1) : # Provisoire/définitif
Endif
TIT += ")"
If [M:DIA]TRC=2
 Call ECR_TRACE(TIT,0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

# Reinit de GCURLEG car qd on lance la validation on passe de GSAISE à GTRAITE et
# on perd le GCURLEG initialisé par CPTTRT
# Dossier mono-leg on force GCURLEG à GDOSLEG
If GNBLEG=1
 GCURLEG = GDOSLEG(1)
Else
 GCURLEG=[M:DIA]LEG
Endif

CRITERE = 'UPDFLG=1'
If [M:DIA]ALLCPY<>2
 CRITERE -= '& CPY="'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2
 CRITERE -= '& FCY="'+[M:DIA]FCY+'"'
Endif
If [M:DIA]STRLOT<>""
 CRITERE -= '& LOT>="'+[M:DIA]STRLOT+'"'
Endif
If [M:DIA]ENDLOT<>""
 CRITERE -= '& LOT<="'+[M:DIA]ENDLOT+'"'
Endif
If [M:DIA]ALLUSR<>2
 CRITERE -= '& (UPDUSR="'+[M:DIA]USR+'"'
 CRITERE -= '| (UPDUSR="" & CREUSR = "'+[M:DIA]USR+'"))'
Endif

Filter [LO2] Where evalue(CRITERE)
Gosub VERROU
Filter [LO2]

Default Mask [HAE0]
Default Mask [HAE1]
Default Mask [HAE2]

For IND_LOT=0 To NBLOT-1
 Raz NBLIGLOT, NBERR
 Read [F:LO2]LOT0 = TSYMBOLE(IND_LOT)
 If [M:DIA]CATLOT=1 & [M:DIA]ALLCPY=2 & func AFNC.PARAM("FRADGI",[F:LO2]CPY)="2"
  STAECT = 2
 Else
  STAECT = [M:DIA]STALOT
 Endif
 For [LOH] Where LOT=TSYMBOLE(IND_LOT)
  Gosub CHARGE_ECR
  Gosub CONTPCE
 Next
 If !NBERR
  Gosub DELSIM
  If GOK>0
   Raz NBLIGLOT
   Gosub TRTVAL
  Endif
  If GOK<1
   GMESSAGE = mess(17,107,1) : # Rollback
   Gosub ER_TRACE : Break
  Endif
 Endif
Next
Gosub DEVERROU

If !NBPCE
 Call ECR_TRACE(mess(8,107,1),0) From GESECRAN : # Aucune pièce à traiter
Endif

If !GSERVEUR & [M:DIA]TRC=2
 Call FERME_TRACE From LECFIC
Endif
Return

#######################################################
$FIN
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif

If !GSERVEUR & [M:DIA]TRC=2
 TRA = 1
Else
 TRA = 0
Endif
Return

$SORTIE
Call UNLOCKCPY() From AX3MONO
Return

#######################################################
$VERROU
Local Integer MAXLOT, NBLOT
MAXLOT = rowcount([LO2])
Local Char    TSYMBOLE(50)(0..MAXLOT)
Raz NBLOT
For [LO2]LOT0
 OK=1
 # if all cpy should take care of the legislation : leg cpy = screen leg
 If [M:DIA]ALLCPY=2
  Call LEC_CPY([F:LO2]CPY) From CPTLEC
  OK *= ([F:CPY]LEG = GCURLEG)
 Endif
 If OK
  TSYMBOLE(NBLOT) = [F:LO2]LOT
  Lock =TSYMBOLE(NBLOT) With lockwait=0
  If !fstat
   NBLOT+=1
  Else
   # Opération en cours sur autre poste
   Call ECR_TRACE(mess(23,107,1)-[F:LO2]LOT-":"-mess(30,100,1),1) From GESECRAN
  Endif
 Endif
Next
Return

#######################################################
$DEVERROU
For IND_LOT=0 To NBLOT-1
 If TSYMBOLE(IND_LOT)<>"" : Unlock =TSYMBOLE(IND_LOT) : Endif
Next
Return

#######################################################
$CHARGE_ECR
Raz [M:HAE0], [M:HAE1], [M:HAE2]
[M:HAE0] = [F:LO2]
[M:HAE0] = [F:LOH]
[M:HAE1] = [F:LOH]

[M:HAE0]DACDIA = [F:LO2]DACDIAGAS

[M:HAEF]TYPENT = 1
Call INIMSKFMT3([M]FCY,[M:HAEF]TYPENT,[M]DACDIA,[M]TYP,[M]ACCDAT,STAT) From SUBGASA
For I=1 To [M:HAEF]NBRLED
 Assign "[M:HAE1]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
 Assign "[M:HAE2]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
Next

[M:HAE1]ORIMOD = 2
[M:HAE0]STA = STAECT
[M:HAE0]CAT = [M:DIA]CATLOT
If [M:DIA]CATLOT>1
 [M:HAE1]REFSIM = "LO" + [F:LOH]LOT
 If dim([M:HAE1]FLGDAS)>0
  [M:HAE1]FLGDAS = 1
 Endif
 [M:HAE1]FLGFUP = 1
Endif
If [M:HAE1]RVSDAT=[0/0/0]
 [M:HAE1]RVS = 1
Else
 [M:HAE1]RVS = 2
Endif
Default Mask [HAE2]
Raz nolign, [M:VTL], [M:VT2], K

For [LOD] Where LOT=[F:LOH]LOT & ORNVCR=[F:LOH]ORNVCR
 NBLIGLOT += 1
 nolign += 1
 [M:HAE0] = [F:LOD]
 [M:HAE1] = [F:LOD]
 [M:HAE2] = [F:LOD]

 For I=1 To [M:HAEF]NBRLED
  INDREF = find([M:HAEF]LEDTYP(I-1),[F:LOD]LEDTYP(0..dim([F:LOD]LEDTYP)-1))
  If INDREF
   Assign "[M:HAE2]ACC"+num$(I)+"("+num$(nolign-1)+")" With [F:LOD]ACC(INDREF-1)
  Endif
 Next

 If [F:LOD]SNS=1
  [M]DEB(nolign-1) = [F:LOD]AMTCUR
  [M]TOTDEB += [F:LOD]AMTCUR
 Else
  [M]CDT(nolign-1) = [F:LOD]AMTCUR
  [M]TOTCDT += [F:LOD]AMTCUR
 Endif

 If [F:LOD]DSP=""
  OK = 0
  For [LOA] Where LOT=[F:LOD]LOT & ORNVCR=[F:LOD]ORNVCR & LIN=nolign
   K += 1
   If !OK : OK = K : Endif
   [M:VT2]TBAMT(K) = [F:LOA]AMTCUR
   [M:VT2]TBQTY(K) = [F:LOA]QTY
   For I=1 To dim([F:LOA]CCE)-1
    AXE = find(evalue("[F:LOA]DIE"+"("+num$(I-1)+")"),[M:HAEF]DIE(0..19))
    If AXE>0
     Assign "[M:VT2]TBCCE"+num$(AXE)+"("+num$(K)+")" With [F:LOA]CCE(I-1)
    Endif
   Next I
  Next

  #-- Si OK<>0, il y a une ventilation analytique.
  #-- Si OK=K, il n'y a qu'une seule ligne analytique donc celle ci se précharge sur le masque HAE1/HAE2
  If OK
   If OK=K
    For I=1 To dim([F:LOA]CCE)-1
     Assign "[M]CCE"+num$(I)+"("+num$(nolign-1)+")" With evalue("[M:VT2]TBCCE"+num$(I)+"("+num$(K)+")")
     Assign "[M:VT2]TBCCE"+num$(I)+"("+num$(K)+")" With ""
    Next I
    K -= 1
   Else
    [M]PTV(nolign-1) = OK
    [M]PTF(nolign-1) = K
    [M]DSP(nolign-1) = "$"
   Endif
  Endif
 Endif
Next
[M:VT2]PTVENT = K+1
[M]NBLIG = nolign
Call LEC_GDE([M:HAE0]DACDIA) From CPTLEC
Call LEC_TCU([M:HAE1]CUR) From CPTLEC
Call LEC_FCY([M:HAE0]FCY) From CPTLEC
Call LEC_CPY([M:HAE0]CPY) From CPTLEC
Call LEC_JOU_LEG(GCURLEG,[M:HAE0]JOU) From CPTLEC
Call LEC_GTE_LEG(GCURLEG,[M:HAE0]TYP) From CPTLEC
[M:HAE1]TYPRAT = [F:GTE]TYPRAT
Return

$CONTPCE
STAT = 0
Call CONTROLE(STAT,MESSA) From CPTBATCH
If STAT
 Gosub MESSAGE From CPTAUTO
 GMESSAGE = mess(23,107,1)-[F:LOH]LOT-mess(61,100,1)-num$(NBLIGLOT)-":"-MESSA
 # Lot ... ligne ..., erreur ...
 Gosub ER_TRACE
 Return
Endif
Return

$ER_TRACE
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
NBERR += 1
Return

$MES_TRACE
If GTRACE<>"" : Call ECR_TRACE(GMESSAGE,0) From GESECRAN : Endif
Return

#######################################################
$TRTVAL
SYMBOLE = "LOT"+[F:LO2]LOT
Lock =SYMBOLE With lockwait=0
If fstat=1
 GMESSAGE = mess(23,107,1)-[F:LO2]LOT-mess(10,100,1) : # Lot ... en cours
 Gosub ER_TRACE
Else
 Call DEBTRANS From GLOCK
 Gosub TR1
 If GOK=1 & !STAT
  GMESSAGE  = mess(24,107,1)-[F:LO2]LOT : # Lot validé
  Gosub MES_TRACE
 Endif
 Unlock =SYMBOLE
Endif
Return

$TR1
GOK=1

Local Char  TZONE(10)(1..10) : # Table of zones to be forced (Ex: ORICOD)   #*X3-39795
Local Char  TVAL(30)(1..10)  : # Table of values for zones to be forced         #*X3-39795
 TZONE(5)= "ORIGIN" : TVAL(5)= "2"        :#Automatic loading                   #*X3-39795
 TZONE(6)= "ORICOD" : TVAL(6)= "CPTLOT"                                         #*X3-39795

Trbegin  [LOT], [HAE], [DAE], [DAA], [AVN]
 Readlock [LOT]LOT0 = [F:LO2]LOT
 If fstat=1
  GOK=-1 : GLOCK="$LOT"-[F:LO2]LOT : Goto ROL_TR1
 Elsif fstat
  GOK=0 : Call RSTA("LOT",[F:LO2]LOT) From GLOCK : Goto AB_TR1
 Endif
 For [LOH] Where LOT=[F:LO2]LOT
  Gosub CHARGE_ECR
  Call CONTROLE(STAT,MESSA) From CPTBATCH
  If STAT
   Gosub MESSAGE From CPTAUTO
   GMESSAGE = MESSA-":"-GMESSAGE
   Gosub ER_TRACE : GOK=0 : Break
  Endif
  GPE = 0
  GPOINT = "CONTROLE" : Gosub ENTREE From EXEFNC
  If !GPE
    #*X3-39795 Call VALPIECE(STAT,MESSA) From CPTBATCH  : # Pas de MAJ balances
    Call VALPIECE2(STAT,MESSA,TZONE,TVAL) From CPTBATCH : # Pas de MAJ balances
   If STAT | GOK<1
    GMESSAGE = mess(23,107,1)-[F:LOH]LOT-mess(61,100,1)-num$(NBLIGLOT)-MESSA
    # Lot ... ligne ..., erreur ...
    Gosub ER_TRACE : Break
   Endif
   If [M:DIA]CATLOT=1 & STAECT=2 & [M:DIA]STALOT<>STAECT
    GMESSAGE = mess(11,107,1)-[F:HAE]TYP-[F:HAE]NUM-"("+tolower(mess(192,107,1))+")"  # Pièce validée
   Else
    GMESSAGE = mess(11,107,1)-[F:HAE]TYP-[F:HAE]NUM
   Endif
   Gosub MES_TRACE
   NBPCE += 1
  Endif
 Next
 If    GOK<0 : Goto ROL_TR1
 Elsif GOK=0 : Goto AB_TR1
 Endif
 GPE = 0
 GPOINT = "MAJLOT" : Gosub ENTREE From EXEFNC
 If !GPE
  Gosub MAJLOT
 Endif
 If    GOK<0 : Goto ROL_TR1
 Elsif GOK=0 : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$MAJLOT
If [M:DIA]RAZLOT=2
 Local Char CLECUR1(20)
 CLECUR1 = [F:LO2]LOT
 Gosub ANNULE From SUBLOT
 If GOK<1 : Return : Endif
 Delete [LOT] Where LOT=[F:LO2]LOT
 If fstat
  GOK=0 : Call FSTA("LOT") From GLOCK : Return
 Endif
Elsif [M:DIA]CATLOT=1 : # Génération réelle
 [F:LOT]UPDFLG = 2
 Rewrite [LOT]
 If fstat
  GOK=0 : Call FSTA("LOT") From GLOCK : Return
 Endif
Endif
Return

$DELSIM
GOK=1
For [HA2]HAE2 Where REFSIM="LO"+[F:LO2]LOT
 GMESSAGE = mess(16,107,1)-[F:HA2]TYP-[F:HA2]NUM : # Annulation de la pièce
 Gosub MES_TRACE
 Call DELPCE([F:HA2]TYP,[F:HA2]NUM) From CPTBATCH
 If GOK<1 : Break : Endif
Next
Return

