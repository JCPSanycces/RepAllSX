#<AdxTL>@(#)0.0.0.0 $Revision$

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Call EXEC(NBPAR,PARAMETRE)
End

#######################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Local Char CRITERE(255),PARAM(30), VALEUR(30)
Local Integer I, J

#MIPEA - 2017-03-09- US X3-11264 ST X3-25377- START
If clalev([F:HRFRM])=0 : Local File HRFRMPAY [HRFRM] : Endif
#If clalev([F:FRM])=0 : Local File FRMPAY [FRM] : Endif
#MIPEA - 2017-03-09- US X3-11264 ST X3-25377- END
CRITERE=""
For I=0 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
#MIPEA - 2017-03-09- US X3-11264 ST X3-25377- START
  Case [L]PARAM
   When "HRFRM" : If [L]VALEUR<>""
                  [L]CRITERE -= '& [F:HRFRM]NUMFRM="'+[L]VALEUR+'"'
                Endif
  Endcase
#  Case [L]PARAM
#   When "FRM" : If [L]VALEUR<>""
#                  [L]CRITERE -= '& [F:FRM]NUMFRM="'+[L]VALEUR+'"'
#                Endif
#  Endcase
#MIPEA - 2017-03-09- US X3-11264 ST X3-25377- END
 Endif
Next
If CRITERE<>"" : CRITERE=right$(CRITERE,3) : Else : CRITERE = "1=1" : Endif

#MIPEA - 2017-03-09- US X3-11264 ST X3-25377- START
For [HRFRM] Where evalue (CRITERE)
#For [FRM] Where evalue (CRITERE)
#MIPEA - 2017-03-09- US X3-11264 ST X3-25377- END
 Call DEBTRANS From GLOCK
 Gosub TR1
Next
End

$TR1
GOK = 1
#MIPEA - 2017-03-09- US X3-11264 ST X3-25377- START
Trbegin [HRFRM]
# Pas de mise à jour si Bordereau Validé...
If [F:HRFRM]STA<>3
 [F:HRFRM]STA=2 : #Imprimé
 Rewrite [F:HRFRM]
 If fstat
  GOK = 0 : Call FSTA("HRFRM") From GLOCK
 Endif
 If GOK<1
   Gosub AB_TR
   Return
 Endif
Endif
Commit
#Trbegin [FRM]
## Pas de mise à jour si Bordereau Validé...
#If [F:FRM]STA<>3
# [F:FRM]STA=2 : #Imprimé
# Rewrite [F:FRM]
# If fstat
#  GOK = 0 : Call FSTA("FRM") From GLOCK
# Endif
# If GOK<1
#   Gosub AB_TR
#   Return
# Endif
#Endif
#Commit
#MIPEA - 2017-03-09- US X3-11264 ST X3-25377- END
Return

$AB_TR
 Rollback
Return

