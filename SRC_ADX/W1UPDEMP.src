#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque UPDEMP 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:59"
A_USER  = "DOC"
A_STAMP = "20181109230659"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask UPDEMP [UPDE]
Gosub HORODAT
Local Inpbox "UPDEMP" From GFONCTION At A_STAMP With A_WINDPREV Mask [UPDE] As [SIM_]
Grizo [UPDE]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [UPDE]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=110 : Y1(0)=1 : Y2(0)=22
Return

$ON_NBLIG
Onevent BEFORE_INPUT Call AS_NBLIG From W1UPDEMP
Return

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(44843,GBOUT1) From OBJDIV
Call TEXTE(5481,GBOUT2) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_NBLIG From W1UPDEMP
Onkey 130 Titled GBOUT2 Call B2_NBLIG From W1UPDEMP
Gosub _AFF
End

Subprog B1_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action GOBJETC1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC1"
 Call OBJET_CHAR([M]REFNUM(nolign-1),"EML","") From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action GOBJETC2
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC2"
 Call OBJET_CHAR([M]CTRNUM(nolign-1),"CTR",[M]REFNUM(nolign-1)+"~"+[M]CTRDAT(nolign-1)) From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_POT
Return

$ON_JOBPOT
Return

$ON_PROPRF
Return

$ON_CPY
Return

$ON_ETRFCY
Return

$ON_ETRSRV
Return

$ON_REFNUM
Return

$ON_CTRNUM
Return

$ON_CTRDAT
Onevent BEFORE_AREA Gosub AV_CTRDAT From W1UPDEMP
Return

$AV_CTRDAT
Chgfmt [M]CTRDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_XITDAT
Onevent BEFORE_AREA Gosub AV_XITDAT From W1UPDEMP
Return

$AV_XITDAT
Chgfmt [M]XITDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_OCOL001
Return

$ON_COL001
Return

$ON_CODTYP001
Return

$ON_NOLIB001
Return

$ON_UPD
Onevent INIT_AREA Call D_UPD(zc) From W1UPDEMP
Onevent BEFORE_INPUT Call AS_UPD(zc) From W1UPDEMP
Return

Subprog D_UPD(VALEUR)
Variable Integer VALEUR
If varinit([M]UPD,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_UPD(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


