#<AdxTL>@(#)0.0.0.0 $Revision$
#-----------------------EVENTS----------------------------------
#---------------------------------------------------------------
$INIT
  this.IS_PROP_CHG = [V]CST_ANO
  this.INVCNDSTA = 1 #--'To be invoiced'
  this.MODFLG    = 1 #--'No'
  this.MODDAT    = [0/0/0]
Return
#---------------------------------------------------------------
$ADELETE_CONTROL_BEFORE
Local Integer WMAXAERROR
  #--This class it is supposed to be used as collection of SVCRINVCND, due to the key structure
  #--To prevent using the subclass DOCINVCND stand alone
  If this.HASRIGHTHEAD<>[V]CST_AYES
    WMAXAERROR=[L]ASTATUS #--To prevent loosing an blocking error set before !
    [L]ASTATUS = max(WMAXAERROR, fmet this.ASETERROR("",func AFNC.MES1(mess(460,192,1),"SVCRINVCND"),[V]CST_AERROR))
  Endif
  #--
  #--Deletion is forbidden if status is "Invoiced"/"Invoiced by credit note"/"Closed"
  #--Also if 'On invoice'/'On credit note'
  # 107888 : Scheduled invoices : X3-6923 (LD:18/01/17)
  # Deletion is possible when status is "Closed"
  #If find(this.INVCNDSTA,2,3,4,5,6)>0
  If find(this.INVCNDSTA,2,3,5,6)>0
  # 107888 : Scheduled invoices : X3-6923 (LD:18/01/17)

    WMAXAERROR=[L]ASTATUS #--To prevent loosing an blocking error set before !
    [L]ASTATUS = max(WMAXAERROR, fmet this.ASETERROR("INVCNDSTA",func AFNC.MES1(mess(470,192,1),mess(1,2419,1)),[V]CST_AERROR))
  Endif

Return
#---------------------------------------------------------------
$AUPDATE_CONTROL_BEFORE
  #--Update is forbidden if status is "Invoiced"/"Invoiced by credit note"/"Closed"
  #If this.snapshot<>null
  #  If this.snapshot.INVCNDSTA>1 or (this.INVCNDSTA=this.snapshot.INVCNDSTA and find(this.INVCNDSTA, 2,3,4)>0)
  #    [L]ASTATUS = fmet this.ASETERROR("INVCNDSTA","Update is forbidden if status is 'INVOICED'/'INVOICED By CREDIT NOTE'/'CLOSED'",[V]CST_AERROR)
  #  Endif
  #Endif

Return
#---------------------------------------------------------------
$ACONTROL
Local Integer WMAXAERROR
  #--This class it is supposed to be used as collection of SVCRINVCND, due to the key structure
  #--To prevent using the subclass DOCINVCND stand alone
  If this.HASRIGHTHEAD<>[V]CST_AYES
    WMAXAERROR=[L]ASTATUS #--To prevent loosing an blocking error set before !
    [L]ASTATUS = max(WMAXAERROR, fmet this.ASETERROR("",func AFNC.MES1(mess(460,192,1),"SVCRINVCND"),[V]CST_AERROR))
  Endif
  #--
  #--Line number is >0
  If this.VCRINVCNDLIN=0
    WMAXAERROR=[L]ASTATUS #--To prevent loosing an blocking error set before !
    [L]ASTATUS = max(WMAXAERROR, fmet this.ASETERROR("VCRINVCNDLIN",mess(472,192,1),[V]CST_AERROR))
  Endif
  #--
  #--Start date <= End date
  If this.PERFROM>this.PERTO
    WMAXAERROR=[L]ASTATUS #--To prevent loosing an blocking error set before !
    [L]ASTATUS = max(WMAXAERROR, fmet this.ASETERROR("PERFROM",mess(473,192,1),[V]CST_AERROR))
  Endif
  #--
  #--Deletion forbidden if status 'Invoiced'/'Credit note'/'Closed'
  # 107888 : Scheduled invoices : X3-6923 (LD:18/01/17)
  # Deletion is possible when status is "Closed"
  #If this.ASTALIN=[V]CST_ADEL and find(this.INVCNDSTA,2,3,4)>0
  If this.ASTALIN=[V]CST_ADEL and find(this.INVCNDSTA,2,3)>0
  # 107888 : Scheduled invoices : X3-6923 (LD:18/01/17)
    WMAXAERROR=[L]ASTATUS #--To prevent loosing an blocking error set before !
    [L]ASTATUS = max(WMAXAERROR, fmet this.ASETERROR("",func AFNC.MES1(mess(470,192,1),mess(1,2419,1)),[V]CST_AERROR))
  Endif

  If this.ASTALIN=[V]CST_AUPD and this.INVCNDSTA>1
    #--The line was "Invoiced/Credit memo/Closed" before updating
    #--These properties are not updatable !
    If this.snapshot<>null and find(this.snapshot.INVCNDSTA,2,3,4)>0 and
&     (this.snapshot.INVCNDQTY    <> this.INVCNDQTY    or
&      this.snapshot.INVCNDAMTNOT <> this.INVCNDAMTNOT or
&      this.snapshot.INVCNDAMTATI <> this.INVCNDAMTATI or
&      this.snapshot.DNETPRINOT   <> this.DNETPRINOT   or
&      this.snapshot.DNETPRIATI   <> this.DNETPRIATI)
      WMAXAERROR=[L]ASTATUS #--To prevent loosing an blocking error set before !
      [L]ASTATUS = max(WMAXAERROR, fmet this.ASETERROR("",func AFNC.MES1(mess(474,192,1),mess(1,2419,1)),[V]CST_AERROR))
    Endif
  Endif
  #--Origin document line has to exist
  #Gosub CONTROL_EXIST_DOCORI
  #--Amount/Qty/% control
  Gosub ACONTROL_INVPERCENT
  WMAXAERROR = max(WMAXAERROR, [L]ASTATUS) #--To prevent loosing an blocking error set before !
  #Gosub ACONTROL_INVCNDQTY
  Gosub ACONTROL_INVCNDAMT
  WMAXAERROR = max(WMAXAERROR, [L]ASTATUS) #--To prevent loosing an blocking error set before !
  Gosub ACONTROL_NEXINVDAT
  WMAXAERROR = max(WMAXAERROR, [L]ASTATUS) #--To prevent loosing an blocking error set before !

  [L]ASTATUS = WMAXAERROR

Return
#---------------------------------------------------------------
$ACONTROL_INVPERCENT
  Case this.INVCNDSTA
    When 0,1   : #--"Not invoiced"
      If this.INVPERCENT<=0 or this.INVPERCENT>100
        [L]ASTATUS = fmet this.ASETERROR("INVPERCENT",mess(475,192,1),[V]CST_AERROR)
      Endif
    When 2,4,5 : #--'Invoiced', 'Closed', 'On invoice'
      If this.INVPERCENT<=0 or this.INVPERCENT>100
        [L]ASTATUS = fmet this.ASETERROR("INVPERCENT",mess(475,192,1),[V]CST_AERROR)
      Endif
    When 3,6   :  #--'Credit note', 'On credit note'
      If this.INVPERCENT>=0 or this.INVPERCENT<-100
        [L]ASTATUS = fmet this.ASETERROR("INVPERCENT",mess(476,192,1),[V]CST_AERROR)
      Endif
    When Default :
  Endcase
Return
#---------------------------------------------------------------
$ACONTROL_INVCNDQTY
#--Done in header class (need of the QTY of header incoice schedule)
#  Case this.INVCNDSTA
#    When 0,1 : #--"Not invoiced"
#      If this.INVCNDQTY<=0
#        [L]ASTATUS = fmet this.ASETERROR("INVCNDQTY","Positive quantity only",[V]CST_AERROR)
#        Return
#      Endif
#    When 2,3,4 :
#    When Default :
#  Endcase
Return
#---------------------------------------------------------------
$ACONTROL_INVCNDAMT
  Case this.INVCNDSTA
    When 0,1 : #--"Not invoiced"
      #--We won't test the PRITYP header property (it's done in the header script)
      If this.INVCNDAMTNOT<0
        [L]ASTATUS = fmet this.ASETERROR("INVCNDAMTNOT",mess(477,192,1),[V]CST_AERROR)
      Elsif this.INVCNDAMTATI<0
        [L]ASTATUS = fmet this.ASETERROR("INVCNDAMTATI",mess(477,192,1),[V]CST_AERROR)
      Endif
    When 2,4,5 : #--'Invoiced', 'Closed','On invoice'
      If this.INVCNDAMTNOT<0
        [L]ASTATUS = fmet this.ASETERROR("INVCNDAMTNOT",mess(477,192,1),[V]CST_AERROR)
      Elsif this.INVCNDAMTATI<0
        [L]ASTATUS = fmet this.ASETERROR("INVCNDAMTATI",mess(477,192,1),[V]CST_AERROR)
      Endif
    When 3,6   : #--'Credit note', 'On credit note'
      If this.INVCNDAMTNOT>0
        [L]ASTATUS = fmet this.ASETERROR("INVCNDAMTNOT",mess(499,192,1),[V]CST_AERROR)
      Elsif this.INVCNDAMTATI>0
        [L]ASTATUS = fmet this.ASETERROR("INVCNDAMTATI",mess(499,192,1),[V]CST_AERROR)
      Endif
    When Default :
  Endcase
Return
#---------------------------------------------------------------
$ACONTROL_NEXINVDAT
  Case this.INVCNDSTA
    When 0,1 : #--"Not invoiced"
      If this.NEXINVDAT=[0/0/0]
        [L]ASTATUS = fmet this.ASETERROR("NEXINVDAT",mess(472,192,1),[V]CST_AERROR)
      Endif
    When 2,3,4 :
    When Default :
  Endcase
Return
#---------------------------------------------------------------

