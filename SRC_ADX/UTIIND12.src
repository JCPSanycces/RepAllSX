#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################
# UTIIND12 
# ---------------------------------------------------------------------- #
#         Suppression de la fct FUNTAXUSA
#        (demande de la filiale US  de janvier 2011) demande 70394
##########################################################################
Infbox "only update folder by patch"
End


##########################################################################
# Pour exécution automatique en gestion de patch                         #
##########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

# mettre a jour uniquement sur tous les dossiers 

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI 
If fstat = 0
    Call EXE_UTIIND12(APPLI)
Endif
End


##########################################################################
## Suppression fct FUNTAXUSA                                             #
##########################################################################
#--------------------
Subprog EXE_UTIIND12(DOSSIER)
Value Char    DOSSIER

Local Char    TRT
Local Integer STAT


Call ECR_TRACE("UTIIND12 Start of Update : Deletion of the process in the folder"+DOSSIER,0) From GESECRAN

# delete FCT
Local Char WFONC
WFONC= "FUNTAXUSA"

If clalev([F:DAFP])=0 : Local File =DOSSIER+".AFCTPRF"   [DAFP] : Endif
If clalev([F:DAFF])=0 : Local File =DOSSIER+".AFCTFCY"   [DAFF] : Endif
If clalev([F:DAVR])=0 : Local File =DOSSIER+".AVARLOC"   [DAVR] : Endif
If clalev([F:DARV])=0 : Local File =DOSSIER+".AREPORTV"  [DARV] : Endif
If clalev([F:DAFC])=0 : Local File =DOSSIER+".AFONCTION" [DAFC] : Endif

Delete [DAFP] Where FNC=WFONC
If fstat=1 : Call ERREUR("AFCTPRF"-WFONC,3) From DOSDIC : Endif
Delete [DAFF] Where FNC=WFONC
If fstat=1 : Call ERREUR("AFCTFCY"-WFONC,3) From DOSDIC : Endif
Delete [DAVR] Where TYP=2 & FCT=WFONC
If fstat=1 : Call ERREUR("AVARLOC"-WFONC,3) From DOSDIC : Endif 
Delete [DARV] Where FONCTION=WFONC
If fstat=1 : Call ERREUR("AREPORTV"-WFONC,3) From DOSDIC : Endif    
Delete [DAFC] Where CODINT=WFONC
If fstat=1 : Call ERREUR("AFONCTION"-WFONC,3) From DOSDIC : Endif
#

# delete Action
If clalev([F:DATR])=0 : Local File =DOSSIER+".ACTPAR"   [DATR] : Endif
If clalev([F:DACT])=0 : Local File =DOSSIER+".ACTION"   [DACT] : Endif

Delete [DATR] Where ACTION="SAITAXUSA"
Delete [DACT] Where ACTION="SAITAXUSA"



# delete Fenetre
Local Char WWIN
WWIN= "FTAXUSA"
Call DELWIN(WWIN,DOSSIER) From MSKDIV

# delete Ecran
Local Char WSCREEN
WSCREEN= "TAXUSA"
Call DELMSK(WSCREEN,DOSSIER) From MSKDIV

# delete Traitement source et adx
For TRT="FUNTAXUSA"
    If filinfo(filpath("TRT",TRT,"adx",DOSSIER),1) >= 0
        Call EFFACE_ADX("",DOSSIER,TRT,STAT) from ORDSYS
        If STAT
            Call ECR_TRACE("UTIIND12: Error of deletion - "-filpath("TRT",TRT,"adx",DOSSIER)
&                                 -"(STAT="+num$(STAT)-")",1) From GESECRAN
        Endif
    Endif
    If filinfo(filpath("TRT",TRT,"src",DOSSIER),1) >= 0
        Call EFFACE(filpath("TRT",TRT,"src",DOSSIER),STAT) From ORDSYS
        If STAT
            Call ECR_TRACE("UTIIND12: Error of deletion - "-filpath("TRT",TRT,"src",DOSSIER)
&                                 -"(STAT="+num$(STAT)-")",1) From GESECRAN
        Endif
    Endif
Next


# delete dico ADICTRT 
If clalev([F:DADC])=0 : Local File =DOSSIER+".ADICTRT"  [DADC] : Endif
Read [F:DADC]ADC0 = "FUNTAXUSA"
If fstat = 0
    Delete [DADC] Where CODTRT = "FUNTAXUSA"
Endif



Call ECR_TRACE("UTIIND12 End of Update",0) From GESECRAN

Close Local File

End



