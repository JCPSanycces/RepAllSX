# GTAMUNI unitaire ou GTAMMAS massif
 Call LAUNCH_ACT(GTAMMAS)
End
#====================================================================================#
#            Gestion de l'action métier FASTRFC                                      #
#====================================================================================#
######################################################################
# Etiquettes modèle Traitement standard / saisie fenêtre / gobjet
######################################################################
$ACTION
  If dim(ORIACT)>0 & ORIACT<>""
    Case ORIACT
     When "TRTOBJ"
      Case ACTION
       When "LIENS"     : Gosub LIENS_MFS
       When Default
      Endcase
     When Default
    Endcase
  Else
   Case ACTION
    When "INIT_DIA"     : Gosub INIT_DIA
    When "INIT"         : Gosub INIT
    When "AVANT_PAR"    : Gosub AVANT_PAR
    When "OUVRE"        : Gosub OUVRE
    When "OUVRE_BATCH"  : Gosub OUVRE_BATCH
    When "DEBUT"        : Gosub DEBUT
    When "CONTROLE"     : Gosub CONTROLE
    # Ajout pour import des mvts
    When "IMP_MVT"      : Gosub IMP_MVT
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "SETBOUT"      : Gosub SETBOUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "BOUTON"       : Gosub BOUTON
    When "END"          : Gosub END_BOITE
    When "OK"           : Gosub OK
    When "ABA"          : Gosub ABA
    When "EXEC"         : Gosub EXEC
    When "FIN"          : Gosub FIN
    When "TERMINE"      : Gosub TERMINE
    When "SORTIE"       : Gosub SORTIE
    When Default
   Endcase
  Endif

Return
#=====================================================================
$OUVRE_BATCH             # (Massif uniquement - Soumission batch uniquement)
  Gosub OUVRE_TABLES From TRTFASMTC
Return
#=====================================================================
$INIT_DIA
  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$INIT                    # (Massif uniquement - interactif et exécution batch)
  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT

  If GSERVEUR
    Gosub CREE_GLOBTRT
  Endif
  G_TRACE       = G_NON
  G_TRF_PCG     = G_NON
  G_TRF_IAS     = G_NON
  G_CFS         = G_NON  : # FQ95754_2
  G_CNLCFS      = G_NON  : # FQ95754_3
  GACTVIRBOUT    = 1

Return
#=====================================================================
$AVANT_PAR               # (Massif uniquement - Interactif et soumission batch)
  Gosub AVANT_PAR From TRTFASMTC

 ##### Préparation et lancement de l'action en mode silencieux
 If ACTSILENCE=G_OUI
  Gosub CREE_GLOBTRT
 Endif

 If ACTSILENCE=G_OUI & TRTFILMSK<>""
  TYPPRG=0
  Gosub INIT_WIN  From TRMPROACT
  Gosub ALIM_MASK From =TRTFILMSK
 Endif

Return
#=====================================================================
$OUVRE                   # (Massif interactif et Unitaire)

  If dim(TRTMODACT)<0
   Global Char TRTMODACT
   TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Endif

  Gosub ACTION From =TRTMODACT
  Gosub OUVRE_TABLES From TRTFASMTC

  Local Char OLDCPY(GLONCPY)

  If !GSERVEUR
    Gosub CREE_GLOBTRT
  Endif

  If ( ACTTYPGES = GTAMMAS )
    Global Integer  G_DEFORCE
  Endif
  G_TRACE       = G_NON

  If  G_TRACE = G_NON : Endif
  G_TRF_PCG     = G_NON
  G_TRF_IAS     = G_NON
  G_CFS         = G_NON  : # FQ95754_2
  G_CNLCFS      = G_NON  : # FQ95754_3
  GACTVIRBOUT    = 1

Return
#=====================================================================
$CREE_GLOBTRT
  #==> Déclaration globales nécessaires à  la fonction
  Global Integer    GACTVIRBOUT
  Global Char       GMD1, GQTY
  Global Integer    G_TRF_IAS, G_TRF_PCG, G_REPORT, G_TRACE, G_INCR
  Global Integer    G_CFS    : # FQ95754_2
  Global Integer    G_CNLCFS : # FQ95754_2
  Global Integer    PLAN(1..G301MAX)              #Fq-58042
  Global Char       TBLDPM(GLONDPM)(1..G301MAX)   #Fq-58042
  Global Decimal    TBLDUR(1..G301MAX)            #Fq-58042
  Global Decimal    TBLRAT(1..G301MAX)            #Fq-58042
  Global Decimal    TBLRAT2(1..G301MAX)           #Fq-58042
  Global Integer    TBLALW(1..G301MAX)            #Fq-58042
  Global Char       TBLVEH(1)(1..G301MAX)         #Fq-58042
  Global Integer    TBLPRA(1..G301MAX)            #Fq-58042
  Global Decimal    TBLACL(1..G301MAX)            #Fq-58042
  Global Integer    G_TBLMAJ(1..5,1..G301MAX)
  Global Char       GFAS, GDPO, GDPN
  Global Integer    G_MES   #*V5 Mise en service
  Global Date       GDATREF
  # FQ109842  If not(dim(GBACAUTNUM)>0) : Global Libelle GBACAUTNUM : Endif : # Numérotation automatique "Code à  barres"
  Global Integer    GFRADGI       #*FQ-87928 indicateur "Règlementation DGI N° 13L-1-06" de la société

  #FQ80039
  If dim(GPRVSITUPD) < 0
    Global Integer  GPRVSITUPD
  Endif
  Raz GPRVSITUPD

  #*FQ-87928 indicateur "Règlementation DGI N° 13L-1-06" de la société
  If dim(GFRADGI) < 0
    Global Integer  GFRADGI
  Endif


Return
#=====================================================================
$DEBUT # (Massif et Unitaire)
Local Integer    I
Global Integer   PLAN(1..G301MAX)              #Fq-58042
Global Char      TBLDPM(GLONDPM)(1..G301MAX)   #Fq-58042
Global Decimal   TBLDUR(1..G301MAX)            #Fq-58042
Global Decimal   TBLRAT(1..G301MAX)            #Fq-58042
Global Decimal   TBLRAT2(1..G301MAX)           #Fq-58042
Global Integer   TBLALW(1..G301MAX)            #Fq-58042
Global Char      TBLVEH(1)(1..G301MAX)         #Fq-58042
Global Integer   TBLPRA(1..G301MAX)            #Fq-58042
Global Decimal   TBLACL(1..G301MAX)            #Fq-58042
Global Integer   G_TBLMAJ(1..5,1..G301MAX)
Local Char       TRC_CPY
Local Char       LACCCOD
Local Integer    LUPDFLG
Local Integer LCDRET
Local Char LMESSAGE

G_MES = G_NON

  #69691 ajout pour import des mvts
  If dim(GFXALMSK) > 0
      Return
  Endif
  # Spécifique
  If ( ACTTYPGES=GTAMUNI )
    # Le type de détention du bien est "En modèle".
    If ( [M:FAS1]OWNTYP = GVML_TDMODEL )
      GERR= 1: GMESSAGE = mess(65,GML_MSGFAS,1) : FIN=1 : Return
    Endif
    # Le bien a fait l'objet d'une sortie réelle.
    If ( [M:FAS4]ISSDAT <> [0/0/0] and [M:FAS4]EXTISSFLG = G_NON )
      GERR= 1: GMESSAGE = mess(66,GML_MSGFAS,1) : FIN=1 : Return
    Endif
  Endif

  # Standard
  If ( ACTTYPGES=GTAMUNI )
#69691 ajout pour import des mvts
# on va venir initialiser ici l'action
$DEB_ITFMVT
    # En unitaire la société est la société du bien
    [M:FASC]CPY2 = [M:FAS0]CPY
    [M:FASC]ITSDATD = [M:FAS1]ITSDAT
    TRC_CPY=[M:FAS0]CPY
    Gosub SET_CPY_DAT
    Call INIT_PLAN_AMT([M:FAS0]CPY)
    # Le code comptable est-il déduit de la famille et non modifiable (selon assoc)
    If ( [M:FAS1]ACGGRP <> "" )
      Call DETER_ACCCOD([M:FAS1]ACGGRP, [M:FAS0]CPY, LACCCOD, LUPDFLG) From TRTASSO
      If LUPDFLG = G_NON :  Diszo [M:FASC]FLGACC : Endif
    Endif
    # conditionnement des champs selon associations (modifiable ou non)
    Raz PLAN
    For I = 1 To [M:FASM]NBLIG1
      If  [M:FASM]TRTFLG(I-1) = G_OUI   #Fq-73545
         PLAN(I) = [M:FASM]DPRPLND(I-1)
      Endif
    Next I

    Call DETER_VAL_PLANS
&   ([M:FAS0]CPY, [M:FAS1]ACGGRP, [M:FAS1]ACCCOD,
&                  PLAN, TBLDPM, TBLDUR, TBLRAT, TBLRAT2, TBLALW, TBLVEH, TBLPRA, TBLACL, G_TBLMAJ)
&   From TRTASSO
  Endif

  Gosub ACTION From =TRTMODACT

  #--> On rend le masque invalide pour faire tous les contrôles
  # Setmok [M:FASM] With 0

  Diszo [M:FASC]GACACND
  Diszo [M:FASC]IASACND
  [M:FASC]FLGOWN = G_NON
  [M:FASC]FLGACG = G_NON
  [M:FASC]FLGACC = G_NON
  [M:FASC]FLGSAL = G_NON     # Fq-51185
  [M:FASC]FLGSALORI = G_NON : # FQ95754_3
  Grizo [M:FASC]OWNTYPD
  Grizo [M:FASC]ACGGRPD
  Grizo [M:FASC]ACCCODD
  Grizo [M:FASC]SALCLSDATD   # Fq-51185
  Grizo [M:FASC]EXTSALAMT    # Fq-85984

  # FQ95754
  If ACTTYPGES=GTAMUNI
    If [M:FAS4]SALCLSDAT <> [0/0/0]
      # FQ95754_3 Pas d'accès aux champs de saisie sauf flag annulation classement pour vente
      Call ACTION_BLOCK (ACB_DISZO, "FASTRFC", "FLGOWN") From GLOBIENS
      [M:FASC]FLGSAL    = G_OUI
      [M:FASC]FLGSALORI = G_OUI : # FQ95754_3
      Actzo [M:FASC]FLGSAL
      Affzo [M:FASC]FLGSAL
      #Diszo [M:FASC]FLGSAL
      # FQ95754_3
      Call AM_FLGSAL([M:FASC]FLGSAL)
      Grizo [M:FASC]SALCLSDATD
      Grizo [M:FASC]EXTSALAMT
      Call ACTION_BLOCK (ACB_DISZO, "FASTRFCP", "NBLIG1") From GLOBIENS
    Endif
  Endif

  # FQ95754_4 Pas de gestion de classement pour vente en massif ou si aucun plan normé IAS/IFRS
  If ( ACTTYPGES = GTAMMAS or find (GVML_NPIAS, [M:FPC]PLNSTD)= 0  )
    Chgfmt [M:FASC]FLGSAL      With "-K:5X"
    Chgfmt [M:FASC]SALCLSDATD  With "-D:"+GFMDAT4
    Chgfmt [M:FASC]EXTSALAMT   With "-N:9.2"
    Chgfmt [M:FASC]ACGCUR      With "-K:5X"
  Endif

  #-TRFC en mode silencieux
  If ACTSILENCE=G_OUI & TRTFILMSK<>""
   TYPPRG=0
   Gosub ALIM_MASK From =TRTFILMSK
  Endif

Return
#=====================================================================
$CONTROLE

    #69691 ajout pour import des mvts
    If dim(GFXDNBERR) > 0

        # ne pas continuer si erreur lors de l'alim des champs (de FXDINT)
        If GFXDERRALCHP = 0

            Local Integer SV_ERR_TRACE
            Default Mask [M:FASC]

            GIMPORT = 1 # permet de ne pas afficher à l'écran les messages d'erreur
            SV_ERR_TRACE = GERRTRACE
            NBLIG = [M:FASM]NBLIG1
            indice = 0

            # contrôle 1° onglet (famille, code comptable...)
            # nota : l'alim de ces champs est faite dans FXDINT
            Call SAIMSK("", "IMP_MVT", "TRTFASTRFC") From W0FASTRFC

            If SV_ERR_TRACE = GERRTRACE

               # alim des champs du 2° onglet (plans)
               # --> pour affectation des TRTFLG qui vont être utiles dans la boucle suivante :
                Default Mask [M:FASM]
                Call ALIMCHP(GFXDNBERR, 2) From FXDINT

                If GFXDNBERR <> GSVNBERREURS
                    GFXDERRALCHP = 1
                Endif
            Endif

            If GFXDERRALCHP = 0 and SV_ERR_TRACE = GERRTRACE
                # --> les TRTFLG positionnent les ACTZO des champs (si...)
                For nolign=1 To NBLIG
                    indice = nolign-1
                    [M]NBLIG1 = nolign
                    # FQ90828
                    #Call AS_TRTFLG([M:FASM]TRTFLG(nolign - 1))
                    If [M:FASM]TRTFLG(nolign-1) = G_OUI
                        Gosub COND_LIGPLN_ACTZO
                        Actzo [M:FASM]TRTFLG(nolign-1)
                    Else
                        [M:FASM]TRTFLG(nolign-1) = G_NON
                        Gosub COND_LIGPLN_DISZO
                        Diszo [M:FASM]TRTFLG(nolign-1)
                    Endif
                Next nolign

                # contrôle 2° onglet et affectation des associations
                Affzo [M:FASM]

                Call SAIMSK("", "IMP_MVT", "TRTFASTRFC") From W0FASTRFCP
                Affzo [M:FASM]
            Endif

            If GFXDERRALCHP = 0 and SV_ERR_TRACE = GERRTRACE
               # (re)alim des champs du 2° onglet
               # --> pour affectation des champs après (sur) les associations
                Call ALIMCHP(GFXDNBERR, 2) From FXDINT

                If GFXDNBERR <> GSVNBERREURS
                    GFXDERRALCHP = 1
                Endif
            Endif

            If GFXDERRALCHP = 0 and SV_ERR_TRACE = GERRTRACE
                # (re)contrôle 2° onglet SANS affectation des associations
                # test par dim(GSAINONASSOC) dans AM_TRTFLG
                Global Integer GSAINONASSOC
                Call SAIMSK("", "IMP_MVT", "TRTFASTRFC") From W0FASTRFCP
                Kill GSAINONASSOC
                Affzo [M:FASM]
            Endif

            If GFXDERRALCHP = 0 and SV_ERR_TRACE = GERRTRACE
                # contrôle si les champs (interfacés) sont saisissable ou non
                Call CTLVARMODE(GFXDNBERR) From FXDINT
            Endif
        Endif

        GIMPORT = 0
        # setmode final
        Setmode

        If GFXDERRALCHP or SV_ERR_TRACE <> GERRTRACE
            FIN = 1
            GERR = 1
            #FQ10941
            If [F:FXM]DESRJTMVT = ""
                [F:FXM]DESRJTMVT = GMESSAGE
                If [F:FXM]DESRJTMVT = ""
                    [F:FXM]DESRJTMVT = right$(GMESSIMP, 2)
                Endif
            Endif
            Return
        Endif
    Endif

    Gosub ACTION From =TRTMODACT
Return
#=====================================================================

#=====================================================================
$APRES_MODIF

  Gosub ACTION From =TRTMODACT
  Case COUZON
    When "FLGCPY"
      If ( val(CZ) = G_OUI )
        Call INIT_PLAN_AMT([M:MHC]CPY(COUIND))
        [M:FASC]CPY2 = [M:MHC]CPY(COUIND)
      Else
        Call ACTION_BLOCK (ACB_EFFZO, "FASTRFC", "FLGOWN") From GLOBIENS
        [M:FASM]NBLIG1 = 0
        Affzo [M:FASM]NBLIG1
      Endif
    When "FLGFCY"
      If ( val(CZ) = G_OUI )
        If ( OLDCPY <> [M:MHC]FCYCPY(COUIND) )
          OLDCPY = [M:MHC]FCYCPY(COUIND)
          Call INIT_PLAN_AMT([M:MHC]FCYCPY(COUIND))
          [M:FASC]CPY2   = [M:MHC]FCYCPY(COUIND)
        Endif
      Else
        If ( find(G_OUI,[M:MHC]FLGCPY) = 0 )
          Call ACTION_BLOCK (ACB_EFFZO, "FASTRFC", "FLGOWN") From GLOBIENS
          [M:FASM]NBLIG1 = 0
          Affzo [M:FASM]NBLIG1
        Endif
      Endif
    When Default
  Endcase


  Local Char ACTCRITERE(255)

  If COUZON="FLGOWN"
   ACTCRITERE="val(CZ)=G_NON"
  Else
   ACTCRITERE="[M:FASC]FLGOWN = G_NON"
  Endif
  If COUZON="ACGGRPD"
   ACTCRITERE+=" and  CZ = ''"
  Else
   ACTCRITERE+=" and  [M:FASC]ACGGRPD = ''"
  Endif
  If COUZON="ACCCODD"
   ACTCRITERE+=" and CZ = '' "
  Else
   ACTCRITERE+=" and [M:FASC]ACCCODD = '' "
  Endif
  If COUZON="SALCLSDAT"
    ACTCRITERE+="  and [M:FASC]FLGSAL = G_NON  "
  Else
     ACTCRITERE+="  and [M:FASC]FLGSAL = G_NON "
  Endif
  If evalue(ACTCRITERE)
    GACTVIRBOUT = 1
  Endif

Return
#=====================================================================
$SETBOUT                 # (Massif interactif et unitaire : )
  Gosub ACTION From =TRTMODACT

  If ( GACTVIRBOUT = 1)
      GACTVIRBOUT = 0
      If ( dim(CHBOU)>0 )   : Call VIREBOUT (CHBOU,"O") From GOBJET : Endif
      If ( dim(CHBOU)>0 )   : Call VIREBOUT (CHMEN,"D") From GOBJET : Endif
  Endif

Return
#=====================================================================
$AV_CHOIX

 # En rappel de mémo, on réalimente GDATREF
 If BOUT="R"
    Local Integer I_CPY
    I_CPY=find(G_OUI,[M:MHC]FLGCPY)
    If I_CPY
       Local Char    L_CPY
       Local Integer L_RET
       Local Date    L_CNXDAT(1..5)
       L_CPY=[M:MHC]CPY(I_CPY-1)
       Call GET_CNX_DAT2(L_CPY, G300CPFI, GVML_TECOURA, L_CNXDAT, L_RET) From GLOBIENS
       GDATREF = L_CNXDAT(3)
    Endif
 Endif

Return
#=====================================================================
$AP_CHOIX                 # (Unitaire : )
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$BOUTON                  # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$END_BOITE               # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$OK                      # (Massif intéractif et unitaire)
 Gosub ACTION From =TRTMODACT
Return
#=====================================================================
$ABA
  If ( dim(GABAERR) > 0)
    Kill GABAERR
  Else
    GACTVIRBOUT = 1
    # Réinitialisation du tableau des paramètres par plan d'amortissement
    If ( ACTTYPGES=GTAMUNI )
      # En unitaire la société est la société du bien
      [M:FASC]CPY2 = [M:FAS0]CPY
      Call INIT_PLAN_AMT([M:FAS0]CPY)
    Endif
  Endif
  Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$EXEC                    # (Massif intéractif et batch)
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$FIN                     # ()
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$TERMINE                  # ()

 Gosub ACTION From =TRTMODACT

Return
#=====================================================================
$SORTIE                   # ()
 Gosub ACTION From =TRTMODACT
Return

######################################################################
# Points d'entrée de l'action métier communs unitaire / massif
######################################################################
#
# Construction du nom des étiquettes :
#
# AAAA_BBBB_CCCCCC
#
# AAAA => Nom de la table origine (MAS1 / TMP1 / TPF1
# BBBB => Etape de l'action
# CCCC => Table destination ou Action ou Objet
#
######################################################################

$ACTMET
 Case ACTMET
  When "CRITMEN"            :   Gosub CRITMEN              # U  - Activation menu ou bouton
  When "SET_PRECHARGE"      :   Gosub SET_PRECHARGE        # U  - A positionner à  G_OUI s'il n'y a pas de bouton sélectionner
  When "SET_CRITACT"        :   Gosub SET_CRITACT          # UM - CRITACT critère de sélection particulier à  l'action métier
  When "FILL_HEA"           :   Gosub FILL_HEA             # U  - Alimentation partie spécifique en-tête

# Locker
  When "OUVR_LOCK"          :   Gosub OUVR_LOCK            # UM - Ouverture de tables annexes pour les lock
  When "MAS1_CONTROLE"      :   Gosub MAS1_CONTROLE        # UM  - Exclusion élément de la population à  sélectionner
  When "MAS1_LOCK_AUTRE"    :   Gosub MAS1_LOCK_AUTRE      # UM - Lock objet lié à  l'enr en ligne de la population

# Charger
  When "OUVR_ALIM_TMP1"     :   Gosub OUVR_ALIM_TMP1       # UM - Ouverture de tables annexes pour l'alim des table tmp.
  When "MAS1_ALIM_TMP1"     :   Gosub MAS1_ALIM_TMP1       # UM - Transfert zones tables de données -> tables tempo

# Applique_temp
  When "OUVR_APPL_TMP1"     :   Gosub OUVR_APPL_TMP1       # UM - Ouverture de tables annexes
  When "TMP1_APPL_TMP1"     :   Gosub TMP1_APPL_TMP1       # UM - Application des paramètres de l'action aux enr de la table temporaire principale
  When "TPF1_APPL_TPF1"     :   Gosub TPF1_APPL_TPF1       # UM - Application des paramètres de l'action aux enr de la table temporaire annexe

# Report_mask Report objet principal dans les masques (unitaire uniquement)
  When "TMP1_ALIM_MASK"     :   Gosub TMP1_ALIM_MASK       # U  - Tansfert table temporaire principale -> masques de l'écran
  When "TPF1_ALIM_MASK"     :   Gosub TPF1_ALIM_MASK       # U  - Tansfert table temporaire annexe     -> masques de l'écran
  When "REAF_ALIM_MASK"     :   Gosub REAF_ALIM_MASK       # U  - Tansfert tables temporaires -> masques de l'écran (pour réaffichage)

# Applique_dirt Mise à  jour directe (massif uniquement)
  When "OUVR_APPL_DIRT"     :   Gosub OUVR_APPL_DIRT       # M  - Ouverture de tables annexes pour la maj directe en massif
  When "MAS1_APPL_DIRT"     :   Gosub MAS1_APPL_DIRT       # M  - Mise à  jour directe des tables de données avec les paramètres de l'action
  When "CLOS_APPL_DIRT"     :   Gosub CLOS_APPL_DIRT       # M  - Fermeture

# reporter
  When "OUVR_ALIM_TABLE"    :   Gosub OUVR_ALIM_TABLE      # UM - Ouverture tables annexes avant report tables tempo -> tables de données
  When "TMP1_ALIM_TABLE"    :   Gosub TMP1_ALIM_TABLE      # UM - Report table temporaire principale -> table de données
  When "TPF1_ALIM_TABLE"    :   Gosub TPF1_ALIM_TABLE      # UM - Report table temporaire par plan   -> table de données par plan
  When "CLOS_ALIM_TABLE"    :   Gosub CLOS_ALIM_TABLE      # UM  - Fermeture

# Fin traitement
  When "END_ALIM_TABLE"     :   Gosub END_ALIM_TABLE       # UM - Traitement de fin unitaire ou de MAJ indirecte
  When "END_APPL_DIRT"      :   Gosub END_APPL_DIRT        # M  - Traitement de fin de MAJ directe

  When Default

 Endcase
Return

#=====================================================================
# Unitaire : critère désactivation / activation menu CRITMEN
$CRITMEN
 Local Integer ACCFCY
 Local Char AUZFCY (15)

 # Accès selon droit à  l'option
 Call DROITSITE ( [M:FAS0]FCY, [L]AUZFCY, [L]ACCFCY ) From SUPCPT
 If ( not [L]ACCFCY or not instr(1, [L]AUZFCY, 'R') )
   CRITMEN = "1=0"
 Else
   CRITMEN = "1=1"
 Endif

Return
#=====================================================================
# Unitaire : Modif de la variable déclenchant le préchargement en unitaire PRECHARGE
$SET_PRECHARGE
 PRECHARGE=G_OUI
Return
#=====================================================================
# Unitaire / massif : Critère de sélection particulier à  l'action métier
$SET_CRITACT
  # CRITACT contient les critères de sélection suppplémentaires à  appliquer à  la population à  sélectionner
  # Les biens modèles ou ceux ayant fait l'objet d'une sortie "réelle" sont exclus de la sélection
  CRITACT=" ( OWNTYP <> GVML_TDMODEL AND ( ISSDAT = [0/0/0] or EXTISSFLG = G_OUI ) ) "
Return
#=====================================================================
# Unitaire : Permet d'alimenter des zones spécifiques de l'en-tête de la fenêtre
$FILL_HEA
Return
#=====================================================================
# Unitaire et massif : Sert à  ouvrir des tables utilisées dans MAS1_CONTROLE
#                      et MAS1_LOCK_AUTRE
$OUVR_LOCK
  Gosub OUVRE_TABLES From TRTFASMTC
Return
#=====================================================================
# Unitaire / massif : contrôle élément pour retrait de la population
$MAS1_CONTROLE

   ##################################################################
   # Fq-54343   Point d'entrée                                      #
   # Avant alimentation del'enregistrement TMP1                     #
   # on donne la possibilité de rejeter un enregistrement de MAS1   #
   # en positionnant GOK à 0                                        #
   ##################################################################
  GOK=1
  GPOINT="TRFCTLMAS1" : Gosub ENTREE From EXEFNC
  If GOK<1 : Return : Endif
  #### Point d'entrée - Fin ######################

Return
#=====================================================================
# Unitaire / massif : Lock d'objet lié à  l'enregistrement en ligne
#                     Alimenter RMES si un message soit apparaitre
$MAS1_LOCK_AUTRE
  # Verrouillage des dépenses associées pour mettre à jour les comptes FQ60753
  Local Integer LCKOK

  For [F:LOF]LOF6 Where AASREF=[F:MAS1]AASREF
   LKEY = func GLOBIENS.GET_KEY_LAYOUTFAS ([F:LOF]CODLOF, [F:LOF]LINLOF)
   If !(LKEY="")
     LCKOK=func GLOBIENS.LOCK_SYMBOLE ("LOF", [F:LOF]CPY, LKEY, 0)
     If LCKOK=0
       RMES=mess(226,GML_MSGFAS,1)-[F:LOF]CODLOF+num$([F:LOF]LINLOF)+"/"+[F:LOF]DES+"." # "Enregistrement en cours d'utilisation"
       GOK=-1
       Break
     Elsif LCKOK=1
       GOK=1
       Raz [TML]
       [F:TML]TRTNUM  = NUMACT
       [F:TML]OBJTYP  = GVML_OMDEPEN
       [F:TML]OBJREF  = [F:LOF]CODLOF
       [F:TML]OBJLIN  = [F:LOF]LINLOF
       [F:TML]OBJCPY  = [F:LOF]CPY
       [F:TML]OBJSYM  = LKEY
       [F:TML]OBJMAIN = G_NON
       Write [TML]
       If fstat
         Case fstat
           When 1
             RMES="TMPMASLCK"-mess(227,GML_MSGFAS,1)  # "TMPMASLCK table verrouillée"
           When 3
             RMES=mess(129,GML_MSGFAS,1)-[F:TML]TRTNUM+"/"+[F:TML]OBJREF  # Tentative d'écriture en double de la clé
             If ACTREFOBJ="LOF" : RMES+="/"+[F:TML]OBJLIN : Endif
             RMES-="\TMPMASLCK."       #
         Endcase
         GOK=0
         Break
       Endif
       NBOBJLCK+=1
     Elsif LCKOK=-1
       GOK=0
     Endif
   Endif
  Next
Return
#=====================================================================
# Unitaire / massif : Sert à  ouvrir des tables utilisées dans MAS1_ALIM_TMP1
$OUVR_ALIM_TMP1
  Gosub OUVRE_TABLES From TRTFASMTC
Return
#=====================================================================
# Unitaire / massif : Chargement de la population en table temporaire
#                     Etiquette appelée par le s/p CHARGER
#                     Si une erreur se produit dans cette étiquette
#                     Alimenter RMES avec le message qui doit apparaître
#                     dans une boîte en unitaire ou en massif
$MAS1_ALIM_TMP1

  #If ( G_TRACE = G_OUI)   : Infbox "MAS1_ALIM_TMP1" : Endif

# Alimentation des tables temporaires
  #**************************
  Raz [F:TMP1]
  Raz [F:TPF1]
  [F:TMP1]FLGERR     = G_NON
  [F:TMP1]FLGMOD     = G_OUI
  # Chargement table temporaire TMPPLNFAS [F:TPF1] avec infos de chacun des plans d'amort [F:MASM]
  # >>>>>>>>>>
  For nolign=1 To [M:FASM]NBLIG1
    #-1------------
    If ([M:FASM]TRTFLG(nolign-1) = G_OUI  or ACTTYPGES= GTAMUNI)
      [F:TPF1]FLGERR = G_NON
      [F:TPF1]FLGMOD = G_OUI
      # Ajout PLO si unitaire ecran de contrôle non modifiable
      If (ACTTYPGES = GTAMUNI )
       [F:TPF1]FLGMOD     = G_NON
      Endif

      # Lecture DEPREC pour l'exercice et la période courante
      Read [DEP] DEP0=[F:MAS1]AASREF;[M:FASM]DPRPLND(nolign-1);
&                     [M:FASM]FIYENDDAT(nolign-1); [M:FASM]PERENDDAT(nolign-1)
      If (fstat)
        # Lecture DEPREC pour l'exercice et la période correspondant au dernier mouvement
        Filter [DEP] Where AASREF= [F:MAS1]AASREF and DPRPLN= [M:FASM]DPRPLND(nolign-1)
        Read [DEP]DEP0 Last
        Filter [DEP]
        If (fstat)
          # Erreur technique
          RMES=mess(104,GML_MSGFAS,1)-"DEPREC"-mess(105,GML_MSGFAS,1)-"03"-mess(106,GML_MSGFAS,1)-[F:MAS1]AASREF+"/"+num$([M:FASM]DPRPLND(nolign-1))
          GOK=0 : Break
        Endif
      Endif

      # ------------------
      [F:TPF1]  = [F:DEP]
      # ------------------


      # Informations spécifiques
      [F:TPF1]TRTNUM     = NUMACT
      [F:TPF1]OBJREF     = [F:MAS1]AASREF
      [F:TPF1]DPRPLN     = [F:DEP]DPRPLN
      [F:TPF1]CNX        = [F:DEP]CNX
      [F:TPF1]FIYENDDAT  = [F:DEP]FIYENDDAT
      [F:TPF1]PERENDDAT  = [F:DEP]PERENDDAT
      [F:TPF1]FIYSTRDAT  = [F:DEP]FIYSTRDAT
      [F:TPF1]PERSTRDAT  = [F:DEP]PERSTRDAT
      [F:TPF1]STRDPRDAT  = [F:DEP]STRDPRDAT
      [F:TPF1]ENDDPRFLGO = [F:DEP]ENDDPRFLG      # FQ82178
      [F:TPF1]ENDDPRDATO = [F:DEP]ENDDPRDAT      # FQ82178
      [F:TPF1]RATCUR     = [F:DEP]RATCUR
      [F:TPF1]DPMO       = [F:DEP]DPM
      [F:TPF1]STRDPRDATO = [F:DEP]STRDPRDAT
      [F:TPF1]DPRDURO    = [F:DEP]DPRDUR
      [F:TPF1]DPRRATFLGO = [F:DEP]DPRRATFLG
      [F:TPF1]DPRRATO    = [F:DEP]DPRRAT
      [F:TPF1]DPRRAT2O   = [F:DEP]DPRRAT2
      [F:TPF1]RSDVALO    = [F:DEP]RSDVAL
      [F:TPF1]CRBVEHCODO = [F:DEP]CRBVEHCOD
      [F:TPF1]ALWCODO    = [F:DEP]ALWCOD
      [F:TPF1]ACLCOEO    = [F:DEP]ACLCOE
      [F:TPF1]PRATYPO    = [F:DEP]PRATYP
      [F:TPF1]FIYENDDAT2 = [M:FASM]FIYENDDAT2(G301CPT-1)
      [F:TPF1]PERENDDAT2 = [M:FASM]PERENDDAT2(G301CPT-1)
      [F:TPF1]FIYENDDAT3 = [M:FASM]FIYENDDAT(G301CPT-1)
      [F:TPF1]PERENDDAT3 = [M:FASM]PERENDDAT(G301CPT-1)

      Write [TPF1]
      #--------
      If (fstat)
        Case fstat
          When 1
            # Erreur technique
            RMES=mess(104,GML_MSGFAS,1)-"TMPPLNFAS"-mess(105,GML_MSGFAS,1)-"04"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TPF1]OBJREF+"/"+num$([F:TPF1]DPRPLN)
            GOK=-1
          When 3
            # Erreur technique - Tentative d'écriture en double
            RMES=mess(129,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TPF1]OBJREF+"/"+num$([F:TPF1]DPRPLN)
            GOK=0
          When Default
            RMES=mess(104,GML_MSGFAS,1)-"TMPPLNFAS"-mess(105,GML_MSGFAS,1)-"04"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TPF1]OBJREF+"/"+num$([F:TPF1]DPRPLN)
            GOK=-1
        Endcase
        Break
      Else
        NBTMPPLN +=1
      Endif
      #--------
    Endif
    #-1-------------
  Next
  # <<<<<<<<<<

  If (GOK <> 1 )   : Return :  Endif

  # Chargement table temporaire TMPFASMAS [F:TMP1] avec infos du bien comptable [F:MAS1]
  [F:TMP1]TRTNUM     = NUMACT
  [F:TMP1]CPY        = [F:MAS1]CPY
  [F:TMP1]OBJREF     = [F:MAS1]AASREF
  [F:TMP1]AASDES1    = [F:MAS1]AASDES1
  [F:TMP1]AASTYP     = [F:MAS1]AASTYP
  [F:TMP1]OWNTYP     = [F:MAS1]OWNTYP
  [F:TMP1]ACGGRP     = [F:MAS1]ACGGRP
  [F:TMP1]ACCCOD     = [F:MAS1]ACCCOD
  [F:TMP1]GAC        = [F:MAS1]GAC
  [F:TMP1]IASACC     = [F:MAS1]IASACC
  [F:TMP1]AASTYP     = [F:MAS1]AASTYP
  [F:TMP1]SALCLSDAT  = [F:MAS1]SALCLSDAT #Fq-51185
  [F:TMP1]EXTSALAMT  = [F:MAS1]EXTSALAMT #Fq-85984
  If  [M:FASC]ITSDATD <> [0/0/0]
     [F:TMP1]ITSDAT  = [M:FASC]ITSDATD
  Else
      [F:TMP1]ITSDAT = [F:MAS1]ITSDAT
  Endif

  Write [TMP1]
  If (fstat)
    Case fstat
      When 1
        # Erreur technique - Entrée sortie.
        RMES=mess(104,GML_MSGFAS,1)-"TMPMASFAS"-mess(105,GML_MSGFAS,1)-"05"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TMP1]OBJREF
        GOK=-1
      When 3
        # Erreur technique - Tentative d'écriture en double
        RMES=mess(129,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TMP1]OBJREF
        GOK=0
      When Default
    Endcase
    Return
  Else
    NBTMP+=1
  Endif
Return
#=====================================================================
# Unitaire / massif : Ouverture de tables annexes
$OUVR_APPL_TMP1
  #If ( G_TRACE = G_OUI)   : Infbox "OUVR_APPL_TMP1" : Endif

  # Ouverture de tables liées à  explorer ou à  mettre à  jour  par l'action massive
  If !(clalev([F:MAS1]))   : Local File FXDASSETS   [MAS1]   : Endif
  If clalev([F:ADI]) =0    : Local File ATABDIV     [ADI]    : Endif #FQ-62386 (ano annexe)

Return
#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire principale
$TMP1_APPL_TMP1

#FQ103489 Local Integer LOK, LERRBCO, LCABAUTO, LIMMAT
Local Integer LOK, LERRBCO, LIMMAT
Local Integer LCDRET
Local Char    LMESSAGE
Local Integer RFLGASS : RFLGASS = G_OUI #*Fq-56390

  #If ( G_TRACE = G_OUI)   : Infbox "TMP1_APPL_TMP1" : Endif

  LOK = G_OUI

  RMES           = ""
  [F:TPF1]MSGERR = ""
  [F:TMP1]FLGMOD = G_NON
  # Contrôle nouvelle imputation pour le bien
  #--------
  If (LOK = G_OUI)

    # Lecture du bien dans MAS1
    Read [MAS1] FAS0=[F:TMP1]OBJREF
    If (fstat)   : GOK= 0 : Return : Endif

    [F:TMP1] = [F:MAS1]

    Gosub CTRL_BIEN

    If ( LERRBCO )
      # Erreur sur bien
      LOK = G_NON
      RMES            = mess(LERRBCO,GML_MSGFAS,1)
      [F:TMP1]MSGERR  = mess(LERRBCO,GML_MSGFAS,1)
    Else
      # Application des nouveaux paramètres
      If ([M:FASC]FLGOWN <> G_NON)
        [F:TMP1]OWNTYP  = [M:FASC]OWNTYPD
      Endif
      # FQ95754_3
      #If ([M:FASC]FLGSAL <> G_NON)
      If ([M:FASC]FLGSAL <> G_NON or G_CNLCFS)
        [F:TMP1]SALCLSDAT  = [M:FASC]SALCLSDATD
        [F:TMP1]EXTSALAMT  = [M:FASC]EXTSALAMT # Fq-85984
      Endif
      If ( [M:FASC]FLGACG <> G_NON ) and ( [M:FASC]ACGGRPD <> "" )    #*Fq-56390
        [F:TMP1]ACGGRP     = [M:FASC]ACGGRPD
#Fq-73545  If (ACTTYPGES = GTAMUNI )
#Fq-73545     Call GERER_ASSOCIATION([M:FASC]ACGGRPD,  "FAM","FAS", [F:TMP1]OWNTYP, "OFAS",RFLGASS ) From TRTASSO   #*Fq-56390
#Fq-73545  Endif
       [F:TMP1]ACGGRP     = [M:FASC]ACGGRPD
#        If GPHY = G_OUI
          #FQ103489 Call IS_IMMATRICULABLE( [M:FASC]ACGGRPD, LIMMAT, LCABAUTO ) From TRTFAS
#          Call IS_IMMATRICULABLE([M:FASC]ACGGRPD, LIMMAT) From TRTFAS
#          [F:TMP1]BACFLG = LIMMAT#FQ103489
#        Endif
      Endif
      If ( [M:FASC]FLGACC <> G_NON )  and ( [M:FASC]ACCCODD <> "" )   #*Fq-56390
#Fq-73545 If (ACTTYPGES = GTAMUNI )
#Fq-73545   Call GERER_ASSOCIATION([M:FASC]ACCCODD ,  "COD", "FAS", [F:TMP1]OWNTYP, "OFAS",RFLGASS) From TRTASSO #*Fq-56390
#Fq-73545  Endif
        [F:TMP1]ACCCODO    = [F:TMP1]ACCCOD
        [F:TMP1]ACCCOD     = [M:FASC]ACCCODD
        [F:TMP1]GAC        = [M:FASC]GACD
        [F:TMP1]GACACN     = [M:FASC]GACACND
        [F:TMP1]IASACC     = [M:FASC]IASACCD
        [F:TMP1]IASACN     = [M:FASC]IASACND
        If  [M:FASC]ITSDATD <> [0/0/0]
           [F:TMP1]ITSDAT    =  [M:FASC]ITSDATD
        Endif
      Endif
    Endif
  Endif
  #--------
## Fq-85984

  If ( LOK = G_OUI and
&      [F:TMP1]OWNTYP     = [F:MAS1]OWNTYP and
&      [F:TMP1]SALCLSDAT  = [F:MAS1]SALCLSDAT and
&      [F:TMP1]EXTSALAMT  = [F:MAS1]EXTSALAMT and
&      [F:TMP1]ACCCOD     = [F:MAS1]ACCCOD and
&      [F:TMP1]ACGGRP     = [F:MAS1]ACGGRP )
    # Imputation comptable inchangée
    LOK            = G_NON
    RMES           = mess(210,GML_MSGFAS,1)
    [F:TMP1]MSGERR = mess(210,GML_MSGFAS,1)
  Endif

  #########################################################
  # Fq-54343   Point d'entrée                             #
  # Contrôles supplémentaires sur les biens               #
  # Modifications SPE sur l'enregistrement TMP1           #
  # on donne la possibilité de mettre le bien en erreur   #
  # en positionnant LOK à 1 (G_NON)                       #
  #########################################################
  GPOINT="TRFCTLTMP1" : Gosub ENTREE From EXEFNC
  If GOK<1 : Return : Endif
  #### Point d'entrée - Fin ######################

  If ( LOK = G_NON )
    [F:TMP1]FLGERR = G_OUI
    # Pas d'affichage des plans
    For [TPF1]TPF0 Where TRTNUM= [F:TMP1]TRTNUM and OBJREF=[F:TMP1]OBJREF
      [F:TPF1]FLGERR = G_NON
      Rewrite [F:TPF1]
    #------------------------------
    Next
  Endif

Return
#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire annexe (par plan)
$TPF1_APPL_TPF1

#If ( G_TRACE = G_OUI)   : Infbox "TPF1_APPL_TPF1" : Endif

Local Integer I_PLN, LCOUR, LOK, LERROR, LCHGD, RETOUR

  # Lecture du bien dans MAS1
  Read [MAS1] FAS0=[F:TMP1]OBJREF
  If (fstat)   : GOK= 0 : Return : Endif

  # [F:TPF1] <- [M:FASM]
  # -------------------------------
  I_PLN=find([F:TPF1]DPRPLN,[M:FASM]DPRPLND) : # Rang du plan dans tableau paramètres

  # Initialisation des indicateurs
  LOK = G_OUI : LERROR = 0
  [F:TPF1]MSGERR    = ""
  [F:TPF1]FLGERR    = G_NON
  [F:TPF1]FLGMOD    = G_OUI
  If (ACTTYPGES = GTAMUNI )   : [F:TPF1]FLGMOD = G_NON : Endif : # Si unitaire, Contrôler non modifiable
  LCHGD = G_NON : # Les paramètres de la méthode n'ont pas changé

  # Lecture DEPREC pour l'exercice et la période courante
  Read [DEP] DEP0=[F:MAS1]AASREF;[M:FASM]DPRPLND(I_PLN-1);
&                                [M:FASM]FIYENDDAT(I_PLN-1);
&                                [M:FASM]PERENDDAT(I_PLN-1)
  If (fstat)
    # Lecture DEPREC pour l'exercice et la période correspondant au dernier mouvement
    Filter [DEP] Where AASREF= [F:MAS1]AASREF and DPRPLN= [M:FASM]DPRPLND(I_PLN-1)
    Read [DEP]DEP0 Last
    Filter [DEP]
    If (fstat)
      # Erreur technique
      RMES=mess(104,GML_MSGFAS,1)-"DEPREC"-mess(105,GML_MSGFAS,1)-"03"-mess(106,GML_MSGFAS,1)-[F:MAS1]AASREF+"/"+num$([M:FASM]DPRPLND(I_PLN-1))
      GOK=0 : Return
    Endif
    LCOUR = G_NON
  Else
    LCOUR = G_OUI
  Endif

  # Contrôle
  If ( LOK = G_OUI and LCOUR = G_NON )
    # Le bien n'est pas amorti dans l'exercice courant/période courante
    LERROR = 180 : LOK = G_NON
    [F:TPF1]FLGMOD = G_NON
  Endif

  # Toujours : Sauvegarde anciennes valeurs dans DEPW
  [F:DEPW] = [F:DEP]
  #Fq-87928 on alimente MET2 avec le plan fiscal si l'on est sur le plan de subvention
  If GFRADGI=G_OUI
     If  [F:DEP]DPRPLN=G301SUB
        [M:MET2]DPRPLN=G301FIS
     Else
     # ou avec le plan de subvention  si l'on est sur le plan fiscal
        If [F:DEP]DPRPLN=G301SUB
           [M:MET2]DPRPLN=G301FIS
        Endif
     Endif
  Endif
  #--- 1 ---
  If ([M:FASM]TRTFLG(I_PLN-1) = G_OUI  )
     # Application de la valeur des paramètres saisis
     If ( LOK = G_OUI )
        # Nouvelles valeurs dans DEP
        Gosub ALIM_ENR_PLN From TRTFASMTC
        # Si la date de début d'amortissement a été saisie en paramètre
        # et qu'il ne s'agit pas d'une mise en service
        #  la date de début d'amortissement peut être modifiée sous certaines conditions
        #Fq-78438   la date de début d'amortissement ne doit pas être modifiée
#Fq-78438        If ( ( [F:MAS1]GACACN = GVML_NIENSER or [M:FASC]GACACND <> GVML_NIENSER )  and
#Fq-78438 &              [F:DEP]STRDPRDAT  <> [F:DEPW]STRDPRDAT )
#Fq-78438            [F:DEP]STRDPRDAT = [F:DEPW]STRDPRDAT
#Fq-78438         Endif
     Endif

     # Contrôle
     # FQ82178 ajout ENDDPRDAT
     If ( LOK = G_OUI and
&       [F:DEP]DPM        = [F:DEPW]DPM       and
&       [F:DEP]STRDPRDAT  = [F:DEPW]STRDPRDAT and
&       [F:DEP]ENDDPRDAT  = [F:DEPW]ENDDPRDAT and
&       [F:DEP]DPRDUR     = [F:DEPW]DPRDUR    and
&       [F:DEP]DPRRAT     = [F:DEPW]DPRRAT    and
&       [F:DEP]DPRRAT2    = [F:DEPW]DPRRAT2   and
&       [F:DEP]RSDVAL     = [F:DEPW]RSDVAL    and
&       [F:DEP]CRBVEHCOD  = [F:DEPW]CRBVEHCOD and
&       [F:DEP]ALWCOD     = [F:DEPW]ALWCOD    and
&       [F:DEP]ACLCOE     = [F:DEPW]ACLCOE    and
&       [F:DEP]PRATYP     = [F:DEPW]PRATYP      )

        # La méthode du plan n'a pas changé
        LERROR = 183 : LOK = G_NON
     Else
        # La méthode du plan a été modifiée
        LCHGD = G_OUI
     Endif

  #Fq-79215  Passage en mode résiduel si le bien a subi une clôture
  If ( LOK = G_OUI and LCHGD = G_OUI)
     Local Integer RETOUR
     If ( ACTMETNAM <>  "FASTRFC" )  or   ( G_MES=G_NON )
        # Pas de passage en résiduel pour un bien ayant subi une clôture et amorti en LP
        Call DETERM_MTCTIADAT( [M:FASM]MTCTIATYP(I_PLN-1),
&                              [M:FASM]FIYSTRDAT(I_PLN-1), [M:FASM]PERSTRDAT(I_PLN-1), [F:DEP]STRDPRDAT,
&                              [F:DEP]MTCTIADAT ) From TRTFASMTC
        #-Dès que la prise d'effet du changement est > à la date de début d'amortissement, on passe en mode résiduel
        If  [F:DEP]MTCTIADAT > [F:DEP]STRDPRDAT and [F:DEPW]DPM <> G_DPMSA  and
&         ( [F:DEP]DPM    <> [F:DEPW]DPM    or
&          [F:DEP]RSDVAL <> [F:DEPW]RSDVAL  or
&          [F:DEP]DPRDUR <> [F:DEPW]DPRDUR  or
&          [F:DEP]DPRRAT <> [F:DEPW]DPRRAT )
           Local Char    WDPM
           Local Integer GNRSD
           Local Char    L_RSDDPMTGR    # MODE RéSIDUEL
           Local Integer L_PRATYP       # Type de prorata
           WDPM = [F:DEP]DPM
           # Si le mode résiduel existe.
           Call GET_DPM_RSD("",WDPM, L_RSDDPMTGR, L_PRATYP ) From TRTFAS
           If ( ( L_RSDDPMTGR <>"" ) & (L_RSDDPMTGR <> WDPM ) ) and ( WDPM <> G_DPMSA )
              [F:DEP]DPM    = L_RSDDPMTGR
             If L_PRATYP > 0
               [F:DEP]PRATYP  = L_PRATYP
             Endif
           Endif
        Endif
     Endif
  Endif #Fq-79215

     # Contrôle - LERROR
     If ( LOK = G_OUI ) and  ( LCHGD = G_OUI )
        # Contrôle de la nouvelle méthode d'amortissement du plan

        [M:METH]       = [F:MAS1]
        [M:METH]GACACN = [M:FASC]GACACND
        [M:METH]IASACN = [M:FASC]IASACND
        [M:METH]       = [F:DEP]
        [M:METH]FLGBCO = G_OUI
        Local Integer I_DEP #FQ-73545
        I_DEP =  find( [F:DEP]DPRPLN,[M:FASM]DPRPLND )#FQ-73545
        If ( [M:FASM]TRTFLG(I_DEP-1) = G_OUI ) #FQ-73545
           # Infbox "Contrôle méthode - 3 (Massif / Unitaire par contrôler ou unitaire direct)"
           Call CONTROLE_METHODE () From TRTFAS
           If ( [M:METH]MSGERR)
              If (ACTTYPGES = GTAMMAS )
                 If [M:METH]MSGERR = 587 : [M:METH]MSGERR = 607 : Endif
                   [F:TMP1]MSGERR  = mess(179,GML_MSGFAS,1) : # "Au moins une erreur détectée sur un plan"
                   [F:TPF1]MSGERR  = '-->'- mess([M:METH]MSGERR,[M:METH]MSGFIL,1)
                 Else
                   LERROR = [M:METH]MSGERR
                 Endif
                 LOK = G_NON
                 LERROR = [M:METH]MSGERR
              Endif    #FQ-73545
           Endif
        Endif

  # Contrôle - LERROR
  If (LOK = G_OUI and [F:DEP]RSDVAL <> [F:DEPW]RSDVAL )
     # Contrôle de la valeur résiduelle
     # (Saisie complémentaire ne concerne pas MAS1_APPL_DIRT)
     Call CTRL_RSDVAL ([F:DEP]RSDVAL, [F:DEP]AASREF, [F:DEP]DPRPLN, [F:DEP]FIYENDDAT, [F:DEP]PERENDDAT, LERROR ) From TRTFAS
     If ( LERROR )   : LOK = G_NON : Endif
  Endif

  # Contrôle - LERROR
  If ( LOK = G_OUI and
&    [F:DEP]DPM <> [F:DEPW]DPM )
     # Si plan normé et changement du mode d'amortissement
     #FQ51203
     #    If ( [F:DEP]DPM = G_DPMLP and [F:DEPW]STRDPRDAT < [M:FASM]FIYSTRDAT(I_PLN-1) ) and
     #&      ( [F:DEP]DPRCUMFLG = G_OUI)
     # FQ82075 FQ105809
     If (( find([F:DEP]DPM, G_DPMLP,G_DPMSL,G_DPMTL) >0) and
&      [F:DEPW]STRDPRDAT < [M:FASM]FIYSTRDAT(I_PLN-1) ) and
&       ( [F:DEP]DPRCUMFLG = G_OUI and [F:DEP]DPRCUM <> 0)
        # Le nouveau mode ne peut pas être LP s'il existe un cumul d'amortissement pour le plan.
        LERROR = 606 : LOK = G_NON
     Endif
  Endif

   # Contrôle - LERROR
   If ( LOK = G_OUI and [F:DEP]STRDPRDAT <> [F:DEPW]STRDPRDAT and [F:DEP]DPRCUM <> 0 )
     # Si bien clôturé le changement de date de début d'amortissement est interdit
     #-Seulement si on est pas dans le cas où le bien est mis en service
      If !(([F:MAS1]GACACN = GVML_NIENCOU and [M:FASC]GACACND = GVML_NIENSER) |
&          ([F:MAS1]IASACN = GVML_NIENCOU and [M:FASC]IASACND = GVML_NIENSER))
      LERROR = 329 : LOK = G_NON
      Endif
   Endif

    # Contrôle - LERROR
    If ( LOK = G_OUI and ([F:DEP]DPRRAT2 <> [F:DEPW]DPRRAT2
&                    or   [F:DEP]DPRRAT  <> [F:DEPW]DPRRAT )
&                    and  [F:DEP]DPM = G_DPMIT and G_DPMIT <> "")
      # Si Mode IT et changement de taux antipato, contrôles sur le taux anticipato
      If ( [F:DEP]DPRRAT2 > 0 )
        Local Integer L_NBANNMAX
        Local Integer L_NUMANNUITE
        Case [F:MAS1]PURNAT
         When GVML_NANEUF
          L_NBANNMAX = 3
         When GVML_NAOCCAS
          L_NBANNMAX = 1
        Endcase

        L_NUMANNUITE = func GLOBB8.TX_ANTICIPATO_PERMIS([F:DEPW]CPY,
&                                                       [F:DEPW]CNX,
&                                                       [F:MAS1]PURNAT,
&                                                       [F:DEPW]STRDPRDAT,
&                                                          [F:DEPW]FIYSTRDAT,
&                                                    [F:DEPW]FIYENDDAT)
        # Test sur le numéro d'annuité
        If ( [F:DEP]DPRRAT2 > 0 & L_NUMANNUITE > L_NBANNMAX)
           # Amt Anticipato ne peut être appliqué au delà de trois ans
           # d'un an pour les biens d'occasion
           If  L_NBANNMAX=1
              LERROR = 489
           Elsif L_NBANNMAX=3
              LERROR = 490
           Endif
           LOK = G_NON
        Endif
        # Test de la valeur du taux anticipato par rapport au taux oridinario
        If ( [F:DEP]DPRRAT2 > [F:DEP]DPRRAT)
           LERROR = 483 : LOK = G_NON
        Endif
     Endif
  Endif

  # Gestion message - LOK - LERROR
  If ( LOK = G_NON and LERROR <> 0 )
     RMES = mess(83,GML_MSGFAS,1)- '-->' - mess(LERROR,GML_MSGFAS,1)
     [F:TMP1]MSGERR    = mess(179,GML_MSGFAS,1) : # "Au moins une erreur détectée sur un plan"
     [F:TPF1]MSGERR    = mess(LERROR,GML_MSGFAS,1)
  Endif

  #--- 1 ---
  Endif

  # ------------------
  If ( LOK = G_OUI and [M:FASM]TRTFLG(I_PLN-1) = G_OUI )
    # Plan à  recalculer
    [F:DEP]DEPSTA    = GVML_SCNOCAL
    Local Integer LCNX
    Call GET_CNX_FROM_PLAN ([M:FASC]CPY2, [M:FASM]DPRPLND(I_PLN-1), LCNX) From GLOBIENS
    Call DETERM_MTCTIADAT ( [M:FASM]MTCTIATYP(I_PLN-1),
&                           [M:FASM]FIYSTRDAT(I_PLN-1),
&                           [M:FASM]PERSTRDAT(I_PLN-1),
&                           [F:DEP]STRDPRDAT,
&                           [F:DEP]MTCTIADAT ) From TRTFASTRFC

   If [M:FASM] MTCTIATYP(I_PLN-1) = GVML_PEDBPE
      [F:DEP]PERREFCLC  = [M:FASM]PERSTRDAT(I_PLN-1)
      [F:DEP]PERREFCLCI = [M:FASM]PERSTRDAT(I_PLN-1)
      [F:DEP]PERREFCLCT = [M:FASM]PERSTRDAT(I_PLN-1)
   Else
      [F:DEP]PERREFCLC  = [M:FASM]FIYSTRDAT(I_PLN-1)
      [F:DEP]PERREFCLCI = [M:FASM]FIYSTRDAT(I_PLN-1)
      [F:DEP]PERREFCLCT = [M:FASM]FIYSTRDAT(I_PLN-1)
   Endif
   [F:DEP]MTCDPEDAT = [F:DEP]MTCTIADAT


    # Si tout est OK la table temporaire est mise à  jour telle que la méthode est actualisée
    # *****************
    [F:TPF1]  = [F:DEP]
    # *****************
  Else
    # En cas d'erreur la table temporaire est mise à  jour telle que le plan conserve son ancienne méthode
    # *****************
    [F:TPF1]  = [F:DEPW]
    # *****************
    If ( LCHGD = G_NON and ACTTYPGES = GTAMUNI)
      # Si on est en unitaire et qu'aucun paramètre saisi pour le plan
      # ou que les paramètres saisis ne modifie pas le plan => pas d'erreur
      RMES = ""
      If ( [F:TMP1]FLGERR <> G_OUI )
        [F:TMP1]MSGERR    = ""
      Endif
      [F:TPF1]MSGERR    = ""
    Else
      [F:TPF1]FLGERR = G_OUI
      [F:TMP1]FLGERR = G_OUI
    Endif
  Endif
  # ------------------
Return
#=====================================================================
# Unitaire : Permet de reporter les infos de TMP1 dans les masques de l'objet métier
#            Positionner ACTMODIF à  1 si des infos de l'objet métier sont modifiées
$TMP1_ALIM_MASK

If ( G_TRACE = G_OUI)   : Infbox "TMP1_ALIM_MASK" : Endif

Local Integer RFLGASS : RFLGASS = G_OUI #*Fq-56390

    ACTMODIF = 1

    [M:FAS1]OWNTYP    = [F:TMP1]OWNTYP
    If  [F:TMP1]ACGGRP <> [M:FAS1]ACGGRP  #Fq-58042
       #*Fq-56390
       #Fq-59277 Call DECLENCHER_ASSOCIATION( [M:FAS0]CPY,[F:TMP1]ACGGRP, "FAM","FAS", "OFAS", "HP", RFLGASS ) From TRTASSO

       Call DECLENCHER_ASSOCIATION( [M:FAS0]CPY,[F:TMP1]ACGGRP, "FAM","FAS", [M:FAS1]OWNTYP, "OFAS", "HP", RFLGASS ) From TRTASSO
       [M:FAS1]ACGGRP    = [F:TMP1]ACGGRP
    Endif
    [M:FAS1]ACGGRP    = [F:TMP1]ACGGRP
    If   (RFLGASS = G_OUI) and ([M:FAS1]ACCCOD <> [F:TMP1]ACCCOD)
       #Fq-59277 Call DECLENCHER_ASSOCIATION([M:FAS0]CPY, [F:TMP1]ACCCOD,  "COD", "FAS", [M:FAS1]OWNTYP, "OFAS", "HP", RFLGASS) From TRTASSO
                 Call DECLENCHER_ASSOCIATION([M:FAS0]CPY, [F:TMP1]ACCCOD,  "COD", "FAS", [M:FAS1]OWNTYP, "OFAS", "HP", RFLGASS) From TRTASSO
    Endif
    [M:FAS1]ACCCOD    = [F:TMP1]ACCCOD
    [M:FAS1]GAC       = [F:TMP1]GAC
    [M:FAS1]GACACN    = [F:TMP1]GACACN
    [M:FAS1]IASACC    = [F:TMP1]IASACC
    [M:FAS1]IASACN    = [F:TMP1]IASACN
    [M:FAS1]ITSDAT    = [F:TMP1]ITSDAT
    [M:FAS4]SALCLSDAT = [F:TMP1]SALCLSDAT #Fq-51185 FQ95754 de FAS1 à FAS4
    [M:FAS4]EXTSALAMT = [F:TMP1]EXTSALAMT #Fq-85984
    [M:FAS4]SALCLSDAT = [F:TMP1]SALCLSDAT #Fq-85984


    If (dim([M:FASC]ZACGGRPD) > 0 )   : [M:FAS1]ZACGGRP = [M:FASC]ZACGGRPD  : Endif
    If (dim([M:FASC]ZACCCODD) > 0 )   : [M:FAS1]ZACCCOD = [M:FASC]ZACCCODD  : Endif
    If (dim([M:FASC]ZGACD)    > 0 )   : [M:FAS1]ZGAC    = [M:FASC]ZGACD     : Endif
    If (dim([M:FASC]ZIASACCD) > 0 )   : [M:FAS1]ZIASACC = [M:FASC]ZIASACCD  : Endif

   [M:FAS0]FLGCLC                      = G_OUI
   If dim(G_CNX)>0                          #<*Fq-37602
     [M:FAS0]FLGCNXCLC(G_CNX)    = G_OUI    #<*Fq-37602
   Else                                     #<*Fq-37602
     [M:FAS0]FLGCNXCLC([F:TPF1]CNX-1)    = G_OUI
   Endif


Return

#=====================================================================
# Unitaire : Permet de reporter les infos de TPF1 dans les masques de l'objet métier
#            Positionner ACTMODIF à  1 si des infos de l'objet métier sont modifiées
$TPF1_ALIM_MASK
 Gosub TPF1_ALIM_MASK From TRTFASMTC2   #FQ57523
Return

#=====================================================================
# Unitaire : Permet de réafficher les masques de l'objet métier si des modifs
#            y ont été reportées.
REAF_ALIM_MASK
  Affzo [M:FAS0]
  Affzo [M:FAS1]
  Affzo [M:FAS3]
Return

#=====================================================================
# Massif : Sert à  ouvrir des tables utilisées dans MAS1_APPL_MAS1
$OUVR_APPL_DIRT

  Gosub OUVRE_TABLES From TRTFASMTC
  # Société courante : rupture société pour émission en-tête trace
  Local Char    TRC_CPY   : Raz TRC_CPY

  Global Integer    G_OWNTYP, G_GACACN, G_IASACN
  Global Decimal    G_PERDPRCUM2, G_PERENDDPE2, G_PERENDDPE
  Global Decimal    G_DERSLDEX, G_DERSLDPC, G_DERSLDPS
  Global Char       G_ACGGRP, G_ACCCOD(GLONCAC), G_GAC(GLONGAC), G_IASACC(GLONGAC)
  Global Date       G_SALCLSDAT   #Fq-51185
  Global Decimal    G_EXTSALAMT   #Fq-85984

  # Liste des biens non inventoriés
  GLSTTITRE(0) = mess(250,GML_MSGFAS,1)
  GLSTCOLNAM(0)= mess(251,GML_MSGFAS,1) +"                                   "

Return

#=====================================================================
# Massif : Application paramètres action aux tables de données : mise à  jour directe
$MAS1_APPL_DIRT

#------------------------------------------
# -----   GOK = 0 : Erreur provoquant l'arrêt de la procédure : DEP et MAS1 subissent un rollback
# -----   MAS1 contient les informations du bien
# -----   DEPW contient les anciennes valeurs du plan
# -----   DEP  contient les nouvelles valeurs du plan
# -----   La mise à  jour des données dans MAS1 et DEP est à  la charge du programme (rewrite).
# La table DEPREC située à  l'intérieur d'un trbegin subit également un rollback en cas d'erreur

If ACTSILENCE<>G_OUI
 #If ( G_TRACE = G_OUI)   : Infbox "MAS1_APPL_DIRT" : Endif
Endif

Local Integer LCDRET, LERRBCO, LOK, LCOUR, I_PLN, LERROR
Local Char    LCDINT(10)
Local Char    PARAM(250)
Local Char    LMESSAGE
Local Date    WDATREF
Local Date    WCPTDATINT

Local Integer I_ERREUR

  #-> A rupture société on émet un en-tête dans la trace
  If ( [F:MAS1]CPY<>TRC_CPY )
     Gosub ECR_ENT_BCO
     TRC_CPY=[F:MAS1]CPY
     Gosub SET_CPY_DAT
     # FQ109842
     # Call PARAM([F:MAS1]FCY,"BACAUTNUM",PARAM) From ADOVAL
     # GBACAUTNUM = val(PARAM)

     # A rupture société réédition entête pour liste annexe (biens non immatriculés)
     Raz GHEADLSTTRC
  Endif

  # Contrôle nouvelle imputation pour le bien
  Gosub CTRL_BIEN
  If ( LERRBCO )
     If ACTSILENCE<>G_OUI
        # FQ95579
        If GMESSAGE = ""
          Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]AASREF, 0, G_OUI, mess(LERRBCO,GML_MSGFAS,1)) From TRCPROCOM
        Else
          Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]AASREF, 0, G_OUI, GMESSAGE) From TRCPROCOM
        Endif

     Else
        G_MAJOK = G_NON
        GT_OBJ_REF(I_OBJ)    = [F:MAS1]AASREF
        GT_OBJ_DES(I_OBJ)    = [F:MAS1]AASDES1 : I_OBJ+=1
        # FQ95579
        If GMESSAGE = ""
          GT_LIS_ERR(I_ERREUR) = mess(LERRBCO,GML_MSGFAS,1)
        Else
          GT_LIS_ERR(I_ERREUR) = GMESSAGE
        Endif
        I_ERREUR+=1
     Endif
     Return
  Endif
  # Contrôle imputation du bien inchangée  # Fq-85984
  If ( (([F:MAS1]OWNTYP    = [M:FASC]OWNTYPD    and [M:FASC]FLGOWN = G_OUI) or ([M:FASC]FLGOWN = G_NON) ) and
&      (([F:MAS1]ACGGRP    = [M:FASC]ACGGRPD    and [M:FASC]FLGACG = G_OUI) or ([M:FASC]FLGACG = G_NON) ) and
&      (([F:MAS1]EXTSALAMT = [M:FASC]EXTSALAMT  and [M:FASC]FLGSAL = G_OUI) or ([M:FASC]FLGSAL = G_NON) ) and
&      (([F:MAS1]SALCLSDAT = [M:FASC]SALCLSDATD and [M:FASC]FLGSAL = G_OUI) or ([M:FASC]FLGSAL = G_NON) ) and
&      (([F:MAS1]ACCCOD    = [M:FASC]ACCCODD    and [M:FASC]FLGACC = G_OUI) or ([M:FASC]FLGACC = G_NON) )
&      )
    # "Imputation comptable inchangée"
    If ACTSILENCE<>G_OUI
     Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]AASREF, 0, G_OUI, mess(210,GML_MSGFAS,1)) From TRCPROCOM
    Else
     G_MAJOK = G_NON
     GT_OBJ_REF(I_OBJ)    = [F:MAS1]AASREF
     GT_OBJ_DES(I_OBJ)    = [F:MAS1]AASDES1 : I_OBJ+=1
     GT_LIS_ERR(I_ERREUR) = mess(210,GML_MSGFAS,1) : I_ERREUR+=1
    Endif
    Return
  Endif

  # Trace anciennes valeurs pour le bien
  Gosub ECR_BCO_OLD

  # Sauvegarde des valeurs d'origine du bien
  # nécessaires à  la génération de l'événement changement d'imputation
  G_OWNTYP    = [F:MAS1]OWNTYP
  G_ACGGRP    = [F:MAS1]ACGGRP
  G_ACCCOD    = [F:MAS1]ACCCOD
  G_SALCLSDAT = [F:MAS1]SALCLSDAT #Fq-51185
  G_EXTSALAMT = [F:MAS1]EXTSALAMT #Fq-85984
  G_GACACN    = [F:MAS1]GACACN
  G_GAC       = [F:MAS1]GAC
  G_IASACN    = [F:MAS1]IASACN
  G_IASACC    = [F:MAS1]IASACC

  # Alimentation de MAS1 avec les nouvelles valeurs pour le bien
  Gosub ALIM_ENR_MAS1

  # Trace nouvelles valeurs pour le bien
  Gosub ECR_BCO_NEW


  # FQ90392
  # Date de mise en service antérieure à la date d'achat ou de comptabilisation.
  If ( ( [F:MAS1]ITSDAT < [F:MAS1]PURDAT or [F:MAS1]ITSDAT < [F:MAS1]AASIPTDAT) )
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO,
&                  func GLOFUNC.SUBSTIT1(mess(914,GML_MSGFAS,1), num$([F:MAS1]ITSDAT)),-1,1) From TRACEABX3
  Endif


  # ===========   D  E  P  R  E  C  ===============
  # Alimentation de la table DEPREC [F:DEP]

  # Initialisation des indicateurs
  G_INCR = G_OUI : # Erreur à  n'incrémenter qu'une seule fois
  LOK = G_OUI : LERROR = 0

  # >>>>>>>>>>>>
  For nolign=1 To [M:FASM]NBLIG1

    # Lecture informations exercice suivant
    Gosub DEP_EXE_SUIV
    # Lecture DEPREC pour l'exercice et la période courante
    Read [DEP] DEP0=[F:MAS1]AASREF;[M:FASM]DPRPLND(nolign-1);
&                   [M:FASM]FIYENDDAT(nolign-1); [M:FASM]PERENDDAT(nolign-1)
    LCOUR = G_OUI
    If (fstat)
      # Lecture DEPREC pour l'exercice et la période correspondant au dernier mouvement
      Filter [DEP] Where AASREF= [F:MAS1]AASREF and DPRPLN= [M:FASM]DPRPLND(nolign-1)
      Read [DEP]DEP0 Last
      Filter [DEP]
      If (fstat)
        # Erreur technique
        RMES= mess(104,GML_MSGFAS,1)+" DEPREC"+mess(105,GML_MSGFAS,1)+" 02"+mess(106,GML_MSGFAS,1)-[F:MAS1]AASREF+"/"+num$([M:FASM]DPRPLND(nolign-1))
        GOK=0 : Return
      Endif
      LCOUR = G_NON
    Else
      LCOUR = G_OUI
    Endif

    # Toujours : Sauvegarde anciennes valeurs dans DEPW
    [F:DEPW] = [F:DEP]

    #--- 1 ---
    If ([M:FASM]TRTFLG(nolign-1) = G_OUI and [M:FASM]MTCFLG(nolign-1) = G_OUI )

      # Trace anciennes valeurs pour le plan du bien
      Gosub ECR_PLN_OLD

      # Contrôle
      If ( LOK = G_OUI and LCOUR = G_NON )
        # Le bien n'est pas amorti dans l'exercice courant/période courante
        LERROR = 180 : LOK = G_NON
      Endif

      # Application de la valeur des paramètres saisis
      If ( LOK = G_OUI )
        # Nouvelles valeurs dans DEP
        I_PLN = nolign
        Gosub ALIM_ENR_PLN From TRTFASMTC : # ( anciennes valeurs dans DEPW )

        # Si la date de début d'amortissement a été saisie en paramètre
        # et qu'il ne s'agit pas d'une mise en service
        # la date de début d'amortissement ne doit pas être modifiée
        #-[F:MAS1]GACACN contient la nouvelle nature : il faut prendre l'ancienne pour faire le test
        If ( ( G_GACACN = GVML_NIENSER or [M:FASC]GACACND <> GVML_NIENSER )
&         and  [F:DEP]STRDPRDAT  <> [F:DEPW]STRDPRDAT )
          [F:DEP]STRDPRDAT = [F:DEPW]STRDPRDAT
        Endif
      Endif

      # Contrôle
      # FQ82178 ajout ENDDPRDAT
      If  ( LOK = G_OUI and
&           [F:DEP]DPM       = [F:DEPW]DPM       and
&           [F:DEP]STRDPRDAT = [F:DEPW]STRDPRDAT and
&           [F:DEP]ENDDPRDAT = [F:DEPW]ENDDPRDAT and
&           [F:DEP]DPRDUR    = [F:DEPW]DPRDUR    and
&           [F:DEP]DPRRAT    = [F:DEPW]DPRRAT    and
&           [F:DEP]DPRRAT2   = [F:DEPW]DPRRAT2   and
&           [F:DEP]RSDVAL    = [F:DEPW]RSDVAL    and
&           [F:DEP]CRBVEHCOD = [F:DEPW]CRBVEHCOD and
&           [F:DEP]ALWCOD    = [F:DEPW]ALWCOD    and
&           [F:DEP]ACLCOE    = [F:DEPW]ACLCOE    and
&           [F:DEP]PRATYP    = [F:DEPW]PRATYP    )
        # La méthode du plan n'a pas changé
        LERROR = 183 : LOK = G_NON
      Endif

      # Contrôle - LERROR
      #Fq-73545 If ( LOK = G_OUI )
      Local Integer I_DEP
      I_DEP =  find( [F:DEP]DPRPLN,[M:FASM]DPRPLND )
      If ( LOK = G_OUI )  and ( [M:FASM]TRTFLG(I_DEP-1) = G_OUI )
        [M:METH] = [F:MAS1]
        [M:METH] = [F:DEP]
        [M:METH]FLGBCO = G_OUI
        #<<<<< Fq-87928--------------------------------------
        If GFRADGI= G_OUI
           If [F:DEP]DPRPLN=G301SUB
              [M:MET2] DPRPLN = G301FIS
              I_FIS =  find( G301FIS,[M:FASM]DPRPLND )
              If I_FIS > 0
                 If [M:FASM]DPRDURD(I_FIS-1) <> 0
                    [M:MET2] DPRDUR = [M:FASM]DPRDURD(I_FIS-1)
                 Else
                   If !clalev([F:DEPF]) : Local File DEPREC    [DEPF] : Endif
                   Read[DEPF]DEP0 = [F:DEP]AASREF;G301FIS;[M:FASM]FIYENDDAT(I_FIS-1);[M:FASM]PERENDDAT(I_FIS-1)
                   If fstat=0
                      [M:MET2]DPRDUR = [F:DEPF]DPRDUR
                   Endif
                 Endif
              Endif
           Endif
           If [F:DEP]DPRPLN=G301FIS
              [M:MET2]DPRPLN = G301SUB
              I_SUB=  find( G301SUB,[M:FASM]DPRPLND )
              If I_SUB > 0
                 If [M:FASM]DPRDURD(I_SUB-1) <> 0
                    [M:MET2]DPRDUR = [M:FASM]DPRDURD(I_SUB-1)
                 Else
                   If !clalev([F:DEPV]) : Local File DEPREC    [DEPV] : Endif
                   Read[DEPV]DEP0 = [F:DEP]AASREF;G301SUB;[M:FASM]FIYENDDAT(I_SUB-1);[M:FASM]PERENDDAT(I_SUB-1)
                   If fstat=0
                      [M:MET2]DPRDUR = [F:DEPV]DPRDUR
                   Endif
                 Endif
              Endif
           Endif
        Endif
       #Fq-87928>>>>>--------------------------------------
        # FQ69691B
        [M:METH]MSGERR = 0
        [M:METH]GACACN = [M:FASC]GACACND
        [M:METH]IASACN = [M:FASC]IASACND
        #Infbox "Contrôle méthode - 4 ( Massif direct )"
        Call CONTROLE_METHODE () From TRTFAS
        If ( [M:METH]MSGERR)
           LOK = G_NON
           #FQ69691B
           LERROR = [M:METH]MSGERR
        Endif
      Endif

      # Contrôle - LERROR
       If ( LOK = G_OUI and   [F:DEP]DPM <> [F:DEPW]DPM )
         # Si plan normé et changement du mode d'amortissement
         # FQ51203
         #    If ( [F:DEP]DPM = G_DPMLP and [F:DEPW]STRDPRDAT < [M:FASM]FIYSTRDAT(nolign-1) ) and
         #&      ( [F:DEP]DPRCUMFLG = G_OUI)
         # FQ82075 FQ105809
         If (( find([F:DEP]DPM, G_DPMLP,G_DPMSL,G_DPMTL)>0) and
&          [F:DEPW]STRDPRDAT < [M:FASM]FIYSTRDAT(nolign-1) ) and
&           ( [F:DEP]DPRCUMFLG = G_OUI and [F:DEP]DPRCUM <> 0)
           # Le nouveau mode ne peut pas être LP s'il existe un cumul d'amortissement pour le plan.
          LERROR = 606 : LOK = G_NON
        Endif
      Endif

      # Contrôle - LERROR
      If ( LOK = G_OUI and [F:DEP]STRDPRDAT <> [F:DEPW]STRDPRDAT and [F:DEP]DPRCUM <> 0  )
        # Si bien clôturé le changement de date de début d'amortissement est interdit
        #-Seulement si on est pas dans le cas où le bien est mis en service
        If !(([F:MAS1]GACACN = GVML_NIENCOU and [M:FASC]GACACND = GVML_NIENSER) |
&           ([F:MAS1]IASACN = GVML_NIENCOU and [M:FASC]IASACND = GVML_NIENSER))
         LERROR = 329 : LOK = G_NON
        Endif
      Endif

      # Contrôle - LERROR
      If ( LOK = G_OUI and ([F:DEP]DPRRAT2 <> [F:DEPW]DPRRAT2
&                      or   [F:DEP]DPRRAT  <> [F:DEPW]DPRRAT)
&                      and  [F:DEP]DPM = G_DPMIT and G_DPMIT <> "")
        # Si Mode IT et changement de taux antipato, contrôles sur le taux anticipato
        If ( [F:DEP]DPRRAT2 > 0 )
          Local Integer L_NBANNMAX
          Case [F:MAS1]PURNAT
            When GVML_NANEUF
             L_NBANNMAX = 3
            When GVML_NAOCCAS
             L_NBANNMAX = 1
           Endcase
           # Test sur le numéro d'annuité
           If  [F:DEP]DPRRAT2 > 0 & func GLOBB8.TX_ANTICIPATO_PERMIS( [F:DEPW]CPY,
&                                                                     [F:DEPW]CNX,
&                                                                     [F:MAS1]PURNAT,
&                                                                     [F:DEPW]STRDPRDAT,
&                                                                     [F:DEPW]FIYSTRDAT,
&                                                                     [F:DEPW]FIYENDDAT )
             # Amt Anticipato ne peut être appliqué au delà de trois ans pour les biens neufs, d'un an pour les biens d'occasion
             If  L_NBANNMAX=1
              LERROR = 489
             Elsif L_NBANNMAX=3
              LERROR = 490
             Endif
             LOK = G_NON
           Endif
           # Test de la valeur du taux anticipato par rapport au taux oridinario
           If ( [F:DEP]DPRRAT2 > [F:DEP]DPRRAT)
             LERROR = 483 : LOK = G_NON
           Endif
         Endif
       Endif

      # Contrôle - LERROR
      If ( LOK = G_NON and LERROR <> 0 )
        If ACTSILENCE<>G_OUI
         Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]AASREF, [F:DEP]DPRPLN, G_INCR, mess(LERROR,GML_MSGFAS,1))
&        From TRCPROCOM
         If (G_INCR = G_OUI)   : G_INCR = G_NON : Endif
        Else
         G_MAJOK = G_NON
         If ( ( I_OBJ>0 & GT_OBJ_REF(I_OBJ-1)<> [F:MAS1]AASREF ) | (I_OBJ=0) )
          GT_OBJ_REF(I_OBJ)    = [F:MAS1]AASREF
          GT_OBJ_DES(I_OBJ)    = [F:MAS1]AASDES1 : I_OBJ+=1
         Endif
         GT_LIS_ERR(I_ERREUR) = mess(LERROR,GML_MSGFAS,1) : I_ERREUR+=1
        Endif
        #FQ69691B
        Break
      Endif

      # ------------------
      If (LOK = G_OUI)
        If ( FLGSIM = G_NON )
          # Date de changement de méthode
          Local Integer LCNX
          Call GET_CNX_FROM_PLAN ([M:FASC]CPY2, [M:FASM]DPRPLND(I_PLN-1), LCNX) From GLOBIENS

          Call DETERM_MTCTIADAT( [M:FASM]MTCTIATYP(nolign-1),
&                                [M:FASM]FIYSTRDAT(nolign-1), [M:FASM]PERSTRDAT(nolign-1), [F:DEP]STRDPRDAT,
&                                [F:DEP]MTCTIADAT ) From TRTFASTRFC
          # Si le mode actuel est "LP - Linéaire pur"
          # FQ82075 FQ105809
          If (( find([F:DEPW]DPM, G_DPMLP,G_DPMSL,G_DPMTL)>0) and
&            not find([F:DEP]DPM, G_DPMRE,G_DPMUO,G_DPMSA))
             # - déb amort < deb exercice et prise d'effet <> déb amort
             # ou
             # - déb amort > deb exercice et < déb per et prise d'effet =  déb per
             #-------------------------------------------
             If ( [F:DEP]STRDPRDAT < [M:FASM]FIYSTRDAT(nolign-1) and [M:FASM]MTCTIATYP(nolign-1)<> GVML_PEDBAM ) or
&               ( [F:DEP]STRDPRDAT > [M:FASM]FIYSTRDAT(nolign-1) and [F:DEP]STRDPRDAT < [M:FASM]PERSTRDAT(nolign-1) and
&                                                                   [M:FASM]MTCTIATYP(nolign-1)= GVML_PEDBPE )
                Local Char    WDPM
                Local Integer GNRSD
                Local Char    L_RSDDPMTGR    # MODE RéSIDUEL
                Local Integer L_PRATYP       # Type de prorata
                WDPM = [F:DEPW]DPM
                # Si le mode résiduel existe.
                Call GET_DPM_RSD("",WDPM, L_RSDDPMTGR, L_PRATYP ) From TRTFAS
                If ( ( L_RSDDPMTGR <>"" ) | (L_RSDDPMTGR <> WDPM ) ) and ( WDPM <> "SA" )
                   [F:DEP]DPM    = L_RSDDPMTGR
                   #*FQ-58289 [F:DEP]PRATYP  = LPRATYP
                   # FQ77265
                   If L_PRATYP > 0
                     [F:DEP]PRATYP  = L_PRATYP
                   Endif
                Endif
             Endif
          Endif
          #-------------------------------------------
          # Génération d'un évènement changement de méthode ( anciennes & nouvelles valeur)
          LCDINT= "FASMTC"+num$([F:DEP]DPRPLN)
          GFAS = "[F:MAS1]"
          GDPO = "[F:DEPW]"
          GDPN = "[F:DEP]"
          # Génération des évènements de changement de méthode
          If [F:DEP]MTCTIADAT=[0/0/0]
             WDATREF        =  [M:FASM]PERSTRDAT(nolign-1)
          Else
             WDATREF        =  [F:DEP]MTCTIADAT
          Endif
          WCPTDATINT     =  max([F:DEP]STRDPRDAT,GCPYSTRPER(LCNX))
          [F:DEP]MTCDPEDAT  =   WDATREF # ajouté car testé dans la réévaluation (MWA:27-02-2008)
          # Si evts de dépréciation non encore comptabilisés  ==>  globales alimentées
          # Sinon, si evts de dépréciation déjà comptabilisés ou pas d'évt de dépréciation ==>  globales à zéro
          Call GENER_EVE
&            (GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,WDATREF,WCPTDATINT, LCDRET)
&         From GENEVE
          If (LCDRET > 20 )
            # Erreur technique
            RMES= mess(107,GML_MSGFAS,1)-LCDINT+"-"+num$(LCDRET)
            GOK = 0
            #FQ69691B
            LOK = G_NON
            Break
#            Return
          Endif
        Endif

        # Trace nouvelles valeurs pour le bien
        Gosub ECR_PLN_NEW

        # -----------------------
        If ( FLGSIM = G_NON )
           # Plan à  recalculer
           #47475[F:DEP]PERREFCLC  = [F:DEP]MTCTIADAT
           #47475[F:DEP]PERREFCLCI = [F:DEP]MTCTIADAT
           #47475[F:DEP]PERREFCLCT = [F:DEP]MTCTIADAT
           If [M:FASM] MTCTIATYP(nolign-1) = GVML_PEDBPE   #47475
              [F:DEP]PERREFCLC  = [M:FASM]PERSTRDAT(nolign-1)
              [F:DEP]PERREFCLCI = [M:FASM]PERSTRDAT(nolign-1)
              [F:DEP]PERREFCLCT = [M:FASM]PERSTRDAT(nolign-1)
           Else
              [F:DEP]PERREFCLC  = [M:FASM]FIYSTRDAT(nolign-1)
              [F:DEP]PERREFCLCI = [M:FASM]FIYSTRDAT(nolign-1)
              [F:DEP]PERREFCLCT = [M:FASM]FIYSTRDAT(nolign-1)
           Endif
           # FQ66894 : ajout de la mise à jour de FLGCLC et FLGCNXCLC
           [F:MAS1]FLGCLC                  = G_OUI
           [F:MAS1]FLGCNXCLC([F:DEP]CNX-1) = G_OUI
           [F:DEP]DEPSTA                   = GVML_SCNOCAL
           # Traitement spécifique si tout est OK
           If   ( [F:DEP]DPRCUM <> 0  and ACTTYPGES = GTAMUNI and
&               ( [F:DEP]DPM     <> [F:DEPW]DPM    or  [F:DEP]DPRDUR <> [F:DEPW]DPRDUR  or
&                 [F:DEP]DPRRAT  <> [F:DEPW]DPRRAT or  [F:DEP]DPRRAT2<> [F:DEPW]DPRRAT2 or
&                 [F:DEP]RSDVAL  <> [F:DEPW]RSDVAL or  [F:DEP]ALWCOD <> [F:DEPW]ALWCOD  or
&                 [F:DEP]ACLCOE  <> [F:DEPW]ACLCOE or  [F:DEP]PRATYP <> [F:DEPW]PRATYP ) )
          Endif
          #---------------
          Rewrite [DEP]
          #---------------
          If fstat
            # Erreur technique
            RMES= mess(104,GML_MSGFAS,1)+" DEPREC"+mess(105,GML_MSGFAS,1)+" 02"+mess(106,GML_MSGFAS,1)-[F:DEP]AASREF+"/"+num$([F:DEP]DPRPLN(nolign-1))
            GOK=0
            #FQ69691B
            LOK = G_NON
            Break
#            Return
          Endif
        Endif
        # -----------------------
      Endif
      # ------------------

    Endif
    #--- 1 ---
    # Génération événement de changement d'imputation comptable
    Gosub CALCUL_DEROG
    Local Integer LCNX
    Call GET_CNX_FROM_PLAN ([F:DEP]CPY, [F:DEP]DPRPLN, LCNX) From GLOBIENS
    G_PERENDDPE = 0
    #  En V5  La notion de calcul réel ou fictif n'existe plus
    If [F:DEP]DEPSTA=GVML_SCCAL
       G_PERENDDPE = [F:DEP]PERENDDPE
     # Suppression de la table EVEFAS 31/10/2014
     #    Else
     #       # On va chercher sur les FASDOT de la période.
     #       If !clalev([F:EFS]) : Local File EVEFAS [EFS] : Endif
     #       Local Decimal L_PERENDDPE
     #       Filter [EFS] Where (REF=[F:DEP]AASREF & PLN=[F:DEP]DPRPLN & EVTDAT>=[F:DEP]PERSTRDAT & EVTDAT<=[F:DEP]PERENDDAT)
     #          For [EFS]
     #             L_PERENDDPE+=[F:EFS]FLDFILN(8)
     #          Next
     #          G_PERENDDPE=L_PERENDDPE
     #       Filter [EFS]
     #       Close Local File [EFS]
    Endif
    Gosub BCO_EVT

    Call MAJFLGCNXFLX("[F:MAS1]", "", [F:DEP]CNX, num$(GVML_FLXNOTG)) From TRTFAS : # FQ66894
  Next nolign
  # <<<<<<<<<<<

  #FQ69691B
  #FQ87928 uniquement en intégration de mouvements
  If dim(GFXDNBERR) > 0
    If LOK <> G_OUI
      GOK=0
      Return
    Endif
  Endif

  # Mise à jour des imputations comptables sur les dépenses FQ60753
  Gosub MAJ_ACC_LOF

  If ( FLGSIM = G_NON ) # ( les indicateurs du bien sont mis "à recalculer" )
    # FQ66894 : remonté au niveau de la mise à jour de DEPSTA
    #[F:MAS1]FLGCLC = G_OUI
    #[F:MAS1]FLGCNXCLC([F:DEP]CNX-1) = G_OUI
    #---------------
    Rewrite [MAS1]
    #---------------
    If fstat
      # Erreur technique
      RMES= mess(104,GML_MSGFAS,1)+" FXDASSETS"+mess(105,GML_MSGFAS,1)+" 01"+mess(106,GML_MSGFAS,1)-[F:MAS1]AASREF
      GOK=0 : Return
    Endif
  Endif

Return

#=====================================================================
# Massif : Fermeture
$CLOS_APPL_DIRT

  ################################################
  # Fq-54343   Point d'entrée                    #
  # Après maj des tables FXDASSETS et DEPREC     #
  ################################################
  GOK=1
  GPOINT="TRFCLODIRT" : Gosub ENTREE From EXEFNC
  If GOK<1 : Return : Endif
  #### Point d'entrée - Fin ######################

  If dim(G_DERSLDEX)    >0   : Kill G_DERSLDEX      : Endif
  If dim(G_DERSLDPC)    >0   : Kill G_DERSLDPC      : Endif
  If dim(G_DERSLDPS)    >0   : Kill G_DERSLDPS      : Endif
  If dim(G_OWNTYP)      >0   : Kill G_OWNTYP        : Endif
  If dim(G_GACACN)      >0   : Kill G_GACACN        : Endif
  If dim(G_IASACN)      >0   : Kill G_IASACN        : Endif
  If dim(G_ACGGRP)      >0   : Kill G_ACGGRP        : Endif
  If dim(G_ACCCOD)      >0   : Kill G_ACCCOD        : Endif
  If dim(G_SALCLSDAT)   >0   : Kill G_SALCLSDAT     : Endif  #Fq-51185
  If dim(G_EXTSALAMT)   >0   : Kill G_EXTSALAMT     : Endif  #Fq-85984
  If dim(G_GAC)         >0   : Kill G_GAC           : Endif
  If dim(G_IASACC)      >0   : Kill G_IASACC        : Endif
  If dim(G_PERDPRCUM2)  >0   : Kill G_PERDPRCUM2    : Endif
  If dim(G_PERENDDPE2)  >0   : Kill G_PERENDDPE2    : Endif
  If dim(G_PERENDDPE)   >0   : Kill G_PERENDDPE     : Endif
  If dim(G_MES)         >0   : Kill G_MES           : Endif

Return


#=====================================================================
# Unitaire / massif : Ouverture de tables annexes avant report du contenu des tables temporaires dans les tables de données
$OUVR_ALIM_TABLE

  Gosub OUVRE_TABLES From TRTFASMTC
  # Société courante : rupture société pour émission en-tête trace
  Local Char TRC_CPY   : Raz TRC_CPY

  Global Integer    G_OWNTYP, G_GACACN, G_IASACN
  Global Decimal    G_PERDPRCUM2, G_PERENDDPE2, G_PERENDDPE
  Global Decimal    G_DERSLDEX, G_DERSLDPC, G_DERSLDPS
  Global Char       G_ACGGRP, G_ACCCOD(GLONCAC), G_GAC(GLONGAC), G_IASACC(GLONGAC)
  Global Date       G_SALCLSDAT   #Fq-51185
  Global Decimal    G_EXTSALAMT   #Fq-85984

  GLSTTITRE(0) = mess(250,GML_MSGFAS,1)
  GLSTCOLNAM(0)= mess(251,GML_MSGFAS,1) +"                                   "

Return
#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire principale dans la table de données principale
$TMP1_ALIM_TABLE
Local Integer LCDRET, LOK
Local Char    LCDINT(10)

#If ( G_TRACE = G_OUI)   : Infbox "TMP1_ALIM_TABLE" : Endif
# Pour chaque bien de la table TMPMASFAS,
# transfert des infos de TMPMASFAS [TMP1] dans la table FXDASSETS [MAS1]
# Pas de rewrite : la mise à  jour est prise en charge par le traitement standard
  G_INCR = G_OUI

  #-> A rupture société on émet un en-tête dans la trace
  If ( [F:TMP1]CPY <> TRC_CPY and ACTTYPGES = GTAMMAS )
    Gosub ECR_ENT_BCO
    TRC_CPY=[F:TMP1]CPY
    # A rupture société réédition entête pour liste annexe (biens non immatriculés)
    Raz GHEADLSTTRC
    Gosub SET_CPY_DAT
  Endif

  # Impression d'un message d'erreur
  If ([F:TMP1]MSGERR <> "" and ACTTYPGES = GTAMMAS )
    If ACTSILENCE<>G_OUI
     Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]AASREF, 0, G_INCR, [F:TMP1]MSGERR) From TRCPROCOM
     If (G_INCR = G_OUI)   : G_INCR = G_NON : Endif
    Else
    Endif
  Endif
  #==============
  If ( [F:TMP1]FLGERR = G_NON)
    Gosub ECR_BCO_OLD   : # Massif uniquement "AVANT"

    # Sauvegarde des valeurs d'origine du bien
    # nécessaires à  la génération de l'événement changement d'imputation
    G_OWNTYP    = [F:MAS1]OWNTYP
    G_ACGGRP    = [F:MAS1]ACGGRP
    G_ACCCOD    = [F:MAS1]ACCCOD
    G_SALCLSDAT = [F:MAS1]SALCLSDAT #Fq-51185
    G_EXTSALAMT = [F:MAS1]EXTSALAMT #Fq-85984
    G_GACACN    = [F:MAS1]GACACN
    G_GAC       = [F:MAS1]GAC
    G_IASACN    = [F:MAS1]IASACN
    G_IASACC    = [F:MAS1]IASACC

    Gosub ALIM_ENR_MAS1

    Gosub ECR_BCO_NEW   : # Massif uniquement "APRES"


    # FQ90392
    # Date de mise en service antérieure à la date d'achat ou de comptabilisation.
    If ( ACTTYPGES = GTAMMAS  and ( [F:MAS1]ITSDAT < [F:MAS1]PURDAT or [F:MAS1]ITSDAT < [F:MAS1]AASIPTDAT) )
      Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO,
&                    func GLOFUNC.SUBSTIT1(mess(914,GML_MSGFAS,1), num$([F:MAS1]ITSDAT)),-1,1) From TRACEABX3
    Endif

  Endif
  #==============

  If ( ACTTYPGES = GTAMMAS )

     # FQ103068
   [F:MAS1]FLGCLC            = G_OUI

    # >>>>>>>>>>>>
    For nolign=1 To [M:FASM]NBLIG1
      ###############  DEP_EXE_SUIV_TMP  ###############
      # Lecture informations exercice suivant
      Local Integer LCNX
      # Lecture PERDEPREC pour l'exercice et la période suivante
      G_PERDPRCUM2 = 0
      G_PERENDDPE2 = 0
      Read [DEP] DEP0=
&          [F:MAS1]AASREF;[M:FASM]DPRPLND(nolign-1);[M:FASM]FIYENDDAT2(nolign-1);[M:FASM]PERENDDAT2(nolign-1)
      If not (fstat)
        G_PERDPRCUM2 = [F:DEP]PERCLOCUM
        Call GET_CNX_FROM_PLAN ([F:DEP]CPY, [F:DEP]DPRPLN, LCNX) From GLOBIENS
        ##*V5   En V5  La notion de calcul réel ou fictif n'existe plus
        #*V5 If ( func GLOBIENS.IS_CALCULE_EN_REEL([F:DEP]CPY, LCNX, GVML_TESUIV) )
          G_PERENDDPE2 = [F:DEP]PERENDDPE
        #*V5 Endif
      Endif
      ###############  DEP_EXE_SUIV_TMP  ###############
      # Génération d'un évènement changement d'imputation comptable en unitaire ou en massif
      Read [DEPW]DEP0=
&          [F:MAS1]AASREF;[M:FASM]DPRPLND(nolign-1);[M:FASM]FIYENDDAT(nolign-1);[M:FASM]PERENDDAT(nolign-1)
      # calcul du solde de dérogatoire pour la génération de l'événement changement d'imputation comptable
      ###############  CALCUL_DEROG_TMP ###############
      # Changement d'imputation PCG ?
      If ( G_GAC     = [F:MAS1]GAC )
        G_TRF_PCG = G_NON
      Else
        G_TRF_PCG = G_OUI
      Endif
      # Changement d'imputation IAS ?
      If ( G_IASACC  = [F:MAS1]IASACC )
        G_TRF_IAS = G_NON
      Else
        G_TRF_IAS = G_OUI
      Endif
      #Fq-51185  Changement date classement bien détenu pour vente ?
      If ( G_SALCLSDAT = [F:MAS1]SALCLSDAT and G_EXTSALAMT = [F:MAS1]EXTSALAMT ) #Fq-85984
        # G_TRF_IAS = G_NON
        G_CFS = G_NON  : # FQ95754_2
      Else
        # G_TRF_IAS = G_OUI
        G_CFS = G_OUI  : # FQ95754_2
      Endif

      # Solde dérogatoire
      G_DERSLDEX = 0 :  G_DERSLDPC = 0 : G_DERSLDPS = 0
      # Calcul du solde dérogatoire au début de l'exercice courant
      G_DERSLDEX  = func TRTFAS.SOLDE_DEROG (
&                   [F:MAS1]AASREF, [M:FASM]FIYENDDAT(0), [M:FASM]PERENDDAT(0), 0)
      # Calcul du solde dérogatoire au début de période courante de l'exercice courant
      G_DERSLDPC  = func TRTFAS.SOLDE_DEROG (
&                   [F:MAS1]AASREF, [M:FASM]FIYENDDAT(0), [M:FASM]PERENDDAT(0), G_OUI)

      # Calcul du solde dérogatoire au début de période courante de l'exercice suivant
      G_DERSLDPS  = func TRTFAS.SOLDE_DEROG (
&                  [F:MAS1]AASREF, [M:FASM]FIYENDDAT2(0), [M:FASM]PERENDDAT2(0), G_OUI)
      ###############  CALCUL_DEROG_TMP ###############
      Call GET_CNX_FROM_PLAN ([F:DEPW]CPY, [F:DEPW]DPRPLN, LCNX) From GLOBIENS
      G_PERENDDPE = 0
      ##*V5   En V5  La notion de calcul réel ou fictif n'existe plus
      ##*V5 If ( func GLOBIENS.IS_CALCULE_EN_REEL([F:DEPW]CPY, LCNX, GVML_TECOURAN) )
      If [F:DEPW]DEPSTA=GVML_SCCAL
         G_PERENDDPE = [F:DEPW]PERENDDPE
         # Suppression de la table EVEFAS 31/10/2014
         #      Else
         #         # On va chercher sur les FASDOT de la période.
         #         If !clalev([F:EFS]) : Local File EVEFAS [EFS] : Endif
         #         Local Decimal L_PERENDDPE
         #         Filter [EFS] Where (REF=[F:DEPW]AASREF & PLN=[F:DEPW]DPRPLN & EVTDAT>=[F:DEPW]PERSTRDAT & EVTDAT<=[F:DEPW]PERENDDAT)
         #         For [EFS]
         #            L_PERENDDPE+=[F:EFS]FLDFILN(8)
         #         Next
         #         G_PERENDDPE=L_PERENDDPE
         #         Filter [EFS]
         #         Close Local File [EFS]
      Endif
      #*V5 Endif
      Gosub BCO_EVT

      Call MAJFLGCNXFLX("[F:MAS1]", "", LCNX, num$(GVML_FLXNOTG)) From TRTFAS : # FQ66894

      # FQ103068
      [F:MAS1]FLGCNXCLC(LCNX-1) = G_OUI
    Next nolign
    # <<<<<<<<<
  Endif

  # Mise à jour des imputations comptables sur les dépenses FQ60753
  If ([F:TMP1]FLGERR = G_NON)
    Gosub MAJ_ACC_LOF
  Endif
Return

#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire annexe dans la table de données annexe
$TPF1_ALIM_TABLE

  #If ( G_TRACE = G_OUI)   : Infbox "TPF1_ALIM_TABLE" : Endif
  Local Integer I_PLN
  I_PLN=find([F:TPF1]DPRPLN,[M:FASM]DPRPLND) : # Rang du plan dans tableau paramètres

# Transfert des zones [TPF1] dans l'enregistrement de la table choisie à  mettre à  jour
# rewrite de la table choisie. Utiliser GOK pour interrompre le traitement.
# Pour chaque bien de la table TMPPLNFAS,
# transfert des infos de TMPPLNFAS [TPF1] dans la table DEPREC [DEP]
# Rewrite à  effectuer : la mise à  jour n'est pas prise en charge par le traitement standard

Local Integer LCDRET, LOK
Local Char    LCDINT(10)

Local Date    WDATREF
Local Date    WCPTDATINT

  # On passe dans nnnn_ALIM_TABLE en massif et en unitaire
  # Ceci afin de rendre possible la génération des événements en unitaire
  # En unitaire, le reste des opérations est pris en charge par la transaction appelante (nnnn_ALIM_MASK)
  # (pas de trace pas de mise à  jour du bien courant)
  # La fonction IS_OBJ_MAIN oui/non permet de savoir s'il s'agit du bien traité dans l'appelant
  # dont les plans sont mis à  jour par l'appelant à  différencier des autres biens (ex: composant)
  # qui eux sont à  mettre à  jour.

  # Pas de traitement sur les plans si le bien est en erreur
  If ( [F:TMP1]FLGERR = G_OUI)   : Return : Endif

  # Lecture informations exercice suivant
  Gosub DEP_EXE_SUIV_TMP

  Read [DEP]DEP0=[TPF1]OBJREF;[TPF1]DPRPLN;[TPF1]FIYENDDAT;[TPF1]PERENDDAT
  #=== 1 =======
  If (fstat)
    If (ACTTYPGES = GTAMMAS)   : # Massif uniquement
      RMES=mess(104,GML_MSGFAS,1)-"DEPREC"-mess(105,GML_MSGFAS,1)-"03"-mess(106,GML_MSGFAS,1)-num$(NUMACT)+"/"+[F:TPF1]OBJREF+"/"+num$([F:TPF1]DPRPLN)
    Endif
    GOK=0 : Return
  #=== 1 =======
  Else
    # Sauvegarde ancienne valeur
    [F:DEPW] = [F:DEP]
    Gosub ECR_PLN_OLD # Massif uniquement
    # Impression d'un message d'erreur
    If ([F:TPF1]MSGERR <> "" and ACTTYPGES = GTAMMAS )
      If ACTSILENCE<>G_OUI
       Call ECR_TRACE_ERREUR([F:MAS1]CPY, [F:MAS1]AASREF, [F:TPF1]DPRPLN, G_INCR, [F:TPF1]MSGERR) From TRCPROCOM
       If (G_INCR = G_OUI)   : G_INCR = G_NON : Endif
      Else
      Endif
    Endif

    If ( ACTTYPGES = GTAMUNI )
      # calcul du solde de dérogatoire pour la génération de l'événement changement d'imputation comptable
      Gosub CALCUL_DEROG_TMP
      Local Integer LCNX
      Call GET_CNX_FROM_PLAN ([F:DEP]CPY, [F:DEP]DPRPLN, LCNX) From GLOBIENS
      G_PERENDDPE = 0
      #  En V5  La notion de calcul réel ou fictif n'existe plus
      #*V5 If ( func GLOBIENS.IS_CALCULE_EN_REEL([F:DEP]CPY, LCNX, GVML_TECOURAN) )
       If [F:DEP]DEPSTA=GVML_SCCAL
         G_PERENDDPE = [F:DEP]PERENDDPE
       # Suppression de la table EVEFAS 31/10/2014
       #       Else
       #        # On va chercher sur les FASDOT de la période.
       #        If !clalev([F:EFS]) : Local File EVEFAS [EFS] : Endif
       #        Local Decimal L_PERENDDPE
       #        Filter [EFS] Where (REF=[F:DEP]AASREF & PLN=[F:DEP]DPRPLN & EVTDAT>=[F:DEP]PERSTRDAT & EVTDAT<=[F:DEP]PERENDDAT)
       #        For [EFS]
       #         L_PERENDDPE+=[F:EFS]FLDFILN(8)
       #        Next
       #        G_PERENDDPE=L_PERENDDPE
       #        Filter [EFS]
       #        Close Local File [EFS]
       Endif
      #*V5 Endif
      # Génération d'un évènement changement d'imputation comptable en unitaire ou en massif
      Gosub BCO_EVT
    Endif

    LOK = G_NON
    If ( [F:DEP]STRDPRDAT <> [F:TPF1]STRDPRDAT )   : [F:DEP]STRDPRDAT = [F:TPF1]STRDPRDAT : LOK = G_OUI : Endif
    # FQ82178
    If ( [F:DEP]ENDDPRDAT <> [F:TPF1]ENDDPRDAT and [F:TPF1]ENDDPRDAT <> [0/0/0] )  Then
      [F:DEP]ENDDPRFLG = G_OUI
      [F:DEP]ENDDPRDAT = [F:TPF1]ENDDPRDAT
      LOK = G_OUI
    Endif
    # FQ82178_2
    If ( [F:DEP]DPM <> [F:TPF1]DPM and find ([F:DEP]DPM, G_DPMRE, G_DPMRA) > 0 and find ([F:TPF1]DPM, G_DPMRE, G_DPMRA) =0)
      # Si le mode est different de RE et de RA alors la date de fin ne peut pas être forcée.
      [F:DEP]ENDDPRFLG = G_NON
    Endif
    If ( [F:DEP]DPM       <> [F:TPF1]DPM       )   : [F:DEP]DPM       = [F:TPF1]DPM       : LOK = G_OUI : Endif
    If ( [F:DEP]DPRDUR    <> [F:TPF1]DPRDUR    )   : [F:DEP]DPRDUR    = [F:TPF1]DPRDUR    : LOK = G_OUI : Endif
    If ( [F:DEP]DPRRATFLG <> [F:TPF1]DPRRATFLG )   : [F:DEP]DPRRATFLG = [F:TPF1]DPRRATFLG : LOK = G_OUI : Endif
    If ( [F:DEP]DPRRAT    <> [F:TPF1]DPRRAT    )   : [F:DEP]DPRRAT    = [F:TPF1]DPRRAT    : LOK = G_OUI : Endif
    If ( [F:DEP]DPRRAT2   <> [F:TPF1]DPRRAT2   )   : [F:DEP]DPRRAT2   = [F:TPF1]DPRRAT2   : LOK = G_OUI : Endif
    If ( [F:DEP]RSDVAL    <> [F:TPF1]RSDVAL    )   : [F:DEP]RSDVAL    = [F:TPF1]RSDVAL    : LOK = G_OUI : Endif
    If ( [F:DEP]CRBVEHCOD <> [F:TPF1]CRBVEHCOD )   : [F:DEP]CRBVEHCOD = [F:TPF1]CRBVEHCOD : LOK = G_OUI : Endif
    If ( [F:DEP]ALWCOD    <> [F:TPF1]ALWCOD    )   : [F:DEP]ALWCOD    = [F:TPF1]ALWCOD    : LOK = G_OUI : Endif
    If ( [F:DEP]ALWAMT    <> [F:TPF1]ALWAMT    )   : [F:DEP]ALWAMT    = [F:TPF1]ALWAMT    : LOK = G_OUI : Endif  #X3-61112
    If ( [F:DEP]ACLCOE    <> [F:TPF1]ACLCOE    )   : [F:DEP]ACLCOE    = [F:TPF1]ACLCOE    : LOK = G_OUI : Endif
    If ( [F:DEP]PRATYP    <> [F:TPF1]PRATYP    )   : [F:DEP]PRATYP    = [F:TPF1]PRATYP    : LOK = G_OUI : Endif
    #FQ80039
    If [F:DEP]DPRCUMFLG <> [F:TPF1]DPRCUMFLG
        [F:DEP]DPRCUMFLG = [F:TPF1]DPRCUMFLG
        LOK = G_OUI
    Endif
    If [F:DEP]DPMI <> [F:TPF1]DPMI
        [F:DEP]DPMI = [F:TPF1]DPMI
        LOK = G_OUI
    Endif
    If [F:DEP]DPMT <> [F:TPF1]DPMT
        [F:DEP]DPMT = [F:TPF1]DPMT
        LOK = G_OUI
    Endif
    If [F:DEP]MTCTIATYP <> [F:TPF1]MTCTIATYP
        [F:DEP]MTCTIATYP = [F:TPF1]MTCTIATYP
        LOK = G_OUI
    Endif


    #*Fq-78438
    If LOK=G_NON
       #-------------------------------------------
       # Si le mode actuel est "LP - Linéaire pur"
       If ( [F:TPF1]DPM = G_DPMLP and  not find([F:DEP]DPM, G_DPMRE,G_DPMUO,G_DPMSA))
          # - déb amort < deb exercice et prise d'effet <> déb amort
          # ou
          # - déb amort > deb exercice et < déb per et prise d'effet =  déb per
          #
          If ( [F:TPF1]STRDPRDAT < [F:TPF1]FIYSTRDAT and [F:TPF1]MTCTIATYP <> GVML_PEDBAM )      or
&            ( [F:TPF1]STRDPRDAT > [F:TPF1]FIYSTRDAT and [F:TPF1]STRDPRDAT < [F:TPF1]PERSTRDAT  and
&                                                        [F:TPF1]MTCTIATYP= GVML_PEDBPE )
             LOK=G_OUI
          Endif
       Endif
    Endif
    [F:DEP]MTCDEVADJ  = [F:TPF1]MTCDEVADJ
    If [F:TPF1] MTCTIATYP = GVML_PEDBPE
       [F:DEP]PERREFCLC  = [F:DEP]PERSTRDAT
       [F:DEP]PERREFCLCI = [F:DEP]PERSTRDAT
       [F:DEP]PERREFCLCT = [F:DEP]PERSTRDAT
    Else
       [F:DEP]PERREFCLC  = [F:DEP]FIYSTRDAT
       [F:DEP]PERREFCLCI = [F:DEP]FIYSTRDAT
       [F:DEP]PERREFCLCT = [F:DEP]FIYSTRDAT
    Endif
    [F:DEP]DEPSTA    = GVML_SCNOCAL


    #===== 2 =========
    If (LOK = G_OUI )
      If ( ( ACTTYPGES = GTAMMAS & dim(FLGSIM) > 0 and  FLGSIM = G_NON )  or  (ACTTYPGES = GTAMUNI) )
      Local Integer LCNX
      Call GET_CNX_FROM_PLAN ( [M:FASC]CPY2, [M:FASM]DPRPLND(I_PLN-1), LCNX ) From GLOBIENS
      Call DETERM_MTCTIADAT( [F:TPF1]MTCTIATYP,
&                            [F:TPF1]FIYSTRDAT, [F:TPF1]PERSTRDAT, [F:TPF1]STRDPRDAT,
&                            [F:DEP]MTCTIADAT ) From TRTFASTRFC
        #-------------------------------------------
        # Si le mode actuel est "LP - Linéaire pur"
        # FQ82075 FQ105809
        If (( find([F:TPF1]DPM, G_DPMLP,G_DPMSL,G_DPMTL) >0) and
&             not find([F:DEP]DPM, G_DPMRE,G_DPMUO,G_DPMSA))
           # - déb amort < deb exercice et prise d'effet <> déb amort
           # ou
           # - déb amort > deb exercice et < déb per et prise d'effet =  déb per
           #
           If ( [F:TPF1]STRDPRDAT < [F:TPF1]FIYSTRDAT and [F:TPF1]MTCTIATYP<> GVML_PEDBAM )      or
&             ( [F:TPF1]STRDPRDAT > [F:TPF1]FIYSTRDAT and [F:TPF1]STRDPRDAT < [F:TPF1]PERSTRDAT  and
&                                                                    [F:TPF1]MTCTIATYP= GVML_PEDBPE )
              Local Char    WDPM
              Local Integer GNRSD
              Local Char    L_RSDDPMTGR    # MODE RéSIDUEL
              Local Integer L_PRATYP       # Type de prorata
              WDPM = [F:TPF1]DPM
              # Si le mode résiduel existe.
              Call GET_DPM_RSD("",WDPM, L_RSDDPMTGR, L_PRATYP ) From TRTFAS
              If ( ( L_RSDDPMTGR <>"" ) | (L_RSDDPMTGR <> WDPM ) ) and ( WDPM <> "SA" )
                 [F:DEP]DPM    = L_RSDDPMTGR
                 #*FQ-58289 [F:DEP]PRATYP  = LPRATYP
                 # FQ77265
                 If L_PRATYP > 0
                   [F:DEP]PRATYP  = L_PRATYP
                 Endif
             Endif
           Endif
         Endif
        #-------------------------------------------
        #47475[F:DEP]PERREFCLC  = [F:DEP]MTCTIADAT
        #47475[F:DEP]PERREFCLCI = [F:DEP]MTCTIADAT
        #47475[F:DEP]PERREFCLCT = [F:DEP]MTCTIADAT
        If [F:TPF1]MTCTIATYP = GVML_PEDBPE
            [F:DEP]PERREFCLC  = [F:TPF1]PERSTRDAT
            [F:DEP]PERREFCLCI = [F:TPF1]PERSTRDAT
            [F:DEP]PERREFCLCT = [F:TPF1]PERSTRDAT
        Else
            [F:DEP]PERREFCLC  = [F:TPF1]FIYSTRDAT
            [F:DEP]PERREFCLCI = [F:TPF1]FIYSTRDAT
            [F:DEP]PERREFCLCT = [F:TPF1]FIYSTRDAT
        Endif
        # Génération d'un évènement changement de méthode en unitaire ou en massif
        LCDINT= "FASMTC"+num$([F:DEP]DPRPLN)
        GFAS = "[F:MAS1]"
        GDPO = "[F:DEPW]"
        GDPN = "[F:DEP]"
        # Génération des évènements de changement de méthode
          # Génération des évènements de changement de méthode
        If [F:DEP]MTCTIADAT=[0/0/0]
           WDATREF        =  [M:FASM]PERSTRDAT(nolign-1)
        Else
           WDATREF        =  [F:DEP]MTCTIADAT
        Endif
        WCPTDATINT    =   max([F:DEP]STRDPRDAT,GCPYSTRPER(LCNX))
        [F:DEP]MTCDPEDAT  =  WDATREF # ajouté car testé dans la réévaluation (MWA:27-02-2008)
        # Si evts de dépréciation non encore comptabilisés  ==>  globales alimentées
        # Sinon, si evts de dépréciation déjà comptabilisés ou pas d'évt de dépréciation ==>  globales à zéro
          Call GENER_EVE
&            (GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,WDATREF,WCPTDATINT,LCDRET)
&         From GENEVE
        If (LCDRET > 20)
          If (ACTTYPGES = GTAMMAS)   : # Massif uniquement
            # Erreur technique
            RMES = mess(107,GML_MSGFAS,1)-LCDINT+"-"+num$(LCDRET)
          Endif
          GOK=0 : Return
        Endif
      Endif

      Gosub ECR_PLN_NEW : # Massif uniquement

      If ( ACTTYPGES = GTAMMAS & dim(FLGSIM) > 0 and  FLGSIM = G_NON )   : # Massif uniquement
        #47475[F:DEP]PERREFCLC  = [F:DEP]MTCTIADAT
        #47475[F:DEP]PERREFCLCI = [F:DEP]MTCTIADAT
        #47475[F:DEP]PERREFCLCT = [F:DEP]MTCTIADAT
        If [F:DEP] MTCTIATYP = GVML_PEDBPE
            [F:DEP]PERREFCLC  =  [F:DEP]PERSTRDAT
            [F:DEP]PERREFCLCI =  [F:DEP]PERSTRDAT
            [F:DEP]PERREFCLCT =  [F:DEP]PERSTRDAT
        Else
            [F:DEP]PERREFCLC  = [F:DEP]FIYSTRDAT
            [F:DEP]PERREFCLCI = [F:DEP]FIYSTRDAT
            [F:DEP]PERREFCLCT = [F:DEP]FIYSTRDAT
        Endif
        [F:DEP]DEPSTA     = GVML_SCNOCAL
        [F:DEP]MTCDPEDAT  = [F:DEP]MTCTIADAT
        Rewrite [DEP]
        If (fstat)
          # Erreur technique
          RMES=mess(104,GML_MSGFAS,1)-"DEPREC"-mess(105,GML_MSGFAS,1)-"04"-mess(106,GML_MSGFAS,1)-[F:DEP]AASREF+"/"+num$([F:DEP]DPRPLN)
          GOK=0 : Return
        Else
          GOK=1 : Return
        Endif
      Endif
    Endif
    #===== 2 =========
  Endif
  #=== 1 =======

Return

#=====================================================================
$END_ALIM_TABLE

  #==> Suppression des globales nécessaires à  la fonction
  If dim(GACTVIRBOUT)   >0   : Kill GACTVIRBOUT     : Endif
  If dim(G_TRF_IAS)     >0   : Kill G_TRF_IAS       : Endif
  If dim(G_CFS)         >0   : Kill G_CFS           : Endif  # FQ95754_2
  If dim(G_CNLCFS)      >0   : Kill G_CNLCFS        : Endif  # FQ95754_3
  If dim(G_TRF_PCG)     >0   : Kill G_TRF_PCG       : Endif
  If dim(GMD1)          >0   : Kill GMD1            : Endif
  If dim(GQTY)          >0   : Kill GQTY            : Endif
  If dim(G_REPORT)      >0   : Kill G_REPORT        : Endif
  If dim(G_TRACE)       >0   : Kill G_TRACE         : Endif
  If dim(G_INCR)        >0   : Kill G_INCR          : Endif
  If dim(GFAS)          >0   : Kill GFAS            : Endif
  If dim(GDPO)          >0   : Kill GDPO            : Endif
  If dim(GDPN)          >0   : Kill GDPN            : Endif
  If dim(PLAN)          >0   : Kill PLAN            : Endif   #Fq-58042
  If dim(TBLDPM)        >0   : Kill TBLDPM          : Endif   #Fq-58042
  If dim(TBLDUR)        >0   : Kill TBLDUR          : Endif   #Fq-58042
  If dim(TBLRAT)        >0   : Kill TBLRAT          : Endif   #Fq-58042
  If dim(TBLRAT2)       >0   : Kill TBLRAT2         : Endif   #Fq-58042
  If dim(TBLALW)        >0   : Kill TBLALW          : Endif   #Fq-58042
  If dim(TBLVEH)        >0   : Kill TBLVEH          : Endif   #Fq-58042
  If dim(TBLPRA)        >0   : Kill TBLPRA          : Endif   #Fq-58042
  If dim(TBLACL)        >0   : Kill TBLACL          : Endif   #Fq-58042
  If dim(G_TBLMAJ)      >0   : Kill G_TBLMAJ        : Endif
  If dim(GDATREF)       >0   : Kill GDATREF         : Endif
  If dim(G_MES)         >0   : Kill G_MES           : Endif

  If ( ACTTYPGES = GTAMMAS and dim(G_DEFORCE) >0 )
    Kill G_DEFORCE
  Endif


Return
