#######################################################################################
## Etiquette ajoutée par le superviseur (écran FASTRFCP) 05/08/2010 10:35:50 (MDJ)
######################################################################################
Subprog AS_TRTFLG(VALEUR)
Variable Integer VALEUR

#*Fq-87928 Local Integer  I_FIS :  I_FIS=find(G301FIS,[M:FASM]DPRPLND)   #FQ-73690
#*Fq-87928  If ( [M:FASM]DPRPLND(nolign-1) <> G301SUB ) or (I_FIS=0)     #FQ-73690
#*Fq-87928  on autorise dans tous les cas le changement de méthode sur tous les plans

# FQ90828 en avant saisie on ne peut rien faire sur la CAC elle même
# FQ90828    Gosub COND_LIGPLN_ACTZO
# FQ90828 -> on supprime l'action sur l'écran

#*Fq-87928  Else
#*Fq-87928    Gosub COND_LIGPLN_DISZO
#*Fq-87928  Endif

End

######################################################################################
##########################################################################
Subprog AM_TRTFLG(VALEUR)
Variable Integer VALEUR

   # Si le flag est modifié et que l'on est déjà  passé par Contrôler
   If ( ACTSTATUS = 8 )
      If ( ACTTYPGES = GTAMMAS )
         Call ACTCHGCRIT From TRCPROCOM
      Else
         Call CHGACTPARM From TRCPROCOM
      Endif
   Endif
  # application des associations sur les paramètres plans (déplacé am_trtflg)
  Local Integer I
  Raz PLAN

  For I = 1 To [M:FASM]NBLIG1
     If VALEUR= G_OUI   #Fq-58042
        PLAN(I) = [M:FASM]DPRPLND(I-1)
        Actzo [M:FASM]MTCTIATYP(I-1)   # Issue 113764
     Endif
  Next I

  If ( ACTTYPGES = GTAMMAS )

     Call DETER_VAL_PLANS
&       ([M:MHC]CPY(find(G_OUI, [M:MHC]FLGCPY)-1), [M:FASC]ACGGRPD, [M:FASC]ACCCODD,
&        PLAN, TBLDPM, TBLDUR, TBLRAT, TBLRAT2, TBLALW, TBLVEH, TBLPRA, TBLACL, G_TBLMAJ)
&        From TRTASSO
  Else
     Call DETER_VAL_PLANS
&       ([M:OAC0]OBJCPY, [M:FASC]ACGGRPD, [M:FASC]ACCCODD,
&        PLAN, TBLDPM, TBLDUR, TBLRAT, TBLRAT2, TBLALW, TBLVEH,  TBLPRA, TBLACL,G_TBLMAJ)
&       From TRTASSO
  Endif

  Local Integer  I_FIS :  I_FIS=find(G301FIS,[M:FASM]DPRPLND)  #FQ-73690
   #FQ-79599 If ( ACTTYPGES=GTAMUNI and VALEUR= G_OUI  ) and
   #FQ-79599 En massif application des associations possibles car action mono-société
   #   If ( ACTTYPGES=GTAMUNI and VALEUR= G_OUI  ) and
   #FQ79599

#Fq-87928  If ( VALEUR= G_OUI  ) and
#Fq-87928 &    ( [M:FASM]DPRPLND(nolign-1) <> G301SUB or I_FIS=0 ) and
#Fq-87928 &    dim(GSAINONASSOC) <= 0

  If ( VALEUR= G_OUI  ) and
&    dim(GSAINONASSOC) <= 0

    [M:FASM]TRTFLG(nolign-1)= VALEUR
    Affzo [M:FASM]TRTFLG(nolign-1)
    Gosub ASSOCIATIONS
    # Si mise en service
    If ( G_MES = G_OUI )
      [M:FASM]STRFLG(nolign-1)= G_OUI
      Affzo  [M:FASM]STRFLG(nolign-1)
      # Deb FQ90392
      #[M:FASM]STRDPRDATD(nolign-1)= [M:FASC]ITSDATD #Fq-58042
      If ( ACTTYPGES = GTAMUNI )
      [M:FASM]STRDPRDATD(nolign-1)= [M:FASC]ITSDATD #Fq-58042
      Else
        If ([M:FASC]ITSDATD <> [0/0/0]) Then
          [M:FASM]STRDPRDATD(nolign-1)= [M:FASC]ITSDATD
        Endif
      Endif
      # Fin FQ90392
      Affzo  [M:FASM]STRDPRDATD(nolign-1)
      If ( [M:FASM]DPRPLND(nolign-1)= G301FIS )  and
&        (  [M:FASM]DPRCUM(nolign-1) <> 0 or [M:FASM]PERCLOCUM(nolign-1) <> 0 )
        GERR= 1: GMESSAGE = mess(612,GML_MSGFAS,1)
        mkstat = 2 : End
      Endif
      #*V5  Gestion de l'écart en fonction de la prise d'effet du chgt de méthode
      If [M:FASM]MTCTIATYP(nolign-1) = GVML_PEDBAM & ( [M:FASM]STRDPRDATD(nolign-1)  < [M:FASM]FIYSTRDAT(nolign-1) )
         [M:FASM]ECTFLG(nolign-1)    = G_OUI
         [M:FASM]MTCDEVADJ(nolign-1) = GVML_RDOTPER
      Else
         [M:FASM]ECTFLG(nolign-1)    = G_NON
         [M:FASM]MTCDEVADJ(nolign-1) = 0
      Endif
    Else
      Actzo [M:FASM]MTCDEVADJ(nolign-1)
    Endif
    If [M:FASM]DPMD(nolign-1) = G_DPMRE
      Actzo  [M:FASM]ENDDPRFLG(nolign-1)
    Endif
  Else
    [M:FASM]MTCDEVADJ(nolign-1) = GVML_RDOTPER
    Actzo [M:FASM]MTCDEVADJ(nolign-1)
  Endif

  # Si abandon sur ACTCHGCRIT mkstat= 2 mais pas de return. Il faut donc le gérer.
  If ( mkstat <> 0 )   : End : Endif

  If ( VALEUR = G_OUI )
    Gosub COND_LIGPLN_ACTZO
  Else
    Gosub COND_LIGPLN_DISZO
  Endif

End
