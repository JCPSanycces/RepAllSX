#--------------------------------------------------------------#
Subprog C_MTCTIATYP(VALEUR)
Variable Integer VALEUR

  If (ACTTYPGES = GTAMUNI )
    If [M:FASM]STRDPRDAT(nolign-1) > [M:FASM]FIYSTRDAT(nolign-1) &
&         VALEUR <> GVML_PEDBAM
      GERR=1
      GMESSAGE ="prise d'effet incorrecte"
      mkstat=2
      End
   Endif
   If  ( [M:FASM]STRDPRDAT(nolign-1) >= [M:FASM]PERSTRDAT(nolign-1) &
&         G_MES=G_OUI    &     VALEUR <>  GVML_PEDBAM   )
      GERR=1
      GMESSAGE ="prise d'effet incorrecte"
      mkstat=2
      End
    Endif
  Endif

End
