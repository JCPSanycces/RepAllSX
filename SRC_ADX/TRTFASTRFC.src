# Mise à jour des imputations comptables sur les dépenses FQ60753
$MAJ_ACC_LOF
  If ([F:MAS1]ACGGRP <> G_ACGGRP or [F:MAS1]GAC <> G_GAC or [F:MAS1]IASACC <> G_IASACC)
    For [F:LOF]LOF6 Where AASREF = [F:MAS1]AASREF
      [F:LOF]ACGGRP = [F:MAS1]ACGGRP
      [F:LOF]GAC    = [F:MAS1]GAC
      [F:LOF]GACACN = [F:MAS1]GACACN
      [F:LOF]IASACC = [F:MAS1]IASACC
      [F:LOF]IASACN = [F:MAS1]IASACN
      Rewrite [F:LOF] Curr
      If fstat
        # Erreur technique
        RMES= mess(104,GML_MSGFAS,1)+" LAYOUTFAS"+mess(105,GML_MSGFAS,1)+" 03"+mess(106,GML_MSGFAS,1)-[F:LOF]CODLOF+"/"+num$([F:LOF]LINLOF)
        GOK=0 : Break
      Endif
    Next
  Endif
Return


#69691 ajout pour import des mvts

$IMP_MVT
Local Char WWIMPZON

    WWIMPZON = IMPZON

    Case IMPZON
        When "FLGOWN"
            If WNUM = G_OUI
                IMPMOD = 1
            Endif
        When "FLGSAL"
            If WNUM = G_OUI
                IMPMOD = 1
            Endif
#        When "SALCLSDATD"
#            If WDATE <> G_OUI
#                IMPMOD = 1
#            Endif
        When "FLGACG"
            If WNUM = G_OUI
                IMPMOD = 1
            Endif
        When "ACGGRPD"
            If WCHAR <> [M:FAS1]ACGGRP
                IMPMOD = 1
            Endif
        When "FLGACC"
            If WNUM = G_OUI
                IMPMOD = 1
            Endif
        When "ACCCODD"
            If WCHAR <> [M:FAS1]ACCCOD
                IMPMOD = 1
            Endif
        When "ITSDATD"
            If WDATE <> [M:FAS1]ITSDAT
                IMPMOD = 1
            Endif
        When Default
    Endcase

    # si champ ds la liste (et valorisé) : il a forcément été paramétré : donc modifié
    If IMPMOD <> 1
        # c'est un champ du tabulaire : il faut l'indicer
        If find(IMPZON, GRUBPLN(1..GNBRUBPLN))
            WWIMPZON += "(" + num$([M]NBLIG1 - 1) + ")"
        Endif

        If find(WWIMPZON, GRUBALIM(1..GNBRUBALIM))
            IMPMOD = 1
        Endif
    Endif

Return
#PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP
# Traitement du ou des masques de paramètres de l'action massive               #
# -----> PARAMETRES  FASMTC, FASMTCP                                           #
#PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP

#===========================================#
# Actions de contrôle sur champ  FASMTC     #
#===========================================#
#

########################################################################## FQ57624
Subprog AV_MVTTYP(VALEUR)
Variable Char    VALEUR()
  Gosub CONDITIONNE_IAS_FASTRFC From TRTFAS
End

##########################################################################
Subprog AM_MVTDAT(VALEUR)
Variable Date    VALEUR

Local Integer I


End

##########################################################################
Subprog AM_FLGOWN(VALEUR)
Variable Integer VALEUR

  If (VALEUR = G_NON)
    Effzo[M:FASC]OWNTYPD : Affzo [M:FASC]OWNTYPD
  Endif
  If ( VALEUR = G_NON and [M:FASC]FLGACG = G_NON and [M:FASC]FLGACC = G_NON and [M:FASC]FLGSAL = G_NON)
    Gosub COND_TABPLN_DISZO
  Else
    Gosub COND_TRTFLG_ACTZO
  Endif
End

##########################################################################
Subprog AS_OWNTYPD(VALEUR)
Variable Integer VALEUR

  # Type de détention ne peut être que "En propriété"
  GMENLOC(GVML_TDLOCAT)=1
  GMENLOC(GVML_TDCBAIL)=1
  GMENLOC(GVML_TDPREVU)=1
  GMENLOC(GVML_TDCONCE)=1
  GMENLOC(GVML_TDMODEL)=1
  GMENLOC(GVML_TDANNUL)=1

End

######################################################################################
Subprog AS_FLGSAL(VALEUR)
Variable Integer VALEUR
  # FQ95754_3
  If ( ACTTYPGES=GTAMUNI ) Then
    If   ([M:FAS1]OWNTYP <> GVML_TDPROPR and [M:FAS1]OWNTYP <> GVML_TDCONCE)   Then
      VALEUR = G_NON
      mkstat = 3
      End
    Endif
  Endif
End

######################################################################################
Subprog AM_FLGSAL(VALEUR)
Variable Integer VALEUR

#Fq-51185
# FQ95754 : suppression du code activité SPA : mise au net du source
# (si on met en commentaires les tests concernés : c'est illisible
  If (VALEUR = G_NON)
    Effzo [M:FASC]SALCLSDATD
    Effzo [M:FASC]EXTSALAMT
    # FQ95754_3
    Effzo [M:FASC]ACGCUR
    Diszo [M:FASC]SALCLSDATD
    Diszo [M:FASC]EXTSALAMT
    If ( ACTTYPGES=GTAMUNI and [M:FAS4]SALCLSDAT <> [0/0/0] ) Then
      G_CNLCFS = G_OUI
    Else
      G_CNLCFS = G_NON
    Endif
  Else
    If ACTTYPGES=GTAMUNI
      G_CNLCFS = G_NON
      [M:FASC]SALCLSDATD = [M:FAS4]SALCLSDAT
      [M:FASC]EXTSALAMT  = [M:FAS4]EXTSALAMT
      [M:FASC]ACGCUR     = [M:FAS1]ACGCUR
      # FQ95754_3
      If ([M:FAS4]SALCLSDAT = [0/0/0] )  Then
        Actzo [M:FASC]SALCLSDATD
        Actzo [M:FASC]EXTSALAMT
      Else
        Diszo [M:FASC]SALCLSDATD
        Diszo [M:FASC]EXTSALAMT
      Endif
    Endif
    # FQ95754_3
    # Actzo [M:FASC]EXTSALAMT
  Endif
  Affzo [M:FASC]SALCLSDATD, EXTSALAMT, ACGCUR

  If [M:FASC]FLGOWN = G_NON and [M:FASC]FLGACG = G_NON and
&    [M:FASC]FLGACC = G_NON and VALEUR = G_NON
    Gosub COND_TABPLN_DISZO
  Else
    Gosub COND_TRTFLG_ACTZO
  Endif

End
##########################################################################
Subprog AM_SALCLSDATD(VALEUR)
Variable Date    VALEUR

If VALEUR <> [M:FASC]SALCLSDATD and VALEUR <>  [0/0/0]
   For I = 1 To [M:FASM]NBLIG1
      If [M:FASM]PLNSTD(I-1) = GVML_NPIAS
         # FQ95754_2 Pas de précochage pour changement de méthode  des plans normés IAS/IFRS
         # [M:FASM]TRTFLG(I-1) = G_OUI : Affzo [M:FASM]TRTFLG(I-1)
         If  ACTTYPGES=GTAMUNI
            If not ( func TRTFAS.IS_SUPEG_EXC ([M:FAS0]CPY, VALEUR, [M:FASM]CNX(I-1)) )
               GERR= 1: GMESSAGE = mess(688, GML_MSGFAS,1)
               mkstat = 2 : End
            Endif
         Endif
      Endif
   Next
Endif
[M:FASC]SALCLSDATD = VALEUR : Affzo [M:FASC]SALCLSDATD

End
##########################################################################
Subprog C_SALCLSDATD(VALEUR)
Variable Date    VALEUR

#Fq-51185
If VALEUR <> [0/0/0]
   For I = 1 To [M:FASM]NBLIG1
      If [M:FASM]PLNSTD(I-1) = GVML_NPIAS
         If ACTTYPGES=GTAMUNI
            If not ( func TRTFAS.IS_SUPEG_EXC ([M:FAS0]CPY, VALEUR, [M:FASM]CNX(I-1)) )
               GERR= 1: GMESSAGE = mess(688, GML_MSGFAS,1)
               mkstat = 2 : End
            Endif
         Endif
      Endif
   Next
Endif

End
##########################################################################
Subprog AV_FLGACG(VALEUR)
Variable Integer VALEUR

  # FQ57624_2
  If ( ACTTYPGES = GTAMUNI )
    # FQ57624
    # Pour un champs de type DATE, un chgfmt est fait après l'avant-zone. Il faut intervenir
    # sur le champ suivant pour refaire le chgfmt
    # FQ95754_4
    If find (GVML_NPIAS, [M:FPC]PLNSTD)= 0  : Chgfmt [M:FASC]SALCLSDATD  With "-D:"+GFMDAT4 : Endif

    #FQ95754
    #   If [M:FPC]FLGIAS <> G_OUI or [M:FPC]LEG<>"SPA": Chgfmt [M:FASC]EXTSALAMT   With "-N:9.2" : Endif   # Fq-85984
    If find (GVML_NPIAS, [M:FPC]PLNSTD)= 0 : Chgfmt [M:FASC]EXTSALAMT   With "-N:9.2" : Endif  : # FQ95754_4
  Endif
  If ( ACTTYPGES = GTAMMAS )
    # FQ57624_4
    Chgfmt [M:FASC]SALCLSDATD  With "-D:"+GFMDAT4
    Chgfmt [M:FASC]EXTSALAMT   With "-N:9.2"
  Endif

End
##########################################################################
Subprog AM_FLGACG(VALEUR)
Variable Integer VALEUR

  If (VALEUR = G_NON)
    Effzo [M:FASC]ACGGRPD : Affzo [M:FASC]ACGGRPD
    If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FASC]FLGACC", 0) = G_NON )
      [M:FASC]FLGACC = G_NON : Affzo [M:FASC]FLGACC
      Raz [M:FASC]ACCCODD, [M:FASC]GACACND, [M:FASC]GACD, [M:FASC]IASACND, [M:FASC]IASACCD
      Affzo [M:FASC]ACCCODD, GACACND, GACD, IASACND, IASACCD
    Endif
  Endif
  If ( [M:FASC]FLGOWN = G_NON and VALEUR = G_NON and [M:FASC]FLGACC = G_NON and [M:FASC]FLGSAL= G_NON)
    Gosub COND_TABPLN_DISZO
  Else
    #FQ69691B
    If dim(GFXDINT) <= 0 Then
      Gosub COND_TRTFLG_ACTZO
    Endif
  Endif
  [M:FASC]FLGACG = VALEUR   #Fq-58042
End

##########################################################################
Subprog AM_ACGGRPD(VALEUR)
Variable Char    VALEUR()

Local Char    LACCCOD
Local Char    LGAC, LIASACC
Local Integer LGACACN, LIASACN, LUPDFLG
Local Integer OK

  # Détermination du code comptable à  partir de la famille
  If ( ACTTYPGES = GTAMMAS )
    # Si la famille est modifiée et que l'on est déjà  passé par Contrôler
    If ( ACTTYPGES = GTAMMAS and ACTSTATUS = 8   )
      If ( find(G_OUI,[M:FASM]TRTFLG) <> 0 )
        Call ACTCHGCRIT From TRCPROCOM
      Else
        # Si aucun changement de méthode de coché
        Call CHGACTPARM From TRCPROCOM
      Endif
    Endif
    # Si abandon sur ACTCHGCRIT ou CHGACTPARM mkstat= 2 mais pas de return. Il faut donc le gérer.
    If ( mkstat <> 0 )   : End : Endif

    Call DETER_ACCCOD(VALEUR, [M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1), LACCCOD, LUPDFLG) From TRTASSO
  Else
    Call DETER_ACCCOD(VALEUR, [M:OAC0]OBJCPY, LACCCOD, LUPDFLG) From TRTASSO
  Endif

  If (LACCCOD <> "" and LACCCOD <> [M:FASC]ACCCODD )
    [M:FASC]FLGACC = G_OUI
    [M:FASC]ACCCODD = LACCCOD
    # FQ90537 ajout du Else : le nouveau code peut être modifiable
    If LUPDFLG = G_NON
      Diszo [M:FASC]FLGACC
      Diszo [M:FASC]ACCCODD
    Else
      Actzo [M:FASC]FLGACC, ACCCODD
    Endif
    # Récupération des champs déterminés par le code comptable
    Call GET_GAC_IAS_FROM_GACCODE (GVML_COGIMMO, LACCCOD, GGACIMMO, GIASIMMO,
&                                  LGACACN, LGAC, LIASACN, LIASACC) From GLOBIENS
    # Contrôle du code comptable
    Gosub CTRL_ACCCOD
    # Affectation des champs écran déterminés par le code comptable
    Gosub ALIM_GAC_IAS_FROM_ACCCOD
  Elsif LACCCOD = ""
    # FQ90537 ajout de ce cas mais ... dépend de [M:FASC]ACCCODD
    Actzo [M:FASC]FLGACC
    Diszo [M:FASC]ACCCODD
  Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran FASTRFC) 07/11/2008 10:40:20 (MDJ)
######################################################################################
Subprog C_ACGGRPD(VALEUR)
Variable Char    VALEUR()

#    If !clalev([ADI]) : Local File ATABDIV [ADI] : Endif : # FQ54343
#    Read [ADI]CODE = GTD_FAMCPT;VALEUR
#    If fstat=0
#      If   [F:ADI]LEG <> ""  &   [F:ADI]LEG <> [M:FPC]LEG
    Local File FASFAM [FAM]
    Read [FAM]FAM0 = VALEUR
    If fstat=0
      If   [F:FAM]LEG <> ""  &  [F:FAM]LEG <> [M:FPC]LEG
         GERR= 1: GMESSAGE = mess(683,GML_MSGFAS,1)-" "-[M:FPC]LEG
         mkstat = 2 : End
      Endif
    Endif

End
##########################################################################
Subprog AM_FLGACC(VALEUR)
Variable Integer VALEUR

  If (VALEUR = G_NON)
    Raz [M:FASC]ACCCODD, [M:FASC]GACACND, [M:FASC]GACD, [M:FASC]IASACND, [M:FASC]IASACCD
    Affzo [M:FASC]ACCCODD, GACACND, GACD, IASACND, IASACCD
  Endif

  If ( [M:FASC]FLGOWN = G_NON and [M:FASC]FLGACG = G_NON and VALEUR= G_NON and [M:FASC]FLGSAL= G_NON )
    Gosub COND_TABPLN_DISZO
  Else
    #FQ69691B
    If dim(GFXDINT) <= 0 Then
      Gosub COND_TRTFLG_ACTZO
    Endif
  Endif
  [M:FASC]FLGACC = VALEUR #Fq-58042
End
##########################################################################
Subprog C_ACCCODD(VALEUR)
Variable Char    VALEUR()

Local Char    LGAC, LIASACC
Local Integer LGACACN, LIASACN
Local Integer OK, I

End

##########################################################################
Subprog AM_ACCCODD(VALEUR)
Variable Char    VALEUR()

Local Char    LACCCOD
Local Char    LGAC, LIASACC
Local Integer LGACACN, LIASACN
Local Integer OK, I

  # Si le code comptable est modifié et que l'on est déjà  passé par Contrôler
  If ( ACTTYPGES = GTAMMAS and ACTSTATUS = 8   )
    If ( find(G_OUI,[M:FASM]TRTFLG) <> 0 )
      Call ACTCHGCRIT From TRCPROCOM
    Else
      # Si aucun changement de méthode de coché
      Call CHGACTPARM From TRCPROCOM
    Endif
  Endif
  # Si abandon sur ACTCHGCRIT ou CHGACTPARM mkstat= 2 mais pas de return. Il faut donc le gérer.
  If ( mkstat <> 0 )   : End : Endif

  # Récupération des champs déterminés par le code comptable
  Call GET_GAC_IAS_FROM_GACCODE (GVML_COGIMMO, VALEUR, GGACIMMO, GIASIMMO,
&                                LGACACN, LGAC, LIASACN, LIASACC) From GLOBIENS

  # Contrôle du code comptable
  LACCCOD = VALEUR
  Gosub CTRL_ACCCOD

  # Affectation des champs écran déterminés par le code comptable
  Gosub ALIM_GAC_IAS_FROM_ACCCOD

End
#-------------
$CTRL_ACCCOD
#-------------
  # Code comptable invalide
  If ( ( GCNXPROIAS = G_OUI and LIASACN = 0 ) or ( LGACACN = 0 ) )
    GERR= 1: GMESSAGE = mess(342,GML_MSGFAS,1)
    mkstat = 2 : End
  Endif

  # Contrôle de l'autorisation Société/site pour le(s) compte(s) PCG (et IAS) en unitaire
  If ACTTYPGES=GTAMUNI
    # FQ95579 + GFASLEDSOC
    Call CTRL_AUT_OBJ("GAC", LGAC, GFASLEDSOC, [M:FAS0]FCY, date$) From GLOBIENS
    If mkstat
      GERR= 1
      # FQ95579 message repris
      If GMESSAGE = ""
        GMESSAGE = LGAC - mess(524, GML_MSGFAS, 1) - LACCCOD - mess(525, GML_MSGFAS, 1) : # <Compte> : ce compte issu du code comptable <code comptable> n'est pas autorisé pour cette société ou ce
      Else
        Local Integer I
        I = instr(1, GMESSAGE, " ")
        If I
          GMESSAGE =right$(GMESSAGE, I + 1)
        Endif
        GMESSAGE = LGAC - mess(524, GML_MSGFAS, 1) - LACCCOD - ":" - GMESSAGE
      Endif

      mkstat = 2 : End
    Endif
    If GCNXPROIAS = G_OUI
      # FQ95579 + GFASLEDIAS
      Call CTRL_AUT_OBJ("GAC", LIASACC, GFASLEDIAS, [M:FAS0]FCY, date$) From GLOBIENS
      If mkstat
        GERR= 1
        # FQ95579 message repris
        If GMESSAGE = ""
          GMESSAGE = LIASACC - mess(524, GML_MSGFAS, 1) - LACCCOD - mess(525, GML_MSGFAS, 1) : # <Compte> : ce compte issu du code comptable <code comptable> n'est pas autorisé pour cette société ou
        Else
          Local Integer I
          I = instr(1, GMESSAGE, " ")
          If I
            GMESSAGE =right$(GMESSAGE, I + 1)
          Endif
          GMESSAGE = LIASACC - mess(524, GML_MSGFAS, 1) - LACCCOD - ":" - GMESSAGE
        Endif

        mkstat = 2 : End
      Endif
    Endif
  Endif

  # L'application contrôle que le bien est imputé sur au moins  un compte immobilisation
  # Soit vis à  vis des normes PCG soit vis à  vis des normes IAS.
  If ( GCNXPROIAS = G_OUI )
    If ( LIASACN = GVML_NICHARG and LGACACN = GVML_NICHARG )
      GERR= 1: GMESSAGE = mess(74,GML_MSGFAS,1)
      mkstat = 2 : End
    Endif
  Else
    If ( LGACACN = GVML_NICHARG )
      GERR= 1: GMESSAGE = mess(74,GML_MSGFAS,1)
      mkstat = 2 : End
    Endif
  Endif

  If ( LGACACN <> 0 and ACTTYPGES=GTAMUNI )
    # Demande de confirmation
    # si la nature du compte comptable passe
    # de "Charge"     à  "En cours"
    # de "Charge"     à  "En service"
    # de "En cours"   à  "Charge"
    # de "En service" à  "Charge"
    # de "En service" à  "En cours"
    If (
&        ( [M:FAS1]GACACN = GVML_NICHARG and LGACACN = GVML_NIENCOU ) or
&        ( [M:FAS1]GACACN = GVML_NICHARG and LGACACN = GVML_NIENSER ) or
&        ( [M:FAS1]GACACN = GVML_NIENCOU and LGACACN = GVML_NICHARG ) or
&        ( [M:FAS1]GACACN = GVML_NIENSER and LGACACN = GVML_NICHARG ) or
&        ( [M:FAS1]GACACN = GVML_NIENSER and LGACACN = GVML_NIENCOU )
&       )
      Call OUINON(
&     mess(68,GML_MSGFAS,1)-mess([M:FAS1]GACACN,2628,1)-mess(70,GML_MSGFAS,1)-mess(LGACACN,2628,1)-mess(71,GML_MSGFAS,1), OK
&                ) From GESECRAN
      If ( OK = 1)   : mkstat = 2 : End : Endif
    Endif
  Endif

  If ( GCNXPROIAS = G_OUI  and LIASACN <> 0 and ACTTYPGES=GTAMUNI )
    # Demande de confirmation
    # si la nature de l'imputation IAS passe
    # de "Charge"     à  "En cours"
    # de "Charge"     à  "En service"
    # de "En cours"   à  "Charge"
    # de "En service" à  "Charge"
    # de "En service" à  "En cours"
    If (
&        ( [M:FAS1]IASACN = GVML_NICHARG and LIASACN = GVML_NIENCOU ) or
&        ( [M:FAS1]IASACN = GVML_NICHARG and LIASACN = GVML_NIENSER ) or
&        ( [M:FAS1]IASACN = GVML_NIENCOU and LIASACN = GVML_NICHARG ) or
&        ( [M:FAS1]IASACN = GVML_NIENSER and LIASACN = GVML_NICHARG ) or
&        ( [M:FAS1]IASACN = GVML_NIENSER and LIASACN = GVML_NIENCOU )
&       )
      Call OUINON(
&     mess(69,GML_MSGFAS,1)-mess([M:FAS1]IASACN,2628,1)-mess(70,GML_MSGFAS,1)-mess(LIASACN,2628,1)-mess(71,GML_MSGFAS,1), OK
&                ) From GESECRAN
      If ( OK = 1)   : mkstat = 2 : End : Endif
    Endif
  Endif

 If ACTTYPGES=GTAMUNI
    # si la nature de l'imputation  PCG passe  de
    # de   "En cours" à "En service""
    If ( [M:FAS1]GACACN = GVML_NIENCOU and LGACACN = GVML_NIENSER )
       [M:FASC]ITSDATD = [M:FAS1]ITSDAT
       G_MES = G_OUI
       Actzo  [M:FASC]ITSDATD
    Else
       G_MES = G_NON
       Grizo [M:FASC]ITSDATD
    Endif
 Else
    # FQ90392
    If ( LGACACN = GVML_NIENSER  ) Then
       G_MES = G_OUI
       Actzo  [M:FASC]ITSDATD
    Else
       G_MES = G_NON
       Grizo [M:FASC]ITSDATD
 Endif
 Endif

 # FQ67615 Contrôle Low value assets
 If ( ACTTYPGES = GTAMUNI )
   If ( [M:FASC]FLGACC = G_OUI ) Then
     # Le compte immobilisation du nouveau code comptable doit être du même type que le statut du bien
     Local Integer L_LVATYP
     Call GET_LVATYP_FROM_GACCODE (GVML_COGIMMO, LACCCOD, GGACIMMO, L_LVATYP) From GLOBIENS
     If ( (L_LVATYP = GVML_GLVALVA  and [M:FAS1]CMPSTA <> GVML_SBLVA)  or
&       (L_LVATYP = GVML_GLVAPOOL and [M:FAS1]CMPSTA <> GVML_SBPOOL) or
&       (([M:FAS1]CMPSTA = GVML_SBPOOL or [M:FAS1]CMPSTA = GVML_SBLVA) and L_LVATYP = GVML_GLVAAUC) or
&       ((L_LVATYP = GVML_GLVALVA or L_LVATYP = GVML_GLVAPOOL ) and
&        [M:FAS1]CMPSTA <> GVML_SBPOOL and [M:FAS1]CMPSTA <> GVML_SBLVA) ) Then

       # Incohérence statut bien et indicateur compte
       GMESSAGE = mess(880,7773,1)
       GERR = 1 : OK = 0 : Return
     Endif
   Endif
 Endif

Return
#--------------------------------------------------------------#
Subprog AS_ITSDATD(VALEUR)
Variable Date    VALEUR

# FQ90392
# If ( ACTTYPGES <> GTAMUNI ) or ( G_MES = G_NON )
If ( G_MES = G_NON ) Then
   #Diszo  [M:FASC]ITSDATD # FQ57819
   Grizo  [M:FASC]ITSDATD
Else
   Actzo [M:FASC]ITSDATD
Endif

End
#--------------------------------------------------------------#
Subprog AV_ITSDATD(VALEUR)
Variable Date    VALEUR

# FQ90392
#If ( ACTTYPGES <> GTAMUNI ) or ( G_MES = G_NON )
If ( G_MES = G_NON ) Then
   #Diszo  [M:FASC]ITSDATD # FQ57819
   Grizo  [M:FASC]ITSDATD
Else
   Actzo [M:FASC]ITSDATD
Endif

End

#--------------------------------------------------------------#
Subprog AM_ITSDATD(VALEUR)
Variable Date    VALEUR
Local Integer OK

# FQ90392
If ( ACTTYPGES = GTAMUNI ) Then
  # La date de mise en service doit être >= à la date d'achat
  If ( VALEUR <> [0/0/0] & VALEUR < [M:FAS1]PURDAT )
    Call OUINON(mess(16,GML_MSGFAS,1), OK) From GESECRAN
    If ( OK = 1)   : mkstat = 2 : End : Endif
  Endif

  # La date de mise en service doit être >= à la date de comptablisation
  If ( VALEUR <> [0/0/0] & VALEUR < [M:FAS1]AASIPTDAT  )
    Call OUINON(mess(1,GML_MSGFAS,1), OK) From GESECRAN
    If ( OK = 1)   : mkstat = 2 : End : Endif
  Endif
Endif

End
