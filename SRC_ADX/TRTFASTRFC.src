##########################################################################
Subprog AS_MTCDEVADJ(VALEUR)
Variable Integer VALEUR

#*V5 si taux anticipato alimenté ==> pas de gestion d'écart en dotation exceptionnelle
If ( [M:FASM]DPRRA2FLGD(nolign-1)  = G_OUI )  or ( [M:FASM]DPRRAT2D(nolign-1) > 0 )
   GMENLOC(GVML_REXCEXE) = 1
   GMENLOC(GVML_REXCPER) = 1
Endif
#*V5  Gestion de l'écart en fonction de la prise d'effet du chgt de méthode
If [M:FASM]MTCTIATYP(nolign-1) = GVML_PEDBAM
   If ( [M:FASM]STRDPRDATD(nolign-1)  < [M:FASM]FIYSTRDAT(nolign-1) )
        [M:FASM]ECTFLG(nolign-1) = G_OUI
        [M:FASM]MTCDEVADJ(nolign-1) = GVML_RDOTPER
      If ( ACTTYPGES=GTAMUNI )
        Actzo [M:FASM]MTCDEVADJ(nolign-1)
      Endif
    Else
      If G_MES = G_NON
         If ( [M:FASM]STRDPRDATD(nolign-1) >= [M:FASM]FIYSTRDAT(nolign-1) &
&             [M:FASM]STRDPRDATD (nolign-1) < [M:FASM]PERSTRDAT(nolign-1) )
              [M:FASM]MTCDEVADJ(nolign-1) = GVML_RDOTEXE
              [M:FASM]ECTFLG(nolign-1) = G_OUI
              Diszo  [M:FASM]MTCDEVADJ(nolign-1)
         Else
            If [M:FASM]STRDPRDATD (nolign-1) >= [M:FASM]PERSTRDAT(nolign-1)
               [M:FASM]MTCDEVADJ(nolign-1) = 0
               [M:FASM]ECTFLG(nolign-1) = G_NON
              Diszo  [M:FASM]MTCDEVADJ(nolign-1)
               mkstat=2
            Endif
         Endif
      Endif
    Endif
  Else
    [M:FASM]MTCDEVADJ(nolign-1) = 0
    [M:FASM]ECTFLG(nolign-1) = G_NON
    Diszo  [M:FASM]MTCDEVADJ(nolign-1)
    mkstat=2
  Endif
  Affzo [M:FASM]MTCDEVADJ(nolign-1)

End
#--------------------------------------------------------------#
Subprog C_MTCDEVADJ(VALEUR)
Variable Integer VALEUR
   Call  C_MTCDEVADJ(VALEUR) From TRTFASMTC
End
