Variable Integer VALEUR
  Call AM_MTCDEVADJ(VALEUR) From TRTFASMTC
End
##########################################################################
Subprog AM_VEHFLG(VALEUR)
Variable Integer VALEUR
  Call AM_VEHFLG(VALEUR) From TRTFASMTC
End
##########################################################################
Subprog AM_ALWFLG(VALEUR)
Variable Integer VALEUR
  Call AM_ALWFLG(VALEUR) From TRTFASMTC
End

##########################################################################
Subprog AS_ALWCODD(VALEUR)
Variable Integer VALEUR
  Call AS_ALWCODD(VALEUR) From TRTFASMTC
End

#==============================================================#
# Traitements appelés par Gosub, Call et Func                  #
#==============================================================#
#

#==============
Subprog INIT_PLAN_AMT(PCPY)
#==============
Value Char    PCPY
Local Integer ORIBAS, I
Local Date    FIYSTRC,  FIYENDC,  PERSTRC,  PERENDC
Local Date    FIYSTRS,  FIYENDS,  PERSTRS,  PERENDS
Local Date    FIYSTRCIAS, PERENDCIAS

FIYSTRCIAS = [0/0/0]
PERENDCIAS = [0/0/0]

  # - Ouverture des tables pour pouvoir appeler ce sous-pro depuis un traitement appelant
  #   utilisant le changement d'imputation comptable en mode silencieux

  If !clalev([F:CNX]) : Local File CONTEXT  [CNX] : Endif
  If !clalev([F:FIS]) : Local File FISCYEAR [FIS] : Endif


  # Initialisation des champs du bien comptable
  Effzo [M:FASC]MVTTYP
  Effzo [M:FASC]ZMVTTYP
  [M:FASC]FLGOWN = G_NON   : Affzo [M:FASC]FLGOWN
  Effzo [M:FASC]OWNTYPD    : Diszo [M:FASC]OWNTYPD
  [M:FASC]FLGSAL = G_NON   : Affzo [M:FASC]FLGSAL      #Fq-51185
  Effzo [M:FASC]SALCLSDATD : Diszo [M:FASC]SALCLSDATD  #Fq-51185
  Effzo [M:FASC]EXTSALAMT  : Diszo [M:FASC]EXTSALAMT   #Fq-85984
  [M:FASC]FLGACG = G_NON   : Affzo [M:FASC]FLGACG
  Effzo [M:FASC]ACGGRPD    : Diszo [M:FASC]ACGGRPD
  Effzo [M:FASC]ZACGGRPD
  [M:FASC]FLGACC = G_NON   : Affzo [M:FASC]FLGACC
  Effzo [M:FASC]ACCCODD    : Diszo [M:FASC]ACCCODD
  Effzo [M:FASC]ZACCCODD
  Effzo [M:FASC]GACD
  Effzo [M:FASC]ZGACD
  [M:FASC]GACACND = 0      : Affzo [M:FASC]GACACND
  Effzo [M:FASC]IASACCD
  Effzo [M:FASC]ZIASACCD
  [M:FASC]IASACND = 0      : Affzo [M:FASC]IASACND

  Call ACTION_BLOCK (ACB_AFFZO, "FASTRFC", "MVTDAT") From GLOBIENS

  # Le tableau est préchargé à  partir des contextes pour que l'on ait pour chaque plan géré
  # la date de début de l'exercice courant et de la période courante
  # Ces dates peuvent différer selon que la date de clôture de chacun des contextes.
  nolign = 1
  For [CNX] Where CPY =PCPY
     #---------------------------
     # Lecture exercice courant
     Filter [FIS] Where CPY=PCPY and CNX = [F:CNX]CNX and STAFIY = GVML_TECOURA
        Read [FIS]First
        If (fstat)   : Raz [F:FIS] : Endif
     Filter [FIS]
     FIYSTRC =[F:FIS]DATSTRFIY
     FIYENDC =[F:FIS]DATENDFIY
     PERSTRC =[F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
     PERENDC =[F:FIS]DATENDPER([F:FIS]INDCURPER-1)
     If find (G301IAS, [F:CNX]PLNCAA(0..[F:CNX]NBPLC-1)) > 0
        FIYSTRCIAS = FIYSTRC
        PERENDCIAS = PERENDC
    Else
       If ( FIYSTRCIAS = [0/0/0] &  PERENDCIAS = [0/0/0] )  & ( find (GVML_NPIAS, [F:CNX]PLNSTD(0..[F:CNX]NBPLC-1)) > 0 )
          FIYSTRCIAS = FIYSTRC
          PERENDCIAS = PERENDC
       Endif
    Endif
     #---------------------------
     # Lecture exercice suivant
     Filter [FIS] Where CPY=PCPY and CNX = [F:CNX]CNX and STAFIY = GVML_TESUIV
        Read [FIS]First
        If (fstat)   : Raz [F:FIS] : Endif
     Filter [FIS]
     FIYSTRS =[F:FIS]DATSTRFIY
     FIYENDS =[F:FIS]DATENDFIY
     PERSTRS =[F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
     PERENDS =[F:FIS]DATENDPER([F:FIS]INDCURPER-1)

     #---------------------------
     For I = 0 To [F:CNX]NBPLC-1
        # Le code véhicule n'est saisissable que pour le plan fiscal
        If ( [F:CNX]PLNCAA(I) <> G301FIS )
          Diszo [M:FASM]VEHFLG(nolign-1)
        Endif
        [M:FASM]DPRPLND(nolign-1)    = [F:CNX]PLNCAA(I)
        [M:FASM]ORIBAS(nolign-1)     = [F:CNX]ORIBASDPR(I)
        If [F:CNX]PLNSTD(I)  = GVML_NPIAS
           [M:FASM]FIYSTRDATI(nolign-1)   = FIYSTRCIAS
           [M:FASM]PERENDDATI(nolign-1)   = PERENDCIAS
        Endif
        [M:FASM]CURD(nolign-1)       = [F:CNX]CUR
        [M:FASM]CPY1(nolign-1)       = [F:CNX]CPY : # FQ78438
        [M:FASM]CNX(nolign-1)        = [F:CNX]CNX
        [M:FASM]ITSDAT(nolign-1)     = [M:FASC]ITSDATD
        [M:FASM]FIYSTRDAT(nolign-1)  = FIYSTRC
        [M:FASM]FIYENDDAT(nolign-1)  = FIYENDC
        [M:FASM]PERSTRDAT(nolign-1)  = PERSTRC
        [M:FASM]PERENDDAT(nolign-1)  = PERENDC
        [M:FASM]FIYENDDAT2(nolign-1) = FIYENDS
        [M:FASM]PERENDDAT2(nolign-1) = PERENDS
        If  (ACTTYPGES=GTAMUNI)
           Read[DEP]DEP0=[M:FAS0]AASREF;[M:FASM]DPRPLND(nolign-1);[M:FASM]FIYENDDAT(nolign-1);[M:FASM]PERENDDAT(nolign-1)
           If fstat=0
             [M:FASM]DPMO(nolign-1)       = [F:DEP]DPM              # Fq-89463
             [M:FASM]DPRDURO(nolign-1)    = [F:DEP]DPRDUR           # Fq-89463
             [M:FASM]DPRRATO(nolign-1)    = [F:DEP]DPRRAT           # Fq-89463
             [M:FASM]STRDPRDAT(nolign-1)  = [F:DEP]STRDPRDAT
             [M:FASM]DPRCUM(nolign-1)     = [F:DEP]DPRCUM
             [M:FASM]PERCLOCUM(nolign-1)  = [F:DEP]PERCLOCUM
             [M:FASM]DPRCUMFLG(nolign-1)  = [F:DEP]DPRCUMFLG
             [M:FASM]DPRRATFLGO(nolign-1) = [F:DEP]DPRRATFLG        # FQ94929
             [M:FASM]ENDDPRDAT(nolign-1)  = [F:DEP]ENDDPRDAT        # FQ82178
             [M:FASM]PRATYPO(nolign-1)    = [F:DEP]PRATYP           # FQ82178
           Endif
        Endif
        [M:FASM]TRTFLG(nolign-1)      = G_NON
        [M:FASM]MTCFLG(nolign-1)      = G_NON
        [M:FASM]STRFLG(nolign-1)      = G_NON
        Raz [M:FASM]STRDPRDATD(nolign-1)
        [M:FASM]ENDDPRFLG(nolign-1)   = G_NON
        Raz [M:FASM]ENDDPRDATD(nolign-1)
        Raz [M:FASM]DPMD(nolign-1)
        [M:FASM]DURFLG(nolign-1)      = G_NON
        Raz [M:FASM]DPRDURD(nolign-1)
        [M:FASM]DPRRATFLGD(nolign-1)  = G_NON
        Raz [M:FASM]DPRRATD(nolign-1)
        [M:FASM]DPRRA2FLGD(nolign-1)  = G_NON
        Raz [M:FASM]DPRRAT2D(nolign-1)
        [M:FASM]RSDVALFLG(nolign-1)   = G_NON
        Raz [M:FASM]RSDVALD(nolign-1)
        [M:FASM]VEHFLG(nolign-1)      = G_NON
        Raz [M:FASM]CRBVEHCODD(nolign-1)
        [M:FASM]ALWFLG(nolign-1)      = G_NON
        [M:FASM]ALWCODD(nolign-1)     = 0
        [M:FASM]ACLCOEFLG(nolign-1)      = G_NON
        [M:FASM]ACLCOED(nolign-1)     = 0
        [M:FASM]PRATYPFLG(nolign-1)      = G_NON
        Raz [M:FASM]PRATYPD(nolign-1)
        [M:FASM]MTCDEVADJ(nolign-1)   = 0
        [M:FASM]PLNSTD(nolign-1)= func GLOBIENS.GET_NORME_PLAN( PCPY, [M:FASM]DPRPLND(nolign-1) )
        #FQ80039
        [M:FASM]DPRCUMFLG(nolign-1)  = [F:DEP]DPRCUMFLG      #*Fq-82531
        # FQ94929
        [M:FASM]DEFORCERAT(nolign-1)  = G_NON
        nolign += 1
    Next I
  Next

  [M:FASM]NBLIG1 = nolign-1

  # Conditionnement de TRTFLG en fonction de la date de changement de méthode
  Call COND_PLN_PARM([M:FASC]MVTDAT)

   #*Fq-87928  Local Integer  I_SUB :  I_SUB=find(G301SUB,[M:FASM]DPRPLND)
   #*Fq-87928   Local Integer  I_FIS :  I_FIS=find(G301FIS,[M:FASM]DPRPLND)  #FQ-73690
   #*Fq-87928     If (I_SUB > 0 and I_FIS > 0) and (func GLOFCYCPY.GET_SOC_PAYS([F:CNX]CPY)= "FR")
   #*Fq-87928       [M:FASM]TRTFLG(I_SUB-1)= G_NON
   #*Fq-87928       Diszo [M:FASM]TRTFLG(I_SUB-1)
   #*Fq-87928     Endif

  Call ACTION_BLOCK (ACB_AFFZO, "FASTRFCP", "NBLIG1") From GLOBIENS

End

#=========================
Subprog COND_PLN_PARM(PMVTDAT)
Value Date PMVTDAT

  # Conditionnement en fonction de la date d'effet
  # Un changement de méthode ne peut avoir eu que si la date d'effet se situe dans la période courante
  # ou dans l'exercice courant si pas de gestion de périodes.
  For nolign = 1 To [M:FASM]NBLIG1
    # FQ90828 test complété avec FLGSAL
    If [M:FASC]FLGOWN = G_NON and [M:FASC]FLGACG = G_NON and
&      [M:FASC]FLGACC = G_NON and [M:FASC]FLGSAL = G_NON
      [M:FASM]TRTFLG(nolign-1) = G_NON  : Diszo [M:FASM]TRTFLG(nolign-1)
      [M:FASM]MTCFLG(nolign-1) = G_NON
    Else
      [M:FASM]TRTFLG(nolign-1) = G_NON  : Actzo [M:FASM]TRTFLG(nolign-1)
      [M:FASM]MTCFLG(nolign-1) = G_NON
    Endif
    Gosub COND_LIGPLN_DISZO

    Affzo [M:FASM]TRTFLG(nolign-1) # FQ90828
  Next nolign

  Call ACTION_BLOCK (ACB_AFFZO, "FASTRFCP", "NBLIG1") From GLOBIENS

End

#====================
#
$COND_TABPLN_DISZO

  For nolign = 1 To [M:FASM]NBLIG1
        [M:FASM]TRTFLG(nolign-1)      = G_NON       : Diszo [M:FASM]TRTFLG(nolign-1)
        [M:FASM]STRFLG(nolign-1)      = G_NON       : Diszo [M:FASM]STRFLG(nolign-1)
        [M:FASM]STRDPRDATD(nolign-1)  = [0/0/0]     : Diszo [M:FASM]STRDPRDATD(nolign-1)
        [M:FASM]DPMD(nolign-1)        = ""          : Diszo [M:FASM]DPMD(nolign-1)
        [M:FASM]ENDDPRFLG(nolign-1)   = G_NON       : Diszo [M:FASM]ENDDPRFLG(nolign-1)
        [M:FASM]ENDDPRDATD(nolign-1)  = [0/0/0]     : Diszo [M:FASM]ENDDPRDATD(nolign-1)
        [M:FASM]DURFLG(nolign-1)      = G_NON       : Diszo [M:FASM]DURFLG(nolign-1)
        [M:FASM]DPRDURD(nolign-1)     = 0           : Diszo [M:FASM]DPRDURD(nolign-1)
        [M:FASM]DPRRATFLGD(nolign-1)  = G_NON       : Diszo [M:FASM]DPRRATFLGD(nolign-1)
        [M:FASM]DPRRATD(nolign-1)     = 0           : Diszo [M:FASM]DPRRATD(nolign-1)
        [M:FASM]DPRRA2FLGD(nolign-1)  = G_NON       : Diszo [M:FASM]DPRRA2FLGD(nolign-1)
        [M:FASM]DPRRAT2D(nolign-1)    = 0           : Diszo [M:FASM]DPRRAT2D(nolign-1)
        [M:FASM]RSDVALFLG(nolign-1)   = G_NON       : Diszo [M:FASM]RSDVALFLG(nolign-1)
        [M:FASM]RSDVALD(nolign-1)     = 0           : Diszo [M:FASM]RSDVALD(nolign-1)
        [M:FASM]VEHFLG(nolign-1)      = G_NON       : Diszo [M:FASM]VEHFLG(nolign-1)
        [M:FASM]CRBVEHCODD(nolign-1)  = ""          : Diszo [M:FASM]CRBVEHCODD(nolign-1)
        [M:FASM]ALWFLG(nolign-1)      = G_NON       : Diszo [M:FASM]ALWFLG(nolign-1)
        [M:FASM]ALWCODD(nolign-1)     = 0           : Diszo [M:FASM]ALWCODD(nolign-1)
        [M:FASM]ACLCOEFLG(nolign-1)    = G_NON      : Diszo [M:FASM]ACLCOEFLG(nolign-1)
        [M:FASM]ACLCOED(nolign-1)      = 0          : Diszo [M:FASM]ACLCOED(nolign-1)
        [M:FASM]PRATYPFLG(nolign-1)   = G_NON       : Diszo [M:FASM]PRATYPFLG(nolign-1)
        [M:FASM]PRATYPD(nolign-1)     = 0           : Diszo [M:FASM]PRATYPD(nolign-1)
        [M:FASM]MTCTIATYP(nolign-1)   = 0           : Diszo [M:FASM]MTCTIATYP(nolign-1)   # Issue 113764
        [M:FASM]MTCDEVADJ(nolign-1)  = 0            : Diszo [M:FASM]MTCDEVADJ(nolign-1)
  Next nolign
  Call ACTION_BLOCK (ACB_AFFZO, "FASTRFCP", "NBLIG1") From GLOBIENS
Return

#====================
#
$COND_TRTFLG_ACTZO

  Local Integer  I_FIS :  I_FIS=find(G301FIS,[M:FASM]DPRPLND)  #FQ-73690

  For nolign = 1 To [M:FASM]NBLIG1
    #*Fq-87928  If [M:FASM]TRTFLG(nolign-1) <> G301SUB or I_FIS=0  #FQ-73690
    [M:FASM]TRTFLG(nolign-1) = G_NON  : Actzo [M:FASM]TRTFLG(nolign-1)
    [M:FASM]MTCFLG(nolign-1) = G_NON
    #*Fq-87928  Endif
    Gosub COND_LIGPLN_DISZO
  Next nolign

  Call ACTION_BLOCK (ACB_AFFZO, "FASTRFCP", "NBLIG1") From GLOBIENS

Return

#====================
#
$COND_LIGPLN_DISZO

# FQ90828 attention : ce champ ()TRTFLG conditionne les autres
# et ne doit donc pas être traité avec. Le fonctionnement peut différer delon l'appel.
# FQ90828  [M:FASM]TRTFLG(nolign-1)  = G_NON   #FQ-66146
# FQ90828  Diszo [M:FASM]TRTFLG(nolign-1)     #FQ-66146
  Diszo [M:FASM]STRFLG(nolign-1)
  Diszo [M:FASM]STRDPRDATD(nolign-1)
  Diszo [M:FASM]DPMD(nolign-1)
  Diszo [M:FASM]ENDDPRFLG(nolign-1)    #Fq-54343
  Diszo [M:FASM]ENDDPRDATD(nolign-1)   #Fq-54343
  Diszo [M:FASM]DURFLG(nolign-1)
  Diszo [M:FASM]DPRDURD(nolign-1)
  Diszo [M:FASM]DPRRATFLGD(nolign-1)
  Diszo [M:FASM]DPRRATD(nolign-1)
  Diszo [M:FASM]DPRRA2FLGD(nolign-1)
  Diszo [M:FASM]DPRRAT2D(nolign-1)
  Diszo [M:FASM]RSDVALFLG(nolign-1)
  Diszo [M:FASM]RSDVALD(nolign-1)
  Diszo [M:FASM]VEHFLG(nolign-1)
  Diszo [M:FASM]CRBVEHCODD(nolign-1)
  Diszo [M:FASM]ALWFLG(nolign-1)
  Diszo [M:FASM]ALWCODD(nolign-1)
  Diszo [M:FASM]ACLCOEFLG(nolign-1)
  Diszo [M:FASM]ACLCOED(nolign-1)
  Diszo [M:FASM]PRATYPFLG(nolign-1)
  Diszo [M:FASM]PRATYPD(nolign-1)
  [M:FASM]ECTFLG(nolign-1) = G_NON
  Diszo [M:FASM]ECTFLG(nolign-1)
  [M:FASM]MTCTIATYP(nolign-1)   = 0  # Issue 113764
  Diszo [M:FASM]MTCTIATYP(nolign-1)  # Issue 113764
  [M:FASM]MTCDEVADJ(nolign-1) = 0
  Diszo [M:FASM]MTCDEVADJ(nolign-1)

Return

#====================
#
$COND_LIGPLN_ACTZO



  #FQ-73690
    #*Fq-87928 Local Integer  I_FIS :  I_FIS=find(G301FIS,[M:FASM]DPRPLND)
    #*Fq-87928  If I_FIS > 0
    #*Fq-87928   If ([M:FASM]DPRPLND(nolign-1) = G301SUB)  #FQ-66146
    #*Fq-87928      [M:FASM]TRTFLG(nolign-1)  = G_NON
    #*Fq-87928      Diszo  [M:FASM]TRTFLG(nolign-1)
    #*Fq-87928      Return
    #*Fq-87928   Endif  #FQ-73690
    #*Fq-87928  Endif
    #FQ-73690 Else
    Actzo [M:FASM]TRTFLG(nolign-1)     #FQ-66146
    Actzo [M:FASM]STRFLG(nolign-1)
    Actzo [M:FASM]DPMD(nolign-1)
    Actzo [M:FASM]DURFLG(nolign-1)
    Actzo [M:FASM]DPRRATFLGD(nolign-1)
    Actzo [M:FASM]DPRRA2FLGD(nolign-1)
    Actzo [M:FASM]DPRRAT2D(nolign-1)
    Actzo [M:FASM]RSDVALFLG(nolign-1)
    If ([M:FASM]DPRPLND(nolign-1) = G301FIS)
      Actzo [M:FASM]VEHFLG(nolign-1)
    Endif
    Actzo [M:FASM]ALWFLG(nolign-1)
    Actzo [M:FASM]ACLCOEFLG(nolign-1)
    Actzo [M:FASM]PRATYPFLG(nolign-1)
    If  [M:FASM]ECTFLG(nolign-1) = G_OUI
       Actzo [M:FASM]MTCDEVADJ(nolign-1)
    Endif
  #Endif    #FQ-66146

  If (   ( [M:FASM]DPMD(nolign-1)= G_DPMSA   and G_DPMSA    <> "" )  or
&        ( [M:FASM]DPMD(nolign-1)= G_DPMLV   and G_DPMLV    <> "" )  or
&        ( [M:FASM]DPMD(nolign-1)= G_DPMIT   and G_DPMIT    <> "" ) )
    # Si mode d'amort = "SA","LV" ou "IT" alors durée non saisissables
    [M:FASM]DURFLG(nolign-1)  = G_OUI
    [M:FASM]DPRDURD(nolign-1) = 0
    Diszo [M:FASM]DURFLG(nolign-1)
  Endif

  # Conditionnement du flag taux d'amortissement FQ77877 FQ84283 FQ84281 FQ105809
  If ( func TRTFAS.GET_MODE_DPM ([M:FASC]CPY2, [M:FASM]DPMD(nolign-1)) = GVML_TMLIBRE or
&      find( [M:FASM]DPMD(nolign-1),  G_DPMUL, G_DPMCA, G_DPMDA, G_DPMUD, G_DPMTD, G_DPMDE, G_DPMDF, G_DPMDX, G_DPMAL, G_DPMAD,
&                                     G_DPMDP, G_DPMDI, G_DPMRE, G_DPMFM, G_DPMLG, G_DPMPR, G_DPMSA, G_DPMHL,
&                                     G_DPMSY, G_DPMUO, G_DPMDV, G_DPMRA, G_DPMRX, G_DPMRD ) <> 0 )
    #-- Pour les modes libres, le taux est déterminé par le calcul.
    #-- Pour ces modes standards, le taux est déterminé par le calcul.
    [M:FASM]DPRRATD(nolign-1)     = 0        :  Diszo [M:FASM]DPRRATD(nolign-1)
    [M:FASM]DPRRATFLGD(nolign-1)  = G_NON    :  Diszo [M:FASM]DPRRATFLGD(nolign-1)
  Endif

  # Conditionnement du flag code Véhicule
  If ( [M:FASM]DPRPLND(nolign-1) <> G301FIS )
    [M:FASM]VEHFLG(nolign-1)  = G_NON
    [M:FASM]CRBVEHCODD(nolign-1)= ""
    Diszo [M:FASM]VEHFLG(nolign-1)
  Endif

 [M:FASM]MTCFLG(nolign-1) =
&   func TRTFASMTC.DETERM_MTCFLG
&    ( [M:FASM]DPMD(nolign-1),       [M:FASM]RSDFLG(nolign-1),     [M:FASM]DURFLG(nolign-1),
&      [M:FASM]DPRRATFLGD(nolign-1), [M:FASM]DPRRA2FLGD(nolign-1), [M:FASM]STRFLG(nolign-1),
&      [M:FASM]RSDVALFLG(nolign-1),  [M:FASM]ALWFLG(nolign-1),     [M:FASM]VEHFLG(nolign-1),
&      [M:FASM]PRATYPFLG(nolign-1),  [M:FASM]ACLCOEFLG(nolign-1),  nolign )


#Fq-73647 If G_MES = G_NON
If G_MES = G_NON or (([M:FASM]MTCTIATYP(nolign-1)= GVML_PEDBAM) & ([M:FASM]STRDPRDATD(nolign-1)< [M:FASM]FIYSTRDAT(nolign-1)))
  Gosub COND_GESTION_ECART From TRTFASMTC
Else
   [M:FASM]ECTFLG(nolign-1)= G_NON
   Diszo  [M:FASM]ECTFLG(nolign-1)
   [M:FASM]MTCDEVADJ(nolign-1)= 0
   Diszo  [M:FASM]MTCDEVADJ(nolign-1)
Endif


Return
#====================
#
#
$ASSOCIATIONS
    If [M:FASM]TRTFLG(nolign-1)  = G_OUI    #Fq-58042
       [M:FASM]DPMD(nolign-1)        = TBLDPM(nolign)

      If dim(GFXDNBERR) <= 0
         [M:FASM]DURFLG(nolign-1)      = G_NON
         [M:FASM]DPRRA2FLGD(nolign-1)  = G_NON
         [M:FASM]VEHFLG(nolign-1)      = G_NON
         [M:FASM]ALWFLG(nolign-1)      = G_NON
         [M:FASM]ACLCOEFLG(nolign-1)   = G_NON
         [M:FASM]PRATYPFLG(nolign-1)   = G_NON
      Endif

      If ( TBLDUR(nolign) <> 0 )
          [M:FASM]DURFLG(nolign-1)     = G_OUI
          [M:FASM]DPRDURD(nolign-1)     = TBLDUR(nolign)
      Endif

       [M:FASM]DPRRATFLGD(nolign-1)  = G_NON
       # Conditionnement du flag taux d'amortissement
       # FQ55960 FQ77877 FQ84283 FQ84281 FQ105809
       If ( func TRTFAS.GET_MODE_DPM ([M:FASC]CPY2, [M:FASM]DPMD(nolign-1)) = GVML_TMLIBRE or
&         find( [M:FASM]DPMD(nolign-1),  G_DPMUL, G_DPMCA, G_DPMDA, G_DPMUD, G_DPMTD, G_DPMDE, G_DPMDF, G_DPMDX, G_DPMHL,
&                                        G_DPMDP, G_DPMDI, G_DPMRE, G_DPMFM, G_DPMLG, G_DPMPR, G_DPMSA, G_DPMAL, G_DPMAD,
&                                        G_DPMSY, G_DPMUO, G_DPMDV, G_DPMRA, G_DPMDM, G_DPMRX, G_DPMRD ) <> 0 )
          #-- Pour les modes libres, le taux est déterminé par le calcul.
          #-- Pour ces modes standards, le taux est déterminé par le calcul.
          [M:FASM]DPRRATD(nolign-1)     = 0        :  Diszo [M:FASM]DPRRATD(nolign-1)
          [M:FASM]DPRRATFLGD(nolign-1)  = G_NON    :  Diszo [M:FASM]DPRRATFLGD(nolign-1)
        Else
           If ( TBLRAT(nolign) <> 0 )
               [M:FASM]DPRRATFLGD(nolign-1)  = G_OUI
               [M:FASM]DPRRATD(nolign-1)     = TBLRAT(nolign)
           Endif
        Endif

       If ( TBLRAT2(nolign) <> 0 )
        [M:FASM]DPRRA2FLGD(nolign-1) = G_OUI
       [M:FASM]DPRRAT2D(nolign-1)     = TBLRAT2(nolign)
        Endif

       If ( TBLVEH(nolign) <> "" )
        [M:FASM]VEHFLG(nolign-1)     = G_OUI
        [M:FASM]CRBVEHCODD(nolign-1)  = TBLVEH(nolign)
        Endif

       If ( TBLALW(nolign) <> 0 )
        [M:FASM]ALWFLG(nolign-1)     = G_OUI
        [M:FASM]ALWCODD(nolign-1)     = TBLALW(nolign)
        Endif

       If ( TBLACL(nolign) <> 0 )
        [M:FASM]ACLCOEFLG(nolign-1)     = G_OUI
         [M:FASM]ACLCOED(nolign-1)     = TBLACL(nolign)
        Endif

       If ( TBLPRA(nolign) <> 0 )
          [M:FASM]PRATYPFLG(nolign-1)     = G_OUI
         [M:FASM]PRATYPD(nolign-1)     = TBLPRA(nolign)
       Endif

       If ( [M:FASM]DPMD(nolign-1) = G_DPMUO )
         [M:FASM]DURFLG(nolign-1)     = G_OUI
         [M:FASM]DPRRATFLGD(nolign-1) = G_OUI
       Endif
   Endif # Fq-58042

  Call ACTION_BLOCK (ACB_AFFZO, "FASTRFCP", "NBLIG1") From GLOBIENS
Return
#====================
#
$ALIM_GAC_IAS_FROM_ACCCOD

  Raz [M:FASC]GACACND, [M:FASC]GACD
  If ( LGACACN <> 0 )
    [M:FASC]GACACND = LGACACN
    [M:FASC]GACD    = LGAC
  Endif
  Raz [M:FASC]IASACND, [M:FASC]IASACCD
  If ( GCNXPROIAS = G_OUI and LIASACN <> 0 )
    [M:FASC]IASACND = LIASACN
    [M:FASC]IASACCD = LIASACC
  Endif
  If (dim([M:FASC]ZGACD)    > 0 )   : Affzo [M:FASC]ZGACD     : Endif
  If (dim([M:FASC]ZIASACCD) > 0 )   : Affzo [M:FASC]ZIASACCD  : Endif
  If (dim([M:FASC]ZACCCODD) > 0 )   : Affzo [M:FASC]ZACCCODD  : Endif
  Affzo [M:FASC]GACACND, GACD, IASACND, IASACCD, ACCCODD
Return

#====================
#
$CTRL_BIEN

  Local Date WSTRDPRDAT
  LERRBCO = 0

  # FQ67615 Contrôle Low value assets
  # Le compte immobilisation du nouveau code comptable doit être du même type que le statut du bien
  If ( [M:FASC]FLGACC = G_OUI ) Then
    Local Integer L_LVATYP
    Call GET_LVATYP_FROM_GACCODE (GVML_COGIMMO, [M:FASC]ACCCODD, GGACIMMO, L_LVATYP) From GLOBIENS
    If ( (L_LVATYP = GVML_GLVALVA  and [F:MAS1]CMPSTA <> GVML_SBLVA)  or
&        (L_LVATYP = GVML_GLVAPOOL and [F:MAS1]CMPSTA <> GVML_SBPOOL) or
&        (([F:MAS1]CMPSTA = GVML_SBPOOL or [F:MAS1]CMPSTA = GVML_SBLVA) and L_LVATYP = GVML_GLVAAUC) or
&        ((L_LVATYP = GVML_GLVALVA or L_LVATYP = GVML_GLVAPOOL) and
&         [F:MAS1]CMPSTA <> GVML_SBPOOL and [F:MAS1]CMPSTA <> GVML_SBLVA) ) Then
      # Incohérence statut bien et indicateur compte
      LERRBCO = 880
      Return
    Endif
  Endif

  #------------------------
  # Ccontrôle de l'autorisation Société/site pour le(s) compte(s) PCG (et IAS)
  # Le contrôle n'est à faire que si le compte PCG et / ou IAS sont à modifier. Pas le cas si le code comptable
  # n'est pas déterminée par la famille.
  If [M:FASC]GACD<>""
    # FQ95579 + GFASLEDSOC
   Call CTRL_AUT_OBJ("GAC", [M:FASC]GACD, GFASLEDSOC, [F:MAS1]FCY, date$) From GLOBIENS
   If mkstat
     LERRBCO = 526 : #
     Return
   Endif
  Endif

  If ( [M:FASC]IASACCD<>"" ) and ( GCNXPROIAS = G_OUI )
      # FQ95579 + GFASLEDIAS
   Call CTRL_AUT_OBJ("GAC", [M:FASC]IASACCD, GFASLEDIAS, [F:MAS1]FCY, date$) From GLOBIENS
   If mkstat
     LERRBCO = 526 : #
     Return
   Endif
  Endif

  If ( [M:FASC]SALCLSDATD <> [0/0/0] ) and ( GCNXPROIAS = G_OUI )
     For I = 1 To [M:FASM]NBLIG1-1
        If [M:FASM]PLNSTD(I-1) = GVML_NPIAS
           If not ( func TRTFAS.IS_SUPEG_EXC ([F:MAS1]CPY,  [M:FASC]SALCLSDATD, [M:FASM]CNX(I-1)) )
              LERRBCO = 526 : Return
            Endif
        Endif
     Next
  Endif

  #------------------------
  If ( [M:FASC]FLGOWN = G_OUI and [F:MAS1]OWNTYP <> GVML_TDPROPR and
&      ( [F:MAS1]OWNTYP <> GVML_TDCBAIL or ([F:MAS1]OWNTYP = GVML_TDCBAIL and [F:MAS1]LEAREF <> "" ) ))
    # Si type passe à  "en propriété" cela est possible si
    # le type de détention du bien est "En crédit bail" et qu'aucun contrat n'est renseigné
    LERRBCO = 142
  Else
    #-----------------------------
    # Si la nature du compte comptable passe "En service" à  "Charge" ou de "En service" à  "En cours"
    If ( ( [F:MAS1]GACACN = GVML_NIENSER and [M:FASC]GACACND = GVML_NICHARG ) or
&        ( [F:MAS1]GACACN = GVML_NIENSER and [M:FASC]GACACND = GVML_NIENCOU ) )
      # Changement de nature interdit si un cumul d'amortissement existe sur l'un des plans du bien sauf IAS
      For I = 1 To [M:FASM]NBLIG1
        #FQ-66146 Read [DEP] DEP0=[F:MAS1]AASREF;[M:FASM]DPRPLND(nolign-1);[M:FASM]FIYENDDAT(nolign-1); [M:FASM]PERENDDAT(nolign-1)
        Read [DEP] DEP0=[F:MAS1]AASREF;[M:FASM]DPRPLND(I-1);[M:FASM]FIYENDDAT(I-1); [M:FASM]PERENDDAT(I-1)
        If fstat = 0
            WSTRDPRDAT = [F:DEP]STRDPRDAT
        Endif
        If ([M:FASM]DPRPLND(I-1) <> G301IAS) & ( (WSTRDPRDAT <  [F:DEP]FIYSTRDAT) ) ##FQ-66146 or  (WSTRDPRDAT <  [F:DEP]PERSTRDAT))
          LERRBCO = 72
          Break 1
        Endif
      Next I
      #------------------------------------
      If (LERRBCO = G_NON)
        # Si la nature du compte IAS passe "En service" à  "Charge" ou de "En service" à  "En cours"
        If ( ( [F:MAS1]IASACN = GVML_NIENSER and [M:FASC]IASACND = GVML_NICHARG ) or
&            ( [F:MAS1]IASACN = GVML_NIENSER and [M:FASC]IASACND = GVML_NIENCOU ) )
          # Changement de nature interdit si un cumul d'amortissement existe sur le plan IAS
          For I = 1 To [M:FASM]NBLIG1
            If ([M:FASM]DPRPLND(I-1) = G301IAS) & ( (WSTRDPRDAT <  [F:DEP]FIYSTRDAT) )#FQ-66146 or  (WSTRDPRDAT <  [F:DEP]PERSTRDAT))
              LERRBCO = 73
              Break 1
            Endif
          Next I
        Endif
      Endif
      #------------------------------------
    Endif
    #-----------------------------
  Endif
  #------------------------

Return


#====================
#
$ALIM_ENR_MAS1

  # [F:MAS1]  <- [M:FASC]
  # -------------------------------
  # Si mise en service, la date de mise en service hérite de la date du transfert
  If ( [F:MAS1]GACACN <> GVML_NIENSER and [M:FASC]GACACND = GVML_NIENSER )
    If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
  Endif

  If ([M:FASC]FLGOWN = G_OUI )
    [F:MAS1]OWNTYP =[M:FASC]OWNTYPD
    If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
  Endif
  If ([M:FASC]FLGSAL = G_OUI )
    [F:MAS1]SALCLSDAT =[M:FASC]SALCLSDATD
    [F:MAS1]EXTSALAMT =[M:FASC]EXTSALAMT  # Fq-85984
    If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
  Endif
  If ([M:FASC]FLGACG = G_OUI )
    [F:MAS1]ACGGRP =[M:FASC]ACGGRPD
    If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
  Endif
  If ([M:FASC]FLGACC = G_OUI )
    [F:MAS1]ACCCOD =[M:FASC]ACCCODD
    [F:MAS1]GAC    =[M:FASC]GACD
    [F:MAS1]GACACN =[M:FASC]GACACND
    [F:MAS1]IASACC =[M:FASC]IASACCD
    [F:MAS1]IASACN =[M:FASC]IASACND
    If   [M:FASC]ITSDATD <> [0/0/0]
       [F:MAS1]ITSDAT =[M:FASC]ITSDATD
    Endif
    If dim(ACTMODIF)>0 and ACTTYPGES = GTAMMAS : ACTMODIF=1 : Endif
  Endif

Return

#====================
#
$DEP_EXE_SUIV

Local Integer LCNX

  # Lecture informations exercice suivant

    # Lecture PERDEPREC pour l'exercice et la période suivante
    G_PERDPRCUM2 = 0
    G_PERENDDPE2 = 0
    Read [DEP] DEP0=[F:MAS1]AASREF;[M:FASM]DPRPLND(nolign-1);
&                   [M:FASM]FIYENDDAT2(nolign-1); [M:FASM]PERENDDAT2(nolign-1)
    If not (fstat)
      G_PERDPRCUM2 = [F:DEP]PERCLOCUM
      Call GET_CNX_FROM_PLAN ([F:DEP]CPY, [F:DEP]DPRPLN, LCNX) From GLOBIENS
      G_PERENDDPE2 = [F:DEP]PERENDDPE
    Endif

Return

#====================
#
$CALCUL_DEROG

  # Infbox "CALCUL_DEROG ==> G_TRF_PCG / G_TRF_IAS"

  # Changement d'imputation PCG ?
  If ( G_GAC   = [F:MAS1]GAC    )
    G_TRF_PCG = G_NON
  Else
    G_TRF_PCG = G_OUI
  Endif

  # Changement d'imputation IAS ?
  If ( G_IASACC  = [F:MAS1]IASACC  )
    G_TRF_IAS = G_NON
  Else
    G_TRF_IAS = G_OUI
  Endif

  #Fq-51185  Changement date classement bien détenu pour vente ? #   Fq-85984
  If ( G_SALCLSDAT = [F:MAS1]SALCLSDAT and G_EXTSALAMT = [F:MAS1]EXTSALAMT)
    # G_TRF_IAS = G_NON
    G_CFS = G_NON  : # FQ95754_2
  Else
    #G_TRF_IAS = G_OUI
    G_CFS = G_OUI  : # FQ95754_2
  Endif


  # Solde dérogatoire
  G_DERSLDEX = 0 :  G_DERSLDPC = 0 : G_DERSLDPS = 0

  #*V5 If (  GSTRDERDAT <> [0/0/0] and
  #*V5 &         [M:FASM]STRDPRDAT(G301FIS-1) >= GSTRDERDAT )

    # Calcul du solde dérogatoire au début de l'exercice courant
    G_DERSLDEX  = func TRTFAS.SOLDE_DEROG (
&                 [F:MAS1]AASREF, [M:FASM]FIYENDDAT(G301CPT-1), [M:FASM]PERENDDAT(G301CPT-1), 0)

    # Calcul du solde dérogatoire au début de période courante de l'exercice courant
    G_DERSLDPC  = func TRTFAS.SOLDE_DEROG (
&                [F:MAS1]AASREF, [M:FASM]FIYENDDAT(G301CPT-1), [M:FASM]PERENDDAT(G301CPT-1), G_OUI)

    # Calcul du solde dérogatoire au début de période courante de l'exercice suivant
    G_DERSLDPS  = func TRTFAS.SOLDE_DEROG (
&                [F:MAS1]AASREF, [M:FASM]FIYENDDAT2(G301CPT-1), [M:FASM]PERENDDAT2(G301CPT-1), G_OUI)
  #*V5  Endif

Return
#====================
#
$BCO_EVT

 Local Date    WFIYENDDAT
 Local Date    WPERENDDAT
 Local Date    WFIYSTRDAT
 Local Date    WPERSTRDAT
 Local Date    WDATREF
 Local Date    WCPTDATINT
 Local Integer RERROR
 Local Char    LMESSAGE(250)
 Local Integer RETOUR
 Local Integer PRET

 If !clalev([F:DEPZ]) : Local File DEPREC    [DEPZ] : Endif

  #- 1 ------------------------------------------------------
  If ( ( ACTTYPGES = GTAMMAS & dim(FLGSIM) > 0 and  FLGSIM = G_NON )  or  (ACTTYPGES = GTAMUNI) )
    # Génération des évènements de changement d'imputation comptable
    #Fq-58142    If ( (G_TRF_PCG = G_OUI and [F:DEP]DPRPLN <> G301IAS ) or
    #Fq-58142&        (G_TRF_IAS = G_OUI and [F:DEP]DPRPLN =  G301IAS )    )
    #Fq-58142 Même si uniquement changement de code comptable ou de famille comptable

    #FQ95754_2     If ( (G_TRF_PCG = G_OUI and [F:DEP]DPRPLN <> G301IAS ) or
    #FQ95754_2 &        (G_TRF_IAS = G_OUI and [F:DEP]DPRPLN =  G301IAS ) or
    #FQ95754_2 &        ( G_ACCCOD <> [F:MAS1]ACCCOD or G_ACGGRP <> [F:MAS1]ACGGRP ) )
    #FQ95754_2 Distinction changement d'imputation et classement pou vente
    #FQ95754_3 Ajout du cas d'annulation G_CNLCFS
    Local Integer B_GENFASCFS : B_GENFASCFS = 0
    If ((G_CFS = G_OUI or G_CNLCFS = G_OUI) and func GLOBIENS.GET_NORME_PLAN ([F:DEP]CPY,[F:DEP]DPRPLN)= GVML_NPIAS ) Then
      B_GENFASCFS =  1
    Endif
    Local Integer B_GENFASCHGIC : B_GENFASCHGIC = 0
    If ( (G_TRF_PCG = G_OUI and [F:DEP]DPRPLN <> G301IAS ) or
&        (G_TRF_IAS = G_OUI and [F:DEP]DPRPLN =  G301IAS ) or
&        ( G_ACCCOD <> [F:MAS1]ACCCOD or G_ACGGRP <> [F:MAS1]ACGGRP ) )
      B_GENFASCHGIC =  1
    Endif

    #- 2 ------------------------------------------------------
    If ( (B_GENFASCFS) or (B_GENFASCHGIC) ) Then

      If (  G_GACACN <> GVML_NIENSER and [F:MAS1]GACACN = GVML_NIENSER )
         WDATREF    = [F:MAS1]ITSDAT

         If [F:DEP]STRDPRDAT <= GCPYENDFIY
            WCPTDATINT =  max([F:MAS1]ITSDAT,GCPYSTRPER(LCNX))
         Else
            WCPTDATINT =  max([F:MAS1]ITSDAT,GCPYSTRPERS(LCNX))
         Endif
      Else
         If [F:DEP]STRDPRDAT <= GCPYENDFIY
            If  GCPYSTRPER(LCNX) <> [0/0/0]
               WDATREF    =  max([F:DEP]STRDPRDAT,GCPYSTRPER(LCNX))
               WCPTDATINT =  max([F:DEP]STRDPRDAT,GCPYSTRPER(LCNX))
            Else
               WDATREF    =  max([F:DEP]STRDPRDAT,GCPYSTRFIY(LCNX))
               WCPTDATINT =  max([F:DEP]STRDPRDAT,GCPYSTRFIY(LCNX))
            Endif
         Else
            If  GCPYSTRPERS(LCNX) <> [0/0/0]
               WDATREF    =  max([F:DEP]STRDPRDAT,GCPYSTRPERS(LCNX))
               WCPTDATINT =  max([F:DEP]STRDPRDAT,GCPYSTRPERS(LCNX))
            Else
               WDATREF    =  max([F:DEP]STRDPRDAT,GCPYSTRFIYS(LCNX))
               WCPTDATINT =  max([F:DEP]STRDPRDAT,GCPYSTRFIYS(LCNX))
            Endif
         Endif
         [F:DEP]MTCDPEDAT  =  WDATREF # ajouté car testé dans la réévaluation (MWA:27-02-2008)
      Endif
      #--------------------------------------------------------------------------------------------
      #-On utilise MVTDAT dans la génération des événements pour déterminer les imputations analytiques.
      Local Date SAV_MVTDAT : SAV_MVTDAT=[M:FASC]MVTDAT : [M:FASC]MVTDAT=GDATREF
      Global Decimal G_PSTIML      : G_PSTIML    = 0
      Global Decimal G_PSTIMLRVE   : G_PSTIMLRVE = 0
      Global Decimal G_PSTDPE      : G_PSTDPE    = 0
      Global Decimal G_PSTEXC      : G_PSTEXC    = 0
      Global Decimal G_PSTDER      : G_PSTDER    = 0
      Global Decimal G_PSTDERRVE   : G_PSTDERRVE = 0
      Global Decimal G_PSTRVETRF   : G_PSTRVETRF = 0
      Global Decimal G_PSTRVACRB   : G_PSTRVACRB = 0
      Global Integer EVTPRINC       # Type d'événement : G_OUI pour l'événement principal de la période d'effet
      Global Char    TIMSTPP

      #- 3 ------------------------------------------------------
      If (B_GENFASCHGIC) Then

        LCDINT= "FASCHGIC"+num$([F:DEP]DPRPLN)

        # Si evts de dépréciation non encore comptabilisés  ==>  globales alimentées
        # Sinon, si evts de dépréciation déjà comptabilisés ou pas d'évt de dépréciation ==>  globales à zéro
        EVTPRINC = G_OUI
        G_PSTDPE    = [F:DEPW]PSTDPE
        G_PSTEXC    = [F:DEPW]PSTEXC
        G_PSTDER    = [F:DEPW]PSTDER
        G_PSTDERRVE = [F:DEPW]PSTDERRVE
        G_PSTRVETRF = [F:DEPW]PSTRVETRF
        G_PSTRVACRB = [F:DEPW]PSTRVACRB
        Call GENER_EVE
&           (GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,WDATREF,WCPTDATINT,LCDRET)
&       From GENEVE
        [M:FASC]MVTDAT=SAV_MVTDAT
        If (LCDRET > 20 )
          RMES= mess(107,GML_MSGFAS,1)-LCDINT+"-"+num$(LCDRET)
          GOK = 0: Return
        Else
         If !clalev([F:E23]) : Local File EFASCHGIMP [F:E23]  : Endif
         Filter [F:E23] Where CPY=[F:MAS1]CPY & FCY=[F:MAS1]FCY & REF=[F:MAS1]AASREF & EVTDAT=WDATREF
         Read [F:E23] Last
         TIMSTPP = [F:E23]TIMSTP
         Filter [F:E23]
        Endif

        # Recherche des périodes de l'exercice courant et suivant pour lesquelles une comptabilisation
        # définitive a été réalisée. Pour chacune de ces périodes, on génère un évènement de transfert
        EVTPRINC=G_NON
        Filter [F:DEPZ] Where (CPY       = [F:MAS1]CPY    &
&                              AASREF    = [F:MAS1]AASREF &
&                              DPRPLN    = [F:DEP]DPRPLN  &
&                              (FIYENDDAT = GCPYENDFIY(LCNX) | FIYENDDAT = GCPYENDFIYS(LCNX))&
&                              FLGPST    = G_OUI)
        For [F:DEPZ]
         If [F:DEPZ]PERENDDAT<>GCPYENDPER(LCNX)
          [F:DEPW]=[F:DEPZ]
          G_PSTDPE    = [F:DEPW]PSTDPE
          G_PSTEXC    = [F:DEPW]PSTEXC
          G_PSTDER    = [F:DEPW]PSTDER
          G_PSTDERRVE = [F:DEPW]PSTDERRVE
          G_PSTRVETRF = [F:DEPW]PSTRVETRF
          G_PSTRVACRB = [F:DEPW]PSTRVACRB
          If G_PSTDPE<>0 | G_PSTEXC<>0 | G_PSTDER<>0 | G_PSTDERRVE<>0 | G_PSTRVETRF<>0 | G_PSTRVACRB<>0
           Call GENER_EVE
&              (GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,[F:DEPW]PERSTRDAT,
&               max([F:DEPW]PERSTRDAT,GCPYSTRPER(LCNX)),LCDRET)
&          From GENEVE
           [M:FASC]MVTDAT=SAV_MVTDAT
           If (LCDRET > 20 )
             RMES= mess(107,GML_MSGFAS,1)-LCDINT+"-"+num$(LCDRET)
             GOK = 0: Break
           Endif
          Endif
         Endif
        Next
        Filter [F:DEPZ]
      Endif
      #- 3 ------------------------------------------------------

      Local Decimal EXTSALAMT_SAV
      # Sauvegarde avant conversion eventuelle
      EXTSALAMT_SAV = [F:MAS1]EXTSALAMT
      #- 3 ------------------------------------------------------
      If (B_GENFASCFS) Then
        If ( G_CNLCFS <> G_OUI ) Then
          # Conversion si nécessaire du montant de sortie dans la devise du plan
          Local Char    LPLNCUR(GLONCUR)
          Local Integer LPLNCURTYP
          If !(clalev([F:CNX]))   : Local File CONTEXT   [CNX]   : Endif
          Read [CNX]CNX0=[F:MAS1]CPY;[F:DEP]CNX
          LPLNCUR    = [F:CNX]CUR
          LPLNCURTYP = [F:CNX]CURTYP

          If (LPLNCUR <> [F:MAS1]ACGCUR) Then
            Local Decimal MTDES
            Local Integer STAT
            Call CONVERT3([F:MAS1]ACGCUR,LPLNCUR, GDEVSOC(find([F:MAS1]CPY,GSOC)), LPLNCURTYP, date$,
&                         [F:MAS1]EXTSALAMT,MTDES,0,STAT) From CPTSUB
            Call GET_MNT_ARRONDI (MTDES, LPLNCUR, MTDES) From GLOBIENS
            [F:MAS1]EXTSALAMT = MTDES
          Endif

          # Evénement de classement pour vente
          LCDINT= "FASCFS"+num$([F:DEP]DPRPLN)
          G_PSTDPE    = [F:DEPW]PSTDPE
          G_PSTEXC    = [F:DEPW]PSTEXC
          G_PSTDER    = [F:DEPW]PSTDER
          G_PSTDERRVE = [F:DEPW]PSTDERRVE
          G_PSTRVETRF = [F:DEPW]PSTRVETRF
          G_PSTRVACRB = [F:DEPW]PSTRVACRB
          Call GENER_EVE
&             (GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,WDATREF,WCPTDATINT,LCDRET)
&         From GENEVE
          If (LCDRET > 20 )
            RMES= mess(107,GML_MSGFAS,1)-LCDINT+"-"+num$(LCDRET)
            GOK = 0: Return
          Endif
        Else
          # Annulation de classement pour vente
          Local Date EVTDAT
          If !clalev([F:EVT0]) : Local File EFASCFS [EVT0] : Endif
          If !clalev([F:EVT1]) : Local File EFASCFS [EVT1] : Endif
          LCDINT="FASCFS"+num$([F:DEP]DPRPLN)
          Filter [F:EVT0]  Where (CPY=[F:MAS1]CPY & EVTINT=LCDINT & DPRPLN=[F:DEP]DPRPLN & REF=[F:MAS1]AASREF & SNSEVE<>GVML_TEAACT)
          Read [F:EVT0]EVE0 Last
          If fstat=0
            If func GENEVE.EXISTE_EXTOURNE_EVE(LCDRET)=G_NON
              EVTDAT=[F:EVT0]EVTDAT
              Call EXTOURNE_EVE(GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,EVTDAT,LCDRET) From GENEVE
            Endif
          Endif
          Filter [EVT0]
        Endif
      Endif
      #- 3 ------------------------------------------------------

      # Restoration après éventuelle conversion
      [F:MAS1]EXTSALAMT = EXTSALAMT_SAV

    Endif
    #- 2 ------------------------------------------------------
  Endif
  #- 1 ------------------------------------------------------

Return

##########################################################################
##########################################################################

#RRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRR
# Points d'entrée objet de reprise
#RRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRRR
##################################
Subprog AV_NBOBJ_MFS

  If ([M:MFS0]NBOBJ > 1)
    Enable GSTAANU
    Enable 65
    GBOUT1=""
   Else
    Disable GSTAANU
    Disable 65
    GBOUT1=""
  Endif

End
#=====================================================================
# Traitement du tableau des infos par plan de l'objet de reprise.
#=====================================================================
$LIENS_MFS

 If ( [M:MFS0]NBPLN > 0 )
  For nolign = 1 To [M:MFS0]NBPLN
    If (G_TBLMAJ(1, nolign) = G_NON )   :  Diszo [M:MFS0]DPM(nolign-1) : Endif
    If (G_TBLMAJ(2, nolign) = G_NON )   :  Diszo [M:MFS0]DPRDUR(nolign-1) : Endif
    If (G_TBLMAJ(3, nolign) = G_NON )   :  Diszo [M:MFS0]DPRRATFLG(nolign-1), DPRRAT(nolign-1) : Endif
    If (G_TBLMAJ(4, nolign) = G_NON )   :  Diszo [M:MFS0]CRBVEHCOD(nolign-1) : Endif
    If (G_TBLMAJ(5, nolign) = G_NON )   :  Diszo [M:MFS0]ALWCOD(nolign-1) : Endif
  Next nolign
 Endif

Return

#==============================================================#
# Cette action est appelée pour chaque enregistrement lu dans  #
# la table temporaire par plan pour l'objet métier sur lequel  #
# on vient de cliquer.                                         #
# Alimenter ici les zones du tableau par plan spécifique à  l' #
# action                                                       #
# Table temporaire -> [F:TPF]   | Pour les BCO                 #
# Masque           -> [M:MFS0]  |                              #
# ligne courante   -> nolign    |                              #
#==============================================================#
$LOADPLN
  # Chargement du masque tableau des infos "spécifiques" par plan suite à  clique sur bien
  # Appelée pour chaque enreg de la table temporaire
  # Masque: [M:MFS0]   Table: [F:TPF]   Ligne courante: nolign
  Gosub LOADPLN From TRTFASMTC
Return

#==============================================================#
# Cette action est appelée pour chaque enregistrement de la    #
# table temporaire à  mettre à  jour.                          #
# Alimenter ici les zones spécifiques à  l'action de la table  #
# temporaire par plan à  partir des zones du tableau par plan  #
# Table temporaire -> [F:TPF]   | Pour les BCO                 #
# Masque           -> [M:MFS0]  |                              #
# ligne courante   -> nolign    |                              #
#==============================================================#
$SAVEPLN
  # MAJ table temporaire avec les infos "spécifiques" du masque tableau des infos par plan
  # Appelée pour chaque enreg de la table temporaire
  # Table: [F:TPF]   Masque: [M:MFS0]   Ligne courante: nolign
  Gosub SAVEPLN From TRTFASMTC
Return


################################################################################
# Traitement du masque de reprise de l'action massive                          #
# -----> MFASTRFCR                                                             #
################################################################################

#==============================================================#
# Actions de contrôle sur champ                                #
#==============================================================#
#
#==============================================================#
# Traitements appelés par Gosub, Call et Func                  #
#==============================================================#
################################################################################
# Traitement de gestion de la trace - informations particulières à  l'action    #
################################################################################

#==============================================================#
# Traitements appelés par Gosub, Call et Func                  #
#==============================================================#
#===============================
$ECR_ENT_BCO

If ACTSILENCE=G_OUI : Return : Endif

Local    Char    LINE(115)

  If ( FLGDET = G_OUI )
    # Entête (ligne 1)
    LINE = string$(115,"*")
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
    LINE =      left$( mess(182,GML_MSGFAS,1) + string$(20,' '), 20)+"!"
    LINE +=     left$( mess(213,GML_MSGFAS,1) + string$(15,' '), 15)+"!"
    LINE +=     left$( mess(214,GML_MSGFAS,1) + string$(15,' '), 15)+'!'
    LINE +=     left$( mess(215,GML_MSGFAS,1) + string$(20,' '), 20)+"!"
    LINE +=     left$( mess(243,GML_MSGFAS,1) + string$(20,' '), 20)+"!"
    LINE +=     left$( mess(245,GML_MSGFAS,1) + string$(20,' '), 20)+"!"
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
    LINE = string$(115,"*")
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
  Endif

Return

#===============================
$ECR_BCO_OLD

If ACTSILENCE=G_OUI : Return : Endif

Local    Char    LINE(115)
  #======================================
  If ( ACTTYPGES = GTAMMAS and FLGDET = G_OUI )
    # Anciennes valeurs (ligne 1)
    LINE  = left$( [F:MAS1]AASREF                      + string$(20,' '), 20)+"!"
    LINE += left$( mess([F:MAS1]OWNTYP,GML_TYPDETEN,1) + string$(15,' '), 15)+"!"
#    LINE += left$( [F:MAS1]SALCLSDAT                   + string$(15,' '), 15)+"!" : # FQ90392
    LINE += left$( [F:MAS1]ACGGRP                      + string$(15,' '), 15)+"!"
    LINE += left$( [F:MAS1]ACCCOD                      + string$(20,' '), 20)+"!"
    LINE += left$( [F:MAS1]GAC                         + string$(20,' '), 20)+"!"
    If ( GCNXPROIAS = G_OUI )
      LINE += left$( [F:MAS1]IASACC + string$(20,' '), 20)
    Else
      LINE += string$(20,' ')
    Endif
    Call ECR_TRACE([F:MAS1]CPY, GTRC_CRACTIO, LINE, 0,1) From TRACEABX3
  Endif
  #======================================
Return

#===============================
$ECR_BCO_NEW
Return

#===============================
$ECR_PLN_OLD
Return

#===============================
$ECR_PLN_NEW
Return


#==============================
$ECR_PARM_PLN

 If ACTSILENCE=G_OUI : Return : Endif

  If (IFIRST = G_OUI)
    IFIRST = G_NON
    # Entête méthode
    Call ECR_TRACE("", GTRC_PARAM, "",0,1) From TRACEABX3
    LINE = string$(115 ,'*')
    Call ECR_TRACE("", GTRC_PARAM, LINE,0,1) From TRACEABX3
    LINE  = left$( mess(184,GML_MSGFAS,1) + string$(12,' '),  12)  + "!"
    LINE += left$( mess(186,GML_MSGFAS,1) + string$(10,' '),  10)  + "!"
    LINE += left$( mess(185,GML_MSGFAS,1) + string$(5 ,' '),   5)  + "!"
    LINE += left$( mess(187,GML_MSGFAS,1) + string$(7 ,' '),   7)  + "!"
    LINE += left$( mess(188,GML_MSGFAS,1) + string$(10,' '),  10)  + "!"
    LINE += left$( mess(192,GML_MSGFAS,1) + string$(4 ,' '),   4)  + "!"
    LINE += left$( mess(193,GML_MSGFAS,1) + string$(27,' '),  27)  + "!"
    LINE += left$( mess(194,GML_MSGFAS,1) + string$(9 ,' '),   9)  + "!"
    LINE += left$( mess(196,GML_MSGFAS,1) + string$(5 ,' '),   5)  + "!"
    LINE += left$( mess(197,GML_MSGFAS,1) + string$(10 ,' '), 10)  + "!"
    LINE += left$( mess(185,GML_MSGFAS,1) + string$(5 ,' '),   5)
    Call ECR_TRACE("", GTRC_PARAM, LINE,0,1) From TRACEABX3
    LINE = string$(115 ,'*')
    Call ECR_TRACE("", GTRC_PARAM, LINE,0,1) From TRACEABX3
  Endif

  LINE = left$( mess([M:FASM]DPRPLND(I-1),GML_NPLAN,1) + string$(12,' '), 12) + "!"
  LINE += string$(10,' ') + "!"

  If ([M:FASM]DPMD(I-1) <>"" )
    LINE += left$( [M:FASM]DPMD(I-1) + string$(5,' '), 5) + "!"
  Else
    LINE += string$(5,' ') + "!"
  Endif
  If ([M:FASM]DURFLG(I-1) = G_OUI )
    LINE += left$( format$("N:3.3",[M:FASM]DPRDURD(I-1)) + string$(7,' '), 7) + "!"
  Else
    LINE += string$(7,' ') + "!"
  Endif
  If ([M:FASM]DPRRATFLGD(I-1) = G_OUI )
    LINE += left$( format$("N:3.6",[M:FASM]DPRRATD(I-1)) + string$(10,' '), 10) + "!"
   Else
    LINE += string$(10,' ') + "!"
  Endif
  If ([M:FASM]VEHFLG(I-1) = G_OUI)
    LINE += left$([M:FASM]CRBVEHCODD(I-1) + string$(4,' '), 4) + "!"
   Else
    LINE += string$(4,' ') + "!"
  Endif
  If ([M:FASM]ALWFLG(I-1) = G_OUI)
    LINE += left$( mess([M:FASM]ALWCODD(I-1),GML_REGLPART,1) + string$(27,' '), 27) + "!"
   Else
    LINE += string$(27,' ') + "!"
  Endif
  LINE += string$(9,' ') + "!"

  If ([M:FASM]MTCDEVADJ(I-1) > 0)
    LINE += left$( num$([M:FASM]MTCDEVADJ(I-1)) + string$(5,' '), 5) + "!"
   Else
    LINE += string$(5,' ') + "!"
  Endif
  LINE += string$(10,' ') + "!"

  Call ECR_TRACE("", GTRC_PARAM, LINE,0,1) From TRACEABX3

Return

#===============================
$GESTRACE

If ACTSILENCE=G_OUI : Return : Endif

Local Char LDES
Local Integer I, LERROR, ERROR
Local    Char    LINE(115)
Local Integer IFIRST


  Case TRTYP
    When 1         # Ouverture de la trace
      Call OUVRE_TRACE(mess(219,GML_MSGFAS,1),1) From TRACEABX3
    When 20        # Paramètres de l'action

      # Date d'effet, motif
      Call GET_TDIV_ALPHA ([M:FASC]MVTTYP, GML_MSGFAS, 'L', LDES, LERROR) From GLOBIENS
      LINE -=  left$( LDES + string$(5,' '), 30)
      Call ECR_TRACE("", GTRC_PARAM, LINE,0,1) From TRACEABX3

      # Type de détention
      LINE  = left$( mess(221,GML_MSGFAS,1) + string$(20,' '), 20) + ": "
      If ( [M:FASC]OWNTYPD <> 0 )
      LINE += left$( mess([M:FASC]OWNTYPD,GML_TYPDETEN,1) + string$(30,' '), 30)
      Endif
      Call ECR_TRACE("", GTRC_PARAM, LINE ,0,1) From TRACEABX3

      #Fq-51185 Date de classement détenu pour vente
      LINE  = left$( mess(687,GML_MSGFAS,1) + string$(43,' '), 43) + ": "
      If ( [M:FASC]SALCLSDATD <> [0/0/0] )
      LINE += left$(format$("DD2", [M:FASC]SALCLSDATD)   + string$(12,' '), 12)
      Endif
      Call ECR_TRACE("", GTRC_PARAM, LINE ,0,1) From TRACEABX3

      # Famille / Nature PCG / Compte PCG
      LINE  = left$( mess(222,GML_MSGFAS,1) + string$(20,' '), 20) + ": "
      LINE += left$( [M:FASC]ACGGRPD + string$(20,' '), 20)
      LINE += left$( mess(242,GML_MSGFAS,1) + string$(12,' '), 12) + ": "
      If ( [M:FASC]GACACND <> 0 )
        LINE += left$( mess([M:FASC]GACACND,GML_NATIMMO,1) + string$(20,' '), 20)
      Else
        LINE += string$(20,' ')
      Endif
      LINE += left$( mess(243,GML_MSGFAS,1) + string$(12,' '), 12) + ": "
      LINE += left$( [M:FASC]GACD    + string$(12,' '), 12)
      Call ECR_TRACE("", GTRC_PARAM, LINE,0,1) From TRACEABX3

      # Code comptable / Nature IAS / compte IAS
      LINE  = left$( mess(223,GML_MSGFAS,1) + string$(20,' '), 20) + ": "
      LINE += left$( [M:FASC]ACCCODD + string$(20,' '), 20)
      LINE += left$( mess(244,GML_MSGFAS,1) + string$(12,' '), 12) + ": "
      If ( [M:FASC]IASACND <> 0 )
        LINE += left$( mess([M:FASC]IASACND,GML_NATIMMO,1) + string$(20,' '), 20)
      Else
        LINE += string$(20,' ')
      Endif
      LINE += left$( mess(245,GML_MSGFAS,1) + string$(12,' '), 12) + ": "
      LINE += left$( [M:FASC]IASACCD + string$(12,' '), 12)
      Call ECR_TRACE("", GTRC_PARAM, LINE,0,1) From TRACEABX3


      IFIRST = G_OUI
      For I = 1 To [M:FASM]NBLIG1
        If ([M:FASM]MTCFLG(I-1) = G_OUI)
          Gosub ECR_PARM_PLN From TRTFASTRFC
        Endif
      Next I
    When Default
  Endcase
Return

######################################################################
# Sous-pro et routines communes
######################################################################

#=====================================================================
Subprog LAUNCH_ACT(PACTTYP)
Value Char PACTTYP

 Case PACTTYP
   When GTAMUNI
     Raz GPILOBJ
     Call DEFVAR From GLOBIMM
     Call INIVAR From GLOBIMM
     Call OBJET("FAS",GBIDC1,GBIDC2) From GOBJET
   When GTAMMAS
     Local Char PARAM(30)(1..5)
     Local Char VALEUR
     PARAM(1)=GTAMMAS            # Massif / unitaire
     PARAM(2)="FASTRFC"          # Nom de l'action métier
     PARAM(3)=num$(GVML_OMBIEN)  # Objet métier de référence
     PARAM(4)=num$(G_OUI)        # Mono société
     PARAM(5)=num$(G_OUI)       # Plan d'amortissement
     Call TRAITE_CHAR(VALEUR,PARAM,"","TRTFASTRFC","FASTRFCM",4,"") From GTRAITE
   When Default
  Endcase
End

#====================
#
$DEP_EXE_SUIV_TMP

  # Lecture informations exercice suivant
  Local Integer LCNX

    # Lecture PERDEPREC pour l'exercice et la période suivante
    G_PERDPRCUM2 = 0
    G_PERENDDPE2 = 0
    Read [DEP] DEP0=[F:TPF1]OBJREF; [F:TPF1]DPRPLN;
&                   [F:TPF1]FIYENDDAT2; [F:TPF1]PERENDDAT2
    If not (fstat)
      G_PERDPRCUM2 = [F:DEP]PERCLOCUM
      Call GET_CNX_FROM_PLAN ([F:DEP]CPY, [F:DEP]DPRPLN, LCNX) From GLOBIENS
        G_PERENDDPE2 = [F:DEP]PERENDDPE
    Endif

Return

#====================
#
$CALCUL_DEROG_TMP

  # Infbox "CALCUL_DEROG ==> G_TRF_PCG / G_TRF_IAS"

  # Changement d'imputation PCG ?
  If ( G_GAC     = [F:MAS1]GAC )
    G_TRF_PCG = G_NON
  Else
    G_TRF_PCG = G_OUI
  Endif

  # Changement d'imputation IAS ?
  If ( G_IASACC  = [F:MAS1]IASACC )
    G_TRF_IAS = G_NON
  Else
    G_TRF_IAS = G_OUI
  Endif

  #Fq-51185  Changement date classement bien détenu pour vente ?
  If ( G_SALCLSDAT = [F:MAS1]SALCLSDAT and G_EXTSALAMT = [F:MAS1]EXTSALAMT)  #Fq-85984
    # G_TRF_IAS = G_NON
    G_CFS = G_NON  : # FQ95754_2
  Else
    # G_TRF_IAS = G_OUI
    G_CFS = G_OUI  : # FQ95754_2
  Endif

  # Solde dérogatoire
  G_DERSLDEX = 0 :  G_DERSLDPC = 0 : G_DERSLDPS = 0

  # Calcul du solde dérogatoire au début de l'exercice courant
  G_DERSLDEX  = func TRTFAS.SOLDE_DEROG (
&               [F:MAS1]AASREF, [F:TPF1]FIYENDDAT3, [F:TPF1]PERENDDAT3, 0)

  # Calcul du solde dérogatoire au début de période courante de l'exercice courant
  G_DERSLDPC  = func TRTFAS.SOLDE_DEROG (
&               [F:MAS1]AASREF, [F:TPF1]FIYENDDAT3, [F:TPF1]PERENDDAT3, G_OUI)

  # Calcul du solde dérogatoire au début de période courante de l'exercice suivant
  G_DERSLDPS  = func TRTFAS.SOLDE_DEROG (
&               [F:MAS1]AASREF, [F:TPF1]FIYENDDAT2, [F:TPF1]PERENDDAT2, G_OUI)

Return
#--------------------------------------------------------------#
# Initialisation des variables contenant les dates de période  #
# et d'exercice des contextes gérés par la société             #
#--------------------------------------------------------------#
$SET_CPY_DAT
 # Création des variables si elles n'existent pas
 If dim(GCPYSTRFIY) <0  : Global Date    GCPYSTRFIY (1..G300MAX) : Endif
 If dim(GCPYENDFIY) <0  : Global Date    GCPYENDFIY (1..G300MAX) : Endif
 If dim(GCPYSTRPER) <0  : Global Date    GCPYSTRPER (1..G300MAX) : Endif
 If dim(GCPYENDPER) <0  : Global Date    GCPYENDPER (1..G300MAX) : Endif
 If dim(GCPYSTRFIYS)<0  : Global Date    GCPYSTRFIYS(1..G300MAX) : Endif
 If dim(GCPYENDFIYS)<0  : Global Date    GCPYENDFIYS(1..G300MAX) : Endif
 If dim(GCPYSTRPERS)<0  : Global Date    GCPYSTRPERS(1..G300MAX) : Endif
 If dim(GCPYENDPERS)<0  : Global Date    GCPYENDPERS(1..G300MAX) : Endif
 Local Integer RETOUR
 # Appel du sous-pro d'alimentation des dates
 Call GET_CPY_DAT_CS
&  (TRC_CPY,GCPYSTRFIY, GCPYENDFIY, GCPYSTRPER, GCPYENDPER,
&           GCPYSTRFIYS,GCPYENDFIYS,GCPYSTRPERS,GCPYENDPERS,
&           RETOUR)
&    From GLOBIENS
Return
#=====================================================================
Subprog DETERM_MTCTIADAT( PTIATYP, PFIYSTRDAT, PPERSTRDAT, PSTRDPRDAT, RDATE)
Value Integer    PTIATYP
Value    Date    PFIYSTRDAT, PPERSTRDAT, PSTRDPRDAT
Variable Date    RDATE

Case PTIATYP
   When GVML_PEDBAM : RDATE =  PSTRDPRDAT
   When GVML_PEDBEX : RDATE =  max(PSTRDPRDAT, PFIYSTRDAT)
   When GVML_PEDBPE : RDATE =  max(PSTRDPRDAT, PPERSTRDAT)
   When Default
Endcase

End
