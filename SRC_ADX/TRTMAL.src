Subprog C_DATEND(VALEUR)
Variable Date    VALEUR
If VALEUR<[M:DIA]DATSTR
#Période incorrecte
 GMESSAGE = mess(25,10702,1)
 mkstat = 2 : End
Endif
End

## DBA le 13/07/2004 : Sugg 22606 -> rendre paramètrable la banque pour
## la subrogation.
Subprog AM_ENAFLG(VALEUR)
Variable Integer VALEUR
If VALEUR<>1
 Actzo [M:DIA]BANRGL
Else
 Effzo [M:DIA]BANRGL
 Grizo [M:DIA]BANRGL
Endif
Affzo [M:DIA]BANRGL
End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran TRTMAL) 10/07/2013 14:55:20 (LANEG)
######################################################################################
Subprog C_BANRGL(VALEUR)
Variable Char    VALEUR()
If [M]CPY <>""
 If [F:BAN]CPY<> [M]CPY
  mkstat=2: GMESSAGE = [L]VALEUR-":"-mess(27,10704,1) #Cette banque n'est pas rattachée à la société saisie
 Endif
Else
 Call LECTURE ("BAN",VALEUR,"") From CONTOBJ
 Call LECTURE ("CPY",[F:BAN]CPY, "") From CONTOBJ
 If [F:CPY]LEG<>GCURLEG
   mkstat=2: GMESSAGE = [L]VALEUR-":"-mess(14,10712,1) : # Fiche inexistante pour la législation courante
 Endif
Endif
End


