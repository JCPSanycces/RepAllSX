#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion du masque TRTMAL
##** V7 : Waiting Time Mangement **#
##*********************************#
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTMAL","TRTMAL",4,"TRTMAL") From GTRAITE
End

#############################################
$ACTION
Case ACTION
 When "INIT"         : Gosub OUVRE
 When "CONTROLE"     : Gosub CONTROLE
 When "DEBUT"        : Gosub DEBUT From TRTAT :#81085
 When "EXEC"         : Gosub EXEC
 When "OK"           : FIN = 1 : GOK = 1
 When "END"          : FIN = 1
 When "SORTIE"       : Gosub SORTIE
 When "BOUTON"       : Gosub BOUTON From TRTAT :#81085
Endcase
Return

#############################################
$OUVRE
#86255
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Local Mask TRTMAL [DIA]
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","mal") From GMEMO
Call AFF_MEMO From DIVPAYE :#81085
Gosub OUVFIC
Gosub DECLARATION

#86255
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
If GLEGFIL<>"" & GCURLEG="" : GCURLEG = GLEGFIL : Endif

If dim([M:MAL0]REFNUM)>=0
 Raz [M:DIA]
 [M:DIA]MATDEB=[M:MAL0]REFNUM
 [M:DIA]MATFIN=[M:MAL0]REFNUM
 [M:DIA]DATSTR=[M:MAL0]DAT
 [M:DIA]DATEND=eomonth([M:MAL0]DAT)
 If dim([M:MAL0]LEG)>=0
  [M:DIA]LEG=[M:MAL0]LEG
  GCURLEG=[M:MAL0]LEG
 Endif
Endif

Return

#############################################
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#############################################
$OUVFIC
If clalev([F:MAL])=0  : Local File MALADIE    [MAL]  : Endif
If clalev([F:MAL1])=0 : Local File MALADIE    [MAL1] : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:BPA])=0  : Local File BPADDRESS  [BPA]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:ID])=0   : Local File EMPLOID    [ID]   : Endif
If clalev([F:AD])=0   : Local File EMPLOAD    [AD]   : Endif
If clalev([F:HRCTR])=0: Local File EMPLOCTR   [HRCTR]: Endif
If clalev([F:CTR1])=0 : Local File EMPLOCTR   [CTR1] : Endif
If clalev([F:HSP])=0  : Local File HISTOPAYE  [HSP]  : Endif
If clalev([F:ECT])=0  : Local File EMPCTR     [ECT]  : Endif
If clalev([F:RUB])=0  : Local File RUBRIQUE   [RUB]  : Endif
If clalev([F:VEP])=0  : Local File VALEMP     [VEP]  : Endif
If clalev([F:CNT])=0  : Local File CONTACT    [CNT]  : Endif
If clalev([F:AIN])=0  : Local File CONTACTCRM [AIN]  : Endif
If clalev([F:BAN])=0  : Local File BANK       [BAN]  : Endif
If clalev([F:ACC])=0  : Local File ACCES      [ACC]  : Endif
#LIPET - 2017-05-20 - START
##** V7 : Waiting Time Mangement **#
#If clalev([F:TIM])=0  : Local File TIMCOD     [TIM]  : Endif
#If clalev([F:TIP])=0  : Local File TIMEMP     [TIP]  : Endif
#If clalev([F:TP2])=0  : Local File TIMEMP     [TP2]  : Endif
#If clalev([F:TP3])=0  : Local File TIMEMP     [TP3]  : Endif
#If GTPS=1
# If clalev([F:TIG])=0  : Local File TIMREGUL  [TIG]  : Endif
# If clalev([F:TG2])=0  : Local File TIMREGUL  [TG2]  : Endif
#Endif
If clalev([F:TIM])=0  : Local File TIMCOD     [TIM]  : Endif
If clalev([F:TIP])=0  : Local File TIMEMP     [TIP]  : Endif
If clalev([F:TP2])=0  : Local File TIMEMP     [TP2]  : Endif
If clalev([F:TP3])=0  : Local File TIMEMP     [TP3]  : Endif
If GTPS=1
 If clalev([F:TIG])=0  : Local File TIMREGUL  [TIG]  : Endif
 If clalev([F:TG2])=0  : Local File TIMREGUL  [TG2]  : Endif
Endif
#LIPET - 2017-05-20 - END
#86255
If clalev([F:HRPOA])=0 : Local File POPULA     [HRPOA] : Endif
Return




#############################################
$DECLARATION
##** V7 : Waiting Time Mangement **#
Global Integer GLONTPS
GLONTPS=5
##**

Local Integer NBSAL, TYPEMPLOI, NBPAYE, I
Local Char    CRITFCY (250), CRITEMP (250), CRITTIP1 (250), CRITTIP2 (250)
Local Char    EVTMAL (GLONTPS)
Local Char    EVTMAT (GLONTPS)
Local Char    EVTPAT (GLONTPS)
Local Char    EVTPPRE (GLONTPS)    :#Patho prénatal = maternité
Local Char    EVTPPST (GLONTPS)    :#Patho postnatal = maladie
Local Char    EVTENCD (GLONTPS)    :#Enceinte dispensée de travail #92831

Local Date    DEBPAYE, FINPAYE, DEBARRET, FINARRET
Local Decimal MONTANT, TOTHRS

Local Char    RUBCOT (GLONRUB)(1..GNBRUBATT) :#Cotisations URSSAF
Local Integer NBCOT
Local Char    RUBHBASE (GLONRUB)(1..GNBRUBATT) :#Heures équivalentes
Local Integer NBHBASE
Local Char    RUBHTOT (GLONRUB)(1..GNBRUBATT) :#Heures réelles
Local Integer NBHTOT
Local Char    RUBNET (GLONRUB)(1..GNBRUBATT):#Salaire net
Local Integer NBNET
Local Char    RUBBRUT (GLONRUB)(1..GNBRUBATT):#Salaire brut
Local Integer NBBRUT
Local Char    RUBBRUTR (GLONRUB)(1..GNBRUBATT) :#Brut réétabli
Local Integer NBBRUTR

Local Char    RUBNETR (GLONRUB)(1..GNBRUBATT) :#Net réétabli
Local Integer NBNETR

Local Char    RUBABSMAL (GLONRUB)(1..GNBRUBATT) :#Absence de type maladie
Local Integer NBABSMAL
Local Char    RUBABSMAT (GLONRUB)(1..GNBRUBATT) :#Absence de type maternité
Local Integer NBABSMAT
Local Char    RUBABSPAT (GLONRUB)(1..GNBRUBATT) :#Absence de type paternité
Local Integer NBABSPAT
Local Char    RUBABSAT (GLONRUB)(1..GNBRUBATT) :#Absence de type AT
Local Integer NBABSAT
Local Char    RUBCP1 (GLONRUB)(1..GNBRUBATT)  :#Cotisations période 1
Local Integer NBCP1
Local Char    RUBCP2 (GLONRUB)(1..GNBRUBATT)  :#Cotisations période 2
Local Integer NBCP2

Local Char    RUBPLF (GLONRUB)(1..GNBRUBATT)  :#Plafond SS
Local Integer NBPLF
Local Char    RUBPLM (GLONRUB)(1..GNBRUBATT)  :#Plafond SS (spécial maladie)
Local Integer NBPLM

Local Char    RUBCHO (GLONRUB)(1..GNBRUBATT)  :#Chômage
Local Integer NBCHO
Local Char    RUBFER (GLONRUB)(1..GNBRUBATT)  :#Fermeture Site
Local Integer NBFER
Local Char    RUBCOP (GLONRUB)(1..GNBRUBATT)  :#Congés payés
Local Integer NBCOP
Local Char    RUBABA (GLONRUB)(1..GNBRUBATT)  :#Absences autorisées
Local Integer NBABA
Local Char    RUBSN (GLONRUB)(1..GNBRUBATT)  :#Service national
Local Integer NBSN
Local Char    RUBAUT (GLONRUB)(1..GNBRUBATT)  :#Autres
Local Integer NBAUT


Local Char    VALPAR (50)
Local Date    REPRISE, OLDDAT
Local Char    EVTCOUR (GLONTPS)
Local Date    LADATE, LADATPYR
Local Char    LISEVT(GLONTPS)
Local Integer NBVEP, IVEP
Local Char    TABEVT (GLONTPS) (0..99)
Local Integer NBREVT
Local Decimal NBJABS, NBJABSMOI
Return

#############################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

#############################################
$EXEC
# ouverture de la trace et écriture de l'en-tête
TIT=mess(82,10703,1) : # Extraction Attestation Maladie/Maternité
Call OUVRE_TRACE(TIT) From LECFIC
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

SYMBOLE = "MAL"+num$(date$)
Lock =SYMBOLE
If fstat
 GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
 GERR = 1 : SAI = 1
 Return
Endif

# Recup des codes évenements maladie et maternité
Call PARAM("","MALADIE",VALPAR)From ADOVAL
EVTMAL = VALPAR
Call PARAM("","MATERNITE",VALPAR)From ADOVAL
EVTMAT = VALPAR
Call PARAM("","PATERNITE",VALPAR)From ADOVAL
EVTPAT = VALPAR

Call PARAM("","PATHPREN",VALPAR)From ADOVAL
EVTPPRE= VALPAR
Call PARAM("","PATHPOST",VALPAR)From ADOVAL
EVTPPST= VALPAR
#92831
Call PARAM("","ENCEINTE",VALPAR)From ADOVAL
EVTENCD= VALPAR
#

If EVTMAL=""
 Call ECR_TRACE("MALADIE"- mess(1,10710,1),1) From GESECRAN
 GOK=0 : Return
Endif
If EVTMAT=""
 Call ECR_TRACE("MATERNITE"- mess(1,10710,1),1) From GESECRAN
 GOK=0 : Return
Endif
If EVTPAT=""
 Call ECR_TRACE("PATERNITE"- mess(1,10710,1),1) From GESECRAN
 GOK=0 : Return
Endif

If EVTPPRE=""
 Call ECR_TRACE("PATHOPREN"- mess(1,10710,1),1) From GESECRAN
 GOK=0 : Return
Endif
If EVTPPST=""
 Call ECR_TRACE("PATHOPOST"- mess(1,10710,1),1) From GESECRAN
 GOK=0 : Return
Endif
#92831
If EVTENCD=""
 Call ECR_TRACE("ENCEINTE"- mess(1,10710,1),1) From GESECRAN
 GOK=0 : Return
Endif
#

CRITFCY="1=1"
If [M:DIA]ALLCPY<>2  #société
 CRITFCY -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2  #site
 CRITFCY -= '& [F:FCY]FCY = "'+[M:DIA]FCY+'"'
Endif

CRITEMP="[F:ID]FLGPAY=2"
If [M:DIA]MATDEB<>"" #borne début matricule
 CRITEMP -= '& [F:ID]REFNUM>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITEMP -= '& [F:ID]REFNUM<="'+[M:DIA]MATFIN+'"'
Endif

##**82073
CRITEMP -= '& [F:HRCTR]CTRDAT<=['+num$([M:DIA]DATEND)+'] & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=['+num$([M:DIA]DATSTR)+'])'
#ADNGO - 2017-02-16 - START
##** V7 : Waiting time management **#
#CRITTIP1 = '(STRDAT>=['+num$([M:DIA]DATSTR)+'] & ENDDAT<=['+num$([M:DIA]DATEND)+']'
#CRITTIP1-= '& (TIM="'+EVTMAL+'" | TIM="'+EVTPPST+'") & NBRDAY>=0 & NBRHOU>=0 & TYPPGN=1)'
#
#CRITTIP2 = '(STRDAT>=['+num$([M:DIA]DATSTR)+'] & ENDDAT<=['+num$([M:DIA]DATEND)+']'
#CRITTIP2-= '& (TIM="'+EVTMAT+'" | TIM="'+EVTPAT+'" | TIM="'+EVTPPRE+'" | TIM="'+EVTENCD+'") & NBRDAY>=0 & NBRHOU>=0 & TYPPGN=1)' :#92831
##**
CRITTIP1 = '(STRDAT>=['+num$([M:DIA]DATSTR)+'] & ENDDAT<=['+num$([M:DIA]DATEND)+']'
CRITTIP1-= '& (TIM="'+EVTMAL+'" | TIM="'+EVTPPST+'") & NBRDAY>=0 & NBRHOU>=0 & TYPPGN=1)'

CRITTIP2 = '(STRDAT>=['+num$([M:DIA]DATSTR)+'] & ENDDAT<=['+num$([M:DIA]DATEND)+']'
CRITTIP2-= '& (TIM="'+EVTMAT+'" | TIM="'+EVTPAT+'" | TIM="'+EVTPPRE+'" | TIM="'+EVTENCD+'") & NBRDAY>=0 & NBRHOU>=0 & TYPPGN=1)' :#92831
#ADNGO - 2017-02-16 - END
NBSAL=0

#86255 : Ajout filtre sur HRPOA
#If [M:DIA]POP<>""
# Link [ECT] With
#&    [ID]ID0=[F:ECT]REFNUM,
#&    [HRCTR]CTR2=[F:ECT]REFNUM;[F:ECT]CTRNUM;[F:ECT]NBRCTR,
#&    [HRPOA]POA0(3)= [M:DIA]POP;[F:ECT]REFNUM;[F:ECT]CTRNUM,
#&    [FCY]FCY0=[F:HRCTR]ETRFCY
#& As [LECT]
#& Where evalue(CRITEMP) & evalue(CRITFCY) & [F:HRPOA]REFNUM<>""
#Else
# Link [ECT] With
#&    [ID]ID0=[F:ECT]REFNUM,
#&    [HRCTR]CTR2=[F:ECT]REFNUM;[F:ECT]CTRNUM;[F:ECT]NBRCTR,
#&    [FCY]FCY0=[F:HRCTR]ETRFCY
#& As [LECT]
#& Where evalue(CRITEMP) & evalue(CRITFCY)
#Endif

If [M:DIA]POP<>""
 Link [HRCTR] With
&    [ID]ID0=[F:HRCTR]REFNUM,
&    [FCY]FCY0=[F:HRCTR]ETRFCY,
&    [HRPOA]POA0= [M:DIA]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
& As [LECT]
& Where evalue(CRITEMP) & evalue(CRITFCY) & [F:HRPOA]REFNUM<>""
Else
 Link [ECT] With
&    [ID]ID0=[F:ECT]REFNUM,
&    [HRCTR]CTR2=[F:ECT]REFNUM;[F:ECT]CTRNUM;[F:ECT]NBRCTR,
&    [FCY]FCY0=[F:HRCTR]ETRFCY
& As [LECT]
& Where evalue(CRITEMP) & evalue(CRITFCY)
Endif

NBSAL=0 : GOK=1
Gosub RECUP_RUBRIQUE
If GOK>0
 Call DEBTRANS From GLOCK
 Gosub TR1
 If GOK<>0
  If NBSAL=0
    Call ECR_TRACE(mess(2,10703,1),0) From GESECRAN : # Aucun matricule à traiter
  Else
   #Opération réalisée
   Call ECR_TRACE(mess(3,10705,1),0) From GESECRAN
  Endif
 Else
  #Opération interrompue : Erreur lors de la transaction.
  Call ECR_TRACE(mess(4,10705,1),1) From GESECRAN
 Endif
Endif

Unlock =SYMBOLE
Call FERME_TRACE From LECFIC
Return

##**82073
$TR0
Local Integer NBTDAT, IP        :#IP = Incide Période
Local Date TSTRDAT (0..50)
Local Date TENDDAT (0..50)
Local Date LSTCTRDAT (0..50)    :#Voir si vraiment utile
IP=0
For [CTR1]CTR0 Where REFNUM=[CTR]REFNUM & CTRNUM=[CTR]CTRNUM & CTRDAT<=[M:DIA]DATEND & (XITDAT=[0/0/0] | XITDAT>=[M:DIA]DATSTR)
 LSTCTRDAT(IP)=[F:CTR1]CTRDAT    :#la dernière de la serie
 If TSTRDAT(IP)=[0/0/0]
  TSTRDAT(IP)=[F:CTR1]CTRDAT
 Endif
 If [F:CTR1]XITDAT<>[0/0/0]
  TENDDAT(IP)=[F:CTR1]XITDAT
  If [F:CTR1]XITFNL=2 : IP+=1 : Endif
 Else
  TENDDAT(IP)=[F:CTR1]CTRDAT
 Endif
Next
NBTDAT=IP
Return

#############################################
##** V7 : Waiting time management **#
$TR1
#ADNGO - 2017-02-16 - START
#Infbox 'Waiting time management ' : Return
#ADNGO - 2017-02-16 - END
GOK=1
Trbegin [MAL]
##**82073
 For [LECT]ECT0
   OK = 1
   Call CONTROLE([F:HRCTR]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,"",OK,0) From DIVPAYE
   If OK
  Gosub TR0
  For IP=0 To NBTDAT
   CRITDAT='CTRDAT>=['+num$([L]TSTRDAT(IP))+'] & CTRDAT<=['+num$([L]TENDDAT(IP))+']'
    ## Maladie(Boucle sur les temps puis sur les réguls temps)
    For [TIP]TIP1 Where evalue(CRITTIP1) & [F:TIP]REFNUM=[F:ID]REFNUM & [F:TIP]CTRNUM=[F:HRCTR]CTRNUM & evalue(CRITDAT)
     LADATE = [F:TIP]STRDAT
     LISEVT = [F:TIP]TIM
     Gosub PREM_ARRET
     If OK=1
      EVTCOUR  = [F:TIP]TIM : DEBARRET = [F:TIP]STRDAT : FINARRET = [F:TIP]ENDDAT : LADATPYR = [F:TIP]DATPYR
      #si existant et en état saisi je supprime et je recommence
      Read [MAL]MAL0=[F:ID]REFNUM;DEBARRET;[F:HRCTR]CTRNUM;1
      If fstat | (!fstat & [F:MAL]STAATT=1)
       Delete [MAL]MAL0=[F:ID]REFNUM;DEBARRET;[F:HRCTR]CTRNUM;1
       If fstat=1 | fstat>5
        GOK=-1 : GLOCK="MAL"-[F:ID]REFNUM-num$(DEBARRET)-[F:HRCTR]CTRNUM
        Break
       Endif
       Gosub CAL_NBJABS
       Gosub RECUP_INFOS
       If GOK<=0 : Break : Endif
      Endif
     Endif
    Next
    If GOK=0 : Goto AB_TR1
    Elsif GOK=-1 : Goto ROLL_TR1
    Endif
    If GTPS=1
     ##**82073
     For [TIG]TIG1 Where evalue(CRITTIP1) & [F:TIG]REFNUM=[F:ID]REFNUM & [F:TIG]CTRNUM=[F:HRCTR]CTRNUM & evalue(CRITDAT)
      LADATE = [F:TIG]STRDAT
      LISEVT = [F:TIG]TIM
      Gosub PREM_ARRET
      If OK=1
       EVTCOUR  = [F:TIG]TIM : DEBARRET = [F:TIG]STRDAT : FINARRET = [F:TIG]ENDDAT : LADATPYR = [F:TIG]DATPYR
       #si existant et en état saisi je supprime et je recommence
       Read [MAL]MAL0=[F:ID]REFNUM;DEBARRET;[F:HRCTR]CTRNUM;1
       If fstat | (!fstat & [F:MAL]STAATT=1)
        Delete [MAL]MAL0=[F:ID]REFNUM;DEBARRET;[F:HRCTR]CTRNUM;1
        If fstat=1 | fstat>5
         GOK=-1 : GLOCK="MAL"-[F:ID]REFNUM-num$(DEBARRET)-[F:HRCTR]CTRNUM
         Break
        Endif
        Gosub CAL_NBJABS
        Gosub RECUP_INFOS
        If GOK<=0 : Break : Endif
       Endif
      Endif
     Next
    Endif
    If GOK=0 : Goto AB_TR1
    Elsif GOK=-1 : Goto ROLL_TR1
    Endif

## Maternité Paternité(Boucle sur les temps puis sur les réguls temps)
    ##**82073
    For [TIP]TIP1 Where evalue(CRITTIP2) & [F:TIP]REFNUM=[F:ID]REFNUM & [F:TIP]CTRNUM=[F:HRCTR]CTRNUM & evalue(CRITDAT)
     LADATE = [F:TIP]STRDAT
     LISEVT = [F:TIP]TIM
     Gosub PREM_ARRET
     If OK=1
      EVTCOUR = [F:TIP]TIM : DEBARRET = [F:TIP]STRDAT : FINARRET = [F:TIP]ENDDAT: LADATPYR = [F:TIP]DATPYR
      #si existant et en état saisi je supprime et je recommence
      Read [MAL]MAL0=[F:ID]REFNUM;DEBARRET;[F:HRCTR]CTRNUM;1
      If fstat | (!fstat & [F:MAL]STAATT=1)
       Delete [MAL]MAL0=[F:ID]REFNUM;DEBARRET;[F:HRCTR]CTRNUM;1
       If fstat=1 | fstat>5
        GOK=-1 : GLOCK="MAL"-[F:ID]REFNUM-num$(DEBARRET)-[F:HRCTR]CTRNUM
        Break
       Endif
       Gosub CAL_NBJABS
       Gosub RECUP_INFOS
       If GOK<=0 : Break : Endif
      Endif
     Endif
    Next
    If GOK=0 : Goto AB_TR1
    Elsif GOK=-1 : Goto ROLL_TR1
    Endif

    If GTPS=1
     ##**82073
     For [TIG]TIG1 Where evalue(CRITTIP2) & [F:TIG]REFNUM=[F:ID]REFNUM & [F:TIG]CTRNUM=[F:HRCTR]CTRNUM & evalue(CRITDAT)
      LADATE = [F:TIG]STRDAT
      LISEVT = [F:TIG]TIM
      Gosub PREM_ARRET
      If OK=1
       EVTCOUR = [F:TIG]TIM : DEBARRET = [F:TIG]STRDAT : FINARRET = [F:TIG]ENDDAT: LADATPYR = [F:TIG]DATPYR
       #si existant et en état saisi je supprime et je recommence
       Read [MAL]MAL0=[F:ID]REFNUM;DEBARRET;[F:HRCTR]CTRNUM;1
       If fstat | (!fstat & [F:MAL]STAATT=1)
        Delete [MAL]MAL0=[F:ID]REFNUM;DEBARRET;[F:HRCTR]CTRNUM;1
        If fstat=1 | fstat>5
         GOK=-1 : GLOCK="MAL"-[F:ID]REFNUM-num$(DEBARRET)-[F:HRCTR]CTRNUM
         Break
        Endif
        Gosub CAL_NBJABS
        Gosub RECUP_INFOS
        If GOK<=0 : Break : Endif
       Endif
      Endif
     Next
     If GOK=0 : Goto AB_TR1
     Elsif GOK=-1 : Goto ROLL_TR1
     Endif
    Endif
  Next
 Endif
Next
Commit
Return

$PREM_ARRET
## Recherche si c'est le 1er jour de l'arrêt initial : Evènement précédent<>MAL initial ou <>MAT et PAT initial
Raz [TP2]
OK = 0
##**82073
Filter [TP2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & STRDAT<LADATE & evalue(CRITDAT)
Read [TP2]TIP1 Last
Filter [TP2]
If [F:TP2]TIM<>LISEVT | ([F:TP2]TIM=LISEVT & [F:TP2]TYPPGN=2) | ([F:TP2]TIM=LISEVT & [F:TP2]ENDDAT<LADATE-1)
 OK = 1
Endif
If GTPS=1
 Raz [F:TG2]
 ##**82073
 Filter [TG2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & STRDAT<LADATE & evalue(CRITDAT)
 Read [TG2]TIG1 Last
 Filter [TG2]
 If [F:TG2]ENDDAT>=[F:TP2]ENDDAT
  If [F:TG2]TIM<>LISEVT | [F:TG2]TYPPGN=2
   OK = 1
  Else
   OK = 0
  Endif
 Endif
Endif
Return

$CAL_NBJABS
NBJABS = 0 : NBJABSMOI = 0
Raz OLDDAT
# On relit l'enregistrement
##**82073
Filter [TP2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & STRDAT>=LADATE & ENDDAT<=[M:DIA]DATEND & TIM=LISEVT & evalue(CRITDAT)
For [TP2]TIP2
 If OLDDAT=[0/0/0] | [F:TP2]STRDAT=OLDDAT+1
  NBJABS += [F:TP2]ENDDAT-[F:TP2]STRDAT +1
  If LADATPYR=[F:TP2]DATPYR
   NBJABSMOI +=[F:TP2]ENDDAT-[F:TP2]STRDAT +1
  Endif
  OLDDAT = [F:TP2]ENDDAT
 Endif
Next
Filter [TP2]

Raz OLDDAT
If GTPS=1
 ##**82073
 Filter [TG2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & STRDAT>=LADATE & ENDDAT<=[M:DIA]DATEND & TIM=LISEVT & evalue(CRITDAT)
 For [TG2]
  If OLDDAT=[0/0/0] | [F:TG2]STRDAT=OLDDAT+1
   NBJABS +=[F:TG2]ENDDAT-[F:TG2]STRDAT +1
   If LADATPYR=[F:TG2]DATPYR
    NBJABSMOI +=[F:TG2]ENDDAT-[F:TG2]STRDAT +1
   Endif
   OLDDAT = [F:TG2]ENDDAT
  Endif
 Next
 Filter [TG2]
Endif
Return

#############################################
$RECUP_INFOS
GOK=1
Raz [F:MAL]
[F:MAL]CTRNUM = [F:HRCTR]CTRNUM

##**82073
[F:MAL]CTRDAT = LSTCTRDAT(IP)

[F:MAL]DAT    = DEBARRET
[F:MAL]STAATT = 1
[F:MAL]NUM    = 1
[F:MAL]FLGREG = 1 :#92831
[F:MAL]NBRDAYMON = NBJABSMOI
Gosub INFOS_EMP
If GOK>0
 Gosub INFOS_FCY
 # 55303 Point d'entrée UPDFCY
 GPOINT = "UPDFCY" : Gosub ENTREE From EXEFNC
Endif
If GOK>0
 If dim([F:MAL]CREDAT)>0 : [F:MAL]CREDAT = date$ : Endif
 If dim([F:MAL]CREUSR)>0 : [F:MAL]CREUSR = GUSER : Endif
 If dim([F:MAL]CRETIM)>0 : [F:MAL]CRETIM = time  : Endif
 Write [F:MAL]
 If fstat<>0
  GOK = 0 : Call FSTA("MAL") From GLOCK : Return
 Endif
 #Extraction des infos pour l'absence du ...
 If [F:MAL]RCVDAT<>[0/0/0]
  Call ECR_TRACE([F:ID]REFNUM-mess(11,10710,1)-num$([F:MAL]DAT)-"-"-num$([F:MAL]RCVDAT),0) From GESECRAN
 Else
  Call ECR_TRACE([F:ID]REFNUM-mess(11,10710,1)-num$([F:MAL]DAT),0) From GESECRAN
 Endif
Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

#############################################
$RECUP_RUBRIQUE
NBCOT=0
NBHBASE=0
NBHTOT=0
NBNET=0
NBBRUT=0
NBBRUTR=0
NBABSMAL=0
NBABSMAT=0
NBABSPAT=0
NBABSAT=0
NBCP1=0
NBCP2=0
NBCHO=0
NBFER=0
NBCOP=0
NBABA=0
NBSN=0
NBAUT=0
NBPLF=0
NBPLM=0
NBNETR=0

For [F:RUB]RUB0 Where LEG=GCURLEG & ATTHIL<>""
 Case [F:RUB]ATTHIL
  When "MAL" : NBABSMAL+=1 : RUBABSMAL(NBABSMAL)=[F:RUB]COD
  When "MAT" : NBABSMAT+=1 : RUBABSMAT(NBABSMAT)=[F:RUB]COD
  When "PAT" : NBABSPAT+=1 : RUBABSPAT(NBABSPAT)=[F:RUB]COD
  When "HTR" : NBHTOT+=1   : RUBHTOT(NBHTOT)    =[F:RUB]COD
  When "HTC" : NBHBASE+=1  : RUBHBASE(NBHBASE)  =[F:RUB]COD
  When "BRU" : NBBRUT+=1   : RUBBRUT(NBBRUT)    =[F:RUB]COD
  When "NET" : NBNET+=1    : RUBNET(NBNET)      =[F:RUB]COD
  When "BRR" : NBBRUTR+=1  : RUBBRUTR(NBBRUTR)  =[F:RUB]COD
  When "COT" : NBCOT+=1    : RUBCOT(NBCOT)      =[F:RUB]COD
  #Pour l'AT pas encore dispo.
  When "ACT" : NBABSAT+=1  : RUBABSAT(NBABSAT)  =[F:RUB]COD
  When "CP1" : NBCP1+=1    : RUBCP1(NBCP1)      =[F:RUB]COD
  When "CP2" : NBCP2+=1    : RUBCP2(NBCP2)      =[F:RUB]COD
  When "CHO" : NBCHO+=1    : RUBCHO(NBCHO)      =[F:RUB]COD
  When "FER" : NBFER+=1    : RUBFER(NBFER)      =[F:RUB]COD
  When "COP" : NBCOP+=1    : RUBCOP(NBCOP)      =[F:RUB]COD
  When "ABA" : NBABA+=1    : RUBABA(NBABA)      =[F:RUB]COD
  When "SN"  : NBSN+=1     : RUBSN (NBSN)       =[F:RUB]COD
  When "AUT" : NBAUT+=1    : RUBAUT(NBAUT)      =[F:RUB]COD
  When "PLF" : NBPLF+=1    : RUBPLF(NBPLF)      =[F:RUB]COD
  When "PLM" : NBPLM+=1    : RUBPLM(NBPLM)      =[F:RUB]COD
  When "NER" : NBNETR+=1   : RUBNETR(NBNETR)    =[F:RUB]COD
 Endcase
Next
If RUBABSMAL(1)=""
 #Aucune rubrique n'a été paramétrée pour l'absence MALADIE
 Call ECR_TRACE(mess(2,10710,1),-1) From GESECRAN
Endif
If RUBABSMAT(1)=""
 #Aucune rubrique n'a été paramétrée pour l'absence MATERNITE
 Call ECR_TRACE(mess(3,10710,1),-1) From GESECRAN
Endif
If RUBABSPAT(1)=""
 #Aucune rubrique n'a été paramétrée pour l'absence PATERNITE
 Call ECR_TRACE(mess(10,10710,1),-1) From GESECRAN
Endif
If RUBCOT(1)=""
 #Aucune rubrique n'a été paramétrée pour la cotisation URSSAF
 Call ECR_TRACE(mess(4,10710,1),-1) From GESECRAN
Endif
If RUBHTOT(1)=""
 #Aucune rubrique n'a été paramétrée pour le nb d'hrs réellement effectuées
 Call ECR_TRACE(mess(5,10710,1),-1) From GESECRAN
Else
 If RUBHBASE(1)="" : RUBHBASE(1)=RUBHTOT : Endif
Endif
If RUBHBASE(1)=""
 #Aucune rubrique n'a été paramétrée pour le nb d'hrs équivalentes à du temps complet
 Call ECR_TRACE(mess(6,10710,1),-1) From GESECRAN
Endif
If RUBBRUTR(1)=""
 #Aucune rubrique n'a été paramétrée pour le brut réétabli
 Call ECR_TRACE(mess(7,10710,1),-1) From GESECRAN
Endif
If RUBNET(1)=""
 #Aucune rubrique n'a été paramétrée pour le salaire net
 Call ECR_TRACE(mess(8,10710,1),-1) From GESECRAN
Endif
If RUBBRUT(1)=""
 #Aucune rubrique n'a été paramétrée pour le salaire brut
 Call ECR_TRACE(mess(12,10710,1),-1) From GESECRAN
Endif
If RUBABSAT(1)=""
 #Aucune rubrique n'a été paramétrée pour l'absence AT
 Call ECR_TRACE(mess(13,10710,1),-1) From GESECRAN
Endif
If RUBCP1(1)=""
 #Aucune rubrique n'a été paramétrée pour les cotisations de période 1
 Call ECR_TRACE(mess(14,10710,1)-"1",-1) From GESECRAN
Endif
If RUBCP2(1)=""
 #Aucune rubrique n'a été paramétrée pour les cotisations de période 2
 Call ECR_TRACE(mess(14,10710,1)-"2",-1) From GESECRAN
Endif

If RUBCHO(1)=""
 #Aucune rubrique n'a été paramétrée pour les absences chomages
 Call ECR_TRACE(mess(28,10710,1),-1) From GESECRAN
Endif
If RUBFER(1)=""
 #Aucune rubrique n'a été paramétrée pour les absences cause de fermeture de site
 Call ECR_TRACE(mess(29,10710,1),-1) From GESECRAN
Endif
If RUBCOP(1)=""
 #Aucune rubrique n'a été paramétrée pour les absences congés payés
 Call ECR_TRACE(mess(30,10710,1),-1) From GESECRAN
Endif
If RUBABA(1)=""
 #Aucune rubrique n'a été paramétrée pour les absences autorisées
 Call ECR_TRACE(mess(31,10710,1),-1) From GESECRAN
Endif

If RUBPLF(1)=""
 #Aucune rubrique n'a été paramétrée pour les plafonds mensuels de sécurité sociale
 Call ECR_TRACE(mess(42,10710,1)-'(PLF)',-1) From GESECRAN
Endif
If RUBPLM(1)=""
 #Aucune rubrique n'a été paramétrée pour les plafonds mensuels de sécurité sociale
 Call ECR_TRACE(mess(42,10710,1)-'(PLM)',-1) From GESECRAN
Endif

If RUBNETR(1)=""
 #Aucune rubrique n'a été paramétrée pour le net réétabli
 Call ECR_TRACE(mess(43,10710,1),-1) From GESECRAN
Endif
Return

######################################
$EVTW
# Appelé de TRTAT
Raz TABEVT : NBREVT=0
For [TIM]TIM0 Where ENAFLG=2 & CATTIM=1
 If NBREVT>99 : Break : Endif
 TABEVT(NBREVT)=[F:TIM]COD
 NBREVT+=1
Next
Return

#############################################
$INFOS_EMP
NBSAL+=1
[F:MAL]=[F:ID]
Filter [CTR1] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT<=[F:MAL]DAT
Read [CTR1]CTR1 Last
Filter [CTR1]
If !fstat
 [F:MAL]JOB    = [F:CTR1]JOB
 TYPEMPLOI     = [F:CTR1]TYPJOB
Else
 TYPEMPLOI=0
 #Erreur de lecture sur le fichier
 Call ECR_TRACE(mess(4,10707,1)-"EMPLOCTR",1) From GESECRAN
 GOK = 0 : Return
Endif

Gosub EVTW

#Dernier jour travaillé (Regul)
If GTPS=1
 Raz[F:TG2]
 ##**82073
 Filter [F:TG2] Where STRDAT<[F:MAL]DAT & REFNUM=[F:ID]REFNUM & find(TIM,TABEVT(0..NBREVT)) & NBRDAY>=0 & NBRHOU>=0
&&                    CTRNUM=[F:HRCTR]CTRNUM & evalue(CRITDAT)
 Read [F:TG2]TIG1 Last
 Filter [F:TG2]
  If !fstat & [F:TG2]ENDDAT>[F:MAL]LSTDAYDAT
  [F:MAL]LSTDAYDAT=[F:TG2]ENDDAT
 Endif
Endif

#Dernier jour travaillé
Raz[F:TP2]
##**82073
Filter [F:TP2] Where STRDAT<[F:MAL]DAT & REFNUM=[F:ID]REFNUM & find(TIM,TABEVT(0..NBREVT))
&&                   CTRNUM=[F:HRCTR]CTRNUM & evalue(CRITDAT)
Read [F:TP2]TIP1 Last
Filter [F:TP2]
If fstat=0
 If [F:TP2]ENDDAT>[F:MAL]LSTDAYDAT
  [F:MAL]LSTDAYDAT=[F:TP2]ENDDAT
 Endif
Else
 #Salarié sans planning, donc pas obligé de boucher les trous par du W !!!
 If dayn(DEBARRET-1)=7    :#Si ça donne un dimanche, on met le samedi précédent.
  [F:MAL]LSTDAYDAT=DEBARRET-2
 Else
  [F:MAL]LSTDAYDAT=DEBARRET-1
 Endif
 #Dernier jour travaillé précédent l'absence, non valide
 Call ECR_TRACE(mess(15,10710,1),1) From GESECRAN
Endif

#Motif de l'arret
If EVTCOUR=EVTMAL | EVTCOUR=EVTPPST
 [F:MAL]GRDABS=1 :#Maladie
Elsif EVTCOUR=EVTMAT  | EVTCOUR=EVTPPRE
 [F:MAL]GRDABS=2 :#Maternité
Elsif EVTCOUR=EVTPAT :#Paternité
 [F:MAL]GRDABS=3
Elsif EVTCOUR=EVTENCD :#92831
 [F:MAL]GRDABS=4      :#92831
Endif

Gosub JOUR_REPRISE
Gosub ETUDES_DROITS
If FINPAYE<>[0/0/0] : Gosub SALAIRES : Endif
Gosub SUBROGATION
Return

#############################################
$JOUR_REPRISE
#Jour de reprise (Régul)
Raz REPRISE
If GTPS=1
 Raz [F:TG2]
 ##**82073
 Filter [F:TG2] Where ((STRDAT<FINARRET & ENDDAT>FINARRET) | STRDAT>FINARRET) & REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & evalue(CRITDAT)
&&                    (TIM<>EVTMAL & TIM<>EVTMAT & TIM<>EVTPAT & TIM<>EVTPPRE & TIM<>EVTPPST & TIM<>EVTENCD) & NBRDAY>=0 & NBRHOU>=0 :#92831
 Read [F:TG2]TIG1 First
 Filter [F:TG2]
 If !fstat
  If [F:TG2]STRDAT<FINARRET & [F:TG2]ENDDAT>FINARRET
   [F:MAL]RCVDAT=FINARRET+1
  Else
   [F:MAL]RCVDAT=[F:TG2]STRDAT
  Endif
  REPRISE= [F:MAL]RCVDAT
  [F:MAL]RCVMIDWRK=1
  [F:MAL]FLGRCV=1
 Endif
Endif

#Jour de reprise (Temps)
Raz [F:TP2]
##**82073
Filter [F:TP2] Where ((STRDAT<FINARRET & ENDDAT>FINARRET) | STRDAT>FINARRET) & REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & evalue(CRITDAT)
&&                    (TIM<>EVTMAL & TIM<>EVTMAT & TIM<>EVTPAT & TIM<>EVTPPRE & TIM<>EVTPPST & TIM<>EVTENCD) :#92831
Read [F:TP2]TIP1 First
Filter [F:TP2]
If fstat=0
 If [F:TP2]STRDAT<FINARRET & [F:TP2]ENDDAT>FINARRET
  [F:MAL]RCVDAT=FINARRET+1
 Else
  [F:MAL]RCVDAT=[F:TP2]STRDAT
 Endif
 # si pas de régul ou date de reprise des temps<date de reprise de la régul, on prend la reprise des temps
 If REPRISE=[0/0/0] | REPRISE>[F:MAL]RCVDAT
  REPRISE= [F:MAL]RCVDAT
  [F:MAL]RCVMIDWRK=1
  [F:MAL]FLGRCV=1
 Else
  [F:MAL]RCVDAT=REPRISE
 Endif
Else
 [F:MAL]FLGRCV=2  :#Non repris à ce jour
Endif
Return

#############################################
$ETUDES_DROITS
#Recherche de la dernière paye précédent la début de l'absence.
# 57997 : Ajout critère '& FLGOUT<>2'
Filter [F:VEP] Where EMP=[F:ID]REFNUM  & ENDDAT<[F:MAL]DAT & CTRNUM=[F:HRCTR]CTRNUM & FLGOUT<>2
Read [VEP]VEP0 Last
Filter [F:VEP]
If fstat=0
 FINPAYE=[F:VEP]PYRDAT
Else
 #Dernière paye précédent l'absence, non valide
 Call ECR_TRACE([F:ID]REFNUM-mess(16,10710,1),1) From GESECRAN
 Return
Endif
If TYPEMPLOI>0
 If NBJABS>180 :#Plus de 6 mois d'arret
  #Cas particulier
  If TYPEMPLOI>4 & TYPEMPLOI<14      :#Type d'emploi="Travail à domicile, saisonnier, autre..."
   [F:MAL]FLGGEN=1 :  [F:MAL]FLGSPE=2 : NBVEP=12
  #Cas général
  Else
   [F:MAL]FLGGEN=2 :  [F:MAL]FLGSPE=1 : NBVEP=6
  Endif
 Else
  #Cas particulier
  If TYPEMPLOI>4 & TYPEMPLOI<14     :#Type d'emploi="Travail à domicile, saisonnier, autre..."
   [F:MAL]FLGGEN=1 :  [F:MAL]FLGSPE=2 : NBVEP=6
  #Cas général
  Else
   [F:MAL]FLGGEN=2 :  [F:MAL]FLGSPE=1 : NBVEP=3
  Endif
 Endif
Endif
IVEP=1
Filter [VEP] Where EMP=[F:ID]REFNUM & PYRDAT<=FINPAYE & CTRNUM=[F:HRCTR]CTRNUM & FLGOUT<>2 Order By PYRDAT Desc
For [VEP]
 If IVEP=1
  #Recherche première paie échue avant arrêt maladie sur 3, 6 ou 12 mois
  #Pas que la date de deb soit vide si pas d'autre paies...
  [F:MAL]STRDAT=[F:VEP]STRDAT
  [F:MAL]ENDDAT=[F:VEP]ENDDAT
  #88414
  If NBVEP=3
    DATEDEB=eomonth(addmonth([F:VEP]ENDDAT,-3))
  Elsif NBVEP=6
    DATEDEB=eomonth(addmonth([F:VEP]ENDDAT,-6))
  Elsif NBVEP=12
    DATEDEB=eomonth(addmonth([F:VEP]ENDDAT,-12))
  Endif
 Else
  If [F:VEP]ENDDAT>DATEDEB
    [F:MAL]STRDAT=[F:VEP]STRDAT
    DEBPAYE=[F:VEP]PYRDAT
  Else
    Break
  Endif
 Endif
# Elsif IVEP=NBVEP
#  #Recherche dernière paie échue avant arrêt maladie
#  [F:MAL]STRDAT=[F:VEP]STRDAT
#  DEBPAYE=[F:VEP]PYRDAT
#  Break
# Elsif IVEP<NBVEP
#  #Recherche dernière paie échue avant arrêt maladie
#  [F:MAL]STRDAT=[F:VEP]STRDAT
# Endif
 IVEP+=1
Next
Filter [VEP]
Return

#############################################
$SALAIRES
If TYPEMPLOI>0
 If TYPEMPLOI>4 & TYPEMPLOI<14
  NBVEP=12
 #Cas général
 Else
  NBVEP=3
 Endif
Endif
NBPAYE=0 : MONTANT=0

#88414
TOTHRS=0
#IVEP=1
#Filter [VEP] Where EMP=[F:ID]REFNUM & PYRDAT<=FINPAYE & CTRNUM=[F:HRCTR]CTRNUM & FLGOUT<>2 Order By PYRDAT Desc
#For [VEP]
# If IVEP=NBVEP
#  #Recherche dernière paie échue avant arrêt maladie
#  DEBPAYE=[F:VEP]PYRDAT
#  Break
# Endif
# IVEP+=1
#Next
#Filter [VEP]
NBMOIS=0
J=0
For [F:VEP]VEP0 Where EMP=[F:ID]REFNUM & PYRDAT>=DEBPAYE & PYRDAT<=FINPAYE & CTRNUM=[F:HRCTR]CTRNUM & FLGOUT<>2
  #88414
# If NBPAYE>11 : Break : Endif
# [F:MAL]STRDATPYR(NBPAYE)=[F:VEP]STRDAT
# [F:MAL]ENDDATPYR(NBPAYE)=[F:VEP]ENDDAT
  If NBPAYE=0
    [F:MAL]STRDATPYR(NBMOIS)=[F:VEP]STRDAT
    [F:MAL]ENDDATPYR(NBMOIS)=[F:VEP]ENDDAT
  Else
    #93388
    #If month(DATBULPRE)=month([F:VEP]ENDDAT)
    If month(DATBULPRE)=month([F:VEP]PYRDAT)
      [F:MAL]ENDDATPYR(NBMOIS)=[F:VEP]ENDDAT
    Else
      NBMOIS+=1
      [F:MAL]STRDATPYR(NBMOIS)=[F:VEP]STRDAT
      [F:MAL]ENDDATPYR(NBMOIS)=[F:VEP]ENDDAT
    Endif
  Endif
 #Calcul montant des cotisations sur la période
 For I=1 To NBCOT
  Read [F:HSP]HSP3 = [F:VEP]BUL;RUBCOT(I);1
  If fstat=0
   MONTANT+=[F:HSP]AMT
  Endif
  Read [F:HSP]HSP3 = [F:VEP]BUL;RUBCOT(I);7
  If fstat=0
   MONTANT+=[F:HSP]AMT
  Endif
 Next
 #Salaire
 #Si c'est de la maladie : mettre le salaire brut
 If EVTCOUR=EVTMAL | EVTCOUR=EVTPPST | EVTCOUR=EVTENCD :#92831
 #88414
  For I=1 To NBBRUT
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBBRUT(I);1
   If fstat=0
    #88414
    #[F:MAL]AMTPYR(NBPAYE)+=[F:HSP]AMT
    [F:MAL]AMTPYR(NBMOIS)+=[F:HSP]AMT
    #
   Endif
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBBRUT(I);7
   If fstat=0
    #88414
    #[F:MAL]AMTPYR(NBPAYE)+=[F:HSP]AMT
    [F:MAL]AMTPYR(NBMOIS)+=[F:HSP]AMT
    #
   Endif
  Next
  #Plafond SS (spécial maladie)
  For I=1 To NBPLM
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBPLM(I);1
   If fstat=0
    #88414
    #[F:MAL]PLFPYR(NBPAYE)+=[F:HSP]AMT
    [F:MAL]PLFPYR(NBMOIS)=max([F:MAL]PLFPYR(NBMOIS),[F:HSP]AMT)
   Endif
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBPLM(I);7
   If fstat=0
    #[F:MAL]PLFPYR(NBPAYE)+=[F:HSP]AMT
    [F:MAL]PLFPYR(NBMOIS)=max([F:MAL]PLFPYR(NBMOIS),[F:HSP]AMT)
   Endif
  Next
 Else
  #Si c'est de la maternité ou de la paternité : mettre le salaire Nets
  For I=1 To NBNET
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBNET(I);1
   If fstat=0
    #88414
    #[F:MAL]AMTPYR(NPAYE)+=[F:HSP]AMT
    [F:MAL]AMTPYR(NBMOIS)+=[F:HSP]AMT
    #
   Endif
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBNET(I);7
   If fstat=0
    #88414
    #[F:MAL]AMTPYR(NPAYE)+=[F:HSP]AMT
    [F:MAL]AMTPYR(NBMOIS)+=[F:HSP]AMT
    #
   Endif
  Next
  #Plafond SS
  For I=1 To NBPLF
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBPLF(I);1
   If fstat=0
   #88414
   #[F:MAL]PLFPYR(NBPAYE)+=[F:HSP]AMT
   [F:MAL]PLFPYR(NBMOIS)+=[F:HSP]AMT
   #
   Endif
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBPLF(I);7
   If fstat=0
   #88414
   #[F:MAL]PLFPYR(NBPAYE)+=[F:HSP]AMT
   [F:MAL]PLFPYR(NBMOIS)+=[F:HSP]AMT
   #
   Endif
  Next
 Endif

 For I=1 To NBCP1
  Read [F:HSP]HSP3 = [F:VEP]BUL;RUBCP1(I);1
  If fstat=0
   #88414
   #[F:MAL]CTBPYR1(NBPAYE)+=[F:HSP]AMT
   [F:MAL]CTBPYR1(NBMOIS)+=[F:HSP]AMT
   #
  Endif
  Read [F:HSP]HSP3 = [F:VEP]BUL;RUBCP1(I);7
  If fstat=0
   #88414
   #[F:MAL]CTBPYR1(NBPAYE)+=[F:HSP]AMT
   [F:MAL]CTBPYR1(NBMOIS)+=[F:HSP]AMT
   #
  Endif
 Next
 For I=1 To NBCP2
  Read [F:HSP]HSP3 = [F:VEP]BUL;RUBCP2(I);1
  If fstat=0
   #88414
   #[F:MAL]CTBPYR2(NBPAYE)+=[F:HSP]AMT
   [F:MAL]CTBPYR2(NBMOIS)+=[F:HSP]AMT
   #
  Endif
  Read [F:HSP]HSP3 = [F:VEP]BUL;RUBCP2(I);7
  If fstat=0
   #88414
   #[F:MAL]CTBPYR2(NBPAYE)+=[F:HSP]AMT
   [F:MAL]CTBPYR2(NBMOIS)+=[F:HSP]AMT
   #
  Endif
 Next
 #Total d'heures reellement travaillées
 For I=1 To NBHTOT
  Read [F:HSP]HSP3 = [F:VEP]BUL;RUBHTOT(I);1
  If fstat=0
   TOTHRS+=[F:HSP]AMT
  Endif
  Read [F:HSP]HSP3 = [F:VEP]BUL;RUBHTOT(I);7
  If fstat=0
   TOTHRS+=[F:HSP]AMT
  Endif
 Next

 Gosub RECH_ABS

#88414: changement de tous les NBPAYE en NBMOIS
 If [F:MAL]GRDABSPYR(NBMOIS)<>""
  #Heures reelles
  For I=1 To NBHTOT
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBHTOT(I);1
   If fstat=0
    [F:MAL]NBRHRSWRK(NBMOIS)+=[F:HSP]AMT
   Endif
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBHTOT(I);7
   If fstat=0
    [F:MAL]NBRHRSWRK(NBMOIS)+=[F:HSP]AMT
   Endif
  Next
  #Heures équivalentes
  For I=1 To NBHBASE
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBHBASE(I);1
   If fstat=0
    [F:MAL]NBRHRSOVR(NBMOIS)+=[F:HSP]AMT
   Endif
   Read [F:HSP]HSP3 = [F:VEP]BUL;RUBHBASE(I);7
   If fstat=0
    [F:MAL]NBRHRSOVR(NBMOIS)+=[F:HSP]AMT
   Endif
  Next
  If EVTCOUR=EVTMAL | EVTCOUR=EVTPPST | EVTCOUR=EVTENCD :#92831
   #Brut réétabli
   For I=1 To NBBRUTR
    Read [F:HSP]HSP3 = [F:VEP]BUL;RUBBRUTR(I);1
    If fstat=0
     [F:MAL]SALRES(NBMOIS)+=[F:HSP]AMT
    Endif
    Read [F:HSP]HSP3 = [F:VEP]BUL;RUBBRUTR(I);7
    If fstat=0
     [F:MAL]SALRES(NBMOIS)+=[F:HSP]AMT
    Endif
   Next
  Else
   #Net réétabli
   For I=1 To NBNETR
    Read [F:HSP]HSP3 = [F:VEP]BUL;RUBNETR(I);1
    If fstat=0
     [F:MAL]SALRES(NBMOIS)+=[F:HSP]AMT
    Endif
    Read [F:HSP]HSP3 = [F:VEP]BUL;RUBNETR(I);7
    If fstat=0
     [F:MAL]SALRES(NBMOIS)+=[F:HSP]AMT
    Endif
   Next
  Endif
 Endif
 NBPAYE=NBPAYE+1
 J+=1

 #88414
 DATBULPRE=[F:HSP]DAT
Next

If [F:MAL]FLGGEN=2
 If TOTHRS>200
  [F:MAL]NBRHRSGEN=2
 Else
  [F:MAL]AMTGEN=MONTANT
 Endif
Else
 If TOTHRS>800
  [F:MAL]NBRHRSSPE=2
 Else
  [F:MAL]AMTSPE=MONTANT
 Endif
Endif
#88414
#[F:MAL]NBRPYR=NBPAYE
[F:MAL]NBRPYR=NBMOIS+1
Return

#############################################
#Si absent durant le mois : Motif abs
$RECH_ABS
[F:MAL]GRDABSPYR(NBPAYE)=""
For I=1 To NBABSMAL
 Look [HSP]HSP3 = [F:VEP]BUL;RUBABSMAL(I);1
 If fstat=0
  [F:MAL]GRDABSPYR(NBPAYE)="MAL" : Break : Return
 Endif
Next
For I=1 To NBABSMAT
 Look [HSP]HSP3 = [F:VEP]BUL;RUBABSMAT(I);1
 If fstat=0
  [F:MAL]GRDABSPYR(NBPAYE)="MAT" : Break : Return
 Endif
Next
For I=1 To NBABSPAT
 Look [HSP]HSP3 = [F:VEP]BUL;RUBABSPAT(I);1
 If fstat=0
  [F:MAL]GRDABSPYR(NBPAYE)="PAT" : Break : Return
 Endif
Next
For I=1 To NBABSAT
 Look [HSP]HSP3 = [F:VEP]BUL;RUBABSAT(I);1
 If fstat=0
  [F:MAL]GRDABSPYR(NBPAYE)="AT" : Break : Return
 Endif
Next
For I=1 To NBCHO
 Look [HSP]HSP3 = [F:VEP]BUL;RUBCHO(I);1
 If fstat=0
  [F:MAL]GRDABSPYR(NBPAYE)="CHOM" : Break : Return
 Endif
Next
For I=1 To NBFER
 Look [HSP]HSP3 = [F:VEP]BUL;RUBFER(I);1
 If fstat=0
  [F:MAL]GRDABSPYR(NBPAYE)="FERM" : Break : Return
 Endif
Next
For I=1 To NBCOP
 Look [HSP]HSP3 = [F:VEP]BUL;RUBCOP(I);1
 If fstat=0
  [F:MAL]GRDABSPYR(NBPAYE)="COP" : Break : Return
 Endif
Next
For I=1 To NBABA
 Look [HSP]HSP3 = [F:VEP]BUL;RUBABA(I);1
 If fstat=0
  [F:MAL]GRDABSPYR(NBPAYE)="ABA" : Break : Return
 Endif
Next
For I=1 To NBSN
 Look [HSP]HSP3 = [F:VEP]BUL;RUBSN(I);1
 If fstat=0
  [F:MAL]GRDABSPYR(NBPAYE)="SN" : Break : Return
 Endif
Next
For I=1 To NBAUT
 Look [HSP]HSP3 = [F:VEP]BUL;RUBAUT(I);1
 If fstat=0
  [F:MAL]GRDABSPYR(NBPAYE)="AUT" : Break : Return
 Endif
Next
Return

#############################################
$SUBROGATION
[F:MAL]ENAFLG=[M:DIA]ENAFLG
If [M:DIA]ENAFLG<>1     :# 1=Non
 [F:MAL]STRSBG=[F:MAL]DAT
 [F:MAL]ENDSBG=FINARRET
 Read [F:BAN]BAN0=[M:DIA]BANRGL
 If fstat=0
  [F:MAL]FCYBID    = [F:BAN]BIDNUM
  [F:MAL]FCYBIDCRY = [F:BAN]CRY
  [F:MAL]FCYCUR    = [F:BAN]CUR
  [F:MAL]DESBID    = [F:BAN]PAB1
 Else
  #Banque de règlement non définie
  Call ECR_TRACE([F:FCY]FCY-mess(9,10710,1),1) From GESECRAN
  Return
 Endif
Endif
Return

#############################################
$INFOS_FCY
[F:MAL]FCY    = [F:FCY]FCY
[F:MAL]FCYCRN = [F:FCY]CRN
Read [CPY]CPY0=[F:FCY]LEGCPY
If fstat=0
 [F:MAL]CURSAL=[F:CPY]ACCCUR
 #86255
 [F:MAL]LEG = [F:CPY]LEG
Endif
Read [BPA]BPA0=3;[F:FCY]FCY;[F:FCY]BPAADD
If fstat= 0
 [F:MAL]FCYADDLIG(0)=[F:BPA]BPAADDLIG(0)
 [F:MAL]FCYADDLIG(1)=[F:BPA]BPAADDLIG(1)
 [F:MAL]FCYADDLIG(2)=[F:BPA]BPAADDLIG(2)
 [F:MAL]FCYPOSCOD=[F:BPA]POSCOD
 [F:MAL]FCYCTY=[F:BPA]CTY
 [F:MAL]FCYCRY=[F:BPA]CRY
 [F:MAL]FCYTEL=[F:BPA]TEL
Else
 Call ECR_TRACE(mess(4,10707,1)-"BPADDRESS",1) From GESECRAN
 GOK = 0 : Return
Endif
Read [F:CNT]CNT0=3;[F:FCY]FCY;[F:FCY]CNTNAM
If fstat=0
 Read [F:AIN]AIN0=[F:FCY]CNTNAM
 If !fstat
  [F:MAL]FCYRPB=[F:AIN]CNTLNA-[F:AIN]CNTFNA
  [F:MAL]FCYRPBFNC=[F:CNT]CNTFNC
  Read [BPA]BPA0=3;[F:FCY]FCY;[F:CNT]BPAADD
  If fstat= 0
   [F:MAL]PLCREF=[F:BPA]CTY
  Endif
 Elsif fstat <>5
  Call ECR_TRACE(mess(4,10707,1)-"CONTACTCRM",1) From GESECRAN
  GOK = 0 : Return
 Endif
Elsif fstat <>5
 Call ECR_TRACE(mess(4,10707,1)-"CONTACT",1) From GESECRAN
 GOK = 0 : Return
Endif
[F:MAL]DATREF=date$
Return

