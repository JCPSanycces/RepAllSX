#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################
#    TRAITEMENT D'IMPORT DES CONTRATS DE LOCATION-FINANCEMENT
#    MDR
#    Création le     :
#    Modification le :
# MDJ  24/02/2015  FQ105960  : Alimentation de certains champs (CUR, NBRMONPER, NBRWEKPER )
# CBO  16/05/2014  FQ99708   : erreur lors de l'utilisation du bouton "TEST"
# GLE  25/01/2012  FQ79404   : Pb import axes et échéancier
# GLE  25/06/2010  FQ65629   : Alimentation LEA4
################################################################################

$ACTION
Case ACTION
 When "IMP_OUVRE"       : Gosub IMP_OUVRE
 When "AP_IMPORT"       : Gosub AP_IMPORT
 When "IMPORT"          : Gosub IMPORT
 When "IMP_VERIF_CRE"   : Gosub IMP_VERIF_CRE
 When "IMP_ZONE"        : Gosub IMP_ZONE    #--> Exécuté pour chaque zone de l'enr
 When "IMP_TAB"         : Gosub IMP_TAB     #--> Exécuté pour chaque zone de l'enr (pour alimenter les tableaux)
 When "SET_IMPMOD"      : IMPMOD = 1
 When Default
Endcase
Return
#-------------------------------------------------------------------------------
$IMP_OUVRE
Local Integer L_I                          : # Indice pour boucle
Local Integer ADI_TAB                      : # Numéro de table diverse
Local Char    ADI_COD(GLONADI)             : # Code de table diverse
Local Char    ADI_DES(GLONDES)             : # Intitulé code de table diverse
Local Char    LPARM                        : # Valeur d'1 paramètre
Local Char    TEXTE(80)                    : # Texte de ATEXTRA
Local Integer TRANS                        : # Indicateur de transaction
Local Integer CREBPR                       : # Indicateur de création auto des bailleurs
Local Integer CREUSRFLDA(10)               : # Indicateur de création auto des codes zones libres

If !clalev([F:BPR]) : Local File BPARTNER[BPR]   : Endif  : # Table des tiers
If !clalev([F:ADI]) : Local File ATABDIV [ADI]   : Endif  : # Tables diverses
If !clalev([F:FCY]) : Local File FACILITY[FCY]   : Endif  : # Tables des sites
If !clalev([F:LEA]) : Local File LEASE[LEA]      : Endif  : # Contrats de location
If !clalev([F:LBB]) : Local File LEABILBOOK[LBB] : Endif  : # Echéanciers des contrats de location

For L_I=0 To 9
  Call PARAM("","CREUSRFL"+num$(L_I+1),LPARM) From ADOVAL         : # Codes zones libres
  CREUSRFLDA(L_I) = val(LPARM)
Next L_I

Return
#-------------------------------------------------------------------------------
$AP_IMPORT

# FQ99708
If [M:IMP2]TEST = G_OUI
  Return
Endif

Case IMPFIC
  When "LBB"
    Gosub IMP_ECHEANCIER
  When Default
Endcase

Return
#-------------------------------------------------------------------------------
$SAIMSK

#Affectation des masks
Case IMPFIC
 When "LEA"
  nolign = 1
  [M:LEA0] = [F:LEA]
  [M:LEA1] = [F:LEA]
  [M:LEA9] = [F:LEA]
  [M:LEA4] = [F:LEA] : # FQ65629
  [M:LEA2] = [F:LBB]
Endcase

Return
#-------------------------------------------------------------------------------
$IMPORT

Case IMPFIC
  When "LEA"
Gosub CREREF_AUTO
If TRANS & !GOK : OK=0 : Endif
  When Default
Endcase

Return
#-------------------------------------------------------------------------------
$IMP_ECHEANCIER

nolign = [M:LEA2]NBPER2+1
[M:LEA2]=[F:LBB]
  indice=nolign-1
  Gosub ALIM_NBRDAYPER    # FQ105960
[M:LEA2]NBPER2 = nolign
Return
#-------------------------------------------------------------------------------
$IMP_ZONE

# Pour alimenter les champs "date d'actualisation" et #FQ105960 "devise société" qui ne sont pas saisissables, on est
# obligé de traiter manuellement le transclasse quand le traitement passe sur une zone correspondant à un champ
# saisissable de l'écran correspondant

Case IMPZON
  When "LEAREF" : [M:LEA1]CUTDAT = [F:LEA]CUTDAT :   [M:LEA1]TRMLEADAT = [F:LEA]TRMLEADAT
  When "FCY"        : [M:LEA0]CUR      = GLOCALDEV        :   [M:LEA1]CUR       = GLOCALDEV
  When "USRFLDA1"   : [M:LEA9]USRFLDA1= [F:LEA]USRFLDA1
  When Default
Endcase

Return
#-------------------------------------------------------------------------------
$IMP_TAB

  Case IMPZON
    When "ENDPERDAT"  : Gosub ALIM_NBRDAYPER
    When Default
  Endcase

Return
#-------------------------------------------------------------------------------
$ALIM_NBRDAYPER


#<<<FQ105960 Alimentation des champs NBRDAYPER, NBRMONPER et NBRWEKPER si non renseignés dans le fichier à importer
Local Integer R_NB_MOIS
Local Integer R_NB_JOUR
Local Integer R_NB_WEEK

  If [F:LBB]NBRDAYPER > 0 and  [F:LBB]NBRMONPER > 0 and [F:LBB]NBRWEKPER > 0
    [M:LEA2]NBRDAYPER(indice)  = [F:LBB]NBRDAYPER
    [M:LEA2]NBRMONPER(indice)  = [F:LBB]NBRMONPER
    [M:LEA2]NBRWEKPER(indice)  = [F:LBB]NBRWEKPER
Else
    R_NB_JOUR = ([M:LEA2]ENDPERDAT(indice) - [M:LEA2]STRPERDAT(indice) + 1)
    Call GET_DATE_MONTH_DELTA ([M:LEA2]STRPERDAT(indice), [M:LEA2]ENDPERDAT(indice), R_NB_MOIS) From SUBLEA
    R_NB_WEEK = arr (R_NB_JOUR/7, 0)
    [M:LEA2]NBRDAYPER(indice)  =  R_NB_JOUR
    [M:LEA2]NBRMONPER(indice)  =  R_NB_MOIS
    [M:LEA2]NBRWEKPER(indice)  =  R_NB_WEEK
Endif
  #FQ105960>>>


#FQ105960 If [F:LBB]NBRDAYPER > 0
#FQ105960    [M:LEA2]NBRDAYPER(indice)  = [F:LBB]NBRDAYPER
#FQ105960 Else
#FQ105960    [M:LEA2]NBRDAYPER(indice) = ([M:LEA2]ENDPERDAT(indice) - [M:LEA2]STRPERDAT(indice) + 1)
#FQ105960 Endif

Return
#-------------------------------------------------------------------------------
$IMP_VERIF_CRE

Case GLEAAUTNUM
  When 1 : Gosub CTL_PRESENCE_REF : # Pas de numérotation automatique
  When 2 : Gosub CTL_ABSENCE_REF  : # Numérotation automatique obligatoire
Endcase

Return
#-------------------------------------------------------------------------------
$CTL_PRESENCE_REF

# La référence du contrat doit être renseignée
If [M:LEA0]LEAREF = ""
  Call ECR_TRACE(mess(55,7771,1)-"("+num$([M:LEA0]LEAREF)+")",1) From GESECRAN
  OK=0
Endif

Return
#-------------------------------------------------------------------------------
$CTL_ABSENCE_REF

# La référence du contrat  ne doit pas être présente
If [M:LEA0]LEAREF <> ""
  Call ECR_TRACE(mess(56,7771,1)-"("+num$([M:LEA0]LEAREF)+")",1) From GESECRAN
  OK=0
Endif

Return

#-------------------------------------------------------------------------------
$CREREF_AUTO

# Création automatique des éléments nécessaires au contrôle du contrat dans le référentiel
TRANS = 0

For L_I=0 To 9                                                                : # Codes zones libres
 # If CREUSRFLDA(L_I)=G_OUI & evalue("[F:LEA]USRFLDA"+num$(L_I+1)) <> "" : Gosub CREUSRFLDA_AUTO : Endif
  If  evalue("[F:LEA]USRFLDA"+num$(L_I+1)) <> "" : Gosub CREUSRFLDA_AUTO : Endif
  If TRANS & !GOK : Break : Endif
Next L_I

If TRANS & !GOK : Return : Endif
If TRANS & GOK : Commit : Endif

Return
#-------------------------------------------------------------------------------
$CREUSRFLDA_AUTO

# Création automatique codes zones libres
ADI_TAB=evalue("GABLIADI"+num$(L_I+1))
ADI_COD=evalue("[F:LEA]USRFLDA"+num$(L_I+1))
ADI_DES=GIMP(16+L_I)
Gosub TRT_TABDIV

Return
#-------------------------------------------------------------------------------
$TRT_TABDIV

# Création automatique codes en tables diverses
Look [F:ADI]CODE=ADI_TAB;ADI_COD
If fstat
  Gosub DEBTRANS
  Raz [F:ADI]
  [F:ADI]NUMTAB=ADI_TAB
  [F:ADI]CODE=ADI_COD
  [F:ADI]CREDAT=date$
  [F:ADI]CREUSR=GUSER
  Write [ADI]
  If fstat
    Call FSTA ("ADI") From GLOCK
    GOK=0 : Gosub AB_TR : Return
  Endif

  If ADI_DES = ""
    ADI_DES="XXX"-ADI_COD-"XXX"
  Endif
  Call MAJTEXTRA(ADI_DES,"ATABDIV","LNGDES",num$(ADI_TAB),ADI_COD) From ATEXTRA
  Call MAJTEXTRA(ADI_COD,"ATABDIV","SHODES",num$(ADI_TAB),ADI_COD) From ATEXTRA
  Call LECTEXTRA(TEXTE,"ATABTAB","LNGDES",num$(ADI_TAB),"") From ATEXTRA
  # Donnée de base créée automatiquement : Table diverse n CODE LNGDES
  Call ECR_TRACE(mess(57,7771,1)-TEXTE-ADI_COD-ADI_DES,0) From GESECRAN
Endif

Return
#-------------------------------------------------------------------------------
$DEBTRANS

If !TRANS
  Call DEBTRANS From GLOCK
  Trbegin [ADI]
  TRANS=1
Endif

Return
#-------------------------------------------------------------------------------
$AB_TR

Rollback

Return
