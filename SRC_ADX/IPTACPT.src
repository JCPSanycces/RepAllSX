#<AdxTL>@(#)7.0.0.0 $Revision$
#X3-39795  MDJ   Manage ORIGIN and ORICOD fields in GL Entry
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = "F"
Call SAISIE_CHAR(VALEUR,PARAM,"FIPTACPT","IPTACPT","") From GSAISIE
End
$ACTION

Case ACTION

 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "SETBOUT"      : Gosub SETBOUT
 When "ENR"          : FIN=1
 When "ABA"          : Gosub RELIT

 When "INIT"         : # Traitement de validation lié à l'action IPTACPTVAL
  Local Char DACVALDAT(10)
  Call PARAM("","DACVALDAT",DACVALDAT) From ADOVAL
  If DACVALDAT="1"
   If !clalev([M:DIA]) : Local Mask DATCPT [DIA] : Endif
   Raz [M:DIA] : BCRIT = ""
  Endif
  TMP = 1 : TRA = 1

 When "INIT_DIA"     : # Traitement de validation lié à l'action IPTACPTVAL
  [M:DIA]FCY=[M:IPT]SITE
  [M:DIA]DACDAT1 = 3
  [M:DIA]DAT2 = [M:IPT]DAT1

 When "EXEC"         : # Traitement de validation lié à l'action IPTACPTVAL
  Gosub DECLARE
  Gosub VALID

 When "SEL_TABLE"    : # Traitement de sélection lié à l'action IPTACPTSEL
  Case TABLE
   When "SELNUM" : Gosub SEL_NUM
  Endcase
 When "FIN_TABLE"    :  # Traitement de sélection lié à l'action IPTACPTSEL
  Case TABLE
   When "SELNUM" : Gosub F_SEL_NUM
  Endcase
Endcase
Return

$OUVRE
If clalev([F:DUD])=0  : Local File GACCDUDATE [DUD]  : Endif
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE]  : Endif
If clalev([F:DAE])=0  : Local File GACCENTRYD [DAE]  : Endif
If clalev([F:PYD])=0  : Local File PAYMENTD   [PYD]  : Endif
If clalev([F:DUD2])=0 : Local File GACCDUDATE [DUD2] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:PYH])=0  : Local File PAYMENTH   [PYH]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:TPY])=0  : Local File TABPAYTYP  [TPY]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
If clalev([F:CAC])=0  : Local File GACCCODE   [CAC]  : Endif
If clalev([F:PYD2])=0 : Local File PAYMENTD   [PYD2] : Endif
If clalev([F:PYO])=0  : Local File PAYORDER   [PYO]  : Endif
If clalev([F:AUS])=0  : Local File AUTILIS    [AUS]  : Endif
If clalev([F:DUD3])=0 : Local File GACCDUDATE [DUD3] : Endif
If clalev([F:MTB])=0  : Local File MTCBATCH   [MTB]  : Endif
If clalev([F:CDA])=0  : Local File GACCDENCOD [CDA] : Endif
Return

$DEBUT
Local Integer CLIFOU
Case PARAM(1)
 When "C"     : [L]CLIFOU = 1
 When "F"     : [L]CLIFOU = 2
 When Default : [L]CLIFOU = 1
Endcase
Raz [M:IPT]
[M:IPT]CLIFOU  = [L]CLIFOU
[M:IPT]SOCIETE = GDEFSOC
Gosub DECLARE
Return

$DECLARE
Local Integer CLECUR , MODIF
Local Integer STAT
Local Char    COUZON(10)
Local Char    SYMBOLE(30) , FILTRE(250) , FILTRE_SPE(250)
Local Char    NUMREG(GLONVCR) , DEVISE(GLONCUR), COA(GLONCOA)
Local Integer I , J , K
Local Decimal MONTANT , MONTIMP , SOLDECH
Local Decimal MONTCUR , MONTREG , MONTLOC
Local Decimal TOTFAC , TOTCOM
Local Integer LIGDUD
Local Char    COMTYP(3) , CODCPT(GLONCAC)
Local Integer MAXPAG
Local Char    TIT(80)
Local Char    CPTACPT(GLONGAC)
Local Decimal EXERCICE, PERIODE
Local Libelle TYPGEN,TYPANA
Local Char    OPT(GLONADP)
Local Integer CLIFOU
[L]CLIFOU = [M:IPT]CLIFOU
Case CLIFOU
 When 1
  TIT = mess(74,121,1)
  COMTYP = "*SO"
  If GMODU(5)=2 & clalev([F:SOH])=0 : Local File SORDER [SOH] : Endif
  If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
 When 2
  TIT = mess(98,121,1)
  COMTYP = "*PO"
  If GMODU(6)=2 & clalev([F:POH])=0 : Local File PORDER [POH] : Endif
  If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
Endcase
Call LECTURE("AUS",GUSER,"") From CONTOBJ
Local Char LLEVPAZ(3)
Call PARAMUTIL("NIVBONPAYE",LLEVPAZ,"","") From SUBAUS
MAXPAZ = val(LLEVPAZ)
Return

$SETBOUT
Raz CHMEN
If CLECUR & MODIF
 CHBOU +="E"
 CHBOU +="A"
Else
 CHMEN +="O"
Endif
CHBOU +="F"
Return

$APRES_MODIF
If find(COUZON,"SOCIETE","SITE","TIERS")
 Assign "[M]"+COUZON With CZ
 Gosub RELIT
Else
 MODIF = 1
Endif
Return

$ABORT
OK = 1
Return

$RELIT
Effzo [IPT]20
If [M]SOCIETE<>"" and [M]TIERS<>""
 Gosub LECTURE
Endif
If [M]NBLIG<>0
 CLECUR = 1
 Affzo [IPT]20
Else
 CLECUR = 0
Endif
MODIF = 0
Return

$LECTURE    # Jeu de piste pour retrouver ce qui est un acompte...
FILTRE = '[F:DUD]CPY="'+[M]SOCIETE+'"'
If [M]SITE<>""
 FILTRE -= '& [F:DUD]FCY="'+[M]SITE+'"'
Endif
FILTRE -= '& [F:DUD]BPRPAY="'+[M]TIERS+'"'
FILTRE -= '& [F:DUD]FLGCLE=1'
FILTRE -= '& [F:DUD]DUDSTA=2'
FILTRE -= '& [F:DUD]BPRTYP='+num$([L]CLIFOU)
Case [L]CLIFOU
 When 1 : FILTRE -= '& [F:DUD]SNS<0'
 When 2 : FILTRE -= '& [F:DUD]SNS>0'
Endcase
FILTRE -= '& left$([F:DAE]REFINTLIN,3)="PYH"'

#### Point d'entrée FILTRE_SPE #################
Raz FILTRE_SPE
GPOINT = "FILTRE" : Gosub ENTREE From EXEFNC
If vireblc(FILTRE_SPE,2)="" : FILTRE_SPE="1=1" : Endif

Read [CPY]CPY0 = [M]SOCIETE
Call LECMAINPLAN(1,[M]SOCIETE,[L]COA) From CPTDIV
Call SETCUR(1,[M]SOCIETE,[M]DEVLOC) From CPTDIV

If dim(GSDDMGT)>0 & [M]CLIFOU=1
 Call PARAM([M]SOCIETE,"SDDMGT",OPT) From ADOVAL
 GSDDMGT=val(OPT)
Endif

Link [DUD] With [DAE]DAE2=[F:DUD]ACCNUM , [HAE]HAE0=[F:DAE]TYP;[F:DAE]NUM
& As [LNK]
& Where evalue(FILTRE) & evalue(FILTRE_SPE)
& Order By [F:DAE]REFINTLIN;[F:HAE]TYP;[F:HAE]NUM
nolign = 0

For [LNK]
 If nolign>=dim([M]TYP)
  Call MESSAGE(mess(26,100,1)) From GESECRAN : # Tableau plein
  Break
 Endif
 SOLDECH = [F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR
 NUMREG = vireblc(right$([F:DAE]REFINTLIN,4),2)
 Read [PYH]PYH0 = NUMREG
 For [PYD]PYD0 Where NUM=NUMREG & (IPTTYP=0 or IPTTYP=[L]CLIFOU)
  Call LEC_CDA_LEG([F:CPY]LEG,[F:PYD]DENCOD) From CPTLEC
  Call LECTURE("CAC",[F:CDA]ACCBPR,"14~"+[L]COA) From CONTOBJ
  If [F:DUD]BPRTYP=1 : [L]CPTACPT = [F:CAC]ACC(2)
  Else               : [L]CPTACPT = [F:CAC]ACC(3)
  Endif
  If ([F:CDA]ACCBPR = "" & [F:DAE]ACC=[F:PYH]ACC) | ([F:DAE]ACC=[L]CPTACPT)
   MONTIMP = 0
   If [F:PYD]IPTTYP=[L]CLIFOU : # C'est une commande
    Read [DUD2]DUD1 = [F:PYD]DUDNUM;[F:PYD]DUDLIG
    If fstat=0 & [F:DUD2]DINAMT=0
     If [F:DUD2]CUR=[F:DUD]CUR
      DEVISE  = [F:DUD]CUR
      MONTANT = [F:DUD]AMTCUR
      MONTIMP = [F:PYD]AMTLIN
     Elsif [F:DUD2]CUR=[M]DEVLOC & [F:DUD]CUR=[F:PYH]CUR
      DEVISE  = [M]DEVLOC
      MONTANT = [F:DUD]AMTLOC
      MONTIMP = [F:PYD]AMTLIN
     Endif
    Endif
   Elsif [F:PYD]CURLIN=[F:DUD]CUR : # Le non imputé est dans la devise de règlement
    DEVISE   = [F:DUD]CUR
    MONTANT = [F:DUD]AMTCUR
    If SOLDECH>=[F:PYD]AMTLIN
     MONTIMP =[F:PYD]AMTLIN
    Else
     MONTIMP = SOLDECH
    Endif
   Endif

   SOLDECH -= MONTIMP
   If MONTIMP>0
    nolign += 1
    [M] = [F:HAE]
    [M] = [F:DAE]
    [M] = [F:DUD]
    If [F:PYD]IPTTYP=[L]CLIFOU
     [M]CDEFAC(nolign-1) = 1
    Else
     [M]CDEFAC(nolign-1) = 3
    Endif
    [M]OCDEFAC(nolign-1) = [M]CDEFAC(nolign-1)
    [M]NUMERO(nolign-1)  = [F:PYD]VCRNUM
    [M]BPRINV(nolign-1)  = [F:PYD]BPRINV
    [M]BPRSACINV(nolign-1) = [F:PYD]BPRSACINV
    [M]ONUMERO(nolign-1) = [M]NUMERO(nolign-1)
    [M]CUR(nolign-1)     = DEVISE
    [M]AMTCUR(nolign-1)  = MONTANT
    [M]AMTIPT(nolign-1)  = MONTIMP
    [M]OAMTIPT(nolign-1) = MONTIMP
    [M]REF(nolign-1)     = NUMREG
    [M]DUDNUM(nolign-1)  = [F:PYD]DUDNUM
    [M]DUDLIG(nolign-1)  = [F:PYD]DUDLIG
    [M]ECHNUM(nolign-1)  = [F:DUD]ACCNUM
    [M]ECHLIG(nolign-1)  = [F:DUD]DUDLIG
    [M]LIGREG(nolign-1)  = [F:PYD]LIN
    [M]VAT(nolign-1)     = [F:PYD]VATLIN
    If dim([M]UMRNUM)>0
     [M]UMRNUM(nolign-1) =  [F:PYH]UMRNUM
    Endif
   Endif
  Endif
 Next
Next
[M]NBLIG = nolign
Return

$VALID
[M:IPT]DAT2 = [M:DIA]DAT2
Default Mask [M:IPT]

Call OUVRE_TRACE(mess(106,121,1)) From LECFIC : # Imputations
Case [L]CLIFOU
 When 1 : Call ECR_TRACE(mess(74,121,1),0) From GESECRAN
 When 2 : Call ECR_TRACE(mess(98,121,1),0) From GESECRAN
Endcase

Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(2,45,1)-" : "-[M]SOCIETE,0) From GESECRAN
If [M]SITE<>"" :  Call ECR_TRACE(mess(3,45,1)-" : "-[M]SITE,0) From GESECRAN : Endif
Call ECR_TRACE(mess(1,672,1)-" : "-[M]TIERS,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

For I=0 To [M]NBLIG-1
 If [M]CDEFAC(I)<>[M]OCDEFAC(I) or [M]NUMERO(I)<>[M]ONUMERO(I) or [M]AMTIPT(I)<>[M]OAMTIPT(I)
  Gosub VALECH
 Endif
Next I

Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
If [M]NBLIG=1
 Case [M]CDEFAC(0)
  When 1 :  Call ECR_TRACE(mess(137,121,1)-mess(18,105,1)-[M]CUR(I-1)-":"-num$([M]AMTIPT(0))-[M]CUR,0) From GESECRAN
  When 2 :  Call ECR_TRACE(mess(136,121,1)-mess(18,105,1)-[M]CUR(I-1)-":"-num$([M]AMTIPT(0))-[M]CUR,0) From GESECRAN
 Endcase
Else

 # Le tableau est trié par type et devise
 Sorta NBLIG NBLIG Order By CDEFAC(indice), CUR(indice)
 For I=0 To [M]NBLIG-1
  If [M]CDEFAC(I)=1    # Commande
   If I>0 & [M]CUR(I)<>[M]CUR(I-1)
    Call ECR_TRACE(mess(137,121,1)-":"-num$(TOTCOM)-[M]CUR(I-1),0) From GESECRAN
    Raz TOTCOM
   Endif
   TOTCOM +=[M]AMTIPT(I)
   If I=[M]NBLIG-1
    Call ECR_TRACE(mess(137,121,1)-":"-num$(TOTCOM)-[M]CUR(I),0) From GESECRAN
    Raz TOTCOM
   Endif
  Elsif [M]CDEFAC(I)=2    # Facture
   If TOTCOM<>0
    Call ECR_TRACE(mess(137,121,1)-":"-num$(TOTCOM)-[M]CUR(I-1),0) From GESECRAN
    Raz TOTCOM
   Elsif I>0 & [M]CUR(I)<>[M]CUR(I-1)
    Call ECR_TRACE(mess(136,121,1)-":"-num$(TOTFAC)-[M]CUR(I-1),0) From GESECRAN
    Raz TOTFAC
   Endif
   TOTFAC +=[M]AMTIPT(I)
   If I=[M]NBLIG-1
    Call ECR_TRACE(mess(136,121,1)-":"-num$(TOTFAC)-[M]CUR(I),0) From GESECRAN
   Endif
  Elsif [M]CDEFAC(I)=3     # Non imputé
   If TOTFAC<>0
    Call ECR_TRACE(mess(136,121,1)-":"-num$(TOTFAC)-[M]CUR(I-1),0) From GESECRAN
    Raz TOTFAC
   Endif
  Endif
 Next I
Endif
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call FERME_TRACE From LECFIC
Return

$VALECH
Case [M]CDEFAC(I)
 When 1
  Call ECR_TRACE(mess(75,121,1)-[M]REF(I)-" ("-num$([M]AMTCUR(I))-[M]CUR(I)-") =>"-mess(1,864,1)-[M]NUMERO(I)-" ("-num$([M]AMTIPT(I))-[M]CUR(I)-")",0) From GESECRAN
#               Imputation règlement           commande
 When 2
  Call ECR_TRACE(mess(75,121,1)-[M]REF(I)-" ("-num$([M]AMTCUR(I))-[M]CUR(I)-") =>"-mess(2,864,1)-[M]VCRTYP(I)-[M]NUMERO(I)-" ("-num$([M]AMTIPT(I))-[M]CUR(I)-")",0) From GESECRAN
#               Imputation règlement           facture
 When 3
  If ![M]NEWACP(I) : Call ECR_TRACE(mess(76,121,1)-[M]REF(I),0) From GESECRAN : Endif
#              Désimputation règlement
Endcase

Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK = 1
Trbegin [DUD] , [DUD2] , [PYD]
 Gosub LECECH
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Case OCDEFAC(I)
  When 1
   Case CDEFAC(I)
    When 1 : Gosub COM_COM
    When 2 : Gosub COM_FAC
    When 3 : Gosub COM_NON
   Endcase
  When 3
   Case CDEFAC(I)
    When 1 : Gosub NON_COM
    When 2 : Gosub NON_FAC
   Endcase
 Endcase
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Unlock =SYMBOLE
Commit
Return

$LECECH
# Verrou du règlement
SYMBOLE = "PYH"+[M]REF(I)
Lock =SYMBOLE
If fstat=1
 GOK = -1 : GLOCK = "%"+SYMBOLE : Return
Endif
# Echéance du règlement
Readlock [DUD]DUD1 = [M]ECHNUM(I);[M]ECHLIG(I)
If fstat=1
 GOK = -1 : GLOCK = "$GACCDUDATE"-num$([M]ECHNUM(I))-num$([M]ECHLIG(I)) : Return
Elsif fstat
 GOK = 0 : Call RSTA("DUD",num$([M]ECHNUM(I))-num$([M]ECHLIG(I))) From GLOCK : Return
Endif
# Echéance imputée avec *SO/*PO (commande)
If [M]DUDNUM(I)<>0
 Readlock [DUD2]DUD1 = [M]DUDNUM(I);[M]DUDLIG(I)
 If fstat=1
  GOK = -1 : GLOCK = "$GACCDUDATE"-num$([M]DUDNUM(I))-num$([M]DUDLIG(I)) : Return
 Elsif fstat
  GOK = 0 : Call RSTA("DUD2",num$([M]DUDNUM(I))-num$([M]DUDLIG(I))) From GLOCK : Return
 Endif
Endif
# Ligne de règlement
Readlock [PYD]PYD0 = [M]REF(I);[M]LIGREG(I)
If fstat=1
 GOK = -1 : GLOCK = "$PAYMENTD"-[M]REF(I)-num$([M]LIGREG(I)) : Return
Elsif fstat
 GOK = 0 : Call RSTA("PYD",[M]REF(I)-num$([M]LIGREG(I))) From GLOCK : Return
Endif
If [F:PYD]VCRNUM<>""
 GOK = 0 : Call ECR_TRACE([M]REF(I)-"/"-num$([M]LIGREG(I))-":"-mess(208,121,1),1) From GESECRAN : Return
Endif
# En-tête de règlement
Readlock [PYH]PYH0 = [M]REF(I)
If fstat=1
 GOK = -1 : GLOCK = "$PAYMENTH"-[M]REF(I) : Return
Elsif fstat
 GOK = 0 : Call RSTA("PYH",[M]REF(I)) From GLOCK : Return
Endif
# Type de paiement
Call LECTURE("CPY",[F:PYH]CPY,"") From CONTOBJ
Call LEC_TPY_LEG([F:CPY]LEG,[F:PYH]PAYTYP) From CPTLEC
Return

########################################################
## Changement de commande ou de montant
########################################################
$COM_COM
Gosub COM_NON
If GOK<1 : Return : Endif
If [M]NUMERO(I)<>[M]ONUMERO(I)
 Gosub NON_COM
Endif
Return

########################################################
## Désimputation d'une commande
########################################################
$COM_NON
Local Integer II
Local Integer XLIGREG : XLIGREG = 0

# Désimputation des montants
If [M]AMTIPT(I)=[M]OAMTIPT(I)
 If !([M]OCDEFAC(I)=1 & [M]CDEFAC(I)=2)
  [F:DUD2]PAYCUR -= [F:PYD]PAYCURLIN
  [F:DUD2]PAYLOC -= [F:PYD]PAYLOCLIN
 Endif
Else
 If !([M]OCDEFAC(I)=1 & [M]CDEFAC(I)=2)
  If [M]NUMERO(I)<>[M]ONUMERO(I)
    MONTCUR = [M]AMTIPT(I)
  Else
    MONTCUR = [M]OAMTIPT(I)-[M]AMTIPT(I)
  Endif
  Gosub CAL_MNT
  If !GOK : Return : Endif
  [F:DUD2]PAYCUR -= MONTCUR
  [F:DUD2]PAYLOC -= MONTLOC
 Endif
Endif
Call SLDECH("DUD")From MODECHE
Call SETMAINREF([F:DUD]CPY,TYPGEN,TYPANA) From CPTDIV
Call GETPERSOC([F:DUD]CPY,TYPGEN,[F:DUD]DUDDAT,EXERCICE,PERIODE) From CPTSUB
[F:DUD]FIY = EXERCICE
[F:DUD]PER = PERIODE
Rewrite [DUD]
If fstat
 GOK = 0 : Call FSTA("DUD") From GLOCK : Return
Endif
Call HISTOECH("DUD",1,[M:IPT]DAT1)From MODECHE
If [F:DUD2]PAMTYP=1 & [F:DUD2]PAYCUR=0 & [F:DUD2]PAYLOC=0
 Call HISTOECH("DUD2",2,[M:IPT]DAT1)From MODECHE
 Delete [DUD2]
Else
 Call SLDECH("DUD2")From MODECHE
 Call SETMAINREF([F:DUD2]CPY,TYPGEN,TYPANA) From CPTDIV
 Call GETPERSOC([F:DUD2]CPY,TYPGEN,[F:DUD2]DUDDAT,EXERCICE,PERIODE) From CPTSUB
 [F:DUD2]FIY = EXERCICE
 [F:DUD2]PER = PERIODE
 Rewrite [DUD2]
 Call HISTOECH("DUD2",1,[M:IPT]DAT1)From MODECHE
Endif
If fstat
 GOK = 0 : Call FSTA("DUD2") From GLOCK : Return
Endif

# Mise à jour ligne de règlement
If [M]AMTIPT(I)<[M]OAMTIPT(I)
 Filter [PYD2] Where NUM=[M]REF(I)
 Read [PYD2]PYD0 Last
 Filter [PYD2]
 LIGDUD = [F:PYD2]LIN
 [F:PYD2] = [F:PYD]
 [F:PYD2]LIN = LIGDUD+1

 MONTCUR = [M]OAMTIPT(I)-[M]AMTIPT(I)
 Gosub CAL_MNT
 If !GOK : Return : Endif
 [F:PYD2]AMTLIN    = MONTCUR
 [F:PYD2]AMTLIN2   = MONTREG
 [F:PYD2]PAYCURLIN = MONTCUR
 [F:PYD2]PAYLOCLIN = MONTLOC
 If !([M]NUMERO(I)<>[M]ONUMERO(I))
  [F:PYD2]VCRTYP = ""
  [F:PYD2]VCRNUM = ""
  [F:PYD2]IPTTYP = 0
  [F:PYD2]DUDNUM = 0
  [F:PYD2]DUDLIG = 0
 Endif
 Write [PYD2]
 If fstat
  GOK = 0 : Call FSTA("PYD2") From GLOCK : Return
 Endif
 If !([M]OCDEFAC(I)=1 & [M]CDEFAC(I)=2)
  XLIGREG = [M]LIGREG(I)
 Endif

 Read [PYD]PYD0 = [M]REF(I);[M]LIGREG(I)
 [F:PYD]AMTLIN    -= MONTCUR
 [F:PYD]AMTLIN2   -= MONTREG
 [F:PYD]PAYCURLIN -= MONTCUR
 [F:PYD]PAYLOCLIN -= MONTLOC
Endif
If [M]NUMERO(I)<>[M]ONUMERO(I)
 [F:PYD]VCRTYP = ""
 [F:PYD]VCRNUM = ""
 [F:PYD]BPRINV = ""
 [F:PYD]BPRSACINV = ""
 [F:PYD]IPTTYP = 0
 [F:PYD]DUDNUM = 0
 [F:PYD]DUDLIG = 0
Endif
Rewrite [PYD]
If fstat
 GOK = 0 : Call FSTA("PYD") From GLOCK : Return
Endif

If XLIGREG<>0
 For II=I To [M]NBLIG-1
  If [M]REF(II) = [M]REF(I)
   If [M]LIGREG(II)=XLIGREG
    [M]LIGREG(II) = [F:PYD2]LIN
   Endif
  Else
   Break
  Endif
 Next
Endif

# Elimination de la ligne PAYORDER
Read [PYO]PYO0 = [M]DUDNUM(I);[M]DUDLIG(I);[M]ECHNUM(I)
If !fstat
 If [M]AMTIPT(I)<[M]OAMTIPT(I)
  If [M]NUMERO(I)<>[M]ONUMERO(I)
   [F:PYO]DUDPAYAMT -= [M]AMTIPT(I)
  Else
   [F:PYO]DUDPAYAMT -= [M]OAMTIPT(I)-[M]AMTIPT(I)
  Endif
  Rewrite [PYO]
  If fstat
   GOK = 0 : Call FSTA("PYO") From GLOCK : Return
  Endif
 Else
  Delete [PYO]
  If fstat=1
   GOK = -1 : GLOCK="$PAYORDER"-num$([M]DUDNUM(I)) : Return
  Endif
 Endif
Endif
Return

########################################################
## Passage commande => facture
########################################################
$COM_FAC
Gosub COM_NON
If GOK<1 : Return : Endif
Gosub NON_FAC
Return

########################################################
## Imputation d'une commande
########################################################
$NON_COM
Call LECMAINPLAN(1,[M]SOCIETE,[L]COA) From CPTDIV

Local Integer II
Local Integer XLIGREG : XLIGREG = 0


If !([M]OCDEFAC(I)=1 & [M]CDEFAC(I)=1)
 If [M]AMTIPT(I)<[M]OAMTIPT(I)
  Filter [PYD2] Where NUM=[M]REF(I)
  Read [PYD2]PYD0 Last
  Filter [PYD2]
  LIGDUD = [F:PYD2]LIN
  [F:PYD2] = [F:PYD]
  [F:PYD2]LIN = LIGDUD+1
  MONTCUR = [M]OAMTIPT(I)-[M]AMTIPT(I)
  Gosub CAL_MNT
  If !GOK : Return : Endif
  [F:PYD2]AMTLIN    = MONTCUR
  [F:PYD2]AMTLIN2   = MONTREG
  [F:PYD2]PAYCURLIN = MONTCUR
  [F:PYD2]PAYLOCLIN = MONTLOC
  Write [PYD2]
  If fstat
   GOK = 0 : Call FSTA("PYD2") From GLOCK : Return
  Endif
  XLIGREG = [M]LIGREG(I)
 Endif
Endif
Read [PYD]PYD0 = [M]REF(I);[M]LIGREG(I)
MONTCUR = [M]AMTIPT(I)
Gosub CAL_MNT
If !GOK : Return : Endif
[F:PYD]AMTLIN    = MONTCUR
[F:PYD]AMTLIN2   = MONTREG
[F:PYD]PAYCURLIN = MONTCUR
[F:PYD]PAYLOCLIN = MONTLOC

# Y-a-t-il une échéance qui le permet ??
LIGDUD = 0
For [DUD2]DUD0 Where TYP=COMTYP & NUM=[M]NUMERO(I)
 LIGDUD = max([F:DUD2]DUDLIG,LIGDUD)
Next
OK = 0
For [DUD2]DUD0 Where TYP=COMTYP & NUM=[M]NUMERO(I)
 If [F:DUD2]AMTCUR*[F:DUD2]AMTCUR>=[F:DUD2]AMTCUR*([F:DUD2]PAYCUR+[F:DUD2]TMPCUR+[M]AMTIPT(I))
  OK = 1 : Break
 Endif
Next
If OK
 [F:DUD2]PAYCUR += [F:PYD]PAYCURLIN
 [F:DUD2]PAYLOC += [F:PYD]PAYLOCLIN
 Call SLDECH("DUD2")From MODECHE
 Call SETMAINREF([F:DUD2]CPY,TYPGEN,TYPANA) From CPTDIV
 Call GETPERSOC([F:DUD2]CPY,TYPGEN,[F:DUD2]DUDDAT,EXERCICE,PERIODE) From CPTSUB
 [F:DUD2]FIY = EXERCICE
 [F:DUD2]PER = PERIODE
 Rewrite [DUD2]
 Call HISTOECH("DUD2",1,[M:IPT]DAT1)From MODECHE
Else
 Raz [F:DUD2]
 Call ACCNUM([F:DUD2]ACCNUM) From SUBGAS
 [F:DUD2]DUDLIG = LIGDUD+1
 [F:DUD2]TYP    = COMTYP
 [F:DUD2]BPRTYP = [M]CLIFOU
 Case [M]CLIFOU
  When 1
   Call LECTURE("SOH",[M]NUMERO(I),"") From CONTOBJ
   If fstat
    GOK = 0 : Call RSTA("SOH",[M]NUMERO(I)) From GLOCK : Return
   Endif
   [F:DUD2]SNS    = 1
   [F:DUD2]BPR    = [F:SOH]BPCINV
   [F:DUD2]BPRPAY = [F:SOH]BPCPYR
   Call LECTURE("BPC",[F:DUD2]BPR,"") From CONTOBJ
   If fstat
    GOK=0 : Call ECR_TRACE([F:DUD2]BPR-":"-mess(139,100,1),1) From GESECRAN : Return # Client inexistant
   Endif
   Call INIT_COMPTE([F:DUD2]BPR,[F:DUD2]CPY,"C",CODCPT) From CPTSUB
   Call LECTURE("CAC",CODCPT,"2~"+[L]COA) From CONTOBJ :# Code comptable
  When 2
   Call LECTURE("POH",[M]NUMERO(I),"") From CONTOBJ
   If fstat
    GOK = 0 : Call RSTA("POH",[M]NUMERO(I)) From GLOCK : Return
   Endif
   [F:DUD2]SNS    = -1
   [F:DUD2]BPR    = [F:POH]BPSINV
   [F:DUD2]BPRPAY = [F:POH]BPRPAY
   Call LECTURE("BPS",[F:DUD2]BPR,"") From CONTOBJ
   If fstat
    GOK=0 : Call ECR_TRACE([F:DUD2]BPR-":"-mess(136,100,1),1) From GESECRAN : Return # Fournisseur inexistant
   Endif
   Call INIT_COMPTE([F:DUD2]BPR,[F:DUD2]CPY,"F",CODCPT) From CPTSUB
   Call LECTURE("CAC",CODCPT,"3~"+[L]COA) From CONTOBJ :# Code comptable
 Endcase
 If fstat
  GOK=0 : Call ECR_TRACE(CODCPT-":"-mess(11,114,1),1) From GESECRAN : Return
 Endif
 Read [GAC]GAC0 = [L]COA;[F:CAC]ACC(0)
 If fstat or [F:GAC]SAC<>2
  GOK=0 : Call ECR_TRACE([F:CAC]ACC(0)-":"-mess(9,106,1),1) From GESECRAN : Return # Collectif inexistant
 Endif
 [F:DUD2]SAC     = [F:GAC]ACCSHO
 [F:DUD2]NUM     = [M]NUMERO(I)
 [F:DUD2]LIG     = 1
 [F:DUD2]PAMTYP  = 2 : # Acompte
 [F:DUD2]SOI     = 1 : # Relevé = Non
 [F:DUD2]DUDSTA  = 1 : # Provisoire
 [F:DUD2]SENINS  = 1 : # Non émis
 [F:DUD2]FLGFUP  = 1 : # A relancer=Non
 [F:DUD2]CPY     = [F:PYH]CPY
 [F:DUD2]PAM     = [F:PYH]PAM
 [F:DUD2]DUDDAT  = [F:PYH]ACCDAT
 [F:DUD2]FCY     = [F:PYD]FCYLIN
 [F:DUD2]CUR     = [F:PYD]CURLIN
 [F:DUD2]VAT     = [F:PYD]VATLIN
 If [F:DUD2]SNS<0 : [F:DUD2]FLGPAZ = [L]MAXPAZ : Endif : # Bon à payer
 [F:DUD2]AMTCUR = [F:PYD]PAYCURLIN : [F:DUD2]PAYCUR  = [F:DUD2]AMTCUR
 [F:DUD2]AMTLOC = [F:PYD]PAYLOCLIN : [F:DUD2]PAYLOC  = [F:DUD2]AMTLOC
 [F:DUD2]IBDAMT = [F:DUD2]AMTCUR  # 87145
 [F:DUD2]TYPDUD = 1  : #Commande
 Call KEYDUD("DUD2") From MODECHE
 Call SLDECH("DUD2")From MODECHE
 Call SETMAINREF([F:DUD2]CPY,TYPGEN,TYPANA) From CPTDIV
 Call GETPERSOC([F:DUD2]CPY,TYPGEN,[F:DUD2]DUDDAT,EXERCICE,PERIODE) From CPTSUB
 [F:DUD2]FIY = EXERCICE
 [F:DUD2]PER = PERIODE
 If dim([F:DUD2]CREDAT)>0 : [F:DUD2]CREDAT = datesyst : Endif
 If dim([F:DUD2]CREUSR)>0 : [F:DUD2]CREUSR = GUSER : Endif
 Write [DUD2]
 If fstat
  GOK = 0 : Call FSTA("DUD2") From GLOCK
 Endif
 Call HISTOECH("DUD2",1,[M:IPT]DAT1)From MODECHE
Endif
If fstat
 GOK = 0 : Call FSTA("DUD2") From GLOCK : Return
Endif
Call SLDECH("DUD")From MODECHE
Call SETMAINREF([F:DUD]CPY,TYPGEN,TYPANA) From CPTDIV
Call GETPERSOC([F:DUD]CPY,TYPGEN,[F:DUD]DUDDAT,EXERCICE,PERIODE) From CPTSUB
[F:DUD]FIY = EXERCICE
[F:DUD]PER = PERIODE
Rewrite [DUD]
If fstat
 GOK = 0 : Call FSTA("DUD") From GLOCK : Return
Endif
Call HISTOECH("DUD",1,[M:IPT]DAT1)From MODECHE
[F:PYD]DUDNUM = [F:DUD2]ACCNUM
[F:PYD]DUDLIG = [F:DUD2]DUDLIG
[F:PYD]VCRNUM = [M]NUMERO(I)
[F:PYD]BPRINV    = [F:DUD2]BPR
[F:PYD]BPRSACINV = [F:DUD2]SAC
[F:PYD]IPTTYP = [M]CLIFOU
Rewrite [PYD]
If fstat
 GOK = 0 : Call FSTA("PYD") From GLOCK : Return
Endif

If XLIGREG<>0
 For II=I To [M]NBLIG-1
  If [M]REF(II) = [M]REF(I)
   If [M]LIGREG(II)=XLIGREG
    [M]LIGREG(II) = [F:PYD2]LIN
   Endif
  Else
   Break
  Endif
 Next
Endif

# Enreg sur PAYORDER
Readlock [PYO]PYO0 = [F:PYD]DUDNUM;[F:PYD]DUDLIG;[M]ECHNUM(I)
If fstat=1
 GOK = -1 : GLOCK = "$PAYORDER" : Goto ROLL_TR1
Elsif fstat
 Raz [F:PYO]
 [F:PYO]DUDNUM    = [F:PYD]DUDNUM
 [F:PYO]DUDLIG    = [F:PYD]DUDLIG
 [F:PYO]PAYNUM    = [M]ECHNUM(I)
 [F:PYO]DUDPAYAMT = [M]AMTIPT(I)
 [F:PYO]PAYVCR    = [M]REF(I)
 Write [PYO]
Else
 [F:PYO]DUDPAYAMT += [M]AMTIPT(I)
 [F:PYO]PAYVCR    = [M]REF(I)
 Rewrite [PYO]
Endif
If fstat
 GOK = 0 : Call FSTA("PYO") From GLOCK : Return
Endif
Return

$CAL_MNT
# En devise de règlement
If [F:PYD]CURLIN=[F:PYH]CUR
 MONTREG = MONTCUR
Else
 Call CONVERT([F:PYD]CURLIN,[F:PYH]CUR,[M:IPT]DEVLOC,[F:TPY]RATTYP,[F:PYH]ACCDAT,MONTCUR,MONTREG,STAT) From TRTDEV
 If STAT
  Call ECR_TRACE(mess(16,114,1)-[F:PYD]CURLIN-"->"-[F:PYH]CUR
&              -"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)-")",1) From GESECRAN
# Pas de cours de devises)
  GOK = 0 : Return
 Endif
Endif
# En devise société
If [M:IPT]DEVLOC=[F:PYD]CURLIN
 MONTLOC = MONTCUR
Elsif [M:IPT]DEVLOC=[F:PYH]CUR
 MONTLOC = MONTREG
Else
 Call CONVERT([F:PYD]CURLIN,[M:IPT]DEVLOC,[M:IPT]DEVLOC,[F:TPY]RATTYP,
&     [F:PYH]ACCDAT,MONTCUR,MONTLOC,STAT) From TRTDEV
 If STAT
  Call ECR_TRACE(mess(16,114,1)-[F:PYD]CURLIN-"->"-[M:IPT]DEVLOC
&              -"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)-")",1) From GESECRAN
# Pas de cours de devises CURLIN -> [M:IPT]DEVLOC (ACCDAT)
  GOK = 0 : Return
 Endif
Endif
Return

########################################################
## Imputation d'une facture
########################################################
$NON_FAC
# Ecriture de transfert d'acompte
Local Integer II
Local Integer XLIGREG : XLIGREG = 0

Local Char GNUMREG(GLONVCR)(1..1) : GNUMREG(1) = [M]REF(I)
Call IMPUTE2([M]INVNUM(I),[M]ECHNUM(I..I),[M]ECHLIG(I..I),[M]AMTIPT(I..I),1,GNUMREG)

If GOK<1 : Return : Endif

# Mise à jour fichier règlement

If !([M]OCDEFAC(I)=1 & [M]CDEFAC(I)=2)
 If [M]AMTIPT(I)<[M]OAMTIPT(I)
  Filter [PYD2] Where NUM=[M]REF(I)
  Read [PYD2]PYD0 Last
  Filter [PYD2]
  LIGDUD = [F:PYD2]LIN
  [F:PYD2] = [F:PYD]
  [F:PYD2]LIN = LIGDUD+1
  MONTCUR = [M]OAMTIPT(I)-[M]AMTIPT(I)
  Gosub CAL_MNT
  If !GOK : Return : Endif
  [F:PYD2]AMTLIN    = MONTCUR
  [F:PYD2]AMTLIN2   = MONTREG
  [F:PYD2]PAYCURLIN = MONTCUR
  [F:PYD2]PAYLOCLIN = MONTLOC
  Write [PYD2]
  If fstat
   GOK = 0 : Call FSTA("PYD2") From GLOCK : Return
  Endif
  XLIGREG = [M]LIGREG(I)
 Endif
Else
 XLIGREG = [M]LIGREG(I)
Endif


Read [PYD]PYD0 = [M]REF(I);[M]LIGREG(I)
MONTCUR = [M]AMTIPT(I)
Gosub CAL_MNT
If !GOK : Return : Endif
[F:PYD]AMTLIN    = MONTCUR
[F:PYD]AMTLIN2   = MONTREG
[F:PYD]PAYCURLIN = MONTCUR
[F:PYD]PAYLOCLIN = MONTLOC

[F:PYD]DUDNUM = [M]INVNUM(I)
[F:PYD]DUDLIG = 1
[F:PYD]VCRNUM = [M]NUMERO(I)
[F:PYD]VCRTYP = [M]VCRTYP(I)
[F:PYD]BPRINV = [M]BPRINV(I)
[F:PYD]BPRSACINV = [M]BPRSACINV(I)
[F:PYD]IPTTYP = 3
Rewrite [PYD]
If fstat
 GOK = 0 : Call FSTA("PYD") From GLOCK : Return
Endif

If XLIGREG<>0
 For II=I To [M]NBLIG-1
  If [M]REF(II) = [M]REF(I)
   If [M]LIGREG(II)=XLIGREG
    [M]LIGREG(II) = [F:PYD2]LIN
   Endif
  Else
   Break
  Endif
 Next
Endif

# Enreg sur PAYORDER
Readlock [PYO]PYO0 = [F:PYD]DUDNUM;[F:PYD]DUDLIG;[M]ECHNUM(I)
If fstat=1
 GOK = -1 : GLOCK = "$PAYORDER" : Goto ROLL_TR1
Elsif fstat
 Raz [F:PYO]
 [F:PYO]DUDNUM    = [F:PYD]DUDNUM
 [F:PYO]DUDLIG    = [F:PYD]DUDLIG
 [F:PYO]PAYNUM    = [M]ECHNUM(I)
 [F:PYO]DUDPAYAMT = [M]AMTIPT(I)
 [F:PYO]INVNUM    = [M]INVNUM(I)
 [F:PYO]PAYVCR    = [M]REF(I)
 Write [PYO]
Else
 [F:PYO]DUDPAYAMT += [M]AMTIPT(I)
 Rewrite [PYO]
Endif
If fstat
 GOK = 0 : Call FSTA("PYO") From GLOCK : Return
Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$SEL_NUM
Case [M]CDEFAC(nolign-1)
 When 1 : # cde cli
  Case [M]CLIFOU
   When 1
    OBJET = "SOH" : OPTIONS = "#"
    CRITERE = "BPCPYR='"+[M]TIERS+"'"
   When 2
    OBJET = "POH" : OPTIONS = "#"
    CRITERE = "BPRPAY='"+[M]TIERS+"'"
  Endcase
 When Default : # Pièce comptable
  Local Integer SENS
  Case [M]CLIFOU
   When 1 : SENS   = +1
   When 2 : SENS   = -1
  Endcase
  Filter [DUD] Where CPY=[M]SOCIETE & AMTCUR*(AMTCUR-PAYCUR-TMPCUR)>0 & TYP=[M]VCRTYP(nolign-1) & BPRFCT='' & SNS=SENS
  Local Char TIERS(GLONBPR) , SITE(GLONFCY)
  TIERS = [M]TIERS : SITE = [M]SITE
  Gosub SEL_DUD From SELDUD1
  Call ADDCRIT(CRITERE,ICRITERE,"CPY ",'CPY="'+[M]SOCIETE+'"',"&") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRITERE,"AMTCUR ",'AMTCUR*(AMTCUR-PAYCUR-TMPCUR)>'+num$(0),"&") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRITERE,"TYP ",'TYP="'+[M]VCRTYP(nolign-1)+'"',"&") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRITERE,"BPRFCT ",'BPRFCT="'+'"',"&") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRITERE,"SNS ",'SNS='+num$(SENS),"&") From GOBJSUB
Endcase
Return

$F_SEL_NUM
Filter [DUD]
Return

########################################################
## Imputation d'un règlement sur une facture
########################################################
Subprog IMPUTE(FACTURE,REGNUM,REGLIG,MONTANT,NBECH)
Value Integer FACTURE        : # ACCNUM de la facture
Value Integer REGNUM(1..)    : # ACCNUM du règlement
Value Integer REGLIG(1..)    : # DUDLIG du règlement
Value Decimal MONTANT(1..)   : # Montant imputé
Value Integer NBECH          : # Nombre d'acomptes

Local Char  REGLEMENT(GLONVCR)(1..NBECH) : # Numéro du règlement
Raz REGLEMENT
Goto IMP

Subprog IMPUTE2(FACTURE,REGNUM,REGLIG,MONTANT,NBECH,REGLEMENT)
Value Integer FACTURE          : # ACCNUM de la facture
Value Integer REGNUM(1..)      : # ACCNUM du règlement
Value Integer REGLIG(1..)      : # DUDLIG du règlement
Value Decimal MONTANT(1..)     : # Montant imputé
Value Integer NBECH            : # Nombre d'acomptes
Value Char    REGLEMENT()(1..) : # Numéro du règlement

$IMP
If clalev([F:DUD])=0  : Local File GACCDUDATE [DUD]  : Endif
If clalev([F:DUD2])=0 : Local File GACCDUDATE [DUD2] : Endif
If clalev([F:DAT4])=0 : Local File GACCTMPD   [DAT4] : Endif
If GMODU(2)=2
 If clalev([F:MTB])=0  : Local File MTCBATCH   [MTB]  : Endif
Endif

Local Integer I , STAT
Local Char    MESSA(80)
Local Char    PCETYP(GLONGTE) , PCENUM(GLONVCR)
Local Integer NUMACC(1..2) , LIGACC(1..2)
Local Integer NBLET , NBLET2
Local Decimal TOTIPT
Local Decimal TOTFACAMT, TOTPAYAMT

## La pièce (DAE) n'existe pas forcément, il faut donc lire une échéance
Read [DUD2]DUD1(1) = FACTURE
If fstat : End : Endif

NBLET = NBECH+1
For [DUD2]DUD1 Where ACCNUM=FACTURE
 NBLET += 1
 TOTFACAMT +=[F:DUD2]AMTCUR
Next

GPOINT = "BEFMTC" : Gosub ENTREE From EXEFNC

NBLET2 = NBLET*2
Local Integer LETNUM(1..NBLET) , LETLIG(1..NBLET)
Local Integer LETNUM2(1..NBLET2) , LETLIG2(1..NBLET2)
Local Decimal LETIPT(1..NBLET)
Local Decimal LETIPT2(1..NBLET2)

NBLET = 0
For I=1 To NBECH

 Read [DUD]DUD1 = REGNUM(I);REGLIG(I)
 If !fstat
  If [F:DUD2]SAC<>[F:DUD]SAC or [F:DUD2]BPR<>[F:DUD]BPR or [F:DUD2]FCY<>[F:DUD]FCY
   Call GEN_PIECE(FACTURE,REGLEMENT(I),REGNUM(I),REGLIG(I),MONTANT(I),STAT,MESSA,PCETYP,PCENUM,NUMACC)
   If STAT
    Gosub MESSAGE From CPTAUTO
    Call ECR_TRACE(MESSA-"("+num$(STAT)+")",1) From GESECRAN
    GOK = 0 : Break
   Endif
   Call ECR_TRACE(mess(40,107,1)-PCETYP-PCENUM,0) From GESECRAN # Création pièce

   LIGACC(1) = 1
   # Lettrage de l'acompte
   NBLET2 = 1
   LETNUM2(NBLET2) = NUMACC(2)
   LETLIG2(NBLET2) = 1
   LETIPT2(NBLET2) = MONTANT(I)
   NBLET2 += 1
   LETNUM2(NBLET2) = REGNUM(I)
   LETLIG2(NBLET2) = REGLIG(I)
   LETIPT2(NBLET2) = MONTANT(I)
   Call LETDIF2(NBLET2,LETNUM2,LETLIG2,LETIPT2,2) From CPTLET
  Else
   NUMACC(1) = REGNUM(I)
   LIGACC(1) = REGLIG(I)
  Endif
  If GOK<1 : Break : Endif
  NBLET += 1
  LETNUM(NBLET) = NUMACC(1)
  LETLIG(NBLET) = LIGACC(1)
  LETIPT(NBLET) = MONTANT(I)
  TOTPAYAMT    +=[F:DUD2]AMTCUR
 Elsif fstat
  ## Si l'échéance de règlement n'existe pas, c'est que la pièce de règlement est encore dans les tables
  ## d'écritures temporaires. On peut faire qq chose si pas de génération de pièce de transfert d'acompte
  ## (=collectif, tiers, site identique)
  Read [DAT4]DAT1 = REGNUM(I)
  If !fstat & !([F:DUD2]SAC<>[F:DAT4]SAC or [F:DUD2]BPR<>[F:DAT4]BPR or [F:DUD2]FCY<>[F:DAT4]FCYLIN)
   NUMACC(1) = REGNUM(I)
   LIGACC(1) = REGLIG(I)
   NBLET += 1
   LETNUM(NBLET) = NUMACC(1)
   LETLIG(NBLET) = LIGACC(1)
   LETIPT(NBLET) = MONTANT(I)
   TOTPAYAMT    +=[F:DUD2]AMTCUR
  Else
   Local Integer MORT
   Call PRESENCE(MORT) From CPTBATCH
   If MORT
    # La tâche comptable doit être démarrée
    GOK = 0 : GMESSAGE = mess(49,134,1) : Break
   Endif
  Endif
 Endif
Next I
If GOK<1 : End : Endif


TOTIPT = sum(MONTANT(1..NBLET))
For [DUD2]DUD1 Where ACCNUM=FACTURE
 NBLET += 1
 LETNUM(NBLET) = FACTURE
 LETLIG(NBLET) = [F:DUD2]DUDLIG
    # Issue X3-49247 - 2017-08-09 by FHA :
    # setting PAYDAT if empty, by the date of current payment (PYH)
    #                if not, by the lowest date between actual PAYDAT vrs date of current payment (PYH)
    If [F:DUD2]PAYDAT=[0/0/0]
     [F:DUD2]PAYDAT = [F:PYH]ACCDAT
    Else
     [F:DUD2]PAYDAT = min([F:DUD2]PAYDAT,[F:PYH]ACCDAT)
    Endif
    Rewrite [DUD2]
    If fstat
     GOK=0 : Call FSTA("DUD2") From GLOCK : Break
    Endif
    # End issue X3-49247
 If [F:DUD2]AMTCUR-[F:DUD2]PAYCUR-[F:DUD2]TMPCUR>=TOTIPT
  LETIPT(NBLET) = TOTIPT
  Break
 Else
  LETIPT(NBLET) = [F:DUD2]AMTCUR-[F:DUD2]PAYCUR-[F:DUD2]TMPCUR
  TOTIPT -= LETIPT(NBLET)
 Endif
Next
If GOK<1 : End : Endif  # Issue X3-49247 - 2017-08-09 by FHA

If GMODU(2)=2
 Filter [MTB] Where ACCNUM=FACTURE
 Look [MTB]MTB0 First
 Filter [MTB]
 If !fstat
  GOK = 0 : Call ECR_TRACE(mess(70,119,1)-[F:DUD2]TYP-[F:DUD2]NUM,1) From GESECRAN : End
 Endif
Endif

If TOTPAYAMT=TOTFACAMT & TOTFACAMT<>TOTIPT & GFONCTION<>"IPTACPTCLI" & GFONCTION<>"IPTACPTFOU"
 Call LETDIF2(NBLET,LETNUM,LETLIG,LETIPT,3) From CPTLET
Else
 GPE=0
 GPOINT = "GNRMTC" : Gosub ENTREE From EXEFNC
 If !GPE
  Call LETDIF2(NBLET,LETNUM,LETLIG,LETIPT,2) From CPTLET
 Endif
Endif
End


##########################################################
## Pièce de transfert d'acompte
##########################################################
Subprog GEN_PIECE(INVNUM,INVREG,ECHNUM,ECHLIG,MONTANT,STAT,MESSA,PCETYP,PCENUM,NUMACC)
Value    Integer INVNUM
Value    Char    INVREG()
Value    Integer ECHNUM
Value    Integer ECHLIG
Value    Decimal MONTANT
Variable Integer STAT
Variable Char    MESSA()
Variable Char    PCETYP()
Variable Char    PCENUM()
Variable Integer NUMACC(1..)

Local Mask SAICURLED [SCL], GACCENTFMT  [HAEF], GACCENTW  [HAEW]
Local Mask GACCENT0 [HAE0], GACCENT1 [HAE1], GACCENT2   [HAE2], VENTILE    [VTL], VENTILE2 [VT2]

Local File GACCTMP [HAE] , GACCTMPD [DAE] , GACCTMPA [DAA]


If clalev([F:GAU])=0 : Local File GAUTACE     [GAU] : Endif
If clalev([F:GAD])=0 : Local File GAUTACED    [GAD] : Endif
If clalev([F:GAG])=0 : Local File GAUTACEF    [GAG] : Endif
If clalev([F:CAC])=0 : Local File GACCCODE    [CAC] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT    [GAC] : Endif
If clalev([F:CPY])=0 : Local File COMPANY     [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY    [FCY] : Endif
If clalev([F:TCU])=0 : Local File TABCUR      [TCU] : Endif
If clalev([F:TCH])=0 : Local File TABCHANGE   [TCH] : Endif
If clalev([F:TCK])=0 : Local File TABACCLIK   [TCK] : Endif
If clalev([F:GTE])=0 : Local File GTYPACCENT  [GTE] : Endif
If clalev([F:DUD])=0 : Local File GACCDUDATE  [DUD] : Endif
If clalev([F:DUD2])=0: Local File GACCDUDATE  [DUD2]: Endif
If clalev([F:CCE])=0 : Local File CACCE       [CCE] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR  [FIY] : Endif
If clalev([F:PER])=0 : Local File PERIOD      [PER] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER    [BPR] : Endif
If clalev([F:TUN])=0 : Local File TABUNIT     [TUN] : Endif
If clalev([F:DSP])=0 : Local File CADSP       [DSP] : Endif
If clalev([F:AUZ])=0 : Local File CAAUZ       [AUZ] : Endif
If clalev([F:ANM])=0 : Local File ACODNUM     [ANM] : Endif
If clalev([F:AVN])=0 : Local File AVALNUM     [AVN] : Endif
If clalev([F:CCE2])=0 : Local File CACCE      [CCE2] : Endif
If clalev([F:HAE2])=0 : Local File GACCTMP    [HAE2] : Endif
If clalev([F:GDE])=0 : Local File GDIAENTRY   [GDE] : Endif
If clalev([F:GDD])=0 : Local File GDIAENTRYD  [GDD] : Endif
If clalev([F:PBS])=0 : Local File GAPARBSE    [PBS] : Endif
If clalev([F:JOU])=0 : Local File GJOURNAL    [JOU] : Endif
If clalev([F:JST])=0 : Local File GAJOUSTA    [JST] : Endif
If clalev([F:HAE1])=0 : Local File GACCENTRY  [HAE1] : Endif
If clalev([F:DAE6])=0 : Local File GACCENTRYD [DAE6] : Endif
If clalev([F:PAN])=0 : Local File PAYACCNUM   [PAN] : Endif
If clalev([F:PMD])=0 : Local File PAYACCNUMD  [PMD] : Endif
If clalev([F:GCM])=0 : Local File GACM        [GCM]  : Endif
If clalev([F:DIE])=0 : Local File GDIE        [DIE] : Endif
If clalev([F:COA])=0 : Local File GCOA        [COA] : Endif
If clalev([F:GCM])=0 : Local File GACM        [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED        [LED] : Endif

Local Char    WIDT, PCEAUTO(GLONGAU), PLAN(GLONCOA), CODTAX(GLONVAT)
Local Integer TABSEC, TABANA, ERR, PCEGRP, LIG, TYPLED, PCEOK
Local Decimal AMTECT
Local Char    TZONE(10)(1..10)    : # Table of the zones to be forced (Ex: ORICOD)   #*X3-39795
Local Char    TVAL(30)(1..10)     : # Table of values for zones to be forced         #*X3-39795

Raz [M:HAE0]
Raz [M:HAE1]
Raz [M:HAE2]

Call PARAM("","GAUACPT",[L]PCEAUTO) From ADOVAL
If [L]PCEAUTO="" : [L]PCEAUTO="ACPT" : Endif
Read [GAU]GAU0 = PCEAUTO

#---- Lecture de la facture (Information d'entête liée à la Facture)
Read [DUD2]DUD1(1) = INVNUM

#Read [TB0]DAE2     = INVNUM
# TB0 est OK lorsque nous sommes dans le cas d'une imputation d'acopte via la fonction "Imputation d'acompte".
# TB0 est NOK lorsque nous sommes dans le cas d'une validation de facture liée à un acompte.
Local File GACCENTRYD [TB0]
Read [TB0]DAE2 = INVNUM
If !fstat
 PCEOK=1
Else
 Close Local File [TB0]
 Local File GACCTMPD [TB0]
 Read [TB0]DAT1 = INVNUM
 If !fstat
  PCEOK=2
 Else
  PCEOK=0
 Endif
Endif

#---- Lecture du règlement
Read [DUD]DUD1 = ECHNUM;ECHLIG

# Evaluation de l'en-tête
[M:HAE1]CUR = [F:DUD2]CUR
[M:HAE0]FCY = [F:DUD2]FCY

If clalev([M:IPT])
 [M:HAE0]ACCDAT = [M:IPT]DAT1
 [M:HAE1]VALDAT = [M:IPT]DAT2
Endif

Call TETE(STAT,MESSA) From TRTPCE
If STAT : End : Endif
Gosub INIT_COURS

Local Integer FLGDEM : FLGDEM = 0
Call FLGDEM([M]CPY,FLGDEM) From CPTDIV

## Initialisation masque de référence [HAEF]
Call GETSOC([M]FCY) From DEVSUB
Call LECPLAN(GSOCIETE,GTYPGEN,PLAN) From CPTDIV
Call LECTURE("GDE",[M]DACDIA,"") From CONTOBJ
## Initialisation masque de référence [HAEF]
Call INIMSKFMT3([M]FCY,1,[M]DACDIA,[M]TYP,[M]ACCDAT,STAT) From SUBGASA
For I=1 To [M:HAEF]NBRLED
 Assign "[M:HAE1]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
 Assign "[M:HAE2]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
Next

Call LECTURE("TCU",[M:HAE1]CUR,"") From CONTOBJ

#--------------------------------------------------------------------------
# Affectation des lignes
# Ligne client / fournisseur
#--------------------------------------------------------------------------
LIG = 0
Read [GAD]GAD0 = PCEAUTO;1
Gosub OUV_LIN
If PCEOK
 If TABSEC=1
  Read [TB1]DAE2 = INVNUM
 Else
  Read [TB1]DAT1 = INVNUM
 Endif
Endif
[M:HAE2]FCYLIN(LIG) = [F:DUD2]FCY
If PCEOK
 For [TB0] Where TYP=[F:DUD2]TYP & NUM=[F:DUD2]NUM & IDTLIN=[F:TB1]IDTLIN
  INDREF = find([F:TB0]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
  If INDREF
   Assign "[M]ACC"+num$(INDREF)+"("+num$(LIG)+")" With [F:TB0]ACC
   Assign "[M]SAC"+num$(INDREF)+"("+num$(LIG)+")" With [F:TB0]SAC
  Endif
 Next
Else
  INDREF = find(GTYPGEN,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
  If INDREF
   Assign "[M]SAC"+num$(INDREF)+"("+num$(LIG)+")" With [F:DUD2]SAC
   Read [GAC]GAC1 = PLAN;[F:DUD2]SAC
   Assign "[M]ACC"+num$(INDREF)+"("+num$(LIG)+")" With [F:GAC]ACC
  Endif
Endif
[M:HAE2]BPR(LIG)    = [F:DUD2]BPR
Call LIGNE(LIG,"",STAT,MESSA) From TRTPCE
If STAT : End : Endif
If [F:DUD2]SNS>0
 [M:HAE2]CDT(LIG) = MONTANT
 [M:HAE2]DEB(LIG) = 0
Else
 [M:HAE2]DEB(LIG) = MONTANT
 [M:HAE2]CDT(LIG) = 0
Endif
[M:HAE2]LIGPCEAUTO(LIG) = 1
If PCEOK & TABANA
 Filter [F:TB2] Where TYP=[F:DUD2]TYP & NUM=[F:DUD2]NUM & LIN=[F:TB1]LIN
 Gosub ANA_LIN
 If STAT : End : Endif
Endif

Gosub LIGNE
Gosub FER_LIN

#--------------------------------------------------------------------------
# Affectation des lignes
# Ligne acompte
#--------------------------------------------------------------------------
LIG += 1
Read [GAD]GAD0 = PCEAUTO;2
Gosub OUV_LIN
If PCEOK & TABSEC
 Read [TB0]DAE2 = [F:DUD]ACCNUM
 Read [TB1]DAE2 = [F:DUD]ACCNUM
Endif
Read [DAE6]DAE2 = [F:DUD]ACCNUM
If !fstat & [F:DAE6]TAX<>""
 [M:HAE2]TAX(LIG) = [F:DAE6]TAX
Endif
[M:HAE2]FCYLIN(LIG) = [F:DUD]FCY
If PCEOK
 For [TB0] Where TYP=[F:DUD]TYP & NUM=[F:DUD]NUM & IDTLIN=[F:TB1]IDTLIN
  INDREF = find([F:TB0]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
  If INDREF
   Assign "[M]ACC"+num$(INDREF)+"("+num$(LIG)+")" With [F:TB0]ACC
   Assign "[M]SAC"+num$(INDREF)+"("+num$(LIG)+")" With [F:TB0]SAC
  Endif
 Next
Else
  INDREF = find(GTYPGEN,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
  If INDREF
   Assign "[M]SAC"+num$(INDREF)+"("+num$(LIG)+")" With [F:DUD]SAC
   Read [GAC]GAC1 = PLAN;[F:DUD]SAC
   Assign "[M]ACC"+num$(INDREF)+"("+num$(LIG)+")" With [F:GAC]ACC
  Endif
Endif
[M:HAE2]BPR(LIG)    = [F:DUD]BPR
Call LIGNE(LIG,"",STAT,MESSA) From TRTPCE
If STAT : End : Endif
If [F:DUD2]SNS>0
 [M:HAE2]DEB(LIG) = MONTANT
 [M:HAE2]CDT(LIG) = 0
Else
 [M:HAE2]CDT(LIG) = MONTANT
 [M:HAE2]DEB(LIG) = 0
Endif
[M:HAE2]LIGPCEAUTO(LIG) = 2
If PCEOK & TABANA
 Filter [F:TB2] Where TYP=[F:TB1]TYP & NUM=[F:TB1]NUM & LIN=[F:TB1]LIN
 Gosub ANA_LIN
 If STAT : End : Endif
Endif
Gosub LIGNE
Gosub FER_LIN

#--------------------------------------------------------------------------
# Affectation des lignes
# Gestion de la TVA
#--------------------------------------------------------------------------
## 1ère passe pour savoir si la pièce de règlement est une pièce qui regroupe plusieurs règlements
PCEGRP = 0
CODTAX = ""
If INVREG<>""
 For [TB0] Where TYP=[F:DUD]TYP & NUM=[F:DUD]NUM & LEDTYP=GTYPGEN
  If [F:DUD]ACCNUM=[F:TB0]ACCNUM : CODTAX = [F:TB0]TAX : Endif
  Filter [PAN] Where TYPNUM = 3 & NUM=INVREG & ACCNUM = [F:TB0]ACCNUM
  Read [PAN]PAN0 First
  If !fstat
   If [F:PAN]ACETYP = 2
    PCEGRP = 1 : Break
   Else
    PCEGRP = 0
   Endif
  Endif
  Filter [PAN]
 Next
 Filter [PAN]
Endif

For [TB0] Where TYP=[F:DUD]TYP & NUM=[F:DUD]NUM & LEDTYP=GTYPGEN
 Call LECTURE("GAC",[F:TB0]ACC,[F:TB0]COA) From CONTOBJ
 If [F:GAC]FLGVAT=3 & CODTAX=[F:TB0]TAX : # Compte de TVA => ligne TVA
  AMTECT = [F:TB0]AMTCUR
  If PCEGRP
   Filter [PMD] Where NUM=INVREG & ACCNUM=[F:TB0]ACCNUM & VCRNUM=[F:TB0]NUM
   Read [PMD]PMD0 First
   Filter [PMD]
   If !fstat
    AMTECT = [F:PMD]AMTCUR
   Endif
  Endif
  If AMTECT>0
   ## Ligne TVA à régulariser
   ##--------------------------------------------------------------------------
   LIG += 1
   Read [GAD]GAD0 = PCEAUTO;3
   If fstat : Break : Endif
   [M:HAE2]FCYLIN(LIG) = [F:DUD]FCY
   Call LIGNE(LIG,"",STAT,MESSA) From TRTPCE
   If STAT : Break : Endif
   If [F:TB0]SNS>0
    ## <PP 05/08/02> Bug 15383 et 15384. Si le montant de l'acompte est inférieur au montant
    ## de l'échéance de la facture, la TVA doit être régularisée au prorata.
    If MONTANT < [F:DUD]AMTCUR
     [M:HAE2]DEB(LIG) = arr((MONTANT*AMTECT)/[F:DUD]AMTCUR,[F:TCU]CURRND)
    Else
     [M:HAE2]DEB(LIG) = AMTECT
    Endif
    [M:HAE2]CDT(LIG) = 0
   Else
    If MONTANT < [F:DUD]AMTCUR
     [M:HAE2]CDT(LIG) = arr((MONTANT*AMTECT)/[F:DUD]AMTCUR,[F:TCU]CURRND)
    Else
     [M:HAE2]CDT(LIG) = AMTECT
    Endif
    [M:HAE2]DEB(LIG) = 0
   Endif
   [M:HAE2]LIGPCEAUTO(LIG) = 3
   Gosub ANA2_LIN
   If STAT : Break : Endif
   Gosub LIGNE

   ## Ligne TVA collectée / à déduire
   ##--------------------------------------------------------------------------
   LIG += 1
   Read [GAD]GAD0 = PCEAUTO;4
   If fstat : LIG -= 1 : Break : Endif
    [M:HAE2]FCYLIN(LIG) = [F:DUD]FCY
    Call LIGNE(LIG,"",STAT,MESSA) From TRTPCE
    If STAT : Break : Endif
    If [F:TB0]SNS>0
     If MONTANT < [F:DUD]AMTCUR
      [M:HAE2]CDT(LIG) = arr((MONTANT*AMTECT)/[F:DUD]AMTCUR,[F:TCU]CURRND)
     Else
      [M:HAE2]CDT(LIG) = AMTECT
     Endif
    [M:HAE2]DEB(LIG) = 0
   Else
    If MONTANT < [F:DUD]AMTCUR
     [M:HAE2]DEB(LIG) = arr((MONTANT*AMTECT)/[F:DUD]AMTCUR,[F:TCU]CURRND)
    Else
     [M:HAE2]DEB(LIG) = AMTECT
    Endif
    [M:HAE2]CDT(LIG) = 0
   Endif
   [M:HAE2]LIGPCEAUTO(LIG) = 4
   Gosub ANA2_LIN
   If STAT : Break : Endif
   Gosub LIGNE
  Endif
 Endif
Next
LIG+=1
If STAT : End : Endif

#### Demande 15320 : point d'entrée Gestion des acomptes Portugal
GPOINT = "PIECE" : Gosub ENTREE From EXEFNC
[M:HAE2]NBLIG = LIG

If FLGDEM = 2 & dim([M]CPALIN)>0 & dim([M]DOEPTR)>0
 For NOL=0 To [M]NBLIG
  If [M]CPALIN(NOL)<>0
   [M]DOEPTR(NOL) = find([M]CPALIN(NOL),[M]LIGPCEAUTO(0..[M]NBLIG-1))
  Endif
 Next
Endif


# Validation pièce
Call CONTROLE(STAT,MESSA) From CPTBATCH
If GOK<1 or STAT : End : Endif

TZONE(5)= "ORIGIN" : TVAL(5)= "2"        :#Automatic loading  #*X3-39795
TZONE(6)= "ORICOD" : TVAL(6)= PCEAUTO                         #*X3-39795

#*X3-39795 Call VALPIECE(STAT,MESSA) From CPTBATCH
Call VALPIECE2(STAT,MESSA,TZONE,TVAL) From CPTBATCH
If GOK<1 or STAT : End : Endif

PCETYP = GTYPPCE
PCENUM = GNUMPCE

Call LECLEDMAIN(1,[M]CPY,TYPLED) From CPTDIV
#--- Lettrage -
For I=0 To [M:HAEW]NB-1
 If [M:HAEW]LIGPCEAUTO(I)=1 and [M:HAEW]LEDTYP(I)=[L]TYPLED
  NUMACC(1)=[M:HAEW]ACCNUM(I)
  Break
 Endif
Next
For I=0 To [M:HAEW]NB-1
 If [M:HAEW]LIGPCEAUTO(I)=2 and [M:HAEW]LEDTYP(I)=[L]TYPLED
  NUMACC(2)=[M:HAEW]ACCNUM(I)
  Break
 Endif
Next

# Ecriture sous PAYACCNUM de l'enregistrement liée au règlement <=> règlement [F:DAE6]
Gosub MAJPAN
End

$LIGNE
GPOINT = "LIGNE" : Gosub ENTREE From EXEFNC
Return

$MAJPAN


Local Char    REG(GLONVCR)
Local Char    PANGRP(50)
Local Integer PANACCNUM

If clalev([F:PYH3])=0 : Local File PAYMENTH   [PYH3] : Endif

[L]REG = vireblc(right$([F:DAE6]REFINTLIN,4),2)
Read [PYH3]PYH0 = REG
If fstat : Return : Endif

Raz [F:PAN]
[F:PAN]TYPNUM = 3
[F:PAN]NUM    = [L]REG
[F:PAN]ACCSTA = [F:PYH3]STA
[F:PAN]STA    = [F:PYH3]STA
[F:PAN]TYPVCR = "T" # Transfert de compte
[F:PAN]ACCNUM = NUMACC(1)
[F:PAN]GRP = ""
[F:PAN]RENCOD = ""
[F:PAN]RVSACCNUM = 0
[F:PAN]ACETYP = 1
Write [PAN]
If fstat
 GOK=0 : Call FSTA("PAN") From GLOCK
Endif
If GOK<1 : Return : Endif
If [F:PYH3]FRMNUM<>""
 # Pièce d'imputation - par règlement
 [L]PANGRP = "R"+[L]REG
 [L]PANACCNUM = [F:PAN]ACCNUM
 Gosub ECRPANFRM
 If GOK<1 : Return : Endif
Endif
Return


$ECRPANFRM
Raz [F:PAN]
[F:PAN]TYPNUM = [F:PYH3]FRMFLG
[F:PAN]NUM    = [F:PYH3]FRMNUM
[F:PAN]STA    = [F:PYH3]STA
[F:PAN]ACCSTA = [F:PYH3]STA
[F:PAN]TYPVCR = "T"

[F:PAN]ACCNUM = [L]PANACCNUM
[F:PAN]GRP    = [L]PANGRP
[F:PAN]RENCOD = ""
[F:PAN]RVSACCNUM = 0
[F:PAN]ACETYP = 1
Write [PAN]
If fstat
 GOK=0 : Call FSTA("PAN") From GLOCK : Return
Endif
If !GOK : Return : Endif
Return

###############################################################################
## # Suggestion V140 (CP) : Pré charger également Factures <--> Règlements
###############################################################################
Subprog  AFFECT
Local Decimal RSTECH, RSTREG, MONTIMP
Local Integer I, INTERM, NUMACP


Local Char FILFAC(255)

# On trie le tableau de sorte d'avoir les échéances regroupées selon leur type
#  ici on s'intéresse essentiellement aux échéances d'acompte (= "Non imputé")
# --> les echéances acomptes les + élévés en premier
Sorta NBLIG NBLIG Order By CDEFAC(indice), CUR(indice), AMTIPT(indice) Desc

# Filtre les échéances liées aux factures
FILFAC = '[F:DUD]CPY="'+[M]SOCIETE+'"'
If [M]SITE<>""
 FILFAC -= '& [F:DUD]FCY="'+[M]SITE+'"'
Endif
FILFAC -= '& [F:DUD]BPRPAY="'+[M]TIERS+'"'
FILFAC -= '& [F:DUD]FLGCLE=1'
#FILFAC -= '& [F:DUD]DUDSTA=2'
#FILFAC -= '& [F:DUD]BPRTYP='+num$([M]CLIFOU)
Case [M]CLIFOU
 When 1 : FILFAC -= '& [F:DUD]SNS>0'
 When 2 : FILFAC -= '& [F:DUD]SNS<0'
Endcase
FILFAC -= '& [F:HAE]FLGREP<>2'
FILFAC -= '& [F:DUD]BPRFCT=""'

Link [DUD] With [DAE]DAE2=[F:DUD]ACCNUM , [HAE]HAE0=[F:DAE]TYP;[F:DAE]NUM
& As [LNK2]
& Where evalue(FILFAC)
& Order By Key CLE = [F:DUD]CUR Desc ; [F:DUD]DUDDAT

# Sous LNK2, on liste les échéances de factures triées par Devise et Date d'échéance
# --> les échéances de factures les + anciennes en premier
# (Possibilité de choix via un paramètre ?)

Raz RSTECH, RSTREG

# Lecture de l'échéance facture
Read [LNK2]First
If fstat : End : Endif

Raz I
INTERM = [M]NBLIG
While I<INTERM

 # Plus de règlement d'acompte
 If [M]CDEFAC(I)<>3 : Break : Endif

 ##########################################################################
 ## Mise à jour des variables pour l'imputation :                         #
 #  Montant déjà imputé sur le règlement de l'échance d'acompte           #
 #     AMTCUR = Montant total du règlement                                #
 #     AMTIPT = Acompte (initialisation faîte lors de la 1ere lecture)    #
 ##########################################################################

 If I=0 | ![M]NEWACP(I)
  RSTREG = [M]AMTCUR(I)-[M]AMTIPT(I)
  [M]OAMTIPT(I) = [M]AMTIPT(I)
 Else
  RSTREG += [M]AMTIPT(I-1)
  [M]OAMTIPT(I) -= [M]AMTIPT(I-1)
 Endif

 ##########################################################################
 ## Mise à jour des variables pour l'imputation :                         #
 #     AMTCUR = Montant de l'échéance de facture                          #
 ##########################################################################
 If I=0
  RSTECH = [F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR
 Elsif [M]INVNUM(I-1)=[F:DUD]ACCNUM & [M]INVLIG(I-1)=[F:DUD]DUDLIG
  RSTECH -= [M]AMTIPT(I-1)
 Else
  RSTECH = [F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR
 Endif

 ##########################################################################
 # Affectation d'une facture ayant la même devise...
 ##########################################################################
 If [M]CUR(I) = [F:DUD]CUR
  Gosub AFF_FACT
  # Soit le montant imputé solde l'échéance d'acompte & l'échéances facture
  If [M]AMTCUR(I)=RSTREG + [M]AMTIPT(I) & RSTECH=[M]AMTIPT(I)
   # Lecture de l'échéanche facture
   Read [LNK2] Next
   If fstat : Break : Endif
   # Soit le montant imputé ne solde pas l'échéance acompte...
  Elsif [M]AMTCUR(I)>RSTREG+[M]AMTIPT(I)
   # Création d'une nouvelle échéance d'acompte (reliquat)
   Insa I+1 NBLIG
   [M]NBLIG += 1 : INTERM +=1
   [M]CDEFAC(I+1)  = 3        # Pour l'instant, je l'indique à 'Non imputé'
   [M]OCDEFAC(I+1) = [M]CDEFAC(I+1)
   [M]CUR(I+1)     = [M]CUR(I)
   [M]AMTCUR(I+1)  = [M]AMTCUR(I)
   [M]AMTIPT(I+1)  = [M]AMTCUR(I)
   [M]OAMTIPT(I+1) = [M]OAMTIPT(I)
   [M]FCYLIN(I+1)  = [M]FCYLIN(I)
   [M]REF(I+1)     = [M]REF(I)
   [M]TYP(I+1)     = [M]TYP(I)
   [M]NUM(I+1)     = [M]NUM(I)
   [M]VAT(I+1)     = [M]VAT(I)
   [M]DUDNUM(I+1)  = [M]DUDNUM(I)
   [M]DUDLIG(I+1)  = [M]DUDLIG(I)
   [M]ECHNUM(I+1)  = [M]ECHNUM(I)
   [M]ECHLIG(I+1)  = [M]ECHLIG(I)

   # Quelle numéro de ligne ?
   # Tenir compte des échances d'acompte (>1 possible pour un même regl.) + échances de reliquat.
   If I=0 | [M]REF(I) <> [M]REF(I-1)
    Filter [PYD2] Where NUM=[M]REF(I)
    Read [PYD2]PYD0 Last
    Filter [PYD2]
    NUMACP = [F:PYD2]LIN+1
   Else
    NUMACP += 1
   Endif

   [M]LIGREG(I+1) = NUMACP

   # Signale que c'est une echéance reliquat
   [M]NEWACP(I+1) = 1

   # Lecture de l'échéance facture
   Read [LNK2] Next
   If fstat : Break : Endif

   # Soit le montant imputé ne solde pas l'échéance...

  Else
   # Pas de lecture, on réutilise l'échéance facture
  Endif

  # On passe à une autre échéance d'acompte
  I+=1

 # Soit la devise de l'échéance acompte < devise de l'échéance facture
 Elsif [M]CUR(I) < [F:DUD]CUR

  # Lecture de l'échéance facture
  Read [LNK2] Next
  If fstat : Break : Endif

  # Soit la devise de l'échéance acompte > devise de l'échéance facture
 Else
  # Lecture de l'échéance acompte
  I+=1
 Endif
Wend
Affzo [IPT]20
MODIF=1
End

$AFF_FACT
# Suite à la suggestion 17325... : vérifier que l'échéance n'est pas en cours de lettrage,
Filter [MTB] Where ACCNUM=[F:DUD]ACCNUM & DUDLIG=[F:DUD]DUDLIG
Look [MTB]MTB0 First
Filter [MTB]
If !fstat : Return : Endif
[M]OCDEFAC(I) = [M]CDEFAC(I)
[M]CDEFAC(I)  = 2
[M]VCRTYP(I)  = [F:DUD]TYP
[M]ONUMERO(I) = [M]NUMERO(I)
[M]NUMERO(I)  = [F:DUD]NUM
[M]INVNUM(I)  = [F:DUD]ACCNUM
[M]INVLIG(I)  = [F:DUD]DUDLIG
[M]BPRINV(I)  = [F:DUD]BPR
[M]BPRSACINV(I) = [F:DUD]SAC

If RSTECH>=[M]AMTCUR(I)-RSTREG
 MONTIMP = [M]AMTCUR(I)-RSTREG
Else
 MONTIMP = RSTECH
Endif

[M]AMTIPT(I)  = MONTIMP
Return

################################################################################
# Etiquettes de l'écran
################################################################################
Subprog C_FCY(VALEUR)
Variable Char VALEUR
If VALEUR=""
 Call CONTALLFCY([M]SOCIETE) From CPTSUB : # Accès à tous les sites de la société ?
Endif
End

########################################
Subprog C_CDEFAC(VALEUR)
Variable Integer VALEUR
Local Integer NOL
NOL=nolign-1

# Il faut affecter les échéances d'acompte les unes après les autres pour un même règlement.
# Si on désimpute une échéance, les échéances suivantes de reliquat (s'il y en a) sont désimputées.
If [M]CDEFAC(NOL)<>3 & VALEUR=3
 For I=NOL+1 To [M]NBLIG-1
  If [M]NEWACP(I) : [M]CDEFAC(I)=3 : Affzo [M]CDEFAC(I) : Else : Break : Endif
 Next
Endif

# Si on impute une échéance de reliquat, les précédentes doivent être imputées.
If NOL=0 : End : Endif
If VALEUR<>3 & [M]NEWACP(NOL)
 If [M]CDEFAC(NOL-1)=3
  GMESSAGE=mess(138,121,1)        # Imputer la ligne précédente
  mkstat=2 : End
 Endif
Endif
End


########################################
Subprog AS_VCRTYP(VALEUR)
Variable Char    VALEUR()
If [M]CDEFAC(nolign-1)<>2 : mkstat = 1 : End : Endif
End

########################################
Subprog AS_NUMERO(VALEUR)
Variable Char    VALEUR()
If [M]CDEFAC(nolign-1)=3 : mkstat = 1 : End : Endif
End

Subprog C_NUMERO(VALEUR)
Variable Char     VALEUR
Local Char    SITE(GLONFCY) , PAYEUR(GLONBPR) , DEVISE(GLONCUR)
Local Integer IND , FLAG , SENS
IND = indice
Case [M]CDEFAC(IND)
 When 1
  Case [M]CLIFOU
   When 1 : # Cde cli
    Call LECTURE("SOH",VALEUR,"") From CONTOBJ
    SITE   = [F:SOH]SALFCY
    PAYEUR = [F:SOH]BPCPYR
    DEVISE = [F:SOH]CUR
    FLAG   = [F:SOH]INVSTA
    SENS   = +1
   When 2
    Call LECTURE("POH",VALEUR,"") From CONTOBJ
    SITE   = [F:POH]POHFCY
    PAYEUR = [F:POH]BPRPAY
    DEVISE = [F:POH]CUR
    FLAG   = [F:POH]INVFLG
    SENS   = -1
    If !fstat & [F:POH]POHTYP<>1 : GMESSAGE=mess([F:POH]POHTYP,506,1) : mkstat=2 : End : Endif
  Endcase
  If fstat : # Commande client/fournisseur inexistante
   GMESSAGE = mess([M]CLIFOU,659,1)-mess(20,117,1) : mkstat = 2 : End
  Endif
  Call LECTURE("FCY",SITE,"") From CONTOBJ
  If [F:FCY]LEGCPY<>[M]SOCIETE
   # Commande client/fournisseur de la société CPY
   GMESSAGE = mess([M]CLIFOU,659,1)-mess(5,117,1)-[F:FCY]LEGCPY : mkstat = 2 : End
  Elsif [M]SITE<>"" & [F:FCY]FINRSPFCY<>[M]SITE
   # Commande client/fournisseur du site FCY
   GMESSAGE = mess([M]CLIFOU,659,1)-mess(4,117,1)-[F:FCY]FINRSPFCY : mkstat = 2 : End
  Endif
  If PAYEUR<>[M]TIERS
   GMESSAGE = mess(1,672,1)-":"-PAYEUR : mkstat = 2 : End
  Endif
  If DEVISE<>[M]CUR(nolign-1)
   GMESSAGE = mess(84,116,1)-":"-DEVISE : mkstat = 2 : End
  Endif
  If FLAG=3
   GMESSAGE = mess(57,117,1) : mkstat = 2 : End
#  Commande totalement facturée
  Endif
 When Default : # Pièce comptable
  Case [M]CLIFOU
   When 1 : SENS   = +1
   When 2 : SENS   = -1
  Endcase
  Call LECTURE("GAS",VALEUR,[M]VCRTYP(IND)) From CONTOBJ
  If fstat : # Pièce comptable inexistante
   GMESSAGE = mess(3,659,1)-mess(20,117,1) : mkstat = 2 : End
  Endif
  If [F:HAE]CPY<>[M]SOCIETE : # Pièce comptable de la societe
   GMESSAGE = mess(3,659,1)-mess(5,117,1)-[F:HAE]CPY : mkstat = 2 : End
  Elsif [M]SITE<>"" & [F:HAE]FCY<>[M]SITE
   GMESSAGE = mess(3,659,1)-mess(4,117,1)-[F:HAE]FCY : mkstat = 2 : End
  Endif
  If [F:HAE]FLGREP=2 : # Pièce de fin d'exercice
   GMESSAGE = mess(20,121,1) : mkstat = 2 : End
  Endif
  If [F:HAE]CUR<>[M]CUR(nolign-1)
   GMESSAGE = mess(84,116,1)-":"-[F:HAE]CUR : mkstat = 2 : End
  Endif
  Filter [DUD2] Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM & BPRPAY=[M]TIERS & SNS=SENS & FLGCLE=1 & BPRFCT=''
  Read [DUD2] First
  If !fstat
   If [M]CLIFOU=1 & dim(GSDDMGT)>0 & GSDDMGT=2  & [M]UMRNUM(IND)<>"" & [F:DUD2]UMRNUM<>[M]UMRNUM(IND)
    GMESSAGE = mess(279,117,1)-[M]UMRNUM(IND)
    mkstat=2
   Endif
   [M]INVNUM(nolign-1) = [F:DUD2]ACCNUM
   [M]INVLIG(nolign-1) = [F:DUD2]DUDLIG
   [M]BPRINV(nolign-1)  = [F:DUD2]BPR
   [M]BPRSACINV(nolign-1) = [F:DUD2]SAC
  Else
   GMESSAGE = mess(45,117,1) : mkstat = 2  # Pas d'échéance
  Endif
  Filter [DUD2]
  If mkstat=2 : End : Endif
  # Suite à la suggestion 17325... : vérifier que l'échéance n'est pas en cours de lettrage,
  Filter [MTB] Where ACCNUM=[M]INVNUM(IND) & DUDLIG=[M]INVLIG(IND)
  Look [MTB]MTB0 First
  Filter [MTB]
  If !fstat
   GMESSAGE=mess(70,119,1) : mkstat=2 : End   :# Echéance en cours de lettrage
  Endif
Endcase
End

########################################
Subprog AS_AMTIPT(VALEUR)
Variable Decimal VALEUR
If [M]CDEFAC(nolign-1)=3
 VALEUR = [M]OAMTIPT(nolign-1)
 mkstat = 2 : End
Endif
End

########################################
Subprog C_AMTIPT(VALEUR)
Variable Decimal VALEUR
Local Decimal  AMTR, AMTC, AMTI
Local Integer NOL
Raz AMTR
Raz AMTC
NOL=nolign-1

If [M]CLIFOU=1 & dim(GSDDMGT)>0 & GSDDMGT=2  & [M]UMRNUM(NOL)<>""
 Filter [DUD3] Where TYP = [M]VCRTYP(NOL) and NUM = [M]NUMERO(NOL)
 For [DUD3]DUD0
  If [F:DUD3]FLGCLE=1
   If [F:DUD3]UMRNUM=[M]UMRNUM(NOL)
    AMTR +=  [F:DUD3]TMPCUR+[F:DUD3]PAYCUR
    AMTC +=  [F:DUD3]AMTCUR
   Else
    Break
   Endif
  Endif
 Next
 If AMTC*(VALEUR+AMTR-AMTC)>0
  GMESSAGE=mess(56,117,1)-num$(AMTC-AMTR) : mkstat = 2     # Sur-règlement non autorisé
 Endif
Else
 # Bug 12741 : Controle du montant imputé maximum accepté.
 Filter [DUD3] Where TYP = [M]VCRTYP(NOL) and NUM = [M]NUMERO(NOL)
 For [DUD3]DUD0
    AMTR +=  [F:DUD3]TMPCUR+[F:DUD3]PAYCUR
    AMTC +=  [F:DUD3]AMTCUR
 Next
 If AMTC*(VALEUR+AMTR-AMTC)>0
   GMESSAGE=mess(56,117,1)-num$(AMTC-AMTR) : mkstat = 2     # Sur-règlement non autorisé
 Endif
Endif
Filter [DUD3]
If mkstat=2 : End : Endif

###################################################################################
# Si modification du pré chargement (Suggestion V140) : Contrôles supplémentaires #
###################################################################################
###################################################################################
# 1 - Somme des montants imputée ne doit pas dépasser le montant de l'échance de facture
###################################################################################
For I=0 To [M]NBLIG-1
 If [M]INVNUM(I)=[M]INVNUM(NOL) & [M]CDEFAC(I)<>3
  If I=NOL : AMTI +=  VALEUR
  Else       AMTI +=  [M]AMTIPT(I)
  Endif
 Endif
Next

If AMTC*(AMTI+AMTR-AMTC)>0
 GMESSAGE=mess(56,117,1)-num$(AMTI-AMTR) : mkstat = 2 : End      # Sur-règlement non autorisé
Endif

###################################################################################
###################################################################################

If VALEUR>[M]OAMTIPT(NOL)
 GMESSAGE = mess(76,196,1)-num$([M]OAMTIPT(NOL))    # Montant supérieur au maximum autorisé
 mkstat = 2 : End
Endif

###################################################################################
# Si modification du pré chargement (Suggestion V140) : Contrôles supplémentaires #
###################################################################################
###################################################################################
# 2 - Somme des montants imputée ne doit pas dépasser le montant de l'échance d'acompte.
###################################################################################
# Si je modifie un montant, je dois mettre à jour le montant maximum autotisé OAMTIPT
# Contôles des échéances d'acompte de reliquat
###################################################################################
If NOL = [M]NBLIG-1 | VALEUR-[M]AMTIPT(NOL)=0 : End : Endif

For I=NOL To [M]NBLIG-2
 If [M]ECHNUM(NOL)=[M]ECHNUM(I+1) & [M]NEWACP(I+1)
  [M]OAMTIPT(I+1) -=VALEUR-[M]AMTIPT(NOL)
  If [M]OAMTIPT(I+1)<=0
   Raz [M]AMTIPT(I+1), OAMTIPT(I+1)
   [M]CDEFAC(I+1)=3
   Affzo [M]AMTIPT(I+1), OAMTIPT(I+1), CDEFAC(I+1)
  Elsif [M]AMTIPT(I+1)>[M]OAMTIPT(I+1)
   [M]AMTIPT(I+1)=[M]OAMTIPT(I+1)
    Affzo [M]AMTIPT(I+1)
  Endif
 Else
  Break
 Endif
Next
End


##########################################################################
## Etiquette ajoutée par le superviseur 05/05/2003 15:06:31 (CP)
##########################################################################
Subprog AM_AMTIPT(VALEUR)
Variable Decimal VALEUR
Local Integer NOL

NOL=nolign-1
# Suggestion 17328 : Gestion dynamique des reliquats

# Si aucun reliquat...
If VALEUR=[M]OAMTIPT(NOL) : End : Endif

# Si le réglement a déjà été dupliqué (option "Affectation")
#If [M]NBLIG>1 & [M]REF(NOL)=[M]REF(NOL+1) : End : Endif ## SDD

# Sinon... création d'un reliquat.
Insa NOL+1 NBLIG
[M]NBLIG += 1
[M]CDEFAC(NOL+1)  = 3
[M]OCDEFAC(NOL+1) = [M]CDEFAC(NOL+1)
[M]CUR(NOL+1)     = [M]CUR(NOL)
[M]AMTCUR(NOL+1)  = [M]AMTCUR(NOL)
[M]OAMTIPT(NOL+1) = [M]OAMTIPT(NOL)-VALEUR
[M]AMTIPT(NOL+1)  = [M]OAMTIPT(NOL+1)
[M]FCYLIN(NOL+1)  = [M]FCYLIN(NOL)
[M]REF(NOL+1)     = [M]REF(NOL)
[M]TYP(NOL+1)     = [M]TYP(NOL)
[M]NUM(NOL+1)     = [M]NUM(NOL)
[M]VAT(NOL+1)     = [M]VAT(NOL)
[M]DUDNUM(NOL+1)  = [M]DUDNUM(NOL)
[M]DUDLIG(NOL+1)  = [M]DUDLIG(NOL)
[M]ECHNUM(NOL+1)  = [M]ECHNUM(NOL)
[M]ECHLIG(NOL+1)  = [M]ECHLIG(NOL)
[M]LIGREG(NOL+1)  = [M]LIGREG(NOL)
If dim([M]UMRNUM)>0
 [M]UMRNUM(NOL+1) =  [M]UMRNUM(NOL)
Endif

[M]NEWACP(NOL+1) = 1

# Mettre à jour numéro de ligne...
For I=nolign+1 To [M]NBLIG-1
 If [M]REF(I)=[M]REF(I+1)
  [M]LIGREG(I) = [M]LIGREG(I-1)+1
 Else
  Break
 Endif
Next

[M]AMTIPT(NOL)=VALEUR
Affzo [IPT]20
End

###################################################################################
# Initialisation des cours (V140 : Demande 18988)                                 #
###################################################################################
$INIT_COURS
Local Char LFCY(GLONFCY)
Local Char OPT(1)
# Recherche de la société
Read [FCY]FCY0 = [M:HAE0]FCY
If [F:FCY]FINFLG<>2
 LFCY = [F:FCY]FINRSPFCY : # Site financier
 Read [FCY]FCY0 = LFCY
Endif
Filter [F:CPY]
Read [CPY]CPY0 = [F:FCY]LEGCPY
[M:HAE0]CPY = [F:FCY]LEGCPY
Read [CPY]CPY0 = [F:FCY]LEGCPY

Call PARAM([F:CPY]CPY,"CHGRATIPT",OPT) From ADOVAL

# OPT="1" : Cours de la facture
# OPT="2" : Cours du règlement
# OPT="3" : Cours du règlement revalorisé

If OPT="3" : Return : Endif
If clalev([F:XHA])=0 : Local File GACCENTRY  [XHA] : Endif
Case OPT
 When "1"     : Read [XHA]HAE0 = [F:DUD2]TYP;[F:DUD2]NUM
 When Default : Read [XHA]HAE0 = [F:DUD]TYP;[F:DUD]NUM
Endcase
If OPT<>"3"
 For I=0 To dim([F:XHA]RATDIV)-1
  [M]RATDIV(I) = [F:XHA]RATDIV(I)
  [M]RATMLT(I) = [F:XHA]RATMLT(I)
 Next
 [M]RATDAT = [F:XHA]ACCDAT
Endif
[M]TYPRAT = [F:XHA]TYPRAT
Return


$ERREUR
#################################
ERR = errn
Resume
Return

$OUV_LIN
# En standard, la pièce ACPTE est liée à GACCENTRYD/GACCENTRYA
# ce qui permet d'aller rechercher des informations si pièce est gérénée => cas de l'appel directement via l'Imputation d'compte
# Dans le cas inverse, lorsque la pièce n'est pas générée, les inforamtions DAE/DAA sont sous les tabels temporaires.
#   (cas d'une validation de facture liée à un acompte).
If LIG=0
 If PCEOK=1
  Onerrgo ERREUR
  Local File GACCENTRYD [TB1] : TABSEC=1
  Onerrgo
  If ERR : TABSEC=0 : Endif
  Onerrgo ERREUR
  Local File GACCENTRYA [TB2] : TABANA=1
  Onerrgo
  If ERR : TABANA=0 : Endif
 Elsif PCEOK=2
  Onerrgo ERREUR
  Local File GACCTMPD [TB1] : TABSEC=2
  Onerrgo
  If ERR : TABSEC=0 : Endif
  Onerrgo ERREUR
  Local File GACCTMPA [TB2] : TABANA=2
  Onerrgo
  If ERR : TABANA=0 : Endif
 Endif
Elsif LIG=1
  If PCEOK
   Close Local File [TB0]
   Local File GACCENTRYD [TB0]
  Endif
  Onerrgo ERREUR
  Local File GACCENTRYD [TB1] : TABSEC=1
  Onerrgo
  If ERR : TABSEC=0 : Endif
  Onerrgo ERREUR
  Local File GACCENTRYA [TB2] : TABANA=1
  Onerrgo
  If ERR : TABANA=0 : Endif
Endif
Return

$ANA_LIN
If TABANA & [M:HAE2]DSP(LIG)=""
 For [TB2]
  Call LIGANA(LIG,STAT,MESSA) From TRTPCE
  If STAT : Break : Endif
 Next
 If STAT : Return : Endif
 Call FINREP(LIG) From TRTPCE
Endif
Return

$ANA2_LIN
If [M:HAE2]DSP(LIG)=""
 Call LIGANA(LIG,STAT,MESSA) From TRTPCE
 If STAT : Return : Endif
 Call FINREP(LIG) From TRTPCE
Endif
Return

$FER_LIN
If TABSEC : Close Local File [TB1] : Raz TABSEC : Endif
If TABANA : Close Local File [TB2] : Raz TABANA : Endif
Return

