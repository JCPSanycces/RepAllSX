#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion objet RPA
######################################################################################
## Etiquette ajoutée par le superviseur (Objet RPA) 28/11/2011 16:57:47 (VPO)
######################################################################################
$ACTION
  Case ACTION
    When "RAZCRE"    : Gosub RAZCRE
    When Default
  Endcase
Return

######################################################################################

$RAZCRE
  [M:RPA1]ITMSRT      =1 : # Tri par article
  Affzo [M:RPA1]
Return

# Issue 99586 - 2014-25-04 by RBA : Volumes managment evolution
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
  If GBATCH & VALEUR=1
    GMESSAGE = mess(163,141,1)
    mkstat = 2 : End
  Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
  If VALEUR=1
    Raz [M]VOLFILWRK
    Grizo [M]VOLFILWRK
  Else
    Actzo [M]VOLFILWRK
  Endif
  Affzo [M]VOLFILWRK
End

Subprog C_VOLFILWRK(VALEUR)
Variable Char    VALEUR()
  Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
  mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]DRTWRK,E_TYPE_FOLDER,GMESSAGE)
End
#/ Issue 99586 - 2014-25-04 by RBA : Volumes managment evolution
