##Local Integer ARET_VALUE
#
#Local Instance INSOPP Using C_OPPOR
#Local Instance TECPTETAS Using C_TECPTETAS
#
#  [L]ARET_VALUE = [V]CST_AOK # Issue X3-66474 - 2018-02-02 by SINGC/FGR
#  # -----------------------------
#  TECPTETAS = NewInstance C_TECPTETAS AllocGroup null
#  INSOPP = NewInstance C_OPPOR AllocGroup null
#  # -----------------------------
#  If this.ASTALIN = [V]CST_ANEW or this.ASTALIN = [V]CST_ADEL or
#&  (this.ASTALIN = [V]CST_AUPD and (this.PTEQTY <> this.snapshot.PTEQTY or this.PIMPBUCOD <> this.snapshot.PIMPBUCOD or
#&  this.PIMTASCOD <> this.snapshot.PIMTASCOD or this.OPENUM <> this.snapshot.OPENUM or this.PTEUOM <> this.snapshot.PTEUOM))
#& Then
#    [L]ARET_VALUE = max([L]ARET_VALUE, fmet INSOPP.PJM_TASK_TIMEENTRY(this.OPPNUM, this, TECPTETAS))
#  Endif
#  FreeGroup TECPTETAS
#  FreeGroup INSOPP
#Return

#######################################################################################
# Issue X3-111733 - 2018-10-08 by FGR : BEGIN
$_PJM_TASK_TIMEENTRY
#Variable Instance PARENTLVL Using OBJECT
#Local Integer ARET_VALUE

Local Instance INSOPP Using C_OPPOR
Local Instance TECPTETAS Using C_TECPTETAS
Local Integer IRET

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  TECPTETAS = NewInstance C_TECPTETAS AllocGroup null
  INSOPP = NewInstance C_OPPOR AllocGroup null
  # -----------------------------
  If fmet this._PJM_TASK_TIMEENTRY_TOUPDATE() = [V]CST_AYES Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet INSOPP.PJM_TASK_TIMEENTRY(this.OPPNUM, this, TECPTETAS))
    If [L]ARET_VALUE <> [V]CST_AOK Then
      IRET = func SYRSTACKTOOLS.MSGSTACK_COPY_TO(INSOPP, PARENTLVL)
    Endif
  Endif
  FreeGroup TECPTETAS
  FreeGroup INSOPP
Return
# Issue X3-69372 - 2018-03-28 by SINGC : END

#$_PJM_TASK_TIMEENTRY
##Variable Instance PARENTLVL Using C_PJMTIMEMPH : # Issue X3-111733 - 2018-10-08 by FGR
##Local Integer ARET_VALUE
#
#Local Instance INSOPP Using C_OPPOR
#Local Instance TECPTETAS Using C_TECPTETAS
#Local Integer IRET # Issue X3-85806 - 2018-06-06 by FGR
#
#  [L]ARET_VALUE = [V]CST_AOK
#  # -----------------------------
#  TECPTETAS = NewInstance C_TECPTETAS AllocGroup null
#  INSOPP = NewInstance C_OPPOR AllocGroup null
#  # -----------------------------
#  If fmet this._PJM_TASK_TIMEENTRY_TOUPDATE() = [V]CST_AYES Then
#    # Issue X3-85806 - 2018-06-06 by FGR : BEGIN
#    [L]ARET_VALUE = max([L]ARET_VALUE, fmet INSOPP.PJM_TASK_TIMEENTRY(this.OPPNUM, this, TECPTETAS))
#    # Issue X3-111733 - 2018-10-08 by FGR : BEGIN was missing
#    If [L]ARET_VALUE <> [V]CST_AOK Then
#      IRET = func SYRSTACKTOOLS.MSGSTACK_COPY_TO(INSOPP, PARENTLVL)
#    Endif
#    # Issue X3-111733 - 2018-10-08 by FGR : END
#    #    IRET = fmet INSOPP.PJM_TASK_TIMEENTRY(this.OPPNUM, this, TECPTETAS)
#    #    [L]ARET_VALUE = max([L]ARET_VALUE, IRET)
#    #    If IRET <> [V]CST_AOK Then
