#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class PJMTIMEMP
###################################################################################################
# METHODS
###################################################################################################
$SETERROR
#Value Char PRO ()
#Value Char MES ()
#Value Integer STA
#Local Integer ARET_VALUE

Local Char SLEVEL(250)

  # Issue X3-62154 - 2017-11-06 by TEJAC
  SLEVEL = func AFNC.MES4(mess(995,2260,1), this.CLB, this.OPPNUM, format$(GFMDAT, this.PTEDAT), num$(this.PTESEQ))
  #[L]ARET_VALUE = fmet this.ASETERROR (PRO, SLEVEL + "\" + MES, STA)                                                    # Issue X3-85933 - 2018-06-19 by FGR
  [L]ARET_VALUE = fmet this.ASETERROR (func OPPOR_CSTD_PROGS_COM.GET_PROPERTY_TITLE(this, PRO), SLEVEL + "\" + MES, STA) # Issue X3-85933 - 2018-06-19 by FGR
Return

###################################################################################################
$GET_PJMPCC
#Variable Char SPJMPCC
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK # Issue X3-66474 - 2018-02-02 by SINGC/FGR
  If this.OPENUM > 0 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._GET_PJMPCC_OPER(SPJMPCC))
  Elsif this.PIMTASCOD <> AVOID.ACHAR Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._GET_PJMPCC_TASK(SPJMPCC))
  Else
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._GET_PJMPCC_EMPLOYEE(SPJMPCC))
  Endif
Return

###################################################################################################
$_GET_PJMPCC_OPER
#Variable Char SPJMPCC
#Local Integer ARET_VALUE

Local Char SFCY(GLONFCY)
Local Integer IFOUND

  [L]ARET_VALUE = [V]CST_AOK # Issue X3-66474 - 2018-02-02 by SINGC/FGR
  # -----------------------------
  Local File PIMPL [PIM]
  Local File PJMTSKOPE [PTKO]
  Local File WORKSTATIO [MWS]
  # -----------------------------
  # 1. READ THE RESOURCE/WORK CENTER AND APPLY THE COST TYPE
  IFOUND = [V]CST_ANO
  # -----------------------------
  Read [PIM]PIM0=this.PIMTASCOD
  Read [PTKO]PTKO0=[F:PIM]OPPNUM;[F:PIM]TASCOD;this.OPENUM;this.OPESPLNUM
  # -----------------------------
  If [F:PTKO]EXTWST <> AVOID.ACHAR Then
    For SFCY = this.FCY, ""
      Read [F:MWS]WST0=[F:PTKO]EXTWST;SFCY
      If !fstat Then
        If [F:MWS]PCCCOD <> AVOID.ACHAR Then
          IFOUND = [V]CST_AYES
          SPJMPCC = [F:MWS]PCCCOD
        Endif
        Break
      Endif
    Next SFCY
  Endif
  If IFOUND = [V]CST_ANO Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._GET_PJMPCC_TASK(SPJMPCC))
  Endif
Return

###################################################################################################
$_GET_PJMPCC_TASK
#Variable Char SPJMPCC
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK # Issue X3-66474 - 2018-02-02 by SINGC/FGR
  # -----------------------------
  Local File PIMPL [PIM]
  Local File PJMTSK [TAS]
  Local File PJMTSKCAT [CTA]
  # -----------------------------
  Read [PIM]PIM0=this.PIMTASCOD
  Read [F:TAS]PTA0=[F:PIM]OPPNUM;[F:PIM]TASCOD
  Read [F:CTA]CTA0=[F:TAS]TCACOD
  # -----------------------------
  If [F:CTA]PCCCOD <> AVOID.ACHAR Then
    SPJMPCC = [F:CTA]PCCCOD
  Else
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._GET_PJMPCC_EMPLOYEE(SPJMPCC))
  Endif
Return

###################################################################################################
$_GET_PJMPCC_EMPLOYEE
#Variable Char SPJMPCC
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK # Issue X3-66474 - 2018-02-02 by SINGC/FGR
  # -----------------------------
  Local File PJMAUS [PAUS]
  # -----------------------------
  Read [F:PAUS]PAUS = this.CLB
  If [F:PAUS]PCCCOD <> AVOID.ACHAR Then
    SPJMPCC = [F:PAUS]PCCCOD
  Else
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._GET_PJMPCC_DEFAULT(SPJMPCC))
  Endif
Return

###################################################################################################
$_GET_PJMPCC_DEFAULT
#Variable Char SPJMPCC
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK # Issue X3-66474 - 2018-02-02 by SINGC/FGR
  # -----------------------------
  SPJMPCC = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "PCCCOD")
Return

###################################################################################################
$GET_PTEUOM
#Variable Char SPTEUOM
#Local Integer ARET_VALUE

Local Char SFCY(GLONFCY)

  [L]ARET_VALUE = [V]CST_AOK # Issue X3-66474 - 2018-02-02 by SINGC/FGR
  # -----------------------------
  Local File PIMPL [PIM]
  Local File PJMTSKOPE [PTKO]
  Local File WORKSTATIO [MWS]
  Local File PJMCOSTCTR [PCC]
  # -----------------------------
  If this.OPENUM > 0  Then
    Read [PIM]PIM0=this.PIMTASCOD
    Read [PTKO]PTKO0=[F:PIM]OPPNUM;[F:PIM]TASCOD;this.OPENUM;this.OPESPLNUM
    If [F:PTKO]EXTWST <> AVOID.ACHAR Then
      If [F:PTKO]OPEUOM2 <> AVOID.ACHAR Then
        SPTEUOM = [F:PTKO]OPEUOM2
      Else
        For SFCY = this.FCY, ""
          Read [F:MWS]WST0=[F:PTKO]EXTWST;SFCY
          If !fstat Then
            If [F:MWS]PCCCOD <> AVOID.ACHAR Then
              Read [PCC]PCC0 = [F:MWS]PCCCOD
              SPTEUOM = [F:PCC]PCCU
            Endif
            Break
          Endif
        Next SFCY
      Endif
    Endif
  Else
    Read [PCC]PCC0=this.PJMPCC
    If [F:PCC]PCCU <> AVOID.ACHAR Then
      SPTEUOM = [F:PCC]PCCU
    Endif
  Endif
Return

###################################################################################################
$GET_PJMCST
#Value Char CODTYP ()
#Value Date DAT
#Value Char UOM ()
#Value Char CUR ()
#Value Integer CHGTYP
#Value Integer QTY
#Variable Decimal RATE
#Local Integer ARET_VALUE

Local Char SUOMORI(GLONUOM)
Local Char SCURORI(GLONCUR)
Local Decimal DRATE
Local Integer ISTAT
Local Char SPCCCOD(GLONPJCC)
Local Char STIMUOM(GLONUOM)
Local Integer IPJMCSTLAB

  [L]ARET_VALUE = [V]CST_AOK # Issue X3-66474 - 2018-02-02 by SINGC/FGR
  # -----------------------------
  Local File PJMAUS [PAUS]
  # -----------------------------
  IPJMCSTLAB = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "PJMCSTLAB")
  STIMUOM = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "HOURLYUNIT")    # Hour unit given by a folder parameter
  If IPJMCSTLAB = 1 Then          # Employee
    Read [F:PAUS]PAUS=this.CLB
    If [F:PAUS]PAUSCST <> 0 Then
      DRATE = [F:PAUS]PAUSCST     # User hourly rate
      If STIMUOM <> UOM Then
        #Call CONVERT_QTY(this.ACTX, STIMUOM, UOM, DRATE) From TRTX3_SYRA   # Issue X3-6208/119577 - 2016-11-04 by SINGC/FGR
        Call CONVERT_QTY(this.ACTX, UOM, STIMUOM, DRATE) From TRTX3_SYRA    # Issue X3-6208/119577 - 2016-11-04 by SINGC/FGR
      Endif
      ISTAT = 0
      If [F:PAUS]PAUSCUR <> CUR Then
        Call CONVERT(this.ACTX, [F:PAUS]PAUSCUR, CUR, CUR, CHGTYP, DAT, DRATE, DRATE, ISTAT) From TRTDEV_SYRA
        If ISTAT <> 0 Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PJMCST", func AFNC.MES2(mess(393,2260,1), [F:PAUS]PAUSCUR, CUR), [V]CST_AERROR))
        Endif
      Endif
      If ISTAT = 0 Then
        #DRATE *= QTY
        #RATE = arr(DRATE, 10^(- fmet this.ACTX.ACACHE.ACUR.AGETVALNUM(CUR,"CURRND"))) # Issue X3-7540/119858 - 2016-11-18 by SINGC
        RATE = arr(DRATE, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(CUR,"CURRND"))         # Issue X3-7540/119858 - 2016-11-18 by SINGC
      Endif
    Else # [F:PAUS]PAUSCST = 0
      Call GETRATE_FROMDATE(CODTYP, DAT, SUOMORI, SCURORI, DRATE) From PJMCOSTCTR_CSTD_PROGS
      # -----------------------------
      # Issue X3-17072/120786 - 2017-01-09 by TEJAC  : Start
      #If DRATE = 0 Then
        # -----------------------------
        # Use default rate if cost type has no rate
        #[L]ARET_VALUE = fmet this.GET_PJMPCC_DEFAULT(SPCCCOD)
        #Call GETRATE_FROMDATE(SPCCCOD, DAT, SUOMORI, SCURORI, DRATE) From PJMCOSTCTR_CSTD_PROGS
      #Endif
      # Issue X3-17072/120786 - 2017-01-09 by TEJAC  : End
      # -----------------------------
      If SUOMORI <> AVOID.ACHAR and SCURORI <> AVOID.ACHAR Then
        # -----------------------------
        # 1°) Convert regarding the UOM given
        If UOM <> SUOMORI Then
          #Call CONVERT_QTY(this.ACTX, SUOMORI, UOM, DRATE) From TRTX3_SYRA  # Issue X3-6208/119577 - 2016-11-04 by SINGC/FGR
          Call CONVERT_QTY(this.ACTX, UOM, SUOMORI, DRATE) From TRTX3_SYRA   # Issue X3-6208/119577 - 2016-11-04 by SINGC/FGR
        Endif
        # -----------------------------
        # 2°) Convert regarding the CUR given
        ISTAT = 0
        If CUR <> SCURORI Then
          Call CONVERT(this.ACTX, SCURORI, CUR, CUR, CHGTYP, DAT, DRATE, DRATE, ISTAT) From TRTDEV_SYRA
          If ISTAT <> 0 Then
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PJMCST", func AFNC.MES2(mess(393,2260,1), SCURORI, CUR), [V]CST_AERROR))
          Endif
        Endif
        If ISTAT = 0 Then
          #DRATE *= QTY
          #RATE = arr(DRATE, 10^(- fmet this.ACTX.ACACHE.ACUR.AGETVALNUM(CUR,"CURRND"))) # Issue X3-7540/119858 - 2016-11-18 by SINGC
          RATE = arr(DRATE, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(CUR,"CURRND"))         # Issue X3-7540/119858 - 2016-11-18 by SINGC
        Endif
      Else # SUOMORI = AVOID.ACHAR and/ or SCURORI = AVOID.ACHAR
        # Rate can't be found
        RATE = 0
      Endif
    Endif
  Else # IPJMCSTLAB = 2 ----------- Project cost type
    Call GETRATE_FROMDATE(CODTYP, DAT, SUOMORI, SCURORI, DRATE) From PJMCOSTCTR_CSTD_PROGS
    # -----------------------------
    # Issue X3-17072/120786 - 2017-01-09 by TEJAC  : Start
    #If DRATE = 0 Then
      # -----------------------------
      # Use default rate if cost type has no rate
      #[L]ARET_VALUE = fmet this._GET_PJMPCC_DEFAULT(SPCCCOD)
      #Call GETRATE_FROMDATE(SPCCCOD, DAT, SUOMORI, SCURORI, DRATE) From PJMCOSTCTR_CSTD_PROGS
    #Endif
    # Issue X3-17072/120786 - 2017-01-09 by TEJAC  : End
    # -----------------------------
    If SUOMORI <> AVOID.ACHAR and SCURORI <> AVOID.ACHAR Then
      # 1°) Convert regarding the UOM given
      If UOM <> SUOMORI Then
        #Call CONVERT_QTY(this.ACTX, SUOMORI, UOM, DRATE) From TRTX3_SYRA  # Issue X3-6208/119577 - 2016-11-04 by SINGC/FGR
        Call CONVERT_QTY(this.ACTX, UOM, SUOMORI, DRATE) From TRTX3_SYRA  # Issue X3-6208/119577 - 2016-11-04 by SINGC/FGR
      Endif
      # 2°) Convert regarding the CUR given
      ISTAT = 0
      If CUR <> SCURORI Then
        Call CONVERT(this.ACTX, SCURORI, CUR, CUR, CHGTYP, DAT, DRATE, DRATE, ISTAT) From TRTDEV_SYRA
        If ISTAT <> 0 Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PJMCST", func AFNC.MES2(mess(393,2260,1), SCURORI, CUR), [V]CST_AERROR))
        Endif
      Endif
      If ISTAT = 0 Then
        #DRATE *= QTY
        #RATE = arr(DRATE, 10^(- fmet this.ACTX.ACACHE.ACUR.AGETVALNUM(CUR,"CURRND"))) # Issue X3-7540/119858 - 2016-11-18 by SINGC
        RATE = arr(DRATE, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(CUR,"CURRND"))         # Issue X3-7540/119858 - 2016-11-18 by SINGC
      Endif
    Else # SUOMORI = AVOID.ACHAR and/ or SCURORI = AVOID.ACHAR
      Read [F:PAUS]PAUS=this.CLB
      If [F:PAUS]PAUSCST <> 0 Then
        DRATE = [F:PAUS]PAUSCST     # User hourly rate
        If STIMUOM <> UOM Then
          #Call CONVERT_QTY(this.ACTX, STIMUOM, UOM, DRATE) From TRTX3_SYRA  # Issue X3-6208/119577 - 2016-11-04 by SINGC/FGR
          Call CONVERT_QTY(this.ACTX, UOM, STIMUOM, DRATE) From TRTX3_SYRA   # Issue X3-6208/119577 - 2016-11-04 by SINGC/FGR
        Endif
        ISTAT = 0
        If [F:PAUS]PAUSCUR <> CUR Then
          Call CONVERT(this.ACTX, [F:PAUS]PAUSCUR, CUR, CUR, CHGTYP, DAT, DRATE, DRATE, ISTAT) From TRTDEV_SYRA
          If ISTAT <> 0 Then
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PJMCST", func AFNC.MES2(mess(393,2260,1), [F:PAUS]PAUSCUR, CUR), [V]CST_AERROR))
          Endif
        Endif
        If ISTAT = 0 Then
          #DRATE *= QTY
          #RATE = arr(DRATE, 10^(- fmet this.ACTX.ACACHE.ACUR.AGETVALNUM(CUR,"CURRND"))) # Issue X3-7540/119858 - 2016-11-18 by SINGC
          RATE = arr(DRATE, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(CUR,"CURRND"))         # Issue X3-7540/119858 - 2016-11-18 by SINGC
        Endif
      Else # [F:PAUS]PAUSCST = 0
        # Rate can't be found
        RATE = 0
      Endif
    Endif
  Endif
  # -----------------------------
  # Issue X3-17072/120786 - 2017-01-09 by TEJAC  : Start
  #If RATE = 0 Then
  #  [L]ARET_VALUE = fmet this.SETERROR("PJMCST", mess(355,2260,1), [V]CST_AERROR)
  #Endif
  If RATE = 0 Then
    If fmet this.ACTX.APARAM.AGETUSERVALNUM("PJMAUSCST0") <> [V]CST_AYES Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PJMCST", mess(490,2260,1), [V]CST_AERROR))
    Endif
  Endif
  # -----------------------------
  # Issue X3-17072/120786 - 2017-01-09 by TEJAC  : End
Return

###################################################################################################
$GET_CLBPCC
#Variable Char SCLBPCC ()
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK # Issue X3-66474 - 2018-02-02 by SINGC/FGR
  # -----------------------------
  Local File PJMAUS [PAUS]
  # -----------------------------
  Read [F:PAUS]PAUS=this.CLB
  If [F:PAUS]PCCCOD <> AVOID.ACHAR Then
    SCLBPCC = [F:PAUS]PCCCOD     # User cost type
  Else
    If this.PJMPCC <> AVOID.ACHAR
      SCLBPCC = this.PJMPCC
    Else
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.GET_PJMPCC(SCLBPCC))
    Endif
  Endif
Return

###################################################################################################
$GET_CLBCST
#Value Char CODTYP ()
#Value Date DAT
#Value Char UOM ()
#Value Char CUR ()
#Value Integer CHGTYP
#Value Integer QTY
#Variable Decimal RATE
#Local Integer ARET_VALUE

Local Decimal DRATE
Local Integer ISTAT
Local Integer IPJMCST
Local Char SUOMORI(GLONUOM)
Local Char SCURORI(GLONCUR)
Local Char STIMUOM(GLONUOM)
Local Char SPCCCOD(GLONPJCC)

  [L]ARET_VALUE = [V]CST_AOK # Issue X3-66474 - 2018-02-02 by SINGC/FGR
  # -----------------------------
  Local File PJMAUS [PAUS]
  # -----------------------------
  IPJMCST = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "PJMCST")
  STIMUOM = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "HOURLYUNIT")    # Hour unit given by a folder parameter
  If IPJMCST = 1 Then             # Employee
    Read [F:PAUS]PAUS=this.CLB
    If [F:PAUS]PAUSCST <> 0 Then
      DRATE = [F:PAUS]PAUSCST     # User hourly rate
      If STIMUOM <> UOM Then
        # Issue X3-6208/119577 - 2016-11-04 by SINGC/FGR Comment BEGIN
        #   The objective is to convert DRATE from the TE unit (UOM) to the 'Employee labor rate' which is in HOURLYUNIT (STIMUOM)
        #   SINGC is right.
        # Issue X3-6208/119577 - 2016-11-04 by SINGC/FGR Comment END
        #Call CONVERT_QTY(this.ACTX, STIMUOM, UOM, DRATE) From TRTX3_SYRA  # Issue X3-6208/119577 - 2016-11-04 by SINGC/FGR
        Call CONVERT_QTY(this.ACTX, UOM, STIMUOM, DRATE) From TRTX3_SYRA   # Issue X3-6208/119577 - 2016-11-04 by SINGC/FGR
      Endif
      ISTAT = 0
      If [F:PAUS]PAUSCUR <> CUR Then
        Call CONVERT(this.ACTX, [F:PAUS]PAUSCUR, CUR, CUR, CHGTYP, DAT, DRATE, DRATE, ISTAT) From TRTDEV_SYRA
        If ISTAT <> 0 Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("CLBCST", func AFNC.MES2(mess(393,2260,1), [F:PAUS]PAUSCUR, CUR), [V]CST_AERROR))
        Endif
      Endif
      If ISTAT = 0 Then
        #DRATE *= QTY
        #RATE = arr(DRATE, 10^(- fmet this.ACTX.ACACHE.ACUR.AGETVALNUM(CUR,"CURRND"))) # Issue X3-7540/119858 - 2016-11-18 by SINGC
        RATE = arr(DRATE, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(CUR,"CURRND"))         # Issue X3-7540/119858 - 2016-11-18 by SINGC
      Endif
    Else # [F:PAUS]PAUSCST = 0
      Call GETRATE_FROMDATE(CODTYP, DAT, SUOMORI, SCURORI, DRATE) From PJMCOSTCTR_CSTD_PROGS
      # -----------------------------
      #Issue X3-17072/120786 - 2017-01-09 by TEJAC : Start
      #If DRATE = 0 Then
        # -----------------------------
        # Use default rate if cost type has no rate
        #[L]ARET_VALUE = fmet this._GET_PJMPCC_DEFAULT(SPCCCOD)
        #Call GETRATE_FROMDATE(SPCCCOD, DAT, SUOMORI, SCURORI, DRATE) From PJMCOSTCTR_CSTD_PROGS
      #Endif
      #Issue X3-17072/120786 - 2017-01-09 by TEJAC : End
      # -----------------------------
      If SUOMORI <> AVOID.ACHAR and SCURORI <> AVOID.ACHAR Then
        # 1°) Convert regarding the UOM given
        If UOM <> SUOMORI Then
          Call CONVERT_QTY(this.ACTX, SUOMORI, UOM, DRATE) From TRTX3_SYRA  # Issue X3-6208/119577 - 2016-11-04 by SINGC/FGR
          #Call CONVERT_QTY(this.ACTX, UOM, SUOMORI, DRATE) From TRTX3_SYRA # Issue X3-6208/119577 - 2016-11-04 by SINGC/FGR
        Endif
        # 2°) Convert regarding the CUR given
        ISTAT = 0
        If CUR <> SCURORI Then
          Call CONVERT(this.ACTX, SCURORI, CUR, CUR, CHGTYP, DAT, DRATE, DRATE, ISTAT) From TRTDEV_SYRA
          If ISTAT <> 0 Then
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("CLBCST", func AFNC.MES2(mess(393,2260,1), SCURORI, CUR), [V]CST_AERROR))
          Endif
        Endif
        If ISTAT = 0 Then
          #DRATE *= QTY
          #RATE = arr(DRATE, 10^(- fmet this.ACTX.ACACHE.ACUR.AGETVALNUM(CUR,"CURRND"))) # Issue X3-7540/119858 - 2016-11-18 by SINGC
          RATE = arr(DRATE, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(CUR,"CURRND"))         # Issue X3-7540/119858 - 2016-11-18 by SINGC
        Endif
      Else # SUOMORI = AVOID.ACHAR and/ or SCURORI = AVOID.ACHAR
        # Rate can't be found
        RATE = 0
      Endif
    Endif
  Else # IPJMCST = 2 -------------- Project cost type
    Call GETRATE_FROMDATE(CODTYP, DAT, SUOMORI, SCURORI, DRATE) From PJMCOSTCTR_CSTD_PROGS
    # -----------------------------
    #Issue X3-17072/120786 - 2017-01-09 by TEJAC
    #If DRATE = 0 Then
      # -----------------------------
      # Use default rate if cost type has no rate
      #[L]ARET_VALUE = fmet this._GET_PJMPCC_DEFAULT(SPCCCOD)
      #Call GETRATE_FROMDATE(SPCCCOD, DAT, SUOMORI, SCURORI, DRATE) From PJMCOSTCTR_CSTD_PROGS
    #Endif
    #ISSUE X3-17072/120786 - 2017-01-09 By TEJAC
    # -----------------------------
    If SUOMORI <> AVOID.ACHAR and SCURORI <> AVOID.ACHAR Then
      # 1°) Convert regarding the UOM given
      If UOM <> SUOMORI Then
        Call CONVERT_QTY(this.ACTX, SUOMORI, UOM, DRATE) From TRTX3_SYRA  # Issue X3-6208/119577 - 2016-11-04 by SINGC/FGR
        #Call CONVERT_QTY(this.ACTX, UOM, SUOMORI, DRATE) From TRTX3_SYRA # Issue X3-6208/119577 - 2016-11-04 by SINGC/FGR
      Endif
      # 2°) Convert regarding the CUR given
      ISTAT = 0
      If CUR <> SCURORI Then
        Call CONVERT(this.ACTX, SCURORI, CUR, CUR, CHGTYP, DAT, DRATE, DRATE, ISTAT) From TRTDEV_SYRA
        If ISTAT <> 0 Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("CLBCST", func AFNC.MES2(mess(393,2260,1), SCURORI, CUR), [V]CST_AERROR))
        Endif
      Endif
      If ISTAT = 0 Then
        #DRATE *= QTY
        #RATE = arr(DRATE, 10^(- fmet this.ACTX.ACACHE.ACUR.AGETVALNUM(CUR,"CURRND"))) # Issue X3-7540/119858 - 2016-11-18 by SINGC
        RATE = arr(DRATE, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(CUR,"CURRND"))         # Issue X3-7540/119858 - 2016-11-18 by SINGC
      Endif
    Else # SUOMORI = AVOID.ACHAR and/ or SCURORI = AVOID.ACHAR
      Read [F:PAUS]PAUS=this.CLB
      If [F:PAUS]PAUSCST <> 0 Then
        DRATE = [F:PAUS]PAUSCST     # User hourly rate
        If STIMUOM <> UOM Then
          Call CONVERT_QTY(this.ACTX, STIMUOM, UOM, DRATE) From TRTX3_SYRA  # Issue X3-6208/119577 - 2016-11-04 by SINGC/FGR
          #Call CONVERT_QTY(this.ACTX, UOM, STIMUOM, DRATE) From TRTX3_SYRA # Issue X3-6208/119577 - 2016-11-04 by SINGC/FGR
        Endif
        ISTAT = 0
        If [F:PAUS]PAUSCUR <> CUR Then
          Call CONVERT(this.ACTX, [F:PAUS]PAUSCUR, CUR, CUR, CHGTYP, DAT, DRATE, DRATE, ISTAT) From TRTDEV_SYRA
          If ISTAT <> 0 Then
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("CLBCST", func AFNC.MES2(mess(393,2260,1), [F:PAUS]PAUSCUR, CUR), [V]CST_AERROR))
          Endif
        Endif
        If ISTAT = 0 Then
          #DRATE *= QTY
          #RATE = arr(DRATE, 10^(- fmet this.ACTX.ACACHE.ACUR.AGETVALNUM(CUR,"CURRND"))) # Issue X3-7540/119858 - 2016-11-18 by SINGC
          RATE = arr(DRATE, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(CUR,"CURRND"))         # Issue X3-7540/119858 - 2016-11-18 by SINGC
        Endif
      Else # [F:PAUS]PAUSCST = 0
        # Rate can't be found
        RATE = 0
      Endif
    Endif
  Endif
  # -----------------------------
  # Issue X3-17072/120786 - 2017-01-09 by TEJAC  : Start
  # If RATE = 0 Then
  #   [L]ARET_VALUE = fmet this.SETERROR("CLBCST", mess(356,2260,1), [V]CST_AERROR)
  # Endif
  If RATE = 0 Then
    If fmet this.ACTX.APARAM.AGETUSERVALNUM("PJMAUSCST0") <> [V]CST_AYES Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("CLBCST", mess(490,2260,1), [V]CST_AERROR))
    Endif
  Endif
  # -----------------------------
  # Issue X3-17072/120786 - 2017-01-09 by TEJAC  : End
Return

#######################################################################################
$CTRL_PTEDAT
#Value Date DAT
#Local Integer ARET_VALUE

Local Integer IDATCTRL
Local Integer ISTRPRD
Local Integer IENDPRD

  [L]ARET_VALUE = [V]CST_AOK # Issue X3-66474 - 2018-02-02 by SINGC/FGR
  # -----------------------------
  Local File PIMPL [PIM]
  Local File PJMOPEAFF [PJOA]
  # -----------------------------
  IDATCTRL = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, this.FCY, "PJMDATCTRL")
  # -----------------------------
  If IDATCTRL = [V]CST_AYES Then
    ISTRPRD = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, this.FCY, "PJMSTRPRD")
    IENDPRD = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, this.FCY, "PJMENDPRD")
    If this.OPENUM > 0 Then
      Read [PIM]PIM0=this.PIMTASCOD
      Filter [PJOA] Where OPPNUM = [F:PIM]OPPNUM and TASCOD = [F:PIM]TASCOD and OPENUM = this.OPENUM and OPESPLNUM = this.OPESPLNUM and POACLB = this.CLB
      Read [PJOA]First
      If fstat = 0 Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._CTRL_PTEDAT_RAFFT(DAT, ISTRPRD, IENDPRD))
      Else
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._CTRL_PTEDAT_OPER(DAT, ISTRPRD, IENDPRD))
      Endif
      Filter [PJOA]
    Elsif this.PIMTASCOD <> AVOID.ACHAR Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._CTRL_PTEDAT_TASK(DAT, ISTRPRD, IENDPRD))
    Else
      #[L]ARET_VALUE = max([L]ARET_VALUE, fmet this._CTRL_PTEDAT_BUDGET(DAT, ISTRPRD, IENDPRD)) # Budget dates not used for this release
    Endif
  Endif
Return

#######################################################################################
$_CTRL_PTEDAT_RAFFT
#Value Date DAT
#Value Integer DSTR
#Value Integer DEND
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK # Issue X3-66474 - 2018-02-02 by SINGC/FGR
  # -----------------------------
  Local File PIMPL [PIM]
  Local File PJMTSK [PTA]
  Local File PJMTSKOPE [PTKO]
  Local File PJMOPEAFF [PJOA]
  # -----------------------------
  Read [PIM]PIM0=this.PIMTASCOD
  Read [PTA]PTA0=[F:PIM]OPPNUM;[F:PIM]TASCOD
  Read [PTKO]PTKO0=[F:PIM]OPPNUM;[F:PIM]TASCOD;this.OPENUM;this.OPESPLNUM
  Filter [PJOA] Where OPPNUM = [F:PIM]OPPNUM and TASCOD = [F:PIM]TASCOD and OPENUM = this.OPENUM and OPESPLNUM = this.OPESPLNUM and POACLB = this.CLB
  For [PJOA]
    # Start date
    If [F:PJOA]POASTR <> [0/0/0] Then
      # From employee assignment
      If (DAT - [F:PJOA]POASTR) < DSTR Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PTEDAT", func AFNC.MES1(mess(143,2260,1), format$("DD2",DAT)), [V]CST_AWARNING))
      Endif
    Elsif [F:PTKO]OPESTR <> [0/0/0] Then
      # From operation
      If (DAT - [F:PTKO]OPESTR) < DSTR Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PTEDAT", func AFNC.MES1(mess(142,2260,1), format$("DD2",DAT)), [V]CST_AWARNING))
      Endif
    Elsif [F:PTA]TASSTARTDT <> [0/0/0] Then
      # From task
      If (DAT - [F:PTA]TASSTARTDT) < DSTR Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PTEDAT", func AFNC.MES1(mess(144,2260,1), format$("DD2",DAT)), [V]CST_AWARNING))
      Endif
    Endif
    # End date
    If [F:PJOA]POAEND <> [0/0/0] Then
      # From employee assignment
      If (DAT - [F:PJOA]POAEND) > DEND Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PTEDAT", func AFNC.MES1(mess(143,2260,1), format$("DD2",DAT)), [V]CST_AWARNING))
      Endif
    Elsif [F:PTKO]OPEEND <> [0/0/0] Then
      # From operation
      If (DAT - [F:PTKO]OPEEND) > DEND Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PTEDAT", func AFNC.MES1(mess(142,2260,1), format$("DD2",DAT)), [V]CST_AWARNING))
      Endif
    Else
      # From task
      If (DAT - [F:PTA]TASENDDT) > DEND Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PTEDAT", func AFNC.MES1(mess(144,2260,1), format$("DD2",DAT)), [V]CST_AWARNING))
      Endif
    Endif
    Break
  Next
  Filter [PJOA]
Return

#######################################################################################
$_CTRL_PTEDAT_OPER
#Value Date DAT
#Value Integer DSTR
#Value Integer DEND
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK # Issue X3-66474 - 2018-02-02 by SINGC/FGR
  # -----------------------------
  Local File PIMPL [PIM]
  Local File PJMTSK [PTA]
  Local File PJMTSKOPE [PTKO]
  # -----------------------------
  Read [PIM]PIM0=this.PIMTASCOD
  Read [PTA]PTA0=[F:PIM]OPPNUM;[F:PIM]TASCOD
  Read [PTKO]PTKO0=[F:PIM]OPPNUM;[F:PIM]TASCOD;this.OPENUM;this.OPESPLNUM
  # -----------------------------
  # Start date
  If [F:PTKO]OPESTR <> [0/0/0] Then
    # From operation
    If (DAT - [F:PTKO]OPESTR) < DSTR Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PTEDAT", func AFNC.MES1(mess(142,2260,1), format$("DD2", DAT)), [V]CST_AWARNING))
    Endif
  Elsif [F:PTA]TASSTARTDT <> [0/0/0] Then
    # From task
    If (DAT - [F:PTA]TASSTARTDT) < DSTR Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PTEDAT", func AFNC.MES1(mess(144,2260,1), format$("DD2", DAT)), [V]CST_AWARNING))
    Endif
  Endif
  # End date
  If [F:PTKO]OPEEND <> [0/0/0] Then
    # From operation
    If (DAT - [F:PTKO]OPEEND) > DEND Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PTEDAT", func AFNC.MES1(mess(142,2260,1), format$("DD2", DAT)), [V]CST_AWARNING))
    Endif
  Elsif [F:PTA]TASENDDT <> [0/0/0]
    # From task
    If (DAT - [F:PTA]TASENDDT) > DEND Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PTEDAT", func AFNC.MES1(mess(144,2260,1), format$("DD2", DAT)), [V]CST_AWARNING))
    Endif
  Endif
Return

#######################################################################################
$_CTRL_PTEDAT_TASK
#Value Date DAT
#Value Integer DSTR
#Value Integer DEND
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK # Issue X3-66474 - 2018-02-02 by SINGC/FGR
  # -----------------------------
  Local File PIMPL [PIM]
  Local File PJMTSK [PTA]
  # -----------------------------
  Read [PIM]PIM0=this.PIMTASCOD
  Read [PTA]PTA0=[F:PIM]OPPNUM;[F:PIM]TASCOD
  # Start date
  If [F:PTA]TASSTARTDT <> [0/0/0] Then
    # From task
    If (DAT - [F:PTA]TASSTARTDT) < DSTR Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PTEDAT", func AFNC.MES1(mess(144,2260,1), format$("DD2", DAT)), [V]CST_AWARNING))
    Endif
  Endif
  # End date
  If [F:PTA]TASENDDT <> [0/0/0]
    # From task
    If (DAT - [F:PTA]TASENDDT) > DEND Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PTEDAT", func AFNC.MES1(mess(144,2260,1), format$("DD2", DAT)), [V]CST_AWARNING))
    Endif
  Endif
Return

#######################################################################################
$_CTRL_PTEDAT_BUDGET
#Value Date DAT
#Value Integer DSTR
#Value Integer DEND
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK # Issue X3-66474 - 2018-02-02 by SINGC/FGR
  # -----------------------------
  Local File PIMPL [PIM]
  Local File PJMBUD [PBU]
  # -----------------------------
  Read [PIM]PIM0=this.PIMPBUCOD
  Read [PBU]PJBU0=[F:PIM]OPPNUM;[F:PIM]PBUCOD
  # Start date
