#######################################################################################
$_PJM_TASK_TIMEENTRY_TOUPDATE
#Local Integer ARET_VALUE

  # Issue X3-69372 - 2018-03-28 by SINGC
  [L]ARET_VALUE = [V]CST_ANO
  # -----------------------------
  If this.ASTALIN = [V]CST_ANEW or this.ASTALIN = [V]CST_ADEL or
&    (this.ASTALIN = [V]CST_AUPD and
&    (
&     this.PTEQTY <> this.snapshot.PTEQTY or
&     this.PIMPBUCOD <> this.snapshot.PIMPBUCOD or
&     this.PIMTASCOD <> this.snapshot.PIMTASCOD or
&     this.OPENUM <> this.snapshot.OPENUM or
&     this.PTEUOM <> this.snapshot.PTEUOM)
&    )
& Then
    [L]ARET_VALUE = [V]CST_AYES
  Endif
Return

#######################################################################################
$CDIE_DELETE
#Local Integer ARET_VALUE

Local Integer NI

  # Issue X3-66474 - 2018-02-02 by SINGC/FGR
  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  For NI = 1 To maxtab(this.CDIE)
    If this.CDIE(NI) <> null and find(this.CDIE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      ILINE = fmet this.ADELLINE("CDIE", this.CDIE(NI).AORDER)
      If ILINE = [V]CST_ANOTDEFINED Then
        IARENDRE = [V]CST_AERROR
        Break
      Endif
    Endif
  Next NI
Return

#######################################################################################
$DIE_LOAD_INPUT_VALUES
#Variable Instance TECDIECCE Using C_TECDIECCE : #
#Local Integer ARET_VALUE

  # Issue X3-81871 - 2018-03-08 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------
  [L]ARET_VALUE = func OPPORPJM_CSTD_PROGS.LOAD_ANALYTICAL_VALUES(this, TECDIECCE)
Return

