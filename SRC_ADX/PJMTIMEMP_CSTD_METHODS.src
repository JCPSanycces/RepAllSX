    If (DAT - [F:PBU]PBUSTARTDT) < DSTR Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PTEDAT", func AFNC.MES1(mess(145,2260,1), format$("DD2", DAT)), [V]CST_AWARNING))
    Endif
  Endif
  # End date
  If [F:PBU]PBUENDDT <> [0/0/0] Then
    # From budget
    If (DAT - [F:PBU]PBUENDDT) > DEND Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PTEDAT", func AFNC.MES1(mess(145,2260,1), format$("DD2", DAT)), [V]CST_AWARNING))
    Endif
  Endif
Return

