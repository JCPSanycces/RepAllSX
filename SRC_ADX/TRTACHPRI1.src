#<AdxTL>@(#)10.0.0.0 $Revision$
#############################################################################
# TRTACHPRI1             Traitement liés aux prix              Module ACHAT #
# ------------------------------------------------------------------------- #
# Actions sur champs                                                        #
#   - PAMDISCRG     : Chargement des motifs remises/frais tarif             #
#   - PAMPLIFLG     : Choix recalcul tarif des lignes                       #
#   - PAVAMTRPT     : Calcul d'un montant en devise de reporting (EURO)     #
# Sous-programmes :                                                         #
#   - EXPCALPRI     : Explication calcul prix unitaire net                  #
#                     remplacé par l'action VISUCLCPRI de TRTPRICE          #
# ------------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Saisie de fenêtre GSAISIE)                      #
#   - SAIREMFRS  : Saisie remises/frais tarif ligne DA ou commande          #
#   - SAIFRSFAC  : Saisie remises/frais tarif ligne facture                 #
#############################################################################


$ACTION
Case ACTION
 When "OUVRE"
  #--------------------------------------------------------------#
  # Avant la définition des boutons et l'ouverture de la fenêtre #
  #--------------------------------------------------------------#
  Case GACTION
   When "SAIREMFRS"  : Gosub OUV_SAIREMFRS
   When "SAIFRSFAC"  : Gosub OUV_SAIFRSFAC
  Endcase
 When "TITRE"
  #---------------------#
  # Titre de la fenêtre #
  #---------------------#
  Case GACTION
   When "SAIREMFRS"  : TIT=mess(39,195,1)
   When "SAIFRSFAC"  : Gosub TIT_SAIFRSFAC
  Endcase
 When "DEBUT"
  #---------------------------------#
  # Après l'ouverture de la fenêtre #
  #---------------------------------#
  Case GACTION
   When "SAIREMFRS"  : Gosub DEB_SAIREMFRS
   When "SAIFRSFAC"  : Gosub DEB_SAIFRSFAC
  Endcase
 When "OK"
  #------------------------------#
  # Après exécution du bouton OK #
  #------------------------------#
  Case GACTION
   When "SAIREMFRS"  : Gosub OK_SAIREMFRS
   When "SAIFRSFAC"  : Gosub OK_SAIFRSFAC
  Endcase
 When "ABA"
  #-------------------------------------#
  # Après l'exécution du bouton ABANDON #
  #-------------------------------------#
  Case GACTION
   When "SAIREMFRS"  : Gosub ABA_SAIREMFRS
   When "SAIFRSFAC"  : Gosub ABA_SAIFRSFAC
  Endcase
 When "APRES_MODIF"
  #------------------------------------#
  # Après chaque modification de champ #
  #------------------------------------#
  Case GACTION
   When "SAIREMFRS"  : REP = "M"
   When "SAIFRSFAC"  : REP = "M"
  Endcase
 When "FINSAI"
  #------------------------------------------#
  # Avant de revenir à la fenêtre précédente #
  #------------------------------------------#
  Case GACTION
   When "SAIREMFRS"  : Gosub FINSAI_SAIREMFRS
   When "SAIFRSFAC"  : Gosub FINSAI_SAIFRSFAC
  Endcase
Endcase
Return


########################################################################
# REMFRS_LIG : S/P saisie remises-frais tarif ligne cde   MBT 12/02/98 #
#   WABMSK   : Abréviation du masque écran contenant les lignes        #
#   NOL      : Indice de la ligne à traiter (nolign-1)                 #
# -------------------------------------------------------------------- #
# Remplacé par m'action SAIREMFRS avec paramètres :                    #
#   zone courante AZC : PU net si DA ou PU brut si commande            #
#   PARAM(1) = WABMSK : Abréviation du masque contenant les lignes     #
#   PARAM(2) = NOLIG  : Indice de la ligne à traiter (nolign-1)        #
########################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_SAIREMFRS
Local  Char     WABMSK(4) : WABMSK =PARAM(1)
Local  Shortint NOL       : NOL=val(PARAM(2))
#----- Variables locales -----#
Local  Libelle  FLGSAI    : FLGSAI=1
Local  Char     FOURN(GLONBPS)
Local  Integer  OK
Local  Shortint SAVGNOLIGN, I
Local  Char     SAVGDEV1(3), SAVGDEVFMT1(10)
#----- Sauvegarde nolign, devise et format devise -----#
SAVNOLIGN=nolign
SAVGDEV1=GDEV1(1)
SAVGDEVFMT1=GDEVFMT1(1)
#----- Lecture BPSUPPLIER si nécessaire pour nom et structure tarif -----#
FOURN=evalue("[M:"+WABMSK+"]BPSNUM(NOL)")
If [F:BPS]BPSNUM<>FOURN
  Read [BPS] BPS0=FOURN : If fstat Raz [F:BPS] : Endif
Endif
#----- Chargement paramètres et libellés colonnes tarif -----#
If GPLISTC<>[F:BPS]PLISTC
  GPLISTC=[F:BPS]PLISTC : Call TARIFCHGT(6) From TRTPRICE
  Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
Endif
#----- Ouverture fichier motifs -----#
If clalev ([F:PPR])<=0 Local File PPREASON [PPR] : Endif
#----- Pour sauvegarde des valeurs -----#
Local Mask PURPRICE [PPR2]
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_SAIREMFRS
Raz [M:PPRI] : Actzo [PPRI]1-99
#----- Chargement formats colonnes tarif -----#
[M:PPRI]CUR   =evalue("[M:"+WABMSK+"]CUR(NOL)")
Call FMTREM("PPRI",[M:PPRI]CUR)  From TRTPRICE
#----- Chargement devise et format pour types de donnée MC1 et MD6 -----#
GDEV1(1)=[M:PPRI]CUR
GDEVFM1(1)=GDEVFMT1(max(find(GDEV1(1),GDEVISE(1..GNBDEV)),1))
#----- Chargement des zones dans le masque -----#
[M:PPRI]BPSNUM=evalue("[M:"+WABMSK+"]BPSNUM(NOL)")
[M:PPRI]BPSNAM=[F:BPS]BPSNAM
[M:PPRI]ITMREF=evalue("[M:"+WABMSK+"]ITMREF(NOL)")
[M:PPRI]ITMDES=evalue("[M:"+WABMSK+"]ITMDES(NOL)")
[M:PPRI]GROPRI=evalue("[M:"+WABMSK+"]GROPRI(NOL)")
[M:PPRI]PRIREN=evalue("[M:"+WABMSK+"]PRIREN(NOL)")
[M:PPRI]NETPRI=evalue("[M:"+WABMSK+"]NETPRI(NOL)")
[M:PPRI]QTYPUU=evalue("[M:"+WABMSK+"]QTYPUU(NOL)")
[M:PPRI]PUU   =evalue("[M:"+WABMSK+"]PUU(NOL)")
If evalue("dim([M:"+WABMSK+"]RETRCPDAT(NOL))")>0
  [M:PPRI]RETRCPDAT=evalue("[M:"+WABMSK+"]RETRCPDAT(NOL)") : Endif
If evalue("dim([M:"+WABMSK+"]EXTRCPDAT(NOL))")>0
  [M:PPRI]EXTRCPDAT=evalue("[M:"+WABMSK+"]EXTRCPDAT(NOL)") : Endif
[M:PPRI]ABREVM=WABMSK
For I=1 To 9
  If evalue("dim([M:"+WABMSK+"]DISCRGREN"+num$(I)+"(NOL))")>0
    Assign "[M:PPRI]DISCRGREN"+num$(I) With
&           evalue("[M:"+WABMSK+"]DISCRGREN"+num$(I)+"(NOL)")
    Assign "[M:PPRI]DISCRGVAL"+num$(I) With
&           evalue("[M:"+WABMSK+"]DISCRGVAL"+num$(I)+"(NOL)")
  Endif
Next I
If clalev([F:PTR])>0
  If [F:PTR]QTYSTUCOD=1                      [M:PPRI]QTYFLG=3 : Endif
  If [F:PTR]QTYPUUCOD=1 | [F:PTR]QTYPUUCOD=2 [M:PPRI]QTYFLG=2 : Endif
  If [F:PTR]QTYUOMCOD=1 | [F:PTR]QTYUOMCOD=2 [M:PPRI]QTYFLG=1 : Endif
Endif
If [M:PPRI]QTYFLG=0 [M:PPRI]QTYFLG=2 : Endif
Case [M:PPRI]QTYFLG
  When 1 : [M:PPRI]QTYUOM=evalue("[M:"+WABMSK+"]QTYUOM(NOL)")
           [M:PPRI]UOM   =evalue("[M:"+WABMSK+"]UOM(NOL)")
  When 2 : [M:PPRI]QTYUOM=evalue("[M:"+WABMSK+"]QTYPUU(NOL)")
           [M:PPRI]UOM   =evalue("[M:"+WABMSK+"]PUU(NOL)")
  When 3 : [M:PPRI]QTYUOM=evalue("[M:"+WABMSK+"]QTYSTU(NOL)")
           [M:PPRI]UOM   =evalue("[M:"+WABMSK+"]STU(NOL)")
Endcase
#-----
For I=1 To 9
  If evalue("dim([M:"+WABMSK+"]DISCRGVAL"+num$(I)+")")>0
    If GCOLREM(I-1)=""
      Case I
        When 1 : Grizo [PPRI]DISCRGVAL1, DISCRGREN1
        When 2 : Grizo [PPRI]DISCRGVAL2, DISCRGREN2
        When 3 : Grizo [PPRI]DISCRGVAL3, DISCRGREN3
        When 4 : Grizo [PPRI]DISCRGVAL4, DISCRGREN4
        When 5 : Grizo [PPRI]DISCRGVAL5, DISCRGREN5
        When 6 : Grizo [PPRI]DISCRGVAL6, DISCRGREN6
        When 7 : Grizo [PPRI]DISCRGVAL7, DISCRGREN7
        When 8 : Grizo [PPRI]DISCRGVAL8, DISCRGREN8
        When 9 : Grizo [PPRI]DISCRGVAL9, DISCRGREN9
      Endcase
    Endif
  Endif
Next I
#----- Contrôle autorisation modification -----#
If !find (GREP,"C","D")
  GBIDC2="M": Gosub AUTORIS_OPT From CONTX3
  If !GBIDI2  Diszo [PPRI]1-99 : Raz FLGSAI : Endif
Endif
#-----
[M:PPR2]=[M:PPRI] : # Sauvegarde des valeurs d'origine
#----- Affichage foreground -----#
Affzo [PPRI]1-99
Return
#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK_SAIREMFRS
If FLGSAI<>0
  Assign "[M:"+WABMSK+"]GROPRI(NOL)" With [M:PPRI]GROPRI
  Assign "[M:"+WABMSK+"]PRIREN(NOL)" With [M:PPRI]PRIREN
  Assign "[M:"+WABMSK+"]NETPRI(NOL)" With [M:PPRI]NETPRI
  #----- On ne modifie pas les dates si on vient des demandes d'achat -----#
  If WABMSK<>"PSH1"
    If evalue("dim([M:"+WABMSK+"]RETRCPDAT(NOL))")>0
      Assign "[M:"+WABMSK+"]RETRCPDAT(NOL)" With [M:PPRI]RETRCPDAT : Endif
    If evalue("dim([M:"+WABMSK+"]EXTRCPDAT(NOL))")>0
      Assign "[M:"+WABMSK+"]EXTRCPDAT(NOL)" With [M:PPRI]EXTRCPDAT : Endif
  Endif
  #-----
  For I=1 To 9
    If evalue("dim([M:"+WABMSK+"]DISCRGVAL"+num$(I)+"(NOL))")>0
      Assign "[M:"+WABMSK+"]DISCRGVAL"+num$(I)+"(NOL)"
&             With evalue("[M:PPRI]DISCRGVAL"+num$(I))
      Assign "[M:"+WABMSK+"]DISCRGREN"+num$(I)+"(NOL)"
&             With evalue("[M:PPRI]DISCRGREN"+num$(I))
    Endif
  Next I
  If WABMSK="PSH1"
    VALEUR=[M:PSH1]NETPRI(NOL)
    [M:PSH1]LINAMT(NOL)=[M:PSH1]QTYPUU(NOL)*VALEUR
  Elsif WABMSK="POI1"
    VALEUR=[M:POI1]GROPRI(NOL)
    [M:POI1]LINAMT(NOL)=[M:POI1]NETPRI(NOL)*[M:POI1]QTYUOM(NOL)
    Call ARRDEV([M:POI1]LINAMT(NOL),[M:POI1]CUR(NOL)) From TRTDIV
  Endif
  mkstat=4
Endif
FIN=1
Return
#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
$ABA_SAIREMFRS
[M:PPRI]=[M:PPR2] : Raz REP
Affzo [PPRI]1-99
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_SAIREMFRS
If clalev([M:PPR2])>0 Close Local Mask [PPR2] : Endif
If mkstat=4 & !GIMPORT
  If WABMSK="PSH1"
    Affzo [PSH1]NETPRI(NOL) ,LINAMT(NOL) : # Raz mkstat : # <- Fait pour le WEB 130
  Elsif WABMSK="POI1"
    Affzo [POI1]GROPRI(NOL), NETPRI(NOL) ,LINAMT(NOL)
  Endif
Endif
nolign=SAVNOLIGN
GDEV1(1)=SAVGDEV1 : GDEVFMT1(1)=SAVGDEVFMT1
Return


########################################################################
# PAMDISCRG : S/P DE CHARGEMENT DES MOTIFS REMISES/FRAIS  MBT 18/12/97 #
#             ET CALCUL/AFFICHAGE DU PRIX NET                          #
#----------------------------------------------------------------------#
# Subprog PAMDISCRG (VALEUR,WABMSK,DISCRGNUM,NOLIG,WCUR)               #
#   VALEUR    : ZONE COURANTE                                          #
#   WABMSK    : ABRéVIATION DU MASQUE éCRAN CONTENANT LES LIGNES       #
#   DISCRGNUM : NUMéRO DE LA COLONNE REMISE/FRAIS à TRAITER (1 à 9)    #
#               POUR PRIX BRUT  0 = APRèS MODIF.                       #
#   NOLIG     : indice DE LA LIGNE ACTIVE (nolign-1)                   #
#   WCUR      : DEVISE POUR ARRONDI DU PRIX NET                        #
#                                                                      #
# ATTENTION   : CE S/P EST APPELé PAR UNE ACTION "APRèS_MODIF" SUR LES #
#               CHAMPS PRIX BRUT ET REMISES/FRAIS.                     #
########################################################################
Subprog PAMDISCRG (VALEUR,WABMSK,DISCRGNUM,NOLIG,WCUR)
Value  Decimal  VALEUR
Value  Char     WABMSK
Value  Integer  DISCRGNUM
Value  Integer  NOLIG
Value  Char     WCUR
#----- CHARGEMENT MOTIF MANUEL PAR DéFAUT -----#
If DISCRGNUM>0 & DISCRGNUM<10
   If !GIMPORT & VALEUR=evalue("[M:"+WABMSK+"]DISCRGVAL"+num$(DISCRGNUM)+"(NOLIG)") End : Endif
   Assign "[M:"+WABMSK+"]DISCRGREN"+num$(DISCRGNUM)+"(NOLIG)" With GDACMANPUR
Elsif DISCRGNUM=0
   If !GIMPORT & VALEUR=evalue("[M:"+WABMSK+"]GROPRI(NOLIG)") End : Endif
   Assign "[M:"+WABMSK+"]PRIREN(NOLIG)" With GDACMANPUR
Endif
If evalue("dim([M:"+WABMSK+"]GROPRI(NOLIG))")<1 End : Endif
#----- CALCUL ET AFFICHAGE DU PRIX NET -----#
Local  Decimal  GROPRI, DISCRGVAL(0..8), NETPRI
Local  Shortint I
If DISCRGNUM<1 GROPRI=VALEUR
          Else GROPRI=evalue("[M:"+WABMSK+"]GROPRI(NOLIG)")
Endif
For I=1 To 9
    If evalue("DIM([M:"+WABMSK+"]DISCRGVAL"+num$(I)+"(NOLIG))")>0
       DISCRGVAL(I-1)=evalue("[M:"+WABMSK+"]DISCRGVAL"+num$(I)+"(NOLIG)")
    Endif
Next I
Case DISCRGNUM
  When 1 DISCRGVAL(0)=VALEUR
  When 2 DISCRGVAL(1)=VALEUR
  When 3 DISCRGVAL(2)=VALEUR
  When 4 DISCRGVAL(3)=VALEUR
  When 5 DISCRGVAL(4)=VALEUR
  When 6 DISCRGVAL(5)=VALEUR
  When 7 DISCRGVAL(6)=VALEUR
  When 8 DISCRGVAL(7)=VALEUR
  When 9 DISCRGVAL(8)=VALEUR
Endcase
Local Decimal QTY
If evalue("dim([M:"+WABMSK+"]QTYUOM(NOLIG))")>0
  QTY=evalue("[M:"+WABMSK+"]QTYUOM(NOLIG)")
Elsif evalue("dim([M:"+WABMSK+"]QTYPUU(NOLIG))")>0
  QTY=evalue("[M:"+WABMSK+"]QTYPUU(NOLIG)")
Else
  QTY=1
Endif
If dim(GPURNEGPRI)<0  Global Libelle GPURNEGPRI : Endif
Raz GPURNEGPRI
If evalue("dim([M:"+WABMSK+"]ITMREF)")>0
  If WABMSK="POC2" I=0 Else I=NOLIG : Endif
  If evalue("[M:"+WABMSK+"]ITMREF(I)")<>[F:ITM]ITMREF
    Read [ITM] ITM0=evalue("[M:"+WABMSK+"]ITMREF(I)")
    If fstat  Raz [F:ITM] : Endif
  Endif
  If [F:ITM]STOMGTCOD=1  GPURNEGPRI=2 : Endif
Endif
If dim(GCALNETLIN)>0  GCALNETLIN=NOLIG+1          : Endif
If dim(GCALNETABR)>0  GCALNETABR="[M:"+WABMSK+"]" : Endif
Call CALNET(2,[F:BPS]PLISTC,GROPRI,DISCRGVAL,QTY,NETPRI,WCUR) From TRTPRICE
If GMESSAGE<>"" Call MESSAGE(GMESSAGE) From GESECRAN : Raz GMESSAGE : Endif
Assign "[M:"+WABMSK+"]NETPRI(NOLIG)" With NETPRI
If !GIMPORT Affzo NETPRI(NOLIG) : Endif
#----- calcul et affichage du montant ligne -----#
If WABMSK="POI1"
  [M:POI1]LINAMT(NOLIG)=[M:POI1]NETPRI(NOLIG)*[M:POI1]QTYUOM(NOLIG)
  Call ARRDEV([M:POI1]LINAMT(NOLIG),[M:POI1]CUR(NOLIG)) From TRTDIV
  If !GIMPORT Affzo [POI1]LINAMT(NOLIG) : Endif
Elsif WABMSK="POH2"
  [M:POH2]LINAMT(NOLIG)=[M:POH2]NETPRI(NOLIG)*[M:POH2]QTYUOM(NOLIG)
  Call ARRDEV([M:POH2]LINAMT(NOLIG),GCUR) From TRTDIV
  If !GIMPORT Affzo [POH2]LINAMT(NOLIG) : Endif
Elsif WABMSK="PTH1"
  [M:PTH1]LINAMT(NOLIG)=[M:PTH1]NETPRI(NOLIG)*[M:PTH1]QTYUOM(NOLIG)
  Call ARRDEV([M:PTH1]LINAMT(NOLIG),GCUR) From TRTDIV
  If !GIMPORT Affzo [PTH1]LINAMT(NOLIG) : Endif
Elsif WABMSK="PNH1"
  [M:PNH1]LINAMT(NOLIG)=[M:PNH1]NETPRI(NOLIG)*[M:PNH1]QTYUOM(NOLIG)
  Call ARRDEV([M:PNH1]LINAMT(NOLIG),[M:PNH1]NETCUR(NOLIG)) From TRTDIV
  If !GIMPORT Affzo [PNH1]LINAMT(NOLIG) : Endif
Endif
End


########################################################################
# PAMPLIFLG : S/P de choix pour recalcul tarif ligne      MBT 27/01/98 #
#----------------------------------------------------------------------#
# Subprog PAMPLIFLG (NBLIG,NOMZON)                                     #
#   NBLIG   : Nombre de lignes créées (Variable bas de tableau lignes) #
#   NOMZON  : Nom du champ courant (remplace le zc MBT 30/11/00)       #
#                                                                      #
# Attention : Ce S/P est appelé par une action "Après_modif"           #
#             et les variables globales GPLIFLG, GVACFLG doivent être  #
#             définies et initialisées à zéro dans la section "OUVRE". #
########################################################################
Subprog PAMPLIFLG (NBLIG,NOMZON)
Value Integer NBLIG
Value Char    NOMZON
If [M]NBLIG=0   End : Endif
If NOMZON="BPSNUM" GVACFLG=1 : Endif
If NOMZON="VACBPR" GVACFLG=1 : Endif
If NOMZON="ORDDAT" GDATFLG=1 : Endif
If GPLIFLG=0
  Local Integer OK
  OK=1 : Call OUINON(mess(63,196,1),OK) From GESECRAN
  If OK=1 GPLIFLG=1 Else GPLIFLG=2 : Endif
Endif
#----- Mise à jour des lignes immédiatement -----#
If clalev([M:POI1])>0
  Gosub RECALCUL_TARLIG From SUBPOIA
Elsif clalev([M:POH2])>0
  # Issue 71937 - 2012-11-07 by MUARN : multileg
  #If NOMZON="VACBPR" & dim([M:POH1]VACBPR)>0  [M:POH1]VACBPR=[F:ADI]CODE : Endif

  Local Shortint SAV_GPURGRUDIS : SAV_GPURGRUDIS=GPURGRUDIS
  GPURGRUDIS=1
  Gosub RECALCUL_TARLIG From SUBPOHB
  GPURGRUDIS=SAV_GPURGRUDIS
Endif
End


########################################################################
# PAVAMTRPT : S/P de calcul d'un montant en devise de     MBT 19/06/98 #
#             reporting (utilisé pour double affichage en EURO)        #
#----------------------------------------------------------------------#
# Subprog PAVAMTRPT (MTDEST,DEVISE,TYPCOURS,DAT,MTORI)                 #
#   MTDEST    : Zone courante                                          #
#   DEVISE    : Devise du montant d'origine à convertir en EURO        #
#   TYPCOURS  : Type de cours de la devise d'origine                   #
#   DAT       : Date de la pièce                                       #
#   MTORI     : Montant d'origine à convertir                          #
#                                                                      #
# ATTENTION   : Ce S/P est appelé par une action "Avant_zone" sur les  #
#               champs à afficher en devise de reporting               #
########################################################################
Subprog PAVAMTRPT (MTDEST,DEVISE,TYPCOURS,DAT,MTORI)
Variable Decimal  MTDEST
Value    Char     DEVISE
Value    Integer  TYPCOURS
Value    Date     DAT
Value    Decimal  MTORI
Local    Integer  STAT
If DEVISE<>GSYSCUR
  Call CONVERT(DEVISE,GSYSCUR,GLOCALDEV,TYPCOURS,DAT,MTORI,MTDEST,STAT) From TRTDEV
  If STAT  Raz MTDEST : Endif
Else
  MTDEST=MTORI
Endif
End


##########################################################################
# REMFRS_LIGFAC: S/P saisie mts rem-fr tarif ligne fac      MBT 07/09/98 #
#   WABMSK    : Abréviation du masque contenant les lignes               #
#   NOL      : Indice de la ligne à traiter (nolign-1)                   #
# ---------------------------------------------------------------------- #
# Remplacé par l'action SAIFRSFAC avec paramètres :         MBT 17/11/00 #
#   PARAM(1) = WABMSK : Abréviation du masque écran contenant les lignes #
#   PARAM(2) = NOLIG  : indice de la ligne à traiter (nolign-1)          #
##########################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_SAIFRSFAC
Local Char     WABMSK(4) : WABMSK=PARAM(1)
Local Shortint I, MK, NOL   : NOL=val(PARAM(2))
If evalue("[M:"+WABMSK+"]TYPORI(NOL)=0") FIN=1 : Return : Endif
#----- Mise à jour des répartitions si nécessaire -----#
If [M:PIH1]NBFAC1>0 & [M:PIH4]NBFAC=0
  [M:PIH4]NBFAC=[M:PIH1]NBFAC1
  For I=0 To [M:PIH1]NBFAC1-1
    Call MAJ_ELEMENT (I,1,+1) From SUBPIHB
  Next I
  If !GIMPORT Affzo [PIH4]5 : Endif
Elsif evalue("[M:"+WABMSK+"]CLCFLG=2")
  For I=0 To [M:PIH1]NBFAC1-1
    Call MAJ_ELEMENT (I,0,-1) From SUBPIHB
    Call MAJ_ELEMENT (I,1,+1) From SUBPIHB
  Next I
  If !GIMPORT
    Affzo [PIH4]5
    If [M:PIH1]NBFAC1=0 Affzo [PIH4]10, 20, 30 : Endif
  Endif
Endif
#-----
nolign=NOL+1 : status=0 : Call AVANT_NBLIG From SUBPIH
Return
#-----------------------------------------------------------------------#
# Après ouverture de l'écran mais avant ouverture de la fenêtre : Titre #
#-----------------------------------------------------------------------#
$TIT_SAIFRSFAC
#----- Chargement des libellés des montants répartis -----#
Local Char     DESIGN(20)
If clalev ([F:PFI])<=0 Local File PFOOTINV [PFI] : Endif
Raz [M:PDC1]
For I=0 To 8
  If evalue("[M:"+WABMSK+"]INVDTALIN2(I)")<>0
    Read [PFI] PFI0=evalue("[M:"+WABMSK+"]INVDTALIN2(I)")
    If fstat Raz [F:PFI] : Endif
    If [F:PFI]PFINUM<>0
      Call LECTEXTRA(DESIGN,"PFOOTINV","SHOAXX",num$([F:PFI]PFINUM),"") From ATEXTRA
      Assign "[M:PDC1]LIB"+num$(I+1) With DESIGN+"  ("+format$("N0:3",[F:PFI]PFINUM)+")"
    Else
      Assign "[M:PDC1]LIB"+num$(I+1) With ""
    Endif
  Endif
Next I
Return
#------------------------------------------------------------------#
# Après l'ouverture de la fenêtre des frais/remises lignes facture #
#------------------------------------------------------------------#
$DEB_SAIFRSFAC
#----- Variables locales -----#
Local Libelle  FLGSAI : FLGSAI=1
Local Char     FOURN(GLONBPS)
Local Integer  OK
#--- Ouvert. fichier motifs, déclaration fenêtre saisie ---#
If clalev ([F:PPR])<=0 Local File PPREASON [PPR] : Endif
Local Mask PDISCRG [PDC2]
#----- Affichage de % ou devise à la suite de la valeur colonne tarif -----#
For I=0 To 8
  If evalue("dim([M:PDC1]DISCRGTYP"+num$(I+1)+")")>0
    If GCOLREM(I)<>""
      If GDISCRGTYP(I)=1
        Assign "[M:PDC1]DISCRGTYP"+num$(I+1) With GCUR
      Else
        Assign "[M:PDC1]DISCRGTYP"+num$(I+1) With "%"
      Endif
    Else
      Assign "[M:PDC1]DISCRGTYP"+num$(I+1) With ""
      #----- Faire disparaitre les champs motifs non actifs -----#
      Case I
        When 0 : Chgfmt [M:PDC1]DISCRGREN1 With "-K:1X"
                 Chgfmt [M:PDC1]DISCRGDES1 With "-K:1X"
        When 1 : Chgfmt [M:PDC1]DISCRGREN2 With "-K:1X"
                 Chgfmt [M:PDC1]DISCRGDES2 With "-K:1X"
        When 2 : Chgfmt [M:PDC1]DISCRGREN3 With "-K:1X"
                 Chgfmt [M:PDC1]DISCRGDES3 With "-K:1X"
        When 3 : Chgfmt [M:PDC1]DISCRGREN4 With "-K:1X"
                 Chgfmt [M:PDC1]DISCRGDES4 With "-K:1X"
        When 4 : Chgfmt [M:PDC1]DISCRGREN5 With "-K:1X"
                 Chgfmt [M:PDC1]DISCRGDES5 With "-K:1X"
        When 5 : Chgfmt [M:PDC1]DISCRGREN6 With "-K:1X"
                 Chgfmt [M:PDC1]DISCRGDES6 With "-K:1X"
        When 6 : Chgfmt [M:PDC1]DISCRGREN7 With "-K:1X"
                 Chgfmt [M:PDC1]DISCRGDES7 With "-K:1X"
        When 7 : Chgfmt [M:PDC1]DISCRGREN8 With "-K:1X"
                 Chgfmt [M:PDC1]DISCRGDES8 With "-K:1X"
        When 8 : Chgfmt [M:PDC1]DISCRGREN9 With "-K:1X"
                 Chgfmt [M:PDC1]DISCRGDES9 With "-K:1X"
      Endcase
    Endif
  Endif
Next I
#----- Chargement formats colonnes tarif -----#
[M:PDC1]CUR       =GCUR
Call FMTREM("PDC1",[M:PDC1]CUR)  From TRTPRICE
#----- Chargement des zones dans le masque -----#
[M:PDC1]TYPORI    =evalue("[M:"+WABMSK+"]TYPORI(NOL)")
[M:PDC1]NUMORI    =evalue("[M:"+WABMSK+"]NUMORI(NOL)")
[M:PDC1]LINORI    =evalue("[M:"+WABMSK+"]LINORI(NOL)")
[M:PDC1]ITMREF    =evalue("[M:"+WABMSK+"]ITMREF(NOL)")
[M:PDC1]ITMDES    =evalue("[M:"+WABMSK+"]ITMDES(NOL)")
[M:PDC1]QTYUOM    =evalue("[M:"+WABMSK+"]QTYUOM(NOL)")
[M:PDC1]UOM       =evalue("[M:"+WABMSK+"]UOM(NOL)")
[M:PDC1]NETPRI    =evalue("[M:"+WABMSK+"]NETPRI(NOL)")
[M:PDC1]AMTNOTLIN =evalue("[M:"+WABMSK+"]AMTNOTLIN(NOL)")
[M:PDC1]DISCRGAMT1=evalue("[M:"+WABMSK+"]DISCRGAMT1(NOL)")
[M:PDC1]DISCRGAMT2=evalue("[M:"+WABMSK+"]DISCRGAMT2(NOL)")
[M:PDC1]DISCRGAMT3=evalue("[M:"+WABMSK+"]DISCRGAMT3(NOL)")
[M:PDC1]DISCRGAMT4=evalue("[M:"+WABMSK+"]DISCRGAMT4(NOL)")
[M:PDC1]DISCRGAMT5=evalue("[M:"+WABMSK+"]DISCRGAMT5(NOL)")
[M:PDC1]DISCRGAMT6=evalue("[M:"+WABMSK+"]DISCRGAMT6(NOL)")
[M:PDC1]DISCRGAMT7=evalue("[M:"+WABMSK+"]DISCRGAMT7(NOL)")
[M:PDC1]DISCRGAMT8=evalue("[M:"+WABMSK+"]DISCRGAMT8(NOL)")
[M:PDC1]DISCRGAMT9=evalue("[M:"+WABMSK+"]DISCRGAMT9(NOL)")
For I=1 To 9
    If evalue("dim([M:"+WABMSK+"]DISCRGREN"+num$(I)+"(NOL))")>0
       Assign "[M:PDC1]DISCRGREN"+num$(I) With
&              evalue("[M:"+WABMSK+"]DISCRGREN"+num$(I)+"(NOL)")
       Assign "[M:PDC1]DISCRGVAL"+num$(I) With
&              evalue("[M:"+WABMSK+"]DISCRGVAL"+num$(I)+"(NOL)")
    Endif
Next I
For I=1 To 9
  If evalue("dim([M:"+WABMSK+"]DISCRGVAL"+num$(I)+")")>0
    If GNPRNOTFLG(I-1)=2 | GCOLREM(I-1)="" | GINVDTALIN(I-1)=0
      Case I
        When 1 : Diszo [PDC1]DISCRGVAL1, DISCRGREN1
        When 2 : Diszo [PDC1]DISCRGVAL2, DISCRGREN2
        When 3 : Diszo [PDC1]DISCRGVAL3, DISCRGREN3
        When 4 : Diszo [PDC1]DISCRGVAL4, DISCRGREN4
        When 5 : Diszo [PDC1]DISCRGVAL5, DISCRGREN5
        When 6 : Diszo [PDC1]DISCRGVAL6, DISCRGREN6
        When 7 : Diszo [PDC1]DISCRGVAL7, DISCRGREN7
        When 8 : Diszo [PDC1]DISCRGVAL8, DISCRGREN8
        When 9 : Diszo [PDC1]DISCRGVAL9, DISCRGREN9
      Endcase
    Endif
  Endif
Next I
Diszo [PDC1]DISCRGAMT1, DISCRGAMT2, DISCRGAMT3, DISCRGAMT4, DISCRGAMT5,
&                       DISCRGAMT6, DISCRGAMT7, DISCRGAMT8, DISCRGAMT9
#----- Si modif non autorisée, désactivation de la saisie par grisage -----#
If GREP<>"C"
  GBIDC2="M" : Gosub AUTORIS_OPT From CONTX3
  If !GBIDI2 | [M:PIH1]STA=3 Diszo [PDC1]10-15 : Raz FLGSAI : Endif
Endif
#-----
[M:PDC2]=[M:PDC1] : # Sauvegarde des valeurs d'origine
#----- Affichage foreground -----#
Affzo [PDC1]1-99
Return
#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK_SAIFRSFAC
If FLGSAI<>0
  For I=1 To 9
      If evalue("dim([M:"+WABMSK+"]DISCRGVAL"+num$(I)+"(NOL))")>0
         Assign "[M:"+WABMSK+"]DISCRGVAL"+num$(I)+"(NOL)"
&               With evalue("[M:PDC1]DISCRGVAL"+num$(I))
         Assign "[M:"+WABMSK+"]DISCRGREN"+num$(I)+"(NOL)"
&               With evalue("[M:PDC1]DISCRGREN"+num$(I))
      Endif
  Next I
  mkstat=4
Endif
FIN=1
Return
#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
ABA_SAIFRSFAC
[M:PDC1]=[M:PDC2] : Raz REP
Affzo [PDC1]1-99
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_SAIFRSFAC
If clalev ([M:PDC2])>0  Close Local Mask [PDC2] : Endif
MK=mkstat
If mkstat=4
  Assign "[M:"+WABMSK+"]LINFLG(NOL)" With 2
  Assign "[M:"+WABMSK+"]UPDFLG(NOL)" With 1
  # MK=6
Endif
nolign=NOL+1 : status=0 : Call APRES_NBLIG From SUBPIH : mkstat=MK
Return


########################################################################
# REAJUST_TARIF  Réajustement des montants unitaires      MBT 11/12/07 #
#   de la ligne tarif après une modification d'unité,                  #
#   de quantité, de coefficient si ligne issue d'un autre document     #
#   ou de catégorie ligne article (LINCAT=2).                          #
# -------------------------------------------------------------------- #
# Subprog REAJUST_TARIF(WABMSK,WNOL,WUNIT1,WUNIT2,WCOEF1,WCOEF2)       #
#   WABMSK   : Abréviation du masque écran contenant les lignes        #
#   WNOL     : Indice de la ligne à traiter (nolign-1)                 #
#   WUNIT1   : Ancienne unité                                          #
#   WUNIT2   : Nouvelle unité                                          #
#   WCOEF1   : Ancien  coefficient de conversion d'unité               #
#   WCOEF2   : Nouveau coefficient de conversion d'unité               #
#                                                                      #
# Attention : Le Call du TYPREM From TRTPRICE doit être fait pour      #
#             charger les variable globales suivantes                  #
#   GINCDCR   (0..8) = Majoration / Minoration                         #
#   GDISCRGTYP(0..8) = Mt / % Cumul / % Cascade                        #
#   GNPRNOTFLG(0..8) = Entre dans le PU Net (Non / Oui)                #
#   GCLCRUL   (0..8) = Calcul par Unité / Ligne / Document             #
#                                                                      #
#   GPLISTC          = Code structure                                  #
#   GCUR             = Devise du document                              #
#   GDECPRI          = Nombre de décimales des prix unitaires          #
########################################################################
Subprog REAJUST_TARIF(WABMSK,WNOL,WUNIT1,WUNIT2,WCOEF1,WCOEF2)
Value Char    WABMSK
Value Integer WNOL
Value Char    WUNIT1
Value Char    WUNIT2
Value Decimal WCOEF1
Value Decimal WCOEF2
#-----
Local Char    WBPSNUM(GLONBPS)
Local Char    WITMREF(GLONITM)
Local Decimal WGROPRI
Local Decimal WDISCRGVAL(0..8)
Local Decimal WNETPRI
Local Decimal WCOEFFICIENT
Local Decimal WQTY1
Local Decimal WQTY2
Local Decimal WQUANTITE
Local Decimal WMONTANT
Local Libelle WTRAIT
Local Char    WLINCUR(GLONCUR)
Local Integer WSTA
Local Decimal WMT1
Local Decimal WMT2
Local Integer I
#-------------------------------------------------------------#
# WTRAIT : Code traitement                                    #
#   1 = Conversion de tous les éléments de la ligne tarif.    #
#   2 = Conversion des éléments hors prix ligne,              #
#       mise à zéro des autres et prix brut = prix net.       #
#   3 = Ligne matière fournie au sous-traitant non facturable #
#       mise à zéro de tous les éléments de la ligne tarif,   #
#       du prix brut, du prix net et du montant ligne.        #
#   4 = Récupération de tous les éléments tarif               #
#       de la ligne commande si même unité                    #
#   5 = Récupération de tous les éléments tarif               #
#       de la ligne de réception si même unité                #
#-------------------------------------------------------------#
WTRAIT=1
Case WABMSK
  When "POI1"
    WBPSNUM  =[M:POI1]BPSNUM(WNOL)
    WITMREF  =[M:POI1]ITMREF(WNOL)
    WQUANTITE=[M:POI1]QTYUOM(WNOL)
    WGROPRI  =[M:POI1]GROPRI(WNOL)
    WNETPRI  =[M:POI1]NETPRI(WNOL)
    #-----
    GCUR     =[M:POI1]CUR(WNOL)
    If [F:BPS]BPSNUM<>WBPSNUM
      Read [BPS] BPS0=WBPSNUM : If fstat Raz [F:BPS] : Endif
    Endif
    #----- Chargement contexte tarif -----#
    If GPLISTC<>[F:BPS]PLISTC
      GPLISTC=[F:BPS]PLISTC
      Call TARIFCHGT(6) From TRTPRICE
      Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
      Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
    Endif
    #-----
  When "POH2"
    WBPSNUM  =[M:POH0]BPSNUM
    WITMREF  =[M:POH2]ITMREF(WNOL)
    WQUANTITE=[M:POH2]QTYUOM(WNOL)
    WGROPRI  =[M:POH2]GROPRI(WNOL)
    WNETPRI  =[M:POH2]NETPRI(WNOL)
  When "PTH1"
    WBPSNUM  =[M:PTH0]BPSNUM
    WITMREF  =[M:PTH1]ITMREF(WNOL)
    WQUANTITE=[M:PTH1]QTYUOM(WNOL)
    WGROPRI  =[M:PTH1]GROPRI(WNOL)
    WNETPRI  =[M:PTH1]NETPRI(WNOL)
    WLINCUR  =[M:PTH1]NETCUR(WNOL)
    #-----
    If [M:PTH1]POHNUM(WNOL)<>""
      Read [POH] POH0=[M:PTH1]POHNUM(WNOL)
      If fstat  Raz [F:POH] : [F:POH]CUR=WLINCUR : Endif
      Read [POQ] POQ0=[M:PTH1]POHNUM(WNOL);[M:PTH1]POPLIN(WNOL);[M:PTH1]POQSEQ(WNOL)
      If !fstat & [F:POQ]UOM=WUNIT2
        If [F:POQ]POHTYP<>2
          Read [POP] POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;1
          If fstat  Raz [F:POP] : Endif
        Else
          Filter [POP] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POPDAT>=[F:POQ]DEMRCPDAT
          Read [POP] POP1 First : If fstat  Raz [F:POP]  : Endif
          Filter [POP]
        Endif
        If [F:POP]POHNUM<>""  WTRAIT=4 : Endif
      Endif
    Endif
    #-----
    If WTRAIT<>4
      If [M:PTH1]LINAMT(WNOL)<>0 & [M:PTH1]QTYUOM(WNOL)<>0
        If ([M:PTH1]POHNUM(WNOL)<>"" | [M:PTH1]SDHNUM(WNOL)<>"") & WCOEF1<>WCOEF2
          WTRAIT=2
        Endif
      Elsif [M:PTH1]LINCAT(WNOL)=2
        WTRAIT=3
      Endif
    Endif
  When "PNH1"
    WBPSNUM  =[M:PNH1]BPSNUM
    WITMREF  =[M:PNH1]ITMREF(WNOL)
    WQUANTITE=[M:PNH1]QTYUOM(WNOL)
    WGROPRI  =[M:PNH1]GROPRI(WNOL)
    WNETPRI  =[M:PNH1]NETPRI(WNOL)
    WLINCUR  =[M:PNH1]NETCUR(WNOL)
    #-----
    If [M:PNH1]PTHNUM(WNOL)<>""
      Read [PTD] PTD0=[M:PNH1]PTHNUM(WNOL);[M:PNH1]PTDLIN(WNOL)
      If !fstat & [F:PTD]UOM=WUNIT2 : WTRAIT=5 : Endif
    Endif
    #-----
    If WTRAIT<>5
      If [M:PNH1]LINAMT(WNOL)<>0 & [M:PNH1]QTYUOM(WNOL)<>0
        If[M:PNH1]PTHNUM(WNOL)<>"" & WCOEF1<>WCOEF2
          WTRAIT=2
        Endif
      Elsif [M:PNH1]LINCAT(WNOL)=2
        WTRAIT=3
      Endif
    Endif
Endcase
#----- Récupération des éléments tarif de la ligne de réception -----#
If WTRAIT=5
  WGROPRI=[F:PTD]GROPRI
  WNETPRI=[F:PTD]NETPRI
  For I=0 To 8
    If evalue("dim([M:"+WABMSK+"]DISCRGVAL"+num$(I+1)+"(WNOL))")>0
      If GDISCRGTYP(I)=1 & GCLCRUL(I)=1
        Assign "[M:"+WABMSK+"]DISCRGVAL"+num$(I+1)+"(WNOL)"
&              With evalue("[F:PTD]DISCRGVAL"+num$(I+1))
      Endif
    Endif
  Next I
  WMONTANT=WNETPRI*WQUANTITE : Call ARRDEV(WMONTANT,WLINCUR) From TRTDIV
#----- Récupération des éléments tarif de la ligne de commande -----#
Elsif WTRAIT=4
  If WLINCUR<>[F:POH]CUR
    Call CONVERT2([F:POH]CUR,WLINCUR,GLOCALDEV,[M:PTH0]CHGTYP,[M:PTH0]RCPDAT,
&                 [F:POP]GROPRI,WGROPRI,WSTA) From TRTDEV
    WGROPRI=arr(WGROPRI,10^-GDECPRI)
    Call CONVERT2([F:POH]CUR,WLINCUR,GLOCALDEV,[M:PTH0]CHGTYP,[M:PTH0]RCPDAT,
&                 [F:POP]NETPRI,WNETPRI,WSTA) From TRTDEV
    WNETPRI=arr(WNETPRI,10^-GDECPRI)
  Else
    WGROPRI=[F:POP]GROPRI
    WNETPRI=[F:POP]NETPRI
  Endif
  For I=0 To 8
    If evalue("dim([M:"+WABMSK+"]DISCRGVAL"+num$(I+1)+"(WNOL))")>0
      If GDISCRGTYP(I)=1 & GCLCRUL(I)=1
        WMT2=evalue("[F:POP]DISCRGVAL"+num$(I+1))
        #-----
        If WLINCUR<>[F:POH]CUR
          WMT1=WMT2
          Call CONVERT([F:POH]CUR,WLINCUR,GLOCALDEV,[M:PTH0]CHGTYP,[M:PTH0]RCPDAT,
&                      WMT1,WMT2,WSTA) From TRTDEV
        Endif
        #-----
        Assign "[M:"+WABMSK+"]DISCRGVAL"+num$(I+1)+"(WNOL)" With WMT2
      Endif
    Endif
  Next I
  WMONTANT=WNETPRI*WQUANTITE : Call ARRDEV(WMONTANT,GCUR) From TRTDIV
Elsif WTRAIT=3
  #----- Remise à zéro de tous les éléments de la ligne tarif -----#
  Raz WGROPRI, WNETPRI, WMONTANT
  For I=0 To 8
    If evalue("dim([M:"+WABMSK+"]DISCRGVAL"+num$(I+1)+"(WNOL))")>0
      Assign "[M:"+WABMSK+"]DISCRGVAL"+num$(I+1)+"(WNOL)" With 0
      Assign "[M:"+WABMSK+"]DISCRGREN"+num$(I+1)+"(WNOL)" With 0
    Endif
  Next I
Else
  If WCOEF1=0 | WCOEF2=0
    Call PCAL_QTY(WQTY1,WUNIT1,WQTY2,WUNIT2,WITMREF,WBPSNUM,3,WCOEFFICIENT) From TRTACHQTE1
  Else
    WCOEFFICIENT=WCOEF2/WCOEF1
  Endif
  #----- Conversion prix unitaire brut -----#
  If WTRAIT=1
    WGROPRI=arr(WGROPRI*WCOEFFICIENT,10^-GDECPRI)
  Else
    WGROPRI=arr(WNETPRI*WCOEFFICIENT,10^-GDECPRI)
  Endif
  #----- Conversion des montants unitaires -----#
  For I=0 To 8
    If evalue("dim([M:"+WABMSK+"]DISCRGVAL"+num$(I+1)+"(WNOL))")>0
      #----- Raz des éléments servant au calcul du prix net -----#
      If WTRAIT=2 & GNPRNOTFLG(I)=2
        Assign "[M:"+WABMSK+"]DISCRGVAL"+num$(I+1)+"(WNOL)" With 0
        Assign "[M:"+WABMSK+"]DISCRGREN"+num$(I+1)+"(WNOL)" With 0
      Else
      #-----
        WDISCRGVAL(I)=evalue("[M:"+WABMSK+"]DISCRGVAL"+num$(I+1)+"(WNOL)")
        If GDISCRGTYP(I)=1 & GCLCRUL(I)=1
          Assign "[M:"+WABMSK+"]DISCRGVAL"+num$(I+1)+"(WNOL)"
&                With arr(WDISCRGVAL(I)*WCOEFFICIENT,10^-GDECPRI)
        Endif
      Endif
    Endif
  Next I
  #----- Calcul Prix unitaire net et montant ligne -----#
  If dim(GCALNETLIN)>0  GCALNETLIN=WNOL+1           : Endif
  If dim(GCALNETABR)>0  GCALNETABR="[M:"+WABMSK+"]" : Endif
  Call CALNET(2,GPLISTC,WGROPRI,WDISCRGVAL,WQUANTITE,WNETPRI,GCUR) From TRTPRICE
  If GMESSAGE<>""  GERR=2 : Endif
  WMONTANT=WNETPRI*WQUANTITE : Call ARRDEV(WMONTANT,GCUR) From TRTDIV
Endif
#----- Affichage de la ligne tarif -----#
Case WABMSK
  When "POI1"
    [M:POI1]GROPRI(WNOL)=WGROPRI
    [M:POI1]NETPRI(WNOL)=WNETPRI
    [M:POI1]LINAMT(WNOL)=WMONTANT
  When "POH2"
    [M:POH2]GROPRI(WNOL)=WGROPRI
    [M:POH2]NETPRI(WNOL)=WNETPRI
    [M:POH2]LINAMT(WNOL)=WMONTANT
    If !GIMPORT
      Affzo [POH2]GROPRI(WNOL)
      If GCOLREM(0)<>""  Affzo [POH2]DISCRGVAL1(WNOL) : Endif
      If GCOLREM(1)<>""  Affzo [POH2]DISCRGVAL2(WNOL) : Endif
      If GCOLREM(2)<>""  Affzo [POH2]DISCRGVAL3(WNOL) : Endif
      If GCOLREM(3)<>""  Affzo [POH2]DISCRGVAL4(WNOL) : Endif
      If GCOLREM(4)<>""  Affzo [POH2]DISCRGVAL5(WNOL) : Endif
      If GCOLREM(5)<>""  Affzo [POH2]DISCRGVAL6(WNOL) : Endif
      If GCOLREM(6)<>""  Affzo [POH2]DISCRGVAL7(WNOL) : Endif
      If GCOLREM(7)<>""  Affzo [POH2]DISCRGVAL8(WNOL) : Endif
      If GCOLREM(8)<>""  Affzo [POH2]DISCRGVAL9(WNOL) : Endif
      Affzo [POH2]NETPRI(WNOL), LINAMT(WNOL)
    Endif
  When "PTH1"
    [M:PTH1]GROPRI(WNOL)=WGROPRI
    [M:PTH1]NETPRI(WNOL)=WNETPRI
    [M:PTH1]LINAMT(WNOL)=WMONTANT
    If !GIMPORT
      Affzo [PTH1]GROPRI(WNOL)
      If GCOLREM(0)<>""  Affzo [PTH1]DISCRGVAL1(WNOL) : Endif
      If GCOLREM(1)<>""  Affzo [PTH1]DISCRGVAL2(WNOL) : Endif
      If GCOLREM(2)<>""  Affzo [PTH1]DISCRGVAL3(WNOL) : Endif
      If GCOLREM(3)<>""  Affzo [PTH1]DISCRGVAL4(WNOL) : Endif
      If GCOLREM(4)<>""  Affzo [PTH1]DISCRGVAL5(WNOL) : Endif
      If GCOLREM(5)<>""  Affzo [PTH1]DISCRGVAL6(WNOL) : Endif
      If GCOLREM(6)<>""  Affzo [PTH1]DISCRGVAL7(WNOL) : Endif
      If GCOLREM(7)<>""  Affzo [PTH1]DISCRGVAL8(WNOL) : Endif
      If GCOLREM(8)<>""  Affzo [PTH1]DISCRGVAL9(WNOL) : Endif
      Affzo [PTH1]NETPRI(WNOL), LINAMT(WNOL)
    Endif
  When "PNH1"
    [M:PNH1]GROPRI(WNOL)=WGROPRI
    [M:PNH1]NETPRI(WNOL)=WNETPRI
    [M:PNH1]LINAMT(WNOL)=WMONTANT
    If !GIMPORT
      Affzo [PNH1]GROPRI(WNOL)
      If GCOLREM(0)<>""  Affzo [PNH1]DISCRGVAL1(WNOL) : Endif
      If GCOLREM(1)<>""  Affzo [PNH1]DISCRGVAL2(WNOL) : Endif
      If GCOLREM(2)<>""  Affzo [PNH1]DISCRGVAL3(WNOL) : Endif
      If GCOLREM(3)<>""  Affzo [PNH1]DISCRGVAL4(WNOL) : Endif
      If GCOLREM(4)<>""  Affzo [PNH1]DISCRGVAL5(WNOL) : Endif
      If GCOLREM(5)<>""  Affzo [PNH1]DISCRGVAL6(WNOL) : Endif
      If GCOLREM(6)<>""  Affzo [PNH1]DISCRGVAL7(WNOL) : Endif
      If GCOLREM(7)<>""  Affzo [PNH1]DISCRGVAL8(WNOL) : Endif
      If GCOLREM(8)<>""  Affzo [PNH1]DISCRGVAL9(WNOL) : Endif
      Affzo [PNH1]NETPRI(WNOL), LINAMT(WNOL)
    Endif
Endcase
#-----
End
