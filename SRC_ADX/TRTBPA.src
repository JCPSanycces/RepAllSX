###################################################################################
## Gestion des adresses
###################################################################################
Subprog CHARG_BPA(TYP,ENTITE,DEFADD)
Value Integer TYP
Value Char    ENTITE
Value Char    DEFADD
Raz [M]
nolign = 0
[M]IDENT  = num$(TYP)+ENTITE
[M]NUMBPA = TYP
For [BPA]BPA0 Where BPATYP=TYP & BPANUM=ENTITE
 If nolign>=dim([M]CODADR)
  Call ERREUR(mess(33,102,1)-":"-mess(26,100,1)) From GESECRAN : Break
 Endif
 nolign += 1
 [M] = [F:BPA]
 [M]CODADR(nolign-1)  = [F:BPA]BPAADD
 [M]BPACRY(nolign-1)  = [F:BPA]CRY
 [M]ADDLIG1(nolign-1) = [F:BPA]BPAADDLIG(0)
 [M]ADDLIG2(nolign-1) = [F:BPA]BPAADDLIG(1)
 [M]ADDLIG3(nolign-1) = [F:BPA]BPAADDLIG(2)
 If dim([M]NAM1)>0
  [M]NAM1(nolign-1) = [F:BPA]NAM(0)
  [M]NAM2(nolign-1) = [F:BPA]NAM(1)
 Endif
 If [F:BPA]BPAADD = DEFADD
  [M]BPAADDFLG (nolign -1) = 2
 Else
  [M]BPAADDFLG (nolign -1) = 1
 Endif
 If dim([M]ATEL)>0
  For I=1 To dim([M]ATEL)
   Assign "[M]TEL"+num$(I)+"(nolign-1)" With [F:BPA]TEL(I-1)
  Next I
 Endif
 If dim([M]AWEB)>0
  For I=1 To dim([M]AWEB)
   Assign "[M]WEB"+num$(I)+"(nolign-1)" With [F:BPA]WEB(I-1)
  Next I
 Endif
 If dim([M]TEL1)>0
  For I=1 To dim([F:BPA]TEL)
   Assign "[M]TEL"+num$(I)+"(nolign-1)" With [F:BPA]TEL(I-1)
  Next I
 Endif
 If dim([M]WEB1)>0
  For I=1 To dim([F:BPA]WEB)
   Assign "[M]WEB"+num$(I)+"(nolign-1)" With [F:BPA]WEB(I-1)
  Next I
 Endif

# MABON - FQ65459 - 29/06/10 - Le champ ACCNONREI a changé de table
# MABON - FQ57657 - 14/09/09
#If dim([M]ACCNONREIM)>0 Then
#  [M]ACCNONREIM(nolign -1) = G_NON
#  If clalev([M:BPR0]) and [M]CODADR(nolign-1)<>"" Then
#    Read [F:BPR]BPR0=[M:BPR0]BPRNUM
#    If !fstat Then
#      For I=0 To dim([F:BPR]ACCNONREI)-1
#        If [F:BPR]ACCNONREI(I)=[M]CODADR(nolign-1) Then
#          [M]ACCNONREIM(nolign -1) = G_OUI
#          Break
#        Endif
#      Next I
#    Endif
#  Endif
#Endif

 #LSE 23/01/2007 (cas flag faux en base) FQ39339  et 18/12/20007  FQ44884
 If [F:BPA]BPAADDFLG<>[M]BPAADDFLG (nolign -1)
  [M]FLMOD(nolign -1)=1
 Endif

 #--------------------------------------------------
 # Pour alimenter des champs spécifiques de [M]
 # à partir de zones de [F:BPA] dont le nom diffère
 #--------------------------------------------------
 GPOINT="LECT_BPA" : Gosub ENTREE From EXEFNC
 #--------------------------------------------------

Next
[M]NBADR      = nolign
If [M]NBADR>0 & !find(2,[M]BPAADDFLG(0..[M]NBADR-1))
 [M]BPAADDFLG(0) = 2
 #LSE 23/01/2007 (cas flag faux en BASE) FQ39339 et 18/12/20007 FQ44884
 [M]FLMOD(0)=1
Endif
If [M]NBADR=0
 Effzo 30-40
 Grizo 30-40
Else
 Actzo 30-40
 NOL = 0
 Gosub REMP_ADR
Endif
End

#MAE, bg 79523, fonction pour charger les adresses du site en plus des adresses tiers
Subprog CHARG_BPA_INTERSITE(TYP,ENTITE,DEFADD)
Value Integer TYP
Value Char    ENTITE
Value Char    DEFADD
#Raz [M]
#nolign = 0
nolign=[M]NBADR
[M]IDENT  = num$(TYP)+ENTITE
[M]NUMBPA = TYP
For [BPA]BPA0 Where BPATYP=TYP & BPANUM=ENTITE
 If nolign>=dim([M]CODADR)
  Call ERREUR(mess(33,102,1)-":"-mess(26,100,1)) From GESECRAN : Break
 Endif
 If find([F:BPA]BPAADD, [M]CODADR(0..[M]NBADR-1))
  Goto SUITE_BOUCLE
 Endif
 nolign += 1
 [M] = [F:BPA]
 [M]CODADR(nolign-1)  = [F:BPA]BPAADD
 [M]BPACRY(nolign-1)  = [F:BPA]CRY
 [M]ADDLIG1(nolign-1) = [F:BPA]BPAADDLIG(0)
 [M]ADDLIG2(nolign-1) = [F:BPA]BPAADDLIG(1)
 [M]ADDLIG3(nolign-1) = [F:BPA]BPAADDLIG(2)
 If dim([M]NAM1)>0
  [M]NAM1(nolign-1) = [F:BPA]NAM(0)
  [M]NAM2(nolign-1) = [F:BPA]NAM(1)
 Endif
 If [F:BPA]BPAADD = DEFADD
  [M]BPAADDFLG (nolign -1) = 2
 Else
  [M]BPAADDFLG (nolign -1) = 1
 Endif
 If dim([M]ATEL)>0
  For I=1 To dim([M]ATEL)
   Assign "[M]TEL"+num$(I)+"(nolign-1)" With [F:BPA]TEL(I-1)
  Next I
 Endif
 If dim([M]AWEB)>0
  For I=1 To dim([M]AWEB)
   Assign "[M]WEB"+num$(I)+"(nolign-1)" With [F:BPA]WEB(I-1)
  Next I
 Endif
 If dim([M]TEL1)>0
  For I=1 To dim([F:BPA]TEL)
   Assign "[M]TEL"+num$(I)+"(nolign-1)" With [F:BPA]TEL(I-1)
  Next I
 Endif
 If dim([M]WEB1)>0
  For I=1 To dim([F:BPA]WEB)
   Assign "[M]WEB"+num$(I)+"(nolign-1)" With [F:BPA]WEB(I-1)
  Next I
 Endif

 #LSE 23/01/2007 (cas flag faux en base) FQ39339  et 18/12/20007  FQ44884
 If [F:BPA]BPAADDFLG<>[M]BPAADDFLG (nolign -1)
  [M]FLMOD(nolign -1)=1
 Else
  [M]FLMOD(nolign-1)=2
 Endif

 #--------------------------------------------------
 # Pour alimenter des champs spécifiques de [M]
 # à partir de zones de [F:BPA] dont le nom diffère
 #--------------------------------------------------
 GPOINT="LECT_BPA_INTERSITE" : Gosub ENTREE From EXEFNC
 #--------------------------------------------------

$SUITE_BOUCLE
Next

[M]NBADR      = nolign
If [M]NBADR>0 & !find(2,[M]BPAADDFLG(0..[M]NBADR-1))
 [M]BPAADDFLG(0) = 2
 #LSE 23/01/2007 (cas flag faux en BASE) FQ39339 et 18/12/20007 FQ44884
 [M]FLMOD(0)=1
Endif
If [M]NBADR=0
 Effzo 30-40
 Grizo 30-40
Else
 Actzo 30-40
 NOL = 0
 Gosub REMP_ADR
Endif
End


Subprog CREBPA(TYP,ENTITE)
Value Integer TYP
Value Char    ENTITE
Local Integer STA , I , J , OLDADR
Local Char    ACTION(20)
If dim([M]VLYSTR)>0 & dim([M]TYPADD)>0
 For I=0 To [M]NBADR-2
  For J=I+1 To [M]NBADR-1
   If [M]TYPADD(I)=[M]TYPADD(J)
    If ([M]VLYSTR(I)=[0/0/0] & [M]VLYEND(I)=[0/0/0])
&    | ([M]VLYSTR(J)=[0/0/0] & [M]VLYEND(J)=[0/0/0])
&    | ([M]VLYSTR(I)=[0/0/0] & [M]VLYSTR(J)<=[M]VLYEND(I))
&    | ([M]VLYSTR(J)=[0/0/0] & [M]VLYSTR(I)<=[M]VLYEND(J))
&    | ([M]VLYEND(I)=[0/0/0] & [M]VLYEND(J)>=[M]VLYSTR(I))
&    | ([M]VLYEND(J)=[0/0/0] & [M]VLYEND(I)>=[M]VLYSTR(J))
&    | ([M]VLYSTR(I)<=[M]VLYEND(J) & [M]VLYEND(I)>=[M]VLYSTR(J))
&    | ([M]VLYSTR(J)<=[M]VLYEND(I) & [M]VLYEND(J)>=[M]VLYSTR(I))
     Call ERREUR(mess(175,133,1)-":"-[M]CODADR(I)-[M]CODADR(J)) From GESECRAN
     # Chevauchement de dates de validité des adresses
     GOK = 0 : Break 2
    Endif
   Endif
  Next J
 Next I
Endif
If GOK<1 : End : Endif

#========================================================================
# FGR 20/10/2009 : X3SUIVI55745 (début)
Local Char SCLEPRIM(GLONVCR), SCLESEC(GLONVCR)(0..1)
Local Char SDOSSIER(GLONVCR)
Local Char PARAM(250)(5)

SDOSSIER = nomap
# FGR 20/10/2009 : X3SUIVI55745 (fin)
#========================================================================
OLDADR = 0
For [BPA] Where BPATYP=TYP & BPANUM=ENTITE
 OLDADR += 1
 If !find([F:BPA]BPAADD,[M]CODADR(0..[M]NBADR-1))
   #========================================================================
   # FGR 20/10/2009 : X3SUIVI55745 (début)
     PARAM(1) = "ADR"
     PARAM(2) = [F:BPA]BPANUM                             #'BPANUM'
     PARAM(3) = num$([F:BPA]BPATYP) + "~" + [F:BPA]BPAADD #'BPATYP' + "~" + 'BPAADD'
     SCLEPRIM = [F:BPA]BPANUM                             #'BPANUM'
     SCLESEC(0) = num$([F:BPA]BPATYP)                     #'BPATYP'
     SCLESEC(1) = [F:BPA]BPAADD                           #'BPAADD'
     Call ANNULATION(SDOSSIER, "ADR", SCLEPRIM, SCLESEC) From ANUCOD
     If GOK < 1 Then
       Break
     Endif
     #Delete [BPA]
     #If fstat = 1
     #  GOK = -1 : GLOCK = "$BPADDRESS"-num$(TYP)-ENTITE-[F:BPA]BPAADD : Break
     #Endif
   # FGR 20/10/2009 : X3SUIVI55745 (fin)
   #========================================================================
 Endif
Next
If GOK<1 : End : Endif
If [M]NBADR>0 & !find(2,[M]BPAADDFLG(0..[M]NBADR-1))
 [M]BPAADDFLG(0) = 2
 #LSE 23/01/2007 (cas flag faux en BASE) FQ39339 et 18/12/20007 FQ44884
 [M]FLMOD(0)=1
Endif

Local Integer IRANGRIB  # FGR 05/08/2013 : X3SUIVI91562
Local Integer INIRIB    # FGR 05/08/2013 : X3SUIVI91562

For nolign=1 To [M]NBADR
 If !OLDADR or [M]FLMOD(nolign-1)
  Readlock [BPA]BPA0 = TYP;ENTITE;[M]CODADR(nolign-1)
  STA = fstat
  If STA=1
   GOK = -1 : GLOCK = "$BPADDRESS"-num$(TYP)-ENTITE-[M]CODADR(nolign-1) : Break
  Endif
  [F:BPA] = [M]
  [F:BPA]BPATYP       = TYP
  [F:BPA]BPANUM       = ENTITE
  [F:BPA]BPAADD       = [M]CODADR(nolign-1)
  If dim([M]NAM1)>0
   [F:BPA]NAM(0) = [M]NAM1(nolign-1)
   [F:BPA]NAM(1) = [M]NAM2(nolign-1)
  Endif
  If dim([M]ATEL)>0
   For I=1 To dim([M]ATEL)
    [F:BPA]TEL(I-1)    = evalue("[M]TEL"+num$(I)+"(nolign-1)")
   Next I
   If dim([F:BPA]FAX)>0
    [F:BPA]FAX = [F:BPA]TEL(1)
   Endif
   If dim([F:BPA]MOB)>0
    [F:BPA]MOB = [F:BPA]TEL(4)
   Endif
  Endif
  If dim([M]AWEB)>0
   For I=1 To dim([M]AWEB)
    [F:BPA]WEB(I-1)    = evalue("[M]WEB"+num$(I)+"(nolign-1)")
   Next I
  Endif
  If dim([M]TEL1)>0
   For I=1 To dim([F:BPA]TEL)
    [F:BPA]TEL(I-1)    = evalue("[M]TEL"+num$(I)+"(nolign-1)")
   Next I
   If dim([F:BPA]FAX)>0
    [F:BPA]FAX = [F:BPA]TEL(1)
   Endif
   If dim([F:BPA]MOB)>0
    [F:BPA]MOB = [F:BPA]TEL(4)
   Endif
  Endif
  If dim([M]WEB1)>0
   For I=1 To dim([F:BPA]WEB)
    [F:BPA]WEB(I-1)    = evalue("[M]WEB"+num$(I)+"(nolign-1)")
   Next I
  Endif
  [F:BPA]BPAADDLIG(0) = [M]ADDLIG1(nolign-1)
  [F:BPA]BPAADDLIG(1) = [M]ADDLIG2(nolign-1)
  [F:BPA]BPAADDLIG(2) = [M]ADDLIG3(nolign-1)
  [F:BPA]CRY          = [M]BPACRY(nolign-1)

  ##-----------------------------------------------------------
  ## RBA EXI 75237 / EDI
  ##-----------------------------------------------------------
  If dim([M]XGLNCOD) > 0
    [F:BPA]GLNCOD = [M]XGLNCOD
  Endif
  If dim([M]XCRN) > 0
    [F:BPA]CRN = [M]XCRN
  Endif

  # ------------------------------------------------
  # FGR 13/08/2013 : X2SUIVI91811 ne faire que si les banques existent
  If dim([M]NBRIB) >= 0 Then
    # FGR 05/08/2013 : X3SUIVI91562 (début)
    If [M]NBRIB > 0 Then
      IRANGRIB = find([F:BPA]BPAADD, [M]BIDBPAADD(0..[M]NBRIB-1))
      If IRANGRIB Then
        # Si l'adresse a au moins une banque on va chercher celle par défaut
        If [M]BIDNUMFLG(IRANGRIB) = 2 Then
          # Si par chance elle est par défaut on la tient
          [F:BPA]BPABID = [M]BIDNUM(IRANGRIB)
        Else
          # Sinon il faut la chercher
          For INIRIB = 0 To [M]NBRIB-1
            If [M]BIDBPAADD(INIRIB) = [F:BPA]BPAADD and [M]BIDNUMFLG(INIRIB) = 2 Then
              [F:BPA]BPABID = [M]BIDNUM(INIRIB)
              Break
            Endif
          Next INIRIB
        Endif
      Else
        # Sinon, on va regarder dans le RIB "toutes adresses" ([M]BIDBPAADD = "")
        IRANGRIB = find("", [M]BIDBPAADD(0..[M]NBRIB-1))
        If IRANGRIB Then
          # Si l'adresse a au moins une banque on va chercher celle par défaut
          If [M]BIDNUMFLG(IRANGRIB) = 2 Then
            # Si par chance elle est par défaut on la tient
            [F:BPA]BPABID = [M]BIDNUM(IRANGRIB)
          Else
            # Sinon il faut la chercher
            For INIRIB = 0 To [M]NBRIB-1
              If [M]BIDBPAADD(INIRIB) = "" and [M]BIDNUMFLG(INIRIB) = 2 Then
                [F:BPA]BPABID = [M]BIDNUM(INIRIB)
                Break
              Endif
            Next INIRIB
          Endif
        Endif
      Endif
    Else
      # S'il n'y a pas de banque, c'est toujours vide
      Raz [F:BPA]BPABID
    Endif
    # FGR 05/08/2013 : X3SUIVI91562 (fin)
  Endif
  # ------------------------------------------------

  ACTION = "ECRIT_BPA"
  Gosub ACTION_BPA
  #--------------------------------------------------
  # Pour alimenter des champs spécifiques de [F:BPA]
  # à partir de zones de [M] dont le nom diffère
  #--------------------------------------------------
  GPOINT="ECRIT_BPA" : Gosub ENTREE From EXEFNC
  #--------------------------------------------------
  If STA
   If dim([F:BPA]CREDAT)>0 : [F:BPA]CREDAT = date$ : Endif
   If dim([F:BPA]CREUSR)>0 : [F:BPA]CREUSR = GUSER : Endif
   If dim([F:BPA]CRETIM)>0 : [F:BPA]CRETIM = time  : Endif
   #MAE, bg 95924
   If dim([F:BPA]UPDDAT)>0 : [F:BPA]UPDDAT = [0/0/0] : Endif
   If dim([F:BPA]UPDUSR)>0 : [F:BPA]UPDUSR = "" : Endif
   If dim([F:BPA]UPDTIM)>0 : [F:BPA]UPDTIM = 0  : Endif
   #Fin MAE
   Write [BPA]
  Else
   If dim([F:BPA]UPDDAT)>0 : [F:BPA]UPDDAT = date$ : Endif
   If dim([F:BPA]UPDUSR)>0 : [F:BPA]UPDUSR = GUSER : Endif
   If dim([F:BPA]UPDTIM)>0 : [F:BPA]UPDTIM = time  : Endif
   Rewrite [BPA]
  Endif
  If fstat
   GOK = 0 : Call FSTA("BPA") From GLOCK : Break
  Endif
 Endif
Next nolign
If GOK=1
 # Gestion des adresses complémentaires Afrique du Sud
 ACTION = "ADD_BPA"
 Gosub ACTION_BPA
 Raz [M]FLMOD
Endif
End

Subprog ANNBPA(TYP,ENTITE)
Value Integer TYP
Value Char    ENTITE

#========================================================================
# FGR 20/10/2009 : X3SUIVI55745 (début)
Local Char SCLEPRIM(GLONVCR), SCLESEC(GLONVCR)(0..1)
Local Char SDOSSIER(GLONVCR)
Local Char PARAM(250)(5)

  SDOSSIER = nomap
# FGR 20/10/2009 : X3SUIVI55745 (fin)
#========================================================================
  GCLE = num$(TYP)+ENTITE
  #========================================================================
  # FGR 20/10/2009 : X3SUIVI55745 (début)
     For [BPA] Where  BPATYP = TYP and BPANUM = ENTITE
       PARAM(1) = "ADR"
       PARAM(2) = ENTITE                                     #'BPANUM'
       PARAM(3) = num$([F:BPA]BPATYP) + "~" + [F:BPA]BPAADD  #'BPATYP' + "~" + 'BPAADD'
       SCLEPRIM = [F:BPA]BPANUM                              #'BPANUM'
       SCLESEC(0) = num$([F:BPA]BPATYP)                      #'BPATYP'
       SCLESEC(1) = [F:BPA]BPAADD                            #'BPAADD'
       Call ANNULATION(SDOSSIER, "-ADR", SCLEPRIM, SCLESEC) From ANUCOD
       If GOK < 1 Then
         Break
       Endif
     Next
     If GOK < 1 Then
       GLOCK = "$BPADDRESS" - PARAM(2) - PARAM(3)
       End
     Endif
     #Delete [BPA] Where BPATYP=TYP & BPANUM=ENTITE
     #If fstat = 1
     #  GOK = -1
     #  GLOCK = "$BPADDRESS"-GCLE : End
     #Endif
   # FGR 20/10/2009 : X3SUIVI55745 (fin)
   #========================================================================
End

Subprog CHGBPA(TYP,OLDENT,NEWENT)
Value Integer TYP
Value Char    OLDENT
Value Char    NEWENT
For [BPA] Where BPATYP=TYP & BPANUM=OLDENT
 [F:BPA]BPANUM = NEWENT
 Rewrite [BPA]
 If fstat
  GOK = 0 : Call FSTA("BPA") From GLOCK : Break
 Endif
Next
End

########################################################################
# Action TRTBPA
########################################################################
$ACTION_BPA
Local Integer OKTRT
Call EXISTE_ADX("","","TRTBPAB",OKTRT) From ORDSYS
If OKTRT>0
 Gosub ACTION From TRTBPAB
Endif
Return

########################################################################
## Ecran BPA
########################################################################
$CHARGE_ADR
If !GWEBSERV Then  # FGR 09/02/2015 : X3SUIVI101637
  Gosub REMP_ADR
Endif
# Gestion des adresses complémentaires Afrique du Sud
ACTION = "REMP_ADRB"
Gosub ACTION_BPA
Affzo 30-40
Return

$REMP_ADR
[M]XCODADR     = [M]CODADR(NOL)
[M]XBPADES     = [M]BPADES   (NOL)
If dim([M]XTYPADD)>0
 [M]XTYPADD = [M]TYPADD(NOL)
Endif
[M]XBPACRY     = [M]BPACRY(NOL)
[M]XCRYNAM     = [M]CRYNAM(NOL)
If dim([M]XNAM)>0
 [M]XNAM(0) = [M]NAM1(NOL)
 [M]XNAM(1) = [M]NAM2(NOL)
Endif
[M]XADDLIG1    = [M]ADDLIG1(NOL)
[M]XADDLIG2    = [M]ADDLIG2(NOL)
[M]XADDLIG3    = [M]ADDLIG3(NOL)
If dim([M]XSAT)>0
 [M]XSAT    = [M]SAT(NOL)
Endif
[M]XPOSCOD     = [M]POSCOD(NOL)
[M]XCTY        = [M]CTY(NOL)
If dim([M]XCODSEE)>0
 [M]XCODSEE = [M]CODSEE(NOL)
Endif
If dim([M]XTEL)>0
 [M]XTEL        = [M]TEL(NOL)
 [M]XMOB        = [M]MOB(NOL)  # FGR 23/07/2008 : X3SUIVI48432 ajout téléphone portable
 [M]XFAX        = [M]FAX(NOL)
Elsif dim([M]XTEL1)>0
 For I=1 To dim([F:BPA]TEL)
  Assign "[M]XTEL"+num$(I) With evalue("[M]TEL"+num$(I)+"(NOL)")
 Next I
Else
 For I=1 To dim([M]ATEL)
  [M]ATEL(I-1)    = evalue("[M]TEL"+num$(I)+"(NOL)")
 Next I
Endif
If dim([M]XWEB)>0
 [M]XWEB        = [M]WEB(NOL)
Elsif dim([M]XWEB1)>0
 For I=1 To dim([F:BPA]WEB)
  Assign "[M]XWEB"+num$(I) With evalue("[M]WEB"+num$(I)+"(NOL)")
 Next I
Else
 For I=1 To dim([M]AWEB)
  [M]AWEB(I-1)    = evalue("[M]WEB"+num$(I)+"(NOL)")
 Next I
Endif
If dim([M]AFCYWEB)>0
 [M]AFCYWEB = [M]FCYWEB(NOL)
Endif
If dim([M]XFCYWEB)>0
 [M]XFCYWEB = [M]FCYWEB(NOL)
Endif
If dim([M]XEXTNUM)>0
 [M]XEXTNUM = [M]EXTNUM(NOL)
Endif
[M]XBPAADDFLG  = [M]BPAADDFLG(NOL)
If dim([M]XVLYSTR)>0
 [M]XVLYSTR = [M]VLYSTR(NOL)
 [M]XVLYEND = [M]VLYEND(NOL)
Endif
If func AFNC.ACTIV("LTA") and dim([M]XADRVAL)>0        #LTA.sn
 [M]XADRVAL    = [M]ADRVAL(NOL)
 If func TRTADRLIB.CHKADR_CRY([M]XBPACRY)
   Chgfmt [M]VALADR  With "K:"  + num$(type([M]VALADR)-10)  + "B"     # show
   Chgfmt [M]XADRVAL With "LA:1"
 Else
   Chgfmt [M]VALADR  With "-K:"  + num$(type([M]VALADR)-10)  + "B"     # hide
   Chgfmt [M]XADRVAL With "-LA:1"
 Endif
Endif
##-----------------------------------------------------------
## RBA EXI 75237 / EDI
##-----------------------------------------------------------
If dim([M]XGLNCOD) > 0
  [M]XGLNCOD = [M]GLNCOD(NOL)
Endif
If dim([M]XCRN) > 0
  If clalev([M:BPR1]) #tiers
    [M]XCRN = [M]CRN(NOL)
  Elsif clalev([M:BPRC]) #clients
    [M]XCRN = [M]CRN(NOL)
  Elsif clalev([M:BPRS]) #fournisseurs
    [M]XCRN = [M]CRN(NOL)
  Endif
Endif
# MABON - FQ65459 - 29/06/10 - Le champ ACCNONREI a changé de table
# MABON - FQ57657 - 14/09/09
#If dim([M]ACCNONREIM)>0 Then
#  [M]XACCNONREIM = [M]ACCNONREIM(NOL)
#Endif
Call LECTURE("TCY",[M]XBPACRY,"") From CONTOBJ
Call TITRES
If dim([M]XCODSEE)>0
 If [F:TCY]POSCODCTL<>2
  # 39555
  Raz [M]CODSEE(NOL)
  Effzo XCODSEE
  Grizo XCODSEE
 Else
  Actzo XCODSEE
 Endif
Endif
If [M]XBPACRY<>""
 Diszo XCRYNAM
Else
 Actzo XCRYNAM
Endif
#--------------------------------------------------
# Pour alimenter des champs spécifiques [M]Xzone
# à partir de la zone de tableau [M]zone(NOL)
#--------------------------------------------------
GPOINT="REMP_ADRBPA" : Gosub ENTREE From EXEFNC
#--------------------------------------------------
Return

Subprog TITRES
Onerrgo ERREUR
Local Integer I , K
Local Char    EBOITE(GLONFEN) , WINPROG(GLONADC)
If GABREV<>""
 Call CONT_FEN(GABREV,EBOITE) From GOBJET
 If EBOITE<>""
  Call NOMTRTWIN(EBOITE,WINPROG) From MSKDIV
  Gosub DEFVAR From =WINPROG
  For I=0 To NBMASK
   If instr(1,ABMSK(I),"BPA")
    K = I : Break
   Endif
  Next I
  If K
   Gosub TITRES From ="W1"+NOMMSK(I)
  Endif
 Endif
Endif
End

$ERREUR
Resume

Subprog IB_NBADR
If GPRODUIT=4 : End : Endif
If [M]NUMBPA<>GADDFCY
 GBOUT1 = ""
Else
 Gosub GETSOC
 If SOCIETE=""
  GBOUT1 = ""
 Endif
Endif
End

Subprog AS_NBADR
Gosub SETNOL
If GREP="D"
 Raz [M]IDENT
Endif
If nolign>0
 [M]XNUMLIG = nolign -1
 Gosub CHARGE_ADR
Endif
If nolign<1 or [M]XCODADR=""
 Grizo 30
Else
 Actzo 30
Endif
End

Subprog C_NBADR
Local Integer NOL
Case status
 When 65
  NOL = nolign-1
  Call VERF_ANU([M]IDENT,[M]CODADR(NOL))
 When 68,83
  For NOL=nolign-1 To nolign1-1
   Call VERF_ANU([M]IDENT,[M]CODADR(NOL))
   If mkstat : Break : Endif
  Next NOL
Endcase
End

Subprog VERF_ANU(CLE,VALEUR)
Value Char CLE
Value Char VALEUR
Local Integer I , J , K
For I=0 To 100
 If maskabr(I)<>""
  K = evalue("dim([M:"+maskabr(I)+"]BIDBPAADD)")
  If K>0
   Default Mask "["+maskabr(I)+"]"
   If dim([M]IDENT)>0 & [M]IDENT=CLE
    If find(VALEUR,[M]BIDBPAADD)
     GMESSAGE = VALEUR-":"-mess(169,133,1) : # Code adresse utilisé dans un RIB
     mkstat = 1 : Break
    Endif
   Endif
  Endif
 Endif
Next I
If mkstat : End : Endif
For I=0 To 100
 If maskabr(I)<>""
  K = evalue("dim([M:"+maskabr(I)+"]CNTADD)")
  If K>0
   Default Mask "["+maskabr(I)+"]"
   If dim([M]IDENT)>0 & [M]IDENT=CLE
    If find(VALEUR,[M]CNTADD)
     GMESSAGE = VALEUR-":"-mess(170,133,1) : # Code adresse utilisé dans un contact
     mkstat = 1 : Break
    Endif
   Endif
  Endif
 Endif
Next I
If mkstat : End : Endif
If !find(GREP,"C","D")
  #========================================================================
  # FGR 20/10/2009 : X3SUIVI55745 (début)
  Local Integer OKANU
  Local Char SCLEPRIM(GLONVCR), SCLESEC(GLONVCR)(0..1)
  Local Char PARAM(250)(5)

  PARAM(1) = "ADR"
  PARAM(2) = mid$(CLE,2, len(CLE))       #'BPANUM'
  PARAM(3) = left$(CLE,1) + "~" + VALEUR #'BPATYP' + "~" + 'BPAADD'
  SCLEPRIM = mid$(CLE,2, len(CLE))       #'BPANUM'
  SCLESEC(0) = left$(CLE,1)              #'BPATYP'
  SCLESEC(1) = VALEUR                    #'BPAADD'
  Call VERIF(nomap, "ADR", SCLEPRIM, SCLESEC, OKANU) From ANUCOD
  If !OKANU Then
    mkstat = 1
    End
  Endif
  # FGR 20/10/2009 : X3SUIVI55745 (fin)
  #========================================================================
  # Issue X3-81390 - 2018-07-13 by ALSHE : Prohibit deletion of address if used as Intesite address
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  # Delete address in GESFCY
  If SCLESEC(0) = "3" Then          # BPATYP = Site
    # check if site has an "Intersite" busines partner address (unique link)
    Filter [F:BPR] Where [F:BPR]BETFCY = [V]CST_AYES and [F:BPR]FCY = SCLEPRIM
    Read [F:BPR] First
    If !fstat Then
      # If address "Intersite" we have to check if used as Business partner address to allow to delete the line
      SCLESEC(0) = "1"              #'BPATYP' --> Business partner
      Call VERIF(nomap, "ADR", [F:BPR]BPRNUM, SCLESEC, OKANU) From ANUCOD
      If !OKANU Then
        mkstat = 1
        Filter [F:BPR]
        End
      Endif
    Endif
    Filter [F:BPR]
  # Delete address in GESBPR
  Elsif SCLESEC(0) = "1" Then       # BPATYP = Business partner
    If [F:BPR]BPRNUM <> SCLEPRIM Then
      Read [BPR]BPR0=SCLEPRIM
    Endif
    If !fstat and [F:BPR]BETFCY = [V]CST_AYES Then
      # If address "Intersite" we have to check if used as a site in a PO to allow to delete the line
      SCLESEC(0) = "3"              #'BPATYP' --> Site
      Call VERIF(nomap, "ADR", [F:BPR]FCY, SCLESEC, OKANU) From ANUCOD
      If !OKANU Then
        mkstat = 1
        End
      Endif
    Endif
  Endif
  # End issue X3-81390
Endif
End

Subprog B1_NBADR
# Copie des adresses sociétés => site
Gosub SETNOL
Local Integer NBRADR , MAXADR
MAXADR = dim([M]CODADR)
Local Char    WCODADR(GLONBPA)(1..MAXADR)
Local Char    WBPADES(GLONDES)(1..MAXADR)
Local Char    WTYPADD(GLONADI)(1..MAXADR)
Local Char    WBPACRY(GLONCRY)(1..MAXADR)
Local Char    WCRYNAM(GLONNCY)(1..MAXADR)
Local Char    WNAM1(GLONNAM)(1..MAXADR)
Local Char    WNAM2(GLONNAM)(1..MAXADR)
Local Char    WADDLIG1(GLONADL)(1..MAXADR)
Local Char    WADDLIG2(GLONADL)(1..MAXADR)
Local Char    WADDLIG3(GLONADL)(1..MAXADR)
Local Char    WSAT(GLONSAT)(1..MAXADR)
Local Char    WPOSCOD(GLONPOS)(1..MAXADR)
Local Char    WCTY(GLONCTY)(1..MAXADR)
Local Char    WCODSEE(10)(1..MAXADR)
Local Char    WTEL(GLONTEL)(1..MAXADR)
Local Char    WMOB(GLONTEL)(1..MAXADR) # FGR 23/07/2008 : X3SUIVI48432 ajout téléphone portable
Local Char    WFAX(GLONTEL)(1..MAXADR)
Local Char    WTEL1(GLONTEL)(1..MAXADR)
Local Char    WTEL2(GLONTEL)(1..MAXADR)
Local Char    WTEL3(GLONTEL)(1..MAXADR)
Local Char    WTEL4(GLONTEL)(1..MAXADR)
Local Char    WTEL5(GLONTEL)(1..MAXADR)
Local Char    WWEB(GLONMAI)(1..MAXADR)
Local Char    WWEB1(GLONMAI)(1..MAXADR)
Local Char    WWEB2(GLONMAI)(1..MAXADR)
Local Char    WWEB3(GLONMAI)(1..MAXADR)
Local Char    WWEB4(GLONMAI)(1..MAXADR)
Local Char    WWEB5(GLONMAI)(1..MAXADR)
Local Char    WFCYWEB(250)(1..MAXADR)
Local Char    WEXTNUM(30)(1..MAXADR)
Local Date    WVLYSTR(1..MAXADR)
Local Date    WVLYEND(1..MAXADR)
Local Integer WADDFLG(1..MAXADR)
Local Integer I , J
Gosub GETSOC
If SOCIETE="" : End : Endif
Local File BPADDRESS [XBPA]
For [XBPA] Where BPATYP=GADDCPY and BPANUM=SOCIETE
 If !find([F:XBPA]BPAADD,[M]CODADR(0..[M]NBADR-1))
  NBRADR   += 1
  WCODADR(NBRADR)  = [F:XBPA]BPAADD
  WBPADES(NBRADR)  = [F:XBPA]BPADES
  If dim([F:XBPA]TYPADD)>0
   WTYPADD(NBRADR) = [F:XBPA]TYPADD
  Endif
  WBPACRY(NBRADR)  = [F:XBPA]CRY
  WCRYNAM(NBRADR)  = [F:XBPA]CRYNAM
  If dim([F:XBPA]NAM)>0
   WNAM1(NBRADR)   = [F:XBPA]NAM(0)
   WNAM2(NBRADR)   = [F:XBPA]NAM(1)
  Endif
  WADDLIG1(NBRADR) = [F:XBPA]BPAADDLIG(0)
  WADDLIG2(NBRADR) = [F:XBPA]BPAADDLIG(1)
  WADDLIG3(NBRADR) = [F:XBPA]BPAADDLIG(2)
  If dim([F:XBPA]SAT)>0
   WSAT (NBRADR)   = [F:XBPA]SAT
  Endif
  WPOSCOD(NBRADR)  = [F:XBPA]POSCOD
  WCTY (NBRADR)    = [F:XBPA]CTY
  If dim([F:XBPA]CODSEE)>0
   WCODSEE(NBRADR) = [F:XBPA]CODSEE
  Endif
  If dim([M]XTEL)>0
   WTEL (NBRADR)    = [F:XBPA]TEL
   WMOB (NBRADR)    = [F:XBPA]MOB  # FGR 23/07/2008 : X3SUIVI48432 ajout téléphone portable
   WFAX (NBRADR)    = [F:XBPA]FAX
  Else
   For K=1 To dim([F:XBPA]TEL)
    Assign "WTEL"+num$(K)+"(NBRADR)" With [F:XBPA]TEL(K-1)
   Next K
  Endif
  If dim([M]XWEB)>0
   WWEB (NBRADR)    = [F:XBPA]WEB
  Else
   For K=1 To dim([F:XBPA]WEB)
    Assign "WWEB"+num$(K)+"(NBRADR)" With [F:XBPA]WEB(K-1)
   Next K
  Endif
  If dim([F:XBPA]FCYWEB)>0
   WFCYWEB(NBRADR) = [F:XBPA]FCYWEB
  Endif
  If dim([F:XBPA]EXTNUM)>0
   WEXTNUM(NBRADR) = [F:XBPA]EXTNUM
  Endif
  If dim([F:XBPA]VLYSTR)>0
   WVLYSTR(NBRADR) = [F:XBPA]VLYSTR
   WVLYEND(NBRADR) = [F:XBPA]VLYEND
  Endif
  If [F:XBPA]BPAADDFLG=2 & !find(2,[M]BPAADDFLG(0..[M]NBADR-1))
   WADDFLG(NBRADR) = 2
  Else
   WADDFLG(NBRADR) = 1
  Endif
 Endif
Next
If NBRADR = 0 : End : Endif
If dim([M]CODADR)<[M]NBADR+NBRADR
 GMESSAGE = mess(45,133,1) : # Insertion impossible
 mkstat = 2 : End
Endif
Insa NOL,NBRADR [M]NBADR
J = 0
For I=NOL To NOL-1+NBRADR
 J += 1
 [M]CODADR(I)     = WCODADR (J)
 [M]BPADES(I)     = WBPADES (J)
 If dim([M]TYPADD)>0
  [M]TYPADD(I) = WTYPADD(J)
 Endif
 [M]BPACRY(I)     = WBPACRY (J)
 [M]CRYNAM(I)     = WCRYNAM (J)
 If dim([M]NAM1)>0
  [M]NAM1(I)   = WNAM1(J)
  [M]NAM2(I)   = WNAM2(J)
 Endif
 [M]ADDLIG1(I)    = WADDLIG1 (J)
 [M]ADDLIG2(I)    = WADDLIG2 (J)
 [M]ADDLIG3(I)    = WADDLIG3 (J)
 If dim([M]SAT)>0
  [M]SAT (I)   = WSAT (J)
 Endif
 [M]POSCOD(I)     = WPOSCOD (J)
 [M]CTY (I)       = WCTY (J)
 If dim([M]CODSEE)>0
  [M]CODSEE(I) = WCODSEE(J)
 Endif
 If dim([M]XTEL)>0
  [M]TEL(I)      = WTEL(J)
  [M]MOB (I)     = WMOB (J) # FGR 23/07/2008 : X3SUIVI48432 ajout téléphone portable
  [M]FAX (I)     = WFAX (J)
 Else
  For K=1 To dim([F:BPA]TEL)
   Assign "[M]TEL"+num$(K)+"(I)" With evalue("WTEL"+num$(K)+"(J)")
  Next K
 Endif
 If dim([M]XWEB)>0
  [M]WEB (I) = WWEB (J)
 Else
  For K=1 To dim([F:BPA]WEB)
   Assign "[M]WEB"+num$(K)+"(I)" With evalue("WWEB"+num$(K)+"(J)")
  Next K
 Endif
 If dim([M]FCYWEB)>0
  [M]FCYWEB(I) = WFCYWEB(J)
 Endif
 If dim([M]EXTNUM)>0
  [M]EXTNUM(I) = WEXTNUM(J)
 Endif
 [M]BPAADDFLG (I) = WADDFLG(J)
 If dim([M]VLYSTR)>0
  [M]VLYSTR(I) = WVLYSTR(J)
  [M]VLYEND(I) = WVLYEND(J)
 Endif
 [M]FLMOD(I) = 1
Next I
[M]NBADR += NBRADR
Affzo NBADR,CODADR
Gosub CHARGE_ADR
Actzo 30
Close File [XBPA]
End

$GETSOC
Local Char    SOCIETE(GLONCPY)
Local Char    ACTION(20)
ACTION = "GETSOC"
Gosub ACTION_BPA
Return

Subprog APRES_NBADR
# Spécifique à l'import --> recharger indice pour sortir boucle de saisie
nolign = [M]NBADR
End

Subprog C_CODADR(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
VALEUR = vireblc(VALEUR, 2)
Call UNICITE(VALEUR,[M]CODADR(0..[M]NBADR-1)) From OBJDIV
If mkstat : End : Endif
##-----------------------------------------------------------
## RBA EXI 75237 / EDI
##-----------------------------------------------------------
If dim([M]XCRN) > 0
#  [M]CRN(nolign-1) = [M:BPR1]CRN
  If clalev([M:BPR1]) #tiers
    [M]CRN(nolign-1) = [M:BPR1]CRN
  Elsif clalev([M:BPRC]) #clients
    [M]CRN(nolign-1) = [M:BPRC]CRN
  Elsif clalev([M:BPRS]) #fournisseurs
    [M]CRN(nolign-1) = [M:BPRS]CRN
  Endif
Endif
End

Subprog AM_CODADR(VALEUR)
Variable Char     VALEUR
Local    Char     WCODADR
Local    Integer  I
Local    Char     ACTION(20)
WCODADR = VALEUR
Gosub SETNOL
If [M]CODADR(NOL) = ""
 If nolign=1
  [M]BPAADDFLG (0)   = 2
 Else
  [M]BPAADDFLG (NOL) = 1
 Endif
 ACTION = "INIT_BPA"
 Gosub ACTION_BPA
 Gosub CHARGE_ADR
 Actzo 30
 zonsui = "XBPADES"
Else
 Call CHRIB(IDENT,[M]CODADR(NOL),VALEUR)
 Call CHCNT(IDENT,[M]CODADR(NOL),VALEUR)
Endif
[M]FLMOD(NOL) = 1
[M]XCODADR = VALEUR

# MABON - FQ65459 - 29/06/10 - Le champ ACCNONREI a changé de table
# MABON - FQ57657 - 14/09/09
#If dim([M]ACCNONREIM)>0 Then
#  Local Integer I
#  [M]ACCNONREIM=G_NON
#  If clalev([M:BPR0]) Then
#    Read [F:BPR]BPR0=[M:BPR0]BPRNUM
#    If !fstat Then
#      For I=0 To dim([F:BPR]ACCNONREI)-1
#        If [F:BPR]ACCNONREI(I)=VALEUR Then
#          [M]ACCNONREIM=G_OUI
#          Break
#        Endif
#      Next I
#    Endif
#  Endif
#Endif
End

Subprog CHRIB(CLE,OVAL,NVAL)
Value Char CLE
Value Char OVAL
Value Char NVAL
Local Integer I , J , K

For I=0 To 100
 If maskabr(I)<>""
  K = evalue("dim([M:"+maskabr(I)+"]BIDBPAADD)")
  If K>0
   Default Mask "["+maskabr(I)+"]"
   If dim([M]IDENT)>0 & [M]IDENT=CLE
    For J=0 To K-1
     If [M]BIDBPAADD(J)=OVAL
      [M]BIDBPAADD(J) = NVAL
      [M]FLMOD(J) = 1
      Affzo BIDBPAADD(J)
     Endif
    Next J
    Break
   Endif
  Endif
 Endif
Next I
End

Subprog CHCNT(CLE,OVAL,NVAL)
Value Char CLE
Value Char OVAL
Value Char NVAL
Local Integer I , J , K
For I=0 To 100
 If maskabr(I)<>""
  K = evalue("dim([M:"+maskabr(I)+"]CNTADD)")
  If K>0
   Default Mask "["+maskabr(I)+"]"
   If dim([M]IDENT)>0 & [M]IDENT=CLE
    For J=0 To K-1
     If [M]CNTADD(J)=OVAL
      [M]CNTADD(J) = NVAL
      [M]FLMOD(J) = 1
      If [M]KNOLIG=J
       KCNTADD = NVAL
       Affzo KCNTADD
      Endif
     Endif
    Next J
    Break
   Endif
  Endif
 Endif
Next I
End

Subprog AM_XBPADES(VALEUR)
Variable Char    VALEUR()
[M]BPADES ([M]XNUMLIG) = VALEUR
[M]FLMOD([M]XNUMLIG) = 1
End

Subprog AM_XTYPADD(VALEUR)
Variable Char    VALEUR()
[M]TYPADD([M]XNUMLIG) = VALEUR
[M]FLMOD([M]XNUMLIG) = 1
End

Subprog AS_XBPACRY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]XCRYNAM=""
 VALEUR = GPAYS
Endif
End

Subprog AM_XBPACRY(VALEUR)
Variable Char    VALEUR()
[M]BPACRY ([M]XNUMLIG) = VALEUR
[M]CRYNAM ([M]XNUMLIG) = [M]XCRYNAM
[M]FLMOD([M]XNUMLIG) = 1
If func AFNC.ACTIV("LTA")     #LTA.sn
  Local Char TCRY(GLONCRY)
  TCRY = VALEUR
  Gosub FMT_ADRVAL From TRTADRLIB
Endif                         #LTA.en
# FGR 19/08/2015 : X3SUIVI82477 (début)
SVXPOSCOD = [M]XPOSCOD
SVXCTY = [M]XCTY
SVXSAT = [M]XSAT
Raz [M]XPOSCOD
Raz [M]XCTY
Raz [M]XSAT
Affzo [M]XPOSCOD
Affzo [M]XCTY
Affzo [M]XSAT
# FGR 19/08/2015 : X3SUIVI82477 (fin)
End

Subprog C_XBPACRY(VALEUR)
Variable Char    VALEUR()
Call TITRES
If dim([M]SAT)>0 & [F:TCY]ETAT<=1
 Raz [M]SAT([M]XNUMLIG)
Endif
If dim([M]XCODSEE)>0
 If [F:TCY]POSCODCTL=2
  Actzo XCODSEE
 Else
  # 39555
  Raz [M]CODSEE([M]XNUMLIG)
  Effzo XCODSEE
  Grizo XCODSEE
 Endif
Endif
If VALEUR<>""
 Diszo XCRYNAM
Else
 Actzo XCRYNAM
Endif
End

Subprog AM_XCRYNAM(VALEUR)
Variable Char    VALEUR()
[M]CRYNAM ([M]XNUMLIG) = VALEUR
[M]FLMOD([M]XNUMLIG) = 1
End

Subprog AM_XNAM(VALEUR)
Variable Char    VALEUR()
Case indice
 When 0 : [M]NAM1([M]XNUMLIG) = VALEUR
 When 1 : [M]NAM2([M]XNUMLIG) = VALEUR
Endcase
[M]FLMOD([M]XNUMLIG) = 1
End

Subprog AM_XADDLIG1(VALEUR)
Variable Char    VALEUR()
[M]ADDLIG1([M]XNUMLIG) = VALEUR
[M]FLMOD([M]XNUMLIG) = 1
End

Subprog AM_XADDLIG2(VALEUR)
Variable Char    VALEUR()
[M]ADDLIG2([M]XNUMLIG) = VALEUR
[M]FLMOD([M]XNUMLIG) = 1
End

Subprog AM_XADDLIG3(VALEUR)
Variable Char    VALEUR()
[M]ADDLIG3([M]XNUMLIG) = VALEUR
[M]FLMOD([M]XNUMLIG) = 1
End

Subprog AS_XSAT(VALEUR)
Variable Char    VALEUR()
Call LECTURE("TCY",[M]XBPACRY,"") From CONTOBJ
End

Subprog AM_XSAT(VALEUR)
Variable Char    VALEUR()
[M]SAT([M]XNUMLIG) = VALEUR
[M]FLMOD([M]XNUMLIG) = 1
End

Subprog AM_XPOSCOD(VALEUR)
Variable Char    VALEUR()
[M]POSCOD([M]XNUMLIG) = VALEUR
[M]CTY([M]XNUMLIG)    = [M]XCTY
[M]SAT([M]XNUMLIG)    = [M]XSAT
[M]FLMOD([M]XNUMLIG) = 1
[M]XPOSCOD = VALEUR
Gosub INSEE
End

Subprog AP_XPOSCOD(VALEUR)
Variable Char    VALEUR()
# after tunnel but when postal code don't change
# in some case we need to charge the name of city
If [M]CTY([M]XNUMLIG)   <> [M]XCTY
      [M]CTY([M]XNUMLIG)    = [M]XCTY
Endif
If [M]SAT([M]XNUMLIG)   <> [M]XSAT
    [M]SAT([M]XNUMLIG)    = [M]XSAT
Endif
[M]FLMOD([M]XNUMLIG) = 1
Gosub INSEE

End

Subprog AM_XCTY(VALEUR)
Variable Char    VALEUR()
[M]CTY([M]XNUMLIG) = VALEUR
[M]POSCOD([M]XNUMLIG) = [M]XPOSCOD     # 18/10/01 TB
[M]SAT([M]XNUMLIG)    = [M]XSAT
[M]FLMOD([M]XNUMLIG) = 1
[M]XCTY = VALEUR
Gosub INSEE
End

Subprog C_XCTY(VALEUR)
Variable Char    VALEUR()

Local Integer I
Local Integer K
Local Char EBOITE(GLONFEN)
Local Char WINPROG(GLONADC)

  # FGR 17/02/2015 : X3SUIVI82479
  Affzo [M]XPOSCOD
  If GABREV <> "" Then
    Call CONT_FEN(GABREV, EBOITE) From GOBJET
    If EBOITE <> "" Then
      Call NOMTRTWIN(EBOITE, WINPROG) From MSKDIV
      Gosub DEFVAR From =WINPROG
      For I = 0 To NBMASK
        If instr(1,ABMSK(I),"BPA") or instr(1,ABMSK(I),"BPF") or instr(1,ABMSK(I),"AUS2") Then
          K = I
          Break
        Endif
      Next I
      If K Then
        Call C_XPOSCOD([M]XPOSCOD) From ="W1"+NOMMSK(I)
      Endif
    Endif
  Endif
End

$INSEE
# 39555
#If dim([M]XCODSEE)>0
If dim([M]XCODSEE)>0 & [F:TCY]POSCODCTL=2
 If clalev([F:POS])=0 : Local File POSCOD [POS] : Endif
 Read [POS]POS1 = [M]XBPACRY;[M]XCTY;[M]XPOSCOD
 If !fstat
  [M]XCODSEE = [F:POS]POSCTYCOD
  [M]CODSEE([M]XNUMLIG) = [M]XCODSEE
 Endif
Endif
Return

