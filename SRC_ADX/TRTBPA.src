# FGR 23/12/2014 : X3SUIVI105015 (début)
Subprog C_KCNTFNA(VALEUR)
Variable Char VALEUR()
Local Char    CLEREC(80) , MESSA(80)
Local Integer WOK
If [M]CNTFULNAM([M]KNOLIG)=""
 MESSA = mess(179,133,1) : # Confirmez_vous la création
Else
 MESSA = mess(180,133,1) : # Confirmez_vous la modification
Endif
CLEREC = func SUBAIN.CLE([M]KCNTLNA,VALEUR)
If CLEREC<>[M]CNTFULNAM([M]KNOLIG)
 Read [AIN]AIN1 = CLEREC
 If !fstat
  # FGR 11/12/2014 : X3SUIVI104600 (début)
  #WOK = 1
  # Interlocuteur déjà existant
  #Call OUINON(mess(178,133,1)+"\"+[F:AIN]CNTNUM-[F:AIN]CNTLNA-[F:AIN]CNTFNA+"\"+MESSA,WOK) From GESECRAN
  # X3-25754 - Allow duplicate contact names thru web service - replaced by parameter DUPCNTNAME below
#  If dim(GKCNTFNA) >= 0 and (GKCNTFNA = 1 or GKCNTFNA = 2) Then
#    WOK = GKCNTFNA
#  Else
#    WOK = 1
#  Endif
  # Interlocuteur déjà existant
  If !GWEBSERV Then
    Call OUINON(mess(178,133,1)+"\"+[F:AIN]CNTNUM-[F:AIN]CNTLNA-[F:AIN]CNTFNA+"\"+MESSA,WOK) From GESECRAN
  Else
    GMESSAGE = mess(178,133,1)+"\"+[F:AIN]CNTNUM-[F:AIN]CNTLNA-[F:AIN]CNTFNA
    # X3-25754 - Allow duplicate contact names thru web service- Start
    Local Char DUPCNTNAME (2)
    Call PARAM("","DUPCNTNAME", DUPCNTNAME) From ADOVAL
    If val(DUPCNTNAME)=[V]CST_AYES : WOK=2 : Endif
    # X3-25754 - Allow duplicate contact names thru web service- End
  Endif
  # FGR 11/12/2014 : X3SUIVI104600 (fin)
  If WOK<>2
   mkstat = 2 : End
  Endif
 Endif
Endif
[M]CNTFULNAM([M]KNOLIG) = CLEREC
End

