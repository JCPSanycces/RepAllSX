Subprog APRES_NBCNT
# Spécifique à l'import --> Recharger indice pour sortir de la boucle de saisie
nolign = [M]NBCNT
End

Subprog B2_NBCNT
# Copie des contacs sociétés => site
Gosub SETNOL
Local Integer NBRCNT , MAXCNT
MAXCNT = dim([M]CCNCRM)
Local Char    WCNTCOD(GLONAIN)(1..MAXCNT)
Local Integer WCNTFNC(1..MAXCNT)
Local Char    WCNTSRV(30)(1..MAXCNT)
Local Char    WCNTMSS(GLONADI)(1..MAXCNT)
Local Char    WCNTADD(GLONADR)(1..MAXCNT)
Local Char    WCNTCRY(GLONCRY)(1..MAXCNT)
Local Char    WCNTTEL(GLONTEL)(1..MAXCNT)
Local Char    WCNTMOB(GLONTEL)(1..MAXCNT) # FGR 23/07/2008 : X3SUIVI48432 ajout téléphone portable
Local Char    WCNTFAX(GLONTEL)(1..MAXCNT)
Local Char    WCNTWEB(GLONMAI)(1..MAXCNT)
Local Integer WCNTFLG(1..MAXCNT)
Local Integer I , J , K
Gosub GETSOC
If SOCIETE="" : End : Endif
Local File CONTACT [AACA]
For [AACA] Where BPATYP=GADDCPY and BPANUM=SOCIETE
 If !find([F:AACA]CCNCRM,[M]CCNCRM(0..[M]NBCNT-1))
  NBRCNT += 1
  WCNTCOD(NBRCNT) = [F:AACA]CCNCRM
  WCNTFNC(NBRCNT) = [F:AACA]CNTFNC
  WCNTSRV(NBRCNT) = [F:AACA]CNTSRV
  WCNTMSS(NBRCNT) = [F:AACA]CNTMSS
  WCNTTEL(NBRCNT) = [F:AACA]TEL
  WCNTMOB(NBRCNT) = [F:AACA]MOB # FGR 23/07/2008 : X3SUIVI48432 ajout téléphone portable
  WCNTFAX(NBRCNT) = [F:AACA]FAX
  WCNTWEB(NBRCNT) = [F:AACA]WEB
  K = find([F:AACA]BPAADD,[M]CODADR(0..[M]NBADR-1))
  If K
   WCNTADD(NBRCNT) = [F:AACA]BPAADD
   WCNTCRY(NBRCNT) = [M]BPACRY(K-1)
  Else
   WCNTCRY(NBRCNT) = GPAYS
  Endif
  #==>JPGA<== 22/04/2008 : Contact par défaut [F:CNT]CNTFLG supprimé de la table CONTACT
  #==>Le nom du contact par défaut CNTNAM a été remonté dans chaque table fonctionnelle (CPY/FCY/BPC/BPR/BPS/BPP/BPT)
  #If [F:AACA]CNTFLG=2 & !find(2,[M]CNTFLG(0..[M]NBCNT-1))
  If !find(2,WCNTFLG(1..NBRCNT)) & !find(2,[M]CNTFLG(0..[M]NBCNT-1))
   WCNTFLG(NBRCNT) = 2
  Else
   WCNTFLG(NBRCNT) = 1
  Endif
 Endif
Next
If NBRCNT=0 : End : Endif
If dim([M]CCNCRM)<[M]NBCNT+NBRCNT
 GMESSAGE = mess(45,133,1) : # Insertion impossible
 mkstat = 2 : End
Endif
Insa NOL,NBRCNT [M]NBCNT
J = 0
For I=NOL To NOL-1+NBRCNT
 J += 1
 [M]CCNCRM(I) = WCNTCOD(J)
 [M]CNTFNC(I) = WCNTFNC(J)
 [M]CNTSRV(I) = WCNTSRV(J)
 [M]CNTMSS(I) = WCNTMSS(J)
 [M]CNTTEL(I) = WCNTTEL(J)
 [M]CNTMOB(I) = WCNTMOB(J)  # FGR 23/07/2008 : X3SUIVI48432 ajout téléphone portable
 [M]CNTFAX(I) = WCNTFAX(J)
 [M]CNTWEB(I) = WCNTWEB(J)
 [M]CNTCRY(I) = WCNTCRY(J)
 [M]CNTADD(I) = WCNTADD(J)
 [M]CNTFLG(I) = WCNTFLG(J)
 Read [AIN]AIN0 = WCNTCOD(J)
 If !fstat
  [M]CNTLNA(I)    = [F:AIN]CNTLNA
  [M]CNTFNA(I)    = [F:AIN]CNTFNA
  [M]CNTTTL(I)    = [F:AIN]CNTTTL
  [M]CNTBIR(I)    = [F:AIN]CNTBIR
  [M]CNTMOB(I)    = [F:AIN]CNTMOB
  [M]CNTFULNAM(I) = [F:AIN]CNTFULNAM
 Endif
 [M]FLMOD(I)     = 1
Next I
[M]NBCNT += NBRCNT
Affzo NBCNT,CCNCRM,CNTLNA
Gosub CHARGE_CNT
Close File [AACA]
Actzo 25-40
End

Subprog AS_CCNCRM(VALEUR)
Variable Char    VALEUR()
# FGR 22/06/2015 : X3SUIVI107416 (début)
#If [M]FLNEW(nolign-1)
# mkstat = 2
#Endif
# FGR 22/06/2015 : X3SUIVI107416 (fin)
End

Subprog C_CCNCRM(VALEUR)
Variable Char     VALEUR
Gosub SETNOL

VALEUR = vireblc(VALEUR, 2)
If VALEUR<>""
 Call UNICITE(VALEUR,[M]CCNCRM(0..[M]NBCNT-1)) From OBJDIV
 If mkstat : End : Endif
 If VALEUR<>[M]CCNCRM(nolign-1) or GIMPORT
  Local Integer ER
  Onerrgo ERR
  Local Char BID(30)
  BID = num$(val(VALEUR))
  Onerrgo
  If ER : BID = "" : Endif
  If BID=VALEUR
   VALEUR = func SUBAIN.COD(val(VALEUR))
  Endif
  Read [AIN]AIN0 = VALEUR
  If !fstat
   [M]CNTTTL(NOL)    = [F:AIN]CNTTTL
   [M]CNTLNA(NOL)    = [F:AIN]CNTLNA
   [M]CNTFNA(NOL)    = [F:AIN]CNTFNA
   [M]CNTBIR(NOL)    = [F:AIN]CNTBIR
   #[M]CNTMOB(NOL)    = [F:AIN]CNTMOB    # FGR 12/01/2016 : X3SUIVI113690(US77755) possible to have different personnal and professional mobiles.
   [M]CNTFULNAM(NOL) = [F:AIN]CNTFULNAM
   #MAE, bg68259
   #[M]CNTTEL(NOL) = [F:AIN]CNTETS
   #[M]CNTFAX(NOL) = [F:AIN]CNTFAX
   #[M]CNTWEB(NOL) = [F:AIN]CNTEMA
   #[M]CNTCRY(NOL) = [F:AIN]CRY     # hcb 88615 # FGR 27/08/2013 : Cette correction est fausse, il ne faut pas faire ça.
  Endif
 Endif
Else
 [M]CNTFULNAM(NOL) = ""
 If !GIMPORT mkstat = 4 Endif
Endif
End

$ERR
ER = errn
Resume

Subprog AM_CCNCRM(VALEUR)
Variable Char    VALEUR()
Local Char ACTION(20)
Gosub APRES_MODIF : If mkstat : End : Endif
Gosub SETNOL
ACTION = "INIT_CNT"
Gosub ACTION_BPA

 # -------------------------------------
 # FGR 27/08/2013 : X3SUIVI88615 (début)
  If dim([M]CRY) > 0 Then
    [M]CNTCRY(nolign-1) = [M]CRY
  Else
    [M]CNTCRY(nolign-1) = GPAYS
  Endif
 # FGR 27/08/2013 : X3SUIVI88615 (fin)
 # -------------------------------------

Gosub CHARGE_CNT
If [M]KCNTLNA=""
 [M]KCNTLNA             = VALEUR
 [M]CNTLNA(nolign-1) = VALEUR
 Affzo CNTLNA(nolign-1)
Endif
# FGR 13/04/2012 : X3SUIVI81552 (début)
  # Lors de la création d'une nouvelle ligne
  If [M]NBCNT = 0 and NOL = 0 Then
    # Si c'est le premier contact : il est automatiquement contact par défaut
    [M]CNTFLG(NOL) = 2
    [M]KCNTFLG = 2
    Affzo KCNTFLG
  Endif
# FGR 13/04/2012 : X3SUIVI81552 (fin)
Actzo 25-40
zonsui = "KCNTTTL"
[M]FLMOD(NOL) = 1
[M]KCCNCRM = VALEUR
End

