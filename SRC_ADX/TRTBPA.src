$APRES_MODIF
Local Char ACTION(20) , COUZON(GLONAVA)
COUZON = zoncou
ACTION = "APRES_MODIF"
Gosub ACTION_BPA
Return

#######################################################
## Sélection e-mail
#######################################################
Subprog SELMAIL(VALEUR)
Variable Char    VALEUR()
Local Char    PARAM(200)(1..10)
Local Integer I
If GBROWS : End : Endif
Raz PARAM
If VALEUR<>""
 PARAM(1) = "_EmailToList="+chr$(1)+VALEUR
Endif
Seldest PARAM = "" With PARAM
For I=1 To stat1
 If left$(toupper(PARAM(I)),13)="_EMAILTOLIST="
  VALEUR = right$(PARAM(I),15) : Break
 Endif
Next I
End

########################################################################
## Sélection adresse
########################################################################
$ACTION
Case ACTION
 When "SEL_LISTE"    : Gosub SEL_LISTE
 When "FIN_LISTE"    : Gosub FIN_LISTE
 When "SEL_TABLE"    : Gosub SEL_TABLE
 When "FIN_TABLE"    : Gosub FIN_TABLE
 When "BOUT_TABLE"
  Case GSTATUT
   When GSTASVG      : Gosub SVG_TABLE
   When GSTAPRG      : Gosub PRG_TABLE
  Endcase
 When "BB1_XPOSCOD"  : Gosub BB1_XPOSCOD
Endcase
Return

$SEL_LISTE
Case LISTE
 When "SELLBPA"    : Gosub SELLBPA
 When "SELEMAIL"   : Gosub SELEMAIL
Endcase
Return

$FIN_LISTE
Case LISTE
 When "SELEMAIL"   : Gosub FINEMAIL
Endcase
Return

$SEL_TABLE
Case TABLE
 When "SELMBPA"    : Gosub SEL_BPA
 When "SELEMAIL"   : Gosub SEL_MAIL
Endcase
Return

$SVG_TABLE
Case TABLE
 When "SELMBPA"    : Gosub SVG_BPA
Endcase
Return

$PRG_TABLE
Case TABLE
 When "SELMBPA"    : Gosub PRG_BPA
Endcase
Return

$FIN_TABLE
Case TABLE
 When "SELEMAIL"   : Gosub FIN_MAIL
Endcase
Return

########################################################################
$SELLBPA
Local Char    WTXT(60)
Local Integer I
If dim([M]NBADR)>0
 For I=0 To [M]NBADR-1
  WTXT = format$("K:"+num$(GLONADR)+"X",[M]CODADR (I))+" "+format$("K:30X",[M]BPADES(I))+" "+[M]POSCOD (I)
  NBTEX += 1
  TEX(NBTEX)   = [M]CODADR(I)
  TEXTE(NBTEX) = WTXT
 Next I
Endif
Return

########################################################################
$SEL_BPA
Local Char    ZON(30) , ABR(GLONABR)
Local Integer DEB , SUITE
Local Char    WCOD(GLONADR)(1..GNBSEL) , WDES(GLONDES)(1..GNBSEL) , WPOS(GLONPOS)(1..GNBSEL)
Local File   (Char BPAADD(GLONADR) , Char BPADES(GLONDES) , Char POSCOD(GLONPOS))
&             From Variable WCOD , WDES , WPOS As [ADR_] Order By BPAADD
If PARAM(1)<>""
 [L]ABR = PARAM(1)
Endif
If [L]ABR<>""
 If evalue("dim([M:"+ABR+"]NBADR)")<=0
  OK = 0 : Return
 Endif
Elsif dim([M]NBADR)<=0
 OK = 0 : Return
Endif
NBCOL = 0
For ZON="BPAADD","BPADES","POSCOD"
 NBCOL += 1
 COL(NBCOL) = "[F:ADR_]"+ZON
 COLTYP(NBCOL) = evalue("type([F:ADR_]"+ZON+")")
 Call TITZON("BPADDRESS",ZON,TIT(NBCOL)) From CONTOBJ
Next ZON
DEB = 0
Gosub LEC_BPA
Default File [ADR_]
TIT = mess(44,133,1) : # Sélection code adresse
Return

$LEC_BPA
Raz J , SUITE
For I=DEB To [M]NBADR-1
 If J>=dim(WCOD)
  SUITE = 1 : Break
 Endif
 J += 1
 If [L]ABR<>""
  WCOD(J) = evalue("[M:"+[L]ABR+"]CODADR("+num$(I)+")")
  WDES(J) = evalue("[M:"+[L]ABR+"]BPADES("+num$(I)+")")
  WPOS(J) = evalue("[M:"+[L]ABR+"]POSCOD("+num$(I)+")")
 Else
  WCOD(J) = [M]CODADR(I)
  WDES(J) = [M]BPADES(I)
  WPOS(J) = [M]POSCOD(I)
 Endif
Next I
For I=J+1 To dim(WCOD)
 WCOD(I) = chr$(255)
Next I
adxmxl = J
Return

$SVG_BPA
If SUITE
 DEB += dim(WCOD)
 Gosub LEC_BPA
Endif
FOK = 0
Return

$PRG_BPA
DEB = max(0,DEB-adxmxl-1)
Gosub LEC_BPA
FOK = 0
Return

########################################################################
$SEL_MAIL
Local Char SAVUSR(GLONAUS)
If clalev([F:AUS])=0
 Local File AUTILIS [AUS]
Else
 SAVUSR = [F:AUS]USR
Endif
Local File AUTILIS [AU_] Order By Key CLE=ADDEML
NBCOL = 0
For ZON="ADDEML","USR","NOMUSR"
 NBCOL += 1
 COL(NBCOL) = "[F:AU_]"+ZON
 COLTYP(NBCOL) = evalue("type([F:AU_]"+ZON+")")
 Call TITZON("AUTILIS",ZON,TIT(NBCOL)) From CONTOBJ
Next ZON
START = "ADDEML"
CRITERE = '[F:AU_]ADDEML<>""'
Default File [AU_]
TIT = mess(150,139,1) : # Sélection adresses eMail
Return

$FIN_MAIL
If SAVUSR<>"" & SAVUSR<>[F:AUS]USR
 Read [AUS]CODUSR = SAVUSR
Endif
Return

########################################################################
$SELEMAIL
Local Char SAVUSR(GLONAUS)
If clalev([F:AUS])=0
 Local File AUTILIS [AUS]
Else
 SAVUSR = [F:AUS]USR
Endif
NBTEX = 0
For [AUS] Where ADDEML<>""
 If NBTEX>=dim(TEX)-1 : Break : Endif
 NBTEX += 1
 TEX(NBTEX)   = '"'+[F:AUS]ADDEML+'"'
 TEXTE(NBTEX) = [F:AUS]USR-[F:AUS]NOMUSR
Next
Return

$FINEMAIL
If SAVUSR<>"" & SAVUSR<>[F:AUS]USR
 Read [AUS]CODUSR = SAVUSR
Endif
Return

##########################################################################################
## Appelé en validation dossier (copie automatique)
## Pour copier les adresses, contact et rib d'une entité (tiers, utilisateur, etc.)
##########################################################################################

Subprog COPIE(TABLE,ZONTYP,TYP)
Value Char    TABLE     : # Code de la table (BPADDRESS, CONTACT, BID)
Value Char    ZONTYP    : # Nom du champ type entité
Value Integer TYP       : # Value de l'entité

Local Integer  NBRAZ , NBREC , MAXREC
Local Char     ZONRAZ(10)(1..50)
Local Integer  I , J , K , T , D , OK

MAXREC = 1000

If TABLE="" | ZONTYP=""
 End
Elsif filinfo(filpath("FIL",TABLE,"fde",[F:ADS]DOSSIER),0)<=0
 End
Endif

OK = 1
If filinfo(filpath("FIL",TABLE,"fde",[F:ADS]DOSCOP),0)>=0
 Local File =[F:ADS]DOSCOP+"."+TABLE  [F1]
Elsif filinfo(filpath("FIL",TABLE,"fde",[F:ADS]DOSREF),0)>=0
 Local File =[F:ADS]DOSREF+"."+TABLE  [F1]
Elsif filinfo(filpath("FIL",TABLE,"fde",GDOSX3),0)>=0
 Local File =GDOSX3+"."+TABLE [F1]
Else
 OK = 0
Endif
If OK & evalue("dim([F:F1]"+ZONTYP+")")<=0
 OK = 0
Endif
If OK
 Local File =[F:ADS]DOSSIER+"."+TABLE [F2]
 NBRAZ = 0
 For [ATZ]CODZONE Where CODFIC=TABLE & ZERO=2
  NBRAZ += 1
  ZONRAZ(NBRAZ) = [F:ATZ]CODZONE
 Next ATZ
 If GINFO
  # Copie des données - Table
  Call AFF_VLC(mess(30,125,1),mess(56,123,1)-TABLE) From GESECRAN
 Endif
 # Table
 Call ECR_TRACE(mess(56,123,1)-TABLE,0) From GESECRAN
 NBREC = 0
 Trbegin [F2]
  For [F1]
   OK = 1
   If dim([F:F1]CODACT)>0 & [F:F1]CODACT<>""
    Read [ACV]CODACT = [F:F1]CODACT
    If fstat or [F:ACV]FLACT<>2 : OK = 0 : Endif
   Endif
   If dim([F:F1]MODULE)>0 & [F:F1]MODULE>0
    If [F:ADS]MODULE([F:F1]MODULE-1)<>2 : OK = 0 : Endif
   Endif
   If evalue("[F:F1]"+ZONTYP)<>TYP : OK = 0 : Endif
   If OK
    If NBREC>=MAXREC
     Commit
     Trbegin [F2]
     NBREC = 0
    Endif
    NBREC += 1
    [F:F2] = [F:F1]
    For I=1 To NBRAZ
     D = evalue("dim([F:F2]"+ZONRAZ(I)+")")
     T = evalue("type([F:F2]"+ZONRAZ(I)+")")
     For J=1 To D
      Case T
       When 1,2,4,5,6,7,8,9
        Assign "[F:F2]"+ZONRAZ(I)+"("+num$(J-1)+")" With 0
       When 3
        Assign "[F:F2]"+ZONRAZ(I)+"("+num$(J-1)+")" With [0/0/0]
       When Default
        Assign "[F:F2]"+ZONRAZ(I)+"("+num$(J-1)+")" With ""
      Endcase
     Next J
    Next I
    Write [F2]
    If fstat
     Call ERREUR(TABLE,1) From DOSDIC
    Endif
   Endif
  Next F1
 Commit
 Close Local File [F1] , [F2]
Endif
End

