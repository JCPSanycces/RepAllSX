###################################################################################
## Gestion des RIB
###################################################################################
Subprog CHARG_RIB(TYP,ENTITE,DEFBID)
Value Integer TYP
Value Char    ENTITE
Value Char    DEFBID
Local Char    ACTION(20) , WADD(GLONADR)
Local Integer WIND , WFLG

ACTION = "CHARGE_RIB" : Gosub ACTION_BPA

Raz [M]
[M]IDENT  = num$(TYP)+ENTITE
[M]NUMBPA = TYP
nolign = 0
For [BID]BID0 Where BPATYP=TYP & BPANUM=ENTITE
 If nolign>=dim([M]BIDCRY)
  Call ERREUR(mess(26,100,1)) From GESECRAN : Break
 Endif
 nolign += 1
 [M] = [F:BID]
 [M]BIDCRY(nolign-1)    = [F:BID]CRY
 [M]BIDCUR(nolign-1)    = [F:BID]CUR
 [M]BIDBPAADD(nolign-1) = [F:BID]BPAADD
 # MABON - FQ65459 - 29/06/10 - Le champ ACCNONREI a changé de table
 If dim([M]ACCNONREI)>0 Then
  [M]ACCNONREI(nolign-1) = [F:BID]ACCNONREI
 Endif
 If DEFBID="~"
  Read [BPA]BPA0=[F:BID]BPATYP;[F:BID]BPANUM;[F:BID]BPAADD
  If !fstat & [F:BPA]BPABID=[F:BID]BIDNUM
   [M]BIDNUMFLG(nolign -1) = 2
  Else
   [M]BIDNUMFLG(nolign -1) = 1
  Endif
 Elsif [F:BID]BIDNUM = DEFBID
  [M]BIDNUMFLG(nolign -1) = 2
 Else
  [M]BIDNUMFLG(nolign -1) = 1
 Endif
 #LSE 05/02/2007 FQ39391 et 18/12/20007 FQ44884
 If [M]BIDNUMFLG(nolign -1)<>[F:BID]BIDNUMFLG
  [M]FLMOD(nolign-1)=1
  # Issue 83182
  [F:BID]BIDNUMFLG = [M]BIDNUMFLG(nolign - 1)
  Rewrite [BID]
  # End issue 83182
 Endif
 If dim([M]IBAN)>0
  Call IBAN([F:BID]CRY,[F:BID]BIDNUM,[M]IBAN(nolign-1))
 Endif
Next
[M]NBRIB  = nolign
# FGR 05/08/2013 : X3SUIVI91562 (début) : ne pas faire ça masque les problèmes
#If [M]NBRIB>0
# If DEFBID="~"
#  WADD = ""
#  WFLG = 0
#  WIND = 0
#  Sorta [M]NBRIB [M]NBRIB Order By [M]BIDBPAADD(indice), [M]BIDNUM(indice)
#  For nolign=1 To [M]NBRIB
#   If WADD<>[M]BIDBPAADD(nolign-1)
#    If WFLG<2 & nolign>1
#     [M]BIDNUMFLG(WIND) = 2
#    Endif
#    WADD = [M]BIDBPAADD(nolign-1)
#    WFLG = [M]BIDNUMFLG(nolign-1)
#    WIND = nolign-1
#   Else
#    WFLG = max(WFLG,[M]BIDNUMFLG(nolign-1))
#   Endif
#  Next nolign
#  If WFLG<2
#   [M]BIDNUMFLG(WIND) = 2
#  Endif
# Elsif !find(2,[M]BIDNUMFLG(0..[M]NBRIB-1))
#  [M]BIDNUMFLG(0) = 2
# Endif
#Endif
# FGR 05/08/2013 : X3SUIVI91562 (fin)
End

#####################################################################################
Subprog CRERIB(TYP,ENTITE)
Value Integer TYP
Value Char    ENTITE
Local Char DEFBID(GLONBID)
Local Integer STA , OLDRIB , OK , WIND , WFLG
Local Char    ACTION(20) , WADD(GLONADR)

ACTION = "CRERIB" : Gosub ACTION_BPA

OLDRIB = 0
For [BID]BID0 Where BPATYP=TYP & BPANUM=ENTITE
 OLDRIB += 1
 OK = 0
 For nolign=1 To [M]NBRIB
  If [F:BID]BIDNUM+[F:BID]BPAADD=[M]BIDNUM(nolign-1)+[M]BIDBPAADD(nolign-1)
   OK = 1 : Break
  Endif
 Next nolign
 If !OK
  Delete [BID]
  If fstat=1
   GOK = -1 : GLOCK = "$BID"-num$(TYP)-ENTITE-[F:BID]BIDNUM : Break
  Endif
 Endif
Next
If GOK<1 : End : Endif
# FGR 03/04/2012 : X3SUIVI81100 (début)
If OLDRIB > 0 Then
  Update [BPA] Where [F:BPA]BPATYP = TYP and [F:BPA]BPANUM = ENTITE With [F:BPA]BPABID = ""
  If fstat Then
    GOK = 0 : Call RSTA("BPA", num$(TYP) + ENTITE) From GLOCK : End
  Endif
Endif
# FGR 03/04/2012 : X3SUIVI81100 (fin)
If [M]NBRIB>0
 If DEFBID="~"
  WADD = ""
  WFLG = 0
  WIND = 0
  Sorta [M]NBRIB [M]NBRIB Order By [M]BIDBPAADD(indice), [M]BIDNUM(indice)
  For nolign=1 To [M]NBRIB
   If WADD<>[M]BIDBPAADD(nolign-1)
    If WFLG<2 & nolign>1
     [M]BIDNUMFLG(WIND) = 2
    Endif
    WADD = [M]BIDBPAADD(nolign-1)
    WFLG = [M]BIDNUMFLG(nolign-1)
    WIND = nolign-1
   Else
    WFLG = max(WFLG,[M]BIDNUMFLG(nolign-1))
   Endif
  Next nolign
  If WFLG<2
   [M]BIDNUMFLG(WIND) = 2
   [M]FLMOD(WIND) = 1
   Affzo BIDNUMFLG(WIND)
  Endif
 Elsif !find(2,[M]BIDNUMFLG(0..[M]NBRIB-1))
  [M]BIDNUMFLG(0) = 2
  #LSE 05/02/2007 FQ39391 et 18/12/20007 FQ44884
  [M]FLMOD(0) = 1
  Affzo BIDNUMFLG(0)
 Endif
Endif
For nolign=1 To [M]NBRIB
 If !OLDRIB or [M]FLMOD(nolign-1)
  Readlock [BID]BID0 = TYP;ENTITE;[M]BIDNUM(nolign-1);[M]BIDBPAADD(nolign-1)
  STA = fstat
  If STA=1
   GOK = -1 : GLOCK = "$BID"-num$(TYP)-ENTITE-[M]BIDNUM(nolign-1) : Break
  Endif
  [F:BID] = [M]
  [F:BID]BPATYP = TYP
  [F:BID]BPANUM = ENTITE
  [F:BID]BPAADD = [M]BIDBPAADD(nolign-1)
  [F:BID]CRY    = [M]BIDCRY(nolign-1)
  [F:BID]CUR    = [M]BIDCUR(nolign-1)
  ACTION = "ECRIT_BID"
  Gosub ACTION_BPA
  If STA
   If dim([F:BID]CREDAT)>0 : [F:BID]CREDAT = date$ : Endif
   If dim([F:BID]CREUSR)>0 : [F:BID]CREUSR = GUSER : Endif
   If dim([F:BID]CRETIM)>0 : [F:BID]CRETIM = time  : Endif
   #MAE, bg 76497
   If dim([F:BID]UPDDAT)>0 : [F:BID]UPDDAT = [0/0/0] : Endif
   If dim([F:BID]UPDUSR)>0 : [F:BID]UPDUSR = "" : Endif
   If dim([F:BID]UPDTIM)>0 : [F:BID]UPDTIM = 0  : Endif
   #Fin MAE
   Write [BID]
  Else
   If dim([F:BID]UPDDAT)>0 : [F:BID]UPDDAT = date$ : Endif
   If dim([F:BID]UPDUSR)>0 : [F:BID]UPDUSR = GUSER : Endif
   If dim([F:BID]UPDTIM)>0 : [F:BID]UPDTIM = time  : Endif
   Rewrite [BID]
  Endif
  If fstat
   GOK = 0 : Call FSTA("BID") From GLOCK : Break
  Endif
 Endif
Next nolign
If GOK=1
 Raz [M]FLMOD
Endif
For nolign=1 To [M]NBRIB
 If [M]BIDNUMFLG(nolign-1)=2
  Readlock [BPA]BPA0=TYP;ENTITE;[M]BIDBPAADD(nolign-1)
  If !fstat
   [F:BPA]BPABID = [M]BIDNUM(nolign-1)
   Rewrite [BPA]
   If fstat
    GOK = 0 : Call FSTA("BPA") From GLOCK : Break
   Endif
  Endif
 Endif
Next nolign
End

Subprog ANNRIB(TYP,ENTITE)
Value Integer TYP
Value Char    ENTITE
GCLE = num$(TYP)+ENTITE
Delete [BID] Where BPATYP=TYP & BPANUM=ENTITE
If fstat = 1
 GOK = -1
 GLOCK = "$BID"-GCLE : End
Endif
# FGR 03/04/2012 : X3SUIVI81100 (début)
  If clalev([F:BPA])=0 : Local File BPADDRESS [BPA] : Endif
  Update [BPA] Where [F:BPA]BPATYP = TYP and [F:BPA]BPANUM = ENTITE With [F:BPA]BPABID = ""
  If fstat Then
    GOK = 0 : Call RSTA("BPA",GCLE) From GLOCK : End
  Endif
# FGR 03/04/2012 : X3SUIVI81100 (fin)
End

Subprog CHGRIB(TYP,OLDENT,NEWENT)
Value Integer TYP
Value Char    OLDENT
Value Char    NEWENT
For [BID] Where BPATYP=TYP & BPANUM=OLDENT
 [F:BID]BPANUM = NEWENT
 Rewrite [BID]
 If fstat
  GOK = 0 : Call FSTA("BID") From GLOCK : Break
 Endif
Next
End

#####################################################################################
## Ecran BID
#####################################################################################
Subprog AVANT_NBRIB
If nolign=0 : End : Endif
Local Integer I
Local Char    ACTION(20)

If status = 82 or status = 73 Then  # FGR 10/04/2012 : X3SUIVI81364
  # Initialisation du code adresse avec le code adresse par défaut
  If [M]BIDBPAADD(nolign-1)="" & dim([M]NBADR)>0
   For I=0 To [M]NBADR-1
    If [M]BPAADDFLG(I)=2
     [M]BIDBPAADD(nolign-1) = [M]CODADR(I) : Affzo [M]BIDBPAADD(nolign-1)
     [M]BIDCRY(nolign-1)    = [M]BPACRY(I) : Affzo [M]BIDCRY(nolign-1)
     Break
    Endif
   Next I
  Endif
  # Initialisation du flag rib par défaut
  If find(GREP,"C","","D")
   If nolign=1 & [M]BIDNUMFLG(nolign-1)=0
    [M]BIDNUMFLG(nolign-1) = 2
   Elsif [M]BIDNUMFLG(nolign-1)=0
    [M]BIDNUMFLG(nolign-1) = 1
   Endif
   Affzo [M]BIDNUMFLG(nolign-1)
  Endif
  # Initialisation du code devise
  If [M]BIDCUR(nolign-1)=""
   If dim ([M]CUR)>0
    [M]BIDCUR(nolign-1) = [M]CUR
   Elsif dim([M]ACCCUR)>0
    [M]BIDCUR(nolign-1) = [M]ACCCUR
   Else
    [M]BIDCUR(nolign-1) = GSYSCUR
   Endif
   Affzo [M]BIDCUR(nolign-1)
  Endif
  ACTION = "INIT_BID"
  Gosub ACTION_BPA
Endif
End

Subprog APRES_NBRIB
If status<>6
 [M]FLMOD(nolign-1) = 1
Endif
End

Subprog IB_NBRIB
If GPRODUIT=4 : End : Endif
If [M]NUMBPA<>GADDFCY
 GBOUT1 = ""
Else
 Gosub GETSOC
 If SOCIETE=""
  GBOUT1 = ""
 Endif
Endif
# 2012-03-29 : X3SUIVI75143 DNE : Remove entry "Enter local BID" from context menu
#                                 when there is no local BID window enabled/existant.
If ([M]BIDCRY(nolign - 1) <> "")
& and (func BIDLOC.CANUSELOCALSCREEN())
& and (func BIDLOC.GETLOCALWINDOW([M]BIDCRY(nolign - 1)) <> "")
Else
 # Deactivate "Button 2".
 GBOUT2 = ""
Endif
End

Subprog B1_NBRIB
# Copie des ribs sociétés => site
Gosub SETNOL
Local Integer NBRRIB , MAXRIB
MAXRIB = dim([M]BIDNUM)
Local Char    WBIDNUM(GLONBID)(1..MAXRIB)
Local Char    WBPAADD(GLONADR)(1..MAXRIB)
Local Integer WBIDNUMFLG(1..MAXRIB)
Local Char    WBNF(GLONPAB)(1..MAXRIB)
Local Char    WPAB1(GLONPAB)(1..MAXRIB)
Local Char    WPAB2(GLONPAB)(1..MAXRIB)
Local Char    WPAB3(GLONPAB)(1..MAXRIB)
Local Char    WPAB4(GLONPAB)(1..MAXRIB)
Local Char    WIBAN(4)(1..MAXRIB)
Local Char    WBICCOD(11)(1..MAXRIB)
Local Char    WCRY(GLONCRY)(1..MAXRIB)
Local Char    WCUR(GLONCUR)(1..MAXRIB)
Local Char    WMIDPAB1(GLONPAB)(1..MAXRIB)
Local Char    WMIDPAB2(GLONPAB)(1..MAXRIB)
Local Char    WMIDPAB3(GLONPAB)(1..MAXRIB)
Local Char    WMIDPAB4(GLONPAB)(1..MAXRIB)
Local Char    WMIDBICCOD(11)(1..MAXRIB)
Local Char    WMIDCRY(GLONCRY)(1..MAXRIB)
Local Date    WVLYSTR(1..MAXRIB)
Local Date    WVLYEND(1..MAXRIB)
Local Integer WBIDSAC(1..MAXRIB)
Local Char    WREG(GLONADI)(1..MAXRIB)
Local Integer I , J
Gosub GETSOC
If SOCIETE="" : End : Endif
Local File BID [XBID]
For [XBID] Where BPATYP=GADDCPY and BPANUM=SOCIETE
 If !find([F:XBID]BIDNUM,[M]BIDNUM(0..[M]NBRIB-1))
  NBRRIB += 1
  WBIDNUM(NBRRIB)    = [F:XBID]BIDNUM
  WBPAADD(NBRRIB)    = [F:XBID]BPAADD
  WBNF(NBRRIB)       = [F:XBID]BNF
  WCRY(NBRRIB)       = [F:XBID]CRY
  WCUR(NBRRIB)       = [F:XBID]CUR
  If [F:XBID]BIDNUMFLG=2 & !find(2,[M]BIDNUMFLG(0..[M]NBRIB-1))
   WBIDNUMFLG(NBRRIB) = 2
  Else
   WBIDNUMFLG(NBRRIB) = 1
  Endif
  If dim([F:XBID]PAB1)>0      : WPAB1(NBRRIB)      = [F:XBID]PAB1      : Endif
  If dim([F:XBID]PAB2)>0      : WPAB2(NBRRIB)      = [F:XBID]PAB2      : Endif
  If dim([F:XBID]PAB3)>0      : WPAB3(NBRRIB)      = [F:XBID]PAB3      : Endif
  If dim([F:XBID]PAB4)>0      : WPAB4(NBRRIB)      = [F:XBID]PAB4      : Endif
  If dim([F:XBID]IBAN)>0      : WIBAN(NBRRIB)      = [F:XBID]IBAN      : Endif
  If dim([F:XBID]BICCOD)>0    : WBICCOD(NBRRIB)    = [F:XBID]BICCOD    : Endif
  If dim([F:XBID]MIDPAB1)>0   : WMIDPAB1(NBRRIB)   = [F:XBID]MIDPAB1   : Endif
  If dim([F:XBID]MIDPAB2)>0   : WMIDPAB2(NBRRIB)   = [F:XBID]MIDPAB2   : Endif
  If dim([F:XBID]MIDPAB3)>0   : WMIDPAB3(NBRRIB)   = [F:XBID]MIDPAB3   : Endif
  If dim([F:XBID]MIDPAB4)>0   : WMIDPAB4(NBRRIB)   = [F:XBID]MIDPAB4   : Endif
  If dim([F:XBID]MIDBICCOD)>0 : WMIDBICCOD(NBRRIB) = [F:XBID]MIDBICCOD : Endif
  If dim([F:XBID]MIDCRY)>0    : WMIDCRY(NBRRIB)    = [F:XBID]MIDCRY    : Endif
  If dim([F:XBID]VLYSTR)>0    : WVLYSTR(NBRRIB)    = [F:XBID]VLYSTR    : Endif
  If dim([F:XBID]VLYEND)>0    : WVLYEND(NBRRIB)    = [F:XBID]VLYEND    : Endif
  If dim([F:XBID]BIDSAC)>0    : WBIDSAC(NBRRIB)    = [F:XBID]BIDSAC    : Endif
  If dim([F:XBID]REG)>0       : WREG(NBRRIB)       = [F:XBID]REG       : Endif
 Endif
Next
If NBRRIB=0 : End : Endif
If dim([M]BIDNUM)<[M]NBRIB+NBRRIB
 GMESSAGE = mess(45,133,1) : # Insertion impossible
 mkstat = 2 : End
Endif
Insa NOL,NBRRIB [M]NBRIB
J = 0
For I=NOL To NOL-1+NBRRIB
 J += 1
 [M]BIDNUM(I)    = WBIDNUM(J)
 If find(WBPAADD(J),[M]CODADR(0..[M]NBADR-1))
  [M]BIDBPAADD(I) = WBPAADD(J)
 Else
  [M]BIDBPAADD(I) = ""
 Endif
 [M]BIDNUMFLG(I) = WBIDNUMFLG(J)
 [M]BNF(I)       = WBNF(J)
 [M]BIDCRY(I)    = WCRY(J)
 [M]BIDCUR(I)    = WCUR(J)
 If dim([M]PAB1)>0      : [M]PAB1(I)      = WPAB1(J)      : Endif
 If dim([M]PAB2)>0      : [M]PAB2(I)      = WPAB2(J)      : Endif
 If dim([M]PAB3)>0      : [M]PAB3(I)      = WPAB3(J)      : Endif
 If dim([M]PAB4)>0      : [M]PAB4(I)      = WPAB4(J)      : Endif
 If dim([M]IBAN)>0      : [M]IBAN(I)      = WIBAN(J)      : Endif
 If dim([M]BICCOD)>0    : [M]BICCOD(I)    = WBICCOD(J)    : Endif
 If dim([M]MIDPAB1)>0   : [M]MIDPAB1(I)   = WMIDPAB1(J)   : Endif
 If dim([M]MIDPAB2)>0   : [M]MIDPAB2(I)   = WMIDPAB2(J)   : Endif
 If dim([M]MIDPAB3)>0   : [M]MIDPAB3(I)   = WMIDPAB3(J)   : Endif
 If dim([M]MIDPAB4)>0   : [M]MIDPAB4(I)   = WMIDPAB4(J)   : Endif
 If dim([M]MIDBICCOD)>0 : [M]MIDBICCOD(I) = WMIDBICCOD(J) : Endif
 If dim([M]MIDCRY)>0    : [M]MIDCRY(I)    = WMIDCRY(J)    : Endif
 If dim([M]VLYSTR)>0    : [M]VLYSTR(I)    = WVLYSTR(J)    : Endif
 If dim([M]VLYEND)>0    : [M]VLYEND(I)    = WVLYEND(J)    : Endif
 If dim([M]BIDSAC)>0    : [M]BIDSAC(I)    = WBIDSAC(J)    : Endif
 If dim([M]REG)>0       : [M]REG(I)       = WREG(J)       : Endif
Next I
[M]NBRIB += NBRRIB
Affzo
Close File [XBID]
End

Subprog C_BIDNUM(VALEUR)
Variable Char     VALEUR
Local Char ACTION(20)
Local Integer OK
OK = 1
ACTION = "C_BIDNUM" : Gosub ACTION_BPA
If !OK : End : Endif
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
Call LECTURE("TCY",[M]BIDCRY(nolign-1),"") From CONTOBJ
If [F:TCY]BIDCTL=2
 Local Char BANQUE(GLONBID)
 If clalev([F:ABN])=0 : Local File ABANK [ABN] : Endif
 BANQUE = left$(VALEUR,[F:TCY]BANLNG)
 Read [ABN]ABN0 = [M]BIDCRY(nolign-1);BANQUE
 If fstat
  GMESSAGE = mess(173,133,1) : # Banque inexistante
  mkstat = 2 : End
 Endif
 [M]PAB1(nolign-1) = [F:ABN]PAB
 Affzo PAB1(nolign-1)
 [M]BICCOD(nolign-1) = [F:ABN]BIC
 Affzo BICCOD(nolign-1)
 If dim([M]REG)>0 & [M]REG(nolign-1)=""
  [M]REG(nolign-1) = [F:ABN]REG
  Affzo REG(nolign-1)
 Endif
Endif
If dim([M]IBAN)>0
 Call IBAN([M]BIDCRY(nolign-1),VALEUR,[M]IBAN(nolign-1))
 Affzo IBAN(nolign-1)
Endif
End

Subprog IBAN(PAYS,RIB,IBAN)
Value    Char PAYS
Value    Char RIB
Variable Char IBAN
Local Char    CNUMBERI(50), CI(2), CNUMBERO(50)
Local Integer D, I
Local Decimal INUMBER , INUMBER1 , INUMBER2
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
Call LECTURE("TCY",PAYS,"") From CONTOBJ
# FQ59624 - MABON 06/11/09 - On teste si "Gestion de l'IBAN" est coché pour le pays
#If !fstat & len([F:TCY]ISO)=2 & [F:TCY]EECCOD<>""
If !fstat & len([F:TCY]ISO)=2 & [F:TCY]FLIBAN=2
 CNUMBERI = RIB+[F:TCY]ISO+"00"
 For I=1 To len(CNUMBERI)
  CI = mid$(CNUMBERI,I,1)
  If CI>"9"
   CI = num$(ascii(CI)-55)
  Endif
  CNUMBERO += CI
 Next I
 If len(CNUMBERO)<=32
  INUMBER = val(CNUMBERO)
  D = 98-mod(INUMBER,97)
 Else
  INUMBER1 = val(left$(CNUMBERO,32))
  INUMBER2 = val(right$(CNUMBERO,33))
  D = mod(mod(INUMBER1,97)*10^^(len(CNUMBERO)-32)+mod(INUMBER2,97),97)
  D = 98-D
 Endif
 IBAN = [F:TCY]ISO+format$("N0:##",D)
Else
 IBAN = ""
Endif
End

Subprog C_BIDBPAADD(VALEUR)
Variable Char     VALEUR
If dim([M]CODADR)>0
 If VALEUR<>"" & !find(VALEUR,[M]CODADR(0..[M]NBADR-1))
  GMESSAGE = mess(46,133,1) : mkstat = 1 : # Code adresse inexistant
 Endif
Endif
End

Subprog AM_BIDNUMFLG(VALEUR)
Variable Integer VALEUR
ACTION = "AM_BIDNUMFLG" :  Gosub ACTION_BPA
End

Subprog AS_PAB1(VALEUR)
Variable Char    VALEUR()
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
Call LECTURE("TCY",[M]BIDCRY(nolign-1),"") From CONTOBJ
If [F:TCY]BIDCTL=2
 If clalev([F:ABN])=0 : Local File ABANK [ABN] : Endif
 Read [ABN]ABN0=[M]BIDCRY(nolign-1);left$([M]BIDNUM(nolign-1),[F:TCY]BANLNG)
 If !fstat
  If VALEUR<>[F:ABN]PAB
   VALEUR = [F:ABN]PAB : Endif
   mkstat = 2
 Endif
Endif
End

Subprog C_VLYSTR(VALEUR)
Variable Date    VALEUR
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
Call LECTURE("TCY",[M]BIDCRY(nolign-1),"") From CONTOBJ
If [F:TCY]BIDCTL=2
 If clalev([F:ABN])=0 : Local File ABANK [ABN] : Endif
 Read [ABN]ABN0 = [M]BIDCRY(nolign-1);left$([M]BIDNUM(nolign-1),[F:TCY]BANLNG)
 If !fstat
  If [F:ABN]VLYSTR>VALEUR
   VALEUR = [F:ABN]VLYSTR
  Endif
 Endif
Endif
End

Subprog C_VLYEND(VALEUR)
Variable Date    VALEUR
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
Call LECTURE("TCY",[M]BIDCRY(nolign-1),"") From CONTOBJ
If [F:TCY]BIDCTL=2
 If clalev([F:ABN])=0 : Local File ABANK [ABN] : Endif
 Read [ABN]ABN0 = [M]BIDCRY(nolign-1);left$([M]BIDNUM(nolign-1),[F:TCY]BANLNG)
 If !fstat
  If [F:ABN]VLYEND<>[0/0/0]
   If VALEUR=[0/0/0] or VALEUR>[F:ABN]VLYEND
    VALEUR = [F:ABN]VLYEND
   Endif
  Endif
 Endif
Endif
End

Subprog C_REG(VALEUR)
Variable Char    VALEUR()
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
Call LECTURE("ADI",VALEUR,"905") From CONTOBJ
If [F:ADI]N2<>2
 GMESSAGE = mess(43,114,1) : # Le mode de règlement n'est pas de type virement
 mkstat   = 2
 End
Endif
End

###################################################################################
## Gestion des contacts
###################################################################################
Subprog CHARG_CNT(LTYP,ENTITE,DEFCNT)
Value Integer LTYP
Value Char    ENTITE
Value Char    DEFCNT
Local Integer NOL

Actzo [M]CCNCRM   # Issue SAM118285 - 2016-12-06 by FGR
Raz [M]
[M]IDENT  = num$(LTYP)+ENTITE
[M]NUMBPA = LTYP
nolign = 0
For [CNT]CNT0 Where BPATYP=LTYP & BPANUM=ENTITE
 If nolign>=dim([M]CNTCRY)
  Call ERREUR(mess(183,197,1)-":"-mess(26,100,1)) From GESECRAN : Break
 Endif
 nolign += 1
 Read [AIN]AIN0 = [F:CNT]CCNCRM
 If !fstat
  #[M]CNTCRY(nolign-1)    = [F:AIN]CRY       # FGR 27/08/2013 : X3SUIVI88615 : Ca n'est pas ce pays là
  [M]CNTLNA(nolign-1)    = [F:AIN]CNTLNA
  [M]CNTFNA(nolign-1)    = [F:AIN]CNTFNA
  [M]CNTTTL(nolign-1)    = [F:AIN]CNTTTL
  [M]CNTMOB(nolign-1)    = [F:AIN]CNTMOB
  [M]CNTBIR(nolign-1)    = [F:AIN]CNTBIR
  [M]CNTFULNAM(nolign-1) = [F:AIN]CNTFULNAM
  [M]CNTFBDMAG(nolign-1) = [F:AIN]CNTFBDMAG   # FGR 04/06/2008 : X3SUIVI46709 (debut)
  [M]CNTLAN(nolign-1)    = [F:AIN]CNTLAN      # FGR 11/02/2009 : X3SUIVI52269
  [M]CNTCSP(nolign-1)    = [F:AIN]CNTCSP      # FGR 11/02/2009 : X3SUIVI52269
 Endif
 [M] = [F:CNT]
 [M]CNTADD(nolign-1) = [F:CNT]BPAADD
 # -------------------------------------
 # FGR 27/08/2013 : X3SUIVI88615 (début)
 If [M]CNTADD(nolign-1) <> "" Then
  If clalev([F:BPA])=0 : Local File BPADDRESS [BPA] : Endif
  Read [BPA]BPA0=LTYP;ENTITE;[M]CNTADD(nolign-1)
  [M]CNTCRY(nolign-1) = [F:BPA]CRY
 Else
  If dim([M]CRY) > 0 Then
    [M]CNTCRY(nolign-1) = [M]CRY
  Else
    [M]CNTCRY(nolign-1) = GPAYS
  Endif
 Endif
 # FGR 27/08/2013 : X3SUIVI88615 (fin)
 # -------------------------------------
 [M]CNTTEL(nolign-1) = [F:CNT]TEL
 [M]CNTMOB(nolign-1) = [F:CNT]MOB  # FGR 23/07/2008 : X3SUIVI48432 ajout téléphone portable
 [M]CNTFAX(nolign-1) = [F:CNT]FAX
 [M]CNTWEB(nolign-1) = [F:CNT]WEB
 #==>JPGA<== 22/04/2008 : Contact par défaut [F:CNT]CNTFLG supprimé de la table CONTACT
 #==>Le nom du contact par défaut CNTNAM a été remonté dans chaque table fonctionnelle (CPY/FCY/BPC/BPR/BPS/BPP/BPT)
 ##LSE 17/06/2006 FQ 36999 On utilise le flag pour ne pas masquer un pb et 18/12/20007 FQ44884
 #[M]CNTFLG(nolign-1)= [F:CNT]CNTFLG
 If [F:CNT]CCNCRM = DEFCNT
  [M]CNTFLG(nolign-1) = 2
 Else
  [M]CNTFLG(nolign-1) = 1
 Endif
 [M]FLNEW(nolign-1) = 1
 [M]FLMOD(nolign-1) = 0 # FGR 11/02/2009 : X3SUIVI52269 : pas obligatoire, fait pas le RAZ mais facilite la compréhension
                        # FGR 11/02/2009 : X3SUIVI52269 : [M]FLMOD(nolign-1) = 0 => Ligne non modifiée
                        # FGR 11/02/2009 : X3SUIVI52269 : [M]FLMOD(nolign-1) = 1 => Ligne modifiée
 # jira 75856 caution only for company
 If dim([M]DPO) >= 0
    [M]DPO(nolign-1) =  [F:CNT]DPO
Endif
 # Memorisations des contacts dans ecran contact CNTxxx         hcb 41886
 GPOINT="LOAD_CTN" : Gosub ENTREE From EXEFNC

Next
[M]NBCNT = nolign

# -------------------------------------
# FGR 22/06/2015 : X3SUIVI107416 (début)
Affzo [M]20
For nolign = 1 To [M]NBCNT
  Diszo [M]CCNCRM(nolign-1)
Next nolign
Affzo [M]20
# FGR 22/06/2015 : X3SUIVI107416 (fin)
# -------------------------------------

If [M]NBCNT>0 & !find(2,[M]CNTFLG(0..[M]NBCNT-1))
 #LSE 17/06/2006 FQ 36999 et 18/12/20007 FQ44884
 I=find(DEFCNT,[M]CCNCRM(0..[M]NBCNT-1))
 If I>0
    [M]CNTFLG(I-1) = 2
    [M]FLMOD (I-1)=1
 Else
    [M]CNTFLG(0) = 2
    [M]FLMOD(0)=1
 Endif
Endif

#[M]KCNTFLG = 1
If [M]NBCNT=0
 Effzo 25-40
 If GBROWS <> 2 Then # FGR 05/07/2011 : X3SUIVI73551 Si GBROW=2 il n'y a pas d'interface donc pas la peine de désactiver l'écran
                     # Du coup pas de problème en Web Services.
   Diszo 25-40
 Endif
Else
 Actzo 25-40
 NOL = 0
 Gosub REMP_CNT
Endif
End

#########################################################################
$ALIMENTE_F_AIN
  # FGR 11/02/2009 : X3SUIVI52269 champs mis dans l'ordre de la table (debut)
  [F:AIN]CNTFULNAM     = func SUBAIN.CLE([F:AIN]CNTLNA,[F:AIN]CNTFNA)
  [F:AIN]CNTTTL        = [M]CNTTTL(nolign-1)
  If LTYP = 6 Then                                # FGR 11/02/2009 : X3SUIVI52269 : initialisé uniquement en création
    [F:AIN]CNTTYP      = 2  # 6 : Lead : CNTTYP=2
  Else
    [F:AIN]CNTTYP      = 1  # Tous les autres cas : CNTTYP=1
  Endif
  [F:AIN]CNTLNA        = [M]CNTLNA(nolign-1)
  [F:AIN]CNTFNA        = [M]CNTFNA(nolign-1)
  [F:AIN]CNTBIR        = [M]CNTBIR(nolign-1)
  [F:AIN]CNTLAN        = [M]CNTLAN(nolign-1)      # FGR 11/02/2009 : X3SUIVI52269
  [F:AIN]CNTCSP        = [M]CNTCSP(nolign-1)      # FGR 11/02/2009 : X3SUIVI52269
  If [F:AIN]CRY = "" Then                         # FGR 13/01/2010 : X3SUIVI58725
    [F:AIN]CRY         = [M]CNTCRY(nolign-1)      # FGR 13/01/2010 : X3SUIVI58725
  Endif                                           # FGR 13/01/2010 : X3SUIVI58725
 #If [M]CNTADD <> "" Then
 #  Read [BPA]BPA0=LTYP;ENTITE;[M]CNTADD(nolign-1)
 #  If !fstat Then
 #    [F:AIN]CRY       = [M]CNTCRY(nolign-1)
 #    [F:AIN]CRYNAM    = [F:BPA]CRYNAM            # FGR 11/02/2009 : X3SUIVI52269
 #    For NI = 0 To dim([F:AIN]ADD)-1
 #      [F:AIN]ADD(NI) = [F:BPA]BPAADDLIG(NI)     # FGR 11/02/2009 : X3SUIVI52269
 #    Next NI
 #    [F:AIN]ZIP       = [F:BPA]POSCOD            # FGR 11/02/2009 : X3SUIVI52269
 #    [F:AIN]CTY       = [F:BPA]CTY               # FGR 11/02/2009 : X3SUIVI52269
 #    [F:AIN]SAT       = [F:BPA]SAT               # FGR 11/02/2009 : X3SUIVI52269
 #  Endif
 #Endif
 #[F:AIN]CNTETS        = [M]CNTTEL(nolign-1)      # FGR 11/02/2009 : X3SUIVI52269
 #[F:AIN]CNTFAX        = [M]CNTFAX(nolign-1)      # FGR 11/02/2009 : X3SUIVI52269
 #[F:AIN]CNTMOB        = [M]CNTMOB(nolign-1)      # FGR 12/01/2016 : X3SUIVI113690(US77755) possible to have different personnal and professional mobiles.
 #[F:AIN]CNTEMA        = [M]CNTWEB(nolign-1)      # FGR 11/02/2009 : X3SUIVI52269
  [F:AIN]CNTFBDMAG     = [M]CNTFBDMAG(nolign-1)   # FGR 04/06/2008 : X3SUIVI46709
  # FGR 11/02/2009 : X3SUIVI52269 champs mis dans l'ordre de la table (fin)
  GPOINT="ALFAIN_CTN" : Gosub ENTREE From EXEFNC  # FGR 19/05/2009 : X3SUIVI55271
 # Point d'entrÃ©e manquant : les rubriques spÃ©cifiques n'Ã©taient jamais enregistrÃ©es
Return
#########################################################################

Subprog CRECNT(LTYP,ENTITE)
Value Integer LTYP
Value Char    ENTITE
Local Integer STA , OLDCNT
Local Char    ACTION(20)
Local Integer NI # FGR11/02/2009 : X3SUIVI52269

  # FGR 27/11/2013 : X3SUIVI94714 (début)
  ACTION = "CRECNT_BEGIN"
  Gosub ACTION_BPA
  If GOK<1 : End : Endif
  # FGR 27/11/2013 : X3SUIVI94714 (fin)

OLDCNT = 0
For [CNT]CNT0 Where BPATYP=LTYP & BPANUM=ENTITE
 OLDCNT += 1
 If !find([F:CNT]CCNCRM,[M]CCNCRM(0..[M]NBCNT-1))
  Delete [CNT]
  If fstat=1
   GOK = -1 : GLOCK = "$CONTACT"-num$(LTYP)-[F:CNT]CCNCRM : Break
  Endif
 Endif
Next
If GOK<1 : End : Endif
If [M]NBCNT>0 & !find(2,[M]CNTFLG(0..[M]NBCNT-1))
 [M]CNTFLG(0) = 2
 #LSE 18/12/2007 FQ44884
 [M]FLMOD(0)=1
Endif
For nolign=1 To [M]NBCNT
 If (!OLDCNT or [M]FLMOD(nolign-1)) & [M]CNTLNA(nolign-1)<>""
  Read [AIN]AIN0 = [M]CCNCRM(nolign-1)
  If !fstat & [M]CCNCRM(nolign-1)<>""
   # FGR 04/06/2008 : X3SUIVI46709 : ajout de CRY qui manquait et CNTFBDMAG qui est nouveau
#  If (                                             # FGR 11/02/2009 : X3SUIVI52269 : Test source d'oubli
#&      [M]CNTTTL(nolign-1)<>[F:AIN]CNTTTL          # FGR 11/02/2009 : X3SUIVI52269 : Test source d'oubli
#&    | [M]CNTLNA(nolign-1)<>[F:AIN]CNTLNA          # FGR 11/02/2009 : X3SUIVI52269 : Test source d'oubli
#&    | [M]CNTFNA(nolign-1)<>[F:AIN]CNTFNA          # FGR 11/02/2009 : X3SUIVI52269 : Test source d'oubli
#&    | [M]CNTMOB(nolign-1)<>[F:AIN]CNTMOB          # FGR 11/02/2009 : X3SUIVI52269 : Test source d'oubli
#&    | [M]CNTBIR(nolign-1)<>[F:AIN]CNTBIR          # FGR 11/02/2009 : X3SUIVI52269 : Test source d'oubli
#&    | [M]CNTCRY(nolign-1)    <> [F:AIN]CRY        # FGR 11/02/2009 : X3SUIVI52269 : Test source d'oubli
#&    | [M]CNTFBDMAG(nolign-1) <> [F:AIN]CNTFBDMAG  # FGR 11/02/2009 : X3SUIVI52269 : Test source d'oubli
#&     )                                            # FGR 11/02/2009 : X3SUIVI52269 : Test source d'oubli
   If [M]FLMOD(nolign-1) = 1 Then                   # FGR 11/02/2009 : X3SUIVI52269 : si un seul champ modifié FLMOD(nolign-1) = 1
    Readlock [AIN]AIN0 Curr
    If fstat=1
     GOK = -1 : GLOCK = "$CONTACTCRM"-[F:CNT]CCNCRM : Break
    Endif
    #
    Gosub ALIMENTE_F_AIN  # FGR 11/02/2009 : X3SUIVI52269
    #
    If dim([F:AIN]UPDDAT)>0 : [F:AIN]UPDDAT = date$ : Endif
    If dim([F:AIN]UPDUSR)>0 : [F:AIN]UPDUSR = GUSER : Endif
    If dim([F:AIN]UPDTIM)>0 : [F:AIN]UPDTIM = time  : Endif
    Rewrite [AIN]
    If fstat
     GOK = 0 : Call FSTA("AIN") From GLOCK : Break
    Endif
   Endif
  Else
   Raz [F:AIN]
   [F:AIN]CNTNUM = [M]CCNCRM(nolign-1)
   If [F:AIN]CNTNUM=""
    Repeat
     [F:AIN]CNTNUM = func SUBAIN.COD([C]INTERLOC)
     [C]INTERLOC += 1
     Look [AIN]AIN0 = [F:AIN]CNTNUM
    Until fstat
    [M]CCNCRM(nolign-1) = [F:AIN]CNTNUM
    Affzo CCNCRM(nolign-1)
    If [M]KNOLIG=nolign-1
     [M]KCCNCRM = [F:AIN]CNTNUM
     Affzo KCCNCRM
    Endif
   Endif
   #
   Gosub ALIMENTE_F_AIN  # FGR 11/02/2009 : X3SUIVI52269
   #
   If dim([F:AIN]CREDAT)>0 : [F:AIN]CREDAT = date$ : Endif
   If dim([F:AIN]CREUSR)>0 : [F:AIN]CREUSR = GUSER : Endif
   If dim([F:AIN]CRETIM)>0 : [F:AIN]CRETIM = time  : Endif
   [F:AIN]CNTFULNAM = func SUBAIN.CLE([F:AIN]CNTLNA,[F:AIN]CNTFNA)
   Write [AIN]
   If fstat
    GOK = 0 : Call FSTA("AIN") From GLOCK : Break
   Endif
  Endif
  Readlock [CNT]CNT0 = LTYP;ENTITE;[M]CCNCRM(nolign-1)
  STA = fstat
  If STA=1
   GOK = -1 : GLOCK = "$CONTACT"-num$(LTYP)-ENTITE-[M]CCNCRM(nolign-1) : Break
  Elsif STA
   Raz [F:CNT]
  Endif
  [F:CNT] = [M]
  [F:CNT]BPATYP = LTYP
  [F:CNT]BPANUM = ENTITE
  [F:CNT]BPAADD = [M]CNTADD(nolign-1)
  [F:CNT]TEL    = [M]CNTTEL(nolign-1)
  [F:CNT]MOB    = [M]CNTMOB(nolign-1)  # FGR 23/07/2008 : X3SUIVI48432 ajout téléphone portable
  [F:CNT]FAX    = [M]CNTFAX(nolign-1)
  [F:CNT]WEB    = [M]CNTWEB(nolign-1)
  # jira 75856 caution only for company
  If dim([M]DPO) >= 0
      [F:CNT]DPO    = [M]DPO(nolign-1)
  Endif
  #==>JPGA<== 22/04/2008 : Contact par défaut [F:CNT]CNTFLG supprimé de la table CONTACT
  #==>Le nom du contact par défaut CNTNAM a été remonté dans chaque table fonctionnelle (CPY/FCY/BPC/BPR/BPS/BPP/BPT)
  ##LSE 17/06/2006 FQ36999  et 18/12/20007 FQ44884
  #[F:CNT]CNTFLG=[M]CNTFLG(nolign-1)
  ##LSE 20/06/2006 FQ36999 et FQ44884
  #If [F:CNT]CNTFLG<>1 and [F:CNT]CNTFLG<>2
  #  [F:CNT]CNTFLG=1
  #Endif

  # FGR 06/04/2010 : X3SUIVI63506 (début)
  #ACTION = "ECRIT_CNT"
  #Gosub ACTION_BPA
  # FGR 06/04/2010 : X3SUIVI63506 (fin)

  If STA
   If dim([F:CNT]CREDAT)>0 : [F:CNT]CREDAT = date$ : Endif
   If dim([F:CNT]CREUSR)>0 : [F:CNT]CREUSR = GUSER : Endif
   If dim([F:CNT]CRETIM)>0 : [F:CNT]CRETIM = time  : Endif
   Write [CNT]
  Else
   If dim([F:CNT]UPDDAT)>0 : [F:CNT]UPDDAT = date$ : Endif
   If dim([F:CNT]UPDUSR)>0 : [F:CNT]UPDUSR = GUSER : Endif
   If dim([F:CNT]UPDTIM)>0 : [F:CNT]UPDTIM = time  : Endif
   Rewrite [CNT]
  Endif
  If fstat
   GOK = 0 : Call FSTA("CNT") From GLOCK : Break
  Endif

  # FGR 06/04/2010 : X3SUIVI63506 (début)
  ACTION = "ECRIT_CNT"
  Gosub ACTION_BPA
  # FGR 06/04/2010 : X3SUIVI63506 (fin)
 Endif
Next nolign
# Gestion des contacts complémentaires Afrique du Sud
If GOK=1
 ACTION = "ADD_CNT"
 Gosub ACTION_BPA
 Raz [M]FLMOD
Endif
End

Subprog ANNCNT(LTYP,ENTITE)
Value Integer LTYP
Value Char    ENTITE

  # FGR 27/11/2013 : X3SUIVI94714 (début)
  ACTION = "ANNCNT_BEGIN"
  Gosub ACTION_BPA
  If GOK<1 : End : Endif
  # FGR 27/11/2013 : X3SUIVI94714 (fin)

GCLE = num$(LTYP)+ENTITE
Delete [CNT] Where BPATYP=LTYP & BPANUM=ENTITE
If fstat = 1
 GOK = -1
 GLOCK = "$CONTACT"-GCLE : End
Endif
End

Subprog CHGCNT(LTYP,OLDENT,NEWENT)
Value Integer LTYP
Value Char    OLDENT
Value Char    NEWENT
For [CNT]CNT0 Where BPATYP=LTYP & BPANUM=OLDENT
 [F:CNT]BPANUM = NEWENT
 Rewrite [CNT]
 If fstat
  GOK = 0 : Call FSTA("CNT") From GLOCK : Break
 Endif
Next
End

$SETNOL
Local Integer NOL
NOL = nolign -1
Return

#######################################################
## Ecran CNT
#######################################################
$CHARGE_CNT
If !GWEBSERV Then  # FGR 09/02/2015 : X3SUIVI101637
  Gosub REMP_CNT
Endif
#Gestion des contacts complémentaires Afrique du Sud
ACTION = "REMP_CNTB"
Gosub ACTION_BPA
Affzo 25-40
Return

$REMP_CNT
Local Integer K
[M]KCCNCRM    = [M]CCNCRM(NOL)
[M]KCNTLNA    = [M]CNTLNA(NOL)
[M]KCNTFNA    = [M]CNTFNA(NOL)
If [M]CNTFLG(NOL) = 0
 [M]KCNTFLG = 1
Else
 [M]KCNTFLG = [M]CNTFLG(NOL)
Endif
If [M]CNTTTL(NOL)=0
 [M]CNTTTL(NOL) = 1
 [M]KCNTTTL        = 1
Else
 [M]KCNTTTL = [M]CNTTTL(NOL)
Endif
If [M]CNTFNC(NOL)=0
 [M]CNTFNC(NOL) = 1
 [M]KCNTFNC        = 1
Else
 [M]KCNTFNC = [M]CNTFNC(NOL)
Endif
[M]KCNTCRY    = [M]CNTCRY(NOL)
[M]KCNTSRV    = [M]CNTSRV(NOL)
[M]KCNTADD    = [M]CNTADD(NOL)
[M]KCNTMSS    = [M]CNTMSS(NOL)
[M]KCNTBIR = [M]CNTBIR(NOL)
# FGR 04/06/2008 : X3SUIVI46709 (debut)
If [M]CNTFBDMAG(NOL) = 0 Then
 [M]CNTFBDMAG(NOL) = 1
 [M]KCNTFBDMAG = [M]CNTFBDMAG(NOL)
Else
 [M]KCNTFBDMAG = [M]CNTFBDMAG(NOL)
Endif
# FGR 04/06/2008 : X3SUIVI46709 (fin)

[M]KCNTLAN = [M]CNTLAN(NOL)      # FGR 11/02/2009 : X3SUIVI52269
[M]KCNTCSP = [M]CNTCSP(NOL)      # FGR 11/02/2009 : X3SUIVI52269

# Recherche du code adresse saisi dans l onglet des codes adresses
# et affichage du libelle de l'adresse BPAADES
K = find([M]KCNTADD,[M]CODADR(0..[M]NBADR-1))
If K
 [M]KADDNAM = [M]BPADES(K-1)
 #MAE, bg 57512
 If dim([M]KCNTCRY)>0
    [M]KCNTCRY = [M]BPACRY(K-1)
 Endif
Elsif [M]KCNTADD="" & 1=0
 [M]KADDNAM = ""
 [M]KCNTCRY    = GPAYS
#       Si on a aucun code adresse : initialiser avec le code adresse par defaut
 For I=0 To [M]NBADR-1
  If [M]BPAADDFLG(I)=2
   [M]KCNTADD        = [M]CODADR(I)
   [M]KCNTCRY        = [M]BPACRY(I)
   [M]CNTCRY(NOL) = [M]BPACRY(I)
   [M]KADDNAM     = [M]BPADES(I)
   [M]CNTADD(NOL) = [M]CODADR(I)
   If dim([M]TEL1)>0
    [M]CNTTEL(NOL) = [M]TEL1(I)
    [M]CNTMOB(NOL) = [M]TEL5(I)
    [M]CNTFAX(NOL) = [M]TEL2(I)
   Else
    [M]CNTTEL(NOL) = [M]TEL(I)
    [M]CNTMOB(NOL) = [M]MOB(I) # FGR 23/07/2008 : X3SUIVI48432 ajout téléphone portable
    [M]CNTFAX(NOL) = [M]FAX(I)
   Endif
   If dim([M]WEB1)>0
    [M]CNTWEB(NOL) = [M]WEB1(I)
   Else
    [M]CNTWEB(NOL) = [M]WEB(I)
   Endif
   Break
  Endif
 Next I
Else
 [M]KADDNAM = ""
Endif
[M]KCNTTEL    = [M]CNTTEL(NOL)
[M]KCNTMOB    = [M]CNTMOB(NOL) # FGR 23/07/2008 : X3SUIVI48432 ajout téléphone portable
[M]KCNTFAX    = [M]CNTFAX(NOL)
[M]KCNTWEB    = [M]CNTWEB(NOL)
# jira 75856 caution only for company
If dim([M]DPO) >= 0
    [M]KDPO       = [M]DPO(NOL)
Endif

# Affichage d un contact dans ecran contact CNTxxx         hcb 41886
GPOINT="REMP_CTN" : Gosub ENTREE From EXEFNC

Return

