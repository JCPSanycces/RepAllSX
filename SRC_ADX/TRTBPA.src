Subprog C_KCNTADD(VALEUR)
Variable Char    VALEUR()
If dim([M]CODADR)>0
 If VALEUR<>"" & !find(VALEUR,[M]CODADR(0..[M]NBADR-1))
  GMESSAGE = mess(46,133,1) : mkstat = 1 : # Code adresse inexistant
 Endif
Endif
End

Subprog AM_KCNTADD(VALEUR)
Variable Char    VALEUR()
Local Integer K
Gosub APRES_MODIF : If mkstat : End : Endif
[M]CNTADD([M]KNOLIG) = VALEUR
[M]FLMOD([M]KNOLIG)  = 1

If VALEUR <> "" Then # FGR 27/08/2013 : X3SUIVI88615 : seulement s'il y a une valeur
  K = find(VALEUR,[M]CODADR(0..[M]NBADR-1))
Endif
If K
 [M]KCNTCRY    = [M]BPACRY(K-1)
 #MAE, bg 84182 : si on est dans les clients, on force l'écran
 If GFONC1 = "GESBPC"
    [M]KADDNAM = [M:BPAC]BPADES(K-1)
 Else
    [M]KADDNAM = [M]BPADES(K-1)
 Endif
If dim([M]TEL1)>0
  #MAE, bg 85690 : on récupére le téléphone et les autres infos uniquement si ils ne sont pas déja renseignés
  If [M]KCNTTEL = "" : [M]KCNTTEL    = [M]TEL1(K-1) : Endif
  If [M]KCNTMOB = "" : [M]KCNTMOB    = [M]TEL5(K-1) : Endif
  If [M]KCNTFAX = "" : [M]KCNTFAX    = [M]TEL2(K-1) : Endif
 Else
  If [M]KCNTTEL = "" : [M]KCNTTEL    = [M]TEL(K-1)  : Endif
  If [M]KCNTMOB = "" : [M]KCNTMOB    = [M]MOB(K-1)  : Endif
  If [M]KCNTFAX = "" : [M]KCNTFAX    = [M]FAX(K-1)  : Endif
 Endif
 If dim([M]WEB1)>0
    If [M]KCNTWEB = "" : [M]KCNTWEB    = [M]WEB1(K-1) : Endif
 Else
    If [M]KCNTWEB = "" : [M]KCNTWEB    = [M]WEB(K-1)  : Endif
 Endif
Else
 # -------------------------------------
 # FGR 27/08/2013 : X3SUIVI88615 (début)
 #[M]KCNTCRY    = GPAYS
 If dim([M]CRY) > 0 Then
   [M]KCNTCRY    = [M]CRY
 Else
   [M]KCNTCRY    = GPAYS
 Endif
 # FGR 27/08/2013 : X3SUIVI88615 (fin)
 # -------------------------------------
 [M]KADDNAM = ""
Endif
Affzo KCNTCRY, KADDNAM, KCNTTEL, KCNTMOB, KCNTFAX, KCNTWEB # FGR 23/07/2008 : X3SUIVI48432 ajout téléphone portable
[M]CNTCRY([M]KNOLIG) = [M]KCNTCRY
[M]CNTTEL([M]KNOLIG) = [M]KCNTTEL
[M]CNTMOB([M]KNOLIG) = [M]KCNTMOB # FGR 23/07/2008 : X3SUIVI48432 ajout téléphone portable
[M]CNTFAX([M]KNOLIG) = [M]KCNTFAX
[M]CNTWEB([M]KNOLIG) = [M]KCNTWEB
End

