# Activation/Desactivation des zones prix en fonction des codes acces
Call PARAMUTIL("SPRIMOD",WPARAM,"","") From SUBAUS
GPRIMOD=val(WPARAM)
If GPRIMOD=0 GPRIMOD=1 Endif

