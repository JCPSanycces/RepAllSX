#--/CPO

For NOL=0 To [M]NBLIG-1
   Raz [M:SDH1]UPDFLG(NOL)
   Raz [M:SDH1]CREFLG(NOL)
   Raz [M:SDH1]RTNQTY(NOL)
   Raz [M:SDH1]XSOHNUM(NOL)
