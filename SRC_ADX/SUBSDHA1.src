[M:SDH1]CFMPAR=1
#---
[M:SDH1]PRNNDE = 1  # FGR 05/07/2014 : X3SUIVI90714
[M:SDH1]PRNNPR = 1  # FGR 05/07/2014 : X3SUIVI90714
