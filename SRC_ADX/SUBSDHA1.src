   Raz [M:SDH1]SOQSEQ(NOL)
   Raz [M:SDH1]YDLVQTY(NOL)
#   Raz [M:SDH1]YALLQTY(NOL)
   # 100691
   Raz [M:SDH1]VCRTYPORI(NOL), [M:SDH1]VCRNUMORI(NOL)
   Raz [M:SDH1]VCRLINORI(NOL), [M:SDH1]VCRSEQORI(NOL)
   # 100691
   # Issue X3-69499 - 2018-02-14 by TS
   [M]LINCFMFLG(NOL)=1
   #---
   If left$([M:SDH1]PRPTEX(NOL),3)="SDD"
       Call DUP_CLOB("SDD",[M:SDH1]PRPTEX(NOL),WRET) From TRTX3TEX
       If WRET<1 Raz [M:SDH1]PRPTEX(NOL) Endif
   Endif
   If left$([M:SDH1]SDDTEX(NOL),3)="SDD"
       Call DUP_CLOB("SDD",[M:SDH1]SDDTEX(NOL),WRET) From TRTX3TEX
       If WRET<1 Raz [M:SDH1]SDDTEX(NOL) Endif
   Endif

   If dim([M:SDH1]LOT)>0     Raz [M:SDH1]LOT(NOL)     Endif
   If dim([M:SDH1]SLO)>0     Raz [M:SDH1]SLO(NOL)     Endif
   If dim([M:SDH1]LOC)>0     Raz [M:SDH1]LOC(NOL)     Endif
   If dim([M:SDH1]SERNUM)>0  Raz [M:SDH1]SERNUM(NOL)  Endif
   If dim([M:SDH1]SERNUMF)>0 Raz [M:SDH1]SERNUMF(NOL) Endif
   If dim([M:SDH1]PALNUM)>0  Raz [M:SDH1]PALNUM(NOL)  Endif
   If dim([M:SDH1]CTRNUM)>0  Raz [M:SDH1]CTRNUM(NOL)  Endif
   Raz [M:SDH1]PRHNUM(NOL)
   Raz [M:SDH1]PRELIN(NOL)
   Raz [M:SDH1]STA(NOL)
   Raz [M:SDH1]MVTDES(NOL)

   Raz GOUVSOR
   Call LECFICSOR([M:SDH1]ITMREF(NOL),[M:SDH0]STOFCY,[M:SDH0]TRSTYP,
&                 [M:SDH0]TRSCOD,0) From STKECR
   # La ligne de livraison est-elle complète du point de vue stock
   If [M]STOMGTCOD(NOL)<>1
      # Si stock à sortir non encore déterminé, init emplacement par défaut
      If dim([M:SDH1]LOC)>0 & [M:SDH1]WSTOSEQ(NOL)=0
         Call STKINIEMPS([M:SDH1]LOC(NOL)) From STKLOC
      Endif
      # Alimentation de [M:ALP]
      Gosub ALI_ALP From SUBSDH
      # Détermination du stock à sortir (automatisme, saisie)
      Call OUVSOR("SDH1",NOL,[M:SDH1]NBLIG,[M:SDH1]WSTOSEQ(NOL),GSLTSTKFLG,WRET)
&                 From STKSOR
      If WRET=1 Endif
   Endif
Next NOL

# BRBAN 24/07/2014 SAM #93745 US2
If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([F:SDH]STOFCY, '')=1
  Raz [M:SDH3]GLBDOCDAT,GLBDOCNUM,GLBDOCTYP,MANDOC,ATDTCOD,GLBDOC
  Actzo [M:SDH3]GLBDOCDAT,GLBDOCNUM,GLBDOCTYP,MANDOC,ATDTCOD,GLBDOC
  Call DIS_MANDOC(GFONCTION) From TRNDOC
Endif
#-

# 101090 - BOL
If dim ([M:SDH2]BOLNUM)>0   : Raz [M:SDH2]BOLNUM  : Endif
If dim ([M:SDH2]SCAC)>0     : Raz [M:SDH2]SCAC    : Endif
If dim ([M:SDH2]PRONUM)>0   : Raz [M:SDH2]PRONUM  : Endif
If dim ([M:SDH2]TRAILER)>0  : Raz [M:SDH2]TRAILER : Endif

Affzo [M:SDH0]1-99
Affzo [M:SDH1]1-99
Affzo [M:SDH2]1-99
Affzo [M:SDH3]1-99

# Gestion de l'état des zones
Gosub ETAT_ZONE From SUBSDHA

# Actzo ou Grizo des dépôts selon le site
Gosub WRH_ETAT From SUBSDHA

Raz YSOHNUM

#------------------------------------------------------------#
# Renseignement des unités de répartition                    #
#------------------------------------------------------------#
[M:SDH0]DSPWEU = GSALDSPWEU
[M:SDH0]DSPVOU = GSALDSPVOU

Raz GSDHSUPPLIGDSP :#--CPO 79343

Call NTSDUP([M:SDH0]BPCORD,"BPCNUM") From TRTNTSCTL   # customer notes

Return

#########################################################################
# 101380 - Setup SST Override related fields
#########################################################################
Subprog SETUP_SSTFIELDS

# If GLOCUSATAX   # 106867.o
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
  Grizo [M:SDH1]VACITM1,VACITM2,VACITM3
  If dim([M:SDH1]SSTCOD)>0 :
    Chgfmt [M:SDH1]SSTCOD     With "K:"   + num$(type([M:SDH1]SSTCOD)-10)     + "B"     # Show enterable
    Chgfmt [M:SDH2]SFISSTCOD  With "K:"   + num$(type([M:SDH2]SFISSTCOD)-10)  + "B"     # Show enterable
    Actzo [M:SDH1]SSTCOD
  Endif
Else
  Actzo [M:SDH1]VACITM1,VACITM2,VACITM3
  If dim([M:SDH1]SSTCOD)>0
    Chgfmt [M:SDH1]SSTCOD     With "-K:"  + num$(type([M:SDH1]SSTCOD)-10)     + "B"     # Hide
    Chgfmt [M:SDH2]SFISSTCOD  With "-K:"  + num$(type([M:SDH2]SFISSTCOD)-10)  + "B"     # Hide
  Endif
Endif

End

#########################################################################
# 101380 - Retrieve SST Code from source doc when copying from earlier document
# Invoicing elements can be re-ordered or dropped due to transfer rules.
#########################################################################
Subprog RELOAD_SFISST
Local Integer NEWELEM, SRCELEM, INBFAC
Local Char    DEST

# Should never get here without an SO attached, but just in case
# If !GLOCUSATAX : End : Endif   # 106867.o
If !(func AFNC.ACTIV("LTA")) | [F:CPY]SSTTAXACT <> 2 : End : Endif   # 106867.n

If [M:SDH0]SOHNUM="" & [M:SDH1]SOHCAT(nolign-1)<>4 : End : Endif

INBFAC=dim([M:SDH2]INVDTA)

Local Char    OGSSTCOD(8) (INBFAC)
Local Integer OGINVDTA    (INBFAC)

#Get the elements from the order and store in local variables
For SRCELEM=0 To INBFAC-1
  [L]OGINVDTA(SRCELEM) = [F:SOH]INVDTA(SRCELEM)
  [L]OGSSTCOD(SRCELEM) = [F:SOH]SFISSTCOD(SRCELEM)
Next I

#Find the correct inv element on the SDH header and update the SSTCOD
For NEWELEM=0 To INBFAC-1
  If [M:SDH1]SOHCAT(nolign-1)=4
    SRCELEM = find([M:SDH2]INVDTA(NEWELEM), [L]OGINVDTA(0..INBFAC-1))
    If SRCELEM>0
      [M:SDH2] SFISSTCOD(NEWELEM)=[L]OGSSTCOD(SRCELEM-1)
    Endif
  Else
    SRCELEM = find([F:SDH]INVDTA(NEWELEM), [L]OGINVDTA(0..INBFAC-1))
    If SRCELEM>0
      [F:SDH] SFISSTCOD(NEWELEM)=[L]OGSSTCOD(SRCELEM-1)
    Endif
  Endif
Next NEWELEM

End
#########################################################################

$CHARGE_STOSOM
#-----------------------------------------------------------------------#
# Chargement des paramètres dans masque STOSOM pour modification des    #
# sorties                                                               #
# Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOSOMA       #
#-----------------------------------------------------------------------#

# Composant d'un kit/sous-traité
If find([M:SDH1]LINTYP(LNOL),3,4,5,11,12,13) GTYPLIG=1 Endif

[M:SOM]TRSTYP    = [M:SDH0]TRSTYP
[M:SOM]TRSCOD    = [M:SDH0]TRSCOD
If [M:SDH1]BETFCY=2
   [M:SOM]TRFFCY = [M:SDH1]PRHFCY
   [M:SOM]BETCPY = [M:SDH1]BETCPY
Else
   [M:SOM]TRFFCY = ""
   [M:SOM]BETCPY = 1
Endif
[M:SOM]VCRTYP    = 4
[M:SOM]VCRNUM    = [M:SDH0]SDHNUM
[M:SOM]VCRLIN    = [M:SDH1]SDDLIN(LNOL)
[M:SOM]STU       = [M:SDH1]STU(LNOL)
[M:SOM]PCU       = [M:SDH1]SAU(LNOL)
[M:SOM]PCUSTUCOE = [M:SDH1]SAUSTUCOE(LNOL)
[M:SOM]SORQTY    = [M:SDH1]QTYSTU(LNOL)
[M:SOM]SORQTYACT = [M:SDH1]QTYSTU(LNOL)
[M:SOM]DLVDAT    = [M:SDH1]DLVDAT
[M:SOM]PECINTLOC = 2
[M:SOM]PECPLFLOC = 2
[M:SOM]PECSCOLOC = 1
[M:SOM]PECQLYCTL = 1
[M:SOM]STOLOC    = ""
[M:SOM]XLOT      = [M:SDH1]LOTFIL(LNOL)
[M:SOM]XLOC      = [M:SDH1]LOCFIL(LNOL)
[M:SOM]XSTA      = [M:SDH1]STAFIL(LNOL)
# FGR 04/05/2015 : X3SUIVI105605 (début)
If dim([M:SDH1]ECCVALMAJ) >= 0 Then
  [M:SOM]WECCVALMAJ = [M:SDH1]ECCVALMAJ(LNOL)
Endif
# FGR 04/05/2015 : X3SUIVI105605 (fin)
# Emplacement prêt ou sous-traitance
If [M:SOM]TRSTYP = 17
   If dim([M:SDH0]XBPCLOC)>0 [M:SOM]BPCLOC = [M:SDH0]XBPCLOC Endif
Elsif [M:SOM]TRSTYP = 20
   If dim([M:SDH3]BPCLOC)>0 [M:SOM]BPCLOC = [M:SDH3]BPCLOC Endif
Endif
If dim([M:SDH1]WRH)>0 [M:SOM]XWRH=[M:SDH1]WRH(LNOL) Endif
#DLUBPC
[M:SOM]BPRNUM    = [M:SDH0]BPCORD

Return

#########################################################################

$APRES_STOSOM
#-----------------------------------------------------------------------#
# Mise à jour complémentaires après enregistrement
# - Recalcul des quantités sorties US, UC de la ligne de document
# - Réalimentation des zones dépendant de la quantité
# - etc ...
#
#   [M:SOM]NBLIG     contient le nombre de ligne de stock traité
#   [M:SOM]SORQTY    contient la quantité US qui était à sortir
#   [M:SOM]SORQTYACT contient la quantité en UA qui était à sortir
#   [M:SOM]PECQTY    contient la quantité US sortie
#   [M:SOM]PECQTYACT contient la quantité en UA sortie
#   [M:SOM]SHTQTY    contient la quantité manquante
#-----------------------------------------------------------------------#

Local    Decimal LQTY, LQTYSTU, DELTAQTY, DELTAQTYSTU
Local    Decimal WCDETTC, WCDEHT, WLIVTTC
Local    Decimal WSALSTU
Local    Decimal WQTY, WSHT
Local    Integer WRET
Local    Char    WSENS
Local    Date    YSHIDAT        : # Pour maj date dernière liv. dans les cdes
Local    Decimal COUTHT, WCOUTHTC : # Bug 53970
Local    Decimal COEF, WDSPLINWEI, WDSPLINVOL : # Bug 72072
Local    Integer NLIG                         : # Bug 72072
Local    Decimal XCRPPRI, XPFM                : # Bug 80451
Local    Decimal PHTNET                       : # 95792 : Variable inexistante dans PE CALPFM
Local    Integer WRTNLINNBR  : # 40127 : Return status management : Number of returned lines
Local    Decimal WSVG_QTY, WSVG_QTYSTU        : # 101874 : V9 : Taxe code control
#Dbgaff #--CPO 28/06/2017 Someone forgot a dbgaff here !! Commented for raising conflict during merging
# On n'a pas enregistré
If WGENR<>1 Return Endif

# Maj du détail livraison
Readlock [SDD]SDD0=[M:SDH0]SDHNUM;[M:SDH1]SDDLIN(LNOL)
If fstat = 1 GOK = -1
   GLOCK = "$SDELIVERYD"-[M:SDH0]SDHNUM-num$([M:SDH1]SDDLIN(LNOL))
   Return
Elsif fstat  GOK =  0
   Call RSTA ("SDD",[M:SDH0]SDHNUM-num$([M:SDH1]SDDLIN(LNOL))) From GLOCK
   Return
Endif

# Quantité traitée
LQTYSTU = [M:SOM]PECQTY + [M:SOM]SHTQTY

If LQTYSTU = 0
   LQTY = 0
Elsif LQTYSTU = [F:SDD]QTYSTU
   LQTY = [F:SDD]QTY
Else
   LQTY = LQTYSTU * [F:SDD]QTY / [F:SDD]QTYSTU
Endif
DELTAQTY    = LQTY    - [F:SDD]QTY
DELTAQTYSTU = LQTYSTU - [F:SDD]QTYSTU

#---------------------------------------------------------------------#
# PE pour maj table spécifique avant maj de la ligne détail livraison #
#---------------------------------------------------------------------#
GPOINT="UPDCFMSDD": Gosub ENTREE From EXEFNC
If GOK = 0 Return Endif

If LQTYSTU = 0
   # 40127 : Return status management
   # The line was completely returned
   If [F:SDD]RTNQTYSTU = [F:SDD]QTYSTU
      WRTNLINNBR -= 1
   Endif
   # 40127

   # Suppression des textes
   If left$([F:SDD]PRPTEX,3)="SDD" Call SUP_CLOB([F:SDD]PRPTEX,WRET) From TRTX3TEX Endif
   If left$([F:SDD]SDDTEX,3)="SDD" Call SUP_CLOB([F:SDD]SDDTEX,WRET) From TRTX3TEX Endif
   # --- Suppression comptes et sections de la ligne de livraison
   Call ENREG_ACCCCE(0,"","","","SDD",0,[F:SDD]SDHNUM,[F:SDD]SDDLIN,0,"","A") From TRTX3CPT
   If GOK<1  Return : Endif
# hcb 103318 deb
   If [F:SDD]PACQTYSTU>0
       # Suppression du colisage de la ligne
       WRET=0
       Call SUP_COLISAGE(4,[F:SDD]SDHNUM,[F:SDD]SDDLIN,"A",WRET) From STKPREPA
       If WRET<>0
          GOK=0
          Return
       Endif
   Endif
# hcb 103318 fin

   Delete [SDD]
Else
    # 40127 : Return status management
    # The line was completely returned
    If [F:SDD]RTNQTYSTU = [F:SDD]QTYSTU
       WRTNLINNBR -= 1
    Endif
    # 40127

   [F:SDD]QTY    += DELTAQTY
   [F:SDD]QTYSTU += DELTAQTYSTU

    # 40127 : Return status management
    # The line is now completely returned
    If [F:SDD]RTNQTYSTU = [F:SDD]QTYSTU
       WRTNLINNBR += 1
    Endif
    # 40127

   # Bug 53970 : Recalcul du prix de revient et de la marge (Ds le cas où valorisation au PMP du lot)
   # --> Si article géré en stock : recalcul

   XCPRPRI  = [F:SDD]CPRPRI          : # Bug 80451
   XPFM     = [F:SDD]PFM             : # Bug 80451
   PHTNET   = [F:SDD]NETPRINOT       : # 95792 : Variable inexistante dans PE CALPFM

   WQTY   = [F:SDD]QTYSTU
   Call DEFCPR ([F:SDD]ITMREF,[M:SDH0]STOFCY,4,[F:SDD]SDHNUM,[F:SDD]SDDLIN,-1,
&               [M:SDH1]SHIDAT,WQTY,COUTHT,WRET) From STKVAL
   If WRET=0
       # Si devise document <> devise base calcul marge (société du site expé)
       If [M:SDH1]CUR <> GLOCALDEV & COUTHT <> 0
           Local Integer STAT
           # Issue X3-98052
           # No rounding, to be consistent with what is done in TRTVENPRI
#           Call CONVERT (GLOCALDEV, [F:SDH]CUR, GLOCALDEV, [M:SDH0]CHGTYP, [M:SDH1]SHIDAT, COUTHT, WCOUTHTC, STAT) From TRTDEV
           Call CONVERT2 (GLOCALDEV, [F:SDH]CUR, GLOCALDEV, [M:SDH0]CHGTYP, [M:SDH1]SHIDAT, COUTHT, WCOUTHTC, STAT) From TRTDEV
           # End issue X3-98052
           COUTHT=WCOUTHTC
       Endif
       # Si Prix de revient récupéré renseigné ou si non renseigné et il n'y avait pas de prix de revient
       If COUTHT<>0 | [F:SDD]CPRPRI=0
           # Le prix de revient est exprimé en US : Le convertir en UV
           COUTHT=COUTHT*[F:SDD]SAUSTUCOE

           # Bug 80451 : PE CALPFM1 non appelé
           #  Point d'entree calcul d'un cout supplémentaire pour le calcul de la marge
           Gosub CALSPEPFM From TRTVENPRI

           If GSALRND = 2
              Call ARRDEV(COUTHT,[F:SDH]CUR) From TRTDIV
              XCPRPRI=COUTHT
           Else
              XCPRPRI=arr(COUTHT,10^-GDECPRI)
           Endif
           # Pas de calcul de marge pour les gratuits
           If [F:SDD]NETPRI<>0 | [F:SDD]FOCFLG<>3
              # Calcul de marge pour les articles vendus ou les articles livrables ayant un prix net
              If [F:ITM]SALFLG=2 | ([F:ITM]SALFLG=1 & [F:SDD]NETPRINOT<>0)
                  # --> Calcul de la marge
                  XPFM = [F:SDD]NETPRINOT - XCPRPRI
              Endif
           Endif
           # Bug 80451
       Endif
   Endif

   # Bug 80451 : PE CALPFM1 non appelé
   #Gosub CALSPEPFM From TRTVENPRI
   #If GSALRND = 2
   #    Call ARRDEV(COUTHT,[M:SDH1]CUR) From TRTDIV
   #    [F:SDD]CPRPRI=COUTHT
   #Else
   #    [F:SDD]CPRPRI=arr(COUTHT,10^-GDECPRI)
   #Endif
   # Point d'entree pour recalcul de la marge
   Gosub CALSPEPFM1 From TRTVENPRI

   [F:SDD]CPRPRI= XCPRPRI
   [F:SDD]PFM   = XPFM

   # Bug 80451

   # Bug 72072
   If [F:ITM]ITMREF<>[F:SDD]ITMREF
      Read [ITM]ITM0=[F:SDD]ITMREF
      If fstat Raz [F:ITM] Endif
   Endif

   WDSPLINWEI = [F:ITM]ITMWEI * DELTAQTY * [F:SDD]SAUSTUCOE
   Call CONVERT_QTY ([F:ITM]WEU,GSALDSPWEU,WDSPLINWEI) From TRTX3
   [F:SDD]DSPLINWEI += WDSPLINWEI

   WDSPLINVOL = [F:ITM]ITMVOU * DELTAQTY * [F:SDD]SAUSTUCOE
   Call CONVERT_QTY ([F:ITM]VOU,GSALDSPVOU,WDSPLINVOL) From TRTX3
   [F:SDD]DSPLINVOL += WDSPLINVOL
   # Bug 72072

   # Bug 80451 : PE CALPFM1 non appelé
   ## Pas de calcul de marge pour les gratuits
   #If [F:SDD]NETPRI<>0 | [F:SDD]FOCFLG<>3
   #    # --> Calcul de la marge
   #    [F:SDD]PFM = [F:SDD]NETPRINOT - [F:SDD]CPRPRI
   #Endif
   # Bug 80451

   Rewrite [SDD]
Endif
If fstat GOK=0 : Call FSTA("SDD") From GLOCK : Return Endif

#-- Maj de l'entête livraison
Readlock [SDH]SDH0=[M:SDH0]SDHNUM
If fstat = 1 GOK = -1
   GLOCK = "$SDELIVERY"-[M:SDH0]SDHNUM
   Return
Elsif fstat  GOK =  0
   Call RSTA ("SDH",[M:SDH0]SDHNUM) From GLOCK
   Return
Endif
YSHIDAT = [F:SDH]SHIDAT
If LQTYSTU = 0 [F:SDH]LINNBR -= 1 Endif

If [F:SDH]LINNBR = 0
   # 101090 - Can't delete shipment if BOL exists
   If dim([M:SDH2]BOLNUM)>0 & [M:SDH2]BOLNUM<>""
    GMESSAGE=func AFNC.MES1(mess(8,2086,1),[M:SDH2]BOLNUM)
    Call ERREUR(GMESSAGE) From GESECRAN
    Raz GMESSAGE : GOK=0 : Return
   Endif

   # 78411 Sage Exchange
   If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC([F:SDH]PTE)
      Call TRANSFER(4,[F:SDH]SDHNUM,2,[F:SDH]SOHNUM,WRET) From SEPPLIB
      If WRET : Raz GOK : Return : Endif
   Endif
# hcb 103318 deb
   If [F:SDH]PACNBR>0
      WRET=0
      Call SUP_COLISAGE(4,[F:SDH]SDHNUM,0,"A",WRET) From STKPREPA
      If WRET<>0
         GOK=0
         Return
      Endif
   Endif
# hcb 103318 fin

   Delete [SDH]
   # Suppression des textes associés
   If left$([F:SDH]PRPTEX1,3)="SDH" Call SUP_CLOB([F:SDH]PRPTEX1,WRET) From TRTX3TEX Endif
   If left$([F:SDH]PRPTEX2,3)="SDH" Call SUP_CLOB([F:SDH]PRPTEX2,WRET) From TRTX3TEX Endif
   If left$([F:SDH]SDHTEX1,3)="SDH" Call SUP_CLOB([F:SDH]SDHTEX1,WRET) From TRTX3TEX Endif
   If left$([F:SDH]SDHTEX2,3)="SDH" Call SUP_CLOB([F:SDH]SDHTEX2,WRET) From TRTX3TEX Endif
   #----------------------------------------------------------------#
   # Modification des enregistrements sans SVCRVAT et SVCRFOOT      #
   #----------------------------------------------------------------#
   Call UPD_VALORISATION ("A","SDH") From TRTVENFACC
   If GOK<1 Return Endif

   # Issue 116758
   #----------------------------------------------------------#
   # Suppression des enr. analytiques des elts de facturation #
   #----------------------------------------------------------#
   [M:SIHV]VCRTYP=2 : [M:SIHV]NUM=[F:SDH]SDHNUM
   Gosub ANU_DIE_FOOT From SUBSIHV
   If GOK < 1 : Return : Endif
   # End issue 116758

#   # Suppression du no livraison des bons de prépa à l'origine de celle-ci
#   For [PRH]PRH1 Where STOFCY=[M:SDH0]STOFCY & DLVFLG=3 & SDHNUM=[M:SDH0]SDHNUM
#      # Raz No livraison et état BP = annulé
#      [F:PRH]SDHNUM = ""
#      [F:PRH]DLVFLG = 4
#      Rewrite [PRH]
#      If fstat GOK=0 : Call FSTA("PRH") From GLOCK : Break Endif
#   Next
#   If GOK <= 0  Return  Endif
Else
   # Maj de la classe [M] nécessaire avant le recalcul de la valorisation
   If LQTYSTU=0
       Dela LNOL,1,[M:SDH1]NBLIG-1 [M:SDH1]NBLIG
       [M:SDH1]NBLIG -= 1
   Else
       WSVG_QTY             = [M:SDH1]QTY(LNOL)     : # 101874 : V9 : Taxe code control
       WSVG_QTYSTU          = [M:SDH1]QTYSTU(LNOL)  : # 101874 : V9 : Taxe code control
       [M:SDH1]QTY(LNOL)    = [F:SDD]QTY
       [M:SDH1]QTYSTU(LNOL) = [F:SDD]QTYSTU
   Endif

   # Pb : La classe [F:SDD] va être écrasée par le VALTTC
   [F:SDD1]=[F:SDD]
   # --- Valorisation TTC (idem calcul facture)
   Global Integer G_CLCDSPLIN : G_CLCDSPLIN=1
   # ACA - GESSDHF = GESSDH avec classe F deja remplie
   Local Char WGREP : WGREP=GREP
   GREP="C"

   # 101874 : V9 : Taxe code control
   # Valuation is always done in this case
   GVALTTC=2
   #---- Paramètres complementaires appel valorisation
   # PARAM_T(0) : Flag contrôle des taxes             (1=Non/2=Oui)
   # PARAM_T(1) : Lecture de la trace par le sous-pro (1=Non/2=Oui)
   # PARAM_T(2) : Flag retour                         (1=KO/2=OK)
   Local    Char     PARAM_T (25) (0..10)
   PARAM_T(0)="2"      : # Contrôle des taxes lors de la creation
   PARAM_T(1)="2"      : # Lecture de la trace
   PARAM_T(2)="0"
   Call VALTTC ("GESSDHF", PARAM_T) From TRTVENFACR
   If PARAM_T(2)="1"
      If LQTYSTU<>0
          [M:SDH1]QTY(LNOL)    = WSVG_QTY
          [M:SDH1]QTYSTU(LNOL) = WSVG_QTYSTU
      Endif
      GOK=0 : Return
   Endif
   #Call VALTTC("GESSDHF") From TRTVENFACR
   # 101874
   GREP=WGREP

   # Pb : La classe [F:SDD] a été écrasée par le VALTTC
   [F:SDD]=[F:SDD1]

   #----------------------------------------------------------------#
   # Modification des enregistrements sans SVCRVAT et SVCRFOOT      #
   #----------------------------------------------------------------#
   Call UPD_VALORISATION ("M","SDH") From TRTVENFACC
   If GOK<1 Return Endif

   [F:SDH]DLVNOT += DELTAQTY * [F:SDD]NETPRINOT
   [F:SDH]DLVATI += DELTAQTY * [F:SDD]NETPRIATI

   # Bug 72072
   # --> Calcul poids net et brut
   If   [F:SDD]WEU <> [F:SDH]WEU
       If clalev([F:TCO]) = 0 Local File TABCOEFF [TCO] : WOUV=1 Endif
       Read [TCO]TCO0=[F:SDD]WEU;[F:SDH]WEU
       If fstat=0
          COEF = [F:TCO]COEUOM
       Else
          Read [TCO]TCO0=[F:SDH]WEU;[F:SDD]WEU
          If fstat=0 & [F:TCO]COEUOM<>0
              COEF = 1/[F:TCO]COEUOM
          Endif
       Endif
       If COEF = 1  WLINWEI = [F:SDD]UNTWEI*DELTAQTY
       Else         WLINWEI = [F:SDD]UNTWEI*DELTAQTY*COEF
                    Call QTEARR(WLINWEI, [F:SDH]WEU) From TRTDIV
       Endif
       If WOUV=1 Close Local File [TCO] : Raz WOUV Endif
   Else WLINWEI = [F:SDD]UNTWEI*DELTAQTY
   Endif

   [F:SDH]NETWEI += WLINWEI
   [F:SDH]GROWEI += WLINWEI
   [M:SDH2]NETWEI = [F:SDH]NETWEI
   [M:SDH2]GROWEI = [F:SDH]GROWEI

   [F:SDH]DSPTOTQTY += DELTAQTYSTU
   [F:SDH]DSPTOTWEI += WDSPLINWEI
   [F:SDH]DSPTOTVOL += WDSPLINVOL
   # Bug 72072

   [M:SDH1]DLVNOT = [F:SDH]DLVNOT : # 92719

   # 40127 : Return status management
   # Alimentation number of returned lines
   [F:SDH]RTNLINNBR += WRTNLINNBR

   # Alimentation returned status
   If [F:SDH]RTNLINNBR >= [F:SDH]LINNBR : [F:SDH]RTNSTA = 3
   Else
       Filter [SDD1] Where SDHNUM=[F:SDD]SDHNUM & SDDLIN<>[F:SDD]SDDLIN & RTNQTYSTU<>0
       Read [SDD1]SDD0 First
       If fstat = 0
          [F:SDH]RTNSTA=2
       Else
          If [F:SDH]RTNLINNBR  = 0 & [F:SDD]RTNQTYSTU=0
              [F:SDH]RTNSTA = 1
          Else
              [F:SDH]RTNSTA = 2
          Endif
       Endif
       Filter [SDD1]
   Endif
   [M:SDH1]RTNSTA = [F:SDH]RTNSTA
   # 40127

   Rewrite [SDH]
Endif
If fstat GOK=0 : Call FSTA("SDH") From GLOCK : Return Endif

#--- Si annulation d'une ligne de BL issue d'un BP
#--- positionnement du flag 'annulé' dans la ligne de BP
If [F:SDD]PRHNUM<>""
   If LQTYSTU = 0
      TRTLIG = "A"
      Gosub MAJLIGPRE From SUBSDHA
      If GOK <= 0  Return  Endif
   Endif
Endif

# La livraison est-elle issue de bons de préparation ?
For [PRH]PRH1 Where STOFCY=[F:SDH]STOFCY & DLVFLG=3 & SDHNUM=[F:SDH]SDHNUM
   Raz I
   For [PRE]PRE0 Where PRHNUM=[F:PRH]PRHNUM & FLGANN=0
      # Il y a au moins une ligne non annulée sur le BP
      I+=1 : Break
   Next
   Readlock [PRH] Curr
   If fstat = 1
      GOK=-1 : GLOCK="$STOPREH"-[F:PRH]PRHNUM : Break
   Elsif fstat
      GOK=0  : Call RSTA ("PRH",[F:PRH]PRHNUM) From GLOCK : Break
   Endif
   # S'il n'y a pas de ligne non annulée
   # Le BP devient annulé, suppression du no de livraison
   If I=0
     [F:PRH]DLVFLG = 4
     [F:PRH]SDHNUM = ""
     Rewrite [PRH]
     If fstat GOK=0 : Call FSTA("PRH") From GLOCK : Break : Endif
   Endif
Next
If GOK<1 Return Endif

#-- Maj de la commande (si nécessaire)
#-- Sorder, Sorderq, (Sorderc), Orders, Bpcustmvt
If [F:SDD]SOHNUM <> ""
   If DELTAQTY <> 0
      If LQTYSTU = 0 TRTLIG = "A"
      Else           TRTLIG = "M"
      Endif
      Raz [M:ALP]DESQTY, [M:ALP]DESQTYSHT
      # Gestion des signatures
      # --> Il faut lire la cde pour savoir si on peut la réallouer en cas de modif/suppression
      If [F:SOH]SOHNUM<>[F:SDD]SOHNUM
          Read [SOH]SOH0=[F:SDD]SOHNUM
          If fstat
             Call RSTA ("SOH",[F:SDD]SOHNUM) From GLOCK
             GOK=0 : Return
          Endif
      Endif
      # Gestion des signatures cdes
      # Si Cde non signée et pas d'encours si cde non signée ou pas d'allocation si cde non signée on ne va pas réallouer
      WGALLORD=GALLORD
      If [F:SOH]APPFLG<3 & (GSOHAPPORD=1 | GSOHAPPALL=1) WGALLORD=1 Endif
      Gosub MAJLIGCDE From SUBSDHA
      If GOK < 1 Return Endif

      # Maj de l'en-cde client dans les mouvements article
      # --> Si cde signée ou Si paramètre maj encours article cde non signée à Oui
# 92719 : Pb update ITMMVT : No update if the item is not managed in stock
#      If [F:SOH]APPFLG>2 | GSOHAPPORD=2
      If ([F:SOH]APPFLG>2 | GSOHAPPORD=2) & [F:SOQ]STOMGTCOD <> 1
# 92719
          #--- Bug 31537
          # La ligne de cde est soldée
          If [F:SOQ]SOQSTA=3
             # Elle était déjà soldée --> pas de maj d'en commande
             If WSOQSTA = 3
                WSALSTU = 0
             # Elle n'était pas soldée --> en cde diminue de qté cde - ancienne qte liv
             Else
                WSALSTU = [F:SOQ]QTYSTU-([F:SOQ]DLVQTYSTU-DELTAQTYSTU)
             Endif
          # La ligne de cde n'est pas soldée
          Else
             # Elle était soldée --> en cde augmente de la qte cde - nouvelle qte liv
             If WSOQSTA = 3
                WSALSTU = -1*([F:SOQ]QTYSTU-[F:SOQ]DLVQTYSTU)
             # Elle n'était pas soldée --> en cde diminue ou augmente du delta de qte
             Else
                WSALSTU = DELTAQTYSTU
             Endif
          Endif
          Call MAJITVVEN([F:SDD]ITMREF,[F:SDD]STOFCY,WSALSTU,"-","S",WRET) From TRTVENMAJ
          If GOK < 1 Return Endif
      Endif
      #--------------

   Endif
Endif

# Maj sf si livraison intra-société
# Maj sf si livraison pour sous-traitance (Bug 52920)

# X3-1152 : Non invoiceable deliveries
#If !([F:SDH]BETFCY=2 & [F:SDH]BETCPY=1) &  !(dim([M:SDH0]SCO)>0 & [M:SDH0]SCO=2)
If !([F:SDH]BETFCY=2 & [F:SDH]BETCPY=1) &  !(dim([M:SDH0]SCO)>0 & [M:SDH0]SCO=2)
&   & ![M:SDH0]SDHCAT=4
# X3-1152 : Non invoiceable deliveries
    # Maj mouvement client (livré non facturé)
    WLIVTTC = DELTAQTY * [F:SDD]NETPRIATI
    WSENS = "+"
    If WLIVTTC < 0
       WLIVTTC = (-1)*WLIVTTC
       WSENS   = "-"
    Endif
    Call MAJMVC ([F:SDH]BPCORD, [F:SDH]CUR, [F:SDH]CHGTYP, 0, [F:SDH]SHIDAT, [F:SDH]SDHNUM, [F:SDH]SALFCY,
&                0, WLIVTTC, WSENS, "D", "", [F:SDH]LND) From TRTBPMVT
    If GOK < 1 Return Endif
Endif

GRELITSDH  = 1
GRELITSDH2 = 1

# 105502 : Pb recalcul de la répartition des élts de facturation sur les lignes
# Le recalcul est réalisé dans VALTTC mais il n'est pas stocké
# Si la livraison n'a pas été supprimé il faut stocker la nouvelle répartition
If [F:SDH]LINNBR <> 0
    # Mise à jour de la Répartition des élements de facturation dans les tables des lignes

    # Ini SAM 107649 (SOH or SDH dimension is major than SIH - JUCON 27/01/2017)
    If G_VALSFL+1>func AFNC.ACTIV("SIH")
      GMESSAGE=mess(547,192,1) # Activity codes SOH or SDH have a dimension major than SIH. SIH must be incremented
      Call ECR_TRACE(GMESSAGE-":"-[F:SDD]SDHNUM+num$([F:SDD]SDDLIN),0) From GESECRAN
      Raz GMESSAGE
      GOK=0: Return
    Endif
    # End SAM 107649 (SOH or SDH dimension is major than SIH - JUCON 27/01/2017)

    If G_VALSFL>0
        If sum([M:SIHV]DDTANOT01(0..G_VALSFL-1),[M:SIHV]DDTANOT02(0..G_VALSFL-1),[M:SIHV]DDTANOT03(0..G_VALSFL-1))<>0 |
&          sum([M:SIHV]DDTANOT04(0..G_VALSFL-1),[M:SIHV]DDTANOT05(0..G_VALSFL-1),[M:SIHV]DDTANOT06(0..G_VALSFL-1))<>0 |
&          sum([M:SIHV]DDTANOT07(0..G_VALSFL-1),[M:SIHV]DDTANOT08(0..G_VALSFL-1),[M:SIHV]DDTANOT09(0..G_VALSFL-1))<>0
            nolign=1
            # On doit travailler avec l'abréviation SDD car UPD_DSPLIN travaille avec SDD
            Filter [SDD] Where SDHNUM = [F:SDH]SDHNUM
            For [SDD]
                Readlock [SDD] Curr
                If    fstat=1 : GOK=-1 : GLOCK="$SDELIVERYD"+[F:SDD]SDHNUM+num$([F:SDD]SDDLIN) : Break
                Elsif fstat   : GOK=0  : Call RSTA("SDD",[F:SDD]SDHNUM+num$([F:SDD]SDDLIN)) From GLOCK : Break
                Endif
                # --- Stockage a la ligne des elt de facturation
                Call UPD_DSPLIN("SDD",nolign-1) From TRTVENFACC
                Rewrite [SDD]
                If fstat GOK=0 : Call FSTA("SDD") From GLOCK : Break : Endif
                nolign+=1
            Next
            Filter [SDD]
            If GOK<0 Return Endif
        Endif
    Endif
Endif
# 105502

# Maj des zones écran pour réaffichage
If [F:SDH]LINNBR = 0
   Raz [M:SDH0], [M:SDH1], [M:SDH2]
   Affzo [M:SDH0]1-99 : Affzo [M:SDH3]1-99 : # Bug 63221
Endif
Affzo [M:SDH2]1-99     : # Bug 72072
Affzo [M:SDH1]1-99     : # 92719
Affzo [M:SDH1]RTNSTA   : # 40127 : Return status management

#Elsif LQTYSTU=0
#   Dela LNOL,1,[M:SDH1]NBLIG-1 [M:SDH1]NBLIG
#   [M:SDH1]NBLIG -= 1
#Else
#   [M:SDH1]QTY(LNOL)    = [F:SDD]QTY
#   [M:SDH1]QTYSTU(LNOL) = [F:SDD]QTYSTU
#Endif
Return
####################################################################
# Issue X3-44998 - 2017-07-27 by CPO : Duplicated sale documents: analytical dimension not controlled (idem X3SUIVI93839)
$VERIF_CTL_ALLCCE
Local Integer NE
Local Char    SAXECTRL(GLONCCE)

  If dim([M:SDH3]CCE)>0
    # -------------------------------------
    For I = 0 To [M:SDH3]NBAXE-1
      If [M:SDH3]CCE(I) <> "" Then
        nolign = I + 1
        Call C_CCE([M:SDH3]CCE(I)) From W1SDH3
        If mkstat Then
          OK = 0
          Break
        Endif
      Endif
    Next
    If OK = 0 Then
      Return
    Endif
  Endif

  For I=0 To [M:SDH1]NBLIG-1
     For NE = 1 To 20
       If evalue("type([M:SDH1]CCE" + num$(NE) + "(I)) >= 0") Then
         SAXECTRL = evalue("[M:SDH1]CCE" + num$(NE) + "(I)")
         If SAXECTRL <> "" Then
           nolign = I + 1
           #--for the ENAFLG flag
           Call CONTSEL("CCE","!",SAXECTRL,num$(GDIE(NE)),mkstat) From CONTOBJ
           If !mkstat
             Call CTRL_CCE(SAXECTRL, NE, "", GFINRSP, [M]SHIDAT) From TRTX3CPT
           Endif
           If mkstat Then
             OK = 0
             GMESSAGE = mess(162,154,1)-[M:SDH1]ITMREF(I)-":"-GMESSAGE
             Break
           Endif
         Endif
       Endif
     Next NE
     If OK = 0 Then
       Break
     Endif
  Next
  If OK = 0 Then
    Return
  Endif

Return
# End issue X3-44998

