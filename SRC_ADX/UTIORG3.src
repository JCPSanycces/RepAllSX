#<AdxTL>@(#)4.0.0.0 $Revision$
#CHECK MIGRATE_SOURCE
################################################################################
# Mise à jour des objets relatifs aux organismes et caisses de cotisations     #
################################################################################

##################################################################
#Comments(1)                                                     #
# Manips à faire                                                 #
#   1. Remplacer UTIXXX par le nom de votre programme            #
#   2. Action OUVRE_TRACE : mettre un titre                      #
#   3. cf Comments(2)                                            #
#   4. cf Comments(3)                                            #
##################################################################

Local Char DOSSIER(30)
DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTIORG3: Mise à jour des objets relatifs aux organismes et caisses de cotisations") From LECFIC
 Call EXE_UTIORG3(DOSSIER)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

###################################################################################################
#Comments(2)                                                                                      #
# Pour exécution automatique en gestion de patch de EXE_UTIXXX                                    #
#   1. Ne pas faire de ouvre_trace/ferme_trace/lec_trace dans cette partie de programme           #
#      (le fichier trace est déjà ouvert / l'intégration de patch peut se faire en batch )        #
#                                             
#   2. Pour les ecr_trace :                                                                       #
#         Utiliser des messages avec l'instruction mess(nnn,ccc,1) ou alors des textes en anglais #
#                                             
#   3. Attention à la déclaration des fichiers : pensez que le client n'a pas forcémment activer  #
#      tous les modules dans ses dossiers
#                                             
#   4. Attention aux moulinettes sur de gros volumes (Erreur Rollback en Oracle)                  #
###################################################################################################

Subprog EXE_UTIORG3(APPLI)
Value Char APPLI
Local Integer OK ,I, J
Local Char CODOBJ (5) (0..2)

Call ECR_TRACE("UTIORG3: Process Start on : "+APPLI,0) From GESECRAN

#### Corps de la moulinette - début

Local File =APPLI+".AOBJLST" [AOL]

Call DEBTRANS From GLOCK
Gosub MAJOBJ

#### Corps de la moulinette - fin 

Call ECR_TRACE("UTIORG3: Process End on : "+APPLI,0) From GESECRAN

Close Local File [AOL]
End


$MAJOBJ
CODOBJ(0)="ORG" : CODOBJ(1)="ORA" : CODOBJ(2)="DUC"

For I=0 To 2
 Trbegin [AOL]
 GOK = 1
 Readlock[F:AOL]AOL0=CODOBJ(I)
 If !fstat
  # on efface
  Raz [F:AOL]SELZON
  Raz [F:AOL]SELFIC
  Raz [F:AOL]SELEXP
  Raz [F:AOL]SELINT
  Raz [F:AOL]SELTYP
  Raz [F:AOL]SELSAI
  Raz [F:AOL]SELLNG
  #Et on recommance
  Case I
   When 0, 1 : Gosub ORGSEL
   When 2 : Gosub DUCSEL 
  Endcase 
  Rewrite [F:AOL]
  If fstat
   GOK = 0 : Call FSTA("AOL") From GLOCK
  Endif
  If GOK
   Call VALID(CODOBJ(I),APPLI,0,OK) From VALOBJ
   CODOBJ(I)="O"+CODOBJ(I)
   Call VALID(CODOBJ(I),APPLI,0,OK) From VALWIN
  Endif 
 Endif
 If !GOK : Goto AB_MAJOBJ : Endif
 Commit
Next I
Return

$AB_MAJOBJ
Rollback
Return

#Liste de gauche ORG & ORA
#############################
$ORGSEL
[F:AOL]NBSEL=4
#Code
[F:AOL]SELZON(0)="COD"
[F:AOL]SELFIC(0)="ORGANISME"
[F:AOL]SELINT(0)=1071
#Desig
[F:AOL]SELZON(1)="DES"
[F:AOL]SELFIC(1)="ORGANISME"
[F:AOL]SELINT(1)=8
#Nature
[F:AOL]SELEXP(2)="string$([F:ORG]TYPIRC<>0,mess([F:ORG]TYPIRC,386,1))"
[F:AOL]SELINT(2)=8213
[F:AOL]SELTYP(2)="A"
[F:AOL]SELLNG(2)=15
#Type
[F:AOL]SELZON(3)="TYP"
[F:AOL]SELFIC(3)="ORGANISME"
[F:AOL]SELINT(3)=273
Return

#Liste de gauche DUC
#############################
$DUCSEL
[F:AOL]NBSEL=3
#Code
[F:AOL]SELZON(0)="CAI"
[F:AOL]SELFIC(0)="PRMDUCS"
[F:AOL]SELINT(0)=8213
#Desig
[F:AOL]SELZON(1)="CPY"
[F:AOL]SELFIC(1)="PRMDUCS"
[F:AOL]SELINT(1)=653
#
[F:AOL]SELZON(2)="FCYDCL"
[F:AOL]SELFIC(2)="PRMDUCS"
[F:AOL]SELINT(2)=3511
Return


###################################################################################################
#Comments(3)                                                                                      #
# Pour exécution automatique  en gestion de patch                                                 #
#   1. Si le traitement ne doit pas s'éxécuter dans le dossier X3 (moulinette applicative)        #
#        ==> Décocher la ligne 1                                                                  #
#                                                                                                 #
#   2. Si le traitement doit s'éxécuter uniquement dans les dossiers ayant activé un module donné #
#        ==> Décocher la ligne 2  et renseigner le n° de module                                   #
#            attention à la numérotation du module qui commence à 0 :                             #
#             (0=superviseur / 1= compta / 2= tiers ... etc ... )                                 #
###################################################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If filinfo(filpath("FIL","AOBJLST","fde",APPLI),0)<=0 : End : Endif  
Call EXE_UTIORG3(APPLI)
End





