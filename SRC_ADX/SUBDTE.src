#** #############################################################################################
#* Obtain and writes the BP account data
#*! #############################################################################################
$WRITEBPACCOUNTDATA
Local Char BPACC(30)
Local Integer TRACECOUNTER
Local Char BPTYPESTRINGEXP(30), BPTYPESTRING(30)

    Gosub BPQUERY

    If BPTYPEFLAG = 1 : BPTYPESTRING = mess(10,3653,1) : BPTYPESTRINGEXP = mess(12,3653,1) : Else : BPTYPESTRING = mess(9,3653,1) : BPTYPESTRINGEXP = mess(13,3653,1) : Endif
    Call ECR_TRACE("------" - BPTYPESTRING, 0) From GESECRAN

    For [LNK]
        If func FORCOMPANY([BPR]BPRNUM, [M:DTE]CPY, [L]BPTYPEFLAG)
          BPACC = [BPR]BPRNUM
          Call TREATACCOUNT(BPACC, 2, MAINCOA)

          Call INITLINES([L]BPACCOUNTS, [L]BPACCOUNTTEXTINDEX)
          [L]BPACCOUNTS(0) = func GETFORMATEDVALUE(BPACC,9,0,[L]BPACCOUNTTEXTINDEX)
          [L]BPACCOUNTS(1) = func GETFORMATEDVALUE([BPR]BPRNAM,50,1,[L]BPACCOUNTTEXTINDEX)
          [L]BPACCOUNTS(8) = func GETFORMATEDVALUE([BPR]CRY,2,8,[L]BPACCOUNTTEXTINDEX)

          # SAM #115165 split EECNUM, angre 17.03.16
          If len([BPR]EECNUM) > 2
            [L]BPACCOUNTS(8) = func GETFORMATEDVALUE(left$([BPR]EECNUM,2),2,8,[L]BPACCOUNTTEXTINDEX)
            [L]BPACCOUNTS(9) = func GETFORMATEDVALUE(right$([BPR]EECNUM,3),13,9,[L]BPACCOUNTTEXTINDEX)
          Endif
          [L]BPACCOUNTS(15) = func GETFORMATEDVALUE([BPA]BPAADDLIG,36,15,[L]BPACCOUNTTEXTINDEX)
          [L]BPACCOUNTS(17) = func GETFORMATEDVALUE([BPA]POSCOD,10,17,[L]BPACCOUNTTEXTINDEX)
          [L]BPACCOUNTS(18) = func GETFORMATEDVALUE([BPA]CTY,30,18,[L]BPACCOUNTTEXTINDEX)
          [L]BPACCOUNTS(19) = func GETFORMATEDVALUE([BPA]CRY,2,19,[L]BPACCOUNTTEXTINDEX)
          Gosub SETBANKDATA
          Gosub SETINVOICEADDRESS
          Call WRITELINE(BPACCOUNTS)
          TRACECOUNTER += 1
        Endif
    Next
    #Call ECR_TRACE("Es wurden " + num$(TRACECOUNTER) - BPTYPESTRING - "exportiert", 0) From GESECRAN
    Call ECR_TRACE(BPTYPESTRINGEXP + ":" -  num$(TRACECOUNTER),0) From GESECRAN
Return


#check if bpnumber is valid for a company
Funprog FORCOMPANY(NUM, COMP, BPTYPE)
Value Char NUM, COMP
Value Integer BPTYPE
Local Integer RESULT
  If (BPTYPE = 2 and [M:DTE]FLGBPCCPY <> 2) or (BPTYPE = 1 and [M:DTE]FLGBPSCPY <> 2) : RESULT = 1 : End RESULT : Endif
  # Issue 56229 - 2017-11-15 by MWA
  If func ASYRFNC.ACTIV("MUL") >0
    Filter  [F:BPE] Where [F:BPE]BPRNUM = NUM and [F:BPE]CPY = COMP and [F:BPE]ACEAUZ <> 2
    If rowcount([F:BPE]) = 0
      RESULT = 1
    Endif
    Filter [F:BPE]
  Else
    RESULT = 1   : # Issue 56229 - 2017-11-15 by MWA
  Endif
End RESULT

#** #############################################################################################
#* Sets Bank data
#* #*! #############################################################################################
$SETBANKDATA

        Link [F:BID] With
&       [F:TCY]TCY0 = [F:BID]CRY
&        As [LNKB]
&        Where [BID]BIDNUM = [BPR]BIDNUM
&       & [F:BID]BIDNUMFLG = 2


        For [LNKB]
        [L]BPACCOUNTS(41) = func GETFORMATEDVALUE([BID]PAB1,30,41,[L]BPACCOUNTTEXTINDEX)
        [L]BPACCOUNTS(43) = func GETFORMATEDVALUE([TCY]ISO,2,43,[L]BPACCOUNTTEXTINDEX)
        [L]BPACCOUNTS(46) = func GETFORMATEDVALUE([BID]BICCOD,11,46,[L]BPACCOUNTTEXTINDEX)
        [L]BPACCOUNTS(48) = func GETFORMATEDVALUE("1",1,48,[L]BPACCOUNTTEXTINDEX)
        #only if country with IBAN
        If [TCY]FLIBAN = 2
            [L]BPACCOUNTS(44) = func GETFORMATEDVALUE([BID]IBAN + [BID]BIDNUM,34,44,[L]BPACCOUNTTEXTINDEX)
        Endif
        Next

Return

#** #############################################################################################
#* Sets invoice address
#*! #############################################################################################
$SETINVOICEADDRESS
    If !clalev([F:BPA2])  : Local File BPADDRESS [BPA2]  : Endif
    If [L]BPTYPEFLAG = 1
        Link [BPS] With
&        [BPA2]BPA0(1) = 1; [BPS]BPSNUM
&        As [LNK2]
&        Where [BPS]BPSNUM = [BPR]BPRNUM
& &     [BPA2]BPAADD = [BPS]BPAINV

    Elsif [L]BPTYPEFLAG = 2
        Link [BPC] With
&        [BPA2]BPA0(1) = 1; [BPC]BPCNUM
&        As [LNK2]
&        Where [BPC]BPCNUM = [BPR]BPRNUM
& &     [BPA2]BPAADD = [BPC]BPAINV
    Endif
        For [LNK2]
            [L]BPACCOUNTS(153) = func GETFORMATEDVALUE([BPA2]BPAADDLIG,36,153,[L]BPACCOUNTTEXTINDEX)
            [L]BPACCOUNTS(155) = func GETFORMATEDVALUE([BPA2]POSCOD,10,155,[L]BPACCOUNTTEXTINDEX)
            [L]BPACCOUNTS(156) = func GETFORMATEDVALUE([BPA2]CTY,30,156,[L]BPACCOUNTTEXTINDEX)
            [L]BPACCOUNTS(157) = func GETFORMATEDVALUE([BPA2]CRY,2,157,[L]BPACCOUNTTEXTINDEX)
        Next

Return


#** #############################################################################################
#* Builds the query for BP Suppliers
#*
#*! #############################################################################################
$BPQUERY
Local Char FILTERSTRING(255)
#Local File BPEXCEPT [BPE]

  #FILTERSTRING = "[BPR]BPCFLG = 2 & [F:BPA]BPAADD = [F:BPR]BPAADD"
  If BPTYPEFLAG = 1
    FILTERSTRING = "[BPR]BPSFLG = 2 & [F:BPA]BPAADD = [F:BPR]BPAADD"
    If [M:DTE]FLGBPSACT = 2
      FILTERSTRING += " & [F:BPS]ENAFLG = 2 "
    Endif

   Link [BPR] With
&  [F:BPA]BPA0(1)  = 1;[F:BPR]BPRNUM
&, [F:BPS]BPS0 = [F:BPR]BPRNUM
& As [LNK]
& Where evalue(FILTERSTRING)


  Elsif BPTYPEFLAG = 2

  FILTERSTRING = "[BPR]BPCFLG = 2 & [F:BPA]BPAADD = [F:BPR]BPAADD"
  If [M:DTE]FLGBPCACT = 2
      FILTERSTRING += " & [F:BPC]BPCSTA = 2 "
  Endif

  Link [BPR] With
&  [F:BPA]BPA0(1)  = 1;[F:BPR]BPRNUM
&, [F:BPC]BPC0 = [F:BPR]BPRNUM
& As [LNK]
& Where evalue(FILTERSTRING)



  Endif

Return


#** #############################################################################################
#* Obtain and writes the GL account data
#*! #############################################################################################
$WRITEGLACCOUNTDATA
# COA = MAINCOA
Local Char FILTERSTRING(30)
Local Char GLACC(30)

    Call ECR_TRACE("-----" - mess(11,3653,1), 0) From GESECRAN

    If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif
    FILTERSTRING = "COA = MAINCOA"
    If [M:DTE]FLGGLACCACT = 2 : FILTERSTRING += " & ENAFLG = 2" : Endif
    Filter [F:GAC] Where evalue(FILTERSTRING)
    For [F:GAC]
        GLACC = [F:GAC]ACC
        Call TREATGLACCOUNT(GLACC, MAINCOA)

        Call INITLINES(GLACCOUNTS, GLACCOUNTTEXTINDEX)
        [L]GLACCOUNTS(0) = func GETFORMATEDVALUE(GLACC,8,0,[L]GLACCOUNTTEXTINDEX)
        [L]GLACCOUNTS(1) = func GETFORMATEDVALUE([F:GAC]DES,40,1,[L]GLACCOUNTTEXTINDEX)
        # GLACCOUNTS(2) empty at the moment


        Call WRITELINE(GLACCOUNTS)
    Next
    #write info to tracefile

    #Call ECR_TRACE("Es wurden " + num$(rowcount([F:GAC])) - "Sachkonten für den Kontenplan " + MAINCOA - "exportiert", 0) From GESECRAN
    Call ECR_TRACE(mess(14,3653,1) + ":" - num$(rowcount([F:GAC])),0) From GESECRAN
    Filter [F:GAC]
Return


#** #############################################################################################
#* Initalize, fills and write the header line for a given Datatype
#* @param Variable Char() HEADERLINE  Header line fields in a Char array
#* @param Variable Integer() TEXTINDEX  Indexes of Textfields in the Headerline
#* @param DATATYPE Value Integer 1=>impersonal accounts; 2=>BP accounts; 3=>Journal entries
#*! #############################################################################################
Subprog WRITEHEADER(HEADERLINE,TEXTINDEX,DATATYPE, GLACCOUNTLENGTH)
Variable Char HEADERLINE
Variable Integer TEXTINDEX
Value Integer DATATYPE
Value Integer GLACCOUNTLENGTH
    Call INITLINES(HEADERLINE, TEXTINDEX)
    Call FILLHEADERLINE(HEADERLINE, DATATYPE, GLACCOUNTLENGTH)
    Call WRITELINE(HEADERLINE)
End


#** #############################################################################################
#* Fills a Char array that contains the field for the header line for a given Datatype
#* @param Variable Char() HEADERLINE  Header line fields in a Char array
#* @param DATATYPE Value Integer 1=>impersonal accounts; 2=>BP accounts; 3=>Journal entries
#*
#*! #############################################################################################
Subprog FILLHEADERLINE(HEADERLINE, DATATYPE, GLACCOUNTLENGTH)
Variable Char HEADERLINE
Value Integer DATATYPE
Value Integer GLACCOUNTLENGTH
    Call FILLCOMMONHEADERDATA(HEADERLINE, GLACCOUNTLENGTH, DATATYPE)
    Case DATATYPE
        When 1
            HEADERLINE(2) = "20" : HEADERLINE(3) = '"Kontenbeschriftungen"'
        When 2
            HEADERLINE(2) = "16" : HEADERLINE(3) = '"Debitoren/Kreditoren"'

        When 3
            HEADERLINE(2) = "21" : HEADERLINE(3) = '"Buchungsstapel"'
            HEADERLINE(14) = func GETDATEASSTRING([M:DTE]DATSTR,1) : HEADERLINE(15) = func GETDATEASSTRING([M:DTE]DATEND,1)
    Endcase
End

#** #############################################################################################
#* Writes the common data for the header line in the given Char array
#* @param Variable Char() HLINE  Header line fields in a Char array
#*! #############################################################################################
Subprog FILLCOMMONHEADERDATA(HLINE, GLACCOUNTLENGTH,DATATYPE)
Variable Char HLINE
Value Integer GLACCOUNTLENGTH
Value Integer DATATYPE
    HLINE(0)='"EXTF"': HLINE(1)= "510" : HLINE(5) = func GETCURRENTDATETIME() : HLINE(7) = '"X3"'
    HLINE(10) = num$([M:DTE]ACCNO) : HLINE(11) = num$([M:DTE]CLIENTNO) : HLINE(12) = func GETFISCALYEAR() : HLINE(13) = num$(GLACCOUNTLENGTH)
    HLINE(18) = "1"
    Case DATATYPE
        When 1
            HLINE(4)= "2"
        When 2
            HLINE(4)= "4"
        When 3
            HLINE(4)= "7"
    Endcase

End

#** #############################################################################################
#* Writes one line in the opened file. Each value in the given Char array is a field in the line
#* @param Variable Char() Line  Line field in a Char array
#*! #############################################################################################
Subprog WRITELINE(LINE)
Variable Char LINE
Local Integer I
For I = 0 To dim(LINE) -1
      If I = dim(LINE) -1
        Wrseq LINE(I) Using [YYY]
      Else
        Wrseq LINE(I); Using [YYY]
      Endif
    Next
End

#** #############################################################################################
#* Opens the file for a given datatype
#* @param DATATYPE Value Integer 1=>impersonal accounts; 2=>BP accounts; 3=>Journal entries
#*! #############################################################################################
Subprog OPENFILE(DATATYPE, EXPORTNAME, EXPORTFILE, URL)
Variable Char EXPORTNAME
Variable Char EXPORTFILE
Variable Char URL
Value Integer DATATYPE
Local Char FILENAMETR(GDIMFIC)
Local Integer FILEEXISTS


      FILENAMETR = func GETFILENAME(DATATYPE)

    If [M]TYPEXP = 1 : # Client
        EXPORTNAME = FILENAMETR
        EXPORTFILE = [M]DIRDATFIL
        Call SET_FICNAM( FILENAMETR, EXPORTFILE, URL) From ORDSYS
        FILENAMETR= EXPORTFILE
    Else # Server
        FILENAMETR = [M]DIRDATFIL
&                  + func GDPDU1.GETDIRSEPARATOR()
&                  + FILENAMETR

        # Validate file path in server mode.
        Call EXISTE( FILENAMETR, FILEEXISTS ) From ORDSYS
        If FILEEXISTS = 1
            Call OUINONT( mess(260,107,1) + chr$(10) + func CNSRSGSTDLIB.REPLACE( FILENAMETR, "\", "/" ), YESNO ) From GESECRAN # "Data already exists.\Do you want to overwrite it?"
            If YESNO = 1 # No --> Cancel.
                End
            Endif
        Endif
    Endif

  Openo FILENAMETR, 0 Using [YYY]
  adxirs = chr$(13) + chr$(10)
  adxifs = ";"
End

#** #############################################################################################
#* Sets main plan code and main ledger for a given company
#* @param COMPANY Value Char
#* @param MAINCOA Variable Char
#* @param MAINLED Variable Char
#*! #############################################################################################
Subprog GETCOMPANYDATA(COMPANY, MAINCOA, MAINLED, MAINCOSTLED)
Value Char COMPANY
Variable Char MAINCOA
Variable Char MAINLED, MAINCOSTLED
Local Char ACM(GLONGCM): ACM = ""      # Accounting core model ID
    Read [CPY]CPY0 = COMPANY
    If !fstat
      ACM = [CPY]ACM
      Read [GCM]GCM0 = ACM
      If !fstat
          MAINLED = [GCM]LED( [GCM]GENLEDTYP - 1 )
          LEDINDEX = [F:GCM]GENLEDTYP - 1
          MAINCOSTLED = [GCM]LED([GCM]ANALEDTYP - 1 )
          Read [LED]LED0 = MAINLED
          If !fstat
              MAINCOA = [LED]COA
          Endif
      Endif
    Endif
End

#** #############################################################################################################
#*Returns the Filepath (including the filename) depending on the parameter DATATYPE
#*
#* @param  DATATYPE Value Integer 1=>impersonal accounts; 2=>BP accounts; 3=>Journal entries
#* @return CHAR(255)
#*! #############################################################################################################
Funprog GETFILEPATH(DATATYPE)
Value Integer DATATYPE

End func GETDIRECTORY + func GETFILENAME(DATATYPE)

#** #############################################################################################
#* Generates the filename depending on the type of data to write
#*! #############################################################################################
Funprog GETFILENAME(DATATYPE)
Value Integer DATATYPE
Local Char FILENAM(255) : FILENAM = "EXTF_"
Local Char FILEEND(30) : FILEEND = "_" + format$( "D:YYYY[-]MM[-]DD", date$ ) + "_" + num$(time)+".csv"
  Case DATATYPE
      When 1 : FILENAM = FILENAM + "SKBeschrift" + FILEEND
      When 2 : FILENAM = FILENAM + "GP_Stamm" + FILEEND
      When 3 : FILENAM = FILENAM + "Buchungsstapel" + FILEEND
  Endcase
End FILENAM



#** #############################################################################################################
#*Returns the Directory with valid seperator
#*
#* @return  Char(255) DIR
#*
#*! #############################################################################################################
Funprog GETDIRECTORY()
Local Char DIRSEP(30) : DIRSEP = func GDPDU1.GETDIRSEPARATOR()
Local Char DIR(255) : DIR = [M:DTE]DIRDATFIL
    If right$( DIR, len( DIR ) ) <> DIRSEP
        DIR += DIRSEP
    Endif
End DIR



#** #############################################################################################################
#*
#* Returns the file directory for the CSV file
#* This directory is declared as parameter XEDATFILPAT
#*
#* @return  Char(255) Result       file directory
#*! #############################################################################################################
Funprog GETDIRPARAM(COMP, PARAMNAME)
Value Char COMP
Value Char PARAMNAME
  If COMP <> ""
    Local Char RESULT(255)
    Call PARAM(COMP,PARAMNAME,RESULT) From ADOVAL
  Endif
End RESULT


Funprog GETDATEVHEADERLINE(DATATYPE)
Value Integer DATATYPE
   If DATATYPE <> 1
   Else
   Endif
End

#** #############################################################################################################
#*
#* Returns the beginning of the fiscal year of given company as char().
#* If no date range is entered the return value is the last fiscal year of the main legal ledger of the
#* company, else the return value is the fiscal year of the company where the date range fits in
#*
#* @return  Char(255) Result       Start date of the fiscal year
#*! #############################################################################################################
Funprog GETFISCALYEAR()
Local Date DAT : DAT = [0/0/0]
Local Char RESULT(30)
    If [M:DTE]DATSTR = [0/0/0] or [M:DTE]DATEND = [0/0/0]
        Filter [F:FIY] Where CPY = [M:DTE]CPY & LEDTYP = 1 & FIYSTA > 1 Order By FIYSTR Desc
    Else
        Filter [F:FIY] Where CPY = [M:DTE]CPY & LEDTYP = 1 & FIYSTA > 1 & FIYSTR <= [M:DTE]DATSTR & FIYEND >= [M:DTE]DATEND
    Endif
    For [F:FIY]
        DAT = [F:FIY]FIYSTR
    Next
    Filter [F:FIY]
    If DAT <> [0/0/0] : RESULT = func GETDATEASSTRING(DAT,1) : Endif
End RESULT


#** #############################################################################################################
#*
#* Function to get a given date as string. The format of the strign depends on parameter FORMATTYPE
#*
#* @param   DAT           Value Date      -> The date to transform in to a string
#* @param   FORMATTYPE    Value Integer   -> Indicates the format of the string. 1 -> YYMMDD; Else -> DDMM
#*
#* @return  RESULT        Local Char       The given date as string
#*! #############################################################################################################
Funprog GETDATEASSTRING(DAT, FORMATTYPE)
Value Date DAT
Value Integer FORMATTYPE
Local Char RESULT(30)
    If DAT = [0/0/0] #or DAT = [00/00/0000]
      End
    Endif
    If FORMATTYPE = 1
      RESULT  = num$(year(DAT)) + func ADD0TODIGIT(month(DAT)) + func ADD0TODIGIT(day(DAT))
    Elsif FORMATTYPE = 2
      RESULT =  func ADD0TODIGIT(day(DAT)) + func ADD0TODIGIT(month(DAT))
    Else
      RESULT = func ADD0TODIGIT(day(DAT)) + func ADD0TODIGIT(month(DAT)) + num$(year(DAT))
    Endif
End RESULT


#** #############################################################################################################
#*
#* Function to get the current date/time as string

#* @return  Datetime        Local Char  -> the current date/time in the format YYMMDDHHMMSS
#*! #############################################################################################################
Funprog GETCURRENTDATETIME()
Local Char DATTIME(30)
Local Char NOW(30) : NOW = time$
    DATTIME = num$(year(date$))+func ADD0TODIGIT(month(date$))+func ADD0TODIGIT(day(date$)) + left$(NOW,2) + seg$(NOW,4,5) + right$(NOW,7) + "017"
End DATTIME

#** #############################################################################################################
#*
#* Adds a leading zero to a number smaller than 10 and return it as char
#*
#* @param   Value Char Digit     Plan code
#*
#* @return  Char Result       number with a leading zero as string
#*! #############################################################################################################
Funprog ADD0TODIGIT(DIGIT)
Value Integer DIGIT
Local Char RESULT(30)
    RESULT = num$(DIGIT)
    If DIGIT < 10 and DIGIT > 0 : RESULT = "0"+RESULT : Endif
End RESULT

#** #############################################################################################################
#*
#* determine the length of the longest GL account for a given plan code
#*
#* @param   Value Char MCOA     Plan code
#*
#* @return  Integer Result       max length of GLACCOUNTS
#*! #############################################################################################################
Funprog GETGLACCOUNTLENGTH(MCOA)
Value Char MCOA
Local Integer RESULT
Local Char TYP(30)
Local Integer TMPLNG
Local Char SQLQUERY(255)

    If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
    Filter [F:GAC] Where [F:GAC]COA = MCOA

    For [GAC]
      TMPLND = len([GAC]ACC)
      If TMPLND > RESULT
        RESULT = TMPLND
      Endif
    Next

   Filter [F:GAC]
End RESULT

#** #############################################################################################################
#*
#* Function that formats the values before writing into file. If the value is expected as
#* string in the file, quotes are added
#*
#* @param   Value Char VLUE         Value to be formatted
#* @param   Value Char DIMENSION    max length
#* @param   Value Char INDEX        lineindex
#* @param   Value Char TEXTINDEX    Array where the lineindices for textvalues are stored
#*
#* @return  Char Result       formatted value
#*! #############################################################################################################
Funprog GETFORMATEDVALUE(VLUE, DIMENSION, INDEX, TEXTINDEX)
Value Char VLUE
Value Integer DIMENSION
Value Integer INDEX
Variable Integer TEXTINDEX()
Local Char STRINGWITHOUT(DIMENSION)
  STRINGWITHOUT = VLUE
  If find(INDEX, [L]TEXTINDEX(0..dim([L]TEXTINDEX)-1)) : DIMENSION += 2 : Endif
  Local Char RESULT(DIMENSION) : RESULT = STRINGWITHOUT
      If find(INDEX, [L]TEXTINDEX(0..dim([L]TEXTINDEX)-1)) : RESULT = '"' + STRINGWITHOUT + '"' : Endif
End RESULT

#** #############################################################################################################
#*
#* Suprog for treating the accounts depending on the entrys of the user
#*
#* @param   Variable Char ACCOUNT      Account
#* @param   Value Char ACCTYPE      Type of the account 1 => GL account; 2 => BPR account
#* @param   Variable Char MCOA        Plan code of the selected company
#*! #############################################################################################################
Subprog TREATACCOUNT(ACCOUNT, ACCTYPE, MCOA)
Variable Char ACCOUNT
Value Integer ACCTYPE
Value Char MCOA

    Case ACCTYPE
        When 1
            Call TREATGLACCOUNT(ACCOUNT, MCOA)
        When 2
            Call TREATBPACCOUNT(ACCOUNT)
        When Default
    Endcase
End


#** #############################################################################################################
#*
#* Suprog for treating the GL accounts depending on the entrys of the user
#*
#* @param   Variable Char GLACC       GL account
#* @param   Variable Char MCOA        Plan code of the selected company
#*! #############################################################################################################
Subprog TREATGLACCOUNT(GLACC, MCOA)
Variable Char GLACC
Variable Char MCOA
    If func GLFROMASSOCTABLE(GLACC,MCOA) = 1
        End
    Else
        Call GLACCLENGTHTREATMENT(GLACC)
        Call REMOVELEADINGZERO(GLACC)
    Endif
End

#** #############################################################################################################
#*
#* Suprog for treating the BPR accounts depending on the entrys of the user
#*
#* @param   Variable Char BPACC       BPR account
#*! #############################################################################################################
Subprog TREATBPACCOUNT(BPACC)
Variable Char BPACC

    If func BPFROMASSOCTABLE(BPACC)
        End
    Else
        Call BPACCLENGTHTREATMENT(BPACC)
    Endif
End

#** #############################################################################################################
#*
#* Suprog for treating selected changing of the length of a GL account (expanding or reducing a account)
#*
#* @param   Variable Char GLACC       GL account
#*! #############################################################################################################
Subprog GLACCLENGTHTREATMENT(GLACC)
Variable Char GLACC

    If  [M:DTE]FLGGLACCRED = 2
      If [M:DTE]GLACCREDDIR = 2 and [M:DTE]GLACCRED > 0
        Call EXPANDACCOUNT(GLACC,[M:DTE]GLACCRED)
      Elsif [M:DTE]GLACCREDDIR <> 2 and [M:DTE]GLACCRED > 0
        Call REDUCEACCOUNT(GLACC,[M:DTE]GLACCRED,[M:DTE]GLREDLEFT)
      Endif
    Endif

End

#** #############################################################################################################
#*
#* Suprog for treating selected changing of the length of a BPR account (reducing a account)
#*
#* @param   Variable Char BPACC       BPR account
#*! #############################################################################################################
Subprog BPACCLENGTHTREATMENT(BPACC)
Variable Char BPACC
    If [M:DTE]FLGBPACCRED = 2
      If [M:DTE]BPREDDIR = 2

        If [M:DTE]BPREDR = 2 and [M:DTE]BPACCREDR > 0
          Call EXPANDACCOUNT(BPACC,[M:DTE]BPACCREDR)
        Endif
      Elsif [M:DTE]BPREDDIR <> 2
        If [M:DTE]BPREDL = 2 and [M:DTE]BPACCREDL > 0
          Call REDUCEACCOUNT(BPACC,[M:DTE]BPACCREDL,2)
        Endif
        If [M:DTE]BPREDR = 2 and [M:DTE]BPACCREDR > 0
          Call REDUCEACCOUNT(BPACC,[M:DTE]BPACCREDR,1)
        Endif
      Endif
   Endif
End

#** #############################################################################################################
#*
#* Suprog for expanding a given account. The given account will be expanded with zeros for the number of position declared in
#* the parameter COUNT
#*
#* @param   Variable Char ACC       Account
#* @param   Value Integer COUNT     Number of positions the account have to be expanded
#*! #############################################################################################################
Subprog EXPANDACCOUNT(ACC, COUNT)
Variable Char ACC
Value Integer COUNT
Local Char EXPSTRING(30)
Local Integer I
    For I = 0 To COUNT - 1
        EXPSTRING = EXPSTRING + "0"
    Next

    ACC = ACC + EXPSTRING
End

#** #############################################################################################################
#*
#* Suprog for reducing the positions of a given account. The given account will be reduced for the number of
#* position declared in the parameter COUNT. The Direction from where the account will be reduced is defined
#* in the parameter DIRECTION
#*
#* @param   Variable Char ACC       Account
#* @param   Value Integer COUNT     Number of positions the account have to be reduced
#* @param   Value Integer DIRECTION     Directon from where the account will have to be reduced 1 => from the right; 2 => from the left
#*! #############################################################################################################
Subprog REDUCEACCOUNT(ACC, COUNT, DIRECTION)
Variable Char ACC
Value Integer COUNT
Value Integer DIRECTION
    If COUNT <= len(ACC)
      If DIRECTION = 2 #links
          ACC = right$(ACC,COUNT + 1)
      Else #rechts
          ACC = left$(ACC,len(ACC)-COUNT)
      Endif
    Endif
End


#** #############################################################################################################
#*
#* Function that determines, if exist, the associated Datev account for a given X3 GL account and plan code
#*
#* @param   Variable Char ACC           account
#* @param   Value Char PLANCODE         plan code
#*
#* @return  Integer Result       1 => if a associated Datev account exists
#*! #############################################################################################################
Funprog GLFROMASSOCTABLE(ACC, PLANCODE)
Variable Char ACC
Value Char PLANCODE
Local Integer ACCINTABLE
Local Char DATEVACC(30)

    If !clalev([F:DTA])  : Local File DATEVGLACC [DTA]  : Endif
    Read [F:DTA]DTA0 = PLANCODE; ACC
    If !fstat
        ACC = [F:DTA]ACCDATEV
        ACCINTABLE = 1
    Endif

End ACCINTABLE



#** #############################################################################################################
#*
#* Function that determines, if exist, the associated Datev account for a given X3 BPR account
#*
#* @param   Variable Char ACC           account

#* @return  Integer Result       1 => if a associated Datev account exists
#*! #############################################################################################################
Funprog BPFROMASSOCTABLE(ACC)
Variable Char ACC
Local Integer ACCINTABLE
Local Char DATEVACC(30)

    If !clalev([F:DTB])  : Local File DATEVBPACC [DTB]  : Endif

    Filter [DTB] Where [DTB]BPRNUM = ACC

    For [DTB]
        DATEVACC = [DTB]ACCDATEV
    Next
    If DATEVACC <> "" : ACC = DATEVACC : ACCINTABLE = 1 Endif
    Filter [DTB]

End ACCINTABLE


#** #############################################################################################################
#*
#* Function that determines, if exist, the associated Datev taxcode for a given X3 tax code
#*
#* @param   Variable Char TAXCODE           X3 tax code

#* @return  Char TAX       associated tax code, if exist.
#*! #############################################################################################################
Funprog GETTAXCODEFROMASSOCTABLE(TAXCODE)
Variable Char TAXCODE
Local Char TAX(30)
    TAX = TAXCODE
    If !clalev([F:DTT])  : Local File DATEVTAX [DTT]  : Endif

    Filter [DTT] Where [DTT]TAX = TAX

    For [DTT]
        DATEVTAX = [DTT]TAXDATEV
    Next
    If DATEVTAX <> "" : TAX = DATEVTAX : Endif
    Filter [DTT]

End TAX

#** #############################################################################################################
#*
#* Subprog that removes leading zeros in a given account string.
#*
#* @param   Variable Char ACC           account
#*! #############################################################################################################
Subprog REMOVELEADINGZERO(ACC)
Variable Char ACC
Local Integer I
Local Char ACCTMP(30)

    While left$(ACC,1) = "0"
        ACC = right$(ACC, 2)
    Wend

End

#** #############################################################################################
#* Get the parameter 'DCLVATDAT' for a given company
#*
#* @param CPY     Value Char  Company
#* @return        Local Char  Result: "1" for Accounting date (default)
#*                                    "2" for Document date
#*! #############################################################################################
Funprog GETCOMPANYVATDAT(CPY)
Value Char CPY
Local Char RESULT(30)
  Call PARAM(CPY, "DCLVATDAT", RESULT) From ADOVAL
  If RESULT = "" : RESULT = "1" : Endif
End RESULT

######################################################################################
$SELCPYDIM
    Local Integer DIMDIM                    # Array for selection values
    Local Integer I                                               # FOR loop counter
    Local Char COMP(30)
    If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
    DIMDIM = dim([CPY]DIE)
    Local Char TEXTE(30)(1..DIMDIM, 1..2)                      # Array for selection rows
    Local Char TEX(30)(1..DIMDIM)
    # Initialize row and column counter.
    NBCOL = 0                                                     # Column counter
    NBTEX = 0                                                     # Row counter

    # Set selection title.
    TIT(NBCOL) = "Kostenstelle" #mess(189,8631,1)                                  # "Tax identifier"

    # Set column titles.
    NBCOL += 1
    TIT(NBCOL) = "Kostenstelle" #mess(189,8631,1)                                  # "Tax identifier"
    NBCOL += 1
    TIT(NBCOL) = "Unternehmen" #mess(190,8631,1)                                  # "Tax office"
    NBCOL += 1
    TIT(NBCOL) = ""


     COMP = [M:DTE]CPY

    Read [F:CPY]CPY0 = COMP
    If !fstat
        For I = 0 To DIMDIM - 1

            # Check if the last tax identifier was reached and break off.
            If [CPY]DIE( I ) = ""
                Break
            Endif

            # Add row to selection list.
            NBTEX += 1
            TEX( NBTEX ) = [CPY]DIE( I )
            TEXTE( NBTEX, 1 ) = [CPY]DIE( I )
            TEXTE( NBTEX, 2 ) = [CPY]CPY
        Next
    Endif
Return


$SELLEGGTE
    Local Integer COUNT                    # Array for selection values
    Local Integer I                                               # FOR loop counter
    Local Char COMP(30)
    Local Char LEGI(30)
    If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
    Read [F:CPY]CPY0 = [M:DTE]CPY
    If !fstat
        LEGI = [F:CPY]LEG
    Endif

    If !clalev([F:GTE])  : Local File GTYPACCENT [GTE]  : Endif
    #Filter [F:GTE] Where [F:GTE]LEG = LEGI
    COUNT = rowcount([F:GTE])

    Local Char TEXTE(30)(1..COUNT, 1..2)                      # Array for selection rows
    Local Char TEX(30)(1..COUNT)

    # Initialize row and column counter.
    NBCOL = 0                                                     # Column counter
    NBTEX = 0                                                     # Row counter

    # Set selection title.
    TIT(NBCOL) = "Dokumententyp" #mess(189,8631,1)

    # Set column titles.
    NBCOL += 1
    TIT(NBCOL) = "Dokumententyp" #mess(189,8631,1)
    NBCOL += 1
    TIT(NBCOL) = "Legislatur" #mess(190,8631,1)
    NBCOL += 1
    TIT(NBCOL) = ""


     COMP = [M:DTE]CPY

    For [F:GTE]

        NBTEX += 1
        TEX( NBTEX ) = [F:GTE]TYP
        TEXTE( NBTEX, 1 ) = [F:GTE]TYP
        TEXTE( NBTEX, 2 ) = [F:GTE]LEG
    Next

    #Filter [F:GTE]

Return

#index for dimension
Funprog GETDIMINDEX(DIMENSION, COMP)
Variable Char DIMENSION, COMP
Local Integer RESULT, I

  If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
  Read [F:CPY]CPY0 = COMP
  For I = 0 To dim([F:CPY]DIE)
    If [F:CPY]DIE(I) = DIMENSION : RESULT = I : Break : Endif
  Next
End RESULT

#Determine Costcenter
Funprog GETCOST(DIMENSION, COMP, COSTLED, JOURNUM)
Variable Char DIMENSION, COMP, COSTLED, JOURNUM
Local Char RESULT(30)

  If !clalev([F:GAA])  : Local File GACCENTRYA    [GAA]  : Endif
    Filter [F:GAA] Where NUM = JOURNUM and LED = COSTLED and CPY = COMP
    For [F:GAA]
      RESULT = CCE(func GETDIMINDEX(DIMENSION, COMP))
    Next
End RESULT



#** #####################################################################################################
#* Get the index of mainledger for a given company
#*
#* @param COMP           Variable Char:           Legislation
#* @param RETURNTYPE     Variable Integer:        Return type: 1-> Index ; 2 -> Mainledgertype
#* @return         Local Integer Result:  index of the mainledger
#*! #####################################################################################################
Funprog GETMAINLEDTYP(COMP)
Value Char COMP
Local Integer RESULT
Link [CPY] With
& [F:GCM]GCM0  = [F:CPY]ACM
& ,[F:LED]LED0  = [F:GCM]LED
& As [LNK2]
& Where [F:CPY]CPY = COMP

For [LNK2]
      RESULT = [F:GCM]GENLEDTYP
Next

End RESULT


