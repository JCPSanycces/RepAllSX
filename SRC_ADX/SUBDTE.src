#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
    Case ACTION
        When "INIT"        : Gosub INIT
        When "OUVRE"       : Gosub OUVRE
        When "OK"          : Gosub OK
        When "DEBUT"       : Gosub DEBUT
        When "BOUTON"      : Gosub BOUTON
        When "SEL_LISTE"   : If LISTE = "SELCPYDIM" : Gosub SELCPYDIM : Elsif LISTE = "SELLEGGTE" : Gosub SELLEGGTE : Endif
        When Default
    Endcase
Return

$INIT
  #check if a valid licence exists
    If !func CHECKLICENCE()
      Call ERREURT( mess(19,3653,1),1) From GESECRAN
      #GOK = 0
      End
    Endif
Return

$BOUTON

  If BOUT = "2"
    Call AM_FLGBPS([M:DTE]FLGBPS)
    Call AM_FLGBPC([M:DTE]FLGBPC)
    Call AM_FLGGLACC([M:DTE]FLGGLACC)
    Call AM_FLGCOST([M:DTE]FLGCOST)
    Call AM_FLGDCOTYP([M:DTE]FLGDCOTYP)
  Endif

Return


$DEBUT
    Raz [M:DTE]
    Grizo [M:DTE]GLACCRED
    [M:DTE]GLREDLEFT = 1
    Grizo [M:DTE]GLREDLEFT
    Grizo [M:DTE]GLACCREDDIR
    Grizo [M:DTE]BPREDDIR
    [M:DTE]BPREDLEFT = 1
    Grizo [M:DTE]BPREDLEFT
    Grizo [M:DTE]BPREDR
    Grizo [M:DTE]BPACCREDR
    Grizo [M:DTE]BPREDL
    Grizo [M:DTE]BPACCREDL
    Grizo [M:DTE]FLGBPCACT
    Grizo [M:DTE]FLGBPSACT
    Grizo [M:DTE]FLGBPSCPY
    Grizo [M:DTE]FLGBPCCPY
    Grizo [M:DTE]FLGGLACCACT
    Grizo [M:DTE]COST1
    Grizo [M:DTE]COST2
    Grizo [M:DTE]TYPSTR
    [M:DTE]INVFLD1 = 1
    [M:DTE]INVFLD2 = 3
    Affzo [M:DTE]INVFLD1
    Affzo [M:DTE]INVFLD2

Return


#** #############################################################################################
#*  checks if a valid licence for DATEV exists
#*  @return RESULT    Local Integer -> 0 -> false; 1 -> true
#*! #############################################################################################
Funprog CHECKLICENCE()
  Local Integer RESULT : RESULT = 1
  If !clalev([F:ADW])  : Local File ADOVAL    [ADW]  : Endif
  Read [F:ADW] ADW0 = "";""; "GERLICDAT"
  If tolower([F:ADW]VALEUR) <> tolower("19a1121dad")
    RESULT = 0
  Endif
  Close File [F:ADW]
End RESULT


#** #############################################################################################
#* Open tables and declare variables
#*! #############################################################################################
$OUVRE

    #############################################################
    # Open company/facility/addres etc. tables.
    #############################################################
    If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
    If !clalev([F:FCY])  : Local File FACILITY   [FCY]  : Endif
    If !clalev([F:GCM])  : Local File GACM       [GCM]  : Endif
    If !clalev([F:LED])  : Local File GLED       [LED]  : Endif
    If !clalev([F:FIY])  : Local File FISCALYEAR [FIY]  : Endif
    If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif
    If !clalev([F:BPC])  : Local File BPCUSTOMER [BPC]  : Endif
    If !clalev([F:BPS])  : Local File BPSUPPLIER [BPS]  : Endif
    If func ASYRFNC.ACTIV("MUL") >0 : # Issue 56229 - 2017-11-15 by MWA
      If !clalev([F:BPE])  : Local File BPEXCEPT   [BPE]  : Endif
    Endif

    If !clalev([F:BPR])  : Local File BPARTNER   [BPR]  : Endif
    If !clalev([F:BPA])  : Local File BPADDRESS  [BPA]  : Endif
    If !clalev([F:BID])  : Local File BID        [BID]  : Endif
    If !clalev([F:TCY])  : Local File TABCOUNTRY [TCY]  : Endif
    If !clalev([F:DAE])  : Local File GACCENTRYD [DAE]  : Endif
    If !clalev([F:HAE])  : Local File GACCENTRY  [HAE]  : Endif
    If !clalev([F:COA])  : Local File GCOA       [COA]  : Endif
    If !clalev([F:GTE])  : Local File GTYPACCENT [GTE]  : Endif

    #############################################################
    #char array for the fields of the header line
    #############################################################
    Local Char HEADER(30)(31)

    #############################################################
    #integer array for the indexes of text fields in the header line
    #############################################################
    Local Integer HEADERTEXTINDEX(12)

    #############################################################
    #char array for the fields of a GL account line
    #############################################################
    Local Char GLACCOUNTS(40)(3)

    #############################################################
    #integer for the index of text fields in the GL account line
    #############################################################
    Local Integer GLACCOUNTTEXTINDEX(2)

    #############################################################
    #char array for the fields of a BP account line
    #############################################################
    Local Char BPACCOUNTS(100)(243)

    #############################################################
    #integer array for the indexes of text fields in the header line
    #############################################################
    Local Integer BPACCOUNTTEXTINDEX(175)

    #############################################################
    #char array for the fields of a journal entry line
    #############################################################
    Local Char JOURNALENTRIES(210)(116)

    #############################################################
     #integer array for the indexes of text fields in a journal entry line
     #############################################################
    Local Integer JOURNALTEXTINDEX(80)

    #############################################################
    #initalize the index arrays for text fields
    #############################################################
    Call INITTEXTINDEX(HEADERTEXTINDEX, 1)
    Call INITTEXTINDEX(JOURNALTEXTINDEX, 2)
    Call INITTEXTINDEX(BPACCOUNTTEXTINDEX, 3)
    Call INITTEXTINDEX(GLACCOUNTTEXTINDEX, 4)

    Local Char MAINLED(GLONLED) : MAINLED   = ""      # Main ledger ID
    Local Char MAINCOSTLED(GLONLED) : MAINCOSTLED = ""# main cost ledger
    Local Char MAINCOA(GLONCOA) : MAINCOA   = ""      # Main ledger's plan code ID
    Local Integer LEDINDEX, COST1DIMINDEX, COST2DIMINDEX
    Local Integer GLACCOUNTLENGTH
    Local Integer BPTYPEFLAG
    Local Char OPT(2) # 1- nach Buchungsdatum, 2 - nach Belegdatum
    Local Char FIL1(255)
    Local Char FIL2(255)
    Local Char FIL3(255)
    Local Char FIL4(255)


Return



#** #############################################################################################
#* Initalizing the arrays which holds the indexes of fields in a output line which are textfields
#* These indexes are needed to inizalize the textfields of a line with '""'
#*
#*  @param INDEXARR  Variable INTEGER()
#*
#*  @param DATATYPE  Value INTEGER 1=>Header; 2=>Journal entries; 3=>BP accounts
#*
#*! #############################################################################################
Subprog INITTEXTINDEX(INDEXARR, DATATYPE)
Variable Integer INDEXARR
Value Integer DATATYPE
Local Integer I : I = 0
Local Integer TEXTINDEX : TEXTINDEX = 0
    Case DATATYPE
        When 1:
            INDEXARR(0)=0:INDEXARR(1)=3:INDEXARR(2)=7:INDEXARR(3)=8:INDEXARR(4)=9:INDEXARR(5)=16:INDEXARR(6)=17:INDEXARR(7)=21
            INDEXARR(8)=23 : INDEXARR(9) = 26 : INDEXARR(10) = 29 : INDEXARR(11) = 30
        When 2:
            # SAM 112918 20151215 ANGRE
            INDEXARR(0)=1:INDEXARR(1)=2:INDEXARR(2)=5:INDEXARR(3)=8:INDEXARR(4)=10:INDEXARR(5)=11:INDEXARR(6)=13:INDEXARR(7)=15

            TEXTINDEX = 19
            For I = 8 To 26 : INDEXARR(I) = TEXTINDEX : TEXTINDEX += 1 : Next

            INDEXARR(27)= 39
            INDEXARR(28)= 41
            TEXTINDEX = 47
            For I = 29 To 68 : INDEXARR(I) = TEXTINDEX : TEXTINDEX += 1 : Next
            INDEXARR(69) = 90
            INDEXARR(70) = 94
            INDEXARR(71) = 95
            INDEXARR(72) = 97
            INDEXARR(73) = 101
            INDEXARR(74) = 102
            INDEXARR(75) = 104
            INDEXARR(76) = 106
            INDEXARR(77) = 108
            INDEXARR(78) = 109
            INDEXARR(79) = 111


        When 3:
            TEXTINDEX = 1
            For I = 0 To 23 :INDEXARR(I) = TEXTINDEX : TEXTINDEX += 1   : Next
            TEXTINDEX = 28
            For I = 24 To 44 : INDEXARR(I) = TEXTINDEX : TEXTINDEX += 1 : Next
            TEXTINDEX = 51
            For I = 45 To 53 : INDEXARR(I) = TEXTINDEX : TEXTINDEX += 1 : Next
            TEXTINDEX = 62
            For I = 54 To 62 : INDEXARR(I) = TEXTINDEX : TEXTINDEX += 1 : Next
            TEXTINDEX = 73
            For I = 63 To 71 : INDEXARR(I) = TEXTINDEX : TEXTINDEX += 1 : Next
            TEXTINDEX = 84
            For I = 72 To 80 : INDEXARR(I) = TEXTINDEX : TEXTINDEX += 1 : Next

            INDEXARR(81)=95:INDEXARR(82)=96:INDEXARR(83)=97:INDEXARR(84)=98:INDEXARR(85)=99:INDEXARR(86)=101:INDEXARR(87)=102:INDEXARR(88)=103:INDEXARR(89)=106:INDEXARR(90)=132
            INDEXARR(91)=133

            TEXTINDEX = 135
            For I = 92 To 118 : INDEXARR(I) = TEXTINDEX : TEXTINDEX += 1 : Next
            TEXTINDEX = 164
            For I = 119 To 127 : INDEXARR(I) = TEXTINDEX : TEXTINDEX += 1 : Next
            TEXTINDEX = 175
            For I = 128 To 136 : INDEXARR(I) = TEXTINDEX : TEXTINDEX += 1 : Next
            TEXTINDEX = 186
            For I = 137 To 145 : INDEXARR(I) = TEXTINDEX : TEXTINDEX += 1 : Next
            TEXTINDEX = 197
            For I = 146 To 154 : INDEXARR(I) = TEXTINDEX : TEXTINDEX += 1 : Next
            TEXTINDEX = 208
            For I = 155 To 163 : INDEXARR(I) = TEXTINDEX : TEXTINDEX += 1 : Next
            INDEXARR(164) = 219
            TEXTINDEX = 221
            For I = 165 To 174 : INDEXARR(I) = TEXTINDEX : TEXTINDEX += 1 : Next
        When 4
           INDEXARR(0) = 1
           INDEXARR(1) = 2
    Endcase
End

#** #############################################################################################
#* Initalizing the line array (LINE) with quotes at the indexes which are defined in the integer
#* array INDEXLINE
#*
#*  @param LINE       Variable Char()
#*
#*  @param INDEXLINE  Variable Integer()
#*
#*! #############################################################################################
Subprog INITLINES(LINE, INDEXLINE)
Variable Char LINE
Variable Integer INDEXLINE
Local Integer C

    Raz LINE
    For C = 0 To dim(INDEXLINE) -1
        LINE(INDEXLINE(C)) ='""'
    Next
End


#** #############################################################################################
#* Start process for reading and writing data
#*! #############################################################################################
$OK

    #############################################################
    #gets the company related data
    #############################################################
    Call GETCOMPANYDATA([M:DTE]CPY,MAINCOA, MAINLED, MAINCOSTLED)
    #############################################################
    #gets the max. length of the gl accounts for the given plan code
    #############################################################
    GLACCOUNTLENGTH = func GETGLACCOUNTLENGTH(MAINCOA)
   Gosub WRITEDATA
Return

#** #############################################################################################
#* Calls the methods for exporting the selected data
#*! #############################################################################################
$WRITEDATA
   Local Char EXPORTNAME(GDIMFIC)
   Local Char EXPORTFILE(GDIMFIC)
   Local Char FILENAMETR (GDIMFIC)
   Local Char URL(GDIMFIC)
   Local Integer STAT
   Local Integer OUTPUT
    #############################################################
    #open trace file
    #############################################################
    Call OUVRE_TRACE (mess(15, 3653,1)) From LECFIC
    If  [M:DTE]FLGGLACC = 2 : OUTPUT = 1 :  Gosub WRITEGLACCOUNTS : Endif
    If  [M:DTE]FLGBPC = 2 :  OUTPUT = 1 :   BPTYPEFLAG = 2 : Gosub WRITEBPACCOUNTS : Endif
    If  [M:DTE]FLGBPS = 2 :  OUTPUT = 1 :   BPTYPEFLAG = 1 : Gosub WRITEBPACCOUNTS : Endif

    If [M:DTE]DATEND <> [0/0/0] and [M:DTE]DATSTR <> [0/0/0] : OUTPUT = 1 : Gosub WRITEJOURNALS : Endif

    #if no information for output is set
    If OUTPUT = 0 : Infbox (mess(18,3653,1)) : FIN = 0 : Endif
    #############################################################
    #close trace file
    #############################################################
    Call FERME_TRACE From LECFIC
    #############################################################
    #display the trace file
    #############################################################
    Call LEC_TRACE From LECFIC
Return

#** #############################################################################################
#* Calls the methods for exporting the GL accounts
#*! #############################################################################################
$WRITEGLACCOUNTS
    Call OPENFILE(1, [L]EXPORTNAME, [L]EXPORTFILE, [L]URL)
    Call WRITEHEADER(HEADER,HEADERTEXTINDEX,1, GLACCOUNTLENGTH)
    Gosub WRITEGLACCOUNTDESC
    Gosub WRITEGLACCOUNTDATA
    Openo Using [YYY]
    Call DOWNLOADFILE(EXPORTFILE, EXPORTNAME)
Return

#** #############################################################################################
#* Downloads the file to the client
#*! #############################################################################################
Subprog DOWNLOADFILE(EXPORTFILE, EXPORTNAME)
  Variable Char EXPORTFILE
  Variable Char EXPORTNAME
  Local Integer STAT
  If [M]TYPEXP = 1 : # Client
        Call COPCLI( EXPORTFILE, EXPORTNAME, STAT ) From ORDSYS
        If STAT = 1
            Call ERREUR( mess(164,141,1) ) From GESECRAN # 'File not copied to the client workstation'
        Elsif STAT > 1
            Call ERREUR( mess(159,141,1) - "(" +num$( STAT ) + ")" ) From GESECRAN # 'File or directory do not exist'
        Endif
    Endif
End


#** #############################################################################################
#* Calls the methods for exporting the journals
#*! #############################################################################################
$WRITEJOURNALS
    [L]OPT = func GETCOMPANYVATDAT([M:DTE]CPY)
    Call OPENFILE(3, [L]EXPORTNAME, [L]EXPORTFILE, [L]URL)
    Call WRITEHEADER(HEADER, HEADERTEXTINDEX,3, GLACCOUNTLENGTH)
    Gosub WRITEJOURNALDESC
    Gosub WRITEJOURNALDATA
Return

#** #############################################################################################
#* Obtain and writes the journal data
#*! #############################################################################################
$WRITEJOURNALDATA
    Gosub ALLJOURNALQUERY

    #check for temporary status
    Filter [LNKN] Where [F:HAE]STA = 1
      If rowcount([LNKN]) > 0
        Local Integer YESNO : YESNO = 1
        Call OUINONT( mess(308,107,1) + chr$(10) + mess(00432,07773,1), YESNO ) From GESECRAN
        If YESNO = 1 : Return : Endif
      Endif
    Filter [LNKN]

    Gosub ANALYSEJOURNALSPERNUMBER
     Openo Using [YYY]
    Call DOWNLOADFILE(EXPORTFILE, EXPORTNAME)
Return

#** #############################################################################################
#* Analyse all journals for a journalrecord with the same journalnumber.
#* Loop through the journals and arrange specific information in arrays for calculation
#* and writing
#*! #############################################################################################
$ANALYSEJOURNALSPERNUMBER
Local Char JNUMBER(255)
Local Integer COUNT #number of rows for a journalnumber
Local Integer I
Local Integer JOURCOUNTER
Local Integer FLGTEMPARR
Local Integer AUTOFLG
Local Char PARAMVATLIMIT(30)
Local Integer USETRANSFLG, HASVATLINE, ISCEE#, USECORRECTIONKEY
Local Integer DONE
Local Integer CHRONO
Local Integer C, J, LINETYPE, TRACECOUNTJOUR, TRACECOUNTJOURLINE
Local Integer BPTOBP : BPTOBP = 1
Local Char DOCTYPE(10)


    Call ECR_TRACE("-----" - mess(4, 3653,1), 0) From GESECRAN

    Call PARAM([M:DTE]CPY, "GERDIFFDAT", PARAMVATLIMIT) From ADOVAL
    #############################################################
    #Open the tables for the data per journalnumber
    #############################################################
    Gosub OPENADDTABLES

    ##############################################################################
    #loop through each journal which are complied with the settings in the screen
    ##############################################################################
    For [LNKN]


        ###################################
        #Treat every new journal
        ##################################

        DONE = 0
        BPTOBP = 1


        If JNUMBER <> [F:DAE]NUM

          TRACECOUNTJOUR +=1
          ##############################################################################
          #check if the invoice/payment is reverse/charge
          ##############################################################################
          ISCEE = (func CHECKCEEFLAG([F:DAE]NUM, [F:HAE]REF, MAINLED) or func CHECKCEEFLAG([F:HAE]RVSORINUM, [F:HAE]REF, MAINLED))

          ##############################################################################
          #set back the variables which indicates a journal has VAT lines
          #and the variable which indicates we have to use the tranfer account
          ##############################################################################
          HASVATLINE = 0
          USETRANSFLG = 0

          ##############################################################################
          #set the variable JNUMBER to the actual journalnumber
          ##############################################################################
          JNUMBER = [F:DAE]NUM

          ##############################################################################
          #execute the query for all lines of a journalnumber
          ##############################################################################
          Gosub JOURNALQUERYFORNUM

          ##############################################################################
          #if the rowcount of the lines for a journalnumber is different from the
          #last one
          ##############################################################################
          If rowcount([LNKJ]) <> COUNT
              ##############################################################################
              #count is the dimension needed to declare the arrays for journallines
              ##############################################################################
              COUNT = rowcount([LNKJ])

              ##############################################################################
              #declare the arrays for temporary journal line data
              ##############################################################################
              Gosub DECLARETEMPARRAYS
          Else

              ##############################################################################
              #clear the arrays for temporary journal line data
              ##############################################################################
              Gosub RAZTEMPARRAYS
          Endif

         # to retrieve and handle all information for a journal, we have iterate through the data 3 times (0 - 2)
         For I = 0 To 2
          #indexcounter for journal lines of the actual journal
          JOURCOUNTER = 0
            For [LNKJ]

             If DOCTYPE <> [F:GTE]TYP
               DOCTYPE = [F:GTE]TYP
             Endif
             # SAM 112918 20151215 ANGRE
             If [F:DAE2]LEDTYP = func GETMAINLEDTYP([F:DAE2]CPY)


              ########################################################################
              #first loop to fill the temporary arrays to hold the needed journal data
              ########################################################################
              If I = 0
                ########################################################################
                #find accounttype 1-> datev autoaccount; 2 -> tax account; 3 -> non autoaccount
                #and fill the related array at index "JOURCOUNTER"
                ########################################################################
                Case func GETACCOUNTTYPE([F:DAE2]ACC, MAINCOA)
                    When 1 : INDEXAUTOACCOUNT(JOURCOUNTER)= 1

                    When 2 : [L]INDEXTAXACCOUNT(JOURCOUNTER) = 1 : [L]HASVATLINE = 1

                    When 3 : If [F:GAC2]VAT <> "" : [L]INDEXNOAUTOACCOUNT(JOURCOUNTER) = 1 :  Endif
                Endcase

                ##########################################################################################
                # set the taxcode, amount, glaccount and debit/creditsign of the line to the related array
                ##########################################################################################
                [L]AMOUNT([L]JOURCOUNTER) = [F:DAE2]AMTLED
                [L]INDEXTAXCODE([L]JOURCOUNTER) = [F:DAE2]TAX
                [L]GLACCOUNTINLINE([L]JOURCOUNTER) = [F:DAE2]ACC
                [L]DEBCREDSIGN([L]JOURCOUNTER) = [F:DAE2]SNS

                ###########################
                If func ACCOUNTTYPE([F:DAE2]ACC, MAINCOA) <> 3
                  BPTOBP = 0
                Endif

                ########################################################################
                #if counterpart account is empty -> transfer account has to be used
                ########################################################################
                If [F:DAE2]OFFACC = "" : USETRANSFLG = 1 : Endif

              ##############################################################################
              # the second loop through the journallines: Perform checks to identify invalid
              # journals and do calculation for AV accounts and other gross accounts
              ##############################################################################
              Elsif I = 1
                  If BPTOBP
                    Gosub WRITEJOURNALLINE
                  Else

                    #handling of multiple tax lines with the same taxcode
                    #shrink it to one amount and set others to 0
                    Local Integer C
                    Local Integer K
                    AUTOFLG = 0

                    If DONE = 0
                      For C=0 To dim(INDEXTAXCODE)-1
                        For K = C+1 To dim(INDEXTAXCODE)-1
                          # SAM # 118008 DEBCREDSIGN has to be taken into account
                          If INDEXTAXCODE(K) = INDEXTAXCODE(C) and INDEXTAXACCOUNT(K) = 1 and INDEXTAXACCOUNT(C) = 1 and GLACCOUNTINLINE(K) = GLACCOUNTINLINE(C) and DEBCREDSIGN(K) = DEBCREDSIGN(C)
                          #If INDEXTAXCODE(K) = INDEXTAXCODE(C) and INDEXTAXACCOUNT(K) = 1 and INDEXTAXACCOUNT(C) = 1 and GLACCOUNTINLINE(K) = GLACCOUNTINLINE(C)
                            AMOUNT(C) += AMOUNT(K)
                            AMOUNT(K) = 0
                        Endif
                       Next
                     Next
                   Endif
                   DONE = 1


                  ########################################################################
                  #check if a Vatcode in a tax line is existing once only. If it is existing more than once => the journal is not valid
                  #Stop loop through the jourallines and write error trace
                  #
                  #!!! checkdoublevatcode not implemented at the moment !!!
                  ########################################################################
                  If !ISCEE and !func CHECKDOUBLEVATCODE([L]INDEXTAXCODE, [L]INDEXTAXACCOUNT, COUNT)
                    Call ECR_TRACE(mess(16, 3653,1) - [F:DAE]NUM, 1) From GESECRAN
                    I = 2
                    If [L]TRACECOUNTJOUR > 0 :  [L]TRACECOUNTJOUR -= 1 : Endif
                    Break
                  Endif
                  ########################################################################
                  # if account is datev autoaccount set AUTOFLG
                  ########################################################################
                 # USECORRECTIONKEY = func ISNONAUTOBUTGROSSACCOUNT(JOURCOUNTER, [L]INDEXNOAUTOACCOUNT, [F:GAC2]VAT)
                  If func ISAUTOACCOUNT(JOURCOUNTER, INDEXAUTOACCOUNT) or func ISNONAUTOBUTGROSSACCOUNT(JOURCOUNTER, [L]INDEXNOAUTOACCOUNT, [F:GAC2]VAT)

                    ########################################################################
                    #check if a taxline is existing for the taxcode in the autoaccount line
                    #If NOT -> Stop loop through the jourallines and write error trace
                    ########################################################################

                    If !func CHECKTAXLINEEXISTENCE([F:DAE2]TAX, INDEXTAXCODE, INDEXTAXACCOUNT, COUNT , [F:DAE2]ACCDAT)
                      Call ECR_TRACE(mess(7, 3653,1) - [F:DAE2]NUM, 1) From GESECRAN
                      I = 2
                      If [L]TRACECOUNTJOUR > 0 :  [L]TRACECOUNTJOUR -= 1 : Endif
                      Break
                    Endif
                    AUTOFLG = 1
                  Elsif func ISNONAUTOACCOUNT(JOURCOUNTER, INDEXNOAUTOACCOUNT)
                      AUTOFLG = 0
                  Endif
                  ########################################################################
                  #check if the taxcode in the line is the same as assigned to the gl account in the line.
                  #If NOT, stop loop through the journallines and write error trace
                  ########################################################################
                  #If func ISVALIDTAXCODE(INDEXAUTOACCOUNT(JOURCOUNTER))
                  If [F:DAE2]TAX = [F:GAC2]VAT or !INDEXAUTOACCOUNT(JOURCOUNTER)
                    ########################################################################
                    #if the journal has a vat line then do the calulation for the line
                    ########################################################################
                    If (AUTOFLG = 1 or HASVATLINE = 1) and INDEXTAXACCOUNT(JOURCOUNTER) <> 1
                      #########################################################################################
                      #do the calculation for tax amount etc... If function return false
                      #a invalid taxcode is used -> write error trace
                      ########################################################################

                      If  !func DOCALCULATION([L]INDEXTAXACCOUNT,[L]INDEXTAXCODE, [L]AMOUNT, GLACCOUNTINLINE, [L]TAXLINEUSAGECOUNT , [L]USEDFROMLINE, [L]DEBCREDSIGN,[F:DAE2]ACCDAT, [L]JOURCOUNTER,
& AUTOFLG, ISCEE)

                        #error trace
                        Call ECR_TRACE(mess(17, 3653,1) - [F:DAE]NUM, 1) From GESECRAN
                        I = 2
                        If [L]TRACECOUNTJOUR > 0 :  [L]TRACECOUNTJOUR -= 1 : Endif
                        Break
                     Endif

                 Endif
                Else
                  #error trace
                  Call ECR_TRACE(mess(8, 3653,1) - [F:DAE]NUM, 1) From GESECRAN
                  I = 2
                  If [L]TRACECOUNTJOUR > 0 :  [L]TRACECOUNTJOUR -= 1 : Endif
                  Break
                Endif
               Endif

              ##############################################################################
              # the third loop through the journallines: Treat the VAT limit and write
              # valid lines to the file
              ##############################################################################
              Else
                If BPTOBP = 0
                  If USEDFROMLINE(JOURCOUNTER) <> -1
                    Local Decimal VATONTOP
                    If INDEXTAXACCOUNT(JOURCOUNTER) <> 1
                      LINETYPE = 1
                    Else
                      LINETYPE = 2
                    Endif
                    Call TREATVATLIMIT(JOURCOUNTER, USEDFROMLINE, TAXLINEUSAGECOUNT, AMOUNT, INDEXTAXCODE, val([L]PARAMVATLIMIT), LINETYPE)
                  Endif

                  ########################################################
                  # no taxlines with amount 0 will be written to the file
                  ########################################################
                  If [L]INDEXTAXACCOUNT(JOURCOUNTER) <> 1 or AMOUNT([L]JOURCOUNTER) <> 0

                    ################################################################
                    # lines with collective accounts will not be written to the file
                    #################################################################
                    If func ACCOUNTTYPE([F:DAE2]ACC, MAINCOA) <> 3 and func ACCOUNTTYPE([F:DAE2]OFFACC, MAINCOA) <> 3

                      ################################################################
                      # write the journal line to the file
                      #################################################################
                      Gosub WRITEJOURNALLINE
                    Endif
                  Endif
                Endif
              Endif
                ################################################################
                # increase the counter variable for the journallines
                #################################################################
               JOURCOUNTER += 1
             Endif
            Next
         Next

        Endif
          ################################################################
          # set the chrono variable to the expnum in the gaccentry table
          #################################################################
          If [F:HAE]EXPNUM > CHRONO : CHRONO = [F:HAE]EXPNUM  : Endif
     # Endif
    Next
    ################################################################
    # store the chrono variable in the helper table DATEVCHRONO
    #################################################################
    Call SETCHRONO(CHRONO)
    ############################
    # close the tables
    ############################
    Call ECR_TRACE(mess(5,3653,1) + ":" - num$([L]TRACECOUNTJOUR),0) From GESECRAN
    Call ECR_TRACE(mess(6,3653,1) + ":" - num$([L]TRACECOUNTJOURLINE),0) From GESECRAN
    Gosub CLOSEADDTABLES
Return

#ist die rechnung eine eu rechnung?
#** #############################################################################################
#*  checks if a invoice/payment is a eu invoice
#*  @param JNUM       Variable Char   -> Journalnumber of the invoice to check
#*  @param REFNUM       Variable Char -> Reference number of the journal
#*  @param MAINLED    Variable Char   -> Mainledger
#*  @return RESULT    Local Integer   -> 0 -> false; 1 -> true
#*! #############################################################################################
Funprog CHECKCEEFLAG(JNUM, REFNUM, MAINLED)
Variable Char JNUM, REFNUM, MAINLED
Local Integer RESULT

  #########################################################
  # if journal is a payment then RESULT will be set in the
  # ISPAYMENT Function. If not RESULT is set directly via
  # the ISCEEINVOICE function
  #########################################################
  If !func ISPAYMENT(MAINLED, REFNUM, RESULT)
    RESULT = func ISCEEINVOICE(JNUM, MAINLED)
  Endif

End RESULT

#** #############################################################################################
#*  checks if a journal is a payment. If so the function checks if a referenced invoice is
#*  Reverse charge
#*  @param JNUM       Variable Char   -> Journalnumber of the invoice to check
#*  @param REFNUM     Variable Char   -> Reference number of the journal
#*  @param MAINLED    Variable Char   -> Mainledger
#*
#*  @return ISPAY     Local Integer   -> 0 -> false; 1 -> true
#*! #############################################################################################
Funprog ISPAYMENT(MAINLED, REFNUM, RESULT)
Variable Char REFNUM, MAINLED
Variable Integer RESULT
Local Integer ISPAY

  If !clalev([F:PYD])  : Local File PAYMENTD [PYD]  : Endif
  Filter [F:PYD] Where [F:PYD]NUM = REFNUM
  For [F:PYD]
    ISPAY = 1
    If func ISCEEINVOICE([F:PYD]VCRNUM, MAINLED)
      RESULT = 1
      Break
    Endif
  Next
  Filter [F:PYD]
End ISPAY

#** #############################################################################################
#*  Checks for a given journalnumber if the journal is a Reverse charge journal
#*  Reverse charge
#*  @param JNUM       Variable Char   -> Journalnumber of the invoice to check
#*  @param MAINLED    Variable Char   -> Mainledger
#*  @return RESULT    Local Integer   -> 0 -> false; 1 -> true
#*! #############################################################################################
Funprog ISCEEINVOICE(JNUM,MAINLED)
  Variable Char JNUM, MAINLED
  Local Integer RESULT

  If !clalev([F:PIH])  : Local File PINVOICE [PIH]  : Endif
  Filter [F:PIH] Where [F:PIH]CPY = [M:DTE]CPY and [F:PIH]LED = MAINLED and [F:PIH]NUM = JNUM
  For [F:PIH]
    RESULT = [F:PIH]CEEFLG - 1
  Next
  Filter [F:PIH]
End RESULT


