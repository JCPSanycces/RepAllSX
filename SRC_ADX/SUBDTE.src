  #[M:DTE]DIRDATFIL = func GETDIRPARAM(VALEUR, "DATEVFILPA")
  Affzo [M:DTE]DIRDATFIL
  [M:DTE]TRANSACC = func GETDIRPARAM(VALEUR, "GERIACCDAT")
  Affzo [M:DTE]TRANSACC
