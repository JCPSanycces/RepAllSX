#setzt den chrono
Subprog SETCHRONO(CHRONO)

Value Integer CHRONO
Local File DATEVCHRONO [F:DTC]
If rowcount([F:DTC]) = 0
  [F:DTC]ID = 1 : [F:DTC]CHRONO = num$(CHRONO)
    Write [F:DTC]
    If fstat
      GOK = 0 : Call FSTA("DTC") From GLOCK : End
    Endif
Elsif CHRONO <> 0
   Readlock [F:DTC]DTC0 = 1
   If fstat
      GOK = 0 : Call FSTA("DTC") From GLOCK : End
    Endif
   [F:DTC]CHRONO = num$(CHRONO)
   Rewrite [F:DTC]
   If fstat
      GOK = 0 : Call FSTA("DTC") From GLOCK : End
    Endif
    Unlock [F:DTC]
    [C]EXPORT += 1
Endif
End

Funprog GETCHRONO()
  Local Char RESULT(30)
  Local File DATEVCHRONO [F:DTC]
  If rowcount([F:DTC]) = 0
    RESULT = "0"
  Else
    Read [F:DTC]DTC0 = 1
    RESULT = [F:DTC]CHRONO
  Endif
End RESULT


#** #############################################################################################
#*  fill the journalentries array and call the writeline sub
#*! #############################################################################################
$WRITEJOURNALLINE
Local Char SIGN(2)
Local Char MACC(30) : MACC = [F:DAE2]ACC
Local Char OFFACC(30) : OFFACC = [F:DAE2]OFFACC
Local Char JOURNALNUMBER(30), ORIJOURNALNUMBER(30), TAXCODE(30), ISSUECODE(30)
Local Char TMPOFFACC(30)

  If AMOUNT(JOURCOUNTER) <> 0



      #angre BPTOBP
      If BPTOBP
        MACC = [F:DAE2]BPR
        OFFACC = [M:DTE]TRANSACC
      Else

        ########################################################################
        #if a transferaccount has to be used set the transferaccount as the counterpart account
        ########################################################################
        If [L]USETRANSFLG or func USETRANSITACCOUNT(MACC, OFFACC, MAINCOA) : OFFACC = [M:DTE]TRANSACC : Endif
      Endif

      ########################################################################
      # Treat the accounts depending on the settings for account treatment
      #######################################################################
      If MACC <> [M:DTE]TRANSACC
        Call TREATACCOUNT(MACC, func ACCOUNTTYPE(MACC, MAINCOA), MAINCOA)
      Endif
      If OFFACC <> [M:DTE]TRANSACC
        Call TREATACCOUNT(OFFACC,func ACCOUNTTYPE(OFFACC, MAINCOA), MAINCOA)
      Endif

      ########################################################################
      # Treat the accounts depending on the settings for account treatment
      #######################################################################
      If MACC <> [M:DTE]TRANSACC
        Call TREATACCOUNT(MACC, func ACCOUNTTYPE(MACC, MAINCOA), MAINCOA)
      Endif
      If OFFACC <> [M:DTE]TRANSACC
        Call TREATACCOUNT(OFFACC,func ACCOUNTTYPE(OFFACC, MAINCOA), MAINCOA)
      Endif

      ########################################################################
      #initalise the values of the journalentries array
      ########################################################################
      Call INITLINES(JOURNALENTRIES, [L]JOURNALTEXTINDEX)

      ########################################################################
      #set debit/credit sign
      ########################################################################
      If [F:DAE2]SNS = 1 : SIGN = "S" Else : SIGN = "H" : Endif

      If AMOUNT(JOURCOUNTER) < 0
        AMOUNT(JOURCOUNTER) = AMOUNT(JOURCOUNTER) * -1
        TAXCODE = "20"
        #SAM #118412 angre 130916
        TMPOFFACC = OFFACC: OFFACC = MACC : MACC = TMPOFFACC
      Else
        If INDEXTAXCODE(JOURCOUNTER) <> "" and !func ISAUTOACC(MACC,MAINCOA)
          TAXCODE = func GETVATASSIGNMENT(INDEXTAXCODE(JOURCOUNTER),0)
          #X3-42494
          ISSUECODE = func GETVATASSIGNMENT(INDEXTAXCODE(JOURCOUNTER),1)
        Endif
      Endif


      [L]JOURNALENTRIES(0) = vireblc(ctrans(func GETFORMATEDVALUE(format$("N:10.2",num$(AMOUNT(JOURCOUNTER))),13,0,[L]JOURNALTEXTINDEX),".",","),0)
      [L]JOURNALENTRIES(1) = func GETFORMATEDVALUE(SIGN,1,1,[L]JOURNALTEXTINDEX)
      [L]JOURNALENTRIES(6) = func GETFORMATEDVALUE(MACC,9,6,[L]JOURNALTEXTINDEX)
      [L]JOURNALENTRIES(7) = func GETFORMATEDVALUE(OFFACC,9,7,[L]JOURNALTEXTINDEX)

      # SAM 112918 20151215 ANGRE (#Taxcode not for taxaccounts)
       If func GETACCOUNTTYPE(MACC, MAINCOA) <> 2 and TAXCODE <> "" Then
        [L]JOURNALENTRIES(8) = func GETFORMATEDVALUE(TAXCODE,2,8,[L]JOURNALTEXTINDEX)
        #X3-42494
        If [L]ISSUECODE <> ""
          [L]JOURNALENTRIES(42) = func GETFORMATEDVALUE([L]ISSUECODE,3,42,[L]JOURNALTEXTINDEX)
        Endif
      Endif

      [L]JOURNALENTRIES(9) = func GETFORMATEDVALUE(func GETDATEASSTRING([F:DAE2]ACCDAT,2 ),4,9,[L]JOURNALTEXTINDEX)

#        ########################################################################
#        #shortening of the journalnumber and original journal number (max. 12 signs)
#        ########################################################################
#      If len([F:DAE2]NUM) <= 12
#        JOURNALNUMBER = [F:DAE2]NUM
#      Else
#       JOURNALNUMBER = right$([F:DAE2]NUM, 1 + len([F:DAE2]NUM) - 12)
#      Endif
#      [L]JOURNALENTRIES(10) = func GETFORMATEDVALUE(JOURNALNUMBER,20,10,[L]JOURNALTEXTINDEX)
 ########################################################################
        #shortening of the journalnumber and original journal number (max. 12 signs)
        ########################################################################
      If len([F:DAE2]NUM) <= 12
        JOURNALNUMBER = [F:DAE2]NUM
      Else
       JOURNALNUMBER = right$([F:DAE2]NUM, 1 + len([F:DAE2]NUM) - 12)
      Endif

      If len([F:HAE2]BPRVCR) <= 12 #and len([F:HAE2]BPRVCR) > 0
        [L]ORIJOURNALNUMBER = [F:HAE2]BPRVCR
      Else
        ORIJOURNALNUMBER = right$([F:HAE2]BPRVCR, 1 + len([F:HAE2]BPRVCR) - 12)
      Endif

      #write journalnumber according to settings in the screen
      #set invoice field 1
      If [M:DTE]INVFLD1 = 1
        [L]JOURNALENTRIES(10) = func GETFORMATEDVALUE(JOURNALNUMBER,20,10,[L]JOURNALTEXTINDEX)
      Elsif [M:DTE]INVFLD1 = 2
        If len([L]ORIJOURNALNUMBER) > 0
          [L]JOURNALENTRIES(10) = func GETFORMATEDVALUE(ORIJOURNALNUMBER,20,10,[L]JOURNALTEXTINDEX)
        Else
          [L]JOURNALENTRIES(10) = func GETFORMATEDVALUE(JOURNALNUMBER,20,10,[L]JOURNALTEXTINDEX)
        Endif
      Endif
      #set invoice field 2
      If [M:DTE]INVFLD2 = 1
        [L]JOURNALENTRIES(11) = func GETFORMATEDVALUE(JOURNALNUMBER,20,11,[L]JOURNALTEXTINDEX)
      Elsif [M:DTE]INVFLD2 = 2 and len(ORIJOURNALNUMBER) > 0
        [L]JOURNALENTRIES(11) = func GETFORMATEDVALUE(ORIJOURNALNUMBER,20,11,[L]JOURNALTEXTINDEX)
      Endif

      #Journaldescription
      [L]JOURNALENTRIES(13) = func GETFORMATEDVALUE([F:DAE2]DES,60,13,[L]JOURNALTEXTINDEX)

        ########################################################################
        #get cost center if needed (not for taxlines)
        ########################################################################
      If [M:DTE]FLGCOST = 2 and [L]INDEXTAXACCOUNT(JOURCOUNTER) <> 1
        [L]JOURNALENTRIES(36) = func GETFORMATEDVALUE(func GETCOST([M:DTE]COST1, [M:DTE]CPY, [L]MAINCOSTLED, [F:DAE2]NUM),8,36,[L]JOURNALTEXTINDEX)
        [L]JOURNALENTRIES(37) = func GETFORMATEDVALUE(func GETCOST([M:DTE]COST2, [M:DTE]CPY, [L]MAINCOSTLED, [F:DAE2]NUM),8,36,[L]JOURNALTEXTINDEX)
      Endif
      If [F:HAE2]BPRDATVCR <> [0/0/0]
        [L]JOURNALENTRIES(115) = func GETFORMATEDVALUE(func GETDATEASSTRING([F:HAE2]BPRDATVCR,3 ),8,115,[L]JOURNALTEXTINDEX)
      Endif
        ########################################################################
        #finally call the method that wrights the line to the file
        ########################################################################
      TRACECOUNTJOURLINE += 1
      Call WRITELINE(JOURNALENTRIES)
  Endif

Return


#** #############################################################################################
#* Function to get the assigned VAT code from DATEV VAT assgnment table
#*  @param VATCODE      Variable Char -> VATCODE
#*  @param CEEFLG      Variable Tiniint -> CEEFLG
#*  @return RESULT  Local Char -> VAT code from assignment table or CEE issue code if CEEFLG <> 0
#*! #############################################################################################
Funprog GETVATASSIGNMENT(VATCODE,CEEFLG)
  Variable Char VATCODE
  Value Tinyint CEEFLG
  Local Char RESULT(30)
  If !clalev([F:DTT]) : Local File DATEVTAX [DTT]  : Endif
    Read [F:DTT]DTT0 = [M:DTE]LEG; VATCODE
    If !fstat
       # X3-42494
        If CEEFLG = 0
          RESULT = num$([F:DTT]TAXDATEV)
        Else
          RESULT = num$([F:DTT]DTTISSCOD)
        Endif
        #Infbox RESULT + " for ceeflg = " + num$(CEEFLG)
        If RESULT = "0" : RESULT = "" : Endif
    Else
      RESULT = ""#VATCODE
    Endif
End RESULT


#** #############################################################################################
#* Function to check if the transferaccount has to be used (both sides are AV accounts)
#*  @param ACC      Variable Char -> Account
#*  @param OFFACC   Variable Char -> Counterpart account
#*  @param MCOA     Variable Char -> Main Coa
#*  @return RESULT  Local Integer -> 0 -> false, 1 -> true
#*! #############################################################################################
Funprog USETRANSITACCOUNT(ACC, OFFACC, MCOA)
  Variable Char OFFACC, ACC, MCOA
  Local Integer RESULT

  ########################################################################
  #If account and counterpart account are gross accounts
  ########################################################################
  #SAM#118123
  If func ACCOUNTTYPE(OFFACC, MCOA) = 1
    RESULT = 1
    End RESULT
  Endif
  If (func ISAUTOACC(ACC, MCOA)  or (func ACCOUNTTYPE(ACC, MCOA) and  func HASVATASSIGNMENT([M]LEG, func GETTAXCODE(ACC, MCOA))))

    If (func ISAUTOACC(OFFACC, MCOA) or (func ACCOUNTTYPE(OFFACC, MCOA) and  func HASVATASSIGNMENT([M]LEG, func GETTAXCODE(OFFACC, MCOA))))

      RESULT = 1

    Endif

  Endif
End RESULT

#steuerschlüssel für konto + coa
#** #############################################################################################
#* Function to get the Taxcode for a given account an coa
#*  @param ACCOUNT  Value Char -> Account
#*  @param MCOA     Value Char -> Main coa
#*  @return RESULT  Local Char -> Taxcode for the given account and coa
#*! #############################################################################################
Funprog GETTAXCODE(ACCOUNT, MCOA)
Value Char ACCOUNT
Value Char MCOA
Local Char RESULT(30)

    If !clalev([F:GACT]) : Local File GACCOUNT  [GACT] : Endif
    Filter [GACT] Where COA = MCOA and ACC = ACCOUNT
    Read First
    If rowcount([GACT]) > 0
      RESULT = [GACT]VAT
    Endif
    Close File [GACT]
End RESULT


#** #############################################################################################
#*  Function to check if a account is a GL account or not
#*  @param ACCOUNT  Value Char    -> Account
#*  @param MCOA     Value Char    -> Main coa
#*  @return RESULT  Local Integer -> 3 -> GL account (collective account); 1 -> Gl account, 2 -> non Gl account
#*! #############################################################################################
Funprog ACCOUNTTYPE(ACCOUNT, MCOA)
Value Char ACCOUNT
Value Char MCOA
Local Integer RESULT
    If !clalev([F:GACT]) : Local File GACCOUNT  [GACT] : Endif

    Filter [GACT] Where COA = MCOA and ACC = ACCOUNT
    Read First
    If rowcount([GACT]) > 0
      If [GACT]SAC = 2 : RESULT = 3 Else : RESULT = 1 Endif
    Else
      RESULT = 2
    Endif
    Close File [GACT]
End RESULT



#** #############################################################################################
#*  Method to treat the VAT limit set in the Global Parameter XETSDDTVAT
#*  @param INDEX              Value    Integer    -> Index of the actual line
#*  @param USEDFROMLINE       Variable Integer    -> array that holds the index of the last line which has accessed a taxline
#*  @param TAXLINEUSAGECOUNT  Variable Integer    -> array that holds the number that indicates the count of access on the taxline
#*  @param AMOUNT             Variable Decimal    -> array that holds the amount for each line of a journal
#*  @param TAXCODE            Variable Char       -> array that holds the taxcode of the account in each line of the journal
#*  @param VATLIMIT           Value    Decimal    -> The VAT limit declared in the global parameter XETSDDTVAT
#*  @param LINETYPE           Value    Integer    -> 1 -> no taxline, 2 -> taxline
#*! #############################################################################################
Subprog TREATVATLIMIT(INDEX, USEDFROMLINE, TAXLINEUSAGECOUNT, AMOUNT, TAXCODE, VATLIMIT, LINETYPE)
Value Integer INDEX
Variable Integer USEDFROMLINE
Variable Integer TAXLINEUSAGECOUNT
Variable Decimal AMOUNT
Variable Char TAXCODE
Value Decimal VATLIMIT
Value Integer LINETYPE
Local Integer I

  #######################################################################
  #if the line is no taxline
  #######################################################################
  If LINETYPE = 1
    #######################################################################
    #if the a taxline is used from this line
    #######################################################################
    I = find(INDEX, USEDFROMLINE)
    If I-1 >= 0
      #################################################################################################
      #if the amount of the used taxline is lower than the VAT limit multiplied by the count of acess
      #################################################################################################
      If AMOUNT(I-1) <= (TAXLINEUSAGECOUNT(I-1) * VATLIMIT)
        ##############################################################################################
        #if VAT rule = 1 (standard) then add the rest of the taxline amount to the gross account line
        ##############################################################################################
        If func GETVATRULE(TAXCODE(INDEX)) = 1
          AMOUNT(INDEX) = AMOUNT(INDEX) + AMOUNT(I-1)
        Endif
        ##############################################################################################
        #set taxline amount to zero
        ##############################################################################################
        AMOUNT(I-1) = 0
        USEDFROMLINE(I-1) = -1 : USEDFROMLINE(INDEX) = I-1
      Endif
    Endif
  #######################################################################
  #if the line is a taxline
  #######################################################################
  Elsif LINETYPE = 2
    #################################################################################################
      #if the amount of thetaxline is lower than the VAT limit multiplied by the count of acess
      #################################################################################################
    If TAXLINEUSAGECOUNT(INDEX) > 0 and AMOUNT(INDEX) <= (TAXLINEUSAGECOUNT(INDEX) * VATLIMIT)
      ##############################################################################################
      #if VAT rule = 1 (standard) then add the rest of the taxline amount to the gross account line
      ##############################################################################################
      If func GETVATRULE(TAXCODE(INDEX)) = 1 and USEDFROMLINE(INDEX) >= 0
        AMOUNT(USEDFROMLINE(INDEX)) += AMOUNT(INDEX)
      Endif
      ##############################################################################################
      #set taxline amount to zero
      ##############################################################################################
      AMOUNT(INDEX) = 0
      USEDFROMLINE(USEDFROMLINE(INDEX)) = -1 :  USEDFROMLINE(INDEX) = -1
    Endif
  Endif
End



#ermitteln der steuerregel (standard (1) oder EU (4))
#** #############################################################################################
#* Get VAT rule for a given Taxcode
#*  @param TAXCODE    Value Char -> Taxcode
#*  @return RESULT    Local Integer -> 1 -> standard; 4 -> EU
#*! #############################################################################################
Funprog GETVATRULE(TAXCODE)
Value Char TAXCODE
Local Integer RESULT
  If !clalev([F:TVB])  : Local File TABVACBPR [TVB]  : Endif
   Read [F:TVB]TVB0 = func GETTAXCODEINFO(TAXCODE,1); [M:DTE]LEG
   RESULT = [F:TVB]REGVAC

End RESULT

#ermitteln von entweder des steuerregelcodes (infotype 1) oder des kontencodes (infotype 2)
#** #############################################################################################
#* Function to get the VAT rule code or the accounting code
#*  @param TAXCODE    Value Char -> Taxcode
#*  @param INFOTYPE   Value Integer -> Infotype (1-> get VAT rule code; 2 -> get accounting code
#*  @return RESULT    Local Char -> Vatrule  or accounting code for the given taxcode
#*! #############################################################################################
Funprog GETTAXCODEINFO(TAXCODE, INFOTYPE)
Value Char TAXCODE
Value Integer INFOTYPE
Local Char RESULT(30)
    If clalev([F:TVT])=0 : Local File TABVAT [TVT] : Endif
    Filter [F:TVT] Where [F:TVT]VAT = TAXCODE
    For [F:TVT]
        Case INFOTYPE
            When 1: RESULT = [F:TVT]VATVAC
            When 2: RESULT = [F:TVT]ACCCOD
        Endcase
    Next
    Filter [F:TVT]

End RESULT

#berechnen und setzen der (Steuer)Beträge
#** #############################################################################################
#*  Calculate the amounts for a datav automatic account line and the related tax account lines
#*  with the same taxcode
#*  @param TAXACCARRAY Variable Integer() -> Array which marks the tax account journal lines
#*  @param TAXCODEARRAY Variable Char() -> Array with the taxcode for the journal lines
#*  @param AMOUNTARRAY Variable Decimal() -> Array with the amounts for the journal lines
#*  @param ACCDATE      Value Date -> Accounting date of the journal which is needen to get the taxrate
#*! #############################################################################################
Funprog DOCALCULATION(TAXACCARRAY, TAXCODEARRAY, AMOUNTARRAY,GLACCINLINE, TAXLINEUSECOUNT, USEDFROMLINE, DEBCREDSIGN, ACCDATE, INDEX, AUTOFLG, ISCEE)
Variable Integer TAXACCARRAY
Variable Char TAXCODEARRAY
Variable Decimal AMOUNTARRAY
Variable Char GLACCINLINE
Variable Integer TAXLINEUSECOUNT
Variable Integer USEDFROMLINE
Variable Integer DEBCREDSIGN
Value Date ACCDATE
Value Integer INDEX
Value Integer AUTOFLG, ISCEE
Local Decimal CALCULATEDTAXAMOUNT, TAXRATE, TAXAMOUNT, TEMPTAXAMOUNT
Local Integer TAXACCINDEX, I, CEETAXINDEX
Local Integer RESULT : RESULT = 1

    TAXRATE = func GETTAXRATE(TAXCODEARRAY(INDEX),ACCDATE)
    TAXAMOUNT = ar2(AMOUNTARRAY(INDEX) / 100 * TAXRATE)

    If AUTOFLG and ![L]ISCEE
      AMOUNTARRAY(INDEX) = AMOUNTARRAY(INDEX) + TAXAMOUNT
    Endif

    For I = 0 To dim(TAXCODEARRAY)-1
        If I <> INDEX
            #test
             # AUTOFLG = 1
            #test end
            If AUTOFLG

              ########################################################################
              # if taxline invalid -> stop and return false
              ########################################################################
              If func ISVALIDTAXLINE(TAXCODEARRAY(I), TAXCODEARRAY(INDEX), TAXACCARRAY(I), DEBCREDSIGN(I), DEBCREDSIGN(INDEX))
#              ###################################################################################
#              # if the taxline is valid -> subtract the calculated taxamount from the amount in the taxline
#              ###################################################################################
                ###################################################################################
                #if reverse charge we have to find and treat the tax transfer posting (in the same way as the normal tax line)
                ###################################################################################
                    ###################################################################################
                    #find index of the transfer posting in the taxlinearray
                    ###################################################################################
                  CEETAXINDEX = func GETCEERELATEDTAXLINEINDEX(AMOUNTARRAY, TAXACCARRAY, DEBCREDSIGN, GLACCINLINE, I)
                  If CEETAXINDEX >= 0
                    AMOUNTARRAY(CEETAXINDEX) = AMOUNTARRAY(CEETAXINDEX) - TAXAMOUNT
                    USEDFROMLINE(CEETAXINDEX) = INDEX
                    TAXLINEUSECOUNT(CEETAXINDEX) += 1
                  Endif
                AMOUNTARRAY(I) = AMOUNTARRAY(I) - TAXAMOUNT
                TAXLINEUSECOUNT(I) += 1
                USEDFROMLINE(I) = INDEX
              Break
            Endif
          Endif
       Endif
    Next
End RESULT


#liefert den Index der Umbuchungszeile für eine reverse charge buchung.
#** #############################################################################################
#*  Function to get the related transfer post line for a taxline in a eu journal
#*  @param AMOUNTARRAY    Variable Decimal ->    array with the amount of each line in a journal
#*  @param TAXACCARRAY    Variable Integer ->    array that indicates if a line (index) is a taxline
#*  @param DEBCREDSIGN    Variable Integer ->    Debit/Credit sign of the taxline
#*  @param GLACCINLINE    Variable Char    ->    GL Account in line
#*  @param TAXINDEX       Value Integer    ->    index of the taxline
#*  @return Result        Local Integer    ->    Index of CEETAXLINE
#*! #############################################################################################
Funprog GETCEERELATEDTAXLINEINDEX(AMOUNTARRAY, TAXACCARRAY, DEBCREDSIGN, GLACCINLINE, TAXINDEX)
Variable Decimal AMOUNTARRAY
Variable Integer TAXACCARRAY
Variable Integer DEBCREDSIGN
Value Integer TAXINDEX
Variable Char GLACCINLINE
Local Integer I, RESULT : RESULT = -1
  For I = 0 To dim(TAXACCARRAY)-1
    If TAXACCARRAY(I) = 1 and AMOUNTARRAY(I) = AMOUNTARRAY(TAXINDEX) and DEBCREDSIGN(I) <> DEBCREDSIGN(TAXINDEX) and GLACCINLINE(I) <> GLACCINLINE(TAXINDEX)
      RESULT = I
    Endif
  Next
End RESULT

#** #############################################################################################
#*  Function to check if a taxline is valid and belongs to the AV account line
#*  @param TAXCODEINTAXLINE    Value Char ->    Taxcode of the taxline
#*  @param TAXCODEINGLLINE     Value Char ->    Taxcode of the GL account line
#*  @param TAXACCFLG           Value Integer -> Flag that indicates that the line is a taxline
#*  @param DEBCREDSIGNTAX      Value Integer -> Debit/Credit sign of the taxline
#*  @param DEBCREDSIGNGL       Value Integer -> Debit/Credit sign of the GL account line
#*  @return Result             Local integer -> 1 if valid
#*! #############################################################################################
Funprog ISVALIDTAXLINE(TAXCODEINTAXLINE, TAXCODEINGLLINE, TAXACCFLG, DEBCREDSIGNTAX, DEBCREDSIGNGL)
Value Char TAXCODEINTAXLINE
Value Char TAXCODEINGLLINE
Value Integer TAXACCFLG
Value Integer DEBCREDSIGNTAX, DEBCREDSIGNGL
Local Integer RESULT : RESULT = 0

    If TAXCODEINTAXLINE = TAXCODEINGLLINE and TAXACCFLG = 1 and DEBCREDSIGNTAX = DEBCREDSIGNGL
            RESULT = 1
    Endif

End RESULT


#** #############################################################################################
#* Function to get the Taxrate for a given taxcode and accounting date
#*  @param TAXCODE    Value Char -> Taxcode
#*  @param ACCDATE   Value Date -> Accounting date of a journal
#*  @return VATRAT    Local Decimal -> Tax rate in %
#*! #############################################################################################
Funprog GETTAXRATE(TAXCODE, ACCDATE)
Value Char TAXCODE
Value Date ACCDATE
Local Decimal VATRAT
Local Date VATSTRDAT
    If !clalev([F:TRA])  : Local File TABRATVAT [TRA]  : Endif
    Filter [F:TRA] Where VAT = TAXCODE
    For [F:TRA]
        If [F:TRA]STRDAT <= ACCDATE : VATRAT = [F:TRA]VATRAT : Endif
    Next
End VATRAT

#** #############################################################################################
#* Function that checks if a account at a given Index is determined as datev automatic account
#*  @param INDEX    Value Integer -> Index to check
#*  @param INDEXAUTOACCOUNT   Variable Integer -> Array that holds the flags which mark
#*  the auto accounts
#*  @return Integer -> 1 if autoaccount
#*! #############################################################################################
Funprog ISAUTOACCOUNT(INDEX, INDEXAUTOACCOUNT)
Value Integer INDEX
Variable Integer INDEXAUTOACCOUNT

End INDEXAUTOACCOUNT(INDEX)

#** #############################################################################################
#* Function that checks if a account at a given Index is determined as non automatic account
#*  @param INDEX    Value Integer -> Index to check
#*  @param INDEXAUTOACCOUNT   Variable Integer -> Array that holds the flags which mark
#*  the non auto accounts
#*  @return Integer -> 1 if non auto account
#*! #############################################################################################
Funprog ISNONAUTOACCOUNT(INDEX, INDEXNONAUTOACCOUNT)
Value Integer INDEX
Variable Integer INDEXNONAUTOACCOUNT

End INDEXNONAUTOACCOUNT(INDEX)

#** #############################################################################################
#* Function that checks if a account at a given Index is determined as non automatic account but
#* anyway has to be treated as a autoaccount
#*  @param INDEX    Value Integer -> Index to check
#*  @param INDEXAUTOACCOUNT   Variable Integer -> Array that holds the flags which mark
#*  the non auto accounts (output of gross amount)
#*  @return Integer -> 1 if non auto account but gross amount
#*! #############################################################################################
Funprog ISNONAUTOBUTGROSSACCOUNT(INDEX, INDEXNONAUTOACCOUNT, VATCODE)
Value Integer INDEX
Variable Integer INDEXNONAUTOACCOUNT
Value Char VATCODE
Local Integer RESULT
    If func ISNONAUTOACCOUNT(INDEX, INDEXNONAUTOACCOUNT) and func HASVATASSIGNMENT([M]LEG, VATCODE)
        RESULT = 1
    Endif
End RESULT

#** #############################################################################################
#* Function that checks if a taxcode has a assignment in the taxcode assignment table
#*  @param VATCODE    Value Char -> Taxcode
#*  @return Result Local Integer -> 1 if a assignment exists
#*! #############################################################################################
Funprog HASVATASSIGNMENT(LEG, VATCODE)
Value Char LEG
Value Char VATCODE
Local Integer RESULT
If !clalev([F:DTT]) : Local File DATEVTAX [DTT]  : Endif
    Read [F:DTT]DTT0 = LEG;VATCODE
    If !fstat
        RESULT = 1
    Endif
End RESULT

#** #############################################################################################
#* Reset temporary arrays
#*! #############################################################################################
$RAZTEMPARRAYS
    Raz INDEXTAXACCOUNT,INDEXAUTOACCOUNT,INDEXTAXCODE,AMOUNT,INDEXNOAUTOACCOUNT,GLACCOUNTINLINE,TAXLINEUSAGECOUNT,USEDFROMLINE
    Local Integer I
    For I = 0 To dim(USEDFROMLINE) -1
      USEDFROMLINE(I) = -2
    Next
Return

#** #############################################################################################
#* Function that returns the accounttype of a given account
#*  @param ACCOUNT    Value Char -> Account
#*  @param MAINCOA    Value Char -> Chart of acccounts
#*  @return Result Local Integer -> 1 -> datev automatic account; 2 -> Tax account; 3 -> non
#*  automatic account
#*! #############################################################################################
Funprog GETACCOUNTTYPE(ACCOUNT, MAINCOA)
Value Char ACCOUNT
Value Char MAINCOA
Local Integer RESULT
    If func ISAUTOACC(ACCOUNT, MAINCOA)
        RESULT = 1
    Elsif [F:GAC2]FLGVAT = 3 or [F:GAC2]FLGVAT = 4
        RESULT = 2
    Else
        RESULT = 3
    Endif

End RESULT


#** #############################################################################################
#* Function that returns if the given account is a datev account or not
#*  @param ACCOUNT    Value Char -> Account
#*  @param MAINCOA    Value Char -> Chart of acccounts
#*  @return Result Local Integer -> 1 -> datev automatic account
#*! #############################################################################################
Funprog ISAUTOACC(ACCOUNT, MAINCOA)
Value Char ACCOUNT
Value Char MAINCOA
Local Integer RESULT
    If !clalev([F:DTA]) : Local File DATEVGLACC [DTA]  : Endif
    Read [F:DTA]DTA0 = MAINCOA;ACCOUNT
    If !fstat
        If [F:DTA]FLGAUTO = 2 : RESULT = 1 : Endif
    Endif
End RESULT

#** #############################################################################################
#* Declaration of temporary arrays to hold the data of a set of journal lines
#*! #############################################################################################
$DECLARETEMPARRAYS

Local Integer INDEXTAXACCOUNT(COUNT)
Local Integer INDEXAUTOACCOUNT(COUNT)
Local Integer INDEXNOAUTOACCOUNT(COUNT)
Local Char INDEXTAXCODE(30)(COUNT)
Local Decimal AMOUNT(COUNT)
Local Char GLACCOUNTINLINE(30)(COUNT)
Local Integer TAXLINEUSAGECOUNT(COUNT)
Local Integer USEDFROMLINE(COUNT)
Local Integer I
For I = 0 To dim(USEDFROMLINE) -1
  USEDFROMLINE(I) = -2
Next
Local Integer DEBCREDSIGN(COUNT)

[L]FLGTEMPARR = 1
Return

#** #############################################################################################
#* closing the additional table instances to run throug a set of journal lines
#*! #############################################################################################
$CLOSEADDTABLES
    Close File [F:CPY2],[F:GTE2],[F:GCM2],[F:LED2],[F:BPR2],[F:DAE2],[F:HAE2],[F:COA2],[F:GAC2]
Return

#** #############################################################################################
#* opening the additional table instances to run throug a set of journal lines
#*! #############################################################################################
$OPENADDTABLES
    If !clalev([F:CPY2])  : Local File COMPANY    [CPY2]  : Endif
    If !clalev([F:FCY2])  : Local File FACILITY   [FCY2]  : Endif
    If !clalev([F:GCM2])  : Local File GACM       [GCM2]  : Endif
    If !clalev([F:LED2])  : Local File GLED       [LED2]  : Endif
    If !clalev([F:BPR2])  : Local File BPARTNER   [BPR2]  : Endif
    If !clalev([F:DAE2])  : Local File GACCENTRYD [DAE2] : Endif
    If !clalev([F:HAE2])  : Local File GACCENTRY  [HAE2] : Endif
    If !clalev([F:COA2])  : Local File GCOA       [COA2] : Endif
    If !clalev([F:GTE2])  : Local File GTYPACCENT [GTE2] : Endif
    If !clalev([F:GAC2])  : Local File GACCOUNT   [GAC2]  : Endif
Return

#** #############################################################################################
#* query to get the needed data of a set of journal lines
#*! #############################################################################################
$JOURNALQUERYFORNUM
    Call SETFILTERSTRINGS(FIL1, FIL2, FIL3, FIL4, 2, OPT)
    Link [DAE2] With
&  [F:CPY2]CPY0  = [F:DAE2]CPY
& ,[F:HAE2]HAE0 = [F:DAE2]TYP ; [F:DAE2]NUM
& ,[F:GCM2]GCM0 = [F:CPY2]ACM
& ,[F:LED2]LED0 = [F:GCM2]LED(LEDINDEX)
& ,[F:COA2]COA0 = [F:LED2]COA
& ,[F:GAC2]GAC0 = [F:DAE2]COA;[F:DAE2]ACC
& ,[F:GTE2]GTE0 = [F:DAE2]TYP ; [M:DTE]LEG
& ,[F:BPR2]BPR0 = [F:DAE2]OFFACC
& As [LNKJ]
& Where evalue(FIL1 + FIL2 + FIL3)
& & [F:HAE2]CAT = 1
& & [F:DAE2]COA = [F:COA2]COA
& & [F:DAE2]NUM = JNUMBER
& & [F:DAE2]LED = [L]MAINLED


#& & ([F:GTE2]VAT = 2 or [F:GTE2]VATPAI = 2)
Return


#** #############################################################################################
#* query to get all journals for the chosen settings
#*! #############################################################################################
$ALLJOURNALQUERY
    Call SETFILTERSTRINGS(FIL1, FIL2, FIL3, FIL4, 1, OPT)

    Link [DAE] With
&  [F:CPY]CPY0  = [F:DAE]CPY
& ,[F:HAE]HAE0 = [F:DAE]TYP ; [F:DAE]NUM
& ,[F:GCM]GCM0 = [F:CPY]ACM
& ,[F:LED]LED0 = [F:GCM]LED(LEDINDEX)
& ,[F:COA]COA0 = [F:LED]COA
& ,[F:GAC]GAC0 = [F:DAE]COA;[F:DAE]ACC
& ,[F:GTE]GTE0 = [F:DAE]TYP
& As [LNKN]
& Where evalue(FIL1 + FIL4 + FIL2 + FIL3)
& & [F:HAE]CAT = 1
& & [F:DAE]COA = [F:COA]COA

Return

#** #############################################################################################
#*  Set the filterstrings for the journal querys.
#*  @param FIL1  Variable Char -> First part of filter string
#*  @param FIL2  Variable Char -> Second part of filter string
#*  @param FIL3  Variable Char -> Third part of filter string
#*  @param QTYPE Value Integer -> 1 -> Filter string for all journal query; 2 -> Filter string for
#*  the query for a specific journalnumber 3 -> Filter string for
#*  the query for temporary data sets
#*  @param OPT  Value Char -> Parameter for date selection
#*! #############################################################################################
Subprog SETFILTERSTRINGS(FIL1, FIL2, FIL3, FIL4, QTYPE, OPT)
    Variable Char FIL1
    Variable Char FIL2
    Variable Char FIL3
    Variable Char FIL4
    Value Integer QTYPE
    Value Char OPT
    Raz FIL1, FIL2, FIL3, FIL4

    If QTYPE = 1
     FIL1 += "[F:DAE]CPY = [M:DTE]CPY"
     If [M:DTE]FLGONLYCLOSE = 2 :  FIL1 += " &[F:GTE]PER = 3" : Endif
     If [M:DTE]FLGNOFORWARD <> 2 : FIL1 += " &[F:GTE]PER <> 2" : Endif
     If [M:DTE]FLGNEWJOU = 2 :     FIL1 += " &[F:HAE]EXPNUM > " + func GETCHRONO() : Endif
    Elsif QTYPE = 2
     FIL1 += "[F:DAE2]CPY = [M:DTE]CPY"
     If [M:DTE]FLGONLYCLOSE = 2  : FIL1 += " &[F:GTE2]PER = 3" : Endif
     If [M:DTE]FLGNOFORWARD <> 2 : FIL1 += " &[F:GTE]PER <> 2" : Endif
    Endif

    If [M:DTE]FCY <> ""
      If QTYPE = 1
        FIL1 += " &[F:DAE]FCYLIN = [M:DTE]FCY"
      Else
        FIL1 += " &[F:DAE2]FCYLIN = [M:DTE]FCY"
      Endif
    Endif

    #conditions for documenttype
    If [M:DTE]FLGDCOTYP = 2
      If [M:DTE]TYPSTR <> ""
        #If QTYPE = 1
         FIL4 = "&[F:DAE]TYP =[M:DTE]TYPSTR"
      Endif
    Endif


    #conditions for the daterange of the accountings
    If [M:DTE]DATSTR <> [0/0/0]
      If OPT = "1" Then
        If QTYPE = 1
            FIL2 += " &[F:DAE]ACCDAT>=[M:DTE]DATSTR"
        Else
            FIL2 += " &[F:DAE2]ACCDAT>=[M:DTE]DATSTR"
        Endif
      Else
        If QTYPE = 1
            FIL2 += " & (([F:HAE]BPRDATVCR>=[M:DTE]DATSTR & [F:HAE]BPRDATVCR <> [0/0/0]) | ([F:HAE]BPRDATVCR = [0/0/0] & [F:DAE]ACCDAT>=[M:DTE]DATSTR))"
        Else
            FIL2 += " & (([F:HAE2]BPRDATVCR>=[M:DTE]DATSTR & [F:HAE2]BPRDATVCR <> [0/0/0]) | ([F:HAE2]BPRDATVCR = [0/0/0] & [F:DAE2]ACCDAT>=[M:DTE]DATSTR))"
        Endif
      Endif
    Endif

    If [M:DTE]DATEND<>[0/0/0]
      If OPT = "1" Then
        If QTYPE = 1
            FIL3 += " &[F:DAE]ACCDAT<=[M:DTE]DATEND"
        Else
            FIL3 += " &[F:DAE2]ACCDAT<=[M:DTE]DATEND"
        Endif
      Else
        If QTYPE = 1
            FIL3 += " & (([F:HAE]BPRDATVCR<=[M:DTE]DATEND & [F:HAE]BPRDATVCR <> [0/0/0]) | ([F:HAE]BPRDATVCR = [0/0/0] & [F:DAE]ACCDAT<=[M:DTE]DATEND))"
        Else
            FIL3 += " & (([F:HAE2]BPRDATVCR<=[M:DTE]DATEND & [F:HAE2]BPRDATVCR <> [0/0/0]) | ([F:HAE2]BPRDATVCR = [0/0/0] & [F:DAE2]ACCDAT<=[M:DTE]DATEND))"
        Endif

      Endif
    Endif
End

#** #############################################################################################
#* Fills the headline for the GL accounts and calls the method for writing the line
#*! #############################################################################################
$WRITEGLACCOUNTDESC
    GLACCOUNTS(0) = "Konto" : GLACCOUNTS(1) = "Kontenbeschriftung" : GLACCOUNTS(2) = "Sprach-ID"
    Call WRITELINE(GLACCOUNTS)
Return

#** #############################################################################################
#* Obtain and writes the BP Customer account data
#*! #############################################################################################
$WRITEBPACCOUNTS
    Gosub BPACCOUNTCOMMONACTIONS
    Gosub WRITEBPACCOUNTDATA
    Openo Using [YYY]
    Call DOWNLOADFILE(EXPORTFILE, EXPORTNAME)
Return


#** #############################################################################################
#* Does common actions for BP customers and BP suppliers
#*! #############################################################################################
$BPACCOUNTCOMMONACTIONS
    Call OPENFILE(2, [L]EXPORTNAME, [L]EXPORTFILE, [L]URL)
    Call INITLINES([L]BPACCOUNTS, [L]BPACCOUNTTEXTINDEX)
    Call WRITEHEADER(HEADER, [L]HEADERTEXTINDEX, 2, [L]GLACCOUNTLENGTH)
    Gosub WRITEBPACCOUNTDESC
Return

