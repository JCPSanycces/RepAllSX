Subprog AM_DATSTR(VALEUR)
Variable Date    VALEUR
  If VALEUR <>[0/0/0] and [M:DTE]DATEND <>[0/0/0]
    If VALEUR > [M:DTE]DATEND or year([M:DTE]DATEND) <> year(VALEUR): Call ERREURT(mess(264,107,1), 1) From GESECRAN : mkstat = 2: Endif
  Endif
End


Subprog AM_DATEND(VALEUR)
Variable Date    VALEUR
  If VALEUR <>[0/0/0] and [M:DTE]DATSTR <>[0/0/0]
    If VALEUR < [M:DTE]DATSTR or year([M:DTE]DATSTR) <> year(VALEUR): Call ERREURT(mess(264,107,1), 1) From GESECRAN : mkstat = 2: Endif
  Endif
End


Subprog AM_ACCNO(VALEUR)
Variable Decimal VALEUR
  If VALEUR < 1001 or VALEUR > 9999999
    Call ERREURT(mess(3, 3653,1), 1) From GESECRAN
    mkstat = 2
  Endif
End


Subprog C_VOLFIL(VALEUR)
Variable Char VALEUR()

    Gosub ENUM_VOLFIL_TYPE From ASYRSTO
    mkstat = func ASYRSTO.CTL_VOLFIL( [M]TYPEXP, VALEUR, [M]DIRDATFIL, E_TYPE_FOLDER, GMESSAGE )
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR

    If VALEUR = 1
        Raz   [M]VOLFIL
        Affzo [M]VOLFIL
        Grizo [M]VOLFIL
    Else
         Actzo [M]VOLFIL
         [M]VOLFIL = func AFNC.PARAM( "GERDATPAT", [M]CPY )
         Affzo [M]VOLFIL
    Endif
End


Subprog AM_FLGGLACCRED(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2
    Actzo [M:DTE]GLACCRED
    Actzo [M:DTE]GLACCREDDIR
    Actzo [M:DTE]GLREDLEFT
    [M:DTE]GLREDLEFT = 1
  Else
    Raz [M:DTE]GLACCRED
    Raz [M:DTE]GLREDLEFT
    Raz [M:DTE]GLACCREDDIR
    Grizo [M:DTE]GLACCRED
    Grizo [M:DTE]GLREDLEFT
    Grizo [M:DTE]GLACCREDDIR
  Endif
End

Subprog AM_FLGBPACCRED(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
    Actzo [M:DTE]BPREDL
    Actzo [M:DTE]BPREDR
    Actzo [M:DTE]BPREDDIR
    [M:DTE]BPREDDIR = 1
    Affzo [M:DTE]BPREDDIR
  Else
    [M:DTE]BPREDL = 1
    Affzo [M:DTE]BPREDL
    Grizo [M:DTE]BPREDL

    Grizo [M:DTE]BPACCREDL
    [M:DTE]BPREDR = 1
    Affzo [M:DTE]BPREDR
    Grizo [M:DTE]BPREDR

    Grizo [M:DTE]BPACCREDR
    Grizo [M:DTE]BPREDLEFT
    Grizo [M:DTE]BPREDDIR
  Endif
End


Subprog AM_GLACCREDDIR(VALEUR)
Variable Integer VALEUR
End

Subprog AM_BPREDDIR(VALEUR)
Variable Integer VALEUR
[M:DTE]BPREDLEFT = 1
  Affzo [M:DTE]BPREDLEFT
  If VALEUR = 2
    [M:DTE]BPREDL = 1
    Affzo [M:DTE]BPREDL
    Grizo [M:DTE]BPREDL
    Grizo [M:DTE]BPACCREDL
  Else
    Actzo [M:DTE]BPREDL
  Endif

End




