###################################################################################
###################################################################################
## ACTION Mise à jour des dimensions X3                                           #
###################################################################################
$ACTION
  Case ACTION
    When "OUVRE_DIM"         : Gosub OUVRE_DIM
    When "FILTRE_DIM_INC"    : #Gosub FILTRE_DIM_INC
    When "FIN_DIM"           : Gosub FIN_DIM
    When "FERME_DIM"         : Gosub FERME_DIM
  Endcase
Return

###################################################################################
$OUVRE_DIM

  # Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
  #--called from the wanted dimensions
  #Gosub TRIGGER_AUDIBI From TRTSYNBISAD
  # End issue X3-38377
  # ---------------------------------------------------
  Case TABLE
    When "D_SADSIH"          : Gosub OUVRE_DIM_SADSIH
    When "D_SADSID"          : Gosub OUVRE_DIM_SADSID
    When "D_SADSIDSVF"       : Gosub OUVRE_DIM_SADSIDSVF
    When "D_SADSIDDUD"       : Gosub OUVRE_DIM_SADSIDDUD
    When "D_SADSDH"          : Gosub OUVRE_DIM_SADSDH
    When "D_SADSDD"          : Gosub OUVRE_DIM_SADSDD
    When "D_SADSDDSVF"       : Gosub OUVRE_DIM_SADSDDSVF
    When "D_SADSQH"          : Gosub OUVRE_DIM_SADSQH
    When "D_SADSQD"          : Gosub OUVRE_DIM_SADSQD
    When "D_SADSQDSVF"       : Gosub OUVRE_DIM_SADSQDSVF
    When "D_SADSRH"          : Gosub OUVRE_DIM_SADSRH
    When "D_SADSRD"          : Gosub OUVRE_DIM_SADSRD
    When "D_SADSOH"          : Gosub OUVRE_DIM_SADSOH
    When "D_SADSOQ"          : Gosub OUVRE_DIM_SADSOQ
    When "D_SADSOP"          : Gosub OUVRE_DIM_SADSOP
    When "D_SADSOQSVF"       : Gosub OUVRE_DIM_SADSOQSVF
  Endcase
Return

