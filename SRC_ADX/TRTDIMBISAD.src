#----------------------------------------------------------------------------------
$OUVRE_DIM_SADSOQSVF
  Gosub OUVRE_DIM_DETAIL
  Local File =MACHINE+"@"+[F:ABW]COD+".D_SADSOQ"           [BBB_]
Return

#----------------------------------------------------------------------------------
$OUVRE_DIM_SADSOQ
  Gosub OUVRE_DIM_DETAIL

  #Call ECR_TIME("***********************************************OUVRE_DIM_SADSOQ Début") From DOSSUB
  #--Remplissage table temporaire paramétrée dans le link de la dimension
  Local File =GDOSSIER+".BITMPSORDERQ"                     [BISOQ_]
  Local File =GDOSSIER+".AUDITBI"                          [WAUI_]

  Local File =GDOSSIER+".SORDERP"                          [WSOP_]
  Local File =GDOSSIER+".SORDERQ"                          [WSOQ_]

  Local Char SWHERE(250)
  Local Char SVID1 (type([F:WAUI_]ID1)-10)
  Local Char SVID2 (type([F:WAUI_]ID1)-10)(1..2)

  Local Integer IADXLOG
  IADXLOG = adxlog
  If IADXLOG = 0 Then
    Trbegin [BISOQ_]
  Endif

  Delete [BISOQ_] Where [BISOQ_]BISOQADXUID = adxuid(1)

	If [L]GEN <> 2 Then
		Raz SVID1
	  Filter [WAUI_] Where (TBL = [F:ABI]TABORG) and (STABI = 2 or STABI = 4) and EVT <> "DELETE" Order By ID1;ID2;SEQ Desc

		For [WAUI_]
			If SVID1 <> ([F:WAUI_]ID1+"~"+[F:WAUI_]ID2) Then
				SWHERE = " (SOHNUM ='"+[F:WAUI_]ID1+"')"
				Call DECOUPE_TILDES([F:WAUI_]ID2,SVID2)
				If SVID2(1)<>"" and SVID2(2)<>""
				  SWHERE -= "& (SOPLIN="+SVID2(1)-"& SOQSEQ="+SVID2(2)+")"
				  Gosub CREATE_BISOQ_TRAVAIL
				  SVID1 = [F:WAUI_]ID1+"~"+[F:WAUI_]ID2
				Endif
			Endif
		Next
		Filter [WAUI_]
	Else
		SWHERE = " (1=1)"
		Gosub CREATE_BISOQ_TRAVAIL
	Endif
	If IADXLOG = 0 Then
    Commit
  Endif
  Close Local File [BISOQ_]
  Close Local File [WAUI_]
  Close Local File [WSOP_]
  Close Local File [WSOQ_]
  #Call ECR_TIME("***********************************************OUVRE_DIM_SADSOQ Fin") From DOSSUB
Return

#----------------------------------------------------------------------------------
$CREATE_BISOQ_TRAVAIL
  #--Commandes ouvertes
  Filter [WSOQ_] Where SOHCAT=4 and DEMSTA=1 and evalue(SWHERE)
  For [WSOQ_]
    Raz [F:BISOQ_]
    [F:BISOQ_]BISOQADXUID = adxuid(1)
    [F:BISOQ_]SOHNUM      = [WSOQ_]SOHNUM
    [F:BISOQ_]SOPLIN      = [WSOQ_]SOPLIN
    [F:BISOQ_]SOQSEQ      = [WSOQ_]SOQSEQ
    [F:BISOQ_]SOPSEQ      = 0
    Filter [WSOP_] Where SOHNUM=[WSOQ_]SOHNUM and SOPLIN=[WSOQ_]SOPLIN and STRDAT<=[WSOQ_]DEMDLVDAT Order By STRDAT Desc
    For [WSOP_]
      [F:BISOQ_]SOPSEQ    = [WSOP_]SOPSEQ
      Break
    Next
    Filter [WSOP_]
    Write [F:BISOQ_]
  Next
  Filter [WSOQ_]
  #--Commandes normales
  Filter [WSOQ_] Where SOHCAT<>4 and evalue(SWHERE)
  For [WSOQ_]
    Raz [F:BISOQ_]
    [F:BISOQ_]BISOQADXUID = adxuid(1)
    [F:BISOQ_]SOHNUM      = [WSOQ_]SOHNUM
    [F:BISOQ_]SOPLIN      = [WSOQ_]SOPLIN
    [F:BISOQ_]SOQSEQ      = [WSOQ_]SOQSEQ
    [F:BISOQ_]SOPSEQ      = [WSOQ_]SOQSEQ
    Write [F:BISOQ_]
  Next
  Filter [WSOQ_]
Return

#----------------------------------------------------------------------------------
$OUVRE_DIM_SADSOP
Local Integer IADXLOG
Local Char SWHERE(250)

  Gosub OUVRE_DIM_DETAIL
  #Call ECR_TIME("***********************************************OUVRE_DIM_SADSOQ Début") From DOSSUB
  #--Remplissage table temporaire paramétrée dans le link de la dimension
  Local File =GDOSSIER+".BITMPSORDERP"                     [BISOP_]
  Local File =GDOSSIER+".AUDITBI"                          [WAUI_]

  Local File =GDOSSIER+".SORDERP"                          [WSOP_]
  Local File =GDOSSIER+".SORDERQ"                          [WSOQ_]

Local Char SVID1 (type([F:WAUI_]ID1)-10)
Local Char SVID2 (type([F:WAUI_]ID1)-10)(1..2)

  IADXLOG = adxlog
  If IADXLOG = 0 Then
    Trbegin [BISOP_]
  Endif
  Delete [BISOP_] Where [BISOP_]BISOPADXUID = adxuid(1)
	If [L]GEN <> 2 Then
		Raz SVID1
		Filter [WAUI_] Where (TBL = [F:ABI]TABORG) and (STABI = 2 or STABI = 4) and EVT <> "DELETE" Order By ID1; ID2; SEQ Desc
		For [WAUI_]
			If SVID1 <> ([F:WAUI_]ID1+"~"+[F:WAUI_]ID2) Then
				SWHERE = " (SOHNUM ='"+[F:WAUI_]ID1+"')"
				Call DECOUPE_TILDES([F:WAUI_]ID2,SVID2)
				If SVID2(1)<>"" and SVID2(2)<>""
				  SWHERE -= "& (SOPLIN="+SVID2(1)-"& SOQSEQ="+SVID2(2)+")"
				  Gosub CREATE_BISOP_TRAVAIL
				  SVID1 = [F:WAUI_]ID1+"~"+[F:WAUI_]ID2
				Endif
			Endif
		Next
		Filter [WAUI_]
	Else
		SWHERE = " (1=1)"
		Gosub CREATE_BISOP_TRAVAIL
	Endif
	If IADXLOG = 0 Then
    Commit
  Endif
  Close Local File [BISOP_]
  Close Local File [WAUI_]
  Close Local File [WSOP_]
  Close Local File [WSOQ_]
  #Call ECR_TIME("***********************************************OUVRE_DIM_SADSOQ Fin") From DOSSUB
Return

#----------------------------------------------------------------------------------
$CREATE_BISOP_TRAVAIL
  #--Commandes ouvertes
  Filter [WSOQ_] Where SOHCAT=4 and DEMSTA=1 and evalue(SWHERE)
  For [WSOQ_]
    Raz [F:BISOP_]
    [F:BISOP_]BISOPADXUID = adxuid(1)
    [F:BISOP_]SOHNUM      = [WSOQ_]SOHNUM
    [F:BISOP_]SOPLIN      = [WSOQ_]SOPLIN
    [F:BISOP_]SOPSEQ      = 0
    Filter [WSOP_] Where SOHNUM=[WSOQ_]SOHNUM and SOPLIN=[WSOQ_]SOPLIN and STRDAT<=[WSOQ_]DEMDLVDAT Order By STRDAT Desc
    For [WSOP_]
      [F:BISOP_]SOPSEQ    = [WSOP_]SOPSEQ
      Break
    Next
    Filter [WSOP_]
    Write [F:BISOP_]
  Next
  Filter [WSOQ_]
  #--Commandes normales
  Filter [WSOQ_] Where SOHCAT<>4 and evalue(SWHERE)
  For [WSOQ_]
    Raz [F:BISOP_]
    [F:BISOP_]BISOPADXUID = adxuid(1)
    [F:BISOP_]SOHNUM      = [WSOQ_]SOHNUM
    [F:BISOP_]SOPLIN      = [WSOQ_]SOPLIN
    [F:BISOP_]SOPSEQ      = [WSOQ_]SOQSEQ
    Write [F:BISOP_]
  Next
  Filter [WSOQ_]
Return

