###################################################################################
$FIN_DIM
  Case TABLE
    When "D_SADSIDSVF"       : Gosub DELETE_DIM_SADSIDSVF
    When "D_SADSIDDUD"       : Gosub DELETE_DIM_SADSIDDUD
    When "D_SADSDDSVF"       : Gosub DELETE_DIM_SADSDDSVF
    When "D_SADSQDSVF"       : Gosub DELETE_DIM_SADSQDSVF
    When "D_SADSOQSVF"       : Gosub DELETE_DIM_SADSOQSVF
    When "D_SADSOP"          : Gosub FIN_DIM_SADSOP
    When Default
  Endcase
Return

#----------------------------------------------------------------------------------
$DELETE_DIM_SADSIDSVF
  Call DELETE_D_SADLINE_MANAGE("SADSID", "SVCRFOOT")
Return

#----------------------------------------------------------------------------------
$DELETE_DIM_SADSIDDUD
  Call DELETE_D_SADLINE_MANAGE("SADSID", "GACCDUDATE")
Return

#----------------------------------------------------------------------------------
$DELETE_DIM_SADSDDSVF
  Call DELETE_D_SADLINE_MANAGE("SADSDD", "SVCRFOOT")
Return

#----------------------------------------------------------------------------------
$DELETE_DIM_SADSQDSVF
  Call DELETE_D_SADLINE_MANAGE("SADSQD", "SVCRFOOT")
Return

#----------------------------------------------------------------------------------
$DELETE_DIM_SADSOQSVF
  Call DELETE_D_SADLINE_MANAGE("SADSOQ", "SVCRFOOT")
Return

#----------------------------------------------------------------------------------
$FIN_DIM_SADSOP
  #--For Open Orders ([SOQ]SOHCAT=4)
  #--In some cases, and due to the [SOP]STRDAT<=[SOQ]DEMDLVDAT restriction,
  #--A [SOQ] delivery request line is not associated to a [SOP]Product line (no price applied)
  #--We therefor need to create the entries from BITMPSORDERQ that have the SOPLIN=0 in the SADSOP dimension

Return

###################################################################################
$FERME_DIM
  If clalev([F:TVB])   : Close Local File [TVB]   : Endif
  If clalev([F:TVT])   : Close Local File [TVT]   : Endif
  If clalev([F:TPT])   : Close Local File [TPT]   : Endif
  If clalev([F:TDA])   : Close Local File [TDA]   : Endif
  If clalev([F:TSC])   : Close Local File [TSC]   : Endif
  If clalev([F:TEC])   : Close Local File [TEC]   : Endif
  If clalev([F:TSO])   : Close Local File [TSO]   : Endif
  If clalev([F:TSV])   : Close Local File [TSV]   : Endif
  If clalev([F:TSD])   : Close Local File [TSD]   : Endif
  If clalev([F:TRE])   : Close Local File [TRE]   : Endif
  #
  If clalev([F:BBB_])  : Close Local File [BBB_]  : Endif
  # --- CAS DELETE (début)
  #  If clalev([F:WDUSI_])  : Close Local File [WDUSI_]   : Endif # Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
  # --- CAS DELETE (fin)
  Case [L]TABLE
    When "D_SADSOQ" : Gosub RAZ_SADSOQ_BITMPSORDER
    When "D_SADSOP" : Gosub RAZ_SADSOP_BITMPSORDER
  Endcase

Return

###################################################################################
$RAZ_SADSOQ_BITMPSORDER
Local Integer IADXLOG

  If clalev([F:BISOQ]) = 0 Then
    Return
  Endif
  #--Raz all entries from BITMPSORDER table for current adxuid(1)
  IADXLOG = adxlog
  If IADXLOG = 0 Then
    Trbegin [BISOQ]
  Endif
  Delete [BISOQ] Where [BISOQ]BISOQADXUID = adxuid(1)
  If IADXLOG = 0 Then
    Commit
  Endif
Return

###################################################################################
$RAZ_SADSOP_BITMPSORDER
Local Integer IADXLOG

  If clalev([F:BISOP]) = 0 Then
    Return
  Endif
  #--Raz all entries from BITMPSORDER table for current adxuid(1)
  IADXLOG = adxlog
  If IADXLOG = 0 Then
    Trbegin [BISOP]
  Endif
  Delete [BISOP] Where [BISOP]BISOPADXUID = adxuid(1)
  If IADXLOG = 0 Then
    Commit
  Endif
Return

###################################################################################
###################################################################################
Subprog DECOUPE_TILDES(SCHAINE, STAB)
Value Char SCHAINE
Variable Char STAB()(0..)

Local Integer NI0
Local Integer NI1
Local Integer NINDTAB
Local Integer NEXIT

  Raz STAB
  NINDTAB = 0
  If instr(0, SCHAINE, "~") = 0 Then
    STAB(NINDTAB) = SCHAINE
  Else
    NI0 = 1
    NEXIT = 0
    Repeat
      NI1 = instr(NI0, SCHAINE, "~")
      If NI1 = 0 Then
        NI1 = len(SCHAINE) + 1
        NEXIT = 1
      Endif
      STAB(NINDTAB) = seg$(SCHAINE, NI0, NI1-1)
      NI0 = NI1 + 1
      NINDTAB += 1
    Until NEXIT = 1
  Endif
End

###################################################################################
Subprog DELETE_D_SADLINE_MANAGE(SDIMENSION, STABLE)
Value Char SDIMENSION
Value Char STABLE

Local Char STAB(GLONVCR)(0..10)
Local Integer NI
Local Char SKEY(GLONVCR)
Local Integer IKEY
Local Integer ISKEY0
Local Integer ISKEY1
Local Integer IDOCTYPLIN

  Local File =GDOSSIER+".AUDITBI" [WAUI_]
  Local File =GDOSSIER+".AUDITBI" [WAUIJ_]

  # -------------------------
  For [WAUI_] Where [F:WAUI_]TBL = STABLE and [F:WAUI_]EVT = "DELETE" and [F:WAUI_]STABI = 4
    #-- Il ne faut pas effectuer le "delete" si l'événement "DELETE" est accompagné par un "INSERT" ayant un n° de seq supérieur !!!
    #-- et parce que nous sommes dans le $FIN_DIM et que la dimension STABLE a déjà été synchonisée ("INSERT" effectué qu'il ne faut pas supprimer)
    Filter [WAUIJ_] Where [F:WAUIJ_]TBL = STABLE and [F:WAUIJ_]EVT = "INSERT" and [F:WAUIJ_]STABI = 4 and [WAUIJ_]SEQ>[WAUI_]SEQ and
&                         [F:WAUIJ_]ID1 = [WAUI_]ID1 and [F:WAUIJ_]ID2 = [WAUI_]ID2
    Look [WAUIJ_] First
    If fstat
      Case SDIMENSION
        When "SADSID"
          # -------------------------
          If STABLE = "SVCRFOOT" Then
            IDOCTYPLIN = 2
            Call DECOUPE_TILDES([F:WAUI_]ID2, STAB)
            SKEY = [F:WAUI_]ID1
            IKEY = val(STAB(1))
          Elsif STABLE = "GACCDUDATE" Then
            IDOCTYPLIN = 3
            Call DECOUPE_TILDES([F:WAUI_]ID2, STAB)
            SKEY = STAB(0)
            ISKEY0 = val(STAB(1))
            ISKEY1 = val(STAB(2))
            IKEY = func FORMAT_SIDLIN_DOCTYPLIN3(ISKEY0, ISKEY1)
          Endif
          If SKEY<>"" and IKEY>0
            Delete [BBB_] Where [F:BBB_]SIHNUM = SKEY and [F:BBB_]DOCTYPLIN = IDOCTYPLIN and [F:BBB_]SIDLIN = IKEY
          Endif
        When "SADSDD"
          # -------------------------
          If STABLE = "SVCRFOOT" Then
            IDOCTYPLIN = 2
            Call DECOUPE_TILDES([F:WAUI_]ID2, STAB)
            SKEY = [F:WAUI_]ID1
            IKEY = val(STAB(1))
          Endif
          If SKEY<>"" and IKEY>0
            Delete [BBB_] Where [F:BBB_]SDHNUM = SKEY and [F:BBB_]DOCTYPLIN = IDOCTYPLIN and [F:BBB_]SDDLIN = IKEY
          Endif
        When "SADSQD"
          # -------------------------
          If STABLE = "SVCRFOOT" Then
            IDOCTYPLIN = 2
            Call DECOUPE_TILDES([F:WAUI_]ID2, STAB)
            SKEY = [F:WAUI_]ID1
            IKEY = val(STAB(1))
          Endif
          If SKEY<>"" and IKEY>0
            Delete [BBB_] Where [F:BBB_]SQHNUM = SKEY and [F:BBB_]DOCTYPLIN = IDOCTYPLIN and [F:BBB_]SQDLIN = IKEY
          Endif
        When "SADSOQ"
          # -------------------------
          If STABLE = "SVCRFOOT" Then
            IDOCTYPLIN = 2
            Call DECOUPE_TILDES([F:WAUI_]ID2, STAB)
            SKEY = [F:WAUI_]ID1
            IKEY = val(STAB(1))
          Endif
          If SKEY<>"" and IKEY>0
            Delete [BBB_] Where [F:BBB_]SOHNUM = SKEY and [F:BBB_]DOCTYPLIN = IDOCTYPLIN and [F:BBB_]SOPLIN = IKEY and [F:BBB_]SOQSEQ = 1000
          Endif
        When Default
      Endcase
    Endif
    Filter [WAUIJ_]
  Next
  # -------------------------
  Close Local File [WAUI_]
  Close Local File [WAUIJ_]
End

###################################################################################
###################################################################################
###################################################################################
## Parcours de SVCRFOOT pour alimenter la dimension SADSID Lignes factures
###################################################################################
Funprog CREATESADSIDSVF(IDOCTYPLIN)
Value Integer IDOCTYPLIN

Local Integer IREAD

  IREAD = 0
  Read [F:BBB_]SSID0=[F:SVF]VCRNUM;IDOCTYPLIN;[F:SVF]DTA
  If fstat Then
    Raz [F:BBB_]
    IREAD = 1
  Endif
  # ---------------------
  [F:BBB_]SIHNUM                = [F:SVF]VCRNUM
  [F:BBB_]SIDLIN                = [F:SVF]DTA
  [F:BBB_]DOCTYPLIN             = IDOCTYPLIN
  Gosub DATA_KEY_SVCRFOOT
  # ---------------------
  If IREAD = 1 Then
    Write   [F:BBB_]
  Else
    Rewrite [F:BBB_]
  Endif
End IDOCTYPLIN

###################################################################################
Funprog FORMAT_SIDLIN_DOCTYPLIN3(ILIG, IDUDLIG)
Value Integer ILIG
Value Integer IDUDLIG

Local Integer IARENDRE

  IARENDRE = (ILIG * 1000) + IDUDLIG
End IARENDRE

###################################################################################
## Parcours de GACCDUDATE pour alimenter la dimension SADSID Lignes factures
###################################################################################
Funprog CREATESADSIDDUD(IDOCTYPLIN)
Value Integer IDOCTYPLIN

Local Integer IREAD
Local Integer IKEY

  IREAD = 0
  IKEY = func FORMAT_SIDLIN_DOCTYPLIN3([F:DUD]LIG, [F:DUD]DUDLIG)
  Read [F:BBB_]SSID0=[F:DUD]NUM;IDOCTYPLIN;IKEY
  If fstat Then
    Raz [F:BBB_]
    IREAD = 1
  Endif
  # ---------------------
  [F:BBB_]SIHNUM                = [F:DUD]NUM
  [F:BBB_]SIDLIN                = IKEY
  [F:BBB_]DOCTYPLIN             = IDOCTYPLIN
  #
  If dim([F:BBB_]DUDTYP)>0      : [F:BBB_]DUDTYP     = [F:DUD]TYP    : Endif
  If dim([F:BBB_]DUDNUM)>0      : [F:BBB_]DUDNUM     = [F:DUD]NUM    : Endif
  If dim([F:BBB_]DUDLIG)>0      : [F:BBB_]DUDLIG     = [F:DUD]LIG    : Endif
  If dim([F:BBB_]DUDDUDLIG)>0   : [F:BBB_]DUDDUDLIG  = [F:DUD]DUDLIG : Endif
  # ---------------------
  If IREAD = 1 Then
    Write   [F:BBB_]
  Else
    Rewrite [F:BBB_]
  Endif
End IDOCTYPLIN

