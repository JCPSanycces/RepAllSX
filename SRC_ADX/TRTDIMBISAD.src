###################################################################################
###################################################################################
###################################################################################
## Parcours de SVCRFOOT pour alimenter la dimension SADSOQ Lignes commandes
###################################################################################
Funprog CREATESADSOQSVF(IDOCTYPLIN)
Value Integer IDOCTYPLIN

Local Integer IREAD

  IREAD = 0
  Read [F:BBB_]SSOQ0=[F:SVF]VCRNUM;IDOCTYPLIN;[F:SVF]DTA;1000
  If fstat Then
    Raz [F:BBB_]
    IREAD = 1
  Endif
  # ---------------------
  [F:BBB_]SOHNUM                = [F:SVF]VCRNUM
  [F:BBB_]SOPLIN                = [F:SVF]DTA
  [F:BBB_]SOPLIN1               = [F:SVF]DTA
  [F:BBB_]DOCTYPLIN             = IDOCTYPLIN
  [F:BBB_]SOQSEQ                = 1000
  If dim([F:BBB_]SOPSEQ)>0      : [F:BBB_]SOPSEQ      = 0              : Endif
  If dim([F:BBB_]TODIMSADSOH)>0 : [F:BBB_]TODIMSADSOH = [F:SVF]VCRNUM  : Endif
  Gosub DATA_KEY_SVCRFOOT
  # ---------------------
  If IREAD = 1 Then
    Write   [F:BBB_]
  Else
    Rewrite [F:BBB_]
  Endif
End IDOCTYPLIN

###################################################################################
$DATA_KEY_SVCRFOOT
#  If dim([F:BBB_]VAT)>0         : [F:BBB_]VAT        = [F:SVF]DTAVAT : Endif
#  If dim([F:BBB_]VAT_LEG)>0     : [F:BBB_]VAT_LEG    = func TRTX3BITC.GETLEG_VAT([F:SVF]DTAVAT, [F:CPY]LEG) : Endif
  If dim([F:BBB_]ITMDES1)>0     : [F:BBB_]ITMDES1    = func LECT_DES_TRAD([F:SFI]ITMREF)                    : Endif
  If dim([F:BBB_]DTAVCRNUM)>0   : [F:BBB_]DTAVCRNUM  = [F:SVF]VCRNUM : Endif
  If dim([F:BBB_]DTAVCRTYP)>0   : [F:BBB_]DTAVCRTYP  = [F:SVF]VCRTYP : Endif
  If dim([F:BBB_]DTADTANUM)>0   : [F:BBB_]DTADTANUM  = [F:SVF]DTA    : Endif
Return

###################################################################################
###################################################################################
###################################################################################
###################################################################################
###################################################################################
# Déclarations des variables de travail communes
###################################################################################
$DECL_VAR
Local Integer DESFLG, NBACT, NBDES
Return

###################################################################################
# Lecture de la dimension, pour voir si elle gère le multi-dossiers
# Lecture de(s) la (les) règles de synchro
###################################################################################
$READ_DIM
  If clalev([F:ABI]) = 0 : Local File =APPLI+".ABIDIM" [ABI] : Endif
  If [F:ABI]CODDIM <> right$(TABLE,3) Then
    Read [ABI]ABI0=right$(TABLE,3)
    If fstat Then
      Raz [F:ABI]
    Endif
  Endif
  # On teste si toutes les règles de synchronisation ayant la même table d'origine que la dimension
  # sont désactivées. Si c'est le cas, le traitement de la dimension n'est pas exécuté
  [L]DESFLG = 1
  [L]NBACT = 0 # nombre de règles activées
  [L]NBDES = 0 # nombre de règles désactivées
  If [F:ABI]TABORG <> "" Then
    If clalev([F:ABV]) = 0 : Local File =APPLI+".ABIREGORG" [ABV] : Endif
    For [F:ABV] Where TABORG = [F:ABI]TABORG
      If dim([F:ABV]DESFLG) > 0 Then
        If [F:ABV]DESFLG = 2 Then # règle désactivée
          [L]NBDES += 1
        Else                      # règle activée
          [L]NBACT += 1
        Endif
      Endif
    Next
  Endif
  If [L]NBACT = 0 and [L]NBDES <> 0 Then # on n'a trouvé que des règles de synchro désactivées
    [L]DESFLG = 2
  Endif
Return

###################################################################################
## ALIM_WBASE alimentation de la variable donnant le type de
## DATABASE à partir de GTYPDBA
###################################################################################
$ALIM_WBASE

  # Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
  WBASE = num$((fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, GACTX.AFOLDER, "TYPDBA") * 2) + 1)

Return

##########################################################################################
# LECT_DES_TRAD : Lecture de la désignation traduite d'un article reçu en paramètre
##########################################################################################
# Parameters E : code de l'article
# Return       : désignation 1 traduite de l'article
##########################################################################################
Funprog LECT_DES_TRAD(P_ITMREF)
Value Char P_ITMREF

Local Char WBASE(1)
Local Char DESAXX(80)
Local Char WREQ2(250)

  Gosub ALIM_WBASE
  DESAXX = ""
  WREQ2 = "select TEXTE_0 From "+GDOSSIER+".ATEXTRA Where CODFIC_0='ITMMASTER' and ZONE_0='DES1AXX' and LANGUE_0='"+GLANGUE+"' and IDENT1_0='"+P_ITMREF+"'"
  For (Char TEXTE(80)) From WBASE Sql WREQ2 As [RE2_]
    DESAXX = [RE2_]TEXTE
    Break
  Next
End DESAXX

##########################################################################################
# READ_REGLE : Lecture des règles de synchro
##########################################################################################
# Parameters E : règle de synchro à lire
# Return       : flag de désactivation de la règle de synchro
##########################################################################################
Funprog READ_REGLE(CODE_REGLE)
Value Char CODE_REGLE

Local Integer DESACT

  DESACT = 1
  If CODE_REGLE <> "" Then
    If clalev([F:ABV]) = 0 : Local File =APPLI+".ABIREGORG" [ABV] : Endif
    Read [F:ABV]ABV0=CODE_REGLE
    If !fstat and dim([F:ABV]DESFLG) > 0 Then
      DESACT = [F:ABV]DESFLG
    Endif
  Endif
End DESACT

