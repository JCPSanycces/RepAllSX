#<AdxTL>@(#)2.0.0.0 $Revision$
Raz GPILOBJ
GBIDC2="" : GBIDC3="" : GFLAG=""
Call OBJET("GAS",GBIDC2,GBIDC3) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"   : Gosub OUVRE
 When "DEBUT"   : Gosub DEBUT
 When "SETBOUT" : Gosub SETBOUT
 When "END"     : mkstat=2
 When "OK"      : Gosub OK
 When "FIN"     : Gosub FIN
 When Default
Endcase
Return

$OUVRE
Local Char     TYPREP(30)          : # Type de répartition %, $, £ ou répatition connue
Local Char     PTV   (30)          : # Pointeur début
Local Char     PTF   (30)          : # Pointeur fin
Local Integer  NBPTV               : # Nb de lignes de ventilation
Local Integer  NOL                 : # No de la ligne d'écriture
Local Decimal  MONTANT             : # Montant à répartir
Local Decimal  QTE                 : # Quantité à répartir
Local Char     UNIT(GLONUOM)       : # Code unité
Local Char     DEV(GLONCUR)        : # Devise de la pièce
Local Char     LED(GLONLED)(0..9)  : # Référentiel
Local Char     ACC(GLONGAC)(0..9)  : # Compte
Local Char     BPR(GLONBPR)        : # Tiers de la pièce
Local Char     FCY(GLONFCY)        : # Site de la pièce
Local Date     DAT                 : # Date écriture de la pièce

Local Integer  I, J, K, L
Local Shortint NBLIG, PTVD, PTVF, NBVENT
Local Char     CLEREP(10), WDIE(GLONDIE)
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif

Local Integer NBREP    : # Nombre de répartitions
Local Integer NBAXE    : # Nombre d'axes
Local Integer IND

## sauvegarde du contexte si "consultation" (param(1)="£")
If left$(PARAM(1),1)="£"
 Local Integer OCONSULT, I
 Local Char    OBOUT(50)(1..12)
 OCONSULT = GCONSULT
 For I=1 To dim(OBOUT)
  OBOUT(I) = evalue("GBOUT"+num$(I))
 Next I
Endif
Return

$DEBUT
# Initialiation des variables
TYPREP  = PARAM(1)
NBPTV   = val(PARAM(4))
NOL     = val(PARAM(5))
MONTANT = val(PARAM(6))
QTE     = val(PARAM(7))
UNIT    = PARAM(8)
DEV     = PARAM(9)
BPR     = PARAM(12)
FCY     = PARAM(13)
DAT     = PARAM(14)

CLEREP = right$(TYPREP,2)
TYPREP = left$(TYPREP,1)

# Mémorisation du pointeur début et pointeur fin
NBLIG=evalue("dim("+PARAM(2)+")")
Local Decimal PTV(NBLIG)
Local Decimal PTF(NBLIG)
For I=0 To NBLIG-1
 PTV(I)=evalue(PARAM(2)+"("+num$(I)+")")
 PTF(I)=evalue(PARAM(3)+"("+num$(I)+")")
Next

NBVENT = GMAXVANA
PTVD   = PTV(NOL)
PTVF   = PTF(NOL)

## récupération de la clé de répartition si celle ci est une clé existante (autre que $,%)
## remarque : si TYPREP="£" alors VALEUR=0 (son type est DCB --> plantage)
If TYPREP<>"£" & type(VALEUR)>10 & VALEUR<>"" & VALEUR<>"$" : TYPREP += VALEUR : Endif

# contrôles
If PTVD = 0
 If [M:VT2]PTVENT+NBVENT>dim([M:VT2]TBAMT)
  GMESSAGE = mess(2,106,1) : # Trop de ventilations sur cette pièce
  GERR = 1 : FIN = 1 : Return
 Else
  If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif
  Call LECTURE("TCU",DEV,"") From CONTOBJ
  If UNIT<>""
   If !clalev([F:TUN]) : Local File TABUNIT [TUN] : Endif
   Call LECTURE("TUN",UNIT,"") From CONTOBJ
  Endif
 Endif
Endif

# Affichage
Effzo [VTL]10-50
[M:VTL]UOM     = PARAM(8)
[M:VTL]BPR     = PARAM(12)
[M:VTL]CUR     = PARAM(9)
[M:VTL]FCY     = PARAM(13)
[M:VTL]DAT     = PARAM(14)
[M:VTL]DSPTYP  = left$(PARAM(1),1)
[M:VTL]TOTREP  = val(PARAM(6))
[M:VTL]QTOTREP = val(PARAM(7))

## Identifie le nombre de référentiel à gérer
I = instr(1,PARAM(11),";")
If !I
 [M:VTL]NBLED  = 1
 [M:VTL]LED(0) = PARAM(10)
 [M:VTL]ACC(0) = PARAM(11)
Else
 While PARAM(11)<>""
  J = instr(1,PARAM(10),";")
  I = instr(1,PARAM(11),";")
  If I
   [M:VTL]LED([M]NBLED) = left$(PARAM(10),J-1) : PARAM(10) = vireblc(right$(PARAM(10),J+1),2)
   [M:VTL]ACC([M]NBLED) = left$(PARAM(11),I-1) : PARAM(11) = vireblc(right$(PARAM(11),I+1),2)
  Else
   [M:VTL]LED([M]NBLED) = PARAM(10) : PARAM(10) = ""
   [M:VTL]ACC([M]NBLED) = PARAM(11) : PARAM(11) = ""
  Endif
  [M]NBLED += 1
 Wend
Endif

## Identifie le nombre des axes à gérer
Local Integer VU
Raz [L]NBAXE
I = instr(1,PARAM(15),";")
If I
 While PARAM(15)<>""
  I = instr(1,PARAM(15),";")
  If I
   [M:VTL]DIE([L]NBAXE) = left$(PARAM(15),I-1) : PARAM(15) = vireblc(right$(PARAM(15),I+1),2)
  Else
   [M:VTL]DIE([L]NBAXE) = PARAM(15) : PARAM(15) = ""
  Endif
  Call LECTEXTRA([M:VTL]INTDIE([L]NBAXE),"GDIE","COLHEA",[M:VTL]DIE([L]NBAXE),"") From ATEXTRA
  ## Dans le cas de saisie de répartitions analytiques à partir des factures tiers on veut inhiber les
  ## axes non flagués 'Saisie en amont'
  Case GFONCTION
   When "GESBIC"
    VU = find([M:VTL]DIE([L]NBAXE),[M:BIC1]DIE(0..dim([M:BIC1]DIE)-1))
    If VU
     [M:VTL]FMTDIE(NBAXE) = [M:BIC1]FMTDIE(VU-1)
    Else
     Call INICCEFMT([M:VTL]DIE([L]NBAXE)) From SETGLBDIE
     [M:VTL]FMTDIE([L]NBAXE) = "K:"+GCCEFMT
    Endif
    Gosub CHG_FMT From W1VENTILE
   When "GESBIS"
    VU = find([M:VTL]DIE([L]NBAXE),[M:BIS1]DIE(0..dim([M:BIS1]DIE)-1))
    If VU
     [M:VTL]FMTDIE(NBAXE) = [M:BIS1]FMTDIE(VU-1)
    Else
     Call INICCEFMT([M:VTL]DIE([L]NBAXE)) From SETGLBDIE
     [M:VTL]FMTDIE([L]NBAXE) = "K:"+GCCEFMT
    Endif
    Gosub CHG_FMT From W1VENTILE
   When Default
    Call INICCEFMT([M:VTL]DIE([L]NBAXE)) From SETGLBDIE
    [M:VTL]FMTDIE([L]NBAXE) = "K:"+GCCEFMT
  Endcase
  [L]NBAXE += 1
 Wend
Else
  For I=1 To [M:VTL]NBLED
   Call INDLED([M:VTL]LED(I-1),"",IND,K) From CPTDIV
   If IND
     For J=1 To GLEDDIENBR(IND)
      WDIE = evalue("GDIE"+num$(J)+"("+num$(IND)+")")
      If !find(WDIE,[M:VTL]DIE(0..[L]NBAXE-1))
      [M:VTL]DIE([L]NBAXE) = WDIE
      Call LECTEXTRA([M:VTL]INTDIE([L]NBAXE),"GDIE","COLHEA",[M:VTL]DIE([L]NBAXE),"") From ATEXTRA
      Call INICCEFMT([M:VTL]DIE([L]NBAXE)) From SETGLBDIE
      [M:VTL]FMTDIE([L]NBAXE) = "K:"+GCCEFMT
      [L]NBAXE+=1
     Endif
    Next
   Endif
  Next
Endif
[M:VTL]NBAXE=[L]NBAXE

For J=NBAXE To 19
 [M:VTL]DIE(J)    = ""
 [M:VTL]INTDIE(J) = ""
 [M:VTL]FMTDIE(J) = "-K:15X"
Next

I=0
If PTVD<>0
 For J=PTVD To PTVF
  [M:VTL]AMT(I) = [M:VT2]TBAMT(J)
  [M:VTL]QTY(I) = [M:VT2]TBQTY(J)
  If [M:VTL]TOTREP<>0
   [M:VTL]PRC(I) = ar2([M:VTL]AMT(I)*100/[M:VTL]TOTREP)
  Endif
  For K=0 To NBAXE-1
   For L=0 To 19
    If ((evalue("[M:VT2]TBDIE("+num$(L)+")")=evalue("[M:VTL]DIE("+num$(K)+")")) | L=19) : Break : Endif
   Next L
  # In case of the equality is never found (no break) then at the last loop L=19 but with the Next L is becoming 20
   # One loop too much : TBCCE21 is not existing !
   If K<20
    Assign "[M:VTL]CCE"+num$(K+1)+"("+num$(I)+")"
&           With evalue("[M:VT2]TBCCE"+num$(L+1)+"("+num$(PTVD+I)+")")
   Endif
  Next K
 I += 1
 Next J
 If CLEREP<>"" : [M:VTL]DSP = CLEREP : Endif
Elsif CLEREP<>""
 Call CHARGE_VTE(CLEREP,UNIT) From VENTILE
 I = [M:VTL]BAS
 [M:VTL]DSP = CLEREP
Endif

[M:VTL]BAS = I
[M:VTL]TOTAL  = sum([M:VTL]AMT(0..I-1))
[M:VTL]QTOTAL = sum([M:VTL]QTY(0..I-1))

# Point d'entrée pour initialiser les lignes
GPOINT = "CHARGE" : Gosub ENTREE From EXEFNC

Affzo [VTL]10-50
If GCONSULT<>0 : Grizo [VTL] : Endif
Return

$SETBOUT
If left$(PARAM(1),1) = "£"
 ETABOU(GVALI) = 0
Else
 ETABOU(GVALI) = 1
Endif
Return

$OK
If GCONSULT=0
 If [M:VTL]TOTAL<>[M:VTL]TOTREP | [M:VTL]QTOTAL<>[M:VTL]QTOTREP
  GMESSAGE = mess(3,106,1) : # Total des ventilations incorrect
  GERR = 1 : FIN=0 : Return
 Else
  Gosub VALVENT
 Endif
Endif

PTV(NOL) = PTVD
PTF(NOL) = PTVF

# (6908) Point d'entrée pour stocker la saisie
GPOINT = "VALID" : Gosub ENTREE From EXEFNC

# Mise à jour du pointeur début et pointeur fin
For I=0 To NBLIG-1
 Assign PARAM(2)+"("+num$(I)+")" With PTV(I)
 Assign PARAM(3)+"("+num$(I)+")" With PTF(I)
Next
nolign = NOL+1
FIN = 1 : ## sort de la fenetre
If type(VALEUR)>10
 VALEUR = "$"
Endif

mkstat=99
If !GCONSULT & clalev([M:SAI1])>0 : mkstat=4 : Endif
Return

$VALVENT
If [M:VT2]PTVENT=0 : [M:VT2]PTVENT=1 : Endif

If PTVD=0
 PTVD = [M:VT2]PTVENT
 [M:VT2]PTVENT += [M:VTL]BAS
Elsif [M:VTL]BAS>PTVF-PTVD+1
 Call ANUVENTIL(PTV,PTF,NBPTV,PTVD,PTVF-PTVD+1) From VENTILE
 PTVD = [M:VT2]PTVENT
 [M:VT2]PTVENT += [M:VTL]BAS
Elsif [M:VTL]BAS<PTVF-PTVD+1
 Call ANUVENTIL(PTV,PTF,NBPTV,PTVD,PTVF-PTVD+1-[M:VTL]BAS) From VENTILE
Endif

PTVF = PTVD+[M:VTL]BAS-1

For I=0 To [M:VTL]BAS-1
 [M:VT2]TBAMT(PTVD+I) = [M:VTL]AMT(I)
 [M:VT2]TBQTY(PTVD+I) = [M:VTL]QTY(I)
 For J=0 To NBAXE-1
  For K=0 To 19
   If ((evalue("[M:VT2]TBDIE("+num$(K)+")")=evalue("[M:VTL]DIE("+num$(J)+")")) | K=19) : Break : Endif
  Next K
  # In case of the equality is never found (no break) then at the last loop K=19 but with the Next K is becoming 20
  # One loop too much : TBCCE21 is not existing !
  If J<20
   Assign "[M:VT2]TBCCE"+num$(K+1)+"("+num$(PTVD+I)+")"
&            With evalue("[M:VTL]CCE"+num$(J+1)+"("+num$(I)+")")
  Endif
 Next J
Next I
Return

$FIN
## restaure du contexte si "consultation" (param(1)="£")
If left$(PARAM(1),1)="£"
 GCONSULT = OCONSULT
 For I=1 To dim(OBOUT)
  Assign "GBOUT"+num$(I) With OBOUT(I)
 Next I
Endif
Return

$SETNOL
NOL=nolign-1
Return


###########################################################
## Masque VENTILE
###########################################################
Subprog AS_PRC(PCENT)
Variable Decimal PCENT
If [M]DSPTYP<>"%" : mkstat=2 : Endif
End

Subprog C_PRC(PCENT)
Variable Decimal PCENT
Gosub SETNOL
[M]PRC(NOL)=PCENT
Gosub TOTTBL
End

Subprog AS_AMT(MONT)
Variable Decimal MONT
If [M]DSPTYP="%" | [M]DSPTYP="£" : mkstat=2 : End : Endif
End

Subprog AP_AMT(MONT)
Variable Decimal MONT
Gosub SETNOL
[M:VTL]AMT(NOL) = MONT
If [M:VTL]TOTREP<>0
 [M:VTL]PRC(NOL) = ar2([M:VTL]AMT(NOL)*100/[M:VTL]TOTREP)
 Affzo PRC(NOL)
Endif
Gosub TOTTBL
End

Subprog B2_AMT(MONT)
Variable Decimal MONT
Gosub SETNOL
MONT = [M]TOTREP - sum([M]AMT(0..NOL-1)) - sum([M]AMT(NOL+1..[M]BAS-1))
[M]QTY(NOL) = [M]QTOTREP-sum([M]QTY(0..NOL-1))-sum([M]QTY(NOL+1..[M]BAS-1))
Affzo QTY(NOL)
End

Subprog AP_QTY(MONT)
Variable Decimal MONT
Gosub SETNOL
[M:VTL]QTY(NOL)=MONT
Gosub TOTTBL
End

Subprog AS_QTY(MONT)
Variable Decimal MONT
If [M]DSPTYP="%" | [M]DSPTYP="£" : mkstat=2 : End : Endif
If [M]QTOTREP=0  : mkstat=1 : End : Endif
End

Subprog B2_QTY(MONT)
Variable Decimal MONT
Gosub SETNOL
MONT = [M]QTOTREP-sum([M]QTY(0..NOL-1))-sum([M]QTY(NOL+1..[M]BAS-1))
End

Subprog AS_DSP(VALEUR)
Variable Char     VALEUR
If [M]BAS<>0 : mkstat=2 : Endif
End

Subprog C_DSP(VALEUR)
Variable Char     VALEUR
Call CONTDSP(VALEUR,[M]FCY,[M]DAT) From SUBGA1
End

Subprog AP_DSP(VALEUR)
Variable Char VALEUR
If VALEUR="" : End : Endif
Local Integer NOL
Call CHARGE_VTE(VALEUR,[M]UOM) From VENTILE
Affzo 20-40
NOL = [M]BAS-1
Gosub TOTTBL
End

Subprog AS_BAS
If find(status,65,68,83,71)
 Local Integer NOL : NOL=-1
 Gosub TOTTBL
Endif
If [M]DSPTYP = "£"
 If !(dim(GWEBSERV)=1 & GWEBSERV=1) : mkstat=2 : Endif
Endif
End

Subprog C_BAS
If status>=65 & status<=90
 # On reste dans le tableau
Elsif status<>7 & status<1792
 Call CONTVENT([M]FCY,[M]DAT)
Endif
End

Subprog CONTVENT(FCY,DAT)
Value Char FCY
Value Date DAT

Local Integer IND, AXE
Local Integer I, J, K
Local Char WDIE(GLONDIE),WCCE(GLONCCE)

For I=0 To [M:VTL]NBLED-1
 Call INDLED([M:VTL]LED(I),"",IND,K) From CPTDIV
 If !IND
  If !(dim(GWEBSERV)=1 & GWEBSERV=1) : mkstat=2 : Endif
  Break
 Endif
 Raz K
 For J=1 To [M:VTL]BAS
  For K=1 To GLEDDIENBR(IND)
   WDIE = evalue("GDIE"+num$(K)+"("+num$(IND)+")")
   AXE=find(WDIE,[M:VTL]DIE(0..dim([M:VTL]DIE)-1))
   If AXE
    WCCE = evalue("[M:VTL]CCE"+num$(AXE)+"("+num$(J-1)+")")
    Call CONTCCE(WCCE,[M:VTL]LED(I),WDIE,[L]FCY,[L]DAT,[M:VTL]ACC(I),[M:VTL]DIE,"[M:VTL]CCE#",J-1) From CPTCNT
    If mkstat
     If dim(GWEBSERV)=1 & GWEBSERV=1 : Raz mkstat : Endif
     Break 3
    Endif
   Endif
  Next K
 Next J
Next I
If mkstat
 GMESSAGE = mess(49,106,1)-num$(J)-":\"+GMESSAGE : # Ligne no
Endif
End

Subprog D_CCE1(VALEUR)
Variable Char    VALEUR()
AXE = 1 : Goto DEFCCE
Subprog D_CCE2(VALEUR)
Variable Char    VALEUR()
AXE = 2 : Goto DEFCCE
Subprog D_CCE3(VALEUR)
Variable Char    VALEUR()
AXE = 3 : Goto DEFCCE
Subprog D_CCE4(VALEUR)
Variable Char    VALEUR()
AXE = 4 : Goto DEFCCE
Subprog D_CCE5(VALEUR)
Variable Char    VALEUR()
AXE = 5 : Goto DEFCCE
Subprog D_CCE6(VALEUR)
Variable Char    VALEUR()
AXE = 6 : Goto DEFCCE
Subprog D_CCE7(VALEUR)
Variable Char    VALEUR()
AXE = 7 : Goto DEFCCE
Subprog D_CCE8(VALEUR)
Variable Char    VALEUR()
AXE = 8 : Goto DEFCCE
Subprog D_CCE9(VALEUR)
Variable Char    VALEUR()
AXE = 9 : Goto DEFCCE
Subprog D_CCE10(VALEUR)
Variable Char    VALEUR()
AXE = 10 : Goto DEFCCE
Subprog D_CCE11(VALEUR)
Variable Char    VALEUR()
AXE = 11 : Goto DEFCCE
Subprog D_CCE12(VALEUR)
Variable Char    VALEUR()
AXE = 12 : Goto DEFCCE
Subprog D_CCE13(VALEUR)
Variable Char    VALEUR()
AXE = 13 : Goto DEFCCE
Subprog D_CCE14(VALEUR)
Variable Char    VALEUR()
AXE = 14 : Goto DEFCCE
Subprog D_CCE15(VALEUR)
Variable Char    VALEUR()
AXE = 15 : Goto DEFCCE
Subprog D_CCE16(VALEUR)
Variable Char    VALEUR()
AXE = 16 : Goto DEFCCE
Subprog D_CCE17(VALEUR)
Variable Char    VALEUR()
AXE = 17 : Goto DEFCCE
Subprog D_CCE18(VALEUR)
Variable Char    VALEUR()
AXE = 18 : Goto DEFCCE
Subprog D_CCE19(VALEUR)
Variable Char    VALEUR()
AXE = 19 : Goto DEFCCE
Subprog D_CCE20(VALEUR)
Variable Char    VALEUR()
AXE = 20 : Goto DEFCCE

$DEFCCE
If VALEUR<>"" : Return : Endif

Local Char WCDE(GLONCDE)
If GFONCTION="GESGAS" & dim([F:GDE]CDE)>0 & [F:GDE]CDE<>""
 WCDE=[F:GDE]CDE
Else
 WCDE = ""
Endif

For I=0 To [M:VTL]NBLED-1
 Call INICCE(VALEUR,[M]DIE(AXE-1),[M]LED(I),[M]ACC(I),WCDE) From CPTINI
Next
If nolign>1 & !mkstat & VALEUR=""
 VALEUR = evalue("[M]CCE"+num$(AXE)+"("+num$(0)+")")
Endif
End

Subprog AS_CCE1(VALEUR)
Variable Char    VALEUR()
AXE = 1 : Goto SAICCE
Subprog AS_CCE2(VALEUR)
Variable Char    VALEUR()
AXE = 2 : Goto SAICCE
Subprog AS_CCE3(VALEUR)
Variable Char    VALEUR()
AXE = 3 : Goto SAICCE
Subprog AS_CCE4(VALEUR)
Variable Char    VALEUR()
AXE = 4 : Goto SAICCE
Subprog AS_CCE5(VALEUR)
Variable Char    VALEUR()
AXE = 5 : Goto SAICCE
Subprog AS_CCE6(VALEUR)
Variable Char    VALEUR()
AXE = 6 : Goto SAICCE
Subprog AS_CCE7(VALEUR)
Variable Char    VALEUR()
AXE = 7 : Goto SAICCE
Subprog AS_CCE8(VALEUR)
Variable Char    VALEUR()
AXE = 8 : Goto SAICCE
Subprog AS_CCE9(VALEUR)
Variable Char    VALEUR()
AXE = 9 : Goto SAICCE
Subprog AS_CCE10(VALEUR)
Variable Char    VALEUR()
AXE = 10 : Goto SAICCE
Subprog AS_CCE11(VALEUR)
Variable Char    VALEUR()
AXE = 11 : Goto SAICCE
Subprog AS_CCE12(VALEUR)
Variable Char    VALEUR()
AXE = 12 : Goto SAICCE
Subprog AS_CCE13(VALEUR)
Variable Char    VALEUR()
AXE = 13 : Goto SAICCE
Subprog AS_CCE14(VALEUR)
Variable Char    VALEUR()
AXE = 14 : Goto SAICCE
Subprog AS_CCE15(VALEUR)
Variable Char    VALEUR()
AXE = 15 : Goto SAICCE
Subprog AS_CCE16(VALEUR)
Variable Char    VALEUR()
AXE = 16 : Goto SAICCE
Subprog AS_CCE17(VALEUR)
Variable Char    VALEUR()
AXE = 17 : Goto SAICCE
Subprog AS_CCE18(VALEUR)
Variable Char    VALEUR()
AXE = 18 : Goto SAICCE
Subprog AS_CCE19(VALEUR)
Variable Char    VALEUR()
AXE = 19 : Goto SAICCE
Subprog AS_CCE20(VALEUR)
Variable Char    VALEUR()
AXE = 20 : Goto SAICCE

$SAICCE
If [M]DSPTYP="£" : mkstat=1 : End : Endif
Gosub SETNOL
Local Integer IND,AXI,I,J,K

mkstat = 2
For I=0 To [M:VTL]NBLED-1
 #-- L'axe est il présent sous le référentiel
 Call INDLED([M:VTL]LED(I),[M:VTL]DIE(AXE-1),IND,AXI) From CPTDIV
 If IND and AXI and [M:VTL]ACC(I)<>""
  Call LEC_GAC([M:VTL]ACC(I),GLEDCOA(IND)) From CPTLEC
  If find([M:VTL]DIE(AXE-1),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1)): mkstat = 0 : Break : Endif
 Endif
Next
End

Subprog C_CCE1(VALEUR)
Variable Char    VALEUR()
AXE = 1 : Goto CONTCCE
Subprog C_CCE2(VALEUR)
Variable Char    VALEUR()
AXE = 2 : Goto CONTCCE
Subprog C_CCE3(VALEUR)
Variable Char    VALEUR()
AXE = 3 : Goto CONTCCE
Subprog C_CCE4(VALEUR)
Variable Char    VALEUR()
AXE = 4 : Goto CONTCCE
Subprog C_CCE5(VALEUR)
Variable Char    VALEUR()
AXE = 5 : Goto CONTCCE
Subprog C_CCE6(VALEUR)
Variable Char    VALEUR()
AXE = 6 : Goto CONTCCE
Subprog C_CCE7(VALEUR)
Variable Char    VALEUR()
AXE = 7 : Goto CONTCCE
Subprog C_CCE8(VALEUR)
Variable Char    VALEUR()
AXE = 8 : Goto CONTCCE
Subprog C_CCE9(VALEUR)
Variable Char    VALEUR()
AXE = 9 : Goto CONTCCE
Subprog C_CCE10(VALEUR)
Variable Char    VALEUR()
AXE = 10 : Goto CONTCCE
Subprog C_CCE11(VALEUR)
Variable Char    VALEUR()
AXE = 11 : Goto CONTCCE
Subprog C_CCE12(VALEUR)
Variable Char    VALEUR()
AXE = 12 : Goto CONTCCE
Subprog C_CCE13(VALEUR)
Variable Char    VALEUR()
AXE = 13 : Goto CONTCCE
Subprog C_CCE14(VALEUR)
Variable Char    VALEUR()
AXE = 14 : Goto CONTCCE
Subprog C_CCE15(VALEUR)
Variable Char    VALEUR()
AXE = 15 : Goto CONTCCE
Subprog C_CCE16(VALEUR)
Variable Char    VALEUR()
AXE = 16 : Goto CONTCCE
Subprog C_CCE17(VALEUR)
Variable Char    VALEUR()
AXE = 17 : Goto CONTCCE
Subprog C_CCE18(VALEUR)
Variable Char    VALEUR()
AXE = 18 : Goto CONTCCE
Subprog C_CCE19(VALEUR)
Variable Char    VALEUR()
AXE = 19 : Goto CONTCCE
Subprog C_CCE20(VALEUR)
Variable Char    VALEUR()
AXE = 20 : Goto CONTCCE

$CONTCCE
Gosub SETNOL
Local Integer IND,AXI,I,J,K
Local Char WDIE(GLONDIE)

For I=0 To [M:VTL]NBLED-1
 #-- L'axe est il présent sous le référentiel
 Call INDLED([M:VTL]LED(I),[M:VTL]DIE(AXE-1),IND,AXI) From CPTDIV
 If IND and AXI
  #-- Liste de tous les axes du référentiel présent sous le masque VTL (utile pour les codes interdictions)
  #   (Module Compta TOUS et Module Tiers, uniquement Saisie en amont)
  Call CONTCCE(VALEUR,[M:VTL]LED(I),[M:VTL]DIE(AXE-1),[M:VTL]FCY,[M:VTL]DAT,[M:VTL]ACC(I),[M:VTL]DIE,"[M:VTL]CCE#",NOL)  From CPTCNT
  If mkstat : Break : Endif
 Endif
Next

End

#################################################################
$TOTTBL
If [M]DSPTYP="%"
 Local Decimal SOMPOUR , SOMP , AROQTE
 Local Integer I, N
 AROQTE = 10^(-[F:TUN]UOMDEC)
 N = max(NOL+1,[M]BAS)-1
 SOMPOUR = sum([M]PRC(0..N))
 If SOMPOUR<>0
  SOMP=0
  For I=0 To N
   [M]AMT(I) = arr((SOMP+[M]PRC(I))*[M]TOTREP/SOMPOUR,[F:TCU]CURRND)
&             -arr(SOMP*[M]TOTREP/SOMPOUR,[F:TCU]CURRND)
   [M]QTY(I) = arr((SOMP+[M]PRC(I))*[M]QTOTREP/SOMPOUR,AROQTE)
&             -arr(SOMP*[M]QTOTREP/SOMPOUR,AROQTE)
   SOMP += [M]PRC(I)
  Next I
 Else
  SOMPOUR=0
  For I=0 To N
   If [M]PRC(I)>0 : SOMPOUR += [M]PRC(I) : Endif
  Next I
  If SOMPOUR<>0
   SOMP=0
   For I=0 To N
    If [M]PRC(I)>0
     [M]AMT(I) = arr((SOMP+[M]PRC(I))*[M]TOTREP/SOMPOUR,[F:TCU]CURRND)
&               -arr(SOMP*[M]TOTREP/SOMPOUR,[F:TCU]CURRND)
     [M]QTY(I) = arr((SOMP+[M]PRC(I))*[M]QTOTREP/SOMPOUR,AROQTE)
&               -arr(SOMP*[M]QTOTREP/SOMPOUR,AROQTE)
     SOMP += [M]PRC(I)
    Endif
   Next I
  Endif
  SOMPOUR=0
  For I=0 To N
   If [M]PRC(I)<0 : SOMPOUR -= [M]PRC(I) : Endif
  Next I
  If SOMPOUR<>0
   SOMP=0
   For I=0 To N
    If [M]PRC(I)<0
     [M]AMT(I) =-arr((SOMP-[M]PRC(I))*[M]TOTREP/SOMPOUR,[F:TCU]CURRND)
&               +arr(SOMP*[M]TOTREP/SOMPOUR,[F:TCU]CURRND)
     [M]QTY(I) =-arr((SOMP-[M]PRC(I))*[M]QTOTREP/SOMPOUR,AROQTE)
&               +arr(SOMP*[M]QTOTREP/SOMPOUR,AROQTE)
     SOMP -= [M]PRC(I)
    Endif
   Next I
  Endif
 Endif
 [M]TOTAL  = sum([M]AMT(0..N))
 [M]QTOTAL = sum([M]QTY(0..N))
 Affzo AMT,QTY,TOTAL,QTOTAL
Elsif [M]DSPTYP="$"
 N = max(NOL+1,[M]BAS)-1
 [M]TOTAL = sum([M]AMT(0..N))
 [M]QTOTAL = sum([M]QTY(0..N))
 Affzo TOTAL, QTOTAL
Endif
Return

