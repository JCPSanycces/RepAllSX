#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "APRES_MODIF" : Gosub APRES_MODIF
Endcase
Return

$APRES_MODIF
#--- Dem 78067
#If [M:ACV2]CODACT="WRH" & COUZON="FLACT"
#   If val(CZ)=2
#      Call ERREUR(mess(94,187,1)) From GESECRAN
#   Endif
#Endif
#--CPO 78543 Code activité SFI et dimensions dans les écrans
#--Si le paramétrage des positions des élts. de facturation dans les documents prévoit
#--des numéros supérieurs à la nouvelle valeur voulue du code activité SFI, on interdit la modification
If [M:ACV2]CODACT="SFI" & COUZON="DIME"
  Call SFI_VERIF_PARAM(val(CZ))
Endif
#--/CPO

If find([M:ACV2]CODACT,"ECC","RVM") & COUZON="FLACT"
    Call VERIF_ECC([M:ACV2]CODACT,zc)
Endif

 # Issue 105932_2 - by MDJ : PRCSL and CSL can't be both equal to "Yes"
If find([M:ACV2]CODACT,"CSL","PRCSL") & COUZON="FLACT"
    Call VERIF_CSL([M:ACV2]CODACT,zc)
Endif
# End Issue 105932_2
# Issue 61553 - 2017-11-15 by MAE : LPN cannot be abled if EMP is enable
If find([M:ACV2]CODACT,"EMP","LPN") & COUZON="FLACT"
    Call VERIF_LPN([M:ACV2]CODACT,zc)
Endif

Return

###########################################################################
Subprog SFI_VERIF_PARAM(VALNOUV)
Value Integer VALNOUV

Local Integer WVALMAX : WVALMAX = VALNOUV
Local Integer WTROUVE : Raz WTROUVE
Local File SFOOTINV [WSFI]

#-- Dans le cas où la nouvelle valeur est inférieure
If [F:ACV]DIME>VALNOUV
  For [WSFI] Where max(DACBPC,DACORD,DACDLV,DACINV)>VALNOUV
    If max([F:WSFI]DACBPC,[F:WSFI]DACORD,[F:WSFI]DACDLV,[F:WSFI]DACINV)>WVALMAX
      WVALMAX = max([F:WSFI]DACBPC,[F:WSFI]DACORD,[F:WSFI]DACDLV,[F:WSFI]DACINV)
    Endif
    WTROUVE = 1
  Next
  If WTROUVE
    Call ERREUR(mess(135,187,1)-num$(WVALMAX)+"\"+mess(136,187,1)) From GESECRAN
    mkstat=2
  Endif
Endif

End

###########################################################################
Subprog VERIF_ECC(CODACV,NEWVAL)
Value Char CODACV
Variable Integer NEWVAL

Case CODACV
    When "ECC" :
        If NEWVAL<>2
            Read [ACV4]CODACT="RVM"
            If !fstat & [F:ACV4]FLACT=2
                # Activity code $1$ cannot be abled if activity code $2$ is disabled
                Call ERREUR(func AFNC.MES2(mess(258,125,1), "RVM", "ECC")) From GESECRAN
                mkstat=2
                NEWVAL=2
            Endif
        Endif
    When "RVM" :
        If NEWVAL=2
            Read [ACV4]CODACT="ECC"
            If !fstat & [F:ACV4]FLACT<>2
                # Activity code $1$ cannot be abled if activity code $2$ is disabled
                Call ERREUR(func AFNC.MES2(mess(258,125,1), "RVM", "ECC")) From GESECRAN
                mkstat=2
                NEWVAL=1
            Endif
        Endif
Endcase
End
###########################################################################
 # Issue Issue 105932_2 - by MDJ : PRCSL and CSL can't be both equal to "Yes"
Subprog VERIF_CSL(CODACV,NEWVAL)
Value Char CODACV
Variable Integer NEWVAL

 Case CODACV
   When "CSL" :
     If NEWVAL=2
       Read [ACV4]CODACT="PRCSL"
         If !fstat & [F:ACV4]FLACT=2
           # Activity code $1$ cannot be abled if activity code $2$ is enabled
           Call ERREUR(func AFNC.MES2(mess(658,199,1), "CSL", "PRCSL")) From GESECRAN
           mkstat=2
           NEWVAL=1
         Endif
       Endif
   When "PRCSL" :
     If NEWVAL=2
       Read [ACV4]CODACT="CSL"
       If !fstat & [F:ACV4]FLACT=2
         # Activity code $1$ cannot be abled if activity code $2$ is enabled
         Call ERREUR(func AFNC.MES2(mess(658,199,1), "PRCSL", "CSL")) From GESECRAN
         mkstat=2
         NEWVAL=1
       Endif
     Endif
  Endcase
End # End issue 105932_2
###########################################################################
# Issue 61553 - 2017-11-15 by MAE : LPN cannolt be abled if EMP id disable
Subprog VERIF_LPN(CODACV,NEWVAL)
Value Char CODACV
Variable Integer NEWVAL

Case CODACV
    When "EMP" :
        If NEWVAL<>2
            Read [ACV4]CODACT="LPN"
            If !fstat & [F:ACV4]FLACT=2
                # Activity code $1$ cannot be abled if activity code $2$ is disabled
                Call ERREUR(func AFNC.MES2(mess(258,125,1), "LPN", "EMP")) From GESECRAN
                mkstat=2
                NEWVAL=2
            Endif
        Endif
    When "LPN" :
        If NEWVAL=2
            Read [ACV4]CODACT="EMP"
            If !fstat & [F:ACV4]FLACT<>2
                # Activity code $1$ cannot be abled if activity code $2$ is disabled
                Call ERREUR(func AFNC.MES2(mess(258,125,1), "LPN", "EMP")) From GESECRAN
                mkstat=2
                NEWVAL=1
            Endif
        Endif
Endcase
End
# End issue 61553

