# Gestion du masque CLOSEL0

##########################################################################
## Etiquette ajoutée par le superviseur 07/11/2003 13:57:02 (MM)
##########################################################################
Subprog C_WFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
   Call CONTROLE("FCY","",VALEUR,"",mkstat) From CONTOBJ
   If mkstat : GMESSAGE = mess(23,100,1)
     End
   Endif
Endif
End

##########################################################################
Subprog C_WNUMDEB(VALEUR)
Variable Char    VALEUR()
If clalev([F:MFG]) = 0 : Local File MFGHEAD     [MFG] : Endif

If VALEUR <> ""
   Read [F:MFG]MFG0 = VALEUR
   If fstat GMESSAGE = mess(23,100,1)
       mkstat = 1
       End
   Endif

    If [F:MFG]MFGTRKFLG < 4
        GMESSAGE = mess(101,193,1)
        mkstat = 1
        End
    Endif
    If [F:MFG]OPTFLG = 2
        GMESSAGE = mess(122,193,1)
        mkstat = 1
        End
    Endif

    # si l'Of est dans le plan de pesée ou en cours de pesée on ne peut pas le sélectionner sr 05.03
    If dim([F:MFG]WGGFLG ) > 0 & find([F:MFG]WGGFLG,3,4)
        GMESSAGE = mess(214,193,1)
        mkstat = 1
        End
    Endif
Endif

End

##########################################################################
Subprog C_WNUMFIN(VALEUR)
Variable Char    VALEUR()
If clalev([F:MFG]) = 0 : Local File MFGHEAD    [MFG] : Endif

If VALEUR <> ""
   Read [F:MFG]MFG0 = VALEUR
    If fstat GMESSAGE = mess(23,100,1)
        mkstat = 1
        End
    Endif

    If [F:MFG]MFGTRKFLG < 4
        GMESSAGE = mess(101,193,1)
        mkstat = 1
        End
    Endif
    If [F:MFG]OPTFLG = 2
        GMESSAGE = mess(122,193,1)
        mkstat = 1
        End
    Endif

    # si l'Of est dans le plan de pesée ou en cours de pesée on ne peut pas le sélectionner sr 05.03
    If dim([F:MFG]WGGFLG ) > 0 & find([F:MFG]WGGFLG,3,4)
        GMESSAGE = mess(214,193,1)
        mkstat = 1
        End
    Endif
Endif
End


##########################################################################
Subprog C_WITMDEB(VALEUR)
Variable Char    VALEUR()
If clalev([F:ITM]) = 0 : Local File ITMMASTER [ITM] : Endif

VALEUR = toupper(VALEUR)
If VALEUR <> "" & right$(VALEUR,len(VALEUR)) <> "*"
    Call CONTROLE("ITM","",VALEUR,"",mkstat) From CONTOBJ
    If mkstat : GMESSAGE = mess(23,100,1)
        End
    Endif
Endif

End

##########################################################################
Subprog C_WITMFIN(VALEUR)
Variable Char    VALEUR()
If clalev([F:ITM]) = 0 : Local File ITMMASTER [ITM] : Endif

VALEUR = toupper(VALEUR)
If VALEUR <> "" & right$(VALEUR,len(VALEUR)) <> "*"
    Call CONTROLE("ITM","",VALEUR,"",mkstat) From CONTOBJ
    If mkstat : GMESSAGE = mess(23,100,1)
        End
    Endif
Endif

End


##########################################################################
Subprog AM_WITMDEB(VALEUR)
Variable Char    VALEUR()

If [M]WITMDEB=""       : [M]WITMFIN = VALEUR : Endif
If [M]WITMFIN < VALEUR : [M]WITMFIN = VALEUR : Endif
End


##########################################################################
Subprog AS_WDATFIN(VALEUR)
Variable Date    VALEUR
If VALEUR = [0/0/0] : VALEUR = [M]WDATDEB : Endif
End

##########################################################################
Subprog AV_WNUMFIN(VALEUR)
Variable Char    VALEUR()
If [M]WNUMDEB<>"" & VALEUR ="" : VALEUR = [M]WNUMFIN: Endif
End


##########################################################################
Subprog AM_WCRFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY
    GFCY=VALEUR
    Gosub CHARG_PARAM From FUNTDUCLO
Endif

End


##########################################################################
Subprog AM_WPJTDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <>""
    [M]WPJTFIN = VALEUR
Endif
End


##########################################################################
Subprog AM_WCDEDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <>""
    [M]WCDEFIN = VALEUR
Endif
End


##########################################################################
Subprog AM_WNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <>""
    [M]WNUMFIN = VALEUR
Endif
End

##########################################################################
# FQ 66881 GA 09/2010 choix du traitement en lancement de batch
Subprog AS_WTRAIT(VALEUR)
Variable Integer  VALEUR
If GBATCH=1
   GMENLOC(1)=1
   # VALEUR=2 # GH 17/10/2014 bug 97602
Endif
End
