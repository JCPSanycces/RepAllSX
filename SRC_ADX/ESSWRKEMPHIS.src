#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
Endcase

Return


$OUVRE
If clalev([F:ESWD6])    = 0 : Local File ESSWRKFLWDET     [ESWD6]     : Endif
If clalev([F:AWS])      = 0 : Local File AWRKHISSUI       [AWS]       : Endif
Return

Return

$DEBUT
Local Char GLOBEML(GLONEML)
GLOBEML=fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")
nolign =0

If PARAM(1) = "2" #Requested only
  Filter [F:ESWD6] Where REFNUM = GLOBEML and STA = 2 and MAIREC = 2
Else
  Filter [F:ESWD6] Where REFNUM = GLOBEML and STA <> 2 and MAIREC = 2
Endif

For [F:ESWD6]ESWD0
  #Get the tracked text from the workflow
  Filter [F:AWS] Where VALCTX5 = num$([F:ESWD6]UID) and (CODEVT="ESWD" | CODEVT = "ESWDMOD" )
  Read [F:AWS] First
  nolign +=1
  [M:ESWEMP]    = [F:ESWD6]
  [M:ESWEMP]MSG(nolign-1) = [F:AWS]TEXSUI
  #Update icon
  If [F:ESWD6]STA=1 | [F:ESWD6]STA=2 | [F:ESWD6]STA=5
    [M]WSTA(nolign-1) = "250"
  Elsif [F:ESWD6]STA=3 |  [F:ESWD6]STA=6
     [M]WSTA(nolign-1) = "246"
  Elsif [F:ESWD6]STA=4 |  [F:ESWD6]STA=7
      [M]WSTA(nolign-1) = "248"
  Else
    [M]WSTA(nolign-1) = "250"
  Endif

  [M:ESWEMP]NBRLIN = nolign
  Filter [F:AWS]
Next
Filter [F:ESWD6]
Affzo [M:ESWEMP]1-99
Return




