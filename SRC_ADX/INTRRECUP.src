#<AdxTL>@(#)1.0.0.0 $Revision$
#CHECK IGNORE_SOURCE
#  Migration des ûˋcrans V130 en V140
#
#  Version   1     : CC  02/12/2002    
#  Rûˋvision 01     : CC  02/12/2002   Mise au point diverses
#  Rûˋvision 02     : CC  27/03/2003   Utilisation de la table des types d'ûˋcran en mûˋmoire


# ------------------------------------------------------------------------------------------

Local Char SCREEND,DOSSO,DOSSD

SCREEND="AOC1"
DOSSO="SUP140"
DOSSD="SUP140"
Call RECUPSCR(DOSSO,DOSSD,SCREEND,SCREEND,1,0,0,2,1,1)
End

# ------------------------------------------------------------------------------------------

Subprog RECUPSCR(DOSSO,DOSSD,SCRDEB,SCRFIN,NBSCRMAX,GEN,DELW,SILENT,TRACE,NIVTRACE)

# DOSSO     : Dossier Origine
# DOSSD     : Dossier Destination
# SCRDEB    : Ecran de dûˋbut
# SCRFIN    : Ecran de fin
# NBSCRMAX  : Nombre d'ûˋcrans û  regûˋnûˋrer (si 0 on prend tous ceux de la fourchette)
# GEN       : Validation ûˋcran X3 enchainûˋe (0 Non , 1 oui)
# DELW      : On supprime les champs Filler (=1) ou on les bascule en champ invisible type 4 (=0)
# SILENT    : Mode silencieux 
#              0 : Non,  1 : Oui, on ne regû´nû´re pas les ûˋcrans dûˋjû  chargûˋs
#              2 : Oui, on regû´nû´re les ûˋcrans dûˋjû  chargûˋs
# TRACE     :  0: Off   1 : On   2 : Trace gûˋrûˋe û  l'extûˋrieur
# NIVTRACE  :  Niveau de trace   0: Titre   1 : Complet

Value Char DOSSO,DOSSD,SCRDEB,SCRFIN
Value Integer NBSCRMAX,GEN,DELW,SILENT,TRACE,NIVTRACE

Local Char TIT(50),VALL1(200),CODACT,SCRFINM
Local Integer NBSCR,I,J,K,ACTIV,DIMENS,NBRLAN,TROUV
Local Integer X1(1..30),Y1(1..30),X2(1..30),Y2(1..30),OK
Local Decimal BLPOS(1..30)
Local Integer BLCOLSPAN(1..30),BLROWSPAN(1..30),MOK,OPENTRACE


TIT="Screen Update in 140 format"
# --> ouverture de la trace
If !GSERVEUR and GTRACE="" and TRACE=1
  OPENTRACE=1
  Call OUVRE_TRACE(TIT) From LECFIC
Endif
Gosub INIFICS
If TRACE>=1 : Call ECR_TRACE(num$(date$)-num$(time$),0) From GESECRAN : Endif
If TRACE>=1 : Call ECR_TRACE(" ===============================================",0) From GESECRAN : Endif

Local File =DOSSO+".AMSK" [AMK]        
Local File =DOSSO+".AMSKZON" [AMZ]
        
Local File =DOSSD+".ACTIV" [AC3]
Local File =DOSSD+".ATYPE" [ATY]
Local File =DOSSD+".AWINDOW" [AWI]
Local File =DOSSD+".AOBJET" [AOB]
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif        
Local File =DOSSD+".AMSK" [UAMK]   :  # Pour les Update        
Local File =DOSSD+".AMSKZON" [UAMZ] : # Pour Les Update       

Local Char LAN(GLONLAN)(1..dim([F:ADS]LAN))

#   Chargement de la table des types d'ûˋcran

Local Char CMSK(10)(1..10000)
Local Integer TMSK(1..10000),NBMSK
Call CREWINSC(DOSSD,CMSK,TMSK,NBMSK)



# Charge les langues du dossier de gûˋnûˋration
Read [ADS]DOSSIER=DOSSD
NBRLAN=[F:ADS]NBRLAN
For I=0 To [F:ADS]NBRLAN-1
  LAN(I+1)=[F:ADS]LAN(I)
Next I


SCRFINM=SCRFIN
If SCRFINM<SCRDEB : SCRFINM=SCRDEB : Endif

For [AMK] Where CODMSK>=SCRDEB and CODMSK<=SCRFINM
  NBSCR+=1
  If NBSCRMAX<>0 and NBSCR > NBSCRMAX : Break 1 : Endif
  If [F:AMK]POSBLOC(0)<>0
    If SILENT=0
      Call OUINON([F:AMK]CODMSK-": Ecran dûˋjû  chargûˋ dans la base. Voulez vous le regûˋnûˋrer ?",OK) From GESECRAN
      If OK<>2 : Goto NEXTSCR : Endif
    Endif
    If SILENT=1 :  Goto NEXTSCR : Endif
  Endif
  Raz X1,Y1,X2,Y2
  For I=0 To [F:AMK]NBBLOC-1
    If [F:AMK]TYPBLOC(I)< 5
      X1(I+1)=[F:AMK]X1(I)  
      Y1(I+1)=[F:AMK]Y1(I)   
      X2(I+1)=[F:AMK]X2(I)  
      Y2(I+1)=[F:AMK]Y2(I)  
    Endif
  Next I
  If TRACE>=1 : Call ECR_TRACE([F:AMK]CODMSK,0) From GESECRAN : Endif
  Gosub TRAITEBLSC
  If TRACE>=1 and NIVTRACE>=1
    Call ECR_TRACE("Size  X(min-max):"-num$(XMIN)-num$(XMAX)+" Y(min-max):"-num$(YMIN)-num$(YMAX),0) From GESECRAN
  Endif
  Gosub TRAITESCR
  If GEN=1 :  Call VALID([F:AMK]CODMSK,DOSSD,NBRLAN,LAN,0,MOK) From VALMSK : Endif
$NEXTSCR:
Next

Gosub FINFICS
If OPENTRACE=1
  Call FERME_TRACE From LECFIC
  Call SUPP_TRACE From LECFIC 
Endif

End


$TRAITEBLSC
  Local Integer LABS(1..50),NBABS,LORD(1..50),NBORD,IABS(1..50),IORD(1..50)
  Local Integer IFABS(1..50),IFORD(1..50),XMIN,XMAX,YMIN,YMAX,TYPSCR,NBRLIG,NBRCOL
  Local Char ROWBL(20),COLBL(30),PBLOC(30)

  Trbegin [UAMK],[UAMZ]
#  Etablit la liste des X diffûˋrents
  For I=1 To [F:AMK]NBBLOC
   If [F:AMK]TYPBLOC(I-1) < 5
    If X1(I)>=0 and !find(X1(I),LABS(1..NBABS)) and !find(X1(I)-1,LABS(1..NBABS)) and !find(X1(I)+1,LABS(1..NBABS))
      NBABS+=1
      LABS(NBABS)=X1(I)
    Endif
    If X2(I)>=0 and !find(X2(I),LABS(1..NBABS)) and !find(X2(I)-1,LABS(1..NBABS)) and !find(X2(I)+1,LABS(1..NBABS))
      NBABS+=1
      LABS(NBABS)=X2(I)
    Endif
   Endif
  Next I

#  Etablit la liste des Y diffûˋrents
  For I=1 To [F:AMK]NBBLOC   
   If [F:AMK]TYPBLOC(I-1) < 5
    If Y1(I)>=0 and !find(Y1(I),LORD(1..NBORD)) and !find(Y1(I)-1,LORD(1..NBORD)) and !find(Y1(I)+1,LORD(1..NBORD))
      NBORD+=1
      LORD(NBORD)=Y1(I)
    Endif
    If Y2(I)>=0 and !find(Y2(I),LORD(1..NBORD)) and !find(Y2(I)-1,LORD(1..NBORD)) and !find(Y2(I)+1,LORD(1..NBORD))
      NBORD+=1
      LORD(NBORD)=Y2(I)
    Endif
   Endif
  Next I

#  Calcul de la taille ûˋcran
  XMIN=min(X1(1..[F:AMK]NBBLOC))
  XMAX=max(X2(1..[F:AMK]NBBLOC))
  YMIN=min(Y1(1..[F:AMK]NBBLOC))
  YMAX=max(Y2(1..[F:AMK]NBBLOC))
  Raz TYPSCR,NBRLIG,NBRCOL
  Gosub TYPSCREEN1
  If TYPSCR=2 and dim([F:AMK]CENTRE)>0 & [F:AMK]CENTRE<>2
    If XMAX-XMIN>80 or YMAX-YMIN>15 : TYPSCR=3 : Endif
  Endif
  If TYPSCR=1 or TYPSCR=2 or TYPSCR=5
    NBRCOL=min((XMAX-XMIN+1)*0.8,84)
    If NBRCOL=0 : NBRCOL=1 : Endif     : # CC cas des ûˋcrans tout "invisible"
#    NBRLIG=YMAX-YMIN+1
    NBRLIG=YMAX-YMIN                   : # CC 08/04/03 pour s'adapter û  l'ancien mode de calcul
#    If TYPSCR=5 : NBRLIG-=1 : Endif   : # CC 17/04/03 erreur signalûˋe 
    If NBRLIG=0 : NBRLIG=1 : Endif  : # CC cas des ûˋcrans tout "invisible"
  Endif
#  Fin du calcul des positions blocs  

  Sorta NBABS LABS
  Sorta NBORD LORD
  For I=1 To [F:AMK]NBBLOC
    If [F:AMK]TYPBLOC(I-1)<>5
      IABS(I) =find(X1(I),LABS(1..NBABS))+find(X1(I)-1,LABS(1..NBABS))+find(X1(I)+1,LABS(1..NBABS))
      IFABS(I)=find(X2(I),LABS(1..NBABS))+find(X2(I)-1,LABS(1..NBABS))+find(X2(I)+1,LABS(1..NBABS))
      IORD(I) =find(Y1(I),LORD(1..NBORD))+find(Y1(I)-1,LORD(1..NBORD))+find(Y1(I)+1,LORD(1..NBORD))
      IFORD(I)=find(Y2(I),LORD(1..NBORD))+find(Y2(I)-1,LORD(1..NBORD))+find(Y2(I)+1,LORD(1..NBORD))
    Endif
  Next I

  VALL1=""
  For I=1 To [F:AMK]NBBLOC
    PBLOC=num$(IORD(I))
    PBLOC+="."+num$(IABS(I))
  #  If IABS(I)>1 : Gosub FRBL : Endif
    BLCOLSPAN(I)=IFABS(I)-IABS(I)
    BLROWSPAN(I)=IFORD(I)-IORD(I)
    BLPOS(I)=val(PBLOC)
    VALL1+="(B"+num$(I)+", P"+num$(BLPOS(I))+", R"+num$(BLROWSPAN(I))+", C"+num$(BLCOLSPAN(I))+") "
  Next I
  If TRACE>=1 and NIVTRACE>=1  
    Call ECR_TRACE(VALL1,0) From GESECRAN
    VALL1=" Type d'ûˋcran : "+mess(TYPSCR,929,1)+"     NBRLIG : "+num$(NBRLIG)+"  NBRCOL : "+num$(NBRCOL)
    Call ECR_TRACE(VALL1,0) From GESECRAN 
  Endif
  Gosub UPDBLOC
Commit
Return

$DEBUG_DETAIL:
#   Trace dûˋtaillûˋe pour Debug
  If TRACE>=1 and NIVTRACE>=2  
    For I=1 To [F:AMK]NBBLOC
      VALL1="Bloc "+num$(I)+"    "-num$(X1(I))-num$(Y1(I))-num$(X2(I))-num$(Y2(I))
      VALL1+="  RangX :"+num$(IABS(I))+"  RangY :"+num$(IORD(I))
      VALL1+="  RangFX :"+num$(IFABS(I))+"  RangFY :"+num$(IFORD(I))
      Call ECR_TRACE(VALL1,0) From GESECRAN
    Next I

    VALL1=" Nb d'ABS : "+num$(NBABS)
    For I=1 To NBABS
      VALL1-=num$(LABS(I))
    Next I
    Call ECR_TRACE(VALL1,0) From GESECRAN

    VALL1=" Nb d'ORD : "+num$(NBORD)
    For I=1 To NBORD
      VALL1-=num$(LORD(I))
    Next I
    Call ECR_TRACE(VALL1,0) From GESECRAN
  Endif
Return

$FRBL:
  Local Integer IRG
  For J=1 To [F:AMK]NBBLOC
    If IORD(J)=IORD(I) and IABS(J)<IABS(I) : IRG+=1 : Endif
  Next J
  IRG+=1    : # CC 03/12 pour compter û  partir de 1
  If IRG<>0 : PBLOC+="."+num$(IRG) : Endif 
Return


#  Traitement de chaque bloc de l'ûˋcran
$TRAITESCR
  Local Integer NBFIELD,NBDELF,NBLIG,MAXFLIG,MAXLIG,ALIG,MAXCOL,LLIEN,ICEL
  Local Char FIELDS(10)(1..100)      : # Nom des champs du bloc
  Local Char DELFIELDS(10)(1..100)   : # Nom des champs du bloc û  supprimer (W sans valeur par dûˋfaut)
  Local Integer POSFL(1..100)        : # Position (ligne) du champ 
  Local Integer POSFC(1..100)        : # Position (Colonne) du champ
  Local Integer LIEN(1..100)         : # =1 si le champ a un lien
  Local Integer LONGF(1..100)        : # Longueur du champ en caractû´res
  Local Integer LONGFL(1..100)       : # Longueur du champ avec champs collûˋs en caractû´res
  Local Integer INTIT(1..100)        : # =1 si le champ a un intitulûˋ
  Local Integer DIMF(1..100)         : # Dimension du champ
  Local Integer LIG(1..200)          : # Nombre de cellules occupûˋes par ligne
  Local Integer TYPGR(1..100)        : # Type de graphique du champ (si valeur entre 3 et 6)
  Local Integer NOLIB(1..100)        : # Numûˋro de menu local
  Local Integer LONGFIELD(1..200)    : # Longueur du plus grand champ sans lien
  Local Integer ILONGFIELD(1..200)   : # Indice de ce champ
  Local Integer LONGFIELDL(1..200)   : # Longueur du plus grand champ avec lien
  Local Integer ILONGFIELDL(1..200)  : # Indice de ce champ
  Local Integer ADDSPANF(1..100)     : # Nombre de Cellules û  rajouter au champ (hors ajouts automatiques)
  Local Integer COLLE(1..100)        : # Nombre de champs collûˋs au champ courant
  Local Integer CHFILLER(1..100)     : # Si champ Filler, Nombre de cellules du filler
For I=1 To [F:AMK]NBBLOC
  If [F:AMK]TYPBLOC(I-1)<>2 : Goto BLOCSUI : Endif
  Raz FIELDS,NBDELF,DELFIELDS,POSFL,POSFC,LIEN,LONGF,LONGFL,INTIT,DIMF,LIG,TYPGR,NOLIB
  Raz LONGFIELD,LONGFIELD,LONGFIELDL,ILONGFIELDL,ADDSPANF,COLLE,CHFILLER 
  Raz NBFIELD,NBLIG,MAXFLIG,MAXLIG,ALIG,MAXCOL,LLIEN  
  
  Gosub TRAITUNBL

$BLOCSUI:
Next I
Return




$TRAITUNBL:
  For [AMZ]CODZON Where CODMSK=[F:AMK]CODMSK and NUMBLOC=I
    If [F:AMZ]SAIAFF<>3
      If ([F:AMZ]CODTYP="W" and [F:AMZ]VALDEF="") 
        NBDELF+=1
        DELFIELDS(NBDELF)=[F:AMZ]CODZON
        Goto NEXTFIELD 
      Endif
      If [F:AMZ]CODACT<>"" 
        CODACT=[F:AMZ]CODACT
        Gosub ACTIV
        If ACTIV=0 : Goto NEXTFIELD : Endif 
      Endif
      NBFIELD+=1
      FIELDS(NBFIELD)=[F:AMZ]CODZON
      If [F:AMZ]INTIT<>0 or [F:AMZ]INTEVAL<>"" : INTIT(NBFIELD)=1 : Endif
      If [F:AMZ]LIEN>=2 : LIEN(NBFIELD)=1 : Endif
      DIMF(NBFIELD)=[F:AMZ]DIME
      If [F:AMZ]CODACT<>"" and DIMENS<>0 :  DIMF(NBFIELD)=DIMENS : Endif
      If [F:AMZ]TYPGRAPH>=3 and [F:AMZ]TYPGRAPH<=6
        TYPGR(NBFIELD)=1   : # Horizontal
        If [F:AMZ]TYPGRAPH=3 or [F:AMZ]TYPGRAPH=4 : TYPGR(NBFIELD)=2 : Endif
        NOLIB(NBFIELD)=[F:AMZ]NOLIB
      Endif
      POSFL(NBFIELD)=[F:AMZ]NOZONE
      ALIG=POSFL(NBFIELD)+DIMF(NBFIELD)-1
      If TYPGR(NBFIELD)=2 : ALIG=POSFL(NBFIELD)+len(mess(0,NOLIB(NBFIELD),1)) : Endif
      MAXLIG=max(MAXLIG,ALIG)
      POSFC(NBFIELD)=[F:AMZ]NOZONE*10-10*POSFL(NBFIELD)+1
      LONGF(NBFIELD)=[F:AMZ]OPTLNG
      If LONGF(NBFIELD)=0 : LONGF(NBFIELD)=[F:AMZ]LONG : Endif
      If LONGF(NBFIELD)=0 and [F:AMZ]CODTYP<>"" 
        Read[ATY]CODTYP=[F:AMZ]CODTYP
        If fstat=0 : LONGF(NBFIELD)=[F:ATY]LNGTYP : Endif 
      Endif
#  Incrûˋmente le nombre de champs par ligne
      If TYPGR(NBFIELD)=2
        For J=1 To len(mess(0,NOLIB(NBFIELD),1))
          LIG(POSFL(NBFIELD)+J-1)+=2
        Next J
      Else
        For J=1 To DIMF(NBFIELD)
          If [F:AMZ]CODTYP="W" 
             LIG(POSFL(NBFIELD)+J-1)+=val([F:AMZ]VALDEF)
             CHFILLER(NBFIELD)=val([F:AMZ]VALDEF)
          Else
             LIG(POSFL(NBFIELD)+J-1)+=1+LIEN(NBFIELD)
             If LIEN(NBFIELD)=0
               If LONGF(NBFIELD) > LONGFIELD(POSFL(NBFIELD)+J-1) 
                 LONGFIELD(POSFL(NBFIELD)+J-1)=LONGF(NBFIELD)
                 ILONGFIELD(POSFL(NBFIELD)+J-1)=NBFIELD
               Endif
             Else
               LLIEN=30
               If [F:AMZ]LIEN=2 : LLIEN=10 : Endif 
               LONGFL(NBFIELD)=LONGF(NBFIELD)+LLIEN
               If LONGFL(NBFIELD)>LONGFIELDL(POSFL(NBFIELD)+J-1) 
                 LONGFIELDL(POSFL(NBFIELD)+J-1)=LONGFL(NBFIELD)
                 ILONGFIELDL(POSFL(NBFIELD)+J-1)=NBFIELD
               Endif
             Endif
          Endif
          If [F:AMZ]CODTYP<>"W" and [F:AMZ]TYPGRAPH<>2  : LIG(POSFL(NBFIELD)+J-1)+=INTIT(NBFIELD) : Endif   
        Next J
      Endif
    Endif

#  Traite comme des champs "collûˋs" les champs sans intitulûˋs exemple dans SOH0
  If NBFIELD>1 and INTIT(NBFIELD)=0 and POSFL(NBFIELD)=POSFL(NBFIELD-1) and CHFILLER(NBFIELD)=0
    If INTIT(NBFIELD-1)=1
      ADDSPANF(NBFIELD-1)+=1
      LONGFL(NBFIELD-1)+=LONGF(NBFIELD)
      COLLE(NBFIELD-1)+=1
    Else
      If NBFIELD-2>0 and POSFC(NBFIELD-2)=POSFC(NBFIELD-1)
        If INTIT(NBFIELD-2)=1
          ADDSPANF(NBFIELD-2)+=1
          LONGFL(NBFIELD-2)+=LONGF(NBFIELD)
          COLLE(NBFIELD-2)+=1
        Else
          If NBFIELD-3>0 and POSFC(NBFIELD-3)=POSFC(NBFIELD-2)
            ADDSPANF(NBFIELD-3)+=1
            LONGFL(NBFIELD-3)+=LONGF(NBFIELD)
            COLLE(NBFIELD-3)+=1
          Else
            ADDSPANF(NBFIELD-2)+=1
            LONGFL(NBFIELD-2)+=LONGF(NBFIELD)
            COLLE(NBFIELD-2)+=1
          Endif
        Endif
      Else
        ADDSPANF(NBFIELD-1)+=1
        LONGFL(NBFIELD-1)+=LONGF(NBFIELD)
        COLLE(NBFIELD-1)+=1
      Endif     
    Endif
  Endif

$NEXTFIELD
  Next

 MAXCOL=max(LIG)
 If TRACE>=1 and NIVTRACE>=1
   VALL1=" Bloc :"+num$(I)+" NBLIG :"+num$(MAXLIG)+" MAXCOL :"+num$(MAXCOL)+"  "
   Call ECR_TRACE(VALL1,0) From GESECRAN  
   For J=1 To MAXLIG
     VALL1="("+num$(J)+","+num$(LIG(J))+")"
     VALL1+= "Max "+num$(ILONGFIELD(J))-num$(LONGFIELD(J))
     VALL1+= "   Max Lien "+num$(ILONGFIELDL(J))-num$(LONGFIELDL(J))
     Call ECR_TRACE(VALL1,0) From GESECRAN  
   Next J
 Endif

#  Traitement des champs du bloc

# Champs û  supprimer 
 If NBDELF>0 : Gosub DELCHAMP : Endif 

 For J=1 To MAXLIG
   For K=1 To NBFIELD
     If POSFL(K)<>J : Goto SUIXX : Endif
     If CHFILLER(K)<>0 : ICEL=CHFILLER(K) : Gosub ECRFIELD : Goto SUIXX : Endif
     If INTIT(K)=0 
       If COLLE(K)=0 and POSFC(K)>1 
         ICEL=0 
       Else
         ICEL=1   : # A recalculer
       Endif
       Gosub ECRFIELD : Goto SUIXX
     Endif
   # Champ normal
     ICEL=1 : # A recalculer
     Gosub ECRFIELD
$SUIXX:
   Next K
 Next J
Return


$ACTIV
ACTIV=0
DIMENS=0
Read[AC3]CODACT=CODACT
If  fstat=0 and [F:AC3]FLACT=2  : ACTIV=1 : DIMENS=[F:AC3]DIME : Endif  
Return



$INIFICS
Local Char SEP,TYPOS,NAMEFIC(200)
SEP="/"
Call GET_OS(adxmac(0),TYPOS) From ORDSYS 
If toupper(TYPOS)="DOS" : SEP="\" : Endif
NAMEFIC=filpath("","","",DOSSO)+SEP+"tmp"+SEP+"UPDT140SC.mvt"
Openo NAMEFIC,0 Using [MVT]
Return


$ECRFIELD
  If ICEL<>0 and LIG(J)<MAXCOL
    If LONGFL(K)>=25+10*(LIEN(K)+COLLE(K)) or LONGF(K)>25 : ICEL+=1 : Endif
  Endif
  If TRACE>=1 and NIVTRACE>=1
    VALL1="Ligne "-num$(POSFL(K))-[F:AMK]CODMSK-FIELDS(K)-num$(ICEL)
    Call ECR_TRACE(VALL1,0) From GESECRAN
  Endif
  Gosub UPDFIELD
Return

$FINFICS
Openo Using [MVT]
Return


$TYPSCREEN1
  TYPSCR=2
  TROUV=find([F:AMK]CODMSK,CMSK(1..NBMSK))
  If TROUV>0
    TYPSCR=TMSK(TROUV)
  Endif
Return

$TYPSCREEN
Filter [AWI] Where MSKENT=[F:AMK]CODMSK
For [AWI]
  TYPSCR=5 : Break 1
Next
Filter [AWI]
If TYPSCR<>0 : Return : Endif

Filter [AWI] Where find([F:AMK]CODMSK,NOMMSK(0..15))
For [AWI]
  If [F:AWI]NBMSK=1 and [F:AWI]MSKENT=""
    TYPSCR=2
    If [F:AWI]OBJ<>"" 
      Read [AOB]ABREV=[F:AWI]OBJ
      If fstat=0 and [F:AOB]TYPGES<>2
        TYPSCR=4 
      Else
        TYPSCR=3
      Endif
    Endif
  Else
    TYPSCR=1
  Endif  
  Break 1
Next
Filter [AWI]
Return


$UPDBLOC
  Readlock [UAMK]CODMSK=[F:AMK]CODMSK
  [F:UAMK]TYPMSK=TYPSCR
  [F:UAMK]NBRLIG=NBRLIG
  [F:UAMK]NBRCOL=NBRCOL  
  For I=1 To [F:AMK]NBBLOC
    [F:UAMK]COLBLOC(I-1)=BLCOLSPAN(I)
    [F:UAMK]LINBLOC(I-1)=BLROWSPAN(I)
    [F:UAMK]POSBLOC(I-1)=BLPOS(I)
  Next I
  Rewrite [UAMK]
Return

$UPDFIELD
  Readlock [UAMZ]CODE=[F:AMK]CODMSK;FIELDS(K)
  [F:UAMZ]PDSZON=ICEL  
  Rewrite [UAMZ]
Return

$DELCHAMP:
  For indice=1 To NBDELF
    Readlock [UAMZ]CODE=[F:AMK]CODMSK;DELFIELDS(indice)
    If fstat=0 
      If DELW=1 : Delete [UAMZ] : Endif 
      If DELW=0 : [F:UAMZ]SAIAFF=4 : Rewrite [UAMZ] : Endif
    Endif
  Next indice
Return


# ----------------------------------------------------------------------------


Subprog CREWINSC(DOSSD,CMSK,TMSK,NBMSK)

Value Char DOSSD
Variable Char CMSK()(1..10000)
Variable Integer TMSK(1..10000),NBMSK

If clalev([F:AWI])=0 : Local File =DOSSD+".AWINDOW" [AWI] : Endif
If clalev([F:AOB])=0 : Local File =DOSSD+".AOBJET"  [AOB] : Endif

Local Integer I,TROUV,TYPS,NBWI

Raz CMSK,TMSK,NBMSK

For [AWI]
  NBWI+=1
#  If NBWI>20 : Break 1 : Endif
  If [F:AWI]MSKENT<>"" : Gosub CREENT : Endif
  For I=1 To 15
    If [F:AWI]NOMMSK(I-1)<>"" : Gosub CRESCR : Endif
  Next I
Next

End

#  TYPSCR   :   1 : Onglet    2 : BoûÛte de dialogue   3 : Plein ûˋcran
#               4 : Plein ûˋcran avec liste   5 : Entûˆte
#  Le type 2 sera transformûˋ en 3 selon les tailles dans INTRRRECUP


$CREENT
  TROUV=find([F:AWI]MSKENT,CMSK(1..NBMSK))
  If TROUV=0
    NBMSK+=1
    CMSK(NBMSK)=[F:AWI]MSKENT
    TMSK(NBMSK)=5
  Else
    TMSK(TROUV)=5
  Endif 
Return

$CRESCR
  TYPS=1
  If [F:AWI]NBMSK=1 and [F:AWI]MSKENT=""
    TYPS=2
    If [F:AWI]OBJ<>"" 
      Read [AOB]ABREV=[F:AWI]OBJ
      If fstat=0 and [F:AOB]TYPGES<>2
        TYPS=4 
      Else
        TYPS=3
      Endif
    Endif
  Endif
  TROUV=find([F:AWI]NOMMSK(I-1),CMSK(1..NBMSK))
  If TROUV=0
    NBMSK+=1
    CMSK(NBMSK)=[F:AWI]NOMMSK(I-1)
    TMSK(NBMSK)=TYPS
  Else
    If TYPS > TMSK(TROUV) : TMSK(TROUV)=TYPS : Endif
  Endif  
Return


