#<AdxTL>@(#)0.0.0.0 $Revision$ 
# Issue X3-53415 - WO operation audit enquiry. This shows operation line revisions.

#Standard actions used,
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "TITRE"      : Gosub LETITRE
 When "DEBUT"      : Gosub DEBUT
 When "FINSAI"     : Gosub FINSAI
Endcase
Return

$OUVRE
Case GACTION
 When "MFGOPEREV"  : Gosub OUV_MFGOPEREV
Endcase
Return

# Set title of enquiry window
$LETITRE
Case GACTION
 When "MFGOPEREV"  : TIT=mess(174,195,1)
Endcase
Return

$DEBUT
Case GACTION
 When "MFGOPEREV"  : Gosub DEB_MFGOPEREV
Endcase
Return

$FINSAI
Case GACTION
 When "MFGOPEREV"  : Gosub FINSAI_MFGOPEREV
Endcase
Return

#########################################################################
$OUV_MFGOPEREV
Local Char     LMFGNUM  : LMFGNUM = PARAM(1)
Local Integer  LOPENUM  : LOPENUM = val(PARAM(2))
Local Integer  LOPESPLNUM  : LOPESPLNUM = val(PARAM(3))
Local Shortint NOL     : NOL    = val(PARAM(4))

Local Shortint SAVGNOLIGN
SAVNOLIGN=nolign
If  evalue("[M:MFG3]OPENUM(NOL)=0") | GREP="C" | GREP="D"
  FIN=1
Endif
Return

#########################################################################
# Read through audit table for all the changes, and display in reverse order
$DEB_MFGOPEREV
Raz [M:MFGOPR]
Call TEMPON("O") From GESECRAN

# Read in material line, and display this at the top of list

If [F:MFO]MFGNUM<>LMFGNUM | [F:MFO]OPENUM<>LOPENUM | [F:MFO]OPESPLNUM<>LOPESPLNUM
  Read [F:MFO] MFO0=LMFGNUM;LOPENUM;LOPESPLNUM
  If fstat
    Raz [F:MFO]
  Endif
Endif

nolign=1
[M:MFGOPR]OPENUM(nolign-1) = [F:MFO]OPENUM
[M:MFGOPR]OPESTA(nolign-1) = [F:MFO]OPESTA
[M:MFGOPR]EXTWST(nolign-1) = [F:MFO]EXTWST
[M:MFGOPR]REVNUM(nolign-1) = 0
[M:MFGOPR]EXTWSTNBR(nolign-1) = [F:MFO]EXTWSTNBR
[M:MFGOPR]EXTQTY(nolign-1) = [F:MFO]EXTQTY
[M:MFGOPR]EXTSETTIM(nolign-1) = [F:MFO]EXTSETTIM
[M:MFGOPR]EXTUNTTIM(nolign-1) = [F:MFO]EXTUNTTIM
[M:MFGOPR]EXTOPETIM(nolign-1) = [F:MFO]EXTOPETIM
[M:MFGOPR]CPLLABNBR(nolign-1) = [F:MFO]CPLLABNBR
[M:MFGOPR]OPESTR(nolign-1) = [F:MFO]OPESTR
[M:MFGOPR]OPEEND(nolign-1) = [F:MFO]OPEEND
[M:MFGOPR]FRCSTRDAT(nolign-1) = [F:MFO]FRCSTRDAT
[M:MFGOPR]FXDTIM(nolign-1) = [F:MFO]PRPTIM + [F:MFO]WAITIM
[M:MFGOPR]SCOCOD(nolign-1) = [F:MFO]SCOCOD
[M:MFGOPR]VARTIM(nolign-1) = [F:MFO]EXTSETTIM + [F:MFO]EXTOPETIM
[M:MFGOPR]SCOWST(nolign-1) = [F:MFO]SCOWST
[M:MFGOPR]SCOITMREF(nolign-1) = [F:MFO]SCOITMREF
[M:MFGOPR]SCOLTI(nolign-1) = [F:MFO]SCOLTI
[M:MFGOPR]EXTLAB(nolign-1)    = [F:MFO]EXTLAB
[M:MFGOPR]EXTLABNBR(nolign-1) = [F:MFO]EXTLABNBR
[M:MFGOPR]REVCOD(nolign-1) = 0
[M:MFGOPR]OPEUOM(nolign-1) = [F:MFO]OPEUOM
[M:MFGOPR]TIMUOMCOD(nolign-1) = [F:MFO]TIMUOMCOD
[M:MFGOPR]FRCSTRHOU(nolign-1) = [F:MFO]FRCSTRHOU
[M:MFGOPR]CREUSR(nolign-1) = [F:MFO]UPDUSR

# use either CREDAT or UPDDAT
If [F:MFO]UPDDAT = [00/00/00]
  [M:MFGOPR]CREDAT(nolign-1) = [F:MFO]CREDAT
Else
  [M:MFGOPR]CREDAT(nolign-1) = [F:MFO]UPDDAT
Endif
[M:MFGOPR]CRETIM(nolign-1) = mid$(num$([F:MFO]UPDDATTIM),12,8)

# open material audit file
If clalev([F:MOR])<=0 Local File MFGOPEREV [MOR] : Endif

# read in all the audit lines for this material, and display on enquiry screen
Filter [MOR] Where [MOR]MFGNUM=LMFGNUM & [MOR]OPENUM=LOPENUM & [MOR]OPESPLNUM=LOPESPLNUM Order By Key MFO0 Desc
For [MOR]
  nolign+=1

  [M:MFGOPR]OPENUM(nolign-1) = [F:MOR]OPENUM
  [M:MFGOPR]OPESTA(nolign-1) = [F:MOR]OPESTA
  [M:MFGOPR]EXTWST(nolign-1) = [F:MOR]EXTWST
  [M:MFGOPR]REVNUM(nolign-1) = [F:MOR]REVNUM
  [M:MFGOPR]EXTWSTNBR(nolign-1) = [F:MOR]EXTWSTNBR
  [M:MFGOPR]EXTQTY(nolign-1) = [F:MOR]EXTQTY
  [M:MFGOPR]EXTSETTIM(nolign-1) = [F:MOR]EXTSETTIM
  [M:MFGOPR]EXTUNTTIM(nolign-1) = [F:MOR]EXTUNTTIM
  [M:MFGOPR]EXTOPETIM(nolign-1) = [F:MOR]EXTOPETIM
  [M:MFGOPR]CPLLABNBR(nolign-1) = [F:MOR]CPLLABNBR
  [M:MFGOPR]OPESTR(nolign-1) = [F:MOR]OPESTR
  [M:MFGOPR]OPEEND(nolign-1) = [F:MOR]OPEEND
  [M:MFGOPR]FRCSTRDAT(nolign-1) = [F:MOR]FRCSTRDAT
  [M:MFGOPR]FXDTIM(nolign-1) = [F:MOR]PRPTIM + [F:MOR]WAITIM
  [M:MFGOPR]SCOCOD(nolign-1) = [F:MOR]SCOCOD
  [M:MFGOPR]VARTIM(nolign-1) = [F:MOR]EXTSETTIM + [F:MOR]EXTOPETIM
  [M:MFGOPR]SCOWST(nolign-1) = [F:MOR]SCOWST
  [M:MFGOPR]SCOITMREF(nolign-1) = [F:MOR]SCOITMREF
  [M:MFGOPR]SCOLTI(nolign-1) = [F:MOR]SCOLTI
  [M:MFGOPR]EXTLAB(nolign-1) = [F:MOR]EXTLAB
  [M:MFGOPR]EXTLABNBR(nolign-1) = [F:MOR]EXTLABNBR
  [M:MFGOPR]REVREASON(nolign-1) = [F:MOR]REVREASON
  [M:MFGOPR]REVCOD(nolign-1) = [F:MOR]REVCOD
  [M:MFGOPR]OPEUOM(nolign-1) = [F:MOR]OPEUOM
  [M:MFGOPR]TIMUOMCOD(nolign-1) = [F:MOR]TIMUOMCOD
  [M:MFGOPR]FRCSTRHOU(nolign-1) = [F:MOR]FRCSTRHOU
  [M:MFGOPR]CREUSR(nolign-1) = [F:MOR]CREUSR
  [M:MFGOPR]CREDAT(nolign-1) = [F:MOR]CREDAT
  [M:MFGOPR]CRETIM(nolign-1) = mid$(num$([F:MOR]CREDATTIM),12,8)

Next

[M:MFGOPR]REVNUM(0) = nolign
[M:MFGOPR]NBLIG = nolign
# clear filter, and screen
Filter [MOR]
Affzo [M:MFGOPR]
Call TEMPOFF From GESECRAN

Return

#########################################################################
$FINSAI_MFGOPEREV
nolign=SAVNOLIGN
Close Local File [F:MOR]
Return

