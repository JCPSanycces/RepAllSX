#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UTICPT63   UTI process                                    Module CPT   #
#            Validation Type de données GTE/TPY/CDA/TAM
##########################################################################

If clalev([F:ADS])=0  
    Local File ADOSSIER [ADS] 
Endif

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOS(WDOSSIER,"") From SAIDOS

If WDOSSIER <> ""
  Read [ADS]DOSSIER=WDOSSIER 
  If fstat <> 0 
        Raz [F:ADS] 
  Endif
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTICPT63(WDOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTICPT63(DOSSIER)
Value Char DOSSIER

Local Integer VALMOD(20)
If DOSSIER=GDOSX3
 End
Else
 For I=0 To dim(VALMOD)-1
  VALMOD(I) = 2
 Next I
Endif

Call ECR_TRACE("UTICPT63 : Start of process on : "+DOSSIER,0) From GESECRAN
Call VALID_TRT(DOSSIER,0,"GTE","","","","","","A","W","","","","","","","","","","","","",VALMOD) From VALDICO
Call VALID_TRT(DOSSIER,0,"TPY","","","","","","A","W","","","","","","","","","","","","",VALMOD) From VALDICO
Call VALID_TRT(DOSSIER,0,"CDA","","","","","","A","W","","","","","","","","","","","","",VALMOD) From VALDICO
Call VALID_TRT(DOSSIER,0,"TAM","","","","","","A","W","","","","","","","","","","","","",VALMOD) From VALDICO
Call ECR_TRACE("UTICPT63 : End of process on :"+DOSSIER,0) From GESECRAN
End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTIXXX63 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI 
If fstat : Raz [F:ADS] : Endif
Call MAJ_UTICPT63(APPLI)        
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
Call MAJ_UTICPT63(APPLI)        
End


