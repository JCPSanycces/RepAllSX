#<AdxTL>@(#)0.0.0.0 $Revision$
#Hanlde all UK Employee property events

$EMPLOID_SRN_PROPAGATE
Return

$EMPLOID_NAM_PROPAGATE
Return

$EMPLOID_PSD_CONTROL
#PSD for UK is limited to 20 characters
Local Integer MAX_PSD
[L]MAX_PSD = 20

If len(this.PSD)>[L]MAX_PSD
  ASTATUS = fmet this.ASETERROR([L]CURPRO,mess(189,10717,1)-num$([L]MAX_PSD),[V]CST_AERROR)
Endif
Return

$EMPLOID_DATBRN_PROPAGATE
#Date of brith mandatory for UK legislation
If this.DATBRN = [00/00/00]
  ASTATUS = fmet this.ASETERROR([L]CURPRO,mess(133,10701,1),[V]CST_AERROR)
Endif
Return

$EMPLOID_CIV_CONTROL
Local Integer MAX_CIV
[L]MAX_CIV = 10

If this.CIV > [L]MAX_CIV
  ASTATUS = fmet this.ASETERROR([L]CURPRO,mess(76,00126,1)-num$([L]MAX_CIV),[V]CST_AERROR)
Endif
Return

