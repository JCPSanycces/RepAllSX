#<AdxTL>@(#)9.0.0.0 $Revision$
##########################################################################################################
#   Consultation des ciblages                                        Module CRM             24 juin 2002 #
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "FIR"          : Gosub PREMIER
    When "PRE"          : Gosub PRECEDENT
    When "SUI"          : Gosub SUIVANT
    When "LAS"          : Gosub DERNIER
    When "MEN"          : Gosub ONMENU
    When "RAF"          : Gosub REFRESH
    When "SUP"          : Gosub ONSUP
    When Default
  Endcase
Return

##########################################################################################################
$REFRESH
  Call TEMPON("L") From GESECRAN
  Call LOADMGD1([M:MGD1]TGRFLT, [M:MGD1]AUSFLT, [M:MGD1]QURCATSEL, 1)
  Call TEMPOFF From GESECRAN
  Affzo [M:MGD1]1-99
Return

##########################################################################################################
$PREMIER
  If [M:MGD1]TOTQUR <= dim([M:MGD1]CREDAT) Then
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712,196,1)
    GERR = 2
    Return
  Endif
  Call TEMPON("L") From GESECRAN
  Call LOADMGD1([M:MGD1]TGRFLT, [M:MGD1]AUSFLT, [M:MGD1]QURCATSEL, 1)
  Call TEMPOFF From GESECRAN
  Affzo [M:MGD1]1-99
Return

##########################################################################################################
$PRECEDENT
  If [M:MGD1]TOTQUR <= dim([M:MGD1]CREDAT) Then
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712,196,1)
    GERR = 2
    Return
  Endif
  Call TEMPON("L") From GESECRAN
  Call LOADMGD1([M:MGD1]TGRFLT, [M:MGD1]AUSFLT, [M:MGD1]QURCATSEL, 2)
  Call TEMPOFF From GESECRAN
  Affzo [M:MGD1]1-99
Return

##########################################################################################################
$SUIVANT
  If [M:MGD1]TOTQUR <= dim([M:MGD1]CREDAT) Then
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712,196,1)
    GERR = 2
    Return
  Endif
  Call TEMPON("L") From GESECRAN
  Call LOADMGD1([M:MGD1]TGRFLT, [M:MGD1]AUSFLT, [M:MGD1]QURCATSEL, 3)
  Call TEMPOFF From GESECRAN
  Affzo [M:MGD1]1-99
Return

##########################################################################################################
$DERNIER
  If [M:MGD1]TOTQUR <= dim([M:MGD1]CREDAT) Then
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712,196,1)
    GERR = 2
    Return
  Endif
  Call TEMPON("L") From GESECRAN
  Call LOADMGD1([M:MGD1]TGRFLT, [M:MGD1]AUSFLT, [M:MGD1]QURCATSEL, 4)
  Call TEMPOFF From GESECRAN
  Affzo [M:MGD1]1-99
Return

##########################################################################################################
$OUVRE
Global Char GSZMGD1FIR(GLONVCR)
Global Char GSZMGD1LAS(GLONVCR)
Global Date GDMGD1FIR
Global Date GDMGD1LAS
Global Integer GPREMGD1NOL

  If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
  If !clalev([F:AOB]) : Local File AOBJET [AOB] : Endif
  If !clalev([F:TGP]) : Local File TGRSSP [TGP] : Endif
  If !clalev([F:SSP]) : Local File SELSSP [SSP] : Endif
  If !clalev([F:SSC]) : Local File SELSSPCPN [SSC] : Endif
  If !clalev([F:MQR]) : Local File MKGQUR [MQR] : Endif
  If !clalev([F:MQP]) : Local File MKGQURPPL [MQP] : Endif
  If !clalev([F:QCR]) : Local File QURCRI [QCR] : Endif
  If !clalev([F:QCV]) : Local File QURCRIVAL [QCV] : Endif
  If !clalev([F:QTP]) : Local File QURTMP [QTP] : Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
  #Table complémentaire pour exécution dans l'assistant Marketing
  If type(GSZWIZMGG) > 0 Then
    If !clalev([F:SEC]) : Local File SELCMG [SEC] : Endif
    If !clalev([F:SCL]) : Local File SELCMGLIS [SCL] : Endif
    If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
    If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
    If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
    If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
    If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif
    If !clalev([F:MOG]) : Local File MKGOPG [MOG] : Endif
  Endif
  GSZMGD1FIR = ""
  GSZMGD1LAS = ""
  GDMGD1FIR = [00/00/00]
  GDMGD1LAS = [00/00/00]
  GPREMGD1NOL = 0
  #Initialisation de la navigation désordonnées
  NAVIG = "FMGD1"
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  #LSE 09/01/2007
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESSRE" Then
      ETABOU(GSPE4) = 1
    Elsif GNAVIG(GPILNAV-1) = "GESSET" Then
      ETABOU(GSPE4) = 1
    Endif
  Endif
  If [M:MGD1]CURQUR = "" Then
    ETAMEN(1) = 0
    ETAMEN(2) = 0
    ETABOU(GSPE2) = 0
    ETABOU(GSPE3) = 0
  Else
    ETAMEN(1) = 1
    ETAMEN(2) = 1
    If [M:MGD1]TGPNUM = "" Then
      ETABOU(GSPE2) = 0
    Else
      ETABOU(GSPE2) = 1
    Endif
    ETABOU(GSPE3) = 1
  Endif
  If type(GSZWIZMGG) > 0 Then
    If GICSTEP = 3 Then
      If GISTECPL(GICSTEP-1) Then
        ETABOU(GSPE5) = 1
      Else
        ETABOU(GSPE5) = 0
      Endif
    Endif
    If GICSTEP = 4 Then
      ETABOU(GSPE4) = 1
    Endif
  Endif
  #Menu Rafraichissement
  ETABOU(GRAFF) = 1
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  If type(GSZWIZMGG) > 0 Then
    #Utilisation dans les assistants marketing
    If GICSTEP = GISTEPBPR Then
      [M:MGD1]TGRFLT = "BPARTNER"
    Elsif GICSTEP = GISTEPAIN Then
      [M:MGD1]TGRFLT = "CONTACTCRM"
      Grizo [M:MGD1]TGRFLT # FGR 05/03/2009 : X3SUIVI28171
    Endif
    #Grizo [M:MGD1]TGRFLT  # FGR 05/03/2009 : X3SUIVI28171
  Else
    #LSE 09/01/2007
    If GPILNAV > 1 Then
      If GNAVIG(GPILNAV-1) = "GESSRE" Then
        #Utilisation dans les demandes de service
        [M:MGD1]TGRFLT = "MACHINES"
        Grizo [M:MGD1]TGRFLT
        [M:SRE7]AMMGD1FLG = 0
      Elsif GNAVIG(GPILNAV-1) = "GESSET" Then
        #Utilisation dans les modèles de demandes de service
        [M:MGD1]TGRFLT = "MACHINES"
        Grizo [M:MGD1]TGRFLT
      Else
        [M:MGD1]TGRFLT = PARAM(1)
      Endif
    Else
      [M:MGD1]TGRFLT = PARAM(1)
    Endif
  Endif
  # FGR 06/05/2009 : X3SUIVI29598 : Etat case a cocher fixé par paramètre. Avant : 2
  If GCIBAUSFLT <> 1 and GCIBAUSFLT <> 2 Then
    [M:MGD1]AUSFLT = 2
  Else
    [M:MGD1]AUSFLT = GCIBAUSFLT
  Endif
  #Supprime tous les ciblages sans cible
  Call CLEANMQR
  #Charge la fenêtre
  Call LOADMGD1([M:MGD1]TGRFLT, [M:MGD1]AUSFLT, [M:MGD1]QURCATSEL, 1)
  Affzo [M:MGD1]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  #Sélection d'un ciblage dans MGG4
  If type(GSZMGG4SELQUR) > 0 Then
    VALEUR = [M:MGD1]CURQUR
  Endif
  #Sélection d'un ciblage dans LKP7
  If type(GSZLKP7SELQUR) > 0 Then
    VALEUR = [M:MGD1]CURQUR
  Endif
  #Nettoie l'écran avant de partir.
  Raz [M:MGD1]
  Kill GSZMGD1FIR
  Kill GSZMGD1LAS
  Kill GDMGD1FIR
  Kill GDMGD1LAS
  Kill GPREMGD1NOL
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Local Char SZMGG0QURNUM(type([M:MGD1]CURQUR)-10)
Local Char SZMGG0TGR(type([M:MGD1]CURTGR)-10)

  SZMGG0QURNUM = [M:MGD1]CURQUR
  SZMGG0TGR = [M:MGD1]CURTGR
  Case BOUT
    When "D"
      If type(GSZWIZMGG) > 0 Then
        Gosub CANCELSTEP
        GISTECPL(GICSTEP-1) = 1
        FIN = 1
      Endif
    When "E"
      FIN = 1
    When "I"
      #LSE 09/01/2007
      If GPILNAV > 1 Then
        If GNAVIG(GPILNAV-1) = "GESSRE" Then
          Gosub ONSELECT
        Elsif GNAVIG(GPILNAV-1) = "GESSET" Then
          Gosub ONSELECT
        Endif
      Endif
    When "1"
      VALEUR = [M:MGD1]CURQUR
      FIN = 1
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Local Char SZMGG0QURNUM(type([M:MGD1]CURQUR)-10)
Local Char SZMGG0TGR(type([M:MGD1]CURTGR)-10)

  SZMGG0QURNUM = [M:MGD1]CURQUR
  SZMGG0TGR = [M:MGD1]CURTGR
  Case BOUT
    When "H"
      If type(GSZWIZMGG) > 0 Then
        If GICSTEP = GISTEPBPR Then
          Gosub RUNSELBPR From TRTMGG
          Gosub SETMKGOPGLNK From TRTMGG
          GISTECPL(GICSTEP-1) = 1
        Endif
        FIN = 1
      Endif
    When Default
  Endcase
Return

##########################################################################################################
$ONSUP
#Suppression d'un ciblage
Local Integer IQSTREP

  IQSTREP = 0
  If [M:MGD1]CURQUR = "" Then
    Return
  Endif
  #Confirmez-vous la suppression du ciblage sélectionné.
  Call OUINON(mess(771,196,1), IQSTREP) From GESECRAN
  If IQSTREP <> 2 Then
    Return
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [MQR], [MQP], [QCR], [QCV], [QTP]
  Delete [MQR] Where [F:MQR]QURNUM = [M:MGD1]CURQUR
  If fstat Then
    #Erreur lors de la suppression des composants du ciblage.
    Rollback
    GMESSAGE = mess(761,196,1)
    GERR = 1
    Return
  Endif
  Delete [MQP] Where [F:MQP]QURNUM = [M:MGD1]CURQUR
  If fstat Then
    #Erreur lors de la suppression des composants du ciblage.
    Rollback
    GMESSAGE = mess(761,196,1)
    GERR = 1
    Return
  Endif
  Delete [QCR] Where [F:QCR]QURNUM = [M:MGD1]CURQUR
  If fstat Then
    #Erreur lors de la suppression des composants du ciblage.
    Rollback
    GMESSAGE = mess(761,196,1)
    GERR = 1
    Return
  Endif
  Delete [QCV] Where [F:QCV]QURNUM = [M:MGD1]CURQUR
  If fstat Then
    #Erreur lors de la suppression des composants du ciblage.
    Rollback
    GMESSAGE = mess(761,196,1)
    GERR = 1
    Return
  Endif
  Delete [QTP] Where [F:QTP]QURNUM = [M:MGD1]CURQUR
  If fstat Then
    #Erreur lors de la suppression des composants du ciblage.
    Rollback
    GMESSAGE = mess(761,196,1)
    GERR = 1
    Return
  Endif
  Commit
  Gosub REFRESH
Return

##########################################################################################################
# Sous-programmes
###################################################################################
#
# LOADMGD1     : Charge la fenêtre de consultation des cibles
# CLEANMQR     : Supprime tous les ciblages sans cible
#
#
###################################################################################
##########################################################################################################
$ONSELECT
  #Sélection d'un filtre parc sur une demande ou un modèle de demande de service.
  VALEUR = [M:MGD1]CURQUR
  mkstat = 4
  FIN = 1
  #LSE 09/01/2007
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESSRE" Then
      Call ONMACFLT([M:SRE0]SRENUM, [M:MGD1]CURQUR, [M:SRE7]MACFLTINT) From SUBSREB2
      [M:SRE7]AMMGD1FLG = 1
    Endif
  Endif
Return

##########################################################################################################
# Charge la fenêtre de consultation des cibles
###################################################################
Subprog LOADMGD1(SZTGR, IAUSFLT, SZQURCAT, IWHATTODO)
Value Char SZTGR
Value Integer IAUSFLT
Value Char SZQURCAT
Value Integer IWHATTODO

Local Integer ITER
Local Integer IZ
Local Integer IFEEDMGC1
Local Integer IFIRLOOP
Local Integer IPRECNT
Local Integer ICANFOR

  IFEEDMGC1 = 1
  IFIRLOOP = 1
  IPRECNT = 0
  ICANFOR = 0
  IZ = 0
  ITER = 0
  Raz [M:MGD1]NBQUR
  Raz [M:MGD1]QURNUM
  Raz [M:MGD1]TGR
  Raz [M:MGD1]QURCAT
  Raz [M:MGD1]QURNAM
  Raz [M:MGD1]QURTOTREC
  Raz [M:MGD1]QURCAT
  Raz [M:MGD1]QURCATCLA
  Raz [M:MGD1]CREDAT
  Raz [M:MGD1]CREUSR
  If type(GSZWIZMGG) > 0 Then
    If dim([M:MGD1]CUROPGFLG) > 0 Then
      Raz [M:MGD1]CUROPGFLG
    Endif
  Endif
  If IWHATTODO = 1 Then
    #Premier
    If SZTGR = "" Then
      If IAUSFLT = 2 Then
        If SZQURCAT = "" Then
          Filter [MQR] Where [F:MQR]CREUSR = GUSER Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
        Else
          Filter [MQR] Where [F:MQR]CREUSR = GUSER and [F:MQR]QURCAT = SZQURCAT Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
        Endif
      Else
        If SZQURCAT = "" Then
          Filter [MQR] Where [F:MQR]TGR <> "" Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
        Else
          Filter [MQR] Where [F:MQR]TGR <> "" and [F:MQR]QURCAT = SZQURCAT Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
        Endif
      Endif
    Else
      If IAUSFLT = 2 Then
        If SZQURCAT = "" Then
          Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]CREUSR = GUSER  Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
        Else
          Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]CREUSR = GUSER and [F:MQR]QURCAT = SZQURCAT Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
        Endif
      Else
        If SZQURCAT = "" Then
          Filter [MQR] Where [F:MQR]TGR = SZTGR Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
        Else
          Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]QURCAT = SZQURCAT Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
        Endif
      Endif
    Endif
    For [MQR]
      If ITER < dim([M:MGD1]CREDAT) Then
        If ITER = 0 Then
          GSZMGD1FIR = [F:MQR]QURNUM
          GDMGD1FIR = [F:MQR]CREDAT
          [M:MGD1]NBQURSEL(ITER) = "->"
          GPREMGD1NOL = 0
        Else
          [M:MGD1]NBQURSEL(ITER) = ""
        Endif
        GSZMGD1LAS = [F:MQR]QURNUM
        GDMGD1LAS = [F:MQR]CREDAT
        If type(GSZWIZMGG) > 0 Then
          [M:MGD1]CUROPGFLG(ITER) = 1
          Filter [MOG] Where [F:MOG]MKGQUR = [F:MQR]QURNUM and [F:MOG]TGR = [F:MQR]TGR Order By [F:MOG]OPGNUM Asc
          For [MOG] Hint Key MOG0
            If [F:MOG]OPGNUM = GSZOPGNUM Then
              [M:MGD1]CUROPGFLG(ITER) = 2
              Break
            Endif
          Next
          Filter [MOG]
        Endif
        [M:MGD1]QURNUM(ITER) = [F:MQR]QURNUM
        [M:MGD1]TGR(ITER) = [F:MQR]TGR
        [M:MGD1]QURCAT(ITER) = [F:MQR]QURCAT
        If [M:MGD1]QURCAT(ITER) = "" Then
          [M:MGD1]QURCATCLA(ITER) = ""
        Else
          Call GET_LIB(438, [M:MGD1]QURCAT(ITER), [M:MGD1]QURCATCLA(ITER)) From CRM_UTIL
        Endif
        [M:MGD1]QURNAM(ITER) = [F:MQR]QURNAM
        If [F:MQR]QURTOTREC = 0 Then
          #Nombre d'enregistrements
          [M:MGD1]QURTOTREC(ITER) = 0
          Filter [QTP] Where [F:QTP]QURNUM = [F:MQR]QURNUM
          For [QTP]
            [M:MGD1]QURTOTREC(ITER) += 1
          Next
          Filter [QTP]
        Else
          [M:MGD1]QURTOTREC(ITER) = [F:MQR]QURTOTREC
        Endif
        [M:MGD1]CREDAT(ITER) = [F:MQR]CREDAT
        Read [AUS]CODUSR=[F:MQR]CREUSR
        If fstat Then
          [M:MGD1]CREUSR(ITER) = [F:MQR]CREUSR
        Else
          [M:MGD1]CREUSR(ITER) = [F:AUS]NOMUSR
        Endif
        ITER += 1
        [M:MGD1]NBQUR += 1
        [M:MGD1]TOTQUR += 1
      Else
        [M:MGD1]TOTQUR += 1
        If [M:MGD1]TOTQUR > dim([M:MGD1]CREDAT)+5 Then
          Break
        Endif
      Endif
    Next
    Filter [MQR]
  Elsif IWHATTODO = 2 Then
    #Précédent
    While IFEEDMGC1
      If IFIRLOOP Then
        If SZTGR = "" Then
          If IAUSFLT = 2 Then
            If SZQURCAT = "" Then
              Filter [MQR] Where [F:MQR]CREUSR = GUSER and [F:MQR]QURNUM >= GSZMGD1FIR and [F:MQR]CREDAT = GDMGD1FIR Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
            Else
              Filter [MQR] Where [F:MQR]CREUSR = GUSER and [F:MQR]QURCAT = SZQURCAT and [F:MQR]QURNUM >= GSZMGD1FIR and [F:MQR]CREDAT = GDMGD1FIR
&                       Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
            Endif
          Else
            If SZQURCAT = "" Then
              Filter [MQR] Where [F:MQR]QURNUM >= GSZMGD1FIR and [F:MQR]CREDAT = GDMGD1FIR Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
            Else
              Filter [MQR] Where [F:MQR]QURNUM >= GSZMGD1FIR and [F:MQR]QURCAT = SZQURCAT and [F:MQR]CREDAT = GDMGD1FIR Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
            Endif
          Endif
        Else
          If IAUSFLT = 2 Then
            If SZQURCAT = "" Then
              Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]CREUSR = GUSER and [F:MQR]QURNUM >= GSZMGD1FIR and [F:MQR]CREDAT = GDMGD1FIR
&                       Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
            Else
              Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]QURCAT = SZQURCAT and [F:MQR]CREUSR = GUSER and [F:MQR]QURNUM >= GSZMGD1FIR
&                            and [F:MQR]CREDAT = GDMGD1FIR
&                       Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
            Endif
          Else
            If SZQURCAT = "" Then
              Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]QURNUM >= GSZMGD1FIR and [F:MQR]CREDAT = GDMGD1FIR Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
            Else
              Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]QURCAT = SZQURCAT and [F:MQR]QURNUM >= GSZMGD1FIR and [F:MQR]CREDAT = GDMGD1FIR
&                       Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
            Endif
          Endif
        Endif
        IFIRLOOP = 0
      Else
        If SZTGR = "" Then
          If IAUSFLT = 2 Then
            If SZQURCAT = "" Then
              Filter [MQR] Where [F:MQR]CREUSR = GUSER and [F:MQR]CREDAT > GDMGD1FIR Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
            Else
              Filter [MQR] Where [F:MQR]CREUSR = GUSER and [F:MQR]QURCAT = SZQURCAT and [F:MQR]CREDAT > GDMGD1FIR Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
            Endif
          Else
            If SZQURCAT = "" Then
              Filter [MQR] Where [F:MQR]CREDAT > GDMGD1FIR Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
            Else
              Filter [MQR] Where [F:MQR]CREDAT > GDMGD1FIR and [F:MQR]QURCAT = SZQURCAT Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
            Endif
          Endif
        Else
          If IAUSFLT = 2 Then
            If SZQURCAT = "" Then
              Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]CREUSR = GUSER and [F:MQR]CREDAT > GDMGD1FIR Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
            Else
              Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]QURCAT = SZQURCAT and [F:MQR]CREUSR = GUSER and [F:MQR]CREDAT > GDMGD1FIR
&                       Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
            Endif
          Else
            If SZQURCAT = "" Then
              Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]CREDAT > GDMGD1FIR Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
            Else
              Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]QURCAT = SZQURCAT and [F:MQR]CREDAT > GDMGD1FIR
&                       Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
            Endif
          Endif
        Endif
        IFEEDMGC1 = 0
      Endif
      If !ICANFOR Then
        IFEEDMGC1 = 1
        For [MQR]
          If IZ >= dim([M:MGD1]CREDAT)-1 Then
            ICANFOR = 1
            IFIRLOOP = 1
            Break
          Endif
          IZ += 1
        Next
        IPRECNT += 1
        If IPRECNT >= 2 Then
          ICANFOR = 1
          IFIRLOOP = 1
        Endif
      Else
        For [MQR]
          If IZ >= 0 Then
            If [M:MGD1]NBQUR = 0 Then
              GSZMGD1LAS = [F:MQR]QURNUM
              GDMGD1LAS = [F:MQR]CREDAT
              [M:MGD1]NBQURSEL(ITER) = "->"
              GPREMGD1NOL = 0
            Else
              [M:MGD1]NBQURSEL(ITER) = ""
            Endif
            GSZMGD1FIR = [F:MQR]QURNUM
            GDMGD1FIR = [F:MQR]CREDAT
            If type(GSZWIZMGG) > 0 Then
              [M:MGD1]CUROPGFLG(IZ) = 1
              Filter [MOG] Where [F:MOG]MKGQUR = [F:MQR]QURNUM and [F:MOG]TGR = [F:MQR]TGR Order By [F:MOG]OPGNUM Asc
              For [MOG] Hint Key MOG0
                If [F:MOG]OPGNUM = GSZOPGNUM Then
                  [M:MGD1]CUROPGFLG(IZ) = 2
                  Break
                Endif
              Next
              Filter [MOG]
            Endif
            [M:MGD1]QURNUM(IZ) = [F:MQR]QURNUM
            [M:MGD1]TGR(IZ) = [F:MQR]TGR
            [M:MGD1]CREDAT(IZ) = [F:MQR]CREDAT
            Read [AUS]CODUSR=[F:MQR]CREUSR
            If fstat Then
              [M:MGD1]CREUSR(IZ) = [F:MQR]CREUSR
            Else
              [M:MGD1]CREUSR(IZ) = [F:AUS]NOMUSR
            Endif
            [M:MGD1]QURCAT(IZ) = [F:MQR]QURCAT
            If [M:MGD1]QURCAT(IZ) = "" Then
              [M:MGD1]QURCATCLA(IZ) = ""
            Else
              Call GET_LIB(438, [M:MGD1]QURCAT(IZ), [M:MGD1]QURCATCLA(IZ)) From CRM_UTIL
            Endif
            [M:MGD1]QURNAM(IZ) = [F:MQR]QURNAM
            If [F:MQR]QURTOTREC = 0 Then
              #Nombre d'enregistrements
              [M:MGD1]QURTOTREC(IZ) = 0
              Filter [QTP] Where [F:QTP]QURNUM = [F:MQR]QURNUM
              For [QTP]
                [M:MGD1]QURTOTREC(IZ) += 1
              Next
              Filter [QTP]
            Else
              [M:MGD1]QURTOTREC(IZ) = [F:MQR]QURTOTREC
            Endif
            IZ -= 1
            [M:MGD1]NBQUR += 1
          Else
            Break
          Endif
        Next
      Endif
      Filter [MQR]
      If ITER >= dim([M:MGD1]CREDAT) Then
        Break
      Endif
    Wend
  Elsif IWHATTODO = 3 Then
    #Suivant
    While IFEEDMGC1
      If IFIRLOOP Then
        If SZTGR = "" Then
          If IAUSFLT = 2 Then
            If SZQURCAT = "" Then
              Filter [MQR] Where [F:MQR]CREUSR = GUSER and [F:MQR]QURNUM <= GSZMGD1LAS and [F:MQR]CREDAT = GDMGD1LAS Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
            Else
              Filter [MQR] Where [F:MQR]CREUSR = GUSER and [F:MQR]QURCAT = SZQURCAT and [F:MQR]QURNUM <= GSZMGD1LAS and [F:MQR]CREDAT = GDMGD1LAS
&                       Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
            Endif
          Else
            If SZQURCAT = "" Then
              Filter [MQR] Where [F:MQR]QURNUM <= GSZMGD1LAS and [F:MQR]CREDAT = GDMGD1LAS Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
            Else
              Filter [MQR] Where [F:MQR]QURNUM <= GSZMGD1LAS and [F:MQR]QURCAT = SZQURCAT and [F:MQR]CREDAT = GDMGD1LAS Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
            Endif
          Endif
        Else
          If IAUSFLT = 2 Then
            If SZQURCAT = "" Then
              Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]CREUSR = GUSER and [F:MQR]QURNUM <= GSZMGD1LAS and [F:MQR]CREDAT = GDMGD1LAS
&                       Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
            Else
               Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]QURCAT = SZQURCAT and [F:MQR]CREUSR = GUSER and [F:MQR]QURNUM <= GSZMGD1LAS
&                             and [F:MQR]CREDAT = GDMGD1LAS
&                        Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
            Endif
          Else
            If SZQURCAT = "" Then
              Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]QURNUM <= GSZMGD1LAS and [F:MQR]CREDAT = GDMGD1LAS Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
            Else
              Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]QURCAT = SZQURCAT and [F:MQR]QURNUM <= GSZMGD1LAS and [F:MQR]CREDAT = GDMGD1LAS
&                       Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
            Endif
          Endif
        Endif
        IFIRLOOP = 0
      Else
        If SZTGR = "" Then
          If IAUSFLT = 2 Then
            If SZQURCAT = "" Then
              Filter [MQR] Where [F:MQR]CREUSR = GUSER and [F:MQR]CREDAT < GDMGD1LAS Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
            Else
              Filter [MQR] Where [F:MQR]CREUSR = GUSER and [F:MQR]QURCAT = SZQURCAT and [F:MQR]CREDAT < GDMGD1LAS
&                       Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
            Endif
          Else
            If SZQURCAT = "" Then
              Filter [MQR] Where [F:MQR]CREDAT < GDMGD1LAS Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
            Else
              Filter [MQR] Where [F:MQR]CREDAT < GDMGD1LAS and [F:MQR]QURCAT = SZQURCAT Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
            Endif
          Endif
        Else
          If IAUSFLT = 2 Then
            If SZQURCAT = "" Then
              Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]CREUSR = GUSER and [F:MQR]CREDAT < GDMGD1LAS Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
            Else
              Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]QURCAT = SZQURCAT and [F:MQR]CREUSR = GUSER and [F:MQR]CREDAT < GDMGD1LAS
&                       Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
            Endif
          Else
            If SZQURCAT = "" Then
              Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]CREDAT < GDMGD1LAS Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
            Else
              Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]QURCAT = SZQURCAT and [F:MQR]CREDAT < GDMGD1LAS Order By [F:MQR]CREDAT Desc; [F:MQR]QURNUM Desc
            Endif
          Endif
        Endif
        IFEEDMGC1 = 0
      Endif
      For [MQR]
        If ITER >= dim([M:MGD1]CREDAT) Then
          Break
        Endif
        If ITER = 0 Then
          GSZMGD1FIR = [F:MQR]QURNUM
          GDMGD1FIR = [F:MQR]CREDAT
          [M:MGD1]NBQURSEL(ITER) = "->"
          GPREMGD1NOL = 0
        Else
          [M:MGD1]NBQURSEL(ITER) = ""
        Endif
        GSZMGD1LAS = [F:MQR]QURNUM
        GDMGD1LAS = [F:MQR]CREDAT
        If type(GSZWIZMGG) > 0 Then
          [M:MGD1]CUROPGFLG(ITER) = 1
          Filter [MOG] Where [F:MOG]MKGQUR = [F:MQR]QURNUM and [F:MOG]TGR = [F:MQR]TGR Order By [F:MOG]OPGNUM Asc
          For [MOG] Hint Key MOG0
            If [F:MOG]OPGNUM = GSZOPGNUM Then
              [M:MGD1]CUROPGFLG(ITER) = 2
              Break
            Endif
          Next
          Filter [MOG]
        Endif
        [M:MGD1]QURNUM(ITER) = [F:MQR]QURNUM
        [M:MGD1]TGR(ITER) = [F:MQR]TGR
        [M:MGD1]CREDAT(ITER) = [F:MQR]CREDAT
        Read [AUS]CODUSR=[F:MQR]CREUSR
        If fstat Then
          [M:MGD1]CREUSR(ITER) = [F:MQR]CREUSR
        Else
          [M:MGD1]CREUSR(ITER) = [F:AUS]NOMUSR
        Endif
        [M:MGD1]QURCAT(ITER) = [F:MQR]QURCAT
        If [M:MGD1]QURCAT(ITER) = "" Then
          [M:MGD1]QURCATCLA(ITER) = ""
        Else
          Call GET_LIB(438, [M:MGD1]QURCAT(ITER), [M:MGD1]QURCATCLA(ITER)) From CRM_UTIL
        Endif
        [M:MGD1]QURNAM(ITER) = [F:MQR]QURNAM
        If [F:MQR]QURTOTREC = 0 Then
          #Nombre d'enregistrements
          [M:MGD1]QURTOTREC(ITER) = 0
          Filter [QTP] Where [F:QTP]QURNUM = [F:MQR]QURNUM
          For [QTP]
            [M:MGD1]QURTOTREC(ITER) += 1
          Next
          Filter [QTP]
        Else
          [M:MGD1]QURTOTREC(ITER) = [F:MQR]QURTOTREC
        Endif
        ITER += 1
        [M:MGD1]NBQUR += 1
      Next
      Filter [MQR]
      If ITER >= dim([M:MGD1]CREDAT) Then
        Break
      Endif
    Wend
  Elsif IWHATTODO = 4 Then
    #Dernier
    If SZTGR = "" Then
      If IAUSFLT = 2 Then
        If SZQURCAT = "" Then
          Filter [MQR] Where [F:MQR]CREUSR = GUSER Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
        Else
          Filter [MQR] Where [F:MQR]CREUSR = GUSER and [F:MQR]QURCAT = SZQURCAT Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
        Endif
      Else
        If SZQURCAT = "" Then
          Filter [MQR] Where [F:MQR]TGR <> "" Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
        Else
          Filter [MQR] Where [F:MQR]TGR <> "" and [F:MQR]QURCAT = SZQURCAT Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
        Endif
      Endif
    Else
      If IAUSFLT = 2 Then
        If SZQURCAT = "" Then
          Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]CREUSR = GUSER Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
        Else
          Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]CREUSR = GUSER and [F:MQR]QURCAT = SZQURCAT Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
        Endif
      Else
        If SZQURCAT = "" Then
          Filter [MQR] Where [F:MQR]TGR = SZTGR Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
        Else
          Filter [MQR] Where [F:MQR]TGR = SZTGR and [F:MQR]QURCAT = SZQURCAT Order By [F:MQR]CREDAT Asc; [F:MQR]QURNUM Asc
        Endif
      Endif
    Endif
    ITER = dim([M:MGD1]CREDAT)-1
    For [MQR]
      If ITER >= 0 Then
        If [M:MGD1]NBQUR = 0 Then
          GSZMGD1LAS = [F:MQR]QURNUM
          GDMGD1LAS = [F:MQR]CREDAT
          [M:MGD1]NBQURSEL(ITER) = "->"
          GPREMGD1NOL = 0
        Else
          [M:MGD1]NBQURSEL(ITER) = ""
        Endif
        GSZMGD1FIR = [F:MQR]QURNUM
        GDMGD1FIR = [F:MQR]CREDAT
        If type(GSZWIZMGG) > 0 Then
          [M:MGD1]CUROPGFLG(ITER) = 1
          Filter [MOG] Where [F:MOG]MKGQUR = [F:MQR]QURNUM and [F:MOG]TGR = [F:MQR]TGR Order By [F:MOG]OPGNUM Asc
          For [MOG] Hint Key MOG0
            If [F:MOG]OPGNUM = GSZOPGNUM Then
              [M:MGD1]CUROPGFLG(ITER) = 2
              Break
            Endif
          Next
          Filter [MOG]
        Endif
        [M:MGD1]QURNUM(ITER) = [F:MQR]QURNUM
        [M:MGD1]TGR(ITER) = [F:MQR]TGR
        [M:MGD1]CREDAT(ITER) = [F:MQR]CREDAT
        Read [AUS]CODUSR=[F:MQR]CREUSR
        If fstat Then
          [M:MGD1]CREUSR(ITER) = [F:MQR]CREUSR
        Else
          [M:MGD1]CREUSR(ITER) = [F:AUS]NOMUSR
        Endif
        [M:MGD1]QURCAT(ITER) = [F:MQR]QURCAT
        If [M:MGD1]QURCAT(ITER) = "" Then
          [M:MGD1]QURCATCLA(ITER) = ""
        Else
          Call GET_LIB(438, [M:MGD1]QURCAT(ITER), [M:MGD1]QURCATCLA(ITER)) From CRM_UTIL
        Endif
        [M:MGD1]QURNAM(ITER) = [F:MQR]QURNAM
        If [F:MQR]QURTOTREC = 0 Then
          #Nombre d'enregistrements
          [M:MGD1]QURTOTREC(ITER) = 0
          Filter [QTP] Where [F:QTP]QURNUM = [F:MQR]QURNUM
          For [QTP]
            [M:MGD1]QURTOTREC(ITER) += 1
          Next
          Filter [QTP]
        Else
          [M:MGD1]QURTOTREC(ITER) = [F:MQR]QURTOTREC
        Endif
        ITER -= 1
        [M:MGD1]NBQUR += 1
      Else
        Break
      Endif
    Next
    Filter [MQR]
  Endif
  If [M:MGD1]NBQUR > 0 Then
    Call SETQURINFO([M:MGD1]QURNUM(0), [M:MGD1]TGR(0))
  Endif
End

##########################################################################################################
# Charge les informations relatives à un ciblage
###################################################################
Subprog SETQURINFO(SZQUR, SZCURTGR)
Value Char SZQUR
Value Char SZCURTGR

  #Définit le ciblage courant
  [M:MGD1]CURQUR = SZQUR
  [M:MGD1]CURTGR = SZCURTGR
  #Renseigne les caractéristiques du ciblage
  Raz [M:MGD1]TGPNUM
  Raz [M:MGD1]NBDES
  Raz [M:MGD1]PPLDES
  Read [MQR]MQR0=SZQUR
  If !fstat Then
    [M:MGD1]TGPNUM = [F:MQR]TGPNUM
  Endif
  #Affiche le résumé du ciblage
  Gosub DISPPPLDES
End

##########################################################################################################
#Affiche le résumé du ciblage
####################################################################
$DISPPPLDES
Local Integer ISUMUPITER
Local Integer INBSUM
Local Char SZOPER(100)
Local Integer ISTR
Local Integer ILOOPSECURE
Local Char SZ1(250)
Local Char SZ2(250)
Local Char SZ3(250)
Local Char SZTEXTE(GLONDCO)

  ILOOPSECURE = 0
  ISTR = 0
  SZ1 = ""
  SZ2 = ""
  SZ3 = ""
  ISUMUPITER = 0
  INBSUM = 0
  SZOPER = ""
  Raz [M:MGD1]NBDES
   Filter [MQP] Where [F:MQP]QURNUM = SZQUR
  For [MQP] MQP1
    If [F:MQP]PPLSELSPT = "" Then
      Break
    Endif
    If [F:MQP]PPLOPD > 1 Then
      SZOPER = mess([F:MQP]PPLOPD,2959,1)
      If [F:MQP]PPLDES = "" Then
        Read [SSP]SSP0=[F:MQP]PPLSELSPT
        If fstat Then
          [M:MGD1]PPLDES(ISUMUPITER) = SZOPER
        Else
          Call LECTEXTRA(SZTEXTE, "SELSSP", "SPTNAMAXX", [F:SSP]SPTNUM, "") From ATEXTRA
          [M:MGD1]PPLDES(ISUMUPITER) = SZOPER - SZTEXTE
        Endif
      Else
        [M:MGD1]PPLDES(ISUMUPITER) = SZOPER - left$([F:MQP]PPLDES, 108 - len(SZOPER))
      Endif
    Else
      If [F:MQP]PPLDES = "" Then
        Read [SSP]SSP0=[F:MQP]PPLSELSPT
        If fstat Then
          [M:MGD1]PPLDES(ISUMUPITER) = ""
        Else
          Call LECTEXTRA(SZTEXTE, "SELSSP", "SPTNAMAXX", [F:SSP]SPTNUM, "") From ATEXTRA
          [M:MGD1]PPLDES(ISUMUPITER) = SZTEXTE
        Endif
      Else
        [M:MGD1]PPLDES(ISUMUPITER) = left$([F:MQP]PPLDES, 110)
      Endif
    Endif
    #On enlève les retours chariots et les line feed de la ligne
    While instr(1, [M:MGD1]PPLDES(ISUMUPITER), chr$(10))
      ISTR = instr(1, [M:MGD1]PPLDES(ISUMUPITER), chr$(10))
      SZ1 = left$([M:MGD1]PPLDES(ISUMUPITER), ISTR - len(chr$(10)))
      SZ2 = right$([M:MGD1]PPLDES(ISUMUPITER), ISTR + 1)
      SZ3 = SZ1 + SZ2
      [M:MGD1]PPLDES(ISUMUPITER) = SZ3
      ILOOPSECURE += 1
      If ILOOPSECURE > 10000 Then
        Break
      Endif
    Wend
    ISTR = 0
    SZ1 = ""
    SZ2 = ""
    SZ3 = ""
    While instr(1, [M:MGD1]PPLDES(ISUMUPITER), chr$(13))
      ISTR = instr(1, [M:MGD1]PPLDES(ISUMUPITER), chr$(13))
      SZ1 = left$([M:MGD1]PPLDES(ISUMUPITER), ISTR - len(chr$(13)))
      SZ2 = right$([M:MGD1]PPLDES(ISUMUPITER), ISTR + 1)
      SZ3 = SZ1 - SZ2
      [M:MGD1]PPLDES(ISUMUPITER) = SZ3
      ILOOPSECURE += 1
      If ILOOPSECURE > 20000 Then
        Break
      Endif
    Wend
    ISUMUPITER += 1
    [M:MGD1]NBDES += 1
  Next
  Filter [MQP]
Return

##########################################################################################################
#Supprime tous les ciblages sans cible
#####################################################################
Subprog CLEANMQR
  Call DEBTRANS From GLOCK
  Trbegin [MQR]
  Delete [MQR] Where [F:MQR]TGR = ""
  If fstat Then
    Rollback
  Else
    Commit
  Endif
End

##########################################################################################################
$CANCELSTEP
Local Char SZMQRNUM(100)
Local Integer IOTHERMQR
Local Integer IDELREMMQR
Local Integer ITRANSFLG

  If !clalev([F:SEC]) : Local File SELCMG [SEC] : Endif
  If !clalev([F:SCL]) : Local File SELCMGLIS [SCL] : Endif
  If !clalev([F:MQR]) : Local File MKGQUR [MQR] : Endif
  If !clalev([F:MQP]) : Local File MKGQURPPL [MQP] : Endif
  If !clalev([F:QCR]) : Local File QURCRI [QCR] : Endif
  If !clalev([F:QCV]) : Local File QURCRIVAL [QCV] : Endif
  If !clalev([F:QTP]) : Local File QURTMP [QTP] : Endif
  Local File MKGOPG [MOG1]
  Local File MKGOPG [MOG2]
  SZMQRNUM = ""
  IOTHERMQR = 0
  IDELREMMQR = 1
  If adxlog Then
    ITRANSFLG = 1
  Else
    ITRANSFLG = 0
  Endif
  If !ITRANSFLG Then
    Call DEBTRANS From GLOCK
    Trbegin [SEC]
  Endif
  Delete [SEC] Where [F:SEC]OPGNUM = GSZOPGNUM and [F:SEC]SELTBL <> "CCN"
  If fstat Then
    If ITRANSFLG Then
      GOK = 0
      Call FSTA("SEC") From GLOCK
    Else
      #Erreur lors de la suppression de l'échantillon.
      GMESSAGE = mess(788,196,1)
      GERR = 1
      Rollback
    Endif
    Close Local File [MOG1]
    Close Local File [MOG2]
    Return
  Endif
  If !ITRANSFLG Then
    Commit
  Endif
  If !ITRANSFLG Then
    Call DEBTRANS From GLOCK
    Trbegin [SCL]
  Endif
  Delete [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP <> "CCN"
  If fstat Then
    If ITRANSFLG Then
      GOK = 0
      Call FSTA("SCL") From GLOCK
    Else
      #Erreur lors de la suppression de l'échantillon.
      GMESSAGE = mess(788,196,1)
      GERR = 1
      Rollback
    Endif
    Close Local File [MOG1]
    Close Local File [MOG2]
    Return
  Endif
  If !ITRANSFLG Then
    Commit
  Endif
  #Suppression des ciblages associés à l'opération marketing
  If GSZOPGNUM = "" Then
    Return
  Endif
  #Traitement de la cible Tiers
  Filter [MOG1] Where [F:MOG1]OPGNUM = GSZOPGNUM and [F:MOG1]TGR = "BPARTNER"
  For [MOG1] MOG2
    Read [MQR]MQR0=[F:MOG1]MKGQUR
    If !fstat Then
      If [F:MQR]WIZCRE = 2 Then
        SZMQRNUM = [F:MOG1]MKGQUR
        IOTHERMQR = 0
        Filter [MOG2] Where [F:MOG2]MKGQUR = SZMQRNUM and [F:MOG2]OPGNUM <> GSZOPGNUM and [F:MOG2]TGR = "BPARTNER"
        For [MOG2]MOG1
          IOTHERMQR = 1
          Break
        Next
        Filter [MOG2]
        #Le ciblage n'est pas utilisé par une autre opération. On peut le supprimer.
        If !IOTHERMQR Then
          If !ITRANSFLG Then
            Call DEBTRANS From GLOCK
            Trbegin [MQR], [MQP], [QCR], [QCV], [QTP]
          Endif
          Delete [MQR] Where [F:MQR]QURNUM = SZMQRNUM
          If fstat Then
            If ITRANSFLG Then
              GOK = 0
              Call FSTA("MQR") From GLOCK
            Else
              #Erreur lors de la suppression des composants du ciblage.
              GMESSAGE = mess(761,196,1)
              GERR = 1
              Rollback
            Endif
            Break
          Endif
          Delete [MQP] Where [F:MQP]QURNUM = SZMQRNUM
          If fstat Then
            If ITRANSFLG Then
              GOK = 0
              Call FSTA("MQP") From GLOCK
            Else
              #Erreur lors de la suppression des composants du ciblage.
              GMESSAGE = mess(761,196,1)
              GERR = 1
              Rollback
            Endif
            Break
          Endif
          Delete [QCR] Where [F:QCR]QURNUM = SZMQRNUM
          If fstat Then
            If ITRANSFLG Then
              GOK = 0
              Call FSTA("QCR") From GLOCK
            Else
              #Erreur lors de la suppression des composants du ciblage.
              GMESSAGE = mess(761,196,1)
              GERR = 1
              Rollback
            Endif
            Break
          Endif
          Delete [QCV] Where [F:QCV]QURNUM = SZMQRNUM
          If fstat Then
            If ITRANSFLG Then
              GOK = 0
              Call FSTA("QCV") From GLOCK
            Else
              #Erreur lors de la suppression des composants du ciblage.
              GMESSAGE = mess(761,196,1)
              GERR = 1
              Rollback
            Endif
            Break
          Endif
          Delete [QTP] Where [F:QTP]QURNUM = SZMQRNUM
          If fstat Then
            If ITRANSFLG Then
              GOK = 0
              Call FSTA("QTP") From GLOCK
            Else
              #Erreur lors de la suppression des composants du ciblage.
              GMESSAGE = mess(761,196,1)
              GERR = 1
              Rollback
            Endif
            Break
          Endif
          If !ITRANSFLG Then
            Commit
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [MOG1]
  If GERR Then
    Close Local File [MOG1]
    Close Local File [MOG2]
    Return
  Endif
  #On supprime maintenant la relation Ciblage / Opération courante.
  If !ITRANSFLG Then
    Call DEBTRANS From GLOCK
    Trbegin [MOG1]
  Endif
  Delete [MOG1] Where [F:MOG1]OPGNUM = GSZOPGNUM and [F:MOG1]TGR = "BPARTNER"
  If fstat Then
    If ITRANSFLG Then
      GOK = 0
      Call FSTA("MOG1") From GLOCK
    Else
      #Erreur lors de la suppression des composants du ciblage.
      GMESSAGE = mess(761,196,1)
      GERR = 1
      Rollback
    Endif
    Close Local File [MOG1]
    Close Local File [MOG2]
    Return
  Endif
  If !ITRANSFLG Then
    Commit
  Endif
  #Traitement de la cible Interlocuteur
  Filter [MOG1] Where [F:MOG1]OPGNUM = GSZOPGNUM and [F:MOG1]TGR = "CONTACTCRM"
  For [MOG1] MOG2
    Read [MQR]MQR0=[F:MOG1]MKGQUR
    If !fstat Then
      If [F:MQR]WIZCRE = 2 Then
        SZMQRNUM = [F:MOG1]MKGQUR
        IOTHERMQR = 0
        Filter [MOG2] Where [F:MOG2]MKGQUR = SZMQRNUM and [F:MOG2]OPGNUM <> GSZOPGNUM and [F:MOG2]TGR = "CONTACTCRM"
        For [MOG2]MOG1
          IOTHERMQR = 1
          Break
        Next
        Filter [MOG2]
        #Le ciblage n'est pas utilisé par une autre opération. On peut le supprimer.
        If !IOTHERMQR Then
          If !ITRANSFLG Then
            Call DEBTRANS From GLOCK
            Trbegin [MQR], [MQP], [QCR], [QCV], [QTP]
          Endif
          Delete [MQR] Where [F:MQR]QURNUM = SZMQRNUM
          If fstat Then
            If ITRANSFLG Then
              GOK = 0
              Call FSTA("MQR") From GLOCK
            Else
              #Erreur lors de la suppression des composants du ciblage.
              GMESSAGE = mess(761,196,1)
              GERR = 1
              Rollback
            Endif
            Break
          Endif
          Delete [MQP] Where [F:MQP]QURNUM = SZMQRNUM
          If fstat Then
            If ITRANSFLG Then
              GOK = 0
              Call FSTA("MQP") From GLOCK
            Else
              #Erreur lors de la suppression des composants du ciblage.
              GMESSAGE = mess(761,196,1)
              GERR = 1
              Rollback
            Endif
            Break
          Endif
          Delete [QCR] Where [F:QCR]QURNUM = SZMQRNUM
          If fstat Then
            If ITRANSFLG Then
              GOK = 0
              Call FSTA("QCR") From GLOCK
            Else
              #Erreur lors de la suppression des composants du ciblage.
              GMESSAGE = mess(761,196,1)
              GERR = 1
              Rollback
            Endif
            Break
          Endif
          Delete [QCV] Where [F:QCV]QURNUM = SZMQRNUM
          If fstat Then
            If ITRANSFLG Then
              GOK = 0
              Call FSTA("QCV") From GLOCK
            Else
              #Erreur lors de la suppression des composants du ciblage.
              GMESSAGE = mess(761,196,1)
              GERR = 1
              Rollback
            Endif
            Break
          Endif
          Delete [QTP] Where [F:QTP]QURNUM = SZMQRNUM
          If fstat Then
            If ITRANSFLG Then
              GOK = 0
              Call FSTA("QTP") From GLOCK
            Else
              #Erreur lors de la suppression des composants du ciblage.
              GMESSAGE = mess(761,196,1)
              GERR = 1
              Rollback
            Endif
            Break
          Endif
          If !ITRANSFLG Then
            Commit
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [MOG1]
  If GERR Then
    Close Local File [MOG1]
    Close Local File [MOG2]
    Return
  Endif
  #On supprime maintenant la relation Ciblage / Opération courante.
  If !ITRANSFLG Then
    Call DEBTRANS From GLOCK
    Trbegin [MOG1]
  Endif
  Delete [MOG1] Where [F:MOG1]OPGNUM = GSZOPGNUM and [F:MOG1]TGR = "CONTACTCRM"
  If fstat Then
    If ITRANSFLG Then
      GOK = 0
      Call FSTA("MOG1") From GLOCK
    Else
      #Erreur lors de la suppression des composants du ciblage.
      GMESSAGE = mess(761,196,1)
      GERR = 1
      Rollback
    Endif
    Close Local File [MOG1]
    Close Local File [MOG2]
    Return
  Endif
  If !ITRANSFLG Then
    Commit
  Endif
  #On supprime enfin tous les ciblages créé via l'assistant qui ne sont pas associé à une opération marketing
  Filter [MQR] Where [F:MQR]WIZCRE = 2
  For [MQR]
    IDELREMMQR = 1
    Filter [MOG1] Where [F:MOG1]MKGQUR = [F:MQR]QURNUM
    For [MOG1]MOG0
      IDELREMMQR = 0
      Break
    Next
    Filter [MOG1]
    If IDELREMMQR Then
      #On supprime le ciblage
      If !ITRANSFLG Then
        Call DEBTRANS From GLOCK
        Trbegin [MQR]
      Endif
      Delete [MQR] Curr
      If fstat Then
        If ITRANSFLG Then
          GOK = 0
          Call FSTA("MQR") From GLOCK
        Else
          #Erreur lors de la suppression des composants du ciblage.
          GMESSAGE = mess(761,196,1)
          GERR = 1
          Rollback
        Endif
        Break
      Else
        If !ITRANSFLG Then
          Commit
        Endif
      Endif
    Endif
  Next
  Filter [MQR]
  Close Local File [MOG1]
  Close Local File [MOG2]
Return
