#<AdxTL>@(#)7.0.0.0 $Revision$
#########################################################################
# CNSCSFSTD : Consultation des lignes de livraisons ventes              #
# ECRAN 1   : CONSCSF1                                                  #
# ECRAN 2   : CONSCSF2                                                  #
# ECRAN CRIT: CRITCSF                                                   #
#########################################################################

$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "DEB_CRIT"   : Gosub DEB_CRIT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AB2_NBLIG"  : Gosub AB2_NBLIG
 When Default
Endcase
Return
############################################################
$AUTORIS
Return
###################################################################
# analyse paramères, initialisations, ouvertures et déclarations  #
###################################################################
$OUVRE
Local Char    WFIL(250),WFIL1(250),WFIL2(250)
Local Char    DEBNUM, FINNUM
Local Date    DEBDAT, FINDAT
Local Integer DEBLIN, FINLIN :# 69747
#MAE, on ajoute la consultation dans la pile de la navigation
NAVIG="CONSCSF"

Gosub DEFCRIT
Return
# --------------------------------------------------------------------------#
# Analyse paramères, initialisations                                        #
# --------------------------------------------------------------------------#
$DEFCRIT

If [M:CSF1]STOFCY<>"" & GUSRFCY(1)<>"\" & !find([M:CSF1]STOFCY,GUSRFCY(1..GNBAUZ))
 [M:CSF1]STOFCY=""
Endif

For I = 1 To dim(PARAM)
  Case I
    When 1 :    : # Parametre article
      If PARAM(I) <> ""
        If [F:ITM]ITMREF<>PARAM(I) Read [F:ITM]ITM0=PARAM(I)
                                     If fstat
                                        Raz [F:ITM], PARAM(I)
                                     Endif
        Endif
        [M:CSF1]ITMREF = PARAM(I)
      Endif

    When 2 :    : # Parametre client
      If PARAM(I) <> ""
        If [F:BPC]BPCNUM<>PARAM(I) Read [F:BPC]BPC0=PARAM(I)
                                     If fstat
                                        Raz [F:BPC], PARAM(I)
                                     Endif
        Endif
        [M:CSF1]BPCORD = PARAM(I)
       Endif

    When 3 :    : # Parametre Site
      If PARAM(I) <> ""
        If [F:FCY]FCY <> PARAM(I)    Read [F:FCY]FCY0 = PARAM(I)
                                     If fstat
                                       Raz [F:FCY], PARAM(I)
                                     Endif
        Endif
        If GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ))
           [M:CSF1]STOFCY = PARAM(I)
           If [M:CSF1]STOFCY <> ""
             Call GETDEV([M:CSF1]STOFCY) From DEVSUB
             [M:CSF1]CPY  = GSOCIETE
           Endif
        Endif
      Endif
    When 4 :    : # Parametre PJT
      # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
      If PARAM(I) <> "" Then
        [M:CSF1]PJTDEB = PARAM(I)
        [M:CSF1]PJTFIN = PARAM(I)
        If find(GNAVIG(GPILNAV-0),"GESPJM") Then   # Note FGR : '-0' is not an error. This is true in this case.
          [M:CSF1]PJTDSPALL = [V]CST_AYES
        Endif
      Endif
      # Issue Issue X3-15598 - 2017-02-23 by FGR : END
    When 5 :    : # Parametre DATBEG
      # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
      If PARAM(I) <> ""  and PARAM(I) <> "000000" Then
        [M:CSF1]DLVDATDEB = PARAM(I)
        [M:CSF1]DLVDATDEB = gdat$(01,month([M:CSF1]DLVDATDEB),year([M:CSF1]DLVDATDEB))
      Endif
      # Issue Issue X3-15598 - 2017-02-23 by FGR : END
  Endcase
Next I

If !find([M:CSF1]LNDO,1,2)    : [M:CSF1]LNDO = 2 : Endif
If !find([M:CSF1]LNDN,1,2)    : [M:CSF1]LNDN = 2 : Endif
If !find([M:CSF1]SCO,1,2)     : [M:CSF1]SCO = 2 : Endif
If !find([M:CSF1]NONINV,1,2)  : [M:CSF1]NONINV = 2  : Endif :# X3-1152 : Non invoiceable deliveries
If !find([M:CSF1]CFMFLGO,1,2) : [M:CSF1]CFMFLGO = 2 : Endif
If !find([M:CSF1]CFMFLGN,1,2) : [M:CSF1]CFMFLGN = 2 : Endif
If !find([M:CSF1]INVFLGO,1,2) : [M:CSF1]INVFLGO = 2 : Endif
If !find([M:CSF1]INVFLGN,1,2) : [M:CSF1]INVFLGN = 2 : Endif
If !find([M:CCSF]INVFLGO,1,2) : [M:CCSF]INVFLGO = 2 : Endif
If !find([M:CCSF]INVFLGN,1,2) : [M:CCSF]INVFLGN = 2 : Endif
If !find([M:CCSF]RTNFLGO,1,2) : [M:CCSF]RTNFLGO = 2 : Endif
If !find([M:CCSF]RTNFLGN,1,2) : [M:CCSF]RTNFLGN = 2 : Endif
If !find([M:CCSF]TRI,1,2)     : [M:CCSF]TRI = 1   : Endif

[M:CSF1]DLVDATFIN=eomonth(date$)
# Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
#[M:CSF1]DLVDATDEB=gdat$(01,month(addmonth(date$,-2)),year(addmonth(date$,-2)))
If [M:CSF1]DLVDATDEB = [0/0/0] Then
  [M:CSF1]DLVDATDEB=gdat$(01,month(addmonth(date$,-2)),year(addmonth(date$,-2)))
Endif
# Issue Issue X3-15598 - 2017-02-23 by FGR : END

# -- copie de l'écran critères (CCSF) vers le masque 1 (CSF1)
Gosub CRITENT From =PROGCNS

Return

############################################################
$DEB_CRIT
#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM","GESITF")
        If find(GNAVIG(GPILNAV-1),"GESITM")
            Diszo [M:CCSF]ITMREF
        Elsif find(GNAVIG(GPILNAV-1),"GESITF")
            Diszo [M:CCSF]ITMREF
            Diszo [M:CCSF]STOFCY
            Diszo [M:CCSF]CPY
        Endif
        If dim([M:CCSF]TSICOD) > 0
          For I = 0 To dim([M:CCSF]TSICOD)-1
            Diszo [M:CCSF]TSICOD(I)
          Next I
        Endif
    Endif
    #acces depuis clients ou fournisseurs
    If find(GNAVIG(GPILNAV-1),"GESBPS","GESBPC")
        Diszo [M:CCSF]BPCORD
        If dim([M:CCSF]TSCCOD) > 0
          For I = 0 To dim([M:CCSF]TSCCOD)-1
            Diszo [M:CCSF]TSCCOD(I)
          Next I
        Endif
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
    If find(GNAVIG(GPILNAV-1),"GESPJM","PJMACTBUD", "PJMACTTAS") Then
      Diszo [M:CCSF]PJTDEB
      Diszo [M:CCSF]PJTFIN
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : END
Endif

Return
############################################################

$LECTURE
Local   Decimal  WMNTORG(0..5), WMNTDES(0..5)
Local   Integer  SPSTAT

#MAE, on utilise GPILNAV et non pas GPILNAV-1 car les consultations ne sont pas comptabilisées dans GPILNAV
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM")
        Diszo[CSF1]ITMREF
    Elsif find(GNAVIG(GPILNAV-1),"GESITF")
        Diszo[CSF1]ITMREF
        Diszo[CSF1]STOFCY
        Diszo[CSF1]CPY
    Endif

    #acces depuis clients ou fournisseurs
    If find(GNAVIG(GPILNAV-1),"GESBPS","GESBPC")
        Diszo [M:CSF1]BPCORD
    Endif

    # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
    If find(GNAVIG(GPILNAV-1),"GESPJM","PJMACTBUD", "PJMACTTAS") Then
      Diszo [M:CSF1]PJTDEB
      Diszo [M:CSF1]PJTFIN
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : END

    # GRNA 16/05/2011
    Local Char CUSSEAORI : CUSSEAORI = "CSF1"
    Gosub LECTURE From CUSSEALIB
Endif

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif
#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

Link [SDD] With [SDH]SDH0=[F:SDD]SDHNUM
&            As [LNK]


# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #
#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CCSF]TRI
      When 1 : # tri par numéro
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SDD0
      When 2 : # tri par date
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                    Order By [F:SDH]DLVDAT;[F:SDD]SDHNUM;[F:SDD]SDDLIN :# 69747
#&                    Order By Key SDD2

    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CCSF]TRI
      When 1 : # tri par numéro
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SDD0 Desc
      When 2 : # tri par date
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                    Order By [F:SDH]DLVDAT Desc;[F:SDD]SDHNUM Desc;[F:SDD]SDDLIN Desc :# 69747
#&                    Order By Key SDD2 Desc

    Endcase
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CSF2] : Endif
#-- lecture
$BOUCLE
For [LNK] With Nohint

# Filtre sur la société
  If [M:CSF1]CPY <> ""
      If [F:FCY]FCY <> [F:SDD]STOFCY Read [F:FCY]FCY0 = [F:SDD]STOFCY
                                     If fstat  Raz [F:FCY] : Endif
                                     Endif
      If [F:FCY]LEGCPY <> [M:CSF1]CPY Goto SUIV : Endif
  Endif

  If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:CSF2] : Endif
     NBLU = 2
  Endif
  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
     NOL    += 1
     If NOL=0
         #69747
         If CHGPAG=2
           If [F:SDD]SDHNUM=FINNUM and [F:SDD]SDDLIN<=FINLIN : NOL-=1 : Goto SUIV : Endif
         Endif
         #fin 69747
         DEBNUM = [F:SDD]SDHNUM
         DEBDAT = [F:SDH]DLVDAT
         DEBLIN = [F:SDD]SDDLIN :# 69747
     Endif
     FINNUM = [F:SDD]SDHNUM
     FINDAT = [F:SDH]DLVDAT
     FINLIN = [F:SDD]SDDLIN :# 69747
  Else
     If NOL <= 0 : RETOUR=2 : Break : Endif
     NOL    -= 1
     If NOL=MAXLIG-1
         #69747
         If CHGPAG=-2
           If [F:SDD]SDHNUM=DEBNUM and [F:SDD]SDDLIN>=DEBLIN : NOL+=1 : Goto SUIV : Endif
         Endif
         #fin 69747
         FINNUM = [F:SDD]SDHNUM
         FINDAT = [F:SDH]DLVDAT
         FINLIN = [F:SDD]SDDLIN :# 69747
     Endif
     DEBNUM = [F:SDD]SDHNUM
     DEBDAT = [F:SDH]DLVDAT
     DEBLIN = [F:SDD]SDDLIN :# 69747
  Endif


#69747 - CPO Problème découvert lors de la résolution de cette fiche
#Pourquoi recharget-on le filtre à l'intérieur du For ????? On rajoute en boucle la même valeur
#A TESTER...J'ai tout mis en commentaire !!!
#Case CHGPAG
#   When 3 : # rafraichissement
#     Case [M:CCSF]TRI
#       When 1 : # tri par numéro
#           WFIL += "&[F:SDD]SDHNUM>=DEBNUM"
#       When 2 : # tri par date
#           WFIL += "&[F:SDH]DLVDAT>=DEBDAT"
#     Endcase
#   When 2 : # suite
#     Case [M:CCSF]TRI
#       When 1 : # tri par numéro
#           WFIL += "&[F:SDD]SDHNUM>FINNUM"
#       When 2 : # tri par date
#           WFIL += "&[F:SDH]DLVDAT>=FINDAT & [F:SDD]SDHNUM>FINNUM"
#     Endcase
#   When -2 : # retour
#     Case [M:CCSF]TRI
#       When 1 : # tri par numéro
#           WFIL += "&[F:SDD]SDHNUM<DEBNUM"
#       When 2 : # tri par date
#           WFIL += "&[F:SDH]DLVDAT<DEBDAT"
#     Endcase
#Endcase






  nolign = NOL+1
  [M:CSF2]=[F:SDH] : # trans-classe de l'entête en premier
  [M:CSF2]=[F:SDD] : # trans-classe des lignes ensuite

  # 40127 : Return status management
  [M:CSF2]RTNSTA(nolign-1)=1
  If [F:SDD]RTNQTYSTU>=[F:SDD]QTYSTU
      [M:CSF2]RTNSTA(nolign-1)=3
  Elsif [F:SDD]RTNQTYSTU<>0
     [M:CSF2]RTNSTA(nolign-1)=2
  Endif
  # 40127

  $SUIV
Next
Filter [LNK]

Return
############################################################
#    Préparation du filtre                                 #
############################################################
$LOAD_FILTER
WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"


If !clalev([F:SDH]) : Local File SDELIVERY [SDH] : Endif

If [M:CSF1]STOFCY <> ""
    WFIL += "&[F:SDD]STOFCY=[M:CSF1]STOFCY"
Endif
#    Autorisation site
#MAE, utilisation des habilitations utilisateurs même si le site est vide
#If GUSRFCY(1)<>"\"& [M:CSF1]STOFCY <> "" & GNBAUZ<>GNBSITE
If GUSRFCY(1)<>"\"& GNBAUZ<>GNBSITE
    WFIL += "& find([F:SDD]STOFCY,GUSRFCY(1..GNBAUZ))"
Endif

If [M:CSF1]ITMREF <> ""
   WFIL += "&[F:SDD]ITMREF =[M:CSF1]ITMREF"
Endif

If [M:CSF1]BPCORD <> ""
   WFIL += "&[F:SDH]BPCORD =[M:CSF1]BPCORD"
Endif

#--CPO 75115 Problème découvert : A FAIRE corriger par une fiche
##Prise en compte des livraisons de sous traitance
##--> si 1(non) on exclut les livraisons de sous traitance
#If [M:CSF1]SCO=1
#    #--CPO 80446
#    #WFIL += "&[F:SDH]SCO<>4"
#    WFIL += "&[F:SDH]SCO<>2"
#    #--/CPO
#Endif
## Prise en compte des livraisons normales
## --> Si 1 (Non) On exclut les livraisons normales
#If [M:CSF1]LNDN = 1
#   WFIL += "&[F:SDH]LND<>1"
#Endif
## Prise en compte des livraisons de pret
## --> Si 1 (Non) On exclut les livraisons de pret
#If [M:CSF1]LNDO = 1
#   WFIL += "&[F:SDH]LND=1"
#Endif
################################################################
# catégorie de liv : normale, prêt, sous-traitance
If [M:CSF1]LNDN = 2 Then         # Normal = Oui
  If [M:CSF1]LNDO = 2 Then       # Prêt = Oui
    If [M:CSF1]SCO = 2 Then      # Sous-traitance = Oui
                                 # Pas de filtre supplémentaire
      # X3-1152 : Non invoiceable deliveries
      If [M:CSF1]NONINV = 2 Then # Nonbillable = Yes
                                 # Pas de filtre supplémentaire
      Else
        WFIL += "&[F:SDH]SDHCAT<>4"
      Endif
      # X3-1152 : Non invoiceable deliveries
    Else                         # Sous-traitance = Non
      # X3-1152 : Non invoiceable deliveries
#      WFIL += "&[F:SDH]SCO<>2"
      If [M:CSF1]NONINV = 2 Then # Nonbillable = Yes
       WFIL += "&[F:SDH]SCO<>2"
      Else                                         # Nonbillable = Yes
       WFIL += "&[F:SDH]SCO<>2&[F:SDH]SDHCAT<>4"   # Nonbillable = Yes
      Endif
      # X3-1152 : Non invoiceable deliveries
    Endif
  Else                           # Prêt = Non
    If [M:CSF1]SCO = 2 Then      # Sous-traitance = Oui
      # X3-1152 : Non invoiceable deliveries
#      WFIL += "&[F:SDH]LND<>2"
       If [M:CSF1]NONINV = 2 Then                   # Nonbillable = Yes
          WFIL += "&[F:SDH]LND<>2"
       Else                                         # Nonbillable = Yes
          WFIL += "&[F:SDH]LND<>2&[F:SDH]SDHCAT<>4" # Nonbillable = no
       Endif
      # X3-1152 : Non invoiceable deliveries
    Else                         # Sous-traitance = Non
       # X3-1152 : Non invoiceable deliveries
#      WFIL += "&[F:SDH]LND<>2&[F:SDH]SCO<>2"
       If [M:CSF1]NONINV = 2 Then                   # Nonbillable = Yes
        WFIL += "&[F:SDH]LND<>2&[F:SDH]SCO<>2"
       Else
        WFIL += "&[F:SDH]LND<>2&[F:SDH]SCO<>2&[F:SDH]SDHCAT<>4"
        # X3-1152 : Non invoiceable deliveries
     Endif
    Endif
  Endif
Else                             # Normal = Non
  If [M:CSF1]LNDO = 2 Then       # Prêt = Oui
    If [M:CSF1]SCO = 2 Then      # Sous-traitance = Oui
      # X3-1152 : Non invoiceable deliveries
#      WFIL += "&([F:SDH]LND=2|[F:SDH]SCO=2)"
      If [M:CSF1]NONINV = 2 Then                    # Nonbillable = Yes
        WFIL += "&([F:SDH]LND=2|[F:SDH]SCO=2|[F:SDH]SDHCAT=4)"
      Else
        WFIL += "&([F:SDH]LND=2|[F:SDH]SCO=2)"
      Endif
      # X3-1152 : Non invoiceable deliveries
    Else                         # Sous-traitance = Non
       # X3-1152 : Non invoiceable deliveries
#      WFIL += "&[F:SDH]LND=2"
      If [M:CSF1]NONINV = 2 Then                    # Nonbillable = Yes
        WFIL += "&([F:SDH]LND=2|[F:SDH]SDHCAT=4)"
      Else
        WFIL += "&[F:SDH]LND=2"
      Endif
      # X3-1152 : Non invoiceable deliveries
    Endif
  Else                           # Prêt = Non
    If [M:CSF1]SCO = 2 Then      # Sous-traitance = Oui
    # X3-1152 : Non invoiceable deliveries
      #WFIL += "&[F:SDH]SCO=2"
      If [M:CSF1]NONINV = 2 Then                    # Nonbillable = Yes
        WFIL += "&([F:SDH]SCO=2|[F:SDH]SDHCAT=4)"
      Else
        WFIL += "&[F:SDH]SCO=2"
      Endif
      # X3-1152 : Non invoiceable deliveries
    Else                         # Sous-traitance = Non
      # X3-1152 : Non invoiceable deliveries
#      WFIL += "&1=2"
      If [M:CSF1]NONINV = 2 Then                    # Nonbillable = Yes
        WFIL += "&[F:SDH]SDHCAT=4"
      Else
        WFIL += "&1=2"
     Endif
     # X3-1152 : Non invoiceable deliveries
    Endif
  Endif
Endif
################################################################
# Prise en compte des livraisons validées
# --> Si 1 (Non) On exclut les livraisons validées
If [M:CSF1]CFMFLGO = 1
   WFIL += "&[F:SDH]CFMFLG<>2"
Endif
# Prise en compte des livraisons non validées
# --> Si 1 (Non) On exclut les livraisons non validées
If [M:CSF1]CFMFLGN = 1
   WFIL += "&[F:SDH]CFMFLG<>1"
Endif
# Prise en compte des livraisons facturées
# --> Si 1 (Non) On exclut les livraisons facturées
If [M:CSF1]INVFLGO = 1
   WFIL += "&[F:SDH]INVFLG<>2"
Endif
# Prise en compte des livraisons non facturées
# --> Si 1 (Non) On exclut les livraisons non facturées
If [M:CSF1]INVFLGN = 1
   WFIL1 += "&[F:SDH]INVFLG<>1"
Endif
# Prise en compte des livraisons retournées
# --> Si 1 (Non) On exclut les livraisons retournées
If [M:CCSF]RTNFLGO = 1
   WFIL1 += "&[F:SDH]RTNSTA<=1"
Endif

# 40127 : Return status management
## Prise en compte des livraisons non retournées
## --> Si 1 (Non) On exclut les livraisons non retournées mais uniquement pour les liv. de prêt
##                l'état retour n'est pas géré pour les livraisons normales (tjs non retournées)
#If [M:CCSF]RTNFLGN = 1
#   WFIL1 += "& ([F:SDH]LND=1 | ([F:SDH]LND=2 & [F:SDH]RTNSTA>1))"
#Endif
# Prise en compte des livraisons non retournées
# --> Si 1 (Non) On exclut les livraisons non retournées
If [M:CCSF]RTNFLGN = 1
   WFIL1 += "&[F:SDH]RTNSTA>1"
Endif
# 40127

If [M:CCSF]SDHNUMDEB <> ""
   WFIL1 += "&[F:SDD]SDHNUM>=[M:CCSF]SDHNUMDEB"
Endif
If [M:CCSF]SDHNUMFIN <> ""
   WFIL1 += "&[F:SDD]SDHNUM<=[M:CCSF]SDHNUMFIN"
Endif

If [M:CCSF]DLVDATDEB <> [0/0/0]
   WFIL1 += "&[F:SDH]DLVDAT>=[M:CCSF]DLVDATDEB"
Endif
If [M:CCSF]DLVDATFIN <> [0/0/0]
   WFIL1 += "&[F:SDH]DLVDAT<=[M:CCSF]DLVDATFIN"
Endif

#--CPO 75115 Prise en compte du "Type de livraison"
#---Livraisons normalles
If [M:CSF1]LNDN=2
If [M:CSF1]DLVTYPNOR<>"" : WFIL1 += "&(([F:SDH]SDHCAT=1 & [F:SDH]SDHTYP=[M:CSF1]DLVTYPNOR)|[F:SDH]SDHCAT<>1)" : Endif
Endif
#---Livraisons de prêt
If [M:CSF1]LNDO=2
If [M:CSF1]DLVTYPLND<>"" : WFIL1 += "&(([F:SDH]SDHCAT=2 & [F:SDH]SDHTYP=[M:CSF1]DLVTYPLND)|[F:SDH]SDHCAT<>2)" : Endif
Endif
#---Livraison pour sous-traitance
If [M:CSF1]SCO=2
If [M:CSF1]DLVTYPSCO<>"" : WFIL1 += "&(([F:SDH]SDHCAT=3 & [F:SDH]SDHTYP=[M:CSF1]DLVTYPSCO)|[F:SDH]SDHCAT<>3)" : Endif
Endif
# X3-1152 : Non invoiceable deliveries
If [M:CSF1]NONINV=2
If [M:CSF1]DLVTYPNIN<>"" : WFIL1 += "&(([F:SDH]SDHCAT=4 & [F:SDH]SDHTYP=[M:CSF1]DLVTYPNIN)|[F:SDH]SDHCAT<>4)" : Endif
Endif
# X3-1152 : Non invoiceable deliveries

#--/CPO

If dim([M:CCSF]TSICOD) > 0
  For I = 0 To dim([M:CCSF]TSICOD)-1
    If [M:CCSF]TSICOD(I) <> ""
        WFIL2 += "&[F:SDD]TSICOD("+num$(I)+")='"+[M:CCSF]TSICOD(I)+"'"
    Endif
  Next I
Endif

If dim([M:CCSF]TSCCOD) > 0
  For I = 0 To dim([M:CCSF]TSCCOD)-1
    If [M:CCSF]TSCCOD(I) <> ""
        WFIL2 += "&[F:SDH]TSCCOD("+num$(I)+")='"+[M:CCSF]TSCCOD(I)+"'"
    Endif
  Next I
Endif

# Issue X3-25731 - 2017-02-24 by FGR : BEGIN
## 71065 : PJT
#If [M:CCSF]PJTDEB <> ""
#   WFIL2 += "&[F:SDD]PJT>=[M:CCSF]PJTDEB"
#Endif
#If [M:CCSF]PJTFIN <> ""
#   WFIL2 += "&[F:SDD]PJT<=[M:CCSF]PJTFIN"
#Endif
## 71065 : PJT
If dim([M:CCSF]PJTDSPALL) >= 0 and [M:CCSF]PJTDSPALL = [V]CST_AYES and [M:CCSF]PJTDEB <> "" Then
  Local Char SPJT(GLONPIM)
  Local Char SBUDGET(GLONTAC)
  Local Char STASK(GLONPBU)
  Local Integer IRET

  IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:CCSF]PJTDEB, SPJT, SBUDGET, STASK)
  WFIL1 += "&pat([F:SDD]PJT,'" + SPJT + "*')<>0"
Else
  If [M:CCSF]PJTDEB <> ""
     WFIL2 += "&[F:SDD]PJT>=[M:CCSF]PJTDEB"
  Endif
  If [M:CCSF]PJTFIN <> ""
     WFIL2 += "&[F:SDD]PJT<=[M:CCSF]PJTFIN"
  Endif
Endif
# Issue X3-25731 - 2017-02-24 by FGR : END

Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CCSF]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:SDD]SDHNUM>=DEBNUM"
       When 2 : # tri par date
           WFIL += "&([F:SDH]DLVDAT>DEBDAT | ([F:SDH]DLVDAT=DEBDAT  & [F:SDD]SDHNUM>=DEBNUM))"
     Endcase
   When 2 : # suite
     Case [M:CCSF]TRI
       When 1 : # tri par numéro
           #WFIL += "&[F:SDD]SDHNUM>FINNUM"
           WFIL += "&[F:SDD]SDHNUM>=FINNUM" :# 69747
       When 2 : # tri par date
           #WFIL += "&([F:SDH]DLVDAT>FINDAT | ([F:SDH]DLVDAT=FINDAT  & [F:SDD]SDHNUM>FINNUM))"
           WFIL += "&([F:SDH]DLVDAT>FINDAT | ([F:SDH]DLVDAT=FINDAT  & [F:SDD]SDHNUM>=FINNUM))" :#69747
     Endcase
   When -2 : # retour
     Case [M:CCSF]TRI
       When 1 : # tri par numéro
           #WFIL += "&[F:SDD]SDHNUM<DEBNUM"
           WFIL += "&[F:SDD]SDHNUM<=DEBNUM" :# 69747
       When 2 : # tri par date
           #WFIL += "& ([F:SDH]DLVDAT<DEBDAT | ([F:SDH]DLVDAT=DEBDAT & [F:SDD]SDHNUM<DEBNUM))"
           WFIL += "& ([F:SDH]DLVDAT<DEBDAT | ([F:SDH]DLVDAT=DEBDAT & [F:SDD]SDHNUM<=DEBNUM))" :#69747
     Endcase
Endcase

Return

############################################################################
#    Avant de fermer la fenetre critère et de revenir à fenetre principale #
############################################################################
$FIN_CRIT


Return

$AB2_NBLIG
Local Char    WOBJET(GLONAOB)
If [M:CSF2]SOPLIN(nolign-1) = [M:CSF2]SOQSEQ(nolign-1)
    WOBJET= "SOH"
Else
    WOBJET= "SOR"
Endif
Return



#############################################################################
##     Etiquettes masques CONSCSD1 & CONSCSD2 & CRITCSD                    ##
#############################################################################
############################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
#If VALEUR <> ""
#  [M]CURS = [F:CPY]ACCCUR : GLOCALDEV=[F:CPY]ACCCUR
#Elsif [M]STOFCY = ""
# Mail CH : 03/03/04
#  GERR=2 : GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
#  Raz [M]CURS
#  [M]CURS=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
#Endif
#Affzo [M]CURS
End
############################################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
# -- Controle autorisation sur le site
    If GUSRFCY(1)<>"\" & !find(VALEUR,GUSRFCY(1..GNBAUZ))
        GMESSAGE=VALEUR-mess(2,104,1)   : # Vous n'avez pas les droits sur ce site
        mkstat=2 : End
    Endif
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE
        Affzo [M]CPY, ZCPY
Elsif [M]CPY = ""
    # Mail CH : 03/03/04
    #    GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
    #    mkstat = 2
    Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif

End
########################################
Subprog IB_NBLIG
GBOUT1 = mess(54, 198,1)-[M]SDHNUM(nolign-1)
Raz GBOUT2, GBOUT3

If [M:CSF2]SOHNUM(nolign-1) <> ""
    If [M:CSF2]SOPLIN(nolign-1) = [M:CSF2]SOQSEQ(nolign-1)
        GBOUT2 = mess(1,306,1)-[M]SOHNUM(nolign-1)
    Else
        GBOUT2 = mess(92,198,1)-[M]SOHNUM(nolign-1)
    Endif
Else
    Raz GBOUT2
Endif


#Gbn-83180-98325
If func AFNC.ACTIV("LST")
 If [M:CSF2]MFGNUM(nolign-1) <> ""
     GBOUT3 = mess(5,306,1)-[M]MFGNUM(nolign-1)
 Endif
Endif

End
