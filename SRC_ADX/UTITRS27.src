##########################################################################
# UTITRS27                              Module   A/P-A/R Accounting      #
#                                                                        #
#               Update STA of PAYLOT                                     #
#                           - 88764 -                                    #
#                                                                        #
##########################################################################

If clalev([F:ADS])=0
    Local File ADOSSIER [ADS]
Endif

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOS(WDOSSIER,"") From SAIDOS

If WDOSSIER <> ""
  Read [ADS]DOSSIER=WDOSSIER
  If fstat <> 0
        Raz [F:ADS]
  Endif

 # Call ACTIVE From TIMING


  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Update STA of PAYLOT") From LECFIC
  Call MAJ_UTITRS27(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC

 # Call ARRET From TIMING


Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTITRS27(DOSSIER)
Value Char DOSSIER

Local Integer WCOMPTEUR, STOP, NB
Local Char TABMIGKEY(30)

Call ECR_TRACE("UTITRS27 : Start of process on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:PYL])  =0 : Local File =DOSSIER+".PAYLOT"     [PYL]   : Endif
If clalev([F:PYH])  =0 : Local File =DOSSIER+".PAYMENTH"   [PYH]   : Endif


WCOMPTEUR = 0
Call DEBTRANS From GLOCK


$LOOP
Raz NB

If STOP = 1
 STOP = 0
 CRITERE = "[F:PYH]PAYLOT>'"+TABMIGKEY+"'"
Else
 CRITERE = "[F:PYH]PAYLOT>''"
Endif

Trbegin [PYL]

 Filter [PYH] Where evalue(CRITERE)

 For [PYH]PYH2(1)
  OK=1
  For [PYH]PYH2
   If [PYH]STA<5 : OK=0 : Break : Endif
  Next
  If OK=1
   Update [PYL] Where COD=[F:PYH]PAYLOT & STA=0 With STA=5
   If fstat = 0
    WCOMPTEUR += [S]adxuprec
    NB+=1
    If NB>GMAXUPDTRS
     TABMIGKEY = [F:PYH]PAYLOT
     STOP=1
     Break
    Endif
   Endif
  Endif
 Next

Commit

If STOP
 Goto LOOP
Endif

Close Local File [PYL]
Call ECR_TRACE("UTITRS27 : "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTITRS27 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif                                 : # Module tiers

If filinfo(filpath("FIL","PAYLOT","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTITRS27(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
#If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif                                 : # N= module
If filinfo(filpath("FIL","PAYLOT","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table

Call MAJ_UTITRS27(APPLI)
End
