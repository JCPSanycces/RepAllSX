#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
 When Default
Endcase
Return


$OUVRE
Local Integer WSRT,WRET
Local Char    CRITERE(255)
Local Char    CRITERE1(255)
Local Char    CRITERE2(255)
Local Char    CRITERE3(255)
Local Char    FORMULE1(250)
# 103333 mm 04.2015
Local Char    DEBNUM(GLONVCR),FINNUM(GLONVCR)
Local Date    DEBDAT,FINDAT
Local Char    DEBITM(GLONITM),FINITM(GLONITM)
#


If clalev ([F:ITM])  <= 0 : Local File ITMMASTER  [ITM] : Endif
If clalev ([F:FCY])  <= 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:MFG])  <= 0 : Local File MFGHEAD    [MFG] : Endif
If clalev ([F:MFI])  <= 0 : Local File MFGITM     [MFI] : Endif
If clalev ([F:TFO])  <= 0 : Local File TABFOR     [TFO] : Endif
If clalev ([F:TUN])  <= 0 : Local File TABUNIT    [TUN] : Endif
If clalev ([F:WGG])  <= 0 : Local File WEIGHING   [WGG] : Endif
If clalev ([F:WGP])  <= 0 : Local File WEIGHPRT   [WGP] : Endif

Gosub DEFCRIT
# 103333 mm 04.2015
If !find([M:CWGP]TRI,1,3,4) : [M:CWGP]TRI = 1 : Endif

NAVIG="CONSWGP"
Return

#############################################################################
# analyse paramètres
$DEFCRIT
For I = 1 To dim(PARAM)
    Case I
        When 1 : # site
                 If PARAM(I) <> ""
                     Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
                     If !fstat & [F:FCY]MFGFLG = 2 : [M:WGP1]MFGFCY = PARAM(I) : Endif
                 Endif
        When 2 : # article
                 If PARAM(I) <> ""
                     Read [ITM]ITM0 = PARAM(I)
                     If !fstat
                         [M:WGP1]ITMREFSTR = PARAM(I)
                         [M:WGP1]ITMREFEND = PARAM(I)
                     Endif
                 Endif
        When 3 : # Pièce
                 If PARAM(I) <> ""
                     [M:WGP1]MFGNUMSTR = PARAM(I)
                     [M:WGP1]MFGNUMEND = PARAM(I)
                 Endif
        When 4 : # date fin
                 If PARAM(I) <> ""
                     If instr(1,PARAM(I),"/")
                         [M:WGP1]CBTDATSTR = "["+PARAM(I)+"]"
                         [M:WGP1]CBTDATEND = "["+PARAM(I)+"]"
                     Else
                         [M:WGP1]CBTDATSTR = PARAM(I)
                         [M:WGP1]CBTDATEND = PARAM(I)
                     Endif
                 Endif
        When 5 : # tri
                 If PARAM(I) <> ""
                     WSRT = val(PARAM(I))
                     If WSRT < 0 | WSRT > 5  : WSRT = 1 : Endif
                     [M:CWGP]TRI = WSRT
                 Endif
        When Default: Break
    Endcase
Next I
# copie de l'écran critères (CWGP) vers le masque 0 (WGP1)
Gosub CRITENT From =PROGCNS
Return







############################################################
$LECTURE
# si le tri n'est pas passé en paramètre, pas de chargement automatique
If [M:WGP1]MFGFCY = ""  : NBLU = 0 : Return : Endif
# si le tri n'est pas passé en paramètre, pas de chargement automatique
If PARAM(5) = "" : NBLU=0 : PARAM(5) = "1" : Return : Endif

Gosub CHANGE_MSK From GCONSULT
If CHGPAG < 0 : NOL = MAXLIG : Endif

# filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif


# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

# application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CWGP]TRI
      When 4 : # tri par date
          Link [WGP] With [MFG]MFG0=[F:WGP]MFGNUM;[F:WGP]MFGLIN;[F:WGP]BOMSEQ;[F:WGP]ITMREF,
&                         [WGG]WGG0=[F:WGP]MFGNUM;[F:WGP]BOMOPE;[F:WGP]ITMREF;[F:WGP]MFGLIN;[F:WGP]BOMSEQ;[F:WGP]CBTDAT;[F:WGP]MVTSEQ
&                    As [WGX]
&                    Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                    evalue(FORMULE1)
&                    Order By Key CLE=[F:WGP]CBTDAT
      When 1 : # tri par OF
          Link [WGP] With [MFG]MFG0=[F:WGP]MFGNUM;[F:WGP]MFGLIN;[F:WGP]BOMSEQ;[F:WGP]ITMREF,
&                         [WGG]WGG0=[F:WGP]MFGNUM;[F:WGP]BOMOPE;[F:WGP]ITMREF;[F:WGP]MFGLIN;[F:WGP]BOMSEQ;[F:WGP]CBTDAT;[F:WGP]MVTSEQ
&                    As [WGX]
&                    Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                    evalue(FORMULE1)
&                    Order By Key CLE=[F:WGP]MFGNUM
      When 3 : # tri par article
           Link [WGP] With [MFG]MFG0=[F:WGP]MFGNUM;[F:WGP]MFGLIN;[F:WGP]BOMSEQ;[F:WGP]ITMREF,
&                         [WGG]WGG0=[F:WGP]MFGNUM;[F:WGP]BOMOPE;[F:WGP]ITMREF;[F:WGP]MFGLIN;[F:WGP]BOMSEQ;[F:WGP]CBTDAT;[F:WGP]MVTSEQ
&                    As [WGX]
&                    Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                    evalue(FORMULE1)
&                    Order By Key CLE=[F:WGP]ITMREF
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CWGP]TRI
      When 4 : # tri par date
          Link [WGP] With [MFG]MFG0=[F:WGP]MFGNUM;[F:WGP]MFGLIN;[F:WGP]BOMSEQ;[F:WGP]ITMREF,
&                         [WGG]WGG0=[F:WGP]MFGNUM;[F:WGP]BOMOPE;[F:WGP]ITMREF;[F:WGP]MFGLIN;[F:WGP]BOMSEQ;[F:WGP]CBTDAT;[F:WGP]MVTSEQ
&                    As [WGX]
&                    Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                    evalue(FORMULE1)
&                    Order By Key CLE=[F:WGP]CBTDAT Desc
      When 1 : # tri par OF
          Link [WGP] With [MFG]MFG0=[F:WGP]MFGNUM;[F:WGP]MFGLIN;[F:WGP]BOMSEQ;[F:WGP]ITMREF,
&                         [WGG]WGG0=[F:WGP]MFGNUM;[F:WGP]BOMOPE;[F:WGP]ITMREF;[F:WGP]MFGLIN;[F:WGP]BOMSEQ;[F:WGP]CBTDAT;[F:WGP]MVTSEQ
&                    As [WGX]
&                    Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                    evalue(FORMULE1)
&                    Order By Key CLE=[F:WGP]MFGNUM Desc
      When 3 : # tri par article
           Link [WGP] With [MFG]MFG0=[F:WGP]MFGNUM;[F:WGP]MFGLIN;[F:WGP]BOMSEQ;[F:WGP]ITMREF,
&                         [WGG]WGG0=[F:WGP]MFGNUM;[F:WGP]BOMOPE;[F:WGP]ITMREF;[F:WGP]MFGLIN;[F:WGP]BOMSEQ;[F:WGP]CBTDAT;[F:WGP]MVTSEQ
&                    As [WGX]
&                    Where evalue(CRITERE1)&evalue(CRITERE2) & evalue(CRITERE3)&
&                    evalue(FORMULE1)
&                    Order By Key CLE=[F:WGP]ITMREF Desc
    Endcase
Endif

# raz du masque
If CHGPAG <> 2 & CHGPAG <> -2 : Raz [M:WGP2] : Endif

# lecture
$BOUCLE

For [WGX]
  If NBLU = 1
     If CHGPAG = 2 | CHGPAG = -2 : Raz [M:WGP2] : Endif
     NBLU = 2
  Endif

  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE = 2 : Break : Endif
     NOL    += 1
     If NOL=0
         DEBNUM = [F:WGG]MFGNUM
         DEBDAT = [F:WGG]CBTDAT
         DEBITM = [F:WGG]ITMREF
     Endif
     FINNUM = [F:WGG]MFGNUM
     FINDAT = [F:WGG]CBTDAT
     FINITM = [F:WGG]ITMREF
  Else
     If NOL <= 0 : RETOUR = 2 : Break : Endif
     NOL    -= 1
     If NOL = MAXLIG-1
         FINNUM = [F:WGG]MFGNUM
         FINDAT = [F:WGG]CBTDAT
         FINITM = [F:WGG]ITMREF
     Endif
     DEBNUM = [F:WGG]MFGNUM
     DEBDAT = [F:WGG]CBTDAT
     DEBITM = [F:WGG]ITMREF
  Endif
  nolign = NOL+1

  Gosub FILLTAB

$SUIV
Next

Return

#############################################################################
# Chargements spéciaux
$FILLTAB
[M:WGP2] = [F:MFG]
[M:WGP2] = [F:WGG]
[M:WGP2] = [F:WGP]

Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[M:WGP2]ITMREF(nolign-1),[M:WGP2]ITMDES1(nolign-1), "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296

Return


#############################################################################
# Préparation du filtre                                                     #
#############################################################################
$LOAD_FILTER
Raz CRITERE
Raz CRITERE1
Raz CRITERE2
Raz CRITERE3

CRITERE1 = "1=1"
# site
If [M:WGP1]MFGFCY <> ""
   CRITERE = "[F:MFG]MFGFCY=[M:WGP1]MFGFCY"
   Gosub LOAD_CRITERE2
Endif

# ordre
If [M:CWGP]MFGNUMSTR <> ""
   CRITERE = "[F:WGG]MFGNUM>=[M:CWGP]MFGNUMSTR"       # borne début ordre
   Gosub LOAD_CRITERE2
Endif
If [M:CWGP]MFGNUMEND<>""
   CRITERE = "[F:WGG]MFGNUM<=[M:CWGP]MFGNUMEND"       # borne fin   ordre
   Gosub LOAD_CRITERE2
Endif

# date de pesée
If [M:CWGP]CBTDATSTR <> [0/0/0]
   CRITERE = "[F:WGG]CBTDAT>=[M:CWGP]CBTDATSTR"       # borne debut date fin
   Gosub LOAD_CRITERE2
Endif
If [M:CWGP]CBTDATEND <> [0/0/0]
   CRITERE = "[F:WGG]CBTDAT<=[M:CWGP]CBTDATEND"       # borne fin date fin
   Gosub LOAD_CRITERE2
Endif

# Composant
If [M:CWGP]ITMREFSTR <> ""
    CRITERE = "[F:WGG]ITMREF>=[M:CWGP]ITMREFSTR"      # borne début article
    Gosub LOAD_CRITERE3
Endif
If [M:CWGP]ITMREFEND<>""
    CRITERE = "[F:WGG]ITMREF<=[M:CWGP]ITMREFEND"      # borne fin   article
    Gosub LOAD_CRITERE3
Endif

# Phase
If [M:CWGP]BOMOPESTR <> 0
    CRITERE = "[F:WGG]BOMOPE>=[M:CWGP]BOMOPESTR"      # borne début article
    Gosub LOAD_CRITERE3
Endif
If [M:CWGP]BOMOPEEND<>0
    CRITERE = "[F:WGG]BOMOPE<=[M:CWGP]BOMOPEEND"      # borne fin   article
    Gosub LOAD_CRITERE3
Endif

Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CWGP]TRI
       When 4 : # tri par date
           CRITERE = "[F:WGG]CBTDAT>=DEBDAT"
           Gosub LOAD_CRITERE3
       When 1 : # tri par OF
           CRITERE = "[F:WGG]MFGNUM>=DEBNUM"
           Gosub LOAD_CRITERE3
       When 3 : # tri par article
           CRITERE = "[F:WGG]ITMREF>=DEBITM"
           Gosub LOAD_CRITERE3
     Endcase
   When 2 : # suite
     Case [M:CWGP]TRI
       When 4 : # tri par date
           CRITERE = "[F:WGG]CBTDAT>FINDAT"
           Gosub LOAD_CRITERE3
       When 1 : # tri par OF
           CRITERE = "[F:WGG]MFGNUM>FINNUM"
           Gosub LOAD_CRITERE3
       When 3 : # tri par article
           CRITERE = "[F:WGG]ITMREF>FINITM"
           Gosub LOAD_CRITERE3
     Endcase
   When -2 : # retour
     Case [M:CWGP]TRI
       When 4 : # tri par date
           CRITERE = "[F:WGG]CBTDAT<DEBDAT"
           Gosub LOAD_CRITERE3
       When 1 : # tri par OF
           CRITERE = "[F:WGG]MFGNUM<DEBNUM"
           Gosub LOAD_CRITERE3
       When 3 : # tri par article
           CRITERE = "[F:WGG]ITMREF<DEBITM"
           Gosub LOAD_CRITERE3
     Endcase
Endcase
If CRITERE2 = "" : CRITERE2 = "1=1" : Endif
If CRITERE3 = "" : CRITERE3 = "1=1" : Endif

# analyse présence formule de sélection
If [M:CWGP]FORMULE  = ""
    FORMULE1 = "1=1"
Else
    Read [F:TFO]TFO0=12;[M:CWGP]FORMULE
    If fstat
        FORMULE1 = "1=1"
    Else
        FORMULE1 = [F:TFO]FORFOR
    Endif
Endif

Return

#############################################################################
$LOAD_CRITERE
If len(CRITERE1)=0
    CRITERE1 += "("
Else
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE
Return

#############################################################################
$LOAD_CRITERE2
If len(CRITERE2)<>0 : CRITERE2 += "&" : Endif
CRITERE2 += CRITERE
Return

#############################################################################
$LOAD_CRITERE3
If len(CRITERE3)<>0 : CRITERE3 += "&" : Endif
CRITERE3 += CRITERE
Return

# Gestion du masque CONSWGP1

######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSWGP1) 11/02/2011 11:25:19 (GBE)
######################################################################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M:WGP1]ITMREFEND = ""     : [M:WGP1]ITMREFEND = VALEUR : Affzo [M:WGP1]ITMREFEND : Endif
If [M:WGP1]ITMREFEND < VALEUR : [M:WGP1]ITMREFEND = VALEUR : Affzo [M:WGP1]ITMREFEND : Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSWGP1) 11/02/2011 16:10:21 (GBE)
######################################################################################
Subprog AM_MFGNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M:WGP1]MFGNUMEND = ""     : [M:WGP1]MFGNUMEND = VALEUR : Affzo [M:WGP1]MFGNUMEND : Endif
If [M:WGP1]MFGNUMEND < VALEUR : [M:WGP1]MFGNUMEND = VALEUR : Affzo [M:WGP1]MFGNUMEND : Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran CRITWGP) 15/02/2011 15:02:57 (GBE)
######################################################################################
Subprog C_CBTDATEND(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:WGP1]CBTDATSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End


######################################################################################
# Module GPAO
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(8)<>2 End Endif

Call VALGTC(APPLI,"WGP") From SUBGTC

End


######################################################################################
## Etiquette ajoutée par le superviseur (écran CRITWGP) 05/05/2015 09:44:01 (MM)
######################################################################################
# 103333 mm 04.2015
Subprog AS_TRI(VALEUR)
Variable Integer VALEUR
  GMENLOC(2)=1
  GMENLOC(5)=1
End


######################################################################################
