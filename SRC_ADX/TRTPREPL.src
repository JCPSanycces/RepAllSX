#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################
# Plan de préparation d'expéditions                            TRTPREPL #
#-----------------------------------------------------------------------#
# Librairie d'actions                                                   # 
#########################################################################

#########################################################################
$SEL_LISTE
Case LISTE
     When "SAIPREP"         : Gosub STKSELTRS
     When "STKSELPRL"       : Gosub STKSELPRL
     When "STKSELPRH"       : Gosub STKSELPRH
Endcase
Return

#########################################################################
$FIN_LISTE

Case LISTE
     When "SAIPREP"         : Gosub STKFINTRS
Endcase
Return

#########################################################################

$CONTROLE
If GFLAG = "" 
   FIN = 1
Endif
Return

########################################################################
# STKSELTRS                                        Selection transaction
########################################################################
$STKSELTRS
Local Char    TABACS(10)(100)
Local Integer NBACS
Local Char    TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char   TIT(30)
Local Integer NBTEX
Local Char    CRITERE(250)

If clalev([F:ACC])=0 : Local File ACCES  [ACC] : Endif 
If clalev([F:SRT])=0 : Local File STKTRS [SRT] : Endif

CRITERE = "SRTTYP=10  & [F:SRT]ENAFLG = 2"     # hcb 88573

If GPROFIL<>GSUPER
  For [ACC]CODACC Where USR=GUSER
    If [F:ACC]EXEC=2 
      [L]TABACS(NBACS)=vireblc([F:ACC]CODACC,1)
      NBACS +=1
    Endif
    If NBACS>99 Break Endif
  Next
  CRITERE += "&(ACSCOD=''|find(ACSCOD,TABACS(0..99)))"
Endif

For [F:SRT] Where evalue(CRITERE)
    NBTEX+= 1
    TEX(NBTEX)   =[F:SRT]SRTNUM
    Call LECTEXTRA(TEXTE(NBTEX),"STKTRS","DESAXX",num$([F:SRT]SRTTYP),[F:SRT]SRTNUM) From ATEXTRA
    TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
Next
TIT(0) = mess(3,126,1) # Choix transactions

If dim(GFLAG)>0 & GFLAG<>""
    Filter [SRT] Where evalue(CRITERE)
    Read [SRT] SRT0=10;GFLAG
    Filter [SRT]
    If !fstat & [F:SRT]ENAFLG=2
        If dim(GHCBBOI)<=0
            Global Char GHCBBOI(GLONFEN) 
        Endif
        GHCBBOI = "WQPRE"+[F:SRT]SRTNUM+"1"
        OK=0
    Endif
Endif

Return

$STKFINTRS
Global Char GLBOI(GLONFEN)
 
If GSTATUT=7
   VALEUR = "" 
   Raz GFLAG
   Return
Endif
Read [SRT] SRT0=10;VALEUR
If fstat | [F:SRT]ENAFLG=1 OK=0 : Endif
GLBOI = "WQPRE"+[F:SRT]SRTNUM+"1"
GFLAG = [F:SRT]SRTNUM

#MAE, le 29/01/08, GRP_LISTE
GGRPFCY = [F:SRT]GFY

Return

#########################################################################
# STKSELPRL      Selection sur fichier STOPRELIS - Liste de préparation #  
#########################################################################
$STKSELPRL
Local Char LFCY(GLONFCY)
Local Char NUMLIS(GLONVCR)

Local Integer Z
Local Char    SZTIT

If clalev([F:PRL])=0 : Local File STOPRELIS [PRL] : Endif

LFCY = PARAM(1)
Raz Z, SZTIT

If LFCY<>""
   Filter [PRL] Where STOFCY=LFCY Order By Key PRL0 Desc
Endif

For [PRL]
   If NUMLIS = [F:PRL]PRLNUM 
      Goto NEXTBON
   Endif 
   NUMLIS = [F:PRL]PRLNUM
   If Z>=dim(TEX)-1 Break Endif
   Z += 1
   TEX(Z)   = [F:PRL]PRLNUM
   TEXTE(Z) = [F:PRL]PRLNUM 
$NEXTBON
Next

If LFCY<>"" Filter [PRL] Endif

NBTEX = Z
SZTIT = mess(23,721,1)
TIT   = left$(SZTIT,20)

Return

#########################################################################
# STKSELPRH    Selection sur fichier STOPREH - Bon préparation en cours #  
#########################################################################
$STKSELPRH
Local Char LFCY(GLONFCY)
Local Char NUM(GLONVCR)

Local Integer Z
Local Char    SZTIT

If clalev([F:PRH])=0 : Local File STOPREH [PRH] : Endif

LFCY = PARAM(1)
Raz Z, SZTIT

If LFCY<>""
   Filter [PRH] Where STOFCY=LFCY & DLVFLG<2 Order By Key PRH0 Desc
Endif

For [PRH]
   If NUM = [F:PRH]PRHNUM 
      Goto NEXTLIS
   Endif 
   NUM = [F:PRH]PRHNUM
   If Z>=dim(TEX)-1 Break Endif
   Z += 1
   TEX(Z)   = [F:PRH]PRHNUM
   TEXTE(Z) = [F:PRH]PRHNUM 
$NEXTLIS
Next

If LFCY<>"" Filter [PRH] Endif

NBTEX = Z
SZTIT = mess(24,721,1)
TIT   = left$(SZTIT,20)

Return

