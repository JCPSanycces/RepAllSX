#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################
# SUBWRH   Gestion des dépôts                                           #
#########################################################################
$ACTION
Case ACTION
 When "CREATION"  : Gosub CREATION
 When "VERF_ANU"  : Gosub VERF_ANU
 When "ANNULE"    : Gosub ANNULE
 When Default
Endcase
Return

#########################################################################
$CREATION
# Création des articles dépôts
Call GENITW(1,[F:WRH]STOFCY,[F:WRH]WRH) From STKWRH
Return

#########################################################################
$VERF_ANU
# Il ne doit plus y avoir de stock sur le dépôt
Filter [STO] Where STOFCY=[F:WRH]STOFCY & WRH=[F:WRH]WRH 
If rowcount([STO])<>0
   Filter [STO]
   GERR = 1 : GMESSAGE = mess(956,196,1)
   OK = 0   : Return
Endif
Filter [STO]
# Il ne doit plus y avoir d'emplacements sur le dépôt
Filter [STC] Where STOFCY=[F:WRH]STOFCY & WRH=[F:WRH]WRH 
If rowcount([STC])<>0
   Filter [STC]
   GERR = 1 : GMESSAGE = mess(957,196,1)
   OK = 0   : Return
Endif
Filter [STC]
Return

#########################################################################
$ANNULE
# Suppression des articles dépôts
Call DELITW(1,[F:WRH]STOFCY,[F:WRH]WRH) From STKWRH
Return


#########################################################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
If [F:FCY]WRHGES<>2
   mkstat=2 : GMESSAGE=mess(337,184,1)
Endif
End

#--- Bug 60422
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
If GREP="C" End Endif
# Il ne doit plus y avoir de stock sur le dépôt
Filter [STO] Where STOFCY=[F:WRH]STOFCY & WRH=[F:WRH]WRH 
If rowcount([STO])<>0
   Filter [STO]
   mkstat=2 : GMESSAGE = mess(954,196,1)
   End
Endif
Filter [STO]
# Il ne doit plus y avoir d'emplacements sur le dépôt
Filter [STC] Where STOFCY=[F:WRH]STOFCY & WRH=[F:WRH]WRH 
If rowcount([STC])<>0
   Filter [STC]
   mkstat=2 : GMESSAGE = mess(955,196,1)
   End
Endif
Filter [STC]
End
#---

#########################################################################
