#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre ONCSH

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:14:27"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"ONCSH",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="NCSH0;NCSH1;NCSH2;NCSH4;NCSH3;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 1
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
OBJLIS(0) = "NCSH"
CHGLIS(0) = 2
BROLIS(0) = 2
TRELIS(0) = 1
DESLIS(0) = "NCSID"
OBJLIS(1) = "NCSH1"
CHGLIS(1) = 2
BROLIS(1) = 2
TRELIS(1) = 1
DESLIS(1) = "NCSID"
OBJLIS(2) = "NCSH2"
CHGLIS(2) = 2
BROLIS(2) = 2
TRELIS(2) = 1
DESLIS(2) = "NCSID"
OBJLIS(3) = "NCSH3"
CHGLIS(3) = 2
BROLIS(3) = 2
TRELIS(3) = 1
DESLIS(3) = ""
OBJLIS(4) = "NCSH4"
CHGLIS(4) = 2
BROLIS(4) = 2
TRELIS(4) = 1
DESLIS(4) = "NCSID"
If clalev([M:NCSH0])=0 : Local Mask NCSH0 [NCSH0] : Endif
If clalev([M:NCSH1])=0 : Local Mask NCSH1 [NCSH1] : Endif
If clalev([M:NCSH2])=0 : Local Mask NCSH2 [NCSH2] : Endif
If clalev([M:NCSH4])=0 : Local Mask NCSH4 [NCSH4] : Endif
If clalev([M:NCSH3])=0 : Local Mask NCSH3 [NCSH3] : Endif
Gosub TIT
nolign = 1
If clalev([F:AXXM])=0 : Local file ATEXTRA [AXXM] : Endif
If clalev([F:AXXP])=0 : Local file ATEXTRA [AXXP] : Endif
If clalev([F:AXXC])=0 : Local file ATEXTRA [AXXC] : Endif
Link [NCSRC] With
& [AXXM]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]NCSMANAGER;"",
& [AXXP]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]NCSPLANNER;"",
& [AXXC]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]CREUSR;""
& As [NCSRC_]
If clalev([F:NCSRC])=0 : Local file NCSRECENT [NCSRC] : Endif
If clalev([F:AXXM])=0 : Local file ATEXTRA [AXXM] : Endif
If clalev([F:AXXP])=0 : Local file ATEXTRA [AXXP] : Endif
If clalev([F:AXXC])=0 : Local file ATEXTRA [AXXC] : Endif
Link [NCSRC] With
& [AXXM]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]NCSMANAGER;"",
& [AXXP]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]NCSPLANNER;"",
& [AXXC]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]CREUSR;""
& As [NCSRC_]
If clalev([F:NCSRC])=0 : Local file NCSRECENT [NCSRC] : Endif
If clalev([F:AXXM])=0 : Local file ATEXTRA [AXXM] : Endif
If clalev([F:AXXP])=0 : Local file ATEXTRA [AXXP] : Endif
If clalev([F:AXXC])=0 : Local file ATEXTRA [AXXC] : Endif
Link [NCSRC] With
& [AXXM]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]NCSMANAGER;"",
& [AXXP]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]NCSPLANNER;"",
& [AXXC]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]CREUSR;""
& As [NCSRC_]
If clalev([F:NCSRC])=0 : Local file NCSRECENT [NCSRC] : Endif
If clalev([F:AXXM])=0 : Local file ATEXTRA [AXXM] : Endif
If clalev([F:AXXP])=0 : Local file ATEXTRA [AXXP] : Endif
If clalev([F:AXXC])=0 : Local file ATEXTRA [AXXC] : Endif
Link [NCSRC] With
& [AXXM]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]NCSMANAGER;"",
& [AXXP]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]NCSPLANNER;"",
& [AXXC]AXX0="AUTILIS";"INTUSR";GLANGUE;[NCSRC]CREUSR;""
& As [NCSRC_]
Return

$DEF_BOITE
Gosub HORODAT From WGONCSH
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "ONCSH" From GFONCTION At A_STAMP With A_WINDPREV Mask [NCSH0]
&   Folder Mask [NCSH1]
& , Folder Mask [NCSH2]
& , Folder Mask [NCSH4]
& , Folder Mask [NCSH3]
&  Listbox [NCSRC_] GAU_CHE
&   [L]SAIRAP(1) = [F:NCSRC]NCSID Using "K:20X" Titled TITSEL(1) ,
&   [L]SAIRAP(2) = mess([F:NCSRC]NCSSTA(0),2033,1) Using "" Titled TITSEL(2) ,
&   [L]SAIRAP(3) = [F:NCSRC]TITLE Using "K:70X" Titled TITSEL(3) ,
&   [L]SAIRAP(4) = [F:NCSRC]SITE Using "K:5c" Titled TITSEL(4) ,
&   [L]SAIRAP(5) = [F:NCSRC]PRODUCT Using "K:20c" Titled TITSEL(5) ,
&   [L]SAIRAP(6) = [F:NCSRC]ECCVALMAJ Using "K:10X" Titled TITSEL(6) ,
&   [L]SAIRAP(7) = [F:NCSRC]ECCVALMIN Using "K:10X" Titled TITSEL(7) ,
&   [L]SAIRAP(8) = [F:NCSRC]NCSBPC Using "K:15c" Titled TITSEL(8) ,
&   [L]SAIRAP(9) = [F:NCSRC]NCSBPS Using "K:15c" Titled TITSEL(9) ,
&   [L]SAIRAP(10) = [NCSRC]NCSMANAGER-[AXXM]TEXTE Using "" Titled TITSEL(10) ,
&   [L]SAIRAP(11) = [NCSRC]NCSPLANNER-[AXXP]TEXTE Using "" Titled TITSEL(11) ,
&   [L]SAIRAP(12) = mess([F:NCSRC]CLOSEDST(0),2042,1) Using "" Titled TITSEL(12) ,
&   [L]SAIRAP(13) = mess([F:NCSRC]NCSCATEGORY(0),3715,1) Using "" Titled TITSEL(13) ,
&   [L]SAIRAP(14) = [F:NCSRC]NCSROOCAU Using "K:20X" Titled TITSEL(14) ,
&   [L]SAIRAP(15) = mess([F:NCSRC]SEVERITY(0),2030,1) Using "" Titled TITSEL(15) ,
&   [L]SAIRAP(16) = mess([F:NCSRC]IMPACT(0),2031,1) Using "" Titled TITSEL(16)
&  Listbox [NCSRC9] GAU_CHE9
&   [L]SAIRAP(1) = [F:NCSRC9]A_TAB1 Using "K:20X" Titled TITSEL9(1)  ,
&   [L]SAIRAP(2) = mess([F:NCSRC9]A_TAB2,2033,1) Using "" Titled TITSEL9(2) ,
&   [L]SAIRAP(3) = [F:NCSRC9]A_TAB3 Using "K:70X" Titled TITSEL9(3)  ,
&   [L]SAIRAP(4) = [F:NCSRC9]A_TAB4 Using "K:5c" Titled TITSEL9(4)  ,
&   [L]SAIRAP(5) = [F:NCSRC9]A_TAB5 Using "K:20c" Titled TITSEL9(5)  ,
&   [L]SAIRAP(6) = [F:NCSRC9]A_TAB6 Using "K:10X" Titled TITSEL9(6)  ,
&   [L]SAIRAP(7) = [F:NCSRC9]A_TAB7 Using "K:10X" Titled TITSEL9(7)  ,
&   [L]SAIRAP(8) = [F:NCSRC9]A_TAB8 Using "K:15c" Titled TITSEL9(8)  ,
&   [L]SAIRAP(9) = [F:NCSRC9]A_TAB9 Using "K:15c" Titled TITSEL9(9)  ,
&   [L]SAIRAP(10) = [F:NCSRC9]A_TAB10 Using "" Titled TITSEL9(10) ,
&   [L]SAIRAP(11) = [F:NCSRC9]A_TAB11 Using "" Titled TITSEL9(11) ,
&   [L]SAIRAP(12) = mess([F:NCSRC9]A_TAB12,2042,1) Using "" Titled TITSEL9(12) ,
&   [L]SAIRAP(13) = mess([F:NCSRC9]A_TAB13,3715,1) Using "" Titled TITSEL9(13) ,
&   [L]SAIRAP(14) = [F:NCSRC9]A_TAB14 Using "K:20X" Titled TITSEL9(14)  ,
&   [L]SAIRAP(15) = mess([F:NCSRC9]A_TAB15,2030,1) Using "" Titled TITSEL9(15) ,
&   [L]SAIRAP(16) = mess([F:NCSRC9]A_TAB16,2031,1) Using "" Titled TITSEL9(16)
&  Listbox [NCSRC_] GAU_CHE1
&   [L]SAIRAP(1) = [F:NCSRC]NCSID Using "K:20X" Titled TITSEL1(1) ,
&   [L]SAIRAP(2) = mess([F:NCSRC]NCSSTA(0),2033,1) Using "" Titled TITSEL1(2) ,
&   [L]SAIRAP(3) = [F:NCSRC]TITLE Using "K:70X" Titled TITSEL1(3) ,
&   [L]SAIRAP(4) = [F:NCSRC]SITE Using "K:5c" Titled TITSEL1(4) ,
&   [L]SAIRAP(5) = [F:NCSRC]PRODUCT Using "K:20c" Titled TITSEL1(5) ,
&   [L]SAIRAP(6) = [F:NCSRC]ECCVALMAJ Using "K:10X" Titled TITSEL1(6) ,
&   [L]SAIRAP(7) = [F:NCSRC]ECCVALMIN Using "K:10X" Titled TITSEL1(7) ,
&   [L]SAIRAP(8) = [F:NCSRC]NCSBPC Using "K:15c" Titled TITSEL1(8) ,
&   [L]SAIRAP(9) = [F:NCSRC]NCSBPS Using "K:15c" Titled TITSEL1(9) ,
&   [L]SAIRAP(10) = [NCSRC]NCSMANAGER-[AXXM]TEXTE Using "" Titled TITSEL1(10) ,
&   [L]SAIRAP(11) = [NCSRC]NCSPLANNER-[AXXP]TEXTE Using "" Titled TITSEL1(11) ,
&   [L]SAIRAP(12) = mess([F:NCSRC]CLOSEDST(0),2042,1) Using "" Titled TITSEL1(12) ,
&   [L]SAIRAP(13) = mess([F:NCSRC]NCSCATEGORY(0),3715,1) Using "" Titled TITSEL1(13) ,
&   [L]SAIRAP(14) = [F:NCSRC]NCSROOCAU Using "K:20X" Titled TITSEL1(14) ,
&   [L]SAIRAP(15) = mess([F:NCSRC]SEVERITY(0),2030,1) Using "" Titled TITSEL1(15) ,
&   [L]SAIRAP(16) = mess([F:NCSRC]IMPACT(0),2031,1) Using "" Titled TITSEL1(16)
&  Listbox [NCSRC_] GAU_CHE2
&   [L]SAIRAP(1) = [F:NCSRC]NCSID Using "K:20X" Titled TITSEL2(1) ,
&   [L]SAIRAP(2) = mess([F:NCSRC]NCSSTA(0),2033,1) Using "" Titled TITSEL2(2) ,
&   [L]SAIRAP(3) = [F:NCSRC]TITLE Using "K:70X" Titled TITSEL2(3) ,
&   [L]SAIRAP(4) = [F:NCSRC]SITE Using "K:5c" Titled TITSEL2(4) ,
&   [L]SAIRAP(5) = [F:NCSRC]PRODUCT Using "K:20c" Titled TITSEL2(5) ,
&   [L]SAIRAP(6) = [F:NCSRC]ECCVALMAJ Using "K:10X" Titled TITSEL2(6) ,
&   [L]SAIRAP(7) = [F:NCSRC]ECCVALMIN Using "K:10X" Titled TITSEL2(7) ,
&   [L]SAIRAP(8) = [F:NCSRC]NCSBPC Using "K:15c" Titled TITSEL2(8) ,
&   [L]SAIRAP(9) = [F:NCSRC]NCSBPS Using "K:15c" Titled TITSEL2(9) ,
&   [L]SAIRAP(10) = [NCSRC]NCSMANAGER-[AXXM]TEXTE Using "" Titled TITSEL2(10) ,
&   [L]SAIRAP(11) = [NCSRC]NCSPLANNER-[AXXP]TEXTE Using "" Titled TITSEL2(11) ,
&   [L]SAIRAP(12) = mess([F:NCSRC]CLOSEDST(0),2042,1) Using "" Titled TITSEL2(12) ,
&   [L]SAIRAP(13) = mess([F:NCSRC]NCSCATEGORY(0),3715,1) Using "" Titled TITSEL2(13) ,
&   [L]SAIRAP(14) = [F:NCSRC]NCSROOCAU Using "K:20X" Titled TITSEL2(14) ,
&   [L]SAIRAP(15) = mess([F:NCSRC]SEVERITY(0),2030,1) Using "" Titled TITSEL2(15) ,
&   [L]SAIRAP(16) = mess([F:NCSRC]IMPACT(0),2031,1) Using "" Titled TITSEL2(16)
&  Listbox [NCSAPP_] GAU_CHE3
&   [L]SAIRAP(1) = [NCSAPP]NCSID Using "K:10X" Titled TITSEL3(1) ,
&   [L]SAIRAP(2) = mess([NCSAPP]NCSSTA,2033,1) Using "" Titled TITSEL3(2) ,
&   [L]SAIRAP(3) = [NCSAPP]TITLE Using "" Titled TITSEL3(3) ,
&   [L]SAIRAP(4) = [NCSAPP]SITE Using "" Titled TITSEL3(4) ,
&   [L]SAIRAP(5) = [NCSAPP]PRODUCT Using "" Titled TITSEL3(5) ,
&   [L]SAIRAP(6) = [NCSAPP]ECCVALMAJ Using "" Titled TITSEL3(6) ,
&   [L]SAIRAP(7) = [NCSAPP]ECCVALMIN Using "" Titled TITSEL3(7) ,
&   [L]SAIRAP(8) = [NCSAPP]NCSBPC Using "" Titled TITSEL3(8) ,
&   [L]SAIRAP(9) = [NCSAPP]NCSBPS Using "" Titled TITSEL3(9) ,
&   [L]SAIRAP(10) = [NCSAPP]NCSMANAGER-[AXXM]TEXTE Using "" Titled TITSEL3(10) ,
&   [L]SAIRAP(11) = [NCSAPP]NCSPLANNER-[AXXP]TEXTE Using "" Titled TITSEL3(11) ,
&   [L]SAIRAP(12) = mess([NCSAPP]CLOSEDST,2042,1) Using "K:10X" Titled TITSEL3(12) ,
&   [L]SAIRAP(13) = mess([NCSAPP]NCSCATEGORY,3715,1) Using "" Titled TITSEL3(13) ,
&   [L]SAIRAP(14) = [NCSAPP]NCSROOCAU-[AXXA]TEXTE Using "" Titled TITSEL3(14) ,
&   [L]SAIRAP(15) = mess([NCSAPP]SEVERITY,2030,1) Using "" Titled TITSEL3(15) ,
&   [L]SAIRAP(16) = mess([NCSAPP]IMPACT,2031,1) Using "" Titled TITSEL3(16)
&  Listbox [NCSRC_] GAU_CHE4
&   [L]SAIRAP(1) = [F:NCSRC]NCSID Using "K:20X" Titled TITSEL4(1) ,
&   [L]SAIRAP(2) = mess([F:NCSRC]NCSSTA(0),2033,1) Using "" Titled TITSEL4(2) ,
&   [L]SAIRAP(3) = [F:NCSRC]TITLE Using "K:70X" Titled TITSEL4(3) ,
&   [L]SAIRAP(4) = [F:NCSRC]SITE Using "K:5c" Titled TITSEL4(4) ,
&   [L]SAIRAP(5) = [F:NCSRC]PRODUCT Using "K:20c" Titled TITSEL4(5) ,
&   [L]SAIRAP(6) = [F:NCSRC]ECCVALMAJ Using "K:10X" Titled TITSEL4(6) ,
&   [L]SAIRAP(7) = [F:NCSRC]ECCVALMIN Using "K:10X" Titled TITSEL4(7) ,
&   [L]SAIRAP(8) = [F:NCSRC]NCSBPC Using "K:15c" Titled TITSEL4(8) ,
&   [L]SAIRAP(9) = [F:NCSRC]NCSBPS Using "K:15c" Titled TITSEL4(9) ,
&   [L]SAIRAP(10) = [NCSRC]NCSMANAGER-[AXXM]TEXTE Using "" Titled TITSEL4(10) ,
&   [L]SAIRAP(11) = [NCSRC]NCSPLANNER-[AXXP]TEXTE Using "" Titled TITSEL4(11) ,
&   [L]SAIRAP(12) = mess([F:NCSRC]CLOSEDST(0),2042,1) Using "" Titled TITSEL4(12) ,
&   [L]SAIRAP(13) = mess([F:NCSRC]NCSCATEGORY(0),3715,1) Using "" Titled TITSEL4(13) ,
&   [L]SAIRAP(14) = [F:NCSRC]NCSROOCAU Using "K:20X" Titled TITSEL4(14) ,
&   [L]SAIRAP(15) = mess([F:NCSRC]SEVERITY(0),2030,1) Using "" Titled TITSEL4(15) ,
&   [L]SAIRAP(16) = mess([F:NCSRC]IMPACT(0),2031,1) Using "" Titled TITSEL4(16)
& As [NCSH1]
Titled [NCSH1] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGONCSH
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "ONCSH" From GFONCTION At A_STAMP With A_WINDPREV Mask [NCSH0]
&   Folder Mask [NCSH1]
& , Folder Mask [NCSH2]
& , Folder Mask [NCSH4]
& , Folder Mask [NCSH3]
& As [NCSH1]
Titled [NCSH1] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [NCSH1] Folder AFOLDEF
Return

$SAISIE_BOITE
Boxinp [NCSH1] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [NCSH1]
Onerrgo
Return

$RIEN
Resume

