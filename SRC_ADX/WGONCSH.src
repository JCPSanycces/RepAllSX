$CHARGEFIC
Case IMA
 When 0 : If clalev([M:NCSH0])>0 : [F:NCSRC] = [M:NCSH0] : Endif
 When 1 : If clalev([M:NCSH1])>0 : [F:NCSRC] = [M:NCSH1] : Endif
 When 2 : If clalev([M:NCSH2])>0 : [F:NCSRC] = [M:NCSH2] : Endif
 When 3 : If clalev([M:NCSH4])>0 : [F:NCSRC] = [M:NCSH4] : Endif
 When 4 : If clalev([M:NCSH3])>0 : [F:NCSRC] = [M:NCSH3] : Endif
Endcase
