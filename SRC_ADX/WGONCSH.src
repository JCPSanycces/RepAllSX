$DEFAUT_BRO
Case ILIS
 When 0 : Default file [NCSRC_]
 When 1 : Default file [NCSRC_]
 When 2 : Default file [NCSRC_]
 When 3 : Default file [NCSAPP_]
 When 4 : Default file [NCSRC_]
Endcase
Return

$SETBOX
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [NCSRC_] Order With CLELISTE
  Setlbox [NCSH1] GAU_CHE
  Filter [NCSRC_]
 When "GAU_CHE9"
  Gosub CLE_DERLU From =PROGOBJ
  Setlbox [NCSH1] GAU_CHE9
 When "GAU_CHE1"
  Gosub SETCLE_1
  Filter [NCSRC_] Order With CLELISTE
  Setlbox [NCSH1] GAU_CHE1
  Filter [NCSRC_]
 When "GAU_CHE2"
  Gosub SETCLE_2
  Filter [NCSRC_] Order With CLELISTE
  Setlbox [NCSH1] GAU_CHE2
  Filter [NCSRC_]
 When "GAU_CHE3"
  Setlbox [NCSH1] GAU_CHE3
 When "GAU_CHE4"
  Gosub SETCLE_4
  Filter [NCSRC_] Order With CLELISTE
  Setlbox [NCSH1] GAU_CHE4
  Filter [NCSRC_]
Endcase
Return

$SETORDER
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [NCSRC_] Order With CLELISTE
 When "GAU_CHE1"
  Gosub SETCLE_1
  Filter [NCSRC_] Order With CLELISTE
 When "GAU_CHE2"
  Gosub SETCLE_2
  Filter [NCSRC_] Order With CLELISTE
 When "GAU_CHE4"
  Gosub SETCLE_4
  Filter [NCSRC_] Order With CLELISTE
