 When 0 : If clalev([M:NCSH0])>0 : [M:NCSH0] = [F:NCSRC] : Endif
 When 1 : If clalev([M:NCSH1])>0 : [M:NCSH1] = [F:NCSRC] : Endif
 When 2 : If clalev([M:NCSH2])>0 : [M:NCSH2] = [F:NCSRC] : Endif
 When 3 : If clalev([M:NCSH4])>0 : [M:NCSH4] = [F:NCSRC] : Endif
