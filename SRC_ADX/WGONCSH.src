$GRISE_CLE
If AMA(0)
 Grizo [NCSH0]NCSID
Else
 Grizo [NCSH1]NCSID
Endif
Return

$DEGRISE_CLE
If AMA(0)
 Actzo [NCSH0]NCSID
Else
 Actzo [NCSH1]NCSID
Endif
Return

$BOUTON
STDBOUT = "ECSAN09<>RHILJMP"
NBTEX  = 0
NBTEX += 1
CBOUT(NBTEX) = "2" : LBOUT(NBTEX) = 1101 : Call TEXTE(1003537,TEXTE(NBTEX)) From OBJDIV
NBTEX += 1
CBOUT(NBTEX) = "4" : LBOUT(NBTEX) = 1102 : Call TEXTE(2917,TEXTE(NBTEX)) From OBJDIV
NBTEX += 1
CBOUT(NBTEX) = "3" : LBOUT(NBTEX) = 1103 : Call TEXTE(10825,TEXTE(NBTEX)) From OBJDIV
NBTEX += 1
CBOUT(NBTEX) = "7" : LBOUT(NBTEX) = 1104 : Call TEXTE(1704,TEXTE(NBTEX)) From OBJDIV
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
NBMEN += 1
NMEN(NBMEN) = 10 : Call TEXTE(12966,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 10 : CMEN(NBMEN) = "B" : LMEN(NBMEN) = 2001 : Call TEXTE(1004471,TMEN(NBMEN)) From OBJDIV
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
 When "3"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  FLGEXE = 1
  GACTION = "NCSREJ"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"DNCSR","SUBNCSR","") From GSAISIE
 When "B"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:NCSH0]PLANID
  PARBOUT(2) = "NCSP"
  FLGEXE = 1
  GACTION = "NCSPLAN"
  Call OBJET_CHAR(PARBOUT(1),PARBOUT(2),PARBOUT(3)) From GOBJET
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


