$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(0) = "NCSH0"        : ABMSK(0)  = "NCSH0"    : AMA(0) = 1
NOMMSK(1) = "NCSH1"        : ABMSK(1)  = "NCSH1"    : AMA(1) = 1
NOMMSK(2) = "NCSH2"        : ABMSK(2)  = "NCSH2"    : AMA(2) = 1
NOMMSK(3) = "NCSH4"        : ABMSK(3)  = "NCSH4"    : AMA(3) = 1
NOMMSK(4) = "NCSH3"        : ABMSK(4)  = "NCSH3"    : AMA(4) = 1
NBMASK = 4
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 0 : If clalev([M:NCSH0])>0 : Default Mask [NCSH0] : Endif
 When 1 : If clalev([M:NCSH1])>0 : Default Mask [NCSH1] : Endif
 When 2 : If clalev([M:NCSH2])>0 : Default Mask [NCSH2] : Endif
 When 3 : If clalev([M:NCSH4])>0 : Default Mask [NCSH4] : Endif
 When 4 : If clalev([M:NCSH3])>0 : Default Mask [NCSH3] : Endif
Endcase
Return

$TITMASK
Case MA
 When 0 : If clalev([M:NCSH0])>0 : Gosub TITRES From W1NCSH0 : Endif
 When 1 : If clalev([M:NCSH1])>0 : Gosub TITRES From W1NCSH1 : Endif
 When 2 : If clalev([M:NCSH2])>0 : Gosub TITRES From W1NCSH2 : Endif
 When 3 : If clalev([M:NCSH4])>0 : Gosub TITRES From W1NCSH4 : Endif
 When 4 : If clalev([M:NCSH3])>0 : Gosub TITRES From W1NCSH3 : Endif
Endcase
Return

$FERME_MASK
If clalev([M:NCSH0])>0 : Close Local Mask [NCSH0] : Endif
If clalev([M:NCSH1])>0 : Close Local Mask [NCSH1] : Endif
If clalev([M:NCSH2])>0 : Close Local Mask [NCSH2] : Endif
If clalev([M:NCSH4])>0 : Close Local Mask [NCSH4] : Endif
If clalev([M:NCSH3])>0 : Close Local Mask [NCSH3] : Endif
Return

$RAZMASK
Case MA
 When 0 : If clalev([M:NCSH0])>0 : Raz [M:NCSH0] : Endif
 When 1 : If clalev([M:NCSH1])>0 : Raz [M:NCSH1] : Endif
 When 2 : If clalev([M:NCSH2])>0 : Raz [M:NCSH2] : Endif
 When 3 : If clalev([M:NCSH4])>0 : Raz [M:NCSH4] : Endif
 When 4 : If clalev([M:NCSH3])>0 : Raz [M:NCSH3] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 0 : If clalev([M:NCSH0])>0 : Affzo [M:NCSH0] : Endif
 When 1 : If clalev([M:NCSH1])>0 : Affzo [M:NCSH1] : Endif
 When 2 : If clalev([M:NCSH2])>0 : Affzo [M:NCSH2] : Endif
 When 3 : If clalev([M:NCSH4])>0 : Affzo [M:NCSH4] : Endif
 When 4 : If clalev([M:NCSH3])>0 : Affzo [M:NCSH3] : Endif
Endcase
