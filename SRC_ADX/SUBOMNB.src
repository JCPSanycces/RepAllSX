#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################################################
#   Programmes utilitaires pour la gestion des campagnes presse    Module CRM             15 Décembre 2003
#
#   DISPICON    : Affichage des icônes
#   SAVECLOB    : Enregistrement des CLOBs
#   DELCLOB     : Suppression des CLOBs
#   LOADCLOB    : Chargement du CLOB compte-rendu
#   CHECKMODIF  : Contrôle de la modification d'une opération.
#
##########################################################################################################

##########################################################################################################
#Affichage des icônes
######################################################
$DISPICON
  Gosub DEFICONNUM From CRMUTIL150
  #Synthèse Objet de l'action
  If len([M:OMN1]FULOBJ) > GLONCLE Then
    If [M:OMN1]OBJFLG Then
      [M:OMN1]OBJICO = SZICOSYNDON
    Else
      [M:OMN1]OBJICO = SZICOSYN
    Endif
    Actzo [M:OMN1]OBJICO
  Else
    [M:OMN1]OBJICO = "-1"
    Grizo [M:OMN1]OBJICO
  Endif
Return

##########################################################################################################
#Enregistrement des CLOBs
######################################################
$SAVECLOB
Local Char SZCTLCLOB(250)

  Gosub DELCLOB
  If GOK < 1 Then
    Return
  Endif
  #Objet de l'action
  Raz SZCTLCLOB
  Setlob SZCTLCLOB With [M:OMN1]FULOBJ
  If SZCTLCLOB <> "" Then
    Raz [F:HD5]
    [F:HD5]NUM = [M:OMN1]NUMFULOBJ
    [F:HD5]TYP = [M:OMN1]TYPFULOBJ
    [F:HD5]CLOB = [M:OMN1]FULOBJ
    Write [HD5]
    If fstat Then
      #Erreur lors de l'enregistrement de la description de l'opération marketing. Transaction abandonnée.
      GMESSAGE = mess(880,182,1)
      GERR = 1
      Call FSTA("HD5") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
#Suppression des CLOBs
######################################################
$DELCLOB
  Delete [HD5] Where [F:HD5]NUM = [M:OMN1]NUMFULOBJ and [F:HD5]TYP = [M:OMN1]TYPFULOBJ
  If fstat Then
    #Erreur lors de la suppression de la description de l'opération marketing. Transaction abandonnée.
    GMESSAGE = mess(881,182,1)
    GERR = 1
    Call FSTA("HD5") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
#Suppression des CLOBs
######################################################
$DELCLOB2
  Delete [HD5] Where [F:HD5]NUM = GSZOPGNUM and [F:HD5]TYP = "OMN"
  If fstat Then
    #Erreur lors de la suppression de la description de l'opération marketing. Transaction abandonnée.
    GMESSAGE = mess(881,182,1)
    GERR = 1
    Call FSTA("HD5") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
# Chargement du CLOB compte-rendu
######################################################
$LOADCLOB
Local Integer ILOOKFORCLOB

  ILOOKFORCLOB = 1
  If [M:OMN1]NUMFULOBJ = "" Then
    Raz [M:OMN1]FULOBJ
    ILOOKFORCLOB = 0
  Endif
  If [M:OMN1]TYPFULOBJ = "" Then
    Raz [M:OMN1]FULOBJ
    ILOOKFORCLOB = 0
  Endif
  If ILOOKFORCLOB Then
    Read [HD5]HD50=[M:OMN1]NUMFULOBJ;[M:OMN1]TYPFULOBJ
    If fstat Then
      Raz [M:OMN1]FULOBJ
    Else
      [M:OMN1]FULOBJ = [F:HD5]CLOB
    Endif
  Endif
Return

##########################################################################################################
# Contrôle de la modification d'une opération.
######################################################
$CHECKDATA
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  # FGR 06/08/2014 : X3SUIVI95250 (début)
  #  #Synthèse Objet de l'action
  #  If [M:OMN1]FULOBJ = "" Then
  #    [M:OMN1]OBJ = ""
  #  Else
  #    [M:OMN1]OBJ = left$([M:OMN1]FULOBJ,250)
  #  Endif
  # FGR 06/08/2014 : X3SUIVI95250 (fin)
  #Contrôle de la présence de dates
  If [M:OMN1]OMNSTR = [00/00/00] Then
    GMESSAGE = mess(107,177,1) #Une date de début et de fin de l'opération doivent être précisées.
    GERR = 2
    OK = 0
    Return
  Endif
  #Contrôle de la présence de dates
  If [M:OMN1]OMNEND = [00/00/00] Then
    GMESSAGE = mess(107,177,1) #Une date de début et de fin de l'opération doivent être précisées.
    GERR = 2
    OK = 0
    Return
  Endif
  #Contrôle de la cohérence des dates
  If [M:OMN1]OMNSTR > [M:OMN1]OMNEND Then
    GMESSAGE = mess(106,177,1) #La date de fin d'opération ne peut pas être inférieure à la date de début.
    GERR = 2
    OK = 0
    Return
  Endif
  Call CMGCTRLDATEDEB([M:OMN1]OMNSTR,[M:OMN0]CMGNUM,IERRINF,ICHAPTER,IBRETOUR) From SUBCMGB
  If IBRETOUR= 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 2
    OK = 0
    Return
  Endif
  Call CMGCTRLDATEFIN([M:OMN1]OMNEND,[M:OMN0]CMGNUM,IERRINF,ICHAPTER,IBRETOUR) From SUBCMGB
  If IBRETOUR= 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 2
    OK = 0
    Return
  Endif
  #La description doit être renseignée.
  If [M:OMN1]DES = "" Then
    GMESSAGE = mess(342,196,1) #Aucune description n'a été saisie. Cette information est obligatoire.
    GERR = 2
    OK = 0
    Return
  Endif
  #La devise doit être renseignée.
  If [M:OMN1]CUR = "" Then
    GMESSAGE = mess(385,196,1) #Aucun code devise n'est renseigné. Création refusée.
    GERR = 2
    OK = 0
    Return
  Endif
  Read [TCU]TCU0=[M:OMN1]CUR
  If fstat Then
    GMESSAGE = mess(84,116,1) #Devise incorrecte.
    GERR = 2
    OK = 0
    Return
  Else
    If [F:TCU]EURFLG = 2 Then
      If [F:TCU]CURENDDAT <> [00/00/00] Then
        If [F:TCU]CURENDDAT < date$ Then
          GMESSAGE = mess(84,116,1) #Devise incorrecte.
          GERR = 2
          OK = 0
          Return
        Endif
      Endif
    Endif
  Endif
Return
