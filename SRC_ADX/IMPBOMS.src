#<AdxTL>@(#)6.0.0.0 $Revision$

$ACTION
Case ACTION
    When "IMP_OUVRE"       :   Gosub OUVRE
    When "EXP_OUVRE"       :   Gosub EXP_OUVRE

    When "EXPORT"          :   Gosub EXPORT From IMPBOMP
    When "IMPORT"          :   Gosub IMPORT From IMPBOMP
    When "IMP_TAB"         :   Gosub IMP_ZONE From IMPBOMP
    When "IMP_ZONE"        :   Gosub IMP_ZONE From IMPBOMP
    When "AP_IMPORT"       :   Gosub AP_IMPORT From IMPBOMP
    When "IMP_VERIF_CRE"   :   Gosub IMP_VERIF_CREMOD From IMPBOMP
    When "IMP_VERIF_MOD"   :   Gosub IMP_VERIF_CREMOD From IMPBOMP
    When "IMP_RAZCRE"      :   Gosub IMP_RAZCRE From IMPBOMP
    When "IMP_APRES_CRE"   :   Gosub IMP_APRES_CREMOD From IMPBOMP
    When "IMP_APRES_MOD"   :   Gosub IMP_APRES_CREMOD From IMPBOMP
Endcase

Return

$OUVRE
Local Integer LBOMALTTYP : LBOMALTTYP = 3

Gosub OUVRE From IMPBOMP

Return

#---------------------------------------------------------------------
$EXP_OUVRE
Local Integer LBOMALTTYP : LBOMALTTYP = 3

Gosub EXP_OUVRE From IMPBOMP
Return

