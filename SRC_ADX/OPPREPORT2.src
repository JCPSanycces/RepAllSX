#<AdxTL>@(#)9.0.0.0 $Revision$
#########################################################################
# OPPREPORT2 : Faiires cloturées par phase ou par représentant          #
# --------------------------------------------------------------------- #
# Chargement des paramètres                                             #
#      Etat OPPOR3 : Affaires cloturées par phase                       #
#      Etat OPPOR4 : Affaires cloturées par représentant                #
#########################################################################
#########################################################################
$ACTION
  Case ACTION
    When "OUVRE"   : Gosub OUVRE2
    When "INIPAR"  : Gosub INIPAR
    When "INIPAR2" : Gosub INIPAR
  Endcase
Return

#########################################################################
$OUVRE2
  If GAUSCRMF <> "" and GAUSCRMA = 2 and (dim(GAUSCRMROL) < 1 or (dim(GAUSCRMROL) > 0 and GAUSCRMROL <> 1)) Then
    GBIDI2 = find("REP",[M:RPT]PARTYP)
    If GBIDI2 Then
      [M:RPT]VALEUR1(GBIDI2-1) = GAUSCRMF
      [M:RPT]VALINT1(GBIDI2-1) = GAUSCRMF
      [M:RPT]VALEUR2(GBIDI2-1) = GAUSCRMF
      [M:RPT]VALINT2(GBIDI2-1) = GAUSCRMF
      Affzo [M:RPT]VALEUR1(GBIDI2-1), VALEUR2(GBIDI2-1)
    Endif  
  Endif
Return

#########################################################################
$INIPAR
  If GAUSCRMF <> "" and GAUSCRMA = 2 and [M:RPT]PARTYP(nolign-1) = "REP" Then
    mkstat = 2
  Endif
Return

######################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

  Call EXEC(NBPAR,PARAMETRE)
End

######################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value Integer    NBPAR 
Variable Char    PARAMETRE()()

Local Integer IMAX
Local Integer ICOUNT
Local Integer IAFFOK
Local Char SZMESS
  #----------------------------------------------------------------
  #   When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
  #   When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
  #----------------------------------------------------------------
  Gosub OUVRE 
  If GERREUR Then
    GERREUR = 0
    End
  Endif 
  Gosub DECLARE 
  Raz WNUMLIG 
  [L]CRITERE  = "1=1"
  [L]CRITERE1 = "& 1=1"
  [L]CRITERE2 = "& OPPCLO = 2"
  [L]CRITERE3 = "& 1=1"
  For I = 1 To NBPAR
    J = instr(1,[L]PARAMETRE(I),"=")
    If J Then
      [L]PARAM  = left$([L]PARAMETRE(I),J-1)
      [L]VALEUR = right$([L]PARAMETRE(I),J+1)
      Case [L]PARAM
        When "X3ETA"       : [L]ETAT = [L]VALEUR
        When "__REQUETE"   : [L]NUMREQ = val([L]VALEUR)
        When "numedt"      : [L]PARAMETRE(I) = "numedt="  +num$([L]NUMREQ)
        When "sitedeb"     : [L]CRITERE  -= "& SALFCY>='"  +[L]VALEUR+"'"
        When "sitefin"     : [L]CRITERE  -= "& SALFCY<='"  +[L]VALEUR+"'"
        When "datedeb"     : [L]DDATREF   =  gdat$(val(right$([L]VALEUR,7)), val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                             [L]CRITERE1 -= "& OPPCDA >=["+format$(GFMD,[L]DDATREF)+"]"
        When "datefin"     : [L]DDATREF   =  gdat$(val(right$([L]VALEUR,7)), val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                             [L]CRITERE1 -= "& OPPCDA <=["+format$(GFMD,[L]DDATREF)+"]"
        When "cur"         : [L]SZCURDES = [L]VALEUR
        When "repdeb"      : [L]CRITERE2 -= "& OPPREP>='"+[L]VALEUR+"'"
        When "repfin"      : If [L]VALEUR=""  [L]VALEUR="zzzzzzzzzz" : Endif
                             [L]CRITERE2 -= "& OPPREP<='"+[L]VALEUR+"'"
      Endcase
    Endif
  Next
  SZMESS = mess(392,196,1)  #Préparation des données
  If !GINTRA Then
    IMAX = nbrecord([F:OPP])
    ICOUNT = 0
    IAFFOK = 1
    Call OUVRE_BOITE(SZMESS, IMAX) From GESECRAN   #Conversion table OPPOR
  Endif
  ###################################################################
  # Conversion de la devise 
  ###################################################################
  Filter [F:OPP] Where evalue([L]CRITERE + [L]CRITERE1 + [L]CRITERE2) 
  For [F:OPP] 
    Call DEBTRANS From GLOCK 
    Trbegin [PPP]
    Readlock [PPP]PPP0=[F:OPP]OPPNUM;"OPP";SZCURDES
    If fstat = 5 Then
      #Création de l'enregistrement dans la table OPPREPORT
      [F:PPP]NUM = [F:OPP]OPPNUM
      [F:PPP]TYPOBJ = "OPP"
      [F:PPP]CUR = SZCURDES
      #Conversion des montants dans la devise de l'état
      IT_IS_OK = 1
      IT_IS_NOT_OK = 0
      If [F:OPP]CUR <> SZCURDES Then
        Call GETDEVCPY("", [F:OPP]SALFCY, CODDEVSOC, IT_IS_OK) From CRM_UTIL
        # Devise d'origine
        # Devise destination
        # Devise de la société
        # Type de cours
        # Date du cours
        # Montant origine
        # Montant destination
        # Status de retour (0 = OK)
        #Montant brut
        Call CONVERT([F:OPP]CUR,SZCURDES,CODDEVSOC,2,date$,[F:OPP]OPPAMT,[F:PPP]AMT1,IT_IS_NOT_OK) From TRTDEV
        If IT_IS_NOT_OK Then
          #Certains montants n'ont pas pus être calculés correctement en raison
          # d'une mauvaise qualification de la table des devises.
          If !IERRDEV Then
            GMESSAGE = mess(278,196,1)
            GERR = 3
            IERRDEV = 1
          Endif
        Endif
        #Double pondération
        Call CONVERT([F:OPP]CUR,SZCURDES,CODDEVSOC,2,date$,[F:OPP]DAM,[F:PPP]AMT2,IT_IS_NOT_OK) From TRTDEV
        If IT_IS_NOT_OK Then
          #Certains montants n'ont pas pus être calculés correctement en raison
          # d'une mauvaise qualification de la table des devises.
          If !IERRDEV Then
            GMESSAGE = mess(278,196,1)
            GERR = 3
            IERRDEV = 1
          Endif
        Endif
      Else
        [F:PPP]AMT1 = [F:OPP]OPPAMT
        [F:PPP]AMT2 = [F:OPP]DAM
      Endif
      Write [F:PPP]   
      If fstat Then
        Rollback
      Else
        Commit
      Endif 
    Else
      #Mise à jour de l'enregistrement existant
      [F:PPP]NUM = [F:OPP]OPPNUM
      [F:PPP]TYPOBJ = "OPP"
      [F:PPP]CUR = SZCURDES
      #Conversion des montants dans la devise de l'état
      IT_IS_OK = 1
      IT_IS_NOT_OK = 0
      If [F:OPP]CUR <> SZCURDES Then
        Call GETDEVCPY("", [F:OPP]SALFCY, CODDEVSOC, IT_IS_OK) From CRM_UTIL
        # Devise d'origine
        # Devise destination
        # Devise de la société
        # Type de cours
        # Date du cours
        # Montant origine
        # Montant destination
        # Status de retour (0 = OK)
        #Montant brut
        Call CONVERT([F:OPP]CUR,SZCURDES,CODDEVSOC,2,date$,[F:OPP]OPPAMT,[F:PPP]AMT1,IT_IS_NOT_OK) From TRTDEV
        If IT_IS_NOT_OK Then
          #Certains montants n'ont pas pus être calculés correctement en raison
          # d'une mauvaise qualification de la table des devises.
          If !IERRDEV Then
            GMESSAGE = mess(278,196,1)
            GERR = 3
            IERRDEV = 1
          Endif
        Endif
        #Double pondération
        Call CONVERT([F:OPP]CUR,SZCURDES,CODDEVSOC,2,date$,[F:OPP]DAM,[F:PPP]AMT2,IT_IS_NOT_OK) From TRTDEV
        If IT_IS_NOT_OK Then
          #Certains montants n'ont pas pus être calculés correctement en raison
          # d'une mauvaise qualification de la table des devises.
          If !IERRDEV Then
            GMESSAGE = mess(278,196,1)
            GERR = 3
            IERRDEV = 1
          Endif
        Endif
      Else
        [F:PPP]AMT1 = [F:OPP]OPPAMT
        [F:PPP]AMT2 = [F:OPP]DAM
      Endif
      Rewrite [F:PPP]   
      If fstat Then
        Rollback
      Else
        Commit
      Endif 
    Endif
    If !GINTRA Then
      ICOUNT += 1
      Call AFF_BOITE (SZMESS, ICOUNT, IAFFOK) From GESECRAN
    Endif
  Next 
  Filter [OPP]
  If !GINTRA Then
    Call FERME_BOITE From GESECRAN
  Endif
End

########################################################################### 
$OUVRE 
  If !clalev([F:PPP]) : Local File PREREPORT [PPP] : Endif
  If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
Return 
 
###########################################################################
$DECLARE 
Local Char    CRITERE(255),CRITERE1(250),CRITERE2(250),CRITERE3(250)
Local Char    PARAM(30),VALEUR(30),ETAT(GLONARP),WNUM(GLONVCR),WFCY(GLONFCY),WREP(GLONREP),WCLI(GLONBPN),WAFF(GLONVCR),WINT(GLONAIN)
Local Integer WTYP, NUMREQ 
Local Date    WDAT    
Local Date DDATREF
Local Char    SZCURDES
Local Char CODDEVSOC
Local Integer WNUMLIG
Local Integer IT_IS_OK
Local Integer IT_IS_NOT_OK
Local Integer IERRDEV

  SZCURDES = ""
  CODDEVSOC = ""
  IT_IS_OK = 1
  IT_IS_NOT_OK = 0
  IERRDEV = 0
Return 
