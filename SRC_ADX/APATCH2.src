### Requêteur

$REQUETES
Local File =DOSSIER+".ALISTEH" [ALH]
Local File =DOSSIER+".ALISTED" [ALD]
Local File =DOSSIER+".ALISTET" [ALT]
Local File =DOSSIER+".ALISTEC" [ALC]
Local File =DOSSIER+".ALISTEL" [ALL]
Read [ALH]ALH0 = [L]CLEOBJ
If !fstat
 FICHIER = "ALISTEH" : ABR = "ALH"  : IDENT = [F:ALH]COD : Gosub FICHIER
 For [ALD]ALD0 Where COD=[L]CLEOBJ
  FICHIER = "ALISTED" : ABR = "ALD" : IDENT = [F:ALH]COD+"~"+num$([F:ALD]LIG) : Gosub FICHIER
 Next
 If ABROBJ="ALQ"
  Gosub PFIX From SUBALQ
  Read [ACB]ACB0 = [L]IDCLOB;[F:ALH]COD;"";""
  If !fstat
   FICHIER = "ACLOB" : ABR = "ACB" : IDENT = [F:ALD]COD : Gosub FICHIER
  Endif
 Elsif ABROBJ="ALT"
  Read [ALC]ALC0 = [L]CLEOBJ
  FICHIER = "ALISTEC" : ABR = "ALC"  : IDENT = [F:ALC]COD : Gosub FICHIER
  For [ALT]ALT0 Where COD=[L]CLEOBJ
   FICHIER = "ALISTET" : ABR = "ALT" : IDENT = [F:ALT]COD : Gosub FICHIER
  Next ALT
  For [ALL]ALL0 Where COD=[L]CLEOBJ
   FICHIER = "ALISTEL" : ABR = "ALL" : IDENT = [F:ALL]COD : Gosub FICHIER
  Next ALL
 Endif
Endif
Close Local File [ALD],[ALH],[ALT],[ALC],[ALL]
Return

