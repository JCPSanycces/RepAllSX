### Traitement d'une table non prévue

$DIVERS
ER = 0
Onerrgo ERRFIC
Read [ATB]ABRFIC = ABROBJ
If !fstat
 If [F:ATB]TYPFIC=3 : # mb 28.11.02 bug 16652
  Local File =GDOSX3+"."+[F:ATB]CODFIC [DIV]
 Else
  Local File =DOSSIER+"."+[F:ATB]CODFIC [DIV]
 Endif
 If ER
  # Erreur d'accès sur un fichier
  GMESSAGE = "|"+[F:ATB]CODFIC+"|\"+mess(12,100,1) : Gosub ERREUR
 Else
  FICHIER = [F:ATB]CODFIC : ABR = "DIV" : IDENT = ""
  For [F] Where evalue([L]CLEOBJ)
   Gosub FICHIER
   Case ABROBJ
    When "AOS"
     If [F]ALL=2
      EXT = "glo"
     Else
      EXT = "sel"
     Endif
     FIC = [F]USR+"_"+[F]CODE+"_"+[F]MEMO+"."+EXT
     Wrseq '3';'"'+EXT+'"'
     Gosub MEMOS
     Wrseq '6';'"'+EXT+'"'
   Endcase
  Next
  If ER
   # Table
   GMESSAGE = mess(56,123,1)-[F:ATB]CODFIC-":"-ME-errmes$(ER) : Gosub ERREUR
  Endif
  Close Local File [DIV]
 Endif
Endif
Onerrgo
Return

### Traitement d'un traitement source

$TRAITEMENT
If filinfo(filpath("TRT",[L]CLEOBJ,"src",DOSSIER),0)<0
 Wrseq string$(10,"*")
 Return
Endif
Openi filpath("TRT",[L]CLEOBJ,"src",DOSSIER)
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
Rdseq CHAINE
While fstat=0
 Wrseq CHAINE
 Rdseq CHAINE
 If len(CHAINE)>=type(CHAINE)-11
  # Traitement incorrect
  # Une ligne de traitement ne doit pas dépasser # caractères
  GMESSAGE = [L]CLEOBJ-":"-mess(13,123,1)+"\"+func AFNC.MES(mess(6,143,1),num$(type(CHAINE)-11)) : Gosub ERREUR
 Endif
Wend
Wrseq string$(10,"*")
Openi
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Return

### Traitement d'un traitement compilé

$TRTADX
REP = "TRT" : EXT = "adx" : Gosub BINAIRE : # Obsolète 14.6.6
Return

$TRTBIN
REP = "TRT" : SREP = "" : EXT = "adx" : FIC = [L]CLEOBJ : Gosub NEWBIN
Return

### Traitement d'un état

$ETATRPT
REP = "REPORT" : EXT = "rpt" : Gosub BINAIRE : # Obsolète 14.6.6
Return

$ETABIN
For ILAN=1 To NBLAN
 REP = "REPORT" : SREP = LANGUE(ILAN) : EXT = "rpt" : FIC = [L]CLEOBJ
 If filinfo(filpath(filpath(REP,SREP,"",DOSSIER),FIC,EXT,DOSSIER),0)>=0
  Wrseq '3';'"'+SREP+'"'
  Gosub NEWBIN
  Wrseq '6';'"'+SREP+'"'
 Endif
Next ILAN
Return

### Traitement d'une table au format neutre

$TABNEUTRE
If instr(1,DOSSIER,"@") : Return : Endif
FIC = [L]CLEOBJ
REP = "SVG"
SREP = ""
Read [ATB]CODFIC = FIC
If !fstat & dim([F:ATB]FLG130)>0 & [F:ATB]FLG130=2
 Call SAUVE([L]CLEOBJ,DOSSIER,REP,2,1,1,STAT) From DOSEXTRA
Else
 Call SAUVE([L]CLEOBJ,DOSSIER,REP,2,1,0,STAT) From DOSEXTRA
Endif
Openo FICPATCH , -1
For EXT="srf","fde","seq","dat"
 Wrseq '3';'"'+EXT+'"'
 Gosub NEWBIN
Next EXT
Return

### Traitement d'un binaire (obsolète 14.6.6)

$BINAIRE
If filinfo(filpath(REP,[L]CLEOBJ,EXT,DOSSIER),0)<0
 Return
Endif
Openi filpath(REP,[L]CLEOBJ,EXT,DOSSIER)
NB = dim(BUFFER)
Getseq NB , BUFFER
COMPTE = 0
While fstat=0
 COMPTE += NB
 Gosub ECR_ADX
 Getseq NB , BUFFER
Wend
If adxseek(0)>COMPTE
 NB = adxseek(0)-COMPTE
 Gosub ECR_ADX
Endif
Wrseq string$(10,"*")
Openi
Return

$ECR_ADX
For K=1 To NB-1
 Wrseq BUFFER(K);
Next K
Wrseq BUFFER(NB)
Return

### Elément web

$WEB
FICWEB = [L]CLEOBJ
Gosub FICWEB
Gosub FICBIN
Return

$FICWEB
Case GOS(1)
 When "unix"  : SEP = "/"
 When Default : SEP = "\"
Endcase
FIC = ctrans(FICWEB,"/\",SEP+SEP)
REPERT = filpath("","","","X3_PUB")
FICBIN = REPERT+SEP+FIC
Return

