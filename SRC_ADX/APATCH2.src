### Traitement d'une table

$TABLE
Read [ATB]CODFIC = [L]CLEOBJ
If fstat : Return : Endif
FICHIER = "ATABLE" : ABR = "ATB" : IDENT = [F:ATB]CODFIC : Gosub FICHIER
For [ATZ]CODZONE Where CODFIC=[L]CLEOBJ
 FICHIER = "ATABZON" : ABR = "ATZ" : IDENT = [F:ATZ]CODZONE : Gosub FICHIER
 For [AMP]CODPAR Where TYPAFF=2 & CODAFF=[L]CLEOBJ & CODZON=[F:ATZ]CODZONE
  FICHIER = "AMSKPAR" : ABR = "AMP" : IDENT = [F:AMP]CODPAR : Gosub FICHIER
 Next AMP
Next ATZ
For [ATI]NUMLIG Where CODFIC=[L]CLEOBJ
 FICHIER = "ATABIND" : ABR = "ATI" : IDENT = [F:ATI]CODIND : Gosub FICHIER
Next ATI
If clalev([F:ATA])>0
 For [ATA]ATA0 Where CODFIC=[L]CLEOBJ
  FICHIER = "ATABAUD" : ABR = "ATA" : IDENT = [F:ATA]FLD : Gosub FICHIER
 Next ATA
Endif
Return

### Traitement d'une vue

$VUE
Read [AVW]AVW0 = [L]CLEOBJ
If fstat : Return : Endif
FICHIER = "AVIEW" : ABR = "AVW" : IDENT = [F:AVW]CODVUE : Gosub FICHIER
For [AVD]AVD0 Where CODVUE=[L]CLEOBJ
 FICHIER = "AVIEWD" : ABR = "AVD" : IDENT = [F:AVD]FLDVUE : Gosub FICHIER
Next
For [AVC]AVC0 Where CODVUE=[L]CLEOBJ
 FICHIER = "AVIEWC" : ABR = "AVC" : IDENT = [F:AVC]CODCLE : Gosub FICHIER
Next
For [AVB]AVB0 Where CODVUE=[L]CLEOBJ
 FICHIER = "AVIEWB" : ABR = "AVB" : IDENT = num$([F:AVB]TYPDBA) : Gosub FICHIER
Next
Return

### Traitement d'un objet

$OBJET
Read [AOB]ABREV = [L]CLEOBJ
If fstat : Return : Endif
FICHIER = "AOBJET" : ABR = "AOB" : IDENT = [F:AOB]ABREV : Gosub FICHIER
For [AOT]ABREV Where ABREV=[L]CLEOBJ
 FICHIER = "AOBJTAB" : ABR = "AOT" : IDENT = [F:AOT]ABREV+num$([F:AOT]NUMLIG) : Gosub FICHIER
Next
Read [AOL]AOL0 = [L]CLEOBJ
FICHIER = "AOBJLST" : ABR = "AOL" : IDENT = [F:AOB]ABREV : Gosub FICHIER
Return

### Traitement d'une fonction

$FONCTION
Read [AFC]CODINT = [L]CLEOBJ
If fstat : Return : Endif
FICHIER = "AFONCTION" : ABR = "AFC" : IDENT = [F:AFC]CODINT : Gosub FICHIER
For [AVR]AVR0 Where TYP = 2 & FCT=[L]CLEOBJ
 FICHIER = "AVARLOC" : ABR = "AVR" : IDENT = num$([F:AVR]TYP)+[F:AVR]FCT+[AVR]COD : Gosub FICHIER
Next
Return

### Traitement d'un web service

$WEBSERVICE
Read [AWE]AWE1 = [L]CLEOBJ
If fstat : Return : Endif
FICHIER = "AWEBSERVIC" : ABR = "AWE" : IDENT = [F:AWE]PUBLI : Gosub FICHIER
For [AWY]AWY1 Where PUBLI = [F:AWE]PUBLI
 FICHIER = "AWEBSERDES" : ABR = "AWY" : IDENT = [F:AWY]PUBLI+[F:AWY]GRP+[F:AWY]CHP : Gosub FICHIER
Next
Return

### Traitement d'une action

$SACTION
Read [ACT]ACTION = [L]CLEOBJ
If fstat : Return : Endif
FICHIER = "ACTION" : ABR = "ACT" : IDENT = [F:ACT]ACTION : Gosub FICHIER
For [ATR]NOPAR Where ACTION=[F:ACT]ACTION
 FICHIER = "ACTPAR" : ABR = "ATR" : IDENT = [F:ATR]CODPAR : Gosub FICHIER
 Read [AAR]CODPAR = [F:ATR]CODPAR
 FICHIER = "ACTCODPAR" : ABR = "AAR" : Gosub FICHIER
Next
Return

### Traitement d'un type de données

$ATYPE
Read [ATY]CODTYP = [L]CLEOBJ
If fstat : Return : Endif
FICHIER = "ATYPE" : ABR = "ATY" : IDENT = [F:ATY]CODTYP : Gosub FICHIER
For [ATYR]ATYR0 Where CODTYP=[L]CLEOBJ
 FICHIER = "ATYPERUL" : ABR = "ATYR" : IDENT = num$([F:ATYR]TYPRUL)+"~"+[F:ATYR]TRTRUL+"~"+[F:ATYR]PRGRUL : Gosub FICHIER
 For [ATYRP]ATYRP0 Where CODTYP=[L]CLEOBJ & TYPRUL=[F:ATYR]TYPRUL & TRTRUL=[F:ATYR]TRTRUL & PRGRUL=[F:ATYR]PRGRUL
  FICHIER = "ATYPERPAR" : ABR = "ATYRP" : Gosub FICHIER
 Next
Next
For [ATYL]ATYL0 Where CODTYP=[L]CLEOBJ
 FICHIER = "ATYPELNK" : ABR = "ATYL" : IDENT = [F:ATYL]CODLNK : Gosub FICHIER
 For [ATYLP]ATYLP0 Where CODTYP=[L]CLEOBJ & CODLNK=[F:ATYL]CODLNK
  FICHIER = "ATYPELPAR" : ABR = "ATYLP" : Gosub FICHIER
 Next
Next
Return

### Traitement d'une structure

### Traitement d'une classe données

$CLASSE
Local File =DOSSIER+".ACLASSE"    [ACLA]
&         ,=DOSSIER+".ACLAFLD"    [ACLAF]
&         ,=DOSSIER+".ACLAPARFLD" [ACLFP]
&         ,=DOSSIER+".ACLAMET"    [ACLAM]
&         ,=DOSSIER+".ACLAPARDEF" [ACLPD]
&         ,=DOSSIER+".ACLAMETSTD" [ACLAT]
&         ,=DOSSIER+".ACLALNK"    [ACLAK]
&         ,=DOSSIER+".ACLAOPT"    [ACLAO]
&         ,=DOSSIER+".ACLACOL"    [ACLAC]
&         ,=DOSSIER+".ACLAMAP"    [ACLAKP]


Read [ACLA]ACLA0 = [L]CLEOBJ
# Issue X3-77407 - 2018-03-01 by CCC
#If fstat : Return : Endif
If fstat=[V]CST_AOK
    FICHIER = "ACLASSE" : ABR = "ACLA" : IDENT = [F:ACLA]CODCLA : Gosub FICHIER

    For [ACLAO]ACLAO0 Where CODCLA=[L]CLEOBJ
     FICHIER = "ACLAOPT" : ABR = "ACLAO" : IDENT = '"'+[F:ACLAO]OPTCOD+'"' : Gosub FICHIER
    Next
    For [ACLAC]ACLAC0 Where CODCLA=[L]CLEOBJ
     FICHIER = "ACLACOL" : ABR = "ACLAC" : IDENT = '"'+[F:ACLAC]CODCOL+'"' : Gosub FICHIER
    Next

    For [ACLAF]ACLAF0 Where CODCLA=[L]CLEOBJ
     FICHIER = "ACLAFLD" : ABR = "ACLAF" : IDENT = '"'+[F:ACLAF]FLDCLA+'"' : Gosub FICHIER
     For [ACLFP]ACLFP0 Where CODCLA=[L]CLEOBJ & FLDCLA=[F:ACLAF]FLDCLA
      FICHIER = "ACLAPARFLD" : ABR = "ACLFP" : Gosub FICHIER
     Next
    Next
    For [ACLAM]ACLAM0 Where CODCLA=[L]CLEOBJ
     FICHIER = "ACLAMET" : ABR = "ACLAM" : IDENT = '"'+[F:ACLAM]CODMET+'"' : Gosub FICHIER
     For [ACLPD]ACLPD0 Where CODCLA=[L]CLEOBJ & CODE=[F:ACLAM]CODMET
      FICHIER = "ACLAPARDEF" : ABR = "ACLPD" : Gosub FICHIER
     Next
    Next
    For [ACLAT]ACLAT0 Where CODCLA=[L]CLEOBJ
     FICHIER = "ACLAMETSTD" : ABR = "ACLAT" : IDENT = '"'+[F:ACLAT]CODMETSTD+'"' : Gosub FICHIER
    Next
    For [ACLAK]ACLAK0 Where CODCLA=[L]CLEOBJ
     FICHIER = "ACLALNK" : ABR = "ACLAK" : IDENT = '"'+[F:ACLAK]REFLNK+'"' : Gosub FICHIER
      For [ACLAKP]ACLAKP0 Where CODCLA=[L]CLEOBJ & REFLNK=[F:ACLAK]REFLNK
      FICHIER = "ACLAMAP" : ABR = "ACLAKP" : Gosub FICHIER
     Next
    Next
Endif
Close Local File [ACLA], [ACLAF], [ACLFP], [ACLAM], [ACLPD], [ACLAT], [ACLAK], [ACLAO], [ACLAC],[ACLAKP]
Return

### Traitement d'une classe représentation

$REPRESENTATION
Local File =DOSSIER+".ASHW"       [ASW]
&         ,=DOSSIER+".ASHWFLD"    [ASWF]
&         ,=DOSSIER+".ASHWPAR"    [ASWP]
&         ,=DOSSIER+".ASHWOPT"    [ASWO]
&         ,=DOSSIER+".ASHWCOL"    [ASWC]
&         ,=DOSSIER+".ASHWSEC"    [ASWS]
&         ,=DOSSIER+".ASHWBLC"    [ASWB]
&         ,=DOSSIER+".ASHWMET"    [ASWM]
&         ,=DOSSIER+".ASHWPARMET" [ASWMP]
&         ,=DOSSIER+".ASHWEXPPRO" [ASWR]
&         ,=DOSSIER+".ASHWLNK"    [ASWK]
&         ,=DOSSIER+".ASHWMENU"   [ASWMN]

Read [ASW]ASW0 = [L]CLEOBJ
# Issue X3-77407 - 2018-03-01 by CCC
#If fstat : Return : Endif
If fstat=[V]CST_AOK
    FICHIER = "ASHW" : ABR = "ASW" : IDENT = [F:ASW]CODREP : Gosub FICHIER
    For [ASWF]ASWF0 Where CODREP=[L]CLEOBJ
     FICHIER = "ASHWFLD" : ABR = "ASWF" : IDENT = '"'+[F:ASWF]CODFLD+'"' : Gosub FICHIER
     For [ASWP]ASWP0 Where CODREP=[L]CLEOBJ & (TYPPAR=1 | TYPPAR=2) & CODFLD=[F:ASWF]CODFLD
      FICHIER = "ASHWPAR" : ABR = "ASWP" : Gosub FICHIER
     Next
    Next
    For [ASWM]ASWM0 Where CODREP=[L]CLEOBJ
     FICHIER = "ASHWMET" : ABR = "ASWM" : IDENT = '"'+[F:ASWM]CODMET+'"' : Gosub FICHIER
     For [ASWMP]ASWMP0 Where CODREP=[L]CLEOBJ & CODMET=[F:ASWM]CODMET
      FICHIER = "ASHWPARMET" : ABR = "ASWMP" : Gosub FICHIER
     Next
    Next
    For [ASWO]ASWO0 Where CODREP=[L]CLEOBJ
     FICHIER = "ASHWOPT" : ABR = "ASWO" : IDENT = '"'+[F:ASWO]OPTCOD+'"' : Gosub FICHIER
    Next
    For [ASWC]ASWC0 Where CODREP=[L]CLEOBJ
     FICHIER = "ASHWCOL" : ABR = "ASWC" : IDENT = '"'+[F:ASWC]CODCOL+'"' : Gosub FICHIER
    Next
    For [ASWS]ASWS0 Where CODREP=[L]CLEOBJ
     FICHIER = "ASHWSEC" : ABR = "ASWS" : IDENT = '"'+[F:ASWS]CODSEC+'"' : Gosub FICHIER
    Next
    For [ASWB]ASWB0 Where CODREP=[L]CLEOBJ
     FICHIER = "ASHWBLC" : ABR = "ASWB" : IDENT = '"'+[F:ASWB]CODBLC+'"' : Gosub FICHIER
    Next
    For [ASWR]ASWR0 Where CODREP=[L]CLEOBJ
     FICHIER = "ASHWEXPPRO" : ABR = "ASWR" : IDENT = '"'+[F:ASWR]ALIAS+'"' : Gosub FICHIER
    Next
    For [ASWMN]ASWMN0 Where CODREP=[L]CLEOBJ
     FICHIER = "ASHWMENU" : ABR = "ASWMN" : IDENT = '"'+[F:ASWMN]CODMENU+'"' : Gosub FICHIER
    Next
    For [ASWK]ASWK0 Where CODREP=[L]CLEOBJ
     FICHIER = "ASHWLNK" : ABR = "ASWK" : IDENT = [F:ASWK]CODLNK+"~"+num$([F:ASWK]AFFLNK)+"~"+[F:ASWK]ANCLNK : Gosub FICHIER
     For [ASWP]ASWP0 Where CODREP=[L]CLEOBJ & TYPPAR=3 & CODFLD=[F:ASWK]ANCLNK & CODLNK=[F:ASWK]CODLNK & AFFLNK=[F:ASWK]AFFLNK
      FICHIER = "ASHWPAR" : ABR = "ASWP" : Gosub FICHIER
     Next
    Next
Endif
Close Local File [ASW], [ASWF], [ASWP], [ASWO],[ASWC],[ASWS],[ASWB], [ASWM], [ASWMP], [ASWR], [ASWK], [ASWMN]
Return

### Traitement d'un Type prototype

$ATYPEPRO
Read [ATYP]ATYP0 = [L]CLEOBJ
If fstat : Return : Endif
FICHIER = "ATYPEPRO" : ABR = "ATYP" : IDENT = [F:ATYP]COD : Gosub FICHIER
