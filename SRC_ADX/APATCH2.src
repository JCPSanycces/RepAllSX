### Traitement d'un binaire

$NEWBIN
If SREP=""
 FICBIN = filpath(REP,FIC,EXT,DOSSIER)
Else
 FICBIN = filpath(filpath(REP,SREP,"",DOSSIER),FIC,EXT,DOSSIER)
Endif

$FICBIN
If filinfo(FICBIN,0)<0
 Wrseq 0
Else
 ER = 0
 Onerrgo ERRFIC
 Openi FICBIN
 Onerrgo
 If ER
  Wrseq 0
  # Erreur d'accès sur un fichier
  GMESSAGE = "|"+FICBIN+"|\"+mess(12,100,1) : Gosub ERREUR
 Else
  NOCT = filinfo(FICBIN,7)
  Wrseq NOCT
  NB = dim(BUFFER)
  Getseq NB , BUFFER
  COMPTE = 0
  While fstat=0
   COMPTE += NB
   Putseq NB , BUFFER
   Getseq NB , BUFFER
  Wend
  If NOCT>COMPTE
   NB = NOCT-COMPTE
   Putseq NB , BUFFER
  Endif
  Openi
 Endif
Endif
Wrseq string$(10,"*")
Return

$ERRFIC
ER = errn
ME = errm
Resume

### Traitement d'un fichier texte

$TEXTE
If left$([L]CLEOBJ,1)='"' or left$([L]CLEOBJ,1)="'"
 FIC = seg$([L]CLEOBJ,2,len([L]CLEOBJ)-1)
Else
 FIC = [L]CLEOBJ
Endif
If filinfo(filpath("TXT",FIC,"txt",DOSSIER),0)<0
 Return
Endif
Onerrgo ERRFIC
ER = 0
Openi filpath("TXT",FIC,"txt",DOSSIER)
Onerrgo
If ER
 # Erreur d'accès sur un fichier
 GMESSAGE = "|"+filpath("TXT",DIC,"txt",DOSSIER)+"|\"+mess(12,100,1) : Gosub ERREUR
Else
 SAVIFS = adxifs
 SAVIRS = adxirs
 SAVIUM = adxium
 adxifs = ""
 adxirs = chr$(10)
 adxium = GUTF8
 Rdseq CHAINE
 While fstat=0
  Wrseq CHAINE
  Rdseq CHAINE
 Wend
 Openi
Endif
Wrseq string$(10,"*")
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Return

### Export d'un fichier quelconque

$FICHIER
Wrseq '3';'"'+ABR+'"';IDENT
NBZONE = evalue("clanbs([F:"+ABR+"],1)")
For Z=1 To NBZONE
 VARIA = evalue("clavar([F:"+ABR+"],"+num$(Z)+")")
 If left$(VARIA,1)<>"~"
  TYP   = evalue("type([F:"+ABR+"]"+VARIA+")")
  IND   = evalue("dim([F:"+ABR+"]"+VARIA+")")
  Case TYP
   When 522 : Gosub EXPBLB
   When 523 : Gosub EXPCLB
   When 525 : # Uuident non exporté
   When Default
    Read [ATZ_]CODZONE = FICHIER;VARIA
    Case [F:ATZ_]CODTYP
     When "ATX"     : Gosub EXPTXT
     When Default   : Gosub EXPZON
    Endcase
  Endcase
 Endif
Next Z
ZTEX = 0
For [ATZ_]CODTYP(2) Where find(CODTYP,"AXX","AX1","AX2","AX3")<>0 & CODFIC=FICHIER
 ZTEX = 1 : Break
Next
If ZTEX
 For [ATZ_]CODTYP Where find(CODTYP,"AXX","AX1","AX2","AX3")<>0 & CODFIC=FICHIER
  VARIA = [F:ATZ_]CODZONE
  IND = [F:ATZ_]DIME
  If [F:ATZ_]CODACT<>""
   Read [ACV]CODACT=[F:ATZ_]CODACT
   If fstat
    IND = 0
   Elsif [F:ACV]FLACT<>2
    IND = 0
   Elsif [F:ACV]DIMFIL>0 & [F:ACV]DIME>0 & [F:ACV]DIMMAX>0
    IND = min(max([F:ACV]DIMFIL,[F:ACV]DIME),[F:ACV]DIMMAX)
   Elsif ([F:ACV]DIMFIL<>0 | [F:ACV]DIME<>0)
    IND = max([F:ACV]DIMFIL,[F:ACV]DIME)
   Endif
  Endif
  Gosub SET_IDENT
  Gosub EXPTRA
 Next
Endif
Wrseq '6';'"'+ABR+'"'
Return

$SET_IDENT
Raz ZVAL , ZP
Read [AMP_]CODPAR(3)=2;FICHIER;VARIA
If !fstat
 For ZPAR="TABLE1","ZONE","CLECUR1","CLECUR2"
  ZP += 1
  Read [AMP_]CODPAR=2;FICHIER;VARIA;ZPAR
  If !fstat & [F:AMP_]VALPAR<>""
   ZVAL(ZP) = [F:AMP_]VALPAR
  Else
   ZVAL(ZP) = '""'
  Endif
 Next ZPAR
Endif
If ZP<>0
 ZFIC = FICHIER : Return
Endif
ZFIC = FICHIER
ZVAL(1) = '"'+FICHIER+'"'
ZVAL(2) = '"'+VARIA+'"'
Read [ATI_]NUMLIG(2) = FICHIER;1
ZIDENT  = [F:ATI_]DESCRIPT
ZVAL(3) = ""
ZVAL(4) = ""
While ZIDENT<>""
 Z1 = instr(1,ZIDENT,"+")
 Z2 = instr(1,ZIDENT,"-")
 If    Z1 & Z2  : Z1 = min(Z1,Z2)
 Elsif Z2 & !Z1 : Z1 = Z2
 Endif
 If Z1
  ZA = left$(ZIDENT,Z1-1) : ZIDENT = right$(ZIDENT,Z1+1)
 Else
  ZA = ZIDENT : ZIDENT = ""
 Endif
 Read [ATZ2]CODZONE = FICHIER;ZA
 Read [ATY_]CODTYP  = [F:ATZ2]CODTYP
 If [F:ATY_]TYPTYP=7
  ZA = "[F:"+ABR+"]"+ZA
 Else
  ZA = "num$([F:"+ABR+"]"+ZA+")"
 Endif
 If ZVAL(3)=""
  ZVAL(3) = ZA
 Elsif ZVAL(4)=""
  ZVAL(4) = ZA
 Else
  ZVAL(4) += '+"~"+'+ZA
 Endif
Wend
If ZVAL(3)="" : ZVAL(3) = '""' : Endif
If ZVAL(4)="" : ZVAL(4) = '""' : Endif
Return

### Export zone normale

$EXPZON
For J=1 To IND
 Wrseq '4';'"'+VARIA+'"';num$(J-1);
 Case TYP
  When 1,2,4,5,6,7,8,9
   Wrseq num$(evalue("[F:"+ABR+"]"+VARIA+"("+num$(J-1)+")"))
  When 3
   Wrseq evalue("[F:"+ABR+"]"+VARIA+"("+num$(J-1)+")")
  When Default
   Wrseq '"'+ctrans(num$(evalue("[F:"+ABR+"]"+VARIA+"("+num$(J-1)+")")),","+chr$(10),chr$(255)+chr$(254))+'"'
 Endcase
Next J
Return

### Export zone dico

$EXPTXT
For J=1 To IND
 For K=1 To NBLAN
  NUMERO = evalue("[F:"+ABR+"]"+VARIA+"("+num$(J-1)+")")
  Read [ATX_]NUMERO = LANGUE(K);NUMERO
  If fstat : Raz [F:ATX_] : Endif
  Wrseq '5';'"'+VARIA+'"';num$(J-1);
  Wrseq '"'+[F:ATX_]TEXTE+'"';'"'+LANGUE(K)+'"';num$(NUMERO);'"'+[F:ATX_]COMMENT+'"'
 Next K
 Wrseq '5';'"'+VARIA+'"';num$(J-1);'""';'"***"'
Next J
Return

### Export texte traduisible

$EXPTRA
For J=1 To IND
 nolign = J
 indice = J-1
 K = 0
 For L=1 To NBLAN
  ER = 0
  CHAINE = dbgstr(2)
  Default File "["+ABR+"]"
  Default [F],[L],[S],[V],[M]
  Read [AXX_]AXX0 = num$(evalue([L]ZVAL(1)));num$(evalue([L]ZVAL(2)));[L]LANGUE([L]L);num$(evalue([L]ZVAL(3)));num$(evalue([L]ZVAL(4)))
  If !fstat & ![L]ER
   Wrseq '9';'"'+[L]VARIA+'"';num$([L]J-1);'"'+[F:AXX_]TEXTE+'"';'"'+[L]LANGUE([L]L)+'"';
   Wrseq '"'+num$(evalue([L]ZVAL(3)))+'"';'"'+num$(evalue([L]ZVAL(4)))+'"'
   [L]K = 1
  Endif
  Default [L],[S],[V],[M],[F]
  If CHAINE<>""
   Default File CHAINE
  Endif
 Next L
 If K
  Wrseq '9';'"'+VARIA+'"';num$(J-1);'""';'"***"'
 Endif
Next J
Return

### Export blob

$EXPBLB
TYPENR = 24
For J=1 To IND
 Wrseq num$(TYPENR);'"'+VARIA+'"';num$(J-1)
 NOCT = evalue("len([F:"+ABR+"]"+VARIA+"("+num$(J-1)+"))")
 Wrseq NOCT
 BLOB = evalue("[F:"+ABR+"]"+VARIA+"("+num$(J-1)+")")
 Putseq 1,BLOB
 Wrseq ""
 Wrseq string$(10,"*")
Next J
Return

### Export clob

$EXPCLB
TYPENR = 25
For J=1 To IND
 Wrseq num$(TYPENR);'"'+VARIA+'"';num$(J-1)
 SAVIFS = adxifs
 SAVIRS = adxirs
 SAVIUM = adxium
 adxifs = ""
 adxirs = ""
 adxium = GUTF8
 CLOB = evalue("[F:"+ABR+"]"+VARIA+"("+num$(J-1)+")")
 If TYPENR=23 : # Clob -> Clob
  Call DIM_CLB(CLOB,FICPATCH,NOCT)
  adxirs = chr$(10)
  Wrseq NOCT
  adxirs = ""
  Wrseq CLOB
 Elsif TYPENR=25 : # Clob -> Blob
  NOCT = strEncode(CLOB,BLOB,GUTF8)
  adxirs = chr$(10)
  Wrseq NOCT
  adxirs = ""
  Putseq 1,BLOB
 Endif
 adxifs = SAVIFS
 adxirs = SAVIRS
 adxium = SAVIUM
 Wrseq ""
 Wrseq string$(10,"*")
Next J
If len(CLOB)<>0 & NOCT=0
 GMESSAGE = VARIA-":"-mess(28,127,1)-num$(len(CLOB))-"->"-num$(NOCT)-mess(133,133,1)
 Gosub ERREUR
Endif
Return

$ERREUR
If GSERVEUR
 Gosub SAV_OPENO
 Call ECR_TRACE(GMESSAGE,1) From GESECRAN
 Gosub REST_OPENO
Else
 Call ERREUR(GMESSAGE) From GESECRAN
Endif
Raz GMESSAGE
Return

Subprog DIM_CLB(CLOB,FICPATCH,NOCT)
Value Clbfile CLOB
Value Char FICPATCH
Variable Integer NOCT
Local Integer STAT
Local Char FIC_TMP(GDIMFIC)
Gosub SAV_OPENO
FIC_TMP = filpath("tmp",num$(adxuid(2)),"tmp")
Openo FIC_TMP,0 Using [TMP_]
Wrseq CLOB Using [TMP_]
Openo Using [TMP_]
NOCT = filinfo(FIC_TMP,7)
Call EFFACE(FIC_TMP,STAT) From ORDSYS
Gosub REST_OPENO
End

$SAV_OPENO
Local Char     SAVIFS(10) , SAVIRS(10)
Local Integer  SAVIUM
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
Return

$REST_OPENO
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Openo FICPATCH
Return

$AGDPRSETTING
Read [AGS]AGS0 = [L]CLEOBJ
If fstat : Return : Endif
FICHIER = "AGDPRSETTING" : ABR = "AGS" : IDENT = [F:AGS]CODE : Gosub FICHIER
Return

$AUTILITY
Read [AUTI]AUTI0 = [L]CLEOBJ
If fstat : Return : Endif
FICHIER = "AUTILITY" : ABR = "AUTI" : IDENT = [F:AUTI]UTICOD : Gosub FICHIER
Return

