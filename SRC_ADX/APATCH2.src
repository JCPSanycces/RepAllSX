#<AdxTL>@(#)10.0.0.0 $Revision$

Local Char PARAM(30)(1..1) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","APATCH","APATCH",4,"") From GTRAITE
End

### Traitement d'un écran

$ECRAN
Read [AMK]CODMSK = [L]CLEOBJ
If fstat : Return : Endif
FICHIER = "AMSK" : ABR = "AMK" : IDENT = [F:AMK]CODMSK : Gosub FICHIER
For [AMZ]CODZON Where CODMSK=[L]CLEOBJ
 FICHIER = "AMSKZON" : ABR = "AMZ" : IDENT = '"'+[F:AMZ]CODZON+'"' : Gosub FICHIER
 For [AMA]TYPAFF Where TYPAFF=1 & CODAFF=[L]CLEOBJ & CODZON=[F:AMZ]CODZON
  FICHIER = "AMSKACT" : ABR = "AMA" : Gosub FICHIER
 Next
 For [AMP]CODPAR Where TYPAFF=1 & CODAFF=[L]CLEOBJ & CODZON=[F:AMZ]CODZON
  FICHIER = "AMSKPAR" : ABR = "AMP" : Gosub FICHIER
 Next
Next
Return

### Traitement d'une aide sur champ

$AIDE_CHAMP
For ILAN=1 To NBLAN
 Read [ADZ]ADZ0 = LANGUE(ILAN);[L]CLEOBJ
 If !fstat
  FICHIER = "ADOCFLD" : ABR = "ADZ" : IDENT = [F:ADZ]LAN+"~"+[F:ADZ]MOTCLE : Gosub FICHIER
 Endif
Next K
Return

### Traitement d'une documentation

$DOCUMENTATION
Local File =DOSSIER+".ADOCUMENT" [ADO]
Local File =DOSSIER+".ADOCBLB"   [ADB]
Local File =DOSSIER+".ADOCCLB"   [ADH]
K = instr(1,[L]CLEOBJ,"~")
If K
 [L]TYPS = left$([L]CLEOBJ,K-1)
 [L]CODS = right$([L]CLEOBJ,K+1)
 For ILAN=1 To NBLAN
  Read [ADO]ADO0 = LANGUE(ILAN);[L]TYPS;[L]CODS
  If !fstat
   For [ADO]ADO0 Where LAN=LANGUE(ILAN) & TYP=[L]TYPS & COD=[L]CODS
    FICHIER = "ADOCUMENT"
    ABR = "ADO"
    IDENT = [F:ADO]LAN+"~"+[F:ADO]TYP+"~"+[F:ADO]COD+"~"+num$([F:ADO]LEV)+"~"+num$([F:ADO]SUBLEV)
    Gosub FICHIER
    # CCL from SCM patch
    For [ADB]ADB0 Where LAN=LANGUE(ILAN) & TYP=[L]TYPS & COD=[L]CODS & LEV=[F:ADO]LEV & SUBLEV=[F:ADO]SUBLEV
     FICHIER = "ADOCBLB"
     ABR = "ADB"
     IDENT = [F:ADB]LAN+"~"+[F:ADB]TYP+"~"+[F:ADB]COD+"~"+num$([F:ADB]LEV)
     IDENT += "~"+num$([F:ADB]SUBLEV)+"~"+num$([F:ADB]LIG)
     Gosub FICHIER
    Next
    For [ADH]ADH0 Where LAN=LANGUE(ILAN) & TYP=[L]TYPS & COD=[L]CODS & LEV=[F:ADO]LEV & SUBLEV=[F:ADO]SUBLEV
     FICHIER = "ADOCCLB"
     ABR = "ADH"
     IDENT = [F:ADH]LAN+"~"+[F:ADH]TYP+"~"+[F:ADH]COD+"~"+num$([F:ADH]LEV)+"~"+num$([F:ADH]SUBLEV)
     Gosub FICHIER
    Next
   Next
  Endif
 Next ILAN
Endif
Close Local File [ADO],[ADB],[ADH]
Return

### Traitement de liens de doc

$LIENS_DOC
Local File =DOSSIER+".ADOCFNC"   [ADF]
K = instr(1,[L]CLEOBJ,"~")
If K
 [L]TYPS = left$([L]CLEOBJ,K-1)
 [L]CODS = right$([L]CLEOBJ,K+1)
 For [ADF]ADF0 Where  TYP=[L]TYPS & COD=[L]CODS
  FICHIER = "ADOCFNC"
  ABR = "ADF"
  IDENT = [F:ADF]TYP+"~"+[F:ADF]COD+"~"+num$([F:ADF]NUM)
  Gosub FICHIER
 Next
Endif
Close Local File [ADF]
Return

