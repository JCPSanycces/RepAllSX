### Traitement d'un état

$ETAT
Local File =DOSSIER+".AREPORT"   [ARP]
Local File =DOSSIER+".AREPORTD"  [ARD]
Local File =DOSSIER+".AREPORTS"  [ARO]
Read [ARP]ARP0 = [L]CLEOBJ
If !fstat
 FICHIER = "AREPORT" : ABR = "ARP" : IDENT = [F:ARP]RPTCOD : Gosub FICHIER
 For [ARD]ARD0 Where RPTCOD=[F:ARP]RPTCOD
  FICHIER = "AREPORTD" : ABR = "ARD" : IDENT = [F:ARD]PARCOD : Gosub FICHIER
 Next
 Read [ARO]ARO0 = [L]CLEOBJ
 If !fstat
  FICHIER = "AREPORTS" : ABR = "ARO" : IDENT = [F:ARP]RPTCOD : Gosub FICHIER
 Endif
Endif
Close Local File [ARP],[ARD],[ARO]
Return

### Traitement d'un menu local / chapitre

$MENLOC
Read [AML]MENLOC = val([L]CLEOBJ)
If fstat : Return : Endif
FICHIER = "AMENLOC" : ABR = "AML" : IDENT = num$([F:AML]MENLOC) : Gosub FICHIER
CHAPITRE = [F:AML]MENLOC : Gosub MESSAGE
Return

$MESSAGE
FICHIER = "APLSTD" : ABR = "AST" : IDENT = num$(CHAPITRE)
Read [AML]MENLOC = CHAPITRE
For KK=1 To NBLAN
 If [F:AML]MENLOCAL=2
  If CHAPITRE<100
   Read [AST2]CLE = 0;CHAPITRE;GLANGUE
   If fstat : Read [AST2]CLE= 0;CHAPITRE : Endif : # 105287 CCL
   Read [AST]CLE  = 0;CHAPITRE;LANGUE(KK)
   If fstat : [F:AST] = [F:AST2] : [F:AST]LAN = LANGUE(KK) : Endif
   Gosub FICHIER
  Elsif CHAPITRE>200
   # mb 17.12.7 bug 44864
   # & CHAPITRE<=8899 : # mb 5.6.2 bug 14521 avant <=8900
   Read [AST2]CLE = 200;CHAPITRE-200;GLANGUE
   If fstat : Read [AST2]CLE= 200;CHAPITRE-200 : Endif : # 105287 CCL
   Read [AST]CLE  = 200;CHAPITRE-200;LANGUE(KK)
   If fstat : [F:AST] = [F:AST2] : [F:AST]LAN = LANGUE(KK) : Endif
   Gosub FICHIER
  Endif
 Endif
 For [AST2]CLE Where LANCHP=CHAPITRE & LAN=GLANGUE
  Read [AST]CLE = CHAPITRE;[F:AST2]LANNUM;LANGUE(KK)
  If fstat : [F:AST] = [F:AST2] : [F:AST]LAN = LANGUE(KK) : Endif
  Gosub FICHIER
 Next
Next KK
Return

### Traitement des tables diverses et de des paramètres

