### Etat BO

$ETAT_BO
Local File =DOSSIER+".ABIREPORT"  [ABO]
Local File =DOSSIER+".ABIREPORTD" [ABQ]
Local File =DOSSIER+".ABITRAUNV"  [ATV]
Read [ABO]ABO0 = [L]CLEOBJ
If !fstat
 FICHIER = "ABIREPORT" : ABR = "ABO" : IDENT = [F:ABO]COD : Gosub FICHIER
 For [ABQ]ABQ0 Where COD=[L]CLEOBJ
  FICHIER = "ABIREPORTD" : ABR = "ABQ" : IDENT = num$([F:ABQ]LIG) : Gosub FICHIER
 Next
 For ILAN=1 To NBLAN
  For [ATV]ATV0 Where ABM =[F:ABO]DATAM &  RAPORT=[F:ABO]REPCOD & LANTRA = LANGUE(ILAN)
   FICHIER = "ABITRAUNV" : ABR = "ATV" :
   IDENT = [F:ATV]ABM+"~"+[F:ATV]RAPORT+"~"+[F:ATV]LANTRA+"~"+[F:ATV]TEXTE : Gosub FICHIER
  Next ATV
 Next K
Endif
Close Local File [ABQ],[ABO],[ATV]
Return

