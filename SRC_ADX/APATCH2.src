$MEMOS
K = instr(1,FIC,".")
If !K
 Wrseq 0
 GMESSAGE = mess(71,143,1) : # Fichier mémo sans extension
 Gosub ERREUR : Return
Endif
EXT = right$(FIC,K+1)
FIC = left$(FIC,K-1)
FICBIN = filpath("ETM",FIC,EXT,DOSSIER)
Gosub FICBIN
Return

