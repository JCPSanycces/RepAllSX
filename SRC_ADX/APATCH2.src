### Processus

$PROCESSUS
Local File =DOSSIER+".APROCESSUS"    [APR]
Local File =DOSSIER+".APROCTEXTE"    [AXP]
K = instr(1,[L]CLEOBJ,"~")
If K
 [L]TYPS = left$([L]CLEOBJ,K-1)
 [L]CODS = right$([L]CLEOBJ,K+1)
 Read [APR]APR1 =[L]TYPS;[L]CODS
 If !fstat
  FICHIER = "APROCESSUS" : ABR = "APR" : IDENT = [F:APR]CODLEG+"~"+[F:APR]CODPRO : Gosub FICHIER
  For ILAN=1 To NBLAN
   For [AXP]AXP0 Where CODPRO=[F:APR]CODPRO & CODLEG=[F:APR]CODLEG & LANG = LANGUE(ILAN)
    FICHIER = "APROCTEXTE" : ABR = "AXP" : IDENT=[F:AXP]CODLEG+"~"+[F:AXP]CODPRO+"~"+LANGUE(ILAN)+"~"+[F:AXP]UNIQIDP: Gosub FICHIER
   Next
  Next
 Endif
Endif
Close Local File [APR],[AXP]
Return

