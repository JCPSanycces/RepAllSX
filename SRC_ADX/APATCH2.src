### Traitement d'un sous programme

$SUBPRG
Local File =DOSSIER+".ASUBPROG"  [ASU]
Local File =DOSSIER+".ASUBPROGD" [ASP]
Local Char PRG(255),SUBPRG(255)
K = instr(1,[L]CLEOBJ,"~")
If K
 [L]PRG = left$([L]CLEOBJ,K-1)
 [L]SUBPRG = right$([L]CLEOBJ,K+1)
 Read [ASU]ASU0 = [L]PRG;[L]SUBPRG
 If !fstat
  FICHIER = "ASUBPROG" : ABR = "ASU" : IDENT = [L]PRG+"~"+[L]SUBPRG : Gosub FICHIER
 Endif
 For [ASP]ASP0 Where PRG=[L]PRG & SUBPRG=[L]SUBPRG
  FICHIER = "ASUBPROGD" : ABR = "ASP" : IDENT = [L]PRG+"~"+[L]SUBPRG+"~"+num$([F:ASP]LIGNE) : Gosub FICHIER
 Next
Endif
Close Local File [ASU],[ASP]
Return

### Traitement d'un mot cle

$MOTCLE
Local File =DOSSIER+".AMOTCLE"  [AMC]
Local Integer WTYPZON
Local Char WIDENT1(250)
K = instr(1,[L]CLEOBJ,"~")
If K
 [L]WTYPZON = val(left$([L]CLEOBJ,K-1))
 [L]WIDENT1 = right$([L]CLEOBJ,K+1)
 K = instr(1,[L]WIDENT1,"~")
 If K
  [L]WIDENT1 = left$([L]WIDENT1,K-1)
 Endif
 For [AMC]AMC0 Where TYPZON=[L]WTYPZON & IDENT1=[L]WIDENT1
  FICHIER = "AMOTCLE" : ABR = "AMC" : IDENT = num$([L]WTYPZON)+"~"+[L]WIDENT1+"~"+[F:AMC]IDENT2 : Gosub FICHIER
 Next
Endif
Close Local File [AMC]
Return


