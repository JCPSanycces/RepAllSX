#<AdxTL>@(#)0.0.0.0 $Revision$Classe Initiateurs internes
# Superviseur
## CRUD-CLASSE ## CCMCRORIGI
# 2018-10-19 07:50:16 309


############################################################################################
### Subprog _AUPDATE
############################################################################################
Subprog _AUPDATE(CCMCRORIGI,ASTATUS)
Variable Instance CCMCRORIGI Using C_CCMCRORIGI
Variable Integer ASTATUS

If CCMCRORIGI = null : End : Endif

Gosub _AVARIABLES From WMC00CCMCRORIGI

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AUPDATE_CCMCRORIGI

End

#-----------------------------------------------------#

############################################################################################
### Subprog AUPDATE
############################################################################################
Subprog AUPDATE(CCMCRORIGI,ASTATUS)
Variable Instance CCMCRORIGI Using C_CCMCRORIGI
Variable Integer ASTATUS

If CCMCRORIGI = null : End : Endif

Gosub AVARIABLES From WMC00CCMCRORIGI
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
CCMCRORIGI.ASTALIN = [V]CST_AUPD
Gosub AUPDATE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If !adxlog
 Gosub AUPDATE_TR_CCMCRORIGI
Else
 Gosub AUPDATE_CCMCRORIGI
Endif
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

Gosub _AUPDATE_AFTER
[L]A_I = CCMCRORIGI.freeSnapshot
CCMCRORIGI.snapshotEnabled = 1
$AUPDATE_END
End


$AUPDATE_CONTROL
Gosub _AUPDATE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGI._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGI._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGI._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AUPDATE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_BEFORE
If CCMCRORIGI.ASTALIN = [V]CST_ANEWDEL : Return : Endif
CCMCRORIGI.ASTALIN = [V]CST_AUPD
If [V]CST_ASTALIN(CCMCRORIGI.ASTALIN)<>""
 [L]A_ASTALIN = CCMCRORIGI.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGI.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif

Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_AFTER

If [V]CST_ASTALIN(CCMCRORIGI.ASTALIN)<>""
 [L]A_ASTALIN = CCMCRORIGI.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGI.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
Return

#-----------------------------------------------------#
$AUPDATE_TR_CCMCRORIGI
Trbegin [F:CCMCROI]
 Gosub AUPDATE_CCMCRORIGI
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AUPDATE_CCMCRORIGI
[L]A_ASTALIN = CCMCRORIGI.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGI.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00CCMCRORIGI._MAJSQL_CCMCRORIGI(CCMCRORIGI))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


[L]A_ASTALIN = CCMCRORIGI.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGI.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AUPDATE_ABORT
Rollback
$_AUPDATE_ABORT
If CCMCRORIGI.snapshotEnabled=1
 [L]A_RETIK = CCMCRORIGI.revertUpdTick
Endif

[L]ASTATUS = max(fmet CCMCRORIGI.ACTION("AUPDATE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AUPDATE_AFTER
If find(CCMCRORIGI.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 CCMCRORIGI.ASTALIN = [V]CST_ALL
Endif
Return



