#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion objet TAT
######################################################################################
# Modifications :
#     V8 SEGAY - FQ81085 - US 1553 02/05/13 - Civility LEG
#     V8 MABOS - FQ81085 - US 1554-1553 14/05/13 - Pb de GCURLEG
######################################################################################

Raz GPILOBJ
Call OBJET("TAT",GBIDC1,"") From GOBJET
End

########################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "FILTRE"      : Gosub FILTRE
 When "LIENS"       : Gosub LIENS
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "RAZDUP"      : [M:TAT0]STAATT = 1
 When "FERME"       : Gosub FERME
 #86255
 When "AS_REFNUM"    : Gosub AS_REFNUM
 When "BS_REFNUM"    : Gosub BS_REFNUM
 When "RAZCRE"       : Gosub RAZCRE
Endcase
Return

$OUVRE
Gosub OUVRE From WPDEFTABLE
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If clalev([F:HRTAT])=0  : Local File TABAT      [HRTAT] : Endif
If clalev([F:TAT2])=0 : Local File TABAT      [TAT2]: Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif
If clalev([F:BPA])=0  : Local File BPADDRESS  [BPA] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif
If clalev([F:CNT])=0  : Local File CONTACT    [CNT] : Endif
If clalev([F:AIN])=0  : Local File CONTACTCRM [AIN] : Endif
If clalev([F:BAN])=0  : Local File BANK       [BAN] : Endif
If clalev([F:WAC])=0  : Local File TRVACC     [WAC] : Endif
If clalev([F:WAR])=0  : Local File TRVACCRAT  [WAR] : Endif
If clalev([F:ORG])=0  : Local File ORGANISME  [ORG] : Endif
Local Char VALPAYBAN(GLONBAN)
# FQ81085 - US 1553 02/05/13 - Civility LEG
Local Char    WNUMLIB(30)
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#86255
$RAZCRE
If GLEGFIL<>""
 GCURLEG=GLEGFIL
Else
 GCURLEG=GDOSLEG
Endif
Return
#

$FILTRE
If GUSRACS<>2
 FILTSUP = '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
 FILTSUP -= "& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))"
Else
 FILTSUP ="1=1"
Endif
Return

$APRES_MODIF
If [F:HRTAT]STAATT=3 & COUZON<>"RCVDAT" & COUZON<>"FLGRCV" & !find(COUZON,CLESEC) & !find(COUZON,CLEPRIM)
 # Modification impossible Attestation validée
 GERR = 1 : GMESSAGE = mess(9,123,1)-"\"-mess(40,10710,1)
 OK=0 : Return
Endif
## NUM = numéro chronologique
If (GREP="C" | GREP="D") & !find(COUZON,CLESEC) & !find(COUZON,CLEPRIM) & [M:TAT0]NUM>1
 Filter [TAT2] Where REFNUM=[M:TAT0]REFNUM & DAT=[M:TAT0]DAT & CTRNUM=[M:TAT0]CTRNUM
 Read [TAT2]TAT0 Last
 Filter [TAT2]
 [M:TAT0]NUM = [F:TAT2]NUM+1
 Affzo [M:TAT0]NUM
Endif
# FQ81085 - US 1553 02/05/13 - Civility LEG
# Le test sur REP et GREP ne sert à rien car n'était fait que sur COUZON="CTRNUM"
# et REP et GREP ne sont pas encore alimentés car la clé n'est pas validée
#If COUZON="REFNUM" | COUZON="DAT" | COUZON="CTRNUM" & (REP="C" | GREP="C" | REP="D" | GREP="D")  #& GTPS=0
#MIPEA - 2016-08-02 - REQ 114309 US102 - START
If COUZON="REFNUM" | COUZON="DAT" | COUZON="CTRNUM" & (REP="C" | GREP="C" | REP="D" | GREP="D")
#If (COUZON="REFNUM" | COUZON="DAT" | COUZON="CTRNUM")
#MIPEA - 2016-08-02 - REQ 114309 US102 - END
 Assign "[M:TAT0]"+COUZON With CZ
 GMODIF=1
 Gosub CHARGE
 Affzo[M:TAT0]
 Affzo[M:TAT1]
 Affzo[M:TAT2]
 Affzo[M:TAT3]
Endif
Return

$VERIF_CRE
Filter [TAT2] Where REFNUM=[M:TAT0]REFNUM & DAT=[M:TAT0]DAT & CTRNUM=[M:TAT0]CTRNUM
Read [TAT2]TAT0 Last
Filter [TAT2]
If [F:TAT2]NUM>=[M:TAT0]NUM
 [M:TAT0]NUM = [F:TAT2]NUM+1
 Affzo [M:TAT0]NUM
Endif
Return

$LIENS
#86255
If GNBLEG = 1         :#=dossier mono-leg
 GCURLEG = GDOSLEG
Else                  :#=dossier multi-leg
 GCURLEG = [F:HRTAT]LEG
Endif
#
Call GRISE_SBG ([M:TAT2]ENAFLG)
# 40284
# Call AM_FCYRPBFNC([M:TAT2]FCYRPBFNC)
Call GRISE_FCYRPBFNC([M:TAT2]FCYRPBFNC)
Call GRISE_FLGRCV([M:TAT1]FLGRCV)
#40284
Read [ID]ID0=[M:TAT0]REFNUM
If !fstat
 Call GRISE_CTRNUM([F:ID]FLGMULCTR)
Endif

Filter [HRCTR] Where REFNUM=[M:TAT0]REFNUM & CTRNUM=[M:TAT0]CTRNUM & CTRDAT<=[M:TAT0]DAT
Read [HRCTR]CTR0 Last
If fstat Then Raz [F:HRCTR] : Endif
Filter [HRCTR]
# FQ81085 - US 1553 02/05/13 - Civility LEG
If !fstat
  Call PARAM([F:HRCTR]ETRFCY,"CIVIL",WNUMLIB) From ADOVAL
Else
  Call PARAM([F:ID]FCYORI,"CIVIL",WNUMLIB) From ADOVAL
Endif
[M:TAT0]NOLIB=val(WNUMLIB)
#MIPEA - 2016-08-01 - REQ 114309 US102 - START
#If [M:TAT0]CIV>0 Then [M:TAT0]CIVA=mess([M:TAT0]CIV,val(WNUMLIB),1) : Endif
#MIPEA - 2016-08-01 - REQ 114309 US102 - END
# END FQ81085 - US 1553
Call LECTURE('FCY',[F:HRCTR]ETRFCY,'') From CONTOBJ
Call LECTURE('CPY',[F:FCY]LEGCPY,'') From CONTOBJ
Diszo [M:TAT3]BUL
Return


$CHARGE
# Onglet Salarié
Read [F:ID]ID0=[M:TAT0]REFNUM
If !fstat
 [M:TAT0]=[F:ID]
#MIPEA - 2016-08-01 - REQ 114309 US102 - START
 [M:TAT0]CIV=0
 [M:TAT0]CIVA=""
#MIPEA - 2016-08-01 - REQ 114309 US102 - END
 [M:TAT1]=[F:ID]
Endif

If [F:ID]NTT="FR"
 [M:TAT1]NTTTYP = 1
Else
 Read[TCY]TCY0=[F:ID]NTT
 If [F:TCY]EECFLG=2 : # Appartenance CEE
  [M:TAT1]NTTTYP = 2
 Else
  [M:TAT1]NTTTYP = 3
 Endif
Endif

Filter [HRCTR] Where REFNUM=[M:TAT0]REFNUM & CTRNUM=[M:TAT0]CTRNUM & CTRDAT<=[M:TAT0]DAT
Read [HRCTR]CTR0 Last
Filter [HRCTR]
If !fstat
 [M:TAT1]JOB    = [F:HRCTR]JOB
 [M:TAT1]DATANC = [F:HRCTR]DATANC

 ##**82073
 [M:TAT0]CTRDAT = [F:HRCTR]CTRDAT

 # FQ81085 - 23/04/13 - Les numéros de sécu arrivent du contrat, et plus du salarié
 [M:TAT1]NUMSSC  = [F:HRCTR]NUMSSCCTR
 [M:TAT1]NUMSSC2 = [F:HRCTR]NUMSSCCTR2
 # FQ81085 - US 1553 02/05/13 - Civility LEG
 Call PARAM([F:HRCTR]ETRFCY,"CIVIL",WNUMLIB) From ADOVAL
 [M:TAT0]NOLIB=val(WNUMLIB)
 If [F:HRCTR]CIVCTR>0 Then
    [M:TAT0]CIVA=mess([F:HRCTR]CIVCTR,val(WNUMLIB),1)
    [M:TAT0]CIV=[F:HRCTR]CIVCTR
 Endif
 # END FQ81085 - US 1553

 If [F:HRCTR]DATANCAPT<>[0/0/0] : # Le salarié est un apprenti
  [M:TAT3]NUMCON = [F:HRCTR]NUMCON
  ##**82073
  [M:TAT3]CTRDATAPT = [F:HRCTR]CTRDAT
 Endif
 [M:TAT1]QLF    = [F:HRCTR]QLF
 Read[WAC]WAC0=[F:HRCTR]RSKWRK
 If !fstat
  [M:TAT1]CODRSK = [F:WAC]CODRSK
 Endif
 #40368
 For I=0 To [M:TAT1]NBR1-1
  [M:TAT1]RATPFL(I) = [F:HRCTR]DED
 Next

 Call LECTURE('FCY',[F:HRCTR]ETRFCY,'') From CONTOBJ
 Call LECTURE('CPY',[F:FCY]LEGCPY,'') From CONTOBJ
 #86255
 If dim([M:TAT0]LEG)>0 : [M:TAT0]LEG=[F:CPY]LEG : Affzo [TAT0]LEG : Endif
 GCURLEG=[F:CPY]LEG
 #
#MIPEA - 2016-09-28 - X3PEOP-752 - START
Local Integer ORGLINE
Local Integer COUNTER
If clalev([F:PCA])=0 : Local File CAISSE [PCA] : Endif
If !clalev([F:ADIZZ]) : Local File ATABDIV [ADIZZ]    : Endif

Filter [ADIZZ] Where [ADIZZ]NUMTAB = 10469 & [ADIZZ]LEG = GCURLEG # & [ADIZZ]CODE = [V]GINDMED

For [ADIZZ]
  [L]COUNTER+=1
    If [ADIZZ]CODE = [V]GINDMED
      [L]ORGLINE=[L]COUNTER-1 : Break
    Endif
Next
 Call ORGANISME([M:TAT0]REFNUM,[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM,[M:TAT1]MEDORG,[L]ORGLINE) From SUBORG
 #Call ORGANISME([M:TAT0]REFNUM,[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM,[M:TAT1]MEDORG,[V]GINDMED-1) From SUBORG
#MIPEA - 2016-09-28 - X3PEOP-752 - END
 Call LECTURE("ORG",[M:TAT1]MEDORG,GCURLEG) From CONTOBJ
 [M:TAT1]MEDADD = [F:ORG]ADD(0)-[F:ORG]POS-[F:ORG]CTY
 [M:TAT1]ETRDAT = [F:HRCTR]CTRDAT
 Read [FCY]FCY0=[F:HRCTR]ETRFCY
 If !fstat
  [M:TAT2]FCY    = [F:FCY]FCY
  [M:TAT2]FCYCRN = [F:FCY]CRN
  Read [BPA]BPA0=3;[F:FCY]FCY;[F:FCY]BPAADD
  If !fstat
   [M:TAT2]FCYADDLIG(0) = [F:BPA]BPAADDLIG(0)
   [M:TAT2]FCYADDLIG(1) = [F:BPA]BPAADDLIG(1)
   [M:TAT2]FCYADDLIG(2) = [F:BPA]BPAADDLIG(2)
   [M:TAT2]FCYPOSCOD    = [F:BPA]POSCOD
   [M:TAT2]FCYCTY       = [F:BPA]CTY
   [M:TAT2]FCYCRY       = [F:BPA]CRY
   [M:TAT2]FCYTEL       = [F:BPA]TEL
  Endif
  Read [CPY]CPY0=[F:FCY]LEGCPY
  If !fstat
   Read [BPA]BPA0=2;[F:CPY]CPY;[F:CPY]BPAADD
   If !fstat
    [M:TAT2]CPY          = [F:CPY]CPY
    [M:TAT2]CPYADDLIG(0) = [F:BPA]BPAADDLIG(0)
    [M:TAT2]CPYADDLIG(1) = [F:BPA]BPAADDLIG(1)
    [M:TAT2]CPYADDLIG(2) = [F:BPA]BPAADDLIG(2)
    [M:TAT2]CPYPOSCOD    = [F:BPA]POSCOD
    [M:TAT2]CPYCTY       = [F:BPA]CTY
    [M:TAT2]CPYCRY       = [F:BPA]CRY
#MIPEA - 2016-07-28 - REQ 114309 US102 - START
    [M:TAT2]CPYTEL       = [F:BPA]TEL
#MIPEA - 2016-07-28 - REQ 114309 US102 - END
   Endif
  Endif
  Read [F:CNT]CNT0=3;[F:FCY]FCY;[F:FCY]CNTNAM
  If !fstat
   Read [F:AIN]AIN0=[F:FCY]CNTNAM
   If !fstat
    [M:TAT2]FCYRPB    = [F:AIN]CNTLNA-[F:AIN]CNTFNA
    [M:TAT2]FCYRPBFNC = [F:CNT]CNTFNC
    Read [BPA]BPA0=3;[F:FCY]FCY;[F:CNT]BPAADD
    If !fstat
     [M:TAT2]PLCREF   = [F:BPA]CTY
    Endif
   Endif
  Endif
  If [F:FCY]PAYBAN<>""
   Read [F:BAN]BAN0=[F:FCY]PAYBAN
   If !fstat
    [M:TAT2]FCYBID    = [F:BAN]BIDNUM
    [M:TAT2]FCYBIDCRY = [F:BAN]CRY
    [M:TAT2]FCYCUR    = [F:BAN]CUR
    [M:TAT2]DESBID    = [F:BAN]PAB1
   Endif
  Else
   Call PARAM([F:FCY]LEGCPY,"PAYBAN",VALPAYBAN) From ADOVAL
   If VALPAYBAN<>""
    Read [F:BAN]BAN0=VALPAYBAN
    If !fstat
     [F:HRTAT]FCYBID    = [F:BAN]BIDNUM
     [F:HRTAT]FCYBIDCRY = [F:BAN]CRY
     [F:HRTAT]FCYCUR    = [F:BAN]CUR
     [F:HRTAT]DESBID    = [F:BAN]PAB1
    Endif
   Endif
  Endif
 Endif
Else
 # FQ81085 - US 1553 02/05/13 - Civility LEG
 Call PARAM([F:ID]FCYORI,"CIVIL",WNUMLIB) From ADOVAL
 [M:TAT0]NOLIB=val(WNUMLIB)
#MIPEA - 2016-08-01 - REQ 114309 US102 - START
# If [F:ID]CIV>0 Then
#    [M:TAT0]CIVA=mess([F:ID]CIV,val(WNUMLIB),1)
#    [M:TAT0]CIV=[F:ID]CIV
# Endif
 #MIPEA - 2016-08-01 - REQ 114309 US102 - END
 # END FQ81085 - US 1553
Endif

[M:TAT2]ENAFLG = 2
[M:TAT2]STRSBG = [M:TAT0]DAT
[M:TAT2]ENDSBG = [M:TAT0]DAT
[M:TAT2]DATREF = date$


Return

$SETBOUT
Gosub SETBOUT From SUBMAL
Return

#Pour se positionner sur le dernier enreg après extraction
$EXEBOUT
If BOUT="B" & GSTATUT=GSTAOK
 Read [F:HRTAT]TAT1 Last
 If !fstat
  [M:TAT0]=[F:HRTAT]
  [M:TAT1]=[F:HRTAT]
  [M:TAT2]=[F:HRTAT]
  [M:TAT3]=[F:HRTAT]
  Affzo [M:TAT0]
  Affzo [M:TAT1]
  Affzo [M:TAT2]
  Affzo [M:TAT3]
 Endif
Endif
If BOUT="G"
 Gosub RELIT From GOBJSUB
Endif
Return


#86255
#Before selection on field REFNUM
#############
$AS_REFNUM
Raz GCURLEG
Return

#After selection on field REFNUM
############
$BS_REFNUM
# To do nothing if the user doesn't select a record
If mkstat>0
 If dim([M:TAT0]LEG)>=0
  GCURLEG=[M:TAT0]LEG
 Elsif GLEGFIL<>""
  GCURLEG=GLEGFIL
 Else
  GCURLEG=GDOSLEG
 Endif
Endif
Return
#


######################################################################################
## Etiquettes Ecran TAT0
######################################################################################

#Subprog AS_DAT(VALEUR)
#Variable Date    VALEUR()
#Infbox "passe"
#End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
#If [F:ID]FLGMULCTR<>2
# Call CHERCHE_CTR(VALEUR,[M:TAT0]DAT,[M:TAT0]CTRNUM) From DIVPAYE
# Affzo [TAT0]CTRNUM
# [M:TAT0]CTRDAT=[F:HRCTR]CTRDAT    :##**82073
#  #GCURLEG=[F:CPY]LEG : #MABOS-14/05/13
#Else
# Raz [M:TAT0]CTRNUM,CTRDAT         :##**82073
# #If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif:#MABOS-14/05/13
#Endif
#Call GRISE_CTRNUM([F:ID]FLGMULCTR)
Filter [F:HRTAT] Where REFNUM=VALEUR
Read [F:HRTAT]TAT0 Last
Filter [HRTAT]
If fstat<=2
 [M:TAT0]DAT = [F:HRTAT]DAT
 [M:TAT0]CTRNUM = [F:HRTAT]CTRNUM
 [M:TAT0]CTRDAT = [F:HRTAT]CTRDAT
 Affzo [M:TAT0]DAT,CTRNUM
 #86255
 If dim([M:TAT0]LEG)>0 : [M:TAT0]LEG=[F:HRTAT]LEG : Affzo [M:TAT0]LEG : Endif
 GCURLEG=[F:HRTAT]LEG
Else
 Raz [M:TAT0]CTRNUM,CTRDAT,DAT
 #86255
 If dim([M:TAT0]LEG)>0 : Raz [M:TAT0]LEG : Endif
 Raz GCURLEG
 mkstat=4
Endif
Call GRISE_CTRNUM([F:ID]FLGMULCTR)
End

Subprog AM_DAT(VALEUR)
Variable Date    VALEUR
#If [F:ID]FLGMULCTR<>2
# #If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif:#MABOS-14/05/13
# Call CHERCHE_CTR([M:TAT0]REFNUM,VALEUR,[M:TAT0]CTRNUM) From DIVPAYE
# Affzo [TAT0]CTRNUM
# [M:TAT0]CTRDAT=[F:HRCTR]CTRDAT    :##**82073
# Call LECTURE('FCY',[F:HRCTR]ETRFCY,'') From CONTOBJ
# Call LECTURE('CPY',[F:FCY]LEGCPY,'') From CONTOBJ
# #GCURLEG=[F:CPY]LEG
#Endif
Filter [F:HRTAT] Where REFNUM=[M:TAT0]REFNUM & DAT=VALEUR
Read [F:HRTAT]TAT0 Last
Filter [HRTAT]
If fstat<=2
 [M:TAT0]CTRNUM = [F:HRTAT]CTRNUM
 [M:TAT0]CTRDAT = [F:HRTAT]CTRDAT
 Affzo [M:TAT0]CTRNUM
 #86255
 If dim([M:TAT0]LEG)>0 : [M:TAT0]LEG=[F:HRTAT]LEG : Affzo [M:TAT0]LEG : Endif
 GCURLEG=[F:HRTAT]LEG
Else
 Raz [M:TAT0]CTRNUM,CTRDAT
 #86255
 If dim([M:TAT0]LEG)>0 : Raz [M:TAT0]LEG : Endif
 Raz GCURLEG
 mkstat=4
 If [F:ID]FLGMULCTR<>2
  Call CHERCHE_CTR([M:TAT0]REFNUM,VALEUR,[M:TAT0]CTRNUM) From DIVPAYE
  If [M:TAT0]CTRNUM=""
   GMESSAGE=mess(158,10702,1) :#A créer
   mkstat=2 : End
  Endif
  [M:TAT0]CTRDAT=[F:HRCTR]CTRDAT
  #86255
  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  If dim([M:TAT0]LEG)>0 : [M:TAT0]LEG=[F:CPY]LEG : Affzo [M:TAT0]LEG : Endif
  GCURLEG=[F:CPY]LEG
 Else
  GCURLEG=GLEGFIL
 Endif
 Affzo [M:TAT0]CTRNUM
Endif
End

Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
#If [M:TAT0]CTRNUM=""
# Call SELCTR([M:TAT0]REFNUM,[M:TAT0]DAT,[M:TAT0]DAT,VALEUR) From DIVPAYE
# [M:TAT0]CTRDAT=[F:HRCTR]CTRDAT    :##**82073
#Endif
If [M:TAT0]CTRNUM=""
 Call SELCTR([M:TAT0]REFNUM,[M:TAT0]DAT,[M:TAT0]DAT,VALEUR) From DIVPAYE
 [M:TAT0]CTRDAT=[F:HRCTR]CTRDAT
 [M:TAT0]CTRNUM=VALEUR
 Affzo [M:TAT0]CTRNUM
 #86255
# Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
# Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
# If dim([M:TAT0]LEG)>0 : [M:TAT0]LEG=[F:CPY]LEG : Affzo [M:TAT0]LEG : Endif
 If dim([M:TAT0]LEG)>0 : [M:TAT0]LEG=GCURLEG : Affzo [M:TAT0]LEG : Endif
# GCURLEG=[F:CPY]LEG
Endif
End


Subprog GRISE_CTRNUM(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Actzo [M:TAT0]CTRNUM
Else
 Diszo [M:TAT0]CTRNUM
Endif
Affzo [M:TAT0]CTRNUM
End

Subprog AM_STAATT(VALEUR)
Variable Integer VALEUR
Local Integer OK
If VALEUR=3
 OK = 2
 # Validation manuelle de l'attestation
 Call AVERTIR(mess(41,10710,1),OK) From GESECRAN
 If OK<>2 : mkstat=2 : Endif
Endif
End

######################################################################################
## Etiquettes Ecran TAT1
######################################################################################

Subprog C_FLGRCV(VALEUR)
Variable Integer VALEUR
Call GRISE_FLGRCV(VALEUR)
End

Subprog GRISE_FLGRCV(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo [TAT1]RCVDAT
 Grizo [TAT1]RCVDAT
Else
 Actzo [TAT1]RCVDAT
Endif
End

Subprog C_MEDORG(VALEUR)
Variable Char    VALEUR()
Local Integer OK
#MIPEA - 2016-09-28 - X3PEOP-752 - START
Local Integer ORGLINE
Local Integer COUNTER
#MIPEA - 2016-09-28 - X3PEOP-752 - END
If clalev([F:PCA])=0 : Local File CAISSE [PCA] : Endif
#MIPEA - 2016-09-28 - X3PEOP-752 - START
If !clalev([F:ADIZZ]) : Local File ATABDIV [ADIZZ]    : Endif

Filter [ADIZZ] Where [ADIZZ]NUMTAB = 10469 & [ADIZZ]LEG = GCURLEG # & [ADIZZ]CODE = [V]GINDMED

For [ADIZZ]
  [L]COUNTER+=1
    If [ADIZZ]CODE = [V]GINDMED
      [L]ORGLINE=[L]COUNTER-1 : Break
    Endif
Next
Filter [ADIZZ]
#MIPEA - 2016-09-28 - X3PEOP-752 - END
For [PCA] Where LEG = GCURLEG
#For [PCA]
#MIPEA - 2016-09-28 - X3PEOP-752 - START
   If [F:PCA]ORG([L]ORGLINE)=VALEUR
   #If [F:PCA]ORG([V]GINDMED-1)=VALEUR
#MIPEA - 2016-09-28 - X3PEOP-752 - END
      OK = 1 : Break
   Endif
Next
If OK=0
 # Cet organisme n'est pas rattaché à la medecine du travail
 GMESSAGE = mess(25,10710,1)
 mkstat = 2 : End
Endif
End

Subprog C_RCVDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M]LSTDAYDAT
 # La date de reprise doit être supérieure au dernier jour travaillé
 GMESSAGE = mess(24,10710,1)
 mkstat = 2 : End
Endif
End
######################################################################################
## Etiquettes Ecran TAT2
######################################################################################

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Read [CPY]CPY0=VALEUR
If !fstat
 Read [BPA]BPA0=2;VALEUR;[F:CPY]BPAADD
 If !fstat
  [M:TAT2]CPYADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [M:TAT2]CPYADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [M:TAT2]CPYADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [M:TAT2]CPYPOSCOD    = [F:BPA]POSCOD
  [M:TAT2]CPYCTY       = [F:BPA]CTY
  [M:TAT2]CPYCRY       = [F:BPA]CRY
  Affzo [TAT2]5
 Endif
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Read [FCY]FCY0=VALEUR
If !fstat & [F:FCY]LEGCPY<>[M:TAT2]CPY
 #Site référencé dans la société
 GMESSAGE = mess(70,104,1)-[M:TAT2]CPY
 mkstat = 2 : End
Endif
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Read [FCY]FCY0=VALEUR
If !fstat
 [M:TAT2]FCYCRN = [F:FCY]CRN
 Read [BPA]BPA0=3;[F:FCY]FCY;[F:FCY]BPAADD
 If !fstat
  [M:TAT2]FCYADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [M:TAT2]FCYADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [M:TAT2]FCYADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [M:TAT2]FCYPOSCOD    = [F:BPA]POSCOD
  [M:TAT2]FCYCTY       = [F:BPA]CTY
  [M:TAT2]FCYCRY       = [F:BPA]CRY
  [M:TAT2]FCYTEL       = [F:BPA]TEL
  Affzo [TAT2]10
 Endif
Endif
End

Subprog C_ENAFLG(VALEUR)
Variable Integer VALEUR
Call GRISE_SBG(VALEUR)
End

Subprog GRISE_SBG(VALEUR)
Value Integer VALEUR
If VALEUR=1
 Effzo [M:TAT2]STRSBG : Grizo [M:TAT2]STRSBG
 Effzo [M:TAT2]ENDSBG : Grizo [M:TAT2]ENDSBG
 Effzo [M:TAT2]FCYBID : Grizo [M:TAT2]FCYBID
 Effzo [M:TAT2]FCYCUR : Grizo [M:TAT2]FCYCUR
 Effzo [M:TAT2]DESBID : Grizo [M:TAT2]DESBID
Else
 Actzo [M:TAT2]STRSBG
 Actzo [M:TAT2]ENDSBG
 Actzo [M:TAT2]FCYBID
 Actzo [M:TAT2]FCYCUR
 Actzo [M:TAT2]DESBID
Endif
Affzo [M:TAT2]15
End

Subprog C_DATREF(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M:TAT0]DAT
 # La date de signature doit être supérieure au
 GMESSAGE = mess(26,10710,1)-num$([M:TAT0]DAT)
 mkstat = 2 : End
Endif
End

Subprog C_FCYRPBFNC(VALEUR)
Variable Integer VALEUR
Call GRISE_FCYRPBFNC(VALEUR)
End

Subprog GRISE_FCYRPBFNC(VALEUR)
Variable Integer VALEUR
If VALEUR=10
 Actzo [M:TAT2]FCYRPBFNC2
Else
 Effzo [M:TAT2]FCYRPBFNC2
 Grizo [M:TAT2]FCYRPBFNC2
Endif
End
######################################################################################
## Etiquettes Ecran TAT3
######################################################################################

# 40368
Subprog D_RATPFL(VALEUR)
Variable Decimal VALEUR
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
Filter [HRCTR] Where REFNUM=[M:TAT0]REFNUM & CTRNUM=[M:TAT0]CTRNUM & CTRDAT<=[M:TAT0]DAT
Read [HRCTR]CTR1 Last
Filter [HRCTR]
If !fstat
 VALEUR = [F:HRCTR]DED
Endif
End
######################################################################################
## Section automatically added (screen TAT0) 14/06/2012 16:08:36 (ADW)
######################################################################################
Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
##86255
#Call CHERCHE_CTR([M:TAT0]REFNUM,[M:TAT0]DAT,VALEUR) From DIVPAYE
#If VALEUR=""
# GMESSAGE=mess(158,10702,1)
# mkstat=2 : End
#Endif
#[M:TAT0]CTRDAT=[F:HRCTR]CTRDAT
#Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
#Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
#If dim([M:TAT0]LEG)>0 : [M:TAT0]LEG=[F:CPY]LEG : Affzo [M:TAT0]LEG : Endif
#GCURLEG=[F:CPY]LEG

Filter [HRCTR] Where REFNUM=[M:TAT0]REFNUM & CTRDAT<=[M:TAT0]DAT & CTRNUM=VALEUR
Read [HRCTR]CTR0 Last
Filter [HRCTR]
If fstat<=2
 [M:TAT0]CTRNUM=VALEUR
 [M:TAT0]CTRDAT=[F:HRCTR]CTRDAT
 Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 If dim([M:TAT0]LEG)>0 : [M:TAT0]LEG=[F:CPY]LEG : Affzo [M:TAT0]LEG : Endif
 GCURLEG=[F:CPY]LEG
Else
 GCURLEG=GLEGFIL
 GMESSAGE=mess(158,10702,1)
 mkstat=2 : End
Endif

End
