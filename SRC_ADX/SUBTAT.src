Subprog AS_GRDABS(VALEUR)
Variable Integer VALEUR
[V]GMENLOC(3)=1
#MIPEA - 2016-06-13 - REQ 114309 US102 - START
# 69363 - 2015-07-16 by BRBAN : Code 4 must appear to Portugal
If (func AFNC.ACTIV("KFR")>0 & func AFNC.ACTIV("KPO")=0) or (func AFNC.ACTIV("KSA")>0 & func AFNC.ACTIV("KPO")=0)
  [V]GMENLOC(4)=1
Endif
End
