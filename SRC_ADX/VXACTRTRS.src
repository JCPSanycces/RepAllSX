#<AdxTL>@(#)5.0.0.0 $Revision$
####################################################################################
# Program Name: VXACTRTRS
# Description : ADC Transaction Control
# Author      : TS
# Date        : January 31th, 2007
####################################################################################

########################################################################
# Action       : VXACTRSTK
# Paramètres E : LTRS  = Code transaction
#                LTYP  = Type transaction
#
#            S : mkstat est positionné à 2 si erreur
#
########################################################################
Subprog VXACTRSTK(LTRS,LTYP)
Value   Char    LTRS
Value   Integer LTYP
If clalev([F:SRT])=0 : Local File STKTRS [SRT] : Endif
If clalev([F:ACC])=0 : Local File ACCES  [ACC] : Endif

Read [SRT]SRT0=LTYP;LTRS
If fstat
   GMESSAGE=mess(13,7750,1) : mkstat=2 : End
Endif

If [F:SRT]ENAFLG<>2
   GMESSAGE=mess(14,7750,1) : mkstat=2 : End
Endif

# Contrôle du code accès
If [F:SRT]ACSCOD<>"" & GUSRACS<>2
  Read [ACC]CODACC = GUSER;[F:SRT]ACSCOD
  If fstat | [F:ACC]EXEC<>2
   GMESSAGE=mess(4,104,1) : mkstat=2 : End
  Endif
Endif
#  HCB 60191
#--- Lot V01 rajour when 5
Case LTYP
 When 1 : If [F:SRT]SPOTFLG=2   | [F:SRT]SRUB1FLG=2 |
&            [F:SRT]SRUB2FLG=2 | [F:SRT]SRUB3FLG=2 | [F:SRT]SRUB4FLG=2
             GMESSAGE=mess(15,7750,1)
             mkstat=2
          Endif
 When 2 : If [F:SRT]STKFLG=2
             GMESSAGE=mess(15,7750,1)
             mkstat=2
          Endif

#--- Lot V01  suppression tests sur prncod = 2
 When 3 : Case GFONC1
           When "VXASC" : If [F:SRT]BETFCYCOD<>1 |
&                            [F:SRT]CHGPCUCOD=2
                             GMESSAGE=mess(15,7750,1)
                             mkstat=2
                          Endif
           When "VXAIT" : If [F:SRT]BETFCYCOD<>2
                             GMESSAGE=mess(15,7750,1)
                             mkstat=2
                          Endif
           When "VXAST" : If [F:SRT]BETFCYCOD<>4
                             GMESSAGE=mess(15,7750,1)
                             mkstat=2
                          Endif
          Endcase
 When 5 : If [F:SRT]SPERFLG=2  | [F:SRT]SPOTFLG=2  | [F:SRT]SRUB1FLG=2 |
&            [F:SRT]SRUB2FLG=2 | [F:SRT]SRUB3FLG=2 | [F:SRT]SRUB4FLG=2
             GMESSAGE=mess(15,7750,1)
             mkstat=2
          Endif
 When 9 : If [F:SRT]STKFLG=2                      # hcb 93103
             GMESSAGE=mess(15,7750,1)             # hcb 93103
             mkstat=2                             # hcb 93103
          Endif                                   # hcb 93103 



Endcase

End

########################################################################
# Action       : VXACTRMFG
# Paramètres E : LTRS  = Code transaction
#                LTYP  = Type transaction
#                        60 pour suivi des temps
#                        61 pour suivi des matières
#                        62 pour suivi de production
#
#            S : mkstat est positionné à 2 si erreur
#
########################################################################
Subprog VXACTRMFG(LTRS,LTYP)
Value   Char    LTRS
Value   Integer LTYP

# If clalev([F:BTS])=0 : Local File BENCHTRS [SRT] : Endif : # GH 16/09/2013 bug 92522
If clalev([F:BTS])=0 : Local File BENCHTRS [BTS] : Endif
If clalev([F:ACC])=0 : Local File ACCES    [ACC] : Endif

Read [BTS]BTS0=LTYP;LTRS
If fstat
   GMESSAGE=mess(13,7750,1) : mkstat=2 : End
Endif

If [F:BTS]ENAFLG<>2
   GMESSAGE=mess(14,7750,1) : mkstat=2 : End
Endif

# Contrôle du code accès
If [F:BTS]ACSCOD<>"" & GUSRACS<>2
  Read [ACC]CODACC = GUSER;[F:BTS]ACSCOD
  If fstat | [F:ACC]EXEC<>2
   GMESSAGE=mess(4,104,1) : mkstat=2 : End
  Endif
Endif
Case LTYP
 When 60 :  If [F:BTS]OPEUOMMOD=2
               GMESSAGE=mess(15,7750,1)
               mkstat=2
            Endif
 When 61 :  If [F:BTS]STKFLG=2
               GMESSAGE=mess(15,7750,1)
               mkstat=2
            Endif
# hcb 60322 suppression de sperflg
 When 62 :  If [F:BTS]SPOTFLG=2  | [F:BTS]SRUB1FLG=2 |
&              [F:BTS]SRUB2FLG=2 | [F:BTS]SRUB3FLG=2 | [F:BTS]SRUB4FLG=2
#MAE, impression des étiquettes autorisée en VT
#&              [F:BTS]PRNCOD1=2
               GMESSAGE=mess(15,7750,1)
               mkstat=2
          Endif
Endcase
End


########################################################################
# Action       : VXACTRPUR
# Paramètres E : LTRS  = Code transaction
#                LTYP  = Type transaction
#
#            S : mkstat est positionné à 2 si erreur
#
########################################################################
Subprog VXACTRPUR(LTRS,LTYP)
Value   Char    LTRS
Value   Integer LTYP
#-----
If !clalev([F:PTR])  Local File PURTRS  [PTR] : Endif
If !clalev([F:ACC])  Local File ACCES   [ACC] : Endif
#-----
Read [PTR] PTR0=LTYP;LTRS
If fstat
  GMESSAGE=mess(13,7750,1) : mkstat=2 : End
Endif
If [F:PTR]ENAFLG<>2
  GMESSAGE=mess(14,7750,1) : mkstat=2 : End
Endif
#----- Contrôle du code accès -----#
If [F:PTR]ACSCOD<>"" & GUSRACS<>2
  Read [ACC] CODACC=GUSER;[F:PTR]ACSCOD
  If fstat | [F:ACC]EXEC<>2
    GMESSAGE=mess(4,104,1) : mkstat=2 : End
  Endif
Endif
#-----
#MAE, impression étiquette pour réception en VT
#When 6 : If [F:PTR]SPOTFLG=2  | [F:PTR]SPERFLG=2  | [F:PTR]SRUB1FLG=2 |
#&            [F:PTR]SRUB2FLG=2 | [F:PTR]SRUB3FLG=2 | [F:PTR]SRUB4FLG=2 |
#&            [F:PTR]PRNCOD1=2  | [F:PTR]DOCFLG=2
# hcb 60191
Case LTYP
 When 6 : If [F:PTR]SPOTFLG=2  |  [F:PTR]SRUB1FLG=2 |
&            [F:PTR]SRUB2FLG=2 | [F:PTR]SRUB3FLG=2 | [F:PTR]SRUB4FLG=2
#&            [F:PTR]DOCFLG=2                                              #--- Lot V01
             GMESSAGE=mess(15,7750,1)
             mkstat=2
          Endif
Endcase
End
