#<AdxTL>@(#)0.0.0.0 $Revision$Class Bank import type codes
# Supervisor
## ACLA-CLASSE ## BSIITCD
# 2018-08-16 22:22:46 661

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0BSIITCD
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_BSICODTC From WMC1BSIITCD : Gosub TESTALLSTAT
Gosub INIT_LIN From WMC1BSIITCD : Gosub TESTALLSTAT
Gosub INIT_LEV From WMC1BSIITCD : Gosub TESTALLSTAT
Gosub INIT_COD From WMC1BSIITCD : Gosub TESTALLSTAT
Gosub INIT_DESAXX From WMC1BSIITCD : Gosub TESTALLSTAT
Gosub INIT_SIG From WMC1BSIITCD : Gosub TESTALLSTAT
Gosub INIT_SUMCOD From WMC1BSIITCD : Gosub TESTALLSTAT
Gosub INIT_REC From WMC1BSIITCD : Gosub TESTALLSTAT
Gosub INIT_DESFLD From WMC1BSIITCD : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1BSIITCD : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1BSIITCD : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1BSIITCD : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1BSIITCD : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1BSIITCD : Gosub TESTALLSTAT
Gosub INIT_BAN From WMC1BSIITCD : Gosub TESTALLSTAT
Gosub AINIT From WMC0BSIITCD : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0BSIITCD
Gosub _ALOADATTRIBUTE_BSICODTC From WMC1BSIITCD : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_LIN From WMC1BSIITCD : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_COD From WMC1BSIITCD : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0BSIITCD
Gosub LNKPRO_CREUSR From WMC1BSIITCD : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC1BSIITCD : Gosub TESTALLSTAT
Gosub LNKPRO_BAN From WMC1BSIITCD : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



