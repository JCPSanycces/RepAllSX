#<AdxTL>@(#)0.0.0.0 $Revision$
#Add 100 rows
Local Char TMP(100)
TMP=func FILLTABLE(100)
End


# Let's use a table AQCS1
Funprog FILLTABLE(N)
Local File AQCS1,ATEXTRA

If adxlog : Rollback : Endif
Trbegin AQCS1
Delete [AQCS1] Where 1=1
Delete [AXX] Where [AXX]CODFIC="AQCS1"

Commit

Local Integer NEXTC, NEXTI, NEXTU, NEXTA, NEXTX,NEXTS,NEXTF
Local Char COUNTRIES(20)(1..), CURRENCY(20)(1..),ACTIV(10)(1..),ACCESS(10)(1..),UOM(10)(1..),FCY(5)(1..3)
Local Uuident UUIDS(1..)
Gosub INIT_VALUES

Trbegin AQCS1
  For I=1 To N
    Gosub NEXTVAL
    [AQCS1]ACV=ACTIV(NEXTA)
    [AQCS1]ACS=ACCESS(NEXTX)
    [AQCS1]DAT=[01/01/2001]+mod(I*37,5101) : # In order to have dispersed dates after 2000 but before today
    [AQCS1]ALPHA(0)=sigma(1,1+mod(mod(I*53,5107),20),chr$(65+mod(mod((I*7+indcum*3)*7001,5107),26))) # In order to have dispersed strings
    [AQCS1]ALPHA(1)=sigma(1,1+mod(mod(I*53,5113),20),chr$(65+mod(mod((I*7+indcum*3)*7013,5107),26))) # In order to have dispersed strings
    [AQCS1]ALPHA(2)=sigma(1,1+mod(mod(I*53,5119),20),chr$(65+mod(mod((I*7+indcum*3)*7019,5119),26))) # In order to have dispersed strings
    [AQCS1]ALPHA(3)=sigma(1,1+mod(mod(I*53,5147),20),chr$(65+mod(mod((I*7+indcum*3)*7047,5147),26))) # In order to have dispersed strings
    [AQCS1]DES="Description "-num$(I)
    [AQCS1]COD=format$("N0:10",I)
    [AQCS1]INTG=mod(I*10007,10009)
    [AQCS1]UUID=UUIDS(NEXTU)
    [AQCS1]FCY = [L]FCY(NEXTF)
    [AQCS1]DTIME=gdatetime$(num$(2001+mod(I*10037,13))+"-"+format$("N0:2",1+mod(I*10039,11))+"-"+format$("N0:2",1+mod(I*10061,27))
&             +"T"+format$("N0:2",1+mod(I*10067,22))+":"+format$("N0:2",1+mod(I*10069,58))+":"+format$("N0:2",1+mod(I*10079,58))+"Z")
    [AQCS1]MENL=1+mod(I,2)
    Write [AQCS1]
    Break (fstat<>0)
    [AXX]CODFIC="AQCS1"
    [AXX]ZONE="TTEXT"
    [AXX]LANGUE="FRA"
    [AXX]LANORI="FRA"
    [AXX]IDENT1=[AQCS1]COD
    [AXX]TEXTE="Description traduisible"-num$(I)
    Write [AXX]
    Break (fstat<>0)
    [AXX]LANGUE="ENG"
    [AXX]TEXTE="Translatable description "-num$(I)
    Write [AXX]
    Break (fstat<>0)
  Next I

If fstat=0 : Commit : Else Rollback : Endif
End string$(fstat=0,num$(N)+" records created")+string$(fstat<>0,"failing to create record after "+num$(I)+" creations"-num$(fstat))


# Fill the arrays with a total count, for every collection, that is a different prime number (in order to allows a good variability)
$INIT_VALUES
Local Char STRING(50)

I=1
# 13 existing country codes
For STRING="FR","US","DE","CA","IT","JP","MX","UK","AR","AN","CH","ES","PT"
 COUNTRIES(I)=STRING
 I+=1
Next

I=1
# 5 existing access codes
For STRING="AQCACS1","AQCACS2","AQCACS3","CREDITCHEC","AUTO"
 ACCESS(I)=STRING
 I+=1
Next
I=1

# 11 existing currency codes
For STRING="EUR","USD","CAD","CHF","TUD","JPY","TL","LBP","GBP","CNY","TND"
 CURRENCY(I)=STRING
 I+=1
Next

I=1
For STRING="AZPL","CSL","KFR","KUS","STA","SUP","ST1" : # 7 existing activity codes
 ACTIV(I)=STRING
 I+=1
Next

I=1
For STRING="1FF","AQC","B","BA","BT","CKG","Ca5", "Car", "CEN", "Cm", "EA","Fut", "G", "Kg", "L","M","UN" : # 17 existing UOM
 UOM(I)=STRING
 I+=1
Next

I=1
For STRING="d73bbd98-02de-4782-bc32-4f28a3086d6e","91529903-2848-4fc4-b9b9-2ddd4f4a4324","22692b84-5d70-421e-9f05-51893f93a0a9","96b54a41-42b6-4e84-8a1d-e420b24cbf46",
&          "6bf8a40f-2ca0-436c-a4f4-fba746697be8","8a57db5c-132c-41be-b695-b8374664e948","7035f5e4-f992-4ff0-a3e8-a0dfcefdc6f1","f2671a19-40f7-4e61-b141-67fe8174120d",
&          "0b38c1de-6f43-4b8d-a5cd-fdf75c474631", "0c38b830-5a72-4a9c-8d02-e16560f5ed1f","82705937-622f-4b60-a20e-a39e1daae19e","2bf5dd77-c133-4045-8a8c-36a553e3edca",
&          "8c018b63-fe0d-4d9d-9fe8-d204ccf7a4b2","ed203ec2-30b8-45f6-915e-5cf2447b429a","808287ca-c77b-4bcf-9fb8-466facfd1bc2","1c5fc9e2-e944-4844-ae0e-5dbb0e67b6df",
&          "5beae9db-9945-48c2-99e9-47841cb17bd5": # 29 existing UUIDs
 UUIDS(I)=toUuid(STRING)
 I+=1
Next

# 3 facilities
I=1
For STRING="TOR","SOP","SIT"
 [L]FCY(I)=STRING
 I+=1
Next

$NEXTVAL
  NEXTC+=1 : If NEXTC>maxtab(COUNTRIES) : NEXTC=1 : Endif
  NEXTI+=1 : If NEXTI>maxtab(CURRENCY) : NEXTI=1 : Endif
  NEXTA+=1 : If NEXTA>maxtab(ACTIV) : NEXTA=1 : Endif
  NEXTU+=1 : If NEXTU>maxtab(UUIDS) : NEXTU=1 : Endif
  NEXTX+=1 : If NEXTX>maxtab(ACCESS) : NEXTX=1 : Endif
  NEXTS+=1 : If NEXTS>maxtab(UOM) : NEXTS=1 : Endif
  NEXTF+=1 : If NEXTF>maxtab([L]FCY) : NEXTF=1 : Endif
Return

