#<AdxTL>@(#)3.0.0.0 $Revision$
#------------------------------------------------------------#
# DOSDICATY   Filling the dictionary of data types
#------------------------------------------------------------#

$DICATY
Call ECR_TIME(mess(15,125,1)-mess(19,125,1)) From DOSSUB
# MAJ dictionnaire - Types de données

Local File =GDOSREF+".ATYPE"             [ATY]
&         ,=GDOSREF+".ATYPERUL"          [ATYR]
&         ,=GDOSREF+".ATYPERPAR"         [ATYRP]
&         ,=GDOSREF+".ATYPELNK"          [ATYL]
&         ,=GDOSREF+".ATYPELPAR"         [ATYLP]
Local File =[F:ADS]DOSSIER+".ATYPE"      [DATY]
&         ,=[F:ADS]DOSSIER+".ATYPE"      [DATY2]
&         ,=[F:ADS]DOSSIER+".ATYPERUL"   [DATYR]
&         ,=[F:ADS]DOSSIER+".ATYPERPAR"  [DATYRP]
&         ,=[F:ADS]DOSSIER+".ATYPELNK"   [DATYL]
&         ,=[F:ADS]DOSSIER+".ATYPELPAR"  [DATYLP]
&         ,=[F:ADS]DOSSIER+".ACTIV"      [DACV]

Local Integer B
If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(19,125,1),"") From GESECRAN
Endif

GNBATY = 0

## Deleting old data types

If !GCRE
 Trbegin [DATY], [DATYR], [DATYRP], [DATYL], [DATYLP]
  For [DATY]CODTYP Where CODTYP<GXX
   Call SPEC([F:DATY]CODACT,SPEC) From DOSSUB
   If !SPEC
    Read [ATY]CODTYP = [F:DATY]CODTYP
    If fstat
     Call EFFACE([F:DATY]CODTYP)
    Endif
   Endif
  Next
 Commit
Endif

## Update of data types

Filter [ATY] Where CODTYP<GXX
Read [ATY]CODTYP First
While fstat<=2
 If GINFO
  Call AFF_VLC(mess(15,125,1)-mess(19,125,1),[F:ATY]CODTYP) From GESECRAN
 Endif
 ACTIV = 0
 Trbegin [DATY], [DATYR], [DATYRP], [DATYL], [DATYLP]
  OLD  = 0
  SPEC = 0
  RWO  = 0
  Read [DATY]CODTYP = [F:ATY]CODTYP
  If !fstat
   OLD = 1
   Call SPEC([F:DATY]CODACT,SPEC) From DOSSUB
  Endif
  Call NEWREC([F:ADS]DOSSIER,[F:ATY]CODACT,[F:ATY]MODULE,NEWREC) From DOSSUB
  If !SPEC

   If OLD & !NEWREC

    Call EFFACE([F:ATY]CODTYP)

   Elsif NEWREC & !OLD

    Raz [F:DATY]
    RWO = 1
    [F:DATY] = [F:ATY]
    If dim([F:DATY]CREDAT)>0 : [F:DATY]CREDAT = date$ : Endif
    [F:DATY]CREUSR = GUSER
    GNBATY += 1
    Write [DATY]
    If fstat : Call ERREUR("ATYPE"-[F:DATY]CODTYP,1) From DOSDIC : Endif
    #
    For [ATYR]ATYR0 Where CODTYP=[F:ATY]CODTYP
     [F:DATYR] = [F:ATYR]
     Write [DATYR]
     If fstat : Call ERREUR("ATYPERUL"-[F:DATYR]CODTYP-num$([F:DATYR]TYPRUL)-[F:DATYR]TRTRUL-[F:DATYR]PRGRUL,1) From DOSDIC : Endif
    Next
    For [ATYRP]ATYRP0 Where CODTYP=[F:ATY]CODTYP
     [F:DATYRP] = [F:ATYRP]
     Write [DATYRP]
     If fstat : Call ERREUR("ATYPERPAR"-[F:DATYRP]CODTYP-num$([F:DATYRP]TYPRUL)-[F:DATYRP]TRTRUL-[F:DATYRP]PRGRUL-[F:DATYRP]PARCOD,1) From DOSDIC : Endif
    Next

   Elsif NEWREC & OLD

    DIFF = 0

    ## Compare the header

    If dim([F:ATY]FLGPRO)>0  &  dim([F:DATY]FLGPRO)>0  &  [F:ATY]FLGPRO <> [F:DATY]FLGPRO    : DIFF = 1 : Endif
    If [F:ATY]CODACT      <>  [F:DATY]CODACT      : DIFF = 1 : Endif
    If [F:ATY]CODTYP      <>  [F:DATY]CODTYP      : DIFF = 1 : Endif
    If [F:ATY]FICLIEN     <>  [F:DATY]FICLIEN     : DIFF = 1 : Endif
    If [F:ATY]FORTYP      <>  [F:DATY]FORTYP      : DIFF = 1 : Endif
    If [F:ATY]INTITTYP    <>  [F:DATY]INTITTYP    : DIFF = 1 : Endif
    If [F:ATY]LNGTYP      <>  [F:DATY]LNGTYP      : DIFF = 1 : Endif
    If [F:ATY]NOLIB       <>  [F:DATY]NOLIB       : DIFF = 1 : Endif
    If [F:ATY]OBJLIEN     <>  [F:DATY]OBJLIEN     : DIFF = 1 : Endif
    If [F:ATY]OPTION      <>  [F:DATY]OPTION      : DIFF = 1 : Endif
    If [F:ATY]TYPTYP      <>  [F:DATY]TYPTYP      : DIFF = 1 : Endif
    If [F:ATY]VALDEF      <>  [F:DATY]VALDEF      : DIFF = 1 : Endif
    If [F:ATY]OPTTAB      <>  [F:DATY]OPTTAB      : DIFF = 1 : Endif
    If [F:ATY]PARTAB      <>  [F:DATY]PARTAB      : DIFF = 1 : Endif
    If [F:ATY]VARTAB      <>  [F:DATY]VARTAB      : DIFF = 1 : Endif
    If [F:ATY]MODULE      <>  [F:DATY]MODULE      : DIFF = 1 : Endif
    If [F:ATY]TYPSELSYR   <>  [F:DATY]TYPSELSYR   : DIFF = 1 : Endif
    If [F:ATY]TYPPROSYR   <>  [F:DATY]TYPPROSYR   : DIFF = 1 : Endif
    If [F:ATY]FMTPROSYR   <>  [F:DATY]FMTPROSYR   : DIFF = 1 : Endif
    If [F:ATY]SUPFLG      <>  [F:DATY]SUPFLG      : DIFF = 1 : Endif
    If [F:ATY]CODCLA      <>  [F:DATY]CODCLA      : DIFF = 1 : Endif
    If [F:ATY]DEFREPDES   <>  [F:DATY]DEFREPDES   : DIFF = 1 : Endif
    If [F:ATY]DEFREPMOB   <>  [F:DATY]DEFREPMOB   : DIFF = 1 : Endif
    If [F:ATY]DEFREPTAB   <>  [F:DATY]DEFREPTAB   : DIFF = 1 : Endif

    If [F:ATY]NBTYP       <>  [F:DATY]NBTYP       : DIFF = 1 : Endif

    If !DIFF : Call TXT([F:ATY]INTITTYP,DIFF) From DOSSUB : Endif

    ## Comparison of actions
    If !DIFF
     For B=0 To [F:ATY]NBTYP-1
        If [F:ATY]ACTION(B)      <>  [F:DATY]ACTION(B)      : DIFF = 1 : Endif
        If [F:ATY]ACTTYP(B)      <>  [F:DATY]ACTTYP(B)      : DIFF = 1 : Endif
        If [F:ATY]EXEACT(B)      <>  [F:DATY]EXEACT(B)      : DIFF = 1 : Endif
     Next B
    Endif

    # --------------------------------#
    ## Comparison and update Rules

    For [ATYR]ATYR0 Where CODTYP=[F:ATY]CODTYP
     Read [DATYR]ATYR0 = [F:ATYR]CODTYP;[F:ATYR]TYPRUL;[F:ATYR]TRTRUL;[F:ATYR]PRGRUL

     If fstat
      DIFF = 1
      [F:DATYR] = [F:ATYR]
      Write [DATYR]
      If fstat : Call ERREUR("ATYPERUL"-[F:DATYR]CODTYP-num$([F:DATYR]TYPRUL)-[F:DATYR]TRTRUL-[F:DATYR]PRGRUL,1) From DOSDIC : Endif
      For [ATYRP]ATYRP0 Where CODTYP=[F:ATYR]CODTYP & TYPRUL=[F:ATYR]TYPRUL & TRTRUL=[F:ATYR]TRTRUL & PRGRUL=[F:ATYR]PRGRUL
       [F:DATYRP] = [F:ATYRP]
       Write [DATYRP]
       If fstat : Call ERREUR("ATYPERPAR"-[F:DATYRP]CODTYP-num$([F:DATYRP]TYPRUL)-[F:DATYRP]TRTRUL-[F:DATYRP]PRGRUL-[F:DATYRP]PARCOD,1) From DOSDIC : Endif
      Next

     Elsif !find([F:DATYR]ACTRUL,GSPE(1..GNBSPE))

      # non-specific rule, comparison

      RW = 0
      Call DIFFACT([F:ADS]DOSSIER,[F:ATYR]ACTRUL,ACTIV) From DOSSUB
      If [F:ATYR]ACTRUL   <> [F:DATYR]ACTRUL       : RW = 1 : Endif
      If [F:ATYR]ORDRUL   <> [F:DATYR]ORDRUL       : RW = 1 : Endif
      If [F:ATYR]ENARUL   <> [F:DATYR]ENARUL       : RW = 1 : Endif


      If RW
       DIFF  = 1
       [F:DATYR] = [F:ATYR]
       Rewrite [DATYR]
       If fstat : Call ERREUR("ATYPERUL"-[F:DATYR]CODTYP-num$([F:DATYR]TYPRUL)-[F:DATYR]TRTRUL-[F:DATYR]PRGRUL,2) From DOSDIC : Endif
      Endif

      # update or creation of rule parameters

      For [ATYRP]ATYRP0 Where CODTYP=[F:ATYR]CODTYP & TYPRUL=[F:ATYR]TYPRUL & TRTRUL=[F:ATYR]TRTRUL & PRGRUL=[F:ATYR]PRGRUL
       Read [DATYRP]ATYRP0 = [F:ATYRP]CODTYP;[F:ATYRP]TYPRUL;[F:ATYRP]TRTRUL;[F:ATYRP]PRGRUL;[F:ATYRP]PARCOD
       If fstat
        DIFF = 1
        [F:DATYRP] = [F:ATYRP]
        Write [DATYRP]
        If fstat : Call ERREUR("ATYPERPAR"-[F:DATYRP]CODTYP-num$([F:DATYRP]TYPRUL)-[F:DATYRP]TRTRUL-[F:DATYRP]PRGRUL-[F:DATYRP]PARCOD,1) From DOSDIC : Endif
       Else
        RW = 0
        If [F:ATYRP]PARORD   <> [F:DATYRP]PARORD   : RW = 57 : Endif
        If [F:ATYRP]PARTIT   <> [F:DATYRP]PARTIT   : RW = 57 : Endif
        If [F:ATYRP]PARTYP   <> [F:DATYRP]PARTYP   : RW = 57 : Endif
        If [F:ATYRP]PARCLA   <> [F:DATYRP]PARCLA   : RW = 57 : Endif
        If [F:ATYRP]PARDIM   <> [F:DATYRP]PARDIM   : RW = 57 : Endif
        If [F:ATYRP]PARMOD   <> [F:DATYRP]PARMOD   : RW = 57 : Endif
        If [F:ATYRP]PARCLE   <> [F:DATYRP]PARCLE   : RW = 57 : Endif

        If !RW : Call TXT([F:ATYRP]PARTIT,RW) From DOSSUB : Endif

        If RW
         DIFF = RW
         [F:DATYRP] = [F:ATYRP]
         Rewrite [DATYRP]
         If fstat : Call ERREUR("ATYPERPAR"-[F:DATYRP]CODTYP-num$([F:DATYRP]TYPRUL)-[F:DATYRP]TRTRUL-[F:DATYRP]PRGRUL-[F:DATYRP]PARCOD,2) From DOSDIC : Endif
        Endif
       Endif
      Next ATYRP

      # removal of excess rule parameters

      For [DATYRP]ATYRP0 Where CODTYP=[F:ATYR]CODTYP & TYPRUL=[F:ATYR]TYPRUL & TRTRUL=[F:ATYR]TRTRUL & PRGRUL=[F:ATYR]PRGRUL
       Read [ATYRP]ATYRP0 = [F:DATYRP]CODTYP;[F:DATYRP]TYPRUL;[F:DATYRP]TRTRUL;[F:DATYRP]PRGRUL;[F:DATYRP]PARCOD
       If fstat
        DIFF = 1
        Delete [DATYRP]
        If fstat=1 : Call ERREUR("ATYPERPAR"-[F:DATYRP]CODTYP-num$([F:DATYRP]TYPRUL)-[F:DATYRP]TRTRUL-[F:DATYRP]PRGRUL-[F:DATYRP]PARCOD,3) From DOSDIC : Endif
       Endif
      Next DATYRP

     Endif
    Next ATYR

    # removal of excess rules

    For [DATYR]ATYR0 Where CODTYP=[F:ATY]CODTYP
     If !find([F:DATYR]ACTRUL,GSPE(1..GNBSPE))
      Read [ATYR]ATYR0 = [F:DATYR]CODTYP;[F:DATYR]TYPRUL;[F:DATYR]TRTRUL;[F:DATYR]PRGRUL
      If fstat
       DIFF = 1
       Delete [DATYRP] Where CODTYP=[F:DATYR]CODTYP & TYPRUL=[F:DATYR]TYPRUL & TRTRUL=[F:DATYR]TRTRUL & PRGRUL=[F:DATYR]PRGRUL
       If fstat=1 : Call ERREUR("ATYPERPAR"-[F:DATYR]CODTYP-num$([F:DATYR]TYPRUL)-[F:DATYR]TRTRUL-[F:DATYR]PRGRUL,3) From DOSDIC : Endif
       Delete [DATYR]
       If fstat=1 : Call ERREUR("ATYPERUL"-[F:DATYR]CODTYP-num$([F:DATYR]TYPRUL)-[F:DATYR]TRTRUL-[F:DATYR]PRGRUL,3) From DOSDIC : Endif
      Endif
     Endif
    Next DATYR


    #########################
    # Update header
    #########################
    If DIFF
     If GTSTDOS
      Call ECR_TRACE("Diff"-mess(19,125,1)-[F:ATY]CODTYP-num$(DIFF),0) From GESECRAN
     Endif
     RWO = 1
     [F:DATY2] = [F:DATY]
     [F:DATY] = [F:ATY]

     GNBATY += 1
     If dim([F:DATY]UPDDAT)>0 : [F:DATY]UPDDAT = date$ : Endif
     [F:DATY]UPDUSR = GUSER
     Rewrite [DATY]
     If fstat : Call ERREUR("ATYPE"-[F:DATY]CODTYP,2) From DOSDIC : Endif

    Elsif ACTIV : # Change of activity code

     RWO = 1
     If dim([F:DATY]UPDDAT)>0 : [F:DATY]UPDDAT = date$ : Endif
     [F:DATY]UPDUSR = GUSER
     GNBATY += 1
     Rewrite [DATY]
     If fstat : Call ERREUR("ATYPE"-[F:DATY]CODTYP,2) From DOSDIC : Endif

    Endif

   Endif : # (new & old)
  Endif : # (spec)

 Commit

 Read [ATY]CODTYP Next
Wend

Close Local File [DATY], [DATY2], [DATYR], [DATYRP], [DATYL], [DATYLP]
Close Local File [DACV]
Close Local File [ATY], [ATYR], [ATYRP], [ATYL], [ATYLP]

Return

## Deleting a data type
#-----------------------------------#
Subprog EFFACE(WCODTYP)
Value Char WCODTYP
Call ECR_TRACE(mess(264,125,1)-WCODTYP,0) From GESECRAN  : # Suppression type de données

Delete [DATY] Where CODTYP=WCODTYP
If fstat=1 : Call ERREUR("ATYPE"-WCODTYP,3) From DOSDIC : Endif
Delete [DATYR] Where CODTYP=WCODTYP
If fstat=1 : Call ERREUR("ATYPERUL"-WCODTYP,3) From DOSDIC : Endif
Delete [DATYRP] Where CODTYP=WCODTYP
If fstat=1 : Call ERREUR("ATYPERPAR"-WCODTYP,3) From DOSDIC : Endif
Delete [DATYL] Where CODTYP=WCODTYP
If fstat=1 : Call ERREUR("ATYPELNK"-WCODTYP,3) From DOSDIC : Endif
Delete [DATYLP] Where CODTYP=WCODTYP
If fstat=1 : Call ERREUR("ATYPELPAR"-WCODTYP,3) From DOSDIC : Endif
End
