# WMACONTEXTTRC_CSTD
# 2018-11-09 07:11:50 095

$PROPERTIES
Case ACTION
 When "GET" : Gosub GET
 When Default
Endcase
Return

$EVENTS
Case AEVENT
 When "AINIT" : Gosub AINIT
 When Default
Endcase
Return

$METHODS
Case [L]AMETHOD
 When Default
Endcase
Return


#------------------------------------------------------------------------------#
$AINIT
Local Char    PARAM(250)
Local Integer RES
this.isReadonly = 0
RES = fmet this.ASETATTRIBUTE("WRKRMTDIR","STA","0")
RES = fmet this.ASETATTRIBUTE("WRKRMTMAC","STA","0")
this.isReadonly = 1
Return

#------------------------------------------------------------------------------#
$GET
Local Char    PARAM(250)
Case CURPRO
When "WRKRMTDIR" : Gosub GET_WRKRMTDIR
When "WRKRMTMAC" : Gosub GET_WRKRMTMAC
Endcase
Return

##############################################################################
# GET for different properties
##############################################################################

#WRKRMTDIR : Workflow links directory
$GET_WRKRMTDIR
Local Char    PARAM(250)
If Fmet THIS.AGETATTRIBUTE("WRKRMTDIR","STA")<>"1"
 this.isReadonly = 0
 Gosub INIT_WRKRMTDIR
 this.isReadonly = 1
 Local Integer RES : RES = Fmet THIS.ASETATTRIBUTE("WRKRMTDIR","STA","1")
Endif
Return

#WRKRMTMAC : Machine:Workflow links port
$GET_WRKRMTMAC
Local Char    PARAM(250)
If Fmet THIS.AGETATTRIBUTE("WRKRMTMAC","STA")<>"1"
 this.isReadonly = 0
 Gosub INIT_WRKRMTMAC
 this.isReadonly = 1
 Local Integer RES : RES = Fmet THIS.ASETATTRIBUTE("WRKRMTMAC","STA","1")
Endif
Return

##############################################################################
# INIT for different properties
##############################################################################

#WRKRMTDIR : Workflow links directory
$INIT_WRKRMTDIR
PARAM = func ADP_TOOL.GET_PARAM(this.APARENT.AFOLDER,1,"","WRKRMTDIR")
this.WRKRMTDIR = PARAM
Return

#WRKRMTMAC : Machine:Workflow links port
$INIT_WRKRMTMAC
PARAM = func ADP_TOOL.GET_PARAM(this.APARENT.AFOLDER,1,"","WRKRMTMAC")
this.WRKRMTMAC = PARAM
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

