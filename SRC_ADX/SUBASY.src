#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion objet ASY
# 97002 25 02 2014

Raz GPILOBJ,GNBMASKOUV
Call OBJET("ASY",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "SETBOUT"   : Gosub SETBOUT
 When "FERME"     : Gosub FERME
 When "INICRE"    : Gosub INICRE
 When "LIENS2"    : Gosub LIENS2
 When "APRES_MOD" : Gosub APRES_MOD
 When "APRES_CRE" : Gosub APRES_CRE
 When "AP_ANNULE" : Gosub AP_ANNULE
 When "VERIF_MOD" : Gosub VERIF_MOD
Endcase
Return

$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Endif
Return

$OUVRE
If clalev([F:AYP])=0 : Local File ASTYLEP [AYP] : Endif
If clalev([F:AY2])=0 : Local File ASTYLEP [AY2] : Endif
Local Char PARAM(GLONADP) , CHAINE(80)
## Styles par défaut et non pas ceux de l'utilisateur
If !GSERVEUR
 Callui CHAINE="" With "UIAction="+chr$(1)+"SessionSettings", "ADXStyleFile="+chr$(1)+"STX_DEFAULT"
Endif
# Pour SCM
Local Integer ATAB_NB,ATAB_I
Local Char    ATAB_CODPAR(GLONAAR)(1..)
Local Char    ATAB_TYPTRA(10)(1..)
Return

$FERME
## On restaure les styles de l'utilisateur
Call PARAMUTIL("STYLE",PARAM,"","") From SUBAUS
If PARAM<>"" & !GSERVEUR
 Callui CHAINE="" With "UIAction="+chr$(1)+"SessionSettings", "ADXStyleFile="+chr$(1)+"STX_"+PARAM
Endif
Return

$INICRE
[F:ASY]LIG = nolign
Return

$LIENS2
Sorta [M]NBLIG [M]NBLIG Order By [M]LIG(indice)
For I=0 To [M]NBLIG-1
 Call TEXTE([M]DES(I),[M]ADES(I)) From OBJDIV
 Call TEXTE([M]SHO(I),[M]ASHO(I)) From OBJDIV
Next I
Gosub STYLES
Return

$STYLES
Chgstl [M]ADES With ""
For I=0 To [M]NBLIG-1
 Chgstl [M]ADES(I) With [M]COD(I)
 Affzo ADES(I)
Next I
Return

$AP_ANNULE
Call GENSTYLE(APPLI,"DEFAULT")
Return

$APRES_MOD
$APRES_CRE
Local Char    STPERSO(GLONAYP)
Local Integer J , K , FLGEN
Call DEBTRANS From GLOCK
Gosub TR1
Call GENERE(nomap)
If !GSERVEUR
 Callui CHAINE="" With "UIAction="+chr$(1)+"SessionSettings", "ADXStyleFile="+chr$(1)+"STX_DEFAULT"
Endif
Gosub STYLES
For ATAB_I=1 To [L]ATAB_NB
 Call TRACE_COR(ABREV,[L]ATAB_CODPAR([L]ATAB_I),"", [L]ATAB_TYPTRA([L]ATAB_I)) From GOBJET
Next
Return

$VERIF_MOD
Raz [L]ATAB_NB,ATAB_CODPAR,ATAB_TYPTRA
For I=0 To [M]NBLIG-1
 Read [ASY]ASY0 = [M]COD(I)
 If fstat
  [M]MODIF(I) = 2
 Elsif [F:ASY]STY<>[M]STY(I) or [F:ASY]DES<>[M]DES(I) or [F:ASY]SHO<>[M]SHO(I)
  [M]MODIF(I) = 1
 Else
  [M]MODIF(I) = 0
 Endif
Next I
If GADONIX=2
 For I=0 To [M]NBLIG-1
  Read [ASY]ASY0 = [M]COD(I)
  If fstat
   #Call TRACE_COR(ABREV,[M]COD(I),"","C") From GOBJET
   [L]ATAB_NB +=1
   [L]ATAB_CODPAR([L]ATAB_NB) = [M]COD(I)
   [L]ATAB_TYPTRA([L]ATAB_NB) = "C"
  Endif
 Next I
 For [ASY]
  I = find([F:ASY]COD,[M]COD(0..[M]NBLIG-1))
  If I=0
   #Call TRACE_COR(ABREV,[F:ASY]COD,"","A") From GOBJET
   [L]ATAB_NB +=1
   [L]ATAB_CODPAR([L]ATAB_NB) = [F:ASY]COD
   [L]ATAB_TYPTRA([L]ATAB_NB) = "A"
  Elsif [F:ASY]STY<>[M]STY(I-1) or [F:ASY]DES<>[M]DES(I-1) or [F:ASY]SHO<>[M]SHO(I-1)
   #Call TRACE_COR(ABREV,[F:ASY]COD,"","m") From GOBJET
   [L]ATAB_NB +=1
   [L]ATAB_CODPAR([L]ATAB_NB) = [F:ASY]COD
   [L]ATAB_TYPTRA([L]ATAB_NB) = "m"
  Endif
 Next
Endif
Return

$TR1
GOK = 1
Trbegin [AY2]
 For [AY2]AYP0(1)
  STPERSO = [F:AY2]CAT
  Raz [M]FLG
  J = 0
  FLGEN = 0
  For [AY2]AYP0
   J = max(J,[F:AY2]LIG)
   K = find([F:AY2]COD,[M]COD(0..[M]NBLIG-1))
   If K
    [M]FLG(K-1) = 1
   Else
    FLGEN = 1
    Delete [AY2]
    If fstat=1
     GOK = -1 : GLOCK = "$ASTYLEP"-[F:AY2]CAT-[F:AY2]COD : Break 2
    Endif
   Endif
  Next
  For K=0 To [M]NBLIG-1
   If [M]FLG(K)=0
    FLGEN = 1
    J += 1
    [F:AY2]CAT = STPERSO
    [F:AY2]LIG = J
    [F:AY2]COD = [M]COD(K)
    [F:AY2]STY = [M]STY(K)
    [F:AY2]CREDAT = date$
    If dim([F:AY2]CRETIM)>0 : [F:AY2]CRETIM = time : Endif
    [F:AY2]CREUSR = GUSER
    Write [AY2]
    If fstat
     GOK = 0 : Call FSTA("AY2") From GLOCK : Break 2
    Endif
   Endif
  Next K
  If FLGEN
   Call GENSTYLE(nomap,STPERSO)
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Endif

#########################################################
Subprog PATCH(APPLI)
Value Char APPLI
Call GENDOS(APPLI)
End

#########################################################
Subprog GENERE(APPLI)
Value Char APPLI
Call GENSTYLE(APPLI,"DEFAULT")
End

#########################################################
Subprog GENDOS(APPLI)
Value Char APPLI
Local File =APPLI+".ASTYLE"  [ASY]
Local File =APPLI+".ASTYLEP" [AYP]
Local File =APPLI+".ASTYLEP" [AYY]
Call ECR_TRACE(mess(123,125,1)-"DEFAULT",0) From GESECRAN : # Création du fichier de style
Call GENSTYLE(APPLI,"DEFAULT")
For [AYY]AYP0(1)
 # Création du fichier de style/sur le dossier
 Call ECR_TRACE(mess(123,125,1)-[F:AYY]CAT-mess(178,126,1)-APPLI,0) From GESECRAN
 Call GENSTYLE(APPLI,[F:AYY]CAT)
Next
End

#########################################################
Subprog GENSTYLE(DOSSIER,NAME)
Value Char DOSSIER
Value Char NAME

Local Char    FICSTL(250) , REPSTL(250) , TIMESTAMP(30) , VERSION(30), FICSTLSJON(250)
Local Integer K , STAT , ER
Local Char    APPLI(GLONADS) , MACHINE(GDIMFIC) , VOLUME(80)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

If clalev([F:ASY])=0 : Local File =DOSSIER+".ASTYLE"  [ASY] : Endif
If clalev([F:AYP])=0 : Local File =DOSSIER+".ASTYLEP" [AYP] : Endif

VERSION   = "2,2004001"
TIMESTAMP = format$("YYYYMMDD",date$)+left$(time$,2)+mid$(time$,4,2)+mid$(time$,7,2)

REPSTL = filpath(APPLI+"/GEN/ALL/STY","","","X3_PUB","",MACHINE)
If filinfo(REPSTL,0)<0
 Call SYSTEME(MACHINE,"ae_mkdir"-REPSTL,"",STAT) From ORDSYS
Endif
FICSTL = filpath(APPLI+"/GEN/ALL/STY","STX_"+NAME,"xml","X3_PUB","",MACHINE)
FICSTLSJON = filpath(APPLI+"/GEN/ALL/STY","STX_"+NAME,"json","X3_PUB","",MACHINE)
Onerrgo ERROPEN
ER = 0
Openo FICSTL,0 Using [AXML]
Openo FICSTLSJON ,0 Using [AJSO]
Onerrgo
If ER : End : Endif
Iomode adxifs "" Using [AXML]
Iomode adxirs chr$(10) Using [AXML]
Iomode adxium GUTF8 Using [AXML]
Iomode adxifs "" Using [AJSO]
Iomode adxirs chr$(10) Using [AJSO]
Iomode adxium GUTF8 Using [AJSO]
Wrseq '<?xml version="1.0" encoding="utf-8" standalone="yes" ?>' Using [AXML]
Wrseq '{ "$name": "'+NAME+'",' Using [AJSO]

Wrseq '<SHEET NAME="STX_'+NAME+'" TIM="'+TIMESTAMP+'" VER="'+VERSION+'">' Using [AXML]
Wrseq '"$stamp": "'+TIMESTAMP+'",' Using [AJSO]
Wrseq '"$vers": "'+VERSION+'",' Using [AJSO]
Wrseq '"$styles": {' Using [AJSO]

If NAME="DEFAULT"
 For [ASY]ASY0
  K += 1
  Wrseq '<STX ID="'+format$("N0:3#",K)+'" NAME="'+[F:ASY]COD+'"'; Using [AXML]
  Wrseq ' CSS="'+[F:ASY]STY+'"/>' Using [AXML]
  If K>1 : Wrseq '},' Using [AJSO] : Endif
  Wrseq '"'+[F:ASY]COD+'": {' Using [AJSO]
  Wrseq '"id": '+num$(K)+',' Using [AJSO]
  Wrseq '"$css": "'+[F:ASY]STY+'"' Using [AJSO]
 Next
Else
 For [AYP]AYP0 Where CAT=NAME
  K += 1
  Wrseq '<STX ID="'+format$("N0:3#",K)+'" NAME="'+[F:AYP]COD+'"'; Using [AXML]
  Wrseq ' CSS="'+[F:AYP]STY+'"/>' Using [AXML]
  If K>1 : Wrseq '},' Using [AJSO] : Endif
  Wrseq '"'+[F:AYP]COD+'": {' Using [AJSO]
  Wrseq '"id": '+num$(K)+',' Using [AJSO]
  Wrseq '"$css": "'+[F:AYP]STY+'"' Using [AJSO]
 Next
Endif
Wrseq '</SHEET>' Using [AXML]
If K>0 : Wrseq '}' Using [AJSO] : Endif
Wrseq '}}' Using [AJSO]

Openo Using [AXML]
Openo Using [AJSO]
End

$ERROPEN
Call ECR_TRACE(mess(12,100,1)+"\|"+FICSTL+"|",1) From GESECRAN : # Erreur d'accès sur le fichier
ER = 1
Resume

#########################################################
Subprog ANUSTYLE(DOSSIER,NAME)
Value Char    DOSSIER
Value Char    NAME
Local Char    FICSTL(250)
Local Integer STAT
Local Char    APPLI(GLONADS) , MACHINE(GDIMFIC)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

FICSTL = filpath(APPLI+"/GEN/ALL/STY","STX_"+NAME,"xml","X3_PUB","",MACHINE)
If filinfo(FICSTL,0)>0
 Call EFFACE(FICSTL,STAT) From ORDSYS
Endif
End

#########################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File ASTYLE  [ASY1]
 Local File ATEXTE   [ATX1]
Else
 Local File =[M]DOSORG+".ASTYLE"  [ASY1]
 Local File =[M]DOSORG+".ATEXTE"  [ATX1]
Endif
If [M]DOSDES=nomap
 Local File ASTYLE  [ASY2]
 Local File ATEXTE  [ATX2]
Else
 Local File =[M]DOSDES+".ASTYLE"  [ASY2]
 Local File =[M]DOSDES+".ATEXTE"  [ATX2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ASY1], [ATX1], [ASY2], [ATX2]
Call GENERE([M]DOSDES)
Return

$TR_COP
GOK = 1
Local Integer NUMERO
Trbegin [ASY2] , [ATX2]
 If TABLE<>""
  Read [ASY1]ASY0=TABLE
  If !fstat
   Read [ASY2]ASY0=TABLE
   If !fstat
    NUMERO = [F:ASY2]LIG
    [F:ASY2] = [F:ASY1]
    [F:ASY2]LIG = NUMERO
    Call COPTEXTE([F:ASY1]DES,[F:ASY2]DES) From OBJDIV
    If GOK<1 : Goto AB_TR_COP : Endif
    Call COPTEXTE([F:ASY1]SHO,[F:ASY2]SHO) From OBJDIV
    If GOK<1 : Goto AB_TR_COP : Endif
    If dim([F:ASY2]UPDUSR)>0 : [F:ASY2]UPDUSR = GUSER : Endif
    If dim([F:ASY2]UPDDAT)>0 : [F:ASY2]UPDDAT = date$ : Endif
    If dim([F:ASY2]UPDTIM)>0 : [F:ASY2]UPDTIM = time : Endif
    Rewrite [ASY2]
    If fstat
     GOK=0 : Call FSTA("ASY2") From GLOCK : Goto AB_TR_COP
    Endif
   Else
    NUMERO = 0
    For [ASY2]ASY0
     NUMERO = max(NUMERO,[F:ASY2]LIG)
    Next ASY2
    NUMERO += 1
    [F:ASY2] = [F:ASY1]
    [F:ASY2]LIG = NUMERO
    Call COPTEXTE([F:ASY1]DES,[F:ASY2]DES) From OBJDIV
    If GOK<1 : Goto AB_TR_COP : Endif
    Call COPTEXTE([F:ASY1]SHO,[F:ASY2]SHO) From OBJDIV
    If GOK<1 : Goto AB_TR_COP : Endif
    If dim([F:ASY2]CREUSR)>0 : [F:ASY2]CREUSR = GUSER : Endif
    If dim([F:ASY2]CREDAT)>0 : [F:ASY2]CREDAT = date$ : Endif
    If dim([F:ASY2]CRETIM)>0 : [F:ASY2]CRETIM = time : Endif
    Write [ASY2]
    If fstat
     GOK=0 : Call FSTA("ASY2") From GLOCK : Goto AB_TR_COP
    Endif
   Endif
  Endif
 Else
  Delete [ASY2] Where 1=1
  If fstat=1
   GOK=-1 : GLOCK = "$"+[M]DOSDES+".ASTYLE" : Goto ROLL_TR_COP
  Elsif fstat>5
   GOK = 0 : Call RSTA("ASY2","") From GLOCK : Goto AB_TR_COP
  Endif
  For [ASY1]ASY0
   [F:ASY2] = [F:ASY1]
   Call COPTEXTE([F:ASY1]DES,[F:ASY2]DES) From OBJDIV
   If GOK<1 : Break : Endif
   Call COPTEXTE([F:ASY1]SHO,[F:ASY2]SHO) From OBJDIV
   If GOK<1 : Break : Endif
   If dim([F:ASY2]UPDUSR)>0 : [F:ASY2]UPDUSR = GUSER : Endif
   If dim([F:ASY2]UPDDAT)>0 : [F:ASY2]UPDDAT = date$ : Endif
   If dim([F:ASY2]UPDTIM)>0 : [F:ASY2]UPDTIM = time : Endif
   Write [ASY2]
   If fstat
    GOK=0 : Call FSTA("ASY2") From GLOCK : Break
   Endif
  Next
  If   GOK<0 : Goto ROLL_TR_COP
  Elsif !GOK : Goto AB_TR_COP
  Endif
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

##########################################################################
## Ecran ASY1
##########################################################################
Subprog C_COD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]COD) From OBJDIV
End

Subprog AVANT_NBLIG
End

