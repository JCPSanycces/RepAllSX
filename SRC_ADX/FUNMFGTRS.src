#<AdxTL>@(#)2.0.0.0 $Revision$
##############################################################################
# FUNMFGTRS : Contient                                          LLC 29/04/99 #
#     - Le S/P de validation des transactions de saisie de la GPAO           #
#     - Le traitement permettant de lancer manuellemnt le S/P de validation  #
##############################################################################
Local Integer OK
Local File    MFGTRS   [MTS]
Local File    BENCHTRS [BTS]
Local Mask    MFGTRS [DIA] : Raz [M:DIA]
Call DIALWIN(OK,mess(100,196,1),"IMFGTRS") From GESECRAN
If OK=2 
   Call OUVRE_TRACE(mess(100,196,1)-[M]LIB-[M]MTSNUM) From LECFIC
   Call VAL_MFGTRS([M]MTSTYP,[M]MTSNUM,nomap)
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE   From LECFIC   
Endif
Close Local File [MTS]
Close Local File [BTS]
Close Local Mask [DIA]
End

#-------------------------------------------#
# Actions sur champ de l'écran MFGTRS [DIA] #
#-------------------------------------------#
Subprog AV_LIB(VALEUR)
Variable Char    VALEUR()
If find([M]MTSTYP,1,2)  
    VALEUR=mess([M]MTSTYP,353,1)
Elsif [M]MTSTYP  > 59           
    If [M]MTSTYP = 90
            VALEUR=mess(8,753,1) 
    Else
        VALEUR=mess([M]MTSTYP-56,753,1) 
    Endif
Else 
    VALEUR=mess(19,197,1) 
Endif
End

Subprog AV_MTSDES(VALEUR)
Variable Char    VALEUR()
If [M]MTSNUM<>"" 
   If  find([M]MTSTYP,1,2) 
       Read [MTS]MTS0=[M]MTSTYP;[M]MTSNUM 
       If fstat : Raz [F:MTS] : Endif
      VALEUR=[F:MTS]MTSDES
   Else
       Read [BTS]BTS0=[M]MTSTYP;[M]MTSNUM 
       If fstat : Raz [F:BTS] : Endif
       VALEUR=[F:BTS]BTSDES
       End
   Endif
Endif
End

##############################################################################
#    Programme appelé par DOSWWW                                             #
##############################################################################
Subprog GENDOS (TYP, APPLI)
Value Integer  TYP
Value Char APPLI
Local Char    ECRAN(GLONAMK)
Local Integer I
Local Integer TOK(1..50)
Local Char    TABFEN(GLONFEN)(0..1), TABECR(GLONAMK)(0..10)

If clalev([F:MTS])<=0 Local File =APPLI+".MFGTRS"    [MTS] : Endif
If clalev([F:BTS])<=0 Local File =APPLI+".BENCHTRS"  [BTS] : Endif
Local File =APPLI+".AWINDOW"    [AWI] : # Déjà ouvert en local, le réouvrir !
Local File =APPLI+".AWINPAR"    [AWP] : # Déjà ouvert en local, le réouvrir !
Local File =APPLI+".AWINBRO"    [AWB] : # Déjà ouvert en local, le réouvrir !
Local File =APPLI+".AWINBOUT"   [AWT] : # Déjà ouvert en local, le réouvrir !
#If clalev([F:AMK])<=0 : Local File =APPLI+".AMSK"      [AMK] : Endif
#If clalev([F:AMZ])<=0 : Local File =APPLI+".AMSKZON"   [AMZ] : Endif
#If clalev([F:AMA])<=0 : Local File =APPLI+".AMSKACT"   [AMA] : Endif
#If clalev([F:AMP])<=0 : Local File =APPLI+".AMSKPAR"   [AMP] : Endif
#If clalev([F:ATY])<=0 : Local File =APPLI+".ATYPE"     [ATY] : Endif
#If clalev([F:ACT])<=0 : Local File =APPLI+".ACTION"    [ACT] : Endif
#If clalev([F:ATR])<=0 : Local File =APPLI+".ACTPAR"    [ATR] : Endif
#If clalev([F:AAR])<=0 : Local File =APPLI+".ACTCODPAR" [AAR] : Endif
#If clalev([F:ATB])<=0 : Local File =APPLI+".ATABLE"    [ATB] : Endif
#If clalev([F:ATZ])<=0 : Local File =APPLI+".ATABZON"   [ATZ] : Endif
Local File =APPLI+".AMSK"      [AMK]
Local File =APPLI+".AMSKZON"   [AMZ]
Local File =APPLI+".AMSKACT"   [AMA]
Local File =APPLI+".AMSKPAR"   [AMP]
Local File =APPLI+".ATYPE"     [ATY]
Local File =APPLI+".ACTION"    [ACT]
Local File =APPLI+".ACTPAR"    [ATR]
Local File =APPLI+".ACTCODPAR" [AAR]
Local File =APPLI+".ATABLE"    [ATB]
Local File =APPLI+".ATABZON"   [ATZ]

# DéJà ouvert en local, le réouvrir !
Local File =APPLI+".ACTIV"     [ACV] 
Local File =APPLI+".AOBJET"    [AOB] 

#If clalev([F:ATX])<=0 Local File =APPLI+".ATEXTE"    [ATX] : Endif
#If clalev([F:ADV])<=0 Local File =APPLI+".ATABTAB"   [ADV] : Endif
Local File =APPLI+".ATEXTE"    [ATX]
Local File =APPLI+".ATABTAB"   [ADV]

# Si code activité MWM à non, on sort demande 36775
# FQ 50870 If TYP = 90 & !func AFNC.ACTIV("MWM") : End : Endif
If TYP = 90 & !func AFNC.ACTIVDOS(APPLI,"MWM") : End : Endif

If dim(GVALTRANS)>0 & GVALTRANS(8)=2
   If TYP < 60 : TOK(TYP) = 1 : Else : TOK(TYP - 49) = 1 : Endif
Else
   Raz TABECR
   Case TYP
       When 1 : # OF
           TABECR(0)="MFG0":TABECR(1)="MFG1":TABECR(2)="MFG2":TABECR(3)="MFG3":TABECR(4)="MFG4"
           TABFEN(0)="OMFG"
       When 2 : # Suivi
           TABECR(0)="MTK00":TABECR(1)="MTK1":TABECR(2)="MTK2":TABECR(3)="MTK3"
           TABFEN(0)="OMTK"
       When 60 : # plan suivi des temps
           TABECR(0)="MTKBENCHO"
           TABFEN(0)="IMBO"
       When 61 : # plan consommation
           TABECR(0)="MTKBENCHM"
           TABFEN(0)="IMBM"
       When 62: # plan production
           TABECR(0)="MTKBENCHI"
           TABFEN(0)="IMBI"
       When 63 : # plan réintégration
           TABECR(0)="MTKBENCHR"
           TABFEN(0)="IMBR"
       When 65 : # pilotage des plans
           TABECR(0)="MTKBENPLT"
           TABFEN(0)="IMBP"
       When 66 : # plan des fiches techniques
           TABECR(0)="MTKBENCHT"
           TABFEN(0)="IMBT"
       When 90 : # plan de pesée
           TABECR(0)="MFGWEIGH"
           TABFEN(0)="IMWG"
   Endcase
   I=0
   # hcb 41037
   While I<2 & TABFEN(I)<>""   
       Read [AWI]AWI0 = TABFEN(I)
       If fstat Raz [F:AWI] : Endif
       If TYP < 60 : TOK(TYP) = 1 : Else : TOK(TYP - 49) = 1 : Endif
       If [F:AWI]UPDFLG = 1 
          Break 
       Endif       
       I+=1
   Wend
   # 12.06 Demande 39038
   If (TYP < 60 & TOK(TYP)<>1) | (TYP >= 60 & TOK(TYP-49)<>1)
       I=0
 # hcb 41037
       While  I<10 &  TABECR(I)<>"" 
           Read [AMK]CODMSK = TABECR(I)
           If fstat Raz [F:AMK] : Endif
           If TYP < 60 : TOK(TYP) = 1 : Else : TOK(TYP - 49) = 1 : Endif
           If [F:AWI]UPDFLG = 1 
              Break 
           Endif       
           I+=1
       Wend
   Endif
Endif

If sum(TOK(1..2)) = 2 & sum(TOK(11..17)) = 6
   Call VAL_MFGTRS(0,"",APPLI)
Else
   If TOK(1) = 1 : Call VAL_MFGTRS(1,"",APPLI) : Endif
   If TOK(2) = 1 : Call VAL_MFGTRS(2,"",APPLI) : Endif
   If TOK(11) = 1 : Call VAL_MFGTRS(60,"",APPLI) : Endif
   If TOK(12) = 1 : Call VAL_MFGTRS(61,"",APPLI) : Endif
   If TOK(13) = 1 : Call VAL_MFGTRS(62,"",APPLI) : Endif
   If TOK(14) = 1 : Call VAL_MFGTRS(63,"",APPLI) : Endif
   If TOK(16) = 1 : Call VAL_MFGTRS(65,"",APPLI) : Endif
   If TOK(17) = 1 : Call VAL_MFGTRS(66,"",APPLI) : Endif
   # FQ 50870 tester le code activité du dossier cible
   If TOK(41) = 1 & func AFNC.ACTIVDOS(APPLI,"MWM") : Call VAL_MFGTRS(90,"",APPLI) : Endif
Endif

End

##############################################################################
#    Programme appelé par SUBMFL, SUBMTL, SUBMOL, SUBMIL, SUBMML, SUBMRE     #
##############################################################################
Subprog GENPATCH(TYP,APPLI)
Value Integer TYP   # FGR 14/01/2010 : X3SUIVI60986
Value Char APPLI    # FGR 14/01/2010 : X3SUIVI60986

If clalev([F:MTS])<=0 Local File =APPLI+".MFGTRS"    [MTS] : Endif
If clalev([F:BTS])<=0 Local File =APPLI+".BENCHTRS"  [BTS] : Endif
Local File =APPLI+".AWINDOW"   [AWI] : # Déjà ouvert en local, le réouvrir !
Local File =APPLI+".AWINPAR"   [AWP] : # Déjà ouvert en local, le réouvrir !
#If clalev([F:AMK])<=0 Local File =APPLI+".AMSK"      [AMK] : Endif
#If clalev([F:AMZ])<=0 Local File =APPLI+".AMSKZON"   [AMZ] : Endif
#If clalev([F:AMA])<=0 Local File =APPLI+".AMSKACT"   [AMA] : Endif
#If clalev([F:AMP])<=0 Local File =APPLI+".AMSKPAR"   [AMP] : Endif
#If clalev([F:ATY])<=0 Local File =APPLI+".ATYPE"     [ATY] : Endif
#If clalev([F:ACT])<=0 Local File =APPLI+".ACTION"    [ACT] : Endif
#If clalev([F:ATR])<=0 Local File =APPLI+".ACTPAR"    [ATR] : Endif
#If clalev([F:AAR])<=0 Local File =APPLI+".ACTCODPAR" [AAR] : Endif
#If clalev([F:ATB])<=0 Local File =APPLI+".ATABLE"    [ATB] : Endif
#If clalev([F:ATZ])<=0 Local File =APPLI+".ATABZON"   [ATZ] : Endif
#If clalev([F:ACV])<=0 Local File =APPLI+".ACTIV"     [ACV] : Endif
#If clalev([F:AOB])<=0 Local File =APPLI+".AOBJET"    [AOB] : Endif
#If clalev([F:ATX])<=0 Local File =APPLI+".ATEXTE"    [ATX] : Endif
#If clalev([F:ADV])<=0 Local File =APPLI+".ATABTAB"   [ADV] : Endif
Local File =APPLI+".AMSK"      [AMK]
Local File =APPLI+".AMSKZON"   [AMZ]
Local File =APPLI+".AMSKACT"   [AMA]
Local File =APPLI+".AMSKPAR"   [AMP]
Local File =APPLI+".ATYPE"     [ATY]
Local File =APPLI+".ACTION"    [ACT]
Local File =APPLI+".ACTPAR"    [ATR]
Local File =APPLI+".ACTCODPAR" [AAR]
Local File =APPLI+".ATABLE"    [ATB]
Local File =APPLI+".ATABZON"   [ATZ]
Local File =APPLI+".ACTIV"     [ACV]
Local File =APPLI+".AOBJET"    [AOB]
Local File =APPLI+".ATEXTE"    [ATX]
Local File =APPLI+".ATABTAB"   [ADV]

# Si code activité MWM à non, on sort demande 36775
# FQ 50870 If TYP = 90 & !func AFNC.ACTIV("MWM") : End : Endif
If TYP = 90 & !func AFNC.ACTIVDOS(APPLI,"MWM") : End : Endif

Call VAL_MFGTRS(TYP,"",APPLI) From FUNMFGTRS
End

#========================================================================================
# FGR 16/11/2009 : X3SUIVI57491 (début)
#----------------------------------------------------------------------------------------
$DYN_TRTMFGATRS
Local Char SZWIN(GLONFEN)
Local Char SZABRFIC(GLONABR)
Local Char SZONGLET(250)

  SZABRFIC = 'MTS'
  # 1
  SZWIN = 'OMFL'
  SZONGLET = '"[MFL0]","[MFL1]","[MFL2]","[MFL3]","[DST]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ1, IREQ1) From FUNSALTRS
  # 2
  SZWIN = 'OMTL'
  SZONGLET = '"[MTL0]","[MTL1]","[MTL2]","[MTL3]","[MTL4]","[ETR2]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ2, IREQ2) From FUNSALTRS
Return

#----------------------------------------------------------------------------------------
$GEN_TRTMFGATRS
Local Char SZADXIFS
Local Char SZADXIRS
Local Integer IVALIDOK
Local Integer IEXIST
Local Char SZPROGNAME(GLONADC)
Local Char SZFULLSRC(250)
Local Char SZFULLADX(250)
Local Integer NI
# 20 lignes
#  5 colonnes :
#               (0) = Complément "Close Local Mask" et "Default Mask"
#               (1) = Listes des autres Mask à ouvrir
#               (2) = Complément affectation classe [F] dans classe [M]
Local Char SZREQ1(250)(20,5)
Local Char SZREQ2(250)(20,5)
Local Integer IREQ1
Local Integer IREQ2
  #------------------------------------------
  Raz SZREQ1
  Raz SZREQ2
  IREQ1 = 0
  IREQ2 = 0
  #------------------------------------------
  Gosub DYN_TRTMFGATRS
  #------------------------------------------
  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  #------------------------------------------
  SZPROGNAME = "WMFGA" + num$(adxpid)
  SZFULLSRC = filpath("TRT", SZPROGNAME, "src", APPLI)
  SZFULLADX = filpath("TRT", SZPROGNAME, "adx", APPLI)
  #------------------------------------------
  #Ouverture du traitement à générer
  Openo SZFULLSRC, 0 Using [TRS_]
  #------------------------------------------
  #Génération du traitement
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%"  Using [TRS_]
  Wrseq "#Traitement généré pour les transactions MFG-A en masse"  Using [TRS_]
  Wrseq "$TRANSAC_MFGA"  Using [TRS_]
  Wrseq 'For [MTS] Where' - CRITERES  Using [TRS_]
  Wrseq '  If [F:MTS]MTSTYP <> WTYP'  Using [TRS_]
  Wrseq '     Case WTYP'  Using [TRS_]
  Wrseq '         When 1 : Close Local Mask [MFL0],[MFL1],[MFL2],[MFL3],[DST]' + SZREQ1(0,0)  Using [TRS_]
  Wrseq '         When 2 : Close Local Mask [MTL0],[MTL1],[MTL2],[MTL3],[MTL4],[ETR2]' + SZREQ2(0,0)  Using [TRS_]          # FQ 50600 ajout MTL4
  Wrseq '     Endcase'  Using [TRS_]
  Wrseq '     Case [F:MTS]MTSTYP'  Using [TRS_]
  Wrseq '         When 1 : If clalev ([M:MFL0])<=0 : Local Mask =APPLI+".MFL0" [MFL0] : Endif'  Using [TRS_]
  Wrseq '                  If clalev ([M:MFL1])<=0 : Local Mask =APPLI+".MFL1" [MFL1] : Endif'  Using [TRS_]
  Wrseq '                  If clalev ([M:MFL2])<=0 : Local Mask =APPLI+".MFL2" [MFL2] : Endif'  Using [TRS_]
  Wrseq '                  If clalev ([M:MFL3])<=0 : Local Mask =APPLI+".MFL3" [MFL3] : Endif'  Using [TRS_]
  Wrseq '                  If clalev ([M:DST])<=0  : Local Mask =APPLI+".DIESCRTRS3" [DST] : Endif'  Using [TRS_]
  For NI = 0 To IREQ1-1
    Wrseq '                ' + SZREQ1(NI,1)  Using [TRS_]
  Next NI
  Wrseq '        When 2 :  If clalev ([M:MTL0])<=0 : Local Mask =APPLI+".MTL0" [MTL0] : Endif'  Using [TRS_]
  Wrseq '                  If clalev ([M:MTL1])<=0 : Local Mask =APPLI+".MTL1" [MTL1] : Endif'  Using [TRS_]
  Wrseq '                  If clalev ([M:MTL2])<=0 : Local Mask =APPLI+".MTL2" [MTL2] : Endif'  Using [TRS_]
  Wrseq '                  If clalev ([M:MTL3])<=0 : Local Mask =APPLI+".MTL3" [MTL3] : Endif'  Using [TRS_]
  Wrseq '                  If clalev ([M:MTL4])<=0 : Local Mask =APPLI+".MTL4" [MTL4] : Endif'  Using [TRS_]  # FQ 50600 ajout MTL4
  Wrseq '                  If clalev ([M:ETR2])<=0 : Local Mask =APPLI+".STOETR2" [ETR2] : Endif'  Using [TRS_]
  For NI = 0 To IREQ2-1
    Wrseq '                ' + SZREQ2(NI,1)  Using [TRS_]
  Next NI
  Wrseq '     Endcase'  Using [TRS_]
  Wrseq '     WTYP=[F:MTS]MTSTYP'  Using [TRS_]
  Wrseq '  Endif'  Using [TRS_]
  Wrseq '  WDIE_DTRTYP=[F:MTS]MTSTYP '  Using [TRS_]
  Wrseq '  ACTION="OUVRE" : Gosub TRT_DIETRS From SUBDST'  Using [TRS_]
  Wrseq '  Call DEBTRANS From GLOCK'  Using [TRS_]
  Wrseq '  Trbegin [MTS]'  Using [TRS_]
  Wrseq '  Case [F:MTS]MTSTYP'  Using [TRS_]
  Wrseq '    When 1 : [M:MFL0]=[F:MTS]'  Using [TRS_]
  Wrseq '             [M:MFL1]=[F:MTS]'  Using [TRS_]
  Wrseq '             [M:MFL2]=[F:MTS]'  Using [TRS_]
  Wrseq '             [M:MFL3]=[F:MTS]'  Using [TRS_]
  Wrseq '             ' + SZREQ1(0,2)  Using [TRS_]
  Wrseq '             Gosub TRT_ECRAN From SUBMFL'  Using [TRS_]
  Wrseq '    When 2 : [M:MTL0]=[F:MTS]'  Using [TRS_]
  Wrseq '             [M:MTL1]=[F:MTS]'  Using [TRS_]
  Wrseq '             [M:MTL2]=[F:MTS]'  Using [TRS_]
  Wrseq '             [M:MTL3]=[F:MTS]'  Using [TRS_]
  Wrseq '             [M:MTL4]=[F:MTS]'  Using [TRS_]  # FQ 50600 ajout MTL4
  Wrseq '             [M:ETR2]=[F:MTS]'  Using [TRS_]
  Wrseq '             ' + SZREQ2(0,2)  Using [TRS_]
  Wrseq '             Gosub TRT_ECRAN From SUBMTL'  Using [TRS_]
  Wrseq '  Endcase'  Using [TRS_]
  Wrseq '  If GOK < 1'  Using [TRS_]
  Wrseq '     Call ECR_TRACE(mess(21,123,1)-mess([F:MTS]MTSTYP,353,1)-[F:MTS]MTSNUM,1) From GESECRAN'  Using [TRS_]
  Wrseq '     Rollback'  Using [TRS_]
  Wrseq '  Else'  Using [TRS_]
  Wrseq '     Call ECR_TRACE(mess(14,123,1)-mess([F:MTS]MTSTYP,353,1)-[F:MTS]MTSNUM,0) From GESECRAN'  Using [TRS_]
  Wrseq '     Commit'  Using [TRS_]
  Wrseq '  Endif'  Using [TRS_]
  Wrseq 'Next'  Using [TRS_]
  Wrseq 'Return'  Using [TRS_]
  Wrseq ''  Using [TRS_]
  Openo Using [TRS_]
  #------------------------------------------
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
  #------------------------------------------
  IVALIDOK = 1
  Call VALID("TRT", SZPROGNAME, APPLI, IVALIDOK) From VALMSKSUB
  If !IVALIDOK Then
    #Erreur lors de la génération : on appelle l'ancien pour que ça fonctionne au moins en standard
    # Je ne l'efface pas. Ca permettrait de trouver ce qui ne va pas
    #IEXIST = 1
    #Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
    Call OLD_VAL_MFGTRSA(TYP,NUM,APPLI)
    Return
  Endif
  #------------------------------------------
  Gosub TRANSAC_MFGA From =APPLI + "." + SZPROGNAME
  #------------------------------------------
  # A mettre dans l'appelant
  IEXIST = 1
  Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
  IEXIST = 1
  Call EFFACE(SZFULLADX, IEXIST) From ORDSYS
Return
# FGR 16/11/2009 : X3SUIVI57491 (fin)
#========================================================================================
#========================================================================================
#========================================================================================
# FGR 16/11/2009 : X3SUIVI57491 (début)
#----------------------------------------------------------------------------------------
$DYN_TRTMFGBTRS
Local Char SZWIN(GLONFEN)
Local Char SZABRFIC(GLONABR)
Local Char SZONGLET(250)

  SZABRFIC = 'BTS'
  # 60
  SZWIN = 'OMOL'
  SZONGLET = '"[MOL0]","[MOL1]","[MOL2]","[MOL3]","[MOL4]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ60, IREQ60) From FUNSALTRS
  # 61
  SZWIN = 'OMML'
  SZONGLET = '"[MML0]","[MML1]","[MML2]","[MML3]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ61, IREQ61) From FUNSALTRS
  # 62
  SZWIN = 'OMIL'
  SZONGLET = '"[MIL0]","[MIL1]","[MIL2]","[MIL3]","[ETR2]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ62, IREQ62) From FUNSALTRS
  # 63
  SZWIN = 'OMRE'
  SZONGLET = '"[MRE0]","[MRE1]","[MRE2]","[MRE3]","[ETR2]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ63, IREQ63) From FUNSALTRS
  # 65
  SZWIN = 'OMPL'
  SZONGLET = '"[MPL0]","[MPL1]","[MPL2]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ65, IREQ65) From FUNSALTRS
  # 66
  SZWIN = 'OMCL'
  SZONGLET = '"[MCL0]","[MCL1]","[MCL2]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ66, IREQ66) From FUNSALTRS
  # 90
  SZWIN = 'OMWL'
  SZONGLET = '"[MWL0]","[MWL1]","[MWL2]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ90, IREQ90) From FUNSALTRS
Return

#----------------------------------------------------------------------------------------
$GEN_TRTMFGBTRS
Local Char SZADXIFS
Local Char SZADXIRS
Local Integer IVALIDOK
Local Integer IEXIST
Local Char SZPROGNAME(GLONADC)
Local Char SZFULLSRC(250)
Local Char SZFULLADX(250)
Local Integer NI
# 20 lignes
#  5 colonnes :
#               (0) = Complément "Close Local Mask" et "Default Mask"
#               (1) = Listes des autres Mask à ouvrir
#               (2) = Complément affectation classe [F] dans classe [M]
Local Char SZREQ60(250)(20,5)
Local Char SZREQ61(250)(20,5)
Local Char SZREQ62(250)(20,5)
Local Char SZREQ63(250)(20,5)
Local Char SZREQ65(250)(20,5)
Local Char SZREQ66(250)(20,5)
Local Char SZREQ90(250)(20,5)
Local Integer IREQ60
Local Integer IREQ61
Local Integer IREQ62
Local Integer IREQ63
Local Integer IREQ65
Local Integer IREQ66
Local Integer IREQ90
  #------------------------------------------
  Raz SZREQ60
  Raz SZREQ60
  Raz SZREQ62
  Raz SZREQ63
  Raz SZREQ65
  Raz SZREQ66
  Raz SZREQ90
  IREQ60 = 0
  IREQ61 = 0
  IREQ62 = 0
  IREQ63 = 0
  IREQ65 = 0
  IREQ66 = 0
  IREQ90 = 0
  #------------------------------------------
  Gosub DYN_TRTMFGBTRS
  #------------------------------------------
  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  #------------------------------------------
  SZPROGNAME = "WMFGB" + num$(adxpid)
  SZFULLSRC = filpath("TRT", SZPROGNAME, "src", APPLI)
  SZFULLADX = filpath("TRT", SZPROGNAME, "adx", APPLI)
  #------------------------------------------
  #Ouverture du traitement à générer
  Openo SZFULLSRC, 0 Using [TRS_]
  #------------------------------------------
  #Génération du traitement
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%"  Using [TRS_]
  Wrseq "#Traitement généré pour les transactions MFG-A en masse"  Using [TRS_]
  Wrseq "$TRANSAC_MFGB"  Using [TRS_]
  Wrseq 'For [BTS] Where' - CRITERES  Using [TRS_]
  Wrseq '  If [F:BTS]BTSTYP <> WTYP'  Using [TRS_]
  Wrseq '     Case WTYP'  Using [TRS_]
  Wrseq '         When 60 : Close Local Mask [MOL0],[MOL1],[MOL2],[MOL3],[MOL4]' + SZREQ60(0,0)  Using [TRS_]
  Wrseq '         When 61 : Close Local Mask [MML0],[MML1],[MML2],[MML3]' + SZREQ61(0,0)  Using [TRS_]
  Wrseq '         When 62 : Close Local Mask [MIL0],[MIL1],[MIL2],[MIL3],[ETR2]' + SZREQ62(0,0)  Using [TRS_]
  Wrseq '         When 63 : Close Local Mask [MRE0],[MRE1],[MRE2],[MRE3],[ETR2]' + SZREQ63(0,0)  Using [TRS_]
  Wrseq '         When 65 : Close Local Mask [MPL0],[MPL1],[MPL2]' + SZREQ65(0,0)  Using [TRS_]
  Wrseq '         When 66 : Close Local Mask [MCL0],[MCL1],[MCL2]' + SZREQ66(0,0)  Using [TRS_]
  Wrseq '         When 90 : Close Local Mask [MWL0],[MWL1],[MWL2]' + SZREQ90(0,0)  Using [TRS_]
  Wrseq '     Endcase'  Using [TRS_]
  Wrseq '     Case [F:BTS]BTSTYP'  Using [TRS_]
  Wrseq '         When 60 : If clalev ([M:MOL0])<=0 : Local Mask =APPLI+".MOL0" [MOL0] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:MOL1])<=0 : Local Mask =APPLI+".MOL1" [MOL1] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:MOL2])<=0 : Local Mask =APPLI+".MOL2" [MOL2] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:MOL3])<=0 : Local Mask =APPLI+".MOL3" [MOL3] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:MOL4])<=0 : Local Mask =APPLI+".MOL4" [MOL4] : Endif'  Using [TRS_]
  For NI = 0 To IREQ60-1
    Wrseq '                ' + SZREQ60(NI,1)  Using [TRS_]
  Next NI
  Wrseq '         When 61 : If clalev ([M:MML0])<=0 : Local Mask =APPLI+".MML0" [MML0] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:MML1])<=0 : Local Mask =APPLI+".MML1" [MML1] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:MML2])<=0 : Local Mask =APPLI+".MML2" [MML2] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:MML3])<=0 : Local Mask =APPLI+".MML3" [MML3] : Endif'  Using [TRS_]
  For NI = 0 To IREQ61-1
    Wrseq '                ' + SZREQ61(NI,1)  Using [TRS_]
  Next NI
  Wrseq '         When 62 : If clalev ([M:MIL0])<=0 : Local Mask =APPLI+".MIL0" [MIL0] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:MIL1])<=0 : Local Mask =APPLI+".MIL1" [MIL1] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:MIL2])<=0 : Local Mask =APPLI+".MIL2" [MIL2] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:MIL3])<=0 : Local Mask =APPLI+".MIL3" [MIL3] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:ETR2])<=0 : Local Mask =APPLI+".STOETR2" [ETR2] : Endif'  Using [TRS_]
  For NI = 0 To IREQ62-1
    Wrseq '                ' + SZREQ62(NI,1)  Using [TRS_]
  Next NI
  Wrseq '         When 63 : If clalev ([M:MRE0])<=0 : Local Mask =APPLI+".MRE0" [MRE0] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:MRE1])<=0 : Local Mask =APPLI+".MRE1" [MRE1] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:MRE2])<=0 : Local Mask =APPLI+".MRE2" [MRE2] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:MRE3])<=0 : Local Mask =APPLI+".MRE3" [MRE3] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:ETR2])<=0 : Local Mask =APPLI+".STOETR2" [ETR2] : Endif'  Using [TRS_]
  For NI = 0 To IREQ63-1
    Wrseq '                ' + SZREQ63(NI,1)  Using [TRS_]
  Next NI
  Wrseq '         When 65 : If clalev ([M:MPL0])<=0 : Local Mask =APPLI+".MPL0" [MPL0] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:MPL1])<=0 : Local Mask =APPLI+".MPL1" [MPL1] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:MPL2])<=0 : Local Mask =APPLI+".MPL2" [MPL2] : Endif'  Using [TRS_]
  For NI = 0 To IREQ65-1
    Wrseq '                ' + SZREQ65(NI,1)  Using [TRS_]
  Next NI
  Wrseq '         When 66 : If clalev ([M:MCL0])<=0 : Local Mask =APPLI+".MCL0" [MCL0] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:MCL1])<=0 : Local Mask =APPLI+".MCL1" [MCL1] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:MCL2])<=0 : Local Mask =APPLI+".MCL2" [MCL2] : Endif'  Using [TRS_]
  For NI = 0 To IREQ66-1
    Wrseq '                ' + SZREQ66(NI,1)  Using [TRS_]
  Next NI
  Wrseq '         When 90 : If clalev ([M:MWL0])<=0 : Local Mask =APPLI+".MWL0" [MWL0] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:MWL1])<=0 : Local Mask =APPLI+".MWL1" [MWL1] : Endif'  Using [TRS_]
  Wrseq '                   If clalev ([M:MWL2])<=0 : Local Mask =APPLI+".MWL2" [MWL2] : Endif'  Using [TRS_]
  For NI = 0 To IREQ90-1
    Wrseq '                ' + SZREQ90(NI,1)  Using [TRS_]
  Next NI
  Wrseq '     Endcase'  Using [TRS_]
  Wrseq '     WTYP=[F:BTS]BTSTYP'  Using [TRS_]
  Wrseq '  Endif'  Using [TRS_]
  Wrseq '  Call DEBTRANS From GLOCK'  Using [TRS_]
  Wrseq '  Trbegin [BTS]'  Using [TRS_]
  Wrseq '  Case [F:BTS]BTSTYP'  Using [TRS_]
  Wrseq '    When 60 : [M:MOL0]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:MOL1]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:MOL2]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:MOL3]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:MOL4]=[F:BTS]'  Using [TRS_]
  Wrseq '             ' + SZREQ60(0,2)  Using [TRS_]
  Wrseq '              MASKREF = "MTKBENCHO"'  Using [TRS_]
  Wrseq '              Gosub TRT_ECRAN From SUBMOL'  Using [TRS_]
  Wrseq '    When 61 : [M:MML0]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:MML1]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:MML2]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:MML3]=[F:BTS]'  Using [TRS_]
  Wrseq '             ' + SZREQ61(0,2)  Using [TRS_]
  Wrseq '              MASKREF = "MTKBENCHM"'  Using [TRS_]
  Wrseq '              Gosub TRT_ECRAN From SUBMML'  Using [TRS_]
  Wrseq '    When 62 : [M:MIL0]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:MIL1]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:MIL2]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:MIL3]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:ETR2]=[F:BTS]'  Using [TRS_]
  Wrseq '             ' + SZREQ62(0,2)  Using [TRS_]
  Wrseq '              MASKREF = "MTKBENCHI"'  Using [TRS_]
  Wrseq '              Gosub TRT_ECRAN From SUBMIL'  Using [TRS_]
  Wrseq '    When 63 : [M:MRE0]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:MRE1]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:MRE2]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:MRE3]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:ETR2]=[F:BTS]'  Using [TRS_]
  Wrseq '             ' + SZREQ63(0,2)  Using [TRS_]
  Wrseq '              MASKREF = "MTKBENCHR"'  Using [TRS_]
  Wrseq '              Gosub TRT_ECRAN From SUBMRE'  Using [TRS_]
  Wrseq '    When 65 : [M:MPL0]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:MPL1]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:MPL2]=[F:BTS]'  Using [TRS_]
  Wrseq '             ' + SZREQ65(0,2)  Using [TRS_]
  Wrseq '              MASKREF = "MTKBENPLT"'  Using [TRS_]
  Wrseq '              Gosub TRT_ECRAN From SUBMPL'  Using [TRS_]
  Wrseq '    When 66 : [M:MCL0]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:MCL1]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:MCL2]=[F:BTS]'  Using [TRS_]
  Wrseq '             ' + SZREQ66(0,2)  Using [TRS_]
  Wrseq '              MASKREF = "MTKBENCHT"'  Using [TRS_]
  Wrseq '              Gosub TRT_ECRAN From SUBMCL'  Using [TRS_]
  Wrseq '    When 90 : [M:MWL0]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:MWL1]=[F:BTS]'  Using [TRS_]
  Wrseq '              [M:MWL2]=[F:BTS]'  Using [TRS_]
  Wrseq '             ' + SZREQ90(0,2)  Using [TRS_]
  Wrseq '              MASKREF = "MFGWEIGH"'  Using [TRS_]
  Wrseq '              Gosub TRT_ECRAN From SUBMWL'  Using [TRS_]
  Wrseq '  Endcase'  Using [TRS_]
  Wrseq '  If GOK < 1'  Using [TRS_]
  Wrseq '     Call ECR_TRACE(mess(21,123,1)-mess([F:BTS]BTSTYP-56,753,1)-[F:BTS]BTSNUM,1) From GESECRAN'  Using [TRS_]
  Wrseq '     Rollback'  Using [TRS_]
  Wrseq '  Else'  Using [TRS_]
  Wrseq '     Call ECR_TRACE(mess(14,123,1)-mess([F:BTS]BTSTYP-56,753,1)-[F:BTS]BTSNUM,0) From GESECRAN'  Using [TRS_]
  Wrseq '     Commit'  Using [TRS_]
  Wrseq '  Endif'  Using [TRS_]
  Wrseq 'Next'  Using [TRS_]
  Wrseq 'Return'  Using [TRS_]
  Wrseq ''  Using [TRS_]
  Openo Using [TRS_]
  #------------------------------------------
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
  #------------------------------------------
  IVALIDOK = 1
  Call VALID("TRT", SZPROGNAME, APPLI, IVALIDOK) From VALMSKSUB
  If !IVALIDOK Then
    #Erreur lors de la génération : on appelle l'ancien pour que ça fonctionne au moins en standard
    # Je ne l'efface pas. Ca permettrait de trouver ce qui ne va pas
    #IEXIST = 1
    #Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
    Call OLD_VAL_MFGTRSB(TYP,NUM,APPLI)
    Return
  Endif
  #------------------------------------------
  Gosub TRANSAC_MFGB From =APPLI + "." + SZPROGNAME
  #------------------------------------------
  # A mettre dans l'appelant
  IEXIST = 1
  Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
  IEXIST = 1
  Call EFFACE(SZFULLADX, IEXIST) From ORDSYS
Return
# FGR 16/11/2009 : X3SUIVI57491 (fin)
#========================================================================================

##############################################################################
# VAL_MFGTRS : S/P Validation en masse des transactions de saisie GPAO       #
# -------------------------------------------------------------------------- #
# Subprog VAL_MFGTRS (TYP,NUM,APPLI)                                         #
#    TYP  : Type des transactions à valider (1n)                             #
#           0 = Toutes                                                       #
#           1 = Ordre de fabrication                                         #
#           2 = Suivi de fabrication                                         #
#         >59 = Transactions plan suivi                                      #   
#    NUM  : Code de la transaction à valider (3c)                            #
#           "" = Toutes                                                      #
#    APPLI: Nom de l'application à mettre à jour                             #
# -------------------------------------------------------------------------- #
# Table à partir de laquelle la validation est effectuée :                   #
#          [F:MTS]MFGTRS   Table des transactions                            #
#          [F:BTS]BENCHTRS Table des transactions plans                      #
# Le fichier trace doit être ouvert avant l'appel du sous-programme          #
##############################################################################
Subprog VAL_MFGTRS(TYP,NUM,APPLI)
Value  Integer  TYP
Value  Char     NUM
Value  Char     APPLI
Local  Integer I
Local  Integer TOK(1..8)
If TYP = 0 | (TYP >= 1  & TYP <= 3)             : Call VAL_MFGTRSA(TYP,NUM,APPLI) : Endif
If TYP = 0 | (TYP >= 60 & TYP <= 66)            : Call VAL_MFGTRSB(TYP,NUM,APPLI) : Endif
If TYP = 90                                     : Call VAL_MFGTRSB(TYP,NUM,APPLI) : Endif
End

##############################################################################
Subprog VAL_MFGTRSA(TYP,NUM,APPLI)
Value  Integer  TYP
Value  Char     NUM
Value  Char     APPLI
Local  Integer  WTYP
Local  Char     ACTION(15), CRITERES(30)
Local Char      WDIE_ABRFIC(3) : WDIE_ABRFIC="MTS" # FQ 51071 GA 12/2008 avant PTR
Local Integer   WDIE_DTRTYP
ACTION="MASSE"
Case TYP
    When 0 :         CRITERES = "1=1"
    When 1 :         CRITERES = "MTSTYP=1"
    When 2 :         CRITERES = "MTSTYP=2"
    When Default :   CRITERES = "1=1"
Endcase
If NUM <> "" & CRITERES <> "" : CRITERES += " & MTSNUM=NUM" : Endif
If clalev([F:MTS]) <= 0 : Local File = APPLI+".MFGTRS"  [MTS] : Endif
If clalev([F:AMK]) <= 0 : Local File = APPLI+".AMSK"    [AMK] : Endif
If clalev([F:AMZ]) <= 0 : Local File = APPLI+".AMSKZON" [AMZ] : Endif

  Gosub GEN_TRTMFGATRS
End

#====================================
Subprog OLD_VAL_MFGTRSA(TYP,NUM,APPLI)
Value  Integer  TYP
Value  Char     NUM
Value  Char     APPLI
Local  Integer  WTYP
Local  Char     ACTION(15), CRITERES(30)
Local Char      WDIE_ABRFIC(3) : WDIE_ABRFIC="MTS" # FQ 51071 GA 12/2008 avant PTR
Local Integer   WDIE_DTRTYP
ACTION="MASSE"
Case TYP
    When 0 :         CRITERES = "1=1"
    When 1 :         CRITERES = "MTSTYP=1"
    When 2 :         CRITERES = "MTSTYP=2"
    When Default :   CRITERES = "1=1"
Endcase
If NUM <> "" & CRITERES <> "" : CRITERES += " & MTSNUM=NUM" : Endif
If clalev([F:MTS]) <= 0 : Local File = APPLI+".MFGTRS"  [MTS] : Endif
If clalev([F:AMK]) <= 0 : Local File = APPLI+".AMSK"    [AMK] : Endif
If clalev([F:AMZ]) <= 0 : Local File = APPLI+".AMSKZON" [AMZ] : Endif
For [MTS] Where evalue(CRITERES)
  If [F:MTS]MTSTYP <> WTYP
     Case WTYP
         When 1 : Close Local Mask [MFL0],[MFL1],[MFL2],[MFL3],[DST]
         When 2 : Close Local Mask [MTL0],[MTL1],[MTL2],[MTL3],[MTL4],[ETR2]          # FQ 50600 ajout MTL4
     Endcase
     Case [F:MTS]MTSTYP
         When 1 : If clalev ([M:MFL0])<=0 : Local Mask =APPLI+".MFL0" [MFL0] : Endif
                  If clalev ([M:MFL1])<=0 : Local Mask =APPLI+".MFL1" [MFL1] : Endif
                  If clalev ([M:MFL2])<=0 : Local Mask =APPLI+".MFL2" [MFL2] : Endif
                  If clalev ([M:MFL3])<=0 : Local Mask =APPLI+".MFL3" [MFL3] : Endif
                  If clalev ([M:DST])<=0  : Local Mask =APPLI+".DIESCRTRS3" [DST] : Endif
        When 2 :  If clalev ([M:MTL0])<=0 : Local Mask =APPLI+".MTL0" [MTL0] : Endif
                  If clalev ([M:MTL1])<=0 : Local Mask =APPLI+".MTL1" [MTL1] : Endif
                  If clalev ([M:MTL2])<=0 : Local Mask =APPLI+".MTL2" [MTL2] : Endif
                  If clalev ([M:MTL3])<=0 : Local Mask =APPLI+".MTL3" [MTL3] : Endif
                  If clalev ([M:MTL4])<=0 : Local Mask =APPLI+".MTL4" [MTL4] : Endif  # FQ 50600 ajout MTL4
                  If clalev ([M:ETR2])<=0 : Local Mask =APPLI+".STOETR2" [ETR2] : Endif
     Endcase
     WTYP=[F:MTS]MTSTYP
  Endif
  WDIE_DTRTYP=[F:MTS]MTSTYP 
  ACTION="OUVRE" : Gosub TRT_DIETRS From SUBDST
  Call DEBTRANS From GLOCK
  Trbegin [MTS]
  Case [F:MTS]MTSTYP
    When 1 : [M:MFL0]=[F:MTS]
             [M:MFL1]=[F:MTS]
             [M:MFL2]=[F:MTS]
             [M:MFL3]=[F:MTS]
             Gosub TRT_ECRAN From SUBMFL
    When 2 : [M:MTL0]=[F:MTS]
             [M:MTL1]=[F:MTS]
             [M:MTL2]=[F:MTS]
             [M:MTL3]=[F:MTS]
             [M:MTL4]=[F:MTS]  # FQ 50600 ajout MTL4
             [M:ETR2]=[F:MTS]
             Gosub TRT_ECRAN From SUBMTL
  Endcase

  If GOK < 1
     Call ECR_TRACE(mess(21,123,1)-mess([F:MTS]MTSTYP,353,1)-[F:MTS]MTSNUM,1) From GESECRAN
     Rollback
  Else
     Call ECR_TRACE(mess(14,123,1)-mess([F:MTS]MTSTYP,353,1)-[F:MTS]MTSNUM,0) From GESECRAN
     Commit
  Endif
Next
End

##############################################################################
Subprog VAL_MFGTRSB(TYP,NUM,APPLI)
Value  Integer  TYP
Value  Char     NUM
Value  Char     APPLI

Local  Integer  WTYP
Local  Char     ACTION(15), CRITERES(30)
Local  Char     LIBEL(30) , MASKREF(GLONAMK), MASKDES(GLONAMK)
Local  Integer  ER
Local  Integer  OK
#
# Si code activité MWM à non, on sort FQ 50870 
If TYP = 90 & !func AFNC.ACTIVDOS(APPLI,"MWM") : End : Endif

ACTION="MASSE"
Case TYP
    When 0  :                                   CRITERES = "BTSTYP>59 "
        # FQ 50870 Si code activité MWM à non, eviter les transactions BTSTYP=90
          If !func AFNC.ACTIVDOS(APPLI,"MWM") : CRITERES += "& BTSTYP<>90": Endif
    When 60 :         Gosub OUVRE From SUBMOL : CRITERES = "BTSTYP=60"
    When 61 :         Gosub OUVRE From SUBMML : CRITERES = "BTSTYP=61"
    When 62 :         Gosub OUVRE From SUBMIL : CRITERES = "BTSTYP=62"
    When 63 :         Gosub OUVRE From SUBMRE : CRITERES = "BTSTYP=63"
    When 65 :         Gosub OUVRE From SUBMPL : CRITERES = "BTSTYP=65"
    When 66 :         Gosub OUVRE From SUBMCL : CRITERES = "BTSTYP=66"
    When 90 :         Gosub OUVRE From SUBMWL : CRITERES = "BTSTYP=90"
    When Default :                              CRITERES = "BTSTYP>95"
Endcase
If NUM <> "" & CRITERES <> "" : CRITERES += " & BTSNUM=NUM" : Endif
If clalev([F:BTS])<=0   : Local File = APPLI+".BENCHTRS" [BTS] : Endif
If clalev([F:AMK])<=0   : Local File = APPLI+".AMSK"     [AMK] : Endif
If clalev([F:AMZ])<=0   : Local File = APPLI+".AMSKZON"  [AMZ] : Endif
If clalev([F:AMA])<=0   : Local File = APPLI+".AMSKACT"  [AMA] : Endif
If clalev([F:AMP])<=0   : Local File = APPLI+".AMSKPAR"  [AMP] : Endif

  Gosub GEN_TRTMFGBTRS
End

#====================================
Subprog OLD_VAL_MFGTRSB(TYP,NUM,APPLI)
Value  Integer  TYP
Value  Char     NUM
Value  Char     APPLI

Local  Integer  WTYP
Local  Char     ACTION(15), CRITERES(30)
Local  Char     LIBEL(30) , MASKREF(GLONAMK), MASKDES(GLONAMK)
Local  Integer  ER
Local  Integer  OK
#
# Si code activité MWM à non, on sort FQ 50870 
If TYP = 90 & !func AFNC.ACTIVDOS(APPLI,"MWM") : End : Endif

ACTION="MASSE"
Case TYP
    When 0  :                                   CRITERES = "BTSTYP>59 "
        # FQ 50870 Si code activité MWM à non, eviter les transactions BTSTYP=90
          If !func AFNC.ACTIVDOS(APPLI,"MWM") : CRITERES += "& BTSTYP<>90": Endif
    When 60 :         Gosub OUVRE From SUBMOL : CRITERES = "BTSTYP=60"
    When 61 :         Gosub OUVRE From SUBMML : CRITERES = "BTSTYP=61"
    When 62 :         Gosub OUVRE From SUBMIL : CRITERES = "BTSTYP=62"
    When 63 :         Gosub OUVRE From SUBMRE : CRITERES = "BTSTYP=63"
    When 65 :         Gosub OUVRE From SUBMPL : CRITERES = "BTSTYP=65"
    When 66 :         Gosub OUVRE From SUBMCL : CRITERES = "BTSTYP=66"
    When 90 :         Gosub OUVRE From SUBMWL : CRITERES = "BTSTYP=90"
    When Default :                              CRITERES = "BTSTYP>95"
Endcase
If NUM <> "" & CRITERES <> "" : CRITERES += " & BTSNUM=NUM" : Endif
If clalev([F:BTS])<=0   : Local File = APPLI+".BENCHTRS" [BTS] : Endif
If clalev([F:AMK])<=0   : Local File = APPLI+".AMSK"     [AMK] : Endif
If clalev([F:AMZ])<=0   : Local File = APPLI+".AMSKZON"  [AMZ] : Endif
If clalev([F:AMA])<=0   : Local File = APPLI+".AMSKACT"  [AMA] : Endif
If clalev([F:AMP])<=0   : Local File = APPLI+".AMSKPAR"  [AMP] : Endif

For [BTS] Where evalue(CRITERES)
  If [F:BTS]BTSTYP <> WTYP
     Case WTYP
         When 60 : Close Local Mask [MOL0],[MOL1],[MOL2],[MOL3],[MOL4]
         When 61 : Close Local Mask [MML0],[MML1],[MML2],[MML3]
         When 62 : Close Local Mask [MIL0],[MIL1],[MIL2],[MIL3],[ETR2]
         When 63 : Close Local Mask [MRE0],[MRE1],[MRE2],[MRE3],[ETR2]
         When 65 : Close Local Mask [MPL0],[MPL1],[MPL2]
         When 66 : Close Local Mask [MCL0],[MCL1],[MCL2]
         When 90 : Close Local Mask [MWL0],[MWL1],[MWL2]
     Endcase
     Case [F:BTS]BTSTYP
         When 60 : If clalev ([M:MOL0])<=0 : Local Mask =APPLI+".MOL0" [MOL0] : Endif
                   If clalev ([M:MOL1])<=0 : Local Mask =APPLI+".MOL1" [MOL1] : Endif
                   If clalev ([M:MOL2])<=0 : Local Mask =APPLI+".MOL2" [MOL2] : Endif
                   If clalev ([M:MOL3])<=0 : Local Mask =APPLI+".MOL3" [MOL3] : Endif
                   If clalev ([M:MOL4])<=0 : Local Mask =APPLI+".MOL4" [MOL4] : Endif
         When 61 : If clalev ([M:MML0])<=0 : Local Mask =APPLI+".MML0" [MML0] : Endif
                   If clalev ([M:MML1])<=0 : Local Mask =APPLI+".MML1" [MML1] : Endif
                   If clalev ([M:MML2])<=0 : Local Mask =APPLI+".MML2" [MML2] : Endif
                   If clalev ([M:MML3])<=0 : Local Mask =APPLI+".MML3" [MML3] : Endif
         When 62 : If clalev ([M:MIL0])<=0 : Local Mask =APPLI+".MIL0" [MIL0] : Endif
                   If clalev ([M:MIL1])<=0 : Local Mask =APPLI+".MIL1" [MIL1] : Endif
                   If clalev ([M:MIL2])<=0 : Local Mask =APPLI+".MIL2" [MIL2] : Endif
                   If clalev ([M:MIL3])<=0 : Local Mask =APPLI+".MIL3" [MIL3] : Endif
                   If clalev ([M:ETR2])<=0 : Local Mask =APPLI+".STOETR2" [ETR2] : Endif
         When 63 : If clalev ([M:MRE0])<=0 : Local Mask =APPLI+".MRE0" [MRE0] : Endif
                   If clalev ([M:MRE1])<=0 : Local Mask =APPLI+".MRE1" [MRE1] : Endif
                   If clalev ([M:MRE2])<=0 : Local Mask =APPLI+".MRE2" [MRE2] : Endif
                   If clalev ([M:MRE3])<=0 : Local Mask =APPLI+".MRE3" [MRE3] : Endif
                   If clalev ([M:ETR2])<=0 : Local Mask =APPLI+".STOETR2" [ETR2] : Endif
         When 65 : If clalev ([M:MPL0])<=0 : Local Mask =APPLI+".MPL0" [MPL0] : Endif
                   If clalev ([M:MPL1])<=0 : Local Mask =APPLI+".MPL1" [MPL1] : Endif
                   If clalev ([M:MPL2])<=0 : Local Mask =APPLI+".MPL2" [MPL2] : Endif
         When 66 : If clalev ([M:MCL0])<=0 : Local Mask =APPLI+".MCL0" [MCL0] : Endif
                   If clalev ([M:MCL1])<=0 : Local Mask =APPLI+".MCL1" [MCL1] : Endif
                   If clalev ([M:MCL2])<=0 : Local Mask =APPLI+".MCL2" [MCL2] : Endif
         When 90 : If clalev ([M:MWL0])<=0 : Local Mask =APPLI+".MWL0" [MWL0] : Endif
                   If clalev ([M:MWL1])<=0 : Local Mask =APPLI+".MWL1" [MWL1] : Endif
                   If clalev ([M:MWL2])<=0 : Local Mask =APPLI+".MWL2" [MWL2] : Endif
     Endcase
     WTYP=[F:BTS]BTSTYP
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [BTS]
  Case [F:BTS]BTSTYP
    When 60 : [M:MOL0]=[F:BTS]
              [M:MOL1]=[F:BTS]
              [M:MOL2]=[F:BTS]
              [M:MOL3]=[F:BTS]
              [M:MOL4]=[F:BTS]
              MASKREF = "MTKBENCHO"
              Gosub TRT_ECRAN From SUBMOL
    When 61 : [M:MML0]=[F:BTS]
              [M:MML1]=[F:BTS]
              [M:MML2]=[F:BTS]
              [M:MML3]=[F:BTS]
              MASKREF = "MTKBENCHM"
              Gosub TRT_ECRAN From SUBMML
    When 62 : [M:MIL0]=[F:BTS]
              [M:MIL1]=[F:BTS]
              [M:MIL2]=[F:BTS]
              [M:MIL3]=[F:BTS]
              [M:ETR2]=[F:BTS]
              MASKREF = "MTKBENCHI"
              Gosub TRT_ECRAN From SUBMIL
    When 63 : [M:MRE0]=[F:BTS]
              [M:MRE1]=[F:BTS]
              [M:MRE2]=[F:BTS]
              [M:MRE3]=[F:BTS]
              [M:ETR2]=[F:BTS]
              MASKREF = "MTKBENCHR"
              Gosub TRT_ECRAN From SUBMRE
    When 65 : [M:MPL0]=[F:BTS]
              [M:MPL1]=[F:BTS]
              [M:MPL2]=[F:BTS]
              MASKREF = "MTKBENPLT"
              Gosub TRT_ECRAN From SUBMPL
    When 66 : [M:MCL0]=[F:BTS]
              [M:MCL1]=[F:BTS]
              [M:MCL2]=[F:BTS]
              MASKREF = "MTKBENCHT"
              Gosub TRT_ECRAN From SUBMCL
    When 90 : [M:MWL0]=[F:BTS]
              [M:MWL1]=[F:BTS]
              [M:MWL2]=[F:BTS]
              MASKREF = "MFGWEIGH"
              Gosub TRT_ECRAN From SUBMWL
  Endcase
  If GOK < 1
     Call ECR_TRACE(mess(21,123,1)-mess([F:BTS]BTSTYP-56,753,1)-[F:BTS]BTSNUM,1) From GESECRAN
     Rollback
  Else
     Call ECR_TRACE(mess(14,123,1)-mess([F:BTS]BTSTYP-56,753,1)-[F:BTS]BTSNUM,0) From GESECRAN
     Commit
  Endif
Next
End

