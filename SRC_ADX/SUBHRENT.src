Subprog IB_CIVA
  If clalev([F:AST])=0  : Local File APLSTD  [AST]  : Endif
  If[M:ENT0]NOLIB<100
    Read [AST]CLE = 0;[M:ENT0]NOLIB;GLANGUE
  Else
    Read [AST]CLE = 200;[M:ENT0]NOLIB-200;GLANGUE
  Endif
  GBOUT1=[F:AST]LANMES
End

Subprog B1_CIVA(VALEUR)
Variable Char    VALEUR()
Local    Char    PARMSK(250)(1..20) , SAVACT(20)
Local    Integer RETOUR

  SAVACT = GACTION : GACTION = "SAIAPLSTD"
  RETOUR = [M]NOLIB
  Call SAISIE_LIB(RETOUR, [L]PARMSK, "FAPLSTD", "APLSTD", "XWFAPLSTD") From GSAISIE
  GACTION = SAVACT
End
# Fin FQ95799


