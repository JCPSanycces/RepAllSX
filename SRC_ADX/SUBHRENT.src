#Subprog GRISE_INT(INTMT)
#Value Integer INTMT
#If INTMT<>2 : # Salarié non intermittent
# [M:ENT2]WCALPAY = 1
# Grizo [ENT2]WCALPAY
# Affzo [ENT2]WCALPAY
# Effzo [CTR3]
# [M:CTR3]STACTR = 2 : # Validé
