 #Call CONTORG([M:ENT2]AGNMIDWRK(NOL),GCURLEG) From SUBORG
 Call CHECK_LEGORG([M:ENT2]AGNMIDWRK(NOL),GCURLEG)
 If mkstat
    ZFIELD="WAGNMIDWRK"
