If VALEUR<>[0/0/0]
 If VALEUR<[M]WCTRDAT
  # Une date de fin de période d'essai doit être supérieure à la date de début du contrat.
  GMESSAGE=mess(138,10702,1)
  mkstat=2 : End
 Endif
 If [M]WENDCON<>[0/0/0] & VALEUR>[M]WENDCON
  # Une date de fin de période d'essai doit être inférieure à la date de fin du contrat.
  GMESSAGE=mess(139,10702,1)
  mkstat=2 : End
 Endif
Endif
End

