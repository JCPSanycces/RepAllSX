#  If fstat
#   GOK = 0 : Call FSTA("HRPOA") From GLOCK : Goto AB_TR_EMBSAL
#  Endif
# Endif

#SBA : move
#Commit
#Return

#JOJAC - START
#FRLAA - 2015-08-27 - REQUIREMENT 108579 US 3892 - START
#Employee Picture from mobile app
# SBA : it is better if the code is in $TR_EMBSAL
# SBA : to do later and cheked

If 1=2
        If clalev([F:BBB]) = 0    : Local File BBLOB    [BBB]          : Endif
        If clalev([F:BBB2]) = 0   : Local File BBLOB    [BBB2]         : Endif
        Read [BBB]BBB0  = "EMPPIC";NEWREFNUM;"";"";""

        If fstat
          Read [BBB2]BBB0  = "EMPPIC";[M:ENT0]REFNUM;"";"";""
          If !fstat
            Update [BBB] Where CODBLB="EMPPIC" and IDENT1=[M:ENT0]REFNUM With IDENT1=NEWREFNUM
          Endif
        Endif

        #FRLAA - 2015-08-27 - REQUIREMENT 108579 US 3892 - END


        #FRLAA - 2016-06-03 - REQUIREMENT 114309 US 211 - START
        If func DIVPAYE.IS_KFR_LEG(GCURLEG)>0 & func DIVPAYE.EXISTE_KXX("SUBCTRKFR") Then
          Gosub CREATE_INTERVIEW From SUBCTRKFR
        Endif
        #JOJAC - END
Endif
Commit
Return


$EMBSAL_CTR


For nolign=1 To [M]NBRCTR

  # calculation of counter for each contract
  # SBA US4302_111201
  TYP_CPT=2
  W_SIT=[M]ETRFCY(nolign-1)
  W_DATCPT=datesyst
  W_CRITCOMP=""
  Gosub GET_COUNTER
  If !GOK :  Break : Endif
  NEWCTRNUM=W_VALUECPT

 If nolign=1
  [F:ID]REFNUM    = NEWREFNUM
  [F:ID]FLGNEWSAL = 1
  [F:ID]ENAFLG    = 2
  [F:ID]FLGTPS    = 2
  Rewrite [ID]
 Endif
 If fstat
  GOK=0 : Call FSTA("ID") From GLOCK : Break
 Endif

 Filter [F] Where REFNUM=[M]REFNUM & CTRNUM=[M:ENT2]CTRNUM(nolign-1)
 Readlock [F] First
 Filter [F]
 If !fstat
  [F]REFNUM = NEWREFNUM
  [F]CTRNUM = NEWCTRNUM
  [F]CIVCTR=[M:ENT0]CIV
# SEGAY 15/10/12 US 854 83632
# n° de sécu 1 and 2
  [F]NUMSSCCTR=[M:ENT1]NUMSSC
  [F]NUMSSCCTR2=[M:ENT1]NUMSSC2
# END SEGAY 15/10/12 US 854 83632

 #JOJAC - START
 # If dim([F]CTRGRD)>0 : [F]CTRGRD = "EMB" : Endif
 If dim([F]CTRGRD)>0 : [F]CTRGRD = "EMB"
  If GPAYE & dim([F]FLGCREBUL)>=0
    Local Integer TEMPO
    Call GET_FLGCREBUL (TEMPO,[F]CTRGRD) From SUBHRCGD
    [F]FLGCREBUL = TEMPO
  Endif
 Endif
  #JOJAC - END
  #SBA : only KFR
  If func DIVPAYE.IS_GINTMT()
    If [F:ID]FLGINT<>2
      If dim([F]STACTR)>0 : [F]STACTR = 2 : Endif : # Validé
      If dim([F]CALPAY)>0 : [F]CALPAY = 1 : Endif  : # par contrat
    Elsif [F:ID]FLGINT=2 & GINTMT=1 & [M:CTR3]STACTR=2
      [F]XITDAT = max([M:CTR3]PSNENDDAT)
      [F]XITGRD = "FDC"
    Endif
  Endif
  Rewrite [F:HRCTR]

  If fstat
   GOK=0 : Call FSTA(TBABREV(I)) From GLOCK : Break
  Endif

 Endif

 # Mise à jour EMPCTR
 Readlock [F:ECT]ECT0=[M]REFNUM;[M]CTRNUM(nolign-1)
 If !fstat
  [F:ECT]REFNUM = NEWREFNUM
  [F:ECT]CTRNUM = NEWCTRNUM
  [F:ECT]FCY    = [M]ETRFCY(nolign-1)
  #FRLAA - 2016-06-17 - REQUIREMENT 114309 US 211 - START
  If dim([F:ECT]UPDUSR)>0       :     [F:ECT]UPDUSR = [V]GUSER        : Endif
  If dim([F:ECT]UPDDAT)>0       :     [F:ECT]UPDDAT = date$           : Endif
  If dim([F:ECT]UPDTIM)>0       :     [F:ECT]UPDTIM = time            : Endif
  If dim([F:ECT]UPDDATTIM)>0    :     [F:ECT]UPDDATTIM = datetime$    : Endif

#  [F:ECT]UPDUSR = [V]GUSER : # 60895
#  [F:ECT]UPDDAT = date$
#  [F:ECT]UPDTIM = time
  #FRLAA - 2016-06-17 - REQUIREMENT 114309 US 211 - END
  Rewrite [F:ECT]
 Endif
 If fstat
  GOK=0 : Call FSTA("ECT") From GLOCK : Break
 Endif


 # SEGAY 18/01/13 US 1231 81085
 # Mise à jour des documents à généner
 Call MAJ_CTRDOC_TXTCTR([M]REFNUM,NEWREFNUM,[M]CTRNUM(nolign-1),NEWCTRNUM,[M]CTRDAT(nolign-1),[M]CTRDAT(nolign-1),GOK) From SUBHRENT
 If GOK < 1 : Break : Endif

 # Mise à jour des documents d'entrée
 For [HRTXC] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM(nolign-1) & CTRDAT=[M]CTRDAT(nolign-1)
  Readlock [HRTXC] Curr
  If fstat=1
   GOK=-1 : GLOCK="$TXTCTR"-[M]REFNUM-[M]CTRNUM(nolign-1)-[M]CTRDAT(nolign-1) : Break 2
  Elsif fstat
   GOK=0 : Call FSTA("HRTXC") From GLOCK : Break 2
  Endif
  Delete [HRTXC] Curr
  If fstat=1
     GOK = -1 : GLOCK = "$TXTCTR"-[M]REFNUM-[M]CTRNUM(nolign-1)-[M]CTRDAT(nolign-1)
     Break 2
  Endif
 Next


 # Mise à jour du fichier Prestations
 #SBA
#If GINTMT=1
 If func DIVPAYE.IS_GINTMT()
  For [PSN] Where REFNUM=[M:ENT0]REFNUM & CTRNUM=[M]CTRNUM(nolign-1)
   Readlock [PSN] Curr
   If fstat=1
    GOK=-1 : GLOCK="$PRESTATION"-[M:ENT0]REFNUM : Break 2
   Elsif fstat
    GOK=0 : Call FSTA("PSN") From GLOCK : Break 2
   Endif
   [F:PSN]REFNUM = NEWREFNUM
   [F:PSN]CTRNUM = NEWCTRNUM
   Rewrite [PSN]
   If fstat
    GOK=0 : Call FSTA("PSN") From GLOCK : Break 2
   Endif
  Next
 Endif

 # Mise à jour de la DUE si elle a été générée
 #JOJAC - START
 #FRLAA - 2016-06-03 - REQUIREMENT 114309 US 211 - START
 If func DIVPAYE.IS_KFR_LEG(GCURLEG)>0
 #If func AFNC.ACTIV("KFR")  Then
 #FRLAA - 2016-06-03 - REQUIREMENT 114309 US 211 - END
 #JOJAC - END
 For [DUE]DUE0 Where REFNUM=[M:ENT0]REFNUM & CTRNUM=[M]CTRNUM(nolign-1) & CTRDAT=[M]CTRDAT(nolign-1)
  Readlock [DUE] Curr
  If fstat=1
   GOK=-1 : GLOCK="$DUEEMP"-[M:ENT0]REFNUM-[M]CTRNUM(nolign-1)-num$([M]CTRDAT(nolign-1)) : Break
  Elsif fstat
   GOK=0 : Call FSTA("DUE") From GLOCK : Break
  Endif
  [F:DUE]REFNUM = NEWREFNUM
  [F:DUE]CTRNUM = NEWCTRNUM
  [F:DUE]CTRDAT = [M]CTRDAT(nolign-1)             :#81440
  Rewrite [DUE]
  If fstat
   GOK=0 : Call FSTA("DUE") From GLOCK : Break
  Endif
 Next
#JOJAC - START
Endif
#JOJAC - END

 #65877
 If GPAYE
  # Mise à jour des caisses
  Read [PCA]PCA0=6;"";"";"";"";"";[M]CTRNUM(nolign-1)
  If !fstat
   If [M]NBRCTR>1
    [F:PCA]CTR = NEWCTRNUM
    Rewrite [PCA]
    If fstat
     GOK=0 : Call FSTA("PCA") From GLOCK : Goto AB_TR_EMBSAL
    Endif
   Else
    Raz [F:PCA]CTR
    [F:PCA]EMP = NEWREFNUM
    [F:PCA]LEV = 5
    Rewrite [PCA]
    If fstat
     GOK=0 : Call FSTA("PCA") From GLOCK : Goto AB_TR_EMBSAL
    Endif
   Endif
  Endif
 Endif

 Gosub POPUL_CTR From SUBEML

 If [V]GOK<1 : Break : Endif
 Gosub MAJ_EMPLOPOT

 If GOK<1 :  Break : Endif


 [M]CTRNUM(nolign-1) = NEWCTRNUM

Next

Return




# SEGAY 04/12/12 US 1040 81085
$EMBSAL_CTR_POPUL1
 # Mise à jour population d'après la règle d'appartenance
 Filter [HRPOP] Where CRI<>""
 For [HRPOP]
  If evalue([F:HRPOP]CRI)=1
   [F:HRPOA]COD    = [F:HRPOP]COD
   [F:HRPOA]TYP    = 0
   [F:HRPOA]REFNUM = NEWREFNUM
   [F:HRPOA]CTRNUM = NEWCTRNUM # SEGAY 04/12/12 US 1040 81085
   [F:HRPOA]CTRDAT = [M]CTRDAT(nolign-1) # SEGAY 04/12/12 US 1040 81085
   # 29593
   [F:HRPOA]MAJTYP = 1 : # Auto
   If dim([F:HRPOA]CREUSR)>0      : [F:HRPOA]CREUSR = GUSER         : Endif
   If dim([F:HRPOA]CREDAT)>0      : [F:HRPOA]CREDAT = date$         : Endif
   If dim([F:HRPOA]CRETIM)>0      : [F:HRPOA]CRETIM = time          : Endif
   If dim([F:HRPOA]CREDATTIM )>0  : [F:HRPOA]CREDATTIM = datetime$  : Endif #FRLAA - 2016-06-17 - REQUIREMENT 114309 US 211
   Write [HRPOA]
   If fstat
    GOK = 0 : Call FSTA("HRPOA") From GLOCK : Break
   Endif
  Endif
 Next
 Filter [HRPOP]
Return

# SEGAY 04/12/12 US 1040 81085
$EMBSAL_CTR_POPUL2
 # Population vide
 Read [HRPOA]POA0 = "";NEWREFNUM;NEWCTRNUM;[M]CTRDAT(nolign-1)
 If fstat
  Raz [F:HRPOA]
  [F:HRPOA]REFNUM = NEWREFNUM
  [F:HRPOA]CTRNUM = NEWCTRNUM # SEGAY 04/12/12 US 1040 81085
  [F:HRPOA]CTRDAT = [M]CTRDAT(nolign-1) # SEGAY 04/12/12 US 1040 81085

  [F:HRPOA]MAJTYP = 2 : # Manuelle
  If dim([F:HRPOA]CREUSR)>0       : [F:HRPOA]CREUSR = GUSER         : Endif
  If dim([F:HRPOA]CREDAT)>0       : [F:HRPOA]CREDAT = date$         : Endif
  If dim([F:HRPOA]CRETIM)>0       : [F:HRPOA]CRETIM = time          : Endif
  If dim([F:HRPOA]CREDATTIM )>0   : [F:HRPOA]CREDATTIM = datetime$  : Endif #FRLAA - 2016-06-17 - REQUIREMENT 114309 US 211
  Write [HRPOA]
  If fstat
   GOK = 0 : Call FSTA("HRPOA") From GLOCK : Return
  Endif
 Endif
Return

