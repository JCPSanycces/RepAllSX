Subprog AM_WJOBPOT(VALEUR)
Variable Char    VALEUR()
Local Integer L_OK
[M]JOBPOT([M]WLIG) = VALEUR
[M]FLGMOD([M]WLIG) = 1
If VALEUR="" : End : Endif
If [M]WMAJJOBPOTB2 : [M]WMAJJOBPOTB2=0 : End : Endif
If !clalev([F:JOT])   : Local File JOBTYP    [JOT]   : Endif
Call LECTURE("JOT",VALEUR,"") From CONTOBJ
L_OK = 1
If ([F:JOT]DATSTRVLY<>[0/0/0] & [M]CTRDAT([M]WLIG)<[F:JOT]DATSTRVLY) | ([F:JOT]DATENDVLY<>[0/0/0] & [M]CTRDAT([M]WLIG)>[F:JOT]DATENDVLY)
 Call AVERTIR(VALEUR-mess(92,10701,1)-format$("DD2",[F:JOT]DATSTRVLY)-"-"-format$("DD2",[F:JOT]DATENDVLY),L_OK) From GESECRAN
 #### Période validité emploi type :
 If L_OK<>2
  mkstat = 2 : End
 Endif
Endif
L_OK=0
Gosub MAJ_JOBTYPDEF
[M]WMAJJOBPOTB2=0
End


