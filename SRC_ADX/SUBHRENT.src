Subprog GRISE_AGENCE (VALEUR)
Value Integer VALEUR
Local Char ZONE(10) : ZONE = "WAGNMIDWRK"
#JOJAC - START
If GCURLEG<>"FRA" Then End : Endif
#JOJAC - END
Gosub SET_ZONE
If MA
#SEGAY US60 01/11/10 Refresh AGNMIDWRK based on legislation - move to SUBCTRLEG?
 #16/04/12 - DKA - Phase 215 - Control only applicable to French legislation
 Case GCURLEG
  When "FRA", ""
   If VALEUR=3 :#interimaire
    Actzo WAGNMIDWRK
   Else
    Effzo WAGNMIDWRK
    Effzo ZWAGNMIDWRK : #20/04/12 - DKA - Erase description too
    Grizo WAGNMIDWRK
    Raz [M]AGNMIDWRK([M]WLIG)
   Endif
  When Default
