## Conversion d'un salarié provisoire en définitif, lors de son embauche
## avec réattribution d'un matricule

$EMBSAL
OK = 2
# Embauche définitive du salarié
Call OUINON (mess(115,10702,1)-[M]NAM,OK) From GESECRAN
# Réponse Non
If OK=1 : Return : Endif
# Réponse oui
Raz NEWREFNUM, NEWCTRNUM
Gosub AFFECTATION_COMPTEUR
If GOK=0 : Return : Endif
Call DEBTRANS From GLOCK
Gosub TR_EMBSAL
If GOK=0 : Return : Endif
[M:ENT0]REFNUM    = NEWREFNUM
[M:ENT0]FLGNEWSAL = 1
Affzo [ENT0]REFNUM
Return


# SBA US4302_111201
$GET_COUNTER
  Gosub GET_COUNTER_SAL From TOOLSHRTCA
Return




# SBA US4302_111201
$AFFECTATION_COMPTEUR
## Reaffectation du no de matricule
  TYP_CPT=1
  W_SIT=[M:ENT2]ETRFCY(0)
  W_DATCPT=datesyst
  W_CRITCOMP=""
  Gosub GET_COUNTER
  If !GOK : Return : Endif
  NEWREFNUM=W_VALUECPT

GPOINT = "MAJMATRI" : Gosub ENTREE From EXEFNC

## Reaffectation du no de contrat
# MOVE : could be different by legislation and for each contract
#COMPTEUR = [F:TCA]CODNUM(4)
#If COMPTEUR=""
# GMESSAGE = mess(39,10701,1) : # Compteur contrat non défini
# GOK = 0 : Return
#Endif
Return





$TR_EMBSAL
GOK = 1
Trbegin [ID],[HRCTR]
 Readlock [F:ID]ID0=[M:ENT0]REFNUM
 If fstat=1
  GOK=-1 : GLOCK="$EMPLOID"-[M:ENT0]REFNUM : Goto ROLL_TR_EMBSAL
 Elsif fstat
  GOK=0 : Call FSTA("ID") From GLOCK : Goto AB_TR_EMBSAL
 Endif

 For I=1 To NBTBL
  TABLE = TBTABLE(I)
  Gosub DEFAUT From WPDEFTABLE
  If TABLE="EMPLOCTR"
   Gosub EMBSAL_CTR
   If GOK<=0 : Break : Endif
  Else
   If dim([F]NUMLIG)>0
    Filter [F] Where REFNUM=[M]REFNUM & NUMLIG=1
   Else
    Filter [F] Where REFNUM=[M]REFNUM
   Endif
   Readlock [F] First
   #JOJAC - START
   Filter [F]
   #JOJAC - END
   If !fstat
    [F]REFNUM = NEWREFNUM
#MASHI - 2017-05-26 - JIRA X3-42004 – START
    If TABLE="EMPLOCTRUKI"
     [F]CTRNUM=NEWCTRNUM
#CHSUL - 2017-10-13 - JIRA X3-59665 – START
     [F]RTIPAYIDT=NEWCTRNUM
#CHSUL - 2017-10-13 - JIRA X3-59665 – END
    Endif
#MASHI - 2017-05-26 - JIRA X3-42004 – END

    Rewrite [F]
    If fstat
     GOK=0 : Call FSTA(TBABREV(I)) From GLOCK : Break
    Endif
   Endif
  Endif
  # 41771
  If TABLE="EMPLOEXN"
   Filter [F] Where REFNUM=[M]REFNUM & NUMLIG=2
   Readlock [F] First
   #JOJAC - START
   Filter [F]
   #JOJAC - END
   If !fstat
    [F]REFNUM = NEWREFNUM
    Rewrite [F]
    If fstat
     GOK=0 : Call FSTA(TBABREV(I)) From GLOCK : Break
    Endif
   Endif
  Endif
 Next

 # SEGAY - 31/05/13 - FQ90058 FQ90059
 GPOINT = "MAJMATAUT" : Gosub ENTREE From EXEFNC

 If GOK=0
  Goto AB_TR_EMBSAL
 Elsif GOK<0
  Goto ROLL_TR_EMBSAL
 Endif

