Gosub DEFVAR From =WINPROG
For I=1 To NBTBL
 TABLE = TBTABLE(I)
 Gosub DEFAUT From WPDEFTABLE
 Filter [F] Where REFNUM=[M:ENT0]REFNUM
 Case TABLE
  When "EMPLOCTR"
    nolign = 0
    For [F]
     # Multi_leg & multi_société
    #sba ADD MAIN SITE
    #Call LECTURE("FCY",[F]ETRFCY,"") From CONTOBJ
     #Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
    # GSOCIETE=[F:CPY]CPY
    # GCURLEG=[F:CPY]LEG
     nolign += 1
     Gosub CHARGE
     #67743
     If GPAYE
#MIPEA - 2016-09-28 - X3PEOP-752 - START
     Filter [ADIZZ] Where [ADIZZ]NUMTAB = 10469 & [ADIZZ]LEG = GCURLEG # & [ADIZZ]CODE = [V]GINDMED

     For [ADIZZ]
       [L]COUNTER+=1
         If [ADIZZ]CODE = [V]GINDMED
           [L]ORGLINE=[L]COUNTER-1 : Break
         Endif
     Next
      Call ORGANISME([M:ENT0]REFNUM,[M]ETRFCY(nolign-1),[M]CTRNUM(nolign-1),[M]MED1(nolign-1),[L]ORGLINE) From SUBORG
      #Call ORGANISME([M:ENT0]REFNUM,[M]ETRFCY(nolign-1),[M]CTRNUM(nolign-1),[M]MED1(nolign-1),[V]GINDMED-1) From SUBORG
#MIPEA - 2016-09-28 - X3PEOP-752 - END

#TODO : DEHEN - START
#SHOW STOPPER
#Employee arrivals not working -  (Typeincompatibility) @GX3APP.TRT/SUBHRENT$adx(295) : Call ORGANISME([M:ENT0]REFNUM,[M]ETRFCY(nolign-1),[M]CTRNUM(nolign-1),[M]URS1(nolign-1),[V]GINDURS-1) From
# SUBORG
      #Call ORGANISME([M:ENT0]REFNUM,[M]ETRFCY(nolign-1),[M]CTRNUM(nolign-1),[M]URS1(nolign-1),val([V]GINDURS-1)) From SUBORG
#DEHEN - END

     Endif
     [M]FLGMOD(nolign-1) = 0
     #JOJAC
     ### SBA : delete
     ### Gosub LOAD_CLAUSE
     #JOJAC
     # SEGAY 18/01/13 US 1231 81085
     Filter [HRDOC] Where REFNUM=[M:ENT0]REFNUM & CTRNUM=[M]CTRNUM(nolign-1) & CTRDAT=[M]CTRDAT(nolign-1) & [F:HRDOC]FLGCRE=2
     Read  [HRDOC]DOC0 First
     Filter [HRDOC]
     If !fstat
        [M]FLGCRE1(nolign-1)=2
     Else
        [M]FLGCRE1(nolign-1)=1
     Endif
     [M]FLGOKDOC(nolign-1)=1
     [M]FLGOLDCTR(nolign-1)=[M]CTRNUM(nolign-1)
     [M]FLGOLDDAT(nolign-1)=[M]CTRDAT(nolign-1)
     # END SEGAY 18/01/13 US 1231 81085
    Next
    Filter [F]
    [M]NBRCTR = nolign
    [M]FLGADD = 0
    Sorta [M]NBRCTR [M]NBRCTR Order By [M]CTRDAT ([S]indice)Desc
    Gosub CHARGE_CTR
  When Default
    Read First
    If !fstat
     Gosub CHARGE
    Endif
 Endcase
 Filter [F]
Next
# Grisage
Read [ID]ID0=[M:ENT0]REFNUM

