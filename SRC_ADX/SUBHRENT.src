Endif
#indice=NOL+1
#Call AS_NBRCTR
Return

$APRES_CHOI
  Case REPONSE
    When GSTASUI, GSTAPRE, GSTAFIR,GSTALAS
      Gosub FILDEM
      If REPONSE=GSTASUI Then Read [ID_]ID0 > [M:ENT0]REFNUM  : Endif
      If REPONSE=GSTAPRE Then Read [ID_]ID0 < [M:ENT0]REFNUM  : Endif
      If REPONSE=GSTAFIR Then Read [ID_]ID0 First             : Endif
      If REPONSE=GSTALAS Then Read [ID_]ID0 Last              : Endif
      Filter [ID_]
#      Gosub SUIVPREC From TOOLSHRLEG
      If fstat<=2
       REPONSE = GSTALFT
      Else
       Call MESSAGE(mess(11,100,1)) From GESECRAN : # Début/fin de fichier
       REPONSE = 0
      Endif
#  SEGAY 05/10/12 US810 81491 84301
# L'exécution du bouton "Embauche" se fait dans l'étiquette APRES_CHOI, de façon
# à pouvoir rafraîchir le browser et les écrans, en positionnant REPONSE à GSTARAF
    When GSTABOU+1 :
      Local Char VALBOUT(250) , PARBOUT(250)(1..20)
      FLGEXE = 1
      Gosub EMBSAL
      REPONSE = GSTARAF
      zoncou="[M:ENT0]REFNUM"
#  END SEGAY 05/10/12 US810 81491 84301
# SEGAY 18/01/13 US 1231 81085
# To receive APRES_MODIF after Action "CTRDOC" windows "Documents to Generate"
# For Display or no buttom menu "Generate Documents" & "Administrativ Documents"
    When GSTACLK+50
       Gosub RELIT From GOBJSUB
# END SEGAY 18/01/13 US 1231 81085
  Endcase
Return


