Subprog AM_WRATMIDWRK(VALEUR)
Variable Decimal VALEUR
Local Char ZONE(10)
[M]RATMIDWRK([M]WLIG) = VALEUR
[M]FLGMOD([M]WLIG)    = 1
Gosub LIRE_SITE
WEKPAR=val(func AFNC.PARAM("HOUWEKLEG",[F:FCY]FCY))
If VALEUR>0 & VALEUR<100
 #56976
 #[M]WHRSWEK=arr((VALEUR*WEKPAR)/100,2)
 [M]WHRSWEK=fix(VALEUR*WEKPAR)/100
Else
 [M]WHRSWEK=WEKPAR
Endif
MONPAR=val(func AFNC.PARAM("HOUMONLEG",[F:FCY]FCY))
If VALEUR>0 & VALEUR<100
 #56976
 #[M]WHRSMTH=arr((VALEUR*MONPAR)/100,2)
 [M]WHRSMTH=fix(VALEUR*MONPAR)/100
Else
 [M]WHRSMTH=MONPAR
Endif
For ZONE = "WHRSWEK","WHRSMTH"
 Gosub SET_ZONE
 If MA
  Affzo =ZONE
 Endif
Next
End

## Sélection poste
Subprog S_WJOB(VALEUR)
Variable Char    VALEUR()
Local Char  PARMSK(250)(1..20) , SAVACT(20), SAVVALEUR(30)
Local Char  ZONE(10)
If !clalev([F:POT])   : Local File POSTE     [POT]   : Endif
If !clalev([F:HRCCV]) : Local File CLASSCONV [HRCCV] : Endif
SAVACT = GACTION : GACTION = "SELOBJSTD"
SAVVALEUR = VALEUR
# SBA ajout car on ne connait pas la provenance
VALEUR=""
PARMSK(1) = "POT"
PARMSK(2) = ""
PARMSK(3) = ""
PARMSK(4) = "([F:POT]DATENDVLY=[0/0/0] | [F:POT]DATENDVLY>=[M]CTRDAT)"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJCRIT","SELOBJ","") From GACTION
GACTION = SAVACT
Read [POT]POT0=VALEUR
If !fstat
# VALEUR = [F:POT]DES
 Local Char DES
 Call LECTEXTRA(DES,"POSTE","DES",VALEUR,"") From ATEXTRA
 VALEUR=DES
 If [F:POT]CCV<>""
  Read [HRCCV]CCV0=[F:POT]CCV;GCURLEG
  If !fstat
# SEGAY 18/12/12 86717 bug 85016 US810 81491 84301
   ZONE = "WCATCSP"
   Gosub SET_ZONE
   If MA
      [M]WCATCSP = [F:HRCCV]CATCSP : Affzo [M]WCATCSP
   Endif
# END SEGAY 18/12/12 86717 bug 85016 US810 81491 84301
#   For ZONE = "GRA","BUIGRA","COE","BUICOE","IND","BUISTA","CATCSP"
   For ZONE = "GRA","COE","IND","CATCSP"
    Gosub SET_ZONE
    If MA
     Case ZONE
      When "GRA"    : [M]WGRA    = [F:HRCCV]GRA    : [M]GRA([M]WLIG)    = [M]WGRA    : Affzo [M]WGRA
#      When "BUIGRA" : [M]WBUIGRA = [F:HRCCV]GRA    : [M]BUIGRA([M]WLIG) = [M]WBUIGRA : Affzo [M]WBUIGRA
      When "COE"    : [M]WCOE    = [F:HRCCV]COE    : [M]COE([M]WLIG)    = [M]WCOE    : Affzo [M]WCOE
#      When "BUICOE" : [M]WBUICOE = [F:HRCCV]COE    : [M]BUICOE([M]WLIG) = [M]WBUICOE : Affzo [M]WBUICOE
      When "IND"    : [M]WIND    = [F:HRCCV]IND    : [M]IND([M]WLIG)    = [M]WIND    : Affzo [M]WIND
#      When "BUISTA" : [M]WBUISTA = [F:HRCCV]IND    : [M]BUISTA([M]WLIG) = [M]WBUISTA : Affzo [M]WBUISTA
      #ADNGO - 2017-05-08 - JIRA X3-33782 - START
      #When "CATCSP" : [M]WCATCSP = [F:HRCCV]CATCSP : [M]CATCSP([M]WLIG) = [M]WCATCSP : Affzo []WCATCSP
      When "CATCSP" : [M:ENT3]WCATCSP = [F:HRCCV]CATCSP : [M]CATCSP([M]WLIG) = [M:ENT3]WCATCSP : Affzo [M:ENT3]WCATCSP
      #ADNGO - 2017-05-08 - JIRA X3-33782 - END
# SEGAY 18/12/12 86717 bug 85016 US810 81491 84301
#      When "CATCSP" : [M]WCATCSP = [F:HRCCV]CATCSP : [M]CATCSP([M]WLIG) = [M]WCATCSP : Affzo [M]WCATCSP
      When "CATCSP" : [M]CATCSP([M]WLIG) = [F:HRCCV]CATCSP
     Endcase
    Endif
   Next
  Endif
 Endif
Else
 VALEUR = SAVVALEUR
Endif
End

