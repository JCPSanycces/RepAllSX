$CAISSE
#67743
If !GPAYE : Return : Endif
Raz MESSAG
ZONE = "MED1"
Gosub SET_ZONE
If MA
#MIPEA - 2016-09-28 - X3PEOP-752 - START
Filter [ADIZZ] Where [ADIZZ]NUMTAB = 10469 & [ADIZZ]LEG = GCURLEG # & [ADIZZ]CODE = [V]GINDMED

For [ADIZZ]
  [L]COUNTER+=1
   If [ADIZZ]CODE = [V]GINDMED
    [L]ORGLINE=[L]COUNTER-1 : Break
   Endif
Next
 Call ORGANISME([F:HRCTR]REFNUM,[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM,CAISSE,[L]ORGLINE) From SUBORG
 #Call ORGANISME([F:HRCTR]REFNUM,[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM,CAISSE,[V]GINDMED-1) From SUBORG
#MIPEA - 2016-09-28 - X3PEOP-752 - END
 If CAISSE<>[M]MED1(nolign-1)
#MIPEA - 2016-09-28 - X3PEOP-752 - START
Filter [ADIZZ] Where [ADIZZ]NUMTAB = 10469 & [ADIZZ]LEG = GCURLEG # & [ADIZZ]CODE = [V]GINDMED

For [ADIZZ]
  [L]COUNTER+=1
   If [ADIZZ]CODE = [V]GINDMED
    [L]ORGLINE=[L]COUNTER-1 : Break
   Endif
Next
  # Création de la caisse pour le contrat
  Call CRE_CAISSE([F:HRCTR]CTRNUM,[M]MED1(nolign-1),[L]ORGLINE) From SUBORG
  #Call CRE_CAISSE([F:HRCTR]CTRNUM,[M]MED1(nolign-1),[V]GINDMED-1) From SUBORG
#MIPEA - 2016-09-28 - X3PEOP-752 - END
  If GOK=1 : MESSAG = [M]MED1(nolign-1) : Endif
 Endif
Endif
ZONE = "URS1"
Gosub SET_ZONE
If MA
 Call ORGANISME([F:HRCTR]REFNUM,[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM,CAISSE,[L]ORGLINE) From SUBORG #HEGES 2017-04-26
 If CAISSE<>[M]URS1(nolign-1) : # Création de la caisse pour le contrat
  Call CRE_CAISSE([F:HRCTR]CTRNUM,[M]URS1(nolign-1),[L]ORGLINE) From SUBORG #HEGES 2017-04-26
  If GOK=1 : MESSAG -=[M]URS1(nolign-1) Endif
 Endif
Endif
If GOK=1 & MESSAG<>""
 # Organisme affecté au salarié
 Call MESSAGE(MESSAG-":"-mess(28,10701,1)) From GESECRAN
Endif
Return

$CREUSR
If dim([F]CREDAT)>0       : [F]CREDAT = date$           : Endif
If dim([F]CRETIM)>0       : [F]CRETIM = time            : Endif
If dim([F]CREUSR)>0       : [F]CREUSR = GUSER           : Endif
If dim([F]EXPNUM)>0       : [F]EXPNUM = [C]EXPORT       : Endif
If dim([F]CREDATTIM)>0    : [F]CREDATTIM = datetime$    : Endif   #FRLAA - 2016-06-17 - REQUIREMENT 114309 US 211

Return

$MODUSR
If dim([F]UPDDAT)>0       : [F]UPDDAT = date$           : Endif
If dim([F]UPDTIM)>0       : [F]UPDTIM = time            : Endif
If dim([F]UPDUSR)>0       : [F]UPDUSR = GUSER           : Endif
If dim([F]EXPNUM)>0       : [F]EXPNUM = [C]EXPORT       : Endif
If dim([F]UPDDATTIM)>0    : [F]UPDDATTIM = datetime$    : Endif    #FRLAA - 2016-06-17 - REQUIREMENT 114309 US 211
Return

$ACT
If FLSPE
 Gosub ACT From =PROGSPE
Endif
Return

$SET_ZONE
Local Integer MA , J
Local Char    AB(1)
MA=0
 #  DEHEN 09/05/17  X3-22269 - X3-22274 - START
    #For J=1 To 6
    #AB = mid$("01234",J,1)
    #If evalue("dim([M:ENT"+AB+"]"+ZONE+")")>0
 For J=1 To 6
  AB = mid$("0123456",J,1)
  If evalue("dim([M:ENT"+AB+"]"+ZONE+")")>0
 #  DEHEN 09/05/17  X3-22269 - X3-22274 - END
  MA = J
  Break
 Endif
Next
Case MA
 When  1 : Default Mask [ENT0]
 When  2 : Default Mask [ENT1]
 When  3 : Default Mask [ENT2]
 When  4 : Default Mask [ENT3]
 When  5 : Default Mask [ENT4] : #  SEGAY 05/10/12  US810 81491 84301
 When  6 : Default Mask [ENT6] #  DEHEN 09/05/17  X3-22269 - X3-22274
Endcase
Return
#  SEGAY 05/10/12  US810 81491 84301
$SET_ZONE2
Local Integer MA , J
Local Char    AB(1)
MA=0
If GINTMT=1
  For J=1 To 1
   AB = mid$("3",J,1)
   If evalue("dim([M:CTR"+AB+"]"+ZONE+")")>0
    MA = J
    Break
   Endif
  Next
  Case MA
   When  1 : Default Mask [CTR3]
  Endcase
Endif
Return

