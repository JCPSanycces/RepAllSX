################################################################################
## Chargement et déchargement des variables commencant par W
################################################################################

$CHARGE_W
Local Integer J
Local Char    CLASSE(10) , NAMFLD(10)
CLASSE = clanam([M])
For J=1 To clanbs([M],1)
 NAMFLD = clavar([M],J)
 If left$(NAMFLD,1)="W" & evalue("dim("+ECRDEF+right$(NAMFLD,2)+")")>0
  If dim([L]SUFFIXE)<=0 or pat(NAMFLD,"*"+SUFFIXE) or pat(NAMFLD,"*"+SUFFIXE+"#")
   If dim([L]PREFIXE)<=0 or pat(NAMFLD,PREFIXE+"*")
    Assign CLASSE+NAMFLD With evalue(ECRDEF+right$(NAMFLD,2)+"("+num$(NOL)+")")
   Endif
  Endif
 Endif
Next
Return

$DECHARGE_W
Local Integer J
Local Char    CLASSE(10) , NAMFLD(10)
CLASSE = clanam([M])
For J=1 To clanbs([M],1)
 NAMFLD = clavar([M],J)
 If left$(NAMFLD,1)="W" & evalue("dim("+ECRDEF+right$(NAMFLD,2)+")")>0
  If dim([L]SUFFIXE)<=0 or pat(NAMFLD,"*"+SUFFIXE) or pat(NAMFLD,"*"+SUFFIXE+"#")
   If dim([L]PREFIXE)<=0 or pat(NAMFLD,PREFIXE+"*")
    Assign ECRDEF+right$(NAMFLD,2)+"("+num$(NOL)+")" With evalue(CLASSE+NAMFLD)
   Endif
  Endif
 Endif
Next
Return

