#  SEGAY 15/10/12 US 854 83632 - "Affzo" NUMSSCCTR, NUMSSCCTR2
# of the contract, to determine if the fields can be seizable or not
Subprog SEIZE_NUMSSC(SITE)
Value Char SITE
Local Char CRYFCY

  CRYFCY=func TRTDIV.LECPAYSIT(SITE)
  If CRYFCY="" Then
   [M:ENT1]NUMSSC  = ""
   [M:ENT1]NUMSSC2 = ""
    # This "Affzo" calls W1ENT1.AV_NUMSSC & W1ENT1.AV_NUMSSC2, and allows to hide or mask the fields with the Chgfmt
    Affzo [M:ENT1]NUMSSC, NUMSSC2
    Grizo [M:ENT1]NUMSSC, NUMSSC2
  Else
    # This "Affzo" calls W1ENT1.AV_NUMSSC & W1ENT1.AV_NUMSSC2, and allows to hide or mask the fields with the Chgfmt
    Affzo [M:ENT1]NUMSSC, NUMSSC2
    Actzo [M:ENT1]NUMSSC, NUMSSC2
  Endif
End
# END SEGAY


