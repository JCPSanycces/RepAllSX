Subprog AM_FCYORI(VALEUR)
Variable Char    VALEUR()
Local Char OLDLEG
Local Char NEWLEG
Local Integer OK
Local Integer OKPAR
Call GET_LEGFCY([M:ENT0]FCYORI,OK,OLDLEG,0) From TOOLSHRLEG
Call GET_LEGFCY(VALEUR,OK,NEWLEG,0) From TOOLSHRLEG
If(NEWLEG<>OLDLEG)
  # RAZ civ
    [M:ENT0]CIV=0
    [M:ENT0]CIVA = ""
  Endif
Call SETCPYLGEG(VALEUR,[M:ENT0]CIV,OKPAR)
If( [M:ENT0]FCYORI ="" & GREP="C"& OKPAR)
    [M:ENT0]CIV=1
    [M:ENT0]CIVA = mess(1,[M:ENT0]NOLIB,1)
    Local Integer WCIV : WCIV=1
    Call GRISE_OLDNAM(WCIV)
Endif
If !OKPAR
  mkstat=2
  End
Endif
# SEGAY 15/10/12 US 854 83632
[M:ENT0]FCYORI=VALEUR
Call SEIZE_NUMSSC([M:ENT0]FCYORI)

##JOJAC - 2016-07-25 - REQ114309 - START
#Read [F:FCY]FCY0 = VALEUR
#[M:ENT2]WCLLCVT = [F:FCY]CLLCVT
#Affzo [M:ENT2]WCLLCVT
##JOJAC - 2016-07-25 - REQ114309 - END

If GCURLEG = "BRI"
  If dim([M:ENT1]SEX )>0     : Chgfmt [M:ENT1]SEX      With "LA:10X"      : Raz [M:ENT1]SEX      : Endif
Else
  If dim([M:ENT1]SEX )>0     : Chgfmt [M:ENT1]SEX      With "-LA:10X"      : Raz [M:ENT1]SEX      : Endif
Endif
End

Subprog AP_FCYORI(VALEUR)
Variable Char    VALEUR()
Local Integer OK
# restaure gcurleg
Call GET_LEGFCY(VALEUR,OK,GCURLEG,0) From TOOLSHRLEG
If(OK)
  GSOCIETE=[F:CPY]CPY
Endif
End


Subprog AS_FCYORI(VALEUR)
Variable Char    VALEUR()
GCURLEG=""
#bidouille car on ne passe par l'après zone que si modifié une fois. La on force même si on change de zone via un clique souris.
Setmok [ENT0]With 0
End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran ENTSAL2) 10/07/2012 16:45:54 (SBA)
######################################################################################
Subprog C_WETRFCY(VALEUR)
Variable Char    VALEUR()
Local Char LLEG
Local Integer OK
If(VALEUR<>"")
  Call GET_LEGFCY(VALEUR,OK,LLEG,0)From TOOLSHRLEG
  If(LLEG<>GCURLEG)
    GMESSAGE=VALEUR-":"-mess(129,10701,1)-"["+GCURLEG+"]"# La législation de ce site est différente de celle du site principal du salarié
    mkstat=2
    End
  Endif
# SEGAY 15/10/12 US 854 83632
  If func TRTDIV.LECPAYSIT(VALEUR)<>func TRTDIV.LECPAYSIT([M:ENT0]FCYORI) Then
# Le pays de ce site est différent de celui du site principal du salarié
    GMESSAGE=VALEUR-":"-mess(136,10701,1)
    mkstat=2
    End
  Endif
Endif
End



