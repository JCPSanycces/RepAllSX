      When "CATCSP" : [M]WCATCSP = [F:HRCCV]CATCSP : [M]CATCSP([M]WLIG) = [M]WCATCSP : Affzo [M]WCATCSP
# SEGAY 18/12/12 86717 bug 85016 US810 81491 84301
#      When "CATCSP" : [M]WCATCSP = [F:HRCCV]CATCSP : [M]CATCSP([M]WLIG) = [M]WCATCSP : Affzo [M]WCATCSP
