# SBA check leg WURS1 and WMED1
If func DIVPAYE.IS_GINTMT()
  If [M]FLGINT=2 & [M:CTR3]STACTR=2 : # Validé
  #If GINTMT=1 & [M]FLGINT=2 & [M:CTR3]STACTR=2 : # Validé
    If [M:CTR3]NBRPSN=0
    # Un contrat validé d'un intermittent doit contenir au moins une prestation
      GMESSAGE = mess(38,10701,1)
      OK = 0 : Return
    Endif
  Endif
  If [M]FLGINT=2 & [M:ENT2]NBRCTR>1
  #If GINTMT=1 & [M]FLGINT=2 & [M:ENT2]NBRCTR>1
    # L'entrée d'un intermittent doit être mono contrat
    GMESSAGE = mess(64,10701,1)
    OK = 0 : Return
  Endif
Endif
If [M]FLGMULCTR<>2 & [M]NBRCTR>1
 # Le salarié n'est pas coché multi-contrats
 # Vous ne pouvez saisir qu'un seul contrat
 GMESSAGE = mess(71,10701,1)-"\"-mess(72,10701,1)
 OK = 0 : Return
