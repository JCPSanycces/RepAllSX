$MODIF
For I=1 To NBTBL
 TABLE = TBTABLE(I)
 Gosub DEFAUT From WPDEFTABLE
 If TABLE="EMPLOCTR"
  # Ajout
  ZONE ="FLGADD"
  Gosub SET_ZONE
  If MA & [M]FLGADD
   Delete [F] Where REFNUM=[F:ID]REFNUM
   If fstat=1
    GOK = -1 : GLOCK = "$"+TABLE-[F:ID]REFNUM : Break
   Endif
   Delete [F:ECT] Where REFNUM=[F:ID]REFNUM
   If fstat=1
     GOK = -1 : GLOCK = "$EMPCTR"-[F:ID]REFNUM : Break
    Endif
   Raz [M]FLGADD
   Raz [F:HRCTR] : # SEGAY 05/10/12  US810 81491 84301
   Gosub MAJZONE
  Else
   # Modif
   ZONE ="FLGMOD"
   Gosub SET_ZONE
   If MA
    For nolign=1 To [M]NBRCTR
     If [M]FLGMOD(nolign-1)
&    or func DIVPAYE.IS_GINTMT()  #  SEGAY 05/10/12 bug 85016 US810 81491 84301
#      Filter [F] Where CTRNUM=[M]CTRNUM(nolign-1)
      Filter [F] Where REFNUM=[F:ID]REFNUM & CTRNUM=[M]CTRNUM(nolign-1)
      Readlock [F] First
      #JOJAC - START
      Filter [F]
      #JOJAC - END
      If fstat=1
       GOK = -1 : GLOCK = "$"+TABLE-[M]CTRNUM(nolign-1) : Break 2
      Elsif fstat
       GOK = 0 : Call RSTA(TBABREV(I),[M]CTRNUM(nolign-1)) From GLOCK : Break 2
      Endif
      Filter [F]
#  SEGAY 05/10/12 Bug 85016 US810 81491 84301
      #If GINTMT=1
      If func DIVPAYE.IS_GINTMT()
        Gosub INTERM
      Endif
#  END 05/10/12 US810 81491 84301
      [F] = [M]
      Gosub CAISSE
      #JOJAC - START
      ### SBA : delete
      ###Gosub SAVE_CLAUSE
      #JOJAC - END
      Gosub MODUSR
      Rewrite
      If fstat
       GOK = 0 : Call FSTA(TBABREV(I)) From GLOCK : Break 2
      Endif
     Endif
    Next nolign
   Endif
  Endif
 Else
  Filter [F] Where REFNUM=[M:ENT0]REFNUM
  Readlock [F] First
  Filter [F]
  If fstat=1
   GOK = -1 : GLOCK = "$"+TABLE-[M:ENT0]REFNUM : Break
  Elsif fstat
   nolign = 1
   Gosub DECHARGE
   Gosub CREUSR
   Write
  Else
   nolign = 1
   Gosub DECHARGE
   Gosub MODUSR
   Rewrite
  Endif
 Endif
 If fstat
  GOK = 0 : Call FSTA(TBABREV(I)) From GLOCK : Break
 Endif
 # 41771
 If TABLE = "EMPLOEXN"
  Filter [F] Where REFNUM=[M:ENT0]REFNUM & NUMLIG=2
  Readlock [F] First
  Filter [F]
  If fstat=1
   GOK = -1 : GLOCK = "$"+TABLE-[M:ENT0]REFNUM : Break
  Elsif fstat
   Gosub DECHARGE
   [F]NUMLIG = 2
   [F]EXSVAR = "#10553"
   Gosub CREUSR
   Write
  Else
   Gosub DECHARGE
   [F]NUMLIG = 2
   [F]EXSVAR = "#10553"
   Gosub MODUSR
   Rewrite
  Endif
 Endif
 # fin 41771
Next
If GINTMT=1
#JOJAC
 #Delete [PSN]PSN0=[M:ENT2]CTRNUM
  Delete [PSN] Where CTRNUM=[M:ENT2]CTRNUM & CTRDAT=[M:ENT2]CTRDAT
#JOJAC
 If fstat=1 | fstat>5
 #JOJAC
  #GOK=0 : Call RSTA("PSN",[M:ENT2]CTRNUM) From GLOCK : Return
  GOK=0 : Call RSTA("PSN",[M:ENT2]CTRNUM-num$([M:ENT2]CTRDAT)) From GLOCK : Return
 #JOJAC
Endif
 #SBA
 If func DIVPAYE.IS_GINTMT() and [M:CTR3]NBRPSN>0
 #If  [M:CTR3]NBRPSN>0
  Raz [F:PSN]
   #FRLAA - 2016-06-17 - REQUIREMENT 114309 US 211 - START
    If dim([F:PSN]UPDDAT)>0           :     [F:PSN]UPDDAT = date$         : Endif
    If dim([F:PSN]UPDUSR)>0           :     [F:PSN]UPDUSR = GUSER         : Endif
    If dim([F:PSN]UPDTIM)>0           :     [F:PSN]UPDTIM = time          : Endif
    If dim([F:PSN]UPDDATTIM)>0        :     [F:PSN]UPDDATTIM = datetime$  : Endif
#  [F:PSN]UPDDAT = date$
#  [F:PSN]UPDUSR = GUSER
#  [F:PSN]UPDTIM = time
   #FRLAA - 2016-06-17 - REQUIREMENT 114309 US 211 - END
  Gosub CRE_PSN
 Endif
Endif
