Subprog AS_WADD(VALEUR)
Variable Integer VALEUR
Local Char    ZONE(10) : ZONE = "WLIG"
Local Integer K
Gosub SET_ZONE
If [M]WCTRDAT<>[0/0/0] & [M]WCTRNUM=""
 [M]FLGADD = 1
 Local Integer NOL
 NOL = [M]NBRCTR
 If len([M]REFNUM)>0
  K = val(right$(max([M:ENT2]CTRNUM(0..[M:ENT2]NBRCTR-1)),len([M]REFNUM)+1))
  [M]WCTRNUM = [M]REFNUM+num$(K+1)
 Else
  [M]WCTRNUM = num$([M]NBRCTR)
 Endif
 # Attention à l'ordre pour la gestion des masques par défaut
 Gosub DECHARGE_CTR
 [M]NBRCTR += 1
 Sorta [M]NBRCTR [M]NBRCTR Order By [M]CTRDAT(indice)Desc
 #VALEUR = 1
 [M]WLIG = find([M]WCTRNUM,[M]CTRNUM(0..[M]NBRCTR-1))-1
 NOL = [M]WLIG
 Gosub CHARGE_CTR
Endif
End
