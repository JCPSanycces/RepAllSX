L_FORCE = 1
#Is something is calculated, we have to warn
L_OK = 1

#We ask only if there is something to do...
Filter [POD] Where [POD]COD=VALEUR
Read [POD]POD0 First
If fstat<4
 L_OK = 2
Endif
Filter [JOD]

L_TYPMAJ="[M]W"

If func SUBCTR.IS_INIT_CTR(VALEUR,1)
  Call OUINON(mess(89,10701,1),L_OK) From GESECRAN

  #### Voulez-vous initialiser ce contrat par les données du poste ?
  If L_OK=2
   If GPAYE : VCLLCVT=[M]WCLLCVT :  Else : VCLLCVT="" : Endif    : #70013 #70013 SEGAY 21/12/12 86859
   Call INIT_CTR(VALEUR,1,[M]WETRFCY,L_FORCE,VCLLCVT,L_TYPMAJ) From SUBHRENT
   mkstat = 0
  Else
   L_OK=0
  Endif
Endif #END_BUG 72064
Return

