Subprog C_DATBRN(VALEUR)
Variable Date    VALEUR
# Display\hide fields based on legilation code
Local Char    WDATE
WDATE=VALEUR
Gosub CTR_DATBRN
End

$CTR_DATBRN
# FQ81085 US524 - SEGAY 05/07/12
# Display\hide fields based on legilation code
Local Char    LISTLEG(5)(1..10)
Local Char    WCRIT(250)
Local Integer WNBLEG
Local Integer WOK
WOK=2
#[M]FLGDATBRN=0
WNBLEG=0
If WDATE < "000001"
 Call LIST_LEG_EML([M:ENT0]REFNUM, [M:ENT0]LEGORI,2, LISTLEG, WNBLEG, WCRIT) From TOOLSHRLEG

 If find("BRI",LISTLEG) > 0 or ([M:ENT0]LEGORI="BRI")
  If WNBLEG > 1 or (WNBLEG=1 & ([M:ENT0]LEGORI<>"BRI"))
# "La date de naissance est obligatoire pour la législation BRI."
# "Êtes-vous sûr que vous ne voulez pas la saisir ?"
     Call AVERTIR (mess(133,10701,1)-mess(134,10701,1),WOK) From GESECRAN
     If WOK=1
      mkstat = 2
      Return
     Else
#      [M]FLGDATBRN=1
     Endif
  Else
    GMESSAGE = mess(133,10701,1) # "La date de naissance est obligatoire pour la législation BRI."
    mkstat = 2 : Return
  Endif
 Endif
Endif
Return

