#  SEGAY 05/10/12  US810 81491 84301
######################################################################################

Subprog INIT_CTR(L_COD, L_TYP,L_FCY,L_FORCE,CLL_CVT,L_TYPMAJ)
Value    Char    L_COD()      : # Code for POSTE or JOBTYP
Value    Integer L_TYP        : # 1 for POSTE, 2 for JOBTYP, 3 PROFIL
Value    Char    L_FCY()      : #
Value    Integer L_FORCE      : # 1 Force update else don't do anything
Value    Char    CLL_CVT      : # Empty don't use, else Convention
Value    Char    L_TYPMAJ
If L_FCY<>[F:FCY]FCY
 Read [FCY]FCY0=L_FCY
 If fstat : Raz [F:FCY] : Endif
Endif
Local Char    L_POPUL(GLONPOP)(0..)
Local Integer L_NB_POPUL
Local Char    L_CRITERE(GDIMFIC)
Local Integer L_IJ
Local Char    ZONE(10)               : # For SET_ZONE
Local Char    L_CODFLD(type([F]FLD)-10)(0..)
Local Integer NB_COD
Local Integer L_WLIG

#MABOS-05/11/12-Pas utile ici
#Call CHARGE_POPUL([M]REFNUM,L_POPUL,L_NB_POPUL) From SUBCTR

If GTEST=1 & GTRACE=""
 Call OUVRE_TRACE(mess(6,10485,1)-[M]REFNUM-[M]CTRNUM(nolign-1)) From LECFIC
 #### Modifs contrat
 Call ECR_TRACE(string$(20,"*")-string$(L_TYP=1,"POSTE")-string$(L_TYP=2,"JOBTYP")
&              -string$(L_TYP=3,"PROFIL")-string$(20,"*"),0) From GESECRAN
Endif

Raz NB_COD, L_CODFLD

#DKA - 23/08/2012 - Moved order around to follow order set in Local Menu 10508
# Convention
If CLL_CVT<>""
 L_CRITERE = "[F]CLLCVT='"+CLL_CVT+"'"
 If GTRACE<>""
  Call ECR_TRACE(string$(50,"*"),0) From GESECRAN
  Call ECR_TRACE(L_CRITERE,0) From GESECRAN
 Endif
 Gosub CHARGE_DEF
Endif

# Facility
L_CRITERE = "[F]FCY='"+L_FCY+"'"
If GTRACE<>""
 Call ECR_TRACE(string$(50,"*"),0) From GESECRAN
 Call ECR_TRACE(L_CRITERE,0) From GESECRAN
Endif
Gosub CHARGE_DEF

# Company
L_CRITERE = "[F]CPY='"+[F:FCY]LEGCPY+"'"
# SEGAY 06/02/12 Bug 79332
# On teste les groupes de société
Filter [F:AGC] Where CPY=[F:FCY]LEGCPY and [F:AGC]GRP <> [F:FCY]LEGCPY
Read [F:AGC]AGC1 First
If !fstat
   L_CRITERE += " or [F]CPY='"+[F:AGC]GRP+"'"
Endif
Filter [F:AGC]
Gosub CHARGE_DEF

# END Bug 79332

#MABOS-05/11/12-Pas utile ici
## Population
#For L_IJ=0 To L_NB_POPUL-1
# If L_POPUL(L_IJ)<>""
#  L_CRITERE = "[F]POP='"+L_POPUL(L_IJ)+"'"
#  If GTRACE<>""
#   Call ECR_TRACE(string$(50,"*"),0) From GESECRAN
#   Call ECR_TRACE(L_CRITERE,0) From GESECRAN
#  Endif
#  Gosub CHARGE_DEF
# Endif : # If L_POPUL(L_IJ)<>""
#Next L_IJ

#pca  order....
If L_TYP<>3
  L_CRITERE = "[F]LEGLEV='"+GCURLEG+"'"
  If GTRACE<>""
   Call ECR_TRACE(string$(50,"*"),0) From GESECRAN
   Call ECR_TRACE(L_CRITERE,0) From GESECRAN
  Endif
  Gosub CHARGE_DEF
Endif



If GTRACE<>""
 Call ECR_TRACE(string$(50,"*"),0) From GESECRAN
 Call ECR_TRACE(L_CRITERE,0) From GESECRAN
Endif
Gosub CHARGE_DEF

# Every body, need somebody (Jake & Elwood^^)
#PJC 14/08/12 ADDED THE leglev used in GESPOT/GESJOT
If GPAYE
  If L_TYP=3
   L_CRITERE = "[F]CPY=''&[F]FCY=''&[F]CLLCVT=''&[F]POP=''"
   Else
    L_CRITERE = "[F]CPY=''&[F]FCY=''&[F]CLLCVT=''&[F]POP=''&[F]LEGLEV=''"
  Endif
Else
  If L_TYP=3
   L_CRITERE = "[F]CPY=''&[F]FCY=''&[F]POP=''"
  Else
  L_CRITERE = "[F]CPY=''&[F]FCY=''&[F]POP=''&[F]LEGLEV=''"
  Endif
Endif
If GTRACE<>""
 Call ECR_TRACE(string$(50,"*"),0) From GESECRAN
 Call ECR_TRACE(L_CRITERE,0) From GESECRAN
Endif
Gosub CHARGE_DEF

If GTEST=1
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif

End
######################################################################################
$CHARGE_DEF
Case L_TYP
 When 1 : Gosub POSTE_DEF
 When 2 : Gosub JOBTYP_DEF
 When 3 : Gosub PROFIL_DEF
Endcase
Return
######################################################################################
$POSTE_DEF
For [POD]POD0 Where [F:POD]COD=L_COD & evalue(L_CRITERE)
 Gosub EVAL_DEF
Next : # [POD]POD0
Return
######################################################################################
$JOBTYP_DEF
For [JOD]JOD0 Where [F:JOD]COD=L_COD & evalue(L_CRITERE)
 Gosub EVAL_DEF
Next : # [JOD]JOD0
Return
######################################################################################
$PROFIL_DEF
For [HRPFD]PFD0 Where [F:HRPFD]PRFCOD=L_COD & [F:HRPFD]LEG=GCURLEG & evalue(L_CRITERE)
 Gosub EVAL_DEF
Next : # [PFD]PFD0
Return
######################################################################################
$EVAL_DEF
If [F]FLD="" | [F]VALINT="" : Return : Endif
Local Char WTYPMAJ
Onerrgo ERREUR
WTYPMAJ=L_TYPMAJ
If WTYPMAJ="[M]W"
 L_WLIG=[M]WLIG
 ZONE = "W"+[F]FLD
 Gosub SET_ZONE
 If !MA
   WTYPMAJ="[M]"
   ZONE = [F]FLD
   Gosub SET_ZONE2
 Endif
 If !MA : Return : Endif
Endif
#If evalue("dim([F]"+[F]FLD+")")>0 & ( L_FORCE=1 | evalue("varinit([F]"+[F]FLD+")")=0 )
#If evalue("dim([F:HRCTR]"+[F]FLD+")")>0 &  L_FORCE=1
If evalue("dim("+WTYPMAJ+[F]FLD+")")>0 &  L_FORCE=1
 If !find([F]FLD, L_CODFLD(0.. NB_COD-1))
  L_CODFLD(NB_COD) = [F]FLD
  NB_COD += 1

  # Small problem with numerical values....
  Case evalue("type("+WTYPMAJ+[F]FLD+")")
   When 1,2,4,5,6,7
        Assign WTYPMAJ+[F]FLD With val([F]VALINT)
        If WTYPMAJ="[M]W"
          Assign  "[M]"+[F]FLD+"("+num$(L_WLIG)+")" With val([F]VALINT)
        Endif
   When Default
        Assign WTYPMAJ+[F]FLD With [F]VALINT
        If WTYPMAJ="[M]W"
          Assign "[M]"+[F]FLD+"("+num$(L_WLIG)+")" With [F]VALINT
        Endif
  Endcase
  If L_TYPMAJ="[M]W"
    Affzo =WTYPMAJ+[F]FLD
    [M]FLGMOD(L_WLIG) = 1
  Endif
  If GTRACE<>""
   Call ECR_TRACE([F]FLD-[F]TIT-"="-[F]VALINT,0) From GESECRAN
  Endif
 Endif : # If !find([F]FLD, ...
Endif : # evalue("dim([M]"+[F]FLD+")")>0 ...
Onerrgo
Return

$ERREUR
Resume


Subprog GENEREDOC(MAT,DAT,CTR,DOC)
