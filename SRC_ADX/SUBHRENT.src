Subprog GRISE_SEVCTR(VALEUR,VALEUR2)
Value Integer VALEUR,VALEUR2
Local Char ZONE(10) : ZONE = "WSEVCTR"
Gosub SET_ZONE
If MA
 If VALEUR=2 & VALEUR2=2 : #Multi contrat + Gestion Paie
  [M]WSEVCTR = 2
  [M]SEVCTR([M]WLIG) = 2
  Grizo WSEVCTR
 Elsif VALEUR=1 & VALEUR2=2 : # Mono contrat + Gestion paie
  [M]WSEVCTR = 1
  [M]SEVCTR([M]WLIG) = 1
  Actzo WSEVCTR
 Else
  Effzo [M]WSEVCTR
  Raz [M]SEVCTR([M]WLIG)
  Grizo WSEVCTR
 Endif
Endif
End

