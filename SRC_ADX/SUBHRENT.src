Subprog AS_NBRCTR
Gosub SETNOL
If NOL>=0 & [M]NBRCTR>0
 If NOL<[M]NBRCTR
  Gosub CHARGE_CTR
 Else
  If [M]FLGMULCTR<>2
   # La salarié n'est pas coché multi-contrats
   GMESSAGE = mess(71,10701,1)
   mkstat=2 : End
  Endif
  [M]WLIG = NOL
  Effzo 20-50
  Local Char ZONE(10) : ZONE = "WADD"
  Gosub SET_ZONE
  Effzo
  #  SEGAY 05/10/12 US810 81491 84301
  ZONE = "WENT4"
  Gosub SET_ZONE
  Effzo
  #  END SEGAY 05/10/12 US810 81491 84301
 Endif
Endif
End

Subprog C_NBRCTR
Local Integer OK
If status=82 : mkstat = 1 : Endif
# SEGAY - 18/01/13 - US 1231 81085 - New type of document HRCTRDOC
#If find(status,65,68,83)
# [M]FLGADD = 1
#Endif
If find(status,65)
 [M]FLGADD = 1
# On stocke dans le tableau invisible, les compétences supprimées
 If status=65 & [M:ENT2]FLGOLDCTR(nolign-1)<>""
   If [M:ENT2]NBRDLTCTR>=dim([M:ENT2]NUMDLTCTR)
    # Veuillez enregistrer les modifications avant de continuer.
    GMESSAGE = mess(558,9900,1)
    mkstat=2 : End
   Endif
   [M:ENT2]NUMDLTCTR([M:ENT2]NBRDLTCTR) = [M:ENT2]CTRNUM(nolign-1)
   [M:ENT2]DATDLTCTR([M:ENT2]NBRDLTCTR) = [M:ENT2]CTRDAT(nolign-1)
   [M:ENT2]NBRDLTCTR +=1
 Endif
Endif
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

