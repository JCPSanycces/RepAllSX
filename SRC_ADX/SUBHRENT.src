######################################################################################
Subprog SETCPYLGEG(VALEUR,CIV,OKPAR)
Value Char VALEUR
Value Integer CIV
Variable Integer OKPAR
If VALEUR <>""
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 If [F:FCY]CRY<>""
  [M:ENT0]FCYCRY=[F:FCY]CRY
 Else
  [M:ENT0]FCYCRY=[F:CPY]CRY
 Endif
 [M:ENT0]CPYORI=[F:CPY]CPY
 [M:ENT0]LEGORI=[F:CPY]LEG
 GSOCIETE=[F:CPY]CPY
 GCURLEG=[M:ENT0]LEGORI
Else
 [M:ENT0]CPYORI=""
 [M:ENT0]LEGORI=GLEGFIL
Endif
Affzo [M:ENT0]6-11

#SBA reprise test CIVIL from SUBEML2
#Local Char NUMTAB
Local Integer NUMTAB
Local Char TMP_LEG

Call VERIF_AML_EML(VALEUR,CIV,1,"CIVIL",NUMTAB,TMP_LEG,TMP_LEG,OKPAR) From SUBEML2

#Call PARAM([F:CPY]LEG,"CIVIL",NUMTAB) From ADOVAL
#If NUMTAB<>"0"
If OKPAR
  #[M:ENT0]NOLIB=val(NUMTAB)
  [M:ENT0]NOLIB=NUMTAB
  Actzo [M:ENT0]CIVA
  [M:ENT0]CIV  = CIV
  If(CIV<>0)
    [M:ENT0]CIVA = mess(CIV,[M:ENT0]NOLIB,1)
  Else
    [M:ENT0]CIVA=""
  Endif
Else
# GMESSAGE=mess(130,10701,1) : # Le paramètre CIVIL n'est pas correctement renseigné
 #[M:ENT0]NOLIB=0
 [M:ENT0]CIVA=""
Endif
# fin modif SBA
Affzo [M:ENT0]CIVA
Call DISPLAY_HIDE()From SUBHRENTLEG

End
