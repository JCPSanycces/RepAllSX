Subprog AM_WETRFCY(VALEUR)
Variable Char    VALEUR()
Local Char ZONE(10)
Local Integer ORGLINE,COUNTER #FRLAA Issue 2017-04-25
[M]ETRFCY([M]WLIG) = VALEUR
[M]FLGMOD([M]WLIG) = 1

# Multi_leg & multi_société
#SBA
#Call LECTURE("FCY",VALEUR,"") From CONTOBJ
#Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
#GSOCIETE=[F:CPY]CPY
#GCURLEG=[F:CPY]LEG

#67743
If GPAYE
 ZONE = "WMED1"
 Gosub SET_ZONE
 If MA
#MIPEA - 2016-09-28 - X3PEOP-752 - START
Filter [ADIZZ] Where [ADIZZ]NUMTAB = 10469 & [ADIZZ]LEG = GCURLEG # & [ADIZZ]CODE = [V]GINDMED

For [ADIZZ]
  [L]COUNTER+=1
   If [ADIZZ]CODE = [V]GINDMED
    [L]ORGLINE=[L]COUNTER-1 : Break
   Endif
Next
  Call ORGANISME([M:ENT0]REFNUM,VALEUR,[M]WCTRNUM,[M]WMED1,[L]ORGLINE) From SUBORG
  #Call ORGANISME([M:ENT0]REFNUM,VALEUR,[M]WCTRNUM,[M]WMED1,[V]GINDMED-1) From SUBORG
#MIPEA - 2016-09-28 - X3PEOP-752 - END
  Affzo [M]WMED1
  [M]MED1([M]WLIG) = [M]WMED1
 Endif
 ZONE = "WURS1"
 Gosub SET_ZONE
 If MA
  Call ORGANISME([M:ENT0]REFNUM,VALEUR,[M]WCTRNUM,[M]WURS1,[L]ORGLINE) From SUBORG #HEGES 2017-04-26
  Affzo [M]WURS1
  [M]URS1([M]WLIG) = [M]WURS1
 Endif
Endif
#SEGAY US60 01/11/10 Refresh AGNMIDWRK based on legislation - move to SUBCTRLEG?
ZONE = "WTYPJOB"
Gosub SET_ZONE
If MA
 Call GRISE_AGENCE([M]WTYPJOB)
Endif
#SEGAY 05/10/12 US810 81491 84301
[M:ENT3]WETRFCYA=VALEUR
Affzo [M:ENT3]WETRFCYA
Affzo [M:ENT3]ZWETRFCYA
#  END SEGAY 05/10/12 US810 81491 84301


##JOJAC - 2016-07-25 - REQ114309 - START
Read [F:FCY]FCY0 = VALEUR
[M:ENT2]WCLLCVT = [F:FCY]CLLCVT
Affzo [M:ENT2]WCLLCVT
##JOJAC - 2016-07-25 - REQ114309 - END

End

