    Delete [HRTXC]TXC2(2)=[M]REFNUM;[M]CTRNUM(nolign-1)
    If fstat=1
      GOK = -1 : GLOCK = "$TXTCTR"-[M]REFNUM-[M]CTRNUM(nolign-1)
    Endif
    If GOK<1 : Return : Endif

    [M]FLGCRE1(nolign-1)=1
    [M]WFLGCRE1=1
  Else
    If [M]FLGOLDCTR(nolign-1) <> "" &  ([M]FLGOLDCTR(nolign-1)<>[M]CTRNUM(nolign-1) | [M]FLGOLDDAT(nolign-1)<>[M]CTRDAT(nolign-1))
       Call MAJ_CTRDOC_TXTCTR([M]REFNUM,[M]REFNUM,[M]FLGOLDCTR(nolign-1),[M]CTRNUM(nolign-1),[M]FLGOLDDAT(nolign-1),[M]CTRDAT(nolign-1),GOK) From SUBHRENT
       If GOK<1 : Return : Endif
    Endif
  Endif

  Local Char NUMLIB(10) : # For TEST LEG of Clause HRTXT with LEG of contract
  Local Integer ONLEG   :#- 1 : Parameter TYPDOC on the leg or 0: Not
  Local Integer WNBRCLCSPE   :# number specif clause
  Local Integer WI
  Local Integer WI,WJ
  Local Integer WMODIF

  For [HRDOC] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM(nolign-1) & CTRDAT=[M]CTRDAT(nolign-1)
    Readlock [HRDOC] Curr
    If fstat=1
     GOK=-1 : GLOCK="$HRCTRDOC"-[M]REFNUM-[M]CTRNUM(nolign-1)-[M]CTRDAT(nolign-1) : Break 1
    Elsif fstat
     GOK=0 : Call FSTA("HRDOC") From GLOCK : Break 1
    Endif
    ONLEG=0
    Call PARAM([M:ENT0]LEGORI,"TYPDOC",NUMLIB,ONLEG) From SUBHRCLC
    WNBRCLCSPE = dim([F:HRDOC]CLAUSESPE)
    For WI=0  To  WNBRCLCSPE -1
        If [L]ONLEG & [F:HRDOC]CLAUSESPE(WI) <> "" & [F:HRDOC]CLAUSESPELEG(WI) = ""
           [F:HRDOC]CLAUSESPE(WI)=""
           WMODIF=1
           Delete [HRTXC]TXC2=[F:HRDOC]REFNUM;[F:HRDOC]CTRNUM;[F:HRDOC]CTRDAT;[F:HRDOC]COD;[F:HRDOC]CLAUSESPE(WI);[F:HRDOC]CLAUSESPELEG(WI)
           If fstat=1
              GOK = -1 : GLOCK = "$TXTCTR"-[F:HRDOC]REFNUM-[F:HRDOC]CTRNUM-[F:HRDOC]CTRDAT-num$([F:HRDOC]COD)
              Break 2
           Endif
           Rewrite [HRDOC]
           If fstat
            GOK=0 : Call FSTA("HRDOC") From GLOCK : Break 2
           Endif
        Endif
     Next
     If WMODIF
        Raz [F:HRDOCW]
        [F:HRDOCW]=[F:HRDOC]
        Raz [F:HRDOC]CLAUSESPE
        Raz [F:HRDOC]CLAUSESPELEG
        WJ=0
        For WI=0  To  WNBRCLCSPE -1
            If [F:HRDOCW]CLAUSESPE(WI) <> ""
              [F:HRDOC]CLAUSESPE(WJ)=[F:HRDOCW]CLAUSESPE(WI)
              [F:HRDOC]CLAUSESPELEG(WJ)=[F:HRDOCW]CLAUSESPELEG(WI)
              WJ+=1
            Endif
        Next
     Endif
   Next
Endif
If GOK<1 : Return : Endif
[M]FLGOLDCTR(nolign-1)=[M]CTRNUM(nolign-1)
[M]FLGOLDDAT(nolign-1)=[M]CTRDAT(nolign-1)
Return
# END SEGAY 18/01/13 US 1231 81085

# SEGAY 18/01/13 US 1231 81085
# Mise à jour des documents à généner
#**
#* MAJ CTRDOC & TXTCTR
#* SEGAY
#* @param PREFNUM  : current REFNUM
#* @param PNEWREFNUM  : NEW REFNUM
#* @param POLDCTRNUM  : OLD REFNUM
#* @param PNEWCTRNUM  : NEW REFNUM
#* @param POLDDAT     : OLD DAT
#* @param PNEWDAT     : NEW DAT
#* @param GOK         : IS good or no
#*
#*!
Subprog MAJ_CTRDOC_TXTCTR(PREFNUM,PNEWREFNUM,POLDCTRNUM,PNEWCTRNUM,POLDDAT,PNEWDAT,GOK)
Value Char PREFNUM()
Value Char PNEWREFNUM()
Value Char POLDCTRNUM()
Value Char PNEWCTRNUM()
Value Date POLDDAT
Value Date PNEWDAT
Variable Integer GOK

Local Integer ONLEG   :#- 1 : Parameter TYPDOC on the leg or 0: Not
Local Char NUMLIB(10) : # For TEST LEG of Clause HRTXT with LEG of contract
Local Char CRITLEG(250) : # For TEST LEG of Clause HRTXT with LEG of contract
Local Integer WNBRCLCSPE   :# number specif clause
Local Integer WI,WJ
Local Integer WMODIF

For [HRDOC] Where REFNUM=PREFNUM & CTRNUM=POLDCTRNUM & CTRDAT=POLDDAT
  Readlock [HRDOC] Curr
  If fstat=1
   GOK=-1 : GLOCK="$HRCTRDOC"-PREFNUM-POLDCTRNUM-POLDDAT : Break 1
  Elsif fstat
   GOK=0 : Call FSTA("HRDOC") From GLOCK : Break 1
  Endif
  ONLEG=0
  CRITLEG = '1=1'
  Call PARAM([M:ENT0]LEGORI,"TYPDOC",NUMLIB,ONLEG) From SUBHRCLC
  If [L]ONLEG Then
    CRITLEG-=' & [F:HRTXC]LEG = [M:ENT0]LEGORI'
  Else
    CRITLEG-=' & ( [F:HRTXC]LEG = [M:ENT0]LEGORI | [F:HRTXC]LEG="" )'
  Endif

  If [F:HRDOC]FLGCRE = 2
   # Mise à jour des documents d'entrée
    WMODIF=0
    WNBRCLCSPE = dim([F:HRDOC]CLAUSESPE)
    For WI=0  To  WNBRCLCSPE -1
        If [L]ONLEG & [F:HRDOC]CLAUSESPE(WI) <> "" & [F:HRDOC]CLAUSESPELEG(WI) = ""
           [F:HRDOC]CLAUSESPE(WI)=""
           WMODIF=1
           Delete [HRTXC]TXC2=[F:HRDOC]REFNUM;[F:HRDOC]CTRNUM;[F:HRDOC]CTRDAT;[F:HRDOC]COD;[F:HRDOC]CLAUSESPE(WI);[F:HRDOC]CLAUSESPELEG(WI)
           If fstat=1
              GOK = -1 : GLOCK = "$TXTCTR"-[F:HRDOC]REFNUM-[F:HRDOC]CTRNUM-[F:HRDOC]CTRDAT-num$([F:HRDOC]COD)
              Break 2
           Endif
        Endif
    Next

    If WMODIF
      Raz [F:HRDOCW]
      [F:HRDOCW]=[F:HRDOC]
      Raz [F:HRDOC]CLAUSESPE
      Raz [F:HRDOC]CLAUSESPELEG
      WJ=0
      For WI=0  To  WNBRCLCSPE -1
          If [F:HRDOCW]CLAUSESPE(WI) <> ""
            [F:HRDOC]CLAUSESPE(WJ)=[F:HRDOCW]CLAUSESPE(WI)
            [F:HRDOC]CLAUSESPELEG(WJ)=[F:HRDOCW]CLAUSESPELEG(WI)
            WJ+=1
          Endif
      Next
    Endif
    For [HRTXC] Where REFNUM=PREFNUM & CTRNUM=POLDCTRNUM & CTRDAT=POLDDAT & [F:HRDOC]COD & evalue(CRITLEG)
      Readlock [HRTXC] Curr
      If fstat=1
       GOK=-1 : GLOCK="$TXTCTR"-PREFNUM-POLDCTRNUM-POLDDAT : Break 2
      Elsif fstat
       GOK=0 : Call FSTA("HRTXC") From GLOCK : Break 2
      Endif
      [F:HRTXC]REFNUM = PNEWREFNUM
      [F:HRTXC]CTRNUM = PNEWCTRNUM
      [F:HRTXC]CTRDAT = PNEWDAT
      Rewrite [HRTXC]
      If fstat
       GOK=0 : Call FSTA("HRTXC") From GLOCK : Break 2
      Endif
    Next
    For [HRTXC] Where REFNUM=PREFNUM & CTRNUM=POLDCTRNUM & CTRDAT=POLDDAT & [F:HRDOC]COD
      Readlock [HRTXC] Curr
      If fstat=1
       GOK=-1 : GLOCK="$TXTCTR"-PREFNUM-POLDCTRNUM-POLDDAT : Break 2
      Elsif fstat
       GOK=0 : Call FSTA("HRTXC") From GLOCK : Break 2
      Endif
      Delete [HRTXC] Curr
      If fstat=1
         GOK = -1 : GLOCK = "$TXTCTR"-PREFNUM-POLDCTRNUM-POLDDAT
         Break 2
      Endif
    Next


    [F:HRDOC]REFNUM = PNEWREFNUM
    [F:HRDOC]CTRNUM = PNEWCTRNUM
    [F:HRDOC]CTRDAT = PNEWDAT
    Rewrite [HRDOC]
    If fstat
     GOK=0 : Call FSTA("HRDOC") From GLOCK : Break 1
    Endif
  Else
    Delete [HRTXC]TXC2(4)=PREFNUM;POLDCTRNUM;POLDDAT;[F:HRDOC]COD
    If fstat=1
       GOK = -1 : GLOCK = "$TXTCTR"-PREFNUM-POLDCTRNUM-POLDDAT-num$([F:HRDOC]COD)
       Break 1
    Endif
    Delete [HRDOC] Curr
    If fstat=1
       GOK = -1 : GLOCK = "$HRDOC"-num$([F:HRDOC]COD)-[F:HRDOC]REFNUM-[F:HRDOC]CTRNUM-[F:HRDOC]CTRDAT
       Break 1
    Endif
  Endif
Next
If GOK<1 : End : Endif
End

$CRE_PSN
[F:PSN]CTRNUM    = [M:ENT2]CTRNUM
[F:PSN]REFNUM    = [M:ENT0]REFNUM
[F:PSN]CTRDAT    = [M:ENT2]CTRDAT
For nolign=1 To [M]NBRPSN
 [F:PSN]       = [M:CTR3]
 [F:PSN]PSNNUM = nolign
 Write [PSN]
 If fstat
  GOK=0 : Call FSTA("PSN") From GLOCK : Break
 Endif
Next
If GOK=0 : Return : Endif
Return

#  SEGAY 05/10/12 Bug 85016 US810 81491 84301
$INTERM
  [F:HRCTR]PSNTYP=[M:CTR3]PSNTYP
  [F:HRCTR]TYPCAC=[M:CTR3]TYPCAC
  [F:HRCTR]STACTR=[M:CTR3]STACTR
  [F:HRCTR]CALPAY=[M:CTR3]CALPAY
  [F:HRCTR]OBJCTR=[M:CTR3]OBJCTR
  [F:HRCTR]LIEU=[M:CTR3]LIEU
Return

