Funprog GET_NCKMAN()
Local Char RES
Local Char WNAM
WNAM=[M:ENT1]OLDNAM
If WNAM=""
   WNAM=[M:ENT0]NAM
Endif
RES=toupper(left$(vireblc([M:ENT0]SRN,4),2)+left$(vireblc(WNAM,4),3))
End RES

Subprog CHECK_LEGORG(CODE,LEG)
Value Char CODE
Value Char LEG
Local Integer RES
RES=0
#GMESSAGE = VALEUR-":"-mess(14,10712,1)-"["+[L]LEG+"]"
If(CODE<>"")
  If clalev([F:TORG_])=0 : Local File ORGANISME [TORG_] : Endif
  Read [TORG_]ORG0=LEG;CODE
  If(fstat)
    mkstat=2
    GMESSAGE = CODE-":"-mess(14,10712,1)-"["+LEG+"]"
  Endif
   Filter [TORG_]
Endif
End

