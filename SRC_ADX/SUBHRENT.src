# SEGAY - 31/05/13 - FQ90058 FQ90059
$MAJ_EMPLOPOT
If [F:HRCTR]FLGVAR=2 : Return : Endif
Delete [EPO] Where [F:EPO]REFNUM=[M:ENT0]REFNUM
&                & [F:EPO]CTRNUM=[M]CTRNUM(nolign-1)
&                & [F:EPO]DATPOT=[M]CTRDAT(nolign-1)
&                & [F:EPO]ORIGINE=1
If fstat=1
 GOK = -1 : GLOCK = "$EMPLOPOT"-[M:ENT0]REFNUM+"\"+[M]CTRNUM(nolign-1)+"\"+[M]CTRDAT(nolign-1)+"\1" : Return
Endif
If [F:HRCTR]SUICAR = 2
  Raz [F:EPO]
  [F:EPO]JOBPOT = [F:HRCTR]JOBPOT
  [F:EPO]POT    = [F:HRCTR]POT
  [F:EPO]REFNUM = NEWREFNUM
  [F:EPO]CTRNUM = NEWCTRNUM
  [F:EPO]DATPOT = [M]CTRDAT(nolign-1)
  [F:EPO]ORIGINE = 1 : # ML 10399 Automatique
  If dim([F:EPO]CREUSR)>0       : [F:EPO]CREUSR = GUSER         : Endif
  If dim([F:EPO]CREDAT)>0       : [F:EPO]CREDAT = date$         : Endif
  If dim([F:EPO]CRETIM)>0       : [F:EPO]CRETIM = time          : Endif
  If dim([F:EPO]CREDATTIM )>0   : [F:EPO]CREDATTIM = datetime$  : Endif #FRLAA - 2016-06-17 - REQUIREMENT 114309 US 211
  Write [EPO]
  If fstat
   GOK = 0 : Call FSTA("EPO") From GLOCK : Return
  Endif
Endif
Return


