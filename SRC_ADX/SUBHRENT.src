[M:DIA]CTRFIN = CTR
[L]DOCUMENT=DOC
[M:DIA]FLGUPD = 2
[M:DIA]LEG =GCURLEG # SEGAY 18/01/13 US 1231 81085
Gosub ADD_CRIT From TRTGENCTR
Gosub TR1 From TRTGENCTR
Close Local Mask [DIA]
End

