# SEGAY 18/01/13 US 1231 81085
If  dim([V]WGDIFLEG)>0
  Raz [V]WGDIFLEG
  If GREP<>"C"
     Read [IDB]ID0=[M:ENT0]REFNUM
     If !fstat
       If [F:IDB]FCYORI<>[M]FCYORI
          Call GET_LEGFCY([F:IDB]FCYORI,OK,WLEGOLD,0)From TOOLSHRLEG
          Call GET_LEGFCY([M]FCYORI,OK,WLEGNEW,0)From TOOLSHRLEG
          OK=1
          If WLEGOLD<>WLEGNEW Then
            [V]WGDIFLEG=1
          Endif
       Endif
     Endif
  Endif
Endif
# END SEGAY 18/01/13 US 1231 81085

