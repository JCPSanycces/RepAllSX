WECR="ENTSAL2"
zonsui="CTRDAT("+num$(NOL)+")"
#If(ZFIELD="WURS1" or ZFIELD="WMED1")
# SEGAY 18/01/13 US 1231 81085
If(ZFIELD="WURS1" or ZFIELD="WMED1" or ZFIELD="WCATCSP" or ZFIELD="WSTACAT")
  If clalev([F:AWIN])=0 : Local File AWINDOW [AWIN] : Endif
  Read [F:AWIN]AWI0 = "OHRENT"
  DEBMES=mess(16,115,1)-func AFNC.TEXTE([F:AWIN]INTMSK(2))+'\'
  WECR="ENTSAL3"
Endif
If clalev([F:AMZ_])=0 : Local File AMSKZON [AMZ_] : Endif
Read [F:AMZ_]CODE=WECR;ZFIELD
If !fstat
