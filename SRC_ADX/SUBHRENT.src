#      Affzo [M:ENTSAL2]CUR #TODO : DEHEN - [M:ENTSAL2] : Class Non-existent - @GX3APP.TRT/SUBHRENT$adx(4954) : Affzo [M:ENTSAL2]CUR
#    Endif
#  Endif

If VALEUR = ""
    #If clalev([F:ZCPY]) : Local File COMPANY [F:ZCPY] : Endif #Moved to OUVRE
    Read [F:CPY]CPY0 = [M:ENT0]CPYORI # Removed [M:ENTSAL0] and replaced only with screen abrev code
    If !fstat
      VALEUR = [F:CPY]ACCCUR # VALUER will never populate the field since it is not assigned
      [M:ENT2]CUR = VALEUR
      Affzo [M:ENT2]CUR # Removed [M:ENTSAL2] and replaced only with screen abrev code
    Endif
  Endif
#DEHEN - END

End
