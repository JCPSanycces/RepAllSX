## Endif
# Affzo [CTR3]
#Endif
#End
#  SEGAY 05/10/12 US810 81491 84301
Subprog GRISE_INT(INTMT)
Value Integer INTMT
If INTMT<>2 : # Salarié non intermittent
 [CTR3]CALPAY = 1
 #JOJAC - START
 If varmode([M:CTR3]CALPAY)=0
  #JOJAC - END
  Grizo [CTR3]CALPAY
  Affzo [CTR3]CALPAY
  #JOJAC - START
 Endif
 #JOJAC - END
 Effzo [CTR3]
 [M:CTR3]STACTR = 2 : # Validé
 Grizo [CTR3]
 Affzo [CTR3]
Else               : # Salarié intermittent
#JOJAC - START
 If varmode([M:CTR3]CALPAY)=0
#JOJAC - END
  Actzo [CTR3]CALPAY
  Affzo [CTR3]CALPAY
 Endif
 Effzo [CTR3]
 Actzo [CTR3]
#76817
# If GOPTCANA>0
#  [M:CTR3]NBAXE = GOPTCANA
# Endif
 Affzo [CTR3]
Endif
End


