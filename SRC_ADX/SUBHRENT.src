Subprog GRISE_CDD(VALEUR)
Value Char VALEUR ()
#JOJAC - START
Local Integer WISTRAINEE
#JOJAC - END
Local Char ZONE(10) : ZONE = "WENDCON"
Gosub SET_ZONE
If MA
#JOJAC - START
 #FRLAA - 2016-06-02 - REQUIREMENT 114309 US 211 - START
 #WISTRAINEE=func DIVPAYE.ISTRAINEE_NAT(VALEUR)  : #US3750 108474 Stagiaire
 WISTRAINEE=func DIVPAYE.ISTRAINEE(VALEUR)  : #US3750 108474 Stagiaire
 #FRLAA - 2016-06-02 - REQUIREMENT 114309 US 211 - END

 Gosub CHGTZON_MATREMP From SUBHRENT : #US3750 108474 Stagiaire
# If VALEUR<>"02" & VALEUR<>"03" & VALEUR<>"25" & VALEUR<>"26" & VALEUR<>"27" & VALEUR<>"28" & VALEUR<>"04" & VALEUR<>"05"
  #FRLAA - 2016-06-02 - REQUIREMENT 114309 US 211 - START
  #If !func DIVPAYE.ISCDD_NAT(VALEUR) & !WISTRAINEE
  If !func DIVPAYE.ISCDD(VALEUR) & !WISTRAINEE  #US3750 108474 Stagiaire
   #FRLAA - 2016-06-02 - REQUIREMENT 114309 US 211 - END
#JOJAC - END
  Effzo WENDCON, WPERCON, WNBRPER, WMATREMP,ZWMATREMP, WCDDGRD
  Grizo WENDCON, WPERCON, WNBRPER, WMATREMP, WCDDGRD
  Raz [M]ENDCON([M]WLIG),[M]PERCON([M]WLIG),[M]NBRPER([M]WLIG), [M]MATREMP([M]WLIG)
 Else
  Actzo WENDCON, WPERCON, WNBRPER,WCDDGRD
    #JOJAC - START
 # If [M]CDDGRD="REM" | [M]CDDGRD="RPL"
If [M]CDDGRD="REM" | [M]CDDGRD="RPL"    | WISTRAINEE #US3750 108474 114634 Stagiaire
  #JOJAC - END
   Actzo WMATREMP
  Else
   Effzo WMATREMP
   Grizo WMATREMP
   Raz [M]MATREMP([M]WLIG)
  Endif
 Endif
Endif
End

