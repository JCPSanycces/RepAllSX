Value Char VAL1, VAL2, VAL3, VAL4
Local Char ZONE(10) : ZONE = "WEXOSTR1"
Gosub SET_ZONE
If MA
 If VAL1=""
  Effzo WEXOSTR1,WEXOEND1
  Grizo WEXOSTR1,WEXOEND1
  Raz [M]EXOSTR1([M]WLIG), [M]EXOEND1([M]WLIG)
 Else
  Actzo WEXOSTR1,WEXOEND1
 Endif
 If VAL2=""
  Effzo WEXOSTR2,WEXOEND2
  Grizo WEXOSTR2,WEXOEND2
  Raz [M]EXOSTR2([M]WLIG), [M]EXOEND2([M]WLIG)
 Else
  Actzo WEXOSTR2,WEXOEND2
 Endif
  If VAL3=""
  Effzo WEXOSTR3,WEXOEND3
  Grizo WEXOSTR3,WEXOEND3
  Raz [M]EXOSTR3([M]WLIG), [M]EXOEND3([M]WLIG)
 Else
  Actzo WEXOSTR3,WEXOEND3
 Endif
 If VAL4=""
  Effzo WEXOSTR4,WEXOEND4
  Grizo WEXOSTR4,WEXOEND4
  Raz [M]EXOSTR4([M]WLIG), [M]EXOEND4([M]WLIG)
 Else
  Actzo WEXOSTR4,WEXOEND4
 Endif
Endif
End

