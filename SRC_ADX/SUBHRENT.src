  Endcase
Endif
End

Subprog GRISE_FLGPAY(VALEUR)
Value Integer VALEUR
Local Char ZONE(10)
#For ZONE = "WENDTRY","WBUICOE","WCOE","WBUIGRA","WGRA","WBUISTA","WIND","WCLLCVT","WRSKWRK","WEXOCOD1","WEXOCOD2","WEXOCOD3",
For ZONE = "WENDTRY","WCOE","WGRA","WIND","WCLLCVT","WRSKWRK","WEXOCOD1","WEXOCOD2","WEXOCOD3",
& "WEXOCOD4","WCATCSP","WSEVEMP","WSTRDATSEV","WENDDATSEV"
 Gosub SET_ZONE
 If MA
  If VALEUR=2
   Actzo =ZONE
  Else
   Effzo =ZONE
   Grizo =ZONE
   Case ZONE
    When "WENDTRY"    : Raz [M]ENDTRY([M]WLIG)
#    When "WBUICOE"    : Raz [M]BUICOE([M]WLIG)
    When "WCOE"       : Raz [M]COE([M]WLIG)
#    When "WBUIGRA"    : Raz [M]BUIGRA([M]WLIG)
    When "WGRA"       : Raz [M]GRA([M]WLIG)
#    When "WBUISTA"    : Raz [M]BUISTA([M]WLIG)
    When "WIND"       : Raz [M]IND([M]WLIG)
    When "WCLLCVT"    : Raz [M]CLLCVT([M]WLIG)
# SEGAY 18/12/12 86717 bug 85016 US810 81491 84301
#    When "WRSKWRK"    : Raz [M]RSKWRK([M]WLIG)
    When "WRSKWRK"    : Raz [M:ENT2]RSKWRK([M]WLIG)
    When "WEXOCOD1"   : Raz [M]EXOCOD1([M]WLIG)
    When "WEXOCOD2"   : Raz [M]EXOCOD2([M]WLIG)
    When "WEXOCOD3"   : Raz [M]EXOCOD3([M]WLIG)
    When "WEXOCOD4"   : Raz [M]EXOCOD4([M]WLIG)
# SEGAY 18/12/12 86717 bug 85016 US810 81491 84301
#    When "WCATCSP"    : Raz [M]CATCSP([M]WLIG)
    When "WCATCSP"    : Raz [M:ENT2]CATCSP([M]WLIG)
    When "WSEVEMP"    : Raz [M]SEVEMP([M]WLIG)
    When "WSTRDATSEV" : Raz [M]STRDATSEV([M]WLIG)
    When "WENDDATSEV" : Raz [M]ENDDATSEV([M]WLIG)
   Endcase
  Endif
  Affzo =ZONE
 Endif
Next
End

