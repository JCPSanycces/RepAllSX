Subprog C_WCDDGRD(VALEUR)
Variable Char    VALEUR()
#Cause code DNA
Local Integer JADI
Local Char CODA1 (10)
If VALEUR=""
 If clalev([F:HRNCT])=0  : Local File HRNATCON [HRNCT]  : Endif
 Call SIMPLEREAD([M]WNATCON,GCURLEG,GERRHRM) From SUBHRNCT
 If !GERRHRM
  CODA1=[F:HRNCT]CODN4H
  If  CODA1="02"
   GMESSAGE = mess(10,123,1) : # Zone Obligatoire
   mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog AM_WCDDGRD(VALEUR)
Variable Char    VALEUR()
#[M]CDDGRD([M]WLIG) = VALEUR
#[M]FLGMOD([M]WLIG) = 1
##JOJAC - START
##If VALEUR="REM" | VALEUR="RPL"
#If VALEUR="REM" | VALEUR="RPL"  | func DIVPAYE.ISTRAINEE([M]NATCON) #US3750 108474 Stagiaire
##JOJAC - END
# Actzo WMATREMP
#Else
# Effzo WMATREMP
# Grizo WMATREMP
# Raz [M]MATREMP([M]WLIG)
#Endif

[M]CDDGRD([M]WLIG) = VALEUR
[M]FLGMOD([M]WLIG) = 1
#JOJAC - START
#If VALEUR="REM" | VALEUR="RPL"
If VALEUR="REM" | VALEUR="RPL"  | func DIVPAYE.ISTRAINEE([M]NATCON) #US3750 108474 Stagiaire
#JOJAC - END
 Actzo WMATREMP
Else
 Effzo WMATREMP
 Grizo WMATREMP
 Raz [M]MATREMP([M]WLIG)
Endif

End
Subprog C_WNBRPER(VALEUR)
Variable Decimal VALEUR
# Zone obligatoire si le motif CDD est différent de "Remplacement".
If !VALEUR & [M]WCDDGRD<>"REM" & [M]WCDDGRD<>"RPL"
 GMESSAGE = mess(10,123,1) :# Zone Obligatoire
 mkstat = 2 : End
Endif
End

Subprog AM_WNBRPER(VALEUR)
Variable Decimal VALEUR
[M]NBRPER([M]WLIG) = VALEUR
[M]FLGMOD([M]WLIG) = 1
If [M]WCTRDAT<>[0/0/0]
 Case [M]WPERCON
  When 1 : [M]WENDCON = [M]WCTRDAT+VALEUR              : # Jours
  When 2 : [M]WENDCON = [M]WCTRDAT+(VALEUR*7)          : # Semaine
  When 3 : [M]WENDCON = addmonth([M]WCTRDAT,VALEUR)    : # Mois
  When 4 : [M]WENDCON = addmonth([M]WCTRDAT,VALEUR*12) : # Année
 Endcase
 [M]ENDCON([M]WLIG) = [M]WENDCON
 Affzo [M]WENDCON
Endif
End

Subprog C_WPERCON(VALEUR)
Variable Integer VALEUR
# Zone obligatoire si le motif CDD est différent de "Remplacement".
If !VALEUR & [M]WCDDGRD<>"REM" & [M]WCDDGRD<>"RPL"
 GMESSAGE = mess(10,123,1) :# Zone Obligatoire
 mkstat = 2 : End
Endif
End

Subprog AM_WPERCON(VALEUR)
Variable Integer VALEUR
[M]PERCON([M]WLIG) = VALEUR
[M]FLGMOD([M]WLIG) = 1
Case VALEUR
 When 1 : [M]WENDCON = [M]WCTRDAT+[M]WNBRPER              : # Jours
 When 2 : [M]WENDCON = [M]WCTRDAT+([M]WNBRPER*7)          : # Semaine
 When 3 : [M]WENDCON = addmonth([M]WCTRDAT,[M]WNBRPER)    : # Mois
 When 4 : [M]WENDCON = addmonth([M]WCTRDAT,[M]WNBRPER*12) : # Année
Endcase
[M]ENDCON([M]WLIG) = [M]WENDCON
Affzo [M]WENDCON
End

