 If [M:ENT0]CIV=1
  Call VDSS([F:TCY]CRY,[M]CRYBRN,1,[M]DATBRN,[M]DEPBRN,[M]CTYBRNSEE,VALEUR) From CONTNUM
 Else
  Call VDSS([F:TCY]CRY,[M]CRYBRN,2,[M]DATBRN,[M]DEPBRN,[M]CTYBRNSEE,VALEUR) From CONTNUM
 Endif

Endif
End

Subprog C_NUMSSC(VALEUR)
Variable Char    VALEUR()
#JOJAC - START
# FQ95799 - 17/04/14 - Gestion des champs spécifiques FRA
Local Char CTYBRNSEE(4) : CTYBRNSEE = ""
Local Char DEPBRN(2)    : DEPBRN    = ""
If GCURLEG="FRA" Then
  CTYSEE=[M]CTYBRNSEE
  DEPBRN=[M]DEPBRN
Endif
#JOJAC - END
If VALEUR<>""
# If [M:ENT0]CIV=1
#  Call CONTSS (VALEUR,[M]NTT,[M]CRYBRN,1,[M]DATBRN,[M]DEPBRN,[M]CTYBRNSEE) From CONTNUM
# Else
#  Call CONTSS (VALEUR,[M]NTT,[M]CRYBRN,2,[M]DATBRN,[M]DEPBRN,[M]CTYBRNSEE) From CONTNUM
# Endif
# SEGAY 15/10/12 US 854 83632
 If [M:ENT0]CIV=1
  Call CONTSS (VALEUR,[F:TCY]CRY,[M]CRYBRN,1,[M]DATBRN,[M]DEPBRN,[M]CTYBRNSEE) From CONTNUM
 Else
  Call CONTSS (VALEUR,[F:TCY]CRY,[M]CRYBRN,2,[M]DATBRN,[M]DEPBRN,[M]CTYBRNSEE) From CONTNUM
 Endif

Endif
End

