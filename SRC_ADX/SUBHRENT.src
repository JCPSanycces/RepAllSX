Subprog AM_WPOT(VALEUR)
Variable Char    VALEUR()
#JOJAC - START
Local Integer L_OK
L_OK=0
#JOJAC - END
[M]POT([M]WLIG) = VALEUR
[M]FLGMOD([M]WLIG) = 1
If VALEUR="" : End : Endif
If [M]WMAJPOTB2 : [M]WMAJPOTB2=0 : End : Endif

If clalev([F:POT])=0 : Local File POSTE    [POT] : Endif
#SEGAY 03/03/01 BUG 72064
Gosub MAJ_POSTEDEF
[M]WMAJPOTB2=0
Call LECTURE("POT",VALEUR,"") From CONTOBJ
If [F:POT]JOBPOT<>""
 [M]WJOBPOT = [F:POT]JOBPOT
 Call AM_WJOBPOT([M]WJOBPOT)
 Affzo [M]WJOBPOT
 [M]JOBPOT([M]WLIG) = [M]WJOBPOT
 mkstat = 0
Endif
End

$MAJ_POSTEDEF
Local Integer L_OK
Local File POSTEDEF [POD]  : # Must be by default
Local Integer L_FORCE      : # 1 Force update else don't do anything
Local Char    CRITCTRL(GDIMFIC)
#70013
