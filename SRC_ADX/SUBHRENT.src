If VALEUR<>[0/0/0] & VALEUR<[M]WCTRDAT
 #Une date de fin de contrat doit être supérieure à la date de début du contrat.
 GMESSAGE=mess(137,10702,1)
 mkstat=2 : End
Endif
End

