#JOJAC - 2016-12-13 - START
#Read [PEO]PEO0 = "";[M:DIA]DAT
#[M:DIA]DATDEB = [F:PEO]PERSTR(0)
#[M:DIA]DATFIN = [F:PEO]PEREND(0)
#[M:DIA]FMOIS  = [F:PEO]PEREND(1)
Read [HRPEOD]HRPEOD1 = [M:DIA]PERCOD;[M:DIA]DAT
[M:DIA]DATDEB = [F:HRPEOD]PERSTR(0)
[M:DIA]DATFIN = [F:HRPEOD]PEREND(0)
[M:DIA]FMOIS  = [F:HRPEOD]PEREND(1)
#JOJAC - 2016-12-13 -  X3-12122 -  END
Call LECMEMO("STD","[M:DIA]","tps") From GMEMO
Return

