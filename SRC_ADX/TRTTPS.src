#MIPEA - 2017-02-01- X3-12122- START
TIT = mess(14,10709,1)     : # Arrêté des temps
#TIT = mess(14,709,1)     : # Arrêté des temps
#MIPEA - 2017-02-01- X3-12122- END
NBPCE=0
