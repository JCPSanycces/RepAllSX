Local Mask TRTTPS [DIA]
If [M:DIA]LEG<>""
  GCURLEG = [M:DIA]LEG
Endif
Raz [M:DIA]
If GPAYE=1
 [M:DIA]DAT = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))
