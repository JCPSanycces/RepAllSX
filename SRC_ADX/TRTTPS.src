## Initialisations pour les appels from SUBPLN
##
#Call PARAM("","INITCP",PARAM) From ADOVAL
#Call PARAM("","CPA",CPA) From ADOVAL
#Call PARAM("","CPE",CPE) From ADOVAL

## Si on doit enchaîner les appels dans une boucle sur les contrats par exemple
## l'appel de INIT_PARAM_CP avant la boucle permet d'optimiser les perfs.
## Remonter l'appel de l'init le plus haut possible dans la pile des traitements
## exécutés.
##
## Si on veut se débarrasser des globales à la fin du trt qui appelle l'init
## faire
#   en fin de trt    If GCREAGLOB :  Kill GPARINITCP , GPARCPA, GPARCPE : Endif
##
################################################################################
#-----------------------------------------------------------
# Performances arrêté des temps
#-----------------------------------------------------------
$INIT_PARAM_CP
If dim(GTPSCREAGLOB) < 0
 Global Integer GTPSCREAGLOB
 Global Char    GTPSPARINITCP (10)
 Global Char    GTPSPARCPA (GLONTPS)
 Global Char    GTPSPARCPE (GLONTPS)
 #ADNGO - 2017-02-03- X3-12122- START
 #Global Char    GTPSMAT (GLONMAT)
 #Global Char    GTPSCTR (GLONCTR)
 Global Char    GTPSMAT (GLONEML)
 Global Char    GTPSCTR (GLONHRCTR)
 #ADNGO - 2017-02-03- X3-12122- END
 Global Date    GTPSCTRDAT
 Global Date    GTPSFINCTR
 Global Date    GTPSDAT
 Global Date    GTPSDEBUT
 Global Date    GTPSFIN
 Global Integer GTPSANNCUR
 Global Integer GTPSSEMCUR
 Global Char    GTPSPLNCUR (GLONPLN)
 Global Char    GTPSSEMTYP(GLONSTY)

 GTPSCREAGLOB = 1
 Local Integer LMAXNAT
 LMAXNAT   = nbrecord([F:NAT])
 Global Integer GTPSNBNAT
 If LMAXNAT=0 : LMAXNAT = 1 : Endif
 Global Char    GTPSTBNAT(GLONNAT)(1..LMAXNAT)
 For [F:NAT]NAT0
   GTPSNBNAT += 1
   GTPSTBNAT(GTPSNBNAT) = [F:NAT]COD
 Next
## Variables par code

 Local Integer LMAXCOD
 LMAXCOD   = nbrecord([F:TIM])
 Global Integer GTPSNBCOD
 If LMAXCOD=0 : LMAXCOD = 1 : Endif
 Global Char    GTPSTBCOD(GLONTPS)(1..LMAXCOD)
 Global Integer GTPSTRAV(1..LMAXCOD) , GTPSREPOS(1..LMAXCOD)
 Global Integer GTPSTBPRNCAL(1..LMAXCOD)
 # FQ86267 - 27/12/12 - Il faut cumuler les absences pour la modulation
 Global Integer GTPSTIMCAT(1..LMAXCOD)
 # Fin FQ86267

 For [TIM]TIM0
   GTPSNBCOD += 1
   GTPSTBCOD(GTPSNBCOD) = [F:TIM]COD
   GTPSTRAV(GTPSNBCOD)  = [F:TIM]WRKTIM
   If dim([F:TIM]REPFLG)>0
    GTPSREPOS(GTPSNBCOD) = [F:TIM]REPFLG
   Endif
   If dim([F:TIM]PRNCAL)>0
    GTPSTBPRNCAL(GTPSNBCOD) = [F:TIM]PRNCAL
   Endif
   # FQ86267 - 27/12/12 - Il faut cumuler les absences pour la modulation
   GTPSTIMCAT(GTPSNBCOD) = [F:TIM]CATTIM
   # Fin FQ86267
 Next
Endif
Call PARAM("","INITCP",GTPSPARINITCP) From ADOVAL
Call PARAM("","CPA",GTPSPARCPA) From ADOVAL
Call PARAM("","CPE",GTPSPARCPE) From ADOVAL

#################################################################################
### Variables Globales pour OPTIMISER APPEL VALORTYP
#################################################################################
Global Char GTABCLE(50)(1..10000)
Global Decimal GTABJOUR(1..10000)
Global Decimal GTABHEURE(1..10000)
Global Integer GTABIND
Global Char GMATRI(50)
Global Integer GOUVTABW
GOUVTABW=0

GTABIND=1
GMATRI=''
Return

$KILLVARG
If dim(GTPSCREAGLOB)>0   : Kill GTPSCREAGLOB   : Endif
If dim(GTPSPARINITCP)>0  : Kill GTPSPARINITCP   : Endif
If dim(GTPSPARCPA)>0 : Kill GTPSPARCPA   : Endif
If dim(GTPSPARCPE)>0 : Kill GTPSPARCPE : Endif
If dim(GTPSNBNAT)>0 : Kill GTPSNBNAT : Endif
If dim(GTPSTBNAT)>0 : Kill GTPSTBNAT : Endif
If dim(GTPSNBCOD)>0 : Kill GTPSNBCOD : Endif
If dim(GTPSTBCOD)>0 : Kill GTPSTBCOD : Endif
If dim(GTPSTRAV)>0 : Kill GTPSTRAV : Endif
If dim(GTPSTBPRNCAL)>0 : Kill GTPSTBPRNCAL : Endif
# FQ86267 - 27/12/12
If dim(GTPSTIMCAT)>0 : Kill GTPSTIMCAT : Endif
# Fin FQ86267

If dim(GTPSMAT) > 0 Kill GTPSMAT : Endif
If dim(GTPSCTR) > 0 Kill GTPSCTR : Endif
If dim(GTPSCTRDAT) > 0 Kill GTPSCTRDAT : Endif
If dim(GTPSFINCTR) > 0 Kill GTPSFINCTR : Endif
If dim(GTPSDAT) > 0 Kill GTPSDAT : Endif
If dim(GTPSDEBUT) > 0 Kill GTPSDEBUT : Endif
If dim(GTPSFIN) > 0 Kill GTPSFIN : Endif
If dim(GTPSANNCUR) > 0 Kill GTPSANNCUR : Endif
If dim(GTPSSEMCUR) > 0 Kill GTPSSEMCUR : Endif
If dim(GTPSPLNCUR) > 0 Kill GTPSPLNCUR : Endif
If dim(GTPSSEMTYP) > 0 Kill GTPSSEMTYP : Endif

If dim(GTABCLE)> 0 Kill GTABCLE : Endif
If dim(GTABJOUR)> 0 Kill GTABJOUR : Endif
If dim(GTABHEURE)> 0 Kill GTABHEURE : Endif
If dim(GTABIND)> 0 Kill GTABIND : Endif
If dim(GMATRI)> 0 Kill GMATRI : Endif
If dim(GOUVTABW)> 0 Kill GOUVTABW : Endif

Return

# FQ82073 - Ajout paramètre CTRD contenant la date du contrat
Funprog TPSDAT(MATRI,DATPAY,CTR,CTRD)
Value Char MATRI()
Value Date DATPAY,CTRD
Value Char CTR
Local Char NUMBUL(20)
# Si pas PAYE Date initialisé à [0/0/0]
If GPAYE=1
  If clalev([F:VEP2])=0 : Local File VALEMP [VEP2] : Endif
  # Cas particulier du décalage de paie avec une sortie sur le mois de paie
  # FQ85116 - On cherche le dernier bulletin PAS extourné, donc RVS à 1
  Filter [VEP2] Where EMP=MATRI & CTRNUM=CTR & CTRDAT=CTRD & RVS<>2 & RVSDAT=[0/0/0]
  Read [VEP2]VEP0 Last
  If !fstat Then
    NUMBUL=[F:VEP2]BUL
  Endif
  #
  # FQ85116 - On cherche le dernier bulletin PAS extourné, donc RVS à 1
  Filter [VEP2] Where EMP=MATRI & PYRDAT<DATPAY & CTRNUM=CTR & CTRDAT=CTRD & RVS<>2 & RVSDAT=[0/0/0]
  #
  Read [VEP2]VEP0 Last
  Filter [VEP2]
  If !fstat
   If NUMBUL=[F:VEP2]BUL Then
     End [0/0/0]
   Else
     End [F:VEP2]DATTPS
   Endif
  Else
   End [0/0/0]
  Endif
Else
  End [0/0/0]
Endif
End

# FQ91472 US2857/58 - SEGAY 23/09/14
#**
#*
#*
#* @param MATRI
#* @param CTR
#* @param CTRD
#* @param XITDAT1
#* @param PYRDAT1
#* @param FCY1
#* @param DATPAY2
#*!
#MIPEA - 2017-01-25- X3-12033- START
Subprog TPSDATPAY(MATRI,CTR,CTRD,XITDAT1,PYRDAT1,FCY1,DATPAY2,CTRPERCOD)
#Subprog TPSDATPAY(MATRI,CTR,CTRD,XITDAT1,PYRDAT1,FCY1,DATPAY2)
#MIPEA - 2017-01-25- X3-12033- END
Value Char MATRI(),FCY1()
Value Date PYRDAT1,CTRD,XITDAT1
Value Char CTR
Variable Date DATPAY2
#MIPEA - 2017-01-25- X3-12033- START
Value Char CTRPERCOD
#MIPEA - 2017-01-25- X3-12033- END
Local Char NUMBUL(20)
Local Date CTRDAT_VEP
Local Char VALPAR(10)
Raz CTRDAT_VEP
DATPAY2=PYRDAT1
If GPAYE=1
 [L]CTRDAT_VEP=[L]CTRD : Endif
 Gosub FILTRE_VEP From TRTTPS
 # JPAY <> 0 uniquement si gestion en décalage de paie (DMA=11)
 Call PARAML([L]FCY1,"JPAY",VALPAR) From ADOVAL
 If val(VALPAR)<>0 & val(VALPAR)<>day(DATPAY2)
    While day(DATPAY2)<>val(VALPAR)
      DATPAY2 += 1
    Wend
 Endif

 # DMA=12
 If val(func AFNC.PARAM('DMA',[L]FCY1))=12 & val(func AFNC.PARAM('UNQDATPAY',[L]FCY1))<>2    :# dates de paie différentes pour CDD successifs
  If [L]XITDAT1<>[0/0/0]
   [L]DATPAY2 = min([L]PYRDAT1,[L]XITDAT1)
   #JOJAC - 2016-12-13 - START
   #Filter [VEP] Where EMP=[L]MATRI & PYRDAT=[L]DATPAY2 & CTRNUM=[L]CTR & evalue (CRITVEP)
#MIPEA - 2017-01-25- X3-12033- START
   Filter [VEP] Where EMP=[L]MATRI & PYRDAT=[L]DATPAY2 & CTRNUM=[L]CTR & PERCOD = CTRPERCOD & evalue (CRITVEP)
#   Filter [VEP] Where EMP=[L]MATRI & PYRDAT=[L]DATPAY2 & CTRNUM=[L]CTR & PERCOD = [M:DIA]PERCOD & evalue (CRITVEP)
#MIPEA - 2017-01-25- X3-12033- END
   #JOJAC - 2016-12-13 - END
   Read [F:VEP] Last
   If fstat Then
     #JOJAC - 2016-12-13 - START
     #Filter [VEP] Where EMP=[L]MATRI & PYRDAT=[L]PYRDAT1 & CTRNUM=[L]CTR & evalue (CRITVEP)
#MIPEA - 2017-01-25- X3-12033- START
     Filter [VEP] Where EMP=[L]MATRI & PYRDAT=[L]PYRDAT1 & CTRNUM=[L]CTR & PERCOD = CTRPERCOD & evalue (CRITVEP)
#     Filter [VEP] Where EMP=[L]MATRI & PYRDAT=[L]PYRDAT1 & CTRNUM=[L]CTR & PERCOD = [M:DIA]PERCOD & evalue (CRITVEP)
#MIPEA - 2017-01-25- X3-12033- END
     #JOJAC - 2016-12-13 - END
     Read [F:VEP] Last
     If !fstat Then [L]DATPAY2=[L]PYRDAT1 : Endif
   Endif
   Filter [VEP]
  Endif
 Endif
End
################################################################################
## Contrôle de saisie
################################################################################
Subprog CONTSAI(LESITE,MATRI,CTR,DATPAY,SEMDEB,SEMFIN)
Value Char  LESITE(), MATRI(), CTR()
Value Date  DATPAY
Value Date  SEMDEB,SEMFIN

Local Date    DATDEB , DATFIN , DATFIN_P , DATCUR, FINMOIS
Local Char    MESSAGE(80)
Local Integer I , J , K
Local Integer ERR , NBTPS
Local Integer MAXSEM
#MAXSEM   = 12
#MAXSEM   = 15
MAXSEM   = 20
Local Integer PRE(1..7*MAXSEM) , EVT(1..7*MAXSEM)
Local Decimal PJOUR(1..7*MAXSEM) , PHEURE(1..7*MAXSEM)
Local Decimal JR, HR
Local Char    SNG(20)(1..7*MAXSEM)
Local Integer EXITSAL
Local Integer RET
# FQ85820 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
Local Date    DATDEBCTR
#

# FQ97072 - 27/03/14 - Séparation de chaque action
If GTRACE<>""
#MIPEA - 2017-02-01- X3-12122- START
 Call ECR_TRACE("-->"-mess(202,10709,1)-MATRI-CTR,0) From GESECRAN : # Contrôle de saisie
# Call ECR_TRACE("-->"-mess(202,709,1)-MATRI-CTR,0) From GESECRAN : # Contrôle de saisie
#MIPEA - 2017-02-01- X3-12122- END
Endif

If SEMDEB=[0/0/0]
 #JOJAC - 2016-12-13 - START
 #DATDEB = [F:PEO]PERSTR(0)
 #DATFIN = [F:PEO]PEREND(0)
 DATDEB = [F:HRPEOD]PERSTR(0)
 DATFIN = [F:HRPEOD]PEREND(0)
 #JOJAC - 2016-12-13 - END
 Call MODULATION(DATPAY,DATDEB,DATFIN,MATRI,CTR) From TPSSTD
Else
 DATDEB = SEMDEB
 DATFIN = SEMFIN
Endif
DATFIN_P=DATFIN
# FQ105373 - Sauvegarde de la date DATFIN pour restauration après la boucle For suivante
Local Date DATFIN_S : DATFIN_S=DATFIN
# FQ99390 - 16/05/14 - CALC_DATEND appelé à l'intérieur de la boucle pour avoir la date de sortie
#Call CALC_DATEND(LESITE, DATPAY, DATDEB, DATFIN, FINMOIS, EXITSAL)
#If DATFIN_P<DATFIN Then DATFIN_P=DATFIN : Endif
Raz PRE
#JOJAC - 2016-12-13 - START
#For [CTR]CTR1 Where REFNUM=MATRI & CTRNUM=CTR
For [HRCTR]CTR1 Where REFNUM=MATRI & CTRNUM=CTR
#JOJAC - 2016-12-13 - END
 DATFIN=DATFIN_S
 # FQ99390 - 16/05/14 - CALC_DATEND appelé ici pour avoir la date de sortie + Ajout nouveaux paramètres dans CALC_DATEND
#JOJAC - 2016-12-13 - START
# Call CALC_DATEND(LESITE, DATPAY, [F:CTR]XITDAT, [F:CTR]XITFNL, [F:CTR]CLEEVETIM, DATDEB, DATFIN, FINMOIS, EXITSAL)
# If DATFIN_P<DATFIN Then DATFIN_P=DATFIN : Endif
# # FQ85820 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
# DATDEBCTR=[F:CTR]CTRDAT
# If [F:CTR]FLGRET=2 & [F:CTR]RETDATEFF<>[0/0/0] Then
#  DATDEBCTR=[F:CTR]RETDATEFF
# Endif
# If [F:CTR]XITDAT=[0/0/0] & DATDEBCTR<=DATFIN
#  For I=max(DATDEB,DATDEBCTR)-DATDEB+1 To DATFIN-DATDEB+1
#   PRE(I) = 1
#  Next I
# Elsif [F:CTR]XITDAT>=DATDEB & DATDEBCTR<=DATFIN
#  For I=max(DATDEB,DATDEBCTR)-DATDEB+1 To min(DATFIN,[F:CTR]XITDAT)-DATDEB+1
#   PRE(I) = 1
#  Next
# Endif
#Next
#DATFIN=DATFIN_S
#MIPEA - 2017-01-20- X3-12122- START
 Call CALC_DATEND(LESITE, DATPAY, [F:HRCTR]XITDAT, [F:HRCTR]XITFNL, [F:HRCTR]CLEEVETIM, DATDEB, DATFIN, FINMOIS, EXITSAL, [F:HRCTR]PERCOD)
# Call CALC_DATEND(LESITE, DATPAY, [F:HRCTR]XITDAT, [F:HRCTR]XITFNL, [F:HRCTR]CLEEVETIM, DATDEB, DATFIN, FINMOIS, EXITSAL)
#MIPEA - 2017-01-20- X3-12122- END
 If DATFIN_P<DATFIN Then DATFIN_P=DATFIN : Endif
 # FQ85820 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
 DATDEBCTR=[F:HRCTR]CTRDAT
 If [F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<>[0/0/0] Then
  DATDEBCTR=[F:HRCTR]RETDATEFF
 Endif
 If [F:HRCTR]XITDAT=[0/0/0] & DATDEBCTR<=DATFIN
  For I=max(DATDEB,DATDEBCTR)-DATDEB+1 To DATFIN-DATDEB+1
   PRE(I) = 1
  Next I
 Elsif [F:HRCTR]XITDAT>=DATDEB & DATDEBCTR<=DATFIN
  For I=max(DATDEB,DATDEBCTR)-DATDEB+1 To min(DATFIN,[F:HRCTR]XITDAT)-DATDEB+1
   PRE(I) = 1
  Next
 Endif
Next
DATFIN=DATFIN_S
#JOJAC - 2016-12-13 - END
NBTPS = 0
Raz EVT , SNG
For [TIP]TIP1 Where REFNUM=MATRI & ENDDAT>=DATDEB & STRDAT<=DATFIN & CTRNUM=CTR
 If GVISA=2 & [F:TIP]STAFLG=""
#JOJAC - 2016-12-13 - START
#  MESSAGE = mess(28,709,1)-format$("D:"+GFMDAT,[F:TIP]STRDAT)-"-"
#&           -format$("D:"+GFMDAT,[F:TIP]ENDDAT)-num$([F:TIP]NBRHOU)-[F:TIP]TIM
  MESSAGE = mess(28,10709,1)-format$("D:"+GFMDAT,[F:TIP]STRDAT)-"-"
&           -format$("D:"+GFMDAT,[F:TIP]ENDDAT)-num$([F:TIP]NBRHOU)-[F:TIP]TIM
#JOJAC - 2016-12-13 - END
  Gosub ERRSAI
# Ligne non visée
 Endif
#ADNGO - 2017-01-11 - X3-12021 - START
# Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
   Call LECTURE("HRTIM",[F:TIP]TIM,GCURLEG) From CONTOBJ
#   Call LECTURE("HRTIM",[F:TIP]TIM,"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
#ADNGO - 2017-01-11 - X3-12021 - END
 If [F:TIM]FILTRE<>"" | [F:TIM]POP<>"" Then
  Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,MATRI,CTR,RET) From DIVPAYE
  If RET>0 Then
    MESSAGE = mess(320,199,1)-[F:TIP]TIM-format$("D:"+GFMDAT,[F:TIP]STRDAT)-"-"
&             -format$("D:"+GFMDAT,[F:TIP]ENDDAT) : # Nature d'événement incompatible avec ce salarié
    Gosub ERRSAI
  Endif
 Endif
 NBTPS += 1
 For K=max(DATDEB,[F:TIP]STRDAT)-DATDEB+1 To min(DATFIN,[F:TIP]ENDDAT)-DATDEB+1
  EVT(K) = 1
  If [F:TIP]STRDAT=[F:TIP]ENDDAT
   SNG(K) -= [F:TIP]TIM
  Endif
 Next K
Next

If NBTPS=0
#MIPEA - 2017-02-01- X3-12122- START
 MESSAGE = mess(66,10709,1) : Gosub ERRSAI : # Pas d'événement saisi
# MESSAGE = mess(66,709,1) : Gosub ERRSAI : # Pas d'événement saisi
#MIPEA - 2017-02-01- X3-12122- END
Else
 Call LECTURE("EML",MATRI,"") From CONTOBJ
 # FQ85820 - 29/04/13 - On cherche si on a une fiche de rétroactivité relative au champ ETRFCY
# Call VALORDET(DATDEB,DATFIN_P,MATRI,GTPSW,PJOUR,PHEURE,[F:CTR]ETRFCY,CTR) From SUBPLN
#JOJAC - 2016-12-13 - START
#LIPET - 2017-01-18 - START
# Call VALORDET(DATDEB,DATFIN_P,MATRI,GTPSW,PJOUR,PHEURE,func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,
#&              DATPAY,"ETRFCY","CTR"),CTR) From SUBPLN
# Call VALORDET(DATDEB,DATFIN_P,MATRI,GTPSW,PJOUR,PHEURE,func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,
#&              DATPAY,"ETRFCY","CTR"),CTR) From SUBPLN
 Call VALORDET(DATDEB,DATFIN_P,MATRI,GTPSW,PJOUR,PHEURE,func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,
&              DATPAY,"ETRFCY","HRCTR"),CTR) From SUBPLN
#LIPET - 2017-01-18 - END
#JOJAC - 2016-12-13 - END
 # Fin FQ85820
 For K=1 To (DATFIN-DATDEB)+1
  DATCUR = DATDEB+K-1
  If PRE(K) & PJOUR(K)<>0 & EVT(K)=0
#MIPEA - 2017-02-01- X3-12122- START
   MESSAGE = mess(69,10709,1)-day$(DATCUR)-format$("D:"+GFMDAT4,DATCUR)
#   MESSAGE = mess(69,709,1)-day$(DATCUR)-format$("D:"+GFMDAT4,DATCUR)
#MIPEA - 2017-02-01- X3-12122- END
#  Pas d'événement le
   Gosub ERRSAI
  Elsif EVT(K) & PRE(K)=0
#MIPEA - 2017-02-01- X3-12122- START
   MESSAGE = mess(67,10709,1)-day$(DATCUR)-format$("D:"+GFMDAT4,DATCUR)
#   MESSAGE = mess(67,709,1)-day$(DATCUR)-format$("D:"+GFMDAT4,DATCUR)
#MIPEA - 2017-02-01- X3-12122- END
#  Evénement hors période de présence le
   Gosub ERRSAI
  Elsif SNG(K)<>"" & PJOUR(K)=0
   # FQ85820 - 29/04/13 - On cherche si on a une fiche de rétroactivité relative au champ PLNTYP
#   If [F:PLE]REFNUM=[F:ID]REFNUM | [F:CTR]PLNTYP<>""
   #JOJAC - X3-12122 - 2016-12-13 - START
   #LIPET - 2017-01-18 - START
   #If [F:PLE]REFNUM=[F:ID]REFNUM | (func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,DATPAY,"PLNTYP","CTR"))<>""
   #If [F:PLE]REFNUM=[F:ID]REFNUM | (func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,DATPAY,"PLNTYP","CTR"))<>""
   If [F:PLE]REFNUM=[F:ID]REFNUM | (func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,DATPAY,"PLNTYP","HRCTR"))<>""
   #LIPET - 2017-01-18 - END
   #JOJAC - X3-12122 - 2016-12-13 - END
   # Fin FQ85820
#MIPEA - 2017-02-01- X3-12122- START
    MESSAGE = mess(68,10709,1)-day$(DATCUR)-format$("D:"+GFMDAT4,DATCUR)-":"-SNG(K)
#    MESSAGE = mess(68,709,1)-day$(DATCUR)-format$("D:"+GFMDAT4,DATCUR)-":"-SNG(K)
#MIPEA - 2017-02-01- X3-12122- END
#   Evénement non prévu le
    Gosub ERRSAI
   Endif
  Endif
 Next K
Endif
End

# FQ99390 - 06/05/14 - Redéfinition des conditions dans lesquelles on recalcule la date de fin de saisie
## Si la date de sortie définitive est supérieure à la date de fin d'extraction, ET inférieure à la date de fin
## d'extration de la période suivante, on veut avoir tous les événements du salarié depuis la date de début
## d'extraction jusqu'à sa date de sortie incluse ==> DATFIN est donc égal à la date de sortie définitive
## Même chose si le départ est temporaire, et que la case "Solde événements temps" est cochée pour le contrat
#Subprog CALC_DATEND(LESITE, DATPAY, DATDEB, DATFIN, FINMOIS, EXITSAL)
#Value    Char    LESITE()
#Value    Date    DATPAY
#Variable Date    DATDEB, DATFIN, FINMOIS
#Variable Integer EXITSAL
#Local    Date    DEBPAY, FINPAY, DATDEBPER, DATFINPER
#Local    Integer LEC_OK
#
#  DEBPAY = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",LESITE))
#  FINPAY = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",LESITE))
#  LEC_OK = 1
#
#  If clalev([F:PEO2])=0 : Local File PERIOD [PEO2] : Endif
#  # Recherche dates début et fin paye pour le contrat en cours
#  Filter [F:PEO2] Where PERSTR(0)=DATDEB & PEREND(0)=DATFIN & FCY=LESITE
#  # Amélioration des temps
#  Read [PEO2]PEO0 Last
#  If !fstat Then
#   DATDEBPER=[F:PEO2]PERSTR(1) : DATFINPER=[F:PEO2]PEREND(1)
#  Endif
#  #
#  Filter [F:PEO2]
#
#  Read [PEO2]PEO0 = LESITE;DATPAY
#  If fstat>2 Then
#    Read [PEO2]PEO0="";DATPAY
#    If fstat>2 Then
#      Read [PEO2]PEO0(1) = LESITE
#      If fstat<=2 Then
#        Filter [PEO2] Where FCY=LESITE & PYRDAT>=DATPAY
#        Read [PEO2]PEO0 First
#      Else
#        Filter [PEO2] Where FCY="" & PYRDAT>=DATPAY
#        Read [PEO2]PEO0 First
#      Endif
#      Filter [PEO2]
#    Endif
#  Endif
#  If !fstat Then
#    LEC_OK = 2
#  Endif
#
#  EXITSAL = 1
#  # Il faut que la date de sortie soit dans la période en cours, ou qu'on soit passé sur les payes suivantes
#   If LEC_OK=2 & [F:CTR]XITDAT<>[0/0/0]
#&             & (([F:CTR]XITDAT>=DEBPAY & [F:CTR]XITDAT<=FINPAY) | ([F:CTR]XITDAT<DEBPAY & [F:CTR]XITDAT>=DATDEBPER & [F:CTR]XITDAT<=DATFINPER))
#&             & ([F:CTR]XITFNL=2 | [F:CTR]CLEEVETIM=2) Then
##&             & ([F:CTR]CLEEVETIM=2) Then
#    Read [F:PEO2] Next
#    If !fstat Then
#      If [F:CTR]XITDAT<=[F:PEO2]PEREND(0) Then
#        DATFIN  = [F:CTR]XITDAT
#        FINMOIS = [F:PEO2]PEREND(1)
#        EXITSAL = 2
#      Endif
#    Endif
#  Endif
#
##  # FQ94174 - 23/12/13 - Si le salarié est sorti pendant la période en cours du bulletin, la date de fin de recherche des
##  # événements doit être la date de sortie
##   If LEC_OK=2 & [F:CTR]XITDAT<>[0/0/0]
##&             & (([F:CTR]XITDAT>=DEBPAY & [F:CTR]XITDAT<=FINPAY) | ([F:CTR]XITDAT<DEBPAY & [F:CTR]XITDAT>=DATDEBPER & [F:CTR]XITDAT<=DATFINPER))
##&             & [F:CTR]XITFNL<>2 Then
##    If !fstat Then
##      If [F:CTR]XITDAT<=[F:PEO2]PEREND(0) Then
##        FINMOIS  = [F:CTR]XITDAT
##      Endif
##    Endif
##  Endif
#End

# FQ102316 - 01/09/14 - Ce n'est pas avec la date de paie qu'on doit comparer, mais avec la date de fin de mois
# FQ99390  - 06/05/14 - Redéfinition des conditions dans lesquelles on recalcule la date de fin de saisie :
#   - CONDITION 1 : Une date de sortie est renseignée
##   - CONDITION 2 : La date de sortie est inférieure ou égale à la date de paie
#   - CONDITION 2 :
#       * La date de sortie est inférieure ou égale à la date de fin de mois
#       OU
#       * Mois de sortie=mois de date de paie (mois de date paie -1 si paie décalée) ET La date de sortie est comprise dans la période d’extraction suivante
#   - CONDITION 3 : La sortie est définitive OU La case Solde événements temps est cochée
#   - CONDITION 4 :
#       * La date de sortie est supérieure ou égale à la date de fin d’extraction
#       OU
#       * La date de sortie est comprise dans la période d’extraction
# ==> Dans ce cas-là, DATFIN est égal à la date de fin du contrat
#**
#* @param LESITE        : Site du contrat
#* @param DATPAY        : Date de paie
#* @param CTRXITDAT     : Date sortie du contrat
#* @param CTRXITFNL     : Sortie définitive O/N
#* @param CTRCLEEVETIM  : Solde événements temps O/N
#* @param DATDEB        : Date début période d'extraction
#* @param DATFIN        : Date fin période d'extraction OU Date de sortie du salarié
#* @param FINMOIS       : Date fin de mois
#* @param EXITSAL       : =2 si recalcul de DATFIN
#*!
#MIPEA - 2017-01-20- X3-12122- START
Subprog CALC_DATEND(LESITE, DATPAY, CTRXITDAT, CTRXITFNL, CTRCLEEVETIM, DATDEB, DATFIN, FINMOIS, EXITSAL, HRCTRPERCOD)
#Subprog CALC_DATEND(LESITE, DATPAY, CTRXITDAT, CTRXITFNL, CTRCLEEVETIM, DATDEB, DATFIN, FINMOIS, EXITSAL)
#MIPEA - 2017-01-20- X3-12122- END
Value    Char    LESITE()
Value    Date    DATPAY, CTRXITDAT
Value    Integer CTRXITFNL, CTRCLEEVETIM
Value    Date    DATDEB
Variable Date    DATFIN, FINMOIS
Variable Integer EXITSAL
#MIPEA - 2017-01-20- X3-12122- START
Value    Char HRCTRPERCOD
#MIPEA - 2017-01-20- X3-12122- END
Local    Date    DATFINPER, DATFINMOIS
Local    Integer LEC_OK, MDATFINMOIS, YDATFINMOIS, EXIT

  # FQ102316 - 01/09/14 - Changement condition 2, donc ici, uniquement conditions 1 et 3
  # Conditions 1 et 3 :
  #   - Une date de sortie est renseignée
  #   - La sortie est définitive OU La case Solde événements temps est cochée
#  If CTRXITDAT=[0/0/0] | CTRXITDAT>DATPAY | (CTRXITFNL<>2 & CTRCLEEVETIM<>2) Then End : Endif
  If CTRXITDAT=[0/0/0] | (CTRXITFNL<>2 & CTRCLEEVETIM<>2) Then End : Endif

  #JOJAC - 2017-01-04 - X3-12122 - START
  #If clalev([F:PEO2])=0 : Local File PERIOD [PEO2] : Endif
  If clalev([F:HRPEOD2])=0 : Local File HRPEODET [HRPEOD2] : Endif
  #JOJAC - 2017-01-04 - X3-12122 - END
  LEC_OK = 1
  #JOJAC - 2017-01-04 - X3-12122 - START
  #Read [PEO2]PEO0 = LESITE;DATPAY
#  If fstat>2 Then
#    Read [PEO2]PEO0="";DATPAY
#    If fstat>2 Then
#      Read [PEO2]PEO0(1) = LESITE
#      If fstat<=2 Then
#        Filter [PEO2] Where FCY=LESITE & PYRDAT>=DATPAY
#        Read [PEO2]PEO0 First
#      Else
#        Filter [PEO2] Where FCY="" & PYRDAT>=DATPAY
#        Read [PEO2]PEO0 First
#      Endif
#      Filter [PEO2]
#    Endif
  Filter [HRPEOD2] Where PERCOD = HRCTRPERCOD & PYRDAT = DATPAY
  Read [HRPEOD2] First
  Filter [HRPEOD2]
  #JOJAC - 2017-01-04 - X3-12122 - END
  # FQ104252 - 04/12/14 no OK car il risque de prendre une ligne sans site pour la même année avec PYRDAT >
#    Filter [PEO2] Where (FCY=LESITE | FCY="") & PYRDAT>=DATPAY Order By PYRDAT Asc; FCY Desc
#    Read [PEO2] First
#    Filter [PEO2]
  If !fstat Then
    DATFINPER  = [F:HRPEOD2]PEREND(0)
    DATFINMOIS = [F:HRPEOD2]PEREND(1)
    LEC_OK = 2
  Endif

  # FQ102316 - 01/09/14 - Changement condition 2
  #   - Condition 2 :
  #       * La date de sortie est inférieure ou égale à la date de fin de mois
  #       OU
  #       * Le mois de sortie=mois de date de paie (mois de date paie -1 si paie décalée) ET La date de sortie est comprise dans la période d’extraction suivante
  If LEC_OK=2 Then
    If CTRXITDAT>DATFINMOIS Then
      EXIT=1
      MDATFINMOIS=month(DATPAY) : YDATFINMOIS=year(DATPAY)
      # FQ104252 - 04/12/14 - Contrôle de l'année aussi, pas que du mois
#      If year(CTRXITDAT)=YDATFINMOIS Then
#        If val(func AFNC.PARAM('DMA',LESITE))<>12 Then
#          If month([F:PEO2]PEREND(1))>1 Then
#            MDATFINMOIS=month([F:PEO2]PEREND(1))+1
#            If CTRXITDAT=DATPAY Then EXIT=2 : Endif
#          Else
#            MDATFINMOIS=12
#          Endif
#        Endif
#        If EXIT=1 Then
#          Read [F:PEO2] Next
#          If !fstat & month(CTRXITDAT)=MDATFINMOIS & CTRXITDAT>=[F:PEO2]PERSTR(1) & CTRXITDAT<=[F:PEO2]PEREND(1) Then
#          Else
#            EXIT=2
#          Endif
#        Endif
#      Endif

      If val(func AFNC.PARAM('DMA',LESITE))<>12 Then
        If month(DATPAY)>1 Then
          MDATFINMOIS=month(DATPAY)-1
#          If CTRXITDAT=DATPAY Then EXIT=2 : Endif
        Else
          MDATFINMOIS=12
        Endif
        If CTRXITDAT=DATPAY Then EXIT=2 : Endif
      Endif
      If year(CTRXITDAT)=YDATFINMOIS Then
        If EXIT=1 Then
          # FQ104252 - 04/12/14 - Recalcul de la période suivante
#          Read [F:PEO2] Next
#          If !fstat & month(CTRXITDAT)=MDATFINMOIS & CTRXITDAT>=[F:PEO2]PERSTR(1) & CTRXITDAT<=[F:PEO2]PEREND(1) Then
          Gosub FIND_NEXT_PEO
          #ADNGO - 2017-02-03- X3-12122- START
          #If FOUND_PEO & month(CTRXITDAT)=MDATFINMOIS & CTRXITDAT>=[F:PEO2]PERSTR(1) & CTRXITDAT<=[F:PEO2]PEREND(1) Then
          If FOUND_PEO & month(CTRXITDAT)=MDATFINMOIS & CTRXITDAT>=[F:HRPEOD2]PERSTR(1) & CTRXITDAT<=[F:HRPEOD2]PEREND(1) Then
          #ADNGO - 2017-02-03- X3-12122- END
          Else
            EXIT=2
          Endif
        Endif
      Else
        EXIT=2
      Endif
    Else
      EXIT=1
    Endif
  Endif
  If EXIT=2 Then End : Endif
  # Fin FQ102316

  EXITSAL = 1
  # Condition 4 :
  #       * La date de sortie est supérieure ou égale à la date de fin d’extraction
  #       OU
  #       * La date de sortie est comprise dans la période d’extraction
#  If LEC_OK=2 & (CTRXITDAT>=DATFINPER | (CTRXITDAT>=DATDEB & CTRXITDAT<=DATFIN)) Then
  If LEC_OK=2 & ((CTRXITDAT>=DATFINPER | (CTRXITDAT>=DATDEB & CTRXITDAT<=DATFIN)) | EXIT=1) Then
    DATFIN  = CTRXITDAT
#    FINMOIS = [F:PEO2]PEREND(1)
    FINMOIS = DATFINMOIS
    EXITSAL = 2
  Endif
End

# FQ104252 - 04/12/14 - Recalcul de la période suivante
$FIND_NEXT_PEO
Local Integer FOUND_PEO : FOUND_PEO=1

  #JOJAC - 2017-01-04 - X3-12122 - START
  #If clalev([F:PEO3])=0 : Local File PERIOD [PEO3] : Endif
  # On positionne PEO3 sur l'enregistrement PEO2 en cours
  #Read [F:PEO3]PEO0=[F:PEO2]FCY;[F:PEO2]PYRDAT
  If clalev([F:HRPEOD3])=0 : Local File HRPEODET [HRPEOD3] : Endif
  Read [F:HRPEOD3]HRPEOD1=HRCTRPERCOD;[F:HRPEOD2]PYRDAT
  #JOJAC - 2017-01-04 - X3-12122 - END

  # On cherche l'enregistrement suivant
  #JOJAC - 2017-01-04 - X3-12122 - START
  #Filter [F:PEO2] Where FCY=LESITE & PYRDAT>[F:PEO3]PYRDAT
  #Read [F:PEO2] First
  Filter [F:HRPEOD2] Where PERCOD=HRCTRPERCOD & PYRDAT>[F:HRPEOD3]PYRDAT
  Read [F:HRPEOD2] First
  #JOJAC - 2017-01-04 - X3-12122 -  END

#JOJAC - 2017-01-04 - X3-12122 -  START
#  If fstat Then
#    Filter [F:PEO2] Where FCY="" & PYRDAT>[F:PEO3]PYRDAT
#    Read [F:PEO2] First
#  Endif
#JOJAC - 2017-01-04 - X3-12122 -  END
  # FQ104252 - 04/12/14 no OK car il risque de prendre une ligne sans site pour la même année avec PYRDAT >
#  Filter [PEO2] Where (FCY=LESITE | FCY="") & PYRDAT>[F:PEO3]PYRDAT Order By PYRDAT Asc; FCY Desc
#  Read [PEO2] First
#  Filter [PEO2]

  If fstat Then FOUND_PEO=0 : Endif
  #JOJAC - 2017-01-04 - X3-12122 -  START
  #Filter [F:PEO2]
  Filter [F:HRPEOD2]
  #JOJAC - 2017-01-04 - X3-12122 -  END
Return

$ERRSAI
If !ERR
 If SEMDEB=[0/0/0]
  # Période
#MIPEA - 2017-02-01- X3-12122- START
  Call ECR_TRACE(MATRI-[F:ID]NAM-[F:ID]SRN-format$("D:"+GFMDAT4,DATPAY)-mess(128,10709,1)
&  -format$("D:"+GFMDAT4,DATDEB)-"-"-format$("D:"+GFMDAT4,DATFIN),1) From GESECRAN
 Else
  # Semaine xx Période
  Call ECR_TRACE(MATRI-[F:ID]NAM-[F:ID]SRN-mess(57,10709,1)-num$(week(SEMDEB))-mess(128,10709,1)
&  -format$("D:"+GFMDAT4,DATDEB)-"-"-format$("D:"+GFMDAT4,DATFIN),1) From GESECRAN
#  Call ECR_TRACE(MATRI-[F:ID]NAM-[F:ID]SRN-format$("D:"+GFMDAT4,DATPAY)-mess(128,709,1)
#&  -format$("D:"+GFMDAT4,DATDEB)-"-"-format$("D:"+GFMDAT4,DATFIN),1) From GESECRAN
# Else
#  # Semaine xx Période
#  Call ECR_TRACE(MATRI-[F:ID]NAM-[F:ID]SRN-mess(57,709,1)-num$(week(SEMDEB))-mess(128,709,1)
#&  -format$("D:"+GFMDAT4,DATDEB)-"-"-format$("D:"+GFMDAT4,DATFIN),1) From GESECRAN
#MIPEA - 2017-02-01- X3-12122- END
 Endif
 ERR = 1
Endif
Call ECR_TRACE("--"-MESSAGE,0) From GESECRAN
Return

