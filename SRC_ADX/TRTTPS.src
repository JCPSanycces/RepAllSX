#######################################################
## Contrôle des paramètres
#######################################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

#######################################################
## Traitement de fin
#######################################################
$FIN
Return

###############################
$FILTRE_VEP
Local Char CRITVEP (250)
CRITVEP = "1=1"
If dim([M:DIA]FLGVAR)>=0 :
 If [M:DIA]FLGVAR=2    : CRITVEP -= '& [F:VEP]FLGVAR <> 2'  : Endif
 If [M:DIA]FLGPRFSUP=2 : CRITVEP -= '& [F:VEP]PRFSUP = "" ' : Endif
Elsif dim([M:VEP0]FLGVAR)>=0
If [M:VEP0]FLGVAR=2
 CRITVEP -= '& [F:VEP]FLGVAR = 2'
Else
# Values can be 0, 1 or 2...
 CRITVEP -= '& [F:VEP]FLGVAR <> 2'
Endif
 CRITVEP -= '& [F:VEP]PRFSUP ="'+[M:VEP1]PRFSUP+'"'
Endif
# FQ91472 - 18/07/14 - Le critère n'est plus sur la date exacte, mais sur une fourchette de dates (STRCTRDAT et CTRDAT) pour gérer
# la consolidation des bulletins
# Pour un même salarié, avec plusieurs périodes d'activité, on peut avoir plusieurs bulletins avec la même date
# de paie. Dans ce cas, pour affecter les valeurs sur le bon bulletin, il faut ajouter la date du contrat dans le critère de filtre
#If dim(CTRDAT_VEP)>0 & CTRDAT_VEP<>[0/0/0] Then
# CRITVEP -= '& [F:VEP]CTRDAT=CTRDAT_VEP'
#Elsif dim([M:VEP0]CTRDAT)>0 & [M:VEP0]CTRDAT<>[0/0/0] Then
# CRITVEP -= '& [F:VEP]CTRDAT=[M:VEP0]CTRDAT'
#Elsif dim([M]CTRDAT)>0 & [M]CTRDAT<>[0/0/0] Then
# CRITVEP -= '& [F:VEP]CTRDAT=[M]CTRDAT'
#Endif
If dim(CTRDAT_VEP)>0 & CTRDAT_VEP<>[0/0/0] Then
 CRITVEP -= '& CTRDAT_VEP>=[F:VEP]STRCTRDAT & CTRDAT_VEP<=[F:VEP]CTRDAT'
Elsif dim([M:VEP0]CTRDAT)>0 & [M:VEP0]CTRDAT<>[0/0/0] Then
 CRITVEP -= '& [M:VEP0]CTRDAT>=[F:VEP]STRCTRDAT & [M:VEP0]CTRDAT<=[F:VEP]CTRDAT'
Elsif dim([M]CTRDAT)>0 & [M]CTRDAT<>[0/0/0] Then
 CRITVEP -= '& [M]CTRDAT>=[F:VEP]STRCTRDAT & [M]CTRDAT<=[F:VEP]CTRDAT'
Endif
Return

#######################################################
## Exécution silencieuse du traitement
#######################################################
$EXEC
Local Date    DATFINPAY , DATPAY , DATPAY2, DATMAT, DATFIN, DATFIN_P, FINMOIS, CTRD
Local Integer RETOUR , OK, EXITSAL
#ADNGO - 2017-02-03- X3-12122- START
#Local Char    MATCUR(GLONMAT) , MATREF(GLONMAT) , MATRI(GLONMAT) , SYMBOLE(50) , SYMBOLEBIS(50), CTR(GLONCTR), MATRIPCE(GLONMAT)
Local Char    MATCUR(GLONEML) , MATREF(GLONEML) , MATRI(GLONEML) , SYMBOLE(50) , SYMBOLEBIS(50), CTR(GLONHRCTR), MATRIPCE(GLONEML)
#ADNGO - 2017-02-03- X3-12122- END
DATPAY = [M:DIA]DAT

#ouverture de la trace et écriture de l'en-tête
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

# mise en place des filtres
CRITERE = "[F:ID]ENAFLG=2 & [F:ID]FLGTPS=2"
#MIPEA - 2017-02-08- X3-12122- START
CRITERE -= '& [F:FCY]LEG = "'+GCURLEG+'"'
#MIPEA - 2017-02-08- X3-12122- END
If [M:DIA]ALLCPY<>2  #société
 CRITERE -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2  #site
 CRITERE -= '& [F:CTRT]ETRFCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]MATDEB<>"" #borne début matricule
 CRITERE -= '& [F:ID]REFNUM>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITERE -= '& [F:ID]REFNUM<="'+[M:DIA]MATFIN+'"'
Endif

# FQ85820 - 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat
# FQ82073 & FQ88356 - 22/02/13 - Remplacement [M:DIA]DATFIN par [M:DIA]FMOIS


# FQ88838 - 28/03/13 - Si périodes d'extraction différentes sur certains sites, et que les coches Toutes sociétés/ Tous sites sont à Oui
# il ne faut pas se baser sur la période affichée dans l'écran de paramétrage, mais sur la date de paie
#CRITERE1  = '([F:CTRT]CTRDAT<=['+format$(GFMD,[M:DIA]FMOIS)+'] | ([F:CTRT]FLGRET=2 & [F:CTRT]RETDATEFF<=['+format$(GFMD,[M:DIA]FMOIS)+']))'
CRITERE1  = '([F:CTRT]CTRDAT<=['+format$(GFMD,[M:DIA]DAT)+'] | ([F:CTRT]FLGRET=2 & [F:CTRT]RETDATEFF<=['+format$(GFMD,[M:DIA]DAT)+']))'
# Fin FQ88838
CRITERE1 -= ' & ([F:CTRT]XITDAT=[0/0/0] | [F:CTRT]XITDAT>=['+format$(GFMD,[M:DIA]DATDEB)+'])'
# Fin 85820
#JOJAC - 2016-12-13 - X3-12122 -  START
CRITERE1 -= '& [F:CTRT]PERCOD<="'+[M:DIA]PERCOD+'"'
#JOJAC - 2016-12-13 - X3-12122 -  END

# FQ85820 - 30/04/13 - La vérification se fait maintenant dans VERIF_FLD, selon la rétroactivité
#If [M:DIA]ALLSRV<>2  #service
# CRITERE1 -= '& [F:CTRT]ETRSRV = "'+[M:DIA]SRV+'"'
#Endif
#If [M:DIA]ALLPRF<>2  #profil
# CRITERE1 -= '& [F:CTRT]PROPRF = "'+[M:DIA]PRF+'"'
#Endif
# Fin FQ85820

If [M:DIA]POP<>""
 Link [CTRT] With
&   [ID]ID0   = [F:CTRT]REFNUM
& , [FCY]FCY0 = [F:CTRT]ETRFCY
& , [POA]POA0 = [M:DIA]POP;[F:ID]REFNUM
& , [CPY]CPY0 = [F:FCY]LEGCPY
&   As [LNK]
&   Where evalue(CRITERE1) & evalue(CRITERE) & [F:POA]REFNUM<>""
Else
 Link [CTRT] With
&   [ID]ID0   = [F:CTRT]REFNUM
& , [FCY]FCY0 = [F:CTRT]ETRFCY
& , [CPY]CPY0 = [F:FCY]LEGCPY
&   As [LNK]
&   Where evalue(CRITERE1) & evalue(CRITERE)
Endif

# Performances arrêté des temps
Gosub INIT_PARAM_CP

Gosub FILTRE_VEP

#FQ92876-US2768-
GORITITCOL = 1
#----- Variables globales pour le multi-référenciels comptabilité -----#
Gosub SAUV_GLOBAL_CPT From TRTHRCPT
#END FQ92876-US2768-

# Traitement
Local Integer NEWMAT
Local Date    PYRDATPEO
Local Char    FCYPEO(GLONFCY)
#JOJAC - 2016-12-13 - X3-12122 -  START
Local Char PERCODPEO(GLONHRPEO)
#JOJAC - 2016-12-13 - X3-12122 -  END
Local Char    VALPAR(10)        :#94084
Local Integer NEWCTR
Local Date WCTRD(0..8) # FQ91472 US2912 SEGAY
Raz WCTRD
#JOJAC - 2016-12-13 - X3-12122 -  START
#PYRDATPEO=[F:PEO]PYRDAT : FCYPEO=[F:PEO]FCY
PYRDATPEO=[F:HRPEOD]PYRDAT : FCYPEO=[F:HRPEOH]FCY : PERCODPEO = [F:HRPEOD]PERCOD
#JOJAC - 2016-12-13 - X3-12122 -  END
For [LNK]
 # FQ85820 - 30/04/13 - Vérification profil/service selon rétroactivité
 If func SUBCTRRET.VERIF_FLD([F:CTRT]REFNUM,[F:CTRT]CTRNUM,[F:CTRT]CTRDAT,[M:DIA]DAT,"ETRSRV",[M:DIA]ALLSRV,[M:DIA]SRV,"CTRT")=2
& & func SUBCTRRET.VERIF_FLD([F:CTRT]REFNUM,[F:CTRT]CTRNUM,[F:CTRT]CTRDAT,[M:DIA]DAT,"PROPRF",[M:DIA]ALLPRF,[M:DIA]PRF,"CTRT")=2 Then
 # Fin FQ85820
# # NEWMAT=0 : # Verrouillé US 2022 65062
   # FQ98507 - 27/05/14 - Le décompte ne doit être fait que si le TRTCONT est ok, donc déplacement dans la boucle "If OK"
#   If MATRI<>[F:ID]REFNUM Then
#    NEWMAT=1
#   Endif
   NEWCTR=0
   If CTR=[F:CTRT]CTRNUM & CTRD<>[F:CTRT]CTRDAT Then
    NEWCTR=1
   Endif
   MATRI  = [F:ID]REFNUM
   DATMAT = [M:DIA]DAT
   CTR    = [F:CTRT]CTRNUM
   CTRD   = [F:CTRT]CTRDAT
   #JOJAC - 2016-12-13 - X3-12122 -  START
   #Gosub LECEMP From DEFTABLE
   Gosub LECEMP From WPDEFTABLE
   #JOJAC - 2016-12-13 - X3-12122 -  END

   Local Date CTRDAT_VEP : CTRDAT_VEP=CTRD : # Verrouillé US 2022 65062
   Gosub FILTRE_VEP : # Verrouillé US 2022 65062
   Gosub TRTCONT
   If OK
    #92876 US2768
    # Repositionnement sur le contrat initial car le Lecemp et TRTCONT a pu changer ! comme dans SUBVEP car o utilise CTR dans TRTANA
    #JOJAC - 2016-12-13 - X3-12122 -  START
    #Read[F:CTR]CTR0=MATRI;CTR;CTRD
    Read[F:HRCTR]CTR0=MATRI;CTR;CTRD
    #JOJAC - 2016-12-13 - X3-12122 -  END
    # FQ98507 - 27/05/14 - Le décompte ne doit être fait que si le TRTCONT est ok, donc déplacement dans la boucle "If OK"
    NEWMAT=0
    If MATRIPCE<>[F:ID]REFNUM Then
     NEWMAT=1
     MATRIPCE=[F:ID]REFNUM
    Endif
    # FQ82073 - Si plusieurs paies sur le même mois
    DATPAY2=DATPAY

    #94084
    If GPAYE

     # JPAY <> 0 uniquement si gestion en décalage de paie (DMA=11)
     Call PARAML([F:CTRT]ETRFCY,"JPAY",VALPAR) From ADOVAL
     If val(VALPAR)<>0 & val(VALPAR)<>day(DATPAY2)
       While day(DATPAY2)<>val(VALPAR)
        DATPAY2 += 1
       Wend
     Endif

     # DMA=12
     If val(func AFNC.PARAM('DMA',[F:CTRT]ETRFCY))=12 & val(func AFNC.PARAM('UNQDATPAY',[F:CTRT]ETRFCY))<>2    :# dates de paie différentes pour CDD successifs
      If [F:CTRT]XITDAT<>[0/0/0]
       DATPAY2 = min(DATPAY,[F:CTRT]XITDAT)

       # FQ93131 - 08/10/13 - Pour un même salarié, avec plusieurs périodes d'activité, on peut avoir plusieurs bulletins avec la même date
       # de paie. Dans ce cas, pour affecter les valeurs sur le bon bulletin, il faut ajouter la date du contrat dans le critère de filtre
       Local Date CTRDAT_VEP
       If clalev([F:CTRT]) Then CTRDAT_VEP=[F:CTRT]CTRDAT : Endif
       # Fin FQ93131

       Gosub FILTRE_VEP From TRTTPS
       #JOJAC - 2016-12-13 -  X3-12122 - START
       #Filter [VEP] Where EMP=MATRI & PYRDAT=DATPAY2 & CTRNUM=CTR & CTRDAT=CTRD & evalue (CRITVEP)
       Filter [VEP] Where EMP=MATRI & PYRDAT=DATPAY2 & CTRNUM=CTR & CTRDAT=CTRD & PERCOD=[M:DIA]PERCOD & evalue (CRITVEP)
       #JOJAC - 2016-12-13 - X3-12122 -  END
       Read [F:VEP] Last
       If fstat Then
         #JOJAC - 2016-12-13 - X3-12122 -  START
         #Filter [VEP] Where EMP=MATRI & PYRDAT=DATPAY & CTRNUM=CTR & CTRDAT=CTRD & evalue (CRITVEP)
         Filter [VEP] Where EMP=MATRI & PYRDAT=DATPAY & CTRNUM=CTR & CTRDAT=CTRD & PERCOD = [M:DIA]PERCOD & evalue (CRITVEP)
         #JOJAC - 2016-12-13 - X3-12122 -  END
         Read [F:VEP] Last
         If !fstat Then DATPAY2=DATPAY : Endif
       Endif
       Filter [VEP]
      Endif
     Endif
    Endif
    #JOJAC - 2016-12-13 - X3-12122 -  START
    #Read [F:PEO]PEO0=FCYPEO;PYRDATPEO
    Read [F:HRPEOD]HRPEOD1=[M:DIA]PERCOD;PYRDATPEO
    #JOJAC - 2016-12-13 - X3-12122 -  END
    If dim([M:DIA]SAI)>0 & [M:DIA]SAI=2
     #Contrôle de saisie
     Call CONTSAI([M:DIA]FCY,MATRI,CTR,DATPAY,[0/0/0],[0/0/0])
    Endif
    If dim([M:DIA]FRT)>0 & [M:DIA]FRT=2
     #Génération des temps issus de la formation
     DATFIN=[M:DIA]DATFIN
     DATFIN_P=DATFIN
     # FQ99390 - 16/05/14 - Ajout nouveaux paramètres dans CALC_DATEND
#MIPEA - 2017-01-20- X3-12122- START
     Call CALC_DATEND([M:DIA]FCY, DATPAY, [F:CTRT]XITDAT, [F:CTRT]XITFNL, [F:CTRT]CLEEVETIM, [M:DIA]DATDEB, DATFIN, FINMOIS, EXITSAL, [F:CTRT]PERCOD)
#     Call CALC_DATEND([M:DIA]FCY, DATPAY, [F:CTRT]XITDAT, [F:CTRT]XITFNL, [F:CTRT]CLEEVETIM, [M:DIA]DATDEB, DATFIN, FINMOIS, EXITSAL)
#MIPEA - 2017-01-20- X3-12122- END
     DATFIN_P=max(DATFIN, DATFIN_P)
     #JOJAC - 2016-12-13 - START
     #Read [F:PEO]PEO0=FCYPEO;PYRDATPEO
     Read [F:HRPEOD]HRPEOD1=[M:DIA]PERCOD;PYRDATPEO
     #JOJAC - 2016-12-13 - END
     Call MAJ(MATRI,DATPAY,CTR,[M:DIA]DATDEB,DATFIN,([M:DIA]TRA=2)) From TRTFOR
    Endif
    If [M:DIA]GEN=2
     #Remplissage automatique
     #JOJAC - 2016-12-13 - START
     #Read [F:PEO]PEO0=FCYPEO;PYRDATPEO
     Read [F:HRPEOD]HRPEOD1=[M:DIA]PERCOD;PYRDATPEO
     #JOJAC - 2016-12-13 - END
     Local Date CTRDAT_VEP : CTRDAT_VEP=CTRD
     # FQ97072 - 27/03/14 - Date de contrat sur laquelle générer les temps
#     Call MAJ(MATRI,DATPAY,CTR,([M:DIA]TRA=2),0) From TRTREM
     Call MAJ_GEN(MATRI,DATPAY2,CTR,([M:DIA]TRA=2),0,CTRD) From TRTREM
     # Fin FQ97072
    Endif
    If dim([M:DIA]SYN)>0 & [M:DIA]SYN=2
     #Mise à jour synthèse
     # FQ98507 - 26/05/14 - Ajout paramètre sur appel de TRTSYN.MAJ
     # FQ82073 - Ajout paramètre CTRD + DATPAY changé en DATPAY2
     # BRBAN 18/06/2014 SAM 96364
     If func AFNC.PARAM("WEEK",FCYPEO)<>'1'
      #JOJAC - 2016-12-13 - START
      #Read [F:PEO]PEO0=FCYPEO;PYRDATPEO
      Read [F:HRPEOD]HRPEOD1=[M:DIA]PERCOD;PYRDATPEO
      #JOJAC - 2016-12-13 - START
#JASMI - 2017-02-02 - Issue 121325 - START
#MIPEA - 2017-02-01- X3-12122- START
#LIPET - 2017-04-10 - X3-32083 - START
      #Call MAJ(MATRI,DATPAY2,CTR,CTRD,([M:DIA]SYN=2),0,([M:DIA]MEL=2),([M:DIA]TRA=2),func TPSDAT(MATRI,DATPAY2,CTR,CTRD),NEWCTR,WCTRD) From TRTHRSYN
     #Call MAJ(MATRI,DATPAY2,CTR,CTRD,([M:DIA]SYN=2),0,([M:DIA]MEL=2),([M:DIA]TRA=2),func TPSDAT(MATRI,DATPAY2,CTR,CTRD),NEWCTR,WCTRD) From TRTHRSYN
     Call MAJ(MATRI,DATPAY2,CTR,CTRD,([M:DIA]SYN=2),0,([M:DIA]MEL=2),([M:DIA]TRA=2),func TPSDAT(MATRI,DATPAY2,CTR,CTRD),NEWCTR,WCTRD,0) From TRTHRSYN
#LIPET - 2017-04-10 - X3-32083 - END
#      Call MAJ(MATRI,DATPAY2,CTR,CTRD,([M:DIA]SYN=2),0,([M:DIA]MEL=2),([M:DIA]TRA=2),func TPSDAT(MATRI,DATPAY2,CTR,CTRD),NEWCTR,WCTRD) From TRTSYN
#MIPEA - 2017-02-01- X3-12122- END
#JASMI - 2017-02-02 - Issue 121325 - END
     Endif
     #
    Endif
    If dim([M:DIA]VRA)>=0 & [M:DIA]VRA=2
     #Mise à jour variables
     # FQ82073 - Ajout paramètre CTRD + DATPAY changé en DATPAY2
     #JOJAC - 2016-12-13 - START
     #Filter [VEP] Where EMP=MATRI & PYRDAT=DATPAY2 & CTRNUM=CTR & evalue(CRITVEP)
     Filter [VEP] Where EMP=MATRI & PYRDAT=DATPAY2 & CTRNUM=CTR & PERCOD = [M:DIA]PERCOD &  evalue(CRITVEP)
     #JOJAC - 2016-12-13 - END
     Read [VEP]VEP0 Last
     Filter [VEP]
     If fstat<=2
      # FQ98507 - 26/05/14 - Ajout paramètre sur appel de TRTSYN.MAJ
      # FQ82073 - Ajout paramètre CTRD + DATPAY changé en DATPAY2
      #JOJAC - 2016-12-13 - START
      #Read [F:PEO]PEO0=FCYPEO;PYRDATPEO
      Read [F:HRPEOD]HRPEOD1=[M:DIA]PERCOD;PYRDATPEO
      #JOJAC - 2016-12-13 - END
#MIPEA - 2017-02-01- X3-12122- START
#LIPET - 2017-04-10 - X3-32083 - START
      #Call MAJ(MATRI,DATPAY2,CTR,CTRD,0,([M:DIA]VRA=2),([M:DIA]MEL=2),([M:DIA]TRA=2),func TPSDAT(MATRI,DATPAY2,CTR,CTRD),NEWCTR,WCTRD) From TRTHRSYN
      #JOJAC - 2017-10-26 - X3-15908 - START
      #If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
      If [M:DIA]PRE=2
      #JOJAC - 2017-10-26 - X3-15908 - END
      #JASMI - 2017-02-01 - Issue 121325 - START
#        Call MAJ(MATRI,DATPAY2,CTR,CTRD,0,([M:DIA]VRA=2),([M:DIA]MEL=2),([M:DIA]TRA=2),func TPSDAT(MATRI,DATPAY2,CTR,CTRD),NEWCTR,WCTRD) From TRTHRSYN
#      Else
#        Call MAJ(MATRI,DATPAY2,CTR,CTRD,0,([M:DIA]VRA=2),([M:DIA]MEL=2),([M:DIA]TRA=2),func TPSDAT(MATRI,DATPAY2,CTR,CTRD),NEWCTR,WCTRD) From TRTHRSYN
#      Endif
        Call MAJ(MATRI,DATPAY2,CTR,CTRD,0,([M:DIA]VRA=2),([M:DIA]MEL=2),([M:DIA]TRA=2),func TPSDAT(MATRI,DATPAY2,CTR,CTRD),NEWCTR,WCTRD,([M:DIA]PRE=2)) From TRTHRSYN
      Else
        Call MAJ(MATRI,DATPAY2,CTR,CTRD,0,([M:DIA]VRA=2),([M:DIA]MEL=2),([M:DIA]TRA=2),func TPSDAT(MATRI,DATPAY2,CTR,CTRD),NEWCTR,WCTRD,0) From TRTHRSYN
      Endif
      #JASMI - 2017-02-01 - Issue 121325 - END
#LIPET - 2017-04-10 - X3-32083 - END
#      Call MAJ(MATRI,DATPAY2,CTR,CTRD,0,([M:DIA]VRA=2),([M:DIA]MEL=2),([M:DIA]TRA=2),func TPSDAT(MATRI,DATPAY2,CTR,CTRD),NEWCTR,WCTRD) From TRTSYN
#MIPEA - 2017-02-01- X3-12122- END
      #
     Else
     #JOJAC - 2016-12-13 - START
#      Filter [VEP] Where EMP=MATRI & PYRDAT<=DATPAY & STRDAT>=[F:PEO]PERSTR(1) & ENDDAT<=[F:PEO]PEREND(1) & CTRNUM=CTR
#&                      & evalue(CRITVEP)
       Filter [VEP] Where EMP=MATRI & PYRDAT<=DATPAY & STRDAT>=[F:HRPEOD]PERSTR(1) & ENDDAT<=[F:HRPEOD]PEREND(1) & CTRNUM=CTR
&                      & PERCOD = [M:DIA]PERCOD &  evalue(CRITVEP)
      #JOJAC - 2016-12-13 - END
      Read [VEP]VEP0 Last
      Filter [VEP]
      If !fstat
       Call VEPSYMBOLE (SYMBOLEBIS, "VEP") From DIVPAYE
       Lock =SYMBOLEBIS
       If fstat
        Call ECR_TRACE([F:ID]REFNUM-":"-mess(10,100,1),1) From GESECRAN
       Else
        # FQ98507 - 26/05/14 - Ajout paramètre sur appel de TRTSYN.MAJ
        # FQ82073
        #JOJAC - 2016-12-13 - START
        #Read [F:PEO]PEO0=FCYPEO;PYRDATPEO
        Read [F:HRPEOD]HRPEOD1=[M:DIA]PERCOD;PYRDATPEO
        #JOJAC - 2016-12-13 - END
#MIPEA - 2017-02-01- X3-12122- START
#LIPET - 2017-04-10 - X3-32083 - START
#        Call MAJ(MATRI,[F:VEP]PYRDAT,[F:VEP]CTRNUM,[F:VEP]CTRDAT,0,([M:DIA]VRA=2),([M:DIA]MEL=2),([M:DIA]TRA=2),func TPSDAT(MATRI,[F:VEP]PYRDAT,CTR,[F:VEP]CTRDAT),NEWCTR,WCTRD) From TRTHRSYN
        #JOJAC - 2017-10-26 - X3-15908 - START
         If [M:DIA]PRE = 2
        #If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
        #JOJAC - 2017-10-26 - X3-15908 - END
        #JASMI - 2017-02-01 - Issue 121325 - START
#          Call MAJ(MATRI,[F:VEP]PYRDAT,[F:VEP]CTRNUM,[F:VEP]CTRDAT,0,([M:DIA]VRA=2),([M:DIA]MEL=2),([M:DIA]TRA=2),func TPSDAT(MATRI,[F:VEP]PYRDAT,CTR,[F:VEP]CTRDAT),NEWCTR,WCTRD) From
#& TRTHRSYN
#        Else
#          Call MAJ(MATRI,[F:VEP]PYRDAT,[F:VEP]CTRNUM,[F:VEP]CTRDAT,0,([M:DIA]VRA=2),([M:DIA]MEL=2),([M:DIA]TRA=2),func TPSDAT(MATRI,[F:VEP]PYRDAT,CTR,[F:VEP]CTRDAT),NEWCTR,WCTRD) From TRTHRSYN
#        Endif
          Call MAJ(MATRI,[F:VEP]PYRDAT,[F:VEP]CTRNUM,[F:VEP]CTRDAT,0,([M:DIA]VRA=2),([M:DIA]MEL=2),([M:DIA]TRA=2),func TPSDAT(MATRI,[F:VEP]PYRDAT,CTR,[F:VEP]CTRDAT),NEWCTR,WCTRD,([M:DIA]PRE=2)) From
& TRTHRSYN
        Else
          Call MAJ(MATRI,[F:VEP]PYRDAT,[F:VEP]CTRNUM,[F:VEP]CTRDAT,0,([M:DIA]VRA=2),([M:DIA]MEL=2),([M:DIA]TRA=2),func TPSDAT(MATRI,[F:VEP]PYRDAT,CTR,[F:VEP]CTRDAT),NEWCTR,WCTRD,0) From TRTHRSYN
        Endif
        #JASMI - 2017-02-01 - Issue 121325 - END
#LIPET - 2017-04-10 - X3-32083 - END
#        Call MAJ(MATRI,[F:VEP]PYRDAT,[F:VEP]CTRNUM,[F:VEP]CTRDAT,0,([M:DIA]VRA=2),([M:DIA]MEL=2),([M:DIA]TRA=2),func TPSDAT(MATRI,[F:VEP]PYRDAT,CTR,[F:VEP]CTRDAT),NEWCTR,WCTRD) From TRTSYN
#MIPEA - 2017-02-01- X3-12122- END
        #
       Endif
      Endif
     Endif
    Endif
    If dim([M:DIA]ANA)>=0 & [M:DIA]ANA=2
     #MAJ Analytique
     # FQ82073 - Filtre du bulletin sur la date de contrat
     #JOJAC - 2016-12-13 - START
     #Filter [VEP] Where EMP=MATRI & PYRDAT=DATPAY2 & CTRNUM=CTR & CTRDAT=CTRD & evalue(CRITVEP)
     Filter [VEP] Where EMP=MATRI & PYRDAT=DATPAY2 & CTRNUM=CTR & CTRDAT=CTRD & PERCOD = [M:DIA]PERCOD & evalue(CRITVEP)
     #JOJAC - 2016-12-13 - END
     #
     Read [VEP]VEP0 Last
     Filter [VEP]
     If fstat<=2
      #JOJAC - 2016-12-13 - START
      #Read [F:PEO]PEO0=FCYPEO;PYRDATPEO
      Read [F:HRPEOD]HRPEOD1=[M:DIA]PERCOD;PYRDATPEO
      #JOJAC - 2016-12-13 - END
      Call MAJ(MATRI,DATPAY2,[F:VEP]CTRNUM,[F:VEP]BUL,([M:DIA]TRA=2)) From TRTANA
     Else
     #JOJAC - 2016-12-13 - START
#      Filter [VEP] Where EMP=MATRI & PYRDAT<=DATPAY & STRDAT>=[F:PEO]PERSTR(1) & ENDDAT<=[F:PEO]PEREND(1) & CTRNUM=CTR
#&                  & evalue(CRITVEP)
      Filter [VEP] Where EMP=MATRI & PYRDAT<=DATPAY & STRDAT>=[F:HRPEOD]PERSTR(1) & ENDDAT<=[F:HRPEOD]PEREND(1) & CTRNUM=CTR
&                  & PERCOD = [M:DIA]PERCOD & evalue(CRITVEP)
     #JOJAC - 2016-12-13 - LAST
      Read [VEP]VEP0 Last
      Filter [VEP]
      If !fstat
       Call VEPSYMBOLE (SYMBOLEBIS, "VEP") From DIVPAYE
       Lock =SYMBOLEBIS
       If fstat
        Call ECR_TRACE([F:ID]REFNUM-":"-mess(10,100,1),1) From GESECRAN
       Else
        #JOJAC - 2016-12-13 - START
        #Read [F:PEO]PEO0=FCYPEO;PYRDATPEO
        Read [F:HRPEOD]HRPEOD1=[M:DIA]PERCOD;PYRDATPEO
        #JOJAC - 2016-12-13 - END
        Call MAJ(MATRI,[F:VEP]PYRDAT,[F:VEP]CTRNUM,[F:VEP]BUL,([M:DIA]TRA=2)) From TRTANA
       Endif
      Endif
     Endif
    Endif
    If NEWMAT Then
      NBPCE += 1
    Endif
   Endif
   Unlock =SYMBOLE
   Unlock =SYMBOLEBIS
 Endif
Next

#FQ92876-US2675-
GORITITCOL = 0
#----- Variables globales pour le multi-référenciels comptabilité -----#
Gosub REST_GLOBAL_CPT From TRTHRCPT
#END FQ92876-US2675-

If !NBPCE
#MIPEA - 2017-02-01- X3-12122- START
 Call ECR_TRACE(mess(2,10703,1),0) From GESECRAN : # Aucun matricule à traiter
Else
 Call ECR_TRACE(mess(117,10703,1)-":"-num$(NBPCE),0) From GESECRAN : # Nombre de salariés concernés
# Call ECR_TRACE(mess(2,703,1),0) From GESECRAN : # Aucun matricule à traiter
#Else
# Call ECR_TRACE(mess(117,703,1)-":"-num$(NBPCE),0) From GESECRAN : # Nombre de salariés concernés
#MIPEA - 2017-02-01- X3-12122- END
Endif

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

$TRTCONT
OK = 0
Local Char    LESITE(GLONFCY) : #59323
#MIPEA - 2017-01-20- X3-12122- START
Local Char    HRCTRPERCOD(GLONHRPEO)
#MIPEA - 2017-01-20- X3-12122- END

Call CONTROLE([F:ID]REFNUM,[M:DIA]DAT,CTR,[M:DIA]CRI,OKC,0) From DIVPAYE
If !OKC : Return : Endif

# Paye en cours de comptabilisation ou comptabilisé
If GPAYE=1
 #JOJAC - 2016-12-13 - START
 #Filter [VEP] Where EMP=MATRI & PYRDAT=DATPAY & CTRNUM=CTR & evalue(CRITVEP)
 Filter [VEP] Where EMP=MATRI & PYRDAT=DATPAY & CTRNUM=CTR & PERCOD = [M:DIA]PERCOD & evalue(CRITVEP)
 #JOJAC - 2016-12-13 - END
 Read [VEP]VEP0 Last
 Filter [VEP]
 If !fstat & ([F:VEP]PST>1
& | [F:VEP]FLGLOCK=2)   : # Verrouillé US 2022 65062
  # Paye déjà comptabilisée
#  Call ECR_TRACE(MATRI-":"-mess(30,709,1),0) From GESECRAN  # Paie déjà comptabilisée
  If [F:VEP]PST>1
#    Call ECR_TRACE(MATRI-":"-mess(30, 709, 1),0) From GESECRAN
    #ADNGO - 2017-02-03- X3-12122- START
    #[L]WMESSAGE=MATRI-"("+mess(6,506,1)-CTR-mess(40,101,1)-format$(GFMD,[F:VEP]CTRDAT)+") :"-[F:VEP]BUL-format$(GFMD,[F:VEP]PYRDAT)-mess(157,123,1)-":"-mess(30,10709,1): #  Opération impossible :
# Paie
    [L]WMESSAGE=MATRI-"("+mess(6,10506,1)-CTR-mess(40,101,1)-format$(GFMD,[F:VEP]CTRDAT)+") :"-[F:VEP]BUL-format$(GFMD,[F:VEP]PYRDAT)-mess(157,123,1)-":"-mess(30,10709,1): #  Opération impossible :
# Paie
    #ADNGO - 2017-02-03- X3-12122- END
# déjà
# comptabilisée.
  Else : # Verrouillé US 2022 65062
    # MESSAGE : Présence de bulletins verrouillés
#    Call ECR_TRACE(MATRI-":"-mess(227, 703, 1),0) From GESECRAN
    #ADNGO - 2017-02-03- X3-12122- START
    #[L]WMESSAGE=MATRI-"("+mess(6,506,1)-CTR-mess(40,101,1)-format$(GFMD,[F:VEP]CTRDAT)+") :"-[F:VEP]BUL-format$(GFMD,[F:VEP]PYRDAT)-mess(224,10703,1): #  Opération impossible : ce bulletin est
    [L]WMESSAGE=MATRI-"("+mess(6,10506,1)-CTR-mess(40,101,1)-format$(GFMD,[F:VEP]CTRDAT)+") :"-[F:VEP]BUL-format$(GFMD,[F:VEP]PYRDAT)-mess(224,10703,1): #  Opération impossible : ce bulletin est
    #ADNGO - 2017-02-03- X3-12122- END
# verrouillé.
  Endif
  Call ECR_TRACE([L]WMESSAGE,1) From GESECRAN
  Return
 Endif
Endif


# Vérif périodes d'extraction

LESITE = [F:CTRT]ETRFCY
#MIPEA - 2017-01-20- X3-12122- START
HRCTRPERCOD = [F:CTRT]PERCOD
#MIPEA - 2017-01-20- X3-12122- END
#JOJAC - 2016-12-13 - START
#Call PERIO(LESITE,MATRI) From SUBPEO
Call PERIO(LESITE,MATRI) From SUBHRPEO
#JOJAC - 2016-12-13 - END
# FQ93131 - 18/10/13 - On cherche en premier si l'enregistrement exact existe, et ensuite on fait le reste
#Read [PEO]PEO0(1) = LESITE
#JOJAC - 2016-12-13 - START
#Read [PEO]PEO0 = LESITE;DATPAY
Read [HRPEOD]HRPEOD1 = [M:DIA]PERCOD;DATPAY
#JOJAC - 2016-12-13 - END
If fstat=0 Then
  #JOJAC - 2016-12-13 - START
  #PYRDATPEO=[F:PEO]PYRDAT : FCYPEO=[F:PEO]FCY
  PYRDATPEO=[F:HRPEOD]PYRDAT : FCYPEO=[F:HRPEOH]FCY
  #JOJAC - 2016-12-13 - END
Else
 #JOJAC - 2016-12-13 - START
 #Read [PEO]PEO0(1) = LESITE
 Read [HRPEOD]HRPEOD1(1) = [M:DIA]PERCOD
 #JOJAC - 2016-12-13 - END
 # FQ95144 - 16/12/13 - Si fstat=0 avec une date de paie >DATPAY, c'est que la 1ere période d'extraction pour ce site, est sur une date postérieure
 # Comme on veut traiter le mois en cours, ajout du test & [F:PEO]PYRDAT<DATPAY
 #JOJAC - 2016-12-13 - START
 #If fstat<=2 & [F:PEO]PYRDAT<DATPAY
   #Filter [PEO] Where FCY=LESITE & PYRDAT>=DATPAY
   #Read [PEO]PEO0 First
 If fstat<=2 & [F:HRPEOD]PYRDAT<DATPAY
  Filter [HRPEOD] Where PERCOD=[M:DIA]PERCOD & PYRDAT>=DATPAY
  Read [HRPEOD]HRPEOD1 First
  #JOJAC - 2016-12-13 - END
  # Si on est dans ce If (fstat<=2), c'est parce que ce site a eu une période d'extraction spécifique une année. Mais ce n'est plus le cas sur l'année de DATPAY
  If fstat=4 Then
  #JOJAC - 2016-12-13 - START
   #Filter [PEO] Where FCY="" & PYRDAT>=DATPAY
   #Read [PEO]PEO0 First
   Filter [HRPEOD] Where PERCOD = [M:DIA]PERCOD & PYRDAT>=DATPAY
   Read [HRPEOD]HRPEOD1 First
   #JOJAC - 2016-12-13 - END
  Endif
 Else
  #JOJAC - 2016-12-13 - START
  #Filter [PEO] Where FCY="" & PYRDAT>=DATPAY
  #Read [PEO]PEO0 First
  Filter [HRPEOD] Where PERCOD = [M:DIA]PERCOD & PYRDAT>=DATPAY
  Read [HRPEOD]HRPEOD1 First
  #JOJAC - 2016-12-13 - END
 Endif
 # FQ104252 - 04/12/14 no OK car il risque de prendre une ligne sans site pour la même année avec PYRDAT >
# Filter [PEO] Where (FCY=LESITE | FCY="") & PYRDAT>=DATPAY Order By PYRDAT Asc; FCY Desc
# Read [PEO] First
#JOJAC - 2016-12-13 - START
 #Filter [PEO]
 Filter [HRPEOD]
#JOJAC - 2016-12-13 - END
 If fstat>2
#MIPEA - 2017-02-01- X3-12122- START
  Call ECR_TRACE(MATRI-format$("D:"+GFMDAT,DATPAY)-":"-mess(92,10703,1),1) From GESECRAN
#  Call ECR_TRACE(MATRI-format$("D:"+GFMDAT,DATPAY)-":"-mess(92,703,1),1) From GESECRAN
#MIPEA - 2017-02-01- X3-12122- END
  # Pas de période d'extraction des temps
  Return
 Endif
Endif

  ##**88946
#JOJAC - 2016-12-13 - START
#PYRDATPEO=[F:PEO]PYRDAT : FCYPEO=[F:PEO]FCY
PYRDATPEO=[F:HRPEOD]PYRDAT : FCYPEO=[F:HRPEOH]FCY
#JOJAC - 2016-12-13 - END
  ##**

# Présence du salarié
# FQ93131 - 18/10/13 - Ajout filtre sur XITFNL, car le salarié peut avoir plusieurs contrats dans le même mois, sans sortie définitive
#JOJAC - 2016-12-13 - START
#If [F:CTRT]XITDAT<[F:PEO]PERSTR & [F:CTRT]XITDAT<>[0/0/0] & [F:CTRT]XITFNL=2
If [F:CTRT]XITDAT<[F:HRPEOD]PERSTR & [F:CTRT]XITDAT<>[0/0/0] & [F:CTRT]XITFNL=2
#JOJAC - 2016-12-13 - END
 Return
Endif

# Verrou
If GPAYE
  #90728
  #SYMBOLE = "VEP"+format$("D:"+GFMDAT,DATPAY)+"\"+[F:ID]REFNUM+"\"+[F:CTRT]CTRNUM+format$("D:"+GFMDAT,[F:CTRT]CTRDAT)
  SYMBOLE = "VEP"+format$("D:"+GFMDAT,DATPAY)+"\"+[F:CTRT]CTRNUM+format$("D:"+GFMDAT,[F:CTRT]CTRDAT)
  Lock =SYMBOLE
  If fstat
   Call ECR_TRACE([F:ID]REFNUM-":"-mess(10,100,1),1) From GESECRAN
   Return
  Endif
Endif
OK = 1
Return

