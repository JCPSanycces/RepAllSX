#<AdxTL>@(#)12.0.0.0 $Revision$

End


######################################################################################
#  SIXBAN : pour traitements de bascule Integrale --> X3                             #
######################################################################################
#                                                                                    #
# Subprog SIXBAN                                                                     #
#     Création des comptes de banques   (Avec MAJ Adresses et RIB)                   #
#                                                                                    #
#                                                                                    #
# ---------------------------------------------------------------------------------- #
# PRE-REQUIS :                                                                       #
# ---------------------------------------------------------------------------------- #
#                                                                                    #
#                                                                                    #
#                                                                                    #
#####################################################################################


# Supp...
If !clalev([F:BAN])  : Local File BANK   [BAN]  : Endif   # Compte en banque
If !clalev([F:XBQE]) : Local File XIBQE  [XBQE] : Endif   # Banque Intégrale

Trbegin [BAN], [XBQE]
Delete [BAN] Where 1=1
Update [XBQE] Where 1=1 With FLGREP=1
Commit 
# Fin Supp
#End
    
Gosub SI_CONTEXT From SIXFONCTION

Global Integer X_NB
Call OUVRE_BOITE("XIBQE",nbrecord([XBQE])) From GESECRAN
Raz X_NB
Call EXEC
Call FERME_BOITE From GESECRAN
Kill X_NB

End
#########################################################################
Subprog EXEC

Local Integer WOUV_TRACE
If GTRACE = ""
 Call OUVRE_TRACE("SIXBAN : Process translation file from INTEGRALE to X3") From LECFIC
 WOUV_TRACE=1
Endif

Onerrgo TRT_ERR

#----  Migration des comptes bancaires : BANK  ------#
Call ECR_TIME("SIXBAN : "+SI_MES(59)+" BANK") From DOSSUB
Call SI_BANK
If GOK<>1 : Goto FIN_BAN : Endif

$FIN_BAN
Onerrgo 
If WOUV_TRACE=1
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

$TRT_ERR
Call ECR_TRACE(errp-"("-num$(errl)-") :"-errmes$(errn)-errm, 1) From GESECRAN
Resume

#########################################################################
# Création des comptes bancaires
#########################################################################
Subprog SI_BANK

Local Integer STOP, NB
Local Char LTMP(50)

If !clalev([F:BAN])  : Local File =SI_DOSSIER+".BANK"       [BAN]  : Endif   # Comptes bancaires
If !clalev([F:TCY])  : Local File =SI_DOSSIER+".TABCOUNTRY" [TCY]  : Endif   # Pays
If !clalev([F:ABN])  : Local File =SI_DOSSIER+".ABANK"      [ABN]  : Endif   # Banque
If !clalev([F:COA])  : Local File =SI_DOSSIER+".GCOA"       [COA]  : Endif   # Comptes
If !clalev([F:GAC])  : Local File =SI_DOSSIER+".GACCOUNT"   [GAC]  : Endif   # Comptes
If !clalev([F:CPY])  : Local File =SI_DOSSIER+".COMPANY"    [CPY]  : Endif   # Société X3
#Read [CPY]  First

If !clalev([F:SPX])  : Local File =SI_DOSSIER+".SIPARX3"    [SPX]  : Endif   # Paramétrage Migration Intégrale 
Read [SPX] First

Local Char    COAGEN(GLONCOA)
Call LEC_COA(1,[F:SPX]CPY,[L]COAGEN) From SIXCPY

If !clalev([F:XBAN]) : Local File =SI_DOSSIER+".XIBQE"      [XBQE] : Endif   # Banque Intégrale

Local Char    BANQUE(GLONBID)

SI_SUBPRG = "SIXBAN"
SI_TABLE  = "XIBQE"
Gosub SI_CRITSUP From SIXFONCTION

$LOOP_BAN
Raz NB

If STOP=1
 CRITERE = "CODBQE>LREPRISE"
 STOP=0
Else
 CRITERE="1=1"
Endif

Call DEBTRANS From GLOCK
Trbegin [BAN], [XBQE]

# Traitement des comptes généraux
For [XBQE] Where left$(CODBQE,2)<>"$$" and FLGREP<>2
&             & evalue(CRITERE)
&             & evalue(SI_CRITERE)
 
 GOK = 1
 Call AFFBOITE([F:XBQE]CODBQE) From SUBSIM

 # creation banque (BANK)
 Gosub CRE_BAN
 If GOK<=0 : Break :  Endif


 Readlock [XBQE] Curr
 [F:XBQE]FLGREP = 2
 Rewrite [XBQE]

 # NB alimenté dans CRE_BAN
 If NB>1000
  LREPRISE = [F:XPCG]CODBQE
  STOP     = 1
  Break
 Endif
Next

If GOK>0    
 If SI_SIMU<>2
  Commit
 Else
  Rollback
 Endif
 If STOP
  Goto LOOP_BAN
 Endif
Else
 Rollback
Endif
End

##################################################################
$CRE_BAN
Raz [F:BAN]

# recuperation et controle code compte
If !func SIXFONCTION.SI_CTL("BAN",[F:XBQE]X3CLE,"XIBQE ("+[F:XBQE]CODBQE+")")
 GOK=0 : Return
Else
 [F:BAN]BAN = [F:XBQE]X3CLE
Endif

[F:BAN]COA    = COAGEN

# Intitulé de compte
#-------------------------------------------------
[F:BAN]DES    = [F:XBQE]NOMBQE    # X3 Type de donnée DES (=30c) Intégrale A24
[F:BAN]DESSHO = [F:XBQE]NOMBQE2   # X3 Type de donnée SHO (=10c) Intégrale A24

# Adresses
#------------------------------------------------- 
[F:BAN]ADDLIG(0) =  [F:XBQE]ADR1      # Ligne adresse 1
[F:BAN]ADDLIG(1) =  [F:XBQE]ADR2      # Ligne adresse 2
[F:BAN]ADDLIG(2) =  [F:XBQE]ADR3      # Ligne adresse 3
[F:BAN]POSCOD    =  [F:XBQE]CODPST    # Code postal     
[F:BAN]CTY       =  [F:XBQE]VIL       # Ville           
Call NUMONLY([F:XBQE]TEL,[F:BAN]TEL) From SIXFONCTION    # Telephone

# Code pays 
If [F:XBQE]CODPAY <> ""
 [F:BAN]CRY = func SIXFONCTION.SI_COR("XIPAY",[F:XBQE]CODPAY,"TABCOUNTRY",mess(115,121,1)-[F:BAN]BAN-"("+[F:XBQE]CODBQE+")")
Endif  
# Nom pays
If [F:BAN]CRY <> "" 
 Call LECTEXTRA([F:BAN]CRYNAM,"TABCOUNTRY","CRYNAM",[F:BAN]CRY,"") From ATEXTRA
Endif

# RIB
#-------------------------------------------------
[F:BAN]BIDNUM  = [F:XBQE]RIBBQE        # RIB - Banque
[F:BAN]BIDNUM += [F:XBQE]RIBAGC        # RIB - Agence
[F:BAN]BIDNUM += [F:XBQE]RIBCPT        # RIB - Compte
[F:BAN]BIDNUM += [F:XBQE]RIBCLE        # RIB - Clé
[F:BAN]BICCOD  = [F:XBQE]CODBIC        # Code BIC

If [F:BAN]BIDNUM<>"" & [F:BAN]CRY<>""  # Code IBAN  
 Call CRE_IBAN([F:BAN]IBACOD,[F:BAN]CRY,"",[F:BAN]BIDNUM) From SUBBID
Endif

# lecture Pays pour controle RIB
If [F:BAN]CRY <> "" &  [F:TCY]CRY <> [F:BAN]CRY
 Read [TCY]TCY0 = [F:BAN]CRY
 If fstat
  Raz [F:TCY]
 Endif
Endif 

BANQUE = left$([F:BAN]CRY,[F:TCY]BANLNG)
Read [ABN]ABN0 = [F:BAN]BIDNUM;BANQUE
If fstat 
 If [F:TCY]BIDCTL=2
  # Comte de banque ... (...) Banque/guichet inexistants
  Call ECR_TRACE(mess(115,121,1)-[F:BAN]BAN-"("+[F:XBQE]CODBQE+")"-mess(173,133,1)-[F:TCY]CRY-BANQUE,1) From GESECRAN
  GOK = 0 : Return
 Endif
Else
 Raz [ABN]
Endif
# Rubriques reprises de la banque  X3
[F:BAN]PAB1  =  [F:ABN]PAB         # Domiciliation     

# Comptes
#------------------------------------------------- 
[F:BAN]BANCSH    = 1 
[F:BAN]NBRJOU    = 1 
[F:BAN]JOUTYP(0) = 1
[F:BAN]JOU(0)    = func SIXFONCTION.SI_COR("XIJRN",[F:XBQE]CODJRN,"GJOURNAL","")         # Journal de Banque
[F:BAN]BANACC    = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XBQE]NUMCPTCTB,"GACCOUNT","")
If dim([F:BAN]TREACC)>0 
 [F:BAN]TREACC(0) =  [F:BAN]BANACC
Endif



# Données initialiées par défaut
#-------------------------------------------------
[F:BAN]BANCSH = 1 
[F:BAN]CPY    = [F:SPX]CPY
Call INITACCCOD([F:BAN]ACCCOD,[F:BAN]CPY,13) From SITSIG

If [F:BAN]BANACC<>""
 Call LECTURE("GAC",[F:BAN]BANACC,[F:BAN]COA) From CONTOBJ
 If [F:GAC]CUR<>""
  [F:BAN]CUR = [F:GAC]CUR
 Else
  Call LECTURE("CPY",[F:CPY]CPY,"") From CONTOBJ
  [F:BAN]CUR = [F:CPY]ACCCUR
 Endif
Endif

[F:BAN]CHQTYPFLG = 2
[F:BAN]FRMDUDFLG = 2
[F:BAN]PABDUDFLG = 2 

# Dates et utilisateurs
#-------------------------------------------------
[F:BAN]CREDAT   = date$
[F:BAN]CREUSR   = GUSER              
[F:BAN]UPDDAT   = date$   
[F:BAN]UPDUSR   = GUSER   


SI_TABLE = "BANK"
Gosub SI_BEFWRI From SIXFONCTION

Write [BAN]
If fstat
 # Compte de Banque... : ... (...) Erreur d'écriture 
 Call ECR_TRACE(mess(115,121,1)-[F:BAN]BAN-"("+[F:XBQE]CODBQE+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0
Else
 NB+=1
Endif
Return


