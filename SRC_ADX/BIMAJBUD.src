#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","BIMAJBUD","BIMAJBUD",3,"") From GTRAITE
End
##########################################################################################

Call MAJBUD('[F:BUD]BUD="BG2" & [F:BUD]CPY="ADX"',1,0,[0/0/0],[31/12/2999])
#Call MAJBUD('',1,1,[01/01/2009],[31/12/2009])
Call LEC_TRACE From LECFIC
End
# '[F:BUD]BUD="CC1"'
##########################################################################################
$ACTION
Case ACTION
 When "INIT"
  TRA = 1
  TMP = 1
 When "EXEC"
  Call MAJBUD('',1,0,[M:DIA]DATDEB,[M:DIA]DATFIN)
Endcase
Return

##########################################################################################
# Mise à jour des budgets
##########################################################################################
Subprog MAJBUD(FILTRE,TRACE,TEST,DATDEB,DATFIN)
Value Char    FILTRE
Value Integer TRACE
Value Integer TEST
Value Date    DATDEB
Value Date    DATFIN

Gosub OUVRE
Local Integer MAXPER
MAXPER = dim([F:BLA]CDTLED)-1

Local Integer I , J , K , P
Local Integer OKBUD , AXE1 , AXE2 , AXE3 , AXE4 , AXE5 , AXE6 , AXE7 , AXE8 , AXE9 , BUDQTE , STAT
Local Integer TYPCOURS
Local Date    DATCOURS
Local Char    FILBAL(250) , FILCPT(250)(0..2) , FILBUD(250)
Local Integer IFIL
Local Char    COMPTE(GLONGAC) , SECTION1(GLONCCE) , SECTION2(GLONCCE) , SECTION3(GLONCCE)
Local Char    SECTION4(GLONCCE) , SECTION5(GLONCCE) , SECTION6(GLONCCE)
Local Char    SECTION7(GLONCCE) , SECTION8(GLONCCE) , SECTION9(GLONCCE)
Local Char    DEVBUD(GLONCUR) , DEVREF(GLONCUR) , VALPAR(30) , TITBUD(50) , LIBSIT(20)
Local Decimal DEBIT(1..MAXPER) , CREDIT(1..MAXPER) , ENGAGE(1..MAXPER) , PREENG(1..MAXPER)
Local Decimal QTYREA(1..MAXPER) , QTYENG(1..MAXPER) , QTYPRE(1..MAXPER)
Local Decimal DIVISE , AROBUD

# Declaration of Variables to Handle Loops Ruptures
Local Integer STOP, NB
Local Char CRITERE(250)(1..3)
Local Integer ICRIT
Local Char AKEY(30)(1..16)
Local Char SAVCPY(GLONCPY), SAVVER(GLONBUV+2)

# On exclut les budgets GDD (déjà OK)
# et les budgets non définitifs

FILBUD = '[F:BUP]GDDFLG<>2 & [F:BUV]CTL=2'
If DATDEB<>[0/0/0]
 FILBUD + ='& [F:FIY]FIYSTR>=DATDEB'
Endif
If DATFIN<>[0/0/0]
 FILBUD + ='& [F:FIY]FIYSTR<=DATFIN'
Endif
If FILTRE<>""
 FILBUD -= '&'-FILTRE
Endif

If !GSERVEUR & TRACE
 Call OUVRE_TRACE("BIMAJBUD") From LECFIC
Endif
Gosub MAJ_BUD
If !GSERVEUR & TRACE
 Call FERME_TRACE From LECFIC
Endif

Columns [CYK1]
Columns [CYK2]
Columns [CYK3]
Columns [CYK4]
Columns [CYK5]
Columns [CYK6]
Columns [CYK7]
Columns [CYK8]
Columns [CYK9]
End

########################################################
$OUVRE
If clalev([F:BUD])=0  : Local File BUD        [BUD]  : Endif
If clalev([F:BUP])=0  : Local File BUDPAR     [BUP]  : Endif
If clalev([F:BUV])=0  : Local File BUDVER     [BUV]  : Endif
If clalev([F:GYK])=0  : Local File GACCPYMLIK [GYK]  : Endif
If clalev([F:CYK1])=0 : Local File GCCEPYMLIK [CYK1] : Endif
If clalev([F:CYK2])=0 : Local File GCCEPYMLIK [CYK2] : Endif
If clalev([F:CYK3])=0 : Local File GCCEPYMLIK [CYK3] : Endif
If clalev([F:CYK4])=0 : Local File GCCEPYMLIK [CYK4] : Endif
If clalev([F:CYK5])=0 : Local File GCCEPYMLIK [CYK5] : Endif
If clalev([F:CYK6])=0 : Local File GCCEPYMLIK [CYK6] : Endif
If clalev([F:CYK7])=0 : Local File GCCEPYMLIK [CYK7] : Endif
If clalev([F:CYK8])=0 : Local File GCCEPYMLIK [CYK8] : Endif
If clalev([F:CYK9])=0 : Local File GCCEPYMLIK [CYK9] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif
If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
If clalev([F:BLA])=0  : Local File BALANA     [BLA]  : Endif
If clalev([F:BLM])=0  : Local File BLACMM     [BLM]  : Endif
If clalev([F:BLQ])=0  : Local File BLAQTY     [BLQ]  : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA    [AXX]  : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif

Columns [CYK1] (CCE)
Columns [CYK2] (CCE)
Columns [CYK3] (CCE)
Columns [CYK4] (CCE)
Columns [CYK5] (CCE)
Columns [CYK6] (CCE)
Columns [CYK7] (CCE)
Columns [CYK8] (CCE)
Columns [CYK9] (CCE)
Return

########################################################
$MAJ_BUD
# Variables to Handle Loops Ruptures
Raz STOP, CRITERE

Link [BUD] With [BUP]BUP0~=[F:BUD]BUD
&              ,[BUV]BUV0~=[F:BUD]BUD;[F:BUD]VER
&              ,[FIY]FIY0~=[F:BUD]CPY;[F:BUD]LEDTYP;[F:BUD]FIY
& As [LBUD]
& Where evalue(FILBUD)
& Order By Key CLE=[F:BUD]CPY;[F:BUD]LEDTYP;[F:BUD]BUD;[F:BUD]VER;[F:BUD]FIY;[F:BUD]FCY;[F:BUD]ACC;
&                  [F:BUD]CCE1;[F:BUD]CCE2;[F:BUD]CCE3;[F:BUD]CCE4;[F:BUD]CCE5;[F:BUD]CCE6;[F:BUD]CCE7;[F:BUD]CCE8;[F:BUD]CCE9

Call DEBTRANS From GLOCK
$LOOP
 Raz NB, ICRIT, CRITERE
 If STOP=1
  STOP = 2
  Call ADDCRIT(CRITERE,ICRIT,"CPY",'CPY="'+AKEY(1)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"LEDTYP",'LEDTYP='+AKEY(2)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"BUD",'BUD="'+AKEY(3)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"VER",'VER="'+AKEY(4)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FIY",'FIY='+AKEY(5)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FCY",'FCY="'+AKEY(6)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"ACC",'ACC="'+AKEY(7)+'"'," & ") From GOBJSUB
  For AX=1 To 8
   Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE"+num$(AX)+"='"+AKEY(AX+7)+"'"," & ") From GOBJSUB
  Next
  Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE9>'"+AKEY(16)+"'"," & ") From GOBJSUB
 Elsif STOP=2
  STOP = 3
  Call ADDCRIT(CRITERE,ICRIT,"CPY",'CPY="'+AKEY(1)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"LEDTYP",'LEDTYP='+AKEY(2)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"BUD",'BUD="'+AKEY(3)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"VER",'VER="'+AKEY(4)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FIY",'FIY='+AKEY(5)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FCY",'FCY="'+AKEY(6)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"ACC",'ACC="'+AKEY(7)+'"'," & ") From GOBJSUB
  For AX=1 To 7
   Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE"+num$(AX)+"='"+AKEY(AX+7)+"'"," & ") From GOBJSUB
  Next
  Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE8>'"+AKEY(15)+"'"," & ") From GOBJSUB
 Elsif STOP=3
  STOP = 4
  Call ADDCRIT(CRITERE,ICRIT,"CPY",'CPY="'+AKEY(1)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"LEDTYP",'LEDTYP='+AKEY(2)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"BUD",'BUD="'+AKEY(3)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"VER",'VER="'+AKEY(4)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FIY",'FIY='+AKEY(5)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FCY",'FCY="'+AKEY(6)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"ACC",'ACC="'+AKEY(7)+'"'," & ") From GOBJSUB
  For AX=1 To 6
   Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE"+num$(AX)+"='"+AKEY(AX+7)+"'"," & ") From GOBJSUB
  Next
  Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE7>'"+AKEY(14)+"'"," & ") From GOBJSUB
 Elsif STOP=4
  STOP = 5
  Call ADDCRIT(CRITERE,ICRIT,"CPY",'CPY="'+AKEY(1)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"LEDTYP",'LEDTYP='+AKEY(2)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"BUD",'BUD="'+AKEY(3)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"VER",'VER="'+AKEY(4)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FIY",'FIY='+AKEY(5)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FCY",'FCY="'+AKEY(6)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"ACC",'ACC="'+AKEY(7)+'"'," & ") From GOBJSUB
  For AX=1 To 5
   Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE"+num$(AX)+"='"+AKEY(AX+7)+"'"," & ") From GOBJSUB
  Next
  Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE6>'"+AKEY(13)+"'"," & ") From GOBJSUB
 Elsif STOP=5
  STOP = 6
  Call ADDCRIT(CRITERE,ICRIT,"CPY",'CPY="'+AKEY(1)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"LEDTYP",'LEDTYP='+AKEY(2)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"BUD",'BUD="'+AKEY(3)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"VER",'VER="'+AKEY(4)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FIY",'FIY='+AKEY(5)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FCY",'FCY="'+AKEY(6)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"ACC",'ACC="'+AKEY(7)+'"'," & ") From GOBJSUB
  For AX=1 To 4
   Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE"+num$(AX)+"='"+AKEY(AX+7)+"'"," & ") From GOBJSUB
  Next
  Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE5>'"+AKEY(12)+"'"," & ") From GOBJSUB
 Elsif STOP=6
  STOP = 7
  Call ADDCRIT(CRITERE,ICRIT,"CPY",'CPY="'+AKEY(1)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"LEDTYP",'LEDTYP='+AKEY(2)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"BUD",'BUD="'+AKEY(3)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"VER",'VER="'+AKEY(4)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FIY",'FIY='+AKEY(5)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FCY",'FCY="'+AKEY(6)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"ACC",'ACC="'+AKEY(7)+'"'," & ") From GOBJSUB
  For AX=1 To 3
   Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE"+num$(AX)+"='"+AKEY(AX+7)+"'"," & ") From GOBJSUB
  Next
  Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE4>'"+AKEY(11)+"'"," & ") From GOBJSUB
 Elsif STOP=7
  STOP = 8
  Call ADDCRIT(CRITERE,ICRIT,"CPY",'CPY="'+AKEY(1)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"LEDTYP",'LEDTYP='+AKEY(2)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"BUD",'BUD="'+AKEY(3)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"VER",'VER="'+AKEY(4)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FIY",'FIY='+AKEY(5)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FCY",'FCY="'+AKEY(6)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"ACC",'ACC="'+AKEY(7)+'"'," & ") From GOBJSUB
  For AX=1 To 3
   Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE"+num$(AX)+"='"+AKEY(AX+7)+"'"," & ") From GOBJSUB
  Next
  Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE4>'"+AKEY(10)+"'"," & ") From GOBJSUB
 Elsif STOP=8
  STOP = 9
  Call ADDCRIT(CRITERE,ICRIT,"CPY",'CPY="'+AKEY(1)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"LEDTYP",'LEDTYP='+AKEY(2)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"BUD",'BUD="'+AKEY(3)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"VER",'VER="'+AKEY(4)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FIY",'FIY='+AKEY(5)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FCY",'FCY="'+AKEY(6)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"ACC",'ACC="'+AKEY(7)+'"'," & ") From GOBJSUB
  For AX=1 To 3
   Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE"+num$(AX)+"='"+AKEY(AX+7)+"'"," & ") From GOBJSUB
  Next
  Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE4>'"+AKEY(9)+"'"," & ") From GOBJSUB
 Elsif STOP=9
  STOP = 10
  Call ADDCRIT(CRITERE,ICRIT,"CPY",'CPY="'+AKEY(1)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"LEDTYP",'LEDTYP='+AKEY(2)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"BUD",'BUD="'+AKEY(3)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"VER",'VER="'+AKEY(4)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FIY",'FIY='+AKEY(5)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FCY",'FCY="'+AKEY(6)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"ACC",'ACC="'+AKEY(7)+'"'," & ") From GOBJSUB
  For AX=1 To 2
   Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE"+num$(AX)+"='"+AKEY(AX+7)+"'"," & ") From GOBJSUB
  Next
  Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE3>'"+AKEY(8)+"'"," & ") From GOBJSUB
 Elsif STOP=10
  STOP = 11
  Call ADDCRIT(CRITERE,ICRIT,"CPY",'CPY="'+AKEY(1)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"LEDTYP",'LEDTYP='+AKEY(2)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"BUD",'BUD="'+AKEY(3)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"VER",'VER="'+AKEY(4)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FIY",'FIY='+AKEY(5)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FCY",'FCY="'+AKEY(6)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"ACC",'ACC="'+AKEY(7)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE1='"+AKEY(8)+"'"," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE2>'"+AKEY(9)+"'"," & ") From GOBJSUB
 Elsif STOP=11
  STOP = 12
  Call ADDCRIT(CRITERE,ICRIT,"CPY",'CPY="'+AKEY(1)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"LEDTYP",'LEDTYP='+AKEY(2)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"BUD",'BUD="'+AKEY(3)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"VER",'VER="'+AKEY(4)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FIY",'FIY='+AKEY(5)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FCY",'FCY="'+AKEY(6)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"ACC",'ACC="'+AKEY(7)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"CCE","CCE1>'"+AKEY(8)+"'"," & ") From GOBJSUB
 Elsif STOP=12
  STOP = 13
  Call ADDCRIT(CRITERE,ICRIT,"CPY",'CPY="'+AKEY(1)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"LEDTYP",'LEDTYP='+AKEY(2)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"BUD",'BUD="'+AKEY(3)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"VER",'VER="'+AKEY(4)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FIY",'FIY='+AKEY(5)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FCY",'FCY="'+AKEY(6)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"ACC",'ACC>"'+AKEY(7)+'"'," & ") From GOBJSUB
Elsif STOP=13
  STOP = 14
  Call ADDCRIT(CRITERE,ICRIT,"CPY",'CPY="'+AKEY(1)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"LEDTYP",'LEDTYP='+AKEY(2)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"BUD",'BUD="'+AKEY(3)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"VER",'VER="'+AKEY(4)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FIY",'FIY='+AKEY(5)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FCY",'FCY>"'+AKEY(6)+'"'," & ") From GOBJSUB
Elsif STOP=14
  STOP = 15
  Call ADDCRIT(CRITERE,ICRIT,"CPY",'CPY="'+AKEY(1)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"LEDTYP",'LEDTYP='+AKEY(2)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"BUD",'BUD="'+AKEY(3)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"VER",'VER="'+AKEY(4)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"FIY",'FIY>'+AKEY(5)," & ") From GOBJSUB
Elsif STOP=15
  STOP = 16
  Call ADDCRIT(CRITERE,ICRIT,"CPY",'CPY="'+AKEY(1)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"LEDTYP",'LEDTYP='+AKEY(2)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"BUD",'BUD="'+AKEY(3)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"VER",'VER>"'+AKEY(4)+'"'," & ") From GOBJSUB
Elsif STOP=16
  STOP = 17
  Call ADDCRIT(CRITERE,ICRIT,"CPY",'CPY="'+AKEY(1)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"LEDTYP",'LEDTYP='+AKEY(2)," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"BUD",'BUD>"'+AKEY(3)+'"'," & ") From GOBJSUB
Elsif STOP=17
  STOP = 18
  Call ADDCRIT(CRITERE,ICRIT,"CPY",'CPY="'+AKEY(1)+'"'," & ") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRIT,"LEDTYP",'LEDTYP>'+AKEY(2)," & ") From GOBJSUB
Elsif STOP=18
  STOP = 0
  Call ADDCRIT(CRITERE,ICRIT,"CPY",'CPY>"'+AKEY(1)+'"'," & ") From GOBJSUB
Else
  CRITERE = '1=1'
Endif

Trbegin [BUD]
GOK = 1
Gosub TR1
If GOK<1 : Goto AB_TR1 : Endif
Return

$TR1
GOK = 1
Gosub BUDGET
Return

$AB_TR1
Rollback
Return

# Parcours des budgets
$BUDGET
Filter [LBUD] Where evalue(FILBUD) & evalue(CRITERE)
For [LBUD]CLE(1)     : # Société
 Call LEC_CPY([F:BUD]CPY) From CPTLEC
 Call LEC_GCM([F:CPY]ACM) From CPTLEC
 Call PARAML([F:BUD]CPY,"BUDTYPCUR",VALPAR) From ADOVAL
 DEVREF = [F:GCM]CUR([F:BUD]LEDTYP-1)
 TYPCOURS = max(1,val(VALPAR))
 DATCOURS = date$
 If TRACE & SAVCPY<>[F:BUD]CPY
  Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Call ECR_TRACE(mess(2,45,1)-":"-[F:CPY]CPY-[F:CPY]CPYNAM,0) From GESECRAN
  Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  SAVCPY=[F:BUD]CPY
 Endif
 For [LBUD]CLE(2)     : # Référentiel
  Call LEC_LED([F:GCM]LED([F:BUD]LEDTYP-1)) From CPTLEC
  For [LBUD]CLE(3)    : # Code budget
   Gosub SETBUD
   If OKBUD
    For [LBUD]CLE(5)  : # Version-Exercice
     If TRACE & SAVVER<>[F:BUD]VER+num$([F:BUD]FIY)
      Call ECR_TRACE(mess(47,103,1)-[F:BUP]BUD-TITBUD-":"-mess(126,105,1)-[F:BUD]VER-":"
&      -format$("D:"+GFMDAT4,[F:FIY]FIYSTR)-"-"-format$("D:"+GFMDAT4,[F:FIY]FIYEND),0) From GESECRAN
      SAVVER=[F:BUD]VER+num$([F:BUD]FIY)
     Endif
     For [LBUD]CLE     : # Détail
      Gosub COMPTE
      If GOK<1 : Break 5 : Endif
     Next
     If TRACE
      Call ECR_TRACE("",0) From GESECRAN
     Endif
    Next
   Endif
  Next
 Next
Next

If GOK<1
 Rollback
Else
 Commit
 If STOP
  Goto LOOP
 Endif
Endif
Return

$SETBUD
OKBUD = 1
AXE1  = 0
AXE2  = 0
AXE3  = 0
AXE4  = 0
AXE5  = 0
AXE6  = 0
AXE7  = 0
AXE8  = 0
AXE9  = 0
If [F:BUP]COA<>[F:LED]COA
 OKBUD = 0 : Return
Endif
For K=1 To [F:BUP]DIENBR
 INDLED = find([F:BUP]DIE(K-1),[F:LED]DIE(0..[F:LED]DIENBR-1))
 If INDLED
  Assign "AXE"+num$(K) With INDLED
 Else
  OKBUD = 0 : Break
 Endif
Next
DEVBUD = [F:BUD]CUR
Call LEC_TCU(DEVBUD) From CPTLEC
AROBUD = [F:TCU]CURRND
DIVISE = [F:BUP]DIVAMT
If DIVISE=0 : DIVISE = 1 : Endif
Call LECTEXTRA(TITBUD,"BUDPAR","DESTRA",[F:BUP]BUD,"") From ATEXTRA
BUDQTE = ([F:BUP]QTY=2)
Return

##########################################
# Traitement d'une ligne de budget
##########################################
$COMPTE

# Filtre sur la balance
FILBAL  = 'LEDTYP='+num$([F:BUD]LEDTYP)
FILBAL -= '& CPY="'+[F:BUD]CPY+'"'
If [F:BUP]LEV=2
 FILBAL -= '& FCY="'+[F:BUD]FCY+'"'
Else
 FILBAL -= '& FCY=""'
Endif
FILBAL -= '& FIY='+num$([F:BUD]FIY)
FILBAL -= '& BPR=""'

# Raz cumuls
Raz DEBIT , CREDIT , ENGAGE , PREENG , QTYREA , QTYENG , QTYPRE

# Parcours des sections
If [F:BUP]PYMACC<>""
 For [GYK] Where PYM=[F:BUP]PYMACC & LEV=[F:BUP]PYMACCLEV & GRU=[F:BUD]ACC
  COMPTE = [F:GYK]ACC
  Gosub SEC1
 Next
Else
 COMPTE = [F:BUD]ACC
 Gosub SEC1
Endif

# Conversion
If DEVBUD<>DEVREF
 For P=1 To MAXPER
  If DEBIT(P)<>0  : Call CONVERT(DEVREF,DEVBUD,DEVREF,TYPCOURS,DATCOURS,DEBIT(P) ,DEBIT(P) ,STAT) From TRTDEV : Endif
  If CREDIT(P)<>0 : Call CONVERT(DEVREF,DEVBUD,DEVREF,TYPCOURS,DATCOURS,CREDIT(P),CREDIT(P),STAT) From TRTDEV : Endif
  If ENGAGE(P)<>0 : Call CONVERT(DEVREF,DEVBUD,DEVREF,TYPCOURS,DATCOURS,ENGAGE(P),ENGAGE(P),STAT) From TRTDEV : Endif
  If PREENG(P)<>0 : Call CONVERT(DEVREF,DEVBUD,DEVREF,TYPCOURS,DATCOURS,PREENG(P),PREENG(P),STAT) From TRTDEV : Endif
 Next P
Endif

# MAJ ligne de budget
For P=1 To MAXPER
 [F:BUD]AMTREA(P-1)    = arr((DEBIT(P)-CREDIT(P))/DIVISE,AROBUD)
 [F:BUD]AMTCMM(P-1)    = arr(ENGAGE(P)/DIVISE,AROBUD)
 [F:BUD]AMTCMMPRP(P-1) = arr(PREENG(P)/DIVISE,AROBUD)
 If BUDQTE
  [F:BUD]QTYREA(P-1)    = QTYREA(P)
  [F:BUD]QTYCMM(P-1)    = QTYENG(P)
  [F:BUD]QTYCMMPRP(P-1) = QTYPRE(P)
 Endif
Next P
If !TEST
 Rewrite [BUD]
 If fstat
  GOK = 0 : Call FSTA("BUD") From GLOCK : Return
 Endif
Endif
If TRACE
 If [F:BUD]FCY<>""
  LIBSIT = "("+[F:BUD]FCY+")"
 Else
  LIBIST = ""
 Endif
 Call ECR_TRACE([F:BUD]ACC-[F:BUD]CCE1-[F:BUD]CCE2-[F:BUD]CCE3-[F:BUD]CCE4-[F:BUD]CCE5
&              -[F:BUD]CCE6-[F:BUD]CCE7-[F:BUD]CCE8-[F:BUD]CCE9-LIBSIT-":"
&              -num$(sum([F:BUD]AMTREA))-num$(sum([F:BUD]AMTCMM))-num$(sum([F:BUD]AMTCMMPRP)),0) From GESECRAN
Endif

NB+=1
If NB>GMAXUPDTRS
 #CPY;LEDTYP;BUD;VER;FIY;FCY;ACC;CCE1;CCE2;CCE3;CCE4;CCE5;CCE6;CCE7;CCE8;CCE9
 AKEY(1)  = [F:BUD]CPY
 AKEY(2)  = num$([F:BUD]LEDTYP)
 AKEY(3)  = [F:BUD]BUD
 AKEY(4)  = [F:BUD]VER
 AKEY(5)  = num$([F:BUD]FIY)
 AKEY(6)  = [F:BUD]FCY
 AKEY(7)  = [F:BUD]ACC
 AKEY(8)  = [F:BUD]CCE1
 AKEY(9)  = [F:BUD]CCE2
 AKEY(10) = [F:BUD]CCE3
 AKEY(11) = [F:BUD]CCE4
 AKEY(12) = [F:BUD]CCE5
 AKEY(13) = [F:BUD]CCE6
 AKEY(14) = [F:BUD]CCE7
 AKEY(15) = [F:BUD]CCE8
 AKEY(16) = [F:BUD]CCE9
 STOP=1
 Return
Endif
Return

###################################################
# Parcours des sections
###################################################
$SEC1
If [F:BUP]PYMCCE(0)<>""
 For [CYK1] Where PYM=[F:BUP]PYMCCE(0) & LEV=[F:BUP]PYMCCELEV(0) & GRU=evalue("[F:BUD]CCE"+num$(AXE1))
  SECTION1 = [F:CYK1]CCE
  Gosub SEC2
 Next
Else
 If AXE1 : SECTION1 = evalue("[F:BUD]CCE"+num$(AXE1)) : Else Raz SECTION1 : Endif
 Gosub SEC2
Endif
Return

$SEC2
If [F:BUP]PYMCCE(1)<>""
 For [CYK2] Where PYM=[F:BUP]PYMCCE(1) & LEV=[F:BUP]PYMCCELEV(1) & GRU=evalue("[F:BUD]CCE"+num$(AXE2))
  SECTION2 = [F:CYK2]CCE
  Gosub SEC3
 Next
Else
 If AXE2 : SECTION2 = evalue("[F:BUD]CCE"+num$(AXE2)) : Else Raz SECTION2 : Endif
 Gosub SEC3
Endif
Return

$SEC3
If [F:BUP]PYMCCE(2)<>""
 For [CYK3] Where PYM=[F:BUP]PYMCCE(2) & LEV=[F:BUP]PYMCCELEV(2) & GRU=evalue("[F:BUD]CCE"+num$(AXE3))
  SECTION3 = [F:CYK3]CCE
  Gosub SEC4
 Next
Else
 If AXE3 : SECTION3 = evalue("[F:BUD]CCE"+num$(AXE3)) Else Raz SECTION3 : Endif
 Gosub SEC4
Endif
Return

$SEC4
If [F:BUP]PYMCCE(3)<>""
 For [CYK4] Where PYM=[F:BUP]PYMCCE(3) & LEV=[F:BUP]PYMCCELEV(3) & GRU=evalue("[F:BUD]CCE"+num$(AXE4))
  SECTION4 = [F:CYK4]CCE
  Gosub SEC5
 Next
Else
 If AXE4 : SECTION4 = evalue("[F:BUD]CCE"+num$(AXE4)) : Else Raz SECTION4 : Endif
 Gosub SEC5
Endif
Return

$SEC5
If [F:BUP]PYMCCE(4)<>""
 For [CYK5] Where PYM=[F:BUP]PYMCCE(4) & LEV=[F:BUP]PYMCCELEV(4) & GRU=evalue("[F:BUD]CCE"+num$(AXE5))
  SECTION5 = [F:CYK5]CCE
  Gosub SEC6
 Next
Else
 If AXE5 : SECTION5 = evalue("[F:BUD]CCE"+num$(AXE5)) Else Raz SECTION5 : Endif
 Gosub SEC6
Endif
Return

$SEC6
If [F:BUP]PYMCCE(5)<>""
 For [CYK6] Where PYM=[F:BUP]PYMCCE(5) & LEV=[F:BUP]PYMCCELEV(5) & GRU=evalue("[F:BUD]CCE"+num$(AXE6))
  SECTION6 = [F:CYK6]CCE
 Next
Else
 If AXE6 : SECTION6 = evalue("[F:BUD]CCE"+num$(AXE6)) Else Raz SECTION6 : Endif
 Gosub SEC7
Endif
Return

$SEC7
If [F:BUP]PYMCCE(6)<>""
 For [CYK7] Where PYM=[F:BUP]PYMCCE(6) & LEV=[F:BUP]PYMCCELEV(6) & GRU=evalue("[F:BUD]CCE"+num$(AXE7))
  SECTION7 = [F:CYK7]CCE
  Gosub SEC8
 Next
Else
 If AXE7 : SECTION7 = evalue("[F:BUD]CCE"+num$(AXE7)) Else Raz SECTION7 : Endif
 Gosub SEC8
Endif
Return

$SEC8
If [F:BUP]PYMCCE(7)<>""
 For [CYK8] Where PYM=[F:BUP]PYMCCE(7) & LEV=[F:BUP]PYMCCELEV(7) & GRU=evalue("[F:BUD]CCE"+num$(AXE8))
  SECTION8 = [F:CYK8]CCE
  Gosub SEC9
 Next
Else
 If AXE8 : SECTION8 = evalue("[F:BUD]CCE"+num$(AXE8)) Else Raz SECTION8 : Endif
 Gosub SEC9
Endif
Return

$SEC9
If [F:BUP]PYMCCE(8)<>""
 For [CYK9] Where PYM=[F:BUP]PYMCCE(8) & LEV=[F:BUP]PYMCCELEV(8) & GRU=evalue("[F:BUD]CCE"+num$(AXE9))
  SECTION9 = [F:CYK9]CCE
  Gosub BALANCE
 Next
Else
 If AXE9 : SECTION9 = evalue("[F:BUD]CCE"+num$(AXE9)) Else Raz SECTION9 : Endif
 Gosub BALANCE
Endif
Return

###################################################
# Calcul des montants
###################################################
$BALANCE
Raz FILCPT, IFIL
Call ADDCRIT(FILCPT,IFIL,"ACC",'ACC="'+COMPTE+'"'," & ") From GOBJSUB
If AXE1 : Call ADDCRIT(FILCPT,IFIL,"CCE",'CCE'+num$(AXE1)+'="'+SECTION1+'"'," & ") From GOBJSUB : Endif
If AXE2 : Call ADDCRIT(FILCPT,IFIL,"CCE",'CCE'+num$(AXE2)+'="'+SECTION2+'"'," & ") From GOBJSUB : Endif
If AXE3 : Call ADDCRIT(FILCPT,IFIL,"CCE",'CCE'+num$(AXE3)+'="'+SECTION3+'"'," & ") From GOBJSUB : Endif
If AXE4 : Call ADDCRIT(FILCPT,IFIL,"CCE",'CCE'+num$(AXE4)+'="'+SECTION4+'"'," & ") From GOBJSUB : Endif
If AXE5 : Call ADDCRIT(FILCPT,IFIL,"CCE",'CCE'+num$(AXE5)+'="'+SECTION5+'"'," & ") From GOBJSUB : Endif
If AXE6 : Call ADDCRIT(FILCPT,IFIL,"CCE",'CCE'+num$(AXE6)+'="'+SECTION6+'"'," & ") From GOBJSUB : Endif
If AXE7 : Call ADDCRIT(FILCPT,IFIL,"CCE",'CCE'+num$(AXE7)+'="'+SECTION7+'"'," & ") From GOBJSUB : Endif
If AXE8 : Call ADDCRIT(FILCPT,IFIL,"CCE",'CCE'+num$(AXE8)+'="'+SECTION8+'"'," & ") From GOBJSUB : Endif
If AXE9 : Call ADDCRIT(FILCPT,IFIL,"CCE",'CCE'+num$(AXE9)+'="'+SECTION9+'"'," & ") From GOBJSUB : Endif

# Balance
For [BLA] Where evalue(FILBAL) & evalue(FILCPT)
 For P=1 To MAXPER
  DEBIT(P)  += [F:BLA]DEBLED(P)
  CREDIT(P) += [F:BLA]CDTLED(P)
 Next P
Next

# Engagements
For [BLM] Where evalue(FILBAL) & evalue(FILCPT)
 For P=1 To MAXPER
  ENGAGE(P) += [F:BLM]CMMLED(P)
  PREENG(P) += [F:BLM]CMMPRPLED(P)
 Next P
Next

# Quantité
If BUDQTE
 For [BLQ] Where evalue(FILBAL) & evalue(FILCPT)
  For P=1 To MAXPER
   QTYREA(P) += [F:BLQ]QTY(P)
   QTYENG(P) += [F:BLQ]QTYCMM(P)
   QTYPRE(P) += [F:BLQ]QTYPRP(P)
  Next P
 Next
Endif
Return

