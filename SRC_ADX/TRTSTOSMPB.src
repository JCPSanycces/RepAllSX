#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################
# LOAD_FROM_SGW : Charge l'écran STOSMP [SMP]            à partir de STOCHGW [SGW]#
#                 Calcul qté refuséee saisie de la ligne à partir de STOCHGW [SGW]#
###################################################################################
$LOAD_FROM_SGW
Local Char WLOT(GLONLOT)
[M:SMP]WSTOSEQ = [M:STQ1]WSTOSEQ(LLIGDOC)
For I=0 To [M:SMP]NBLIG-1
    If [M:SMP]WSTJFLG (I) = 0
       Call RECSGW_SMP        ((I),[M:SMP]WSTOSEQ,[M:SMP]WSTOCOU(I),"") From TRTSTOSMPB
       Call CAL_QTYSMPREFLIG  ((I),[M:SMP]WSTOSEQ,[M:SMP]WSTOCOU(I),"") From TRTSTOSMPB
       If [M:SMP]MODFLG(I) = 2
          If dim([M:SMP]LPNNUMDES) >0 & [M:SMP]LPNNUMDES(I) <> ""                             # hcb X3-77043
             Diszo [M:SMP]LPNNUMDES (I)                                                       # hcb X3-77043
          Endif                                                                               # hcb X3-77043
          If dim([M:SMP]LOCTYPDES) >0 & [M:SMP]LOCTYPDES(I) <> ""
             Diszo [M:SMP]LOCTYPDES (I)
             Diszo [M:SMP]LOCDES    (I)
             If dim([M:SMP]WRHDES) > 0
                Diszo [M:SMP]WRHDES (I)
             Endif
          Endif
       Endif
       # Transfert zones de l'écran STOCHGW vers l'écran STOSMP
       GPOINT="SGW_SMP" : Gosub ENTREE From EXEFNC
    Endif
Next

Return


####################################################################################
# CTR_SGW : Controle STOCHGW [SGW]                                                 #
#  si l echantillon est en Statut "R" il ne doit pas avoir de statut autres que "R"#
####################################################################################
$CTR_SGW
Local Integer I
Local Integer Y

# hcb 67176 : test réécrit
I = find([M:SMP]WSTOSEQ, [M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))
#
If I>0
    I-=1
    While I<[M:SGW]NBLIG & [M:SMP]WSTOSEQ=[M:SGW]WSTOSEQ(I)
          If left$([M:SGW]WSTADES (I),1) <> "R"
             LERR = 1
             Break
          Endif
          I+=1
    Wend
Endif
#

Return
########################################################################
# RECSTJ_SMP_SMP
# Cherche pour une ligne de document donné si dans le détail de cette ligne:
#    - Le statut qualité est unique ou multiple
#    - Le type d'emplacement est unique ou multiple
#    - L'emplacement est unique ou multiple
#    - Désignation du mouvement unique.
# Cette fonction permet de faire apparaître un $ pour montrer la décomposition du champ
########################################################################
# Paramètres E : FCY  = Site
#              : VCR  = Numéro document
#              : TYP  = Type de document
#              : NOL  = Indice de ligne dans le tableau du document (nolign-1)
#              : LSUP = Inutilisé (paramètre supplémentaire au cas où)
#
# Prérequis : Fichier STOJOU [STJ] ouvert
#             Fichier ITMMASTER [ITM] ouvert et positionné
#             Fichier ITMFACILIT [ITF] ouvert et positionné
########################################################################
Subprog RECSTJ_SMP_SMP (ITM,FCY,TYP,VCR,LIN,NOL,LSUP)
Value Char    ITM
Value Char    FCY
Value Integer TYP
Value Char    VCR
Value Integer LIN
Value Integer NOL
Value Char    LSUP

Local Char    PSTA   (GLONSTA)
Local Char    PLOCTYP(GLONTLO)
Local Char    PLOC   (GLONEMP)
Local Char    PWRH   (GLONWRH)
Local Char    PSER   (GLONSER)
Local Char    PLPN   (GLONLPN)                                                                # hcb X3-77043

Local Char LSER(GLONSER),LSERF(GLONSER)
Local Integer I
Local Integer LRET

Local Shortint CLOC    # 1=vérifie la décomposition en plusieurs emplacements
Local Shortint CSER    # 1=vérifie la décomposition en n° série discontinus
Local Shortint CLPN    # 1=vérifie la décomposition en plusieurs n° contenant                 # hcb X3-77043

Local Char CAR(1) : CAR = "$"
Local Char CRITERE(50)

Raz I
Raz PSTA
Raz PLOC
Raz PLOCTYP
Raz PSER
Raz PWRH
Raz PLPN              # hcb X3-77043


If !clalev([F:STJ]) : Local File STOJOU     [STJ] : Endif
If !clalev([F:STC]) : Local File STOLOC     [STC] : Endif

If !clalev([F:ITF])
    Local File ITMFACILIT [ITF]
    Read [ITF]ITF0=ITM;FCY
Elsif [F:ITF]ITMREF<>ITM |  [F:ITF]STOFCY<>FCY
    Read [ITF]ITF0=ITM;FCY
Endif

CLOC = dim([M:SMP]LOC)>0    & [F:ITF]LOCMGTCOD = 2
CLPN = dim([M:SMP]LPNNUM)>0 & [F:ITF]LPNMGTCOD = 2                                            # hcb X3-77043
If dim([M:SMP]SERNUM)>0
    CSER = dim([M:SMP]SERNUM)>0 & LSER<>""
Endif
################################
# Recherche pour STA, LOC
CRITERE  = "1=1"
If [F:ITF]SMPMOD = 2
   CRITERE = "LOT = LLOT"
Endif

Filter [STJ] Where STOFCY = FCY
&                & ITMREF = ITM
&                & VCRTYP = TYP
&                & VCRNUM = VCR
&                & VCRLIN = LIN
&                & REGFLG = 1
&                & QTYSTU > 0
&                & left$(STA,1) <> "Q"
For [STJ] Hint Key STJ1
    I+=1
    If left$([F:STJ]STA,1) = "R"
       [M:SMP]QTYSMPREFLIG(NOL) + = [F:STJ]QTYSTU
    Endif
    [M:SMP]WSTJFLG(NOL) = 1
    # Au 1er tour on initialise les variables qui permettront les comparaisons
    If I=1
        PSTA = [F:STJ]STA
        If CLPN=1                                                                             # hcb X3-77043
           PLPN = [F:STJ]LPNNUM                                                               # hcb X3-77043
        Endif                                                                                 # hcb X3-77043
        If CLOC=1
            PLOC = [F:STJ]LOC
            PWRH = [F:STJ]WRH
            Read [STC]STC0=FCY;PLOC
            If !fstat
                PLOCTYP = [F:STC]LOCTYP
            Endif
        Endif
        If CSER=1
            [M:SMP]SERNUM(NOL) = [F:STJ]SERNUM
            PSER = [F:STJ]SERNUM
        Endif

    ###########
    # Aux tours suivants on regarde les différences
    Else
        If [F:STJ]STA <> PSTA
            PSTA = CAR
        Endif
#                                                                                             # hcb X3-77043 deb
        If CLPN
            If [F:STJ]LPNNUM <> PLPN
                PLPN = CAR
            Endif
        Endif
#                                                                                             # hcb X3-77043 fin
        If CLOC
            If [F:STJ]LOC <> PLOC
                PLOC = CAR
                Read [STC]STC0=FCY;[F:STJ]LOC
                If !fstat
                    If [F:STC]LOCTYP <> PLOCTYP
                        PLOCTYP = CAR
                    Endif
                Endif
            Endif
            If [F:STJ]WRH <> PWRH
                PWRH = CAR
            Endif
        Endif
        If CSER & PSER<>CAR
            Call PLUS_UN(PSER,PSER,LRET) From STKLIB
            If PSER<>[F:STJ]SERNUM
                PSER = CAR
            Endif
        Endif
    Endif
Next

Filter [STJ]

[M:SMP]STADES(NOL) =  PSTA
If CLPN=1 & evalue("dim([M:SMP]LPNNUMDES)")>0                                                 # hcb X3-77043
   [M:SMP]LPNNUMDES(NOL) = PLPN                                                               # hcb X3-77043
Endif                                                                                         # hcb X3-77043
If CLOC=1 & evalue("dim([M:SMP]LOCTYPDES)")>0
   [M:SMP]LOCTYPDES(NOL) = PLOCTYP
   [M:SMP]LOCDES   (NOL) = PLOC
   If dim([M:SMP]WRHDES) > 0
      [M:SMP]WRHDES   (NOL) = PWRH
   Endif
Endif


End


########################################################################
# RECSGW_STQ met à jour l ecran STOQUA à partir STOCHGW
#                appel depui TRTSTOSMP  ecran STOSMP
# Cherche pour une ligne de document donné si dans le détail de cette ligne:
#    - Le statut qualité est unique ou multiple
#    - Le type d'emplacement est unique ou multiple
#    - L'emplacement est unique ou multiple
#    - Désignation du mouvement unique.
# Cette fonction permet de faire apparaître un $ pour montrer la décomposition du champ
########################################################################
# Paramètres E : ABR  = Ecran "XYZ"
#              : FCY  = Site
#              : VCR  = Numéro document
#              : TYP  = Type de document
#              : NOL  = Indice de ligne dans le tableau du document (nolign-1)
#              : LSUP = Inutilisé (paramètre supplémentaire au cas où)
#
# Prérequis : Fichier ITMFACILIT [ITF] ouvert et positionné
########################################################################
Subprog RECSGW_STQ (ITM,FCY,NOL,PSEQ,LSUP)
Value Char    ITM
Value Char    FCY
Value Integer NOL
Value Integer PSEQ
Value Char    LSUP

Local Char    PSTA    (GLONSTA)
Local Char    PLOCTYP (GLONTLO)
Local Char    PLOC    (GLONEMP)
Local Char    PWRH    (GLONWRH)
Local Char    PLPN    (GLONLPN)                                                               # hcb X3-77043

Local Integer I, J
Local Integer LRET
Local Integer LNBSTJ
Local Integer LNBDET, LNBEG

Local Shortint CLOC    # 1=vérifie la décomposition en plusieurs emplacements
Local Shortint CLPN    # 1=vérifie la décomposition en plusieurs n°contenant                  # hcb X3-77043

Local Char CAR(1) : CAR = "$"

Raz I,J
Raz PSTA
Raz PLOC
Raz PWRH
Raz PLOCTYP
Raz PLPN                                                                                      # hcb X3-77043
If [F:ITF]ITMREF<>ITM | [F:ITF]STOFCY<>FCY
    Read [ITF]ITF0=ITM;FCY
Endif

I = find(PSEQ,[M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))
If I>0
    I-=1
    PSTA    = [M:SGW]WSTADES    (I)
    PLOCTYP = [M:SGW]WLOCTYPDES (I)
    PLOC    = [M:SGW]WLOCDES    (I)
    PWRH    = [M:SGW]WWRHDES    (I)
    PLPN    = [M:SGW]WLPNNUMDES (I)                                                           # hcb X3-77043

    LNBDET = sigma(I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ))
    LNBEG  = sigma(I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WSTADES(indcum)=PSTA) )
    If LNBEG<>LNBDET
       PSTA = CAR
    Endif
#                                                                                             # hcb X3-77043 deb
    If PLPN<>""
        LNBEG  = sigma(I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WLPNNUMDES(indcum)=PLPN) )
        If LNBEG<>LNBDET
           PLPN = CAR
        Endif
    Endif
#                                                                                             # hcb X3-77043 fin
    If PLOCTYP<>""
        LNBEG  = sigma(I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WLOCTYPDES(indcum)=PLOCTYP) )
        If LNBEG<>LNBDET
           PLOCTYP = CAR
        Endif
        LNBEG  = sigma(I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WLOCDES(indcum)=PLOC) )
        If LNBEG<>LNBDET
           PLOC = CAR
        Endif
        LNBEG  = sigma(I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WWRHDES(indcum)=PWRH) )
        If LNBEG<>LNBDET
           PWRH = CAR
        Endif
    Endif
Endif
CLOC = dim([M:STQ1]LOC)>0 & [F:ITF]LOCMGTCOD = 2
CLPN = dim([M:STQ1]LPNNUM)>0 & [F:ITF]LPNMGTCOD = 2                                           # hcb X3-77043
[M:STQ1]PCUDES             (NOL) = [M:STQ1]PCU        (NOL)
[M:STQ1]QTYPCUDES          (NOL) = [M:STQ1]QTYPCU     (NOL)
[M:STQ1]COEDES             (NOL) = [M:STQ1]PCUSTUCOE  (NOL)
[M:STQ1]QTYSTUDES          (NOL) = [M:STQ1]QTYSTU     (NOL)
If dim([M:STQ1]SERNUM)>0
   [M:STQ1]SERNUM          (NOL) = [M:STQ1]SERNUMDEP  (NOL)
   [M:STQ1]SERNUMF         (NOL) = [M:STQ1]SERNUMFDEP (NOL)
   Affzo [M:STQ1]SERNUM    (NOL)
   Affzo [M:STQ1]SERNUMF   (NOL)
Endif

[M:STQ1]STADES             (NOL) = PSTA
If CLPN=1 & dim([M:STQ1]LPNNUMDES) >0                                                         # hcb X3-77043
   [M:STQ1]LPNNUMDES       (NOL) = PLPN                                                       # hcb X3-77043
   Affzo [M:STQ1]LPNNUMDES (NOL)                                                              # hcb X3-77043
Endif                                                                                         # hcb X3-77043
If CLOC=1 & dim([M:STQ1]LOCTYPDES) >0
   [M:STQ1]LOCTYPDES       (NOL) = PLOCTYP
   [M:STQ1]LOCDES          (NOL) = PLOC
   If dim([M:STQ1]WRHDES) > 0
      [M:STQ1]WRHDES   (NOL) = PWRH
      Affzo [M:STQ1]WRHDES  (NOL)
   Endif
   Affzo [M:STQ1]LOCTYPDES (NOL)
   Affzo [M:STQ1]LOCDES    (NOL)
Endif

Affzo [M:STQ1]PCUDES       (NOL)
Affzo [M:STQ1]QTYPCUDES    (NOL)
Affzo [M:STQ1]COEDES       (NOL)
Affzo [M:STQ1]QTYSTUDES    (NOL)
Affzo [M:STQ1]STADES       (NOL)

End



##################################################
# Contrôle qu'on ne dépasse pas la quantité de départ
# Et si l'article est géré en n° série E/S recalcule le n° série fin
##################################################
Subprog CTRNEWQTY( PNOL, PQTYN, PCOEN )
Value Integer PNOL
Value Decimal PQTYN
Value Decimal PCOEN

Local Integer I
Local Decimal LQTYSTUN
Local Integer LRET
Local Char    LSERF(GLONSER)

LQTYSTUN = PQTYN*PCOEN

Call QTEARR(LQTYSTUN,[M:SMP1]STU) From TRTDIV    # hcb 63440

If sum([M:SMP1]QTYSTUDES)-[M:SMP1]QTYSTUDES(PNOL) + LQTYSTUN > [M:SMP1]QTYSTU
    mkstat = 2
    GMESSAGE = mess( 393, 199, 1)
Endif
End

#####################################################################################
#                                                                   Ecran STOMP1/SMP1
#####################################################################################
# LOAD_FROM_STJ_SMP1 : Charge l'écran STOSMP1 [SMP1] à partir du fichier STOJOU [STJ]
#####################################################################################
$LOAD_FROM_STJ_SMP1
Local Integer LSTJRET

#                                                         hcb ???
Filter [STJ] Where   STOFCY = [M:SMP1]STOFCY
&                  & VCRTYP = [M:SMP1]VCRTYP
&                  & VCRNUM = [M:SMP1]VCRNUM
&                  & VCRLIN = [M:SMP1]VCRLIN
&                  & REGFLG = 1
&                  & QTYSTU > 0
&                  & left$(STA,1) <> "Q"

    For [STJ] Hint Key STJ1
        If [M:SMP1]NBLIG=0
            [M:SMP1]NBLIG=1
            If dim([M:SMP1]SERNUM)>0
                [M:SMP1]SERNUM([M:SMP1]NBLIG-1)    = [F:STJ]SERNUM
            Endif
        Else
#                                                                                             # hcb X3-77043 rajout test [F:STJ]LPNNUM
            If [M:SMP1]PCUDES([M:SMP1]NBLIG)    <> [F:STJ]PCU
&            | [M:SMP1]COEDES([M:SMP1]NBLIG)    <> [F:STJ]PCUSTUCOE
&            | [M:SMP1]STADES([M:SMP1]NBLIG)    <> [F:STJ]STA
&            | dim([M:SMP1]LOCDES)>0 & [M:SMP1]LOCDES([M:SMP1]NBLIG) <> [F:STJ]LOC
&            | dim([M:SMP1]LPNNUMDES)>0 & [M:SMP1]LPNNUMDES([M:SMP1]NBLIG) <> [F:STJ]LPNNUM
&            | dim([M:SMP1]WRHDES)>0 & [M:SMP1]WRHDES([M:SMP1]NBLIG) <> [F:STJ]WRH
                    [M:SMP1]NBLIG += 1
                    If dim([M:SMP1]SERNUM)>0
                        [M:SMP1]SERNUM([M:SMP1]NBLIG-1)    = [F:STJ]SERNUM
                    Endif
            Endif
        Endif
        Gosub CHARG_SMP1
    Next

Filter [STJ]
Return

$CHARG_SMP1
    [M:SMP1]WSTJFLG     ([M:SMP1]NBLIG-1)   = 1
    [M:SMP1]PCUDES      ([M:SMP1]NBLIG-1)   = [F:STJ]PCU
    [M:SMP1]QTYPCUDES   ([M:SMP1]NBLIG-1)  += [F:STJ]QTYPCU
    [M:SMP1]COEDES      ([M:SMP1]NBLIG-1)   = [F:STJ]PCUSTUCOE
    [M:SMP1]QTYSTUDES   ([M:SMP1]NBLIG-1)  += [F:STJ]QTYSTU
    [M:SMP1]STADES      ([M:SMP1]NBLIG-1)   = [F:STJ]STA
    If dim([M:SMP1]SERNUM)>0
       [M:SMP1]SERNUM   ([M:SMP1]NBLIG-1)   = [F:STJ]SERNUM
#                                                                     # hcb 110327 deb
       If [F:STJ]SERDEB <> ""
          [M:SMP1]SERNUM   ([M:SMP1]NBLIG-1)   = [F:STJ]SERDEB
          [M:SMP1]SERNUMF  ([M:SMP1]NBLIG-1)   = [F:STJ]SERFIN
       Endif
#                                                                     # hcb 110327 end
    Endif
    If dim([M:SMP1]LPNNUMDES)>0                                                               # hcb X3-77043
       [M:SMP1]LPNNUMDES([M:SMP1]NBLIG-1)   = [F:STJ]LPNNUM                                   # hcb X3-77043
    Endif                                                                                     # hcb X3-77043
    If dim([M:SMP1]LOCDES)>0
       [M:SMP1]LOCDES   ([M:SMP1]NBLIG-1)   = [F:STJ]LOC
    Endif
    If dim([M:SMP1]WRHDES)>0
       [M:SMP1]WRHDES   ([M:SMP1]NBLIG-1)   = [F:STJ]WRH
    Endif
    If dim([M:SMP1]LOCTYPDES)>0
       If [F:STC]STOFCY<>[F:STJ]STOFCY | [F:STC]LOC <> [F:STJ]LOC
           Read [STC]STC0=[F:STJ]STOFCY;[F:STJ]LOC
       Endif
       [M:SMP1]LOCTYPDES([M:SMP1]NBLIG-1)   = [F:STC]LOCTYP
    Endif
    # Transfert zones du fichier STOJOU vers l'écran STOSMP1
    GPOINT="STJ_SMP1" : Gosub ENTREE From EXEFNC
Return

##################################################
$MAJ_PECQTY
[M:SMP1]PECQTYSTU     = sum([M:SMP1]QTYSTUDES)
[M:SMP1]PECQTYPCU     = sum([M:SMP1]QTYSTUDES)/[M:SMP1]PCUSTUCOE

Affzo [M:SMP1]PECQTYSTU,PECQTYPCU
Gosub MAJ_QTYSMPREFS
Return

# Calcul de la qté refusée saisie : qty refusee des uatres lignes plus ligne en cours
$MAJ_QTYSMPREFS
Local Integer I
[M:SMP1]QTYSMPREFS = sigma (I=0,max([M:SMP1]NBLIG-1,nolign-1),[M:SMP1]QTYSTUDES(I)*(left$([M:SMP1]STADES(I),1)= "R"))
[M:SMP1]QTYSMPREFS += [M:SMP1]QTYSMPREFO
Affzo [M:SMP1]QTYSMPREFS
Return


###############################################################################
# LOAD_FROM_SGW : Charge l'écran STOSMP [SMP1] à partir de STOCHGW [SGW]       #
###############################################################################
$LOAD_FROM_SGW_SMP1
Local Char LUSCAV
Local Char LFMT
Local Integer LMODIF
Local Decimal LCOE
Local Integer K
#                                                                     # hcb 110327 deb
Local Char LMSKCOU
LMSKCOU = func STKLIB.MSKDEF
If LMSKCOU = "[CHGS]"
   [M:SMP1]WSTOSEQ = [M:CHGS]WSTOSEQ
   [M:SMP1]WSTOCOU = [M:CHGS]STOCOU
Else
#                                                          # hcb 110327 end
   [M:SMP1]WSTOSEQ = [M:SMP]WSTOSEQ
   [M:SMP1]WSTOCOU = [M:SMP]WSTOCOU(LLIGDOC)
Endif                                                      # hcb 110327

I = sigma(0,[M:SGW]NBLIG-1,(indcum+1)*([M:SGW]WSTOSEQ(indcum)=[M:SMP1]WSTOSEQ & [M:SGW]WSTOCOU(indcum)=[M:SMP1]WSTOCOU & (K=0 & sigma(K=1,1,1))))

If I>0
    I-=1
     While I<[M:SGW]NBLIG & [M:SMP1]WSTOSEQ=[M:SGW]WSTOSEQ(I)                               # hcb 110327
          If [M:SGW]WSTOCOU(I)=[M:SMP1]WSTOCOU                                             # hcb 110327
             If [M:SMP1]NBLIG=0
                [M:SMP1]NBLIG=1
             Endif
             [M:SMP1]PCUDES   ([M:SMP1]NBLIG-1)               = [M:SGW]WPCUDES    (I)
             [M:SMP1]QTYPCUDES([M:SMP1]NBLIG-1)               = [M:SGW]WQTYPCUDES (I)
             [M:SMP1]QTYSTUDES([M:SMP1]NBLIG-1)               = [M:SGW]WQTYSTUDES (I)
             [M:SMP1]STADES   ([M:SMP1]NBLIG-1)               = [M:SGW]WSTADES    (I)
             [M:SMP1]COEDES   ([M:SMP1]NBLIG-1)               = [M:SGW]WCOEDES    (I)
             Actzo [M:SMP1]PCUDES([M:SMP1]NBLIG-1),QTYPCUDES([M:SMP1]NBLIG-1),COEDES([M:SMP1]NBLIG-1)
             Call CTLUOM([M:SMP1]ITMREF,3,"",[M:SMP1]PCUDES([M:SMP1]NBLIG-1),LCOE, LUSCAV, LFMT, LMODIF) From STKACT
             If LMODIF=2
                Diszo [M:SMP1]COEDES([M:SMP1]NBLIG-1)
             Endif
             If dim([M:SMP1]SERNUM)>0
                [M:SMP1]SERNUM([M:SMP1]NBLIG-1)           = [M:SGW]WSERNUM   (I)
             Endif
             If dim([M:SMP1]LPNNUMDES)>0                                                      # hcb X3-77043
                [M:SMP1]LPNNUMDES([M:SMP1]NBLIG-1)        = [M:SGW]WLPNNUMDES(I)              # hcb X3-77043
             Endif                                                                            # hcb X3-77043
             If dim([M:SMP1]LOCTYPDES)>0
                [M:SMP1]LOCTYPDES([M:SMP1]NBLIG-1)        = [M:SGW]WLOCTYPDES(I)
             Endif
             If dim([M:SMP1]LOCDES)>0
                [M:SMP1]LOCDES   ([M:SMP1]NBLIG-1)        = [M:SGW]WLOCDES   (I)
             Endif
             If dim([M:SMP1]WRHDES)>0
                [M:SMP1]WRHDES   ([M:SMP1]NBLIG-1)        = [M:SGW]WWRHDES   (I)
             Endif
             If dim([M:SMP1]WLOCSEQ)>0
                [M:SMP1]WLOCSEQ  ([M:SMP1]NBLIG-1)        = [M:SGW]WLOCSEQ   (I)
             Endif
#                                                                             # hcb 110327 deb
             If dim([M:SMP1]SERNUMF)>0
                [M:SMP1]SERNUMF      ([M:SMP1]NBLIG-1)     = [M:SGW]WSERNUMF  (I)
             Endif
             If dim([M:SMP1]WSTOSEQIND)>0
                [M:SMP1]WSTOSEQIND   ([M:SMP1]NBLIG-1)     = [M:SGW]WSTOSEQIND(I)
             Endif
#                                                                             # hcb 110327 fin
             # Transfert zones de l'écran STOCHGW vers l'écran STOSMP1
             GPOINT="SGW_SMP1" : Gosub ENTREE From EXEFNC
             [M:SMP1]NBLIG += 1
          Endif
          I+=1
    Wend
Endif
Return


########################################################################
# RECSGW_SMP     met à jour l ecran STOSMP à partir STOCHGW
#                appel depui TRTSTOSMP1  ecran STOSMP1
# Cherche pour une ligne de document donné si dans le détail de cette ligne:
#    - Le statut qualité est unique ou multiple
#    - Le type d'emplacement est unique ou multiple
#    - L'emplacement est unique ou multiple
#    - Désignation du mouvement unique.
# Cette fonction permet de faire apparaître un $ pour montrer la décomposition du champ
########################################################################
# Paramètres E : ABR  = Ecran "XYZ"
#              : NOL  = Indice de ligne dans le tableau du document (nolign-1)
#              : LSUP = Inutilisé (paramètre supplémentaire au cas où)
#
########################################################################
Subprog RECSGW_SMP (PNOL,PSEQ,PCOU,LSUP)
Value    Integer PNOL
Value    Integer PSEQ
Value    Decimal PCOU

Value    Char    PSUP

Local Char    PSTA    (GLONSTA)
Local Char    PLOCTYP (GLONTLO)
Local Char    PLOC    (GLONEMP)
Local Char    PSER    (GLONSER)
Local Char    PSERF   (GLONSER)
Local Char    PWRH    (GLONWRH)
Local Char    PPCU    (GLONUOM)
Local Char    PLPN    (GLONLPN)                                                               # hcb X3-77043
Local Decimal PCOE

Raz PPCU, PSTA, PLOCTYP, PLOC, PSER, PSERF, PWRH,PCOE,PLPN                                    # hcb X3-77043

Local Char PCAR : PCAR = "$"
Local Integer I,J,K,CLOC,CLPN                                                                 # hcb X3-77043
Local Integer LRET
Local Integer LNBDET, LNBEG
I = sigma(0,[M:SGW]NBLIG-1,(indcum+1)*([M:SGW]WSTOSEQ(indcum)=PSEQ & [M:SGW]WSTOCOU(indcum)=PCOU & (K=0 & sigma(K=1,1,1))))

If I>0
    I-=1
    PSTA    = [M:SGW]WSTADES   (I)
    PLOCTYP = [M:SGW]WLOCTYPDES(I)
    PLOC    = [M:SGW]WLOCDES   (I)
    PPCU    = [M:SGW]WPCUDES   (I)
    PCOE    = [M:SGW]WCOEDES   (I)
    PLPN    = [M:SGW]WLPNNUMDES(I)                                                            # hcb X3-77043
    LNBDET = sigma(I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WSTOCOU(indcum)=PCOU))
    LNBEG  = sigma(I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WSTADES(indcum)=PSTA)&([M:SGW]WSTOCOU(indcum)=PCOU))
    If LNBEG<>LNBDET
        PSTA = PCAR
    Endif
    LNBEG  = sigma(I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WPCUDES(indcum)=PPCU)&([M:SGW]WSTOCOU(indcum)=PCOU))
    If LNBEG<>LNBDET
        PPCU = PCAR
        PCOE = 1
    Endif
#---
    LNBEG = sigma(I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&(left$([M:SGW]WSTADES(indcum),1)="Q"))
#---
#                                                                                             # hcb X3-77043 deb
    If PLPN<>""
        LNBEG  = sigma(I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WLPNNUMDES(indcum)=PLPN)&([M:SGW]WSTOCOU(indcum)=PCOU))
        If LNBEG<>LNBDET
            PLPN = PCAR
        Endif
    Endif
#                                                                                             # hcb X3-77043 fin
    If PLOCTYP<>""
        LNBEG  = sigma(I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WLOCTYPDES(indcum)=PLOCTYP)&([M:SGW]WSTOCOU(indcum)=PCOU))
        If LNBEG<>LNBDET
            PLOCTYP = PCAR
        Endif
        LNBEG  = sigma(I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WLOCDES(indcum)=PLOC)&([M:SGW]WSTOCOU(indcum)=PCOU))
        If LNBEG<>LNBDET
            PLOC = PCAR
        Endif
        LNBEG  = sigma(I,[M:SGW]NBLIG-1,([M:SGW]WSTOSEQ(indcum)=PSEQ)&([M:SGW]WWRHDES(indcum)=PWRH)&([M:SGW]WSTOCOU(indcum)=PCOU))
        If LNBEG<>LNBDET
           PWRH = CAR
        Endif
    Endif

    [M:SMP]NUMLIGLOT  (PNOL) = [M:SGW]NUMLIGLOT(I)                                  # hcb 110327
    If [M:SGW]WSERNUM<>"" & [F:ITM]SERMGTCOD <> 4                                   # hcb 110327
        Local Char LTABSER(GLONSER)(LNBDET)
        Local Char LTABSERF(GLONSER)(LNBDET)
        For J=0 To LNBDET-1
            LTABSER(J)  = [M:SGW]WSERNUM(I+J)
            LTABSERF(J) = [M:SGW]WSERNUMF(I+J)
        Next
        Sorta LTABSER, LTABSERF
        PSER  = LTABSER(0)
        PSERF = LTABSERF(0)
        For J=1 To LNBDET-1
            Call PLUS_UN(LTABSERF(J-1),LTABSERF(J-1), LRET) From STKLIB
            If LTABSER(J) <> LTABSERF(J-1)
                PSERF = PCAR
            Else
                PSERF = LTABSERF(J)
            Endif
        Next
    Endif
Endif

CLOC = dim([M:SMP]LOC)>0 & [F:ITF]LOCMGTCOD = 2
CLPN = dim([M:SMP]LPNNUMDES)>0 & [F:ITF]LPNMGTCOD = 2  # hcb 110327

[M:SMP]STADES             (PNOL) = PSTA
[M:SMP]PCUDES             (PNOL) = PPCU
[M:SMP]COEDES             (PNOL) = PCOE
#                                                       # hcb 110327 deb
If LNBDET <> 0
   [M:SMP]MODFLG          (PNOL) = 1
Endif
#                                                       # hcb 110327 end
If LNBDET > 1
   [M:SMP]MODFLG          (PNOL) = 2
Endif
If CLPN=1 & dim([M:SMP]LPNNUMDES) >0                                                          # hcb X3-77043
   [M:SMP]LPNNUMDES       (PNOL) = PLPN                                                       # hcb X3-77043
   Affzo [M:SMP]LPNNUMDES (PNOL)                                                              # hcb X3-77043
Endif                                                                                         # hcb X3-77043
If CLOC=1 & dim([M:SMP]LOCTYPDES) >0
   [M:SMP]LOCTYPDES       (PNOL) = PLOCTYP
   [M:SMP]LOCDES          (PNOL) = PLOC
   If dim([M:SMP]WRHDES) > 0
      [M:SMP]WRHDES       (PNOL) = PWRH
      Affzo [M:SMP]WRHDES (PNOL)
   Endif
   Affzo [M:SMP]LOCTYPDES (PNOL)
   Affzo [M:SMP]LOCDES    (PNOL)
Endif
If [M:SMP]PCUDES          (PNOL) = ""
   [M:SMP]PCUDES          (PNOL) = [M:SMP]PCU        (PNOL)
   [M:SMP]COEDES          (PNOL) = [M:SMP]PCUSTUCOE  (PNOL)
Endif

[M:SMP]QTYPCUDES          (PNOL) = [M:SMP]QTYPCU     (PNOL)
[M:SMP]QTYSTUDES          (PNOL) = [M:SMP]QTYSTU     (PNOL)

Affzo [M:SMP]PCUDES       (PNOL)
Affzo [M:SMP]QTYPCUDES    (PNOL)
Affzo [M:SMP]COEDES       (PNOL)
Affzo [M:SMP]QTYSTUDES    (PNOL)
Affzo [M:SMP]STADES       (PNOL)

End



########################################################################################
# CAL_QTYSMPREFLIG  Calcul qte refusée saisie de la ligne SMP à partir de STOCHGW [SGW]#
########################################################################################
Subprog CAL_QTYSMPREFLIG (PNOL,PSEQ,PCOU,LSUP)
Value    Integer PNOL
Value    Integer PSEQ
Value    Decimal PCOU
Value    Char    PSUP
Local    Integer I1
Local    Integer K1
I1 = sigma(0,[M:SGW]NBLIG-1,(indcum+1)*([M:SGW]WSTOSEQ(indcum)=PSEQ & [M:SGW]WSTOCOU(indcum)=PCOU & (K1=0 & sigma(K1=1,1,1))))

If I1>0
    I1-=1
    While I1<[M:SGW]NBLIG & (PSEQ=[M:SGW]WSTOSEQ(I1) & [M:SGW]WSTOCOU(I1)=PCOU)
          If left$([M:SGW]WSTADES(I1),1) = "R"
             [M:SMP]QTYSMPREFLIG(PNOL) + = [M:SGW]WQTYSTUDES (I1)
          Endif
          I1+=1

    Wend
Endif
End



###############################################################################
# DELSTOCHGW : Efface le détail de N lignes de document changement stock
###############################################################################
# Paramètres E : PFCY   = Site de départ
#                PSEQ   = Séquence
#                PCOU   = Stocou
#                PDELLOC= Indique s'il faut supprimer les réservations d'emplacement
#
#            S : PRET   = Code retour (0=OK, 1=Erreur)
#
# Appelé dans le cadre de la suppression d'un bloc de ligne
# ou de toutes les lignes
###############################################################################
Subprog DELSTOCHGW(PFCY, PSEQ, PCOU, PDELLOC, PRET )
Value    Char    PFCY
Value    Integer PSEQ
Value    Decimal PCOU
Value    Integer PDELLOC
Variable Integer PRET

Local Integer WTRBEGIN, I, IND
Local Decimal LSTOCOU
Local Decimal LWIPQTY, LWIPQTA

Raz WTRBEGIN

If clalev([F:STO1])=0  Local File STOCK   [STO1]  Endif
If clalev([F:SWW]) =0  Local File STOWIPW [SWW]   Endif

# On fait 2 boucles pour ne pas déphaser les qtes en cours de traitement
# de la table [STO1] et l'écran de stockage des lignes à sortir en cas de
# problème sur la table stock

# Si pas de transaction en cours
If adxlog<>1
   GOK=1
   Trbegin [STO1]
   WTRBEGIN=1
Endif

For I=0 To [M:SGW]NBLIG-1
    If [M:SGW]WSTOSEQ(I)>0 & (PSEQ =[M:SGW]WSTOSEQ(I) & PCOU =[M:SGW]WSTOCOU(I))
        Readlock [STO1]STO0=PFCY;[M:SGW]WSTOCOU(I)
        If fstat
            If fstat=1
                GOK=0
                Call RSTA("STO1",PFCY-num$([M:SGW]WSTOCOU(I))) From GLOCK
                LRET=1 : Break
            Endif
        Else
            # Dans le cas où l'on serait passé en négatif
            If [F:STO1]SERNUM<>""
                LWIPQTY = [F:STO1]QTYSTU
                LWIPQTA = [F:STO1]QTYSTUACT
            Else
                LWIPQTY = [M:SGW]WWIPQTY(I)
                LWIPQTA = [M:SGW]WWIPQTA(I)
            Endif
            [F:STO1]CUMWIPQTY  = max(0,[F:STO1]CUMWIPQTY-LWIPQTY)
            [F:STO1]CUMWIPQTA  = max(0,[F:STO1]CUMWIPQTA-LWIPQTA)

            # Suppression qté en cours de traitement
            LSTOCOU = [F:STO1]STOCOU
            Call DEL_STOWIPW(LSTOCOU,LWIPQTY) From STKLIB
            Rewrite [STO1]
            If fstat
                GOK=0  : Call FSTA("STO1") From GLOCK
                LRET=1 : Break
            Endif
#                                                                                               # hcb 110327 deb
            If [M:SGW]WSTOSEQIND(I) <> 0 & [M:SGW]WSERNUM(I) <> ""
            # Suppression série en cours de traitement
               Call DEL_STOSERW([F:STO]ITMREF,[M:SGW]WSERNUM(I),[M:SGW]WQTYSTUDES(I),PRET) From STKLIB
               If PRET <>0
                  Break
               Endif
            Endif
            [M:SGW]WSTOSEQ(I) = 0
#                                                                                               # hcb 110327 fin
            [M:SGW]WSTOCOU(I) = 0
            IND+=1
        Endif
    Endif
Next I

# Si on a ouvert une transaction
If WTRBEGIN=1
    If GOK=0
        Rollback
        End
    Else
        Commit
        Raz WTRBEGIN
    Endif
Endif


For I=0 To [M:SGW]NBLIG-1
    If [M:SGW]WSTOSEQ(I)>0 & (PSEQ =[M:SGW]WSTOSEQ(I) & PCOU =[M:SGW]WSTOCOU(I))
        If PDELLOC
            Call STKDELRES([M:SGW]WLOCSEQ(I), "", "", PRET) From STKLOC
        Endif
        Raz [M:SGW]WSTOSEQ(I),[M:SGW]WQTYPCUDES(I)
    Endif
    If clalev([M:VALW])
       # J=evalue("find([M:VALW]WSTOSEQ(I),[M:"+PABR+"]WSTOSEQ(PLIG..PLIG1))")    # hcb 110327
         J=evalue("find([M:VALW]WSTOSEQ(I),PSEQ)")                                # hcb 110327
        If J>0
            Raz [M:VALW]WSTOSEQ(J-1)
        Endif
    Endif

Next I

End

