#<AdxTL>@(#)0.0.0.0 $Revision$
#FRLAA - 2016-12-05 - REQUIREMENT X3-11647 US X3-12771 - START
$ACTION
Case ACTION
  When "OUVRE"          : Gosub OUVRE
  When "LIENS"          : Gosub LIENS
  When "STYLE"          : Gosub STYLE
  When "RAZCRE"         : Gosub RAZCRE
  When "CREATION"       : Gosub CREATION
  When "APRES_CRE"      : Gosub APRES_CRE
  When "MODIF"          : Gosub MODIF
  When "APRES_MOD"      : Gosub APRES_MOD
  When "RAZDUP"         : Gosub RAZDUP
  When "AV_ANNULE"      : Gosub AV_ANNULE
  When "ANNULE"         : Gosub ANNULE
  When "FERME"          : Gosub FERME
  When "FILTRE"        : Gosub FILTRE
 When Default
Endcase
Return

$OUVRE
#Disabling the classic CUD operation - Hybrid development (ANOWRITE)
Local Integer ANOWRITE
ANOWRITE = 1

#Opening tables and declaring an instance of the main class
If clalev([F:EPAHEA]) = 0 : Local File EPAHEADER        [EPAHEA]         : Endif
If clalev([F:EPADET]) = 0 : Local File EPADETAILS       [EPADET]         : Endif
If clalev([F:EPASPD]) = 0 : Local File EPASUSPEND       [EPASPD]         : Endif
If clalev([F:EPAADP]) = 0 : Local File EPAADDPAY        [EPAADP]         : Endif
If clalev([F:HRCTR])    = 0 : Local File EMPLOCTR         [HRCTR]        : Endif
If clalev([F:ID])     = 0 : Local File EMPLOID          [ID]             : Endif

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

#ADNGO - 2018-02-13 - X3-74506 - START
#If GLEGFIL <> ""
#  GCURLEG = GLEGFIL
#  #GCURLEG ="[F:EPATYP]LEG='"+GLEGFIL+"'"
#  #Filter [EPAHEA] Where LEG = GLEGFIL
#Else
#  GCURLEG = ""
#Endif
#ADNGO - 2018-02-13 - X3-74506 - END

Global Instance I_EPAHEADER Using C_EPAHEADER
Return

$LIENS
#This will be the only Supervisor action we will allow in classic mode
# We wil let the supervisor read from the database and populate the mask
#Instantiate the class with the key from the screen to have it online for update/delete transactions
If (I_EPAHEADER <> null) : FreeGroup I_EPAHEADER : Endif
I_EPAHEADER = NewInstance C_EPAHEADER AllocGroup null
Local Integer READSTATUS
#[L]READSTATUS = fmet I_EPAHEADER.AREAD([M:EPA0]LEG,[M:EPA0]REFNUM,[M:EPA0]EPACOD)
[L]READSTATUS = fmet I_EPAHEADER.AREAD([M:EPA0]LEG,[M:EPA0]EPACOD)
If ([L]READSTATUS  >= [V]CST_AERROR)
  Call GET_ERRORS(I_EPAHEADER)
  If GOK=0 : Return : Endif
Endif

#The supervisor will not load the collections from the table to the mask - this must be done using the collections from the class to the mask!
#Reading from the collections to the mask = Collection instantiated with the main class
Gosub LOAD_COLLECTIONS

#Additional information
[M:EPA0]NAM = I_EPAHEADER.TCHNAM
[M:EPA0]SRN = I_EPAHEADER.TCHSRN

GCURLEG = [M:EPA0]LEG

Affzo [M:EPA0]1-99
Affzo [M:EPA1]1-99
Affzo [M:EPA3]1-99

#FRLAA 2018-06-25 X3-89704 - START
#Do not allow the change on contract on existing record
Diszo [M:EPA0]CTRNUM
#FRLAA 2018-06-25 X3-89704 - END
Return

$MODIF
Local Integer WRITESTATUS, MY_STATUS, I
#Set the instance the same as for CREATION
SetInstance I_EPAHEADER With [F:EPAHEA]

For I = 1 To maxtab(I_EPAHEADER.EPASUSPEND)
  If I_EPAHEADER.EPASUSPEND(1) <> null : [L]MY_STATUS = fmet I_EPAHEADER.ADELLINE("EPASUSPEND",1) : Endif
   If ([L]MY_STATUS >= [V]CST_AERROR)
    Call GET_ERRORS(I_EPATYP)
    GOK=0 : GERR=1 : Return
  Endif
Next I

For I = 1 To maxtab(I_EPAHEADER.EPAADDPAY)
  If I_EPAHEADER.EPAADDPAY(1) <> null : [L]MY_STATUS = fmet I_EPAHEADER.ADELLINE("EPAADDPAY",1) : Endif
   If ([L]MY_STATUS >= [V]CST_AERROR)
    Call GET_ERRORS(I_EPAHEADER)
    GOK=0 : GERR=1 : Return
  Endif
Next I

#Adding lines to the collections
Gosub WRITE_COLLECTIONS

#Invoke the creation process and handle the error if applicable
[L]WRITESTATUS = fmet I_EPAHEADER.AUPDATE()
If ([L]WRITESTATUS >= [V]CST_AERROR)
  Call GET_ERRORS(I_EPAHEADER)
  If GOK=0 : Return : Endif
Endif
Return

$APRES_MOD
#This action is called after a successful update. You may have to refresh some screen fields
Gosub RELIT From GOBJSUB
Return

$RAZDUP
#Raz GCURLEG
#GCURLEG = GLEGFIL

Local Integer MY_STATUS
If (I_EPAHEADER <> null) : FreeGroup I_EPAHEADER : Endif
I_EPAHEADER = NewInstance C_EPAHEADER AllocGroup null

[L]MY_STATUS = fmet I_EPAHEADER.AINIT()
If ([L]MY_STATUS >= [V]CST_AERROR)
  Call GET_ERRORS(I_EPAHEADER)
  GOK = 0 : GERR = 1
  Return
Endif

Affzo [M:EPA0]1-99
Affzo [M:EPA1]1-99
Return


$STYLE
If [M:EPA1]BALFLG = 2
  Actzo [M:EPA1]EPABAL
Else
  Raz [M:EPA1]EPABAL
  Diszo [M:EPA1]EPABAL
Endif
Return

$RAZCRE

Local Integer MY_STATUS

#ADNGO - 2018-02-13 - X3-74506 - START
#If GLEGFIL <> "" and GCURLEG = ""
#  GCURLEG = GLEGFIL
#  Infbox GCURLEG
#Else
#  Raz GCURLEG
#Endif
#If GNBLEG = 1         :#=dossier mono-leg
# #Infbox GCURLEG
# GCURLEG = GDOSLEG
#Else
#  GCURLEG = ""
#Endif
If [M]LEG <> "" Then
  GCURLEG = [M]LEG
Else
  Raz GCURLEG
Endif
#ADNGO - 2018-02-13 - X3-74506 - END
If (I_EPAHEADER <> null) : FreeGroup I_EPAHEADER : Endif
I_EPAHEADER = NewInstance C_EPAHEADER AllocGroup null

[L]MY_STATUS = fmet I_EPAHEADER.AINIT()
If ([L]MY_STATUS >= [V]CST_AERROR)
  Call GET_ERRORS(I_EPAHEADER)
  GOK = 0 : GERR = 1
  Return
Endif

SetInstance [F:EPAHEA] With I_EPAHEADER
#MIPEA - 2018-06-04-  X3-94402- START
#If GLEGFIL <> ""
#  GCURLEG = GLEGFIL
#Else
#  Raz GCURLEG
#Endif
#MIPEA - 2018-06-04-  X3-94402- END


#[M:EPA0] = [F:EPAHEA]

Affzo [M:EPA0]1-99
Return

$CREATION
#Transfer the data from the file to the class - all field names are the same
#The supervisor has already transfered the data from the mask to the file
SetInstance I_EPAHEADER With [F:EPAHEA]
#Adding lines to the collections
#Setting variable
Gosub WRITE_COLLECTIONS

#Invoke the creation process and handle the error if applicable
Local Integer WRITESTATUS
[L]WRITESTATUS = fmet I_EPAHEADER.AINSERT()
If ([L]WRITESTATUS >= [V]CST_AERROR)
  Call GET_ERRORS(I_EPAHEADER)
  If GOK=0 : Return : Endif
Endif

#After a successful insert, refresh the [F] file because the key may be generated in the AINSERT method
SetInstance [F:EPAHEA] With I_EPAHEADER
Return

$APRES_CRE
#This action is called after a successful creation. You may have to refresh some screen fields
Gosub RELIT From GOBJSUB
Return

$AV_ANNULE
#Diable supervisor - separate process
Local Integer ANOWRITE
ANOWRITE = 1
Return

$ANNULE
#The class should not be instantiated already as a read in LIENS
#Invoke the delete method
Local Integer DELETESTATUS
[L]DELETESTATUS = fmet I_EPAHEADER.ADELETE()
If ([L]DELETESTATUS >= [V]CST_AERROR)
  Call GET_ERRORS(I_EPAHEADER)
  If GOK=0 : Return : Endif
Endif
Return


$FERME
#Free the instance after leaving the transaction
If (I_EPAHEADER <> null) : FreeGroup I_EPAHEADER : Endif
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$WRITE_COLLECTIONS
Local Char ALLFIELDS(35)
Local Integer I,INDEX
INDEX = 1
#Adding lines to the collections
If I_EPAHEADER.EPADETAILS(INDEX) = null : INDEX = fmet I_EPAHEADER.ADDLINE("EPADETAILS", [V]CST_ALASTPOS) : Endif

#Transfer data on the line to the collection line
Raz [F:EPADET]
[F:EPADET] = [M:EPA1]
SetInstance I_EPAHEADER.EPADETAILS(INDEX) With [F:EPADET]

I_EPAHEADER.EPADETAILS(INDEX).EPACOD = [M:EPA0]EPACOD
I_EPAHEADER.EPADETAILS(INDEX).REFNUM = [M:EPA0]REFNUM
I_EPAHEADER.EPADETAILS(INDEX).LEG = [M:EPA0]LEG

#Supension
For nolign = 1 To [M:EPA3]EPAA3A
  #Add new line to the collection
  INDEX = fmet I_EPAHEADER.ADDLINE("EPASUSPEND", [V]CST_ALASTPOS)
  If INDEX = [V]CST_ANOTDEFINED
    Call GET_ERRORS(I_EPATYP)
    GOK=0 : GERR=1 : Return
  Endif

  #Transfer data on the line to the collection line
  Raz [F:EPASPD]
  [F:EPASPD] = [M:EPA3]
  SetInstance I_EPAHEADER.EPASUSPEND(INDEX) With [F:EPASPD]
  I_EPAHEADER.EPASUSPEND(INDEX).EPACOD              = [M:EPA0]EPACOD
  I_EPAHEADER.EPASUSPEND(INDEX).REFNUM             =  [M:EPA0]REFNUM
  I_EPAHEADER.EPASUSPEND(INDEX).LEG             =  [M:EPA0]LEG
Next nolign

#Additional payments
For nolign = 1 To [M:EPA3]EPAA3B
  #Add new line to the collection
  INDEX = fmet I_EPAHEADER.ADDLINE("EPAADDPAY", [V]CST_ALASTPOS)
  If INDEX = [V]CST_ANOTDEFINED
    Call GET_ERRORS(I_EPATYP)
    GOK=0 : GERR=1 : Return
  Endif

  #Transfer data on the line to the collection line
  Raz [F:EPAADP]
  [F:EPAADP] = [M:EPA3]
  SetInstance I_EPAHEADER.EPAADDPAY(INDEX) With [F:EPAADP]
  I_EPAHEADER.EPAADDPAY(INDEX).EPACOD              = [M:EPA0]EPACOD
  I_EPAHEADER.EPAADDPAY(INDEX).REFNUM             =  [M:EPA0]REFNUM
  I_EPAHEADER.EPAADDPAY(INDEX).LEG             =  [M:EPA0]LEG
Next nolign

Return

Subprog EPA_SIMULATE()
#Declare variables for simulation
Local Date EMOIPAY
Local Decimal BALPAY, MTHINSPAY, ADMCOSTPAY, ADDPAY, PAYVAL, TOTPAY,ADMSPD,INSSPD,MTHINSFIX,ADMFIX
Local Char REFNUM(GLONEML), CTRNUM(GLONHRCTR), EPACOD(GLONEPA), LEG(20)
Local Date CTRDAT
Local Integer PERCOUNT,BALFLG
#FRLAA 2018-06-25 X3-89704 - START
Local Decimal PCTR_PAYADM,PCTR_PAYINS,PCTR_PAYADD

Local File EMPLOCTR [HRCTR2]
Read [HRCTR2]CTR0 = [M:EPA0]REFNUM;[M:EPA0]CTRNUM;[M:EPA0]CTRDAT
If !fstat
  CTRDATEND = [F:HRCTR2]XITDAT
Else
  End
Endif
#FRLAA 2018-06-25 X3-89704 - END

#Assign all the variables for the calculation function
BALFLG      = [M:EPA1]BALFLG
BALPAY      = [M:EPA1]EPABAL
REFNUM      = [M:EPA0]REFNUM
CTRNUM      = [M:EPA0]CTRNUM
CTRDAT      = [M:EPA0]CTRDAT
EPACOD      = [M:EPA0]EPACOD
MTHINSFIX   = [M:EPA1]MTHINS
MTHINSPAY   = MTHINSFIX
PERCOUNT    = 1
LEG         = [M:EPA0]LEG

#If no record found at this stage process can not continue - no values - end 0
If MTHINSPAY = 0
  End
Endif

#Set EMOIPAY (Start date of the payment) to the end of the month and start the loop
EMOIPAY = eomonth([M:EPA1]STRDAT)
nolign = 1
#Start the calculations
While EMOIPAY <= eomonth([V]GMOIPAY)
  #FRLAA 2018-06-25 X3-89704 - START
#  If func EPAFUNCTIONS.CALC_EPA(EMOIPAY, BALPAY, MTHINSPAY, MTHINSFIX, ADMFIX,ADMCOSTPAY, ADDPAY, PAYVAL, TOTPAY, EPACOD, REFNUM, CTRNUM, CTRDAT, PERCOUNT, ADMSPD, INSSPD, BALFLG, LEG) = 2
#    Gosub  CHARGE_EPA : Break
#  Endif
  If CTRDATEND <> [00/00/00] and EMOIPAY > CTRDATEND : Break : Endif
  If func EPAFUNCTIONS.CALC_EPA([V]GMOIPAY,EMOIPAY, BALPAY, MTHINSPAY, MTHINSFIX, ADMFIX,ADMCOSTPAY, ADDPAY, PAYVAL, TOTPAY, EPACOD, REFNUM, CTRNUM, CTRDAT, PERCOUNT, ADMSPD, INSSPD, BALFLG,
& PCTR_PAYADM,PCTR_PAYINS,PCTR_PAYADD,LEG) <> 1
  #FRLAA 2018-06-25 X3-89704 - END
    Gosub  CHARGE_EPA
    nolign+=1
    #Write current month
    If eomonth(EMOIPAY) = eomonth(GMOIPAY)
      Gosub CHARGE_EPA_CURRENT
    Endif
  Endif #FRLAA 2018-06-25 X3-89704
  #Check the start date of the record
  EMOIPAY = eomonth(addmonth(EMOIPAY,1))
  PERCOUNT += 1
Wend

[M:EPA2]EPAA2 = nolign
Affzo [M:EPA2]

End

$CHARGE_EPA

[M:EPA2]PAYMON(nolign-1)            = EMOIPAY
[M:EPA2]BALVAL(nolign-1)            = BALPAY
[M:EPA2]MTHINSVAL(nolign-1)         = MTHINSPAY
[M:EPA2]ADMCSTVAL(nolign-1)         = ADMCOSTPAY
[M:EPA2]ADDPAY(nolign-1)            = ADDPAY
[M:EPA2]PAYVAL(nolign-1)            = PAYVAL
[M:EPA2]TOTINS(nolign-1)            = TOTPAY
Return

$CHARGE_EPA_CURRENT
Local Integer CURRLINE : CURRLINE = 1

#Simulate when active flag is false, to show zero values
If [M:EPA0]ACTFLG = 1
  BALPAY = 0
  MTHINSPAY = 0
  ADMCOSTPAY = 0
  ADDPAY = 0
  TOTPAY = 0
Endif

[M:EPA2]PAYMONPAY(CURRLINE-1)            = EMOIPAY
[M:EPA2]BALVALPAY(CURRLINE-1)            = BALPAY
[M:EPA2]MTHINSVALPAY(CURRLINE-1)         = MTHINSPAY
[M:EPA2]ADMCSTVALPAY(CURRLINE-1)         = ADMCOSTPAY
[M:EPA2]ADDPAYPAY(CURRLINE-1)            = ADDPAY
[M:EPA2]TOTINSPAY(CURRLINE-1)            = TOTPAY
[M:EPA2]EPAA1 = CURRLINE
Affzo [M:EPA2]
Return

Subprog GET_ERRORS(WCONTAINER)
Variable Instance WCONTAINER Using C_EPAHEADER

Local Integer I
Local Char WTEXTE(50)

 GMESSAGE = func LCCLIB.MAXMSG(WCONTAINER)
 If GMESSAGE = AVOID.ACHAR
   #--- Lines errors
  For I=1 To maxtab(WCONTAINER.EPADETAILS)
    GMESSAGE = func LCCLIB.MAXMSG(WCONTAINER.EPADETAILS(I))
    If GMESSAGE <> AVOID.ACHAR
      Call TEXTE(53658, WTEXTE) From OBJDIV
      GMESSAGE = WTEXTE + " : " + GMESSAGE
   Endif
  Next I
Endif
GOK=0 : GERR=1
End

Subprog AM_ADMVAL(VALEUR)
Variable Decimal VALEUR
Local Integer INDEX : INDEX = 1
If I_EPAHEADER.EPADETAILS(INDEX) = null : INDEX = fmet I_EPAHEADER.ADDLINE("EPADETAILS", [V]CST_ALASTPOS) : Endif
I_EPAHEADER.EPADETAILS(INDEX).ADMVAL = VALEUR
[M:EPA1]WADMVAL = I_EPAHEADER.EPADETAILS(INDEX).WADMVAL
#[M:EPA1]WADMVAL = func EPAFUNCTIONS.ADMCOST(GMOIPAY,[M:EPA0]REFNUM,[M:EPA0]CTRNUM,[M:EPA0]CTRDAT,VALEUR,[M:EPA1]ADMCST,[M:EPA1]MTHINS)
Affzo [M:EPA1]WADMVAL
End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
Read[F:ID]ID0=VALEUR
  If !fstat Then
    [M:EPA0]NAM = [F:ID]NAM
    [M:EPA0]SRN = [F:ID]SRN
  Endif
End

Subprog AP_CTRNUM(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
End


Subprog AM_BALFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  Actzo [M:EPA1]EPABAL
Else
  Raz [M:EPA1]EPABAL
  Diszo [M:EPA1]EPABAL
Endif
End

Subprog C_EPABAL(VALEUR)
Variable Decimal VALEUR

Local Integer INDEX : INDEX = 1
If I_EPAHEADER.EPADETAILS(INDEX) = null : INDEX = fmet I_EPAHEADER.ADDLINE("EPADETAILS", [V]CST_ALASTPOS) : Endif
If (fmet I_EPAHEADER.EPADETAILS(INDEX).BALCONTROL(VALEUR,[M:EPA1]MTHINS,[M:EPA1]BALFLG))=2
  #Handle the error
  GMESSAGE = mess(00011,10661,1)
  mkstat = 2 : GERR=1
Elsif (fmet I_EPAHEADER.EPADETAILS(INDEX).BALCONTROL(VALEUR,[M:EPA1]MTHINS,[M:EPA1]BALFLG))=3
  #Handle the error
  GMESSAGE = mess(00009,10661,1)
  mkstat = 2 : GERR=1
Endif
End



Subprog AM_ADMCST(VALEUR)
Variable Integer VALEUR
Local Char VCPY(GLONCPY), VFCY(GLONFCY)
Local Integer TYPVAL

Local Integer INDEX : INDEX = 1
If I_EPAHEADER.EPADETAILS(INDEX) = null : INDEX = fmet I_EPAHEADER.ADDLINE("EPADETAILS", [V]CST_ALASTPOS) : Endif
#If it is a new record the contract details might not be on the class - populate
I_EPAHEADER.REFNUM = [M:EPA0]REFNUM
I_EPAHEADER.CTRNUM = [M:EPA0]CTRNUM
I_EPAHEADER.CTRDAT = [M:EPA0]CTRDAT

#Pass the new ADMCST value to invoke propagate on the class
I_EPAHEADER.EPADETAILS(INDEX).ADMCST = VALEUR
[M:EPA1]WADMVAL = I_EPAHEADER.EPADETAILS(INDEX).WADMVAL
Affzo [M:EPA1]WADMVAL
End

Subprog C_MTHINS(VALEUR)
Variable Decimal VALEUR
End




Subprog C_CTRNUM(VALEUR)
Variable Char     VALEUR


#If [M:EPA0]EPACOD <> "" : End : Endif #FRLAA 2018-06-25 X3-89704

Local Char COUNTER(20)
Local Char COMPTEUR(5)
Local Integer  STAT
Local Integer OK

Filter [F:HRCTR] Where REFNUM = [M:EPA0]REFNUM and CTRNUM = VALEUR Order By CTRDAT
Read [F:HRCTR] Last

[M:EPA0]CTRDAT = [F:HRCTR]CTRDAT


#FRLAA 2018-06-25 X3-89704 - START
#Allow the user to change contracts during creation
If [M:EPA0]EPACOD <> "" : End : Endif
#FRLAA 2018-06-25 X3-89704 - END

If clalev([F:CTR2])=0 : Local File EMPLOCTR [CTR2] : Endif
Filter [CTR2] Where CTRNUM = VALEUR and CTRDAT = [F:HRCTR]CTRDAT
Read [CTR2] First
If !fstat
If clalev([F:TCA])=0    : Local File TABCOUAFF    [TCA]   : Endif
  Call LECTCA(9, STAT) From SUBTCA
  If !STAT
    GMESSAGE = mess(104,117,1)
    GOK = 0 : End
  Else
    COMPTEUR = [F:TCA]CODNUM(17)
  Endif

  Call NUMERO(COMPTEUR, [F:HRCTR]ETRFCY, date$, "", COUNTER, STAT) From SUBANM
  If STAT
    GMESSAGE = mess(104,117,1)-COMPTEUR
    GOK = 0 : End
  Endif
 [M:EPA0]EPACOD = COUNTER
 Affzo [M:EPA0]EPACOD
Endif
End

$LOAD_COLLECTIONS
nolign = 0
Local Integer NI
For NI = 1 To maxtab(I_EPAHEADER.EPADETAILS)
  If I_EPAHEADER.EPADETAILS(NI) <> null and find(I_EPAHEADER.EPADETAILS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
    #SetInstance [M:EPA1] With I_EPAHEADER.EPADETAILS(NI)  #New functionality - Ignore errors on the sub 2016-12-05
    #Source not compiling on U9 - Manual transfer 2017/01/31
    [M:EPA1]ADMCST          = I_EPAHEADER.EPADETAILS(NI).ADMCST
    [M:EPA1]ADMVAL          = I_EPAHEADER.EPADETAILS(NI).ADMVAL
    [M:EPA1]BALFLG          = I_EPAHEADER.EPADETAILS(NI).BALFLG
    [M:EPA1]EPABAL          = I_EPAHEADER.EPADETAILS(NI).EPABAL
    [M:EPA1]EPAREF          = I_EPAHEADER.EPADETAILS(NI).EPAREF
    [M:EPA1]EPATYP          = I_EPAHEADER.EPADETAILS(NI).EPATYP
    [M:EPA1]EPAVARADDPAY    = I_EPAHEADER.EPADETAILS(NI).EPAVARADDPAY
    [M:EPA1]EPAVARADM       = I_EPAHEADER.EPADETAILS(NI).EPAVARADM
    [M:EPA1]EPAVARBAL       = I_EPAHEADER.EPADETAILS(NI).EPAVARBAL
    [M:EPA1]EPAVARINS       = I_EPAHEADER.EPADETAILS(NI).EPAVARINS
    [M:EPA1]HEARNK          = I_EPAHEADER.EPADETAILS(NI).HEARNK
    [M:EPA1]MTHINS          = I_EPAHEADER.EPADETAILS(NI).MTHINS
    [M:EPA1]ORG             = I_EPAHEADER.EPADETAILS(NI).ORG
    [M:EPA1]STRDAT          = I_EPAHEADER.EPADETAILS(NI).STRDAT
    [M:EPA1]WADMVAL         = I_EPAHEADER.EPADETAILS(NI).WADMVAL
  Endif
Next

#Suspensions
For NI = 1 To maxtab(I_EPAHEADER.EPASUSPEND)
  If I_EPAHEADER.EPASUSPEND(NI) <> null and find(I_EPAHEADER.EPASUSPEND(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
    nolign +=1
    #Source not compiling on U9 - Manual transfer 2017/01/31
    #SetInstance [M:EPA3] 5 With I_EPAHEADER.EPASUSPEND(NI)  #New functionality - Ignore errors on the sub 2016-12-05
    [M:EPA3]DATDEBSPD(nolign-1)     = I_EPAHEADER.EPASUSPEND(NI).DATDEBSPD
    [M:EPA3]DATFINSPD(nolign-1)     = I_EPAHEADER.EPASUSPEND(NI).DATFINSPD
    [M:EPA3]INSFLG(nolign-1)        = I_EPAHEADER.EPASUSPEND(NI).INSFLG
    [M:EPA3]ADMCSTFLG(nolign-1)     = I_EPAHEADER.EPASUSPEND(NI).ADMCSTFLG
    [M:EPA3]ACPFLG(nolign-1)        = I_EPAHEADER.EPASUSPEND(NI).ACPFLG
    [M:EPA3]WROFLG(nolign-1)       = I_EPAHEADER.EPASUSPEND(NI).WROFLG
  Endif
Next
[M:EPA3]EPAA3A = nolign

nolign = 0
#Additional payments
For NI = 1 To maxtab(I_EPAHEADER.EPAADDPAY)
  If I_EPAHEADER.EPAADDPAY(NI) <> null and find(I_EPAHEADER.EPAADDPAY(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
    nolign +=1
    #Source not compiling on U9 - Manual transfer 2017/01/31
    #SetInstance [M:EPA3] 10 With I_EPAHEADER.EPAADDPAY(NI)  #New functionality - Ignore errors on the sub 2016-12-05
    [M:EPA3]DATDEB(nolign-1)    = I_EPAHEADER.EPAADDPAY(NI).DATDEB
    [M:EPA3]DATFIN(nolign-1)    = I_EPAHEADER.EPAADDPAY(NI).DATFIN
    [M:EPA3]AMT(nolign-1)      = I_EPAHEADER.EPAADDPAY(NI).AMT
Endif
Next
[M:EPA3]EPAA3B = nolign

Return


