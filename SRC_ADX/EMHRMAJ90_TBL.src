  If dim([F:XXT]LEGID)>0
#    Update[XXT] Where LEGID = "" With LEGID = LDOSLEGMIG
    Update[XXT] With LEGID = LDOSLEGMIG
    Gosub TRACE_LOG
  Endif
Return

$TRACE_LOG
  If fstat Then
    Call ECR_TRACE("EMHRMAJ90_TBL: Failed to re-write",0) From GESECRAN
    STAT = 0 # To be used between function calls if there are any other actions needed?
#    Rollback
  Else
#    Commit
    Local Integer COMPTEUR
    [L]COMPTEUR += adxuprec
    Call ECR_TRACE(THISPROC+" : " +num$(COMPTEUR)+" records processed "+LDOSSIER,0) From GESECRAN
  Endif
Return

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT90 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif
If [F:ADS]MODULE(14)<>2 : End : Endif
Call MAJ_EMHRMAJ90_TBL(APPLI)
End

#######################################################################
# To execute during DOSMAJ90 process (validation of folder)
# call by DOSMAJ90
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(14)<>2 : End : Endif
Call MAJ_EMHRMAJ90_TBL(APPLI)
End

