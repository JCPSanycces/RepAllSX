#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# EMHRMAJ90_TBL  UTI process                                    PAY Module
#                Migration To U12 - Vnext version
#
# ==>  Update LEGISLATION columns with the U9 LEG
#
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  # Check Payroll Module
  If [F:ADS]MODULE(14)<>2 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Update LEGISLATION columns with the U9 LEG") From LECFIC

  Call MAJ_EMHRMAJ90_TBL(WDOSSIER)

  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

Subprog MAJ_EMHRMAJ90_TBL(LDOSSIER)
Value Char LDOSSIER

Local Char DOSLEGMIG(5)
Local Char TABLEARRAY(GLONATB)(1..)
Local Char TABLELEGCOD(5)(1..)
Local Integer STAT : STAT = 1
Local Integer NBRREC, I, NBRTAB
Local Char THISPROC(20) : THISPROC = "EMHRMAJ90_TBL"

  Onerrgo CYCLECHECKERROR

  Call ECR_TRACE("EMHRMAJ90_TBL: Update LEGISLATION columns with the U9 LEG",0) From GESECRAN
  Call ECR_TRACE("EMHRMAJ90_TBL: Start of process on : "+LDOSSIER,0) From GESECRAN

  #Getting the legislaton of the folder based on the activity codes
  DOSLEGMIG = func EMHRMAJ90_LEG.GET_LEG(LDOSSIER)

  Call ECR_TRACE("EMHRMAJ90_TBL: DOSLEGMIG (aka Folder legislation) = " + DOSLEGMIG,0) From GESECRAN
  #Adding all the tables to an array
  Gosub ADD_TABLE_ARRAY_LEG

  #Loop through the tables and call MIGARTE subprog
  Gosub LOOP_TABLE_ARRAY_LEG

  Call ECR_TRACE("EMHRMAJ90_TBL : End of process on : "+LDOSSIER,0) From GESECRAN

End

$CYCLECHECKERROR
  Call ECR_TRACE("Error in EMHRMAJ90_TBL: " + num$(errn)-errmes$(errn)-errm, -1) From GESECRAN

Resume

$ADD_TABLE_ARRAY_LEG
#Add the tables here needed to migrate for legislation
#Index start at 1
  I=0
#  I+=1 : TABLELEGCOD(I) = "LEG"     : TABLEARRAY(I)="ACODNUM"
#  I+=1 : TABLELEGCOD(I) = "DOSLEG"  : TABLEARRAY(I)="ADELIVER"
#  I+=1 : TABLELEGCOD(I) = "TABLEG"  : TABLEARRAY(I)="ADELIVERO"
#  I+=1 : TABLELEGCOD(I) = "DOSLEG"  : TABLEARRAY(I)="ADOSSIER"
