  For I=1 To [L]NBRTAB
    Call MIGRATE_TABLE(THISPROC,DOSLEGMIG,STAT,LDOSSIER,TABLEARRAY(I),TABLELEGCOD(I))
  Next

Return

Subprog MIGRATE_TABLE(THISPROC,LDOSLEGMIG,STAT,LDOSSIER,TABLENAME,TBLLEGCOD)
Value Char LDOSSIER,THISPROC,LDOSLEGMIG,TABLENAME,TBLLEGCOD
Value Integer STAT : STAT = 1

  Call ECR_TRACE(THISPROC +": Table migration - " + TABLENAME + " - Start on : "+LDOSSIER,0) From GESECRAN

#Open your own table - leave =DOSSER and only change the abbreviation ADW - XXX
  If filinfo(filpath("FIL",TABLENAME,"fde",LDOSSIER),0)<=0
    Call ECR_TRACE("EMHRMAJ90_TBL: Table: " + TABLENAME + " does not exist on folder: " + LDOSSIER,0) From GESECRAN
    End
  Endif

  If clalev([F:XXT])=0 : Local File =LDOSSIER+"."+TABLENAME [XXT] : Endif

#  If adxlog = 0
#    Trbegin [XXT]
#  Endif
#Handling the transactions per legislation column
#-----------LEG-----------------------------------------#
  If TBLLEGCOD = "LEG"     : Gosub TRN_LEGCOL_LEG     : Endif
  If TBLLEGCOD = "DOSLEG"  : Gosub TRN_LEGCOL_DOSLEG  : Endif
  If TBLLEGCOD = "TABLEG"  : Gosub TRN_LEGCOL_TABLEG  : Endif
  If TBLLEGCOD = "CODLEG"  : Gosub TRN_LEGCOL_CODLEG  : Endif
  If TBLLEGCOD = "TCH_LEG" : Gosub TRN_LEGCOL_TCH_LEG : Endif
  If TBLLEGCOD = "CAILEG"  : Gosub TRN_LEGCOL_CAILEG  : Endif
  If TBLLEGCOD = "ACTLEG"  : Gosub TRN_LEGCOL_ACTLEG  : Endif
  If TBLLEGCOD = "LEGCLS"  : Gosub TRN_LEGCOL_LEGCLS  : Endif
  If TBLLEGCOD = "LEGLEV"  : Gosub TRN_LEGCOL_LEGLEV  : Endif
  If TBLLEGCOD = "LEGPLF"  : Gosub TRN_LEGCOL_LEGPLF  : Endif
  If TBLLEGCOD = "LEGID"   : Gosub TRN_LEGCOL_LEGID   : Endif

  Close Local File [XXT]

End

$TRN_LEGCOL_LEG
  If dim([F:XXT]LEG)>0
#    Update[XXT] Where LEG = "" With LEG = LDOSLEGMIG
    Update[XXT] With LEG = LDOSLEGMIG
    Gosub TRACE_LOG
  Endif
Return

$TRN_LEGCOL_DOSLEG
  If dim([F:XXT]DOSLEG)>0
#    Update[XXT] Where DOSLEG = "" With DOSLEG = LDOSLEGMIG
    Update[XXT] With DOSLEG = LDOSLEGMIG
    Gosub TRACE_LOG
  Endif
Return

$TRN_LEGCOL_TABLEG
  If dim([F:XXT]TABLEG)>0
#    Update[XXT] Where TABLEG = "" With TABLEG = LDOSLEGMIG
    Update[XXT] With TABLEG = LDOSLEGMIG
    Gosub TRACE_LOG
  Endif
Return

$TRN_LEGCOL_CODLEG
  If dim([F:XXT]CODLEG)>0
#    Update[XXT] Where CODLEG = "" With CODLEG = LDOSLEGMIG
