#############################################################################################
#  Traitement générale pour la gestion des fenêtres de sélection                   
#  Centrale de pesée
#  11/12/2000
#############################################################################################

$ACTION
Case ACTION
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "VERF_TABLE"  : Gosub VERF_TABLE
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "VERF_LISTE"  : Gosub VERF_LISTE
 When Default
Endcase
Return

$SEL_TABLE
Case TABLE
 When "SELSBX"      : Gosub SEL_SELSBX
 When Default
Endcase
Return

$VERF_TABLE
Case TABLE
 When "SELSBX"      : Gosub VERF_SELSBX
 When Default
Endcase
Return

$SEL_LISTE
Case LISTE
 When "XXX"     : Gosub SEL_XXX
 When Default
Endcase
Return

$VERF_LISTE
Case LISTE
 When "XXX"     : Gosub VERF_XXX
 When Default
Endcase
Return

##########################################################################################################################
#                                                                                                                        #
#                                                SELECTIONS TABLE                                                        #
#                                                                                                                        #
##########################################################################################################################
#####################################################################
$SEL_SELSBX
Local Char SZBPCNAM
SZBPCNAM = ""
If !clalev([F:SBX]) : Local File STATIONBOX [SBX] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON : Endif
Local Char CODFIC    : CODFIC = "STATIONBOX"

Default File [SBX]

CRITERE = "1=1"
START   = "STI" #Start doit contenir le nom du champs de clé de l'objet.
ORDRE = "STI"
TIT(0) = "Centrale de pesée" #mess(257,196,2) + SZBPCNAM #Machines chez
NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "STI" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
NBCOL += 1 : COL(NBCOL) = "BOX" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
NBCOL += 1 : COL(NBCOL) = "SBXDES" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV  
Return

$VERF_SELSBX
#Sélection des machines sur une demande de service
Return
#####################################################################


##########################################################################################################################
#                                                                                                                        #
#                                                SELECTIONS LISTE    (Pour exemples, ouvrir TRTCRMSEL)                   #
#                                                                                                                        #
##########################################################################################################################
#####################################################################
$SEL_XXX
Return

$VERF_XXX
Return
#####################################################################

