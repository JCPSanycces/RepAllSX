#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################
Subprog C_FIE(VALEUR)
Variable Char    VALEUR()

Local Integer ICANDISP
ICANDISP = 1

If VALEUR <> ""
    Read [ATZ] CODZONE = "MACHINES";VALEUR
    If fstat
        GMESSAGE = mess(83, 123, 1) #Valeur incorrect.
        GERR = 1
        mkstat = 2
    Else
        #Traitement des exceptions
        Call CHECKFIEMAC(VALEUR, ICANDISP) From SUBMACB

        If !ICANDISP
            #Ce champ ne peut pas être utilisé comme critère d'agrégation.
            GMESSAGE = mess(38, 177, 2)
            GERR = 2
            mkstat = 2
        Endif
    Endif
Endif

End

##########################################################################
Subprog AM_FIE(VALEUR)
Variable Char    VALEUR()

[M:MCC1]FIECLA = ""

If VALEUR <> ""
    Read [ATZ] CODZONE = "MACHINES";VALEUR
    If !fstat
        Call TEXTE([F:ATZ]NOCOURT, [M:MCC1]FIECLA) From OBJDIV    
    Endif
Endif

[M:MCC1]FIE = VALEUR
Affzo [M:MCC1]

End

##########################################################################
Subprog IB_NBLIG

Raz GBOUT1

If [M:MCC2]MACNUM(nolign - 1) <> ""
    Call TEXTE(5562, GBOUT1) From OBJDIV      #Détail
Endif

End

##########################################################################
Subprog C_CNSMCCCPY(VALEUR)
Variable Char    VALEUR()
End

##########################################################################
Subprog C_CNSMCCFCY(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
# -- Controle autorisation sur le site
    If GUSRFCY(1)<>"\" & !find(VALEUR,GUSRFCY(1..GNBAUZ))
        GMESSAGE=VALEUR-mess(2,104,1)   : # Vous n'avez pas les droits sur ce site
        GERR = 2
        mkstat=2
        End
    Endif
    Call GETDEV(VALEUR) From DEVSUB
    [M:MCC1]CNSMCCCPY = GSOCIETE 
    Affzo [M:MCC1]
Else
    If [M:MCC1]CNSMCCCPY <> ""
        Call CONTALLFCY([M:MCC1]CNSMCCCPY) From CPTSUB : # Accès à tous les sites de la société ?
    Endif
Endif

End

##########################################################################
Subprog AM_CNSMCCCPY(VALEUR)
Variable Char    VALEUR()

[M:MCC1]CNSMCCFCY = ""
[M:MCC1]CNSMCCCPY = VALEUR
Affzo [M:MCC1]
End



