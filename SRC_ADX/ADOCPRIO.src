#<AdxTL>@(#)8.0.0.0 $Revision$
Local Char PARAM(10)(1..3) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ADOCPRIO","ADOCPRIO",3,"") From GTRAITE
End

###############################################################
$ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "INIT_DIA"   : Gosub INIT_DIA
 When "CONTROLE"   : Gosub CONTROLE
 When "EXEC"       : Gosub EXEC
 When "SORTIE"     : Gosub SORTIE
Endcase
Return

###################################################################
$INIT
  If clalev([ADO])=0    : Local File  ADOCUMENT [ADO] : Endif
  If clalev([ADZ])=0    : Local File  ADOCFLD   [ADZ] : Endif

  If dim([V]PRIO_OBJ)<0 : Global Char PRIO_OBJ(3)     : Endif
Return

###################################################################
$INIT_DIA
  Raz [M:ADOP], [F:ADO], [F:ADZ]

  # Chargement des 4 paramètres de l'action : Type d'objet appelant / Langue / Type / Code
  [V]PRIO_OBJ= PARAM(1)
  Case [V]PRIO_OBJ
    When "ADO"
      [F:ADO]LAN       = PARAM(2)
      [F:ADO]TYP       = PARAM(3)
      [F:ADO]COD       = PARAM(4)
      Read [ADO]ADO0(3)=
      If !fstat
        [M:ADOP]TYPOBJ = mess(41,176,1)
        #Prise en compte pour toute les langues : On ne prend pas pour l'instant le paramètre LAN
        #[M:ADOP]LANDOC= [F:ADO]LAN
        [M:ADOP]TYPDOC = [F:ADO]TYP
        [M:ADOP]CODDOC = [F:ADO]COD
        If ![F:ADO]PRIO
          [M:ADOP]PRIO = 1
        Else
          [M:ADOP]PRIO = [F:ADO]PRIO
        Endif
      Endif
    When "ADZ"
      [M:ADOP]TYPOBJ   = mess(42,176,1)
      [F:ADZ]LAN       = PARAM(2)
      [F:ADZ]MOTCLE    = PARAM(4)
      Read [ADZ]ADZ0(2)=
      If !fstat
        #Prise en compte pour toute les langues : On ne prend pas pour l'instant le paramètre LAN
        #[M:ADOP]LANDOC  = [F:ADZ]LAN
        [M:ADOP]CODDOC   = [F:ADZ]MOTCLE
        If ![F:ADZ]PRIO
          [M:ADOP]PRIO = 1
        Else
          [M:ADOP]PRIO = [F:ADZ]PRIO
        Endif
      Endif
  Endcase
Return

###################################################################
$CONTROLE
  Case [V]PRIO_OBJ
    When "ADO"
      Read [ADO]ADO0(3)=
      If fstat
        GERR=1  :  GMESSAGE=mess(262,139,1)-"("+[M:ADOP]TYPOBJ+")"  :  FIN=1  :  Return
      Endif
      #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
      If !func AGENLIBA.CONTROLE_GROUPE_OK([V]PRIO_OBJ, [ADO]LAN, [ADO]TYP, [ADO]COD)
        GERR=1 :  FIN=1  :  Return
      Endif
    When "ADZ"
      Read [ADZ]ADZ0(2)=
      If fstat
        GERR=1  :  GMESSAGE=mess(262,139,1)-"("+[M:ADOP]TYPOBJ+")"  :  FIN=1  :  Return
      Endif
      #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
      If !func AGENLIBA.CONTROLE_GROUPE_OK([V]PRIO_OBJ, [ADZ]LAN, "", [ADZ]MOTCLE)
        GERR=1 :  FIN=1  :  Return
      Endif
    When Default
      GERR=1    :  GMESSAGE=mess(262,139,1)                         :  FIN=1  :  Return
  Endcase
Return

###################################################################
$EXEC
Local Char CRITERE(250) , CLEADO(30)(0..3), OLDLAN(GLONLAN)

  Call DEBTRANS From GLOCK

  CRITERE = ""
  Case [V]PRIO_OBJ
    When "ADO"
      #Prise en compte pour toute les langues : On ne prend pas pour l'instant le paramètre LAN
      #CRITERE += 'LAN="'+[M:ADOP]LANDOC+'"'
      If CRITERE<>"" : CRITERE += "&" : Endif
      CRITERE += 'TYP="'+[M:ADOP]TYPDOC+'"'
      If CRITERE<>"" : CRITERE += "&" : Endif
      CRITERE += 'COD="'+[M:ADOP]CODDOC+'"'

      # Transaction de MAJ des Documentation impactées par les critères.
      Gosub TR1_ADO
    When "ADZ"
      #Prise en compte pour toute les langues : On ne prend pas pour l'instant le paramètre LAN
      #CRITERE += 'LAN="'+[M:ADOP]LANDOC+'"'
      If CRITERE<>"" : CRITERE += "&" : Endif
      CRITERE += 'MOTCLE="'+[M:ADOP]CODDOC+'"'

      # Transaction de MAJ des Documentation impactées par les critères.
      Gosub TR1_ADZ
    When Default
  Endcase
Return

###################################################################
$SORTIE
  Kill [V]PRIO_OBJ
Return

###################################################################
$TR1_ADO
Trbegin [ADO]

  Filter [ADO] Where evalue(CRITERE)
  For [ADO]ADO0(3)
    For [ADO]ADO0
      [F:ADO]PRIO=[M:ADOP]PRIO
      Rewrite [ADO]
      If fstat
        GOK = 0 : Call FSTA("ADO") From GLOCK : Break 2
      Endif
    Next ADO

    Gosub TRACE_COR_ADO
  Next ADO(3)
  Filter [ADO]

  If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$TR1_ADZ
Trbegin [ADZ]

  Filter [ADZ] Where evalue(CRITERE)
  For [ADZ]ADZ0
    [F:ADZ]PRIO=[M:ADOP]PRIO
    Rewrite [ADZ]
    If fstat
      GOK = 0 : Call FSTA("ADZ") From GLOCK : Break
    Endif

    Gosub TRACE_COR_ADZ
  Next ADZ
  Filter [ADZ]

  If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
  Rollback
Return

$TRACE_COR_ADO
    # Tracage des corrections car on est pas sur l'objet ADO pour lequel la gestion est automatique.
    ###If find(nomap(0),"SUPERV6","SUPERV","SUPERV150")
    If GADONIX=2
      CLEADO(0) = [F:ADO]LAN
      CLEADO(1) = [F:ADO]COD
      Call TRACE_COR("ADO",[F:ADO]TYP,CLEADO,"M")              From AGENLIBA
    Endif

    # MAJ des Environnements d'Indus pour les différents produits.
    Call MAJ_ENVINDUS_DOC ([F:ADO]LAN,[F:ADO]TYP,[F:ADO]COD,2) From AGENREM : # SI024 94779_1 TCH : Split AGENLIBA + Trace dans remontée des traductions
Return

$TRACE_COR_ADZ
    # Tracage des corrections car on est pas sur l'objet ADZ pour lequel la gestion est automatique.
    ###If find(nomap(0),"SUPERV6","SUPERV","SUPERV150")
    If GADONIX=2
      Call TRACE_COR("ADZ",[F:ADZ]MOTCLE,[F:ADZ]LAN,"M") From AGENLIBA
    Endif

    # MAJ des Environnements d'Indus pour les différents produits.
    Call MAJ_ENVINDUS_FLD ([F:ADZ]LAN,[F:ADZ]MOTCLE)     From AGENREM : # SI024 94779_1 TCH : Split AGENLIBA + Trace dans remontée des traductions
Return
