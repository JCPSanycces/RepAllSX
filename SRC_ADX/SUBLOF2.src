#<AdxTL>@(#)10.0.0.0 $Revision$
################################################################################
# CREATION DE LA DEPENSE A PARTIR D'UNE FACTURE ACHAT OU TIERS FOURNISSEUR
#                        A PARTIR D'UNE PIECE COMPTABLE
#    GLE
#    Création le : 01/10/2008
################################################################################
#
#    Modifications
# Issue X3-89474 - 2018-07-30 MDJ : Expense created on a non financial site after a stock issue
# Issue X3-83776 - 2018-04-13 MDJ : Expense generated via (CPTVAL) shows an incorrect company currency
# MDJ   19.07.2017  X3-45308    No currency rate on Expense from Journal import
# MDJ   03.03.2017  121664      Mauvais signe sur dépense issue d'une facture d'avoir (1 ligne+répartition analytique)
# CBO   22.12.2016  119659      GDECRCU used for calculing rate
# MDJ   13.12.2016  120121      Error on currency rate of expense created from Journal entry
# CBO   22.09.2016  118031      Expenses with special character
# MDJ   02.08.2016  117536      Sections remise à blanc à tort
# MDJ   13.06.2016  116402      TVA intracommunautaire - les montants TVA doivent être nuls sur la dépense
# MDJ   26.11.2015  FQ112686  : Global validation + currency = no rate applied in the expenses
# MDJ   04.08.2015  FQ 110082 : FLGIAS not tested and ACCLIN can be equal to 0
# MDJ   20.04.2015  FQ102691  : FA Expense creation on stock issue
# GLE   07.05.2015  FQ108144  : La table ACTIV n'est pas ouverte lorsque la validation de facture achat est appelée en massif
# GLE   20.03.2015  FQ107113  : Erreur en validation de facture achat si plus de 9 éléments de facturation
# MDJ   16.03.2015  FQ106882  : Paramètre VATAUTVAL : définition au niveau société non prise en compte
# MDJ   09.02.2015  FQ100398  : Suppression site géographique
# GLE   08.12.2014  FQ104498  : Site financier erroné sur la dépense
# GLE   02.12.2014  FQ96016   : Gestion des éléments de facturation dans les demandes d'achat
# CBO   28.11.2014  FQ104360  : Unlinked expense when balance sht val is changed
# MDJ   30.10.2014  FQ68023   : GER - Reduction of acquisition and production costs
# MWA   27.10.2014  FQ103398  : Quantité par défaut à 1 pour les dépenses issues de factures tiers
# GLE   07.10.2014  FQ102796  : Gestion des factures de type Note de débit et Note de crédit
# GLE   25.06.2014  FQ102396  : Le type de facture n'est pas renseigné dans les dépenses issues de factures tiers fournisseur
# MDJ   16.06.2014  FQ98116   : Deductible VAT recalculated when capitalizing Expense
# MDJ   19.08.2014  FQ102148  : Division by 0 error
# GLE   25.06.2014  FQ99885   : Le montant récupéré sur les pièces en validation directe doit être considéré comme un montant HT + TVA - TVArec
# GLE   05.06.2014  FQ100587  : La date de référence pour la récupération des taux passe de DATIMP à DATVCR
# GLE   09.07.2013  FQ90615   : Correction problème de valorisation erronée des depenses suite au lancement successif de CPTVAL
# GLE   16.04.2013  FQ88945   : Prise en compte de la ventilation analytique manuelle dans les factures tiers et les pièces
# CBO   26.12.2012  FQ86455   : Désignation venant de la facture tiers
# GLE   11.12.2012  FQ86521   : OD - Erreur DIE(20) indice incorrect si la somme des axes des référentiels du modèle > 20
# CBO   31.10.2012  FQ84796   : Gestion correcte du site financier (factures d'achat)
# GLE   15.10.2012  FQ85201   : Gestion correcte du site géographique
# GLE   24.09.2012  FQ84734   : Factures achat et tiers fournisseur : prise en compte du taux diviseur
# GLE   21.09.2012  FQ83883   : Suppression des dépenses si annulation de facture
# GLE   11.07.2012  FQ83288   : Erreur si message d'erreur lors de la validation massive des pièces comptables
# GLE   23.04.2012  FQ81533   : Mise au propre des transformations de type de dépense et de signe des montants
# GLE   10.11.2011  FQ77257   : correction montant négatifs si facture négative
# MDJ   10.11.2011  FQ77295   : récupération du site de la ligne facture (cas d'une dépense inter-sites)
# GLE   06.09.2011  FQ75672   : gestion des montants forcés en devise
# GLE   17.03.2011  FQ69212   : amélioration de la récupération du code fournisseur
# GLE   15.02.2011  FQ71607   : non création de dépense à tort si pas IAS, compte social suivi et article non suivi
# GLE   04.01.2011  FQ70141   : correction dans un message d'erreur lors de la lecture du code TVA
# GLE   09.12.2010  FQ69770   : correction suite à une erreur lors des extourne car PARAM est déjà déclaré
# GLE   20.09.2010  FQ67340   : création des dépenses en validation massive des pièces (CPTVAL)
# GLE   20.07.2010  FQ65625   : Certification NF - Flux OD -> dépense
# GLE   06.07.2010  FQ63306   : création de la dépense si le type de pièce est coché "Création dépense"
# GLE   05.05.2010  FQ57785   : validation automatique de la TVA récupérée de la dépense si paramètre VATAUTVAL à Oui ou si legislation non française
# GLE   12.01.2010  FQ61524   : erreur compte inexistant si partage du même plan de compte entre Social et IAS et qu'un des comptes n'est pas renseigné
# GLE   07.12.2009  FQ60673   : erreur "[M:HAE0] Classe inexistante" en saisie de pièce 1 page
# GLE   19.06.2009  FQ55977   : si le compte PCG n'est pas suivi et qu'il n'y a pas de compte IAS -> on passe la ligne
################################################################################
End

################################################################################
# CREATION DE LA DEPENSE A PARTIR D'UN OBJET :
# Facture Achat (TRTACHFAC1)
# Facture Tiers fournisseur (SUBBIS)
# Pièce comptable (SUBGAS)
# pièce comptable validation batch (CPTVAL)
# Ligne de règlement (PAYCPTA)
# Ligne de sortie de stock (FUNSTKACC)
#
Subprog CREDEP(OBJORI, RMESSAGE)
Value    Char OBJORI      : # Objet d'origine :
                            # "PIH" = facture achat,
                            # "BIS" = facture tiers fournisseur,
                            # "HAE" = pièce comptable,
                            # "VAL" = pièce comptable validation batch
                            # "PYD" = Payment line       #*FQ68023
                            # "STJ" = Stock issue        #*FQ102691
Variable Char RMESSAGE

  Local Integer  RET
  Local Integer  N_I, N_J, N_K, N_L, NUMLIG
  Local Integer  OK
  Local Shortint FLGEXPCRE(1..2)
  Local Char     GACACC(20), GACIAS(20)
  Local Shortint NB_LOF  : # Nombre de dépenses créées
  Local Integer  LIGNE        : LIGNE = 0
  Local Decimal  MNT
  Local Char     LCPY, LPARAM : # FQ69770 : PARAM -> LPARAM

  # Récupération des taux de TVA
  Local Date     DAT
  Local Char     COMPANY
  Local Char     TAX
  Local Integer  STAT
  Local Decimal  TAUX1, TAUX2

  Local Char     DEFUOM     : # Unité par défaut
  Local Integer  VATAUTVAL  : # Validation automatique de la TVA récupérée de la dépense FQ57785

  # Déclarations
  Local   Char DBGSTR_SAV(255) : DBGSTR_SAV = dbgstr(1)
  Local   Mask FASPARCPY [FPC] : # Masque de travail contenant le modèle comptable de la société
  Default Mask DBGSTR_SAV

  If !clalev([F:TPV])  : Local File TABPIVTYP  [TPV]  : Endif
  If !clalev([F:CAL])  : Local File CPTANALIN  [CAL]  : Endif
  If !clalev([F:PIA])  : Local File BPSINVLIGA [PIA]  : Endif
  If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif
  If !clalev([F:CAC])  : Local File GACCCODE   [CAC]  : Endif
  If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
  If !clalev([F:GCM])  : Local File GACM       [GCM]  : Endif
  If !clalev([F:LOF])  : Local File LAYOUTFAS  [LOF]  : Endif
  If !clalev([F:SLOF]) : Local File LAYOUTFAS  [SLOF] : Endif
  If !clalev([F:LOFP]) : Local File LAYOUTFAS  [LOFP] : Endif    : # FQ68023
  If !clalev([F:PYA])  : Local File PAYMENTA   [PYA]  : Endif    : # Analytical payment lines  FQ68023
  If !clalev([F:TRA])  : Local File TABRATVAT  [TRA]  : Endif
  If !clalev([F:ITM])  : Local File ITMMASTER  [ITM]  : Endif
  If !clalev([F:RDE])  : Local File RUBASSDEF  [RDE]  : Endif   : # Associations : définition
  If !clalev([F:RVA])  : Local File RUBASSVAL  [RVA]  : Endif   : # Associations : valeurs
  If !clalev([F:ZATZ]) : Local File ATABZON    [ZATZ] : Endif   : # Tables : rubriques
  If !clalev([F:ZATY]) : Local File ATYPE      [ZATY] : Endif   : # Types
  If !clalev([F:TVT])  : Local File TABVAT     [TVT]  : Endif   : # Table des taxes pour multi-leg
  If !clalev([F:ACV])  : Local File ACTIV      [ACV]  : Endif   : # Table des codes activité FQ108144
  If !clalev([F:TVB])  : Local File TABVACBPR  [TVB]  : Endif   : # Issue 116402 : régimes de taxe
  If !clalev([F:FCY])  : Local File FACILITY   [FCY]  : Endif   : # X3-89474 : sites

  Raz [F:LOF]

  If [L]OBJORI="PIH" or [L]OBJORI="BIS"
    [L]LCPY = [F:PIH]CPY
  Elsif [L]OBJORI="HAE"
    [L]LCPY = [M]CPY     : # FQ60673
  Elsif [L]OBJORI="VAL"
    [L]LCPY = [F:HAE]CPY : # FQ67340
  Elsif [L]OBJORI="PYD"
    [L]LCPY = [F:PYH]CPY : # FQ68023
  Elsif [L]OBJORI="STJ"
    [L]LCPY = [F:SJT]CPY : # FQ102691 STJTMP [F:SJT]Journal des Stocks-Interface
  Endif

  # Chargement du masque de travail contenant le paramétrage comptable de la société
  Call LOAD_FASPARCPY([L]LCPY,"",G_NON,RET) From GLOFCYCPY
  If RET : RMESSAGE=[L]LCPY-mess(198,105,1)-num$(RET) : Gosub TRAITE_ERREUR : End : Endif

  # Lecture de la société
  Call LECTURE("CPY",[L]LCPY,"") From CONTOBJ

  # Lecture de l'unité par défaut
  Call PARAM("","DEFUOM",[L]DEFUOM) From ADOVAL

  # Validation automatique de la dépense FQ57785 : Chapitre= AAS/Groupe=VAT
  #-FQ106882 Call PARAM("","VATAUTVAL",[L]LPARAM) From ADOVAL : # FQ69770 : PARAM -> LPARAM
  Call PARAM([L]LCPY,"VATAUTVAL",[L]LPARAM) From ADOVAL
  [L]VATAUTVAL = val([L]LPARAM)                    : # FQ69770 : PARAM -> LPARAM

  Case [L]OBJORI
    When "PIH" : Gosub ALIM_PIH     : # FACTURE ACHAT
    When "BIS" : Gosub ALIM_BIS     : # FACTURE TIERS FOURNISSEUR
    When "HAE" : Gosub ALIM_GAS     : # PIECE COMPTABLE
    When "VAL" : Gosub ALIM_GAS_VAL : # PIECE COMPTABLE EN VALIDATION DEFINITIVE  FQ67340
    When "PYD" : Gosub ALIM_PYD     : # PAYMENT LINE                              FQ68023
    When "STJ" : Gosub ALIM_STJ     : # STOCK ISSUE                               FQ102691
  Endcase

  If GOK and [L]NB_LOF > 0
    Call ECR_TRACE(num$([L]NB_LOF)-mess(141,104,1),0) From GESECRAN
  Elsif !GOK
    GMESSAGE = RMESSAGE
  Endif

  Close Local Mask [FPC]
End

###################
#  FACTURE ACHAT  #
###################
$ALIM_PIH

  #----------------------------------------------
  # FQ96016 : Gestion des éléments de facturation
  #----------------------------------------------
  # Un élément de facturation est un montant facturé ou un avoir en plus des montants des lignes. Il peut représenter des frais
  # de port, un escompte, etc.. Il est possible d'en avoir jusqu'à 9 sur une facture achat X3, et il faut les prendre en compte
  # lors de la création des dépenses.
  #
  # Il existe deux cas à considérer pour chaque élément de facturation :
  #   - le montant de l'élément de facturation est à prendre dans son intégralité pour créer une dépense, il est imputé sur le compte
  #     indiqué dans le tableau des éléments de facturation. Les tables mises en oeuvre sont PVCRFOOT et CPTANALIN.
  #   - le montant est ventilé sur les lignes et s'ajoute (ou se retranche) du montant de la ligne. Il est de fait imputé sur le compte
  #     de la ligne. Les tables mises en oeuvre sont PINVOICED et CPTANALIN.
  #
  # Pour connaitre le cas a appliquer, il faut croiser des informations du type de facture (champ FASDSPLIN table TABPIVTYP) et
  # du type d'élément de facturation (champ DSPLIN table PFOOTINV) :
  #   - si FASDSPLIN est à 1 (Pas de répartition) -> 1 dépense pour le montant total de l'élément de facturation
  #   - sinon
  #     - si DSPLIN est à 1 (Pas de répartition) -> 1 dépense pour le montant total de l'élément de facturation
  #     - sinon le montant réparti est ajouté au montant de la ligne
  # Pour chaque type le cas est stocké dans la structure FOOTINVDSP

  # Lecture du code activité PFI qui dimensionne le tableau des éléments de facturation FQ107113
  Local Integer PFIVAL : # Valeur du code activité de dimensionnement PFI
  Call LECTURE("ACV","PFI","") From CONTOBJ
  PFIVAL = [F:ACV]DIME

  # Utilisation de la valeur du code activité PFI pour les structures de travail FQ107113
  Local Shortint FOOTINVDSP(PFIVAL)          : # Permet de savoir si l'élément de facturation est :
                                               #   0 - Non géré
                                               #   1 - Géré non ventilé
                                               #   2 - Géré ventilé
  Local Char     FOOTINVTAX(GLONVAT)(PFIVAL) : # Code taxe associé (FQ107113 inversion des dimensions)
  Local Integer  FOOTINVIND(PFIVAL)          : # Dans le cas d'une ventilation, indice du champ DISCRGAMT sur la ligne de facture

  If !clalev([F:PVF]) : Local File PVCRFOOT  [PVF] : Endif : # Table des éléments de facturation de la facture

  # Lecture du type de facture
  #-- X3suivi 71937 - T249 : Multi-Leg--#
  #Call LECTURE("TPV",[F:PIH]PIVTYP,"") From CONTOBJ
  Local Integer WRET
  Local Char    WLEG (20)
  Call GETLEG([F:PIH]CPY,"G",WLEG) From TRTLECLEG
  Call LEC_TPV_LEG(WLEG,[F:PIH]PIVTYP,WRET) From TRTLECLEG

  # Initialisation à "Non géré" des éléments de facturation, à blanc les code taxe, à zéro les indices de ligne
  Raz FOOTINVDSP, FOOTINVTAX, FOOTINVIND

  # FQ96016
  Local Integer N_J : N_J = 1
  For [F:PVF]PVF0 Where VCRNUM=[F:PIH]NUM
    If ([F:TPV]FASDSPLIN = 2)
      FOOTINVDSP([F:PVF]IND-1) = 1 : # géré dans son intégralité (non ventilé) -> une dépense sera créé pour
                                     # cet élément de facturation
    Else
      If [F:PVF]INVLINFLG = 1
        FOOTINVDSP([F:PVF]IND-1) = 1 : # géré dans son intégralité (non ventilé) -> une dépense sera créé pour
                                       # cet élément de facturation
      Else
        FOOTINVDSP([F:PVF]IND-1) = 2 : # géré ventilé -> le montant ventilé se trouve directement sur chaque
                                       # ligne et devra être cumulé au montant de la ligne
        FOOTINVTAX([F:PVF]IND-1) = [F:PVF]INVDTAVAT
        FOOTINVIND([F:PVF]IND-1) = N_J
        N_J += 1
      Endif
    Endif
  Next

  [F:LOF]           = [F:PIH]

  # Issue 118031
  If func SUBLOF2.CTL_FMT("LAYOUTFAS", "CODLOF", [F:PIH]NUM, RMESSAGE) = 0
    GOK = 0
    Return
  Endif
  # End Issue 118031

  [F:LOF]CODLOF     = [F:PIH]NUM              : # Numéro de pièce
  [F:LOF]DATVCR     = [F:PIH]BPRDAT           : # Date d'achat
  [F:LOF]DATIMP     = [F:PIH]ACCDAT           : # Date d'imputation comptable

  # FQ102796
  #[F:LOF]TYPVCR     = [F:TPV]INVTYP           : # Type de document. Ce type pourra être modifié si montants négatifs
  [F:LOF]TYPVCR     = func SUBLOF2.GET_TYPVCR_FROM_INVTYP([F:TPV]INVTYP)

  If GDECRCU # Issue 119659
    [F:LOF]RATCUR     = arr([F:PIH]RATMLT(0)/[F:PIH]RATDIV(0), 10^-GDECRCU)
  Else
    [F:LOF]RATCUR     = [F:PIH]RATMLT(0)/[F:PIH]RATDIV(0)       : # FQ84734 : division par le taux diviseur
  Endif # End Issue 119659
  [F:LOF]DES        = mess([F:TPV]INVTYP,645,1)-[F:PIH]BPRNAM

  [F:LOF]FLGGRA     = 1                                       : # Flag subventionnée
  [F:LOF]FLGAMTGRA  = 1                                       : # Flag Force Mt subvention
  [F:LOF]FLGLIKAAS  = 1                                       : # Flag liaison Bien
  [F:LOF]FLGLOFMAI  = 1                                       : # Flag dépense principale
  [F:LOF]FLGDETEXP  = G_OUI                                   : # détachable Flag FQ104360

  # Si c'est un avoir, on stocke sur DES2 le numéro de facture à laquelle il se rapporte
  If find([F:PIH]INVTYP,2,4)
    If [F:PIH]INVNUM <> ""
      [F:LOF]DES2 = mess(6,159,1)-":"-[F:PIH]INVNUM           : # Référence : <numéro de facture>
    Else
      [F:LOF]DES2 = mess(9,119,1)                             : # Avoir sans numéro de facture
    Endif
  Endif

  # Sauvegarde des informations communes à toutes les lignes
  [F:SLOF] = [F:LOF]

  For [F:PID]PID0 Where NUM=[F:PIH]NUM
    # Initialisation de la classe avec les informations communes à toutes les lignes
    [F:LOF] = [F:SLOF]

    # Récupération des comptes et des sections dans la table CPTANALIN
    Read [CAL]CAL0="PID";0;[F:PID]NUM;[F:PID]PIDLIN;0;"";1
    If fstat
      # Aucune imputation comptable... On passe à la ligne suivante
      Goto SUITE_PID
    Else
      [L]GACACC = [F:CAL]ACC([M:FPC]GENLEDTYP-1)
      If [M:FPC]FLGIAS = G_OUI
        [L]GACIAS = [F:CAL]ACC([M:FPC]IASLEDTYP-1)
      Endif
    Endif

    # Lecture des comptes à partir de [L]GACACC et [L]GACIAS
    Gosub CHARGE_COMPTES
    If fstat : Break : Endif

    # Lecture de l'article
    If [F:PID]ITMREF<>""
      Call LECTURE("ITM",[F:PID]ITMREF,"") From CONTOBJ
    Else
      Raz [F:ITM]
      [F:ITM]FLGFAS = G_OUI
    Endif

    ### CONTROLES DE COHERENCE ###

    If [F:PID]ITMREF<>""
      # Article sur la ligne

      # Article immobilisable et comptes non suivis dans Abel : avertissement
      If ([M:FPC]FLGIAS  =  G_OUI and [F:ITM]FLGFAS = G_OUI and ([L]FLGEXPCRE(1)<> G_OUI and [L]FLGEXPCRE(2)<> G_OUI))
&     or ([M:FPC]FLGIAS  <> G_OUI and [F:ITM]FLGFAS = G_OUI and  [L]FLGEXPCRE(1)<> G_OUI)
        If dim([M]XCPYFLG)<0 : # Pour savoir si on est en interactif ou en validation massive
          # Aucune dépense ne sera créée pour la ligne <LIGNE> : Comptes social et IAS non immobilisables et article immobilisable. Voulez-vous continuer ?
          Call OUINON(mess(72,7772,1)-num$([F:PID]PIDLIN)-":"-mess(73,7772,1)-"("+[F:ITM]ITMREF+")."-mess(205,100,1),OK) From GESECRAN
          If OK<>2
            RMESSAGE=num$([F:PID]PIDLIN)-":"-mess(73,7772,1)-"("+[F:ITM]ITMREF+")." : Gosub TRAITE_ERREUR : Break
          Else
            Goto SUITE_PID
          Endif
        Else
          RMESSAGE=num$([F:PID]PIDLIN)-":"-mess(73,7772,1)-"("+[F:ITM]ITMREF+")." : Gosub TRAITE_ERREUR : Break
        Endif
      Endif

      # Article non immobilisable et comptes suivis dans Abel : avertissement
      If ([M:FPC]FLGIAS =  G_OUI and [F:ITM]FLGFAS <> G_OUI and ([L]FLGEXPCRE(1)= G_OUI and [L]FLGEXPCRE(2)= G_OUI))
&     or ([M:FPC]FLGIAS <> G_OUI and [F:ITM]FLGFAS <> G_OUI and  [L]FLGEXPCRE(1)= G_OUI)
        If dim([M]XCPYFLG)<0 : # Pour savoir si on est en interactif ou en validation massive
          # <LIGNE> Comptes social et IAS immobilisables et article non immobilisable. Voulez-vous créer la dépense à la validation ?
          Call OUINON(mess(17,104,1)-[F:PIH]NUM-num$([F:PID]PIDLIN)-":"-mess(74,7772,1)-"("+[F:ITM]ITMREF+")."-mess(75,7772,1),OK) From GESECRAN
          If OK<>2
            Goto SUITE_PID
          Endif
        Else
          RMESSAGE=num$([F:PID]PIDLIN)-":"-mess(74,7772,1)-"("+[F:ITM]ITMREF+")." : Gosub TRAITE_ERREUR : Break
        Endif
      Endif

      # Article non immobilisable et comptes non suivis dans Abel : pas de dépense à créer

      If ([M:FPC]FLGIAS =  G_OUI and [F:ITM]FLGFAS <> G_OUI and [L]FLGEXPCRE(1)<> G_OUI and [L]FLGEXPCRE(2)<> G_OUI)
&     or ([M:FPC]FLGIAS <> G_OUI and [F:ITM]FLGFAS <> G_OUI and [L]FLGEXPCRE(1)<> G_OUI)
#&     or ([M:FPC]FLGIAS <> G_OUI and [F:ITM]FLGFAS <> G_OUI) : # FQ71607
        Goto SUITE_PID
      Endif
    Else
      # Pas d'article sur la ligne

      # Aucun compte suivi : on ne fait rien
      If ([M:FPC]FLGIAS =  G_OUI and [L]FLGEXPCRE(1)<> G_OUI and [L]FLGEXPCRE(2)<> G_OUI)
&     or ([M:FPC]FLGIAS <> G_OUI and [L]FLGEXPCRE(1)<> G_OUI)
        Goto SUITE_PID
      Endif
    Endif

    # Un seul compte suivi : avertissement
    If ([M:FPC]FLGIAS = G_OUI) and ([L]FLGEXPCRE(1)<> G_OUI and [L]FLGEXPCRE(2)=  G_OUI)
      If dim([M]XCPYFLG)<0 : # Pour savoir si on est en interactif ou en validation massive
        # Aucune dépense ne sera créée pour la ligne ### : Compte social non suivi et compte IAS suivi. Voulez-vous continuer ?
        Call OUINON([F:PIH]NUM-mess(72,7772,1)-num$([F:PID]PIDLIN)-":"-mess(77,7772,1)-mess(205,100,1),OK) From GESECRAN
        If OK<>2
          RMESSAGE=num$([F:PID]PIDLIN)-":"-mess(77,7772,1) : Gosub TRAITE_ERREUR : Break
        Else
          Goto SUITE_PID
        Endif
      Else
        RMESSAGE=num$([F:PID]PIDLIN)-":"-mess(77,7772,1) : Gosub TRAITE_ERREUR : Break
      Endif
    Endif

    If ([M:FPC]FLGIAS = G_OUI ) and ([L]FLGEXPCRE(1)= G_OUI and [L]FLGEXPCRE(2)<>  G_OUI)
      If dim([M]XCPYFLG)<0 : # Pour savoir si on est en interactif ou en validation massive
        # Aucune dépense ne sera créée pour la ligne ### : Compte social suivi et compte IAS non suivi. Voulez-vous continuer ?
        Call OUINON([F:PIH]NUM-mess(72,7772,1)-num$([F:PID]PIDLIN)-":"-mess(78,7772,1)-mess(205,100,1),OK) From GESECRAN
        If OK<>2
          RMESSAGE=num$([F:PID]PIDLIN)-":"-mess(78,7772,1) : Gosub TRAITE_ERREUR : Break
        Else
          Goto SUITE_PID
        Endif
      Else
        RMESSAGE=num$([F:PID]PIDLIN)-":"-mess(78,7772,1) : Gosub TRAITE_ERREUR : Break
      Endif
    Endif

    ### FIN DES CONTROLES DE COHERENCE ###

    If [F:PID]ITMDES1<>""
      [F:LOF]DES     = [F:PID]ITMDES1
    Endif

    [F:LOF]ORDBUY    = [F:PID]POHNUM
    [F:LOF]ITMREF    = [F:PID]ITMREF
    [F:LOF]UOM       = [F:PID]UOM
    If [F:LOF]UOM = ""
      [F:LOF]UOM = [L]DEFUOM  : # Unité par défaut
    Endif
    [F:LOF]QTY       = [F:PID]QTYUOM

    # Taux de TVA et TVA récupérée
    [L]TAX           = [F:PID]VAT
    Gosub LEC_VAT
    If [L]STAT : GOK = 0 : Break : Endif
    Gosub INI_2008_VAT

    # Montants en devise facture
    [F:LOF]AMTNOTCUR  = [F:PID]AMTNOTLIN
    [F:LOF]AMTVATCUR  = [F:PID]AMTTAXLIN1
    [F:LOF]AMTVATRCUR = [F:PID]DEDTAXLIN1

    # FQ96016 : ajout des éléments de facturation ventilés
    Local Integer N_I
    Decimal AMTVAT, AMTRVAT
    For N_I = 1 To 9
      If FOOTINVDSP(N_I-1) = 2
        [F:LOF]AMTNOTCUR  += evalue("[F:PID]DISCRGAMT"+num$(FOOTINVIND(N_I-1)))
        If FOOTINVTAX(N_I-1) <> ""
          [L]TAX = FOOTINVTAX(N_I-1)
          Gosub LECTAX From SUBTVT

          [L]AMTVAT = evalue("[F:PID]DISCRGAMT"+num$(FOOTINVIND(N_I-1))) * [L]TAUX1 / 100
          Call ARRDEV([L]AMTVAT,[F:PIH]CUR) From TRTDIV

          [L]AMTRVAT = [L]AMTVAT * [L]TAUX2 / 100
          Call ARRDEV([L]AMTRVAT,[F:PIH]CUR) From TRTDIV

          [F:LOF]AMTVATCUR  += AMTVAT
          [F:LOF]AMTVATRCUR += AMTRVAT
        Endif
      Endif
    Next

    Gosub PUT_FLG_FORCE
    Gosub AMT_CPY
    Gosub AVOIR_AMT

    # Imputations analytiques
    # Dans une facture achat, on a une et une seule ligne dans CPTANALIN par ligne de facture, sur laquelle
    # on trouve soit une répartition a priori soit des imputations analytiques
    [F:LOF]DSP    = [F:CAL]DSP
    For N_I=0 To dim(GDIE)-1
      [F:LOF]DIE(N_I) = [F:CAL]DIE(N_I)
      [F:LOF]CCE(N_I) = [F:CAL]CCE(N_I)
    Next

    # Famille comptable
    If [F:PID]ITMREF<>""
      [F:LOF]ACGGRP = func GLOBIENS.GET_FAMILLE_ARTICLE ([F:ITM]ITMREF, [M:FPC]LEG)
      If [F:LOF]ACGGRP <> ""
        Gosub GERER_ASSOCIATION
        If [L]RET
          [L]LIBERR = mess(124,104,1)-"("+[F:LOF]ACGGRP+")" : # Erreur dans les associations AbelX3 (Famille)
          GOK=0
        Endif
      Endif
    Endif

    [F:LOF]CPMCREORI  = 1                                       : # Origine complément X3 Achat
    [F:LOF]LIGORI     = [F:PID]PIDLIN
    [F:LOF]TYPORI     = ""

    # DEBUT FQ104498
    If ([F:PID]FCYLIN = "")
      # Le site de la ligne n'est pas renseigné, on prend celui de l'en-tête
      [F:LOF]FCY = [F:PID]FCY
    Else
      # Le site de la ligne est renseigné, on regarde si c'est un site financier
      If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif
      If ([F:FCY]FCY <> [F:PID]FCYLIN)
        Read [FCY]FCY0=[F:PID]FCYLIN
        If fstat
          # Ne devrait jamais arriver
          Raz [F:FCY]
        Endif
      Endif
      If [F:FCY]FCY = ""
        # Cas normalement impossible, le site de la ligne est renseigné mais n'est pas dans la table FACILITY
        [F:LOF]FCY    = [F:PID]FCY
      Elsif [F:FCY]FINFLG = G_OUI
        # Le site de la ligne est un site financier, on le prend
        [F:LOF]FCY    = [F:PID]FCYLIN
      Else
        # Le site de la ligne n'est pas un site financier, on prend son site financier de rattachement
        [F:LOF]FCY    = [F:FCY]FINRSPFCY
      Endif
    Endif
    # FIN FQ104498

    Gosub ECRIRE_DEP

    If !GOK : Break : Endif

$SUITE_PID
  Next

  # FQ96016 Création des dépenses pour les éléments de facturation non ventilés
  If GOK
    Gosub VCRFOOT
  Endif
Return

#---------------------------------------------- FQ96016
# Gestion des éléments de facturation
#----------------------------------------------
$VCRFOOT
  # FQ96016 Création des dépenses pour les éléments de facturation non ventilés
  Local Integer N_PVF
  For N_PVF = 1 To 9
    If FOOTINVDSP(N_PVF-1) = 1
      # Initialisation de la classe avec les informations communes à toutes les lignes
      [F:LOF] = [F:SLOF]

      # Lecture de la table des éléments de facturation PVCRFOOT
      Read [F:PVF]PVF0 = [F:PIH]NUM;8;N_PVF
      If fstat
        # Cas improbable puisqu'on a réussi à lire l'enregistrement en début de traitement.
        # On passe à la ligne suivante
        Goto SUITE_PVF
      Endif

      # Récupération des comptes et des sections dans la table CPTANALIN
      Read [CAL]CAL0="PVF";8;[F:PID]NUM;0;N_PVF;"";1
      If fstat
        # Aucune imputation comptable... On passe à la ligne suivante
        Goto SUITE_PVF
      Else
        [L]GACACC = [F:CAL]ACC([M:FPC]GENLEDTYP-1)
        If [M:FPC]FLGIAS = G_OUI
          [L]GACIAS = [F:CAL]ACC([M:FPC]IASLEDTYP-1)
        Endif
      Endif

      # Lecture des comptes à partir de [L]GACACC et [L]GACIAS
      Gosub CHARGE_COMPTES
      If fstat : Break : Endif

      ### CONTROLES DE COHERENCE ###

      # Aucun compte suivi : on ne fait rien
      If ([M:FPC]FLGIAS =  G_OUI and [L]FLGEXPCRE(1)<> G_OUI and [L]FLGEXPCRE(2)<> G_OUI)
&     or ([M:FPC]FLGIAS <> G_OUI and [L]FLGEXPCRE(1)<> G_OUI)
        Goto SUITE_PVF
      Endif

      # Un seul compte suivi : avertissement
      If ([M:FPC]FLGIAS = G_OUI) and ([L]FLGEXPCRE(1)<> G_OUI and [L]FLGEXPCRE(2)=  G_OUI)
        If dim([M]XCPYFLG)<0 : # Pour savoir si on est en interactif ou en validation massive
          # Aucune dépense ne sera créée pour l'élément de facturation ### : Compte social non suivi et compte IAS suivi. Voulez-vous continuer ?
          Call OUINON([F:PIH]NUM-mess(106,7772,1)-num$([F:PVF]INVDTA)-":"-mess(77,7772,1)-mess(205,100,1),OK) From GESECRAN
          If OK<>2
            RMESSAGE=num$([F:PVF]INVDTA)-":"-mess(77,7772,1) : Gosub TRAITE_ERREUR : Break
          Else
            Goto SUITE_PVF
          Endif
        Else
          RMESSAGE=num$([F:PVF]INVDTA)-":"-mess(77,7772,1) : Gosub TRAITE_ERREUR : Break
        Endif
      Endif

      If ([M:FPC]FLGIAS = G_OUI ) and ([L]FLGEXPCRE(1)= G_OUI and [L]FLGEXPCRE(2)<>  G_OUI)
        If dim([M]XCPYFLG)<0 : # Pour savoir si on est en interactif ou en validation massive
          # Aucune dépense ne sera créée pour l'élément de facturation ### : Compte social suivi et compte IAS non suivi. Voulez-vous continuer ?
          Call OUINON([F:PIH]NUM-mess(106,7772,1)-num$([F:PVF]INVDTA)-":"-mess(78,7772,1)-mess(205,100,1),OK) From GESECRAN
          If OK<>2
            RMESSAGE=num$([F:PVF]INVDTA)-":"-mess(78,7772,1) : Gosub TRAITE_ERREUR : Break
          Else
            Goto SUITE_PVF
          Endif
        Else
          RMESSAGE=num$([F:PVF]INVDTA)-":"-mess(78,7772,1) : Gosub TRAITE_ERREUR : Break
        Endif
      Endif

      ### FIN DES CONTROLES DE COHERENCE ###

      Local Char VALEUR(GLONDCO)
      Call LECTEXTRA(VALEUR,"PFOOTINV","DESAXX",num$([F:PVF]INVDTA),"") From ATEXTRA
      If (VALEUR <> "")
        [F:LOF]DES = VALEUR
      Endif

      If [F:LOF]UOM = ""
        [F:LOF]UOM = [L]DEFUOM  : # Unité par défaut
      Endif
      [F:LOF]QTY       = 1

      # Taux de TVA et TVA récupérée
      [L]TAX           = [F:PVF]INVDTAVAT
      Gosub LEC_VAT
      If [L]STAT : GOK = 0 : Break : Endif
      Gosub INI_2008_VAT

      # Montants en devise facture
      [F:LOF]AMTNOTCUR  = [F:PVF]INVDTAAMT
      [F:LOF]AMTVATCUR  = [F:PVF]DTAAMTTAX
      [F:LOF]AMTVATRCUR = [F:PVF]DTADEDTAX

      Gosub PUT_FLG_FORCE
      Gosub AMT_CPY
      Gosub AVOIR_AMT

      # Imputations analytiques
      # Dans une facture achat, on a une et une seule ligne dans CPTANALIN par ligne de facture, sur laquelle
      # on trouve soit une répartition a priori soit des imputations analytiques
      [F:LOF]DSP    = [F:CAL]DSP
      For N_I=0 To dim(GDIE)-1
        [F:LOF]DIE(N_I) = [F:CAL]DIE(N_I)
        [F:LOF]CCE(N_I) = [F:CAL]CCE(N_I)
      Next

      [F:LOF]CPMCREORI  = 1                                       : # Origine complément X3 Achat
      [F:LOF]LIGORI     = [F:PVF]IND
      [F:LOF]TYPORI     = ""

      Gosub ECRIRE_DEP

      If !GOK : Break : Endif

$SUITE_PVF
    Endif
  Next
Return

##########################################
#  ANNULATION FACTURE TIERS FOURNISSEUR  #
##########################################
$DEVALID
  OK=1
  If clalev([F:RLOF])=0 : Local File LAYOUTFAS [RLOF] : Endif
  If clalev([F:RALK])=0 : Local File APLLCK    [RALK] : Endif
  Filter [RLOF] Where CODLOF=[F:PIH]NUM and CPMCREORI<>0 and FLGLIKAAS=2
  If rowcount([RLOF])>0
     Call ECR_TRACE(mess(76,119,1)+"."-mess(49,117,1),1) From GESECRAN    # Une dépense issue de cette facture est immobilisée. Annulation impossible
     Unlock =SYMBOLE
     Filter [RLOF]
     GOK = 0 : End
  Endif
  Filter [RLOF]
  For [RLOF] Where CODLOF=[F:PIH]NUM and CPMCREORI<>0
    Look [RALK]LCKCLE="LOF"+num$([F:RLOF]LINLOF)+"\"+[F:RLOF]CODLOF;0
    If !fstat
      Call ECR_TRACE(mess(77,119,1)+"."-mess(49,117,1),1) From GESECRAN    # Une dépense issue de cette facture est verrouillée. Annulation impossible
      Unlock =SYMBOLE
      GOK = 0 : Break
    Endif
  Next
  If GOK=0 : End : Endif
Return

$MAJ_ANUBIS
 Local Char CRITLOF(255)

 CRITLOF="CODLOF=[F:PIH]NUM and CPMCREORI<>0"

 For [RLOF] Where evalue(CRITLOF)
   Readlock [RLOF]LOF0=[F:RLOF]CODLOF;[F:RLOF]LINLOF
   If fstat
     Call ECR_TRACE(mess(77,119,1)+"."-mess(49,117,1),1) From GESECRAN    # Une dépense issue de cette facture est verrouillée. Annulation impossible
     GOK = 0
   Elsif ([F:RLOF]FLGLIKAAS=2)
     Call ECR_TRACE(mess(76,119,1)+"."-mess(49,117,1),1) From GESECRAN    # Une dépense issue de cette facture est immobilisée. Annulation impossible
     GOK = 0
   Endif
   Delete [RLOF] Curr
 Next
Return

###############################
#  FACTURE TIERS FOURNISSEUR  #
###############################

$ALIM_BIS
  # Lecture du type de facture
  # FQ102396
  #Call LECTURE("TPV",[F:PIH]PIVTYP,"") From CONTOBJ
  Local Integer WRET
  Local Char    WLEG (20)
  Call GETLEG([F:PIH]CPY,"G",WLEG) From TRTLECLEG
  Call LEC_TPV_LEG(WLEG,[F:PIH]PIVTYP,WRET) From TRTLECLEG

  [F:LOF]           = [F:PIH]

  # Issue 118031
  If func SUBLOF2.CTL_FMT("LAYOUTFAS", "CODLOF", [F:PIH]NUM, RMESSAGE) = 0
    GOK = 0
    Return
  Endif
  # End Issue 118031

  [F:LOF]CODLOF     = [F:PIH]NUM              : # Numéro de pièce
  [F:LOF]DATVCR     = [F:PIH]BPRDAT           : # Date d'achat
  [F:LOF]DATIMP     = [F:PIH]ACCDAT           : # Date d'imputation comptable

  # FQ102796
  #[F:LOF]TYPVCR     = [F:TPV]INVTYP           : # Type de document. Ce type pourra être modifié si montants négatifs
  [F:LOF]TYPVCR = func SUBLOF2.GET_TYPVCR_FROM_INVTYP([F:TPV]INVTYP)

  If GDECRCU # Issue 119659 GDECRCU
    [F:LOF]RATCUR     = arr([F:PIH]RATMLT(0)/[F:PIH]RATDIV(0), 10^-GDECRCU)
  Else
    [F:LOF]RATCUR     = [F:PIH]RATMLT(0)/[F:PIH]RATDIV(0)       : # FQ84734 : division par le taux diviseur
  Endif # End Issue 119659

  [F:LOF]DES        = mess([F:TPV]INVTYP,645,1)-[F:PIH]BPRNAM

  [F:LOF]FLGGRA     = 1                                       : # Flag subventionnée
  [F:LOF]FLGAMTGRA  = 1                                       : # Flag Force Mt subvention
  [F:LOF]FLGLIKAAS  = 1                                       : # Flag liaison Bien
  [F:LOF]FLGLOFMAI  = 1                                       : # Flag dépense principale
  [F:LOF]FLGDETEXP  = G_OUI                                   : # détachable Flag FQ104360

  # Sauvegarde des informations communes à toutes les lignes
  [F:SLOF] = [F:LOF]

  ## <87307/88413> : Intercompany Invoices Management
  If [F:PIH]NBRCPY>1
   Local Char OCPY(GLONCPY)
   [L]OCPY = [F:PIH]CPY
   If clalev([F:ICF])=0 : Local File INTCOFLO  [ICF] : Endif
  Endif
  ## <End 87307/88413> : Intercompany Invoices Management

  For [PIL] Where NUM=[F:PIH]NUM
    # Initialisation de la classe avec les informations communes à toutes les lignes
    [F:LOF] = [F:SLOF]

    ## <87307/88413> : Intercompany Invoices Management
    If [F:PIH]NBRCPY>1
     Call LEC_CPY([F:PIL]CPYLIN) From CPTLEC
     GSOCIETE = [F:CPY]CPY
     [F:LOF]CPY = [F:PIL]CPYLIN
     If [F:PIL]CPYLIN<>[L]OCPY
      Call LOAD_FASPARCPY([F:PIL]CPYLIN,"",G_NON,RET) From GLOFCYCPY
      If RET : RMESSAGE=[F:PIL]CPYLIN-mess(198,105,1)-num$(RET) : Gosub TRAITE_ERREUR : Break : Endif
      [L]OCPY = [F:PIL]CPYLIN
     Endif
     If [F:PIL]CPYLIN<>[F:PIH]CPY
      Read [F:ICF]ICF0 = "PIH";[F:PIH]NUM;[F:PIH]CPY;GSOCIETE;""
      If !fstat
        If GDECRCU # Issue 119659 GDECRCU
          [F:LOF]RATCUR     = arr([F:ICF]RATMLT(0)/[F:ICF]RATDIV(0), 10^-GDECRCU)
        Else
          [F:LOF]RATCUR     = [F:ICF]RATMLT(0)/[F:ICF]RATDIV(0)       : # FQ84734 : division par le taux diviseur
        Endif # End Issue 119659
      Endif
     Endif
    Endif
    ## <87307/88413> : Intercompany Invoices Management

    [L]GACACC = [F:PIL]ACC([M:FPC]GENLEDTYP-1)
    If [M:FPC]FLGIAS = G_OUI
      [L]GACIAS = [F:PIL]ACC([M:FPC]IASLEDTYP-1)
    Endif

    # FQ86455
    If [F:PIL]DES <> ""
        [F:LOF]DES = [F:PIL]DES
    Endif

    # Lecture des comptes à partir de [L]GACACC et [L]GACIAS
    Gosub CHARGE_COMPTES
    If fstat : Break : Endif

    ### CONTROLES DE COHERENCE ###
    ###
    If ([M:FPC]FLGIAS =  G_OUI and [L]FLGEXPCRE(1)<> G_OUI and [L]FLGEXPCRE(2)<> G_OUI)
&   or ([M:FPC]FLGIAS <> G_OUI and [L]FLGEXPCRE(1)<> G_OUI)
      Goto SUITE_PIL
    Endif

    # Un seul compte suivi : avertissement
    If ([M:FPC]FLGIAS = G_OUI) and ([L]FLGEXPCRE(1)<> G_OUI and [L]FLGEXPCRE(2)=  G_OUI)
      If dim([M]XCPYFLG)<0 : # Pour savoir si on est en interactif ou en validation massive
        # <FACTURE> Aucune dépense ne sera créée pour la ligne ### : Compte social non suivi et compte IAS suivi. Voulez-vous continuer ?
        Call OUINON([F:PIH]NUM-mess(72,7772,1)-num$([F:PIL]LIG)-":"-mess(77,7772,1)-mess(205,100,1),OK) From GESECRAN
        If OK<>2
          RMESSAGE=num$([F:PIL]LIG)-":"-mess(77,7772,1) : Gosub TRAITE_ERREUR : Break
        Else
          Goto SUITE_PIL
        Endif
      Else
        RMESSAGE=num$([F:PIL]LIG)-":"-mess(77,7772,1) : Gosub TRAITE_ERREUR : Break
      Endif
    Endif

    If ([M:FPC]FLGIAS = G_OUI) and ([L]FLGEXPCRE(1)= G_OUI and [L]FLGEXPCRE(2)<>  G_OUI)
      If dim([M]XCPYFLG)<0 : # Pour savoir si on est en interactif ou en validation massive
        # <FACTURE> Aucune dépense ne sera créée pour la ligne ### : Compte social suivi et compte IAS non suivi. Voulez-vous continuer ?
        Call OUINON([F:PIH]NUM-mess(72,7772,1)-num$([F:PIL]LIG)-":"-mess(78,7772,1)-mess(205,100,1),OK) From GESECRAN
        If OK<>2
          RMESSAGE=num$([F:PIL]LIG)-":"-mess(78,7772,1) : Gosub TRAITE_ERREUR : Break
        Else
          Goto SUITE_PIL
        Endif
      Else
        RMESSAGE=num$([F:PIL]LIG)-":"-mess(78,7772,1) : Gosub TRAITE_ERREUR : Break
      Endif
    Endif
    ###
    ### FIN DES CONTROLES DE COHERENCE ###

    [F:LOF]UOM       = [F:PIL]UOM
    If [F:LOF]UOM = ""
      [F:LOF]UOM = [L]DEFUOM  : # Unité par défaut
    Endif

    [F:LOF]QTY        = [F:PIL]QTY
    # FQ103398
    If [F:PIL]QTY = 0 : [F:LOF]QTY = 1 :  Endif

    [F:LOF]CPMCREORI  = 2                                       : # Origine complément X3 Tiers
    [F:LOF]LIGORI     = [F:PIL]LIG
    [F:LOF]TYPORI     = ""

    If [F:PIL]FCYLIN <> ""
      [F:LOF]FCY = [F:PIL]FCYLIN                            : # FQ77295
    Endif

    # Taux de TVA et TVA récupérée
    [L]TAX           = [F:PIL]VAT
    Gosub LEC_VAT
    If [L]STAT : GOK = 0 : Break : Endif
    Gosub INI_2008_VAT

    # FQ88945 : gestion des ventilations analytiques manuelles

    # Imputations analytiques et montants
    # Dans une facture tiers, on a soit
    # - cas (1) : pas de répartition, donc pas de lignes dans BPSINLIGA
    # - cas (2) : une affectation directe dans axes sur les sections de la ligne, et dans ce cas on aura une seule ligne dans
    #             BPSINVLIGA avec les axes
    # - cas (3) : une répartition a priori sur la ligne de facture, et dans ce cas on aura plusieurs ligne dans
    #             BPSINVLIGA correspondant à la ventilation et un code renseigné dans DSP
    # - cas (4) : une répartition manuelle, et dans ce cas on aura plusieurs ligne dans BPSINVLIGA correspondant
    #             à la ventilation et pas code renseigné dans DSP
    #
    # Pour les cas (1), (2) et (3) on ne crée qu'un seule dépense pour la ligne, avec l'alimentation (en fonction des cas)
    # des champs DSP et CCE.
    # Pour le cas (4) il va falloir créer une ligne par ventilation car on ne sait pas stocker les ventilations manuelles
    #
    # La présence ou non d'un code de répartition et de lignes dans BPSINLIGA permettre de traiter :
    # - si 0 ligne ou code de répartition a priori, cas (1) ou (3)
    # - si 1+ lignes et pas de code de répartition a priori, cas (2) ou (4)

    Local Integer NB_PIA, I_PIA
    Local Decimal R_AMTVATCUR, R_AMTVATRCUR : # Reliquat des montants de TVA et de TVA récupérées à imputer sur le dernière dépense

    Filter [F:PIA] Where NUM=[F:PIL]NUM and LIG=[F:PIL]LIG
    NB_PIA = rowcount([F:PIA])
    Filter [F:PIA]
    If ([F:PIL]DSP = "") and (NB_PIA > 0)
      # Cas (2) ou (4)
      R_AMTVATCUR  = [F:PIL]AMTVAT
      R_AMTVATRCUR = [F:PIL]DEDVAT
      I_PIA            = 0
      For [F:PIA] Where NUM=[F:PIL]NUM and LIG=[F:PIL]LIG
        I_PIA += 1
        # Montants en devise facture
        [F:LOF]AMTNOTCUR  = [F:PIA]AMT
        If I_PIA = NB_PIA
          # On est sur la dernière ligne, on solde le montant de TVA et le montant de TVA récupéré
          [F:LOF]AMTVATCUR  = R_AMTVATCUR
          [F:LOF]AMTVATRCUR = R_AMTVATRCUR
        Else
          #*FQ102148  Test que le  Montant HT de la ligne facture Tiers <> 0
          If  [F:PIL]AMTNOTLIN <> 0
            # Détermination des montants de TVA et de TVA récupérées en proratant par rapport aux montants HT
            Call GET_MNT_ARRONDI ([F:PIL]AMTVAT * [F:PIA]AMT / [F:PIL]AMTNOTLIN, [F:LOF]CUR, [F:LOF]AMTVATCUR) From GLOBIENS
            Call GET_MNT_ARRONDI ([F:PIL]DEDVAT * [F:PIA]AMT / [F:PIL]AMTNOTLIN, [F:LOF]CUR, [F:LOF]AMTVATRCUR) From GLOBIENS
          Else #*FQ102148
            [F:LOF]AMTVATCUR  = 0
            [F:LOF]AMTVATRCUR = 0
          Endif #*FQ102148 END
          R_AMTVATCUR  -= [F:LOF]AMTVATCUR
          R_AMTVATRCUR -= [F:LOF]AMTVATRCUR
        Endif

        [F:LOF]ANALIGORI = [F:PIA]ANALIG
        [F:LOF]TYPVCR  = [F:TPV]INVTYP #Fq-121664
        Gosub ECRIRE_DEP_BIS
      Next
    Else
      # Cas (1) ou (3)
      # Montants en devise facture
      [F:LOF]AMTNOTCUR  = [F:PIL]AMTNOTLIN
      [F:LOF]AMTVATCUR  = [F:PIL]AMTVAT
      [F:LOF]AMTVATRCUR = [F:PIL]DEDVAT

      Raz [F:PIA]
      [F:LOF]ANALIGORI = 0
      [F:LOF]TYPVCR  = [F:TPV]INVTYP  #Fq-121664
      Gosub ECRIRE_DEP_BIS
    Endif

$SUITE_PIL
  Next
  ## <87307/88413> : Intercompany Invoices Management
  If [F:PIH]NBRCPY>1
   GSOCIETE = [L]LCPY
  Endif
  ## <End 87307/88413> : Intercompany Invoices Management

Return

$ECRIRE_DEP_BIS
    [F:LOF]DSP    = [F:PIL]DSP

    For N_I=0 To dim(GDIE)-1
      [F:LOF]DIE(N_I) = [F:PIA]DIE(N_I)
      [F:LOF]CCE(N_I) = [F:PIA]CCE(N_I)
    Next

    # Issue 116402 - si  le taux de TVA facturée = 0 ==> montants de TVA facturée/récupérée sont nuls
    If [F:LOF]RATVAT    = 0
       [F:LOF]AMTVATCUR  = 0
       [F:LOF]AMTVATCPY  = 0
       [F:LOF]AMTVATRCUR = 0
       [F:LOF]AMTVATRCPY = 0
    Endif
    # End Issue 116402

    Gosub PUT_FLG_FORCE
    Gosub AMT_CPY
    Gosub AVOIR_AMT

    Gosub ECRIRE_DEP
Return

######################################################### FQ67340
# CREATION DE LA DEPENSE A PARTIR D'UNE PIECE COMPTABLE #
# EN VALIDATION DEFINITIVE (CPTVAL)                     #
#########################################################

$ALIM_GAS_VAL
  # Chargement des masques
  Local   Char DBGSTR_SAV(255) : DBGSTR_SAV = dbgstr(1)
  Local   Mask GACCENT0   [HAE0]
  Local   Mask GACCENT1   [HAE1]
  Local   Mask GACCENTW   [HAEW]
  Local   Mask GACCENTFMT [HAEF]
  Default Mask "[HAE0],[HAE1],[HAEW],[HAEF],"+DBGSTR_SAV

  # FQ90615 : Raz des masques car un local Mask ne réouvre pas un masque ouvert et on peut se retrouver avec les valeurs
  #           d'un appel précédent
  Raz [M:HAE0]
  Raz [M:HAE1]
  Raz [M:HAEW]
  Raz [M:HAEF]

  [M:HAE0] = [F:HAE]
  [M:HAE1] = [F:HAE]

  Call INIMSKFMT([F:HAE]FCY,[F:HAE]DACDIA,[F:HAE]TYP,[F:HAE]ACCDAT,STAT)  From SUBGASA

  Local Integer NOLI : NOLI = 0
  Local Integer N_CCE

  For [F:DAE]DAE0 Where TYP=[F:HAE]TYP and NUM=[F:HAE]NUM
    Gosub MAJMSK From SUBGASB
  Next

#########################################################
# CREATION DE LA DEPENSE A PARTIR D'UNE PIECE COMPTABLE #
#########################################################
$ALIM_GAS
  Local Integer  LINDEB, LINFIN, LINCUR
  Local Char     LDIE(GLONDIE), LCCE(GLONCCE) : # FQ86521
  Local Char     LDSP(GLONDSP)                : # FQ88945 : répartition à priori de la ligne
  Local Decimal  WRATCUR, WRATDIV             : #*X3-83776

  # Conditions d'éligibilité de la pièce

  # Ce doit être une pièce comptable
  If !clalev([M:HAE1]) : Return : Endif

  # La pièce doit être réelle
  If [M]CAT<>1 : Return : Endif

  # La pièce doit être définitive
  If [M]STA<>2 : Return : Endif

  # Le type de pièce doit être flagué comme donnant lieu à la création de dépenses FQ63306
  If !clalev([F:GTE]) : Local File GTYPACCENT [GTE] : Endif

  If [F:GTE]TYP <> [M]TYP
    # 71937 : Multilégislation
    #Call LECTURE("GTE",[M]TYP,"") From CONTOBJ
    Local Integer WRET
    Call LEC_GTE_LEG(GCURLEG,[M]TYP,WRET) From TRTLECLEG
  Endif

  If [F:GTE]FLGEXPCRE<>G_OUI : Return : Endif

  # Contrôle que l'on ne traite que des pièces créées directement en compta FQ102691
  If !([M]ORIMOD = 2)
    Return
  Endif

  # Contrôle qu'il n'existe pas déjà des dépenses issue d'une facture FQ65625
  If func SUBLOF2.CHECKDEP([M]NUM)
    # Au moins une dépense existe, on ne fait rien
    Return
  Endif

  # End Issue 118031
  If func SUBLOF2.CTL_FMT("LAYOUTFAS", "CODLOF", [M]NUM, RMESSAGE) = 0
    GOK = 0
    Return
  Endif
  # End Issue 118031

  # En-tête
  [F:LOF]CPY    = [M]CPY
  [F:LOF]CODLOF = [M]NUM
  [F:LOF]LINLOF = 0
  [F:LOF]DATIMP = [M]ACCDAT
  [F:LOF]DATVCR = [M]ACCDAT
  [F:LOF]JOU    = [M]JOU
  [F:LOF]BPRVCR = [M]BPRVCR
  [F:LOF]CUR    = [M]CUR

  #*X3-83776 to initialize the currency rate (Multiplier or Divisor defined on Ledger type)
  Case [L]OBJORI
    When "HAE"
      WRATCUR = [M]RAT2(0)     : # Journal entry (GESGAS)
      WRATDIV = [M]RAT1(0)
    When "VAL"
      WRATCUR = [M]RATMLT(0)   : # Journal entry in Final validation (CPTVAL)  FQ67340
      WRATDIV = [M]RATDIV(0)
  Endcase

  #*FQ112686 If [M]RAT1 = 0
  #*FQ112686   # FQ98116 Si [M]RAT1 = 0 c'est que la devise pièce et la devise société sont identiques. Le taux est égal à 1.
  #*FQ112686   [F:LOF]RATCUR = 1
  #*FQ112686 Else
  #*FQ112686   [F:LOF]RATCUR = [M]RAT2 / [M]RAT1 : # FQ75672 FQ98116
  #*FQ112686 Endif

  If !GIMPORT  #YYFIN_X3-45308 different cases if we are importing or not
      #*X3-83776 If [M]RATDIV(0) <> 0
      #/YYFIN_120121 [F:LOF]RATCUR = [M]RATMLT(0)/[M]RATDIV(0)  : # FQ112686 : division par le taux diviseur
      #*X3-83776
      #*X3-83776   [F:LOF]RATCUR = [M]RAT2(0)/[M]RATDIV(0)
      #*X3-83776 Else
      #*X3-83776   [F:LOF]RATCUR =  [M]RAT2(0)
      #*X3-83776 Endif
    If WRATDIV <> 0
      [F:LOF]RATCUR =  WRATCUR / WRATDIV
    Else
      [F:LOF]RATCUR =  WRATCUR
    Endif
    If  [F:LOF]RATCUR = 0
      [F:LOF]RATCUR = 1
    Endif
  Else # if Import
    If clalev([M:HAEF])
      If [M:HAEF]RATDIVC(0) <> 0
        [F:LOF]RATCUR = [M:HAEF]RATMLTC(0)/[M:HAEF]RATDIVC(0)
      Else
        [F:LOF]RATCUR =  [M:HAEF]RATMLTC(0)
      Endif
    Endif
  Endif

  If  [F:LOF]RATCUR = 0
    [F:LOF]RATCUR = 1
  Endif

  If GDECRCU # Issue 119659 GDECRCU
    [F:LOF]RATCUR     = arr([F:LOF]RATCUR, 10^-GDECRCU)
  Endif # End Issue 119659

  #YYFIN_120121/
  [F:LOF]CURTYP = [M]TYPRAT

  [F:LOF]FLGGRA     = 1                                       : # Flag subventionnée
  [F:LOF]FLGAMTGRA  = 1                                       : # Flag Force Mt subvention
  [F:LOF]FLGLIKAAS  = 1                                       : # Flag liaison Bien
  [F:LOF]FLGLOFMAI  = 1                                       : # Flag dépense principale
  [F:LOF]FLGDETEXP  = G_OUI                                   : # détachable Flag FQ104360

  # Sauvegarde des informations communes à toutes les lignes
  [F:SLOF] = [F:LOF]

  # Lignes. On travaille avec le masque générique [HAEW], attention il y a un groupe de lignes (une par référentiel)
  # par ligne de la pièce, on les repère car elles portent le même IDTLIN
  Sorta [M:HAEW]NB [M:HAEW]NB Order By [M:HAEW]IDTLIN(indice), [M:HAEW]LEDTYP(indice)

  For N_I = 0 To [M:HAEW]NB-1
    LINDEB = N_I
    LDSP   = "" : # FQ88945
    While [M:HAEW]LIN(N_I)=[M:HAEW]LIN(LINDEB)
      # FQ88945 : en validation batch, si le référentiel n'est pas analytique, DSP n'est pas alimenté sur la ligne
      #           du référentiel. Si DSP est valorisé pour au moins une ligne il est stocké dans LDSP et utilisé
      #           lors de la gestion de imputations analytiques.
      If ([M:HAEW]DSP(N_I) <> "") and (LDSP = "")
        LDSP = [M:HAEW]DSP(N_I)
      Endif
      N_I += 1
    Wend
    N_I   -= 1
    LINFIN = N_I
    LINCUR = [M:HAEW]LIN(LINDEB)

    # Initialisation de la classe avec les informations communes à toutes les lignes
    [F:LOF] = [F:SLOF]

    # Recherche du compte social
    If find([M:FPC]GENLEDTYP,[M:HAEW]LEDTYP(LINDEB..LINFIN))=0
      [L]GACACC = ""
    Else
      [L]GACACC = [M:HAEW]ACC(find([M:FPC]GENLEDTYP,[M:HAEW]LEDTYP(LINDEB..LINFIN))+LINDEB-1)
    Endif

    # Recherche du compte IAS
    If [M:FPC]FLGIAS = G_OUI and find([M:FPC]IASLEDTYP,[M:HAEW]LEDTYP(LINDEB..LINFIN)) <> 0
      [L]GACIAS = [M:HAEW]ACC(find([M:FPC]IASLEDTYP,[M:HAEW]LEDTYP(LINDEB..LINFIN))+LINDEB-1)
    Else
      [L]GACIAS = ""
    Endif

    # Lecture des comptes à partir de [L]GACACC et [L]GACIAS
    Gosub CHARGE_COMPTES
    If fstat : Break : Endif

    ### CONTROLES DE COHERENCE ###
    If ([M:FPC]FLGIAS =  G_OUI and [L]FLGEXPCRE(1)<> G_OUI and [L]FLGEXPCRE(2)<> G_OUI)
&   or ([M:FPC]FLGIAS <> G_OUI and [L]FLGEXPCRE(1)<> G_OUI)
      Goto SUITE_GAS
    Endif

    # Un seul compte suivi : avertissement
    If ([M:FPC]FLGIAS = G_OUI) and ([L]FLGEXPCRE(1)<> G_OUI and [L]FLGEXPCRE(2)=  G_OUI)
      If dim([M]XCPYFLG)<0 : # Pour savoir si on est en interactif ou en validation massive
        # <OD> Aucune dépense ne sera créée pour la ligne ### : Compte social non suivi et compte IAS suivi. Voulez-vous continuer ?
        Call OUINON([M]NUM-mess(72,7772,1)-num$(LINCUR)-":"-mess(77,7772,1)-mess(205,100,1),OK) From GESECRAN
        If OK<>2
          RMESSAGE=num$(LINCUR)-":"-mess(77,7772,1) : Gosub TRAITE_ERREUR : Break
        Else
          Goto SUITE_GAS
        Endif
      Else
        RMESSAGE=num$(LINCUR)-":"-mess(77,7772,1) : Gosub TRAITE_ERREUR : Break
      Endif
    Endif

    If ([M:FPC]FLGIAS = G_OUI) and ([L]FLGEXPCRE(1)= G_OUI and [L]FLGEXPCRE(2)<>  G_OUI)
      If dim([M]XCPYFLG)<0 : # Pour savoir si on est en interactif ou en validation massive
        # <OD> Aucune dépense ne sera créée pour la ligne ### : Compte social suivi et compte IAS non suivi. Voulez-vous continuer ?
        Call OUINON([M]NUM-mess(72,7772,1)-num$(LINCUR)-":"-mess(78,7772,1)-mess(205,100,1),OK) From GESECRAN
        If OK<>2
          RMESSAGE=num$(LINCUR)-":"-mess(78,7772,1) : Gosub TRAITE_ERREUR : Break
        Else
          Goto SUITE_GAS
        Endif
      Else
        RMESSAGE=num$(LINCUR)-":"-mess(78,7772,1) : Gosub TRAITE_ERREUR : Break
      Endif
    Endif
    ### FIN DES CONTROLES DE COHERENCE ###

    [F:LOF]FCY = [M:HAEW]FCYLIN(LINDEB)

    If [M:HAEW]DES(LINDEB) <> ""
      [F:LOF]DES = [M:HAEW]DES(LINDEB)
    Elsif [M]DESVCR <> ""
      [F:LOF]DES = [M]DESVCR
    Else
      [F:LOF]DES = [M]NUM
    Endif

    If dim([F:DAE]OFFACC) < 0 : # FQ69212
      [F:LOF]BPR     = [M:HAEW]BPR(LINDEB)
    Else
      [F:LOF]BPR     = [F:DAE]OFFACC
    Endif

    [F:LOF]UOM       = [M:HAEW]UOM(LINDEB) : If [F:LOF]UOM="" : [F:LOF]UOM=[L]DEFUOM : Endif
    [F:LOF]QTY       = [M:HAEW]QTY(LINDEB) : If [F:LOF]QTY=0  : [F:LOF]QTY=1         : Endif

    # Taux de TVA et TVA récupérée
    [L]TAX           = [M:HAEW]TAX(LINDEB)
    Gosub LEC_VAT
    If [L]STAT : GOK = 0 : Break : Endif
    Gosub INI_2008_VAT

    # Informations Origine X3
    [F:LOF]CPMCREORI = 3             : # O.D.
    [F:LOF]LIGORI    = LINCUR
    [F:LOF]TYPORI    = [M]TYP

    # FQ88945 : gestion des ventilations analytiques manuelles

    # Imputations analytiques et montants
    # Dans le cas de la pièce comptable, les ventilations analytiques sont stockées dans la table GACCENTRYA
    # On distingue plusieurs cas :
    # - cas (1) : pas de répartition, donc pas de lignes dans GACCENTRYA ni d'imputations directes
    # - cas (2) : une affectation directe des axes sur les sections de la ligne, et dans ce cas on a une ligne dans GACCENTRYA
    # - cas (3) : une répartition a priori sur la ligne de facture, et dans ce cas on a la ventilation dans GACCENTRYA
    #             et le code de répartition est indiqué dans LDSP
    # - cas (4) : une répartition manuelle, et dans ce cas on a la ventilation dans GACCENTRYA
    #             et pas de code de répartition est indiqué dans LDSP
    #
    # Pour les cas (1), (2) et (3) on ne crée qu'un seule dépense pour la ligne, avec l'alimentation (en fonction des cas)
    # des champs DSP et CCE.
    # Pour le cas (4) il va falloir créer une ligne par ventilation car on ne sait pas stocker les ventilations manuelles

    Local Integer  NB_DAA, I_DAA             : # Nombre total de lignes et nombre de lignes traitées de GACCENTRYA
    Local Decimal  AMTNOT, AMTVAT, DEDVAT    : # Montants en devise pièce : HT, TVA, TVA récupérée
    Local Decimal  R_AMTVATCUR, R_AMTVATRCUR : # Reliquat des montants de TVA et de TVA récupérées à imputer sur le dernière dépense
    Local Char     NUMDAA(20)                  #*YYFIN_117536

    # Initialisation des codes axes
    For N_K = 0 To [M:FPC]NBDIE-1
      [F:LOF]DIE(N_K) = [M:FPC]DIE(N_K)
    Next N_K

    # Valorisation en devise pièce
    Gosub GAS_MNT_CUR

    If !clalev([F:DAA])  : Local File GACCENTRYA  [DAA]  : Endif   : # lignes analytiques

    # Y-a-t'il des imputations analytiques pour la ligne ?
    #*YYFIN_117536   Filter [F:DAA] Where TYP=[M]TYP and NUM=[M]NUM and LIN=LINCUR
    If [F:HAE]RVS>1
      NUMDAA=[F:HAE]NUM
    Else
      NUMDAA=[M]NUM
    Endif

    Filter [F:DAA] Where TYP=[M]TYP and NUM=NUMDAA and LIN=LINCUR
    NB_DAA = rowcount([F:DAA])
    Filter [F:DAA]

    # La présence ou non d'un code de répartition vide ou à "$" et de lignes dans GACCENTRYA permettre de traiter :
    # - si 0 ligne ou code de répartition a priori, cas (1) ou (3)
    # - si 1+ lignes et pas de code de répartition a priori, cas (2) ou (4)
    If (LDSP = "$" or LDSP = "") and (NB_DAA > 0)
      # Cas (2) ou (4)
      [F:LOF]DSP = ""
      R_AMTVATCUR  = [L]AMTVAT
      R_AMTVATRCUR = [L]DEDVAT
      I_DAA            = 0
      #*YYFIN_117536  For [F:DAA]DAA2 Where TYP=[M]TYP and NUM=[M]NUM and LIN=LINCUR
      For [F:DAA]DAA2 Where TYP=[M]TYP and NUM=NUMDAA and LIN=LINCUR
        # L'index DAA2 est utilisé car il trie d'abord en fonction de la ligne analytique et ensuite par référentiel. En
        # effet il faut lire pour chaque ligne analytique tous les référentiels pour alimenter la dépense
        If [F:LOF]ANALIGORI <> [F:DAA]ANALIN
          # On change de ligne de ventilation, il faut créer la dépense
          If [F:LOF]ANALIGORI <> 0
            Gosub ECRIRE_DEP_GAS
          Endif

          # Montants
          #[F:LOF]AMTNOTCUR = [F:DAA]AMTCUR                                      : # FQ99885
          [F:LOF]AMTNOTCUR = [F:DAA]AMTCUR/(1+([L]TAUX1/100)*(1-([L]TAUX2/100))) : # FQ99885

          If I_DAA = NB_DAA
            # On est sur la dernière ligne, on solde le montant de TVA et le montant de TVA récupéré
            [F:LOF]AMTVATCUR  = R_AMTVATCUR
            [F:LOF]AMTVATRCUR = R_AMTVATRCUR
          Else
            #*FQ102148  Test que le Montant HT de la  pièce est <> 0
            If [L]AMTNOT <> 0
              # Détermination des montants de TVA et de TVA récupérées en proratant par rapport aux montants HT
              Call GET_MNT_ARRONDI ([L]AMTVAT * [F:LOF]AMTNOTCUR / [L]AMTNOT, [F:LOF]CUR, [F:LOF]AMTVATCUR) From GLOBIENS
              Call GET_MNT_ARRONDI ([L]DEDVAT * [F:LOF]AMTNOTCUR / [L]AMTNOT, [F:LOF]CUR, [F:LOF]AMTVATRCUR) From GLOBIENS
            Else #*FQ102148
              [F:LOF]AMTVATCUR  = 0
              [F:LOF]AMTVATRCUR = 0
            Endif #*FQ102148  END
            R_AMTVATCUR  -= [F:LOF]AMTVATCUR
            R_AMTVATRCUR -= [F:LOF]AMTVATRCUR
          Endif
          [F:LOF]ANALIGORI = [F:DAA]ANALIN
        Endif

        For N_K = 0 To 8
          If [F:DAA]DIE(N_K) <> ""
            N_L = find([F:DAA]DIE(N_K), [F:LOF]DIE)
            If N_L > 0
              [F:LOF]CCE(N_L-1) = [F:DAA]CCE(N_K)
            Endif
          Endif
        Next

        I_DAA += 1
      Next

      Gosub ECRIRE_DEP_GAS
    Else
      # Cas (1) ou (3)
      # Montants
      [F:LOF]AMTNOTCUR  = [L]AMTNOT
      [F:LOF]AMTVATCUR  = [L]AMTVAT
      [F:LOF]AMTVATRCUR = [L]DEDVAT

      [F:LOF]DSP = LDSP

      # Remise à blanc des sections
      For N_K = 0 To [M:FPC]NBDIE-1
        [F:LOF]CCE(N_K) = ""
      Next N_K

      [F:LOF]ANALIGORI = 0

      Gosub ECRIRE_DEP_GAS
    Endif

    If !GOK : Break : Endif

$SUITE_GAS
  Next
Return

# Montants en devise pièce, stockés dans
# - [L]AMTNOT pour le montant HT
# - [L]AMTVAT pour le montant de TVA
# - [L]DEDVAT pour le montant de TVA récupéré
$GAS_MNT_CUR
  # FQ99885 DEBUT

#  # Valorisations
#  If [M:HAEW]DEB(LINDEB) = 0
#    [F:LOF]TYPVCR = 2
#    [L]AMTNOT     = [M:HAEW]CDT(LINDEB)
#  Else
#    [F:LOF]TYPVCR = 1
#    [L]AMTNOT     = [M:HAEW]DEB(LINDEB)
#  Endif

  Local Decimal GASAMTNOT

  # Valorisations
  If [M:HAEW]DEB(LINDEB) = 0
    [F:LOF]TYPVCR = 2
    [L]GASAMTNOT  = [M:HAEW]CDT(LINDEB)
  Else
    [F:LOF]TYPVCR = 1
    [L]GASAMTNOT  = [M:HAEW]DEB(LINDEB)
  Endif
  [L]AMTNOT = [L]GASAMTNOT/(1+([L]TAUX1/100)*(1-([L]TAUX2/100)))
  Call ARRDEV([L]AMTNOT,[F:LOF]CUR) From TRTDIV
  # FQ99885 FIN

  #*FQ98116 [F:LOF]FLGVATFCR = 1
  [F:LOF]FLGVATFCR = G_OUI
  [L]AMTVAT = [L]AMTNOT * [F:LOF]RATVAT / 100
  Call ARRDEV([L]AMTVAT,[F:LOF]CUR) From TRTDIV

  #*FQ98116 [F:LOF]FLGRECFVR  = 1
  [F:LOF]FLGRECFVR  = G_OUI
  #[L]DEDVAT = [L]AMTVAT * [F:LOF]RATVATREC / 100
  #Call ARRDEV([L]DEDVAT,[F:LOF]CUR) From TRTDIV
  [L]DEDVAT = [L]AMTNOT + [L]AMTVAT - [L]GASAMTNOT # FQ99885
Return

# Sous-programme de création d'une dépense à partir d'une ligne ou d'une ventilation analytique d'une pièce comptable
# Alimentation des montants en devise société, détermination du cas de l'avoir et création de la dépense
$ECRIRE_DEP_GAS
  If [M:HAEW]AMTFLG(LINDEB)
    # FQ75672 Gestion des montants forcés en devise société
    If [M:HAEW]SNS(LINDEB) = -1
      [F:LOF]TYPVCR = 2
    Else
      [F:LOF]TYPVCR = 1
    Endif
    #*FQ102148  Test que le Montant HT de la ligne de la pièce est <> 0
    If [L]AMTNOT <> 0
      [F:LOF]AMTNOTCPY = [M:HAEW]AMTLED1(LINDEB) * [F:LOF]AMTNOTCUR / [L]AMTNOT
      # Montant de TVA en devise société
      [F:LOF]AMTVATCPY = [F:LOF]AMTNOTCPY * [F:LOF]RATVAT / 100
      Call ARRDEV([F:LOF]AMTVATCPY,[F:CPY]ACCCUR) From TRTDIV
      # Montant de TVA récupéré en devise société
      [F:LOF]AMTVATRCPY = [F:LOF]AMTVATCPY * [F:LOF]RATVATREC / 100
      Call ARRDEV([F:LOF]AMTVATRCPY,[F:CPY]ACCCUR) From TRTDIV
    Endif #*FQ102148 END
  Else
    Gosub AMT_CPY
  Endif

  Gosub AVOIR_AMT

  Gosub ECRIRE_DEP
Return

##########################
# Création de la dépense #
##########################

$ECRIRE_DEP
  [L]NUMLIG += 1                                                  : # Incrémentation du compteur de lignes
  [F:LOF]LINLOF = [L]NUMLIG                                       : # Ligne

  [F:LOF]CREUSR = GUSER
  [F:LOF]CREDAT = date$
  [F:LOF]CREORI = 4

  # Point d'entrée permettant de compléter la dépense avant écriture
  GPE=0
  GPOINT="ECRI_DEP" : Gosub ENTREE From EXEFNC
  If GPE : GOK=0 : Return : Endif

  Write [F:LOF]
  If fstat : RMESSAGE=mess(76,7772,1)-[F:LOF]CODLOF-num$([F:LOF]LINLOF)-" fstat : "-num$(fstat) : Gosub TRAITE_ERREUR : Endif
  #*FQ68023 : ajout références des dépenses générées
  Call ECR_TRACE(mess(141,104,1)-" : "-num$([F:LOF]CODLOF-"/"-num$([F:LOF]LINLOF)),0) From GESECRAN
  [L]NB_LOF += 1

Return

######################################################### FQ65625
# CONTROLE DE L'EXISTENCE D'UNE DEPENSE                 #
#########################################################
Funprog CHECKDEP(PNUM)
Value Char     PNUM : # Référence de l'objet

Local Shortint RVALUE : # 0- aucune dépense n'existe
                        # 1- au moins une dépense existe

  RVALUE = 0

  Local File LAYOUTFAS [WLOF]

  Look [WLOF]LOF0(1)=PNUM

  If !fstat
    # La dépense existe
    RVALUE = 1
  Endif
End RVALUE

#########################################
# Lecture des comptes Social et IAS
#########################################
$CHARGE_COMPTES
  FLGEXPCRE(1) = G_NON
  FLGEXPCRE(2) = G_NON

  # Lecture du compte SOC
  If [L]GACACC <> ""
    Read [GAC]GAC0=[M:FPC]COA([M:FPC]GENLEDTYP-1);[L]GACACC
    If fstat : RMESSAGE=[M:FPC]COA([M:FPC]GENLEDTYP-1)-"<"+[L]GACACC+">"-mess(44,102,1)-"("+num$(fstat)+")" : Gosub TRAITE_ERREUR : Return : Endif

    [L]FLGEXPCRE(1)  = [F:GAC]FLGEXPCRE

    [F:LOF]GAC       = [F:GAC]ACC
    [F:LOF]GACORI    = [F:GAC]ACC
    [F:LOF]GACACN    = [F:GAC]GACACN
  Endif

  # Lecture du compte IAS
  If [M:FPC]FLGIAS = G_OUI
    # Alimentation du compte IAS avec celui par défaut du compte social si celui-ci n'est pas alimenté
    If [L]GACIAS = "" and [L]GACACC <> "" and find([M:FPC]COA([M:FPC]IASLEDTYP-1),[F:GAC]OTHCOA)
      [L]GACIAS = [F:GAC]DEFACC(find([M:FPC]COA([M:FPC]IASLEDTYP-1),[F:GAC]OTHCOA)-1)
    Endif
    # Alimentation du compte IAS avec celui du compte social si celui-ci n'est pas alimenté et que les référentiels sont les mêmes FQ61524
    If [L]GACIAS = "" and [L]GACACC <> "" and [M:FPC]COA([M:FPC]GENLEDTYP-1) = [M:FPC]COA([M:FPC]IASLEDTYP-1)
      [L]GACIAS = [L]GACACC
    Endif

    # FQ55977
    # Si le compte PCG n'est pas suivi et qu'on n'a pas de compte IAS ni sur la ligne ni en compte par défaut sur le PCG on passe
    # à la ligne suivante
    If [L]FLGEXPCRE(1) = G_OUI or [L]GACIAS <> ""
      Read [GAC]GAC0=[M:FPC]COA([M:FPC]IASLEDTYP-1);[L]GACIAS
      If fstat : RMESSAGE=[M:FPC]COA([M:FPC]IASLEDTYP-1)-"<"+[L]GACIAS+">"-mess(44,102,1)-"("+num$(fstat)+")" : Gosub TRAITE_ERREUR : Return : Endif

      [L]FLGEXPCRE(2)  = [F:GAC]FLGEXPCRE
      [F:LOF]IASACC    = [F:GAC]ACC
      [F:LOF]IASACCORI = [F:GAC]ACC
      [F:LOF]IASACN    = [F:GAC]GACACN

      If [L]GACACC = "" and find([M:FPC]COA([M:FPC]GENLEDTYP-1),[F:GAC]OTHCOA)
        [L]GACACC = [F:GAC]DEFACC(find([M:FPC]COA([M:FPC]GENLEDTYP-1),[F:GAC]OTHCOA)-1)
        If [L]GACACC <> ""
          Read [GAC]GAC0=[M:FPC]COA([M:FPC]GENLEDTYP-1);[L]GACACC
          If fstat : RMESSAGE=[M:FPC]COA([M:FPC]GENLEDTYP-1)-"<"+[L]GACACC+">"-mess(44,102,1)-"("+num$(fstat)+")" : Gosub TRAITE_ERREUR : Return : Endif

          [L]FLGEXPCRE(1)  = [F:GAC]FLGEXPCRE

          [F:LOF]GAC       = [F:GAC]ACC
          [F:LOF]GACORI    = [F:GAC]ACC
          [F:LOF]GACACN    = [F:GAC]GACACN
        Endif
      Endif
    Else
      [L]FLGEXPCRE(2)  = G_NON
    Endif
  Else
    [L]FLGEXPCRE(2)  = G_NON
  Endif
Return

#########################################
# Recherche des taux associés au code TVA
#########################################
$LEC_VAT
  If [L]TAX = ""
    # Le code taxe peut ne pas être renseigné. Dans ce cas on estime que les taux de TVA et TVA récupérée sont à zéro
    [F:LOF]RATVAT    = 0
    [F:LOF]RATVATREC = 0
    Return
  Endif

  ## Issue 116402  si régime CEE ==> auto-liquidation de la TVA ==> taux de TVA facturée/récupérée nuls
  Read [TVT]TVT0 = [L]TAX;GCURLEG
  If fstat
    Read [TVT]TVT0 = [L]TAX;""
  Else
    fstat = 0
  Endif
  Call LEC_TVB(GCURLEG,[F:TVT]VATVAC) From CPTLEC
  If !fstat
    If [F:TVB]REGVAC=4  # régime CEE
      [F:LOF]RATVAT    = 0
      [F:LOF]RATVATREC = 100 # sinon lors de l'immobilisation de la dépense le taux de TVA facturé est recalculé
     Return
    Endif
  Endif
  # End issue 116402

  #[L]DAT     = [F:LOF]DATIMP # FQ100587
  [L]DAT     = [F:LOF]DATVCR  # FQ100587
  [L]COMPANY = [F:LOF]CPY

  Gosub LECTAX From SUBTVT

  If ![L]STAT
    [F:LOF]RATVAT    = [L]TAUX1
    [F:LOF]RATVATREC = [L]TAUX2
  Else
    Call ERR_CALTAXE([L]STAT,RMESSAGE) From SUBTVT
    Case [L]OBJORI
      When "PIH"
        RMESSAGE = RMESSAGE-"("+mess(61,100,1)-num$([F:PID]PIDLIN)+","-mess(37,100,1)-[L]TAX+")"
      When "BIS"
        RMESSAGE = RMESSAGE-"("+mess(61,100,1)-num$([F:PIL]LIG)+","-mess(37,100,1)-[L]TAX+")"
      When "HAE"
        RMESSAGE = RMESSAGE-"("+mess(61,100,1)-num$(LINCUR)+","-mess(37,100,1)-[L]TAX+")" : # FQ70141 : correction [M:HAEW]NUMLIG(LINCUR) -> LINCUR
      When "PYD"
        RMESSAGE = RMESSAGE-"("+mess(61,100,1)-num$([F:PYD]LIN)+","-mess(37,100,1)-[L]TAX+")"
    Endcase
    Gosub TRAITE_ERREUR
  Endif
Return

#########################################
# Intitialisation des champs TVA 2008
#########################################
$INI_2008_VAT
  [F:LOF]TAXCOE    = arr([F:LOF]RATVATREC/100, 0.01)
  [F:LOF]TAXCOEFLG = 1
  [F:LOF]ASJCOE    = 1.
  [F:LOF]ADMCOE    = 1.

  If [F:LOF]RATVATREC = 100 or [L]VATAUTVAL = G_OUI or [F:CPY]LEG <> "FRA" : # FQ57785
    [F:LOF]FLGVAL = 2
  Else
    [F:LOF]FLGVAL = 1
  Endif
Return

########################################################
# Gestion des flags de montant forcé (TVA et TVA récup.)
########################################################
$PUT_FLG_FORCE

#* Local Decimal MNT
## si les montants de TVA ou de TVA récupérable sont différents des montants qu'on calculerait avec les taux
## de TVA et de TVA récupérable, on positionne les flags de montant forcé
#  [F:LOF]FLGVATFCR  = G_NON
#  [F:LOF]FLGRECFVR  = G_NON
#
#  [L]MNT = [F:LOF]AMTNOTCUR * [F:LOF]RATVAT / 100
#  Call ARRDEV([L]MNT,[F:LOF]CUR) From TRTDIV
#  If [F:LOF]AMTVATCUR <> [L]MNT
#    [F:LOF]FLGVATFCR = G_OUI
#  Else
#    [F:LOF]FLGVATFCR = G_NON
#  Endif
#
#  [L]MNT = [F:LOF]AMTVATCUR * [F:LOF]RATVATREC / 100
#  Call ARRDEV([L]MNT,[F:LOF]CUR) From TRTDIV
#  If [F:LOF]AMTVATRCUR <> [L]MNT
#    [F:LOF]FLGRECFVR = G_OUI
#  Else
#    [F:LOF]FLGRECFVR = G_NON
#  Endif
##*FQ98116 END

##*FQ98116 les montants de TVA sont toujours forcés
  [F:LOF]FLGVATFCR = G_OUI
  [F:LOF]FLGRECFVR = G_OUI

Return

#################################################################################### FQ102796
# Alimentation du type de dépense en fonction du type de facture
#
#  INVTYP (facture ML645)    TYPVCR (dépense ML3117)
#  1 - Facture          ->   1 - Facture
#  2 - Avoir            ->   2 - Avoir
#  3 - Note de débit    ->   1 - Facture
#  4 - Note de crédit   ->   2 - Avoir
#  5 - Proforma         ->   1 - Facture
####################################################################################
Funprog GET_TYPVCR_FROM_INVTYP(INVTYP)
Value Integer INVTYP

  Local Integer RESULT

  Case INVTYP
    When 2, 4    : RESULT = 2
    When Default : RESULT = 1
  Endcase
End RESULT

####################################################################################
# Inversion des montant et changement du type si montants négatifs
####################################################################################
$AVOIR_AMT

#  If [F:LOF]AMTNOTCUR < 0 : # FQ77257
#    [F:LOF]AMTNOTCUR  = -[F:LOF]AMTNOTCUR
#    [F:LOF]AMTVATCUR  = -[F:LOF]AMTVATCUR
#    [F:LOF]AMTVATRCUR = -[F:LOF]AMTVATRCUR
#    [F:LOF]AMTNOTCPY  = -[F:LOF]AMTNOTCPY
#    [F:LOF]AMTVATCPY  = -[F:LOF]AMTVATCPY
#    [F:LOF]AMTVATRCPY = -[F:LOF]AMTVATRCPY
#
#    Case [F:LOF]TYPVCR
#      When GVML_TDFACT  : [F:LOF]TYPVCR = GVML_TDAVOIR
#      When GVML_TDAVOIR : [F:LOF]TYPVCR = GVML_TDFACT
#    Endcase
#  Endif
  # FQ81533

  #FQ68023 If [F:LOF]TYPVCR = GVML_TDAVOIR
  #FQ68023 Ajout test s/type facture Escompte/Agios
  If [F:LOF]TYPVCR = GVML_TDAVOIR or [F:LOF]TYPVCR = GVML_TDESCAG
    [F:LOF]AMTNOTCUR  = -[F:LOF]AMTNOTCUR
    [F:LOF]AMTVATCUR  = -[F:LOF]AMTVATCUR
    [F:LOF]AMTVATRCUR = -[F:LOF]AMTVATRCUR
    [F:LOF]AMTNOTCPY  = -[F:LOF]AMTNOTCPY
    [F:LOF]AMTVATCPY  = -[F:LOF]AMTVATCPY
    [F:LOF]AMTVATRCPY = -[F:LOF]AMTVATRCPY
  Endif

  If [F:LOF]TYPVCR = GVML_TDAVOIR
    If [F:LOF]AMTNOTCUR < 0
      [F:LOF]TYPVCR = GVML_TDFACT
    Endif
  Endif

Return

########################################################
# Calcul des montants en devise société
########################################################
$AMT_CPY
  Local Decimal MNT

  If [F:LOF]CUR = [F:CPY]ACCCUR
    # Si devise société est identique à la devise facture, on prend directement le montant en devise de la facture
    [F:LOF]AMTNOTCPY = [F:LOF]AMTNOTCUR
  Else
    # sinon on convertit le montant en devise facture
    [L]MNT = [F:LOF]AMTNOTCUR * [F:LOF]RATCUR
    Call ARRDEV([L]MNT,[F:CPY]ACCCUR) From TRTDIV
    [F:LOF]AMTNOTCPY = [L]MNT
  Endif

  # Montant TVA : on regarde si le montant de TVA en devise de transaction a été forcé. Si c'est le cas on
  # convertit le montant de TVA en devise transaction, sinon on le détermine à partir du montant HT en devise société
  If [F:LOF]FLGVATFCR = G_OUI
    # Montant forcé
    [L]MNT = [F:LOF]AMTVATCUR * [F:LOF]RATCUR
    Call ARRDEV([L]MNT,[F:CPY]ACCCUR) From TRTDIV
  Else
    # Montant non forcé. On calcule le montant de TVA à partir du montant HT
    [L]MNT = [F:LOF]AMTNOTCPY * [F:LOF]RATVAT / 100
    Call ARRDEV([L]MNT,[F:CPY]ACCCUR) From TRTDIV
  Endif
  [F:LOF]AMTVATCPY = [L]MNT

  # Montant TVA récupérée : on regarde si le montant de TVA récupérée en devise de transaction a été forcé. Si c'est le cas on
  # convertit le montant de TVA récupérée en devise transaction, sinon on le détermine à partir du montant de TVA en devise société
  If [F:LOF]FLGRECFVR = G_OUI
    # Montant forcé
    [L]MNT = [F:LOF]AMTVATRCUR * [F:LOF]RATCUR
    Call ARRDEV([L]MNT,[F:CPY]ACCCUR) From TRTDIV
  Else
    # Montant non forcé. On calcule le montant de TVA récupérée à partir du montant de TVA
    [L]MNT = [F:LOF]AMTVATCPY * [F:LOF]RATVATREC / 100
    Call ARRDEV([L]MNT,[F:CPY]ACCCUR) From TRTDIV
  Endif
  [F:LOF]AMTVATRCPY = [L]MNT
Return

####################################################################################
# Associations à partir de la famille sur le dépense AbelX3
# Ces traitements sont des simplifications des traitements AbelX3 de TRTASSO
####################################################################################
$GERER_ASSOCIATION
Local Integer J

#* On recherche s'il existe une association pour la société
Read [RDE]RDE0=1;1;[F:CPY]ACM;[F:LOF]CPY
If fstat | [F:RDE]ENAFLG <> 2
  # Ou par défaut
  Read [RDE]RDE0=1;1;[F:CPY]ACM;""
Endif
If !fstat & [F:RDE]ENAFLG = 2
  # Il y a une association de définie et elle est active
  Read [RVA]RVA0="11"+[F:CPY]ACM+[F:RDE]CPY;[F:LOF]ACGGRP
  If fstat=0
    # Il y a une associatin pour cette famille
    For J = 0 To [F:RDE]NBRUB0-1
      If [F:RDE]RUBRAS(J)<>"" & [F:RDE]MGTFLG(J) = 2
        I=find([F:RDE]RUBRAS(J),[F:RVA]RUBRAS(0..[F:RVA]NBLIG-1))-1
        If I >= 0
          If [F:RVA]VALDETEAS(I) <> ""
            # Lecture du type de la rubrique dans la table LAYOUTFAS
            Read [ZATZ]CODZONE="LAYOUTFAS";[F:RVA]RUBRAS(I)
            If fstat
              [L]RET=1
              Return
            Endif

            # Lecture du type dans la table des type pour avoir le type interne
            Read [ZATY]CODTYP=[F:ZATZ]CODTYP
            If fstat
              [L]RET=1
              Return
            Endif

            # Formats définis dans le menu local 30
            Case [F:ZATY]TYPTYP
              When 1, 2, 3, 4, 5, 6
                Assign "[F:LOF]"+[F:RVA]RUBRAS(I) With val([F:RVA]VALDETEAS(I))
              When 8
                # on ne traite pas les dates
              When Default
                Assign "[F:LOF]"+[F:RVA]RUBRAS(I) With [F:RVA]VALDETEAS(I)
            Endcase
          Endif
        Endif
      Endif
    Next J
  Endif
Endif
Return

########################
# Formatage du message #
########################

$TRAITE_ERREUR
  Local Char REFNUM(GLONVCR)

  #RMESSAGE = mess(134,104,1)-":"-[F:PIH]NUM-RMESSAGE : # FQ83288
  Case [L]OBJORI
    When "PIH" : [L]REFNUM = [F:PIH]NUM
    When "BIS" : [L]REFNUM = [F:PIH]NUM
    When "HAE" : [L]REFNUM = [M]NUM
    When "VAL" : [L]REFNUM = [F:HAE]NUM
    When "PYH" : [L]REFNUM = [F:PYH]NUM      #FQ68023
    When "STJ" : [L]REFNUM = [F:STJ]NUMVCR   #FQ102691
  Endcase

  RMESSAGE = mess(134,104,1)-":"-[L]REFNUM-RMESSAGE
  GOK = 0
Return

##########################################################################################
## FQ68023_2  Creation of FA expense when payment with early discount line
########################################################################################
$ALIM_PYD

  Local Decimal MNT, AMTVAT, AMTVATREC
  Local Integer WRET
  Local Char    WLEG (20)
  Local Integer NUMLIG
  Call GETLEG([F:PYH]CPY,"G",WLEG) From TRTLECLEG

  [F:LOF]           = [F:PYH]

  [F:LOF]TYPVCR = GVML_TDESCAG           : # P27 NEW : Discount/Agios

  # Issue 118031
  If func SUBLOF2.CTL_FMT("LAYOUTFAS", "CODLOF", [F:PYD]VCRNUM, RMESSAGE) = 0
    GOK = 0
    Return
  Endif
  # End Issue 118031

  [F:LOF]FCY        = [F:PYD]FCYLIN
  [F:LOF]CODLOF     = [F:PYD]VCRNUM       : # Document no.

  # Reading expense generated when validation of the invoice
  Filter [LOFP] Where CODLOF = [F:PYD]VCRNUM
    Read[LOFP]LOF0 Last
  Filter [LOFP]

  [L]NUMLIG         = [F:LOFP]LINLOF      : # Last line
  [F:LOF]DATVCR     = [F:PYH]ACCDAT       : # Invoice date
  [F:LOF]DATIMP     = [F:PYH]ACCDAT       : # Allocation date

  [F:LOF]DES        = mess(101,7772,1)    : # "Early discount/late charge"
  [F:LOF]DES2       = [F:PYD]DESLIN       : # Description payment line
  [F:LOF]BPR        = [F:PYH]BPR          : # Business Partner
  [F:LOF]BPRVCR     = [F:PYH]NUM          : # Payment no.

  [F:LOF]FLGGRA     = 1                   : # Subsidised Flag (No)
  [F:LOF]FLGAMTGRA  = 1                   : # Subsidy strength (No)
  [F:LOF]FLGLIKAAS  = 1                   : # Asset link (No)
  [F:LOF]FLGLOFMAI  = 1                   : # Principal expense (No)
  [F:LOF]FLGDETEXP  = G_OUI               : # détachable Flag FQ104360

  [F:LOF]CREORI     = 4                   : # Entry origin = "Interface"
  [F:LOF]CPMCREORI  = 4                   : # NEW : Règlement

  [F:LOF]ITMREF    = ""
  [F:LOF]UOM = [L]DEFUOM                   : # Unit by default
  If [F:PYD]QTYLIN > 0
    [F:LOF]QTY       = [F:PYD]QTYLIN
  Else
    [F:LOF]QTY  = 1
  Endif

  [F:LOF]CUR        =  [F:PYD]CURLIN      : # Currency payment line
  [F:LOF]CURTYP     =  1                  : # Rate type
  Call CDVCAL([F:LOF]RATCUR, [F:PYD]CURLIN , GCOUDEV, [F:PYH]CPY,[F:LOF]CURTYP, [F:PYH]ACCDAT) From TRTDIV

  # reading accounts
  [L]GACACC = [F:PYD]ACC([M:FPC]GENLEDTYP-1)

  If [M:FPC]FLGIAS = G_OUI
    [L]GACIAS = [F:PYD]ACC([M:FPC]IASLEDTYP-1)
  Endif

  [F:LOF]ACGGRP = ""

  Gosub CHARGE_COMPTES
  If fstat
    [F:LOF]GAC        = [L]GACACC
    [F:LOF]GACORI     = [L]GACACC
    [F:LOF]IASACC     = [L]GACIAS
    [F:LOF]IASACCORI  = [L]GACIAS
  Endif

  # CoA natures are the same as the initial expense
  [F:LOF]GACACN       = [F:LOFP]GACACN
  [F:LOF]IASACN       = [F:LOFP]IASACN

  ###
  ### CONSISTENCY CHECKS ###
  ###
  # If no account tracked  : nothing is done
  If ([M:FPC]FLGIAS =  G_OUI and [L]FLGEXPCRE(1)<> G_OUI and [L]FLGEXPCRE(2)<> G_OUI)
&     or ([M:FPC]FLGIAS <> G_OUI and [L]FLGEXPCRE(1)<> G_OUI)
    Infbox "FLGIAS control is KO"
    GOK=0
    Return
  Endif

  # If one account tracked : Warning
  If ([M:FPC]FLGIAS = G_OUI) and ([L]FLGEXPCRE(1)<> G_OUI and [L]FLGEXPCRE(2)=  G_OUI)
    If dim([M]XCPYFLG)<0 :
      # Social account not tracked and IAS account tracked. Do you wish to continue?
      Call OUINON([F:PYD]NUM-mess(72,7772,1)-num$([F:PYD]LIN)-":"-mess(77,7772,1)-mess(205,100,1),OK) From GESECRAN
      If OK<>2
        RMESSAGE=num$([F:PYD]LIN)-":"-mess(77,7772,1) : Gosub TRAITE_ERREUR : Return
      Else
#       Goto SUITE_PYD
        Return
      Endif
    Else
      RMESSAGE=num$([F:PYD]LIN)-":"-mess(77,7772,1) : Gosub TRAITE_ERREUR : Return
    Endif
  Endif
  ###
  ### END CONSISTENCY CHECKS ###

  # Invd VAT rate and  Recovered VAT
  [L]TAX           = [F:PYD]VATLIN
  # On récupère RATVAT  et RATVATREC
  Gosub LEC_VAT
  If [L]STAT : GOK = 0 : Return :  Endif
  Gosub INI_2008_VAT

  # Amount ex-tax cur
  [L]MNT =  [F:PYD]AMTLIN / (1+([F:LOF]RATVAT/100))
  Call ARRDEV( [L]MNT,[F:LOF]CUR) From TRTDIV
  [F:LOF]AMTNOTCUR =  [L]MNT

  # VAT amt currency
  [L]AMTVAT =  [F:LOF]AMTNOTCUR *([L]TAUX1/100)
  Call ARRDEV([L]AMTVAT,[F:LOF]CUR) From TRTDIV
  [F:LOF]AMTVATCUR = [L]AMTVAT

  # Recovered VAT amt
  [L]AMTVATREC = [F:LOF]AMTVATCUR * ([F:LOF]RATVATREC / 100)
  Call ARRDEV([L]AMTVATREC,[F:LOF]CUR) From TRTDIV
  [F:LOF]AMTVATRCUR = [L]AMTVATREC

  # Amounts in company currency if same currencies
  If [F:LOF]CUR = [F:CPY]ACCCUR
    [F:LOF]AMTNOTCPY  = [F:LOF]AMTNOTCUR
    [F:LOF]AMTVATCPY  = [F:LOF]AMTVATCUR
    [F:LOF]AMTVATRCPY = [F:LOF]AMTVATRCUR
  Endif

  Gosub PUT_FLG_FORCE # maj FLGRECFVR et FLGVATFCR
  Gosub AMT_CPY
  Gosub AVOIR_AMT

  # Analytical payment lines
  Filter[PYA] Where NUM=[F:PYD]NUM and LIN=[F:PYD]LIN
    Read [PYA] First
    If fstat=0
      [F:LOF]DSP    = [F:PYD]DSP
      For N_I=0 To dim(GDIE)-1
        [F:LOF]DIE(N_I) = [F:PYA]DIE(N_I)
        [F:LOF]CCE(N_I) = [F:PYA]CCE(N_I)
      Next
    Endif
  Filter[PYA]

  [F:LOF]CPMCREORI  = 4              : # Additional entry source = "Payment"
  [F:LOF]LIGORI     = [F:PYD]LIN     : # Detail line source
  [F:LOF]TYPORI     = [F:PYD]VCRTYP  : # Entry type

  [F:LOF]FCY = [F:PYD]FCYLIN

  Gosub ECRIRE_DEP

Return
########################################################################################
## FQ68023_3  Accounting cancellation ==> new expense or cancellation of an expense   ##
########################################################################################
$MAJ_ANU_PYD

 Local Char CRITLOF(255)
 Local Integer NUMLIG
 Local Shortint NB_LOF     :  # Nunber of expenses created
 Local Char OBJORI(3)      :  # Source object
 Local Decimal WMT_TTC

 [L]OBJORI = "PYD"
 CRITLOF="CODLOF=[F:PYD]VCRNUM and CPMCREORI= 4 and BPRVCR=[F:PYD]NUM"

 If clalev([F:LOF])=0  : Local File LAYOUTFAS [LOF] : Endif
 If clalev([F:RLOF])=0 : Local File LAYOUTFAS [RLOF] : Endif

 For [RLOF] Where evalue(CRITLOF) With Stability
   Readlock  [RLOF]
   If fstat
     # An expense coming from this invoice is locked.  Cancellation not possible
     Call ECR_TRACE(mess(77,119,1)+"."-mess(49,117,1),1) From GESECRAN
     GOK = 0
     Break
   Elsif ([F:RLOF]FLGLIKAAS=2)
     [F:LOF]=[RLOF]
     [F:LOF]AASREF = ""
     [F:LOF]FLGLIKAAS=1
     [L]NUMLIG  =  [F:LOF]LINLOF
     [F:LOF]DES2 = mess(102,7772,1)         : # "Accounting cancellation"
     [F:LOF]CREDAT = date$
     [F:LOF]CREORI = 4
     [F:LOF]CREUSR = GUSER
     [F:LOF]TYPVCR = GVML_TDESCAG
     Gosub AVOIR_AMT
     [L]NUMLIG += 1
     [F:LOF]LINLOF = [L]NUMLIG             : # Expense new line
      Write [F:LOF]
      If fstat : RMESSAGE=mess(76,7772,1)-[F:LOF]CODLOF-num$([F:LOF]LINLOF)-" fstat : "-num$(fstat) : Gosub TRAITE_ERREUR : Endif
      # Generated expense(s)
      Call ECR_TRACE(mess(141,104,1)-" : "-num$([F:LOF]CODLOF-"/"-num$([F:LOF]LINLOF)),0) From GESECRAN
      [L]NB_LOF += 1
     Break
   Else
     # Expense are not locked and capitalized
     # Cancelled expense(s)
     Call ECR_TRACE(mess(103,7772,1)-" : "-num$([F:RLOF]CODLOF-"/"-num$([F:RLOF]LINLOF)),0) From GESECRAN
     Delete [RLOF] Curr
     Break
   Endif
 Next

Return
##########################################################################################
## FQ102691 Creation of FA expense when Stock issue
########################################################################################
$ALIM_STJ

  Local Decimal MNT, AMTVAT, AMTVATREC
  Local Integer WRET
  Local Integer NUMLIG
  Local Char    GACACC(GLONGAC), GACIAS(GLONGAC)
  Local Char    WCOA(GLONCOA), WCOAIAS(GLONCOA)

  #*FQ102691 Lecture du numéro de la ligne de compte à récupérer pour les sorties de stock
  Local Integer LACCLIN
  Call PARAM([L]LCPY,"STKISSACC",[L]LPARAM) From ADOVAL
  [L]LACCLIN = val([L]LPARAM)
  # Issue 110082
  If [L]LACCLIN <= 0
      RMESSAGE= mess(108,7772,1)-" : "-num$([L]LCPY) : Gosub TRAITE_ERREUR : Return
  Endif  # End issue 110082

  # Charts of accounts
  WCOA    = [M:FPC]COA([M:FPC]GENLEDTYP-1)
  # Issue 110082   WCOAIAS = [M:FPC]COA([M:FPC]IASLEDTYP-1)

  [F:LOF]           = [F:STJ]

  [F:LOF]TYPVCR     = 7                   : #  Stock issue (ML 3117)
  [F:LOF]CPY        = [L]LCPY

  #X3-89474  [F:LOF]FCY   = [F:STJ]STOFCY : # Stockage site (non-financial site)
  If [F:STJ]FINRSPFCY <> ""
    [F:LOF]FCY      = [F:STJ]FINRSPFCY    : # financial site
  Else
    Read[FCY]FCY0=[F:STJ]STOFCY
    If fstat=0
      [F:LOF]FCY    = [F:FCY]FINRSPFCY
    Endif
  Endif

  [F:LOF]CODLOF     = [F:STJ]VCRNUM       : # Document no.

  # End Issue 118031
  If func SUBLOF2.CTL_FMT("LAYOUTFAS", "CODLOF", [F:STJ]VCRNUM, RMESSAGE) = 0
    GOK = 0
    Return
  Endif
  # End Issue 118031

  # On vérifie s'il existe ou non une dépense avec même n° de pièce
  Filter [LOFP] Where CODLOF = [F:STJ]VCRNUM
    Read[LOFP]LOF0 Last
    If fstat
      Raz [F:LOFP]
    Endif
  Filter [LOFP]

  [L]NUMLIG         = [F:LOFP]LINLOF      : # Last line
  [F:LOF]DATVCR     = [F:STJ]IPTDAT       : # Allocation date
  If [F:STJ]ACCDAT <> [0/0/0]
    [F:LOF]DATIMP   = [F:STJ]ACCDAT       : # Accounting date
  Else
    [F:LOF]DATIMP   = [F:STJ]IPTDAT
  Endif

  # On récupère le code Journal par défaut sur le type de pièce
  [F:LOF]JOU        = [M:HAE0]JOU

  [F:LOF]DES        = [F:ITM]ITMDES1      : # Item Designation 1
  [F:LOF]DES2       = [F:ITM]ITMDES2      : # Item Designation 2

  [F:LOF]FLGGRA     = 1                   : # Subsidised Flag (No)
  [F:LOF]FLGAMTGRA  = 1                   : # Subsidy strength (No)
  [F:LOF]FLGLIKAAS  = 1                   : # Asset link (No)
  [F:LOF]FLGLOFMAI  = 1                   : # Principal expense (No)
  [F:LOF]FLGDETEXP  = G_OUI               : # détachable

  [F:LOF]CREORI     = 4                   : # Entry origin = "Interface"
  [F:LOF]CPMCREORI  = 6                   : # Stock issue (ML3107)

  [F:LOF]ITMREF     = [F:STJ]ITMREF
  [F:LOF]UOM        = [F:STJ]STU          : # Unit
  If [F:LOF]UOM     = ""
    [F:LOF]UOM      = [L]DEFUOM           : # Unit by default
  Endif
  [F:LOF]QTY        = [F:STJ]QTYSTU*(-1)

  [F:LOF]CUR        = [F:CPY]ACCCUR       : # Company currency
  [F:LOF]CURTYP     = 1                   : # Day Rate
  Call CDVCAL([F:LOF]RATCUR, [F:LOF]CUR , GCOUDEV, [F:LOF]CPY ,[F:LOF]CURTYP, [F:STJ]ACCDAT) From TRTDIV
  If [F:LOF]RATCUR=0
    [F:LOF]RATCUR=1
  Endif

  # Famille comptable
  [F:LOF]ACGGRP = func GLOBIENS.GET_FAMILLE_ARTICLE ([F:ITM]ITMREF, [M:FPC]LEG)
  If [F:LOF]ACGGRP <> ""
    Gosub GERER_ASSOCIATION
    If [L]RET
      # Erreur dans les associations (Famille)
      [L]LIBERR = mess(124,104,1)-"("+[F:LOF]ACGGRP+")"
      GOK=0
    Endif
  Endif

  # reading accounts
  Read [CAC]CAC0=1;[F:ITM]ACCCOD;WCOA
  If fstat=0
    [L]GACACC=[F:CAC]ACC([L]LACCLIN-1)
    Read [GAC]GAC0=[M:FPC]COA([M:FPC]GENLEDTYP-1);[L]GACACC
    If fstat
      RMESSAGE=[M:FPC]COA([M:FPC]GENLEDTYP-1)-"<"+[L]GACACC+">"-mess(44,102,1)-"("+num$(fstat)+")"
      Gosub TRAITE_ERREUR
      Return
    Endif
    [L]FLGEXPCRE(1)  = [F:GAC]FLGEXPCRE
    [F:LOF]GACACN       = [F:GAC]GACACN
  Else
    RMESSAGE=[M:FPC]COA([M:FPC]GENLEDTYP-1)-"<"+[F:ITM]ACCCOD+">"-mess(44,102,1)-"("+num$(fstat)+")"
    Gosub TRAITE_ERREUR
    Return
  Endif

  If [M:FPC]FLGIAS = G_OUI
    WCOAIAS = [M:FPC]COA([M:FPC]IASLEDTYP-1)    # Issue 110082
    Read [CAC]CAC0=1;[F:ITM]ACCCOD;WCOAIAS
    If fstat=0
      [L]GACIAS=[F:CAC]ACC([L]LACCLIN-1)
      Read [GAC]GAC0=[M:FPC]COA([M:FPC]IASLEDTYP-1);[L]GACIAS
      If fstat
        RMESSAGE=[M:FPC]COA([M:FPC]IASLEDTYP-1)-"<"+[F:ITM]ACCCOD+">"-mess(44,102,1)-"("+num$(fstat)+")"
        Gosub TRAITE_ERREUR
        Return
      Endif
      [L]FLGEXPCRE(2)  = [F:GAC]FLGEXPCRE
      [F:LOF]IASACN    = [F:GAC]GACACN
    Else
      RMESSAGE=[M:FPC]COA([M:FPC]IASLEDTYP-1)-"<"+[F:ITM]ACCCOD+">"-mess(44,102,1)-"("+num$(fstat)+")"
      Gosub TRAITE_ERREUR
      Return
    Endif
  Endif

  [F:LOF]GAC        = [L]GACACC
  [F:LOF]GACORI     = [L]GACACC
  [F:LOF]IASACC     = [L]GACIAS
  [F:LOF]IASACCORI  = [L]GACIAS

  ###
  ### CONSISTENCY CHECKS ###
  ###
  # Article immobilisable et comptes non suivis : avertissement
  If (  [M:FPC]FLGIAS  =  G_OUI and ([L]FLGEXPCRE(1)<> G_OUI and [L]FLGEXPCRE(2)<> G_OUI))
&   or ([M:FPC]FLGIAS  <> G_OUI and  [L]FLGEXPCRE(1)<> G_OUI)
    If dim([M]XCPYFLG)<0 : # Pour savoir si on est en interactif ou en validation massive
      # ==> <LIGNE:> Comptes social et IAS non immobilisables et article immobilisable. Voulez-vous continuer ?
      Call OUINON([F:STJ]VCRNUM-"-"-num$([F:STJ]VCRLIN)-":"-mess(73,7772,1)-mess(205,100,1),OK) From GESECRAN
      If OK<>2
         RMESSAGE=num$([F:STJ]VCRLIN)-":"-mess(73,7772,1)-"("+[F:ITM]ITMREF+")." : Gosub TRAITE_ERREUR : Return
      Else
        Return
      Endif
    Else
      RMESSAGE=num$([F:STJ]VCRLIN)-":"-mess(73,7772,1)-"("+[F:ITM]ITMREF+")." : Gosub TRAITE_ERREUR : Return
    Endif
  Endif

  # Un seul compte suivi : avertissement
  If ([M:FPC]FLGIAS = G_OUI) and ([L]FLGEXPCRE(1)<> G_OUI and [L]FLGEXPCRE(2)=  G_OUI)
    If dim([M]XCPYFLG)<0 : # Pour savoir si on est en interactif ou en validation massive
      #==> <LIGNE:>==>  Compte social non suivi et compte IAS suivi. Voulez-vous continuer ?
      Call OUINON([F:STJ]VCRNUM-"-"-num$([F:STJ]VCRLIN)-":"-mess(77,7772,1)-mess(205,100,1),OK) From GESECRAN
      If OK<>2
         RMESSAGE=num$([F:STJ]VCRLIN)-":"-mess(77,7772,1)-"("+[F:ITM]ITMREF+")." : Gosub TRAITE_ERREUR : Return
      Else
        Return
      Endif
    Else
      RMESSAGE=num$([F:STJ]VCRLIN)-":"-mess(77,7772,1)-"("+[F:ITM]ITMREF+")." : Gosub TRAITE_ERREUR : Return
    Endif
  Endif
  ###
  ### END OF CONSISTENCY CHECKS ###

  [F:LOF]TAXCOE  = 1
  [F:LOF]ACT     = ""

  # Le code taxe n'est pas renseigné : les taux de TVA et TVA récupérée sont à zéro
  [F:LOF]RATVAT    = 0
  [F:LOF]RATVATREC = 0

  Gosub INI_2008_VAT

  Call ARRDEV([F:STJ]VARVAL,[F:LOF]CUR) From TRTDIV
  [F:LOF]AMTNOTCUR =  [F:STJ]VARVAL*(-1)

  # Amounts are always in company currency for stock issues
  [F:LOF]AMTNOTCPY  = [F:LOF]AMTNOTCUR

  # Analytical payment lines
  For N_I=0 To dim(GDIE)-1
    [F:LOF]DIE(N_I) = [F:STJ]DIE(N_I)
    [F:LOF]CCE(N_I) = [F:STJ]CCE(N_I)
  Next

  [F:LOF]LIGORI    =    [F:STJ]VCRLIN  : # Detail line source
  [F:LOF]TYPORI    =    [F:STJ]GTE     : # Entry type

  Gosub ECRIRE_DEP

Return

# Issue 118031
Funprog CTL_FMT(PTABBLE, PCHAMP, PVALEUR, RMESSAGE)
Value Char PTABBLE(), PCHAMP(), PVALEUR()
Variable Char RMESSAGE()

Local Char WFMT(50)

  WFMT = format$("K:" + num$(len(PVALEUR)) +  "c", PVALEUR)
  WFMT = vireblc(WFMT, 4)

  If WFMT <> PVALEUR
    RMESSAGE = func AFNC.MES1(mess(109, 7772, 1), PVALEUR)
    End [V]CST_AFALSE
  Endif

End [V]CST_ATRUE

