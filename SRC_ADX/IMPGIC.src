#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
#    Process Name:    IMPGIC - GL Intercompany journal import  SAM #100597
#
#    Authors:         BeSpr   Jul, 2014
#
#    Modifications:
#                     BeSpr   Jul xx, 2014   xxxx
######################################################################################
######################################################################################
$ACTION
Case ACTION
 When "IMP_OUVRE"     : Gosub OUVRE
 When "IMP_RAZCRE"    : Gosub RAZCRE
 When "IMPORT"        : Gosub IMPORT
 When "IMP_ZONE"      : Gosub IMP_ZONE
 When "IMP_TAB"       : Gosub IMP_ZONE
Endcase
Return

###################################################################################
$OUVRE

# From SUBGIC
If clalev([M:VTL])  = 0 : Local Mask VENTILE  [VTL]  : Endif
If clalev([M:VT2])  = 0 : Local Mask VENTILE2 [VT2]  : Endif
# Screens of working
Local Mask GACCENTFMT  [HAEF]        # Openning of screen for miscellaneous informations
Local Mask SAICURLED   [SCL]         # Openning of screen for management of currencies

# From GASIMPORT and SUBGIC
If clalev([F:FCY]) = 0  : Local File  FACILITY  [FCY]  : Endif
If clalev([F:CPY]) = 0  : Local File  COMPANY   [CPY]  : Endif
If clalev([F:GCM]) = 0  : Local File  GACM      [GCM]  : Endif
If clalev([F:LED]) = 0  : Local File  GLED      [LED]  : Endif
If clalev([F:COA]) = 0  : Local File  GCOA      [COA]  : Endif
If clalev([F:GAC]) = 0  : Local File  GACCOUNT  [GAC]  : Endif

If clalev([M:GIC1])=0 : Local Mask GACCINTCPY   [GIC1] : Endif
If clalev([M:HAEW])=0 : Local Mask GACCENTW     [HAEW] : Endif
If clalev([M:HAEF])=0 : Local Mask GACCENTFMT   [HAEF] : Endif
If clalev([M:SCL]) =0 : Local Mask SAICURLED    [SCL]  : Endif
If clalev([M:VTL]) =0 : Local Mask VENTILE      [VTL]  : Endif
If clalev([M:VT2]) =0 : Local Mask VENTILE2     [VT2]  : Endif

Local Integer AX , AXE, MAXECH , MAXECR , NBECH , ECH , K , NOL, OPTTV, OPTF, NBANA, NBLED, LINORI, OKCHAMP, DSPOK, I

Local Integer STAT
Local Char    MESSA(80)
Local Char    COMPTE(GLONGAC)
Local Integer NLED, TLED, VU
Local Integer OKFIELD

# From SUBGIC
Local Char    ABR(10)    : ABR="GIC1"

Return

###################################################################################
$RAZCRE

Raz [M:GIC1]
Raz [M:HAEF]
Raz [M:HAEW]
Raz [M:VTL]
Raz [M:VT2]

Return

###################################################################################
# Partly from GASIMPORT and SUBGIC; LIENS
$IMPORT

Case IMPFIC

 When "GIC"
  GSOCIETE = [F:GIC]CPY
  Call RESET_INTCPYCOA([F:GIC]CPY,[F:GIC]FCY) From INTCPYLIB
  Raz [M:GIC1]
  [M:GIC1] = [F:GIC]
  [M:GIC1]FLGPST = 1

  Call LEC_FCY([F:GIC]FCY) From CPTLEC
  If fstat <> 0
   GMESSAGE = mess(14,114,1)
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
   Raz GMESSAGE
   OK=0 : Return
  Endif

  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
  If fstat <> 0
   GMESSAGE = mess(15,114,1)
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
   Raz GMESSAGE
   OK=0 : Return
  Endif

  Call LEC_GTE_LEG([F:CPY]LEG,[F:GIC]TYP) From CPTLEC
  If fstat <> 0
   GMESSAGE = mess(17,114,1)
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
   Raz GMESSAGE
   OK=0 : Return
  Endif

  Call LEC_GCM([F:CPY]ACM) From CPTLEC
  If fstat <> 0
   GMESSAGE = mess(198,105,1)
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
   Raz GMESSAGE
   OK=0 : Return
  Endif


 When "GID"

  Call LEC_FCY([F:GID]FCYLIN) From CPTLEC
  If fstat <> 0
   GMESSAGE = mess(14,114,1)
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
   Raz GMESSAGE
   OK=0 : Return
  Endif

  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
  If fstat <> 0
   GMESSAGE = mess(15,114,1)
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
   Raz GMESSAGE
   OK=0 : Return
  Endif

  Call LEC_GTE_LEG([F:CPY]LEG,[F:GID]TYPLIN) From CPTLEC
  If fstat <> 0
   GMESSAGE = mess(17,114,1)
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
   Raz GMESSAGE
   OK=0 : Return
  Endif

  Call LEC_GCM([F:CPY]ACM) From CPTLEC
  If fstat <> 0
   GMESSAGE = mess(198,105,1)
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
   Raz GMESSAGE
   OK=0 : Return
  Endif

  # Initialize variables for the correct company
  Call RESET_INTCPYCOA([F:GID]CPYLIN,[F:GID]FCYLIN) From INTCPYLIB
  GSOCIETE = [F:GID]CPYLIN
  [M:GIC1] = [F:GID]

  # Index of the line
  [M:GIC1]NBLIG += 1
  NOL = [M:GIC1]NBLIG - 1
  nolign = [M:GIC1]NBLIG
  [F:GID]LIN = nolign  ## Needed for ANA lines as well

  [M:GIC1]CPYLIN(NOL)     = [F:GID]CPYLIN
  [M:GIC1]FCYLIN(NOL)     = [F:GID]FCYLIN
  [M:GIC1]BPR(NOL)        = [F:GID]BPR
  [M:GIC1]DES(NOL)        = [F:GID]DES
  [M:GIC1]CURLIN(NOL)     = [F:GID]CURLIN
  [M:GIC1]TAX(NOL)        = [F:GID]TAX
  [M:GIC1]DOCNUMLIN(NOL)  = [F:GID]DOCNUMLIN
  [M:GIC1]UOM(NOL)        = [F:GID]UOM
  [M:GIC1]QTY(NOL)        = [F:GID]QTY

  # The screen (HAEF) stores everything in ACC1 or ACC2 but the tables need to be stored by ledger ACC(ledger)
  # Main general
  If GTYPGEN > 0
    Assign "[M:GIC1]COA1("+num$(NOL)+")"  With [F:GID]COA(GTYPGEN-1)
    Assign "[M:GIC1]ACC1("+num$(NOL)+")"  With [F:GID]ACC(GTYPGEN-1)
    Assign "[M:GIC1]SAC1("+num$(NOL)+")"  With [F:GID]SAC(GTYPGEN-1)
  Endif
  # Main analytical
  If GTYPANA > 0 and GTYPGEN <> GTYPANA
    Assign "[M:GIC1]COA2("+num$(NOL)+")"  With [F:GID]COA(GTYPANA-1)
    Assign "[M:GIC1]ACC2("+num$(NOL)+")"  With [F:GID]ACC(GTYPANA-1)
    Assign "[M:GIC1]SAC2("+num$(NOL)+")"  With [F:GID]SAC(GTYPANA-1)
  Endif

  MONTANT = [F:GID]AMTCUR
  If [F:GID]SNS=1
   [M:GIC1]DEB(NOL) = [F:GID]AMTCUR
   [M:GIC1]TOTDEB += MONTANT
  Else
   [M:GIC1]CDT(NOL) = [F:GID]AMTCUR
   [M:GIC1]TOTCDT += MONTANT
  Endif
  [M:GIC1]SOLDE = ([M]TOTDEB-[M]TOTCDT)

  # Needs to be for all ledgers not just those entered [M:HAEF]NBRLED
  For I=1 To len(mess(0,2644,1))
   Assign "[M:GIC1]RATDIV"+num$(I)+"("+num$(NOL)+")" With [F:GID]RATDIV(I-1)
   Assign "[M:GIC1]RATMLT"+num$(I)+"("+num$(NOL)+")" With [F:GID]RATMLT(I-1)
  Next

  # Needed to remove Mandatory field setting for BPR in screen GACCINTCPY so check here
  If ([M:GIC1]SAC1(NOL) <> ""  | [M:GIC1]SAC2(NOL) <> "") & [M:GIC1]BPR(NOL) = ""
    Local Char WACC(GLONGAC)
    If [M:GIC1]SAC1(nolign-1) <> "" : WACC = [M:GIC1]ACC1(NOL) : Endif
    If [M:GIC1]SAC2(nolign-1) <> "" : WACC = [M:GIC1]ACC2(NOL) : Endif
    GMESSAGE = mess(7,21,1)+" <"+[F:GID]TYPLIN+"> "+mess(30,105,1)+" "+WACC+" :"+"/"+mess(197,107,1)+" ("+mess(3,40,1)+" "+num$(NOL+1)+")"
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    Raz GMESSAGE
    OK=0
    Return
  Endif


 When "GIA"

  If GREP="M" & [F:GIA]LIN>=1 & [F:GIA]LIN<=[M:GIC1]NBLIG
   nolign = [F:GIA]LIN
  Else
   nolign = [F:GID]LIN
  Endif
  [F:GIA]LIN = nolign

  Call RESET_INTCPYCOA([F:GID]CPYLIN,[F:GID]FCYLIN) From INTCPYLIB

  If [F:GID]DSP=""
   DSPOK = 0
    K += 1
    If !DSPOK : DSPOK = K : Endif
      [M:VT2]TBAMT(K) = [F:GIA]AMTCUR
      [M:VT2]TBQTY(K) = [F:GIA]QTY
    For I=1 To dim([F:GIA]CCE)-1
      Assign "[M:VT2]TBCCE"+num$(I)+"("+num$(K)+")" With [F:GIA]CCE(I-1)
    Next I
   If DSPOK
    If DSPOK=K
     For I=1 To dim([F:GIA]CCE)-1
      Assign "[M:GIC1]CCE"+num$(I)+"("+num$(nolign-1)+")" With evalue("[M:VT2]TBCCE"+num$(I)+"("+num$(K)+")")
      Assign "[M:VT2]TBCCE"+num$(I)+"("+num$(K)+")" With ""
     Next I
     K -= 1
    Else
     [M]PTV(nolign-1) = DSPOK
     [M]PTF(nolign-1) = K
     [M]DSP(nolign-1) = "$"
    Endif
   Endif
  Endif

  # Check for Source and Target line mandatory dimensions
  If ([M:GIC1]ACC1(NOL) <> "" or [M:GIC1]ACC2(NOL) <> "")
    Local Integer TMPERR : Raz TMPERR
    Call CHECK_MANDATORY(TMPERR,NOL)
    If TMPERR
      Call ECR_TRACE(mess(7,21,1)+" <"+[F:GID]TYPLIN+"> "+GMESSAGE+" ("+mess(3,40,1)+" "+num$(NOL+1)+")",1) From GESECRAN
      Raz GMESSAGE
      OK=0
      Return
    Endif
  Endif

Endcase

Return

###################################################################################
## Exceptions
###################################################################################
$IMP_ZONE

Case IMPZON

 When "TYP"
  # The setting of this is skipped in SUBGIC; AM_TYP when GIMPORT therefore it needs to be set here
  If [M:GIC1]TYPRAT = 0 : [M:GIC1]TYPRAT = [F:GTE]TYPRAT : Endif
  # Initialize currency rates
  If [M:GIC1]CUR <> "" & [M:GIC1]RATDIV(0) = 0
   Gosub CHARG_ZONES_DEV From SUBGIC
   Gosub INIT_COURS From SUBGIC
  Endif

 When "FCYLIN"
  [M:GIC1]CPYLIN(nolign-1) = [F:GID]CPYLIN

 When "ACC1","ACC2"
 # Needed to balanced journal not displaying when GL account blank like in GAS so zero and back out amounts
  If [M:GIC1]ACC1(nolign-1) = "" & [M:GIC1]ACC2(nolign-1) = ""
    If [M:GIC1]DEB(nolign-1) <> 0
      [M:GIC1]TOTDEB -= [M:GIC1]DEB(nolign-1)
      [M:GIC1]DEB(nolign-1) = 0
    Else
      [M:GIC1]TOTCDT -= [M:GIC1]CDT(nolign-1)
      [M:GIC1]CDT(nolign-1) = 0
    Endif
    [M:GIC1]SOLDE = ([M]TOTDEB-[M]TOTCDT)
  Endif

 When "DES"
  If [M:GIC1]DES(nolign-1) = "" : [M:GIC1]DES(nolign-1) = [M]DESNUM : Endif

Endcase

Return

###################################################################################
# Checking to see if any dimensions are missing that are mandatory in the Target company
# Some of the code is from INTCPYCCE
Subprog CHECK_MANDATORY(TMPERR, NOL)
Variable Integer TMPERR, NOL
Local Integer AXE
Local Char    TESTCCE(GLONCCE)
Local Integer NLED, TLED
Local Char LED(GLONLED)

Raz mkstat

For AXE=1 To GNBAXE
  TESTCCE = evalue ("[M:GIC1]CCE"+num$(AXE)+"("+num$(NOL)+")")
  If TESTCCE = ""
    Local Char    COMPTE(GLONGAC)
    For NLED=1 To GNBTYPLED
      COMPTE = evalue("[M:GIC1]ACC"+num$(NLED)+"("+num$(NOL)+")")
      If COMPTE<>""
        [L]TLED = GTYPLED(NLED)
        Gosub LECLED
        Call INICCE(TESTCCE,GAXE(AXE),[L]LED,evalue("[M:GIC1]ACC"+num$(NLED)+"("+num$(NOL)+")"),"") From CPTINI
        If TESTCCE <> "" : Assign "[M:GIC1]CCE"+num$(AXE)+"("+num$(NOL)+")" With TESTCCE : Endif
        Call CONTCCE(TESTCCE,[L]LED,GAXE(AXE),[M:GIC1]FCYLIN(NOL),[M:GIC1]ACCDAT,COMPTE,GAXE,"[M:GIC1]CCE#",0) From CPTCNT
        If mkstat : Break : Endif
      Endif
    Next NLED
    If mkstat : Break : Endif
  Endif
Next AXE
TMPERR = mkstat
End

$LECLED
Local Char DEV(GLONCUR)
Call LECLED ([M:GIC1]CPYLIN(nolign-1),[L]TLED,LED,DEV) From CPTDIV
Call LECTURE("LED",[L]LED,"") From CONTOBJ
Return
