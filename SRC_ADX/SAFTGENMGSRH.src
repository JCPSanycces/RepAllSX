#<AdxTL>@(#)0.0.0.0 $Revision$
$SRETURN
Gosub OPEN_LNK_SRH From SAFTGENPORMG
For [F:MGT2]
  Read [F:PTDK2]DKD0="SAFT-PT";[F:PTSRH]SRHTYP;[F:PTSRH]SRHNUM
  Call LEC_TRE_LEG([F:PTFCY]LEG, [F:PTSRH]SRHTYP, STAT) From TRTLECLEG
  If [L]SAFTTYPE = 8
    If !STAT & !find([F:PTDK2]RECTYP,1) : Goto NEXTSRH2 : Endif
    If !STAT & [F:TRE]COMAT<>2 : Goto NEXTSRH2 : Endif
    If func PORLEGLIB1.CTRL_COMDAT([F:PTSRH]STOFCY,[F:PTSRH]DPEDATR,[F:PTSRH]ETDR)<>1 : Goto NEXTSRH2 : Endif
  Endif

  Gosub RAZVAR_MG From SAFTGENPORMG
  Gosub FEED_VARS
  $NEXTSRH2
Next
Gosub CLOSE_LNK_SRH From SAFTGENPORMG
Return

$FEED_VARS
#DocumentNumber
Call PTNUMDOC([F:PTSRH]SRHTYP,[F:PTSRH]SRHNUM,[L]MGDOCNUMB) From SAFTGENPORMG

#ATCUD
[L]MGATCUD = "0"

#MovementStatuts
[L]MGMOVSTAT = 'N'

#SystemEntryDate, Reason, SourceID(Modification), Hash, HashControl, SourceID(Criation)
# Issue 105227 - 2015-08-21 by BRBAN :[L]MGMOVTYPE - MovementType must come from DKSDATA
If [F:PTDK2]RECTYP=4
  Call DOCSTAT([F:PTSRH]SRHTYP,[F:PTSRH]SRHNUM,[F:PTSRH]RTNDAT,2,[L]MGHASHCOD,[L]MGHSHCONT,[L]MGSYSENTD,[L]MGCREUSER,
&              [L]MGATCODID,[L]MGSOURCEB,[L]MGMOVTYPE) From SAFTGENPORMG
Else
  Call DOCSTAT([F:PTSRH]SRHTYP,[F:PTSRH]SRHNUM,[F:PTSRH]RTNDAT,1,[L]MGHASHCOD,[L]MGHSHCONT,[L]MGSYSENTD,[L]MGCREUSER,
&              [L]MGATCODID,[L]MGSOURCEB,[L]MGMOVTYPE) From SAFTGENPORMG
Endif

#MovementType
# Issue 105227 - 2015-08-21 by BRBAN : If it's null, then fill with [F:TRE]SAFTTRNTYP
# RMA * Do not change, this is for previous cases when we didn't have SAFTTRNTYP on DKSDATA
If [L]MGMOVTYPE=''
  Call MANDOC_TEXT_GT([F:TRE]RECTYP,[F:TRE]SAFTTRNTYP,[L]MGMOVTYPE) From PORLEGLIB
Endif

#SourceID(Criation)
If [L]MGCREUSER = ''
  [L]MGCREUSER = [F:PTSRH]CREUSR
Endif

#MovementStatusDate
[L]MGMOVSTDT = [L]MGSYSENTD
#SourceID -> DocumentStatus
[L]MGUPDUSER = [L]MGCREUSER
#Period
[L]MGPERIODE  = func SAFTGENPOR.GET_PERIOD_NUMBER([F:PTSRH]CPY, [F:PTSRH]RTNDAT)
#MovementDate
[L]MGMOVEDAT  =  format$("D:YYYY[-]MM[-]DD",[F:PTSRH]RTNDAT)

#TransactionID
#Só preencher o este campo quando estamos a tirar um SAF-T do tipo integrado.
If [L]SAFTTYPE=2
  Filter [F:PTSTJ] Where VCRNUM=[F:PTSRH]SRHNUM & STOFCY= [F:PTSRH]STOFCY
  Read [F:PTSTJ] First
  If !fstat
    Read [F:HAE]HAE0 = [F:PTSTJ]GTE;[F:PTSTJ]NUMVCR
    If !fstat
      If len([F:HAE]TYP+ctrans([F:HAE]NUM,"_-.\/",""))>20
        [L]MGTRANSID = format$("D:YYYY[-]MM[-]DD",[F:HAE]ACCDAT) + " " + [F:HAE]JOU + " " + ctrans([F:HAE]NUM,"_-.\/","")
      Else
        [L]MGTRANSID = format$("D:YYYY[-]MM[-]DD",[F:HAE]ACCDAT) + " " + [F:HAE]JOU + " " + [F:HAE]TYP+ctrans([F:HAE]NUM,"_-.\/","")
      Endif
    Endif
  Endif
  Filter [F:PTSTJ]
Endif
#CustomerID
[L]MGCUSTOID = [F:PTSRH]BPCORD
#SupplierID
[L]MGSUPPLID = ""
#MovementComments
[L]MGCOMMENT = ""
#DeliveryID
#Issue X3-90614 – 2018-05-29 2018.R5 - Insert the tag <DeliveryID> with value vehicle...
[L]MGDELIVID = vireblc([F:PTSRH]LICPLATER-[F:PTSRH]TRLLICPLATER, 2)
If [L]MGDELIVID = ""
  [L]MGDELIVID = "Desconhecido"
Endif
#Issue end
#DeliveryDate
#Introduzir o RTNDAT
[L]MGDELIVDT = [F:PTSRH]RTNDAT

#LocationID
[L]MGLOCATID = ""
#BuildingNumber
[L]MGBUIDNBR = "Desconhecido"
#ShipTo
#WarehouseID
[L]MGWAREHID_ST = [F:PTSRH]STOFCY

#StreetName,AddressDetail,City,PostalCode,Region
Call ADDRESS(3,[F:PTSRH]STOFCY,[F:PTFCY]BPAADD,[L]MGSTREETN_ST,[L]MGADDDETA_ST,[L]MGCITY_ST,[L]MGPOSTCOD_ST,[L]MGCOUNTRY_ST,[L]MGREGION_ST) From SAFTGENPORMG
If [L]MGCOUNTRY_ST <> "PT" & [L]SAFTTYPE = 8 : Return : Endif

#ShipFrom
#WarehouseID
[L]MGWAREHID_SF = ""
#StreetName,AddressDetail,City,PostalCode,Region
If ctrans([F:PTSRH]BPDADDLIG(0)+[F:PTSRH]BPDADDLIG(1)+[F:PTSRH]BPDADDLIG(2),' ','')<>''
  [L]MGSTREETN_SF = ''
  [L]MGADDDETA_SF = vireblc([F:PTSRH]BPDADDLIG(0)-[F:PTSRH]BPDADDLIG(1)-[F:PTSRH]BPDADDLIG(2),2)
  [L]MGCITY_SF    = vireblc([F:PTSRH]BPDCTY,2)
  [L]MGPOSTCOD_SF = vireblc([F:PTSRH]BPDPOSCOD,2)
  [L]MGCOUNTRY_SF = vireblc([F:PTSRH]BPDCRY,2)
  [L]MGREGION_SF  = vireblc([F:PTSRH]BPDSAT,2)
Else
  Call ADDRESS(1,[F:PTSRH]BPCORD,[F:PTSRH]BPAADD,[L]MGSTREETN_SF,[L]MGADDDETA_SF,[L]MGCITY_SF,[L]MGPOSTCOD_SF,[L]MGCOUNTRY_SF,[L]MGREGION_SF) From SAFTGENPORMG
Endif

If [L]MGADDDETA_SF  = '' : [L]MGADDDETA_SF  = 'Desconhecido' : Endif
If [L]MGCITY_SF     = '' : [L]MGCITY_SF     = 'Desconhecido' : Endif
If [L]MGPOSTCOD_SF  = '' : [L]MGPOSTCOD_SF  = '0000000'      : Endif
If [L]MGREGION_SF   = '' : [L]MGREGION_SF   = 'Desconhecido' : Endif
If [L]MGCOUNTRY_SF  = '' : [L]MGCOUNTRY_SF  = 'PT'           : Endif
If [L]MGCOUNTRY_SF <> "PT" & [L]SAFTTYPE = 8 : Return : Endif #RM, não comunicamos se não for para portugal
If len([L]MGPOSTCOD_SF) = 7 & [L]MGCOUNTRY_SF = 'PT'
  [L]MGPOSTCOD_SF = format$("K:4#[-]3#", [L]MGPOSTCOD_SF)
Endif

#MovementEndTime
If [F:PTSRH]ARVDATR <>[0/0/0] & [F:PTSRH]ETAR <>"0000"
  [L]MGMOVENDT = format$("D:YYYY[-]MM[-]DD",[F:PTSRH]ARVDATR)+"T"+format$("hh[:]mm[:]ss",ctrans([F:PTSRH]ETAR,":","")+"00")
Endif
#MovementStartTime
If [F:PTSRH]DPEDATR <>[0/0/0] & [F:PTSRH]ETDR <>"0000"
  [L]MGMOVSTRT = format$("D:YYYY[-]MM[-]DD",[F:PTSRH]DPEDATR)+"T"+format$("hh[:]mm[:]ss",ctrans([F:PTSRH]ETDR,":","")+"00")
Else
  Call ECR_TRACE (mess(13,701,1)-[F:PTSRH]SRHNUM-mess(236,7711,1), 1) From GESECRAN
Endif
#Gosub SET_TZ From PORLEGLIB1

#VEHICLEID
[L]VEHICLEID = [F:PTSRH]LICPLATER+[F:PTSRH]TRLLICPLATER

If [L]SAFTWAY=1
 Gosub WRITE_MOVEG_H From SAFTGENPORMG
Endif

For [F:PTSRD] Where SRHNUM = [F:PTSRH]SRHNUM
  Gosub RAZVAR_MG_D From SAFTGENPORMG
  #ExchangeRate
  Call GET_CHANGE([F:PTSRD]CUR,[F:PTSRH]RTNDAT,[L]MGTEXCRAT) From SAFTGENPORMG
  #-
  #LineNumber
  #[L]MGDLINNBR = [F:PTSRD]SRDLIN
  [L]MGDLINNBR += 1
  #OriginatingON
  If [F:PTSRD]SDHNUM<>''
    Read [F:PTSDD]SDD0=[F:PTSRD]SDHNUM;[F:PTSRD]SDDLIN
    If !fstat
      If [F:PTSRD]NETPRINOT<>0
        #TaxCountryRegion,TaxCode,TaxPercentage,TaxExemptionReason
        For YC = 0 To 0
         If [F:PTSDD]VAT(YC)<>""
          #Issue X3-31864 – 2017-04-11  by MANOW
          Call GETTAX([L]SOC,[F:PTSDD]VAT(YC),[F:PTSDD]SHIDAT,[L]MGDTAXTYP,[L]MGDTAXCOU,[L]MGDTAXCOD,[L]MGDTAXPER,[L]MGDTAXAMO,[L]MGDTAXEXA,[L]MGDTAXEXAC,[L]VENEXEFLG) From SAFTGENPORVAT
          #Issue X3-31864 end
          If [L]VENEXEFLG = 2 : [L]MGDTAXPER = 0.0 : Endif
         Endif
        Next
      Endif
    Endif
  Endif

  [L]MGDORIGIN  = [F:PTSRH]GLBDOCNUMR
  [L]MGDORDDAT  = [F:PTSRH]GLBDOCDATR

  #ProductCode
  [L]MGDPRODUC = [F:PTSRD]ITMREF
  #ProductDescription
  If [F:PTSRD]ITMDES1<>""
    [L]MGDPRODES = [F:PTSRD]ITMDES1
  Else
    [L]MGDPRODES = "Desconhecido"
  Endif
  #Description
  If[F:PTSRD]ITMDES<>""
    [L]MGDLINDES = [F:PTSRD]ITMDES
  Else
    [L]MGDLINDES = "Desconhecido"
  Endif
  #Quantity
  [L]MGDQUANTI  = [F:PTSRD]QTY
  #UnitOfMeasure
  [L]MGDUOM    = [F:PTSRD]SAU
  #TaxType
  [L]MGDTAXTYP = "IVA"
  #UnitPrice
  [L]MGDNETPRI = [F:PTSRD]NETPRINOT * [L]MGTEXCRAT

  If [F:PTSRD]NETPRINOT=0
    #OrderDate
    [L]MGDTAXTYP = ""
    #TaxType
    [L]MGDTAXTYP = ""
    #TaxCountryRegion
    [L]MGDTAXCOU = ""
    #TaxCode
    [L]MGDTAXCOD = ""
    #TaxPercentage
    [L]MGDTAXPER = 0
    #TaxAmount
    [L]MGDTAXAMO = 0
    #TaxExemptionReason
    If [L]ISSAFTVERCURRENT = 1
      [L]MGDTAXEXA = ''
    Else
      [L]MGDTAXEXA = 'Documento sem imposto calculado'
    Endif
    #DebitAmount
    [L]MGDDEBAMT = 0
    #CreditAmount
    [L]MGDCREAMT = 0
  Else
    #DebitAmount/CreditAmount
    If [F:PTSRD]NETPRINOT<0
      [L]MGDDEBAMT = abs(([F:PTSRD]NETPRINOT*[L]MGTEXCRAT)*[F:PTSRD]QTY)
    Else
      [L]MGDCREAMT = ([F:PTSRD]NETPRINOT*[L]MGTEXCRAT)*[F:PTSRD]QTY
    Endif
  Endif

  # Issue X3-31864 - 2017-05-08 by VV: Serial numbers
  If [F:ITM]ITMREF <> [F:PTSRD]ITMREF
    Read [F:ITM]ITM0 = [F:PTSRD]ITMREF
  Endif
  If [F:ITM]SERMGTCOD > 1
    For [F:STJ]STJ1 Where [F:STJ]STOFCY = [F:PTSRH]STOFCY & [F:STJ]VCRTYP = 13 & [F:STJ]VCRNUM = [F:PTSRH]SRHNUM & [F:STJ]VCRLIN = [F:PTSRD]SRDLIN & [F:STJ]SERNUM <> ""
      [L]SDLSERNUM(maxtab([L]SDLSERNUM)+1)=[F:STJ]SERNUM
    Next
  Endif
  #end Issue X3-31864

  If [L]SAFTWAY=1
   Gosub WRITE_MOVEG_D From SAFTGENPORMG
  Else
    Gosub FEED_VAR_WS From PORLEGLIB1
  Endif

    #TaxPayable
    [L]MGTTAXPAY += (([F:PTSRD]NETPRIATI-[F:PTSRD]NETPRINOT)*[L]MGTEXCRAT)*[F:PTSRD]QTY
    #NetTotal
    [L]MGTNETTOT += ([F:PTSRD]NETPRINOT*[L]MGTEXCRAT)*[F:PTSRD]QTY
    #GrossTotal
    [L]MGTGROTOT += ([F:PTSRD]NETPRIATI*[L]MGTEXCRAT)*[F:PTSRD]QTY
  #-
Next
#CurrencyCode
[L]MGTCURCOD = ""

If [L]SAFTWAY=1
 Gosub WRITE_MOVEG_T From SAFTGENPORMG
Endif

Return

