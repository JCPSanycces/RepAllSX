#<AdxTL>@(#)1.0.0.0 $Revision$
########################################################################################################################
#
# POLISH MODERNIZATION
# ====================
#
# @ver        0.0.1
# @date       31.01.2011
# @user       GBO
#
########################################################################################################################
# Modifications :
# -------------
#
#    USR - DD.MM.YYYY FQnnnnnn  Comment
#    MWA - 12.05.2016 FQ116234  Génération d'un événement d'annulation de modernisation à tort
#    MWA - 12.05.2016 FQ116077  Annulation d'une modernisation
#    MWA - 24.03.2016 FQ112798  Prise en compte d'une nième modernisation dans l'exercice
#    CBO - 16.03.2016 FQ115035  Undo an expense
#    MWA - 01.02.2011 FQ72372 : Dégressif polonais
#    MDJ - 22.09.2011 FQ76430 : plantage si PARAM n'existe pas (cas d'une société non-POL (si maj ADMCOE)
########################################################################################################################
#CHECK IGNORE_BEGIN
$TEST_SUBPROG
 Local Char SPTEST(30) : SPTEST="IS_MDR_PENDING"
 Case SPTEST
  When "IS_MDR_PENDING" : Gosub TST_IS_MDR_PENDING
  When Default
 Endcase
End
#----------------------------------------------------


#----------------------------------------------------
$TST_IS_MDR_PENDING
 Infbox num$(func TRTFASMDR.IS_MDR_PENDING("GBNPL","GBNP11102FX00016",G300IAS,G301AUC))
End
#CHECK IGNORE_END

########################################################################################################################
# Action labels called from FASMDR action
########################################################################################################################
$ACTION
 Case ACTION
  When "OUVRE"    : Gosub OUVRE
  When "DEBUT"    : Gosub DEBUT
  When "OK"       : Gosub OK
  When "CONTROLE" : Gosub CONTROLE
  When "END"      : GOK=0
  When Default
 Endcase
Return

#-----------------------------------------------------------------------------------------------------------------------
$OUVRE
 If PARAM(1)="GESFAS" & PARAM(2)="2" : Gosub CANCEL_MDR : Endif
Return

#-----------------------------------------------------------------------------------------------------------------------
$DEBUT
 If PARAM(1)=""
  Chgfmt [M:FMR]MDRDEV    With "-Nz3:13.2#"
  Chgfmt [M:FMR]CCLMDRFLG With "-N:5.0"
 Endif
 Raz [M:FMR]
 Local Char VALPARAM
 Call PARAM([M:FAS0]CPY,"MDRCURPER", VALPARAM) From ADOVAL
 [M:FMR]MDRCURPER=val(VALPARAM)
 Gosub FILL_MDRPLN_TAB
 Gosub COND_MDRPLN_TAB : # FQ72372
 Gosub SET_MDRMINDAT_FIELD
 Call AM_MDRDATACT([M:FMR]MDRDATACT) From TRTFASMDR
 Affzo [M:FMR]1-99
Return

#-----------------------------------------------------------------------------------------------------------------------
$OK

 #> Modernization by expense linking
 If PARAM(1)=""
  Local Integer I_PLN
  [M:LOF6]MDRDATACT=[M:FMR]MDRDATACT
  For I_PLN=1 To [M:FMR]NBPLN
# FQ116077
#   [M:LOF6]MDRPLNFLG([M:FMR]MDRPLN(I_PLN-1)-1)= [M:FMR]MDRPLNFLG(I_PLN-1)
#   [M:LOF6]MDRDAT([M:FMR]MDRPLN(I_PLN-1)-1)   = [M:FMR]MDRDAT(I_PLN-1)
   [M:LOF6]MDRPLNFLG(I_PLN-1)= [M:FMR]MDRPLNFLG(I_PLN-1)
   [M:LOF6]MDRDAT(I_PLN-1)   = [M:FMR]MDRDAT(I_PLN-1)
  Next I_PLN
  If !find(G_OUI,[M:FMR]MDRPLNFLG)
    Global Integer ABANDON
  Endif
 Endif

 #> Modernization for a fixed asset created without expense

 If PARAM(1)="GESFAS"
  If PARAM(2)<>"2"
   [M:FAS1]ACGETRNOT+=[M:FMR]MDRDEV : Affzo [M:FAS1]ACGETRNOT
   Gosub TVA_FAC_PCG From SUBFAS
   Gosub TVA_REC_PCG From SUBFAS
   Gosub CALCUL_VALEUR_BILAN From TRTFAS
  Endif
 Endif

 #> Global variable identifiying action type : Modernization or Cancellation.

 If !GERR & PARAM(1)="GESFAS"
   Global Integer GFASMDR
   Global Integer GACTMODIF
 Endif

Return

#-----------------------------------------------------------------------------------------------------------------------
$CONTROLE
  If dim(ABANDON)>0
   GERR     = 2
   GMESSAGE = mess(820,GML_MSGFAS,1) #"Au moins un plan doit être modernisé"
   SAI      = 1
   Kill ABANDON
  Endif
Return

#-----------------------------------------------------------------------------------------------------------------------
$FILL_MDRPLN_TAB
 Local Integer I_PLN
 For I_PLN=1 To [M:FAS3]NBLIG1
  If [M:FAS3]ORIBAS(I_PLN-1)=GVML_OBPCG
   If find([M:FAS3]DPM(I_PLN-1),GMDRDPMLST)
    [M:FMR]MDRPLN([M:FMR]NBPLN)      = [M:FAS3]DPRPLN(I_PLN-1)
    [M:FMR]MDRPLNFLG([M:FMR]NBPLN)   = G_OUI
    [M:FMR]MDRPLNCNX([M:FMR]NBPLN)   = [M:FAS3]CNX(I_PLN-1)
    [M:FMR]FIYSTRDAT([M:FMR]NBPLN)   = [M:FAS3]FIYSTRDAT(I_PLN-1)
    [M:FMR]FIYENDDAT([M:FMR]NBPLN)   = [M:FAS3]FIYENDDAT(I_PLN-1)  : # FQ72372
    [M:FMR]PERSTRDAT([M:FMR]NBPLN)   = [M:FAS3]PERSTRDAT(I_PLN-1)
    [M:FMR]STRDPRDAT([M:FMR]NBPLN)   = [M:FAS3]STRDPRDAT(I_PLN-1)
    [M:FMR]MDRPREDAT([M:FMR]NBPLN)   = [M:FAS3]KMDRDAT(I_PLN-1)
    If [M:FMR]MDRPLN([M:FMR]NBPLN)   = G301CPT | ([M:FMR]MDRPLN([M:FMR]NBPLN)<>G301CPT & [M:FMR]MDRDATACT=[0/0/0])
     [M:FMR]MDRDATACT=[M:FMR]PERSTRDAT([M:FMR]NBPLN)
    Endif
    [M:FMR]PERENDDAT([M:FMR]NBPLN)=[M:FAS3]PERENDDAT(I_PLN-1)
    [M:FMR]DPM([M:FMR]NBPLN)      = [M:FAS3]DPM(I_PLN-1)           : # FQ72372
    [M:FMR]NBPLN+=1
   Endif
  Endif
 Next I_PLN
Return

#-----------------------------------------------------------------------------------------------------------------------
$COND_MDRPLN_TAB
 # FQ72372
 Local Integer I_PLN
 For I_PLN= 1 To [M:FMR]NBPLN
  If [M:FAS3]DPM(I_PLN-1)<>G_DPMMD
    Diszo [M:FMR]MDRDAT(I_PLN-1) : Affzo [M:FMR]MDRDAT(I_PLN-1)
  Endif
 Next I_PLN
Return
#-----------------------------------------------------------------------------------------------------------------------
$CANCEL_MDR
  Local Integer LMDRDEV
  Local Integer I_PLN, I_MDRPLN
  Global Integer GFASMDRCCL
  Raz [M:FMR]
  [M:FMR]CCLMDRFLG=G_OUI
  Gosub FILL_MDRPLN_TAB
  For I_PLN=1 To [M:FAS3]NBLIG1
   I_MDRPLN=find([M:FAS3]DPRPLN(I_PLN-1),[M:FMR]MDRPLN)
   If I_MDRPLN
    If [M:FAS3]KMDRDEV(I_PLN-1)<>0
     [M:FMR]MDRPLNFLG(I_MDRPLN-1)=G_OUI
     If LMDRDEV=0 : LMDRDEV=[M:FAS3]KMDRDEV(I_PLN-1) : Endif
     Gosub RECTIFIE_BCO From TRTFASMDR
    Else
     [M:FMR]MDRPLNFLG(I_MDRPLN-1)=G_NON
    Endif
   Endif
  Next I_PLN
  [M:FMR]MDRDEV=LMDRDEV
  [M:FAS1]ACGETRNOT-=[M:FMR]MDRDEV : Affzo [M:FAS1]ACGETRNOT
  Gosub TVA_FAC_PCG From SUBFAS
  Gosub TVA_REC_PCG From SUBFAS
  Gosub CALCUL_VALEUR_BILAN From TRTFAS
  Call MESSAGE(mess(821,GML_MSGFAS,1)) From GESECRAN #"Modernisation annulée : cliquer sur enregistrer pour confirmer."
  FIN=1
Return

#-----------------------------------------------------------------------------------------------------------------------
$SET_MDRMINDAT_FIELD
 Local Integer I_PLN
 Raz [M:FMR]MDRMINDAT
 For I_PLN=1 To [M:FMR]NBPLN
  If [M:FMR]MDRPLNFLG(I_PLN-1)=G_OUI
   [M:FMR]MDRMINDAT=max([M:FMR]MDRMINDAT, func TRTFASMDR.GET_MDR_DAT_MIN([M:FAS0]AASREF,[M:FMR]MDRPLN(I_PLN-1)))
  Endif
 Next I_PLN
Return

########################################################################################################################
# Action labels called from FUNLOFLDAB
########################################################################################################################

#-----------------------------------------------------------------------------------------------------------------------
$DEBUT_LOFLDAB
  If dim([M:LOF6]MDRFLG)>0 & ([M:FPC]LEG<>"POL" | GREP="C")
   Chgfmt [M:LOF6]MDRFLG     With "-N:5.0"
  Else
   Actzo [M:LOF6]MDRFLG : [M:LOF6]MDRFLG=G_NON
  Endif
  [M:LOF6]NBDESTORI=[M:LOF6]NBDEST
Return

#-----------------------------------------------------------------------------------------------------------------------
$BOUTON_LOFLDAB
  If GERR : Return : Endif
  If BOUT="2" & [M:FPC]LEG="POL" & [M:LOF6]MDRFLG=G_OUI
   #> The modernization value must be not null
   If ![M:LOF6]CUMAMTVCR
    GERR=2
    GMESSAGE=mess(822,GML_MSGFAS,1) #"Action impossible : la valeur de modernisation ne doit pas être nulle"
    Return
   Endif
   Call TRAITE_CHAR(VALEUR,PARAM,"","TRTFASMDR","FASMDR",4,"") From GTRAITE
  Endif
Return

#-----------------------------------------------------------------------------------------------------------------------
# Called by $REMPLI_SOURCE in FUNLOFLDAB
#-----------------------------------------------------------------------------------------------------------------------
$REMPLI_SOURCE
 If [M:FPC]LEG="POL" & [M:LOF6]MDRFLG=G_OUI
  LCOND1+="&TYPVCR<>2"
 Endif
Return

#-----------------------------------------------------------------------------------------------------------------------
# Called by $MODIF in SUBFAS2 via $MARQUE_DEPENSE_LIEES in FUNLOFLDAB
#-----------------------------------------------------------------------------------------------------------------------
$GEN_MDR_EVENT

  If [M:FPC]LEG="POL" & ([M:LOF6]MDRFLG=G_OUI | dim(GFASMDR)>0)
   #> Loop on the modernized depreciation plans :
   #  For each those plans, a modernization event is created with an effect date set to the first day of the current period.
   #  If an error appears during the modernization event creation, the asset update transaction is aborted.
   Local Char    LCODINT
   Local Integer I_MDRPLN
   If [F:DEP]KMDRDEV<>0
    If  clalev([F:EVT0]) : Close Local File  [F:EVT0] : Endif
    If  clalev([F:EVT1]) : Close Local File  [F:EVT1] : Endif
    # FQ116077
    # LCODINT = "FASPLMDR"+num$(nolign)
    LCODINT = "FASPLMDR"+num$([M:FAS3]DPRPLN(nolign-1))
    WDATEFF = [M:FMR]MDRDATACT
    WACCDAT = [M:FMR]MDRDATACT
    Call GENER_EVE(GVML_OMBIEN,[F:FAS]CPY,[F:FAS]FCY,[F:FAS]AASREF,0,LCODINT,WDATEFF,WACCDAT, CDRET) From GENEVE
    If CDRET > 20 Then
     # Error during the modernization event creation
     GMESSAGE  = mess(823,GML_MSGCPT,1)-num$(CDRET) :  #"Erreur lors de la génération de l'événement de modernisation"
     GOK       = 0
     Call FSTA("FAS") From GLOCK
     Return
    Endif
   Endif
  Endif

Return

#-----------------------------------------------------------------------------------------------------------------------
$MARQUE_DEPENSE_LIEES
 If [M:LOF6]MDRFLG=G_OUI
  [F:LOF]KMDRFLG    = G_OUI
  [F:LOF]KMDRDATACT = [M:LOF6]MDRDATACT
#  [M:LOF6]MDRFLG    = G_NON FQ115035
 Else
  [F:LOF]KMDRFLG    = G_NON
  [F:LOF]KMDRDATACT = [0/0/0]
 Endif

Return

#-----------------------------------------------------------------------------------------------------------------------
$DISABLE_MDRFLG
 If [M:FPC]LEG="POL" & [M:LOF6]NBDESTORI<>[M:LOF6]NBDEST
  Grizo [M:LOF6]MDRFLG : Affzo [M:LOF6]MDRFLG
 Endif
Return

#-----------------------------------------------------------------------------------------------------------------------
$ENABLE_MDRFLG
  If [M:FPC]LEG="POL" & [M:LOF6]NBDESTORI=[M:LOF6]NBDEST
   Actzo [M:LOF6]MDRFLG : Affzo [M:LOF6]MDRFLG
  Endif
Return

########################################################################################################################
# Action labels called from TRTFASDDE
########################################################################################################################

#-----------------------------------------------------------------------------------------------------------------------
# Called in the DEBUT action in TRTFASDDE
#-----------------------------------------------------------------------------------------------------------------------
$DEBUT_TRTFASDDE

 #> Management of the cancelation flag

 If [M:FPC]LEG<>"POL" | ([M:FPC]LEG="POL" & func TRTFASMDR.IS_MDR_PENDING([F:FAS]CPY,[F:FAS]AASREF,0,G301AUC)=0)
  Chgfmt [M:OAC0]CCLMDRFLG  With "-N:5.0"
 Elsif [M:FPC]LEG="POL" & func TRTFASMDR.IS_MDR_PENDING([F:FAS]CPY,[F:FAS]AASREF,0,G301AUC)>0
  [M:OAC0]CCLMDRFLG=G_OUI
  If !clalev([F:EVTR]) : Local File EFASPLMDR [EVTR] : Endif
  For I_PLN=1 To [M:FAS3]NBLIG1
   If [M:FAS3]KMDRDEV(I_PLN-1)<>0
    Filter [F:EVTR] Where REF=[M:FAS0]AASREF & DPRPLN=[M:FAS3]DPRPLN(I_PLN-1)& SNSEVE=GVML_TEACT
    Read [F:EVTR] Last
    If !fstat
     If [F:EVTR]EVTDAT<[M:FAS3]PERSTRDAT(I_PLN-1) | [F:EVTR]EVTDAT>[M:FAS3]PERENDDAT(I_PLN-1)
      [M:OAC0]CCLMDRFLG=G_NON
      Chgfmt [M:OAC0]CCLMDRFLG  With "-N:5.0" : Break
     Endif
    Else
     [M:OAC0]CCLMDRFLG=G_NON
     Chgfmt [M:OAC0]CCLMDRFLG  With "-N:5.0" : Break
    Endif
    Filter [F:EVTR]
   Endif
  Next I_PLN
  If [M:OAC0]CCLMDRFLG=G_OUI
   Filter [F:LOF] Where AASREF=[M:FAS0]AASREF & [F:LOF]FLGLIKAAS=G_OUI & FLGLOFMAI=G_NON & KMDRFLG<>G_OUI
   If !rowcount([F:LOF])
    Grizo [M:OAC0]CCLMDRFLG
   Endif
   Filter [F:LOF]
  Endif
 Endif

Return

#-----------------------------------------------------------------------------------------------------------------------
# Called in the DEBUT action in TRTFASDDE
#-----------------------------------------------------------------------------------------------------------------------
$REMPLI_TABLEAU

 # Looking for the date of the last modernization in the modernization events table

 Local Date LMDRDATACT
 Local File EFASPLMDR [EVT]
 If !clalev([F:EVTA]) : Local File EFASPLMDR [EVTA] : Endif
 Filter [F:EVT] Where REF=[F:FAS]AASREF & SNSEVE=GVML_TEACT
 Read [F:EVT] Last
 If !fstat
  [M:DDE1]MDRDATACT=[F:EVT]EVTDAT
 Endif
 Filter [F:EVT]
 Close Local File [F:EVT]

 # Filling the expenses tab

 For [LOF] Where AASREF=[M:FAS0]AASREF &[F:LOF]FLGLIKAAS=G_OUI & [F:LOF]KMDRFLG=G_OUI & [F:LOF]KMDRDATACT=[M:DDE1]MDRDATACT
  Gosub ALIMENTE_LIGNES From TRTFASDDE
  [M:DDE1]FLGULI(nolign-2) = G_OUI
 Next
 [M:DDE1]NBDEST = nolign-1
 Call ACTION_BLOCK (ACB_AFFZO, "FASDDE1", "FLGULI") From GLOBIENS
 Grizo [M:DDE1]
 Call TEMPOFF() From GESECRAN

Return

#-----------------------------------------------------------------------------------------------------------------------
# Called on the AVANT_MODFIC action in SUBFAS2 (via TRTOBJACT)
#-----------------------------------------------------------------------------------------------------------------------
$APPLIQUER_DDAB

 #> Cancellation event

 If (dim(GFASMDRCCL)>0)  | (dim([M:OAC0]CCLMDRFLG)>0 & [M:OAC0]CCLMDRFLG=G_OUI)
  If  clalev([F:EVT0]) : Close Local File  [F:EVT0] : Endif
  If  clalev([F:EVT1]) : Close Local File  [F:EVT1] : Endif
  If !clalev([F:DEPR]) : Local File DEPREC [F:DEPR] : Endif
  Local Integer I_PLN
  Local Char    LEVTINT
  Local Date    LEVTDAT
  Local Integer REVTCREE
  Local Integer RCOD
  For I_PLN=1 To [M:FAS3]NBLIG1
   Read [F:DEPR]DEP0=[F:FAS]AASREF;[M:FAS3]DPRPLN(I_PLN-1);[M:FAS3]FIYENDDAT(I_PLN-1);[M:FAS3]PERENDDAT(I_PLN-1)
   # FQ116234
   #If [F:DEPR]KMDRDAT<>[0/0/0]
   If [F:DEPR]KMDRDAT<>[0/0/0] and [F:DEPR]KMDRDAT >= [M:FAS3]PERSTRDAT(I_PLN-1)
    LEVTINT = "FASPLMDR"+num$([M:FAS3]DPRPLN(I_PLN-1))
    LEVTDAT = [00/00/0000]
    Call ANNULE_EVE(GVML_OMBIEN,[F:FAS]CPY,[F:FAS]FCY,[F:FAS]AASREF,0,LEVTINT,LEVTDAT,REVTCREE,RCOD) From GENEVE
    If RCOD
     GERR     = 1
     GMESSAGE = mess(823,GML_MSGCPT,1)-mess(I_PLN,3101,1) #"Erreur génération événement d'annulation de modernisation sur le plan"
     GOK      = 0
     Break
    Endif
   Endif
  Next I_PLN
 Endif

 If dim(GFASMDRCCL)>0 : Kill GFASMDRCCL : Endif

Return

#-----------------------------------------------------------------------------------------------------------------------
# Called on the AVANT_MODFIC action in SUBFAS2 (via TRTOBJACT)
#-----------------------------------------------------------------------------------------------------------------------
$DDAB_LOF
 If [F:LOF]KMDRFLG=G_OUI
  [F:LOF]KMDRFLG    = G_NON
  [F:LOF]KMDRDATACT = [0/0/0]
 Endif
Return

#-----------------------------------------------------------------------------------------------------------------------
# Called on the OK action from TRTFASDDE or TRTFASMDR
#-----------------------------------------------------------------------------------------------------------------------
$RECTIFIE_BCO
  # Issue FQ112798
  #If dim([M:OAC0]CCLMDRFLG)>0 & [M:OAC0]CCLMDRFLG=G_OUI
  If ( dim([M:OAC0]CCLMDRFLG)>0 and [M:OAC0]CCLMDRFLG=G_OUI ) or
&    ( dim( [M:FMR]CCLMDRFLG)>0 and  [M:FMR]CCLMDRFLG=G_OUI )
  # End issue FQ112798
    [M:FAS3]KMDRDEV(I_PLN-1)=0       : Affzo [M:FAS3]KMDRDEV(I_PLN-1)
    Local Date    LOLDMDRDAT
    Local Decimal LOLDMDRDEV
    If [M:FAS3]LSTCLODAT(I_PLN-1)<>[0/0/0]
      # Reading of the previous deprec record
      If !clalev([F:DEPR]) : Local File DEPREC [DEPR] : Endif
      Local Date LFIYENDDAT, LPERENDDAT
      If [M:FAS3]PERSTRDAT(I_PLN-1)=[M:FAS3]FIYSTRDAT(I_PLN-1)
        LFIYENDDAT=[M:FAS3]FIYSTRDAT(I_PLN-1)-1
      Else
        LFIYENDDAT=[M:FAS3]FIYENDDAT(I_PLN-1)
      Endif
      LPERENDDAT=[M:FAS3]PERSTRDAT(I_PLN-1)-1
      Read [F:DEPR]DEP0=[M:FAS0]AASREF;[M:FAS3]DPRPLN(I_PLN-1);LFIYENDDAT;LPERENDDAT
      If !fstat
        LOLDMDRDAT=[F:DEPR]KMDRDAT
        LOLDMDRDEV=[F:DEPR]KMDRDEV
        # FQ116077
        LOLDMDRDEV=0
      Endif
    Else
      LOLDMDRDAT=[0/0/0]
      LOLDMDRDEV=0
    Endif
    [M:FAS3]KMDRDAT(I_PLN-1)=LOLDMDRDAT : Affzo [M:FAS3]KMDRDAT(I_PLN-1)
    [M:FAS3]KMDRDEV(I_PLN-1)=LOLDMDRDEV : Affzo [M:FAS3]KMDRDEV(I_PLN-1)
  Endif
Return

########################################################################################################################
# Action labels called from TRTFAS
########################################################################################################################

#**
#* Set the LMDRPLNFLG variable used by $CALCULER_VALEUR_BILAN in TRTFAS :
#*    - G_OUI (2)      The depreciation plan basis is modified
#*    - G_NON (1)      The depreciation plan basis is not modified
#*!
$MAJ_PLN

 Local Integer LMDRPLNFLG : LMDRPLNFLG=G_NON
 If GREP="C" : Return : Endif
 If dim(PARAM)<0 | (dim(PARAM)>0 & PARAM(1)<>"GESFAS")
  If [M:LOF6]MDRFLG=G_OUI
   If [M:LOF6]MDRPLNFLG(I_PLN-1)=G_OUI
    LMDRPLNFLG = G_OUI
   Else
    LMDRPLNFLG = G_NON
   Endif
  Else
   LMDRPLNFLG = G_OUI
  Endif
 Endif

 If dim(PARAM)>0 & PARAM(1)="GESFAS"
  If [M:FMR]MDRPLNFLG(I_PLN-1)=G_OUI
   LMDRPLNFLG = G_OUI
  Else
   LMDRPLNFLG = G_NON
  Endif
 Endif

Return

#**
#* Set the modernization informations on the FAS3 mask
#*!
$MAJ_MDR_INF
 If [M:LOF6]MDRFLG=G_OUI
  [M:FAS3]KMDRDEV(I_PLN-1)=MTDES-[M:FAS3]DPRBAS(I_PLN-1)
  [M:FAS3]KMDRDAT(I_PLN-1)=[M:LOF6]MDRDAT(I_PLN-1)
 Endif
 If dim(PARAM)>0 #Fq-76430
 If PARAM(1)="GESFAS" & [M:FMR]CCLMDRFLG<>G_OUI
  [M:FAS3]KMDRDEV(I_PLN-1)=MTDES-[M:FAS3]DPRBAS(I_PLN-1)
  [M:FAS3]KMDRDAT(I_PLN-1)=[M:FMR]MDRDAT(find([M:FAS3]DPRPLN(I_PLN-1),[M:FMR]MDRPLN)-1)
 Endif
 # Issue FQ112798
 # If PARAM(1)="GESFAS" & [M:FMR]CCLMDRFLG=G_OUI
 #  [M:FAS3]KMDRDEV(I_PLN-1)=0
 #  [M:FAS3]KMDRDAT(I_PLN-1)=[0/0/0]
 # Endif
 # End issue FQ112798
 Endif #Fq-76430
Return

########################################################################################################################
# miscellaneous tools for polish modernization management
########################################################################################################################

#**
#* This function returns the number of pending modernizations for :
#*
#*  - All depreciation plans, all fixed assets of a company if only PCPY parameter is set
#*  - All depreciation plans of a context for a company if only PCPY and PCNX parameters are set
#*  - One depreciation plan of a company if only PCPY and PDPRPLN parameters are set
#*
#* @param PCPY      Company
#* @param PAASREF   Asset reference
#* @param PCNX      Deprecation context
#* @param PDPRPLN   Depreciation plan
#*!
Funprog IS_MDR_PENDING(PCPY,PAASREF,PCNX,PDPRPLN)
Value Char    PCPY
Value Char    PAASREF
Value Integer PCNX
Value Integer PDPRPLN
Local Integer RRESULT : RRESULT = 0

 If !clalev([F:DEPR])  : Local File DEPREC    [F:DEPR] : Endif
 If !clalev([F:FISR])  : Local File FISCYEAR  [F:FISR] : Endif
 If !clalev([F:CNXR])  : Local File CONTEXT   [F:CNXR] : Endif

 Local Char LCRITSUP(255)
 Local Char LCRITFAS(255)
 Local Char LCRITPLN(255)
 Local Char LCRITDAT(255)

 LCRITSUP = "KMDRDEV<>0&CPY='"+PCPY+"'"
 If PAASREF=""
  LCRITFAS="1=1"
 Else
  LCRITFAS="AASREF='"+PAASREF+"'"
 Endif

 For [F:CNXR] Where CPY=PCPY
  If PCNX=0 | (PCNX>0 & [F:CNXR]CNX=PCNX)
   If PDPRPLN>0 & PDPRPLN<G301AUC & find(PDPRPLN,[F:CNXR]PLNCAA)
    Read [F:FISR]FIY1=[F:CNXR]CPY;[F:CNXR]CNX;GVML_TECOURA
    If !fstat
     LCRITPLN="CNX=[F:CNXR]CNX&DPRPLN="+num$(PDPRPLN)
     LCRITDAT="FIYENDDAT=[F:FISR]DATENDFIY & PERENDDAT=[F:FISR]DATENDPER([F:FISR]INDCURPER-1)"
     Gosub COUNT_MDR
    Endif
   Else
    Local Integer I_PLN
    Read [F:FISR]FIY1=[F:CNXR]CPY;[F:CNXR]CNX;GVML_TECOURA
    If !fstat
     For I_PLN=1 To [F:CNXR]NBPLC
      If [F:CNXR]ORIBASDPR(I_PLN-1)=GVML_OBPCG
       LCRITPLN="CNX=[F:CNXR]CNX&DPRPLN="+num$(I_PLN)
       LCRITDAT="FIYENDDAT=[F:FISR]DATENDFIY & PERENDDAT=[F:FISR]DATENDPER([F:FISR]INDCURPER-1)"
       Gosub COUNT_MDR
      Endif
     Next I_PLN
    Endif
   Endif
  Endif
 Next

End RRESULT

#-------------------------------
$COUNT_MDR
 Filter [F:DEPR] Where evalue(LCRITSUP)&
&                      evalue(LCRITDAT)&
&                      evalue(LCRITFAS)&
&                      evalue(LCRITPLN)
 RRESULT+=rowcount([F:DEPR])
 Filter [F:DEPR]
Return

#**
#* This subprog controls if actions have been made on the asset's depreciation plan given in parameters.
#*
#* @param PCPY      Company
#* @param PAASREF   Asset reference
#* @param PDPRPLN   Depreciation plan
#* @param PMDRDAT   Modernization date
#* @param RACT      Other actions list
#*                  RACT(1) => Reevaluation
#*                  RACT(2) => Impairment Loss
#*                  RACT(3) => Method change (Not yet controlled)
#* @param RCOD      return code
#*!
Subprog CTRL_MDR_OTH_ACT(PCPY, PAASREF, PDPRPLN, PMDRDAT, RACT,RCOD)
Value    Char    PCPY
Value    Char    PAASREF
Value    Integer PDPRPLN
Value    Date    PMDRDAT
Variable Integer RACT(1..)
Variable Integer RCOD
If !clalev([F:DEPC]) : Local File DEPREC [DEPC] : Endif
If !clalev([F:DEPP]) : Local File DEPREC [DEPP] : Endif

#> Loading needing parameters for controls

Local Integer LCNX, RCOD
Local Date    LCNXDAT(1..5)
Call GET_CNX_FROM_PLAN(PCPY, PDPRPLN, LCNX) From GLOBIENS
Call GET_CNX_DAT( PCPY, LCNX, LCNXDAT, RCOD ) From GLOBIENS
Read [F:DEPC]DEP0=PAASREF;PDPRPLN;LCNXDAT(2);LCNXDAT(4)
If fstat
 RCOD = 1 # No DEPREC for the current period.
 End
Endif

#> Control

If [F:DEPC]PERRVADEV<>0 | [F:DEPC]PERIMLCUM<>0 | [F:DEPC]PERRVECUM<>0
 Filter [F:DEPC] Where AASREF=PAASREF & DPRPLN=PDPRPLN & PERSTRDAT>=PMDRDAT & PERENDDAT<LCNXDAT(3)
 For [F:DEPC]
  If [F:DEPC]RVAAMT<>0
   RACT(1) = G_OUI
  Endif
  If [F:DEPC]IML<>0 | [F:DEPC]IMLRVE<>0
   RACT(2) = G_OUI
  Endif
 Next
 Filter [F:DEPC]
Endif

End

#**
#* This function returns the starting date of the first DEPREC record for the depreciation plan of the
#* fixed asset given.
#* A modernization can not be performed before this date because, in this case, the calculation engine
#* don't have the exact P-1 accumulation amount.
#*
#* @param PAASREF   Fixed asset reference
#* @param PDPRPLN   Depreciation plan
#*!
Funprog GET_MDR_DAT_MIN(PAASREF,PDPRPLN)
Value Char    PAASREF
Value Integer PDPRPLN

Local Date LMDRDATMIN : LMDRDATMIN=[0/0/0]

If clalev([F:DEPR])=0 : Local File DEPREC [DEPR] : Endif
Filter [F:DEPR] Where AASREF=PAASREF & DPRPLN=PDPRPLN
Read [F:DEPR] First
LMDRDATMIN=[F:DEPR]PERSTRDAT
Filter [F:DEPR]

End LMDRDATMIN

#**
#* This subprogram controls if the value of MDRCURPER parameter can be changed
#*
#* The parameter cannot be changed if a modernization is pending
#*
#* @param PARAM     Parameter name
#* @param VALEUR    Parameter value
#* @param OK        Return boolean
#*!
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value    Char    PARAM
Value    Char    VALEUR
Variable Integer OK

   # FQ67577
   If (CMP <> "") Then
     # Niveau société
     Local Char LPARAM
     Call PARAM(CMP,"MDRCURPER",LPARAM) From ADOVAL
     If (VALEUR <> LPARAM) Then
       If (func TRTFASMDR.IS_MDR_PENDING(CMP, "", 0, G301AUC) <> 0 ) Then
         # La valeur de ce paramètre ne peut pas être modifiée car des modernisations sont en cours
         GMESSAGE = mess(265,7770,1)
         mkstat = 2
         OK=0
       Endif
     Endif
   Else
     # Niveau dossier
     Local Char LPARAM
     Call PARAM(CMP,"MDRCURPER",LPARAM) From ADOVAL
     If (VALEUR <> LPARAM) Then
       If !clalev([F:WCPY]) : Local File COMPANY [WCPY] : Endif
       If !clalev([F:WADW]) : Local File ADOVAL  [WADW] : Endif
       Filter [F:WCPY] Where LEG = "POL"
       For [WCPY]CPY1
         Read [ADW]ADW1="MDRCURPER";[F:WCPY]CPY;""
         If (fstat) Then
           If (func TRTFASMDR.IS_MDR_PENDING([F:WCPY]CPY, "", 0, G301AUC) <> 0 ) Then
             # La valeur de ce paramètre ne peut pas être modifiée car des modernisations sont en cours
             GMESSAGE = mess(265,7770,1)
             mkstat = 2
             OK=0
             Break
           Endif
         Endif
       Next
       Filter [F:WCPY]
     Endif
   Endif
End

######################################################################################
# Field actions of the [M:FAS3] mask
######################################################################################

#-------------------------------------------------------------------------------------
Subprog AS_NBLIG1

 #> Update mode : modernization forbidden
 If GREP<>""
  GBOUT7=""
  End
 Endif

 If [M:FPC]LEG<>"POL" |  ([M:FPC]LEG="POL" & GNBDEPLIEES<>0)
  #> Other legislation than polish legislation or Asset with linked expenses
  GBOUT7=""
 Else
  #> Depreciation method not allowed for modernization
  Local Integer I_PLN
  Local Integer LNOMDR : LNOMDR=G_OUI
  For I_PLN=1 To [M:FAS3]NBLIG1
   If find([M:FAS3]DPM(I_PLN-1),GMDRDPMLST)
    LNOMDR=G_NON
    Break
   Endif
  Next I_PLN
  If LNOMDR=G_OUI
   GBOUT7=""
   End
  Endif
  #> Modernization in progress : modification of the menu text ==> Cancellation
  If func TRTFASMDR.IS_MDR_PENDING([M:FAS0]CPY,[M:FAS0]AASREF,0,G301AUC)
   GBOUT7= mess(825,GML_MSGFAS,1)#"Annuler modernisation"
   If !clalev([F:EVTR]) : Local File EFASPLMDR [EVTR] : Endif
   For I_PLN=1 To [M:FAS3]NBLIG1
    If [M:FAS3]KMDRDEV(I_PLN-1)<>0
     Filter [F:EVTR] Where REF=[M:FAS0]AASREF & DPRPLN=[M:FAS3]DPRPLN(I_PLN-1)& SNSEVE=GVML_TEACT
     Read [F:EVTR] Last
     If !fstat
      If [F:EVTR]EVTDAT<[M:FAS3]PERSTRDAT(I_PLN-1) | [F:EVTR]EVTDAT>[M:FAS3]PERENDDAT(I_PLN-1)
       GBOUT7="" : Break
      Endif
     Else
      GBOUT7=""
     Endif
     Filter [F:EVTR]
    Endif
   Next I_PLN
  Endif
 Endif
End

#-------------------------------------------------------------------------------------
Subprog B7_NBLIG1
 Local Char VALBOUT(250) , PARAM(250)(1..2)
 PARAM(1)   = "GESFAS"
 If func TRTFASMDR.IS_MDR_PENDING([M:FAS0]CPY,[M:FAS0]AASREF,0,G301AUC)
  PARAM(2)  = num$(GVML_TEAACT)
 Else
  PARAM(2)  = num$(GVML_TEACT)
  Gosub ACCUMULATION_CONTROL
 Endif

  If !GERR
   Call SAISIE_CHAR(VALBOUT,PARAM,"FASMDR","TRTFASMDR","") From GSAISIE
   If (dim(GFASMDR)>0 & dim(ACTMODIF)) | dim(GFASMDRCCL)>0 : GREP="M" : Endif
   If ( GREP = "M" ) Then  : mkstat = 4 : Endif
  Endif

End

######################################################################################
# Field actions of the [M:LOF6] mask
######################################################################################

#-------------------------------------------------------------------------------------
Subprog C_MDRFLG(VALEUR)
Variable Integer VALEUR

 # No depreciation method allowed for modernization

 If VALEUR=G_OUI
  Local Integer I_PLN
  Local Integer LNOMDR : LNOMDR=G_OUI
  For I_PLN=1 To [M:FAS3]NBLIG1
   If find([M:FAS3]DPM(I_PLN-1),GMDRDPMLST)
    LNOMDR=G_NON
    Break
   Endif
  Next I_PLN
  If LNOMDR=G_OUI
   GERR     = 1
   GMESSAGE = mess(826,GML_MSGFAS,1) #"Action impossible : Tous les plans d'amortissement utilisent des modes qui n'autorisent pas la modernisation"
   mkstat   = 1
   End
  Endif
 Endif

 # Modernization in progress for, at least, on depreciation plan

 If VALEUR=G_OUI
  If func TRTFASMDR.IS_MDR_PENDING([F:FAS]CPY,[F:FAS]AASREF,0,G301AUC)
   GERR     = 1
   GMESSAGE = mess(827,GML_MSGFAS,1) #"Action impossible : modernisation en cours."
   mkstat   = 1
   VALEUR   = G_NON
   End
  Endif
 Endif

 # Asset without accumulated depreciation year start / period start entered => Modernization forbidden

 If VALEUR=G_OUI
  Gosub ACCUMULATION_CONTROL
 Endif

End

#-------------------------------------------------------------------------------------
Subprog AM_MDRFLG(VALEUR)
Variable Integer VALEUR
 [M:LOF6]MDRFLG=VALEUR
 Gosub REMPLI_SOURCE From FUNLOFLDAB : Affzo [M:LOF6]15
End

#------------------------------------------------
$ACCUMULATION_CONTROL
  Local Integer I_PLN, LERRE_1, LERRP_1
  Local Integer LPLNERRE_1(1..G301MAX-1)
  Local Integer LPLNERRP_1(1..G301MAX-1)

  For I_PLN=1 To [M:FAS3]NBLIG1
   If [M:FAS3]ORIBAS(I_PLN-1)=GVML_OBPCG
    If find([M:FAS3]DPM(I_PLN-1),GMDRDPMLST)
     If [M:FAS3]LSTCLODAT(I_PLN-1)=[0/0/0]
      # Accumulated depreciation year start control
      If [M:FAS3]STRDPRDAT(I_PLN-1)<[M:FAS3]FIYSTRDAT(I_PLN-1) & [M:FAS3]DPRCUMFLG(I_PLN-1)<>G_OUI
       GERR=1 : LERRE_1=1
       LPLNERRE_1([M:FAS3]DPRPLN(I_PLN-1))=G_OUI
      Endif
      #> Accumulated depreciation period start control
      If [M:FAS3]PERSTRDAT(I_PLN-1)<>[M:FAS3]FIYSTRDAT(I_PLN-1) & [M:FAS3]STRDPRDAT(I_PLN-1)<[M:FAS3]PERSTRDAT(I_PLN-1) & [M:FAS3]PERCLOCUM(I_PLN-1)=0
       GERR=1 : LERRP_1=1
       LPLNERRP_1([M:FAS3]DPRPLN(I_PLN-1))=G_OUI
      Endif
     Endif
    Endif
   Endif
  Next I_PLN
  If GERR=1
   If LERRE_1
    GMESSAGE  = mess(828,GML_MSGFAS,1)#"Modernisation impossible : Date de début d'amortissement antérieure à l'exercice courant et cumul E-1 non saisi."
    GMESSAGE += "\"+mess(184,GML_MSGFAS,1)+" : "  #Plan
    For I_PLN=1 To G301MAX-1
     If LPLNERRE_1(I_PLN)=G_OUI
      GMESSAGE+=mess(I_PLN,3101,1)+space$(1)
     Endif
    Next I_PLN
   Endif
   If LERRP_1
    GMESSAGE  = mess(829,GML_MSGFAS,1) #"Modernisation impossible : Date de début d'amortissement antérieure à la période courante et cumul P-1 non saisi."
    GMESSAGE += "\"+mess(184,GML_MSGFAS,1)+" : "  #Plan
    For I_PLN=1 To G301MAX-1
     If LPLNERRP_1(I_PLN)=G_OUI
      GMESSAGE+=mess(I_PLN,3101,1)+space$(1)
     Endif
    Next I_PLN
   Endif
   mkstat=2
   End
  Endif
Return

######################################################################################
# Field actions of the [M:MDR] mask
######################################################################################

#-------------------------------------------------------------------------------------
Subprog C_MDRDATACT(VALEUR)
Variable Date    VALEUR
 Local Integer I_PLN

 For I_PLN=1 To [M:FMR]NBPLN
  If [M:FMR]MDRPLNFLG(I_PLN-1)=G_OUI
   #> Control on the starting date of fiscal year
   If VALEUR<[M:FMR]FIYSTRDAT(I_PLN-1)
    GERR     = 1
    GMESSAGE = mess(830,GML_MSGFAS,1) #"La date de modernisation ne peut inférieure à la date de début d'exercice des plans à moderniser"
    mkstat   = 2
    End
   Endif
   #> Control on the end date of current period
   If VALEUR>[M:FMR]PERENDDAT(I_PLN-1)
    GERR     = 1
    GMESSAGE = mess(831,GML_MSGFAS,1) #"La date de modernisation ne peut superieure à la date de fin de période des plans à moderniser"
    mkstat   = 2
    End
   Endif
   #> Control on the starting date of depreciation
   If VALEUR<[M:FMR]STRDPRDAT(I_PLN-1)
    GERR     = 1
    GMESSAGE = mess(832,GML_MSGFAS,1)-"["+format$(GFMDAT4,[M:FMR]STRDPRDAT(I_PLN-1))+"]" #"La date de modernisation ne peut être antérieure à la date de début d'amortissement"
    mkstat   = 2
    End
   Endif
  Endif
 Next I_PLN

 #> Retroactive modernization : DEPREC record existing control

 For I_PLN=1 To [M:FMR]NBPLN
  If VALEUR<[M:FMR]MDRMINDAT
   GERR     = 1
   GMESSAGE = mess(838,GML_MSGFAS,1)-"["+format$(GFMDAT4,[M:FMR]MDRMINDAT)+"]" #"La date de modernisation ne peut être antérieure à la période de reprise du bien débutant le"
   Break
  Endif
 Next I_PLN
 If GERR : End : Endif

 #> Retroactive modernization : Other actions control

 Local Integer LRVAACT(1..G301MAX-1)
 Local Integer LIMLACT(1..G301MAX-1)

 For I_PLN=1 To [M:FMR]NBPLN
  If VALEUR<[M:FMR]PERSTRDAT(I_PLN-1)
   Local Integer LACT(1..3)
   Local Integer CODERR
   Call CTRL_MDR_OTH_ACT([M:FAS0]CPY, [M:FAS0]AASREF, [M:FMR]MDRPLN(I_PLN-1), VALEUR, LACT,CODERR)
   If LACT(1)=G_OUI : LRVAACT([M:FMR]MDRPLN(I_PLN-1))=G_OUI : Endif
   If LACT(2)=G_OUI : LIMLACT([M:FMR]MDRPLN(I_PLN-1))=G_OUI : Endif
  Endif
 Next I_PLN

 If find(G_OUI,LRVAACT) | find (G_OUI,LIMLACT)
  GMESSAGE = mess(833,GML_MSGFAS,1)+":\" #"Date de modernisation antérieure à"
  If find(G_OUI,LRVAACT)
   GMESSAGE+= mess(834,GML_MSGFAS,1)-":"-mess(184,GML_MSGFAS,1)+space$(1) #"Réévaluation"
   For I_PLN=1 To G301MAX-1
    If LRVAACT(I_PLN)=G_OUI
     GMESSAGE+=mess(I_PLN,3101,1)+space$(1)
    Endif
   Next I_PLN
   GMESSAGE+="\"
  Endif
  If find(G_OUI,LIMLACT)
   GMESSAGE+=mess(148,GML_MSGFAS,1)-":"-mess(184,GML_MSGFAS,1)+space$(1) # "Dépréciation"-":"-"plan"
   For I_PLN=1 To G301MAX-1
    If LIMLACT(I_PLN)=G_OUI
     GMESSAGE+=mess(I_PLN,3101,1)+space$(1)
    Endif
   Next I_PLN
  Endif
  If GMESSAGE<>""
   GERR   = 2
   mkstat = 2
   End
  Endif
 Endif

End

#-------------------------------------------------------------------------------------
Subprog AM_MDRDATACT(VALEUR)
Variable Date    VALEUR

 If VALEUR=[0/0/0] : End : Endif

 Local Integer I_MDRPLN
 Local Integer LMDRPOST
 Local Date    LREAMDRDAT
 For I_MDRPLN=1 To [M:FMR]NBPLN
  If VALEUR<[M:FMR]PERSTRDAT(I_MDRPLN-1)
   LMDRPOST=0
  Else
   If [M:FMR]MDRPLN(I_MDRPLN-1)=G301FIS | [M:FMR]MDRCURPER<>G_OUI
    LMDRPOST=1
   Else
    LMDRPOST=0
   Endif
  Endif
  LREAMDRDAT=gdat$(1,month(VALEUR)+LMDRPOST,year(VALEUR))
  #> Retroactive modernization : date control.
  If LREAMDRDAT<=[M:FMR]MDRPREDAT(I_MDRPLN-1)
   GERR     = 2
   GMESSAGE = mess(835,GML_MSGFAS,1) #"La date de modernisation ne peut être inférieure ou égale à la date effective d'une précédente modernisation"
   mkstat=2
   End
  Else
   [M:FMR]MDRDAT(I_MDRPLN-1)=LREAMDRDAT
  Endif
 Next I_MDRPLN

 Affzo [M:FMR]MDRDAT
End

#-------------------------------------------------------------------------------------
Subprog AM_MDRPLNFLG(VALEUR)
Variable Integer VALEUR
 If VALEUR=G_OUI
   #> Control on the starting date of fiscal year
   If [M:FMR]MDRDATACT<[M:FMR]FIYSTRDAT(nolign-1)
    GERR     = 1
    GMESSAGE = mess(836,GML_MSGFAS,1) #"La date de modernisation ne peut inférieure à la date de début d'exercice des plans à moderniser"
    mkstat   = 2
    End
   Endif
   #> Control on the end date of current period
   If [M:FMR]MDRDATACT>[M:FMR]PERENDDAT(nolign-1)
    GERR     = 1
    GMESSAGE = mess(837,GML_MSGFAS,1) #"La date de modernisation ne peut supérieure à la date de fin de période des plans à moderniser"
    mkstat   = 2
   Endif
 Elsif VALEUR=G_NON
  Local Integer I_MDRPLN
  For I_MDRPLN=1 To [M:FMR]NBPLN
   If I_MDRPLN<>nolign & [M:FMR]MDRPLNFLG(I_MDRPLN-1)=G_OUI
    Local Integer LONEPLN : Break
   Endif
  Next I_MDRPLN
  If dim(LONEPLN)<0
   GERR     = 1
   GMESSAGE = mess(820,GML_MSGFAS,1) #"Au moins un plan doit être modernisé"
   mkstat   = 2
  Else
   Kill LONEPLN
  Endif
 Endif
End

#-------------------------------------------------------------------------------------
Subprog AM_MDRDAT(VALEUR)
Variable Date    VALEUR


 If [M:FMR]MDRDATACT < [M:FMR]PERSTRDAT(nolign-1) and VALEUR <> [M:FMR]MDRDATACT
  # Dans le cas d'une modernisation rétroactive, la date effective doit être égale à la date de modernisation
  GMESSAGE = mess(855,GML_MSGFAS,1)
  GERR   = 1
  mkstat = 2
  End
 Else
  If VALEUR<[M:FMR]STRDPRDAT(nolign-1)
   # "La date effective ne peut être antérieure à la date de début d'amortissement"
   GERR     = 1
   GMESSAGE = mess(858,GML_MSGFAS,1)-"["+format$(GFMDAT4,[M:FMR]STRDPRDAT(nolign-1))+"]"
   mkstat   = 2
   End
  Else
   If find (VALEUR, [M:FMR]PERSTRDAT(nolign-1), [M:FMR]PERENDDAT(nolign-1)+1, [M:FMR]FIYENDDAT(nolign-1)+1 ) = 0
    # La date effective ne peut être que le début de la période courante ou suivante ou le début de l'exercice suivant
    GMESSAGE = mess(854,GML_MSGFAS,1)
    GERR   = 1
    mkstat = 2
    End
   Endif
  Endif
 Endif



End
######################################################################################
# Field actions of the [M:OAC0] mask
######################################################################################

#-------------------------------------------------------------------------------------
Subprog AM_CCLMDRFLG(VALEUR)
Variable Integer VALEUR
 Actzo [M:DDE1]
 [M:OAC0]CCLMDRFLG=VALEUR
 Gosub REMPLI_TABLEAU From TRTFASDDE
End

