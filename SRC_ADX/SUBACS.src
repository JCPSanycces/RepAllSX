#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion du fichier ACCCOD
#Call S_TAB_CHAR(GBIDC1,GBIDC2,"SELACC","SUBACS","") From GACTION
#End
Call OBJET("ACS",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "CHANGE"    : Gosub CHANGE
 When "MODIF"     : Gosub MODIF
 When "ANNULE"    : Gosub ANNULE
 When "SETBOUT"   : Gosub SETBOUT
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "INICRE"    : Gosub INICRE
 When "SEL_TABLE" : Gosub SEL_TABLE
 When Default
Endcase
Return

$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Endif
Return

$VERIF_MOD
Local Char BID(80)
For I=0 To [M]NBLIG-1
 Read [ACS]ACS0 = [M]CODACC(I)
 If fstat
  [M]MODIF(I) = 2
 Else
  Call LECTEXTRA(BID,"ACCCOD","DESACC",[M]CODACC(I),"") From ATEXTRA
  If BID<>[M]DESACC(I)
   [M]MODIF(I) = 1
  Else
   [M]MODIF(I) = 0
  Endif
 Endif
Next I
Return

$INICRE
Case [M]MODIF(nolign-1)
 When 0
  If dim([F:ACS]CREUSR)>0 & dim([M]CREUSR)>0 : [F:ACS]CREUSR = [M]CREUSR(nolign-1) : Endif
  If dim([F:ACS]CREDAT)>0 & dim([M]CREDAT)>0 : [F:ACS]CREDAT = [M]CREDAT(nolign-1) : Endif
 When 1 : # Modification
  If dim([F:ACS]CREUSR)>0 & dim([M]CREUSR)>0 : [F:ACS]CREUSR = [M]CREUSR(nolign-1) : Endif
  If dim([F:ACS]CREDAT)>0 & dim([M]CREDAT)>0 : [F:ACS]CREDAT = [M]CREDAT(nolign-1) : Endif
  If dim([F:ACS]UPDUSR)>0 : [F:ACS]UPDUSR = GUSER   : Endif
  If dim([F:ACS]UPDDAT)>0 : [F:ACS]UPDDAT = date$   : Endif
 When 2 : # Création
  If dim([F:ACS]CREUSR)>0 : [F:ACS]CREUSR = GUSER   : Endif
  If dim([F:ACS]CREDAT)>0 : [F:ACS]CREDAT = date$   : Endif
  If dim([F:ACS]UPDUSR)>0 : [F:ACS]UPDUSR = ""      : Endif
  If dim([F:ACS]UPDDAT)>0 : [F:ACS]UPDDAT = [0/0/0] : Endif
Endcase
Return

$ANNULE
For [AUS]
 Lock ="AUS"+[F:AUS]USR With lockwait=0
 If fstat : GOK = -1 : Break : Endif
 Delete [ACC] Where  USR=[F:AUS]USR & CODACC=[L]CODE
Next AUS
If GOK<>1 : Return : Endif
Delete [AXX] Where CODFIC="ACCCOD" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

$MODIF
For [AUS]
 If [F:AUS]ALLACS=2
  Lock ="AUS"+[F:AUS]USR With lockwait=0
  If fstat : GOK = -1 : Break : Endif
  For nolign=1 To [M]NBLIG
   Look [ACC]CODACC = [F:AUS]USR;[M:ACS1]CODACC(nolign-1)
   If fstat
    Raz [F:ACC]
    [F:ACC]CONSUL = 2
    [F:ACC]EXEC   = 2
    [F:ACC]MODIF  = 2
    [F:ACC]USR    = [F:AUS]USR
    [F:ACC]CODACC = [M:ACS1]CODACC(nolign-1)
    Write [ACC]
    If fstat
     GOK = 0 : Call FSTA("ACC") From GLOCK : Break 2
    Endif
   Endif
  Next nolign
 Endif
Next AUS
If GOK<>1 : Return : Endif
Delete [AXX] Where CODFIC="ACCCOD" & LANGUE=GLANGUE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX","*") From GLOCK : Return
Endif
For nolign=1 To [M]NBLIG
 Call MAJTEXTRA([M]DESACC(nolign-1),"ACCCOD","DESACC",[M]CODACC(nolign-1),"") From ATEXTRA
 If GOK<1 : Break : Endif
Next nolign
Return

$CHANGE
Update [AXX] Where CODFIC="ACCCOD" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA ACCCOD"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

#######################################################################
$SEL_TABLE
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ACC])=0 : Local File ACCES   [ACC] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
If clalev([F:ACS])=0 : Local File ACCCOD  [ACS] : Endif
If GUSRACS=2
 OBJET = "ACS"
 SUPP = ""
Else
 Link [ACS] With
& [ACC]CODACC = GUSER;[F:ACS]CODACC,
& [AXX]AXX0="ACCCOD";"DESACC";GLANGUE;[F:ACS]CODACC;""
& As [ACS_]
 Default File [ACS_]
 CRITERE = '[F:ACC]USR="'+GUSER+'" & [F:ACC]MODIF=2'
 ORDRE = "CODACC"
 START = "CODACC"
 TIT(0) = mess(5,104,1) : # Choix code d'accès
 Call TRANSCOL("ACS",NBCOL,COL,TIT,FMTCOL) From OBJDIV
Endif
Return

$TEXTE
Read [ATZ]CODZONE = FICHE;right$(COL(NBCOL),instr(1,COL(NBCOL),"]")+1)
Call TEXTE([F:ATZ]NOCOURT,TIT(NBCOL)) From OBJDIV
Return

################################################################
## Contrôle que le code d'accès est autorisé en modif         ##
################################################################
Subprog CONTACC(ACCES)
Value    Char     ACCES
If ACCES="" : End : Endif
If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
Read [ACC]CODACC = GUSER;ACCES
If GUSRACS=2
 If fstat
  GMESSAGE = ACCES-":"-mess(56,133,1) : mkstat = 2 : End
# Code inexistant
 Endif
Else
 If fstat
  GMESSAGE = ACCES-":"-mess(57,133,1) : mkstat = 2 : End
# Vous n'avez pas accès à ce code
 Endif
 If [F:ACC]MODIF<>2
  GMESSAGE = ACCES-":"-mess(58,133,1) : mkstat = 2
#  Vous n'avez pas les droits pour ce code
 Endif
Endif
End

################################################################
## Lecture du droit de modifier la fiche                      ##
################################################################
Subprog LECACC(ACCES,DROIT)
Value    Char    ACCES
Variable Integer DROIT
If ACCES="" or GUSRACS=2 : DROIT = 1 : End : Endif
If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
Read [ACC]CODACC = GUSER;ACCES
If !fstat & [F:ACC]MODIF=2
 DROIT = 1
Else
 DROIT = 0
Endif
End

################################################################
## Contrôle droit d'exécution                                 ##
################################################################
Subprog CONTEXE(ACCES)
Value    Char    ACCES
If ACCES="" or GUSRACS=2 : mkstat = 0 : End : Endif
If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
Read [ACC]CODACC = GUSER;ACCES
If fstat | [F:ACC]EXEC<>2
 GMESSAGE = ACCES-":"-mess(59,133,1) : # Vous n'avez pas les droits d'exécution
 mkstat = 1
Else
 mkstat = 0
Endif
End

##########################################################################
## Lecture du droit de consulter la fiche                     ##
################################################################
Subprog CONSACC(ACCES,DROIT)
Value    Char    ACCES
Variable Integer DROIT
If ACCES="" or GUSRACS=2 : DROIT = 1 : End : Endif
If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
Read [ACC]CODACC = GUSER;ACCES
If !fstat & [F:ACC]CONSUL=2
 DROIT = 1
Else
 DROIT = 0
Endif
End

#######################################
$TRTCOP
If [M]DOSORG=nomap
 Local File ACCCOD  [ACS1]
 Local File ATEXTRA [AXX1]
Else
 Local File =[M]DOSORG+".ACCCOD"  [ACS1]
 Local File =[M]DOSORG+".ATEXTRA" [AXX1]
Endif
If [M]DOSDES=nomap
 Local File ACCCOD  [ACS2]
 Local File ATEXTRA [AXX2]
 Local File AUTILIS [AUS2]
 Local File ACCES [ACC2]
Else
 Local File =[M]DOSDES+".ACCCOD"  [ACS2]
 Local File =[M]DOSDES+".ATEXTRA" [AXX2]
 Local File =[M]DOSDES+".AUTILIS" [AUS2]
 Local File =[M]DOSDES+".ACCES" [ACC2]
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ACS1], [ACS2] , [AXX1] , [AXX2], [AUS2],[ACC2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [ACS2]
 For [ACS1]ACS0
  Read [ACS2]ACS0 = [F:ACS1]CODACC
  If fstat
   [F:ACS2] = [F:ACS1]
   If dim([F:ACS2]CREUSR)>0 : [F:ACS2]CREUSR = GUSER : Endif
   If dim([F:ACS2]CREDAT)>0 : [F:ACS2]CREDAT = date$ : Endif
   If dim([F:ACS2]CRETIM)>0 : [F:ACS2]CRETIM = time  : Endif
   If dim([F:ACS2]UPDUSR)>0 : Raz [F:ACS2]UPDUSR     : Endif
   If dim([F:ACS2]UPDDAT)>0 : Raz [F:ACS2]UPDDAT     : Endif
   If dim([F:ACS2]UPDTIM)>0 : Raz [F:ACS2]UPDTIM     : Endif
   Write [ACS2]
   If fstat
    GOK=0 : Call FSTA("ACS2") From GLOCK : Break
   Endif
   Call COPTEXTRA("ACCCOD","DESACC",[F:ACS1]CODACC,"") From ATEXTRA
   #111464
   For [AUS2]
    If [F:AUS2]ALLACS=2
      Look [ACC2]CODACC = [F:AUS2]USR;[F:ACS2]CODACC
      If fstat
       Raz [F:ACC2]
       [F:ACC2]CONSUL = 2
       [F:ACC2]EXEC   = 2
       [F:ACC2]MODIF  = 2
       [F:ACC2]USR    = [F:AUS2]USR
       [F:ACC2]CODACC = [F:ACS2]CODACC
       Write [ACC2]
       If fstat
        GOK = 0 : Call FSTA("ACC2") From GLOCK : Break 2
       Endif
      Endif
    Endif
   Next AUS2
  Endif
 Next ACS1
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

########################################################
Subprog C_CODACC(VALEUR)
Variable Char     VALEUR
Call UNICITE(VALEUR,[M]CODACC(0..[M]NBLIG-1)) From OBJDIV
End

Subprog AS_CODACC(VALEUR)
Variable Char     VALEUR
If VALEUR <> ""
 Look [ACS]ACS0 = VALEUR
 If !fstat : mkstat = 2 : Endif
Endif
End

