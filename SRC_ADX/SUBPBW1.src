#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion du masque PBENCHW3
########################################
$ACTION
Case ACTION
 When "AAM_STOFCY"   : Gosub AAM_STOFCY
 When "BAM_STOFCY"   : Gosub BAM_STOFCY
Endcase
Return

########################################
$AAM_STOFCY
#-------------------------------------------------------------#
# Avant exécution de l'action GOBJETC0A (tunnel article-site) #
#-------------------------------------------------------------#
Local Shortint NOL       : NOL=nolign-1
Local Char     SITE(GLONFCY)   : SITE=VALEUR
Local Char     WOBJET(GLONAOB) : WOBJET="ITF"
#----- Restauration de l'ancienne valeur et blocage sur le champ -----#
If GBIDI1=1  VALEUR=[M:PBW1]STOFCY : mkstat=1 : Endif
If GBIDI1<>2 WOBJET="" : Endif : # Pas d'exécution du tunnel
GFLTITM=[M:PBW1]ITMREF
Return

########################################
$BAM_STOFCY
#-------------------------------------------------------------#
# Après exécution de l'action GOBJETC0A (tunnel article-site) #
#-------------------------------------------------------------#
nolign=NOL+1: # Restitution du nolign
Raz GFLTITM
If GBIDI1=0  Return : Endif
VALEUR=SITE
Read [ITF] ITF0=[M:PBW1]ITMREF;VALEUR
If fstat Raz [F:ITF] : Endif
If [F:ITF]ITMREF="" mkstat=1 : Endif
Return
########################################
Subprog AM_EXTRCPDAT(VALEUR)
Variable Date    VALEUR
Local    Date    TODAY : TODAY = date$

If VALEUR < datesyst
          Call MESSAGE(mess(65,194,1)) From GESECRAN
Endif
[M:PBW1]EXTRCPDAT = VALEUR
Gosub CHARGE_WRCPDAT From BENCHLIBP

# raffraichissement liste contrats
If [M:PBW1]EXTRCPDAT <> [0/0/0]
    WDATEREF = [M:PBW1]EXTRCPDAT
Else
    WDATEREF = TODAY
Endif
# GH 27/06/2012 bug 83199
#Filter [POC] Where ITMREF = [M:PBW1]ITMREF & ENDDAT >= WDATEREF & PRHFCY = [M:PBW1]STOFCY & WDATEREF >= date$
Filter [POC] Where ITMREF = [M:PBW1]ITMREF & ENDDAT >= WDATEREF & PRHFCY = [M:PBW1]STOFCY & STRDAT <= WDATEREF
nolign = 1
For [POC]POC2
    If nolign > dim([M:PBW1]SELIND) : Break : Endif
    Read [POH]POH0=[F:POC]POHNUM
    If fstat : Goto N_POC : Endif
    If !find([F:POH]APPFLG,3,4,5) : Goto N_POC : Endif
    If [F:POH]CLEFLG = 2          : Goto N_POC : Endif
    [M:PBW1]SELIND(nolign-1) = 1
    [M:PBW1]POHNUM(nolign-1) = [F:POC]POHNUM
    [M:PBW1]BPSNUM2(nolign-1)= [F:POC]BPSNUM
    [M:PBW1]STRDAT(nolign-1) = [F:POC]STRDAT
    [M:PBW1]ENDDAT(nolign-1) = [F:POC]ENDDAT
    [M:PBW1]PUU2(nolign-1)   = [F:POC]PUU
    [M:PBW1]USEPLC2(nolign-1)= [F:POC]USEPLC
    [M:PBW1]PURFCY(nolign-1) = [F:POC]POHFCY
    nolign += 1
$N_POC
Next
[M:PBW1]NBLIG = nolign - 1
Filter [POC]

Actzo [M:PBW1]BPSNUM
Actzo [M:PBW1]PJT
Affzo [M:PBW1]25

End

########################################
Subprog AS_QTYUOM(VALEUR)
Variable Decimal VALEUR
GBOUT1 = ""

If clalev([F:ITF])=0 Local File ITMFACILIT [ITF]  Endif

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [M:PBW1]STOFCY | [F:ITF]ITMREF <> [F:ITM]ITMREF
   Read [ITF]ITF0 = [F:ITM]ITMREF;[M:PBW1]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif

If [F:ITF]STOMGTCOD > 1 : GBOUT1=mess(102,198,1) : Endif
GBOUT2 = mess(332,198,1)
End

########################################
Subprog AM_QTYUOM(VALEUR)
Variable Decimal VALEUR

Call UPD_PPTOTALS([M:PBW1]QTYSTU)    # 106430.n
Affzo [M:PBW1]QTYSTU

End

########################################
Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()
Local Integer    WRETOUR, I
Local Decimal    WCOEUOM

If VALEUR = "" : Goto NXT_BPS : Endif

# interx
If [F:BPR]BPRNUM <> VALEUR
    Read [F:BPR]BPR0=VALEUR
    If fstat : Raz [BPR] : Endif
Endif
If [F:BPR]FCY <> ""
    [M:PBW1]APPFCY = [F:BPR]FCY
Endif
#-------------------------------------------#
# vérification couple article - fournisseur #
#-------------------------------------------#
If clalev([F:ITP]) = 0 : Local File ITMBPS [ITP] : Endif
Read [ITP]ITP0 = [M:PBW1]ITMREF;VALEUR
If fstat = 0
    # test du code blocage
    If [F:ITP]DOUFLG = 3
           GMESSAGE = mess(9,194,1)
           Call ERREUR(GMESSAGE) From GESECRAN
           mkstat = 2
           End
    Elsif [F:ITP]DOUFLG = 2
           GMESSAGE = mess(9,194,1)
           Call AVERTIR(GMESSAGE, WRETOUR) From GESECRAN
           If WRETOUR= 1
                     VALEUR = [M:PBW1]BPSNUM
                     mkstat = 2
                     End
           Endif
    Endif
    # récupération du nouveau coeff de UOM si l'ancien et le nouveau founisseur ont la même unité
    If [F:ITP]PUU = [M:PBW1]UOM
            Call PCAL_QTY ([M:PBW1]QTYUOM, [M:PBW1]UOM, [M:PBW1]QTYSTU, [M:PBW1]STU,
&                  [M:PBW1]ITMREF, VALEUR, 1, WCOEUOM) From TRTACHQTE1
            Affzo [M:PBW1]15
            End
    Endif
    If [F:ITP]PCU = [M:PBW1]UOM
            Call PCAL_QTY ([M:PBW1]QTYUOM, [M:PBW1]UOM, [M:PBW1]QTYSTU, [M:PBW1]STU,
&                  [M:PBW1]ITMREF, VALEUR, 1, WCOEUOM) From TRTACHQTE1
            Affzo [M:PBW1]15
            End
    Endif
    Gosub SEARCH_UNIT
    End
Endif

$NXT_BPS
# couple article - fournisseur n'existe pas
# Issue 77999 - 2011-11-18 by VPO : référencement inutile si fournisseur de type Divers
If clalev ([F:BPS]) <= 0 : Local File BPSUPPLIER [BPS] : Endif
If [F:BPS]BPSNUM<>VALEUR
  Read [BPS] BPS0=VALEUR : If fstat Raz [F:BPS] : Endif
Endif
#----- Si fournisseur <> Divers -----#
If [F:BPS]BPSTYP<>3
  # Issue 6976 - 2011-12-16 by MUARN : référencement inutile si article type générique
  If [F:ITM]GENFLG <> 2
    # couple article - fournisseur n'existe pas
    If GITMBPS = 1
        # paramètre général : on ne continue pas
        Call ERREUR(mess(8,194,1)) From GESECRAN
        mkstat = 2
    Elsif GITMBPS = 2
        # paramètre général : facultatif donc avertir
        Call AVERTIR(mess(8,194,1),WRETOUR) From GESECRAN
        If WRETOUR = 1
            VALEUR = [M:PBW1]BPSNUM
            mkstat = 2
        Endif
    Endif
  Endif
Endif
If mkstat : End : Endif

Gosub SEARCH_UNIT

End

########################################
$SEARCH_UNIT
Local Integer WFIND : WFIND = 0


# si l'ancien fournisseur utilisait une unité qui n'est ni l'US, ni l'UC ni l'UA, on force l'UOM à l'UA
For [ITM]ITM0 Where ITMREF = [M:PBW1]ITMREF
    If [F:ITM]PUU = [M:PBW1]UOM : WFIND =1 : Break : Endif
    If [F:ITM]STU = [M:PBW1]UOM : WFIND =1 : Break : Endif
    I = 0
    While  [F:ITM]PCU(I)<>""
        If [F:ITM]PCU(I) = [M:PBW1]UOM :  WFIND =1 : Break 2 : Endif
        I += 1
    Wend
Next
If  WFIND = 1
    Call PCAL_QTY ([M:PBW1]QTYUOM, [M:PBW1]UOM, [M:PBW1]QTYSTU, [M:PBW1]STU,
&                  [M:PBW1]ITMREF, VALEUR, 1, WCOEUOM) From TRTACHQTE1
Else
    # l'unité XXX n'est trouvée que chez le fournisseur YYY. Il y aura conversion.
    GMESSAGE = mess(364,194,1)-[M:PBW1]UOM- mess(365,194,1) -[M:PBW1]BPSNUM -"."- mess(366,194,1)
    Call MESSAGE(GMESSAGE) From GESECRAN
    # on n'a pas trouvé [M]UOM, on force sa valeur à PUU
    [M:PBW1]UOM = [F:ITM]PUU
    Call PCAL_QTY ([M:PBW1]QTYSTU, [M:PBW1]STU,[M:PBW1]QTYUOM, [M:PBW1]UOM,
&                  [M:PBW1]ITMREF, VALEUR, 1, WCOEUOM) From TRTACHQTE1
Endif

Affzo [M:PBW1]15

Return

########################################
Subprog B2_QTYUOM(VALEUR)
Variable Decimal VALEUR
Local    Char    WNUM(GLONVCR) : WNUM = [M:PBW1]VCRNUM
Local    Char    WLIN          : WLIN = num$([M:PBW1]VCRLIN)

If [M:PBW1]POCNUM <> ""
    Call OBJET ("POD", WLIN, WNUM) From GOBJET
Else
    Call OBJET("POH",WNUM,"") From GOBJET
Endif

End

########################################
Subprog AS_BPSNUM(VALEUR)
Variable Char    VALEUR()
GBOUT2 = mess(23,198,1)
GBOUT3 = mess(24,198,1)

End

########################################
Subprog C_EXTRCPDAT(VALEUR)
Variable Date    VALEUR
# llc 11.01 11042
#----- Contrôle article en fin de vie ------#
If [F:ITM]LIFENDDAT <> [0/0/0] & [F:ITM]LIFENDDAT < date$
   mkstat = 1 : GMESSAGE = mess(12,318,1) : End
Endif
# Issue 104943 - 2015-07-06 by BEEBE : Implementing Versioning
If dim([M:PBW5]ECCVALMAJ)>0
    Call C_EXTRCPDAT(VALEUR, "PBW1") From SUBPBWECC
Endif
End


##########################################################################
Subprog C_BPSNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer INDINTER : INDINTER = 0

If VALEUR <> ""
    Read [BPR]BPR0=VALEUR
    If fstat : Raz [F:BPR] : Endif

    If [F:BPR]FCY <> ""
        If [F:FCY]FCY <> [F:BPR]FCY
            Read [FCY]FCY0=[F:BPR]FCY
            If fstat : Raz [FCY] : Endif
        Endif
    Endif
    If !find([M:PBW1]INTHAB,2,3,4,5,6,7) & [F:BPR]FCY <> "" & [F:FCY]LEGCPY = GSOCIETE
        GMESSAGE =mess(233,193,1) :  mkstat=2 : End
    Endif
    If !find([M:PBW1]APPHAB,2,3,4,5,6,7) & ([F:BPR]FCY = "" | ([F:BPR]FCY <> "" & [F:FCY]LEGCPY <> GSOCIETE))
        GMESSAGE =mess(235,193,1) :  mkstat=2 : End
    Endif
    If [F:BPR]FCY <> "" & [F:FCY]LEGCPY = GSOCIETE  : INDINTER = 1 : Endif
Endif
End


##########################################################################

##########################################################################
## Etiquette ajoutée par le superviseur 16/02/2004 09:35:52 (LLC)
##########################################################################
Subprog AM_SELIND(VALEUR)
Variable Integer VALEUR
Local Integer I
Local Integer    WRETOUR
Local Decimal    WQTY
Local Decimal    WCOEUOM


[M:PBW1]SELIND(nolign-1) = VALEUR
For  I = 0 To [M:PBW1]NBLIG - 1
    If I <> nolign - 1 : [M:PBW1]SELIND(I) = 1 : Endif
Next I
Case VALEUR
    When 2:            Call C_BPSNUM([M:PBW1]BPSNUM2(nolign-1))
                       If mkstat : End : Endif
                       WQTY = [M:PBW1]QTYUOM

                       # 29397 mm 12.06
                       If [M:PBW1]UOM <> [M:PBW1]PUU2(nolign-1)
                            #Les unités d'achat et de commande sont différentes.\Il y aura reconversion
                            GMESSAGE =mess(363,194,1)
                            Call MESSAGE(GMESSAGE) From GESECRAN
                            #--------- qté achat saisie ------#
                            Call PCAL_QTY ([M:PBW1]QTYUOM, [M:PBW1]UOM, WQTY, [M:PBW1]PUU2(nolign-1),
&                                         [M:PBW1]ITMREF, [M:PBW1]BPSNUM2(nolign-1), 1, WCOEUOM) From TRTACHQTE1
                       Endif

                       [M:PBW1]QTYUOM = WQTY
                       [M:PBW1]UOM    = [M:PBW1]PUU2(nolign-1)
                       # qté stock saisie
                       Call PCAL_QTY ([M:PBW1]QTYUOM, [M:PBW1]UOM, [M:PBW1]QTYSTU, [M:PBW1]STU,
&                                      [M:PBW1]ITMREF, [M:PBW1]BPSNUM2(nolign-1), 1, WCOEUOM) From TRTACHQTE1

                       [M:PBW1]POCNUM = [M:PBW1]POHNUM(nolign-1)
                       [M:PBW1]BPSNUM = [M:PBW1]BPSNUM2(nolign-1)
                       [M:PBW1]USEPLC = [M:PBW1]USEPLC2(nolign-1)
                       [M:PBW1]PSHFCY = [M:PBW1]PURFCY(nolign-1)
    When Default:      [M:PBW1]POCNUM = ""
                       Call AM_BPSNUM([M:PBW1]BPSNUM)
Endcase
Affzo [M:PBW1]15-25
End

########################################
Subprog AV_BPSNUM(VALEUR)
Variable Char    VALEUR()

If [M:PBW1]ORDQTYPUU <>0 : End : Endif            # 29397 mm 12.06 - cas où la DA partielle commandée

If find(2,[M:PBW1]SELIND(0..[M:PBW1]NBLIG-1))
    Diszo [M:PBW1]UOM
    Diszo [M:PBW1]BPSNUM
    Diszo [M:PBW1]PJT
Else
    If [F:BTS]UOMSAI=2 : Actzo [M:PBW1]UOM : Endif          # 29397 mm 12.06 - UOM non saisissable
    Actzo [M:PBW1]BPSNUM
    Actzo [M:PBW1]PJT
Endif


End



