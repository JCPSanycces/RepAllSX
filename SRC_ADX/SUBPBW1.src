End

Subprog AM_WEICAP(VALEUR)
Variable Decimal VALEUR

Raz [M:PBW1]WEIAVL
If VALEUR > 0 : [M:PBW1]WEIAVL = VALEUR-[M:PBW1]WEITOT : Endif

If [M:PBW1]WEIAVL<0
  Chgstl [M:PBW1]WEIAVL With "NBNEGATIF"
Else
  Chgstl [M:PBW1]WEIAVL With ""
Endif

Affzo [M:PBW1]WEIAVL

End

Subprog AM_VOLCAP(VALEUR)
Variable Decimal VALEUR

Raz [M:PBW1]VOLAVL
If VALEUR > 0 : [M:PBW1]VOLAVL = VALEUR-[M:PBW1]VOLTOT : Endif

If [M:PBW1]VOLAVL<0
  Chgstl [M:PBW1]VOLAVL With "NBNEGATIF"
Else
  Chgstl [M:PBW1]VOLAVL With ""
Endif

Affzo [M:PBW1]VOLAVL

End

######################################################################################
# 106430 - Purhcase planning - Update header total fields
######################################################################################
Subprog UPD_PPTOTALS(QTY)
Variable Decimal QTY

Raz [M:PBW1]WEITOT, WEIAVL, VOLTOT, VOLAVL, TOTCOST

[M:PBW1]WEITOT    = [M:PBW1]ITMWEI * QTY
If [M:PBW1]WEU<>[M:PBW1]TCTRWEU
  Call CONVERT_QTY([M:PBW1]WEU,[M:PBW1]TCTRWEU,[M:PBW1]WEITOT)From TRTX3
Endif
If [M:PBW1]WEICAP > 0 : [M:PBW1]WEIAVL = [M:PBW1]WEICAP-[M:PBW1]WEITOT : Endif

#Volumes
[M:PBW1]VOLTOT    = [M:PBW1]ITMVOL * QTY
If [M:PBW1]VOU<>[M:PBW1]TCTRVOU
  Call CONVERT_QTY([M:PBW1]VOU,[M:PBW1]TCTRVOU,[M:PBW1]VOLTOT)From TRTX3
Endif
If [M:PBW1]VOLCAP > 0 : [M:PBW1]VOLAVL = [M:PBW1]VOLCAP-[M:PBW1]VOLTOT : Endif

#Costs
[M:PBW1]TOTCOST     = [M:PBW1]PURBASPRI * QTY

If [M:PBW1]WEIAVL<0
  Chgstl [M:PBW1]WEIAVL With "NBNEGATIF"
Else
  Chgstl [M:PBW1]WEIAVL With ""
Endif

If [M:PBW1]VOLAVL<0
  Chgstl [M:PBW1]VOLAVL With "NBNEGATIF"
Else
  Chgstl [M:PBW1]VOLAVL With ""
Endif

Affzo [M:PBW1]WEITOT, WEIAVL, VOLTOT, VOLAVL, TOTCOST

End

######################################################################################
# 106430 - Update container related fields
######################################################################################
Subprog UPD_CONTAINER (TCTRNUM,TCTRQTY)
Value Char    TCTRNUM
Value Integer TCTRQTY

Read [TCTR]TCTR0 = [L]TCTRNUM
If fstat : Raz [F:TCTR] : Endif

If [L]TCTRNUM = ""
  Raz [M:PBW1]TCTRQTY : Diszo [M:PBW1]TCTRQTY
  Actzo [M:PBW1]WEICAP, VOLCAP
Else
  Actzo [M:PBW1]TCTRQTY

  #Set the weight and volume capacity for the container
  If [L]TCTRQTY <= 0 : [L]TCTRQTY=1 : Endif
  [M:PBW1]WEICAP = [F:TCTR]MAXWEI  * [L]TCTRQTY
  [M:PBW1]VOLCAP = [F:TCTR]TCTRVOL * [L]TCTRQTY

  Affzo [M:PBW1]WEICAP, VOLCAP
  Diszo [M:PBW1]WEICAP, VOLCAP
Endif

#Set the UOM for both weight and volume
If [F:TCTR]WEU="" : [M:PBW1]TCTRWEU = GSALDSPWEU : Else : [M:PBW1]TCTRWEU = [F:TCTR]WEU : Endif
If [F:TCTR]VOU="" : [M:PBW1]TCTRVOU = GSALDSPVOU : Else : [M:PBW1]TCTRVOU = [F:TCTR]VOU : Endif

[M:PBW1]WEITOT = [M:PBW1]ITMWEI * [M:PBW1]QTYSTU
If [M:PBW1]WEU<>[M:PBW1]TCTRWEU #If we didn't change - no need to update
  Call CONVERT_QTY([M:PBW1]WEU,[M:PBW1]TCTRWEU,[M:PBW1]WEITOT)From TRTX3
Endif
If [M:PBW1]WEICAP > 0 : [M:PBW1]WEIAVL = [M:PBW1]WEICAP-[M:PBW1]WEITOT : Endif

[M:PBW1]VOLTOT = [M:PBW1]ITMVOL * [M:PBW1]QTYSTU
If [M:PBW1]VOU<>[M:PBW1]TCTRVOU #If we didn't change - no need to update
  Call CONVERT_QTY([M:PBW1]VOU,[M:PBW1]TCTRVOU,[M:PBW1]VOLTOT)From TRTX3
Endif
If [M:PBW1]VOLCAP > 0 : [M:PBW1]VOLAVL = [M:PBW1]VOLCAP-[M:PBW1]VOLTOT : Endif

If [M:PBW1]WEIAVL<0
  Chgstl [M:PBW1]WEIAVL With "NBNEGATIF"
Else
  Chgstl [M:PBW1]WEIAVL With ""
Endif

If [M:PBW1]VOLAVL<0
  Chgstl [M:PBW1]VOLAVL With "NBNEGATIF"
Else
  Chgstl [M:PBW1]VOLAVL With ""
Endif

Affzo [M:PBW1]TCTRWEU, TCTRVOU, WEITOT, WEIAVL, VOLTOT, VOLAVL
End

