$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Char     A_BUF1(5)(0..GNBDERNIER)
Local Char     A_BUF2(35)(0..GNBDERNIER)
Local Char     A_BUF3(10)(0..GNBDERNIER)
Local Char     A_BUF4(20)(0..GNBDERNIER)
If clalev([F:CPY9])>0 : Close Local File [CPY9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Char     A_TAB1(5),
& Char     A_TAB2(35),
& Char     A_TAB3(10),
& Char     A_TAB4(20)
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4
& As [CPY9]
Return

$LEC_DERLU
Return

$CHARGE_DERLU
If clalev([F:CPY9])>0
 Read [CPY9] = [F:CPY9]A_TABI
 [L]CLE = [F:CPY9]A_TABC
Endif
Return

$REMP_DERLU
If clalev([F:CPY9])>0
 Filter [CPY9]
& Where A_TABI<>0
& Order by A_TABI
 Fillbox [APPLEV1] GAU_CHE9
Endif
Return

$CLE_DERLU
If clalev([F:CPY9])>0
 Local Integer A_IND
 Local Char    A_CLEDERLU(200)
 A_CLEDERLU = ""
 A_CLEDERLU = [F:CPY]CPY+"~"
 A_IND = find(A_CLEDERLU,A_BUFC)
 If A_IND
  [F:CPY9]A_TABI = A_BUFI(A_IND-1)
 Else
  Raz [F:CPY9]
 Endif
Endif
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 1
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:CPY]CPY"
Call TEXTE(1343,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "K:5c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:CPY]CPY"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:CPY]CPYNAM"
Call TEXTE(18622,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:35X"
SELFOR(NBSEL) = "K:35X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:CPY]CPYNAM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:CPY]CPYSHO"
Call TEXTE(4064,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:10X"
SELFOR(NBSEL) = "K:10X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:CPY]CPYSHO"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:CPY]LEG"
Call TEXTE(26213,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:CPY]LEG"
TRILIB(NBTRI) = SELLIB(NBSEL)
Return

