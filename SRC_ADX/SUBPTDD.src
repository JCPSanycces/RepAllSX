#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion du masque PTHD
##########################################################################
# SUBPTDD : Affichage de la situation d'une ligne rcp       HN 05/02/03  #
# ---------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par l'action         #
# VISUETAPTD et sert à gérer le masque  écran "PTDD [PTDD]"              #
##########################################################################
$ACTION
#---------------------------------------------------------------------#
# Actions sur la saisie de fenêtre (GSAISIE)                          #
# VISUETAPTD : Affichage situation ligne de réception                 #
#---------------------------------------------------------------------#
Case ACTION
 When "OUVRE"       : Gosub OUV_VISUETAPTD
 When "TITRE"       : Gosub TITRE_VISUETAPTD
 When "DEBUT"       : Gosub DEB_VISUETAPTD
 When "FINSAI"      : Gosub FINSAI_VISUETAPTD
Endcase
Return
#############################################################################
# Remplacé par l'action VISUETAPTD avec paramètres :                        #
#   PARAM(1) = NUM    : Numéro   de la récept à traiter                     #
#   PARAM(2) = LIN    : Numéro   de la ligne de récept à traiter            #
#   PARAM(3) = WABMSK : Abréviation du masque écran contenant les lignes    #
#   PARAM(4) = NOLIG  : Numéro de ligne tableau lignes commande (nolign-1)  #
#############################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_VISUETAPTD
#----- Variables locales -----#
Local Char     NUMRCP(GLONPTH) : NUMRCP=PARAM(1)
Local Integer  LINRCP          : LINRCP=val(PARAM(2))
Local Char     WABMSK(4)       : WABMSK =PARAM(3)
Local Shortint NOL             : NOL=val(PARAM(4))
Local Shortint SAVGNOLIGN, I, J, K, L
SAVNOLIGN=nolign
If evalue("[M:"+WABMSK+"]NBLIG=0") | 
&  evalue("[M:"+WABMSK+"]ITMREF(NOL)=''") | GREP="C" | GREP="D"
  FIN=1
Endif
Return
#-------------------------------------------#
# Titre juste avant ouverture de la fenêtre #
#-------------------------------------------#
$TITRE_VISUETAPTD
TIT=mess(164,198,1)-NUMRCP-num$(LINRCP)
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUETAPTD
Raz [M:PTDD]
Call TEMPON("O") From GESECRAN
#----- Lecture ligne commande à traiter si nécessaire -----#
If [F:PTD]POHNUM<>NUMRCP | [F:PTD]PTDLIN<>LINRCP
  Read [PTD] PTD0=NUMRCP;LINRCP  : If fstat Raz [F:PTD] : Endif
Endif
#----- Ouverture des fichiers si nécessaire ----#
If clalev([F:PND])<=0 Local File PRETURND  [PND] : Endif
If clalev([F:PIH])<=0 Local File PINVOICE  [PIH] : Endif
If clalev([F:PID])<=0 Local File PINVOICED [PID] : Endif
#----- Chargement des zones dans le masque -----#
[M:PTDD]=[F:PTD]
[M:PTDD]PUU1=[F:PTD]PUU
[M:PTDD]STU1=[F:PTD]STU
#-- Si quantité facturée >= quantité de la réception
If [F:PTD]INVQTYPUU>=[F:PTD]QTYPUU
  [M:PTDD]WLININVFLG=3 : # Totalement facturée
Elsif [F:PTD]INVQTYPUU<=0
  [M:PTDD]WLININVFLG=1 : # Non facturée
Elsif [F:PTD]INVQTYPUU>=0
  [M:PTDD]WLININVFLG=2 : # Facturation partielle
Endif
Raz I
Filter [PID] Where TYPORI=2 & NUMORI=[F:PTD]PTHNUM & LINORI=[F:PTD]PTDLIN & SEQORI=0
&              Order By Key PID1
Gosub CHARG_LIG_FAC
Filter [PID]
If [F:PTD]POHNUM<>""
  #----- Chargement des factures effectuées sur la ligne de commande -----#
  Filter [PID] Where TYPORI=1 & NUMORI=[F:PTD]POHNUM & LINORI=[F:PTD]POPLIN & SEQORI=[F:PTD]POQSEQ
&              Order By Key PID1
  Gosub CHARG_LIG_FAC
  Filter [PID]
Endif
Raz J
Filter [PND] Where PTHNUM=[F:PTD]PTHNUM & PNDLIN=[F:PTD]PTDLIN
&            Order By Key PND1
Gosub CHARG_LIG_RET
Filter [PND]
[M:PTDD]LININVNBR=[M:PTDD]NBFAC
[M:PTDD]LINPNHNBR=[M:PTDD]NBPNH
#----- Affichage foreground -----# 
Filter [PID] : Filter [PND]
Affzo [PTDD] 
Call TEMPOFF From GESECRAN
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUETAPTD
nolign=SAVNOLIGN
Return

#--------------------------#
# Chargement ligne facture #
#--------------------------#
$CHARG_LIG_FAC
For [PID]
 OK=1
 For L=0 To [M:PTDD]NBFAC-1
   If [M:PTDD]NUM(L)=[F:PID]NUM & [M:PTDD]PIDLIN(L)=[F:PID]PIDLIN
     OK=0
   Endif
   If OK=0 Break : Endif
 Next L
 If OK<>0
   [M:PTDD]TYPORI(I)   =[F:PID]TYPORI
   [M:PTDD]NUM(I)      =[F:PID]NUM
   [M:PTDD]PIDLIN(I)   =[F:PID]PIDLIN
   If [F:PIH]NUM<>[F:PID]NUM
     Read [PIH] PIH0=[F:PID]NUM : If fstat Raz [F:PIH] : Endif
   Endif
   [M:PTDD]ACCDAT(I)   =[F:PIH]ACCDAT
   [M:PTDD]FCY(I)     =[F:PID]FCY
   If [F:PID]PIHTYP>2 [M:PTDD]FACQTYPUU(I)=0-[M:PTDD]FACQTYPUU(I) : Endif
   [M:PTDD]FACQTYPUU(I)=[F:PID]QTYPUU
   [M:PTDD]FACQTYSTU(I)=[F:PID]QTYSTU
   If [F:PID]PIHTYP>2 [M:PTDD]FACQTYPUU(I)=0-[M:PTDD]FACQTYPUU(I) : Endif
   [M:PTDD]NETPRI(I)   =[F:PID]NETPRI
   [M:PTDD]CUR(I)      =[F:PIH]CUR
   [M:PTDD]AMTNOTLIN(I)=[F:PID]AMTNOTLIN
   If [F:PID]PIHTYP>2 [M:PTDD]AMTNOTLIN(I)=0-[M:PTDD]AMTNOTLIN(I) : Endif
   I+=1 : [M:PTDD]NBFAC=I
   If I>dim([M:PTDD]NUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
 Endif
Next
Return

#----------------------------#
# Chargement ligne de retour #
#----------------------------#
$CHARG_LIG_RET
For [PND]
  [M:PTDD]PNHNUM(J)=[F:PND]PNHNUM
  [M:PTDD]PNDLIN(J)=[F:PND]PNDLIN
  [M:PTDD]RTNDAT(J)=[F:PND]RTNDAT
  [M:PTDD]PNHFCY(J)=[F:PND]PNHFCY
  [M:PTDD]RTNQTYPUU(J)=[F:PND]QTYPUU
  [M:PTDD]RTNQTYSTU(J)=[F:PND]QTYSTU
  #-- Si quantité facturée >= quantité de la réception
  If [F:PND]INVQTYPUU>=[F:PND]QTYPUU
    [M:PTDD]XLININVFLG(J)=3 : # Totalement facturée
  Elsif [F:PND]INVQTYPUU<=0
    [M:PTDD]XLININVFLG(J)=1 : # Non facturée
  Elsif [F:PND]INVQTYPUU>=0
    [M:PTDD]XLININVFLG(J)=2 : # Facturation partielle
  Endif
  J+=1 : [M:PTDD]NBPNH=J
  If J>dim([M:PTDD]PNHNUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
Next
Gosub CHARG_RET_FAC
Return

$CHARG_RET_FAC
#---------------------------#
# Chargement des avoir      #
#---------------------------#
For J=0 To [M:PTDD]NBPNH-1
  If [M:PTDD]XLININVFLG(J)>1
    I=[M:PTDD]NBFAC
    If I+1>dim([M:PTDD]NUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
    Filter [PID] Where TYPORI=3 & NUMORI=PNHNUM(J) & LINORI=PNDLIN(J)
&                Order By Key PID1
     Gosub CHARG_LIG_FAC
    Filter [PID]
  Endif
Next
Return

##########################################################################



Subprog IB_NBPNH
#--------------------------------------------#
# Avant zone : Activation bouton "Réception" #
#--------------------------------------------#
Raz GBOUT1
If [M:PTDD]PNHNUM(nolign-1)<>"" & GFONC1<>"GESPNH"
  GBOUT1=mess(192,198,1)-[M:PTDD]PNHNUM(nolign-1)
Endif
End

Subprog IB_NBFAC
#------------------------------------------#
# Avant zone : Activation bouton "Facture" #
#------------------------------------------#
Raz GBOUT1
If [M:PTDD]NUM(nolign-1)<>"" & GFONC1<>"GESPIH"
  GBOUT1=mess(55,198,1)-[M:PTDD]NUM(nolign-1)
Endif
End

