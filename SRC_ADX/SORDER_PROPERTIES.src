#######################################################################################
# PROPERTIES                                                                          #
#######################################################################################
# Issue 119956 - 20161124 by LD : Error on orders (read only pages)
# Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - removed all _LEG calls
# ----------------------- LEG --------------------------------------
$LEG
  Case [L]ARULE
    When "GET"       : Gosub GET_LEG
    When Default     : Return
  Endcase
Return

$GET_LEG
  If this.CPY<>""
    Local File COMPANY [CPY]
    Read [F:CPY]CPY0=this.CPY
    If fstat Raz [F:CPY] : Endif
    this.LEG = [F:CPY]LEG
  Endif
Return

# ----------------------- CPY --------------------------------------
$CPY
  Case [L]ARULE
    When "PROPAGATE" : Gosub PROPAGATE_CPY
    When Default     : Return
  Endcase
Return

$PROPAGATE_CPY
Local Integer WI

  If this.CPY<>""
    Local File COMPANY [CPY]
    Read [F:CPY]CPY0=this.CPY
    If fstat Raz [F:CPY] : Endif
    this.LEG = [F:CPY]LEG
    this.CPYCUR = [F:CPY]ACCCUR
  Endif
Return

# ----------------------- CPYCUR --------------------------------------
$CPYCUR
  Case [L]ARULE
    When "GET"       : Gosub GET_CPYCUR
    When Default     : Return
  Endcase
Return

$GET_CPYCUR
  If this.CPY<>""
    Local File COMPANY [CPY]
    Read [F:CPY]CPY0=this.CPY
    If fstat Raz [F:CPY] : Endif
    this.CPYCUR = [F:CPY]ACCCUR
  Endif
Return

# ----------------------- INVDTA --------------------------------------
$INVDTA
  Case [L]ARULE
    When "PROPAGATE" : Gosub PROPAGATE_INVDTA
    When Default     : Return
  Endcase
Return


$PROPAGATE_INVDTA
  #--CPO 14.08.2013 Revue code classes this.INVCDTA = num$(this.INVDTA)
Return

