#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque AMCEPUR
$ACTION
Case ACTION
 When "INIT_DIA" : Gosub INIT
 When "EXEC"     : Gosub EXEC
 When "SORTIE"   : Gosub TERMINE
 When Default
Endcase
Return


######################################################################################
$INIT
[M:DIA]ALLTYP  = 1
[M:DIA]ALLCOD  = 1
[M:DIA]TYPZON  = val(PARAM(1))
[M:DIA]CODDEB  = PARAM(2)
[M:DIA]CODFIN  = PARAM(2)
[M:DIA]SIMU=2
Return

######################################################################################
$EXEC
If [M:DIA]SIMU=2
  Call EPUR(1)
Else
  Call EPUR(0)
Endif
Return


Subprog EPUR (SIMU)
Value Integer SIMU
Local Integer OK, OKSUP
If SIMU
 TIT = mess(294,139,1)-"/"-mess(6,115,1) : # Epuration mots-clés d'aide / Simulation
Else
 TIT = mess(294,139,1) : # Epuration documentation
Endif
If !SIMU
 Call AVERTIR(TIT+"\"+mess(205,100,1),OK) From GESECRAN : # Voulez-vous continuer ?
 If OK<>2 : Return : Endif
Endif

Call OUVRE_TRACE(TIT) From LECFIC
Call TEMPON(TIT) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN

Local File AMOTCLE [AMC]

Local Char EV(200)
EV=""
EV+=string$( [M:DIA]ALLTYP=1, string$(EV<>""," & ")+"[AMC]TYPZON=[M:DIA]TYPZON" )
EV+=string$( [M:DIA]ALLCOD=1, string$(EV<>""," & ")+"[AMC]IDENT1>=[M:DIA]CODDEB & [AMC]IDENT1<=[M:DIA]CODFIN" )
EV+=string$( EV="","1=1" )

GOK = 1
Trbegin [AMC]

For [AMC]AMC0  Where evalue(EV)
  OKSUP=0
  MESSA=mess([F:AMC]TYPZON,7985,1)
  Case [F:AMC]TYPZON
    When 1 : MESSA-="[ATZ]" : Read [ATZ]CODZONE=[F:AMC]IDENT1;[F:AMC]IDENT2
    When 2 : MESSA-="[AMZ]" : Read [AMZ]CODE=[F:AMC]IDENT1;[F:AMC]IDENT2
    When 3 : MESSA-="[ACLAF]" : Read [ACLAF]ACLAF0=[F:AMC]IDENT1;[F:AMC]IDENT2
    When 4 : MESSA-="[ASWR]" : Read [ASWR]ASWR0=[F:AMC]IDENT1;[F:AMC]IDENT2
  Endcase
  If fstat>1
    OKSUP=1
  # Issue 87374 - 2013-01-18 by VPO : Suppression des aides sur champs invisibles
  Elsif !fstat & [F:AMC]TYPZON=2 & !([F:AMZ]SAIAFF<=2 & [F:AMZ]CODTYP<>"ABS")
    OKSUP=1
  Endif
  If OKSUP
    # Objet inexistant
    MESSA -= [F:AMC]IDENT1-[F:AMC]IDENT2-":"-mess(161,123,1)
    Call ECR_TRACE(MESSA,0) From GESECRAN
    If !SIMU
      Delete [AMC] Curr
      If fstat
         GOK=-1 : Call RSTA("AMC",num$([F:AMC]TYPZON)-[F:AMC]IDENT1-[F:AMC]IDENT2) From GLOCK : Break
      Endif
    Endif
  Endif
Next

If GOK<1
 Rollback
Else
 Commit
Endif

Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

######################################################################################
$TERMINE
Return

######################################################################################
Subprog C_ALLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Raz [M]TYPZON : Effzo [M]TYPZON : Grizo [M]TYPZON
Else
 Actzo [M]TYPZON
Endif
End

Subprog C_ALLCOD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]CODDEB = "" : Affzo [M]CODDEB : Grizo [M]CODDEB
 [M]CODFIN = "" : Affzo [M]CODFIN : Grizo [M]CODFIN
Else
 Actzo [M]CODDEB
 Actzo [M]CODFIN
Endif
End

Subprog AM_CODDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" and [M]CODFIN=""
    [M]CODFIN=VALEUR : Affzo [M]CODFIN
Endif
End

Subprog AS_CODFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   VALEUR=[M:DIA]CODDEB
   If VALEUR=""
       VALEUR="X"
   Endif
Endif
End


######################################################################################
