#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion du fichier TXSA
####################################################################################################
# Tables
#   TXSA (clé LSTGRP+TXSNAM)          : paramétrage tableaux
#   TXSAC(clé TXSNAM+NUMCOL)          : paramétrage colonnes des tableaux
#   TXSD (clé TXSNAM+LIG+COL)         : formules des tableaux
#   TXSV (clé TXSNAM+VERSION+VARNAM)  : variables des tableaux
###########################################################################################################
# Masks      Intitulé       Windows   Function    Programs             Object/action    Masks +20 columns
# -----      --------       -------   --------    --------             --------------  -----------------
# TXSA0   |
# TXSA1   |  Paramétrage    OTXS      GESTXS      SUBTXS  (Objet)      TXS              TXSAA
# TXSA2   |                                       SUBTXSA (Etiquettes) SELVARIA         TXSAB
# TXSA3   |                                       SUBTXSB (Formules)
# TXSA4   |
# TXSAFMT    Format         DTXSFMT               TXSFMT               TXSFMT
# TXSADET    Détail         DTXSADET              TXSADET              TXSADET
# TXSFRM     Signification  TXSFRM                TXSFRM               TXSFRM
# TXSWIZ     Assistant      TXSWIZ                TXSWIZ
#
###########################################################################################################
Raz GPILCOD, GBIDC1, GBIDC2
Close Mask
GLANGUE="FRA"
Call OBJET("TXS",GBIDC1,GBIDC2) From GOBJET
End

###########################################################################################################
$ACTION
Case ACTION
 When "DEFTRANS"    : Gosub DEFTRANS
 When "SETTRANS"    : Gosub SETTRANS
 When "SETBOUT"     : Gosub SETBOUT
 When "OUVRE"       : Gosub OUVRE
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "FILTRE"      : Gosub FILTRE
 When "LIENS"       : Gosub LIENS
 When "STYLE"       : Gosub STYLE
 When "INICRE"      : Gosub INICRE
 When "AVANT_MODFIC": Gosub AVANT_MODFIC
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "APRES_CHOI"  : Gosub APRES_CHOI
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "ANNULE"      : Gosub ANNULE
 When "FIN_ACTION"  : Gosub FIN_ACTION
 When "FERME"       : Kill GMAXNUMCOL, GMAXLIG
Endcase
Return

###########################################################################################################
$DEFTRANS
If TUNNEL=1 & SAVFONC="GESTXW"
 GFLAG = SAVGFLAG
Endif
Return

###########################################################################################################
$SETTRANS
If GFLAG="NOLIMIT"
  maxmem = max(int(maxmem/1024),200000)
Endif
Return

###########################################################################################################
$SETBOUT
If REP<>"" | GREP<>"" | [M]LSTGRP="" | [M]TXSNAM=""
 Call VIREBOUT(CHAINE,"O") From GOBJET   :# bouton Copie
Else
 CHMEN += "1"   :# Paramétrage export
Endif
If VERROU
 [M:TXA2]DETAIL = 1
Else
 [M:TXA2]DETAIL = 0
Endif
If TUNNEL
 Call VIREBOUT(CHAINE,"<>09CDAH") From GOBJET
 Grizo [TXA0]TXSNAM
Endif
Return

###########################################################################################################
$OUVRE
If clalev([F:TXM])=0 : Local File TXSM      [TXM] : Endif
If clalev([F:TXP])=0 : Local File TXSP      [TXP] : Endif
If clalev([F:TXW])=0 : Local File TXSW      [TXW] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE    [ATX] : Endif
If clalev([F:ATY])=0 : Local File ATYPE     [ATY] : Endif
If clalev([F:AOB])=0 : Local File AOBJET    [AOB] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA   [AXX] : Endif
If clalev([F:TXS2])=0: Local File TXSA      [TXS2]: Endif
If clalev([F:TXA])=0 : Local File TXSAC     [TXA] : Endif

Local Integer IC, IL, GMODIF, OKVERS, OUV
Local Char    FORMULE(250), TABLEAU(10), MESSA(100), RACINE(50) , GROUPE(10) , ACCES(GLONACS)
Local Decimal PID
Global Integer GMAXNUMCOL, GMAXLIG
Return

###########################################################################################################
$FILGAUCHE
If FILTRE<>"" & currbox<>"GAU_CHE"
 If CRITERE<>"" : CRITERE -= "&" : Endif
 CRITERE = vireblc(CRITERE-"("+vireblc(FILTRE,2)+")",2)
Endif
If GFLAG="LIMIT"
 FILGAUSUP = "[F:TXS]NBRCOL<=20"
Endif
Return

###########################################################################################################
$FILTRE
If GFLAG="LIMIT"
 FILTRE = "[F:TXS]NBRCOL<=20"
 FILTSUP = "[F:TXS]NBRCOL<=20" : # For the select button on the field TXSNAM
Endif
Return

###########################################################################################################
$LIENS
Call TEMPON("") From GESECRAN
GROUPE = [F:TXS]LSTGRP
[L]ACCES = [F:TXS]ACS
Call LECTEXTRA([M:TXA0]TXSDES,"TXSA","TXSDES",[M:TXA0]TXSNAM,"") From ATEXTRA
Call LECTEXTRA([M:TXA0]GRPDES,"TXSA","GRPDES",[M:TXA0]LSTGRP,"") From ATEXTRA
For [TXA]TXA0 Where TXSNAM=[M:TXA0]TXSNAM
 If [F:TXA]NUMCOL>dim([M:TXA1]COLNUM)
  Call ERREUR(mess(26,100,1)) From GESECRAN
  Break
 Endif
 [M:TXA1]NUMCOL([F:TXA]NUMCOL-1) = [F:TXA]NUMCOL
 [M:TXA1]COLNUM([F:TXA]NUMCOL-1) = [F:TXA]COLNUM
 [M:TXA1]SAICOL([F:TXA]NUMCOL-1) = [F:TXA]SAICOL
 [M:TXA1]FMTCOL([F:TXA]NUMCOL-1) = [F:TXA]FMTCOL
 [M:TXA1]EFFCOL([F:TXA]NUMCOL-1) = [F:TXA]EFFCOL
 [M:TXA1]DIVCOL([F:TXA]NUMCOL-1) = [F:TXA]DIVCOL
 [M:TXA1]DECCOL([F:TXA]NUMCOL-1) = [F:TXA]DECCOL
Next

For I=1 To [M:TXA1]NBRCOL
 Call LECTEXTRA([M:TXA1]NAMCOL(I-1),"TXSAC","NAMCOL",[M:TXA0]TXSNAM,num$([M:TXA1]NUMCOL(I-1))) From ATEXTRA
Next I

Gosub CHARGE_COL   :# Chargement de l'intitulé des colonnes
Gosub CHARGE_LIG   :# Chargement des lignes
Gosub CHARGE_VAR   :# Chargement des variables
Call C_DETACC([F:TXS]DETACC) From SUBTXSA
Call C_DETBPR([F:TXS]DETBPR) From SUBTXSA
Call C_DETCCE([F:TXS]DETCCE) From SUBTXSA
Call TEMPOFF From GESECRAN
GMAXNUMCOL = max([M]NUMCOL)
GMAXLIG    = max([M]LIG)
Return

$CHARGE_COL
# Called from the program SUBTXSA
Local Char    FMTCOL(7)
FMTCOL = "K:250X"
For I=1 To [M:TXA1]NBRCOL
 Gosub FORMAT_COL
Next
FMTCOL = "-K:250X"
For I=[M:TXA1]NBRCOL+1 To dim([M:TXA1]COLNUM)
 Gosub FORMAT_COL
Next
# 1ere colonne = Intitulé
Titcol [M:TXA2]NBLIG mess(30,109,1),
&      [M:TXA1]NAMCOL(0),  [M:TXA1]NAMCOL(1),  [M:TXA1]NAMCOL(2),  [M:TXA1]NAMCOL(3),
&      [M:TXA1]NAMCOL(4),  [M:TXA1]NAMCOL(5),  [M:TXA1]NAMCOL(6),  [M:TXA1]NAMCOL(7),
&      [M:TXA1]NAMCOL(8),  [M:TXA1]NAMCOL(9),  [M:TXA1]NAMCOL(10), [M:TXA1]NAMCOL(11),
&      [M:TXA1]NAMCOL(12), [M:TXA1]NAMCOL(13), [M:TXA1]NAMCOL(14), [M:TXA1]NAMCOL(15),
&      [M:TXA1]NAMCOL(16), [M:TXA1]NAMCOL(17), [M:TXA1]NAMCOL(18), [M:TXA1]NAMCOL(19),
&      [M:TXA1]NAMCOL(20), [M:TXA1]NAMCOL(21), [M:TXA1]NAMCOL(22), [M:TXA1]NAMCOL(23),
&      [M:TXA1]NAMCOL(24), [M:TXA1]NAMCOL(25), [M:TXA1]NAMCOL(26), [M:TXA1]NAMCOL(27),
&      [M:TXA1]NAMCOL(28), [M:TXA1]NAMCOL(29), [M:TXA1]NAMCOL(30), [M:TXA1]NAMCOL(31),
&      [M:TXA1]NAMCOL(32), [M:TXA1]NAMCOL(33), [M:TXA1]NAMCOL(34), [M:TXA1]NAMCOL(35),
&      [M:TXA1]NAMCOL(36), [M:TXA1]NAMCOL(37), [M:TXA1]NAMCOL(38), [M:TXA1]NAMCOL(39),
&      [M:TXA1]NAMCOL(40), [M:TXA1]NAMCOL(41), [M:TXA1]NAMCOL(42), [M:TXA1]NAMCOL(43),
&      [M:TXA1]NAMCOL(44), [M:TXA1]NAMCOL(45), [M:TXA1]NAMCOL(46), [M:TXA1]NAMCOL(47),
&      [M:TXA1]NAMCOL(48), [M:TXA1]NAMCOL(49), [M:TXA1]NAMCOL(50), [M:TXA1]NAMCOL(51),
&      [M:TXA1]NAMCOL(52), [M:TXA1]NAMCOL(53), [M:TXA1]NAMCOL(54), [M:TXA1]NAMCOL(55),
&      [M:TXA1]NAMCOL(56), [M:TXA1]NAMCOL(57), [M:TXA1]NAMCOL(58), [M:TXA1]NAMCOL(59),
&      [M:TXA1]NAMCOL(60), [M:TXA1]NAMCOL(61), [M:TXA1]NAMCOL(62), [M:TXA1]NAMCOL(63),
&      [M:TXA1]NAMCOL(64), [M:TXA1]NAMCOL(65), [M:TXA1]NAMCOL(66), [M:TXA1]NAMCOL(67),
&      [M:TXA1]NAMCOL(68), [M:TXA1]NAMCOL(69), [M:TXA1]NAMCOL(70), [M:TXA1]NAMCOL(71),
&      [M:TXA1]NAMCOL(72), [M:TXA1]NAMCOL(73), [M:TXA1]NAMCOL(74), [M:TXA1]NAMCOL(75),
&      [M:TXA1]NAMCOL(76), [M:TXA1]NAMCOL(77), [M:TXA1]NAMCOL(78), [M:TXA1]NAMCOL(79),
&      [M:TXA1]NAMCOL(80), [M:TXA1]NAMCOL(81), [M:TXA1]NAMCOL(82), [M:TXA1]NAMCOL(83),
&      [M:TXA1]NAMCOL(84), [M:TXA1]NAMCOL(85), [M:TXA1]NAMCOL(86), [M:TXA1]NAMCOL(87),
&      [M:TXA1]NAMCOL(88), [M:TXA1]NAMCOL(89), [M:TXA1]NAMCOL(90), [M:TXA1]NAMCOL(91),
&      [M:TXA1]NAMCOL(92), [M:TXA1]NAMCOL(93), [M:TXA1]NAMCOL(94), [M:TXA1]NAMCOL(95),
&      [M:TXA1]NAMCOL(96), [M:TXA1]NAMCOL(97), [M:TXA1]NAMCOL(98)
Return


