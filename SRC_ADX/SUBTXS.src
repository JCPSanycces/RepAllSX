###########################################################################################################
$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

###########################################################################################################
$MODIF
If [F:TXS]LSTGRP<>GROUPE
 Update [TXW] Where TXSNAM=[F:TXS]TXSNAM With LSTGRP=[F:TXS]LSTGRP
 Update [TXX] Where TXSNAM=[F:TXS]TXSNAM With LSTGRP=[F:TXS]LSTGRP
Endif
If [F:TXS]ACS<>[L]ACCES
 Update [TXW] Where TXSNAM=[F:TXS]TXSNAM With ACS=[F:TXS]ACS
 Raz [L]ACCES
Endif
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

###########################################################################################################
$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("TXSA","TXSDES",CLECUR1,"","TXSA","TXSDES",[M:TXA0]TXSNAM,"")  From ATEXTRA
 #75140 :No longer needed on GRPDES
 #Call DUPTEXTRA("TXSA","GRPDES",CLECUR1,"","TXSA","GRPDES",[M:TXA0]TXSNAM,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M:TXA0]TXSDES,"TXSA","TXSDES",[M:TXA0]TXSNAM,"") From ATEXTRA
#75140
#Call MAJTEXTRA([M:TXA0]GRPDES,"TXSA","GRPDES",[M:TXA0]TXSNAM,"") From ATEXTRA
Call MAJTEXTRA([M:TXA0]GRPDES,"TXSA","GRPDES",[M:TXA0]LSTGRP,"") From ATEXTRA
Gosub MTXT_FRM0
Return

## Mise à jour des textes traduisibles de l'intutulé de ligne dans le tableau TXA2.

$MTXT_FRM0
If GREP="M"
 ## Mise à jour des textes traduisibles en ajout/insertion de lignes dans le tableau des intitulés de lignes
 For I=0 To [M:TXA2]NBLIG-1
  If [M:TXA2]LIG(I) <> 0
   Call DUPTEXTRA("TXSD","DES",[M:TXA0]TXSNAM,num$([M:TXA2]LIG(I)),"TXSD","DES",[M:TXA0]TXSNAM,chr$(255)+num$(I+1)) From ATEXTRA
  Endif
 Next I
 Delete [AXX] Where CODFIC = "TXSD" & ZONE = "DES" & IDENT1 = [M:TXA0]TXSNAM & left$(IDENT2,1) <> chr$(255)
 If fstat=1
  GOK=-1 : Call RSTA("AXX","TXSD"-[M:TXA0]TXSNAM) From GLOCK : Return
 Endif
 Update [AXX] Where CODFIC = "TXSD" & ZONE = "DES" & IDENT1 = [M:TXA0]TXSNAM & left$(IDENT2,1) = chr$(255)
&             With [AXX]IDENT2 = right$([AXX]IDENT2,2)
 If fstat=1
  GOK=-1 : Call RSTA("AXX","TXSD"-[M:TXA0]TXSNAM) From GLOCK : Return
 Endif
 For I=0 To [M:TXA2]NBLIG-1
  Call MAJTEXTRA([M:TXA2]FRM0(I),"TXSD","DES",[M:TXA0]TXSNAM,num$(I+1)) From ATEXTRA
  #Renuméroter le LIG correctement
  [M:TXA2]LIG(I) = I+1
 Next
Else
 If GREP="D"
  ## En duplication, on veut récupérer tous les intitulés traduisibles.
  For I=0 To [M:TXA2]NBLIG-1
   Call DUPTEXTRA("TXSD","DES",CLECUR1,num$([M:TXA2]LIG(I)),"TXSD","DES",[M:TXA0]TXSNAM,num$(I+1)) From ATEXTRA
  Next
 Endif
 If GREP="C" | GREP="D"
  For I=0 To [M:TXA2]NBLIG-1
   Call MAJTEXTRA([M:TXA2]FRM0(I),"TXSD","DES",[M:TXA0]TXSNAM,num$(I+1)) From ATEXTRA
  Next
 Endif
Endif  #GREP
Return

###########################################################################################################
$AVANT_MODFIC
#75140
#Local Char DESIG(50)
#Call LECTEXTRA(DESIG,"TXSA","GRPDES",[F:TXS]TXSNAM,"") From ATEXTRA
#If [M:TXA0]GRPDES<>DESIG
# For [AXX] Where CODFIC="TXSA" & ZONE="GRPDES" & LANGUE=GLANGUE & IDENT1<>[F:TXS]TXSNAM
#  Readlock [AXX]Curr
#  If fstat=1
#   GOK = -1 : GLOCK = "$ATEXTRA TXSA GRPDES"-GLANGUE-[F:TXS]TXSNAM : Break
#  Endif
#  [F:AXX]TEXTE = DESIG
#  Rewrite [AXX]
#  If fstat
#   GOK = 0 : Call FSTA("AXX") From GLOCK : Break
#  Endif
# Next
#Endif
Return

###########################################################################################################
$INIMOD
# The table TXSAC contains the display's set up
Gosub CRE_TXA
If GOK<1 : Return : Endif
If [M:TXA2]MODIF<>2   :# On n'a modifié aucune formule
 Return
Else
 Gosub VERF_LCK
 If GOK<1 : Return : Endif
 Filter [TXM] Where TXSNAM=[M]TXSNAM
 Look [TXM]TXM0 First
 Filter [TXM]
 If !fstat
  MESSA = mess(137,111,1)   :# Effacement des montants des versions ?
  OK = 1
  Call OUINON(MESSA,OK) From GESECRAN
  If OK=2
   Gosub ANN_TXM
   If GOK<1 : Return : Endif
  Endif
 Endif
Endif

$INICRE
Call TEMPON("") From GESECRAN
Gosub CRE_TXD
If GOK<1 : Call TEMPOFF From GESECRAN : Return : Endif
Gosub CRE_TXX
If GOK<1 : Call TEMPOFF From GESECRAN : Return : Endif
Gosub CRE_TXA
If GOK<1 : Call TEMPOFF From GESECRAN : Return : Endif
[M:TXA2]MODIF = 1
Call TEMPOFF From GESECRAN
Return

$CRE_TXD
Delete [TXD] Where TXSNAM=[M:TXA0]TXSNAM
If fstat=1
 GOK=-1 : GLOCK="$TXSD"-[M:TXA0]TXSNAM : Return
Elsif fstat>5
 GOK=0 : Call RSTA("TXD",[M:TXA0]TXSNAM) From GLOCK : Return
Endif
For IL=0 To [M:TXA2]NBLIG-1
 For IC=0 To [M:TXA1]NBRCOL
  FORMULE = evalue("[M:TXA2]FRM"+num$(IC)+"(IL)")
  Raz [F:TXD]
  [F:TXD]TXSNAM = [M:TXA0]TXSNAM
  [F:TXD]LIG = IL+1
  [F:TXD]COL = IC
  [F:TXD]FRM = FORMULE
  If IC=0
   [F:TXD]FRM    = ""
   [F:TXD]FMTPRN = [M:TXA2]FMTPRN0(IL)
   [F:TXD]EFFPRN = [M:TXA2]EFFPRN0(IL)
  Else
   [F:TXD]FMTPRN = val(mid$([M:TXA2]FMTPRN(IL),IC,1))
   [F:TXD]EFFPRN = val(mid$([M:TXA2]EFFPRN(IL),IC,1))
   [F:TXD]CEN    = val(mid$([M:TXA2]CEN(IL),IC,1))
   [F:TXD]DECCOL = val(mid$([M:TXA2]DEC(IL),IC,1))
  Endif
  Write [TXD]
  If fstat
   GOK=0 : Call FSTA("TXD") From GLOCK : Break 2
  Endif
 Next IC
Next IL
Return

$CRE_TXX
Delete [TXX] Where TXSNAM=[M:TXA0]TXSNAM & VERSION=""
If fstat=1
 GOK=-1 : GLOCK="$TXSV"-[M:TXA0]TXSNAM : Return
Elsif fstat>5
 GOK=0 : Call RSTA("TXX",[M:TXA0]TXSNAM) From GLOCK : Return
Endif
For I=0 To [M:TXA3]NBVAR-1
 nolign = I+1
 Raz [F:TXX]
 [F:TXX] = [M:TXA3]
 [F:TXX]LSTGRP = [M:TXA0]LSTGRP
 [F:TXX]TXSNAM = [M:TXA0]TXSNAM
 [F:TXX]VERSION = ""
 Write [TXX]
 If fstat
  GOK=0 : Call FSTA("TXX") From GLOCK : Break
 Endif
 Call MAJTEXTRA([M:TXA3]VARDES(I),"TXSV","VARTRA",[M:TXA0]TXSNAM,[M:TXA3]VARNAM(I)) From ATEXTRA
Next I
Return

###########################################################################################################
$VERF_LCK
GOK = 1
If !clalev([F:LKK]) : Local File =adxtlk [LKK] : OUV=1 : Endif
RACINE = "TXW"+[M]TXSNAM+"\"+[M]LSTGRP+"*"
PID = adxuid(2)    :# cette session
For [LKK] Where LCKPID<>PID & pat(num$([F:LKK]LCKSYM),RACINE)<>0
 Lock =[F:LKK]LCKSYM
 If fstat=0
  Unlock =[F:LKK]LCKSYM
 Else
  GOK = 0 : GERR = 1 : GMESSAGE = mess(138,111,1)   :# Version en cours de modification
  Break
 Endif
Next
If OUV : Close Local File [LKK] : OUV=0 : Endif
Return

$ANN_TXM
Delete [TXM] Where TXSNAM=[M:TXA0]TXSNAM
If fstat=1
 GOK=-1 : GLOCK="$TXSA"-[M:TXA0]TXSNAM : Return
Elsif fstat>5
 GOK=0 : Call RSTA("TXA",[M:TXA0]TXSNAM) From GLOCK : Return
Endif
Return

$CRE_TXA
Delete [TXA] Where TXSNAM=[M:TXA0]TXSNAM
If fstat=1
 GOK=-1 : GLOCK="$TXAC"-[M:TXA0]TXSNAM : Return
Elsif fstat>5
 GOK=0 : Call RSTA("TXA",[M:TXA0]TXSNAM) From GLOCK : Return
Endif
For I=0 To [M:TXA1]NBRCOL-1
 Raz [TXA]
 [F:TXA]TXSNAM = [M:TXA0]TXSNAM
 [F:TXA]NUMCOL = I+1
 [F:TXA]COLNUM = [M:TXA1]COLNUM(I)
 [F:TXA]SAICOL = [M:TXA1]SAICOL(I)
 [F:TXA]FMTCOL = [M:TXA1]FMTCOL(I)
 [F:TXA]EFFCOL = [M:TXA1]EFFCOL(I)
 [F:TXA]DIVCOL = [M:TXA1]DIVCOL(I)
 [F:TXA]DECCOL = [M:TXA1]DECCOL(I)
 Write [TXA]
 If fstat
  GOK=0 : Call FSTA("TXA") From GLOCK : Break
 Endif
Next
If GOK=0 : Return : Endif
# 8 is the minimum because the report link the table ATEXTRA with the table TXSA
# to display 8 columns max. Texts must be generated even if then are null.
Gosub MTXT_NAMCOL
Return

## Mise à jour des textes traduisibles de l'intutulé de colonne.

$MTXT_NAMCOL
If GREP="M"
 ## Mise à jour des textes traduisibles en ajout/insertion de lignes dans le tableau des intitulés de colonnes
 For I=0 To [M:TXA1]NBRCOL-1
  If [M:TXA1]NUMCOL(I) <> 0
   Call DUPTEXTRA("TXSAC","NAMCOL",[M:TXA0]TXSNAM,num$([M:TXA1]NUMCOL(I)),"TXSAC","NAMCOL",[M:TXA0]TXSNAM,chr$(255)+num$(I+1)) From ATEXTRA
  Endif
 Next I
 Delete [AXX] Where CODFIC = "TXSAC" & ZONE = "NAMCOL" & IDENT1 = [M:TXA0]TXSNAM & left$(IDENT2,1) <> chr$(255)
 If fstat=1
  GOK=-1 : Call RSTA("AXX","TXSAC"-[M:TXA0]TXSNAM) From GLOCK : Return
 Endif
 Update [AXX] Where CODFIC = "TXSAC" & ZONE = "NAMCOL" & IDENT1 = [M:TXA0]TXSNAM & left$(IDENT2,1) = chr$(255)
&             With [AXX]IDENT2 = right$([AXX]IDENT2,2)
 If fstat=1
  GOK=-1 : Call RSTA("AXX","TXSAC"-[M:TXA0]TXSNAM) From GLOCK : Return
 Endif
 For I=0 To [M:TXA1]NBRCOL-1
  Call MAJTEXTRA([M:TXA1]NAMCOL(I),"TXSAC","NAMCOL",[M:TXA0]TXSNAM,num$(I+1)) From ATEXTRA
  #Renuméroter le NUMCOL correctement
  [M:TXA1]NUMCOL(I) = I+1
 Next
Else
 If GREP="D"
  ## En duplication, on veut récupérer tous les intitulés traduisibles.
  For I=0 To [M:TXA1]NBRCOL-1
   Call DUPTEXTRA("TXSAC","NAMCOL",CLECUR1,num$([M:TXA1]NUMCOL(I)),"TXSAC","NAMCOL",[M:TXA0]TXSNAM,num$(I+1)) From ATEXTRA
  Next
 Endif
 If GREP="C" | GREP="D"
  For I=0 To [M:TXA1]NBRCOL-1
   Call MAJTEXTRA([M:TXA1]NAMCOL(I),"TXSAC","NAMCOL",[M:TXA0]TXSNAM,num$(I+1)) From ATEXTRA
  Next
 Endif
Endif  #GREP
Return

###########################################################################################################
$APRES_CHOI
Case REPONSE
 When GSTAENR, GSTARET :
   Sorta [M:TXA3]NBVAR [M:TXA3]NBVAR
   Affzo [TXA3]
 When GSTANEW :
   Actzo [M:TXA0]GRPDES
 When GSTAANU   :# Supprimer les lignes de la table détail TXSD
   REPONSE=0
   Gosub VERF_LCK
   If GOK<1 : Return : Endif
   Gosub ANNUL
Endcase
Return

$ANNUL
TABLEAU = [M:TXA0]TXSNAM
MESSA = mess(123,105,1)   :# Confirmez-vous la suppression ?
OKVERS=0
Filter [TXW] Where TXSNAM=TABLEAU
Look [TXW]TXW1 First
Filter [TXW]
If !fstat
 OKVERS=1
 MESSA = mess(122,105,1)+"\"+MESSA   :# Des versions existent pour ce tableau
Endif
OK = 1
Call OUINON(MESSA,OK) From GESECRAN
If OK=1 : Return : Endif
Call DEBTRANS From GLOCK
Gosub TR_ANNUL
Default File [TXS]
CLECUR = 0 : CLECUR1 = ""
Gosub RELIT From GOBJET
Return

$TR_ANNUL
Trbegin [TXS], [TXD], [TXM], [TXP], [TXW], [TXX]
GOK = 1
Gosub ANN_TXS
If GOK<0   : Goto ROLL_TR_ANNUL
Elsif !GOK : Goto AB_TR_ANNUL
Endif
If OKVERS
 Gosub ANN_VERS
 If GOK<0   : Goto ROLL_TR_ANNUL
 Elsif !GOK : Goto AB_TR_ANNUL
 Endif
Endif
Commit
Return

$ANN_TXS
Delete [TXS] Where TXSNAM=TABLEAU
If fstat=1
 GOK = -1 : GLOCK="$TXSA"-TABLEAU : Return
Endif
Delete [TXA] Where TXSNAM=TABLEAU
If fstat=1
 GOK = -1 : GLOCK="$TXSAC"-TABLEAU : Return
Endif
#-------------------------------------
#75140
Filter [TXS2] Where LSTGRP=[M:TXA0]LSTGRP
Look [TXS2]TXS1 First
Filter [TXS2]
If fstat
  #il n'y a plus de tableau sur le groupe, on Supprime le textra du groupe
 Call SUPTEXTRA("TXSA","GRPDES",[M:TXA0]LSTGRP,"") From ATEXTRA
Endif
#-------------------------------------
Delete [TXD] Where TXSNAM=TABLEAU
If fstat=1
 GOK = -1 : GLOCK="$TXSD"-TABLEAU : Return
Endif
Delete [TXX] Where TXSNAM=TABLEAU
If fstat=1
 GOK = -1 : GLOCK="$TXSV"-TABLEAU : Return
Endif
Delete [AXX] Where CODFIC="TXSA" & IDENT1=TABLEAU
If fstat=1
 GOK = -1 : GLOCK="$ATEXTRA TXSA"-TABLEAU : Return
Endif
Delete [AXX] Where CODFIC="TXSAC" & IDENT1=TABLEAU
If fstat=1
 GOK = -1 : GLOCK="$ATEXTRA TXSAC"-TABLEAU : Return
Endif
Delete [AXX] Where CODFIC="TXSD" & IDENT1=TABLEAU
If fstat=1
 GOK = -1 : GLOCK="$ATEXTRA TXSD"-TABLEAU : Return
Endif
Delete [AXX] Where CODFIC="TXSV" & IDENT1=TABLEAU
If fstat=1
 GOK = -1 : GLOCK="$ATEXTRA TXSV"-TABLEAU : Return
Endif
Return

$ANN_VERS
Delete [TXM] Where TXSNAM=TABLEAU
If fstat=1
 GOK=-1 : GLOCK="$TXM"-TABLEAU : Return
Elsif fstat>5
 GOK=0 : Call RSTA("TXM",TABLEAU) From GLOCK : Return
Endif
Delete [TXP] Where TXSNAM=TABLEAU
If fstat=1
 GOK=-1 : GLOCK="$TXP"-TABLEAU : Return
Elsif fstat>5
 GOK=0 : Call RSTA("TXP",TABLEAU) From GLOCK : Return
Endif
Delete [TXW] Where TXSNAM=TABLEAU
If fstat=1
 GOK=-1 : GLOCK="$TXW"-TABLEAU : Return
Elsif fstat>5
 GOK=0 : Call RSTA("TXW",TABLEAU) From GLOCK : Return
Endif
Return

$ROLL_TR_ANNUL
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ANNUL : Endif

$AB_TR_ANNUL
Rollback
Return

###########################################################################################################
$APRES_MODIF
Local Integer I, COL
Case COUZON
 When "NBVAR", "NBLIG", "NBLIG1", "NBLIG2" :
   Case status
    When 65,73,82,83 : [M:TXA2]MODIF=2
   Endcase
 When "VARNAM", "VARTYP", "VARDES","VARPAR", "VARDEF", "TL", "TR", "TC", "FL", "FC", "FR",
&     "DETACC", "DETBPR", "DETCCE", "DETIMM" :
   [M:TXA2]MODIF=2
 When "NBRCOL" :   # Column inserted ou deleted : we move the formula and update the style/effect/decimal
   Case status
    When 65    :# delete
      For IC=nolign To [M:TXA1]NBRCOL-1
       For IL=0 To [M:TXA2]NBLIG-1
        Assign "[M:TXA2]FRM"+num$(IC)+"(IL)" With evalue("[M:TXA2]FRM"+num$(IC+1)+"(IL)")
       Next IL
      Next IC
      Effzo [TXA2] ="FRM"+num$([M:TXA1]NBRCOL)
      For IL=0 To [M:TXA2]NBLIG-1
       [M:TXA2]EFFPRN(IL) = left$([M:TXA2]EFFPRN(IL),nolign-1) + right$([M:TXA2]EFFPRN(IL),nolign+1)
       [M:TXA2]FMTPRN(IL) = left$([M:TXA2]FMTPRN(IL),nolign-1) + right$([M:TXA2]FMTPRN(IL),nolign+1)
       [M:TXA2]DEC(IL) = left$([M:TXA2]DEC(IL),nolign-1) + right$([M:TXA2]DEC(IL),nolign+1)
      Next
      [M:TXA2]MODIF=2
      Affzo [TXA2]
    When 73    :# insert
      For IC=[M:TXA1]NBRCOL+1 To nolign Step -1
       If IC>1
        For IL=0 To [M:TXA2]NBLIG-1
         Assign "[M:TXA2]FRM"+num$(IC)+"(IL)" With evalue("[M:TXA2]FRM"+num$(IC-1)+"(IL)")
        Next IL
       Endif
      Next IC
      For IL=0 To [M:TXA2]NBLIG-1
       [M:TXA2]EFFPRN(IL) = left$([M:TXA2]EFFPRN(IL),nolign-1) + num$(1) + right$([M:TXA2]EFFPRN(IL),nolign)
       [M:TXA2]FMTPRN(IL) = left$([M:TXA2]FMTPRN(IL),nolign-1) + num$(1) + right$([M:TXA2]FMTPRN(IL),nolign)
       If nolign>1
        [M:TXA2]DEC(IL) = left$([M:TXA2]DEC(IL),nolign-1) + num$([M:TXA1]DECCOL(nolign-1)) + right$([M:TXA2]DEC(IL),nolign)
       Else
        [M:TXA2]DEC(IL) = left$([M:TXA2]DEC(IL),nolign-1) + num$(0) + right$([M:TXA2]DEC(IL),nolign)
       Endif
      Next
      [M:TXA2]MODIF=2
      Affzo [TXA2]
    When 82   :# append
     [M:TXA2]MODIF=2
   Endcase
Endcase
Return

###########################################################################################################
$AP_CHANGE
Call CHGTEXTRA("TXSA","TXSDES",[M:TXA0]TXSNAM,"",NCODE,"") From ATEXTRA
#75140
#Call CHGTEXTRA("TXSA","GRPDES",[M:TXA0]TXSNAM,"",NCODE,"") From ATEXTRA
If clalev([F:TXD])=0 : Local File TXSD [TXD] : Endif
If clalev([F:TXP])=0 : Local File TXSP [TXP] : Endif
If clalev([F:TXW])=0 : Local File TXSW [TXW] : Endif
Call DEBTRANS From GLOCK
Gosub CHGCODE
Return

###########################################################################################################
$ANNULE
Call SUPTEXTRA("TXSA","TXSDES",[M:TXA0]TXSNAM,"") From ATEXTRA
#75140
#Call SUPTEXTRA("TXSA","GRPDES",[M:TXA0]TXSNAM,"") From ATEXTRA
Return

$CHGCODE
Trbegin [TXD], [TXA], [TXM], [TXP], [TXW], [TXX]
GOK=1
Filter [TXD] Where TXSNAM=OCODE
For [TXD]TXD0
 [F:TXD]TXSNAM = NCODE
 Rewrite [TXD]
 If fstat
  GOK=0 : Call FSTA("TXD") From GLOCK : Break
 Endif
Next
Filter [TXD]
If GOK<1 : Rollback : Return : Endif

Filter [TXA] Where TXSNAM=OCODE
For [TXA]TXA0
 [F:TXA]TXSNAM = NCODE
 Rewrite [TXA]
 If fstat
  GOK=0 : Call FSTA("TXA") From GLOCK : Break
 Endif
Next
Filter [TXA]
If GOK<1 : Rollback : Return : Endif

Filter [TXM] Where TXSNAM=OCODE
For [TXM]TXM0
 [F:TXM]TXSNAM = NCODE
 Rewrite [TXM]
 If fstat
  GOK=0 : Call FSTA("TXM") From GLOCK : Break
 Endif
Next
Filter [TXM]
If GOK<1 : Rollback : Return : Endif

Filter [TXP] Where TXSNAM=OCODE
For [TXP]TXP0
 [F:TXP]TXSNAM = NCODE
 Rewrite [TXP]
 If fstat
  GOK=0 : Call FSTA("TXP") From GLOCK : Break
 Endif
Next
Filter [TXP]
If GOK<1 : Rollback : Return : Endif

Filter [TXW] Where TXSNAM=OCODE
For [TXW]TXW1
 [F:TXW]TXSNAM = NCODE
 Rewrite [TXW]
 If fstat
  GOK=0 : Call FSTA("TXW") From GLOCK : Break
 Endif
Next
Filter [TXW]

Local Integer RW
For [TXX]TXX0
 RW = 0
 If [F:TXX]TXSNAM=OCODE
  [F:TXX]TXSNAM = NCODE
  RW = 1
 Endif
 If left$([F:TXX]VARDEF,len(OCODE)+1)="$"+OCODE
  [F:TXX]VARDEF = "$"+NCODE+right$([F:TXX]VARDEF,len(OCODE)+2)
  RW = 1
 Endif
 If left$([F:TXX]VARVAL,len(OCODE)+1)="$"+OCODE
  [F:TXX]VARVAL = "$"+NCODE+right$([F:TXX]VARVAL,len(OCODE)+2)
  RW = 1
 Endif
 If RW
  Rewrite [TXX]
  If fstat
   GOK=0 : Call FSTA("TXX") From GLOCK : Break
  Endif
 Endif
Next

Update [AXX] Where CODFIC="TXSAC" & ZONE="NAMCOL" & IDENT1=[M:TXA0]TXSNAM With IDENT1=NCODE
Update [AXX] Where CODFIC="TXSD" & ZONE="DES" & IDENT1=[M:TXA0]TXSNAM With IDENT1=NCODE
Update [AXX] Where CODFIC="TXSV" & ZONE="VARTRA" & IDENT1=[M:TXA0]TXSNAM With IDENT1=NCODE

Commit
Return

###########################################################################################################
$FIN_ACTION
Case BOUT
 When "H" :
   Gosub RAFFRAICHIR From GOBJSUB   :# Changement de clé
Endcase
Return

###########################################################################################################
$TRTCOP
If TABLE="" | TABLE2="" : Return : Endif
If [M]DOSORG=nomap
 Local File TXSA    [TXSO]
 Local File TXSAC   [TXAO]
 Local File TXSD    [TXDO]
 Local File TXSV    [TXXO]
 Local File ATEXTRA [AXX1]
Else
 Local File =[M]DOSORG+".TXSA"    [TXSO]
 Local File =[M]DOSORG+".TXSAC"   [TXAO]
 Local File =[M]DOSORG+".TXSD"    [TXDO]
 Local File =[M]DOSORG+".TXSV"    [TXXO]
 Local File =[M]DOSORG+".ATEXTRA" [AXX1]
Endif
If [M]DOSDES=nomap
 Local File TXSA    [TXSD]
 Local File TXSAC   [TXAD]
 Local File TXSD    [TXDD]
 Local File TXSV    [TXXD]
 Local File ATEXTRA [AXX2]
Else
 Local File =[M]DOSDES+".TXSA"    [TXSD]
 Local File =[M]DOSDES+".TXSAC"   [TXAD]
 Local File =[M]DOSDES+".TXSD"    [TXDD]
 Local File =[M]DOSDES+".TXSV"    [TXXD]
 Local File =[M]DOSDES+".ATEXTRA" [AXX2]
Endif
OK = 1
Read [TXSD]TXS0 = TABLE;TABLE2
If !fstat
 Call AVERTIR([M]DOSDES-TABLE-TABLE2-":"-mess(22,100,1),OK) From GESECRAN
 #### Fiche déjà existante
 If OK=1 : OK = 0 : Endif
Endif
If OK
 Call TEMPON("T") From GESECRAN
 Call DEBTRANS From GLOCK
 Gosub TR_COP
 Call TEMPOFF From GESECRAN
Endif
Close Local File [TXSO], [TXAO], [TXDO], [TXSD], [TXAD], [TXDD], [TXXO], [TXXD], [AXX1], [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [TXSD], [TXDD], [TXXD], [TXAD]
GCLE = TABLE-TABLE2
# Suppression de la destination
Delete [TXSD] Where LSTGRP=TABLE & TXSNAM=TABLE2
If fstat=1
 GOK=-1 : GLOCK = "$"+[M]DOSDES+".TXSA" : Goto ROLL_TR_COP
Elsif fstat>5
 GOK = 0 : Call RSTA("TXSD",GCLE) From GLOCK : Goto AB_TR_COP
Endif
Delete [TXDD] Where TXSNAM=TABLE2
If fstat=1
 GOK=-1 : GLOCK = "$"+[M]DOSDES+".TXSD" : Goto ROLL_TR_COP
Elsif fstat>5
 GOK = 0 : Call RSTA("TXDD",GCLE) From GLOCK : Goto AB_TR_COP
Endif
Delete [TXXD] Where TXSNAM=TABLE2
If fstat=1
 GOK=-1 : GLOCK = "$"+[M]DOSDES+".TXSV" : Goto ROLL_TR_COP
Elsif fstat>5
 GOK = 0 : Call RSTA("TXXD",GCLE) From GLOCK : Goto AB_TR_COP
Endif
Delete [TXAD] Where TXSNAM=TABLE2
If fstat=1
 GOK=-1 : GLOCK = "$"+[M]DOSDES+".TXSAC" : Goto ROLL_TR_COP
Elsif fstat>5
 GOK = 0 : Call RSTA("TXAD",GCLE) From GLOCK : Goto AB_TR_COP
Endif


# La copie...
Read [TXSO]TXS0 = TABLE;TABLE2
If !fstat
 Raz [F:TXSD]
 [F:TXSD] = [F:TXSO]
 Write [TXSD]
 If fstat
  GOK=0 : Call FSTA("TXSD") From GLOCK : Goto AB_TR_COP
 Endif
 For [TXDO]TXD0 Where TXSNAM=TABLE2
  Raz [F:TXDD]
  [F:TXDD] = [F:TXDO]
  Write [TXDD]
  If fstat
   GOK=0 : Call FSTA("TXDD") From GLOCK : Break
  Endif
 Next
 For [TXXO]TXX0 Where TXSNAM=TABLE2
  Raz [F:TXXD]
  [F:TXXD] = [F:TXXO]
  If [TXXO]VERSION=""
   Call COPTEXTRA("TXSV","VARTRA",[F:TXXO]TXSNAM,[F:TXXO]VARNAM) From ATEXTRA
   If GOK<1 : Break : Endif
  Endif
  Write [TXXD]
  If fstat
   GOK=0 : Call FSTA("TXXD") From GLOCK : Break
  Endif
 Next
 For [TXAO]TXA0 Where TXSNAM=TABLE2
  Raz [F:TXAD]
  [F:TXAD] = [F:TXAO]
  Write [TXAD]
  If fstat
   GOK=0 : Call FSTA("TXAD") From GLOCK : Break
  Endif
 Next
Endif
If   GOK<0 : Goto ROLL_TR_COP
Elsif !GOK : Goto AB_TR_COP
Endif
# Textes traduisibles
Call COPTEXTRA("TXSA","TXSDES",[F:TXSO]TXSNAM,"") From ATEXTRA
#75140
#Call COPTEXTRA("TXSA","GRPDES",[F:TXSO]TXSNAM,"") From ATEXTRA
Call COPTEXTRA("TXSA","GRPDES",[F:TXSO]LSTGRP,"") From ATEXTRA
For I=1 To [F:TXSO]NBRCOL
 Call COPTEXTRA("TXSAC","NAMCOL",[F:TXSO]TXSNAM,num$(I)) From ATEXTRA
Next I
For I=1 To [F:TXSO]NBLIG
 Call COPTEXTRA("TXSD","DES",[F:TXSO]TXSNAM,num$(I)) From ATEXTRA
Next I
If   GOK<0 : Goto ROLL_TR_COP
Elsif !GOK : Goto AB_TR_COP
Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
