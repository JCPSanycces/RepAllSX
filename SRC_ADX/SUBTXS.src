Return

$CHARGE_LIG
Filter [TXD] Where TXSNAM=[M]TXSNAM
For [TXD]TXD1(2)   :# tableau + col
 IC = [F:TXD]COL
 For [TXD]TXD1   :# tableau + col + lig
  IL = [F:TXD]LIG-1
  Assign "[M:TXA2]FRM"+num$(IC)+"(IL)" With [F:TXD]FRM
  If IC=0
   [M:TXA2]LIG(IL)=[F:TXD]LIG
   Call LECTEXTRA([M:TXA2]FRM0(IL),"TXSD","DES",[M:TXA0]TXSNAM,num$([M:TXA2]LIG(IL))) From ATEXTRA
   [M:TXA2]FMTPRN0(IL)=[F:TXD]FMTPRN
   [M:TXA2]EFFPRN0(IL)=[F:TXD]EFFPRN
  Else
   [M:TXA2]FMTPRN(IL) = func REPCAR([M:TXA2]FMTPRN(IL),num$([F:TXD]FMTPRN),IC)
   [M:TXA2]EFFPRN(IL) = func REPCAR([M:TXA2]EFFPRN(IL),num$([F:TXD]EFFPRN),IC)
   [M:TXA2]CEN(IL)    = func REPCAR([M:TXA2]CEN(IL),num$([F:TXD]CEN),IC)
   [M:TXA2]DEC(IL)    = func REPCAR([M:TXA2]DEC(IL),num$([F:TXD]DECCOL),IC)
  Endif
 Next
Next
Filter [TXD]
[M:TXA2]NBLIG = IL+1
Return

Funprog REPCAR(ZONE,CAR,COL)
Value Char  ZONE(), CAR()
Value Integer COL
Local Char T(99)
T = left$(ZONE,COL-1)+CAR+right$(ZONE,COL+1)
End T

$CHARGE_VAR
Raz nolign
For [TXX]TXX0 Where TXSNAM=[M]TXSNAM & VERSION=""
 nolign += 1
 [M:TXA3] = [F:TXX]
 Call LECTEXTRA([M:TXA3]VARDES(nolign-1),"TXSV","VARTRA",[M:TXA0]TXSNAM,[M:TXA3]VARNAM(nolign-1)) From ATEXTRA
Next
[M:TXA3]NBVAR = nolign
Return

###########################################################################################################
$STYLE
For J=1 To [M:TXA1]NBRCOL
 Case J
  When  1 : Chgstl [M:TXA2]FRM1  With "TDB00"
  When  2 : Chgstl [M:TXA2]FRM2  With "TDB00"
