 Filter [FCY]
 [L]AFFOK=1
When "S41.G01.00.007.001"
 [F:HRDAE]WRKCRN=[F:ATT]TXT
 [L]AFFOK=1
When "S41.G01.00.007.002"
 [F:HRDAE]WRKCRN+=[F:ATT]TXT
 [L]AFFOK=1
When "S40.G05.00.001"                             # NIC avant SIREN !!!
 [F:HRDAE]WRKCRN=[F:ATT]TXT
 [L]AFFOK=1
When "S40.G05.00.070"
  GBIDC1=[F:HRDAE]WRKCRN
 [F:HRDAE]WRKCRN=[F:ATT]TXT+GBIDC1
 [L]AFFOK=1
When "S40.G05.00.002"
 [F:HRDAE]WRKFLGADD=1
 [F:HRDAE]WRKNAM=[F:ATT]TXT
 [L]AFFOK=1
When "S41.G01.00.060.001","S40.G05.00.060.001"
 [F:HRDAE]WRKFLGADD=1
 [F:HRDAE]WRKADD1=[F:ATT]TXT
 [L]AFFOK=1
When "S41.G01.00.008.001","S40.G10.00.008.001"
 [F:HRDAE]SEVEMP=val([F:ATT]TXT)
 [L]AFFOK=1
When "S41.G01.00.008.002","S40.G10.00.008.002"
  If dim([F:HRDAE]SEVJOB)>=0 : [F:HRDAE]SEVJOB=val([F:ATT]TXT) : Endif
  If dim([F:HRDAE]SEVCTR)>=0 : [F:HRDAE]SEVCTR=val([F:ATT]TXT) : Endif
  [L]AFFOK=1
When "S40.G10.00.009.002"                                                                 :#N4DS
 Case val([F:ATT]TXT)
  When 90 :       [F:HRDAE]WAGPAYPER=8
  When Default :  [F:HRDAE]WAGPAYPER=val([F:ATT]TXT)-10
 Endcase
 [L]AFFOK=1
When "S41.G01.00.034","S40.G10.00.034.001"                                                :#N4DS
 Case val([F:ATT]TXT)
  When 1 : [F:HRDAE]WRKSTG=3
  When 2 : [F:HRDAE]WRKSTG=1
 Endcase
 [L]AFFOK=1
When "S41.G01.00.011","S41.G01.00.011.001","S40.G10.05.011.001"
 [F:HRDAE]CATCSP   =func ATABDIV(362,"A1",[F:ATT]TXT)
 If dim([F:HRDAE]CTRCODSEE)>=0 : [F:HRDAE]CTRCODSEE=[F:ATT]TXT : Endif
 [L]AFFOK=1
When "S41.G01.00.011.002","S40.G10.05.011.002"
 [F:HRDAE]PSNJOB   =func ATABDIV(604,"A1",[F:ATT]TXT)
 [L]AFFOK=1
When "S41.G01.00.012.001","S40.G10.05.012.001"
 [F:HRDAE]NATCON=func ATABDIV(354,"A1",[F:ATT]TXT)
 If [F:ATT]TXT="01" :  [F:HRDAE]NATCON = "CDI" : Endif
 If [F:ATT]TXT="02" :  [F:HRDAE]NATCON = "CDD" : Endif
 [L]AFFOK=1
When "S41.G01.00.012.002","S40.G10.05.012.002"                                            :#N4DS
 [F:HRDAE]PRUCTR=val([F:ATT]TXT)
 [L]AFFOK=1
When "S40.G10.05.012.003"
 Case  val([F:ATT]TXT)
  When 21 : If [F:HRDAE]NATCON = "CDD" : [F:HRDAE]NATCON = "CIE" : Else  : [F:HRDAE]NATCON = "CII" : Endif
  When 26 : [F:HRDAE]NATCON = "CEC"
  When 40 : [F:HRDAE]NATCON = "CDD"
  When 41 : [F:HRDAE]NATCON = "CRE"
  When 61 : If [F:HRDAE]NATCON = "CDD" : [F:HRDAE]NATCON = "CPR" : Else  : [F:HRDAE]NATCON = "CPI" : Endif
 Endcase
 [L]AFFOK=1
When "S41.G01.00.013","S40.G10.05.013.004"
 Case val([F:ATT]TXT)
  When 4,5     : [F:HRDAE]TYPJOB=val([F:ATT]TXT) : [F:HRDAE]DNATYPMOD=val([F:ATT]TXT)-3
  When 6       : [F:HRDAE]TYPJOB=9               : [F:HRDAE]DNATYPMOD=3
  When 7       : [F:HRDAE]TYPJOB=10              : [F:HRDAE]DNATYPMOD=4
  When 8       : [F:HRDAE]TYPJOB=13              : [F:HRDAE]DNATYPMOD=5
  When Default : [F:HRDAE]TYPJOB=0               : [F:HRDAE]DNATYPMOD=6
 Endcase
 [L]AFFOK=1
When "S41.G01.00.014"
 [F:HRDAE]CATJOB=func ATABDIV(357,"A1",[F:ATT]TXT)
 [L]AFFOK=1
When "S41.G01.00.015.001","S40.G10.05.015.001"
 [F:HRDAE]STACAT=func ATABDIV(364,"A1",[F:ATT]TXT)
 If dim([F:HRDAE]STAEMP)>=0
  If [F:HRDAE]STACAT="CAD"
   [F:HRDAE]STAEMP=len(mess(0,306,1))
  Else
   [F:HRDAE]STAEMP=1
  Endif
 Endif
 [L]AFFOK=1
When "S41.G01.00.015.002","S40.G10.05.015.002"
 [F:HRDAE]STACAT2=func ATABDIV(368,"A1",[F:ATT]TXT)
 [L]AFFOK=1
When "S41.G01.00.016","S40.G10.05.016"
 [F:HRDAE]CLLCVT=func ATABDIV(358,"A1",[F:ATT]TXT)
 [L]AFFOK=1
When "S41.G01.00.020"
 [F:HRDAE]RATMIDWRK = val([F:ATT]TXT)/100
 [L]AFFOK=1
When "S40.G15.00.020.001"
 [F:HRDAE]RATMIDWRK = val([F:ATT]TXT)
 [L]AFFOK=1
When "S41.G01.00.018.001"                                                                 :#Supprimé en N4DS
 [F:HRDAE]SYSSSC=func ATABDIV(355,"A1",[F:ATT]TXT)
 [L]AFFOK=1
When "S41.G01.00.018.002","S40.G20.00.018.002"                                            :#N4DS
 [F:HRDAE]SYSMAL=func ATABDIV(355,"A1",[F:ATT]TXT)
 [L]AFFOK=1
When "S41.G01.00.018.003","S40.G20.00.018.003"                                            :#N4DS
 [F:HRDAE]SYSAT=func ATABDIV(355,"A1",[F:ATT]TXT)
 [L]AFFOK=1
When "S41.G01.00.018.004","S40.G20.00.018.004"                                            :#N4DS
 [F:HRDAE]SYSVIP=func ATABDIV(355,"A1",[F:ATT]TXT)
 [L]AFFOK=1
When "S41.G01.00.018.005"                                                                 :#Supprimé en N4DS
 [F:HRDAE]SYSVIS=func ATABDIV(355,"A1",[F:ATT]TXT)
 [L]AFFOK=1
When "S41.G01.00.018.007","S40.G20.00.018.007"                                            :#N4DS
 [F:HRDAE]DEGMAL=val([F:ATT]TXT)
 [L]AFFOK=1
When "S41.G01.00.018.006","S40.G20.00.018.011"                                            :#N4DS
 [F:HRDAE]SYSFLG=2
 [L]AFFOK=1
When "S41.G01.00.038"
 [F:HRDAE]AVNNAT+="N"
 [L]AFFOK=1
When "S41.G01.00.039"
 [F:HRDAE]AVNNAT+="L"
 [L]AFFOK=1
When "S41.G01.00.040"
 [F:HRDAE]AVNNAT+="V"
 [L]AFFOK=1
When "S41.G01.00.041"
 [F:HRDAE]AVNNAT+="A"
 [L]AFFOK=1
When "S41.G01.00.068"                                                                     :#Supprimé en N4DS
 [F:HRDAE]NTIC=2
 [L]AFFOK=1
When "S40.G40.05.036"
 IAVN+=1
 Case val([F:ATT]TXT):
  When 1 : [F:HRDAE]AVNNAT+="N"
  If dim([F:HRDAE]AVNNATD)>=0 : [F:HRDAE]AVNNATD(IAVN)=1 : Endif
  When 2 : [F:HRDAE]AVNNAT+="L"
  If dim([F:HRDAE]AVNNATD)>=0 : [F:HRDAE]AVNNATD(IAVN)=2 : Endif
  When 3 : [F:HRDAE]AVNNAT+="V"
  If dim([F:HRDAE]AVNNATD)>=0 : [F:HRDAE]AVNNATD(IAVN)=3 : Endif
  When 4 : [F:HRDAE]NTIC=2
  If dim([F:HRDAE]AVNNATD)>=0 : [F:HRDAE]AVNNATD(IAVN)=4 : Endif
  When 9 : [F:HRDAE]AVNNAT+="A"
  If dim([F:HRDAE]AVNNATD)>=0 : [F:HRDAE]AVNNATD(IAVN)=5 : Endif
 Endcase
 [L]AFFOK=1
When "S41.G01.00.045"
 [F:HRDAE]EXSPFL+="F"
 [L]AFFOK=1
When "S41.G01.00.046"
 [F:HRDAE]EXSPFL+="R"
 [L]AFFOK=1
When "S41.G01.00.047"
 [F:HRDAE]EXSPFL+="P"
 [L]AFFOK=1
When "S41.G01.00.048"
 [F:HRDAE]EXSPFL+="D"
 [L]AFFOK=1
When "S40.G40.10.043"                                                                     :#N4DS
 IEXS+=1
Case val([F:ATT]TXT):
 When 1 : [F:HRDAE]EXSPFL+="F"
  If dim([F:HRDAE]EXSPFLD)>=0 : [F:HRDAE]EXSPFLD(IEXS)=1 : Endif
  When 2 : [F:HRDAE]EXSPFL+="R"
  If dim([F:HRDAE]EXSPFLD)>=0 : [F:HRDAE]EXSPFLD(IEXS)=2 : Endif
  When 3 : [F:HRDAE]EXSPFL+="P"
  If dim([F:HRDAE]EXSPFLD)>=0 : [F:HRDAE]EXSPFLD(IEXS)=3 : Endif
  When 4 : [F:HRDAE]EXSPFL+="D"
  If dim([F:HRDAE]EXSPFLD)>=0 : [F:HRDAE]EXSPFLD(IEXS)=4 : Endif
 Endcase
 [L]AFFOK=1
When "S41.G01.00.043","S40.G40.00.043"
