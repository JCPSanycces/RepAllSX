 [F:HRDAE]CODCNB=val([F:ATT]TXT)
 [L]AFFOK=1
#S65
When "S41.G02.00.009","S65.G40.05.009"                                                    :#N4DS
 [F:HRDAE]PRUCOL=val([F:ATT]TXT)
 [L]AFFOK=1
When "S41.G02.00.010","S65.G40.05.010"                                                    :#N4DS
