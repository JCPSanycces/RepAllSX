#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion du masque TRTIMPTDS
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTIMPTDS","TRTIMPTDS",4,"") From GTRAITE
End

#########################################
## Traitement des actions : TRTIMPTDS
#########################################
$ACTION
Case ACTION
 When "INIT"        : Goto INIT
 When "CONTROLE"    : Goto CONTROLE
 When "EXEC"        : Goto EXEC
 When "TERMINE"     : If [L]TRA : Call FERME_TRACE From LECFIC : Endif
 When "DEBUT"       : Gosub DEBUT
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

################################################################################
$INIT
If !clalev([F:FTD])  : Local File HRFILTDS     [FTD]  : Endif
If !clalev([F:ADI])  : Local File ATABDIV    [ADI]  : Endif
If !clalev([F:FGR])  : Local File FACGROUP   [FGR]  : Endif
If !clalev([F:AGF])  : Local File AGRPFCY    [AGF]  : Endif
If !clalev([F:AGC])  : Local File AGRPCPY    [AGC]  : Endif
If !clalev([F:AIN])  : Local File CONTACTCRM [AIN]  : Endif
If !clalev([F:AIN2]) : Local File CONTACTCRM [AIN2] : Endif
If !clalev([F:CNT])  : Local File CONTACT    [CNT]  : Endif
If !clalev([F:CNT2]) : Local File CONTACT    [CNT2] : Endif
If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
If !clalev([F:FCS])  : Local File FACILITY   [FCS]  : Endif
If !clalev([F:FCD])  : Local File FACILITY   [FCD]  : Endif
If !clalev([F:FCY])  : Local File FACILITY   [FCY]  : Endif
If !clalev([F:FCE])  : Local File FACILITY   [FCE]  : Endif

If !clalev([F:BPA])  : Local File BPADDRESS  [BPA]  : Endif
If !clalev([F:BPA2]) : Local File BPADDRESS  [BPA2] : Endif
If !clalev([F:BPS])  : Local File BPADDRESS  [BPS]  : Endif
If !clalev([F:BPD])  : Local File BPADDRESS  [BPD]  : Endif
If !clalev([F:BPE])  : Local File BPADDRESS  [BPE]  : Endif
If !clalev([F:HRDAE])  : Local File EMPLOCTR   [HRDAE]  : Endif
If !clalev([F:HRCTR])  : Local File EMPLOCTR   [HRCTR]  : Endif
If !clalev([F:ID])   : Local File EMPLOID    [ID]   : Endif
If !clalev([F:AD])   : Local File EMPLOAD    [AD]   : Endif
If !clalev([F:CPT])  : Local File EMPLOCPT   [CPT]  : Endif
If !clalev([F:ARM])  : Local File AREPORTM   [ARM]  : Endif
If !clalev([F:ATT])  : Local File ATMPTRA    [ATT]  : Endif
If !clalev([F:ARM2]) : Local File AREPORTM   [ARM2] : Endif
If !clalev([F:ATT2]) : Local File ATMPTRA    [ATT2] : Endif
If !clalev([F:CAC])  : Local File GACCCODE   [CAC]  : Endif
If !clalev([F:TCA])  : Local File TABCOUAFF  [TCA]  : Endif
If !clalev([F:AXX])  : Local File ATEXTRA    [AXX]  : Endif
If !clalev([F:POS])  : Local File POSCOD     [POS]  : Endif
If !clalev([F:PEO])  : Local File PERIOD     [PEO]  : Endif
If [V]GPAYE
 If !clalev([F:TD0])  : Local File PRMTDS0    [TD0]  : Endif
 If !clalev([F:TD02]) : Local File PRMTDS0    [TD02] : Endif
 If !clalev([F:TD1])  : Local File PRMTDS1    [TD1]  : Endif
 If !clalev([F:WAC])  : Local File TRVACC     [WAC]  : Endif
 If !clalev([F:WAR])  : Local File TRVACCRAT  [WAR]  : Endif
 If !clalev([F:WAR2]) : Local File TRVACCRAT  [WAR2] : Endif
 If !clalev([F:VPR])  : Local File VALPRV     [VPR]  : Endif
 If !clalev([F:VPR1]) : Local File VALPRV     [VPR1] : Endif
 If !clalev([F:VPH])  : Local File VALPRVH    [VPH]  : Endif
 If !clalev([F:RCT])  : Local File REPCUMTDS  [RCT]  : Endif
Endif

If !clalev([F:ECT])  : Local File EMPCTR  [ECT] : Endif
If !clalev([F:DFY])  : Local File DADFCY  [DFY] : Endif

If clalev([F:HRXGD])=0  : Local File HRXITGRD [HRXGD]  : Endif
If clalev([F:HRCGD])=0 : Local File HRCTRGRD [HRCGD] : Endif

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif


If func AFNC.ACTIV("PAR")>0
 If !clalev([F:PAR])  : Local File EMPLOPAR     [PAR]  : Endif
Endif

If func AFNC.ACTIV("NOF")>0
 If !clalev([F:EXN])  : Local File EMPLOEXN     [EXN]  : Endif
Endif

If clalev([F:POA])=0 : Local File POPULA   [POA]         : Endif

Local Char     REFNUM([V]GLONMAT), SAVIFS(1), SAVIRS(2), MAIFCY([V]GLONCRT)
Local Integer  NUMREQ, I, J, SAVIUM, K, MAJ, AFFOK, IAVN, IEXS
Local Integer  NBCTR, NBRTABVRA, NBREVE
Local Decimal  RATWAC
Local Char     CTR([V]GLONCTR), FICHIER([V]GDIMFIC), FICCLI([V]GDIMFIC), XCTR(GLONCTR)
Local Char     LESITE(GLONFCY), OLDREFNUM(GLONMAT), OLDCTRNUM(GLONCTR), MATRI(GLONMAT), TABVRA(GLONVRA+GLONRCT)(1..100)
Local Date     DATMAT
Local Mask TRTIMPTDS [ITDS]
Raz [M:ITDS]

Call LECMEMO("STD","[M:ITDS]","imp") From GMEMO

Local Char YEAFTD (4)
Call PARAM("","DADYEA",YEAFTD) From ADOVAL
Return

################################################################################
$DEBUT
Affzo [M:ITDS]
Setmok [ITDS] With 0
Call GRISE_CPY([M:ITDS]CPY)
Call GRISE_FCY([M:ITDS]FCY)
Call GRISE_EMP([M:ITDS]EMP)
Call GRISE_WAC([M:ITDS]WAC)
Call GRISE_VRA([M:ITDS]VRA)
If [ITDS]TYPEXP<>2
 Call SET_NAMCLI([M:ITDS]FIL) From ORDSYS
 Grizo [ITDS] FIL
 Affzo [ITDS] FIL
Else
 Actzo [ITDS] FIL
Endif

#Demarrage en cours d'année
If [M:ITDS]FLGYEA=2
 [M:ITDS]EMP=2    :# Obligatoire pour importer...
 Affzo [M:ITDS]EMP
 Grizo 15-20
 Actzo [M:ITDS]FICYEA
 Actzo [M:ITDS]FLGRAZ
Else
 Effzo [M:ITDS]FICYEA : Grizo [M:ITDS]FICYEA
 Effzo [M:ITDS]FLGRAZ : Grizo [M:ITDS]FLGRAZ
Endif

Return


################################################################################
$CONTROLE
If [V]GSTATUT<>[V]GSTAOK : [L]FIN=1 : Return : Endif

If [M:ITDS]CPY<>2 & [M:ITDS]FCY<>2 & [M:ITDS]EMP<>2 & [M:ITDS]WAC<>2 & [M:ITDS]VRA<>2
 # Erreur sur critère de sélection
 GMESSAGE = mess(33,100,1)
 GERR = 1
 Return
Endif

[L]FICHIER=[M:ITDS]FIL
If [M:ITDS]TYPEXP=2
 [L]FICHIER=filpath([V]GDIRBQR,[M:ITDS]FIL,"tds")
Else
 [L]FICCLI=[L]FICHIER
 Call SET_FICNAM([L]FICCLI,[L]FICHIER,[L]MAIFCY) From ORDSYS
 Call COPSRV([L]FICCLI,[L]FICHIER,I) From ORDSYS
 If I : [L]SAI=1 : Return : Endif
Endif

[L]TMP=1
[L]TRA=1
Return

################################################################################
$EXEC
Call OUVRE_TRACE(mess(23,10711,1)) From LECFIC : # Import des données à la norme DADSU
[L]NUMREQ=func NUMREQ()

Call DEBTRANS From GLOCK
If [M:ITDS]VRA=2
 Gosub OUVRE From WPDEFTABLE
 Gosub TR_IMPORT_VRA
 #Demarrage en cours d'année
Elsif [M:ITDS]FLGYEA=2
 Gosub OUVRE From TRTIMPTDS2
 Gosub TR_IMPORT_IDA From TRTIMPTDS2
Else
 Gosub TR_IMPORT
Endif
Return

#-------------------------------------------------------------------------------
$TR_IMPORT
GOK=1
Trbegin [HRDAE]
 Gosub IMPORT
 If [V]GOK=-1
  Rollback
  Call ROLL From GLOCK
  If [V]GROLL : Return : Else Goto TR_IMPORT : Endif
 Elsif ![V]GOK
  Rollback
  Return
 Endif
Commit

For [FCD]FCY0 Where pat(FCY,"*#")
 Call CREATIONSITE([F:FCD]FCY,[F:FCD]LEGCPY) From SUBAFP1
Next

# Mise à jour de EMPCTR et de NUMLIG dans EMPLOCTR
Gosub MAJ

If nbrecord([CPY])>=dim(GSOC)
 # Pour utiliser cette nouvelle société, il faut redémarrer une nouvelle session
 Call MESSAGE(mess(91,127,1)) From GESECRAN
Elsif nbrecord([FCY])>=dim(GSITE)
 # Pour utiliser ce nouveau site, il faut redémarrer une nouvelle session
 Call MESSAGE(mess(92,127,1)) From GESECRAN
Else
 Call INISOC From GLOBSUP  : # Réinit de la tables des sociétés
Endif
Return

#-------------------------------------------------------------------------------
$IMPORT
Raz [F:ARM], [F:ATT]
[F:ARM]NUMREQ=[L]NUMREQ
[F:ARM]CREDAT=date$
[F:ARM]USR   =[V]GUSER
[F:ARM]RPTCOD="TRTIMPTDS"
[F:ATT]NUMREQ=[F:ARM]NUMREQ
[F:ATT]CREDAT=[F:ARM]CREDAT


Filter [FTD] Where YEA=[L]YEAFTD & IMPORT=2

[L]SAVIFS=adxifs
[L]SAVIRS=adxirs
[L]SAVIUM=adxium
adxifs   =","
adxirs   =chr$(13)+chr$(10)
adxium   =[V]GASCII
Openi [L]FICHIER, 0

Repeat
 Rdseq [F:ARM]CLEA1, [F:ATT]TXT
 If fstat : Break : Endif

 If !instr(1,[F:ATT]TXT,",")

 [F:ATT]TXT=seg$([F:ATT]TXT,2,len([F:ATT]TXT)-1)

 Case [F:ARM]CLEA1
 When "S20.G01.00.001"
  I            =([M:ITDS]CPY=2)
  [F:ARM]CLEA2 =[F:ATT]TXT                                     :# SIREN de l'entreprise
  [F:ARM]SEQREQ=2
  If [M:ITDS]CPY=2 & [M:ITDS]FCY=2
   [L]MAIFCY=[F:ATT]TXT
  Endif
  Raz [F:ARM]CLEN1, [F:ARM]CLEA3, [F:ARM]CLEA4, [F:ARM]CLED1
 When "S20.G01.00.008","S20.G01.00.010", "S20.G05.00.010"                    :#N4DS
  I            =([M:ITDS]FCY=2)
  #Le site principal n'est plus l'emetteur mais le siège (Demande BASAH)
  If [F:ARM]CLEA1 ="S20.G01.00.008" & [M:ITDS]CPY=2 & [M:ITDS]FCY=2
   [L]MAIFCY+=[F:ATT]TXT
  Endif
  [F:ARM]CLEA3 =[F:ATT]TXT                                     :# NIC de l'établissement siege/déclarant
  [F:ARM]SEQREQ=3
  Raz [F:ARM]CLEA4, [F:ARM]CLED1
 When "S10.G01.00.001.001","S80.G01.00.001.001"
  I            =([M:ITDS]FCY=2)
  [F:ARM]CLEA2 =[F:ATT]TXT
  [F:ARM]SEQREQ=3
  Raz [F:ARM]CLEA3, [F:ARM]CLEA4, [F:ARM]CLED1
 When "S10.G01.00.001.002","S80.G01.00.001.002"
  If val([L]YEAFTD)>2010 & [F:ARM]CLEA1 ="S80.G01.00.001.002"
   I            =([M:ITDS]FCY=2)
   [F:ARM]SEQREQ=3
   [F:ARM]CLEA3 =[F:ATT]TXT
  Endif
  [F:ARM]CLEA3 =[F:ATT]TXT
  If I
   Update [ARM2] Where NUMREQ=[L]NUMREQ & NUMLIG=[F:ARM]NUMLIG With CLEA3=[F:ARM]CLEA3
   If fstat
    [V]GOK=0
    Call FSTA("ARM") From GLOCK
    Break
   Endif
  Endif
 When "S30.G01.00.001"
  I            =([M:ITDS]EMP=2)
  [F:ARM]CLEA4 =[F:ATT]TXT : # N°ss
  [F:ARM]SEQREQ=4
  Raz [F:ARM]CLED1
 When "S41.G01.00.001","S40.G01.00.001"        :#N4DS
  [F:ARM]CLED1 =func GDAT([F:ATT]TXT)

 When "S41.G01.00.025","S40.G25.00.025"        :#N4DS
  [F:ARM]CLEA5 =[F:ATT]TXT
  If [M:ITDS]WAC=2
   I=1
   [F:ARM]SEQREQ=5
  Elsif [M:ITDS]EMP=2
   I=1
   [F:ARM]SEQREQ=4
  Endif
 When "S41.G01.00.026","S40.G25.00.026"        :#N4DS
  [F:ARM]CLEA5+=[F:ATT]TXT
  If I
   Update [ARM2] Where NUMREQ=[L]NUMREQ & NUMLIG=[F:ARM]NUMLIG With CLEA5=[F:ARM]CLEA5
   If fstat
    [V]GOK=0
    Call FSTA("ARM") From GLOCK
    Break
   Endif
  Endif
 When "S41.G01.00.029.001","S40.G28.05.029.001"    :#N4DS
  I            =([M:ITDS]EMP=2)
  [F:ARM]SEQREQ=4
  Raz [F:ARM]CLEA5
 Endcase

 If I
  Look [FTD]FTD0=[L]YEAFTD;[F:ARM]CLEA1
  If !fstat
   [F:ARM]NUMLIG+=1
   [F:ATT]LIG    =[F:ARM]NUMLIG
   Write [ARM]
   If fstat
    [V]GOK=0
    Call FSTA("ARM") From GLOCK
    Break
   Endif
   Write [ATT]
   If fstat
    [V]GOK=0
    Call FSTA("ATT") From GLOCK
    Break
   Endif
  Endif
 Endif
 Endif

Until 0
Filter [FTD]

Openi
adxifs=[L]SAVIFS
adxirs=[L]SAVIRS
adxium=[L]SAVIUM

If [V]GOK<1 : Return : Endif

Link [ARM] With [ATT]ATT0=NUMREQ;NUMLIG As [LNK]


Filter [LNK] Where NUMREQ=[L]NUMREQ & SEQREQ=2 Order By Key CLE=CLEA2;NUMLIG
For [LNK]CLE(1)
 Gosub SOCIETE
 If [V]GOK<1 : Break : Endif
Next
Filter [LNK]
If [V]GOK<1 : Return : Endif

Filter [LNK] Where NUMREQ=[L]NUMREQ & SEQREQ=3 Order By Key CLE=CLEA2;CLEA3;NUMLIG
For [LNK]CLE(2)
 Gosub SITE
 If [V]GOK<1 : Break : Endif
Next
Filter [LNK]
If [V]GOK<1 : Return : Endif

If [L]MAIFCY>""
 Gosub SOCIETE2
 If [V]GOK<1 : Return : Endif
Endif

Link [ARM2] With [ATT2]ATT0=NUMREQ;NUMLIG As [LNK2]
Filter [LNK] Where NUMREQ=[L]NUMREQ & SEQREQ=4 Order By Key CLE=CLEA4;CLED1;NUMLIG
For [LNK]CLE(1)
 Gosub SALARIE
 If [V]GOK<1 : Break : Endif
Next
Filter [LNK]
If [V]GOK<1 : Return : Endif

Filter [LNK] Where NUMREQ=[L]NUMREQ & SEQREQ=5 Order By Key CLE=CLEA5;CLED1;NUMLIG
For [LNK]CLE(1)
 Gosub ACCIDENT
 If [V]GOK<1 : Break : Endif
Next
Filter [LNK]
If [V]GOK<1 : Return : Endif

Delete [ATT] Where NUMREQ=[L]NUMREQ
Delete [ARM] Where NUMREQ=[L]NUMREQ
Return

#-------------------------------------------------------------------------------
$SOCIETE
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(func AFNC.MES1(mess(53,10711,1),[F:ARM]CLEA2),0) From GESECRAN
#              Import société de SIREN $1$

Filter [CPY] Where CRN=[F:ARM]CLEA2
Read [CPY] First
Filter [CPY]
If !fstat & [M:ITDS]FLGCPY<>2 : # Pas de mise à jour autorisée
 Call ECR_TRACE([F:CPY]CPY-":"-mess(25,10711,1)-[F:ARM]CLEA2,1) From GESECRAN
 #              Société non importée : Société déjà existante avec n° SIRET
 Return
Elsif !fstat
 MAJ = 1 : # Mise à jour
Else
 MAJ = 0 : # Création
 Raz [F:CPY]
 [F:CPY]ACCCUR =[V]GSYSCUR
 [F:CPY]CPY    =func CODENT()
 [F:CPY]LEG    =GDOSLEG(1) : # 60898
 If [F:CPY]CRY="" : [F:CPY]CRY=[V]GPAYS : Endif
 Call INITACCCOD([F:CPY]ACCCOD,[V]GCACCPY) From TRTINTCPT
 [F:CPY]CPYLEGFLG=2
Endif

For [LNK]CLE
 Gosub AFFECTE
Next

Default File [CPY]
Gosub MENU1
If MAJ
 Rewrite [CPY]
Else
 Write [CPY]
Endif
If fstat
 [V]GOK=0
 Call FSTA("CPY") From GLOCK
 Return
Endif

# Création/maj du groupe "société juridique"
#69916
Read [AGF]AGF0 = [F:CPY]CPY
If fstat
 Raz [F:AGF]
 [F:AGF]GRP    = [F:CPY]CPY
 [F:AGF]DES    = [F:CPY]CPYNAM
 [F:AGF]SHO    = [F:CPY]CPYSHO
 [F:AGF]FLGCPY = [F:CPY]CPYLEGFLG
 [F:AGF]FLGLEG = [F:CPY]CPYLEGFLG
 [F:AGF]CREDAT = date$
 If dim([F:AGF]CRETIM)>0 : [F:AGF]CRETIM = time : Endif
 [F:AGF]CREUSR = GUSER
 Write [AGF]
 If fstat
  [V]GOK=0
  Call FSTA("AGF") From GLOCK
  Return
 Endif
Endif

If [F:CPY]CPYLEGFLG=2
 Read [AGC]AGC0 = [F:CPY]CPY;[F:CPY]CPY
 If fstat
  [F:AGC]GRP = [F:CPY]CPY
  [F:AGC]CPY = [F:CPY]CPY
  Write [AGC]
  If fstat
   [V]GOK=0
   Call FSTA("AGC") From GLOCK
   Return
  Endif
 Endif
Endif
#

If MAJ
 Call ECR_TRACE(func AFNC.MES1(mess(60,10711,1),[F:CPY]CPY),0) From GESECRAN
 #              Mise à jour société de code $1$
Else
 Call ECR_TRACE(func AFNC.MES1(mess(29,10711,1),[F:CPY]CPY),0) From GESECRAN
 #              Création société de code $1$
Endif
Return

#-------------------------------------------------------------------------------
$SITE
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(func AFNC.MES1(mess(54,10711,1),[F:ARM]CLEA2+[F:ARM]CLEA3),0) From GESECRAN
#              Import site de SIRET $1$

# SIREN+NIC = SIRET

Filter [FCY] Where CRN=[F:ARM]CLEA2+[F:ARM]CLEA3
Read [FCY]FCY0 First
Filter [FCY]
If !fstat & [M:ITDS]FLGFCY<>2
 Call ECR_TRACE(mess(27,10711,1)-":"-[F:FCY]FCY,1) From GESECRAN
 #              Site non importée : Site déjà existant avec n° SIRET
 Return
Elsif !fstat
 MAJ = 1 : # Mise à jour
 Read [FCY]FCY0=[F:FCY]FCY
Else
 MAJ = 0 : # Création
 Raz [F:FCY], [F:FCY]
Endif


Filter [CPY] Where CRN=[F:ARM]CLEA2
Read [CPY] First
Filter [CPY]
If fstat
 Call ECR_TRACE( func AFNC.MES2(mess(49,10711,1),[F:ARM]CLEA2+[F:ARM]CLEA3,[F:ARM]CLEA2),1
&              ) From GESECRAN
 #               Site de SIRET $1$ non importé car société de SIREN $2$ inexistante
 Return
Endif

# Fusion des différentes infos du site se trouvant dans les enregistrements DADSU du site déclarant [FCD]
# du site émetteur [FCE] et du site siège social [FCS]
Raz [F:FCS], [F:FCD], [F:BPA], [F:BPS], [F:BPD], [F:FCE], [F:BPE]
& , [F:AIN], [F:CNT]
For [LNK]CLE
 [F:FCS]=[F:FCY]
 [F:FCD]=[F:FCY]
 [F:FCE]=[F:FCY]
 Gosub AFFECTE

 # Si FCD<>FCS
 If !func IDENT("FCD","FCS")
  If func IDENT("FCY","FCD") : [F:FCY]=[F:FCS] : Else [F:FCY]=[F:FCD] : Endif
 Elsif !func IDENT("FCD","FCE")
  If func IDENT("FCY","FCD") : [F:FCY]=[F:FCE] : Else [F:FCY]=[F:FCD] : Endif
 Elsif !func IDENT("FCE","FCS")
  If func IDENT("FCY","FCE") : [F:FCY]=[F:FCS] : Else [F:FCY]=[F:FCE] : Endif
 Endif

Next

If MAJ=0
 If [F:FCY]CRY="" : [F:FCY]CRY=[F:CPY]CRY : Endif
 [F:FCY]LEGCPY=[F:CPY]CPY
 [F:FCY]FCY   =func CODENT()
 [F:FCY]FINFLG=2      :# Site financier par défaut
 [F:FCY]FINRSPFCY=[F:FCY]FCY
 [F:FCY]BPAADD="S1"
 Call INITACCCOD([F:FCY]ACCCOD,[V]GCACFCY) From TRTINTCPT

 # Par défaut prendre 'adresse du siège et non plus de l'emetteur car emetteur externe possible...
 #If [F:BPE]POSCOD>""
 # If  !func IDENT("BPA","BPE")
 #  [F:FCY]BPAADD="A0"
 # Endif
 #Endif

 If [F:BPA]POSCOD>""
  If  !func IDENT("BPA","BPS")
   [F:FCY]BPAADD="A1"
  Endif
 Endif

Endif

Default File [FCY]
Gosub MENU1
If MAJ
 Rewrite [FCY]
Else
 Write [FCY]
Endif
If fstat
 [V]GOK=0
 Call FSTA("FCY") From GLOCK
 Return
Endif

#69916
For [AGC]AGC0(1) Where CPY=[F:CPY]CPY
 Readlock [FGR]FGR0 = [F:AGC]GRP;[F:FCY]FCY
 If fstat=1
  GOK = -1 : GLOCK = "$FACGROUP"-[F:AGC]GRP-[F:FCY]FCY : Break
 Elsif fstat
  Raz [F:FGR]
  [F:FGR]CPY    = [F:AGC]GRP
  [F:FGR]FCY    = [F:FCY]FCY
  Write [FGR]
  If fstat
   [V]GOK=0
   Call FSTA("FCY") From GLOCK
   Break
  Endif
 Endif
Next
If ! [V]GOK : Return :  Endif
#

If [F:BPS]POSCOD>"" & [F:FCY]BPASGE=""
 If func IDENT("BPE","BPS")
  [F:FCY]BPASGE="S1"
 Elsif func IDENT("BPA","BPE")
  [F:FCY]BPASGE="A1"
 Else
  [F:FCY]BPASGE="A0"
 Endif
Endif


If [F:BPD]POSCOD>"" & [F:FCY]BPADCL=""
 If func IDENT("BPS","BPD")
  [F:FCY]BPADCL=[F:FCY]BPASGE
 Elsif func IDENT("BPA","BPD")
   [F:FCY]BPADCL="A1"
 Elsif func IDENT("BPE","BPD")
  [F:FCY]BPADCL="A0"
 Else
  [F:FCY]BPADCL="D1"
 Endif
Endif


# Adresse site S80 <> siège
If [F:BPA]POSCOD>""
 If  !func IDENT("BPS","BPA")
  [F:BPA]BPATYP=3
  [F:BPA]BPANUM=[F:FCY]FCY
  [F:BPA]BPAADD="A1"
  [F:BPA]BPADES=mess(47,119,1)
  Call PAYS([F:BPA]CRY,[F:BPA]CRYNAM)
  Default File [BPA]
  Gosub PAYS2
  Gosub MENU1
  Read [BPA]BPA0 =
  If !fstat
   Rewrite [BPA]
  Else
   Write [BPA]
  Endif
  If fstat
   [V]GOK=0
   Call FSTA("BPA") From GLOCK
   Return
  Endif
 Endif
Endif

# Adresse siege
If [F:BPS]POSCOD>""
 [F:BPS]BPATYP=3
 [F:BPS]BPANUM=[F:FCY]FCY
 [F:BPS]BPAADD="S1"
 [F:BPS]BPADES='Siège'
 Call PAYS([F:BPS]CRY,[F:BPS]CRYNAM)
 Default File [BPS]
 Gosub PAYS2
 Gosub MENU1
 Read [BPS]BPA0 =
 If !fstat
  Rewrite [BPS]
 Else
  Write [BPS]
 Endif
 If fstat
  [V]GOK=0
  Call FSTA("BPS") From GLOCK
  Return
 Endif
Endif

If [F:FCY]BPADCL="D1"
 [F:BPD]BPATYP=3
 [F:BPD]BPANUM=[F:FCY]FCY
 [F:BPD]BPAADD=[F:FCY]BPADCL
 [F:BPD]BPADES='Déclarant'
 Call PAYS([F:BPD]CRY,[F:BPD]CRYNAM)
 Default File [BPD]
 Gosub PAYS2
 Gosub MENU1
 Read [BPD]BPA0 =
 If !fstat
  Rewrite[BPD]
 Else
  Write [BPD]
 Endif
 If fstat
  [V]GOK=0
  Call FSTA("BPD") From GLOCK
  Return
 Endif
Endif

If [F:FCY]BPASGE="A0"
 [F:BPE]BPATYP=3
 [F:BPE]BPANUM=[F:FCY]FCY
 [F:BPE]BPAADD=[F:FCY]BPASGE
 [F:BPE]BPADES='Emetteur'
 Call PAYS([F:BPE]CRY,[F:BPE]CRYNAM)
 Default File [BPE]
 Gosub PAYS2
 Gosub MENU1
 Read [BPE]BPA0 =
 If !fstat
  Rewrite [BPE]
 Else
  Write [BPE]
 Endif
 If fstat
  [V]GOK=0
  Call FSTA("BPE") From GLOCK
  Return
 Endif
Endif

# Contact emetteur
# Si mise à jour autorisée : Si le contact existe on le met à jour sinon on le crée
If [F:AIN]CNTLNA<>""
 Filter [AIN2] Where toupper(CNTLNA)=toupper([F:AIN]CNTLNA) & toupper(CNTFNA)=toupper([F:AIN]CNTFNA)
 Read [F:AIN2]First
 Filter [AIN2]
 If fstat
  [F:AIN]CNTNUM =func SUBAIN.COD([C]INTERLOC)
  [C]INTERLOC  +=1
  [F:AIN]CNTTYP =1 : # Standard
  Default File [AIN]
  Gosub PAYS2
  Gosub MENU1
  Write [AIN]
  If fstat
   [V]GOK=0
   Call FSTA("AIN") From GLOCK
   Return
  Endif
  [F:CNT]BPANUM=[F:FCY]FCY
  [F:CNT]CCNCRM=[F:AIN]CNTNUM
  [F:CNT]BPATYP=3
  Default File [CNT]
  Gosub MENU1
  Write [CNT]
  If fstat
   [V]GOK=0
   Call FSTA("CNT") From GLOCK
   Return
  Endif
 Else
  [F:AIN2]CNTTTL = [F:AIN]CNTTTL
  [F:AIN2]CNTEMA = [F:AIN]CNTEMA
  [F:AIN2]CNTETS = [F:AIN]CNTETS
  [F:AIN2]CNTFAX = [F:AIN]CNTFAX
  Default File [AIN2]
  Gosub MENU1
  Rewrite [AIN2]
  Read [CNT2]CNT0=3;[F:FCY]FCY;[F:AIN2]CNTNUM
  If fstat>=2
   [F:CNT2]BPANUM=[F:FCY]FCY
   [F:CNT2]CCNCRM=[F:AIN2]CNTNUM
   [F:CNT2]BPATYP=3
   Default File [CNT2]
   Gosub MENU1
   Write [CNT2]
   If fstat
    [V]GOK=0
    Call FSTA("CNT2") From GLOCK
    Return
   Endif
  Endif
 Endif
Endif

If MAJ=0
 [F:FCY]FCY   =[F:FCY]FCY
 [F:FCY]PAYFLG=2 : # Site de paye par defaut
 [F:FCY]DADFLG=2 : # Site DADS par defaut
 [F:FCY]DADFCY=[F:FCY]FCY
Endif

If [F:FCY]CNTDDS="" : [F:FCY]CNTDDS=[F:CNT]CCNCRM : Endif

Default File [FCY]
Gosub MENU1
If MAJ=0
 Write [FCY]
Else
 Rewrite [FCY]
Endif
If fstat
 [V]GOK=0
 Call FSTA("FCY") From GLOCK
 Return
Endif


If MAJ
 Call ECR_TRACE(func AFNC.MES1(mess(61,10711,1),[F:FCY]FCY),0) From GESECRAN
 #              Mise à jour site de code $1$
Else
Call ECR_TRACE(func AFNC.MES1(mess(30,10711,1),[F:FCY]FCY),0) From GESECRAN
#              Création site de code $1$
Endif
Return

#-------------------------------------------------------------------------------
$SOCIETE2

Filter [FCY] Where CRN=[L]MAIFCY
Read [FCY] First
Filter [FCY]
If fstat : Return : Endif

Readlock [CPY]CPY0=[F:FCY]LEGCPY
If fstat=1
 [V]GOK  =-1
 [V]GLOCK="$COMPANY"-[F:FCY]LEGCPY
 Return
Elsif fstat
 [V]GOK=0
 Call RSTA("CPY",[F:FCY]LEGCPY) From GLOCK
 Return
Endif
[F:CPY]MAIFCY=[F:FCY]FCY
[F:CPY]NAF   =[F:FCY]NAF
Rewrite [CPY]
If fstat
 [V]GOK=0
 Call FSTA("CPY") From GLOCK
 Return
Endif

For [BPA] Where BPANUM=[F:FCY]FCY & BPATYP=3
 [F:BPA2] = [F:BPA]
 [F:BPA2]BPATYP=2
 [F:BPA2]BPANUM=[F:FCY]LEGCPY
 Readlock[BPA2]BPA0=2;[F:FCY]LEGCPY;[F:BPA]BPAADD
 If fstat=1
  [V]GOK=-1 : GLOCK="$BPADDRESS"-[F:BPA2]BPANUM
 Elsif !fstat
  Rewrite [BPA2]
 Else
  Write [BPA2]
 Endif
 If fstat
  [V]GOK=0
  Call FSTA("BPA") From GLOCK
  Break
 Endif
Next
If [V]GOK<1 : Return : Endif

For [F:CNT]CNT0 Where BPANUM=[F:FCY]FCY & BPATYP=3
 Readlock[CNT2]CNT0=2;[F:FCY]LEGCPY;[F:CNT]CCNCRM
 If fstat=1
  [V]GOK=-1 : GLOCK="$CONTACT"-[F:CNT]CCNCRM
 Elsif !fstat
  [F:CNT2] = [F:CNT]
  [F:CNT2]BPATYP=2
  [F:CNT2]BPANUM=[F:FCY]LEGCPY
  Rewrite [CNT2]
 Else
  [F:CNT2] = [F:CNT]
  [F:CNT2]BPATYP=2
  [F:CNT2]BPANUM=[F:FCY]LEGCPY
  Write [CNT2]
 Endif
 If fstat
  [V]GOK=0
  Call FSTA("CNT2") From GLOCK
  Break
 Endif
Next
If [V]GOK<1 : Return : Endif
Return

#-------------------------------------------------------------------------------
$SALARIE
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(func AFNC.MES1(mess(55,10711,1),[F:ARM]CLEA4),0) From GESECRAN
#              Import salarié de NIR $1$

If [F:ARM]CLEA4="1999999999999" | [F:ARM]CLEA4="2999999999999" | len([F:ARM]CLEA4)<>13
 Call ECR_TRACE(mess(63,10711,1)-[F:ARM]CLEA4,1) From GESECRAN
 #              Salarié non importé; N° sécurité sociale incomplet : XXX
 Return
Endif

Raz [L]REFNUM

#62642
#Filter [ID] Where NUMSSC=[F:ARM]CLEA4
Filter [ID] Where left$(NUMSSC,13)=[F:ARM]CLEA4
Read [ID]ID0 First
Filter [ID]
If !fstat & [M:ITDS]FLGEMP<>2
 Call ECR_TRACE(mess(38,10711,1)-[F:ID]REFNUM,1) From GESECRAN
 #              Salarié non importé : No sécurité sociale déjà existant XXX
 Return
Elsif !fstat
 MAJ=1
 [L]REFNUM = [F:ID]REFNUM
Else
 MAJ=0 : # Création
Endif

If MAJ=0 : # Création
 # "S41.G01.00.019" & "S30.G10.05.001"= Matricule du salarié dans l'entreprise
 # "S40.G10.00.019" & "S30.G01.00.019"= Matricule du salarié dans l'entreprise     :    # N4DS
 Filter [LNK2] Where NUMREQ=[L]NUMREQ & SEQREQ=4 & CLEA2=[F:ARM]CLEA2
&    &               CLEA4=[F:ARM]CLEA4 & (CLEA1="S41.G01.00.019" | CLEA1="S30.G10.05.001"
&    |               CLEA1="S40.G10.00.019" | CLEA1="S30.G01.00.019")
&                    Order By Key CLE=CLED1 Desc
 Read [LNK2] First
 Filter [LNK2]
 #82086
 #If fstat
 # [L]REFNUM=""
 #Else
 # Look [ID]ID0=[F:ATT2]TXT
 # If !fstat :# 62643 & [M:ITDS]FLGEMP<>2
 #  Call ECR_TRACE(mess(36,10711,1)-[F:ATT]TXT,1) From GESECRAN
 #  #              Salarié non importé : Matricule déjà existant XXX
 #  Return
 # Endif
 # If [M:ITDS]FLGNUM=2 & [F:ATT2]TXT<>""
 #  [L]REFNUM=[F:ATT2]TXT
 # Else
 #  Raz [L]REFNUM
 # Endif
 #Endif

 #Forcement un nouveau salarié car MAJ =0 donc N° SS non trouvé 
 If !fstat & [M:ITDS]FLGNUM=2 & [F:ATT2]TXT<>""
  [L]REFNUM=[F:ATT2]TXT
 Endif
Endif

#"S41.G01.00.005" : NIC de l'établissement d'affectation
#"S40.G01.00.005" : NIC de l'établissement d'affectation                                  :#N4DS
Filter [LNK2] Where NUMREQ=[L]NUMREQ & SEQREQ=4 & CLEA2=[F:ARM]CLEA2
&                 & CLEA4=[F:ARM]CLEA4 & (CLEA1="S41.G01.00.005" | CLEA1="S40.G01.00.005")
&      Order By Key CLE=CLED1
I=0
For [LNK2]CLE
 Filter [FCY] Where CRN=[F:ARM2]CLEA2+[F:ATT2]TXT
 Read [FCY]FCY0 First
 Filter [FCY]
 If fstat
  Call ECR_TRACE(mess(39,10711,1)-":"-[F:ARM2]CLEA2+[F:ATT2]TXT,1) From GESECRAN
  #              Salarié non importé ; Site de rattachement inconnu
  I=1
 Endif
Next
Filter [LNK2]
If I : Return : Endif

If [L]REFNUM=""
 Call NUMERO([F:TCA]CODNUM(2),[F:FCY]FCY,[F:ARM2]CLED1,"",[L]REFNUM,I) From SUBANM
 If I
  Call ECR_TRACE(mess(4,10702,1)-[F:TCA]CODNUM(2),1) From GESECRAN : # Erreur sur compteur
  [V]GOK=0
  Return
 Endif
Endif

Raz [F:ID], [F:AD], [F:CPT], [L]CTR
Read [ID]ID0=[L]REFNUM
Read [AD]AD0=[L]REFNUM
Read [CPT]CPT0=[L]REFNUM

# Sauve le [HRCTR]NUMLIG avant le trasnclass lors d'une MAJ de CTR
NBRLIG=0

For [LNK]CLE(2)
 Raz [F:HRDAE], [F:FCD]
 Raz NBCTR

 For [LNK]CLE
  If ([F:ARM]CLEA1="S41.G01.00.001" | [F:ARM]CLEA1="S40.G01.00.001") & NBCTR=1    :#N4DS
   Gosub WRITE_DAE
   If [V]GOK<1 : Break 2 : Endif
   Raz [F:HRDAE], [F:FCD]
  Endif
  Gosub AFFECTE
 Next
 Gosub WRITE_DAE
 If [V]GOK<1 : Break : Endif
Next

If [V]GOK<1 : Return : Endif

[F:ID]REFNUM=[L]REFNUM
[F:ID]FCY   =[F:HRDAE]ETRFCY
Read [FCY]FCY0=[F:HRDAE]ETRFCY
If !fstat
 [F:ID]CPY = [F:FCY]LEGCPY
Endif
If [F:HRDAE]SEVCTR=2
 [F:ID]FLGMULCTR = 2
Else
 [F:ID]FLGMULCTR = 1
Endif
[F:ID]PRF   =[F:HRDAE]PROPRF
[F:ID]SRV   =[F:HRDAE]ETRSRV
If [F:ID]NAM="" : [F:ID]NAM=[F:ID]OLDNAM : Endif
Call PAYS([F:ID]CRY,[F:ID]CRYNAM)
Call PAYS([F:ID]NTT,[F:ID]NTTNAM)
Call PAYS([F:ID]CRYBRN,[F:ID]CRYNAMBRN)
[F:ID]ENAFLG   =2          : # Salarié actif par défaut
[F:ID]FLGPAY   =1+[V]GPAYE : # Gestion de la paye
[F:ID]FLGTPS   =[F:ID]FLGPAY: # Gestion des temps si paye
Filter [POS] Where CRY=[F:ID]CRY & POSCOD=[F:ID]CODPOS & POSCTY=[F:ID]CTY
Read [POS]POS1 First
Filter [POS]
If !fstat
 [F:ID]CODSEE = [F:POS]POSCTYCOD
Endif
Filter [POS] Where CRY=[F:ID]CRYBRN & POSCTY=[F:ID]CTYBRN
Read [POS]POS1 First
Filter [POS]
If !fstat
 [F:ID]CTYBRNSEE = [F:POS]POSCTYCOD
Endif
Default File [ID]
Gosub MENU1
If MAJ=1
 Rewrite [ID]
 Call ECR_TRACE(func AFNC.MES1(mess(64,10711,1),[F:ID]REFNUM),0) From GESECRAN
 #              Mise à jour du salarié de matricule $1$
Else
 Write [ID]
 Call ECR_TRACE(func AFNC.MES1(mess(37,10711,1),[F:ID]REFNUM),0) From GESECRAN
 #              Création salarié de matricule $1$
Endif
If fstat
 [V]GOK=0
 Call FSTA("ID") From GLOCK : Return
Endif

Read [POA]POA0 = "";[L]REFNUM
If fstat
 Raz [F:POA]
 [F:POA]REFNUM = [L]REFNUM
 [F:POA]MAJTYP = 2 : # Manuelle
 If dim([F:POA]CREUSR)>0 : [F:POA]CREUSR = GUSER : Endif
 If dim([F:POA]CREDAT)>0 : [F:POA]CREDAT = date$ : Endif
 If dim([F:POA]CRETIM)>0 : [F:POA]CRETIM = time  : Endif
 Write [POA]
 If fstat
  GOK = 0 : Call FSTA("POA") From GLOCK : Return
 Endif
Endif

Read [AD]AD0=[L]REFNUM
If !fstat & MAJ=1
 Default File [AD]
 Gosub MENU1
 Rewrite [AD]
Else
 [F:AD]REFNUM=[L]REFNUM
 Default File [AD]
 Gosub MENU1
 Write [AD]
Endif
If fstat
 [V]GOK=0
 Call FSTA("AD") From GLOCK
 Return
Endif

Read [CPT]CPT0=[L]REFNUM
If !fstat & MAJ=1
 Default File [CPT]
 Gosub MENU1
 Rewrite [CPT]
Else
 [F:CPT]REFNUM=[L]REFNUM
 [F:CPT]ACCCOD=[F:CAC]ACCCOD
 Default File [CPT]
 Gosub MENU1
 Write [CPT]
Endif
If fstat
 [V]GOK=0
 Call FSTA("CPT") From GLOCK
 Return
Endif

# Créer enregistrement dans participation et dans note de frais
If func AFNC.ACTIV("PAR")>0
 Read [PAR]PAR0=[L]REFNUM;1
 If fstat
  Raz [F:PAR]
  [F:PAR]REFNUM = [L]REFNUM
  [F:PAR]NUMLIG = 1
  [F:PAR]FLGITS = 2
  [F:PAR]FLGPAR = 2
  [F:PAR]PARDAT = [F:HRDAE]CTRDAT
  [F:PAR]CREDAT = date$
  [F:PAR]CREUSR = GUSER
  [F:PAR]CRETIM = time
  Write [F:PAR]
  If fstat
   GOK=0 : Call FSTA("PAR") From GLOCK
   Return
  Endif
 Endif
Endif

If func AFNC.ACTIV("NOF")>0
 For I=1 To 2
  Read [EXN]EXN0=[L]REFNUM;I
  If fstat
   Raz [F:EXN]
   [F:EXN]REFNUM = [L]REFNUM
   [F:EXN]NUMLIG = I
   [F:EXN]CREDAT = date$
   [F:EXN]CREUSR = GUSER
   [F:EXN]EXSAMT = 1
   [F:EXN]EXSDAT = [F:HRDAE]CTRDAT
   If I=1
    [F:EXN]EXSVAR = "#553"
   Else
    [F:EXN]EXSVAR = "#554"
   Endif
   Write [F:EXN]
   If fstat
    GOK=0 : Call FSTA("EXN") From GLOCK : Break
   Endif
  Endif
 Next
 If GOK=0 : Return : Endif
Endif
Return

#-------------------------------------------------------------------------------

$WRITE_DAE
If [F:ARM]CLED1>[0/0/0]
 Read [FCY]FCY0=[F:FCY]FCY

 If ![F:HRDAE]WRKSTG : [F:HRDAE]WRKSTG=2 : Endif : # Non
 If ![F:HRDAE]CODCNB : [F:HRDAE]CODCNB=5 : Endif : # Aucun
 If ![F:HRDAE]HRSWEK : [F:HRDAE]HRSWEK=val(func AFNC.PARAM("HOUWEKLEG",[F:FCY]FCY)) : Endif
 If ![F:HRDAE]HRSMTH : [F:HRDAE]HRSMTH=val(func AFNC.PARAM("HOUMONLEG",[F:FCY]FCY)) : Endif

 [F:HRDAE]REFNUM =[L]REFNUM
 [F:HRDAE]ETRFCY=[F:FCY]FCY
 If [F:HRDAE]CLLCVT="" : [F:HRDAE]CLLCVT=[F:FCY]CLLCVT : Endif
 If [F:HRDAE]RSKWRK="" : [F:HRDAE]RSKWRK=[F:FCY]RSKWRK : Endif
 If [F:HRDAE]DNACODTIM=0 : [F:HRDAE]DNACODTIM = 3      : Endif              :# A l'heure

 If ![F:HRDAE]DNASITADM : [F:HRDAE]DNASITADM=1         : Endif              :# droit privé
 If ![F:HRDAE]DNACPYSTG : [F:HRDAE]DNACPYSTG=len(mess(0,2512,1)) : Endif    :# non étrangère
 If ![F:HRDAE]DNAACTASS : [F:HRDAE]DNAACTASS=1         : Endif              :# Assujetti chomage
 If ![F:HRDAE]DNAEXOASS : [F:HRDAE]DNAEXOASS=len(mess(0,2522,1)) : Endif    :# non concerné
 If ![F:HRDAE]DNAAGS    : [F:HRDAE]DNAAGS=1                      : Endif    :# Assujetti AGS
 [F:HRDAE]STACTR=2
 If [F:HRDAE]XITGRD<>""
   Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
   GSOCIETE=[F:CPY]CPY
   GCURLEG=[F:CPY]LEG
  Call SIMPLEREAD([F:HRDAE]XITGRD,GCURLEG,GERRHRM) From SUBHRXGD
  If !GERRHRM
    If [F:HRXGD]POLEMP=2 | [F:HRXGD]CODMVT="LA" : # Motif Assedic ou Licenciement
     [F:HRDAE]XITFNL = 2
    Endif
  Else
    GMESSAGE=mess(4,10707,1)-"HRXITGRD [HRXGD]"
  Endif
 Endif

 If [F:HRDAE]DNACCP=0 & [F:HRDAE]NUMCCP="" : [F:HRDAE]DNACCP=4 : Endif
 If [F:HRDAE]TYPLNK>0 : [F:HRDAE]LNK=2 : Else [F:HRDAE]LNK=1 : Endif

 [F:HRDAE]DNACATSPE="100"
 [F:HRDAE]ETRTIM="0800"
 [F:HRDAE]RPTBUL= func AFNC.PARAM("NOMRPTBUL",[F:FCY]FCY)
 [F:HRDAE]PROPRF=[F:FCY]PRF
 [F:HRDAE]ETRSRV=[F:FCY]SRV

 GPOINT = "IMPDADS" : Gosub ENTREE From EXEFNC

 Default File [HRDAE]
 Gosub MENU1

 # Emploi unique
 If [F:HRDAE]SEVCTR=1
  Filter [HRCTR] Where REFNUM=[L]REFNUM & CTRDAT=[F:HRDAE]CTRDAT
  Read [HRCTR]CTR0 First
  Filter [HRCTR]
  If !fstat & MAJ=1
   [L]CTR    = [F:HRCTR]CTRNUM
   [L]NBRLIG = [F:HRCTR]NUMLIG
   [F:HRCTR]   = [F:HRDAE]
   [F:HRCTR]CTRNUM = [L]CTR
   [F:HRCTR]NUMLIG = [L]NBRLIG
   Rewrite [HRCTR]
   If fstat
    [V]GOK=0
    Call FSTA("CTR") From GLOCK
    Return
   Endif
  #Tentive de création (Car MAJ=0) d'une fiche contrat avec même chrono (car emploi unique) et même date (car !fstat)
  Elsif !fstat
    #Import impossible : des contrats sont déjà crées pour le salarié XXXX (no ctr + date)
    Call ECR_TRACE(mess(45,10711,1)-[L]REFNUM-[L]CTR-num$([F:HRDAE]CTRDAT),1) From GESECRAN
    [V]GOK=0 : Return
  Else
   If [L]CTR=""
    Call NUMERO([F:TCA]CODNUM(4),[F:FCY]FCY,[F:ARM]CLED1,"",CTR,I) From SUBANM
    If I
     Call ECR_TRACE(mess(4,10702,1)-[F:TCA]CODNUM(4),1) From GESECRAN : # Erreur sur compteur
     [V]GOK=0 : Return
    Endif
   Else
    Filter [HRCTR] Where REFNUM=[L]REFNUM & ETRFCY=[F:HRDAE]ETRFCY
    Read [HRCTR]CTR0 Last
    If fstat
     Filter [HRCTR] Where REFNUM=[L]REFNUM
     Read [HRCTR]CTR0 Last
    Endif
    Filter [HRCTR]
    [L]CTR = [F:HRCTR]CTRNUM
   Endif
   [F:HRDAE]CTRNUM = [L]CTR
   [F:HRDAE]NUMLIG = [L]NBCTR
   If dim([F:HRDAE]CREUSR)>0
    [F:HRDAE]CREUSR = [V]GUSER
    [F:HRDAE]CREDAT = date$
    [F:HRDAE]CRETIM = time
   Endif
   Write [HRDAE]
   If fstat
    [V]GOK=0
    Call FSTA("DAE") From GLOCK
    Return
   Endif
  Endif

 Else

  # Emploi multiple
  Filter [HRCTR] Where REFNUM=[L]REFNUM & CTRDAT=[F:HRDAE]CTRDAT & CTRGRD=[F:HRDAE]CTRGRD & ETRFCY=[F:HRDAE]ETRFCY & JOB=[F:HRDAE]JOB
&& NATCON=[F:HRDAE]NATCON & XITGRD=[F:HRDAE]XITGRD & XITDAT=[F:HRDAE]XITDAT
  Read [HRCTR]CTR0 First
  Filter [HRCTR]
  If !fstat & MAJ=1
   [L]CTR    = [F:HRCTR]CTRNUM
   [L]NBRLIG = [F:HRCTR]NUMLIG
   [F:HRCTR] = [F:HRDAE]
   [F:HRCTR]CTRNUM = [L]CTR
   [F:HRCTR]NUMLIG = [L]NBRLIG
   Rewrite [HRCTR]
   If fstat
     [V]GOK=0
     Call FSTA("CTR") From GLOCK
     Return
    Endif
  Else
   If [L]CTR<>""
    # Chevauchement des dates de contrats => Création d'un chrono
    Filter [HRCTR] Where REFNUM=[L]REFNUM & ETRFCY=[F:HRDAE]ETRFCY
&&  ([F:HRCTR]XITDAT>=[F:HRDAE]CTRDAT | [F:HRCTR]XITDAT=[0/0/0]) & ([F:HRCTR]CTRDAT<=[F:HRDAE]XITDAT | [F:HRDAE]XITDAT=[0/0/0])
    Read [HRCTR]CTR0 First
    Filter [HRCTR]
   Endif
   # Chevauchement ou nouveau contrat dans la structure DADSU
   If !fstat |  [L]CTR=""
    Call NUMERO([F:TCA]CODNUM(4),[F:FCY]FCY,[F:ARM]CLED1,"",CTR,I) From SUBANM
    If I
     Call ECR_TRACE(mess(4,10702,1)-[F:TCA]CODNUM(4),1) From GESECRAN : # Erreur sur compteur
     [V]GOK=0 : Return
    Endif
    [F:HRDAE]CTRNUM = [L]CTR
    [F:HRDAE]NUMLIG = 1
    If dim([F:HRDAE]CREUSR)>0 : # 60895
     [F:HRDAE]CREUSR = [V]GUSER
     [F:HRDAE]CREDAT = date$
     [F:HRDAE]CRETIM = time
    Endif
    Write [HRDAE]
   Else
    # Les périodes sont consécutives: On regarde si code TDS du motif d'entrée crée un chrono contrat
    ##Read [ADI]CODE=10386;[F:HRDAE]CTRGRD
    Read [HRCGD]HRCGD0=[F:HRDAE]CTRGRD;GCURLEG
    ##Read [ADI]CODE=10607;[F:ADI]A1
    Read [ADI]CODE=10607;[F:HRCGD]CODN4H
    If [F:ADI]N1=2 | fstat
     Call NUMERO([F:TCA]CODNUM(4),[F:FCY]FCY,[F:ARM]CLED1,"",CTR,I) From SUBANM
     If I
      Call ECR_TRACE(mess(4,10702,1)-[F:TCA]CODNUM(4),1) From GESECRAN : # Erreur sur compteur
      [V]GOK=0 : Return
     Endif
     [F:HRDAE]CTRNUM = [L]CTR
     [F:HRDAE]NUMLIG = 1
     If dim([F:HRDAE]CREUSR)>0 : # 60895
      [F:HRDAE]CREUSR = [V]GUSER
      [F:HRDAE]CREDAT = date$
      [F:HRDAE]CRETIM = time
     Endif
     Write [HRDAE]
    Else
     Filter [HRCTR] Where REFNUM=[L]REFNUM & ETRFCY=[F:HRDAE]ETRFCY & CTRDAT<[F:HRDAE]CTRDAT
     Read [HRCTR]CTR0 Last
     Filter [HRCTR]
     If !fstat
      [F:HRDAE]CTRNUM = [F:HRCTR]CTRNUM
      [F:HRDAE]NUMLIG = [F:HRCTR]NUMLIG +1
     Else
      Call NUMERO([F:TCA]CODNUM(4),[F:FCY]FCY,[F:ARM]CLED1,"",CTR,I) From SUBANM
      If I
       Call ECR_TRACE(mess(4,10702,1)-[F:TCA]CODNUM(4),1) From GESECRAN : # Erreur sur compteur
       [V]GOK=0 : Return
      Endif
      [F:HRDAE]CTRNUM = [L]CTR
      [F:HRDAE]NUMLIG = 1
     Endif
     If dim([F:HRDAE]CREUSR)>0
      [F:HRDAE]CREUSR = [V]GUSER
      [F:HRDAE]CREDAT = date$
      [F:HRDAE]CRETIM = time
     Endif
     Write [HRDAE]
    Endif
    If fstat
     [V]GOK=0
     Call FSTA("DAE") From GLOCK
     Return
    Endif
   Endif
  Endif
 Endif
Endif
Return

#-------------------------------------------------------------------------------

$MAJ
Trbegin [ECT],[HRCTR]
 For [HRCTR]CTR0(2)
  I = 0
  For [HRCTR]CTR0
   I +=1
   [F:HRCTR]NUMLIG = I
   Rewrite [HRCTR]
   If fstat
    [V]GOK=0
    Call FSTA("CTR") From GLOCK
    Break 2
   Endif
  Next
  Readlock [F:ECT]ECT0=[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM
  If fstat=1
   [V]GOK=0
   Call FSTA("ECT") From GLOCK
   Break
  Elsif !fstat
   [F:ECT]FCY    = [F:HRCTR]ETRFCY
   [F:ECT]PRF    = [F:HRCTR]PROPRF
   [F:ECT]SRV    = [F:HRCTR]ETRSRV
   [F:ECT]NBRCTR = [F:HRCTR]NUMLIG
   If dim([F:ECT]UPDUSR)>0 : # 60895
    [F:ECT]UPDUSR = [V]GUSER
    [F:ECT]UPDDAT = date$
    [F:ECT]UPDTIM = time
   Endif
   Rewrite [ECT]
  Else
   Raz [F:ECT]
   [F:ECT]REFNUM = [F:HRCTR]REFNUM
   [F:ECT]CTRNUM = [F:HRCTR]CTRNUM
   [F:ECT]FCY    = [F:HRCTR]ETRFCY
   [F:ECT]PRF    = [F:HRCTR]PROPRF
   [F:ECT]SRV    = [F:HRCTR]ETRSRV
   [F:ECT]NBRCTR = [F:HRCTR]NUMLIG
   If dim([F:ECT]CREUSR)>0 : # 60895
    [F:ECT]CREUSR = [V]GUSER
    [F:ECT]CREDAT = date$
    [F:ECT]CRETIM = time
   Endif
   Write [ECT]
  Endif
  If fstat
   [V]GOK=0
   Call FSTA("ECT") From GLOCK
   Break
  Endif
 Next
 If [V]GOK<=0 : Goto AB_MAJ: Endif
 For [ID]ID0
  Filter [HRCTR] Where REFNUM=[F:ID]REFNUM
  [F:ID]NBRCTR = rowcount([F:HRCTR])
  Filter [HRCTR]
  Rewrite [ID]
  If fstat
   [V]GOK=0
   Call FSTA("ID") From GLOCK
   Break
  Endif
 Next
 If [V]GOK<=0 : Goto AB_MAJ: Endif
Commit
Return

$AB_MAJ
Rollback
Return

#-------------------------------------------------------------------------------
$ACCIDENT
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(func AFNC.MES2(mess(56,10711,1),left$([F:ARM]CLEA5,2),right$([F:ARM]CLEA5,3))
&             ,0) From GESECRAN
#              Import risque AT de section $1$ et de code $2$

Filter [WAC] Where CODRSK=right$([F:ARM]CLEA5,3) & SCTFCY=left$([F:ARM]CLEA5,2)
Read [WAC]WAC0 First
Filter [WAC]
If !fstat & [M:ITDS]FLGWAC<>2
 Call ECR_TRACE(mess(33,10711,1)-[F:WAC]CODWAC,1) From GESECRAN
 #              Risque AT non importé : Code risque déjà existant XXX
 Return
Elsif !fstat
 MAJ=1 : # Mise à jour
Else
 MAJ=0 : # Création
Endif

Raz [L]RATWAC, [F:WAC]
For [LNK]CLE(2)
 Raz [F:WAR]
 For [LNK]CLE
  Gosub AFFECTE
 Next
 If [F:WAR]RATWAC<>[L]RATWAC
  [L]RATWAC    =[F:WAR]RATWAC
  [F:WAR]CODWAC=[F:ARM]CLEA5
  [F:WAR]DATWAC=[F:ARM]CLED1
  Readlock [WAR2]WAR0=[F:WAR]CODWAC;[F:WAR]DATWAC
  If fstat=1
   GOK  =-1
   GLOCK="$TRVACCRAT"-[F:WAR]CODWAC-num$([F:WAR]DATWAC)
   Break
  Elsif !fstat
   [F:WAR2]RATWAC = [F:WAR]RATWAC
   Rewrite [WAR2]
  Else
   Raz [F:WAR2]
   [F:WAR2] = [F:WAR]
   Write [WAR2]
  Endif
  If fstat
   [V]GOK=0
   Call FSTA("WAR2") From GLOCK
   Break
  Endif
 Endif
Next
If [V]GOK<1 : Return : Endif

[F:WAC]CODWAC=[F:ARM]CLEA5
Default File [WAC]
Gosub MENU1
If MAJ=0
 Write [WAC]
Else
 Rewrite [WAC]
Endif
If fstat
 [V]GOK=0
 Call FSTA("WAC") From GLOCK
 Return
Endif

If MAJ=0
 Call ECR_TRACE(func AFNC.MES1(mess(32,10711,1),[F:WAC]CODWAC),0) From GESECRAN
 #              Création risque AT de code $1$
Else
 Call ECR_TRACE(func AFNC.MES1(mess(62,10711,1),[F:WAC]CODWAC),0) From GESECRAN
 #              Mise à jour risque AT de code $1$
Endif
Return

#-------------------------------------------------------------------------------
$AFFECTE
[L]AFFOK=0
Gosub AFFECTE_COMMUN
If ![L]AFFOK : Gosub AFFECTE_SUITE : Endif
Return

$AFFECTE_COMMUN
Case [F:ARM]CLEA1
When "S41.G01.00.005","S40.G01.00.005"
