 [L]AFFOK=1
When "S56.G01.00.006"
 If val([F:ATT]TXT)=1 : [F:HRDAE]BUICODASS=2 : Else : [F:HRDAE]BUICODASS=1 : Endif
 [L]AFFOK=1
When "S56.G01.00.007"
 [F:HRDAE]BUICODSAL=val([F:ATT]TXT)
 [L]AFFOK=1
When "S56.G01.00.009"
 [F:HRDAE]BUICODHRS=val([F:ATT]TXT)
 [L]AFFOK=1
When "S56.G01.00.021"
 [F:HRDAE]BUICODJOB=func ATABDIV(403,"A1",[F:ATT]TXT)
 [L]AFFOK=1
When "S66.G01.00.015","S56.G01.00.015"                                                    :#N4DS
 Case [F:ATT]TXT
  When "90"    : [F:HRDAE]BUISTAPAY=4
  When Default : [F:HRDAE]BUISTAPAY=val([F:ATT]TXT)
 Endcase
 [L]AFFOK=1
When "S66.G01.00.022","S56.G01.00.022"                                                    :#N4DS
 [F:HRDAE]BUIRETPRV=val([F:ATT]TXT)
 [L]AFFOK=1
When "S56.G01.00.026"
 [F:HRDAE]BUICODQLY=func ATABDIV(404,"A1",[F:ATT]TXT)
 [L]AFFOK=1
Endcase
Return

#-------------------------------------------------------------------------------
$AFFECTE_SUITE
Case [F:ARM]CLEA1
When "S10.G01.00.001.001"
 [F:FCE]CRN=[F:ATT]TXT
When "S10.G01.00.001.002"
 [F:FCE]CRN+=[F:ATT]TXT
When "S10.G01.00.002"
 [F:FCE]FCYNAM=[F:ATT]TXT
When "S10.G01.00.003.001"
 [F:BPE]BPAADDLIG(0)=[F:ATT]TXT
When "S10.G01.00.003.006"
 [F:BPE]BPAADDLIG(1)=[F:ATT]TXT
When "S10.G01.00.003.007"
 [F:BPE]CODSEE=[F:ATT]TXT
When "S10.G01.00.003.009"
 [F:BPE]BPAADDLIG(2)=[F:ATT]TXT
 [F:BPE]CTY=[F:ATT]TXT                            :#N4DS (.009 = .012)
When "S10.G01.00.003.010","S10.G01.00.003.016"    :#N4DS
 [F:BPE]POSCOD=[F:ATT]TXT
When "S10.G01.00.003.012"
 [F:BPE]CTY=[F:ATT]TXT
When "S10.G01.00.003.013"
 [F:BPE]CRY=[F:ATT]TXT
When "S10.G01.01.001.001"
 [F:AIN]CNTTTL=val([F:ATT]TXT)
When "S10.G01.01.001.002"
 K=instr(1,[F:ATT]TXT,' ')
 If K
  [F:AIN]CNTLNA=seg$([F:ATT]TXT,1,K-1)
  [F:AIN]CNTFNA=seg$([F:ATT]TXT,K+1,len([F:ATT]TXT))
 Else
  [F:AIN]CNTLNA=[F:ATT]TXT
 Endif
When "S10.G01.01.002"
 [F:CNT]CNTMSS=func ATABDIV(906,"A1",[F:ATT]TXT)
When "S20.G01.00.001"
 [F:CPY]CRN=[F:ATT]TXT
When "S20.G01.00.002"
 [F:CPY]CPYNAM=[F:ATT]TXT
When "S20.G01.00.008"
 [F:FCS]CRN=[F:ARM]CLEA2+[F:ATT]TXT
When "S20.G01.00.009.001"
 [F:BPS]BPAADDLIG(0)=[F:ATT]TXT
When "S20.G01.00.009.006"
 [F:BPS]BPAADDLIG(1)=[F:ATT]TXT
When "S20.G01.00.009.007"
 [F:BPS]CODSEE=[F:ATT]TXT
When "S20.G01.00.009.009"
 [F:BPS]BPAADDLIG(2)=[F:ATT]TXT
 [F:BPS]CTY=[F:ATT]TXT
When "S20.G01.00.009.010","S20.G01.00.009.016"
 [F:BPS]POSCOD=[F:ATT]TXT
When "S20.G01.00.009.012"
 [F:BPS]CTY=[F:ATT]TXT
When "S20.G01.00.009.013"
 [F:BPS]CRY=[F:ATT]TXT
When "S20.G01.00.010","S20.G05.00.010"
 [F:FCD]CRN=[F:ARM]CLEA2+[F:ATT]TXT
When "S20.G05.00.012.001"
 [F:BPD]BPAADDLIG(0)=[F:ATT]TXT
When "S20.G05.00.012.006"
 [F:BPD]BPAADDLIG(1)=[F:ATT]TXT
When "S20.G05.00.012.007"
 [F:BPD]CODSEE=[F:ATT]TXT
When "S20.G05.00.012.009"
 [F:BPD]BPAADDLIG(2)=[F:ATT]TXT
 [F:BPD]CTY=[F:ATT]TXT
When "S20.G05.00.012.010","S20.G05.00.012.016"
 [F:BPD]POSCOD=[F:ATT]TXT
When "S20.G05.00.012.012"
 [F:BPD]CTY=[F:ATT]TXT
When "S20.G05.00.012.013"
 [F:BPD]CRY=[F:ATT]TXT
When "S30.G01.00.001"
 If [F:ATT]TXT<>left$([F:ID]NUMSSC,13)
  [F:ID]NUMSSC=[F:ATT]TXT
 Endif
When "S30.G01.00.002"
 [F:ID]OLDNAM=[F:ATT]TXT
When "S30.G01.00.004"
 [F:ID]NAM=[F:ATT]TXT
When "S30.G01.00.003"
 [F:ID]SRN=[F:ATT]TXT
When "S30.G01.00.007"
 [F:ID]CIV=val([F:ATT]TXT)
 If [F:ID]CIV>1 : [F:ID]SEX=2 : Else [F:ID]SEX=1 : Endif
When "S30.G01.00.008.001"
 K = len(toupper(ctrans(vireblc(ctrans([F:ATT]TXT,"'.-",""),4))))
 If toupper(ctrans(vireblc(ctrans([F:ATT]TXT,"'.-",""),4)))<>left$(toupper(ctrans(vireblc(ctrans([F:ID]ADD1,"'.-",""),4))),K)
  [F:ID]ADD1=[F:ATT]TXT
 Endif
When "S30.G01.00.008.006"
 K = len(toupper(ctrans(vireblc(ctrans([F:ATT]TXT,"'.-",""),4))))
 If toupper(ctrans(vireblc(ctrans([F:ATT]TXT,"'.-",""),4)))<>left$(toupper(ctrans(vireblc(ctrans([F:ID]ADD2,"'.-",""),4))),K)
  [F:ID]ADD2=[F:ATT]TXT
 Endif
When "S30.G01.00.008.007"
 [F:ID]CODSEE=[F:ATT]TXT
When "S30.G01.00.008.009"                                                                 :#N4DS (.009 = .012)
 [F:ID]ADD3=[F:ATT]TXT
 [F:ID]CTY=[F:ATT]TXT
When "S30.G01.00.008.010","S30.G01.00.008.016"                                            :#N4DS
 [F:ID]CODPOS=[F:ATT]TXT
When "S30.G01.00.008.012"
 [F:ID]CTY=[F:ATT]TXT
When "S30.G01.00.008.013"
 [F:ID]CRY=[F:ATT]TXT
When "S30.G01.00.009"
 [F:ID]DATBRN=func GDAT([F:ATT]TXT)
When "S30.G01.00.010"
 [F:ID]CTYBRN=[F:ATT]TXT
When "S30.G01.00.011"
 [F:ID]DEPBRN=[F:ATT]TXT
When "S30.G01.00.012"
 [F:ID]CRYNAMBRN=[F:ATT]TXT
When "S30.G01.00.013"
 [F:ID]NTTNAM=[F:ATT]TXT
When "S30.G10.05.001","S41.G01.00.019","S30.G01.00.019","S40.G10.00.019"                  :#N4DS
 [V]GOK=1     : # Juste pour ne pas avoir d'erreur dans la trace car info utilisées
                # mais non importées directement (Matricules)

When "S41.G01.00.001","S40.G01.00.001"                                                    :#N4DS
 [F:HRDAE]CTRDAT=func GDAT([F:ATT]TXT)
 [F:HRDAE]DEGMAL=3         # valeur par défaut si S41.G01.00.018.007 absente...
 [F:HRDAE]WRKFLGADD=2      # valeur par défaut si S41.G01.00.060.001 absente...
 NBCTR +=1
 IAVN=-1 : IEXS=-1
When "S41.G01.00.002.001","S40.G01.00.002.001"                                            :#N4DS
 Read [ADI]CODE=10607;[F:ATT]TXT
 If !fstat
  [F:HRDAE]CTRGRD=[F:ADI]A1
 Else
  [F:HRDAE]CTRGRD=func ATABDIV(386,"A1",[F:ATT]TXT)
 Endif
When "S41.G01.00.004.001","S40.G01.00.004.001"                                            :#N4DS
 If val([F:ATT]TXT)=98    :# ACT (donc pas sorti !)
  [F:HRDAE]XITDAT=[0/0/0]
  [F:HRDAE]XITGRD=""
 Else
  Read [ADI]CODE=10607;[F:ATT]TXT
  If !fstat
   [F:HRDAE]XITGRD=[F:ADI]A2
  Else
   [F:HRDAE]XITGRD=func GROUND_COD("HRXGD","CODN4H",[F:ATT]TXT)
  Endif
 Endif
When "S40.G10.00.005"                                                                     :#N4DS
Case val([F:ATT]TXT)
  When 10 : [F:HRDAE]DNASITADM=1
  When 11 : [F:HRDAE]DNASITADM=2
  When 13 : [F:HRDAE]DNASITADM=3
  When 14 : [F:HRDAE]DNASITADM=4
  When 40 : [F:HRDAE]DNASITADM=5
  When 42 : [F:HRDAE]DNASITADM=6
  When 43 : [F:HRDAE]DNASITADM=7
 Endcase
When "S40.G10.00.006"                                                                     :#N4DS
 [F:HRDAE]DNACPYSTG   =val([F:ATT]TXT)
When "S40.G10.00.008.003"                                                                :#N4DS
  [F:HRDAE]NUMOBJ=[F:ATT]TXT
When "S40.G10.00.037"                                                                    :#N4DS
 Case val([F:ATT]TXT)
  When 90 : [F:HRDAE]TYPLNK=5
  When Default : [F:HRDAE]TYPLNK=val([F:ATT]TXT)
 Endcase
When "S40.G10.05.012.005"
 [F:HRDAE]NUMCON=[F:ATT]TXT
When "S40.G10.05.012.006"
 [F:HRDAE]ENDCON=func GDAT([F:ATT]TXT)
When "S40.G10.06.001.001"
 If val([F:ATT]TXT)<4                                                                     :#N4DS
  [F:HRDAE]DNACCP=val([F:ATT]TXT)
 Elsif val([F:ATT]TXT)=4                                                                  :#N4DS
  [F:HRDAE]DNACCP=5
 Endif
When "S40.G10.06.001.001","S66.G01.00.001","S56.G01.00.001"                               :#N4DS
 [F:HRDAE]NUMCCP=[F:ATT]TXT
 If [F:ARM]CLEA1="S56.G01.00.001" : [F:HRDAE]DNACCP=1 : Endif
When "S40.G15.00.001"
 Case val([F:ATT]TXT)
  When 10 : [F:HRDAE]DNACODTIM = 3
  When 12 : [F:HRDAE]DNACODTIM = 9
  When 20 : [F:HRDAE]DNACODTIM = 5
  When 21 : [F:HRDAE]DNACODTIM = 6
  When 31 : [F:HRDAE]DNACODTIM = 1
  When 32 : [F:HRDAE]DNACODTIM = 2
  When 33 : [F:HRDAE]DNACODTIM = 7
  When 34 : [F:HRDAE]DNACODTIM = 8
  When 36 : [F:HRDAE]DNACODTIM = 4
  When Default : [F:HRDAE]DNACODTIM = 3
 Endcase
When "S40.G15.05.013.001"                                                                 :#N4DS
  Case val([F:ATT]TXT)
   When 10 : [F:HRDAE]DNACODMOD=1
   When 20 : [F:HRDAE]DNACODMOD=2
   When 21 : [F:HRDAE]DNACODMOD=3
   When Default : [F:HRDAE]DNACODMOD=4
  Endcase
 If [F:HRDAE]TYPJOB=0 :
  Case val([F:ATT]TXT)
   When 10    : [F:HRDAE]TYPJOB=1
   When 20,21 : [F:HRDAE]TYPJOB=2
   When Default :  [F:HRDAE]TYPJOB=12    :#Autre
  Endcase
 Endif
When "S41.G01.00.025","S40.G25.00.025"                                                    :#N4DS
 [F:WAC]SCTFCY=[F:ATT]TXT
 [F:HRDAE]RSKWRK=[F:ATT]TXT
When "S41.G01.00.026","S40.G25.00.026"                                                    :#N4DS
 [F:WAC]CODRSK=[F:ATT]TXT
 [F:HRDAE]RSKWRK+=[F:ATT]TXT
 [F:WAC]DESWAC=mess(1,10708,1)-":"-[F:ATT]TXT
When "S41.G01.00.027","S40.G25.00.027"                                                    :#N4DS
 [F:WAC]CODOFC=2
When "S41.G01.00.028","S40.G25.00.028"                                                    :#N4DS
 [F:WAR]RATWAC=val([F:ATT]TXT)/100


When "S45.G01.01.009","S45.G01.00.002"                                                    :#N4DS
 Case [F:ATT]TXT
  When "90"    : [F:ID]SITFAM=8
  When "91"    : [F:ID]SITFAM=9
  When Default : [F:ID]SITFAM=val([F:ATT]TXT)
 Endcase
When "S45.G01.01.010","S45.G05.00.004","S45.G01.00.006","S66.G01.00.013","S56.G01.00.013"        :#N4DS
 [F:ID]CHD=val([F:ATT]TXT)
 If [F:ARM]CLEA1="S45.G01.00.006" : NBREVE=0 : Endif
When "S45.G05.05.001"
 [F:HRDAE]EVECTRCOD(NBREVE)=[F:ATT]TXT
When "S45.G05.05.002"
 [F:HRDAE]EVECTRDAT(NBREVE)=func GDAT([F:ATT]TXT)
 NBREVE+=1
When "S45.G05.25.002"
 [F:HRDAE]NBRPEO2=val([F:ATT]TXT)
When "S45.G05.25.003"
 [F:HRDAE]NBRPEO3=val([F:ATT]TXT)
When "S45.G05.25.004"
 [F:HRDAE]NBRPEO4=val([F:ATT]TXT)
When "S48.G10.00.015"
 [F:HRDAE]DNAACTASS = val([F:ATT]TXT)
When "S48.G10.00.016"
 Case val([F:ATT]TXT)
  When 1,2     : [F:HRDAE]DNAEXOASS = val([F:ATT]TXT)
  When 3       : [F:HRDAE]DNAEXOASS = 4
  When Default : [F:HRDAE]DNAEXOASS = 3
 Endcase
When "S48.G10.00.017"
 [F:HRDAE]DNAAGS = val([F:ATT]TXT)
When "S66.G01.00.002.001","S56.G01.00.002.001"
 Case val([F:ATT]TXT)
  When 3     : [F:HRDAE]BUICODTIM = 2
  When 7     : [F:HRDAE]BUICODTIM = 3
  When 9     : [F:HRDAE]BUICODTIM = 4
  When Default: [F:HRDAE]BUICODTIM = 1
 Endcase
When "S66.G01.00.010","S56.G01.00.010"                                                    :#N4DS
 [F:HRDAE]HRSWEK=val([F:ATT]TXT)
When "S66.G01.00.012","S56.G01.00.012"                                                    :#N4DS
 Case [F:ATT]TXT
  When "99"    : [F:ID]SITFAM=8
  When Default : [F:ID]SITFAM=val([F:ATT]TXT)
 Endcase
When "S80.G01.00.001.001"                                                                 :#Supprimé en N4DS
 If [F:FCY]CRN="" : [F:FCS]CRN=[F:ATT]TXT : Endif
When "S80.G01.00.001.002"
 If [F:FCY]CRN="": [F:FCS]CRN=[F:ARM]CLEA2+[F:ATT]TXT : Endif
When "S80.G01.00.002"
If [F:FCY]FCYNAM="" :  [F:FCS]FCYNAM=[F:ATT]TXT : Endif
When "S80.G01.00.005"
 [F:FCY]TAXWAG=3-val([F:ATT]TXT)
When "S80.G01.00.006"
 If [F:FCY]NAF="" : [F:FCS]NAF=[F:ATT]TXT : Endif
When "S80.G01.00.007.001"
 Case val([F:ATT]TXT)
  When 1 : [F:FCY]REGPRH=2
  When 2 : [F:FCY]REGPRH=3
  When 3 : [F:FCY]REGPRH=1
  When 4 : [F:FCY]REGPRH=4
 Endcase
When "S80.G01.00.007.002"
 Case val([F:ATT]TXT)
  When 1 : [F:FCY]SECPRH=2
  When 2 : [F:FCY]SECPRH=3
  When 3 : [F:FCY]SECPRH=1
  When 4 : [F:FCY]SECPRH=4
 Endcase
When "S80.G62.05.001","S80.G62.05.003"                                                    :#N4DS
 [F:FCY]FLGAPP=3-val([F:ATT]TXT)
When "S80.G62.10.001"
 [F:FCY]FLGFOR=3-val([F:ATT]TXT)
When Default
Onerrgo ERREUR
 Read [FTD]FTD0=[L]YEAFTD;[F:ARM]CLEA1
 If !fstat
  Case [F:FTD]TYPREC
   When 1 : Assign [F:FTD]XPSRES With vireblc(evalue([F:FTD]XPSRES)-[F:ATT]TXT,2)
   When 2 : Assign [F:FTD]XPSRES With val([F:ATT]TXT)
   When 3 : Assign [F:FTD]XPSRES With func GDAT([F:ATT]TXT)
  Endcase
 Endif
Onerrgo
Endcase
Return

$ERREUR
Call ECR_TRACE([F:ARM]CLEA1-mess(93,100,1)-num$(errn)-errmes$(errn),0) From GESECRAN
Resume

#-------------------------------------------------------------------------------
Funprog NUMREQ()

If !clalev([F:AES]) : Local File AESPION [AES] : Endif

End uniqid([AES])

#-------------------------------------------------------------------------------
Funprog CODENT()

Local Char     CODE([V]GLONFCY)
Local Shortint I

Local File FACILITY [FCY], COMPANY [CPY]

Repeat
 I+=1
 [L]CODE=format$("N0:"+num$(min(3,[V]GLONFCY))+"#",I)
 Look [FCY]FCY0=[L]CODE
 If fstat : Look [CPY]CPY0=[L]CODE : Endif
Until fstat

End [L]CODE

Funprog GROUND_COD(OBJECT,FIELDCOD,VALEUR)
Value Char OBJECT ()
Value Char FIELDCOD ()
Value Char VALEUR ()
Local Char CODE

Raz [L]CODE

If clalev([F:HRGD])=0
  If OBJECT="HRXGD" : Local File HRXITGRD [HRGD] : Endif
  If OBJECT="HRCGD" : Local File HRCTRGRD [HRGD] : Endif
Endif

Filter [F:HRGD] Where LEG=GCURLEG & left$(evalue([L]FIELDCOD),len(VALEUR)+1)=[L]VALEUR+"|"
Read[F:HRGD] First
Filter [F:HRGD]
If !fstat
  [L]CODE=[F:HRGD]COD
Else
  Filter [F:HRGD] Where LEG=GCURLEG & evalue([L]FIELDCOD+'="'+[L]VALEUR+'"')
  Read[F:HRGD] First
  Filter [F:HRGD]
  If !fstat
    [L]CODE=[F:HRGD]COD
  Endif
Endif

Close Local File [HRGD]
End [L]CODE

#-------------------------------------------------------------------------------
Funprog ATABDIV(NUMTAB,COL,VALEUR)
Value Integer NUMTAB
Value Char COL ()
Value Char VALEUR ()
Local Char CODE

Raz [L]CODE
#If [L]NUMTAB=359
# Filter [ADI] Where NUMTAB=[L]NUMTAB & left$(evalue([L]COL),len(VALEUR)+1)=[L]VALEUR+"|"
# Read [ADI] First
# Filter [ADI]
# #60779
# If fstat
#  Filter [ADI] Where NUMTAB=[L]NUMTAB & evalue([L]COL+'="'+[L]VALEUR+'"')
#  Read [ADI] First
#  Filter [ADI]
# Endif
# # fin 60779
#Else
 Filter [ADI] Where NUMTAB=[L]NUMTAB & evalue([L]COL+'="'+[L]VALEUR+'"')
 Read [ADI] First
 Filter [ADI]
#Endif
# : End [F:ADI]CODE : Else End "" : Endif
 If !fstat
  [L]CODE = [F:ADI]CODE
 Endif
End [L]CODE

#-------------------------------------------------------------------------------
$MENU1
For I=0 To [G]nbzon-1
 If evalue("type([F]"+[G]adxfname(I)+")")=1
  For J=0 To evalue("dim([F]"+[G]adxfname(I)+")")-1
   If evalue("[F]"+[G]adxfname(I)+"(J)")=0
    Assign "[F]"+[G]adxfname(I)+"(J)" With 1
   Endif
  Next
 Else
  Case [G]adxfname(I)
   When "CREUSR" : If !MAJ : [F]CREUSR=[V]GUSER : Endif
   When "CREDAT" : If !MAJ : [F]CREDAT=date$    : Endif
   When "CRETIM" : If !MAJ : [F]CRETIM=time     : Endif
   When "UPDUSR" : If MAJ  : [F]UPDUSR=[V]GUSER : Endif
   When "UPDDAT" : If MAJ  : [F]UPDDAT=date$    : Endif
   When "UPDTIM" : If MAJ  : [F]UPDTIM=time     : Endif
  Endcase
 Endif
Next
Return

#DBA : Comparaison de 2 enregistrements
#-------------------------------------------------------------------------------
Funprog IDENT(REF, ABR)
Value Char REF ()
Value Char ABR ()

Local Libelle I, J

Default File "["+[L]REF+"]"

For I=0 To [G]nbzon-1
 If !find( [G]adxfname(I)
&        , "CREDAT","CRETIM","CREUSR","EXTNUM","EXPNUM","UPDDAT","UPDTIM", "UPDUSR"
&        )
  For J=0 To evalue("dim([F]"+[G]adxfname(I)+")-1")
   If evalue("[F]"+[G]adxfname(I)+"(J)<>[F:"+[L]ABR+"]"+[G]adxfname(I)+"(J)")
    I=0
    Break 2
   Endif
  Next
 Endif
Next

End I

#-------------------------------------------------------------------------------
Funprog GDAT(VALEUR)
Value Char VALEUR

End gdat$(right$([L]VALEUR,5)+mid$([L]VALEUR,3,2)+left$([L]VALEUR,2))

#-------------------------------------------------------------------------------
Subprog PAYS(COD,NOM)
Variable Char COD(), NOM()

Case find("",[L]COD+[L]NOM,[L]COD,[L]NOM)
When 1
 [L]COD=[V]GPAYS
 Read [AXX]AXX0="TABCOUNTRY";"CRYDES";[V]GLANGUE;[L]COD;""
 If !fstat : [L]NOM=[F:AXX]TEXTE : Endif
When 2
 Filter [AXX] Where CODFIC="TABCOUNTRY" & ZONE="CRYDES" & LANGUE=[V]GLANGUE
&                 & toupper(TEXTE)=toupper([L]NOM)
 Read [AXX] First
 Filter [AXX]
 If !fstat : [L]COD=[F:AXX]IDENT1 : Endif
When 3
 Filter [AXX] Where CODFIC="TABCOUNTRY" & ZONE="CRYDES" & LANGUE=[V]GLANGUE
&                 & IDENT1=[L]COD
 Read [AXX] First
 Filter [AXX]
 If !fstat : [L]NOM=[F:AXX]TEXTE : Endif
Endcase

End

#-------------------------------------------------------------------------------
$PAYS2
If [F]CRY="" & [F]CRYNAM="" : [F]CRY=[F:FCY]CRY : Endif
Call PAYS([F]CRY,[F]CRYNAM)
Return

#-------------------------------------------------------------------------------
$TR_IMPORT_VRA
GOK=1
Trbegin [VPR],[VPH]
 Gosub IMPORT_VRA
 If [V]GOK=-1
  Rollback
  Call ROLL From GLOCK
  If [V]GROLL : Return : Else Goto TR_IMPORT_VRA : Endif
 Elsif ![V]GOK
  Rollback
  Return
 Endif
Commit
Delete [ATT] Where NUMREQ=[L]NUMREQ
Delete [ARM] Where NUMREQ=[L]NUMREQ
Return

#-------------------------------------------------------------------------------
$IMPORT_VRA

Raz [F:ARM], [F:ATT]
[F:ARM]NUMREQ=[L]NUMREQ
[F:ARM]CREDAT=date$
[F:ARM]USR   =[V]GUSER
[F:ARM]RPTCOD="TRTIMPTDS"
[F:ATT]NUMREQ=[F:ARM]NUMREQ
[F:ATT]CREDAT=[F:ARM]CREDAT

Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
#Import des cumuls dans les variables de paie
Call ECR_TRACE(mess(147,10702,1),0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

[L]SAVIFS=adxifs
[L]SAVIRS=adxirs
[L]SAVIUM=adxium
adxifs   =","
adxirs   =chr$(13)+chr$(10)
adxium   =[V]GASCII
Openi [L]FICHIER, 0

Repeat
 Rdseq [F:ARM]CLEA1, [F:ATT]TXT
 If fstat : Break : Endif
 [F:ATT]TXT=seg$([F:ATT]TXT,2,len([F:ATT]TXT)-1)

 Case [F:ARM]CLEA1
  When "S20.G01.00.001"
   [F:ARM]CLEA2 =[F:ATT]TXT : # SIREN de l'entreprise
   Raz [F:ARM]CLEN1, [F:ARM]CLEA3, [F:ARM]CLEA4, [F:ARM]CLEA5, [F:ARM]CLED1, I
   Filter [CPY] Where CRN=[F:ATT]TXT : # SIREN de l'entreprise
   Read [CPY] First
   Filter [CPY]
   If !fstat
    Filter [TD1] Where LEV=2 & CPY=[F:CPY]CPY & FLGDNA<>2 & RCVCUM<>""
    Read [TD1]TD10 First
    If !fstat
     I = 2
    Else
     Filter [TD1] Where LEV=1 & CPY="" & FLGDNA<>2 & RCVCUM<>""
     Read [TD1]TD10 First
     If !fstat
      I = 1
     Else
      # Variables de reprise non paramétrées dans l'extraction DADS-U
      Call ECR_TRACE(mess(148,10702,1),1) From GESECRAN
     Endif
    Endif
    Filter [TD1]
   Else
    # Société inexistante
    Call ECR_TRACE([F:ATT]TXT-mess(65,10702,1),1) From GESECRAN
   Endif

  When "S30.G01.00.001"
   [F:ARM]CLEA3 = [F:ATT]TXT :              :#N°ss

  When "S41.G01.00.001","S40.G01.00.001"    :#N4DS
   [F:ARM]CLED1 = func GDAT([F:ATT]TXT)

  When "S41.G01.00.005","S40.G01.00.005"    :#N4DS
   [F:ARM]CLEA4 = [F:ATT]TXT                :#Site du salarié

  When "S90.G01.00.001"
   Raz [F:ARM]CLEA2                         :#Fin enreg entreprise

  When "S41.G01.00.020"                     :#N4DS : /100 inutile car plus en centième !
   [F:ATT]TXT = num$(val([F:ATT]TXT)/100)

  When "S41.G30.36.003"                     :#N4DS : /100 inutile car plus en centième !
   [F:ATT]TXT = num$(val([F:ATT]TXT)/100)

  When "S41.G30.11.001.002"                 :#N4DS : /100 inutile car plus en centième !
   [F:ATT]TXT = num$(val([F:ATT]TXT)/100)

  When "S41.G30.12.002"                     :#N4DS : /100 inutile car plus en centième !
   [F:ATT]TXT = num$(val([F:ATT]TXT)/100)

  When "S41.G30.12.003"                     :#N4DS : /100 inutile car plus en centième !
   [F:ATT]TXT = num$(val([F:ATT]TXT)/100)

  When "S66.G01.00.014"                     :#N4DS : /100 inutile car plus en centième !
   [F:ATT]TXT = num$(val([F:ATT]TXT)/100)

  Endcase

 If [F:ARM]CLEA2<>"" & I>0
  Read [FTD]FTD0=[L]YEAFTD;[F:ARM]CLEA1
  If !fstat
   If I=1
    Filter [TD1] Where LEV=1 & CPY="" & FLGDNA<>2 & FLD=[F:FTD]XPSRES & RCVCUM<>""
   Elsif I=2
    Filter [TD1] Where LEV=2 & CPY=[F:CPY]CPY & FLGDNA<>2 & FLD=[F:FTD]XPSRES & RCVCUM<>""
   Endif
   Read [TD1]TD11 First
   Filter [TD1]
   If !fstat
    [F:ARM]CLEA5   = [F:TD1]RCVCUM : # Code reprise
    [F:ARM]CLEN1   = I             : # 1=Dossier 2=Entreprise
    [F:ARM]NUMLIG += 1
    [F:ATT]LIG     = [F:ARM]NUMLIG
    Write [ARM]
    If fstat
     [V]GOK=0
     Call FSTA("ARM") From GLOCK
     Break
    Endif
    Write [ATT]
    If fstat
     [V]GOK=0
     Call FSTA("ATT") From GLOCK
     Break
    Endif
   Endif
  Endif
 Endif
Until 0

Openi
adxifs=[L]SAVIFS
adxirs=[L]SAVIRS
adxium=[L]SAVIUM

If [V]GOK<1 : Return : Endif

# Mise à jour des variables de paie
Call TEMPON(mess(41,10709,1)) From GESECRAN

Link [ARM] With [ATT]ATT0=NUMREQ;NUMLIG As [LNK]

Filter [LNK] Where NUMREQ=[L]NUMREQ Order By Key CLE=CLEA3;CLEA4;NUMLIG : # Salarié/site
For [LNK] CLE(1)
 Filter [ID] Where left$(NUMSSC,13)=left$([F:ARM]CLEA3,13)
 Read [ID]ID0 First
 Filter [ID]
 If fstat
  # Matricule inexistant
  Call ECR_TRACE([F:ARM]CLEA3-mess(83,10702,1),1) From GESECRAN
 Else
  Call ECR_TRACE(string$(70," "),0) From GESECRAN
  Call ECR_TRACE([F:ID]REFNUM-[F:ID]NAM-[F:ID]SRN,0) From GESECRAN
  For [LNK]CLE(2)
   Gosub VARIA
   If [V]GOK<1 : Break 2 : Endif
  Next
 Endif
Next
Filter [LNK]
If [V]GOK<1 : Return : Endif

Return

#-------------------------------------------------------------------------------
$VARIA
## Contrôles
#62945
#If [F:FCY]CRN<>[F:ARM]CLEA2+[F:ARM]CLEA4 : # On change de site
 Filter [FCY] Where CRN=[F:ARM]CLEA2+[F:ARM]CLEA4
 Read [F:FCY]FCY0 First
 Filter [FCY]
 If fstat
  # Site inexistant
  Call ECR_TRACE([F:ARM]CLEA4-mess(19,116,1),1) From GESECRAN
  Return
 Endif
#Endif
# Récupération du numéro de contrat tel qu'il a été créé lors de l'import des données salarié
Filter [HRCTR] Where REFNUM=[F:ID]REFNUM & CTRDAT<=[F:ARM]CLED1 & ETRFCY=[F:FCY]FCY
Read [HRCTR] CTR0 Last
Filter [HRCTR]
If fstat
 # Pas de contrat valide sur la période et sur le site
 Call ECR_TRACE(mess(160,10702,1)-[F:FCY]FCY,1) From GESECRAN
 Return
Endif
#62945
XCTR = [F:HRCTR]CTRNUM

# Récupération de la fiche contrat à la date DATPAY pour ce numéro de contrat
#62945
#Filter [HRCTR] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT<=[M:ITDS]DATPAY
Filter [HRCTR] Where REFNUM=[F:ID]REFNUM & CTRNUM=XCTR & CTRDAT<=[M:ITDS]DATPAY
Read [HRCTR] CTR0 Last
Filter [HRCTR]
If fstat
 # Pas de contrat valide sur la période
 Call ECR_TRACE(mess(158,10702,1),1) From GESECRAN
 Return
Endif

LESITE = [F:HRCTR]ETRFCY
Call PERIO(LESITE,[F:ID]REFNUM) From SUBPEO
Read [PEO]PEO0(1) = LESITE
If fstat<=2
 Filter [PEO] Where FCY=LESITE & PYRDAT=[M:ITDS]DATPAY
Else
 Filter [PEO] Where FCY="" & PYRDAT=[M:ITDS]DATPAY
Endif
Read [PEO]PEO0 First
Filter [PEO]
If fstat
 #Date de paie inexistante en période d'extraction
 #68748 -> avertissement non bloquant
 # Call ECR_TRACE(LESITE-mess(159,10702,1),1) From GESECRAN
 #Return
 Call ECR_TRACE(LESITE-mess(159,10702,1),-1) From GESECRAN
 #
Endif

## Mise à jour tables [VPH] et [VPR]
If OLDREFNUM<>[F:ID]REFNUM & OLDCTRNUM<>[F:HRCTR]CTRNUM
 Raz TABVRA
 MATRI  = [F:ID]REFNUM
 CTR    = [F:HRCTR]CTRNUM
 DATMAT = [M:ITDS]DATPAY
 Gosub LECEMP From WPDEFTABLE
 Read [FCY]FCY0=[F:HRCTR]ETRFCY
 Case [F:ARM]CLEN1
  When 1 : CRITERE = 'LEV=1 & CPY="" & FLGDNA=1 & RCVCUM<>""'
  When 2 :
   Filter [CPY] Where CRN=[F:ARM]CLEA2 : # SIREN de l'entreprise
   Read [CPY] First
   Filter [CPY]
   CRITERE = 'LEV=2 & CPY="'+[F:CPY]CPY+'" & FLGDNA=1 & RCVCUM<>""'
 Endcase
 For [TD1] Where evalue(CRITERE)
  For [RCT]RCT0 Where COD=[F:TD1]RCVCUM
   If [F:RCT]CRI="" | evalue([F:RCT]CRI)=1
    I= find("", TABVRA)
    TABVRA(I)=[F:TD1]RCVCUM+[F:RCT]VRA
    Delete [VPR] Where EMP=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & DAT=[M:ITDS]DATPAY & VARCOD=[F:RCT]VRA
    If fstat=1 | fstat>5
     GOK=-1 : GLOCK="$VALPRV" : Break 2
    Endif
   Endif
  Next
 Next
 NBRTABVRA = find("", TABVRA)
 If GOK<=0 : Return : Endif
 OLDREFNUM = [F:ID]REFNUM
 OLDCTRNUM = [F:HRCTR]CTRNUM
Endif

If NBRTABVRA=0 : Return : Endif

Raz [VPH]
Readlock [VPH]VPH0=[F:ID]REFNUM;[F:HRCTR]CTRNUM
If fstat=1
 GOK=-1 : GLOCK="$VALPRVH"-[F:ID]REFNUM-[F:HRCTR]CTRNUM
 Return
Elsif !fstat
 [F:VPH]FCY    = [F:HRCTR]ETRFCY
 [F:VPH]SRV    = [F:HRCTR]ETRSRV
 [F:VPH]CODACS = [F:ID]CODACS
 [F:VPH]UPDDAT = date$
 [F:VPH]UPDUSR = GUSER
 [F:VPH]UPDTIM = time
 Rewrite [VPH]
Else
 [F:VPH]EMP    = [F:ID]REFNUM
 [F:VPH]CTRNUM = [F:HRCTR]CTRNUM
 [F:VPH]FCY    = [F:HRCTR]ETRFCY
 [F:VPH]SRV    = [F:HRCTR]ETRSRV
 [F:VPH]CODACS = [F:ID]CODACS
 [F:VPH]CREDAT = date$
 [F:VPH]CREUSR = GUSER
 [F:VPH]CRETIM = time
 Write [VPH]
Endif
If fstat
 GOK=0 : Call FSTA("VPH") From GLOCK
 Return
Endif

For [LNK]CLE(3)
 Raz [VPR]
 For I=1 To NBRTABVRA
  If left$(TABVRA(I),len([F:ARM]CLEA5))=[F:ARM]CLEA5
   VALVRA = right$(TABVRA(I),len([F:ARM]CLEA5)+1)
   Readlock [VPR]VPR0=[F:ID]REFNUM;[F:HRCTR]CTRNUM;[M:ITDS]DATPAY;VALVRA
   If fstat=1
    GOK=-1 : GLOCK="$VALPRV"-[F:ID]REFNUM-[F:HRCTR]CTRNUM-num$([M:ITDS]DATPAY)-VALVRA
    Break
   Elsif !fstat
    [F:VPR]VARVAL += val([F:ATT]TXT)
    [F:VPR]UPDDAT  = date$
    [F:VPR]UPDUSR  = GUSER
    [F:VPR]UPDTIM  = time
    Rewrite [VPR]
   Else
    # Mise à jour variable
    Call ECR_TRACE(mess(25,10709,1)-VALVRA,0) From GESECRAN
    [F:VPR]EMP    = [F:ID]REFNUM
    [F:VPR]CTRNUM = [F:HRCTR]CTRNUM
    [F:VPR]VARCOD = VALVRA
    [F:VPR]DAT    = [M:ITDS]DATPAY
    [F:VPR]VARVAL = val([F:ATT]TXT)
    [F:VPR]CREDAT = date$
    [F:VPR]CREUSR = GUSER
    [F:VPR]CRETIM = time
    Write [VPR]
   Endif
   If fstat
    GOK=0 : Call FSTA("VPR") From GLOCK
    Break
   Endif
  Endif
 Next
Next
If GOK<=0 : Return : Endif

Return

$SORTIE
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

################################################################################
#
# Etiquettes écran TRTIMPTDS [ITDS]
#
################################################################################

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR

If [V]GBATCH & [L]VALEUR<2
 [V]GMESSAGE=mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat     =2
Endif

End

########################################
Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR

If [L]VALEUR=2
 Actzo [ITDS] FIL
Else
 Call SET_NAMCLI([M:ITDS]FIL) From ORDSYS
 Grizo [ITDS] FIL
Endif

End

########################################
Subprog C_FIL(VALEUR)
Variable Char    VALEUR()

Local Integer OK

Call C_NOMEXP(VALEUR,"tds") From TRTDUE
If mkstat=2 : End : Endif

Call EXISTE(filpath([V]GDIRBQR,[L]VALEUR,"tds",0),[L]OK) From ORDSYS
If ![L]OK
 [V]GMESSAGE=mess(101,100,1) : # Fichier inexistant
 mkstat     =2
Endif

End

########################################
Subprog AM_CPY(VALEUR)
Variable Integer VALEUR

If [L]VALEUR=2
 Effzo [ITDS]EMP
 Call GRISE_EMP([M:ITDS]EMP)
Endif
Call GRISE_CPY([L]VALEUR)
Call GRISE_BLOC("CPY",VALEUR)
End

########################################
Subprog GRISE_CPY(VALCPY)
Value Integer VALCPY

If VALCPY=2
 Actzo [ITDS]FLGCPY
Else
 Effzo [ITDS]FLGCPY
 Diszo [ITDS]FLGCPY
Endif
Affzo [ITDS]FLGCPY
End

########################################
Subprog AM_FCY(VALEUR)
Variable Integer VALEUR

If [L]VALEUR=2
 Effzo [ITDS]EMP
 Call GRISE_EMP([M:ITDS]EMP)
Endif
Call GRISE_FCY([L]VALEUR)
Call GRISE_BLOC("FCY",VALEUR)
End

########################################
Subprog GRISE_FCY(VALFCY)
Value Integer VALFCY

If VALFCY=2
 Actzo [ITDS]FLGFCY
Else
 Effzo [ITDS]FLGFCY
 Diszo [ITDS]FLGFCY
Endif
Affzo [ITDS]FLGFCY
End

########################################
Subprog AM_WAC(VALEUR)
Variable Integer VALEUR

If [L]VALEUR=2 & ![V]GPAYE
 [V]GMESSAGE=mess(48,10711,1) : # Le module paye n'est pas activé
 mkstat     =2
Endif
Call GRISE_WAC([L]VALEUR)
Call GRISE_BLOC("WAC",VALEUR)
End

########################################
Subprog GRISE_WAC(VALWAC)
Value Integer VALWAC

If VALWAC=2
 Actzo [ITDS]FLGWAC
Else
 Effzo [ITDS]FLGWAC
 Diszo [ITDS]FLGWAC
Endif
Affzo [ITDS]FLGWAC
End

########################################
Subprog C_EMP(VALEUR)
Variable Integer VALEUR

If [L]VALEUR<2 : End : Endif

#Read [TCA]TCA0=9 : # Module tronc commun
#If [F:TCA]CODNUM(0)=""
# [V]GMESSAGE=mess(3,10702,1) : # Compteur matricule non défini
# mkstat     =2
# End
#Elsif [F:TCA]CODNUM(2)=""
# [V]GMESSAGE=mess(39,10701,1) : # Compteur contrat non défini
# mkstat=2
# End
#Endif

#Need to have GCURLEG and GSOCIETE on line
Call LECTCA(9,STAT) From SUBTCA
If [F:TCA]CODNUM(2)
 [V]GMESSAGE=mess(3,10702,1) : # Compteur matricule non défini
 mkstat     =2
 End
Elsif [F:TCA]CODNUM(4)=""
 [V]GMESSAGE=mess(39,10701,1) : # Compteur contrat non défini
 mkstat=2
 End
Endif

Filter [CAC] Where TYP=1
Read [CAC]CAC0 First
Filter [CAC]
If fstat | [F:CAC]ACCCOD=""
 [V]GMESSAGE=mess(47,10711,1) : # Code comptable non défini pour le type salarié
 mkstat     =2
 End
Endif

Effzo [ITDS] CPY, FCY
Call GRISE_CPY([M:ITDS]CPY)
Call GRISE_FCY([M:ITDS]FCY)

End

########################################
Subprog AM_EMP(VALEUR)
Variable Integer VALEUR
Call GRISE_EMP([L]VALEUR)
Call GRISE_BLOC("EMP",VALEUR)
End

########################################
Subprog GRISE_EMP(VALEMP)
Value Integer VALEMP
# 62644 : FLGNUM
If VALEMP=2
 Actzo [ITDS]FLGEMP
 Actzo [ITDS]FLGNUM
Else
 Effzo [ITDS]FLGEMP
 Diszo [ITDS]FLGEMP
 Effzo [ITDS]FLGNUM
 Diszo [ITDS]FLGNUM
Endif
Affzo [ITDS]FLGEMP, FLGNUM
End

######################################################################################
Subprog AM_VRA(VALEUR)
Variable Integer VALEUR
Call GRISE_VRA(VALEUR)
End

######################################################################################
Subprog GRISE_VRA(VALEUR)
Value Integer VALEUR

If VALEUR=2
 Actzo [ITDS]DATPAY
 Grizo [ITDS] 15
Else
 Effzo [ITDS]DATPAY
 Diszo [ITDS]DATPAY
 Actzo [ITDS]CPY,FCY,WAC,EMP
Endif
Affzo [ITDS]
End


######################################################################################
Subprog GRISE_BLOC(ZON,VALEUR)
Value Char    ZON
Value Integer VALEUR

If VALEUR=2 | (ZON<>"EMP" & [M]EMP=2) | (ZON<>"WAC" & [M]WAC=2) | (ZON<>"FCY" & [M]FCY=2) | (ZON<>"CPY" & [M]CPY=2)
 Effzo [ITDS]20
 Grizo [ITDS]20
 Affzo [ITDS]20
Else
 Actzo [ITDS]20
 Affzo [ITDS]20
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran TRTIMPTDS) 03/08/2010 14:29:27 (DBA)
######################################################################################
Subprog AM_FLGYEA(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M:ITDS]EMP=2    :# Obligatoire pour importer...
 Affzo [M:ITDS]EMP
 Grizo 15-20
 Actzo [M:ITDS]FICYEA : Actzo [M:ITDS]FLGRAZ
Else
 Effzo [M:ITDS]FICYEA : Grizo [M:ITDS]FICYEA
 Effzo [M:ITDS]FLGRAZ : Grizo [M:ITDS]FLGRAZ
 Call GRISE_CPY([M:ITDS]CPY)
 Call GRISE_FCY([M:ITDS]FCY)
 Call GRISE_EMP([M:ITDS]EMP)
 Call GRISE_WAC([M:ITDS]WAC)
 Actzo [M:ITDS]VRA
 Call GRISE_VRA([M:ITDS]VRA)
Endif
End

Subprog C_FICYEA(VALEUR)
Variable Char    VALEUR()
Filter [FTD] Where YEA=VALEUR
Read [FTD]FTD0 First
If fstat
 GMESSAGE = "Paramétrage de la structure inexistant pour l'année" -VALEUR
 mkstat=2 : End
Else
 [M:ITDS]FICVER=[F:FTD]VER
 [M:ITDS]FLGRAZ=1
Endif
End


######################################################################################
