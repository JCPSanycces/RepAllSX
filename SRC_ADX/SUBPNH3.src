#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque PDSYPNH

######################################################################################
## Clic droit Pièce sur la réception
######################################################################################
Subprog IB_NBPTH

  GBOUT2 = mess(117,198,1)
  If GPILNAV>1 Then
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If find("GESPTH",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
  Endif
End

Subprog B2_NBPTH
Local Integer NOL

  If clalev([F:PTH])=0 : Local File PRECEIPT [PTH] : Endif 
  Filter [F:PTH]
  GCONSULT = 2
  Local Char SAV_VCRNUM
  NOL = nolign-1
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  SAV_VCRNUM = [M:PNH3]PTHNUM(NOL)
  Call OBJET("PTH",[M:PNH3]PTHNUM(NOL),"") From GOBJET
  [M:PNH3]PTHNUM(NOL) = SAV_VCRNUM 

  GCONSULT = 0
End

######################################################################################
## Clic droit Pièce sur l'avoir
######################################################################################
Subprog IB_NBPIH

  GBOUT2 = mess(2,267,1)
  If GPILNAV>1 Then
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If find("GESPIH",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
  Endif
End

Subprog B2_NBPIH
Local Integer NOL

  If clalev([F:PIH])=0 : Local File PINVOICE [PIH] : Endif 
  Filter [F:PIH]
  GCONSULT = 2
  Local Char SAV_VCRNUM
  NOL = nolign-1
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  SAV_VCRNUM = [M:PNH3]NUM(NOL)
  Call OBJET("PIH",[M:PNH3]NUM(NOL),"2") From GOBJET
  [M:PNH3]NUM(NOL) = SAV_VCRNUM 

  GCONSULT = 0
End


######################################################################################
## Clic droit Pièce sur la commande
######################################################################################
Subprog IB_NBPOH
Local Integer NOL

  GBOUT2 = mess(191,198,1)
  If GPILNAV>1 Then
    NOL = nolign-1
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If [M:PNH3]POHTYP(NOL)=1 and find("GESPOH",GNAVIG(1..GPILNAV)) Then GBOUT2="" 
    Elsif [M:PNH3]POHTYP(NOL)=2 and find("GESPOC",GNAVIG(1..GPILNAV)) Endif
  Endif
End

Subprog B2_NBPOH
Local Integer NOL

  If clalev([F:POH])=0 : Local File PORDER [POH] : Endif 
  Filter [F:POH]
  GCONSULT = 2
  Local Char SAV_VCRNUM
  NOL = nolign-1
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  SAV_VCRNUM = [M:PNH3]POHNUM(NOL)
  If [M:PNH3]POHTYP(NOL)=1 Then
    Call OBJET("POH",[M:PNH3]POHNUM(NOL),"") From GOBJET
  Elsif [M:PNH3]POHTYP(NOL)=2 Then
    Call OBJET("POC",[M:PNH3]POHNUM(NOL),"") From GOBJET
  Endif
  [M:PNH3]POHNUM(NOL) = SAV_VCRNUM 

  GCONSULT = 0
End


######################################################################################

