Onevent BEFORE_INPUT Call AS_EMP(zc) From W1CLF1
Onevent AFTER_CHANGE Gosub AMM_EMP From W1CLF1
Return

Subprog AS_EMP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_EMP(VALEUR) From SUBCLF
If mkstat=2
 [M]EMP(INDIC) = VALEUR
 Affzo EMP(INDIC) : mkstat = 2
Endif
Onkey   2 Titled GBOUTS Call S_EMP(zc) From W1CLF1
Onkey 144 Titled GBOUTP Call P_EMP(zc) From W1CLF1
Onkey 146 Titled GBOUTA Call SA_EMP(zc) From W1CLF1
Gosub _AFF
End

Subprog C_EMP(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "EMP" : GZNUM = 16058 : Endif
If !GWEBSERV
 If !mkstat
  ## Action CONTEMP
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTEMP"
  PARMSK(1) = [M]CPY
  PARMSK(2) = [M]FCY
  PARMSK(3) = [M]SRV
  PARMSK(4) = ""
  PARMSK(5) = ""
  PARMSK(6) = [M]LEG
  Call S_LIS_CHAR(VALEUR,PARMSK,"","DIVPAYE","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "EMP" : GZNUM = 16058 : Endif
 Endif
Endif
If !mkstat
 ## Action DROITEMP
 Call DROIT(VALEUR,"","",[M]EMP) From DIVPAYE
 If mkstat : GERR = 1 : GZONE = "EMP" : GZNUM = 16058 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("EML","",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "EMP" : GZNUM = 16058 : Endif
  If !mkstat
   ## Action STD
   Call C_EMP(VALEUR) From SUBCLF
   If mkstat : GERR = 1 : GZONE = "EMP" : GZNUM = 16058 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_EMP
Call AM_EMP(zc)
If !mkstat & GOBJET
 zoncou = "EMP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_EMP(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_EMP(VALEUR) From SUBCLF
If mkstat : GERR = 1 : GZONE = "EMP" : GZNUM = 16058 : Endif
Gosub _AFF
End

Subprog S_EMP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "EML"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_EMP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "EML"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_EMP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("EML",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_CTR
Onevent CONTROL Call C_CTR(zc) From W1CLF1
Onevent BEFORE_INPUT Call AS_CTR(zc) From W1CLF1
Onevent AFTER_CHANGE Gosub AMM_CTR From W1CLF1
Return

Subprog AS_CTR(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_CTR(VALEUR) From SUBCLF
If mkstat=2
 [M]CTR(INDIC) = VALEUR
 Affzo CTR(INDIC) : mkstat = 2
Endif
Onkey   2 Titled GBOUTS Call S_CTR(zc) From W1CLF1
Onkey 144 Titled GBOUTP Call P_CTR(zc) From W1CLF1
Onkey 146 Titled GBOUTA Call SA_CTR(zc) From W1CLF1
Gosub _AFF
End

Subprog C_CTR(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CTR" : GZNUM = 5481 : Endif
If !mkstat
 ## Action CONTVCR
 Call CONTVCR(VALEUR) From TRTDIV
 If mkstat : GERR = 1 : GZONE = "CTR" : GZNUM = 5481 : Endif
 If !GWEBSERV
  If !mkstat
   ## Action CONTCTR
   Call CONTCTR(VALEUR,"") From DIVPAYE
   If mkstat : GERR = 1 : GZONE = "CTR" : GZNUM = 5481 : Endif
  Endif
 Endif
Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("CTR","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CTR" : GZNUM = 5481 : Endif
 If !mkstat
  ## Action STD
  Call C_CTR(VALEUR) From SUBCLF
  If mkstat : GERR = 1 : GZONE = "CTR" : GZNUM = 5481 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CTR
Call AM_CTR(zc)
If !mkstat & GOBJET
 zoncou = "CTR" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CTR(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CTR(VALEUR) From SUBCLF
If mkstat : GERR = 1 : GZONE = "CTR" : GZNUM = 5481 : Endif
Gosub _AFF
End

Subprog S_CTR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELEMPCTR
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMPCTR"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AS_CTR" : PROGSUB = "SUBCLF" : PROGSPE = "SPECLF" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = ""
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = ""
 PARMSK(6) = ""
 PARMSK(7) = ""
 PARMSK(8) = ""
 PARMSK(9) = ""
 PARMSK(10) = ""
 PARMSK(11) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELEMPCTR","SELMAT","") From GACTION
 ACTION = "BS_CTR" : PROGSUB = "SUBCLF" : PROGSPE = "SPECLF" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_CTR(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CTR"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CTR(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("CTR",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$CHG_STY
Return


