#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CLF1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:11"
A_USER  = "DOC"
A_STAMP = "20181109230311"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CLF1 [CLF1]
Gosub HORODAT
Local Inpbox "CLF1" From GFONCTION At A_STAMP With A_WINDPREV Mask [CLF1] As [SIM_]
Grizo [CLF1]5
Grizo [CLF1]10
Grizo [CLF1]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CLF1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=74 : Y1(1)=3 : Y2(1)=26
X1(2)=1 : X2(2)=74 : Y1(2)=27 : Y2(2)=28
Return

$ON_TYPCLD
Onevent INIT_AREA Call D_TYPCLD(zc) From W1CLF1
Return

Subprog D_TYPCLD(VALEUR)
Variable Integer VALEUR
If varinit([M]TYPCLD,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_PERIOD
Onevent INIT_AREA Call D_PERIOD(zc) From W1CLF1
Return

Subprog D_PERIOD(VALEUR)
Variable Char    VALEUR()
If varinit([M]PERIOD,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10702","") From SUBADI
Endif
Gosub _AFF
End

$ON_ZPERIOD
Onevent BEFORE_AREA Gosub AV_ZPERIOD From W1CLF1
Return

$AV_ZPERIOD
Call LECTEXTRA(zc,"ATABDIV","LNGDES","10702",num$([M]PERIOD(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_NBLIG
Onevent BEFORE_INPUT Call AS_NBLIG From W1CLF1
Onevent AFTER_CHANGE Gosub AMM_NBLIG From W1CLF1
Return

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_NBLIG From SUBCLF
Gosub _AFF
End

$AMM_NBLIG
Call AM_NBLIG
If !mkstat & GOBJET
 zoncou = "NBLIG" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_NBLIG
Local Decimal BASPAG
## Action STD
Call AM_NBLIG From SUBCLF
If mkstat : GERR = 1 : GZONE = "NBLIG" : GZNUM = 0 : Endif
Gosub _AFF
End

$ON_LEV
Onevent CONTROL Call C_LEV(zc) From W1CLF1
Onevent INIT_AREA Call D_LEV(zc) From W1CLF1
Onevent BEFORE_INPUT Call AS_LEV(zc) From W1CLF1
Return

Subprog D_LEV(VALEUR)
Variable Integer VALEUR
If varinit([M]LEV,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_LEV(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_LEV(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "LEV" : GZNUM = 5230 : Endif
If !mkstat
 ## Action STD
 Call C_LEV(VALEUR) From SUBCLF
 If mkstat : GERR = 1 : GZONE = "LEV" : GZNUM = 5230 : Endif
Endif
Gosub _AFF
End

$ON_POP
Onevent CONTROL Call C_POP(zc) From W1CLF1
Onevent BEFORE_INPUT Call AS_POP(zc) From W1CLF1
Onevent AFTER_CHANGE Gosub AMM_POP From W1CLF1
Return

Subprog AS_POP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_POP(VALEUR) From SUBCLF
If mkstat=2
 [M]POP(INDIC) = VALEUR
 Affzo POP(INDIC) : mkstat = 2
Endif
Onkey   2 Titled GBOUTS Call S_POP(zc) From W1CLF1
Onkey 144 Titled GBOUTP Call P_POP(zc) From W1CLF1
Onkey 146 Titled GBOUTA Call SA_POP(zc) From W1CLF1
Gosub _AFF
End

Subprog C_POP(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
If !mkstat
 ## Action CONTPOP
 Call CONTPOP(VALEUR,"") From SUBPOP
 If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("POP","",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
  If !mkstat
   ## Action STD
   Call C_POP(VALEUR) From SUBCLF
   If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_POP
Call AM_POP(zc)
If !mkstat & GOBJET
 zoncou = "POP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_POP(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_POP(VALEUR) From SUBCLF
If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
Gosub _AFF
End

Subprog S_POP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPOP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPOP"
 PARMSK(1) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPOP","SUBPOP","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_POP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "POP"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_POP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("POP",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

