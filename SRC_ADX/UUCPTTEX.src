 Endif
 If dim([F:GBS]DESSHO)>0
  Call MAJTEXTRA([F:GBS]DESSHO,"GBAGSCR","SHOTRA",num$([F:GBS]FLGHIS),[F:GBS]COD) From ATEXTRA
 Endif

 If NB>GMAXUPDTRS
  ICLE1 = [F:GBS]FLGHIS
  ACLE1 = [F:GBS]COD
  STOP=1
  Break
 Endif

Next

If STOP
 Goto LOOP_GBS
Endif

Close Local File [GBS]
Return


##########################################################################################################
$GFUPSCR
