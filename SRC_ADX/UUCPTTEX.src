Call AFF_VLC(mess(81,125,1),"TABBUDTYP") From GESECRAN: # maj table


Raz STOP
$LOOP_TBU
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:TBU]BUDTYP='"+ACLE1+"' & [F:TBU]COLNUM>"+num$([F:TBU]COLNUM)
Elsif STOP=2
 STOP = 0 
 CRITERE = "[F:TBU]BUDTYP>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif
 
For [TBU]TBU0 Where evalue(CRITERE)

 If dim([F:TBU]DES)>0
  Call MAJTEXTRA([F:TBU]DES,"TABBUDTYP","DESTRA",[F:TBU]BUDTYP,"0") From ATEXTRA
 Endif
 If dim([F:TBU]DESSHO)>0
  Call MAJTEXTRA([F:TBU]DESSHO,"TABBUDTYP","SHOTRA",[F:TBU]BUDTYP,"0") From ATEXTRA
 Endif

 If NB>GMAXUPDTRS
  ACLE1 = [F:TBU]BUDTYP
  ICLE  = [F:TBU]COLNUM
  STOP=1
  Break
 Endif

Next

If STOP
 Goto LOOP_TBU
Endif

Close Local File [TBU]
Return

