##########################################################################################################
$GACCCODE
Local File =[L]ADOS+".GACCCODE"  [CAC]

Call ECR_TIME(mess(81,125,1)-": GACCCODE") From DOSSUB : # maj table
Call AFF_VLC(mess(81,125,1),"GACCCODE") From GESECRAN: # maj table

Local Integer FLGOK : Raz FLGOK

Raz STOP
$LOOP_CAC
Raz NB

If STOP = 1
 STOP = 2 
 CRITERE = "[F:CAC]TYP="+num$(ICLE1)+" & [F:CAC]ACCCOD='"+ACLE1+"' & [F:CAC]COA>'"+ACLE2+"'"
Elsif STOP = 2 
 STOP = 3
 CRITERE = "[F:CAC]TYP="+num$(ICLE1)+" & [F:CAC]ACCCOD>'"+ACLE1+"'"
Elsif STOP = 3 
 STOP = 0 
 CRITERE = "[F:CAC]TYP>"+num$(ICLE1)
Else
 CRITERE = "1=1"
Endif
 
For [CAC]CAC0 Where evalue(CRITERE)

 If dim([F:CAC]DES)>0
  Call MAJTEXTRA([F:CAC]DES,"GACCCODE","DESTRA",num$([F:CAC]TYP),[F:CAC]ACCCOD) From ATEXTRA
 Endif

 If !FLGOK & dim([F:CAC]TYPCAR)>0 & [F:CAC]TYPCAR=""
  FLGOK = 1
 Endif 

 If NB>GMAXUPDTRS
  ICLE1 = [F:CAC]TYP
  ACLE2 = [F:CAC]ACCCOD
  ACLE3 = [F:CAC]COA
  STOP=1
  Break
 Endif

Next

If STOP
 Goto LOOP_CAC
Endif

########################################
If [L]FLGOK
 
 Call ECR_TIME(mess(81,125,1)-": GACCCODE-TYPCAR") From DOSSUB : # maj table
 Call AFF_VLC(mess(81,125,1),"GACCCODE-TYPCAR") From GESECRAN: # maj table

 Raz STOP
 $LOOP_CAC_TYP
 Raz NB
 If STOP = 1
  STOP = 2 
  CRITERE = "[F:CAC]TYP="+num$(ICLE1)+" & [F:CAC]ACCCOD='"+ACLE1+"' & [F:CAC]COA>'"+ACLE2+"'"
 Elsif STOP = 2 
  STOP = 3
  CRITERE = "[F:CAC]TYP="+num$(ICLE1)+" & [F:CAC]ACCCOD>'"+ACLE1+"'"
 Elsif STOP = 3 
  STOP = 0 
  CRITERE = "[F:CAC]TYP>"+num$(ICLE1)
 Else
  CRITERE = "1=1"
 Endif
 
 Trbegin [CAC]
 GOK = 1
 For [CAC]CAC0 Where evalue(CRITERE)

   Call ECR_TRACE("GACCODE"-num$([F:CAC]TYP)-[F:CAC]ACCCOD-[F:CAC]COA-[F:CAC]TYPCAR-CRITERE,-1) From GESECRAN

  If dim([F:CAC]TYPCAR)>0 & [F:CAC]TYPCAR=""
   [F:CAC]TYPCAR = num$([F:CAC]TYP)
   Rewrite [CAC]
   If fstat
    GOK = 0 : Call ERREUR("GACCCODE"-[F:CAC]ACCCOD,1) From DOSDIC
   Else
    Call ECR_TRACE("GACCODE"-num$([F:CAC]TYP)-[F:CAC]ACCCOD-[F:CAC]COA,-1) From GESECRAN
   Endif
  Endif

  NB+=1
  If NB>GMAXUPDTRS
   ICLE1 = [F:CAC]TYP
   ACLE1 = [F:CAC]ACCCOD
   ACLE2 = [F:CAC]COA
   STOP=1
   Break
  Endif
 Next
 
 Commit
 If STOP
  Goto LOOP_CAC_TYP
 Endif
Endif

Close Local File [CAC]
Return

