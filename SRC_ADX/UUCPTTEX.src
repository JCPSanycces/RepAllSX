Call AFF_VLC(mess(81,125,1),"GFUPSCR") From GESECRAN : # maj table


Raz STOP
$LOOP_GFP
Raz NB
If STOP
 STOP = 0 
 CRITERE = "[F:GFP]COD>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif
 
For [GFP]GFP0 Where evalue(CRITERE)

 If dim([F:GFP]DES)>0
