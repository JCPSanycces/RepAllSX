Raz STOP
$LOOP_GAD
Raz NB
If STOP = 1 
 STOP = 2
 CRITERE = "[F:GAD]COD='"+ACLE1+"' & [F:GAD]LINNUM>"+num$(ICLE)
Elsif STOP = 2
 STOP = 0
 CRITERE = "[F:GAD]COD>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif
 
For [GAD]GAD0 Where evalue(CRITERE)

 If dim([F:GAD]DES)>0
  Call MAJTEXTRA([F:GAD]DES,"GAUTACED","DESTRA",[F:GAD]COD,num$([F:GAD]LINNUM)) From ATEXTRA
 Endif
 If dim([F:GAD]DESSHO)>0
  Call MAJTEXTRA([F:GAD]DESSHO,"GAUTACED","SHOTRA",[F:GAD]COD,num$([F:GAD]LINNUM)) From ATEXTRA
 Endif

 If !FLGOK & dim([F:GAD]LINNUMCAR)>0 & [F:GAD]LINNUMCAR=""
  FLGOK = 1
 Endif 

 If NB>GMAXUPDTRS
  ACLE1 = [F:GAD]COD
  ICLE1 = [F:GAD]LINNUM
  STOP=1
  Break
 Endif

Next

If STOP
 Goto LOOP_GAD
Endif

###############################################

If FLGOK

 Raz STOP
 $LOOP_GAD_TYP
 Raz NB
 If STOP = 1 
  STOP = 2
  CRITERE = "[F:GAD]COD='"+ACLE1+"' & [F:GAD]LINNUM>"+num$(ICLE)
 Elsif STOP = 2
  STOP = 0
  CRITERE = "[F:GAD]COD>'"+ACLE1+"'"
 Else
  CRITERE = "1=1"
 Endif
 
 Trbegin [GAD]
 For [GAD]GAD0 Where evalue(CRITERE)

  If dim([F:GAD]LINNUMCAR)>0 & [F:GAD]LINNUMCAR=""
   [F:GAD]LINNUMCAR = num$([F:GAD]LINNUM)
   Rewrite [GAD]
   If fstat
    GOK = 0 : Call ERREUR("GAUTACED"-[F:GAD]COD,1) From DOSDIC
   Else
   Endif
  Endif

  NB+=1
  If NB>GMAXUPDTRS
   ACLE1 = [F:GAD]COD
   ICLE1 = [F:GAD]LINNUM
   STOP=1
   Break
  Endif

 Next

 Commit
 If STOP
  Goto LOOP_GAD_TYP
 Endif
Endif
Close Local File [GAD]
Return




