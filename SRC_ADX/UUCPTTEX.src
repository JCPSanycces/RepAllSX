##########################################################################################################
$GACCCLS
Local File =[L]ADOS+".GACCCLS"  [CLS]

Call ECR_TIME(mess(81,125,1)-": GACCCLS") From DOSSUB : # maj table
Call AFF_VLC(mess(81,125,1),"GACCCLS") From GESECRAN

Raz STOP
$LOOP_CLS
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:CLS]LEG='"+ACLE1+"' & [F:CLS]CLSCOD>'"+ACLE2+"'"
Elsif STOP = 2
 STOP = 0 
 CRITERE = "[F:CLS]LEG>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif
 
For [CLS]CLS0 Where evalue(CRITERE)

 If dim([F:CLS]CLSNAM)>0
  Call MAJTEXTRA([F:CLS]CLSNAM,"GACCCLS","DESTRA",[F:CLS]LEG,[F:CLS]CLSCOD) From ATEXTRA
 Endif

 If NB>GMAXUPDTRS
  ACLE1 = [F:CLS]LEG
  ACLE2 = [F:CLS]CLSCOD
  STOP=1
  Break
 Endif

Next

If STOP
 Goto LOOP_CLS
Endif

Close Local File [CLS]
Return

