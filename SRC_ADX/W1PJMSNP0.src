Subprog SA_OPPNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "PIM"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_OPPNUM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("PIM",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZOPPNUM
Onevent BEFORE_AREA Gosub AV_ZOPPNUM From W1PJMSNP0
Return

$AV_ZOPPNUM
Call LECTEXTRA(zc,"PIMPL","PIMDESAXX",num$([M]OPPNUM(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_SNPCOD
Onevent CONTROL Call C_SNPCOD(zc) From W1PJMSNP0
Return

Subprog C_SNPCOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTVCR
 Call CONTVCR(VALEUR) From TRTDIV
 If mkstat : GERR = 1 : GZONE = "SNPCOD" : GZNUM = 1003359 : Endif
Endif
Gosub _AFF
End

$ON_DESAXX
Onevent INIT_AREA Call D_DESAXX(zc) From W1PJMSNP0
Onevent BEFORE_INPUT Call AS_DESAXX(zc) From W1PJMSNP0
Onevent CONTROL Call C_DESAXX(zc) From W1PJMSNP0
Return

Subprog IB_DESAXX(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BOUTTEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BOUTTEXTRA"
 Call S_AFF_CHAR(VALEUR,PARMSK,"","ATEXTRA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog D_DESAXX(VALEUR)
Variable Char    VALEUR()
If varinit([M]DESAXX,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"PJMSNPH","DESAXX",[M:PSNP0]SNPCOD,"") From ATEXTRA
Endif
Gosub _AFF
End

Subprog AS_DESAXX(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(9637,GBOUT1) From OBJDIV
Call IB_DESAXX(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_DESAXX(zc) From W1PJMSNP0
Gosub _AFF
End

Subprog C_DESAXX(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DESAXX" : GZNUM = 8 : Endif
Gosub _AFF
End

Subprog B1_DESAXX(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATEXTRA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_DESAXX" : PROGSUB = "SUBPJMSNP" : PROGSPE = "SPEPJMSNP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "PJMSNPH"
 PARMSK(2) = "DESAXX"
 PARMSK(3) = [M:PSNP0]SNPCOD
 PARMSK(4) = ""
 Call SAISIE_CHAR(VALEUR,PARMSK,"ATEXTRA","ATEXTRA","") From GSAISIE
 ACTION = "BB1_DESAXX" : PROGSUB = "SUBPJMSNP" : PROGSPE = "SPEPJMSNP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_SHOWGRP
Onevent INIT_AREA Call D_SHOWGRP(zc) From W1PJMSNP0
Onevent CONTROL Call C_SHOWGRP(zc) From W1PJMSNP0
Onevent BEFORE_INPUT Call AS_SHOWGRP(zc) From W1PJMSNP0
Onevent AFTER_CHANGE Gosub AMM_SHOWGRP From W1PJMSNP0
Return

Subprog D_SHOWGRP(VALEUR)
Variable Char    VALEUR()
If varinit([M]SHOWGRP,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"388","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_SHOWGRP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"388") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_SHOWGRP(zc) From W1PJMSNP0
Onkey   2 Titled GBOUTS Call S_SHOWGRP(zc) From W1PJMSNP0
Onkey 144 Titled GBOUTP Call P_SHOWGRP(zc) From W1PJMSNP0
Onkey 146 Titled GBOUTA Call SA_SHOWGRP(zc) From W1PJMSNP0
If VALEUR="" : Call INIADI(VALEUR,"388") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_SHOWGRP(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "SHOWGRP" : GZNUM = 54294 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"388","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "SHOWGRP" : GZNUM = 54294 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"388",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "SHOWGRP" : GZNUM = 54294 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_SHOWGRP
Call AM_SHOWGRP(zc)
If !mkstat & GOBJET
 zoncou = "SHOWGRP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_SHOWGRP(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZSHOWGRP)")>indice
 [M]SHOWGRP(indice) = VALEUR
 Affzo ZSHOWGRP(indice)
Endif
Gosub _AFF
End

