#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMSNP0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:51"
A_USER  = "DOC"
A_STAMP = "20181109230551"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMSNP0 [PSNP0]
Gosub HORODAT
Local Inpbox "PJMSNP0" From GFONCTION At A_STAMP With A_WINDPREV Mask [PSNP0] As [SIM_]
Grizo [PSNP0]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PSNP0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=10
Return

$ON_OPPNUM
Onevent AFTER_CHANGE Gosub AMM_OPPNUM From W1PJMSNP0
Onevent BEFORE_INPUT Call AS_OPPNUM(zc) From W1PJMSNP0
Onevent CONTROL Call C_OPPNUM(zc) From W1PJMSNP0
Return

Subprog IB_OPPNUM(VALEUR)
Variable Char    VALEUR()
## Action IBUPJMPIM
Call IBUPIM(VALEUR) From PJMSELECT
Gosub _AFF
End

Subprog AS_OPPNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(14664,GBOUT1) From OBJDIV
Call TEXTE(14664,GBOUT2) From OBJDIV
Call TEXTE(55763,GBOUT3) From OBJDIV
Call TEXTE(1001026,GBOUT4) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Call IB_OPPNUM(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_OPPNUM(zc) From W1PJMSNP0
Onkey 130 Titled GBOUT2 Call B2_OPPNUM(zc) From W1PJMSNP0
Onkey 131 Titled GBOUT3 Call B3_OPPNUM(zc) From W1PJMSNP0
Onkey 132 Titled GBOUT4 Call B4_OPPNUM(zc) From W1PJMSNP0
Onkey   2 Titled GBOUTS Call S_OPPNUM(zc) From W1PJMSNP0
Onkey 144 Titled GBOUTP Call P_OPPNUM(zc) From W1PJMSNP0
Onkey 146 Titled GBOUTA Call SA_OPPNUM(zc) From W1PJMSNP0
Gosub _AFF
End

Subprog C_OPPNUM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 41532 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("PIM","A",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 41532 : Endif
Endif
Gosub _AFF
End

$AMM_OPPNUM
Call AM_OPPNUM(zc)
If !mkstat & GOBJET
 zoncou = "OPPNUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_OPPNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_OPPNUM(VALEUR) From SUBPJMSNP
If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 41532 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZOPPNUM)")>indice
 [M]OPPNUM(indice) = VALEUR
 Affzo ZOPPNUM(indice)
Endif
Gosub _AFF
End

Subprog S_OPPNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPJMOPP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPJMOPP"
 PARMSK(1) = "0"
 PARMSK(2) = "0"
 PARMSK(3) = ""
 PARMSK(4) = num$([V]CST_ANO)
 PARMSK(5) = "0"
 PARMSK(6) = "[F:PIM]PIMNUM desc"
 PARMSK(7) = ""
 PARMSK(8) = ""
 PARMSK(9) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPJMOPP","PJMSELECT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_OPPNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNPJMPIM
 Call TUNPIM(VALEUR) From PJMSELECT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_OPPNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNPJMOPP
 Call TUNCRM(VALEUR) From PJMSELECT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
