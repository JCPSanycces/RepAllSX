##########################################################################################################
Funprog GET_COUNTRY_PHONE_FMT(SCRY)
Value Char SCRY

Local Char SARENDRE(250)

  # Issue X3-46689 - 2017-07-04 by FGR
  Raz SARENDRE
  If SCRY <> "" Then
    Local File TABCOUNTRY [TCY]
    Read [TCY]TCY0=SCRY
    If !fstat Then
      SARENDRE = [F:TCY]TELFMT
    Endif
  Endif
End SARENDRE

##########################################################################################################
Funprog OL_EXTRACT_PHONE(SCRY, STEL)
Value Char SCRY
Value Char STEL

Local Char SARENDRE(250)
Local Char SFMT(250)
Local Char SFMTALPHA(250)
Local Char SPHONEALPHA(250)
Local Char SPHONEALPHA1(250)
Local Char STELNUM(250)
Local Char SCHAR1(1)
Local Integer NI
Local Integer IPHONELEN

  # Issue X3-46689 - 2017-07-04 by FGR
  Raz SARENDRE
  If STEL <> "" Then
    SFMT = func GET_COUNTRY_PHONE_FMT(SCRY)
    If GTRACE <> "" Then
      Call ECR_TRACE("OL_EXTRACT_PHONE SCRY=" + SCRY - "STEL=" + STEL - "SFMT=" + SFMT, 0) From GESECRAN
    Endif
    # --------------------------------
    # Replace "#" by "X"
    Raz SFMTALPHA
    For NI = 1 To len(SFMT)
      If mid$(SFMT,NI,1) = "#" Then
        SFMTALPHA += "X"
      Else
        SFMTALPHA += mid$(SFMT,NI,1)
      Endif
    Next NI
    # --------------------------------
    # Extract Lenght of the phone number stored in X3 in IPHONELEN
    SPHONEALPHA = format$(SFMTALPHA,string$(100,"a"))
    Raz SPHONEALPHA1
    For NI = 1 To len(SPHONEALPHA)
      If mid$(SPHONEALPHA,NI,1) = "a" Then
        SPHONEALPHA1 += mid$(SPHONEALPHA,NI,1)
      Endif
    Next NI
    IPHONELEN = len(SPHONEALPHA1)
    # --------------------------------
    # extract number of the given phone
    Raz STELNUM
    For NI = 1 To len(STEL)
      SCHAR1 = mid$(STEL,NI,1)
      #If SCHAR1 >= "1" and SCHAR1 <= "9" Then   # Issue X3-82186 - 2018-04-04 by FGR
      If SCHAR1 >= "0" and SCHAR1 <= "9" Then    # Issue X3-82186 - 2018-04-04 by FGR
        STELNUM += SCHAR1
      Endif
    Next NI
    # --------------------------------
    If len(STELNUM) <= IPHONELEN Then
      SARENDRE = STELNUM
    Else
      SARENDRE = right$(STELNUM, len(STELNUM)-IPHONELEN+1)
    Endif
    If GTRACE <> "" Then
      Call ECR_TRACE("OL_EXTRACT_PHONE SARENDRE=" + SARENDRE, 0) From GESECRAN
    Endif
  Endif
End SARENDRE

