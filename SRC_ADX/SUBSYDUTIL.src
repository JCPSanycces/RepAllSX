#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################################################
# Programme de utilitaire pour la synchronisation
#
# SYN_GETBPR     : Recherche code tiers Ă  partir de son libellĂŠ
# SYN_SETBPR     : Renvoi le libellĂŠ du tiers avec codif
# SYN_GETAIN     : Recherche code interlocuteur Ă  partir de son libellĂŠ
# SYN_SETAIN     : Renvoi le libellĂŠ du interlocuteur avec codif
#
# GETDATEFROMCHAR: Transforme une date de type char "AAAAMMJJHHMMSS" en un champs date X3
# GETTIMEFROMCHAR: Transforme une date de type char "AAAAMMJJHHMMSS" en un champs heure X3
# SETDATETIMETOCHAR  : Transforme une date et une heure de type X3 en char "AAAAMMJJHHMMSS"
# DECOD_OTKID    : dĂŠcompose l'identifiant en objet et clĂŠ
# CODE_OTKID     : compose l'identifiant Outlook
# SYN_GETPAYS    : Renvoi le code du pays par rapport Ă  son libellĂŠ ou code
# SYN_SETPAYS    : Renvoi le libellĂŠ du pays en fonction de la langue et du code
# SYN_DECODIFADR : Decompose une chaine adresse en 3 sous chaine adresse
# SYN_CODIFADR   : Compose une chaine Ă  partir des  3 sous chaine adresse
# SYN_TRTTEL     : Traite un numĂŠro de tĂŠlĂŠphone pour enlever son format
# CONCATCLOB     : Prend deux clob regarde si balise OTK existe et si oui concatĂ¨ne les 2
# ADDBALISEOTK   : Rajoute la balise OTK Ă  un CLOB
# FINDLASTREF    : Recherche si une chaine de texte existe renvoi la place de la derniĂ¨re occurence
# ADDBALISEBAP   :rajoute la balise entĂŞte pour un rendez vous
# CLEANCLOBBAP   : enlĂ¨ve la partie entĂŞte d'un clob provenant d'eun rendez-vous Outlook
##########################################################################################################
##########################################################################################################
# Recherche code tiers Ă  partir de son libellĂŠ
# ------------------------------------------------------------
Subprog SYN_GETBPR(SZLIBBPR, SZCODEBPR, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZLIBBPR()
Variable Char SZCODEBPR()
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IFIRSTPOS
Local Integer ILASTPOS
Local Char SZVALEUR(type(SZLIBBPR)-10)
Local Integer IBTROUVE

  IFIRSTPOS = 0
  ILASTPOS = 0
  Raz SZVALEUR
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  IBTROUVE = 0
  Local File BPARTNER [BPR]
  #On regarde si le libellĂŠ ne contient pas le code du tiers
  #Recherche chaine #code#
  IFIRSTPOS = instr(1,SZLIBBPR,"#")
  If IFIRSTPOS > 0 Then
    ILASTPOS = instr(IFIRSTPOS+1,SZLIBBPR,"#")
    If ILASTPOS > 0 Then
      SZVALEUR = seg$(SZLIBBPR,IFIRSTPOS+1,ILASTPOS-1)
      Read [BPR]BPR0=SZVALEUR
      If fstat = 0 Then
        IBTROUVE = 1
        SZCODEBPR = SZVALEUR
      Endif
    Endif
  Endif
  If IBTROUVE = 0 Then
    #On recherche si pas code direct
    SZVALEUR = vireblc(SZLIBBPR,2)
    Read [BPR]BPR0=SZVALEUR
    If fstat = 0 Then
      IBTROUVE = 1
      SZCODEBPR = SZVALEUR
    Endif
  Endif
  SZVALEUR = vireblc(SZLIBBPR,2)
  If IBTROUVE = 0 Then
    #On recherche sur raison social
    For [BPR] Where [F:BPR]BPRNAM=SZVALEUR
      IBTROUVE = 1
      SZCODEBPR= [F:BPR]BPRNUM
    Next
  Endif
  If IBTROUVE = 0 Then
    #On recherche sur raison social en majuscule
    For [BPR] Where toupper([F:BPR]BPRNAM)=toupper(SZVALEUR)
      IBTROUVE = 1
      SZCODEBPR= [F:BPR]BPRNUM
    Next
  Endif
  If IBTROUVE = 0 Then
    #On recherche sur IntitulĂŠ court
    For [BPR]BPR1 Where [F:BPR]BPRSHO=SZVALEUR
      IBTROUVE = 1
      SZCODEBPR= [F:BPR]BPRNUM
    Next
  Endif
  If IBTROUVE = 0 Then
    #On recherche sur IntitulĂŠ court en majuscule
    For [BPR]BPR1 Where toupper([F:BPR]BPRSHO)=toupper(SZVALEUR)
      IBTROUVE = 1
      SZCODEBPR= [F:BPR]BPRNUM
    Next
  Endif
End

##########################################################################################################
# Renvoi le libellĂŠ du tiers avec codif
# ------------------------------------------------------------
Subprog SYN_SETBPR(SZCODEBPR, SZLIBBPR, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZCODEBPR()
Variable Char SZLIBBPR()
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  Local File BPARTNER [BPR]
  Read [BPR]BPR0=SZCODEBPR
  If fstat = 0 Then
    SZLIBBPR = [F:BPR]BPRNAM + "   #" + SZCODEBPR + "#"
  Else
    IBRETOUR = 0
  Endif
End

##########################################################################################################
# Recherche code interlocuteur Ă  partir de son libellĂŠ
# ------------------------------------------------------------
Subprog SYN_GETAIN(SZLIBAIN, SZCODEAIN, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZLIBAIN()
Variable Char SZCODEAIN()
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IFIRSTPOS
Local Integer ILASTPOS
Local Char SZVALEUR(type(SZLIBAIN)-10)

  IFIRSTPOS = 0
  ILASTPOS = 0
  Raz SZVALEUR
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  #On regarde si le libellĂŠ ne contient pas le code du tiers
  #Recherche chaine #code#
  IFIRSTPOS = instr(1,SZLIBAIN,"#")
  If IFIRSTPOS > 0 Then
    ILASTPOS = instr(IFIRSTPOS+1,SZLIBAIN,"#")
    If ILASTPOS > 0 Then
      SZVALEUR = seg$(SZLIBAIN,IFIRSTPOS+1,ILASTPOS-1)
      SZCODEAIN = SZVALEUR
    Endif
  Endif
End

##########################################################################################################
# Renvoi le libellĂŠ du interlocuteur avec codif
# ------------------------------------------------------------
Subprog SYN_SETAIN(SZCODEAIN, SZLIBAIN, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZCODEAIN()
Variable Char SZLIBAIN()
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  Local File CONTACTCRM[AIN]
  Read [AIN]AIN0=SZCODEAIN
  If fstat = 0 Then
    SZLIBAIN = [F:AIN]CNTLNA - [F:AIN]CNTFNA + "   #" + SZCODEAIN + "#"
  Else
    IBRETOUR = 0
  Endif
End

##########################################################################################################
# Transforme une date de type char "AAAAMMJJHHMMSS" en un champs date X3
# ------------------------------------------------------------
Subprog GETDATEFROMCHAR(SZDATE, DTVALEUR, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZDATE()
Variable Date DTVALEUR()
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IVALYEAR
Local Integer IVALMONTH
Local Integer IVALDAY

  IVALYEAR = 0
  IVALMONTH = 0
  IVALDAY = 0
  IVALYEAR = val(left$(SZDATE,4))
  IVALMONTH = val(mid$(SZDATE,5,2))
  IVALDAY = val(mid$(SZDATE,7,2))
  DTVALEUR = gdat$(IVALDAY,IVALMONTH,IVALYEAR)
  IBRETOUR = 1
End

##########################################################################################################
# Transforme une date de type char "AAAAMMJJHHMMSS" en un champs heure X3
# ------------------------------------------------------------
Subprog GETTIMEFROMCHAR(SZDATE, HMVALEUR, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZDATE()
Variable Char HMVALEUR()
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

  HMVALEUR = mid$(SZDATE,9,4)
  IBRETOUR = 1
End

##########################################################################################################
#  Transforme une date time de type X3 en char "AAAAMMJJHHMMSS"
# ------------------------------------------------------------
Subprog SETDATETIMETOCHAR (DTDATE, HMHEURE, SZVALEUR, IERRINF, ICHAPTER, IBRETOUR)
Value Date DTDATE
Value Char HMHEURE
Variable Char SZVALEUR
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Char SZVALYEAR(250)
Local Char SZVALMONTH(250)
Local Char SZVALDAY(250)
Local Char SZVALHEURE(250)
Local Char SZAJOUT(250)

  IBRETOUR = 1
  Raz SZVALYEAR
  Raz SZVALMONTH
  Raz SZVALDAY
  Raz SZVALHEURE
  Raz SZAJOUT
  If DTDATE = [00/00/00] Then
    #Valeur null
    SZVALEUR = "00000000000000"
    End
  Endif
  SZVALYEAR = num$(year (DTDATE))
  If month(DTDATE) < 10 Then
    SZVALMONTH = "0" + num$(month(DTDATE))
  Else
    SZVALMONTH = num$(month(DTDATE))
  Endif
  If day(DTDATE) < 10 Then
    SZVALDAY = "0" + num$(day(DTDATE))
  Else
    SZVALDAY = num$(day(DTDATE))
  Endif
  SZVALHEURE = HMHEURE
  If len(HMHEURE) < 6 Then
    Case len(HMHEURE)
      When 0
        SZAJOUT = "000000"
      When 1
        SZAJOUT = "00000"
      When 2
        SZAJOUT = "0000"
      When 3
        SZAJOUT = "000"
      When 4
        SZAJOUT = "00"
      When 5
        SZAJOUT = "0"
    Endcase
    SZVALHEURE = HMHEURE + SZAJOUT
  Endif
  SZVALEUR = SZVALYEAR + SZVALMONTH + SZVALDAY + SZVALHEURE
  IBRETOUR = 1
End

##########################################################################################################
Subprog FMTCHARDATETIME(SZDTHM, SZDTHMFMT, SZMESSAGE, IBRETOUR)
Value Char SZDTHM
Variable Char SZDTHMFMT
Variable Char SZMESSAGE
Variable Integer IBRETOUR

Local Date DTDATE
Local Char HMHEURE(250)
Local Char SZRETOUR(250)
Local Integer IERRINF
Local Integer ICHAPTER

  IBRETOUR = 1
  Call GETDATEFROMCHAR(SZDTHM, DTDATE, IERRINF, ICHAPTER, IBRETOUR)
  SZRETOUR = format$(GFMDAT4,DTDATE)
  Call GETTIMEFROMCHAR (SZDTHM, HMHEURE, IERRINF, ICHAPTER, IBRETOUR)
  SZRETOUR = SZRETOUR - format$("XX[:]XX",HMHEURE)
  SZDTHMFMT = SZRETOUR
End

##########################################################################################################
# DECOD_OTKID     : dĂŠcompose l'identifiant outlook en objet et clĂŠ
Subprog DECOD_OTKID(SZOTKID, SZDEFOBJET, SZADXID, SZADXOBJET)
Value Char SZOTKID()
Value Char SZDEFOBJET()
Variable Char SZADXID()
Variable Char SZADXOBJET()

  #Traitement de l'identifiant tache
  If len(SZOTKID) >= 3 Then
    SZADXOBJET = left$(SZOTKID,3)
    SZADXID = right$(SZOTKID,4)
  Else
    SZADXOBJET = SZDEFOBJET
    SZADXID = SZADXID
  Endif
End

##########################################################################################################
# CODE_OTKID     : Compose l'identifiant outlook en fonction de la clĂŠ et de l'objet
Subprog CODE_OTKID(SZADXID, SZADXOBJET, SZOTKID)
Value Char SZADXID()
Value Char SZADXOBJET()
Variable Char SZOTKID()

  SZOTKID = SZADXOBJET + SZADXID
End

##########################################################################################################
# Recherche code pays Ă  partir de son code ou son libellĂŠ
# ------------------------------------------------------------
Subprog SYN_GETPAYS(SZLIBPAYS, SZCODEPAYS, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZLIBPAYS()
Variable Char SZCODEPAYS()
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Char SZVALEUR(250)
Local Integer IBTROUVE

  Raz SZVALEUR
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  IBTROUVE = 0
  #On regarde dans la table ATextra si le libellĂŠ existe pour TABCOUNTRY
  Local File ATEXTRA [AXXW]
  Local File TABCOUNTRY [TCYW]
  For [AXXW] Where [F:AXXW]CODFIC = "TABCOUNTRY" and [F:AXXW]ZONE = "CRYDES" and toupper([F:AXXW]TEXTE) = toupper(SZLIBPAYS)
    SZVALEUR = [F:AXXW]IDENT1
    IBTROUVE = 1
    Break
  Next
  #On regarde si ce n'est pas le code
  If len(SZLIBPAYS) < 4 and IBTROUVE = 0 Then
    For [TCYW] Where toupper([F:TCYW]CRY) = toupper(SZLIBPAYS)
      SZVALEUR = [F:TCYW]CRY
      IBTROUVE = 1
      Break
    Next
  Endif
  If IBTROUVE = 1 Then
    #On a trouvĂŠ on resort
    SZCODEPAYS = SZVALEUR
  Else
    IBRETOUR = 0
  Endif
End

##########################################################################################################
# Renvoi le libellĂŠ du pays en fonction de la langue et du code
# ------------------------------------------------------------
Subprog SYN_SETPAYS(SZCODEPAYS, SZLANGUE, SZLIBPAYS, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZCODEPAYS()
Value Char SZLANGUE()
Variable Char SZLIBPAYS()
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Char SZVALEUR(250)
Local Integer IBTROUVE

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  Raz SZVALEUR
  IBTROUVE = 0
  #On regarde dans la table ATextra si le libellĂŠ existe pour TABCOUNTRY
  Local File ATEXTRA [AXXW]
  For [AXXW]  Where [F:AXXW]CODFIC = "TABCOUNTRY" and [F:AXXW]ZONE = "CRYDES" and [F:AXXW]LANGUE = SZLANGUE and [F:AXXW]IDENT1 = SZCODEPAYS
    SZVALEUR = [F:AXXW]TEXTE
    IBTROUVE = 1
    Break
  Next
  If IBTROUVE = 1 Then
    #On a trouvĂŠ on resort
    SZLIBPAYS = SZVALEUR
  Else
    IBRETOUR = 0
  Endif
End

##########################################################################################################
# Decompose une chaine adresse en 3 sous chaine adresse
# ------------------------------------------------------------
Subprog SYN_DECODIFADR(SZADRESSE, SZADR1, SZADR2, SZADR3, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZADRESSE()
Variable Char SZADR1()
Variable Char SZADR2()
Variable Char SZADR3()
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Char SZVAL1(250)
Local Char SZVAL2(250)
Local Char SZVAL3(250)
Local Char SZRETOURCHAR(GLONDES)

  Raz SZVAL1
  Raz SZVAL2
  Raz SZVAL3
  SZRETOURCHAR = chr$(13) + chr$(10)
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  IFIRSTPOS = instr(1,SZADRESSE,SZRETOURCHAR)
  If IFIRSTPOS > 0 Then
    ILASTPOS = instr(IFIRSTPOS+2,SZADRESSE,SZRETOURCHAR)
    If ILASTPOS > 0 Then
      SZVAL2 = seg$(SZADRESSE,IFIRSTPOS+2,ILASTPOS-1)
      SZVAL3 = right$(SZADRESSE,ILASTPOS+2)
    Else
      SZVAL2 = right$(SZADRESSE,IFIRSTPOS+2)
    Endif
    SZVAL1 = left$(SZADRESSE,IFIRSTPOS-1)
  Else
    SZVAL1 = SZADRESSE
  Endif
  SZADR1 = SZVAL1
  SZADR2 = SZVAL2
  SZADR3 = SZVAL3
End

##########################################################################################################
# Decompose une chaine adresse en 3 sous chaine adresse
# ------------------------------------------------------------
Subprog SYN_CODIFADR(SZADR1, SZADR2, SZADR3, SZADRESSE, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZADR1()
Value Char SZADR2()
Value Char SZADR3()
Variable Char SZADRESSE()
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Char SZRETOURCHAR(GLONDES)
Local Char SZVALEUR(250)
Local Char SZVAL1(250)
Local Char SZVAL2(250)
Local Char SZVAL3(250)

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  Raz SZADRESSE
  SZRETOURCHAR = chr$(13) + chr$(10)
  If SZADR1 <> "" Then
    SZVAL1 = SZADR1
    If SZADR2 <> "" Then
      SZVAL2 = SZADR2
      If SZADR3 <> "" Then
        SZVAL3 = SZADR3
      Endif
    Else
      If SZADR3 <> "" Then
        SZVAL2 = SZADR3
      Endif
    Endif
  Else
    If SZADR2 <> "" Then
      SZVAL1 = SZADR2
      If SZADR3 <> "" Then
        SZVAL2 = SZADR3
      Endif
    Else
      If SZADR3 <> "" Then
        SZVAL1 = SZADR3
      Endif
    Endif
  Endif
  If SZVAL1 <> "" Then
    SZVALEUR = SZVAL1
    If SZVAL2 <> "" Then
      SZVALEUR = SZVALEUR + SZRETOURCHAR + SZVAL2
      If SZVAL3 <> "" Then
        SZVALEUR = SZVALEUR + SZRETOURCHAR + SZVAL3
      Endif
    Endif
  Endif
  If SZVALEUR <> "" Then
    SZADRESSE = SZVALEUR
  Endif
End

#SYN_TRTTEL      : Traite un numĂŠro de tĂŠlĂŠphone pour enlever son format
##########################################################################################################
# Traite un numĂŠro de tĂŠlĂŠphone pour enlever son format
# ------------------------------------------------------------
Subprog SYN_TRTTEL(SZTEL, SZPAYS, SZTELNOFMT, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZTEL()
Value Char SZPAYS()
Variable Char SZTELNOFMT()
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer ILGFMT
Local Char SZVALEUR(250)
Local Char SZCHAR(250)
Local Char SZCHAINE(250)
Local Integer ILENGTH
Local Integer IBCONTINUE
Local Integer IBKEEP
Local Integer IVAL

  ILGFMT = 0
  Raz SZVALEUR
  Raz SZCHAR
  Raz SZCHAINE
  ILENGTH = 0
  IBKEEP = 0
  IBCONTINUE = 1
  IVAL = 0
  If SZPAYS = "" Then
    End
  Endif
  Local File TABCOUNTRY [TCY]
  Read [TCY]TCY0=SZPAYS
  If fstat = 0 Then
    SZFORMAT = [F:TCY]TELFMT
  Endif
  If SZFORMAT = "" Then
    SZTELNOFMT = SZTEL
    End
  Endif
  #On a un format  on traite
  Call LNGFMT(SZFORMAT, ILGFMT) From FMTVAR
  If len(SZTEL) < ILGFMT Then
    SZTELNOFMT = SZTEL
    End
  Endif
  SZVALEUR = SZTEL
  While IBCONTINUE  = 1
    ILENGTH=len(SZVALEUR)
    SZCHAR = right$(SZVALEUR,ILENGTH)
    IVAL=ascii(SZCHAR)
    If IVAL >= 48 and IVAL <= 57 Then
      IBKEEP = 1
    Else
      IBKEEP= 0
    Endif
    If IBKEEP = 1 Then
      SZCHAINE = SZCHAR + SZCHAINE
    Endif
    If len(SZCHAINE) >= ILGFMT Then
      IBCONTINUE = 0
      Break
    Endif
    If ILENGTH-1 > 0 Then
      SZVALEUR = left$(SZVALEUR,ILENGTH-1)
    Else
      IBCONTINUE = 0
      Break
    Endif
  Wend
  SZTELNOFMT = SZCHAINE
End

##########################################################################################################
#Prend deux clob regarde si balise OTK existe et si oui concatĂ¨ne les 2
# ------------------------------------------------------------
Subprog CONCATCLOB(SZUSER, LBCLOBADX, LBCLOBOTK, ITYPCONFLIT, IBMODIF, SZMESSAGE, IBRETOUR)
Value Char SZUSER
Variable Clbfile LBCLOBADX
Variable Clbfile LBCLOBOTK
Value Integer ITYPCONFLIT
Variable Integer IBMODIF
Variable Char SZMESSAGE
Variable Integer IBRETOUR

Local Char SZTXTREF(250)
Local Integer IRESULT
Local Clbfile LBEXTRACT
Local Char SZDATEBAL(250)
Local Char SZDATEJOUR(250)
Local Char SZBALADXDEB(250)
Local Char SZBALADXFIN(250)

  IBRETOUR = 1
  SZTXTREF = "<#OTK:"
  #Texte ajouter <#OTK:AAAAMMJJ#>
  IRESULT = 0
  Raz LBEXTRACT
  Raz SZDATEBAL
  Raz SZDATEJOUR
  Raz SZBALADXDEB
  Raz SZBALADXFIN
  #Raz LBCLOBADX  # FGR 04/06/2014 : X3SUIVI100191 : faut pas l'effacer !
  Call FINDLASTREF(LBCLOBOTK, SZTXTREF, IRESULT)
  If IRESULT > 0 Then
    SZDATEBAL = mid$(LBCLOBOTK,IRESULT+6,8)
    SZDATEJOUR = format$("YYYYMMDD",date$)
    LBEXTRACT = right$(LBCLOBOTK,(IRESULT+16))
    Call TRIMDEBPARA(LBEXTRACT) From CRMUTIL150
    LBEXTRACT = vireblc(LBEXTRACT,2)
    If len(LBEXTRACT) > 0 Then
      SZBALADXDEB = chr$(13) + chr$(10) + "<#"+SZUSER + ":" + SZDATEBAL + "--->"  + chr$(13) + chr$(10)
      SZBALADXFIN = chr$(13) + chr$(10) + "<---"+SZUSER+":"+SZDATEJOUR+"#>" + chr$(13) + chr$(10)
      Call TRIMFINPARA (LBCLOBADX) From CRMUTIL150
      LBCLOBADX = LBCLOBADX + SZBALADXDEB + LBEXTRACT
      Call TRIMFINPARA (LBCLOBADX) From CRMUTIL150
      LBCLOBADX = LBCLOBADX + SZBALADXFIN
      IBMODIF = 1
    Endif
  Else
    If ITYPCONFLIT = 0 Then
      #Pas de conflit on affecte les valeur de OTK
      LBCLOBADX = LBCLOBOTK
      IBMODIF = 1
    Elsif ITYPCONFLIT = 1 Then
      #Conflit Outlook le plus rĂŠcent
      LBCLOBADX = LBCLOBOTK
      IBMODIF = 1
    Elsif ITYPCONFLIT = 2 Then
      #Conflit Adonix le plus rĂŠcent
      #On ne fait rien
    Endif
  Endif
End

##########################################################################################################
#Rajoute la balise OTK Ă  un clob
# ------------------------------------------------------------
Subprog ADDBALISEOTK(LBCLOB, SZMESSAGE, IBRETOUR)
Variable Clbfile LBCLOB
Variable Char SZMESSAGE
Variable Integer IBRETOUR

Local Char SZSZBALISEOTK(250)
Local Char SZDATEJOUR(250)

  IBRETOUR = 1
  Raz SZSZBALISEOTK
  SZDATEJOUR = format$("YYYYMMDD",date$)
  SZBALISEOTK = chr$(13) + chr$(10) + "<#OTK:"+SZDATEJOUR+"#>" + chr$(13) + chr$(10)
  Call TRIMFINPARA(LBCLOB) From CRMUTIL150
  LBCLOB = LBCLOB + SZBALISEOTK
End

##########################################################################################################
#recherche si une chaine de texte existe renvoi la place de la derniĂ¨re occurence
# ------------------------------------------------------------
Subprog FINDLASTREF(LBCLOB, SZREFERENCE, IRESULT)
Value Clbfile LBCLOB
Value Char SZREFERENCE
Variable Integer IRESULT

Local Integer ITROUVE
Local Integer IBCONTINUE
Local Integer IPOSDEB

  IBCONTINUE = 1
  ITROUVE = 0
  IPOSDEB = 0
  While IBCONTINUE = 1
    ITROUVE = instr(IPOSDEB,LBCLOB,SZREFERENCE)
    If ITROUVE = 0 Then
      IBCONTINUE = 0
      Break
    Else
      IRESULT  = ITROUVE
      IPOSDEB = ITROUVE + 1
    Endif
  Wend
End

##########################################################################################################
# rajoute la balise entĂŞte pour un rendez vous
# ------------------------------------------------------------
Subprog ADDBALISEBAP(LBCLOB)
Variable Clbfile LBCLOB

  If LBCLOB <> "" Then
    LBCLOB = LBCLOB + chr$(13) + chr$(10) + "----------------------------------<\OTK-HEADER\>"
  Endif
End

##########################################################################################################
#EnlĂ¨ve la partie entĂŞte d'un clob provenant d'eun rendez-vous Outlook
# ------------------------------------------------------------
Subprog CLEANCLOBBAP(LBCLOB)
Variable Clbfile LBCLOB

Local Char SZREFERENCE(250)
Local Integer ILENHEADER
Local Integer ITROUVE

  SZREFERENCE = "<\OTK-HEADER\>"
  ILENHEADER = len(SZREFERENCE)
  ITROUVE = instr(0,LBCLOB,SZREFERENCE)
  If ITROUVE <> 0 Then
    LBCLOB = right$(LBCLOB,ITROUVE+ILENHEADER)
    Call TRIMDEBPARA(LBCLOB) From CRMUTIL150
  Endif
End

##########################################################################################################
Subprog GET_INFO_CORRESPONDANT(SCORNUM, LBCLOB)
Value Char SCORNUM
Variable Clbfile LBCLOB

Local Char SSPACE(15)
Local Integer NI

  # FGR 25/08/2014 : X3SUIVI102228
  # ------------------------------------------------------------------------------
  # IMPORTANT : TOUJOURS CONCATENNER SUR LBCLOB. IL N'EST PAS VIDE. ON LE COMPLETE
  # ------------------------------------------------------------------------------
  Local File TABCOUNTRY [TCY]
  Local File CORRESPOND [COR]
  Read [COR]COR0=SCORNUM
  If !fstat Then
    End
  Endif
  # --------------------------------------------------------
  SSPACE = string$(type(SSPACE)-10, ' ')
  # --------------------------------------------------------
  If [F:COR]BPRNUM <> "" Then
    # Si le correspondant est rattachĂŠ Ă  un tiers on propose les informations professionnelles
    For NI = 0 To dim([F:COR]CPYADD)-1
      If [F:COR]CPYADD(NI) <> "" Then
        LBCLOB += chr$(13) + chr$(10) + SSPACE + [F:COR]CPYADD(NI)
      Endif
    Next NI
    LBCLOB += chr$(13) + chr$(10) + SSPACE + [F:COR]CPYZIP - [F:COR]CPYCTY
    If  [F:COR]CPYSAT <> "" Then
      LBCLOB += chr$(13) + chr$(10) + SSPACE + [F:COR]CPYSAT
    Endif
    LBCLOB += chr$(13) + chr$(10) + SSPACE + [F:COR]CPYCRY - [F:COR]CPYCRYNAM
    Read [TCY]TCY0=[F:COR]CPYCRY
    If [F:COR]CPYTEL <> "" Then
      LBCLOB += chr$(13) + chr$(10) + SSPACE + mess(374,183,1) - ":" - format$([F:TCY]TELFMT, [F:COR]CPYTEL)
    Endif
    If [F:COR]CPYFAX <> "" Then
      LBCLOB += chr$(13) + chr$(10) + SSPACE + mess(376,183,1) - ":" - format$([F:TCY]TELFMT, [F:COR]CPYFAX)
    Endif
    If [F:COR]CPYMOB <> "" Then
      LBCLOB += chr$(13) + chr$(10) + SSPACE + mess(76,183,1) - ":" - format$([F:TCY]TELFMT, [F:COR]CPYMOB)
    Endif
    If [F:COR]CPYEML <> "" Then
      LBCLOB += chr$(13) + chr$(10) + SSPACE + mess(392,183,1) - ":" - [F:COR]CPYEML
    Endif
  Else
    # Sinon on propose les informations personnelles
    For NI = 0 To dim([F:COR]HOMADD)-1
      If [F:COR]HOMADD(NI) <> "" Then
        LBCLOB += chr$(13) + chr$(10) + SSPACE + [F:COR]HOMADD(NI)
      Endif
    Next NI
    LBCLOB += chr$(13) + chr$(10) + SSPACE + [F:COR]HOMZIP - [F:COR]HOMCTY
    If  [F:COR]HOMSAT <> "" Then
      LBCLOB += chr$(13) + chr$(10) + SSPACE + [F:COR]HOMSAT
    Endif
    LBCLOB += chr$(13) + chr$(10) + SSPACE + [F:COR]HOMCRY - [F:COR]HOMCRYNAM
    Read [TCY]TCY0=[F:COR]HOMCRY
    If [F:COR]HOMTEL <> "" Then
      LBCLOB += chr$(13) + chr$(10) + SSPACE + mess(1150,196,1) - ":" - format$([F:TCY]TELFMT, [F:COR]HOMTEL)
    Endif
    If [F:COR]HOMFAX <> "" Then
      LBCLOB += chr$(13) + chr$(10) + SSPACE + mess(1151,196,1) - ":" - format$([F:TCY]TELFMT, [F:COR]HOMFAX)
    Endif
    If [F:COR]HOMMOB <> "" Then
      LBCLOB += chr$(13) + chr$(10) + SSPACE + mess(76,183,1) - ":" - format$([F:TCY]TELFMT, [F:COR]HOMMOB)
    Endif
    If [F:COR]HOMEML <> "" Then
      LBCLOB += chr$(13) + chr$(10) + SSPACE + mess(392,183,1) - ":" - [F:COR]HOMEML
    Endif
  Endif
End

##########################################################################################################
Funprog GET_HYPERLINK(SSTRING, SFUNCTION, SKEY)
Value Char SSTRING
Value Char SFUNCTION
Value Char SKEY

Local Char TABKEY(50)(1..10)
Local Char TABKEYVAL(50)(1..10)
Local Char TABPAR(50)(1..10)
Local Char TABPARVAL(250)(1..10)
Local Integer ASTATUS
Local Clbfile CLARENDRE(2)
Local Clbfile CLURL(2)

  # FGR 28/05/2015 : X3SUIVI105431
  Raz CLARENDRE
  Raz TABKEY
  Raz TABKEYVAL
  Raz TABPAR
  Raz TABPARVAL
  # ---------------------------------------------------------------
  Case SFUNCTION
    When "GESBAP"
      TABKEY(1) = "APTNUM"
      TABKEYVAL(1) = SKEY
    When "GESREP"
      TABKEY(1) = "REPNUM"
      TABKEYVAL(1) = SKEY
    When "GESOPP"
      TABKEY(1) = "OPPNUM"
      TABKEYVAL(1) = SKEY
    When "GESAIN"
      TABKEY(1) = "CNTNUM"
      TABKEYVAL(1) = SKEY
    When "GESLDS"
      TABKEY(1) = "PSTNUM"
      TABKEYVAL(1) = SKEY
    When "GESCLL"
      TABKEY(1) = "CLLNUM"
      TABKEYVAL(1) = SKEY
    When "GESCOR"
      TABKEY(1) = "CORNUM"
      TABKEYVAL(1) = SKEY
    When "GESCOR"
      TABKEY(1) = "CORNUM"
      TABKEYVAL(1) = SKEY
    When "GESTSK"
      TABKEY(1) = "TSKNUM"
      TABKEYVAL(1) = SKEY
    When "GESBPR"
      TABKEY(1) = "BPRNUM"
      TABKEYVAL(1) = SKEY
    When "GESBPC"
      TABKEY(1) = "BPCNUM"
      TABKEYVAL(1) = SKEY
    When "GESBPP"
      TABKEY(1) = "BPPNUM"
      TABKEYVAL(1) = SKEY
    When "GESBPT"
      TABKEY(1) = "BPTNUM"
      TABKEYVAL(1) = SKEY
    When Default
  Endcase
  # ---------------------------------------------------------------
  If TABKEY(1) <> "" Then
    ASTATUS = func ASYRFNC.AGET_CLASSICURL(GACTX, [V]CST_ATRUE, SFUNCTION, [V]CST_AMODIFFCT, TABKEY, TABKEYVAL, TABPAR, TABPARVAL, CLURL)
    If [L]ASTATUS = [V]CST_AOK Then
      # IMPORTANT : penser Ă  mettre un espace avant et aprĂ¨s l'URL { http:.... }
      If SSTRING <> "" Then
        CLARENDRE = "{{" + SSTRING + "}{" - CLURL - "}}"
      Else
        CLARENDRE = "{{" + SKEY + "}{" - CLURL - "}}"
      Endif
    Else
      # Erreur dans la construction du lien : pour ne pas planter on renvoi le texte de base.
      CLARENDRE = SSTRING
    Endif
  Else
    # Pas trouvĂŠ de clĂŠ : pour ne pas planter on renvoi le texte de base.
    CLARENDRE = SSTRING
  Endif
  # ---------------------------------------------------------------
End CLARENDRE

##########################################################################################################
# Issue X3-46689 - 2017-07-04 by FGR : BEGIN
Funprog GET_FORMATTED_CRY_PHONE(SCRY, STEL)
Value Char SCRY
Value Char STEL

Local Char SARENDRE(250)
Local Char SFMT(250)

  # Issue X3-42496 - 2017-06-15 by FGR
  Raz SARENDRE
  If STEL <> "" Then
    If GTRACE <> "" Then
      Call ECR_TRACE("GET_FORMATTED_CRY_PHONE SCRY=" + SCRY - "STEL=" + STEL, 0) From GESECRAN
    Endif
    SFMT = func GET_COUNTRY_PHONE_FMT(SCRY)
    SARENDRE = format$(SFMT, STEL)
    If GTRACE <> "" Then
      Call ECR_TRACE("GET_FORMATTED_CRY_PHONE SARENDRE=" + SARENDRE, 0) From GESECRAN
    Endif
  Endif
End SARENDRE

