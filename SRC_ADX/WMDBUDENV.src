#<AdxTL>@(#)0.0.0.0 $Revision$
# Supervisor
## BI-DIMENSION ## Synchronization rule BUDENV

$OUVRE
Local Char FILTRE(250)
OUVTAB = GDOSSIER+".ENVELOPPE" : If clalev([F:ENV])=0 : Local File =OUVTAB [ENV] : Endif
OUVTAB = GDOSSIER+".ATEXTRA" : If clalev([F:AXX1])=0 : Local File =OUVTAB [AXX1] : Endif
OUVTAB = GDOSSIER+".ATEXTRA" : If clalev([F:AXX2])=0 : Local File =OUVTAB [AXX2] : Endif
OUVTAB = "Link [ENV]"
Link [ENV] With
& [AXX1]AXX0 = "ENVELOPPE";"DESTRA";GLANGUE;[F:ENV]ENV;"",
& [AXX2]AXX0 = "ENVELOPPE";"SHOTRA";GLANGUE;[F:ENV]ENV;""
& As [LNK_]
& Order By Key CLE = [ENV]ENV
FILTRE = ""
Return

$FERME
If clalev([F:ENV]) : Close local File [ENV] : Endif
If clalev([F:AXX1]) : Close local File [AXX1] : Endif
If clalev([F:AXX2]) : Close local File [AXX2] : Endif
Return

$DCLE
Local Char    DCLE(GLONAVA)(1..1)
Local Integer DTYP(1..1)
Local Integer NBDCLE
NBDCLE = 1
DCLE(1) = "ENV"
DTYP(1) =  7
Return

$CHARGE_CLE
If dim([F:AAA_]ENV)>0
 [F:AAA_]ENV = [F:ENV]ENV
Endif
Return

########################################################################
# Return the filter necessary for incremental delete in synchroonization
Subprog GET_FLTDELINC(PFLT)
Variable Clbfile PFLT
PFLT = "1=1"
Append PFLT, " & [F:AAA_]ENV=[F:ENV]ENV"

End

$MAJFLD
### ENV
[L]FLD="ENV"
[L]FORMULE='[F:ENV]ENV'
If dim([F:AAA_]ENV)>0
 [F:AAA_]ENV = [F:ENV]ENV
Endif

