#<AdxTL>@(#)4.0.0.0 $Revision$
###################################################
# Maj texte traduisibles des propriété AEV
###################################################
Call PATCH(nomap)
End

Subprog PATCH(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".AEXPV3"    [AEV] 
Local File =DOSSIER+".ATEXTRA"     [AXX]

If dim([F:AEV]DES)<0 
 Close Local File [AEV],[AXX]
 End 
Endif

# Mise à jour de la table AEXPV3
Call ECR_TRACE(mess(81,125,1)-"AEXPV3:"-time$,0) From GESECRAN
Trbegin [AEV]
For [AEV]AEV0
  If [F:AEV]DES <> ""
   Call MAJTEXTRA([F:AEV]DES,"AEXPV3","INTIT",[F:AEV]CODE,"")  From SUPMAJ30
  Endif
 Next
Commit

Close Local File [AEV],[AXX]
End

