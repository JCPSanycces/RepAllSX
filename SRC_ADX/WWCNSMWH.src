#<AdxTL>@(#)%I%
# Supervisor
# Inquiry MWH

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "08:11:12"
A_USER  = "ADMIN"
A_STAMP = "20181109081112"
Return

$DEFAUT
Return

$OUVFIC
Return

$NOMFIC
Local Char    TIT(GLONDES) , TITT(GLONDES)
Local Char    PROGSTD(GLONADC) , PROGSPE(GLONADC)
Local Char    ABMSK(GLONABR)(16) , NOMMSK(GLONAMK)(16) , CABMSK(GLONABR) , CNOMMSK(GLONAMK)
Local Char    BOITE(GLONFEN) , CBOITE(GLONFEN)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , OBJDERLU(GLONAOB)
Local Char    CODMSKDEF(GLONAMK) , CMEMO(GLONAMM)
Local Libelle MAGNETO
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA)
Call TEXTE(18151,TITT) From OBJDIV
TIT        = mess(15,126,1)
If dim(CNSCOD)>0 : TIT -= CNSCOD : Endif
PROGSTD    = "CNSMWHSTD"
PROGSPE    = "CNSMWHSPE"
CBOITE     = "DCNSMWH"
BOITE      = "FCNSMWH"
NOMMSK(0)  = "CONSMWH1"
ABMSK(0)   = "MWH1"
NOMMSK(1)  = "CONSMWH2"
ABMSK(1)   = "MWH2"
CMEMO      = "mwh"
CNOMMSK    = "CRITMWH"
CABMSK     = "CMWH"
CODMSKDEF  = "STD"
MAGNETO    = 1
Return

$SETCLE
Local Char    CLE(10), CLECMP(10)(0..0), CLEMSK(10)(0..0)
Local Integer NBCMP
Local Char    FILTRE(250)
CLE = ""
NBCMP = 0
CLECMP = "" : CLEMSK = ""
Return

$OUVRE
If clalev([F:ITM])=0 : Local File ITMMASTER    [ITM] : Endif
If clalev([F:ITF])=0 : Local File ITMFACILIT   [ITF] : Endif
If clalev([F:FCY])=0 : Local File FACILITY     [FCY] : Endif
If clalev([F:SLE])=0 : Local File SCALES       [SLE] : Endif
If clalev([F:STX])=0 : Local File STATION      [STX] : Endif
If clalev([F:SBX])=0 : Local File STATIONBOX   [SBX] : Endif
Return

$OUVRE_MSK
Case MA
 When -1 : Local Mask =CNOMMSK   [CMWH]
 When  0 : Local Mask =NOMMSK(0) [MWH1]
 When  1 : Local Mask =NOMMSK(1) [MWH2]
Endcase
Return

$GRISE_MSK
Case MA
 When -1 : Grizo [CMWH]
 When  0 : Grizo [MWH1]
 When  1 : Grizo [MWH2]
Endcase
Return

$GRISE_CLE
Return

$GRISE_CRIT
If dim([M:CMWH]ITMREFSTR)>0
 Grizo [CMWH]ITMREFSTR
Endif
If dim([M:CMWH]ITMREFEND)>0
 Grizo [CMWH]ITMREFEND
Endif
If dim([M:CMWH]BOMOPESTR)>0
 Grizo [CMWH]BOMOPESTR
Endif
If dim([M:CMWH]BOMOPEEND)>0
 Grizo [CMWH]BOMOPEEND
Endif
If dim([M:CMWH]CTNSTR)>0
 Grizo [CMWH]CTNSTR
Endif
If dim([M:CMWH]CTNEND)>0
 Grizo [CMWH]CTNEND
Endif
If dim([M:CMWH]MFGNUMSTR)>0
 Grizo [CMWH]MFGNUMSTR
Endif
Return

$FERME_MSK
Case MA
 When -1 : If clalev([M:CMWH])>0 : Close Local Mask [CMWH] : Endif
 When  0 : If clalev([M:MWH1])>0 : Close Local Mask [MWH1] : Endif
 When  1 : If clalev([M:MWH2])>0 : Close Local Mask [MWH2] : Endif
Endcase
Return

$SETMASK
Case MA
 When -1 : Default Mask [CMWH]
 When  0 : Default Mask [MWH1]
 When  1 : Default Mask [MWH2]
Endcase
Return

$RAZMASK
Case MA
 When -1 : Raz [M:CMWH]
 When  0 : Raz [M:MWH1]
 When  1 : Raz [M:MWH2]
Endcase
Return

$CRITENT
If dim([M:CMWH]ITMREFSTR)>0 & dim([M:MWH1]ITMREFSTR)>0
 [M:CMWH]ITMREFSTR = [M:MWH1]ITMREFSTR
Endif
If dim([M:CMWH]ITMREFEND)>0 & dim([M:MWH1]ITMREFEND)>0
 [M:CMWH]ITMREFEND = [M:MWH1]ITMREFEND
Endif
If dim([M:CMWH]BOMOPESTR)>0 & dim([M:MWH1]BOMOPESTR)>0
 [M:CMWH]BOMOPESTR = [M:MWH1]BOMOPESTR
Endif
If dim([M:CMWH]BOMOPEEND)>0 & dim([M:MWH1]BOMOPEEND)>0
 [M:CMWH]BOMOPEEND = [M:MWH1]BOMOPEEND
Endif
If dim([M:CMWH]CTNSTR)>0 & dim([M:MWH1]CTNSTR)>0
 [M:CMWH]CTNSTR = [M:MWH1]CTNSTR
Endif
If dim([M:CMWH]CTNEND)>0 & dim([M:MWH1]CTNEND)>0
 [M:CMWH]CTNEND = [M:MWH1]CTNEND
Endif
If dim([M:CMWH]MFGNUMSTR)>0 & dim([M:MWH1]MFGNUMSTR)>0
 [M:CMWH]MFGNUMSTR = [M:MWH1]MFGNUMSTR
Endif
Return

$ENTCRIT
If dim([M:CMWH]ITMREFSTR)>0 & dim([M:MWH1]ITMREFSTR)>0
[M:MWH1]ITMREFSTR = [M:CMWH]ITMREFSTR
Endif
If dim([M:CMWH]ITMREFEND)>0 & dim([M:MWH1]ITMREFEND)>0
[M:MWH1]ITMREFEND = [M:CMWH]ITMREFEND
Endif
If dim([M:CMWH]BOMOPESTR)>0 & dim([M:MWH1]BOMOPESTR)>0
[M:MWH1]BOMOPESTR = [M:CMWH]BOMOPESTR
Endif
If dim([M:CMWH]BOMOPEEND)>0 & dim([M:MWH1]BOMOPEEND)>0
[M:MWH1]BOMOPEEND = [M:CMWH]BOMOPEEND
Endif
If dim([M:CMWH]CTNSTR)>0 & dim([M:MWH1]CTNSTR)>0
[M:MWH1]CTNSTR = [M:CMWH]CTNSTR
Endif
If dim([M:CMWH]CTNEND)>0 & dim([M:MWH1]CTNEND)>0
[M:MWH1]CTNEND = [M:CMWH]CTNEND
Endif
If dim([M:CMWH]MFGNUMSTR)>0 & dim([M:MWH1]MFGNUMSTR)>0
[M:MWH1]MFGNUMSTR = [M:CMWH]MFGNUMSTR
Endif
Return

$CRITAFF
Local Integer NBCA
Local Char    CRITAFF(10)(1..1) , CRITAFF2(10)(1..1)
NBCA = 0
Return

$STYLEPLAG
Return

Subprog GETACT(NOL,TITBOUT,VALBOUT)
Value Integer NOL
Variable Char TITBOUT()(1..) , VALBOUT()(1..)
Local Integer ONOL , NBBOUT
ONOL   = nolign
nolign = NOL
indice = max(0,nolign-1)
Call AS_NBLIG From ="W1CONSMWH2"
NBBOUT = 0
If GBOUT1<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT1
 VALBOUT(NBBOUT) = "MWH"
 VALBOUT(NBBOUT) += "~B1"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 Onerrgo
Endif
If GBOUT2<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT2
 VALBOUT(NBBOUT) = "MWH"
 VALBOUT(NBBOUT) += "~B2"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans("","~","¨")
 Onerrgo
Endif
If GBOUT3<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT3
 VALBOUT(NBBOUT) = "MWH"
 VALBOUT(NBBOUT) += "~B3"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans([MWH2]MFGNUM(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans(num$([MWH2]BOMOPE(nolign-1)),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans([MWH2]ITMREF(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans(num$([MWH2]MFGLIN(nolign-1)),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans(num$([MWH2]BOMSEQ(nolign-1)),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans([MWH2]CBTDAT(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans(num$([MWH2]MVTSEQ(nolign-1)),"~","¨")
 Onerrgo
Endif
nolign = ONOL
indice = max(0,nolign-1)
End

Subprog ACTRUN(INFO)
Value Char INFO
Local Char    BOUT(3)
Local Integer ONOL
ONOL    = nolign
BOUT    = func AFNC.PART(INFO,1)
nolign  = val(func AFNC.PART(INFO,2))
indice  = max(0,nolign-1)
Gosub NOMFIC
For MA=0 to dim(NOMMSK)-1
 Gosub OUVRE_MSK
Next MA
For MA=0 to dim(NOMMSK)-1
 Gosub SETMASK
Next MA
Case BOUT
 When "B1"
  Onerrgo RIEN
  Assign "[MWH2]MVTSEQ(nolign-1)" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Onerrgo
  Call B1_NBLIG From ="W1CONSMWH2"
 When "B2"
  Onerrgo RIEN
  Assign "[MWH2]MVTSEQ(nolign-1)" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Onerrgo
  Call B2_NBLIG From ="W1CONSMWH2"
 When "B3"
  Onerrgo RIEN
  Assign "[MWH2]MFGNUM(nolign-1)" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Assign "[MWH2]BOMOPE(nolign-1)" With val(ctrans(func AFNC.PART(INFO,4),"¨","~"))
  Assign "[MWH2]ITMREF(nolign-1)" With ctrans(func AFNC.PART(INFO,5),"¨","~")
  Assign "[MWH2]MFGLIN(nolign-1)" With val(ctrans(func AFNC.PART(INFO,6),"¨","~"))
  Assign "[MWH2]BOMSEQ(nolign-1)" With val(ctrans(func AFNC.PART(INFO,7),"¨","~"))
  Assign "[MWH2]CBTDAT(nolign-1)" With ctrans(func AFNC.PART(INFO,8),"¨","~")
  Assign "[MWH2]MVTSEQ(nolign-1)" With val(ctrans(func AFNC.PART(INFO,9),"¨","~"))
  Onerrgo
  Call B3_NBLIG From ="W1CONSMWH2"
Endcase
nolign = ONOL
indice = max(0,nolign-1)
End

$RIEN
Resume


