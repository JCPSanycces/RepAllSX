#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UTIACH18      Utilitaire de resynchronisation des         Module ACHAT #
#               formats des ûˋlûˋments de facturation                      #
#               commande                                                 #
##########################################################################


Call MAJ_UTIACH18
End


Subprog MAJ_UTIACH18
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIACH18 - Resynchro formats ûˋlûˋments commande") From SAIDOS
If DOSSIER<>""
  #-----
  Local Integer OK
  Local Libelle WSIMFLG
  Call OUINON("Simulation ?",OK) From GESECRAN
  If OK=2  WSIMFLG=1 Else Raz WSIMFLG : Endif
  #-----
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIACH18 : Utilitaire resynchro formats ûˋlûˋments commande") From LECFIC
  Call EXE_UTIACH18(DOSSIER,WSIMFLG)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End


Subprog EXE_UTIACH18(DOSSIER,WSIMFLG)
Value Char    DOSSIER
Value Libelle WSIMFLG
#----- Variables locales -----#
Local Char     WMSG(90), WCRITERE(100)
Local Integer  NBENR, NBCOR
Local Integer  WVCRTYP
Local Char     WVCRNUM(GLONVCR)
Local Integer  WIND
Local Integer  WCLE1
Local Char     WCLE2(GLONVCR)
Local Integer  WCLE3
Local Char     WFORMAT(15)
Local Integer WCOMPTEUR, WSTOP
Local Libelle  WTRACE : WTRACE=2 : # WTRACE=2 --> Trace dûˋtaillûˋe
#-----
Call ECR_TIME("UTIACH18 : Dûˋbut traitement du dossier "+DOSSIER) From DOSSUB
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
If WSIMFLG  Call ECR_TRACE("***** Simulation *****",0) From GESECRAN : Endif
#----- Ouverture des fichiers -----#
If !clalev([F:PVF])  Local File =DOSSIER+".PVCRFOOT"    [PVF] : Endif
If !clalev([F:ATY])  Local File =DOSSIER+".ATYPE"       [ATY] : Endif
#----- Dûˋbut du traitement -----#
Raz NBENR, NBCOR
Gosub TRT_FMT1
Gosub TRT_FMT2
#----- Fin du traitement -----#
$FIN_UTIACH18
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
WMSG ="UTIACH18 : Nbre d'enregistrements traitûˋs :"-num$(NBENR)
WMSG+=" dont corrigûˋs :"-num$(NBCOR)
Call ECR_TIME(WMSG) From DOSSUB
If WSIMFLG  Call ECR_TRACE("***** Simulation *****",0) From GESECRAN : Endif
Close Local File [PVF], [ATY] 
End


#---------------------------------#
# Traitement des formats montants #
#---------------------------------#
$TRT_FMT1
If WTRACE=2
  Call ECR_TRACE("----- Format des montants",0) From GESECRAN
Endif
Call DEBTRANS From GLOCK
Raz WCLE1, WCLE2, WCLE3, WSTOP
$BOUCLE_FMT1
GOK=1
If WSTOP=1
  WSTOP=2 : WCRITERE='VCRTYP='+num$(WCLE1)+' & VCRNUM="'+WCLE2+'" & IND>'+num$(WCLE3)
Elsif WSTOP=2
  WSTOP=3 : WCRITERE='VCRTYP='+num$(WCLE1)+' & VCRNUM>"'+WCLE2+'"'
Elsif WSTOP=3
  WSTOP=0 : WCRITERE='VCRTYP>'+num$(WCLE1)
Else
  WCRITERE="1=1"
Endif
Raz WCOMPTEUR
Trbegin [PVF]
  For [PVF] PVF1 Where find(VCRTYP,3,5)<>0 & AMTCOD=2 & evalue(WCRITERE)
    NBENR+=1
    WVCRTYP=[F:PVF]VCRTYP
    WVCRNUM=[F:PVF]VCRNUM
    WIND   =[F:PVF]IND
    #-----
    If len([F:PVF]FORMAT)>2 & right$([F:PVF]FORMAT,len([F:PVF]FORMAT)-1)="[]"
      WCOMPTEUR+=1
      Readlock [PVF] PVF1=WVCRTYP;WVCRNUM;WIND
      #----- Erreur d'accû´s sur le ficher PVCRFOOT -----#
      If fstat
        WMSG=mess(12,100,1)-"PVCRFOOT"-num$(WVCRTYP)-WVCRNUM-num$(WIND)
        Call ECR_TRACE(WMSG-"Error="+num$(fstat),0) From GESECRAN
        WSTOP=0 : Break 
      Endif
      #-----
      WMSG=num$(WVCRTYP)-WVCRNUM-num$([F:PVF]INVDTA)-":"-[F:PVF]FORMAT
      [F:PVF]FORMAT=left$([F:PVF]FORMAT,len([F:PVF]FORMAT)-1)+" ]"
      WMSG-="-->"-[F:PVF]FORMAT
      If WTRACE=2
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      If !WSIMFLG
        Rewrite [PVF]
      Else
        Unlock  [PVF]
      Endif
      #----- Erreur d'ûˋcriture sur le fichier PVCRFOOT -----#
      If fstat
        WMSG=mess(13,100,1)-"PVCRFOOT"-num$(WVCRTYP)-WVCRNUM-num$(WIND)
        Call ECR_TRACE(WMSG-"Error="+num$(fstat),0) From GESECRAN
        WSTOP=0 : Break
      #-----
      Else
        NBCOR+=1
      Endif
    Endif
    #-----
    If WCOMPTEUR>GMAXUPDTRS
      WCLE1=WVCRTYP : WCLE2=WVCRNUM : WCLE3=WIND : WSTOP=1 : Break
    Endif
  Next
Commit
If WSTOP  Goto BOUCLE_FMT1 : Endif
Return


#--------------------------------#
# Traitement des formats remises #
#--------------------------------#
$TRT_FMT2
If WTRACE=2
  Call ECR_TRACE("----- Format des remises",0) From GESECRAN
Endif
Call DEBTRANS From GLOCK
Raz WCLE1, WCLE2, WCLE3, WSTOP
$BOUCLE_FMT2
GOK=1
If WSTOP=1
  WSTOP=2 : WCRITERE='VCRTYP='+num$(WCLE1)+' & VCRNUM="'+WCLE2+'" & IND>'+num$(WCLE3)
Elsif WSTOP=2
  WSTOP=3 : WCRITERE='VCRTYP='+num$(WCLE1)+' & VCRNUM>"'+WCLE2+'"'
Elsif WSTOP=3
  WSTOP=0 : WCRITERE='VCRTYP>'+num$(WCLE1)
Else
  WCRITERE="1=1"
Endif
Raz WCOMPTEUR
Trbegin [PVF]
  For [PVF] PVF1 Where find(VCRTYP,3,5)<>0 & AMTCOD=1 & evalue(WCRITERE)
    NBENR+=1
    WVCRTYP=[F:PVF]VCRTYP
    WVCRNUM=[F:PVF]VCRNUM
    WIND   =[F:PVF]IND
    #-----
    WFORMAT=func TRTX3FNC.GETFMTREM(1)
    If len([F:PVF]FORMAT)>2 & [F:PVF]FORMAT<>WFORMAT
      WCOMPTEUR+=1
      Readlock [PVF] PVF1=WVCRTYP;WVCRNUM;WIND
      #----- Erreur d'accû´s sur le ficher PVCRFOOT -----#
      If fstat
        WMSG=mess(12,100,1)-"PVCRFOOT"-num$(WVCRTYP)-WVCRNUM-num$(WIND)
        Call ECR_TRACE(WMSG-"Error="+num$(fstat),0) From GESECRAN
        WSTOP=0 : Break 
      Endif
      #-----
      WMSG=num$(WVCRTYP)-WVCRNUM-num$([F:PVF]INVDTA)-":"-[F:PVF]FORMAT-"-->"-WFORMAT
      [F:PVF]FORMAT=WFORMAT
      If WTRACE=2
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      If !WSIMFLG
        Rewrite [PVF]
      Else
        Unlock  [PVF]
      Endif
      #----- Erreur d'ûˋcriture sur le fichier PVCRFOOT -----#
      If fstat
        WMSG=mess(13,100,1)-"PVCRFOOT"-num$(WVCRTYP)-WVCRNUM-num$(WIND)
        Call ECR_TRACE(WMSG-"Error="+num$(fstat),0) From GESECRAN
        WSTOP=0 : Break
      #-----
      Else
        NBCOR+=1
      Endif
    Endif
    If WCOMPTEUR>GMAXUPDTRS
      WCLE1=WVCRTYP : WCLE2=WVCRNUM : WCLE3=WIND : WSTOP=1 : Break
    Endif
  Next
Commit
If WSTOP  Goto BOUCLE_FMT2 : Endif
Return
