#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMFOVDE 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_PDEDAT
Onevent BEFORE_AREA Gosub AV_PDEDAT From W2PJMFOVDE
Return

$AV_PDEDAT
Chgfmt [M]PDEDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_OBJET
Return

$TIT_COL
Local Char TITCL(200)(1..20)
Raz TITCL
Case BASPAG
 When "NBCAT"
  TITCL(1) = func PJMFOVDE.COL_GET_TITLE(5)
  TITCL(2) = func PJMFOVDE.COL_GET_TITLE(6)
  TITCL(3) = func PJMFOVDE.COL_GET_TITLE(7)
  TITCL(4) = func PJMFOVDE.COL_GET_TITLE(8)
  TITCL(5) = func PJMFOVDE.COL_GET_TITLE(9)
  TITCL(6) = func PJMFOVDE.COL_GET_TITLE(10)
  TITCL(7) = func PJMFOVDE.COL_GET_TITLE(11)
  TITCL(8) = func PJMFOVDE.COL_GET_TITLE(12)
  TITCL(9) = func PJMFOVDE.COL_GET_TITLE(13)
  TITCL(10) = func PJMFOVDE.COL_GET_TITLE(14)
  TITCL(11) = func PJMFOVDE.COL_GET_TITLE(25)
  TITCL(12) = func PJMFOVDE.COL_GET_TITLE(26)
  TITCL(13) = func PJMFOVDE.COL_GET_TITLE(31)
  TITCL(14) = func PJMFOVDE.COL_GET_TITLE(32)
  TITCL(15) = func PJMFOVDE.COL_GET_TITLE(33)
  TITCL(16) = func PJMFOVDE.COL_GET_TITLE(34)
  TITCL(17) = func PJMFOVDE.COL_GET_TITLE(35)
  TITCL(18) = func PJMFOVDE.COL_GET_TITLE(36)
  TITCL(19) = func PJMFOVDE.COL_GET_TITLE(37)
  TITCL(20) = func PJMFOVDE.COL_GET_TITLE(38)
  If !GORITITCOL
   Titcol [M]NBCAT TITCL(1) For PDEQTY1
   Titcol [M]NBCAT TITCL(2) For PDEAMT1
   Titcol [M]NBCAT TITCL(3) For PDEQTY2
   Titcol [M]NBCAT TITCL(4) For PDEAMT2
   Titcol [M]NBCAT TITCL(5) For PDEQTY3
   Titcol [M]NBCAT TITCL(6) For PDEAMT3
   Titcol [M]NBCAT TITCL(7) For PDEQTY4
   Titcol [M]NBCAT TITCL(8) For PDEAMT4
   Titcol [M]NBCAT TITCL(9) For PDEQTY5
   Titcol [M]NBCAT TITCL(10) For PDEAMT5
   Titcol [M]NBCAT TITCL(11) For PDEQTY6
   Titcol [M]NBCAT TITCL(12) For PDEAMT6
   Titcol [M]NBCAT TITCL(13) For PDEQTY7
   Titcol [M]NBCAT TITCL(14) For PDEAMT7
   Titcol [M]NBCAT TITCL(15) For PDEQTY8
   Titcol [M]NBCAT TITCL(16) For PDEAMT8
   Titcol [M]NBCAT TITCL(17) For PDEQTY9
   Titcol [M]NBCAT TITCL(18) For PDEAMT9
   Titcol [M]NBCAT TITCL(19) For PDEQTY10
   Titcol [M]NBCAT TITCL(20) For PDEAMT10
  Else
   Titcol [M:PFODE]NBCAT TITCL(1) For PDEQTY1
   Titcol [M:PFODE]NBCAT TITCL(2) For PDEAMT1
   Titcol [M:PFODE]NBCAT TITCL(3) For PDEQTY2
   Titcol [M:PFODE]NBCAT TITCL(4) For PDEAMT2
   Titcol [M:PFODE]NBCAT TITCL(5) For PDEQTY3
   Titcol [M:PFODE]NBCAT TITCL(6) For PDEAMT3
   Titcol [M:PFODE]NBCAT TITCL(7) For PDEQTY4
   Titcol [M:PFODE]NBCAT TITCL(8) For PDEAMT4
   Titcol [M:PFODE]NBCAT TITCL(9) For PDEQTY5
   Titcol [M:PFODE]NBCAT TITCL(10) For PDEAMT5
   Titcol [M:PFODE]NBCAT TITCL(11) For PDEQTY6
   Titcol [M:PFODE]NBCAT TITCL(12) For PDEAMT6
   Titcol [M:PFODE]NBCAT TITCL(13) For PDEQTY7
   Titcol [M:PFODE]NBCAT TITCL(14) For PDEAMT7
   Titcol [M:PFODE]NBCAT TITCL(15) For PDEQTY8
   Titcol [M:PFODE]NBCAT TITCL(16) For PDEAMT8
   Titcol [M:PFODE]NBCAT TITCL(17) For PDEQTY9
   Titcol [M:PFODE]NBCAT TITCL(18) For PDEAMT9
   Titcol [M:PFODE]NBCAT TITCL(19) For PDEQTY10
   Titcol [M:PFODE]NBCAT TITCL(20) For PDEAMT10
  Endif
 When "NBDET"
  TITCL(1) = func PJMFOVDE.COL_GET_TITLE(5)
  TITCL(2) = func PJMFOVDE.COL_GET_TITLE(6)
  TITCL(3) = func PJMFOVDE.COL_GET_TITLE(7)
  TITCL(4) = func PJMFOVDE.COL_GET_TITLE(8)
  TITCL(5) = func PJMFOVDE.COL_GET_TITLE(9)
  TITCL(6) = func PJMFOVDE.COL_GET_TITLE(10)
  TITCL(7) = func PJMFOVDE.COL_GET_TITLE(11)
  TITCL(8) = func PJMFOVDE.COL_GET_TITLE(12)
  TITCL(9) = func PJMFOVDE.COL_GET_TITLE(13)
  TITCL(10) = func PJMFOVDE.COL_GET_TITLE(14)
  TITCL(11) = func PJMFOVDE.COL_GET_TITLE(25)
  TITCL(12) = func PJMFOVDE.COL_GET_TITLE(26)
  TITCL(13) = func PJMFOVDE.COL_GET_TITLE(31)
  TITCL(14) = func PJMFOVDE.COL_GET_TITLE(32)
  TITCL(15) = func PJMFOVDE.COL_GET_TITLE(33)
  TITCL(16) = func PJMFOVDE.COL_GET_TITLE(34)
  TITCL(17) = func PJMFOVDE.COL_GET_TITLE(35)
  TITCL(18) = func PJMFOVDE.COL_GET_TITLE(36)
  TITCL(19) = func PJMFOVDE.COL_GET_TITLE(37)
  TITCL(20) = func PJMFOVDE.COL_GET_TITLE(38)
  If !GORITITCOL
   Titcol [M]NBDET TITCL(1) For PDEQTY1D
   Titcol [M]NBDET TITCL(2) For PDEAMT1D
   Titcol [M]NBDET TITCL(3) For PDEQTY2D
   Titcol [M]NBDET TITCL(4) For PDEAMT2D
   Titcol [M]NBDET TITCL(5) For PDEQTY3D
   Titcol [M]NBDET TITCL(6) For PDEAMT3D
   Titcol [M]NBDET TITCL(7) For PDEQTY4D
   Titcol [M]NBDET TITCL(8) For PDEAMT4D
   Titcol [M]NBDET TITCL(9) For PDEQTY5D
   Titcol [M]NBDET TITCL(10) For PDEAMT5D
   Titcol [M]NBDET TITCL(11) For PDEQTY6D
   Titcol [M]NBDET TITCL(12) For PDEAMT6D
   Titcol [M]NBDET TITCL(13) For PDEQTY7D
   Titcol [M]NBDET TITCL(14) For PDEAMT7D
   Titcol [M]NBDET TITCL(15) For PDEQTY8D
   Titcol [M]NBDET TITCL(16) For PDEAMT8D
   Titcol [M]NBDET TITCL(17) For PDEQTY9D
   Titcol [M]NBDET TITCL(18) For PDEAMT9D
   Titcol [M]NBDET TITCL(19) For PDEQTY10D
   Titcol [M]NBDET TITCL(20) For PDEAMT10D
  Else
   Titcol [M:PFODE]NBDET TITCL(1) For PDEQTY1D
   Titcol [M:PFODE]NBDET TITCL(2) For PDEAMT1D
   Titcol [M:PFODE]NBDET TITCL(3) For PDEQTY2D
   Titcol [M:PFODE]NBDET TITCL(4) For PDEAMT2D
   Titcol [M:PFODE]NBDET TITCL(5) For PDEQTY3D
   Titcol [M:PFODE]NBDET TITCL(6) For PDEAMT3D
   Titcol [M:PFODE]NBDET TITCL(7) For PDEQTY4D
   Titcol [M:PFODE]NBDET TITCL(8) For PDEAMT4D
   Titcol [M:PFODE]NBDET TITCL(9) For PDEQTY5D
   Titcol [M:PFODE]NBDET TITCL(10) For PDEAMT5D
   Titcol [M:PFODE]NBDET TITCL(11) For PDEQTY6D
   Titcol [M:PFODE]NBDET TITCL(12) For PDEAMT6D
   Titcol [M:PFODE]NBDET TITCL(13) For PDEQTY7D
   Titcol [M:PFODE]NBDET TITCL(14) For PDEAMT7D
   Titcol [M:PFODE]NBDET TITCL(15) For PDEQTY8D
   Titcol [M:PFODE]NBDET TITCL(16) For PDEAMT8D
   Titcol [M:PFODE]NBDET TITCL(17) For PDEQTY9D
   Titcol [M:PFODE]NBDET TITCL(18) For PDEAMT9D
   Titcol [M:PFODE]NBDET TITCL(19) For PDEQTY10D
   Titcol [M:PFODE]NBDET TITCL(20) For PDEAMT10D
  Endif
Endcase
Return

$CHG_STY
Return


