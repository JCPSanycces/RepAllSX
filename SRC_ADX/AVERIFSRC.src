#____________________________________________________________________________________
# traite les CHECK... etsupprime la partie commentaire d'une ligne


# PREINIT           réinitialiser à vide la chaine si l'action sur les CHECK le demande
#                   (toujours à 1 sauf en phase 1 du VERIFCALL où il faut tout charger)

# PVERIFIDX         ignorer le contrôle des indexes : juste pour XVERIFIDX (toujours à 0 sauf...)

# RFILE             table trouvée pour #CHECK FILE_DECLARE
# RABREV            abréviation trouvée pour #CHECK FILE_DECLARE
#                   A ajouter dans le tableau  au retour de cette fonction : il faut lire ATABLE pour compléter
#                   le tableau des abrev standard

# RIGNWRSEQ         initialiser à 0 en début de contrôle d'un source
# RIGNWRTRT         initialiser à 0 en début de contrôle d'un source
#                   1 ignorer tout le source : il ne faut plus analyser le source : à tester en retour de cette fonction
#                   2 phase #CHECK IGNORE_BEGIN
#                   3 ignorer tout le source (même en phase 1 du CAll) CHECK UNUSED
#                   4 ignorer la suite (même en phase 1 du CAll) CHECK UNUSED_BEGIN

# RMIGRATE          initialiser à 0 en début de contrôle d'un source
#                   source de migration ou utilitaire : ne pas analyser les erreurs
#                   dont le n° est contenu dans le tableau de Booléen GTMIGRATE

Subprog VIRECOMCHK(PCHAINE, PREINIT, PVERIFIDX, RFILE, RABREV, RIGNWRSEQ, RIGNWRTRT, RMIGRATE)

Variable Clbfile PCHAINE

Value Integer PREINIT
Value Integer PVERIFIDX

Variable Char RFILE
Variable Char RABREV

Variable Integer RIGNWRSEQ
Variable Integer RIGNWRTRT
Variable Integer RMIGRATE


Local Integer ID
Local Char WCHAINE(50)



    Raz RFILE, RABREV

#CHECK IGNORE_BEGIN
# Phase recherche d'1 CHECK


# CBO 20110111 FQ70150
# pour gérer #CHECK FILE_DECLARE et #CHECK MASK_DECLARE
# faire RIGNWRTRT += 20 pour file et += 30 pour MASK


# en retour de ce call :

# SI >= 20 ET < 30 :
# c'est un file, faire...
# RIGNWRTRT -= 20
#
# SI >= 30 ET < 40 :
# c'est un mask, faire...
# RIGNWRTRT -= 30
# --> gérer le tableau des abrev de masques non std (même lmogique que celui des tables)
#



    If instr(1, PCHAINE, "#CHECK ")
        If instr(1, PCHAINE, "#CHECK FILE_DECLARE")
            # recherche du fichier et de l'abrev

            WCHAINE = vireblc(PCHAINE, 4)
            WCHAINE = right$(WCHAINE, instr(1, WCHAINE, "DECLARE") + 7)

            ID =  instr(1, WCHAINE, "[")
            If ID = 0
                PCHAINE = ""
                End
            Endif
            RFILE = left$(WCHAINE, ID - 1)
            RABREV = right$(WCHAINE, ID + 1)
            RABREV = left$(RABREV, len(RABREV) - 1)

            PCHAINE = ""
            # CBO 20110111 FQ70150
            RIGNWRTRT += 20
            End

        # CBO 20110111 FQ70150
        Elsif instr(1, PCHAINE, "#CHECK MASK_DECLARE")
            # recherche du masque et de l'abrev

            WCHAINE = vireblc(PCHAINE, 4)
            WCHAINE = right$(WCHAINE, instr(1, WCHAINE, "DECLARE") + 7)

            ID =  instr(1, WCHAINE, "[")
            If ID = 0
                PCHAINE = ""
                End
            Endif
            RFILE = left$(WCHAINE, ID - 1)
            RABREV = right$(WCHAINE, ID + 1)
            RABREV = left$(RABREV, len(RABREV) - 1)

            PCHAINE = ""
            RIGNWRTRT += 30
            End
        Elsif PVERIFIDX = 1 and instr(1, PCHAINE, "#CHECK IGNORE_INDEX")
            PCHAINE = ""
            End
        Elsif instr(1, PCHAINE, "#CHECK IGNORE_LINE")
            If PREINIT
                PCHAINE = ""
                End
            Endif
        Elsif instr(1, PCHAINE, "#CHECK IGNORE_WRSEQ")
            RIGNWRSEQ = 1
            End
        Elsif instr(1, PCHAINE, "#CHECK IGNORE_SOURCE")
            RIGNWRTRT = 1
            End
        Elsif instr(1, PCHAINE, "#CHECK UNUSED_SOURCE")
            RIGNWRTRT = 3
            End
        Elsif instr(1, PCHAINE, "#CHECK MIGRATE_SOURCE")
            RMIGRATE = 1
            End
            # => de sortir de la boucle de trt du source au retour de la fonction
        Elsif instr(1, PCHAINE, "#CHECK IGNORE_BEGIN")
            RIGNWRTRT = 2
        Elsif instr(1, PCHAINE, "#CHECK UNUSED_BEGIN")
            RIGNWRTRT = 4
        Elsif instr(1, PCHAINE, "#CHECK IGNORE_END")
            RIGNWRTRT = 0
        Elsif instr(1, PCHAINE, "#CHECK UNUSED_END")
            RIGNWRTRT = 0
        Elsif instr(1, PCHAINE, "#CHECK WRSEQ_END")
            RIGNWRSEQ = 0
        Endif
    Endif


# Phase éxécution d'1 CHECK
#CHECK IGNORE_END

    # On est en ignore begin...
    If RIGNWRTRT = 2 and PREINIT
        PCHAINE = ""
        End
    Endif
#CBO 20110111 FQ69707 traitement de PIGNWRSEQ passé de VIRECOMCHK à DECOUPCH
#cbowrseq
#    # on est en ignore Wrseq et on en trouve un
#    If RIGNWRSEQ = 1 and PREINIT and pat(PCHAINE, "*Wrseq*")
#        PCHAINE = ""
#        End
#    Endif
     # On est en ignore unused begin...
    If RIGNWRTRT = 4
        PCHAINE = ""
        End
    Endif


# partie de traitement de commentaire (simple)

    # Si la chaine est toute un commentaire
    If left$(PCHAINE, 1) = "#" or left$(PCHAINE, 2) = " #"
        PCHAINE = ""
        End
    Endif

    # trouve-t'on un commentaire en fin de chaine
    ID = instr(1, PCHAINE, "#")

    If ID
        # vérifier si on n'est pas ds une chaine "ddd: #" ou 'ddd:#'
        If func DANSQUOTE(PCHAINE, ID) = 0
            PCHAINE = left$(PCHAINE, ID - 1)
        Endif
    Endif
End

Subprog LIBCHPATZ(PLANGUE, PMASQUE, PCHAMP, RLIBELLE)
Value Char PLANGUE, PMASQUE, PCHAMP
Variable Char RLIBELLE

    Read [AMZ]CODE = PMASQUE ; PCHAMP
    If fstat
        RLIBELLE = ""
    Else
        Read [ATX]NUMERO =PLANGUE ; [F:AMZ]INTIT
        RLIBELLE = [F:ATX]TEXTE
    Endif
End

