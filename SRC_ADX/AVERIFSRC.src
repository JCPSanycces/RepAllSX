Subprog C_OWNER(VALEUR)
#----------------#
# Contrôle owner #
#----------------#
Variable Char    VALEUR()
Local Integer OWNER

    If VALEUR <> ""
        Call OWNER_FROM_NAME (VALEUR, [L]OWNER) From XXOWNER
        If [L]OWNER=0
            Call ERREUR("Ce owner n'est pas connu") From GESECRAN
            mkstat=2
        Endif
    Endif

End



######################################################################################
Subprog AV_TRACE(VALEUR)
Variable Integer VALEUR

    If GADXPNO1
#        Effzo [M:DIA]TRACE
#        Effzo [M:DIA]TRACENAME
        Diszo [M:DIA]TRACE, TRACENAME
    Else
        Diszo [M:DIA]TRACENAME
    Endif
End
Subprog AM_TRACE(VALEUR)
#-------------------#
# Contrôle trace #
#-------------------#
Variable Integer VALEUR

    If VALEUR = 1
        [M:DIA]TRACENAME = ""
        Diszo [M:DIA]TRACENAME
    Else
        If GAWNUMPATCH = 0
            If [M:DIA]TRACENAME = ""
                [M:DIA]TRACENAME = "Verif.txt"
            Endif
            Actzo [M:DIA]TRACENAME
        Else
            Actzo [M:DIA]NUMPATCH, SRCPATCH, TRACENAME    #CHECK IGNORE_LINE
            If [M:DIA]TRACENAME = ""
                [M:DIA]TRACENAME = "VerifPatch" + num$(GAWNUMPATCH) + ".txt"
            Endif
        Endif
    Endif

    If GAWACTIVITE
        Affzo [M:DIA]NUMPATCH, SRCPATCH, TRACENAME        #CHECK IGNORE_LINE
    Endif

End

Subprog C_PARMODULE(VALEUR)
Variable Integer VALEUR

    GTRTPARMODULE += 1
End
