Subprog AV_PRODUIT(VALEUR)
Variable Integer VALEUR

    If    [M:DIA]INDUSPRD = 0
        Grizo [M:DIA]PRODUIT
    Endif
End


Subprog AM_PRODUIT(VALEUR)
Variable Integer VALEUR

    Call FDOSSIERNV (VALEUR, [M:DIA]VERSION, [M:DIA]NUMPATCH,
&                    [M:DIA]DOSSIER, GAWPORT, GAWMACHINE, GAWSRCPATCH)    #CHExxCK IGNORE_LINE

    If GAWACTIVITE
        [M:DIA]PORT = GAWPORT
        [M:DIA]MACHINE = GAWMACHINE
        [M:DIA]SRCPATCH = GAWSRCPATCH
        Affzo [M:DIA]DOSSIER, PORT, MACHINE, SRCPATCH
    Endif

    Call FLASTPATCH ()

End

Subprog AM_VERSION(VALEUR)
Variable Integer VALEUR

    Call FDOSSIERNV ([M:DIA]PRODUIT, VALEUR, [M:DIA]NUMPATCH,
&                    [M:DIA]DOSSIER, GAWPORT, GAWMACHINE, GAWSRCPATCH)    #CHECK IGNORE_LINE

    If GAWACTIVITE
        [M:DIA]PORT = GAWPORT
        [M:DIA]MACHINE = GAWMACHINE
        [M:DIA]SRCPATCH = GAWSRCPATCH
        Affzo [M:DIA]DOSSIER, PORT, MACHINE, SRCPATCH
    Endif

    Call FLASTPATCH ()

End

