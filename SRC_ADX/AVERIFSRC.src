Return

$ERRDOSSIER

    TPASFIC(IFIC) = 1

Resume

Subprog RECAPMOUL(PDEB, PFIN, RTTERREUR)
Value Integer PDEB, PFIN
Variable Integer RTTERREUR()

Local Integer INDERREUR, IB
Local Char WTEXTE(250)

    For INDERREUR = PDEB To PFIN

        If GTLIBERREUR(GNUMMOUL, INDERREUR) <> "" and GBTDESACTIVE(GNUMMOUL, INDERREUR) = 0
            If GBTWARNING(GNUMMOUL, INDERREUR)
                WTEXTE = mess(55, 144, 1)
            Else
                WTEXTE = mess(56, 144, 1)
            Endif
            WTEXTE = WTEXTE - num$(INDERREUR + ((GNUMMOUL - 1))* 100 )

            If GBTDESACTIVE(GNUMMOUL, INDERREUR)
                If INDERREUR > 9
                    WTEXTE = WTEXTE + " (désactivée)"
                Else
                    WTEXTE = WTEXTE + "  (désactivée)"
                Endif
            Else
                If INDERREUR > 9
                    WTEXTE = WTEXTE + " Nombre :"
                Else
                    WTEXTE = WTEXTE + "  Nombre :"
                Endif
                WTEXTE = WTEXTE  - num$(RTTERREUR(INDERREUR))
            Endif

            IB = len(WTEXTE)
            IB = 40 - IB

            If IB > 0
                WTEXTE = WTEXTE + string$(IB, " ")
            Else
                WTEXTE = WTEXTE
            Endif
            If GBTWARNING(GNUMMOUL, INDERREUR)
                Wrseq WTEXTE + GTLIBERREUR(GNUMMOUL, INDERREUR) Using [FWR]
            Else
                Wrseq WTEXTE + GTLIBERREUR(GNUMMOUL, INDERREUR) Using [FER]
            Endif
        Endif

        Next INDERREUR
End
# --------------------------------------------------------------------------------------------------------------
Funprog TITREFMT(PCHAINE, PLGVOULUE)
Value Char PCHAINE
Value Integer PLGVOULUE

Local Integer IB


    IB = len(PCHAINE)
    IB = PLGVOULUE - IB

    If IB > 0
        PCHAINE = PCHAINE + string$(IB, " ")
    Endif

End PCHAINE


# Ecrire un message à plusieurs paramètres
Funprog MESNUM(PNUMMESS, PCHAPMESS, PVAR1, PVAR2, PVAR3, PVAR4, PVAR5)
Value Integer PNUMMESS, PCHAPMESS
Value Char PVAR1, PVAR2, PVAR3, PVAR4, PVAR5

Local Char WMESS(200)

    WMESS = mess(PNUMMESS, PCHAPMESS, 1)

    If PVAR1 = ""
        End WMESS
    Endif

End func AFNC.MES5(WMESS, PVAR1, PVAR2, PVAR3, PVAR4, PVAR5)




# --------------------------------------------------------------------------------------------------------------



# recherche du dossier
Subprog FDOSSIERNV (PPRODUIT, PVERSION, PPATCH,
&                 RDOSSIER, RPORT, RMACHINE, RSRCPATCH)
Value Shortint PPRODUIT
Value Shortint PVERSION
Value Shortint PPATCH

Variable Char RDOSSIER()
Variable Integer RPORT
Variable Char RMACHINE(), RSRCPATCH()


    RPORT = 0
    RMACHINE = ""
    RSRCPATCH = ""

    Read [XID]XID1 = PPRODUIT ; PVERSION
    If fstat
        mkstat = 2
        Call ERREUR("Couple produit" -  mess(PPRODUIT, 2402, 1) - "/ version" - mess(PVERSION, 2411, 1) - "non trouvé")
&       From GESECRAN
        End
    Endif

    RDOSSIER = [F:XID]XDOSIND
    RPORT = [F:XID]XSERVICE
    If dim([F:XID]XMACHIND) < 0
        RMACHINE = "aydaix06" : RMACHINE = "aws-x3-indv5"
    Else
        RMACHINE = [F:XID]XMACHIND
    Endif

#CHECK IGNORE_BEGIN

    If PPATCH
        If PVERSION < 7
            RSRCPATCH = [F:XID]XDOSREPVER
            RSRCPATCH = RSRCPATCH + "/" + [F:XID]XCOD + mess([F:XID]XVERM, 2411, 1) + "_P" + num$(PPATCH) + "/SRC"
        Else
            RSRCPATCH = [F:XID]XDOSREPPAT + "/" + "V" + ctrans([F:XID]XVERX, ".", "") + "/"
            RSRCPATCH = RSRCPATCH  + [F:XID]XCOD + mess([F:XID]XVERM, 2411, 1) + "_P" +num$(PPATCH) + "/" + "SRC"
        Endif
    Endif
#CHECK IGNORE_END

End


Subprog FDOSSIER (PPRODUIT, PVERSION, PPATCH)
Value Shortint PPRODUIT
Value Shortint PVERSION
Value Shortint PPATCH

    Read [XID]XID1 = PPRODUIT ; PVERSION
    If fstat
        mkstat = 2
        Call ERREUR("Couple produit" -  mess(PPRODUIT, 2402, 1) - "/ version" - mess(PVERSION, 2411, 1) - "non trouvé")
&       From GESECRAN

    Else
        [M:DIA]DOSSIER = [F:XID]XDOSIND
        # CBO 20110331
#        [M:DIA]DOSSIER = mess([F:XID]XDOSINDLM, 3005, 1)
        Affzo [M:DIA]DOSSIER
    Endif
#CHECK IGNORE_BEGIN
    If GAWACTIVITE
        If GAWACTIVITE = 10
            End
        Endif
        If GAWACTIVITE = 5
            [M:DIA]PORT = [F:XID]XSERVICE
            [M:DIA]MACHINE = [F:XID]XMACHIND
            Affzo [M:DIA]PORT, MACHINE
            End
        Endif

        If PPATCH
            If PVERSION < 7
                [M:DIA]SRCPATCH = [F:XID]XDOSREPVER
                [M:DIA]SRCPATCH = [M:DIA]SRCPATCH + "/" + [F:XID]XCOD + mess([F:XID]XVERM, 2411, 1) + "_P" + num$(PPATCH) + "/SRC"
            Else
                [M:DIA]SRCPATCH = [F:XID]XDOSREPPAT + "/" + "V" + ctrans([F:XID]XVERX, ".", "") + "/"
                [M:DIA]SRCPATCH = [M:DIA]SRCPATCH  + [F:XID]XCOD + mess([F:XID]XVERM, 2411, 1) + "_P" +num$(PPATCH) + "/" + "SRC"
            Endif
        Else
            [M:DIA]SRCPATCH  = ""
        Endif

         Affzo [M:DIA]SRCPATCH
    Endif
#CHECK IGNORE_END
    GAWPORT = [F:XID]XSERVICE
    If PVERSION < 7  : # avant la version 6 on n'a pas l'info sur XIDINDPRD (info ajoutéé dans XID à partir du 15/05/2009 par JPGA)
        If dim([F:XID]XMACHIND) < 0
           GAWMACHINE = "aydaix06" : GAWMACHINE = "aws-x3-indv5"
        Else
           GAWMACHINE = [F:XID]XMACHIND
        Endif
    Else
        If dim([F:XID]XMACHIND) < 0
            GAWMACHINE = "aydaix05" : GAWMACHINE = "aws-x3-devx3"
        Else
            GAWMACHINE = [F:XID]XMACHIND
        Endif
    Endif

    If GAWACTIVITE
        [M:DIA]PORT = [F:XID]XSERVICE
        [M:DIA]MACHINE = GAWMACHINE

        Affzo [M:DIA]PORT, MACHINE
    Endif

End
#___________________________
# recherche du dernier patch




Subprog FLASTPATCHNV (PXVERM, PXPATQLT,
&                     PCOD, PVERX,
&                     RPATCHMAXI)
Value Integer PXVERM, PXPATQLT
Value Char PCOD(), PVERX()
Variable Shortint RPATCHMAXI



    If PXVERM >= 7   # V6 et plus
        RPATCHMAXI = PXPATQLT
        End
    Endif

    RPATCHMAXI = 1

    Local File = "aws-x3-indv5:15005@MNTPRD.XXMNT" [XXM2]
    Filter[XXM2] Where XXXVER =  PVERX and XXXPRD = PCOD and XXXNUM > 0 and XXXPAT > 0 Order By XXXPAT
    Read[XXM2] Last

    If fstat = 0
        RPATCHMAXI = [F:XXM2]XXXPAT
    Endif
    Filter[XXM2]
    Close File [XXM2]
End

Subprog FLASTPATCH ()

Local Shortint MXPATCH

    Call FLASTPATCHNV ([F:XID]XVERM, [F:XID]XPATQLT,
&                       [F:XID]XCOD, [F:XID]XVERX,
&                      MXPATCH)

    [M:DIA]NBPATCH = [F:XID]XPATQLT #CHECK IGNORE_LINE
    Affzo [M:DIA]NBPATCH  #CHECK IGNORE_LINE
End

