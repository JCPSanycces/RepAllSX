Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
    Call TRAITE_CHAR(VALBOUT, PARBOUT, "", "AVERIFSRC", "AVERIFSRC", 3, "") From GTRAITE
End

$ACTION
Case ACTION
    When "INIT_DIA"     : Gosub INIT_DIA
    When "CONTROLE"     : Gosub CONTROLE
    When "EXEC"         : Gosub EXEC
    When "TERMINE"      : Gosub TERMINE
Endcase
Return

#________
$INIT_DIA
Global Integer GNBERRTOT, GNBWARNTOT, GADXPNO1

Local Char PATCH(3)          : # numéro du patch éventuel
Global Char GXDOSSIER(GLONADS) : # Globale dossier pour le workflow
Local Char CHEMINTRA(128)    : # chemin du fichier trace
Local Char CHEMINSRC(128)    : # chemin contenant les sources du patch
Local Integer NUMOWNER          : # owner des fichiers éventuel
Local Char CHEMINTRAW(128), WTRACENAME(128), WTRACENAMEW(128)
Local Integer BSRCWARNING    : # création (+ ouverture) du fichier pour les warning
Local Integer NBERRTOT, NBWARTOT, I, WNUMERREUR, NBERRCHECK, NBWARCHECK, NBDELTAERR, NBDELTAWAR, SUPERTOT

Local Integer NBLCLMSK, TBMODULE(21), WMINMODULE, WMAXMODULE, WMOTCOMPLET, WCH1ET2
#Infbox adxpno(0) - adxpno(1) - adxpno(2)
If instr(1, adxpno(1), "ARQTPAR") or instr(1, adxpno(1), "ARQTPAB")
    GADXPNO1 = 1
Else
    GADXPNO1 = 0
Endif

Local Char WCODOPE(100)(1..20), WOPE(5), WSVTRACE(50)
Local Shortint WRANG
Global Integer GTRTPARMODULE
# a intégrer en paramètre pour Sage dev puis les distri...

Local Integer WNVDEMANDEUR

# on a besoin de pas mal de mémoire pour certaines vérifs
maxmem = max(int(maxmem/1024),512000)

Local Char LIBCALL(80),  LIBRAZ(80),  LIBDAC(80),  LIBVAR(80),  LIBCTLU(80)
Local Char LIBAUT(80),  LIBMOD(80),  LIBDIC(80),  LIBDOC(80),  LIBTYPE(80)
Local Char LIBSSMODULE(80),  LIBTRTNA(80), LIBREFCRX(80), WLIB(80)
#############################################################################################################
# Liste de variable déclarées en global pour VERIFCALL phase 1 :
# cela évite de la faire tourner à chaque fois qu'on traite trié par module
# Elles seront détruite après
#GT... comme global temporaire


Global Integer GMAX_SOUSPRO, GMAX_VAR, GMAX_TRT, GMAX_ZONEMSK, GMAX_TYPE
Global Integer GMAX_LGSSPRO, GMAX_NBPAR, GMAX_NBFIC, GMAX_ZONEFIC, GMAX_NBMSK
#Global Integer GLG_TRT

#Dimension des tableaux:
#Comment retailler automatiquement (ou presque)…
#En dynamique ds le trt  pour
# - les GTGOS, GTGOSB, GTGOSC
# - GTSOUSPRO avec les fics associés
# - GTZONMSK GTZONMSKB
# - GTZONES

#Si on dépasse, on fait :
#- A l’affectation
#cptrGTGOS += 1
# evalue(‘ Global Char GTGOS’ + num$( cptrGTGOS) + ‘(1..10, 1..GMAX_SOUSPRO)’)
#- A la recherché : soit un Evalue soit le test avec un nombre de cas finis
#- Faire le kill en fct de chaque compteur
# prévoir un max d'incrément (genre 10 pour ne pas ecraser 1 disque dur par ex...)

GMAX_TRT     = 15000

GMAX_SOUSPRO = 20000
GMAX_LGSSPRO = 50

GMAX_NBFIC   = 2000
GMAX_ZONEFIC = 32767

GMAX_NBMSK   = 4000
GMAX_ZONEMSK = 32767

GMAX_NBPAR   = 100
GMAX_TYPE    = 1000
GMAX_VAR     = 6000

# débloquer pour tailler plus largement les tableaux pour les sources générés W
# on peut alors avoir des pbs de mémoire
#      GMAX_TRT     = 15000
#      GMAX_SOUSPRO = 20000
#      GMAX_NBMSK   = 4000
#      maxmem = max(int(maxmem/1024),512000)
# fin de débloquer pour trt en W


Global Char GPREFIXE(10), GSANSLG(30)
GPREFIXE = "GLON"
GSANSLG = "LG NON DEF"


Global Integer NS1, NG1, GNBTRTADX, NBFI, NBMA, NBZM, NBZMB

Local Char TLCLMSK(20)(GMAX_NBMSK) : # ce tableau est chargé dans AVERIFVAR et utilisé dans xxVERIFECR
                                     # il contient les masques déclarés en local

Global Integer GTPPTPRO(1..GMAX_SOUSPRO), GTPPTGOS(1..GMAX_SOUSPRO)
Global Char GTSOUSPRO(GMAX_LGSSPRO)(1..10, 1..GMAX_SOUSPRO)
Global Char GTGOS(GMAX_LGSSPRO)(1..10, 1..GMAX_SOUSPRO), GTGOSB(GMAX_LGSSPRO)(1..10, 1..GMAX_SOUSPRO), GTGOSC(GMAX_LGSSPRO)(1..10, 1..GMAX_SOUSPRO)
Global Char GTPROGUNUSED(GMAX_LGSSPRO)(1000)

#GMAX_NBARG REMPLACÉ PAR GMAX_SOUSPRO
Global Libelle GTTYPARG(0..GMAX_NBPAR, 1..10, 1..GMAX_SOUSPRO)
Global Libelle GTTYPFUNP(1..10, 1..GMAX_SOUSPRO) : # Si non nul, le sous-programme est un Funprog et le type s'y trouve,
Global Libelle GTTYPZO(1..GMAX_ZONEFIC), GTTYPTYP(1..GMAX_TYPE)

Global Char GTTRAITEMENTS(GLONADC)(1..GMAX_TRT), GTFICHIERS(GLONABR)(1..GMAX_NBFIC), GTZONES(GLONAVA)(1..GMAX_ZONEFIC)
Global Integer GTINDFIC(1..GMAX_NBFIC), GTINDMAS(1..GMAX_NBMSK), GNBPROGUNUSED
Global Char GTMASQUES(GLONABR)(1..GMAX_NBMSK)
Global Libelle GTTYPMZO(1..GMAX_ZONEMSK), GTTYPMZOB(1..GMAX_ZONEMSK)
Global Char GTZONMSK(GLONAVA)(1..GMAX_ZONEMSK), GTZONMSKB(GLONAVA)(1..GMAX_ZONEMSK)

# ce tableau est chargé dans VERIFCALL et utilisé dans VERIFTYPE

# lu ds les trts étudiés
Global Char GTVARGLOB(16)(GMAX_VAR), GPROGVARGLOB(12)(GMAX_VAR)
Global Shortint GTYPVARGLOB(GMAX_VAR)
Global Integer GTLGVARGLOB(GMAX_VAR)
Global Char GLIBTYPGLOB(30)(1..GMAX_VAR)

# lu dans la table du dico AGB
Global Char GTVARGLOBDIC(16)(GMAX_VAR)
Global Shortint GTYPVARGLOBDIC(GMAX_VAR)
Global Integer GTLGVARGLOBDIC(GMAX_VAR)
Global Char GWLIBERREURS(10), GWLIBANOMALIES(10)

# lu dans les sources GLON
Global Char GTVARGLOBSRC(20)(GMAX_VAR)
Global Integer GTLGVARGLOBSRC(GMAX_VAR)

# pour sortie indics
Global Integer GVALCBO(1000)

Local Integer NBVARGLOB, NBVARGLOBDIC, NBVARGLOBSRC


#spécif pour vérifvar

Global Char GTFICHIERSV(GLONABR)(GMAX_NBFIC), GTZONESV(GLONAVA)(GMAX_ZONEFIC)
Global Integer GTINDFICV(GMAX_NBFIC)
Global Integer GNBFIV, GNBZOV
Global Char GAWDOSDISTRI(20), GAWDOSSPECIF(20)

# N° moulinette, n° module et n° erreur
Global Integer GCUMULERR
# GCUMULERR sert à cumuler l'erreur (ss recap par module)
GCUMULERR = 23

# regroupement des libellés des messages d'erreur (1° indice = moulinette, 2° = n° erreur)

Global Integer GNB_MOUL
GNB_MOUL = 11

Global Integer GTRECAPERR(GNB_MOUL, GCUMULERR + 1, 52)
# passage 1 fois en chargement et/ou en passe 1
Global Integer GNBERREUR(GNB_MOUL), GCONTROLE, GBTWARNING(GNB_MOUL, 100), GBTDESACTIVE(GNB_MOUL, 100), GNUMMOUL
Global Char GTLIBERREUR(100)(GNB_MOUL, 100)

# erreurs à ne pas contrôler si #CHECK MIGRATE_SOURCE
Global Integer GTMIGRATE(GNB_MOUL, 100)

Local Integer WPASSE1CALL, WPASSE1VAR, WBLISTETRT, WACTIVITE
WPASSE1CALL = 0
WPASSE1VAR = 0
WBLISTETRT = 0


# variables globales : Gestion de code activité :

Global Integer GAWACTIVITE, GAWPORT, GAWNUMPATCH, GAWNBPATCH, GAWVERSION
Global Char GAWMACHINE(10), GAWSRCPATCH(60)
Global Integer GAWVERIFCALL, GAWVERIFVAR, GAWVERIFRAZ, GAWVERIFCTLU, GAWVERIFIDX, GAWVERIFMOD
Global Integer GAWVERIFDAC, GAWVERIFTYPE, GAWVERIFDIC, GAWREFCRX, GAWVERIFDOC, GAWVERIFAUT, GAWTRTNA
Global Integer GAWSANSMODULE, GAWNUMERR, GAWECREXP, GAWLONGUEURDT, GAWPARMODULE, GAWEXCLSUPERV
Global Char GAWTYPEDT(3), GAWOWNER(10)

# sert à savoir (quand on revient ds la fonction) qu'on analyse une instruction
# d'1 ligne du type if cond instr1 else instr2 endif
Global Char GREPEREIF(6)
Global Integer GCPTDBG
GREPEREIF = "XCBOX"

#############################################################################################################


    Raz [M:DIA]
#    GAWACTIVITE = func AFNC.ACTIV("AM2")

    If (nomap(0) = "MNTPRD" or nomap(0) = "INDUSPRD") and dim([M:DIA]PRODUIT) >= 0
        GAWACTIVITE = 1

        If clalev ([F:XID])
            Close File [XID]
        Endif
        Local File = "XIDPRDIND" [XID]            : # table des produits industrialisés (Indus)

        [M:DIA]INDUSPRD = 1
        WNVDEMANDEUR = 0
    Else
        GAWACTIVITE = 0

        GAWMACHINE = ""
        GAWPORT = 0
        If GAWACTIVITE
            [M:DIA]MACHINE = ""
            [M:DIA]PORT = 0
        Endif
        [M:DIA]DOSSIER = nomap(0)

        [M:DIA]INDUSPRD = 0
        WNVDEMANDEUR = 5

    Endif

    Gosub CHGLIBERR

    GAWNUMPATCH = 0
    GAWNBPATCH = 0
    GAWSRCPATCH = ""
    GAWVERSION = 7
    If [M:DIA]INDUSPRD
        [M:DIA]PRODUIT = 1
        If nomap(0) = "MNTPRD"
            [M:DIA]VERSION =  6    :# 7 = version 6    6 = version 5
        Else
            [M:DIA]VERSION =  7
        Endif

        GAWVERSION = [M:DIA]VERSION
        [M:DIA]NUMPATCH = 0     #CHECK IGNORE_LINE
        [M:DIA]SRCPATCH = ""    #CHECK IGNORE_LINE
    Endif

    # actions toujours valides
    GAWVERIFCALL  = 1
    GAWVERIFVAR   = 1

    # actions soumies à code activité
    GAWVERIFRAZ   = 1
    GAWVERIFCTLU  = 1
    GAWVERIFIDX   = 1
    GAWVERIFMOD   = 1
    GAWVERIFDAC   = 1

    GAWVERIFTYPE  = 1
    GAWVERIFDIC   = 1
    GAWREFCRX     = 1
    GAWVERIFDOC   = 1
    GAWVERIFAUT   = 1

    GAWTRTNA      = 1
    GAWSANSMODULE = 1

    GAWNUMERR = 0
    GAWECREXP = 1
    GAWLONGUEURDT = 0
    GAWTYPEDT = ""
    GAWPARMODULE = 1
    GAWEXCLSUPERV = 1
    GAWOWNER = ""

    # actions toujours valides
    [M:DIA]VERIFVAR  = GAWVERIFVAR
    [M:DIA]VERIFCALL = GAWVERIFCALL

    # actions soumies à code activité
    If GAWACTIVITE
        [M:DIA]VERIFRAZ=1
        [M:DIA]VERIFCTLU=1
        [M:DIA]VERIFIDX=1     #CHECK IGNORE_LINE
        [M:DIA]VERIFMOD=1
        [M:DIA]VERIFDAC=1

        [M:DIA]VERIFTYPE=1    #CHECK IGNORE_LINE
        [M:DIA]VERIFDIC=1
        [M:DIA]REFCRX=1       #CHECK IGNORE_LINE
        [M:DIA]VERIFDOC=1
        [M:DIA]VERIFAUT=1

        [M:DIA]TRTNA=1        #CHECK IGNORE_LINE
        [M:DIA]SANSMODULE = 1 #CHECK IGNORE_LINE

        [M:DIA]NUMERR = 0
        [M:DIA]ECREXP=1
        [M:DIA]PARMODULE = 1
        [M:DIA]EXCLSUPERV = 1   #CHECK IGNORE_LINE
    Else
        If WNVDEMANDEUR > 5
            GAWEXCLSUPERV = 2
        Else
            GAWEXCLSUPERV = 1
        Endif
    Endif

    [M:DIA]NOMSRC="*"
    [M:DIA]TRACENAME=""
    WTRACENAME = ""
    WTRACENAMEW = ""
    GTRTPARMODULE = 0
    [M:DIA]TRACE=1

    Diszo [M:DIA]TRACENAME
#    Infbox adxpno(0)
#    Infbox adxpno(1)
#    Infbox adxpno(2)
    If [M:DIA]INDUSPRD
        If GAWACTIVITE
            Call FDOSSIERNV ([M:DIA]PRODUIT, [M:DIA]VERSION, [M:DIA]NUMPATCH,
&                          [M:DIA]DOSSIER, GAWPORT, GAWMACHINE, GAWSRCPATCH)

            [M:DIA]PORT = GAWPORT
            [M:DIA]MACHINE = GAWMACHINE
            [M:DIA]SRCPATCH = GAWSRCPATCH
            Affzo [M:DIA]DOSSIER, PORT, MACHINE, SRCPATCH

            Call FLASTPATCH()
        Else
            [M:DIA]DOSSIER = nomap(0)
        Endif
    Endif


Return

#________
$CONTROLE

    # actions toujours valides
    GAWVERIFCALL = [M:DIA]VERIFCALL
    GAWVERIFVAR = [M:DIA]VERIFVAR
    GAWVERIFAUT   = [M:DIA]VERIFAUT
    GAWNUMERR = [M:DIA]NUMERR

    # on s'affranchit des var écran soumises à code activité
    If GAWACTIVITE
        GAWVERIFRAZ   = [M:DIA]VERIFRAZ
        GAWVERIFCTLU  = [M:DIA]VERIFCTLU
        GAWVERIFIDX   = [M:DIA]VERIFIDX   #CHECK IGNORE_LINE
        GAWVERIFMOD   = [M:DIA]VERIFMOD
        GAWVERIFDAC   = [M:DIA]VERIFDAC

        GAWVERIFTYPE  = [M:DIA]VERIFTYPE   #CHECK IGNORE_LINE
        GAWVERIFDIC   = [M:DIA]VERIFDIC
        GAWREFCRX     = [M:DIA]REFCRX   #CHECK IGNORE_LINE
        GAWVERIFDOC   = [M:DIA]VERIFDOC

        GAWTRTNA      = [M:DIA]TRTNA   #CHECK IGNORE_LINE
        GAWSANSMODULE = [M:DIA]SANSMODULE   #CHECK IGNORE_LINE

        GAWMACHINE = [M:DIA]MACHINE
        GAWPORT    = [M:DIA]PORT

        GAWNUMPATCH = [M:DIA]NUMPATCH   #CHECK IGNORE_LINE

        GAWLONGUEURDT = [M:DIA]LONGUEURDT   #CHECK IGNORE_LINE
        GAWTYPEDT = [M:DIA]TYPEDT   #CHECK IGNORE_LINE
        GAWPARMODULE = [M:DIA]PARMODULE
        GAWEXCLSUPERV = [M:DIA]EXCLSUPERV   #CHECK IGNORE_LINE
        GAWOWNER = [M:DIA]OWNER   #CHECK IGNORE_LINE
    Endif

    # Chemin des sources du patch
    If GAWACTIVITE and GAWNUMPATCH

        [L]CHEMINSRC = [M:DIA]SRCPATCH   #CHECK IGNORE_LINE

        If filinfo(CHEMINSRC, 0) < 0
            GERR = 1

            Call FLASTPATCH ()

            GMESSAGE = "Patch n°" - num$(GAWNUMPATCH) - "non trouvé. (Il y en a" - num$([M:DIA]NBPATCH) +")"   #CHECK IGNORE_LINE
            zonsui = "NUMPATCH"
            Return
        Endif
    Endif

    If [M:DIA]TRACE = 1
        [M:DIA]TRACENAME = ""
        If GAWACTIVITE
            [M:DIA]PARMODULE = 1
        Endif
        GAWPARMODULE = 1
        Diszo [M:DIA]TRACENAME
    Else
        If [M:DIA]TRACENAME = ""
            [M:DIA]TRACENAME = "Verif.txt"
        Endif
    Endif
    Affzo [M:DIA]TRACENAME

    If GAWMACHINE = ""
        If filinfo(filpath("FIL", "ATABLE", "fde", [M:DIA]DOSSIER),1) < 0
            GERR = 1
            GMESSAGE = [M:DIA]DOSSIER - "non trouvé"
            Return
        Endif

    Else
        If filinfo(filpath("FIL","ATABLE","fde", GAWMACHINE + ":" + num$(GAWPORT) + "@" + [M:DIA]DOSSIER),1) < 0
            GERR = 1
            GMESSAGE = GAWMACHINE + ":" + num$(GAWPORT) + "@" + [M:DIA]DOSSIER - "non trouvé"
            Return
        Endif
    Endif


    # niveau du dossier
    If func NIVDOSDEMAND([M:DIA]INDUSPRD, GAWMACHINE, GAWPORT, [M:DIA]DOSSIER,
&           WNVDEMANDEUR, TBMODULE, WMINMODULE, WMAXMODULE) = 0
        GERR = 1
        GMESSAGE = "Problème recherche niveau dossier"
        Return
    Endif

    #WNVDEMANDEUR = 15
    # recherche de la version du dossier
    If [M:DIA]INDUSPRD = 0

        If clalev ([F:APT])
            Close File [APT]
        Endif
        If GAWMACHINE = ""
            Local File = "APATCH" [APT]
        Else
            Local File = GAWMACHINE + ":" + num$(GAWPORT) + "@" + DOSSIER + ".APATCH" [APT]
        Endif
        Local Char SV_VERSION(10)
        SV_VERSION = ""
        #1.5. ou 1.6.
        For [APT]APT2 Where TYP = "P"
            If [F:APT]RELEASE > SV_VERSION
                SV_VERSION = [F:APT]RELEASE
            Endif
        Next

        If left$(SV_VERSION, 3) <= "1.5"
            GAWVERSION = 6
        Else
            GAWVERSION = 7
        Endif
        Close File [APT]
    Endif

    If GAWVERIFTYPE = 2
        If GAWTYPEDT = "" and GAWLONGUEURDT
            GERR = 1
            GMESSAGE = func MESNUM(59, 144, num$(GAWLONGUEURDT), "", "", "", "")
            Return
        Endif
    Endif

    # le contrôle des indexes n'est plus d'actualité : on peut le lancer par ce bias... (VERIFIDX invisible)
    If GAWNUMERR = 99
        GAWACTIVITEVERIFIDX = 2
        GAWNUMERR = 0
    Endif

    If GAWNUMERR
        I = 0
        If GAWVERIFVAR = 2
            I += 1
        Endif
        If GAWVERIFCALL = 2
            I += 1
        Endif
        If GAWVERIFDAC = 2
            I += 1
        Endif
        If GAWVERIFMOD = 2
            I += 1
        Endif
        If GAWVERIFAUT = 2
            I += 1
        Endif

        If I <> 1 and(GUSER <> "CBO")
            GERR = 1
            GMESSAGE = mess(60, 144, 1)
            Return

        Elsif GAWVERIFRAZ = 2 or GAWVERIFCTLU = 2 or GAWVERIFIDX = 2 or
&             GAWVERIFDIC = 2
            GERR = 1
            GMESSAGE = mess(61, 144, 1)
            Return
        Elsif GAWVERIFCALL = 2 and (GAWNUMERR < 5 or GAWNUMERR = 15)
            GERR = 3
            GMESSAGE = mess(62, 144, 1)
        Endif
    Endif
    # Ces 2 traitements doivent être éxécutés seuls : utilisation 'modifiée' d'1 pgm d'1 autre traitement
    If GAWSANSMODULE = 2
        If GAWVERIFIDX = 2 or GAWVERIFCALL = 2 or GAWVERIFMOD = 2 or
&          GAWVERIFDAC = 2 or GAWVERIFDIC = 2  or GAWVERIFDOC = 2 or
&          GAWVERIFRAZ = 2 or GAWVERIFCTLU = 2 or GAWTRTNA = 2    or
&          GAWVERIFTYPE = 2  or GAWREFCRX = 2    or GAWVERIFAUT = 2 or
&          GAWVERIFVAR = 2

            GERR = 1
            GMESSAGE = mess(63, 144, 1)
            Return
        Endif
    Endif

    If GAWTRTNA = 2
        If GAWVERIFVAR = 2 or GAWVERIFCALL = 2 or GAWVERIFMOD = 2 or
&          GAWVERIFDAC = 2 or GAWVERIFDIC = 2  or GAWVERIFDOC = 2 or
&          GAWVERIFRAZ = 2 or GAWVERIFCTLU = 2 or GAWVERIFIDX = 2 or
&          GAWVERIFTYPE = 2  or GAWREFCRX = 2    or GAWVERIFAUT = 2 or
&          GAWSANSMODULE = 2

            GERR = 1
            GMESSAGE = mess(64, 144, 1)
            Return
        Endif
    Endif

    If GSERVEUR
        WRANG = 3
    Else
        WOPE = ""
        If GAWVERIFTYPE = 2

            WCODOPE(1) = "Longueur de variable affectée <  à celle de la variable affectant"
            WCODOPE(2) = "Longueur de variable affectée <= à celle de la variable affectant"
            WCODOPE(3) = "Longueur de variable affectée =  à celle de la variable affectant"
            WCODOPE(4) = "Longueur de variable affectée >  à celle de la variable affectant"
            WCODOPE(5) = "Longueur de variable affectée >= à celle de la variable affectant"
            WCODOPE(6) = "Quelquesoit les longueurs de variable"

            WRANG = 3
            Selbox WCODOPE(1..6) Titled "Choix " Using WRANG

            If WRANG < 0
                WRANG = 3
            Endif
            If WRANG = 0
                GERR = 1
                GMESSAGE = "Annulation"
                Return
            Elsif WRANG = 1
                WOPE = "<"
            Elsif WRANG = 2
                WOPE = "<="
            Elsif WRANG = 3
                WOPE = "="
            Elsif WRANG = 4
                WOPE = ">"
            Elsif WRANG = 5
                WOPE = ">="
            Elsif WRANG = 6
                WOPE = "T"
            Endif
        Endif
    Endif

    # si on traite l'indus, on se considère comme un dossier de développeur
    If [M:DIA]DOSSIER = "MNTPRD" or [M:DIA]DOSSIER = "INDUSPRD"
        WNVDEMANDEUR = 5
    Endif

    If dim([M:DIA]SRCGENERE) >= 0
        If [M:DIA]SRCGENERE = 2
            WNVDEMANDEUR = -5
        Endif
    Endif

    If dim([M:DIA]SRCTOUS) >= 0
        If [M:DIA]SRCTOUS = 2
            WNVDEMANDEUR = -1
            If [M:DIA]SRCGENERE = 2
                WNVDEMANDEUR = -2
            Endif

        Endif
    Endif

    # ================================= mettre ici les modifs de paramètres (perso CBO) =====================================
    If GSERVEUR = 0 and GUSER = "CBO" and GUSER <> "CBO"

        WCODOPE(1) = "niveau indus"
        WCODOPE(2) = "niveau dev"
        WCODOPE(3) = "niveau distri ou spe"
        WCODOPE(4) = "tout"
        WCODOPE(5) = "les générés W"

        WRANG = 1
        Selbox WCODOPE(1..5) Titled "Choix " Using WRANG

        If status = 7
            Return
        Endif

        If WRANG = 0
            GERR = 1
            GMESSAGE = "Annulation"
            Return
        Elsif WRANG = 1
            WNVDEMANDEUR = 0
        Elsif WRANG = 2
            WNVDEMANDEUR = 5
        Elsif WRANG = 3
            WNVDEMANDEUR = 10
        Elsif WRANG = 4
            WNVDEMANDEUR = -1
        Elsif WRANG = 5
            WNVDEMANDEUR = -5
        Endif

    Endif

    WMOTCOMPLET = 0
    WCH1ET2 = 0
    If GSERVEUR = 0 and GUSER = "CBO" and dim([M:DIA]AVERIFCHAINE) >= 0
        If [M:DIA]AVERIFCHAINE = 2

            WCODOPE(1) = "Mot complet"
            WCODOPE(2) = "Mot incomplet"
            WCODOPE(3) = "call from : trt appelé"
            WCODOPE(4) = "func : trt appelé"
            WCODOPE(5) = "Gosub from : trt appelé"
            WCODOPE(6) = "choix Call + func + Gosub"
            WRANG = 1
            Selbox WCODOPE(1..6) Titled "Choix " Using WRANG

            If status = 7
                Return
            Endif

            If WRANG <> 2
                WMOTCOMPLET = WRANG
            Endif

            If WMOTCOMPLET <> 6
                WCODOPE(1) = "Chaîne 1 ET 2"
                WCODOPE(2) = "Chaîne 1 ET/OU 2"
                WRANG = 1
                Selbox WCODOPE(1..2) Titled "Choix " Using WRANG

                If status = 7
                    Return
                Endif

                If WRANG = 1
                    WCH1ET2 = 1
                Endif
            Endif
        Endif
    Endif
Return


#________
$EXEC
Local Integer MI1, MODULEDEB, MODULEFIN, WACTION
Local Shortint WSIMODULE, WSISAUVEMODULE

    # Recherche des traitements sans module : adaptation de qq paramètres
    If GAWSANSMODULE = 2

        [M:DIA]NOMSRC = ""
        [M:DIA]NUMMODULE = 0
        [L]NUMOWNER=0
        GAWEXCLSUPERV = 1
    Endif

    # Recherche des traitements non utilisés : adaptation de qq paramètres
    If GAWTRTNA = 2

        [M:DIA]NOMSRC = ""
        [M:DIA]NUMMODULE = 0
        [M:DIA]PARMODULE = 1
        [L]NUMOWNER=0
        GAWEXCLSUPERV = 1
    Endif


    # réservé dossier Indus
    If WNVDEMANDEUR <> 0 and GAWVERIFVAR = 2
        GBTDESACTIVE(2, 1) = 1
    Endif

    #___________________________________________________________________________________________________
    # gérer ce tableau de bool pour lancer les moulinettes par module :
    # mettre les modules à ne pas traiter en commentaire


#    If instr(1, [M:DIA]DOSSIER, "GE")
#        TBMODULE(1) = 1
#        TBMODULE(2) = 1
#    Elsif instr(1, [M:DIA]DOSSIER, "PA") or  instr(1, [M:DIA]DOSSIER, "HR")
#        TBMODULE(1) = 1
#        TBMODULE(2) = 1
#        TBMODULE(3) = 1
#        TBMODULE(4) = 1
#        TBMODULE(5) = 1
#
#        TBMODULE(6) = 1
#        TBMODULE(7) = 1
#        TBMODULE(8) = 1
#        TBMODULE(9) = 1
#        TBMODULE(10) = 1
#    Elsif [M:DIA]DOSSIER = "INDUSPRD" or [M:DIA]DOSSIER = "MNTPRD"
#        TBMODULE(1) = 1
#        TBMODULE(11) = 1
#        TBMODULE(19) = 1
#    Else
#        TBMODULE(1) = 1
#        TBMODULE(2) = 1
#        TBMODULE(3) = 1
#        TBMODULE(5) = 1
#
#        TBMODULE(6) = 1
#        TBMODULE(7) = 1
#        TBMODULE(8) = 1
#        TBMODULE(9) = 1
#
#        TBMODULE(10) = 1
#        TBMODULE(12) = 1
#        TBMODULE(13) = 1
#        TBMODULE(14) = 1
#
#
#        TBMODULE(4)  = 0 # n'existe pas sur X3
#        TBMODULE(11) = 0 # n'existe pas sur X3
#    Endif

    #___________________________________________________________________________________________________



    GXDOSSIER=[M:DIA]DOSSIER
    If len([M:DIA]TRACENAME) - 4 > 0
        If right$([M:DIA]TRACENAME, len([M:DIA]TRACENAME) - 3) <> ".txt" and
&          right$([M:DIA]TRACENAME, len([M:DIA]TRACENAME) - 3) <> ".tra"
            [M:DIA]TRACENAME = [M:DIA]TRACENAME + ".txt"
        Endif
    Endif
    If GAWPARMODULE = 2
        MODULEDEB = WMINMODULE
        MODULEFIN = WMAXMODULE
    Else
        MODULEDEB = [M:DIA]NUMMODULE
        MODULEFIN = [M:DIA]NUMMODULE
    Endif

    Raz GTVARGLOB,    GTLGVARGLOB,    NBVARGLOB,    GTYPVARGLOB,   GPROGVARGLOB
    Raz GTVARGLOBDIC, GTLGVARGLOBDIC, NBVARGLOBDIC, GTYPVARGLOBDIC
    Raz GTVARGLOBSRC, GTLGVARGLOBSRC, NBVARGLOBSRC

    For MI1 = MODULEDEB To MODULEFIN
        [M:DIA]NUMMODULE = MI1

        # si non trié par module : Ok
        # si trié par module et booléen du module à 1 : Ok

        If GAWPARMODULE = 1 or (GAWPARMODULE = 2 and TBMODULE(MI1) = 1)

            Raz TLCLMSK, NBLCLMSK, NBERRTOT, NBWARTOT, NBERRCHECK, NBWARCHECK, NBDELTAERR, NBDELTAWAR

            # patch ou dossier ?
            If GAWACTIVITE and GAWNUMPATCH
                [L]PATCH=num$(GAWNUMPATCH)
            Else
                [L]PATCH=""
            Endif

            # contrôles demandés avec fichier pour les warning
            BSRCWARNING = 0
            If GAWVERIFVAR = 2 or GAWVERIFIDX = 2 or GAWVERIFCALL = 2 or GAWVERIFMOD = 2
&               or GAWVERIFDAC = 2 or GAWVERIFDIC = 2 or GAWVERIFAUT = 2 or GAWVERIFTYPE = 2
&               or GAWTRTNA = 2
                BSRCWARNING = 1
            Endif

            # Gestion de la trace
            If GAWPARMODULE = 2
                WTRACENAME  = [M:DIA]TRACENAME
                If right$(WTRACENAME, len(WTRACENAME) - 3) = ".txt" or right$(WTRACENAME, len(WTRACENAME) - 3) = ".tra"
                    WTRACENAME = left$(WTRACENAME, len(WTRACENAME) - 4) + num$(MI1) + ".txt"
                Else
                    WTRACENAME = WTRACENAME + num$(MI1) + ".txt"
                Endif
                WTRACENAMEW = left$(WTRACENAME, len(WTRACENAME) - 4) + "W.txt"

            Else
                If [M:DIA]TRACE = 2
                    WTRACENAME  = [M:DIA]TRACENAME
                    WTRACENAMEW = left$(WTRACENAME, len(WTRACENAME) - 4) + "W.txt"

                Else

                    [M:DIA]TRACENAME = ""
                    WTRACENAME = ""
                    WTRACENAMEW = ""

                Endif
            Endif

            If clalev ([F:AMZ])
                Close File [AMZ]
            Endif
            Local File = "AMSKZON" [AMZ]
            If clalev ([F:ATX])
                Close File [ATX]
            Endif
            Local File = "ATEXTE" [ATX]

            Call LIBCHPATZ(GLANGUE, "AVERIFSRC", "VERIFCALL", LIBCALL)
            Call LIBCHPATZ(GLANGUE, "AVERIFSRC", "VERIFRAZ", LIBRAZ)
            Call LIBCHPATZ(GLANGUE, "AVERIFSRC", "VERIFDAC", LIBDAC)
            Call LIBCHPATZ(GLANGUE, "AVERIFSRC", "VERIFVAR", LIBVAR)
            Call LIBCHPATZ(GLANGUE, "AVERIFSRC", "VERIFCTLU", LIBCTLU)

            Call LIBCHPATZ(GLANGUE, "AVERIFSRC", "VERIFAUT", LIBAUT)
            Call LIBCHPATZ(GLANGUE, "AVERIFSRC", "VERIFMOD", LIBMOD)
            Call LIBCHPATZ(GLANGUE, "AVERIFSRC", "VERIFDIC", LIBDIC)
            Call LIBCHPATZ(GLANGUE, "AVERIFSRC", "VERIFDOC", LIBDOC)
            Call LIBCHPATZ(GLANGUE, "AVERIFSRC", "VERIFTYPE", LIBTYPE)

            Call LIBCHPATZ(GLANGUE, "AVERIFSRC", "SANSMODULE", LIBSSMODULE)
            Call LIBCHPATZ(GLANGUE, "AVERIFSRC", "TRTNA", LIBTRTNA)
            Call LIBCHPATZ(GLANGUE, "AVERIFSRC", "REFCRX", LIBREFCRX)


            Close File [AMZ], [ATX]


            GWLIBERREURS = mess(2, 144, 1)
            GWLIBANOMALIES = mess(3, 144, 1)

            Call OUVRE_TRACE(func MESNUM(1, 144, GWLIBERREURS, "", "", "", "")) From LECFIC

            Openo filpath("TRA", GTRACE, "tra"), -1
            [L]CHEMINTRA  = filpath("TRA", GTRACE, "tra")
            [L]CHEMINTRAW = filpath("TRA", GTRACE + "W", "tra")

            #Gestion du module
            If [M:DIA]LIBMODULE <> ""
                GAWSANSMODULE = 1
                GAWTRTNA = 1
            Endif

            # Gestion du owner
            If GAWOWNER = ""
                [L]NUMOWNER=0
            Else
                Call OWNER_FROM_NAME (GAWOWNER,[L]NUMOWNER) From XXOWNER
            Endif


            # Entête : partie erreurs et anomalies____________________________________________________________

            Wrseq "-------->" - func MESNUM(1, 144, GWLIBERREURS, "", "", "", "")
            Gosub ECRDEBUT

            If BSRCWARNING

                # pour mettre le titre : vient de OUVRE_TRACE du traitement LECFIC
                Openo [L]CHEMINTRAW , 0
                adxifs = ""
                adxirs = chr$(10)
                adxium = GUTF8
                TEXTE  = "#<AdxV"+GADOVERS+">@(#)%I%"-format$("D:"+GFMDAT,date$)-time$-"("+GUSER
                If GPRODUIT=1 & dim(GFCY)>0 & dim(GDEP)>0 : ## GEODE
                    TEXTE-=GFCY+"/"+GDEP
                Endif
                TEXTE += ")" - func MESNUM(1, 144, GWLIBANOMALIES, "", "", "", "")
                Wrseq TEXTE
                Openo
                # pour mettre le titre : fin de OUVRE_TRACE du traitement LECFIC

                Openo CHEMINTRAW, -1
                Wrseq "-------->" - func MESNUM(1, 144, GWLIBANOMALIES, "", "", "", "")
                Gosub ECRDEBUT
            Endif



            # Vérification des Call, variables globales et locales
            If GAWVERIFCALL = 2 or GAWTRTNA = 2 or GAWVERIFTYPE = 2

                WACTION = 0
                WLIB = LIBCALL
                If GAWVERIFCALL = 1 and GAWTRTNA = 2
                    WACTION = 1
                    WLIB = LIBTRTNA
#                Elsif GAWVERIFCALL = 2 and GAWTRTNA = 2
#                    WACTION = 2 #impossible : ces 2 actions doivent s'éxécuter séparément
                Endif

                If GAWVERIFCALL = 1 and GAWVERIFTYPE = 2
                    WACTION = 3
                    WLIB = LIBTYPE
                Endif

                If GAWVERIFCALL = 2 and GAWVERIFTYPE = 2
                    WACTION = 4
                Endif

                # ruse pour traiter la passe 1 de VERIFCALL module par module :
                # pour pouvoir sortir les erreurs et ano correspondantes triées par module
                # il faut activer 'par module', le désactiver et le réactiver...
                If GAWPARMODULE = 2
                    If GTRTPARMODULE = 3
                        GTRTPARMODULE = 1
                    Else
                        GTRTPARMODULE = 2
                    Endif
                Else
                    GTRTPARMODULE = 1
                Endif

$EXECCALL

                GNUMMOUL = 1
                Call AVERIFCALL([L]CHEMINTRA, [L]PATCH, [L]CHEMINSRC, [M:DIA]NOMSRC,
&                   [M:DIA]DOSSIER, [M:DIA]NUMMODULE, [L]NUMOWNER,
&                   GAWECREXP, GAWEXCLSUPERV, GAWPORT, GAWMACHINE, [L]CHEMINTRAW,
&                   NBERRTOT, NBWARTOT, GAWNUMERR, WACTION,
&                   NBVARGLOB, NBVARGLOBDIC, NBVARGLOBSRC, WNVDEMANDEUR,
&                   WPASSE1CALL, WBLISTETRT, GTRTPARMODULE, GAWTYPEDT, WLIB) From AVERIFCALL
                NBERRCHECK = NBERRTOT
                NBWARCHECK = NBWARTOT

                GTRTPARMODULE = 0
                If WACTION = 3 or WACTION = 4

                    GNUMMOUL = 4
                    Call AVERIFTYPE([L]CHEMINTRA, [L]PATCH, [L]CHEMINSRC, [M:DIA]NOMSRC,
&                        [M:DIA]DOSSIER, [M:DIA]NUMMODULE, [L]NUMOWNER,
&                        GAWEXCLSUPERV, GAWPORT, GAWMACHINE,
&                        [L]CHEMINTRAW, NBERRTOT, NBWARTOT, GAWNUMERR,
&                        NBVARGLOB, NBVARGLOBDIC, NBVARGLOBSRC, [M:DIA]TYPEDT, [M:DIA]LONGUEURDT, WOPE,
&                        WNVDEMANDEUR, LIBTYPE) From AVERIFTYPE   #CHECK IGNORE_LINE
                NBDELTAERR = NBERRTOT - NBERRCHECK
                NBDELTAWAR = NBWARTOT - NBWARCHECK

                Endif
            Endif


            # Vérification des variables dans les classes F : la vérif des variables charge un tableau pour la vérif des écrans
            If GAWVERIFVAR = 2 or GAWVERIFMOD = 2 or GAWSANSMODULE = 2
                # ne pas interférer si recherche d'1 erreur particulière dans la recherche des écrans
                If GAWVERIFVAR = 1
                    WNUMERREUR = 0
                Else
                    WNUMERREUR = GAWNUMERR
                Endif

                If GAWVERIFVAR = 2 or GAWVERIFMOD = 2
                    WLIB = LIBVAR
                Else
                    WLIB = LIBSSMODULE
                Endif

                GNUMMOUL = 2
                Call AVERIFVAR([L]CHEMINTRA, [L]PATCH, [L]CHEMINSRC, [M:DIA]NOMSRC, [M:DIA]DOSSIER,
&                    [M:DIA]NUMMODULE, [L]NUMOWNER,
&                    GAWECREXP, GAWEXCLSUPERV, GAWPORT, GAWMACHINE, [L]CHEMINTRAW,
&                    TLCLMSK, NBLCLMSK, NBERRTOT, NBWARTOT, GAWVERIFVAR, GAWSANSMODULE,
&                    WNUMERREUR, WNVDEMANDEUR, WPASSE1VAR, WBLISTETRT, WLIB, GAWVERSION) From AVERIFVAR
                # Ne pas tenir compte du VERIFTYPE (on enlève le delta)
                NBERRCHECK = NBERRTOT - NBDELTAERR
                NBWARCHECK = NBWARTOT - NBDELTAWAR
            Endif


            # Vérification des écrans
            If GAWVERIFMOD = 2
                GNUMMOUL = 3
                Call AVERIFECR ([M:DIA]DOSSIER, [M:DIA]NUMMODULE, [L]CHEMINTRA, GAWEXCLSUPERV,
&                    GAWPORT, GAWMACHINE, [L]CHEMINTRAW,
&                    TLCLMSK, NBLCLMSK, NBERRTOT, NBWARTOT, GAWNUMERR, LIBMOD) From AVERIFECR
            Endif


            # Vérification des liens vers les tables en RAZ
            If GAWVERIFRAZ = 2
                GNUMMOUL = 5
                Call AVERIFRAZ([L]CHEMINTRA, [M:DIA]DOSSIER, GAWPORT, GAWMACHINE,
&                    [M:DIA]NUMMODULE, NBERRTOT, NBWARTOT, LIBRAZ) From AVERIFRAZ
            Endif


            # Vérification des flags users manquants dans les fonctions
            If GAWVERIFCTLU = 2
                GNUMMOUL = 6
                Call AVERIFCTLU([L]CHEMINTRA, [M:DIA]DOSSIER, GAWPORT, GAWMACHINE,
&                    [M:DIA]NUMMODULE, NBERRTOT, NBWARTOT, LIBCTLU) From AVERIFCTLU
            Endif


            If GAWVERIFDIC = 2
                GNUMMOUL = 7
                Call AVERIFDIC([L]CHEMINTRA, [M:DIA]DOSSIER, [M:DIA]NUMMODULE,
&                    GAWEXCLSUPERV, GAWPORT, GAWMACHINE, [L]CHEMINTRAW,
&                    NBERRTOT, NBWARTOT, LIBDIC) From AVERIFDIC
            Endif


            If GAWVERIFAUT = 2
                GNUMMOUL = 9
                Call AVERIFAUTRE ([L]CHEMINTRA, [L]PATCH, [L]CHEMINSRC, [M:DIA]NOMSRC,
&                   [M:DIA]DOSSIER, [M:DIA]NUMMODULE, [L]NUMOWNER,
&                   GAWEXCLSUPERV, GAWPORT, GAWMACHINE,
&                   [L]CHEMINTRAW, GAWNUMERR, NBERRTOT, NBWARTOT,
&                   WNVDEMANDEUR, WBLISTETRT, LIBAUT, GLANGUE) From AVERIFAUTRE
            Endif


# ______________________________________________________________________________________________________________


            # Vérification Dico des actions, tableaux passés en value...
            If GAWVERIFDAC = 2
                GNUMMOUL = 8
                Call AVERIFDAC([L]CHEMINTRA, [L]PATCH, [L]CHEMINSRC, [M:DIA]NOMSRC, [M:DIA]DOSSIER,
&                    [M:DIA]NUMMODULE, [L]NUMOWNER,
&                    GAWEXCLSUPERV, GAWPORT, GAWMACHINE, [L]CHEMINTRAW,
&                    NBERRTOT, NBWARTOT, GAWNUMERR, WNVDEMANDEUR, LIBDAC) From AVERIFDAC

            Endif


            # Vérification des performances par rapport aux index utilisés
            If GAWVERIFIDX=2
                Call AVERIFIDX([L]CHEMINTRA, [L]PATCH, [L]CHEMINSRC, [M:DIA]DOSSIER, [M:DIA]NOMSRC,
&                    [M:DIA]NUMMODULE, [L]NUMOWNER, GAWECREXP, GAWEXCLSUPERV, GAWPORT,
&                    GAWMACHINE, [L]CHEMINTRAW, NBERRTOT, NBWARTOT, [M:DIA]INDUSPRD) From AVERIFIDX
            Endif


            # Vérification de la documentation : traitement à lancer seul : il s'adresse aux documentailistes et non aux développeurs
            If GAWVERIFDOC = 2
                GNUMMOUL = 10
                Call AVERIFDOCU([L]CHEMINTRA, [M:DIA]DOSSIER, [M:DIA]NUMMODULE,
&                    GAWEXCLSUPERV, GAWPORT, GAWMACHINE, [L]CHEMINTRAW,
&                    GLANGUE, NBERRTOT, NBWARTOT, [M:DIA]NOMSRC, LIBDOC, GAWNUMERR) From AVERIFDOCU

            Endif

            If GAWREFCRX = 2
                Call AVERIFCROISE ([L]CHEMINTRA, [L]PATCH, [L]CHEMINSRC, [M:DIA]NOMSRC,
&                   [M:DIA]DOSSIER, [M:DIA]NUMMODULE, [L]NUMOWNER,
&                   EXCLSUPERVEXCLSUPERV, GAWPORT, GAWMACHINE, [L]CHEMINTRAW,
&                   WNVDEMANDEUR, WBLISTETRT, LIBREFCRX) From AVERIFCROISE
            Endif



# ______________________________________________________________________________________________________________
#CHECK IGNORE_BEGIN
            If dim([M:DIA]AVERIFCHAINE) >= 0
                If [M:DIA]AVERIFCHAINE = 2

                Call AVERIFCHAINE ([L]CHEMINTRA, [M:DIA]NOMSRC, [M:DIA]DOSSIER, GAWPORT,
&                    GAWMACHINE, WNVDEMANDEUR, [M:DIA]NUMMODULE,
&                    [M:DIA]CH1, [M:DIA]CH2, WMOTCOMPLET, WCH1ET2) From AVERIFCHAINE

                Endif
            Endif
#CHECK IGNORE_END
# ______________________________________________________________________________________________________________



# Vérification pour la trad
#If GUSER = 'CBO' and GAWVERIFVAR=1 and GAWVERIFCALL=1  and GAWVERIFRAZ=1  and GAWVERIFIDX=1 and GAWVERIFMOD=1
#        Call VERIFTRAD([L]CHEMINTRA,[L]PATCH,[L]CHEMINSRC,[M:DIA]NOMSRC,[M:DIA]DOSSIER, [M:DIA]NUMMODULE, [L]NUMOWNER, GAWECREXP) From CBOVERIFTRAD
#endif

            Gosub ECRIREFIN
        Endif
    Next MI1

    If [M:DIA]TRACE = 1 and GSERVEUR = 0

        WSVTRACE = GTRACE
        Call LEC_TRACE From LECFIC

        # si on a supprimé la trace (FQxxxxx.tra), on supprime aussi les FQxxxxxW.tra et FQxxxxxX.tra
        If filinfo(filpath("TRA", WSVTRACE, "tra", -1), 1) < 0
            If filinfo(filpath("TRA", WSVTRACE + "W", "tra", -1), 1) >= 0
                Call EFFACE(filpath("TRA", WSVTRACE + "W", "tra", ""), I) From ORDSYS
            Endif

            #fic récapitulatif réservé CBO
            If filinfo(filpath("TRA", WSVTRACE + "X", "tra", -1), 1) >= 0
                Call EFFACE(filpath("TRA", WSVTRACE + "X", "tra", ""), I) From ORDSYS
            Endif
        Endif
    Endif

Return


#_______
$TERMINE

    If [M:DIA]INDUSPRD
        Close File [XID]
    Endif

#############################################################################################################

    Kill NS1, NG1, GNBTRTADX, NBFI, NBMA, NBZM, NBZMB
    Kill GTPPTPRO, GTPPTGOS, GTSOUSPRO, GTGOS, GTGOSB, GTGOSC
    Kill GTTYPARG, GTTYPFUNP, GPREFIXE, GSANSLG

    Kill GTTYPZO, GTTYPTYP, GTTRAITEMENTS, GTFICHIERS, GTZONES
    Kill GTINDFIC, GTINDMAS, GTMASQUES, GTZONMSK, GTZONMSKB, GTTYPMZO, GTTYPMZOB

    Kill GTRTPARMODULE, GMAX_VAR, GMAX_SOUSPRO, GMAX_TRT, GMAX_NBMSK, GLIBTYPGLOB

    Kill GTVARGLOB, GTVARGLOBDIC, GPROGVARGLOB, GTYPVARGLOB, GTYPVARGLOBDIC, GTLGVARGLOB, GTLGVARGLOBDIC
    Kill GMAX_ZONEMSK, GMAX_TYPE, GMAX_LGSSPRO, GMAX_NBPAR, GMAX_NBFIC, GMAX_ZONEFIC
    Kill GTVARGLOBSRC, GTLGVARGLOBSRC

    Kill GTFICHIERSV, GTZONESV, GTINDFICV, GNBFIV, GNBZOV, GREPEREIF, GCPTDBG, GTRECAPERR, GCUMULERR


    # variables globales : Gestion de code activité :

Kill GAWACTIVITE, GAWPORT, GAWNUMPATCH, GAWNBPATCH, GAWVERSION
Kill GAWMACHINE, GAWSRCPATCH
Kill GAWVERIFCALL, GAWVERIFVAR, GAWVERIFRAZ, GAWVERIFCTLU, GAWVERIFIDX, GAWVERIFMOD
Kill GAWVERIFDAC, GAWVERIFTYPE, GAWVERIFDIC, GAWREFCRX, GAWVERIFDOC, GAWVERIFAUT, GAWTRTNA
Kill GAWSANSMODULE, GAWNUMERR, GAWECREXP, GAWLONGUEURDT
Kill GAWTYPEDT, GVALCBO

Kill GTMIGRATE, GAWDOSDISTRI, GAWDOSSPECIF
Kill GNBERREUR, GTLIBERREUR, GCONTROLE, GBTWARNING, GBTDESACTIVE, GNUMMOUL, GNB_MOUL
Kill GTPROGUNUSED, GNBPROGUNUSED, GWLIBERREURS, GWLIBANOMALIES

#############################################################################################################

Return

$ECRDEBUT

    Wrseq
    Wrseq
    Wrseq func TITREFMT(mess(4, 144, 1), 20) + ": " + [M:DIA]DOSSIER
#    If GUSER = "CBO"
#        Wrseq "Niveau dossier/moulinette" - num$(WNVDEMANDEUR)
#    Endif
    If GAWACTIVITE
        If [M:DIA]INDUSPRD
           Wrseq func TITREFMT(mess(5, 144, 1), 20) + ": " + mess([M:DIA]VERSION, 2411, 1)
        Endif
        Wrseq func TITREFMT(mess(6, 144, 1), 20) + ": " + GAWMACHINE  + '/' + num$(GAWPORT)

        If GAWNUMPATCH
            Wrseq func TITREFMT(mess(7, 144, 1), 20) + ": " + num$(GAWNUMPATCH)
            Wrseq func TITREFMT(mess(8, 144, 1), 20) + ": " + CHEMINSRC
        Endif
    Endif
    Wrseq func TITREFMT(mess(9, 144, 1), 20) + ": " + [M:DIA]NOMSRC

    If GAWPARMODULE = 2
      WSISAUVEMODULE = 0
      WSIMODULE = MI1

        If clalev ([F:AST])
            Close File [AST]
        Endif
        If GAWMACHINE = ""
            Local File = [M:DIA]DOSSIER + ".APLSTD"  [AST]
        Else
            Local File = GAWMACHINE + ":" + num$(GAWPORT) + "@" + [M:DIA]DOSSIER + ".APLSTD"  [AST]
        Endif
        Wrseq func TITREFMT(mess(10, 144, 1), 20) + ": (" + num$(WSIMODULE) + ")" - func LIBMODULE(WSIMODULE, WSISAUVEMODULE)
        Close File [AST]
    Else
        If NUMMODULE
            Wrseq func TITREFMT(mess(10, 144, 1), 20) + ": (" + num$([M:DIA]NUMMODULE) + ")" - LIBMODULE
        Endif
    Endif

    Wrseq
    If GAWPARMODULE = 2
        Wrseq mess(11, 144, 1)
    Endif

    If GAWEXCLSUPERV = 2
        Wrseq mess(12, 144, 1)
    Endif

    If GAWOWNER <> ""
        Wrseq func TITREFMT(mess(13, 144, 1), 20) + ":" - GAWOWNER
    Endif

    If GAWNUMERR and GAWNUMERR < 90
        Wrseq func TITREFMT(mess(14, 144, 1), 20) + ":" - num$(GAWNUMERR)
    Endif

    If GAWVERIFTYPE = 2
        If [M:DIA]TYPEDT <> ""   #CHECK IGNORE_LINE
            Wrseq func TITREFMT(mess(15, 144, 1), 20) + ":" - [M:DIA]TYPEDT   #CHECK IGNORE_LINE
        Endif                    #CHECK IGNORE_LINE
        If [M:DIA]LONGUEURDT     #CHECK IGNORE_LINE
            Wrseq func TITREFMT(mess(16, 144, 1), 20) + ":" - num$([M:DIA]LONGUEURDT)   #CHECK IGNORE_LINE
        Endif                    #CHECK IGNORE_LINE
        If WOPE <> ""
            If WOPE = "T"
                Wrseq mess(65, 144, 1)
            Else
                Wrseq func MESNUM(66, 144, WOPE, "", "", "", "")
            Endif
        Endif
    Endif

#____________________________________________________________________________________________________

    Wrseq  mess(17, 144, 1) - ":"

    If GAWVERIFCALL=2
        Wrseq "  -" - LIBCALL
    Endif
    If GAWVERIFVAR = 2
        If GAWSANSMODULE = 1
            Wrseq "  -" - LIBVAR
        Endif
    Endif
    If GAWVERIFMOD=2
        Wrseq "  -" - LIBMOD
    Endif
    If GAWSANSMODULE = 2
        Wrseq "  -" - LIBSSMODULE
    Endif
    Wrseq


    If GAWVERIFRAZ=2
        Wrseq "  -" - LIBRAZ
    Endif
    If GAWVERIFCTLU=2
        Wrseq "  -" - LIBCTLU
    Endif
    If GAWVERIFDIC=2
        Wrseq "  -" - LIBDIC
    Endif
    If GAWVERIFDOC=2
        Wrseq "  -" - LIBDOC
    Endif
    Wrseq


    If GAWVERIFDAC=2
        Wrseq "  -" - LIBDAC
    Endif
    If GAWVERIFAUT=2
        Wrseq "  -" - LIBAUT
    Endif
    If GAWVERIFIDX=2
        Wrseq "  -" - "Performances par rapport aux indexes utilisés"
    Endif
    Wrseq


    If GAWVERIFTYPE = 2
        Wrseq "  -" - LIBTYPE
    Endif
    If GAWTRTNA=2
        Wrseq "  -" - LIBTRTNA
    Endif
    If GAWREFCRX=2
        Wrseq "  -" - LIBREFCRX
    Endif

    If dim([M:DIA]SRCGENERE) >= 0
        If [M:DIA]SRCGENERE = 2
            Wrseq "  - Sources générés W"
        Endif
    Endif

    If dim([M:DIA]SRCTOUS) >= 0
        If [M:DIA]SRCTOUS = 2
            Wrseq "  - Tous les sources"
        Endif
    Endif

    Wrseq
    Wrseq "Le" - format$("D:DD[/]MM[/]YYYY", date$) - "à" - time$
    Wrseq
    Wrseq

    Openo

Return

$ECRIREFIN


    Openo [L]CHEMINTRA, -1

    Wrseq
    Wrseq
    Wrseq
    Wrseq
    Wrseq
    Wrseq
    Wrseq "_____________________________________________________________"
    Wrseq "_____________________________________________________________"
    Wrseq
    Wrseq
    Wrseq
    Wrseq "                    " + mess(19, 144, 1)
    Wrseq
    Wrseq
    Wrseq "          " + mess(20, 144, 1) - func TITREFMT(GWLIBERREURS, 10) + ":" - num$(NBERRTOT)
    Wrseq "          " + mess(20, 144, 1) - func TITREFMT(GWLIBANOMALIES, 10) + ":" - num$(NBWARTOT)
    Wrseq
    Wrseq "_____________________________________________________________"
    Wrseq "_____________________________________________________________"

    #gestion du workflow
    GNBERRTOT  = NBERRTOT
    GNBWARNTOT = NBWARTOT

    # ajouter le NBWARCHECK dans le test lorsque les Warning seront analysées
    If (GAWVERIFVAR = 2 or GAWVERIFCALL = 2) and NBERRCHECK #  or NBWARCHECK)
#CHECK IGNORE_BEGIN
        Wrseq
        Wrseq
        Wrseq
        Wrseq "______________________________________________________"
        Wrseq ""
        Wrseq mess(21, 144, 1)
        Wrseq "____________________________"
        Wrseq ""
        Wrseq ""
        Wrseq "#CHECK FILE_DECLARE <file> [<abrev>]"
        Wrseq "  " + mess(22, 144, 1)
        Wrseq "  " + mess(23, 144, 1)
        Wrseq "  --> " + mess(24, 144, 1)
        Wrseq ""
        Wrseq "#CHECK MASK_DECLARE <mask> [<abrev>]"
        If mess(95, 144, 1) = ""
          Wrseq "  Pour déclarer un masque écran ayant été ouvert dans un autre traitement avec une abrev non standard"
          Wrseq "  Ne déclarer qu’un seul masque par ligne"
        Else
          Wrseq "  " + mess(95, 144, 1)
          Wrseq "  " + mess(96, 144, 1)
        Endif
        Wrseq "  --> " + mess(24, 144, 1)
        Wrseq ""
        Wrseq "#CHECK IGNORE_SOURCE"
        Wrseq "  " + mess(25, 144, 1)
        Wrseq "  --> " + mess(26, 144, 1)
        Wrseq ""
        Wrseq "#CHECK IGNORE_BEGIN"
        Wrseq "  " + mess(27, 144, 1)
        Wrseq "  --> " + mess(28, 144, 1)
        Wrseq ""
        Wrseq "#CHECK IGNORE_END"
        Wrseq "  " + mess(29, 144, 1)
        Wrseq "  --> " + mess(30, 144, 1)
        Wrseq ""
        Wrseq "#CHECK IGNORE_LINE"
        Wrseq "  " + mess(31, 144, 1)
        Wrseq "  --> " + mess(32, 144, 1)
        Wrseq ""
        Wrseq "#CHECK IGNORE_WRSEQ"
        Wrseq "  " + mess(33, 144, 1)
        Wrseq "  --> " + mess(30, 144, 1)
        Wrseq ""
        Wrseq "#CHECK WRSEQ_END"
        Wrseq "  " + mess(94, 144, 1)
        Wrseq "  --> " + mess(30, 144, 1)
        Wrseq ""
        Wrseq "#CHECK UNUSED_SOURCE"
        Wrseq "  " + mess(34, 144, 1)
        Wrseq "  --> " + mess(26, 144, 1)
        Wrseq ""
        Wrseq "#CHECK UNUSED_BEGIN"
        Wrseq "  " + mess(35, 144, 1)
        Wrseq "  --> " + mess(28, 144, 1)
        Wrseq ""
        Wrseq "#CHECK UNUSED_END"
        Wrseq "  " + mess(36, 144, 1)
        Wrseq "  --> " + mess(30, 144, 1)

        Wrseq ""
        Wrseq "#CHECK MIGRATE_SOURCE"
        Wrseq "  " + mess(37, 144, 1)
        Wrseq "  --> " + mess(28, 144, 1)
        Local Integer I01, J01
        Local Char WER01(80), WTIT01(80)
        WTIT01 = "  --> " + mess(38, 144, 1) - ":"

        # Cette boucle edite la liste des erreurs ignorées, une ligne par moulinette concernée.
        For I01 = 1 To 10
            WER01 = ""
            For I02 = 1 To 99
                If GTMIGRATE(I01, I02)
                    WER01 -= num$((I01 - 1) * 100 + I02)
                Endif
            Next I02
            If WER01 <> ""
                If WTIT01 <> ""
                    Wrseq WTIT01
                    WTIT01 = ""
                Endif
                Wrseq "      N°" - WER01
            Endif
        Next I01

        Wrseq ""
        Wrseq "______________________________________________________"
#CHECK IGNORE_END
    Endif

    Openo

    If GAWPARMODULE <> 2 and [M:DIA]TRACE = 2 and GSERVEUR = 0

        WSVTRACE = GTRACE
        Call LEC_TRACE From LECFIC
        GTRACE = WSVTRACE
    Endif


    If [M:DIA]TRACE = 2
        Call COPY_SRVTOCLI(1, WTRACENAME, "RtsTemp", "TRA/" + GTRACE + ".tra", "", "", I) From ORDSYS
        Call EFFACE(filpath("TRA", GTRACE, "tra", ""), I) From ORDSYS
    Else

# Callui fonctionne aussi directement...
#Callui RETOUR = "" With "UIAction=" + chr$(1) + "GetFileAlways",
#& "UIRemoteFile=" + chr$(1) + "TRA/" + GTRACE + ".tra",
#& "UILocalFile=" + chr$(1) + GTRACE + ".tra",
#& "UILocalDir=" + chr$(1) + "RtsTemp"
#
#Callui RETOUR = "" With "UIAction=" + chr$(1) + "GetFileAlways",
#& "UIRemoteFile=" + chr$(1) + "TRA/" + GTRACE + "W.tra",
#& "UILocalFile=" + chr$(1) + GTRACE + "W.tra",
#& "UILocalDir=" + chr$(1) + "RtsTemp"


        # Il faut que Temp sous Rts soit partagé sur le poste client
        # F:\Program Files\Sage\Sage X3 Client V5\rts\temp

#        Call COPY_SRVTOCLI(1, GTRACE + ".tra", "RtsTemp", "TRA/" + GTRACE + ".tra", "", "", I) From ORDSYS
    Endif

    If BSRCWARNING
        Openo [L]CHEMINTRAW, -1
        Wrseq
        Wrseq "_____________________________________________________________"
        Wrseq "_____________________________________________________________"
        Wrseq
        Wrseq
        Wrseq
        Wrseq "                    " + mess(19, 144, 1)
        Wrseq
        Wrseq
        Wrseq "          " + mess(20, 144, 1) - func TITREFMT(GWLIBERREURS, 10) + ":" - num$(NBERRTOT)
        Wrseq "          " + mess(20, 144, 1) - func TITREFMT(GWLIBANOMALIES, 10) + ":" - num$(NBWARTOT)
        Wrseq
        Wrseq "_____________________________________________________________"
        Wrseq "_____________________________________________________________"

        Openo

        If [M:DIA]TRACE = 2
            Call COPY_SRVTOCLI(1, WTRACENAMEW, "RtsTemp", "TRA/" + GTRACE + "W.tra", "", "", I) From ORDSYS
            Call EFFACE(filpath("TRA", GTRACE + "W", "tra", ""), I) From ORDSYS
        Endif
    Endif

    Gosub TABRECAP

 Return




$TABRECAP
    # éditer un tableau récapitulatif $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ (réservé  CBO) $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$

    If GUSER <> "CBO" or MI1 <> MODULEFIN
        Return
    Endif

    # sur batch global pour avoir le tableau recap
    # pas de module sélectionné ou dernier module
    If GSERVEUR
        If MODULEDEB <> 0 and MI1 <> MODULEFIN
            Return
        Endif
    Endif


        If GAWVERIFCALL = 1 and GAWVERIFVAR = 1  and GAWVERIFMOD = 1 and GAWVERIFTYPE = 1 and
&          GAWVERIFRAZ = 1  and GAWVERIFCTLU = 1 and GAWVERIFDIC = 1 and GAWVERIFDAC = 1  and
&          GAWVERIFAUT = 1  and GAWVERIFDOC = 1
            Return
        Endif



    Local Integer XXJ, XXK, XXL, TXXTOTMODERR(21), TXXTOTMODANO(21), TXXTOTERR(51), NBMODULE, NBERRANO
    Local Char XXC(250), XXCLIB(250)
    Local Integer TXXGENERR(21), TXXGENANO(21)

#_________________________________________________________________________________
    [L]CHEMINTRAW = filpath("TRA", GTRACE + "X", "tra")
    Openo [L]CHEMINTRAW, 0
    adxifs = ""
    adxirs = chr$(10)
    adxium = GUTF8
    TEXTE  = "#<AdxV"+GADOVERS+">@(#)%I%"-format$("D:"+GFMDAT,date$)-time$-"("+GUSER
    If GPRODUIT=1 & dim(GFCY)>0 & dim(GDEP)>0 : ## GEODE
        TEXTE-=GFCY+"/"+GDEP
    Endif
    TEXTE += ")" - func MESNUM(1, 144, "C.R. CBO", "", "", "", "")
              Wrseq TEXTE
    Wrseq '--------> Vérification des sources (Tableau récapitulatif)'
    Openo


    Openo [L]CHEMINTRAW, -1
    Gosub ECRDEBUT
    Openo [L]CHEMINTRAW, -1
    Wrseq
    Wrseq
#_________________________________________________________________________________



    NBMODULE = 14

    Wrseq
    Wrseq "Le" - format$("D:DD[/]MM[/]YYYY", date$) - "à" - time$
    Wrseq
    # moulinette (call, var...)
    For GNUMMOUL = 1 To GNB_MOUL - 1

        NBERRANO = 0
        If GNUMMOUL = 1 and GAWVERIFCALL = 2
            XXC = "VERFIFCALL "
            NBERRANO = GNBERREUR(GNUMMOUL)
        Elsif GNUMMOUL = 2 and GAWVERIFVAR = 2
            XXC = "VERIFVAR   "
            NBERRANO = GNBERREUR(GNUMMOUL)
        Elsif GNUMMOUL = 3 and GAWVERIFMOD = 2
            XXC = "VERIFECR   "
            NBERRANO = GNBERREUR(GNUMMOUL)
        Elsif     GNUMMOUL = 4 and GAWVERIFTYPE = 2
            XXC = "VERIFTYPE  "
            NBERRANO = GNBERREUR(GNUMMOUL)
        Elsif     GNUMMOUL = 5 and GAWVERIFRAZ = 2
            XXC = "VERIFRAZ   "
            NBERRANO = GNBERREUR(GNUMMOUL)
        Elsif     GNUMMOUL = 6 and GAWVERIFCTLU = 2
            XXC = "VERIFCTLU  "
            NBERRANO = GNBERREUR(GNUMMOUL)
        Elsif     GNUMMOUL = 7 and GAWVERIFDIC = 2
            XXC = "VERIFDIC   "
            NBERRANO = GNBERREUR(GNUMMOUL)
        Elsif     GNUMMOUL = 8 and GAWVERIFDAC = 2
            XXC = "VERIFDAC   "
            NBERRANO = GNBERREUR(GNUMMOUL)
        Elsif     GNUMMOUL = 9 and GAWVERIFAUT = 2
            XXC = "VERIFAUTRE "
            NBERRANO = GNBERREUR(GNUMMOUL)
        Elsif     GNUMMOUL = 10 and GAWVERIFDOC = 2
            XXC = "VERIFDOCU  "
            NBERRANO = GNBERREUR(GNUMMOUL)
        Endif

        # N'édite que si la moulinette est lancée
        If NBERRANO
            Wrseq XXC + " (" + num$(GNBERREUR(GNUMMOUL)) - "sortes d'erreur/anomalie)"
            Wrseq

            # entête module
            XXCLIB = "Module       "
            For XXK = 0 To NBMODULE
                XXL = 10 - len(num$(XXK))
                XXCLIB = XXCLIB + string$(XXL, " ") + num$(XXK)
            Next XXK
            Wrseq XXCLIB + "   Total"
            Wrseq

            # erreurs
            SUPERTOT = 0
            For XXJ = 1 To GNBERREUR(GNUMMOUL)
                If GBTWARNING(GNUMMOUL, XXJ) = 0 and GTLIBERREUR(GNUMMOUL, XXJ) <> ""
                    If XXJ < 10
                        XXC = "Err  " + num$(XXJ)
                    Else
                        XXC = "Err" - num$(XXJ)
                    Endif
                    If GBTDESACTIVE(GNUMMOUL, XXJ)
                        XXC = XXC - "desact"
                    Else
                        XXC = XXC + "       "
                    Endif
                    # module
                    For XXK = 0 To NBMODULE
                        XXL = 10 - len(num$(GTRECAPERR(GNUMMOUL, XXK, XXJ)))
                        XXC = XXC + string$(XXL, " ") + num$(GTRECAPERR(GNUMMOUL, XXK, XXJ))
                        TXXTOTERR(XXJ) += GTRECAPERR(GNUMMOUL, XXK, XXJ)
                        TXXTOTMODERR(XXK)  += GTRECAPERR(GNUMMOUL, XXK, XXJ)
                        SUPERTOT += GTRECAPERR(GNUMMOUL, XXK, XXJ)
                        TXXGENERR(XXK)  += GTRECAPERR(GNUMMOUL, XXK, XXJ)
                    Next XXK

                    XXL = 10 - len(num$(TXXTOTERR(XXJ)))
                    XXC = XXC + string$(XXL, " ") + num$(TXXTOTERR(XXJ))
                    Wrseq XXC
                Endif
            Next XXJ

            # cumul erreur par module
            XXC = "Total Err    "
            For XXJ = 0 To NBMODULE
                XXL = 10 - len(num$(TXXTOTMODERR(XXJ)))
                XXC = XXC + string$(XXL, " ") + num$(TXXTOTMODERR(XXJ))
            Next XXJ

            XXL = 10 - len(num$(SUPERTOT))
            XXC = XXC + string$(XXL, " ") + num$(SUPERTOT)

            Wrseq XXC
            Wrseq

            Wrseq XXCLIB + "     Total"
            Wrseq

            # anomalies
            SUPERTOT = 0
            For XXJ = 1 To GNBERREUR(GNUMMOUL)
                If GBTWARNING(GNUMMOUL, XXJ) = 1 and GTLIBERREUR(GNUMMOUL, XXJ) <> ""
                    If XXJ < 10
                        XXC = "Ano  " + num$(XXJ)
                    Else
                        XXC = "Ano" - num$(XXJ)
                    Endif

                    If GBTDESACTIVE(GNUMMOUL, XXJ)
                        XXC = XXC - "desact"
                    Else
                        XXC = XXC + "       "
                    Endif

                    # module
                    For XXK = 0 To NBMODULE
                        XXL = 10 - len(num$(GTRECAPERR(GNUMMOUL, XXK, XXJ)))
                        XXC = XXC + string$(XXL, " ") + num$(GTRECAPERR(GNUMMOUL, XXK, XXJ))
                        TXXTOTERR(XXJ) += GTRECAPERR(GNUMMOUL, XXK, XXJ)
                        TXXTOTMODANO(XXK)  += GTRECAPERR(GNUMMOUL, XXK, XXJ)
                        SUPERTOT += GTRECAPERR(GNUMMOUL, XXK, XXJ)
                        TXXGENANO(XXK)  += GTRECAPERR(GNUMMOUL, XXK, XXJ)
                    Next XXK

                    XXL = 10 - len(num$(TXXTOTERR(XXJ)))
                    XXC = XXC + string$(XXL, " ") + num$(TXXTOTERR(XXJ))
                    Wrseq XXC
                Endif
            Next XXJ

            # cumul ano par module
            XXC = "Total Ano    "
            For XXJ = 0 To NBMODULE
                XXL = 10 - len(num$(TXXTOTMODANO(XXJ)))
                XXC = XXC + string$(XXL, " ") + num$(TXXTOTMODANO(XXJ))
            Next XXJ

            XXL = 10 - len(num$(SUPERTOT))
            XXC = XXC + string$(XXL, " ") + num$(SUPERTOT)

            Wrseq XXC
            Wrseq
            Wrseq
            Wrseq "Rappel des erreurs :"
            Wrseq

            XXC = ""
            For XXJ = 1 To GNBERREUR(GNUMMOUL)

                If GTLIBERREUR(GNUMMOUL, XXJ) <> ""
                    If GBTWARNING(GNUMMOUL, XXJ)
                        XXC = "Ano"
                    Else
                        XXC = "Err"
                    Endif
                    XXC = XXC - num$(XXJ)
                    If GBTDESACTIVE(GNUMMOUL, XXJ)
                        XXC = XXC + " désact"
                    Else
                        XXC = XXC + "       "
                    Endif

                    If XXJ < 10
                        XXC = XXC + "  : "
                    Else
                        XXC = XXC + " : "
                    Endif
                    XXC = XXC + GTLIBERREUR(GNUMMOUL, XXJ)

                    Wrseq XXC
                Endif
            Next XXJ
            Wrseq
            Wrseq


            Raz TXXTOTMODERR, TXXTOTMODANO, TXXTOTERR
        Endif
    Next GNUMMOUL

    # cumul général erreurs par module
    Wrseq XXCLIB + "     Total"
    Wrseq
    XXC = " Général Err"
    SUPERTOT = 0
    For XXJ = 0 To NBMODULE
        XXL = 10 - len(num$(TXXGENERR(XXJ)))
        XXC = XXC + string$(XXL, " ") + num$(TXXGENERR(XXJ))
        SUPERTOT += TXXGENERR(XXJ)
    Next XXJ

    XXL = 10 - len(num$(SUPERTOT))
    XXC = XXC + string$(XXL, " ") + num$(SUPERTOT)

    Wrseq XXC
    Wrseq

    # nb sources par module (VERIFVAR)
    If GAWVERIFVAR = 2
        SUPERTOT = 0
        XXC = "Nb sources   "
        For XXJ = 0 To NBMODULE
            XXL = 10 - len(num$(GVALCBO(100 + XXJ)))
            XXC = XXC + string$(XXL, " ") + num$(GVALCBO(100 + XXJ))
            SUPERTOT += GVALCBO(100 + XXJ)
        Next XXJ

        XXL = 10 - len(num$(SUPERTOT))
        XXC = XXC + string$(XXL, " ") + num$(SUPERTOT)

        Wrseq XXC
        Wrseq
    Endif

    # cumul général ano par module
    XXC = " Général Ano"
    SUPERTOT = 0
    For XXJ = 0 To NBMODULE
        XXL = 10 - len(num$(TXXGENANO(XXJ)))
        XXC = XXC + string$(XXL, " ") + num$(TXXGENANO(XXJ))
        SUPERTOT += TXXGENANO(XXJ)
    Next XXJ

    XXL = 10 - len(num$(SUPERTOT))
    XXC = XXC + string$(XXL, " ") + num$(SUPERTOT)

    Wrseq XXC
    Wrseq


    # GVALCBO(101) à ... donne le nb de sources du module (fait ds AVERIFVAR)

    If GAWVERIFCALL = 2
        Wrseq ""
        Wrseq "Indic de AVERIFCALL :"
        Wrseq ""
        Wrseq "- nombre de sous-pro     :" - num$(GVALCBO(1)) - "/" - "GMAX_SOUSPRO =" - num$(GMAX_SOUSPRO)
        Wrseq "- nombre d'étiquettes    :" - num$(GVALCBO(2)) - "/" - "GMAX_SOUSPRO =" - num$(GMAX_SOUSPRO) - "(Limite à 3 * GMAX_SOUSPRO)"
        Wrseq "- nombre de tables       :" - num$(GVALCBO(31)) - "/" - "GMAX_NBFIC =" - num$(GMAX_NBFIC)
        Wrseq "- nombre de var table    :" - num$(GVALCBO(3)) - "/" - "GMAX_ZONEFIC =" - num$(GMAX_ZONEFIC)
        If GVALCBO(4) > GMAX_ZONEMSK
            GVALCBO(4) = GMAX_ZONEMSK
        Endif

        Wrseq "- nombre de masques      :" - num$(GVALCBO(32)) - "/" - "GMAX_NBMSK =" - num$(GMAX_NBMSK)
        Wrseq "- nombre de var masque 1 :" - num$(GVALCBO(4)) - "/" - "GMAX_ZONEMSK =" - num$(GMAX_ZONEMSK)
        Wrseq "- nombre de var masque 2 :" - num$(GVALCBO(5))
        Wrseq "- max arguments trouvés  :" - num$(GVALCBO(6)) - "/" - "GMAX_NBPAR =" - num$(GMAX_NBPAR)
        Wrseq "- nombre de trts en UNUSED_SOURCE :" - num$(GVALCBO(7))
        Wrseq "- nombre de var globales déclarées     :" - num$(GVALCBO(8)) - "/" - "GMAX_VAR =" - num$(GMAX_VAR)
        Wrseq "- nombre de var globales DIC déclarées :" - num$(GVALCBO(9))
        Wrseq "- nombre de var globales SRC déclarées :" - num$(GVALCBO(10))
    Endif

    If GAWVERIFVAR = 2
        Wrseq ""
        Wrseq "Indic de AVERIFVAR :"
        Wrseq ""
        Wrseq "- nombre de var table    :" - num$(GVALCBO(11)) - "/" - "GMAX_ZONEFIC =" -  num$(GMAX_ZONEFIC)
        Wrseq "- max abrev non std      :" - num$(GVALCBO(12))
        Wrseq "- max abrev msk non ana  :" - num$(GVALCBO(13))
        Wrseq "- max abrev fic non ana  :" - num$(GVALCBO(14))
        Wrseq "- max msk ds TLCMSK      :" - num$(GVALCBO(15)) - "/" - "GMAX_NBMSK =" - num$(GMAX_NBMSK)
    Endif

    Openo

    If [M:DIA]TRACE = 2
        WTRACENAMEW  = [M:DIA]TRACENAME
        If right$(WTRACENAMEW, len(WTRACENAMEW) - 3) = ".txt" or right$(WTRACENAMEW, len(WTRACENAMEW) - 3) = ".tra"
            WTRACENAMEW = left$(WTRACENAMEW, len(WTRACENAMEW) - 4) + "X.txt"
        Else
            WTRACENAMEW = WTRACENAMEW + "X.txt"
        Endif


        Call COPY_SRVTOCLI(1, WTRACENAMEW, "RtsTemp", "TRA/" + GTRACE + "X.tra", "", "", I) From ORDSYS
        Call EFFACE(filpath("TRA", GTRACE + "X", "tra", ""), I) From ORDSYS
    Endif

Return
# fin éditer un tableau récapitulatif $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$ (réservé  CBO) $$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$


$CHGLIBERR

    Raz GNBERREUR, GTLIBERREUR, GBTDESACTIVE, GBTWARNING


    # call ___________________________________________________________________
    GNUMMOUL = 1

    GNBERREUR(GNUMMOUL) = 23

    For I = 1 To GNBERREUR(GNUMMOUL)
        GTLIBERREUR(GNUMMOUL, I) = mess(1000 + I, 144, 1)
    Next I


      GBTWARNING(GNUMMOUL, 1) = 1    # phase 1    Fonction inexistante dans le dictionnaire ASUBPROG.
    GBTWARNING(GNUMMOUL, 2) = 1    # phase 1    Fonction ayant un type d'argument non renseigné dans le dictionnaire ASUBPROG.
    GBTWARNING(GNUMMOUL, 3) = 1    # phase 1    Fonction ayant un type d'argument (du End) dans le dico différent de celui du traitement
    GBTWARNING(GNUMMOUL, 4) = 1    # phase 1    le sous-programme (ou fonction) a l'argument n° N non déclaré.
    #                                5          DBGAFF trouvé.
    #                                6          Traitement inexistant.
    #                                7          Sous-programme (ou fonction) inexistant.
    #                                8          Erreur lors d'un appel par GOSUB d'un Call.
    #                                9          Variable globale inexistante.
      GBTWARNING(GNUMMOUL, 10) = 1     #          Variable LOCALE var DÉJÀ DÉCLARÉE EN GLOBALE DANS UN AUTRE TRAITEMENT.
      GBTWARNING(GNUMMOUL, 11) = 1     #          Variable locale VAR déjà déclarée avec un type différent.
    GBTWARNING(GNUMMOUL, 12) = 1     #          Variable globale VAR déjà déclarée avec un type différent.
    #                                13         Paramètre de type différent sur appel de Sous-programme (ou fonction).
    #                                14         Nombre de paramètres différent sur appel Sous-programme (ou fonction).
    GBTWARNING(GNUMMOUL, 15) = 1    # phase 1   Sous-programme (ou fonction) avec un descriptif vide (documetation)
      GBTWARNING(GNUMMOUL, 16) = 1     #          Paramètre [VALEUR] de type différent sur appel de Sous-programme (ou fonction).
    GBTWARNING(GNUMMOUL, 17) = 1    # phase 1   Paramètre de type différent entre dico et déclaration du sous-programme (ou fonction).
    GBTWARNING(GNUMMOUL, 18) = 1    # phase 1   Paramètre ayant un passage par adresse/valeur différent entre dico et déclaration du sous-pro. (ou fct).
    GBTWARNING(GNUMMOUL, 19) = 1    # phase 1   Nombre de paramètres différent entre dico et déclaration du sous-programme (ou fonction).
    GBTWARNING(GNUMMOUL, 20) = 1    # phase 1   le sous-programme (ou fonction) a l'argument n° N qui a un nom différent lors de la définition du type.
    #                                21         Goto à une étiquette située dans un autre traitement.
    #                                22         Appel d'une étiquette par un Call.
    #                                23         Etiquette inexistante.

    GBTDESACTIVE(GNUMMOUL, 1) = 1
    GBTDESACTIVE(GNUMMOUL, 10) = 1
    GBTDESACTIVE(GNUMMOUL, 11) = 1
    GBTDESACTIVE(GNUMMOUL, 16) = 1

    # var ___________________________________________________________________


    GNUMMOUL = 2
    GNBERREUR(GNUMMOUL) = 14

    For I = 1 To GNBERREUR(GNUMMOUL)
        GTLIBERREUR(GNUMMOUL, I) = mess(1000 + (GNUMMOUL - 1)*100 + I, 144, 1)
    Next I

    # réservé dossier Indus
    If WNVDEMANDEUR <> 0
        GBTDESACTIVE(GNUMMOUL, 1) = 1
        GTLIBERREUR(GNUMMOUL, 1) = ""
    Else
        GTLIBERREUR(GNUMMOUL, 1) = "Source ne devrait pas être présent en environnement Indus."
    Endif

    # Erreur disponible
    GTLIBERREUR(GNUMMOUL, 3) = ""

    #                                1         Source ne devrait pas être présent en environnement Indus.
    #                                2         Source non référencé dans le dictionnaire des traitements.
    GBTWARNING(GNUMMOUL, 3) = 1     #
      GBTWARNING(GNUMMOUL, 4) = 1     #          abréviation inexistante.
      GBTWARNING(GNUMMOUL, 5) = 1     #          Abréviation écran inexistante.
      GBTWARNING(GNUMMOUL, 6) = 1     #          abréviation table inexistante.
      GBTWARNING(GNUMMOUL, 7) = 1     #          Variable inexistante [ABV]CHP
    #                                8         Variable écran inexistante.
    #                                9         Variable table inexistante.
    GBTWARNING(GNUMMOUL, 10) = 1    #          Variable inexistante [G:]CHP
      GBTWARNING(GNUMMOUL, 11) = 1    #          Variable système (liée aux tables) inexistante [S:]CHP
    #                                12        Variable inexistante dans les tables du LNK
    #                                13        Table non trouvée
    #                                14        Abréviation trop longue (> 4)

    # désactivation d'erreurs ou d'anomalies

    GBTDESACTIVE(GNUMMOUL, 2) = 1
    GBTDESACTIVE(GNUMMOUL, 4) = 1
    GBTDESACTIVE(GNUMMOUL, 5) = 1
    GBTDESACTIVE(GNUMMOUL, 6) = 1
    GBTDESACTIVE(GNUMMOUL, 7) = 1
    GBTDESACTIVE(GNUMMOUL, 11) = 1


    # Erreurs non contrôlées (si source topé en #CHECK SOURCE_MIGRATE) :

    GTMIGRATE(GNUMMOUL, 9) = 1


    # VERIFECR ___________________________________________________________________
    GNUMMOUL = 3

    GNBERREUR(GNUMMOUL) = 25
    GTLIBERREUR(GNUMMOUL, 1) = "Fenêtre xxx : Aucun écran associé (Champ NBMSK = 0)."
    GTLIBERREUR(GNUMMOUL, 2) = "Fenêtre xxx : Il n'y a pas d'entête mais plusieurs écrans"
    GTLIBERREUR(GNUMMOUL, 3) = "Fenêtre xxx : L'écran entête yyy a le type z"
    GTLIBERREUR(GNUMMOUL, 4) = "Fenêtre xxx : L'écran entête yyy est de module différent"
    GTLIBERREUR(GNUMMOUL, 5) = "Fenêtre xxx : L'écran yyy est de module différent"
    GTLIBERREUR(GNUMMOUL, 6) = "Fenêtre xxx : L'écran yyy a z lignes : fenêtre VT standard :zz"
    GTLIBERREUR(GNUMMOUL, 7) = "Fenêtre xxx : Les écrans entête et onglet ont un nombre de lignes > à 28"
    GTLIBERREUR(GNUMMOUL, 8) = "Fenêtre xxx : L'écran yyy de type zzz devrait être de type onglet"
    GTLIBERREUR(GNUMMOUL, 9) = "Fenêtre xxx : L'écran yyy de type zzz n'est pas associé à une fenêtre VT."
    GTLIBERREUR(GNUMMOUL, 10) = "Fenêtre xxx : L'écran yyy de type zzz n'est pas de type VT et est associé à une fenêtre VT."
    GTLIBERREUR(GNUMMOUL, 11) = "Fenêtre xxx : nombre de masques (NBMSK) = yyy et est différent du nombre d'écrans trouvés."

    GTLIBERREUR(GNUMMOUL, 12) = "Fenêtre xxx : est de type objet mais elle n'en possède pas."
    GTLIBERREUR(GNUMMOUL, 13) = "Fenêtre xxx : est de type et elle possède un objet."
    GTLIBERREUR(GNUMMOUL, 14) = "Fenêtre xxx : son type est non renseigné et elle possède un objet"
    GTLIBERREUR(GNUMMOUL, 15) = "Fenêtre xxx : L'objet yyy n'est pas trouvé"
    GTLIBERREUR(GNUMMOUL, 16) = "Fenêtre xxx : son module est yyy et l'objet a zzz"

    GTLIBERREUR(GNUMMOUL, 17) = "Fenêtre xxx : est de type yyy mais elle ne possède pas de consultation."
    GTLIBERREUR(GNUMMOUL, 18) = "Fenêtre xxx : est de type yyy et elle possède une consultation."
    GTLIBERREUR(GNUMMOUL, 19) = "Fenêtre xxx : consultation yyy non trouvée dans la table AOBJET ou ACONSULT"
    GTLIBERREUR(GNUMMOUL, 20) = "Fenêtre xxx : module différent de la consultation."

    GTLIBERREUR(GNUMMOUL, 21) = "Fenêtre xxx : de type yyy associée à aucune action."
    GTLIBERREUR(GNUMMOUL, 22) = "Fenêtre xxx : module différent de celui de l'action."

    GTLIBERREUR(GNUMMOUL, 23) = "Fenêtre xxx : est de type yyy et devrait être une fenêtre plein écran"
    GTLIBERREUR(GNUMMOUL, 24) = "Fenêtre xxx : est de type yyy et devrait être une boîte de dialogue"

    GTLIBERREUR(GNUMMOUL, 25) = "Ecran xxx : associé à aucune fenêtre."


    GBTWARNING(GNUMMOUL, 1) = 1
    GBTWARNING(GNUMMOUL, 2) = 1
    GBTWARNING(GNUMMOUL, 3) = 1
    GBTWARNING(GNUMMOUL, 4) = 1
    GBTWARNING(GNUMMOUL, 5) = 1
    GBTWARNING(GNUMMOUL, 6) = 1
    GBTWARNING(GNUMMOUL, 7) = 1
    GBTWARNING(GNUMMOUL, 8) = 1
    GBTWARNING(GNUMMOUL, 9) = 1
    GBTWARNING(GNUMMOUL, 10) = 1

    GBTWARNING(GNUMMOUL, 11) = 1
    GBTWARNING(GNUMMOUL, 12) = 1
    GBTWARNING(GNUMMOUL, 17) = 1
    GBTWARNING(GNUMMOUL, 19) = 1
    GBTWARNING(GNUMMOUL, 20) = 1
    GBTWARNING(GNUMMOUL, 21) = 1
    GBTWARNING(GNUMMOUL, 22) = 1
    GBTWARNING(GNUMMOUL, 23) = 1
    GBTWARNING(GNUMMOUL, 24) = 1
    GBTWARNING(GNUMMOUL, 25) = 1
    #pas de GBTDESACTIVE


    # VERIFTYPE ___________________________________________________________________
    GNUMMOUL = 4

    GNBERREUR(GNUMMOUL) = 8
    GTLIBERREUR(GNUMMOUL, 1) = "> Il faut mieux déclarer cette variable en précisant sa longueur par une variable globale"
    GTLIBERREUR(GNUMMOUL, 2) = "="
    GTLIBERREUR(GNUMMOUL, 3) = "<"
    GTLIBERREUR(GNUMMOUL, 4) = "Variable déclarée sans longueur et affectée à une variable typée"
    GTLIBERREUR(GNUMMOUL, 5) = "Longueur de la chaîne non décodée (var ou expression)"
    GTLIBERREUR(GNUMMOUL, 6) = "Différence entre le type de données et la variable globale"
    GTLIBERREUR(GNUMMOUL, 7) = "Variable globale GLON sans correspondance dans la table des Types"
    GTLIBERREUR(GNUMMOUL, 8) = "Variable non déclarée"

    GBTDESACTIVE(GNUMMOUL, 8) = 1

    GBTWARNING(GNUMMOUL, 5) = 1
    GBTWARNING(GNUMMOUL, 8) = 1


    # VERIFRAZ ___________________________________________________________________
    GNUMMOUL = 5
    GNBERREUR(GNUMMOUL) = 1
    GTLIBERREUR(GNUMMOUL, 1) = "Zone de table (sans remise à zéro) avec un lien vers une table avec remise à zéro"


    # VERIFCTLU ___________________________________________________________________
    GNUMMOUL = 6
    GNBERREUR(GNUMMOUL) = 1
    GTLIBERREUR(GNUMMOUL, 1) = "Recherche des flags utilisateurs manquant dans les fonctions"


    # VERIFDIC ___________________________________________________________________
    GNUMMOUL = 7
    GNBERREUR(GNUMMOUL) = 13
    GTLIBERREUR(GNUMMOUL, 1) = "Type BPN trouvé à tort sur champs de table"
    GTLIBERREUR(GNUMMOUL, 2) = "Type VCR sur champs de table dont le paramètre VCROBJ n'existe pas (ou non renseigné)"
    GTLIBERREUR(GNUMMOUL, 3) = "Type BPS ou BPC trouvé sur champs de table avec annulation différente de Autre"
    GTLIBERREUR(GNUMMOUL, 4) = "Type de donnée dont le format est issu d'une classe [F]"
    GTLIBERREUR(GNUMMOUL, 5) = "Option T absente du bloc tableau si graphe par défaut"
    GTLIBERREUR(GNUMMOUL, 6) = "Action batch avec une fenêtre principale"
    GTLIBERREUR(GNUMMOUL, 7) = "Champ ayant annulation à autre avec le type lié à la table elle-même"
    GTLIBERREUR(GNUMMOUL, 8) = "Champ clob ou blob de longueur > 9"
    GTLIBERREUR(GNUMMOUL, 9) = "Champ de type blob sans champ associé de type AT"
    GTLIBERREUR(GNUMMOUL, 10) = "Fonction de consultation dont dont le code impression a une valeur <> PRTSCR"
    GTLIBERREUR(GNUMMOUL, 11) = "Action CONTOBJW  ou CONTOBJ mais champ avec flag obligatoire non positionné"
    GTLIBERREUR(GNUMMOUL, 12) = "Dictionnaire des sous-programmes : TYPASU = 1 = Divers"
    GTLIBERREUR(GNUMMOUL, 13) = "Action avec le type à Divers"

    GBTWARNING(GNUMMOUL, 12) = 1
    GBTWARNING(GNUMMOUL, 13) = 1


    # VERIFDAC ___________________________________________________________________
    GNUMMOUL = 8
    GNBERREUR(GNUMMOUL) = 5

    GTLIBERREUR(GNUMMOUL, 1) = "Début d'un sous-programme (ou fonction) alors que le précédent n'est pas fini"
    GTLIBERREUR(GNUMMOUL, 2) = "Le sous-programme (ou fonction) ne contient aucun code"
    GTLIBERREUR(GNUMMOUL, 3) = "Le sous-programme n'existe pas dans les actions sur champ."
    GTLIBERREUR(GNUMMOUL, 4) = "Sous-programme non éxécuté pour un champ invisible"
    GTLIBERREUR(GNUMMOUL, 5) = "Sous-programme non éxécuté pour un champ en affichage"

    # attention le trt n'ouvre que le CR des warnings verifxxxW.txt
    GBTWARNING(GNUMMOUL, 1) = 1
    GBTWARNING(GNUMMOUL, 2) = 1
    GBTWARNING(GNUMMOUL, 3) = 1
    GBTWARNING(GNUMMOUL, 4) = 1
    GBTWARNING(GNUMMOUL, 5) = 1


    # VERIFAUTRE ___________________________________________________________________

    GNUMMOUL = 9
    GNBERREUR(GNUMMOUL) = 24

    For I = 1 To GNBERREUR(GNUMMOUL)
        GTLIBERREUR(GNUMMOUL, I) = mess(1000 + (GNUMMOUL - 1)*100 + I, 144, 1)
    Next I

    #                               1       Sous- prog (ou fct) fini et For sans Next
    #                               2       Sous- prog (ou fct) fini et If sans Endif
    #                               3       Sous- prog (ou fct) fini et Case sans Endcase
    #                               4       Sous- prog (ou fct) fini et While sans Wend
      GBTWARNING(GNUMMOUL, 5)  = 1    #       Début du sous-programme (ou fonction) alors que le précédent n'est pas fini
    GBTWARNING(GNUMMOUL, 6)  = 1    #       Sous-programme (ou fonction) ne contient aucun code
    #                               7       End trouvé dans une boucle For [Read]
    #                               8       Return trouvé dans une boucle For [Read]
    GBTWARNING(GNUMMOUL, 9)  = 1    #       Sous-programme (ou fonction) a un tableau en paramètre passé par valeur
      GBTWARNING(GNUMMOUL, 10)  = 1   #       Etiquette trouvée après un Sous-programme (ou fonction)
      GBTWARNING(GNUMMOUL, 11)  = 1   #       Return trouvé dans un Sous-programme (ou fonction)
      GBTWARNING(GNUMMOUL, 12)  = 1   #       End trouvé en dehors d'un sous-programme (ou fonction)

    GBTWARNING(GNUMMOUL, 21)  = 1   #       Message d'erreur imprécis (problème de compteur), à compléter par : "(" + [L]COMPTEUR - num$([L]STAT) + ")"
    GBTWARNING(GNUMMOUL, 22)  = 1   #       #@ est une instruction obsolette
    #                               23      Documentations de point d'entrée inexistante.
    GBTWARNING(GNUMMOUL, 24)  = 1   #       Instruction evalue inutile sur un dim de champ.

    GBTDESACTIVE(GNUMMOUL, 5) = 1
    GBTDESACTIVE(GNUMMOUL, 10) = 1
    GBTDESACTIVE(GNUMMOUL, 11) = 1
    GBTDESACTIVE(GNUMMOUL, 12) = 1


    # VERIFDOCU ___________________________________________________________________
    GNUMMOUL = 10

    GNBERREUR(GNUMMOUL) = 12
    GTLIBERREUR(GNUMMOUL, 1) = "Fonction xxx : Documentation absente (paragraphe PRE)"
    GTLIBERREUR(GNUMMOUL, 2) = "Fonction xxx : Documentation (ou intitulé) absente (paragraphe TIT)"
    GTLIBERREUR(GNUMMOUL, 3) = "Fonction xxx : Texte non renseigné (paragraphe PRE)"

    GTLIBERREUR(GNUMMOUL, 4) = "Fonction, fenêtre : écran xxx sans documentation"
    GTLIBERREUR(GNUMMOUL, 5) = "Fonction, fenêtre : bouton xxx sans documentation"
    GTLIBERREUR(GNUMMOUL, 6) = "Fonction, fenêtre : menu xxx sans documentation"

    GTLIBERREUR(GNUMMOUL, 7) = "Fonction, fenêtre, écran, champ xxx : mot clef d'aide absent"
    GTLIBERREUR(GNUMMOUL, 8) = "Fonction, fenêtre, écran, champ : mot clef xxx : Aide sur champ absente"
    GTLIBERREUR(GNUMMOUL, 9) = "Fonction, fenêtre, écran, champ : bouton Bx sans documentation"
    GTLIBERREUR(GNUMMOUL, 10) = "Fonction, fenêtre : champ écran non renseigné dans la documentation (paragraphe ENT)"
    GTLIBERREUR(GNUMMOUL, 11) = "Fonction, fenêtre : champ écran différent dans la documentation (paragraphe ENT)"
    GTLIBERREUR(GNUMMOUL, 12) = "Fonction, fenêtre xxx : de y onglets a une documentation sur l'onglet z"
    # GTLIBERREUR(GNUMMOUL, 13) = "nombre de fonctions traitées"
Return


$OUVREDOSSIER

    If clalev ([F:AMK])
        Close File [AMK]
    Endif
    If clalev ([F:ACN])
        Close File [ACN]
    Endif
    If clalev ([F:ACT])
        Close File [ACT]
    Endif
    If clalev ([F:ABR])
        Close File [ABR]
    Endif
    If clalev ([F:ABT])
        Close File [ABT]
    Endif

    If clalev ([F:ADP])
        Close File [ADP]
    Endif
    If clalev ([F:APE])
        Close File [APE]
    Endif
    If clalev ([F:AFC])
        Close File [AFC]
    Endif
    If clalev ([F:AOB])
        Close File [AOB]
    Endif
    If clalev ([F:AOE])
        Close File [AOE]
    Endif

    If clalev ([F:ARP])
        Close File [ARP]
    Endif
    If clalev ([F:AHI])
        Close File [AHI]
    Endif
    If clalev ([F:ATN])
        Close File [ATN]
    Endif
    If clalev ([F:AUR])
        Close File [AUR]
    Endif
    If clalev ([F:AWE])
        Close File [AWE]
    Endif

    If clalev ([F:PS2])
        Close File [PS2]
    Endif
    If clalev ([F:TCY])
        Close File [TCY]
    Endif



    Onerrgo ERRDOSSIER

    IFIC = 1  + IREF * 20
    Local File = PDOSSIER + ".AMSK"      [AMK]
    IFIC += 1
    Local File = PDOSSIER + ".ACTION"  [ACT]
    IFIC += 1
    Local File = PDOSSIER + ".AREPORT" [ARP]
    IFIC += 1
    Local File = PDOSSIER + ".ATRANSAC" [ATN]
    IFIC += 1
    Local File = PDOSSIER + ".AHISTO" [AHI]

    IFIC += 1
    Local File = PDOSSIER + ".ACONSULT"  [ACN]
    IFIC += 1
    Local File = PDOSSIER + ".ABATRQT"  [ABR]
    IFIC += 1
    Local File = PDOSSIER + ".ABATTAC"  [ABT]
    IFIC += 1
    Local File = PDOSSIER + ".ADOPAR"  [ADP]
    IFIC += 1
    Local File = PDOSSIER + ".AENTREE"  [APE]

    IFIC += 1
    Local File = PDOSSIER + ".AFONCTION" [AFC]
    IFIC += 1
    Local File = PDOSSIER + ".AOBJET" [AOB]
    IFIC += 1
    Local File = PDOSSIER + ".AOBJEXT" [AOE]
    IFIC += 1
    Local File = PDOSSIER + ".AURL" [AUR]
    IFIC += 1
    Local File = PDOSSIER + ".AWEBSERVIC" [AWE]

    IFIC += 1
    Local File = PDOSSIER + ".PARSTA2" [PS2]
    IFIC += 1
    Local File = PDOSSIER + ".TABCOUNTRY" [TCY]

    Onerrgo

Return

$FERMEDOSSIER

    Onerrgo ERRDOSSIER
    IFIC = 1

    Close File [AMK]
    Close File [ACN]
    Close File [ACT]
    Close File [ABR]
    Close File [ABT]

    Close File [ADP]
    Close File [APE]
    Close File [AFC]
    Close File [AOB]
    Close File [AOE]

    Close File [ARP]
    Close File [AHI]
    Close File [ATN]
    Close File [AUR]
