    VALEUR=vireblc(toupper(VALEUR),4)
End


######################################################################################


Subprog AM_NUMPATCH(VALEUR)
Variable Decimal VALEUR

    Call FDOSSIERNV ([M:DIA]PRODUIT, [M:DIA]VERSION, VALEUR,
&                    [M:DIA]DOSSIER, GAWPORT, GAWMACHINE, GAWSRCPATCH)    #CxxHECK IGNORE_LINE

    If GAWACTIVITE
        [M:DIA]PORT = GAWPORT
        [M:DIA]MACHINE = GAWMACHINE
        [M:DIA]SRCPATCH = GAWSRCPATCH
        Affzo [M:DIA]DOSSIER, PORT, MACHINE, SRCPATCH
    Endif

    GAWNUMPATCH = VALEUR
    If VALEUR and [M:DIA]TRACE = 2
        [M:DIA]TRACENAME = "VerifPatch" + num$(VALEUR) + ".txt"
    Endif
    Affzo TRACENAME

End


