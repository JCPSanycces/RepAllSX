# supprime les parties entre quote (ou double) d'1 chaine commençant par PMOTCLEF (= Wrseq...)
Subprog PURGECH(PMOTCLEF, PCHAINE, PBSUPMOTCLEF)
Value Char PMOTCLEF
Variable Clbfile PCHAINE
Value Integer PBSUPMOTCLEF

Local Integer I, J, DIS, DID, DI1, SIMPLEQUOT, DOUBLEQUOT
Local Clbfile CH1(3)

    If left$(PCHAINE, 1) = "#"
        If left$(PCHAINE, 6) <> "#CHECK"
            PCHAINE = ""
        Endif
        End
    Endif

    If instr(1, PCHAINE, "GPOINT") or instr(1, PCHAINE, "EXISTE_ADX")
        End
    Endif
    If instr(1, PCHAINE, "Local File")
        End
    Endif

    If PMOTCLEF <> ""

        I = instr(1, PCHAINE, PMOTCLEF)
        If I = 0
            End
        Endif

        If PBSUPMOTCLEF
            PCHAINE = right$(PCHAINE, I + len(PMOTCLEF))
        Endif
    Endif


# On cherche le 1° délimiteur de chaine quote ou doublequote


    DI1 = 1

    While DI1
        SIMPLEQUOT = 0
        DOUBLEQUOT = 0

        DID = instr(DI1, PCHAINE, '"')
        DIS = instr(DI1, PCHAINE, "'")

        If DID
            DOUBLEQUOT = 1
            DI1 = DID
        Endif

      #  qui est le premier ? quote ou doublequote
        If DIS  and (DIS < DID or DID = 0)
            DI1 = DIS
            SIMPLEQUOT = 1
            DOUBLEQUOT = 0
        Endif

        # pas de quote (ou double)
        If SIMPLEQUOT = 0 and DOUBLEQUOT = 0
            End
        Endif

        CH1 = left$(PCHAINE, DI1)

        If SIMPLEQUOT
            DI1 = instr(DI1 + 1, PCHAINE, "'")
        Else
            DI1 = instr(DI1 + 1, PCHAINE, '"')
        Endif

        # c'est un pb...
        If DI1 = 0
            End
        Endif

        # on a transformé : Wrseq "abc" - "[M:ABV]CHP1 =" - [M:ABV]CHP1
        # en              : "" - "[M:ABV]CHP1" - [M:ABV]CHP1
        # puis en         : "" - "" - [M:ABV]CHP1

        PCHAINE = CH1 + right$(PCHAINE, DI1)
        DI1 = len(CH1) + 2
    Wend

End

#____________________________________________________________________________________
# indique si la position passée en paramètre se trouve dans une chaine entre " ou '
# RETOUR 0 la position demandée n'est pas dans une chaine
# RETOUR 1 la position demandée est dans une chaine

Funprog DANSQUOTE (PCHAINE, PPOSITION)
#Value Char CHAINE
Variable Clbfile PCHAINE
Value Shortint PPOSITION

Local Shortint DI1,DI2, DID, DIS, RETOUR
Local Shortint SIMPLEQUOT, DOUBLEQUOT, LGCH

    If PPOSITION = 0
        End 0
    Endif


# On cherche le 1° délimiteur de chaine quote ou doublequote

    RETOUR = 0
    SIMPLEQUOT = 0
    DOUBLEQUOT = 0
    DI1 = 0

    LGCH = len(PCHAINE)
    DID = instr(1, PCHAINE, '"')
    DIS = instr(1, PCHAINE, "'")

    If DID
        DOUBLEQUOT = 1
        DI1 = DID
    Endif

  #  qui est le premier ? quote ou doublequote
    If DIS  and (DIS < DID or DID = 0)
        DI1 = DIS
        SIMPLEQUOT = 1
        DOUBLEQUOT = 0
    Endif

    # pas de quote (ou double)
    If DI1 = 0
        End 0
    Endif
    # quote après la position
    If DI1 > PPOSITION
        End 0
    Endif

    DI1 += 1

    While DI1 < LGCH
        If DOUBLEQUOT
            DID = instr(DI1, PCHAINE, '"')
            If DID > PPOSITION
                RETOUR = 1
                Break
            Endif
            If DID
                DI1 = DID + 1
            Endif
            DOUBLEQUOT  = 0
        Elsif SIMPLEQUOT
            DIS = instr(DI1, PCHAINE, "'")
            If DIS > PPOSITION
                RETOUR = 1
                Break
            Endif
            If DIS
                DI1 = DIS + 1
            Endif
            SIMPLEQUOT  = 0
        Else
            DID = instr(DI1, PCHAINE, '"')
            DIS = instr(DI1, PCHAINE, "'")

            If DID
                DOUBLEQUOT = 1
                DI1 = DID
            Endif
            #  qui est le premier ? quote ou doublequote
            If DIS  and (DIS < DID or DID = 0)
                DI1 = DIS
                SIMPLEQUOT = 1
                DOUBLEQUOT = 0
            Endif
            # si on commence une chaine après, on n'est pas dedans...
            If DI1 > PPOSITION
                RETOUR = 0
                Break
            Endif
            # si on n'a rien trouvé, on n'est pas dedans...
            If DID = 0 and DIS = 0
                RETOUR = 0
                Break
            Endif
            DI1 += 1
        Endif
    Wend


End RETOUR



#____________________________________________________________________________________
# supprime la partie commentaire d'une ligne
Subprog VIRECOMMEN(PCHAINE)
Variable Clbfile PCHAINE

Local Integer ID


    # Si la chaine est toute un commentaire
    If left$(PCHAINE, 1) = "#" or left$(PCHAINE, 2) = " #"
        PCHAINE = ""
    Else

        PCHAINE = vireblc(PCHAINE, 5)
        # trouve-t'on un commentaire en fin de chaine
        #ID = instr(1, PCHAINE, ":#")
       ID = instr(1, PCHAINE, ":#")
       If ID = 0
           ID = instr(1, PCHAINE, ": #")
       Endif
       If ID = 0
            ID = instr(1, PCHAINE, "#")
       Endif

       If ID
            # vérifier si on n'est pas ds une chaine "ddd: #" ou 'ddd:#'
            If func DANSQUOTE(PCHAINE, ID) = 0
                PCHAINE = left$(PCHAINE, ID - 1)
            Endif
       Endif
    Endif
End





Subprog LIREETFMT(RCHAINE, RCHAINELEC, RBCHAINELEC, RFST, RNLIG, RNSK, RNSKLEC)
Variable Clbfile RCHAINE, RCHAINELEC
Variable Integer RBCHAINELEC, RFST, RNLIG, RNSK, RNSKLEC

Local Clbfile WCHAINE1(3)

    If RBCHAINELEC
        RCHAINE = RCHAINELEC
        RCHAINELEC = ""
        RBCHAINELEC = 0
        RNSK = RNSKLEC
    Else
        RNSK = adxseek(0)
        Rdseq RCHAINE
        RFST = fstat
    Endif
    RNLIG += 1

    While RFST = 0
        RNSKLEC = adxseek(0)
        Rdseq WCHAINE1
        RFST = fstat
        If left$(WCHAINE1, 1) = "&"
            RNLIG += 1
            RCHAINE = RCHAINE - right$(WCHAINE1, 2)
        Else
            RCHAINELEC = WCHAINE1
            RBCHAINELEC = 1
            Break
        Endif
    Wend

    # Pour éviter les problèmes de variables intégrant un CALL et les commentaires...
    # pas de blanc en début et fin et pas de blancs consécutifs

    Call FMTCLOB(RCHAINE)
#    Call PURGECH("Wrseq", RCHAINE, 1)
    # sur cette moulinette, on recherche les evalue ("if dim...
    If GNUMMOUL = 9
        If pat(RCHAINE, "*evalue*") = 0
            Call PURGECH("", RCHAINE, 1)
        Endif
    #CBO 20110110 FQ70043
    Elsif GNUMMOUL <> -1

        Call PURGECH("", RCHAINE, 1)
    Endif
End

######################################################################################
# format un clbfile selon "KT:250X" et enlève les blanc aux extrémités et n'en laisse qu'1 entre 2
Subprog FMTCLOB(RCHAINE)
Variable Clbfile RCHAINE


Local Clbfile CHTMP(3)
#Local Char CHN1(250), CHN1W(30), CHN1SAV(30)
Local Char WFORMAT(10)


    CHTMP = vireblc(vireblc(RCHAINE, 2), 5)

    If CHTMP = ""
        RCHAINE = ""
        End
    Endif

    If len(CHTMP) < 251
        WFORMAT = "KT:250X"
#        CHTMP = toupper(CHTMP)
        RCHAINE = format$(WFORMAT, CHTMP)
        RCHAINE = vireblc(RCHAINE, 2)
    Else
        RCHAINE = CHTMP
    Endif
End



Funprog SRCAPASTRAITER(SRCCOURANT, SRCPARAM, PCHEDOSSIER, PMODULE, PEXCLSUP, PATCH, SRCPATCH, OWNER, TXTERR, PDEMANDEUR)

Value Char SRCCOURANT, SRCPARAM
Value Char PCHEDOSSIER
Value Integer PMODULE, PEXCLSUP
Value Char PATCH, SRCPATCH
Value Integer OWNER
Variable Char TXTERR
Value Integer PDEMANDEUR

# niveau du demandeur : -1 tous les pgms (source existant) sauf W
#                       -2 tous les pgms (source existant) avec W
#                       -5 les pgms W*
#                        1 indus
#                        5 dev
#                       10 vertical
#                       15 spécif

# retour :  0 à traiter
#           1 ne pas traiter
#           2 erreur
#           3 warning + arrêt
#           4 warning + suite
#           5 pas le source mais le trt

Local Integer BSPECIF

    # source ne correspond pas à la sélection (SRCPARAM)
    If SRCPARAM <> "" and SRCPARAM <> "*"
        If (pat(SRCCOURANT, SRCPARAM) = 0)
            End 1
        Endif
    Endif

    If PDEMANDEUR = -1 or PDEMANDEUR = -2
        # source non trouvé
        If filinfo(filpath("TRT", SRCCOURANT, "src", PCHEDOSSIER), 0) < 0
            End 1
        Endif

    # contrôle du module
        If PMODULE or PEXCLSUP = 2
            Read [ADC]ADC0 = SRCCOURANT
            If fstat
                [F:ADC]MODULE = 0
                End 1
            Else
                If PMODULE and [F:ADC]MODULE <> PMODULE
                    End 1
                Endif

                If PEXCLSUP = 2 and [F:ADC]MODULE = 1
                    End 1
                Endif
            Endif
        Endif

        End 0
    Endif

    If PDEMANDEUR = -5
        # source non trouvé
        If left$(SRCCOURANT, 1) < "W"
            End 1
        Endif
        If filinfo(filpath("TRT", SRCCOURANT, "src", PCHEDOSSIER), 0) < 0
            End 1
        Endif
        End 0
    Endif


    If pat(SRCCOURANT, "GES*")
        End 1
    Endif

    # traitements de migration de l'intégrale vers X3 : utilise des tables X... avec code activité
    If left$(SRCCOURANT, 3) = "SIX" or SRCCOURANT = "SUBSIP" or SRCCOURANT = "SUBSIT" or SRCCOURANT = "SUBSITF"
        End 1
    Endif

    # source non trouvé

    If filinfo(filpath("TRT", SRCCOURANT, "src", PCHEDOSSIER), 0) < 0
        End 1
    Endif


    BSPECIF = 0
    If   left$(SRCCOURANT, 3) = "SPE" or
&   (left$(SRCCOURANT, 3) = "SUB" and SRCCOURANT > "SUBX") or
&   (left$(SRCCOURANT, 3) = "IMP" and SRCCOURANT > "IMPX") or
&   (left$(SRCCOURANT, 3) = "FUN" and SRCCOURANT > "FUNX") or
&   (left$(SRCCOURANT, 3) = "CNS" and SRCCOURANT > "CNSX") or
&   (left$(SRCCOURANT, 3) = "CNS" and right$(SRCCOURANT, len(SRCCOURANT)-2) = "SPE")
        BSPECIF = 1
    Endif


    # contrôle du module
    Read [ADC]ADC0 = SRCCOURANT
    If fstat
        [F:ADC]MODULE = 0
        If PDEMANDEUR = 0 and left$(SRCCOURANT, 1) < "W"

            If BSPECIF
                # Le message est en dur : ne sort qu'en indus
                TXTERR = "  ***" - SRCCOURANT - ":" - "Source ne devrait pas être présent en environnement Indus."
                End 3
            Endif
            # Le message est en dur : ne sort qu'en indus
            TXTERR = "  ***" - SRCCOURANT - ":" - "Source ne devrait pas être présent en environnement Indus."
            If PMODULE
                End 3
            Endif
            End 4
        Endif
    Else
        If PMODULE <> 0 and [F:ADC]MODULE <> PMODULE
            End 1
        Endif

        If PEXCLSUP = 2 and [F:ADC]MODULE = 1
            End 1
        Endif
    Endif

    # contrôle du owner (si source standard)
    If  left$(SRCCOURANT, 1) < "W"
        If PATCH=""
            If OWNER <> 0 and filinfo(filpath("TRT", SRCCOURANT, "src", PCHEDOSSIER), 5) <> OWNER
                End 1
            Endif
        Else
            If OWNER
                If filinfo(SRCPATCH + "/" + SRCCOURANT + ".src", 5) <> OWNER
                    End 1
                Endif
            Else
                If filinfo(SRCPATCH + "/" + SRCCOURANT + ".src", 0) <= 0
                    End 2
                Endif
            Endif
        Endif
    Endif

    If func NVDEMANDEUR (PDEMANDEUR, SRCCOURANT) = 0
        End 1
    Endif
End 0



# cette fonction indque si le niveau du demandeur est OK par rapport au traitement
# Dans ce cas, un traitement pourra sortir (éventuellement) en erreur

# Niveau
#  0 = Sage Indus   : le traitement doit être < W  -> ne sort pas en erreur si non trouvé
#  5 = Sage Dev     : le traitement doit être < W  -> ne sort pas en erreur si non trouvé
# 10 = Distributeur :
# 15 = Client       : tout Ok
# -1 = Tout sauf W
# -2 = Tout avec W
# -5 = Générés W

# retour :
# 0 ne pas contrôler
# 1 contrôler
# 2 hors plage distri/spécif (ABANDONNE)
# 5 pas de source mais traitement trouvé (dossier ou dossier > )

Funprog NVDEMANDEUR (PDEMANDEUR, PTRAITEMENT)
Value Integer PDEMANDEUR
Value Char PTRAITEMENT



    # Industrialisation ou Développement
    If (PDEMANDEUR = 0 or PDEMANDEUR = 5) and PTRAITEMENT < "W" and
&        left$(PTRAITEMENT, 3) <> "SPE" and left$(PTRAITEMENT, 3) <> "SPV" and
&        (left$(PTRAITEMENT, 3) <> "CNS" or right$(PTRAITEMENT, len(PTRAITEMENT)-2) <> "SPE")
        End 1
    # Développement
#    Elsif PDEMANDEUR = 5 and PTRAITEMENT < "W" and left$(PTRAITEMENT, 3) <> "SPE"
#        End 1

    # Distributeur ou spécifique
    Elsif PDEMANDEUR = 10 or PDEMANDEUR = 15

        If PTRAITEMENT < "X" and
&           left$(PTRAITEMENT, 3) <> "SPE" and left$(PTRAITEMENT, 3) <> "SPV" and
&          (left$(PTRAITEMENT, 3) <> "CNS" or right$(PTRAITEMENT, len(PTRAITEMENT)-2) <> "SPE")
            End 0
        Endif

        # source non trouvé et trt existe
        If filinfo(filpath("TRT", PTRAITEMENT, "src", [M:DIA]DOSSIER), 0) < 0
            # trt non trouvé
            If filinfo(filpath("TRT", PTRAITEMENT, "adx", [M:DIA]DOSSIER), 0) >= 0
                End 5
            Endif
            If GAWDOSDISTRI <> "" and filinfo(filpath("TRT", PTRAITEMENT, "adx", GAWDOSDISTRI), 0) >= 0
                End 5
            Endif
            If GAWDOSSPECIF <> "" and filinfo(filpath("TRT", PTRAITEMENT, "adx", GAWDOSSPECIF), 0) >= 0
                End 5
            Endif
        Endif

        End 1

    # cas pour ne rien exclure
    Elsif PDEMANDEUR = -1 or  PDEMANDEUR = -2
        End 1
    # cas pour traiter les générés
    Elsif PDEMANDEUR = -5 and left$(PTRAITEMENT, 1) = "W"
        End 1
    Endif

End 0





# cherche les trts en fonction du demandeur (Indus, dev, distri, client...)
Subprog LISTETRT(PDEMANDEUR, PPORT, PMACHINE, PDOSSIER)
Value Integer PDEMANDEUR, PPORT
Value Char PMACHINE, PDOSSIER

If PDEMANDEUR = -1
Local Char WTTRTS(GLONADC)(1..15000), WMACHINE(100)
Else
Local Char WTTRTS(GLONADC)(1..GMAX_TRT), WMACHINE(100)
Endif
Local Integer WNBTRTS, I

# Dossier niveau 1 (X3)
#  0 = Sage Indus   : le traitement doit être < W  -> ne sort pas en erreur si non trouvé
#  5 = Sage Dev     : le traitement doit être < X  -> ne sort pas en erreur si non trouvé

# Dossier niveau 2 (Distributeur)
# 10 = Distributeur : le traitement doit être < Y  -> ne sort pas en erreur si non trouvé

# Dossier niveau 3 (Spécifique)
# 15 = Client       : tout Ok

    If PMACHINE = ""
        WMACHINE = ""
    Else
        WMACHINE = PMACHINE + ":" + num$(PPORT)
    Endif

Local Char    MACHINE(50), OS_ORD(GDIMFIC)(1..3)
Call GET_OS(MACHINE, OS_ORD) From ORDSYS
#Infbox OS_ORD(1) - OS_ORD(2)

    Raz WTTRTS, WNBTRTS, GTTRAITEMENTS, GNBTRTADX

    # Contrôle de tout

    If PDEMANDEUR = -1
        Call SYSTEME2(WMACHINE, 'lsadx -a' - PDOSSIER - 'TRT adx', "", WNBTRTS, WTTRTS) From ORDSYS

        GNBTRTADX = 0
        For I = 1 To WNBTRTS
            If left$(WTTRTS(I), 1) <> "W"
                GNBTRTADX += 1
                GTTRAITEMENTS(GNBTRTADX) = WTTRTS(I)
            Endif
        Next I

        End
    Endif

    If PDEMANDEUR = -2
        Call SYSTEME2(WMACHINE, 'lsadx -a' - PDOSSIER - 'TRT adx', "", GNBTRTADX, GTTRAITEMENTS) From ORDSYS
        End
    Endif

    If OS_ORD(1) = "unix"
        If PDEMANDEUR = 0 or PDEMANDEUR = 5
            Call SYSTEME2(WMACHINE, 'lsadx -a' - PDOSSIER - 'TRT adx | grep "^[A-V]"', "", GNBTRTADX, GTTRAITEMENTS) From ORDSYS
        Elsif PDEMANDEUR = 10 or PDEMANDEUR = 15

            If GADONIX = 2
                Call SYSTEME2(WMACHINE, 'lsadx -a' - PDOSSIER - 'TRT adx | grep "^[A-V]"', "", GNBTRTADX, GTTRAITEMENTS) From ORDSYS
            Else
                # 1°) chargement des CNS * SPE
                Call SYSTEME2(WMACHINE, 'lsadx -a' - PDOSSIER - 'TRT adx | grep "^[C-C]"', "", WNBTRTS, WTTRTS) From ORDSYS

                GNBTRTADX = 0
                For I = 1 To WNBTRTS
                    If (left$(WTTRTS(I), 3) = "CNS" and right$(WTTRTS(I), len(WTTRTS(I))-2) = "SPE")
                        GNBTRTADX += 1
                        GTTRAITEMENTS(GNBTRTADX) = WTTRTS(I)
                    Endif
                Next I


                # 2°) chargement des SPExxx et SPVxxx
                Raz WTTRTS, WNBTRTS
                Call SYSTEME2(WMACHINE, 'lsadx -a' - PDOSSIER - 'TRT adx | grep "^[S-S]"', "", WNBTRTS, WTTRTS) From ORDSYS

                For I = 1 To WNBTRTS
                    If left$(WTTRTS(I), 3) = "SPE" or  left$(WTTRTS(I), 3) = "SPV"
                        GNBTRTADX += 1
                        GTTRAITEMENTS(GNBTRTADX) = WTTRTS(I)
                    Endif
                Next I
            Endif

            # 3°) chargement de l'intervalle
            Raz WTTRTS, WNBTRTS
            Call SYSTEME2(WMACHINE, 'lsadx -a' - PDOSSIER - 'TRT adx | grep "^[X-Z]"', "", WNBTRTS, WTTRTS) From ORDSYS

            For I = 1 To WNBTRTS
                GNBTRTADX += 1
                GTTRAITEMENTS(GNBTRTADX) = WTTRTS(I)
            Next I

        # Contrôle des générés
        Elsif PDEMANDEUR = -5

            # récup des pgms superviseur
            Call SYSTEME2(WMACHINE, 'lsadx -a' - PDOSSIER - 'TRT adx | grep "^[A-V]"', "", WNBTRTS, WTTRTS) From ORDSYS

            For I = 1 To WNBTRTS
                # contrôle du module
                Read [ADC]ADC0 = WTTRTS(I)
                If fstat = 0 and [F:ADC]MODULE = 1
                    GNBTRTADX += 1
                    GTTRAITEMENTS(GNBTRTADX) = WTTRTS(I)
                Endif
            Next I

            # 2°) chargement des pgms générés
            Raz WTTRTS, WNBTRTS
            Call SYSTEME2(WMACHINE, 'lsadx -a' - PDOSSIER - 'TRT adx | grep "^[W-W]"', "", WNBTRTS, WTTRTS) From ORDSYS

            # 3°) ajout de l'intervalle au tableau principal
            For I = 1 To WNBTRTS
                GNBTRTADX += 1
                GTTRAITEMENTS(GNBTRTADX) = WTTRTS(I)
            Next I
        Endif
    Else

        # cas Windows ________________________________________________________________________________

        Call SYSTEME2(WMACHINE, 'lsadx -a' - PDOSSIER - 'TRT adx', "", WNBTRTS, WTTRTS) From ORDSYS
#        Infbox num$(WNBTRTS)


        If PDEMANDEUR = 0 or PDEMANDEUR = 5

            For I = 1 To WNBTRTS
                If left$(WTTRTS(I), 1) <= "V"
                    GNBTRTADX += 1
                    GTTRAITEMENTS(GNBTRTADX) = WTTRTS(I)
                Endif
            Next I

        Elsif PDEMANDEUR = 10 or PDEMANDEUR = 15

            # 1°) chargement des CNS * SPE
            # 2°) chargement des SPExxx et SPVxxx
            # 3°) chargement de l'intervalle

            For I = 1 To WNBTRTS

                If (GADONIX = 2 and
&                   ((left$(WTTRTS(I), 1) >= "A" and left$(WTTRTS(I), 1) <= "V") or
&                    (left$(WTTRTS(I), 1) >= "X" and left$(WTTRTS(I), 1) <= "Z"))) or
&                  (GADONIX <> 2 and
&                    ((left$(WTTRTS(I), 3) = "CNS" and right$(WTTRTS(I), len(WTTRTS(I))-2) = "SPE") or
&                   left$(WTTRTS(I), 3) = "SPE" or  left$(WTTRTS(I), 3) = "SPV" or
&                   left$(WTTRTS(I), 1) >= "X"))
                    GNBTRTADX += 1
                    GTTRAITEMENTS(GNBTRTADX) = WTTRTS(I)
                Endif
            Next I

        # Contrôle des générés
        Elsif PDEMANDEUR = -5

            # 1°) récup des pgms superviseur
            # 2°) chargement des pgms générés
            Call SYSTEME2(WMACHINE, 'lsadx -a' - PDOSSIER - 'TRT adx | grep "^[A-V]"', "", WNBTRTS, WTTRTS) From ORDSYS
            For I = 1 To WNBTRTS
                If left$(WTTRTS(I), 1) <= "V"
                    # contrôle du module
                    Read [ADC]ADC0 = WTTRTS(I)
                    If fstat = 0 and [F:ADC]MODULE = 1

                        GNBTRTADX += 1
                        GTTRAITEMENTS(GNBTRTADX) = WTTRTS(I)
                    Endif
                Elsif left$(WTTRTS(I), 1) = "W"
                    GNBTRTADX += 1
                    GTTRAITEMENTS(GNBTRTADX) = WTTRTS(I)
                Endif

            Next I
        Endif
    Endif
    Raz WTTRTS, WNBTRTS

#    If GSERVEUR = 0 and GNBTRTADX > 0.9 * GMAX_TRT
#        Infbox "Attention :" - num$(GNBTRTADX) - "traitements trouvés et max possible =" - num$(GMAX_TRT)
#    Endif
End


# recherche le niveau du dossier traité
Funprog NIVDOSDEMAND(PINDUS, PMACHINE, PPORT, PDOSSIER, RNVDEMANDEUR, RTBMODULE, RMINMODULE, RMAXMODULE)

Value Integer PINDUS  # indique si on vient de INDUSPRD, MNTPRD ou ... (1, 0)
Value Char PMACHINE
Value Integer PPORT
Value Char PDOSSIER
Variable Integer RNVDEMANDEUR, RTBMODULE(), RMINMODULE, RMAXMODULE


Local Char WDOS(200)

    # recherche du dossier système
    If PMACHINE = ""
        WDOS = PDOSSIER
    Else
        WDOS = PMACHINE + ":" + num$(PPORT) + "@" + PDOSSIER
    Endif
    If GAWVERSION > 6

        WDOS = func DOSCONT.DOSX3(WDOS)
        If clalev ([ADS])
            Close File [ADS]
        Endif
    Endif
    Local File = WDOS + ".ADOSSIER" [ADS]


    Read [ADS]DOSSIER = PDOSSIER
    If fstat
        Close File [ADS]
        End 0
    Endif

    # appelé à partir de l'env d'indus : c'est le niveau correspondant à une fabrication de version
    If PINDUS
        Call MODULEACTIF(RTBMODULE, RMINMODULE, RMAXMODULE, WDOS)
        RNVDEMANDEUR = 0
        End 1
    Endif

    If [F:ADS]DOSREF = "" or [F:ADS]DOSREF = PDOSSIER
        # 1 seul niveau : c'est un niveau Sage : Ici développement
        Call MODULEACTIF(RTBMODULE, RMINMODULE, RMAXMODULE, WDOS)
        RNVDEMANDEUR = 5
        Close File [ADS]
        End 1
    Endif
    WDOSREF2 = [F:ADS]DOSREF
    GAWDOSDISTRI = [F:ADS]DOSREF

    Read [ADS]DOSSIER = [F:ADS]DOSREF
    If fstat
        Close File [ADS]
        End 0
    Endif

    If [F:ADS]DOSREF = "" or [F:ADS]DOSREF = WDOSREF2
        # 1 deuxième niveau : c'est un niv de developpement distributeur
        Call MODULEACTIF(RTBMODULE, RMINMODULE, RMAXMODULE, WDOS)
        RNVDEMANDEUR = 10
        Close File [ADS]
        End 1
    Endif
    GAWDOSSPECIF = [F:ADS]DOSREF

    Read [ADS]DOSSIER = [F:ADS]DOSREF
    If fstat = 0 and [F:ADS]DOSREF <> "" and [F:ADS]DOSREF <> [F:ADS]DOSSIER
        # 1 troisième niveau : c'est un niv de developpement spécifique
        Call MODULEACTIF(RTBMODULE, RMINMODULE, RMAXMODULE, WDOS)
        RNVDEMANDEUR = 15
    Endif

    Close File [ADS]

End 1


Subprog MODULEACTIF(RTBMODULE, RMINMODULE, RMAXMODULE, PDOSSIER)
Variable Integer RTBMODULE(), RMINMODULE, RMAXMODULE
Value Char PDOSSIER

Local Integer I, WTRTTROUVE

    If clalev ([ADC])
        Close File [ADC]
    Endif
    Local File = PDOSSIER + ".ADICTRT" [ADC]


    Raz RTBMODULE
    RMINMODULE = 99
    RMAXMODULE = 0

    For I = 1 To 20
        # Module actif
        If [F:ADS]MODULE(I - 1) = 2

            Filter [ADC] Where MODULE = I
            WTRTTROUVE = 0
            For [ADC]
                WTRTTROUVE = 1
                Break
            Next
            Filter [ADC]

            If WTRTTROUVE
                RTBMODULE(I) = 1
                If I < RMINMODULE
                    RMINMODULE = I
                Endif
                If I > RMINMODULE
                    RMAXMODULE = I
                Endif
            Endif
        Endif
    Next I

    If RMINMODULE = 99
        RMINMODULE = 0
    Endif
    Close File [ADC]
End


#_____________________________________________________
# affiche le libellé du module de l'application lancée
Funprog LIBMODULE (NUMMODULE, SAUVEMODULE)
Value Shortint NUMMODULE
Variable Shortint SAUVEMODULE

    If NUMMODULE = 0
        End ""
    Endif

    If SAUVEMODULE = NUMMODULE
        End [F:AST]LANMES
    Else
        [F:AST]LANMES = ""
        SAUVEMODULE = NUMMODULE

        Read [AST]CLE=14 ; NUMMODULE ; GLANGUE
        If fstat
            End ""
        Else
            End [F:AST]LANMES
        Endif
    Endif

End



######################################################################################


# analyse un source pour charger en tableaux les variables globales et leur longueur
# ex : dans WWGLOBLON, on cherche la longeur des var commençant par GLON

Subprog CHGSRCVARGLOB(PDOSSIER, PNOMTRT, PPREFIXE, PNBVARGLOBSRC, PTYPE)
Value Char PDOSSIER, PNOMTRT, PPREFIXE
Variable Integer PNBVARGLOBSRC
Value Char PTYPE

Local Integer FST, I
Local Char CHVG(250), CHVG2(250)


    Openi filpath("TRT", PNOMTRT, "src", PDOSSIER), 0
    PNBVARGLOBSRC = 0

    FST=0

    While FST=0
        Rdseq CHVG
        FST = fstat

        Call VIRECOMMEN(CHVG)
        CHVG2 = vireblc(CHVG, 4)
        If pat(CHVG2, PPREFIXE + "*=*")
            PNBVARGLOBSRC += 1
            I = instr(1, CHVG2, "=")
            GTVARGLOBSRC(PNBVARGLOBSRC) = right$(vireblc(left$(CHVG2, I - 1), 4), 5)
            GTLGVARGLOBSRC(PNBVARGLOBSRC) = val(vireblc(right$(CHVG2, I + 1), 4))
            # si sélection sur type de données
            If PTYPE <> "" and PTYPE <> GTVARGLOBSRC(PNBVARGLOBSRC)
                GTVARGLOBSRC(PNBVARGLOBSRC) = ""
                GTLGVARGLOBSRC(PNBVARGLOBSRC) = 0
                PNBVARGLOBSRC -= 1
            Endif
        Endif
    Wend

    Openi
End

Funprog VALN(PCHAINE)
Value Char PCHAINE

Local Integer LG, I
Local Char CC(1)

    LG = len(PCHAINE)
    If LG > 6
        End -1
    Endif

    For I = 1 To LG
        CC = mid$(PCHAINE, I, 1)
        If instr(1, "0123456789", CC) = 0
            End -1
        Endif
    Next I

    End val(PCHAINE)
End


Subprog TRTINUTILISE (DOSSIER, DOSSIER2, TRTUTILISE, TRTUTILDANS, PACTION,
& NBTRAITES, INDERREUR)
Value Char DOSSIER, DOSSIER2
Variable Integer TRTUTILISE()
Variable Char TRTUTILDANS()
Value Integer PACTION, NBTRAITES
Variable Integer INDERREUR



    Local Char TLIBTAB(40)(41), WNOMOBJ(GLONAOB), DOSREFPRM(200)(20), WDOS(200), PDOSSIER(200)
    Local Integer MI1, MI2, MI3, POSUTIL, TRTTABLE(200), TRTTRVE, TRTNTPM, IREF, MAX_TBTRT, TPASFIC(200), IFIC
    Local Shortint SAUVEMODULE

    Raz TLIBTAB, TPASFIC

    Call TEMPON("VERIFCALL liste des traitements non appelés") From GESECRAN

    Wrseq ""  Using [FWR]
    Wrseq ""  Using [FWR]
    Wrseq ""  Using [FWR]
    Wrseq '                         ###------------------------------------------###' Using [FWR]
    Wrseq "-------------------------###" - mess(39, 144, 1) - "###---------------------------------" Using [FWR]
    Wrseq '                         ###------------------------------------------###' Using [FWR]
    Wrseq "" Using [FWR]
    Wrseq "" Using [FWR]
    Wrseq "" Using [FWR]

    TLIBTAB(1) = "[AMK]"
    TLIBTAB(2) = "[ACT]"
    TLIBTAB(3) = "[ARP]"
    TLIBTAB(4) = "[ATN]"
    TLIBTAB(5) = "[AHI]"

    TLIBTAB(6) = "[ACN]"
    TLIBTAB(7) = "[ABR]"
    TLIBTAB(8) = "[ABT]"
    TLIBTAB(9) = "[ADP]"
    TLIBTAB(10) = "[APE]"

    TLIBTAB(11) = "[AFC]"
    TLIBTAB(12) = "[AOB]"
    TLIBTAB(13) = "[AOE]"
    TLIBTAB(14) = "[AUR]"
    TLIBTAB(15) = "[AWE]"

    TLIBTAB(16) = "[PS2]"
    TLIBTAB(17) = "[TCY]"

    MAX_TBTRT = 17


# recherche sur le dossier étudié ------------------------------------------------------------------------------------


    PDOSSIER = DOSSIER2
    IREF = 0
    Gosub OUVREDOSSIER

    For POSUTIL = 1 To GNBTRTADX
        If GTTRAITEMENTS(POSUTIL) >= "W"
            Break
        Endif
        If mod(POSUTIL, 100) = 0
            Call TEMPON("VERIFCALL (" + DOSSIER + ") :" - num$(POSUTIL) + "/" + num$(GNBTRTADX) - GTTRAITEMENTS(POSUTIL))
&           From GESECRAN
        Endif

        If TRTUTILISE(POSUTIL) = 0

            Call TRTEXCPT(GTTRAITEMENTS(POSUTIL), TRTUTILISE(POSUTIL))
            If TRTUTILISE(POSUTIL) = 0
                TRTTABLE(199) += 1
                Call CHERCHETRT(TRTTRVE, IREF, GTTRAITEMENTS(POSUTIL), TPASFIC)

                If TRTTRVE
                    TRTTABLE(TRTTRVE) += 1
                    TRTUTILISE(POSUTIL) = 2
                    TRTUTILDANS(POSUTIL) = num$(TRTTRVE)
                Endif

            Endif
        Endif
    Next POSUTIL

    Gosub FERMEDOSSIER


# recherche sur les dossiers de référence ------------------------------------------------------------------------------------



    Raz DOSREFPRM

#   X3REFPRM est 1 dos fille de X3INDV6
#   notion de produit industrialisé : X3REFPRM et X3REFSTD sont des dossiers de ref sous X3INDV6
#   notion client X3REFPRM (ou X3REFSTD) est le dossier mère du client
#   celui du distri : fille et le spécif client petite fille : accès en remontant
#   par le champ dossier de référence sur la table ADOSSIER (table système)

    If instr(1, DOSSIER, "GE")
    Elsif instr(1, DOSSIER, "PA") or  instr(1, DOSSIER, "HR")
        DOSREFPRM(1) = "aws-x3-indv6" + ":" + num$(16170) + "@" + "PAYREFFRA"
        DOSREFPRM(2) = "aws-x3-indv6" + ":" + num$(16170) + "@" + "PAYREFPOR"
    Else
        DOSREFPRM(1) = "aws-x3-indv6" + ":" + num$(16160) + "@" + "X3REFPRM"
        DOSREFPRM(2) = "aws-x3-indv6" + ":" + num$(16160) + "@" + "X3REFSTD"
    Endif



    For IREF = 1 To 5
        If DOSREFPRM(IREF) <> ""

            PDOSSIER = DOSREFPRM(IREF)
            Gosub OUVREDOSSIER

            POSUTIL = instr(1, DOSREFPRM(IREF), "@")
            WDOS = right$(DOSREFPRM(IREF), POSUTIL + 1)

            For POSUTIL = 1 To GNBTRTADX
                If GTTRAITEMENTS(POSUTIL) >= "W"
                    Break
                Endif

                If mod(POSUTIL,100)=0
                    Call TEMPON("VERIFCALL (" + WDOS +") :" - num$(POSUTIL) + "/" + num$(GNBTRTADX) - GTTRAITEMENTS(POSUTIL))
&                   From GESECRAN
                Endif

                If TRTUTILISE(POSUTIL) = 0

                    Call CHERCHETRT(TRTTRVE, IREF, GTTRAITEMENTS(POSUTIL), TPASFIC)

                    If TRTTRVE
                        TRTTABLE(TRTTRVE) += 1
                        TRTUTILISE(POSUTIL) = IREF + 10
                        TRTUTILDANS(POSUTIL) = num$(TRTTRVE)
                    Endif

                Endif
            Next POSUTIL

            Gosub FERMEDOSSIER
        Endif
    Next IREF



# boucle sur les erreurs (par module) ------------------------------------------------------------------------------------



    If instr(1, DOSSIER, "GE")
        MI2 = 1
        MI3 = 2
    Elsif instr(1, DOSSIER, "PA") or  instr(1, DOSSIER, "HR")
        MI2 = 1
        MI3 = 10
    Else
        MI2 = 1
        MI3 = 14
    Endif
    Wrseq mess(40, 144, 1)- ":" - num$(NBTRAITES) Using [FWR]

    For MI1 = MI2 To MI3
        [M:DIA]NUMMODULE = MI1
        TRTNTPM = 0

        If instr(1, [M:DIA]DOSSIER, "X3") and (MI1 = 4 or MI1 = 10 or MI1 = 11)
        Else
            Wrseq "" Using [FWR]
            Wrseq "" Using [FWR]
            Wrseq " ******" - mess(10, 144, 1) - num$(MI1) - ":" - func LIBMODULE (MI1, SAUVEMODULE) Using [FWR]
            Wrseq "" Using [FWR]

            For POSUTIL = 1 To GNBTRTADX
                If GTTRAITEMENTS(POSUTIL) >= "W"
                    Break
                Endif
                If mod(POSUTIL,100)=0
                    Call TEMPON("VERIFCALL (module" - num$(MI1) + ") :" - num$(POSUTIL) + "/" + num$(GNBTRTADX) - GTTRAITEMENTS(POSUTIL))
&                   From GESECRAN
                Endif


                Read [ADC]ADC0 = GTTRAITEMENTS(POSUTIL)
                If fstat = 0 and [F:ADC]MODULE = MI1

                    # écritures immos
                    If [F:ADC]MODULE = 14 and (left$(GTTRAITEMENTS(POSUTIL), 2) = "GV" or left$(GTTRAITEMENTS(POSUTIL), 2) = "GW")
                        TRTUTILISE(POSUTIL) = -1
                    Endif

                    If TRTUTILISE(POSUTIL) = 0
                        TRTTABLE(199) += 1
                        Wrseq func MESNUM(41, 144, GTTRAITEMENTS(POSUTIL), "", "", "", "") Using [FWR]
                        INDERREUR += 1
                        TRTNTPM += 1
# débloquer si on veut trouver qui (au moins) utilise le traitement (autre trt ou table)
#                    Elsif TRTUTILISE(POSUTIL) = 1 and PACTION = 1
#                        Wrseq "traitement" - GTTRAITEMENTS(POSUTIL) - "appelé dans le traitement" - TRTUTILDANS(POSUTIL) Using [FER]
#                    Elsif TRTUTILISE(POSUTIL) > 1 and PACTION = 1
#                        Wrseq "traitement" - GTTRAITEMENTS(POSUTIL) - "appelé dans la table" - TLIBTAB(mod(val(TRTUTILDANS(POSUTIL)), 20)) Using [FER]
                    Endif

                Endif
            Next POSUTIL

            Wrseq "" Using [FWR]
            Wrseq "Total :" - num$(TRTNTPM) Using [FWR]
        Endif
    Next MI1

    # recherche sur les modules non trouvés (si pas de sel sur les modules)
    If MI2 <> MI3

        TRTNTPM = 0
        Wrseq "" Using [FWR]
        Wrseq "" Using [FWR]
        Wrseq " ******  " + mess(42, 144, 1) Using [FWR]
        Wrseq "" Using [FWR]

        For POSUTIL = 1 To GNBTRTADX
            If GTTRAITEMENTS(POSUTIL) >= "W"
                Break
            Endif
            If mod(POSUTIL,100) = 0
                Call TEMPON("VERIFCALL (sans module) :" - num$(POSUTIL) + "/" + num$(GNBTRTADX) - GTTRAITEMENTS(POSUTIL))
&               From GESECRAN
            Endif

            If TRTUTILISE(POSUTIL) = 0

                Read [ADC]ADC0 = GTTRAITEMENTS(POSUTIL)
                If (fstat = 0 and [F:ADC]MODULE = 0) or fstat
                    [F:ADC]MODULE = 0

                    If TRTUTILISE(POSUTIL) = 0
                        Wrseq func MESNUM(41, 144, GTTRAITEMENTS(POSUTIL), "", "", "", "") Using [FWR]
                        INDERREUR += 1
                        TRTNTPM += 1
# débloquer si on veut trouver qui (au moins) utilise le traitement (autre trt ou table)
#                    Elsif TRTUTILISE(POSUTIL) = 1 and PACTION = 1
#                        Wrseq "traitement" - GTTRAITEMENTS(POSUTIL) - "appelé dans le traitement" - TRTUTILDANS(POSUTIL) Using [FER]
#                    Elsif TRTUTILISE(POSUTIL) > 1 and PACTION = 1
#                        Wrseq "traitement" - GTTRAITEMENTS(POSUTIL) - "appelé dans la table" - TLIBTAB(mod(val(TRTUTILDANS(POSUTIL)), 20)) Using [FER]
                    Endif
                Endif
            Endif
        Next POSUTIL
        Wrseq "" Using [FWR]
        Wrseq "Total :" - num$(TRTNTPM) Using [FWR]
    Endif

    Wrseq "" Using [FWR]
    Wrseq "" Using [FWR]
    Wrseq func MESNUM(43, 144, num$(INDERREUR), num$(TRTTABLE(199)), "", "", "") Using [FWR]
    Wrseq "" Using [FWR]
    Wrseq "" Using [FWR]


# comptabilisation des tables ayant trouvé un traitement

    For POSUTIL = 1 To MAX_TBTRT
        If TLIBTAB(POSUTIL) <> "" and TPASFIC(POSUTIL) = 0
            Wrseq func MESNUM(44, 144, TLIBTAB(POSUTIL), DOSSIER, num$(TRTTABLE(POSUTIL)), "", "") Using [FWR]
        Endif
    Next POSUTIL
    Wrseq "" Using [FWR]

    For IREF = 1 To 5
        If DOSREFPRM(IREF) <> ""
            POSUTIL = instr(1, DOSREFPRM(IREF), "@")
            Wrseq "" Using [FWR]
            DOSREFPRM(IREF) = right$(DOSREFPRM(IREF), POSUTIL + 1)
            For POSUTIL = 1 To MAX_TBTRT
                If TLIBTAB(POSUTIL) <> "" and TPASFIC(IREF * 20 + POSUTIL) = 0
                    Wrseq func MESNUM(44, 144, TLIBTAB(POSUTIL), DOSREFPRM(IREF), num$(TRTTABLE(IREF * 20 + POSUTIL)), "", "") Using [FWR]
                Endif
            Next POSUTIL
        Endif
    Next IREF

    Wrseq "" Using [FWR]
    Wrseq "" Using [FWR]

End





Subprog CHERCHETRT(PTRTTRVE, PIREF, PTRAITEMENT, TPASFIC)
Variable Integer PTRTTRVE, PIREF
Variable Char PTRAITEMENT
Variable Integer TPASFIC()

Local Integer IFIC

    PTRTTRVE = 0
    IFIC = PIREF * 20

    IFIC +=1
    If TPASFIC(IFIC) = 0
        Filter [AMK] Where TRTSTD = PTRAITEMENT or TRTSPE = PTRAITEMENT or TRTSPV = PTRAITEMENT
        For [AMK]
            PTRTTRVE = IFIC
            Break
        Next
        Filter [AMK]
        If PTRTTRVE
            End
        Endif
    Endif

    IFIC +=1
    If TPASFIC(IFIC) = 0
        Filter [ACT] Where CODTRT = PTRAITEMENT or SPETRT = PTRAITEMENT
        For [ACT]
            PTRTTRVE = IFIC
            Break
        Next
        Filter [ACT]
        If PTRTTRVE
            End
        Endif
    Endif

    IFIC +=1
    If TPASFIC(IFIC) = 0
        Filter [ARP] Where TRTINI = PTRAITEMENT or TRTSPE = PTRAITEMENT
        For [ARP]
            PTRTTRVE = IFIC
            Break
        Next
        Filter [ARP]
        If PTRTTRVE
            End
        Endif
    Endif


    IFIC +=1
    If TPASFIC(IFIC) = 0
        Filter [ATN] Where CODTRT = PTRAITEMENT
        For [ATN]
            PTRTTRVE = IFIC
            Break
        Next
        Filter [ATN]
        If PTRTTRVE
            End
        Endif
    Endif

    # n° 5
    IFIC +=1
    If TPASFIC(IFIC) = 0
        Filter [AHI] Where CTLTRT = PTRAITEMENT or SPETRT = PTRAITEMENT
        For [AHI]
            PTRTTRVE = IFIC
            Break
        Next
        Filter [AHI]
        If PTRTTRVE
            End
        Endif
    Endif

    IFIC +=1
    If TPASFIC(IFIC) = 0
        Filter [ACN] Where PRGSTD = PTRAITEMENT or PRGSTD = PTRAITEMENT
        For [ACN]
            PTRTTRVE = IFIC
            Break
        Next
        Filter [ACN]
        If PTRTTRVE
            End
        Endif
    Endif

    IFIC +=1
    If TPASFIC(IFIC) = 0
        Filter [ABR] Where ETAT = PTRAITEMENT
        For [ABR]
            PTRTTRVE = IFIC
            Break
        Next
        Filter [ABR]
        If PTRTTRVE
            End
        Endif
    Endif

    IFIC +=1
    If TPASFIC(IFIC) = 0
        Filter [ABT] Where PROGPAR = PTRAITEMENT or TRAIT = PTRAITEMENT
        For [ABT]
            PTRTTRVE = IFIC
            Break
        Next
        Filter [ABT]
        If PTRTTRVE
            End
        Endif
    Endif

    IFIC +=1
    If TPASFIC(IFIC) = 0
        Filter [ADP] Where TRAIT = PTRAITEMENT
        For [ADP]
            PTRTTRVE = IFIC
            Break
        Next
        Filter [ADP]
        If PTRTTRVE
            End
        Endif
    Endif

    # n° 10
    IFIC +=1
    If TPASFIC(IFIC) = 0
        Filter [APE] Where TRTSTD = PTRAITEMENT or TRTSPE = PTRAITEMENT
        For [APE]
            PTRTTRVE = IFIC
            Break
        Next
        Filter [APE]
        If PTRTTRVE
            End
        Endif
    Endif

    IFIC +=1
    If TPASFIC(IFIC) = 0
        Filter [AFC] Where TRAIT = PTRAITEMENT
        For [AFC]
            PTRTTRVE = IFIC
            Break
        Next
        Filter [AFC]
        If PTRTTRVE
            End
        Endif
    Endif

    IFIC +=1
    If TPASFIC(IFIC) = 0
        Filter [AOB] Where TRTSPE = PTRAITEMENT or TRTSPV = PTRAITEMENT
        For [AOB]
            PTRTTRVE = IFIC
            Break
        Next
        Filter [AOB]
        If PTRTTRVE
            End
        Endif
    Endif

    IFIC +=1
    If TPASFIC(IFIC) = 0
        Filter [AOE] Where TRTIMP = PTRAITEMENT or SPEIMP = PTRAITEMENT
        For [AOE]
            PTRTTRVE = IFIC
            Break
        Next
        Filter [AOE]
        If PTRTTRVE
            End
        Endif
    Endif


    IFIC +=1
    If TPASFIC(IFIC) = 0
        Filter [AUR] Where UPRG = PTRAITEMENT
        For [AUR]
            PTRTTRVE = IFIC
            Break
        Next
        Filter [AUR]
        If PTRTTRVE
            End
        Endif
    Endif

    # n° 15
    IFIC +=1
    If TPASFIC(IFIC) = 0
        Filter [AWE] Where PRG = PTRAITEMENT
        For [AWE]
            PTRTTRVE = IFIC
            Break
        Next
        Filter [AWE]
        If PTRTTRVE
            End
        Endif
    Endif

    IFIC +=1
    If TPASFIC(IFIC) = 0
        Filter [PS2] Where PERPRG = PTRAITEMENT
        For [PS2]
            PTRTTRVE = IFIC
            Break
        Next
        Filter [PS2]
        If PTRTTRVE
            End
        Endif
    Endif

    IFIC +=1
    If TPASFIC(IFIC) = 0
        Filter [TCY] Where CTLPRG = PTRAITEMENT
        For [TCY]
            PTRTTRVE = IFIC
            Break
        Next
        Filter [TCY]
    Endif

End




Subprog TRTEXCPT(PTRAITEMENT, PTRTUTILISE)
Variable Char PTRAITEMENT
Variable Integer PTRTUTILISE

Local Char WNOMOBJ(20)

    # moulinettes de patch
    If left$(PTRAITEMENT, 3) = "UTI" or left$(PTRAITEMENT, 2) = "UU"
        PTRTUTILISE = -1
        End
    Endif


    # migration intégrale
    If left$(PTRAITEMENT, 3) = "SIX"
&      or PTRAITEMENT = "SUBSIP" or PTRAITEMENT = "SUBSIT" or PTRAITEMENT = "SUBSITF"
        PTRTUTILISE = -1
        End
    Endif

    # traitement SUB + nom d'objet
    # --> le jour où le SUPERVISEUR ne génèrera plus cet objet, le contrôle pourra être mis
    # pour purger l'appli : fstat = 0 remplacé par fstat = 0 and [F:AOB]TYPGES <> 4

    If left$(PTRAITEMENT, 3) = "SUB"
        WNOMOBJ = right$(PTRAITEMENT, 4)
        If len(WNOMOBJ) <= GLONAOB
            Read [AOB]ABREV = WNOMOBJ

            If fstat = 0
                PTRTUTILISE = -1
                End
            Endif
        Endif
    Endif

End


Subprog ECRIRETITRE(TITAECRIRE, TITAECRIREW, INDERREUR, PMODULE, PTRAITEMENT, SAUVEMODULE,
&       NBERREUR, NBWARNING, NLIG, NLIGSAV)

Variable Integer TITAECRIRE, TITAECRIREW
Value Integer INDERREUR, PMODULE
Value Char PTRAITEMENT
Variable Shortint SAUVEMODULE
Variable Integer NBERREUR, NBWARNING, NLIG, NLIGSAV


Local Char WTITRE(150), WTITRE2(150)
Local Integer IB


    If (TITAECRIRE and GBTWARNING(GNUMMOUL, INDERREUR) = 0) or (TITAECRIREW and GBTWARNING(GNUMMOUL, INDERREUR))

        WTITRE2 = ""
        WTITRE  = PTRAITEMENT + ".src"

        # Recherche du module
        Read [ADC]ADC0=PTRAITEMENT
        If fstat = 0
            WTITRE  = WTITRE + " (" + [F:ADC]DES + ")   "

            If PMODULE = 0
                WTITRE2 = "   (MODULE" - num$([F:ADC]MODULE) - ":" - func LIBMODULE ([F:ADC]MODULE, SAUVEMODULE) - ")"

                IB = len(WTITRE) + len(WTITRE2)
                IB = 120 - IB

                If IB > 0
                    WTITRE = WTITRE + string$(IB, "_") + WTITRE2
                Else
                    WTITRE = WTITRE - WTITRE2
                Endif
            Endif
        Else
            [F:ADC]MODULE = 0

            WTITRE2 = "   (MODULE ?? : [ADC] non lu)"

            IB = len(WTITRE) + len(WTITRE2)
            IB = 120 - IB

            If IB > 0
                WTITRE = WTITRE + string$(IB, "_") + WTITRE2
            Else
                WTITRE = WTITRE - WTITRE2
            Endif

        Endif
    Endif


    # Ecrire le titre (si) et la première ligne d'erreur
    If GBTWARNING(GNUMMOUL, INDERREUR)
        NBWARNING += 1

        If NLIG <> NLIGSAV
            Wrseq Using [FWR]
        Endif
        If TITAECRIREW
            Wrseq WTITRE Using [FWR]
        Endif
        TITAECRIREW = 0
    Else
        NBERREUR += 1

        If NLIG <> NLIGSAV
            Wrseq Using [FER]
        Endif
        If TITAECRIRE
            Wrseq WTITRE Using [FER]
        Endif
        TITAECRIRE = 0
    Endif
    NLIGSAV = NLIG

End


######################################################################################




#_________________________________________________________________________________________
# renvoie la 1° instruction d'1 chaine et décrémente de cette instruction la chaine totale
#CBO 20110111 FQ69707 traitement de PIGNWRSEQ passé de VIRECOMCHK à DECOUPCH
Funprog DECOUPCH (CHAININS, PIGNWRSEQ)
Variable Clbfile CHAININS
Value Integer PIGNWRSEQ

Local Clbfile CHTMP(3)
Local Shortint DID, DIC, BNIVEAUIF
Local Char WWFUNC

    CHTMP = ""
    # beaucoup d'instructions sur 1 ligne : on doit boucler...
    If GCPTDBG > 20
#        Dbgaff
        CHAININS = ""
        End CHTMP
    Endif

    BNIVEAUIF = 0
    # 0 : rien
    # 1 : If, While
    # 2 : retour de If, While
    # 3 : Else ou Elsif en début de ligne
    # 4 : Endif, Wend
    # cbo while : ajouter un groupe d'instructions fonctionnant sans un deux-points entre


    If CHAININS = ""
        End CHTMP
    Endif

#cbowrseq
    While CHAININS <> "" and CHTMP = ""
        If left$(CHAININS, 5) = GREPEREIF
            BNIVEAUIF = 2
            CHAININS = right$(CHAININS, len(GREPEREIF) + 2)
        Elsif left$(CHAININS, 4) = "Else" ###or (len(CHAININS) > 4 and right$(CHAININS, len(CHAININS) - 4) = "Endif")
            BNIVEAUIF = 1
        # cbo while
        Elsif left$(CHAININS, 5) = "While"
            BNIVEAUIF = 1

        Endif

        # trouve-t'on un début de nouvelle instruction
        DID = instr(1, CHAININS, ":")
        If DID = 0 and BNIVEAUIF = 0 and
&           left$(CHAININS, 2) <> "If" and left$(CHAININS, 4) <> "Else" and left$(CHAININS, 5) <> "Endif" and
&           left$(CHAININS, 4) <> "When" and
&          left$(CHAININS, 5) <> "While" and left$(CHAININS, 4) <> "Wend"
# cbo while
            CHTMP = CHAININS
            CHAININS = ""
#cbowrseq
            # on est en ignore Wrseq et on en trouve un
            If PIGNWRSEQ = 1 and pat(CHTMP, "*Wrseq*")
                CHTMP = ""
            Endif
            End CHTMP
        Endif

        DIC = 1    # existence d'1 [

        While DIC > 0 or DID
            If DID > 2
                # on regarde si on est dans un [x:yyy
                DIC = instr(DID - 2, CHAININS, "[")

                If DIC = DID - 2
                    # on cherche alors un autre ":" plus loin
                    DID = instr(DID + 1, CHAININS, ":")
                Else
                    # on ne se trouve pas dans une chaîne ou : ne se trouve pas dans une constante : il y a donc plusieurs instructions
                    If func DANSQUOTE (CHAININS, DID) = 0
                        CHTMP = vireblc(left$(CHAININS, DID - 1), 2)
                        CHAININS = vireblc(right$(CHAININS, DID + 1), 2)
                        Break
                    Endif
                    DID = instr(DID + 1, CHAININS, ":")
                Endif
            Elsif DID
                CHAININS = vireblc(right$(CHAININS, DID + 1), 2)
                DID = instr(1, CHAININS, ":")
                DIC = 0
            Else
                DIC = 0
            Endif
        Wend

        If (DID = 0 and BNIVEAUIF = 0) or CHTMP = ""
            CHTMP = vireblc(CHAININS, 2)
            CHAININS = ""
        Endif
        If CHAININS <> ""
            CHAININS = vireblc(CHAININS, 2)
        Endif

        # cas de l'instruction If qui peut avoir if cond instr endif...
        # on va éventuellement découper CHTMP
        If func ANAIF(CHTMP, CHAININS, BNIVEAUIF, PIGNWRSEQ) = ""
            DID = 0
        Endif
#cbowrseq
        # on est en ignore Wrseq et on en trouve un
        If PIGNWRSEQ = 1 and pat(CHTMP, "*Wrseq*")
            CHTMP = ""
        Endif
    Wend

End CHTMP

# if cond [Then ou :] instr1 [Elsif instr2] [:] [Elsif instr3] [Else instr4] [endif]
# While cond instr Wend
Funprog ANAIF(CHTMP, CHAININS, BREPERETRVE, PIGNWRSEQ)
Variable Clbfile CHTMP, CHAININS
Value Integer BREPERETRVE, PIGNWRSEQ

Local Clbfile CH1
Local Integer I, J, WBPREMIER, WNBPARENTH, WBOPERATEUR, WLG, LGFIN
Local Char CH2(1), CHFIN(10)



    If left$(CHTMP, 2) = "If"
        WBPREMIER = 1
    # cbo while
    Elsif left$(CHTMP, 5) = "While"
        WBPREMIER = 1
    Elsif left$(CHTMP, 4) = "When"
        WBPREMIER = 2
    Elsif BREPERETRVE
        WBPREMIER = 0
    Else
        End "0"
    Endif

    # rechercher le passage de cond à instr1 :

    # la séparation peut être soit un then, soit un : soit un blanc
    # le : est traité dans DECOUPCH
    # pour identifier le blanc, il faut analyser et/ou ainsi que les ()
    # si WBPREMIER = 2 il peut y avoir plusieurs conditions séparées par des ,
    If WBPREMIER
        I = instr(1, CHTMP, "Then")
        If I
            If CHAININS = ""
                CHAININS = GREPEREIF - right$(CHTMP, I + 4)
            Else
                CH1 = CHAININS
                CHAININS = GREPEREIF - right$(CHTMP, I + 4) + " : " + CH1
            Endif
            CHTMP = left$(CHTMP, I - 1)
            End "1"
        Endif

        # analyse de la condition : recherche de la fin
        # if (a ou (b et c)) instr
        # if a ou (b et c) instr
        # if a ou b instr
        # if a = 1 instr
        # if a instr
        # if func f(i) instr

        WNBPARENTH = 0
        WBOPERATEUR = 1
        I = 3
        J = len(CHTMP)
        While (I <= J)

            CH2 = mid$(CHTMP, I, 1)
            If CH2 = "("
                WBOPERATEUR = 0
                WNBPARENTH += 1
            Elsif mid$(CHTMP, I, 2) = " ("
                WBOPERATEUR = 0
                WNBPARENTH += 1
                I += 1
            Elsif CH2 = ")"
                WBOPERATEUR = 0
                WNBPARENTH -= 1
            Elsif instr(1, "*/|&><=", CH2)
                WBOPERATEUR = 1
            Elsif instr(1, "+-", CH2)
                If instr(1, "0123456789", mid$(CHTMP, I + 1, 1))
                    # c'est un indic de signe : var = -1 et non un opérateur
                    WBOPERATEUR = 0
                Else
                    WBOPERATEUR = 1
                Endif
            Elsif mid$(CHTMP, I, 3) = "And"
                WBOPERATEUR = 1
                I += 2
            Elsif mid$(CHTMP, I, 2) = "Or"
                WBOPERATEUR = 1
                I += 1
            Elsif mid$(CHTMP, I, 4) = "func"    #CHECK IGNORE_LINE
                I += 4

            Elsif CH2 = " "
                If WNBPARENTH = 0 and WBOPERATEUR = 0
                    # si le car suivant = ',' et en when : on change de condition
                    If WBPREMIER = 2 and mid$(CHTMP, I + 1, 1) = ","
                        If CHAININS = ""
                            CHAININS = "When" - right$(CHTMP, I + 2)
                        Else
                            CH1 = CHAININS
                            CHAININS = "When" - right$(CHTMP, I + 2) + " : " + CH1
                        Endif
                        CHAININS = vireblc(CHAININS, 5)
                        CHTMP = left$(CHTMP, I - 1)

                        Break
                    Endif

                    # si le car suivant n'est pas un opérateur, alors on est bon
                    If instr(1, "+-*/|&><=", mid$(CHTMP, I + 1, 1)) = 0 and
&                         mid$(CHTMP, I + 1, 3) <> "And" and mid$(CHTMP, I + 1, 2) <> "Or"
                        WBOPERATEUR = 0

                        # on a la fin de la condition
                        If CHAININS = ""
                            CHAININS = right$(CHTMP, I + 1)
                        Else
                            CH1 = CHAININS
                            CHAININS = right$(CHTMP, I + 1) + " : " + CH1
                        Endif
                        CHAININS = vireblc(CHAININS, 5)
                        CHTMP = left$(CHTMP, I - 1)

                        Break
                    Endif
                Endif
            # le car  = ',' et en when : on change de condition
            Elsif WBPREMIER = 2 and WNBPARENTH = 0 and WBOPERATEUR = 0 and CH2 = ","
                If CHAININS = ""
                    CHAININS = "When" - right$(CHTMP, I + 1)
                Else
                    CH1 = CHAININS
                    CHAININS = "When" - right$(CHTMP, I + 1) + " : " + CH1
                Endif
                CHTMP = left$(CHTMP, I - 1)

                Break
            Else

                # caractère std
                WBOPERATEUR = 0
            Endif

            I += 1
        Wend

        CH1 = CHAININS
        CHAININS = GREPEREIF - CH1
        End "1"
    Endif
    # fin du WBPREMIER (recherche de la condition du If)



#    séparation des différentes instructions

###    CHTMP = right$(CHTMP, 7)


    I = instr(1, CHTMP, "Then")
    If I
        CHTMP = right$(CHTMP, I + 5)
    Endif

    WLG = 0
    I = instr(1, CHTMP, "Elsif")
    If I
        WLG = 6
    Else
        I = instr(1, CHTMP, "Else")
        If I
            WLG = 5
        Else
            I = instr(1, CHTMP, "Endif")
            If I
                WLG = 6
            Else
                # cbo while
                I = instr(1, CHTMP, "Wend")
                If I
                    WLG = 5
                Endif
            Endif
        Endif
    Endif

    # si i = 1 ou 2, on passe directement au else
    If I
        CH1 = CHAININS
        If I > 2
            CHAININS = vireblc(right$(CHTMP, I) - CH1, 2) #cbo CHAININS ajouté en fin
            CHTMP = vireblc(left$(CHTMP, I - 2), 2)
        Else
            CHAININS = vireblc(right$(CHTMP, I + WLG) - CH1, 2) #cbo CHAININS ajouté en fin
            CHTMP = vireblc(left$(CHTMP, I + WLG - 1), 2)
        Endif
        If CHAININS <> ""
            CH1 = CHAININS
            CHAININS = GREPEREIF - CH1
        Endif

        If CHTMP = ""
            CHTMP = func DECOUPCH(CHAININS, PIGNWRSEQ)
        Endif
        End "1"

    Endif

    # difficile de découper les instructions (essai non concluants)
    # on va juste séparer le Endif si il y a lieu

    CHFIN = ""
    I = instr(1, CHTMP, "Endif")
    If I
        CHFIN = "Endif"
        LGFIN = 5
    Else
        # cbo while
        I = instr(1, CHTMP, "Wend")
        If I
            CHFIN = "Wend"
            LGFIN = 4
        Endif
    Endif

    # CHTMP est la partie gauche de la chaîne découpée
    If I > 2
        CHTMP = left$(CHTMP, I - 1)
        If CHAININS = ""
            CHAININS = CHFIN
        Else
            CH1 = CHAININS
            CHAININS = GREPEREIF - CHFIN - CH1
        Endif
    Elsif I
        If len(CHTMP) > (LGFIN + 1)
            If CHAININS = ""
                CHAININS = GREPEREIF - right$(CHTMP, LGFIN + 2)
                CHTMP = CHFIN
            Else
                CH1 = CHAININS
                CHAININS = GREPEREIF - right$(CHTMP, LGFIN + 2) - CH1
            Endif
        Else
            If CHAININS <> ""
                CH1 = CHAININS
                CHAININS = GREPEREIF - CH1
            Endif
        Endif
    Else
        If CHAININS <> ""
            CH1 = CHAININS
            CHAININS = GREPEREIF - CH1
        Endif
    Endif

End "1"


# recherche si la def d'un type est complexe
Funprog MTCLEFCOMPLEXE(PCHAINE)
Value Char PCHAINE

    If instr(1, PCHAINE, "+")
        End 1
    Endif
    If instr(1, PCHAINE, "*")
        End 1
    Endif
    If instr(1, PCHAINE, "[")
        End 1
    Endif
    If instr(1, PCHAINE, "(")
        End 1
    Endif
    If instr(1, PCHAINE, "max")
        End 1
    Endif
    If instr(1, PCHAINE, "len")
        End 1
    Endif
    If instr(1, PCHAINE, "type")
        End 1
    Endif

End 0


