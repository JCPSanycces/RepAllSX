    GMENLOC(1)=1
    GMENLOC(2)=1
    GMENLOC(3)=1
    GMENLOC(4)=1
    GMENLOC(5)=1
    GMENLOC(8)=1
    GMENLOC(9)=1
    GMENLOC(10)=1
    GMENLOC(11)=1
    GMENLOC(12)=1
    GMENLOC(13)=1
