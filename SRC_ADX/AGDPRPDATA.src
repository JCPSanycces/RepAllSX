#<AdxTL>@(#)0.0.0.0 $Revision$
###########################################################################
#  Function AGPRDPDATA
#  extraction data type releated to personal data
#
#  can be executed in batch mode
# ----------------------------------------------------------------------- #
#################################################################################
# in batch mode is possible
Gosub OUVRE
Call EXPORT
Gosub TERMINE
End
#################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "FINSAI"       : Gosub TERMINE
    When "BOUTON"       : Gosub BOUTON

  Endcase
Return

##############################################
$OUVRE
#--------- files
Local File AGDPRSETTING [AGS]
Local File ATABZON [ATZ]
Local File ATABLE  [ATB]
Local File ATEXTE  [AX1]

#--------- variables

Local Integer WSAVIUM
Local Char    WSAVIFS(10) , WSAVIRS(5)


#--------- initialisations
[L]WSAVIFS= adxifs
[L]WSAVIRS= adxirs
[L]WSAVIUM= adxium


Return

##############################################
$TERMINE
LogicClose File [AGS]
LogicClose File [ATZ]
LogicClose File [ATB]
LogicClose File [AX1]
#
adxifs =[L]WSAVIFS
adxirs =[L]WSAVIRS
adxium =[L]WSAVIUM

Return

##############################################
$DEBUT

Return

##############################################
$BOUTON
Case BOUT
    When "E" : Call EXPORT
Endcase
Return

###################################################################
# export in format csv on local desktop
# can be launched in batch mode just after the extract but only in TRA directory
###################################################################
Subprog EXPORT

Local Char ZFIC (GDIMFIC)
Local Char WFICORI (GDIMFIC)
Local Integer WERROR
Local Integer WOK

Local Char WTEXT_ZONE(GDIMFIC)
Local Char WTEXT_FILE(GDIMFIC)
Local Char WMESSAGE(GDIMFIC)


Filter [AGS] Where TYP = 1 and ENAFLG = 2 Order By Key AGS2 Asc
If rowcount([F:AGS]) = 0
      If !GSERVEUR
          Call  WARNING(mess(18,155,1),WOK) From GESECRAN
      Else
          #("Rien a traiter , le paramétrage des settings n a pas été fait
          Call ECR_TRACE (mess(18,155,1),0) From GESECRAN
      Endif
      Filter [AGS]
      Goto FIN_EXPORT
Endif

If !GSERVEUR
    Call TEMPON(mess(19,155,1)) From GESECRAN
Endif

ZFIC = filpath("TRA", "ALISTGDPRPDAT" , "tra","","",adxmac(0))
Openo ZFIC, 0                   Using [WFTP]
Iomode adxium GUTF8             Using [WFTP]
Iomode adxirs chr$(13)+chr$(10) Using [WFTP]
Iomode adxifs ';'               Using [WFTP]

WMESSAGE ='Table;Description;Field;Description'
Wrseq  WMESSAGE       Using [WFTP]

For [AGS]
    For [ATZ]CODTYP Where [F:ATZ]CODTYP=[F:AGS]CODATY
#&                       or ([F:ATZ]CODFIC=[F:AGS]CODATB and [F:ATZ]CODZONE=[F:AGS]CODFLD)
             # updusr et creusr are filtered, not necessary to give information
             If [F:ATZ]CODZONE<>"UPDUSR" and [F:ATZ]CODZONE<>"CREUSR"
                 Read [ATB]CODFIC = [F:ATZ]CODFIC
                 If fstat = 0
                    Call TEXTE([F:ATZ]NOLONG,WTEXT_ZONE) From OBJDIV
                    Call TEXTE([F:ATB]INTITFIC,WTEXT_FILE) From OBJDIV
                    #
                    WMESSAGE = [F:ATZ]CODFIC+';'+escJson(WTEXT_FILE)+';'+[F:ATZ]CODZONE+';'+escJson(WTEXT_ZONE)
                    Wrseq WMESSAGE   Using  [WFTP]
                 Endif
                 Raz WTEXT_ZONE
                 Raz WTEXT_FILE
                 Raz WMESSAGE
             Endif
    Next
Next
Openo      Using [WFTP]
Filter [AGS]

If !GSERVEUR
          # upload fichier
          WFICORI = ZFIC
          ZFIC= "ALISTGDPRPDAT.csv"
          Call SET_NAMCLI(ZFIC) From ORDSYS
          Call MOVCLI(WFICORI,ZFIC,WERROR) From ORDSYS
          If WERROR
             Call ERREUR(mess(12,139,1)) From GESECRAN
          Endif
          Call EFFACE(WFICORI, WERROR) From ORDSYS
          # end of process
          Call  MESSAGE(mess(27,150,1)) From GESECRAN
Else
          # "you can find export file under :"
          Call ECR_TRACE (mess(16,155,1)- ZFIC,0) From GESECRAN
Endif

If !GSERVEUR
    Call TEMPOFF From GESECRAN
Endif


$FIN_EXPORT
End

