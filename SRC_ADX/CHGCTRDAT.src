#<AdxTL>@(#)0.0.0.0 $Revision$
##** V7 : Waiting Time Mangement **#
Raz GPILOBJ , GNBMASKOUV
Call OBJET("CTR",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "EXEC"     : Gosub EXEC
 When "INIT_DIA" : Gosub INIT_DIA
Endcase
Return

$INIT_DIA
[M:CHG]CTRDAT = [M:CTR0]CTRDAT
Return

$INIT
If clalev([F:HRCTR])=0 : Local File EMPLOCTR    [HRCTR]  : Endif
If clalev([F:ID])=0    : Local File EMPLOID     [ID]   : Endif
If clalev([F:CTR1])=0  : Local File EMPLOCTR    [CTR1] : Endif
Return

$EXEC
If [M:CHG]CTRDAT<>[M:CTR0]CTRDAT
#SAVAN - 2018/04/23 - X3-86552 - start
  Local Date OLDDATE
  OLDDATE = [M:CTR0]CTRDAT
#SAVAN - 2018/04/23 - X3-86552 - end
 Call TEMPON("O") From GESECRAN
 Call CHGDAT([M:CTR0]REFNUM,[M:CTR0]CTRNUM,[M:CTR0]CTRDAT,[M:CHG]CTRDAT)
 Call TEMPOFF From GESECRAN
 If GOK=1
  #ADNGO - 2017-05-29 - JIRA X3-12050 - START
  Local Date INIDAT : INIDAT=[M:CTR0]CTRDAT
  #ADNGO - 2017-05-29 - JIRA X3-12050 - END
  [M:CTR0]CTRDAT = [M:CHG]CTRDAT

  #ADNGO - 2017-05-29 - JIRA X3-12050 - START
  Local Integer VOK
  VOK=1
  #Call OUINON(mess(247,10702,1),VOK) From GESECRAN
  Call OUINON(mess(250,10702,1),VOK) From GESECRAN
  If VOK=2
    Gosub MAJ_OTHCTR
    If !GOK
     GMESSAGE = mess(157,123,1)-":"-mess(13,100,1)-"EMPLOCTR"
     Return
    Endif
  Endif
  #ADNGO - 2017-05-29 - JIRA X3-12050 - END
  ##**72216 & 91821
  If [M:CTR0]FLGRET=2
  Local Integer VOK
   VOK=1
   #Voulez-vous mettre à jour la date de fin du contrat précédent ?
   Call OUINON(mess(236,10702,1),VOK) From GESECRAN
   If VOK=2
    Gosub RETMAJ_XITDAT
    If !GOK
     #"Opération impossible : pb d'ecriture sur la table EMPLOCTR"
     GMESSAGE = mess(157,123,1)-":"-mess(13,100,1)-"EMPLOCTR"
     Return
    Endif
   Endif
  Endif
 Endif
 #SAVAN - 2018/04/23 - X3-86552 - start - HRLST contract CTRDAT update in sub type screen
  If clalev([HRLSTD]) = 0 : Local File HRLVESUBDET [HRLSTD] : Endif
  If clalev([HRACCRU])= 0 : Local File HRLVEACCRU [HRACCRU] : Endif
  Filter [HRLSTD] Where [HRLSTD]CTRNUM=[M:CTR0]CTRNUM
  Read [HRLSTD] First
  If !fstat
    Update [HRLSTD] Where [HRLSTD]CTRNUM=[M:CTR0]CTRNUM and [HRLSTD]CTRDAT=OLDDATE With [HRLSTD]CTRDAT=[M:CHG]CTRDAT
  Endif
  Update [HRACCRU] Where [HRACCRU]CTR=[M:CTR0]CTRNUM and [HRACCRU]CTRDAT=OLDDATE and [HRACCRU]LVEACCTYP="Linking" With [HRACCRU]CTRDAT=[M:CHG]CTRDAT
  Close File [HRLSTD], [HRACCRU]
#SAVAN - 2018/04/23 - X3-86552 - end - HRLST contract CTRDAT update in sub type screen
Endif

#ADNGO - 2017-05-29 - JIRA X3-12050 - START
If func DIVPAYE.IS_AFRICA_LEG(GCURLEG) Then
If clalev([F:ETA]) = 0 : Local File EMPLOTAXAFR [ETA] : Endif
 Gosub MAJ_TAXSTRDAT
Endif
#ADNGO - 2017-05-29 - JIRA X3-12050 - END

#ADNGO - 2017-05-29 - JIRA X3-12050 - START
If func DIVPAYE.IS_KZA(GCURLEG) Then
If clalev([F:ETR9]) = 0 : Local File EMPLOTAXREC [ETR9] : Endif
 Gosub MAJ_IRPSTRDAT
Endif
#ADNGO - 2017-05-29 - JIRA X3-12050 - END


#MAPAD - 2018-05-28- JIRA X3-91756 - START
If func DIVPAYE.IS_ZA_DEV() Then
 Gosub MAJ_DATCRE
Endif
#MAPAD - 2017-05-28 - JIRA X3-91756 - END
End

End
##**72216 & 91821
#########################
$RETMAJ_XITDAT
If clalev([F:CTRW])=0 : Local File EMPLOCTR         [CTRW] : Endif
Filter [F:CTRW] Where REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM & CTRDAT<[M:CTR0]CTRDAT
Readlock [F:CTRW]CTR0 Last
Filter [F:CTRW]
If !fstat
 [F:CTRW]XITDAT=[M:CTR0]CTRDAT-1
 Rewrite [F:CTRW]
 If fstat <> 0
  [V]GOK = 0
  Call FSTA("CTRW") From GLOCK
 Endif
Endif
Return

Subprog CHGDAT(MATRI,CONTRAT,OLDDAT,NEWDAT)
Value Char MATRI
Value Char CONTRAT
Value Date OLDDAT
Value Date NEWDAT
Local Char TABLE(GLONATB) , DATFLD(GLONAVA) , ABREV(5)
Local File ATABLE  [ATB]
Local File ATABZON [ATZ]
Local Char CRITERE (250)        :#92669
Call DEBTRANS From GLOCK
Gosub TR1
End

$TR1
GOK = 1
Trbegin [HRCTR]
 For [ATZ]CODTYP(2) Where CODTYP="DTR"
  Read [ATB]CODFIC = [F:ATZ]CODFIC
  TABLE  = [F:ATZ]CODFIC
  ABREV  = [F:ATB]ABRFIC
  DATFLD = "[F]"+[F:ATZ]CODZONE
  Local File =TABLE
  #92669
  [L]CRITERE=''
  If dim([F]REFNUM)>0 & dim([F]CTRNUM)>0
   [L]CRITERE='REFNUM=MATRI & CTRNUM=CONTRAT & evalue(DATFLD)=OLDDAT'
  Elsif dim([F]EMP)>0 & dim([F]CTRNUM)>0
   [L]CRITERE='EMP=MATRI & CTRNUM=CONTRAT & evalue(DATFLD)=OLDDAT'
  Elsif dim([F]IDENT1)>0 & dim([F]IDENT3)>0
   [L]CRITERE='IDENT1=MATRI & IDENT3=CONTRAT & evalue(DATFLD)=OLDDAT'
  Endif
  If CRITERE<>''
   For [F] Where evalue(CRITERE)
    Assign DATFLD With NEWDAT
    Rewrite [F]
    If fstat=1  : GOK = -1 : GLOCK = "$"+ABREV-MATRI-CONTRAT-num$(OLDDAT) : Break 2
    Elsif fstat : GOK = 0  : Call FSTA(ABREV) From GLOCK : Break 2
    Endif
   Next
  Endif
 Next ABREV
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

##########################################
## Contrôle
##########################################
Subprog C_CTRDAT(DAT)
Variable Date DAT

If DAT=[M:CTR0]CTRDAT : End : Endif

##**87968
If [M:CTR8]XITDAT<>[0/0/0] & DAT > [M:CTR8]XITDAT
  GMESSAGE = mess(6,10702,1): #La date de sortie ne peut pas être inférieure à la date d'entrée
  mkstat = 2 : End
Endif

# Un autre contrat à une même date

Read [HRCTR]CTR0 = [M:CTR0]REFNUM;[M:CTR0]CTRNUM;DAT
If !fstat
 GMESSAGE = mess(16,10715,1) : # Contrat déjà existant à cette date
 mkstat = 2
 End
Endif

# Verif chronologie

Read [ID]ID0 = [M:CTR0]REFNUM
If [F:ID]FLGMULCTR=2
 Filter [CTR1] Where REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM & CTRDAT<>[M:CTR0]CTRDAT
Else
 Filter [CTR1] Where REFNUM=[M:CTR0]REFNUM & CTRDAT<>[M:CTR0]CTRDAT
Endif
For [CTR1]CTR1
 If [F:CTR1]CTRNUM<>[M:CTR0]CTRNUM | [F:CTR1]CTRDAT<>DAT
#  If ([F:CTR1]XITDAT>=DAT & [F:CTR1]CTRDAT<=[M:CTR8]XITDAT & [M:CTR8]XITDAT<>[0/0/0] & [F:CTR1]XITDAT<>[0/0/0])
#&|   ([F:CTR1]CTRDAT>=DAT & [F:CTR1]XITDAT=[0/0/0] & ([M:CTR8]XITDAT=[0/0/0] | [M:CTR8]XITDAT>=[F:CTR1]CTRDAT))
#&|   ([F:CTR1]XITDAT>=DAT & [F:CTR1]CTRDAT<=DAT & [F:CTR1]XITDAT<>[0/0/0])
##**87968
 If ([F:CTR1]XITDAT>=DAT & [M:CTR8]XITDAT=[0/0/0] )
&|  ([M:CTR8]XITDAT<>[0/0/0] & !([F:CTR1]XITDAT<DAT  | [M:CTR8]XITDAT<[F:CTR1]CTRDAT))
   # La période du contrat chevauche celle d'un contrat déja existant :
   GMESSAGE = mess(35,10701,1)-num$([F:CTR1]CTRDAT)-num$([F:CTR1]XITDAT)
   mkstat = 2 : Break
  Endif
 Endif
Next
Filter [CTR1]
#ADNGO - 2017-05-20 - START
##** V7 : Waiting Time Mangement **#
#If  mkstat <> 2
#  Gosub CONTROLE_TIP
#  If  mkstat = 2 : End : Endif
#Endif
If  mkstat <> 2
  Gosub CONTROLE_TIP
  If  mkstat = 2 : End : Endif
Endif
#ADNGO - 2017-05-20 - END
End

##** V7 : Waiting Time Mangement **#
$CONTROLE_TIP
Local Char    CRITCTRL (250)
Local Date    DATDEBCTR
If [L]DAT<>[0/0/0] & [M:CTR0]CTRDAT > [L]DAT : Return : Endif
Read [HRCTR]CTR0 = [M:CTR0]REFNUM;[M:CTR0]CTRNUM;[M:CTR0]CTRDAT
If fstat : Return : Endif

CRITCTRL="REFNUM='"+[M:CTR0]REFNUM+"' & CTRNUM='"+[M:CTR0]CTRNUM+"'"
If [L]DAT<>[0/0/0]
##**82073
 CRITCTRL-="& (CTRDAT=[0/0/0] | CTRDAT=["+num$([M:CTR0]CTRDAT)+"])"
# CRITCTRL-="& DATPYR>=["+num$(DAT)+"]"
Endif
DATDEBCTR=[L]DAT
If [F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<>[0/0/0] Then
 DATDEBCTR=[F:HRCTR]RETDATEFF
Endif

Filter [TIP] Where evalue(CRITCTRL)
For [F:TIP]
    # Conrôle règle métier
#    If  !(([L]DAT<=[F:TIP]DATPYR | ([F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<=[F:TIP]DATPYR))
    If  !(([L]DATDEBCTR<=[F:TIP]DATPYR )
&     & ([F:HRCTR]XITDAT=[0/0/0] | [F:TIP]ENDDAT<=[F:HRCTR]XITDAT )) Then
       # Modification impossible : Temps saisis sur la période
       GMESSAGE = mess(13,701,1)
       mkstat = 2 : Break
    Endif
    # Présence de l'employé sur la période
    If [F:TIP]STRDAT < DATDEBCTR
      # Modification impossible : Temps saisis sur la période
       GMESSAGE = mess(13,701,1)
       mkstat = 2 : Break
    Endif
Next
Filter [TIP]
Return

#ADNGO - 2017-05-29 - JIRA X3-12050 - START
$MAJ_IRPSTRDAT

Local Char VSITE(50)
Local Char TMP_TAXSTRDAT(30), TMP_TAXENDDAT(30)
Local Integer THISTAXYEAR
Local Date DTAXSTR, DTAXEND
#Local Char STAXSTR(9), STAXEND(9) : STAXSTR  = "TAXSTRDAT" : STAXEND = "TAXENDDAT"

#  Call PARAM(VSITE, STAXSTR, TMP_TAXSTRDAT) From ADOVAL
#  If TMP_TAXSTRDAT = "" Then : TMP_TAXSTRDAT = "00000000" : Endif
#  DTAXSTR = gdat$(TMP_TAXSTRDAT)
If clalev([F:HRPEOH]) = 0 : Local File HRPEOHEA [HRPEOH] : Endif

Filter [F:HRPEOH] Where [F:HRPEOH]PERCOD = [M:CTR1]PERCOD & [F:HRPEOH]FLGENA=2
Read First
If !fstat
  DTAXSTR=gdat$([F:HRPEOH]CYCSTRDAT)
  DTAXEND=gdat$([F:HRPEOH]CYCENDDAT)
Else
  DTAXSTR = gdat$("00000000")
  DTAXEND=gdat$("00000000")
Endif


THISTAXYEAR=year(DTAXEND)



Filter [F:HRPEOH]

  If clalev([F:ETR3])=0 : Local File EMPLOTAXREC    [ETR3] : Endif


  Filter [F:ETR3] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and TAXYEA=THISTAXYEAR
  Read [F:ETR3]ETR0 Last

  If !fstat
    [F:ETR3]CTRDAT=[M:CHG]CTRDAT
      If [M:CHG]CTRDAT <= DTAXSTR Then
         [F:ETR3]IRPSTRDAT=DTAXSTR
      Else
         [F:ETR3]IRPSTRDAT=[M:CHG]CTRDAT
      Endif
    Rewrite [F:ETR3]
     If fstat <> 0
      [V]GOK = 0
      Call FSTA("ETR") From GLOCK
     Endif

  Endif
 Filter [F:ETR3]

 If clalev([F:CTRSA])=0 : Local File EMPLOCTRSA    [CTRSA] : Endif

   Filter [F:CTRSA] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and CTRDAT=[HRCTR]CTRDAT
   If !fstat
     Read [F:CTRSA]CTRSA0 = [HRCTR]REFNUM;[HRCTR]CTRNUM;[HRCTR]CTRDAT

      If [M:CHG]CTRDAT <= DTAXSTR Then
         [F:CTRSA]IRPSTRDAT=DTAXSTR
      Else
         [F:CTRSA]IRPSTRDAT=[M:CHG]CTRDAT
      Endif

     [F:CTRSA]CTRDAT=[M:CHG]CTRDAT
     Rewrite [F:CTRSA]
       If fstat <> 0
        [V]GOK = 0
        Call FSTA("CTRSA") From GLOCK
       Endif
    Endif
   Filter [F:CTRSA]
Return
#ADNGO - 2017-05-29 - JIRA X3-12050 - END

#ADNGO - 2017-05-29 - JIRA X3-12050 - START
$MAJ_TAXSTRDAT

Local Char VSITE(50)
Local Char TMP_TAXSTRDAT(30), TMP_TAXENDDAT(30)
Local Integer THISTAXYEARAFR
Local Date DTAXSTR, DTAXEND
#Local Char STAXSTR(9), STAXEND(9) : STAXSTR  = "TAXSTRDAT" : STAXEND = "TAXENDDAT"

#  Call PARAM(VSITE, STAXSTR, TMP_TAXSTRDAT) From ADOVAL
#  If TMP_TAXSTRDAT = "" Then : TMP_TAXSTRDAT = "00000000" : Endif
#  DTAXSTR = gdat$(TMP_TAXSTRDAT)
If clalev([F:HRPEOH]) = 0 : Local File HRPEOHEA [HRPEOH] : Endif

Filter [F:HRPEOH] Where [F:HRPEOH]PERCOD = [M:CTR1]PERCOD & [F:HRPEOH]FLGENA=2
Read First
If !fstat
  DTAXSTR=gdat$([F:HRPEOH]CYCSTRDAT)
  DTAXEND=gdat$([F:HRPEOH]CYCENDDAT)
Else
  DTAXSTR = gdat$("00000000")
  DTAXEND=gdat$("00000000")
Endif
Filter [F:HRPEOH]


THISTAXYEARAFR=year(DTAXEND)

  Filter [F:ETA] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and TAXYEA=THISTAXYEARAFR
  Read [F:ETA]ETA0 Last

  If !fstat

    [F:ETA]CTRDAT=[M:CHG]CTRDAT

      If [M:CHG]CTRDAT <= DTAXSTR Then
         [F:ETA]TAXSTRDAT=DTAXSTR
      Else
         [F:ETA]TAXSTRDAT=[M:CHG]CTRDAT
      Endif
    Rewrite [F:ETA]
     If fstat <> 0
      [V]GOK = 0
      Call FSTA("ETA") From GLOCK
     Endif
  Endif

 Filter [F:ETA]

   Filter [F:CTRAFR] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and CTRDAT=[HRCTR]CTRDAT
   If !fstat
     Read [F:CTRAFR]CTRAFR0 = [HRCTR]REFNUM;[HRCTR]CTRNUM;[HRCTR]CTRDAT
      If [M:CHG]CTRDAT <= DTAXSTR Then
         [F:CTRAFR]TAXSTRDAT=DTAXSTR
      Else
         [F:CTRAFR]TAXSTRDAT=[M:CHG]CTRDAT
      Endif
     [F:CTRAFR]CTRDAT=[M:CHG]CTRDAT
     Rewrite [F:CTRAFR]
       If fstat <> 0
        [V]GOK = 0
        Call FSTA("CTRAFR") From GLOCK
       Endif
    Endif
   Filter [F:CTRAFR]
Return
#ADNGO - 2017-05-29 - JIRA X3-12050 - END
#ADNGO - 2017-05-29 - JIRA X3-12050 - START
$MAJ_OTHCTR

  If clalev([F:CTRW])=0 : Local File EMPLOCTR         [CTRW] : Endif
  Read [F:CTRW]CTR0=[M:CTR0]REFNUM;[M:CTR0]CTRNUM;[M:CTR0]CTRDAT
  If !fstat Then
    If [F:CTRW]DATANC<>[0/0/0] & [F:CTRW]DATANC=INIDAT       Then [F:CTRW]DATANC    = [M:CTR0]CTRDAT : Endif
    If [F:CTRW]DATANCAPT<>[0/0/0] & [F:CTRW]DATANCAPT=INIDAT Then [F:CTRW]DATANCAPT = [M:CTR0]CTRDAT : Endif
    If [F:CTRW]DATFCY<>[0/0/0] & [F:CTRW]DATFCY=INIDAT       Then [F:CTRW]DATFCY    = [M:CTR0]CTRDAT : Endif
    If [F:CTRW]DATCPY<>[0/0/0] & [F:CTRW]DATCPY=INIDAT       Then [F:CTRW]DATCPY    = [M:CTR0]CTRDAT : Endif

    Rewrite [F:CTRW]
    If fstat <> 0
      [V]GOK = 0
      Call FSTA("CTRW") From GLOCK
     Endif
  Endif
Return
#ADNGO - 2017-05-29 - JIRA X3-12050 - END


#MAPAD - 2018-05-28- JIRA X3-91756 - START
#MAPAD - 2018-05-28- JIRA X3-91756 - START
$MAJ_DATCRE
If clalev([F:CTRD])=0 : Local File EMPLOCTR         [CTRD] : Endif
Read [F:CTRD]CTR0=[M:CTR0]REFNUM;[M:CTR0]CTRNUM;[M:CTR0]CTRDAT


If !fstat Then
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
    If dim([M:CTR1]DATCRE)>0 #and [F:CTR1]DATCRE =[0/0/0]
      Filter [HRCTR]
      Filter [HRCTR] Where [F:HRCTR]CTRNUM =[M:CTR0]CTRNUM and [F:HRCTR]REFNUM=[M:CTR0]REFNUM#check if other contracts with same chrono
        If rowcount([F:HRCTR])> 1
          Gosub PREV_DATCRE
        Else
           Filter [HRCTR] Where [F:HRCTR]REFNUM =[M:CTR0]REFNUM and [F:HRCTR]CTRNUM<>""
           If rowcount([F:HRCTR])> 1
               Gosub NEW_DATCRE_DIFFCHRONO
           Else
            Gosub NEW_DATCRE
           Endif
        Endif

        Rewrite [F:CTRD]

        If fstat <> 0
          [V]GOK = 0
           Call FSTA("CTRD") From GLOCK
        Endif
    Endif
  Endif
Endif

Return


$PREV_DATCRE
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
    Read [F:HRCTR]CTR0 First
    If [F:HRCTR]DATCRE <> [0/0/0] Then
      [F:CTRD]DATCRE=[F:HRCTR]DATCRE #Take date from previous contract
    Endif
Endif
Return


$NEW_DATCRE_DIFFCHRONO
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
    Gosub GETPAYPERIOD From SUBCTR2
   [F:CTRD]DATCRE =MAXDATE
Endif
Return


$NEW_DATCRE
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then

   Gosub GETPAYPERIOD From SUBCTR2

   If [M:CHG]CTRDAT >= MINDATE and [M:CHG]CTRDAT <= MAXDATE Then
      [F:CTRD]DATCRE = MAXDATE #[M:CTR0]CTRDAT
   Elsif [M:CHG]CTRDAT < MINDATE Then
      [F:CTRD]DATCRE=MAXDATE
   Elsif  [M:CHG]CTRDAT > MAXDATE Then
       [F:CTRD]DATCRE = [M:CHG]CTRDAT
   Endif
Endif

Return

#MAPAD - 2018-05-28- JIRA X3-91756 - END

