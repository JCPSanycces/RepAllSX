#<AdxTL>@(#)9.0.0.0 $Revision$
######################################################################## 
# FUNSPS                                           JL - Novembre 2000  #
#                                                                      #
#    PARAMETRAGE STRUCTURE TARIFS VENTES                               #
#                                                                      #
#    - Traitement        : FUNSPS                                      #
#    - Action e_commerce : SAISPS   (Saisie fenêtre)                   #
#                                    Fenêtre : FSPS                    #
#----------------------------------------------------------------------# 
# Attention : Ce traitement contient aussi les actions sur champ       # 
#             des écrans SPS1 [M:SPS1]                                 # 
######################################################################## 

######################################################################## 
# Etiquettes ACTION
######################################################################## 
$ACTION

#--- Actions liées à la fenêtre de Recherche du tarif
Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "DEBUT"        : Raz [M:SPS1]
  When "SETBOUT"      : Gosub SETBOUT 
  When "AV_CHOIX"     : Gosub AV_CHOIX
  When "APRES_MODIF"  : REP="M"
  When "ABA"          : REP=""
  When "ENR"          : Gosub ENR : REP="" 
Endcase
Return

######################################################################## 
# Détail des actions liées à la saisie fenêtre
######################################################################## 
$OUVRE
Local Integer ACVOPEN, NBRCOLONNE
If !clalev([F:PRS])  Local File PRICSTRUCT [PRS] : Endif     
If !clalev([F:AXX])  Local File ATEXTRA    [AXX] : Endif      
If !clalev([F:ACV])  Local File ACTIV      [ACV] : ACVOPEN=1 : Endif
Read [ACV] CODACT="SPR" : If fstat  Raz [F:ACV] : Endif
NBRCOLONNE=[F:ACV]DIME
If ACVOPEN=1  Close Local File [ACV] : Endif
#---- Effacement par sécurité des colonnes tarif non activées par les codes activité ----#
Read [PRS] PRS0=1;""
If fstat
  Raz [F:PRS]
Else
  If dim(I)<1  Local Integer I : Endif
  If NBRCOLONNE=0 & (sigma(I=0,8,[F:PRS]LANDESSHO(I)<>"") | 
&                    sigma(I=0,8,[F:PRS]INCDCR(I)<>0)     |
&                    sigma(I=0,8,[F:PRS]VALTYP(I)<>0)     |
&                    sigma(I=0,8,[F:PRS]CLCRUL(I)<>0)     |
&                    sigma(I=0,8,[F:PRS]NPRVLTFLG(I)<>0)  |
&                    sigma(I=0,8,[F:PRS]NPRNOTFLG(I)<>0)  |
&                    sigma(I=0,8,[F:PRS]INVDTA(I)<>0))
    Trbegin [PRS]
    Readlock [PRS] PRS0=1;""
    If !fstat
      Raz [F:PRS]LANDESSHO, [F:PRS]INCDCR,    [F:PRS]VALTYP, [F:PRS]CLCRUL,
&         [F:PRS]NPRVLTFLG, [F:PRS]NPRNOTFLG, [F:PRS]INVDTA
      Rewrite [PRS]
      If fstat  Rollback  Else  Commit : Endif
    Else
      Rollback
    Endif
  Elsif NBRCOLONNE<9 & ([F:PRS]LANDESSHO(NBRCOLONNE)<>"" |
&                       [F:PRS]INCDCR(NBRCOLONNE)<>0     |
&                       [F:PRS]VALTYP(NBRCOLONNE)<>0     |
&                       [F:PRS]CLCRUL(NBRCOLONNE)<>0     |
&                       [F:PRS]NPRVLTFLG(NBRCOLONNE)<>0  |
&                       [F:PRS]NPRNOTFLG(NBRCOLONNE)<>0  |
&                       [F:PRS]INVDTA(NBRCOLONNE)<>0)
    Trbegin [PRS]
    Readlock [PRS] PRS0=1;""
    If !fstat
      For I=NBRCOLONNE To 8
        Raz [F:PRS]LANDESSHO(I), [F:PRS]INCDCR(I),    [F:PRS]VALTYP(I), [F:PRS]CLCRUL(I),
&           [F:PRS]NPRVLTFLG(I), [F:PRS]NPRNOTFLG(I), [F:PRS]INVDTA(I)
      Next I
      Rewrite [PRS]
      If fstat  Rollback  Else  Commit : Endif
    Else
      Rollback
    Endif
  Endif
Endif
#-----

# un seul enr. dans le fichier qui doit exister 
Raz [F:PRS] 
[F:PRS]BPCBPS=1 : [F:PRS]PLISTC="" 
Look [PRS]PRS0=1;"" 
If fstat 
  Write [PRS] 
  If fstat : FIN=1 : Return : Endif 
Endif  

Read [PRS]PRS0=1;"" 

Return

######################################################################## 
$AV_CHOIX
[M:SPS1]=[F:PRS] 
For I=0 To dim([M:SPS1]INCDCR)-1 
  [M:SPS1]INCDCR(I)    = [F:PRS]INCDCR(I)  
  [M:SPS1]VALTYP(I)    = [F:PRS]VALTYP(I)  
  [M:SPS1]CLCRUL(I)    = [F:PRS]CLCRUL(I)  
  [M:SPS1]NPRNOTFLG(I) = [F:PRS]NPRNOTFLG(I)  
  [M:SPS1]INVDTA(I)    = [F:PRS]INVDTA(I)  
Next I  
nolign=dim([M:SPS1]INCDCR)
If dim([M:SPS1]BASTAB)>0 : [M:SPS1]BASTAB=dim([M:SPS1]INCDCR) : Endif 
Affzo [M:SPS1]

Return

######################################################################## 
$ENR
Local Integer IJL

Trbegin [PRS]

Readlock [PRS]PRS0=1;"" 
If !fstat 

#    Cle en alpha
  [F:PRS]BPCBPSCAR="1"

  If dim([F:PRS]LANDESHO)>0 : Raz [F:PRS]LANDESSHO : Endif
  For IJL=0 To dim([F:PRS]INCDCR)-1
    [F:PRS]INCDCR(IJL)    = 0   
    [F:PRS]VALTYP(IJL)    = 0   
    [F:PRS]CLCRUL(IJL)    = 0   
    [F:PRS]NPRNOTFLG(IJL) = 0   
    [F:PRS]INVDTA(IJL)    = 0   
  Next IJL

  For IJL=0 To dim([M:SPS1]INCDCR)-1  
    [F:PRS]INCDCR(IJL)    = [M:SPS1]INCDCR(IJL)   
    [F:PRS]VALTYP(IJL)    = [M:SPS1]VALTYP(IJL)   
    [F:PRS]CLCRUL(IJL)    = [M:SPS1]CLCRUL(IJL)   
    [F:PRS]NPRNOTFLG(IJL) = [M:SPS1]NPRNOTFLG(IJL)   
    [F:PRS]INVDTA(IJL)    = [M:SPS1]INVDTA(IJL)   
    If [F:PRS]INCDCR(IJL)>0
#        Creation / Modif de ATEXTRA
       Call MAJTEXTRA ([M:SPS1]DESAXX(IJL),"PRICSTRUCT","DESAXX("+num$(IJL)+")","1","") 
&                     From ATEXTRA
       Call MAJTEXTRA ([M:SPS1]SHOAXX(IJL),"PRICSTRUCT","SHOAXX("+num$(IJL)+")","1","") 
&                     From ATEXTRA
#        SOS libellés
       If dim([F:PRS]LANDESSHO)>=IJL 
          [F:PRS]LANDESSHO(IJL)=GLANGUE+"~"+[M:SPS1]DESAXX(IJL)+"~"+[M:SPS1]SHOAXX(IJL)  
       Endif
    Else 
       Delete [AXX] Where CODFIC="PRICSTRUCT" & ZONE="DESAXX("+num$(IJL)+")" 
&                       & IDENT1="1" & IDENT2=""
       Delete [AXX] Where CODFIC="PRICSTRUCT" & ZONE="SHOAXX("+num$(IJL)+")" 
&                         & IDENT1="1" & IDENT2="" 
    Endif
  Next IJL   

  Rewrite [PRS] 
Endif 

Commit

Return

######################################################################## 
$SETBOUT
#--- désactivation bouton "Copie" 
If REP ="M" Call VIREBOUT(CHMEN, "1") From GOBJET : Endif 
Return

###################################################################### 
# Traitement de copie de la structure des tarifs ventes 
# TABLE = Clé de l'enregistrement à copier (1er element)
#         si la cle est numerique val(TABLE)
#   CLE = CLIFOU    : Type de structure (client=1, fournisseur=2) 
#         STRUCTURE : Code structure (toujours="")
###################################################################### 
$TRTCOP

If [M]DOSORG=nomap
  Local File PRICSTRUCT [PRS1]
  Local File ATEXTRA    [AXX1]
Else
  Local File =[M]DOSORG+".PRICSTRUCT" [PRS1]
  Local File =[M]DOSORG+".ATEXTRA"    [AXX1]
Endif
If [M]DOSDES=nomap
  Local File PRICSTRUCT [PRS2]
  Local File ATEXTRA    [AXX2]
Else
  Local File =[M]DOSDES+".PRICSTRUCT" [PRS2]
  Local File =[M]DOSDES+".ATEXTRA"    [AXX2]
Endif
Look [PRS2] PRS0=val(TABLE);""
If !fstat
   OK= 1 : Call AVERTIR([M]DOSDES-mess(148,196,1),OK) From GESECRAN
   If OK=1 : Return : Endif
Endif

Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Return

#---------------------------------------------------------------------
$TR_COP

GOK=1
Trbegin [PRS2]
  Delete [PRS2] Where BPCBPS=1 & PLISTC=""
  If fstat=1  GOK=-1 : GLOCK="$"+[M]DOSDES+".PRICSTRUCT"-TABLE : Goto ROLL_TR_COP
  Elsif fstat GOK=0 : Call RSTA("PRS2",TABLE) From GLOCK          : Goto AB_TR_COP
  Endif
  Read [PRS1] PRS0=val(TABLE);""
  If !fstat
    [F:PRS2]=[F:PRS1]

    Local Integer IJL
    For IJL =0 To dim([F:PRS1]INCDCR)-1
        If [F:PRS1]INCDCR(IJL)>0
           Call COPTEXTRA("PRICSTRUCT","DESAXX("+num$(IJL)+")","1","") From ATEXTRA
           If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
           Call COPTEXTRA("PRICSTRUCT","SHOAXX("+num$(IJL)+")","1","") From ATEXTRA
           If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
        Endif
    Next IJL

    Write [PRS2]
    If fstat GOK=0 : Call FSTA("PRS2") From GLOCK : Goto AB_TR_COP : Endif
  Endif
Commit
Return

#----- Abandon de la copie -----#
$AB_TR_COP
Rollback 
Return
#----- Nouvel essai si nécessaire -----#
$ROLL_TR_COP
Rollback 
Call ROLL From GLOCK 
If !GROLL Goto TR_COP : Endif 
Return

 
######################################################################### 
# Actions champs de l'écran SPS1                                        # 
######################################################################### 

Subprog AV_INCDCR(VALEUR) 
Variable Integer  VALEUR 
If [M:SPS1]DESAXX(nolign-1)="" 
  VALEUR=0 
Elsif VALEUR=0 
  VALEUR=1 
Endif 
End 

########################################
Subprog AV_VALTYP(VALEUR) 
Variable Integer  VALEUR 
If [M:SPS1]DESAXX(nolign-1)="" 
  VALEUR=0 
Elsif VALEUR=0 
  VALEUR=1 
Endif 
End 

########################################
Subprog AV_CLCRUL(VALEUR) 
Variable Integer  VALEUR 
If [M:SPS1]DESAXX(nolign-1)="" 
  VALEUR=0 
Elsif VALEUR=0 
  VALEUR=1 
Endif 
End 
#--------------------------------------- 
Subprog AS_CLCRUL(VALEUR) 
Variable Integer  VALEUR 
If [M:SPS1]VALTYP(nolign-1)>1 : VALEUR=1 : mkstat=2 : Endif 
End 
#--------------------------------------- 
Subprog AP_CLCRUL(VALEUR) 
Variable Integer  VALEUR 
Raz GMENLOC 
If VALEUR=3 : [M:SPS1]NPRNOTFLG(nolign-1)=2 : Endif 
End 

########################################
Subprog AV_NPRNOTFLG(VALEUR) 
Variable Integer  VALEUR 
If [M:SPS1]DESAXX(nolign-1)="" 
  VALEUR=0 
Elsif VALEUR=0 
  VALEUR=2 
Endif 
End 

#--------------------------------------- 
Subprog AS_NPRNOTFLG(VALEUR) 
Variable Integer  VALEUR 
If [M:SPS1]CLCRUL (nolign-1)=3 :  VALEUR=2 : mkstat=2 : Endif 
End 

######################################################################### 

 




