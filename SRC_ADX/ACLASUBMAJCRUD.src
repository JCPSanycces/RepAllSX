#<AdxTL>@(#)0.0.0.0 $Revision$
Gosub TEST From ACLAVAL
End

#-------------------------------------------------------#

$ADDCLB
Append CLOB,space$(DIF)+LIGNE+chr$(10)
Return

$ADDCLB0
Append CLOB,LIGNE+chr$(10)
Return

#-------------------------------------------------------#
# Sous-programme recusive pour C et U
#-------------------------------------------------------#
Subprog PRG_AINSERT(ATBORI,ATBDES,ACLA,PROGRAM,NIVEAU,NIVPARCOURS,TABPARCOURS,NBFOR,ISFOR,CLOB,DIF)
Value    Char     ATBORI
Value    Char     ATBDES
Value    Instance ACLA Using C_ACLA
Value    Char     PROGRAM
Value    Integer  NIVEAU
Variable Integer  NIVPARCOURS
Variable Char     TABPARCOURS
Variable Integer  NBFOR
Variable Integer ISFOR
Variable Clbfile  CLOB
Variable Integer DIF

Gosub PRG_DEB From ACLAVALCRUD
Local Integer OKPROG

Case PROGRAM
 When "AINSERT" : OKPROG = (ACLA.ACLAK(NIVEAU).FLGC=2)
 When "AUPDATE" : OKPROG = (ACLA.ACLAK(NIVEAU).FLGU=2)
 When "ADELETE" : OKPROG = (ACLA.ACLAK(NIVEAU).FLGD=2)
Endcase

If ACLA.ACLAK(NIVEAU).CLALNK<>""
 If find(ACLA.ACLAK(NIVEAU).TYPLNK,2,4)  : #  For 1-> N
  ISFOR = 1 : NBFOR +=1
  LIGNE = "For A_N"+num$(NIVPARCOURS)+"=1 To"-ACLA.ACLAK(NIVEAU).STRMAXFOR : Gosub ADDCLB
  DIF += 1
  If OKPROG>0
   Gosub PRG_CRE_UPD
  Endif
 Elsif find(ACLA.ACLAK(NIVEAU).TYPLNK,1,3) : # Read 1 -> 1
  #ISFOR = 0
  LIGNE = "A_N"+num$(NIVPARCOURS)+"="
  If ACLA.ACLAK(NIVEAU).DIMCLALNK=2
   LIGNE += "0"
  Else
   LIGNE += "1"
  Endif
  Gosub ADDCLB
  LIGNE = "If"-ACLA.ACLAK(NIVEAU).STRCUR-'<> null and ': Gosub ADDCLB
  LIGNE = "&"-space$(DIF)-ACLA.ACLAK(NIVEAU).STRCUR+'.ASTALIN=[V]CST_ALL' : Gosub ADDCLB0
  LIGNE = ACLA.ACLAK(NIVEAU).STRCUR+'.ASTALIN = [V]CST_AUPD' : Gosub ADDCLB
  LIGNE = 'Endif' : Gosub ADDCLB
  If OKPROG>0
   Gosub PRG_CRE_UPD
  Endif
 Endif
Else
 If PROGRAM="AUPDATE" : LIGNE = 'If [V]CST_ASTALIN('+ACLA.ACLAK(NIVEAU).STRCUR+'.ASTALIN)<>""' : Gosub ADDCLB : DIF += 1 : Endif
 If OKPROG>0
  Call DECLARE_ACTION(ACLA.ACLAK(NIVEAU).STRCUR,PROGRAM,"","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
  Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
 Endif
 If PROGRAM="AUPDATE" : DIF -= 1 : LIGNE = 'Endif' : Gosub ADDCLB  :Endif
Endif

### Boucle récusivre vers les sous-structures
For I=1 To maxtab(ACLA.ACLAK)
 If ACLA.ACLAK(I).TABORI=func ACLASUBCRUD.TABLE(ATBDES) & ACLA.ACLAK(I).ABRORI=func ACLASUBCRUD.ABREV(ATBDES)
  NIVPARCOURS +=1
  Call PRG_AINSERT(ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI,ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK,ACLA,PROGRAM,I,NIVPARCOURS,TABPARCOURS,NBFOR,ISFOR,CLOB,DIF)
  NIVPARCOURS -=1
 Endif
Next I

If find(ACLA.ACLAK(NIVEAU).TYPLNK,2,4)  : #  For
 DIF -= 1 : LIGNE = "Next A_N"+num$(NIVPARCOURS) : Gosub ADDCLB
 ISFOR = (find(ACLA.ACLAK(find(ACLA.ACLAK(NIVEAU).TABORI,ACLA.ACLAK(1..maxtab(ACLA.ACLAK)).TABLNK)).TYPLNK,2,4))
 NBFOR -= 1
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
Endif

If DIF=0
 LIGNE = "#-----------------------------------------------------#" : Gosub ADDCLB
Else
 LIGNE = "#-----------------------#" : Gosub ADDCLB
Endif

End

#-------------------------------------------------------#
# Programme commun majsql rich media
#-------------------------------------------------------#
$MAJSQL_RICHMEDIA
Local Integer WTYPRUL
For J=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF)
 If ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY<>null & find(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.TYPTYP,9,10)>0
  If  ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.SUPFLG=2 & ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).LOBTAB<>ACLA.ACLAK(NIVEAU).TABLNK
   #106394 do MAJSQL only if necessary
   LIGNE="If find("-ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN,[V]CST_ANEW,[V]CST_ADEL) | " : Gosub ADDCLB
   LIGNE="& (find("-ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN,[V]CST_AUPD) & " : Gosub ADDCLB
   LIGNE='& fmet '-ACLA.ACLAK(NIVEAU).STRCUR+'.AGETATTRIBUTE("'+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA+'","$isLoaded")="true")'
   Gosub ADDCLB
   LIGNE ="[L]ASTATUS = func "+ACLA.ACLAV.TRTCRUD+"._MAJSQL_"+ACLA.ACLAK(NIVEAU).CLALNK+"_"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA
   LIGNE += "("+ACLA.ACLAK(NIVEAU).STRCUR+","+ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA+")" : Gosub ADDCLB
   Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
   LIGNE="Endif" : Gosub ADDCLB
  Elsif ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.SUPFLG<>2
   Case [L]PROGRAM
    When "AUPDATE" : WTYPRUL=7
    When "ADELETE" : WTYPRUL=8
    When "AINSERT" : WTYPRUL=9
   Endcase
   For R=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.ARUL)
    If ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.ARUL(R)<>null & ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.ARUL(R).TYPRUL=WTYPRUL
     LIGNE = "Call "+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.ARUL(R).PRGRUL+"("
     For RP=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.ARUL(R).APARRUL)
      If RP>1 : LIGNE += "," : Endif
      LIGNE += func ACLAVALTRT.EVAL_VALEUR(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.ARUL(R).APARRUL(RP).PARVAL,ACLA,ACLA.ACLAK(NIVEAU).STRCUR)
     Next
     LIGNE += ") From "+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.ARUL(R).TRTRUL : Gosub ADDCLB
     Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
    Endif
   Next
  Endif
 Endif
Next
Return

#-------------------------------------------------------#
# Programme commun creation/modification
#-------------------------------------------------------#
$PRG_CRE_UPD
LIGNE = "If"-ACLA.ACLAK(NIVEAU).STRCUR-"<> null and" : Gosub ADDCLB
LIGNE = "&"-space$(DIF)-"("+ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN=[L]A_TYPMAJ or": Gosub ADDCLB0
LIGNE = "&"-space$(DIF)-ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN=[V]CST_ALL)"
If ACLA.ACLAK(NIVEAU).FLGV = 2
 LIGNE += " and ([L]A_TYPMAJ<>[V]CST_ADEL)"
Endif
Gosub ADDCLB0
DIF += 1
If ACLA.ACLAK(NIVEAU).FLGV = 2   & PROGRAM="AUPDATE"
 LIGNE = "If [L]A_TYPMAJ=[V]CST_AUPD"  : Gosub ADDCLB
 DIF += 1
 LIGNE = ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN=[V]CST_ANEW"  : Gosub ADDCLB
 DIF -=1
 LIGNE = "Else" : Gosub ADDCLB
 DIF += 1
Endif
LIGNE = "If"-ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN=[L]A_TYPMAJ" : Gosub ADDCLB
DIF += 1
If ACLA.ACLAK(NIVEAU).FLGA<>2
 If PROGRAM="AUPDATE" : LIGNE = 'If [V]CST_ASTALIN('+ACLA.ACLAK(NIVEAU).STRCUR+'.ASTALIN)<>""' : Gosub ADDCLB : DIF += 1 : Endif
 If PROGRAM="AINSERT"  : LIGNE = "Raz [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]" : Gosub ADDCLB : Endif
 Call DECLARE_ACTION(ACLA.ACLAK(NIVEAU).STRCUR,PROGRAM+"_BEFORE","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD :
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
 If PROGRAM="AUPDATE" : DIF -= 1 : LIGNE = 'Endif' : Gosub ADDCLB  :Endif
Endif
If (ACLA.ACLAK(NIVEAU).FLGC <> 2 & PROGRAM="AINSERT") or (ACLA.ACLAK(NIVEAU).FLGU<>2 & PROGRAM="AUPDATE")
 If PROGRAM="AUPDATE" : LIGNE = 'If [V]CST_ASTALIN('+ACLA.ACLAK(NIVEAU).STRCUR+'.ASTALIN)<>""' : Gosub ADDCLB : DIF += 1 : Endif
 Call DECLARE_ACTION(ACLA.ACLAK(NIVEAU).STRCUR,PROGRAM,"","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
 If PROGRAM="AUPDATE" : DIF -= 1 : LIGNE = 'Endif' : Gosub ADDCLB  :Endif
Elsif ACLA.ACLAK(NIVEAU).FLGA<>2
 LIGNE ="[L]ASTATUS = func "+ACLA.ACLAV.TRTCRUD+"._MAJSQL_"+ACLA.ACLAK(NIVEAU).TABLNK+"("+ACLA.ACLAK(NIVEAU).STRCUR+")" :  Gosub ADDCLB
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
Elsif  ACLA.ACLAK(NIVEAU).FLGA=2
 LIGNE = "Case"-ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN" : Gosub ADDCLB
 DIF +=1
 LIGNE = "When [V]CST_AUPD  : [L]ASTATUS = max([L]ASTATUS,fmet "+ACLA.ACLAK(NIVEAU).STRCUR+"._AUPDATE)": Gosub ADDCLB
 LIGNE = "When [V]CST_ANEW : [L]ASTATUS = max([L]ASTATUS,fmet "+ACLA.ACLAK(NIVEAU).STRCUR+"._AINSERT)": Gosub ADDCLB
 LIGNE = "When [V]CST_ADEL  : [L]ASTATUS = max([L]ASTATUS,fmet "+ACLA.ACLAK(NIVEAU).STRCUR+"._ADELETE)": Gosub ADDCLB
 DIF -= 1
 LIGNE = "Endcase" : Gosub ADDCLB
 #LIGNE = "[L]ASTATUS = fmet "+ACLA.ACLAK(NIVEAU).STRCUR+"._"+PROGRAM : Gosub ADDCLB
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
Endif
If ACLA.ACLAK(NIVEAU).FLGA<>2
 If PROGRAM="AUPDATE" : LIGNE = 'If [V]CST_ASTALIN('+ACLA.ACLAK(NIVEAU).STRCUR+'.ASTALIN)<>""' : Gosub ADDCLB : DIF += 1 : Endif
 Call DECLARE_ACTION(ACLA.ACLAK(NIVEAU).STRCUR,PROGRAM+"_AFTER","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD :
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
 If PROGRAM="AUPDATE" : DIF -= 1 : LIGNE = 'Endif' : Gosub ADDCLB  :Endif
Endif

DIF -= 1 : LIGNE = "Endif" : Gosub ADDCLB
If ACLA.ACLAK(NIVEAU).FLGV =2  & PROGRAM="AUPDATE"
 DIF -= 1 : LIGNE = "Endif" : Gosub ADDCLB
Endif
DIF -= 1 : LIGNE = "Endif" : Gosub ADDCLB
Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD

Return

#-------------------------------------------------------#
# TRT_AFTERREWRITE_COLLECTION
#-------------------------------------------------------#
Subprog TRT_AFTERREWRITE_COLLECTION(ACLA,NIVEAU,PROGRAM,TYPACT,ISFOR,NBFOR,NIVPARCOURS,LIGNE,DIF,CLOB)
Variable Instance ACLA Using OBJECT
Value Integer NIVEAU
Value Char PROGRAM
Value Char TYPACT
Value Integer ISFOR
Variable Integer NBFOR
Variable Integer NIVPARCOURS
Variable Char LIGNE
Variable Integer DIF
Variable Clbfile CLOB
For I=1 To ACLA.ACLAK(NIVEAU).ACLALNK.NBRGRP
 If ACLA.ACLAK(NIVEAU).ACLALNK.CRECLAGRP(I)=2
  LIGNE = "For [L]A_I=1 To maxtab("+ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+")" : Gosub ADDCLB
  DIF += 1
  LIGNE = "If "+ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+"([L]A_I)<>null"  : Gosub ADDCLB
  DIF += 1
  If TYPACT="OK"
   LIGNE = "If "+ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+"([L]A_I).ASTALIN=[V]CST_ADEL "
   LIGNE += "or "+ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+"([L]A_I).ASTALIN=[V]CST_ANEWDEL"
   Gosub ADDCLB
   DIF += 1
   LIGNE = "FreeInstance"-ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+"([L]A_I)" : Gosub ADDCLB
   LIGNE = ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+"([L]A_I) = null"  : Gosub ADDCLB
   DIF -= 1
   #106394 don't assign [V]CST_ALL if it's already [V]CST_ALL
   LIGNE = "Elsif "+ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+"([L]A_I).ASTALIN <> [V]CST_ALL" : Gosub ADDCLB
   DIF += 1
   LIGNE = ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+"([L]A_I).ASTALIN = [V]CST_ALL" : Gosub ADDCLB
   DIF -= 1
   LIGNE = "Endif" : Gosub ADDCLB
  Elsif TYPACT="KO"
   LIGNE = "If "+ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+"([L]A_I).ASTALIN=[V]CST_ANEWDEL" : Gosub ADDCLB
   DIF += 1
   LIGNE = ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+"([L]A_I).ASTALIN = [V]CST_ANEW" : Gosub ADDCLB
   DIF -= 1
   LIGNE = "Endif" : Gosub ADDCLB
  Endif
  DIF -= 1
  LIGNE = "Endif" : Gosub ADDCLB
  DIF -= 1
  LIGNE = "Next" :  Gosub ADDCLB
  Gosub ERREUR_ACTION_GOTO From ACLASUBCRUD
 Endif
Next
End

#-------------------------------------------------------#
# PRG_AFTERREWRITE
#-------------------------------------------------------#
Subprog PRG_AFTERREWRITE(ATBORI,ATBDES,ACLA,PROGRAM,TYPACT,NIVEAU,NIVPARCOURS,TABPARCOURS,NBFOR,CLOB,DIF)
Value    Char     ATBORI
Value    Char     ATBDES
Value    Instance ACLA Using C_ACLA
Value    Char     PROGRAM
Value    Char     TYPACT
Value    Integer  NIVEAU
Variable Integer  NIVPARCOURS
Variable Char     TABPARCOURS()()
Variable Integer  NBFOR
Variable Clbfile  CLOB
Variable Integer DIF

Local Integer   I,ISFOR
Local Char      LIGNE(250)

# Call Ajout au tableau de parcours l'enreg courant : couple TABDES-TABORI
For I=1 To dim(TABPARCOURS)
 If TABPARCOURS(I)=""
  TABPARCOURS(I)= ATBDES-ATBORI
  Break
 Endif
Next

LIGNE = "Local Integer ASTATUS2" : Gosub ADDCLB

If ACLA.ACLAK(NIVEAU).CLALNK<>""
 If find(ACLA.ACLAK(NIVEAU).TYPLNK,2,4)  : #  For 1-> N
  ISFOR = 1 : NBFOR +=1
  LIGNE = "For A_N"+num$(NIVPARCOURS)+"=1 To"-ACLA.ACLAK(NIVEAU).STRMAXFOR : Gosub ADDCLB
  DIF += 1
 Elsif find(ACLA.ACLAK(NIVEAU).TYPLNK,1,3) : # Read 1 -> 1
  ISFOR = 0
  LIGNE = "A_N"+num$(NIVPARCOURS)+"="
  If ACLA.ACLAK(NIVEAU).DIMCLALNK=2
   LIGNE += "0"
  Else
   LIGNE += "1"
  Endif
  Gosub ADDCLB
 Endif
Endif

LIGNE = "If"-ACLA.ACLAK(NIVEAU).STRCUR-"<> null" : Gosub ADDCLB
DIF += 1

### Boucle récusivre vers les sous-structures
For I=1 To maxtab(ACLA.ACLAK)
 If ACLA.ACLAK(I).TABORI=func ACLASUBCRUD.TABLE(ATBDES) & ACLA.ACLAK(I).ABRORI=func ACLASUBCRUD.ABREV(ATBDES)
  NIVPARCOURS +=1
  Call PRG_AFTERREWRITE(ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI,ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK,ACLA,PROGRAM,TYPACT,I,NIVPARCOURS,TABPARCOURS,NBFOR,CLOB,DIF)
  NIVPARCOURS -=1
 Endif
Next I

If ACLA.ACLAK(NIVEAU).FLGA=2
 LIGNE= '[L]ASTATUS2 = fmet '+ACLA.ACLAK(NIVEAU).STRCUR+"._"+PROGRAM+"_"
 If TYPACT="OK"
  LIGNE += "AFTER"
 Else
  LIGNE += "ABORT"
 Endif
 Gosub ADDCLB
 LIGNE = "If "+ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN=[V]CST_ADEL or "+ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN=[V]CST_ANEWDEL" : Gosub ADDCLB
 DIF += 1
 LIGNE = "FreeInstance"-ACLA.ACLAK(NIVEAU).STRCUR : Gosub ADDCLB
 LIGNE = ACLA.ACLAK(NIVEAU).STRCUR-"= null"  : Gosub ADDCLB
 DIF -= 1
 LIGNE = "Endif"  : Gosub ADDCLB
Else
 If TYPACT="OK"
  LIGNE = "If "+ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN=[V]CST_ADEL or "+ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN=[V]CST_ANEWDEL" : Gosub ADDCLB
  DIF += 1
  LIGNE = "FreeInstance"-ACLA.ACLAK(NIVEAU).STRCUR : Gosub ADDCLB
  LIGNE = ACLA.ACLAK(NIVEAU).STRCUR-"= null"  : Gosub ADDCLB
  DIF -= 1
  #106394 don't assign [V]CST_ALL if it's already [V]CST_ALL
  LIGNE = "Elsif "+ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN <> [V]CST_ALL" : Gosub ADDCLB
  DIF += 1
  LIGNE = ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN = [V]CST_ALL" : Gosub ADDCLB
 Elsif TYPACT="KO"
  LIGNE = "If "+ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN=[V]CST_ANEWDEL" : Gosub ADDCLB
  DIF += 1
  LIGNE = ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN = [V]CST_ANEW" : Gosub ADDCLB
 Endif
 Call TRT_AFTERREWRITE_COLLECTION(ACLA,NIVEAU,PROGRAM,TYPACT,ISFOR,NBFOR,NIVPARCOURS,LIGNE,DIF,CLOB)
Endif


If ACLA.ACLAK(NIVEAU).FLGA<>2
 DIF -= 1 : LIGNE = "Endif"  : Gosub ADDCLB
Endif

LIGNE = "[L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)" : Gosub ADDCLB

DIF -= 1 : LIGNE = "Endif" : Gosub ADDCLB

If find(ACLA.ACLAK(NIVEAU).TYPLNK,2,4)  : #  For
 DIF -= 1 : LIGNE = "Next A_N"+num$(NIVPARCOURS) : Gosub ADDCLB
 ISFOR = (find(ACLA.ACLAK(find(ACLA.ACLAK(NIVEAU).TABORI,ACLA.ACLAK(1..maxtab(ACLA.ACLAK)).TABLNK)).TYPLNK,2,4))
 NBFOR -= 1
Endif

End

#-------------------------------------------------------#
# A_CONTROL
#-------------------------------------------------------#
$A_CONTROL
NIVEAU = 1
LIGNE = "" : Gosub ADDCLB
LIGNE = "$"+PROGRAM+"_CONTROL"  : Gosub ADDCLB
LIGNE = "Gosub _"+PROGRAM+"_CONTROL_BEFORE"  : Gosub ADDCLB
LIGNE = "If [L]ASTATUS>=[V]CST_AERROR : Return : Endif" : Gosub ADDCLB

If PROGRAM<>[V]CST_APRGADELETE : # Not adelete
 LIGNE = "# Control mandatory" : Gosub ADDCLB : # Control mandatory
 LIGNE = "[L]ASTATUS =  max([L]ASTATUS,fmet "+[L]ROOTNAM+"."+ACLA.ACLAV.TBMET(6)+")" : Gosub ADDCLB
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD

 LIGNE = "" : Gosub ADDCLB
 LIGNE = "# Control format" : Gosub ADDCLB : # Control format
 LIGNE = "[L]ASTATUS =  max([L]ASTATUS,fmet "+[L]ROOTNAM+"."+ACLA.ACLAV.TBMET(7)+")" : Gosub ADDCLB
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD

 LIGNE = "" : Gosub ADDCLB
 LIGNE = "# Control other" : Gosub ADDCLB : # Control other
 LIGNE = "[L]ASTATUS =  max([L]ASTATUS,fmet "+[L]ROOTNAM+"."+ACLA.ACLAV.TBMET(8)+")" : Gosub ADDCLB
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD

Else : # adelete
 If ACLA.TYPCLA=2
  LIGNE = "# Verification delete" : Gosub ADDCLB
  LIGNE = "[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE("+[L]ROOTCLA+",ALNKDELTAB))" : Gosub ADDCLB
  LIGNE = "If [L]ASTATUS>=[V]CST_AERROR : Return : Endif" : Gosub ADDCLB
 Endif

Endif
LIGNE = "Gosub _"+PROGRAM+"_CONTROL_AFTER"  : Gosub ADDCLB
LIGNE = "If [L]ASTATUS>=[V]CST_AERROR : Return : Endif" : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = "#-----------------------------------------------------#"  : Gosub ADDCLB
LIGNE = "$_"+PROGRAM+"_CONTROL_BEFORE"  : Gosub ADDCLB
LIGNE = "If"-ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN = [V]CST_ANEWDEL : Return : Endif" : Gosub ADDCLB
If PROGRAM="AINSERT"
 LIGNE = ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN = [V]CST_ANEW" : Gosub ADDCLB
Elsif PROGRAM ="AUPDATE"
 LIGNE = ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN = [V]CST_AUPD"  : Gosub ADDCLB
Elsif PROGRAM ="ADELETE"
 LIGNE = ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN = [V]CST_ADEL"  :  Gosub ADDCLB
Endif
If PROGRAM="AUPDATE" : LIGNE = 'If [V]CST_ASTALIN('+ACLA.ACLAK(NIVEAU).STRCUR+'.ASTALIN)<>""' : Gosub ADDCLB : DIF += 1 : Endif
Call DECLARE_ACTION(ACLA.ACLAK(NIVEAU).STRCUR,PROGRAM+"_CONTROL_BEFORE","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
If PROGRAM="AUPDATE" : DIF -= 1 : LIGNE = 'Endif' : Gosub ADDCLB  :Endif

Call CONTROLE_COLLECTION(ACLA,NIVEAU,PROGRAM,"CONTROL_BEFORE",ISFOR,NBFOR,NIVPARCOURS,LIGNE,DIF,CLOB)

Raz LIGNE
Raz TABPARCOURS
For I=2 To maxtab(ACLA.ACLAK)
 If !find(ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK-ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI,TABPARCOURS)
  ATBDES    = ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK
  ATBORI    = ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI
  NIVPARCOURS = 2
  Call PRG_CONTROL(ATBORI,ATBDES,ACLA,PROGRAM,"CONTROL_BEFORE",I,NIVPARCOURS,TABPARCOURS,NBFOR ,CLOB,DIF)
 Endif
Next I
NIVEAU = 1
LIGNE = "" : Gosub ADDCLB
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = "#-----------------------------------------------------#"  : Gosub ADDCLB
LIGNE = "$_"+PROGRAM+"_CONTROL_AFTER"  : Gosub ADDCLB
Raz LIGNE,NBFOR
Raz TABPARCOURS
For I=2 To maxtab(ACLA.ACLAK)
 If !find(ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK-ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI,TABPARCOURS)
  ATBDES    = ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK
  ATBORI    = ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI
  NIVPARCOURS = 2
  Call PRG_CONTROL(ATBORI,ATBDES,ACLA,PROGRAM,"CONTROL_AFTER",I,NIVPARCOURS,TABPARCOURS,NBFOR ,CLOB,DIF)
 Endif
Next I

Raz NIVPARCOURS
LIGNE = "" : Gosub ADDCLB

Call CONTROLE_COLLECTION(ACLA,NIVEAU,PROGRAM,"CONTROL_AFTER",1,NBFOR,NIVPARCOURS,LIGNE,DIF,CLOB)

If PROGRAM="AUPDATE" : LIGNE = 'If [V]CST_ASTALIN('+ACLA.ACLAK(NIVEAU).STRCUR+'.ASTALIN)<>""' : Gosub ADDCLB : DIF += 1 : Endif
Call DECLARE_ACTION(ACLA.ACLAK(NIVEAU).STRCUR,PROGRAM+"_CONTROL_AFTER","","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
If PROGRAM="AUPDATE" : DIF -= 1 : LIGNE = 'Endif' : Gosub ADDCLB  :Endif
LIGNE = "Return" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

#-------------------------------------------------------#
# CONTROLE_COLLECTION
#-------------------------------------------------------#
Subprog CONTROLE_COLLECTION(ACLA,NIVEAU,PROGRAM,TYPACT,ISFOR,NBFOR,NIVPARCOURS,LIGNE,DIF,CLOB)
Variable Instance ACLA Using OBJECT
Value Integer NIVEAU
Value Char PROGRAM
Value Char TYPACT
Value Integer ISFOR
Variable Integer NBFOR
Variable Integer NIVPARCOURS
Variable Char LIGNE
Variable Integer DIF
Variable Clbfile CLOB
For I=1 To ACLA.ACLAK(NIVEAU).ACLALNK.NBRGRP
 If ACLA.ACLAK(NIVEAU).ACLALNK.CRECLAGRP(I)=2
  LIGNE = "For [L]A_I=1 To maxtab("+ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+")" : Gosub ADDCLB
  ISFOR = 1 : NBFOR+=1
  DIF += 1
  LIGNE = "If "+ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+"([L]A_I)<>null"  : Gosub ADDCLB
  DIF += 1
  Call DECLARE_ACTION(ACLA.ACLAK(NIVEAU).STRCUR+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+"([L]A_I)",PROGRAM+"_"+TYPACT,"","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
  Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
  DIF -= 1
  LIGNE = "Endif" : Gosub ADDCLB
  DIF -= 1
  LIGNE = "Next" :  Gosub ADDCLB
  NBFOR -= 1 : ISFOR =0
  Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
 Endif
Next
End


#-------------------------------------------------------#
# PRG_CONTROL
#-------------------------------------------------------#
Subprog PRG_CONTROL(ATBORI,ATBDES,ACLA,PROGRAM,TYPACT,NIVEAU,NIVPARCOURS,TABPARCOURS,NBFOR,CLOB,DIF)
Value    Char     ATBORI
Value    Char     ATBDES
Value    Instance ACLA Using C_ACLA
Value    Char     PROGRAM
Value    Char     TYPACT
Value    Integer  NIVEAU
Variable Integer  NIVPARCOURS
Variable Char     TABPARCOURS
Variable Integer  NBFOR
Variable Clbfile  CLOB
Variable Integer DIF

Local Integer   I,ISFOR,OKPROG
Local Char      LIGNE(250)

# Call Ajout au tableau de parcours l'enreg courant : couple TABDES-TABORI
For I=1 To dim(TABPARCOURS)
 If TABPARCOURS(I)=""
  TABPARCOURS(I)= ATBDES-ATBORI
  Break
 Endif
Next

Case PROGRAM
 When "AINSERT" : OKPROG = (ACLA.ACLAK(NIVEAU).FLGC=2)
 When "AUPDATE" : OKPROG = (ACLA.ACLAK(NIVEAU).FLGU=2)
 When "ADELETE" : OKPROG = (ACLA.ACLAK(NIVEAU).FLGD=2)
Endcase

If ACLA.ACLAK(NIVEAU).CLALNK<>""
 If find(ACLA.ACLAK(NIVEAU).TYPLNK,2,4)  : #  For 1-> N
  ISFOR = 1 : NBFOR +=1
  LIGNE = "For A_N"+num$(NIVPARCOURS)+"=1 To"-ACLA.ACLAK(NIVEAU).STRMAXFOR-": #"-ACLA.ACLAK(NIVEAU).CLALNK-"--"-num$(NIVEAU) : Gosub ADDCLB
  DIF += 1
 Elsif find(ACLA.ACLAK(NIVEAU).TYPLNK,1,3) : # Read 1 -> 1
  ISFOR = 0
  LIGNE = "A_N"+num$(NIVPARCOURS)+"="
  If ACLA.ACLAK(NIVEAU).DIMCLALNK=2
   LIGNE += "0"
  Else
   LIGNE += "1"
  Endif
  Gosub ADDCLB
 Endif
Endif

LIGNE = "If"-ACLA.ACLAK(NIVEAU).STRCUR-"<> null" : Gosub ADDCLB
If PROGRAM="AINSERT"
 LIGNE = "& and !find("+ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)" : Gosub ADDCLB0
Else
 LIGNE = "& and "+ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN<>[V]CST_ANEWDEL" : Gosub ADDCLB0
Endif
DIF += 1

If OKPROG>0

  If PROGRAM="AUPDATE" & TYPACT = "CONTROL_BEFORE"
   If NIVEAU>=2
    LIGNE = "If "+ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN<>[V]CST_ANEW & "+ACLA.ACLAK(NIVEAU).STRCURFAT+".ASTALIN=[V]CST_ADEL"  : Gosub ADDCLB
    DIF += 1
    LIGNE =  ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN = [V]CST_ADEL"  : Gosub ADDCLB
    DIF -= 1
    LIGNE = "Endif"  : Gosub ADDCLB
    LIGNE = "If "+ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN=[V]CST_ANEW & find("+ACLA.ACLAK(NIVEAU).STRCURFAT+".ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0" : Gosub ADDCLB
    DIF += 1
    LIGNE =  ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN = [V]CST_ANEWDEL"  : Gosub ADDCLB
    DIF -= 1
    LIGNE = "Endif" : Gosub ADDCLB
   Endif
  Endif

  If PROGRAM="ADELETE" & TYPACT = "CONTROL_BEFORE"
   LIGNE = "If "+ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN<>[V]CST_ANEW"  : Gosub ADDCLB
   DIF += 1
   LIGNE =  ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN = [V]CST_ADEL"  : Gosub ADDCLB
  Endif

  If PROGRAM="AUPDATE" : LIGNE = 'If [V]CST_ASTALIN('+ACLA.ACLAK(NIVEAU).STRCUR+'.ASTALIN)<>""' : Gosub ADDCLB : DIF += 1 : Endif

  If ACLA.ACLAK(NIVEAU).FLGA=2 : # Managment by class
   If PROGRAM="AUPDATE"
    LIGNE = 'Case [V]CST_ASTALIN('+ACLA.ACLAK(NIVEAU).STRCUR+'.ASTALIN)'  : Gosub ADDCLB
    DIF += 1
    LIGNE = 'When [V]CST_APRGAINSERT  : [L]ASTATUS = max([L]ASTATUS,fmet '+ACLA.ACLAK(NIVEAU).STRCUR+"._"+[V]CST_APRGAINSERT+"_"+TYPACT+")" : Gosub ADDCLB
    LIGNE = 'When [V]CST_APRGAUPDATE : [L]ASTATUS = max([L]ASTATUS,fmet '+ACLA.ACLAK(NIVEAU).STRCUR+"._"+[V]CST_APRGAUPDATE+"_"+TYPACT+")"  : Gosub ADDCLB
    LIGNE = 'When [V]CST_APRGADELETE  : [L]ASTATUS = max([L]ASTATUS,fmet '+ACLA.ACLAK(NIVEAU).STRCUR+"._"+[V]CST_APRGADELETE+"_"+TYPACT+")"  : Gosub ADDCLB
    DIF -=1
    LIGNE = "Endcase"  : Gosub ADDCLB
   Else
    LIGNE= '[L]ASTATUS = max([L]ASTATUS,fmet '+ACLA.ACLAK(NIVEAU).STRCUR+"._"+PROGRAM+"_"+TYPACT+")" : Gosub ADDCLB
   Endif
  Else
   Call DECLARE_ACTION(ACLA.ACLAK(NIVEAU).STRCUR,PROGRAM+"_"+TYPACT,"","","",LIGNE,DIF,CLOB) From ACLASUBCRUD
  Endif
  Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
   If PROGRAM="AUPDATE" : DIF -= 1 : LIGNE = 'Endif' : Gosub ADDCLB  :Endif

  Call CONTROLE_COLLECTION(ACLA,NIVEAU,PROGRAM,TYPACT,ISFOR,NBFOR,NIVPARCOURS,LIGNE,DIF,CLOB) From ACLASUBMAJCRUD

  If find(PROGRAM+"_"+TYPACT,"ADELETE_CONTROL_BEFORE")>0
   DIF -= 1 : LIGNE = "Endif" : Gosub ADDCLB
  Endif

Endif

If find(ACLA.ACLAK(NIVEAU).TYPLNK,2,4)
 DIF -= 1 : LIGNE = "Endif" : Gosub ADDCLB
Endif


### Boucle récusivre vers les sous-structures
For I=1 To maxtab(ACLA.ACLAK)
 If ACLA.ACLAK(I).TABORI=func ACLASUBCRUD.TABLE(ATBDES) & ACLA.ACLAK(I).ABRORI=func ACLASUBCRUD.ABREV(ATBDES)
  NIVPARCOURS +=1
  Call PRG_CONTROL(ACLA.ACLAK(I).TABORI-ACLA.ACLAK(I).ABRORI,ACLA.ACLAK(I).TABLNK-ACLA.ACLAK(I).ABRLNK,ACLA,PROGRAM,TYPACT,I,NIVPARCOURS,TABPARCOURS,NBFOR,CLOB,DIF)
  NIVPARCOURS -=1
 Endif
Next I

If find(ACLA.ACLAK(NIVEAU).TYPLNK,2,4)  : #  For
 DIF -= 1 : LIGNE = "Next A_N"+num$(NIVPARCOURS) : Gosub ADDCLB
 ISFOR = (find(ACLA.ACLAK(find(ACLA.ACLAK(NIVEAU).TABORI,ACLA.ACLAK(1..maxtab(ACLA.ACLAK)).TABLNK)).TYPLNK,2,4))
 NBFOR -= 1
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
Elsif find(ACLA.ACLAK(NIVEAU).TYPLNK,1,3) : # read
 DIF -= 1 : LIGNE = "Endif" : Gosub ADDCLB
 Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
Endif

If find(PROGRAM,"AINSERT","AUPDATE")>0 : #102478 CCL No control on minimum number of lines in collection
 If find(ACLA.ACLAK(NIVEAU).TYPLNK,3,4)>0 : # 100935 New Bug 'Error when delete header/lines
   LIGNE = "Local Integer A_OK1" : Gosub ADDCLB
   If ACLA.ACLAK(NIVEAU).TYPLNK=4
    LIGNE = "For A_N"+num$(NIVPARCOURS)+"=1 to "+ACLA.ACLAK(NIVEAU).STRMAXFOR : Gosub ADDCLB
    DIF += 1
    LIGNE = "If"-ACLA.ACLAK(NIVEAU).STRCUR+"<>null" :Gosub ADDCLB
    DIF += 1
    LIGNE = "If "+ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN<>[V]CST_ADEL & "+ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN<>[V]CST_ANEWDEL" : Gosub ADDCLB
    DIF += 1
    LIGNE = "[L]A_OK1 = 1 : Break" : Gosub ADDCLB
    DIF -= 1
    LIGNE = "Endif" : Gosub ADDCLB
    DIF -= 1
    LIGNE = "Endif" : Gosub ADDCLB
    DIF -= 1
    LIGNE = "Next" : Gosub ADDCLB
   Else
    LIGNE = "A_N"+num$(NIVPARCOURS)+"="
    If ACLA.ACLAK(NIVEAU).DIMCLALNK=2
     LIGNE += "0"
    Else
     LIGNE += "1"
    Endif
    Gosub ADDCLB
    LIGNE = "If "+ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN<>[V]CST_ADEL & "+ACLA.ACLAK(NIVEAU).STRCUR+".ASTALIN<>[V]CST_ANEWDEL" : Gosub ADDCLB
    DIF += 1
    LIGNE = "[L]A_OK1 = 1" : Gosub ADDCLB
    DIF -= 1
    LIGNE = "Endif" : Gosub ADDCLB
   Endif
   LIGNE = "If [L]A_OK1=0" : Gosub ADDCLB
   DIF += 1
   LIGNE = "[L]ASTATUS = func ASYRSUB._ASETSTATUS("+ACLA.ACLAK(NIVEAU).STRCURFAT+',"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,"'
   LIGNE += +ACLA.ACLAK(NIVEAU).TABLNK+':"-mess(70,126,1))'-': #'-mess(70,126,1) : Gosub ADDCLB
   Gosub ERREUR_ACTION_RECURSIF From ACLASUBCRUD
   DIF -= 1
   LIGNE = "Endif" : Gosub ADDCLB
  Endif
Endif
End

$MAJSQLLOB
If !find(ACLA.ACLAK(NIVEAU).TABLNK,ACLA.ACLAK(1..NIVEAU-1).TABLNK)
 For J=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF)
  If ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY<>null
   If  ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.SUPFLG=2 & ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).LOBTAB=ACLA.ACLAK(NIVEAU).TABLNK
    If ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY<>null & find(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.TYPTYP,9,10)>0 & ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.SUPFLG=2
     LIGNE = "Call _MAJSQL_"+ACLA.ACLAK(NIVEAU).CLALNK+"_"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA+"("+WCLASSE+","+WCLASSE+"."+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA+")"  :  Gosub ADDCLB
    Endif
   Endif
  Endif
 Next
Endif
Return

$CTLDATASTABLE
If GADONIX=[V]CST_AFALSE : Return : Endif
LIGNE ="[L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE("+WCLASSE+',"'+ACLA.ACLAK(NIVEAU).TABLNK+'")' : Gosub ADDCLB
LIGNE ="If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif" : Gosub ADDCLB
Return

#-------------------------------------------------------#
# TRT_MAJSQL
#-------------------------------------------------------#
$TRT_MAJSQL
PROGRAM = ""
Local Char    TYPOBJ(GLONAOB)(1..), CUROBJ(GLONAOB)
Local Integer NBTYP
Call SET_TYPOBJ(DOSSIER,NBTYP,TYPOBJ) From ASYRFNC

Local Char WCLASSE(250)
For NIVEAU=1 To maxtab(ACLA.ACLAK)
 If !find(ACLA.ACLAK(NIVEAU).TABLNK,ACLA.ACLAK(1..NIVEAU-1).TABLNK)
 WCLASSE = "W"+ACLA.ACLAK(NIVEAU).ABRLNK
 LIGNE = "############################################################################################" : Gosub ADDCLB
 LIGNE = "### "+ACLA.ACLAK(NIVEAU).TABLNK+"("+WCLASSE+")" : Gosub ADDCLB
 LIGNE = "############################################################################################" : Gosub ADDCLB
 LIGNE = "Funprog  _MAJSQL_"+ACLA.ACLAK(NIVEAU).TABLNK+"("+WCLASSE+")"  :  Gosub ADDCLB
 LIGNE = "Variable Instance "+WCLASSE+" Using C_"+ACLA.ACLAK(NIVEAU).CLALNK :  Gosub ADDCLB
 LIGNE = "Local Integer ASTATUS,A_I,A_J" : Gosub ADDCLB
 LIGNE = "Default File [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]" : Gosub ADDCLB

 # CREATE
 LIGNE = "If "+WCLASSE+".ASTALIN=[V]CST_ANEW":  Gosub ADDCLB
 DIF +=1
 LIGNE = "Call INICRE("+WCLASSE+") From ASYRSUB" : Gosub ADDCLB
 LIGNE = "SetInstance [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"] With"-WCLASSE  : Gosub ADDCLB
 Call TRT_TEXTE(ACLA,NIVEAU,[V]CST_APRGAINSERT,WCLASSE,ISFOR,NBFOR,LIGNE,CLOB,DIF) From ACLATXTCRUD
 Gosub MAJSQLCOL
 Gosub MAJSQLLOB
 LIGNE = "Write [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"  :  Gosub ADDCLB
 Gosub ERREUR_FSTA
 Call MAJXCB(ACLA.ACLAK(NIVEAU),WCLASSE,"AINSERT",ACLA.LNKOBJ,TYPOBJ,NBTYP,DOSSIER,LIGNE,DIF,CLOB)
 LIGNE = WCLASSE+".updTick = [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]updTick"  : Gosub ADDCLB
 DIF -=1

 ### UPDATE
 LIGNE = "Elsif "+WCLASSE+".ASTALIN=[V]CST_ALL or "+WCLASSE+".ASTALIN=[V]CST_AUPD":  Gosub ADDCLB
 DIF += 1
 LIGNE = "Call INIUPD("+WCLASSE+") From ASYRSUB" : Gosub ADDCLB
 LIGNE = "SetInstance [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"] With"-WCLASSE  : Gosub ADDCLB
 Call TRT_TEXTE(ACLA,NIVEAU,[V]CST_APRGAUPDATE,WCLASSE,ISFOR,NBFOR,LIGNE,CLOB,DIF) From ACLATXTCRUD
 Gosub MAJSQLCOL
 Gosub MAJSQLLOB
 Gosub CTLDATASTABLE
 LIGNE = "RewriteByKey [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"+ACLA.ACLAK(NIVEAU).CLELNK-"= [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"+ACLA.ACLAK(NIVEAU).INDEX(1)
 For I=2 To ACLA.ACLAK(NIVEAU).NBRIND
  LIGNE += ";[F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"+ACLA.ACLAK(NIVEAU).INDEX(I)
 Next I
 Gosub ADDCLB
 Gosub ERREUR_FSTA
 Call MAJXCB(ACLA.ACLAK(NIVEAU),WCLASSE,"AUPDATE",ACLA.LNKOBJ,TYPOBJ,NBTYP,DOSSIER,LIGNE,DIF,CLOB)
 LIGNE = WCLASSE+".updTick = [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]updTick"  : Gosub ADDCLB
 DIF -= 1

 # DELETE
 LIGNE = "Elsif "+WCLASSE+".ASTALIN=[V]CST_ADEL":  Gosub ADDCLB
 DIF +=1
 LIGNE = "SetInstance [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"-"With "+WCLASSE : Gosub ADDCLB
 Call TRT_TEXTE(ACLA,NIVEAU,[V]CST_APRGADELETE,WCLASSE,ISFOR,NBFOR,LIGNE,CLOB,DIF) From ACLATXTCRUD
 Gosub CTLDATASTABLE
 LIGNE = "DeleteByKey [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"+ACLA.ACLAK(NIVEAU).CLELNK-"= [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"+ACLA.ACLAK(NIVEAU).INDEX(1)
 For I=2 To ACLA.ACLAK(NIVEAU).NBRIND
  LIGNE += ";[F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"+ACLA.ACLAK(NIVEAU).INDEX(I)
 Next I
 Gosub ADDCLB
 Gosub ERREUR_FSTA
 Call MAJXCB(ACLA.ACLAK(NIVEAU),WCLASSE,"ADELETE",ACLA.LNKOBJ,TYPOBJ,NBTYP,DOSSIER,LIGNE,DIF,CLOB)
 DIF -= 1

 LIGNE = "Endif":  Gosub ADDCLB
 LIGNE = "End [V]CST_AOK" :  Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB
 Endif
Next

# Clob and Blob
Local Char    KEYVAL(120)(1..15)
Local Integer NBKEY, KEYTYP(1..15)
Local Integer NK
Local Integer WCAS
Local Char WCODZONE(GLONAVA),WCODCNT(GLONAVA)
Local Integer ISINFILE

For NIVEAU=1 To maxtab(ACLA.ACLAK)

 If !find(ACLA.ACLAK(NIVEAU).TABLNK,ACLA.ACLAK(1..NIVEAU-1).TABLNK)
  For J=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF)
   Raz ISINFILE
   If ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY<>null & ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.SUPFLG=2 & ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).LOBTAB=ACLA.ACLAK(NIVEAU).TABLNK
    ISINFILE=1
   Endif

   If ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY<>null & find(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.TYPTYP,9,10)>0 & ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.SUPFLG=2
    WCLASSE = "W"+ACLA.ACLAK(NIVEAU).ABRLNK
    LIGNE = "Funprog  _MAJSQL_"+ACLA.ACLAK(NIVEAU).CLALNK+"_"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA+"("+WCLASSE+","+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA+")"  :  Gosub ADDCLB
    LIGNE = "Variable Instance "+WCLASSE+" Using C_"+ACLA.ACLAK(NIVEAU).CLALNK :  Gosub ADDCLB
    LIGNE = "Value "
    Case ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.TYPTYP
     When 9 : LIGNE += "Blbfile "
     When 10 : LIGNE+= "Clbfile "
    Endcase
    LIGNE += ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA : Gosub ADDCLB
    #---
    Case ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.TYPTYP
     When 9 : LIGNE = "Local Blbfile WEMPTY" : Gosub ADDCLB
     When 10 : LIGNE= "Local Clbfile WEMPTY" : Gosub ADDCLB
    Endcase
    #---
    LIGNE = "Local Char WCNT(100),WATYP(GLONATYP)" : Gosub ADDCLB
    LIGNE = "Local Integer ASTATUS" : Gosub ADDCLB
    Read [ATB]CODFIC = ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).LOBTAB
    WCAS=0
    WCODCNT=""
    WCODZONE=""
    If ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).LOBCNT<>""
      WCODCNT=ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).LOBCNT
    Else
     For [ATZ] Where CODFIC=ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).LOBTAB and CODTYP="ATYP"
      WCODCNT=[F:ATZ]CODZONE
      Break
     Next
    Endif
    For [ATZ] Where CODFIC=ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).LOBTAB and CODTYP="AT"
     WCAS=1
     WCODZONE=[F:ATZ]CODZONE
     Break
    Next
    If WCAS=0
     For [ATZ] Where CODFIC=ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).LOBTAB and CODTYP="ADI" and find(CODZONE,"TYPDOC","TYPJOI")<>0
      WCAS=2
      WCODZONE=[F:ATZ]CODZONE
      Break
     Next
    Endif
    Read [ATI]NUMLIG = ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).LOBTAB;1
    Call GET_INDEX([L]DOSSIER,ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).LOBTAB,1,NBKEY,KEYVAL,KEYTYP) From ACLASUB
     If !ISINFILE : LIGNE = "Local File "+[ATB]CODFIC+" [F:"+[ATB]ABRFIC+"]" : Gosub ADDCLB : Endif
    LIGNE = "If "+WCLASSE+".ASTALIN=[V]CST_ANEW & [L]WEMPTY<>[L]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA :  Gosub ADDCLB
    DIF += 1
    If !ISINFILE
     LIGNE =  "Raz ["+[ATB]ABRFIC+"]": Gosub ADDCLB
     LIGNE = "Call INICRE("+WCLASSE+") From ASYRSUB" : Gosub ADDCLB
     For II=1 To NBKEY
      For JJ=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATBKEY)
       If KEYVAL(II)= ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATBKEY(JJ).CODPAR
        LIGNE =   "[F:"+[ATB]ABRFIC+"]"+KEYVAL(II)-"="-func ACLAVALTRT.EVAL_VALEUR(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATBKEY(JJ).VALEUR,ACLA,WCLASSE)
        NK = instr(1,toupper(LIGNE),"THIS.")
        If NK
         LIGNE = left$(LIGNE,NK-1)+WCLASSE+"."+right$(LIGNE,NK+5)
        Endif
        Gosub ADDCLB
       Endif
      Next
     Next
    Endif
    LIGNE =  "[F:"+[ATB]ABRFIC+"]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).LOBFLD+" = [L]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA: Gosub ADDCLB
    If ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.PROPREFLG=2
     LIGNE = '[L]WCNT=fmet '+WCLASSE+'.AGETATTRIBUTE("'+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA+'","$contentType")' :  Gosub ADDCLB
     LIGNE = "If [L]WCNT<>''":  Gosub ADDCLB
     DIF += 1
     LIGNE =  "[L]WATYP = func ASYRLOB.F_CNTTYP_TO_ATYP("+num$(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.TYPTYP)+",'',[L]WCNT)" : Gosub ADDCLB
     DIF -=1
     LIGNE = "Else":  Gosub ADDCLB
     DIF += 1
     LIGNE =  "[L]WATYP = '"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.TYPPROSYR+"'": Gosub ADDCLB
     LIGNE =  "[L]WCNT = '"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.PROTYP+"'": Gosub ADDCLB
     DIF -=1
     LIGNE = "Endif":  Gosub ADDCLB
    Else
     LIGNE =  "[L]WATYP = '"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.TYPPROSYR+"'": Gosub ADDCLB
     LIGNE =  "[L]WCNT = '"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.PROTYP+"'": Gosub ADDCLB
    Endif
    If WCODCNT<>""
     LIGNE =  "[F:"+[ATB]ABRFIC+"]"+WCODCNT+" = [L]WATYP": Gosub ADDCLB
    Endif
    If WCAS=1
     LIGNE =  "[F:"+[ATB]ABRFIC+"]"+WCODZONE+" = func ASYRLOB.F_CNTTYP_TO_AML7806([L]WCNT)": Gosub ADDCLB
    Elsif WCAS=2
     LIGNE = "Local Char WFILENAME(250)" : Gosub ADDCLB
     LIGNE = '[L]WFILENAME=fmet '+WCLASSE+'.AGETATTRIBUTE("'+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA+'","$filename")' :  Gosub ADDCLB
     LIGNE =  "[F:"+[ATB]ABRFIC+"]"+WCODZONE+" = func ASYRLOB.F_CNTTYP_TO_ADI902("+num$(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.TYPTYP)+",'',[L]WFILENAME)": Gosub ADDCLB
    Endif
    If !ISINFILE
     LIGNE =  "Write [F:"+[ATB]ABRFIC+"]": Gosub ADDCLB
     Gosub ERREUR_FSTA
     DIF -=1
     LIGNE = "Elsif "+WCLASSE+".ASTALIN=[V]CST_ADEL":  Gosub ADDCLB
     DIF +=1
     LIGNE = "Read [F:"+[ATB]ABRFIC+"]"+[ATI]CODIND+" ="
     Raz NK
     For II=1 To NBKEY
      For JJ=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATBKEY)
       If KEYVAL(II)= ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATBKEY(JJ).CODPAR
       NK += 1
       If NK>1 : LIGNE += ';' : Endif
        LIGNE += func ACLAVALTRT.EVAL_VALEUR(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATBKEY(JJ).VALEUR,ACLA,WCLASSE)
       Endif
      Next
     Next
     NK = instr(1,toupper(LIGNE),"THIS.")
     If NK
      LIGNE = left$(LIGNE,NK-1)+WCLASSE+"."+right$(LIGNE,NK+5)
     Endif
     Gosub ADDCLB
     LIGNE =  "If !fstat": Gosub ADDCLB
     DIF +=1
     LIGNE = "Delete [F:"+[ATB]ABRFIC+"]" : Gosub ADDCLB
     Gosub ERREUR_FSTA
     DIF -= 1
     LIGNE = "Endif" : Gosub ADDCLB
    Endif
    DIF -=1
    LIGNE = "Elsif "+WCLASSE+".ASTALIN=[V]CST_ALL or "+WCLASSE+".ASTALIN=[V]CST_AUPD" :  Gosub ADDCLB
    DIF += 1
    LIGNE = 'If fmet '+WCLASSE+'.AGETATTRIBUTE("'+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA+'","$isLoaded")="true"' :  Gosub ADDCLB
    DIF += 1
    If !ISINFILE
     LIGNE = "Read [F:"+[ATB]ABRFIC+"]"+[ATI]CODIND+" ="
     Raz NK
     For II=1 To NBKEY
      For JJ=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATBKEY)
       If KEYVAL(II)= ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATBKEY(JJ).CODPAR
       NK += 1
       If NK>1 : LIGNE += ';' : Endif
        LIGNE += func ACLAVALTRT.EVAL_VALEUR(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATBKEY(JJ).VALEUR,ACLA,WCLASSE)
       Endif
      Next
     Next
     NK = instr(1,toupper(LIGNE),"THIS.")
     If NK
      LIGNE = left$(LIGNE,NK-1)+WCLASSE+"."+right$(LIGNE,NK+5)
     Endif
     Gosub ADDCLB
     LIGNE =  "If !fstat & [L]WEMPTY<>[L]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA : Gosub ADDCLB
    Else
     LIGNE =  "If [L]WEMPTY<>[L]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA : Gosub ADDCLB
    Endif
    DIF +=1
    If !ISINFILE : LIGNE = "Call INIUPD("+WCLASSE+") From ASYRSUB" : Gosub ADDCLB : Endif
    LIGNE =  "[F:"+[ATB]ABRFIC+"]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).LOBFLD+" = [L]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA: Gosub ADDCLB
    If ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.PROPREFLG=2
     LIGNE = '[L]WCNT=fmet '+WCLASSE+'.AGETATTRIBUTE("'+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA+'","$contentType")' :  Gosub ADDCLB
     LIGNE = "If [L]WCNT<>''":  Gosub ADDCLB
     DIF += 1
     LIGNE =  "[L]WATYP = func ASYRLOB.F_CNTTYP_TO_ATYP("+num$(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.TYPTYP)+",'',[L]WCNT)" : Gosub ADDCLB
     DIF -=1
     LIGNE = "Else":  Gosub ADDCLB
     DIF += 1
     LIGNE =  "[L]WATYP = '"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.TYPPROSYR+"'": Gosub ADDCLB
     LIGNE =  "[L]WCNT = '"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.PROTYP+"'": Gosub ADDCLB
     DIF -=1
     LIGNE = "Endif":  Gosub ADDCLB
    Else
     LIGNE =  "[L]WATYP = '"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.TYPPROSYR+"'": Gosub ADDCLB
     LIGNE =  "[L]WCNT = '"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.PROTYP+"'": Gosub ADDCLB
    Endif
    If WCODCNT<>""
     LIGNE =  "[F:"+[ATB]ABRFIC+"]"+WCODCNT+" = [L]WATYP": Gosub ADDCLB
    Endif
    If WCAS=1
     LIGNE =  "[F:"+[ATB]ABRFIC+"]"+WCODZONE+" = func ASYRLOB.F_CNTTYP_TO_AML7806([L]WCNT)": Gosub ADDCLB
    Elsif WCAS=2
     LIGNE = "Local Char WFILENAME(250)" : Gosub ADDCLB
     LIGNE = '[L]WFILENAME=fmet '+WCLASSE+'.AGETATTRIBUTE("'+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA+'","$filename")' :  Gosub ADDCLB
     LIGNE =  "[F:"+[ATB]ABRFIC+"]"+WCODZONE+" = func ASYRLOB.F_CNTTYP_TO_ADI902("+num$(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.TYPTYP)+",'',[L]WFILENAME)": Gosub ADDCLB
    Endif
    If !ISINFILE
     LIGNE = "Rewrite [F:"+[ATB]ABRFIC+"]" : Gosub ADDCLB
     Gosub ERREUR_FSTA
     DIF -=1
     LIGNE =  "Elsif !fstat & [L]WEMPTY=[L]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA : Gosub ADDCLB
     DIF += 1
     LIGNE = "Delete [F:"+[ATB]ABRFIC+"]" : Gosub ADDCLB
     Gosub ERREUR_FSTA
     DIF -=1
     LIGNE =  "Elsif fstat & [L]WEMPTY<>[L]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA : Gosub ADDCLB
     DIF += 1
     LIGNE =  "Raz ["+[ATB]ABRFIC+"]": Gosub ADDCLB
     LIGNE = "Call INICRE("+WCLASSE+") From ASYRSUB" : Gosub ADDCLB
     For II=1 To NBKEY
      For JJ=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATBKEY)
       If KEYVAL(II)= ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATBKEY(JJ).CODPAR
        LIGNE =   "["+[ATB]ABRFIC+"]"+KEYVAL(II)-"="-func ACLAVALTRT.EVAL_VALEUR(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATBKEY(JJ).VALEUR,ACLA,WCLASSE)
        NK = instr(1,toupper(LIGNE),"THIS.")
        If NK
         LIGNE = left$(LIGNE,NK-1)+WCLASSE+"."+right$(LIGNE,NK+5)
        Endif
        Gosub ADDCLB
       Endif
      Next
     Next
     LIGNE =  "[F:"+[ATB]ABRFIC+"]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).LOBFLD+" = [L]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA: Gosub ADDCLB
     If ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.PROPREFLG=2
      LIGNE = '[L]WCNT=fmet '+WCLASSE+'.AGETATTRIBUTE("'+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA+'","$contentType")' :  Gosub ADDCLB
      LIGNE = "If [L]WCNT<>''":  Gosub ADDCLB
      DIF += 1
      LIGNE =  "[L]WATYP = func ASYRLOB.F_CNTTYP_TO_ATYP("+num$(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.TYPTYP)+",'',[L]WCNT)" : Gosub ADDCLB
      DIF -=1
      LIGNE = "Else":  Gosub ADDCLB
      DIF += 1
      LIGNE =  "[L]WATYP = '"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.TYPPROSYR+"'": Gosub ADDCLB
      LIGNE =  "[L]WCNT = '"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.PROTYP+"'": Gosub ADDCLB
      DIF -=1
      LIGNE = "Endif":  Gosub ADDCLB
     Else
      LIGNE =  "[L]WATYP = '"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.TYPPROSYR+"'": Gosub ADDCLB
      LIGNE =  "[L]WCNT = '"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.PROTYP+"'": Gosub ADDCLB
     Endif
     If WCODCNT<>""
      LIGNE =  "[F:"+[ATB]ABRFIC+"]"+WCODCNT+" = [L]WATYP": Gosub ADDCLB
     Endif
     If WCAS=1
      LIGNE =  "[F:"+[ATB]ABRFIC+"]"+WCODZONE+" = func ASYRLOB.F_CNTTYP_TO_AML7806([L]WCNT)": Gosub ADDCLB
     Elsif WCAS=2
      LIGNE = "Local Char WFILENAME(250)" : Gosub ADDCLB
      LIGNE = '[L]WFILENAME=fmet '+WCLASSE+'.AGETATTRIBUTE("'+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).FLDCLA+'","$filename")' :  Gosub ADDCLB
      LIGNE =  "[F:"+[ATB]ABRFIC+"]"+WCODZONE+" = func ASYRLOB.F_CNTTYP_TO_ADI902("+num$(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(J).ATY.TYPTYP)+",'',[L]WFILENAME)": Gosub ADDCLB
     Endif
     LIGNE =  "Write [F:"+[ATB]ABRFIC+"]": Gosub ADDCLB
     Gosub ERREUR_FSTA
    Endif
    DIF -=1
    LIGNE =  "Endif": Gosub ADDCLB
    DIF -=1
    LIGNE =  "Endif : #isLoaded": Gosub ADDCLB
    DIF -=1
    LIGNE =  "Endif : #[V]CST_AUPD ": Gosub ADDCLB
    If !ISINFILE : LIGNE =  "Close Local File [F:"+[ATB]ABRFIC+"]" : Gosub ADDCLB : Endif
    LIGNE =  "End 0" :  Gosub ADDCLB
    LIGNE =  "" : Gosub ADDCLB
   Endif
  Next
 Endif
Next
Return

#-------------------------------------------------------#
# ERREUR_FSTA
#-------------------------------------------------------#
$ERREUR_FSTA
LIGNE = "If fstat" : Gosub ADDCLB
DIF += 1
LIGNE = 'Call FSTA("'+ACLA.ACLAK(NIVEAU).ABRLNK+'",'+[L]WCLASSE+',[L]ASTATUS) From ASYRSUB'
If PROGRAM<>""
 If   ISFOR   : LIGNE += ' : Break'-string$(NBFOR>1,num$(NBFOR))
 Else          : LIGNE += ' : Return'
 Endif
Else
 Gosub ADDCLB
 LIGNE = "End [L]ASTATUS"
Endif
Gosub ADDCLB
DIF -= 1 : LIGNE =  "Endif" : Gosub ADDCLB
Return

#-------------------------------------------------------#
# managment tagging objects
#------------------------------------------------------#
Subprog MAJXCB(ACLAK,WCLASSE,PROGRAM,LNKOBJ,TYPOBJ,NBTYP,DOSSIER,LIGNE,DIF,CLOB)
Variable Instance ACLAK Using OBJECT
Value Char WCLASSE
Value Char PROGRAM
Value Char LNKOBJ
Value Char TYPOBJ()(1..)
Value Integer NBTYP
Value Char DOSSIER
Variable Char LIGNE
Variable Integer DIF
Variable Clbfile CLOB
If PROGRAM<>"" & LNKOBJ<>"" &  find(LNKOBJ,TYPOBJ(1..NBTYP))>0 & (filinfo(filpath("","sophia_gaillard","",DOSSIER),0)>0) & filinfo(filpath("FIL","XXCORT","fde",DOSSIER),0)>0
 LIGNE = 'Local Char _ATABKEY(250)(1..16)'  : Gosub ADDCLB
 For I=1 To ACLAK.NBRIND
  LIGNE = '[L]_ATABKEY('+num$(I)+') = '
  If ACLAK.TYPIND(I)<>[V]CST_ATYPCHAR : LIGNE += 'num$(' : Endif
  LIGNE += '[F:'+ACLAK.ABRLNK+"]"+ACLAK.INDEX(I)
  If ACLAK.TYPIND(I)<>[V]CST_ATYPCHAR : LIGNE +=')'   : Endif
 Gosub ADDCLB
 Next I
 LIGNE = 'If func  ASYRXCB.ACREATE_TAG('+WCLASSE+',"'+LNKOBJ+'",[L]_ATABKEY,'
 Case PROGRAM
  When "AINSERT" : LIGNE   += '"C"'
  When "AUPDATE" : LIGNE  += '"M"'
  When "ADELETE" : LIGNE   += '"A"'
 Endcase
 LIGNE += ')=[V]CST_AFALSE'  : Gosub ADDCLB
 DIF +=1
 LIGNE = 'End [V]CST_AERROR'  : Gosub ADDCLB
 DIF -=1
 LIGNE = 'Endif' : Gosub ADDCLB
Endif
End

#-------------------------------------------------------#
# MAJSQLCOL
#-------------------------------------------------------#
$MAJSQLCOL
Local Integer OKCOL
For I=1 To ACLA.ACLAK(NIVEAU).ACLALNK.NBRGRP
 If ACLA.ACLAK(NIVEAU).ACLALNK.CRECLAGRP(I)=2
  If ACLA.ACLAK(NIVEAU).ACLALNK.MAXGRP(I)=0
   K=0
   For M=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF)
    If  ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).LNKCLA="" & ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).FLDGRP=ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)
     Read [F:ATZ]CODZONE = ACLA.ACLAK(NIVEAU).TABLNK;ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).FLDCLA
     If !fstat
      K=1
      LIGNE = "For [L]A_J=1 to dim("+"[F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).FLDCLA+")" : Gosub ADDCLB
      ISFOR = 1 : NBFOR +=1
      Break
     Endif
    Endif
   Next
   If !K
    LIGNE = "For [L]A_J=1 To maxtab("+WCLASSE+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+")" : Gosub ADDCLB
    ISFOR = 1 : NBFOR +=1
   Endif
  Else
   LIGNE = "For [L]A_J=1 to "+num$(ACLA.ACLAK(NIVEAU).ACLALNK.MAXGRP(I)) : Gosub ADDCLB
   ISFOR = 1 : NBFOR +=1
  Endif
  DIF += 1
  LIGNE = "For [L]A_I=1 To maxtab("+WCLASSE+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+")" : Gosub ADDCLB
  ISFOR = 1 : NBFOR +=1
  DIF += 1
  LIGNE = "If "+WCLASSE+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+"([L]A_I)<>null & !find("+WCLASSE+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)
  LIGNE += "([L]A_I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)"
  LIGNE += " & "+WCLASSE+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+"([L]A_I).AORDER=[L]A_J"
  Gosub ADDCLB
  DIF += 1
  For M=1 To maxtab(ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF)
   If  ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).LNKCLA="" & ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).FLDGRP=ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)
    Read [F:ATZ]CODZONE = ACLA.ACLAK(NIVEAU).TABLNK;ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).FLDCLA
    If !fstat and !find([F:ATZ]CODTYP,"AXX","AX1","AX2","AX3")
     LIGNE = "[F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"+ACLA.ACLAK(NIVEAU).ACLALNK.ACLAF(M).FLDCLA+"([L]A_J-1) = "+WCLASSE+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+"([L]A_I)."+ACLA.ACLAK(NIVEAU).ACLALNK.
& ACLAF(M).FLDCLA :  Gosub ADDCLB
    Endif
   Endif
  Next
  Call TRT_TEXTECOL(ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I),ACLA,NIVEAU,[V]CST_APRGAINSERT,WCLASSE+"."+ACLA.ACLAK(NIVEAU).ACLALNK.CODGRP(I)+"([L]A_I)",ISFOR,NBFOR,LIGNE,CLOB,DIF) From ACLATXTCRUD
  LIGNE = "Break" : Gosub ADDCLB
  DIF -= 1
  LIGNE = "Endif" : Gosub ADDCLB
  DIF -= 1
  LIGNE = "Next" : Gosub ADDCLB
  DIF -= 1
  LIGNE = "Next" : Gosub ADDCLB
  ISFOR =0  : NBFOR = 0
  LIGNE = "If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif" : Gosub ADDCLB
 Endif
Next
Return

#-------------------------------------------------------#
#TR_BEGIN
#-------------------------------------------------------#
$TR_BEGIN
LIGNE = "#-----------------------------------------------------#"  : Gosub ADDCLB
LIGNE = "$"+PROGRAM+"_TR_"+[L]ROOTNAM  : Gosub ADDCLB
If ACLA.FLGTR=2
 If ACLA.TYPCLA=2
  LIGNE = "Trbegin [F:"+ACLA.ACLAK(NIVEAU).ABRLNK+"]"  : Gosub ADDCLB
 Elsif ACLA.TYPCLA=5
  LIGNE = "Trbegin [F:__INT]"  : Gosub ADDCLB
 Endif
 DIF += 1
Endif
LIGNE = "Gosub "+PROGRAM+"_"+[L]ROOTNAM   : Gosub ADDCLB
LIGNE = "If [L]ASTATUS>=[V]CST_AERROR : Gosub "+PROGRAM+"_ABORT : Return : Endif"  : Gosub ADDCLB
If ACLA.FLGTR=2
 DIF -= 1
 LIGNE = "Commit"   : Gosub ADDCLB
Endif
LIGNE = "Return"   : Gosub ADDCLB
LIGNE = ""   : Gosub ADDCLB
LIGNE = "#-----------------------------------------------------#" : Gosub ADDCLB
Return

