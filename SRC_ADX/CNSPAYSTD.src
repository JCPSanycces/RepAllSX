#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(12)(1..9)
Call GCONSULT("PAY","",PARAM) From GCONSULT
End

$ACTION
Case ACTION
 When "AUTORIS"    : Gosub AUTORIS
 When "OUVRE"      : Gosub OUVRE
 When "FERME"      : Gosub FERME
 When "LECTURE"    : Gosub LECTURE
 When "AB1_NBLIG"  : Gosub AB1_NBLIG
 When "AB2_NBLIG"  : Gosub AB2_NBLIG
 When "BB1_NBLIG"  : Gosub BB_NBLIG
 When "BB2_NBLIG"  : Gosub BB_NBLIG
 When "SEL_TABLE"  : Gosub SEL_TABLE
Endcase
Return

##################################################################
$AUTORIS
Local Libelle OTUNCPT
OTUNCPT=GTUNCPT(11)
If GTUNCPT(11)
 Call MESSAGE(mess(247,199,1)) From GESECRAN : OK=0
 # Une même fonction ne peut pas être appelée deux fois !
Else
 GTUNCPT(11) = 1 
Endif

If PARAM(1)<>"" & PARAM(5)<>""
 Local Char WCOA(GLONCOA)
If PARAM(4)<>""
 Call GETSOC(PARAM(4)) From DEVSUB
Else
 Call LEC_CPY(PARAM(5)) From CPTLEC
 Call GETSOC([F:CPY]MAIFCY) From DEVSUB
 Endif
 Call LECPLAN(PARAM(5),GTYPGEN,WCOA) From CPTDIV
 If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
 Read [GAC]GAC1 = WCOA;PARAM(1)
 If !fstat & [F:GAC]SAC=2 & [F:GAC]ACS<>""
  Local Integer DROIT
  Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
  If !DROIT : Call MESSAGE(mess(4,104,1)) From GESECRAN : OK=0  :  Endif   # "Vous n'avez pas les droits pour ce code"
 Endif
Endif
Return

##################################################################
$FERME
If dim(OTUNCPT)>0 : GTUNCPT(11) = OTUNCPT : Endif
Return

##################################################################
$OUVRE

# Variables pour effectur le filtre
Local Char FILTPAY(250)(1..4)
Local Integer IFILT : IFILT=1 # Initialiser à 1 pour le CRITERE de SEL_TABLE.
Local Char DNUM(GLONVCR), FNUM(GLONVCR)
Local Integer DLIN(3), FLIN(3)
Local Char ORDPAY, MESSAGE(80)
Local Integer FLAG  : Raz FLAG # Utiliser pour le filtre direct ou via SEL_TABLE

# Site, regroupement de sites
Local Integer NBSITE
NBSITE = max(1,GNBSITE)
Local Char    TSITE(GLONFCY)(1..NBSITE)
NBSITE = 0

# Divers
Local Integer I,J
Local Date    DEBDAT, FINDAT
Local Libelle GRP
Local Integer DROIT, CTLACS

Gosub DEFCRIT

# Préchargement
CHARGMT=1

Return 

##################################################################
$DEFCRIT
# Paramètres, il faut faire attention à ce que les paramètres restent cohérents entre eux

If [M:CPA1]FCY<>"" & GUSRFCY(1)<>"\" & !find([M:CPA1]FCY,GUSRFCY(1..GNBAUZ))
 [M:CPA1]FCY=""
Endif

DEBDAT=[M:CPA1]DATDEB
FINDAT=[M:CPA1]DATFIN

For I=1 To dim(PARAM)
 Case I
  When 1 : # Collectif
   If PARAM(I)<>"" & [M:CPA1]COA<>""
    Call LECTURE("GAC",PARAM(I),[M:CPA1]COA) From CONTOBJ
    If !fstat & [F:GAC]SAC=2 : [M:CPA1]COLLEC = PARAM(I) : Endif
   Endif
  When 2: # Tiers Facturé
   If PARAM(I)<>"" 
    Call LECTURE("BPR",PARAM(I),"") From CONTOBJ
    If !fstat : [M:CPA1]BPR = PARAM(I) : Endif
   Endif
  When 3: # Tiers Payeur
   If PARAM(I)<>"" 
    Call LECTURE("BPR",PARAM(I),"") From CONTOBJ
    If !fstat : [M:CPA1]BPRPAY = PARAM(I) : Endif
   Endif
  When 4: # Site
   If PARAM(I)<>""
    Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
    If !fstat & (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
     [M:CPA1]FCY = PARAM(I)
     [M:CPA1]CPY = [F:FCY]LEGCPY
     PARAM(5)=""
    Endif
   Endif 
  When 5 : # Société
   If PARAM(I)<>""
    Call LECTURE("CPY",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:CPA1]CPY = PARAM(I)
     If [M:CPA1]FCY<>""
      Call LECTURE("FCY",[M:CPA1]FCY,"") From CONTOBJ
      If [F:FCY]LEGCPY<>[M:CPA1]CPY : [M:CPA1]FCY="" : Endif
     Endif
    Endif
   Endif
  When 6 : # Date début
   If PARAM(I)<>""  & PARAM(I)<>[0/0/0]
    If instr(1,PARAM(I),"/")
     [M:CPA1]DATDEB = "["+PARAM(I)+"]"
    Elsif PARAM(I)<>""
     [M:CPA1]DATDEB = PARAM(I)
    Endif    
   Endif
  When 7 : # Date fin
   If PARAM(I)<>""  & PARAM(I)<>[0/0/0]
    If instr(1,PARAM(I),"/")
     [M:CPA1]DATFIN = "["+PARAM(I)+"]"
    Elsif PARAM(I)<>""
     [M:CPA1]DATFIN = PARAM(I)
    Endif
   Endif
  When 8 : # Règlement début
   If PARAM(I)<>""
    Call LECTURE("PAY",PARAM(I),"") From CONTOBJ
    If !fstat : [M:CPA1]REGDEB = PARAM(I) : Endif
   Endif
  When 9 : # Règlement fin
   If PARAM(I)<>""
    Call LECTURE("PAY",PARAM(I),"") From CONTOBJ
    If !fstat : [M:CPA1]REGFIN = PARAM(I) : Endif
   Endif
  When 10 : # Facture début
   If PARAM(I)<>""
    [M:CPA1]FACDEB = PARAM(I)
   Endif
  When 11 : # Facture fin
   If PARAM(I)<>""
    [M:CPA1]FACFIN = PARAM(I)
   Endif
  When 12 : # Code écran
   If PARAM(I)<>""
    Call VERFGTC("PAY",PARAM(I),[M:CPAY]ECRAN,MESSAGE,OK) From GCONSULT
    If OK : [M:CPAY]ECRAN = PARAM(I) : Endif
   Endif
  When 13 : Break
 Endcase
Next I

# Valeurs par défaut
Default Mask [CPA1]
Call INIT(DEBDAT,FINDAT) From CONSSUB
If [M]CPY="" : [M]CPY = GDEFSOC : Endif 
If [M]FCY<>""
 Call GETSOC([M]FCY) From DEVSUB
Else
 Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
 Call GETSOC([F:CPY]MAIFCY) From DEVSUB
Endif
[M]LEDTYP=GTYPGEN
Call LECPLAN([M]CPY,[M]LEDTYP,[M:CPA1]COA) From CPTDIV
If PARAM(1)<>"" & [M:CPA1]COA<>""
 Read [GAC]GAC1 = [M:CPA1]COA;PARAM(1)
 If !fstat & [F:GAC]SAC=2 : [M:CPA1]COLLEC = PARAM(1) : Else Raz [M:CPA1]COLLEC : Endif
Endif

# Initialisation de la fenetre critère
If [M:CPAY]ACPT = 0 : [M:CPAY]ACPT = 1 : Endif
If [M:CPAY]STA  = 0 : [M:CPAY]STA  = 2 : Endif

# Si je viens de la consultation des factures (via tunnel)
If GTUNCPT(12)=1
 Raz [M:CPAY]CUR, [M:CPAY]PAM, [M:CPAY]BAN, [M:CPAY]CHQNUM
Endif

Gosub CRITENT From =PROGCNS
Return


##################################################################
$LECTURE
# Changement d'écran ?
Gosub CHANGE_MSK From GCONSULT 
If CHGPAG<0 : NOL = MAXLIG : Endif

If [M:CPA1]CPY="" or [M:CPA1]DATDEB=[0/0/0] or [M:CPA1]DATFIN=[0/0/0]
 NBLU=0 : Return
Endif

# Chargement du tableau
Gosub INIT
Gosub FILTRE

If PROGSPE<>"" :  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE : Endif

If CHGPAG>0
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
 ORDPAY = "NUM Asc ; LIN Asc"
Else
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
 ORDPAY = "NUM Desc ; LIN Desc"
Endif
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CPA2] : Endif

Link [PYD] With [PYH]PYH0=[F:PYD]NUM  
&          As [LNK]
&          Where evalue(FILTPAY)
&          Order With ORDPAY

CTLACS = 1
For [LNK]
 OK = 1
 If [F:GAC]COA<>[M]COA | [F:GAC]ACCSHO<>[F:PYH]BPRSAC
  Read [GAC]GAC1 = [M]COA;[F:PYH]BPRSAC
 Endif
 If [F:GAC]SAC=2 & [F:GAC]ACS<>""
  Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
  If !DROIT : CTLACS = 0 : OK = 0 : Endif
 Endif

 If OK
  If NBLU=1 # Toute 1er lecture
   If CHGPAG=2 or CHGPAG=-2 : Raz [M:CPA2] : Endif
   NBLU=2
  Endif

  # Sauvegarde les bornes de clés pour les lectures
  If CHGPAG>0 # Lecture ascendante
   If NOL>=MAXLIG-1 : SUITE=2 : Break : Endif
   NOL += 1
   If NOL= 0 
    DNUM = [F:PYD]NUM
    DLIN = [F:PYD]LIN
   Endif
   FNUM = [F:PYD]NUM
   FLIN = [F:PYD]LIN
  Else    # Lecture descendante
   If NOL<=0 : RETOUR = 2 : Break : Endif
   NOL -= 1
   If NOL=MAXLIG-1
    FNUM = [F:PYD]NUM
    FLIN = [F:PYD]LIN
   Endif
   DNUM = [F:PYD]NUM
   DLIN = [F:PYD]LIN
  Endif

  # Chargement du tableau
  nolign = NOL+1

  # Informations sur le règlement
  [M:CPA2] = [F:PYH]
  [M:CPA2] = [F:PYD]

  # Informations sur l'échéance
  Read [DUD]DUD1 = [F:PYD]DUDNUM;[F:PYD]DUDLIG
  If !fstat
   [M:CPA2]SOINUM(nolign-1)    = [F:DUD]SOINUM
   [M:CPA2]DUDDATFAC(nolign-1) = [F:DUD]DUDDAT
    
   [M:CPA2]DUDAMTCUR(nolign-1) = [F:DUD]AMTCUR
   [M:CPA2]DUDCUR(nolign-1)    = [F:DUD]CUR

   # Identifier l'échéance
   [M:CPA2]ACCNUM(nolign-1)    = [F:DUD]ACCNUM
   [M:CPA2]DUDLIG(nolign-1)    = [F:DUD]DUDLIG

   # Informations sur la facture
   Read [F:SIH]SIH2 = [F:DUD]TYP;[F:DUD]NUM
   If !fstat 
    [M:CPA2]ACCDATFAC(nolign-1) = [F:SIH]ACCDAT
    [M:CPA2]BPRVCR(nolign-1)    = [F:SIH]BPRVCR
   Elsif fstat=5
    Read [F:PIH]PIH2 = [F:DUD]TYP;[F:DUD]NUM
    If !fstat        
     [M:CPA2]ACCDATFAC(nolign-1) = [F:PIH]ACCDAT
     [M:CPA2]BPRVCR(nolign-1)    = [F:PIH]BPRVCR
    Endif
   Endif
   # Colorise les règlements temporaires
   If [F:DUD]PAYCUR=[F:DUD]AMTCUR    
    [M:CPA2]COLOR(nolign-1)=1
   Else
    [M:CPA2]COLOR(nolign-1)=0
   Endif
  Else
   [M:CPA2]COLOR(nolign-1)=1
  Endif
 Endif
Next
If !CTLACS
 Call MESSAGE(mess(55,109,1)) From GESECRAN
 # Vos résultats sont restreints à vos droits utilisateurs
Endif
Return


##################################################################
$INIT
Call LECTURE("CPY",[M:CPA1]CPY,"") From CONTOBJ
GRP=([F:CPY]CPYLEGFLG=1)

If GRP
 NBSITE = 0 
 For [FGR]FGR0 Where CPY = [M:CPA1]CPY
  Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
  NBSITE+=1
  TSITE(NBSITE) = [F:FGR]FCY
Next : # [FGR]
Endif

Return

##################################################################
$FILTRE
Raz FILTPAY,IFILT

# Collectif et groupe de collectif
If [M:CPA1]COLLEC<>""
  Call ADDCRIT(FILTPAY, IFILT,"COLLEC",'[F:PYH]BPRSAC="'+[M:CPA1]COLLEC+'"'," & ") From GOBJSUB
Elsif [M:CPA1]GROUPE<>""
  Call ADDCRIT(FILTPAY, IFILT,"COLLEC",'find([F:PYH]BPRSAC',"&") From GOBJSUB
  Filter [GSC] Where [F:GSC]COA=[M]COA & [F:GSC]GRU=[M:CPA1]GROUPE
  For [GSC]
    Call ADDCRIT(FILTPAY, IFILT,"GROUPE",'"'+[F:GSC]SAC+'"',",") From GOBJSUB
  Next
  Filter [GSC]
  Call ADDCRIT(FILTPAY, IFILT,"GROUPE",')',"") From GOBJSUB
Endif

# Tiers facturé
If [M:CPA1]BPR<>""
  Call ADDCRIT(FILTPAY, IFILT,"BPR",'[F:PYD]BPRINV="'+[M:CPA1]BPR+'"'," & ") From GOBJSUB
Endif

# Tiers payeur
If [M:CPA1]BPRPAY<>""
  Call ADDCRIT(FILTPAY, IFILT,"BPRPAY",'[F:PYH]BPR="'+[M:CPA1]BPRPAY+'"'," & ") From GOBJSUB
Endif

# Société & Site
If !GRP
 Call ADDCRIT(FILTPAY, IFILT,"CPY",'[F:PYH]CPY="'+[M:CPA1]CPY+'"'," & ") From GOBJSUB
 If [M:CPA1]FCY<>""
  Call ADDCRIT(FILTPAY, IFILT,"FCY",'[F:PYH]FCY="'+[M:CPA1]FCY+'"'," & ") From GOBJSUB
 Endif
Else
 # Groupement de sites
 Call ADDCRIT(FILTPAY, IFILT,"FCY",'find([F:PYH]FCY,TSITE(1..NBSITE))'," & ") From GOBJSUB
Endif

# Autorisation site
If GUSRFCY(1)<>"\" & ([M:CPA1]FCY<>"" | GRP) & GNBAUZ<>GNBSITE
 Call ADDCRIT(FILTPAY, IFILT,"FCY",'find([F:PYH]FCY,GUSRFCY(1..GNBAUZ))'," & ") From GOBJSUB
Endif

# Dates
If [M:CPA1]DATDEB<>[0/0/0]
 Call ADDCRIT(FILTPAY, IFILT,"DATDEB",'[F:PYH]ACCDAT>=['+format$(GFMD,[M:CPA1]DATDEB)+']'," & ") From GOBJSUB
Endif
If [M:CPA1]DATFIN<>[0/0/0]
 Call ADDCRIT(FILTPAY, IFILT,"DATDEB",'[F:PYH]ACCDAT<=['+format$(GFMD,[M:CPA1]DATFIN)+']'," & ") From GOBJSUB
Endif

# Règlement 
If [M:CPA1]REGDEB<>"" & !FLAG
 Call ADDCRIT(FILTPAY, IFILT,"REGDEB",'[F:PYH]NUM>="'+[M:CPA1]REGDEB+'"'," & ") From GOBJSUB
Endif
If [M:CPA1]REGFIN<>"" & !FLAG
 Call ADDCRIT(FILTPAY, IFILT,"REGFIN",'[F:PYH]NUM<="'+[M:CPA1]REGFIN+'"'," & ") From GOBJSUB
Endif

# Facture
If [M:CPA1]FACDEB<>""
 Call ADDCRIT(FILTPAY, IFILT,"FACDEB",'[F:PYD]VCRNUM>="'+[M:CPA1]FACDEB+'"'," & ") From GOBJSUB
Endif
If [M:CPA1]FACFIN<>""
 Call ADDCRIT(FILTPAY, IFILT,"FACFIN",'[F:PYD]VCRNUM<="'+[M:CPA1]FACFIN+'"'," & ") From GOBJSUB
Endif

# On s'intérresse uniquement aux lignes imputés de règlements.
Call ADDCRIT(FILTPAY, IFILT,"AMTLIN",'num$([F:PYD]AMTLIN)="0"'," & ( ") From GOBJSUB
Call ADDCRIT(FILTPAY, IFILT,"AMTLIN",'num$([F:PYD]AMTLIN)<>"0"'," | (") From GOBJSUB
Call ADDCRIT(FILTPAY, IFILT,"AMTLIN2)",'num$([F:PYD]AMTLIN2)<>"0"'," & ") From GOBJSUB
Call ADDCRIT(FILTPAY, IFILT,"AMTLIN2",'))',"") From GOBJSUB

# Filtre sur le masque des critères...
########################################
# Devise
If [M:CPAY]CUR<>"" 
    Call ADDCRIT(FILTPAY, IFILT,"CUR",'[F:PYH]CUR="'+[M:CPAY]CUR+'"'," & ") From GOBJSUB
Endif

# Acomptes uniquement
If [M:CPAY]ACPT = 2
    Call ADDCRIT(FILTPAY, IFILT,"ACPT",'[F:PYD]VCRNUM=""'," & ") From GOBJSUB
Endif
 
# Inclure les règlements provisoires
If [M:CPAY]STA <> 2
    Call ADDCRIT(FILTPAY, IFILT,"STA",'[F:PYH]STA>=9'," & ") From GOBJSUB
Endif
    
# Banque
If [M:CPAY]BAN<>"" 
    Call ADDCRIT(FILTPAY, IFILT,"BAN",'[F:PYH]BAN="'+[M:CPAY]BAN+'"'," & ") From GOBJSUB
Endif

# Mode de règlement
If [M:CPAY]PAM<>"" 
    Call ADDCRIT(FILTPAY, IFILT,"PAM",'[F:PYH]PAM="'+[M:CPAY]PAM+'"'," & ") From GOBJSUB
Endif

# Numéro de chèque
If [M:CPAY]CHQNUM<>"" 
    Call ADDCRIT(FILTPAY, IFILT,"CHQNUM",'[F:PYH]CHQNUM="'+[M:CPAY]CHQNUM+'"'," & ") From GOBJSUB
Endif

Case CHGPAG
 When 2 : # Suite
  Call ADDCRIT(FILTPAY, IFILT,"NUM",'(([F:PYD]NUM="'+FNUM+'"'," & ") From GOBJSUB
  Call ADDCRIT(FILTPAY, IFILT,"LIN",'[F:PYD]LIN>FLIN)'," & ") From GOBJSUB
  Call ADDCRIT(FILTPAY, IFILT,"NUM",'[F:PYD]NUM>"'+FNUM+'")'," | ") From GOBJSUB
 When 3 : # Raffraichissement 
  Call ADDCRIT(FILTPAY, IFILT,"NUM",'(([F:PYD]NUM="'+DNUM+'"'," & ") From GOBJSUB
  Call ADDCRIT(FILTPAY, IFILT,"LIN",'[F:PYD]LIN>=DLIN)'," & ") From GOBJSUB
  Call ADDCRIT(FILTPAY, IFILT,"NUM",'[F:PYD]NUM>"'+DNUM+'")'," | ") From GOBJSUB
 When -2 : # Retour 
  Call ADDCRIT(FILTPAY, IFILT,"NUM",'(([F:PYD]NUM="'+DNUM+'"'," & ") From GOBJSUB
  Call ADDCRIT(FILTPAY, IFILT,"LIN",'[F:PYD]LIN<DLIN)'," & ") From GOBJSUB
  Call ADDCRIT(FILTPAY, IFILT,"NUM",'[F:PYD]NUM<"'+DNUM+'")'," | ") From GOBJSUB
Endcase

If FILTPAY="" : FILTPAY="1=1" : Endif
Return

########################################
# Sélection sur les règlements.        #
########################################
$SEL_TABLE

# Variables pour effectur le filtre
Local Char FILTPAY(250)(1..4)
Local Integer IFILT : IFILT = 1     # Initialiser à 1 pour le CRITERE de SEL_TABLE.
Local Libelle GRP
Local Integer CHGPAG,SVG_CHGPAG
Local Integer FLAG  : FLAG=1        # Utiliser pour le filtre direct ou via SEL_TABLE

# Filtre sur les informations déjà saisies.
SVG_CHGPAG = CHGPAG
Raz CHGPAG
Gosub INIT
Gosub FILTRE
CHGPAG=SVG_CHGPAG

# Variables initialisées pour la sélection 
OBJET    = "PAY"
For I=1 To dim(FILTPAY)
 CRITERE(I)  = FILTPAY(I)
Next
ICRITERE = IFILT
Raz GFONC1    # Action FILTRE de l'objet PAY
Return



#############################################################
##     Etiquettes masques CONSPAY1 & CRITPAY & CONSPAY2    ##
#############################################################

## Ecran CONSPAY1 ##

Subprog AS_COLLEC(VALEUR)
Variable Char    VALEUR()
If [M]GROUPE<>"" : mkstat=2 : Endif
End

Subprog C_COLLEC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Raz [M]GROUPE : Affzo [M]GROUPE
 Read [GAC]GAC1 = [M]COA;VALEUR
 If [F:GAC]ACS<>""
  Local Integer DROIT
  Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
  If !DROIT
   # "Vous n'avez pas les droits pour ce code"    
   GMESSAGE = mess(4,104,1) : mkstat = 2 : End
  Endif
 Endif
Endif 
End

Subprog AS_GROUPE(VALEUR)
Variable Char    VALEUR()
If [M]COLLEC<>"" : mkstat=2 : Endif
End

Subprog C_GROUPE(VALEUR)
Variable Char    VALEUR()
Local Integer DROIT
If VALEUR<>""
 Raz [M]COLLEC :  Affzo [M]COLLEC
 Filter [GSC] Where [F:GSC]COA=[M]COA & [F:GSC]GRU=VALEUR
 For [GSC]
  Read [GAC]GAC1 = [M]COA;[F:GSC]SAC
  If !fstat & [F:GAC]ACS<>""
   Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
   If !DROIT  
    GMESSAGE = mess(4,104,1)-" : "-[F:GSC]SAC(I) : mkstat = 2 : Break
    # "Vous n'avez pas les droits pour ce code"    
   Endif 
  Endif
 Next
 Filter [GSC]
Endif
End

Subprog AM_REGDEB(VALEUR)
Variable Char    VALEUR()
If [M]REGFIN="" :  [M]REGFIN = VALEUR :  Endif
End

Subprog C_REGFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]REGDEB : mkstat=1 : Endif
End

Subprog AM_FACDEB(VALEUR)
Variable Char    VALEUR()
If [M]FACFIN="" :  [M]FACFIN = VALEUR : Endif
End

Subprog C_FACFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]FACDEB : mkstat=1 : Endif
End

##########################################################################
## Ecrans CONSPAY1 & CRITPAY ##

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Char WSOC(GLONCPY) : WSOC=[M]CPY
Call C_CPY(VALEUR) From CONSSUB
If WSOC<>[M]CPY : Gosub INIT_COA : Endif
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR) From CONSSUB
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Local Char WSOC(GLONCPY) : WSOC=[M]CPY
Call C_FCY(VALEUR) From CONSSUB
If WSOC<>[M]CPY : Gosub INIT_COA : Endif
End

Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
Call C_DATDEB(VALEUR) From CONSSUB
End

Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
Call C_DATFIN(VALEUR) From CONSSUB
End

$INIT_COA
[M]LEDTYP=GTYPGEN
Call LECPLAN([M]CPY,[M]LEDTYP,[M]COA) From CPTDIV
If [M:CPA1]COLLEC<>"" & [M:CPA1]COA<>""
 Read [GAC]GAC1 = [M:CPA1]COA;[M:CPA1]COLLEC
 If fstat | [F:GAC]SAC<>2 : Raz [M:CPA1]COLLEC : Endif
Endif
Affzo [M:CPA1]
Return

##########################################################################
## Ecran CONSPAY2 ##
##########################################################################

Subprog IB_NBLIG
################
# Bouton 1 : Zoom sur le règlement
# Bouton 2 : Zoom vers la consultation des factures
# Bouton 3 : Zoom sur pièce

# Seul le bouton 2 est sous condition, on peut consulter des règlements non liés à une facture.
Raz GBOUT2

If clalev([F:DUD])=0  : Local File GACCDUDATE [DUD]  : Endif
If clalev([F:DUD2])=0 : Local File GACCDUDATE [DUD2] : Endif

Read [DUD]DUD1 = [M]ACCNUM(nolign-1);[M]DUDLIG(nolign-1)
If !fstat  & [F:DUD]TYPDUD=2 : GBOUT2 = mess(394,198,1) : Endif

#Initialisation des champs MINDATFAC et MAXDATFAC pour la consultation des factures
If dim([M:CPA2]MINDATFAC)>0 & dim([M:CPA2]MAXDATFAC)>0 & ([M:CPA2]MINDATFAC(nolign-1) = [0/0/0] | [M:CPA2]MAXDATFAC(nolign-1) = [0/0/0])
 Read [DUD2]DUD1 = [M]ACCNUM(nolign-1)
 If !fstat
  #Pour l'écran de consultation des factures il faut :
  Local Date TMPDAT, MINDAT, MAXDAT
  TMPDAT=[0/0/0] 
  MINDAT=[0/0/0]
  MAXDAT=[0/0/0]
  For [DUD2]DUD1 Where ACCNUM = [M]ACCNUM(nolign-1)
  # si de type facture on va balayer toutes les échéances de la facture et pour alimenter les 
  # dates de l'écran de consultation facture ainsi la date début = date de l'échéance 
  # min et la date fin = date de l'échéance max 
  If [F:DUD2]TYPDUD=2 
   If TMPDAT=[0/0/0]
    TMPDAT = [F:DUD2]DUDDAT
    MINDAT = [F:DUD2]DUDDAT
    MAXDAT = [F:DUD2]DUDDAT
   Endif 
   If [F:DUD2]DUDDAT <= MINDAT   : MINDAT = [F:DUD2]DUDDAT
   Elsif [F:DUD2]DUDDAT > MAXDAT : MAXDAT = [F:DUD2]DUDDAT
   Endif
  Endif
  TMPDAT = [F:DUD2]DUDDAT
  #Champs invisibles qui sont passés en paramétres dans l'écran CNSPAYSTD sur le bouton Consultation de factures
  [M:CPA2]MINDATFAC(nolign-1) = MINDAT 
  [M:CPA2]MAXDATFAC(nolign-1) = MAXDAT
  Next
 Endif
Endif

End

## Tunnel vers les règlements
$AB1_NBLIG
Gosub SAV_CONSULT From CONSSUB
Return

## Tunnel vers la consultation des factures
$AB2_NBLIG
Gosub SAV_CONSULT From CONSSUB
Return

$BB_NBLIG
Gosub RST_CONSULT From CONSSUB
Return

##########################################################################
Subprog AV_COLOR(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 : Chgstl [M]NBLIG(nolign-1) With "MTC3" : Endif
End

#############################################
## Etiquette ajoutée par le superviseur 
#############################################
Subprog AV_STA(VALEUR)
Variable Integer VALEUR
End


