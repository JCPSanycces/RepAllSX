# Gestion du masque CALREO

Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
Read [STE]STE0=VALEUR;""
If fstat
  mkstat = 2
  GMESSAGE = mess(174,199,1)
Endif
End

Subprog AM_WRHSTR(VALEUR)
Variable Char    VALEUR()
If [M]WRHEND=[M]WRHSTR | [M]WRHEND<VALEUR
   [M]WRHEND = VALEUR
   Affzo [M]WRHEND
Endif
End

Subprog C_WRHEND(VALEUR)
Variable Char    VALEUR()
If [M]WRHSTR>VALEUR
   GMESSAGE = mess(44,199,1) 
   mkstat=2
Endif
If VALEUR = ""
   VALEUR = [M]WRHSTR
Endif
End

Subprog AM_LOCTYPSTR(VALEUR)
Variable Char    VALEUR()
If [M]LOCTYPEND = ""     : [M]LOCTYPEND = VALEUR : Affzo [M]LOCTYPEND : Endif
If [M]LOCTYPEND < VALEUR : [M]LOCTYPEND = VALEUR : Affzo [M]LOCTYPEND : Endif
End

Subprog C_LOCTYPEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]LOCTYPSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

Subprog AM_LOCSTR(VALEUR)
Variable Char    VALEUR()
If [M]LOCEND = ""     : [M]LOCEND = VALEUR : Affzo [M]LOCEND : Endif
If [M]LOCEND < VALEUR : [M]LOCEND = VALEUR : Affzo [M]LOCEND : Endif
End

Subprog C_LOCEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]LOCSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M]ITMREFEND = ""     : [M]ITMREFEND = VALEUR : Affzo [M]ITMREFEND : Endif
If [M]ITMREFEND < VALEUR : [M]ITMREFEND = VALEUR : Affzo [M]ITMREFEND : Endif
End

Subprog C_ITMREFEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]ITMREFSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

Subprog AM_WSTSTR(VALEUR)
Variable Char    VALEUR()
If [M]WSTEND = ""     : [M]WSTEND = VALEUR : Affzo [M]WSTEND : Endif
If [M]WSTEND < VALEUR : [M]WSTEND = VALEUR : Affzo [M]WSTEND : Endif
End

Subprog C_WSTEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]WSTSTR: GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

Subprog AM_INTFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
   [M]SCOFLG = 2
   Affzo [M]SCOFLG
Endif 
End

Subprog AM_SCOFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
   [M]INTFLG = 2
   Affzo [M]INTFLG
Endif 
End

# Action TRTSIMREO  simulation

##################################################
Subprog ACT_SIMREO
Global Integer GSIMREO
Call TRT_REAPPRO From CALREO
Kill GSIMREO

End


