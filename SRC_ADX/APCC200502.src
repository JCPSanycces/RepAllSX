#<AdxTL>@(#)5.0.0.0 $Revision$
################################################################################
# SQUELETTE D'UNE MOULINETTE POUR POUVOIR LA LANCER EN INTEGRATION DE PATCH    #
################################################################################

##################################################################
#Comments(1)                                                     #
# Manips à faire                                                 #
#   1. Remplacer UTIXXX par le nom de votre programme            #
#   2. Action OUVRE_TRACE : mettre un titre                      #
#   3. cf Comments(2)                                            #
#   4. cf Comments(3)                                            #
##################################################################

Local Char DOSSIER(30)
DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("APCC200502") From LECFIC
 Call APCC200502(DOSSIER)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

###################################################################################################
#Comments(2)                                                                                      #
# Pour exécution automatique en gestion de patch de APCC200502                                    #
#   1. Ne pas faire de ouvre_trace/ferme_trace/lec_trace dans cette partie de programme           #
#      (le fichier trace est déjà ouvert / l'intégration de patch peut se faire en batch )        #
#                                             
#   2. Pour les ecr_trace :                                                                       #
#         Utiliser des messages avec l'instruction mess(nnn,ccc,1) ou alors des textes en anglais #
#                                             
#   3. Attention à la déclaration des fichiers : pensez que le client n'a pas forcèment activé    #
#      tous les modules dans ses dossiers
#                                              
#   4. Attention aux moulinettes sur de gros volumes (Erreur Rollback en Oracle)                  #
###################################################################################################

Subprog APCC200502(APPLI)
Value Char APPLI
Local Integer OK


Call ECR_TRACE("APCC200502: Process Start on : "+APPLI,0) From GESECRAN

#### Corps de la moulinette - début
Local File =APPLI+".AWINBRO" [AWB]
Local File =APPLI+".AWINBRO" [AW_B]
Local File =APPLI+".AWINDOW" [AWI]
Local File =APPLI+".AMSK"    [AMK]
Local File =APPLI+".AOBJLST" [AOL]

Local Integer I,NBWIN,PICKL,TABINW,LAFLBRO,RESOL,MAXC
Local Char VALL1(200),PARHR
Call ECR_TRACE("Initialise Windows browser list size",0) From GESECRAN

#   Mise à jour de la colonne AFLBRO de la table AWINBRO
#   1 - Minimal
#   2 - Moyen
#   3 - Large

#   Algorithme d'initialisation
#
#   Pour toutes les fenêtres qui ont au moins une liste de browser
#   Si le dossier est défini en haute résolution AFLBRO est initialisé à minimal
#   Sinon
#      Si il y a une liste de picking ou de picking simple     PICK=1
#      Si il y a au moins un tableau dans la fenêtre           TABINW=1
#      Nombre maximum de colonnes dans une des listes gauche de la fenêtre   MAXC
#
#      Si il n'y a pas de tableau dans la fenêtre  (TABINW=0)     
#        Si PICK=1                      AFLBRO=Large
#        Sinon                          AFLBRO=Moyen
#
#      Sinon  (TABINW=1)
#        Si PICK=1                      AFLBRO=Large
#        Sinon                          AFLBRO=Minimal



Call PARAM("","ECRRESOL",PARHR) From ADOVAL
RESOL = val(PARHR)
Trbegin [AW_B]

For [AWB]
  VALL1="Window :"-[F:AWB]WIN
#  Call ECR_TRACE("Window :"-[F:AWB]WIN,0) From GESECRAN
  PICKL=0 : MAXC=0 : LAFLBRO=1
  For I=1 To [F:AWB]NBLIS
    If [F:AWB]TRELIS(I-1)=3 or [F:AWB]TRELIS(I-1)=5
      PICKL=1 :  #Break 1
    Endif 
    Read [AOL]AOL0=[F:AWB]OBJLIS(I-1)
    If fstat=0
      If [F:AOL]NBSEL>MAXC : MAXC=[F:AOL]NBSEL : Endif
 #     VALL1-=[F:AWB]OBJLIS(I-1)+":"+num$([F:AOL]NBSEL)+"  "
    Endif      
  Next I
  If [F:AWB]NBLIS>0
    Gosub ISTABLEAU
    NBWIN+=1
#    If TABINW=1 : VALL1+=" Tableau" : Endif
    If RESOL=2
      LAFLBRO=1
    Else 
      If TABINW=0
        If  PICKL=1 : LAFLBRO=3 : Else : LAFLBRO=2 : Endif
      Else
        If PICKL=1 
          LAFLBRO=3 
        Else
          LAFLBRO=1
        Endif
      Endif 
    Endif
    VALL1-=mess(LAFLBRO,942,1)
    Call ECR_TRACE(num$(NBWIN)+". "+VALL1,0) From GESECRAN
  Endif
  Read [AW_B]AWB0=[F:AWB]WIN
  [F:AW_B]AFLBRO=LAFLBRO
  Rewrite [AW_B]
Next
Commit
End



$ISTABLEAU
  TABINW=0
  Read [AWI]AWI0=[F:AWB]WIN
  For I=1 To [F:AWI]NBMSK
    Read [AMK]CODMSK=[F:AWI]NOMMSK(I-1)
    If fstat=0
      For J=1 To [F:AMK]NBBLOC
        If [F:AMK]TYPBLOC(J-1)=1 : TABINW=1 : Break 2 : Endif
      Next J
    Endif
  Next I
Return



###################################################################################################
#Comments(3)                                                                                      #
# Pour exécution automatique  en gestion de patch                                                 #
#   1. Si le traitement ne doit pas s'éxécuter dans le dossier X3 (moulinette applicative)        #
#        ==> Décocher la ligne 1                                                                  #
#                                                                                                 #
#   2. Si le traitement doit s'éxécuter uniquement dans les dossiers ayant activé un module donné #
#        ==> Décocher la ligne 2  et renseigner le n° de module                                   #
#            attention à la numérotation du module qui commence à 0 :                             #
#             (0=superviseur / 1= compta / 2= tiers ... etc ... )                                 #
###################################################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#If APPLI=adxmother(0) : End : Endif
Call APCC200502(APPLI)
End


