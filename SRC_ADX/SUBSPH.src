#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
## Fiche 70589
## Possibilitûˋ de choisir les colonnes et l'ordre des colonnes dans le tableau "Saisie
## du plan" dans l'ûˋcran PLF1
## La validation de l'objet permet de crûˋer l'ûˋcran WMPLF<code objet> et la fenûˆtre
## WFPLF<code objet> qui remplaceront respectivement PLF1 et OPLF dans la saisie des
## plans prûˋvisionnels
## Pour cela, la fenûˆtre OPLF a ûˋtûˋ dûˋfinie en tant que fenûˆtre modû´le
######################################################################################

$ACTION

  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "RAZCRE"       : Gosub RAZCRE
    When "SETBOUT"      : Gosub SETBOUT
    When "EXEBOUT"      : Gosub EXEBOUT
    When "LIENS"        : Gosub LIENS
    When "INIMOD"       : Gosub INIMOD
    When "FERME"        : Gosub FERME
    When "INICRE"       : Gosub INICRE
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "FILTRE"       : Gosub FILTRE
    When "ANNULE"       : Gosub ANNULE
  Endcase
Return

$OUVRE

  If clalev([F:AMZ])=0 : Local File AMSKZON  [AMZ] : Endif
  If clalev([F:ATY])=0 : Local File ATYPE    [ATY] : Endif
  If clalev([F:ACV])=0 : Local File ACTIV    [ACV] : Endif
  Local Char    LIBEL(30) , MASKREF(GLONAMK), VFORMAT(30), CODAFF(1)
  Local Integer ER
  Local Char    OPTFMT(20) , OPTSAI(20) , CARFMT(10)
  #ADNGO - 2017-11-15 - X3-63976 - START
  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
  #ADNGO - 2017-11-15 - X3-63976 - END
Return

$SETBOUT

  If !CLECUR | REP<>"" | !VERROU
    Call VIREBOUT(CHAINE,"V2") From GOBJET
  Endif
  # Transaction inactive
  If [M]ENAFLG<>2
    Call VIREBOUT(CHAINE,"V") From GOBJET
  Endif
Return

# Gûˋnûˋration de l'ûˋcran et de la fenûˆtre relative aux champs saisis
$EXEBOUT

  Case BOUT
    When "V" :  Call GENECR(nomap,[F:HRSPH]COD) From SUBSPH2
  Endcase
Return

#ADNGO - 2017-11-15 - X3-63976 - START
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return
#ADNGO - 2017-11-15 - X3-63976 - end

$RAZCRE

  [M]ENAFLG=2
Return

$MASKREF

  MASKREF="PLF1"
Return

# En crûˋation d'une nouvelle transaction de saisie, rûˋcupûˋration des zones du masque PLF1/ Tableau NBRPLF
$CHARGE_CHAMP
Local Char    LIBEL(30) , MASKREF(GLONAMK), VFORMAT(30)
Local Integer ER

  Gosub MASKREF
  Effzo [M]20
  Read [F:AMZ]CODE = MASKREF;"NBRPLF"
  If fstat=0 : J=[F:AMZ]NUMBLOC : Else J=0 : Endif
  For [F:AMZ]CODZON Where CODMSK=MASKREF
    OK = 1
    If [F:AMZ]CODTYP="ABS" | [F:AMZ]SAIAFF=3 | (J & [F:AMZ]NUMBLOC<>J)
      OK = 0
    Endif
    If [F:AMZ]CODACT<>""
      Read [F:ACV]CODACT = [F:AMZ]CODACT
      If fstat | [F:ACV]FLACT<>2 : OK = 0 : Endif
    Endif
    If OK & !find([F:AMZ]CODZON,[M]FLD(0..[M]NBRFLD-1))
      NOL = [M]NBRFLD
      [M]FLD(NOL)  = [F:AMZ]CODZON
      [M]OPT(NOL)  = [F:AMZ]SAIAFF
      [M]OBG(NOL)  = [F:AMZ]OBLIG
      [M]ORD(NOL)  = [F:AMZ]NOZONE-2
      [M]LIEN(NOL) = [F:AMZ]LIEN
      If [F:AMZ]INTEVAL<>""
        Onerrgo ERRLIB
        ER = 0
        [M]TIT(NOL) = evalue([F:AMZ]INTEVAL)
        If ER
          [M]TIT(NOL) = [F:AMZ]INTEVAL
        Endif
        Onerrgo
      Else
        Call TEXTE([F:AMZ]INTIT,LIBEL) From OBJDIV
        [M]TIT(NOL) = LIBEL
      Endif
      # Champs saisie obligatoire
      If find([F:AMZ]CODZON,"NBREMP","STG","CATFRT")>0 : [M]OPT(NOL)=1 : [M]OBG(NOL)=2 :  Endif
      # Champs affichûˋs
      If find([F:AMZ]CODZON,"ORI","FLGPRO","DAT","DEMNUM","STA","SRN")>0 Then
        [M]OBG(NOL) = 1
        Grizo [M]OPT(NOL), OBG(NOL)
      Endif
      [M]NBRFLD += 1
    Endif
  Next
  Affzo [M]
Return

$ERRLIB

  ER = errn
Resume

$LIENS
GCURLEG = [M:SPH1]LEG
  nolign=1
  For [F:HRSPD]SPD0 Where COD=[F:HRSPH]COD
    [M]=[F:HRSPD]
    nolign+=1
  Next
  [M]NBRFLD=nolign-1
Return

# On procû´de par suppression/crûˋation
$INIMOD
$INICRE

  Delete [F:HRSPD] Where COD=[F:HRSPH]COD
  If fstat=1
    GOK =-1 : GLOCK = "$SCRPLFD" : Return
  Endif

  For nolign=1 To [M]NBRFLD
    Raz [F:HRSPD]
    [F:HRSPD]=[M]
    [F:HRSPD]LIG=nolign
    Gosub FORMAT
    Write [F:HRSPD]
    If fstat<>0
      GOK = 0 : Call FSTA("HRSPD") From GLOCK : Break
    Endif
  Next
Return

# Le numûˋro d'ordre doit ûˆtre unique
$VERIF_MOD
$VERIF_CRE

  For nolign=1 To [M:SPH1]NBRFLD
    Call UNICITE([M:SPH1]ORD(nolign-1),[M:SPH1]ORD) From OBJDIV
    If mkstat=2 Then
      GMESSAGE = num$([M:SPH1]ORD(nolign-1))-"("+mess(234,10717,1)-num$(nolign)+") :"-GMESSAGE
      Break
    Endif
  Next
Return

$FORMAT

  VFORMAT=""
  If [M]OPT(nolign-1)=2
    CODAFF = "P"
  Else
    CODAFF = ""
  Endif
  Gosub MASKREF
  Read [F:AMZ]CODE = MASKREF;[F:HRSPD]FLD
  If fstat : Return : Endif
  Read [F:ATY]CODTYP=[F:AMZ]CODTYP
  If fstat : Return : Endif
  Case [F:ATY]TYPTYP
    When 1 : VFORMAT="LA"+CODAFF+num$([F:AMZ]NOLIB)+":"+num$([F:AMZ]LONG)
    When 2,3,4,5,6 : VFORMAT="N"+CODAFF+[F:ATY]OPTION+":"
      If [F:ATY]FORTYP<>""
        If left$([F:ATY]FORTYP,1)="="
          VFORMAT+=evalue(seg$([F:ATY]FORTYP,2,len([F:ATY]FORTYP)))
        Else
          VFORMAT+=[F:ATY]FORTYP
        Endif
      Else
        If [F:AMZ]LONG<>0 : VFORMAT+=num$([F:AMZ]LONG)+"#": Else : VFORMAT+=num$([F:ATY]LNGTYP)+"#" :  Endif
      Endif
    When 7
      If [F:ATY]FORTYP<>""
        If left$([F:ATY]FORTYP,1)="="
          VFORMAT="K"+CODAFF+":"
          VFORMAT+=evalue(seg$([F:ATY]FORTYP,2,len([F:ATY]FORTYP)))
        Else
          OPTSAI = [F:ATY]OPTION
          Raz OPTFMT, CARFMT
          Gosub OPTCAR From SUBFMT
          VFORMAT="K"+CODAFF+OPTFMT+":"+[F:ATY]FORTYP
        Endif
      Else
        OPTSAI = [F:ATY]OPTION
        Raz OPTFMT, CARFMT
        Gosub OPTCAR From SUBFMT
        If [F:AMZ]LONG<>0
          VFORMAT = "K"+CODAFF+OPTFMT+":"+num$([F:AMZ]LONG)+CARFMT
        Else
          VFORMAT = "K"+CODAFF+OPTFMT+":"+num$([F:ATY]LNGTYP)+CARFMT
        Endif
      Endif
    When 8 :VFORMAT="D"+CODAFF+[F:ATY]OPTION+":"
      If [F:ATY]FORTYP<>""
        If left$([F:ATY]FORTYP,1)="="
          VFORMAT+=evalue(seg$([F:ATY]FORTYP,2,len([F:ATY]FORTYP)))
        Else
          VFORMAT+=[F:ATY]FORTYP
        Endif
      Else
        VFORMAT+=GFMDAT4
      Endif
  Endcase
  If [F:HRSPD]OPT<3 :#saisie ou affichûˋ
    [F:HRSPD]FRMFLD=VFORMAT
  Else
    [F:HRSPD]FRMFLD="-"+VFORMAT
  Endif
Return

$FILTRE

  If GACTION="SELOBJW"
    If !clalev([F:ACV]) : Local File ACTIV [ACV] : Endif
    CRITERE = '1=1'
    For [HRSPH]SPH0 Where CODACT<>""
      Read [ACV]CODACT=[F:HRSPH]CODACT
      If fstat | [F:ACV]FLACT<>2
        CRITERE -= ' & CODACT<>"'+[F:HRSPH]CODACT+'"'
      Endif
    Next
  Endif
Return

# Annulation de l'ûˋcran, de la fenûˆtre et des traitements associûˋs
$ANNULE
Local Char MASQUE(10)
Local Char NOMWIN(10)

  MASQUE = "WMPLF"+[M:SPH1]COD
  Call DELMSK(MASQUE,nomap) From MSKDIV
  If GOK<1 : Return : Endif
  NOMWIN = "WFPLF"+[M:SPH1]COD
  Call DELWIN(NOMWIN,nomap) From MSKDIV
  If GOK<1 : Return : Endif
Return


#########################################
# Traitement appelûˋ par ACOPIE (bouton Copie des donnûˋes)
$TRTCOP

  If [M]DOSORG=nomap
    Local File SCRPLFH [SPH1]
    Local File SCRPLFD [SPD1]
  Else
    Local File =[M]DOSORG+".SCRPLFH" [SPH1]
    Local File =[M]DOSORG+".SCRPLFD" [SPD1]
  Endif
  If [M]DOSDES=nomap
    Local File SCRPLFH [SPH2]
    Local File SCRPLFD [SPD2]
  Else
    Local File =[M]DOSDES+".SCRPLFH" [SPH2]
    Local File =[M]DOSDES+".SCRPLFD" [SPD2]
  Endif

  Call DEBTRANS From GLOCK
  Gosub TR_COP
  Close Local File [SPH1], [SPH2],[SPD1],[SPD2]
Return

$TR_COP

  GOK = 1
  Trbegin [SPH2],[SPD2]
  Delete [SPH2] Where COD=TABLE
  If fstat=1
    GOK=-1 : GLOCK = "$"+[M]DOSDES+".SCRPLFH" : Goto ROLL_TR_COP
  Elsif fstat>5
    GOK = 0 : Call RSTA("SPH2","") From GLOCK : Goto AB_TR_COP
  Endif
  Delete [SPD2] Where COD=TABLE
  If fstat=1
    GOK=-1 : GLOCK = "$"+[M]DOSDES+".SCRPLFD" : Goto ROLL_TR_COP
  Elsif fstat>5
    GOK = 0 : Call RSTA("SPHD","") From GLOCK : Goto AB_TR_COP
  Endif
  #Entete
  Read [SPH1]SPH0=TABLE
  If !fstat
    [F:SPH2] = [F:SPH1]
    If dim([F:SPH2]CREUSR)>0 : [F:SPH2]CREUSR = GUSER : Endif
    If dim([F:SPH2]CREDAT)>0 : [F:SPH2]CREDAT = date$ : Endif
    If dim([F:SPH2]CRETIM)>0 : [F:SPH2]CRETIM = time : Endif
    If dim([F:SPH2]UPDUSR)>0 : Raz [F:SPH2]UPDUSR  : Endif
    If dim([F:SPH2]UPDDAT)>0 : Raz [F:SPH2]UPDDAT  : Endif
    If dim([F:SPH2]UPDTIM)>0 : Raz [F:SPH2]UPDTIM  : Endif
    Write [SPH2]
    If fstat
      GOK = 0 : Call FSTA("SPH2") From GLOCK : Return
    Endif
    #Lignes
    For [SPD1]SPD0 Where COD=[F:SPH1]COD
      [SPD2]=[SPD1]
      Write [SPD2]
      If fstat
        GOK = 0 : Call FSTA("SPD2") From GLOCK : Break
      Endif
    Next
    If   GOK<0 : Goto ROLL_TR_COP
    Elsif !GOK : Goto AB_TR_COP
    Endif
  Endif
  Commit
Return

$AB_TR_COP

  Rollback
Return

$ROLL_TR_COP

  Rollback
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto TR_COP : Endif
Return

########################################
# Traitement appelûˋ dans DOSVAL lors de la validation des transactions (GENTRANS) de la validation de dossier
Subprog GENDOS(APPLI)
Value Char    APPLI()

  If clalev([F:HRSPH])=0  : Local File =APPLI+".SCRPLFH"    [HRSPH]  : Endif
  If clalev([F:HRSPD])=0  : Local File =APPLI+".SCRPLFD"    [HRSPD]  : Endif
  If clalev([F:ACV])=0    : Local File =APPLI+".ACTIV"      [ACV]    : Endif

  Call DEBTRANS From GLOCK

  For [HRSPH]SPH0 Where ENAFLG=2
    If GTRACE<>"" : Call ECR_TRACE([F:HRSPH]COD,0) From GESECRAN : Endif
    Call GENECR(APPLI,[F:HRSPH]COD) From SUBSPH2
    If GOK=0 : Break : Endif
  Next
End

######################################################################################

# Les champs NBREMP, STG et CATFRT sont obligatoires dans le traitement SUBPLF, donc OPT est forcûˋment û  1
# Les champs ORI, FLGPRO et DAT sont calculûˋs dans SUBPLF, donc affichûˋs : il ne peuvent donc pas ûˆtre saisis
Subprog AS_OPT(VALEUR)
Variable Integer VALEUR

  Case [M]FLD(nolign-1)
    When "NBREMP", "STG", "CATFRT"   : VALEUR=1 : mkstat = 2
    When "ORI", "FLGPRO", "DAT"      : GMENLOC(1)=1
  Endcase
End

# Si on modifie la saisie de EMP, la saisie de CTRNU doit bouger de la mûˆme faûÏon
# Si la saisie passe û  Invisible, le lien passe û  vide
# Si la saisie passe û  Saisi ou Affichûˋ, le lien passe û  Non s'il ûˋtait û  vide
Subprog AM_OPT(VALEUR)
Variable Integer VALEUR
Local    Integer K

  If [M]FLD(nolign-1)="EMP"
    K = find("CTRNUM", [M]FLD(0..[M]NBRFLD-1))
    If K>0 Then [M]OPT(K-1)=VALEUR : Affzo [M]OPT(K-1) : Endif
  Endif
  If VALEUR=3 Then
    [M]LIEN(nolign-1)=0 : Affzo [M]LIEN(nolign-1)
  Elsif find([M:SPH1]FLD(nolign-1),"STG","DOM","THM","AGE","JOBPOT","POT","EMP","FCY","CATFRT","SRV")>0 & [M]LIEN(nolign-1)=0 Then
    [M]LIEN(nolign-1)=1 : Affzo [M]LIEN(nolign-1)
  Endif
End

# Si la saisie est Affichûˋ ou Inivisible, l'option Obligatoire devient Non
# Si on est sur les champs NBREMP, STG ou CATFRT qui sont forcûˋment obligatoires, on ne peut pas modifier la valeur
# Si on est sur le champ CTRNUM, on ne peut pas modifier la valeur, qui dûˋpend de celle du champ EMP
Subprog AS_OBG(VALEUR)
Variable Integer VALEUR

  If [M]OPT(nolign-1)<>1 : VALEUR=1 : mkstat=2 : End : Endif
  Case [M]FLD(nolign-1)
    When "NBREMP", "STG", "CATFRT" : VALEUR=2 : mkstat=2
    When "CTRNUM" : mkstat=2
  Endcase
End

# La valeur Obligatoire du champ CTRNUM dûˋpend de celle du champ EMP
Subprog AM_OBG(VALEUR)
Variable Integer VALEUR
Local    Integer I, K
Local    Char    ZON(10)

  Case [M]FLD(nolign-1)
    When "EMP"
        K = find("CTRNUM", [M]FLD(0..[M]NBRFLD-1))
        If K>0 & [M]OBG(K-1) <> VALEUR
          [M]OBG(K-1) = VALEUR
          Affzo [M]OBG(K-1)
        Endif
  Endcase
End

Subprog C_ENAFLG(VALEUR)
Variable Integer VALEUR

  If GREP="C" | [M]ENAFLG<>VALEUR Then
    [M]ENAFLG=VALEUR
    Gosub CHARGE_CHAMP
  Endif
End

# L'ordre des colonnes doit ûˆtre compris entre 1 et 23
Subprog C_ORD(VALEUR)
Variable Decimal VALEUR

  If VALEUR<1 | VALEUR>23 Then
    GMESSAGE=mess(233,10717,1)
    mkstat=2
  Endif
End

# La saisie du lien n'est possible que pour les champs indiquûˋs ci-dessous
# Si on est en Invisible, le lien n'est pas saisissable
Subprog AS_LIEN(VALEUR)
Variable Integer VALEUR

  If !find([M:SPH1]FLD(nolign-1),"STG","DOM","THM","AGE","JOBPOT","POT","EMP","FCY","CATFRT","SRV") Then
    mkstat=1
  Endif
  If [M:SPH1]OPT(nolign-1)=3 Then
    mkstat=1
  Endif
End


######################################################################################

######################################################################################
## Section automatically added (screen SPH1) 11/15/2017 11:27:47 (LIPET)
######################################################################################
#ADNGO - 2017-11-15 - X3-63976 - START
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
  GCURLEG = VALEUR
End
#ADNGO - 2017-11-15 - X3-63976 - END

######################################################################################

