Variable Decimal VALEUR
If [M]DIU="" & VALEUR <> 0
  mkstat = 2
  Call TEXTE(2086,GMESSAGE) From OBJDIV
  GMESSAGE -= ":"-mess(10,123,1) # unité dimension : zone obligatoire (08/07/04)
Endif
End

