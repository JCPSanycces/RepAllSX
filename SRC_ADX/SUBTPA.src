#<AdxTL>@(#)11.0.0.0 $Revision$
######################################################################
# SUBTPA : Gestion Table des emballages      TABPACKAGE              #
######################################################################

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INICRE 
 When "ANNULE"      : Gosub ANNULE 
 When "RAZCRE"      : [M:TPA1]PCKPRIDEV = GCUR
 When "CHANGE"      : Gosub CHANGE # correction bug 23386 modif AXX 27/07/04 TB
When Default
Endcase
Return

######################################################################
$OUVRE
Local Decimal WMNTORG
Local Decimal WMNTDES
Local Integer SPSTAT
#---- Chargement de GCUR 
Call CHARGE_GCUR() From TRTX3
Return

######################################################################
$LIENS
# Alimentation des mnts stockés en dev dossier dans [F] pour saisie en dev soc dans [M]
WMNTORG = [F:TPA]PCKPRI 
Call CONVERT(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMNTORG,WMNTDES,SPSTAT) From TRTDEV
If SPSTAT = 0
   [M:TPA1]PCKPRI = WMNTDES 
Endif
[M:TPA1]PCKPRIDEV = GCUR

Return

######################################################################
$INICRE
# Réalimentation des mnts saisis en dev soc dans [M] pour stockage en dev dossier dans [F] 
WMNTORG = [M:TPA1]PCKPRI 
Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMNTORG,WMNTDES,SPSTAT) From TRTDEV
If SPSTAT = 0
   [F:TPA]PCKPRI = WMNTDES 
Endif

#--- Creation / Modif de ATEXTRA
Call MAJTEXTRA ([M:TPA1]DESAXX,"TABPACKAGE","DESAXX",[M:TPA1]PCK,"") From ATEXTRA
Call MAJTEXTRA ([M:TPA1]SHOAXX,"TABPACKAGE","SHOAXX",[M:TPA1]PCK,"") From ATEXTRA

#    SOS libellés
If dim([F:TPA]LANDESSHO)>0 
   [F:TPA]LANDESSHO=GLANGUE+"~"+[M:TPA1]DESAXX+"~"+[M:TPA1]SHOAXX 
Endif

Return

######################################################################
$ANNULE
Delete [AXX]Where CODFIC="TABPACKAGE" & IDENT1=[F:TPA]PCK
Return

######################################################################
$CHANGE
# transformer les enregistrements ATEXTRA rattachés : bug 23386 (27/07/04)
Update [AXX] Where CODFIC="TABPACKAGE" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA TABPACKAGE"-[L]OCODE : Return
Elsif fstat
 #GOK=0 : Call RSTA([AXX],[L]OCODE) From GLOCK : Return
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return  # FGR 17/12/2009 : X3SUIVI60986
Endif
Return
######################################################################
##########################################################################
## Etiquette ajoutée par le superviseur 08/07/2004 10:26:48 (TB)
##########################################################################
Subprog C_PCKWEI(VALEUR)
Variable Decimal VALEUR
If [M]WEU="" & VALEUR <> 0
  mkstat = 2
  Call TEXTE(5900,GMESSAGE) From OBJDIV        #correction bug 23377
  GMESSAGE -= ":"-mess(10,123,1) # unité de poids : zone obligatoire (08/07/04)
Endif
End

