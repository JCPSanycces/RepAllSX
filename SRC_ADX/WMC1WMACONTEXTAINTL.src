####################################################################
# 1 : TWODIGITYEAR Base date ( Field C 0)
####################################################################

$GET_TWODIGITYEAR
Gosub DECLARE_VAR From WMC0WMACONTEXTAINTL
[L]CURPRO = "TWODIGITYEAR"
[L]ARULE = "GET" : [L]ACTION = "GET" : Gosub ACTION From ASYRSUB
Return


