#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe TABCONTAINER
# Issue 113105 - 2016-01-13 by MAE : Refactoring code
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AINIT"  : Gosub AINIT
      When "AINSERT_CONTROL_BEFORE"  : Gosub CONTROL
      When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE
    Endcase
Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  #Case CURPRO
  #Endcase
Return



#$METHODS
#Case CURPTH
#  When ""
#      Case ACTION
#        When "AINIT"  : Gosub AINIT
#        When "AINSERT_CONTROL_BEFORE"  : Gosub CONTROL
#        When "AUPDATE_CONTROL_BEFORE"  : Gosub CONTROL
#
#        #When "AREAD_AFTER"    : Gosub AREAD_AFTER
#        When Default
#      Endcase
#  When Default
#  Endcase
#Return
#
#$PROPERTIES
#Return
######################################################################################
$AINIT
#
 # Issue 60582 - 2017-11-08 by MAE : plus d'initialisation des unités
 #this.WEU    = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"SALDSPWEU")
 #this.VOU    = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"SALDSPVOU")
 this.ENAFLG = [V]CST_AYES
 this.INTFLG = [V]CST_ANO
 this.FREFLG = [V]CST_ANO
 this.MONITMFLG = [V]CST_ANO
 this.MONLOTFLG = [V]CST_ANO
Return
######################################################################################
$AUPDATE_CONTROL_BEFORE
Local File CONTAINER[CTRH]
Local File LPN[LPN]
#si FREFLG est décoché : est ce que le contenant est utilisé dans les conteneurs ?
If this.FREFLG<>2 and this.snapshot.FREFLG = 2
  Filter [CTRH] Where TCTRNUM = this.TCTRNUM
  Look [CTRH] First
  If fstat = 0
    [L]ASTATUS = fmet this.ASETERROR("FREFLG", mess(515,184, 1), [V]CST_AERROR)
    Filter [CTRH]
    Return
  Endif
  Filter [CTRH]
Endif
#si INTFLG est décoché : est ce que le contenant est utilisé dans les LPN ?
If this.INTFLG <> 2 and this.snapshot.INTFLG = 2
  Filter [LPN] Where TCTRNUM = this.TCTRNUM
  Look [LPN] First
  If fstat = 0
    [L]ASTATUS = fmet this.ASETERROR("INTFLG", mess(515,184, 1), [V]CST_AERROR)
    Filter [LPN]
    Return
  Endif
  Filter[LPN]
Endif

Gosub CONTROL
Return
######################################################################################
$CONTROL
#Mandatory fields
# Issue X3FEAT-345 - 2017-11-08 by MAE : poids et volume obligatoire si fret
If this.FREFLG = 2
  If this.DIU <> this.snapshot.DIU and this.snapshot.DIU <> AVOID.ACHAR
    [L]ASTATUS = fmet this.ASETERROR("DIU", mess(9,123, 1), [V]CST_AERROR)
    Return
  Endif
  If this.WEU <> this.snapshot.WEU and this.snapshot.WEU <> AVOID.ACHAR
    [L]ASTATUS = fmet this.ASETERROR("WEU", mess(9,123, 1), [V]CST_AERROR)
    Return
  Endif
  If this.VOU <> this.snapshot.VOU and this.snapshot.VOU <> AVOID.ACHAR
    [L]ASTATUS = fmet this.ASETERROR("VOU", mess(9,123, 1), [V]CST_AERROR)
    Return
  Endif

  If this.DIU=AVOID.ACHAR
   [L]ASTATUS = fmet this.ASETERROR("DIU", mess(627,199, 1), [V]CST_AERROR)  # saisir une unité de dimension
   Return
  Endif
  If this.WEU = AVOID.ACHAR
    [L]ASTATUS = fmet this.ASETERROR("WEU", mess(169,192, 1), [V]CST_AERROR)  # saisir une unité de poids
    Return
  Endif
  If this.VOU = AVOID.ACHAR
    [L]ASTATUS = fmet this.ASETERROR("VOU", mess(628,199, 1), [V]CST_AERROR)  # saisir une unité de volume
    Return
  Endif

Endif

If this.TARWEI <> 0 and this.WEU=""
   [L]ASTATUS = fmet this.ASETERROR("TARWEI", mess(169,192, 1), [V]CST_AERROR)  # saisir une unité de poids
   Return
Endif
If this.MAXWEI <> 0 and this.WEU=""
   [L]ASTATUS = fmet this.ASETERROR("MAXWEI", mess(169,192, 1), [V]CST_AERROR)  # saisir une unité de poids
   Return
Endif
If this.MAXWEI < this.TARWEI
   [L]ASTATUS = fmet this.ASETERROR("MAXWEI", mess(625,199, 1), [V]CST_AERROR)  # Poids maxi  inférieur  à la tare !
   Return
Endif

If this.TCTRVOL < this.USFVOL
   [L]ASTATUS = fmet this.ASETERROR("USFVOL", mess(637,199, 1), [V]CST_AERROR)  # Poids maxi  inférieur  à la tare !
   Return
Endif

If this.TCTRVOL <> 0 and this.VOU=""
   [L]ASTATUS = fmet this.ASETERROR("TCTRVOL", mess(628,199, 1), [V]CST_AERROR)  # saisir une unité de volume
   Return
Endif
If this.TEU<>0 & this.TEU<> 1 & this.TEU<>2 & this.TCTRTYP=1
   [L]ASTATUS = fmet this.ASETERROR("TEU", mess(624,199, 1), [V]CST_AERROR)  # Equivalent 20 pieds ne peut avoir une valeur supérieure à 2  !
   Return
Endif

# Issue X3FEAT-345 - 2017-11-08 by MAE : compteur contenant obligatoire si interne
# Issue X3-95089 - 2018-06-15 by MAE : Le compteur n'est plus obligatoire
#If this.INTFLG = 2
#  If this.LPNREFCOU = AVOID.ACHAR
#    [L]ASTATUS = fmet this.ASETERROR("LPNREFCOU", mess(509,184, 1), [V]CST_AERROR)  # compteur obligatoire
#    Return
#  Endif
#Endif

#un contenant est soit de type fret, soit de type interne
If this.INTFLG <> 2 & this.FREFLG <> 2
  [L]ASTATUS = fmet this.ASETERROR("", mess(514,184, 1), [V]CST_AERROR)
  Return
Endif



Return
##############################################################################################

