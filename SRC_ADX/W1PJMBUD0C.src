#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMBUD0C 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:44"
A_USER  = "DOC"
A_STAMP = "20181109230544"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMBUD0C [PJBU0C]
Gosub HORODAT
Local Inpbox "PJMBUD0C" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJBU0C] As [SIM_]
Grizo [PJBU0C]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJBU0C]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=43 : X2(0)=100 : Y1(0)=1 : Y2(0)=10
Return

$ON_PBUSTATE
Onevent INIT_AREA Call D_PBUSTATE(zc) From W1PJMBUD0C
Return

Subprog D_PBUSTATE(VALEUR)
Variable Integer VALEUR
If varinit([M]PBUSTATE,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_PBUDATO
Onevent BEFORE_AREA Gosub AV_PBUDATO From W1PJMBUD0C
Return

$AV_PBUDATO
Chgfmt [M]PBUDATO(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_PBUDATS
Onevent BEFORE_AREA Gosub AV_PBUDATS From W1PJMBUD0C
Return

$AV_PBUDATS
Chgfmt [M]PBUDATS(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_PBUDATH
Onevent BEFORE_AREA Gosub AV_PBUDATH From W1PJMBUD0C
Return

$AV_PBUDATH
Chgfmt [M]PBUDATH(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$CHG_STY
Return


