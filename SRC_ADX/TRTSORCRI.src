#<AdxTL>@(#)0.0.0.0 $Revision$
#CHECK UNUSED_BEGIN
Local Char PARAM(250)(1..20) , SAVACT(10)
PARAM(1) = "ALL"
Local Decimal VALEUR
#SAVACT = GACTION : GACTION = "SAISORCRI"
Call SAISIE_NUM(VALEUR,PARAM,"ISORCRI","TRTSORCRI") From GSAISIE
#GACTION = SAVACT
End
#CHECK UNUSED_END

#########################################################################
# TRTSORCRI    Saisie des filtres pour la liste de picking des sorties  #
#########################################################################

$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "AVANT_ENR"   : Gosub AVANT_ENR
 When "ENR"         : Gosub ENR
 When "ABA"         : Gosub ABA
Endcase
Return

#########################################################################
$OUVRE_BOITE

Gosub FORMAT_INV From STKLIB

Return

#########################################################################
$DEBUT

Local Char    WABMSK
Local Integer I,J

Raz [M:SCR]
WABMSK           = PARAM(1)
[M:SCR]STOFCY    = evalue("[M:"+WABMSK+"]STOFCY")
[M:SCR]ITMREF    = evalue("[M:"+WABMSK+"]ITMREF")
[M:SCR]VCRNUM    = evalue("[M:"+WABMSK+"]VCRNUM")
[M:SCR]AUZSST    = evalue("[M:"+WABMSK+"]AUZSST")
[M:SCR]FORSTA    = evalue("[M:"+WABMSK+"]FORSTA")
[M:SCR]AAASTA    = evalue("[M:"+WABMSK+"]AAASTA")
[M:SCR]QQQSTA    = evalue("[M:"+WABMSK+"]QQQSTA")
[M:SCR]RRRSTA    = evalue("[M:"+WABMSK+"]RRRSTA")
[M:SCR]FLGSHLLOT = evalue("[M:"+WABMSK+"]FLGSHLLOT")            # hcb V6percri
[M:SCR]FLGDLULOT = evalue("[M:"+WABMSK+"]FLGDLULOT")            # hcb V6percri
[M:SCR]PECINTLOC = evalue("[M:"+WABMSK+"]PECINTLOC")
[M:SCR]PECPLFLOC = evalue("[M:"+WABMSK+"]PECPLFLOC")
[M:SCR]PECSCOLOC = evalue("[M:"+WABMSK+"]PECSCOLOC")
[M:SCR]STODISFLG = evalue("[M:"+WABMSK+"]STODISFLG")
[M:SCR]PCU       = evalue("[M:"+WABMSK+"]XPCUFIL")
[M:SCR]STA       = evalue("[M:"+WABMSK+"]XSTA")
#--- Issue 53322
If dim([M:SCR]LPNNUM)>0 [M:SCR]LPNNUM = evalue("[M:"+WABMSK+"]FLPNNUM") Endif
#---
If dim([M:SCR]PALNUM)>0 [M:SCR]PALNUM = evalue("[M:"+WABMSK+"]XPALNUM") Endif
If dim([M:SCR]CTRNUM)>0 [M:SCR]CTRNUM = evalue("[M:"+WABMSK+"]XCTRNUM") Endif
If dim([M:SCR]LOT)>0    [M:SCR]LOT    = evalue("[M:"+WABMSK+"]XLOT")    Endif
If evalue("dim([M:"+WABMSK+"]OWNFLG)")>0
   [M:SCR]OWNFLG    = evalue("[M:"+WABMSK+"]OWNFLG")
Endif
If evalue("dim([M:"+WABMSK+"]NOTOWNFLG)")>0
   [M:SCR]NOTOWNFLG = evalue("[M:"+WABMSK+"]NOTOWNFLG")
Endif
If evalue("dim([M:"+WABMSK+"]PECOWNER)")>0
   [M:SCR]PECOWNER  = evalue("[M:"+WABMSK+"]PECOWNER")
Endif
If evalue("dim([M:"+WABMSK+"]PECTRU)")>0
   [M:SCR]PECTRU    = evalue("[M:"+WABMSK+"]PECTRU")
Endif
#--- TS 106217
If dim([M:SCR]PECECC)>0 & evalue("dim([M:"+WABMSK+"]PECECC)")>0
   [M:SCR]PECECC    = evalue("[M:"+WABMSK+"]PECECC")
Endif
#---
# Filter dépôt
If dim([M:SCR]WRH)>0 [M:SCR]WRH = evalue("[M:"+WABMSK+"]XWRH") Endif

Affzo [M:SCR]

If find([M:SCR]STA,"","*")
   Actzo [M:SCR]AUZSST
Else
   Diszo [M:SCR]AUZSST
Endif

# Si Réception s-traitance, OF, Suivi matière, Retour liv pour s-traitance,
# Sortie diverse, EO
If find(evalue("[M:"+WABMSK+"]VCRTYP"),6,10,12,13,20,36)
   Actzo [M:SCR]PECSCOLOC
Else
   Diszo [M:SCR]PECSCOLOC
Endif

If [M:SCR]NOTOWNFLG=2
   Actzo [M:SCR]PECOWNER
Else
   Diszo [M:SCR]PECOWNER
Endif

If dim([M:SCR]WRH)>0
   If [F:FCY]FCY<>[M:SCR]STOFCY
      Read [FCY]FCY0=[M:SCR]STOFCY
      If fstat Raz [F:FCY] Endif
   Endif
   #--- Bug 66484
   If [F:ITF]ITMREF<>[M:SCR]ITMREF | [F:ITF]STOFCY<>[M:SCR]STOFCY
      Read [ITF]ITF0 = [M:SCR]ITMREF;[M:SCR]STOFCY
      If fstat Raz [F:ITF] Endif
   Endif
   # Pas de gestion de dépôt sur le site ou pas de gestion d'emplacement
   If [F:FCY]WRHGES<>2 | [F:ITF]LOCMGTCOD<2
   #If [F:FCY]WRHGES<>2
   #---
      [M:SCR]WRH=""
      Grizo [M:SCR]WRH
   # Si dépôt obligatoire (param transaction) --> non modifiable
   Elsif evalue("[M:"+WABMSK+"]WRHOBY")=2
      Diszo [M:SCR]WRH
   Else
      Actzo [M:SCR]WRH
   Endif
Endif

Return

#########################################################################
$SETBOUT

ETABOU(GENRE)=1
ETABOU(GABAN)=1

Return

#########################################################################
$AVANT_ENR

If [M:SCR]OWNFLG<>2 & [M:SCR]NOTOWNFLG<>2
   GERR=1 : GMESSAGE=mess(259,184,1)
   FOK =0
Endif

Return

#########################################################################
$ENR

Assign "[M:"+WABMSK+"]AUZSST"    With [M:SCR]AUZSST
Assign "[M:"+WABMSK+"]FORSTA"    With [M:SCR]FORSTA
Assign "[M:"+WABMSK+"]AAASTA"    With [M:SCR]AAASTA
Assign "[M:"+WABMSK+"]QQQSTA"    With [M:SCR]QQQSTA
Assign "[M:"+WABMSK+"]RRRSTA"    With [M:SCR]RRRSTA
Assign "[M:"+WABMSK+"]FLGSHLLOT" With [M:SCR]FLGSHLLOT         # hcb V6percri
Assign "[M:"+WABMSK+"]FLGDLULOT" With [M:SCR]FLGDLULOT         # hcb V6percri
Assign "[M:"+WABMSK+"]PECINTLOC" With [M:SCR]PECINTLOC
Assign "[M:"+WABMSK+"]PECPLFLOC" With [M:SCR]PECPLFLOC
Assign "[M:"+WABMSK+"]PECSCOLOC" With [M:SCR]PECSCOLOC
Assign "[M:"+WABMSK+"]STODISFLG" With [M:SCR]STODISFLG
Assign "[M:"+WABMSK+"]XPCUFIL"   With [M:SCR]PCU
Assign "[M:"+WABMSK+"]XSTA"      With [M:SCR]STA
#--- Issue 53322
If dim([M:SCR]LPNNUM)>0 Assign "[M:"+WABMSK+"]FLPNNUM" With [M:SCR]LPNNUM Endif
#---
If dim([M:SCR]PALNUM)>0 Assign "[M:"+WABMSK+"]XPALNUM" With [M:SCR]PALNUM Endif
If dim([M:SCR]CTRNUM)>0 Assign "[M:"+WABMSK+"]XCTRNUM" With [M:SCR]CTRNUM Endif
If dim([M:SCR]LOT)>0    Assign "[M:"+WABMSK+"]XLOT"    With [M:SCR]LOT    Endif
If evalue("dim([M:"+WABMSK+"]OWNFLG)")>0
   Assign "[M:"+WABMSK+"]OWNFLG"    With [M:SCR]OWNFLG
Endif
If evalue("dim([M:"+WABMSK+"]NOTOWNFLG)")>0
   Assign "[M:"+WABMSK+"]NOTOWNFLG" With [M:SCR]NOTOWNFLG
Endif
If evalue("dim([M:"+WABMSK+"]PECOWNER)")>0
   Assign "[M:"+WABMSK+"]PECOWNER"  With [M:SCR]PECOWNER
Endif
If evalue("dim([M:"+WABMSK+"]PECTRU)")>0
   Assign "[M:"+WABMSK+"]PECTRU"    With [M:SCR]PECTRU
Endif
#--- TS 106217
If dim([M:SCR]PECECC)>0 & evalue("dim([M:"+WABMSK+"]PECECC)")>0
   Assign "[M:"+WABMSK+"]PECECC"    With [M:SCR]PECECC
Endif
#---
# Filter dépôt
If dim([M:SCR]WRH)>0 Assign "[M:"+WABMSK+"]XWRH" With [M:SCR]WRH Endif

GOK = 1
FIN = 1

Return

#########################################################################
$ABA

# Réalimentation avec les valeurs initiales
Gosub DEBUT

Return

##########################################################################
## Etiquette ajoutée par le superviseur 29/09/2003 08:21:50 (TS)
##########################################################################

##########################################################################
Subprog C_AUZSST(VALEUR)
Variable Char    VALEUR()

Local Integer I,J
Local Char    WWSTA(30)
Local Char    WSTA(3)(20)

If VALEUR="" mkstat=2 : End Endif

VALEUR=toupper(VALEUR)
WWSTA=VALEUR
J=instr(J,WWSTA,",")
While J<>0
   WSTA(I)=left$ (WWSTA,J-1)
   WWSTA  =right$(WWSTA,J+1)
   J=instr(J,WWSTA,",")
   I+=1
Wend
J=I
WSTA(I)=WWSTA
For I=0 To J
   If !find(left$(WSTA(I),1),"A","Q","R")
      mkstat=2 : GMESSAGE=mess(21,199,1)
      Break
   Elsif len(WSTA(I))>GLONSTA
      mkstat=2 : GMESSAGE=mess(456,199,1)-num$(GLONSTA)
      Break
   Endif
Next I

# Construction de la formule :
Call DECODE_STAT(VALEUR,[M:SCR]FORSTA) From TRTCATEG

End

##########################################################################
Subprog C_STA(VALEUR)
Variable Char    VALEUR()

Local Integer I,J,K,L
Local Char    WWSTA(12),  WWSRU(12)
Local Char    WSTA(3)(6), WSRU(3)(6)
Local Char    WSTA2(3)
Local Char    WCRITSTA(200)

If VALEUR="" End Endif

# Contrôle par rapport à la règle de gestion
VALEUR=toupper(VALEUR)
WWSTA=VALEUR
J=instr(J,WWSTA,",")
While J<>0
   WSTA(I)=left$ (WWSTA,J-1)
   WWSTA  =right$(WWSTA,J+1)
   J=instr(J,WWSTA,",")
   I+=1
Wend
J=I
WSTA(I)=WWSTA
For I=0 To J
   Raz WCRITSTA
   Call CREE_FORMULE([M:SCR]FORSTA,"WSTA(I)",WCRITSTA) From TRTCATEG
   If !evalue(WCRITSTA)
      mkstat=2 : GMESSAGE=mess(456,199,1)
      Break
   # Le pat ne sait pas contrôler les jokers entre eux
   Elsif right$(WSTA(I),len(WSTA(I)))="*"
      # Dépack des sous-statuts autorisés
      WWSRU=[M:SCR]AUZSST
      L=instr(L,WWSRU,",")
      While L<>0
         WSRU(K)=left$ (WWSRU,L-1)
         WWSRU  =right$(WWSRU,L+1)
         L=instr(L,WWSRU,",")
         K+=1
      Wend
      L=K
      WSRU(K)=WWSRU
      Case len(WSTA(I))
       When 2 : If !find(WSTA(I),WSRU(0..L))
                   mkstat=2 : GMESSAGE=mess(456,199,1)
                   Break
                Endif
       When 3 : If !find(WSTA(I),WSRU(0..L))
                   WSTA2=left$(WSTA(I),1)+right$(WSTA(I),len(WSTA(I)))
                   If !find(WSTA2,WSRU(0..L))
                      mkstat=2 : GMESSAGE=mess(456,199,1)
                      Break
                   Endif
                Endif
      Endcase
   Endif
Next I

End

##########################################################################
Subprog AM_STA(VALEUR)
Variable Char    VALEUR()

If find(VALEUR,"","*")
   Actzo [M:SCR]AUZSST
Else
   Diszo [M:SCR]AUZSST
Endif
Affzo [M:SCR]AUZSST

End

##########################################################################
Subprog B1_STA(VALEUR)
Variable Char    VALEUR()
VALEUR = GXSTA
End

##########################################################################
Subprog B1_AUZSST(VALEUR)
Variable Char    VALEUR()
VALEUR = [F:SRU]AUZSST
End

##########################################################################
Subprog AM_NOTOWNFLG(VALEUR)
Variable Integer VALEUR

If VALEUR=2
   Actzo [M:SCR]PECOWNER
Else
   Diszo [M:SCR]PECOWNER
   Raz   [M:SCR]PECOWNER
Endif
Affzo [M:SCR]PECOWNER

End

##########################################################################
Subprog C_PECOWNER(VALEUR)
Variable Char    VALEUR()
Local Char    WSUP
Local Integer WRET
If [M:SCR]NOTOWNFLG=2 & VALEUR=""
   mkstat=2 : GMESSAGE=mess(516,199,1) : End
Endif
Call STKOWNER("C",VALEUR,WSUP,WRET) From STKACT
End



#  Hcb V6percri deb
######################################################################################
Subprog AM_FLGSHLLOT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
   [M:SCR]FLGDLULOT = 2
Endif
Affzo [M:SCR]FLGDLULOT

End

Subprog AM_FLGDLULOT(VALEUR)
Variable Integer VALEUR
If VALEUR=1
   [M:SCR]FLGSHLLOT = 1
Endif
Affzo [M:SCR]FLGSHLLOT

End
#  Hcb V6percri fin

