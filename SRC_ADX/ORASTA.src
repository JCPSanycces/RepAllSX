## Etiquette ajoutée par le superviseur (écran ORASTA1) 24/02/2006 13:42:08 (VPO)
######################################################################################
Subprog B1_NBTAB
For I=nolign To [M:STA1]NBTAB
  [M:STA1]PROFLG(I-1)=2
Next I
Affzo [M:STA1]5
#gerer les boutons de fenetre + bouton contextuel
mkstat=4
End

Subprog B2_NBTAB
For I=nolign To [M:STA1]NBTAB
  [M:STA1]PROFLG(I-1)=1
Next I
Affzo [M:STA1]5
#gerer les boutons de fenetre + bouton contextuel
mkstat=4
End

Subprog B3_NBTAB
Local Integer ERR
Local Integer INDOBJ : INDOBJ=1
Call ACTUALISER_LIGNE(INDOBJ,ERR)
Affzo [M:STA1]5
End

Subprog B4_NBTAB
Local Integer ERR
Local Integer INDOBJ : INDOBJ=1
Call GENERER_LIGNE(INDOBJ,ERR)
Call ACTUALISER_LIGNE(INDOBJ,ERR)
Affzo [M:STA1]5
End

Subprog B5_NBTAB
Local Integer ERR
Local Integer INDOBJ : INDOBJ=1
Call SUPPRIMER_LIGNE(INDOBJ,ERR)
Call ACTUALISER_LIGNE(INDOBJ,ERR)
Affzo [M:STA1]5
End


