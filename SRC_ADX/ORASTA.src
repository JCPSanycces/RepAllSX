#<AdxTL>@(#)12.0.0.0 $Revision$
Close Local Mask
Call ORASTA(nomap)
End

########################################################################
Subprog ORASTA(APPLI)
Value Char APPLI
Local Char PARAM(30)(1..2)
Call SAISIE_CHAR(APPLI,PARAM,"ORASTA","ORASTA","") From GSAISIE
End

######################################################################################
# Gestion du masque ORASTA0
####################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEBUT"        : Gosub DEBUT
 When "SETBOUT"      : Gosub SETBOUT
 When "BOUTON"       : Gosub BOUTON
 When "RAF"          : Gosub RAF
 When "FIN"          : Gosub FIN

 When "INIT"         : Gosub OUVRE
 When "INIT_DIA"     : Gosub DEBUT
 When "CONTROLE"     : Gosub CONTROLE
 When "CONT_BATCH"   : Gosub CONTROLE
 When "EXEC"         : Gosub LANCER
 When Default
Endcase
Return

####################
$CONTROLE
If GTYPDBA<>1
    FIN=1
    Return
Endif
If [M]DEL<>2 & [M]CRE<>2
    GERR=1
    GMESSAGE=mess(232,100,1)
    SAI=1
    Return
Endif
Return

$OUVRE
If GTYPDBA<>1
    FIN=1
    Return
Endif
Return

####################
$DEBUT
If GTYPDBA<>1
    Call ERREUR(mess(108,115,1)) From GESECRAN : # La base de données n'est pas oracle
    FIN=1
    Return
Endif

If GACTION<>"ORASTAB" & GBOITE<>"ORASTAB"
    Raz [M:STA0]
Endif
Call VERS_ORA([M]BDDNAM,[M]VER,[M]VERDES,FIN) From ORAPROP
If FIN : Return : Endif
[M]DOSSIER=nomap
If GACTION<>"ORASTAB" & GBOITE<>"ORASTAB"
    Diszo [M:STA0]
Endif
Gosub ACTUALISER
Return

####################
$FIN
Return

####################
$BOUTON
Case BOUT
   When "A" : Gosub ACTUALISER
   When "G" : Gosub GENERER
   When "S" : Gosub SUPPRIMER
   When "E" : Gosub LANCER
Endcase
Return

#########
$SETBOUT
Call VIREBOUT(CHMEN,"AGS") From GOBJET

#on affiche toujours Actualiser
CHMEN+="A" 
CHBOU += "=" : # Raffraîchir

NOTAB=find(2,[M:STA1]PROFLG(0..[M:STA1]NBTAB-1))
#Infbox "SETBOUT NOTAB="+num$(NOTAB)
If NOTAB<>0
   CHMEN+="G"
   CHMEN+="S"
Else
    NOIND=find(2,[M:STA2]PROFLG(0..[M:STA2]NBINDEX-1))
    If NOIND<>0
       CHMEN+="G"
       CHMEN+="S"
    Endif
Endif

Gosub SET_BOUT_SPE From GSAISIE
Return

####################
$RAF
$ACTUALISER
If GACTION<>"ORASTAB" & GBOITE<>"ORASTAB" : Raz [M:STA4] : Endif
[M]NDEGREE=2
If GACTION<>"ORASTAB" & GBOITE<>"ORASTAB"
    Diszo [M:STA4]CASCADE
    Diszo [M:STA4]METHOPT
    Diszo [M:STA4]DEGREE
    Diszo [M:STA4]NDEGREE
    Affzo [M:STA4]
    Call TEMPON("L") From GESECRAN
    Call CHARGE_STA1(FIN)
    Call CHARGE_STA2(FIN)
    Call CHARGE_STA3(FIN)
    Affzo [M:STA1]
    Affzo [M:STA2]
    Affzo [M:STA3]
    Call TEMPOFF From GESECRAN
Endif
Return

####################
$LANCER
Local Integer ERR
If [M]DEL<>2 & [M]CRE<>2
Call ERREUR(mess(232,100,1)) From GESECRAN
Return
Endif

Call TEMPON("") From GESECRAN
If [M]DEL=2 
    Call SUPPRIMER_SCHEMA(ERR)
Endif

If [M]CRE=2 
    Call GENERER_SCHEMA(ERR)
Endif
Call TEMPOFF From GESECRAN

Gosub ACTUALISER
Return

###################################################################################################
###################################################################################################
Subprog GENERER_SCHEMA(ERR)
Variable Integer ERR

Local Char SQLREQ (250)
Onerrgo ERR_SCHEMA

SQLREQ = "BEGIN"

SQLREQ -= "dbms_stats.gather_schema_stats(ownname=> '"+[M]DOSSIER+"', estimate_percent=>dbms_stats.auto_sample_size"

If [M]CASCADE=2
SQLREQ -= ", cascade=>true"
Else
SQLREQ -= ", cascade=>false"
Endif

If [M]METHOPT=2
SQLREQ -= ", method_opt=>'for all indexed columns'"
Endif

If [M]DEGREE=2 & [M]NDEGREE>0
SQLREQ -= ", degree=>"+num$([M]NDEGREE)
Endif


SQLREQ -= ");"

SQLREQ -= "END;"

Execsql From "3" Sql SQLREQ

Onerrgo
End

###################################################################################################
###################################################################################################
Subprog SUPPRIMER_SCHEMA(ERR)
Variable Integer ERR

Local Char SQLREQ (250)

Onerrgo ERR_SCHEMA

SQLREQ = "BEGIN"
SQLREQ -= "dbms_stats.delete_schema_stats(ownname=> '"+[M]DOSSIER+"');"
SQLREQ -= "END;"

Execsql From "3" Sql SQLREQ

Onerrgo
End

###################################################################################################
###################################################################################################
$ERR_SCHEMA
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ERREUR(GMESSAGE) From GESECRAN
ERR=1
End



####################
$GENERER
Local Integer ERR,I,COUNT
Local Integer INDOBJ 
Local Integer INTERRUPT : INTERRUPT=1

COUNT=0
For nolign=1 To [M:STA1]NBTAB
  If [M:STA1]PROFLG(nolign-1)=2
     COUNT+=1
  Endif
Next nolign
For nolign=1 To [M:STA2]NBINDEX
  If [M:STA2]PROFLG(nolign-1)=2
     COUNT+=1
  Endif
Next nolign

Call OUVRE_BOITE(mess(219,100,1),COUNT) From GESECRAN
COUNT=0
#generation pour les tables
INDOBJ=1
For nolign=1 To [M:STA1]NBTAB
  I=nolign-1
  If [M:STA1]PROFLG(nolign-1)=2
     COUNT+=1
     Call AFF_BOITE([M:STA1]TAB(I),COUNT,INTERRUPT ) From GESECRAN
     Call GENERER_LIGNE(INDOBJ,ERR)
  Endif
Next nolign

#generation pour les index
INDOBJ=2
For nolign=1 To [M:STA2]NBINDEX
  I=nolign-1
  If [M:STA2]PROFLG(nolign-1)=2
     COUNT+=1
     Call AFF_BOITE([M:STA2]INDEX(I),COUNT,INTERRUPT ) From GESECRAN
     Call GENERER_LIGNE(INDOBJ,ERR)
  Endif
Next nolign

Call FERME_BOITE From GESECRAN

Gosub ACTUALISER
Return

####################
$SUPPRIMER
Local Integer ERR,I,COUNT
Local Integer INDOBJ 
Local Integer INTERRUPT : INTERRUPT=1

COUNT=0
For nolign=1 To [M:STA1]NBTAB
  If [M:STA1]PROFLG(nolign-1)=2
     COUNT+=1
  Endif
Next nolign
For nolign=1 To [M:STA2]NBINDEX
  If [M:STA2]PROFLG(nolign-1)=2
     COUNT+=1
  Endif
Next nolign

Call OUVRE_BOITE(mess(220,100,1),COUNT) From GESECRAN
COUNT=0
#suppression pour les tables
INDOBJ=1
For nolign=1 To [M:STA1]NBTAB
  I=nolign-1
  If [M:STA1]PROFLG(nolign-1)=2
     COUNT+=1
     Call AFF_BOITE([M:STA1]TAB(I),COUNT,INTERRUPT ) From GESECRAN
     Call SUPPRIMER_LIGNE(INDOBJ,ERR)
  Endif
Next nolign

#suppression pour les index
INDOBJ=2
For nolign=1 To [M:STA2]NBINDEX
  I=nolign-1
  If [M:STA2]PROFLG(nolign-1)=2
     COUNT+=1
     Call AFF_BOITE([M:STA2]INDEX(I),COUNT,INTERRUPT ) From GESECRAN
     Call SUPPRIMER_LIGNE(INDOBJ,ERR)
  Endif
Next nolign

Call FERME_BOITE From GESECRAN

Gosub ACTUALISER
Return

###################################################################################################
###################################################################################################
Subprog CHARGE_STA1(ERR)
Variable Integer ERR

Raz [M:STA1]
nolign = 0

Onerrgo ERR_SQL

For (Char VTAB(50),Char VSTA(50),Char VDAT(50),Char VHEU(50)) From '3' Sql
&  "SELECT table_name,DECODE(blocks,null,'NO','YES'),"
& -"TO_CHAR(last_analyzed,'YYYYMMDD'),TO_CHAR(last_analyzed,'HH24:MI:SS')"
& -"From USER_TABLES"
& -"Order BY 1"
&   As [BXX]
    nolign +=1
    [M:STA1]TAB(nolign-1)=[BXX]VTAB
    If [BXX]VSTA="YES"
       [M:STA1]STTFLG(nolign-1)=2
    Else
       [M:STA1]STTFLG(nolign-1)=1
    Endif
    [M:STA1]STTDAT(nolign-1)=format$("DZ<:YYYYMMDD",[BXX]VDAT)
    [M:STA1]STTHOU(nolign-1)=[BXX]VHEU
Next
[M:STA1]NBTAB = nolign 
Onerrgo
End


###################################################################################################
###################################################################################################
Subprog CHARGE_STA2(ERR)
Variable Integer ERR

Raz [M:STA2]
nolign = 0

Onerrgo ERR_SQL

For (Char VTAB(50),Char VIND(50),Char VSTA(50),Char VDAT(50),Char VHEU(50)) From '3' Sql
&  "SELECT table_name,index_name,DECODE(BLEVEL,null,'NO','YES'),"
& -"TO_CHAR(last_analyzed,'YYYYMMDD'),TO_CHAR(last_analyzed,'HH24:MI:SS')"
& -"From USER_INDEXES"
& -"where substr(index_name,1,6)!='SYS_IL'"
& -"Order BY 1,2"
&   As [BXX]
    nolign +=1
    [M:STA2]TAB(nolign-1)=[BXX]VTAB
    [M:STA2]INDEX(nolign-1)=[BXX]VIND
    If [BXX]VSTA="YES"
       [M:STA2]STTFLG(nolign-1)=2
    Else
       [M:STA2]STTFLG(nolign-1)=1
    Endif
    [M:STA2]STTDAT(nolign-1)=format$("DZ<:YYYYMMDD",[BXX]VDAT)
    [M:STA2]STTHOU(nolign-1)=[BXX]VHEU
Next
[M:STA2]NBINDEX = nolign 
Onerrgo
End

###################################################################################################
###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ERREUR(GMESSAGE) From GESECRAN
ERR=1
End

###################################################################################################
###################################################################################################
$ERR_SQL_STA3
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
If errn=75
    GMESSAGE += "\"+"V$PARAMETER"
Endif
Call ERREUR(GMESSAGE) From GESECRAN
ERR=1
End


###################################################################################################
###################################################################################################
Subprog CHARGE_STA3(ERR)
Variable Integer ERR
Raz [M:STA3]
nolign = 0

Onerrgo ERR_SQL_STA3

For (Char VNAM(50),Char VVAL(50),Char VDEF(50),Char VDES(250)) From '3' Sql
&  "SELECT v.name, v.value value,"
& -"DECODE(v.isDefault, 'TRUE', 'YES', 'FALSE', 'NO') , v.description"
& -"From V$PARAMETER v WHERE name not like 'nls%'"
& -"and name like 'opti%'"
& -"Order BY 1"
&   As [BZZ]
    nolign +=1
    [M:STA3]PAR(nolign-1)=[BZZ]VNAM
    [M:STA3]PARVAL(nolign-1)=[BZZ]VVAL
    If [BZZ]VDEF="YES"
       [M:STA3]DEFVAL(nolign-1)=2
    Else
       [M:STA3]DEFVAL(nolign-1)=1
    Endif
    [M:STA3]DES(nolign-1)=[BZZ]VDES
Next
[M:STA3]NBPAR = nolign 
Onerrgo
End

###################################################################################################
###################################################################################################
Subprog ACTUALISER_LIGNE(INDOBJ,ERR)
Variable Integer INDOBJ
Variable Integer ERR

Onerrgo ERR_LIG

If INDOBJ=1
    For (Char VTAB(50),Char VSTA(50),Char VDAT(50),Char VHEU(50)) From '3' Sql
&  "SELECT table_name,DECODE(blocks,null,'NO','YES'),"
& -"TO_CHAR(last_analyzed,'YYYYMMDD'),TO_CHAR(last_analyzed,'HH24:MI:SS')"
& -"From USER_TABLES"
& -"where TABLE_NAME='"+[M:STA1]TAB(nolign-1)+"'"
& -"Order BY 1"
&   As [BXX]
        [M:STA1]TAB(nolign-1)=[BXX]VTAB
        If [BXX]VSTA="YES"
           [M:STA1]STTFLG(nolign-1)=2
        Else
           [M:STA1]STTFLG(nolign-1)=1
        Endif
        [M:STA1]STTDAT(nolign-1)=format$("DZ<:YYYYMMDD",[BXX]VDAT)
        [M:STA1]STTHOU(nolign-1)=[BXX]VHEU
       Break
    Next
Else
    For (Char VTAB(50),Char VIND(50),Char VSTA(50),Char VDAT(50),Char VHEU(50)) From '3' Sql
&  "SELECT table_name,index_name,DECODE(BLEVEL,null,'NO','YES'),"
& -"TO_CHAR(last_analyzed,'YYYYMMDD'),TO_CHAR(last_analyzed,'HH24:MI:SS')"
& -"From USER_INDEXES"
& -"where substr(index_name,1,6)!='SYS_IL'"
& -"and INDEX_NAME='"+[M:STA2]INDEX(nolign-1)+"'"
& -"Order BY 1,2"
&   As [BXX]
        [M:STA2]TAB(nolign-1)=[BXX]VTAB
        [M:STA2]INDEX(nolign-1)=[BXX]VIND
        If [BXX]VSTA="YES"
           [M:STA2]STTFLG(nolign-1)=2
        Else
           [M:STA2]STTFLG(nolign-1)=1
        Endif
        [M:STA2]STTDAT(nolign-1)=format$("DZ<:YYYYMMDD",[BXX]VDAT)
        [M:STA2]STTHOU(nolign-1)=[BXX]VHEU
       Break
    Next
Endif
Onerrgo
End

###################################################################################################
###################################################################################################
Subprog GENERER_LIGNE(INDOBJ,ERR)
Variable Integer INDOBJ
Variable Integer ERR

Local Char SQLREQ (250)

Onerrgo ERR_LIG

SQLREQ = "BEGIN"
If INDOBJ=1
SQLREQ -= "dbms_stats.gather_table_stats(ownname=> '"+[M]DOSSIER+"', tabname=> '"+[M:STA1]TAB(nolign-1)+"');"
Else
SQLREQ -= "dbms_stats.gather_index_stats(ownname=> '"+[M]DOSSIER+"', indname=> '"+[M:STA2]INDEX(nolign-1)+"');"
Endif
SQLREQ -= "END;"

Execsql From "3" Sql SQLREQ

Onerrgo
End

###################################################################################################
###################################################################################################
Subprog SUPPRIMER_LIGNE(INDOBJ,ERR)
Variable Integer INDOBJ
Variable Integer ERR

Local Char SQLREQ (250)

Onerrgo ERR_LIG

SQLREQ = "BEGIN"
If INDOBJ=1
SQLREQ -= "dbms_stats.delete_table_stats(ownname=> '"+[M]DOSSIER+"', tabname=> '"+[M:STA1]TAB(nolign-1)+"');"
Else
SQLREQ -= "dbms_stats.delete_index_stats(ownname=> '"+[M]DOSSIER+"', indname=> '"+[M:STA2]INDEX(nolign-1)+"');"
Endif
SQLREQ -= "END;"

Execsql From "3" Sql SQLREQ

Onerrgo
End

###################################################################################################
###################################################################################################
$ERR_LIG
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ERREUR(GMESSAGE) From GESECRAN
ERR=1
End


