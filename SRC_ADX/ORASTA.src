######################################################################################
## Etiquette ajoutée par le superviseur (écran ORASTA1) 20/03/2006 14:25:06 (VPO)
######################################################################################
Subprog AM_PROFLG(VALEUR)
Variable Integer VALEUR
#Infbox "AM_PROFLG PROFLG="+num$([M]PROFLG(nolign-1))+ "VALEUR="+num$(VALEUR)
[M]PROFLG(nolign-1)=VALEUR
Affzo [M]PROFLG(nolign-1)
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran ORASTAB) 22/04/2008 16:48:54 (VPO)
######################################################################################
Subprog AM_CRE(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    Actzo [M]CASCADE
    Actzo [M]METHOPT
    Actzo [M]DEGREE
    Actzo [M]NDEGREE
Else
    Diszo [M]CASCADE
    Diszo [M]METHOPT
    Diszo [M]DEGREE
    Diszo [M]NDEGREE
Endif
End


