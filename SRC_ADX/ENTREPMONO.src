#  GOK = -1 : GLOCK = "$ADOVAL MONO" : Goto ROLL_MULTI
# Elsif fstat
#  GOK = 0 : Call RSTA("$ADOVAL","MONO") From GLOCK : Goto AB_MULTI
# Endif
# [F:ADW]VALEUR = "0"
# Rewrite [ADW]
# If fstat
