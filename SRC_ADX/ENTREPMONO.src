#################################################
## Test mono et passage en mono si possible
## ok=0 => impossible
## ok=1 => on y est déjà ou ghyper=1
## ok=2 => on est passé en mono (silencieux)
#################################################
Subprog TSTMONO(OK)
Variable Integer OK

Local Char    DOSSIER(GDIMFIC), VALEUR(1)
Local Char    APPLI(GDIMFIC), MACHINE(GDIMFIC)
Local Integer CAS

APPLI   = nomap(0)
MACHINE = adxmac(0)
If MACHINE=""
 DOSSIER = APPLI
Else
 DOSSIER = MACHINE+"@"+APPLI
Endif
VALEUR  = "1"
CAS     = 1
Goto TSTMONO0

Subprog TSTMONODOS(DOSSIER,VALEUR,OK)
Value    Char    DOSSIER()
Value    Char    VALEUR()
Variable Integer OK

Local Char    APPLI(GDIMFIC), MACHINE(GDIMFIC)
Local Integer CAS
CAS=2
Call MACHINE(DOSSIER,MACHINE,MACHINE) From ORDSYS
Goto TSTMONO0

$TSTMONO0
OK=0
If GHYPER=1
 OK=1
Else
 Onerrgo ERREUR From CONTROLE
  If DOSSIER=nomap(0) | DOSSIER=adxmac(0)+"@"+nomap(0)
   Local File ADOVAL [ADW]
  Else
   Local File =DOSSIER+".ADOVAL" [ADW]
  Endif
 Onerrgo
 If GERREUR : GERREUR=0 : End : Endif

 #107271
 Local Integer MONO
 Local Char WCHMONO(50)
 #Read [ADW]ADW0 = "";"";"MONO"
 #MONO = val([F:ADW]VALEUR)
 Local Integer ISHISTFOLD
 ISHISTFOLD=func DOSSUB.ISHISTFOLD(DOSSIER)
 If ISHISTFOLD
  Call GETPARHIS(DOSSIER,"MONO",WCHMONO) From SUBADS
 Else
  Call GETPAR(DOSSIER,"MONO",WCHMONO) From SUBADS
 Endif
 MONO=val(WCHMONO)
 If WCHMONO<>VALEUR
  If CAS=1
   Call MONO(OK)
  Else
   Call MONODOS(DOSSIER,VALEUR,OK)
  Endif
  If OK : OK=2 : Endif
 Else
  OK=1
 Endif
Endif
Close Local File
End

