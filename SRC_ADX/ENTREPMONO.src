#<AdxTL>@(#)51.0.0.0 $Revision$
###############################################
## Passage en Mono / Multi                  ###
###############################################
Subprog MONO(OK)
Variable Integer OK

Local Char DOSSIER(GDIMFIC), VALEUR(1)
Local Char APPLI(GDIMFIC), MACHINE(GDIMFIC)

APPLI   = nomap(0)
MACHINE = adxmac(0)
If MACHINE=""
 DOSSIER = APPLI
Else
 DOSSIER = MACHINE+"@"+APPLI
Endif
VALEUR  = "1"
Goto MONO0

Subprog MONODOS(DOSSIER,VALEUR,OK)
Value Char DOSSIER
Variable Integer OK
Value    Char    VALEUR()

Local Char APPLI(GDIMFIC), MACHINE(GDIMFIC)
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
Goto MONO0

$MONO0
OK=0
If APPLI=nomap & GPROFIL<>GSUPER & find(GUSER,GADMIN)=0
 Call ECR_TRACE(mess(145,124,1),1) From GESECRAN : End
# Fonction réservée à l'administrateur
Endif

If DOSSIER=nomap(0) or DOSSIER=adxmac(0)+"@"+nomap(0)
 Local File ADOVAL  [ADW]
 Local File AUTILIS [AUS]
Else
 Local File =DOSSIER+".ADOVAL"  [ADW]
 Local File =DOSSIER+".AUTILIS" [AUS]
Endif

#107271
Local Integer MONO
Local Char WCHMONO(50)
#Read [ADW]ADW0 = "";"";"MONO"
#MONO = val([F:ADW]VALEUR)
Local Integer ISHISTFOLD
ISHISTFOLD=func DOSSUB.ISHISTFOLD(DOSSIER)
If ISHISTFOLD
 Call GETPARHIS(DOSSIER,"MONO",WCHMONO) From SUBADS
Else
 Call GETPAR(DOSSIER,"MONO",WCHMONO) From SUBADS
Endif
MONO=val(WCHMONO)
#Read [ADW]ADW0 = "";"";"MONO"
#If fstat | val([F:ADW]VALEUR)>0
If MONO>0
 Case MONO
  When 2           : # Gestion de dossier
   Call ECR_TRACE(mess(146,124,1),1) From GESECRAN
  When 3           : # Sauvegarde
   Call ECR_TRACE(mess(147,124,1),1) From GESECRAN
  When 4           : # Récup.
   Call ECR_TRACE(mess(148,124,1),1) From GESECRAN
  When 5           : # R.A.Z.
   Call ECR_TRACE(mess(149,124,1),1) From GESECRAN
  When Default     : # Autres cas non répertoriés
   Call ECR_TRACE(mess(153,100,1),1) From GESECRAN
 Endcase
 End
Endif

Call VERROU(DOSSIER,"MONO",0) From GLOCK
If fstat=1
 # Modification en cours sur un autre poste
 Call ECR_TRACE(mess(10,100,1),1) From GESECRAN : End
Endif

Local Integer NBUSR
Local Char    LISTE(250)
Call USER_LISTE(APPLI,NBUSR,LISTE) From PSADX

If (APPLI=nomap & NBUSR>1) | (APPLI<>nomap & NBUSR>0)
 # Nombre d'utilisateurs connectés :
 Call ECR_TRACE(DOSSIER-mess(150,124,1)-num$(NBUSR)+"\"+LISTE,1) From GESECRAN
 Goto FIN_MONO
Endif
Call DEBTRANS From GLOCK
#107271
#Gosub TR_MONO
If ISHISTFOLD
 Call MAJPARHIS(DOSSIER,"MONO","1") From SUBADS
Else
 Call MAJPAR(DOSSIER,"MONO","1") From SUBADS
Endif
If GOK=1
 OK=1
Endif

$FIN_MONO
Call DEVERROU(DOSSIER,"MONO") From GLOCK
Close Local File
End

#$TR_MONO
#GOK=1
#Trbegin [ADW]
# Readlock [ADW]ADW0 = "";"";"MONO"
# If fstat=1
#  GOK = -1 : GLOCK = "$ADOVAL MONO" : Goto ROLL_MONO
# Elsif fstat
#  GOK = 0 : Call RSTA("$ADOVAL","MONO") From GLOCK : Goto AB_MONO
# Endif
# [F:ADW]VALEUR = "1"
# Rewrite [ADW]
# If fstat
#  GOK = 0 : Call FSTA("ADW") From GLOCK : Goto AB_MONO
# Endif
#Commit
#Return
#
#$AB_MONO
#Rollback
#Return
#
#$ROLL_MONO
#Rollback
#Call ROLL From GLOCK
#If GROLL : Return : Else : Goto TR_MONO : Endif

Subprog MULTI(OK)
Variable Integer OK

Local Char DOSSIER(GDIMFIC), APPLI(GDIMFIC), MACHINE(GDIMFIC)

APPLI   = nomap(0)
MACHINE = adxmac(0)
If MACHINE=""
 DOSSIER = APPLI
Else
 DOSSIER = MACHINE+"@"+APPLI
Endif
Goto MULTI0

Subprog MULTIDOS(DOSSIER,OK)
Value    Char    DOSSIER()
Variable Integer OK

Local Char APPLI(GDIMFIC), MACHINE(GDIMFIC)
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
Goto MULTI0

$MULTI0
OK=0
If APPLI=nomap & GPROFIL<>GSUPER & find(GUSER,GADMIN)=0
 Call ECR_TRACE(mess(145,124,1),1) From GESECRAN : End
# Fonction réservée à l'administrateur
Endif

Onerrgo ERREUR From CONTROLE
 If DOSSIER=nomap(0) | DOSSIER=adxmac(0)+"@"+nomap(0)
  Local File ADOVAL [ADW]
 Else
  Local File =DOSSIER+".ADOVAL" [ADW]
 Endif
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

Call VERROU(DOSSIER,"MONO",0) From GLOCK
If fstat=1
 Call ECR_TRACE(mess(10,100,1),1) From GESECRAN : End
Endif
Call DEBTRANS From GLOCK
#107271
#Gosub TR_MULTI
Local Integer ISHISTFOLD
ISHISTFOLD=func DOSSUB.ISHISTFOLD(DOSSIER)
If ISHISTFOLD
 Call MAJPARHIS(DOSSIER,"MONO","0") From SUBADS
Else
 Call MAJPAR(DOSSIER,"MONO","0") From SUBADS
Endif
If GOK=1
 OK=1
Endif

$FIN_MULTI
Call DEVERROU(DOSSIER,"MONO") From GLOCK
Close Local File
End

