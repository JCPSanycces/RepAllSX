#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UUMGTRTPUR05   Migration des Historiques de Commandes     Module Achats#
#                Commandes ouvertes                                      #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
    Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-06-12 by SR : adaptation
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTPUR05") From LECFIC
  Endif

  #Call RAZ_UUMGTRTPUR05(DOSSIER)
  Call MAJ_UUMGTRTPUR05(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

##########################################################################
Subprog RAZ_UUMGTRTPUR05(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  End
Endif

Local Char WNAMUOHM,WNAMUOPM,WNAMUOQM,WNAMUOCM
Call MIGTABNAME (DOSSIER,"UPORDER",WNAMUOHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"UPORDERP",WNAMUOPM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"UPORDERQ",WNAMUOQM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"UPORDERC",WNAMUOCM,ERR) From TRTMIG

If ERR
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMUOHM,"fde",[F:ADS]DOSSIER),0) < 0
  End
Endif
If filinfo(filpath("FIL",WNAMUOPM,"fde",[F:ADS]DOSSIER),0) < 0
  End
Endif
If filinfo(filpath("FIL",WNAMUOQM,"fde",[F:ADS]DOSSIER),0) < 0
  End
Endif
If filinfo(filpath("FIL",WNAMUOCM,"fde",[F:ADS]DOSSIER),0) < 0
  End
Endif

##2 - On vide les fichiers selon le cas
#######################################
Local Char REQTSQL (250) (2)
Local File =DOSSIER+".UPORDER"    [UOH]
Local File =DOSSIER+".UPORDERP"    [UOP]
Local File =DOSSIER+".UPORDERQ"    [UOQ]
Local File =DOSSIER+".UPORDERC"    [UOC]
Local File =DOSSIER+".CPTANALIN"   [CAL]

Onerrgo ERR_SQL
Trbegin [UOH]
REQTSQL(0)="DELETE FROM "-DOSSIER+".UPORDER WHERE POHTYP_0=2 "
Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
Onerrgo
Commit

Onerrgo ERR_SQL
Trbegin [UOP]
REQTSQL(0)="DELETE FROM "-DOSSIER+".UPORDERP WHERE POHTYP_0=2 "
Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
Onerrgo
Commit

Onerrgo ERR_SQL
Trbegin [UOQ]
REQTSQL(0)="DELETE FROM "-DOSSIER+".UPORDERQ WHERE POHTYP_0=2 "
Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
Onerrgo
Commit

Call MIGTABRAZ (DOSSIER,"UPORDERC",ERR) From TRTMIG

Onerrgo ERR_SQL
Trbegin [CAL]
REQTSQL(0)="DELETE FROM "-DOSSIER+".CPTANALIN WHERE ABRFIC_0='UOP' AND "
REQTSQL(1)="NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".UPORDER WHERE CPTANALIN.VCRNUM_0=UPORDER.POHNUM_0) "
Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
Onerrgo
Commit

##3 - On vide AMIGKEY pour le flux
####################

Call MIGRAZKEY (DOSSIER,"UUMGTRTPUR05",ERR) From TRTMIG

End

###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Call ECR_TRACE(REQTSQL,1) From GESECRAN
ERR=1
Resume

###################################################################################
Subprog MAJ_UUMGTRTPUR05(DOSSIER)
Value Char DOSSIER

# Issue 108760 - 2015-06-12 by SR : adaptation
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR05",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
# Issue 89740 - 2013-05-06 by MAE : Prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR05",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

Local Char WNAMUOHM,WNAMUOPM,WNAMUOQM,WNAMUOCM
Call MIGTABNAME (DOSSIER,"UPORDER",WNAMUOHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"UPORDERP",WNAMUOPM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"UPORDERQ",WNAMUOQM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"UPORDERC",WNAMUOCM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR05",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMUOHM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR05",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMUOPM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR05",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMUOQM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR05",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMUOCM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR05",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR05",2,ERR) From TRTMIG : #2=En cours
# Issue 108857 - 2015-06-15 by SR : Déplacé avant définition des variables qui utilisent adxwrb
Gosub MIG_OUVRE From TRTMIG

###################

Local Char WTAB_UOH (100) (adxwrb)
Local Char WTAB_UOP (100) (adxwrb)
Local Char WTAB_UOQ (100) (adxwrb)
Local Char WTAB_UOC (100) (adxwrb)
Local Char WTAB_PVF (100) (adxwrb)
Local Char WTAB_CAL (100) (adxwrb)
Local Shortint WCPT_UOH,WCPT_UOP,WCPT_UOQ,WCPT_UOC,WCPT_PVF,WCPT_CAL

Call ECR_TIME("UUMGTRTPUR05 Purchase Orders Contracts Process : Update UPORDER-C-P-Q") From DOSSUB
Call ECR_TRACE("UUMGTRTPUR05 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#

Call MIGTABINIT (DOSSIER,"UPORDER",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"UPORDERP",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"UPORDERQ",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"UPORDERC",ERR) From TRTMIG
##Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABINIT (DOSSIER,"CPTANALIN",ERR) From TRTMIG
#Call MIGTABINIT (DOSSIER,"PVCRFOOT",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:UOH])  = 0 : Local File =DOSSIER+".UPORDER"    [UOH]  : Endif   # Fichier X3 "Vide"
If clalev([F:UOP])  = 0 : Local File =DOSSIER+".UPORDERP"    [UOP]  : Endif   # Fichier X3 "Vide"
If clalev([F:UOQ])  = 0 : Local File =DOSSIER+".UPORDERQ"    [UOQ]  : Endif   # Fichier X3 "Vide"
If clalev([F:UOC])  = 0 : Local File =DOSSIER+".UPORDERC"    [UOC]  : Endif   # Fichier X3 "Vide"

If clalev([F:UOHM]) = 0 : Local File =DOSSIER+"."+WNAMUOHM   [UOHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:UOPM]) = 0 : Local File =DOSSIER+"."+WNAMUOPM   [UOPM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:UOQM]) = 0 : Local File =DOSSIER+"."+WNAMUOQM   [UOQM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:UOCM]) = 0 : Local File =DOSSIER+"."+WNAMUOCM   [UOCM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBLUS, NBCOMMIT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=5
Local Char TABMIGKEY(30)(1..NBMIGKEY)

Raz NBLUS, STOP, CRITERE, NBCOMMIT

Gosub OUVRE_PUR From UUMGTRTPUR00
Gosub OUVRE_POH From UUMGTRTPUR00
# Issue 88474 - 2013-05-06 by SR : Pour V6 et V7
Gosub OUVRE_PUR02 From UUMGTRTPUR02

# Déclaration des variables communes de travail
Local Integer I, J

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTPUR05",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

#-----  Lien des tables entête & lignes -----#
Link [UOHM] With [BPS]BPS0=[F:UOHM]BPSNUM As [LNK]
&    Order By Key CLE = [F:UOHM]POHTYP;[F:UOHM]POHFCY;[F:UOHM]POHNUM;[F:UOHM]REVNUM

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTPUR05" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_UOC00
Raz NB
If STOP = 1
 STOP = 2
 # Issue 88364 - 2013-03-04 by SR
 CRITERE = "[F:UOHM]POHTYP=2 & [F:UOHM]POHFCY=TABMIGKEY(2) & [F:UOHM]POHNUM=TABMIGKEY(3) & [F:UOHM]REVNUM>val(TABMIGKEY(4))"
Elsif STOP = 2
 STOP = 3
 CRITERE = "[F:UOHM]POHTYP=2 & [F:UOHM]POHFCY=TABMIGKEY(2) & [F:UOHM]POHNUM>TABMIGKEY(3)"
Elsif STOP=3
 STOP = 0
 CRITERE = "[F:UOHM]POHTYP=2 & [F:UOHM]POHFCY>TABMIGKEY(2)"
Else
 CRITERE = "[F:UOHM]POHTYP=2 "
Endif

Trbegin [UOH],[UOP], [UOQ], [UOC]
GOK = 1

For [LNK]CLE(4) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTPUR05" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLEPOC : Endif
  Endif

  #  version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
    Gosub RAZV6_UOH From UUMGTRTPUR04
  Endif
  #  version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
    Gosub RAZV7_UOH From UUMGTRTPUR04
  Endif
  [F:UOH] = [F:UOHM]

  If WSITE<>[F:UOH]POHFCY
    #----- Alimentation de la société sur l'entête de demande d'achat -----#
      Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:UOH]POHFCY) From TRTX3CPT
      WSITE=[F:UOH]POHFCY
  Endif

  [F:UOH]CPY=GSOCIETE
  #  version < V6, traitement v6
  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_AVUOH From UUMGTRTPUR04
    If GOK<1 : Break : Endif
  Endif
  #  version < V7, traitement v7
  If val(VERSION)<GMIGX3VER70
    Gosub MAJV7_AVUOH From UUMGTRTPUR04
    If GOK<1 : Break : Endif
  Endif

  [F:TB0]=[F:UOH]
  ############################
  #-- Boucle sur les lignes
  ############################
  Link [UOCM] With [ITM]ITM0=[F:UOCM]ITMREF As [LNKC]
  For [LNKC]POC0 Where POHNUM=[F:UOH]POHNUM & LINREVNUM=[F:UOH]REVNUM
    #rupture par ligne de facture
    #  version < V6, raz des champs v6
    If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_UOC
    Endif
    #  version < V7, raz des champs v7
    If val(VERSION)<GMIGX3VER70
      # Issue 96493 - 2014-02-04 by MUARN : obsolète en V7.1
      #Gosub RAZV7_UOC
    Endif
   # Issue 112754 - 2016-12-19 by SR : Services en V12
    #  version < V12, raz des champs v12
    If val(VERSION)<GMIGX3VER120
      Gosub RAZV12_UOC
    Endif
    [F:UOC] = [F:UOCM]

    #Appel proc de migration sur detail
    #  version < V6, raz des champs v6
    If val(VERSION)<GMIGX3VER60
      Gosub MAJV6_UOC
      If GOK<1 : Break : Endif
    Endif
#    #  version < V7, raz des champs v7
#    If val(VERSION)<GMIGX3VER70
#      # Issue 96493 - 2014-02-04 by MUARN : obsolète en V7.1
#      #Gosub MAJV7_UOC
#      If GOK<1 : Break : Endif
#    Endif
   # Issue 112754 - 2016-12-19 by SR : Services en V12
   #  version < V12, traitement v12
    If val(VERSION)<GMIGX3VER120
       Gosub MAJV12_UOC
       If GOK<1 : Break : Endif
    Endif
   # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#    If NEWMOTEUR
#        Gosub UOC_STK : # pour stocker ref
#        WriteB [UOC]
#    Else
#        Write [UOC]
#    Endif
#    If fstat
#        If NEWMOTEUR & adxwrb>1
#          Call ECR_TRACE("File UPORDERC, Error ="-num$(fstat),1) From GESECRAN
#          Gosub UOC_ERRTRA : # pour afficher les ref
#        Else
#          Call ECR_TRACE("File UPORDERC(POHNUM/LINREVNUM/POPLIN)"-[F:UOC]POHNUM-num$([F:UOC]LINREVNUM)-num$([F:UOC]POPLIN)+", Error ="-num$(fstat),1) From GESECRAN
#        Endif
#        GOK=0 : Break
#    Endif
     Gosub UOC_STK : # pour stocker ref
     WriteB [UOC]
     If fstat
        Call ECR_TRACE("File UPORDERC, Error ="-num$(fstat),1) From GESECRAN
        Gosub UOC_ERRTRA : # pour afficher les ref
        GOK=0 : Break
     Endif
     # End issue 108760
  Next
  If GOK<1 : Break : Endif
   # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#  If NEWMOTEUR & adxwrb>1
    Flush [F:UOP]
    If fstat
        Call ECR_TRACE("File UPORDERP, Error ="-num$(fstat),1) From GESECRAN
        Gosub UOP_ERRTRA From UUMGTRTPUR04 : # pour afficher les ref
        GOK=0
    Endif
 # Endif
 # End issue 108760
  If GOK<1 : Break : Endif

# Issue 112754 - 2017-01-27 by SR : Services
 #Appel proc de migration sur entete
  #  version < V7, traitement v7
  If val(VERSION)<GMIGX3VER120
    Gosub MAJ_UOH From UUMGTRTPUR04
    If GOK<1 : Break : Endif
  Endif

  # --- alimentation des champs et écriture enreg
   # --- alimentation des champs et écriture enreg
  # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#  If NEWMOTEUR
#      Gosub UOH_STK From UUMGTRTPUR04 : # pour stocker ref
#      WriteB [F:UOH]
#  Else
#      Write [F:UOH]
#  Endif
#  If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File UPORDER, Error ="-num$(fstat),1) From GESECRAN
#      Gosub UOH_ERRTRA From UUMGTRTPUR04 : # pour afficher les ref
#    Else
#      Call ECR_TRACE("File UPORDER(POHNUM/REVNUM)"-[F:UOH]POHNUM-num$([F:UOH]REVNUM)+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Break
#  Endif
   Gosub UOH_STK From UUMGTRTPUR04 : # pour stocker ref
   WriteB [F:UOH]
   If fstat
      Call ECR_TRACE("File UPORDER, Error ="-num$(fstat),1) From GESECRAN
      Gosub UOH_ERRTRA From UUMGTRTPUR04 : # pour afficher les ref
      GOK=0 : Break
   Endif
   # End issue 108760
  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = num$([F:UOHM]POHTYP)
    TABMIGKEY(2) = [F:UOHM]POHFCY
    TABMIGKEY(3) = [F:UOHM]POHNUM
    TABMIGKEY(4) = num$([F:UOHM]REVNUM)
    STOP=1
    Break
  Endif
$SUITE_BOUCLEPOC
Next

$FIN_BOUCLEUOC
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR05",7,ERR) From TRTMIG : #7=Erreur
Else
  # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#  If NEWMOTEUR & adxwrb>1
    Flush [F:UOH]
    If fstat
        Call ECR_TRACE("File UPORDER, Error ="-num$(fstat),1) From GESECRAN
        Gosub UOH_ERRTRA From UUMGTRTPUR04 : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEUOC : #on part sur rollback
    Endif
    Flush [F:UOP]
    If fstat
        Call ECR_TRACE("File UPORDERP, Error ="-num$(fstat),1) From GESECRAN
        Gosub UOP_ERRTRA From UUMGTRTPUR04 : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEUOC : #on part sur rollback
    Endif
    Flush [F:UOQ]
    If fstat
        Call ECR_TRACE("File UPORDERQ, Error ="-num$(fstat),1) From GESECRAN
        Gosub UOQ_ERRTRA From UUMGTRTPUR04 : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEUOC : #on part sur rollback
    Endif
    Flush [F:UOC]
    If fstat
        Call ECR_TRACE("File UPORDERC, Error ="-num$(fstat),1) From GESECRAN
        Gosub UOC_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEUOC : #on part sur rollback
    Endif
    Flush [F:PVF]
    If fstat
        Call ECR_TRACE("File PVCRFOOT, Error ="-num$(fstat),1) From GESECRAN
        Gosub PVF_ERRTRA From UUMGTRTPUR00: # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEUOC : #on part sur rollback
    Endif
    Flush [F:CAL]
    If fstat
        Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
        Gosub CAL_ERRTRA From UUMGTRTPUR00: # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEUOC : #on part sur rollback
    Endif
#  Endif
# End issue 108760
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTPUR05",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLEUOC
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTPUR05",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_UOC00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST
Filter [UOHM]

Close Local File [UOH], [UOP], [UOQ], [UOC]
Close Local File [UOHM], [UOPM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"UPORDER",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"UPORDERP",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"UPORDERQ",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"UPORDERC",ERR) From TRTMIG
##Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABEND (DOSSIER,"CPTANALIN",ERR) From TRTMIG
#Call MIGTABEND (DOSSIER,"PVCRFOOT",ERR) From TRTMIG
Call MIGTRTEND (DOSSIER,"UUMGTRTPUR05") From TRTMIG
Call ECR_TIME("UUMGTRTPUR05 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End


################################################
$UOC_STK
Call STK (WTAB_UOC,WCPT_UOC,[F:UOC]POHNUM-'/'-num$([F:UOC]LINREVNUM)-'/'-num$([F:UOC]POPLIN)) From TRTMIG
Return
##############################################################################################
$UOC_ERRTRA
Call ERRTRA (WTAB_UOC,WCPT_UOC,"File UPORDERC(POHNUM/LINREVNUM/POPLIN)=") From TRTMIG
Return

##############################################################################################
$RAZV6_UOC
Raz [F:UOC]COA
Raz [F:UOC]CPY
Raz [F:UOC]EECICT2
Raz [F:UOC]EECLOC2
Raz [F:UOC]EECNUM2
Raz [F:UOC]FFWADD2
Raz [F:UOC]FFWNUM2
Raz [F:UOC]ICTCTY2
Raz [F:UOC]LINACC
Raz [F:UOC]LINPURTYP
Return
##############################################################################################
$RAZV7_UOC
# Issue 96602 - 2014-02-07 by SR : rien en V7
Return
################################################
# Issue 112754 - 2016-12-19 by SR : Services en V12
$RAZV12_UOC
Raz [F:UOC]ITMKND
Return
##############################################################################################
$MAJV6_UOC
        WPOPLIN=[F:UOC]POPLIN
        #----- Chargement de la société -----#
        [F:UOC]CPY=[F:UOH]CPY
        #----- Chargement comptes et type d'achat -----#
        If [F:UOC]COA(0)="" & [F:UOC]LINACC(0)="" & [F:UOC]COA(1)="" & [F:UOC]LINACC(1)=""
          [F:TB1]=[F:UOH]
          [F:TB1]=[F:UOC]
          [F:TB1]LINPURTYP=max([F:UOC]LINPURTYP,1)
          #-----
          If dim([F:UOQM]LINACC)>0
            Filter [UOQM] Where POHNUM=[F:UOH]POHNUM & LINREVNUM=[F:UOH]REVNUM & POPLIN=WPOPLIN & (LINACC<>"" | LINCNA<>"")
          Else
            Filter [UOQM] Where POHNUM=[F:UOH]POHNUM & LINREVNUM=[F:UOH]REVNUM & POPLIN=WPOPLIN
          Endif
          Read [UOQM] POQ0 First
          If fstat
            Raz [F:UOQM]
          Else
            [F:TB1]=[F:UOQM]
          Endif
          Filter [UOQM]
          #-----
          If dim([F:UOQM]LINACC)>0 & ([F:UOQM]LINACC<>"" | [F:UOQM]LINCNA<>"")
            Raz TPLAN, TCOMPTE
            TPLAN(1)  =GCOA(1)
            TCOMPTE(1)=[F:UOQM]LINACC
            TPLAN(2)  =GCOA(2)
            TCOMPTE(2)=[F:UOQM]LINCNA
            TPLAN(3)  =GCOA(3)
            WPURTYP   =max([F:UOQM]LINPURTYP,1)
          Else
            #----- Chargement table liée UPORDERP pour la pièce auto PORD -----#
            Read [UOPM] POP0(3)=[F:UOH]POHNUM;[F:UOH]REVNUM;WPOPLIN
            If fstat
              Raz [F:UOPM]
            Endif
            [G:UOPM]currind=1 : [G:UOPM]currlen=0 : # Réinitialisation clé par défaut
            If [F:UOPM]POHNUM=""
              [F:UOPM]=[F:UOH]
              [F:UOPM]=[F:UOC]
              Gosub LECT_ITMUOC
              For I=0 To dim([F:UOPM]TSICOD)-1
                [F:UOPM]TSICOD(I)=[F:ITM]TSICOD(I)
              Next I
              Gosub ALIVATCOD
            Endif
            #----- Chargement table liée CPTANALIN pour la pièce auto PORD -----#
            Raz [F:TB2]
            [F:TB2]ABRFIC="UOP"
            [F:TB2]VCRNUM=[F:UOH]POHNUM
            [F:TB2]VCRLIN=WPOPLIN
            [F:TB2]VCRSEQ=[F:UOPM]POPSEQ
            [F:TB2]CPLCLE=num$([F:UOPM]LINREVNUM)
            [F:TB2]ANALIG=1
            For I=1 To max(GNBCOA,2)
              [F:TB2]LED(I-1)=GLEDSOC(I)
              [F:TB2]COA(I-1)=GCOA(I)
              [F:TB2]ACC(I-1)=""
            Next I
            For I=1 To max(GNBDIE,GOPTCANA)
              [F:TB2]DIE(I-1)=GDIE(I)
              Case I
              When 1 : [F:TB2]CCE(I-1)=[F:UOPM]CCE1
              When 2 : [F:TB2]CCE(I-1)=[F:UOPM]CCE2
              When 3 : [F:TB2]CCE(I-1)=[F:UOPM]CCE3
              When 4 : [F:TB2]CCE(I-1)=[F:UOPM]CCE4
              When 5 : [F:TB2]CCE(I-1)=[F:UOPM]CCE5
              When 6 : [F:TB2]CCE(I-1)=[F:UOPM]CCE6
              When 7 : [F:TB2]CCE(I-1)=[F:UOPM]CCE7
              When 8 : [F:TB2]CCE(I-1)=[F:UOPM]CCE8
              When 9 : [F:TB2]CCE(I-1)=[F:UOPM]CCE9
              When Default
              Endcase
            Next I
            #----- Recherche comptes et type d'achat -----#
            Raz ID1,ID2
            #Call COMPTE("PORD",1,ID1,ID2,TPLAN,TCOMPTE,STAT,WMSG) From TRTACHCDE1
            #If STAT
            #  Raz TPLAN, TCOMPTE
            #  WPURTYP=1
            #Else
            #  If [F:GAC]COA<>TPLAN(1) | [F:GAC]ACC<>TCOMPTE(1)
            #    Read [GAC] GAC0=TPLAN(1);TCOMPTE(1) : If fstat  Raz [F:GAC] : Endif
            #  Endif
            #  If [F:GAC]VATIPT=5
            #    WPURTYP=3
            #  Elsif [F:GAC]VATIPT=4
            #    WPURTYP=2
            #  Else
            #    WPURTYP=1
            #  Endif
            #Endif
            Raz TPLAN, TCOMPTE : WPURTYP=1
          Endif
          #-----
          Raz [F:UOC]COA, [F:UOC]LINACC
          For I=1 To 10
            If TPLAN(I)<>""
              J=find(TPLAN(I),GCOA(1..GNBCOA))
              If J
                [F:UOC]COA(J-1)   =GCOA(J)
                [F:UOC]LINACC(J-1)=TCOMPTE(I)
              Endif
            Endif
          Next I
          [F:UOC]LINPURTYP=WPURTYP
        Endif
        #----- Chargement des informations douanières -----#
        If [F:UOC]EECICT2=""  [F:UOC]EECICT2=[L]WEECICT : Endif : # Incoterm
        If GACTDEB=2
          If [F:UOC]EECLOC2=0 [F:UOC]EECLOC2=[L]WEECLOC : Endif : # Lieu de transport CEE
          If [F:UOC]EECNUM2=""
            Gosub LECT_BPRI From UUMGTRTPUR04
            [F:UOC]EECNUM2=[F:BPR]EECNUM : # Identification CEE
          Endif
        Endif
        #---------Traitement des POP--------------#
        Gosub BOUCLE_UOP
        If GOK<1 : Return : Endif
Return
# Issue 112754 - 2017-01-27 by SR : Inutile en passage en V12
###############################################################################################
#$MAJV7_UOC
## Issue 96602 - 2014-02-07 by SR : rien en V7
## Issue 111289 - 2015-09-25 by SR : copier à minima POPM dans POP
## Issue 111478 - 2015-10-08 by SR : Si version < V6, la copie a déjà été faite pour passer en V6, donc on ne le refait pas
#If val(VERSION) >= GMIGX3VER60 & val(VERSION) < GMIGX3VER70
#  Gosub BOUCLE_UOP
#  If GOK<1 : Return : Endif
#Endif
#
#Return
# Issue 112754 - 2016-12-19 by SR : Services en v12
########################################################################
$MAJV12_UOC
[F:UOC]ITMKND = 1
  # Si version < V6, la copie a déjà été faite pour passer en V6, donc on ne le refait pas
  # sinon, il faut au moins récupérer les enreg POP
  If val(VERSION) >= GMIGX3VER60 & val(VERSION) < GMIGX3VER120
     Gosub BOUCLE_UOP
  Endif
Return
##############################################################################################

$BOUCLE_UOP
  For [UOPM] POP0 Where POHNUM=[F:UOC]POHNUM & LINREVNUM=[F:UOC]LINREVNUM & POPLIN=[F:UOC]POPLIN
      #  version < V6, raz des champs v6
      If val(VERSION)<GMIGX3VER60
        Gosub RAZV6_UOP From UUMGTRTPUR04
      Endif
      #  version < V7, raz des champs v7
      If val(VERSION)<GMIGX3VER70
        Gosub RAZV7_UOP From UUMGTRTPUR04
      Endif
      [F:UOP] = [F:UOPM]

      #Appel proc de migration sur detail
      #  version < V6, traitement v6
      If val(VERSION)<GMIGX3VER60
        Gosub MAJV6_UOP From UUMGTRTPUR04
        If GOK<1 : Break : Endif
      Endif
      #  version < V7, traitement v7
      If val(VERSION)<GMIGX3VER70
        Gosub MAJV7_UOP From UUMGTRTPUR04
        If GOK<1 : Break : Endif
      Endif

      #----- Création lignes comptables analytiques pour commandes ouvertes -----#
      Gosub WRITE_CAL_UOC
      If GOK<1 : Break : Endif
      # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#      If NEWMOTEUR
#          Gosub UOP_STK From UUMGTRTPUR04 : # pour stocker ref
#          WriteB [UOP]
#      Else
#          Write [UOP]
#      Endif
#      If fstat
#          If NEWMOTEUR & adxwrb>1
#            Call ECR_TRACE("File UPORDERP, Error ="-num$(fstat),1) From GESECRAN
#            Gosub UOP_ERRTRA From UUMGTRTPUR04 : # pour afficher les ref
#          Else
#            Call ECR_TRACE("File UPORDERP(POHNUM/LINREVNUM/POPLIN/POPSEQ)="-[F:UOP]POHNUM-num$([F:UOP]LINREVNUM)-num$([F:UOP]POPLIN)-num$([F:UOP]POPSEQ)+", Error ="-num$(fstat),1) From GESECRAN
#          Endif
#          GOK=0 : Break
#      Endif
       Gosub UOP_STK From UUMGTRTPUR04 : # pour stocker ref
       WriteB [UOP]
       If fstat
          Call ECR_TRACE("File UPORDERP, Error ="-num$(fstat),1) From GESECRAN
          Gosub UOP_ERRTRA From UUMGTRTPUR04 : # pour afficher les ref
          GOK=0 : Break
       Endif
       # End issue 108760
  Next
Return

$WRITE_CAL_UOC
  Raz [F:CAL]
  [F:CAL]ABRFIC="UOP"
  [F:CAL]VCRNUM=[F:UOP]POHNUM
  [F:CAL]VCRLIN=[F:UOP]POPLIN
  [F:CAL]VCRSEQ=[F:UOP]POPSEQ
  [F:CAL]CPLCLE=num$([F:UOP]LINREVNUM)
  [F:CAL]ANALIG=1
  For I=1 To max(GNBCOA,2)
    [F:CAL]LED(I-1)=GLEDSOC(I)
    [F:CAL]COA(I-1)=GCOA(I)
    [F:CAL]ACC(I-1)=[F:UOC]LINACC(I-1)
  Next I
  For I=1 To max(GNBDIE,GOPTCANA)
    [F:CAL]DIE(I-1)=GDIE(I)
    ###If evalue("dim([F:UOPM]CCE"+num$(I)+")")>0
    ###  [F:CAL]CCE(I-1)=evalue("[F:UOPM]CCE"+num$(I))
    ###Endif
    Case I
    When 1 : [F:CAL]CCE(I-1)=[F:UOPM]CCE1
    When 2 : [F:CAL]CCE(I-1)=[F:UOPM]CCE2
    When 3 : [F:CAL]CCE(I-1)=[F:UOPM]CCE3
    When 4 : [F:CAL]CCE(I-1)=[F:UOPM]CCE4
    When 5 : [F:CAL]CCE(I-1)=[F:UOPM]CCE5
    When 6 : [F:CAL]CCE(I-1)=[F:UOPM]CCE6
    When 7 : [F:CAL]CCE(I-1)=[F:UOPM]CCE7
    When 8 : [F:CAL]CCE(I-1)=[F:UOPM]CCE8
    When 9 : [F:CAL]CCE(I-1)=[F:UOPM]CCE9
    When Default
    Endcase
  Next I
  # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#  If NEWMOTEUR
#      Gosub CAL_STK From UUMGTRTPUR00 : # pour stocker ref
#      WriteB [F:CAL]
#  Else
#      Write [F:CAL]
#  Endif
#  If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
#      Gosub CAL_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
#    Else
#    Call ECR_TRACE("File CPTANALIN UOP 0"-[F:UOP]POHNUM-num$([F:UOP]POPLIN)+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Return
#  Endif
   Gosub CAL_STK From UUMGTRTPUR00 : # pour stocker ref
   WriteB [F:CAL]
   If fstat
      Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
      Gosub CAL_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
      GOK=0 : Return
   Endif
   # End issue 108760
Return
#############################################
# Alimentation des codes taxes dans [F:UOP] #
#############################################
$ALIVATCOD
    If [F:ITM]VACITM(0)<>""
      WJTVC=find([F:BPS]VACBPR+'/'+[F:ITM]VACITM(0),WTVCCLE(0..NBTVC))
      If WJTVC>0
        [F:UOP]VAT(0)=WTVCVAT(WJTVC-1)
      Endif
    Endif
    If [F:ITM]VACITM(1)<>""
      WJTVC=find([F:BPS]VACBPR+'/'+[F:ITM]VACITM(1),WTVCCLE(0..NBTVC))
      If WJTVC>0
        [F:UOP]VAT(1)=WTVCVAT(WJTVC-1)
      Endif
    Endif
    If [F:ITM]VACITM(2)<> ""
      WJTVC=find([F:BPS]VACBPR+'/'+[F:ITM]VACITM(2),WTVCCLE(0..NBTVC))
      If WJTVC>0
        [F:UOP]VAT(2)=WTVCVAT(WJTVC-1)
      Endif
    Endif
Return

$LECT_ITMUOC
  If [F:ITM]ITMREF<>[F:UOC]ITMREF
    WITM=[F:UOC]ITMREF
    Gosub LECT_ITM From UUMGTRTPUR04
  Endif
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 108760 - 2015-06-12 by SR : adaptation
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif

Call MAJ_UUMGTRTPUR05(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTPUR05(APPLI)
End

