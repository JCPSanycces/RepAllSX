#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* LECTRA - Retrieve the sequence counter code based on module, company and legislation.
#* Also return whether sequence is manual or not. Based on table TABCOUAFF.
#*
#* @param CONTEXT - Instance context (e.g., this.ACTX) - (is mandatory)
#* @param MODULE - The module number from local menu - (is mandatory)
#* @param CPY - Company
#* @param LEG - Legislation
#* @param DOC_INDEX - Document type - (is mandatory)
#* @param SEQ_CODE - Sequence code
#* @param SEQ_ISMANUAL - Sequence is manual ([V]CST_AYES, [V[CSTANO)
#* @param MESSAGE - If no error then blank, otherwise error message
#*
#* @return LECTCA - Success = [V]CST_ATRUE, Failure = [V]CST_AFALSE. Failure means unable to retrieve
#* Sequence code
#*
#*!
Funprog LECTCA(CONTEXT, MODULE, CPY, LEG, DOC_INDEX, SEQ_CODE, SEQ_ISMANUAL, MESSAGE)
Value Instance CONTEXT Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Integer MODULE
Value Char CPY(), LEG()
Value Integer DOC_INDEX
Variable Char SEQ_CODE()
Variable Integer SEQ_ISMANUAL
Variable Char MESSAGE()

Local Integer OK                   # OK is the funprog return status (true or false)
Local Integer FOUND                # Found indicates sequence row found
Local Char LECTCA_LEG(30)          # LECTCA legislation is equal to the company or the passed legislation
[L]OK = [V]CST_ATRUE

Gosub LECTCA_CONTROL_PARAMS
If [L]OK             : Gosub LECTCA_INIT           : Endif
If [L]OK & ![L]FOUND : Gosub LECTCA_CPY            : Endif
If [L]OK & ![L]FOUND : Gosub LECTCA_LEG            : Endif
If [L]OK & ![L]FOUND : Gosub LECTCA_MODULE         : Endif

If [L]OK & ![L]FOUND : Gosub LECTCA_NOFOUND        : Endif
If [L]OK             : Gosub LECTCA_RETURN_PARAMS  : Endif

End [L]OK

#**
#*  LECTCA_CONTROL_PARAMS - Validate parameters passed are set correctly
#*!
$LECTCA_CONTROL_PARAMS
If [L]MODULE<=0 | [L]DOC_INDEX<=0
  # If module or DOC_INDEX are set 0 or less then issue error (these two params are mandatory)
  [L]OK=[V]CST_AFALSE
  If [L]MODULE <= 0
    # The module is mandatory ti search for a counter code
    [L]MESSAGE = mess(267,133,1)
  Else
    # The type of document is mandatory to search for a counter code
    [L]MESSAGE = mess(268,133,1)
  Endif
Endif
If [L]OK=[V]CST_ATRUE & [L]LEG<>AVOID.ACHAR
  If [L]CPY<>AVOID.ACHAR & [L]LEG<>fmet CONTEXT.ACACHE.ACPY.AGETVALCHAR([L]CPY, "LEG")
    [L]OK = [V]CST_AFALSE
    # "The legislation $1$ does not correspond to legislation $2$ of the company $3$."
    [L]MESSAGE = func ASYRFNC.MES3(mess(269,133,1),[L]LEG,fmet CONTEXT.ACACHE.ACPY.AGETVALCHAR([L]CPY, "LEG"),[L]CPY)
  Endif
Endif
Return

#**
#* Initialize
#*!
$LECTCA_INIT
[L]FOUND = [V]CST_AFALSE      # Found indicates sequence found

Raz [L]SEQ_ISMANUAL, [L]SEQ_CODE, [L]MESSAGE

# Open TABCOUAFF - Sequence number assignments
Local File =CONTEXT.AFOLDER+".TABCOUAFF" [TCA]

# Determine which legislation to use when company is blank or not blank
If [L]CPY<>AVOID.ACHAR
  [L]LECTCA_LEG = fmet CONTEXT.ACACHE.ACPY.AGETVALCHAR([L]CPY, "LEG")
Else
  [L]LECTCA_LEG = [L]LEG
Endif
Return

#**
#* LECTCA_CPY - Lookup sequence based on company
#*!
$LECTCA_CPY
If [L]CPY<>AVOID.ACHAR
  Read [F:TCA]TCA0 = [L]MODULE;AVOID.ACHAR;[L]CPY
  If fstat = [V]CST_AOK
    [L]FOUND=[V]CST_ATRUE
  Endif
Endif
Return

#**
#* LECTCA_LEG - Lookup sequence based on legislation when CPY is not supplied and legislation is supplied
#*!
$LECTCA_LEG
If [L]LECTCA_LEG<>AVOID.ACHAR
  Read [F:TCA]TCA0 = [L]MODULE;[L]LECTCA_LEG;AVOID.ACHAR
  If fstat = [V]CST_AOK
    [L]FOUND=[V]CST_ATRUE
  Endif
Endif
Return

#**
#* LECTCA_MODULE - Lookup sequence based on module
#*!
$LECTCA_MODULE
Read [F:TCA]TCA0=MODULE;AVOID.ACHAR;AVOID.ACHAR
If fstat = [V]CST_AOK
  [L]FOUND=[V]CST_ATRUE
Endif
Return

#**
#* LECTCA_NOFOUND - Lookups all failed then set error and message
#*!
$LECTCA_NOFOUND
[L]OK=[V]CST_AFALSE
# Problem upon counter assignment: counter empty
[L]MESSAGE = mess(270,133,1)
Return

#**
#* LECTCA_RETURN_PARAMS- sets the return parameters based on TCA row already read in previous routines
#*!
$LECTCA_RETURN_PARAMS
 # check DOC_INDEX is in bounds
If dim([F:TCA]CODNUM) >= DOC_INDEX & [F:TCA]CODNUM(DOC_INDEX-1)<>AVOID.ACHAR
  [L]SEQ_CODE     = [F:TCA]CODNUM(DOC_INDEX-1)
  [L]SEQ_ISMANUAL = [F:TCA]MANCOU(DOC_INDEX-1)
Else
  [L]OK=[V]CST_AFALSE
  [L]MESSAGE = mess(270,133,1)
Endif
Return
