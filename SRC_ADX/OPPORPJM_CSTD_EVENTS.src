#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Classe OPPORPJM
#######################################################################################
# EVENTS
#######################################################################################
$AINSERT_CONTROL_BEFORE
  Gosub AINSERT_AUPDATE_CONTROL_BEFORE
  [L]ASTATUS = max([L]ASTATUS, fmet this.CDIE_INSERT())
Return

#######################################################################################
$AUPDATE_CONTROL_BEFORE
  Gosub AINSERT_AUPDATE_CONTROL_BEFORE
  If this.TCHACTION <> "CLOSING" Then
    If this.OPPSTATE = 4 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
  If this.OPPIMPT <> this.snapshot.OPPIMPT Then
    If fmet this.BUD_COUNT() > 0 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPPIMPT", mess(210,2260,1), [V]CST_AERROR))
    Endif
  Endif
  If [L]ASTATUS = [V]CST_AOK Then
    If this.OPPSTATE <> 1 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.BUD_ENABLE_ALL())
    Endif
  Endif
Return

#######################################################################################
# To write it one time
$AINSERT_AUPDATE_CONTROL_BEFORE
Local Integer NI
Local Integer IBUDIDX
Local Integer IBUDIDXDAD
Local Integer ITASPAEIDX
Local Integer ITASIDX

  # ---------------------------------------
  [L]ASTATUS = fmet this.PROJECT_PROPAGATE_OPPSTATE()
  # ---------------------------------------
  For NI = 1 To maxtab(this.BUD)
    If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.BUD(NI).OPPNUM = "" Then
        this.BUD(NI).OPPNUM = this.OPPNUM
      Endif
    Endif
  Next NI
  # ---------------------------------------
  For NI = 1 To maxtab(this.TAS)
    If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.TAS(NI).OPPNUM = "" Then
        this.TAS(NI).OPPNUM = this.OPPNUM
      Endif
    Endif
  Next NI
  # ---------------------------------------
  For NI = 1 To maxtab(this.TAS)
    If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ANEW,[V]CST_AUPD) <> 0 Then
      If this.TAS(NI).PBUCOD = AVOID.ACHAR and this.TAS(NI).TASBUDAUT = [V]CST_AYES Then
        IBUDIDX = fmet this.BUD_GET_INDEX(this.TAS(NI).TASCOD)
        If IBUDIDX = 0 Then
          # The budget is not existing : we have to create it
          IBUDIDX = fmet this.ADDLINE("BUD", [V]CST_ALASTPOS)
          If IBUDIDX <> [V]CST_ANOTDEFINED Then
            # 1°) Create the new budget
            this.BUD(IBUDIDX).PBUFCY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.TAS(NI).TASFCY, "FINRSPFCY")
            this.BUD(IBUDIDX).PBUCOD = this.TAS(NI).TASCOD
            this.BUD(IBUDIDX).PBUSOR = this.TAS(NI).TASSOR # Issue X3-91329 - 2018-06-01 by FGR
            this.BUD(IBUDIDX).PIMPL.PIMDESAXX = this.TAS(NI).PIMPL.PIMDESAXX
            If this.TAS(NI).TASPAE <> AVOID.ACHAR Then
              IBUDIDXDAD = fmet this.BUD_GET_INDEX(this.TAS(NI).TASPAE)
              If IBUDIDXDAD > 0 Then
                this.BUD(IBUDIDX).PBUPAE = this.TAS(NI).TASPAE
              Endif
              # ------------------------------------
              ITASPAEIDX = fmet this.TAS_GET_INDEX(this.TAS(NI).TASPAE)
              If ITASPAEIDX > 0 Then
                If this.TAS(ITASPAEIDX).PBUCOD <> AVOID.ACHAR Then
                  this.TAS(ITASPAEIDX).PBUCOD = AVOID.ACHAR
                Endif
              Endif
              # ------------------------------------
            Endif
            # 2°) Link the task to the new budget
            this.TAS(NI).PBUCOD = this.BUD(IBUDIDX).PBUCOD
          Endif
        Endif
      Endif
    Endif
  Next NI
  # ---------------------------------------
  ITASIDX = fmet this.TAS_MIN_STRDAT()
  If ITASIDX > 0 Then
    If this.STRDAT = AVOID.ADATE or this.STRDAT > this.TAS(ITASIDX).TASSTARTDT Then
      # ---------------------------------------
      If this.STRDAT <> this.snapshot.STRDAT Then
        # Need to do like that because if next line is only once after the "Endif", warning message is erased by supervisor ?
        this.STRDAT = this.TAS(ITASIDX).TASSTARTDT
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("STRDAT", func AFNC.MES3(mess(987,2260,1), format$(GFMDAT,
&            this.TAS(ITASIDX).TASSTARTDT), this.TAS(ITASIDX).TASCOD, format$(GFMDAT, this.TAS(ITASIDX).TASSTARTDT)), [V]CST_AWARNING))
      Else
        this.STRDAT = this.TAS(ITASIDX).TASSTARTDT
      Endif
      # ---------------------------------------
    Endif
  Endif
  # ---------------------------------------
  ITASIDX = fmet this.TAS_MAX_ENDDAT()
  If ITASIDX > 0 Then
    If this.ENDDAT = AVOID.ADATE or this.ENDDAT < this.TAS(ITASIDX).TASENDDT Then
      If this.ENDDAT <> this.snapshot.ENDDAT Then
        # Need to do like that because if next line is only once after the "Endif", warning message is erased by supervisor ?
        this.ENDDAT = this.TAS(ITASIDX).TASENDDT
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ENDDAT", func AFNC.MES3(mess(988,2260,1), format$(GFMDAT,
&            this.TAS(ITASIDX).TASENDDT), this.TAS(ITASIDX).TASCOD, format$(GFMDAT, this.TAS(ITASIDX).TASENDDT)), [V]CST_AWARNING))
      Else
        this.ENDDAT = this.TAS(ITASIDX).TASENDDT
      Endif
    Endif
  Endif
  # ---------------------------------------
Return

#######################################################################################
$ACONTROL
Local Integer NI
Local Integer NE
Local Integer NFOUND
#Local Integer ICOUNT
Local Integer ILINE
Local Char SFCYCPYSAL(GLONCPY)
Local Char SFCYCPYOPE(GLONCPY)
Local Integer ITASIDX

  # Careful in ACONTROL method, it's impossible to modify a class property value.
  # You only can make control here.
  # To change value, you have to use adapted methods (ie AINSERT_CONTROL_BEFORE)
  # Dependig of your need.
  If this.APARENT = null Then
    [L]ASTATUS = fmet this.SETERROR("", mess(192,2260,1), [V]CST_AFATAL)
    Return
  Endif
  # ---------------------------------------
  If this.SALFCY <> this.OPEDEFFCY Then
    SFCYCPYSAL = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.SALFCY, "LEGCPY")
    SFCYCPYOPE = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.OPEDEFFCY, "LEGCPY")
    If SFCYCPYSAL <> SFCYCPYOPE Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPEDEFFCY", mess(325,2260,1), [V]CST_AERROR))
    Endif
  Endif
  # ---------------------------------------
  If this.OPPSTATE <> 1 Then
    If this.OPPMOD = [V]CST_AYES Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(446,2260,1), [V]CST_AERROR))
    Endif
  Endif
  # ---------------------------------------
  ITASIDX = fmet this.TAS_MIN_STRDAT()
  If ITASIDX > 0 Then
    If this.STRDAT <> AVOID.ADATE and this.STRDAT > this.TAS(ITASIDX).TASSTARTDT Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("STRDAT", func AFNC.MES2(mess(992,2260,1),
&           format$(GFMDAT, this.TAS(ITASIDX).TASSTARTDT), this.TAS(ITASIDX).TASCOD), [V]CST_AERROR))
    Endif
  Endif
  # ---------------------------------------
  ITASIDX = fmet this.TAS_MAX_ENDDAT()
  If ITASIDX > 0 Then
    If this.ENDDAT <> AVOID.ADATE and this.ENDDAT < this.TAS(ITASIDX).TASENDDT Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("ENDDAT", func AFNC.MES2(mess(993,2260,1),
&           format$(GFMDAT, this.TAS(ITASIDX).TASENDDT), this.TAS(ITASIDX).TASCOD), [V]CST_AERROR))
    Endif
  Endif
  # ---------------------------------------
  If this.STRDAT <> AVOID.ADATE and this.ENDDAT <> AVOID.ADATE Then
    If this.STRDAT > this.ENDDAT Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("STRDAT", mess(289,2260,1), [V]CST_AERROR))
      Return
    Endif
  Endif
Return

#######################################################################################
$AUPDATE_AFTER
  [L]ASTATUS = max([L]ASTATUS, fmet this.CDIE_UPDATE())
  # Issue X3-101833 - 2018-07-30 by FGR : BEGIN
  If [L]ASTATUS < [V]CST_AERROR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.TAS_RITT_CLOSE_MANUF_PART())
  Endif
  # Issue X3-101833 - 2018-07-30 by FGR : END
Return

#######################################################################################
$ADELETE_AFTER
  [L]ASTATUS = max([L]ASTATUS, fmet this.CDIE_DELETE())
Return

#######################################################################################
$ADELETE_CONTROL_BEFORE
  If this.APARENT = null Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(193,2260,1), [V]CST_AFATAL))
    Return
  Endif
  If this.OPPSTATE <> 1 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(1143,196,1), [V]CST_AERROR))
  Endif
  If fmet this.BUD_COUNT() > 0 or fmet this.TAS_COUNT() > 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(1143,196,1), [V]CST_AERROR))
  Endif
Return

#######################################################################################
$BUD_ACONTROL
Local Integer ISTATUS
Local Integer ILINE
Local Integer ICOUNT
Local Char SFCYCPYDAD(GLONCPY)
Local Char SFCYCPYBUD(GLONCPY)

  # ---------------------------------------
  If this.APARENT.TCHACTION = "" Then
    If this.APARENT.OPPSTATE = 4 Then
      # A budget can't be update on a closed project
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(200,2260,1), [V]CST_AERROR))
    Endif
  Endif
  # ---------------------------------------
  If this.PBUFCY <> this.APARENT.SALFCY Then
    # Site can be changed, but must be on the same company than the parent site
    SFCYCPYDAD = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.APARENT.SALFCY, "LEGCPY")
    SFCYCPYBUD = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.PBUFCY, "LEGCPY")
    If SFCYCPYDAD <> SFCYCPYBUD Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUFCY", func AFNC.MES1(mess(322,2260,1), this.PBUCOD), [V]CST_AERROR))
    Endif
  Endif
  # ---------------------------------------
  If this.CUR <> this.APARENT.CUR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("CUR", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.OPPCMP <> this.APARENT.OPPCMP Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPPCMP", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.TCHOPPIMPT <> this.APARENT.OPPIMPT Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TCHOPPIMPT", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.TCHCHGTYP <> this.APARENT.TCHCHGTYP Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TCHCHGTYP", mess(18,9804,1), [V]CST_AERROR))
  Endif
  # ---------------------------------------
  If (this.ASTALIN = [V]CST_ANEW and this.PBUPAE <> AVOID.ACHAR) or (this.ASTALIN = [V]CST_AUPD and this.PBUPAE <> this.snapshot.PBUPAE) Then
    # The parent code can't be defined for a closed budget, or for a budget which have at least one budget line
    ILINE = fmet this.APARENT.BUD_GET_INDEX(this.PBUPAE)
    If ILINE > 0 Then
      # ---------------------------------------
      If this.APARENT.BUD(ILINE).PBUSTATE = 4 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUPAE", func AFNC.MES1(mess(212,2260,1), this.PBUPAE), [V]CST_AERROR))
      Endif
      # ---------------------------------------
      If this.APARENT.OPPIMPT = [V]CST_ANO Then
        ICOUNT = fmet this.APARENT.BUD(ILINE).BUDLIG_COUNT()
        If ICOUNT > 0 Then
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUPAE", func AFNC.MES2(mess(211,2260,1), this.PBUPAE, this.PBUCOD), [V]CST_AERROR))
        Endif
        If this.APARENT.BUD(ILINE).PBUIMP = [V]CST_ANO Then
          If func PJMTIMEMP_CSTD_PROGS.IS_PJMTEMEMP_FOR_BUD(this.OPPNUM, this.PBUPAE) = [V]CST_AYES Then
            [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUPAE", func AFNC.MES1(mess(419,2260,1), this.PBUPAE), [V]CST_AERROR))
          Endif
        Endif
      Endif
      # ---------------------------------------
    Endif
  Endif
  # ---------------------------------------
  If this.APARENT.OPPIMPT = [V]CST_ANO Then
    # If this is decide that not elementary budget can be chargeable PBUIMP have to be to [V]CST_ANO
    If this.PBUELE = [V]CST_ANO and this.PBUIMP = [V]CST_AYES Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUIMP", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
  If this.PBUELE = [V]CST_AYES and this.PBUIMP <> [V]CST_AYES Then
    # An elementary budget have to be chargeable
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUIMP", mess(18,9804,1), [V]CST_AERROR))
  Endif
  # ---------------------------------------
  If this.APARENT.OPPSTATE = 1 Then
    If this.PIMPL.PIMSTA = [V]CST_AYES Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.PIMPL.SETERROR("PIMSTA", func AFNC.MES1(mess(275,2260,1), mess(this.PIMPL.PIMSTA,1,1)), [V]CST_AERROR))
    Endif
  Endif
  # ---------------------------------------
  If this.PBUIMP = [V]CST_ANO Then
    If fmet this.APARENT.TAS_IS_BUDGET_USED(this.PBUCOD) = [V]CST_AYES Then
      # It should not be possible to unflag "Chargeable" on a budget code if a task is linked to this budget code
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUIMP", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

#######################################################################################
$BUD_AINSERT_CONTROL_BEFORE
  Gosub BUD_AINSERT_AUPDATE_CONTROL_BEFORE
Return

#######################################################################################
$BUD_AUPDATE_CONTROL_BEFORE
Local Integer ILINE
Local Integer IISPARENT

  Gosub BUD_AINSERT_AUPDATE_CONTROL_BEFORE
  If this.PBUPAE <> this.snapshot.PBUPAE and this.snapshot.PBUPAE <> AVOID.ACHAR Then
    # The parent has changed and was not empty
    IISPARENT = fmet this.APARENT.BUD_IS_PARENT(this.snapshot.PBUPAE)
    If IISPARENT = [V]CST_ANO Then
      ILINE = fmet this.APARENT.BUD_GET_INDEX(this.snapshot.PBUPAE)
      # If budget was parent, but not after the deletetion
      If this.APARENT.BUD(ILINE).PBUELE = [V]CST_ANO Then
        # the budget is an elementary budget
        this.APARENT.BUD(ILINE).PBUELE = [V]CST_AYES
      Endif
      If this.APARENT.BUD(ILINE).PBUIMP = [V]CST_ANO Then
        # the budget is an elementary budget
        this.APARENT.BUD(ILINE).PBUIMP = [V]CST_AYES
      Endif
    Endif
  Endif
Return

#######################################################################################
$BUD_AINSERT_AUPDATE_CONTROL_BEFORE
Local Integer ILINE

  # ---------------------------
  If this.PBUPAE <> AVOID.ACHAR Then
    ILINE = fmet this.APARENT.BUD_GET_INDEX(this.PBUPAE)
    If ILINE > 0 Then
      If this.APARENT.BUD(ILINE).PBUELE = [V]CST_AYES Then
        # The budget is not an elementary budget
        this.APARENT.BUD(ILINE).PBUELE = [V]CST_ANO
      Endif
      If this.APARENT.BUD(ILINE).PBUIMP = [V]CST_AYES and this.APARENT.BUD(ILINE).TCHOPPIMPT = [V]CST_ANO Then
        this.APARENT.BUD(ILINE).PBUIMP = [V]CST_ANO
        this.APARENT.BUD(ILINE).PIMPL.TCHACTION = "STATUS"
        this.APARENT.BUD(ILINE).PIMPL.PIMSTA = [V]CST_ANO
      Endif
    Endif
  Endif
  # ---------------------------
  If fmet this.APARENT.BUD_IS_PARENT(this.PBUCOD) = [V]CST_ANO Then
    If this.PBUELE = [V]CST_ANO Then
      this.PBUELE = [V]CST_AYES
    Endif
    If this.PBUIMP = [V]CST_ANO Then
      this.PBUIMP = [V]CST_AYES
    Endif
  Endif
  # ---------------------------
  [L]ASTATUS = max([L]ASTATUS, fmet this.APARENT.PROJECT_PROPAGATE_PBUSTATE(this.PBUCOD))
  # ---------------------------
Return

#######################################################################################
$BUD_ADDLINE_BEFORE
Local Integer NI

  If this.OPPSTATE = 4 Then
    # A budget can't be added on a close project
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(198,2260,1), [V]CST_AERROR))
  Endif
  # Issue X3-52534 - 2017-08-17 by FGR : BEGIN
  For NI = 1 To maxtab(this.BUD)
    If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.BUD(NI).PBUCOD = AVOID.ACHAR Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(969,2260,1), [V]CST_AERROR))
        Break
      Endif
    Endif
  Next NI
Return

#######################################################################################
$BUD_ADDLINE_AFTER
  # Note that is "this" is the current "this" of the budget (BUD) collection.
  # So, its parent class is stored in .APARENT. technical property.
  # It's different in BUD_INIT_TECH_PROP method. This one is called from OPPORPJM class.
  # So, the "this" is about OPPORPJM class, and BUD is a subclass.
  # ---------------------------------------
  this.PBUFCY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.APARENT.OPEDEFFCY, "FINRSPFCY") # the Financial site of the project operational site.
  this.CUR = this.APARENT.CUR                    # Technical at this level. have to be in BUD_INIT_TECH_PROP method
  this.OPPCMP = this.APARENT.OPPCMP
  this.TCHOPPIMPT = this.APARENT.OPPIMPT         # Technical at this level. have to be in BUD_INIT_TECH_PROP method
  this.TCHCHGTYP = this.APARENT.TCHCHGTYP        # Technical at this level. have to be in BUD_INIT_TECH_PROP method
  this.TCHOPPSTATE = this.APARENT.OPPSTATE       # Technical at this level. have to be in BUD_INIT_TECH_PROP method
  # ---------------------------------------
  this.PIMPL.PIMTYP = 4                          # Constant value in this case
  this.PIMPL.OPPSTATE = this.APARENT.OPPSTATE
  # ---------------------------------------
  If this.APARENT.OPPSTATE = 1 Then
    this.PBUSTATE = 1
  Else
    this.PBUSTATE = 2
  Endif
  # ---------------------------------------
Return

#######################################################################################
$BUD_ADELLINE_BEFORE
Local Integer IISPARENT

  # ------------------------------------------
  If this.BUD([L]ALINE).PBUSTATE = 4 or this.BUD([L]ALINE).PBUSTATE = 9 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(242,2260,1), mess(this.BUD([L]ALINE).PBUSTATE,2249,1)), [V]CST_AERROR))
  Endif
  # ------------------------------------------
  IISPARENT = fmet this.BUD_IS_PARENT(this.BUD([L]ALINE).PBUCOD)
  If IISPARENT = [V]CST_AYES Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.BUD([L]ALINE).SETERROR("PBUCOD", func AFNC.MES1(mess(153,2260,1), this.BUD([L]ALINE).PBUCOD), [V]CST_AERROR))
  Endif
  # ------------------------------------------
  If fmet this.TAS_IS_BUDGET_USED(this.BUD([L]ALINE).PBUCOD) = [V]CST_AYES Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(321,2260,1), [V]CST_AERROR))
  Endif
  # ------------------------------------------
  If func PJMTIMEMP_CSTD_PROGS.IS_PJMTEMEMP_FOR_BUD(this.OPPNUM, this.BUD([L]ALINE).PBUCOD) = [V]CST_AYES Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUCOD", mess(423,2260,1), [V]CST_AERROR))
  Endif
Return

#######################################################################################
$BUD_ADELLINE_AFTER
Local Integer ILINE
Local Integer IISPARENT

  If this.PBUPAE <> AVOID.ACHAR Then
    IISPARENT = fmet this.APARENT.BUD_IS_PARENT(this.PBUPAE)
    If IISPARENT = [V]CST_ANO Then
      ILINE = fmet this.APARENT.BUD_GET_INDEX(this.PBUPAE)
      # ------------------------------------------
      # If budget was parent, but not after the deletetion
      If this.APARENT.BUD(ILINE).PBUELE = [V]CST_ANO Then
        # the budget is an elementary budget
        this.APARENT.BUD(ILINE).PBUELE = [V]CST_AYES
      Endif
      If this.APARENT.BUD(ILINE).PBUIMP = [V]CST_ANO Then
        # the budget is an elementary budget
        this.APARENT.BUD(ILINE).PBUIMP = [V]CST_AYES
      Endif
    Endif
  Endif
Return

#######################################################################################
$BUD_SPLD_ADELLINE_BEFORE
  [L]ASTATUS = max([L]ASTATUS, fmet this.APARENT.SPLD_RESET_SPLDREF(this.SPLD([L]ALINE).KEYCONCAT))
Return

#######################################################################################
$TAS_ACONTROL
Local Integer ISTATUS
Local Integer ILINE
Local Integer ILINETAS
Local Integer ILINEBUD
Local Integer ICOUNT
Local Integer ICHILDLINE
Local Integer IEXIT
Local Integer NI
Local Integer BUDLIN
Local Integer NI
Local Integer NI1
Local Char SFCYCPYDAD(GLONCPY)
Local Char SFCYCPYTAS(GLONCPY)
Local Char SFCYFINTAS(GLONFCY)
Local Char SFCYFINBUD(GLONFCY)

  # ---------------------------------------
  If this.APARENT.TCHACTION = "" Then
    If this.APARENT.OPPSTATE = 4 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(201,2260,1), [V]CST_AERROR))
    Endif
  Endif
  # ---------------------------------------
  If this.TASFCY <> this.APARENT.OPEDEFFCY Then
    # Site can be changed, but must be on the same financial site than the parent one (FINRSPFCY)
    SFCYCPYDAD = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.APARENT.OPEDEFFCY, "LEGCPY")
    SFCYCPYTAS = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.TASFCY, "LEGCPY")
    If SFCYCPYDAD <> SFCYCPYTAS Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASFCY", func AFNC.MES1(mess(323,2260,1), this.TASCOD), [V]CST_AERROR))
    Endif
  Endif
  # ---------------------------------------
  If this.CUR <> this.APARENT.CUR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("CUR", mess(18,9804,1), [V]CST_AERROR))
  Endif
  # ---------------------------------------
  If this.OPPCMP <> this.APARENT.OPPCMP Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPPCMP", mess(18,9804,1), [V]CST_AERROR))
  Endif
  # ---------------------------------------
  If this.TASSTARTDT <> AVOID.ADATE or this.TASENDDT <> AVOID.ADATE Then
    If fmet this.APARENT.TAS_IS_PARENT(this.TASCOD) = [V]CST_AYES Then
      NI = find(this.TASCOD, this.APARENT.TAS(1..maxtab(this.APARENT.TAS)).TASPAE)
      While NI > 0
        If this.APARENT.TAS(NI) <> null and find(this.APARENT.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          # --------------------------------------
          If this.APARENT.TAS(NI).TASSTARTDT <> [0/0/0] and this.APARENT.TAS(NI).TASSTARTDT < this.TASSTARTDT Then
            # If parent start date is after child start date
            [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASSTARTDT", func AFNC.MES2(mess(373,2260,1), this.TASSTARTDT, this.APARENT.TAS(NI).TASCOD), [V]CST_AERROR))
          Endif
          # --------------------------------------
          If this.APARENT.TAS(NI).TASENDDT <> [0/0/0] and this.APARENT.TAS(NI).TASENDDT > this.TASENDDT Then
            # If parent start date is after child end date
            [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASENDDT", func AFNC.MES2(mess(374,2260,1), this.TASENDDT, this.APARENT.TAS(NI).TASCOD), [V]CST_AERROR))
          Endif
        Endif
        NI1 = NI
        NI = find(this.TASCOD, this.APARENT.TAS(NI+1..maxtab(this.APARENT.TAS)).TASPAE)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
    Endif
  Endif
  # ---------------------------------------
  If this.PBUCOD <> AVOID.ACHAR Then
    # ---------------------------------------
    # 1°) Check that the budget is existing
    ILINE = fmet this.APARENT.BUD_GET_INDEX(this.PBUCOD)
    If ILINE < 1 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUCOD", func AFNC.MES1(mess(217,2260,1), this.PBUCOD), [V]CST_AERROR))
    Endif
    If ILINE > 0 Then
      # 2°) the budget have to be chargeable and not close
      If this.PBUCOD <> this.snapshot.PBUCOD Then
        If this.APARENT.BUD(ILINE).PBUSTATE = 4 Then
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUCOD", func AFNC.MES1(mess(377,2260,1), this.PBUCOD), [V]CST_AERROR))
        Endif
        If this.APARENT.BUD(ILINE).PBUIMP = [V]CST_ANO Then
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUCOD", func AFNC.MES1(mess(376,2260,1), this.PBUCOD), [V]CST_AERROR))
        Endif
      Endif
      # 3°) Site of budget and task have to be on the same financial site
      SFCYCPYTAS = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.TASFCY, "FINRSPFCY")
      SFCYFINBUD = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.APARENT.BUD(ILINE).PBUFCY, "FINRSPFCY")
      If SFCYCPYTAS <> SFCYFINBUD Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASFCY", func AFNC.MES2(mess(324,2260,1), this.TASCOD, this.APARENT.BUD(ILINE).PBUFCY), [V]CST_AERROR))
      Endif
    Endif
  Endif
  If fmet this.APARENT.TAS_IS_PARENT(this.TASCOD) = [V]CST_ANO Then
    # For an operationnal task
    If this.TASSTATE <> 1 Then
      If this.PBUCOD <> this.snapshot.PBUCOD and this.PBUCOD = AVOID.ACHAR Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUCOD", func AFNC.MES1(mess(413,2260,1), mess(this.TASSTATE,2250,1)), [V]CST_AERROR))
      Endif
      If this.TASSTARTDT <> this.snapshot.TASSTARTDT and this.TASSTARTDT = AVOID.ADATE Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASSTARTDT", func AFNC.MES1(mess(413,2260,1), mess(this.TASSTATE,2250,1)), [V]CST_AERROR))
      Endif
      If this.TASENDDT <> this.snapshot.TASENDDT and this.TASENDDT = AVOID.ADATE Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASENDDT", func AFNC.MES1(mess(413,2260,1), mess(this.TASSTATE,2250,1)), [V]CST_AERROR))
      Endif
    Endif
  Endif
Return

#######################################################################################
$TAS_AINSERT_CONTROL_BEFORE
  Gosub TAS_AINSERT_AUPDATE_CONTROL_BEFORE
Return

#######################################################################################
$TAS_AUPDATE_CONTROL_BEFORE
  Gosub TAS_AINSERT_AUPDATE_CONTROL_BEFORE
Return

#######################################################################################
$TAS_AINSERT_AUPDATE_CONTROL_BEFORE
Local Integer ILINE
Local Integer ICURLINE
Local Integer IEXIT
Local Integer IUPDATE

  If this.TASPAE <> AVOID.ACHAR Then
    # ---------------------------------------
    If this.TASSTARTDT <> [0/0/0] or this.TASENDDT <> [0/0/0] Then
      ICURLINE = fmet this.APARENT.TAS_GET_INDEX(this.TASCOD)                            # Index of the current line
      IEXIT = [V]CST_ANO
      Repeat
        ILINE = fmet this.APARENT.TAS_GET_INDEX(this.APARENT.TAS(ICURLINE).TASPAE)       # Index of the parent line
        IUPDATE = [V]CST_ANO
        If this.APARENT.TAS(ILINE).TASSTARTDT = AVOID.ADATE or (this.APARENT.TAS(ILINE).TASSTARTDT <> AVOID.ADATE and this.APARENT.TAS(ILINE).TASSTARTDT > this.APARENT.TAS(ICURLINE).TASSTARTDT) Then
          # If the parent start date is empty : parent start date = current start date
          # Or if the parent start date is greater the current start date
          this.APARENT.TAS(ILINE).TASSTARTDT = this.APARENT.TAS(ICURLINE).TASSTARTDT
          IUPDATE = [V]CST_AYES
        Endif
        # --------------------------------------
        If this.APARENT.TAS(ILINE).TASENDDT = [0/0/0] or (this.APARENT.TAS(ILINE).TASENDDT <> [0/0/0] and this.APARENT.TAS(ILINE).TASENDDT < this.APARENT.TAS(ICURLINE).TASENDDT) Then
          # If the parent end date is empty : parent end date = current end date
          # Or if the parent end date is lower ther current end date
          this.APARENT.TAS(ILINE).TASENDDT = this.APARENT.TAS(ICURLINE).TASENDDT
          IUPDATE = [V]CST_AYES
        Endif
        If this.APARENT.TAS(ILINE).TASPAE = AVOID.ACHAR or IUPDATE = [V]CST_ANO Then
          # If the parent have not parent : we are on the top level : exit of the loop
          # optimisation : if there is not change on the current line, there is no reason to have any change on the parent one
          IEXIT = [V]CST_AYES
        Else
          # The current line become the the current line
          ICURLINE = ILINE
        Endif
      Until IEXIT = [V]CST_AYES
    Endif
  Endif
Return

#######################################################################################
$TAS_AINSERT_CONTROL_AFTER
  Gosub TAS_AINSERT_AUPDATE_CONTROL_AFTER
Return

#######################################################################################
$TAS_AUPDATE_CONTROL_AFTER
  Gosub TAS_AINSERT_AUPDATE_CONTROL_AFTER
Return

#######################################################################################
$TAS_AINSERT_AUPDATE_CONTROL_AFTER
Local Integer ILINE
Local Integer ICOUNT

  # ---------------------------------------
  If this.TASPAE <> this.snapshot.TASPAE Then
    # The parent code can't be changed for a closed budget, or for a budget which have at least one budget line
    ILINE = fmet this.APARENT.TAS_GET_INDEX(this.TASPAE)
    If ILINE > 0 Then
      If this.APARENT.TAS(ILINE).TASSTATE = 4 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASPAE", func AFNC.MES1(mess(213,2260,1), this.TASPAE), [V]CST_AERROR))
      Endif
      ICOUNT = fmet this.APARENT.TAS(ILINE).RITT_COUNT()
      If ICOUNT > 0 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASPAE", func AFNC.MES2(mess(214,2260,1), this.TASPAE, this.TASCOD), [V]CST_AERROR))
      Endif
      ICOUNT = fmet this.APARENT.TAS(ILINE).RTKO_COUNT()
      If ICOUNT > 0 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASPAE", func AFNC.MES2(mess(215,2260,1), this.TASPAE, this.TASCOD), [V]CST_AERROR))
      Endif
    Endif
  Endif
  # ---------------------------------------
Return

#######################################################################################
$TAS_ADDLINE_BEFORE
Local Integer NI

  If this.OPPSTATE = 4 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(199,2260,1), [V]CST_AERROR))
  Endif
  For NI = 1 To maxtab(this.TAS)
    If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.TAS(NI).TASCOD = AVOID.ACHAR Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(970,2260,1), [V]CST_AERROR))
        Break
      Endif
    Endif
  Next NI
Return

#######################################################################################
$TAS_ADDLINE_AFTER
  this.TASFCY = this.APARENT.OPEDEFFCY
  this.CUR = this.APARENT.CUR                     # Technical at this level. have to be in TAS_INIT_TECH_PROP method
  this.OPPCMP = this.APARENT.OPPCMP
  this.TCHCHGTYP = this.APARENT.TCHCHGTYP         # Technical at this level. have to be in TAS_INIT_TECH_PROP method
  # ---------------------------------------
  this.TASBUDAUT = this.APARENT.TASBUDAUT         # Technical property given only for a new task. Not on READ
  # ---------------------------------------
  this.PIMPL.OPPSTATE = this.APARENT.OPPSTATE
  # ---------------------------------------
Return

#######################################################################################
$TAS_ADELLINE_BEFORE
Local Integer NI
Local Integer NE
Local Integer IISPARENT

  # ---------------------------------------
  If this.OPPSTATE = 4 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(204,2260,1), mess(this.OPPSTATE,2249,1)), [V]CST_AERROR)) # Issue X3-81871 - 2018-04-13 by FGR : not 206
  Endif
  If this.TAS([L]ALINE).TASDATL <> AVOID.ADATE Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(343,2260,1), [V]CST_AERROR))
  Endif
  IISPARENT = fmet this.TAS_IS_PARENT(this.TAS([L]ALINE).TASCOD)
  If IISPARENT = [V]CST_AYES Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.TAS([L]ALINE).SETERROR("TASCOD", func AFNC.MES1(mess(318,2260,1), this.TAS([L]ALINE).TASCOD), [V]CST_AERROR))
  Endif
  If fmet this.TAS([L]ALINE).RITT_COUNT() > 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(319,2260,1), [V]CST_AERROR))
  Endif
  If fmet this.TAS([L]ALINE).RTKO_COUNT() > 0 Then
    [L]ASTATUS = fmet this.SETERROR("", mess(320,2260,1), [V]CST_AERROR)
  Endif
  # ---------------------------------------
  For NI = 1 To maxtab(this.TAS)
    If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.TAS(NI) <> this.TAS([L]ALINE) Then
        For NE = 1 To maxtab(this.TAS(NI).PTLNK)
          If this.TAS(NI).PTLNK(NE) <> null and find(this.TAS(NI).PTLNK(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            If this.TAS(NI).PTLNK(NE).PIMOPPTASLNK = this.TAS([L]ALINE).KEYCONCAT Then
              [L]ASTATUS = max([L]ASTATUS, fmet this.TAS([L]ALINE).SETERROR("TASCOD", func AFNC.MES2(mess(974,2260,1), this.TAS([L]ALINE).TASCOD, this.TAS(NI).PTLNK(NE).TASCOD), [V]CST_AERROR))
            Endif
          Endif
        Next NE
      Endif
    Endif
  Next NI
Return

#######################################################################################
$TAS_RITT_ADDLINE_BEFORE
  If fmet this.APARENT.TAS_IS_PARENT(this.TASCOD) = [V]CST_AYES Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(484,2260,1), this.TASCOD), [V]CST_AERROR))
  Endif
Return

#######################################################################################
$TAS_RTKO_ADDLINE_BEFORE
  If fmet this.APARENT.TAS_IS_PARENT(this.TASCOD) = [V]CST_AYES Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(485,2260,1), this.TASCOD), [V]CST_AERROR))
  Endif
Return

#######################################################################################
$TAS_RTKO_RAFFT_AINSERT_CONTROL_BEFORE
  Gosub TAS_RTKO_RAFFT_AINSERT_AUPDATE_CONTROL_BEFORE
Return

#######################################################################################
$TAS_RTKO_RAFFT_AUPDATE_CONTROL_BEFORE
  Gosub TAS_RTKO_RAFFT_AINSERT_AUPDATE_CONTROL_BEFORE
Return

#######################################################################################
$TAS_RTKO_RAFFT_AINSERT_AUPDATE_CONTROL_BEFORE
Local Integer NI
Local Integer IFOUND
Local Integer ILINE

  IFOUND = [V]CST_ANO
  For NI = 1 To maxtab(this.APARENT.APARENT.APARENT.PAF)
    If this.APARENT.APARENT.APARENT.PAF(NI) <> null and find(this.APARENT.APARENT.APARENT.PAF(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.APARENT.APARENT.APARENT.PAF(NI).PAFCLB = this.POACLB Then
        IFOUND = [V]CST_AYES
        Break
      Endif
    Endif
  Next NI
  If IFOUND = [V]CST_ANO Then
    ILINE = fmet this.APARENT.APARENT.APARENT.ADDLINE("PAF", [V]CST_ALASTPOS)
    If ILINE <> [V]CST_ANOTDEFINED Then
      this.APARENT.APARENT.APARENT.PAF(ILINE).PAFCLB = this.POACLB
    Endif
  Endif
Return

#######################################################################################
$TAS_SPLD_ADDLINE_BEFORE
  If fmet this.APARENT.TAS_IS_PARENT(this.TASCOD) = [V]CST_AYES Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(486,2260,1), this.TASCOD), [V]CST_AERROR))
  Endif
Return

#######################################################################################
$TAS_SPLD_ADELLINE_BEFORE
  [L]ASTATUS = max([L]ASTATUS, fmet this.APARENT.SPLD_RESET_SPLDREF(this.SPLD([L]ALINE).KEYCONCAT))
Return

#######################################################################################
$TAS_PTLNK_ADDLINE_BEFORE
  If fmet this.APARENT.TAS_IS_PARENT(this.TASCOD) = [V]CST_AYES Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(580,2260,1), this.TASCOD), [V]CST_AERROR))
  Endif
Return

#######################################################################################
$TAS_PTLNK_ACONTROL
Local Char PROJECT(GLONOPP)
Local Char BUDGET(GLONPBU)
Local Char TASK(GLONTAC)
Local Integer IRET
Local Integer ILINELNK
Local Integer IOFFSET
Local Integer ITODO

  If this.APARENT.TASSTARTDT <> AVOID.ADATE and this.APARENT.TASENDDT <> AVOID.ADATE Then
    IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(this.ACTX, this.PIMOPPTASLNK, PROJECT, BUDGET, TASK)
    If PROJECT = this.OPPNUM Then
      # On the same project
      ILINELNK = fmet this.APARENT.APARENT.TAS_GET_INDEX(TASK)
      If ILINELNK = 0 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMOPPTASLNK", func AFNC.MES1(mess(6,2260,1), TASK), [V]CST_AERROR))
        Return
      Endif
      If this.APARENT.APARENT.TAS(ILINELNK).TASSTARTDT <> AVOID.ADATE and this.APARENT.APARENT.TAS(ILINELNK).TASENDDT <> AVOID.ADATE Then
        Case this.TASLNKTYP
          When 1
            # End to start
            ITODO = 1
            IRET = func OPPORPJM_CSTD_PROGS.GET_OFFSET_RECTIFIED(this, this.APARENT.TASFCY, AVOID.ACHAR, AVOID.ACHAR,
&                                                                this.APARENT.APARENT.TAS(ILINELNK).TASENDDT, AVOID.ACHAR, this.TASLNKLAG, ITODO,
&                                                                IOFFSET)
            [L]ASTATUS = max([L]ASTATUS, IRET)
          When 2
            # Start to start
            If this.TASLNKLAG > 0 Then
              ITODO = 1
            Else
              ITODO = 2
            Endif
            IRET = func OPPORPJM_CSTD_PROGS.GET_OFFSET_RECTIFIED(this, this.APARENT.TASFCY, AVOID.ACHAR, AVOID.ACHAR,
&                                                                this.APARENT.APARENT.TAS(ILINELNK).TASSTARTDT, AVOID.ACHAR, this.TASLNKLAG, ITODO,
&                                                                IOFFSET)
            [L]ASTATUS = max([L]ASTATUS, IRET)
          When 3
            # End to end
            If this.TASLNKLAG > 0 Then
              ITODO = 1
            Else
              ITODO = 2
            Endif
            IRET = func OPPORPJM_CSTD_PROGS.GET_OFFSET_RECTIFIED(this, this.APARENT.TASFCY, AVOID.ACHAR, AVOID.ACHAR,
&                                                                this.APARENT.APARENT.TAS(ILINELNK).TASENDDT, AVOID.ACHAR, this.TASLNKLAG, ITODO,
&                                                                IOFFSET)
            [L]ASTATUS = max([L]ASTATUS, IRET)
          When 4
            # Start to end
            If this.TASLNKLAG > 0 Then
              ITODO = 1
            Else
              ITODO = 2
            Endif
            IRET = func OPPORPJM_CSTD_PROGS.GET_OFFSET_RECTIFIED(this, this.APARENT.TASFCY, AVOID.ACHAR, AVOID.ACHAR,
&                                                                this.APARENT.APARENT.TAS(ILINELNK).TASSTARTDT, AVOID.ACHAR, this.TASLNKLAG, ITODO,
&                                                                IOFFSET)
            [L]ASTATUS = max([L]ASTATUS, IRET)
        Endcase
        # ----------------------------------
        If IRET < [V]CST_AERROR Then
          Case this.TASLNKTYP
            When 1
              # End to start
              If this.APARENT.TASSTARTDT <= this.APARENT.APARENT.TAS(ILINELNK).TASENDDT + IOFFSET Then
                Case this.TASLNKCSTR
                  When 1
                    # Flexible
                    If find(this.ASTALIN,[V]CST_ANEW,[V]CST_AUPD) <> 0
&                     or this.APARENT.TASSTARTDT <> this.APARENT.snapshot.TASSTARTDT
&                     or this.TASLNKLAG <> this.snapshot.TASLNKLAG
&                     or this.APARENT.APARENT.TAS(ILINELNK).TASENDDT <> this.APARENT.APARENT.TAS(ILINELNK).snapshot.TASENDDT
&                   Then
                      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES2(mess(565,2260,1), this.TASCOD, this.APARENT.APARENT.TAS(ILINELNK).TASCOD) + "\" +
&                                                                         func AFNC.MES1(mess(984,2260,1), format$(GFMDAT, this.APARENT.APARENT.TAS(ILINELNK).TASENDDT + IOFFSET)),
&                                                                     [V]CST_AWARNING))
                    Endif
                  When 2
                    # Strict
                    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES2(mess(563,2260,1), this.TASCOD, this.APARENT.APARENT.TAS(ILINELNK).TASCOD) + "\" +
&                                                                       func AFNC.MES1(mess(984,2260,1), format$(GFMDAT, this.APARENT.APARENT.TAS(ILINELNK).TASENDDT + IOFFSET)),
&                                                                   [V]CST_AERROR))
                Endcase
              Endif
            When 2
              # Start to start
              If this.APARENT.TASSTARTDT < this.APARENT.APARENT.TAS(ILINELNK).TASSTARTDT + IOFFSET Then
                Case this.TASLNKCSTR
                  When 1
                    # Flexible
                    If find(this.ASTALIN,[V]CST_ANEW,[V]CST_AUPD) <> 0
&                      or this.APARENT.TASSTARTDT <> this.APARENT.snapshot.TASSTARTDT
&                      or this.TASLNKLAG <> this.snapshot.TASLNKLAG
&                      or this.APARENT.APARENT.TAS(ILINELNK).TASSTARTDT <> this.APARENT.APARENT.TAS(ILINELNK).snapshot.TASSTARTDT
&                   Then
                      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES2(mess(569,2260,1), this.TASCOD, this.APARENT.APARENT.TAS(ILINELNK).TASCOD) + "\" +
&                                                                         func AFNC.MES1(mess(985,2260,1), format$(GFMDAT, this.APARENT.APARENT.TAS(ILINELNK).TASSTARTDT + IOFFSET)),
&                                                                     [V]CST_AWARNING))
                    Endif
                  When 2
                    # Strict
                    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES2(mess(567,2260,1), this.TASCOD, this.APARENT.APARENT.TAS(ILINELNK).TASCOD) + "\" +
&                                                                       func AFNC.MES1(mess(985,2260,1), format$(GFMDAT, this.APARENT.APARENT.TAS(ILINELNK).TASSTARTDT + IOFFSET)),
&                                                                   [V]CST_AERROR))
                Endcase
              Endif
            When 3
              # End to end
              If this.APARENT.TASENDDT < this.APARENT.APARENT.TAS(ILINELNK).TASENDDT + IOFFSET Then
                Case this.TASLNKCSTR
                  When 1
                    # Flexible
                    If find(this.ASTALIN,[V]CST_ANEW,[V]CST_AUPD) <> 0
&                      or this.APARENT.TASENDDT <> this.APARENT.snapshot.TASENDDT
&                      or this.TASLNKLAG <> this.snapshot.TASLNKLAG
&                      or this.APARENT.APARENT.TAS(ILINELNK).TASENDDT <> this.APARENT.APARENT.TAS(ILINELNK).snapshot.TASENDDT
&                   Then
                      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES2(mess(573,2260,1), this.TASCOD, this.APARENT.APARENT.TAS(ILINELNK).TASCOD) + "\" +
&                                                                         func AFNC.MES1(mess(986,2260,1), format$(GFMDAT, this.APARENT.APARENT.TAS(ILINELNK).TASENDDT + IOFFSET)),
&                                                                     [V]CST_AWARNING))
                    Endif
                  When 2
                    # Strict
                    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES2(mess(571,2260,1), this.TASCOD, this.APARENT.APARENT.TAS(ILINELNK).TASCOD) + "\" +
&                                                                       func AFNC.MES1(mess(986,2260,1), format$(GFMDAT, this.APARENT.APARENT.TAS(ILINELNK).TASENDDT + IOFFSET)),
&                                                                   [V]CST_AERROR))
                Endcase
              Endif
            When 4
              # Start to end
              If this.APARENT.TASENDDT < this.APARENT.APARENT.TAS(ILINELNK).TASSTARTDT + IOFFSET Then
                Case this.TASLNKCSTR
                  When 1
                    # Flexible
                    If find(this.ASTALIN,[V]CST_ANEW,[V]CST_AUPD) <> 0
&                      or this.APARENT.TASENDDT <> this.APARENT.snapshot.TASENDDT
&                      or this.TASLNKLAG <> this.snapshot.TASLNKLAG
&                      or this.APARENT.APARENT.TAS(ILINELNK).TASSTARTDT <> this.APARENT.APARENT.TAS(ILINELNK).snapshot.TASSTARTDT
&                   Then
                      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES2(mess(577,2260,1), this.TASCOD, this.APARENT.APARENT.TAS(ILINELNK).TASCOD) + "\" +
&                                                                         func AFNC.MES1(mess(986,2260,1), format$(GFMDAT, this.APARENT.APARENT.TAS(ILINELNK).TASSTARTDT + IOFFSET)),
&                                                                     [V]CST_AWARNING))
                    Endif
                  When 2
                    # Strict
                    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES2(mess(575,2260,1), this.TASCOD, this.APARENT.APARENT.TAS(ILINELNK).TASCOD) + "\" +
&                                                                       func AFNC.MES1(mess(986,2260,1), format$(GFMDAT, this.APARENT.APARENT.TAS(ILINELNK).TASSTARTDT + IOFFSET)),
&                                                                   [V]CST_AERROR))
                Endcase
              Endif
          Endcase
        Endif
      Endif
    Else
      # On another project
      Local File PJMTSK [PJTA]
      Read [PJTA]PTA0=PROJECT;TASK
      If !fstat Then
        If [F:PJTA]TASSTARTDT <> AVOID.ADATE and [F:PJTA]TASENDDT <> AVOID.ADATE Then
          # ----------------------------------
          Case this.TASLNKTYP
            When 1
              # End to start
              ITODO = 1
              IRET = func OPPORPJM_CSTD_PROGS.GET_OFFSET_RECTIFIED(this, this.APARENT.TASFCY, AVOID.ACHAR, AVOID.ACHAR,
&                                                                  [F:PJTA]TASENDDT, AVOID.ACHAR, this.TASLNKLAG, ITODO,
&                                                                  IOFFSET)
              [L]ASTATUS = max([L]ASTATUS, IRET)
            When 2
              # Start to start
              If this.TASLNKLAG > 0 Then
                ITODO = 1
              Else
                ITODO = 2
              Endif
              IRET = func OPPORPJM_CSTD_PROGS.GET_OFFSET_RECTIFIED(this, this.APARENT.TASFCY, AVOID.ACHAR, AVOID.ACHAR,
&                                                                  [F:PJTA]TASSTARTDT, AVOID.ACHAR, this.TASLNKLAG, ITODO,
&                                                                  IOFFSET)
              [L]ASTATUS = max([L]ASTATUS, IRET)
            When 3
              # End to end
              If this.TASLNKLAG > 0 Then
                ITODO = 1
              Else
                ITODO = 2
              Endif
              IRET = func OPPORPJM_CSTD_PROGS.GET_OFFSET_RECTIFIED(this, this.APARENT.TASFCY, AVOID.ACHAR, AVOID.ACHAR,
&                                                                  [F:PJTA]TASENDDT, AVOID.ACHAR, this.TASLNKLAG, ITODO,
&                                                                  IOFFSET)
              [L]ASTATUS = max([L]ASTATUS, IRET)
            When 4
              # Start to end
              If this.TASLNKLAG > 0 Then
                ITODO = 1
              Else
                ITODO = 2
              Endif
              IRET = func OPPORPJM_CSTD_PROGS.GET_OFFSET_RECTIFIED(this, this.APARENT.TASFCY, AVOID.ACHAR, AVOID.ACHAR,
&                                                                  [F:PJTA]TASSTARTDT, AVOID.ACHAR, this.TASLNKLAG, ITODO,
&                                                                  IOFFSET)
              [L]ASTATUS = max([L]ASTATUS, IRET)
          Endcase
          # ----------------------------------
          Case this.TASLNKTYP
            When 1
              # End to start
              If this.APARENT.TASSTARTDT <= [F:PJTA]TASENDDT + IOFFSET Then
                Case this.TASLNKCSTR
                  When 1
                    # Flexible
                    If find(this.ASTALIN,[V]CST_ANEW,[V]CST_AUPD) <> 0 or this.TASLNKLAG <> this.snapshot.TASLNKLAG or this.APARENT.TASSTARTDT <> this.APARENT.snapshot.TASSTARTDT Then
                      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES3(mess(566,2260,1), this.TASCOD, [F:PJTA]TASCOD, [F:PJTA]OPPNUM) + "\" +
&                                                                         func AFNC.MES1(mess(984,2260,1), format$(GFMDAT, [F:PJTA]TASENDDT + IOFFSET)),
&                                                                     [V]CST_AWARNING))
                    Endif
                  When 2
                    # Strict
                    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES3(mess(564,2260,1), this.TASCOD, [F:PJTA]TASCOD, [F:PJTA]OPPNUM) + "\" +
&                                                                       func AFNC.MES1(mess(984,2260,1), format$(GFMDAT, [F:PJTA]TASENDDT + IOFFSET)),
&                                                                   [V]CST_AERROR))
                Endcase
              Endif
            When 2
              # Start to start
              If this.APARENT.TASSTARTDT < [F:PJTA]TASSTARTDT + IOFFSET Then
                Case this.TASLNKCSTR
                  When 1
                    # Flexible
                    If find(this.ASTALIN,[V]CST_ANEW,[V]CST_AUPD) <> 0 or this.TASLNKLAG <> this.snapshot.TASLNKLAG or this.APARENT.TASSTARTDT <> this.APARENT.snapshot.TASSTARTDT Then
                      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES3(mess(570,2260,1), this.TASCOD, [F:PJTA]TASCOD, [F:PJTA]OPPNUM) + "\" +
&                                                                         func AFNC.MES1(mess(985,2260,1), format$(GFMDAT, [F:PJTA]TASSTARTDT + IOFFSET)),
&                                                                     [V]CST_AWARNING))
                    Endif
                  When 2
                    # Strict
                    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES3(mess(568,2260,1), this.TASCOD, [F:PJTA]TASCOD, [F:PJTA]OPPNUM) + "\" +
&                                                                       func AFNC.MES1(mess(985,2260,1), format$(GFMDAT, [F:PJTA]TASSTARTDT + IOFFSET)),
&                                                                   [V]CST_AERROR))
                Endcase
              Endif
            When 3
              # End to end
              If this.APARENT.TASENDDT < [F:PJTA]TASENDDT + IOFFSET Then
                Case this.TASLNKCSTR
                  When 1
                    # Flexible
                    If find(this.ASTALIN,[V]CST_ANEW,[V]CST_AUPD) <> 0 or this.TASLNKLAG <> this.snapshot.TASLNKLAG or this.APARENT.TASENDDT <> this.APARENT.snapshot.TASENDDT Then
                      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES3(mess(574,2260,1), this.TASCOD, [F:PJTA]TASCOD, [F:PJTA]OPPNUM) + "\" +
&                                                                         func AFNC.MES1(mess(986,2260,1), format$(GFMDAT, [F:PJTA]TASENDDT + IOFFSET)),
&                                                                     [V]CST_AWARNING))
                    Endif
                  When 2
                    # Strict
                    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES3(mess(572,2260,1), this.TASCOD, [F:PJTA]TASCOD, [F:PJTA]OPPNUM) + "\" +
&                                                                       func AFNC.MES1(mess(986,2260,1), format$(GFMDAT, [F:PJTA]TASENDDT + IOFFSET)),
&                                                                   [V]CST_AERROR))
                Endcase
              Endif
            When 4
              # Start to end
              If this.APARENT.TASENDDT < [F:PJTA]TASSTARTDT + IOFFSET Then
                Case this.TASLNKCSTR
                  When 1
                    # Flexible
                    If find(this.ASTALIN,[V]CST_ANEW,[V]CST_AUPD) <> 0 or this.TASLNKLAG <> this.snapshot.TASLNKLAG or this.APARENT.TASENDDT <> this.APARENT.snapshot.TASENDDT Then
                      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES3(mess(578,2260,1), this.TASCOD, [F:PJTA]TASCOD, [F:PJTA]OPPNUM) + "\" +
&                                                                         func AFNC.MES1(mess(986,2260,1), format$(GFMDAT, [F:PJTA]TASSTARTDT + IOFFSET)),
&                                                                     [V]CST_AWARNING))
                    Endif
                  When 2
                    # Strict
                    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES3(mess(576,2260,1), this.TASCOD, [F:PJTA]TASCOD, [F:PJTA]OPPNUM) + "\" +
&                                                                       func AFNC.MES1(mess(986,2260,1), format$(GFMDAT, [F:PJTA]TASSTARTDT + IOFFSET)),
&                                                                   [V]CST_AERROR))
                Endcase
              Endif
          Endcase
        Endif
      Endif
    Endif
  Endif
Return

#######################################################################################
$SPLD_ACONTROL
  If this.CUR <> this.APARENT.CUR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("CUR", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.OPPCMP <> this.APARENT.OPPCMP Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPPCMP", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.TASCOD <> AVOID.ACHAR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASCOD", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.PBUCOD <> AVOID.ACHAR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUCOD", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If fmet this.ACTX.ACACHE.AFCY.AGETVALNUM(this.APARENT.SALFCY, "WRHFLG") = [V]CST_AYES Then
    If this.STOFCY <> this.APARENT.SALFCY Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("STOFCY", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Else
    If this.STOFCY <> AVOID.ACHAR Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("STOFCY", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

#######################################################################################
$SPLD_ADDLINE_BEFORE
  If this.OPPSTATE = 4 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(204,2260,1), mess(this.OPPSTATE,2249,1)), [V]CST_AERROR)) # Issue X3-81871 - 2018-04-13 by FGR : not 206
  Endif
Return

#######################################################################################
$SPLD_ADDLINE_AFTER
  this.CUR = this.APARENT.CUR
  this.OPPCMP = this.APARENT.OPPCMP
  If fmet this.ACTX.ACACHE.AFCY.AGETVALNUM(this.APARENT.SALFCY, "WRHFLG") = [V]CST_AYES Then
    this.STOFCY = this.APARENT.SALFCY
  Else
    this.STOFCY = AVOID.ACHAR
  Endif
Return

#######################################################################################
$SPLD_ADELLINE_BEFORE
  If this.OPPSTATE = 4 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(204,2260,1), mess(this.OPPSTATE,2249,1)), [V]CST_AERROR)) # Issue X3-81871 - 2018-04-13 by FGR : not 206
  Endif
  If this.SPLD([L]ALINE).PSONUM <> AVOID.ACHAR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(196,143,1), [V]CST_AERROR))
  Endif
Return

#######################################################################################
$SPLD_ADELLINE_AFTER
  [L]ASTATUS = max([L]ASTATUS, fmet this.APARENT.SPLD_RESET_SPLDREF(this.KEYCONCAT))
Return

