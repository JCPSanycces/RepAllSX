#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation script NCSIMPITM_RSTD - impact analysis Stock
###############################################################################
# Issue 110210/8 - 2015-12-14 by JUSYN : New labels for supervisor update
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"
          Gosub GET_CHANGE_REQUEST_DETAILS
          Gosub IS_IMPACT_AVAILABLE
          Gosub DISABLE_LINK
      Endcase
  Endcase
Return

$METHODS
  Case [L]AMETHOD
  Endcase
Return

$PROPERTIES
  Case [L]CURPRO
  Endcase
Return
###############################################################################

# Using CRID, get change request details
$GET_CHANGE_REQUEST_DETAILS
  Local Char MESSAGE(100)
  Local Instance SELNCSRECENT Using C_NCSRECENT
  SELNCSRECENT = NewInstance C_NCSRECENT AllocGroup null
  ASTATUS = fmet SELNCSRECENT.AREAD(this.CCMIITM.CRID)
  If  ASTATUS<>[V]CST_AOK
    MESSAGE = func ASYRFNC.MES1(mess(20,3702,1),this.CCMIITM.CRID)
    ASTATUS = fmet  this.ASETERROR ("", MESSAGE, [V]CST_AERROR)
  Else
    this.NCSID = SELNCSRECENT.CRID
    this.PRODUCT = SELNCSRECENT.PRODUCT
    this.ECCVALMAJ   = SELNCSRECENT.ECCVALMAJ
    this.ECCVALMIN   = SELNCSRECENT.ECCVALMIN
    this.CRSTATUS = SELNCSRECENT.CRSTATUS
    this.NCSMANAGER = SELNCSRECENT.NCSMANAGER
  Endif
  FreeGroup SELNCSRECENT
Return

# ------------------------------------------------------
# Subroutine: DISABLE_LINK
#
# Called from this Script.
# Disable Update link if not allowed to update
#
$DISABLE_LINK

  Local Integer LOCSTATUS
  If (this.CCMIITM.IMPACTANAL <> 1 and this.CRSTATUS = 2 and this.NCSMANAGER = this.ACTX.USER)
    LOCSTATUS = fmet this.ASETLINKENABLE("UPDATE",[V]CST_AFFLNKREC)
  Else
    LOCSTATUS = fmet this.ASETLINKDISABLE("UPDATE",[V]CST_AFFLNKREC)
  Endif

Return

# ------------------------------------------------------
# Subroutine: IS_IMPACT_AVAILABLE
#
# Called from this Script.
# Is Impact Analysis available?
#
$IS_IMPACT_AVAILABLE

  Local Integer LOCAL_STATUS

  If (this.CCMIITM.IMPACTANAL = 0)
    LOCAL_STATUS = fmet this.ASETERROR("", mess(69,2038,1), CST_AWARNING)
  Elsif (this.CCMIITM.IMPACTANAL = 1)
    LOCAL_STATUS = fmet this.ASETERROR("", mess(68,2038,1), CST_AWARNING)
  Endif

Return

