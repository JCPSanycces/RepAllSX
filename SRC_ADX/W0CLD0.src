#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CLD0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone TYPCLD
mkstat = 0
zoncou = "TYPCLD"
indice = 0
IMPENT = [M]TYPCLD
If varinit([M]TYPCLD,indice)=0
 IMPENT = 1
Endif
If varmode([M]TYPCLD,indice)=0
 [M]TYPCLD(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TYPCLD" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TYPCLD(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "TYPCLD" : GZNUM = 25891 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]TYPCLD = IMPENT

## Zone DESIGN
mkstat = 0
zoncou = "DESIGN"
indice = 0
If varinit([M]DESIGN,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]DESIGN,"10703","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DESIGN,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DESIGN" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]DESIGN,"10703","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "DESIGN" : GZNUM = 55903 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]DESIGN,"10703",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "DESIGN" : GZNUM = 55903 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone PERIOD
mkstat = 0
zoncou = "PERIOD"
indice = 0
If varinit([M]PERIOD,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]PERIOD,"10702","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]PERIOD,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "PERIOD" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]PERIOD,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "PERIOD" : GZNUM = 56620 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]PERIOD,"10702","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PERIOD" : GZNUM = 56620 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]PERIOD,"10702",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "PERIOD" : GZNUM = 56620 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone COMMENT
mkstat = 0
zoncou = "COMMENT"
indice = 0
If varmode([M]COMMENT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "COMMENT" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBRDAT
mkstat = 0
zoncou = "NBRDAT"
indice = 0
status = 1
zoncou = "NBRDAT"
If varmode([M]NBRDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRDAT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRDAT
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRDAT = nolign
   status = 75
   Call SAI_NBRDAT(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBRDAT(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRDAT
mkstat = 0
zoncou = "NBRDAT"

## Zone STRDAT
mkstat = 0
zoncou = "STRDAT"
If varmode([M]STRDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "STRDAT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_STRDAT([M]STRDAT(indice)) From SUBCLD
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "STRDAT" : GZNUM = 1805 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone ENDDAT
mkstat = 0
zoncou = "ENDDAT"
If varmode([M]ENDDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENDDAT" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "DATDEBFIN"
 Call DATDEBFIN([M]ENDDAT(indice),[M]STRDAT(nolign-1)) From EXEFNC
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ENDDAT" : GZNUM = 1806 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_ENDDAT([M]ENDDAT(indice)) From SUBCLD
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ENDDAT" : GZNUM = 1806 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone NBRDAT
mkstat = 0
zoncou = "NBRDAT"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CLD0"
Return

