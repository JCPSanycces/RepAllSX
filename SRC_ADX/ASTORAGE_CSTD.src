#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe ASTORAGE

$ACTION
Case ACTION
 When "GETFULLPATHNAME"   : Gosub GETFULLPATHNAME
 When "READCLOB"          : Gosub READCLOB
 When "READCLOB_"         : Gosub READCLOB_
 When "LS"                : Gosub LS
 When "GETFILEINFO"       : Gosub GETFILEINFO
 When "GETFILEDATETIME"   : Gosub GETFILEDATETIME
 When "GETFILECOM"        : Gosub GETFILECOM
 When "DELETEFILE"        : Gosub DELETEFILE
 Endcase
Return

$GETFULLPATHNAME
Case this.PROTOCOL
 When 1
   Gosub GETFULLPATHNAME From ="ASTORAGE_"+ num$(this.PROTOCOL)
 When Default
  ASTATUS = CST_AERROR
Endcase
Return


#**
#* READCLOB
#* Param : Char    NAME ()
#* Return: Clbfile CLOB
#*!
$READCLOB
Local Char    LINE(255)
Local Char    FILEPATH(255)
FILEPATH = this.PATH + "/" + [L]NAME

If filinfo(FILEPATH,0) > 0
 Openi FILEPATH
 #adxifs="" : adxirs=chr$(13)+chr$(10)
 adxium=[L]IUM
 While 1
  Rdseq LINE
  Append CLOB,LINE
  Break (fstat<>0)
 Wend
 Openi
Endif
Return

#**
#* READCLOB_
#* Param : Char     PATH ()
#* Param : Char     CALLBACK
#* Value Char       IFS
#* Value Char       IRS
#* Value Integer    IUM
#* Value Char       CALLBACK
#* Variable Clbfile CLOB

#*!
$READCLOB_
Local Char      LINE(255)
Local Char      FILEPATH(255)
Local Integer   RES
Local Integer   I,J,K
Local Char      LINE(255)

FILEPATH = this.PATH + "/" + [L]NAME
If filinfo(FILEPATH,0) > 0
 Openi FILEPATH
 adxifs=IFS
 adxirs=IRS
 adxium=IUM
 While 1
  Rdseq LINE
  RES = func =CALLBACK With (LINE,CLOB)
  Break (RES<>0 or fstat<>0)
 Wend
 Openi
Endif
Return

#**
#* LS
#*!
$LS
Local Instance ISTORAGE Using C_ASTORAGE
Local Char     MACHINE(250),WCMDE(250)
Local Char     FICHIER(250) : FICHIER=nomap
Local Char     PATH(255)
Local Integer  ASTATUS: ASTATUS=0
Local Integer  ISWITCH
Call MACHINE(nomap, MACHINE, FICHIER) From ASYRSYS


WCMDE  = MACHINE + "@" + 'lsadx -a"' - nomap + '" '
For ISWITCH=1 To maxtab(SWITCHES)
 WCMDE += SWITCHES(ISWITCH) + " "
Next ISWITCH
WCMDE += this.PATH - EXTENSION - SEARCHPATTERN
Local File (NAME(30)) From System WCMDE As [WCMDE_]

For [WCMDE_]
 [L]NBFILES += 1 :  FILES([L]NBFILES) = [WCMDE_]NAME
 If len(EXTENSION) : FILES([L]NBFILES) += "." + EXTENSION : Endif
Next WCMDE_
Close Local File [WCMDE_]
Return

#**
#* GETFILEINFO
#*!
$GETFILEINFO
Local Char     FPATH(255)
[L]FPATH = this.PATH + "/" + [L]NAME
FILEINFO     = max(0,filinfo(FPATH,[L]ATTRIBUTE))
Return

#**
#* GETFILEDATETIME
#*!
$GETFILEDATETIME
Local Char     FPATH(255)
Local Integer  FTIMES
Local Integer  S , H , M
Local Date     D
Local Char     TIMESTAMP(20)
Local Integer  FTIMES

ASTATUS = CST_AERROR

[L]FPATH = this.PATH + "/" + [L]NAME
[L]FTIMES= filinfo(FPATH,9)
If FTIMES > 0
 Raz ASTATUS
 S = int(mod(FTIMES,60))
 M = int(mod(FTIMES,3600)/60)
 H = int(mod(FTIMES,86400)/3600)
 D = [01/01/1970]+int(FTIMES/86400)
 TIMESTAMP = right$(num$(100+H),2)+":"+right$(num$(100+M),2)+":"+right$(num$(100+S),2)+"Z"
 TIMESTAMP = num$(year(D))+"-"+right$(num$(100+month(D)),2)+"-"+right$(num$(100+day(D)),2)+"T"+TIMESTAMP
 FDATETIME = gdatetime$(TIMESTAMP)
Endif
Return


#**
#* GETFILECOM
#*!
$GETFILECOM
Local Char     FPATH(255)
[L]FPATH = this.PATH + "/" + [L]NAME
[L]COMMENT     = filcom([L]FPATH,"", "", -1)
Return

#**
#* DELETEFILE
#*!
$DELETEFILE
Local Char     PATH(255)
Local Integer  ASTATUS
PATH = this.PATH + "/" + [L]NAME
ASTATUS = Delfile(PATH)
Return
