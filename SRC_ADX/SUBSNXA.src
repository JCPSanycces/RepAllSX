$CHARG_PARAM

#----- Chargement des globales référenciels, comptes et sections de la société -----#
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
#                                                        # hcb x3-53485 deb
Local Integer LRET
# Récupération des codes compteur
If clalev ([F:TCA])<=0
   Local File TABCOUAFF [TCA]
Endif
# Compteur module stock
Call LECTCA(7,LRET) From SUBTCA
If !LRET
   GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1)
   GERR=1
   Return
Endif

GSTKCPTMAN(6)  = [F:TCA]MANCOU(6)  # Cpt des listes inventaires
GSTKCPT   (6)  = [F:TCA]CODNUM(6)

GSTKCPTMAN(13) = [F:TCA]MANCOU(13) # Cpt des sessions inventaires
GSTKCPT   (13) = [F:TCA]CODNUM(13)

#                                                        # hcb x3-53485 fin

Return

