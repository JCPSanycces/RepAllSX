########################################################################
# LOA_LIGNES_EMP                     Chargement des lignes à inventorier
########################################################################
$LOA_LIGNES_EMP
Local Integer WBASPAG
Local Integer J
Local Char    WPCU(GLONUOM)
Local Char    WFILSTO   (250)
Local Char    WFILSTO1  (250)
Local Char    WFILSTO2  (150)
Local Char    WFILSTOWRH(100)
Local Char    WFILBPD   (250)
Local Char    WFILSTC1  (250)
Local Char    WCUNLISNUM
Local Integer WOUI

#
# Preparation filtres
WFILSTO    = "1=1"
WFILSTO1   = "1=1"
WFILSTO2   = "1=1"
WFILSTOWRH = "1=1"
WFILBPD    = "1=1"
WFILSTC1   = "1=1"
If GCOD_EMP = 2
# type emplacement
  If [M:SNU2]LOCTYPSTR <> "" | [M:SNU2]LOCTYPEND <> ""
     WFILSTO += "&[F:STO]LOCTYP>='"+[M:SNU2]LOCTYPSTR+"'&[F:STO]LOCTYP<='"+[M:SNU2]LOCTYPEND+"'"
  Endif
# emplacement
  If [M:SNU2]LOCSTR <> "" | [M:SNU2]LOCEND <> ""
     WFILSTO += "&[F:STO]LOC>='"+[M:SNU2]LOCSTR+"'&[F:STO]LOC<='"+[M:SNU2]LOCEND+"'"
  Endif
# tiers  recherche sur Bpdlvcust si emplacement de type client
  If [M:SNU2]BPRNUMSTR <> "" | [M:SNU2]BPRNUMEND <> ""
     WFILBPD += "&[F:BPD]BPCNUM>='"+[M:SNU2]BPRNUMSTR+"'&[F:BPD]BPCNUM<='"+[M:SNU2]BPRNUMEND+"'"
     WFILSTO += "&[F:STO]LOCCAT>=3 &[F:STO]LOCCAT<=4 "
  Endif

Endif

#lot
If dim([M:SNU2]LOTSTR) > 0 & ([M:SNU2]LOTSTR <> "" | [M:SNU2]LOTEND <> "")
   WFILSTO2 += "&[F:STO]LOT>='"+[M:SNU2]LOTSTR+"'&[F:STO]LOT<='"+[M:SNU2]LOTEND+"'"
Endif
#depot
If dim([M:SNU2]WRHSTR) > 0 & ([M:SNU2]WRHSTR <> "" | [M:SNU2]WRHEND <> "")
   WFILSTOWRH += "&[F:STO]WRH>='"+[M:SNU2]WRHSTR+"'&[F:STO]WRH<='"+[M:SNU2]WRHEND+"'"
Endif


GPOINT = "FILLOALIG"            # hcb 49878
Gosub  ENTREE From EXEFNC       # hcb 49878
#

WBASPAG  = [M:SIW]NBLIG
WITM = " "
Filter [STO] Where STOFCY = [M:SNU0]STOFCY &
&                  evalue(WRUPLOC)         &
&                  QTYSTU <> 0             &
&                  evalue(WFILSTO)         &
&                  evalue(WFILSTO1)        &
&                  evalue(WFILSTOWRH)      &
&                  evalue(WFILSTO2)
&                Order By Key CLE = STOFCY ; LOC ; ITMREF
    For [STO]
# hcb 94192   deb
        WOUI = 2
        If dim([M:SNU2]BPRNUMSTR)>0 & ([M:SNU2]BPRNUMSTR <> "" | [M:SNU2]BPRNUMEND <> "")
           WOUI = 1
           If [M:SNU2]BPRNUMEND <> ""   # si selection sur tiers controle sur BPDLVUST
              Gosub TRT_BPDLVCUST
           Endif
        Endif
        If WOUI = 2
#          Raz WOUI   # hcb  98033
# hcb 94192  fin
           If [F:STO]ITMREF <> WITM
              WOUI = 1
              WITM = [F:STO]ITMREF
              Read [ITF]ITF0=WITM;[F:STO]STOFCY
              If fstat
                 Raz [F:ITF]
              Endif
              WABCCLS  = [F:ITF]ABCCLS
              If fstat = 0 & evalue(WFILF) & evalue(WFILSPEITF)
                 Read [ITM]ITM0=WITM
                 If fstat = 0 & evalue(WFIL1) & evalue(WFIL2) & evalue(WSELFOR)  # hcb 1901
                   WOUI = 2
                 Endif
              Endif
           Endif
           If WOUI = 2
              GPOINT = "AFTREASTO"
              GPE    = 0
              Gosub  ENTREE From EXEFNC
              If GPE = 0
                 Gosub LOA_TABLEAU
                 If WERR <> 0
                    Break
                 Endif
              Endif
           Endif
        Endif                    # hcb 94192
    Next
    Filter [STO]   # hcb 69036
    If WERR <> 0
      Goto LOA_LIGNE1_EMP
    Endif
#Filter [STO]   # hcb 69036

# hcb 34676
GPOINT="ARLOAEMP"
Gosub ENTREE From EXEFNC

#Test si article entièrement chargé
$LOA_LIGNE1_EMP
If WERR = 3
   Return
Endif
Return

########################################################################
# ANA_SELFOR0     analyse et execution de la formule SELFOR0 (articles)
#     en entrée buffer ITM et ITF
#     en sortie WFOR0 = 0 : OK
#               WFOR0 = 1 : pas OK
########################################################################
$ANA_SELFOR0

Local Integer WFOR0
Raz WFOR0
If WSELFOR0 <> "1=1"
   If clalev([F:ITV])  = 0 Local File ITMMVT    [ITV]  Endif
   If clalev([F:ITS])  = 0 Local File ITMSALES  [ITS]  Endif
   If clalev([F:ITP])  = 0 Local File ITMBPS    [ITP]  Endif
   If clalev([F:ITH])  = 0 Local File ITMMVTHIS [ITH]  Endif
   If clalev([F:PER])  = 0 Local File PERIOD    [PER]  Endif

# lecture ITMMVT si besoin
   If (instr(1,WSELFOR0,"ITV]")  & ([F:ITV]ITMREF <> [F:ITF]ITMREF | [F:ITV]STOFCY <> [F:ITF]STOFCY))
      Read [ITV]ITV0=[F:ITF]ITMREF;[F:ITF]STOFCY
      If fstat
         Raz [ITV]
      Endif
   Endif

# lecture ITMSALES si besoin
   If (instr(1,WSELFOR0,"ITS]")  & [F:ITS]ITMREF <> [F:ITF]ITMREF)
      Read [ITS]ITS0=[F:ITF]ITMREF
      If fstat
         Raz [ITS]
      Endif
   Endif
# lecture ITMBPS si besoin
   If (instr(1,WSELFOR0,"ITP]")  & [F:ITP]ITMREF <> [F:ITF]ITMREF)
      Filter [ITP] Where ITMREF=[F:ITF]ITMREF & DOUFLG<3
      Read [ITP] ITP1 First
      If fstat
         Raz [F:ITP]
      Endif
      Filter [ITP]
   Endif
#lecture ITMMVTHIS si besoin
   If (instr(1,WSELFOR0,"ITH]") & ([F:ITH]ITMREF <> [F:ITF]ITMREF | [F:ITH]STOFCY <> [F:ITF]STOFCY | [F:ITH]PERSTR <> GPERSTR))
      If GPERSTR = [0/0/0]
         Local Decimal WEXERCICE, WPERIODE
         Call GETPERSOC(GSOCIETE,1,datesyst,[L]WEXERCICE,[L]WPERIODE) From CPTSUB
         GPERSTR = [F:PER]PERSTR
      Endif
      Read [ITH] ITH0=[F:ITF]ITMREF;[F:ITF]STOFCY;GPERSTR
      If fstat
         Raz [ITH]
      Endif
   Endif

   If evalue(WSELFOR0)
      Raz WFOR0
   Else
      WFOR0 = 1
      Return
   Endif
Endif
If GITMWRH = 2
   Gosub ANA_SELFOR3
Endif
Return

########################################################################
# ANA_SELFOR3     analyse et execution de la formule SELFOR3 (depot)
#     en sortie WFOR0 = 0 : OK
#               WFOR0 = 1 : pas OK
########################################################################
$ANA_SELFOR3
Local Char WITMWRH(GLONWRH)
Local Integer WFOR0
Raz WFOR0
If WSELFOR3 = "1=1"
   Return
Endif
If clalev([F:WRH]) = 0 Local File WAREHOUSE    [WRH] Endif

If GITMWRH = 2
   WITMXRH = [F:ITW]WRH
Else
   WITMWRH = [F:STO]WRH
Endif

# lecture  WAREHOUSE si besoin
If (instr(1,WSELFOR3,"WRH]") & [F:WRH]WRH <> WITMWRH)
   Read [WRH] WRH0=WITMWRH
   If fstat
      Raz [WRH]
   Endif
Endif

If evalue(WSELFOR3)
   Return
Else
   WFOR0 = 1
Endif
Return

