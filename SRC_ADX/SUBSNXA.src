########################################################################
#  Sous programmes                                      appeles par CALL
########################################################################

# LOAD_SNU3                             Chargement de l onglet liste SNU3
# NUM_INV                   Affectation d'un numéro de liste d'inventaire
# NUM_SSS              Affectation d'un numéro d une session d'inventaire

########################################################################
#  Sous programmes                                     appeles par GOSUB
########################################################################
# CAL_COMPTAGE Calcul nb articles prévisionnel a compter par classe ABCD
# CAL_SEL    calcul nombre d'articles sélectionnés total par classe ABCD
# GEN_MANUEL                                           Inventaire MANUEL
# GEN_TOURNANT                                       Inventaire TOURNANT
# GEN_ANNUEL                                           Inventaire ANNUEL
# LOA_TABLEAU                        Chargement des lignes à inventorier
# LOA_LIGNES                         Chargement des lignes à inventorier
# GRISE_CLE                             Grisage saisie numero de session
# DEGRISE_CLE                         Dégrisage saisie numero de session
# CAL_SIMULATION                                       Calcul simulation

########################################################################
#  Sous programmes                                A C T I O N S  boutons
########################################################################
# ACT_SIMSNU          bouton SIMULATION               session inventaire
# ACT_GENSNU          bouton GENERATION               session inventaire

########################################################################
#  Sous programmes                                      appeles par CALL
########################################################################
# LOAD_SNU3                             Chargement de l onglet liste SNU3
# NUM_INV                   Affectation d'un numéro de liste d'inventaire
# NUM_SSS              Affectation d'un numéro d une session d'inventaire

#########################################################################
# LOAD_SNU3                             Chargement de l onglet liste SNU3
#########################################################################
Subprog LOAD_SNU3
Raz [M:SNU3]
Local Integer I
I = 0

Filter [CUL] Where [F:CUL]CUNSSSNUM = [F:CUN]CUNSSSNUM Order By Key CUL0

For [CUL]

    If I > dim([SNU3]CUNLISNUM)-1 : Break : Endif
    If I >  GCOD_INL : Break : Endif
    [M:SNU3]CUNLISNUM    (I) = [F:CUL]CUNLISNUM
    [M:SNU3]NBRLIG       (I) = [F:CUL]NBRLIG
    [M:SNU3]CUNLISSTA    (I) = [F:CUL]CUNLISSTA
    [M:SNU3]CUNLOKFLG    (I) = [F:CUL]CUNLOKFLG
    [M:SNU3]CUNSTADAT    (I) = [F:CUL]CUNSTADAT
    [M:SNU3]USR          (I) = [F:CUL]USR
    [M:SNU3]CUNLISDES    (I) = [F:CUL]CUNLISDES
    [M:SNU3]CREUSR       (I) = [F:CUL]CREUSR
    [M:SNU3]IPTDAT       (I) = [F:CUL]IPTDAT
    [M:SNU3]LASIPTDAT    (I) = [F:CUL]LASIPTDAT
    [M:SNU3]CREDAT       (I) = [F:CUL]CREDAT
    If dim([M:SNU3]WRH) > 0
       If [F:CUN]CUNITMWRH = 2
          [M:SNU3]WRH    (I) = [F:CUL]WRH
       Endif
    Endif
    I += 1
Next
[M:SNU3]NBLIG = I
Filter [CUL]

Affzo [M:SNU3]
If [M:SNU3]NBLIG > 0
   Grizo [M:SNU2]
   Grizo [M:SNU1]
Endif
End
#########################################################################
# NUM_INV                   Affectation d'un numéro de liste d'inventaire
#########################################################################
Subprog NUM_INV(LFCY,LDAT,LINV)
Variable Char    LFCY
Variable Date    LDAT
Variable Char    LINV
Local    Integer VS
Call NUMERO(GSTKCPT(6),LFCY,LDAT,"",LINV,VS) From SUBANM
If VS = 1
  GOK = 0
  LINV = ""
Endif
End
#########################################################################
# NUM_SSS              Affectation d'un numéro d une session d'inventaire
#########################################################################
Subprog NUM_SSS(LFCY,LDAT,LINV)
Variable Char    LFCY
Variable Date    LDAT
Variable Char    LINV
Local    Integer VS
Call NUMERO(GSTKCPT(13),LFCY,LDAT,"",LINV,VS) From SUBANM
Case VS
  When 1  : GMESSAGE = mess(12,114,1)  : # Compteur inexistant
  When 2  : GMESSAGE = mess(13,114,1)  : # Dépassement de compteur
  When 3  : GMESSAGE = mess(34,113,1)  : # Exercice non ouvert
  When 5  : GMESSAGE = mess(62,133,1)  : # Société ou site incorrect
  When 4  : GMESSAGE = mess(111,123,1) : # Longueur incorrecte
  When 10 : GMESSAGE = mess(21,143,1)  : # Format incorrect (présence d'espaces ou longueur trop grande)
  When 99 : GMESSAGE = mess(235,143,1) : # Erreur mise à jour compteur séquentiel
Endcase

If VS   <> 0
   GOK  = 0
   LINV = ""
Endif
End

########################################################################
#  Sous programmes                                     appeles par GOSUB
########################################################################
# AB_TRT                                       Abandon de la transaction
# CAL_COMPTAGE Calcul du nombre prévisionnel d'articles a compter / ABCD
# CAL_SEL    calcul nombre d'articles sélectionnés total par classe ABCD
# GEN_MANUEL                                           Inventaire MANUEL
# GEN_TOURNANT                                       Inventaire TOURNANT
# GEN_ANNUEL                                           Inventaire ANNUEL
# LOA_LIGNES                         Chargement des lignes à inventorier
# LOA_TABLEAU                        Chargement des lignes à inventorier
# GRISE_CLE                             Grisage saisie numero de session
# DEGRISE_CLE                         Dégrisage saisie numero de session
# CAL_SIMULATION                                       Calcul simulation

########################################################################
# AB_TRT                                       Abandon de la transaction
########################################################################
$AB_TRT
WABTRT = 9     # hcb ctr
If !GIMPORT
   Rollback
Endif
Return
########################################################################
# CAL_COMPTAGE Calcul nb articles prévisionnel a compter par classe ABCD
########################################################################
$CAL_COMPTAGE

Local Integer WDAY
Local Decimal WCPT
Local Date    WDTE
[M:SNU1]CUNNBRA = 0
[M:SNU1]CUNNBRB = 0
[M:SNU1]CUNNBRC = 0
[M:SNU1]CUNNBRD = 0

If [M:SNU1]CUNSSSMOD <> 2
   Grizo [M:SNU1]CUNNBRA
   Grizo [M:SNU1]CUNNBRB
   Grizo [M:SNU1]CUNNBRC
   Grizo [M:SNU1]CUNNBRD
   Return
Endif

Read [STE]STE0=[M:SNU0]STOFCY;""
If fstat = 0
  WDTE = [F:STE]CYCCUNDAT
  If year(WDTE) <> year(date$)
     WDTE = gdat$(1,1,year(date$))
  Endif
  WDAY = date$ - WDTE
  If WDAY > 0
    WCPT = ([F:STE]YEACUNNBRA * WDAY)/365
    If WCPT > [F:STE]CUNNBRA
       [M:SNU1]CUNNBRA = int(WCPT - [F:STE]CUNNBRA)
    Endif
    WCPT = ([F:STE]YEACUNNBRB * WDAY)/365
    If WCPT > [F:STE]CUNNBRB
       [M:SNU1]CUNNBRB = int(WCPT - [F:STE]CUNNBRB)
    Endif
    WCPT = ([F:STE]YEACUNNBRC * WDAY)/365
    If WCPT > [F:STE]CUNNBRC
       [M:SNU1]CUNNBRC = int(WCPT - [F:STE]CUNNBRC)
    Endif
     WCPT = ([F:STE]YEACUNNBRD * WDAY)/365
    If WCPT > [F:STE]CUNNBRD
       [M:SNU1]CUNNBRD = int(WCPT - [F:STE]CUNNBRD)
    Endif
  Endif
Endif
[M:SNU1]ABCCLSA = 2
[M:SNU1]ABCCLSB = 2
[M:SNU1]ABCCLSC = 2
[M:SNU1]ABCCLSD = 2
Return

########################################################################
# CAL_SEL    calcul nombre d'articles sélectionnés total par classe ABCD
########################################################################
$CAL_SEL

If [M:SNU1]CUNSSSMOD = 2
   Return
Endif

Local Char    WITMREF(GLONITM)
Local Integer I
WITMREF = ""

For I = 0 To [M:SIW]NBLIG-1
  If WITMREF <> [M:SIW]ITMREF(I)
    Case [M:SIW]ABCCLS(I)
      When 1 : [M:SNU1]CPLCUNNBRA += 1
      When 2 : [M:SNU1]CPLCUNNBRB += 1
      When 3 : [M:SNU1]CPLCUNNBRC += 1
      When 4 : [M:SNU1]CPLCUNNBRD += 1
    Endcase
  Endif
  WITMREF = [M:SIW]ITMREF(I)
Next I
Return


########################################################################
# GEN_MANUEL                                           Inventaire MANUEL
########################################################################
$GEN_MANUEL
Local Integer WABTRT         # hcb ctr
Raz WABTRT                   # hcb ctr
Local Integer WITMNBR
Local Integer WITMSTK
Local Integer WOUI
Local Char    WFILBPD(250)
WFILBPD  = "1=1"

WITMNBR = 0
WITMSTK = 0
WWRH = "1=1"

If !GIMPORT
   Call DEBTRANS From GLOCK
   Trbegin [CUD]
Endif
# Si inventaire de type Emplacement
# lecture par la table STOlOC Sinon lecture par ITMFACILITY + ITMMASTER
#
If [M:SNU1]CUNSSSTYP = 2
#rubriques pour gerer la rupture position emplacement
   Local Char WLOCLEC ([F:CUN]LOCPOS)
   Local Char WLOCRUP ([F:CUN]LOCPOS)
   Raz WLOCLEC
   Raz WLOCRUP

   If clalev([F:STC]) = 0 : Local File STOLOC [STC] : Endif
#Filtre STOLOC
   Local Char WFILEMP(250)
#Societe
   WFILEMP = "[F:STC]STOFCY=[M:SNU0]STOFCY"
# Type emplacement
   If dim([M:SNU2]LOCTYPSTR) > 0
      If [M:SNU2]LOCTYPSTR <> "" | [M:SNU2]LOCTYPEND <> ""
         WFILEMP += "&[F:STC]LOCTYP>='"+[M:SNU2]LOCTYPSTR+"'&[F:STC]LOCTYP<='"+[M:SNU2]LOCTYPEND+"'"
      Endif
   Endif
# Emplacement
   If dim([M:SNU2]LOCSTR) > 0
      If [M:SNU2]LOCSTR <> "" | [M:SNU2]LOCEND <> ""
         WFILEMP += "&[F:STC]LOC>='"+[M:SNU2]LOCSTR+"'&[F:STC]LOC<='"+[M:SNU2]LOCEND+"'"
      Endif
   Endif
#
   Raz GPE                         # hcb 49878
   GPOINT = "FILGENMAN"            # hcb 49878
   Gosub  ENTREE From EXEFNC       # hcb 49878
   If GPE = 0                      # hcb 49878
      Filter [STC] Where evalue(WFILEMP) & evalue(WSELFOR2)
&            Order By Key STC0
   Endif                           # hcb 49878
   For [STC]
        WOUI = 2
#        If dim([M:SNU2]BPRNUMSTR)>0 & ([M:SNU2]BPRNUMSTR <> "" | [M:SNU2]BPRNUMEND <> "")# hcb 94192
#           WOUI = 1                                                                      # hcb 94192
#           If [M:SNU2]BPRNUMEND <> ""   # si selection sur tiers controle sur BPDLVUST   # hcb 94192
#              Gosub TRT_BPDLVCUST                                                        # hcb 94192
#           Endif                                                                         # hcb 94192
#        Endif                                                                            # hcb 94192
        If WOUI = 2
           Raz GPE                         # hcb 52308
           GPOINT = "RUPLOCMAN"            # hcb 52308
           Gosub  ENTREE From EXEFNC       # hcb 52308
           If GPE =  0                     # hcb 52308
              WRUPLOC = "[F:STO]LOC =  [F:STC]LOC"
              If GLONLOC <>  [F:CUN]LOCPOS
# gestion rupture position emplacement
                 WLOCLEC = [F:STC]LOC
                 If WLOCRUP = ""
                    WLOCRUP = [F:STC]LOC
                 Endif
                 If WLOCLEC <> WLOCRUP
                    Call CRE_NEW_INV From STKINV
                    WLOCRUP = WLOCLEC
                 Endif
              Endif
           Endif                           # hcb 52308

$GEN_M1
           Gosub LOA_LIGNES_EMP
#                                                            # hcb 110327 deb
# Quantité ligne de stock différente du nombre de série
           If WERR = 4
              GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-mess(50,196,1)-num$([F:STO]STOCOU)-mess(146,184,1)-"="-num$([F:STO]QTYSTU)-mess(483,184,1)-"="-num$(WQTYSTS)
              GMESSAGE+="\"+mess(491,184,1)
              Call MESSAGE(GMESSAGE) From GESECRAN
              Filter [STC]
              Gosub AB_TRT
              Break
           Endif
#                                                            # hcb 110327 fin

# stock en attente de rangment ligne de stock incomplete
           If WERR = 3
              GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(378,199,1)
              GMESSAGE+="\"+mess(377,199,1)
              Call MESSAGE(GMESSAGE) From GESECRAN
              Filter [STC]
              Gosub AB_TRT
              Break    # hcb ctr
           Endif
# il ni a pas assez de ligne pour un article .........
           If WERR = 2
              Call MESSAGE(mess(426,199,1)) From GESECRAN   # hcb 27888
              Gosub LOA_LIGNES_CPT                          # hcb 27888
              Filter [STC]
              Gosub AB_TRT
              Break    # hcb ctr
           Endif
           If WERR = 1
              Call CRE_NEW_INV From STKINV
              WERR = 0
              If GOK < 1
                 Filter [STC]
                 Gosub AB_TRT
                 Break    # hcb ctr
              Endif
             Goto GEN_M1
           Endif
        Endif
   Next
   If WABTRT = 0               # hcb ctr
      Filter [STC]
   Endif
Else
   If GITMWRH = 2
      Local Char WWRHLEC (GLONWRH)
      Local Char WWRHRUP (GLONWRH)
      Raz WWRHLEC
      Raz WWRHRUP
      Link [ITW] With [ITM]ITM0=[F:ITW]ITMREF,[ITF]ITF0=[F:ITW]ITMREF;[F:ITW]STOFCY
&                As [INV]
&                Where evalue(WFILF)    &
&                      evalue(WFILSPEITF) &
&                      evalue(WFILITW)  &
&                      evalue(WSELFOR)
&                Order By Key ITW1
      For [INV]
          Gosub ANA_SELFOR0
          If !WFOR0
             WITM = [F:ITF]ITMREF
             WITMSTK  = 0
             WABCCLS  = [F:ITF]ABCCLS
             WITMNBR  += 1
             If WITMNBR > [F:CUN]ITMNBR
                Call CRE_NEW_INV From STKINV
                WITMNBR = 1
             Endif
# gestion rupture depot
             WWRH    = "[F:STO]WRH = [F:ITW]WRH"
             WWRHLEC = [F:ITW]WRH
             If WWRHRUP = ""
                WWRHRUP = [F:ITW]WRH
             Endif
             If WWRHLEC <> WWRHRUP
                Call CRE_NEW_INV From STKINV
                WITMNBR = 1
                WWRHRUP = WWRHLEC
             Endif

$GEN_M2ITW
             Gosub LOA_LIGNES
#                                                            # hcb 110327 deb
# Quantité ligne de stock différente du nombre de série
             If WERR = 4
                GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-mess(50,196,1)-num$([F:STO]STOCOU)-mess(146,184,1)-"="-num$([F:STO]QTYSTU)-mess(483,184,1)-"="-num$(WQTYSTS)
                GMESSAGE+="\"+mess(491,184,1)
                Call MESSAGE(GMESSAGE) From GESECRAN
                Filter [STC]
                Gosub AB_TRT
                Break
             Endif
#                                                            # hcb 110327 fin
# stock en attente de rangment ligne de stock incomplete
             If WERR = 3
                GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(378,199,1)
                GMESSAGE+="\"+mess(377,199,1)
                Call MESSAGE(GMESSAGE) From GESECRAN
                Gosub AB_TRT
                Break    # hcb ctr
             Endif

# il ni a pas assez de ligne pour un article .........
             If WERR = 2
                Gosub LOA_LIGNES_CPT
                Gosub AB_TRT
                Break    # hcb ctr
             Endif
             If WERR = 1
                Call CRE_NEW_INV From STKINV
                WERR = 0
                If GOK < 1
                   Gosub AB_TRT
                   Break    # hcb ctr
                Endif
                Goto GEN_M2ITW
             Endif
          Endif
      Next
   Else

      Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF
&                As [INV]
&                Where evalue(WFILF)     &
&                      evalue(WFILSPEITF) &
&                      evalue(WSELFOR)
&                Order By Key ITF1
      For [INV]
          Gosub ANA_SELFOR0
          If !WFOR0
             WITM = [F:ITF]ITMREF
             WITMSTK  = 0
             WABCCLS  = [F:ITF]ABCCLS
             WITMNBR  += 1
             If WITMNBR > [F:CUN]ITMNBR
                Call CRE_NEW_INV From STKINV
                WITMNBR = 1
             Endif
$GEN_M2
             Gosub LOA_LIGNES
#                                                            # hcb 110327 deb
# Quantité ligne de stock différente du nombre de série
             If WERR = 4
                GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-mess(50,196,1)-num$([F:STO]STOCOU)-mess(146,184,1)-"="-num$([F:STO]QTYSTU)-mess(483,184,1)-"="-num$(WQTYSTS)
                GMESSAGE+="\"+mess(491,184,1)
                Call MESSAGE(GMESSAGE) From GESECRAN
                Filter [STC]
                Gosub AB_TRT
                Break
             Endif
#                                                            # hcb 110327 fin

# stock en attente de rangment ligne de stock incomplete
             If WERR = 3
                GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(378,199,1)
                GMESSAGE+="\"+mess(377,199,1)
                Call MESSAGE(GMESSAGE) From GESECRAN
                Gosub AB_TRT
                Break    # hcb ctr
             Endif

# il ni a pas assez de ligne pour un artricle .........
             If WERR = 2
                Gosub LOA_LIGNES_CPT                # hcb 27888
                Gosub AB_TRT
                Break    # hcb ctr
             Endif
             If WERR = 1
                Call CRE_NEW_INV From STKINV
                WERR = 0
                If GOK < 1
                   Gosub AB_TRT
                   Break    # hcb ctr
                Endif
                Goto GEN_M2
             Endif
          Endif
      Next
   Endif
Endif
If WABTRT = 9     # hcb ctr
   Return
Endif

If [M:SIW]NBLIG > 0
     Call CRE_NEW_INV From STKINV
Endif
#maj session inventaire

If GOK = 1
   Gosub MAJ_CUN From STKINV
   If GOK = 1
      Gosub TRT_ECRSTJBID From STKINV
   Else
      Gosub AB_TRT
      Return
   Endif
Else
   Gosub AB_TRT
   Return
Endif
If !GIMPORT
   Commit
Endif
Return
########################################################################
# GEN_TOURNANT                                       Inventaire TOURNANT
########################################################################
$GEN_TOURNANT
Local Integer WITMNBR
Local Integer WITMSTK   # nombre de ligne de stock par article
Local Date    WNEXCUNDAT
Local Integer WABTRT         # hcb ctr
Raz WABTRT                   # hcb ctr

WITMSTK = 0
WITMNBR = 0
WWRH    = "1=1"
Call DEBTRANS From GLOCK
Trbegin [CUD]

If GITMWRH = 2
   Local Char WWRHLEC (GLONWRH)
   Local Char WWRHRUP (GLONWRH)
   Raz WWRHLEC
   Raz WWRHRUP
   Link [ITW] With [ITM]ITM0=[F:ITW]ITMREF,[ITF]ITF0=[F:ITW]ITMREF;[F:ITW]STOFCY
&             As [INV]
&             Where evalue(WFILF)    &
&                   evalue(WFILSPEITF) &
&                   evalue(WFILITW)  &
&                   evalue(WSELFOR)
&             Order By Key ITW1
   For [INV]
       Gosub ANA_SELFOR0
       If !WFOR0
          If [F:ITW]CUNWRHFLG = 2
              If [F:ITW]NEXCUNDAT = [0/0/0]
                If [F:ITW]CREDAT = [0/0/0]
                   WDAT = [F:ITF]CREDAT
                Else
                   WDAT = [F:ITW]CREDAT
                Endif
                WCOD = [F:ITW]CUNCOD                                                    # hcb 62497
                Call CAL_NEXINVITW([F:ITF]STOFCY,[F:ITM]TCLCOD,WDAT,WCOD) From STKINV
             Endif
             WNEXCUNDAT = [F:ITW]NEXCUNDAT                                              # hcb 62497
          Else
             Read [ITV]ITV0=[F:ITF]ITMREF;[F:ITF]STOFCY
             If fstat
                Raz [F:ITV]
             Endif
             If [F:ITV]NEXCUNDAT = [0/0/0]
                If [F:ITV]CREDAT = [0/0/0]
                   WDAT = [F:ITF]CREDAT
                Else
                   WDAT = [F:ITV]CREDAT
                Endif
                WCOD = [F:ITF]CUNCOD
                Call CAL_NEXINV([F:ITF]STOFCY,[F:ITM]TCLCOD,WDAT,WCOD) From STKINV
             Endif
             WNEXCUNDAT = [F:ITV]NEXCUNDAT                                             # hcb 62497
          Endif
          If  WNEXCUNDAT <= [M:SNU1]CUNSSSDAT
              WOK = 1
              Case [F:ITF]ABCCLS
                  When 1 :       If [M:SNU1]CPLCUNNBRA < [M:SNU1]CUNNBRA
                                    [M:SNU1]CPLCUNNBRA += 1
                                    WOK = 2
                                 Endif
                  When 2 :       If [M:SNU1]CPLCUNNBRB < [M:SNU1]CUNNBRB
                                    [M:SNU1]CPLCUNNBRB += 1
                                    WOK = 2
                                 Endif
                  When 3 :       If [M:SNU1]CPLCUNNBRC < [M:SNU1]CUNNBRC
                                    [M:SNU1]CPLCUNNBRC += 1
                                    WOK = 2
                                 Endif
                  When 4 :       If [M:SNU1]CPLCUNNBRD < [M:SNU1]CUNNBRD
                                    [M:SNU1]CPLCUNNBRD += 1
                                    WOK = 2
                                 Endif
              Endcase
              If WOK = 2
                 WITM = [F:ITF]ITMREF
                 WITMSTK  = 0
                 WABCCLS  = [F:ITF]ABCCLS
                 WITMNBR  += 1
                 If WITMNBR > [F:CUN]ITMNBR
                    Call CRE_NEW_INV From STKINV
                    WITMNBR = 1
                 Endif
# gestion rupture position emplacement
                 WWRH    = "[F:STO]WRH = [F:ITW]WRH"
                 WWRHLEC = [F:ITW]WRH
                 If WWRHRUP = ""
                    WWRHRUP = [F:ITW]WRH
                 Endif
                 If WWRHLEC <> WWRHRUP
                    Call CRE_NEW_INV From STKINV
                    WITMNBR = 1
                    WWRHRUP = WWRHLEC
                 Endif
$GEN_T1ITW
                 Gosub LOA_LIGNES
#                                                            # hcb 110327 deb
# Quantité ligne de stock différente du nombre de série
                 If WERR = 4
                    GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-mess(50,196,1)-num$([F:STO]STOCOU)-mess(146,184,1)-"="-num$([F:STO]QTYSTU)-mess(483,184,1)-"="-num$(WQTYSTS)
                    GMESSAGE+="\"+mess(491,184,1)
                    Call MESSAGE(GMESSAGE) From GESECRAN
                    Filter [STC]
                    Gosub AB_TRT
                    Break
                 Endif
#                                                            # hcb 110327 fin

# stock en attente de rangment ligne de stock incomplete
                 If WERR = 3
                    GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(378,199,1)
                    GMESSAGE+="\"+mess(377,199,1)
                    Call MESSAGE(GMESSAGE) From GESECRAN
                    Filter [INV]  # hcb ctr
                    Gosub AB_TRT
                    Break    # hcb ctr
                 Endif

# il ni a pas assez de ligne pour un article .........
                 If WERR = 2
                    Gosub LOA_LIGNES_CPT
                    Filter [INV]  # hcb ctr
                    Gosub AB_TRT
                    Break    # hcb ctr
                 Endif
                 If WERR = 1
                    Call CRE_NEW_INV From STKINV
                    WERR = 0
                    If GOK < 1
                       Filter [INV]  # hcb ctr
                       Gosub AB_TRT
                       Break    # hcb ctr
                    Endif
                    Goto GEN_T1ITW
                 Endif
              Endif
          Endif
      Endif
   Next
   If WABTRT = 0          # hcb ctr
      Filter [INV]
   Endif
Else
   Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF
&               As [INV]
&               Where evalue(WFILF)     &
&                     evalue(WFILSPEITF) &
&                     evalue(WSELFOR)
&               Order By Key ITF1
   For [INV]
       Gosub ANA_SELFOR0
       If !WFOR0
          Read [ITV]ITV0=[F:ITF]ITMREF;[F:ITF]STOFCY
          If fstat
             Raz [F:ITV]
          Endif
# FILTRE date
          If [F:ITV]NEXCUNDAT = [0/0/0]
             If [F:ITV]CREDAT = [0/0/0]
                WDAT = [F:ITF]CREDAT
             Else
                WDAT = [F:ITV]CREDAT
             Endif
             WCOD = [F:ITF]CUNCOD
             Call CAL_NEXINV([F:ITF]STOFCY,[F:ITM]TCLCOD,WDAT,WCOD) From STKINV
          Endif
          If [F:ITV]NEXCUNDAT <= [M:SNU1]CUNSSSDAT
             WOK = 1
             Case [F:ITF]ABCCLS
                  When 1 :       If [M:SNU1]CPLCUNNBRA < [M:SNU1]CUNNBRA
                                    [M:SNU1]CPLCUNNBRA += 1                    #  26712
                                    WOK = 2
                                 Endif
                  When 2 :       If [M:SNU1]CPLCUNNBRB < [M:SNU1]CUNNBRB
                                    [M:SNU1]CPLCUNNBRB += 1                    #  26712
                                    WOK = 2
                                 Endif
                  When 3 :       If [M:SNU1]CPLCUNNBRC < [M:SNU1]CUNNBRC
                                    [M:SNU1]CPLCUNNBRC += 1                    #  26712
                                    WOK = 2
                                 Endif
                  When 4 :       If [M:SNU1]CPLCUNNBRD < [M:SNU1]CUNNBRD
                                    [M:SNU1]CPLCUNNBRD += 1                    #  26712
                                    WOK = 2
                                 Endif
             Endcase
             If WOK = 2
                WITM     =  [F:ITF]ITMREF
                WITMSTK  =  0
                WABCCLS  =  [F:ITF]ABCCLS
                WITMNBR  += 1
                If WITMNBR > [F:CUN]ITMNBR
                   Call CRE_NEW_INV From STKINV
                   WITMNBR = 1
                Endif
$GEN_T1
                Gosub LOA_LIGNES
#                                                            # hcb 110327 deb
# Quantité ligne de stock différente du nombre de série
                If WERR = 4
                   GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-mess(50,196,1)-num$([F:STO]STOCOU)-mess(146,184,1)-"="-num$([F:STO]QTYSTU)-mess(483,184,1)-"="-num$(WQTYSTS)
                   GMESSAGE+="\"+mess(491,184,1)
                   Call MESSAGE(GMESSAGE) From GESECRAN
                   Filter [STC]
                   Gosub AB_TRT
                   Break
                Endif
#                                                            # hcb 110327 fin

# stock en attente de rangment ligne de stock incomplete
                If WERR = 3
                   GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(378,199,1)
                   GMESSAGE+="\"+mess(377,199,1)
                   Call MESSAGE(GMESSAGE) From GESECRAN
                   Filter [INV]
                   Gosub AB_TRT
                   Break    # hcb ctr
                Endif

# il ni a pas assez de ligne pour un artricle .........
                If WERR = 2
                   Gosub LOA_LIGNES_CPT
                   Filter [INV]
                   Gosub AB_TRT
                   Break    # hcb ctr
                Endif
                If WERR = 1
                   Call CRE_NEW_INV From STKINV
                   WERR = 0
                   If GOK < 1
                      Filter [INV]
                      Gosub AB_TRT
                      Break    # hcb ctr
                   Endif
                   Goto GEN_T1
                Endif
             Endif
          Endif
       Endif
   Next
   If WABTRT = 0          # hcb ctr
      Filter [INV]
   Endif
Endif
If WABTRT = 9     # hcb ctr
   Return
Endif
If [M:SIW]NBLIG > 0
     Call CRE_NEW_INV From STKINV
Endif
#maj session inventaire
If GOK = 1
   Gosub MAJ_CUN From STKINV
   If GOK = 1
      Gosub TRT_ECRSTJBID From STKINV
   Else
      Gosub AB_TRT
      Return
   Endif
Else
   Gosub AB_TRT
   Return
Endif

Commit

Return
########################################################################
# GEN_ANNUEL                                           Inventaire ANNUEL
########################################################################
$GEN_ANNUEL

Local Integer WITMNBR
Local Integer WITMSTK   # nombre de ligne de stock par article
Local Integer WABTRT         # hcb ctr
Raz WABTRT                   # hcb ctr

WITMSTK = 0
WITMNBR = 0
WWRH    = "1=1"
Call DEBTRANS From GLOCK
Trbegin [CUD]
If GITMWRH = 2
   Local Char WWRHLEC (GLONWRH)
   Local Char WWRHRUP (GLONWRH)
   Raz WWRHLEC
   Raz WWRHRUP
   Link [ITW] With [ITM]ITM0=[F:ITW]ITMREF,[ITF]ITF0=[F:ITW]ITMREF;[F:ITW]STOFCY
&             As [INV]
&             Where evalue(WFILF)    &
&                   evalue(WFILSPEITF) &
&                   evalue(WFILITW)  &
&                   evalue(WSELFOR)
&             Order By Key ITW1
   For [INV]
       Gosub ANA_SELFOR0
       If !WFOR0
          WITM = [F:ITF]ITMREF
          WITMSTK  = 0
          WABCCLS  = [F:ITF]ABCCLS
          WITMNBR  += 1
          If WITMNBR > [F:CUN]ITMNBR
             Call CRE_NEW_INV From STKINV
             WITMNBR = 1
          Endif
# gestion rupture position emplacement
          WWRH    = "[F:STO]WRH = [F:ITW]WRH"
          WWRHLEC = [F:ITW]WRH
          If WWRHRUP = ""
             WWRHRUP = [F:ITW]WRH
          Endif
          If WWRHLEC <> WWRHRUP
             Call CRE_NEW_INV From STKINV
             WITMNBR = 1
             WWRHRUP = WWRHLEC
          Endif

$GEN_1ITW
          Gosub LOA_LIGNES
#                                                            # hcb 110327 deb
# Quantité ligne de stock différente du nombre de série
           If WERR = 4
              GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-mess(50,196,1)-num$([F:STO]STOCOU)-mess(146,184,1)-"="-num$([F:STO]QTYSTU)-mess(483,184,1)-"="-num$(WQTYSTS)
              GMESSAGE+="\"+mess(491,184,1)
              Call MESSAGE(GMESSAGE) From GESECRAN
              Filter [STC]
              Gosub AB_TRT
              Break
           Endif
#                                                            # hcb 110327 fin

# stock en attente de rangment ligne de stock incomplete
          If WERR = 3
             GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(378,199,1)
             GMESSAGE+="\"+mess(377,199,1)
             Call MESSAGE(GMESSAGE) From GESECRAN
             Filter [INV] # hcb ctr
             Gosub AB_TRT
             Break    # hcb ctr
          Endif

# il ni a pas assez de ligne pour un article .........
          If WERR = 2
             Gosub LOA_LIGNES_CPT
             Filter [INV] # hcb ctr
             Gosub AB_TRT
             Break    # hcb ctr
          Endif
          If WERR = 1
             Call CRE_NEW_INV From STKINV
             WERR = 0
             If GOK < 1
                Filter [INV] # hcb ctr
                Gosub AB_TRT
                Break    # hcb ctr
             Endif
             Goto GEN_1ITW
          Endif
       Endif
    Next
    If WABTRT = 0           # hcb ctr
       Filter [INV]
    Endif
Else
   Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF
&             As [INV]
&             Where evalue(WFILF)     &
&                   evalue(WFILSPEITF) &
&                   evalue(WSELFOR)
&             Order By Key ITF1
   For [INV]
       Gosub ANA_SELFOR0
       If !WFOR0
          WITM     = [F:ITF]ITMREF
          WITMSTK  = 0
          WABCCLS  = [F:ITF]ABCCLS
          WITMNBR  += 1
          If WITMNBR > [F:CUN]ITMNBR
             Call CRE_NEW_INV From STKINV
             WITMNBR = 1
          Endif
$GEN_1
          Gosub LOA_LIGNES
#                                                            # hcb 110327 deb
# Quantité ligne de stock différente du nombre de série
           If WERR = 4
              GMESSAGE = [F:STO]STOFCY-[F:STO]ITMREF-mess(50,196,1)-num$([F:STO]STOCOU)-mess(146,184,1)-"="-num$([F:STO]QTYSTU)-mess(483,184,1)-"="-num$(WQTYSTS)
              GMESSAGE+="\"+mess(491,184,1)
              Call MESSAGE(GMESSAGE) From GESECRAN
              Filter [STC]
              Gosub AB_TRT
              Break
           Endif
#                                                            # hcb 110327 fin
# stock en attente de rangment ligne de stock incomplete
          If WERR = 3
             GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(378,199,1)
             GMESSAGE+="\"+mess(377,199,1)
             Call MESSAGE(GMESSAGE) From GESECRAN
             Filter [INV]
             Gosub AB_TRT
             Break    # hcb ctr
          Endif

# il ni a pas assez de ligne pour un article .........
          If WERR = 2
             Gosub LOA_LIGNES_CPT                           # hcb 27888
             Filter [INV]
             Gosub AB_TRT
             Break    # hcb ctr
          Endif
          If WERR = 1
             Call CRE_NEW_INV From STKINV
             WERR = 0
             If GOK < 1
                Filter [INV]
                Gosub AB_TRT
                Break    # hcb ctr
             Endif
             Goto GEN_1
          Endif
     Endif
  Next
  If WABTRT = 0           # hcb ctr
     Filter [INV]
  Endif
Endif
If WABTRT = 9     # hcb ctr
   Return
Endif

If [M:SIW]NBLIG > 0
     Call CRE_NEW_INV From STKINV
Endif
#maj session inventaire
If GOK = 1
   Gosub MAJ_CUN From STKINV
   If GOK = 1
      Gosub TRT_ECRSTJBID From STKINV
   Else
      Gosub AB_TRT
      Return
   Endif
Else
   Gosub AB_TRT
   Return
Endif

Commit
Return

########################################################################
# LOA_LIGNES                         Chargement des lignes à inventorier
########################################################################
$LOA_LIGNES
Local Integer WBASPAG
Local Integer J
Local Char    WPCU(GLONUOM)
Local Char    WFILSTO   (250)
Local Char    WFILSTO1  (250)
Local Char    WFILSTO2  (250)
Local Char    WFILSTOWRH(100)
Local Char    WFILBPD   (250)
Local Char    WFILSTC1  (250)
Local Char    WCUNLISNUM
Local Integer WOUI
Local Integer WUNELIGNE
WOUI = 2
Raz [F:STC]
If find(WITM,[M:SIW]ITMREF(0..[M:SIW]NBLIG-1))
  Return
Endif

Raz GPE                         # hcb 49878
GPOINT = "DEBLOALIG"            # hcb 49878
Gosub  ENTREE From EXEFNC       # hcb 49878
If GPE <> 0                     # hcb 49878
   Return                       # hcb 49878
Endif                           # hcb 49878

#
# Preparation filtres
WFILSTO    = "1=1"
WFILSTO1   = "1=1"
WFILSTO2   = "1=1"
WFILSTOWRH = "1=1"
WFILBPD    = "1=1"
WFILSTC1   = "1=1"
If GCOD_EMP = 2
# type emplacement
   If [M:SNU2]LOCTYPSTR <> "" | [M:SNU2]LOCTYPEND <> ""
      WFILSTO += "&[F:STO]LOCTYP>='"+[M:SNU2]LOCTYPSTR+"'&[F:STO]LOCTYP<='"+[M:SNU2]LOCTYPEND+"'"
   Endif
# emplacement
   If [M:SNU2]LOCSTR <> "" | [M:SNU2]LOCEND <> ""
      WFILSTO += "&[F:STO]LOC>='"+[M:SNU2]LOCSTR+"'&[F:STO]LOC<='"+[M:SNU2]LOCEND+"'"
   Endif
# tiers  recherche sur Bpdlvcust si emplacement de type client
   If [M:SNU2]BPRNUMSTR <> "" | [M:SNU2]BPRNUMEND <> ""
      WFILBPD += "&[F:BPD]BPCNUM>='"+[M:SNU2]BPRNUMSTR+"'&[F:BPD]BPCNUM<='"+[M:SNU2]BPRNUMEND+"'"
      WFILSTO += "&[F:STO]LOCCAT>=3 &[F:STO]LOCCAT<=4 "
   Endif
Endif

#lot
If dim([M:SNU2]LOTSTR) > 0 & ([M:SNU2]LOTSTR <> "" | [M:SNU2]LOTEND <> "")
   WFILSTO2 += "&[F:STO]LOT>='"+[M:SNU2]LOTSTR+"'&[F:STO]LOT<='"+[M:SNU2]LOTEND+"'"
Endif
#depot
If dim([M:SNU2]WRHSTR) > 0 & ([M:SNU2]WRHSTR <> "" | [M:SNU2]WRHEND <> "")
   WFILSTOWRH += "&[F:STO]WRH>='"+[M:SNU2]WRHSTR+"'&[F:STO]WRH<='"+[M:SNU2]WRHEND+"'"
Endif

#
GPOINT = "FILLOALIG"            # hcb 49878
Gosub  ENTREE From EXEFNC       # hcb 49878

Read [ITM]ITM0=WITM
If fstat = 0
   WBASPAG  = [M:SIW]NBLIG
   If evalue(WFIL1) & evalue(WFIL2)
      Link [STO] With [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
&                As [STOL]
&                Where STOFCY = [M:SNU0]STOFCY &
&                      ITMREF = WITM           &
&                      QTYSTU <> 0             &
&                      evalue(WWRH)            &
&                      evalue(WRUPLOC)         &
&                      evalue(WFILSTO)         &
&                      evalue(WFILSTO1)        &
&                      evalue(WFILSTO2)        &
&                      evalue(WFILSTOWRH)      &
&                      evalue(WSELFOR1)
&                Order By Key STO3

      For [STOL]
          If (dim([M:SNU2]BPRNUMSTR)>0 & ([M:SNU2]BPRNUMSTR <> "" | [M:SNU2]BPRNUMEND <> "")) | WSELFOR2 <> "1=1"
             If [F:STC]STOFCY <> [M:SNU0]STOFCY | [F:STC]LOC <> [F:STO]LOC
                WOUI = 1
                Read [STC]STC0=[M:SNU0]STOFCY;[F:STO]LOC
                If fstat = 0 & evalue(WSELFOR2)
                   WOUI = 2
                   If [M:SNU2]BPRNUMEND <> ""   # si selection sur tiers controle sur BPDLVUST
                      Gosub TRT_BPDLVCUST
                   Endif
                Endif
             Endif
          Endif
          If GITMWRH = 1
             Gosub ANA_SELFOR3
             If WFOR0
                WOUI = 1
             Endif
          Endif
          If WOUI = 2
             GPOINT = "AFTREASTO"
             GPE    = 0
             Gosub  ENTREE From EXEFNC
             If GPE = 0
                Gosub LOA_TABLEAU
                If WERR <> 0
                   Break
                Endif
             Endif
          Endif
      Next
      If WERR <> 0
         Goto LOA_LIGNE1
      Endif
#     Filter [STOL]    # hcb 69036
# Création d'au moins une ligne  sauf si
#          - type inventaire = emplacement (<> 1)
#          - selection lot                             (WFILSTO2)
#          - Formule stocks                            (WSELFOR1)
#          - Formule Emplacements                      (WSELFOR2)
#          - selection emplacement / type emplacement  (WFILSTO)
#          - pas d'autre liste inv pour meme article
      WUNELIGNE  = 1
      If GITMWRH = 2
         If [M:SNU1]CUNSSSTYP = 1     & WITMSTK  = 0    & WFILSTO = "1=1" & WFILSTO2 = "1=1" & [M:SNU1]CUNNULSTK = 2 &
&           WSELFOR1          = "1=1" & WSELFOR2 = "1=1"
            WUNELIGNE = 2
            Call EXI_LIS([M:SNU0]STOFCY,[F:ITF]ITMREF,"",WCUNLISNUM,[F:ITW]WRH) From STKINV
         Endif
      Else
         If [M:SNU1]CUNSSSTYP = 1     & WITMSTK  = 0     & WFILSTO  = "1=1" & WFILSTO2 = "1=1" & [M:SNU1]CUNNULSTK = 2 &
&           WSELFOR1          = "1=1" & WSELFOR2 = "1=1" & WSELFOR3 = "1=1" & WFILSTOWRH = "1=1"
            WUNELIGNE = 2
            Call EXI_LIS([M:SNU0]STOFCY,[F:ITF]ITMREF,"",WCUNLISNUM,"") From STKINV
         Endif
      Endif
      If WCUNLISNUM = "" & WUNELIGNE = 2
         Raz [STO]
         [F:STO]STOFCY    = [M:SNU0]STOFCY
         [F:STO]OWNER     = [M:SNU0]STOFCY   # hcb 58324
         [F:STO]ITMREF    = WITM
         [F:STO]STA       = "A"
         [F:STO]PCU       = [F:ITM]STU
         If GITMWRH = 2
            [F:STO]WRH    = [F:ITW]WRH
         Endif
         [F:STO]PCUSTUCOE = 1
         GPOINT = "AFTREAITM"              #  Hcb 050105 27350
         GPE    = 0                        #  Hcb 050105 27350
         Gosub  ENTREE From EXEFNC         #  Hcb 050105 27350
         If GPE = 0                        #  Hcb 050105 27350
            Gosub LOA_TABLEAU
            If WERR <> 0
               Goto LOA_LIGNE1
            Endif
         Endif                             #  Hcb 050105 27350
      Endif
    Endif
    If WBASPAG = [M:SIW]NBLIG
       If WITMNBR > 0
          WITMNBR -= 1
       Endif
# hcb 72997 deb
       If [M:SNU1]CUNSSSMOD = 2
          Case [F:ITF]ABCCLS
               When 1 : If [M:SNU1]CPLCUNNBRA > 0
                           [M:SNU1]CPLCUNNBRA -= 1
                        Endif
               When 2 : If [M:SNU1]CPLCUNNBRB > 0
                           [M:SNU1]CPLCUNNBRB -= 1
                        Endif
               When 3 : If [M:SNU1]CPLCUNNBRC > 0
                           [M:SNU1]CPLCUNNBRC -= 1
                        Endif
               When 4 : If [M:SNU1]CPLCUNNBRD > 0
                           [M:SNU1]CPLCUNNBRD -= 1
                        Endif
          Endcase
       Endif
# hcb 72997 fin
    Endif
Endif
#Test si article entièrement chargé
$LOA_LIGNE1
If WERR = 3 | WERR = 4                                           # hcb 110327
   Return
Endif
If WERR <> 0 & WBASPAG <> [M:SIW]NBLIG
   J = dim([M:SIW]ITMREF)-WBASPAG
   Dela WBASPAG,J [M:SIW]NBLIG
   [M:SIW]NBLIG = WBASPAG
#si nblig = 0 cela veut dire qu il ni a pas assez de lignes pour un article
   If [M:SIW]NBLIG = 0
      WERR = 2
   Endif
Endif

GPOINT = "FINLOALIG"            # hcb 52365
Gosub  ENTREE From EXEFNC       # hcb 52365

Return

########################################################################
# LOA_TABLEAU                        Chargement des lignes à inventorier
########################################################################
$LOA_TABLEAU
Local Integer  WRET

# quantite 0 interdit si type inventaire = emplacement
# ne sert à rien en stantard mais enlever pour le besoin du PE ARLOAEMP  # hcb 34676
#If [F:CUN]CUNSSSTYP = 2 & [F:STO]QTYSTU = 0
#   Return
#Endif
#dans un inventaire global les lignes de stock doivent etre completes (Lot slo serie de renseignés)
#                   sinon bloquage
#dans un inventaire partiel si les lignes de stock sont incompletes (Lot slo serie non renseignés)
#                   elles sont ignorées
# La ligne de stock en attente de rangement est-elle complète?
If [F:STO]LOCCAT=2
   Raz WRET
   Call CTLPLFLOC([F:STO]ITMREF ,"[F:STO]",WRET) From STKSOR
   If WRET<>0
      If [F:CUN]CUNLASFLG <> 2
         GQUAI +=     1                               # hcb 110327
         Return
      Else
         WERR = 3
      Endif
   Endif
Endif

#                                                        # hcb 110327 deb
 If [F:ITM]SERMGTCOD = 4 & WRET = 0
    Local Char    LMSK
    LMSK = "SIW"
    Raz WRET
    Gosub VERIF_DESYNCHRO From STKINV1
    If WRET<>0
       If [F:CUN]CUNLASFLG <> 2
          GDESYNCHRO +=1
          Return
       Else
          If dim(GCTRSYNCHRO) > 0 & GCTRSYNCHRO <> 0
             GDESYNCHRO +=1
             Return
          Else
             WERR = 4
          Endif
       Endif
    Endif
Endif
#                                                        # hcb 110327 fin

# Wmaxligcal necessaire pour assurer l arrondi
Local Integer WMAXLIGCAL
WMAXLIGCAL       = [M:SNU1]MAXLIGCAL

Raz GPE                         # hcb 49878
GPOINT = "DEBLOATAB"            # hcb 49878
Gosub  ENTREE From EXEFNC       # hcb 49878
If GPE <> 0                     # hcb 49878
   WERR = 1                     # hcb 49878
   Return                       # hcb 49878
Endif                           # hcb 49878

# hcb 100205 27888 deb
If [F:CUN]MULLISFLG = 2 | [M:SNU1]CUNSSSTYP = 2
   If [M:SIW]NBLIG >= WMAXLIGCAL
      Call CRE_NEW_INV From STKINV
      WMAXLIGCAL       = [M:SNU1]MAXLIGCAL
      WITMNBR = 1
   Endif
Endif
# hcb 100205 27888  fin

[M:SIW]STOFCY    = [M:SNU0]STOFCY
[M:SIW]CUNSSSNUM = [M:SNU0]CUNSSSNUM
[M:SIW]CUR       = [M:SNU0]CUR
[M:SIW]CUNLISDAT = [M:SNU1]CUNSSSDAT
If [F:CUN]CUNITMWRH = 2
   [M:SIW]WRHCUL = [F:STO]WRH
Endif
Local Char    SECTION
Local Integer Y
Local Char LWRH(GLONWRH)
If GWRHACT = 2
   LWRH     = [F:STO]WRH
Else
   Raz LWRH
Endif
Local Integer K
If [M:SIW]NBLIG < WMAXLIGCAL
    WITMSTK +=1
    Call EXI_CUD([M:SIW]STOFCY,[F:STO]ITMREF,[F:STO]LOT,[F:STO]SLO,[F:STO]ECCVALMAJ,[F:STO]LPNNUM,[F:STO]LOC,
&                [F:STO]STA,[F:STO]SERNUM,[F:STO]PCU,[F:STO]PCUSTUCOE,
&                [F:STO]PALNUM,[F:STO]CTRNUM,[F:STO]QLYCTLDEM,[F:STO]OWNER,LWRH,[F:STO]STOFLD1,[F:STO]STOFLD2,K)
&        From STKINV
    If K = 1
      Return
    Endif
    Raz GPE                         # hcb 52365
    GPOINT = "AVNLOATAB"            # hcb 52365
    Gosub  ENTREE From EXEFNC       # hcb 52365
    If GPE <> 0                     # hcb 52365
       WERR = 1                     # hcb 52365
       Return                       # hcb 52365
    Endif                           # hcb 52365
    [M:SIW]NBLIG   += 1
    nolign =   [M:SIW]NBLIG
    [M:SIW]ITMREF    (nolign-1) = [F:STO]ITMREF

    If dim([F:STO]WRH) > 0
       [M:SIW]WRH    (nolign-1) = [F:STO]WRH
    Endif
    [M:SIW]ABCCLS    (nolign-1) = WABCCLS
    [M:SIW]LOC       (nolign-1) = [F:STO]LOC
    [M:SIW]LOT       (nolign-1) = [F:STO]LOT
    [M:SIW]LPNNUM    (nolign-1) = [F:STO]LPNNUM
    [M:SIW]SLO       (nolign-1) = [F:STO]SLO
    [M:SIW]ECCVALMAJ (nolign-1) = [F:STO]ECCVALMAJ
    [M:SIW]PCU       (nolign-1) = [F:STO]PCU
    [M:SIW]STA       (nolign-1) = [F:STO]STA
    [M:SIW]QTYPCU    (nolign-1) = [F:STO]QTYPCU
    [M:SIW]PCUSTUCOE (nolign-1) = [F:STO]PCUSTUCOE
    [M:SIW]QTYSTU    (nolign-1) = [F:STO]QTYSTU
    [M:SIW]SERNUM    (nolign-1) = [F:STO]SERNUM
    [M:SIW]STOCOU    (nolign-1) = [F:STO]STOCOU
    [M:SIW]PALNUM    (nolign-1) = [F:STO]PALNUM
    [M:SIW]CTRNUM    (nolign-1) = [F:STO]CTRNUM
    [M:SIW]STOFLD1   (nolign-1) = [F:STO]STOFLD1
    [M:SIW]STOFLD2   (nolign-1) = [F:STO]STOFLD2
    [M:SIW]QLYCTLDEM (nolign-1) = [F:STO]QLYCTLDEM
    [M:SIW]OWNER     (nolign-1) = [F:STO]OWNER
    [M:SIW]LINFLG    (nolign-1) = 2
# en import complet  on cree avec stock nul à oui ..
    If GIMPORT
       [M:SIW]ZERSTOFLG (nolign-1) = 2
       [M:SIW]CUNLISSTA (nolign-1) = 2
    Endif

# si simulation on ne valorise pas et on ne gere pas les sections analytiques
    If dim(GSIMSNU) <= 0
# valorisation
       Call TRT_VALEUR  (nolign-1,"SIW") From STKINV

# sections analytiques
       If nolign-1 > 0 & [M:SIW]ITMREF    (nolign-1) = [M:SIW]ITMREF    (nolign-2)
          For Y = 1 To GNBDIE
              Assign "[M:SIW]CCE"+num$(Y)+"(nolign-1)" With evalue("[M:SIW]CCE"+num$(Y)+"(nolign-2)")
          Next
       Else
          For Y=1 To GNBDIE
              Call INISEC(SECTION, "STKINVD", Y) From TRTX3CPT
              Assign "[M:SIW]CCE"+num$(Y)+"(nolign-1)" With SECTION
          Next
       Endif
    Endif
Else
  WERR = 1
Endif

Return

########################################################################
# GRISE_CLE                             Grisage saisie numero de session
########################################################################
$GRISE_CLE
If GIMPORT
   Return
Endif
Diszo [SNU0]CUNSSSNUM

Actzo [M:SNU2]
Actzo [M:SNU1]
If dim([M:SNU1]LOCPOS) > 0
   Diszo [M:SNU1]LOCPOS
Endif
If dim([M:SNU2]BPRNUMSTR)>0
   Diszo [M:SNU2]BPRNUMSTR
   Diszo [M:SNU2]BPRNUMEND
Endif
Diszo [M:SNU1]CUNNBRA
Diszo [M:SNU1]CUNNBRB
Diszo [M:SNU1]CUNNBRC
Diszo [M:SNU1]CUNNBRD


Return
########################################################################
# DEGRISE_CLE                         Dégrisage saisie numero de session
########################################################################
$DEGRISE_CLE
If GIMPORT
   Return
Endif
Actzo [SNU0]CUNSSSNUM
Diszo [SNU0]STOFCY
Return

########################################################################
# CAL_SIMULATION                                       Calcul simulation
########################################################################
$CAL_SIMULATION

Local Integer I
# tri inventaire
Case [F:CUN]CUNSSSTYP
  When 2 :
    Sorta [M:SIW]NBLIG [M:SIW]NBLIG Order By LOC(indice),ITMREF(indice)
#compteur emplacement
    For I = 0 To [M:SIW]NBLIG-1
        If GSIMNUMLOC <> [M:SIW]LOC(I)  # hcb 140205 27888
           GSIMNUMLOC =  [M:SIW]LOC(I)  # hcb 140205 27888
           GSIMEMP += 1
        Endif
#compteur lignes de stock
        If [M:SIW]STOCOU (I) <> 0
           GSIMSTK += 1
        Endif
    Next
  When Default :
    Sorta [M:SIW]NBLIG [M:SIW]NBLIG Order By ITMREF(indice),LOC(indice)
#compteur article
    Local Char WART
    For I = 0 To [M:SIW]NBLIG-1
        If GITMWRH <> 2
           If [F:CUN]MULLISFLG = 2
              If GSIMNUMART <> [M:SIW]ITMREF(I)
                 GSIMNUMART =  [M:SIW]ITMREF(I)
                 GSIMART += 1
              Endif
           Else
              If WART <> [M:SIW]ITMREF(I)
                 WART =  [M:SIW]ITMREF(I)
                 GSIMART += 1
              Endif
           Endif
        Endif
#compteur lignes de stock
        If [M:SIW]STOCOU (I) <> 0
           GSIMSTK += 1
        Endif
    Next
Endcase
#compteur liste
GSIMLIS += 1
#compteur lignes d inventaire
GSIMLIG += [M:SIW]NBLIG

Raz [M:SIW]

Return

########################################################################
#  Sous programmes                                A C T I O N S  boutons
########################################################################
# ACT_SIMSNU                                           bouton SIMULATION
# ACT_GENSNU                                           bouton GENERATION
# ACT_SUPSNU                                      bouton SUPPRIMER LISTE

########################################################################
# ACT_SIMSNU                                           bouton SIMULATION
########################################################################
Subprog ACT_SIMSNU
Global Integer GSIMSNU
Global Integer GSIMLIS
Global Integer GSIMEMP
Global Integer GSIMART
Global Integer GSIMSTK
Global Integer GSIMLIG
Global Char    GSIMNUMART
Global Char    GSIMNUMLOC(GLONLOC)
Call ACT_GENSNU From SUBSNXA
Kill GSIMSNU
Kill GSIMLIS
Kill GSIMEMP
Kill GSIMART
Kill GSIMSTK
Kill GSIMLIG
Kill GSIMNUMART
Kill GSIMNUMLOC

End
########################################################################
# ACT_GENSNU                                           bouton GENERATION
########################################################################
Subprog ACT_GENSNU
Local Integer WTAB
Local Integer WERR : WERR = 0
Local Char    WITM(GLONITM)
Local Char    WWRH(50)
Local Integer WABCCLS
Local Integer I
Local Integer ILOA
Local Char    WFIL1   (250)    : WFIL1    = "1=1"
Local Char    WFIL2   (250)    : WFIL2    = "1=1"
Local Char    WFILF   (250)    : WFILF    = "1=1"
Local Char    WFILITW (250)    : WFILITW  = "1=1"
Local Char    WSELFOR (250)    : WSELFOR  = "1=1"
Local Char    WSELFOR0(250)    : WSELFOR0 = "1=1"
Local Char    WSELFOR1(250)    : WSELFOR1 = "1=1"
Local Char    WSELFOR2(250)    : WSELFOR2 = "1=1"
Local Char    WSELFOR3(250)    : WSELFOR3 = "1=1"
Local Char    WSELWRH (50)     : WSELWRH  = "1=1"
#MAE, PE 92616
Local Char    WFILSPEITF (250) : WFILSPEITF = "1=1"
Local Char    WRUPLOC (50)     : WRUPLOC  = "1=1"
Local Integer WDIM             : WDIM = int(dim([M:INV2]ITMREF)*0.9)
Local Date    WDAT
Local Integer WCOD
Local Integer WLIG
Global Date GPERSTR
Raz GPERSTR
#                                                                   # hcb 110327 deb
Global Integer GQUAI
Global Integer GDESYNCHRO
Raz GQUAI
Raz GDESYNCHRO
#                                                                   # hcb 110327 fin
If clalev([M:SIW])=0 Local Mask STOINVW   [SIW] Endif  #  ecran détail inventaire
Raz [M:SIW]

[M:SNU1]CPLCUNNBRA = 0
[M:SNU1]CPLCUNNBRB = 0
[M:SNU1]CPLCUNNBRC = 0
[M:SNU1]CPLCUNNBRD = 0

If GITMWRH = 2
# Préparation filtre ITMFACILIT + ITMWRH  si article depot à oui
   WFILF = "[F:ITF]STOFCY=[M:SNU0]STOFCY&[F:ITF]STOMGTCOD>1 "
   If [M:SNU2]ITMREFSTR <> "" | [M:SNU2]ITMREFEND <> ""
      WFILF = WFILF+"&[F:ITF]ITMREF>=[M:SNU2]ITMREFSTR&[F:ITF]ITMREF<=[M:SNU2]ITMREFEND"
   Endif
# depot
   If [M:SNU2]WRHSTR <> "" | [M:SNU2]WRHEND <> ""
      WFILITW = WFILITW+"&[F:ITW]WRH>=[M:SNU2]WRHSTR&[F:ITW]WRH<=[M:SNU2]WRHEND"
   Endif
#mode inventaire
# cunsssmod 1 manuel
# cunsssmod 2 tournant
# cunsssmod 3 annuel
   Case [M:SNU1]CUNSSSMOD
      When 2 :
          WFILITW = WFILITW+"&(([F:ITW]CUNWRHFLG=2&[F:ITW]CUNCOD=1)|([F:ITW]CUNWRHFLG=1&[F:ITF]CUNCOD=1))"   # 1 = tournant
      When 3 :
          WFILITW = WFILITW+"&(([F:ITW]CUNWRHFLG=2&[F:ITW]CUNCOD=2)|([F:ITW]CUNWRHFLG=1&[F:ITF]CUNCOD=2))"   # 2 = annuel
      When Default
          WFILITW = WFILITW+"&(([F:ITW]CUNWRHFLG=2&[F:ITW]CUNCOD<>3)|([F:ITW]CUNWRHFLG=1&[F:ITF]CUNCOD<>3))" # 3 = pas inventaire
   Endcase
#classe abcd sauf tournant
   If [M:SNU1]CUNSSSMOD <> 2
      If !([M:SNU1]ABCCLSA = 1 & [M:SNU1]ABCCLSB = 1 & [M:SNU1]ABCCLSC = 1& [M:SNU1]ABCCLSD = 1)
         WFILF = WFILF+"&find([F:ITF]ABCCLS"
         If [M:SNU1]ABCCLSA = 2
            WFILF = WFILF+",1"
         Endif
         If [M:SNU1]ABCCLSB = 2
            WFILF = WFILF+",2"
         Endif
         If [M:SNU1]ABCCLSC = 2
            WFILF = WFILF+",3"
         Endif
         If [M:SNU1]ABCCLSD = 2
            WFILF = WFILF+",4"
         Endif
         WFILF = WFILF+")"
      Endif
   Endif
#classe abcd tournant
   If [M:SNU1]CUNSSSMOD = 2
      If !([M:SNU1]ABCCLSA = 1 & [M:SNU1]ABCCLSB = 1 & [M:SNU1]ABCCLSC = 1& [M:SNU1]ABCCLSD = 1)
         WFILF = WFILF+"&find([F:ITF]ABCCLS"
         If [M:SNU1]ABCCLSA = 2 & [M:SNU1]CUNNBRA <> 0
            WFILF = WFILF+",1"
         Endif
         If [M:SNU1]ABCCLSB = 2 & [M:SNU1]CUNNBRB <> 0
            WFILF = WFILF+",2"
         Endif
         If [M:SNU1]ABCCLSC = 2 & [M:SNU1]CUNNBRC <> 0
            WFILF = WFILF+",3"
         Endif
         If [M:SNU1]ABCCLSD = 2 & [M:SNU1]CUNNBRD <> 0    # hcb 86919
            WFILF = WFILF+",4"
         Endif
         WFILF = WFILF+")"
      Endif
   Endif

#acheteur
   If [M:SNU2]BUYSTR <> "" | [M:SNU2]BUYEND <> ""
      WFILF = WFILF+"&[F:ITF]BUY>=[M:SNU2]BUYSTR&[F:ITF]BUY<=[M:SNU2]BUYEND"
   Endif
Else
# Préparation filtre ITMFACILIT  si article depot à non

   WFILF = "[F:ITF]STOFCY=[M:SNU0]STOFCY&[F:ITF]STOMGTCOD>1 "
   If [M:SNU2]ITMREFSTR <> "" | [M:SNU2]ITMREFEND <> ""
      WFILF = WFILF+"&[F:ITF]ITMREF>=[M:SNU2]ITMREFSTR&[F:ITF]ITMREF<=[M:SNU2]ITMREFEND"
   Endif
#mode inventaire
# cunsssmod 1 manuel
# cunsssmod 2 tournant
# cunsssmod 3 annuel
   Case [M:SNU1]CUNSSSMOD
      When 2 :
         WFILF = WFILF+"&[F:ITF]CUNCOD=1"   # 1 = tournant
      When 3 :
         WFILF = WFILF+"&[F:ITF]CUNCOD=2"   # 2 = annuel
      When Default
         WFILF = WFILF+"&[F:ITF]CUNCOD<>3"  # 3 = pas inventaire
   Endcase
#classe abcd sauf tournant
   If [M:SNU1]CUNSSSMOD <> 2
      If !([M:SNU1]ABCCLSA = 1 & [M:SNU1]ABCCLSB = 1 & [M:SNU1]ABCCLSC = 1& [M:SNU1]ABCCLSD = 1)
         WFILF = WFILF+"&find([F:ITF]ABCCLS"
         If [M:SNU1]ABCCLSA = 2
            WFILF = WFILF+",1"
         Endif
         If [M:SNU1]ABCCLSB = 2
            WFILF = WFILF+",2"
         Endif
         If [M:SNU1]ABCCLSC = 2
            WFILF = WFILF+",3"
         Endif
         If [M:SNU1]ABCCLSD = 2
            WFILF = WFILF+",4"
         Endif
         WFILF = WFILF+")"
      Endif
   Endif
#classe abcd tournant
   If [M:SNU1]CUNSSSMOD = 2
      If !([M:SNU1]ABCCLSA = 1 & [M:SNU1]ABCCLSB = 1 & [M:SNU1]ABCCLSC = 1& [M:SNU1]ABCCLSD = 1)
         WFILF = WFILF+"&find([F:ITF]ABCCLS"
         If [M:SNU1]ABCCLSA = 2 & [M:SNU1]CUNNBRA <> 0
            WFILF = WFILF+",1"
         Endif
         If [M:SNU1]ABCCLSB = 2 & [M:SNU1]CUNNBRB <> 0
            WFILF = WFILF+",2"
         Endif
         If [M:SNU1]ABCCLSC = 2 & [M:SNU1]CUNNBRC <> 0
            WFILF = WFILF+",3"
         Endif
         If [M:SNU1]ABCCLSD = 2 & [M:SNU1]CUNNBRD <> 0
            WFILF = WFILF+",4"
         Endif
         WFILF = WFILF+")"
      Endif
   Endif

#acheteur
   If [M:SNU2]BUYSTR <> "" | [M:SNU2]BUYEND <> ""
      WFILF = WFILF+"&[F:ITF]BUY>=[M:SNU2]BUYSTR&[F:ITF]BUY<=[M:SNU2]BUYEND"
   Endif
Endif

#MAE, PE 92616
GPOINT = "FILSPEITF"
Gosub  ENTREE From EXEFNC

# Préparation filtre ITMMASTER
#gestion stock
#statut article
If [M:SNU2]ITMSTA006 = 2
   WFIL1 = "[F:ITM]STOMGTCOD>1"
Else
   WFIL1 = "[F:ITM]STOMGTCOD>1&[F:ITM]ITMSTA<>6"
Endif
#Famille statistique
WFIL2 = "1=1"
If [M:SNU2]TCLCODSTR <> "" | [M:SNU2]TCLCODEND <> ""
   WFIL1 += "&[F:ITM]TCLCOD>=[M:SNU2]TCLCODSTR&[F:ITM]TCLCOD<=[M:SNU2]TCLCODEND"
Endif
If dim([M:SNU2]TSICODSTR) > 0
   For I = 0 To dim([M:SNU2]TSICODSTR)-1
   If [M:SNU2]TSICODSTR(I) <> "" | [M:SNU2]TSICODEND(I) <> ""
      If len(WFIL1) > 200
        WFIL2 += "&[F:ITM]TSICOD("+num$(I)+")>='"+[M:SNU2]TSICODSTR(I)+
&                "'&[F:ITM]TSICOD("+num$(I)+")<='"+[M:SNU2]TSICODEND(I)+"'"
      Else
        WFIL1 += "&[F:ITM]TSICOD("+num$(I)+")>='"+[M:SNU2]TSICODSTR(I)+
&                "'&[F:ITM]TSICOD("+num$(I)+")<='"+[M:SNU2]TSICODEND(I)+"'"
      Endif
    Endif
  Next I
Endif
#
# Lecture des formules

# WSELFOR  correspond à la premiere formule de selection du bloc "Articles"     (ITM + ITF) ou (ITM + ITF + ITW si article depots à oui)
# WSELFOR0 correspond à la deuxieme formule de selection du bloc "Articles"     (ITV + ITS + ITP)
# WSELFOR1 correspond à la          formule de selection du bloc "Stocks"       (STO + STL)
# WSELFOR2 correspond à la          formule de selection du bloc "Emplacements" (STC)
# WSELFOR3 correspond à la          formule de selection du bloc "Article-depot"(WRH)

WSELFOR  = "1=1"
WSELFOR0 = "1=1"
WSELFOR1 = "1=1"
WSELFOR2 = "1=1"
WSELFOR3 = "1=1"
If [M:SNU2]SELFOR <> ""
   Read [TFO]TFO0=[M:SNU2]NUMSELFOR;[M:SNU2]SELFOR
   If fstat = 0
      WSELFOR = [F:TFO]FORFOR
   Endif
Endif
If [M:SNU2]SELFOR0 <> ""
   Read [TFO]TFO0=29;[M:SNU2]SELFOR0
   If fstat = 0
      WSELFOR0 = [F:TFO]FORFOR
   Endif
Endif
If [M:SNU2]SELFOR1 <> ""
   Read [TFO]TFO0=27;[M:SNU2]SELFOR1
   If fstat = 0
      WSELFOR1 = [F:TFO]FORFOR
   Endif
Endif
If dim([M:SNU2]SELFOR2) > 0 & [M:SNU2]SELFOR2 <> ""    #  hcb 107895
   Read [TFO]TFO0=28;[M:SNU2]SELFOR2
   If fstat = 0
      WSELFOR2 = [F:TFO]FORFOR
   Endif
Endif
If GITMWRH <> 0
   If [M:SNU2]SELFOR3 <> ""
      Read [TFO]TFO0=43;[M:SNU2]SELFOR3
      If fstat = 0
         WSELFOR3 = [F:TFO]FORFOR
      Endif
   Endif
Endif
#message opération en cours ...
Call TEMPON("O") From GESECRAN
#génération des listes suivant le mode
Case [M:SNU1]CUNSSSMOD
  When 1 : Gosub GEN_MANUEL
  When 2 : Gosub GEN_TOURNANT
  When 3 : Gosub GEN_ANNUEL
Endcase
If dim(GSIMSNU) > 0
#suppression message opération en cours ...
   Call TEMPOFF   From GESECRAN
   Close Local Mask  [SIW]
   If  WERR <> 2
      Local Char MES(255)
      MES = mess(428,199,1)-[F:CUN]CUNSSSNUM+"\"           # Simulation session
      MES += num$(GSIMLIS)-" : "-mess(429,199,1)+"\"       # Listes
      If [F:CUN]CUNSSSTYP = 1 & GITMWRH <> 2
         MES += num$(GSIMART)-" : "-mess(431,199,1)+"\"    # Articles
      Endif
      If [F:CUN]CUNSSSTYP = 2
         MES += num$(GSIMEMP)-" : "-mess(432,199,1)+"\"    # Emplacements
      Endif
      MES += num$(GSIMSTK)-" : "-mess(430,199,1)+"\"       # Lignes de stock
      MES += num$(GSIMLIG)-" : "-mess(433,199,1)+"\"       # Lignes d inventaire
#                                                              # hcb 110327 deb
     # Call MESSAGE(MES) From GESECRAN                     # hcb 110327
      If GQUAI <> 0 | GDESYNCHRO <> 0
         If GQUAI <> 0
            MES += num$(GQUAI)-" : "-mess(492,184,1)+"\"    # Ligne(s) de stock ignorée(s) car incomplete(s)
         Endif
         If GDESYNCHRO <> 0
            MES += num$(GDESYNCHRO)-" : "-mess(493,184,1)  # ligne(s) de stock ignorée(s) car la quantité est différente du nombre de série présents !
         Endif
      Endif
      Call MESSAGE(MES) From GESECRAN
#                                                              # hcb 110327 fin
   Endif
   End
 #                                                              # hcb 110327 deb
Else
   Local Char MES(255)
   Raz MES
   If GQUAI <> 0
      MES = num$(GQUAI)-" : "-mess(492,184,1)       # Ligne(s) de stock incomplete(s)
   Endif
   If GDESYNCHRO <> 0
      If MES <> ""
         MES +="\"
      Endif
      MES += num$(GDESYNCHRO)-" : "-mess(493,184,1) # ligne(s) de stock dont la quantité est différente du nombre de série présents !
   Endif
   If MES <> ""
      Call MESSAGE(MES) From GESECRAN
   Endif
#                                                              # hcb 110327 fin
Endif

Raz GPE                              # hcb 103386
GPOINT = "FINGENSNU1"                # hcb 103386
Gosub  ENTREE From EXEFNC            # hcb 103386

If [M:SNU1]CUNSSSTYP = 2 | GPE <> 0  # hcb 49878 + 103386
   GPOINT = "FINGENSNU"              # hcb 49878
   Gosub  ENTREE From EXEFNC         # hcb 49878
   Raz GPE                           # hcb 103386
Endif                                # hcb 49878

#chargement onglet listes
Call LOAD_SNU3 From SUBSNXA

#suppression message opération en cours ...
Call TEMPOFF   From GESECRAN

Affzo [M:SNU1]CPLCUNNBRA
Affzo [M:SNU1]CPLCUNNBRB
Affzo [M:SNU1]CPLCUNNBRC
Affzo [M:SNU1]CPLCUNNBRD

If [M:SNU3]NBRLIG(0) = 0
   If GIMPORT                                        # hcb 43817
      Call ECR_TRACE(mess(7,187,1),0) From GESECRAN  # hcb 43817
      GOK = 0                                        # hcb 43817
   Else                                              # hcb 43817
      Call MESSAGE(mess(7,187,1)) From GESECRAN
   Endif                                             # hcb 43817
Endif

Close Local Mask  [SIW]

End



########################################################################
# ACT_SUPSNU                                      bouton SUPPRIMER LISTE
########################################################################
Subprog ACT_SUPSNU

Local Integer WABTRT         # hcb ctr
Raz WABTRT                   # hcb ctr

Call DEBTRANS From GLOCK

Gosub  VERF_ANU From SUBSNX
If GOK = 0
   End
Endif

Trbegin [CUD]

Gosub  ANNULE From SUBSNX
If GOK = 0
   Gosub AB_TRT
   End
Endif
If clalev([F:CUN1])=0 Local File CUNSESSION [CUN1]  Endif

Readlock [CUN1]CUN0=[M:SNU0]CUNSSSNUM
Case fstat
     When 0 :
     When 1 :
             GOK = -1
             GMESSAGE = mess(20,100,1)-"CUNSESSION"-[M:SNU0]CUNSSSNUM
             Return
     When Default :
             GOK = 0
             Call FSTA("CUN") From GLOCK
             Return
     Endcase

[F:CUN1]CPLCUNNBRA = 0
[F:CUN1]CPLCUNNBRB = 0
[F:CUN1]CPLCUNNBRC = 0
[F:CUN1]CPLCUNNBRD = 0

[F:CUN1]CUNSSSSTA  = 1
[F:CUN1]CREUSR     = GUSER
[F:CUN1]CREDAT     = date$

Rewrite  [CUN1]
If fstat
   GOK = 0
   Call FSTA("CUN") From GLOCK
   Gosub AB_TRT
   End
Endif

Close Local File [CUN1]

# read pour rafraichir le buffer CUN
Read [CUN]CUN0=[M:SNU0]CUNSSSNUM

Commit

#chargement onglet listes
Raz   [M:SNU3]
Affzo [M:SNU3]
[M:SNU0]CUNSSSSTA = 1
Raz [M:SNU1]CPLCUNNBRA
Raz [M:SNU1]CPLCUNNBRB
Raz [M:SNU1]CPLCUNNBRC
Raz [M:SNU1]CPLCUNNBRD

Affzo [M:SNU0]CUNSSSSTA
Affzo [M:SNU1]CPLCUNNBRA
Affzo [M:SNU1]CPLCUNNBRB
Affzo [M:SNU1]CPLCUNNBRC
Affzo [M:SNU1]CPLCUNNBRD

Gosub LIENS From SUBSNX

End



#################################################################################################
# TRT_BPDLVCUST Controle tier  emplacement pret  type emplacement client (fichier Clients livrés)
#################################################################################################
$TRT_BPDLVCUST
Raz [BPD]

Local Char    WBPDLOC(50)
#
# Preparation filtres
WBPDLOC = "1=1"

# type client
If [F:STO]LOCCAT = 3
   WBPDLOC += "&[F:BPD]BPCLOC = [F:STC]LOC"
Endif
# type sous-traitant
If [F:STO]LOCCAT = 4
   WBPDLOC += "&[F:BPD]SCOLOC = [F:STC]LOC"
Endif

Filter [BPD] Where STOFCY = [F:STC]STOFCY &
&                  evalue(WBPDLOC)&
&                  evalue(WFILBPD)
&            Order By STOFCY

Look [BPD] First
If fstat = 0
   WOUI = 2
Else
   WOUI = 1
Endif
Filter [BPD]

Return



