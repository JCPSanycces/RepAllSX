#<AdxTL>@(#)12.0.0.0 $Revision$
###############################################################################################################
#
#   Génération XML du planning des techniciens                                                   Version 140
#   Module CRM                             
#
#   PLXINXML    : Extraction XML du planning des techniciens
#   
###############################################################################################################
###############################################################################################################
Subprog PLXINXML(SZSKILL, IDAYRANGE, SZDAYPOS, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZSKILL
Value Integer IDAYRANGE
Value Char SZDAYPOS
Value Integer IGENERICFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF

Local Char SZFCY(GLONFCY)
Local Char SZPBLNAME(100)
Local Integer ICELLHOU
Local Integer ICELLMNT
Local Integer ICELLSTART
Local Integer ICELLEND
Local Integer IOVERDAY
Local Date DOVERDAT
Local Date DOVERDATEND
Local Char SZOVERHOUEND
Local Integer IWHOLEDAY
Local Char SZXCELLSTART
Local Char SZXCELLEND
Local Char SZXAXISLINE
Local Char SZXAXISCOL
Local Char SZXID
Local Char SZXDATECOLL
Local Char SZXDATEELT
Local Char SZXRECORDNAME
Local Char SZXAUSTITLE
Local Char SZAUSTITLE(100)
Local Integer IAXISCOL

  If !clalev([F:ITN]) : Local File INTERVEN [ITN] : Endif
  If !clalev([F:PBL]) : Local File FAMPB [PBL] : Endif
  If !clalev([F:PBR]) : Local File FAMPBREP [PBR] : Endif
  If !clalev([F:AUS2]) : Local File AUTILIS [AUS2] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  If !clalev([F:AXX]) : Local File ATEXTRA [AXX] : Endif      # FGR 23/09/2009 : X3SUIVI58024
  ICHAPTER = 0
  IERRINF = 0
  SZFULLRETFILE = ""
  SZRETFILENAME = ""
  If IDAYRANGE <= 0 Then
    IDAYRANGE = 31
  Endif
  If SZDAYPOS = "" Then
    SZDAYPOS = "DNM"
  Endif
  # FGR 05/12/2008 : Chargement des paramètres tronc commun
  SZFCY = ""
  #Vérification de la compétence
  If SZSKILL <> "" Then
    Read [PBL]PBL0=SZSKILL
    If fstat Then
      End
    Else
      # FGR 23/09/2009 : X3SUIVI58024
      #SZPBLNAME = [F:PBL]GRPPBLDES
      Call LECTEXTRA(SZPBLNAME,"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
    Endif
  Endif
  IWHOLEDAY = 24 * 60
  SZXRECORDNAME = "XRECORDNAME"
  SZXAUSTITLE = "XAUSTITLE"
  SZXDATECOLL = "XDATECOLL"
  SZXDATEELT = "XDATEELT"
  SZXID = "XID"
  SZXAXISLINE = "XAXISLINE"
  SZXAXISCOL = "XAXISCOL"
  SZXCELLSTART = "XCELLSTART"
  SZXCELLEND = "XCELLEND"
  Gosub XMLPART1 From CRMXML140
  Call TEXTE(14442, SZAUSTITLE) From OBJDIV      #Collaborateurs
  If SZSKILL = "" Then
    #Planning des techniciens après-ventes.
    SZHTMLTITLE = mess(165,177,1)
  Else
    #Planning des techniciens compétents sur : (XXX) XXXXXXX
    SZHTMLTITLE = mess(166,177,1) - ": (" + SZSKILL + ")" - SZPBLNAME
  Endif
  SZSUBPROG = "PLXINXML"
  SZAOBABREV = "PLX"
  If SZXRECORDNAME = "" Then
    SZXRECORDNAME = "XRECORDNAME"
  Endif
  If SZXAUSTITLE = "" Then
    SZXAUSTITLE = "XAUSTITLE"
  Endif
  If SZXDATECOLL = "" Then
    SZXDATECOLL = "XDATECOLL"
  Endif
  If SZXDATEELT = "" Then
    SZXDATEELT = "XDATEELT"
  Endif
  If SZXID = "" Then
    SZXID = "XID"
  Endif
  If SZXAXISLINE = "" Then
    SZXAXISLINE = "XAXISLINE"
  Endif
  If SZXAXISCOL = "" Then
    SZXAXISCOL = "XAXISCOL"
  Endif
  If SZXCELLSTART = "" Then
    SZXCELLSTART = "XCELLSTART"
  Endif
  If SZXCELLEND = "" Then
    SZXCELLEND = "XCELLEND"
  Endif
  Gosub XMLPART2PLX From CRMXML140
  If IERRINF Then
    End
  Endif
  Gosub DOCOREDATE
  Gosub DOCOREXML
  Gosub XMLPART3 From CRMXML140
End

###################################################################
# Génération XML des dates
###################################################################
$DOCOREDATE
Local Integer ICOUNTDATE
Local Char SZMULTIDATE(50)(3)
Local Integer IDATECTL
Local Integer ITERDATE
Local Date DCOMPDATE

  Raz SZMULTIDATE
  ICOUNTDATE = 0
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXDATECOLL + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  For ITERDATE = 0 To IDAYRANGE
    If ITERDATE = 0 Then
      DCOMPDATE = date$
    Else
      DCOMPDATE = date$ + ITERDATE
    Endif
    Gosub GENDATE
  Next
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXDATECOLL + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

###################################################################
$GENDATE
  ICOUNTDATE += 1
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXDATEELT - SZXID + "=" + VQ + num$(ICOUNTDATE) + VQ + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZMULTIDATE
  If instr(1, SZDAYPOS, "D") Then
    IDATECTL = instr(1, SZDAYPOS, "D") - 1
    SZMULTIDATE(IDATECTL) = mess(dayn(DCOMPDATE),742,1)
  Endif
  If instr(1, SZDAYPOS, "N") Then
    IDATECTL = instr(1, SZDAYPOS, "N") - 1
    SZMULTIDATE(IDATECTL) = num$(day(DCOMPDATE))
  Endif
  If instr(1, SZDAYPOS, "M") Then
    IDATECTL = instr(1, SZDAYPOS, "M") - 1
    SZMULTIDATE(IDATECTL) = mess(month(DCOMPDATE),961,1)
  Endif
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = SZMULTIDATE(0) - SZMULTIDATE(1) - SZMULTIDATE(2)
  Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXDATEELT + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

###################################################################
# Génération XML
###################################################################
$DOCOREXML
Local Date DDATESTART
Local Date DDATEEND
Local Integer ICOUNTAUS
Local Integer ITER
Local Char SZADILIB(200)
Local Char SZHDKREP
Local Integer IHDKREP
Local Integer IAUSSKILL

  IAUSSKILL = 0
  SZHDKREP = ""
  IHDKREP = 0
  ITER = 0
  ICOUNTAUS = 0
  DDATESTART = date$
  DDATEEND = date$ + IDAYRANGE
  #On extrait
  Filter [AUS2] Where [F:AUS2]USR <> "" Order By [F:AUS2]USR Asc
  For [AUS2]
    If SZSKILL = "" Then
      #Le technicien doit être un collaborateur après-vente
      SZHDKREP = ""
      IHDKREP = 0
      Call PARAMUTIL("AUSHDKA", SZHDKREP, [F:AUS2]USR, "") From SUBAUS
      If SZHDKREP = "" Then
        IHDKREP = 1
      Else
        IHDKREP = val(SZHDKREP)
      Endif
      If IHDKREP = 2 Then
        Gosub EXTRACTITN
      Endif
    Else
      IAUSSKILL = 0
      Filter [PBR] Where [F:PBR]GRPPBLNUM = SZSKILL and [F:PBR]REPNUM = [F:AUS2]USR and [F:PBR]STTFLG = 0
      For [PBR]PBR2
        IAUSSKILL = 1
      Next
      Filter [PBR]
      If IAUSSKILL Then
        Gosub EXTRACTITN
      Endif
    Endif
  Next
  Filter [AUS2]
Return

###############################################
$EXTRACTITN
  ICOUNTAUS += 1
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXRECORD - SZXID + "=" + VQ + num$(ICOUNTAUS) + VQ + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXRECORDNAME + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = "(" + [F:AUS2]USR + ")" - [F:AUS2]NOMUSR
  Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXRECORDNAME + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Filter [ITN] Where (([F:ITN]DATX >= DDATESTART and [F:ITN]DATX <= DDATEEND and [F:ITN]DAT <> [00/00/00])
&                 or ([F:ITN]DAT <> [00/00/00] and [F:ITN]DATX < DDATESTART and [F:ITN]DATEND >= DDATESTART))
&                and [F:ITN]SCO <> 2 and [F:ITN]REP = [F:AUS2]USR and [F:ITN]SCONUM = "" and [F:ITN]DON <> 2
  For [ITN]ITN4 Hint Key ITN1
    If SZFCY <> [F:ITN]SALFCY Then
      # FGR 05/12/2008 : Chargement des paramètres tronc commun
      SZFCY = [F:ITN]SALFCY
      Call GLOBVAR(SZFCY) From WWGLOBTC
    Endif
    #Gestion des interventions s'étalant sur plusieurs jours.
    IOVERDAY = 0
    DOVERDAT = [F:ITN]DAT
    DOVERDATEND = [F:ITN]DATEND
    SZOVERHOUEND = [F:ITN]HOUEND
    While 1
      If DOVERDATEND = [F:ITN]DAT Then
        If IOVERDAY Then
          [F:ITN]HOU = "0000"
          [F:ITN]DATEND = [F:ITN]DAT
          [F:ITN]HOUEND = SZOVERHOUEND
        Endif
        Gosub XMLITN
        Break
      Else
        If IOVERDAY Then
          [F:ITN]HOU = "0000"
          [F:ITN]DATEND = [F:ITN]DAT
          [F:ITN]HOUEND = "0000"
        Else
          [F:ITN]DATEND = [F:ITN]DAT
          [F:ITN]HOUEND = "0000"
        Endif
        Gosub XMLITN
      Endif
      [F:ITN]DAT = [F:ITN]DAT + 1
      IOVERDAY += 1
    Wend
  Next
  Filter [ITN]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXRECORD + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

##################################################################
$XMLITN
  If [F:ITN]DAT < DDATESTART Then
    Return
  Endif
  IAXISCOL = nday([F:ITN]DAT) - nday(date$)
  IAXISCOL += 1
  SZBUFFTOFILL(0) = num$(IAXISCOL)
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXAOB + " T=" + VQ + "ITN" + VQ - SZXAOBNUM + "=" + VQ + [F:ITN]NUM + VQ - SZXAXISLINE + "=" + VQ + num$(ICOUNTAUS) + VQ - SZXAXISCOL + "=" + VQ + num$(IAXISCOL) + VQ + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXCELLSTART + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  Gosub SETCELLSTART
  Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXCELLSTART + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXCELLEND + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  Gosub SETCELLEND
  Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXCELLEND + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Gosub ITNFIELD
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXAOB + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

###############################################################
$SETCELLSTART
  ICELLHOU = val(left$([F:ITN]HOU, 2))
  ICELLMNT = val(mid$([F:ITN]HOU, 3, 2))
  ICELLSTART = ICELLMNT + (ICELLHOU * 60)
  SZBUFFTOFILL(0) = num$(ICELLSTART)
Return

###############################################################
$SETCELLEND
  ICELLHOU = val(left$([F:ITN]HOUEND, 2))
  ICELLMNT = val(mid$([F:ITN]HOUEND, 3, 2))
  ICELLEND = ICELLMNT + (ICELLHOU * 60)
  If ICELLEND <= 0 Then
    ICELLEND = IWHOLEDAY
  Endif
  SZBUFFTOFILL(0) = num$(ICELLEND)
Return

###############################################################
$ITNFIELD
  #Catégorie
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXAOBDATA + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXLABEL + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  Call TEXTE(707, SZBUFFTOFILL(0)) From OBJDIV      #Catégorie
  Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXLABEL + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXFIELD + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  Call GET_LIB(407, [F:ITN]TYP, SZADILIB) From CRM_UTIL
  SZBUFFTOFILL(0) = "(" + [F:ITN]TYP + ") " + SZADILIB
  Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXFIELD + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXAOBDATA + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  #Client
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXAOBDATA + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXLABEL + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  Call TEXTE(3662, SZBUFFTOFILL(0)) From OBJDIV      #Client
  Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXLABEL + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXFIELD + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  If [F:ITN]BPC <> "" Then
    Read [BPR]BPR0=[F:ITN]BPC
    If !fstat Then
      SZBUFFTOFILL(0) = "(" + [F:BPR]BPRNUM + ")" - [F:BPR]BPRNAM
      Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
      Wrseq SZBUFFTOFILL(0) Using [FXML]
    Endif
  Endif
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXFIELD + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXAOBDATA + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  #Début
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXAOBDATA + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXLABEL + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  Call TEXTE(828, SZBUFFTOFILL(0)) From OBJDIV      #Début
  Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXLABEL + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXFIELD + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = format$(GFMD,[F:ITN]DAT) - "-" - left$([F:ITN]HOU, 2) + ":" + mid$([F:ITN]HOU, 3, 2)
  Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXFIELD + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXAOBDATA + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  #Fin
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXAOBDATA + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXLABEL + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  Call TEXTE(829, SZBUFFTOFILL(0)) From OBJDIV      #Fin
  Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXLABEL + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXFIELD + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = format$(GFMD,[F:ITN]DATEND) - "-" - left$([F:ITN]HOUEND, 2) + ":" + mid$([F:ITN]HOUEND, 3, 2)
  Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXFIELD + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXAOBDATA + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  #Adresse
  For ITER = 0 To dim([F:ITN]ADD) - 1
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = A + SZXAOBDATA + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = A + SZXLABEL + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    Call TEXTE(1499, SZBUFFTOFILL(0)) From OBJDIV      #Adresse
    Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = B + SZXLABEL + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = A + SZXFIELD + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = [F:ITN]ADD(ITER)
    Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = B + SZXFIELD + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = B + SZXAOBDATA + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
  Next
  #Code postal
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXAOBDATA + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXLABEL + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  Call TEXTE(210, SZBUFFTOFILL(0)) From OBJDIV      #Code postal
  Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXLABEL + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXFIELD + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = [F:ITN]ZIP
  Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXFIELD + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXAOBDATA + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  #Ville
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXAOBDATA + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXLABEL + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  Call TEXTE(251, SZBUFFTOFILL(0)) From OBJDIV      #Ville
  Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZXLABEL + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZXFIELD + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = [F:ITN]CTY
  Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
