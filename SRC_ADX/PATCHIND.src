#<AdxTL>@(#)10.0.0.0 $Revision$
End
#################################################################
## Intégration d'un texte traduit
# mise a jour des traductions sur ATEXTE sans etre obliger de passer
# par les ecrans fenetres etc.....
#################################################################
$TRANSLATE
#Infbox "type reservé indus"
Local Integer WTYPENR
Local Integer WPRODUIT
WPRODUIT = 0
Case GPRODUIT
   When -1 : If PRODUIT<>"SU" : WPRODUIT = 1 : Endif
   When  0 : If PRODUIT<>"X3" : WPRODUIT = 1 : Endif
   When  1 : If PRODUIT<>"GX" : WPRODUIT = 1 : Endif
   When  2 : If PRODUIT<>"PA" : WPRODUIT = 1 : Endif
   When  3 : If PRODUIT<>"AB" : WPRODUIT = 1 : Endif
Endcase


adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

Raz TEXTE
Raz LANGUE
NBLAN = 0


 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 5 :
    # champ 1 ---> designation
    # champ 2 ---> code langue
    # champ 3 ---> numero
    # champ 4 --> commentaire
    VARIA  = ""
    IND    = 0
    NUMTXT = val(CHAMP(3))
    #U11 COMT   = CHAMP(4)
    COMT   = CHAMP(4)
    NBLAN += 1
    TEXTE(NBLAN)  = CHAMP(1)
    LANGUE(NBLAN) = CHAMP(2)
    COMT(NBLAN) = CHAMP(4)
   When Default
    ER = 32
  Endcase
  If ER : Break : Endif
 Until 1=0
 If ER : Goto ABORT : Endif


If WPRODUIT = 0
   # mise a jour uniquement si même produit sinon on casse les textes
    WTYPENR =TYPENR
    TYPENR = 5
    # mise a jour texte , on force le typenr  = 5 pour avoir automatisme du superviseur
    Gosub AFF_ZONE From PATCH
    TYPENR = WTYPENR
    Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
    # ensuite à la fin il faudra valider tous les ecrans et fenetres......

Else
    Call ECR_TRACE(" product code is different ---"-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
Endif


Return

$ABORT
Return

$SEARCH_ELT
# recherche si le numero est deja dans la table
# et uniquement si write du texte ou rewrite
# avec info dossier + code langue
# tableau dossier~langue~numero
# car si le texte n'est pas reecrit cela ne sert à rien
If !find([F:ADS]DOSSIER+"~"+[F:ATX]LAN+"~"+num$(NUMTXT),NUMINDTXT(1..NBINDTXT))
    If NBINDTXT < 10000
        NBINDTXT +=1
        NUMINDTXT (NBINDTXT)= [F:ADS]DOSSIER+"~"+[F:ATX]LAN+"~"+num$(NUMTXT)
        NUMINDNUM (NBINDTXT)= NUMTXT
    Endif
Endif
Return

