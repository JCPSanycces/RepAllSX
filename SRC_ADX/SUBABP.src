Subprog S_REPJOB(VALEUR)
Variable Char    VALEUR()
Goto S_REP

Subprog S_REPMOD(VALEUR)
Variable Char    VALEUR()
Goto S_REP

Subprog S_REPSTA(VALEUR)
Variable Char    VALEUR()
Goto S_REP

