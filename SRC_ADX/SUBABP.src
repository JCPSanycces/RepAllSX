#<AdxTL>@(#)182.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,GWINDOW,"SUBABP","ABATPAR",3,"SPEABP") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "EXEC"        : Gosub EXEC
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

$INIT
Local Mask ABP1 [DIA]
If clalev([F:ABP])=0 : Local File ABATPAR [ABP] : Endif
If clalev([F:ABR])=0 : Local File ABATRQT [ABR] : Endif
Lock [ABP]
If fstat
 GBIDI1 = 1 : # Locké par un autre utilisateur
 GCONSDIA = 1
Else
 GBIDI1 = 0
 GCONSDIA = 0
Endif
Read [ABP]SPOOL First
If fstat
 Raz [M:DIA]
Else
 [M:DIA] = [F:ABP]
 [M:DIA]REPJOB = [F:ABP]REPJOB(0)
 [M:DIA]REPMOD = [F:ABP]REPJOB(1)
 [M:DIA]REPSTA = [F:ABP]REPJOB(2)
 [M:DIA]REPRUN = [F:ABP]REPJOB(3)
 [M:DIA]REPREQ = [F:ABP]REPJOB(4)
 [M:DIA]REPKIL = [F:ABP]REPJOB(5)
 [M:DIA]REPOLD = [F:ABP]REPJOB(6)
Endif
Return

$SORTIE
If !GBIDI1
 Unlock [ABP]
Endif
Raz GBIDI1
Raz GCONSDIA
Return

$EXEC
If !GBIDI1
 Call DEBTRANS From GLOCK
 Gosub TR1
 If GOK=-2
  Call ERREUR(num$([M:DIA]NUMREQ)-":"-mess(115,134,1)) From GESECRAN
  SAI = 1
 Endif
Endif
Return

$TR1
GOK = 1
Trbegin [ABP]
 Read [ABR]NUMREQ=[M:DIA]NUMREQ
 If !fstat
  GOK = -2 : Goto AB_TR1
 Else
  Readlock [ABP]SPOOL First With lockwait=5
  If fstat=1
   GOK = -1 : GLOCK = "$ABATPAR" : Goto ROLL_TR1
  Endif
  [F:ABP] = [M:DIA]
  [F:ABP]REPJOB(0) = [M:DIA]REPJOB
  [F:ABP]REPJOB(1) = [M:DIA]REPMOD
  [F:ABP]REPJOB(2) = [M:DIA]REPSTA
  [F:ABP]REPJOB(3) = [M:DIA]REPRUN
  [F:ABP]REPJOB(4) = [M:DIA]REPREQ
  [F:ABP]REPJOB(5) = [M:DIA]REPKIL
  [F:ABP]REPJOB(6) = [M:DIA]REPOLD
  If fstat
   Write [ABP]
  Else
   Rewrite [ABP]
  Endif
  If fstat
   GOK = 0 : Call FSTA("ABP") From GLOCK : Goto AB_TR1
  Endif
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

###########################################################################
