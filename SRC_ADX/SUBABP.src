#Endif
End

Subprog C_JOB(VALEUR)
Value Decimal VALEUR
If VALEUR=1
 [M]REPJOB = ""
 [M]REPMOD = ""
 [M]REPSTA = ""
 [M]REPRUN = ""
 [M]REPREQ = ""
 [M]REPKIL = ""
 [M]REPOLD = ""
 Affzo REPJOB, REPMOD, REPSTA, REPRUN, REPREQ, REPKIL, REPOLD
 Grizo REPJOB, REPMOD, REPSTA, REPRUN, REPREQ, REPKIL, REPOLD
Else
 Actzo REPJOB, REPMOD, REPSTA, REPRUN, REPREQ, REPKIL, REPOLD
Endif
End

Subprog AV_SPOOL(VALEUR)
Variable Char    VALEUR()
Local Char JOB(1)
If !GBIDI1 & GPROFIL=GSUPER
 Actzo
 If clalev([F:ABP])=0 & dim([M]TIME1)>0
  Grizo 10
 Endif
 Call PARAMUTIL("EXTBATCH",[L]JOB,"","") From SUBAUS
 If [L]JOB<>"2"
  Diszo JOB
  Diszo REPJOB, REPMOD, REPSTA, REPRUN, REPREQ, REPKIL, REPOLD
 Else
  Actzo JOB
  If [M]JOB=2
   Actzo REPJOB, REPMOD, REPSTA, REPRUN, REPREQ, REPKIL, REPOLD
  Else
   Grizo REPJOB, REPMOD, REPSTA, REPRUN, REPREQ, REPKIL, REPOLD
  Endif
 Endif
Else
 Grizo
Endif
End

Subprog C_REPJOB(VALEUR)
Variable Char    VALEUR()
Goto REPERT

Subprog C_REPMOD(VALEUR)
Variable Char    VALEUR()
Goto REPERT

Subprog C_REPSTA(VALEUR)
Variable Char    VALEUR()
Goto REPERT

Subprog C_REPRUN(VALEUR)
Variable Char    VALEUR()
Goto REPERT

Subprog C_REPREQ(VALEUR)
Variable Char    VALEUR()
Goto REPERT

Subprog C_REPKIL(VALEUR)
Variable Char    VALEUR()
Goto REPERT

Subprog C_REPOLD(VALEUR)
Variable Char    VALEUR()

$REPERT
#  Bug 81458       CC  16/04/2012
If right$(VALEUR,len(VALEUR))="/" or right$(VALEUR,len(VALEUR))="\"
  VALEUR=left$(VALEUR,len(VALEUR)-1)
Endif
#Control that the directory [XXX] exists :
If len(VALEUR) & pat(VALEUR,"[*]*")>0
 Local Integer ASTATUS
 Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
 ASTATUS = func ASYRSTO.CTL_VOLFIL(2,VALEUR,VALEUR,E_TYPE_FOLDER,GMESSAGE)
 If ASTATUS<>CST_AOK : mkstat = 1 : End : Endif
Endif

Local Integer EXISTE
Local Char    REPERT(250)
Local Char    MACHINE(GDIMFIC) , OS(10)
If VALEUR="" : End : Endif
If left$(VALEUR,1)="#"
 GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
 mkstat = 2 : End
Endif
Call MACHINE(VALEUR,MACHINE,REPERT) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If OS=""
 GMESSAGE = MACHINE-mess(90,141,1) : # Machine inexistante
 mkstat = 2 : End
Elsif OS="unix"
 If pat(left$(REPERT,3),"!:\")
  GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
  mkstat = 2 : End
 Elsif left$(REPERT,1)="\"
  GMESSAGE = mess(147,141,1) : # Répertoire inaccessible
  mkstat = 2 : End
 Endif
Else
 If left$(REPERT,1)="/"
  GMESSAGE = mess(147,141,1) : # Répertoire inaccessible
  mkstat = 2 : End
 Endif
Endif
REPERT = filpath(VALEUR,"","",[F:ABP]APPLI,"",adxmac(0))
Call EXISTE(REPERT,EXISTE) From ORDSYS
If EXISTE<>2
 GMESSAGE = mess(9,141,1) : # Répertoire inexistant
 mkstat = 2 : End
Endif
End
######################################################################################
Subprog AM_FLGPATCH(VALEUR)
Variable Integer VALEUR
Local Integer OK
OK=1 : Call OUINON(mess(116,134,1),OK) From GESECRAN
If OK<>2
 VALEUR  = [M]FLGPATCH
Endif
End

######################################################################################
Subprog AS_FLGPATCH(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
 mkstat=1 : End
Endif
End


