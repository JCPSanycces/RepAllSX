Goto S_REP

Subprog S_REPKIL(VALEUR)
Variable Char    VALEUR()
Goto S_REP

Subprog S_REPOLD(VALEUR)
Variable Char    VALEUR()

######################################################################################
$S_REP
Call SELREPREPOLD(VALEUR) From SELFICREP
#Control that the directory [XXX] exists :
If len(VALEUR) & pat(VALEUR,"[*]*")>0
 Local Integer ASTATUS
 Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
 ASTATUS = func ASYRSTO.CTL_VOLFIL(2,VALEUR,VALEUR,E_TYPE_FOLDER,GMESSAGE)
 If ASTATUS<>CST_AOK : mkstat = 1 : End : Endif
Endif
End


