#<AdxTL>@(#)3.0.0.0 $Revision$

#----------------------------------------------------------------#
# Affectation des valeurs
#----------------------------------------------------------------#

Funprog NUMCLE(ACTX,COMPTEUR,SITE,DAT,COMP,TYP,VALEUR,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    COMPTEUR
Value    Char    SITE
Value    Date    DAT
Value    Char    COMP
Value    Char    TYP
Variable Char    VALEUR(),ERRMES()
Local Integer STAT,ASTATUS
[L]ASTATUS=[V]CST_AOK

Local Char  VALORG(255) , VALDES(255)
[L]ASTATUS=func NUMERO(ACTX,COMPTEUR,SITE,DAT,COMP,VALEUR,ERRMES)
If [L]ASTATUS<>[V]CST_AOK : End [L]ASTATUS : Endif

VALORG = VALEUR
[L]ASTATUS=func FMTVAR_SYRA.CONTROLE(ACTX,VALORG,TYP,0,0,VALDES,ERRMES)
If [L]ASTATUS<>[V]CST_AOK | VALEUR<>vireblc(VALDES,4)
 STAT = 10
Endif
If STAT
 [L]ASTATUS=[V]CST_AERROR
 Gosub SET_ERRMES
Endif
End [L]ASTATUS

Funprog NUMERO_FIY(ACTX,COMPTEUR,SITE,DAT,COMP,LEDTYP,VALEUR,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    COMPTEUR
Value    Char    SITE
Value    Date    DAT
Value    Char    COMP
Value    Integer LEDTYP
Variable Char    VALEUR(),ERRMES()
Gosub NUM1
If STAT
 [L]ASTATUS=[V]CST_AERROR
 Gosub SET_ERRMES
Endif
End [L]ASTATUS


Funprog NUMERO(ACTX,COMPTEUR,SITE,DAT,COMP,VALEUR,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    COMPTEUR
Value    Char    SITE
Value    Date    DAT
Value    Char    COMP
Variable Char    VALEUR(),ERRMES()
Gosub NUM1
If STAT
 [L]ASTATUS=[V]CST_AERROR
 Gosub SET_ERRMES
Endif
End [L]ASTATUS

#####################################################################################
$NUM1
Raz [L]VALEUR
Gosub DECL_VAR
Gosub OPEN_FILE
If STAT : Return : Endif

Read [ANM]ANM0 = COMPTEUR
If fstat
 Call RSTA("ANM",COMPTEUR,0,ERRMES) From GLOCK_SYRA
 STAT = 1 : Return
Endif

If WPRODUIT=1 & COMP="" & dim([F:ANM]SEQDEP)>0 & [F:ANM]SEQDEP=2 : ## GEODE
 STAT = 6 : Return
Endif
If !find(9,[F:ANM]POSTYP(0..[F:ANM]NBPOS-1))
 COMP = ""
Endif

Case [F:ANM]NIVRAZ
 When 1 : PERIODE = 0
 When 2 : PERIODE = mod(year(DAT),100)
 When 3 : PERIODE = 100*mod(year(DAT),100)+month(DAT)
 When 4
  # On fait comme pour l'année
  PERIODE = mod(year(DAT),100)
 When 5
  # On fait comme pour le mois
  PERIODE = 100*mod(year(DAT),100)+month(DAT)
Endcase
If PFILEB
 [L]ACTION="NUM1_NIVRAZ"
 Gosub ACTION From =FILEB
 If STAT : Return : Endif
Endif

If [F:ANM]NIVDEF>1 & SITE=""
 STAT = 5 : Return
Endif
Case [F:ANM]NIVDEF
 When 1   : SIT = ""
 When 2   : Gosub SETSOC : SIT = SOC
 When 3   : SIT = SITE
Endcase

## Point d'entrée pour affecter COMP

#GPE = 0
#GPOINT = "NUMERO" : Gosub ENTREE From EXEFNC
#If GPE : Return : Endif : # mb 6.2.2 demande 12328

##

I = find(8,[F:ANM]POSTYP(0..[F:ANM]NBPOS-1))
If !I
 STAT = 4 : Return
Endif

## Attribution du numéro de séquence

VALMAX = val(string$([F:ANM]POSLNG(I-1),"9"))
NBLEC = 0
Repeat
 If dim([F:ANM]SEQ)>0
  Case [F:ANM]SEQ
   When 1 : NBRSEQ = 0 : Gosub SEQ_NORMAL
   When 2 : Gosub SEQ_UNIQ
   When 3 : Gosub SEQ_BUFFER
  Endcase
 Else
  NBRSEQ = 0 : Gosub SEQ_NORMAL
 Endif
 If STAT : Break : Endif
 SEQUENCE = mod(SEQUENCE,VALMAX+1)
Until SEQUENCE<>0
If STAT : Return : Endif
Gosub ATTRIB_NUMERO

#93589
## Point d'entrée pour Retravailler le compteur
#GPE = 0
#GPOINT = "NUMEROCHG" : Gosub ENTREE From EXEFNC
#If GPE : End : Endif

Return

#---------------------------------------#
$ATTRIB_NUMERO
VALEUR = ""
For I=0 To [F:ANM]NBPOS-1
 Case [F:ANM]POSTYP(I)
  When 1 : # Constante
   VALEUR += [F:ANM]POSCTE(I)
  When 2 : # Année
   Case [F:ANM]POSLNG(I)
    When 1 : VALEUR += num$(mod(year(DAT),10))
    When 2 : VALEUR += format$("N0:2#",mod(year(DAT),100))
    When 4 : VALEUR += format$("N0:4#",year(DAT))
   Endcase
  When 3 : # Mois
   Case [F:ANM]POSLNG(I)
    When 2 : VALEUR += format$("N0:2#",month(DAT))
    When 3 : VALEUR += format$("D:MMM",DAT)
   Endcase
  When 4 : # Semaine
   VALEUR += format$("N0:2#",week(DAT))
  When 5 : # Jours
   Case [F:ANM]POSLNG(I)
    When 1 : VALEUR += num$(dayn(DAT))
    When 2 : VALEUR += format$("N0:2#",day(DAT))
    When 3 : VALEUR += format$("N0:3#",DAT-gdat$(1,1,year(DAT))+1)
   Endcase
  When 6 : # Société
   Gosub SETSOC
   If len(SOC)<[F:ANM]POSLNG(I) & [F:ANM]CTLCHR=2
    VALEUR += SOC+string$([F:ANM]POSLNG(I)-len(SOC),"_")
   Else
    VALEUR += left$(SOC,[F:ANM]POSLNG(I))
   Endif
  When 7 : # Site
   If len(SITE)<[F:ANM]POSLNG(I) & [F:ANM]CTLCHR=2
    VALEUR += SITE+string$([F:ANM]POSLNG(I)-len(SITE),"_")
   Else
    VALEUR += left$(SITE,[F:ANM]POSLNG(I))
   Endif
  When 8 : # Séquence
   If SEQUENCE>val(string$([F:ANM]POSLNG(I),"9"))
    STAT = 2
   Endif
   VALEUR += format$("N0:"+num$([F:ANM]POSLNG(I))+"#",SEQUENCE)
  When 9 : # Complément
   If [F:ANM]POSLNG(I)=0
    If len(COMP)>0 & [F:ANM]CTLCHR=2
     STAT = 4
    Endif
    VALEUR += COMP
   Else
    If len(COMP)<[F:ANM]POSLNG(I) & [F:ANM]CTLCHR=2
     STAT = 4
    Endif
    VALEUR += left$(COMP,[F:ANM]POSLNG(I))
   Endif
  When 10 : # Exercice
   If PFILEB
    [L]ACTION="ATTRIB_NUMERO"
    Gosub ACTION From =FILEB
    If STAT : Return : Endif
   Else
     Case [F:ANM]POSLNG(I)
      When 1 : VALEUR += num$(mod(year(DAT),10))
      When 2 : VALEUR += format$("N0:2#",mod(year(DAT),100))
      When 4 : VALEUR += format$("N0:4#",year(DAT))
     Endcase
   Endif
  When 11 : # Période
   If PFILEB
    [L]ACTION="ATTRIB_NUMERO"
    Gosub ACTION From =FILEB
    If STAT : Return : Endif
   Else
     VALEUR += format$("N0:"+num$([F:ANM]POSLNG(I))+"#",month(DAT))
   Endif
  When 12 : # Formule
   Onerrgo RIEN
   FORMU   = evalue([F:ANM]POSCTE(I))
   Onerrgo
   VALEUR += format$("K:"+num$([F:ANM]POSLNG(I))+"X",toupper(FORMU))
 Endcase
Next I
If [F:ANM]TYP=2
 VALEUR = num$(val(VALEUR))
Endif
Return

#---------------------------------------#
$RIEN
Resume

#---------------------------------------#
$DECL_VAR
Local Integer STAT,ASTATUS
[L]STAT=0 : [L]ASTATUS=[V]CST_AOK
Local Integer WPRODUIT : WPRODUIT= fmet ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,ACTX.AFOLDER,"TYPDOS")-1
Local Char ACTION(30),FILEB(50)
FILEB="ANM_TOOLB"
Local Integer  PFILEB
Call EXISTE_ADX("","",FILEB,PFILEB) From ORDSYS

Local Integer I , K
Local Integer PERIODE
Local Char    SIT(10) , SOC(10) , FORMU(20) , COMPLEMENT(30)
Local Integer NBRSEQ , TEMPO , NBLEC , MAXLEC
Local Decimal VALMAX , SEQUENCE

If dim([L]COMP)>0
 COMPLEMENT = COMP
Endif
TEMPO = 3   : # Pour le sleep
MAXLEC = 10 : # Nb max de tentative de lecture si le compteur est verrouillé avant d'afficher le message
Return
#---------------------------------------#
$OPEN_FILE
If ACTX.AFOLDER=nomap
 Local File AVALNUM [AVN]
 Local File ACODNUM [ANM]
Else
 Local File =ACTX.AFOLDER+".AVALNUM" [AVN]
 Local File =ACTX.AFOLDER+".ACODNUM" [ANM]
Endif
If PFILEB
 [L]ACTION="OPEN_FILE"
 Gosub ACTION From =FILEB
 If STAT : Return : Endif
Endif
Return
#---------------------------------------#
$SETSOC
#If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
#If [F:FCY]FCY<>SITE  : Read [FCY]FCY0 = SITE : Endif
#SOC = [F:FCY]LEGCPY
SOC=fmet ACTX.ACACHE.AFCY.AGETVALCHAR(SITE, "LEGCPY")
Return

#--------------------------------------------------------------------------------#
# Message d'erreurs gestion des compteurs
#--------------------------------------------------------------------------------#

$SET_ERRMES
If dim(STAT)>0
 Case STAT
  When 1  : ERRMES -= string$(ERRMES<>"","\")+mess(12,114,1)-COMPTEUR  : # Compteur inexistant
  When 2  : ERRMES -= string$(ERRMES<>"","\")+mess(13,114,1)-COMPTEUR  : # Dépassement de compteur
  When 3  : ERRMES -= string$(ERRMES<>"","\")+mess(34,113,1)  : # Exercice non ouvert
  When 5  : ERRMES -= string$(ERRMES<>"","\")+mess(62,133,1)  : # Société ou site incorrect
  When 4  : ERRMES -= string$(ERRMES<>"","\")+mess(111,123,1) : # Longueur incorrecte
  When 6  : If WPRODUIT=1 : ## GEODE
             ERRMES -= string$(ERRMES<>"","\")+mess(79,310,1) : # Déposant inexistant
            Endif
  When 10 : ERRMES -= string$(ERRMES<>"","\")+mess(21,143,1)  : # Format incorrect (présence d'espaces ou longueur trop grande)
  When 99 : ERRMES -= string$(ERRMES<>"","\")+mess(235,143,1)-COMPTEUR : # Erreur mise à jour compteur séquentiel  (mb 7.5.13 demande 89665)
 Endcase
Endif
Return

#--------------------------------------------------------------------------------#
# Différentes méthodes d'attribution de la séquence
#--------------------------------------------------------------------------------#

$SEQ_NORMAL
Readlock [AVN]AVN0 = COMPTEUR;SIT;PERIODE;COMP
If fstat=1
 If NBLEC>=MAXLEC
  ERRMES = "$AVALNUM"-COMPTEUR-SIT-num$(PERIODE)-COMP : STAT = 99
 Else
  NBLEC += 1 : Sleep TEMPO
 Endif
 Return
Elsif fstat
 SEQUENCE = 1
 Raz [F:AVN]
 [F:AVN]CODNUM  = COMPTEUR
 [F:AVN]SITE    = SIT
 [F:AVN]PERIODE = PERIODE
 [F:AVN]COMP    = COMP
 [F:AVN]VALEUR  = 2+NBRSEQ
 Write [AVN]
Else
 SEQUENCE = [F:AVN]VALEUR
 [F:AVN]VALEUR += 1+NBRSEQ
 Rewrite [AVN]
Endif
If fstat
 Call FSTA("AVN",0,ERRMES) From GLOCK_SYRA : STAT = 99 : Return
Endif
For K=1 To NBRSEQ
 [F:AVA] = [F:AVN]
 [F:AVA]VALEUR = SEQUENCE+K
 Write [AVA]
 If fstat
  Call FSTA("AVA",0,ERRMES) From GLOCK_SYRA : Break
 Endif
Next K
Return

$SEQ_UNIQ
#If evalue("clalev([F:"+[F:ANM]SEQABR+"])")=0
  If ACTX.AFOLDER=nomap
   Local File =[F:ANM]SEQTBL
  Else
   Local File =ACTX.AFOLDER+"."+[F:ANM]SEQTBL
  Endif
#Endif
SEQUENCE = evalue("uniqid([F:"+[F:ANM]SEQABR+"])")
Return

$SEQ_BUFFER
If ACTX.AFOLDER=nomap
 Local File AVALATT [AVA]
Else
 Local File =ACTX.AFOLDER+".AVALATT" [AVA]
Endif
SEQUENCE = 0
For [AVA]AVA0 Where CODNUM=COMPTEUR & SITE=SIT & PERIODE=[L]PERIODE & COMP=[L]COMP
 Readlock [AVA]AVA0 Curr With lockwait=0
 If fstat=0
  SEQUENCE = [F:AVA]VALEUR
  Delete [AVA]
  Break
 Endif
Next
If SEQUENCE=0
 NBRSEQ = [F:ANM]SEQNBR
 Gosub SEQ_NORMAL
Endif
Return

#--------------------------------------------------------------------------------#
## Renvoie le numéro précédent
#--------------------------------------------------------------------------------#
# si VALEUR est renseigné, retourne VALEUR-1,
# sinon, renvoie le dernier numéro créé
#--------------------------------------------------------------------------------#

Funprog NUMERO_PREC(ACTX,COMPTEUR,SITE,DAT,COMP,VALEUR,SEQ,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    COMPTEUR
Value    Char    SITE
Value    Date    DAT
Value    Char    COMP
Variable Char    VALEUR()
Variable Integer SEQ
Variable Char    ERRMES()

Raz [L]VALEUR
Gosub DECL_VAR
Gosub OPEN_FILE
If STAT : Goto FIN_PREC : Endif

Local Integer LNG, DEPL
Local Char CHAINE(20)
SEQ = 0 : STAT = 0

Read [ANM]ANM0 = COMPTEUR
If fstat
 Call RSTA("ANM",COMPTEUR,0,ERRMES) From GLOCK_SYRA
 STAT = 1 : Goto FIN_PREC
Endif
# On décrémente de 1 le numéro de séquence du compteur
DEPL=1 : LNG=0 : I=0
If VALEUR <> ""
 While ([F:ANM]POSTYP(I)<>8) & (I<=[F:ANM]NBPOS-1)
  DEPL += [F:ANM]POSLNG(I)
  I += 1
 Wend
 If I<=[F:ANM]NBPOS-1 : LNG = [F:ANM]POSLNG(I) : Else STAT = 99 : Goto FIN_PREC : Endif
 SEQ = val(mid$(VALEUR,DEPL,LNG))
 If SEQ = 0 : SEQ = 1
 Elsif SEQ > 1 : SEQ -= 1 : Endif
 CHAINE = left$(VALEUR,DEPL-1) + format$("N0:"+num$(LNG)+"#",SEQ)
 If DEPL+LNG <= len(VALEUR)
  CHAINE += seg$(VALEUR,DEPL+LNG,len(VALEUR)) : # mb 3.3.3 Bug 17503
 Endif
 VALEUR = CHAINE
 Goto FIN_PREC
Endif

Local Integer PERIODE
Local Char    SIT(10) , SOC(10)

If !find(9,[F:ANM]POSTYP(0..[F:ANM]NBPOS-1))
 COMP = ""
Endif
Case [F:ANM]NIVRAZ
 When 1 : PERIODE = 0
 When 2 : PERIODE = mod(year(DAT),100)
 When 3 : PERIODE = 100*mod(year(DAT),100)+month(DAT)
 When 4
  # On fait comme pour le mois
  PERIODE = 100*mod(year(DAT),100)+month(DAT)
Endcase
If PFILEB
 [L]ACTION="NUMERO_PREC_NIVRAZ"
 Gosub ACTION From =FILEB
 If STAT : Return : Endif
Endif
Case [F:ANM]NIVDEF
 When 1   : SIT = ""
 When 2   : Gosub SETSOC : SIT = SOC
 When 3   : SIT = SITE
Endcase
Read [AVN]AVN0 = COMPTEUR;SIT;PERIODE;COMP
If !fstat
 SEQUENCE = [F:AVN]VALEUR-1
Elsif fstat=5
 SEQUENCE = 1
Endif
SEQ = SEQUENCE
VALEUR = ""
For I=0 To [F:ANM]NBPOS-1
 Case [F:ANM]POSTYP(I)
  When 1 : # Constante
   VALEUR += [F:ANM]POSCTE(I)
  When 2 : # Année
   Case [F:ANM]POSLNG(I)
    When 1 : VALEUR += num$(mod(year(DAT),10))
    When 2 : VALEUR += format$("N0:2#",mod(year(DAT),100))
    When 4 : VALEUR += format$("N0:4#",year(DAT))
   Endcase
  When 3 : # Mois
   Case [F:ANM]POSLNG(I)
    When 2 : VALEUR += format$("N0:2#",month(DAT))
    When 3 : VALEUR += format$("D:MMM",DAT)
   Endcase
  When 4 : # Semaine
   VALEUR += format$("N0:2#",week(DAT))
  When 5 : # Jours
   Case [F:ANM]POSLNG(I)
    When 1 : VALEUR += num$(dayn(DAT))
    When 2 : VALEUR += format$("N0:2#",day(DAT))
    When 3 : VALEUR += format$("N0:3#",DAT-gdat$(1,1,year(DAT))+1)
   Endcase
  When 6 : # Société
   Gosub SETSOC
   If len(SOC)<[F:ANM]POSLNG(I) & [F:ANM]CTLCHR=2
    VALEUR += SOC+string$([F:ANM]POSLNG(I)-len(SOC),"_")
   Else
    VALEUR += left$(SOC,[F:ANM]POSLNG(I))
   Endif
  When 7 : # Site
   If len(SITE)<[F:ANM]POSLNG(I) & [F:ANM]CTLCHR=2
    VALEUR += SITE+string$([F:ANM]POSLNG(I)-len(SITE),"_")
   Else
    VALEUR += left$(SITE,[F:ANM]POSLNG(I))
   Endif
  When 8 : # Séquence
   If SEQUENCE>val(string$([F:ANM]POSLNG(I),"9"))
    STAT = 2
   Endif
   VALEUR += format$("N0:"+num$([F:ANM]POSLNG(I))+"#",SEQUENCE)
  When 9 : # Complément
   If [F:ANM]POSLNG(I)=0
    If len(COMP)>0 & [F:ANM]CTLCHR=2
     STAT = 4
    Endif
    VALEUR += COMP
   Else
    If len(COMP)<[F:ANM]POSLNG(I) & [F:ANM]CTLCHR=2
     STAT = 4
    Endif
    VALEUR += left$(COMP,[F:ANM]POSLNG(I))
   Endif
 Endcase
Next I
If [F:ANM]TYP=2
 VALEUR = num$(val(VALEUR))
Endif
$FIN_PREC
If STAT
 [L]ASTATUS=[V]CST_AERROR
 Gosub SET_ERRMES
Endif
End [L]ASTATUS
