#<AdxTL>@(#)4.0.0.0 $Revision$
#<AdxTL>@(#)4.0.0.0 $Revision$
######################################################################################
##  Xtend: Copie fiche Message Xtend
##  Version 0001
######################################################################################
#    GACTION
#        AYSCOP        Copie d'une donnée Xtend
#        AYSFCYCOP     Copie globale d'un site
#    [L]
#        FCYORG, DOSORG
#        FCYDES, DOSDES
#        ELTCOD
#    [F:AYS1] Site origine       Ouvert et lu
#    [F:AYS2] Site destination   Ouvert et lu
######################################################################################
$TRTCOP
If [L]DOSORG=nomap
 Local File AYTMES    [AYM1]
 Local File ATEXTE    [ATX1]
 Local File ATEXTRA   [AXX1]
Else
 Local File =[L]DOSORG+".AYTMES"     [AYM1]
 Local File =[L]DOSORG+".ATEXTE"     [ATX1]
 Local File =[L]DOSORG+".ATEXTRA"    [AXX1]
Endif
If [L]DOSDES=nomap
 Local File AYTMES     [AYM2]
 Local File ATEXTE     [ATX2]
 Local File ATEXTRA    [AXX2]
Else
 Local File =[L]DOSDES+".AYTMES"     [AYM2]
 Local File =[L]DOSDES+".ATEXTE"     [ATX2]
 Local File =[L]DOSDES+".ATEXTRA"    [AXX2]
Endif

Read [AYM1]AYM0 = [L]FCYORG;[L]ELTCOD
If fstat
  OK=0
  Call RSTA("AYM",[L]FCYORG-[L]ELTCOD) From GLOCK
  Goto FINALLY
Endif

Read [AYM2]AYM0 = [L]FCYDES;[L]ELTCOD
DES_ELTCOD=[F:AYM2]MESCOD : Gosub MSGDESOBJ From AYTCOP
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif


$FINALLY
Close Local File [AYM1], [ATX1] , [AXX1]
&              , [AYM2], [ATX2] , [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [AYM2] , [ATX2]
 If DES_HASELT
     Delete [AYM2] Where FCYCOD=[L]FCYDES and MESCOD=[L]DES_ELTCOD
     If fstat=1
      GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTMES" : Goto ROLL_TR_COP
     Elsif fstat>5
      GOK = 0 : Call RSTA("AYM2","") From GLOCK : Goto AB_TR_COP
     Endif
 Endif
 For [AYM1]AYM0 Where FCYCOD=[L]FCYORG & MESCOD=[L]ELTCOD
  [F:AYM2] = [F:AYM1]
  [F:AYM2]FCYCOD = [L]FCYDES
  Call COPTEXTRA("AYTMES","INTIT",[F:AYM1]FCYCOD,[F:AYM1]MESCOD,[L]FCYDES) From SUBAYS
  If GOK<1 : Break : Endif
  [F:AYM2]UPDUSR = GUSER
  [F:AYM2]UPDDAT = date$
  # [F:AYM2]UPDTIM = time  - 93575
  Call SET_UPDTIM("AYM2") From AYTCOP # 93575
  [F:AYM2]BRWX3  = [F:AYM2]FCYCOD+"_"+[F:AYM2]MESCOD
#*  [F:AYM2]CODACT = [L]ELTCODACT
  Write [AYM2]
  If fstat
   GOK=0 : Call FSTA("AYM2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
