# SAM 112148 XML signature
# JUCON
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM
Value Char VALEUR
Variable Integer OK
OK=1
  Case PARAM
    When "FACTURAE"
    If func AFNC.ACTIV("EDIX3")<0 and VALEUR=2: OK=0 : GMESSAGE="EDIX3:"- mess(24,176,1) : Endif  #Inactive Activity Code
  Endcase

End

