#<AdxTL>@(#)0.0.0.0 $Revision$
$TEST
Raz GBIDI1,GBIDI2
Local Integer TYPAGE
Call VALCTRLREF("ZQLF",nomap,1,0,GBIDI2)
End

#------------------------------------------------------------------#
Subprog VALCTRLREF(CODTYP,DOSSIER,TEST,SILENCE,OK)
Value    Char       CODTYP
Value    Char       DOSSIER
Value    Integer    TEST
Value    Integer    SILENCE
Variable Integer    OK

Local Char    MACHINE(GDIMFIC) , APPLI(GLONADS)

OK = 1

If TEST>0 & GTRACE=""
 # Validation du type de données
 Call OUVRE_TRACE(mess(326,139,1)-[L]CODTYP) From LECFIC
Endif

Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

If !SILENCE
 Call TEMPON(mess(326,139,1)-[L]CODTYP) From GESECRAN
Endif

If GTRACE<>""
 Call ECR_TRACE(mess(326,139,1)-[L]CODTYP,0) From GESECRAN
Endif

Local Instance ATY   Using C_ACLATYPE
Local Instance AERR(1..)   Using C_AERROR

ATY = NewInstance  C_ACLATYPE AllocGroup null

Call VERIF_VALID_ATY(MACHINE, APPLI,DOSSIER,CODTYP,OK,AERR)
If  func ACLACONTROL.HAS_AERR(AERR)>0
 Goto PERDU
Endif

If OK=-1 : OK=1 : Goto FIN : Endif
If !OK : Goto FIN : Endif

# Chargement classe

Call INI_ACLAVARDEF([L]CODTYP,DOSSIER,ATY,AERR)

Call LOAD_ATY(TEST,DOSSIER,CODTYP,ATY,AERR)
If func ACLACONTROL.HAS_AERR(AERR)>0
 Goto PERDU
Endif

#If !find("ACTRLREF",ATY.ARUL(1..).PRGRUL) : Goto FIN : Endif
If !find("ACTRLREF",ATY.ARUL(1..maxtab(ATY.ARUL)).PRGRUL) | ATY.ACLA.ACLAK(1).TABLNK="" : Goto FIN : Endif

Call VALTRT_ATY(DOSSIER,MACHINE,APPLI,CODTYP,ATY,AERR)
If func ACLACONTROL.HAS_AERR(AERR)>0
 Goto PERDU
Endif

Goto FIN

#-------------------------------------------------------#
$FIN
#pour afficher les erreurs et warning
Call TRACE_AERR(AERR) From ACLACONTROL
If !SILENCE
 Call TEMPOFF From GESECRAN
Endif
If TEST
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
FreeGroup ATY
End

#-------------------------------------------------------#
$PERDU
OK=0
Raz GMESSAGE
Goto FIN

#-------------------------------------------------------#
$ERREUR
Call ECR_TRACE(errp-mess(93,100,1)-num$(errl)+"\"+errmes$(errn)-"("+num$(errn)+")|"-errm,1) From GESECRAN
Resume

#-------------------------------------------------------#
$ADDCLB
Append CLOB,space$(DIF)+LIGNE+chr$(10)
Return

#-------------------------------------------------------#
$ADDCLB0
Append CLOB,LIGNE+chr$(10)
Return

#-------------------------------------------------------#
Subprog VALTRT_ATY(DOSSIER,MACHINE,APPLI,CODTYP,ATY,AERR)
Value Char DOSSIER , MACHINE,APPLI,CODTYP
Variable  Instance  ATY  Using C_ACLATYPE
Variable  Instance  AERR(1..) Using C_AERROR

Gosub TRT_ACTRLREF

Call STC_DEB([L]APPLI,[L]MACHINE,ATY.ACLAV.CTLPRG,ATY.ACLAV.IDENTSTC,ATY.CODTYP,func ASYRFNC.TEXTE(ATY.INTITTYP),ATY.ACLAV.MAGIC,ATY.ACLAV.TITETA,"TRT") From ACLASUB
Call TRT_FIN([L]CLOB,ATY.ACLAV.CTLPRG,0,[L]DOSSIER,"TRT",[L]OK,AERR) From ACLASUB
If maxtab(AERR)>0  : End : Endif

End

#-------------------------------------------------------#
$TRT_ACTRLREF
Local Clbfile    CLOB(9)
Local Integer   DIF,OK,I,J,K,L,M,IRUL,IRULP,HASFILTER,HASENAFLG
Local Char      LIGNE(250)

If ATY.TEST : Call ECR_TRACE("- Create ACTLTRT :"-ATY.ACLAV.CTLPRG,0) From GESECRAN : Endif
# Header subprog
LIGNE = "Funprog "+[V]CST_ANAMCTLREF+"("
For IRUL=1 To maxtab(ATY.ARUL)
 If ATY.ARUL(IRUL).PRGRUL=[V]CST_ANAMCTLREF
  For IRULP=1 To maxtab(ATY.ARUL(IRUL).APARRUL)
   If IRULP>1 :  LIGNE += "," : Endif
   LIGNE += ATY.ARUL(IRUL).APARRUL(IRULP).PARCOD
  Next
  Break
 Endif
Next
LIGNE +=")" : Gosub ADDCLB
For IRUL=1 To maxtab(ATY.ARUL)
 If ATY.ARUL(IRUL).PRGRUL=[V]CST_ANAMCTLREF
  Raz [L]HASFILTER,[L]HASENAFLG
  For IRULP=1 To maxtab(ATY.ARUL(IRUL).APARRUL)
   LIGNE =  func  ACLAVALTRT.DECLARE_MODE(ATY.ARUL(IRUL).APARRUL(IRULP).PARMOD)
   LIGNE -= func ACLAVALTRT.DECLARE_TYPTYP(ATY.ARUL(IRUL).APARRUL(IRULP).PARTYP)
   LIGNE -= ATY.ARUL(IRUL).APARRUL(IRULP).PARCOD
   If ATY.ARUL(IRUL).APARRUL(IRULP).PARCLA<>""
    LIGNE -= "Using "
    If ATY.ARUL(IRUL).APARRUL(IRULP).PARCLA<>"OBJECT"
     LIGNE += "C_"
    Endif
    LIGNE += ATY.ARUL(IRUL).APARRUL(IRULP).PARCLA
   Endif
   Gosub ADDCLB
   If ATY.ARUL(IRUL).APARRUL(IRULP).PARCOD= "AFILTER" : [L]HASFILTER= 1 : Endif
   If ATY.ARUL(IRUL).APARRUL(IRULP).PARCOD= "AENABLE" : [L]HASENAFLG= 1 : Endif
  Next
  Break
 Endif
Next
LIGNE = "" : Gosub ADDCLB
LIGNE = "Local Integer ASTATUS" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
If ATY.ACLA.ACLAK(1).INDEX(1)<>""
 LIGNE = 'If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0' : Gosub ADDCLB
 DIF += 1
 LIGNE = "Local File"-ATY.ACLA.ACLAK(1).TABLNK-"["+ATY.ACLA.ACLAK(1).ABRLNK+"]"  : Gosub ADDCLB
 DIF -= 1
 LIGNE = "Else" : Gosub ADDCLB
 DIF += 1
 LIGNE = 'Local File =AINSTANCE.ACTX.AFOLDER+".'+ATY.ACLA.ACLAK(1).TABLNK+'" ['+ATY.ACLA.ACLAK(1).ABRLNK+']'  : Gosub ADDCLB
 DIF -= 1
 LIGNE = "Endif" : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB
 LIGNE = "Default File [F:"+ATY.ACLA.ACLAK(1).ABRLNK+"]"  : Gosub ADDCLB
 LIGNE = "Read [F:"+ATY.ACLA.ACLAK(1).ABRLNK+"]"+ATY.ACLA.ACLAK(1).CLELNK-"= [L]"+ATY.ACLA.ACLAK(1).INDEX(1)
 For I=2 To ATY.ACLA.ACLAK(1).NBRIND
  LIGNE += ";[L]"+ATY.ACLA.ACLAK(1).INDEX(I)
 Next I
 Gosub ADDCLB
 LIGNE = "If fstat : #"-mess(23,100,1)  : Gosub ADDCLB
 DIF += 1
 LIGNE = '[L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]'+ATY.ACLA.ACLAK(1).INDEX(1)+")"
 For I=2 To ATY.ACLA.ACLAK(1).NBRIND
  LIGNE += '+"~"+num$([L]'+ATY.ACLA.ACLAK(1).INDEX(I)+")"
 Next I
 LIGNE += '-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS' : Gosub ADDCLB
 DIF -= 1
 LIGNE =  "Endif" : Gosub ADDCLB
 If [L]HASFILTER>0
  LIGNE = "" : Gosub ADDCLB
  LIGNE = "Local Integer ATSTFILTER" :  Gosub ADDCLB
  LIGNE = "Local Char     AMESFILTER(250)" :  Gosub ADDCLB
  LIGNE = "Case [L]AFILTER" :  Gosub ADDCLB
  DIF += 1
  For I=1 To ATY.ACLA.NBROPT
   LIGNE = 'When "'+ATY.ACLA.ACLAOPT(I).OPTCOD+'"'  :  Gosub ADDCLB
   DIF += 1
   LIGNE = "[L]ATSTFILTER = ("+ATY.ACLA.ACLAOPT(I).OPTCND+') : [L]AMESFILTER= func ASYRFNC.TEXTE('+num$(ATY.ACLA.ACLAOPT(I).OPTERR)+')'  :  Gosub ADDCLB
   DIF -= 1
  Next
  LIGNE = "When Default" :  Gosub ADDCLB
  DIF += 1
  LIGNE = "[L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)"  :  Gosub ADDCLB
  DIF -= 1
  DIF -= 1
  LIGNE = "Endcase" :  Gosub ADDCLB
  LIGNE = "If [L]ATSTFILTER=0 : #"-mess(23,100,1) : Gosub ADDCLB
  DIF += 1
  LIGNE = '[L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]'+ATY.ACLA.ACLAK(1).INDEX(1)+")"
  For I=2 To ATY.ACLA.ACLAK(1).NBRIND
   LIGNE += '+"~"+num$([L]'+ATY.ACLA.ACLAK(1).INDEX(I)+")"
  Next I
  LIGNE += '-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS' : Gosub ADDCLB
  DIF -= 1
  LIGNE =  "Endif" : Gosub ADDCLB
  If[L]HASENAFLG>0 : # Fiche inactive
   LIGNE = "" : Gosub ADDCLB
   LIGNE = "If dim([F:"+ATY.ACLA.ACLAK(1).ABRLNK+"]ENAFLG) & [F:"+ATY.ACLA.ACLAK(1).ABRLNK+"]ENAFLG<>2 : #"-mess(2,126,1) : Gosub ADDCLB
   DIF += 1
   LIGNE = '[L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]'+ATY.ACLA.ACLAK(1).INDEX(1)+")"
   For I=2 To ATY.ACLA.ACLAK(1).NBRIND
    LIGNE += '+"~"+num$([L]'+ATY.ACLA.ACLAK(1).INDEX(I)+")"
   Next I
   LIGNE += '-":"-mess(2,126,1),[V]CST_AERROR): End [L]ASTATUS' : Gosub ADDCLB
   DIF -= 1
   LIGNE =  "Endif" : Gosub ADDCLB
  Endif
 Endif
Endif
LIGNE = "" : Gosub ADDCLB
LIGNE = "End [V]CST_AOK" : Gosub ADDCLB
Return

#-------------------------------------------------------#
Subprog LOAD_ATY(TEST,DOSSIER,CODTYP,ATY,AERR)
Value Integer TEST
Value Char DOSSIER , CODTYP
Variable  Instance  ATY  Using C_ACLATYPE
Variable  Instance  AERR(1..) Using C_AERROR

Gosub OPEN_FILE From ACLAVALLEC

Local Integer NBR_RUL,NBR_RULPAR,ACLAK_NBR
Read [F:ATY]CODTYP = [L]CODTYP
If !fstat
 SetInstance ATY With [F:ATY]
 ATY.TEST = [L]TEST
 If ATY.TEST
  Call ECR_TRACE("Type :"-ATY.CODTYP,0) From GESECRAN
 Endif
 For [F:ATYR]ATYR0 Where CODTYP= ATY.CODTYP
  If [ATYR]ACTRUL<>""
   Read [ACV]CODACT =  [ATYR]ACTRUL
  Endif
  If (!fstat & [F:ACV]FLACT=2) or  [ATYR]ACTRUL=""
   NBR_RUL += 1
   ATY.ARUL(NBR_RUL) = NewInstance C_ACLATYPRUL AllocGroup ATY
   SetInstance ATY.ARUL(NBR_RUL)  With [F:ATYR]
   If ATY.TEST
    Call ECR_TRACE("--"-num$(NBR_RUL)-":"-mess(ATY.ARUL(NBR_RUL).TYPRUL,7961,1)-ATY.ARUL(NBR_RUL).TRTRUL-ATY.ARUL(NBR_RUL).PRGRUL,0) From GESECRAN
   Endif
   Raz NBR_RULPAR
   For [ATYRP]ATYRP1 Where  CODTYP= ATY.CODTYP & TYPRUL= ATY.ARUL(NBR_RUL).TYPRUL
&                                    & TRTRUL=ATY.ARUL(NBR_RUL).TRTRUL & PRGRUL=ATY.ARUL(NBR_RUL).PRGRUL
    NBR_RULPAR +=1
    ATY.ARUL(NBR_RUL).APARRUL(NBR_RULPAR) = NewInstance C_ACLATYPRULP AllocGroup ATY
    SetInstance ATY.ARUL(NBR_RUL).APARRUL(NBR_RULPAR) With [F:ATYRP]
    If ATY.TEST
     Call ECR_TRACE("---"-num$(NBR_RULPAR)-":"-ATY.ARUL(NBR_RUL).APARRUL(NBR_RULPAR).PARCOD,0) From GESECRAN
    Endif
   Next
  Endif
 Next
 ATY.ACLA = NewInstance C_ACLA  AllocGroup ATY
 Call CHARGE_ACLA(ATY.CODCLA,0,ATY.ACLA,AERR) From ACLAVALLEC   : # Classe
 Call CHARGE_ACLAF(ATY.CODCLA,0,"",ATY.ACLA,AERR) From ACLAVALLEC : # Champs
 Call CHARGE_ACLE(ATY.CODCLA,ATY.ACLA,AERR) From ACLAVALLEC : # Clés
 If ATY.TEST
  Call ECR_TRACE("## Class :"-ATY.ACLA.CODCLA,0) From GESECRAN
 Endif
 ACLAK_NBR += 1
 ATY.ACLA.ACLAK(ACLAK_NBR) = NewInstance C_ACLALNK  AllocGroup ATY
 ATY.ACLA.ACLAK(ACLAK_NBR).CLALNK  = ATY.CODCLA
 ATY.ACLA.ACLAK(ACLAK_NBR).TABLNK  = ATY.ACLA.TABREF
 ATY.ACLA.ACLAK(ACLAK_NBR).CLELNK  = ATY.ACLA.INDREF
 Read [F:ATB]CODFIC  = ATY.ACLA.ACLAK(ACLAK_NBR).TABLNK
 ATY.ACLA.ACLAK(ACLAK_NBR).ABRLNK  = [F:ATB]ABRFIC
 Read [ATI]CODIND = ATY.ACLA.ACLAK(ACLAK_NBR).TABLNK;ATY.ACLA.ACLAK(ACLAK_NBR).CLELNK
 If !fstat & [F:ATI]HOMONYM<2
  ATY.ACLA.ACLAK(ACLAK_NBR).EXPLNK = [F:ATI]DESCRIPT
 Endif
 Call  EXPR_INDEX_TRI(ATY.ACLA.ACLAK(ACLAK_NBR),[L]DOSSIER) From ACLAVALLEC : # Expression fields / index fields
 For I=1 To ATY.ACLA.ACLAK(1).NBRIND
  J=find(ATY.ACLA.ACLAK(1).INDEX(I),ATY.ACLA.ACLAF(1..maxtab(ATY.ACLA.ACLAF)).FLDCLA)
  If J
   ATY.ACLA.ACLAK(1).CODTYPIND(I) = ATY.ACLA.ACLAF(J).CODTYP
   ATY.ACLA.ACLAK(1).TYPIND(I)  = ATY.ACLA.ACLAK(1).TYPIND(I)
   ATY.ACLA.ACLAK(1).LNGIND(I) = ATY.ACLA.ACLAF(J).LON
  Endif
 Next
Endif

Gosub CLOSE_FILE From ACLAVALLEC
End

#--------------------------------------------------#
Subprog INI_ACLAVARDEF(CODTYP,DOSSIER,ATY,AERR)
Value Char CODTYP
Value Char DOSSIER
Variable  Instance  ATY  Using OBJECT
Variable  Instance  AERR Using C_AERROR
ATY.ACLAV = NewInstance C_ACLAVARDEF  AllocGroup ATY
ATY.ACLAV.MAGIC      = mess(77,133,1) : # Superviseur Adonix
ATY.ACLAV.TITETA     = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
ATY.ACLAV.IDENTSTC  = "## ATY-ATYPE ##"
ATY.ACLAV.CTLPRG     = func APREFIXTRT.GET_PREFIX_TYP_ACTRLREF+[L]CODTYP
End

#--------------------------------------------------#
Subprog VERIF_VALID_ATY(MACHINE, APPLI,DOSSIER, CODTYP,RES_OK,AERR)
Value Char       MACHINE, APPLI,DOSSIER
Value Char       CODTYP
Variable Integer RES_OK
Variable  Instance  AERR(1..) Using C_AERROR

Gosub OPEN_FILE From ACLAVALLEC

Read [F:ATY]CODTYP = [L]CODTYP
If fstat
 RES_OK = 0
 Call  ADD_AERR( [L]CODTYP-":"-mess(4,176,1) ,[V]CST_AERROR,0,AERR) From ACLACONTROL  : # Type de donnée inexistant
 Goto FIN_VERIF_VALID_ATY
Elsif !fstat
 If [F:ATY]CODACT<>""
  Read [ACV]CODACT = [F:ATY]CODACT
  If fstat or [F:ACV]FLACT<>2
   RES_OK = -1
   Call  ADD_AERR([L]CODTYP-":"-mess(24,176,1)-"("+[F:ATY]CODACT+")",[V]CST_AWARNING,0,AERR) From ACLACONTROL  : #  : # inactiv typ
   Goto FIN_VERIF_VALID_ATY
  Endif
 Endif
 Gosub DEL_TRT
 If [ATY]CODCLA="" or [ATY]TYPSELSYR<>2
  RES_OK =-1 : Goto FIN_VERIF_VALID_ATY
 Endif
 Read [ACLA]ACLA0 = [ATY]CODCLA
 If fstat
   RES_OK = -1
   Call  ADD_AERR([L]CODTYP-":"-mess(4,140,1)-"("+[F:ATY]CODCLA+")",[V]CST_AWARNING,0,AERR) From ACLACONTROL
   Goto FIN_VERIF_VALID_ATY
 Endif
 If [F:ACLA]TABREF<>""
  Read [F:ATB]CODFIC  = [F:ACLA]TABREF
  If fstat
    RES_OK = -1
    Call  ADD_AERR([L]CODTYP-":"-mess(73,125,1)-"("+[F:ACLA]TABREF+")",[V]CST_AWARNING,0,AERR) From ACLACONTROL
    Goto FIN_VERIF_VALID_ATY
  Endif
 Endif
Endif

$FIN_VERIF_VALID_ATY
Gosub CLOSE_FILE From ACLAVALLEC
End

#--------------------------------------------------#
$DEL_TRT
Local Char     NAMFIC(250)
Local Integer STAT,OKTRT
[L]NAMFIC = filpath("TRT",func APREFIXTRT.GET_PREFIX_TYP_ACTRLREF+[L]CODTYP,"src",APPLI,"",MACHINE)
If filinfo([L]NAMFIC,0)>=0
 Call _EFFACE([L]NAMFIC,STAT) From ASYRSYS
Endif
Call EXISTE_ADX(MACHINE,APPLI,func APREFIXTRT.GET_PREFIX_TYP_ACTRLREF+[L]CODTYP,OKTRT) From ASYRSYS
If OKTRT>0
 Call _EFFACE_ADX(MACHINE,APPLI,func APREFIXTRT.GET_PREFIX_TYP_ACTRLREF+[L]CODTYP,STAT) From ASYRSYS
Endif
Return
