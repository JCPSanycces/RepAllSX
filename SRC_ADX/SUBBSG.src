#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion objet BSG
Call OBJET ("BSG",GBIDC1,GBIDC2) From GOBJET
End
########################################################################
#    GESTION DES CATEGORIES FOURNISSEURS                               #
#----------------------------------------------------------------------#
#                                                         DL Aout 2007 #
#                                                                      #
########################################################################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "STATUT"       : Gosub STATUT
 When "LIENS"        : Gosub LIENS
 When "RAZCRE"       : Gosub RAZCRE
 When "RAZDUP"       : Gosub RAZDUP
 When "APRES_CRE"    : Gosub FINMODIF
 When "AB_CREATION"  : Gosub FINMODIF
 When "AVANT_MOD"    : Gosub AVANTMOD
 When "VERIF_CRE"    : Gosub VERIFCRE_MOD
 When "INICRE"       : Gosub INICRE
 When "VERIF_MOD"    : Gosub VERIFCRE_MOD
 When "INIMOD"       : Gosub INIMOD
 When "APRES_MOD"    : Gosub APRES_MOD
 When "FERME"        : Gosub FERME
 When "CHANGE"       : Call CHANGE_AXX ("BPSCATEG", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
 When Default
Endcase
Return

#########################################################################
########### ACTIONS STANDARD ############################################
#########################################################################


#########################################################################
$OUVRE
If GMODU(7)=2 & !clalev([F:STC])  Local File STOLOC [STC] : Endif

Local Integer WBPATYP : WBPATYP = 1

If clalev([F:ACV])=0  : Local File ACTIV [ACV]  : Endif

If GMODU(2)=2  :# Compta
   Read[ACV]CODACT="DAS"
   If !fstat & [F:ACV]FLACT=2
   If clalev ([PRV]) = 0 : Local File HONPRV [PRV] : Endif
   Endif
Endif

#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB

Local Char SYMBOLE2 (20)
#-----------------------------------------------------#
# Récupérer le site comptable du site tiers  pour     #
# afficher les mouvements du fournisseur  sur ce site #
# la devise est stockée dans les mouvements           #
#                                                     #
# il faut récupérer la devise du site comptable       #
# pour afficher et saisir les montants correctement   #
# car les encours et montants min sont affichés dans  #
# cette devise bien que stockés dans devise dossier   #
#                                                     #
#  - récupérer le site par défaut module TRONC COMMUN #
#  - lecture table des sites avec ce site par defaut  #
#  - ceci nous donne la société juridique et site cpt #
#  - lecture table des sociétés avec societe juridique#
#-----------------------------------------------------#
Local Char WLEGCPY (GLONCPY)    : # société juridique
Local Char WFINRSPFCY (GLONFCY)  : # site comptable

WFINRSPFCY = GFCYDEF(9)
WLEGCPY = ""

#----- on récupére la devise dans une variable globale bidon #
#------ car variable accessible de partout  -----------------#
GCUR= GSYSCUR

If GFCYDEF (9) <> ""
       If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif

       Read [FCY]FCY0 = GFCYDEF(9)
       If fstat = 0
                WLEGCPY    = [F:FCY]LEGCPY
                WFINRSPFCY = [F:FCY]FINRSPFCY
       Endif
Endif
If clalev([F:CPY]) = 0 : Local File COMPANY [CPY] : Endif
If WLEGCPY <> ""
     Read [CPY]CPY0 = WLEGCPY
     If fstat = 0
         GCUR  = [F:CPY]ACCCUR
     Endif
Endif

#---------------------------------------------------------------#
# recherche cours entre devise dossier et devise site comptable #
#---------------------------------------------------------------#
Local Integer SPSTAT

#-- si pas de cours entre devise dossier et devise affichage
#-- la devise affichage devient la devise de reporting
#-- cg le 14 septembre 99 demande numéro ????

GBIDD1 = 0
GBIDD2 = 0

Call CONVERT(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,GBIDD1,GBIDD2,SPSTAT) From TRTDEV
If SPSTAT <> 0
        GCUR = GSYSCUR
Endif

#-----------------------#
# decimal de la devise  #
#-----------------------#
Local Decimal WDECIMAL
WDECIMAL = 0
Read [TCU]TCU0= GCUR
If fstat = 0
    WDECIMAL = [F:TCU]CURRND
Endif

GBIDD1 = 0  : #--- cours devise dossier / devise site comptable ---#
GBIDD2 = 0  : #--- cours devise site comptable / devise dossier ---#
#--- plus besoin le 3 avril 98 double conversion suite à EURO
#Call COURDEV(GSYSCUR,GCUR,GCHGTYP,GHIDATE,GBIDD1,SPSTAT) From TRTDIV
#Call COURDEV(GCUR,GSYSCUR,GCHGTYP,GHIDATE,GBIDD2,SPSTAT) From TRTDIV
#---- Initialisation du code comptable par défaut
#MAE, le 06/01/09, SUP_GACCCOD
#Call INITACCCOD(GACCCOD,3) From TRTX3

If !clalev([F:ADI])  Local File ATABDIV [ADI] : Endif

Gosub OUVRE From TEN99LIB    #1099.n

Return

###################################################################
$FERME
#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
Return

#########################################################################
$AFFICHE_TOUT
Affzo [M:BSG0]1-99
Affzo [M:BSGI]1-99
Affzo [M:BSG1]1-99
Affzo [M:BSG2]1-99
Affzo [M:BSG3]1-99
Return

#########################################################################
$STATUT
Case BOUT
 When "H" : Call NYTBIL([M]BSGCOD,WLEGCPY,"",2,1) From TIERSZOOM : # Effet non échu1
 When "J" : Call NYTBIL([M]BSGCOD,WLEGCPY,"",2,2) From TIERSZOOM : # Effet non échu2
 When "K" : Call NYTBIL([M]BSGCOD,WLEGCPY,"",2,3) From TIERSZOOM : # Effet non échu3
 When "L" : Call PROROG([M]BSGCOD,WLEGCPY,"",2)   From TIERSZOOM : # Prorogations
Endcase

Return

###################################################################
$AVANTMOD
Return

###################################################################
$FINMODIF
Gosub GRIZE_LIENS
If !GIMPORT Gosub RELIT From GOBJSUB : Endif
Return

###################################################################
$GRIZE_LIENS
Return

###################################################################
$LIENS
#-----------------------------#
# Chargement tableau des axes #
#-----------------------------#
If dim([M:BSG2]NBAXE)>0
  If dim([M:BSG0]SOC)>0 & [M:BSG0]SOC<>""
    Call CHARG_DIE(103,[M:BSG0]SOC,"BSG2","NBAXE") From TRTX3CPT
  Else
    Call CHARG_DIE(103,"","BSG2","NBAXE") From TRTX3CPT
  Endif
Endif

#------------------------------------------------------------------#
# chargement des deux zones                                        #
#        montant mini commande et encours autorisé                 #
# ces deux champs sont affichés et saisis en devise site comptable #
# mais elles sont stockées dans BPSCATEG en devise dossier         #
#------------------------------------------------------------------#

Local Decimal WMONTORG (0..2)   # 106430.c - was 0..1
Local Decimal WMONTDES (0..2)
WMONTORG(0) = [F:BSG]ORDMINAMT
WMONTORG(1) = [F:BSG]OSTAUZAMT
WMONTORG(2) = [F:BSG]ORDFREFRT  # 106430.n

Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMONTORG(0),WMONTDES(0),SPSTAT) From TRTDEV
Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMONTORG(1),WMONTDES(1),SPSTAT) From TRTDEV
Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMONTORG(2),WMONTDES(2),SPSTAT) From TRTDEV

If SPSTAT = 0
     #-- on avait un problème suite à la double conversion
     #-- exemple si on saisit un montant de 50 FRF --> conversion EUR
     #-- ensuite reconversion en FRF dans liens pour reaffichage --> 50.03 FRF
     #-- solution aucun arrondi mais uniquement à la fin arrondi
     #-- arrondi de la devise affichage - le stockage est fait avec toute la précision
     If GACTFTC=2
       [M:BSG1]WORDMINAMT = arr(WMONTDES(0),WDECIMAL)
       [M:BSG1]WORDFREFRT = arr(WMONTDES(2),WDECIMAL)  # 106430.n
     Endif
     [M:BSGI]WOSTAUZAMT = arr(WMONTDES(1),WDECIMAL)
Else
     If GACTFTC=2
       [M:BSG1]WORDMINAMT = [F:BSG]ORDMINAMT
       [M:BSG1]WORDFREFRT = [F:BSG]ORDFREFRT  # 106430.n
     Endif
     [M:BSGI]WOSTAUZAMT = [F:BSG]OSTAUZAMT
Endif

#------------------------------------------------------#
# les elements de facturations sont maintenant stockés #
# dans le fournisseur  et on peut supprimer ou inserer #
#------------------------------------------------------#
Local Integer NBPOSTE (2),I
I = 0
J = 0
#----- lecture devise du fournisseur #

If GACTFTC=2
  [M:BSG1]CURWORDMIN=GCUR
  [M:BSG1]CURFREFRT=GCUR   # 106430.n
Endif

Read [TCU]TCU0 = [M:BSGI]CUR
If fstat  : Raz [F:TCU] : Endif
If GACTFTC=2
   Raz [M:BSG1]INVDTAAMT
   Raz [M:BSG1]INVDTA
   Raz [M:BSG1]AMTCOD
   Raz [M:BSG1]WWCUR
   Raz [M:BSG1]FORMAT
   For  J = 0 To dim([F:BSG]INVDTA)-1
      If [F:BSG]INVDTA (J) <> 0
         [M:BSG1]INVDTAAMT (I)  = [F:BSG]INVDTAAMT (J)
         [M:BSG1]INVDTA    (I)  = [F:BSG]INVDTA (J)
         [M:BSG1]AMTCOD    (I)  = [F:BSG]AMTCOD (J)
         Read [PFI]PFI0 = [F:BSG]INVDTA (J)
         If !fstat
           Call LECTEXTRA([M:BSG1]SHO(I),"PFOOTINV","SHOAXX",
&                         num$([F:PFI]PFINUM),"") From ATEXTRA
         Endif
         #---------------------------------------#
         #on veut afficher la devise fournisseur #
         #derriere les montants                  #
         #---------------------------------------#
         If [M:BSG1]AMTCOD(I) = 2
            [M:BSG1]WWCUR(I) = [M:BSGI]CUR
            [M:BSG1]FORMAT (I) = "NZ:"+[F:TCU]CURFMT1
         Else
            [M:BSG1]FORMAT (I) = "NZ:3.2#[      ]"
         Endif
         I +=1
      Endif
   Next J
   NBPOSTE = I
   [M:BSG1]NBELEMENT = NBPOSTE
Endif

Gosub DEFAUT

#---------------------------------------------------#
#Modif CRM 6/02/2002
#If GMODU(13) = 2
#    Call SETPREREP("BSG") From TRTMST4
#Endif
#---------------------------------------------------#

If GS1099 Call SUB_GRIZE_LIENS("BSG2") From TEN99LIB  : Endif #1099.n


Return

####################################################################
$DEFAUT
For MA=0 To NBMASK
 If AMA(MA)
  Gosub SETMASK From="WGO"+GABREV
 Endif
Next MA
Return

###################################################################
$RAZCRE

# Ne pas écraser les zones qui ont pu venir du tiers
If [M:BSGI]CRY = ""
    [M:BSGI]CRY = GPAYS
    If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
    If [F:TCY]CRY <> GPAYS
        Read [TCY]TCY0 = GPAYS
        If fstat Raz [F:TCY] Endif
    Endif
    [M:BSGI]LAN = [F:TCY]LAN
    [M:BSGI]CUR = [F:TCY]CUR
Endif
# A vérifier
If GACTFTC=2
   [M:BSG1]CURWORDMIN = GCUR
   [M:BSG1]CURFREFRT  = GCUR  # 106430.n
   [M:BSG1]ABCCLS     = 4
Endif

#---------------------------------#
# Initialisation tableau des axes #
#---------------------------------#
If dim([M:BSG2]NBAXE)>0
  If dim([M:BSG0]SOC)>0 & [M:BSG0]SOC<>""
    Call INIT_DIE(3,[M:BSG0]SOC,"BSG2","NBAXE") From TRTX3CPT
  Else
    Call INIT_DIE(3,"","BSG2","NBAXE") From TRTX3CPT
  Endif
Endif

#MAE, le 06/01/09, SUP_GACCCOD
#[M:BSG2]ACCCOD = GACCCOD

#-----------------------------------------------------------------------------------#
# IRMUE 14.06.12 81574:AR/AP management
# The amount type PURPRITYP is initialized with parameter PURPRITYP/GPURPRITYP.
# The X3 user can change the amount type always.
#-----------------------------------------------------------------------------------#
If (GMODU(3)=2 or GMODU(6)=2)
 If dim(GPURPRITYP)>0   : [M:BSG2]PURPRITYP = GPURPRITYP : Endif
 If [M:BSG2]PURPRITYP=0 : [M:BSG2]PURPRITYP=1 Endif
Endif
#IRMUE 14.06.12 81574:AP/AR management <End>

Gosub AFFICHE_TOUT

If GS1099 Call SUB_GRIZE_LIENS("BSG2") From TEN99LIB : Endif  #1099.n

Return

###################################################################
$RAZDUP
Local Integer WRET

# A vérifier
If GACTFTC=2
   [M:BSG1]CURWORDMIN = GCUR
   [M:BSG1]CURFREFRT  = GCUR  # 106430.n
Endif

#-----------------------------------------------------------------------------------#
# IRMUE 14.06.12 81574:AP/AR management
# The amount type PURPRITYP is initialized with parameter PURPRITYP/GPURPRITYP.
# The X3 user can change the amount type always.
#-----------------------------------------------------------------------------------#
If (GMODU(3)=2 or GMODU(6)=2)
 If dim(GPURPRITYP)>0   : [M:BSG2]PURPRITYP = GPURPRITYP : Endif
 If [M:BSG2]PURPRITYP=0 : [M:BSG2]PURPRITYP=1 Endif
Endif
#IRMUE 14.06.12 81574:AP/AR management <End>

Gosub AFFICHE_TOUT

If GS1099 Call SUB_GRIZE_LIENS("BSG2") From TEN99LIB : Endif  #1099.n

Return

###################################################################
$VERIFCRE_MOD
#----------------------------------------------------#
# attention au blanc dans la zone numéro fournisseur #
# option C ne fonctionne pas le 30 juillet 98        #
#----------------------------------------------------#
#--- %DL% : à voir
[M:BSG0]BSGCOD= vireblc ([M:BSG0]BSGCOD,2)
If [M:BSG0]BSGCOD = ""
      GERR=1:GMESSAGE=mess(6,199,1):OK = 0
      Return
Endif
Gosub AFFICHE_TOUT
Return

###################################################################
$INICRE
#------------------------------------#
# etiquette appelee avant le write   #
# dans la transaction de creation    #
#------------------------------------#
Gosub CREBSG
If GOK < 1 : Return : Endif
Return

###################################################################
$INIMOD
#------------------------------------#
# etiquette appellee avant le rewrite#
# dans la transaction de modification#
#------------------------------------#
Gosub CREBSG
If GOK<1 Return Endif
Return

############################################################################
$APRES_MOD
#---- %DL% : à voir
#Met à jour l'utilisateur associé au représentant
Call UPDAUSFROMBPR([M:BSG0]BSGCOD) From SUBAUSCRM
If !GIMPORT Gosub RELIT From GOBJSUB : Endif
Return

#######################################################################
############# GOSUB ###################################################
#######################################################################

########################################################################
$CREBSG
#-------------------------------------#
# chargement des elements facturation #
#-------------------------------------#
Raz [F:BSG]INVDTA
Raz [F:BSG]INVDTAAMT
Raz [F:BSG]AMTCOD

If GACTFTC=2
   For I = 0 To dim([F:BSG]INVDTA)-1
      If [M:BSG1]INVDTA (I) <> 0
         [F:BSG]INVDTA (I)    = [M:BSG1]INVDTA (I)
         [F:BSG]INVDTAAMT (I) = [M:BSG1]INVDTAAMT (I)
         [F:BSG]AMTCOD (I)    = [M:BSG1]AMTCOD (I)
      Endif
   Next I
Endif

#--------------------------------------------------------#
# il faut reconvertir les montants en devise dossier     #
#--------------------------------------------------------#
Local Decimal WMONTORG (0..2)  # 106430.c - was 0..1
Local Decimal WMONTDES (0..2)
If GACTFTC=2
   WMONTORG(0) = [M:BSG1]WORDMINAMT
   WMONTORG(2) = [M:BSG1]WORDFREFRT  # 106430.n
Endif
WMONTORG(1) = [M:BSGI]WOSTAUZAMT

#-- on avait un problème suite à la double conversion
#-- exemple si on saisit un montant de 50 FRF --> conversion EUR
#-- ensuite reconversion en FRF dans liens pour reaffichage --> 50.03 FRF
#-- solution aucun arrondi mais uniquement à la fin arrondi pour affichage
#-- le stockage est fait avec toute la précision

Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMONTORG (0),WMONTDES (0),SPSTAT) From TRTDEV
Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMONTORG (1),WMONTDES (1),SPSTAT) From TRTDEV
Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMONTORG (2),WMONTDES (2),SPSTAT) From TRTDEV   #106430.n

If SPSTAT = 0
   If GACTFTC=2
     [F:BSG]ORDMINAMT=WMONTDES(0)
     [F:BSG]ORDFREFRT=WMONTDES(2)  # 106430.n
   Endif
   [F:BSG]OSTAUZAMT=WMONTDES(1)
Else
   If GACTFTC=2
     [F:BSG]ORDMINAMT=[M:BSG1]WORDMINAMT
     [F:BSG]ORDFREFRT=[M:BSG1]WORDFREFRT  # 106430.n
   Endif
   [F:BSG]OSTAUZAMT=[M:BSGI]WOSTAUZAMT
Endif
Call MAJTEXTRA([M:BSG0]DESAXX,"BPSCATEG","DESAXX",[M:BSG0]BSGCOD,"") From ATEXTRA
Call MAJTEXTRA([M:BSGI]SHOAXX,"BPSCATEG","SHOAXX",[M:BSG0]BSGCOD,"") From ATEXTRA

Return

###################################################################
##############    SUBPROG   #######################################
###################################################################

##############################################################################
#CHECK UNUSED_BEGIN
Subprog CALCUL(WNOTE)
Variable Decimal WNOTE
#-----------------------------#
# calcul de la note générale  #
#-----------------------------#

If [M:BSG3]LTIMRKCOE+[M:BSG3]PRIMRKCOE+[M:BSG3]QLYMRKCOE+[M:BSG3]QTYMRKCOE+[M:BSG3]RSKMRKCOE <> 0
   WNOTE = ([M:BSG3]LTIMRK*[M:BSG3]LTIMRKCOE+[M:BSG3]PRIMRK*[M:BSG3]PRIMRKCOE+
&           [M:BSG3]QLYMRK*[M:BSG3]QLYMRKCOE+[M:BSG3]QTYMRK*[M:BSG3]QTYMRKCOE+
&           [M:BSG3]RSKMRK*[M:BSG3]RSKMRKCOE) /
&          ([M:BSG3]LTIMRKCOE+[M:BSG3]PRIMRKCOE+[M:BSG3]QLYMRKCOE+[M:BSG3]QTYMRKCOE+[M:BSG3]RSKMRKCOE)
Else
   WNOTE = 0
Endif
End
#CHECK UNUSED_END

##############################################################################
######################### ACTIONS CHAMPS #####################################
##############################################################################

# --------------------------------------------------------------------------------
#                                        Ecran BSG0
# --------------------------------------------------------------------------------

Subprog AM_BSGCOD(VALEUR)
Variable Char    VALEUR()
Look [BSG] BSG0=VALEUR
If !fstat
    # Si le fournisseur existe, Vérification qu'il est bien autorisé par la gestion des rôles -----#
    # (S'il n'existe pas, il faut autoriser sa création)
    GBIDC2="" : Call FILROLE("BSG",GBIDC2) From SUBARL
    If GBIDC2<>""
        Filter [BSG] Where evalue(GBIDC2)
        Look [BSG] BSG0=VALEUR
        Filter [BSG]
        If fstat  End : Endif
    Endif
Endif
End

# --------------------------------------------------------------------------------
#                                        Ecran BPRBSG
# --------------------------------------------------------------------------------

Subprog C_REFCOU(VALEUR)
Variable Char    VALEUR()
If !clalev([F:ANM]) Local File ACODNUM [ANM] Endif  # avant modif du dico Objet
If VALEUR <> ""
 For I = 0 To dim([F:ANM]POSTYP)-1
   # FQ 58536 Controler que la formule puisse être évaluée
   If instr(1,[F:ANM]POSCTE(I),"[")
       Onerrgo ERR_FORMU
       Local Char FORMU(GLONVCR)
       FORMU   = evalue([F:ANM]POSCTE(I))
       Onerrgo
       If mkstat = 2
         Break
       Endif
   # Controler que la constante est de type format "c"
   Elsif [F:ANM]POSCTE(I) <> ""
&  & format$("K:"+num$([F:ANM]POSLNG(I))+"c",[F:ANM]POSCTE(I)) = string$([F:ANM]POSLNG(I)," ")
     mkstat = 2
     Break
   Endif
 Next I
 If mkstat = 2
    GERR=1
    GMESSAGE = mess(6,196,1)-"("-[F:ANM]POSCTE(I)-")"
    End                          # hcb 58728
 Endif

 # Controle que le compteur n'est pas déjà utilisé dans une catégorie
 Local File BPSCATEG [BSG2] # pour ne pas écraser le buffer
 For [F:BSG2] Where BSGCOD <> [M]BSGCOD & REFCOU = VALEUR
   GMESSAGE = mess(7,196,1)-[F:BSG2]BSGCOD
   GERR = 2 # avertissement seulement
   Break
 Next
Endif
End
$ERR_FORMU
   mkstat = 2
Resume

Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()
#---------------------------------------------------------------#
# Convertion des montants si changement de devise               #
#---------------------------------------------------------------#
If GACTFTC=2
Call INVDTAAMT (VALEUR,[M]CHGTYP,"BSG") From SUBBPR
[M]CUR = VALEUR
Gosub AFFICHE_TOUT
Endif
End


Subprog AM_CRY(VALEUR)
Variable Char    VALEUR()
Local Char SZMESSAGE (250)
Local Integer IBRETOUR, I
IBRETOUR=1

If VALEUR<>""
    Call GETCRYDATA(VALEUR, [M]LAN, [M]CUR, SZMESSAGE, IBRETOUR) From TRTX3FNC
    If IBRETOUR= 1
        Affzo [M]1-99
        If [M:BSG1]NBELEMENT<>0
           For I=0 To [M:BSG1]NBELEMENT-1
              If [M:BSG1]AMTCOD(I)=2 [M:BSG1]WWCUR(I)=[M]CUR Endif
           Next I
           Affzo [M:BSG1]30
        Endif
    Endif
Endif
End


# --------------------------------------------------------------------------------
#                                        Ecran BSG1
# --------------------------------------------------------------------------------


#-----------------------------------------#
# Après modification du mode de livraison #
#-----------------------------------------#
Subprog AM_MDL(VALEUR)
Variable Char    VALEUR()
#----- Chargement et affichage "Incoterm" venant du mode de livraison -----#
[M:BSG1]EECICT=[F:TMD]EECICT : Affzo [BSG1]EECICT
#----- Chargement et affichage "Lieu de transport" (soumis au code activité DEB) -----#
If dim([M:BSG1]EECLOC)>0
  [M:BSG1]EECLOC=[F:TMD]EECLOC : Affzo [BSG1]EECLOC
Endif
#-----
End


Subprog AS_INVDTA (VALEUR)
Variable Decimal VALEUR
If VALEUR<>0 mkstat=2 Endif
End

Subprog C_INVDTA (VALEUR)
Variable Decimal  VALEUR
Local Integer STAT
Local Integer I
I=find(VALEUR,[M:BSG1]INVDTA(0..[M:BSG1]NBELEMENT-1))
If I <> 0 & I <> nolign
  mkstat    = 2
  GMESSAGE  = mess(102,194,1)
Else
  Call LECTEXTRA([M:BSG1]SHO(nolign-1),"PFOOTINV","SHOAXX",
&                num$([F:PFI]PFINUM),"") From ATEXTRA
  #----------------------------#
  # voir la valeur par defaut  #
  #----------------------------#
  [M:BSG1]AMTCOD (nolign -1) = [F:PFI]AMTCOD
  If [F:PFI]AMTCOD = 2
    [M:BSG1]WWCUR(nolign-1) = [M:BSGI]CUR
    [M:BSG1]FORMAT (nolign-1) = "NZ:"+[F:TCU]CURFMT1
    GBIDD1 = 0
    Call CONVERT(GSYSCUR,[M:BSGI]CUR,GCUR,[M:BSGI]CHGTYP,datesyst,[F:PFI]DEFVAL,GBIDD1,STAT) From TRTDEV
    [M:BSG1]INVDTAAMT (nolign-1) = GBIDD1
  Else
    [M:BSG1]FORMAT (nolign-1) = "NZ:3.2#[      ]"
    [M:BSG1]INVDTAAMT (nolign-1) = [F:PFI]DEFVAL
  Endif
  Affzo [M:BSG1]SHO (nolign-1)
  Affzo [M:BSG1]INVDTAAMT (nolign-1)
  Affzo [M:BSG1]WWCUR (nolign-1)
Endif
End

Subprog C_INVDTAAMT(VALEUR)
Variable Decimal  VALEUR
If [M:BSG1]AMTCOD (nolign -1) <> 2
If VALEUR > 100.00
mkstat = 2
Endif
Endif
End

# --------------------------------------------------------------------------------
#                                        Ecran BSG2
# --------------------------------------------------------------------------------

########################################
#------------------------------------------------------------------#
# Ritenzione (KIB) - Controle de validite du code retenue saisi    #
#------------------------------------------------------------------#
Subprog C_RITCOD(VALEUR)
Variable Char    VALEUR()
NOL=nolign-1
If find(VALEUR,[M:BSG2]RITCOD(0..NOL-1)) | find(VALEUR,[M:BSG2]RITCOD(NOL+1..[M:BSG2]RITNBR-1))
   GMESSAGE=mess(22,131,1) # Code retenue déjà spécifié
   mkstat=2
Endif
End

#------------------------------------------------------------------#
# Ritenzione (KIB) - Tri des codes retenues selon type & categorie #
#------------------------------------------------------------------#
Subprog C_RITNBR

## <PP 13/09/04> Demande 24452
#Local Char TABCOD(30)(1..5) # tableau des codes retenues
#Local Integer TABPRIO(1..5) # tableau des priorites
#Local Integer TABSORT(1..5) # tableau des index de retenues tries
Local Char TABCOD(30)(1..dim([F:BSG]RITCOD)) # tableau des codes retenues
Local Integer TABPRIO(1..dim([F:BSG]RITCOD)) # tableau des priorites
Local Integer TABSORT(1..dim([F:BSG]RITCOD)) # tableau des index de retenues tries
## <Fin PP>

Local Integer I,J,AUX       # variables de boucles

If clalev([F:RTZ])=0 : Local File RITENZIONE [RTZ] : Endif

If status>=65 & status<=90 # On reste dans le tableau
Elsif status<>7 & status<1792

   # INIT DES TABLEAUX DE CODES, PRIORITES, INDEX

   For nolign=1 To [M:BSG2]RITNBR
       TABCOD(nolign)=[M:BSG2]RITCOD(nolign-1) # recopie
       Read [F:RTZ]RTZ0=TABCOD(nolign) # lecture fiche retenue
       TABPRIO(nolign)=[F:RTZ]TYP*10+[F:RTZ]CAT
       TABSORT(nolign)=nolign
   Next nolign

   # TRI DU TABLEAU DES INDEX (TABSORT)

   For J=[M:BSG2]RITNBR To 2 Step -1
       For I=1 To J-1
           If TABPRIO(TABSORT(I))>TABPRIO(TABSORT(I+1)) Then # on swap les indexes
              AUX=TABSORT(I)
              TABSORT(I)=TABSORT(I+1)
              TABSORT(I+1)=AUX
           Endif
       Next I
   Next J

   # REORDONNANCEMENT DU TABLEAU DES CODES RETENUES

   For nolign=1 To [M:BSG2]RITNBR
       [M:BSG2]RITCOD(nolign-1)=TABCOD(TABSORT(nolign))
   Next nolign

   Affzo [M:BSG2]1-99 # refresh du masque

Endif
End

#------------------------------------------------------------------#
# Ritenzione (KIB) - Controle de validite du taux d'abattement     #
#------------------------------------------------------------------#
Subprog C_RITRAT(VALEUR)
Variable Decimal VALEUR
If VALEUR<0 | VALEUR>100
   GMESSAGE=mess(17,131,1) # Taux incorrect
   mkstat=2
Endif
End

######################################################################################
#1099.sn
######################################################################################
Subprog AM_FRM1099(VALEUR)
#--------------------------------------------------------------------#
# When we have a Form Value allow entry of Box, and
# For Transactions Disable DAS2 if a 1099 since we can only allow one
#--------------------------------------------------------------------#
Variable Integer VALEUR

Call AM_FRM1099(VALEUR, "BSG2") From TEN99LIB  # with screen
End
#1099.en

