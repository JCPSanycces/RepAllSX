#<AdxTL>@(#)1.0.0.0 $Revision$
###########################################################################################
#   Gestion des conflits de rendez-vous                  Module CRM         17 juillet 2000
###########################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When Default
Endcase
Return


$OUVRE
Return

$DEFBOUT
Return

$SETBOUT
Return

$OUVRE_BOITE
Return

$DEBUT
Local Integer I
Local Integer I2
Local Integer IDX
Local Integer BPCCLOSINGFLG
Local Integer REPCLOSINGFLG
Local Integer CCNCLOSINGFLG
BPCCLOSINGFLG = 0
REPCLOSINGFLG = 0
CCNCLOSINGFLG = 0
I = 0
I2 = 0
IDX = 0

If !clalev([F:BPC])
    Local File BPCUSTOMER [BPC]
    BPCCLOSINGFLG = 1
Endif

If !clalev([F:REP])
    Local File SALESREP [REP]
    REPCLOSINGFLG = 1
Endif

If !clalev([F:AIN])
    Local File CONTACTCRM [AIN]
    CCNCLOSINGFLG = 1
Endif

#Remplit l'en-tête
[M:BAPA]TTRDAT = PARAM(1)
[M:BAPA]TTRHOU = PARAM(3)
[M:BAPA]TTRDATEND = PARAM(4)
[M:BAPA]TTRHOUEND = PARAM(5)
Read [BPC] BPC0 = PARAM(2)
If fstat
    [M:BAPA]TTRBPC = PARAM(2)
Else
    [M:BAPA]TTRBPC = [F:BPC]BPCNAM
Endif

For I = 0 To dim([F:BAP]APTREPNUM) - 1
    If IBUSYREP(I)
        I2 = 0
        For I2 = 0 To 9
            If GSZCONFAPP(I + (10 * I2)) <> ""
                [M:BAPA]REPNUM(IDX) = [M:BAP2]APTREPNUM(I)
                Read [REP] REP0 = [M:BAP2]APTREPNUM(I)
                If fstat
                    [M:BAPA]REP(IDX) = [M:BAP2]APTREPNUM(I)
                Else
                    [M:BAPA]REP(IDX) = [F:REP]REPNAM
                Endif
                Read [BAP] APP0 = GSZCONFAPP(I + (10 * I2))
                If !fstat
                    [M:BAPA]DAT(IDX) = [F:BAP]APTDAT
                    [M:BAPA]HOU(IDX) = [F:BAP]APTHOU
                    [M:BAPA]DATEND(IDX) = [F:BAP]APTDATEND
                    [M:BAPA]HOUEND(IDX) = [F:BAP]APTHOUEND
                    [M:BAPA]BPC(IDX) = [F:BAP]APTCMP
                    [M:BAPA]APPNUM(IDX) = [F:BAP]APTNUM
                    Read [AIN] AIN0 = [F:BAP]APTCCNNUM(0)
                    If !fstat
                        Call BUILDFULNAM("AIN", [M:BAPA]CNT(IDX)) From CRMUTIL140
                    Endif
                Endif
                IDX += 1
            Else
                Break
            Endif
        Next
    Endif
Next

[M:BAPA]NBCONF = IDX

If CCNCLOSINGFLG : Close Local File [AIN] : Endif
If REPCLOSINGFLG : Close Local File [REP] : Endif
If BPCCLOSINGFLG : Close Local File [BPC] : Endif

Affzo [M:BAPA]

Return

$AV_CHOIX
Return

AP_CHOIX
Return

$AVANT_BOUTON
Return

$FINSAI
Return

$FIN
Return

$ABANDON
Return

$APRES_MODIF
Return

$BOUTON
Case BOUT
    When "a"
    When Default
Endcase
Return


#########################################################
# Sous-programmes
#########################################################
#########################################################
