#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque MIGX1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone TMOSELALL
mkstat = 0
zoncou = "TMOSELALL"
indice = 0
IMPENT = [M]TMOSELALL
WNUM = IMPENT
If varinit([M]TMOSELALL,indice)=0
 IMPENT = 1
Endif
If varmode([M]TMOSELALL,indice)=0
 [M]TMOSELALL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TMOSELALL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TMOSELALL(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "TMOSELALL" : GZNUM = 26794 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_TMOSELALL(IMPENT) From SUBMIGX
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "TMOSELALL" : GZNUM = 26794 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]TMOSELALL = IMPENT

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone TMNBR
mkstat = 0
zoncou = "TMNBR"
indice = 0
status = 1
zoncou = "TMNBR"
If varmode([M]TMNBR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TMNBR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]TMNBR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]TMNBR = nolign
   status = 75
   Call SAI_TMNBR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_TMNBR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone TMNBR
mkstat = 0
zoncou = "TMNBR"

## Zone TMINCLUDE
mkstat = 0
zoncou = "TMINCLUDE"
IMPENT = [M]TMINCLUDE(indice)
If varinit([M]TMINCLUDE,indice)=0
 IMPENT = 1
Endif
If varmode([M]TMINCLUDE,indice)=0
 [M]TMINCLUDE(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TMINCLUDE" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TMINCLUDE(indice)
 Endif
Endif
[M]TMINCLUDE(indice) = IMPENT

## Zone TMSRCTBL
mkstat = 0
zoncou = "TMSRCTBL"
If varmode([M]TMSRCTBL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TMSRCTBL" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ATB","!",[M]TMSRCTBL(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "TMSRCTBL" : GZNUM = 12075 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone TMCLSMAP
mkstat = 0
zoncou = "TMCLSMAP"
If varmode([M]TMCLSMAP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TMCLSMAP" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone TMNBR
mkstat = 0
zoncou = "TMNBR"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "MIGX1"
Return

