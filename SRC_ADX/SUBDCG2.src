For [HRCTR]CLE(1) Where REFNUM=[F:DCG]REFNUM & (XITDAT=[0/0/0] | XITDAT>=[F:DCG]STRDAT)
&                   & (CTRDAT<=[F:DCG]ENDDAT | (FLGRET=2 & RETDATEFF<=[F:DCG]ENDDAT)) & find([F:DCG]CTRNUM,"",CTRNUM)<>0
