Subprog S_LVERATDES(VALEUR)
Variable Char    VALEUR()
  Local Integer NBRATETYP
  Local Integer RATETYP
  Local Char LIBRATETYP(130)(0..100)
  Local Char TITLE(250) : TITLE = mess(8,11691,1)

  If !clalev([HRLSTH]) : Local File HRLVESUBHEA [HRLSTH] : Endif

  Filter [F:HRLSTH] Where LEG = GCURLEG & COD = [M:DCG1]WLVESUBTYP(nolign-1)
  Read [HRLSTH] Last

  If rowcount([HRLSTH]) = 0
    GERR = 2 : GMESSAGE = mess(99,100,1) #### MIPEA make better message here
  Endif

  For RT = 0 To dim([F:HRLSTH]LVEPAYDES)-1
    If [F:HRLSTH]LVEPAYDES(RT)="" : Break : Endif
    NBRATETYP+=1
    LIBRATETYP(NBRATETYP) = [F:HRLSTH]LVEPAYDES(RT)
  Next

  NBRATETYP+=1
  LIBRATETYP(NBRATETYP) = "Not applicable"

  Call SAITEX(NBRATETYP,LIBRATETYP,RATETYP,TITLE) From GESECRAN # Choose rate types from leave sub type setup

  If RATETYP > 0
    If RATETYP < NBRATETYP
      [M:DCG1]WLVESUBRAT(nolign-1) = RATETYP
      Assign "[M:DCG1]LVESUBRAT" + num$(nolign-1) + "(" + num$(GPARENT_NOLIGN) + ")" With RATETYP
      Affzo [M:DCG1]WLVESUBRAT(nolign-1)
      [M:DCG1]LVERATDES(nolign-1) = [F:HRLSTH]LVEPAYDES(RATETYP-1)
      VALEUR = [F:HRLSTH]LVEPAYDES(RATETYP-1)
    Else
      [M:DCG1]WLVESUBRAT(nolign-1) = 99
      Assign "[M:DCG1]LVESUBRAT" + num$(nolign-1) + "(" + num$(GPARENT_NOLIGN) + ")" With 99
      Affzo [M:DCG1]WLVESUBRAT(nolign-1)
      [M:DCG1]LVERATDES(nolign-1) = ""
      VALEUR=""
## PEVAN 2017-08-30 X3-54263 END
    Endif
  Endif
  Filter [F:HRLSTH]

End
$AS_STA1
#SAVAN - X3-81285  Hiding Option on Tracking - start
If GCURLEG="BRI" & [M:DCG1]STA0(nolign-1) <> 3
 [V]GMENLOC(1)=1 : [V]GMENLOC(2)=1 :  [V]GMENLOC(4)=1 : [V]GMENLOC(6)=1 :  [V]GMENLOC(7)=1 : # Annulation refusée
 Else
 [V]GMENLOC(1)=1 : [V]GMENLOC(2)=1 :  [V]GMENLOC(4)=1 : [V]GMENLOC(5)=1 :  [V]GMENLOC(6)=0 :  [V]GMENLOC(7)=1 :
Endif
#SAVAN - X3-81285  Hiding Option on Tracking - start
Return
Subprog AM_LVERATDES(VALEUR)
Variable Char    VALEUR()

  Local Integer VALIDCHK

  #PEVAN - 2017-08-28- US X3-39538- START
  #SAVAN  - 2018/03/15 - Move to SUBDCG2 - ESS SOA - start
  If !clalev([HRLSTH]) : Local File HRLVESUBHEA [HRLSTH] : Endif
  VALIDCHK=-1
  Read [HRLSTH]HRLST0 = GCURLEG;[M:DCG1]WLVESUBTYP(nolign-1)
  For X = 0 To dim([F:HRLSTH]LVEPAYDES)-1
    If VALEUR = [F:HRLSTH]LVEPAYDES(X)
      VALIDCHK = X
      Break
    Endif
  Next

  If VALIDCHK >= 0
    [M:DCG1]WLVESUBRAT(nolign-1) = VALIDCHK+1
  Else
    GERR=2
    GMESSAGE= mess(23,11691,1) + " - " + [M:DCG1]WLVESUBTYP(nolign-1)
    mkstat=2
    If [M:DCG1]WLVESUBRAT(nolign-1) <> 0
      Read [HRLSTH]HRLST0 = GCURLEG;[M:DCG1]WLVESUBTYP(nolign-1)
      [M:DCG1]LVERATDES(nolign-1) = [F:HRLSTH]LVEPAYDES([M:DCG1]WLVESUBRAT-1)
      Raz VALEUR
      VALEUR = [M:DCG1]LVERATDES(nolign-1)
    Endif
  Endif
  #SAVAN  - 2018/03/15 - Move to SUBDCG2 - ESS SOA - end
  #PEVAN - 2017-08-28- US X3-39538- END
End
#FRLAA X3-86842 2018-05-14 START
Subprog C_ENDDAT(VALEUR)
Variable Date VALEUR
Local Integer I
Local Date    DAT, DAT2
#62192
Local Date    DAT3
Local Integer TROUVE
Local Date    DATDEBCR

Local Integer WRET
Call C_NBLIG_FIELDCONTROL(WRET) From SUBDCG
If !WRET
  mkstat     =2
  End
Endif

If ![V]GWEBSERV & ([L]VALEUR<[M:DCG1]DATDEB | [L]VALEUR>[M:DCG1]DATFIN)
 [V]GMESSAGE=mess(1,10709,1)
 mkstat     =2
 End
Endif

  Link [HRCTR]
&   With [FCY]FCY0=ETRFCY
&   As [LNK]
&   Where REFNUM=[M:DCG1]REFNUM & find([M:DCG1]CTRNUM(nolign-1),"",CTRNUM)
&       & (CTRDAT<=[L]VALEUR | (FLGRET=2 & RETDATEFF<=[L]VALEUR))
&       & (XITDAT=[0/0/0] | XITDAT>=[M:DCG1]STRDAT(nolign-1))
&       & [FCY]LEG=GCURLEG
&       Order By Key CLE=REFNUM; CTRNUM; CTRDAT Desc

 For [LNK]CLE(2) Where REFNUM=[M:DCG1]REFNUM & find([M:DCG1]CTRNUM(nolign-1),"",CTRNUM)
&                 & (CTRDAT<=[L]VALEUR | (FLGRET=2 & RETDATEFF<=[L]VALEUR))
&                 & (XITDAT=[0/0/0] | XITDAT>=[M:DCG1]STRDAT(nolign-1))
 [L]DAT  = [M:DCG1]STRDAT(nolign-1)
 [L]DAT3 = [M:DCG1]STRDAT(nolign-1) : #62192

 For [LNK]CLE
 #FRLAA X3-86842 2018-05-14 START
  #If ([F:HRCTR]CTRDAT>[L]DAT & ([F:HRCTR]FLGRET<>2 | [F:HRCTR]RETDATEFF>[L]DAT)) & TROUVE=0
  If ([F:HRCTR]CTRDAT>[L]DAT & ([F:HRCTR]FLGRET<>2 | [F:HRCTR]RETDATEFF>[L]DAT)) & TROUVE=0 &  !func AFNC.ACTIV("GLM")
 #FRLAA X3-86842 2018-05-14 END

   [V]GMESSAGE=func AFNC.MES2( mess(171,10709,1),format$([V]GFMD,[L]DAT)
&                            , format$([V]GFMD,[F:HRCTR]CTRDAT-1)
&                            )

   mkstat     =2
   Break 2
  Elsif [F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=[L]VALEUR
   [L]DAT  = [L]VALEUR
   [L]DAT3 = [L]VALEUR  : #62192
  Else
   [L]DAT3 = max([L]DAT,[F:HRCTR]XITDAT) : #62192
   [L]DAT  = max([L]DAT,[F:HRCTR]XITDAT)+1
  Endif

  # FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
  DATDEBCTR=[F:HRCTR]CTRDAT
  If [F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<>[0/0/0] Then
   DATDEBCTR=[F:HRCTR]RETDATEFF
  Endif
  [L]DAT2 = max([M:DCG1]STRDAT(nolign-1),DATDEBCTR)
  Filter [HRPEOD] Where PERSTR(0)  <=[L]VALEUR & PEREND(1)>=[M:DCG1]STRDAT(nolign-1)
&                  & find(PERCOD,"",[F:HRCTR]PERCOD)<>0
&       Order By Key CLE=PYRDAT; PERCOD Desc
  For [HRPEOD]CLE(1)
   If ([F:HRPEOD]STA<>2 & [V]GTPS) | [F:HRPEOD]PERSTR(0)>[L]DAT2
    [V]GMESSAGE=mess(58,10709,1)

    mkstat     =2
    Break 3
   Elsif [F:HRPEOD]PEREND(0)>=[L]VALEUR
    [L]DAT2=[L]VALEUR
    Break
   Else
    [L]DAT2=[F:HRPEOD]PEREND(0)+1
   Endif
   #On autorise la saisie sur période de paie calculée
  Next
  # Fiche 68349 - 25/10/2010 : même message si aucune période d'extraction
  If !mkstat & ([L]DAT2<[L]VALEUR or rowcount([F:HRPEOD]) = 0)

    [V]GMESSAGE=mess(10,11691,1)

   mkstat     =2
   Break 2
  Endif
  #62192
  TROUVE = 1
 Next
Next

Filter [HRPEOD]

If clalev([F:VEP]) : Filter [VEP] : Endif

If mkstat
 End
Elsif [L]DAT3<[L]VALEUR : #62192 : [L]DAT remplacé par [L]DAT3
 If [L]DAT3=[0/0/0] : [L]DAT3=[M:DCG1]STRDAT(nolign-1) : Endif : #62192 : [L]DAT remplacé par [L]DAT3
 #MIPEA - 2016-12-15 - X3-12089- START
 [V]GMESSAGE=func AFNC.MES2( mess(171,10709,1),format$([V]GFMD,[L]DAT3)
&                          , format$([V]GFMD,[L]VALEUR)
&                          )
 mkstat     =2
 End
Endif


#If [M:DCG1]CTRNUM(nolign-1)="" #FRLAA X3-86842 2018-05-15 Comment - We need to read contract on date change

  Link [HRCTR]
&   With [FCY]FCY0=ETRFCY
&   As [LNK]
&   Where REFNUM=[M:DCG1]REFNUM & find([M:DCG1]CTRNUM(nolign-1),"",CTRNUM)
&       & (CTRDAT<=[L]VALEUR | (FLGRET=2 & RETDATEFF<=[L]VALEUR))
&       & (XITDAT=[0/0/0] | XITDAT>=[M:DCG1]STRDAT(nolign-1))
&       & (CTRDAT<=[M:DCG1]STRDAT(nolign-1)) & [FCY]LEG=GCURLEG

  Filter [LNK]
  Read [LNK] First
  If rowcount([LNK])=1
    [M:DCG1]CTRNUM(nolign-1) = [F:HRCTR]CTRNUM
    #FRLAA X3-86842 2018-05-15 START
    [M:DCG1]CTRDAT(nolign-1) = [F:HRCTR]CTRDAT
    #FRLAA X3-86842 2018-05-15 END
  Endif
#Endif #FRLAA X3-86842 2018-05-15 Comment - We need to read contract on date change

If func AFNC.ACTIV("GLM")
  #Check multiple contracts with the same Chrono
  If func SUBDCGGLM.CHECK_MULTIPLE_CTR_CHRONO([M:DCG1]STRDAT(nolign-1),VALEUR,[M:DCG1]REFNUM,[M:DCG1]CTRNUM)>0
    [V]GMESSAGE=mess(39,11691,1)
    mkstat = 2
    End
  Else
    #Check if leave is being captured for an old contract
    Local Char CTRARRAY(GLONHRCTR)(1..)
    Local Date DTRARRAY (1..)
    Local Integer I
    If func SUBDCGGLM.CHECK_XITCTR([M:DCG1]STRDAT(nolign-1),VALEUR,[M:DCG1]REFNUM,[M:DCG1]CTRNUM,CTRARRAY,DTRARRAY)>0
      For I = 1 To maxtab(CTRARRAY)
        If CTRARRAY(I)<>""
          Infbox mess(40,11691,1)-num$(CTRARRAY(I))-num$(DTRARRAY(I))+"."+mess(41,11691,1)
        Endif

      Next


    Endif
  Endif

  #Check if leave is being captured for an old contract

Endif

End
#FRLAA X3-86842 2018-05-14 END

#FRLAA X3-86842 2018-05-14 START
Subprog C_STRDAT(VALEUR)
Variable Date VALEUR
#FRLAA X3-86842 2018-05-14 END

If func AFNC.ACTIV("GLM")
  If func SUBDCGGLM.CHECK_MULTIPLE_CTR_CHRONO(VALEUR,[M:DCG1]ENDDAT(nolign-1),[M:DCG1]REFNUM,[M:DCG1]CTRNUM)>0
    [V]GMESSAGE=mess(39,11691,1)
    mkstat = 2
    End
  Endif
Endif



End
#FRLAA X3-86842 2018-05-14 END

