#&                   & DEBDAT<=[F:DCG]ENDDAT & FINDAT>=[F:DCG]STRDAT
  Local Char     CRITERIA(100)
#MIPEA - 2016-12-19 - X3-12089- START
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
#  If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#MIPEA - 2016-12-19 - X3-12089- END
    CRITERIA = '[F:CNE]EMPLEASTR<=[F:DCG]ENDDAT & [F:CNE]EMPLEAEND>=[F:DCG]STRDAT'
  Else
    CRITERIA = 'DEBDAT<=[F:DCG]ENDDAT & FINDAT>=[F:DCG]STRDAT'
  Endif
#MIPEA - 2016-12-19 - X3-12089- START
    For [LNK]CNG0 Where CPY=func DIVPAYE.GETSOC([F:HRCTR]ETRFCY) & TIM=[F:DCG]TIM
&                   & evalue(CRITERIA)
#  For [LNK]CNG0 Where CPY=func DIVPAYE.GETSOC([F:CTR]ETRFCY) & TIM=[F:DCG]TIM
#&                   & evalue(CRITERIA)
#MIPEA - 2016-12-19 - X3-12089- END
#JASMI - 2014/08/31 - END
   If [F:CNE]REFNUM=""
#MIPEA - 2016-12-15 - X3-12089- START
    [V]GMESSAGE=mess(165,10709,1)-num$([F:CNG]YEA)
#    [V]GMESSAGE=mess(165,709,1)-num$([F:CNG]YEA)
#MIPEA - 2016-12-15 - X3-12089- END
    #           Fiche congé par employé inexistante pour l'année
    [V]GERR    =1
    [L]OK      =0
    Break 2
   Endif
  Next
 Endif

 If find([F:DCG]STA,3,6) : # Demande Acceptée, Annulation acceptée
#MIPEA - 2016-12-19 - X3-12089- START
  For [HRPEOD]CLE(1) Where find(PERCOD,"",[F:HRCTR]PERCOD)<>0 & PEREND(I)>=[F:DCG]STRDAT
&                     & PERSTR(I)<=[F:DCG]ENDDAT
#  For [HRPEO]CLE(1) Where find(FCY,"",[F:HRCTR]ETRFCY)<>0 & PEREND(I)>=[F:DCG]STRDAT
#&                     & PERSTR(I)<=[F:DCG]ENDDAT
#MIPEA - 2016-12-19 - X3-12089- END
   #90728
   #[L]SYMBOLE2="TPS"+format$("D:"+[V]GFMDAT,[F:PEO]PYRDAT)+"\"+[M:DCG1]REFNUM+"\"+[F:CTR]CTRNUM+format$("D:"+[V]GFMDAT,[F:CTR]CTRDAT)
#MIPEA - 2016-12-19 - X3-12089- START
    [L]SYMBOLE2="TPS"+format$("D:"+[V]GFMDAT,[F:HRPEOD]PYRDAT)+"\"+[F:HRCTR]CTRNUM+format$("D:"+[V]GFMDAT,[F:HRCTR]CTRDAT)
#   [L]SYMBOLE2="TPS"+format$("D:"+[V]GFMDAT,[F:PEO]PYRDAT)+"\"+[F:HRCTR]CTRNUM+format$("D:"+[V]GFMDAT,[F:HRCTR]CTRDAT)
#MIPEA - 2016-12-19 - X3-12089- END
   Lock =[L]SYMBOLE2
   If fstat
    Call QUILOCKE([L]SYMBOLE2,2) From DIVPAYE
    If !adxlog : Call DELOCK("TPS") From GLOCK : Endif
    [V]GERR=1
    [L]OK  =0
