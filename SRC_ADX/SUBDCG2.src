  [V]GMESSAGE=mess(13,10715,1)-num$([V]GMOIPAY-val(func AFNC.PARAM("DCGJOUANT",[F:HRCTR]ETRFCY)))
#  [V]GMESSAGE=mess(13,715,1)-num$([V]GMOIPAY-val(func AFNC.PARAM("DCGJOUANT",[F:CTR]ETRFCY)))
