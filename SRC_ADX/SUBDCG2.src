If ![L]OK : Return : Endif
#MIPEA - 2016-12-19 - X3-12089- START
Read [TIM]TIM0=GCURLEG;[F:DCG]TIM
#Read [TIM]TIM0=[F:DCG]TIM
#MIPEA - 2016-12-19 - X3-12089- END
If [F:TIM]MONDAC=2 : I=1 : Else I=0 : Endif : #1=Extraction temps; 2=Mois calendaire
#MIPEA - 2016-12-19 - X3-12089- START
Filter [HRPEOD] Order By Key CLE=PYRDAT;PERCOD Desc
# FQ85820 - 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat
For [F:HRCTR]CTR0 Where REFNUM=[F:DCG]REFNUM & find([F:DCG]CTRNUM,"",CTRNUM)
&                  & (CTRDAT<=[F:DCG]ENDDAT | (FLGRET=2 & RETDATEFF<=[F:DCG]ENDDAT)) & (XITDAT=[0/0/0] | XITDAT>=[F:DCG]STRDAT)
#Filter [PEO] Order By Key CLE=PYRDAT;FCY Desc
## FQ85820 - 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat
#For [CTR]CTR0 Where REFNUM=[F:DCG]REFNUM & find([F:DCG]CTRNUM,"",CTRNUM)
#&                  & (CTRDAT<=[F:DCG]ENDDAT | (FLGRET=2 & RETDATEFF<=[F:DCG]ENDDAT)) & (XITDAT=[0/0/0] | XITDAT>=[F:DCG]STRDAT)
#MIPEA - 2016-12-19 - X3-12089- END
 If [F:TIM]CATTIM=3 & [F:TIM]FLGBLC=2 & find([F:DCG]STA,2,3) : # Demande, Accepté
#MIPEA - 2016-12-19 - X3-12089- START
  Link [CNG] With [CNE]CNE0=YEA;[DCG]REFNUM;[F:HRCTR]CTRNUM;TIM As [LNK]
#  Link [CNG] With [CNE]CNE0=YEA;[DCG]REFNUM;[F:CTR]CTRNUM;TIM As [LNK]
