     GMOIPAY = gdat$(func DIVPAYE.INIPARUSR("MOIPAY","",""))
  Endif
## PEVAN - 2017-09-26 - X3-57236 - END
   If [F:DCG]STRDAT<GMOIPAY-val(func AFNC.PARAM("DCGJOUANT",[F:HRCTR]ETRFCY))
# If [F:DCG]STRDAT<[V]GMOIPAY-val(func AFNC.PARAM("DCGJOUANT",[F:CTR]ETRFCY))
 #MIPEA - 2016-12-19 - X3-12089- END
  # La saisie ne peut s'effectuer à une date antérieure au
