#    If [F:CTR3]ETRFCY<>"" Then [F:TIP]FCY=[F:CTR3]ETRFCY : Endif
#    If [F:CTR3]ETRSRV<>"" Then [F:TIP]SRV=[F:CTR3]ETRSRV : Endif
#  Endif
#MIPEA - 2016-12-19 - X3-12089- END
 Endif
 Write [TIG]
 If fstat
  [V]GOK=0
  Call FSTA("TIG") From GLOCK
  Return
 Endif

Endif

# 26/11/12 - Test sur PDEB sinon erreur d'appel de ADD_CPPRIS
If [F:TIM]CATTIM=3 & [L]PDEB>0 & I>0
 If ITER<>0 : Raz [F:TIP] : [F:TIP] = [F:TIG] : Endif
 Call ADD_CPPRIS([L]JOUR([L]PDEB..I)) From TPSSTD1
 If [V]GOK<1 : Return : Endif
Endif

If [V]GTPS
#MIPEA - 2016-12-15 - X3-12089- START
 Case [F:DCG]WRK
  When "C" : [L]WRK=mess(75,10709,1) : # Ajout
  When "M" : [L]WRK=mess(77,10709,1) : # Modif (après)
 Endcase
# Case [F:DCG]WRK
#  When "C" : [L]WRK=mess(75,709,1) : # Ajout
#  When "M" : [L]WRK=mess(77,709,1) : # Modif (après)
# Endcase
