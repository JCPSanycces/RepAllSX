#<AdxTL>@(#)0.0.0.0 $Revision$
#MIPEA SOURCE REMERGE
######################################################################################

$REFRESHLVESUBNNR
##SAVAN 2017-08-15
  Local Integer LP,M,DR
  If nolign>[M]UID : End : Endif
  If !clalev([F:HRLSTH]) : Local File HRLVESUBHEA [HRLSTH] : Endif
  If !clalev([F:DCG]) : Local File DEMCONGE [DCG] : Endif

##PEVAN 2017-11-08 X3-62395 START
  [M:DCG1]LVESUBNNR = 0
  Raz [M:DCG1]WLVESUBTYP
  Raz [M:DCG1]WLVESUBBAL
  Raz [M:DCG1]WNBRHOU
  Raz [M:DCG1]WLVESUBRAT
  Raz [M:DCG1]LVERATDES
  Affzo [M:DCG1]45
##PEVAN 2017-11-08 X3-62395 END

  If nolign>=1 & [M]CTRNUM(nolign-1)<>""
    Local Integer PRAT, LINENUM
    Global Integer GLOBAL_UID : GLOBAL_UID = [M]UID(GPARENT_NOLIGN)
    Read [DCG]DCG2=[M]UID(GPARENT_NOLIGN)
    LINENUM=0

## PEVAN 2017-09-06 X3-54579 START
    If [M]UID(GPARENT_NOLIGN) <> 0
      [M:DCG1]LVERATDES(M) = ""
      Actzo [M:DCG1]LVERATDES(M)
## PEVAN 2017-09-06 X3-54579 END
      For LP=1 To dim([DCG]LVESUBTYP)
        Filter [HRLSTH] Where COD=[F:DCG]LVESUBTYP(LP-1)
        Read [HRLSTH] First
        If [DCG]LVESUBTYP(LP-1) <> ""
          Call LECTEXTRA([M:DCG1]DES(LINENUM),"HRLVESUBHEA","DES",GCURLEG,[DCG]LVESUBTYP(LP-1)) From ATEXTRA
          [M:DCG1]WLVESUBTYP(LINENUM) = [F:DCG]LVESUBTYP(LP-1)
          [M:DCG1]WLVESUBBAL(LINENUM)  = [F:DCG]LVESUBBAL(LP-1)
          If [F:DCG]NBRDAY > 0
            [M:DCG1]WNBRHOU(LINENUM)  = ([F:DCG]LVESUBBAL(LP-1)/[F:DCG]NBRDAY)*[F:DCG]NBRHOU
          Endif
          If [F:DCG]LVESUBBAL(LP-1) > 0
            PRAT = 0
            PRAT = evalue("[M:DCG1]LVESUBRAT" + num$(LP-1) + "(" + num$(GPARENT_NOLIGN) + ")")
#            PRAT = evalue("[M:DCG1]LVESUBRAT" + num$(GPARENT_NOLIGN) + "(" + num$(LP-1) + ")")
            If PRAT = 0 #The values was not loaded onto the screen fields, get them from the database
              Filter [DCG] Where UID = GLOBAL_UID
              Read [DCG] First
              If fstat = 0
                PRAT = evalue("[F:DCG]LVESUBRAT(" + num$(LP-1) + ")")
                Assign "[M:DCG1]LVESUBRAT" + num$(LP-1) + "(" + num$(GPARENT_NOLIGN) + ")" With PRAT
              Endif
              Filter [DCG]
            Endif
            [M:DCG1]WLVESUBRAT(LINENUM) = PRAT
            If PRAT > 0 & PRAT <> 99
              [M:DCG1]LVERATDES(LINENUM) = [F:HRLSTH]LVEPAYDES(PRAT-1)
              Actzo [M:DCG1]LVERATDES(M)
            Endif
          Else
## PEVAN 2017-08-30 X3-54262 START
            Diszo [M:DCG1]WLVESUBRAT(M)
            Grizo [M:DCG1]LVERATDES(M)
            Raz [M:DCG1]LVERATDES(M)
## PEVAN 2017-08-30 X3-54262 END
          Endif
          M=M+1
          LINENUM += 1
        Endif
        Filter [HRLSTH]
      Next
      [M:DCG1]LVESUBNNR = M
## PEVAN 2017-09-06 X3-54579 START
    Else
      [M:DCG1]LVESUBNNR = 0
      Raz [M:DCG1]WLVESUBTYP
      Raz [M:DCG1]WLVESUBBAL
      Raz [M:DCG1]WNBRHOU
      Raz [M:DCG1]WLVESUBRAT
      Raz [M:DCG1]LVERATDES
    Endif
## PEVAN 2017-09-06 X3-54579 END
  Endif
##PEVAN 2017-08-21 X3-52945 start
##Affzo [M:DCG1]
  Affzo [M:DCG1]45
##PEVAN 2017-08-21 X3-52945 end

Return

Subprog SET_LVESUBRAT(PARENT_INDEX)
Value Integer PARENT_INDEX
  Local Integer PRAT
  For PRAT = 0 To 14
  ##PEVAN 2017-09-14 X3-55894 START
    Case PRAT
      When 0  : [F:DCG]LVESUBRAT(PRAT) = evalue("[M:DCG1]LVESUBRAT" + num$(PRAT) + "(" + num$(PARENT_INDEX) + ")")
      When 1  : [F:DCG]LVESUBRAT(PRAT) = evalue("[M:DCG1]LVESUBRAT" + num$(PRAT) + "(" + num$(PARENT_INDEX) + ")")
      When 2  : [F:DCG]LVESUBRAT(PRAT) = evalue("[M:DCG1]LVESUBRAT" + num$(PRAT) + "(" + num$(PARENT_INDEX) + ")")
      When 3  : [F:DCG]LVESUBRAT(PRAT) = evalue("[M:DCG1]LVESUBRAT" + num$(PRAT) + "(" + num$(PARENT_INDEX) + ")")
      When 4  : [F:DCG]LVESUBRAT(PRAT) = evalue("[M:DCG1]LVESUBRAT" + num$(PRAT) + "(" + num$(PARENT_INDEX) + ")")
      When 5  : [F:DCG]LVESUBRAT(PRAT) = evalue("[M:DCG1]LVESUBRAT" + num$(PRAT) + "(" + num$(PARENT_INDEX) + ")")
      When 6  : [F:DCG]LVESUBRAT(PRAT) = evalue("[M:DCG1]LVESUBRAT" + num$(PRAT) + "(" + num$(PARENT_INDEX) + ")")
      When 7  : [F:DCG]LVESUBRAT(PRAT) = evalue("[M:DCG1]LVESUBRAT" + num$(PRAT) + "(" + num$(PARENT_INDEX) + ")")
      When 8  : [F:DCG]LVESUBRAT(PRAT) = evalue("[M:DCG1]LVESUBRAT" + num$(PRAT) + "(" + num$(PARENT_INDEX) + ")")
      When 9  : [F:DCG]LVESUBRAT(PRAT) = evalue("[M:DCG1]LVESUBRAT" + num$(PRAT) + "(" + num$(PARENT_INDEX) + ")")
      When 10 : [F:DCG]LVESUBRAT(PRAT) = evalue("[M:DCG1]LVESUBRAT" + num$(PRAT) + "(" + num$(PARENT_INDEX) + ")")
      When 11 : [F:DCG]LVESUBRAT(PRAT) = evalue("[M:DCG1]LVESUBRAT" + num$(PRAT) + "(" + num$(PARENT_INDEX) + ")")
      When 12 : [F:DCG]LVESUBRAT(PRAT) = evalue("[M:DCG1]LVESUBRAT" + num$(PRAT) + "(" + num$(PARENT_INDEX) + ")")
      When 13 : [F:DCG]LVESUBRAT(PRAT) = evalue("[M:DCG1]LVESUBRAT" + num$(PRAT) + "(" + num$(PARENT_INDEX) + ")")
      When 14 : [F:DCG]LVESUBRAT(PRAT) = evalue("[M:DCG1]LVESUBRAT" + num$(PRAT) + "(" + num$(PARENT_INDEX) + ")")
    Endcase
  ##PEVAN 2017-09-14 X3-55894 END
  Next

End

#PEVAN - 2018-04-04 - X3-81467 - START
Subprog UPDATE_LVESUBRAT(PARENT_INDEX,DCGUID)
Value Integer PARENT_INDEX,DCGUID
  Update [F:DCG] Where [F:DCG]UID=DCGUID With
& [F:DCG]LVESUBRAT(0)  = evalue("[M:DCG1]LVESUBRAT0(" + num$(PARENT_INDEX) + ")"),
& [F:DCG]LVESUBRAT(1)  = evalue("[M:DCG1]LVESUBRAT1(" + num$(PARENT_INDEX) + ")"),
& [F:DCG]LVESUBRAT(2)  = evalue("[M:DCG1]LVESUBRAT2(" + num$(PARENT_INDEX) + ")"),
& [F:DCG]LVESUBRAT(3)  = evalue("[M:DCG1]LVESUBRAT3(" + num$(PARENT_INDEX) + ")"),
& [F:DCG]LVESUBRAT(4)  = evalue("[M:DCG1]LVESUBRAT4(" + num$(PARENT_INDEX) + ")"),
& [F:DCG]LVESUBRAT(5)  = evalue("[M:DCG1]LVESUBRAT5(" + num$(PARENT_INDEX) + ")"),
& [F:DCG]LVESUBRAT(6)  = evalue("[M:DCG1]LVESUBRAT6(" + num$(PARENT_INDEX) + ")"),
& [F:DCG]LVESUBRAT(7)  = evalue("[M:DCG1]LVESUBRAT7(" + num$(PARENT_INDEX) + ")"),
& [F:DCG]LVESUBRAT(8)  = evalue("[M:DCG1]LVESUBRAT8(" + num$(PARENT_INDEX) + ")"),
& [F:DCG]LVESUBRAT(9)  = evalue("[M:DCG1]LVESUBRAT9(" + num$(PARENT_INDEX) + ")"),
& [F:DCG]LVESUBRAT(10) = evalue("[M:DCG1]LVESUBRAT10(" + num$(PARENT_INDEX) + ")"),
& [F:DCG]LVESUBRAT(11) = evalue("[M:DCG1]LVESUBRAT11(" + num$(PARENT_INDEX) + ")"),
& [F:DCG]LVESUBRAT(12) = evalue("[M:DCG1]LVESUBRAT12(" + num$(PARENT_INDEX) + ")"),
& [F:DCG]LVESUBRAT(13) = evalue("[M:DCG1]LVESUBRAT13(" + num$(PARENT_INDEX) + ")"),
& [F:DCG]LVESUBRAT(14) = evalue("[M:DCG1]LVESUBRAT14(" + num$(PARENT_INDEX) + ")")
End
#PEVAN - 2018-04-04 - X3-81467 - END

######################################################################################
#LIPET - 2017-08-25 - X3-53555 - START
Subprog COMPARE_DAYS(STRDAY, ENDDAY, CTR, BEFORENON, AFTERNON, DOK)
  Variable Date STRDAY
  Variable Date ENDDAY
  Variable Char CTR
  Variable Integer BEFORENON
  Variable Integer AFTERNON
  Variable Integer DOK
  Local Date SDAT : If STRDAY<>[0/0/0]:SDAT = STRDAY-1:Endif
  Local Date EDAT : If ENDDAY<>[0/0/0]:EDAT = ENDDAY+1:Endif
  Local Char STDAT(30)
  Local Char EDDAT(30)
  Local Integer YY : YY = year(date$)
  Local Integer X
  Local Integer FAILED

  If clalev([F:HLY1])=0  : Local File HLYDAY    [HLY1]  : Endif
  If clalev([F:HRCTR1])=0  : Local File EMPLOCTR [HRCTR1]  : Endif
  If clalev([F:PLN1])=0  : Local File PLANTYP [PLN1]  : Endif
  If clalev([F:WTY1])=0  : Local File TYPWEEK [WTY1]  : Endif

  Filter [HRCTR1] Where CTRNUM = CTR and PLNTYP <> ""
  Read [HRCTR1] Last
  Filter [HRCTR1]
  If !fstat Then
    Filter [PLN1] Where COD = [HRCTR1]PLNTYP and LEG = GCURLEG and WEKTYP(0) <> ""
    Read [PLN1] First
    Filter [PLN1]
    If !fstat Then
      Filter [WTY1] Where COD = [PLN1]WEKTYP(0) and LEG = GCURLEG
      Read [WTY1] First
      Filter [WTY1]
      If !fstat Then
## PEVAN 2017-09-12 X3-55566 START
#        If STRDAY <> [0/0/0] Then
#          #Before non-business
#          If [WTY1]TYPDAY(dayn(SDAT)-1) = 3 Then
#            GERR=1
#            [V]GMESSAGE = mess(10,123,1)
#            DOK =1
#            GOK=0 :End
#          Endif
#         Elsif ENDDAY <> [0/0/0] Then
#          #After non-business
#          If [WTY1]TYPDAY(dayn(EDAT)-1) = 3 Then
#            GERR=1
#            [V]GMESSAGE = mess(10,123,1)
#            DOK =1
#            GOK=0 :End
#          Endif
#        Endif
        If (AFTERNON = 2)
          Local Integer STRDAYINT, ENDDAYINT
          If dayn(STRDAY)-1 < 0
            STRDAYINT = 6
          Else
            STRDAYINT = dayn(STRDAY)-1
          Endif
          If dayn(ENDDAY)-1 < 0
            ENDDAYINT = 6
          Else
            ENDDAYINT = dayn(ENDDAY)-1
          Endif
          If ([WTY1]TYPDAY(STRDAYINT) = 3 or [WTY1]TYPDAY(ENDDAYINT) = 3)
            FAILED = 1
          Elsif (ENDDAY - STRDAY > 2)
            Local Date COUNTERDATE: COUNTERDATE = STRDAY:
            Local Integer COUNTERDATEINT
            While COUNTERDATE < ENDDAY and FAILED = 0
              If dayn(COUNTERDATE)-1 < 0
                COUNTERDAYINT = 6
              Else
                COUNTERDAYINT = dayn(COUNTERDATE)-1
              Endif
              If ([WTY1]TYPDAY(COUNTERDAYINT) = 3)
                FAILED = 1
              Endif
              COUNTERDATE += 1
            Wend
          Endif
        Endif
        If (FAILED = 1)
          GERR = 1
          [V]GMESSAGE = mess(10,123,1)
          DOK = 1
          GOK = 0 :End
        Endif
        If (BEFORENON = 2)
          Local Integer STRDAYINT, ENDDAYINT
          If dayn(STRDAY)+1 > 6
            STRDAYINT = 0
          Else
            STRDAYINT = dayn(STRDAY)+1
          Endif
          If dayn(ENDDAY)+1 > 6
            ENDDAYINT = 0
          Else
            ENDDAYINT = dayn(ENDDAY)+1
          Endif
          If ([WTY1]TYPDAY(STRDAYINT) = 3 or [WTY1]TYPDAY(ENDDAYINT) = 3)
            FAILED = 1
          Elsif (ENDDAY - STRDAY > 2)
            Local Date COUNTERDATE: COUNTERDATE = STRDAY:
            Local Integer COUNTERDATEINT
            While COUNTERDATE < ENDDAY and FAILED = 0
              If dayn(COUNTERDATE)+1 > 6
                COUNTERDAYINT = 0
              Else
                COUNTERDAYINT = dayn(COUNTERDATE)+1
              Endif
              If ([WTY1]TYPDAY(COUNTERDAYINT) = 3)
                FAILED = 1
              Endif
              COUNTERDATE += 1
            Wend
          Endif
        Endif
        If (FAILED = 1)
          GERR = 1
          [V]GMESSAGE = mess(10,123,1)
          DOK = 1
          GOK = 0 :End
        Endif
## PEVAN 2017-09-12 X3-55566 END
      Endif
    Endif
  Endif

  #Checks for public holidays
  Filter [HLY1] Where YEA = YY and LEG = GCURLEG
  Read [HLY1] First
  Filter [HLY1]
  If !fstat
    For X=1 To dim([HLY1]HLYDAY)
      If [HLY1]HLYDAY(X-1) <> [0/0/0] Then
        If ([HLY1]HLYDAY(X-1) = STRDAY and [HLY1]HLYDAY(X-1) = ENDDAY) ## Nothing should happen as this is a public holiday that was selected
        Elsif (BEFORENON = 2 and ([HLY1]HLYDAY(X-1) - 1 = STRDAY or [HLY1]HLYDAY(X-1) - 1 = ENDDAY or ([HLY1]HLYDAY(X-1) >= STRDAY and [HLY1]HLYDAY(X-1) <= ENDDAY))) or
&          (AFTERNON = 2 and ([HLY1]HLYDAY(X-1) + 1 = STRDAY or [HLY1]HLYDAY(X-1) + 1 = ENDDAY or ([HLY1]HLYDAY(X-1) >= STRDAY and [HLY1]HLYDAY(X-1) <= ENDDAY)))
          GERR = 1
          [V]GMESSAGE = mess(10,123,1)
          DOK = 1
          GOK = 0 :End
        Endif
      Endif
    Next
  Endif
End
#LIPET - 2017-08-25 - X3-53555 - END
##################################################################################
#LIPET - 2017-08-30 - X3-54261 - START
Subprog GET_LASTUPDATES(CTRN)
  Variable  Char CTRN()

  If !clalev([F:VALEMP]) : Local File VALEMP [VALEMP] : Endif
  If !clalev([F:ACCRU]) : Local File HRLVEACCRU [ACCRU] : Endif

    Filter [VALEMP] Where [VALEMP]CTRNUM = CTRN Order By [VALEMP]PYRDAT
    Read [VALEMP] Last
    Filter [VALEMP]
    If fstat = 0
        [M:DCG1]DATPYR = [VALEMP]ENDDAT
        Affzo [M:DCG1]DATPYR
      Else
        Effzo [M:DCG1]DATPYR #No payslip
    Endif

    Filter [ACCRU] Where [ACCRU]CTR = CTRN and [ACCRU]LVEACCAMT <> "0" Order By [F:ACCRU]LVEACCDAT
    Read [ACCRU] Last
    Filter [ACCRU]
    If fstat = 0
      [M:DCG1]DATLVE = [F:ACCRU]LVEACCDAT
      Affzo [M:DCG1]DATLVE
    Endif
End
#LIPET - 2017-08-30 - X3-54261 - END
##################################################################################
#LIPET - 2017-09-05 - X3-54629 - START
Subprog CONTLVERSN(RSNCOD,TIM,NM)
  Variable Char RSNCOD()
  Variable Char TIM
  Variable Integer NM : NM=0

    If RSNCOD <> "" Then
      If clalev([F:HRLSE])=0 : Local File HRLVEREA  [HRLSE] : Endif
      Filter [HRLSE] Where COD=RSNCOD and LEG = GCURLEG
      Read [HRLSE]
      If !fstat and [HRLSE]TIMCOD <> TIM Then
        GERR=1
        GMESSAGE = mess(25,11691,1)-TIM
        NM=1
      Endif
    Endif
End
#LIPET - 2017-09-05 - X3-54629 - END
##################################################################################
#LIPET - 2017-09-06 - START
Subprog MULTICTR_DAT_UPT(RNUM)
Variable Char RNUM()
If clalev([F:HRCTR])=0  : Local File EMPLOCTR [HRCTR]  : Endif

  Filter [HRCTR] Where REFNUM = RNUM & [F:HRCTR]XITDAT = [0/0/0]
  If rowcount([HRCTR]) = 1 Then
    Call GET_LASTUPDATES([HRCTR]CTRNUM)
  Endif
  Filter [HRCTR]

End
#LIPET - 2017-09-06 - END
##################################################################################
####MIPEA - 2017-09-11- US X3-54010- START
$WRT_TIP

If ITER=0

 [F:TIP]DCGUID=[F:DCG]UID
 [F:TIP]LIG   =uniqid([TIP])

#MIPEA - 2017-09-08- US X3-54010- START
If func AFNC.ACTIV("GLM")
  If PREVUID<>[F:DCG]UID
    Local Integer X
    Local Decimal RUNTOT : RUNTOT=[F:TIP]NBRDAY
    ###Local Decimal STBALANCES(0..14)

    For X = 0 To dim([F:DCG]LVESUBTYP)-1
      If [F:DCG]LVESUBTYP(X)="" : Break : Endif
        If RUNTOT <= [F:DCG]LVESUBBAL(X) & [F:DCG]LVESUBBAL(X)>0
          [F:TIP]LVESUBBAL(X) = RUNTOT
          ###STBALANCES(X)+=RUNTOT
          RUNTOT=0
          #JOJAC - START
          [F:DCG]LVESUBBAL(X) -= [F:TIP]LVESUBBAL(X)
          #JOJAC - END


        Elsif RUNTOT > [F:DCG]LVESUBBAL(X) & [F:DCG]LVESUBBAL(X)>0
          [F:TIP]LVESUBBAL(X) = RUNTOT-(RUNTOT-[F:DCG]LVESUBBAL(X))
          ###STBALANCES(X)+=  RUNTOT-(RUNTOT-[F:DCG]LVESUBBAL(X))
          RUNTOT=RUNTOT-[F:DCG]LVESUBBAL(X)

          #JOJAC - START
          [F:DCG]LVESUBBAL(X) -= [F:TIP]LVESUBBAL(X)
          #JOJAC - END

        Else
          [F:TIP]LVESUBBAL(X) = 0
          ###STBALANCES(X)=0
        Endif
        [F:TIP]LVESUBTYP(X) = [F:DCG]LVESUBTYP(X)
        [F:TIP]LVESUBRAT(X) = [F:DCG]LVESUBRAT(X)
    Next X
  Else
    Local Integer X
    Local Decimal RUNTOT : RUNTOT=[F:TIP]NBRDAY

    For X = 0 To dim([F:DCG]LVESUBTYP)-1
      If [F:DCG]LVESUBTYP(X)="" : Break : Endif
        If (RUNTOT <= [F:DCG]LVESUBBAL(X)) & ([F:DCG]LVESUBBAL(X)>0) ###& (STBALANCES(X)<[F:DCG]LVESUBBAL(X))
          [F:TIP]LVESUBBAL(X) = RUNTOT
          #If GUSER = 'JOJAC' : Infbox '364'-num$([F:TIP]LVESUBBAL(X))-num$([DCG]STRDAT) : Endif
          ###STBALANCES(X)+=RUNTOT
          RUNTOT=0
          #JOJAC - START
          [F:DCG]LVESUBBAL(X) -= [F:TIP]LVESUBBAL(X)
          #JOJAC - END
        Elsif (RUNTOT > [F:DCG]LVESUBBAL(X)) & ([F:DCG]LVESUBBAL(X)>0)### & (STBALANCES(X)<[F:DCG]LVESUBBAL(X))


          [F:TIP]LVESUBBAL(X) = RUNTOT-(RUNTOT-[F:DCG]LVESUBBAL(X))
          ###STBALANCES(X)+=  RUNTOT-(RUNTOT-[F:DCG]LVESUBBAL(X))
          RUNTOT=RUNTOT-[F:DCG]LVESUBBAL(X)
          #JOJAC - START
          [F:DCG]LVESUBBAL(X) -= [F:TIP]LVESUBBAL(X)
          #JOJAC - END
        Else
          [F:TIP]LVESUBBAL(X) = 0
          ###STBALANCES(X)=0
        Endif
        [F:TIP]LVESUBTYP(X) = [F:DCG]LVESUBTYP(X)
        [F:TIP]LVESUBRAT(X) = [F:DCG]LVESUBRAT(X)
    Next X
  Endif

  PREVUID =[F:DCG]UID
Endif
#MIPEA - 2017-09-08- US X3-54010- END

 # FQ82073 - 18/12/12 - Initialisation de TIP.CTRDAT selon règle métier
 If [F:TIP]CTRDAT=[0/0/0] & [F:TIP]ENDDAT<>[0/0/0] Then
  [F:TIP]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIP]REFNUM,[F:TIP]CTRNUM,[F:TIP]ENDDAT,[F:TIP]DATPYR,[F:TIP]ENDDAT,1)
  # FQ81491 - 13/12/13 - Récup site et service du contrat trouvé
#MIPEA - 2016-12-19 - X3-12089- START
  If clalev([F:HRCTR3])=0  : Local File EMPLOCTR [HRCTR3]  : Endif
  Read [F:HRCTR3]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
  If !fstat Then
    If [F:HRCTR3]ETRFCY<>"" Then [F:TIP]FCY=[F:HRCTR3]ETRFCY : Endif
    If [F:HRCTR3]ETRSRV<>"" Then [F:TIP]SRV=[F:HRCTR3]ETRSRV : Endif
  Endif
#  If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
#  Read [F:CTR3]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
#  If !fstat Then
#    If [F:CTR3]ETRFCY<>"" Then [F:TIP]FCY=[F:CTR3]ETRFCY : Endif
#    If [F:CTR3]ETRSRV<>"" Then [F:TIP]SRV=[F:CTR3]ETRSRV : Endif
#  Endif
#MIPEA - 2016-12-19 - X3-12089- END
 Endif
 # Entry point for update specific field [F:TIP]
 GPOINT = "MAJTIPSPE" : Gosub ENTREE From EXEFNC
 If GOK<1 : Return : Endif
 Write [TIP]
 If fstat
  [V]GOK=0
  Call FSTA("TIP") From GLOCK
  Return
 Endif
Else

 [F:TIG]DCGUID=[F:DCG]UID
 [F:TIG]LIG   =uniqid([TIP])

####MIPEA - 2017-09-11- US X3-54010- START
If func AFNC.ACTIV("GLM")

  If PREVUIDTIG<>[F:DCG]UID
    Local Integer X
    Local Decimal RUNTOT : RUNTOT=[F:TIG]NBRDAY
    ###Local Decimal STBALANCESTIG(0..14)

    For X = 0 To dim([F:DCG]LVESUBTYP)-1
      If [F:DCG]LVESUBTYP(X)="" : Break : Endif
        If RUNTOT <= [F:DCG]LVESUBBAL(X) & [F:DCG]LVESUBBAL(X)>0
          [F:TIG]LVESUBBAL(X) = RUNTOT
          ###STBALANCESTIG(X)+=RUNTOT
          RUNTOT=0
          #JOJAC - START
          [F:DCG]LVESUBBAL(X) -= [F:TIG]LVESUBBAL(X)
          #JOJAC - END


        Elsif RUNTOT > [F:DCG]LVESUBBAL(X) & [F:DCG]LVESUBBAL(X)>0
          [F:TIG]LVESUBBAL(X) = RUNTOT-(RUNTOT-[F:DCG]LVESUBBAL(X))
          ###STBALANCESTIG(X)+=  RUNTOT-(RUNTOT-[F:DCG]LVESUBBAL(X))
          RUNTOT=RUNTOT-[F:DCG]LVESUBBAL(X)
          #JOJAC - START
          [F:DCG]LVESUBBAL(X) -= [F:TIG]LVESUBBAL(X)
          #JOJAC - END


        Else
          [F:TIG]LVESUBBAL(X) = 0
          ###STBALANCESTIG(X)=0
        Endif
        [F:TIG]LVESUBTYP(X) = [F:DCG]LVESUBTYP(X)
        [F:TIG]LVESUBRAT(X) = [F:DCG]LVESUBRAT(X)
    Next X
  Else
    Local Integer X
    Local Decimal RUNTOT : RUNTOT=[F:TIG]NBRDAY

    For X = 0 To dim([F:DCG]LVESUBTYP)-1
      If [F:DCG]LVESUBTYP(X)="" : Break : Endif
        If (RUNTOT <= [F:DCG]LVESUBBAL(X)) & ([F:DCG]LVESUBBAL(X)>0)## & (STBALANCESTIG(X)<[F:DCG]LVESUBBAL(X))
          [F:TIG]LVESUBBAL(X) = RUNTOT
          ##STBALANCESTIG(X)+=RUNTOT
          RUNTOT=0
          #JOJAC - START
          [F:DCG]LVESUBBAL(X) -= [F:TIG]LVESUBBAL(X)
          #JOJAC - END
        Elsif (RUNTOT > [F:DCG]LVESUBBAL(X)) & ([F:DCG]LVESUBBAL(X)>0)## & (STBALANCESTIG(X)<[F:DCG]LVESUBBAL(X))


          [F:TIG]LVESUBBAL(X) = RUNTOT-(RUNTOT-[F:DCG]LVESUBBAL(X))
          ##STBALANCESTIG(X)+=  RUNTOT-(RUNTOT-[F:DCG]LVESUBBAL(X))
          RUNTOT=RUNTOT-[F:DCG]LVESUBBAL(X)
          #JOJAC - START
          [F:DCG]LVESUBBAL(X) -= [F:TIG]LVESUBBAL(X)
          #JOJAC - END


        Else
          [F:TIG]LVESUBBAL(X) = 0
          ##STBALANCESTIG(X)=0
        Endif
        [F:TIG]LVESUBTYP(X) = [F:DCG]LVESUBTYP(X)
        [F:TIG]LVESUBRAT(X) = [F:DCG]LVESUBRAT(X)
    Next X
  Endif
  PREVUIDTIG =[F:DCG]UID
Endif
####MIPEA - 2017-09-11- US X3-54010- END

 # FQ105844 - 24/02/15 - Le FLGBUL ne sert plus, le champ DATPYR est suffisant
# [F:TIG]FLGBUL = 2
 # FQ82073 - 18/12/12 - Initialisation de TIP.CTRDAT selon règle métier
 If [F:TIG]CTRDAT=[0/0/0] & [F:TIG]ENDDAT<>[0/0/0] Then
  [F:TIG]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIG]REFNUM,[F:TIG]CTRNUM,[F:TIG]ENDDAT,[F:TIG]DATPYR,[F:TIG]ENDDAT,1)
  # FQ81491 - 13/12/13 - Récup site et service du contrat trouvé
#MIPEA - 2016-12-19 - X3-12089- START
  If clalev([F:HRCTR3])=0  : Local File EMPLOCTR [HRCTR3]  : Endif
  Read [F:HRCTR3]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
  If !fstat Then
    If [F:HRCTR3]ETRFCY<>"" Then [F:TIP]FCY=[F:HRCTR3]ETRFCY : Endif
    If [F:HRCTR3]ETRSRV<>"" Then [F:TIP]SRV=[F:HRCTR3]ETRSRV : Endif
  Endif
#  If clalev([F:CTR3])=0  : Local File EMPLOCTR [CTR3]  : Endif
#  Read [F:CTR3]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
