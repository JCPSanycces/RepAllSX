Subprog CHECK_SUB_RATE_CHANGED(PARENT_INDEX, SUBRATECHANGED)
Value Integer PARENT_INDEX
Variable Integer SUBRATECHANGED
  Local Integer PRAT
  For PRAT = 0 To 14
    If [F:DCG]LVESUBRAT(PRAT) <> evalue("[M:DCG1]LVESUBRAT" + num$(PRAT) + "(" + num$(PARENT_INDEX) + ")")
      SUBRATECHANGED = 1
      Break
    Endif
  Next
End
##PEVAN 2017-09-14 X3-55894 END
#MIPEA - 2017-10-20- START
$DROIT
Local Char CRITERE3(250)
If GWEBSERV
# Pour les webservices [M:DCG1] non valorisé
# CRITERE3 = '(XITDAT=[0/0/0] | XITDAT>=['+num$([M:DCG1]DATFIN)+']) & CTRDAT<=['+num$([M:DCG1]DATFIN)+']'
 # FQ85820 - 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat
# CRITERE3 = '(XITDAT=[0/0/0] | XITDAT>=date$) & CTRDAT<=date$'
 CRITERE3 = '(XITDAT=[0/0/0] | XITDAT>=date$) & (CTRDAT<=date$ | (FLGRET=2 & RETDATEFF<=date$))'
 Else
 CRITERE3 = "1=1"
Endif

# FQ85108 - 11/12/10 - Vérifier que [F:ID]REFNUM est bien renseigné, car appelé aussi sur la ligne pour vérification du suppléant
# 19/12/12 86713 - 86831 error message "128 trop de constante"
# FQ73176 - 12/04/11 - Si on navigue et que le matricule trouvé ne correspond pas aux critères, on relance la recherche
# FQ76705 - 04/10/11 - test sur !GWEBSERV sinon, REPONSE n'existe pas !!
# 19/12/12 86713 - 86831 error message "128 trop de constante" quand on utilise find(ETRSRV,[V]GAUTSRV(1..[V]GNBSERV))<>0
If [F:ID]REFNUM<>"" Then
  If !clalev([F:ACC]) : Local File ACCES [ACC] : Endif
  If GUSRACS<>2
    CRITERE3 -= '& ([F:SRV]CODACC="" or [F:ACC]EXEC=2)'
  Endif
#MIPEA - 2016-12-19 - X3-12089- START
  Link [HRCTR] With
&                [SRV]SRV0=ETRSRV
&              , [ACC]CODACC=GUSER;[F:SRV]CODACC
&             As [LNK]
&          Where REFNUM=[F:ID]REFNUM & evalue(CRITERE3)
&             & ([V]GUSRFCY="/" |  find([HRCTR]ETRFCY,[V]GUSRFCY))
#  Link [CTR] With
#&                [SRV]SRV0=ETRSRV
#&              , [ACC]CODACC=GUSER;[F:SRV]CODACC
#&             As [LNK]
#&          Where REFNUM=[F:ID]REFNUM & evalue(CRITERE3)
#&             & ([V]GUSRFCY="/" |  find([CTR]ETRFCY,[V]GUSRFCY))
#MIPEA - 2016-12-19 - X3-12089- END
  If !rowcount([LNK]) & !GWEBSERV
    # FQ85108 - 11/12/10 - Ajout du test sur dim(REPONSE)>0
    If dim(REPONSE)>0 & find(REPONSE, GSTAFIR,GSTAPRE,GSTASUI,GSTALAS)>0 Then
      CLECUR1=[F:ID]REFNUM
      Case REPONSE
        When GSTAFIR : Gosub PREMIER   From GOBJSUB
        When GSTAPRE : Gosub PRECEDENT From GOBJSUB
        When GSTASUI : Gosub SUIVANT   From GOBJSUB
        When GSTALAS : Gosub DERNIER   From GOBJSUB
      Endcase
    Else
#MIPEA - 2016-12-19 - X3-12089- START
      CLECUR=0  : Filter [HRCTR] : Return
#      CLECUR=0  : Filter [CTR] : Return
#MIPEA - 2016-12-19 - X3-12089- end
    Endif
  Endif
#MIPEA - 2016-12-19 - X3-12089- START
  Filter [HRCTR]
#  Filter [CTR]
#MIPEA - 2016-12-19 - X3-12089- end
Endif
Return
#MIPEA - 2017-10-20- END
