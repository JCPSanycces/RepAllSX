#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog INIT(REPERT_BASE,REPERT_ORI,REPERT_DES,FICHIER_CONFIG)
Variable Char REPERT_BASE(),REPERT_ORI(),REPERT_DES(),FICHIER_CONFIG()
Local Char SLASH(1)

  Global Char TRS_CO(100)(1..20),CODE_LANG(3)

  SLASH="/" : # car on est ici sous UNIX

# A modifier lors de l'implûˋmentation dûˋfinitive
  If REPERT_BASE="" : REPERT_BASE="/home/mbz" : Endif
  CODE_LANG='FRA'

# Dûˋtermination des rûˋpertoires de base, de destination, et du fichier
# de configuration
  If left$(REPERT_ORI,1)<>SLASH
    REPERT_ORI=REPERT_BASE+SLASH+REPERT_ORI
  Endif
  If left$(REPERT_DES,1)<>SLASH
    REPERT_DES=REPERT_BASE+SLASH+REPERT_DES
  Endif
  If FICHIER_CONFIG="" : FICHIER_CONFIG="html.cfg" : Endif
  If left$(FICHIER_CONFIG,1)<>SLASH
    FICHIER_CONFIG=REPERT_BASE+SLASH+FICHIER_CONFIG
  Endif

  Call LIT_FICHIER_CONFIG(FICHIER_CONFIG)
End

# Lecture du fichier de config optionnel
Subprog LIT_FICHIER_CONFIG(FICHIER)
Value Char FICHIER()
Local Char CHAINE(255)
Local Integer L
Onerrgo EROUV

# Valeurs par dûˋfaut au cas oû¿...
TRS_CO(1)='<H1 ALIGN="CENTER"><FONT FACE="Comic Sans MS" SIZE="7" COLOR="#FF0000">'
TRS_CO(2)='<H2><FONT FACE="Comic Sans MS" SIZE="6" COLOR="#0000FF">'
TRS_CO(3)='<H3><FONT FACE="Comic Sans MS" SIZE="5" COLOR="#0000FF">'
TRS_CO(4)='<H4><FONT FACE="Comic Sans MS" SIZE="4" COLOR="#0000FF">'
TRS_CO(5)='<H5><FONT FACE="Comic Sans MS" SIZE="3" COLOR="#0000FF">'
TRS_CO(6)="Lucida Console"
TRS_CO(7)='<UL><FONT FACE="Comic Sans MS" SIZE="4" COLOR="#00FF00">'
TRS_CO(8)='<LI>'
TRS_CO(9)='</FONT></UL>'
TRS_CO(10)="Arial Black"
TRS_CO(11)="Arial Narrow"
TRS_CO(12)="../hlp/"
TRS_CO(13)='<FONT FACE="Comic Sans MS" SIZE="3">'
Openi FICHIER,0

# Fichiers aux normes UNIX svp !
adxifs=chr$(10):adxirs=chr$(0)

fstat=0
While fstat=0
  Rdseq CHAINE : CHAINE=vireblc(CHAINE,0)
  If left$(CHAINE,1)="<"
    L=instr(1,CHAINE,">")
    If L
      Case seg$(CHAINE,2,L-1)
        When "H1","H2","H3","H4","H5"
        TRS_CO(val(mid$(CHAINE,3,1)))=CHAINE
      When "BUTTON"
        TRS_CO(6)=vireblc(right$(CHAINE,L+1),0)
      When "STARTMENU"
        TRS_CO(7)=vireblc(right$(CHAINE,L+1),0)
      When "ENDMENU"
        TRS_CO(9)=vireblc(right$(CHAINE,L+1),0)
      When "LINEMENU"
        TRS_CO(8)=vireblc(right$(CHAINE,L+1),0)
      When "IMAGE"
        TRS_CO(10)=vireblc(right$(CHAINE,L+1),0)
      When "LIEN"
        TRS_CO(11)=vireblc(right$(CHAINE,L+1),0)
      When "DIRHLPCHP"
        TRS_CO(12)=vireblc(right$(CHAINE,L+1),0)
      When "FONTHLP"
        TRS_CO(13)=vireblc(right$(CHAINE,L+1),0)
      When Default
        # Rien pour le moment...
      Endcase
    Endif
  Endif
Wend
Openi
$EROUV
End
