#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour table intitulé traduisibles sur dictionnaire des traitements
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update translated field ADICTRT file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
#Gosub DESADC
End

#-------------------#
$DESADC

Local Integer I , VALMOD(20)

If DOSSIER<>GDOSX3
 For I=0 To dim(VALMOD)-1
  VALMOD(I) = 2
 Next I
Else
 VALMOD(0) = 2
 For I=1 To dim(VALMOD)-1
  VALMOD(I) = 1
 Next I
Endif

If filinfo(filpath("FIL","ADICTRT","fde",DOSSIER),0)<=0 : Return : Endif

Local File =DOSSIER+".ADICTRT"   [ADC]
Local File =DOSSIER+".ATEXTRA"   [AXX]

If dim([F:ADC]DES)<0
 Close Local File [ADC],[AXX]
 Return
Endif

# Mise à jour de la table ADICTRT
Call ECR_TRACE(mess(81,125,1)-"ADICTRT:"-time$,0) From GESECRAN
Trbegin [ADC]
 For [ADC]ADC0
  If [F:ADC]DES<>""
   Call MAJTEXTRA([F:ADC]DES,"ADICTRT","INTIT",[F:ADC]CODTRT,"") From ATEXTRA
   #[F:ADC]DES = ""
   Rewrite [ADC]
   If fstat
    Call ERREUR("ADICTRT"-[F:ADC]CODTRT,2) From DOSDIC
   Endif
  Endif
 Next
Commit

Close Local File [ADC],[AXX]

# Onglet Sélection

Call MAJ_SEL(DOSSIER,"ADC") From PATCHAOB

# Validation de l'objet ADC

#Call VALID_TRT(DOSSIER,0,"","","","","","","","","ADC","ADC","","","","","","",VALMOD) From VALDICO
Call VALID_TRT(DOSSIER,0,"","","","","","","","","ADC","ADC","","","","","","","","","","",VALMOD) From VALDICO
Call VALFEN(DOSSIER,"ADC") From SUBAOB

Return
