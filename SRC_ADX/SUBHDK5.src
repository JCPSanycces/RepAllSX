#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion du masque HDK5
########################################
Subprog AS_NBQUE
If nolign > 0
    GSZSELQUE = [M:HDK5]QUENUM(nolign - 1)
Endif
End

########################################
Subprog C_NBQUE
If nolign > 0
    GSZSELQUE = [M:HDK5]QUENUM(nolign - 1)
Endif
End

##########################################################################
Subprog IB_NBQUE

Local Integer ISOPEN
ISOPEN = 0

Raz GBOUT1
Raz GBOUT2

#Détail
Call TEXTE(5562, GBOUT1) From OBJDIV

Call ISFUNOPEN("GESSRE", ISOPEN) From CRMUTIL140
If !ISOPEN
    #Demandes de service
    Call TEXTE(14508, GBOUT2) From OBJDIV
Endif

End



