#<AdxTL>@(#)0.0.0.0 $Revision$
# Mask Management INVNUMSPA
$ACTION
Case ACTION
  When "OUVRE"    : Gosub OUVRE_ARRE
  When "AV_CHOIX" : Gosub AV_CHOIX
  When "OK"       : Gosub OK_ARRE
  When "END"      : Gosub END_ARRE
Endcase
Return

$OUVRE_ARRE

If clalev([M:ISP])=0 : Local Mask INVNUMSPA [ISP]: Endif
If clalev([F:ISP])=0 : Local File INVNUMSPA [ISP]: Endif

Raz [M:ISP]

If dim ([M:VSP2]INVUPDFLG)>0
  If [M:VSP2]INVUPDFLG(NL)=2
    Read [ISP]ISP0=[M:VSP2]NUM(NL)
    If !fstat
      [M:ISP]INVNUMDAT=[F:ISP]INVNUMDAT
      [M:ISP]INVNUM   =[F:ISP]INVNUM
      [M:VSP2]INVNUMDAT(NL)=[M:ISP]INVNUMDAT
      [M:VSP2]INVNUM(NL)   =[M:ISP]INVNUM
      Affzo [M:VSP2]INVNUMDAT(NL)
      Affzo [M:VSP2]INVNUM(NL)
    Elsif [M:VSP2]INVNUM(NL)<>""
      [M:ISP]INVNUMDAT=[M:VSP2]INVNUMDAT(NL)
      [M:ISP]INVNUM   =[M:VSP2]INVNUM(NL)
       Affzo [M:ISP]
    Endif
  Elsif [M:VSP2]INVUPDFLG(NL)=1
    [M:ISP]INVNUMDAT=[M:VSP2]INVNUMDAT(NL)
    [M:ISP]INVNUM   =[M:VSP2]INVNUM(NL)
  Endif
Endif

Return


$AV_CHOIX
  Affzo [M:ISP]
Return

$OK_ARRE
  [M:VSP2]INVNUMDAT(NL)=[M:ISP]INVNUMDAT
  [M:VSP2]INVNUM(NL)   =[M:ISP]INVNUM

   Affzo [M:VSP2]INVNUMDAT(NL)
   Affzo [M:VSP2]INVNUM(NL)

Return

$END_ARRE
NL=-1
Return


######################################################################################
## Section automatically added (screen INVNUMSPA) 06/05/2015 09:34:42 (JUCON)
######################################################################################
Subprog C_INVNUMDAT(VALEUR)
Variable Date    VALEUR
Local Integer NOL

  NOL = nolign-1
  If  VALEUR>[M:VSP2]ACCDAT(NOL)
      GMESSAGE=mess(395,107,1)  #The date must be earlier than or equal to the credit memo accounting date
      mkstat=2
      [M:ISP]INVNUMDAT=VALEUR
    Endif
    If VALEUR=[0/0/0] and [M:ISP]INVNUM<>""
      GMESSAGE=mess(384,107,1)  #'Value is mandatory. Source date or source document already exist in the screen
      mkstat=2
    Endif
End

Subprog C_INVNUM(VALEUR)
Variable Char    VALEUR()
Local Integer NOL

  NOL = nolign-1
  If VALEUR="" and [M:ISP]INVNUMDAT<>[0/0/0]
    GMESSAGE=mess(384,107,1)  #Value is mandatory. Source date or source document already exist in the screen
    mkstat=2
  Endif
  If VALEUR<>"" and [M:ISP]INVNUMDAT=[0/0/0]
    GMESSAGE=mess(384,107,1)  #Value is mandatory. Source date or source document already exist in the screen
    mkstat=2
  Endif
End


######################################################################################

