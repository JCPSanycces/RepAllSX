 VALEUR = GPAYS
Endif
Gosub _AFF
End

Subprog AS_JNTCRY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(53316,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_JNTCRY(zc) From W4CTR4
Onkey   2 Titled GBOUTS Call S_JNTCRY(zc) From W4CTR4
Onkey 144 Titled GBOUTP Call P_JNTCRY(zc) From W4CTR4
Onkey 146 Titled GBOUTA Call SA_JNTCRY(zc) From W4CTR4
Gosub _AFF
End

Subprog C_JNTCRY(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("TCY","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "JNTCRY" : GZNUM = 235 : Endif
Gosub _AFF
End

$AMM_JNTCRY
Call AM_JNTCRY(zc)
If !mkstat & GOBJET
 zoncou = "JNTCRY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_JNTCRY(VALEUR)
Variable Char    VALEUR()
## Action INIPAYS
Call INIPAYS(VALEUR,[M]JNTCRYNAM) From TRTDIV
If mkstat : GERR = 1 : GZONE = "JNTCRY" : GZNUM = 235 : Endif
Gosub _AFF
End

Subprog S_JNTCRY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TCY"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_JNTCRY(VALEUR)
Variable Char    VALEUR()
Call OBJET("TCY",VALEUR,"") From GOBJET
