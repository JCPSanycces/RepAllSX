#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR4 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_MIDPOSCOF
Onevent INIT_AREA Call D_MIDPOSCOF(zc) From W4CTR4
Onevent BEFORE_INPUT Call AS_MIDPOSCOF(zc) From W4CTR4
Return

Subprog D_MIDPOSCOF(VALEUR)
Variable Integer VALEUR
If varinit([M]MIDPOSCOF,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_MIDPOSCOF(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

