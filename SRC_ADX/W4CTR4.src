$ON_NOLIBM
Return

$ON_SITFAMA
Onevent BEFORE_INPUT Call AS_SITFAMA(zc) From W4CTR4
Onevent CONTROL Call C_SITFAMA(zc) From W4CTR4
Onevent AFTER_CHANGE Gosub AMM_SITFAMA From W4CTR4
Return

Subprog IB_SITFAMA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTBOUT
 Call BOUTSEL(VALEUR,"M",[M]NOLIBM,"") From FMTVAR
Endif
Gosub _AFF
End

Subprog AS_SITFAMA(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(877,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_SITFAMA(VALEUR)
## Action AFMTSAI
Call ASAISIE(VALEUR,"M") From FMTVAR
If mkstat=2
 [M]SITFAMA(INDIC) = VALEUR
 Affzo SITFAMA(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_SITFAMA(zc) From W4CTR4
Onkey   2 Titled GBOUTS Call S_SITFAMA(zc) From W4CTR4
Gosub _AFF
End

Subprog C_SITFAMA(VALEUR)
Variable Char    VALEUR()
## Action AFMTCONT
Call CONTROLE(VALEUR,"M",[M]NOLIBM,15,[M]VALINTM) From FMTVAR
If mkstat : GERR = 1 : GZONE = "SITFAMA" : GZNUM = 46034 : Endif
If !mkstat
 ## Action ACONTACL
 Call CONTACL([M]VALINTM,"M","","") From SUBACL
 If mkstat : GERR = 1 : GZONE = "SITFAMA" : GZNUM = 46034 : Endif
 If !mkstat
  ## Action STD
  Call C_SITFAMA(VALEUR) From SUBCTR
  If mkstat : GERR = 1 : GZONE = "SITFAMA" : GZNUM = 46034 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_SITFAMA
Call AM_SITFAMA(zc)
If !mkstat & GOBJET
 zoncou = "SITFAMA" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_SITFAMA(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_SITFAMA(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "SITFAMA" : GZNUM = 46034 : Endif
Gosub _AFF
End

Subprog S_SITFAMA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTSEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTSEL"
 PARMSK(1) = "M"
 PARMSK(2) = num$([M]NOLIBM)
 PARMSK(3) = "15"
 PARMSK(4) = [M]VALINTM
 PARMSK(5) = [M]VALPARM
 PARMSK(6) = ""
 PARMSK(7) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]VALINTM = PARMSK(4)
 GACTION = SAVACT
Endif
If !GWEBSERV
 ## Action AFMTLIB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTLIB"
 PARMSK(1) = "M"
 PARMSK(2) = num$([M]NOLIBM)
 PARMSK(3) = "15"
 PARMSK(4) = [M]VALINTM
 PARMSK(5) = [M]VALPARM
 PARMSK(6) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]VALINTM = PARMSK(4)
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_SITFAMA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTB1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTB1"
 PARMSK(1) = "M"
 PARMSK(2) = [M]VALPARM
 PARMSK(3) = num$([M]NOLIBM)
 PARMSK(4) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"AFMTB1","FMTVAR","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_MRGDAT
Onevent BEFORE_INPUT Call AS_MRGDAT(zc) From W4CTR4
Return

Subprog AS_MRGDAT(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_MRGDAT(VALEUR) From SUBCTR
If mkstat=2
 [M]MRGDAT(INDIC) = VALEUR
 Affzo MRGDAT(INDIC) : mkstat = 2
Endif
If !mkstat
 ## Action SUBCTRLEG
 Call BEFORE_ENTRY(VALEUR) From SUBCTRLEG
 If mkstat=2
  [M]MRGDAT(INDIC) = VALEUR
  Affzo MRGDAT(INDIC) : mkstat = 2
 Endif
Endif
Gosub _AFF
End

$ON_JNTREFNUM
Onevent CONTROL Call C_JNTREFNUM(zc) From W4CTR4
Onevent BEFORE_INPUT Call AS_JNTREFNUM(zc) From W4CTR4
Return

Subprog AS_JNTREFNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_JNTREFNUM(zc) From W4CTR4
Gosub _AFF
End

Subprog C_JNTREFNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_JNTREFNUM(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "JNTREFNUM" : GZNUM = 46454 : Endif
Gosub _AFF
End

Subprog S_JNTREFNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELEMLLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMLLEG"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AS_JNTREFNUM" : PROGSUB = "SUBCTR" : PROGSPE = "SPECTR4" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = func TOOLSHRLEG.LEGWRK
 PARMSK(2) = ""
 PARMSK(3) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"SELEMLLEG","TOOLSHRLEG","") From GACTION
 ACTION = "BS_JNTREFNUM" : PROGSUB = "SUBCTR" : PROGSPE = "SPECTR4" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
Gosub _AFF
End

