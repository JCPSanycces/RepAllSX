End

$ON_FAX
Onevent BEFORE_AREA Gosub AV_FAX From W4CTR4
Onevent CONTROL Call C_FAX(zc) From W4CTR4
Onevent AFTER_CHANGE Gosub AMM_FAX From W4CTR4
Return

$AV_FAX
## Action FMTTELPAY
Call FMTTELPAY([M:CTR4]CRYCNT) From TRTDIV
If GFMT<>""
 Chgfmt [M]FAX(indice) With "K:"+GFMT
Else
 Chgfmt [M]FAX(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog C_FAX(VALEUR)
Variable Char    VALEUR()
## Action ACNTTEL
Call CONTTEL(VALEUR,[M:CTR4]CRYCNT) From CONTNUM
If mkstat : GERR = 1 : GZONE = "FAX" : GZNUM = 919 : Endif
Gosub _AFF
End

$AMM_FAX
Call AM_FAX(zc)
If !mkstat & GOBJET
 zoncou = "FAX" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_FAX(VALEUR)
Variable Char    VALEUR()
## Action ACNTTELMOD
Call CONTTELMOD(VALEUR,[M:CTR4]CRYCNT) From CONTNUM
If mkstat : GERR = 1 : GZONE = "FAX" : GZNUM = 919 : Endif
Gosub _AFF
End

$TIT_COL
Gosub TIT_COL From W5CTR4
Return


