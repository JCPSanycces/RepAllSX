#<AdxTL>@(#)7.0.0.0 $Revision$
$ACTION
Case ACTION
  When "AVANT_OUVRE"  : Gosub AVANT_OUVRE
  When "OUVRE"        : Gosub OUVRE
  When "LIENS"        : Gosub LIENS
  When "FERME"        : Gosub FERME
  When "SETBOUT"      : Gosub SETBOUT
  When "EXEBOUT"      : Gosub EXEBOUT
  When "APRES_CHOI"   : Gosub APRES_CHOI
  When "RAZCRE"       : Gosub RAZCRE
  When "RAZDUP"       : Gosub RAZCRE        # FQ 64266 GA 04/2010
  When "VERIF_CRE"    : Gosub VERIF_CRE
  When "VERIF_MOD"    : Gosub VERIF_MOD
  When "ABANDON"      : Gosub ABANDON
  When "VERF_ANU"     : Gosub VERF_ANU
  When "ANNULE"       : Gosub ANNULE
  When "INICRE"       : Gosub INIMOD        # FQ 60020 GA 11/2009
  When "INIMOD"       : Gosub INIMOD        # FQ 60020 GA 11/2009
  When "AP_ANNULE"    : Gosub AP_ANNULE
  When "AV_IMPRIME"   : Gosub COP_ECRAN
                        OK = 0
  When "AP_CHANGE"    : GCFG_GENTRT=1
  When "FIN_ACTION"   : Gosub FIN_ACTION     # JPJ E21797
  When "CHANGE" : Call CHANGE_AXX ("CFGSHA", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
  When Default
Endcase
Return
###########################################################
$AVANT_OUVRE
Local Integer W_I
Call ACT_CFGUSR(GFONCTION,W_I) From CFGLIBD
If W_I <> 0
  OK = 0
Endif
Return
############################################################
$OUVRE
Global Integer GCFG_GENTRT # Flag de gestion de génération automatique
#
If clalev([F:CSH1]) = 0 : Local File CFGSHA [CSH1] : Endif
If clalev([F:CBB1]) = 0 : Local File CBLOB  [CBB1] : Endif
Gosub CFG_CONSTANTES From CFGLIB
Gosub CFG_SYMBOLES   From CFGLIB
Local Char    W_FOR(250)
Local Char    W_TXT(40)(3)
Local Integer W_I, W_J
Return
############################################################
$LIENS
[M:CSH1]PAR010 = [M:CSH1]SHACAT+[M:CSH1]SHANUM

Raz [F:CBB]
Read [CBB]CBB0="CSH";[M:CSH1]SHACAT;[M:CSH1]SHANUM
If !fstat
    [M:CSH1]CSHPIC = [F:CBB]BLOB
Endif
Gosub CFG_CONSTANTES From CFGLIB
Gosub CFG_SYMBOLES   From CFGLIB
Call CFGSETFOR(7,"","*",[M:CSH1]FILTAB,[M:CSH1]TEXCON,[M:CSH1]VARSUP) From CFGLIB
# FQ 60020 GA 11/2009 lecture des textes
# FQ 63171 GA 03/2010 pb s/texte associé à la Forme
#Call LECTEXTRA([M:CSH1]SHACATAXX,"CFGSHA","SHACATAXX",[F:CSH]SHACAT,[F:CSH]SHANUM) From ATEXTRA
Call LECTEXTRA([M:CSH1]SHACATAXX,"CFGSHA","SHACATAXX",[F:CSH]SHACAT,"") From ATEXTRA
Call LECTEXTRA([M:CSH1]SHANUMAXX,"CFGSHA","SHANUMAXX",[F:CSH]SHACAT,[F:CSH]SHANUM) From ATEXTRA
Return
############################################################
$APRES_CHOI
Case REPONSE
  When GSTARET :
    Case GREP
      When "C", "D" : REPONSE = GSTACRE
      When "M"      : REPONSE = GSTAENR
    Endcase
Endcase
Case REPONSE
  When GSTAENR
    Trbegin [CSH]
    GOK = 1
    Call GEN_LABELS([M:CSH1]SYMNUM000,[M:CSH1]SYMNBR000)
    If len([M:CSH1]CSHPIC) = 0         # 140: conditionnement image  (130: SHAPCT = "")
      [M:CSH1]PAR001 = nomap
      [M:CSH1]PAR002 = "CFGMOD"
      [M:CSH1]PAR003 = [M:CSH1]SHACAT+[M:CSH1]SHANUM
      [M:CSH1]PAR004 = "MWUF12"
      [M:CSH1]PAR010 = ""
    Else
      [M:CSH1]PAR001 = nomap
      [M:CSH1]PAR002 = "CFGSHA"
      [M:CSH1]PAR003 = [M:CSH1]SHACAT+[M:CSH1]SHANUM
      [M:CSH1]PAR004 = "MWUF20"
      [M:CSH1]PAR010 = ""
    Endif
  When GSTACRE :
    If [M:CSH1]SYMNBR > 0
      Trbegin [CSH]
      GOK = 1
      Call GEN_LABELS([M:CSH1]SYMNUM000,[M:CSH1]SYMNBR000)
      If len([M:CSH1]CSHPIC) = 0          # 140: conditionnement image  (130: SHAPCT = "")
        [M:CSH1]PAR001 = nomap
        [M:CSH1]PAR002 = "CFGMOD"
        [M:CSH1]PAR003 = [M:CSH1]SHACAT+[M:CSH1]SHANUM
        [M:CSH1]PAR004 = "CWUF12"
      Else
        [M:CSH1]PAR001 = nomap
        [M:CSH1]PAR002 = "CFGSHA"
        [M:CSH1]PAR003 = [M:CSH1]SHACAT+[M:CSH1]SHANUM
        [M:CSH1]PAR004 = "CWUF20"
      Endif
    Endif
  When 1802 :
    Call GEN_LABELS([M:CSH1]SYMNUM000,[M:CSH1]SYMNBR000)
    If len([M:CSH1]CSHPIC) = 0          # 140: conditionnement image  (130: SHAPCT = "")
      [M:CSH1]PAR001 = nomap
      [M:CSH1]PAR002 = "CFGMOD"
      [M:CSH1]PAR003 = [M:CSH1]SHACAT+[M:CSH1]SHANUM
      [M:CSH1]PAR004 = "VWUF12"
      [M:CSH1]PAR010 = ""
    Else
      [M:CSH1]PAR001 = nomap
      [M:CSH1]PAR002 = "CFGSHA"
      [M:CSH1]PAR003 = [M:CSH1]SHACAT+[M:CSH1]SHANUM
      [M:CSH1]PAR004 = "VWUF20"
      [M:CSH1]PAR010 = ""
    Endif
    Trbegin [CSH]
    GOK = 1
Endcase
Return
###########################################################
$EXEBOUT
Local Char WDMY
Case REP
  When "a"
    adxmbm = adxmbm
    Gosub SUP_GLOBALES   From WUVAR
    Gosub CFG_CONSTANTES From CFGLIB
    Gosub CFG_SYMBOLES   From CFGLIB
    Call CFGSETFOR(7,"","*",[M:CSH1]FILTAB,[M:CSH1]TEXCON,[M:CSH1]VARSUP) From CFGLIB
  When "b" :
    If GOK = 1 & [M:CSH1]RETCOD = 0
        # Issue 105050 by GA 08/2015
        # Generation liens pour cas d'emplois - FQ 63125 GA 03/2010
        #Call CFGWUS(9,[M:CSH1]SHACAT,0) From CFGLIBE
#       If GOK = 1
          Commit
#       Else
#         Rollback
#         OK = 0
#       Endif
    Else  # Issue 86113 GH 06/04/2018 : crash when exit the function
          # because transaction was not closed in this case
      Rollback
      OK = 0
    Endif
  When "c" :
    Call VISUM("WUF"+CLECUR2+CLECUR1) From SUBAMK
  When "2" :
    If !GINTRA
      Call COPIE([M:CSH1]SHACAT,[M:CSH1]SHANUM)
    Endif
  When "1"
     Gosub GEN_TRT : GCFG_GENTRT=0
Endcase
Return
###########################################################
$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET
If GFONC1 <> "GESCSH"
  Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
If GREP = "C" | GREP = "D"
  Call VIREBOUT(CHAINE,"c") From GOBJET
Endif
If GINTRA
  Call VIREBOUT(CHAINE,"c2") From GOBJET
Else
  If [M]SHACAT = "" | [M]SHANUM = ""
    Call VIREBOUT(CHAINE,"bc2") From GOBJET
  Endif
Endif
If [M:CSH1]SYMNBR = 0
  Call VIREBOUT(CHAINE,"c") From GOBJET
Endif
Return
############################################################
$RAZCRE
Call CFGSETFOR(7,"","*",[M:CSH1]FILTAB,[M:CSH1]TEXCON,[M:CSH1]VARSUP) From CFGLIB
Return
###########################################################
$VERIF_CRE
If [M:CSH1]RETCOD = 0
  If [M:CSH1]SYMNBR = 0
    W_J = 1
    Call AVERTIR(mess(36,188,1),W_J) From GESECRAN
    If W_J = 1
      Rollback
      OK = 0
    Endif
  Else
      # Issue 105050 by GA 08/2015
      # FQ 63125 déplacé en APRES_MOD - FQ 64266 Raz de la modif 63125
      # Generation liens pour cas d'emplois
      #Call CFGWUS(9,[M:CSH1]SHACAT,0) From CFGLIBE
      Gosub MAJ_FLG
      If GOK = 1
        Commit
      Else
        Rollback
        OK = 0
      Endif
   Endif
Else
  Rollback
  OK = 0
Endif
Return
############################################################
$VERIF_MOD
If [M:CSH1]RETCOD = 0
  # Issue 105050 by GA 08/2015
  # FQ 63125 déplacé en APRES_MOD - FQ 64266 Raz de la modif 63125
  # Generation liens pour cas d'emplois
  #Call CFGWUS(9,[M:CSH1]SHACAT,0) From CFGLIBE
  Gosub MAJ_FLG
  If GOK = 1
    Commit
  Else
    Rollback
    OK = 0
  Endif
Else
  Rollback
  OK = 0
Endif
Return
############################################################
$INIMOD
# FQ 63171 GA 03/2010 pb s/texte associé à la Forme
#Call MAJTEXTRA([M:CSH1]SHACATAXX,"CFGSHA","SHACATAXX",[M:CSH1]SHACAT,[M:CSH1]SHANUM) From ATEXTRA
Call MAJTEXTRA([M:CSH1]SHACATAXX,"CFGSHA","SHACATAXX",[M:CSH1]SHACAT,"") From ATEXTRA
Call MAJTEXTRA([M:CSH1]SHANUMAXX,"CFGSHA","SHANUMAXX",[M:CSH1]SHACAT,[M:CSH1]SHANUM) From ATEXTRA

# Issue 79301 GA 02/2012 Image
If len([M:CSH1]CSHPIC)<>0
    Readlock [CBB]CBB0="CSH";[M:CSH1]SHACAT;[M:CSH1]SHANUM
    Case fstat
        When 0 :
            [F:CBB]BLOB = [M:CSH1]CSHPIC
            Call REWCBB From TRTX3BLB
        When 5 :
            Raz [F:CBB]
            [F:CBB]CODBLB = "CSH"
            [F:CBB]IDENT1 = [M:CSH1]SHACAT
            [F:CBB]IDENT2 = [M:CSH1]SHANUM
            [F:CBB]TYPBLB = 3
            [F:CBB]BLOB = [M:CSH1]CSHPIC
            Call ECRCBB From TRTX3BLB
    Endcase
Else
    Delete [CBB] Where CODBLB="CSH" & IDENT1=[M:CSH1]SHACAT & IDENT2=[M:CSH1]SHANUM
Endif
Return
############################################################
$FIN_ACTION
# Action tj appelée après
# Destruction en cas de création en duplication      # JPJ E21797 ->
#  et abandon utilisateur suite message std "Confirmation duplication" oui/non
If (OK=0 & BOUT="C" & GREP="D")
    Rollback
Endif
# JPJ E21797 <-
Return
############################################################
# Positionnement a 1 du champs SHAFLG si des enregistrements existent
# deja pour cette categorie
$MAJ_FLG
[M:CSH1]SHAFLG = 0
Filter [CSH1] Where SHACAT =  [M:CSH1]SHACAT &
&                   SHANUM <> [M:CSH1]SHANUM &
&                   SHAFLG =  0
&             Order By Key CSH0
For [CSH1]
  [M:CSH1]SHAFLG = 1
  Break
Next
Filter [CSH1]
Return
############################################################
$COP_ECRAN
Call PRTSCR("CSH1","CSH1","",0,0) From ATRTX3
Return
############################################################
Subprog GEN_LABELS(LTAB,LNBR)
Variable Char    LTAB
Variable Decimal LNBR
#
Local    Integer W_I
Local    Char    W_FOR(250)
#
Raz LTAB, LNBR
#
If [M:CSH1]SHANUM <> ""
  For W_I = 0 To [M:CSH1]SYMNBR-1
    W_FOR = W_PRS+[M:CSH1]SYMNUM(W_I)
    Call LOA_SYMBOLES("1",W_FOR,LTAB,LNBR) From CFGLIB
  Next W_I
  For W_I = 0 To [M:CSH1]VARNBR-1
    If [M:CSH1]VARFOR(W_I) <> ""
      W_FOR = [M:CSH1]VARFOR(W_I)
      Call LOA_SYMBOLES("1",W_FOR,LTAB,LNBR) From CFGLIB
   Endif
  Next W_I
Endif
End
############################################################
$VERF_ANU
Local Char    W_MSG(250)
Local Char    W_PRO(5)(10)
Local Char    W_SCE(5)(10)
Local Integer I_PRO, I_SCE
# On autorise la suppression s'il reste au moins une forme / modele apres suppression
If clalev([F:CSH1]) = 0 : Local File CFGSHA [CSH1] : Endif
Filter [CSH1] Where SHACAT  = [M:CSH1]SHACAT  &
&                   SHANUM <> [M:CSH1]SHANUM
&             Order By Key CSH0
I_PRO = 0
For [CSH1]
  I_PRO = 1
  Break
Next
Filter [CSH1]
#
If I_PRO = 1
  Return
Endif
#
Raz W_PRO, W_SCE, I_PRO, I_SCE
# Exploration procedures
Filter [CFM] Where SYMTYP = 9              &
&                  SYMNUM = [M:CSH1]SHACAT
&            Order By Key CFM1
For [CFM]
  If !find([F:CFM]MACNUM,W_PRO(0..I_PRO-1))
    If I_PRO < dim(W_PRO)-1
      W_PRO(I_PRO) = [F:CFM]MACNUM
      I_PRO += 1
    Else
      Break
    Endif
  Endif
Next
Filter [CFM]
# Exploration scenarios
Filter [CSL] Where SYMTYP = 9              &
&                  SYMNUM = [M:CSH1]SHACAT
&            Order By Key CSL1
For [CSL]
  If !find([F:CSL]SCENUM,W_SCE(0..I_SCE-1))
    If I_SCE < dim(W_SCE)-1
      W_SCE(I_SCE) = [F:CSL]SCENUM
      I_SCE += 1
    Else
      Break
    Endif
  Endif
Next
Filter [CSL]
If I_PRO <> 0 | I_SCE <> 0
  W_MSG = mess(86,188,1)
  If I_PRO <> 0
    W_MSG += "\"+mess(7,752,1)+" : "
    For W_K = 0 To I_PRO-1
      W_MSG += W_PRO(W_K)+", "
    Next W_K
  Endif
  If I_SCE <> 0
    W_MSG += "\"+mess(1,188,1)+" : "
    For W_K = 0 To I_SCE-1
      W_MSG += W_SCE(W_K)+", "
    Next W_K
  Endif
  Call ERREUR(W_MSG) From GESECRAN
  OK = 0
Endif
Return
############################################################
$ANNULE
Call DEL_WIN(nomap,"WUF"+[M:CSH1]SHACAT+[M:CSH1]SHANUM,"","") From CFGLIBA
Delete [AXX] Where CODFIC="CFGSHA" & IDENT1=[M:CSH1]SHACAT & IDENT2=[M:CSH1]SHANUM
Return
############################################################
$AP_ANNULE
Call CFGWUS(9,[M:CSH1]SHACAT,1) From CFGLIBE
GCFG_GENTRT=1
Return
############################################################
$ABANDON
# JPJ E21797 : ajout réponse <> ( abandon ou fin) dans le test
#    car si l'utilisateur click sur le bouton bas d'écran abandon (ou fin) le trbegin de APRES_CHOI n'est pas fait
If GREP = "D" & !find(REPONSE,GSTAFIN, GSTAEND)
  Rollback    #
Endif
Return
############################################################
$FERME
# Generation des labels correspondant aux formes et modeles
# Issue 105050 by GA 08/2015
#If GCFG_GENTRT : Gosub GEN_TRT : Endif
Gosub GEN_TRT
#
Call IMPSCR        From ATRTX3
Gosub SUP_GLOBALES From WUVAR
#
Call DEA_CFGUSR(GFONCTION) From CFGLIBD
Return
############################################################
# Generation des labels correspondant aux formes et modeles
$GEN_TRT
Local Integer W_ITR : W_ITR = 0
Local Char    WQSTDES(GLONDES)    # FQ 60020 GA 11/2009
Local Char    WSHACATDES(GLONDES) # FQ 60020 GA 11/2009
$GEN_TRT1
Call DEBTRANS From GLOCK
Trbegin [CQU]
GOK = 1
Filter [CQU] Where QSTORI = 2
&            Order By Key CQU1
For [CQU]
  Readlock [CSH]CSH0=[F:CQU]SHACAT
  Case fstat
    When 0 :
    When 1 :
      GOK = -1
      Break
    When 4, 5 :
      Delete [CQU]
      If fstat
        Call FSTA("CSH"        ) From GLOCK
        GOK = 0
        Break
      Endif
    When Default
      Call FSTA("CSH") From GLOCK
      GOK = 0
      Break
  Endcase
Next
Filter [CQU]
#
If GOK = 1
  Filter [CSH]
  For [CSH]
    Readlock [CQU]CQU0=[F:CSH]SHACAT
    Case fstat
      When 1 :
        GOK = -1
        Break
      When 0 :
        Call LECTEXTRA(WQSTDES   ,"CFGQST","QSTAXX"   ,[F:CQU]QSTNUM,"") From ATEXTRA
        # FQ 63171 GA 03/2010 pb s/texte associé à la Forme
        #Call LECTEXTRA(WSHACATDES,"CFGSHA","SHACATAXX",[F:CSH]SHACAT,[M:CSH1]SHANUM) From ATEXTRA
        Call LECTEXTRA(WSHACATDES,"CFGSHA","SHACATAXX",[F:CSH]SHACAT,"") From ATEXTRA
        If WQSTDES <> WSHACATDES
           # copie: [F:CQU]QSTDES    = [F:CSH]SHACATDES
           Call DUPTEXTRA("CFGSHA","SHACATAXX",[F:CSH]SHACAT,"","CFGQST","QSTAXX",[F:CQU]QSTNUM,"") From ATEXTRA
        Endif
# FQ 53410 textes traduits - FQ 60020 GA 11/2009
#       If [F:CQU]QSTDES <> [F:CSH]SHACATDES | [F:CQU]QSTSHO <> [F:CSH]SHACATDES
#          [F:CQU]QSTDES    = [F:CSH]SHACATDES
     # FQ 63171 GA 03/2010 il faut mettre à jour [F:CQU]QSTSHO(0)
        If [F:CQU]QSTSHO(0) = ""
           [F:CQU]QSTSHO(0) = WSHACATDES # avant [F:CSH]SHACATDES
           [F:CQU]UPDDAT    = date$
           [F:CQU]UPDUSR    = GUSER
           Rewrite [CQU]
           If fstat
             GOK = 0
             Call FSTA("CQU") From GLOCK
             Break
           Endif
        Endif
      When 4,5 :
        Raz [F:CQU]
        [F:CQU]QSTNUM    = [F:CSH]SHACAT
        # FQ 53410 remplacé par le lien
        #[F:CQU]QSTDES    = [F:CSH]SHACATDES
        # FQ 60020 GA 11/2009
        Call LECTEXTRA(WQSTDES   ,"CFGQST","QSTAXX"   ,[F:CQU]QSTNUM,"") From ATEXTRA
       # FQ 63171 GA 03/2010 pb s/texte associé à la Forme
      # Call LECTEXTRA(WSHACATDES,"CFGSHA","SHACATAXX",[F:CSH]SHACAT,[M:CSH1]SHANUM) From ATEXTRA
        Call LECTEXTRA(WSHACATDES,"CFGSHA","SHACATAXX",[F:CSH]SHACAT,"") From ATEXTRA
        If WQSTDES <> WSHACATDES
           # copie: [F:CQU]QSTDES    = [F:CSH]SHACATDES
           Call DUPTEXTRA("CFGSHA","SHACATAXX",[F:CSH]SHACAT,"","CFGQST","QSTAXX",[F:CQU]QSTNUM,"") From ATEXTRA
        Endif
      # FQ 63171 GA 03/2010 il faut mettre à jour [F:CQU]QSTSHO(0)
        [F:CQU]QSTSHO(0) = WSHACATDES # avant [F:CSH]SHACATDES
        [F:CQU]QSTLEN    = 99 - len([F:CSH]SHACAT)
        [F:CQU]QSTTYP    = 1
        [F:CQU]QSTORI    = 2
        [F:CQU]QSTDIM    = 1
        [F:CQU]ASWTYP    = 1
        [F:CQU]ASWCHA    = 1
        [F:CQU]CTLTYP    = 4
        [F:CQU]SHACAT    = [F:CSH]SHACAT
        If [F:CSH]SHATYP = 2
          [F:CQU]ASWCHA    = 3
          [F:CQU]ALPDEFVAL = tolower([F:CSH]SHACAT)
        Endif
        [F:CQU]CTLBLO    = 2
        [F:CQU]HISFLG    = 2
        [F:CQU]SEAFLG    = 1
        [F:CQU]QUOFLG    = 1
        [F:CQU]ORDFLG    = 1
        [F:CQU]CREDAT    = date$
        [F:CQU]CREUSR    = GUSER
        Write [CQU]
        If fstat
          GOK = 0
          Call FSTA("CQU") From GLOCK
          Break
        Endif
      When Default :
        GOK = 0
        Call FSTA("CQU") From GLOCK
        Break
    Endcase
  Next
  Filter [CSH]
Endif
Case GOK
  When -1 :
    Rollback
    Call ROLL From GLOCK
    If !GROLL
      Goto GEN_TRT1
    Endif
  When 1 :
    Commit
    Call TEMPON(mess(76,188,1)) From GESECRAN
    Call GEN_WUVAR(nomap,"","") From CFGLIBA
    # Issue 105050 by GA 08/2015 after GEN_WUVAR
    Call CFGWUS(9,[M:CSH1]SHACAT,0) From CFGLIBE
    adxmbm = adxmbm
    Call TEMPOFF From GESECRAN
  When Default :
    Rollback
Endcase
Return
############################################################
Subprog COPIE(LFAM,LNUM)
Value Char    LFAM
Value Char    LNUM
#
Local Char    W_SYM(10)(500)
Local Decimal W_NBR
#
Local Char    W_FOR(250)
Local Char    W_TRA(100)
Local Char    W_EVA1(80)
Local Char    W_EVA2(80)
Local Integer W_OK
Local Integer W_ERR
Local Integer W_I, W_J, W_K
#
If GTRACE = ""
  Call OUVRE_TRACE(mess(114,188,1)-LFAM-LNUM) From LECFIC
Endif
W_ERR = 0
If clalev([M:DIA]) = 0
  GMODIF = 0
  Local Mask ACOPIE [DIA]
  Raz [M:DIA]
  [M:DIA]OBJET = mess(9,752,1)+" : "+LFAM-LNUM
  W_OK = 2
  zonsui = "DOSDES"
  Call DIALWIN(W_OK,mess(114,188,1),"ACOPIE") From GESECRAN
  If W_OK <> 2
   Goto COPIE_FIN
  Endif
Endif
# Tables en lecture (From)
If [M:DIA]DOSORG <> nomap
  Call ERREUR(mess(94,188,1)) From GESECRAN
  Goto COPIE_FIN
Else
  Local File CFGQST    [CQU1]
  Local File CFGABQ    [CAB1]
  Local File CFGSHA    [CSH1]
  Local File TABCTL    [TCT1]
  Local File ATEXTRA   [AXX1]
Endif
# tables en ecriture (To)
If [M:DIA]DOSDES = nomap
  Call ERREUR(mess(94,188,1)) From GESECRAN
  Goto COPIE_FIN
Else
  Local File =[M:DIA]DOSDES+".CFGQST"    [CQU2]
  Local File =[M:DIA]DOSDES+".CFGABQ"    [CAB2]
  Local File =[M:DIA]DOSDES+".CFGSHA"    [CSH2]
  Local File =[M:DIA]DOSDES+".CBLOB"     [CBB2]
  Local File =[M:DIA]DOSDES+".TABCTL"    [TCT2]
  Local File =[M:DIA]DOSDES+".ATEXTRA"   [AXX2]
Endif
# Contrôle copie possible (les elements existants doivent etre de meme nature)
Read [CSH1]CSH0=LFAM;LNUM
If fstat
  Goto COPIE_FIN
Endif
#
For W_K = 0 To [F:CSH1]SYMNBR-1
  W_FOR = W_PRS+[F:CSH1]SYMNUM(W_K)
  Call LOA_SYMBOLES("12",W_FOR,W_SYM,W_NBR) From CFGLIB
Next W_K
#
For W_K = 0 To [F:CSH1]VARNBR-1
  W_FOR = W_PRS+[F:CSH1]VARNUM(W_K)
  Call LOA_SYMBOLES("12",W_FOR,W_SYM,W_NBR) From CFGLIB
  W_FOR = [F:CSH1]VARFOR(W_K)
  Call LOA_SYMBOLES("12",W_FOR,W_SYM,W_NBR) From CFGLIB
Next W_K
# Contrôle symboles memes caracteristiques si existant
For W_I = 0 To W_NBR-1
  Read [CQU1]CQU0=W_SYM(W_I)
  If fstat
    W_TRA = W_SYM(W_I)-mess(90,188,1)
    W_ERR = 1
    Call ECR_TRACE(W_TRA,1) From GESECRAN
  Endif
  If [F:CQU1]TCT <> ""
    Read [TCT1]TCT0=[F:CQU1]TCT;1
    If fstat
      W_TRA = [F:CQU1]TCT-mess(104,188,1)
      W_ERR = 1
      Call ECR_TRACE(W_TRA,1) From GESECRAN
    Endif
  Endif
  Read [CQU2]CQU0=W_SYM(W_I)
  If fstat = 0
    If [F:CQU1]QSTTYP <> [F:CQU2]QSTTYP |
&      [F:CQU1]QSTORI <> [F:CQU2]QSTORI |
&      [F:CQU1]ASWTYP <> [F:CQU2]ASWTYP |
&      [F:CQU1]CTLTYP <> [F:CQU2]CTLTYP |
&      [F:CQU1]TCT    <> [F:CQU2]TCT
      W_TRA = W_SYM(W_I)-mess(90,188,1)
      W_ERR = 1
      Call ECR_TRACE(W_TRA,1) From GESECRAN
    Endif
  Endif
  If [F:CQU1]TCT <> ""
    Read [TCT2]TCT0=[F:CQU1]TCT;1
    If fstat = 0
      If [F:TCT1]TCTTYP <> [F:TCT2]TCTTYP
        W_TRA = [F:CQU1]TCT-mess(103,188,1)
        W_ERR = 1
        Call ECR_TRACE(W_TRA,1) From GESECRAN
      Endif
    Endif
  Endif
Next W_I
#
If W_ERR <> 0
  Goto COPIE_FIN
Endif
Read [CSH2]CSH0=LFAM;LNUM
If fstat = 0
  W_OK = 2
  Call OUINON(mess(148,196,1),W_OK) From GESECRAN
  If W_OK <> 2
    Call OUVRE_TRACE(mess(114,188,1)-LFAM-LNUM) From LECFIC
    Goto COPIE_FIN
  Endif
Endif
Gosub OUVDOS From ATEXTRA
# Tout est ok on copie
#
Call TEMPON("T") From GESECRAN
Call DEBTRANS    From GLOCK
Gosub TRT_COPIE
Call TEMPOFF From GESECRAN
# Fin de copie
$COPIE_FIN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End
############################################################
$TRT_COPIE
Local Char    WAMK(GLONAMK) : # FQ 49403 GA 01/2009
Trbegin [CSH2]
Delete [CSH2] Where SHACAT = LFAM &
&                   SHANUM = LNUM
# Copie formes / modeles
Read [CSH1]CSH0=LFAM;LNUM
If fstat = 0
  Read [CSH2]CSH0=[F:CSH1]SHACAT;[F:CSH1]SHANUM
  If fstat
    [F:CSH2] = [F:CSH1]
    [F:CSH2]CREUSR = GUSER
    [F:CSH2]CREDAT = date$
    [F:CSH2]UPDUSR = ""
    [F:CSH2]UPDDAT = [0/0/0]
    Write [CSH2]
    If fstat
      GOK = 0
      Call FSTA("CSH2") From GLOCK
    Else
      # FQ 49403 copie fenêtre+écran - Réponses formes & modèles
      WAMK = "WUF"+[F:CSH1]SHACAT+[F:CSH1]SHANUM
      Call COP_CFGWIN([M:DIA]DOSORG,[M:DIA]DOSDES,WAMK,WAMK,"") From CFGLIBA

      W_TRA = mess(91,123,1)-mess(9,752,1)-[F:CSH2]SHACAT-[F:CSH2]SHANUM
      Call ECR_TRACE(W_TRA,0) From GESECRAN
    Endif
    # FQ 63171 GA 03/2010 pb s/texte associé à la Forme
    #Call COPTEXTRA("CFGSHA","SHACATAXX",[F:CSH1]SHACAT,[F:CSH1]SHANUM) From ATEXTRA
    Call COPTEXTRA("CFGSHA","SHACATAXX",[F:CSH1]SHACAT,"") From ATEXTRA
    Call COPTEXTRA("CFGSHA","SHANUMAXX",[F:CSH1]SHACAT,[F:CSH1]SHANUM) From ATEXTRA
    Read [CBB1]CBB0="CSH";[F:CSH1]SHACAT;[F:CSH1]SHANUM
    If !fstat
        Read [CBB2]CBB0="CSH";[F:CSH1]SHACAT;[F:CSH1]SHANUM
        If fstat
            [F:CBB2] = [F:CBB1]
            Raz [F:CBB2]UPDUSR, [F:CBB2]UPDDAT, [F:CBB2]UPDTIM
            #Call ECRCBB From TRTX3BLB # utilise le buffer [F:CBB]
            [F:CBB2]CREUSR = GUSER
            [F:CBB2]CREDAT = date$
            Write [CBB2]
            If fstat
               GOK = 0
               Call FSTA("CBB2") From GLOCK
            Endif
        Endif
    Endif
  Endif
Endif
If GOK <> 1
  Goto AB_COPIE
Endif
# Copie symboles
For W_I = 0 To W_NBR-1
  Read [CQU1]CQU0=W_SYM(W_I)
  If fstat
    GOK = 0
    Call FSTA("CQU1") From GLOCK
    Break
  Endif
  Read [CQU2]CQU0=W_SYM(W_I)
  If fstat
    [F:CQU2] = [F:CQU1]
    [F:CQU2]CREUSR = GUSER
    [F:CQU2]CREDAT = date$
    [F:CQU2]UPDUSR = ""
    [F:CQU2]UPDDAT = [0/0/0]
    Write [CQU2]
    If fstat
      GOK = 0
      Call FSTA("CQU2") From GLOCK
      Break
    Endif
    W_TRA = mess(91,123,1)-mess([F:CQU2]QSTTYP,752,1)-[F:CQU2]QSTNUM
    Call ECR_TRACE(W_TRA,0) From GESECRAN
    Call COPTEXTRA("CFGQST","QSTAXX",[F:CQU1]QSTNUM,"") From ATEXTRA
    Read [CBB1]CBB0="CQU";[F:CQU1]QSTNUM;""
    If !fstat
        Read [CBB2]CBB0="CQU";[F:CQU1]QSTNUM;""
        If fstat
            [F:CBB2] = [F:CBB1]
            Raz [F:CBB2]UPDUSR, [F:CBB2]UPDDAT, [F:CBB2]UPDTIM
            #Call ECRCBB From TRTX3BLB # utilise le buffer [F:CBB]
            [F:CBB2]CREUSR = GUSER
            [F:CBB2]CREDAT = date$
            Write [CBB2]
            If fstat
               GOK = 0
               Call FSTA("CBB2") From GLOCK
               Break
            Endif
        Endif
    Endif
  Endif
  If [F:CQU1]TCT <> ""
    Read [TCT2]TCT0=[F:CQU1]TCT;1
    If fstat
      Filter [TCT1] Where TCT = [F:CQU1]TCT
      For [TCT1]
        [F:TCT2] = [F:TCT1]
        [F:TCT2]CREUSR = GUSER
        [F:TCT2]CREDAT = date$
        [F:TCT2]UPDUSR = ""
        [F:TCT2]UPDDAT = [0/0/0]
        Write [TCT2]
        If fstat
          GOK = 0
          Call FSTA("TCT2") From GLOCK
          Break
        Endif
        If [F:TCT2]TCTLIN = 1
          W_TRA = mess(91,123,1)-mess(105,188,1)-[F:TCT2]TCT
          Call ECR_TRACE(W_TRA,0) From GESECRAN
        Endif
      Next
      Filter [TCT1]
    Endif
  Endif
Next W_I

If GOK <> 1
  Goto AB_COPIE
Else
  Commit
Endif
Return
############################################################
$AB_COPIE
Rollback
Return
############################################################
$ROLL_COPIE
Rollback
Call ROLL From GLOCK
If !GROLL
  Goto TRT_COPIE
Endif
Return

############################################################
# FQ 60007 GA 11/2009 SHACATDES remplacé par SHACATAXX
Subprog AS_SHACATAXX(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" End Endif
Filter [CSH1] Where SHACAT = [M]SHACAT
For [CSH1]
  # FQ 63171 GA 03/2010 pb s/texte associé à la Forme
  #Call LECTEXTRA(VALEUR,"CFGSHA","SHACATAXX",[F:CSH1]SHACAT,[F:CSH1]SHANUM) From ATEXTRA
  Call LECTEXTRA(VALEUR,"CFGSHA","SHACATAXX",[F:CSH1]SHACAT,"") From ATEXTRA
  Break
Next
Filter [CSH1]
End
############################################################
Subprog C_SHACAT(VALEUR)
Variable Char    VALEUR()
Read [CQU]CQU0=VALEUR
If fstat = 0 & [F:CQU]QSTORI = 1
  mkstat = 2
Else
  If GREP = "C" | GREP = "D"
    Filter [CSH1] Where SHACAT = VALEUR &
&                       SHATYP = 2
&                 Order By Key CSH0
    For [CSH1]
      mkstat = 2
      Break
    Next
    Filter [CSH1]
  Endif
Endif
End
#############################################################
Subprog AS_SHATYP(VALEUR)
Variable Integer VALEUR
If GREP = "D"
  mkstat = 2
Else
  If GREP = "C"
    Filter [CSH1] Where SHACAT = [M:CSH1]SHACAT
&                 Order By Key CSH0
    For [CSH1]
      VALEUR = 1
      mkstat = 2
      Break
    Next
    Filter [CSH1]
  Endif
  # FQ 60007 GA 11/2009 SHANUMDES remplacé par SHANUMAXX
  If [M:CSH1]VARNBR > 0 | [M:CSH1]SHANUM <> "" | [M:CSH1]SHANUMAXX <> ""
    mkstat = 2
    # VALEUR = 1 # FQ 50694 ne pas écraser la valeur en modif (si case cochée ...)
  Endif
Endif
End
#############################################################
Subprog AM_SHATYP(VALEUR)
Variable Integer VALEUR
End
#############################################################
Subprog AS_VARNBR
If [M:CSH1]SHATYP = 2
  mkstat = 2
Endif
End
##############################################################
Subprog AS_SHANUM(VALEUR)
Variable Char    VALEUR()
If [M:CSH1]SHATYP = 2
  VALEUR = [M:CSH1]SHACAT
  mkstat = 2
Endif
End
##############################################################
  # FQ 60007 GA 11/2009 SHANUMDES remplacé par SHANUMAXX
Subprog AS_SHANUMAXX(VALEUR)
Variable Char    VALEUR()
If [M:CSH1]SHATYP = 2
  VALEUR = [M:CSH1]SHACATAXX
  mkstat = 2
Endif
End
###############################################################
Subprog AS_SYMCND(VALEUR)
Variable Char    VALEUR()
End

