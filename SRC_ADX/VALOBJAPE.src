#<AdxTL>@(#)0.0.0.0 $Revision$

# Insertion du traitement SPV dans la table des points d'entrée s'il n'y existe pas

$AENTREE
#jira 78086 file must be opened in appli folder
If clalev([F:APE])=0 : Local File =APPLI+".AENTREE" [APE] : Endif

Call EXISTE_ADX("","","SPV"+OBJET,OK) From ORDSYS
If OK
 Read [APE]APE0="";OBJET;"SPV"+OBJET
 If fstat
  Trbegin [APE]
   Raz [F:APE]
   [F:APE]TRTSPE = "SPV"+OBJET
   [F:APE]OBJ    = OBJET
   [F:APE]TYP    = 2 : # Objet
   [F:APE]MODULE = [L]AOB_MOD
   [F:APE]CODACT = [L]AOB_ACV
   If dim([F:APE]CREUSR)>0 : [F:APE]CREUSR = GUSER : Endif
   If dim([F:APE]CREDAT)>0 : [F:APE]CREDAT = date$ : Endif
   If dim([F:APE]CRETIM)>0 : [F:APE]CRETIM = time  : Endif
   Write [APE]
  Commit
 Endif
Else
 Read [APE]APE0="";OBJET;"SPV"+OBJET
 If !fstat
  Delete [F:APE] Curr
  If fstat=1
   GOK=-1 : Call RSTA("APE",";"+OBJET+";SPV"+OBJET) From GLOCK : Return
  Endif
 Endif
Endif
Return

