#     Contains syracuse constants:

Subprog INIVAR
Gosub DEFVAR_CHECK
Gosub DEFVAR_AURL
Gosub DEFVAR_CRUD
Gosub DEFVAR_TAB
Gosub DEFVAR_TYPE
Gosub DEFVAR_ACTX
Gosub DEFVAR_ACCESSORFILTER
Gosub DEFVAR_SNAPSHOTFILTER
Gosub DEFVAR_SETINSTANCEFILTER
