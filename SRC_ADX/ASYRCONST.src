$DEFVAR_CRUD
# constants CRUD
Global Integer CST_ALL           : [V]CST_ALL     =  0
Global Integer CST_ANEW          : [V]CST_ANEW    =  2
Global Integer CST_AUPD          : [V]CST_AUPD    =  4
Global Integer CST_ADEL          : [V]CST_ADEL    = 16
Global Integer CST_ANEWDEL       : [V]CST_ANEWDEL =  1

# Pour le crud Nom des programmes CruD
Global Schar   CST_APRGAINSERT(GLONAVB) : [V]CST_APRGAINSERT = "AINSERT" : # C Create
Global Schar   CST_APRGAREAD(GLONAVB)   : [V]CST_APRGAREAD = "AREAD"     : # R Read
Global Schar   CST_APRGAUPDATE(GLONAVB) : [V]CST_APRGAUPDATE = "AUPDATE" : # U Update
Global Schar   CST_APRGADELETE(GLONAVB) : [V]CST_APRGADELETE = "ADELETE" : # D Delete

Global Schar CST_ASTALIN(10)(0..) # Status of line
[V]CST_ASTALIN([V]CST_ALL)       = ""
[V]CST_ASTALIN([V]CST_ANEW)      = "AINSERT"
[V]CST_ASTALIN([V]CST_AUPD )     = "AUPDATE"
[V]CST_ASTALIN([V]CST_ADEL)      = "ADELETE"
[V]CST_ASTALIN([V]CST_ANEWDEL)   = ""
Return

