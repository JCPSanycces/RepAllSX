$DEFVAR_AVOID
# for global variable AVOID internal used
Global Char CST_CLASS_AISNULL_NAME(GLONAVB)
CST_CLASS_AISNULL_NAME = "AISNULL"
Global Char CST_CLASS_AISNULL_C_NAME(GLONAVB)
CST_CLASS_AISNULL_C_NAME = "C_AISNULL"
Global Char CST_INSTANCE_AISNULL_NAME(GLONAVB)
CST_INSTANCE_AISNULL_NAME = "AVOID"
Global Char CST_LIST_AISNULL_PRO_NAME(GLONAVA)(1..12)
CST_LIST_AISNULL_PRO_NAME(1)  = "ACHAR"
CST_LIST_AISNULL_PRO_NAME(2)  = "ASHORT"
CST_LIST_AISNULL_PRO_NAME(3)  = "AINT"
CST_LIST_AISNULL_PRO_NAME(4)  = "ADEC"
CST_LIST_AISNULL_PRO_NAME(5)  = "ADATE"
CST_LIST_AISNULL_PRO_NAME(6)  = "ALIB"
CST_LIST_AISNULL_PRO_NAME(7)  = "ACLOB"
CST_LIST_AISNULL_PRO_NAME(8)  = "ABLOB"
CST_LIST_AISNULL_PRO_NAME(9)  = "AINS"
CST_LIST_AISNULL_PRO_NAME(10) = "AUUIDENT"
CST_LIST_AISNULL_PRO_NAME(11) = "ADATTIM"
CST_LIST_AISNULL_PRO_NAME(12) = "ATINYINT"
