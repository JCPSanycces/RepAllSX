$DECLARE_AVOID
## Class AISNULL
If dim(AVOID)<0
 Global Instance AVOID Using =[V]CST_CLASS_AISNULL_C_NAME
Endif
If AVOID=null
 AVOID = evalue( "NewInstance "+[V]CST_CLASS_AISNULL_C_NAME-"AllocGroup Null" )
 AVOID.setAccessorEnabled = 1
 AVOID.getAccessorEnabled = 1
 AVOID.AINF = NewInstance C_AINFO AllocGroup AVOID
 AVOID.AINF.NBTRT += 1
 AVOID.AINF.TRT(AVOID.AINF.NBTRT) = "AISNULL_CSTD"
 AVOID.AINF.TYP(AVOID.AINF.NBTRT) = 1
 AVOID.AINF.PTH(AVOID.AINF.NBTRT) = ""
Endif
Return

$DEFVAR_ACCESSORFILTER
# Optimisation
Local Integer NBACCFLT  : [S]accessorFilter([L]NBACCFLT) = "APARENT"
[L]NBACCFLT += 1         : [S]accessorFilter([L]NBACCFLT) = "ACTX"
[L]NBACCFLT += 1         : [S]accessorFilter([L]NBACCFLT) = "ATT"
[L]NBACCFLT += 1         : [S]accessorFilter([L]NBACCFLT) = "AATTRIBUTES"
[L]NBACCFLT += 1         : [S]accessorFilter([L]NBACCFLT) = "AXX"
[L]NBACCFLT += 1         : [S]accessorFilter([L]NBACCFLT) = "AERROR"
[L]NBACCFLT += 1         : [S]accessorFilter([L]NBACCFLT) = "AINF"
[L]NBACCFLT += 1         : [S]accessorFilter([L]NBACCFLT) = "_APARAMURL"
[L]NBACCFLT += 1         : [S]accessorFilter([L]NBACCFLT) = "AINFOS"
[L]NBACCFLT += 1         : [S]accessorFilter([L]NBACCFLT) = "ATX"
Return

$DEFVAR_SNAPSHOTFILTER
Local Integer NBSNAPFLT  : [S]snapshotFilter([L]NBSNAPFLT) = "ACTX"
[L]NBSNAPFLT += 1         : [S]snapshotFilter([L]NBSNAPFLT) = "AXX"
[L]NBSNAPFLT += 1         : [S]snapshotFilter([L]NBSNAPFLT) = "AINF"
[L]NBSNAPFLT += 1         : [S]snapshotFilter([L]NBSNAPFLT) = "_APARAMURL"
[L]NBSNAPFLT += 1         : [S]snapshotFilter([L]NBSNAPFLT) = "AINFOS"
[L]NBSNAPFLT += 1         : [S]snapshotFilter([L]NBSNAPFLT) = "ATX"
[L]NBSNAPFLT += 1         : [S]snapshotFilter([L]NBSNAPFLT) = "_ASTADETLNK"
Return

$DEFVAR_SETINSTANCEFILTER
Local Integer NBSETINSFLT : [S]ADXSTI([L]NBSETINSFLT)= "UPDTICK"
[L]NBSETINSFLT += 1       : [S]ADXSTI([L]NBSETINSFLT)= "AUUID"
[L]NBSETINSFLT += 1       : [S]ADXSTI([L]NBSETINSFLT)= "CREDAT"
[L]NBSETINSFLT += 1       : [S]ADXSTI([L]NBSETINSFLT)= "UPDDAT"
[L]NBSETINSFLT += 1       : [S]ADXSTI([L]NBSETINSFLT)= "CREUSR"
[L]NBSETINSFLT += 1       : [S]ADXSTI([L]NBSETINSFLT)= "UPDUSR"
[L]NBSETINSFLT += 1       : [S]ADXSTI([L]NBSETINSFLT)= "CREDATTIM"
[L]NBSETINSFLT += 1       : [S]ADXSTI([L]NBSETINSFLT)= "UPDDATTIM"
Return

$DEFVAR_SUP
# Attribut for wright test
Global Char CST_ARIGHTACCESS(14) : [V]CST_ARIGHTACCESS= "$_rightAccess"

# Nex syntac allocgroup
Global Char CST_ALLOCGROUP(20) : [V]CST_ALLOCGROUP = "AllocGroup"

# Pour la validation de classe à la volée
adxovs =  "ACLAVAL"
adxovf =  "VALID_ONDEMAND"
Return

