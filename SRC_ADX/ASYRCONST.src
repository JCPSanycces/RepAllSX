Gosub DEFVAR_SUP
Gosub DEFVAR_FACETTE
Gosub DEFVAR_AVOID
Gosub EXEC_DEFVAR From SUBACST
End

$DEFVAR_HTTP_ERRORS
# Http errors
Global Integer CST_AHTTP_OK : [V]CST_AHTTP_OK =  200
Global Integer CST_AHTTP_CREATED : [V]CST_AHTTP_CREATED =  201
Global Integer CST_AHTTP_ACCEPTED : [V]CST_AHTTP_ACCEPTED =  202
Global Integer CST_AHTTP_NO_CONTENT : [V]CST_AHTTP_NO_CONTENT = 204
#
Global Integer CST_AHTTP_NO_MODIFIED : [V]CST_AHTTP_NO_MODIFIED = 304
#HTTP client error
Global Integer CST_AHTTP_BAD_REQUEST : [V]CST_AHTTP_BAD_REQUEST = 400
Global Integer CST_AHTTP_UNAUTHORIZED : [V]CST_AHTTP_UNAUTHORIZED = 401
Global Integer CST_AHTTP_FORBIDDEN : [V]CST_AHTTP_FORBIDDEN = 403
Global Integer CST_AHTTP_NOT_FOUND : [V]CST_AHTTP_NOT_FOUND     =  404
Global Integer CST_AHTTP_NOT_ACCEPTABLE : [V]CST_AHTTP_NOT_ACCEPTABLE     =  406
Global Integer CST_AHTTP_CONFLICT : [V]CST_AHTTP_CONFLICT = 409
Global Integer CST_AHTTP_PRECONDITION_FAILED : [V]CST_AHTTP_PRECONDITION_FAILED = 412
Global Integer CST_AHTTP_UNSUPPORTED_MEDIA : [V]CST_AHTTP_UNSUPPORTED_MEDIA =  415
Global Integer CST_AHTTP_EXPECTATION_FAILED : [V]CST_AHTTP_EXPECTATION_FAILED = 417
#HTTP server error
Global Integer CST_AHTTP_INTERNAL: [V]CST_AHTTP_INTERNAL = 500
Global Integer CST_AHTTP_NOT_IMPLEMENTED : [V]CST_AHTTP_NOT_IMPLEMENTED = 501
Return

