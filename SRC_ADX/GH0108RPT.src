#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################
## Compûˋtences par salariûˋ
####################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Call TEMPON("O") From GESECRAN

Local Char    PARAM(20), ETAT(GLONARP), CRITERE(250), CRITERE1(250)
Local Char    CPY(GLONCPY), FCYDEB(GLONFCY), FCYFIN(GLONFCY)
Local Char    PRF(GLONPRF), SRV(GLONSRV)
Local Char    MATDEB(GLONEML), MATFIN(GLONEML),POP(GLONPOP)
Local Char TAXYEAR(4)

Local Decimal NUMREQ

If clalev([F:ARM])=0    : Local File AREPORTM  [ARM]    : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR  [HRCTR]  : Endif
If clalev([F:FGR])=0    : Local File FACGROUP  [FGR]    : Endif
If clalev([F:HRPOA])=0  : Local File POPULA    [HRPOA]  : Endif
If clalev([F:HRPEOD])=0 : Local File HRPEODET  [HRPEOD] : Endif
If clalev([F:HRPEOH])=0 : Local File HRPEOHEA  [HRPEOH] : Endif

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT)
Call GETPARAM("cpy",NBPAR,PARAMETRE,CPY)
Call GETPARAM("fcydeb",NBPAR,PARAMETRE,FCYDEB)
Call GETPARAM("fcyfin",NBPAR,PARAMETRE,FCYFIN)
Call GETPARAM("matdeb",NBPAR,PARAMETRE,MATDEB)
Call GETPARAM("matfin",NBPAR,PARAMETRE,MATFIN)
Call GETPARAM("srv",NBPAR,PARAMETRE,SRV)
Call GETPARAM("taxyear",NBPAR,PARAMETRE,TAXYEAR)
Call GETPARAM("prf",NBPAR,PARAMETRE,PRF)
Call GETPARAM("pop",NBPAR,PARAMETRE,POP)
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) : [L]NUMREQ = val(PARAM)

PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

CRITERE1 = "1=1"

If CPY<>"" : CRITERE1 -= "& [F:FGR]CPY='"+CPY+"'"    : Endif
If FCYDEB<>"" : CRITERE1 -= "& [F:HRCTR]ETRFCY>='"+FCYDEB+"'"    : Endif
If FCYFIN<>"" : CRITERE1 -= "& [F:HRCTR]ETRFCY<='"+FCYFIN+"'"    : Endif
If PRF<>"" : CRITERE1 -= "& [F:HRCTR]PROPRF='"+PRF+"'"    : Endif
If MATDEB<>"" : CRITERE1 -= "& [F:HRCTR]REFNUM>='"+MATDEB+"'" : Endif
If MATFIN<>"" : CRITERE1 -= "& [F:HRCTR]REFNUM<='"+MATFIN+"'" : Endif
If SRV<>"" : CRITERE1 -= "& [F:HRCTR]ETRSRV='"+SRV+"'"    : Endif


Gosub TR1
Gosub TR2

End

$TR1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER
Commit
Return

$TR2
Trbegin [ARM]

  Local Date STRDAT, ENDDAT
  Local Date RESULT_VALUE, RESULT_VALUE2
  Local Integer ITAXYEAR
  Local Integer ITAXMON
  Local Integer K

#initialize
  RESULT_VALUE=date$
  RESULT_VALUE2=date$
  K=0

  ITAXYEAR = val(TAXYEAR)
  ITAXMON = 1

Link [HRPEOH] With
&   [HRPEOD]HRPEOD0(1) = [HRPEOH]PERCOD
& As [LNK]
& Where [F:HRPEOD]PERYEA =[F:HRPEOH]PERYEA & [F:HRPEOH]PERYEA = ITAXYEAR & [F:HRPEOH]LEG = "GHA" & [F:HRPEOH]FLGENA = 2
& Order By [F:HRPEOD]PEREND Asc

 For [LNK]
    Raz [F:ARM]
    K+=1
    RESULT_VALUE = [F:HRPEOH]CYCSTRDAT
    If ([F:HRPEOD]PERSTR < RESULT_VALUE) Then
     RESULT_VALUE = [F:HRPEOH]CYCSTRDAT
    Endif
    RESULT_VALUE2= max(RESULT_VALUE2,[F:HRPEOH]CYCENDDAT)
    [F:ARM]USR    = GUSER
    [F:ARM]RPTCOD = [L]ETAT
    [F:ARM]NUMREQ = [L]NUMREQ
    [F:ARM]CLEA1  = [L]CPY
    [F:ARM]CLED1  = RESULT_VALUE
    [F:ARM]CLED2  = RESULT_VALUE2
    [F:ARM]NUMLIG = K

    Write [ARM]
    If fstat
     GOK = 0 : Call FSTA("ARM") From GLOCK : Break 2
    Endif
  Next
 If GOK=0
  Goto AB_TR2
 Elsif GOK=-1
  Goto ROLL_TR2
 Endif
Commit
Return


$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif
Return

$AB_TR2
Rollback
Return

Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End

