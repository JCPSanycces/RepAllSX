#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UTIOPP001 Table OPPOR Déplacement des tableaux dans des      Module TC #
#           sous-tables                                                  #
##########################################################################
# FGR 02/05/2011 : X3SUIVIxxxxx
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTIOPP001(DOSSIER)
    Call MAJ_UTIOPP002(DOSSIER)
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIOPP001(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Integer NI
Local Integer NCOUNTOK
Local Integer NCOUNTERROR
Local Char WOBJET(GLONAOB)
Local Char WCHAINE(250)

  IERR = 0
  Call ECR_TRACE("UTIOPP001: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table OPPOR
  #
  If filinfo(filpath("FIL", "OPPOR", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".OPPOR" [OPP]
  #
  If filinfo(filpath("FIL", "OPPORCRM", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".OPPORCRM" [OPPCRM]
  #
  If filinfo(filpath("FIL", "OPPORSTB", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".OPPORSTB" [OSB]
  #
  If filinfo(filpath("FIL", "OPPORSTA", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".OPPORSTA" [OSA]
  #
  If filinfo(filpath("FIL", "OPPORCPP", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".OPPORCPP" [OCP]
  #
  If filinfo(filpath("FIL", "OPPORSBB", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".OPPORSBB" [OBB]
  #
  If filinfo(filpath("FIL", "ATABDIV", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".ATABDIV" [ADI]
  # -------------------------
  If dim([F:OPP]STE) > 0 Then
    # Je mets la modification de ADI ici pour ne faire cette modification qu'une seule fois
    Trbegin [OPP]
    NCOUNT = 0
    NCOUNTERROR = 0
    Call ECR_TRACE("UTIOPP001: Updating ATABDIV(400)", 0) From GESECRAN
    Filter [ADI] Where [F:ADI]NUMTAB = 400 and [F:ADI]N3 <> 1 and [F:ADI]N3 <> 2
    For [ADI]
      NCOUNT += 1
      If [F:ADI]N2 = 3 or [F:ADI]N2 = 5 Then
        [F:ADI]N3 = 2
      Else
        [F:ADI]N3 = 1
      Endif
      Rewrite [ADI]
      If fstat Then
        Call ECR_TRACE("File ATABDIV(400) " - [F:ADI]CODE - "/" - [F:ADI]N3 + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [ADI]
    If NCOUNTERROR = 0 Then
      Call ECR_TRACE("UTIOPP001: ATABDIV(400)" - num$(NCOUNT) - "updated.", 0) From GESECRAN
    Else
      Call ECR_TRACE("UTIOPP001: ATABDIV(400)" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
    Endif
    # -------------------------
    NCOUNT = 0
    NCOUNTERROR = 0
    Call ECR_TRACE("UTIOPP001: Updating ATABDIV(421)", 0) From GESECRAN
    Filter [ADI] Where [F:ADI]NUMTAB = 421 and [F:ADI]N2 <> 1 and [F:ADI]N2 <> 2
    For [ADI]
      NCOUNT += 1
      [F:ADI]N2 = 1
      Rewrite [ADI]
      If fstat Then
        Call ECR_TRACE("File ATABDIV(421) " - [F:ADI]CODE - "/" - [F:ADI]N2 + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [ADI]
    If NCOUNTERROR = 0 Then
      Call ECR_TRACE("UTIOPP001: ATABDIV(421)" - num$(NCOUNT) - "updated.", 0) From GESECRAN
    Else
      Call ECR_TRACE("UTIOPP001: ATABDIV(421)" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
    Endif
    # -------------------------
    NCOUNT = 0
    NCOUNTERROR = 0
    Call ECR_TRACE("UTIOPP001: Updating OPPOR", 0) From GESECRAN
    For [OPP]OPP0
      IUPDATE = 0
      # -----------
      Raz [F:OPPCRM]
      [F:OPPCRM] = [F:OPP]
      # -----------
      Write [OPPCRM]
      If fstat Then
        IERR = 1
        Call ECR_TRACE("File OPPORCRM " - [F:OPP]OPPNUM + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
      # -----------
      For NI = 0 To dim([F:OPP]STE)-1
        # -----------
        If [F:OPP]STE(NI) <> "" Then
          Raz [F:OSB]
          [F:OSB]OPPNUM = [F:OPP]OPPNUM
          [F:OSB]STELIN = 1
          [F:OSB]STE    = [F:OPP]STE(NI)
          [F:OSB]STRDAT = [F:OPP]ENDDAT(NI)
          [F:OSB]ENDDAT = [F:OPP]ENDDAT(NI)
          [F:OSB]DON    = [F:OPP]DON(NI)
          [F:OSB]REN    = [F:OPP]REN(NI)
          #----------
          $WRITE_OSB
          Write [OSB]
          If fstat = 3 Then
            [F:OSB]STELIN += 1
            Goto WRITE_OSB
          Elsif fstat Then
            Call ECR_TRACE("File OPPORSTE(400) " - [F:OPP]OPPNUM - "/" - [F:OPP]STE(NI) - "/" - num$(NI) + ", Error =" - num$(fstat), 1) From GESECRAN
            GOK = 1
            IERR = 1
            NCOUNTERROR += 1
          Endif
        Else
          Break
        Endif
      Next NI
      # -----------
      For NI = 0 To dim([F:OPP]STEX)-1
        If [F:OPP]STEX(NI) <> "" Then
          Raz [F:OSA]
          [F:OSA]OPPNUM  = [F:OPP]OPPNUM
          [F:OSA]STELINX = 1
          [F:OSA]STEX    = [F:OPP]STEX(NI)
          [F:OSA]STRDATX = [F:OPP]ENDDATX(NI)
          [F:OSA]ENDDATX = [F:OPP]ENDDATX(NI)
          [F:OSA]DONX    = [F:OPP]DONX(NI)
          [F:OSA]RENX    = [F:OPP]RENX(NI)
          #----------
          $WRITE_OSA
          Write [OSA]
          If fstat = 3 Then
            [F:OSA]STELIN += 1
            Goto WRITE_OSA
          Elsif fstat Then
            IERR = 1
            Call ECR_TRACE("File OPPORSTE(421) " - [F:OPP]OPPNUM - "/" - [F:OPP]STEX(NI) - "/" - num$(NI) + ", Error =" - num$(fstat), 1) From GESECRAN
            GOK = 1
            IERR = 1
            NCOUNTERROR += 1
          Endif
        Else
          Break
        Endif
      Next NI
      # -----------
      For NI = 0 To dim([F:OPP]CPP)-1
        If [F:OPP]CPP(NI) <> "" Then
          Raz [F:OCP]
          [F:OCP]OPPNUM  = [F:OPP]OPPNUM
          [F:OCP]CPP     = [F:OPP]CPP(NI)
          [F:OCP]CPPAMT  = [F:OPP]CPPAMT(NI)
          [F:OCP]ASE     = [F:OPP]ASE(NI)
          [F:OCP]SHC     = [F:OPP]SHC(NI)
          Write [OCP]
          If fstat Then
            IERR = 1
            Call ECR_TRACE("File OPPORCPP " - [F:OPP]OPPNUM - "/" - [F:OPP]CPP(NI) + ", Error =" - num$(fstat), 1) From GESECRAN
            GOK = 1
            IERR = 1
            NCOUNTERROR += 1
          Endif
        Else
          Break
        Endif
      Next NI
      # -----------
      For NI = 0 To dim([F:OPP]SBBPJT)-1
        If [F:OPP]SBBPJT(NI) <> "" Then
          Raz [F:OBB]
          [F:OBB]OPPNUM  = [F:OPP]OPPNUM
          [F:OBB]SBBPJT  = [F:OPP]SBBPJT(NI)
          Write [OBB]
          If fstat Then
            IERR = 1
            Call ECR_TRACE("File OPPORSBB " - [F:OPP]OPPNUM - "/" - [F:OPP]SBBPJT(NI) + ", Error =" - num$(fstat), 1) From GESECRAN
            GOK = 1
            IERR = 1
            NCOUNTERROR += 1
          Endif
        Else
          Break
        Endif
      Next NI
      # -----------
      NCOUNT += 1
    Next
    If NCOUNTERROR = 0 Then
      Call ECR_TRACE("UTIOPP001: OPPOR" - num$(NCOUNT) - "updated.", 0) From GESECRAN
    Else
      Call ECR_TRACE("UTIOPP001: OPPOR" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
    Endif
    # -----------
    If IERR = 0 Then
      Commit
      Call ECR_TRACE("UTIOPP001 : records processed without error.", 0) From GESECRAN
    Else
      Rollback
      Call ECR_TRACE("UTIOPP001 : records processed with error(s).", 0) From GESECRAN
    Endif
  Endif
End

##########################################################################
Subprog MAJ_UTIOPP002(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Integer NI
Local Integer NCOUNTOK
Local Integer NCOUNTERROR
Local Char WOBJET(GLONAOB)
Local Char WCHAINE(250)

  IERR = 0
  Call ECR_TRACE("UTIOPP002: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table OPPOR
  #
  If filinfo(filpath("FIL", "ATEXTRA", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".ATEXTRA" [AXX]
  #
  If filinfo(filpath("FIL", "PIMPL", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".PIMPL" [PIM]
  #
  If filinfo(filpath("FIL", "OPPOR", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".OPPOR" [OPP]
  Local File =SZAPPLI + ".FACILITY" [FCY]
  # -------------------------
  Trbegin [OPP]
  NCOUNT = 0
  NCOUNTERROR = 0
  Call ECR_TRACE("UTIOPP002: Updating OPPOR", 0) From GESECRAN
  For [OPP]OPP0
    IUPDATE = 0
    # -------------------------
    Read [FCY]FCY0=[F:OPP]SALFCY
    # -------------------------
    # A la base, une affaire ne peut être que CRM
    # -------------------------
    # Initialisation de la table PIMPL
    # On teste ça ici aussi pour permettre de repasser le traitement sans écraser les valeurs de PRP
    Read [PIM]PIM0=[F:OPP]OPPNUM
    If fstat Then
      Raz [F:PIM]
      [F:PIM]PIMNUM    = [F:OPP]OPPNUM
      [F:PIM]OPPNUM    = [F:OPP]OPPNUM
      [F:PIM]FCY       = [F:OPP]SALFCY
      [F:PIM]PIMTYP = 1
      [F:PIM]PIMSTA = G_OUI
      #
      [F:PIM]CPY       = [F:FCY]LEGCPY
      [F:PIM]FINRSPFCY = [F:FCY]FINRSPFCY
      Write [PIM]
      If fstat Then
        IERR = 1
        Call ECR_TRACE("File(Write) PIMPL" - [F:PIM]PIMNUM + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Else
      [F:PIM]OPPNUM    = [F:OPP]OPPNUM
      [F:PIM]FCY       = [F:OPP]SALFCY
      #[F:PIM]PIMTYP   = 1
      #[F:PIM]PIMSTA   = G_OUI
      [F:PIM]UPDUSR    = [F:OPP]UPDUSR
      [F:PIM]UPDDAT    = [F:OPP]UPDDAT
      #
      [F:PIM]CPY       = [F:FCY]LEGCPY
      [F:PIM]FINRSPFCY = [F:FCY]FINRSPFCY
      Rewrite [PIM]
      If fstat Then
        IERR = 1
        Call ECR_TRACE("File(Rewrite) PIMPL" - [F:PIM]PIMNUM + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Endif
    # -------------------------
    # Gestion de la désignation traduisible
    If dim([F:OPP]OPPDES) > 0 Then
      If [F:OPP]OPPDES <> "" Then
        Call MAJTEXTRA([F:OPP]OPPDES, "PIMPL", "PIMDESAXX", [F:OPP]OPPNUM, "") From ATEXTRA
        If GOK < 1 Then
          Call ECR_TRACE("File ATEXTRA PIMPL-PIMDESAXX" - [F:OPP]OPPNUM + ",Error =" - num$(fstat), 1) From GESECRAN
          GOK = 1
          IERR = 1
          Break
        Endif
        IUPDATE = 1
        [F:OPP]OPPDES = ""
      Else
        Call LECTEXTRA(WCHAINE, "PIMPL", "PIMDESAXX", [F:OPP]OPPNUM, "") From ATEXTRA
        If WCHAINE = "" Then
          Call MAJTEXTRA(WCHAINE, "PIMPL", "PIMDESAXX", [F:OPP]OPPNUM, "") From ATEXTRA
        Endif
      Endif
    Endif
    # -------------------------
    # Gestion de la conversion de devise
    If dim([F:OPP]CHGTYP) > 0 Then
      If [F:OPP]CHGTYP < 1 Then
        [F:OPP]CHGTYP = 1
        IUPDATE = 1
      Endif
    Endif
    # -------------------------
    If IUPDATE = 1 Then
      Rewrite [OPP]
      If fstat Then
        IERR = 1
        Call ECR_TRACE("File OPPOR" - [F:OPP]OPPNUM + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
      NCOUNT += 1
    Endif
  Next
  If NCOUNTERROR = 0 Then
    Call ECR_TRACE("UTIOPP002: OPPOR" - num$(NCOUNT) - "updated.", 0) From GESECRAN
  Else
    Call ECR_TRACE("UTIOPP002: OPPOR" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
  Endif
  # -----------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIOPP002 : records processed without error.", 0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIOPP002 : records processed with error(s).", 0) From GESECRAN
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTIOPP001(APPLI)
  Call MAJ_UTIOPP002(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = "X3" Then
    End
  Endif
  Call MAJ_UTIOPP001(APPLI)
  Call MAJ_UTIOPP002(APPLI)
End

