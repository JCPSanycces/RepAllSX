#<AdxTL>@(#)0.0.0.0 $Revision$ Object Management CRMSFS01
# SUBCRMSFS01 - Sales order info for Salesforce CRM - published as classic soap webservice



$ACTION
Case [L]ACTION
  When "OUVRE" : Gosub OUVRE
  When "LIENS" : Gosub SETBOUT
Endcase
Return

$OUVRE
If !clalev([F:SOQ])   : Local File SORDERQ [SOQ] : Endif
If !clalev([F:SOP])   : Local File SORDERP [SOP] : Endif
If !clalev([F:AXXX1]) : Local File ATEXTRA [AXXX1] : Endif
If !clalev([F:AXXX2]) : Local File ATEXTRA [AXXX2] : Endif
Return

$SETBOUT
Gosub LOAD_DATA
Return

$LOAD_DATA
Gosub LOAD_SALFCY_NAME
Gosub LOAD_BPCPYR_NAME
Gosub LOAD_REP_NAME
Gosub LOAD_VACBPR_DES
Gosub LOAD_STOFCY_NAME
Gosub LOAD_BPT_NAME
Gosub LOAD_MDL_DES
Gosub LOAD_INVOICE_ELEMENTS
Gosub LOAD_LINES
Gosub LOAD_LINE_FORMATS

Gosub LOAD_DESORDDAT
Gosub LOAD_DESAPPFLG
Gosub LOAD_DESORDSTA
Gosub LOAD_DESALLSTA
Gosub LOAD_DESHLDSTA
Gosub LOAD_DESCDTSTA
Gosub LOAD_DESDLVSTA
Gosub LOAD_DESINVSTA
Gosub LOAD_BPD_ADDRESS
Gosub LOAD_DESDLVPIO
Gosub LOAD_DESDEMDLVDAT
Gosub LOAD_DESSHIDAT
Gosub LOAD_DESBPCINV

Return

$LOAD_BPCPYR_NAME
Read [F:BPC]BPC0=[F:SOH]BPCPYR
If fstat=[V]CST_AOK
  [M:CRMSFS02]BPCPYRNAM=[F:BPC]BPCNAM
Endif
Affzo [M:CRMSFS02]BPCPYRNAM
Return

$LOAD_REP_NAME
Read [F:REP]REP0=[F:SOH]REP(0)
If fstat=[V]CST_AOK
  [M:CRMSFS02]REPNAM=[F:REP]REPNAM
Endif
Affzo [M:CRMSFS02]REPNAM
Return

$LOAD_VACBPR_DES
Call LECTEXTRA([M:CRMSFS02]VACBPRDES,"TABVACBPR","DESAXX",[F:SOH]VACBPR,"") From ATEXTRA
Affzo [M:CRMSFS02]VACBPRDES
Return

$LOAD_STOFCY_NAME
Read [F:FCY]FCY0=[F:SOH]STOFCY
If fstat=[V]CST_AOK
  [M:CRMSFS03]FCYNAM=[F:FCY]FCYNAM
  Affzo [M:CRMSFS03]FCYNAM
Endif
Return

$LOAD_BPT_NAME
Read [F:BPT]BPT0=[F:SOH]BPTNUM
If fstat=[V]CST_AOK
  [M:CRMSFS03]BPTNAM=[F:BPT]BPTNAM
Endif
Affzo [M:CRMSFS03]BPTNAM
Return

$LOAD_MDL_DES
Call LECTEXTRA([M:CRMSFS03]MDLDES,"TABMODELIV","DESAXX",[F:SOH]MDL,"") From ATEXTRA
Affzo [M:CRMSFS03]MDLDES
Return

$LOAD_SALFCY_NAME
Read [F:FCY]FCY0=[F:SOH]SALFCY
If fstat=[V]CST_AOK
  [M:CRMSFS01]FCYNAM=[F:FCY]FCYNAM
  Affzo [M:CRMSFS01]FCYNAM
Endif
Return

$LOAD_INVOICE_ELEMENTS
Raz [M:CRMSFS04]NBFAC
For I=0 To dim([F:SOH]INVDTA) - 1
    If [F:SOH]INVDTA([L]I) = 0 : Break : Endif
    nolign = [L]I
    Call LECTEXTRA([M:CRMSFS04]DES(nolign),"SFOOTINV","DESAXX",num$([F:SOH]INVDTA([L]I)),"") From ATEXTRA
    [M:CRMSFS04]INVDTAAMT(nolign) = [F:SOH]INVDTAAMT([L]I)
    [M:CRMSFS04]FORMAT(nolign) = func TRTX3FNC.GETFMTREM(1)
Next
If [L]I>0
  [M:CRMSFS04]NBFAC = [L]I
Endif
Affzo [M:CRMSFS04]
Return

$LOAD_LINES
Raz [M:CRMSFS05]NBLIG
If !clalev([F:SOQ]) : Local File SORDERQ [SOQ] : Endif
If !clalev([F:SOP]) : Local File SORDERP [SOP] : Endif

Link [F:SOQ] With [SOP]SOP0=[SOQ]SOHNUM;[SOQ]SOPLIN;[SOQ]SOQSEQ As [LNK1]
& Where [F:SOQ]SOHNUM=[M:CRMSFS01]SOHNUM Order By [F:SOQ]SOPLIN;[F:SOQ]SOQSEQ

Raz nolign
For [LNK1]
  [M:CRMSFS05]ITMREF(nolign) = [F:SOQ]ITMREF
  [M:CRMSFS05]ITMDES(nolign) = [F:SOP]ITMDES
  [M:CRMSFS05]QTY(nolign)    = [F:SOQ]QTY
  [M:CRMSFS05]SAU(nolign)    = [F:SOP]SAU
  Call LECTEXTRA([M:CRMSFS05]DESSAU(nolign),"TABUNIT","DES",[F:SOP]SAU,"") From ATEXTRA
  [M:CRMSFS05]NETPRI(nolign) = [F:SOP]NETPRI
  If nolign<=99                                        # Limit lines to 100 (0 thru 99)
    nolign+=1
  Else
    Break
  Endif

Next

[M:CRMSFS05]NBLIG = nolign
Affzo [M:CRMSFS05]

LogicClose File [F:SOQ],[F:SOP]

Return

$LOAD_LINE_FORMATS
  If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif
  If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif

  Read [F:AMZ]CODE="CRMSFS05";"NETPRI"
  Read [F:ATY]CODTYP = [F:AMZ]CODTYP
  [M:CRMSFS05]NETPRIFMT = "Nv2" + [F:ATY]OPTION + ":" + num$([F:ATY]LNGTYP)

  [M:CRMSFS05]QTYFMT = "Nv2:" + GUNTFMT

Return

$LOAD_DESORDDAT
  Local Char DATEFORMAT(20)
  DATEFORMAT = func CRMSF.GETDATEFORMAT(GACTX.LAN)
  [M:CRMSFS01]DESORDDAT = format$("DZ:"+DATEFORMAT, [F:SOH]ORDDAT)
  Affzo [M:CRMSFS01]DESORDDAT
Return

$LOAD_DESAPPFLG
  [M:CRMSFS02]DESAPPFLG = mess([F:SOH]APPFLG, 280, 1)
  Affzo [M:CRMSFS02]DESAPPFLG
Return

$LOAD_DESORDSTA
  [M:CRMSFS02]DESORDSTA = mess([F:SOH]ORDSTA, 415, 1)
  Affzo [M:CRMSFS02]DESORDSTA
Return

$LOAD_DESALLSTA
  [M:CRMSFS02]DESALLSTA = mess([F:SOH]ALLSTA, 416, 1)
  Affzo [M:CRMSFS02]DESALLSTA
Return

$LOAD_DESHLDSTA
  [M:CRMSFS02]DESHLDSTA = mess([F:SOH]HLDSTA, 491, 1)
  Affzo [M:CRMSFS02]DESHLDSTA
Return

$LOAD_DESCDTSTA
  [M:CRMSFS02]DESCDTSTA = mess([F:SOH]CDTSTA, 419, 1)
  Affzo [M:CRMSFS02]DESCDTSTA
Return

$LOAD_DESDLVSTA
  [M:CRMSFS02]DESDLVSTA = mess([F:SOH]DLVSTA, 417, 1)
  Affzo [M:CRMSFS02]DESDLVSTA
Return

$LOAD_DESINVSTA
  [M:CRMSFS02]DESINVSTA = mess([F:SOH]INVSTA, 418, 1)
  Affzo [M:CRMSFS02]DESINVSTA
Return

$LOAD_BPD_ADDRESS

  Local Char ERRMSG(255)

  [M:CRMSFS02]BPDADDLIG1 = [F:SOH]BPDADDLIG(0)
  [M:CRMSFS02]BPDADDLIG2 = [F:SOH]BPDADDLIG(1)
  [M:CRMSFS02]BPDADDLIG3 = [F:SOH]BPDADDLIG(2)

  Call FORMATADDRESS([M:CRMSFS02]BPDCRY, [M:CRMSFS02]BPDADDLIG1, [M:CRMSFS02]BPDADDLIG2, [M:CRMSFS02]BPDADDLIG3,
&                    [M:CRMSFS02]BPDCTY, [M:CRMSFS02]BPDSAT, [M:CRMSFS02]DESBPDSAT, [M:CRMSFS02]BPDPOSCOD,
&                    [M:CRMSFS02]BPDCRYNAM, ERRMSG) From CRMSF

Return

$LOAD_DESDLVPIO
  [M:CRMSFS03]DESDLVPIO = mess([F:SOH]DLVPIO, 410, 1)
  Affzo [M:CRMSFS03]DESDLVPIO
Return

$LOAD_DESDEMDLVDAT
  Local Char DATEFORMAT(20)
  DATEFORMAT = func CRMSF.GETDATEFORMAT(GACTX.LAN)
  [M:CRMSFS03]DESDEMDLVDAT = format$("DZ:"+DATEFORMAT, [F:SOH]DEMDLVDAT)
  Affzo [M:CRMSFS03]DESDEMDLVDAT
Return

$LOAD_DESSHIDAT
  Local Char DATEFORMAT(20)
  DATEFORMAT = func CRMSF.GETDATEFORMAT(GACTX.LAN)
  [M:CRMSFS03]DESSHIDAT = format$("DZ:"+DATEFORMAT, [F:SOH]SHIDAT)
  Affzo [M:CRMSFS03]DESSHIDAT
Return

$LOAD_DESBPCINV
Read [F:BPC]BPC0=[F:SOH]BPCINV
If fstat=[V]CST_AOK
  [M:CRMSFS02]DESBPCINV=[F:BPC]BPCNAM
Endif
Affzo [M:CRMSFS02]DESBPCINV
Return

