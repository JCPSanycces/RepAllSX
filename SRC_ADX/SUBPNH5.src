#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion du masque PQTYPND
#######################################################################
# SUBPNH5 : Saisie détail ligne retour                   MBT 17/07/01 #
# ------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par le s/p de     #
# saisie du détail d'une ligne retour et ne sert qu'à gérer le        #
# masque écran "PQTYPND [PNH5]".                                      #
#######################################################################


Subprog C_QTYSTU(VALEUR)
#-------------------------------#
# Contrôle quantité à retourner #
#-------------------------------#
Variable Decimal VALEUR
Local Shortint NOL : NOL=nolign-1
If VALEUR>[M:PNH5]QTYSTUAVA(NOL)
  GERR=1 : GMESSAGE=mess(106,194,1)-num$([M:PNH5]QTYSTUAVA(NOL)) : mkstat=1
Elsif [M:PNH5]WQTYSTU-[M:PNH5]QTYSTU(NOL)+VALEUR>[M:PNH5]WMAXQTYSTU
  GERR=1 : GMESSAGE=mess(106,194,1)-num$([M:PNH5]WMAXQTYSTU)     : mkstat=1
Endif
End


Subprog AM_QTYSTU(VALEUR)
#----------------------------------------#
# Après modif de la quantité à retourner #
#----------------------------------------#
Variable Decimal VALEUR
Local Shortint NOL : NOL=nolign-1
If left$([M:PNH5]STA(NOL),1)="A"
  [M:PNH5]WAARQTYSTU-=[M:PNH5]QTYSTU(NOL)
  [M:PNH5]WAARQTYSTU+=VALEUR
Endif
[M:PNH5]WQTYSTU=sum([M:PNH5]QTYSTU(0..[M:PNH5]NBLIG-1))
[M:PNH5]WQTYSTU-=[M:PNH5]QTYSTU(NOL)
[M:PNH5]WQTYSTU+=VALEUR
If [M:PNH5]UOM(NOL)<>[M:PNH5]STU(NOL)
  Call PCAL_QTY(VALEUR,[M:PNH5]STU(NOL),[M:PNH5]QTYUOM(NOL),[M:PNH5]UOM(NOL),
&                      [M:PNH5]ITMREF,[M:PNH1]BPSNUM,1,GBIDD1) From TRTACHQTE1
Else
  [M:PNH5]QTYUOM(NOL)=[M:PNH5]QTYSTU(NOL)
Endif
Affzo [PNH5]WQTYSTU
End
