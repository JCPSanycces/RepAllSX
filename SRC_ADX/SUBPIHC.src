#<AdxTL>@(#)10.0.0.0 $Revision$
#########################################################################
# SUBPIHC : Gestion des factures d'achat                   MBT 15/10/98 #
# --------------------------------------------------------------------- #
# Traitements complémentaires de l'objet "PIH"                          #
# Les traitements sur champ "Call"     se trouvent dans le SUBPIH       #
# Les actions "Gosub" de l'objet "PIH" se trouvent dans le SUBPIHA      #
# Les traitements complémentaires -1-  se trouvent dans le SUBPIHB      #
#########################################################################

#########################################################################
# MAJ_CUMBASTAX_LIG : S/P de mise à jour des cumuls,       MBT 16/10/98 #
#                     bases et montants de taxe à partir                #
#                     des valeurs de la ligne de facture                #
# --------------------------------------------------------------------- #
# Subprog MAJ_CUMBASTAX_LIG(NOL,SENS)                                   #
#   NOL    : indice de la ligne de facture (nolign-1)                   #
#   SENS   : Sens de la mise à jour (+1=Cumul, -1=Soustraction)         #
# (+2=Cumul sans màj Mt pied cde, -2=Soustraction sans màj Mt pied cde) #
#########################################################################
Subprog MAJ_CUMBASTAX_LIG(NOL,SENS)
Value   Shortint NOL
Value   Integer  SENS
#---- Test si ligne existe bien (Avant ligne d'une nouvelle ligne) ----#
If [M:PIH3]TYPORI(NOL)=0  End : Endif
#----- Variables locales -----#
Local   Shortint SVGNOLIGN : SVGNOLIGN=nolign
Local   Shortint SVGNOL    : SVGNOL   =NOL
#-----
Local   Shortint I, J, K, I2, J2, K2, WNBLIG
Local   Integer  STAT
# Issue 101278 - 2018-08-06 by SR : Déclaration MT1
Local   Decimal  MT, WBASE, WDISBASE, WAMTTAX, WDEDTAX, WRND, MT2, WINVCPLAMT, WINVORDAMT, MT1
Local   Decimal  WMNTMAX, WQTEMAX, WQTYSTU, WQTYSTUMAX
Local   Char     WTAX(GLONVAT)
Local   Libelle  WFLAG, WVCRTYP, WTYPORI
Local   Char     WVCRNUM(GLONVCR), WDSPWEU(GLONUOM), WDSPVOU(GLONUOM), WCUR(GLONCUR)
Local   Decimal  WTOTLINQTY, WTOTLINAMT, WTOTLINWEU, WTOTLINVOU
Local   Integer  WINVNBR
Local   Libelle  WPECFLG
# Issue 71937 - 2012-03-27 by SR report CPO
Local   Integer  WRET
# Issue 83026 - 2012-06-29 by MUARN : early discount
Local   Decimal  WBASETVA, WBASESUP
Local   Integer  WVATTYP, WVATCHA
#----- SENS = +2 ou -2, pas de màj des montants venant des pieds de commande -----#
WFLAG=0
If SENS=-2  SENS=-1 : WFLAG=1 : Endif
If SENS=+2  SENS=+1 : WFLAG=1 : Endif
#----- Chargement arrondi devise facture -----#
If [F:TCU]CUR<>[M:PIH1]CUR
  Read [TCU] TCU0=[M:PIH1]CUR
  If !fstat WRND=[F:TCU]CURRND Else WRND=0.01 : Endif
Else
  WRND=[F:TCU]CURRND
Endif
#----------------------------------------------------------------------#
# Mise à jour du nombre de ligne avec quantité ou prix différent       #
# Uniquement pour facture et avoir/retour pour les lignes non diverses #
#----------------------------------------------------------------------#
If ([M:PIH0]PIHTYP=1 | [M:PIH0]PIHTYP=4) & [M:PIH3]TYPORI(NOL)<>5
  If [M:PIH3]PRTFLG(NOL)=1 & [M:PIH3]QTYPUU(NOL)<>[M:PIH3]ORIQTYPUU(NOL)
    If SENS=1 [M:PIH4]QTYLINNBR+=1
         Else [M:PIH4]QTYLINNBR-=1 : Endif
  Endif
  If [M:PIH3]NETPRI(NOL)<>[M:PIH3]ORINETPRI(NOL)
    If SENS=1 [M:PIH4]PRILINNBR+=1
         Else [M:PIH4]PRILINNBR-=1 : Endif
  Endif
Endif
#--------------------------------------------------#
# Réajustement indicateur ligne partielle si avoir #
#--------------------------------------------------#
If [M:PIH0]PIHTYP=3
  # Issue X3-88031 - 2018-04-27 by SR : tester >= à cause des avoir avec qté > qté facture
  #If [M:PIH3]QTYPUU(NOL)=[M:PIH3]ORIQTYPUU(NOL) &
  If [M:PIH3]QTYPUU(NOL)>=[M:PIH3]ORIQTYPUU(NOL) &
&    [M:PIH3]NETPRI(NOL)=[M:PIH3]ORINETPRI(NOL) [M:PIH3]PRTFLG(NOL)=1
Else [M:PIH3]PRTFLG(NOL)=2
  Endif
Endif
#---------------------------------------------------#
# Mise à jour total HT ligne et total des quantités #
#---------------------------------------------------#
If SENS=1
  #----- Cumuls HT si ce n'est pas le composé (produit fini) -----#
  If [M:PIH3]LINTYP(NOL)<>2
    [M:PIH3]CUMLINAMT1+=[M:PIH3]AMTNOTLIN(NOL)
  Endif
  #----- Cumuls qtés, si ce n'est pas un composant service -----#
  If [M:PIH3]LINTYP(NOL)<>3
    [M:PIH4]TOTLINQTY+=[M:PIH3]QTYPUU(NOL)
    #----- Cumuls poids, volume si ce n'est pas service, matière fournie -----#
    If [M:PIH3]LINTYP(NOL)<3
      [M:PIH4]TOTLINWEU+=[M:PIH3]QTYWEU(NOL)
      [M:PIH4]TOTLINVOU+=[M:PIH3]QTYVOU(NOL)
    Endif
  Endif
Else
  #----- Cumuls HT si ce n'est pas le composé (produit fini) -----#
  If [M:PIH3]LINTYP(NOL)<>2
    [M:PIH3]CUMLINAMT1-=[M:PIH3]AMTNOTLIN(NOL)
  Endif
  #----- Cumuls qtés, si ce n'est pas un composant service -----#
  If [M:PIH3]LINTYP(NOL)<>3
    [M:PIH4]TOTLINQTY-=[M:PIH3]QTYPUU(NOL)
    #----- Cumuls poids, volume si ce n'est pas service, matière fournie -----#
    If [M:PIH3]LINTYP(NOL)<3
      [M:PIH4]TOTLINWEU-=[M:PIH3]QTYWEU(NOL)
      [M:PIH4]TOTLINVOU-=[M:PIH3]QTYVOU(NOL)
    Endif
  Endif
Endif
#------------------------------------------------------------#
# Mise à jour montants éléments venant des pieds de commande #
#------------------------------------------------------------#
If [M:PIH3]TYPORI(NOL)<>5 & [M:PIH0]PIHTYP<>2 & !WFLAG
  Gosub LECT_CDE
  #----- Si facture d'une réception directe -----#
  If [M:PIH3]TYPORI(NOL)=2 & [F:POH]POHNUM=""
    WTYPORI   =2
    WVCRTYP   =6
    WVCRNUM   =[F:PTH]PTHNUM
    WCUR      =[F:PTH]CUR
    WINVNBR   =[F:PTH]INVLINCTR
    WDSPWEU   =[F:PTH]DSPWEU
    WDSPVOU   =[F:PTH]DSPVOU
    #-----
    Raz WTOTLINAMT, WTOTLINQTY, WTOTLINWEU, WTOTLINVOU

    #--- TS start
    # Issue 86623 - 2012-12-20 by TS/MUARN : perf picking réception directe
    Local Integer WPOH : WPOH=0
    Filter [PTDB] Where PTHNUM=[F:PTH]PTHNUM & POHNUM<>"" Order By Key PTD0
    Read [PTDB] First
    If !fstat WPOH=1 Endif
    Filter [PTDB]
    If WPOH=0
      WTOTLINAMT+=[F:PTH]TOTLINAMT
      WTOTLINQTY+=[F:PTH]TOTLINQTY
      WTOTLINWEU+=[F:PTH]TOTLINWEU
      WTOTLINVOU+=[F:PTH]TOTLINVOU
    Else
    #--- TS end

      # Issue 88270 - 2013-02-27 by MUARN : Picking optimisation réception des lignes directe et d'autres sur commande
#      For [PTDB] PTD0 Where PTHNUM=[F:PTH]PTHNUM & POHNUM=""
#        WTOTLINAMT+=[F:PTDB]LINAMT
#        WTOTLINQTY+=[F:PTDB]QTYPUU
#        WTOTLINWEU+=[F:PTDB]QTYWEU
#        WTOTLINVOU+=[F:PTDB]QTYVOU
#      Next
      Local Char REQUETE(255)(2)
      REQUETE(0) = "SELECT SUM(LINAMT_0),SUM(QTYPUU_0),SUM(QTYWEU_0),SUM(QTYVOU_0)"
      REQUETE(1)=" from PRECEIPTD WHERE PTHNUM_0='"+[F:PTH]PTHNUM+"' and POHNUM_0 =' ' "
      For (Decimal WLINAMT,Decimal WQTYPUU, Decimal WQTYWEU, Decimal WQTYVOU) From num$(GTYPDBA*2+1) Sql REQUETE As [SPTD]
        WTOTLINAMT=[SPTD]WLINAMT
        WTOTLINQTY=[SPTD]WQTYPUU
        WTOTLINWEU=[SPTD]WQTYWEU
        WTOTLINVOU=[SPTD]WQTYVOU
      Next

    #--- TS start
    Endif
    #--- TS end

  Else
    WTYPORI   =1
    If [F:POH]POHTYP=1  WVCRTYP=3  Else  WVCRTYP=5 : Endif
    WVCRNUM   =[F:POH]POHNUM
    WCUR      =[F:POH]CUR
    WINVNBR   =[F:POH]INVNBR
    WDSPWEU   =[F:POH]DSPWEU
    WDSPVOU   =[F:POH]DSPVOU
    #-----
    WTOTLINAMT=[F:POH]TOTLINAMT
    WTOTLINQTY=[F:POH]TOTLINQTY
    WTOTLINWEU=[F:POH]TOTLINWEU
    WTOTLINVOU=[F:POH]TOTLINVOU
  Endif
  #------------------- Point d'entrée PECINVDTA -------------------#
  # Permet de ne pas prendre en compte les éléments de facturation #
  # de la commande ou de la réception                              #
  #                                                                #
  # [F:PVF]VCRTYP : Type de document concerné                      #
  #             3 = Commande                                       #
  #             5 = Commande ouverte                               #
  #             6 = Réception                                      #
  # [F:PVF]VCRNUM : Numéro du document concerné                    #
  # [F:PVF]INVDTA : Numéro de l'élément en cours de traitement     #
  # WPECFLG : Indicateur de prise en compte des éléments           #
  #       0 = Aucune prise en compte d'élément pour le             #
  #           document [F:PVF]VCRNUM                               #
  #       1 = Pas de prise en compte de l'élément [F:PVF]INVDTA    #
  #       2 = Prise en compte de l'élément [F:PVF]INVDTA           #
  #       3 = Prise en compte de tous les éléments du              #
  #           document [F:PVF]VCRNUM                               #
  #----------------------------------------------------------------#
  WPECFLG=2
  For [PVF] PVF1 Where VCRTYP=WVCRTYP & VCRNUM=WVCRNUM & INVLINFLG<>6 & DISVATFLG<>2
    #----- Si réception directe, prendre le delta entre réception et commande -----#
    If [M:PIH3]TYPORI(NOL)=2 & [F:POH]POHNUM=""
      [F:PVF]INVDTAAMT-=[F:PVF]INVORDAMT
    Endif
    #----- Particularité pour réception -----#
    If WVCRTYP=6 & [F:PVF]DISVATFLG<>2
      [F:PVF]INVORDAMT=[F:PVF]INVDTAAMT
    Endif
    #-----
    If [F:PVF]INVDTA<>0 & !find(WPECFLG,0,3)
      GPOINT="PECINVDTA" : Gosub ENTREE From EXEFNC
    Endif
    #-----
    If [F:PVF]INVDTA<>0 & WPECFLG>1
      If [F:PFI]PFINUM<>[F:PVF]INVDTA
        Read [PFI] PFI0=[F:PVF]INVDTA : If fstat  Raz [F:PFI] : Endif
      Endif
      #----- Recherche si élément présent dans le tableau -----#
      J=find([F:PVF]INVDTA,[M:PIH4]INVDTA(0..[M:PIH1]NBFAC1-1))
      #----- Si pas de montant, on peut récupérer le code taxe de l'élément cde/rcp -----#
      If J<>0 & ([M:PIH4]INVDTAAMT(J-1)=0 | GIMPORT)
&             & !find([F:PVF]INVDTA,[M:PIH4]INVDTA(J..[M:PIH1]NBFAC1-1))
&             & (SENS=-1 | [M:PIH4]INVORDAMT(J-1)=0)
        [M:PIH4]INVDTAVAT(J-1)=[F:PVF]INVDTAVAT
      #----- Autrement il faut que le code taxe corresponde -----#
      Elsif J<>0 & [M:PIH4]INVDTAVAT(J-1)<>[F:PVF]INVDTAVAT
        K=find([F:PVF]INVDTA,[M:PIH4]INVDTA(J..[M:PIH1]NBFAC1-1))
        If K<>0
          J+=K
          If [M:PIH4]INVDTAVAT(J-1)<>[F:PVF]INVDTAVAT
            K=find([F:PVF]INVDTA,[M:PIH4]INVDTA(J..[M:PIH1]NBFAC1-1))
            If K<>0
              J+=K
              If [M:PIH4]INVDTAVAT(J-1)<>[F:PVF]INVDTAVAT
                K=find([F:PVF]INVDTA,[M:PIH4]INVDTA(J..[M:PIH1]NBFAC1-1))
                If K<>0 J+=K Else J=0 : Endif
              Endif
            Else
              J=0
            Endif
          Endif
        Else
          J=0
        Endif
      Endif
      #-----
      If J=0 & [M:PIH1]NBFAC1<dim([M:PIH4]INVDTA)
        #----- Elément non présent dans le tableau, on l'ajoute -----#
        J=[M:PIH1]NBFAC1+1
        [M:PIH1]INVDTA1(J-1)=[F:PVF]INVDTA
        [M:PIH4]INVDTA(J-1) =[F:PVF]INVDTA
        Call LECTEXTRA(GBIDC3,"PFOOTINV","SHOAXX",num$([F:PVF]INVDTA),"") From ATEXTRA
        [M:PIH1]INVDTALIB1(J-1)=GBIDC3
        [M:PIH4]INVDTALIB(J-1) =GBIDC3
        If [F:PFI]VATRUL=2
         #Local Char WVAT(GLONVAT)
         #If !clalev([F:TVC])  Local File TABVAC [TVC] : Endif
         #Call RECHVATFOOT(2,[M:PIH0]BPR,[F:PFI]PFINUM,"PIH4",WVAT) From TRTX3
         #[M:PIH4]INVDTAVAT(J-1)=WVAT
          [M:PIH4]INVDTAVAT(J-1)=[F:PVF]INVDTAVAT : # Récupération code taxe saisi sur cde/rcp
        Endif
        [M:PIH1]INVDTAFLG1(J-1)=1
        [M:PIH4]INVLINFLG(J-1)=[F:PFI]DSPLIN
        [M:PIH4]INVORDFLG(J-1)=[F:PFI]DACORD
        [M:PIH4]CLCORD(J-1)   =[F:PFI]CLCORD
        [M:PIH4]CLCBAS(J-1)   =[F:PFI]CLCBAS
        # Issue 83026 - 2012-06-26 by MUARN : early escompte
        [M:PIH4]DEPFLG(J-1)   =[F:PFI]DEPFLG
        [M:PIH4]INCDCR(J-1)   =[F:PFI]INCDCR
        If dim([M:PIH4]DISVATFLG)>0  [M:PIH4]DISVATFLG(J-1)=[F:PFI]DISVATFLG : Endif
        If [M:PIH0]PIHTYP<3
          [M:PIH1]DEBCDT1(J-1)=[F:PFI]INCDCR
        Else
          [M:PIH1]DEBCDT1(J-1)=3-[F:PFI]INCDCR
        Endif
        [M:PIH4]DEBCDT(J-1)=[M:PIH1]DEBCDT1(J-1)
        If dim([M:PIH4]DSP)>0
          [M:PIH4]DSP(J-1)    =[F:PFI]DSP
        Endif
        #----- Chargement comptes et sections analytiques -----#
        nolign=J : NOL=J-1
        Call CHARG_ACCCCE(NOL,"[M:PIH4]ACC","[M:PIH4]DSP","[M:PIH4]PFICCE",
&                    "PVF",[F:PVF]VCRTYP,[F:PVF]VCRNUM,0,[F:PVF]IND,"") From TRTX3CPT
        GBIDI2=0 : Gosub PREP_INIT_PFICCE From SUBPIHB
        nolign=SVGNOLIGN : NOL=SVGNOL
        #-----
        [M:PIH1]NBFAC1+=1
        If [M:PIH4]NBFAC<>0  [M:PIH4]NBFAC=[M:PIH1]NBFAC1 : Endif
        #-----
      Elsif [M:PIH4]INVORDAMT(J-1)=0 & NOL=0 & SENS=1 & [M:PIH3]LINFLG(NOL)=0
        #----- chargement comptes et sections analytiques si 1ère commande/réception -----#
        nolign=J : NOL=J-1
        Call CHARG_ACCCCE(NOL,"[M:PIH4]ACC","[M:PIH4]DSP","[M:PIH4]PFICCE",
&                    "PVF",[F:PVF]VCRTYP,[F:PVF]VCRNUM,0,[F:PVF]IND,"") From TRTX3CPT
        GBIDI2=0 : Gosub PREP_INIT_PFICCE From SUBPIHB
        nolign=SVGNOLIGN : NOL=SVGNOL
        #-----
      Endif
      #----- C'est une remise sur taxe (Settlement discount) -----#
      If J<>0 & dim([M:PIH4]DISVATFLG)>0 & [M:PIH4]DISVATFLG(J-1)=2
        If WVCRTYP=6
          [M:PIH4]INVORDAMT(J-1)=[F:PVF]INVORDAMT : # Si réception
        Else
          [M:PIH4]INVORDAMT(J-1)=[F:PVF]INVDTAAMT : # Si commande
        Endif
      Elsif J<>0
        Raz MT
        #----- Calcul des valeurs maxi (qté et montant) -----#
        If [M:PIH3]TYPORI(NOL)=1 | [F:POH]POHNUM=""
          Call CAL_QTEMAX(NOL,[M:PIH3]NBLIG,WQTEMAX) From SUBPIHB
          WQTEMAX=min(GPIH_QTEMAX,WTOTLINQTY)
        Else
          Call CAL_QTEPOHMAX(NOL,[M:PIH3]NBLIG,WQTEMAX) From SUBPIHB
        Endif
        WMNTMAX=min(arr(WQTEMAX*[M:PIH3]ORINETPRI(NOL),WRND),WTOTLINAMT)
        #----- C'est un montant (si réception ce n'est que des montants) -----#
        If [F:PVF]AMTCOD=2 | WVCRTYP=6
          #----- Calcul du montant par une règle de trois -----#
          If find([F:PFI]TRFINV,1,2,3,4)
            If [F:PFI]TRFINV=1
              If [M:PIH3]LINTYP(NOL)<>2
                #----- Calcul au prorata des montants -----#
                GBIDD1=[M:PIH3]AMTNOTLIN(NOL)
                If WCUR<>[M:PIH1]CUR : # Si devise différente, conversion
                  Call CONVERT([M:PIH1]CUR,WCUR,GLOCALDEV,[M:PIH1]CURTYP,
&                              [M:PIH0]ACCDAT,[M:PIH3]AMTNOTLIN(NOL),GBIDD1,STAT) From TRTDEV
                Endif
                If WTOTLINAMT>min(GBIDD1,WMNTMAX) & WTOTLINAMT<>0
                  If WMNTMAX>GBIDD1
                    MT=abs([F:PVF]INVDTAAMT)*GBIDD1/WTOTLINAMT
                  Else
                    MT=abs([F:PVF]INVDTAAMT)*WMNTMAX/WTOTLINAMT
                  Endif
                Else
                  MT=abs([F:PVF]INVDTAAMT)
                Endif
              Endif
            Elsif [F:PFI]TRFINV=2
              If [M:PIH3]LINTYP(NOL)<>3
                #----- Calcul au prorata des quantités -----#
                GBIDD1=[M:PIH3]QTYPUU(NOL)
                If WTOTLINQTY>min(GBIDD1,WQTEMAX) & WTOTLINQTY<>0
                  If WQTEMAX>GBIDD1
                    MT=abs([F:PVF]INVDTAAMT)*GBIDD1/WTOTLINQTY
                  Else
                    MT=abs([F:PVF]INVDTAAMT)*WQTEMAX/WTOTLINQTY
                  Endif
                Else
                  MT=abs([F:PVF]INVDTAAMT)
                Endif
              Endif
            # Issue X3-73377 - 2018-01-29 by MUARN : faire que sur le lancé
            #Elsif [M:PIH3]LINTYP(NOL)<>3
            Elsif [M:PIH3]LINTYP(NOL)<3
                #----- Calcul au prorata des poids ou des volumes -----#
               If [F:ITM]ITMREF<>[M:PIH3]ITMREF(NOL)
                 Read [ITM] ITM0=[M:PIH3]ITMREF(NOL) : If fstat  Raz [F:ITM] : Endif
               Endif
               #----- Calcul des quantités en US -----#
               If [M:PIH3]PUU(NOL)=[F:ITM]STU
                 WQTYSTU   =[M:PIH3]QTYPUU(NOL)
                 WQTYSTUMAX=WQTEMAX
               Else
                 Call PCAL_QTY([M:PIH3]QTYPUU(NOL),[M:PIH3]PUU(NOL),WQTYSTU,[F:ITM]STU,
&                       [M:PIH3]ITMREF(NOL),[M:PIH3]BPSNUM(NOL),1,GBIDD1) From TRTACHQTE1
                 Call PCAL_QTY(WQTEMAX,[M:PIH3]PUU(NOL),WQTYSTU,[F:ITM]STU,
&                       [M:PIH3]ITMREF(NOL),[M:PIH3]BPSNUM(NOL),1,GBIDD1) From TRTACHQTE1
               Endif
               #-----
               If [F:PFI]TRFINV=3
                 #----- Calcul au prorata des poids -----#
                 GBIDD1=[F:ITM]ITMWEI*WQTYSTU
                 Call CONVERT_QTY([F:ITM]WEU,WDSPWEU,GBIDD1) From TRTX3
                 GBIDD2=[F:ITM]ITMWEI*WQTYSTUMAX
                 Call CONVERT_QTY([F:ITM]WEU,WDSPWEU,GBIDD2) From TRTX3
                 If WTOTLINWEU>min(GBIDD1,GBIDD2) & WTOTLINWEU<>0
                   If GBIDD2>GBIDD1
                     MT=abs([F:PVF]INVDTAAMT)*GBIDD1/WTOTLINWEU
                   Else
                     MT=abs([F:PVF]INVDTAAMT)*GBIDD2/WTOTLINWEU
                   Endif
                 Else
                   MT=abs([F:PVF]INVDTAAMT)
                 Endif
               Else
                 #----- Calcul au prorata des volumes -----#
                 GBIDD1=[F:ITM]ITMVOU*WQTYSTU
                 Call CONVERT_QTY([F:ITM]VOU,WDSPVOU,GBIDD1) From TRTX3
                 GBIDD2=[F:ITM]ITMVOU*WQTYSTUMAX
                 Call CONVERT_QTY([F:ITM]VOU,WDSPVOU,GBIDD2) From TRTX3
                 If WTOTLINVOU>min(GBIDD1,GBIDD2) & WTOTLINVOU<>0
                   If GBIDD2>GBIDD1
                     MT=abs([F:PVF]INVDTAAMT)*GBIDD1/WTOTLINVOU
                   Else
                     MT=abs([F:PVF]INVDTAAMT)*GBIDD2/WTOTLINVOU
                   Endif
                 Else
                   MT=abs([F:PVF]INVDTAAMT)
                 Endif
               Endif
            Endif
            #----- Ajustement du montant calculé pour écart d'arrondi -----#
            Gosub AJUST_MT
          #----- Prise en compte intégrale du montant sur 1ère facture ou toutes -----#
          Else
            GBIDC3=[M:PIH3]NUMORI(NOL)
            [M:PIH3]NUMORI(NOL)=""
            If !find(WVCRNUM,[M:PIH3]NUMORI(0..[M:PIH3]NBLIG-1)) |
&              !find(WTYPORI,[M:PIH3]TYPORI(0..[M:PIH3]NBLIG-1))
              #----- Recherche si réceptions sur cette commande présentes sur autre ligne -----#
              Raz J2
              Gosub RECH_PTDPOHNUM
              #-----
              If J2=0 & ([F:PFI]TRFINV=6 | ([F:PFI]TRFINV=5 & WINVNBR=0))
                MT=abs([F:PVF]INVDTAAMT)
              Endif
            Endif
            [M:PIH3]NUMORI(NOL)=GBIDC3
          Endif
          #---- Conversion du montant calculé en devise facture si nécessaire ----#
          If WCUR<>[M:PIH1]CUR : # Si devise différente, conversion
            Call CONVERT(WCUR,[M:PIH1]CUR,GLOCALDEV,[M:PIH1]CURTYP,
&                        [M:PIH0]ACCDAT,MT,GBIDD1,STAT) From TRTDEV
            MT=GBIDD1
          Endif
          # Issue X3-101278 - 2018-08-06 by SR :
          #----- Mt pied de commande = Mt élément -----#
          MT1=MT
        #----- C'est un pourcentage ou une action -----#
        Else
          #----- Calcul au prorata des montants -----#
          GBIDD1=[M:PIH3]AMTNOTLIN(NOL)
          If WCUR<>[M:PIH1]CUR : # Si devise différente, conversion
            Call CONVERT([M:PIH1]CUR,WCUR,GLOCALDEV,[M:PIH1]CURTYP,
&                        [M:PIH0]ACCDAT,[M:PIH3]AMTNOTLIN(NOL),GBIDD1,STAT) From TRTDEV
          Endif
          # Issue X3-101278 - 2018-08-06 by SR :
          # pour un élément de type  % : MT1 à la place de MT : calcul de MT1 et MT comme ce qui est fait en réception (SUBPTHD TRT_ELEMENT)
          # quel que soit le type de commande (ouverte ou pas)
#         If WTOTLINAMT>min(GBIDD1,WMNTMAX) & WTOTLINAMT<>0
#            If WMNTMAX>GBIDD1
#              MT=abs([F:PVF]INVORDAMT)*GBIDD1/WTOTLINAMT
#            Else
#              MT=abs([F:PVF]INVORDAMT)*WMNTMAX/WTOTLINAMT
#            Endif
#          Else
#            MT=abs([F:PVF]INVORDAMT)
#          Endif
#          Gosub AJUST_MT
          If WTOTLINAMT>min(GBIDD1,WMNTMAX) & WTOTLINAMT<>0
            If WMNTMAX>GBIDD1
              MT1=abs([F:PVF]INVORDAMT)*GBIDD1/WTOTLINAMT
            Else
              MT1=abs([F:PVF]INVORDAMT)*WMNTMAX/WTOTLINAMT
            Endif
          Else
            MT1=abs([F:PVF]INVORDAMT)
          Endif
          #----- Calcul de MT
          If [F:PFI]CLCBAS=2
            MT=[M:PIH3]AMTNOTLIN(NOL)*[F:PVF]INVDTAAMT/100
          Elsif [F:PFI]CLCBAS=3
            MT=[M:PIH3]AMTATILIN(NOL)*[F:PVF]INVDTAAMT/100
          Elsif [F:PFI]CLCBAS=4
            #----- Si action, calcul au prorata des montants (récupération du MT1) -----#
            MT=MT1
            #-----
          Endif
          # ne  faire que si "Pas  commande ouverte", puisque que montant non calculé
          # sur la commande ouverte donc pas possible de réajuster quoi que ce soit
          If WVCRTYP <>5
            Gosub AJUST_MT
          Endif
          # End issue X3-101278
        Endif
        #-----
        MT=arr(MT,WRND)
        If ([M:PIH0]PIHTYP<3 & [M:PIH4]DEBCDT(J-1)=2) |
&          ([M:PIH0]PIHTYP>2 & [M:PIH4]DEBCDT(J-1)=1) MT=-MT : # Si minoration
           # Issue X3-101278 - 2018-08-06 by SR : Idem pour MT1
           MT1=-MT1 : # Si minoration
        Endif
        # Issue X3-101278 - 2018-08-06 by SR
        #If SENS=1 [M:PIH4]INVORDAMT(J-1)+=MT Else [M:PIH4]INVORDAMT(J-1)-=MT : Endif
        If SENS=1
          If WVCRTYP = 5
            [M:PIH4]INVORDAMT(J-1)+=MT
          Else
            [M:PIH4]INVORDAMT(J-1)+=MT1
          Endif
        Else
          If WVCRTYP = 5
            [M:PIH4]INVORDAMT(J-1)-=MT
          Else
            [M:PIH4]INVORDAMT(J-1)-=MT1
          Endif
        Endif
        # End issue X3-101278
        #----- Alimentation Mt pied de réception -----#
        If [M:PIH3]TYPORI(NOL)=2
          Gosub ALIM_RCPCPLAMT
        Endif
      Endif
    Endif
  Next
  #----- Si origine réception non directe, vérif si éléments ajoutés sur réception -----#
  If [M:PIH3]TYPORI(NOL)=2 & WVCRTYP<>6
    If !clalev([F:PVF2])  Local File PVCRFOOT [PVF2] : Endif
    For [PVF] PVF1 Where VCRTYP=6 & VCRNUM=[M:PIH3]NUMORI(NOL) & INVLINFLG<>6
      If [F:PFI]PFINUM<>[F:PVF]INVDTA
        Read [PFI] PFI0=[F:PVF]INVDTA : If fstat  Raz [F:PFI] : Endif
      Endif
      Filter [PVF2] Where VCRTYP=WVCRTYP & VCRNUM=WVCRNUM & INVDTA=[F:PFI]PFINUM
      Look [PVF2] PVF1 First
      Filter [PVF2]
      If fstat
        J=find([F:PVF]INVDTA,[M:PIH4]INVDTA(0..[M:PIH1]NBFAC1-1))
        #----- Si pas de montant, on peut récupérer le code taxe de l'élément rcp -----#
        If J<>0 & ([M:PIH4]INVDTAAMT(J-1)=0 | GIMPORT)
&               & !find([F:PVF]INVDTA,[M:PIH4]INVDTA(J..[M:PIH1]NBFAC1-1))
&               & (SENS=-1 | [M:PIH4]RCPCPLAMT(J-1)=0)
          [M:PIH4]INVDTAVAT(J-1)=[F:PVF]INVDTAVAT
        #----- Autrement il faut que le code taxe corresponde -----#
        Elsif J<>0 & [M:PIH4]INVDTAVAT(J-1)<>[F:PVF]INVDTAVAT
          K=find([F:PVF]INVDTA,[M:PIH4]INVDTA(J..[M:PIH1]NBFAC1-1))
          If K<>0
            J+=K
            If [M:PIH4]INVDTAVAT(J-1)<>[F:PVF]INVDTAVAT
              K=find([F:PVF]INVDTA,[M:PIH4]INVDTA(J..[M:PIH1]NBFAC1-1))
              If K<>0
                J+=K
                If [M:PIH4]INVDTAVAT(J-1)<>[F:PVF]INVDTAVAT
                  K=find([F:PVF]INVDTA,[M:PIH4]INVDTA(J..[M:PIH1]NBFAC1-1))
                  If K<>0 J+=K Else J=0 : Endif
                Endif
              Else
                J=0
              Endif
            Endif
          Else
            J=0
          Endif
        Endif
        #-----
        If J=0 & [M:PIH1]NBFAC1<dim([M:PIH4]INVDTA)
          #----- Elément non présent dans le tableau, on l'ajoute -----#
          J=[M:PIH1]NBFAC1+1
          [M:PIH1]INVDTA1(J-1)=[F:PVF]INVDTA
          [M:PIH4]INVDTA(J-1) =[F:PVF]INVDTA
          Call LECTEXTRA(GBIDC3,"PFOOTINV","SHOAXX",num$([F:PVF]INVDTA),"") From ATEXTRA
          [M:PIH1]INVDTALIB1(J-1)=GBIDC3
          [M:PIH4]INVDTALIB(J-1) =GBIDC3
          If [F:PFI]VATRUL=2
            [M:PIH4]INVDTAVAT(J-1)=[F:PVF]INVDTAVAT : # Récupération code taxe saisi sur rcp
          Endif
          [M:PIH1]INVDTAFLG1(J-1)=1
          [M:PIH4]INVLINFLG(J-1)=[F:PFI]DSPLIN
          [M:PIH4]INVORDFLG(J-1)=[F:PFI]DACORD
          [M:PIH4]CLCORD(J-1)   =[F:PFI]CLCORD
          [M:PIH4]CLCBAS(J-1)   =[F:PFI]CLCBAS
          # Issue 83026 - 2012-06-26 by MUARN : early escompte
          [M:PIH4]DEPFLG(J-1)   =[F:PFI]DEPFLG
          [M:PIH4]INCDCR(J-1)   =[F:PFI]INCDCR
          If dim([M:PIH4]DISVATFLG)>0  [M:PIH4]DISVATFLG(J-1)=[F:PFI]DISVATFLG : Endif
          If [M:PIH0]PIHTYP<3
            [M:PIH1]DEBCDT1(J-1)=[F:PFI]INCDCR
          Else
            [M:PIH1]DEBCDT1(J-1)=3-[F:PFI]INCDCR
          Endif
          [M:PIH4]DEBCDT(J-1)=[M:PIH1]DEBCDT1(J-1)
          If dim([M:PIH4]DSP)>0
            [M:PIH4]DSP(J-1)    =[F:PFI]DSP
          Endif
          #----- Chargement comptes et sections analytiques -----#
          nolign=J : NOL=J-1
          Call CHARG_ACCCCE(NOL,"[M:PIH4]ACC","[M:PIH4]DSP","[M:PIH4]PFICCE",
&                      "PVF",[F:PVF]VCRTYP,[F:PVF]VCRNUM,0,[F:PVF]IND,"") From TRTX3CPT
          GBIDI2=0 : Gosub PREP_INIT_PFICCE From SUBPIHB
          nolign=SVGNOLIGN : NOL=SVGNOL
          #-----
          [M:PIH1]NBFAC1+=1
          If [M:PIH4]NBFAC<>0  [M:PIH4]NBFAC=[M:PIH1]NBFAC1 : Endif
        Endif
        #----- Alimentation Mt pied de réception -----#
        Gosub ALIM_RCPCPLAMT
        #If SENS=1 [M:PIH4]INVORDAMT(J-1)+=MT Else [M:PIH4]INVORDAMT(J-1)-=MT : Endif
        #-----
      Endif
    Next I
  Endif
  #-----
Endif
#-----------------------------------------------#
# Mise à jour montants éléments venant du tarif #
#-----------------------------------------------#
# If [M:PIH3]TYPORI(NOL)<>5 & [M:PIH0]PIHTYP<>2 : # Extension aux lignes de type divers
  For I=1 To 9
    If evalue("dim([M:PIH3]DISCRGVAL"+num$(I)+"(NOL))")>0
      If GNPRNOTFLG(I-1)=1 & GINVDTALIN(I-1)<>0
        J=find(GINVDTALIN(I-1),[M:PIH4]INVDTA(0..[M:PIH1]NBFAC1-1))
        If J<>0
          #----- C'est un montant -----#
          If GDISCRGTYP(I-1)=1
            If GCLCRUL(I-1)=1 : # Par unité
              MT=arr(evalue("[M:PIH3]DISCRGVAL"+num$(I)+"(NOL)")*[M:PIH3]QTYUOM(NOL),WRND)
            Else              : # Par ligne
              MT=evalue("[M:PIH3]DISCRGVAL"+num$(I)+"(NOL)")
            Endif
          #----- C'est un pourcentage -----#
          Else
            MT=arr([M:PIH3]AMTNOTLIN(NOL)*evalue("[M:PIH3]DISCRGVAL"+num$(I)+"(NOL)")/100,WRND)
          Endif
          If SENS=1 [M:PIH4]INVLINAMT(J-1)+=MT
               Else [M:PIH4]INVLINAMT(J-1)-=MT : Endif
        Endif
      Endif
    Endif
  Next I
# Endif
#----- Si c'est le composé (produit fini), pas de chiffrage -----#
If [M:PIH3]LINTYP(NOL)=2   End : Endif
#-----------------------------------------------#
# Mise à jour des bases et des montants de taxe #
#-----------------------------------------------#
For I=1 To 3+4*(func AFNC.ACTIV("PTX") & dim([M:PIH3]TAXRCP)>0)
  Raz WDISBASE
  Case I
    When 1 : WTAX   =[M:PIH3]VAT1(NOL)       : WBASE  =[M:PIH3]BASTAXLIN1(NOL)
             WAMTTAX=[M:PIH3]AMTTAXLIN1(NOL) : WDEDTAX=[M:PIH3]DEDTAXLIN1(NOL)
             If dim([M:PIH3]DISBASLIN1)>0
               WDISBASE=[M:PIH3]DISBASLIN1(NOL)
             Endif
             # Issue 83026 - 2012-06-29 by MUARN : early discount
             Call LEC_TVT_LEG(GCURLEG,[M:PIH3]VAT1(NOL),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif :#--CPO 71937 TVT
             #If [F:TVT]VAT<>WTAX
             #  Read [TVT] TVT0=WTAX : If fstat Raz [F:TVT] : Endif
             #Endif
             #--/CPO
             WVATTYP = [F:TVT]VATTYP
             WVATCHA = [F:TVT]VATCHA
             If [F:TVT]VATTYP=1
               WBASETVA=[M:PIH3]AMTNOTLIN(NOL)
               WBASESUP=0
             Else
               WBASETVA = 0
               WBASESUP=WAMTTAX
             Endif

    When 2 : WTAX   =[M:PIH3]VAT2(NOL)       : WBASE  =[M:PIH3]AMTNOTLIN(NOL)
             WAMTTAX=[M:PIH3]AMTTAXLIN2(NOL) : WDEDTAX=[M:PIH3]DEDTAXLIN2(NOL)
             # Issue 83026 - 2012-06-29 by MUARN : early discount
             Call LEC_TVT_LEG(GCURLEG,[M:PIH3]VAT2(NOL),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif :#--CPO 71937 TVT
             #If [F:TVT]VAT<>WTAX
             #  Read [TVT] TVT0=WTAX : If fstat Raz [F:TVT] : Endif
             #Endif
             #--/CPO
             WVATTYP = [F:TVT]VATTYP
             WVATCHA = [F:TVT]VATCHA
             If [F:TVT]VATTYP=1
               WBASETVA=[M:PIH3]AMTNOTLIN(NOL)
               WBASESUP=0
             Else
               WBASETVA = 0
               WBASESUP=WAMTTAX
             Endif

    When 3 : WTAX   =[M:PIH3]VAT3(NOL)       : WBASE  =[M:PIH3]AMTNOTLIN(NOL)
             WAMTTAX=[M:PIH3]AMTTAXLIN3(NOL) : WDEDTAX=[M:PIH3]DEDTAXLIN3(NOL)
             # Issue 83026 - 2012-06-29 by MUARN : early discount
             Call LEC_TVT_LEG(GCURLEG,[M:PIH3]VAT3(NOL),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif :#--CPO 71937 TVT
             #If [F:TVT]VAT<>WTAX
             #  Read [TVT] TVT0=WTAX : If fstat Raz [F:TVT] : Endif
             #Endif
             #--/CPO
             WVATTYP = [F:TVT]VATTYP
             WVATCHA = [F:TVT]VATCHA
             If [F:TVT]VATTYP=1
               WBASETVA=[M:PIH3]AMTNOTLIN(NOL)
               WBASESUP=0
             Else
               WBASETVA = 0
               WBASESUP=WAMTTAX
             Endif

    When 4 : WTAX   =[M:PIH3]TAXRCP(NOL)     : WBASE  =[M:PIH3]AMTNOTLIN(NOL)
             WAMTTAX=[M:PIH3]AMTTAXRCP(NOL)  : WDEDTAX=[M:PIH3]DEDTAXRCP(NOL)
             # Issue 83026 - 2012-06-29 by MUARN : early discount
             Call LEC_TVT_LEG(GCURLEG,[M:PIH3]TAXRCP(NOL),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif :#--CPO 71937 TVT
             #If [F:TVT]VAT<>WTAX
             #  Read [TVT] TVT0=WTAX : If fstat Raz [F:TVT] : Endif
             #Endif
             #--/CPO
             WVATTYP = [F:TVT]VATTYP
             WVATCHA = [F:TVT]VATCHA
             If [F:TVT]VATTYP=1
               WBASETVA=[M:PIH3]AMTNOTLIN(NOL)
               WBASESUP=0
             Else
               WBASETVA = 0
               WBASESUP=WAMTTAX
             Endif

    When 5 : WTAX   =[M:PIH3]TAXISS(NOL)     : WBASE  =[M:PIH3]AMTNOTLIN(NOL)
             WAMTTAX=[M:PIH3]AMTTAXISS(NOL)  : WDEDTAX=[M:PIH3]DEDTAXISS(NOL)
             # Issue 83026 - 2012-06-29 by MUARN : early discount
             Call LEC_TVT_LEG(GCURLEG,[M:PIH3]TAXISS(NOL),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif :#--CPO 71937 TVT
             #If [F:TVT]VAT<>WTAX
             #  Read [TVT] TVT0=WTAX : If fstat Raz [F:TVT] : Endif
             #Endif
             #--/CPO
             WVATTYP = [F:TVT]VATTYP
             WVATCHA = [F:TVT]VATCHA
             If [F:TVT]VATTYP=1
               WBASETVA=[M:PIH3]AMTNOTLIN(NOL)
               WBASESUP=0
             Else
               WBASETVA = 0
               WBASESUP=WAMTTAX
             Endif

    When 6 : WTAX   =[M:PIH3]TAXOTH1(NOL)    : WBASE  =[M:PIH3]AMTNOTLIN(NOL)
             WAMTTAX=[M:PIH3]AMTTAXOTH1(NOL) : WDEDTAX=[M:PIH3]DEDTAXOTH1(NOL)
             # Issue 83026 - 2012-06-29 by MUARN : early discount
             Call LEC_TVT_LEG(GCURLEG,[M:PIH3]TAXOTH1(NOL),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif :#--CPO 71937 TVT
             #If [F:TVT]VAT<>WTAX
             #  Read [TVT] TVT0=WTAX : If fstat Raz [F:TVT] : Endif
             #Endif
             #--/CPO
             WVATTYP = [F:TVT]VATTYP
             WVATCHA = [F:TVT]VATCHA
             If [F:TVT]VATTYP=1
               WBASETVA=[M:PIH3]AMTNOTLIN(NOL)
               WBASESUP=0
             Else
               WBASETVA = 0
               WBASESUP=WAMTTAX
             Endif

    When 7 : WTAX   =[M:PIH3]TAXOTH2(NOL)    : WBASE  =[M:PIH3]AMTNOTLIN(NOL)
             WAMTTAX=[M:PIH3]AMTTAXOTH2(NOL) : WDEDTAX=[M:PIH3]DEDTAXOTH2(NOL)
             # Issue 83026 - 2012-06-29 by MUARN : early discount
             Call LEC_TVT_LEG(GCURLEG,[M:PIH3]TAXOTH2(NOL),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif :#--CPO 71937 TVT
             #If [F:TVT]VAT<>WTAX
             #  Read [TVT] TVT0=WTAX : If fstat Raz [F:TVT] : Endif
             #Endif
             #--/CPO
             WVATTYP = [F:TVT]VATTYP
             WVATCHA = [F:TVT]VATCHA
             If [F:TVT]VATTYP=1
               WBASETVA=[M:PIH3]AMTNOTLIN(NOL)
               WBASESUP=0
             Else
               WBASETVA = 0
               WBASESUP=WAMTTAX
             Endif

  Endcase
  If WTAX<>""
    #--CPO 71937 TVT et multi-lég
    #If [F:TVT]VAT<>WTAX
      # Issue 71937 - 2012-03-27 by SR report CPO : comment
      Call LEC_TVT_LEG(GCURLEG,WTAX,WRET) From TRTLECLEG
      If WRET : Raz [F:TVT] : Endif
			#Read [TVT] TVT0=WTAX : If fstat Raz [F:TVT] : Endif
    #Endif
    #--/CPO
    If I>1 & [F:TVT]VATBAS>1
      WBASE=evalue("[M:PIH3]CLCAMT"+num$(I)+"(NOL)") : # Bases spéciales 2-7
    Endif
    #----- Recherche si taxe déja existante -----#
    J=find(WTAX,[M:PIH4]TAX(0..[M:PIH4]NBTAX-1))
    If J<>0 & [M:PIH4]PURTYP(J-1)<>[M:PIH3]LINPURTYP(NOL)
      K=find(WTAX,[M:PIH4]TAX(J..[M:PIH4]NBTAX-1))
      If K<>0
        J+=K
        If [M:PIH4]PURTYP(J-1)<>[M:PIH3]LINPURTYP(NOL)
          K=find(WTAX,[M:PIH4]TAX(J..[M:PIH4]NBTAX-1))
          If K<>0 J+=K Else J=0 : Endif
        Endif
      Else
        J=0
      Endif
    Endif
    #----- Nouvelle taxe -----#
    If J=0
      #----- Le nombre maximum de taxe est dépassé ! ------#
      If [M:PIH4]NBTAX>=dim([M:PIH4]TAX)
        Call ERREUR (WTAX-mess(300,194,1)) From GESECRAN
        Goto MAJ_SUIT1
      Endif
      #-----
      J=[M:PIH4]NBTAX
      [M:PIH4]NBTAX+=1
      [M:PIH4]TAX(J)=WTAX
      Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:PIH4]LIBTAX(J)) From TRTX3TEX
      [M:PIH4]PURTYP(J)=[M:PIH3]LINPURTYP(NOL)
      [M:PIH4]VATTYP(J)=[F:TVT]VATTYP
      # Issue 83026 - 2012-06-29 by MUARN : early discount
      [M:PIH4]VATCHA(J)=[F:TVT]VATCHA
    Else
      J-=1
    Endif
    #----- Mise à jour de la base et des montants de taxe -----#
    If SENS=1
      If dim([M:PIH4]DISBAS)>0  [M:PIH4]DISBAS(J)+=WDISBASE : Endif
      [M:PIH4]BASTAX(J)+=WBASE
      [M:PIH4]AMTTAX(J)+=WAMTTAX
      [M:PIH4]DEDTAX(J)+=WDEDTAX

      # Issue 83026 - 2012-06-29 by MUARN : early discount
      [M:PIH4]VATGRO(J)+=WBASETVA
      # calcul base escomptable uniquement sur facture et facture complémentaire
      If [M:PIH0]PIHTYP<3
        If [M:PIH1]DEP<>""
          If [M:PIH1]DEPTYP = 1 & [M:PIH4]VATGRO(J)<>0
            [M:PIH4]BASDEPNOT(J)+=WBASE-WDISBASE
          Elsif [M:PIH1]DEPTYP = 2
            If WVATTYP=1
              If [M:PIH1]VACTYP<>4
                [M:PIH4]BASDEPATI(J)+=WBASE+WAMTTAX-WDISBASE
              Else
                [M:PIH4]BASDEPATI(J)+=WBASE-WDISBASE
              Endif
            Elsif [M:PIH4]VATCHA(J)=1
              [M:PIH4]BASDEPATI(J)+=WAMTTAX
            Endif
          Endif
        Endif
      Endif

    Else
      If dim([M:PIH4]DISBAS)>0  [M:PIH4]DISBAS(J)-=WDISBASE : Endif
      [M:PIH4]BASTAX(J)-=WBASE
      [M:PIH4]AMTTAX(J)-=WAMTTAX
      [M:PIH4]DEDTAX(J)-=WDEDTAX

      # Issue 83026 - 2012-06-29 by MUARN : early discount
      # calcul base escomptable uniquement sur facture et facture complémentaire
      If [M:PIH0]PIHTYP<3
        If [M:PIH1]DEP<>""
          If [M:PIH1]DEPTYP = 1 & [M:PIH4]VATGRO(J)<>0
            [M:PIH4]BASDEPNOT(J)-=WBASE-WDISBASE
          Elsif [M:PIH1]DEPTYP = 2
            If WVATTYP=1
              If [M:PIH1]VACTYP<>4
                [M:PIH4]BASDEPATI(J)-=WBASE+WAMTTAX-WDISBASE
              Else
                [M:PIH4]BASDEPATI(J)-=WBASE-WDISBASE
              Endif
            Elsif [M:PIH4]VATCHA(J)=1
              [M:PIH4]BASDEPATI(J)-=WAMTTAX
            Endif
          Endif
        Endif
      Endif
      [M:PIH4]VATGRO(J)-=WBASETVA

      #----- Suppression ligne taxe si aucun montant -----#
      If [M:PIH4]BASTAX(J)=0 & [M:PIH4]AMTTAX(J)=0 & [M:PIH4]DEDTAX(J)=0
        If !GIMPORT
          Dela J,1,[M:PIH4]NBTAX-1 [M:PIH4]NBTAX : [M:PIH4]NBTAX-=1
        Endif
      Endif
    Endif
    # Issue 83026 - 2012-07-02 by MUARN : early discount - cas taxe supplémentaire
    If [M:PIH0]PIHTYP<3
      If WBASESUP <>0
        J=find([M:PIH3]VAT1(NOL),[M:PIH4]TAX(0..[M:PIH4]NBTAX-1))
        If J<>0
          J-=1
          If SENS = 1
            [M:PIH4]VATSUPAMT(J)+=WBASESUP
            If (WVATTYP >1 & WVATCHA=2 & [M:PIH1]DEPTYP=1) | (WVATTYP >1 & WVATCHA=2 & [M:PIH1]DEPTYP=2 & [M:PIH1]VACTYP=4)
              [M:PIH4]BASDEPNOT(J)-=WBASESUP
            Endif
          Else
            [M:PIH4]VATSUPAMT(J)-=WBASESUP
            If (WVATTYP >1 & WVATCHA=2 & [M:PIH1]DEPTYP=1) | (WVATTYP >1 & WVATCHA=2 & [M:PIH1]DEPTYP=2 & [M:PIH1]VACTYP=4)
              [M:PIH4]BASDEPNOT(J)+=WBASESUP
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
$MAJ_SUIT1
Next I
# Issue 83026 - 2012-06-29 by MUARN : early discount
[M:PIH4]BASDEP = max(sum([M:PIH4]BASDEPNOT(0..[M:PIH4]NBTAX-1)), sum([M:PIH4]BASDEPATI(0..[M:PIH4]NBTAX-1)))
# Issue 88270 - 2013-02-28 by MUARN : perf inutile
#Affzo [PIH4]BASDEP
End
#--------------------------------------------------------------#
# Lecture fichier entête commande en fonction du type de ligne #
#--------------------------------------------------------------#
#VPO 03/02/11 71185 ajout lecture POHNUMORI ssi TYPORI=2
$LECT_CDE_PTD
If [M:PIH3]TYPORI(NOL)=2 : #réception
  If [F:PTD]PTHNUM<>[M:PIH3]NUMORI(NOL) | [F:PTD]PTDLIN<>[M:PIH3]LINORI(NOL)
    Read [PTD] PTD0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL) : If fstat Raz [F:PTD] : Endif
  Endif
  [M:PIH3]POHNUMORI(NOL)=[F:PTD]POHNUM
  # Issue 107480 - 2015-04-16 by SR : Perf
  [M:PIH3]POHNUMPTD(NOL)     = [F:PTD]POHNUM
  [M:PIH3]POPLINPTD(NOL)     = [F:PTD]POPLIN
  [M:PIH3]POQSEQPTD(NOL)     = [F:PTD]POQSEQ
  [M:PIH3]QTYPUUPTD(NOL)     = [F:PTD]QTYPUU
  [M:PIH3]INVQTYPUUPTD(NOL)  = [F:PTD]INVQTYPUU
  # End issue 107480
Endif
Return

$LECT_CDE
If [M:PIH3]TYPORI(NOL)=1
  If [F:POH]POHNUM<>[M:PIH3]NUMORI(NOL)
    Read [POH] POH0=[M:PIH3]NUMORI(NOL) : If fstat  Raz [F:POH] : Endif
  Endif
Elsif [M:PIH3]TYPORI(NOL)=2
  If [F:PTH]PTHNUM<>[M:PIH3]NUMORI(NOL)
    Read [PTH] PTH0=[M:PIH3]NUMORI(NOL) : If fstat  Raz [F:PTH] : Endif
  Endif
  If [F:PTD]PTHNUM<>[M:PIH3]NUMORI(NOL) | [F:PTD]PTDLIN<>[M:PIH3]LINORI(NOL)
    Read [PTD] PTD0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL) : If fstat Raz [F:PTD] : Endif
  Endif
  If [F:PTD]POHNUM="" Raz [F:POH] : Return : Endif : # Réception sans commande
  If [F:POH]POHNUM<>[F:PTD]POHNUM
    Read [POH] POH0=[F:PTD]POHNUM       : If fstat Raz [F:POH] : Endif
  Endif
Elsif [M:PIH3]TYPORI(NOL)=3
  If [F:PND]PNHNUM<>[M:PIH3]NUMORI(NOL) | [F:PND]PNDLIN<>[M:PIH3]LINORI(NOL)
    Read [PND] PND0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL) : If fstat Raz [F:PND] : Endif
  Endif
  If [F:PND]POHNUM="" Raz [F:POH] : Return : Endif : # Retour sur Rcp sans commande
  If [F:POH]POHNUM<>[F:PND]POHNUM
    Read [POH] POH0=[F:PND]POHNUM       : If fstat Raz [F:POH] : Endif
  Endif
Elsif [M:PIH3]TYPORI(NOL)=4
  If clalev([F:PIDB])<=0 Local File PINVOICED [PIDB] : Endif
  If [F:PIDB]NUM<>[M:PIH3]NUMORI(NOL) | [F:PIDB]PIDLIN<>[M:PIH3]LINORI(NOL)
    Read [PIDB] PID0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL) : If fstat Raz [F:PIDB] : Endif
  Endif
  If [F:PIDB]TYPORI=1
    If [F:POH]POHNUM<>[F:PIDB]NUMORI
      Read [POH] POH0=[F:PIDB]NUMORI : If fstat Raz [F:POH] : Endif
    Endif
  Elsif [F:PIDB]TYPORI=2
    If [F:PTD]PTHNUM<>[F:PIDB]NUMORI | [F:PTD]PTDLIN<>[F:PIDB]LINORI
      Read [PTD] PTD0=[F:PIDB]NUMORI;[F:PIDB]LINORI : If fstat Raz [F:PTD] : Endif
    Endif
    If [F:PTD]POHNUM="" Raz [F:POH]  : Return : Endif : # Réception sans commande
    If [F:POH]POHNUM<>[F:PTD]POHNUM
      Read [POH] POH0=[F:PTD]POHNUM  : If fstat Raz [F:POH] : Endif
    Endif
  Elsif [F:PIDB]TYPORI=3
    If [F:PND]PNHNUM<>[F:PIDB]NUMORI | [F:PND]PNDLIN<>[F:PIDB]LINORI
      Read [PND] PND0=[F:PIDB]NUMORI;[F:PIDB]LINORI : If fstat Raz [F:PND] : Endif
    Endif
    If [F:PND]POHNUM="" Raz [F:POH]  : Return : Endif : # Retour sur Rcp sans commande
    If [F:POH]POHNUM<>[F:PND]POHNUM
      Read [POH] POH0=[F:PND]POHNUM  : If fstat Raz [F:POH] : Endif
    Endif
  Endif
Endif
Return

#########################################################################
# MAJ_CALTAX_LIG : S/P de calcul des bases et des taxes    MBT 16/10/98 #
#                     de la ligne de facture                            #
# --------------------------------------------------------------------- #
# Subprog MAJ_CALTAX_LIG(NOL)                                           #
#   NOL    : indice de la ligne de facture (nolign-1)                   #
#########################################################################
Subprog MAJ_CALTAX_LIG(NOL)
Value   Shortint NOL
#----- Si c'est le composé (produit fini), pas de chiffrage -----#
If [M:PIH3]LINTYP(NOL)=2   End : Endif
#----- Variables locales -----#
Local  Libelle  X : X=3+4*(func AFNC.ACTIV("PTX") & dim([M:PIH3]TAXRCP)>0)
Local  Shortint I
Local  Integer  TYPREG, STAT
Local  Decimal  BASE, MONTANT(1..X), MONTDED(1..X)
Local  Char     TAXE(GLONVAT)(1..X)
Local  Decimal  WCLCAMT(1..X)
Local  Decimal  WRND
# Issue 71937 - 2012-03-27 by SR report CPO
Local  Integer  WRET
#----- Chargement arrondi devise facture -----#
If [F:TCU]CUR<>[M:PIH1]CUR
  Read [TCU] TCU0=[M:PIH1]CUR
  If !fstat WRND=[F:TCU]CURRND Else WRND=0.01 : Endif
Else
  WRND=[F:TCU]CURRND
Endif
#----- Calcul des taxes du montant ligne (marchandise) -----#
Call ALICLCAMT2([M:PIH3]ITMREF(NOL),[M:PIH3]QTYUOM(NOL),NOL,"PIH3",WCLCAMT) From TRTX3
For I=1 To X
  Case I
    When 1 : TAXE(1) = [M:PIH3]VAT1(NOL)
    When 2 : TAXE(2) = [M:PIH3]VAT2(NOL)
    When 3 : TAXE(3) = [M:PIH3]VAT3(NOL)
    When 4 : TAXE(4) = [M:PIH3]TAXRCP(NOL)
    When 5 : TAXE(5) = [M:PIH3]TAXISS(NOL)
    When 6 : TAXE(6) = [M:PIH3]TAXOTH1(NOL)
    When 7 : TAXE(7) = [M:PIH3]TAXOTH2(NOL)
  Endcase
Next I
Gosub RECH_DATE_TAXE From SUBPIHB
Call CALTAXE2(GSOCIETE,GBIDA1,[M:PIH1]VAC,GCUR,X,TAXE,1,[M:PIH3]AMTNOTLIN(NOL),
&             WCLCAMT,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
For I=1 To X
  Case I
    When 1
      If dim([M:PIH3]DISBASLIN1)>0  Raz [M:PIH3]DISBASLIN1(NOL) : Endif
      [M:PIH3]BASTAXLIN1(NOL)=[M:PIH3]AMTNOTLIN(NOL)
      [M:PIH3]CLCAMT1   (NOL)=WCLCAMT(1)
      [M:PIH3]AMTTAXLIN1(NOL)=MONTANT(1)
      [M:PIH3]DEDTAXLIN1(NOL)=MONTDED(1)
    When 2
      If [M:PIH3]VAT2(NOL)=""
        Raz [M:PIH3]CLCAMT2(NOL), [M:PIH3]AMTTAXLIN2(NOL), [M:PIH3]DEDTAXLIN2(NOL)
      Else
        [M:PIH3]CLCAMT2   (NOL)=WCLCAMT(2)
        [M:PIH3]AMTTAXLIN2(NOL)=MONTANT(2)
        [M:PIH3]DEDTAXLIN2(NOL)=MONTDED(2)
        If !clalev([F:TVT])  Local File TABVAT [TVT] : Endif
        # Issue 71937 - 2012-03-27 by SR report CPO : comment
        Call LEC_TVT_LEG(GCURLEG,[M:PIH3]VAT2(NOL),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=[M:PIH3]VAT2(NOL) : If fstat  Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 [M:PIH3]BASTAXLIN1(NOL)+=[M:PIH3]AMTTAXLIN2(NOL) : Endif
      Endif
    When 3
      If [M:PIH3]VAT3(NOL)=""
        Raz [M:PIH3]CLCAMT3(NOL), [M:PIH3]AMTTAXLIN3(NOL), [M:PIH3]DEDTAXLIN3(NOL)
      Else
        [M:PIH3]CLCAMT3   (NOL)=WCLCAMT(3)
        [M:PIH3]AMTTAXLIN3(NOL)=MONTANT(3)
        [M:PIH3]DEDTAXLIN3(NOL)=MONTDED(3)
        If !clalev([F:TVT])  Local File TABVAT [TVT] : Endif
        # Issue 71937 - 2012-03-27 by SR report CPO
        Call LEC_TVT_LEG(GCURLEG,[M:PIH3]VAT3(NOL),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=[M:PIH3]VAT3(NOL) : If fstat  Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 [M:PIH3]BASTAXLIN1(NOL)+=[M:PIH3]AMTTAXLIN3(NOL) : Endif
      Endif
    When 4
      If [M:PIH3]TAXRCP(NOL)=""
        Raz [M:PIH3]CLCAMT4(NOL), [M:PIH3]AMTTAXRCP(NOL), [M:PIH3]DEDTAXRCP(NOL)
      Else
        [M:PIH3]CLCAMT4  (NOL)=WCLCAMT(4)
        [M:PIH3]AMTTAXRCP(NOL)=MONTANT(4)
        [M:PIH3]DEDTAXRCP(NOL)=MONTDED(4)
        If !clalev([F:TVT])  Local File TABVAT [TVT] : Endif
        # Issue 71937 - 2012-03-27 by SR report CPO
        Call LEC_TVT_LEG(GCURLEG,[M:PIH3]TAXRCP(NOL),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=[M:PIH3]TAXRCP(NOL) : If fstat  Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 [M:PIH3]BASTAXLIN1(NOL)+=[M:PIH3]AMTTAXRCP(NOL) : Endif
      Endif
    When 5
      If [M:PIH3]TAXISS(NOL)=""
        Raz [M:PIH3]CLCAMT5(NOL), [M:PIH3]AMTTAXISS(NOL), [M:PIH3]DEDTAXISS(NOL)
      Else
        [M:PIH3]CLCAMT5  (NOL)=WCLCAMT(5)
        [M:PIH3]AMTTAXISS(NOL)=MONTANT(5)
        [M:PIH3]DEDTAXISS(NOL)=MONTDED(5)
        If !clalev([F:TVT])  Local File TABVAT [TVT] : Endif
       # Issue 71937 - 2012-03-27 by SR report CPO
        Call LEC_TVT_LEG(GCURLEG,[M:PIH3]TAXISS(NOL),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=[M:PIH3]TAXISS(NOL) : If fstat  Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 [M:PIH3]BASTAXLIN1(NOL)+=[M:PIH3]AMTTAXISS(NOL) : Endif
      Endif
    When 6
      If [M:PIH3]TAXOTH1(NOL)=""
        Raz [M:PIH3]CLCAMT6(NOL), [M:PIH3]AMTTAXOTH1(NOL), [M:PIH3]DEDTAXOTH1(NOL)
      Else
        [M:PIH3]CLCAMT6   (NOL)=WCLCAMT(6)
        [M:PIH3]AMTTAXOTH1(NOL)=MONTANT(6)
        [M:PIH3]DEDTAXOTH1(NOL)=MONTDED(6)
        If !clalev([F:TVT])  Local File TABVAT [TVT] : Endif
      # Issue 71937 - 2012-03-27 by SR report CPO
        Call LEC_TVT_LEG(GCURLEG,[M:PIH3]TAXOTH1(NOL),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=[M:PIH3]TAXOTH1(NOL) : If fstat  Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 [M:PIH3]BASTAXLIN1(NOL)+=[M:PIH3]AMTTAXOTH1(NOL) : Endif
      Endif
    When 7
      If [M:PIH3]TAXOTH2(NOL)=""
        Raz [M:PIH3]CLCAMT7(NOL), [M:PIH3]AMTTAXOTH2(NOL), [M:PIH3]DEDTAXOTH2(NOL)
      Else
        [M:PIH3]CLCAMT7   (NOL)=WCLCAMT(7)
        [M:PIH3]AMTTAXOTH2(NOL)=MONTANT(7)
        [M:PIH3]DEDTAXOTH2(NOL)=MONTDED(7)
        If !clalev([F:TVT])  Local File TABVAT [TVT] : Endif
        # Issue 71937 - 2012-03-27 by SR report CPO
        Call LEC_TVT_LEG(GCURLEG,[M:PIH3]TAXOTH2(NOL),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=[M:PIH3]TAXOTH2(NOL) : If fstat  Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 [M:PIH3]BASTAXLIN1(NOL)+=[M:PIH3]AMTTAXOTH2(NOL) : Endif
      Endif
  Endcase
Next I
If [M:PIH1]VACTYP<>4
  [M:PIH3]AMTATILIN(NOL)=[M:PIH3]AMTNOTLIN(NOL)
  For I=1 To X
    Case I
      When 1 : [M:PIH3]AMTATILIN(NOL)+=[M:PIH3]AMTTAXLIN1(NOL)
      When 2 : [M:PIH3]AMTATILIN(NOL)+=[M:PIH3]AMTTAXLIN2(NOL)
      When 3 : [M:PIH3]AMTATILIN(NOL)+=[M:PIH3]AMTTAXLIN3(NOL)
      When 4 : [M:PIH3]AMTATILIN(NOL)+=[M:PIH3]AMTTAXRCP(NOL)
      When 5 : [M:PIH3]AMTATILIN(NOL)+=[M:PIH3]AMTTAXISS(NOL)
      When 6 : [M:PIH3]AMTATILIN(NOL)+=[M:PIH3]AMTTAXOTH1(NOL)
      When 7 : [M:PIH3]AMTATILIN(NOL)+=[M:PIH3]AMTTAXOTH2(NOL)
    Endcase
  Next I
Else
  [M:PIH3]AMTATILIN(NOL)=[M:PIH3]AMTNOTLIN(NOL)
Endif
#----- Calcul de la taxe des montants remises/frais de la ligne tarif -----#
For I=1 To 9
  If evalue("dim([M:PIH3]DISCRGVAL"+num$(I)+"(NOL))")>0
    If GNPRNOTFLG(I-1)=1 & GINVDTALIN(I-1)<>0
      If [M:PIH3]INVDTAVAT1(I-1)=""
        Raz TAXE : TAXE(1)=[M:PIH3]VAT1(NOL)
        #----- C'est un montant -----#
        If GDISCRGTYP(I-1)=1
          If GCLCRUL(I-1)=1 : # Par unité
            BASE=arr(evalue("[M:PIH3]DISCRGVAL"+num$(I)+"(NOL)")*[M:PIH3]QTYUOM(NOL),WRND)
          Else              : # Par ligne
            BASE=evalue("[M:PIH3]DISCRGVAL"+num$(I)+"(NOL)")
          Endif
        #----- C'est un pourcentage -----#
        Else
          BASE=arr([M:PIH3]AMTNOTLIN(NOL)*evalue("[M:PIH3]DISCRGVAL"+num$(I)+"(NOL)")/100,WRND)
        Endif
        #-----
        If BASE<>0
          Gosub RECH_DATE_TAXE From SUBPIHB
          Call CALTAXE(GSOCIETE,GBIDA1,[M:PIH1]VAC,GCUR,1,TAXE,1,
&                      BASE,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
          [M:PIH3]BASTAXLIN1(NOL)+=BASE
          [M:PIH3]AMTTAXLIN1(NOL)+=MONTANT(1)
          [M:PIH3]DEDTAXLIN1(NOL)+=MONTDED(1)
        Endif
      Endif
    Endif
  Endif
Next I
#----- Calcul de la taxe des montants remises/frais de pied répartis -----#
For I=1 To 9
  If [M:PIH3]INVDTALIN2(I-1)<>0 & [M:PIH3]INVDTAVAT2(I-1)=""
    Raz TAXE : TAXE(1)=[M:PIH3]VAT1(NOL)
    BASE=evalue("[M:PIH3]DISCRGAMT"+num$(I)+"(NOL)")
    If BASE<>0
      Gosub RECH_DATE_TAXE From SUBPIHB
      Call CALTAXE(GSOCIETE,GBIDA1,[M:PIH1]VAC,GCUR,1,TAXE,1,
&                  BASE,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
      [M:PIH3]BASTAXLIN1(NOL)+=BASE
      [M:PIH3]AMTTAXLIN1(NOL)+=MONTANT(1)
      [M:PIH3]DEDTAXLIN1(NOL)+=MONTDED(1)
    Endif
  Endif
Next I
#----- Positionnement de l'indicateur de calcul en sortie de tableau -----#
[M:PIH3]CLCFLG=2
End

#########################################################################
# DEVERROU_FAC : S/P de deblocage logique de toutes        MBT 22/10/98 #
#                les nouvelles lignes d'une facture                     #
#########################################################################
$DEVERROU_FAC
If [M:PIH0]BETCPY=2 & [M:PIH0]SIHNUM<>""
  If GREP="C"
    SYMBOL2="SIV"+[M:PIH0]SIHNUM
    Unlock=SYMBOL2
  Endif
Else
  If [M:PIH3]NBLIG=0 Return : Endif
  Raz GBIDC3
  For I=0 To [M:PIH3]NBLIG-1
    #----- Pas de déblocage logique si ligne diverse ou ancienne -----#
    If [M:PIH3]TYPORI(I)<5 & [M:PIH3]CREFLG(I)=0
      #----- Déblocage loqique en fonction du type de la ligne -----#
      Case [M:PIH3]TYPORI(I)
        When 1 : SYMBOL2="POH"+[M:PIH3]NUMORI(I)
        When 2 : SYMBOL2="PTH"+[M:PIH3]NUMORI(I)
        When 3 : SYMBOL2="PNH"+[M:PIH3]NUMORI(I)
        When 4 : SYMBOL2="PIH"+[M:PIH3]NUMORI(I)
      Endcase
      If SYMBOL2<>GBIDC3
        Unlock=SYMBOL2 : GBIDC3=SYMBOL2
      Endif
    Endif
  Next I
Endif
Return

########################################################################
# SUPPRESS_TEX : S/P de tous les textes d'une facture     MBT 12/11/98 #
#                entête, pied et lignes                                #
########################################################################
$SUPPRESS_TEX
#----- Suppression texte entête et pied -----#
If GREP="D"
  If left$([M:PIH0]TEX1,3)="PIV"
    Call SUP_CLOB([M:PIH0]TEX1,GBIDI1) From TRTX3TEX
  Endif
  If left$([M:PIH0]TEX2,3)="PIV"
    Call SUP_CLOB([M:PIH0]TEX2,GBIDI1) From TRTX3TEX
  Endif
Endif
#----- Suppression des textes ligne -----#
For I=0 To [M:PIH3]NBLIG-1
  If left$([M:PIH3]LINTEX(I),3)="PID" & [M:PIH3]CREFLG(I)=0
    Call SUP_CLOB([M:PIH3]LINTEX(I),GBIDI1) From TRTX3TEX
  Endif
Next I
#-----
Call RAZ_CLOB From ACLOB
Return

########################################################################
# DEVERROU_LIG : S/P de deblocage logique d'une ligne     MBT 17/10/98 #
# -------------------------------------------------------------------- #
# Subprog DEVERROU_LIG(NOL)                                            #
#   NOL    : indice de la ligne de facture (nolign-1)                  #
########################################################################
Subprog DEVERROU_LIG(NOL)
Value   Shortint NOL
#----- Pas de deblocage logique si ligne diverse ou ancienne -----#
If [M:PIH3]TYPORI(NOL)>4 | [M:PIH3]CREFLG(NOL)<>0 End : Endif
#----- Pas de déblocage logique de ligne si facture inter-société -----#
If [M:PIH0]BETCPY=2 & [M:PIH0]SIHNUM<>""  End : Endif
#----- Variables locales -----#
Local Shortint I, J, TYP
Local Char     NUM(GLONVCR), FICH(3), SYMBOL2(30)
#----- Test si presence du meme numero dans une autre ligne -----#
Raz I : TYP=[M:PIH3]TYPORI(NOL) : NUM=[M:PIH3]NUMORI(NOL)
While I<[M:PIH3]NBLIG
  J=find(NUM,[M:PIH3]NUMORI(I..[M:PIH3]NBLIG-1))
  If J=0 I=[M:PIH3]NBLIG
     Elsif [M:PIH3]TYPORI(I+(J-1))=TYP & [M:PIH3]CREFLG(I+(J-1))=0 & I+(J-1)<>NOL
           I=[M:PIH3]NBLIG
     Else  I+=J : J=0
  Endif
Wend
#----- Deblocage loqique en fonction du type de la ligne -----#
If J=0
  Case TYP
    When 1 : FICH="POH"
    When 2 : FICH="PTH"
    When 3 : FICH="PNH"
    When 4 : FICH="PIH"
  Endcase
  SYMBOL2=FICH+NUM : Unlock=SYMBOL2
Endif
End

########################################################################
# MAJ_QTYCPR_LIG : S/P de calcul qté à désengager et      MBT 16/10/98 #
#                  prix unitaire de revient                            #
# -------------------------------------------------------------------- #
# Subprog MAJ_QTYCPR_LIG(NOL)                                          #
#   NOL    : indice de la ligne de facture (nolign-1)                  #
########################################################################
# on alimente coûts achat et coûts stock pour
# PIHTYP = 1 : Facture
# PIHTYP = 2 : Facture complémentaire si CSTMAJLIN =2
# PIHTYP = 4 : Avoir sur retour
#
# PIHTYP = 3 : Avoir à définir $$$$$$$$$$$$
#
########################################################################
Subprog MAJ_QTYCPR_LIG(NOL)
Value   Shortint NOL

#-----------------------------------#
# Mise à jour quantité à désengager #
#-----------------------------------#
[M:PIH3]QTYBUDLIN(NOL)=[M:PIH3]QTYPUU(NOL)
#------------------------------------------------------------------#
# - Mise à jour prix unitaire de revient sauf pour les factures    #
#   complémentaires ou les avoirs en montant car cette mise à jour #
#   s'effectuera à la validation à partir de la facture d'origine  #
# - Pas de calcul de CPR pour les composants (services et matières #
#   fournies (13/02/09)                                            #
#------------------------------------------------------------------#
Local   Char     WSTU(GLONUOM)
Local   Decimal  WBASE, WMT, WQTYSTU, WCOURS, WRND, WTAXE
Local   Integer  STAT, I, J
# Issue X3-25003 - 2017-07-03 by SR : Avoir sur FCC
Local   Integer  WPIHTYP

# Issue 121905 - 2017-03-08 by MUARN : utililser QTYUOM, QTYPUU peut être nul en fonction de la décimalisation
# Issue 109089 - 2015-07-01 by MUARN : avoir financier pour CPR diviser par quantité de la facture d'origine
#If [M:PIH0]PIHTYP=3 & [M:PIH3]QTYPUU(NOL)=0
If [M:PIH0]PIHTYP=3 & [M:PIH3]QTYUOM(NOL)=0
  #----- Calcul écart unitaire de revient -----#
  Local Decimal  MONTANT, WMT, WCOURS
  If [M:PIH3]TYPORI(NOL)=4
    If clalev([F:PIDB])<=0 Local File PINVOICED [PIDB] : Default File [PID] : Endif
    # Issue X3-39273 - 2017-08-10 by MUARN : gestion erreur
    #Read [PIDB] PID0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL) : If fstat  Raz [F:PIDB] : Return : Endif
    Read [PIDB] PID0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
    If fstat
      Raz [F:PIDB]
      GOK=0 : GERR=1
      GMESSAGE=mess(23,100,1)-"PINVOICED"-[M:PIH3]NUMORI(NOL) - " " - num$([M:PIH3]LINORI(NOL))
      End
    Endif
    # Issue X3-25003 - 2017-07-03 by SR : Avoir sur FCC
    WPIHTYP = [F:PIDB]PIHTYP
    #----- Si facture complémentaire, recherche facture d'origine -----#
    If [F:PIDB]PIHTYP=2 & [F:PIDB]TYPORI=4 & [F:PIDB]QTYSTU=0
      Local Char     WNUMORI(GLONVCR) : WNUMORI=[F:PIDB]NUMORI
      Local Integer  WLINORI          : WLINORI=[F:PIDB]LINORI
      Read [PIDB] PID0=WNUMORI;WLINORI
      # Issue X3-39273 - 2017-08-10 by MUARN : gestion erreur
      #If fstat  Raz [F:PIDB] : Return : Endif
      If fstat
        Raz [F:PIDB]
        GOK=0 : GERR=1
        GMESSAGE=mess(23,100,1)-"PINVOICED"-WNUMORI - " " - num$(WLINORI)
        End
      Endif
    Endif
  Endif
  #-----
  If [M:PIH3]QTYUOM(NOL)<>0
    MONTANT=[M:PIH3]NETPRI(NOL)*[M:PIH3]QTYUOM(NOL) : # Mt ligne avec précision maxi
  Else
    MONTANT=[M:PIH3]AMTNOTLIN(NOL)           : # Mt ligne arrondi suivant devise
  Endif

  #----- Eléments provenant du tarif -----#
  For I=1 To 9
    If GINVDTALIN(I-1)<>0 & GNPRNOTFLG(I-1)=1
      Read [PFI] PFI0=GINVDTALIN(I-1) : If fstat Raz [F:PFI] : Endif
      If [F:PFI]NPRVLT=2
        If [M:PIH3]LINTYP(NOL)=2
          J=NOL+1
          While [M:PIH3]LINTYP(J)>2 & J<[M:PIH3]NBLIG
            #----- C'est un montant -----#
            If GDISCRGTYP(I-1)=1
              If GCLCRUL(I-1)=1 : # Par unité
                MONTANT+=evalue("[M:PIH3]DISCRGVAL"+num$(I)+"(J)")*[M:PIH3]QTYUOM(NOL)
              Else              : # Par ligne
                MONTANT+=evalue("[M:PIH3]DISCRGVAL"+num$(I)+"(J)")
              Endif
            #----- C'est un pourcentage -----#
            Else
              MONTANT+=arr([M:PIH3]AMTNOTLIN(J)*evalue("[M:PIH3]DISCRGVAL"+num$(I)+"(J)")/100,WRND)
            Endif
            J+=1
          Wend
        Else
          #----- C'est un montant -----#
          If GDISCRGTYP(I-1)=1
            If GCLCRUL(I-1)=1 : # Par unité
              MONTANT+=evalue("[M:PIH3]DISCRGVAL"+num$(I)+"(NOL)")*[M:PIH3]QTYUOM(NOL)
            Else              : # Par ligne
              MONTANT+=evalue("[M:PIH3]DISCRGVAL"+num$(I)+"(NOL)")
            Endif
          #----- C'est un pourcentage -----#
          Else
            MONTANT+=arr([M:PIH3]AMTNOTLIN(NOL)*evalue("[M:PIH3]DISCRGVAL"+num$(I)+"(NOL)")/100,WRND)
          Endif
        Endif
      Endif
    Endif
  Next I
  #----- Eléments provenant du pied de facture -----#
  For I=1 To 9
    If [M:PIH3]INVDTALIN2(I-1)<>0
      Read [PFI] PFI0=[M:PIH3]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
      If [F:PFI]NPRVLT=2
        If [M:PIH3]LINTYP(NOL)=2
          J=NOL+1
          While [M:PIH3]LINTYP(J)>2 & J<[M:PIH3]NBLIG
            MONTANT+=evalue("[M:PIH3]DISCRGAMT"+num$(I)+"(J)")
            J+=1
          Wend
        Else
          MONTANT+=evalue("[M:PIH3]DISCRGAMT"+num$(I)+"(NOL)")
        Endif
      Endif
    Endif
  Next I

  If GNODVATSTO = 2
      #----- Taxes non déductible -----#
      WTAXE=[M:PIH3]AMTTAXLIN1(NOL)-[M:PIH3]DEDTAXLIN1(NOL)
      WTAXE+=[M:PIH3]AMTTAXLIN2(NOL)-[M:PIH3]DEDTAXLIN2(NOL)
      WTAXE+=[M:PIH3]AMTTAXLIN3(NOL)-[M:PIH3]DEDTAXLIN3(NOL)
      If dim([M:PIH3]AMTTAXRCP(NOL))>0
        WTAXE+=[M:PIH3]AMTTAXRCP(NOL) -[M:PIH3]DEDTAXRCP(NOL)
        WTAXE+=[M:PIH3]AMTTAXISS(NOL) -[M:PIH3]DEDTAXISS(NOL)
        WTAXE+=[M:PIH3]AMTTAXOTH1(NOL)-[M:PIH3]DEDTAXOTH1(NOL)
        WTAXE+=[M:PIH3]AMTTAXOTH2(NOL)-[M:PIH3]DEDTAXOTH2(NOL)
      Endif
      MONTANT += WTAXE
  Endif
  #----- Conversion si nécessaire du montant en devise société -----#
  If [M:PIH1]CUR<>GLOCALDEV
    WMT=MONTANT
    WCOURS=0
    If [M:PIH1]RAT1<>0  WCOURS=[M:PIH1]RAT2/[M:PIH1]RAT1 : Endif
    Call COURMNT([M:PIH1]CUR,GLOCALDEV,GLOCALDEV,[M:PIH1]CURTYP,[M:PIH1]RATDAT,0,
&              WMT,MONTANT,WCOURS,STAT) From TRTDEV
  Endif
  [M:PIH3]LINAMTCPR(NOL)=arr(MONTANT,10^-GDECPRI)

  #----- Calcul écart unitaire en US -----#
  # Issue X3-25003 - 2017-07-03 by SR : Avoir sur FCC : On prend le montant, sinon, on divise par la qté
  If [M:PIH3]TYPORI(NOL)=4 & WPIHTYP <> 2
    If [F:PIDB]QTYSTU<>0 WMT=arr(MONTANT/[F:PIDB]QTYSTU,10^-8) Else WMT=arr(MONTANT,10^-8) : Endif
  Else
    WMT=arr(MONTANT,10^-8)
  Endif
  #----- Mise à jour du prix de revient -----#
  [M:PIH3]CPR(NOL)=WMT
Else

  #----- Chargement arrondi devise facture -----#
  If [F:TCU]CUR<>[M:PIH1]CUR
    Read [TCU] TCU0=[M:PIH1]CUR
    If !fstat WRND=[F:TCU]CURRND Else WRND=0.01 : Endif
  Else
    WRND=[F:TCU]CURRND
  Endif
  #----- Si ligne de composant, recherche ligne du composé (produit fini) -----#
  If [M:PIH3]LINTYP(NOL)>2
    If NOL>0
      I=NOL-1
      While [M:PIH3]LINTYP(I)>2 & I>0 : I-=1 : Wend
      If [M:PIH3]LINTYP(I)=2
        NOL=I
      Else
        End : # Ligne produit fini non trouvée, pas de calcul de CPR possible !
      Endif
    Else
      End   : # Ligne produit fini non trouvée, pas de calcul de CPR possible !
    Endif
  Endif
  #-----
  Raz WBASE
  If [M:PIH3]LINTYP(NOL)=2
    J=NOL+1
    While [M:PIH3]LINTYP(J)>2 & J<[M:PIH3]NBLIG
      If [M:PIH3]QTYUOM(J)<>0
        WBASE+=[M:PIH3]NETPRI(J)*[M:PIH3]QTYUOM(J)   : # Mt ligne avec précision maxi
      Else
        WBASE+=[M:PIH3]AMTNOTLIN(J)                  : # Mt ligne arrondi suivant devise
      Endif
      J+=1
    Wend
  Else
    # Issue 82067 - 2012-07-09 by MUARN : écart arrondi facture/réception après valo stock
    # si montant ligne modifié manuellement on prend ce montant saisi
    If [M:PIH3]AMTNOTLIN(NOL)<> [M:PIH3]AMTNOTLINCAL(NOL)
      WBASE +=[M:PIH3]AMTNOTLIN(NOL)
    Else # si montant non modifié manuellement le NETPRI est plus précis en nombre de décimal
      If [M:PIH3]QTYUOM(NOL)<>0
        WBASE+=[M:PIH3]NETPRI(NOL)*[M:PIH3]QTYUOM(NOL) : # Mt ligne avec précision maxi
      Else
        WBASE+=[M:PIH3]AMTNOTLIN(NOL)                  : # Mt ligne arrondi suivant devise
      Endif
    Endif
  Endif
  #----- Réajustement Montant net ligne avec coefficient d'approche -----#
  If GPIHCPR=2
    # Issue 70985 - 2012-06-11 by MUARN : landed cost CPRCOE ajouté sur facture
    If [M:PIH3]CPRCOE(NOL) <> 0
      WBASE=WBASE*[M:PIH3]CPRCOE(NOL)
    Endif
  Endif
  #----- Eléments provenant du tarif -----#
  For I=1 To 9
    If GINVDTALIN(I-1)<>0 & GNPRNOTFLG(I-1)=1
      Read [PFI] PFI0=GINVDTALIN(I-1) : If fstat Raz [F:PFI] : Endif
      If [F:PFI]NPRVLT=2
        If [M:PIH3]LINTYP(NOL)=2
          J=NOL+1
          While [M:PIH3]LINTYP(J)>2 & J<[M:PIH3]NBLIG
            #----- C'est un montant -----#
            If GDISCRGTYP(I-1)=1
              If GCLCRUL(I-1)=1 : # Par unité
                WBASE+=evalue("[M:PIH3]DISCRGVAL"+num$(I)+"(J)")*[M:PIH3]QTYUOM(NOL)
              Else              : # Par ligne
                WBASE+=evalue("[M:PIH3]DISCRGVAL"+num$(I)+"(J)")
              Endif
            #----- C'est un pourcentage -----#
            Else
              WBASE+=arr([M:PIH3]AMTNOTLIN(J)*evalue("[M:PIH3]DISCRGVAL"+num$(I)+"(J)")/100,WRND)
            Endif
            J+=1
          Wend
        Else
          #----- C'est un montant -----#
          If GDISCRGTYP(I-1)=1
            If GCLCRUL(I-1)=1 : # Par unité
              WBASE+=evalue("[M:PIH3]DISCRGVAL"+num$(I)+"(NOL)")*[M:PIH3]QTYUOM(NOL)
            Else              : # Par ligne
              WBASE+=evalue("[M:PIH3]DISCRGVAL"+num$(I)+"(NOL)")
            Endif
          #----- C'est un pourcentage -----#
          Else
            WBASE+=arr([M:PIH3]AMTNOTLIN(NOL)*evalue("[M:PIH3]DISCRGVAL"+num$(I)+"(NOL)")/100,WRND)
          Endif
        Endif
      Endif
    Endif
  Next I
  #----- Eléments provenant di pied de facture -----#
  For I=1 To 9
    If [M:PIH3]INVDTALIN2(I-1)<>0
      Read [PFI] PFI0=[M:PIH3]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
      If [F:PFI]NPRVLT=2
        If [M:PIH3]LINTYP(NOL)=2
          J=NOL+1
          While [M:PIH3]LINTYP(J)>2 & J<[M:PIH3]NBLIG
            WBASE+=evalue("[M:PIH3]DISCRGAMT"+num$(I)+"(J)")
            J+=1
          Wend
        Else
          WBASE+=evalue("[M:PIH3]DISCRGAMT"+num$(I)+"(NOL)")
        Endif
      Endif
    Endif
  Next I

  # Issue 84130 - 2012-12-20 by MAE : landed cost
  If GNODVATSTO = 2
      #----- Taxes non déductible -----#
      WTAXE+=[M:PIH3]AMTTAXLIN1(NOL)-[M:PIH3]DEDTAXLIN1(NOL)
      WTAXE+=[M:PIH3]AMTTAXLIN2(NOL)-[M:PIH3]DEDTAXLIN2(NOL)
      WTAXE+=[M:PIH3]AMTTAXLIN3(NOL)-[M:PIH3]DEDTAXLIN3(NOL)
      If dim([M:PIH3]AMTTAXRCP(NOL))>0
        WTAXE+=[M:PIH3]AMTTAXRCP(NOL) -[M:PIH3]DEDTAXRCP(NOL)
        WTAXE+=[M:PIH3]AMTTAXISS(NOL) -[M:PIH3]DEDTAXISS(NOL)
        WTAXE+=[M:PIH3]AMTTAXOTH1(NOL)-[M:PIH3]DEDTAXOTH1(NOL)
        WTAXE+=[M:PIH3]AMTTAXOTH2(NOL)-[M:PIH3]DEDTAXOTH2(NOL)
      Endif
      # Issue 114006 - 2016-02-04 by MUARN : ne pas tenir compte de la quantité
      WBASE += WTAXE
  Endif

  #----- Conversion si nécessaire du montant en devise société -----#
  If [M:PIH1]CUR<>GLOCALDEV
    WMT=WBASE
    WCOURS=0
    If [M:PIH1]RAT1<>0  WCOURS=[M:PIH1]RAT2/[M:PIH1]RAT1 : Endif
    Call COURMNT([M:PIH1]CUR,GLOCALDEV,GLOCALDEV,[M:PIH1]CURTYP,[M:PIH1]RATDAT,0,
&              WMT,WBASE,WCOURS,STAT) From TRTDEV
  Endif
  #----- Calcul du prix unitaire de revient en US -----#
  If [F:ITM]ITMREF<>[M:PIH3]ITMREF(NOL)
    Read [ITM] ITM0=[M:PIH3]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
  Endif
  If [F:ITM]STU="" WSTU=[M:PIH3]PUU(NOL) Else WSTU=[F:ITM]STU : Endif
  If [M:PIH3]UOM(NOL)=WSTU
    WQTYSTU=[M:PIH3]QTYUOM(NOL)
  Else
    Call PCAL_QTY([M:PIH3]QTYPUU(NOL),[M:PIH3]PUU(NOL),WQTYSTU,WSTU,
&               [M:PIH3]ITMREF(NOL),[M:PIH3]BPSNUM(NOL),1,GBIDD1) From TRTACHQTE1
  Endif

  # Issue 70985 - 2012-06-11 by MUARN : landed cost
  If GPIHCPR=2
    WBASE+=[M:PIH3]CPRAMT(NOL)*[M:PIH3]QTYPUU(NOL)
  Endif

  [M:PIH3]LINAMTCPR(NOL)=WBASE

  # Issue 84130 - 2013-03-06 by MUARN : tenir compte des factures complémentaires
  # dans ce cas le calcul du CPR est fait ici et non dans CHARGLIGNE de SUBPIHA
  If [M:PIH0]PIHTYP<>2
   If WQTYSTU<>0
      [M:PIH3]CPR(NOL)=arr(WBASE/WQTYSTU,10^-8)
   Else
      [M:PIH3]CPR(NOL)=arr(WBASE,10^-8)
   Endif
  Else # gestion des factures complémentaires
      [M:PIH3]CPR(NOL)=arr(WBASE,10^-8)
  Endif

  # Issue 84130 - 2013-02-14 by MUARN : Landed cost - Si structure de cout
  If [M:PIH3]STCNUM(NOL) <> ""
    [M:PIH3]LINAMTCPR(NOL) += [M:PIH3]FCSCPR(NOL)
    # Issue 112216 - 2015-10-28 by MUARN : Contrôle qty 0
    If [M:PIH3]QTYSTU(NOL) <> 0
      [M:PIH3]CPR(NOL)        = [M:PIH3]LINAMTCPR(NOL) / [M:PIH3]QTYSTU(NOL)
    Else
      [M:PIH3]CPR(NOL)        = [M:PIH3]LINAMTCPR(NOL)
    Endif
    [M:PIH3]CPR(NOL)        = arr([M:PIH3]CPR(NOL),10^-GDECPRI)
  Endif
  [M:PIH3]LINAMTCPR(NOL)= arr([M:PIH3]LINAMTCPR(NOL),10^-GDECPRI)
Endif

# Issue 84129 - 2012-10-03 by MUARN : calcul cout achat et cout achat unitaire
Call MAJ_CSTPUR_LIG("PIH3",NOL,[M:PIH1]RATDAT,[M:PIH1]CUR, [M:PIH1]CURTYP) From STCCLC

# Issue 70985 - 2012-06-11 by MUARN : landed cost
If !GIMPORT & !GPIH_PICK
  Affzo [M:PIH3]CPR(NOL), LINAMTCPR(NOL), CSTPUR(NOL) ,LINCSTPUR(NOL)
Endif

# Issue 120672 - 2017-02-02 by MUARN : SST le CPR est stocké sur le lancé
[M:PIH3]UPDFLG(NOL)=1

End

########################################################################
# MAJ_MVS_INVDTA : S/P de mise à jour                     MBT 21/10/98 #
#                - BPSUPPMVT  [MVS] Mvts fournisseur facturant         #
#                     INVAMT    : Mt facturé non comptabilisé          #
#                - LASTSUPMVT [LSM] Derniers mvts fournisseurs         #
#                     MVTDAT    : Date dernière facture/avoir          #
#                     VCRNUM    : Numéro facture/avoir                 #
#                     AMT       : Montant TTC facture/avoir            #
#                - PVCRFOOT   [PVF] Eléments de pied de commande       #
#                     INVCPLAMT : Mt facturé élément facturation       #
# -------------------------------------------------------------------- #
# Subprog MAJ_MVS_INVDTA (SENS,ILIG)                                   #
#   SENS   : Sens de la mise à jour (+1=Cumul, -1=Soustraction)        #
#   ILIG   : Indicateur origine valeurs ligne                          #
#            0 = A partir de la classe [M:PIH3]                        #
#            1 = A partir des lignes relues [F:PIDB]                   #
########################################################################
Subprog MAJ_MVS_INVDTA (SENS,ILIG)
Value   Integer   SENS
Value   Integer   ILIG
#----- Variables locales -----#
Local   Integer   STAT
Local   Decimal   MNT, WINVAMT, WAMTATI
Local   Integer   WIFFTYP
Local   Libelle   WVCRTYP
Local   Integer   WIND
#-------------------------------------------------------------------#
# Mise à jour mt facturé non comptabilisé & dernier mvt fournisseur #
#-------------------------------------------------------------------#
If ILIG=1
  WAMTATI=[F:PIV]CLCLINAMT
  For [PVF] PVF0 Where VCRNUM=[F:PIH]NUM & VCRTYP=8
    WAMTATI+=[F:PVF]INVORDAMT
    WAMTATI+=[F:PVF]INVLINAMT
    If [F:PVF]INVORDAMT=0 & [F:PVF]INVLINFLG<6 & [F:PVF]INVORDFLG=1
      WAMTATI+=[F:PVF]INVDTAAMT
    Endif
    If dim([F:PVF]DISVATFLG)>0 & [F:PVF]DISVATFLG=2
      WAMTATI-=[F:PVF]INVORDAMT
    Endif
  Next
  If [F:PIH]CEEFLG<>2
    For [PVV] PVV0 Where VCRNUM=[F:PIH]NUM & VCRTYP=8
      WAMTATI+=[F:PVV]AMTTAX
    Next
  Endif
Else
  WAMTATI=sum([M:PIH4]INVORDAMT)+sum([M:PIH4]INVLINAMT)+[M:PIH4]CLCLINAMT
  If [M:PIH1]VACTYP<>4  WAMTATI+=sum([M:PIH4]AMTTAX) : Endif
  If [M:PIH1]NBFAC1<>0
    Local Shortint WI
    For WI=0 To [M:PIH1]NBFAC1-1
      If [M:PIH4]INVORDAMT(WI)=0 & [M:PIH4]INVLINFLG(WI)<6 & [M:PIH4]INVORDFLG(WI)=1
        WAMTATI+=[M:PIH4]INVDTAAMT(WI)
      Endif
      If dim([M:PIH4]DISVATFLG)>0 & [M:PIH4]DISVATFLG(WI)=2
        WAMTATI-=[M:PIH4]INVORDAMT(WI)
      Endif
    Next WI
  Endif
Endif
WINVAMT=WAMTATI*SENS*(3-(2*[F:PIH]INVTYP))
#WINVAMT=[F:PIH]AMTATI*SENS*(3-(2*[F:PIH]INVTYP))
WIFFTYP=[F:PIH]INVTYP+5
Call MAJENC_BPS([F:PIH]BPR,WIFFTYP,[F:PIH]FCY,[F:PIH]CUR,[F:PIH]CURTYP,[F:PIH]ACCDAT,
&               [F:PIH]NUM,0,WINVAMT,[F:PIH]AMTATI) From TRTBPMVT
If [F:PIH]STA<>3
  #------------------------------------------------------------------------#
  # Mise à jour du mt facturé des éléments de facturation sur l'entête cde #
  #                uniquement si facture NON validée !                     #
  #------------------------------------------------------------------------#
  If [F:PIV]LINNBR=0 End : Endif
  Local   Shortint  I, J, K, NOL, TYPORI
  Local   Integer   LINORI
  Local   Decimal   WORDAMT(max(func AFNC.ACTIV("PFI"),20)), DIFMNT
  Local   Char      NUMORI(GLONVCR), NUMERO(GLONVCR), WNUMERO(GLONVCR)
  Local   Char      SYMBOL2(30), CLEFIC(33)
  #----- Chargement des montants facturés dans une variable dimensionnée -----#
  Raz I
  For [PVF] PVF1 Where VCRTYP=8 & VCRNUM=[F:PIH]NUM
    WORDAMT(I)=[F:PVF]INVORDAMT
    If WORDAMT(I)<0 WORDAMT(I)=-WORDAMT(I) : Endif
    I+=1
  Next
  #----- Mise à jour a partir du masque écran -----#
  If ILIG=0
    If [M:PIH3]NBLIG=0 End : Endif
    For NOL=0 To [M:PIH3]NBLIG-1
        TYPORI=[M:PIH3]TYPORI(NOL)
        NUMORI=[M:PIH3]NUMORI(NOL)
        LINORI=[M:PIH3]LINORI(NOL)
        Gosub MAJ_INVCPLAMT From SUBPIHC
        If GOK<1 Break : Endif
    Next NOL
  #----- Mise à jour a partir du fichier des lignes relues -----#
  Else
    If clalev([F:PIDB])<=0 Local File PINVOICED [PIDB] : Endif
    For [PIDB] PID0 Where NUM=[F:PIH]NUM
        TYPORI=[F:PIDB]TYPORI
        NUMORI=[F:PIDB]NUMORI
        LINORI=[F:PIDB]LINORI
        Gosub MAJ_INVCPLAMT From SUBPIHC
        If GOK<1 Break : Endif
    Next
  Endif
  #----- Si surfacturation mettre le dépassement sur la dernière commande -----#
  If GOK=1 & WNUMERO<>"" & sigma(I=0,max(func AFNC.ACTIV("PFI"),20)-1,WORDAMT(I)<>0)
    Gosub MAJ_EXTRA_INVCPLAMT
  Endif
  #-----
  If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Endif
End
#------------------------------------------------------------------------#
# Mise à jour surfacturation de l'élément de facturation entête commande #
#------------------------------------------------------------------------#
$MAJ_EXTRA_INVCPLAMT
#----- Si entête commande bloquée logiquement --> Abandon -----#
CLEFIC=WNUMERO : SYMBOL2="POH"+WNUMERO : Lock=SYMBOL2
If fstat
  GMESAGE="$PORDER"-CLEFIC-mess(10,100,1) : GERR=1 : GOK=0 : Raz SYMBOL2 : Return
Endif
#----- Lecture entête commande -----#
Read [POH] POH0=WNUMERO
If GIMPORT & fstat  Return : Endif
If fstat  GOK=0 : Call RSTA("POH",CLEFIC) From GLOCK : Return : Endif
If [F:POH]POHTYP=1  WVCRTYP=3  Else  WVCRTYP=5 : Endif
#----- Boucle de lecture des éléments de facturation pied de commande -----#
For [PVF] PVF1 Where VCRTYP=WVCRTYP & VCRNUM=[F:POH]POHNUM
  If [F:PVF]INVDTA<>0
    #----- Recherche si élément présent dans le tableau -----#
    J=find([F:PVF]INVDTA,[M:PIH4]INVDTA(0..[M:PIH1]NBFAC1-1))
    If J<>0 & [M:PIH4]INVDTAVAT(J-1)<>[F:PVF]INVDTAVAT
      K=find([F:PVF]INVDTA,[M:PIH4]INVDTA(J..[M:PIH1]NBFAC1-1))
      If K<>0
        J+=K
        If [M:PIH4]INVDTAVAT(J-1)<>[F:PVF]INVDTAVAT
          K=find([F:PVF]INVDTA,[M:PIH4]INVDTA(J..[M:PIH1]NBFAC1-1))
          If K<>0
            J+=K
            If [M:PIH4]INVDTAVAT(J-1)<>[F:PVF]INVDTAVAT
              K=find([F:PVF]INVDTA,[M:PIH4]INVDTA(J..[M:PIH1]NBFAC1-1))
              If K<>0 J+=K Else J=0 : Endif
            Endif
          Else
            J=0
          Endif
        Endif
      Else
        J=0
      Endif
    Endif
    #-----
    If J<>0
      If WORDAMT(J-1)<>0
        #----- Conversion du montant en devise commande -----#
        Call CONVERT([F:PIH]CUR,[F:POH]CUR,GLOCALDEV,[F:PIH]CURTYP,
&                    [F:PIH]ACCDAT,WORDAMT(J-1),MNT,STAT) From TRTDEV
        MNT=MNT*SENS
        WIND=[F:PVF]IND
        Update [PVF] Where VCRTYP=WVCRTYP & VCRNUM=[F:POH]POHNUM & IND=WIND
&                    With  INVCPLAMT+=MNT*(3-(2*[F:PIH]INVTYP))
        If fstat  GOK=0 : Call FSTA("PVF") From GLOCK : Break : Endif
        [F:PVF]INVCPLAMT+=MNT*(3-(2*[F:PIH]INVTYP))
        Raz WORDAMT(J-1)
      Endif
    Endif
  Endif
Next
#-----
Unlock=SYMBOL2 : Raz SYMBOL2
Return
#-----------------------------------------------------------------------#
# Mise à jour du Mt facturé de l'élément de facturation entête commande #
#-----------------------------------------------------------------------#
$MAJ_INVCPLAMT
If TYPORI<>5 & [F:PIH]PIHTYP<>2
  Gosub RECH_NUMCDE From SUBPIHC
  If NUMERO<>"" & NUMERO<>WNUMERO
    #----- Si entête commande bloquée logiquement --> Abandon -----#
    CLEFIC=NUMERO : SYMBOL2="POH"+NUMERO : Lock=SYMBOL2
    If fstat GMESSAGE="$PORDER"-CLEFIC-mess(10,100,1) : GERR=1
             GOK=0 : Raz SYMBOL2 : Return : Endif
    #----- Lecture entête commande -----#
    Read [POH] POH0=NUMERO
    If GIMPORT & fstat Return : Endif
    If fstat  GOK=0 : Call RSTA("POH",CLEFIC) From GLOCK : Return : Endif
    If [F:POH]POHTYP=1  WVCRTYP=3  Else  WVCRTYP=5 : Endif
    #----- Boucle de lecture des éléments de facturation pied de commande -----#
    For [PVF] PVF1 Where VCRTYP=WVCRTYP & VCRNUM=[F:POH]POHNUM
      If [F:PVF]INVDTA<>0
        #----- Recherche si élément présent dans le tableau -----#
        J=find([F:PVF]INVDTA,[M:PIH4]INVDTA(0..[M:PIH1]NBFAC1-1))
        If J<>0 & [M:PIH4]INVDTAVAT(J-1)<>[F:PVF]INVDTAVAT
          K=find([F:PVF]INVDTA,[M:PIH4]INVDTA(J..[M:PIH1]NBFAC1-1))
          If K<>0
            J+=K
            If [M:PIH4]INVDTAVAT(J-1)<>[F:PVF]INVDTAVAT
              K=find([F:PVF]INVDTA,[M:PIH4]INVDTA(J..[M:PIH1]NBFAC1-1))
              If K<>0
                J+=K
                If [M:PIH4]INVDTAVAT(J-1)<>[F:PVF]INVDTAVAT
                  K=find([F:PVF]INVDTA,[M:PIH4]INVDTA(J..[M:PIH1]NBFAC1-1))
                  If K<>0 J+=K Else J=0 : Endif
                Endif
              Else
                J=0
              Endif
            Endif
          Else
            J=0
          Endif
        Endif
        #-----
        If J<>0
          If WORDAMT(J-1)<>0
            #----- Conversion du montant en devise commande -----#
            Call CONVERT([F:PIH]CUR,[F:POH]CUR,GLOCALDEV,[F:PIH]CURTYP,
&                        [F:PIH]ACCDAT,WORDAMT(J-1),MNT,STAT) From TRTDEV
            Raz DIFMNT
            If [F:PVF]AMTCOD=1 : # C'est un pourcentage
              If (SENS=1 & [F:PIH]PIHTYP>2) | (SENS=-1 & [F:PIH]PIHTYP<3)
                If MNT>[F:PVF]INVCPLAMT
                   MNT=[F:PVF]INVCPLAMT
                   #----- Conversion du Mt a deduire en devise facture -----#
                   Call CONVERT([F:POH]CUR,[F:PIH]CUR,GLOCALDEV,[F:PIH]CURTYP,
&                               [F:PIH]ACCDAT,MNT,DIFMNT,STAT) From TRTDEV
                   WORDAMT(J-1)-=DIFMNT
                Else
                  Raz WORDAMT(J-1)
                Endif
              Else
                Raz WORDAMT(J-1)
              Endif
            Else                  : # C'est un montant
              If (SENS=1 & [F:PIH]PIHTYP<3) | (SENS=-1 & [F:PIH]PIHTYP>2)
                If MNT>[F:PVF]INVDTAAMT-[F:PVF]INVCPLAMT
                   DIFMNT=MNT-[F:PVF]INVDTAAMT-[F:PVF]INVCPLAMT
                   MNT=[F:PVF]INVDTAAMT-[F:PVF]INVCPLAMT
                Endif
              Else
                If MNT>[F:PVF]INVCPLAMT
                   DIFMNT=MNT-[F:PVF]INVCPLAMT
                   MNT=[F:PVF]INVCPLAMT
                Endif
              Endif
              If DIFMNT<>0
                #----- Conversion du Mt a déduire en devise facture -----#
                Call CONVERT([F:POH]CUR,[F:PIH]CUR,GLOCALDEV,[F:PIH]CURTYP,
&                            [F:PIH]ACCDAT,MNT,DIFMNT,STAT) From TRTDEV
                WORDAMT(J-1)-=DIFMNT
              Else
                Raz WORDAMT(J-1)
              Endif
            Endif
            MNT=MNT*SENS
            WIND=[F:PVF]IND
            Update [PVF] Where VCRTYP=WVCRTYP & VCRNUM=[F:POH]POHNUM & IND=WIND
&                    With  INVCPLAMT+=MNT*(3-(2*[F:PIH]INVTYP))
            If fstat  GOK=0 : Call FSTA("PVF") From GLOCK : Break : Endif
            [F:PVF]INVCPLAMT+=MNT*(3-(2*[F:PIH]INVTYP))
          Endif
        Endif
      Endif
    Next
    #----- Déblocage logique entête commande -----#
    Unlock=SYMBOL2 : Raz SYMBOL2
    WNUMERO=NUMERO
  Endif
Endif
Return
#------------------------------------------------------------------------------#
# Recherche du numéro de commande à mettre à jour en fonction du type de ligne #
#------------------------------------------------------------------------------#
$RECH_NUMCDE
Raz NUMERO
If TYPORI=1
  NUMERO=NUMORI
Elsif TYPORI=2
  If [F:PTD]PTHNUM<>NUMORI | [F:PTD]PTDLIN<>LINORI
    Read [PTD] PTD0=NUMORI;LINORI : If fstat Raz [F:PTD] : Endif
  Endif
  NUMERO=[F:PTD]POHNUM
Elsif TYPORI=3
  If [F:PND]PNHNUM<>NUMORI | [F:PND]PNDLIN<>LINORI
    Read [PND] PND0=NUMORI;LINORI : If fstat Raz [F:PND] : Endif
  Endif
  NUMERO=[F:PND]POHNUM
Elsif TYPORI=4
  If clalev([F:PIDC])<=0 Local File PINVOICED [PIDC] : Endif
  Read [PIDC] PID0=NUMORI;LINORI : If fstat Raz [F:PIDC] : Endif
  If [F:PIDC]TYPORI=1
    NUMERO=[F:PIDC]NUMORI
  Elsif [F:PIDC]TYPORI=2
    If [F:PTD]PTHNUM<>[F:PIDC]NUMORI | [F:PTD]PTDLIN<>[F:PIDC]LINORI
      Read [PTD] PTD0=[F:PIDC]NUMORI;[F:PIDC]LINORI : If fstat Raz [F:PTD] : Endif
    Endif
    NUMERO=[F:PTD]POHNUM
  Elsif [F:PIDC]TYPORI=3
    If [F:PND]PNHNUM<>[F:PIDC]NUMORI | [F:PND]PNDLIN<>[F:PIDC]LINORI
      Read [PND] PND0=[F:PIDC]NUMORI;[F:PIDC]LINORI : If fstat Raz [F:PND] : Endif
    Endif
    NUMERO=[F:PND]POHNUM
  Endif
Endif
Return

########################################################################
# REAJUST_BASTAXLIN1 : S/P de réajustement de la base     MBT 29/10/98 #
#            de TVA si modif d'un montant de taxe parafiscale          #
#            ou spéciale soumise à TVA                                 #
# -------------------------------------------------------------------- #
# Subprog REAJUST_BASTAXLIN1 (NOL,MT)                                  #
#   NOL    : Indice de la ligne de facture concernée                   #
#   MT     : Montant de l'écart pour mise à jour                       #
########################################################################
Subprog REAJUST_BASTAXLIN1 (NOL,MT)
Value   Shortint   NOL
Value   Decimal    MT
#----- Variables locales -----#
Local   Shortint   I, J
# Issue 71937 - 2012-03-27 by SR report CPO
Local   Integer    WRET
#----- Mise à jour base taxe de la ligne de facture -----#
[M:PIH3]BASTAXLIN1(NOL)+=MT
#----- Recherche si taxe déja existante -----#
I=find([M:PIH3]VAT1(NOL),[M:PIH4]TAX(0..[M:PIH4]NBTAX-1))
If I<>0 & [M:PIH4]PURTYP(I-1)<>[M:PIH3]LINPURTYP(NOL)
   J=find([M:PIH3]VAT1(NOL),[M:PIH4]TAX(I..[M:PIH4]NBTAX-1))
   If J<>0
     I+=J
     If [M:PIH4]PURTYP(I-1)<>[M:PIH3]LINPURTYP(NOL)
       J=find([M:PIH3]VAT1(NOL),[M:PIH4]TAX(I..[M:PIH4]NBTAX-1))
       If J<>0  I+=J Else I=0 : Endif
     Endif
   Else
     I=0
   Endif
Endif
#----- Nouvelle taxe -----#
If I=0
  #----- Le nombre maximum de taxe est dépassé ! ------#
  If [M:PIH4]NBTAX>=dim([M:PIH4]TAX)
    Call ERREUR ([M:PIH3]VAT1(NOL)-mess(300,194,1)) From GESECRAN
    End
  Endif
  #-----
  I=[M:PIH4]NBTAX
  [M:PIH4]NBTAX+=1
  [M:PIH4]TAX(I)=[M:PIH3]VAT1(NOL)
  # Issue 71937 - 2012-03-27 by SR report CPO
  Call LEC_TVT_LEG(GCURLEG,[M:PIH3]VAT1(NOL),WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
  #Read [TVT] TVT0=[M:PIH3]VAT1(NOL) : If fstat Raz [F:TVT] : Endif
  Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:PIH4]LIBTAX(I)) From TRTX3TEX
  [M:PIH4]PURTYP(I)=[M:PIH3]LINPURTYP(NOL)
  [M:PIH4]VATTYP(I)=[F:TVT]VATTYP
  # Issue 83026 - 2012-06-29 by MUARN : early discount
  [M:PIH4]VATCHA(I)=[F:TVT]VATCHA
Else
  I-=1
Endif
#----- Mise à jour de la base taxe du tableau des taxes -----#
[M:PIH4]BASTAX(I)+=MT : GPIH_INDBASTAX(I)=1
End

########################################################################
# REAJUST_CLCAMT : S/P de réajustement des bases          MBT 20/10/05 #
#            spéciales si modif du montant de taxe principale          #
#            et base spéciale incluant la taxe (Canada)                #
# -------------------------------------------------------------------- #
# Subprog REAJUST_CLCAMT (NOL,MT)                                      #
#   NOL       : Indice de la ligne de facture concernée                #
#   MT        : Montant de l'écart pour mise à jour                    #
#   CLCAMTFLG : Indicateur màj                                         #
#               1=Base 1                                               #
#               2=Base 2   3=Bases 1+2                                 #
#               4=Base 3   5=Bases 1+3   6=Bases 2+3   7=Bases 1+2+3   #
#               8=Base 4   9=Bases 1+8  10=Bases 2+8  11=Bases 1+2+8   #
#               ... etc                                                #
########################################################################
Subprog REAJUST_CLCAMT (NOL,MT,CLCAMTFLG)
Value   Shortint   NOL
Value   Decimal    MT
Value   Shortint   CLCAMTFLG
# Issue 71937 - 2012-03-27 by SR report CPO
Local Integer  WRET
#----- Variables locales -----#
Local   Shortint   I, J, L
Local   Char       VATSPE(GLONVAT)
#-----
For L=3+4*(func AFNC.ACTIV("PTX") & dim([M:PIH3]TAXRCP)>0) To 2 Step -1
  If CLCAMTFLG>=2^L-1
    Case L
      When 2 : VATSPE=[M:PIH3]VAT2(NOL)
      When 3 : VATSPE=[M:PIH3]VAT3(NOL)
      When 4 : VATSPE=[M:PIH3]TAXRCP(NOL)
      When 5 : VATSPE=[M:PIH3]TAXISS(NOL)
      When 6 : VATSPE=[M:PIH3]TAXOTH1(NOL)
      When 7 : VATSPE=[M:PIH3]TAXOTH2(NOL)
    Endcase
    Gosub MAJ_BASTAX_CLCAMT
    CLCAMTFLG-=2^L-1
  Endif
Next L
End
#-----------------------------------------------------#
# Mise à jour de la base de taxe du tableau des taxes #
#-----------------------------------------------------#
$MAJ_BASTAX_CLCAMT
#--CPO 71937 TVT et multi-lég
#If [F:TVT]VAT<>VATSPE
#--/CPO
  # Issue 71937 - 2012-03-27 by SR report CPO
  Call LEC_TVT_LEG(GCURLEG,VATSPE,WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
#  Read [TVT] TVT0=VATSPE : If fstat  Raz [F:TVT] : Endif
#Endif
#----- Si pas montant 1 ou 2 alors pas de mise à jour -----#
If [F:TVT]VATBAS<2  Return : Endif
#----- Mise à jour bases spéciales 2-7 de la ligne -----#
Case L
  When 2 : [M:PIH3]CLCAMT2(NOL)+=MT
  When 3 : [M:PIH3]CLCAMT3(NOL)+=MT
  When 4 : [M:PIH3]CLCAMT4(NOL)+=MT
  When 5 : [M:PIH3]CLCAMT5(NOL)+=MT
  When 6 : [M:PIH3]CLCAMT6(NOL)+=MT
  When 7 : [M:PIH3]CLCAMT7(NOL)+=MT
Endcase
#----- Recherche si taxe déja existante -----#
I=find(VATSPE,[M:PIH4]TAX(0..[M:PIH4]NBTAX-1))
If I<>0 & [M:PIH4]PURTYP(I-1)<>[M:PIH3]LINPURTYP(NOL)
  J=find(VATSPE,[M:PIH4]TAX(I..[M:PIH4]NBTAX-1))
  If J<>0
    I+=J
    If [M:PIH4]PURTYP(I-1)<>[M:PIH3]LINPURTYP(NOL)
      J=find(VATSPE,[M:PIH4]TAX(I..[M:PIH4]NBTAX-1))
      If J<>0  I+=J Else I=0 : Endif
    Endif
  Else
    I=0
  Endif
Endif
#----- Nouvelle taxe -----#
If I=0
  #----- Le nombre maximum de taxe est dépassé ! ------#
  If [M:PIH4]NBTAX>=dim([M:PIH4]TAX)
    Call ERREUR (VATSPE-mess(300,194,1)) From GESECRAN : End
  Endif
  #-----
  I=[M:PIH4]NBTAX
  [M:PIH4]NBTAX+=1
  [M:PIH4]TAX(I)=VATSPE
  Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:PIH4]LIBTAX(I)) From TRTX3TEX
  [M:PIH4]PURTYP(I)=[M:PIH3]LINPURTYP(NOL)
  [M:PIH4]VATTYP(I)=[F:TVT]VATTYP
  # Issue 83026 - 2012-06-29 by MUARN : early discount
  [M:PIH4]VATCHA(I)=[F:TVT]VATCHA
Else
  I-=1
Endif
#----- Mise à jour de la base taxe du tableau des taxes -----#
[M:PIH4]BASTAX(I)+=MT
Return

########################################################################
# FIRST_DUD : S/P de chargement de la 1ère échéance       MBT 30/10/98 #
#             et affichage suivant paramètre                           #
# -------------------------------------------------------------------- #
# Subprog FIRST_DUD (AFF)                                              #
#   AFF    : Indicateur d'affichage (0=Non, 1=Oui)                     #
########################################################################
Subprog FIRST_DUD (AFF)
Value   Integer   AFF
# Issue 82113 - 2012-05-25 by MUARN : mise à jour champ bon à payer pour tous types facture
#If [M:PIH0]PIHTYP<3
  If clalev([F:DUD])<=0 Local File GACCDUDATE [DUD] : Endif
  Filter [DUD] Where TYP=[M:PIH0]GTE & NUM=[M:PIH0]NUM
  Read [DUD] DUD0 First : If fstat Raz [F:DUD] : Endif
  Filter [DUD]
  [M:PIH1]DUDDAT1=[F:DUD]DUDDAT
  #----- Si facture validée, récupération BAP de la 1ère échéance -----#
  If [M:PIH1]STA=3 & [F:DUD]FLGPAZ<>0 & !GIMPORT
    [M:PIH0]PAZ=[F:DUD]FLGPAZ
    If AFF=1 Affzo [PIH0]PAZ : Endif
  Endif
  #-----
  If AFF=1 & !GIMPORT Affzo [PIH1]DUDDAT1 : Endif
#Endif
End

########################################################################
# INIT_COMPTES_LIGNE : S/P d'initialisation               MBT 11/07/06 #
#                des comptes d'une ligne de facture                    #
# -------------------------------------------------------------------- #
# Subprog INIT_COMPTES_LIGNE (NOL)                                     #
#   NOL    : Indice de la ligne de facture à traiter (nolign-1)        #
########################################################################
Subprog INIT_COMPTES_LIGNE (NOL)
Value    Shortint NOL
#-----
Local    Shortint I
Local Integer     RET
#----- Chargement de comptes avec "" pour désactiver l'action d'init -----#
For I=1 To 10
  If evalue("dim([M:PIH3]LINACC"+num$(I)+")")>0
    Assign "[M:PIH3]LINACC"+num$(I)+"(NOL)" With ""
  Endif
Next I
#----- Si ligne vide, pas la peine d'initialiser ! -----#
If [M:PIH3]TYPORI(NOL)=0  End : Endif
#-----
Local    Char     ID1(20)(1..1), ID2(20)(1..2), CODPIECE(GLONGAU)
Local    Shortint J, LIG, SAVNOLIGN : SAVNOLIGN=nolign
Local    Integer  STA
Local    Char     TPLAN  (GLONCOA)(1..10)
Local    Char     TCOMPTE(GLONGAC)(1..10)
Local    Char     WMESSAGE(80)
#-----
Local File PINVOICEV [TB0], PINVOICED [TB1], CPTANALIN [TB2]
nolign=NOL+1
#----- Chargement pseudo fichier complément entête PINVOICEV [TB0] -----#
[F:TB0]=[M:PIH0] : [F:TB0]=[M:PIH1] : [F:TB0]=[M:PIH3] : [F:TB0]=[M:PIH4]
If [M:PIH0]PIHTYP<3 [F:TB0]INVTYP=1
               Else [F:TB0]INVTYP=2 : Endif
[F:TB0]LINNBR=[M:PIH3]NBLIG
For I=0 To dim([F:TB0]INVDTALIN1)-1 : [F:TB0]INVDTALIN1(I)=GINVDTALIN(I) : Next I
#----- Chargement pseudo fichier ligne PINVOICED [TB1] -----#
[F:TB1]=[M:PIH0] : [F:TB1]=[M:PIH1] : [F:TB1]=[M:PIH3] : [F:TB1]=[M:PIH4]
[F:TB1]PIHTYP=[F:TB0]PIHTYP : [F:TB1]INVTYP=[F:TB0]INVTYP
Case [F:TB1]TYPORI
  When 1 : [F:TB1]POHNUM=[F:TB1]NUMORI : [F:TB1]POPLIN=[F:TB1]LINORI
           [F:TB1]POQSEQ=[F:TB1]SEQORI
  When 2 : [F:TB1]PTHNUM=[F:TB1]NUMORI : [F:TB1]PTDLIN=[F:TB1]LINORI
  When 3 : [F:TB1]PNHNUM=[F:TB1]NUMORI : [F:TB1]PNDLIN=[F:TB1]LINORI
  When 4 : [F:TB1]INVNUM=[F:TB1]NUMORI : [F:TB1]INVLIN=[F:TB1]LINORI
Endcase
[F:TB1]CPRCUR=GLOCALDEV
If dim([M:PIH3]TSICOD1(NOL))>0 [F:TB1]TSICOD(0)=[M:PIH3]TSICOD1(NOL) : Endif
If dim([M:PIH3]TSICOD2(NOL))>0 [F:TB1]TSICOD(1)=[M:PIH3]TSICOD2(NOL) : Endif
If dim([M:PIH3]TSICOD3(NOL))>0 [F:TB1]TSICOD(2)=[M:PIH3]TSICOD3(NOL) : Endif
If dim([M:PIH3]TSICOD4(NOL))>0 [F:TB1]TSICOD(3)=[M:PIH3]TSICOD4(NOL) : Endif
If dim([M:PIH3]TSICOD5(NOL))>0 [F:TB1]TSICOD(4)=[M:PIH3]TSICOD5(NOL) : Endif
[F:TB1]VAT(0)=[M:PIH3]VAT1(NOL)
[F:TB1]VAT(1)=[M:PIH3]VAT2(NOL)
[F:TB1]VAT(2)=[M:PIH3]VAT3(NOL)
If [F:TB1]LINPURTYP=0  [F:TB1]LINPURTYP=1 : Endif
#----- Chargement pseudo fichier lignes comptables CPTANALIN [TB2] -----#
Raz [F:TB2]
[F:TB2]ABRFIC="PID"
[F:TB2]VCRNUM=[M:PIH0]NUM
[F:TB2]VCRLIN=[M:PIH3]PIDLIN(NOL)
[F:TB2]ANALIG=1
For I=1 To max(GNBCOA,2)
  J=GTYPLED(I)
  If J
    [F:TB2]LED(J-1)=GLEDSOC(I)
    [F:TB2]COA(J-1)=GCOA(I)
    [F:TB2]ACC(J-1)=evalue("[M:PIH3]LINACC"+num$(I)+"(NOL)")
  Endif
Next I
For I=1 To max(GNBDIE,GOPTCANA)
  [F:TB2]DIE(I-1)=GDIE(I)
  If evalue("dim([M:PIH3]CCE"+num$(I)+")")>0
    [F:TB2]CCE(I-1)=evalue("[M:PIH3]CCE"+num$(I)+"(NOL)")
  Endif
Next I
#----- Chargement table liée PINVOICE pour les pièces auto PIHI ...etc -----#
[F:PIH]=[M:PIH0] : [F:PIH]=[M:PIH1] : [F:PIH]=[M:PIH3] : [F:PIH]=[M:PIH4]
[F:PIH]PIHTYP=[F:TB0]PIHTYP : [F:PIH]INVTYP=[F:TB0]INVTYP
If [M:PIH1]VACTYP=4 [F:PIH]CEEFLG=2 Else [F:PIH]CEEFLG=1 : Endif
[F:PIH]=[M:PCEZ]
#----- Chargement des identifiants (pas indispensable) -----#
ID1(1)=[M:PIH0]NUM : # Num pas chargé en création si cteur auto !!
ID2(1)=[M:PIH0]NUM
ID2(2)=num$([M:PIH3]PIDLIN(NOL))
If [M:PIH0]NUM="" Raz ID1,ID2 : Endif
#----- Lecture si nécessaire du type facture utilisateur -----#
If clalev([F:TPV])<=0 Local File TABPIVTYP [TPV] : Endif
If [F:TPV]PIVTYP<>[M:PIH0]PIVTYP
  #MAE, ajout LEG
  Call LEC_TPV_LEG(GCURLEG,[M:PIH0]PIVTYP,RET) From TRTLECLEG
  #Read [TPV] TPV0=[M:PIH0]PIVTYP :
  If RET Raz [F:TPV] : Endif
Endif
CODPIECE=[F:TPV]COD
If CODPIECE=""
   If [M:PIH0]PIHTYP>2 CODPIECE="PIHC" Else CODPIECE="PIHI" : Endif
Endif
#----- Lecture de la pièce automatique -----#
If clalev([F:GAU])<=0 Local File GAUTACE   [GAU] : Endif
Read [GAU] GAU0=CODPIECE : If fstat Raz [F:GAU] : CODPIECE="PIHI" : Endif
#----- Recherche du numéro de ligne de la pièce auto -----#
Onerrgo SANSRIEN
If clalev([F:GAD])<=0 Local File GAUTACED  [GAD] : Endif
# Issue 88923 - 2013-03-29 by MUARN : compte par défaut
#Filter [GAD] Where COD=CODPIECE & LINNUM>0
#For [GAD]
#  If instr(1,vireblc([F:GAD]ACCKEY(0),4),"ITMREF") |
#&    ([F:GAD]LIKTBL(0)="ITMMASTER" & [F:GAD]LIKFLD(0)="ITMREF")
#    If [F:GAD]FORCND<>""
#      STA=evalue([F:GAD]FORCND)
#      If STA
#        LIG=[F:GAD]LINNUM : Break
#      Endif
#    Else
#      LIG=[F:GAD]LINNUM : Break
#    Endif
#  Endif
#Next
#Filter [GAD]
# Issue X3-42310 - 2017-08-04 by MUARN : refonte pour les formules
#Filter [GAD] Where COD=CODPIECE & LINNUM>0
#For [GAD]
#  For I=0 To dim([F:GAD]FORCND)-1
#    If instr(1,vireblc([F:GAD]ACCKEY(0),4),"ITMREF") |
#&    ([F:GAD]LIKTBL(0)="ITMMASTER" & [F:GAD]LIKFLD(0)="ITMREF")
#      If [F:GAD]FORCND(I)<>""
#        STA = evalue([F:GAD]FORCND(I))
#        If STA
#           LIG=[F:GAD]LINNUM : Break 2
#        Endif
#      Endif
#    Endif
#  Next
#Next
Filter [GAD] Where COD=CODPIECE & LINNUM>0
For [GAD]
  If instr(1,vireblc([F:GAD]ACCKEY(0),4),"ITMREF") |
&    ([F:GAD]LIKTBL(0)="ITMMASTER" & [F:GAD]LIKFLD(0)="ITMREF")
    STA=1
    For I=0 To dim([F:GAD]FORCND)-1
      If [F:GAD]FORCND(I)<>""
        STA=evalue([F:GAD]FORCND(I))
        # Une des lignes de la condition n'est pas respectée, il faut rechercher la ligne suivante de la pièce auto
        If !STA : Break : Endif
      Else
        # Il n'y a pas de condition, on garde cette ligne de la pièce auto
        LIG=[F:GAD]LINNUM : Break
      Endif
    Next
    If STA
      # Toutes les lignes de la condition sont respectées ou pas de condition, on garde cette ligne de la pièce auto
      LIG=[F:GAD]LINNUM : Break
    Endif
  Endif
Next
Filter [GAD]

If LIG=0
  Look [GAD] GAD0=CODPIECE;2
  If !fstat  LIG=2  Else  LIG=20 : Endif
Endif
Onerrgo
#----- Recherche des comptes à l'aide de la pièce auto -----#
Filter [GAC] : # Par sécurité
Call COMPTE(CODPIECE,LIG,ID1,ID2,TPLAN,TCOMPTE,STA,WMESSAGE) From CPTCOD
If STA
  Raz TPLAN, TCOMPTE, GMESSAGE
Else
  If [F:GAD]COD<>CODPIECE | [F:GAD]LINNUM<>LIG
    Read [GAD] GAD0=CODPIECE;LIG : If fstat  Raz [F:GAD] : Endif
  Endif
  For I=1 To 10
    If TPLAN(I)<>""
     #J=find(TPLAN(I),GCOA(1..GNBCOA))
      J=find([F:GAD]LEDTYP(I-1),GTYPLED(1..GNBTYPLED))
      If J
        Assign "[M:PIH3]LINACC"+num$(J)+"(NOL)" With TCOMPTE(I)
      Endif
    Endif
  Next I
Endif
#-----
Close Local File [TB0], [TB1], [TB2]
nolign=SAVNOLIGN
End
$SANSRIEN
STA=0
Resume

########################################################################
# INIT_COMPTES_INVDTA : S/P d'initialisation              MBT 11/07/06 #
#                des comptes d'un élément de facturation               #
# -------------------------------------------------------------------- #
# Subprog INIT_COMPTES_INVDTA (NOL)                                    #
#   NOL    : Indice de la ligne de l'élément à traiter (nolign-1)      #
########################################################################
Subprog INIT_COMPTES_INVDTA (NOL)
Value    Shortint NOL
#-----
Local    Shortint I
Local Integer     RET
#----- Chargement de comptes avec "" pour désactiver l'action d'init -----#
For I=1 To 10
  If evalue("dim([M:PIH4]ACC"+num$(I)+")")>0
    Assign "[M:PIH4]ACC"+num$(I)+"(NOL)" With ""
  Endif
Next I
#----- Si ligne vide, pas la peine d'initialiser ! -----#
If [M:PIH4]INVDTA(NOL)=0  End : Endif
#-----
Local    Libelle  WCDTFLG
Local    Char     ID1(20)(1..1), ID2(20)(1..3), CODPIECE(GLONGAU)
Local    Shortint J, LIG, SAVNOLIGN : SAVNOLIGN=nolign
Local    Integer  STA
Local    Char     TPLAN  (GLONCOA)(1..10)
Local    Char     TCOMPTE(GLONGAC)(1..10)
Local    Char     WMESSAGE(80)
#-----
If [M:PIH4]DEBCDT(NOL)=2 & [M:PIH4]INVDTAAMT(NOL)=0
  [M:PIH4]INVDTAAMT(NOL)=-1 : WCDTFLG=1
Else
  Raz WCDTFLG
Endif
#-----
Local File PINVOICEV [TB0], PVCRFOOT [TB1], CPTANALIN [TB2]
nolign=NOL+1
#----- Chargement pseudo fichier complément entête PINVOICEV [TB0] -----#
[F:TB0]=[M:PIH0] : [F:TB0]=[M:PIH1] : [F:TB0]=[M:PIH3] : [F:TB0]=[M:PIH4]
#-----
If [M:PIH0]PIHTYP<3 [F:TB0]INVTYP=1
               Else [F:TB0]INVTYP=2 : Endif
[F:TB0]LINNBR=[M:PIH3]NBLIG
For I=0 To dim([F:TB0]INVDTALIN1)-1 : [F:TB0]INVDTALIN1(I)=GINVDTALIN(I) : Next I
#----- Chargement pseudo fichier ligne éléments facturation PVCRFOOT [TB1] -----#
[F:TB1]=[M:PIH0] : [F:TB1]=[M:PIH1] : [F:TB1]=[M:PIH3] : [F:TB1]=[M:PIH4]
[F:TB1]VCRNUM=[M:PIH0]NUM
[F:TB1]VCRTYP=8
[F:TB1]IND   =NOL+1
#----- Pour forcer la condition de la pièce auto et charger le compte et la nature -----#
If [F:TB1]INVLINFLG=2 | [F:TB1]INVLINFLG=3 | [F:TB1]INVLINFLG=4 | [F:TB1]INVLINFLG=5
  [F:TB1]INVLINFLG=0
Endif
#----- Chargement pseudo fichier lignes comptables CPTANALIN [TB2] -----#
Raz [F:TB2]
[F:TB2]ABRFIC="PVF"
[F:TB2]VCRTYP=8
[F:TB2]VCRNUM=[M:PIH0]NUM
[F:TB2]VCRSEQ=NOL+1
[F:TB2]ANALIG=1
For I=1 To max(GNBCOA,2)
  J=GTYPLED(I)
  If J
    [F:TB2]LED(J-1)=GLEDSOC(I)
    [F:TB2]COA(J-1)=GCOA(I)
    [F:TB2]ACC(J-1)=evalue("[M:PIH4]ACC"+num$(I)+"(NOL)")
  Endif
Next I
For I=1 To max(GNBDIE,GOPTCANA)
  [F:TB2]DIE(I-1)=GDIE(I)
  If evalue("dim([M:PIH4]PFICCE"+num$(I)+")")>0
    [F:TB2]CCE(I-1)=evalue("[M:PIH4]PFICCE"+num$(I)+"(NOL)")
  Endif
Next I
#----- Chargement table liée PINVOICE pour les pièces auto PIHI ...etc -----#
[F:PIH]=[M:PIH0] : [F:PIH]=[M:PIH1] : [F:PIH]=[M:PIH3] : [F:PIH]=[M:PIH4]
[F:PIH]PIHTYP=[F:TB0]PIHTYP : [F:PIH]INVTYP=[F:TB0]INVTYP
If [M:PIH1]VACTYP=4 [F:PIH]CEEFLG=2 Else [F:PIH]CEEFLG=1 : Endif
[F:PIH]=[M:PCEZ]
#----- Chargement des identifiants (pas indispensable) -----#
ID1(1)=[M:PIH0]NUM : # Num pas chargé en création si cteur auto !!
ID2(1)=[M:PIH0]NUM
ID2(2)="8"
ID2(3)=num$(NOL+1)
If [M:PIH0]NUM="" Raz ID1,ID2 : Endif
#----- Lecture si nécessaire du type facture utilisateur -----#
If clalev([F:TPV])<=0 Local File TABPIVTYP [TPV] : Endif
If [F:TPV]PIVTYP<>[M:PIH0]PIVTYP
  #MAE, ajout LEG
  Call LEC_TPV_LEG(GCURLEG,[M:PIH0]PIVTYP,RET) From TRTLECLEG
  #Read [TPV] TPV0=[M:PIH0]PIVTYP :
  If RET Raz [F:TPV] : Endif
Endif
#-----
CODPIECE=[F:TPV]COD
If CODPIECE=""
  If [M:PIH0]PIHTYP>2 CODPIECE="PIHC" Else CODPIECE="PIHI" : Endif
Endif
#----- Lecture de la pièce automatique -----#
If clalev([F:GAU])<=0 Local File GAUTACE   [GAU] : Endif
Read [GAU] GAU0=CODPIECE : If fstat Raz [F:GAU] : CODPIECE="PIHI" : Endif
#----- Recherche du numéro de ligne de la pièce auto -----#
If clalev([F:GAD])<=0 Local File GAUTACED  [GAD] : Endif
Filter [GAD] Where COD=CODPIECE & LINNUM>0
For [GAD]
  If instr(1,vireblc([F:GAD]ACCKEY(0),4),"INVDTA")
    LIG=[F:GAD]LINNUM : Break
  Endif
Next
Filter [GAD]
If LIG=0
  Look [GAD] GAD0=CODPIECE;9
  If !fstat  LIG=9  Else  LIG=120 : Endif
Endif
#----- Recherche des comptes à l'aide de la pièce auto -----#
Call COMPTE(CODPIECE,LIG,ID1,ID2,TPLAN,TCOMPTE,STA,WMESSAGE) From CPTCOD
If STA
  Raz TPLAN, TCOMPTE, GMESSAGE
Else
  If [F:GAD]COD<>CODPIECE | [F:GAD]LINNUM<>LIG
    Read [GAD] GAD0=CODPIECE;LIG : If fstat  Raz [F:GAD] : Endif
  Endif
  For I=1 To 10
    If TPLAN(I)<>""
     #J=find(TPLAN(I),GCOA(1..GNBCOA))
      J=find([F:GAD]LEDTYP(I-1),GTYPLED(1..GNBTYPLED))
      If J
        Assign "[M:PIH4]ACC"+num$(J)+"(NOL)" With TCOMPTE(I)
      Endif
    Endif
  Next I
Endif
#-----
Close Local File [TB0], [TB1], [TB2]
If WCDTFLG=1  [M:PIH4]INVDTAAMT(NOL)=0 : Endif
nolign=SAVNOLIGN
#-----
End

########################################################################
# TRT_ACOMPTES : S/P d'affectation des acomptes           MBT 20/04/99 #
#              des commandes facturées sur la facture                  #
# -------------------------------------------------------------------- #
# Subprog TRT_ACOMPTES(SENS,TRAIT,MT)                                  #
#   SENS   : Sens de la mise à jour (+1=Affectation, -1=Annulation)    #
#   TRAIT  : Code traitement (1=Création, 2=Modif, 3=Suppress facture) #
#   MT     : Montant maximum d'acomptes à traiter (Total TTC facture)  #
########################################################################
Subprog TRT_ACOMPTES(SENS,TRAIT,MT)
Value    Integer  SENS
Value    Integer  TRAIT
Value    Decimal  MT
Local    Shortint I, J, K
Local    Char     NUMCDE(GLONPOH), CRITERES(70)
Local    Integer  LIGCDE, STAT
Local    Decimal  MTDEVFAC, MTDEVCDE, WMT
#----- Variables locales pour traitement de la table PAYORDER -----#
Local    Integer  WDUDNUM         (50), WACCNUM1(40)
Local    Shortint WDUDLIG         (50), WDUDLIG1(40)
Local    Decimal  WMONTANT        (50), WIBDAMT1(40)
Local    Char     WCUR   (GLONCUR)(50), WCUR1(GLONCUR)(40)
Local    Char     WPAYVCR(GLONVCR)(50)
Local    Integer  WPAYNUM         (50)
Local    Integer  WINVNUM         (50)
#----- Ouverture tables des échéances si nécessaire ----#
If clalev([F:DUD])=0 Local File GACCDUDATE [DUD] : Endif
If clalev([F:PYO])=0 Local File PAYORDER   [PYO] : Endif
#----- Calcul total des acomptes réglés à enlever ------#
If SENS=-1
  Raz WMT
  For [DUD] DUD0 Where TYP=[F:PIH]GTE & NUM=[F:PIH]NUM & CPY=[F:PIH]CPY & CUR=[F:PIH]CUR
    WMT+=[F:DUD]PAYCUR
  Next
  If WMT<MT MT=WMT : Endif
Endif
#----- Mise à jour Mts acompte déduit et à déduire sur acomptes des commandes -----#
MTDEVFAC=MT
For [PID] PID0 Where NUM=[F:PIH]NUM
  Raz NUMCDE, LIGCDE
  Case [F:PID]TYPORI
    When 1 : NUMCDE=[F:PID]NUMORI : LIGCDE=[F:PID]LINORI
    When 2 : Read [PTD] PTD0=[F:PID]NUMORI;[F:PID]LINORI
             If fstat Raz [F:PTD] : Endif
             NUMCDE=[F:PTD]POHNUM : LIGCDE=[F:PTD]POPLIN
  Endcase
  If NUMCDE<>""
    #----- Filtre et ordre de lecture suivant le sens de la mise à jour -----#
    If SENS=1
      Filter [DUD] Where TYP="*PO" & NUM=NUMCDE & IBDAMT>0 Order By Key DUD0 Asc
    Else
      Filter [DUD] Where TYP="*PO" & NUM=NUMCDE & DINAMT>0 Order By Key DUD0 Desc
    Endif
    For [DUD]
      Readlock [DUD] Curr
      If fstat=1
        GOK=-1 : GLOCK="$GACCDUDATE"-"*PO"-NUMCDE         : Break
      Elsif fstat
        GOK=0  : Call RSTA("DUD","*PO"+NUMCDE) From GLOCK : Break
      Endif
      #--- Conversion du montant d'acompte à affecter si devise cde différente ---#
      If [F:DUD]CUR<>[F:PIH]CUR
        Call CONVERT([F:PIH]CUR,[F:DUD]CUR,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]ACCDAT,
&                    MTDEVFAC,MTDEVCDE,STAT) From TRTDEV
      Else
        MTDEVCDE=MTDEVFAC
      Endif
      WACCNUM1(I)=[F:DUD]ACCNUM
      WDUDLIG1(I)=[F:DUD]DUDLIG
      WCUR1   (I)=[F:DUD]CUR
      #----- Affectation des acomptes -----#
      If SENS=1
        If [F:DUD]IBDAMT>MTDEVCDE
          [F:DUD]DINAMT+=MTDEVCDE
          WIBDAMT1(I)=MTDEVCDE
          Raz MTDEVCDE
        Else
          [F:DUD]DINAMT+=[F:DUD]IBDAMT
          WIBDAMT1(I)=[F:DUD]IBDAMT
          MTDEVCDE-=[F:DUD]IBDAMT
        Endif
      #----- Suppression de l'affectation des acomptes -----#
      Elsif [F:DUD]DINAMT>MTDEVCDE
        [F:DUD]DINAMT-=MTDEVCDE
        WIBDAMT1(I)=MTDEVCDE
        Raz MTDEVCDE
      Else
        MTDEVCDE-=[F:DUD]DINAMT
        WIBDAMT1(I)=[F:DUD]DINAMT
        Raz [F:DUD]DINAMT
      Endif
      I+=1
      #----- Conversion du Mt acompte restant à affecter si devise cde différente -----#
      If [F:DUD]CUR<>[F:PIH]CUR
        Call CONVERT([F:DUD]CUR,[F:PIH]CUR,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]ACCDAT,
&                    MTDEVCDE,MTDEVFAC,STAT) From TRTDEV
      Else
        MTDEVFAC=MTDEVCDE
      Endif
      [F:DUD]IBDAMT=[F:DUD]AMTCUR-[F:DUD]DINAMT
      #----- Conversion du Mt réglé -----#
      Call CONVERT([F:DUD]CUR,GLOCALDEV,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]ACCDAT,
&                  [F:DUD]PAYCUR,[F:DUD]PAYLOC,STAT) From TRTDEV
#      Call CONVERT([F:DUD]CUR,GSYSCUR,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]ACCDAT,
#&                  [F:DUD]PAYCUR,[F:DUD]PAYRPT,STAT) From TRTDEV
      #-----
      Call SLDECH("DUD")From MODECHE
      Local Decimal EXERCICE, PERIODE
      Call GETPERSOC([F:DUD]CPY,GTYPGEN,[F:DUD]DUDDAT,EXERCICE,PERIODE) From CPTSUB
      [F:DUD]FIY= EXERCICE
      [F:DUD]PER= PERIODE
      Rewrite [DUD]
      If fstat GOK=0 : Call FSTA("DUD") From GLOCK : Break : Endif
      Call HISTOECH("DUD",1,[F:PIH]ACCDAT)From MODECHE
      If MTDEVFAC=0 Break : Endif
    Next
    If GOK<1 Break : Endif
    If MTDEVFAC=0 Break : Endif
  Endif
Next
Filter [DUD]
If GOK<1   End : Endif : # Si erreur
#----- Mise à jour Mts réglés sur échéances de la facture (sauf si annulation) -----#
If TRAIT<>3 : # Les échéances factures sont supprimées en annulation de facture
  MTDEVFAC=MT-MTDEVFAC : # Montant réel d'acomptes affectés
  For [DUD] Where TYP=[F:PIH]GTE & NUM=[F:PIH]NUM & CPY=[F:PIH]CPY & CUR=[F:PIH]CUR
    WMT=[F:DUD]AMTCUR-([F:DUD]PAYCUR+[F:DUD]TMPCUR)
    If WMT>0
      Readlock [DUD] Curr
      If fstat=1
        GOK=-1 : GLOCK="$GACCDUDATE"-[F:PIH]GTE-[F:PIH]NUM         : Break
      Elsif fstat
        GOK=0  : Call RSTA("DUD",[F:PIH]GTE+[F:PIH]NUM) From GLOCK : Break
      Endif
      If WMT>MTDEVFAC
        [F:DUD]PAYCUR+=MTDEVFAC*SENS : Raz MTDEVFAC
      Else
        [F:DUD]PAYCUR+=WMT*SENS : MTDEVFAC-=WMT
      Endif
      Call CONVERT([F:DUD]CUR,GLOCALDEV,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]ACCDAT,
&                  [F:DUD]PAYCUR,[F:DUD]PAYLOC,STAT) From TRTDEV
#      Call CONVERT([F:DUD]CUR,GSYSCUR,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]ACCDAT,
#&                  [F:DUD]PAYCUR,[F:DUD]PAYRPT,STAT) From TRTDEV
      Call SLDECH("DUD")From MODECHE
      Local Decimal EXERCICE, PERIODE
      Call GETPERSOC([F:DUD]CPY,GTYPGEN,[F:DUD]DUDDAT,EXERCICE,PERIODE) From CPTSUB
      [F:DUD]FIY= EXERCICE
      [F:DUD]PER= PERIODE
      Rewrite [DUD]
      If fstat GOK=0 : Call FSTA("DUD") From GLOCK : Break : Endif
      Call HISTOECH("DUD",1,[F:PIH]ACCDAT)From MODECHE
      If MTDEVFAC=0 Break : Endif
    Endif
  Next
  If GOK<1   End : Endif : # Si erreur
Endif
#----- Recherche règlement acompte -----#
Raz K
For J=0 To I-1
  WMT=WIBDAMT1(J)
  If SENS=1
    #----- Non encore imputé à la facture -----#
    CRITERES="DUDNUM=WACCNUM1(J) & DUDLIG=WDUDLIG1(J) & INVNUM=0"
  Else
    #----- Déjà imputé à la facture (cas suppression de la facture) -----#
    CRITERES="DUDNUM=[F:PIH]ACCNUM & DUDLIG=WDUDLIG1(J) & INVNUM=WACCNUM1(J)"
  Endif
  For [PYO] Where evalue(CRITERES)
    If WMT=0 Break : Endif
    If [F:PYO]DUDPAYAMT>WMT
      WMONTANT(K)=WMT
    Else
      WMONTANT(K)=[F:PYO]DUDPAYAMT
    Endif
    WMT-=WMONTANT(K)
    WDUDNUM   (K)=[F:PYO]DUDNUM
    WDUDLIG   (K)=[F:PYO]DUDLIG
    WPAYVCR   (K)=[F:PYO]PAYVCR
    WPAYNUM   (K)=[F:PYO]PAYNUM
    WINVNUM   (K)=[F:PYO]INVNUM
    WCUR      (K)=WCUR1(J)
    K+=1
  Next
Next J
#-----
For J=0 To K-1
  Readlock [PYO] PYO0=WDUDNUM(J);WDUDLIG(J);WPAYNUM(J)
  If fstat=1
    GLOCK="$PAYORDER"-num$(WDUDNUM(J))-num$(WDUDLIG(J))-num$(WPAYNUM(J))
    GOK=-1 : Break
  Elsif fstat
    Call RSTA("PYO",num$(WDUDNUM(J))-num$(WDUDLIG(J))-num$(WPAYNUM(J))) From GLOCK
    GOK=0  : Break
  Endif
  If SENS=1
    #----- Diminution du montant payé de l'acompte commande -----#
    [F:PYO]DUDPAYAMT-=WMONTANT(J)
    If [F:PYO]DUDPAYAMT<=0
      Delete [PYO]
      If fstat=1
        GLOCK="$PAYORDER"-num$(WDUDNUM(J))-num$(WDUDLIG(J))-num$(WPAYNUM(J))
        GOK=-1 : Break
      Endif
    Else
      Rewrite [PYO]
      If fstat GOK=0 : Call FSTA("PYO") From GLOCK : Break : Endif
    Endif
    If WCUR(J)<>[F:PIH]CUR
      Call CONVERT(WCUR(J),[F:PIH]CUR,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]ACCDAT,
&                  WMONTANT(J),WMT,STAT) From TRTDEV
    Else
      WMT=WMONTANT(J)
    Endif
    #----- Augmentation ou création du montant payé de l'acompte facture -----#
    Read [PYO] PYO0=[F:PIH]ACCNUM;WDUDLIG(J);WPAYNUM(J)
    If fstat
      #----- Création de l'enregistrement acompte facture -----#
      [F:PYO]DUDNUM   =[F:PIH]ACCNUM
      [F:PYO]DUDLIG   =WDUDLIG(J)
      [F:PYO]DUDPAYAMT=WMT
      [F:PYO]PAYVCR   =WPAYVCR(J)
      [F:PYO]PAYNUM   =WPAYNUM(J)
      [F:PYO]INVNUM   =WDUDNUM(J)
      Write [PYO]
      If fstat GOK=0 : Call FSTA("PYO") From GLOCK : Break : Endif
    Else
      #----- Augmentation du montant payé de l'acompte facture -----#
      [F:PYO]DUDPAYAMT+=WMT
      [F:PYO]INVNUM=WDUDNUM(J)
      Rewrite [PYO]
      If fstat GOK=0 : Call FSTA("PYO") From GLOCK : Break : Endif
    Endif
    #----------------------------------------------------------------#
    # L'imputation du règlement à la facture se fera à la validation #
    # car on ne sait pas faire machine arrière en modif ou suppress. #
    #----------------------------------------------------------------#
    # If GMODU(2)=2
    #   Call IMPUTE([F:PIH]ACCNUM,WPAYNUM(J),WDUDLIG(J),WMT) from IPTACPT
    # Endif
  Else
    #----- Diminution du montant payé de l'acompte facture -----#
    [F:PYO]DUDPAYAMT-=WMONTANT(J)
    If [F:PYO]DUDPAYAMT<=0
      Delete [PYO]
      If fstat=1
        GLOCK="$PAYORDER"-num$(WDUDNUM(J))-num$(WDUDLIG(J))-num$(WPAYNUM(J))
        GOK=-1 : Break
      Endif
    Else
      Rewrite [PYO]
      If fstat GOK=0 : Call FSTA("PYO") From GLOCK : Break : Endif
    Endif
    If WCUR(J)<>[F:PIH]CUR
      Call CONVERT([F:PIH]CUR,WCUR(J),GLOCALDEV,[F:PIH]CURTYP,[F:PIH]ACCDAT,
&                  WMONTANT(J),WMT,STAT) From TRTDEV
    Else
      WMT=WMONTANT(J)
    Endif
    #----- Augmentation ou création du montant payé de l'acompte commande -----#
    Read [PYO] PYO0=WINVNUM(J);WDUDLIG(J);WPAYNUM(J)
    If fstat
      #----- Création de l'enregistrement acompte commande -----#
      [F:PYO]DUDNUM   =WINVNUM(J)
      [F:PYO]DUDLIG   =WDUDLIG(J)
      [F:PYO]DUDPAYAMT=WMT
      [F:PYO]PAYVCR   =WPAYVCR(J)
      [F:PYO]PAYNUM   =WPAYNUM(J)
      [F:PYO]INVNUM   =0
      Write [PYO]
      If fstat GOK=0 : Call FSTA("PYO") From GLOCK : Break : Endif
    Else
      #----- Augmentation du montant payé de l'acompte commande -----#
      [F:PYO]DUDPAYAMT+=WMT
      [F:PYO]INVNUM=0
      Rewrite [PYO]
      If fstat GOK=0 : Call FSTA("PYO") From GLOCK : Break : Endif
    Endif
    #--------------------------------------------------------------#
    # On ne sait pas faire machine arrière en modif ou suppression #
    #--------------------------------------------------------------#
    # If GMODU(2)=2
    #   Call IMPUTE([F:PIH]ACCNUM,WPAYNUM(J),WDUDLIG(J),-WMONTANT(J)) from IPTACPT
    # Endif
  Endif
Next J
If GOK<1   End : Endif : # Si erreur
End

#-------------------------------------------------------------------------#
$PREP_PTDORIWRK
#on doit avoir une seule fois chaque ligne de réception
    For NOLPIH3=0 To ([M:PIH3]NBLIG-1)
      If [M:PIH3]POHNUMORI(NOLPIH3)<>""
        [M:PIH3]PTDORIWRK(NOLPIH3)=[M:PIH3]NUMORI(NOLPIH3)-'/'-num$([M:PIH3]LINORI(NOLPIH3))
      Else
        Raz [M:PIH3]PTDORIWRK(NOLPIH3)
      Endif
    Next NOLPIH3

    For NOLPIH3=0 To ([M:PIH3]NBLIG-1)
      If [M:PIH3]PTDORIWRK(NOLPIH3)<>""
        J2=find([M:PIH3]PTDORIWRK(NOLPIH3),[M:PIH3]PTDORIWRK(NOLPIH3+1..[M:PIH3]NBLIG-1))
        If J2>0
          Raz [M:PIH3]PTDORIWRK(NOLPIH3)
        Endif
      Endif
    Next NOLPIH3
Return
#-------------------------------------------------------------------------#

#-------------------------------------------------------------------------#
# Ajustement du montant calculé pour éviter au mieux les écarts d'arrondi #
# ----------------------------------------------------------------------- #
# [F:PVF]INVCPLAMT : Montant déjà facturé (factures déjà enregistrées)    #
# WINVCPLAMT       : Cumul facturé (autres lignes )mais non encore màj    #
# MT               : Montant facturé ligne en cours à réajuster           #
#-------------------------------------------------------------------------#
$AJUST_MT
Local Integer NOLPIH3 : Raz NOLPIH3
#----- Modif ou suppression d'une ligne existante déjà enregistrée -----#
If [M:PIH3]CREFLG(NOL)<>0
  #-----
  If WCUR<>[M:PIH1]CUR : # Si devise différente, conversion
    Call CONVERT([M:PIH1]CUR,WCUR,GLOCALDEV,[M:PIH1]CURTYP,
&                [M:PIH0]ACCDAT,abs([M:PIH4]INVORDAMT(J-1)),WINVORDAMT,STAT) From TRTDEV
  Else
    WINVORDAMT=abs([M:PIH4]INVORDAMT(J-1))
  Endif
  #-----
  If SENS=-1 & abs(WINVORDAMT-arr(MT,WRND))<=WRND
    MT=WINVORDAMT
  Elsif SENS=1 & abs(abs([F:PVF]INVORDAMT)-(WINVORDAMT+arr(MT,WRND)))<=WRND
    MT=abs([F:PVF]INVORDAMT)-WINVORDAMT
  Endif
  #-----
  If SENS=-1 & MT>WINVORDAMT  MT=WINVORDAMT : Endif
  Return
Endif
#----- Traitement d'une nouvelle ligne pas encore enregistrée -----#
Raz WINVCPLAMT
#----- Recherche si commande/réception présente sur autre ligne -----#
Raz I2
While I2<[M:PIH3]NBLIG
  J2=find(WVCRNUM,[M:PIH3]NUMORI(I2..[M:PIH3]NBLIG-1))
  K2=I2+(J2-1)
  If J2=0
    I2=[M:PIH3]NBLIG
  Elsif [M:PIH3]TYPORI(K2)=1                   &
&       [M:PIH3]CREFLG(K2)=0                   &
&       K2<>NOL
    #----- Calcul des valeurs maxi (qté et montant) -----#
    Call CAL_QTEMAX(K2,[M:PIH3]NBLIG,WQTEMAX) From SUBPIHB
    WQTEMAX=min(GPIH_QTEMAX,WTOTLINQTY)
    WMNTMAX=min(arr(WQTEMAX*[M:PIH3]ORINETPRI(K2),WRND),WTOTLINAMT)
    #----- Calcul du montant par une règle de trois -----#
    If [F:PFI]TRFINV=2
      # Issue X3-73377 - 2018-01-29 by MUARN : ne pas faire que sur le service
      If [M:PIH3]LINTYP(K2) <> 3
        #----- Calcul au prorata des quantités -----#
        GBIDD1=[M:PIH3]QTYPUU(K2)
        If WTOTLINQTY>min(GBIDD1,WQTEMAX) & WTOTLINQTY<>0
          If WQTEMAX>GBIDD1
            WINVCPLAMT+=arr(abs([F:PVF]INVORDAMT)*GBIDD1/WTOTLINQTY,WRND)
          Else
            WINVCPLAMT+=arr(abs([F:PVF]INVORDAMT)*WQTEMAX/WTOTLINQTY,WRND)
          Endif
        Else
          WINVCPLAMT+=abs([F:PVF]INVORDAMT)
        Endif
      Endif
    Elsif find([F:PFI]TRFINV,3,4)
      # Issue X3-73377 - 2018-01-29 by MUARN : ne pas faire que sur le lancé
      If [M:PIH3]LINTYP(K2) < 3
        #----- Calcul au prorata des poids ou des volumes -----#
        If [F:ITM]ITMREF<>[M:PIH3]ITMREF(K2)
          Read [ITM] ITM0=[M:PIH3]ITMREF(K2) : If fstat  Raz [F:ITM] : Endif
        Endif
        #----- Calcul des quantités en US -----#
        If [M:PIH3]PUU(K2)=[F:ITM]STU
          WQTYSTU   =[M:PIH3]QTYPUU(K2)
          WQTYSTUMAX=WQTEMAX
        Else
          Call PCAL_QTY([M:PIH3]QTYPUU(NOL),[M:PIH3]PUU(NOL),WQTYSTU,[F:ITM]STU,
&                     [M:PIH3]ITMREF(NOL),[M:PIH3]BPSNUM(NOL),1,GBIDD1) From TRTACHQTE1
          Call PCAL_QTY(WQTEMAX,[M:PIH3]PUU(NOL),WQTYSTU,[F:ITM]STU,
&                     [M:PIH3]ITMREF(NOL),[M:PIH3]BPSNUM(NOL),1,GBIDD1) From TRTACHQTE1
        Endif
        #-----
        If [F:PFI]TRFINV=3
          #----- Calcul au prorata des poids -----#
          GBIDD1=[F:ITM]ITMWEI*WQTYSTU
          Call CONVERT_QTY([F:ITM]WEU,WDSPWEU,GBIDD1) From TRTX3
          GBIDD2=[F:ITM]ITMWEI*WQTYSTUMAX
          Call CONVERT_QTY([F:ITM]WEU,WDSPWEU,GBIDD2) From TRTX3
          If WTOTLINWEU>min(GBIDD1,GBIDD2) & WTOTLINWEU<>0
            If GBIDD2>GBIDD1
              WINVCPLAMT+=arr(abs([F:PVF]INVORDAMT)*GBIDD1/WTOTLINWEU,WRND)
            Else
              WINVCPLAMT+=arr(abs([F:PVF]INVORDAMT)*GBIDD2/WTOTLINWEU,WRND)
            Endif
          Else
            WINVCPLAMT+=abs([F:PVF]INVORDAMT)
          Endif
        Else
          #----- Calcul au prorata des volumes -----#
          GBIDD1=[F:ITM]ITMVOU*WQTYSTU
          Call CONVERT_QTY([F:ITM]VOU,WDSPVOU,GBIDD1) From TRTX3
          GBIDD2=[F:ITM]ITMVOU*WQTYSTUMAX
          Call CONVERT_QTY([F:ITM]VOU,WDSPVOU,GBIDD2) From TRTX3
          If WTOTLINVOU>min(GBIDD1,GBIDD2) & WTOTLINVOU<>0
            If GBIDD2>GBIDD1
              WINVCPLAMT+=arr(abs([F:PVF]INVORDAMT)*GBIDD1/WTOTLINVOU,WRND)
            Else
              WINVCPLAMT+=arr(abs([F:PVF]INVORDAMT)*GBIDD2/WTOTLINVOU,WRND)
            Endif
          Else
            WINVCPLAMT+=abs([F:PVF]INVORDAMT)
          Endif
        Endif
      Endif
    Else
      #----- Calcul au prorata des montants -----#
      If WCUR<>[M:PIH1]CUR : # Si devise différente, conversion
        Call CONVERT([M:PIH1]CUR,WCUR,GLOCALDEV,[M:PIH1]CURTYP,
&                    [M:PIH0]ACCDAT,[M:PIH3]AMTNOTLIN(K2),MT2,STAT) From TRTDEV
      Else
        MT2=[M:PIH3]AMTNOTLIN(K2)
      Endif
      If WTOTLINAMT>min(MT2,WMNTMAX) & WTOTLINAMT<>0
        If WMNTMAX>MT2
          WINVCPLAMT+=arr(abs([F:PVF]INVORDAMT)*MT2/WTOTLINAMT,WRND)
        Else
          WINVCPLAMT+=arr(abs([F:PVF]INVORDAMT)*WMNTMAX/WTOTLINAMT,WRND)
        Endif
      Else
        WINVCPLAMT+=abs([F:PVF]INVORDAMT)
      Endif
    Endif
    I2+=J2 : J2=0
  Else
    I2+=J2 : J2=0
  Endif
Wend
#----- Recherche si réceptions sur cette commande présentes sur autre ligne -----#
If WTYPORI<>2
  #VPO 03/02/11 71185 perf: faire boucle ssi cde std et pas cde ouverte
  If [F:POH]POHNUM<>WVCRNUM
    Read [POH] POH0=WVCRNUM  : If fstat Raz [F:POH] : Endif
  Endif
  If [F:POH]POHTYP=1 : #cde std
    #VPO 03/02/11 71185 perf: on passe par des champs de travail plutôt que req en base
###  For [PTDB] PTD2 Where POHNUM=WVCRNUM
    #on doit avoir une seule fois chaque ligne de réception
    Gosub PREP_PTDORIWRK

    For NOLPIH3=0 To ([M:PIH3]NBLIG-1)
      If [M:PIH3]POHNUMORI(NOLPIH3)=WVCRNUM & [M:PIH3]PTDORIWRK(NOLPIH3)<>""
        WPTHNUM=[M:PIH3]NUMORI(NOLPIH3)
        WPTDLIN=[M:PIH3]LINORI(NOLPIH3)
###
        Raz I2
        While I2<[M:PIH3]NBLIG
###          J2=find([F:PTDB]PTHNUM,[M:PIH3]NUMORI(I2..[M:PIH3]NBLIG-1))
          J2=find(WPTHNUM,[M:PIH3]NUMORI(I2..[M:PIH3]NBLIG-1))
          K2=I2+(J2-1)
          If J2=0
            I2=[M:PIH3]NBLIG
###&               [M:PIH3]LINORI(K2)=[F:PTDB]PTDLIN &
          Elsif [M:PIH3]TYPORI(K2)=2             &
&               [M:PIH3]LINORI(K2)=WPTDLIN       &
&               [M:PIH3]CREFLG(K2)=0             &
&               K2<>NOL
            #----- Calcul des valeurs maxi (qté et montant) -----#
            Call CAL_QTEMAX(K2,[M:PIH3]NBLIG,WQTEMAX) From SUBPIHB
            WQTEMAX=min(GPIH_QTEMAX,WTOTLINQTY)
            WMNTMAX=min(arr(WQTEMAX*[M:PIH3]ORINETPRI(K2),WRND),WTOTLINAMT)
            #----- Calcul du montant par une règle de trois -----#
            If [F:PFI]TRFINV=2
              # ISSUE X3-73377 - 2018-01-29 By MUARN : NE PAS FAIRE QUE SUR LE SERVICE
              If [M:PIH3]LINTYP(K2) <> 3
                #----- Calcul au prorata des quantités -----#
                GBIDD1=[M:PIH3]QTYPUU(K2)
                If WTOTLINQTY>min(GBIDD1,WQTEMAX) & WTOTLINQTY<>0
                  If WQTEMAX>GBIDD1
                    WINVCPLAMT+=arr(abs([F:PVF]INVORDAMT)*GBIDD1/WTOTLINQTY,WRND)
                  Else
                    WINVCPLAMT+=arr(abs([F:PVF]INVORDAMT)*WQTEMAX/WTOTLINQTY,WRND)
                  Endif
                Else
                  WINVCPLAMT+=abs([F:PVF]INVORDAMT)
                Endif
              Endif
            Elsif find([F:PFI]TRFINV,3,4)
              # Issue X3-73377 - 2018-01-29 by MUARN : ne pas faire que sur le lancé
              If [M:PIH3]LINTYP(K2) < 3
                #----- Calcul au prorata des poids ou des volumes -----#
                If [F:ITM]ITMREF<>[M:PIH3]ITMREF(K2)
                  Read [ITM] ITM0=[M:PIH3]ITMREF(K2) : If fstat  Raz [F:ITM] : Endif
                Endif
                #----- Calcul des quantités en US -----#
                If [M:PIH3]PUU(K2)=[F:ITM]STU
                  WQTYSTU   =[M:PIH3]QTYPUU(K2)
                  WQTYSTUMAX=WQTEMAX
                Else
                  Call PCAL_QTY([M:PIH3]QTYPUU(NOL),[M:PIH3]PUU(NOL),WQTYSTU,[F:ITM]STU,
&                             [M:PIH3]ITMREF(NOL),[M:PIH3]BPSNUM(NOL),1,GBIDD1) From TRTACHQTE1
                  Call PCAL_QTY(WQTEMAX,[M:PIH3]PUU(NOL),WQTYSTU,[F:ITM]STU,
&                             [M:PIH3]ITMREF(NOL),[M:PIH3]BPSNUM(NOL),1,GBIDD1) From TRTACHQTE1
                Endif
                #-----
                If [F:PFI]TRFINV=3
                  #----- Calcul au prorata des poids -----#
                  GBIDD1=[F:ITM]ITMWEI*WQTYSTU
                  Call CONVERT_QTY([F:ITM]WEU,WDSPWEU,GBIDD1) From TRTX3
                  GBIDD2=[F:ITM]ITMWEI*WQTYSTUMAX
                  Call CONVERT_QTY([F:ITM]WEU,WDSPWEU,GBIDD2) From TRTX3
                  If WTOTLINWEU>min(GBIDD1,GBIDD2) & WTOTLINWEU<>0
                    If GBIDD2>GBIDD1
                      WINVCPLAMT+=arr(abs([F:PVF]INVORDAMT)*GBIDD1/WTOTLINWEU,WRND)
                    Else
                      WINVCPLAMT+=arr(abs([F:PVF]INVORDAMT)*GBIDD2/WTOTLINWEU,WRND)
                    Endif
                  Else
                    WINVCPLAMT+=abs([F:PVF]INVORDAMT)
                  Endif
                Else
                  #----- Calcul au prorata des volumes -----#
                  GBIDD1=[F:ITM]ITMVOU*WQTYSTU
                  Call CONVERT_QTY([F:ITM]VOU,WDSPVOU,GBIDD1) From TRTX3
                  GBIDD2=[F:ITM]ITMVOU*WQTYSTUMAX
                  Call CONVERT_QTY([F:ITM]VOU,WDSPVOU,GBIDD2) From TRTX3
                  If WTOTLINVOU>min(GBIDD1,GBIDD2) & WTOTLINVOU<>0
                    If GBIDD2>GBIDD1
                      WINVCPLAMT+=arr(abs([F:PVF]INVORDAMT)*GBIDD1/WTOTLINVOU,WRND)
                    Else
                      WINVCPLAMT+=arr(abs([F:PVF]INVORDAMT)*GBIDD2/WTOTLINVOU,WRND)
                    Endif
                  Else
                    WINVCPLAMT+=abs([F:PVF]INVORDAMT)
                  Endif
                Endif
              Endif
            Else
              #----- Calcul au prorata des montants -----#
              If WCUR<>[M:PIH1]CUR : # Si devise différente, conversion
                Call CONVERT([M:PIH1]CUR,WCUR,GLOCALDEV,[M:PIH1]CURTYP,
&                            [M:PIH0]ACCDAT,[M:PIH3]AMTNOTLIN(K2),MT2,STAT) From TRTDEV
              Else
                MT2=[M:PIH3]AMTNOTLIN(K2)
              Endif
              If WTOTLINAMT>min(MT2,WMNTMAX) & WTOTLINAMT<>0
                If WMNTMAX>MT2
                  WINVCPLAMT+=arr(abs([F:PVF]INVORDAMT)*MT2/WTOTLINAMT,WRND)
                Else
                  WINVCPLAMT+=arr(abs([F:PVF]INVORDAMT)*WMNTMAX/WTOTLINAMT,WRND)
                Endif
              Else
                WINVCPLAMT+=abs([F:PVF]INVORDAMT)
              Endif
            Endif
            I2+=J2 : J2=0
          Else
            I2+=J2 : J2=0
          Endif
        Wend
      Endif
    Next NOLPIH3
###    Next
  Endif
Endif
#----- Ajustement du montant calculé -----#
MT2=arr(MT,WRND)
#----- C'est une facture -----#
If [M:PIH0]PIHTYP<3
  If abs(abs([F:PVF]INVORDAMT)-(MT2+WINVCPLAMT+[F:PVF]INVCPLAMT))<=WRND
    MT=abs([F:PVF]INVORDAMT)-(WINVCPLAMT+[F:PVF]INVCPLAMT)
  Endif
  If MT>abs([F:PVF]INVORDAMT)-WINVCPLAMT-[F:PVF]INVCPLAMT
    MT=abs([F:PVF]INVORDAMT)-WINVCPLAMT-[F:PVF]INVCPLAMT
  Endif
Else
#----- C'est un avoir -----#
  If abs([F:PVF]INVCPLAMT-(MT2+WINVCPLAMT))<=WRND
    MT=[F:PVF]INVCPLAMT-WINVCPLAMT
  Endif
  If MT>[F:PVF]INVCPLAMT-WINVCPLAMT
    MT=[F:PVF]INVCPLAMT-WINVCPLAMT
  Endif
Endif
#-----
If MT<0  Raz MT : Endif
Return

#--------------------------------------------------------------------------------#
#----- Recherche si réceptions sur cette commande présentes sur autre ligne -----#
#--------------------------------------------------------------------------------#
$RECH_PTDPOHNUM
Local Integer NOLPIH3 : Raz NOLPIH3
If WTYPORI<>2
  #VPO 03/02/11 71185 perf: faire boucle ssi cde std et pas cde ouverte
  If [F:POH]POHNUM<>WVCRNUM
    Read [POH] POH0=WVCRNUM  : If fstat Raz [F:POH] : Endif
  Endif
  If [F:POH]POHTYP=1 : #cde std
    #VPO 03/02/11 71185 perf: on passe par des champs de travail plutôt que req en base
###    For [PTDB] PTD2 Where POHNUM=WVCRNUM
    #on doit avoir une seule fois chaque ligne de réception
    Gosub PREP_PTDORIWRK

    For NOLPIH3=0 To ([M:PIH3]NBLIG-1)
      If [M:PIH3]POHNUMORI(NOLPIH3)=WVCRNUM & [M:PIH3]PTDORIWRK(NOLPIH3)<>""
        WPTHNUM=[M:PIH3]NUMORI(NOLPIH3)
        WPTDLIN=[M:PIH3]LINORI(NOLPIH3)

        Raz I2
        While I2<[M:PIH3]NBLIG
###          J2=find([F:PTDB]PTHNUM,[M:PIH3]NUMORI(I2..[M:PIH3]NBLIG-1))
          J2=find(WPTHNUM,[M:PIH3]NUMORI(I2..[M:PIH3]NBLIG-1))
          K2=I2+(J2-1)
          If J2=0
            I2=[M:PIH3]NBLIG
###&               [M:PIH3]LINORI(K2)=[F:PTDB]PTDLIN &
          Elsif [M:PIH3]TYPORI(K2)=2              &
&               [M:PIH3]LINORI(K2)=WPTDLIN        &
&               [M:PIH3]CREFLG(K2)=0              &
&               K2<>NOL
            I2=[M:PIH3]NBLIG
          Else
            I2+=J2 : J2=0
          Endif
        Wend
        If J2<>0  Break : Endif
      Endif
###    Next
    Next NOLPIH3
  Endif
Endif
Return

#-----------------------------------#
# Alimentation Mt pied de réception #
#-----------------------------------#
$ALIM_RCPCPLAMT
If !clalev([F:PVF2])  Local File PVCRFOOT [PVF2] : Endif
Filter [PVF2] Where VCRTYP=6 & VCRNUM=[M:PIH3]NUMORI(NOL) & INVDTA=[F:PFI]PFINUM
Read [PVF2] PVF1 First
Filter [PVF2]
If fstat  Return : Endif
#-----
If [F:PTH]PTHNUM<>[M:PIH3]NUMORI(NOL)
  Read [PTH] PTH0=[M:PIH3]NUMORI(NOL) : If fstat  Raz [F:PTH] : Endif
Endif
Raz MT
Case [F:PFI]TRFINV
  When 2       : #----- Prorata quantité
    GBIDD1=[M:PIH3]QTYPUU(NOL)
    If [F:PTH]TOTLINQTY>GBIDD1 & [F:PTH]TOTLINQTY<>0
      MT=abs([F:PVF2]INVDTAAMT)*GBIDD1/[F:PTH]TOTLINQTY
    Else
      MT=abs([F:PVF2]INVDTAAMT)
    Endif
  When 3,4     : #----- Prorara poids ou volume
    If [F:ITM]ITMREF<>[M:PIH3]ITMREF(NOL)
      Read [ITM] ITM0=[M:PIH3]ITMREF(NOL) : If fstat  Raz [F:ITM] : Endif
    Endif
    If [M:PIH3]PUU(NOL)=[F:ITM]STU
      WQTYSTU=[M:PIH3]QTYPUU(NOL)
    Else
      Call PCAL_QTY([M:PIH3]QTYPUU(NOL),[M:PIH3]PUU(NOL),WQTYSTU,[F:ITM]STU,
&                   [M:PIH3]ITMREF(NOL),[M:PIH3]BPSNUM(NOL),1,GBIDD1) From TRTACHQTE1
    Endif
    #----- Prorata poids -----#
    If [F:PFI]TRFINV=3
      GBIDD1=[F:ITM]ITMWEI*WQTYSTU
      Call CONVERT_QTY([F:ITM]WEU,WDSPWEU,GBIDD1) From TRTX3
      If [F:PTH]TOTLINWEU>GBIDD1 & [F:PTH]TOTLINWEU<>0
        MT=abs([F:PVF2]INVDTAAMT)*GBIDD1/[F:PTH]TOTLINWEU
      Else
        MT=abs([F:PVF2]INVDTAAMT)
      Endif
    #----- Prorata volume -----#
    Else
      GBIDD1=[F:ITM]ITMVOU*WQTYSTU
      Call CONVERT_QTY([F:ITM]VOU,WDSPVOU,GBIDD1) From TRTX3
      If [F:PTH]TOTLINVOU>GBIDD1 & [F:PTH]TOTLINVOU<>0
        MT=abs([F:PVF2]INVDTAAMT)*GBIDD1/[F:PTH]TOTLINVOU
      Else
        MT=abs([F:PVF2]INVDTAAMT)
      Endif
    Endif
  When Default : #----- Prorata montant
     GBIDD1=[M:PIH3]AMTNOTLIN(NOL)
     If [F:PTH]CUR<>[M:PIH1]CUR : # Si devise différente, conversion
        Call CONVERT([M:PIH1]CUR,[F:PTH]CUR,GLOCALDEV,[M:PIH1]CURTYP,
&                    [M:PIH0]ACCDAT,[M:PIH3]AMTNOTLIN(NOL),GBIDD1,STAT) From TRTDEV
     Endif
     If [F:PTH]TOTLINAMT>GBIDD1 & [F:PTH]TOTLINAMT<>0
       MT=abs([F:PVF2]INVDTAAMT)*GBIDD1/[F:PTH]TOTLINAMT
     Else
       MT=abs([F:PVF2]INVDTAAMT)
     Endif
Endcase
#-----
MT=arr(MT,WRND)
If ([M:PIH0]PIHTYP<3 & [M:PIH4]DEBCDT(J-1)=2) |
&  ([M:PIH0]PIHTYP>2 & [M:PIH4]DEBCDT(J-1)=1)
  MT=-MT : # Si minoration
Endif
If SENS=1 [M:PIH4]RCPCPLAMT(J-1)+=MT Else [M:PIH4]RCPCPLAMT(J-1)-=MT : Endif
#-----
Return

# Issue 83026 - 2012-08-02 by MUARN : early discount
#############################################################################
# DISPLAY_BASDEP : S/P d'affichage de la base escomptable  MUARN 02/08/2012 #
#############################################################################
Subprog DISPLAY_BASDEP
  Local Integer LSHOWBASDEP : LSHOWBASDEP=1
#  Local Integer LGERDSC
#  Local Char    LPARAM
  If [M:PIH1]DEP="" | [M:PIH0]PIHTYP>2 | [M:PIH1]DEPTYP=0 | GDEPMGTMOD = 4
    LSHOWBASDEP=0
#  Else
#    Call PARAM(GFCY,"GERDSC",LPARAM) From ADOVAL : LGERDSC=val(LPARAM)
#    If LGERDSC = 2 LSHOWBASDEP =0 Endif
  Endif
  If !LSHOWBASDEP
    If GFMT ="" GFMT ="13.2" Endif
    Chgfmt [M:PIH4]BASDEP With "-NPz3:"+GFMT
  Else
    Call FMTFM1DEV([M:PIH1]CUR) From TRTDIV
    Chgfmt [M:PIH4]BASDEP With "NPz3:"+GFMT
  Endif
End

# Issue 84130 - 2013-02-13 by MUARN : landed cost
#########################################################################
# MAJ_REPART_LIG : S/P de répartition des éléments de facturation sur   #
#         les lignes de commande au prorata des qantités ou montants,   #
#         calcul taxes et prix unitaires de revient                     #
# --------------------------------------------------------------------- #
# Subprog MAJ_REPART_LIG                                                #
#########################################################################
Subprog MAJ_REPART_LIG
#----- Variables locales -----#
Local Shortint I, J, K
Local Decimal  MTLIG, CUMLIG
Local Integer SAV_NOLIGN
#-----
# Issue 105663 - 2015-01-22 by MUARN : le calcul a déjà été réalisé et le montant taxe peut devenir faux
#For I=0 To [M:PIH4]NBFAC-1
#  Call MAJ_ELEMENT (I,0,-1) From SUBPIHB
#  Call MAJ_ELEMENT (I,0,+1) From SUBPIHB
#Next I
#-----

For I=0 To [M:PIH3]NBLIG-1
  If [M:PIH3]ITMREF(I) <> ""
    Call MAJ_QTYCPR_LIG(I) From SUBPIHC
  Endif
  # Issue X3-39273 - 2017-08-10 by MUARN : gestion erreur
  If GOK =0 : Break : Endif
Next I
End

#####################################################################
# Issue 71253 - 2012-05-21 by SR
$CHARG_FMTPOR
#----- Relecture transaction si nécessaire -----#
If [F:PTR]PTRTYP<>8 | [F:PTR]PTRNUM<>GPTRNUM
     Read [PTR] PTR0=8;GPTRNUM : If fstat Raz [F:PTR] : Endif
Endif
If func AFNC.PARAM("PORVAT",GFCY) = "2"
#----- Localisation Espagnole -----#
  If find([F:PTR]PORTVACOD,0,1)
    #----- Saisi -----#
    If [M:PIH1]STA = 3
       GPIH_FMTKPO ="KP:"+num$(GLONEEC)+"X"
    Else
      GPIH_FMTKPO ="K:"+num$(GLONEEC)+"X"
    Endif
  Elsif [F:PTR]PORTVACOD=2
    #----- Affiché -----#
    GPIH_FMTKPO ="KP:"+num$(GLONEEC)+"X"
  Else
    #----- Invisible -----#
    GPIH_FMTKPO ="-K:"+num$(GLONEEC)+"X"
  Endif
Else
  #----- Invisible -----#
  GPIH_FMTKPO ="-K:"+num$(GLONEEC)+"X"
Endif
Return

########################################################################
# MAJ_RET : S/P de mise à jour des fichiers retour entête et ligne     #
#                      (PRETURN et PRETURND)                           #
# -------------------------------------------------------------------- #
# Subprog MAJ_RET(SIGN,NUMERO,LIGNE)                                   #
#   SIGN     : Sens de la mise à jour (+1=Cumul, -1=Soustraction)      #
#   NUMERO   : Numéro du retour à mettre à jour                        #
#   LIGNE    : Ligne  du retour à mettre à jour                        #
########################################################################
Subprog MAJ_RET(SIGN,NUMERO,LIGNE)
Value    Integer  SIGN
Value    Char     NUMERO
Value    Integer  LIGNE
#----- Variables locales -----#
Local    Shortint FLG
Local    Char     SYMBOL2(30), CLEFIC(33)
#----- Variables pour le point d'entrée MAJFAC -----#
Local    Char     FICHIER(GLONATB), ABRFIC(3)
#----- Si entête retour bloquée logiquement --> Abandon -----#
CLEFIC=NUMERO : SYMBOL2="PNH"+NUMERO : Lock=SYMBOL2
If fstat GMESSAGE="$PRETURN"-CLEFIC-mess(10,100,1) : GERR=1
         GOK=0 : End : Endif
#----- Lecture entête et ligne retour avec blocage physique -----#
Readlock [PNH] PNH0=NUMERO
#----- Pas de màj et pas d'erreur en import si retour n'existe pas -----#
If GIMPORT & fstat Raz [F:PNH] : Goto DEBLOC_RET : Endif
If fstat=1  GOK=-1 : GLOCK="$PRETURN"-CLEFIC            : Goto DEBLOC_RET
Elsif fstat GOK=0  : Call RSTA("PNH",CLEFIC) From GLOCK : Goto DEBLOC_RET
Endif
CLEFIC+=" "+num$(LIGNE)
Readlock [PND] PND0=NUMERO;LIGNE
#----- Pas de màj et pas d'erreur en import si ligne retour n'existe pas -----#
If GIMPORT & fstat Raz [F:PND] : Goto DEBLOC_RET : Endif
If fstat=1  GOK=-1 : GLOCK="$PRETURND"-CLEFIC           : Goto DEBLOC_RET
Elsif fstat GOK=0  : Call RSTA("PND",CLEFIC) From GLOCK : Goto DEBLOC_RET
Endif
If SIGN=-1
# #----- Mise à jour qtés facturées -----#
  [F:PND]INVQTYPUU-=[F:PID]QTYPUU*((2*[F:PIH]INVTYP)-3)
  If [F:PID]UOM=[F:PND]STU
    GBIDD1=[F:PID]QTYUOM
  Else
    Call PCAL_QTY([F:PID]QTYPUU,[F:PID]PUU,GBIDD1,[F:PND]STU,
&                 [F:PID]ITMREF,[F:PNH]BPSNUM,1,GBIDD2) From TRTACHQTE1
  Endif
  [F:PND]INVQTYSTU-=GBIDD1*((2*[F:PIH]INVTYP)-3)
# #----- Positionnement indicateur ligne facturée -----#
  If [F:PND]QTYPUU>[F:PND]INVQTYPUU
     FLG=1 Else FLG=2
  Endif
  If [F:PND]LININVFLG<>FLG
     If FLG=2 [F:PNH]INVLINNBR+=1 Else [F:PNH]INVLINNBR-=1 : Endif
     [F:PND]LININVFLG=FLG
  Endif
Else
# #--- Mise à jour qtés facturées --#
  [F:PND]INVQTYPUU+=[F:PID]QTYPUU*((2*[F:PIH]INVTYP)-3)
  If [F:PID]UOM=[F:PND]STU
    GBIDD1=[F:PID]QTYUOM
  Else
    Call PCAL_QTY([F:PID]QTYPUU,[F:PID]PUU,GBIDD1,[F:PND]STU,
&                 [F:PID]ITMREF,[F:PNH]BPSNUM,1,GBIDD2) From TRTACHQTE1
  Endif
  [F:PND]INVQTYSTU+=GBIDD1*((2*[F:PIH]INVTYP)-3)
# #----- Positionnement indicateur ligne facturée -----#
  If [F:PND]QTYPUU<=[F:PND]INVQTYPUU | [F:PID]PRTFLG=1
     FLG=2 Else FLG=1
  Endif
  If [F:PND]LININVFLG<>FLG
     If FLG=2 [F:PNH]INVLINNBR+=1 Else [F:PNH]INVLINNBR-=1 : Endif
     [F:PND]LININVFLG=FLG
  Endif
Endif
#----------------------------------------------------------------------#
# Point d'entrée MAJFAC pour modif zones std et alim zones spécifiques #
# -------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                          #
#                                                                      #
# FICHIER : Nom de la table qui va être écrite                         #
# ABRFIC  : Abréviation de la table qui va être écrite                 #
# Les classes [F:PIH], [F:PIV] et [F:PID] sont disponibles             #
# La  classe  [F:PND] est modifiable avant le Rewrite                  #
#----------------------------------------------------------------------#
[L]FICHIER="PRETURND"
[L]ABRFIC ="PND"
GPOINT="MAJFAC" : Gosub ENTREE From EXEFNC
#----- Réécriture ligne retour -----#
Rewrite [PND] : If fstat GOK=0 : Call FSTA("PND") From GLOCK : Goto DEBLOC_RET : Endif
#----- Remise à jour nbre lignes facturées si modif par point d'entrée -----#
If [F:PND]LININVFLG<>FLG
  If [F:PND]LININVFLG=2
    [F:PNH]INVLINNBR+=1
  Else
    [F:PNH]INVLINNBR-=1
  Endif
Endif
#----- Positionnement indicateur facture -----#
If [F:PNH]LINNBR<=[F:PNH]INVLINNBR [F:PNH]INVFLG=3
Elsif [F:PNH]INVLINNBR<>0 [F:PNH]INVFLG=2 Else [F:PNH]INVFLG=1 : Endif
#----------------------------------------------------------------------#
# Point d'entrée MAJFAC pour modif zones std et alim zones spécifiques #
# -------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                          #
#                                                                      #
# FICHIER : Nom de la table qui va être écrite                         #
# ABRFIC  : Abréviation de la table qui va être écrite                 #
# Les classes [F:PIH], [F:PIV] et [F:PID] sont disponibles             #
# La  classe  [F:PNH] est modifiable avant le Rewrite                  #
#----------------------------------------------------------------------#
[L]FICHIER="PRETURN"
[L]ABRFIC ="PNH"
GPOINT="MAJFAC" : Gosub ENTREE From EXEFNC
#----- Réécriture entête retour -----#
Rewrite [PNH] : If fstat GOK=0 : Call FSTA("PNH") From GLOCK : Goto DEBLOC_RET : Endif
$DEBLOC_RET
Unlock=SYMBOL2
End
######################################################################################

# Issue 71069 - 2016-09-06 by MUARN : PJT
$AM_PJTH

If [M:PIH3]NBLIG = 0

  [M:PIH1]PJTH=VALEUR

  If dim([M:PIH1]NBAXE)>0
    If [M:PIH1]NBAXE>0
        For I=1 To [M:PIH1]NBAXE Raz [M:PIH1]CCE(I-1) : Next
    Endif
    Call INIT_CCEH("PIH1","NBAXE","PIH") From TRTX3CPT
    If !GIMPORT : Affzo [M:PIH1]25 : Endif
  Endif

$MAJ_CCE_PFI
  If dim([M:PIH4]NBFAC) > 0
    For I=0 To [M:PIH4]NBFAC-1
      If [M:PIH4]DSP(I) = ""
        For J=1 To GNBDIE
          Case J
            When  1 :
              Raz [M:PIH4]PFICCE1 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PIH4]PFICCE1(I),J,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
            When  2 :
              Raz [M:PIH4]PFICCE2 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [M:PIH4] : Endif
              Call INIT_CCE([M:PIH4]PFICCE2(I),J,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
            When  3 :
              Raz [M:PIH4]PFICCE3 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PIH4]PFICCE3(I),J,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
            When  4 :
              Raz [M:PIH4]PFICCE4 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PIH4]PFICCE4(I),J,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
            When  5
              Raz [M:PIH4]PFICCE5 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PIH4]PFICCE5(I),J,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
            When  6 :
              Raz [M:PIH4]PFICCE6 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PIH4]PFICCE6(I),J,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
            When  7 :
              Raz [M:PIH4]PFICCE7 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PIH4]PFICCE7(I),J,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
            When  8 :
              Raz [M:PIH4]PFICCE8 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PIH4]PFICCE8(I),J,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
            When  9 :
              Raz [M:PIH4]PFICCE9 (I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PIH4]PFICCE9(I),J,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
            When 10 :
              Raz [M:PIH4]PFICCE10(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PIH4]PFICCE10(I),J,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
            When 11 :
              Raz [M:PIH4]PFICCE11(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PIH4]PFICCE11(I),J,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
            When 12 :
              Raz [M:PIH4]PFICCE12(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PIH4]PFICCE12(I),J,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
            When 13 :
              Raz [M:PIH4]PFICCE13(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PIH4]PFICCE13(I),J,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
            When 14 :
              Raz [M:PIH4]PFICCE14(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PIH4]PFICCE14(I),J,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
            When 15 :
              Raz [M:PIH4]PFICCE16(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PIH4]PFICCE15(I),J,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
            When 16 :
              Raz [M:PIH4]PFICCE17(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PIH4]PFICCE16(I),J,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
            When 17 :
              Raz [M:PIH4]PFICCE17(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PIH4]PFICCE17(I),J,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
            When 18 :
              Raz [M:PIH4]PFICCE18(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PIH4]PFICCE18(I),J,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
            When 19 :
              Raz [M:PIH4]PFICCE19(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PIH4]PFICCE19(I),J,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
            When 20 :
              Raz [M:PIH4]PFICCE20(I)
              nolign = I + 1
              Read [PFI] PFI0=[M:PIH4]INVDTA(I) : If fstat Raz [F:PFI] : Endif
              Call INIT_CCE([M:PIH4]PFICCE20(I),J,"PIV","[M:PIH4]ACC",I) From TRTX3CPT
          Endcase
        Next J
      Endif
    Next I
    If !GIMPORT : Affzo [M:PIH4]5 : Endif
  Endif

Endif

Return

