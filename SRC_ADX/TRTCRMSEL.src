#####################################################################
$SEL_SELFLDCUS
Local Char CODFIC(GLONATB)

  #Sélection de libellés à partir d'un champs alphanumérique d'un tiers divers
  If !clalev([F:BPG]) : Local File BPMISCCGF [BPG] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  CODFIC = "ATABDIV"
  Default File [BPG]
  CRITERE = '[F:BPG]BPRTYP = "LIBDOO" and [F:BPG]LAN = GLANGUE and [F:BPG]TTRINT(0) = PARAM(1)'
  START = "TTRALH(0)" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "TTRALH(0)"
  TIT(0) = PARAM(2)
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "TTRALH(0)" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return

$VERF_SELFLDCUS
  #Sélection de libellés à partir d'un champs alphanumérique d'un tiers divers
Return
#####################################################################

#####################################################################
$SEL_SELSRE0DOO
Local Char CODFIC(GLONATB)

  #Sélection des donneurs d'ordre sur une demande de service
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  If PARAM(1) = "DOO2" Then
    CODFIC = "BPARTNER"
    Default File [BPR]
    CRITERE = "[F:BPR]DOOFLG = 2"
    START   = "BPRNUM" #Start doit contenir le nom du champs de clé de l'objet.
    ORDRE = "BPRNUM"
    TIT(0) = mess(254,196,1) #Liste des donneurs d'ordre
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "BPRNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "BPRNAM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  Elsif PARAM(1) = "SRE0" Then
    If [M:SRE0]SREBPC = "" Then
      CODFIC = "BPARTNER"
      Default File [BPR]
      CRITERE = "[F:BPR]DOOFLG = 2 and [F:BPR]BPCFLG = 2"  # FGR 16/04/2012 : X3SUIVI81400
      START = "BPRNUM" #Start doit contenir le nom du champs de clé de l'objet.
      ORDRE = "BPRNUM"
      TIT(0) = mess(254,196,1) #Liste des donneurs d'ordre
      NBCOL = 0
      NBCOL += 1 : COL(NBCOL) = "BPRNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
      NBCOL += 1 : COL(NBCOL) = "BPRNAM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
    Else
      If !clalev([F:DBL]) : Local File DOOBPCLNK [DBL] : Endif
      CODFIC = "DOOBPCLNK"
      Default File [DBL]
      CRITERE = "[F:DBL]BPCNUM = [M:SRE0]SREBPC"
      START = "DOONUM" #Start doit contenir le nom du champs de clé de l'objet.
      ORDRE = "DOONUM"
      TIT(0) = mess(254,196,1) #Liste des donneurs d'ordre
      NBCOL = 0
      NBCOL += 1 : COL(NBCOL) = "DOONUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
      NBCOL += 1 : COL(NBCOL) = "DOONAM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
    Endif
  Endif
  DEFPAG = 1    # FGR 16/04/2012 : X3SUIVI81400 : pour la pagination
Return

$VERF_SELSRE0DOO
  #Sélection des donneurs d'ordre sur une demande de service
Return
#####################################################################

#####################################################################
$SEL_SELSRE0BPC
Local Char CODFIC(GLONATB)
Local Char SZDOONAM(GLONNAM)

  #Sélection des clients sur une demande de service
  SZDOONAM = ""
  If [M:SRE0]SREDOO = "" Then
    #Cas : un donneur d'ordre n'est pas renseigné.
    If !clalev([F:DBI]) : Local File DOOBPCINT [DBI] : Endif
    If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
    CODFIC = "DOOBPCINT"
    Default File [DBI]
    CRITERE = "[F:DBI]INTBPC = 2"
    START = "BPCNUM" #Start doit contenir le nom du champs de clé de l'objet.
    ORDRE = "BPCNUM"
    TIT(0) = mess(255,196,1) #Liste des clients internes.
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "BPCNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "BPCNAM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "BPCSHO" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  Else
    #Cas : un donneur d'ordre est renseigné.
    If !clalev([F:DBL]) : Local File DOOBPCLNK [DBL] : Endif
    If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
    Read [BPR]BPR0=[M:SRE0]SREDOO
    If !fstat Then
      SZDOONAM = [F:BPR]BPRNAM
    Endif
    CODFIC = "DOOBPCLNK"
    Default File [DBL]
    CRITERE = "[F:DBL]DOONUM = [M:SRE0]SREDOO"
    START = "BPCNUM" #Start doit contenir le nom du champs de clé de l'objet.
    ORDRE = "BPCNUM"
    TIT(0) = mess(256,196,1) - SZDOONAM #Clients de
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "BPCNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "BPCNAM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "BPCSHO" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  Endif
Return

$VERF_SELSRE0BPC
#Sélection des clients sur une demande de service
Return
#####################################################################

#####################################################################
$SEL_SELSRE0MAC
Local Char SZBPCNAM(GLONNAM)
Local Char SZCCNNAM(GLONNAC)
Local Char CODFIC(GLONATB)

  SZBPCNAM = ""
  SZCCNNAM = ""
  If !clalev([F:MAC]) : Local File MACHINES [MAC] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  If [M:SRE0]SREBPC = "" and [M:SRE0]SRECCN = "" Then
    Return
  Endif
  If [M:SRE0]SREBPC <> "" Then
    #Obtient le nom du tiers
    Read [BPR]BPR0=[M:SRE0]SREBPC
    If !fstat Then
      SZBPCNAM = [F:BPR]BPRNAM
    Endif
    TIT(0) = mess(503,196,1) - SZBPCNAM #Parc de
  Elsif [M:SRE0]SREBPC = "" and [M:SRE0]SRECCN <> "" Then
    #Obtient le nom de l'interlocuteur
    Read [AIN]AIN0=[M:SRE0]SRECCN
    If !fstat Then
      Call BUILDFULNAM("AIN", SZCCNNAM) From CRMUTIL140
    Endif
    TIT(0) = mess(503,196,1) - SZCCNNAM #Parc de
  Endif
  #Sélection des machines sur une demande de service
  CODFIC = "MACHINES"
  Default File [MAC]
  If [M:SRE0]SREBPC <> "" Then
    If [M:SRE7]ITM(nolign-1) = "" Then
      If [M:SRE0]SREBPAADD <> "" Then
        CRITERE = "[F:MAC]BPCNUM = [M:SRE0]SREBPC and [F:MAC]FCYITN = [M:SRE0]SREBPAADD"
      Else
        CRITERE = "[F:MAC]BPCNUM = [M:SRE0]SREBPC"
      Endif
    Else
      If [M:SRE0]SREBPAADD <> "" Then
        CRITERE = "[F:MAC]BPCNUM = [M:SRE0]SREBPC and [F:MAC]FCYITN = [M:SRE0]SREBPAADD and [F:MAC]MACPDTCOD = [M:SRE7]ITM(nolign-1)"
      Else
        CRITERE = "[F:MAC]BPCNUM = [M:SRE0]SREBPC and [F:MAC]MACPDTCOD = [M:SRE7]ITM(nolign-1)"
      Endif
    Endif
  Elsif [M:SRE0]SREBPC = "" and [M:SRE0]SRECCN <> "" Then
    CRITERE = "[F:MAC]CCNNUM = [M:SRE0]SRECCN"
  Endif
  START = "MACNUM" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "MACNUM"
  DEFPAG = 1 # FGR 04/10/2011 : X3SUIVI76520
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "MACBRACLA" : Call TEXTE(14543, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "MACPDTCOD" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "MACDES"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "MACSERNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "MACITNDAT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "MACNUM"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return

$VERF_SELSRE0MAC
  #Sélection des machines sur une demande de service
Return
#####################################################################

#####################################################################
$SEL_SELSRE2AS2
Local Integer ITERPBLMAC
Local Char SZMACPBL
Local Char CODFIC(GLONATB)

  ITERPBLMAC = 0
  SZMACPBL = ""
  Case [M:SRE2]SREASS
    When 1
      If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
      OBJET = "FCY"
      VALEUR = ""
    When 2
      If !clalev([F:PBR]) : Local File FAMPBREP [PBR] : Endif
      If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
      CODFIC = "FAMPBREP"
      Default File [PBR]
      If [M:SRE7]SREPBLGRP = "" Then
        For ITERPBLMAC = 0 To [M:SRE7]NBMAC-1
          If [M:SRE7]MACDEF(ITERPBLMAC) = 2 Then
            SZMACPBL = [M:SRE7]PBL(ITERPBLMAC)
            Break
          Endif
        Next
        If SZMACPBL = "" Then
          #On met un filtre qui ne renvoie rien.
          CRITERE = "[F:PBR]STTFLG = 9"
        Else
          CRITERE = "[F:PBR]GRPPBLNUM = SZMACPBL and [F:PBR]STTFLG = 0"
        Endif
      Else
        CRITERE = "[F:PBR]GRPPBLNUM = [M:SRE7]SREPBLGRP and [F:PBR]STTFLG = 0"
      Endif
      START = "REPNUM" #Start doit contenir le nom du champs de clé de l'objet.
      ORDRE = "REPNUM"
      TIT(0) = mess(267,196,1) #Collaborateurs compétents
      NBCOL = 0
      NBCOL += 1 : COL(NBCOL) = "REPNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
      NBCOL += 1 : COL(NBCOL) = "REPNAM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
    When 3
      If !clalev([F:PBQ]) : Local File FAMPBQUE [PBQ] : Endif
      If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
      CODFIC = "FAMPBQUE"
      Default File [PBQ]
      If [M:SRE7]SREPBLGRP = "" Then
        For ITERPBLMAC = 0 To [M:SRE7]NBMAC-1
          If [M:SRE7]MACDEF(ITERPBLMAC) = 2 Then
            SZMACPBL = [M:SRE7]PBL(ITERPBLMAC)
            Break
          Endif
        Next
        If SZMACPBL = "" Then
          #On met un filtre qui ne renvoie rien.
          CRITERE = "[F:PBQ]STTFLG = 9"
        Else
          CRITERE = "[F:PBQ]GRPPBLNUM = SZMACPBL & [F:PBQ]STTFLG = 0"
        Endif
      Else
        CRITERE = "[F:PBQ]GRPPBLNUM = [M:SRE7]SREPBLGRP & [F:PBQ]STTFLG = 0"
      Endif
      START = "QUENUM" #Start doit contenir le nom du champs de clé de l'objet.
      ORDRE = "QUENUM"
      TIT(0) = mess(268,196,1) #Queues concernées
      NBCOL = 0
      NBCOL += 1 : COL(NBCOL) = "QUENUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
      NBCOL += 1 : COL(NBCOL) = "QUENAM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
    When Default
  Endcase
Return

$VERF_SELSRE2AS2
#Sélection des affectations sur une demande de service
Return
