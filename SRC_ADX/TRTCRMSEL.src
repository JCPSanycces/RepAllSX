#####################################################################

#####################################################################
$SEL_SELPHO5TEL
Local Char SZMSNEND
Local Date DMSNEND
Local Char SZFNC
Local Integer IFNC
Local Char SZSTA
Local Integer ISTA
Local Integer Z
Local Char SZTIT(100)
Local Date DOPGDATEND

  #Sélection des téléacteurs actifs
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  If !clalev([F:REP]) : Local File SALESREP [REP] : Endif
  If !clalev([F:OMP]) : Local File PHONING [OMP] : Endif
  SZMSNEND = ""
  DMSNEND = [00/00/00]
  SZFNC = ""
  IFNC = 0
  SZSTA = ""
  ISTA = 0
  Z = 0
  SZTIT = ""
  DOPGDATEND = [00/00/00]
  #Obtient la date de fin de la campagne d'appel
  Read [OMP]OMP0=GSZOPGNUM
  If fstat Then
    DOPGDATEND = date$
  Else
    DOPGDATEND = [F:OMP]OMPEND
  Endif
  Filter [REP] Where [F:REP]AUSNUM <> ""
  For [REP] REP1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    If [F:REP]REPNUM <> "" Then
      Call PARAMUTIL("AUSCRMA", SZFNC, [F:REP]AUSNUM, "") From SUBAUS
      If SZFNC = "" Then
        IFNC = 1
      Else
        IFNC = val(SZFNC)
      Endif
      Call PARAMUTIL("AUSCRMB", SZSTA, [F:REP]AUSNUM, "") From SUBAUS
      If SZSTA = "" Then
        ISTA = 1
      Else
        ISTA = val(SZSTA)
      Endif
      Call PARAMUTIL("AUSCRMD", SZMSNEND, [F:REP]AUSNUM, "") From SUBAUS
      If SZMSNEND = "" Then
        DMSNEND = [00/00/00]
      Else
        DMSNEND = gdat$(val(right$(SZMSNEND,7)), val(seg$(SZMSNEND,5,6)),val(left$(SZMSNEND,4)))
      Endif
      Read [AUS]CODUSR=[F:REP]AUSNUM
      If !fstat Then
        If IFNC = 3 Then
          If ISTA = 1 Then
            #Téléacteur permanent
            Z += 1
            TEX(Z) = [F:REP]REPNUM
            TEXTE(Z) = [F:REP]REPNUM - "-" - [F:REP]REPNAM
          Else
            If DMSNEND >= DOPGDATEND Then
              Z += 1
              TEX(Z) = [F:REP]REPNUM
              TEXTE(Z) = [F:REP]REPNUM - "-" - [F:REP]REPNAM
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [REP]
  NBTEX = Z
  SZTIT = mess(363,196,1) #Téléacteurs
  TIT = left$(SZTIT, 50)
Return

$VERF_SELPHO5TEL
  #Sélection des téléacteurs actifs
Return
