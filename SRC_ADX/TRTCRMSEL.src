      Break
    Endif
    TEX(Z) = "OMT" + [F:OMT]OMTNUM
    TEXTE(Z) = left$([F:OMT]DES, 50)
  Next
  Filter [OMT]
  Filter [OMN] Where [F:OMN]CMGNUM = [M:OPP1]OPPCMGNUM Order By [F:OMN]OMNNUM
  ITITLE = 0
  For [OMN]
    If !ITITLE Then
      Z += 1
      TEX(Z) = ""
