$SEL_SELCLL0OPP
Local Char CODFIC(GLONATB)
Local Char SZBPCNAM(GLONNAM)
Local Char SZCCNNAM(GLONNAC)
Local Integer ICCNSEL

  SZBPCNAM = ""
  SZCCNNAM = ""
  ICCNSEL = 1
  If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  If [M:CLL0]CLLCMP <> "" Then
    #Sélection des affaires sur un appel pour un tiers.
    Read [BPR]BPR0=[M:CLL0]CLLCMP
    If !fstat Then
      SZBPCNAM = [F:BPR]BPRNAM
    Endif
    CODFIC = "OPPOR"
    Default File [OPP]
    CRITERE = "[F:OPP]OPPCMP = [M:CLL0]CLLCMP"
    START = "OPPNUM" #Start doit contenir le nom du champs de clé de l'objet.
    ORDRE = "OPPNUM"
    TIT(0) = mess(413,196,1) - SZBPCNAM #Affaires chez
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "OPPDES"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "OPPSTE"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "OPPCDA"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "OPPREP"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "OPPNUM"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
    ICCNSEL = 0
  Elsif ICCNSEL Then
    If [M:CLL0]CLLCCN <> "" Then
      #Sélection des affaires sur un appel pour un interlocuteur.
      Read [AIN]AIN0=[M:CLL0]CLLCCN
      If !fstat Then
        Call BUILDFULNAM("AIN", SZCCNNAM) From CRMUTIL140
      Endif
      CODFIC = "OPPOR"
      Default File [OPP]
      CRITERE = "[F:OPP]OPPMCN = [M:CLL0]CLLCCN"
      START = "OPPNUM" #Start doit contenir le nom du champs de clé de l'objet.
      ORDRE = "OPPNUM"
      TIT(0) = mess(413,196,1) - SZCCNNAM #Affaires chez
      NBCOL = 0
      NBCOL += 1 : COL(NBCOL) = "OPPDES"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
      NBCOL += 1 : COL(NBCOL) = "OPPSTE"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
      NBCOL += 1 : COL(NBCOL) = "OPPCDA"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
      NBCOL += 1 : COL(NBCOL) = "OPPREP"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
      NBCOL += 1 : COL(NBCOL) = "OPPNUM"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
    Endif
  Endif
Return

