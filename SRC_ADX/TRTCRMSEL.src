#############################################################################################
#  Traitement générale pour la gestion des fenêtres de sélection                   Module CRM
#  Créé le 6 juin 2000
#############################################################################################
$ACTION
  Case ACTION
    When "SEL_TABLE"   : Gosub SEL_TABLE
    When "VERF_TABLE"  : Gosub VERF_TABLE
    When "SEL_LISTE"   : Gosub SEL_LISTE
    When "VERF_LISTE"  : Gosub VERF_LISTE
    When Default
  Endcase
Return

#############################################################################################
$SEL_TABLE
  DEFPAG = 1 # FGR 24/04/2012 : X3SUIVI81798 Initialisation générale de la gestion des pages.
