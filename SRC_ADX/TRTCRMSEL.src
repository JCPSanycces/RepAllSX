#####################################################################
$SEL_SELITM2COT
Local Char CODFIC(GLONATB)

  #Sélection d'une modèle de contrat de service sur une fiche article
  If !clalev([F:COT]) : Local File CONTTEMPL [COT] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  CODFIC = "CONTTEMPL"
  Default File [COT]
  If PARAM(1) = "" Then
    CRITERE = "1=1"
  Elsif PARAM(1) = "GAR" Then
    CRITERE = "[F:COT]CONCAT = 1"
  Elsif PARAM(1) = "GARPIT" Then
    CRITERE = "[F:COT]CONCAT = 1 or [F:COT]CONCAT = 4"
  Elsif PARAM(1) = "COT" Then
    CRITERE = "[F:COT]CONCAT = 2 or [F:COT]CONCAT = 3"
  Elsif PARAM(1) = "COTPIT" Then
    CRITERE = "[F:COT]CONCAT <> 1"
  Elsif PARAM(1) = "PIT" Then
    CRITERE = "[F:COT]CONCAT = 4"
  Elsif PARAM(1) = "LND" Then
    CRITERE = "[F:COT]CONCAT <> 4"
  Endif
  START = "CONNUM" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "CONNUM"
  TIT(0) = mess(328,196,1) #Modèles de contrats de service.
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "CONNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "TPLNAM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "CONTYPCLA" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return

