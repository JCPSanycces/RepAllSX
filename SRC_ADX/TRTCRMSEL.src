#####################################################################
$SEL_SELITN1REP
Local Integer Z
Local Char SZHDKREP
Local Integer IHDKREP

  #Sélection de l'intervenant sur une intervention
  SZHDKREP = ""
  IHDKREP = 0
  Z = 0
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  Filter [AUS] Where [F:AUS]ENAFLG = 2 and [F:AUS]USR >= VALEUR
  For [AUS]
    Call PARAMUTIL("AUSHDKA", SZHDKREP, [F:AUS]USR, "") From SUBAUS
    If SZHDKREP = "" Then
      IHDKREP = 1
    Else
      IHDKREP = val(SZHDKREP)
    Endif
    If IHDKREP = 2 Then
      Z += 1
      If Z >= dim(TEX)-1 Then
        Break
      Endif
      TEX(Z) = [F:AUS]USR
      TEXTE(Z) = [F:AUS]USR - "-" - [F:AUS]NOMUSR
    Endif
  Next
  Filter [AUS]
  NBTEX = Z
  TIT = mess(262,196,1) #Collaborateurs Help-Desk
Return

