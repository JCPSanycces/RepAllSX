$SEL_SELAPP1CCN
Local Integer Z
Local Char SZTTLLIB
Local Char SZTIT(100)

  #Sélection des interlocuteurs d'un tiers sur une fiche rendez-vous
  Z = 0
  SZTTLLIB = ""
  SZTIT = ""
  # Si aucun tiers n'est mentionné, on ne fait rien.
  If [M:BAP0]APTCMP = "" Then
    #Aucun tiers n'est mentionné pour le rendez-vous.
    # Aucun interlocuteur ne peut être identifié.
    GMESSAGE = mess(341,196,1)
    GERR = 2
    Return
  Endif
  Filter [CNT] Where [F:CNT]BPANUM = [M:BAP0]APTCMP and [F:CNT]BPATYP = 1
  For [CNT]
    Z += 1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    TEX(Z) = [F:CNT]CCNCRM
    Read [AIN]AIN0=[F:CNT]CCNCRM
    If fstat Then
      TEXTE(Z) = [F:CNT]CCNCRM
    Else
      Call BUILDFULNAM("AIN", TEXTE(Z)) From CRMUTIL140
    Endif
  Next
  Filter [CNT]
  NBTEX = Z
  Read [BPR]BPR0=[M:BAP0]APTCMP
  If fstat Then
    SZTIT = mess(194,196,1) - [M:BAP0]APTCMP
  Else
    SZTIT = mess(194,196,1) - [F:BPR]BPRNAM
  Endif
  TIT = left$(SZTIT, 50)
Return

$VERF_SELAPP1CCN
  #Sélection des interlocuteurs d'un tiers sur une fiche rendez-vous
Return
