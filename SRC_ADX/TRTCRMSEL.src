#####################################################################

#####################################################################
$SEL_SELMGG2TAB
Local Integer Z
Local Char SZTIT(100)
Local Char SZTABINTIT(50)
Local Char SZTEXTE(GLONDCO)

  #Sélection des tables d'un support de sélection
  If !clalev([F:SSP]) : Local File SELSSP [SSP] : Endif
  If !clalev([F:SSC]) : Local File SELSSPCPN [SSC] : Endif
  If !clalev([F:FID]) : Local File FIEDIC [FID] : Endif
  If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
  Z = 0
  SZTIT = ""
  SZTABINTIT = ""
  #On met au moins la cible
  Read [SSP]SSP0=PARAM(1)
  If fstat Then
    Return
  Else
    Z += 1
    TEX(Z) = [F:SSP]SPTTGR
    Read [FID]FID0=[F:SSP]SPTTGR;GAUSCRMI
    If fstat Then
      Read [FID]FID0=[F:SSP]SPTTGR;""
      If fstat Then
        Read [ATB]CODFIC=[F:SSP]SPTTGR
        If fstat Then
          TEXTE(Z) = '0' - "-" - [F:SSP]SPTTGR
        Else
          SZTABINTIT = ""
          Call TEXTE([F:ATB]INTITFIC, SZTABINTIT) From OBJDIV
          TEXTE(Z) = '0' - "-" - [F:SSP]SPTTGR - "-" - SZTABINTIT
        Endif
      Else
        # FGR 06/03/2009 : X3SUIVI52963 : Texte traduisible
        Call LECTEXTRA(SZTEXTE, "FIEDIC", "CRITABAXX", [F:FID]CRITAB, [F:FID]CAT) From ATEXTRA
        TEXTE(Z) = '0' - "-" - [F:SSP]SPTTGR - "-" - SZTEXTE
      Endif
    Else
      # FGR 06/03/2009 : X3SUIVI52963 : Texte traduisible
      Call LECTEXTRA(SZTEXTE, "FIEDIC", "CRITABAXX", [F:FID]CRITAB, [F:FID]CAT) From ATEXTRA
      TEXTE(Z) = '0' - "-" - [F:SSP]SPTTGR - "-" - SZTEXTE
    Endif
  Endif
  Filter [SSC] Where [F:SSC]SPTNUM = PARAM(1) Order By [F:SSC]SPTLEV Asc
  For [SSC]
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    Z += 1
    TEX(Z) = [F:SSC]SPTTAB
    Read [FID]FID0=[F:SSC]SPTTAB;GAUSCRMI
    If fstat Then
      Read [FID]FID0=[F:SSC]SPTTAB;""
      If fstat Then
        Read [ATB]CODFIC=[F:SSC]SPTTAB
        If fstat Then
          TEXTE(Z) = num$([F:SSC]SPTLEV) - "-" - [F:SSC]SPTTAB
        Else
          Call TEXTE([F:ATB]INTITFIC, SZTABINTIT) From OBJDIV
          TEXTE(Z) = num$([F:SSC]SPTLEV) - "-" - [F:SSC]SPTTAB - "-" - SZTABINTIT
        Endif
      Else
        # FGR 06/03/2009 : X3SUIVI52963 : Texte traduisible
        Call LECTEXTRA(SZTEXTE, "FIEDIC", "CRITABAXX", [F:FID]CRITAB, [F:FID]CAT) From ATEXTRA
        TEXTE(Z) = num$([F:SSC]SPTLEV) - "-" - [F:SSC]SPTTAB - "-" - SZTEXTE
      Endif
    Else
      # FGR 06/03/2009 : X3SUIVI52963 : Texte traduisible
      Call LECTEXTRA(SZTEXTE, "FIEDIC", "CRITABAXX", [F:FID]CRITAB, [F:FID]CAT) From ATEXTRA
      TEXTE(Z) = num$([F:SSC]SPTLEV) - "-" - [F:SSC]SPTTAB - "-" - SZTEXTE
    Endif
  Next
  Filter [SSC]
  NBTEX = Z
  #Composants du support.
  SZTIT = mess(586,196,1)
  TIT = left$(SZTIT, 50)
Return

$VERF_SELMGG2TAB
#Sélection des tables d'un support de sélection
Return
#####################################################################

#####################################################################
$SEL_SELMGG2FIE
Local Integer Z
Local Integer ITERZ
Local Char SZTIT(100)
Local Char SZFIEINTIT(50)
Local Char SZTEXTE(GLONDCO)

  #Sélection des champs d'une table ou du dictionnaire des critères
  If !clalev([F:FID]) : Local File FIEDIC [FID] : Endif
  If !clalev([F:FDF]) : Local File FIEDICFIE [FDF] : Endif
  If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  Z = 0
  ITERZ = 0
  SZTIT = ""
  SZFIEINTIT = ""
  If PARAM(1) = "" Then
    #Aucun code de table n'a été mentionné.
    GMESSAGE = mess(587,196,1)
    GERR = 3
    Return
  Endif
  Read [FID]FID0=PARAM(1);GAUSCRMI
  If fstat Then
    Read [FID]FID0=PARAM(1);""
    If fstat Then
      #La table est exploité telle quelle.
      Filter [ATZ] Where [F:ATZ]CODFIC = PARAM(1) and [F:ATZ]CODZONE >= VALEUR
      For [ATZ]CODZONE
        If Z >= dim(TEX)-1 Then
          Break
        Endif
        If [F:ATZ]CODACT = "" or ([F:ATZ]CODACT <> "" and func ASYRFNC.ACTIV([F:ATZ]CODACT) = [V]CST_ATRUE) Then  # FGR 26/08/2016 : X3SUIVI117480
          If func CRMUTIL150.IS_TBLFIELD_USABLE([F:ATZ]CODFIC, [F:ATZ]CODZONE) = [V]CST_AYES Then # FGR 04/02/2015 : X3SUIVI105938
            Z += 1
            TEX(Z) = [F:ATZ]CODZONE
            Call TEXTE([F:ATZ]NOLONG, TEXTE(Z)) From OBJDIV
            TEXTE(Z) = [F:ATZ]CODZONE - "-" - TEXTE(Z)
          Endif
        Endif
      Next
      Filter [ATZ]
    Else
      #La table a fait l'objet d'un paramétrage dans le dictionnaire des critères
      Filter [FDF] Where [F:FDF]CRITAB = PARAM(1) and [F:FDF]SELCRIFIE >= VALEUR and [F:FDF]SELCRIFLG = 2 and [F:FDF]CAT = "" Order By [F:FDF]SELCRISRT Asc
      For [FDF]
        If Z >= dim(TEX)-1 Then
          Break
        Endif
        Call LECTEXTRA(SZTEXTE, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
        Z += 1
        TEX(Z) = [F:FDF]SELCRIFIE
        If SZTEXTE = "" Then
          Read [ATZ]CODZONE=PARAM(1);[F:FDF]SELCRIFIE
          If fstat Then
            TEXTE(Z) = [F:FDF]SELCRIFIE
          Else
            If [F:ATZ]CODACT = "" or ([F:ATZ]CODACT <> "" and func ASYRFNC.ACTIV([F:ATZ]CODACT) = [V]CST_ATRUE) Then  # FGR 26/08/2016 : X3SUIVI117480
              If func CRMUTIL150.IS_TBLFIELD_USABLE([F:ATZ]CODFIC, [F:ATZ]CODZONE) = [V]CST_AYES Then # FGR 04/02/2015 : X3SUIVI105938
                Call TEXTE([F:ATZ]NOLONG, SZFIEINTIT) From OBJDIV
                TEXTE(Z) = [F:FDF]SELCRIFIE - "-" - SZFIEINTIT
              Endif
            Endif
          Endif
        Else
          TEXTE(Z) = [F:FDF]SELCRIFIE - "-" - SZTEXTE
        Endif
      Next
      Filter [FDF]
      #On recherche ensuite soit des nouveaux champs standards non maquillés soit des champs spécifiques
      Filter [ATZ] Where [F:ATZ]CODFIC = PARAM(1) and [F:ATZ]CODZONE >= VALEUR
      For [ATZ]CODZONE
        If Z >= dim(TEX)-1 Then
          Break
        Endif
        If [F:ATZ]CODACT = "" or ([F:ATZ]CODACT <> "" and func ASYRFNC.ACTIV([F:ATZ]CODACT) = [V]CST_ATRUE) Then  # FGR 26/08/2016 : X3SUIVI117480
          If func CRMUTIL150.IS_TBLFIELD_USABLE([F:ATZ]CODFIC, [F:ATZ]CODZONE) = [V]CST_AYES Then # FGR 04/02/2015 : X3SUIVI105938
            Read [FDF]FDF0=PARAM(1);[F:ATZ]CODZONE;""
            If fstat Then
              Z += 1
              TEX(Z) = [F:ATZ]CODZONE
              Call TEXTE([F:ATZ]NOLONG, TEXTE(Z)) From OBJDIV
              TEXTE(Z) = [F:ATZ]CODZONE - "-" - TEXTE(Z)
            Endif
          Endif
        Endif
      Next
      Filter [ATZ]
    Endif
  Else
    #La table a fait l'objet d'un paramétrage dans le dictionnaire des critères
    Filter [FDF] Where [F:FDF]CRITAB = PARAM(1) and [F:FDF]SELCRIFIE >= VALEUR and [F:FDF]SELCRIFLG = 2 and [F:FDF]CAT = GAUSCRMI Order By [F:FDF]SELCRISRT Asc
    For [FDF]
      If Z >= dim(TEX)-1 Then
        Break
      Endif
      Call LECTEXTRA(SZTEXTE, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
      Z += 1
      TEX(Z) = [F:FDF]SELCRIFIE
      If SZTEXTE = "" Then
        Read [ATZ]CODZONE=PARAM(1);[F:FDF]SELCRIFIE
        If fstat Then
          TEXTE(Z) = [F:FDF]SELCRIFIE
        Else
          If [F:ATZ]CODACT = "" or ([F:ATZ]CODACT <> "" and func ASYRFNC.ACTIV([F:ATZ]CODACT) = [V]CST_ATRUE) Then  # FGR 26/08/2016 : X3SUIVI117480
            If func CRMUTIL150.IS_TBLFIELD_USABLE([F:ATZ]CODFIC, [F:ATZ]CODZONE) = [V]CST_AYES Then # FGR 04/02/2015 : X3SUIVI105938
              Call TEXTE([F:ATZ]NOLONG, SZFIEINTIT) From OBJDIV
              TEXTE(Z) = [F:FDF]SELCRIFIE - "-" - SZFIEINTIT
            Endif
          Endif
        Endif
      Else
        TEXTE(Z) = [F:FDF]SELCRIFIE - "-" - SZTEXTE
      Endif
    Next
    Filter [FDF]
    #On recherche ensuite soit des nouveaux champs standards non maquillés soit des champs spécifiques
    Filter [ATZ] Where [F:ATZ]CODFIC = PARAM(1) and [F:ATZ]CODZONE >= VALEUR
    For [ATZ]CODZONE
      If Z >= dim(TEX)-1 Then
        Break
      Endif
      If [F:ATZ]CODACT = "" or ([F:ATZ]CODACT <> "" and func ASYRFNC.ACTIV([F:ATZ]CODACT) = [V]CST_ATRUE) Then  # FGR 26/08/2016 : X3SUIVI117480
        If func CRMUTIL150.IS_TBLFIELD_USABLE([F:ATZ]CODFIC, [F:ATZ]CODZONE) = [V]CST_AYES Then                 # FGR 04/02/2015 : X3SUIVI105938
          Read [FDF]FDF0=PARAM(1);[F:ATZ]CODZONE;GAUSCRMI
          If fstat Then
            Z += 1
            TEX(Z) = [F:ATZ]CODZONE
            Call TEXTE([F:ATZ]NOLONG, TEXTE(Z)) From OBJDIV
            TEXTE(Z) = [F:ATZ]CODZONE - "-" - TEXTE(Z)
          Endif
        Endif
      Endif
    Next
    Filter [ATZ]
  Endif
  NBTEX = Z
  SZTIT = mess(376,196,1) #Liste des champs
  TIT = left$(SZTIT, 50)
Return

$VERF_SELMGG2FIE
  #Sélection des champs d'une table ou du dictionnaire des critères
Return
#####################################################################

#####################################################################
$SEL_SELMGG2VAL
Local Char SZTABPLUSFIE
Local Integer Z
Local Integer Z3
Local Char SZTIT(100)
Local Char SZTEXTE
Local Integer IADISEPARATOR
Local Char SZLEFTCRIFIE(GLONAVA)
Local Integer IDIMLEVPOS1
Local Integer IDIMLEVPOS2
Local Integer IDIMLEVPOS3
Local Integer IUSERDIMLEV
Local Integer IFAMSTATDEB
Local Integer IFAMSTATFIN

  #Sélection des valeurs possibles de critère
  IADISEPARATOR = 0
  Z = 0
  Z3 = 0
  SZTIT = ""
  SZTEXTE = ""
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  If PARAM(1) = "" Then
    #Aucun code de table n'a été mentionné.
    GMESSAGE = mess(587,196,1)
    GERR = 3
    Return
  Elsif PARAM(2) = "" Then
    #Aucun nom de champ n'a été mentionné.
    GMESSAGE = mess(588,196,1)
    GERR = 3
    Return
  Endif
  IFAMSTATDEB = 0
  IFAMSTATFIN = 0
  IUSERDIMLEV = 0
  IDIMLEVPOS1 = 0
  IDIMLEVPOS2 = 0
  IDIMLEVPOS3 = 0
  SZLEFTCRIFIE = func CRMUTIL150.GET_CHAMP_SSIND(PARAM(2)) # FGR 12/01/2009 : X3SUIVI51579
  If instr(1, PARAM(2), '(') Then
    #Obtention de l'indice saisi
    IDIMLEVPOS1 =  instr(1, [M:MGG2]CRIFIE(GPRECRINOL), '(')
    If instr(1, [M:MGG2]CRIFIE(GPRECRINOL), ')') Then
      IDIMLEVPOS2 =  instr(1, [M:MGG2]CRIFIE(GPRECRINOL), ')')
      If IDIMLEVPOS2 > IDIMLEVPOS1 Then
        IDIMLEVPOS3 = IDIMLEVPOS2 - IDIMLEVPOS1
        If IDIMLEVPOS3 > 1 Then
          IUSERDIMLEV = val(mid$([M:MGG2]CRIFIE(GPRECRINOL), IDIMLEVPOS1+1, IDIMLEVPOS3-1))
        Endif
      Endif
    Endif
  Endif
  SZTABPLUSFIE = PARAM(1) + SZLEFTCRIFIE
  Read [ATZ]CODZONE=PARAM(1);SZLEFTCRIFIE
  If fstat Then
    #Erreur lors de la recherche des éléments de la liste.
    GMESSAGE = mess(589,196,1)
    GERR = 1
    Return
  Endif
  #If func CRMUTIL150.IS_TBLFIELD_USABLE([F:ATZ]CODFIC, [F:ATZ]CODZONE) = [V]CST_AYES Then # FGR 04/02/2015 : X3SUIVI105938
  If func CRMUTIL150.IS_TBLFIELD_USABLE([F:ATZ]CODFIC, [F:ATZ]CODZONE) = [V]CST_ANO Then   # FGR 30/06/2016 : X3SUIVI117419
    #Erreur lors de la recherche des éléments de la liste.
    GMESSAGE = mess(589,196,1)
    GERR = 1
    Return
  Endif
  If ([F:ATZ]CODACT <> "" and func ASYRFNC.ACTIV([F:ATZ]CODACT) = [V]CST_AFALSE) Then  # FGR 26/08/2016 : X3SUIVI117480
    #Erreur lors de la recherche des éléments de la liste.
    GMESSAGE = mess(589,196,1)
    GERR = 1
    Return
  Endif
  If [F:ATZ]CODTYP = "ADI" Then
    Case SZTABPLUSFIE
      When "BPCUSTOMERTSCCOD"
        If instr(1, PARAM(2), '(') Then
          IFAMSTATDEB = IUSERDIMLEV + 30
          IFAMSTATFIN = IUSERDIMLEV + 30
        Else
          IFAMSTATDEB = 30
          IFAMSTATFIN = 34
        Endif
        Filter [ADI] Where [F:ADI]NUMTAB >= IFAMSTATDEB and [F:ADI]NUMTAB <= IFAMSTATFIN
        For [ADI] CODE
          Z += 1
          If Z >= dim(TEX)-1 Then
            Break
          Endif
          Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, SZTEXTE) From CRM_UTIL
          TEX(Z) = [F:ADI]CODE
          TEXTE(Z) = SZTEXTE
        Next
        Filter [ADI]
      When "BPSUPPLIERTSSCOD"
        If instr(1, PARAM(2), '(') Then
          IFAMSTATDEB = IUSERDIMLEV + 40
          IFAMSTATFIN = IUSERDIMLEV + 40
        Else
          IFAMSTATDEB = 40
          IFAMSTATFIN = 44
        Endif
        Filter [ADI] Where [F:ADI]NUMTAB >= IFAMSTATDEB and [F:ADI]NUMTAB <= IFAMSTATFIN
        For [ADI] CODE
          Z += 1
          If Z >= dim(TEX)-1 Then
            Break
          Endif
          Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, SZTEXTE) From CRM_UTIL
          TEX(Z) = [F:ADI]CODE
          TEXTE(Z) = SZTEXTE
        Next
        Filter [ADI]
      When "ITMMASTERTSICOD"
        If instr(1, PARAM(2), '(') Then
          IFAMSTATDEB = IUSERDIMLEV + 20
          IFAMSTATFIN = IUSERDIMLEV + 20
        Else
          IFAMSTATDEB = 20
          IFAMSTATFIN = 24
        Endif
        Filter [ADI] Where [F:ADI]NUMTAB >= IFAMSTATDEB and [F:ADI]NUMTAB <= IFAMSTATFIN
        For [ADI] CODE
          Z += 1
          If Z >= dim(TEX)-1 Then
            Break
          Endif
          Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, SZTEXTE) From CRM_UTIL
          TEX(Z) = [F:ADI]CODE
          TEXTE(Z) = SZTEXTE
        Next
        Filter [ADI]
      When "SERREQUESTTSDCOD"
        If instr(1, PARAM(2), '(') Then
          IFAMSTATDEB = IUSERDIMLEV + 445
          IFAMSTATFIN = IUSERDIMLEV + 445
        Else
          IFAMSTATDEB = 445
          IFAMSTATFIN = 449
        Endif
        Filter [ADI] Where [F:ADI]NUMTAB >= IFAMSTATDEB and [F:ADI]NUMTAB <= IFAMSTATFIN
        For [ADI] CODE
          Z += 1
          If Z >= dim(TEX)-1 Then
            Break
          Endif
          Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, SZTEXTE) From CRM_UTIL
          TEX(Z) = [F:ADI]CODE
          TEXTE(Z) = SZTEXTE
        Next
        Filter [ADI]
      When "CONTSERVCONTYP"
        If instr(1, PARAM(2), '(') Then
          IFAMSTATDEB = IUSERDIMLEV + 440
          IFAMSTATFIN = IUSERDIMLEV + 440
        Else
          IFAMSTATDEB = 440
          IFAMSTATFIN = 444
        Endif
        Filter [ADI] Where [F:ADI]NUMTAB >= IFAMSTATDEB and [F:ADI]NUMTAB <= IFAMSTATFIN
        For [ADI] CODE
          Z += 1
          If Z >= dim(TEX)-1 Then
            Break
          Endif
          Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, SZTEXTE) From CRM_UTIL
          TEX(Z) = [F:ADI]CODE
          TEXTE(Z) = SZTEXTE
        Next
        Filter [ADI]
      When Default
        IADISEPARATOR = instr(1, [F:ATZ]EXPLIEN, ";")
        IADISEPARATOR -= 1
        Filter [ADI] Where [F:ADI]NUMTAB = val(left$([F:ATZ]EXPLIEN, IADISEPARATOR)) Order By [F:ADI]CODE Asc
        For [ADI]
          Z += 1
          If Z >= dim(TEX)-1 Then
            Break
          Endif
          Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, SZTEXTE) From CRM_UTIL
          TEX(Z) = [F:ADI]CODE
          TEXTE(Z) = SZTEXTE
        Next
        Filter [ADI]
    Endcase
  Elsif [F:ATZ]CODTYP = "M" or [F:ATZ]CODTYP = "MM" Then
    Z3 = 1
    While mess(Z3, [F:ATZ]NOLIB, 2) <> ""
      Z += 1
      If Z >= dim(TEX)-1 Then
        Break
      Endif
      SZTEXTE = mess(Z3,[F:ATZ]NOLIB,1)
      TEX(Z) = num$(Z3)
      TEXTE(Z) = SZTEXTE
      Z3 += 1
    Wend
  Endif
  NBTEX = Z
Return

$VERF_SELMGG2VAL
  #Sélection des valeurs possibles de critère
Return
#####################################################################

#####################################################################
$SEL_SELTGL1FIE
Local Integer Z
Local Integer Z2
Local Char SZTIT(100)
Local Char SZFIENAMX

  #Sélection d'un champ de tri d'une cible
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  Z = 0
  SZTIT = ""
  SZFIENAMX = ""
  For Z2 = 0 To [M:TGL2]NBFIE-1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    Z += 1
    TEX(Z) = [M:TGL2]TGRFIE(Z2)
    Read [ATZ]CODZONE=[M:TGL2]TGRTABLNK(Z2);[M:TGL2]TGRFIE(Z2)
    If fstat Then
      TEXTE(Z) = [M:TGL2]TGRFIE(Z2)
    Else
      If [F:ATZ]CODACT = "" or ([F:ATZ]CODACT <> "" and func ASYRFNC.ACTIV([F:ATZ]CODACT) = [V]CST_ATRUE) Then  # FGR 26/08/2016 : X3SUIVI117480
        If func CRMUTIL150.IS_TBLFIELD_USABLE([F:ATZ]CODFIC, [F:ATZ]CODZONE) = [V]CST_AYES Then # FGR 04/02/2015 : X3SUIVI105938
          Call TEXTE([F:ATZ]NOLONG, SZFIENAMX) From OBJDIV
          TEXTE(Z) = [M:TGL2]TGRFIE(Z2) - "-" - SZFIENAMX
        Endif
      Endif
    Endif
  Next
  NBTEX = Z
  SZTIT = mess(376,196,1) #Liste des champs
  TIT = left$(SZTIT, 50)
Return

$VERF_SELTGL1FIE
  #Sélection d'un champ de tri d'une cible
Return
