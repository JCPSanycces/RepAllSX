#####################################################################
$SEL_SELMGG2VA2
Local Char CODFIC(GLONATB)
Local Char SZLEFTCRIFIE(GLONAVA)

  #Sélection des valeurs possibles de critère sur la base d'un objet
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
  If !clalev([F:AOB]) : Local File AOBJET [AOB] : Endif
  If PARAM(1) = "" Then
    #Aucun code de table n'a été mentionné.
    GMESSAGE = mess(587,196,1)
    GERR = 3
    Return
  Elsif PARAM(2) = "" Then
    #Aucun nom de champ n'a été mentionné.
    GMESSAGE = mess(588,196,1)
    GERR = 3
    Return
  Endif
  SZLEFTCRIFIE = func CRMUTIL150.GET_CHAMP_SSIND(PARAM(2)) # FGR 12/01/2009 : X3SUIVI51579
  Read [ATZ]CODZONE=PARAM(1);SZLEFTCRIFIE
  If fstat Then
    #Erreur lors de la recherche des éléments de la liste.
    GMESSAGE = mess(589,196,1)
    GERR = 1
    Return
  Endif
  #If func CRMUTIL150.IS_TBLFIELD_USABLE([F:ATZ]CODFIC, [F:ATZ]CODZONE) = [V]CST_AYES Then # FGR 04/02/2015 : X3SUIVI105938
  If func CRMUTIL150.IS_TBLFIELD_USABLE([F:ATZ]CODFIC, [F:ATZ]CODZONE) = [V]CST_ANO Then   # FGR 30/06/2016 : X3SUIVI117419
    #Erreur lors de la recherche des éléments de la liste.
    GMESSAGE = mess(589,196,1)
    GERR = 1
    Return
  Endif
  If ([F:ATZ]CODACT <> "" and func ASYRFNC.ACTIV([F:ATZ]CODACT) = [V]CST_AFALSE) Then  # FGR 26/08/2016 : X3SUIVI117480
    #Erreur lors de la recherche des éléments de la liste.
    GMESSAGE = mess(589,196,1)
    GERR = 1
    Return
  Endif
  If [F:ATZ]CODTYP = "" Then
    #Erreur lors de la recherche des éléments de la liste.
    GMESSAGE = mess(589,196,1)
    GERR = 1
    Return
  Else
    Read [ATY]CODTYP=[F:ATZ]CODTYP
    If fstat Then
      #Erreur lors de la recherche des éléments de la liste.
      GMESSAGE = mess(589,196,1)
      GERR = 1
      Return
    Else
      If [F:ATY]OBJLIEN = "" Then
        #Il n'y a pas de sélection possible associée à ce champ.
        GMESSAGE = mess(597,196,1)
        GERR = 3
        Return
      Else
        Read [AOB]ABREV=[F:ATY]OBJLIEN
        If !fstat Then
          OBJET = [F:ATY]OBJLIEN
        Endif
      Endif
    Endif
  Endif
Return

$VERF_SELMGG2VA2
  #Sélection des valeurs possibles de critère sur la base d'un objet
Return
#####################################################################

#####################################################################
$SEL_SELMGG2VA3
Local Char CODFIC(GLONATB)
Local Char SZCRITABCOD
Local Char SZDESCRIPT(100)
Local Char SZLEFTCRIFIE(GLONAVA)

  #Sélection des valeurs possibles de critère
  If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
  If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
  If !clalev([F:ATI]) : Local File ATABIND [ATI] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  If PARAM(1) = "" Then
    #Aucun code de table n'a été mentionné.
    GMESSAGE = mess(587,196,1)
    GERR = 3
    Return
  Elsif PARAM(2) = "" Then
    #Aucun nom de champ n'a été mentionné.
    GMESSAGE = mess(588,196,1)
    GERR = 3
    Return
  Endif
  SZLEFTCRIFIE = func CRMUTIL150.GET_CHAMP_SSIND(PARAM(2)) # FGR 12/01/2009 : X3SUIVI51579
  SZCRITABCOD = PARAM(1) + '|' + SZLEFTCRIFIE
  CODFIC = ""
  SZDESCRIPT = ""
  Read [DVA]DVA0="MGV";SZCRITABCOD
  If fstat Then
    Return
  Else
    If [F:DVA]ALHX(0) = "" Then
      Return
    Endif
    Read [ATB]CODFIC=[F:DVA]ALHX(0)
    If fstat Then
      Return
    Else
      #Contrôle tout d'abord si la cible souhaitée comporte une clé par défaut à composante unique.
      Filter [ATI] Where [F:ATI]CODFIC = [F:ATB]CODFIC Order By [F:ATI]CODIND Asc
      For [ATI]
        SZDESCRIPT = [F:ATI]DESCRIPT
        Break
      Next
      Filter [ATI]
      If SZDESCRIPT = "" Then
        Return
      Endif
      If instr(1, SZDESCRIPT, "+") Then
        Return
      Endif
      #Vérifie si le champ indiqué fait partie de la table saisie
      Read [ATZ]CODZONE=[F:ATB]CODFIC;SZDESCRIPT
      If fstat Then
        Return
      Endif
      #If func CRMUTIL150.IS_TBLFIELD_USABLE([F:ATZ]CODFIC, [F:ATZ]CODZONE) = [V]CST_AYES Then # FGR 04/02/2015 : X3SUIVI105938
      If func CRMUTIL150.IS_TBLFIELD_USABLE([F:ATZ]CODFIC, [F:ATZ]CODZONE) = [V]CST_ANO Then   # FGR 30/06/2016 : X3SUIVI117419
        Return
      Endif
      If ([F:ATZ]CODACT <> "" and func ASYRFNC.ACTIV([F:ATZ]CODACT) = [V]CST_AFALSE) Then  # FGR 26/08/2016 : X3SUIVI117480
        Return
      Endif
      Local File =[F:ATB]CODFIC [VA3X]
      Default File [VA3X]
      CODFIC = [F:ATB]CODFIC
      CRITERE = SZDESCRIPT + " >= VALEUR"
      START = SZDESCRIPT #Start doit contenir le nom du champs de clé de l'objet.
      ORDRE = SZDESCRIPT
      TIT(0) = mess(8,31,1)   #Sélection
      NBCOL = 0
      NBCOL += 1 : COL(NBCOL) = SZDESCRIPT : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
      If [F:ATB]INTIT <> "" Then
        NBCOL += 1 : COL(NBCOL) = [F:ATB]INTIT : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
      Endif
      If [F:ATB]INTITC <> "" Then
        NBCOL += 1 : COL(NBCOL) = [F:ATB]INTITC : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
      Endif
    Endif
  Endif
Return

$VERF_SELMGG2VA3
  #Sélection des valeurs possibles de critère
Return
