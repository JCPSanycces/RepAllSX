Local Char SZTABCOD(GLONATB)

  #Sélection des champs d'une table X3
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  Z = 0
  SZTIT = ""
  If PARAM(1) = "" Then
    SZTABCOD = "BPARTNER"
  Else
    SZTABCOD = PARAM(1)
  Endif
  Filter [ATZ] Where [F:ATZ]CODFIC = SZTABCOD and [F:ATZ]CODZONE >= VALEUR
  For [ATZ]CODZONE
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    If [F:ATZ]CODACT = "" or ([F:ATZ]CODACT <> "" and func ASYRFNC.ACTIV([F:ATZ]CODACT) = [V]CST_ATRUE) Then  # FGR 26/08/2016 : X3SUIVI117480
      If func CRMUTIL150.IS_TBLFIELD_USABLE([F:ATZ]CODFIC, [F:ATZ]CODZONE) = [V]CST_AYES Then # FGR 04/02/2015 : X3SUIVI105938
        Z += 1
        TEX(Z) = [F:ATZ]CODZONE
        Call TEXTE([F:ATZ]NOLONG, TEXTE(Z)) From OBJDIV
        TEXTE(Z) = [F:ATZ]CODZONE - "-" - TEXTE(Z)
      Endif
    Endif
  Next
  Filter [ATZ]
  NBTEX = Z
  SZTIT = mess(376,196,1) #Liste des champs
  TIT = left$(SZTIT, 50)
Return

$VERF_SELMST2FIE
  #Sélection des champs d'une table X3
Return
#####################################################################

#####################################################################
$SEL_SELMST2VAL
Local Integer Z
Local Integer Z3
Local Char SZTIT(100)
Local Char SZTEXTE
Local Integer IADISEPARATOR

  #Sélection des valeurs possibles de critère
  IADISEPARATOR = 0
  Z = 0
  SZTIT = ""
  SZTEXTE = ""
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  Read [ATZ]CODZONE=[M:MST2]MARTABCLA(GPRECRINOL);[M:MST2]MARSCTFIE(GPRECRINOL)
  If fstat Then
    Return
  Endif
  #If func CRMUTIL150.IS_TBLFIELD_USABLE([F:ATZ]CODFIC, [F:ATZ]CODZONE) = [V]CST_AYES Then # FGR 04/02/2015 : X3SUIVI105938
  If func CRMUTIL150.IS_TBLFIELD_USABLE([F:ATZ]CODFIC, [F:ATZ]CODZONE) = [V]CST_ANO Then   # FGR 30/06/2016 : X3SUIVI117419
    Return
  Endif
  If ([F:ATZ]CODACT <> "" and func ASYRFNC.ACTIV([F:ATZ]CODACT) = [V]CST_AFALSE) Then  # FGR 26/08/2016 : X3SUIVI117480
    Return
  Endif
  If [F:ATZ]CODTYP = "ADI" Then
    IADISEPARATOR = instr(1, [F:ATZ]EXPLIEN, ";")
    IADISEPARATOR -= 1
    Filter [ADI] Where [F:ADI]NUMTAB = val(left$([F:ATZ]EXPLIEN, IADISEPARATOR)) Order By [F:ADI]CODE Asc
    For [ADI]
      Z += 1
      If Z >= dim(TEX)-1 Then
        Break
      Endif
      Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, SZTEXTE) From CRM_UTIL
      TEX(Z) = [F:ADI]CODE
      TEXTE(Z) = SZTEXTE
    Next
    Filter [ADI]
  Elsif [F:ATZ]CODTYP = "M" or [F:ATZ]CODTYP = "MM" Then
    Z3 = 1
    While mess(Z3, [F:ATZ]NOLIB, 2) <> ""
      Z += 1
      If Z >= dim(TEX)-1 Then
        Break
      Endif
      SZTEXTE = mess(Z3,[F:ATZ]NOLIB,1)
      TEX(Z) = num$(Z3)
      TEXTE(Z) = SZTEXTE
      Z3 += 1
    Wend
  Endif
  NBTEX = Z
Return

$VERF_SELMST2VAL
  #Sélection des valeurs possibles de critère
Return
