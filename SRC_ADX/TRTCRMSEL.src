#####################################################################
$SEL_SELMKG2TAW
Local Integer Z
Local Char SZTIT(100)

  #Sélection d'une table X3
  If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
  Z = 0
  SZTIT = ""
  Filter [ATB] Where [F:ATB]CODFIC >= VALEUR
  For [ATB]CODFIC
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    Z += 1
    TEX(Z) = [F:ATB]CODFIC
    Call TEXTE([F:ATB]INTITFIC, TEXTE(Z)) From OBJDIV
    TEXTE(Z) = [F:ATB]CODFIC - "-" - TEXTE(Z)
  Next
  Filter [ATB]
  NBTEX = Z
  SZTIT = mess(31,9021,1) #Liste des tables
  TIT = left$(SZTIT, 50)
Return

