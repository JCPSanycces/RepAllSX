#####################################################################
$SEL_SELMOTIF2
Local Integer Z
Local Char SZTIT
Local Char SZINTSHO

  #Sélection des motifs liés à l'étape avant-vente sélectionnée
  SZINTSHO = ""
  SZTIT = ""
  Z = 0
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  Filter [ADI] Where [F:ADI]NUMTAB = val(PARAM(2))
  For [ADI]
    Call GET_LIBSHO([F:ADI]NUMTAB, [F:ADI]CODE, SZINTSHO) From CRM_UTIL
    If SZINTSHO = PARAM(1) Then
      Z += 1
      Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, TEX(Z)) From CRM_UTIL
      Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, TEXTE(Z)) From CRM_UTIL
    Endif
  Next
  NBTEX = Z
  Filter [ADI]
  SZTIT = mess(219,196,1)
  TIT = left$(SZTIT, 50)
Return

$VERF_SELMOTIF2
  #Sélection des motifs liés à l'étape avant-vente sélectionnée
Return
#####################################################################

#####################################################################
$SEL_SELSCPREP
Local Integer Z
Local Integer Z2
Local Integer Z3
Local Integer TOTZ2
Local Integer ISTOP
Local Char SZTIT(100)
Local Char SZCNDTYP
Local Char SZTEXTE
Local Char SZMID
Local Integer ICNDTYP
Local Integer ITFOUND

  #Sélection des réponses possibles à un script
  Z = 0
  Z2 = 0
  Z3 = 0
  TOTZ2 = 0
  SZTIT = ""
  ISTOP = 0
  SZCNDTYP = ""
  ICNDTYP = 0
  SZTEXTE = ""
  SZMID = ""
  ITFOUND = 0
  Filter [SQC] Where [F:SQC]SCPNUM = [M:SCP1]SCPNUM and [F:SQC]QSTNUM = [M:SCP1]QSTNUM and [F:SQC]CND = 3
  For [SQC] SQC2
    Z += 1
    If Z >= dim(TEX)-1 Then
      ISTOP = 1
      Break
    Endif
    SZTEXTE = " -> " + [F:SQC]ALHCND
    TEX(Z) = [F:SQC]ALHCND
    TEXTE(Z) = SZTEXTE
  Next
  Filter [SQC]
  If !ISTOP Then
    Filter [SQC] Where [F:SQC]SCPNUM = [M:SCP1]SCPNUM and [F:SQC]QSTNUM = [M:SCP1]QSTNUM and [F:SQC]CND = 4
    For [SQC] SQC2
      Z += 1
      If Z >= dim(TEX)-1 Then
        ISTOP = 1
        Break
      Endif
      SZTEXTE = " -> " + [F:SQC]ALHCND
      TEX(Z) = [F:SQC]ALHCND
      TEXTE(Z) = SZTEXTE
    Next
    Filter [SQC]
  Endif
  If !ISTOP Then
    Filter [SQC] Where [F:SQC]SCPNUM = [M:SCP1]SCPNUM and [F:SQC]QSTNUM = [M:SCP1]QSTNUM and [F:SQC]CND = 5
    For [SQC] SQC2
      Z += 1
      If Z >= dim(TEX)-1 Then
        ISTOP = 1
        Break
      Endif
      SZTEXTE = " -> " + [F:SQC]ALHCND
      TEX(Z) = [F:SQC]ALHCND
      TEXTE(Z) = SZTEXTE
    Next
    Filter [SQC]
  Endif
  NBTEX = Z
  SZTIT = mess(375,196,1) #Réponses possibles.
  TIT = left$(SZTIT, 50)
  If [M:SCP1]ASWFIE = ""
    Return
  Endif
  #Ajout des autres réponses possibles non définies dans le script.
  If Z > 0 Then
    TOTZ2 = Z
    Z += 1
    TEX(Z) = ""
    TEXTE(Z) = "---------------------"
  Endif
  ITFOUND = 0
  If GXSZCNDTYP = "ADI" Then
    If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
    Filter [ADI] Where [F:ADI]NUMTAB = GXICNDTYP Order By [F:ADI]CODE Asc
    For [ADI]
      If !ITFOUND Then
        Z += 1
      Endif
      If Z >= dim(TEX)-1 Then
        Break
      Endif
      Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, SZTEXTE) From CRM_UTIL
      ITFOUND = 0
      For Z2 = 1 To TOTZ2
        If TEXTE(Z2) <> "" Then
          SZMID = mid$(TEXTE(Z2), 5, len(TEXTE(Z2))-4)
        Endif
        If SZTEXTE = SZMID Then
          ITFOUND = 1
          TEX(Z2) = [F:ADI]CODE
          Break
        Endif
      Next
      If !ITFOUND Then
        TEX(Z) = [F:ADI]CODE
        TEXTE(Z) = SZTEXTE
      Endif
    Next
    Filter [ADI]
  Endif
  Z3 = 0
  ITFOUND = 0
  If GXSZCNDTYP = "M" Then
    While mess(Z3, GXICNDTYP, 2) <> ""
      If !ITFOUND Then
        Z += 1
      Endif
      Z3 += 1
      If Z >= dim(TEX)-1 Then
        Break
      Endif
      SZTEXTE = mess(Z3,GXICNDTYP,1)
      ITFOUND = 0
      For Z2 = 1 To TOTZ2
        If TEXTE(Z2) <> "" Then
          SZMID = mid$(TEXTE(Z2), 5, len(TEXTE(Z2))-4)
        Endif
        If SZTEXTE = SZMID Then
          ITFOUND = 1
          TEX(Z2) = num$(Z3)
          Break
        Endif
      Next
      If !ITFOUND Then
        TEX(Z) = num$(Z3)
        TEXTE(Z) = SZTEXTE
      Endif
    Wend
  Endif
  NBTEX = Z
Return

$VERF_SELSCPREP
  #Sélection des réponses possibles à un script
Return
#####################################################################

#####################################################################
$SEL_SELFIETAB
Local Integer Z
Local Char SZTIT(100)
Local Char SZLIBTEX
Local Integer ITYPFOUND

  #Sélection des champs d'une table
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
  Z = 0
  SZTIT = ""
  SZLIBTEX = ""
  ITYPFOUND = 0
  If [M:PHX8]ASWTAB = 1 Then
    Filter [ATZ] Where [F:ATZ]CODFIC = "BPARTNER"
  Elsif [M:PHX8]ASWTAB = 2 Then
    Filter [ATZ] Where [F:ATZ]CODFIC = "BPCUSTOMER"
  Elsif [M:PHX8]ASWTAB = 3 Then
    Filter [ATZ] Where [F:ATZ]CODFIC = "CONTACTCRM"
  Endif
  For [ATZ]CODZONE
    If [F:ATZ]CODACT = "" or ([F:ATZ]CODACT <> "" and func ASYRFNC.ACTIV([F:ATZ]CODACT) = [V]CST_ATRUE) Then  # FGR 26/08/2016 : X3SUIVI117480
      If func CRMUTIL150.IS_TBLFIELD_USABLE([F:ATZ]CODFIC, [F:ATZ]CODZONE) = [V]CST_AYES Then # FGR 04/02/2015 : X3SUIVI105938
        ITYPFOUND = 0
        If Z >= dim(TEX)-1 Then
          Break
        Endif
        Case [F:ATZ]CODTYP
          When "A"
            ITYPFOUND = 1
            If [M:PHX8]QSTTYP = 1 Then
              Z += 1
              Call TEXTE([F:ATZ]NOCOURT, SZLIBTEX) From OBJDIV
              TEX(Z) = [F:ATZ]CODZONE
              TEXTE(Z) = [F:ATZ]CODZONE - "-" - SZLIBTEX
            Endif
          When "L", "C", "DCB"
            ITYPFOUND = 1
            If [M:PHX8]QSTTYP = 2 Then
              Z += 1
              Call TEXTE([F:ATZ]NOCOURT, SZLIBTEX) From OBJDIV
              TEX(Z) = [F:ATZ]CODZONE
              TEXTE(Z) = [F:ATZ]CODZONE - "-" - SZLIBTEX
            Endif
          When "D"
            ITYPFOUND = 1
            If [M:PHX8]QSTTYP = 3 Then
              Z += 1
              Call TEXTE([F:ATZ]NOCOURT, SZLIBTEX) From OBJDIV
              TEX(Z) = [F:ATZ]CODZONE
              TEXTE(Z) = [F:ATZ]CODZONE - "-" - SZLIBTEX
            Endif
          When "M"
            ITYPFOUND = 1
            If [F:ATZ]NOLIB = 1 Then
              If [M:PHX8]QSTTYP = 4 Then
                Z += 1
                Call TEXTE([F:ATZ]NOCOURT, SZLIBTEX) From OBJDIV
                TEX(Z) = [F:ATZ]CODZONE
                TEXTE(Z) = [F:ATZ]CODZONE - "-" - SZLIBTEX
              Endif
            Else
              If [M:PHX8]QSTTYP = 1 Then
                Z += 1
                Call TEXTE([F:ATZ]NOCOURT, SZLIBTEX) From OBJDIV
                TEX(Z) = [F:ATZ]CODZONE
                TEXTE(Z) = [F:ATZ]CODZONE - "-" - SZLIBTEX
              Endif
            Endif
          When Default
        Endcase
        If !ITYPFOUND Then
          Read [ATY] CODTYP = [F:ATZ]CODTYP
          If !fstat Then
            Case [F:ATY]TYPTYP
              When 2,3,4,5,6
                If [M:PHX8]QSTTYP = 2 Then
                  Z += 1
                  Call TEXTE([F:ATZ]NOCOURT, SZLIBTEX) From OBJDIV
                  TEX(Z) = [F:ATZ]CODZONE
                  TEXTE(Z) = [F:ATZ]CODZONE - "-" - SZLIBTEX
                Endif
              When 7
                If [M:PHX8]QSTTYP = 1 Then
                  Z += 1
                  Call TEXTE([F:ATZ]NOCOURT, SZLIBTEX) From OBJDIV
                  TEX(Z) = [F:ATZ]CODZONE
                  TEXTE(Z) = [F:ATZ]CODZONE - "-" - SZLIBTEX
                Endif
              When 8
                If [M:PHX8]QSTTYP = 3 Then
                  Z += 1
                  Call TEXTE([F:ATZ]NOCOURT, SZLIBTEX) From OBJDIV
                  TEX(Z) = [F:ATZ]CODZONE
                  TEXTE(Z) = [F:ATZ]CODZONE - "-" - SZLIBTEX
                Endif
              When Default
            Endcase
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [ATZ]
  NBTEX = Z
  SZTIT = mess(376,196,1) #Liste des champs.
  TIT = left$(SZTIT, 50)
Return

#####################################################################
$VERF_SELFIETAB
  #Sélection des champs d'une table
Return
#####################################################################

#####################################################################
$SEL_SELCNDREP
Local Integer Z
Local Char SZTIT(100)
Local Char SLCNDTYP(10)
Local Integer NICNDTYP

  #Sélection des réponses associées à un champs de stockage.
  # FGR 07/11/2008 : Suite modif script, l'un ou l'autre permet de continuer a faire
  #                  fonctionner la saisie des scripts soit avec l'ancienne méthode soit avec la nouvelle
  #                  A TERME la technique basée sur la globale devrait disparaitre
  If dim([M:PHX8]CNDTYP) > 0 Then
    SLCNDTYP= [M:PHX8]CNDTYP
    NICNDTYP = [M:PHX8]ICNDTYP
  Elsif dim(GICNDTYP) > 0 Then
    SLCNDTYP= GSZCNDTYP
    NICNDTYP = GICNDTYP
  Endif
  Z = 0
  SZTIT = ""
  If SLCNDTYP = "ADI" Then
    If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
    Filter [ADI] Where [F:ADI]NUMTAB = NICNDTYP Order By [F:ADI]CODE Asc
    For [ADI]
      Z += 1
      If Z >= dim(TEX)-1 Then
        Break
      Endif
      TEX(Z) = [F:ADI]CODE
      Call GET_LIB([F:ADI]NUMTAB, [F:ADI]CODE, TEXTE(Z)) From CRM_UTIL
    Next
    Filter [ADI]
    If dim([M:PHX8]MUSTCONV) > 0 Then
      [M:PHX8]MUSTCONV = 1
    Endif
    If dim(GMUSTCONVERT) > 0 Then
      GMUSTCONVERT = 1
    Endif
  Elsif SLCNDTYP = "M" Then
    While mess(Z,NICNDTYP,1) <> ""
      Z += 1
      If Z >= dim(TEX)-1 Then
        Break
      Endif
      TEX(Z) = num$(Z)
      TEXTE(Z) = mess(Z,NICNDTYP,1)
    Wend
    If dim([M:PHX8]MUSTCONV) > 0 Then
      [M:PHX8]MUSTCONV = 1
    Endif
    If dim(GMUSTCONVERT) > 0 Then
      GMUSTCONVERT = 1
    Endif
  Endif
  NBTEX = Z
  SZTIT = mess(375,196,1) #Réponses possibles.
  TIT = left$(SZTIT, 50)
Return

$VERF_SELCNDREP
  #Sélection des réponses associées à un champs de stockage.
Return
#####################################################################

#####################################################################
$SEL_SELCLL2OPG
Local Integer Z
Local Integer ITITLE
Local Char SZTIT(100)

  #Sélection des opérations marketing d'une campagne mentionnée sur l'appel
  Z = 0
  ITITLE = 0
  SZTIT = ""
  If !clalev([F:OMM]) : Local File MAILING [OMM] : Endif
  If !clalev([F:OMP]) : Local File PHONING [OMP] : Endif
  If !clalev([F:OMT]) : Local File TRADESHOW [OMT] : Endif
  If !clalev([F:OMN]) : Local File MEDIA [OMN] : Endif
  Filter [OMM] Where [F:OMM]CMGNUM = [M:CLL2]CLLCMGNUM Order By [F:OMM]OMMNUM
  ITITLE = 0
  For [OMM]
    If !ITITLE Then
      Z += 1
      TEX(Z) = ""
      TEXTE(Z) = "-----" - mess(379,196,1) - "-----" #Publipostages
      ITITLE = 1
    Endif
    Z += 1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    TEX(Z) = "OMM" + [F:OMM]OMMNUM
    TEXTE(Z) = left$([F:OMM]DES, 50)
  Next
  Filter [OMM]
  Filter [OMP] Where [F:OMP]CMGNUM = [M:CLL2]CLLCMGNUM Order By [F:OMP]OMPNUM
  ITITLE = 0
  For [OMP]
    If !ITITLE Then
      Z += 1
      TEX(Z) = ""
      TEXTE(Z) = "-----" - mess(380,196,1) - "-----" #Campagnes d'appels
      ITITLE = 1
    Endif
    Z += 1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    TEX(Z) = "OMP" + [F:OMP]OMPNUM
    TEXTE(Z) = left$([F:OMP]DES, 50)
  Next
  Filter [OMP]
  Filter [OMT] Where [F:OMT]CMGNUM = [M:CLL2]CLLCMGNUM Order By [F:OMT]OMTNUM
  ITITLE = 0
  For [OMT]
    If !ITITLE Then
      Z += 1
      TEX(Z) = ""
      TEXTE(Z) = "-----" - mess(381,196,1) - "-----" #Salons professionnels
      ITITLE = 1
    Endif
    Z += 1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    TEX(Z) = "OMT" + [F:OMT]OMTNUM
    TEXTE(Z) = left$([F:OMT]DES, 50)
  Next
  Filter [OMT]
  Filter [OMN] Where [F:OMN]CMGNUM = [M:CLL2]CLLCMGNUM Order By [F:OMN]OMNNUM
  ITITLE = 0
  For [OMN]
    If !ITITLE Then
      Z += 1
      TEX(Z) = ""
      TEXTE(Z) = "-----" - mess(382,196,1) - "-----" #Campagnes presse
      ITITLE = 1
    Endif
    Z += 1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    TEX(Z) = "OMN" + [F:OMN]OMNNUM
    TEXTE(Z) = left$([F:OMN]DES, 50)
  Next
  Filter [OMN]
  NBTEX = Z
  SZTIT = mess(378,196,1) #Opérations marketing
  TIT = left$(SZTIT, 50)
Return

$VERF_SELCLL2OPG
  #Sélection des opérations marketing d'une campagne mentionnée sur l'appel
Return
