$SEL_SELTGP1FIE
Local Integer Z
Local Integer Z2
Local Char SZTIT(100)
Local Char SZFIENAMX

  #Sélection d'un champ de tri d'une cible
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  Z = 0
  SZTIT = ""
  SZFIENAMX = ""
  For Z2 = 0 To [M:TGP1]NBFIE-1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    Z += 1
    TEX(Z) = [M:TGP1]TGRFIE(Z2)
    Read [ATZ]CODZONE=[M:TGP1]TGRTABLNK(Z2);[M:TGP1]TGRFIE(Z2)
    If fstat Then
      TEXTE(Z) = [M:TGP1]TGRFIE(Z2)
    Else
      If [F:ATZ]CODACT = "" or ([F:ATZ]CODACT <> "" and func ASYRFNC.ACTIV([F:ATZ]CODACT) = [V]CST_ATRUE) Then  # FGR 26/08/2016 : X3SUIVI117480
        If func CRMUTIL150.IS_TBLFIELD_USABLE([F:ATZ]CODFIC, [F:ATZ]CODZONE) = [V]CST_AYES Then # FGR 04/02/2015 : X3SUIVI105938
          Call TEXTE([F:ATZ]NOLONG, SZFIENAMX) From OBJDIV
          TEXTE(Z) = [M:TGP1]TGRFIE(Z2) - "-" - SZFIENAMX
        Endif
      Endif
    Endif
  Next
  NBTEX = Z
  SZTIT = mess(376,196,1) #Liste des champs
  TIT = left$(SZTIT, 50)
Return

$VERF_SELTGP1FIE
  #Sélection d'un champ de tri d'une cible
Return
#####################################################################

#####################################################################
$SEL_SELTGL1TAB
Local Integer Z
Local Integer Z2
Local Char SZTABNAM

  #Sélection d'une table du champ de tri d'une cible
  If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
  Z = 0
  SZTIT = ""
  SZTABNAM = ""
  For Z2 = 0 To [M:TGL2]NBFIE-1
    If [M:TGL2]TGRFIE(Z2) = PARAM(1) Then
      If Z >= dim(TEX)-1 Then
        Break
      Endif
      Z += 1
      TEX(Z) = [M:TGL2]TGRTABLNK(Z2)
      Read [ATB]CODFIC=[M:TGL2]TGRTABLNK(Z2)
      If fstat Then
        TEXTE(Z) = [M:TGL2]TGRTABLNK(Z2)
      Else
        Call TEXTE([F:ATB]INTITFIC, SZTABNAM) From OBJDIV
        TEXTE(Z) = [M:TGL2]TGRTABLNK(Z2) - '-' - SZTABNAM
      Endif
    Endif
  Next
  NBTEX = Z
  TIT = mess(599,196,1) #Tables liées
Return

$VERF_SELTGL1TAB
  #Sélection d'une table du champ de tri d'une cible
Return
#####################################################################

#####################################################################
$SEL_SELTGP1TAB
Local Integer Z
Local Integer Z2
Local Char SZTABNAM

  #Sélection d'une table du champ de tri d'une cible
  If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
  Z = 0
  SZTIT = ""
  SZTABNAM = ""
  For Z2 = 0 To [M:TGP1]NBFIE-1
    If [M:TGP1]TGRFIE(Z2) = PARAM(1) Then
      If Z >= dim(TEX)-1 Then
        Break
      Endif
      Z += 1
      TEX(Z) = [M:TGP1]TGRTABLNK(Z2)
      Read [ATB]CODFIC=[M:TGP1]TGRTABLNK(Z2)
      If fstat Then
        TEXTE(Z) = [M:TGP1]TGRTABLNK(Z2)
      Else
        Call TEXTE([F:ATB]INTITFIC, SZTABNAM) From OBJDIV
        TEXTE(Z) = [M:TGP1]TGRTABLNK(Z2) - '-' - SZTABNAM
      Endif
    Endif
  Next
  NBTEX = Z
  TIT = mess(599,196,1) #Tables liées
Return

$VERF_SELTGP1TAB
  #Sélection d'une table du champ de tri d'une cible
Return
#####################################################################

#####################################################################
$SEL_SELTGL2LNK
Local Integer Z
Local Char SZTABINTIT

  #Sélection d'une table liée
  SZTABINTIT = ""
  Z = 0
  #Param(1) = Table cible.
  If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
  #On met d'abord la table cible
  Z += 1
  TEX(Z) = PARAM(1)
  TEXTE(Z) = PARAM(1)
  Read [ATB]CODFIC=PARAM(1)
  If !fstat Then
    Call TEXTE([F:ATB]INTITFIC, SZTABINTIT) From OBJDIV
    TEXTE(Z) = TEXTE(Z) - '-' - SZTABINTIT
  Endif
  #Ensuite les tables liées
  Filter [TLL] Where [F:TLL]TGRTAB = PARAM(1) Order By [F:TLL]TGRLNK Asc
  For [TLL]
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    Z += 1
    TEX(Z) = [F:TLL]TGRLNK
    TEXTE(Z) = [F:TLL]TGRLNK
    Read [ATB]CODFIC=[F:TLL]TGRLNK
    If !fstat Then
      Call TEXTE([F:ATB]INTITFIC, SZTABINTIT) From OBJDIV
      TEXTE(Z) = TEXTE(Z) - '-' - SZTABINTIT
    Endif
  Next
  Filter [TLL]
  NBTEX = Z
  TIT = mess(599,196,1) #Tables liées
Return

$VERF_SELTGL2LNK
  #Sélection d'une table liée
Return
#####################################################################

#####################################################################
$SEL_SELRPTSCP
Local Integer Z
Local Integer IREPFOUND

  #Sélection d'un script depuis l'état SCPASW1
  If !clalev([F:SCP]) : Local File SCRIPT [SCP] : Endif
  If !clalev([F:SCA]) : Local File SCPASW [SCA] : Endif
  IREPFOUND = 0
  Z = 0
  Filter [SCP] Where [F:SCP]SCPNUM >= VALEUR
  For [SCP]
    IREPFOUND = 0
    Filter [SCA] Where [F:SCA]SCP = [F:SCP]SCPNUM
    For [SCA]
      IREPFOUND = 1
      Break
    Next
    Filter [SCA]
    If IREPFOUND Then
      Z += 1
      If Z >= dim(TEX)-1 Then
        Break
      Endif
      TEX(Z) = [F:SCP]SCPNUM
      TEXTE(Z) = [F:SCP]SCPNUM - '-' - [F:SCP]SCPNAM
    Endif
  Next
  Filter [SCP]
  NBTEX = Z
  TIT = mess(8,31,1) #Sélection
Return

$VERF_SELRPTSCP
  #Sélection d'un script depuis l'état SCPASW1
Return
#####################################################################

#####################################################################
$SEL_SELSSP2PAE
Local Integer Z
Local Integer Z2
Local Integer ZNOL
Local Integer IFOUND
Local Integer ILEVEL
Local Char SZTABNAM

  #Sélection d'une table parent parmi les composants d'un suppport de sélection
  If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
  Z = 0
  ZNOL = nolign-1
  IFOUND  = 0
  SZTABNAM = ""
  ILEVEL = [M:SSP2]SPTLEV(nolign-1)-1
  #Niveau 1
  If [M:SSP2]SPTLEV(nolign-1) = 1 Then
    Read [ATB]CODFIC=[M:SSP0]SPTTGR
    If fstat Then
      Return
    Else
      Z += 1
      TEX(Z) = [M:SSP0]SPTTGR
      SZTABNAM = ""
      Call TEXTE([F:ATB]INTITFIC, SZTABNAM) From OBJDIV
      TEXTE(Z) = [M:SSP0]SPTTGR - '-' - SZTABNAM
      NBTEX = Z
      TIT = mess(686,196,1) #Tables parents
      Return
    Endif
  Endif
  #Niveau supérieur à 1
  If [M:SSP2]SPTLEV(nolign-1) > 1 Then
    For Z2 = 0 To [M:SSP2]NBCPN-1
      If [M:SSP2]SPTLEV(Z2) = ILEVEL Then
        If Z2 <> ZNOL Then
          #Vérifie si la table parent n'est pas déjà dans la liste
          IFOUND = 0
          For Z3 = 1 To dim(TEX)-1
            If TEX(Z3) = "" Then
              Break
            Endif
            If TEX(Z3) <> "" Then
              If [M:SSP2]SPTTAB(Z2) <> "" Then
                If [M:SSP2]SPTTAB(Z2) = TEX(Z3) Then
                  IFOUND = 1
                Endif
              Endif
            Endif
          Next
          If !IFOUND Then
            If Z >= dim(TEX)-1 Then
              Break
            Endif
            Read [ATB]CODFIC=[M:SSP2]SPTTAB(Z2)
            If !fstat Then
              Z += 1
              TEX(Z) = [M:SSP2]SPTTAB(Z2)
              SZTABNAM = ""
              Call TEXTE([F:ATB]INTITFIC, SZTABNAM) From OBJDIV
              TEXTE(Z) = [M:SSP2]SPTTAB(Z2) - '-' - SZTABNAM
            Endif
          Endif
        Endif
      Endif
    Next
  Else
    Return
  Endif
  NBTEX = Z
  TIT = mess(686,196,1) #Tables parents
Return

$VERF_SELSSP2PAE
  #Sélection d'une table parent parmi les composants d'un suppport de sélection
Return
#####################################################################

#####################################################################
$SEL_SELSSP2IDX
Local Integer Z

  #Sélection d'un index pour un composant de support de sélection
  If [M:SSP2]SPTTAB(nolign-1) = "" Then
    Return
  Endif
  If [M:SSP2]SPTKEY(nolign-1) = "" Then
    Return
  Endif
  If !clalev([F:ATI]) : Local File ATABIND [ATI] : Endif
  Z = 0
  Filter [ATI] Where [F:ATI]CODFIC = [M:SSP2]SPTTAB(nolign-1) Order By [F:ATI]CODIND Asc
  For [ATI]
    If instr(1, [F:ATI]DESCRIPT, [M:SSP2]SPTKEY(nolign-1)) Then
      Z += 1
      If Z >= dim(TEX)-1 Then
        Break
      Endif
      TEX(Z) = [F:ATI]CODIND
      TEXTE(Z) = [F:ATI]CODIND - '-' - [F:ATI]DESCRIPT
    Endif
  Next
  Filter [ATI]
  NBTEX = Z
  TIT = mess(8,31,1) #Sélection
Return

$VERF_SELSSP2IDX
  #Sélection d'un index pour un composant de support de sélection
Return
#####################################################################

#####################################################################
$SEL_SELTGL3IDX
Local Integer Z

  #Sélection d'un index pour une table liée à une cible
  If [M:TGL3]TGRLNK(nolign-1) = ""
    Return
  Endif
  If !clalev([F:ATI]) : Local File ATABIND [ATI] : Endif
  Z = 0
  Filter [ATI] Where [F:ATI]CODFIC = [M:TGL3]TGRLNK(nolign-1) Order By [F:ATI]CODIND Asc
  For [ATI]
    Z += 1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    TEX(Z) = [F:ATI]CODIND
    TEXTE(Z) = [F:ATI]CODIND - '-' - [F:ATI]DESCRIPT
  Next
  Filter [ATI]
  NBTEX = Z
  TIT = mess(8,31,1) #Sélection
Return

$VERF_SELTGL3IDX
  #Sélection d'un index pour une table liée à une cible
Return
#####################################################################

#####################################################################
$SEL_SELTGL3AOB
Local Integer Z
Local Char SZAOBNAM

  #Sélection d'un objet pour une cible
  If !clalev([F:AOB]) : Local File AOBJET [AOB] : Endif
  Z = 0
  SZAOBNAM = ""
  Filter [AOB] Where [F:AOB]NOMFIC = [M:TGL0]TGRTAB
  For [AOB]NOMFIC
    Z += 1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    TEX(Z) = [F:AOB]ABREV
    SZAOBNAM = ""
    Call TEXTE([F:AOB]LIBEL, SZAOBNAM) From OBJDIV
    TEXTE(Z) = [F:AOB]ABREV - '-' - SZAOBNAM
  Next
  Filter [AOB]
  NBTEX = Z
  TIT = mess(8,31,1) #Sélection
Return

$VERF_SELTGL3AOB
  #Sélection d'un objet pour une cible
Return
#####################################################################

#####################################################################
$SEL_SELTGL3TAB
Local Integer Z
Local Integer ITERLIS
Local Integer ITABF
Local Char SZTABNAM

  #Sélection d'une table liée pour une cible sur la base de support de sélections existants
  If !clalev([F:SSP]) : Local File SELSSP [SSP] : Endif
  If !clalev([F:SSC]) : Local File SELSSPCPN [SSC] : Endif
  Z = 0
  ITABF = 0
  SZTABNAM = ""
  Filter [SSP] Where [F:SSP]SPTTGR = [M:TGL0]TGRTAB and [F:SSP]SPTTYP = 4
  For [SSP]SSP1
    Filter [SSC] Where [F:SSC]SPTNUM = [F:SSP]SPTNUM
    For [SSC]SSC1
      #Vérifie si la table n'est pas déjà dans la liste
      ITABF = 0
      For ITERLIS = 1 To dim(TEX)-1
        If TEX(ITERLIS) = "" Then
          Break
        Endif
        If TEX(ITERLIS) <> "" Then
          If [F:SSC]SPTTAB <> "" Then
            If TEX(ITERLIS) = [F:SSC]SPTTAB Then
              ITABF = 1
              Break
            Endif
          Endif
        Endif
      Next
      #On ajoute la table dans la liste
      If !ITABF Then
        For ITERLIS = 1 To dim(TEX)-1
          If TEX(ITERLIS) = "" Then
            Z += 1
            If Z >= dim(TEX)-1 Then
              Break
            Endif
            TEX(Z) = [F:SSC]SPTTAB
            Read [ATB]CODFIC=[F:SSC]SPTTAB
            If fstat Then
              TEXTE(Z) = [F:SSC]SPTTAB
            Else
              Call TEXTE([F:ATB]INTITFIC, SZTABNAM) From OBJDIV
              TEXTE(Z) = [F:SSC]SPTTAB - '-' - SZTABNAM
            Endif
            Break
          Endif
        Next
      Endif
      If Z >= dim(TEX)-1 Then
        Break
      Endif
    Next
    Filter [SSC]
    If Z >= dim(TEX)-1 Then
      Break
    Endif
  Next
  Filter [SSP]
  NBTEX = Z
  TIT = mess(8,31,1) #Sélection
Return

$VERF_SELTGL3TAB
  #Sélection d'une table liée pour une cible sur la base de support de sélections existants
Return
#####################################################################

#####################################################################
$SEL_SELTGL3TGL
Local Integer Z
Local Char SZTEXTE(GLONDCO)

  # FGR 23/12/2008 : X3SUIVI28171
  #Sélection d'une cible
  If !clalev([F:TGL]) : Local File TGRLIS [TGL] : Endif
  Z = 0
  If type(GSZWIZMGG) > 0 Then          # FGR 24/02/2016 : X3SUIVI114711 : seulement si on est en opération marketing
    Filter [TGL] Where TGRTAB = "BPARTNER" or TGRTAB = "BPCUSTOMER" or TGRTAB = "BPSUPPLIER" or TGRTAB = "BPCARRIER" or TGRTAB = "SALESREP"
  Endif
  For [TGL]TGL0
    Z += 1
    If Z >= dim(TEX)-1 Then
      Break
    Endif
    TEX(Z) = [F:TGL]TGRTAB
    # FGR 03/03/2009 : X3SUIVI52963 : Texte traduisible
    Call LECTEXTRA(SZTEXTE, "TGRLIS", "TGRNAMAXX", [F:TGL]TGRTAB, "") From ATEXTRA
    TEXTE(Z) = [F:TGL]TGRTAB - '-' - SZTEXTE
  Next
  Filter [TGL]
  NBTEX = Z
  TIT = mess(8,31,1) #Sélection
Return

$VERF_SELTGL3TGL
  #Sélection d'une cible
Return
#####################################################################

#####################################################################
$SEL_SELASWREP
Local Integer Z
Local Integer IREPFOUND
Local Integer ITERATOR

  #Sélection d'une réponse à un script d'appel
  If !clalev([F:SCA]) : Local File SCPASW [SCA] : Endif
  IREPFOUND = 0
  Z = 0
  ITERATOR = 1
  Filter [SCA] Where [F:SCA]ASWALH >= VALEUR Order By [F:SCA]ASWALH Asc
  For [SCA]
    If [F:SCA]ASWALH <> "" Then
      IREPFOUND = 0
      For ITERATOR = 1 To dim(TEX)-1
        If TEX(ITERATOR) = "" Then
          Break
        Endif
        If TEX(ITERATOR) = [F:SCA]ASWALH Then
          IREPFOUND = 1
          Break
        Endif
      Next
      If !IREPFOUND Then
        Z += 1
        If Z >= dim(TEX)-1 Then
          Break
        Endif
        TEX(Z) = [F:SCA]ASWALH
        TEXTE(Z) = [F:SCA]ASWALH
      Endif
    Endif
  Next
  Filter [SCA]
  NBTEX = Z
  TIT = mess(8,31,1) #Sélection
Return

$VERF_SELASWREP
  #Sélection d'une réponse à un script d'appel
Return
#####################################################################

#####################################################################
$SEL_SELSRE2ASS
Local Integer Z
Local Char SZHDKREP
Local Integer IHDKREP
Local Char SZDES(GLONDCO) # FGR 23/09/2009 : X3SUIVI58037

  #Sélection des affectations sur une demande de service
  SZHDKREP = ""
  IHDKREP = 0
  Z = 0
  Case [M:SRE2]SREASS
    When 1
      If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
      Filter [FCY] Where [F:FCY]FCY >= VALEUR
      For [FCY]
        Z += 1
        If Z >= dim(TEX)-1 Then
          Break
        Endif
        TEX(Z) = [F:FCY]FCY
        TEXTE(Z) = [F:FCY]FCY - "-" - [F:FCY]FCYNAM
      Next
      Filter [FCY]
      NBTEX = Z
      TIT = mess(264,198,1) #Sélection sites
    When 2
      If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
      Filter [AUS] Where [F:AUS]ENAFLG = 2 and [F:AUS]USR >= VALEUR
      For [AUS]
        Call PARAMUTIL("AUSHDKA", SZHDKREP, [F:AUS]USR, "") From SUBAUS
        If SZHDKREP = "" Then
          IHDKREP = 1
        Else
          IHDKREP = val(SZHDKREP)
        Endif
        If IHDKREP = 2 Then
          Z += 1
          If Z >= dim(TEX)-1 Then
            Break
          Endif
          TEX(Z) = [F:AUS]USR
          TEXTE(Z) = [F:AUS]USR - "-" - [F:AUS]NOMUSR
        Endif
      Next
      Filter [AUS]
      NBTEX = Z
      TIT = mess(262,196,1) #Collaborateurs Help-Desk
    When 3
      If !clalev([F:QUE]) : Local File QUEUE [QUE] : Endif
      Filter [QUE] Where [F:QUE]NUM >= VALEUR
      For [QUE]
        Z += 1
        If Z >= dim(TEX)-1 Then
          Break
        Endif
        TEX(Z) = [F:QUE]NUM
        # FGR 23/09/2009 : X3SUIVI58037
        #TEXTE(Z) = [F:QUE]NUM - "-" - [F:QUE]TTR
        Call LECTEXTRA(SZDES,"QUEUE","QUEDESAXX",[F:QUE]NUM,"") From ATEXTRA
        TEXTE(Z) = [F:QUE]NUM - "-" - SZDES
      Next
      Filter [QUE]
      NBTEX = Z
      TIT = mess(341,182,1) #Sélection queues
    When Default
  Endcase
Return

$VERF_SELSRE2ASS
  #Sélection des affectations sur une demande de service
Return
