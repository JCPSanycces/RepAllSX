$SEL_SELITN0SRE
Local Char CODFIC(GLONATB)

  #Sélection des demandes de services sur une intervention
  If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ]: Endif
  CODFIC = "SERREQUEST"
  Default File [SRE]
  CRITERE = "[F:SRE]SREASS <> 5"
  START = "SRENUM" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "SRENUM"
  TIT(0) = mess(260,196,1) #Demandes de services
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "SALFCY" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "SREBPC" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "SREDOO" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "SRETTR" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "SREDATASS" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "SRENUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return

$VERF_SELITN0SRE
  #Sélection des demandes de services  sur une intervention
Return
#####################################################################

#####################################################################
$SEL_SELITN0MAC
Local Char SZBPCNAM(GLONNAM)
Local Char SZCCNNAM(GLONNAC)
Local Char CODFIC(GLONATB)

  #Sélection des machines sur une intervention
  SZBPCNAM = ""
  SZCCNNAM = ""
  If !clalev([F:MAC]) : Local File MACHINES [MAC] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  If [M:ITN0]BPC = "" and [M:ITN0]CCN = "" Then
    Return
  Endif
  If [M:ITN0]BPC <> "" Then
    #Obtient le nom du tiers
    Read [BPR]BPR0=[M:ITN0]BPC
    If !fstat Then
      SZBPCNAM = [F:BPR]BPRNAM
    Endif
    TIT(0) = mess(503,196,1) - SZBPCNAM #Parc de
  Elsif [M:ITN0]BPC = "" and [M:ITN0]CCN <> "" Then
    #Obtient le nom de l'interlocuteur
    Read [AIN]AIN0=[M:ITN0]CCN
    If !fstat Then
      Call BUILDFULNAM("AIN", SZCCNNAM) From CRMUTIL140
    Endif
    TIT(0) = mess(503,196,1) - SZCCNNAM #Parc de
  Endif
  CODFIC = "MACHINES"
  Default File [MAC]
  If [M:ITN0]BPC <> "" Then
    CRITERE = "[F:MAC]BPCNUM = [M:ITN0]BPC"
  Elsif [M:ITN0]BPC = "" and [M:ITN0]CCN <> "" Then
    CRITERE = "[F:MAC]CCNNUM = [M:ITN0]CCN"
  Endif
  START = "MACNUM" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "MACNUM"
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "MACBRACLA" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "MACPDTCOD" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "MACDES" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "MACSERNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "MACITSDAT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "MACNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return

$VERF_SELITN0MAC
  #Sélection des machines sur une intervention
Return
#####################################################################

#####################################################################
$SEL_SELCON2MAC
Local Char CODFIC(GLONATB)
Local Char SZBPRNAM(GLONNAM)

  #Sélection d'un produit physique ou d'une gamme de produit sur un contrat de service
  If PARAM(1) = "1" Then
    #Produit physique
    If GABREV = "CON" Then
      SZBPRNAM = ""
      If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
      CODFIC = "MACHINES"
      Default File [MAC]
      CRITERE = "[F:MAC]MACCUTBPC = [M:CON0]CONBPC"
      START = "MACNUM" #Start doit contenir le nom du champs de clé de l'objet.
      ORDRE = "MACNUM"
      Read [BPR]BPR0=[M:CON0]CONBPC
      If fstat Then
        SZBPRNAM = [M:CON0]CONBPC
      Else
        SZBPRNAM = [F:BPR]BPRNAM
      Endif
      TIT(0) = mess(271,196,1) - SZBPRNAM #Parc de
      NBCOL = 0
      NBCOL += 1 : COL(NBCOL) = "MACBRACLA" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
      NBCOL += 1 : COL(NBCOL) = "MACPDTCOD" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
      NBCOL += 1 : COL(NBCOL) = "MACDES" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
      NBCOL += 1 : COL(NBCOL) = "MACSERNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
      NBCOL += 1 : COL(NBCOL) = "MACITNDAT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
      NBCOL += 1 : COL(NBCOL) = "MACNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
    Else
      OBJET = "MAC"
    Endif
  Elsif PARAM(1) = "2" Then
    #Référence article
    OBJET = "ITM"
  Else
    Return
  Endif
Return

$VERF_SELCON2MAC
#Sélection d'un produit physique ou d'une gamme de produit sur un contrat de service
Return
