#####################################################################
$SEL_SELMAC2CO1
Local Char CODFIC(GLONATB)

  # FGR 19/08/2009 : X3SUIVI57246 : Prendre en compte le site du parc
  #Sélection d'un contrat de service sur une fiche parc
  If !clalev([F:CON]) : Local File CONTSERV [CON] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  CODFIC = "CONTSERV"
  Default File [CON]
  If [M:MAC1]BPCNUM <> "" and [M:MAC1]CCNNUM = "" Then
    CRITERE = "[F:CON]CONBPC = [M:MAC1]BPCNUM and [F:CON]RSIFLG <> 2"
  Elsif [M:MAC1]BPCNUM = "" and [M:MAC1]CCNNUM <> "" Then
    CRITERE = "[F:CON]CONCCN = [M:MAC1]CCNNUM and [F:CON]RSIFLG <> 2"
  Endif
  If [M:MAC0]SALFCY <> "" Then
    If CRITERE <> "" Then
      CRITERE = CRITERE  - "AND"
    Endif
    CRITERE = CRITERE  - "[F:CON]SALFCY = [M:MAC0]SALFCY"
  Endif
  #If [M:MAC1]BPCNUM = "" and [M:MAC1]CCNNUM = "" Then
  If CRITERE = "" Then
    CRITERE = "1=1"
  Endif
  START = "CONNUM" #Start doit contenir le nom du champs de clé de l'objet.
  ORDRE = "CONNUM"
  TIT(0) = mess(293,196,1) #Contrats de service
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "CONNUM" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "CONTYPCLA" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "CONSTRDAT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "CONENDDAT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "CONAMT" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "CUR" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "SALFCY" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return

$VERF_SELMAC2CO1
  #Sélection d'un contrat de service sur une fiche parc
Return
