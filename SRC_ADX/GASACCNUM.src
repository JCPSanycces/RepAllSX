#<AdxTL>@(#)11.0.0.0 $Revision$
GBIDC1="" : GBIDC2="" : GFLAG="STDCO"
Call OBJET("GAS",GBIDC1,GBIDC2) From GOBJET
End

Local Char PARAM(30)(1..10) , VALEUR(10)
PARAM(1) = "688757"
PARAM(1) = "658287"
Call SAISIE_CHAR(VALEUR,PARAM,"DGASACCNUM","GASACCNUM","") From GSAISIE
End


##################################################################################
# CPTTRCVCR                                               Modules  Accounting    #
#                                                                                #
# Project EMERAUDE - Feature ENTTRAC - Requirement 71257                         #
#                                                                                #
#                    Journal Entry Tracability                                   #
#                                                                                #
#                                                                                #
#                                                                                #
##################################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "TRT_DIV"     : Gosub TRT_DIV
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "VERF_LISTE"  : Gosub VERF_LISTE
 When Default
Endcase
Return

##################################################################################
$OUVRE

Local    Integer  NUMERO, I
Local Char NAMZON(120)

Case GACTION
 When "GASACCNUM1"
  # Useful to $READ_TB9
  If clalev([F:TB9]) : Close File [TB9] : Endif
  Local Char    TRCABRFIC(30) : [L]TRCABRFIC = "TB9"
  Local Integer TRCCAS        : [L]TRCCAS = 3
  Local Char    IDX(GLONANX), VKEY(50)
  Local Decimal NBRKEYTB9
  Local Char PKEYTB9(GLONAVA)(1..20)

 When "GASACCNUM"
  Local Char PKEY(GLONAVA)(1..20)
Endcase


If clalev([F:GAT])=0 : Local File GAUTRCVCR   [GAT] : Endif
If clalev([F:GAU])=0 : Local File GAUTACE     [GAU] : Endif

If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif
If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif

If clalev([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif

If clalev([F:ACT]) : Local File ACTION     [ACT] : Endif
If clalev([F:AAR]) : Local File ACTCODPAR  [AAR] : Endif

Return

##################################################################################
$DEBUT
# Action GASACCNUM  =>  Remplissage masque GAA selon les champs d'index 1 de la Table des Elements Déclencheurs (Table liée à un objet)
# Action GASACCNUM1 =>  Remplissage masque GAA selon les paramètres de l'action (paramètre = liste des champs de la Table des Elements Déclencheurs)

Raz [M:GAA]

NUMERO = val(PARAM(1))
Read [DAE]DAE2 = NUMERO
If fstat : FIN = 1 : Return : Endif
Read [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
If fstat : FIN = 1 : Return : Endif
Read [GAT]GAT2 = NUMERO
If fstat=5 : Return : Endif

# Format des colonnes
Case GACTION

 When "GASACCNUM1"

    # Useful to $READ_TB9
    Local File =[F:GAT]TBL [TB9]
    [L]IDX = [F:GAT]IDX
    Call KEY_FIELD([F:GAT]LIK,PKEYTB9,NBRKEYTB9) From CPTTRCVCR
    For I=1 To 13
     Read [ATZ]CODZONE = [F:GAT]TBL;PARAM(I+1)
     If !fstat
      Call TEXTE([F:ATZ]NOLONG,[L]NAMZON) From OBJDIV  
      Assign "[M:GAA]NAMKEY"+num$(I) With [F:ATZ]CODZONE
      Assign "[M:GAA]LIBKEY"+num$(I) With [L]NAMZON
      Assign "[M:GAA]FMTKEY"+num$(I) With "KP:25X"
      [M]NBRKEY+=1
     Else
      Assign "[M:GAA]FMTKEY"+num$(I) With "-KP:25X"
     Endif
    Next

  When "GASACCNUM"
   Call KEY_FIELD([F:GAT]LIK,[L]PKEY,[M]NBRKEY) From CPTTRCVCR
    I=1
    While I<=[M]NBRKEY
     [L]NAMZON = [L]PKEY(I)
     Read [ATZ]CODZONE = [F:GAT]TBL;[L]PKEY(I)
     If !fstat
      Call TEXTE([F:ATZ]NOLONG,[L]NAMZON) From OBJDIV  
     Endif
     Assign "[M:GAA]NAMKEY"+num$(I) With [F:ATZ]CODZONE
     Assign "[M:GAA]LIBKEY"+num$(I) With [L]NAMZON
     Assign "[M:GAA]FMTKEY"+num$(I) With "KP:25X"
     I+=1
    Wend
    For I=[M]NBRKEY+1 To 13
     Assign "[M:GAA]FMTKEY"+num$(I) With "-KP:25X"
    Next

Endcase

# Remplissage du masque
nolign = 0
For [GAT]GAT2 Where ACCNUM=NUMERO
 If nolign>=dim([M:GAA]ACCNUM) : Break : Endif
 nolign += 1
 [M:GAA] = [F:GAT]
 [M:GAA]AMTTOT += [F:GAT]AMTCUR
 If [F:GAT]SNS=1
  [M:GAA]DEB(nolign-1) = [F:GAT]AMTCUR
  [M:GAA]CDT(nolign-1) = 0
 Else
  [M:GAA]CDT(nolign-1) = [F:GAT]AMTCUR
  [M:GAA]DEB(nolign-1) = 0
 Endif
 If GACTION="GASACCNUM1"
  Gosub READ_TB9 From CPTTRCVCR
  For I=1 To [M]NBRKEY
   Assign "[M:GAA]KEY"+num$(I)+"("+num$(nolign-1)+")" With num$(evalue("[F:TB9]"+evalue("[M:GAA]NAMKEY"+num$(I))))
  Next
 Endif
Next
[M:GAA]NBACCNUM=nolign

Affzo [M:GAA]
Return


######################################################################################
# Masque GASACCNUM - Liste des éléments justifiant la tracabilité
######################################################################################
Subprog IB_NBACCNUM
Gosub SETNOL
Raz GBOUT1
[M:GAA]OBJ(NOL) = ""
Case [M:GAA]TBL
 When "SINVOICE" : 
  If clalev([F:SIH])=0 : Local File SINVOICE  [SIH] : Endif
  If [F:SIH]NUM<>[M:GAA]KEY1(NOL)
   Read [F:SIH]SIH0 = [M:GAA]KEY1(NOL)
  Endif
  Case [F:SIH]ORIMOD
   When 3 : [M:GAA]OBJ(NOL)="BIC" : GBOUT1 = mess(43,109,1) : # Facture tiers client
   When 5 : [M:GAA]OBJ(NOL)="SIH" : GBOUT1 = mess(45,109,1) : # Facture vente
  Endcase
 When "PINVOICE" : # Facture tiers fournisseur
  If clalev([F:PIH])=0 : Local File PINVOICE  [PIH] : Endif
  If [F:PIH]NUM<>[M:GAA]KEY1(NOL)
   Read [F:PIH]PIH0 = [M:GAA]KEY1(NOL)
  Endif
  Case [F:PIH]ORIMOD
   When 3 : [M:GAA]OBJ(NOL)="BIS" : GBOUT1 = mess(44,109,1) : # Facture tiers fournisseur
   When 6 : [M:GAA]OBJ(NOL)="PIH" : GBOUT1 = mess(46,109,1) : # Facture achat
  Endcase           
 When Default
  Filter [AOB] Where NOMFIC=[F:GAT]TBL & TYPGES=1
  Read [AOB]NOMFIC First
  If !fstat
   [M:GAA]OBJ(NOL)=[F:AOB]ABREV : Call TEXTE([F:AOB]LIBEL,GBOUT1) From OBJDIV  
  Endif
  Filter [AOB]
Endcase
End

$SETNOL
Local Integer NOL
NOL=nolign-1
Return

######################################################################################
######################################################################################
$SEL_LISTE
Case LISTE
 When "GASACCNUM2" : Gosub B8_NBLIG_SEL
Endcase
Return

$VERF_LISTE
Case LISTE
 When "GASACCNUM2" : Gosub B8_NBLIG_VRF
Endcase
Return

$B8_NBLIG_SEL  # GBOUT8 on [M:HAE2] or GBOUT1 on [M:GAA]
Gosub SETNOL
Raz GBIDC1, GBIDC2, GBIDC3
Local    Decimal  NBRKEY , I
Local Char PKEY(GLONAVA)(1..20)


If dim([M:GAA]NBACCNUM)>=0

 # Masque GAA => liste des éléments déclenchants => zoom vers 1 Elément
 If [M]NBRKEY=1

  NBTEX += 1
  TEXTE(NBTEX) += evalue("[M:GAA]KEY1("+num$(NOL)+")")
  TEX(NBTEX)   += evalue("[M:GAA]KEY1("+num$(NOL)+")")

 Elsif [M]NBRKEY>1

  Local Char TEX(GLONDES)(1..300), TEXTE(GLONDES)(1..300,1..2)

  NBTEX += 1
  TEX(NBTEX) = evalue("[M:GAA]KEY2("+num$(NOL)+")")
  TEXTE(NBTEX,1) = evalue("[M:GAA]KEY2("+num$(NOL)+")")
  TEXTE(NBTEX,2) = evalue("[M:GAA]KEY1("+num$(NOL)+")")
  For I=3 To [L]NBRKEY
   TEXTE(NBTEX,2) += "~"+evalue("[M:GAA]KEY"+num$(I)+"("+num$(NOL)+")")
  Next

 Endif
 [L]NBRKEY = [M]NBRKEY

Else
 
 # Masque HAE2/HAE1 "Saisie de pièces comptables" => liste des éléments déclenchants en Sélection Liste avant Zoom vers 1 Element

 If !clalev([F:GAT]) : Local File GAUTRCVCR   [GAT] : Endif

 Read [GAT]GAT2 = [M]ACCNUM(NOL)
 If fstat : Return : Endif
 Call KEY_FIELD([F:GAT]LIK,PKEY,[L]NBRKEY) From CPTTRCVCR

 If [L]NBRKEY=1

  For [GAT]GAT2 Where ACCNUM=[M]ACCNUM(NOL)
   If NBTEX>=dim(TEX)-1 : Break : Endif
   NBTEX += 1
   TEXTE(NBTEX) += [F:GAT]KEY1
   TEX(NBTEX)   += [F:GAT]KEY1
  Next

 Elsif [L]NBRKEY>1

  Local Char TEX(GLONDES)(1..300), TEXTE(GLONDES)(1..300,1..2)

  For [GAT]GAT2 Where ACCNUM=[M]ACCNUM(NOL)
   If NBTEX>=dim(TEX)-1 : Break : Endif
   NBTEX += 1
   TEX(NBTEX) = [F:GAT]KEY2
   TEXTE(NBTEX,1) = [F:GAT]KEY2
   TEXTE(NBTEX,2) = [F:GAT]KEY1
   For I=3 To [L]NBRKEY
    TEXTE(NBTEX,2) += "~"+evalue("[F:GAT]KEY"+num$(I))
   Next
  Next
 Endif
Endif

TIT(0) = mess(40,100,1)
Return

$B8_NBLIG_VRF 

If !clalev([F:GAU]) : Local File GAUTACE    [GAU] : Endif
If !clalev([F:AOB]) : Local File AOBJET     [AOB] : Endif
If !clalev([F:ACT]) : Local File ACTION     [ACT] : Endif

Read [GAT]GAT2 = [M]ACCNUM(NOL)
If fstat : Return : Endif
Read [GAU]GAU0 = [F:GAT]GAU
If fstat : Return : Endif

#---- Init GBIDC1 = Objet
Filter [AOB] Where NOMFIC=[F:GAT]TBL & TYPGES=1
Read [AOB]NOMFIC First
If !fstat
 GBIDC1  = [F:AOB]ABREV
 #--- cas particulier PIH/BIS et SIH/BIC
 Case [F:GAT]TBL
  When "SINVOICE" : 
   If clalev([F:SIH])=0 : Local File SINVOICE  [SIH] : Endif
   If [F:SIH]NUM<>TEX(CHOIX)
    Read [F:SIH]SIH0 = TEX(CHOIX)
   Endif
   Case [F:SIH]ORIMOD
    When 3 : GBIDC1="BIC" : GBOUT8 = mess(43,109,1) : # Facture tiers client
    When 5 : GBIDC1="SIH" : GBOUT8 = mess(45,109,1) : # Facture vente
   Endcase
  When "PINVOICE" : # Facture tiers fournisseur
   If clalev([F:PIH])=0 : Local File PINVOICE  [PIH] : Endif
   If [F:PIH]NUM<>TEX(CHOIX)
    Read [F:PIH]PIH0 = TEX(CHOIX)
   Endif
   Case [F:PIH]ORIMOD
    When 3 : GBIDC1="BIS" : GBOUT8 = mess(44,109,1) : # Facture tiers fournisseur
    When 6 : GBIDC1="PIH" : GBOUT8 = mess(46,109,1) : # Facture achat
   Endcase           
 Endcase
Endif
Filter [AOB]

#---- Init GBIDC1 = Clé
GBIDC2  = TEX(CHOIX)
If [L]NBRKEY>1
 GBIDC3 = TEXTE(NBTEX,2)
Endif
Return

######################################################################################
######################################################################################
$SEL_TABLE
CRITERE = "[F:ATZ]CODFIC='"+PARAM(1)+"'"
OBJET = "ATZ"
ORDRE = "CODFIC;CODZONE"
START = "[F:ATZ]CODZONE"
EXPSTART = START+'>""'
Return

######################################################################################
######################################################################################
$TRT_DIV
Case TRAIT
 When "GASACCNUM3" : Gosub B9_NBLIG
Endcase
Return

$B9_NBLIG   # GBOUT8 on [M:HAE2] or GBOUT1 on [M:GAA]

If !clalev([F:GAT]) : Local File GAUTRCVCR   [GAT] : Endif
If !clalev([F:GAU]) : Local File GAUTACE     [GAU] : Endif

If !clalev([F:ACT]) : Local File ACTION     [ACT] : Endif
If !clalev([F:AAR]) : Local File ACTCODPAR  [AAR] : Endif

 
Read [GAT]GAT1 = [M]TYP;[M]NUM
If fstat : Return : Endif
Read [GAU]GAU0 = [F:GAT]GAU
If fstat : Return : Endif

If [F:GAU]TRCACT<>""
 Read [ACT]ACTION = [F:GAU]TRCACT
 If fstat : Return : Endif
Endif

Local Decimal BASPAG
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = [F:GAU]TRCACT

If GACTION="GASACCNUM1"

  PARMSK(1) = PARAM(1) # ACCNUM

  For I=1 To dim([F:GAU]TRCCODPAR)-1
   Read [AAR]CODPAR = [F:GAU]TRCCODPAR(I-1)
   If !fstat & [F:GAU]TRCVALPAR(I-1)<>""
    PARMSK(I+1) = num$([F:GAU]TRCVALPAR(I-1))
   Else
    PARMSK(I+1) = ""
   Endif
  Next

Else

 For I=1 To dim([F:GAU]TRCCODPAR)-1
  Read [AAR]CODPAR = [F:GAU]TRCCODPAR(I-1)
  If !fstat & [F:GAU]TRCVALPAR(I-1)<>""
   Onerrgo EVAL
   Case [F:AAR]TYPPAR
    When 1,4,6   : PARMSK(I) = evalue([F:GAU]TRCVALPAR(I-1))
    When Default : PARMSK(I) = num$(evalue([F:GAU]TRCVALPAR(I-1)))
   Endcase
   Onerrgo

  Else
   PARMSK(I) = ""
  Endif
 Next

Endif

Case [F:ACT]TYP
 When 1 : # Objet
   Call OBJET_CHAR(PARMSK(2),PARMSK(1),PARMSK(3)) From GOBJET
   #Call OBJET(PARMSK(1),PARMSK(2),PARMSK(3)) From GOBJET
 When 2 : # Consultation
   Call GCONSULT([F:ACT]PARAM1,"",PARMSK) From GCONSULT
   #Call CONSULT_NUM(BASPAG,[F:ACT]PARAM1,PARMSK) From GCONSULT
 When 4 : # Saisie
   Call SAISIE_NUM(BASPAG,PARMSK,[F:ACT]PARAM2,[F:ACT]CODTRT,[F:ACT]SPETRT) From GSAISIE
Endcase
GACTION = SAVACT
Return

$EVAL
Resume
