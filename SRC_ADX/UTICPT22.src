#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################
# UTICPT22   MAJ du nouveau champ BPRNUM - Table TDSPRV     Module CPT   #
#                                                                        #                     
##########################################################################
Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTICPT22(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTICPT22(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTICPT22 : Process Start on : "+DOSSIER,0) From GESECRAN

If clalev([F:ACV])=0 : Local File =DOSSIER+".ACTIV" [ACV] : Endif

If !func AFNC.ACTIV("DAS") : End : Endif

If filinfo(filpath("FIL","TDSPRV","fde",DOSSIER),0) < 0 : End : Endif
#----- Ouverture des fichiers -----#
Local File =DOSSIER+".TDSPRV" [TPR]



Call DEBTRANS From GLOCK

Trbegin [TPR]


Update [TPR] Where BPRNUM=""  With BPRNUM = [F:TPR]PRVNUM
If fstat
 # Erreur d'écriture
 GOK = 0 : Call ECR_TRACE(mess(13,100,1)-"TDSPRV",-1) From GESECRAN : Goto AB_UTICPT22 
Endif


Commit
Close Local File [TPR]
Call ECR_TRACE("UTICPT22 : record processed",0) From GESECRAN
End

$AB_UTICPT22
Rollback
End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
Call MAJ_UTICPT22(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 :  End : Endif 
Call MAJ_UTICPT22(APPLI)
End








