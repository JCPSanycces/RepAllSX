#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTITC36   Table ITMFACILIT                                   Module TC #
#           Mettre "Réception" pour type de mvt avec FG sur services     #
##########################################################################
# CCC 28/10/11 77464 : utilitaire non livré car un peu dangereux   
##########################################################################

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Call OUVRE_TRACE("Correction FG services") From LECFIC

For [ADS]
  Call TEMPON("O") From GESECRAN
  Call MAJ_UTITC36([F:ADS]DOSSIER) 
  Call TEMPOFF     From GESECRAN
Next

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

End

Subprog MAJ_UTITC36(PDOSSIER)
Value Char PDOSSIER

Local Integer COMPTEUR
Local Integer STAT
Local Char APPLI : APPLI = PDOSSIER

If filinfo(filpath("FIL","ITMFACILIT","fde",APPLI),0)<=0 : End : Endif  
Call ECR_TRACE("UTITC36: Process Start on : "+PDOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:ITF])  <>0   Close File [ITF] : Endif
If clalev([F:ITF])  =0  Local File =PDOSSIER+".ITMFACILIT"   [ITF] : Endif
If clalev([F:ITM])  <>0   Close File [ITM] : Endif
If clalev([F:ITM])  =0  Local File =PDOSSIER+".ITMMASTER"   [ITM] : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [ITF]
For [ITM] Where SCSFLG=2
    Update [ITF] Where ITMREF=[F:ITM]ITMREF & (OTRSTYP(0)>0 | OTRSTYP(1)>0 | OTRSTYP(2)>0 | OTRSTYP(2)>0 | OTRSTYP(4)>0)
&                With OTRSTYP(0)=3,
&                     OTRSTYP(1)=0,
&                     OTRSTYP(2)=0,
&                     OTRSTYP(3)=0,
&                     OTRSTYP(4)=0,
&                     OVECOD(1)="",
&                     OVECOD(2)="",
&                     OVECOD(3)="",
&                     OVECOD(4)=""
    COMPTEUR+=adxuprec
Next
Commit

Close Local File [ITM], [ITF]

Call ECR_TRACE("UTITC36: "+num$(COMPTEUR)+" records processed",0) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If filinfo(filpath("FIL","ITMFACILIT","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= code table  
Call MAJ_UTITC36(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If filinfo(filpath("FIL","ITMFACILIT","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= code table  
Call MAJ_UTITC36(APPLI)        
End

