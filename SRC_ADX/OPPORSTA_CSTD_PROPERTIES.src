#<AdxTL>@(#)0.0.0.0 $Revision$
End
#######################################################################################
# Classe OPPORSTA
#######################################################################################
# PROPERTIES                                                                          #
#######################################################################################
#######################################################################################
$ENDDATX
  Case [L]ARULE
    When "PROPAGATE" : Gosub ENDDATX_PROPAGATE
  Endcase
Return

$ENDDATX_PROPAGATE
  this.STRDATX = this.ENDDATX
Return

#######################################################################################
$STEX
  # Issue X3-36832 - 2017-06-01 by FGR
  Case [L]ARULE
    When "PROPAGATE" : Gosub STEX_PROPAGATE
  Endcase
Return

$STEX_PROPAGATE
  # Issue X3-36832 - 2017-06-01 by FGR
  If this.STEX <> AVOID.ACHAR Then
    Local File ATABDIV [ADI]
    Read [ADI]CODE=421;this.STEX
    If [F:ADI]N3 = [V]CST_AYES or [F:ADI]N3 = [V]CST_ANO Then
      this.DONX = [F:ADI]N3
    Else
      this.DONX = [V]CST_ANO
    Endif
  Endif
Return

