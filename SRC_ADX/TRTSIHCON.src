###########################################################################################
$CON_SIH_PLUS
  #--CPO 79550 Transferts : Contrats de serv -> Factures
  #--Avant le GENSIH car le GENSIH=>SAI_NBLIG=>APRES_NBLIG=>APRES_LIGNE=>ADD_TOT=>MAJ_SFIT_QTY
  #--qui a besoin d'avoir dans le [M:SFIT] les DTA avec le VCRENT du contrat en cours
  #--Le VCRENT est alimenté par le CON_SIH_PLUS...
  Gosub CON_SIH_PLUS From SUBSFIT
  If GERR <> 0 Then
    Return
  Endif

Return

