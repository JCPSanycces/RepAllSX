#<AdxTL>@(#)12.0.0.0 $Revision$
###########################################################################################
# TRTSIHCON  : Picking contrats de service dans les factures        Module CRM  3/11/2003
###########################################################################################
#    pour GENSIH composant calcul facture
#    chargement masques SIH0 SIH1 SIH2 SIH4
###########################################################################################
$ACTION_GS
  Case GWACTION_GS
    When "READ_DETAIL"
      Gosub READ_DETAIL
    When "MSK_ENTETE"
      Gosub MSK_ENTETE
    When "MSK_DETAIL"
      Gosub MSK_DETAIL
    When "ERREUR"
      Gosub ERREUR
  Endcase
Return

#-----------------------------------------------------------------------
$MSK_ENTETE
  Case IMPZON
    When "SALFCY"
      # FGR 09/10/2009 : X3SUIVI58438
      IMPMOD = 1
      [M]SALFCY = [F:CON]SALFCY
    When "INVDAT"
      IMPMOD = 1
      [M]INVDAT = [F:CON]NEXINVDAT
    When "BPCINV"
      Gosub SETBPCINF
    When "INVREF"
      # FGR 26/02/2009 : CONORITXT est inutile
      #If [F:CON]CONORIVCR <> "" and [F:CON]CONORITXT = mess(2,2977,1) Then
      If [F:CON]CONORIVCR <> "" and [F:CON]CONORI = 2 Then
        Gosub LEC_SOH
        If [F:SOH]CUSORDREF <> "" Then
          [M]INVREF = [F:SOH]CUSORDREF
          IMPMOD = 1
        Endif
      Endif
    When "BPAADD"
      # FGR 26/02/2009 : CONORITXT est inutile
      #If [F:CON]CONORIVCR <> "" and [F:CON]CONORITXT = mess(2,2977,1) Then
      If [F:CON]CONORIVCR <> "" and [F:CON]CONORI = 2 Then
        Gosub LEC_SOH
        If [F:SOH]BPAADD <> "" Then
          [M]BPAADD = [F:SOH]BPAADD
          IMPMOD = 1
        Endif
      Endif
    When "PJT"
      If [M:SIH4]NBLIG = 0 Then
        # FGR 02/01/2012 : X3SUIVI71065 Seulement pour la première ligne
        IMPMOD = 1
        [M]PJT = [F:CON]CONPJT
      Endif
    When "CUR"
      IMPMOD = 1
      [M]CUR = [F:CON]CUR
      [M]CURTYP = [F:CON]CONCHGTYP     # FGR 26/10/2015 : X3SUIVI112020
    When "PTE"
      IMPMOD = 1
      [M]PTE = [F:CON]PTE
    When "REP"
      Case indice
        When 0
          [M]REP(0) = [F:CON]SALREP(0)
        When 1
          [M]REP(1) = [F:CON]SALREP(1)
      Endcase
    When "INVDTAAMT"
      #Gosub SETINVDTA #--CPO 79550 Nouvelle règle de transfert : Contrats de services -> Factures
    When "VACBPR"
      # FGR 12/08/2008 : X3SUIVI48614 : faire unitairement a cause de l'AM_ sur BPCINV notamment
      IMPMOD = 1
      [M]VACBPR = [F:CON]CONVACBPR
    When "BPCORD"
      # FGR 12/08/2008 : X3SUIVI48614 : faire unitairement a cause de l'AM_ sur BPCINV notamment
      IMPMOD = 1
      [M]BPCORD = [F:CON]CONBPC
    When "BPCGRU"
      # FGR 12/08/2008 : X3SUIVI48614 : faire unitairement a cause de l'AM_ sur BPCINV notamment
      IMPMOD = 1
      [M]BPCGRU = [F:CON]CONBPCGRU
    When "BPRPAY"
      # FGR 12/08/2008 : X3SUIVI48614 : faire unitairement a cause de l'AM_ sur BPCINV notamment
      IMPMOD = 1
      [M]BPRPAY = [F:CON]CONBPCPYR
    When "PRITYP"
      # FGR 12/08/2008 : X3SUIVI48614 : faire unitairement a cause de l'AM_ sur BPCINV notamment
      IMPMOD = 1
      [M]PRITYP = [F:CON]CONPRITYP
    When "CURTYP"  # FGR 26/10/2015 : X3SUIVI112020 et pas "CHGTYP"
      # FGR 12/08/2008 : X3SUIVI48614 : faire unitairement a cause de l'AM_ sur BPCINV notamment
      IMPMOD = 1
      [M]CURTYP = [F:CON]CONCHGTYP  # FGR 26/10/2015 : X3SUIVI112020 et pas "CHGTYP"
    When "STRDATSVC"
      # FGR 12/03/2009 : X3SUIVI28408 : chargement dates début/fin période prestation  pour CCA/FCA
      IMPMOD = 1
      [M]STRDATSVC = [F:CON]CONSTRDAT
    When "ENDDATSVC"
      # FGR 12/03/2009 : X3SUIVI28408 : chargement dates début/fin période prestation  pour CCA/FCA
      IMPMOD = 1
      [M]ENDDATSVC = [F:CON]CONENDDAT
    When "CCE"
      #FQ68364 Axes lignes Contrat de service vers facture
      #Chargement des sections analytiques entête facture à partir du contrat
      Call CHARG_CCEH("SIH2","NBAXE","CON") From TRTX3CPT
      #Initialisation sections analytiques vides
      If dim([M:SIH2]NBAXE)>0
          Local Char SECTION
          For I=1 To GNBDIE
              #If [F:SIH]CCE(I-1)=""
              If [M:SIH2]CCE(I-1)=""
                  [F:SIH]DIE(I-1)=GDIE(I)
                  [M:SIH2]DIE(I-1)=GDIE(I)
                  Call INISEC(SECTION,"SIH",GDIE(I)) From SUBCDE
                  [F:SIH]CCE(I-1) = SECTION
                  [M:SIH2]CCE(I-1) = SECTION
              Endif
          Next I
      Endif
      #fin FQ68364
  Endcase
Return
#--------------------------------------------------------------------------------
# Lecture entête commande vente pour alimentation des zones venant de la commande
#--------------------------------------------------------------------------------
$LEC_SOH
  If [F:SOH]SOHNUM <> [F:CON]CONORIVCR Then
    Read [SOH]SOH0=[F:CON]CONORIVCR
    If fstat Then
      Raz [F:SOH]
    Endif
  Endif
Return

#-----------------------------------------------------------------------
$READ_DETAIL
  nolign = 0
  LIG_DETAIL = "C"     : # uniquement de la creation
  If LEC_DETAIL = 0 Then
    LEC_DETAIL = 1
  Else
    LEC_DETAIL = 2
  Endif
Return

#-----------------------------------------------------------------------
$MSK_DETAIL
  Case IMPZON
    When "ITMREF"
      Gosub SETITMCON
      Gosub MAJ_STRDAT_ENDDAT  # FGR 31/01/2013 : X3SUIVI87639
      Gosub CON_SIH_PLUS :#--CPO 79550
    When "DPJT"
      # FGR 02/01/2012 : X3SUIVI71065
      IMPMOD = 1
      [M]DPJT(nolign-1) = [F:CON]CONPJT
    When "QTY"
      Gosub SETQTYCON
    When "SAU"
      Gosub SETSAUCON
    When "GROPRI"
      Gosub SETPRICON
    # FGR 31/01/2013 : X3SUIVI87639 (début) : déplacé dans MAJ_STRDAT_ENDDAT
    #    When "STRDAT"
    #      # FGR 08/04/2010 : X3SUIVI38132 : chargement dates début/fin période prestation  pour CCA/FCA
    #      IMPMOD = 1
    #      [M]STRDAT(nolign-1) = [F:CON]CONSTRDAT
    #    When "ENDDAT"
    #      # FGR 08/04/2010 : X3SUIVI38132 : chargement dates début/fin période prestation  pour CCA/FCA
    #      IMPMOD = 1
    #      #[M]ENDDAT(nolign-1) = [F:CON]CONENDDAT
    #      # ------------------------------------------------------------------------------------------------
    #      # FGR 02/07/2012 : X3SUIVI81775
    #      Local Integer OKREP
    #
    #      Gosub CALCUL_FIN_PERIODE
    #      Call INVCPTCON([M:SIH4]CONNUM(nolign-1), 0, OKREP) From SUBCONB1
    #      If !OKREP
    #        #Erreur lors de la mise à jour du contrat de service n° XXX.
    #        GMESSAGE = mess(356,196,1) + [M:SIH4]CONNUM(nolign-1)
    #        GERR = 1
    #        Return
    #      Endif
    #      If [F:CON]INVMET = 2 Then
    #        Gosub CALCUL_DEBUT_PERIODE
    #      Endif
    #      # ------------------------------------------------------------------------------------------------
    # FGR 31/01/2013 : X3SUIVI87639 (fin) : déplacé dans MAJ_STRDAT_ENDDAT
  Endcase
Return

#-----------------------------------------------------------------------
$ERREUR
  Call ERREUR (GBIDC3) From GESECRAN
Return

#########################################################################
$MAJ_STRDAT_ENDDAT
  # FGR 31/01/2013 : X3SUIVI87639 déplacé dans ITMREF
  # STRDAT et ENDDAT peuvent être rendus non saisissable par transaction de saisie
  # Dans ce cas, il n'y a pas IMPZON="STRDAT" et IMPZON="ENDDAT"
  # ------------------------------------------------------------
  # FGR 11/02/2013 : X3SUIVI87630 (début)
  If dim(GSPCKCON) >= 0 and GSPCKCON <> "INICRE_LIG" Then
    # Si on est en picking on ne fait pas ça ici
    Return
  Endif
  # FGR 11/02/2013 : X3SUIVI87630 (fin)

  IMPMOD = 1
  [M]STRDAT(nolign-1) = [F:CON]CONSTRDAT
  #
  Local Integer OKREP

  Gosub CALCUL_FIN_PERIODE
  Call INVCPTCON([M:SIH4]CONNUM(nolign-1), 0, OKREP) From SUBCONB1
  If !OKREP
    #Erreur lors de la mise à jour du contrat de service n° XXX.
    GMESSAGE = mess(356,196,1) + [M:SIH4]CONNUM(nolign-1)
    GERR = 1
    Return
  Endif
  If [F:CON]INVMET = 2 Then
    Gosub CALCUL_DEBUT_PERIODE
  Endif
Return

#########################################################################
$CALCUL_DEBUT_PERIODE
  # FGR 29/06/2012 : X3SUIVI81775
  If [F:CON]INVMET = 1 Then
    # Pré-facturation (terme à échoir)
    # On facture au début donc de la période :
    #     * La (date de prochaine facture) ou la date de début de contrat :
    #                 => est la date de début de période
    #     * La (date de PROCHAINE prochaine facture -1) ou la date de fin de contrat :
    #                 => est la date de fin de période
    # ---------------------------------------------------------------------------------
    If [F:CON]NEXINVDAT <> [0/0/0] Then
      # Si le contrat a déjà été facturé, le début de la période commence au lendemain
      [M]STRDAT(nolign-1) = [F:CON]NEXINVDAT
    Else
      # ... Sinon, elle commence au début du contrat
      [M]STRDAT(nolign-1) = [F:CON]CONSTRDAT
    Endif
  Else
    # Post-facturation (terme échu)
    # On facture à la fin de la période :
    #     * La (date de dernière facture +1) ou la date de début de contrat :
    #                 => est la date de début de période
    #     * La (date de prochaine facture -1) ou la date de fin de contrat :
    #                 => est la date de fin de période
    # ---------------------------------------------------------------------------------
    # FGR 25/03/2013 : X3SUIVI87947 (début)
    If [F:CON]OLASINVDAT <> [0/0/0] Then
      If clalev([F:WSID]) = 0 Local File SINVOICED [WSID] : Endif
      Filter [F:WSID] Where [F:WSID]CONNUM=[F:CON]CONNUM Order By [F:WSID]INVDAT Desc; [F:WSID]NUM Asc
      If rowcount([F:WSID]) = 0 Then
        [F:CON]OLASINVDAT = [0/0/0]
      Endif
      Filter [F:WSID]
    Endif
    # FGR 25/03/2013 : X3SUIVI87947 (fin)
    If [F:CON]OLASINVDAT <> [0/0/0] Then
      # Si le contrat a déjà été facturé, le début de la période commence au lendemain
      [M]STRDAT(nolign-1) = [F:CON]OLASINVDAT
    Else
      # ... Sinon, elle commence au début du contrat
      #[M]STRDAT(nolign-1) = [F:CON]CONSTRDAT
      [M]STRDAT(nolign-1) = [F:WCON]CONSTRDAT   # FGR 25/03/2013 : X3SUIVI87947
    Endif
  Endif
Return

#########################################################################
$CALCUL_FIN_PERIODE
  # FGR 29/06/2012 : X3SUIVI81775
  If [F:CON]INVMET = 1 Then
    # Pré-facturation (terme à échoir)
    # On facture au début donc de la période :
    #     * La (date de prochaine facture) ou la date de début de contrat :
    #                 => est la date de début de période
    #     * La (date de PROCHAINE prochaine facture -1) ou la date de fin de contrat :
    #                 => est la date de fin de période
    # ---------------------------------------------------------------------------------
    Gosub CALCUL_DEBUT_PERIODE
    Call SNEXINVDAT([F:CON]NEXINVDAT, [F:CON]INVFRY, [F:CON]INVFRYBAS, [F:CON]SIUDAT, [F:CON]CONSTRDAT, [M]ENDDAT(nolign-1)) From SUBCOND
    #If [M]ENDDAT(nolign-1) <> [0/0/0] Then                                                                  # FGR 17/12/2015 : X3SUIVI113219
    # Note X3SUIVI113219 : Les contrats à points arrivent soit à leur terme, soit sont refacturés lorsque
    # le crédit de points est épuisé. La date de fin les concernant est donc obligatoirement la date de fin de contrat.
    If [M]ENDDAT(nolign-1) <> [0/0/0] and [M]ENDDAT(nolign-1) <= [F:CON]CONENDDAT and [F:CON]CONCAT <> 4 Then# FGR 17/12/2015 : X3SUIVI113219
      # C'est la veille de la PROCHAINE prochaine facture
      [M]ENDDAT(nolign-1) =  [M]ENDDAT(nolign-1) - 1
    Else
      # S'il n'en n'a pas, c'est qu'il se termine, et la fin est la fin du contrat
      [M]ENDDAT(nolign-1) = [F:CON]CONENDDAT
    Endif
  Else
    # Post-facturation (terme échu)
    # On facture à la fin de la période :
    #     * La (date de dernière facture +1) ou la date de début de contrat :
    #                 => est la date de début de période
    #     * La (date de prochaine facture -1) ou la date de fin de contrat :
    #                 => est la date de fin de période
    # ---------------------------------------------------------------------------------
    If [F:CON]NEXINVDAT <> [0/0/0] Then
      # S'il n'en n'a pas, c'est qu'il se termine, et la fin est la fin du contrat
      [M]ENDDAT(nolign-1) = [F:CON]NEXINVDAT - 1
    Else
      # Sinon, c'est la veille de la prochaine facture la fin de la période
      [M]ENDDAT(nolign-1) =  [F:CON]CONENDDAT
    Endif
  Endif
Return

###########################################################################################
$SETBPCINF
  IMPMOD = 1
  [M]BPCINV = [F:CON]CONBPCINV
  [M]SIHORI = 7
  [M]SIHORINUM = [F:CON]CONNUM

  # FGR 12/08/2008 : X3SUIVI48614 : faire unitairement a cause de l'AM_ sur BPCINV notamment
  #[M]VACBPR = [F:CON]CONVACBPR
  #[M]BPCORD = [F:CON]CONBPC    # a faire sur GX3APP mais pas en 140 et v5
  #[M]BPCGRU = [F:CON]CONBPCGRU
  #[M]BPRPAY = [F:CON]CONBPCPYR
  #[M]PRITYP = [F:CON]CONPRITYP
  #[M]CHGTYP = [F:CON]CONCHGTYP
Return

###########################################################################################
$SETITMCON
  IMPMOD = 1
  [M]ITMREF(nolign-1) = [F:CON]ITMREF
  [M]CONNUM(nolign-1) = [F:CON]CONNUM
  Gosub SETPRICON
Return

###########################################################################################
$SETQTYCON
  IMPMOD = 1
  [M]QTY(nolign-1) = 1
  Gosub SETPRICON
Return

###########################################################################################
$SETSAUCON
  IMPMOD = 1
  Read [ITM]ITM0=[F:CON]ITMREF
  If !fstat Then
    [M]SAU(nolign-1) = [F:ITM]SAU
  Endif
  Gosub SETPRICON
Return

###########################################################################################
$SETPRICON
Local Decimal WCONPRIX

  IMPMOD = 1
  [M]GROPRI(nolign-1) = [F:CON]NEXINVAMT
  Call SETSIHPRICE(WCONPRIX) From SUBCONB2
  [M]GROPRI(nolign-1) = WCONPRIX
Return

