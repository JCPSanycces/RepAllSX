#<AdxTL>@(#)7.0.0.0 $Revision$
##################################################################################################
# SUBRRSB    Gestion des réservations de ressources                           10 juillet 2000    #
#                                                                                                #
# Sous-programmes utilitaires                                                                    #
##################################################################################################
#                                                                                                #
# CHKRRSDISP    : Vérifie si une réservation n'est pas déjà enregistrée pour la période indiquée #
#                                                                                                #
##################################################################################################
Subprog CHKRRSDISP(SZRSSNUM, DRERDAT, DRERDATEND, SZNUM, SZHOUSTR, SZHOUEND, ISDISP, IFOG, SZNUMCFL)
Value Char SZRSSNUM
Value Date DRERDAT
Value Date DRERDATEND
Value Char SZNUM
Value Char SZHOUSTR
Value Char SZHOUEND
Variable Integer ISDISP
Variable Integer IFOG
Variable Char SZNUMCFL

Local Integer INBDAYFOG
Local Integer IDAYRANGE
Local Integer IXNBCTL
Local Integer IXPTPOS
Local Integer IXC1DAYC
Local Decimal IXC1HOURC
Local Char SZXC1HOURC
Local Decimal IXC1MINUTEC
Local Decimal IXC1TOTC
Local Integer IXC2DAYC
Local Decimal IXC2HOURC
Local Char SZXC2HOURC
Local Decimal IXC2MINUTEC
Local Decimal IXC2TOTC
Local Integer IXF1DAYC
Local Decimal IXF1HOURC
Local Char SZXF1HOURC
Local Decimal IXF1MINUTEC
Local Decimal IXF1TOTC
Local Integer IXF2DAYC
Local Decimal IXF2HOURC
Local Char SZXF2HOURC
Local Decimal IXF2MINUTEC
Local Decimal IXF2TOTC

  INBDAYFOG = 0
  IDAYRANGE = 0
  ISDISP = 1
  IFOG = 0
  IXPTPOS = 0
  IXC1DAYC = nday(DRERDAT)
  IXC1MINUTEC = val(mid$(SZHOUSTR, 3, 2)) / 60
  IXC1HOURC = ((100 * val(left$(SZHOUSTR, 2))) / 24) + IXC1MINUTEC
  IXPTPOS = instr(1, num$(IXC1HOURC), '.')
  If IXPTPOS Then
    SZXC1HOURC = left$(num$(IXC1HOURC), IXPTPOS - 1) + right$(num$(IXC1HOURC), IXPTPOS + 1)
  Else
    SZXC1HOURC = num$(IXC1HOURC)
  Endif
  IXC1TOTC = val(num$(IXC1DAYC) + '.' + SZXC1HOURC)
  IXPTPOS = 0
  IXC2DAYC = nday(DRERDATEND)
  IXC2MINUTEC = val(mid$(SZHOUEND, 3, 2)) / 60
  IXC2HOURC = ((100 * val(left$(SZHOUEND, 2))) / 24) + IXC2MINUTEC
  IXPTPOS = instr(1, num$(IXC2HOURC), '.')
  If IXPTPOS Then
    SZXC2HOURC = left$(num$(IXC2HOURC), IXPTPOS - 1) + right$(num$(IXC2HOURC), IXPTPOS + 1)
  Else
    SZXC2HOURC = num$(IXC2HOURC)
  Endif
  IXC2TOTC = val(num$(IXC2DAYC) + '.' + SZXC2HOURC)
  Filter [RRS] Where [F:RRS]RSSNUM = SZRSSNUM
&                  and (([F:RRS]RERDAT >= DRERDAT and [F:RRS]RERDAT <= DRERDATEND) or ([F:RRS]RERDATEND >= DRERDAT and [F:RRS]RERDATEND <= DRERDATEND))
  For [RRS]
    If [F:RRS]NUM <> SZNUM Then
      IXPTPOS = 0
      IXF1DAYC = nday([F:RRS]RERDAT)
      IXF1MINUTEC = val(mid$([F:RRS]HOUSTR, 3, 2)) / 60
      IXF1HOURC = ((100 * val(left$([F:RRS]HOUSTR, 2))) / 24) + IXF1MINUTEC
      IXPTPOS = instr(1, num$(IXF1HOURC), '.')
      If IXPTPOS Then
        SZXF1HOURC = left$(num$(IXF1HOURC), IXPTPOS - 1) + right$(num$(IXF1HOURC), IXPTPOS + 1)
      Else
        SZXF1HOURC = num$(IXF1HOURC)
      Endif
      IXF1TOTC = val(num$(IXF1DAYC) + '.' + SZXF1HOURC)
      IXPTPOS = 0
      IXF2DAYC = nday([F:RRS]RERDATEND)
      IXF2MINUTEC = val(mid$([F:RRS]HOUEND, 3, 2)) / 60
      IXF2HOURC = ((100 * val(left$([F:RRS]HOUEND, 2))) / 24) + IXF2MINUTEC
      IXPTPOS = instr(1, num$(IXF2HOURC), '.')
      If IXPTPOS Then
        SZXF2HOURC = left$(num$(IXF2HOURC), IXPTPOS - 1) + right$(num$(IXF2HOURC), IXPTPOS + 1)
      Else
        SZXF2HOURC = num$(IXF2HOURC)
      Endif
      IXF2TOTC = val(num$(IXF2DAYC) + '.' + SZXF2HOURC)
      If IXC1TOTC >= IXF1TOTC and IXC1TOTC <= IXF2TOTC Then
        SZNUMCFL = [F:RRS]NUM
        ISDISP = 0
        Break
      Endif
      If IXC2TOTC >= IXF1TOTC and IXC2TOTC <= IXF2TOTC Then
        SZNUMCFL = [F:RRS]NUM
        ISDISP = 0
        Break
      Endif
      If IXC1TOTC <= IXF1TOTC and IXC2TOTC >= IXF2TOTC Then
        SZNUMCFL = [F:RRS]NUM
        ISDISP = 0
        Break
      Endif
    Endif
  Next
  Filter [RRS]
  If !ISDISP Then
    End
  Endif
  Filter [RRS] Where [F:RRS]RSSNUM = SZRSSNUM and [F:RRS]RERDAT < DRERDAT and [F:RRS]RERDATEND > DRERDATEND
  For [RRS]
    If [F:RRS]NUM <> SZNUM Then
      SZNUMCFL = [F:RRS]NUM
      ISDISP = 0
      INBDAYFOG = nday([F:RRS]RERDATEND) - nday([F:RRS]RERDAT)
      If INBDAYFOG = 4 Then
        IFOG = 1
      Endif
      Break
    Endif
  Next
  Filter [RRS]
  If !ISDISP Then
    End
  Endif
  IDAYRANGE = nday(DRERDATEND) - nday(DRERDAT)
  If IDAYRANGE > 1 Then
    Filter [RRS] Where [F:RRS]RSSNUM = SZRSSNUM and [F:RRS]RERDAT > DRERDAT and [F:RRS]RERDATEND < DRERDATEND
    For [RRS]
      If [F:RRS]NUM <> SZNUM Then
        SZNUMCFL = [F:RRS]NUM
        ISDISP = 0
        INBDAYFOG = nday([F:RRS]RERDATEND) - nday([F:RRS]RERDAT)
        If INBDAYFOG = 4 Then
          IFOG = 1
        Endif
        Break
      Endif
    Next
    Filter [RRS]
  Endif
End
