#<AdxTL>@(#)5.0.0.0 $Revision$
##################################################################################
# UUMGTRTCPT00                        Modules  Accounting & A/P-A/R Accounting   #
#                                                                                #
#                                                                                #
#                    Migration Process                                           #
#                                                                                #
#                                                                                #
#     Sub-programs to migration Financial Document &  BP Accounting              #
#                                                                                #
##################################################################################
# MAJ_UUMGTRTCPT00                                                                
#   Deleting of Tables                    
#   Run all Migration Process    
##################################################################################
# OPEN_FILE 
#   Opening of common files
# DECLARE
#   Common Variables Declaration
# INIT_CPY  
#   Initialisation of the variables around the Account Core Model of the Company 
# GETPERSOC 
#   Initialisation of Fiscalyear and fiscal period from a date
#
##################################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UUMGTRTCPT00") From LECFIC

  Call MAJ_UUMGTRTCPT00(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UUMGTRTCPT00(DOSSIER)
Value Char DOSSIER

Gosub ALL_SUPP
Gosub ALL_MIG

End

#############################################################################################################
$ALL_SUPP
Call RAZ_UUMGTRTTRC04(DOSSIER) From UUMGTRTTRC04
Call RAZ_UUMGTRTCPT01(DOSSIER) From UUMGTRTCPT01
Call RAZ_UUMGTRTCPT02(DOSSIER) From UUMGTRTCPT02
Call RAZ_UUMGTRTCPT03(DOSSIER) From UUMGTRTCPT03
Call RAZ_UUMGTRTCPT04(DOSSIER) From UUMGTRTCPT04
Call RAZ_UUMGTRTCPT05(DOSSIER) From UUMGTRTCPT05
Call RAZ_UUMGTRTCPT06(DOSSIER) From UUMGTRTCPT06
Call RAZ_UUMGTRTCPT51(DOSSIER) From UUMGTRTCPT51
Call RAZ_UUMGTRTCPT52(DOSSIER) From UUMGTRTCPT52
Call RAZ_UUMGTRTCPT53(DOSSIER) From UUMGTRTCPT53
Call RAZ_UUMGTRTCPT54(DOSSIER) From UUMGTRTCPT54
Call RAZ_UUMGTRTTRS01(DOSSIER) From UUMGTRTTRS01
Call RAZ_UUMGTRTTRS02(DOSSIER) From UUMGTRTTRS02
Call RAZ_UUMGTRTTRS03(DOSSIER) From UUMGTRTTRS03
Call RAZ_UUMGTRTTRS04(DOSSIER) From UUMGTRTTRS04

Call RAZ_UUMGPOSTRC03(DOSSIER) From UUMGPOSTRC03
Call RAZ_UUMGPOSTRC04(DOSSIER) From UUMGPOSTRC04
Call RAZ_UUMGPOSTRC51(DOSSIER) From UUMGPOSTRC51
Call RAZ_UUMGPOSTRC52(DOSSIER) From UUMGPOSTRC52
Call RAZ_UUMGPOSTRC53(DOSSIER) From UUMGPOSTRC53
Call RAZ_UUMGPOSTRC54(DOSSIER) From UUMGPOSTRC54
Call RAZ_UUMGPOSCPT03(DOSSIER) From UUMGPOSCPT03
Call RAZ_UUMGPOSCPT05(DOSSIER) From UUMGPOSCPT05
Call RAZ_UUMGPOSCPT51(DOSSIER) From UUMGPOSCPT51
Call RAZ_UUMGPOSCPT52(DOSSIER) From UUMGPOSCPT52
Call RAZ_UUMGPOSCPT53(DOSSIER) From UUMGPOSCPT53
Call RAZ_UUMGPOSCPT54(DOSSIER) From UUMGPOSCPT54
Call RAZ_UUMGPOSTRS03(DOSSIER) From UUMGPOSTRS03
Return

#############################################################################################################
$ALL_MIG
Call MAJ_UUMGCTLCPT00(DOSSIER) From UUMGCTLCPT00
Call MAJ_UUMGCTLTRS00(DOSSIER) From UUMGCTLTRS00
Call MAJ_UUMGPRETRC04(DOSSIER) From UUMGPRETRC04
Call MAJ_UUMGTRTTRC04(DOSSIER) From UUMGTRTTRC04
Call MAJ_UUMGTRTCPT01(DOSSIER) From UUMGTRTCPT01
Call MAJ_UUMGTRTCPT02(DOSSIER) From UUMGTRTCPT02
Call MAJ_UUMGTRTCPT03(DOSSIER) From UUMGTRTCPT03
Call MAJ_UUMGTRTCPT04(DOSSIER) From UUMGTRTCPT04
Call MAJ_UUMGTRTCPT05(DOSSIER) From UUMGTRTCPT05
Call MAJ_UUMGTRTCPT06(DOSSIER) From UUMGTRTCPT06
Call MAJ_UUMGTRTCPT51(DOSSIER) From UUMGTRTCPT51
Call MAJ_UUMGTRTCPT52(DOSSIER) From UUMGTRTCPT52
Call MAJ_UUMGTRTCPT53(DOSSIER) From UUMGTRTCPT53
Call MAJ_UUMGTRTCPT54(DOSSIER) From UUMGTRTCPT54
Call MAJ_UUMGTRTTRS01(DOSSIER) From UUMGTRTTRS01
Call MAJ_UUMGTRTTRS02(DOSSIER) From UUMGTRTTRS02
Call MAJ_UUMGTRTTRS03(DOSSIER) From UUMGTRTTRS03
Call MAJ_UUMGTRTTRS04(DOSSIER) From UUMGTRTTRS04
Call MAJ_UUMGPOSTRC03(DOSSIER) From UUMGPOSTRC03
Call MAJ_UUMGPOSTRS03(DOSSIER) From UUMGPOSTRS03
Call MAJ_UUMGPOSTRC04(DOSSIER) From UUMGPOSTRC04
Call MAJ_UUMGPOSCPT03(DOSSIER) From UUMGPOSCPT03
Call MAJ_UUMGPOSCPT05(DOSSIER) From UUMGPOSCPT05
Call MAJ_UUMGPOSTRC51(DOSSIER) From UUMGPOSTRC51
Call MAJ_UUMGPOSTRC52(DOSSIER) From UUMGPOSTRC52
