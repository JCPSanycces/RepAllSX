Return

##################################################################################
$OPEN_FILE
If clalev([F:GCM])  = 0 : Local File =DOSSIER+".GACM"        [GCM]   : Endif      # Account core model
If clalev([F:LED])  = 0 : Local File =DOSSIER+".GLED"        [LED]   : Endif      # Ledger
If clalev([F:CPY])  = 0 : Local File =DOSSIER+".COMPANY"     [CPY]   : Endif      # Company
Return

##################################################################################
$DECLARE
# Declaration of Variables to Handle Loops Ruptures 
Local Integer STOP, NB, ISVALID, NBCOMMIT, NBLUS
Local Char CRITERE(250),CRITERESPE(250),HINTSPE(30)

# Common variable PE declaration
Local Char FLUX
Local Integer FILTRELIN

# Common variable declaration
Local Char COMPANY(GLONCPY)
Local Integer I, J, IREF, AXE

# Declaration of Variables linked to the Account Core Model 
Local Integer NBRAXE               # Number of Dimension types for a Company / Nombre d'axes analytiques pour la société
Local Integer NBAAXE               # Number of Dimension types of Main Analytical ledgerfor a Company / Nombre d'axes analytiques du référentiel analytique principal
Local Integer TYPGEN               # Reference type of Legal Ledger / Type de référentiel dit 'Social'
Local Integer TYPANA               # Reference type of Analytical Ledger / Type de référentiel dit 'Analytique'
Local Integer TYPIAS               # Reference type of IAS Ledger / Type de référentiel dit 'Sectoriel'
Local Integer TYPAUTGEN            # Automatical Type of Legal Ledger / Reference Type de référentiel automatique 
Local Integer TYPAUTANA            # Automatical Type of Analytical Ledger / Type de référentiel automatique 
Local Integer TYPAUTIAS            # Automatical Type of IAS Ledger / Type de référentiel automatique 
Local Char    LEDGEN(GLONLED)      # Legal Ledger / Code Référentiel dit "Social"
Local Char    LEDANA(GLONLED)      # Analytical Ledger / Code Référentiel dit "Analytique"
Local Char    LEDIAS(GLONLED)      # IAS Ledger / Code Référentiel dit "Sectoriel"
Local Char    COAGEN(GLONCOA)      # Chart of Account of Legal Ledger / Code Plan dit "Social"
Local Char    COAANA(GLONCOA)      # Chart of Account of Analytical Ledger / Code Plan dit "Analytique"
Local Char    COAIAS(GLONCOA)      # Chart of Account of IAS Ledger / Code Plan dit "Sectoriel"
Local Char    AXEA(GLONDIE)(1..9)  # Dimension type of Analytical Ledger / Axes du référentiel analytique
Local Char    AXEI(GLONDIE)(1..9)  # Dimension type of IAS Ledger / Axes du référentiel IAS
Local Libelle LEDGENMAIN           # Reference type of Main general ledger / Type de Référentiel général principal
Return


##################################################################################
$INI_CPY
Raz TYPGEN, TYPANA, TYPIAS, TYPAUTGEN, TYPAUTANA, TYPAUTIAS,COAGEN, COAANA, COAIAS, NBRAXE
Read [CPY]CPY0 = [L]COMPANY
If !fstat
 If [F:CPY]ACM <> [F:GCM]GCM
  Read [F:GCM]GCM0 = [F:CPY]ACM
 Endif
 LEDGEN     = [F:GCM]LED(0)
 LEDANA     = [F:GCM]LED(1)
 LEDIAS     = [F:GCM]LED(2)
 LEDGENMAIN = [F:GCM]GENLEDTYP
 If [F:LED]LED <> LEDGEN
  Read [F:LED]LED0 = LEDGEN
 Endif
 COAGEN = [F:LED]COA
 TYPGEN = 1
 #NBRAXE+=[F:LED]DIENBR
 If  LEDANA<>""
  If [F:LED]LED <> LEDANA
   Read [F:LED]LED0 = LEDANA
  Endif
  COAANA = [F:LED]COA
  TYPANA = 2
  NBRAXE+=[F:LED]DIENBR
  NBAAXE=[F:LED]DIENBR
  For I=1 To dim([F:LED]DIE)
   If [F:LED]DIE(I-1)<>""
    [L]AXEA(I)=[F:LED]DIE(I-1)
   Else
    Break
   Endif
  Next
 Else
  If [F:GCM]ANALEDTYP=0
   # Reading error - Account Core Model doesn't exist
   TYPANA = 0 : GOK=0 : Call ERREUR(mess(2,45,1)-[L]COMPANY-"-"-mess(5,618,1)-[F:CPY]ACM-"-"-mess(198,105,1),4) From DOSDIC
  Else
   If [F:LED]LED <> [F:GCM]LED([F:GCM]ANALEDTYP-1)
    Read [F:LED]LED0 = [F:GCM]LED([F:GCM]ANALEDTYP-1)
   Endif
   COAANA = [F:LED]COA
   TYPANA = [F:GCM]ANALEDTYP
   LEDANA = [F:GCM]LED([F:GCM]ANALEDTYP-1)
   NBRAXE+=[F:LED]DIENBR
   NBAAXE=[F:LED]DIENBR
   For I=1 To dim([F:LED]DIE)
    If [F:LED]DIE(I-1)<>""
     [L]AXEA(I)=[F:LED]DIE(I-1)
    Else
     Break
    Endif
   Next
  Endif
 Endif
 If LEDIAS<>""
  If [F:LED]LED <> LEDIAS
   Read [F:LED]LED0 = LEDIAS
  Endif
  COAIAS = [F:LED]COA
  TYPIAS = 3
  #NBRAXE+=[F:LED]DIENBR
  For I=1 To dim([F:LED]DIE)
   If [F:LED]DIE(I-1)<>""
    [L]AXEI(I)=[F:LED]DIE(I-1)
   Else
    Break
   Endif
  Next
 Endif
 For I=3 To dim([F:GCM]LED)-1
  If [F:GCM]LED(I)<>""
   Case [F:GCM]LED(I)
    When LEDGEN : [L]TYPAUTGEN = I
    When LEDANA : [L]TYPAUTANA = I
    When LEDIAS : [L]TYPAUTIAS = I
   Endcase
  Endif 
 Next
Else
 # No company... Migration isn't avaiable for journal entries
 GOK = 0 : Call ERREUR([L]COMPANY-mess(16,104,1),4) From DOSDIC
Endif
Return


#############################################################################################################
$GETPERSOC
If [L]DAT>=[F:PER]PERSTR & [L]DAT<=[F:PER]PEREND &  [L]COMPANY=[F:PER]CPY & [L]LEDGENMAIN=[F:PER]LEDTYP
 [L]EXERCICE = [F:PER]FIYNUM
 [L]PERIODE  = [F:PER]PERNUM
 Return
Endif
For [PER]PER0 Where [F:PER]CPY=[L]COMPANY & [F:PER]PERSTR<=[L]DAT & [F:PER]PEREND>=[L]DAT & [F:PER]LEDTYP=[L]LEDGENMAIN
 [L]EXERCICE = [F:PER]FIYNUM
 [L]PERIODE  = [F:PER]PERNUM
Next
Return



