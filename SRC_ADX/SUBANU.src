#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion objet ANU
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ANU",GBIDC1,GBIDC2) From GOBJET
End

#------------------------------------------------#
$ACTION
Case ACTION
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "LIENS"       : Gosub LIENS
 When "MODIF"       : Gosub MODIF
 When "CREATION"    : Gosub CREATION
 When "APRES_CRE"   : Gosub APRES_CRE
 When "APRES_MOD"   : Gosub APRES_MOD
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "ANNULE"      : Gosub ANNULE
 When "AP_ANNULE"   : Gosub AP_ANNULE
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "AVANTBOUT"   : Gosub AVANTBOUT
 When "SEL_LISTE"   : Gosub SEL_LISTE
Endcase
Return

#--------------------------------------------#
$LIENS
For I=1 To [M]NBRFLD
 Case [M]TYPFLD(I-1)
  When 1,2,3
   Read [ATZ]CODZONE="AUTILIS";CODFLD(I-1)
   If !fstat
    Call TEXTE([F:ATZ]NOCOURT,[M]NAMFLD(I-1)) From OBJDIV
   Endif
  When 4
   Read [ADP]ADP1=CODFLD(I-1)
   If !fstat
    Call TEXTE([F:ADP]NAM,[M]NAMFLD(I-1)) From OBJDIV
   Endif
 Endcase
Next I
For I=1 To dim([F:ANU]FORFLD)
 K = find(I,[F:ANU]TYPFLD)
 If K
  [M]FORFOR(K-1) = [F:ANU]FORFLD(I-1)
 Endif
Next I
Return

#--------------------------------------------#
$CREATION
$MODIF
Call MAJTEXTRA([M]INTIT,"ANNUAIRE","INTIT",[M]COD,"") From ATEXTRA
Return

#--------------------------------------------#
$INICRE
$INIMOD
For I=1 To dim([F:ANU]FORFLD)
 K = find(I,[M]TYPFLD)
 If K
  [F:ANU]FORFLD(I-1) = [M]FORFOR(K-1)
 Endif
Next I
Return

#--------------------------------------------#
$VERIF_CRE
$VERIF_MOD
If !find(1,[M]TYPFLD)
 GMESSAGE = mess(57,130,1) : # Identificateur unique non renseigné
 OK = 0 : Return
Endif
Return

#--------------------------------------------#
$APRES_CRE
$APRES_MOD
Call VALID(CLECUR1,nomap,0) From ASSOGEN
Return

#--------------------------------------------#
$ANNULE
Delete [AXX] Where CODFIC="ANNUAIRE" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

#--------------------------------------------#
$AP_ANNULE
Local Char PREF(10)
Call SET_PREF(PREF)
Call DELTRT(PREF+[L]CODE,"") From SUBADC
Return

#--------------------------------------------#
$APRES_MODIF
Case zoncou
 When "MODPAS" : Affzo PASSE 
Endcase
Return

#-----------------------------------------------#
$AVANTBOUT
Case BOUT
 When "1"
  OK = 1 : Call OUINON(mess(54,100,1)-CLECUR1,OK) From GESECRAN
  If OK=2
   Call DEBTRANS From GLOCK
   Gosub TR_PASSE
   If GOK=1
    [M]PASSE = "" : Affzo PASSE
   Endif
  Endif
Endcase
Return

#---------------#
$TR_PASSE
GOK=1
Trbegin [ANU]
 Readlock [ANU]ANU0 = CLECUR1
 If fstat=1
  GOK=-1 : GLOCK="$ANNUAIRE"-CLECUR1 : Goto ROLL_PASSE
 Endif
 If dim([F:ANU]UPDUSR)>0 : [F:ANU]UPDUSR = GUSER : Endif
 If dim([F:ANU]UPDDAT)>0 : [F:ANU]UPDDAT = date$ : Endif
 [F:ANU]PASSE  = ""
 Rewrite [ANU]
 If fstat
  GOK=0 : Call FSTA("ANU") From GLOCK : Goto AB_PASSE
 Endif
Commit
Return

$ROLL_PASSE
Rollback
Call ROLL From GLOCK
If !GROLL : Goto TR_PASSE : Endif
Return

$AB_PASSE
Rollback
Return

#--------------------------------------------#
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET
Else
 CHMEN += "3"
 If instr(1,GUSRAUZ(1),"P")
  CHMEN += "1" : # Mot de passe
 Endif
Endif
Return

#--------------------------------------------#
$EXEBOUT
Case BOUT
 When "V" : Call VALID(CLECUR1,nomap,0) From ASSOGEN
Endcase
Return

#------------------------------------------------#
Subprog SET_PREF(PREF)
Variable Char PREF
PREF = "WMO"
End

#------------------------------------------------#
$SEL_LISTE
Case LISTE
 When "ASSOSELTYP"
  Gosub SET_LEVEL
  NBTEX += 1 : TEX(NBTEX) = LEVEL(1)
  NBTEX += 1 : TEX(NBTEX) = LEVEL(2)
  NBTEX += 1 : TEX(NBTEX) = LEVEL(3)
 When "ASSOSELDOM"
  # Recherche du domaine courant
  Local Char DOMAINE(50)
  Call PARCLI("NameDnsDomain",DOMAINE) From GLOBVAR
  I = instr(1,DOMAINE,"\")
  If I
   DOMAINE = left$(DOMAINE,I-1)
  Endif
  NBTEX += 1
  TEX(NBTEX) = DOMAINE
Endcase
Return

#--------------------------#
$SET_LEVEL
Local Char LEVEL(10)(1..3)
LEVEL(1) = "LEVEL"
LEVEL(2) = "BASE"
LEVEL(3) = "SUBTREE"
Return

#------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap 
 Local File ANNUAIRE  [ANU1] 
 Local File ATEXTRA   [AXX1]
Else 
 Local File =[M]DOSORG+".ANNUAIRE"  [ANU1]
 Local File =[M]DOSORG+".ATEXTRA"   [AXX1] 
Endif 
If [M]DOSDES=nomap 
 Local File ANNUAIRE  [ANU2] 
 Local File ATEXTRA   [AXX2] 
Else 
 Local File =[M]DOSDES+".ANNUAIRE"  [ANU2]
 Local File =[M]DOSDES+".ATEXTRA"   [AXX2] 
Endif 
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ANU1] , [ANU2] , [AXX1] , [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [ANU2]
 Delete [ANU2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ANNUAIRE" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ANU2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AXX2] Where CODFIC="ANNUAIRE" & ZONE="INTIT" & IDENT1=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ANNUAIRE" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AXX2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ANU1] Where COD=TABLE
  [F:ANU2] = [F:ANU1]
  Call COPTEXTRA("ANNUAIRE","INTIT",num$(TABLE),"") From ATEXTRA
  If dim([F:ANU2]UPDUSR)>0 : [F:ANU2]UPDUSR = GUSER : Endif
  If dim([F:ANU2]UPDDAT)>0 : [F:ANU2]UPDDAT = date$ : Endif
  If dim([F:ANU2]UPDTIM)>0 : [F:ANU2]UPDTIM = time  : Endif
  Write [ANU2]
  If fstat
   GOK=0 : Call FSTA("ANU2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#-----------------------------------------------#
# Vérification saisie paramètre SSODIRECT
#-----------------------------------------------#

Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM
Variable Char VALEUR
Variable Integer OK
Local Integer K
Local Char    MESSA(200)
Case PARAM
 When "SSODIRECT"
  End : # Paramètre obsolète
  Local Integer PORT , AERR
  Local Char    MESSAG(250)
  Call VERIF(0,"",PORT,AERR,MESSAG) From ASSOCODE
  If AERR
   Call ERREUR(MESSAG) From GESECRAN
   OK = 0 : End
  Endif
Endcase
End

#------------------------------------------------------------#
# Appelé en validation dossier
#------------------------------------------------------------#

Subprog GENDOS(APPLI)
Value Char APPLI
Local Integer OK
If clalev([F:AN2])=0 : Local File =APPLI+".ANNUAIRE" [AN2] : Endif
For [AN2]ANU0
 Call ECR_TRACE([F:AN2]COD,0) From GESECRAN
 Call VALID([F:AN2]COD,APPLI,1) From ASSOGEN
Next AN2
End

#------------------------------------------------#
Subprog C_CODFLD(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Case [M]TYPFLD(nolign-1)
 When 1,2,3
  Read [ATZ]CODZONE="AUTILIS";VALEUR
  If fstat
   Call AVERTIR(VALEUR-":"-mess(13,133,1)-"AUTILIS",OK) From GESECRAN : # Champ inexistant dans la table
   If OK<>2 : mkstat =2 : End : Endif
  Endif
 When 4
  Read [ADP]ADP1=VALEUR
  If fstat
   Call AVERTIR(mess(2,114,1),OK) From GESECRAN : # Code paramètre inexistant
   If OK<>2 : mkstat =2 : End : Endif
  Elsif [F:ADP]NIVDEF<>4
   Call ERREUR(mess(161,142,1)-mess([F:ADP]NIVDEF,987,1)) From GESECRAN : # Le paramètre est défini au niveau 
   mkstat = 2 : End
  Endif
Endcase
End

Subprog AM_CODFLD(VALEUR)
Variable Char    VALEUR()
Case [M]TYPFLD(nolign-1)
 When 1,2,3
  Read [ATZ]CODZONE="AUTILIS";VALEUR
  If !fstat
   Call TEXTE([F:ATZ]NOCOURT,[M]NAMFLD(nolign-1)) From OBJDIV
  Endif
 When 4
  Read [ADP]ADP1=VALEUR
  If !fstat
   Call TEXTE([F:ADP]NAM,[M]NAMFLD(nolign-1)) From OBJDIV
  Endif
Endcase
End

Subprog S_CODFLD(VALEUR)
Variable Char    VALEUR()
Local Char    VALPAR(30) , PARAM(250)(1..20)
Case [M]TYPFLD(nolign-1)
 When 1,2,3
  PARAM(1) = "AUTILIS"
  Call S_TAB_CHAR(VALEUR,PARAM,"SELFLDTAB1","LNKSUB","") From GACTION
 When 4
  Filter [ADP] Where NIVDEF=4
  PARAM(1) = "ADP"
  Call S_TAB_CHAR(VALEUR,PARAM,"SELOBJSTD","SELOBJ","") From GACTION
  Filter [ADP]
Endcase
End

Subprog C_TYPFLD(VALEUR)
Variable Integer VALEUR
End

Subprog AS_FORFOR(VALEUR)
Variable Char    VALEUR()
If !find([M]TYPFLD(nolign-1),1,2) : mkstat = 1 : End : Endif
End

Subprog IB_DOMAIN
# Recherche du domaine courant
Local Char DOMAINE(50)
Local Integer I
Call PARCLI("NameDnsDomain",DOMAINE) From GLOBVAR
I = instr(1,DOMAINE,"\")
If I
 DOMAINE = left$(DOMAINE,I-1)
Endif
I = 0
For [ANU]ANU0 Where DOMAIN=[L]DOMAINE & ENAFLG=2
 I += 1
Next ANU
If I or DOMAINE="" : Raz GBOUTS : Endif
End

Subprog S_DOMAIN(VALEUR)
Variable Char    VALEUR()
Local Char PARAM(30)(1..2)
Call S_LIS_CHAR(VALEUR,PARAM,"ASSOSELDOM","SUBANU","") From GACTION
End

Subprog C_DOMAIN(VALEUR)
Variable Char    VALEUR()
Local Char COD(GLONANU)
If VALEUR="" : End : Endif
For [ANU]ANU0 Where DOMAIN=VALEUR & COD<>[M]COD & ENAFLG=2
 COD = [F:ANU]COD
Next ANU
If [L]COD<>""
 GMESSAGE = VALEUR-":"-func AFNC.MES1(mess(104,130,1),[L]COD) : # Domaine déjà référencé sur le code $1$
 mkstat = 1 : End
Endif
End

