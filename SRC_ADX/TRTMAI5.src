#<AdxTL>@(#)3.0.0.0 $Revision$
################################################################################################################
# Etape 5 de la définition d'un mailing                                   Module CRM          5 décembre 2000  #
################################################################################################################
# Sélection du mode d'expédition
################################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "SETBOUT"      : Gosub SETBOUT
    When "DEBUT"        : Gosub DEBUT
    When "FINSAI"       : Gosub FINSAI
    When "BOUTON"       : Gosub BOUTON
    When Default
  Endcase
Return

################################################################################################################
$OUVRE
Global Char GSZTPLSRC(50)
Global Char GSZNEWTPL(50)
Global Char GSZEMASUBJECT(90)
Global Integer GIEMATXT
Global Integer GITPLSEL

  If clalev ([F:ARP]) <= 0 : Local File AREPORT [ARP] : Endif
  If clalev ([F:ARD]) <= 0 : Local File AREPORTD [ARD] : Endif
  If clalev ([F:ARV]) <= 0 : Local File AREPORTV [ARV] : Endif
  If clalev ([F:OMR]) <= 0 : Local File OMMRPT [OMR] : Endif
  If clalev ([F:MXL]) <= 0 : Local File MAILXML [MXL] : Endif
  GSZTPLSRC = ""
  GSZNEWTPL = ""
  GIEMATXT = 0
  GITPLSEL = 0
Return

################################################################################################################
$DEBUT
  Read [OMM]OMM0=GSZOPGNUM
  If fstat Then
    [M:MAI5]SHIMOD = 1
    [M:MAI5]TYPMRG = 1
    [M:MAI5]TPL = ""
    If GSZTPLSRC <> "" Then
      Call REMTPLEXT(GSZTPLSRC, [M:MAI5]TPL) From CRM_UTIL
    Endif
  Else
    If [F:OMM]TPL = "" Then
      [M:MAI5]SHIMOD = 1
      [M:MAI5]TYPMRG = 1
      [M:MAI5]TPL = ""
      If GSZTPLSRC <> "" Then
        Call REMTPLEXT(GSZTPLSRC, [M:MAI5]TPL) From CRM_UTIL
      Endif
    Else
      [M:MAI5]SHIMOD = [F:OMM]SHIMOD
      [M:MAI5]TPL = [F:OMM]TPL
      If [F:OMM]TYPMRG = 0 Then
        [M:MAI5]TYPMRG = 1
      Else
        [M:MAI5]TYPMRG = [F:OMM]TYPMRG
      Endif
    Endif
  Endif
  Affzo [M:MAI5]
Return

################################################################################################################
$SETBOUT
  # -------------------------
  # Boutons :
  #          A-Modèle
  #          B-Texte e-mail
  #          C-Confirmer
  # -------------------------
  If [M:MAI5]SHIMOD <> 2 Then
    Call VIREBOUT(CHMEN, "B") From GOBJET
  Endif
  If [M:MAI5]SHIMOD = 2 Then
    # En mail, il faut avoir saisi le texte et un modèle pour pouvoir confirmer
    If GIEMATXT = 0 or GITPLSEL = 0 Then
      Call VIREBOUT(CHMEN, "C") From GOBJET
    Endif
  Else
    # Autrement, il faut avoir indiqué un modèle pour confirmer
    If GITPLSEL = 0 Then
      Call VIREBOUT(CHMEN, "C") From GOBJET
    Endif
  Endif
  # -----------------------------
  Gosub SET_BOUT_SPE From GSAISIE
Return

################################################################################################################
$BOUTON
  Case BOUT
    When "C"
      Gosub ONCONFIRM
    When Default
  Endcase
Return

################################################################################################################
$FINSAI
  Raz [M:MAI5]
  Kill GSZTPLSRC
  Kill GSZNEWTPL
  Kill GIEMATXT
  Kill GITPLSEL
  Kill GSZEMASUBJECT
Return

#########################################################
# Sous-programmes
#########################################################
#############################################################
$ONCONFIRM
Local Char RETOUR(250)
Local Char SZFEXT(3)

  SZFEXT = "rpt"
  #Affecte le modèle et le mode d'expédition à l'opération marketing.
  Call DEBTRANS From GLOCK
  Trbegin [OMM]
  Readlock [OMM]OMM0=GSZOPGNUM
  #Il s'agit d'un nouvel enregistrement
  If fstat Then
    [F:OMM]SHIMOD = [M:MAI5]SHIMOD
    [F:OMM]TPL = toupper([M:MAI5]TPL)
    [F:OMM]TYPMRG = [M:MAI5]TYPMRG
    [F:OMM]DEFADD = GIDEFADD
    [F:OMM]HIEBPR = GIHIEBPR
    [F:OMM]TYPSEA = GSZTYPSEA
    [F:OMM]CNTTTR = GSZXMLCNTTTR
    [F:OMM]CREHIS = 0
    Write [OMM]
    If fstat Then
      GMESSAGE = mess(100,141,1) #Erreur Création
      GERR = 1
      Rollback
      End
    Else
      Commit
    Endif
  Else
    [F:OMM]SHIMOD = [M:MAI5]SHIMOD
    [F:OMM]TPL = toupper([M:MAI5]TPL)
    [F:OMM]TYPMRG = [M:MAI5]TYPMRG
    [F:OMM]DEFADD = GIDEFADD
    [F:OMM]HIEBPR = GIHIEBPR
    [F:OMM]TYPSEA = GSZTYPSEA
    [F:OMM]CNTTTR = GSZXMLCNTTTR
    [F:OMM]CREHIS = 0
    Rewrite [OMM]
    If fstat Then
      GMESSAGE = mess(101,141,1) #Erreur modification
      GERR = 1
      Rollback
      End
    Else
      Commit
    Endif
  Endif
  #Pour les mailing XML, on s'arrête là.
  If [M:MAI5]SHIMOD = 4 Then
    GISTECPL(GICSTEP-1) = 1
    FIN = 1
    Return
  Endif
  GISTECPL(GICSTEP-1) = 1
  FIN = 1
Return

#############################################################
$CANCELSTEP
  If GSZRPTTOCCEL = "" Then
    Return
  Endif
  #
  If clalev ([F:ARP]) <= 0 : Local File AREPORT [ARP] : Endif
  If clalev ([F:ARD]) <= 0 : Local File AREPORTD [ARD] : Endif
  If clalev ([F:ARV]) <= 0 : Local File AREPORTV [ARV] : Endif
  If clalev ([F:OMR]) <= 0 : Local File OMMRPT [OMR] : Endif
  #
  Call DEBTRANS From GLOCK
  Trbegin [ARP], [ARD], [ARV], [OMR]
  #
  #Suppression de l'état
  Delete [ARP] Where [F:ARP]RPTCOD = GSZRPTTOCCEL
  If fstat Then
    Rollback
    Return
  Endif
  #Suppression des paramètres
  Delete [ARD] Where [F:ARD]PARCOD = "opgnum" and [F:ARD]RPTCOD = GSZRPTTOCCEL
  If fstat Then
    Rollback
    Return
  Endif
  #Suppression des paramètres
  Delete [ARD] Where [F:ARD]PARCOD = "opgsnd" and [F:ARD]RPTCOD = GSZRPTTOCCEL
  If fstat Then
    Rollback
    Return
  Endif
  #Suppression des paramètres
  Delete [ARD] Where [F:ARD]PARCOD = "opgkey" and [F:ARD]RPTCOD = GSZRPTTOCCEL
  If fstat Then
    Rollback
    Return
  Endif
  #Suppression des valeurs par défaut
  Delete [ARV] Where [F:ARV]FONCTION = "OMMMAI" and [F:ARV]ETAT = GSZRPTTOCCEL and [F:ARV]PARAM = "opgkey"
  If fstat Then
    Rollback
    Return
  Endif
  #Suppression des valeurs par défaut
  Delete [ARV] Where [F:ARV]FONCTION = "OMMMAI" and [F:ARV]ETAT = GSZRPTTOCCEL and [F:ARV]PARAM = "opgnum"
  If fstat Then
    Rollback
    Return
  Endif
  #Suppression des valeurs par défaut
  Delete [ARV] Where [F:ARV]FONCTION = "OMMMAI" and [F:ARV]ETAT = GSZRPTTOCCEL and [F:ARV]PARAM = "opgsnd"
  If fstat Then
    Rollback
    Return
  Endif
  #Suppression des valeurs par défaut
  Delete [ARV] Where [F:ARV]FONCTION = "OMMEMA" and [F:ARV]ETAT = GSZRPTTOCCEL and [F:ARV]PARAM = "opgkey"
  If fstat Then
    Rollback
    Return
  Endif
  #Suppression des valeurs par défaut
  Delete [ARV] Where [F:ARV]FONCTION = "OMMEMA" and [F:ARV]ETAT = GSZRPTTOCCEL and [F:ARV]PARAM = "opgnum"
  If fstat Then
    Rollback
    Return
  Endif
  #Suppression des valeurs par défaut
  Delete [ARV] Where [F:ARV]FONCTION = "OMMEMA" and [F:ARV]ETAT = GSZRPTTOCCEL and [F:ARV]PARAM = "opgsnd"
  If fstat Then
    Rollback
    Return
  Endif
  #Suppression des valeurs par défaut
  Delete [ARV] Where [F:ARV]FONCTION = "OMMFAX" and [F:ARV]ETAT = GSZRPTTOCCEL and [F:ARV]PARAM = "opgkey"
  If fstat Then
    Rollback
    Return
  Endif
  #Suppression des valeurs par défaut
  Delete [ARV] Where [F:ARV]FONCTION = "OMMFAX" and [F:ARV]ETAT = GSZRPTTOCCEL and [F:ARV]PARAM = "opgnum"
  If fstat Then
    Rollback
    Return
  Endif
  #Suppression des valeurs par défaut
  Delete [ARV] Where [F:ARV]FONCTION = "OMMFAX" and [F:ARV]ETAT = GSZRPTTOCCEL and [F:ARV]PARAM = "opgsnd"
  If fstat Then
    Rollback
    Return
  Endif
  #Suppression dans la liste des maquettes de mailing
  # FLORENT ICI : voir pourquoi c'est là ?
  #  Delete [OMR] Where [F:OMR]MAGTPL = GSZRPTTOCCEL
  #  If fstat Then
  #    Rollback
  #    Return
  #  Endif
  Commit
Return

#############################################################
Funprog DEFINE_ETAT(SZETAT, SMESSAGE)
Value Char SZETAT
Variable Char SMESSAGE

Local Integer ISUCCESS
Local Integer ITRANSFLG

  If adxlog Then
    ITRANSFLG = 1
  Else
    ITRANSFLG = 0
  Endif
  # ----------------------- adxuid(1)
  SZETAT = toupper(SZETAT)
  # -----------------------
  ISUCCESS = 1
  Raz SMESSAGE
  #Crée un nouvel état dans le dictionnaire
  Local File AREPORT [ARP]
  Local File AREPORTD [ARD]
  # -----------------------
  # On regarde d'abord si l'état existe. Pas la peine de le créer dans ce cas.
  # Ni de faire une erreur, puisqu'on va le supprimer à la fin.
  Read [ARP]ARP0=SZETAT
  If !fstat Then
    End ISUCCESS
  Endif
  # -----------------------
  If !ITRANSFLG Then
    Call DEBTRANS From GLOCK
    Trbegin [ARP], [ARD]
  Endif
  [F:ARP]RPTCOD = SZETAT
  [F:ARP]GRP = 15
  [F:ARP]ENAFLG = 2
  [F:ARP]MODULE = 13
  [F:ARP]CODACT = ""
  [F:ARP]MULLAN = 1
  [F:ARP]LAN = GLANGUE
  [F:ARP]RPTDES= 0
  [F:ARP]RPTSHO= 0
  [F:ARP]ORIENT = 1
  [F:ARP]CRYCOD = SZETAT
  [F:ARP]TRTINI = "MAILING"
  [F:ARP]EXEFLG = 2
  [F:ARP]FNC = ""
  [F:ARP]AUZFCY = 1
  [F:ARP]ACS = ""
  [F:ARP]PRTSRV = ""
  [F:ARP]PRTNAM = ""
  [F:ARP]PRTOBL = 1
  [F:ARP]PRTDRV = ""
  [F:ARP]PRTPOR = ""
  [F:ARP]PRTDES = ""
  Write [ARP]
  If fstat Then
    SMESSAGE = mess(100,141,1) - "(a)" #Erreur création
    ISUCCESS = 0
    If !ITRANSFLG Then
      Rollback
    Endif
    End ISUCCESS
  Endif
  #Crée les paramètre pour le nouvel état
  #Paramètre opgnum
  [F:ARD]RPTCOD = SZETAT
  [F:ARD]PARNUM = 1
  [F:ARD]PARCOD = "opgnum"
  [F:ARD]PARNAM = 0
  [F:ARD]PARTYP = "A"
  [F:ARD]PARLNG = 15
  [F:ARD]PARNOLIB = 0
  [F:ARD]PARSTREND = 1
  [F:ARD]PARDEF1 = ""
  [F:ARD]PARDEF2 = ""
  [F:ARD]PARCTL = ""
  [F:ARD]PARCTLTAB = ""
  [F:ARD]PARSAI = 2
  [F:ARD]PARPAR = ""
  Write [ARD]
  If fstat Then
    SMESSAGE = mess(100,141,1) - "(b)" #Erreur création
    ISUCCESS = 0
    If !ITRANSFLG Then
      Rollback
    Endif
    End ISUCCESS
  Endif
  #Paramètres opgsnd
  [F:ARD]RPTCOD = SZETAT
  [F:ARD]PARNUM = 2
  [F:ARD]PARCOD = "opgsnd"
  [F:ARD]PARNAM = 0
  [F:ARD]PARTYP = "A"
  [F:ARD]PARLNG = 3
  [F:ARD]PARNOLIB = 0
  [F:ARD]PARSTREND = 1
  [F:ARD]PARDEF1 = ""
  [F:ARD]PARDEF2 = ""
  [F:ARD]PARCTL = ""
  [F:ARD]PARCTLTAB = ""
  [F:ARD]PARSAI = 2
  [F:ARD]PARPAR = ""
  Write [ARD]
  If fstat Then
    SMESSAGE = mess(100,141,1) - "(c)" #Erreur création
    ISUCCESS = 0
    If !ITRANSFLG Then
      Rollback
    Endif
    End ISUCCESS
  Endif
  #Paramètres opgkey
  [F:ARD]RPTCOD = SZETAT
  [F:ARD]PARNUM = 3
  [F:ARD]PARCOD = "opgkey"
  [F:ARD]PARNAM = 0
  [F:ARD]PARTYP = "A"
  [F:ARD]PARLNG = 15
  [F:ARD]PARNOLIB = 0
  [F:ARD]PARSTREND = 1
  [F:ARD]PARDEF1 = ""
  [F:ARD]PARDEF2 = ""
  [F:ARD]PARCTL = ""
  [F:ARD]PARCTLTAB = ""
  [F:ARD]PARSAI = 2
  [F:ARD]PARPAR = ""
  Write [ARD]
  If fstat Then
    SMESSAGE = mess(100,141,1) - "(d)" #Erreur création
    ISUCCESS = 0
    If !ITRANSFLG Then
      Rollback
    Endif
    End ISUCCESS
  Endif
  If !ITRANSFLG Then
    Commit
  Endif
  GSZRPTTOCCEL = SZETAT
End ISUCCESS

#############################################################
Funprog DELETE_ETAT(SZETAT, SMESSAGE)
Value Char SZETAT
Variable Char SMESSAGE

Local Integer ISUCCESS
Local Integer ITRANSFLG

  If adxlog Then
    ITRANSFLG = 1
  Else
    ITRANSFLG = 0
  Endif
  # -----------------------
  ISUCCESS = 1
  Raz SMESSAGE
  If SZETAT = "MAILING" Then
    # Celui là on en a besoin pour la règle de Workflow. On ne le supprime pas.
    End ISUCCESS
  Endif
  #Crée un nouvel état dans le dictionnaire
  Local File AREPORT [ARP]
  Local File AREPORTD [ARD]
  # -----------------------
  If !ITRANSFLG Then
    Call DEBTRANS From GLOCK
    Trbegin [ARP], [ARD]
  Endif
  # -----------------------
  Delete [ARP] Where [F:ARP]RPTCOD = toupper(SZETAT)
  If fstat Then
    SMESSAGE = mess(1,115,1)
    ISUCCESS = 0
    If !ITRANSFLG Then
      Rollback
    Endif
    End ISUCCESS
  Endif
  # -----------------------
  Delete [ARD] Where [F:ARD]RPTCOD = toupper(SZETAT)
  If fstat Then
    SMESSAGE = mess(1,115,1)
    ISUCCESS = 0
    If !ITRANSFLG Then
      Rollback
    Endif
    End ISUCCESS
  Endif
  # -----------------------
  If !ITRANSFLG Then
    Commit
  Endif
End ISUCCESS
