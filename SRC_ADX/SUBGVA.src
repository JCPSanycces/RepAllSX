#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion du fichier GVARCODPAR
Call OBJET("GVA",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "CREATION"  : Gosub CREATION
 When "INICRE"    : Gosub INICRE
Endcase
Return

$OUVRE
If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
Return

$LIENS
Call LECTEXTRA([M:GVA1]DESTRA(nolign-1),"GVARCODPAR","DESTRA",[M:GVA1]CODPAR(nolign-1),"") From ATEXTRA
Return

$VERIF_MOD
Local Char BID(80)
For I=0 To [M]NBLIG-1
 Read [GVA]GVA0 = [M]CODPAR(I)
 If fstat
  [M]MODIF(I) = 2
 Elsif [F:GVA]TYPPAR<>[M]TYPPAR(I)
  [M]MODIF(I) = 1
 Else
  Call LECTEXTRA(BID,"GVARCODPAR","DESTRA",[M:GVA1]CODPAR(I),"") From ATEXTRA
  If BID<>[M:GVA1]DESTRA(I)
   [M]MODIF(I) = 1
  Else
   [M]MODIF(I) = 0
  Endif
 Endif
Next I
Return

$INICRE
Case [M]MODIF(nolign-1)
 When 0
  If dim([F:GVA]CREUSR)>0 & dim([M]CREUSR)>0 : [F:GVA]CREUSR = [M]CREUSR(nolign-1) : Endif
  If dim([F:GVA]CREDAT)>0 & dim([M]CREDAT)>0 : [F:GVA]CREDAT = [M]CREDAT(nolign-1) : Endif
 When 1 : # Modification
  Call MAJTEXTRA([M:GVA1]DESTRA(nolign-1),"GVARCODPAR","DESTRA",[M:GVA1]CODPAR(nolign-1),"") From ATEXTRA
  If dim([F:GVA]CREUSR)>0 & dim([M]CREUSR)>0 : [F:GVA]CREUSR = [M]CREUSR(nolign-1) : Endif
  If dim([F:GVA]CREDAT)>0 & dim([M]CREDAT)>0 : [F:GVA]CREDAT = [M]CREDAT(nolign-1) : Endif
  If dim([F:GVA]UPDUSR)>0 : [F:GVA]UPDUSR = GUSER   : Endif
  If dim([F:GVA]UPDDAT)>0 : [F:GVA]UPDDAT = date$   : Endif
 When 2 : # Création
  If dim([F:GVA]CREUSR)>0 : [F:GVA]CREUSR = GUSER   : Endif
  If dim([F:GVA]CREDAT)>0 : [F:GVA]CREDAT = date$   : Endif
  If dim([F:GVA]UPDUSR)>0 : [F:GVA]UPDUSR = ""      : Endif
  If dim([F:GVA]UPDDAT)>0 : [F:GVA]UPDDAT = [0/0/0] : Endif
  Call MAJTEXTRA([M:GVA1]DESTRA(nolign-1),"GVARCODPAR","DESTRA",[M:GVA1]CODPAR(nolign-1),"") From ATEXTRA
Endcase
Return

$CREATION
For I=0 To [M]NBLIG-1
 If [M]MODIF(I)>0
  For [GVP]GVP0 Where CODPAR=[M]CODPAR(I)
   [F:GVP]TYPPAR   = [M]TYPPAR(I)
   Rewrite [GVP]
   If fstat
    GOK = 0 : Call FSTA("ATR") From GLOCK : Break 2
   Endif
  Next
 Endif
Next I 
Return

Subprog CRE_PAR(PARAM)
Value Char PARAM
Local Integer OK
Local Mask AARCRE [DIA]
[M:DIA]CODPAR = PARAM

$SAI_CREPAR
OK = 2 : Call DIALWIN(OK,mess(25,124,1),"AARCRE") From GESECRAN
# Création paramètre
If OK=2
 Call DEBTRANS From GLOCK
 Gosub TR_CREPAR
 If GOK<1 : Goto SAI_CREPAR : Endif
Endif
End

$TR_CREPAR
GOK = 1
Trbegin [GVA]
 Raz [F:GVA]
 [F:GVA] = [M:DIA]
 Write [GVA]
 If fstat
  GOK = 0 : Call FSTA("GVA") From GLOCK : Goto AB_CREPAR
 Endif
Commit
Return

$AB_CREPAR
Rollback
Return


#########################################################################
# Etiquettes du masque GVA1
#########################################################################
Subprog C_CODPAR(VALEUR)
Variable Char VALEUR()
If VALEUR<>"" & [M]CODPAR(nolign-1)<>""
 If clalev([F:GVP])=0 : Local File GVARPARGAU [GVP] : Endif
 Filter [GVP] Where CODPAR=[M]CODPAR(nolign-1)
 Read [GVP]GVP0 First
 Filter [GVP]
 If !fstat
  GMESSAGE = mess(9,123,1) : # Modification impossible
  VALEUR = [M]CODPAR(nolign-1) : mkstat = 2 : End
 Endif
Elsif VALEUR=""
 mkstat = 2
Endif
Call UNICITE(VALEUR,[M]CODPAR(0..[M]NBLIG-1)) From OBJDIV
End


