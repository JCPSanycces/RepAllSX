#<AdxTL>@(#)2.0.0.0 $Revision$
#*********************************************************************
#
# IMPORT STANDARD DE DEMANDES DE RENOUVELLEMENT DE BIENS EN CONCESSION
#
#*********************************************************************
#    Création
#    GLE - 12.11.2013
#
#*********************************************************************
#    Modification
#
#    XXX - XX.XX.XXXX FQXXXXX XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
#*********************************************************************
End

$ACTION
  Case ACTION
    When "IMP_OUVRE"        : Gosub IMP_OUVRE
    When "IMPORT"           : Gosub IMPORT
    When "IMP_FERME"        : Gosub IMP_FERME
    When Default
  Endcase
Return

$IMP_OUVRE
  Local File FXDASSETS [WFAS]
  Local File RNWPREP   [WRWP]
Return

$IMPORT
  # Contôle d'unicité car pas fait en interactif (la liste de picking est filtrée en conséquence)
  Filter [F:WRWP] Where RNWAASREF <> [F:RWP]RNWAASREF
  Read [F:WRWP]RWP1=[F:RWP]CPY;[F:RWP]MOTHAASREF
  Filter [F:WRWP]

  If !fstat
    Call ECR_TRACE([F:RWP]MOTHAASREF-":"-mess(908,GML_MSGFAS,1),1) From GESECRAN : # bien déjà présent dans une opération de renouvellement
    OK = 0
    Return
  Endif

  # Alimentation par programme du tableau des biens à renouveler car ce tableau n'est pas
  # saisissable en interactif (liste de picking)
  Gosub ADD_MOTHAASREF
Return

$IMP_FERME
  Close File [WFAS]
  Close File [WRWP]
Return

# Alimentation par programme du tableau des biens à renouveler car ce tableau n'est pas
# saisissable en interactif (liste de picking)
$ADD_MOTHAASREF
 Read [F:WFAS]FAS0=[F:RWP]MOTHAASREF

 If fstat
   GMESSAGE = [F:RWP]RNWAASREF-":"-[F:RWP]MOTHAASREF-"not found"-num$(fstat)
   GERR = 1 : OK = 0
   Return
 Endif

 If !find([F:WFAS]AASREF,[M:RWP0]MOTHAASREF)
  If [M:RWP0]RNWDAT<>[0/0/0] & [F:WFAS]PURDAT > [M:RWP0]RNWDAT
   # "La date d'achat de ce bien est postérieure à la date de renouvellement."
   GMESSAGE = mess(812,GML_MSGFAS,1)-format$(GFMDAT4,[F:WFAS]PURDAT)-"-"-format$(GFMDAT4,[M:RWP0]RNWDAT)
   OK = 0
  Else
   [M:RWP0]MOTHAASREF([M:RWP0]NBMOTH)=[F:WFAS]AASREF
   [M:RWP0]MOTHAASDES([M:RWP0]NBMOTH)=[F:WFAS]AASDES1
   [M:RWP0]MOTHRNWFLG([M:RWP0]NBMOTH)=[F:WFAS]RNWFLG
   [M:RWP0]MOTHRNWVAL([M:RWP0]NBMOTH)=[F:WFAS]RNWVAL
   [M:RWP0]MOTHRNWDAT([M:RWP0]NBMOTH)=[F:WFAS]RNWDAT
   [M:RWP0]MOTHPURDAT([M:RWP0]NBMOTH)=[F:WFAS]PURDAT
  Endif
 Endif
Return
