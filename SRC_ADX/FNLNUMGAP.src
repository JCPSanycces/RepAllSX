#<AdxTL>@(#)5.0.0.0 $Revision$
$ACTION
Case ACTION
 When "OUVRE" : Gosub OUVRE
 When "CONT1" : Gosub CONT1
 When "CONT2" : Gosub CONT2
Endcase
Return

$OUVRE
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
If clalev([F:GCM])=0 : Local File GACM [GCM] : Endif
Return

$CONT1
If [M:RPT]PARCOD(nolign-1)="ledtyp"
 Onerrgo

 Local Integer N, LEDTYP
 Local Char CPY(GLONCPY)
 Local Date DAT

 N = find("cpy", [M:RPT]PARCOD)
 CPY = [M:RPT]VALEUR1(N-1)
 N = find("ledtyp", [M:RPT]PARCOD)
 LEDTYP = val([M:RPT]VALINT1(N-1))

 Call LEC_CPY(CPY) From CPTLEC
 Call LEC_GCM([F:CPY]ACM) From CPTLEC
 If [F:GCM]LED(LEDTYP-1)=""
  GMESSAGE = mess(LEDTYP,2644,1)-":"-mess(105,104,1)-CPY
  mkstat = 2 : Return
 Endif
Elsif [M:RPT]PARCOD(nolign-1)="datstr"
 Onerrgo

 Local Integer N, LEDTYP, FIY
 Local Char CPY(GLONCPY)
 Local Date DAT

 N = find("cpy", [M:RPT]PARCOD)
 CPY = [M:RPT]VALEUR1(N-1)
 N = find("ledtyp", [M:RPT]PARCOD)
 LEDTYP = val([M:RPT]VALINT1(N-1))
 [L]DAT = gdat$(val(seg$([M:RPT]VALINT1(nolign-1), 7, 8)), val(seg$([M:RPT]VALINT1(nolign-1), 5, 6)), val(seg$([M:RPT]VALINT1(nolign-1), 1, 4)))

 #Call GETFIY(CPY, LEDTYP, DAT, FIY) From CPTSUB
 #If GUSER="JFL" : Dbgaff : Endif
 Filter [FIY] Where CPY=[L]CPY & LEDTYP=[L]LEDTYP & FIYSTR<=[L]DAT
 Read [FIY]FIY0 Last
 Filter [FIY]
 If fstat
 #If FIY=0
  GMESSAGE = mess(73,104,1)
  mkstat = 2
  Return
 Else
  Raz GMESSAGE, mkstat

  VALEUR = format$(GFMDAT4, [F:FIY]FIYSTR)
  [M]VALEUR1(nolign-1) = VALEUR
  Call CHARGE([M]VALEUR1(nolign-1),[M]PARTYP(nolign-1),[M]NOLIB(nolign-1),[M]LONG(nolign-1),[M]VALINT1(nolign-1)) From FMTVAR

  [M]VALEUR2(nolign-1) = format$(GFMDAT4, [F:FIY]FIYEND)
  Call CHARGE([M]VALEUR2(nolign-1),[M]PARTYP(nolign-1),[M]NOLIB(nolign-1),[M]LONG(nolign-1),[M]VALINT2(nolign-1)) From FMTVAR

  Affzo [M:RPT]
 Endif
Endif
Return

$CONT2
If [M:RPT]PARCOD(nolign-1)="datstr"
 Onerrgo
 If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
 Local Integer N, LEDTYP, FIY
 Local Char CPY(GLONCPY)
 Local Date DAT

 N = find("cpy", [M:RPT]PARCOD)
 CPY = [M:RPT]VALEUR1(N-1)
 N = find("ledtyp", [M:RPT]PARCOD)
 LEDTYP = val([M:RPT]VALINT1(N-1))
 [L]DAT = gdat$(val(seg$([M:RPT]VALINT2(nolign-1), 7, 8)), val(seg$([M:RPT]VALINT2(nolign-1), 5, 6)), val(seg$([M:RPT]VALINT2(nolign-1), 1, 4)))

 Filter [FIY] Where CPY=[L]CPY & LEDTYP=[L]LEDTYP & FIYEND>=[L]DAT
 Read [FIY]FIY0 First
 Filter [FIY]
 If fstat
  GMESSAGE = mess(14,101,1)
  mkstat = 2
 Else
  Raz GMESSAGE, mkstat
  VALEUR = format$(GFMDAT4, [F:FIY]FIYEND)

  [M]VALEUR1(nolign-1) = format$(GFMDAT4, [F:FIY]FIYSTR)
  Call CHARGE([M]VALEUR1(nolign-1),[M]PARTYP(nolign-1),[M]NOLIB(nolign-1),[M]LONG(nolign-1),[M]VALINT1(nolign-1)) From FMTVAR

  [M]VALEUR2(nolign-1) = VALEUR
  Call CHARGE([M]VALEUR2(nolign-1),[M]PARTYP(nolign-1),[M]NOLIB(nolign-1),[M]LONG(nolign-1),[M]VALINT2(nolign-1)) From FMTVAR

  Affzo [M:RPT]
 Endif
Endif
Return

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Integer OKTCA, LEDTYP
Local Date STRDAT
Local Char CPY(GLONCPY), VALEUR(250)

If clalev([F:TCA])=0 : Local File TABCOUAFF  [TCA] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif

Call GETPARAM("cpy", NBPAR, PARAMETRE, GSOCIETE) From ETAT
Call LECTCA(2, OKTCA) From SUBTCA
If OKTCA
 Call SETPARAM("counter", NBPAR, PARAMETRE, [F:TCA]CODNUM(15)) From ETAT
Else
 GMESSAGE = mess(236,108,1)
 GOK=0
 End
Endif
End
