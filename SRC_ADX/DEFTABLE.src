#<AdxTL>@(#)0.0.0.0 $Revision$
#JOJAC - START

$DEFAUT
Case TABLE
 When "EMPLOAD"       : Default File [AD]
 When "EMPLOCPT"      : Default File [CPT]
 When "EMPLOID"       : Default File [ID]
 When "EMPLOIDAFR"    : Default File [EAF]
 When "EMPLOIDMID"    : Default File [EMID]
 When "EMPLOIDPOR"    : Default File [IDPOR]
 When "EMPLOIDSA"     : Default File [ESA]
 When "EMPLOCHD"      : Default File [CHD]
 #JOJAC - START
 #When "EMPLOEXM"      : Default File [EXM]
 When "EMPLOEXM"      : Default File [HREXM]
 #JOJAC - END
 When "EMPLOEXN"      : Default File [EXN]
 When "EMPLOHAB"      : Default File [HAB]
 When "EMPLOJNT"      : Default File [JNT]
 When "EMPLOMED"      : Default File [MED]
 When "EMPLOPAR"      : Default File [PAR]
 When "EMPLORIB"      : Default File [RIB]
 When "EMPLOTRY"      : Default File [TRY]
 When "EMPLOCTR"      : Default File [CTR]
 When "EMPLOCTRAFR"   : Default File [CTRAFR]
 When "EMPLOCTRCPT"   : Default File [CPR]
 When "EMPLOCTRFRA"   : Default File [CTRFRA]
 When "EMPLOCTRMID"   : Default File [CTRMID]
 When "EMPLOCTRPEN"   : Default File [CPN]
 When "EMPLOCTRPOR"   : Default File [CTRPO]
 When "EMPLOCTRSA"    : Default File [CTRSA]
 When "EMPLOCUM"      : Default File [EPC]
 #JOJAC - START
 #When "EMPLODIRNUM"   : Default File [EDM]
 When "EMPLODIRNUM"   : Default File [HREDM]
 #JOJAC - END
 When "EMPLOELC"      : Default File [ELC]
 When "EMPLOPOT"      : Default File [EPO]
 When "EMPLOSAL"      : Default File [SAL]
 When "EMPLOTAXREC"   : Default File [ETR]
Endcase
Return

$LECEMP
If dim(CTR)<0
 Local Char CTR(GLONCTR)
Endif
Read [AD]AD0 = MATRI
Read [CPT]CPT0 = MATRI
Read [ID]ID0 = MATRI
Read [EAF]EAF0 = MATRI
Read [EMID]EMID0 = MATRI
Read [IDPOR]IDPOR0 = MATRI
Read [ESA]ESA0 = MATRI
Filter [CHD] Where REFNUM=MATRI
Read [CHD]CHD1 Last
If fstat : Raz [F:CHD] : Endif
Filter [CHD]
#JOJAC - START
#Filter [EXM] Where REFNUM=MATRI & DATEXM<=DATMAT
#Read [EXM]EXM1 Last
#If fstat : Raz [F:EXM] : Endif
#Filter [EXM]
Filter [HREXM] Where REFNUM=MATRI & DATEXM<=DATMAT
Read [HREXM]EXM1 Last
If fstat : Raz [F:HREXM] : Endif
Filter [HREXM]
#JOJAC - END
Filter [EXN] Where REFNUM=MATRI & EXSDAT<=DATMAT
Read [EXN]EXN1 Last
If fstat : Raz [F:EXN] : Endif
Filter [EXN]
Filter [HAB] Where REFNUM=MATRI
Read [HAB]HAB0 First
If fstat : Raz [F:HAB] : Endif
Filter [HAB]
Filter [JNT] Where REFNUM=MATRI
Read [JNT]JNT0 First
If fstat : Raz [F:JNT] : Endif
Filter [JNT]
Filter [MED] Where REFNUM=MATRI
Read [MED]MED0 First
If fstat : Raz [F:MED] : Endif
Filter [MED]
Filter [PAR] Where REFNUM=MATRI & PARDAT<=DATMAT
Read [PAR]PAR1 Last
If fstat : Raz [F:PAR] : Endif
Filter [PAR]
Filter [RIB] Where REFNUM=MATRI
Read [RIB]RIB0 First
If fstat : Raz [F:RIB] : Endif
Filter [RIB]
Filter [TRY] Where REFNUM=MATRI & STRDATTRY<=DATMAT
Read [TRY]TRY1 Last
If fstat : Raz [F:TRY] : Endif
Filter [TRY]
If CTR<>''
#JOJAC - START
# Filter [CTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
#JOJAC - END

Else
#JOJAC - START
# Filter [CTR] Where REFNUM=MATRI & CTRDAT<=DATMAT
Filter [HRCTR] Where REFNUM=MATRI & CTRDAT<=DATMAT
#JOJAC - END
Endif
#JOJAC - START
#Read [CTR]CTR1 Last
#If fstat : Raz [F:CTR] : Endif
Read [HRCTR]CTR1 Last
If fstat : Raz [F:HRCTR] : Endif
Filter [HRCTR]
#Filter [CTR]
#JOJAC - END
If CTR<>''
 Filter [CTRAFR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
Else
 Filter [CTRAFR] Where REFNUM=MATRI & CTRDAT<=DATMAT
Endif
Read [CTRAFR]CTRAFR1 Last
If fstat : Raz [F:CTRAFR] : Endif
Filter [CTRAFR]
If CTR<>''
 Filter [CPR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
Else
 Filter [CPR] Where REFNUM=MATRI & CTRDAT<=DATMAT
Endif
Read [CPR]CPR1 Last
If fstat : Raz [F:CPR] : Endif
Filter [CPR]
If CTR<>''
 Filter [CTRFRA] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
Else
 Filter [CTRFRA] Where REFNUM=MATRI & CTRDAT<=DATMAT
Endif
Read [CTRFRA]CTRFRA1 Last
If fstat : Raz [F:CTRFRA] : Endif
Filter [CTRFRA]
If CTR<>''
 Filter [CTRMID] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
Else
 Filter [CTRMID] Where REFNUM=MATRI & CTRDAT<=DATMAT
Endif
Read [CTRMID]CTRMID1 Last
If fstat : Raz [F:CTRMID] : Endif
Filter [CTRMID]
#JOJAC - START
#Filter [CPN] Where REFNUM=MATRI & CTRNUM=[F:CTR]CTRNUM
Filter [CPN] Where REFNUM=MATRI & CTRNUM=[F:HRCTR]CTRNUM
#JOJAC - END
Read [CPN]CPN0 First
If fstat : Raz [F:CPN] : Endif
Filter [CPN]
If CTR<>''
 Filter [CTRPO] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
Else
 Filter [CTRPO] Where REFNUM=MATRI & CTRDAT<=DATMAT
Endif
Read [CTRPO]CTRPO1 Last
If fstat : Raz [F:CTRPO] : Endif
Filter [CTRPO]
If CTR<>''
 Filter [CTRSA] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
Else
 Filter [CTRSA] Where REFNUM=MATRI & CTRDAT<=DATMAT
Endif
Read [CTRSA]CTRSA1 Last
If fstat : Raz [F:CTRSA] : Endif
Filter [CTRSA]
#JOJAC - START
#Filter [EPC] Where REFNUM=MATRI & CTRNUM=[F:CTR]CTRNUM
Filter [EPC] Where REFNUM=MATRI & CTRNUM=[F:HRCTR]CTRNUM
#JOJAC - END
Read [EPC]EPC0 First
If fstat : Raz [F:EPC] : Endif
Filter [EPC]
#JOJAC - START
#Filter [EDM] Where REFNUM=MATRI & CTRNUM=[F:CTR]CTRNUM
#Read [EDM]EDM0 First
#If fstat : Raz [F:EDM] : Endif
#Filter [EDM]
Filter [HREDM] Where REFNUM=MATRI & CTRNUM=[F:HRCTR]CTRNUM
Read [HREDM]EDM0 First
If fstat : Raz [F:HREDM] : Endif
Filter [HREDM]
#JOJAC - END
Filter [ELC] Where REFNUM=MATRI
Read [ELC]ELC0 First
If fstat : Raz [F:ELC] : Endif
Filter [ELC]
#JOJAC - START
#Filter [EPO] Where REFNUM=MATRI & CTRNUM=[F:CTR]CTRNUM
Filter [EPO] Where REFNUM=MATRI & CTRNUM=[F:HRCTR]CTRNUM
#JOJAC - END
Read [EPO]EPO0 First
If fstat : Raz [F:EPO] : Endif
Filter [EPO]
If CTR<>''
 Filter [SAL] Where REFNUM=MATRI & CTRNUM=CTR & SALDAT<=DATMAT
Else
 Filter [SAL] Where REFNUM=MATRI & SALDAT<=DATMAT
Endif
Read [SAL]SAL1 Last
If fstat : Raz [F:SAL] : Endif
Filter [SAL]
If CTR<>''
 Filter [ETR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
Else
 Filter [ETR] Where REFNUM=MATRI & CTRDAT<=DATMAT
Endif
Read [ETR]ETR1 Last
If fstat : Raz [F:ETR] : Endif
Filter [ETR]
Return

$OUVRE
If clalev([F:AD])=0 : Local File EMPLOAD [AD] : Endif
If clalev([F:CPT])=0 : Local File EMPLOCPT [CPT] : Endif
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
If clalev([F:EAF])=0 : Local File EMPLOIDAFR [EAF] : Endif
If clalev([F:EMID])=0 : Local File EMPLOIDMID [EMID] : Endif
If clalev([F:IDPOR])=0 : Local File EMPLOIDPOR [IDPOR] : Endif
If clalev([F:ESA])=0 : Local File EMPLOIDSA [ESA] : Endif
If clalev([F:CHD])=0 : Local File EMPLOCHD [CHD] : Endif
If clalev([F:HREXM])=0 : Local File EMPLOEXM [HREXM] : Endif
If clalev([F:EXN])=0 : Local File EMPLOEXN [EXN] : Endif
If clalev([F:HAB])=0 : Local File EMPLOHAB [HAB] : Endif
If clalev([F:JNT])=0 : Local File EMPLOJNT [JNT] : Endif
If clalev([F:MED])=0 : Local File EMPLOMED [MED] : Endif
If clalev([F:PAR])=0 : Local File EMPLOPAR [PAR] : Endif
If clalev([F:RIB])=0 : Local File EMPLORIB [RIB] : Endif
If clalev([F:TRY])=0 : Local File EMPLOTRY [TRY] : Endif
#JOJAC - START
#If clalev([F:CTR])=0 : Local File EMPLOCTR [CTR] : Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
#JOJAC - END
If clalev([F:CTRAFR])=0 : Local File EMPLOCTRAFR [CTRAFR] : Endif
If clalev([F:CPR])=0 : Local File EMPLOCTRCPT [CPR] : Endif
If clalev([F:CTRFRA])=0 : Local File EMPLOCTRFRA [CTRFRA] : Endif
If clalev([F:CTRMID])=0 : Local File EMPLOCTRMID [CTRMID] : Endif
If clalev([F:CPN])=0 : Local File EMPLOCTRPEN [CPN] : Endif
If clalev([F:CTRPO])=0 : Local File EMPLOCTRPOR [CTRPO] : Endif
If clalev([F:CTRSA])=0 : Local File EMPLOCTRSA [CTRSA] : Endif
If clalev([F:EPC])=0 : Local File EMPLOCUM [EPC] : Endif
#JOJAC - START
#If clalev([F:EDM])=0 : Local File EMPLODIRNUM [EDM] : Endif
If clalev([F:HREDM])=0 : Local File EMPLODIRNUM [HREDM] : Endif
#JOJAC - END
If clalev([F:ELC])=0 : Local File EMPLOELC [ELC] : Endif
If clalev([F:EPO])=0 : Local File EMPLOPOT [EPO] : Endif
If clalev([F:SAL])=0 : Local File EMPLOSAL [SAL] : Endif
If clalev([F:ETR])=0 : Local File EMPLOTAXREC [ETR] : Endif
Return

$VARTEMPS
NBVAR = 0
NBVAR += 1 : TBVAR(NBVAR) = "HOUSUP10"
LIBVAR(NBVAR) = "Increased hours"
NBVAR += 1 : TBVAR(NBVAR) = "HOUSUP25"
LIBVAR(NBVAR) = "Overtime 25§%"
NBVAR += 1 : TBVAR(NBVAR) = "HOUSUP50"
LIBVAR(NBVAR) = "Overtime 50%"
NBVAR += 1 : TBVAR(NBVAR) = "HOUCTG"
LIBVAR(NBVAR) = "Hour quota"
NBVAR += 1 : TBVAR(NBVAR) = "HOUREP50"
LIBVAR(NBVAR) = "Time off in lieu 50%"
NBVAR += 1 : TBVAR(NBVAR) = "HOUREP100"
LIBVAR(NBVAR) = "Time off in lieu 100%"
