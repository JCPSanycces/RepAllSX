$DATETEMPS
NBDAT = 0
NBDAT += 1 : TBDAT(NBDAT) = "DEBMAL"
LIBDAT(NBDAT) = "Start of last sick leave"
NBDAT += 1 : TBDAT(NBDAT) = "MAL"
LIBDAT(NBDAT) = "End of last sick leave"
NBDAT += 1 : TBDAT(NBDAT) = "DEBAT"
LIBDAT(NBDAT) = "Start of last leave"
NBDAT += 1 : TBDAT(NBDAT) = "AT"
LIBDAT(NBDAT) = "End of last leave"
NBDAT += 1 : TBDAT(NBDAT) = "DEBMPR"
LIBDAT(NBDAT) = "Start date of last occupational disease"
NBDAT += 1 : TBDAT(NBDAT) = "MPR"
LIBDAT(NBDAT) = "End date of last occupational disease"
NBDAT += 1 : TBDAT(NBDAT) = "DEBATJ"
LIBDAT(NBDAT) = "Start date of last AtfW"
NBDAT += 1 : TBDAT(NBDAT) = "ATJ"
LIBDAT(NBDAT) = "End date of last AtfW"
Return


#JOJAC - END

