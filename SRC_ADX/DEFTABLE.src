LIBVAR(NBVAR) = "Night baskets"
NBVAR += 1 : TBVAR(NBVAR) = "QTY1"
LIBVAR(NBVAR) = "First quantity"
NBVAR += 1 : TBVAR(NBVAR) = "QTY2"
LIBVAR(NBVAR) = "Second quantity"
