#<AdxTL>@(#)11.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Update field LANISO on file TABLAN
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Update field LANISO on file TABLAN") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
If DOSSIER=nomap
 Local File TABLAN [TLA]
Else
 Local File =DOSSIER+".TABLAN" [TLA]
Endif
Gosub MAJTABLAN
Close Local File [TLA]
End

#----------------------------------------------------------------------------------------#
$MAJTABLAN
Trbegin [TLA]
# laniso has to be fixed for known languages
# For [TLA] Where LANISO=""
 For [TLA]
  Case [F:TLA]LAN
   When "BRI" : [F:TLA]LANISO = "en-GB"
   When "CHI" : [F:TLA]LANISO = "zh-CN"
   When "ENG" : [F:TLA]LANISO = "en-US"
   When "FRA" : [F:TLA]LANISO = "fr-FR"
   When "GER" : [F:TLA]LANISO = "de-DE"
   When "ITA" : [F:TLA]LANISO = "it-IT"
   When "POL" : [F:TLA]LANISO = "pl-PL"
   When "POR" : [F:TLA]LANISO = "pt-PT"
   When "RUS" : [F:TLA]LANISO = "ru-RU"
   When "SPA" : [F:TLA]LANISO = "es-ES"
  Endcase
  If [F:TLA]LANISO<>""
   Rewrite [F:TLA]
   If fstat
    Call ERREUR("TLA"-[F:TLA]LAN,2) From DOSDIC
   Endif
  Endif
 Next
Commit
Return

#----------------------------------------------------------------------------------------#

