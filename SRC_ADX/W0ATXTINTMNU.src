#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ATXTINTMNU 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone LANCHP
mkstat = 0
zoncou = "LANCHP"
indice = 0
WNUM = [M]LANCHP
If varmode([M]LANCHP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LANCHP" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_LANCHP([M]LANCHP) From ATXTINTMNU
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "LANCHP" : GZNUM = 775 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>[M]LANCHP or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_LANCHP([M]LANCHP) From ATXTINTMNU
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "LANCHP" : GZNUM = 775 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone LAN
mkstat = 0
zoncou = "LAN"
indice = 0
If varmode([M]LAN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LAN" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]LAN,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "LAN" : GZNUM = 1505 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("TLA","",[M]LAN,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "LAN" : GZNUM = 1505 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_LAN([M]LAN) From ATXTINTMNU
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "LAN" : GZNUM = 1505 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone LANNUMA
mkstat = 0
zoncou = "LANNUMA"
indice = 0
WCHAR = [M]LANNUMA
If varmode([M]LANNUMA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LANNUMA" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]LANNUMA,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "LANNUMA" : GZNUM = 171 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_LANNUMA([M]LANNUMA) From ATXTINTMNU
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "LANNUMA" : GZNUM = 171 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]LANNUMA or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_LANNUMA([M]LANNUMA) From ATXTINTMNU
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "LANNUMA" : GZNUM = 171 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone TXTPDTCODA
mkstat = 0
zoncou = "TXTPDTCODA"
indice = 0
WCHAR = [M]TXTPDTCODA
If varmode([M]TXTPDTCODA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TXTPDTCODA" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_TXTPDTCODA([M]TXTPDTCODA) From ATXTINTMNU
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "TXTPDTCODA" : GZNUM = 12792 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]TXTPDTCODA or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_TXTPDTCODA([M]TXTPDTCODA) From ATXTINTMNU
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "TXTPDTCODA" : GZNUM = 12792 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone NONTRA
mkstat = 0
zoncou = "NONTRA"
indice = 0
IMPENT = [M]NONTRA
If varinit([M]NONTRA,indice)=0
 IMPENT = 1
Endif
[M]NONTRA = IMPENT

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone UPDCODE
mkstat = 0
zoncou = "UPDCODE"
indice = 0
If varmode([M]UPDCODE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "UPDCODE" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone UPDLANORI
mkstat = 0
zoncou = "UPDLANORI"
indice = 0
If varmode([M]UPDLANORI,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "UPDLANORI" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("TLA","!",[M]UPDLANORI,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "UPDLANORI" : GZNUM = 9760 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone UPDTEXTE
mkstat = 0
zoncou = "UPDTEXTE"
indice = 0
If varmode([M]UPDTEXTE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "UPDTEXTE" : Gosub ACTION From =IMPTRT
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "ATXTINTMNU"
Return

