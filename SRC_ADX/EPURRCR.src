#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "OUVRE"
     Case [F:AHI]COD
       When "RCH"   : Gosub OUVRE_RCRINVOICE
     Endcase
  When "EPURE"
    Case [F:AHI]COD
       When "RCH"   : Gosub EPURE_RCRINVOICE
    Endcase
  When "FERME"
    Case [F:AHI]COD
       When "RCH"   : Gosub FERME_RCRINVOICE
    Endcase
Endcase
Return

$OUVRE_RCRINVOICE
If clalev([F:F1])=0  : Local File =[L]APPLI+".RCRINVOICE" [F1]  : Endif
If clalev([F:SIH])=0 : Local File =[L]APPLI+".SINVOICE" [SIH] : Endif
If clalev([F:PIH])=0 : Local File =[L]APPLI+".PINVOICE" [PIH] : Endif
Return

$EPURE_RCRINVOICE
If [L]SIMUL : Return : Endif

Case TABLE
  When "RCRINVOICE"
    If [F:F1]RCRTYP = 1
      Update [F:SIH] Where RCRNUM = [F:F1]RCRNUM With RCRNUM = "", RCRDAT = [0/0/0]
    Elsif [F:F1]RCRTYP = 2
      Update [F:PIH] Where RCRNUM = [F:F1]RCRNUM With RCRNUM = "", RCRDAT = [0/0/0]
    Endif
Endcase
Return

$FERME_RCRINVOICE
If clalev([F:F1])   Close Local File [F1]  : Endif
If clalev([F:SIH])  Close Local File [SIH] : Endif
If clalev([F:PIH])  Close Local File [PIH] : Endif
Return
