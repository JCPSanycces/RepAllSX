$MET_VALIDATE
Gosub DECLARE_VAR
[L]AISMET = [V]CST_AYES
[L]AMETHOD = "MET_VALIDATE" : [L]ACTION = "MET_VALIDATE" : [L]CURPRO = "" : Gosub ACTION_MET From ASYRSUB
Return

