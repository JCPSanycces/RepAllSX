####################################################################
# Global methods & standards
####################################################################
$AINIT
Gosub DECLARE_VAR
[L]AEVENT = "AINIT" : [L]ACTION = "AINIT" : [L]CURPRO = "" : Gosub ACTION From ASYRSUB
Return

####################################################################
# AERRORS
####################################################################

$_AERROR
Gosub DECLARE_VAR From WMC0EDISEQFIL
Local Integer ALLSTAT
Call ALLERRORS(this,_CTX,_SUPP) From ASYRSUB
For AINDCLA=1 To maxtab(this.ESFD)
 If this.ESFD(AINDCLA)<>null
  [L]ASTATUS = fmet this.ESFD(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.ESFF)
 If this.ESFF(AINDCLA)<>null
  [L]ASTATUS = fmet this.ESFF(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
For AINDCLA=1 To 20
 If this.ESFN(AINDCLA)<>null
  [L]ASTATUS = fmet this.ESFN(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
Return

####################################################################
# Delete all errors
####################################################################

$_ADELERRORS
Gosub DECLARE_VAR From WMC0EDISEQFIL
Local Integer ALLSTAT
[L]ASTATUS = fmet this.ADELETEERROR([L]_APARAM)
For AINDCLA=1 To maxtab(this.ESFD)
 If this.ESFD(AINDCLA)<>null
  [L]ASTATUS = fmet this.ESFD(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.ESFF)
 If this.ESFF(AINDCLA)<>null
  [L]ASTATUS = fmet this.ESFF(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
For AINDCLA=1 To 20
 If this.ESFN(AINDCLA)<>null
  [L]ASTATUS = fmet this.ESFN(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
Return

####################################################################
# _ASEARCHINFOS
####################################################################

$_ASEARCHINFOS
Gosub DECLARE_VAR From WMC0EDISEQFIL
ASTATUS= func ASYRSUB.ASEARCHINFOS(this,[L]AINS_ORI,[L]ERR_TYPE,[L]PROPERTY,[L]ASTAT,[L]SELSTAT,[L]PATH)
If [L]ERR_TYPE=[V]CST_ACURRENT : Return : Endif
For AINDCLA=1 To maxtab(this.ESFD)
 If this.ESFD(AINDCLA)<>null
  [L]ASTATUS = fmet this.ESFD(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'ESFD('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.ESFF)
 If this.ESFF(AINDCLA)<>null
  [L]ASTATUS = fmet this.ESFF(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'ESFF('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
For AINDCLA=1 To 20
 If this.ESFN(AINDCLA)<>null
  [L]ASTATUS = fmet this.ESFN(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'ESFN('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
Return

####################################################################
# AGETERRORSFROM
####################################################################

$_AGETERRORSFROM
Gosub DECLARE_VAR From WMC0EDISEQFIL
If AINS_FROM<>null
 [L]ASTATUS = fmet AINS_FROM.ASEARCHINFOS( [V]CST_ALL, "", [V]CST_AFATAL, 0)
Endif
Call AGETERRORSFROM(AINS_FROM,this,ENVIRONNEMENT) From ASYRSUB
Return

####################################################################
$ACONTROL
####################################################################
Gosub DECLARE_VAR
[L]AEVENT = "ACONTROL" : [L]ACTION = "ACONTROL" : [L]CURPRO = "" : Gosub ACTION From ASYRSUB
Return

####################################################################
# ADELLINE
####################################################################
$ADELLINE
Case _ACOLLECTION
 When "ESFD"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"ESFD",this)
 When "ESFF"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"ESFF",this)
 When "ESFN"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"ESFN",this)
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# ADDLINE
####################################################################
$ADDLINE
Case _ACOLLECTION
 When "ESFD"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"ESFD","C_EDISEQFILD",this)
 When "ESFF"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"ESFF","C_EDISEQFILF",this)
 When "ESFN"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"ESFN","C_EDISEQFIL_ESFN",this)
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# AGETDIM
####################################################################
$AGETDIM
Case _ACOLLECTION
 When "ESFD"
  [L]_ALINE = 0
 When "ESFF"
  [L]_ALINE = 0
 When "ESFN"
  [L]_ALINE = 20
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# AGETMIN
####################################################################
$AGETMIN
Case _ACOLLECTION
 When "ESFD"
  [L]_ALINE = 1
 When "ESFF"
  [L]_ALINE = 1
 When "ESFN"
  [L]_ALINE = 1
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# _ALOAD_KEYS
####################################################################
$_ALOAD_KEYS
this.AKEYS(1) = "MSGCOD"
this.AKEYS(2) = "MSGREL"
this.AKEYS(3) = "MSGFILNOR"
Return

