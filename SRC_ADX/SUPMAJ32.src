#<AdxTL>@(#)8.0.0.0 $Revision$
#CHECK MIGRATE_SOURCE
Local Char DOSVAL(GLONADS) , DOSREF(GLONADS) , DOSCOP(GLONADS)
#X3-76171
If dim(GMAXSPEACV)>=0 & GMAXSPEACV>0
  Global Char    GSPE(GLONACV)(1..GMAXSPEACV)
Else
  Global Char    GSPE(GLONACV)(1..300)
Endif
#X3-76171
Global Integer GNBSPE
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = "TEST2"
If fstat : End : Endif
DOSVAL = [F:ADS]DOSSIER
DOSREF  = [F:ADS]DOSREF
DOSCOP  = [F:ADS]DOSCOP
Local File ADOSACT [ADA]
GNBSPE = 0
For [ADA]ADA0 Where [F]DOSSIER=[L]DOSVAL & CODACT>="X"
 GNBSPE += 1
 GSPE(GNBSPE) = [F:ADA]CODACT
Next ADA
Close Local File [ADA]
Call OUVRE_TRACE("") From LECFIC
Gosub AMAJSUP
Gosub MAJSUP
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

################################################################################################
#
#  Moulinettes superviseur pour la v6.2
#
#  Ces moulinettes sont réexécutables :
#  si elles sont été déjà lancées elles sont effet si on les lance une deuxième fois
#
################################################################################################


######################################################################
Subprog MAJDIC
Local Integer I , J , K , OK , OKCOP , DETAIL , OUVFIC , EXISTE
Local Char    X3(20) , OBJET(15), APPLI(15) , MESSA(80)
Local Char    TABSPE(GLONATB)(1..100), TABACTS(GLONACV)(1..300)
Local Integer NBSPE , NBACTS , NBFLD , DIME , VERCUR

# Dans cette version, il n'y pas de moulinettes avant

End

######################################################################
Subprog AMAJ
#107271
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER) : End : Endif

Local Char DOSVAL(GLONADS) , DOSREF(GLONADS) , DOSCOP(GLONADS)
DOSVAL = [F:ADS]DOSSIER
DOSREF = [F:ADS]DOSREF
DOSCOP = [F:ADS]DOSCOP
Gosub AMAJSUP
Read [ADS]DOSSIER Curr
End

##################################
$AMAJSUP
If GINFO
 Call AFF_VLC(mess(93,125,1),"Update Supervisor") From GESECRAN
Endif
Call UTIMAJALDNUMTEX(DOSVAL)                      : #  Bug 78943 : Ajout de champ NUMTEX dans la table ALISTED
Call UTIMAJAFPOPT(DOSVAL)                         : #  Bug 81482 : Update the field OPT in table AFCTPRF
Call UTIMAJASUASP(DOSVAL)                    : # Init des champs de la table ASUBPROG dans ASUBPROGD
If GINFO
 Call AFF_VLC("","") From GESECRAN
Endif
Return

######################################################################
Subprog MAJ
#107271
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER) : End : Endif

Local Char DOSVAL(GLONADS) , DOSREF(GLONADS) , DOSCOP(GLONADS)
DOSVAL = [F:ADS]DOSSIER
DOSREF = [F:ADS]DOSREF
DOSCOP = [F:ADS]DOSCOP
Gosub MAJSUP
End

$MAJSUP
If GINFO
 Call AFF_VLC(mess(93,125,1),"Update Supervisor") From GESECRAN
Endif
Call UTILAUSCON(DOSVAL)                      : # Mise à jour du flag USRCONXTD à Oui si USRCONNECT=2
Call UTIMAJAOD(DOSVAL)                       : # Mise à jour table intitulé traduisibles sur les lignes des modèles export
Call UUMAJAOE(DOSVAL)                        : # Mise à jour balise champ dans les modèles d'import/export
Call UTIMAJADCRIG(DOSVAL)                    : # Mise à jour droit sur la table ADICTRT
Call UTIMAJWRKAOE(DOSVAL)                    : # Mise a jour champ workflow dnas les modeles de données
Call UTIMAJFLGSTR(DOSVAL)                    : # Mise a jour champ flgstr dnas les modeles de données
Call UTIMAJACG(DOSVAL)                       : # Mise à jour no de rang dans fonctions ACHANGE
Call UTIMAJADCPAR(DOSVAL)                    : # Rajout du paramètre TYPCOD dans les champs avec le type de données ADC
Call UTIMAJBID(DOSVAL)                       : # Initialisation nouveau champ ACCNONREI
Call UTILEGFIL(DOSVAL)                       : # Suppression du paramètre LEGPORT et de la variable globale GLEGPORT
Call UTIMAJANX(DOSVAL)                       : # Champ commentaire de la table AINDEX en texte traduisible
Call UTIENAARZ(DOSVAL)                       : # Mise à jour flag actif dans fiche paramètrage ZPL
Call UTIMAJTEL(DOSVAL)                       : # Initialisation des nouveaux champs "Téléphone"
Call UTIMAJCTYPAR(DOSVAL)                    : # Mise à jour table paramètre ACTL sur champs avec type de données CTY
Call UTIDOSXTEND(DOSVAL)                     : # mise a jour repertoire xtend
Call UUMAJXTDDIRLAN(DOSVAL)                  : # mise a jour champ DIRLAN Xtend
Call UTIXTDLNKBUSINT(DOSVAL)                 : # Mise à jour table champ LNKBUSINT
Call UTIMAJFLGAWM(DOSVAL)                    : # Mise a jour champ dans les modeles de données
Call UUMAJAUDBI(DOSVAL)                      : # maj audith revalidation ttable ABI
Call UUMAJAUDIDENT(DOSVAL)                   : # maj audith pour gestion IDENT2---IDENT9
Call UTIFLDAWM2(DOSVAL)                      : # Mise à jour table WRKLNK, init champ FLGWRK et FLGAPH supplementaire
Call UTIMAJBIDNUM(DOSVAL)                    : # Mise à jour table BID, init champ BIDNUMFLG
If GINFO
 Call AFF_VLC("","") From GESECRAN
Endif
Return

