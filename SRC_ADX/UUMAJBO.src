#<AdxTL>@(#)11.0.0.0 $Revision$
Call OUVRE_TRACE("MAJ patch BO") From LECFIC
Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End



Subprog PATCH(APPLI)
Value Char APPLI

If !func AFNC.ACTIVDOS(APPLI,"ABI")
 End
Endif

# Mise à jour de la table ABIDIM (Dimensions)
Call ECR_TRACE(mess(81,125,1)-"ABIDIM"-time$,0) From GESECRAN
Call MAJABI(APPLI)
# Mise à jour de la table ABIDATMRT(Champs table de datamart)
Call ECR_TRACE(mess(81,125,1)-"ABIDATMRT"-time$,0) From GESECRAN
Call MAJABM(APPLI)
# Mise à jour de la table ABIDIMFLD (Champs table de dimension)
Call ECR_TRACE(mess(81,125,1)-"ABIDIMFLD"-time$,0) From GESECRAN
Call MAJOPTJNT(APPLI)

End 


#########################################################################################
# Mise à jour des champs option de jointures
#########################################################################################
Subprog MAJOPTJNT(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".ABIDIMFLD"    [ABJ]



Trbegin [ABJ]
 For [ABJ]ABJ0
  If [F:ABJ]DIMFAT<>"" & [F:ABJ]OPTJNT = 0
   [F:ABJ]OPTJNT = 1
   Rewrite [F:ABJ]
   If fstat
    Call ERREUR("ABIDIMFLD"-[F:ABJ]CODDIM,1) From DOSDIC
   Endif
  Endif
 Next
Commit

Close Local File [ABJ]
End


#########################################################################################
# Mise à jour des champs SUPVID dans les dimensions
#########################################################################################

Subprog MAJABI(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".ABIDIM"    [ABI]

Trbegin [ABI]
 For [ABI]ABI0
  If dim([F:ABI]SUPVID)>0 & [F:ABI]SUPVID = 0
   [F:ABI]SUPVID=1
  Endif
  Rewrite [F:ABI]
  If fstat
   Call ERREUR("ABIDIM"-[F:ABI]CODDIM,1) From DOSDIC
  Endif
 Next
Commit

Close Local File [ABI]
End

#########################################################################################
# Mise à jour des champs mesure et code ansi
#########################################################################################
Subprog MAJABM(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".ABIDATMRT"    [ABM]

Trbegin [ABM]
 For [ABM]ABM0
  If dim([F:ABM]ANSI)>0 & [F:ABM]ANSI = 0
   [F:ABM]ANSI=1
  Endif
  If dim([F:ABM]MESURE)>0 & [F:ABM]MESURE = 0
   [F:ABM]MESURE=1
  Endif
  Rewrite [F:ABM]
  If fstat
   Call ERREUR("ABIDATMRT"-[F:ABM]COD,1) From DOSDIC
  Endif
 Next
Commit

Close Local File [ABM]
End
