# Modification
# BFO 23/08/2017 X3-51072: Adding declaration of the variable SAI
# GLE 23/09/2014 FQ102448: L'option Simulation doit toujours être initialisée avec sa valeur quand on ouvre la fonction
# GLE 16/09/2014 FQ95754 : Contrôle sur les biens classés pour vente de l'exercice non sortis
# GLE 20/02/2014 FQ96983 : erreur CLC(-1) : Indice incorrect si aucune société n'est clôturable
# GLE 23/01/2014 FQ96071 : contrôles liés aux concessions uniquement si le contexte les gère
# CBO 23/10/2013 FQ93731 : ajout d'1 fct de contrôle des contextes
# GLE 25/07/2013 FQ91104 : Réactivation des messages lors des clôtures de contextes avec plans de production
# CBO 29/05/2013 FQ88911 : ajout de 2 dates (vides) en paramètre
# GLE 10/12/2012 FQ86530 : il pouvait y avoir des contextes clôturés ou non clôturés à tort lors de la soumission via le serveur batch
# GLE 30/11/2012 FQ84664 : contrôle des événements comptabilisés en prenant en compte la législation
# GLE 30/06/2011 FQ74678:  Le tableau des contextes est vide lorsqu'on rentre sur la fonction
# GLE 14/02/2011 FQ70465 : contrôle pour pouvoir clôturer que le contexte n'est pas désynchronisé avec la compta
# GLE 11/05/2010 FQ65544 : contrôle sur le "A comptabiliser" sur écart de plan
# GLE 13/04/2010 FQ63987 : suppression du contrôle obsolète sur le nombre de paramètre lors de la soumission par requête
# GLE 11/02/2010 FQ54343 : Gestion des concessions
# GLE 02/06/2009 FQ56137 : message "<société> Auncun site n'est accessible dans cette société" à tort
# GBN 01/07/2009 FQ56251 : Impossible de clôturer les contextes si plan de subvention défini sur le contexte comptable et fiscal de la dernière société.
# GLE 29/06/2009 FQ56130 : correction erreur sur classe [FIY] inexistante en soumission batch
# GLE 10/04/2009 FQ54377 : erreur P1 "Variable inexistante" lors de la soumission via une requête
################################################################################
Local Char VALBOUT(30)
Local Char PARBOUT(250)(1..10)
VALBOUT = "12"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","FASCLOTURE","DFASCLO",3, "") From GTRAITE
End

################################################################################
$ACTION
  # Infbox "ACTION = "-ACTION
  Case ACTION
    When "OUVRE_BATCH"      : Gosub OUVRE_BATCH
    When "INIT"             : Gosub INIT
    When "INIT_DIA"         : Gosub INIT_DIA
    When "CONT_BATCH"       : Gosub CONT_BATCH
    When "CONTROLE"         : Gosub CONTROLE
    When "EXEC"             : Gosub EXEC
    When "TERMINE"          : Gosub TERMINE
    When Default
  Endcase
Return
################################################################################

#-------------------------------------------------------------------------------
$OUVRE_BATCH
Global Integer GCURCPY                     : # Indice société cliquée
Global Integer LDIMLSTPLN : LDIMLSTPLN = 2 : # Nombre de dimensions du tableau des liste de plans
Global Integer LIN_PLAN   : LIN_PLAN   = 0 : # Numéro de plan
Global Integer LIN_FLUX   : LIN_FLUX   = 1 : # Flux géré (G_OUI/G_NON)
Local Integer SAI # Issue X3-51072 - 2017-08-22 by BEFOU : SAI : Variable nonexistent

  If clalev([F:FAS])  = 0 : Local File FXDASSETS   [FAS]  : Endif
  If clalev([F:CNX])  = 0 : Local File CONTEXT     [CNX]  : Endif
  If clalev([F:FIS])  = 0 : Local File FISCYEAR    [FIS]  : Endif
  If clalev([F:FISS]) = 0 : Local File FISCYEAR    [FISS] : Endif
  If clalev([F:CPY])  = 0 : Local File COMPANY     [CPY]  : Endif
  If clalev([F:DEP])  = 0 : Local File DEPREC      [DEP]  : Endif
Return

#-------------------------------------------------------------------------------
$INIT
Global Integer GCURCPY                     : # Indice société cliquée
Global Integer LDIMLSTPLN : LDIMLSTPLN = 2 : # Nombre de dimensions du tableau des liste de plans
Global Integer LIN_PLAN   : LIN_PLAN   = 0 : # Numéro de plan
Global Integer LIN_FLUX   : LIN_FLUX   = 1 : # Flux géré (G_OUI/G_NON)

  If clalev([F:FAS])  = 0 : Local File FXDASSETS   [FAS]  : Endif
  If clalev([F:CNX])  = 0 : Local File CONTEXT     [CNX]  : Endif
  If clalev([F:FIS])  = 0 : Local File FISCYEAR    [FIS]  : Endif
  If clalev([F:FISS]) = 0 : Local File FISCYEAR    [FISS] : Endif
  If clalev([F:CPY])  = 0 : Local File COMPANY     [CPY]  : Endif
  If clalev([F:DEP])  = 0 : Local File DEPREC      [DEP]  : Endif
Return

#-------------------------------------------------------------------------------
$INIT_DIA
  Call TEMPON("R") From GESECRAN
  Gosub AFFICHE
  Call TEMPOFF From GESECRAN
Return

#-------------------------------------------------------------------------------
$AFFICHE
Local Integer NPLANGERE
Local Integer N_I, N_E, N_FIRST, LNBRTRY
Local Char    LCNBRTRY

Local Integer WCNXERR # FQ93731
Local Char WSOCERR(30), WMESS(250) # FQ93731

  # FQ102448
  If !GSERVEUR
    Raz [M:FAST]FLGSIM : # Le Raz permet à l'INIT de s'exécuter quand on retourne sur la fonction (voir instruction varinit)
  Endif

  Call PARAM("","NBESSCLC",LCNBRTRY) From ADOVAL
  LNBRTRY = val(LCNBRTRY)
  If LNBRTRY < 0 Then
    LNBRTRY = 0
  Endif
  #------------------------------
  N_I = 1
  N_E = 1
  For [CPY]CPY0
   If func GLOBIENS.HAS_CPY_FAS_DISABLE([CPY]CPY) = G_NON
    Call CONTALLFCY([F:CPY]CPY) From SUPCPT
    If mkstat<>2
     Gosub TRT_CPY
    Else
     GMESSAGE = "" : # FQ56137 : dans ce cas là, il faut remettre le message à blanc sinon il apparait à tort plus tard
     mkstat=1
    Endif
   Endif
  Next CPY0
  #------------------------------
  [M:FAST]NBCNXG = N_I-1
  [M:FAST]NBCPY  = N_E-1
  [M:FAST]NBCNX  = 0
  #------------------------------
  Call ACTION_BLOCK (ACB_AFFZO, "FASCLOTURE", "CPY") From GLOBIENS
  Call ACTION_BLOCK (ACB_AFFZO, "FASCLOTURE", "CNXG") From GLOBIENS
  #------------------------------
  If ( [M:FAST]NBCPY = 0 ) Then
    Call MESSAGE (mess(55,7774,1)) From GESECRAN
    End : # FQ96983 : attention, le End est volontaire car c'est le seul moyen d'interrompre le Superviseur si aucune société n'est cloturable
# FQ74678
#  Else
#    GCURCPY        = 1
#    Call AFFICHE_G_EN_D (GCURCPY)
  Endif
  #------------------------------
Return

#----------------------------
# Alimentation des société éligibles pour la clôture
$TRT_CPY
  Local Shortint CNX_OK
  Local Integer  TYP
  Local Char     TLSTEVTTYP(1)
  Local Integer  TLSTPLN(1)
  Local Integer  TLSTNBE(1)
  Local Integer  RET

  N_FIRST = 0

  For [CNX]CNX0 Where CPY=[F:CPY]CPY
    CNX_OK=G_OUI
    #------------------------------
    Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TECOURA
    Read [FIS]FIY0 First
    Filter [FIS]
    #------------------------------
    If [F:FIS]DATENDFIY = [F:FIS]DATENDPER([F:FIS]INDCURPER-1) Then
      TYP = 2 : # contrôle sur l'exercice
    Else
      TYP = 1 : # contrôle sur la période courante
    Endif
    #------------------------------
    If !GBATCH and !GSERVEUR Then
      #--------------------------------
      # on vérifie qu'une CIG utilisant la société n'a pas été définie
      Local Integer RETOUR
      Call CONTROLE_CIG([F:CPY]CPY, 2, RETOUR) From GLOBIENS
      If RETOUR
        Break : # Toute la société est rejetée
      Endif

      #------------------------------
      # Existe-t'il un bien non calculé ?
      If CNX_OK = G_OUI and func GLOBIENS.IS_CNX_CALCULATE([F:CNX]CPY, [F:CNX]CNX,
&                                       [F:FIS]DATENDFIY, [F:FIS]DATENDPER([F:FIS]INDCURPER-1)) = G_NON
        CNX_OK = G_NON
      Endif

      #------------------------------ FQ70465
      # Les périodes des référentiels de la compta qui suivent la période courante sont-elles ouvertes ?
      If func GLOBIENS.ACCPERCTL([F:CNX]CPY)
        Local Shortint N_PLN
        For N_PLN = 0 To [F:CNX]NBPLC-1
          If func GLOBIENS.PERCPT_STATE([F:CPY]CPY, [F:CNX]LEDTYP(N_PLN), [F:FIS]DATENDPER([F:FIS]INDCURPER-1)+1) <> 2
            CNX_OK = G_NON
            Break
          Endif
        Next
      Endif

      #------------------------------
      # En clôture exercice, toutes les périodes sont-elles en comptabilisation définitive ?
      If CNX_OK = G_OUI and func GLOBIENS.IS_ALL_PER_POSTED([F:CNX]CPY, [F:CNX]CNX, [F:FIS]DATENDFIY) = G_NON
        CNX_OK = G_NON
      Endif

      #------------------------------
      # Existe-t'il au moins un bien avec des dotations à comptabiliser ?
      If CNX_OK = G_OUI and func GLOBIENS.IS_CNX_POSTED([F:CNX]CPY, [F:CNX]CNX,
&                                                       [F:FIS]DATENDFIY, [F:FIS]DATENDPER([F:FIS]INDCURPER-1)) = G_NON
        CNX_OK = G_NON
      Endif

      #------------------------------ FQ65544
      # Existe-t'il au moins un bien avec des dotations par écart sur plan à comptabiliser ?
      If CNX_OK = G_OUI and func GLOLNK.IS_LNK_POSTED([F:CNX]CPY, [F:CNX]CNX,
&                                                     [F:FIS]DATENDFIY, [F:FIS]DATENDPER([F:FIS]INDCURPER-1)) = G_NON
        CNX_OK = G_NON
      Endif

      #------------------------------
      # Existe-t'il au moins un bien avec des événements à comptabiliser (si on est sur la dernière période) ?
      # FQ84664 : Ajout de la législation en paramètre
      If  CNX_OK = G_OUI
&     and TYP = 2
&     and func GENEVE.CTRL_ALL_EVT_CPT([F:CPY]LEG,
&                                      [F:CNX]CPY,
&                                      [F:CNX]CNX,
&                                      TYP,
&                                      1,
&                                      "",
&                                      TLSTEVTTYP,
&                                      TLSTPLN,
&                                      TLSTNBE,
&                                      RET,
&                                      [0/0/0], [0/0/0]) = G_NON Then
        CNX_OK = G_NON
      Endif

      #------------------------------
      # Dans le cas de la clôture exercice, il faut vérifier qu'il n'existe pas pour les biens sortis dans
      # l'exercice des amortissements "A comptabiliser" sur des périodes futures en comptabilisation définitives
      If  CNX_OK = G_OUI
&     and TYP = 2
&     and func GLOBIENS.IS_CNX_POSTED_ISS_FUTURE([F:CNX]CPY,
&                                                [F:CNX]CNX) = G_NON Then
        CNX_OK = G_NON
      Endif

      #------------------------------ FQ65544
      # ... ainsi que des dotations par écart de plan
      If  CNX_OK = G_OUI
&     and TYP = 2
&     and func GLOLNK.IS_LNK_POSTED_ISS_FUTURE([F:CNX]CPY,
&                                              [F:CNX]CNX) = G_NON Then
        CNX_OK = G_NON
      Endif

      # Contrôles liés aux concessions par renouvellement
      #If CNX_OK = G_OUI and G_ACTCCN = G_OUI and [F:CNX]CNX = G300CPFI : # FQ96071
      If CNX_OK = G_OUI and G_ACTCCN = G_OUI and [F:CNX]CCNFLG = G_OUI  and [F:CNX]CCNMOD = GVML_GCRNW
        #------------------------------ FQ54343
        # Existe-t'il un bien dont les provisions sont non calculées ?
        If CNX_OK = G_OUI and func GLOCCN.IS_RPR_CALCULATE([F:CNX]CPY) = G_NON
          CNX_OK = G_NON
        Endif

        #------------------------------ FQ54343
        # Existe-t'il au moins un bien avec des provisions à comptabiliser ?
        If CNX_OK = G_OUI and func GLOCCN.IS_CPY_RPR_POSTED([F:CNX]CPY, [F:FIS]DATENDFIY, [F:FIS]DATENDPER([F:FIS]INDCURPER-1)) = G_NON
          CNX_OK = G_NON
        Endif

        #------------------------------ FQ54343
        # Dans le cas de la clôture exercice, il faut vérifier qu'il n'existe pas des biens fils en service
        # sans renouvellement effectif
        #
        If  CNX_OK = G_OUI
&       and TYP = 2
&       and func GLOCCN.IS_BCO_NOT_RNW([F:CNX]CPY) = G_OUI Then
          CNX_OK = G_NON
        Endif

        #------------------------------ FQ54343
        # Dans le cas de la clôture exercice, il faut vérifier qu'il n'existe pas des opérations de
        # renouvellement dont la date est vide ou dans l'exercice
        #
        If  CNX_OK = G_OUI
&       and TYP = 2
&       and func GLOCCN.IS_RNWOP_NOT_DONE([F:CNX]CPY) = G_OUI Then
          CNX_OK = G_NON
        Endif

        #------------------------------ FQ54343
        # Dans le cas de la clôture exercice, il faut vérifier qu'il n'existe pas pour les biens sortis dans
        # l'exercice des provisions "A comptabiliser" sur des périodes futures en comptabilisation définitives
        #
        If  CNX_OK = G_OUI
&       and TYP = 2
&       and func GLOCCN.IS_RPR_POSTED_ISS_FUTURE([F:CNX]CPY) = G_NON Then
          CNX_OK = G_NON
        Endif
      Endif

      #-------------------------------- FQ95754
      # Contrôle qu'il ne reste pas des biens classés pour vente et non sortis dans l'exercice clôturé
      #--------------------------------
      If  CNX_OK = G_OUI
&     and TYP = 2
&     and func GLOBIENS.HAS_FAS_SALCLS([F:CNX]CPY, [F:FIS]DATENDFIY) = G_OUI Then
        CNX_OK = G_NON
      Endif

      # FQ93731
      If  CNX_OK = G_OUI
        If func SUBCNX2.CTRL_CNX([F:CNX]CPY, 0, 0, WSOCERR, WCNXERR, WMESS) > 0
          CNX_OK = G_NON
        Endif
      Endif

      #------------------------ FQ54343
      Local Shortint CLOCNX : CLOCNX = G_OUI
      GPOINT="CRITCNXCLO" : Gosub ENTREE From EXEFNC : #CHECK IGNORE_LINE
      If CLOCNX = G_NON : CNX_OK = G_NON : Endif
    Endif

    # => On pourrait demander une clôture
    #------------------------------
    If N_FIRST = 0 Then
      [M:FAST]CLC(N_E-1)           = G_NON
      [M:FAST]CPY(N_E-1)           = [F:CPY]CPY
      [M:FAST]CNXBEG(N_E-1)        = N_I
      #------------------------------
      [M:FAST]NBRTRY(N_E-1)        = LNBRTRY
      [M:FAST]CODRETCLC(N_E-1)     = 0
      #------------------------------
      N_E                         += 1
      N_FIRST                      = 1
    Endif
    #------------------------------
    [M:FAST]CPYCNXG(N_I-1)         = [F:FIS]CPY
    [M:FAST]CNXG(N_I-1)            = [F:FIS]CNX
    [M:FAST]TYPCLCG(N_I-1)         = GVML_TCNOCLO
    [M:FAST]CNXOKG(N_I-1)          = CNX_OK

    If !GBATCH and !GSERVEUR Then
      [M:FAST]DATSTRFIYG(N_I-1)      = [F:FIS]DATSTRFIY
      [M:FAST]DATENDFIYG(N_I-1)      = [F:FIS]DATENDFIY
      [M:FAST]INDCURPERG(N_I-1)      = [F:FIS]INDCURPER
      [M:FAST]NBRPERG(N_I-1)         = [F:FIS]NBRPER
      [M:FAST]DATSTRPERG(N_I-1)      = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
      [M:FAST]DATENDPERG(N_I-1)      = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
    Endif

    N_I += 1
  #-------------------
  # Suite de la boucle
  Next CNX0
  #------------------
  If N_FIRST = 1 Then
    [M:FAST]CNXEND(N_E-2) = N_I-1
  Endif

  If N_FIRST = 1 and !find(G_OUI,[M:FAST]CNXOKG([M:FAST]CNXBEG(N_E-2)-1..[M:FAST]CNXEND(N_E-2)-1))
    # Aucun contexte n'est éligible, on supprime la société
    N_I = [M:FAST]CNXBEG(N_E-2)
    N_E -= 1
  Endif
Return

# Ajout suppression des sociétés non sélectionnées pour fonctionnement correct en batch
#-------------------------------------------------------------------------------
$CONT_BATCH
 Gosub DEMANDE_CONFIRMATION
 If SAI : Return : Endif

 # Pour comptabilité avec le lancement par groupe de tâche.
 If ([M:FAST]NBCPY)>0
  Call AFFICHE_D_EN_G (GCURCPY)
  Gosub VIDE_CPYNSEL
  Call AFFICHE_G_EN_D (1) : # FQ86530 : pour avoir les indices INDCOR corrects après nettoyage
  #Call SETPAR(ABRCRIT,P1,P2) From REQUETES : # FQ54377
 Endif
Return

#-------------------------------------------------------------------------------
$CONTROLE
  Call AFFICHE_D_EN_G (GCURCPY)
  Gosub CTRL_CLOTURE
Return

#-------------------------------------------------------------------------------
$EXEC
  Gosub CLOTURER From GLOCLOT
  FIN = 1
Return

#-------------------------------------------------------------------------------
$TERMINE
  Kill GCURCPY
  Kill LDIMLSTPLN
  Kill LIN_PLAN
  Kill LIN_FLUX

  Raz [M:FAST]
Return

#-------------------------------------------------------------------------------
# Supprime du masque toutes les infos des sociétés non sélectionnées
$VIDE_CPYNSEL

 # 1) boucle sur la table des sociétés,
 # 2) Si la société n'est pas géré, appel la fonction permettant de la supprimer de l'écran

 Local Integer I_CPY, I_V, I_G
 Local Integer FINI
 Local Integer L_CNXBEG
 Local Integer L_CNXEND
 Local Integer L_NBDELLINE
 Local Integer L_NEWCNXBEG
 Local Integer L_NEWCNXEND
 Local Integer L_ISFIRST

 # Recherche et suppression des informations de toutes les sociétés non sélectionnées

 FINI=G_NON
 Repeat
  I_CPY=find (G_NON,[M:FAST]CLC)
  If I_CPY=0 : FINI=G_OUI : Break : Endif
  Gosub SUP_CPY
 Until FINI=G_OUI

 # Mise à jour des variables de bas de tableaux

 Raz nolign
 For I_V=1 To [M:FAST]NBCPY
  If [M:FAST]CPY(I_V-1)=""
   Break
  Endif
  nolign+=1
 Next nolign
 [M:FAST]NBCPY=nolign

 Raz nolign
 For I_G=1 To [M:FAST]NBCNXG
  If [M:FAST]CPYCNXG(I_G-1)=""
   Break
  Endif
  nolign+=1
 Next nolign
 [M:FAST]NBCNXG=nolign

Return

#---
$SUP_CPY

 #Infbox "Suppression de la société :"-[M:FASt]CPY(I_CPY-1)

 # Sauvegarde de CNXBEG et CNXEND
 L_CNXBEG = [M:FAST]CNXBEG(I_CPY-1)
 L_CNXEND = [M:FAST]CNXEND(I_CPY-1)
 # Calcul du nombre de lignes à supprimer dans le tableau invisible
 L_NBDELLINE = (L_CNXEND-L_CNXBEG)+1
 # Suppression dans le tableau invisible G
 Dela L_CNXBEG-1, L_NBDELLINE [M:FAST]NBCNXG
 # Suppression dans le tableau Visible
 Dela I_CPY-1, 1 [M:FAST]NBCPY
 # Mise à jour des CNXBEG et CNXEND dans le tableau invisible à partir de CNXBEG mémorisé
 For I_V=I_CPY To [M:FAST]NBCPY
  L_ISFIRST=G_OUI
  For I_G=1 To [M:FAST]NBCNXG
   If [M:FAST]CPYCNXG(I_G-1)=[M:FAST]CPY(I_V-1)
    If L_ISFIRST=G_OUI
     L_NEWCNXBEG = I_G
     L_ISFIRST     = G_NON
    Endif
    L_NEWCNXEND = I_G
   Endif
  Next I_G
  [M:FAST]CNXBEG(I_V-1) = L_NEWCNXBEG
  [M:FAST]CNXEND(I_V-1) = L_NEWCNXEND
 Next I_V

Return

#----
# Uniquement pour développement : permet d'afficher la liste des sociétés sélectionnées dans la trace
$CTRL_VIDE_CPYNSEL
 Local Integer I_V, I_G
 Local Char    LIGNE(120)
 Call ECR_TRACE("============================",0) From GESECRAN
 Call ECR_TRACE("Pour test",0) From GESECRAN
 For I_V=1 To [M:FAST]NBCPY
  LIGNE=num$(I_V)+" "+[M:FAST]CPY(I_V-1)+" "+num$([M:FAST]CNXBEG(I_V-1))+" "+num$([M:FAST]CNXEND(I_V-1))
  Call ECR_TRACE(LIGNE,0) From GESECRAN
 Next I_V
 Call ECR_TRACE("",0) From GESECRAN
 For I_G=1 To [M:FAST]NBCNXG
  LIGNE=num$(I_G)+" "+[M:FAST]CPYCNXG(I_G-1)+" "+mess([M:FAST]CNXG(I_G-1),3100,1)+" "+mess([M:FAST]TYPCLCG(I_G-1),3184,1)
  Call ECR_TRACE(LIGNE,0) From GESECRAN
 Next I_G
 Call ECR_TRACE("============================",0) From GESECRAN
Return

#-------------------------------------------------------------------------------
$CTRL_CLOTURE
Local Integer  N_E, N_I, N_NBSOCCLC
Local Char     LNIVTRACE(1)
Local Shortint INDIC_PPL

  #------------------------------
  N_NBSOCCLC = 0
  INDIC_PPL  = G_NON
  #------------------------------
  For N_E = 1 To [M:FAST]NBCPY
    #------------------------------
    If [M:FAST]CLC(N_E-1)=G_OUI
      #------------------------------
      # Contrôles lors du lancement par serveur batch
      If GSERVEUR
        #--------------------------------
        # on revérifie qu'une CIG utilisant la société n'a pas été définie
        #--------------------------------
        Local Integer RETOUR
        Call CONTROLE_CIG([M:FAST]CPY(N_E-1), 1, RETOUR) From GLOBIENS
        If RETOUR
          [M:FAST]CLC(N_E-1) = G_NON
          For N_I = [M:FAST]CNXBEG(N_E-1) To [M:FAST]CNXEND(N_E-1)
            If [M:FAST]TYPCLCG(N_I-1) <> GVML_TCNOCLO Then
              [M:FAST]TYPCLCG(N_I-1)=GVML_TCNOCLO
            Endif
          Next N_I
        Endif

        Local Integer LNBR
        For N_I = [M:FAST]CNXBEG(N_E-1) To [M:FAST]CNXEND(N_E-1)
          # FQ96071 : lecture du contexte (pour savoir s'il gère les concessions)
          Read [CNX]CNX0=[M:FAST]CPYCNXG(N_I-1);[M:FAST]CNXG(N_I-1)
          If fstat
            GMESSAGE = "CTRL_CLOTURE 0"-[M:FAST]CPYCNXG(N_I-1)-num$([M:FAST]CNXG(N_I-1))-num$(fstat)
            FIN      = 0
            GERR     = 1
          Endif

          # FQ56130 : remplacement ci-dessous de [FIY] par [FIS]
          Read [FIS]FIY1=[M:FAST]CPYCNXG(N_I-1);[M:FAST]CNXG(N_I-1);GVML_TECOURA
          If fstat
            GMESSAGE = "CTRL_CLOTURE 1"-[M:FAST]CPYCNXG(N_I-1)-num$([M:FAST]CNXG(N_I-1))-num$(fstat)
            FIN      = 0
            GERR     = 1
          Endif

          #------------------------------
          # En lancement de la requête batch on détermine si on a une clôture période ou exercice ([M:FAST]TYPCLCG(X))
          # en fonction du contexte du moment
          #------------------------------
          If [M:FAST]FLGCNXG(N_I-1) = G_OUI Then
            If [F:FIS]DATENDPER([F:FIS]INDCURPER-1) = [F:FIS]DATENDFIY
              [M:FAST]TYPCLCG(N_I-1) = GVML_TCCLOEX
            Else
              [M:FAST]TYPCLCG(N_I-1) = GVML_TCCLOPE
            Endif
          Else
            [M:FAST]TYPCLCG(N_I-1) = GVML_TCNOCLO
          Endif

          #--------------------------------
          # CONTRÔLE AVANT CLÔTURE
          #--------------------------------
          If [M:FAST]TYPCLCG(N_I-1) <> GVML_TCNOCLO Then : # au cas où le contexte est desélectionné plus haut
           Local Integer LACLOTURER : LACLOTURER=G_OUI

           #--------------------------------
           # Contrôle que tous les Secteurs d'activité de la société ont leur coefficient définitif forcé
           #--------------------------------
           If    [M:FAST]TYPCLCG(N_I-1)=GVML_TCCLOEX and func FASCLOTURE.IS_SAC_CLOTURABLE ([M:FAST]CPYCNXG(N_I-1)) = G_NON Then
            [M:FAST]TYPCLCG(N_I-1)=GVML_TCNOCLO
            Call ECR_TRACE(mess(650,7773,1),1) From GESECRAN
           Endif

           #--------------------------------
           # Contrôle que des biens n'ont pas été modifiés depuis le paramètrage de la requête
           #--------------------------------
           If func GLOBIENS.IS_CNX_CALCULATE([M:FAST]CPYCNXG(N_I-1),
&                                            [M:FAST]CNXG(N_I-1),
&                                            [F:FIS]DATENDFIY,
&                                            [F:FIS]DATENDPER([F:FIS]INDCURPER-1)) = G_NON
             LACLOTURER = G_NON
             Call ECR_TRACE(mess(90,7770,1)-mess([M:FAST]CNXG(N_I-1),3100,1)-" : "-mess(100,7774,1),1) From GESECRAN
           Endif

           #------------------------------ FQ70465
           # Contrôle que les périodes des référentiels de la compta qui suivent la période courante sont ouvertes
           #--------------------------------
           If func GLOBIENS.ACCPERCTL([M:FAST]CPYCNXG(N_I-1))
             Local Shortint N_PLN
             For N_PLN = 0 To [F:CNX]NBPLC-1
               # FQ96071 : utilisations à tort de [F:CPY]CPY qui n'est pas correctement alimenté à ce moment là
               #If func GLOBIENS.PERCPT_STATE([F:CPY]CPY, [F:CNX]LEDTYP(N_PLN), [F:FIS]DATENDPER([F:FIS]INDCURPER-1)+1) <> 2
               If func GLOBIENS.PERCPT_STATE([M:FAST]CPYCNXG(N_I-1), [F:CNX]LEDTYP(N_PLN), [F:FIS]DATENDPER([F:FIS]INDCURPER-1)+1) <> 2
                 LACLOTURER = G_NON
                 Call ECR_TRACE(mess(90,7770,1)-mess([M:FAST]CNXG(N_I-1),3100,1)-" : "-mess(264,7770,1),1) From GESECRAN
                 Break
               Endif
             Next
           Endif

           #--------------------------------
           # Contrôle que toutes les périodes sont en comptabilisation définitive lors d'une clôture exercice
           #--------------------------------
           If func GLOBIENS.IS_ALL_PER_POSTED([M:FAST]CPYCNXG(N_I-1), [M:FAST]CNXG(N_I-1), [F:FIS]DATENDFIY) = G_NON
             LACLOTURER = G_NON
             Call ECR_TRACE(mess(90,7770,1)-mess([M:FAST]CNXG(N_I-1),3100,1)-" : "-mess(608,7773,1),1) From GESECRAN : # "Il y des périodes en comptabilisation provisoire, ce qui n'est pas compatible
# avec une clôture exercice."
           Endif

           #--------------------------------
           # Contrôle que les comptabilisations de dotations sont correctes dans l'exercice ou la période
           #--------------------------------
           If func GLOBIENS.IS_CNX_POSTED([M:FAST]CPYCNXG(N_I-1),
&                                         [M:FAST]CNXG(N_I-1),
&                                         [F:FIS]DATENDFIY,
&                                         [F:FIS]DATENDPER([F:FIS]INDCURPER-1)) = G_NON
             LACLOTURER = G_NON
             Call ECR_TRACE(mess(90,7770,1)-mess([M:FAST]CNXG(N_I-1),3100,1)-" : "-mess(174,7774,1),1) From GESECRAN
           Endif

           #-------------------------------- FQ65544
           # Contrôle que les comptabilisations par écart sont correctes dans l'exercice ou la période
           #--------------------------------
           If func GLOLNK.IS_LNK_POSTED([M:FAST]CPYCNXG(N_I-1),
&                                       [M:FAST]CNXG(N_I-1),
&                                       [F:FIS]DATENDFIY,
&                                       [F:FIS]DATENDPER([F:FIS]INDCURPER-1)) = G_NON
             LACLOTURER = G_NON
             Call ECR_TRACE(mess(90,7770,1)-mess([M:FAST]CNXG(N_I-1),3100,1)-" : "-mess(175,7774,1),1) From GESECRAN
           Endif

           #--------------------------------
           # Contrôle que les comptabilisations d'événements sont correctes dans l'exercice ou la période
           #--------------------------------
#           Local Integer RETOUR, LTYPCTRL
#           If [M:FAST]TYPCLCG(N_I-1)=GVML_TCCLOEX
#            LTYPCTRL=2
#           Elsif [M:FAST]TYPCLCG(N_I-1)=GVML_TCCLOPE
#            LTYPCTRL=1
#           Endif
#
#           # FQ84664
#           If [F:CPY]CPY<>[M:FAST]CPYCNXG(N_I-1)
#             Call LECTURE("CPY",[M:FAST]CPYCNXG(N_I-1),"") From CONTOBJ
#           Endif
#
#           #Call CONTROLE_EVENEMENTS([M:FAST]CPYCNXG(N_I-1), [M:FAST]CNXG(N_I-1), LTYPCTRL, 1, RETOUR) From GENEVE
#           Call CONTROLE_EVENEMENTS([F:CPY]LEG,[M:FAST]CPYCNXG(N_I-1), [M:FAST]CNXG(N_I-1), LTYPCTRL, 1, RETOUR) From GENEVE
#           If RETOUR
#            LACLOTURER=G_NON
#           Endif
           Local Integer RETOUR
           If [M:FAST]TYPCLCG(N_I-1)=GVML_TCCLOEX
             # FQ84664
             If [F:CPY]CPY<>[M:FAST]CPYCNXG(N_I-1)
               Call LECTURE("CPY",[M:FAST]CPYCNXG(N_I-1),"") From CONTOBJ
             Endif

             #Call CONTROLE_EVENEMENTS([M:FAST]CPYCNXG(N_I-1), [M:FAST]CNXG(N_I-1), LTYPCTRL, 1, RETOUR) From GENEVE
             Call CONTROLE_EVENEMENTS([F:CPY]LEG,[M:FAST]CPYCNXG(N_I-1), [M:FAST]CNXG(N_I-1), [M:FAST]TYPCLCG(N_I-1), 1, RETOUR) From GENEVE
             If RETOUR
              LACLOTURER=G_NON
             Endif
           Endif

           # Contrôles liés aux concessions par renouvellement
           #If G_ACTCCN = G_OUI and [M:FAST]CNXG(N_I-1) = G300CPFI : # FQ96071
           If G_ACTCCN = G_OUI and [F:CNX]CCNFLG = G_OUI and [F:CNX]CCNMOD = GVML_GCRNW
             #------------------------------ FQ54343
             # Existe-t'il un bien dont les provisions sont non calculées ?
             If func GLOCCN.IS_RPR_CALCULATE([M:FAST]CPYCNXG(N_I-1)) = G_NON
               LACLOTURER = G_NON
               Call ECR_TRACE(mess(90,7770,1)-mess([M:FAST]CNXG(N_I-1),3100,1)-" : "-mess(172,7774,1),1) From GESECRAN
             Endif

             #------------------------------ FQ54343
             # Existe-t'il au moins un bien avec des provisions à comptabiliser ?
             If func GLOCCN.IS_CPY_RPR_POSTED([M:FAST]CPYCNXG(N_I-1), [F:FIS]DATENDFIY, [F:FIS]DATENDPER([F:FIS]INDCURPER-1)) = G_NON
               LACLOTURER = G_NON
               Call ECR_TRACE(mess(90,7770,1)-mess([M:FAST]CNXG(N_I-1),3100,1)-" : "-mess(173,7774,1),1) From GESECRAN
             Endif

             #------------------------------ FQ54343
             # Dans le cas de la clôture exercice, il faut vérifier qu'il n'existe pas des biens fils en service
             # sans renouvellement effectif
             #
             If [M:FAST]TYPCLCG(N_I-1) = GVML_TCCLOEX and func GLOCCN.IS_BCO_NOT_RNW([M:FAST]CPYCNXG(N_I-1)) = G_OUI Then
               LACLOTURER = G_NON
               Call ECR_TRACE(mess(90,7770,1)-mess([M:FAST]CNXG(N_I-1),3100,1)-" : "-mess(729,7773,1),1) From GESECRAN
             Endif

             #------------------------------ FQ54343
             # Dans le cas de la clôture exercice, il faut vérifier qu'il n'existe pas des opérations de
             # renouvellement dont la date est vide ou dans l'exercice
             #
             If [M:FAST]TYPCLCG(N_I-1) = GVML_TCCLOEX and func GLOCCN.IS_RNWOP_NOT_DONE([M:FAST]CPYCNXG(N_I-1)) = G_OUI Then
               LACLOTURER = G_NON
               Call ECR_TRACE(mess(90,7770,1)-mess([M:FAST]CNXG(N_I-1),3100,1)-" : "-mess(730,7773,1),1) From GESECRAN
             Endif

             #------------------------------ FQ54343
             # Dans le cas de la clôture exercice, il faut vérifier qu'il n'existe pas pour les biens sortis dans
             # l'exercice des provisions "A comptabiliser" sur des périodes futures en comptabilisation définitives
             #
             If [M:FAST]TYPCLCG(N_I-1) = GVML_TCCLOEX and func GLOCCN.IS_RPR_POSTED_ISS_FUTURE([M:FAST]CPYCNXG(N_I-1)) = G_NON Then
               LACLOTURER = G_NON
               Call ECR_TRACE(mess(90,7770,1)-mess([M:FAST]CNXG(N_I-1),3100,1)-" : "-mess(124,7778,1),1) From GESECRAN
             Endif
           Endif

           #-------------------------------- FQ95754
           # Contrôle qu'il ne reste pas des biens classés pour vente et non sortis dans l'exercice clôturé
           #--------------------------------
           If  ([M:FAST]TYPCLCG(N_I-1)=GVML_TCCLOEX)
&          and (func GLOBIENS.HAS_FAS_SALCLS([M:FAST]CPYCNXG(N_I-1), [F:FIS]DATENDFIY) = G_OUI) Then
             [M:FAST]TYPCLCG(N_I-1)=GVML_TCNOCLO
             Call ECR_TRACE(mess(932,7773,1),1) From GESECRAN
           Endif

             #------------------------------ FQ93731

            If func SUBCNX2.CTRL_CNX ([M:FAST]CPYCNXG(N_I-1), [M:FAST]CNXG(N_I-1), 0, WSOCERR, WCNXERR, WMESS) > 0
              LACLOTURER = G_NON
              Call ECR_TRACE(mess(90,7770,1)-mess([M:FAST]CNXG(N_I-1),3100,1)-" : " - WMESS,1) From GESECRAN
            Endif

           #------------------------ FQ54343
           Local Shortint CLOCNX : CLOCNX = G_OUI
           GPOINT="CRITCNXCLO" : Gosub ENTREE From EXEFNC : #CHECK IGNORE_LINE
           If CLOCNX = G_NON : LACLOTURER = G_NON : Endif

           # Le contexte est toujours à clôturer ?
           If LACLOTURER=G_NON
             [M:FAST]TYPCLCG(N_I-1)=GVML_TCNOCLO
           Endif

          Endif
          #------------------------------
        Next N_I
      Endif

      #------------------------------
      # Dans le cas de la clôture exercice, il faut vérifier qu'il n'existe pas pour les biens sortis dans
      # l'exercice du "A comptabiliser" sur des périodes futures en comptabilisation définitives
      # FQ65544 ainsi que sur écart de plan
      For N_I = [M:FAST]CNXBEG(N_E-1) To [M:FAST]CNXEND(N_E-1)
        #------------------------------
        If [M:FAST]TYPCLCG(N_I-1) =  GVML_TCCLOEX Then
          If func GLOBIENS.IS_CNX_POSTED_ISS_FUTURE([M:FAST]CPYCNXG(N_I-1), [M:FAST]CNXG(N_I-1)) = G_NON
            [M:FAST]CLC(N_E-1) = G_NON
            Affzo [M:FAST]CLC(N_E-1)
            Break
          Endif
          #------------------------------ FQ65544
          If func GLOLNK.IS_LNK_POSTED_ISS_FUTURE([M:FAST]CPYCNXG(N_I-1), [M:FAST]CNXG(N_I-1)) = G_NON
            [M:FAST]CLC(N_E-1) = G_NON
            Affzo [M:FAST]CLC(N_E-1)
            Break
          Endif
        Endif
        #------------------------------
        # Suite de la boucle
      Next N_I

      #------------------------------
      # Si aucun contexte de la société n'est à clôturer, on le signale
      If find(GVML_TCCLOEX,[M:FAST]TYPCLCG([M:FAST]CNXBEG(N_E-1)-1..[M:FAST]CNXEND(N_E-1)-1))
&     or find(GVML_TCCLOPE,[M:FAST]TYPCLCG([M:FAST]CNXBEG(N_E-1)-1..[M:FAST]CNXEND(N_E-1)-1))
        N_NBSOCCLC += 1
      Else
        Call MESSAGE (mess(52,7774,1)-num$([M:FAST]CPY(N_E-1))-mess(82,7774,1)) From GESECRAN
        [M:FAST]CLC(N_E-1) = G_NON
        Affzo [M:FAST]CLC(N_E-1)
      Endif

      #------------------------------
      # Si le contexte de la société gère des plans de production, on en avertit l'utilisateur
      If !GBATCH and !GSERVEUR
        CRITERE = 'CPY="'+[M:FAST]CPY(N_E-1)+'" and FLGCNXUO=G_OUI and ('
        For N_I = [M:FAST]CNXBEG(N_E-1) To [M:FAST]CNXEND(N_E-1)
          CRITERE -= 'CNX='+num$([M:FAST]CNXG(N_I-1))-'or'
        Next N_I
        CRITERE = left$(CRITERE,len(CRITERE)-2)+")"
        Filter [CNX] Where evalue(CRITERE)
        If rowcount([F:CNX])>0 : INDIC_PPL = G_OUI : Endif
        Filter [CNX]
      Endif
      #------------------------------
    Endif
    # Suite de la boucle
  Next N_E
  #------------------------------
  # Aucune société n'est sélectionnée !
  If N_NBSOCCLC = 0 Then
    GMESSAGE = mess(55,7774,1)
    FIN      = 0
    GERR     = 1
  Endif
  #------------------------------
  If INDIC_PPL = G_OUI Then
    # 145 Attention au moins un contexte sélectionné gère un plan de production. Confirmez-vous le traitement ?
    Call OUINON(mess(145,7774,1), OK) From GESECRAN
    If (OK = 1) Then
      GMESSAGE = mess(77,7774,1) : # Traitement interrompu par l'utilisateur
      FIN      = 0
      GERR     = 1
      Return
    Endif
  Endif
  #------------------------------
  Call PARAM("","NIVTRACE",LNIVTRACE) From ADOVAL
  If val(LNIVTRACE) = 3 Then
    # 75 Attention vous utilisez un niveau de trace détaillé et peut saturer votre serveur. Confirmez-vous le traitement ?
    Call OUINON(mess(75,7774,1), OK) From GESECRAN
    If (OK = 1) Then
      GMESSAGE = mess(77,7774,1) : # Traitement interrompu par l'utilisateur
      FIN      = 0
      GERR     = 1
      Return
    Endif
  Elsif val(LNIVTRACE) > 3 Then
    # 76 Attention vous utilisez un niveau de trace très détaillé et peut saturer votre serveur. Confirmez-vous le traitement ?
    Call OUINON(mess(76,7774,1), OK) From GESECRAN
    If (OK = 1) Then
      GMESSAGE = mess(77,7774,1) : # Traitement interrompu par l'utilisateur
      FIN      = 0
      GERR     = 1
      Return
    Endif
  Endif
  #------------------------------
  Gosub DEMANDE_CONFIRMATION
  If SAI : Return : Endif
Return

########################################
$DEMANDE_CONFIRMATION
 If [M:FAST]FLGSIM = G_OUI
   # 176 Attention, le traitement sera exécuté en simulation. Confirmez-vous ?
   Call OUINON(mess(176,7774,1), OK) From GESECRAN
   If (OK = 1) Then
     SAI = 1
     Return
   Endif
 Else
  # 170 Attention, le traitement de clôture est irréversible. Confirmez-vous ?
  Call OUINON(mess(170,7774,1), OK) From GESECRAN
  If (OK = 1) Then
     SAI = 1
    Return
  Endif
 Endif
Return

########################################
Subprog AFFICHE_G_EN_D (P_IND)
# Affiche les contextes de la société sélectionnée dans le tableau visible
Value Integer P_IND

Local Integer N_I, N_E
  #------------------------------
  [M:FAST]NBCNX = 0
  Call ACTION_BLOCK (ACB_EFFZO, "FASCLOTURE", "CNX") From GLOBIENS
  N_E = 1
  #------------------------------
  For N_I = [M:FAST]CNXBEG(P_IND-1) To [M:FAST]CNXEND(P_IND-1)
    [M:FAST]CPYCNX(N_E-1)         = [M:FAST]CPYCNXG(N_I-1)
    [M:FAST]CNX(N_E-1)            = [M:FAST]CNXG(N_I-1)
    [M:FAST]TYPCLC(N_E-1)         = [M:FAST]TYPCLCG(N_I-1)
    [M:FAST]FLGCNX(N_E-1)         = [M:FAST]FLGCNXG(N_I-1)
    #GBN-FQ54251-Impossible de clôturer les contextes si plan de subvention défini sur le contexte comptable et fiscal de la dernière société.
    #If find(G301SUB, [F:CNX]PLNCAA) Then
    #  Diszo[M:FAST]TYPCLC(N_E-1)
    #  Diszo[M:FAST]FLGCNX(N_E-1)
    #Else
    #  Actzo[M:FAST]TYPCLC(N_E-1)
    #  Actzo[M:FAST]FLGCNX(N_E-1)
    #Endif

    [M:FAST]INDCOR(N_E-1)       = N_I

    If !GBATCH and !GSERVEUR
      [M:FAST]DATSTRFIY(N_E-1)    = [M:FAST]DATSTRFIYG(N_I-1)
      [M:FAST]DATENDFIY(N_E-1)    = [M:FAST]DATENDFIYG(N_I-1)
      [M:FAST]NBRPER(N_E-1)       = [M:FAST]NBRPERG(N_I-1)
      [M:FAST]INDCURPER(N_E-1)    = [M:FAST]INDCURPERG(N_I-1)
      [M:FAST]DATSTRPER(N_E-1)    = [M:FAST]DATSTRPERG(N_I-1)
      [M:FAST]DATENDPER(N_E-1)    = [M:FAST]DATENDPERG(N_I-1)

      If [M:FAST]CNXOKG(N_I-1) <> G_OUI
        [M:FAST]CNXOK(N_E-1) = "127"
      Else
        [M:FAST]CNXOK(N_E-1) = "128"
      Endif
    Endif

    N_E                        += 1
    #------------------------------
    # Suite de la boucle
  Next N_I
  #------------------------------
  [M:FAST]NBCNX = N_E-1
  Call ACTION_BLOCK (ACB_AFFZO, "FASCLOTURE", "CNX") From GLOBIENS
  #------------------------------
End

########################################
Subprog AFFICHE_D_EN_G (P_IND)
# renvoi les contextes modifiés de la société sélectionnée dans le tableau invisible
Value Integer P_IND

Local Integer N_I, N_E

  #------------------------------
  For N_I = 1 To [M:FAST]NBCNX
    N_E = [M:FAST]INDCOR(N_I-1)
    #------------------------------
    [M:FAST]TYPCLCG(N_E-1) = [M:FAST]TYPCLC(N_I-1)
    [M:FAST]FLGCNXG(N_E-1) = [M:FAST]FLGCNX(N_I-1)
    #------------------------------
    # Suite de la boucle
  Next N_I
  #------------------------------
  Call ACTION_BLOCK (ACB_AFFZO, "FASCLOTURE", "CNXG") From GLOBIENS
  #------------------------------
End

########################################
Funprog IS_SAC_CLOTURABLE ( PSOC )
# Rend G_OUI si tous les secteurs TVA de la société ont leur coefficient définitif forcé
#
# FQ 46680 Nouvelles règles TVA
#
#
Value  Char   PSOC

Local Integer RTRN

  If clalev([F:SEA]) =0  : Local File SECACT  [SEA]  : Endif  : # secteurs d'activité

  RTRN = G_OUI
  Filter [SEA] Where CPY= PSOC
  #>>>>
  For [SEA]SEA0
    If ( [F:SEA]TAXCOEFLG = G_NON ) Then
      RTRN = G_NON
      Break
    Endif
  Next
  #<<<<
  Filter [SEA]

End RTRN


################################################################################
# ECRAN : FAST
################################################################################
########################################
Subprog AS_NBCPY

Local Integer N_I
Local Integer N_TROUVE

  Chgstl [M:FAST]CPY  With ""
  Chgstl [M:FAST]ZCPY With ""
  Chgstl [M:FAST]CPY(nolign-1)  With "SELLIG"
  Chgstl [M:FAST]ZCPY(nolign-1) With "SELLIG"

  #------------------------------
  Call AFFICHE_D_EN_G (GCURCPY)
  #------------------------------
  If nolign-1 < [M:FAST]NBCPY Then
    # on reçoit quelque chose lorqu'on passe la dernière ligne : faut pas le faire dans ce cas !
    GCURCPY = nolign
    Call AFFICHE_G_EN_D (GCURCPY)
  Endif
  #------------------------------
  If [M:FAST]CLC(GCURCPY-1) = G_OUI Then
    N_TROUVE = 0
    For N_I = 1 To [M:FAST]NBCNX
      If [M:FAST]TYPCLC(N_I-1) <> GVML_TCNOCLO Then
        N_TROUVE = 1
        Break
      Endif
      #------------------------------
      # Suite de la boucle
    Next N_I
  Endif
  #------------------------------
End

########################################
Subprog AM_CLC(VALEUR)
Variable Integer VALEUR
  Local Integer N_I

  # Interdiction de clôturer la société si une opération de cession intra-groupe est en cours
  If VALEUR=G_OUI
    Local Integer RETOUR
    Call CONTROLE_CIG([M:FAST]CPY(nolign-1), 0, RETOUR) From GLOBIENS
    If RETOUR : VALEUR=G_NON : End : Endif

    # Sélection automatique de tous les contextes
    For N_I = 0 To [M:FAST]NBCNX-1
      If !GBATCH and !GSERVEUR
        If [M:FAST]CNXOK(N_I)<>"127"
          Call WARNING_UO(N_I) : # FQ91104
          If mkstat <> 2
            If [M:FAST]INDCURPER(N_I) = [M:FAST]NBRPER(N_I) Then
              [M:FAST]TYPCLC(N_I) = GVML_TCCLOEX
            Else
              [M:FAST]TYPCLC(N_I) = GVML_TCCLOPE
            Endif
            [M:FAST]FLGCNX(N_I) = G_OUI
          Endif
        Endif
      Else
        [M:FAST]FLGCNX(N_I) = G_OUI
      Endif
    Next
  Else
    For N_I = 0 To [M:FAST]NBCNX-1
      [M:FAST]TYPCLC(N_I) = GVML_TCNOCLO
      [M:FAST]FLGCNX(N_I) = G_NON
    Next
  Endif
End

########################################
Subprog AS_FLGCNX(VALEUR)
Variable Integer VALEUR
  If [M:FAST]CLC(GCURCPY-1) = G_NON Then
    [M:FAST]CLC(GCURCPY-1) = G_OUI
    Affzo [M:FAST]CLC(GCURCPY-1)
  Endif
End

########################################
Subprog AM_FLGCNX(VALEUR)
Variable Integer VALEUR
  If VALEUR = G_NON
    [M:FAST]FLGCNX(nolign-1) = VALEUR
    If (find(G_OUI,[M:FAST]FLGCNX)=0)
      [M:FAST]CLC(GCURCPY-1) = G_NON
      Affzo [M:FAST]CLC(GCURCPY-1)
    Endif
  Else
    If [M:FAST]CLC(GCURCPY-1) = G_NON
      [M:FAST]CLC(GCURCPY-1) = G_OUI
      Affzo [M:FAST]CLC(GCURCPY-1)
    Endif
  Endif
End

########################################
Subprog AV_TYPCLC(VALEUR)
Variable Integer VALEUR
  If !GBATCH and !GSERVEUR
    If [M:FAST]CNXOK(nolign-1)="127"
      Diszo [M:FAST]TYPCLC(nolign-1)
    Else
      Actzo [M:FAST]TYPCLC(nolign-1)
    Endif
  Endif
End

########################################
Subprog AS_TYPCLC(VALEUR)
Variable Integer VALEUR

  #------------------------------
  #If [M:FAST]CLC(GCURCPY-1) = G_NON Then
  #  GMESSAGE = mess(115,7774,1) : # La société doit être "A clôturer" pour définir un type de clôture
  #  GMESSAGE = mess(115,7774,1) : # La société doit être "A clôturer" pour définir un type de clôture
  #  mkstat = 2
  #  End
  #Endif
  #------------------------------
  If !GSERVEUR
    If [M:FAST]INDCURPER(nolign-1) = [M:FAST]NBRPER(nolign-1) Then
      # Si c'est la dernière période, on ne peut faire qu'une clôture exercice
      GMENLOC(GVML_TCCLOPE) = 1
    Else
      # Sinon, on ne peut faire qu'une clôture période
      GMENLOC(GVML_TCCLOEX) = 1
    Endif
  Endif
  #------------------------------
End

########################################
Subprog C_TYPCLC(VALEUR)
Variable Integer VALEUR
  # Si le contexte est retenu pour la gestion des UO, on demande à l'utilisateur s'il a calculé les
  # amortissement en fonction des UO réalisés.
  # FQ91104 : factorisation de la boite d'avertissement
  If VALEUR<>GVML_TCNOCLO
    Call WARNING_UO(nolign-1)
    If mkstat = 2
      VALEUR = GVML_TCNOCLO
    Endif
  Endif
End

########################################
Subprog AM_TYPCLC(VALEUR)
Variable Integer VALEUR

Local    Integer N_C

  If ( VALEUR = GVML_TCCLOEX and func FASCLOTURE.IS_SAC_CLOTURABLE ([M:FAST]CPYCNX(nolign-1)) = G_NON ) Then
   # Non clôturable si au moins un Secteur d'activité de la société n'a pas son coefficient définitif forcé
   GMESSAGE = mess(650,7773,1)
   GERR     = 1
   mkstat   = 2
   End
  Endif

  If VALEUR = GVML_TCNOCLO
    [M:FAST]TYPCLC(nolign-1) = VALEUR
    If (find(GVML_TCCLOEX,[M:FAST]TYPCLC)=0) & (find(GVML_TCCLOPE,[M:FAST]TYPCLC)=0)
      [M:FAST]CLC(GCURCPY-1) = G_NON
      Affzo [M:FAST]CLC(GCURCPY-1)
    Endif
  Else
    If [M:FAST]CLC(GCURCPY-1) = G_NON
      [M:FAST]CLC(GCURCPY-1) = G_OUI
      Affzo [M:FAST]CLC(GCURCPY-1)
    Endif
  Endif
End

########################################
# Ask the user if the production plan was updated before the closure process
Subprog WARNING_UO(RANK)
Value Integer RANK

  If func GLOBIENS.IS_CNX_UO([M:FAST]CPYCNX(RANK),[M:FAST]CNX(RANK)) = G_OUI
    Local Libelle REP
    Wrnbox mess(621, 7773, 1) Using [L]REP
    If [L]REP=2 Then
      mkstat = 2
    Endif
  Endif
End

