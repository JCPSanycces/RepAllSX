#<AdxTL>@(#)9.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ANU",GBIDC1,GBIDC2) From GOBJET
End

#---------------------------------------------------------#
# Pour la recherche dans l'annuaire LDAP
#---------------------------------------------------------#

Subprog VALID(CODE,DOSSIER,SILENCE)
Value    Char    CODE
Value    Char    DOSSIER
Value    Integer SILENCE

Local Char     NOMPROG(GLONADC) , FICSRC(GDIMFIC)
Local Char     SAVIFS(10) , SAVIRS(10) , IDENT(20)
Local Integer  SAVIUM

Local Integer  I , J , K , OK , NBCLE , NBRFLD
Local Char     CHAINE(250) , CHAINE2(250) , MAGIC(80) , PREF(4) , PASSE(30)
Local Char     MACHINE(GDIMFIC) , APPLI(GLONADS)

If clalev([F:ANU])=0 : Local File =DOSSIER+".ANNUAIRE" [ANU] : Endif

Local Integer ACOL(1..dim([F:ANU]ADDFLD)+1)
Gosub SET_LEVEL From SUBANU

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

MAGIC   = mess(77,133,1) : # Superviseur Adonix
Call SET_PREF(PREF) From SUBANU
NOMPROG = PREF+CODE
IDENT   = "## ANNUAIRE ##"

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

If !SILENCE
 Call TEMPON(mess(159,133,1)-NOMPROG) From GESECRAN : # Validation du traitement
Endif

Read [ANU]ANU0=CODE
If !fstat
 Gosub TRT_DEB
 If OK
  Gosub ETIQ
  Gosub TRT_FIN
 Endif
Endif

If !SILENCE
 Call TEMPOFF From GESECRAN
Endif

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
End

#-------------------------------------------------------#
$TRT_DEB
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
FICSRC = filpath("TRT",NOMPROG,"src",APPLI,"",MACHINE)
If filinfo(FICSRC,0)>=0
 Openi FICSRC Using [SSS_]
 Raz I, OK
 Rdseq CHAINE Using [SSS_]
 While !fstat
  I += 1 : If I>5 : Break : Endif
  If left$(CHAINE,len(IDENT))=IDENT
   OK = 1 : Break
  Endif
  Rdseq CHAINE Using [SSS_]
 Wend
 Openi Using [SSS_]
 If I<=1
  OK = 1
 Elsif !OK
  # Ce traitement est déjà utilisé par un autre paramètrage
  Call ECR_TRACE(NOMPROG-":"-mess(215,139,1),1) From GESECRAN
  Return
 Endif
Else
 OK = 1
Endif
Openo FICSRC , 0
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq "#"-MAGIC
Wrseq IDENT-"Annuaire"-CODE : # Annuaire
Wrseq
Return

#-------------------------------------------------------#
$TRT_FIN
Wrseq
Openo
Call VALID("TRT",NOMPROG,DOSSIER,OK) From VALMSKSUB
Return

#-------------------------------------------------------#
$ETIQ
Wrseq "$INIT"
Wrseq 'Local Char ASCOPE(20) , ABASE(250) , AFILTRE(250) , AVALEUR(20)(1..'+num$([F:ANU]NBRFLD)+')'
Wrseq 'Local Integer AERR'
For I=1 To [F:ANU]NBRFLD
 J = len([F:ANU]ADDFLD(I-1))
 If J>4 & toupper(right$([F:ANU]ADDFLD(I-1),J-3))="GUID"
  ACOL(I) = 1
  Wrseq 'AVALEUR('+num$(I)+') = "ACLOB'+num$(I)+'"'
 Else
  Wrseq 'AVALEUR('+num$(I)+') = "ACHAR'+num$(I)+'"'
 Endif
Next I
For I=1 To [F:ANU]NBRFLD
 Case ACOL(I)
  When 1       : Wrseq 'Local Clbfile ACLOB'+num$(I)+'(1)   : # '+[F:ANU]ADDFLD(I-1)
  When Default : Wrseq 'Local Char    ACHAR'+num$(I)+'(250) : # '+[F:ANU]ADDFLD(I-1)
 Endcase
Next I
Wrseq 'Return'
Wrseq
Wrseq '$LIRE'
If [F:ANU]NBRFLD>0
 Wrseq 'Case ASCOPE'
 Wrseq ' When "'+LEVEL(1)+'"'
 Wrseq '  Srldaplv '; : Gosub CHAMP
 Wrseq ' When "'+LEVEL(2)+'"'
 Wrseq '  Srldapbs '; : Gosub CHAMP
 Wrseq ' When default'
 Wrseq '  Srldaptr '; : Gosub CHAMP
 Wrseq "Endcase"
Endif
Wrseq 'Return'
Wrseq
Wrseq '$SUITE'
Wrseq 'Nxldap using [ALDP]'
Wrseq 'Return'
Wrseq
Return

$CHAMP
Wrseq 'ABASE Filter AFILTRE With'
For I=1 To [F:ANU]NBRFLD
 Case ACOL(I)
  When 1        : Wrseq '&  ACLOB'+num$(I)-'As'-'"'+[F:ANU]ADDFLD(I-1)+'"';
  When Default  : Wrseq '&  ACHAR'+num$(I)-'As'-'"'+[F:ANU]ADDFLD(I-1)+'"';
 Endcase
 If I<[F:ANU]NBRFLD
  Wrseq ','
 Else
  Wrseq
 Endif
Next I
Wrseq '&  Using [ALDP]'
Return
