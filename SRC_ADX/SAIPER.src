#<AdxTL>@(#)10.0.0.0 $Revision$
Call OBJET("PER",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"
  Local Integer EXERCICE , PERIODE , EXESUIV , NBPER , I_J
  Local Libelle DER_PER
  Local Char    SOCIETE(GLONCPY), SYMBOLE(40)
  Local Date    DEBEX , FINEX , DAT_DEB, DAT_FIN
 When "DEBUT"
  Case BOITE
   When "FPEROUV"
    SYMBOLE = "PER"+num$([M:PER1]FIYNUM)+"\"+[M:PER1]CPY
    Lock =SYMBOLE With lockwait=0
    If fstat  
     GERR = 2 : GMESSAGE = mess(10,100,1) : # Modification en cours sur un autre poste
     FIN = 1 : Return
    Endif
    Gosub CHARGE_OUV From SUBPER
    If !I_J
     GERR = 2 : GMESSAGE = mess(64,100,1) : # Toutes les périodes sont ouvertes
     FIN = 1 : Unlock =SYMBOLE : Return
    Endif
    Affzo
  Endcase
 When "FIN"
  Case BOITE
   When "FPEROUV"
    Unlock =SYMBOLE
  Endcase
 When "OK"
  Case BOITE
   When "FPEROUV"
    Gosub VALID_OUV From SUBPER
    Unlock =SYMBOLE
    FIN = 1
  Endcase
Endcase
Return



