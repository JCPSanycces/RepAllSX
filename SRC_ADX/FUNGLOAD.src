#<AdxTL>@(#)8.0.0.0 $Revision$
#########################################################################
#    ACTION MODELISATION                                                #
#                                                                       #
# GACTION  : VISULOAD    : Action visualisation charge graphique        #
#                                                                       #
#########################################################################
# Paramètres
#     WFCY  = Site de production
#     WJAL  = non jalonné / jalonné
#     WSTA  = Choix suggéré = 1 / planifié = 2 / ferme = 4
#     WWCRD = Centre charge début
#     WWCRF = Centre charge fin
#     WWSTD = Poste charge début
#     WWSTF = Poste charge fin
#     WWSTTYPD = type poste début
#     WWSTTYPF = type poste fin
#     WPER  = Périodicité jour = 1 / semaine = 2 / mois = 3
#     WPERN = Nombre de périodes
#     WDATD = Date début
#########################################################################
$ACTION
Case ACTION
    When "OUVRE"          :
        Case GACTION
            When "VISULOAD" :  Gosub OUVRE
        Endcase
    When "DEBUT"          :
        Case GACTION
            When "VISULOAD" :  Gosub DEBUT
            When "IGLOADG"  :  Gosub DEBUT_GRAPHE
        Endcase
    When "OK"
        Case GACTION
            When "VISULOAD" :  Gosub OUVRE
                               Gosub DEBUT
        Endcase
    When Default
Endcase
Return

########################################################################
$OUVRE
# désactivation en Web --> Plus a partir de la V5
#If GBROWS : GMESSAGE = mess(85,150,1) : GERR = 2 : FIN = 1 : Endif

Local Char    WFCY(GLONFCY)
Local Integer WJAL
Local Integer WSTA
Local Char    WWCRD(GLONWCR)
Local Char    WWCRF(GLONWCR)
Local Char    WWSTD(GLONWST)
Local Char    WWSTF(GLONWST)
Local Integer WWSTTYPD
Local Integer WWSTTYPF
Local Integer WPER
Local Integer WPERN
Local Date    WDATD
Local Char    WDATC(10)
Local Char    WORI(1)     # 30913 MM 06.05

If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:WKL]) = 0 : Local File WORKLOAD   [WKL] : Endif
If clalev([F:OPS]) = 0 : Local File OPERATIONS [OPS] : Endif
If clalev([F:SCH]) = 0 : Local File SCHEDULING [SCH] : Endif
If clalev([F:MWS]) = 0 : Local File WORKSTATIO [MWS] : Endif
If clalev([F:TWC]) = 0 : Local File TABWRKCTR  [TWC] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:TUV]) = 0 : Local File TABUNAVAIL [TUV] : Endif
If clalev([F:TWD]) = 0 : Local File TABWEEDIA  [TWD] : Endif
If clalev([F:CPV]) = 0 : Local File CAPVAR     [CPV] : Endif
If clalev([M:OPSG]) <= 0 : Local Mask OPSG      [OPSG] : Endif
Return

########################################################################
$DEBUT
Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
WFCY = PARAM(1)            :    If WFCY = "" : WFCY = GFCY : Endif
WJAL = val(PARAM(2))       :    If !WJAL     : WJAL = 1    : Endif
WSTA = val(PARAM(3))
WWCRD = PARAM(4)
WWCRF = PARAM(5)
WWSTD = PARAM(6)
WWSTF = PARAM(7)
WWSTTYPD = val(PARAM(8))   :    If !find(WWSTTYPD,1,2,3) : WWSTTYPD = 1 : Endif
WWSTTYPF = val(PARAM(9))   :    If !find(WWSTTYPF,1,2,3) : WWSTTYPF = 3 : Endif
WPER  = val(PARAM(10))     :    If !find(WPER,1,2,3)     : WPER     = 1 : Endif                    :
WPERN = val(PARAM(11))
WDATC = PARAM(12)          :    If WDATC <> "" : If instr(1,WDATC,"/") : WDATD = "["+WDATC+"]" : Else : WDATD = WDATC : Endif : Endif
WORI  = PARAM(13)          # 30913 MM 06.05
FIN = 0

# alimentation écran
Raz [M:OPSC]
[M:OPSC]MFGFCY     = WFCY
[M:OPSC]XJAL       = WJAL
If find(WSTA,1,3,5,7) : [M:OPSC]OWS = 2 : Else : [M:OPSC]OWS = 1 : Endif
If find(WSTA,2,3,6,7) : [M:OPSC]OWP = 2 : Else : [M:OPSC]OWP = 1 : Endif
If find(WSTA,4,5,6,7) : [M:OPSC]OWF = 2 : Else : [M:OPSC]OWF = 1 : Endif
[M:OPSC]WCRSTR     = WWCRD
[M:OPSC]WCREND     = WWCRF
[M:OPSC]WSTSTR     = WWSTD
[M:OPSC]WSTEND     = WWSTF
[M:OPSC]WSTTYPSTR  = WWSTTYPD
[M:OPSC]WSTTYPEND  = WWSTTYPF
If WDATD <> [0/0/0]  : [M:OPSC]STRDAT = WDATD : Else : [M:OPSC]STRDAT = date$ : Endif
[M:OPSC]PERCOD     = WPER
If !WPERN
    Case WPER
        When 1 : [M:OPSC]PERNBR = 30
        When 2 : [M:OPSC]PERNBR = 15
        When 3 : [M:OPSC]PERNBR = 12
    Endcase
Else
    [M:OPSC]PERNBR = WPERN
Endif
# 30913 MM 06.05 : gestion memo STD
#[M:OPSC]FUNORI = WORI
#If filinfo(filpath("ETM",GUSER+"_"+"STD","ops",0),0)>=0
#    If [M:OPSC]FUNORI =""
#        Raz [M:OPSC]
#        Call LECMEMO("STD","[M:OPSC]","ops") From GMEMO
#    Endif
#Endif

Affzo [M:OPSC]1-99
Return

#########################################################################
$DEBUT_GRAPHE
FIN = 0
Case [M:OPSC]XJAL
    When 1: Call AFF_GRAPHED
    When 2: Call AFF_GRAPHE
Endcase
Return

############################################################
Subprog AFF_GRAPHE
Local Date    WDAT, WDTE
Local Date    WDATD([M:OPSC]PERNBR)
Local Date    WDATF([M:OPSC]PERNBR)
Local Decimal WCRGF([M:OPSC]PERNBR+1)
Local Decimal WCRGP([M:OPSC]PERNBR+1)
Local Decimal WCRGS([M:OPSC]PERNBR+1)
Local Decimal WCRGM([M:OPSC]PERNBR+1)
Local Decimal WCRGT([M:OPSC]PERNBR+1)         # FQ 53994 Charge Totale
Local Char    WABS1(20)([M:OPSC]PERNBR+1)
Local Char    WABS2(20)([M:OPSC]PERNBR+1)     # FQ 62353 pour liste des opérations
#Local Char    WABS2(03)([M:OPSC]PERNBR+1)
Local Char    WORD(20)(4)
Local Char    WWCRT(20)
Local Char    WWSTT(20)
Local Char    WWSTTYPT(20)
Local Integer WROW
Local Char    WTIT(60)
Local Char    WFOO(140)
#Local Char    WNAM
Local Decimal WLOA, WMAX
Local Integer WTYP, I
Raz WDATD, WDATF, WCRGF, WCRGP, WCRGS, WCRGM, WCRGT, WABS1, WABS2, WORD
# Calcul date début et fin buckets
Case [M:OPSC]PERCOD
    When 1 : WDTE = [M:OPSC]STRDAT
             For I = 0 To [M:OPSC]PERNBR-1
                 WDATD(I) = WDTE
                 WDATF(I) = WDTE
                 WDTE += 1
             Next I
    When 2 : WDATD(0) = [M:OPSC]STRDAT
             WDATF(0) = [M:OPSC]STRDAT + (7-dayn(WDATD(0)))
             WDTE = WDATF(0)+1
             For I = 1 To [M:OPSC]PERNBR-1
                 WDATD(I) = WDTE
                 WDATF(I) = WDTE + 6
                 WDTE += 7
             Next I
    When 3 : WDATD(0) = [M:OPSC]STRDAT
             WDATF(0) = eomonth(WDATD(0))
             WDTE = WDATF(0)+1
             For I = 1 To [M:OPSC]PERNBR-1
                 WDATD(I) = WDTE
                 WDATF(I) = eomonth(WDATD(I))
                 WDTE = WDATF(I) + 1
             Next I
Endcase

# lecture site
If [F:FCY]FCY <> [M:OPSC]MFGFCY
    Call LECTURE ("FCY", [M:OPSC]MFGFCY, "") From CONTOBJ
Endif

# lecture indisponibilités
If [F:TUV]UVYCOD <> [F:FCY]UVYCOD
    Read [F:TUV]UVY0=[F:FCY]UVYCOD
    If fstat : Raz [TUV] : Endif
Endif

# récupération courbe de capacité
Local Integer WNBJOUR : WNBJOUR = (WDATF([M:OPSC]PERNBR-1) - WDATD(0)) + 1
Local Decimal WCAP(WNBJOUR)
Local Integer WNBR(WNBJOUR)
Local Integer WRET
Local Char    CRITERE(255)

CRITERE = "[F:MWS]WCRFCY=[M:OPSC]MFGFCY"
If [M:OPSC]WCRSTR <> ""            : CRITERE += "&WCR>=[M:OPSC]WCRSTR"       : Endif
If [M:OPSC]WCREND <> ""            : CRITERE += "&WCR<=[M:OPSC]WCREND"       : Endif
If [M:OPSC]WSTSTR <> ""            : CRITERE += "&WST>=[M:OPSC]WSTSTR"       : Endif
If [M:OPSC]WSTEND <> ""            : CRITERE += "&WST<=[M:OPSC]WSTEND"       : Endif
If find([M:OPSC]WSTTYPSTR,1,2,3)   : CRITERE += "&WSTTYP>=[M:OPSC]WSTTYPSTR" : Endif
If find([M:OPSC]WSTTYPEND,1,2,3)   : CRITERE += "&WSTTYP<=[M:OPSC]WSTTYPEND" : Endif

Filter [MWS] Where evalue(CRITERE)
For [MWS]WST4
    Call LOACAPN(WDATD(0),WDATF([M:OPSC]PERNBR-1),WCAP,WNBR,WRET) From JALLIBB
    For I = 0 To [M:OPSC]PERNBR-1
        WMAX = 0
        WDTE = WDATD(I)
        While (WDTE <= WDATF(I))
            WMAX += WCAP(WDTE - WDATD(0))
            WDTE += 1
        Wend
        WCRGM(I) += WMAX
    Next I
Next
Filter [MWS]

# Composition labels abscisses
For I = 0 To [M:OPSC]PERNBR
    WABS1(I) = " "
    WABS2(I) = " "
Next I
WABS1(0) = format$("D:"+GFMDAT4,WDATD(0))
WABS2(0) = format$("D:"+GFMDAT4,WDATF(0))    # FQ 62353 pour liste des opérations
#Case [M:OPSC]PERCOD
#    When 1,2  : WABS2(0) = format$("K:3X",month$(WDATD(0)))
#Endcase

For I = 0 To [M:OPSC]PERNBR-1              # FQ 61941 GA 03/2010 avant For I=1

    #bug  56994 09.09 le fait que toutes les dates ne soient pas renseignées en abscisse
    #posait problème
    #        When 1 : If dayn(WDATD(I)) = 1 & I <> 1
    #                     WABS1(I) = format$("D:"+GFMDAT4,WDATD(I))
    #                 Endif
    #                 If day(WDATD(I)) = 1
    #                     WABS2(I) =  format$("K:3X",month$(WDATD(I)))
    #                 Endif
    #        When 2 : WABS1(I) = format$("D:"+GFMDAT4,WDATD(I))
    #                 If gdat$(1,month(WDATF(I)),year(WDATF(I))) >= WDATD(I) &
    #&                   gdat$(1,month(WDATF(I)),year(WDATF(I))) <= WDATF(I)
    #                     WABS2(I) =  format$("K:3X",month$(WDATD(I)))
    #                 Endif

    Case [M:OPSC]PERCOD
        When 1 : WABS1(I) = format$("D:"+GFMDAT4,WDATD(I))
                 WABS2(I) = format$("D:"+GFMDAT4,WDATF(I))   # FQ 62353 pour liste des opérations
        When 2 : WABS1(I) = format$("D:"+GFMDAT4,WDATD(I))
                 WABS2(I) = format$("D:"+GFMDAT4,WDATF(I))   # FQ 62353 pour liste des opérations
        When 3 : WABS1(I) = format$("K:3X",month$(WDATD(I)))
                 WABS2(I) = format$("K:3X",month$(WDATF(I))) # FQ 62353 pour liste des opérations
    Endcase
Next I


# calcul date fin
WDAT = WDATF([M:OPSC]PERNBR-1)
# Lecture charge
If [M:OPSC]WCRSTR = "" & [M:OPSC]WCREND = ""
    If [M:OPSC]WSTSTR = "" & [M:OPSC]WSTEND = ""
        Link [WKL] With [MWS]WST0=[F:WKL]WST;[F:WKL]MFGFCY
&                  As [XWKL]
&                  Where [F:WKL]MFGFCY  = [M:OPSC]MFGFCY &
&                        [F:MWS]WSTTYP >= [M:OPSC]WSTTYPSTR &
&                        [F:MWS]WSTTYP <= [M:OPSC]WSTTYPEND &
&                        [F:WKL]PERSTR <= WDAT           &
&                        [F:WKL]PEREND >= [M:OPSC]STRDAT
&                  Order By Key WKL1
    Else
        Link [WKL] With [MWS]WST0=[F:WKL]WST;[F:WKL]MFGFCY
&                  As [XWKL]
&                  Where [F:WKL]MFGFCY  = [M:OPSC]MFGFCY &
&                        [F:WKL]WST    >= [M:OPSC]WSTSTR &
&                        [F:WKL]WST    <= [M:OPSC]WSTEND &
&                        [F:MWS]WSTTYP >= [M:OPSC]WSTTYPSTR &
&                        [F:MWS]WSTTYP <= [M:OPSC]WSTTYPEND &
&                        [F:WKL]PERSTR <= WDAT           &
&                        [F:WKL]PEREND >= [M:OPSC]STRDAT
&                  Order By Key WKL1
    Endif
Else
    If [M:OPSC]WSTSTR = "" & [M:OPSC]WSTEND = ""
        Link [WKL] With [MWS]WST0= [F:WKL]WST;[F:WKL]MFGFCY
&                  As [XWKL]
&                  Where [F:WKL]MFGFCY  = [M:OPSC]MFGFCY &
&                        [F:WKL]WCR    >= [M:OPSC]WCRSTR &
&                        [F:WKL]WCR    <= [M:OPSC]WCREND &
&                        [F:MWS]WSTTYP >= [M:OPSC]WSTTYPSTR &
&                        [F:MWS]WSTTYP <= [M:OPSC]WSTTYPEND &
&                        [F:WKL]PERSTR <= WDAT           &
&                        [F:WKL]PEREND >= [M:OPSC]STRDAT
&                  Order By Key WKL1
    Else
        Link [WKL] With [MWS]WST0= [F:WKL]WST;[F:WKL]MFGFCY
&                  As [XWKL]
&                  Where [F:WKL]MFGFCY  = [M:OPSC]MFGFCY &
&                        [F:WKL]WCR    >= [M:OPSC]WCRSTR &
&                        [F:WKL]WCR    <= [M:OPSC]WCREND &
&                        [F:WKL]WST    >= [M:OPSC]WSTSTR &
&                        [F:WKL]WST    <= [M:OPSC]WSTEND &
&                        [F:MWS]WSTTYP >= [M:OPSC]WSTTYPSTR &
&                        [F:MWS]WSTTYP <= [M:OPSC]WSTTYPEND &
&                        [F:WKL]PERSTR <= WDAT           &
&                        [F:WKL]PEREND >= [M:OPSC]STRDAT
&                 Order By Key WKL1
    Endif
Endif


For [XWKL]
    # Issue 102692 - 2014-09-17 by JUSYN : Considers now holidays and weekends to display a better average of the load
    # I = ([F:WKL]PEREND-[F:WKL]PERSTR)+1
    I = [F:WKL]PERWRKNBR

    If I > 0
        If ([M:OPSC]OWF = 2 & [F:WKL]OWFLOD <> 0)
            WLOA = [F:WKL]OWFLOD
            WTYP = 1
            Gosub CUM_LOAD
        Endif
        If ([M:OPSC]OWP = 2 & [F:WKL]OWPLOD <> 0)
            WLOA = [F:WKL]OWPLOD
            WTYP = 2
            Gosub CUM_LOAD
        Endif
        If (([M:OPSC]OWS = 2 & [F:WKL]OWSLOD <> 0) & find([M:OPSC]MRPFLG,2,3))
            WLOA = [F:WKL]OWSLOD
            WTYP = 3
            Gosub CUM_LOAD
        Endif
        If (([M:OPSC]OWS = 2 & [F:WKL]ORSLOD <> 0) & find([M:OPSC]MRPFLG,1,3))
            WLOA = [F:WKL]ORSLOD
            WTYP = 3
            Gosub CUM_LOAD
        Endif
    Endif
Next
Filter [XWKL]

WROW = [M:OPSC]PERNBR+1

Gosub AFF_GRAPHIQUE
End

#-----------------------------------------------------------
$CUM_LOAD
# Issue 102692 - 2014-09-17 by JUSYN : Considers now holidays and weekends to display a better average of the load
Local Decimal WLOADP
Local Decimal WLOADD
Local Integer K

WLOADD = 0

If I > 0
    WLOA  = WLOA/I
    WDTE  = [F:WKL]PERSTR
    While WDTE <= [F:WKL]PEREND
        If WDTE >= WDATD(0)
            For J = 0 To [M:OPSC]PERNBR-1
                # Issue 102692 - 2014-09-17 by JUSYN : Considers now holidays and weekends to display a better average of the load
                #If WDTE >= WDATD(J) & WDTE <= WDATF(J)
                #    Case WTYP
                #        When 1 : WCRGF(J) += WLOA
                #        When 2 : WCRGP(J) += WLOA
                #        When 3 : WCRGS(J) += WLOA
                #    Endcase
                #    WCRGT(J) += WLOA    # FQ 53994 Charge Totale
                #    Break
                #Endif
                If WDTE = WDATD(J)
                  K = func GET_PERWRKNBR(WDATD(J), WDATF(J))
                  WLOADP = WLOA * K
                  WLOADD = 0
                Endif
                If WDTE >= WDATD(J) & WDTE <= WDATF(J) & WCRGM(J) <> 0
                    If WLOADD <= WLOADP
                      Case WTYP
                          When 1 : WCRGF(J) += WLOA
                          When 2 : WCRGP(J) += WLOA
                          When 3 : WCRGS(J) += WLOA
                      Endcase
                      WCRGT(J) += WLOA    # FQ 53994 Charge Totale
                      WLOADD += WLOA
                    Endif
                    Break
                Endif
            Next J
        Endif
        WDTE += 1
    Wend
Endif
Return

############################################################
Subprog AFF_GRAPHED
Local Date    WDAT, WDTE
Local Date    WDATD([M:OPSC]PERNBR)
Local Date    WDATF([M:OPSC]PERNBR)
Local Decimal WCRGF([M:OPSC]PERNBR+1)
Local Decimal WCRGP([M:OPSC]PERNBR+1)
Local Decimal WCRGS([M:OPSC]PERNBR+1)
Local Decimal WCRGM([M:OPSC]PERNBR+1)
Local Decimal WCRGT([M:OPSC]PERNBR+1)         # FQ 53994 Charge Totale
Local Char    WABS1(20)([M:OPSC]PERNBR+1)
Local Char    WABS2(20)([M:OPSC]PERNBR+1)     # FQ 62353 pour liste des opérations
#Local Char    WABS2(03)([M:OPSC]PERNBR+1)
Local Char    WORD(20)(4)
Local Char    WWCRT(20)
Local Char    WWSTT(20)
Local Char    WWSTTYPT(20)  # 15302 09.02 MM
Local Integer WROW
Local Char    WTIT(80)
Local Char    WFOO(140)    # 15302 09.02 MM
#Local Char    WNAM
Local Decimal WLOA, WMAX
Local Integer WTYP, I, X
Raz WDATD, WDATF, WCRGF, WCRGP, WCRGS, WCRGM, WCRGT, WABS1, WABS2, WORD

# Calcul date début et fin buckets
Case [M:OPSC]PERCOD
    When 1 : WDTE = [M:OPSC]STRDAT
             For I = 0 To [M:OPSC]PERNBR-1
                 WDATD(I) = WDTE
                 WDATF(I) = WDTE
                 WDTE += 1
             Next I
    When 2 : WDATD(0) = [M:OPSC]STRDAT
             WDATF(0) = [M:OPSC]STRDAT + (7-dayn(WDATD(0)))
             WDTE = WDATF(0)+1
             For I = 1 To [M:OPSC]PERNBR-1
                 WDATD(I) = WDTE
                 WDATF(I) = WDTE + 6
                 WDTE += 7
             Next I
    When 3 : WDATD(0) = [M:OPSC]STRDAT
             WDATF(0) = eomonth(WDATD(0))
             WDTE = WDATF(0)+1
             For I = 1 To [M:OPSC]PERNBR-1
                 WDATD(I) = WDTE
                 WDATF(I) = eomonth(WDATD(I))
                 WDTE = WDATF(I) + 1
             Next I
Endcase

# lecture site
If [F:FCY]FCY <> [M:OPSC]MFGFCY
    Call LECTURE ("FCY", [M:OPSC]MFGFCY, "") From CONTOBJ
Endif

# lecture indisponibilités
If [F:TUV]UVYCOD <> [F:FCY]UVYCOD
    Read [F:TUV]UVY0=[F:FCY]UVYCOD
    If fstat : Raz [TUV] : Endif
Endif

# récupération courbe de capacité
Local Integer WNBJOUR : WNBJOUR = (WDATF([M:OPSC]PERNBR-1) - WDATD(0)) + 1
Local Decimal WCAP(WNBJOUR)
Local Integer WNBR(WNBJOUR)
Local Integer WRET
Local Char    CRITERE(255)

CRITERE = "[F:MWS]WCRFCY=[M:OPSC]MFGFCY"
If [M:OPSC]WCRSTR <> ""                 : CRITERE += "&WCR>=[M:OPSC]WCRSTR"       : Endif
If [M:OPSC]WCREND <> ""                 : CRITERE += "&WCR<=[M:OPSC]WCREND"       : Endif
If [M:OPSC]WSTSTR <> ""                 : CRITERE += "&WST>=[M:OPSC]WSTSTR"       : Endif
If [M:OPSC]WSTEND <> ""                 : CRITERE += "&WST<=[M:OPSC]WSTEND"       : Endif
If find([M:OPSC]WSTTYPSTR,1,2,3)        : CRITERE += "&WSTTYP>=[M:OPSC]WSTTYPSTR" : Endif
If find([M:OPSC]WSTTYPEND,1,2,3)        : CRITERE += "&WSTTYP<=[M:OPSC]WSTTYPEND" : Endif

Filter [MWS] Where evalue(CRITERE)
For [MWS]WST4
    Call LOACAPN(WDATD(0),WDATF([M:OPSC]PERNBR-1),WCAP,WNBR,WRET) From JALLIBB
    For I = 0 To [M:OPSC]PERNBR-1
        WMAX = 0
        WDTE = WDATD(I)
        While (WDTE <= WDATF(I))
            WMAX += WCAP(WDTE - WDATD(0))
            WDTE += 1
        Wend
        WCRGM(I) += WMAX
    Next I
Next
Filter [MWS]

# Composition labels abscisses
For I = 0 To [M:OPSC]PERNBR
    WABS1(I) = " "
    WABS2(I) = " "
Next I
WABS1(0) = format$("D:"+GFMDAT4,WDATD(0))
WABS2(0) = format$("D:"+GFMDAT4,WDATF(0)) # FQ 62353 pour liste des opérations
#Case [M:OPSC]PERCOD
#    When 1,2  : WABS2(0) = format$("K:3X",month$(WDATD(0)))
#Endcase

For I = 0 To [M:OPSC]PERNBR-1              # FQ 61941 GA 03/2010 avant For I=1

    #bug  56994 09.09 le fait que toutes les dates ne soient pas renseignées en abscisse
    #posait problème
    #        When 1 : If dayn(WDATD(I)) = 1 & I <> 1
    #                     WABS1(I) = format$("D:"+GFMDAT4,WDATD(I))
    #                 Endif
    #                 If day(WDATD(I)) = 1
    #                     WABS2(I) =  format$("K:3X",month$(WDATD(I)))
    #                 Endif
    #       When 2 : WABS1(I) = format$("D:"+GFMDAT4,WDATD(I))
    #                 If gdat$(1,month(WDATF(I)),year(WDATF(I))) >= WDATD(I) &
    #&                   gdat$(1,month(WDATF(I)),year(WDATF(I))) <= WDATF(I)
    #                     WABS2(I) =  format$("K:3X",month$(WDATD(I)))
    #                 Endif

    Case [M:OPSC]PERCOD
        When 1 : WABS1(I) = format$("D:"+GFMDAT4,WDATD(I))
                 WABS2(I) = format$("D:"+GFMDAT4,WDATF(I))   # FQ 62353 pour liste des opérations
        When 2 : WABS1(I) = format$("D:"+GFMDAT4,WDATD(I))
                 WABS2(I) = format$("D:"+GFMDAT4,WDATF(I))   # FQ 62353 pour liste des opérations
        When 3 : WABS1(I) = format$("K:3X",month$(WDATD(I)))
                 WABS2(I) = format$("K:3X",month$(WDATD(I))) # FQ 62353 pour liste des opérations
    Endcase
Next I

# calcul date fin
WDAT = WDATF([M:OPSC]PERNBR-1)
# Lecture charge
If [M:OPSC]WCRSTR = "" & [M:OPSC]WCREND = ""
    X = 1
    If [M:OPSC]WSTSTR = "" & [M:OPSC]WSTEND = ""
        Link [OPS] With [MWS]WST0=[F:OPS]EXTWST;[F:OPS]MFGFCY
&                  As [LIE]
&                  Where [F:OPS]MFGFCY  = [M:OPSC]MFGFCY &
&                        [F:MWS]WSTTYP >= [M:OPSC]WSTTYPSTR &
&                        [F:MWS]WSTTYP <= [M:OPSC]WSTTYPEND &
&                        [F:OPS]OPESTR <= WDAT           &
&                        [F:OPS]OPEEND >= [M:OPSC]STRDAT
&                  Order By Key OPS3
    Else
        Link [OPS] With [MWS]WST0=[F:OPS]EXTWST;[F:OPS]MFGFCY
&                  As [LIE]
&                  Where [F:OPS]MFGFCY  = [M:OPSC]MFGFCY &
&                        [F:OPS]EXTWST >= [M:OPSC]WSTSTR &
&                        [F:OPS]EXTWST <= [M:OPSC]WSTEND &
&                        [F:MWS]WSTTYP >= [M:OPSC]WSTTYPSTR &
&                        [F:MWS]WSTTYP <= [M:OPSC]WSTTYPEND &
&                        [F:OPS]OPESTR <= WDAT           &
&                        [F:OPS]OPEEND >= [M:OPSC]STRDAT
&                  Order By Key OPS3
    Endif
Else
    X = 2
    If [M:OPSC]WSTSTR = "" & [M:OPSC]WSTEND = ""
        Link [OPS] With [MWS]WST0=[F:OPS]EXTWST;[F:OPS]MFGFCY As [XOPS]
&                  Where [F:OPS]MFGFCY  = [M:OPSC]MFGFCY &
&                        [F:MWS]WCR >= [M:OPSC]WCRSTR &
&                        [F:MWS]WCR <= [M:OPSC]WCREND &
&                        [F:MWS]WSTTYP >= [M:OPSC]WSTTYPSTR &
&                        [F:MWS]WSTTYP <= [M:OPSC]WSTTYPEND &
&                        [F:OPS]OPESTR <= WDAT           &
&                        [F:OPS]OPEEND >= [M:OPSC]STRDAT
&                  Order By Key OPS3
    Else
        Link [OPS] With [MWS]WST0=[F:OPS]EXTWST;[F:OPS]MFGFCY As [XOPS]
&                  Where [F:OPS]MFGFCY  = [M:OPSC]MFGFCY &
&                        [F:MWS]WCR >= [M:OPSC]WCRSTR &
&                        [F:MWS]WCR <= [M:OPSC]WCREND &
&                        [F:OPS]EXTWST >= [M:OPSC]WSTSTR &
&                        [F:OPS]EXTWST <= [M:OPSC]WSTEND &
&                        [F:MWS]WSTTYP >= [M:OPSC]WSTTYPSTR &
&                        [F:MWS]WSTTYP <= [M:OPSC]WSTTYPEND &
&                        [F:OPS]OPESTR <= WDAT           &
&                        [F:OPS]OPEEND >= [M:OPSC]STRDAT
&                  Order By Key OPS3
    Endif
Endif

Case X
    When 1: For [LIE]
                Read [F:SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM
                If fstat : Goto NXT1 : Endif
                If [F:SCH]OPESTRDAT <> [0/0/0] : Goto NXT1 : Endif
                Gosub LOOP_LOAD
$NXT1
            Next
            Filter [LIE]
    When 2: For [XOPS]
                Read [F:SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM
                If fstat : Goto NXT2: Endif
                If [F:SCH]OPESTRDAT <> [0/0/0] : Goto NXT2: Endif
                Gosub LOOP_LOAD
$NXT2
            Next
            Filter [XOPS]
Endcase

# deuxième passage pour gérer la main d'oeuvre secondaire
# Lecture charge
If [M:OPSC]WCRSTR = "" & [M:OPSC]WCREND = ""
    X = 1
    If [M:OPSC]WSTSTR = "" & [M:OPSC]WSTEND = ""
        Link [OPS] With [MWS]WST0=[F:OPS]EXTLAB;[F:OPS]MFGFCY As [LIE]
&                  Where [F:OPS]MFGFCY  = [M:OPSC]MFGFCY &
&                        [F:MWS]WSTTYP >= [M:OPSC]WSTTYPSTR &
&                        [F:MWS]WSTTYP <= [M:OPSC]WSTTYPEND &
&                        [F:OPS]OPESTR <= WDAT           &
&                        [F:OPS]OPEEND >= [M:OPSC]STRDAT
&                  Order By Key OPS3
    Else
        Link [OPS] With [MWS]WST0=[F:OPS]EXTLAB;[F:OPS]MFGFCY As [LIE]
&                  Where [F:OPS]MFGFCY  = [M:OPSC]MFGFCY &
&                        [F:OPS]EXTLAB >= [M:OPSC]WSTSTR &
&                        [F:OPS]EXTLAB <= [M:OPSC]WSTEND &
&                        [F:MWS]WSTTYP >= [M:OPSC]WSTTYPSTR &
&                        [F:MWS]WSTTYP <= [M:OPSC]WSTTYPEND &
&                        [F:OPS]OPESTR <= WDAT           &
&                        [F:OPS]OPEEND >= [M:OPSC]STRDAT
&                  Order By Key OPS3
    Endif
Else
    X = 2
    If [M:OPSC]WSTSTR = "" & [M:OPSC]WSTEND = ""
        Link [OPS] With [MWS]WST0=[F:OPS]EXTLAB;[F:OPS]MFGFCY As [XOPS]
&                  Where [F:OPS]MFGFCY  = [M:OPSC]MFGFCY &
&                        [F:MWS]WCR >= [M:OPSC]WCRSTR &
&                        [F:MWS]WCR <= [M:OPSC]WCREND &
&                        [F:MWS]WSTTYP >= [M:OPSC]WSTTYPSTR &
&                        [F:MWS]WSTTYP <= [M:OPSC]WSTTYPEND &
&                        [F:OPS]OPESTR <= WDAT           &
&                        [F:OPS]OPEEND >= [M:OPSC]STRDAT
&                  Order By Key OPS3
    Else
        Link [OPS] With [MWS]WST0=[F:OPS]EXTLAB;[F:OPS]MFGFCY As [XOPS]
&                  Where [F:OPS]MFGFCY  = [M:OPSC]MFGFCY &
&                        [F:MWS]WCR >= [M:OPSC]WCRSTR &
&                        [F:MWS]WCR <= [M:OPSC]WCREND &
&                        [F:OPS]EXTLAB >= [M:OPSC]WSTSTR &
&                        [F:OPS]EXTLAB <= [M:OPSC]WSTEND &
&                        [F:MWS]WSTTYP >= [M:OPSC]WSTTYPSTR &
&                        [F:MWS]WSTTYP <= [M:OPSC]WSTTYPEND &
&                        [F:OPS]OPESTR <= WDAT           &
&                        [F:OPS]OPEEND >= [M:OPSC]STRDAT
&                  Order By Key OPS3
    Endif
Endif

Case X
    When 1:
        For [LIE]
           Read [F:SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM
           If fstat : Goto NXT1 : Endif
           If [F:SCH]OPESTRDAT <> [0/0/0] : Goto NXT3 : Endif
           Gosub LOOP_LOAD2
$NXT3
        Next
        Filter [LIE]
    When 2:
        For [XOPS]
            Read [F:SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM
            If fstat : Goto NXT2: Endif
            If [F:SCH]OPESTRDAT <> [0/0/0] : Goto NXT4: Endif
            Gosub LOOP_LOAD2
$NXT4
        Next
        Filter [XOPS]
Endcase

WROW = [M:OPSC]PERNBR+1
Gosub AFF_GRAPHIQUE
End

#--------------------------------------------------------------
$AFF_GRAPHIQUE
Effzo [M:OPSG]
For I = 0 To [M:OPSC]PERNBR-1
      [M:OPSG]WABS1(I) = WABS1(I)
      If dim([M:OPSG]WABS2)>I [M:OPSG]WABS2(I) = WABS2(I) Endif     # FQ 62353 pour liste des opérations
      [M:OPSG]WCRGM(I) = WCRGM(I)
      [M:OPSG]WCRGF(I) = WCRGF(I)
      [M:OPSG]WCRGP(I) = WCRGP(I)
      [M:OPSG]WCRGS(I) = WCRGS(I)
      If dim([M:OPSG]WCRGT)>0 [M:OPSG]WCRGT(I) = WCRGT(I) Endif     # FQ 53994 Charge Totale
      If dim([M:OPSG]WDAT1)>0 [M:OPSG]WDAT1(I) = WDATD(I) Endif     # FQ 64660 GA 07/2010
      If dim([M:OPSG]WDAT2)>0 [M:OPSG]WDAT2(I) = WDATF(I) Endif     # FQ 64660 GA 07/2010
Next
[M:OPSG]NBLIGC = WROW
Affzo [M:OPSG]
Return

#-------------------------------------------------------------
$LOOP_LOAD
# Issue 102692 - 2014-09-17 by JUSYN : Considers now holidays and weekends to display a better average of the load
# I = ([F:OPS]OPEEND-[F:OPS]OPESTR)+1
# Issue 108332 - 2015-05-26 by JUSYN : when operation with forced start date then operation start date is filled with lowest possible date or is empty
[F:OPS]OPESTR = [F:OPS]OPESTR + 0
If [F:OPS]OPESTR = [0/0/0] | [F:OPS]OPESTR <= [31/12/1899]
    I = func GET_PERWRKNBR([F:OPS]INFCAPSTR, [F:OPS]INFCAPEND)
Else
    I = func GET_PERWRKNBR([F:OPS]OPESTR, [F:OPS]OPEEND)
Endif

If I > 0
    If ([M:OPSC]OWF = 2 & [F:OPS]OPSSTA = 1)
        WLOA = 0
        If [F:OPS]CPLSETTIM <= [F:OPS]EXTSETTIM : WLOA += [F:OPS]EXTSETTIM - [F:OPS]CPLSETTIM : Endif
        If [F:OPS]CPLOPETIM <= [F:OPS]EXTOPETIM : WLOA += [F:OPS]EXTOPETIM - [F:OPS]CPLOPETIM : Endif
        If [F:OPS]TIMUOMCOD = 2 : WLOA /=60 : Endif
        WTYP = 1
        Gosub CUM_LOADD
    Endif
    If([M:OPSC]OWP = 2 & [F:OPS]OPSSTA = 2)
        WLOA = [F:OPS]EXTSETTIM + [F:OPS]EXTOPETIM
        If [F:OPS]TIMUOMCOD = 2 : WLOA /=60 : Endif
        WTYP = 2
        Gosub CUM_LOADD
    Endif
   If (([M:OPSC]OWS = 2 & [F:OPS]OPSSTA = 3)  &
&       ((find([M:OPSC]MRPFLG,1,3) & [F:OPS]OPSTYP = 2) | (find([M:OPSC]MRPFLG,2,3) & [F:OPS]OPSTYP = 1)))
       WLOA = [F:OPS]EXTSETTIM + [F:OPS]EXTOPETIM
       If [F:OPS]TIMUOMCOD = 2 : WLOA /=60 : Endif
       WTYP = 3
       Gosub CUM_LOADD
   Endif
Endif
Return

#-------------------------------------------------------------
$LOOP_LOAD2
# # Issue 102692 - 2014-09-17 by JUSYN : Considers now holidays and weekends to display a better average of the load
# I = ([F:OPS]OPEEND-[F:OPS]OPESTR)+1
# Issue 108332 - 2015-05-26 by JUSYN : when operation with forced start date then operation start date is filled with lowest possible date or is empty
[F:OPS]OPESTR = [F:OPS]OPESTR + 0
If [F:OPS]OPESTR = [0/0/0] | [F:OPS]OPESTR <= [31/12/1899]
    I = func GET_PERWRKNBR([F:OPS]INFCAPSTR, [F:OPS]INFCAPEND)
Else
    I = func GET_PERWRKNBR([F:OPS]OPESTR, [F:OPS]OPEEND)
Endif

If I > 0
    If ([M:OPSC]OWF = 2 & [F:OPS]OPSSTA = 1)
        WLOA = 0
        If [F:OPS]CPLSETTIM <= [F:OPS]EXTSETTIM : WLOA += ([F:OPS]EXTSETTIM - [F:OPS]CPLSETTIM) * [F:OPS]SETLABCOE : Endif
        If [F:OPS]CPLOPETIM <= [F:OPS]EXTOPETIM : WLOA += ([F:OPS]EXTOPETIM - [F:OPS]CPLOPETIM) * [F:OPS]OPELABCOE : Endif
        If [F:OPS]TIMUOMCOD = 2 : WLOA /=60 : Endif
        WTYP = 1
        Gosub CUM_LOADD
    Endif
    If ([M:OPSC]OWP = 2 & [F:OPS]OPSSTA = 2)
        WLOA = ([F:OPS]EXTSETTIM * [F:OPS]SETLABCOE) + ([F:OPS]EXTOPETIM * [F:OPS]OPELABCOE)
        If [F:OPS]TIMUOMCOD = 2 : WLOA /=60 : Endif
        WTYP = 2
        Gosub CUM_LOADD
    Endif
   If (([M:OPSC]OWS = 2 & [F:OPS]OPSSTA = 3) &
&       ((find([M:OPSC]MRPFLG,1,3) & [F:OPS]OPSTYP = 2) | (find([M:OPSC]MRPFLG,2,3) & [F:OPS]OPSTYP = 1)))
       WLOA = ([F:OPS]EXTSETTIM * [F:OPS]SETLABCOE) + ([F:OPS]EXTOPETIM * [F:OPS]OPELABCOE)
       If [F:OPS]TIMUOMCOD = 2 : WLOA /=60 : Endif
       WTYP = 3
       Gosub CUM_LOADD
   Endif
Endif
Return

#-------------------------------------------------------------
$CUM_LOADD
# Issue 102692 - 2014-09-17 by JUSYN : Considers now holidays and weekends to display a better average of the load
Local Decimal WLOADP
Local Decimal WLOADD
Local Integer K

WLOADD = 0

If I > 0
    WLOA  = WLOA/I
    WDTE  = [F:OPS]OPESTR
    While WDTE <= [F:OPS]OPEEND
        If WDTE >= WDATD(0)
            For J = 0 To [M:OPSC]PERNBR-1
                # Issue 102692 - 2014-09-17 by JUSYN : Considers now holidays and weekends to display a better average of the load.
                #If WDTE >= WDATD(J) & WDTE <= WDATF(J)
                #    Case WTYP
                #        When 1 : WCRGF(J) += WLOA
                #        When 2 : WCRGP(J) += WLOA
                #        When 3 : WCRGS(J) += WLOA
                #    Endcase
                #    WCRGT(J) += WLOA    # FQ 53994 Charge Totale
                #    Break
                #Endif
                If WDTE = WDATD(J)
                  K = func GET_PERWRKNBR(WDATD(J), WDATF(J))
                  WLOADP = WLOA * K
                  WLOADD = 0
                Endif
                If WDTE >= WDATD(J) & WDTE <= WDATF(J) & WCRGM(J) <> 0
                    If WLOADD < WLOADP
                      Case WTYP
                          When 1 : WCRGF(J) += WLOA
                          When 2 : WCRGP(J) += WLOA
                          When 3 : WCRGS(J) += WLOA
                      Endcase
                      WCRGT(J) += WLOA    # FQ 53994 Charge Totale
                      WLOADD += WLOA
                    Endif
                    Break
                Endif
            Next J
        Endif
        WDTE += 1
    Wend
Endif
Return

############################################################
Subprog AV_MFGFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = GFCY
Endif
End
############################################################
Subprog AS_MFGFCY(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog C_MFGFCY(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog AM_PERCOD(VALEUR)
Variable Integer VALEUR
Case VALEUR
  When 1 : [M:OPSC]PERNBR = 30
  When 2 : [M:OPSC]PERNBR = 15
  When 3 : [M:OPSC]PERNBR = 12
Endcase
Affzo [M:OPSC]PERNBR
End
############################################################
Subprog AV_PERNBR(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0
  Case [M:OPSC]PERCOD
    When 1 : VALEUR = 30
    When 2 : VALEUR = 15
    When 3 : VALEUR = 12
  Endcase
Endif
End

########################################
Subprog AM_WCRSTR(VALEUR)
Variable Char    VALEUR()
[M:OPSC]WCREND = VALEUR
End

########################################
Subprog AM_WSTSTR(VALEUR)
Variable Char    VALEUR()
[M:OPSC]WSTEND = VALEUR
End

########################################
Subprog S_WSTSTR(VALEUR)
Variable Char    VALEUR()
Filter [F:MWS] Where WCRFCY = [M:OPSC]MFGFCY
Call SELECT("MWS","",[M:OPSC]MFGFCY,"") From SELOBJ
Filter [F:MWS]
If status = 7 : End
Else
    VALEUR = [F:MWS]WST
Endif
End


########################################
# 15302 09.02 MM
Subprog AM_WSTTYPSTR(VALEUR)
Variable Integer VALEUR
If [M]WSTTYPSTR < VALEUR : [M]WSTTYPEND= VALEUR : Endif
End

########################################
# 15302 09.02 MM
Subprog C_WSTTYPEND(VALEUR)
Variable Integer VALEUR
If VALEUR < [M]WSTTYPEND : GMESSAGE = mess(44,199,1) : Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran OPSG) 29/11/2005 09:10:53 (SR)
######################################################################################
Subprog IB_NBLIGC
End


######################################################################################
## Returns number of workdays within passed period                                  ##
######################################################################################
# Issue 102692 - 2014-09-17 by JUSYN : Considers now holidays and weekends to display a better average of the load.
Funprog GET_PERWRKNBR(LOPESTR, LOPEEND)
Value Date LOPESTR
Value Date LOPEEND

Local Integer WRET, WNBJOP
Local Integer NBPMX : NBPMX = 1000   : # dimension of table periods
Local Integer NBJMX : NBJMX = 2000   : # dimension of table calendar
Local Integer WPERWRKNBR
Local Integer WNBJPER
#
Local Decimal WCAP1(NBJMX)           : # theoretical capacities of period
# Issue 102692 - 2014-10-06 by JUSYN : replaced LOACAP by LOACAPN because of performance; WNBRD as new parameter
Local Integer  NBJCAL   : NBJCAL=1000
Local Integer WNBRD (NBJCAL)
#
#Call LOACAP (LOPESTR,LOPEEND,WCAP1,WRET) From JALLIBB
Call LOACAPN (LOPESTR,LOPEEND,WCAP1,WNBRD,WRET) From JALLIBB

WNBJPER = (LOPEEND-LOPESTR)+1
WNBJOP  = 0

For J = 0 To WNBJPER
    If WCAP1(J) > 0
        WNBJOP += 1
    Endif
Next J
#

WPERWRKNBR = WNBJOP

End WPERWRKNBR

