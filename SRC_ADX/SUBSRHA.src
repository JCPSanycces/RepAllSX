#########################################################################
# Issue X3-44998 - 2017-07-27 by CPO : Duplicated sale documents: analytical dimension not controlled (idem X3SUIVI93839)
$VERIF_CTL_ALLCCE
Local Integer NE
Local Char SAXECTRL(GLONCCE)

  If func AFNC.ACTIV("ANA")>0
    # -------------------------------------
    For I = 0 To [M]NBAXE-1
      If [M]CCE(I) <> "" Then
        nolign = I + 1
        Call C_CCE([M]CCE(I)) From W1SRH2
        If mkstat Then
          OK = 0
          Break
        Endif
      Endif
    Next
    If OK = 0 Then
      Return
    Endif
    #--This control has to be done also during Creation/Update of a document
    For WIJ=0 To [M:SRH1]NBLIG-1
      # -------------------------------------
      For NE = 1 To 20
        If evalue("type([M:SRH1]CCE" + num$(NE) + "(WIJ)) >= 0") Then
          SAXECTRL = evalue("[M:SRH1]CCE" + num$(NE) + "(WIJ)")
          If SAXECTRL <> "" Then
            nolign = WIJ + 1
            #--for the ENAFLG flag
            Call CONTSEL("CCE","!",SAXECTRL,num$(GDIE(NE)),mkstat) From CONTOBJ
            If !mkstat
              Call CTRL_CCE(SAXECTRL, NE, "", GFINRSP, [M:SRH0]ENTRTNDAT) From TRTX3CPT
            Endif
            If mkstat Then
              OK = 0
              GMESSAGE = mess(162,154,1)-[M:SRH1]ITMREF(WIJ)-":"-GMESSAGE
              Break
            Endif
          Endif
        Endif
      Next NE
      If OK = 0 Then
        Break
      Endif
      # -------------------------------------
    Next
    If OK = 0 Then
      Return
    Endif
  Endif

Return
# End issue X3-44998

