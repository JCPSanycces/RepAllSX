#<AdxTL>@(#)10.0.0.0 $Revision$
#@ Check diff -CPO-16/12/13
# Issue X3-80406 - 2018-07-13 by BAKHA : Before we delete the customer return check
#                                        if this document is in any non-conformances.
#                                        When customer return deleted, mark non-conformances
#                                        as document deleted.
# Issue X3-102712 - 2018-07-31 by BAKHA : Disable Non-conformance create/List buttons in Create/Amend mode

#########################################################################
# Contient les traitements des actions appelés par l'objet SUBSRH       #
# Etiquettes                                                            #
#########################################################################
#########################################################################
$DEFTRANS
# Si on ne vient pas de la gestion des retours
If GFONC1 <> "GESSRH" Raz GFLAG Endif

# GRNA 18/05/2011
Local Char CUSSEAPAR : CUSSEAPAR = "TRSCSRET"
Gosub DEFTRANS From CUSSEALIB

Return

#########################################################################
$VARIANTE
# La transaction lu est elle utilisable ?
If clalev ([F:SLT])=0 Local File SALTRS [SLT] Endif
Read [SLT]SLT0=6;[F:AWI]TRN
If fstat
   OK = 0
Elsif [F:SLT]ENAFLG<>2
   OK = 0
Endif
Return

#########################################################################
$SETTRANS

Gosub SETTRANS_DEF

If clalev ([F:SLT])=0 Local File SALTRS [SLT] Endif
Read [SLT]SLT0=6;GFLAG
If clalev ([F:DTR])=0 Local File DIETRS [DTR] Endif
Read [DTR]DTR0="SLT";6;GFLAG;0;0

GSLTSRGWAIFLG  = [F:SLT]SRGWAIFLG
GSLTPRNCOD1    = [F:SLT]PRNCOD1
GSLTPRNNBFLG1  = [F:SLT]PRNNBFLG1

WSLTTRSFAM     = [F:SLT]TRSFAM : Gosub VERIF_TRSFAM From TRTVENSTK
WSLTTRSCOD     = [F:SLT]TRSCOD : Gosub VERIF_TRSCOD From TRTVENSTK

WSLTDOCFLG     = [F:SLT]DOCFLG
WSLTDOCNAM     = [F:SLT]DOCNAM
WSLTUOMSAIFLG  = [F:SLT]UOMSAIFLG
WSLTENTCOD     = [F:SLT]ENTCOD

# Dépôt entête obligatoire ou non (mono-dépôt)
If GWRHACT=2
  GWRHOBY = [F:SLT]WRHOBY
Else
  GWRHOBY = 1
Endif
GSVGWRHOBY = GWRHOBY

#MAE, le 29/01/08, GRP_SITE
GGRPFCY = [F:SLT]GFY

#Close Local File [SLT]
Close Local File [DTR]
Return
#-------------------------------------------------------------
# Afin d'être appelé dans ouvre pour ne pas planter en import
$SETTRANS_DEF

If dim(GSVGWRHOBY)   <=0 : Global Integer  GSVGWRHOBY    : Endif

If dim(GSLTSRGWAIFLG)<=0 : Global Shortint GSLTSRGWAIFLG : Endif
If dim(GSLTPRNCOD1)  <=0 : Global Libelle  GSLTPRNCOD1   : Endif
If dim(GSLTPRNNBFLG1)<=0 : Global Shortint GSLTPRNNBFLG1 : Endif

If dim(WSLTTRSFAM)   <=0 : Local  Char     WSLTTRSFAM(GLONADI) : Endif
If dim(WSLTTRSCOD)   <=0 : Local Char      WSLTTRSCOD(GLONADI) : Endif

If dim(WSLTDOCFLG)   <=0 : Local Shortint  WSLTDOCFLG          : Endif
If dim(WSLTDOCNAM)   <=0 : Local Char      WSLTDOCNAM(GLONARP) : Endif

If dim(WSLTUOMSAIFLG)<=0 : Local Shortint  WSLTUOMSAIFLG : Endif
If dim(WSLTENTCOD)   <=0 : Local Char      WSLTENTCOD(GLONGAU) : Endif

Return
#########################################################################
$OUVRE
Raz GSOC_ACTIVE
#-----------------------------------#
# Sauvegarde des variables globales #
#-----------------------------------#
Gosub SAUV_GLOB From TRTX3GLOB

If GIMPORT Gosub SETTRANS_DEF Endif

Global Integer  GSTASEL1
Global Char     GNUM(GLONVCR)  : # N° DE RETOUR
Global Integer  GAUZRET        : # Flag autorisation des retours
Global Shortint GETATCEE       : # Flag etat appartenant à la CEE
Global Shortint GRELITSRH      : # GRELITSRH = 1 pour relire le retour

Global Shortint GXLOT          : # GXLOT=1 Liv mono-lot / GXLOT=2 Liv multi-lot

#--CPO 75115 Nouveau champ SRHTYP
Global Char     GCPTENDNBR (GLONANM) : # Compteur no xx (Retour définitif)
If clalev([F:TRE])=0 : Local File TABSRHTYP [TRE] : Endif

Local  Decimal  WLIVTTC        : # En livraison TTC
Local  Decimal  WCDEHT         : # En commande HT
Local  Decimal  WCDETTC        : # En commande TTC

Local Char      CODE (3)
Local Integer   RETOUR
Local Integer   WPICK
Local Shortint  IBOX
Local Shortint  DKSOK            # RMA * 85785

Raz GRELITSRH
GDLVTYP = 1

If !clalev([F:TCA])  Local File TABCOUAFF  [TCA] Endif

If !clalev([F:GCM])  Local File GACM       [GCM] Endif

# 40127 : Return status management
If !clalev([F:SDD1]) Local File SDELIVERYD [SDD1]  Endif
# 40127

#-----------------------------------------------------------#
# Chargement flag autorisation des retours                  #
#-----------------------------------------------------------#
Local Char WPARAM(10)
Call PARAMUTIL("SAUZRET",WPARAM,"","") From SUBAUS
GAUZRET=val(WPARAM)
If GAUZRET=0 GAUZRET=1 Endif

GFCY=GFCYDEF(7)
# Ctrl site par défaut par rapport au critère, si aucun site par défaut, charge le 1er site correspondant au critere
Call GETFCYDEF(GFCY,"[F:FCY]WRHFLG=2") From TRTX3
# Chargement globales référenciels, comptes et sections de la société
Gosub CHARG_PARAM : If GERR=1 OK=0 : Return Endif

#--CPO 107883 Issue revealed by RMA 24/04/2015
##--CPO 75115 Recherche du compteur en fonction du SRHTYP
#Gosub REC_CPT_RET From SUBSRH
#If GERR=1 OK=0 : Return Endif

# Récupération des paramètres vente du site / de la société
Call GLOBVAR(GFCY,"VEN") From TRTX3
GORITITCOL=1
Call GLOBSTOFCY(GFCY) From TRTVENGLOB

# C'est une fonction vente qui travaille sur un site d'expédition
# On surcharge donc le site par défaut du module avec celui d'expédition
# pour que les contrôles d'autorisation des sites soient corrects.
GFCYDEF(0) = GFCYDEF(7)

# --- Déclaration classe ecran pour les encours --- #
Local Mask ORDK   [ORDK]

# v6 affectations
Gosub OPEN_MTO From MTOLINKLIB

If !clalev ([F:FCY]) : Local File FACILITY   [FCY] : Endif
#-----------------------------------------------------------#
# Si module achat                                           #
# Fichiers : Retour fsseur entête, Retour fsseur détail     #
#-----------------------------------------------------------#
If GMODU(6)=2 : # Module achat actif
  If clalev([F:PNH]) =0 Local File PRETURN    [PNH]  : Endif : # Retour fsseur entête
  If clalev([F:PND]) =0 Local File PRETURND   [PND]  : Endif : # Retour fsseur détail
  If clalev([F:PTD]) =0 Local File PRECEIPTD  [PTD]  : Endif : # réception détail
  If clalev([F:POQ]) =0 Local File PORDERQ    [POQ]  : Endif
Endif

# Si présence module Support Client, gestion du parc client
If GMODU(12)=2
    If !clalev ([M:MACW]) : Local Mask MACW [MACW] : Endif
Endif

# Déclaration des fenêtres d'adresse
# Bug 70949
#Local Mask ADRBPC [ADB2]
If clalev([M:ADB2])=0
    Local Mask ADRBPC [ADB2]                     : # Déclaration de l'écran d'adresse ADB1
Else
  If !clalev([M:ADBQ])
    Local Mask ADRBPC [ADBQ] : [M:ADBQ]=[M:ADB2] : # Sauvegarde de l'adresse ADB2 à cause de la navigation
  Endif
Endif
# Bug 70949

#-------------------------#
# Ouverture masques stock #
#-------------------------#
#-- Ecran stockage mvt du document
If !clalev([M:ENTW])
    Local Mask STOENTW  [ENTW]
#    Raz [M:ENTW]
    [M:ENTW]WZONPCU    = "SAU"
    [M:ENTW]WZONQUC    = "QTY"
    [M:ENTW]WZONCCS    = "SAUSTUCOE"
    [M:ENTW]WZONQUS    = "QTYSTU"
    [M:ENTW]WZONSTOUPD = "WSTOUPD"
Endif
#-- Ecran de travail enreg mvt du document
If clalev([M:STW])=0 Local Mask STOWORK   [STW]  : Endif
Raz [M:STW]
If !clalev([M:SVW]) : Local Mask STOVALWORK [SVW] : Endif
If !clalev([M:SVWD]) : Local Mask STOVALWORK [SVWD] : Endif
# Issue 80482 - 2012-04-24 by CCC : Le détail de prix n'était pas renseigné
If clalev([M:VALW])<=0 : Local Mask STOVALW [VALW] : Endif

#--CPO 94689 Intrastat for Customer returns with nil quantity
If func AFNC.ACTIV("DEB")>0
  If clalev([F:DEB]) =0 Local File DEB [DEB]  : Endif
  Global Integer GMODMSDGFORDEB : GMODMSDGFORDEB = 1
Endif
#--/

Gosub STK_INILOC From STKLOC

# FGR 28/07/2015 : X3SUIVI108078 : Optimisation (début)
  Link [SRD] With [ITM]ITM0=[F:SRD]ITMREF,
&                 [ITU]ITU0=[F:SRD]ITMREF;[F:SRH]BPCORD
&              As [LSRD]
# FGR 28/07/2015 : X3SUIVI108078 : Optimisation

Gosub DECLARE From TABLEAUX

# BRBAN 28-06-2014 SAM 93745 US2
If func AFNC.ACTIV('DKS')>0
  If clalev([F:PTDKD])=0 : Local File DKSDATA [PTDKD] : Endif
Endif

Return

#########################################################################
$OUVRE_BOITE

# Récupération des noms de currbox des tiroirs
Global Char     GBOXSD2(10), GBOXPN1(10)
Global Char     GBOXSD5(10)                           # X3-1152 : Non invoiceable deliveries

GBOXSD2 = "GAU_CHE" +num$(find("SD2",OBJLIS(1..8)))
GBOXPN1 = "GAU_CHE" +num$(find("PN1",OBJLIS(1..8)))
GBOXSD5 = "GAU_CHE" +num$(find("SD5",OBJLIS(1..8)))   # X3-1152 : Non invoiceable deliveries

Return
####################################################################
$FERME
Raz GORITITCOL

# Bug 70949
# --- Restitution des écrans d'adresse à cause de la navigation -----#
If clalev([M:ADBQ]) & clalev([M:ADB2])
  [M:ADB2]=[M:ADBQ] : Close Local Mask [ADB2]
Endif
# Bug 70949

#------------------------------------#
# Restitution des variables globales #
#------------------------------------#
Gosub REST_GLOB From TRTX3GLOB
#-- effacement icone texte
If !GIMPORT : Call RESET_IMAGE (4) From GESECRAN : Endif

#--CPO 94689 Intrastat for Customer returns with nil quantity
If func AFNC.ACTIV("DEB")>0 and dim(GMODMSDGFORDEB)>0
  Kill GMODMSDGFORDEB
Endif
#--/
  Gosub PJM_TECALLITM_FREEGROUP From SUBSDHA  # Issue X3-31898 - 2017-11-17 by FGR
Return

#########################################################################
$FILTRE
Default File [SRH]
#-- On n'accède pas aux retours de prêt
#--CPO 82362 Pas de retour de prêt ni de sous-traitance
#FILTSUP = "[F:SRH]LNDRTN <> 2"
FILTSUP = "[F:SRH]LNDRTN <> 2 & [F:SRH]SCORTN <> 2"

Return

####################################################################
$SETBOUT

# Si l'on vient d'ailleurs, suppression des accès aux autres enregistrements
If GFONC1 <> "GESSRH"
   Call VIREBOUT(CHAINE,"RCD<>S09") From GOBJET
Endif
# Suppression boutons changement de code / duplication
Call VIREBOUT(CHAINE,"DH") From GOBJET
# Suppression bouton supprimer si le retour a fait l'objet d'un avoir
If sum([M]SIHNUM) <> ""
   Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
# ------------------------------------------------------------------------------------- #
# Activation/Désactivation des menus                                                    #
# ------------------------------------------------------------------------------------- #
#   D,E : Texte              : Actif si ret.en ligne ou création ou duplication         #
#     F : Adresse            : Actif si ret.en ligne ou création ou duplication         #
#     G : Crit. picking      : Actif si client et site renseignés                       #
#                                    si modif, il faut avoir des droits de modif        #
#     M : Info douanières    : Actif si retour en ligne                                 #
#     P : Transaction                                                                   #
#     N : Traçabilité pièces                                           SYMEU 08/12/2008 #
# ------------------------------------------------------------------------------------- #
# Création ou dupplication ou clé courante
If GREP="C" | GREP="D" | CLECUR CHMEN += "DEF" Endif
If CLECUR : CHMEN += "M" : Endif
CHMEN += "P"
If ([M]BPCORD<>"" | COUZON="BPCORD" & CZ<>"") & [M]STOFCY<>""
    If GREP<>"C"
        GBIDC2="M": GFCY=[M]STOFCY : Gosub AUTORIS_OPT From CONTX3
        If GBIDI2 CHMEN+="G" Endif
    Else
        CHMEN+="G"
    Endif
Endif
#Modif CRM 25/09/2003
#Parc client
If REP="" & GMODU(12)=2
    CHMEN += "7"
Endif

If !find(GREP,"C","D") and !find("CONSPIV",GNAVIG(1..GPILNAV)) Then CHMEN += "N" Endif # SYMEU 08/12/2008 : branchement traçabilité pièces

# 78411 Sage Exchange
#If CLECUR & GREP="" & func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC_SRH()  ## 101049.o
If CLECUR & GREP="" & func AFNC.ACTIV("SEPP") # now always enable the menu and check payment method when pressed in TRTSEAUTH ## 101049.n
  #If the payment method has Sage Exchange turned on - enable the menu
  If !instr(0,CHMEN,"S") : CHMEN += "S" : Endif
Endif

#85785
If GREP<>"" | !CLECUR
  Call VIREBOUT(CHAINE,"1") From GOBJET
Endif
If [M:SRH0]STOFCY <> ""
  If func PORLEGLIB.DIGSIGN([M:SRH0]STOFCY, "") <> 1
    Call VIREBOUT(CHAINE,"1") From GOBJET
  Endif
Endif
If dim([M:SRH0]SRHCFMFLG)>0
  If [M:SRH0]SRHCFMFLG = 2
    Call VIREBOUT(CHAINE,"A1") From GOBJET
  Endif
Endif
# BRBAN 28-07-2014 SAM 93745 US2
If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([M:SRH0]STOFCY,'')=1
  If [M:SRH0]SRHCFMFLG = 2 & GREP = "" & [M:SRH0]SRHNUM <> "" & func PORLEGLIB.DOCCTR(3,[F:BPC]BPCNUM,[F:SRH]SRHTYP,[F:SRH]STOFCY)=1
    Read [F:PTDKD]DKD0 = "SAFT-PT";[M:SRH0]SRHTYP;[M:SRH0]SRHNUM
    # BRBAN 24-03-2015 #106027
    If !fstat & [F:PTDKD]ATDTCOD = "" & func PORLEGLIB1.CTRL_COMDAT([F:SRH]STOFCY,[F:SRH]DPEDATR,[F:SRH]ETDR) = 1
      CHMEN+='U'
    Endif
  Endif
Endif

# Issue X3-77854 - 2018-04-24 by JUSYN : Activate Non-conformance creation button
If func AFNC.ACTIV("NCS") and [M:SRH0]SRHNUM <> "" Then
    # Issue X3-102712 - only enable create if not in create/amend/delete/duplicate mode
    If (!find (GREP, "C","D","M","A"))
      CHMEN += "O"
    Endif
    # Enable List if not IN Create mode
    If (!find (GREP, "C","D"))
      CHMEN += "V"
    Endif
Endif
# End issue X3-77876

Gosub SET_BOUT_SPE From GSAISIE

Return
#########################################################################
# Avant éxécution des boutons et menus
#########################################################################
$AVANTBOUT
Local Char    WFONC1(30)
Local Integer I, WLIG, WCOD, WMODULE
Local Char    WTYP(4), WTEX(12), SYMBOLE2(50)

GERR=0
WMODULE = 5
Case BOUT
 When "D" :   If [M]SRHNUM = "" & GREP <> "C" & GREP <> "D"        : # Texte entete
#                 GMESSAGE est à blc, il faut positionner ERR
                  GERR = 1 : GMESSAGE= "" : Return
              Endif
 When "E" :   If [M]SRHNUM = "" & GREP <> "C" & GREP <> "D"        : # Texte pied
#                 GMESSAGE est à blc, il faut positionner ERR
                  GERR = 1 : GMESSAGE= "" : Return
              Endif
 When "F" :   [M]CNTNAM=[M:ADB2]CNTNAM                             : # Adresse livraison
 When "1" : If [M:SRH0]SRHNUM = "" | [M:SRH0]STOFCY = ""           #85785
              OK = 0 : Return
            Else
              If func PORLEGLIB.DIGSIGN([M:SRH0]STOFCY, "") <> 1
                OK = 0 : Return
              Endif
            Endif
Endcase
Return
###########################################################################################
# A SUPPRIMER
#$AVTBOUT_TEXTE
#---------------------------------------------------#
# OPTION : Gestion des textes entete et pied        #
#---------------------------------------------------#
#Local Integer WRETOUR
#Local Char    WNUMTEX(12), WCLE1
#WRETOUR = 0
#WNUMTEX = WTEX
#If GREP <> "C" WCLE1 = [M]SRHNUM : Endif
#Return
###########################################################################################
#    Après execution des menus                                                            #
###########################################################################################
$STATUT

Case BOUT
    When "D"     : If mkstat=4 & GREP=""            : # Texte entete
#                      GREP="M" : REP="M"
#                      Gosub SETBOUT From GOBJSUB
                       Gosub ENTRE_MODIF From GOBJSUB
                   Endif
                   If [M]SRHTEX1 <> "" & !GIMPORT
                       Call SET_IMAGE (4) From GESECRAN
                   Elsif !GIMPORT
                       Call RESET_IMAGE (4) From GESECRAN
                   Endif
    When "E"     : If mkstat=4 & GREP=""            : # Texte entete
#                      GREP="M" : REP="M"
#                      Gosub SETBOUT From GOBJSUB
                       Gosub ENTRE_MODIF From GOBJSUB
                   Endif
                   If [M]SRHTEX2 <> "" & !GIMPORT
                       Call SET_IMAGE (4) From GESECRAN
                   Elsif !GIMPORT
                       Call RESET_IMAGE (4) From GESECRAN
                   Endif

    When "F"    :  If [M:ADB2]ADBFLG = 2 | [M]CNTNAM <> [M:ADB2]CNTNAM
                       If GREP <> "C" & GREP <> "M" & GREP <> "D"
                          Gosub MAJADRESSE          : # Adresse client livré
                       Endif
                       If [M:ADB2]BPRNAM(0) <> ""
                          [M:SRH0]BPDNAM = [M:ADB2]BPRNAM(0)
                          Affzo [M:SRH0]BPDNAM
                       Endif
                   Endif
    When "G"    :  Gosub TIROIR From SUBSRHC         : # Critères picking
    When "M"    :  If mkstat=4 & GREP=""             : # Informations CEE
#                      GREP="M" : REP="M" : # Pour forcer le bouton 'enregistrer'
                       Gosub ENTRE_MODIF From GOBJSUB
                   Endif
     When "U"
       # BRBAN 25-07-2014 SAM 93745 US2 - Update ATDTCOD
       If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([M:SRH0]STOFCY,'')=1
         Read [F:PTDKD]DKD0='SAFT-PT';[F:SRH]SRHTYP;[F:SRH]SRHNUM
         If !fstat & [F:PTDKD]ATDTCOD <> ''
          [M:SRH2]ATDTCODR = [F:PTDKD]ATDTCOD
          Affzo [M:SRH2]ATDTCODR
          Diszo [M:SRH2]ARVDATR,DPEDATR,ETDR,ETAR,LICPLATER,TRLLICPLATER
          Diszo [M:SRH2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR,ATDTCODR,MANDOCR,GLBDOCR
         Endif
       Endif
Endcase

Return
###########################################################################################
# 87368
#######################################################################
# Après exécution d'une action et avant l'exécution de l'action suite #
#######################################################################
$AVANT_SUITE
Case BOUT
  When "F" :  # After execution Adresse and before execution recalculate prices
    # Not trigger recalculate prices if globale not informed
    OK=0
Endcase
Return
# 87368
#########################################################################
$APRES_MODIF

# Pour l'activation/désactivation de l'option critère picking
If find (COUZON,"STOFCY","BPCORD") Gosub SETBOUT From GOBJSUB : Endif

# On vient de modifier une ligne de retour maj en stock
If GRELITSRH = 1
   Raz GRELITSRH
   Gosub RELIT From GOBJSUB
   OK = 0
Endif

If find(COUZON,"STOFCY","BPCORD","BPAADD","AUZUSR")
   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   If COUZON="BPCORD" [M:SRH0]BPCORD=CZ Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   If COUZON="BPAADD" [M:SRH0]BPAADD=CZ Endif : # Particularité sur ce chps pour que FILGAUCHE fonctionne
   Gosub TIROIR From SUBSRHC
Endif

#RMA * 85785
If find(COUZON, "ENTRTNDAT", "QTY", "QTYEXT", "PRIORD", "NETPRINOT")
   [L]DKSOK = 0
Endif

Return
####################################################################
$VERIF_CRE
Gosub VERIF

Return

####################################################################
$RAZCRE

#If GFCYDEF(5)<>""
#    If GFCY<>GFCYDEF(5)
#        Call GLOBVAR(GFCYDEF(5)) From WWGLOBVEN
#        GFCY=GFCYDEF(5)
#    Endif
#Elsif GFCYDEF(7)<>""
#    If GFCY<>GFCYDEF(7)
#        Call GLOBVAR(GFCYDEF(7)) From WWGLOBVEN
#        GFCY=GFCYDEF(7)
#    Endif
#Endif
If GFCY<>GFCYDEF(7)
    GFCY=GFCYDEF(7)
    #------------------------------------------------------------------------#
    # Chargement site stock par défaut                                       #
    # Chargement globales référenciels, comptes et sections de la société    #
    # Récupération des paramètres stock du site / de la société              #
    # -----------------------------------------------------------------------#
    # Ctrl site par défaut par rapport au critère, si aucun site par défaut, charge le 1er site correspondant au critere
    Call GETFCYDEF(GFCY,"[F:FCY]WRHFLG=2") From TRTX3
    Gosub CHARG_PARAM : If GERR=1 OK=0 : Return Endif
    Call GLOBSTOFCY(GFCY) From TRTVENGLOB
Endif
[M:SRH0]STOFCY    = GFCY
#--CPO 75115 Init et recherche du compteur en fonction du SRHTYP
Local Char WSRHTYP(GLONTRE) : Local Integer  WSRHCAT
Gosub SRHTYP From SUBSRH
[M:SRH0]SRHTYP=WSRHTYP : [M:SRH0]SRHCAT=WSRHCAT

Gosub REC_CPT_RET From SUBSRH
If GERR=1 OK=0 : Return Endif

#--CPO X3Suivi 75115 Libellé Catégorie --#
[M:SRH0]WSRHCAT = mess(8,105,1) - ':' - mess([M:SRH0]SRHCAT,493,1)
#--

# Affichage entêtes colonnes variables (comptes et sections analytiques)
Gosub AFF_TITCOL
# Récupération des paramètres vente du site / de la société
Call GLOBVAR(GFCY,"VEN") From TRTX3

[M:SRH0]ENTRTNDAT = date$
[M:SRH2]AUZUSR    = GUSER

#If dim([M:SRH0]EECNAT)>0
#   [M:SRH0]EECNAT = "011"
#   If GDEBGBR=1 [M:SRH0]EECNAT="20" Endif
#   [M:SRH0]EECSCH = "11"
#Endif

# -- gestion des textes
Call RAZ_CLOB From ACLOB
Raz [M:SRH0]SRHTEX1, [M:SRH0]SRHTEX2

If !GIMPORT : Call RESET_IMAGE (4) From GESECRAN : Endif

[M:SRH0]TRSCOD = WSLTTRSCOD
[M:SRH2]TRSFAM = WSLTTRSFAM
[M:SRH0]ENTCOD = WSLTENTCOD

# Effacement des masques adresses
Raz [M:ADB2]

# Gestion de l'état des zones
Gosub ETAT_ZONE

# GRNA 18/05/2011
Local Char CUSSEAORI : CUSSEAORI = "SRH0"
Gosub RAZCRE From CUSSEALIB

Affzo [M:SRH0]1-99
Affzo [M:SRH1]1-99
# Ne pas afficher tt l'écran car l'init des sections ana. ne doit se faire qu'après saisie du client
Affzo [M:SRH2]TRSFAM, AUZUSR

# Remplissage des boites de picking
Gosub REMPBOX From SUBSRHC

If dim([M:SRH1]WRHE)>0
   Call WRHINIT([M:SRH1]WRHE,[M:SRH0]STOFCY,4) From STKWRH
Endif
# Actzo ou Grizo des dépôts selon le site
Gosub WRH_ETAT

#--CPO 94689 Intrastat for Customer returns with nil quantity
If func AFNC.ACTIV("DEB")>0 and dim(GMODMSDGFORDEB)>0
  Raz GMODMSDGFORDEB
Endif
#--/

#RMA * 85785
If dim([M:SRH0]SRHCFMFLG) > 0
  Chgfmt [M:SRH0]SRHCFMFLG   With "-LA1:15X"
Endif

Return

####################################################################
$INICRE

If dim([F:SRH]CPY)>0 : [F:SRH]CPY=GSOCIETE : Endif

# -- Raz variable utilisée pour la maj des mvts clients
Raz WCDEHT, WCDETTC, WLIVTTC

# -- Alimentation date retour entête
[F:SRH]RTNDAT = [M]ENTRTNDAT

# -- Alimentation flag "retour prêt" à NON
[F:SRH]LNDRTN = 1

# Alimentation dépôt entête si mono-dépôt
If dim([M:SRH1]WRHE)>0 & GWRHOBY=2
  [F:SRH]WRHE = [M:SRH1]WRHE
Else
  [F:SRH]WRHE = ""
Endif

# -- Récupération du compteur de retour
If  GMANCOU <> 2 | (GMANCOU=2 & vireblc([M:SRH0]SRHNUM,2)="")
    Call NUMERO (GCPT,[F:SRH]STOFCY,[F:SRH]RTNDAT,"",GNUM,STAT) From SUBANM
    If GOK<0 Return Endif
    If STAT = 0
        [F:SRH]SRHNUM  = GNUM
        [M:SRH0]SRHNUM = GNUM
        Affzo [M:SRH0]SRHNUM
    Else
       # problème lors de la récupération du compteur
       GERR=1 : GMESSAGE=mess(60,199,1)
       GOK = 0
    Endif
Endif
Gosub INITXC

# Chargement adresses libres
Gosub CHARGEADR

# Initialisation Nature et Régime CEE
#  supprimer le contenu sauf si import
If !GIMPORT : Raz [F:SRH]EECNAT : Raz [F:SRH]EECSCH : Endif
#If dim([F:SRH]EECNAT)>0 : # Bug 73295
If GACTDEB=2             : # Bug 73295
   Call INICRE_EEC("SRH",GBIDI2,[F:SRH]EECNAT,[F:SRH]EECSCH,GBIDI3,GBIDC2,GBIDC3) From FUNDEBA
Endif

Return
#########################################################################
$INITXC

If [M:SRH0]SRHTEX1<>""
   If left$([M:SRH0]SRHTEX1,3)="SRH"
      Call CRE_CLOB([M:SRH0]SRHTEX1,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Elsif left$([M:SRH0]SRHTEX1,3)<>"BPC"
      Call DUP_CLOB("SRH",[M:SRH0]SRHTEX1,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Endif
   [F:SRH]SRHTEX1 = [M:SRH0]SRHTEX1
Endif
If [M:SRH0]SRHTEX2<>""
   If left$([M:SRH0]SRHTEX2,3)="SRH"
      Call CRE_CLOB([M:SRH0]SRHTEX2,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Elsif left$([M:SRH0]SRHTEX2,3)<>"BPC"
      Call DUP_CLOB("SRH",[M:SRH0]SRHTEX2,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Endif
   [F:SRH]SRHTEX2 = [M:SRH0]SRHTEX2
Endif
Return
####################################################################
$CREATION

# -- Enregistrement des lignes du tableau
Gosub CREATION From TABLEAUX
If  GOK<1 : Return : Endif
#------------------------------------#
# Mise à jour des mouvements clients #
#------------------------------------#
# Maj du n° dernier retour
Call  MAJMVC ([F:SRH]BPCORD, "", 0, 0, [F:SRH]RTNDAT, [F:SRH]SRHNUM, [F:SRH]STOFCY,
&             0, 0, "+", "R", GREP, 0) From TRTBPMVT
If GOK<1: Return: Endif
If WLIVTTC <> 0
   # -- Maj mouvement client (en-cours livraison)
   Call MAJMVC ([F:SDH]BPCORD, [F:SDH]CUR, [F:SDH]CHGTYP, 0, [F:SDH]SHIDAT, [F:SDH]SDHNUM, [F:SDH]SALFCY,
&               0, WLIVTTC, "-", "D", "", [F:SDH]LND) From TRTBPMVT
   If  GOK<1 : Return : Endif
Endif
# Maj des statistiques
Call VALSTA("SRH",1) From SUBPS2
If GOK < 1 : Return : Endif

# FGR 04/01/2011 : X3SUIVI70100 (début) c'est mieux dans la transaction
# Si présence module Support Client, gestion du parc client
#If GMODU(12)=2                                           : # Bug 84870 : Pas de gestion du parc si inter-site
If GMODU(12)=2 & !([F:SRH]BETFCY=2 & [F:SRH]BETCPY<>2)    : # Bug 84870
  Gosub TRT_MACRULE From SUBSRH
  If GOK < 1 : Return : Endif  # ... et ajout de la gestion d'erreur
Endif
# FGR 04/01/2011 : X3SUIVI70100 (fin) c'est mieux dans la transaction

  # -------------------------------------------------
  # Issue X3-31898 - 2017-11-17 by FGR : BEGIN
  Gosub PJM_TECALLITM From SUBSDHA
  If GOK < 1 : Return : Endif
  # Issue X3-31898 - 2017-11-17 by FGR : END
  # -------------------------------------------------

Gosub DEVERROU_PICKING

#85785 * RMA
##--CPO for RMA Issue 75115 Digital signature of shipments and customer returns
## ----------------------------------------------------------- #
## Digital signature of shipments and customer returns         #
## ----------------------------------------------------------- #
#If func AFNC.ACTIV("DKS") & func AFNC.PARAM("PORDKS",[F:SRH]CPY)="2"
#  Gosub DIGSIGN
#Endif
## ----------------------------------------------------------- #

Return

####################################################################
$ABANDON

Gosub DEVERROU_PICKING

# A SUPPRIMER
#----- suppression des textes si abandon en dupli ou creation --#
#Local Integer I, WRETOUR : WRETOUR = 0
#Local Char    WNUMTEX (12)
#If GREP ="C"
#    WNUMTEX = [M]SRHTEX1
#    Call TEX(5,"SRH1","","","",WNUMTEX,"A",WRETOUR) From TRTX3TEX
#    WNUMTEX = [M]SRHTEX2
#    Call TEX(5,"SRH2","","","",WNUMTEX,"A",WRETOUR) From TRTX3TEX
#Endif
#--- suppression des textes sur la ligne ---#
#For I = 0 To [M]NBLIG -1
#    If GREP ="C" | (REP="M" & [M]CREFLG(I) = 0)
#        WNUMTEX = [M]SRDTEX (I)
#        Call TEX(5,"SRD1","","","",WNUMTEX,"A",WRETOUR) From TRTX3TEX
#    Endif
#Next I

Local Integer I, WRET
If sum([M:SRH1]DETSDHNUM)<>""
   For I=0 To [M]NBLIG-1
      If [M:SRH1]DETSDHNUM(I)<>"" & [M:SRH1]CREFLG(I)=0
          If left$([M:SRH1]SRDTEX(I),3)="SRD"
             Call SUP_CLOB([M:SRH1]SRDTEX(I),WRET) From TRTX3TEX
          Endif
      Endif
   Next I
Endif

Call RAZ_CLOB From ACLOB

  Gosub PJM_TECALLITM_FREEGROUP From SUBSDHA  # Issue X3-31898 - 2017-11-17 by FGR

# Remise à 0 de l'écran STOENTW
Call DELSTOENTW (-1,-1,"SRH1",1,1,[M:SRH0]STOFCY,1,"") From STKENT
Actzo [M:SRH0]SRHNUM
If GREP="C"
   Raz GREP
   Gosub REMPBOX From SUBSRHC
Endif

Return
####################################################################
$APRES_CRE
Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)

# -- Régularisation des manquants et alloc
Call REGFROMENT(0,"SRH1","[M:SRH1]CREFLG(I)=0","ITMREF",[M:SRH0]STOFCY) From TRTSHTCOM

# FGR 04/01/2011 : X3SUIVI70100 (début) déplacé dans la transaction
# Si présence module Support Client, gestion du parc client
#If GMODU(12)=2
#   Gosub TRT_MACRULE From SUBSRH
#Endif
# FGR 04/01/2011 : X3SUIVI70100 (fin) déplacé dans la transaction

# -- Impression du bon de retour
If !GIMPORT & !GWEBSERV & WSLTDOCFLG = 2
    Gosub SET_CLE From GOBJSUB
    CLECUR = 1
    Call ETAT(WSLTDOCNAM,"GESSRH",TBPAR,TBVAL) From ETAT
Endif

# Vide la table de travail de la gestion des emplacements
Local Integer WRET
Call STKDELRES(0,[M:SRH0]STOFCY,"",WRET) From STKLOC

# -- Impression des étiquettes -----#
If GSLTPRNCOD1>1 & sum([M:SRH1]RTNSTOUPD) > [M:SRH1]NBLIG
    Local Char    LCRIT(250)
    Local Char WPARAM(GLONVCR)(1..4) , WVALEUR(10)
    Local Integer WCREATION
    WPARAM(1) = [M:SRH0]STOFCY
    WPARAM(2) = num$(13)
    WPARAM(3) = [M:SRH0]SRHNUM
#                                                                                           # hcb X3-91077 - X3-92342 deb
#   Call TRAITE_CHAR(WVALEUR,WPARAM,"ISTOLBE","SUBSLP","",4,"SPESLP") From GTRAITE
    Case GSLTPRNCOD1
         When 2 :
           Call TRAITE_CHAR(WVALEUR,WPARAM,"IRCPLBE1","SUBRCPLBE","",4,"SPERCPLBE") From GTRAITE  # Etiquette stock
         When 6 :
           Call TRAITE_CHAR(WVALEUR,WPARAM,"IRCPLBE2","SUBRCPLBE","",4,"SPERCPLBE") From GTRAITE  # Etiquette nouveau contenant
         When 7 :
           If !clalev([F:LPN])  : Local File LPN          [LPN]  : Endif
           Raz WCREATION
           LCRIT   = "STOFCY=[M:SRH0]STOFCY"
           LCRIT  += "&VCRNUM>=[M:SRH0]SRHNUM"
           LCRIT  += "&VCRNUM<=[M:SRH0]SRHNUM"
           LCRIT  += "&PRTFLG <> 2"
           Filter [F:LPN] Where evalue(LCRIT)
&          Order By Key LPN0
           For [LPN]
               WCREATION = 2
               Break
           Next
           Filter [LPN]
           If WCREATION = 2
              Call TRAITE_CHAR(WVALEUR,WPARAM,"IRCPLBE3","SUBRCPLBE","",4,"SPERCPLBE") From GTRAITE  # Etiquette stock et contenant créé
           Else
              Call TRAITE_CHAR(WVALEUR,WPARAM,"IRCPLBE1","SUBRCPLBE","",4,"SPERCPLBE") From GTRAITE  # Etiquette stock
           Endif
         When Default
    Endcase
#                                                                                           # hcb X3-91077 - X3-92342 fin



Endif

Gosub RELIT From GOBJSUB
[M:SRH0]SRHNUM = [F:SRH]SRHNUM

Return

####################################################################
$AB_CRE_MOD

Gosub DEVERROU_PICKING

Affzo [M:SRH1]20

Return

####################################################################
$LIENS
Local Char WSVGGREP(1)

[L]DKSOK = 1 #RMA * 85785

# -- Remise à zéro du masque STOENTW
Call DELSTOENTW (-1,-1,"SRH1",1,1,[M:SRH0]STOFCY,1,"") From STKENT

## -- Réalimentation site fin.(GFINRSP) (GSOCIETE)(GLOCALDEV)
## -- réalimentation param stock : TRSVENRET
#If [F:SRH]SALFCY <> ""
#    If [F:SRH]SALFCY <> GFCY
#        Call GLOBVAR([F:SRH]SALFCY) From WWGLOBVEN
#        GFCY = [F:SRH]SALFCY
#    Endif
#Else
#    If [F:SRH]STOFCY <> GFCY
#        Call GLOBVAR([F:SRH]STOFCY) From WWGLOBVEN
#        GFCY = [F:SRH]STOFCY
#    Endif
#Endif
If [F:SRH]STOFCY <> GFCY
    GFCY = [F:SRH]STOFCY
    #------------------------------------------------------------------------#
    # Chargement globales référenciels, comptes et sections de la société    #
    # Récupération des paramètres stock du site / de la société              #
    # -----------------------------------------------------------------------#
    #Call GETDEV(GFCY)  From DEVSUB
    Gosub CHARG_PARAM : Raz GERR : Raz GMESSAGE
    #--CPO 75115 Recherche du compteur en fonction du SRHTYP
    Gosub REC_CPT_RET From SUBSRH

    Call GLOBSTOFCY(GFCY) From TRTVENGLOB
Endif
# Affichage entêtes colonnes variables (comptes et sections analytiques)
Gosub AFF_TITCOL
# Chargement des sections analytiques entête du document
Call CHARG_CCEH("SRH2","NBAXE","SRH") From TRTX3CPT

# Récupération des paramètres vente du site / de la société
If [F:SRH]SALFCY <> ""
    Call GLOBVAR([F:SRH]SALFCY,"VEN") From TRTX3
Else
    Call GLOBVAR(GFCY,"VEN") From TRTX3
Endif

GBPCNUM = [F:SRH]BPCORD
# -- Alimentation entête
[M]ENTRTNDAT  = [F:SRH]RTNDAT

#-------------------------------------------------------#
# Lecture Client livré   : Alimentation du nom client   #
#-------------------------------------------------------#
If [F:SRH]BPDNAM(0)<>""
    [M:SRH0]BPDNAM = [F:SRH]BPDNAM(0)
Else
    If [F:BPD]BPCNUM <> [F:SRH]BPCORD | [F:BPD]BPAADD <> [F:SRH]BPAADD
       Read [BPD]BPD0 = [F:SRH]BPCORD;[F:SRH]BPAADD
       If fstat : Raz [F:BPD]:Call RSTA("BPD",[F:SRH]BPCORD) From GLOCK : Endif
    Endif
    [M:SRH0]BPDNAM = [F:BPD]BPDNAM
Endif

#---------------------------#
# Alimentation des adresses #
#---------------------------#
[M:ADB2]ADBBPR       = [F:SRH]BPCORD
[M:ADB2]BPAADD       = [F:SRH]BPAADD
[M:ADB2]BPRNAM(0)    = [F:SRH]BPDNAM(0)
[M:ADB2]BPRNAM(1)    = [F:SRH]BPDNAM(1)
[M:ADB2]BPAADDLIG(0) = [F:SRH]BPDADDLIG(0)
[M:ADB2]BPAADDLIG(1) = [F:SRH]BPDADDLIG(1)
[M:ADB2]BPAADDLIG(2) = [F:SRH]BPDADDLIG(2)
[M:ADB2]POSCOD       = [F:SRH]BPDPOSCOD
[M:ADB2]CTY          = [F:SRH]BPDCTY
[M:ADB2]SAT          = [F:SRH]BPDSAT
[M:ADB2]CRY          = [F:SRH]BPDCRY
[M:ADB2]CRYNAM       = [F:SRH]BPDCRYNAM
[M:ADB2]CNTNAM       = [F:SRH]CNDNAM

If [M:ADB2]BPRNAM <> "" | [M:ADB2]BPAADDLIG <> "" |
&  [M:ADB2]POSCOD <> "" | [M:ADB2]CTY <> "" |
&  [M:ADB2]SAT    <> "" |
&  [M:ADB2]CRY    <> "" | [M:ADB2]CRYNAM <> ""
    [M:ADB2]ADBFLG = 3
Else
    [M:ADB2]ADBFLG = 0
Endif

If !clalev ([F:BPA]) : Local File BPADDRESS [BPA] : Endif
If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:SRH]BPCORD | [F:BPA]BPAADD<>[F:SRH]BPAADD
    Read [BPA]BPA0=1;[F:SRH]BPCORD;[F:SRH]BPAADD
    If fstat Raz [F:BPA] Endif
Endif
If !clalev ([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
If [F:TCY]CRY<>[F:BPA]CRY
    Read [TCY]TCY0=[F:BPA]CRY
    If fstat Raz [F:TCY] Endif
Endif
GETATCEE = [F:TCY]EECFLG
# Alimentation pays client livré pour affichage et ctrl n°identification CEE
If [M:ADB2]CRY<>""
    [M:SRH0]EECNUMCRY=[M:ADB2]CRY
Else
    [M:SRH0]EECNUMCRY=[F:BPA]CRY
Endif
# X3-101236 (LCC-23/07/18) Control "EU VAT no"
# The country can be the country of the ship to customer or the country of the bill to customer
Local Char WDUMMY(20)
Call INIEECNUM ([M:SRH0]BPCORD,[M:SRH0]BPAADD,[M:SRH1]BPCINV,WDUMMY,[M:SRH0]EECNUMCRY) From TRTVENDIV
# end X3-101236 (LCC-23/07/18) Control "EU VAT no"

If GFONC1="GESSRH" Call RAZ_CLOB From ACLOB Endif

#--CPO X3Suivi 75115 Libellé Catégorie --#
[M:SRH0]WSRHCAT = mess(8,105,1) - ':' - mess([M:SRH0]SRHCAT,493,1)

# Raz des champs critères picking
Raz [M:SRH0]CRISDHNUM, [M:SRH0]CRIPNHNUM, [M:SRH0]CRIITMREF, [M:SRH0]CRIDLVDAT, [M:SRH0]CRIRTNDAT

# -- Chargement des lignes dans le tableau
Gosub LIENS From TABLEAUX

#------------------------#
# affichage icone texte  #
#------------------------#
If [M:SRH0]SRHTEX1 <> "" | [M:SRH0]SRHTEX2 <> ""
  If !GIMPORT : Call SET_IMAGE (4) From GESECRAN : Endif
Else
  If !GIMPORT : Call RESET_IMAGE (4) From GESECRAN : Endif
Endif

# -- Gestion de l'état des zones
WSVGGREP = GREP : Raz GREP
Gosub ETAT_ZONE
GREP = WSVGGREP

#Affzo [M:SRH1]1-99
# -- Grise les colonnes ne pouvant plus être modifiées
Call STKDISCOL("SRH1",[M]NBLIG) From STKECR

# Remplissage des boites de picking
Gosub REMPBOX From SUBSRHC

# Actzo ou Grizo des dépôts selon le site
GWRHOBY = GSVGWRHOBY
Gosub WRH_ETAT

#--CPO 94689 Intrastat for Customer returns with nil quantity
If func AFNC.ACTIV("DEB")>0 and dim(GMODMSDGFORDEB)>0
  Raz GMODMSDGFORDEB
Endif
#--/
# BRBAN 28/07/2014 SAM #93745 US2
If func AFNC.ACTIV('KPO')>0
  If func PORLEGLIB.DIGSIGN("", [F:SRH]CPY)=1
    Actzo [M:SRH2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR,MANDOCR
    Diszo [M:SRH2]ATDTCODR
    If func PORLEGLIB.DOCCTR(3,[F:SRH]BPCORD ,[F:SRH]SRHTYP,[F:SRH]STOFCY)=1
      If [F:SRH]SRHCFMFLG<>2
        Actzo [M:SRH2]ATDTCODR
      Else
        Read [F:PTDKD]DKD0 = "SAFT-PT";[F:SRH]SRHTYP;[F:SRH]SRHNUM
        If !fstat & [F:PTDKD]ATDTCOD<>''
          Diszo [M:SRH2]ARVDATR,DPEDATR,ETDR,ETAR,LICPLATER,TRLLICPLATER
          Diszo [M:SRH2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR,ATDTCODR,MANDOCR,GLBDOCR
          [M:SRH2]ATDTCODR= [F:PTDKD]ATDTCOD
          Affzo [M:SRH2]ATDTCODR
        Endif
      Endif
    Endif
    If [M:SRH2]GLBDOCR = 2
      Diszo [M:SRH2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR
    Endif
    Call DIS_MANDOC(GFONCTION) From TRNDOC

    Chgfmt [M:SRH0]SRHCFMFLG   With "LA1:15X"

  Else
    Diszo [M:SRH2]GLBDOCDATR,GLBDOCNUMR,GLBDOCTYPR,MANDOCR,ATDTCODR,GLBDOCR
    If dim([M:SRH0]SRHCFMFLG) > 0
      Chgfmt [M:SRH0]SRHCFMFLG   With "-LA1:15X"
    Endif
  Endif
Endif
#-
Return

####################################################################
$AVANT_MOD
OK = 1
# -- Modification impossible si pas les droits d'accès
If [F:SRH]AUZUSR <> "" & [F:SRH]AUZUSR <> GUSER & GAUZRET = 1
   GERR=1 : GMESSAGE=mess(71,192,1)
   OK = 0
Endif
Return

####################################################################
$AVANT_MODFIC
#------------------------------------------#
# Traitement avant modification            #
#------------------------------------------#
# Maj des statistiques
Call VALSTA("SRH",-1) From SUBPS2
If GOK < 1 : Return : Endif

# Cas particulier où on modifie le texte en le supprimant
Local Integer WRET
If [M:SRH0]SRHTEX1="" & left$([F:SRH]SRHTEX1,3)="SRH"
    Call SUP_CLOB([F:SRH]SRHTEX1,WRET) From TRTX3TEX
Endif
If [M:SRH0]SRHTEX2="" & left$([F:SRH]SRHTEX2,3)="SRH"
    Call SUP_CLOB([F:SRH]SRHTEX2,WRET) From TRTX3TEX
Endif
# Réalimenter [M]WRHE avec [F]WRHE pour ne pas écraser le mono-dépôt
If dim([M:SRH1]WRHE)>0
   [M:SRH1]WRHE = [F:SRH]WRHE
Endif

Return

####################################################################
$VERIF_MOD
#RMA * 85785
If func PORLEGLIB.DIGSIGN([M:SRH0]STOFCY, "")
  If [M:SRH0]SRHCFMFLG = 2 & ![L]DKSOK
    OK       = 0 : GERR = 1
    GMESSAGE = mess(51,7711,1) + mess(654,7773,1)
  Endif
Endif
Gosub VERIF
Return

####################################################################
$INIMOD
# -- Raz variable utilisée pour la maj des mvts clients
Raz WCDEHT, WCDETTC, WLIVTTC

# -- Alimentation date retour entête
[F:SRH]RTNDAT = [M]ENTRTNDAT

Gosub INITXC
# Chargement adresses libres
Gosub CHARGEADR

Return

####################################################################
$MODIF

#--CPO 94689 Intrastat for Customer returns with nil quantity
If func AFNC.ACTIV("DEB")>0 and dim(GMODMSDGFORDEB)>0 and GMODMSDGFORDEB<>2
  If [F:SRH]EECNUMDEB>0
      Filter [F:DEB] Where EECNUMDEB=[F:SRH]EECNUMDEB and VCRNUM=[F:SRH]SRHNUM and CPY=[F:SRH]CPY
      Read [F:DEB]First
      If fstat : Raz [F:DEB] : Endif
      Filter [F:DEB]
      If [F:DEB]DEBDAT<>[0/0/0]
        Call ECR_TRACE (mess(74,191,1)-[F:SRH]SRHNUM-mess(803,197,1)-num$([F:SRH]EECNUMDEB)-mess(98,107,1)-format$("DD2",[F:DEB]DEBDAT),0) From GESECRAN
      Else
        Call ECR_TRACE (mess(74,191,1)-[F:SRH]SRHNUM-mess(803,197,1)-num$([F:SRH]EECNUMDEB),0) From GESECRAN
      Endif
      GMODMSDGFORDEB = 2
  Endif
Endif
#--/

If [M:SRH1]BETFCY=2 & [M:SRH0]BPSNUM<>"" & [M:SRH0]PNHFCY<>""
    # Si sup.ligne, pour recherche éventuelle dernier n°retour vente d'une ligne retour fsseur
    If clalev([F:SRD1])=0 Local File SRETURND [SRD1] Endif
Endif
# -- Modification des lignes d'un retour #
Gosub MODIF From TABLEAUX
If GOK<1 : Return : Endif
If [M:SRH1]BETFCY=2 & [M:SRH0]BPSNUM<>"" & [M:SRH0]PNHFCY<>""
    Close Local File [SRD1] : Default File [SRH]
Endif
#------------------------------------#
# Mise à jour des mouvements clients #
#------------------------------------#
# Maj du n° dernier retour
Call  MAJMVC ([F:SRH]BPCORD, "", 0, 0, [F:SRH]RTNDAT, [F:SRH]SRHNUM, [F:SRH]STOFCY,
&             0, 0, "+", "R", GREP, 0) From TRTBPMVT
If GOK<1: Return: Endif
If WLIVTTC <> 0
   # -- Maj mouvement client (en-cours livraison)
   Call MAJMVC ([F:SDH]BPCORD, [F:SDH]CUR, [F:SDH]CHGTYP, 0, [F:SDH]SHIDAT, [F:SDH]SDHNUM, [F:SDH]SALFCY,
&               0, WLIVTTC, "-", "D", "", [F:SDH]LND) From TRTBPMVT
   If  GOK<1 : Return : Endif
Endif
# Maj des statistiques
Call VALSTA("SRH",1) From SUBPS2
If GOK < 1 : Return : Endif

# FGR 04/01/2011 : X3SUIVI70100 (début) c'est mieux dans la transaction
# Si présence module Support Client, gestion du parc client
#If GMODU(12)=2 Then                                      : # Bug 84870 : Pas de gestion du parc si inter-site
If GMODU(12)=2 & !([F:SRH]BETFCY=2 & [F:SRH]BETCPY<>2)    : # Bug 84870
  Gosub TRT_MACRULE_MOD From SUBSRH
  If GOK < 1 : Return : Endif  # ... et ajout de la gestion d'erreur
Endif
# FGR 04/01/2011 : X3SUIVI70100 (fin) c'est mieux dans la transaction

  # -------------------------------------------------
  # Issue X3-31898 - 2017-11-17 by FGR : BEGIN
  Gosub PJM_TECALLITM From SUBSDHA
  If GOK < 1 : Return : Endif
  # Issue X3-31898 - 2017-11-17 by FGR : END
  # -------------------------------------------------

Gosub DEVERROU_PICKING

#85785 * RMA
##--CPO for RMA Issue 75115 Digital signature of shipments and customer returns
## ----------------------------------------------------------- #
## Digital signature of shipments and customer returns         #
## ----------------------------------------------------------- #
#If func AFNC.ACTIV("DKS") & func AFNC.PARAM("PORDKS",[F:SRH]CPY)="2"
#  Gosub DIGSIGN
#Endif
## ----------------------------------------------------------- #

Return

####################################################################
$APRES_MOD
Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)

#-- 77964 -- Régularisation des manquants et alloc
If GWEBSERV
 Call REGFROMENT(0,"SRH1","[M:SRH1]CREFLG(I)=1","ITMREF",[M:SRH0]STOFCY) From TRTSHTCOM
Else
 Call REGFROMENT(0,"SRH1","[M:SRH1]CREFLG(I)=0","ITMREF",[M:SRH0]STOFCY) From TRTSHTCOM
Endif

# FGR 04/01/2011 : X3SUIVI70100 (début) déplacé dans la transaction
# Si présence module Support Client, gestion du parc client
#If GMODU(12)=2 Gosub TRT_MACRULE_MOD From SUBSRH : Endif
# FGR 04/01/2011 : X3SUIVI70100 (fin) déplacé dans la transaction

# -- 77964 Impression du bon de retour
If !GIMPORT & !GWEBSERV & WSLTDOCFLG = 2
    Gosub SET_CLE From GOBJSUB
    CLECUR = 1
    Call ETAT(WSLTDOCNAM,"GESSRH",TBPAR,TBVAL) From ETAT
Endif

# Vide la table de travail de la gestion des emplacements
Local Integer WRET
Call STKDELRES(0,[M:SRH0]STOFCY,"",WRET) From STKLOC

# -- Impression des étiquettes -----#
#-- X3Suivi 77964 : Retour client via le connecteur
If GSLTPRNCOD1>1 & !GWEBSERV & sum([M:SRH1]RTNSTOUPD) > [M:SRH1]NBLIG
   Local Char    LCRIT(250)
   Local Char WPARAM(GLONVCR)(1..4) , WVALEUR(10)
   Local Integer WCREATION
   WPARAM(1) = [M:SRH0]STOFCY
   WPARAM(2) = num$(13)
   WPARAM(3) = [M:SRH0]SRHNUM
#                                                                                           # hcb X3-91077 - X3-92342 deb
#   Call TRAITE_CHAR(WVALEUR,WPARAM,"ISTOLBE","SUBSLP","",4,"SPESLP") From GTRAITE
   Case GSLTPRNCOD1
        When 2 :
          Call TRAITE_CHAR(WVALEUR,WPARAM,"IRCPLBE1","SUBRCPLBE","",4,"SPERCPLBE") From GTRAITE  # Etiquette stock
        When 6 :
          Call TRAITE_CHAR(WVALEUR,WPARAM,"IRCPLBE2","SUBRCPLBE","",4,"SPERCPLBE") From GTRAITE  # Etiquette nouveau contenant
        When 7 :
          If !clalev([F:LPN])  : Local File LPN          [LPN]  : Endif
          Raz WCREATION
          LCRIT   = "STOFCY=[M:SRH0]STOFCY"
          LCRIT  += "&VCRNUM>=[M:SRH0]SRHNUM"
          LCRIT  += "&VCRNUM<=[M:SRH0]SRHNUM"
          LCRIT  += "&PRTFLG <> 2"
          Filter [F:LPN] Where evalue(LCRIT)
&         Order By Key LPN0
          For [LPN]
              WCREATION = 2
              Break
          Next
          Filter [LPN]
          If WCREATION = 2
             Call TRAITE_CHAR(WVALEUR,WPARAM,"IRCPLBE3","SUBRCPLBE","",4,"SPERCPLBE") From GTRAITE  # Etiquette stock et contenant créé
          Else
             Call TRAITE_CHAR(WVALEUR,WPARAM,"IRCPLBE1","SUBRCPLBE","",4,"SPERCPLBE") From GTRAITE  # Etiquette stock
          Endif
        When Default
   Endcase
#                                                                                           # hcb X3-91077 - X3-92342 fin

Endif

Gosub RELIT From GOBJSUB
[M:SRH0]SRHNUM = [F:SRH]SRHNUM

Return

####################################################################
$VERF_ANU
OK = 1
# "Vous n'avez pas les droits pour ce retour"
#If [F:SRH]AUZUSR <> GUSER & GAUZRET = 1                        # FGR 03/03/2015 : X3SUIVI106716 : tester [F:SRH]AUZUSR <> ""
If [F:SRH]AUZUSR <> "" & [F:SRH]AUZUSR <> GUSER & GAUZRET = 1   # FGR 03/03/2015 : X3SUIVI106716 : tester [F:SRH]AUZUSR <> ""
   GERR=1 : GMESSAGE=mess(71,192,1)
   OK = 0 : Return
Endif
# "Stock mis à jour ! Utilisez le bouton contextuel 'Modif mvts de stock'"
If sum([M:SRH1]RTNSTOUPD) > [M:SRH1]NBLIG
   GERR=1 : GMESSAGE=mess(72,192,1)+"\"+mess(121,192,1)-mess(3,184,1)
   OK = 0 : Return
Endif

# X3-80406 - Before we delete the customer return check if this document is in any non-conformances
If func AFNC.ACTIV ("NCS")
    Local Integer LOK
    Local Integer EXISTS
    Local Char NCSMESS(255)
    [L]EXISTS = func NCSDOCHDR_CSTD.NON_CONFORMANCE_EXISTS (2, [M:SRH0]SRHNUM, -1, [L]NCSMESS, 1)
    If [L]EXISTS > 0
        Call OUINON([L]NCSMESS,LOK) From GESECRAN
        If LOK = 1
            GMESSAGE = ""
            OK = 0
            Return
        Endif
    Endif
Endif
# X3-80406 - end

# "Commande mise à jour ! Voulez-vous continuer ? "
If sum([M:SRH1]ORDUPD) > [M:SRH1]NBLIG
   Call OUINON(mess(74,192,1)+"\"+mess(108,192,1)+"\"+mess(205,100,1), OK) From GESECRAN
   If   OK = 1 : OK = 0 : Endif
Endif

#85785
If func PORLEGLIB.DIGSIGN([M:SRH0]STOFCY, "")
  If [M:SRH0]SRHCFMFLG = 2
    OK       = 0 : GERR = 1
    GMESSAGE = mess(51,7711,1) + mess(654,7773,1)
  Endif
Endif

Return
###############################################################
$ANNULE
Local  Decimal  WCDEHT         : # En commande HT
Local  Decimal  WCDETTC        : # En commande TTC
Local  Decimal  WLIVTTC        : # En livraison TTC

#--CPO 94689 Intrastat for Customer returns with nil quantity
If func AFNC.ACTIV("DEB")>0 and dim(GMODMSDGFORDEB)>0 and GMODMSDGFORDEB<>2
  If [F:SRH]EECNUMDEB>0
      Filter [F:DEB] Where EECNUMDEB=[F:SRH]EECNUMDEB and VCRNUM=[F:SRH]SRHNUM and CPY=[F:SRH]CPY
      Read [F:DEB]First
      If fstat : Raz [F:DEB] : Endif
      Filter [F:DEB]
      If [F:DEB]DEBDAT<>[0/0/0]
        Call ECR_TRACE (mess(74,191,1)-[F:SRH]SRHNUM-mess(803,197,1)-num$([F:SRH]EECNUMDEB)-mess(98,107,1)-format$("DD2",[F:DEB]DEBDAT),0) From GESECRAN
      Else
        Call ECR_TRACE (mess(74,191,1)-[F:SRH]SRHNUM-mess(803,197,1)-num$([F:SRH]EECNUMDEB),0) From GESECRAN
      Endif
      GMODMSDGFORDEB = 2
  Endif
Endif
#--/

#------------------------------------#
# supression des textes associées    #
#------------------------------------#
Local Integer WRET
If left$([F:SRH]SRHTEX1,3)="SRH"
   Call SUP_CLOB([F:SRH]SRHTEX1,WRET) From TRTX3TEX
Endif
If left$([F:SRH]SRHTEX2,3)="SRH"
   Call SUP_CLOB([F:SRH]SRHTEX2,WRET) From TRTX3TEX
Endif

# Raz des variables utilisées pour la maj des mvts clients
Raz WCDEHT, WCDETTC, WLIVTTC
If sum([M:SRH1]PNDLIN)<>0
    # Pour recherche dernier n°retour vente d'une ligne retour fsseur
    If clalev([F:SRD1])=0 Local File SRETURND [SRD1] Endif
Endif
Gosub ANNULE From TABLEAUX : # Effacement des lignes
If GOK<1 : Return : Endif
If sum([M:SRH1]PNDLIN)<>0
    Close Local File [SRD1] : Default File [SRH]
Endif
#------------------------------------#
# Mise à jour des mouvements clients #
#------------------------------------#
# Maj du n° dernier retour
Call  MAJMVC ([F:SRH]BPCORD, "", 0, 0, [F:SRH]RTNDAT, [F:SRH]SRHNUM, [F:SRH]STOFCY,
&             0, 0, "+", "R", GREP, 0) From TRTBPMVT
If GOK<1: Return: Endif

If WLIVTTC <> 0
   # -- Maj mouvement client (livré non facturé)
   Call MAJMVC ([F:SDH]BPCORD, [F:SDH]CUR, [F:SDH]CHGTYP, 0, [F:SDH]SHIDAT, [F:SDH]SDHNUM, [F:SDH]SALFCY,
&               0, WLIVTTC, "-", "D", "", [F:SDH]LND) From TRTBPMVT
   If  GOK<1 : Return : Endif
Endif

  # ------------------------------------------
  # Issue X3-31898 - 2017-11-17 by FGR : BEGIN
  #If func ASYRFNC.ACTIV("PJM") Then        # Issue X3-77485 - 2018-02-19 by FGR : Deactived at the moment
  If func ASYRFNC.ACTIV("PJM") and 0=1 Then # Issue X3-77485 - 2018-02-19 by FGR : Deactived at the moment
    Local Integer IPJMRET
    Local Integer ZF

    If dim(ZTECALLITM) < 0 Then
      Local Instance ZTECALLITM Using C_TECALLITM
    Endif
    If ZTECALLITM = null Then
      ZTECALLITM = NewInstance C_TECALLITM AllocGroup null
    Endif
    For ZF = 0 To [M:SRH1]NBLIG-1
      # COMMENTS TO EXPLAIN
#      IPJMRET = fmet ZTECALLITM.SAL_ADD_LINE([M:SRH1]DPJT(ZF), [M:SRH1]ITMREF(ZF), [M:SRH1]STU(ZF),
#&                                            0,                          # Delivered qty when delivery NOT validated : STILL 0 on return
#&                                            ([M:SRH1]QTYSTU(ZF) * -1),  # Delivered qty when delivery validated
#&                                            ([M:SRH1]QTYSTU(ZF) * -1)   # Order qty alloc. STU : Increase allocated QTY with the return QTY
#&                                            )
      IPJMRET = fmet ZTECALLITM.SAL_ADD_LINE([M:SRH1]DPJT(ZF), [M:SRH1]ITMREF(ZF), [M:SRH1]STU(ZF),
&                                            0,
&                                            ([M:SRH1]QTYSTU(ZF) * -1),
&                                            ([M:SRH1]QTYSTU(ZF) * -1)
&                                            )
      If IPJMRET >= [V]CST_AERROR Then
        # TODO FLORENT ICI prevoir gestion erreur
        Break
      Endif
    Next ZF
  Endif
  # Issue X3-31898 - 2017-11-17 by FGR : END
  # ------------------------------------------

# Maj des statistiques
Call VALSTA("SRH",-1) From SUBPS2
If GOK < 1 : Return : Endif

# X3-80406 - If we have deleted the customer return then mark this document as deleted in any non-conformances
If func AFNC.ACTIV ("NCS") & GOK > 0
    Local Integer WSTATUS
    WSTATUS = func NCSDOCHDR_CSTD.DELETE_NON_CONFORMANCE_DOCUMENTS (2, [F:SRH]SRHNUM, -1)
    If WSTATUS
        GMESSAGE = mess(47,3702,1)
        GOK = 0
        Return
    Endif
Endif
# X3-80406 - endif

Return

###############################################################
$DEFLIG
#----------------------------------#
# Définition du fichier des lignes #
#----------------------------------#
# Critère de lecture      (CRIT)   #
# Nom du fichier          (FICLIG) #
# Abréviation du fichier  (ABLIG)  #
# Zone numéro de ligne    (ZONLIG) #
#----------------------------------#
Default Mask [SRH1]
# FGR 24/07/2015 : X3SUIVI109796 : Optimisation (début)
#Default File [SRD]
#Default File [LSRD]
If dim(SAVACT) >= 0 and find(SAVACT,"MODIF","CREATION","ANNULE") Then
  Default File [SRD]
Else
  Default File [LSRD]
Endif
# FGR 24/07/2015 : X3SUIVI109796 : Optimisation (fin)

CRIT = 'SRHNUM="'+[M:SRH0]SRHNUM+'"'
FICLIG = "SRETURND" : ABLIG = "SRD"
ZONLIG = "SRDLIN"
Return

####################################################################
$INI_LIG
Local Shortint NOL

[F:SRD]SRHNUM = [M:SRH0]SRHNUM
[F:SRD]STOFCY = [M:SRH0]STOFCY
If dim([F:SRD]CPY)>0 : [F:SRD]CPY=GSOCIETE : Endif

NOL=nolign-1
# -- Alimentation des zones de détail
[F:SRD]SDHNUM  = [M]DETSDHNUM(NOL)
[F:SRD]RTNDAT  = [M]DETRTNDAT(NOL)
If [M:SRH1]SRDTEX(NOL)<>""
   If left$([M:SRH1]SRDTEX(NOL),3)="SRD"
      Call CRE_CLOB([M:SRH1]SRDTEX(NOL),GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Elsif !find(left$([M:SRH1]SRDTEX(NOL),3),"ITU","ITS")
      Call DUP_CLOB("SRD",[M:SRH1]SRDTEX(NOL),GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Endif
   [F:SRD]SRDTEX = [M:SRH1]SRDTEX(NOL)
Endif

If ACTION="INICRE_LIG"
  # Alimentation dépôt ligne si renseigné
  If dim([M:SRH1]WRH)>0 & [M:SRH1]WRH(NOL)<>""
    [F:SRD]WRH = [M:SRH1]WRH(NOL)
  Else
    [F:SRD]WRH = ""
  Endif
Endif

[F:SRD]PJT    = [M:SRH1]DPJT(NOL):#--CPO 71065 Code affaire en-tête / lignes
[F:SRD]SRHCAT = [M:SRH0]SRHCAT   :#--CPO 75115 - 275 SRHCAT contient la catègorie de retour

Return

####################################################################
$LIENS_LIG
Local Shortint NOL
NOL = nolign-1

[M]DETSALFCY(NOL)  = [F:SRH]SALFCY
[M]DETBPCINV(NOL)  = [F:SRH]BPCINV

If [F:SRD]SDHNUM <> ""
   # -- Lecture entête livraison
   Read [SDH] SDH0=[F:SRD]SDHNUM
   If fstat
       Call MESSAGE ([F:SRD]SDHNUM-":"-mess(239,192,1)) From GESECRAN : Raz [F:SDH]
   Else
       # -- Lecture détail livraison
       Read [SDD] SDD0=[F:SRD]SDHNUM;[F:SRD]SDDLIN
       If fstat
           Call MESSAGE ([F:SRD]SDHNUM-":"-num$([F:SRD]SDDLIN)-mess(239,192,1)) From GESECRAN : Raz [F:SDD]
       Endif
       If [F:SDD]SOHNUM<>""
           # -- Lecture détail commande
           Read [SOP] SOP0=[F:SDD]SOHNUM;[F:SDD]SOPLIN;[F:SDD]SOQSEQ
           If fstat Raz [F:SOP] Endif
           [M]SOHSAU(NOL)   =[F:SOP]SAU       # FGR 07/02/2014 : X3SUIVI96339 : manquait (NOL)
           [M]SOHSAUCOE(NOL)=[F:SOP]SAUSTUCOE # FGR 07/02/2014 : X3SUIVI96339 : manquait (NOL)
       Endif
   Endif
   # -- Alimentation des zones de détail par la livraison
   [M]STOMGTCOD(NOL)  = [F:SDD]STOMGTCOD
   [M]DETSALFCY(NOL)  = [F:SDH]SALFCY
   [M]DETBPCINV(NOL)  = [F:SDH]BPCINV

   [M]SIHNUMFAC(NOL)  = [F:SDH]SIHNUM
   [M]SOHCAT(NOL)     = [F:SDD]SOHCAT

   # Calcul de la quantité livrée dans l'unité du retour
   If [F:SDD]SAU=[F:SRD]SAU & [F:SDD]SAUSTUCOE=[F:SRD]SAUSTUCOE
        # 77101 : Tout est retourné en US, on peut afficher la qté livrée à 0
        If [F:SDD]RTNQTYSTU>=[F:SDD]QTYSTU
            [M]DLVQTY(NOL) = 0
        Else
            [M]DLVQTY(NOL) = [F:SDD]QTY - [F:SDD]RTNQTY
        Endif
   Else
        # l'unité de la livraison n'est pas l'unité du retour
        # On repart de la qté livrée en US et on convertit dans l'unité de retour
        Local Decimal WDLVQTY
        WDLVQTY = [F:SDD]QTYSTU - [F:SDD]RTNQTYSTU
        WDLVQTY=WDLVQTY/[F:SRD]SAUSTUCOE
#        Call QTEARR(WDLVQTY, [F:SRD]SAU) From TRTDIV
        [M]DLVQTY(NOL)     = WDLVQTY
   Endif
   [M]DLVQTYSTU(NOL)  = [F:SDD]QTYSTU - [F:SDD]RTNQTYSTU
   [M]LINTYP(NOL)     = [F:SDD]LINTYP
   [M]RCPQTYSTU(NOL)  = [F:SDD]RCPQTYSTU
Endif
# FGR 27/07/2015 : X3SUIVI108078 : Optimisation (début)
# -- Lecture article
#If [F:ITM]ITMREF<>[F:SRD]ITMREF
#    Read [ITM]ITM0=[F:SRD]ITMREF
#    If fstat Call RSTA ("ITM",[F:SRD]ITMREF)  From GLOCK : Raz [F:ITM] : Endif
#Endif
# FGR 27/07/2015 : X3SUIVI108078 : Optimisation (fin)
#If [F:ITM]ITMREF<>[F:SRD]ITMREF | [F:ITU]BPCNUM<>[F:SRH]BPCORD
#    Read [ITU]ITU0=[F:SRD]ITMREF;[F:SRH]BPCORD
#    If fstat Raz [F:ITU] : Endif
#Endif
# FGR 27/07/2015 : X3SUIVI108078 : Optimisation (fin)

Gosub ALI_DACSAUCOE
If [F:SRD]SDHNUM="" | [F:SDH]SDHNUM="" | [F:SDD]SDHNUM = ""
    [M]STOMGTCOD(NOL)=[F:ITM]STOMGTCOD
    If [F:ITM]STOMGTCOD>1
        If [F:ITF]ITMREF<>[F:SRD]ITMREF | [F:ITF]STOFCY<>[F:SRD]STOFCY
            Read [ITF] ITF0=[F:SRD]ITMREF;[F:SRD]STOFCY
            If fstat Raz [F:ITF] : Endif
        Endif
        If [F:ITF]STOMGTCOD>0 [M]STOMGTCOD(NOL) = [F:ITF]STOMGTCOD Endif
    Endif
Endif
If [F:SRD]PNHNUM<>""
   # -- Lecture retour fournisseur
   Read [PNH]PNH0=[F:SRD]PNHNUM
   If fstat Call RSTA ("PNH",[F:SRD]PNHNUM)  From GLOCK : Raz [F:PNH] : Endif
   # -- Lecture détail retour fournisseur
   Read [PND] PND0=[F:SRD]PNHNUM;[F:SRD]PNDLIN
   If fstat Call RSTA ("PND",[F:SRD]PNHNUM-num$([F:SRD]PNDLIN)) From GLOCK : Raz [F:PND] : Endif
   [M]PNHFCY = [F:PNH]PNHFCY
   [M]BPSNUM = [F:PNH]BPSNUM
   [M]PNDQTYSTU(NOL)  = [F:PND]QTYSTU - [F:PND]SRDQTYSTU
Elsif [M]BETFCY=2
   # alimentation du site reception pour la maj des stock transféré et en transit
   Call RECPRHFCY([M]BPCORD, [M]BPAADD, [M]PNHFCY) From TRTVENISOC
   If GERR=1 Raz GMESSAGE : Raz GERR Endif : # Si aucun trouvé tanpis on continue
Endif

# -- Alimentation des zones de détail
[M]DETSDHNUM(NOL)  = [F:SRD]SDHNUM
[M]DETRTNDAT(NOL)  = [F:SRD]RTNDAT
#----- Chargement sections analytiques -----#
Call CHARG_CCE("SRH1",NOL,"SRD",0,[F:SRD]SRHNUM,[F:SRD]SRDLIN,0,"") From TRTX3CPT

# -- Alimentation des zones de sauvegarde
[M]XQTY(NOL)       = [M]QTY(NOL)
[M]XQTYSTU(NOL)    = [M]QTYSTU(NOL)
[M]XEXTQTY(NOL)    = [M]EXTQTY(NOL)
[M]XEXTQTYSTU(NOL) = [M]EXTQTYSTU(NOL)
[M]XORDUPD(NOL)    = [M]ORDUPD(NOL)
[M]YRTNSTOUPD(NOL) = [M]RTNSTOUPD(NOL)
Raz [M]WSTOUPD(NOL)

If [M]RTNSTOUPD(NOL)=2
  # Recherche du contenu des zones stock d'une ligne document dans le fichier STOJOU
  Call RECSTO_F ("SRH1", [M:SRH0]STOFCY, 13,
&              [M:SRH0]SRHNUM, [M:SRH1]SRDLIN(NOL), NOL, "") From STKECR
  [M:SRH1]WSTOFLG(NOL)=1
Else
  Raz [M:SRH1]WSTOFLG(NOL)
Endif

#--CPO 71065 Code affaire en-tête / lignes
[M:SRH1]DPJT(NOL)=[F:SRD]PJT
#--/CPO

Return

####################################################################
# ------------------------------------ #
# Alimentation du flag coef modifiable #
# ------------------------------------ #
$ALI_DACSAUCOE
If [M]SAU(NOL)=[M]STU(NOL)
    [M]DACSAUCOE(NOL)=1
Elsif [M]SAU(NOL)=[F:ITM]SAU
    [M]DACSAUCOE(NOL)=[F:ITM]DACSAUCOE
Elsif [M]SAU(NOL)=[F:ITU]SAU | [M]SAU(NOL)=[F:ITU]PCU1 | [M]SAU(NOL)=[F:ITU]PCU2
    [M]DACSAUCOE(NOL)=1
Else
    Local Integer I    : # L'unité est une unité de conditionnement
    For I=0 To dim([F:ITM]PCU)-1
       If find([F:ITM]PCU(I),[M]SAU(NOL))
          [M]DACSAUCOE(NOL)=[F:ITM]DACPCUCOE(I)
          Break
       Endif
    Next I
Endif
Return
#########################################################################
$VALLIG
#----------------------------------------------------------------#
# En création     : TRTLIG = "C" et SIGN = +1 (après le write)   #
# En modification : TRTLIG = "M" et SIGN = -1 (avant le rewrite) #
#                                   SIGN = +1 (après le rewrite) #
# En annulation   : TRTLIG = "A" et SIGN = -1 (avant le delete)  #
#----------------------------------------------------------------#
Local Char    WMAJ
Local Integer WOPT, WRET
Local Decimal WQTE, WQTY, WSHT, WCNVDELTAQTY
Local Integer NOL, SNOL
Local Decimal DELTAQTY     : # Delta de la quantité retournée (en + ou -)
Local Decimal DELTAQTYSTU  : # Delta de la quantité retournée US (en + ou -)
Local Decimal ECARTQTY     : # Ecart entre qte cde et qte liv (en + ou -)
Local Integer WMAJ_LIV     : WMAJ_LIV=1
Local Integer WMAJ_PNH     : WMAJ_PNH=1

NOL  = nolign-1   : SNOL = nolign-1
WMAJ = "C"        : # Création allocation
WRET = 0          : # Code retour

# -- lecture livraison avec lock
If [F:SRD]SDHNUM <> "" Gosub LEC_LIV : If GOK <= 0  Return  Endif : Endif
# -- lecture retour fournisseur avec lock
If [F:SRD]PNHNUM <> "" Gosub LEC_PNH : If GOK <= 0  Return  Endif : Endif

# -- traitement création / modif / annul
If TRTLIG = "C"             : Gosub VALLIGCRE : Endif
If TRTLIG = "M" & SIGN = +1 : Gosub VALLIGMOD : Endif
If TRTLIG = "A"             : Gosub VALLIGANN : Endif

If GOK < 1 : Return : Endif
If [F:SRD]SDHNUM <> "" Unlock [SDH] : Unlock [SDD] Endif
If [F:SRD]PNHNUM <> "" Unlock [PNH] : Unlock [PND] Endif

If TRTLIG = "A"
    If left$([F:SRD]SRDTEX,3)="SRD"
        Call SUP_CLOB([F:SRD]SRDTEX,WRET) From TRTX3TEX
        If WRET=0 GOK=0 : Return Endif
    Endif
    #----- Suppression comptes et sections de la ligne de facture -----#
    Call ENREG_ACCCCE(0,"","","","SRD",0,[F:SRD]SRHNUM,[F:SRD]SRDLIN,0,"","A") From TRTX3CPT
    If GOK<1  Return : Endif
    #-----
Elsif TRTLIG = "M" & SIGN=-1
    # Cas particulier où on modifie le texte en le supprimant
    If [M:SRH1]SRDTEX(NOL)="" & left$([F:SRD]SRDTEX,3)="SRD"
        Call SUP_CLOB([F:SRD]SRDTEX,WRET) From TRTX3TEX
    Endif
# --> Création et Modification
Elsif SIGN = +1
    #----- Ecriture des sections de la ligne de retour -----#
    Call ENREG_ACCCCE(nolign-1,"","","[M:SRH1]CCE","SRD",
&                     0,[F:SRD]SRHNUM,[F:SRD]SRDLIN,0,"",TRTLIG) From TRTX3CPT
    If GOK<1  Return : Endif
    #-----
Endif
Raz WRET

# A SUPPRIMER
#Local Integer WRETOUR
#Local Char WNUMTEX (12)
#If TRTLIG = "A"
#-- Suppression texte ligne
#-- probleme non resolu :
#--      CAS de ajout ligne sur une cde avec saisie d'un texte
#--      le texte est creer sur le disque  mais on abandonne la modif
#--      On ne peux pas supprimer le texte puisque la ligne cde n'a jamais existe
#--      il faudrait faire un boucle - pour l instant on laisse
#-- attention on n utilise pas masque et nolign-1 (car probleme avec anucod)
#    WNUMTEX = [F:SRD]SRDTEX
#    If WNUMTEX <> ""
#        WRETOUR = 0
#        Call TEX(5,"SRD1","","","",WNUMTEX,"A",WRETOUR) From TRTX3TEX
#    Endif
#Endif

  # ------------------------------------------
  # Issue X3-31898 - 2017-11-17 by FGR : BEGIN
  #If func ASYRFNC.ACTIV("PJM") Then        # Issue X3-77485 - 2018-02-19 by FGR : Deactived at the moment
  If func ASYRFNC.ACTIV("PJM") and 0=1 Then # Issue X3-77485 - 2018-02-19 by FGR : Deactived at the moment
    Local Integer IPJMRET
    If dim(ZTECALLITM) < 0 Then
      Local Instance ZTECALLITM Using C_TECALLITM
    Endif
    If ZTECALLITM = null Then
      ZTECALLITM = NewInstance C_TECALLITM AllocGroup null
    Endif
      # COMMENTS TO EXPLAIN
#      IPJMRET = fmet ZTECALLITM.SAL_ADD_LINE([M:SRH1]DPJT(ZF), [M:SRH1]ITMREF(ZF), [M:SRH1]STU(ZF),
#&                                            0,                          # Delivered qty when delivery NOT validated : STILL 0 on return
#&                                            ([M:SRH1]QTYSTU(ZF) * -1),  # Delivered qty when delivery validated
#&                                            ([M:SRH1]QTYSTU(ZF) * -1)   # Order qty alloc. STU : Increase allocated QTY with the return QTY
#&                                            )
    IPJMRET = fmet ZTECALLITM.SAL_ADD_LINE([F:SRD]PJT, [F:SRD]ITMREF, [F:SRD]STU,
&                                          0,
&                                          ([F:SRD]QTYSTU * SIGN),
&                                          ([F:SRD]QTYSTU * SIGN)
&                                          )
    If IPJMRET >= [V]CST_AERROR Then
      # TODO FLORENT ICI prevoir gestion erreur
    Endif
  Endif
  # Issue X3-31898 - 2017-11-17 by FGR : END
  # ------------------------------------------

# Maj des statistiques
Call VALSTA("SRD",SIGN) From SUBPS2
If GOK < 1 : Return : Endif

Return


#########################################################################
#-----------------------------------------------------------------------#
# ETIQUETTES APPELEES PAR LES ACTIONS OBJETS                            #
#-----------------------------------------------------------------------#
#########################################################################
#---------------------------------------#
# Mise à jour de l'adresse              #
#---------------------------------------#
$MAJADRESSE
Call DEBTRANS From GLOCK
$TR_ADR
GOK=1
Trbegin [SRH]
  Readlock [SRH] SRH0=[M]SRHNUM
  If fstat=1  GOK=-1 : GLOCK="$SRETURN"-[M]SRHNUM          : Goto ROLL_ADR
  Elsif fstat GOK=0  : Call RSTA("SRH",[M]SRHNUM) From GLOCK : Goto AB_ADR : Endif
  [F:SRH]CNDNAM = [M:ADB2]CNTNAM
  If [M:ADB2]ADBFLG = 2 Gosub CHARGE_ADRBPD Endif
  Rewrite [SRH]
  If fstat GOK=0 : Call FSTA("SRH") From GLOCK : Goto AB_ADR : Endif
Commit
Gosub RELIT From GOBJSUB  # FGR 24/07/2014 : X3SUIVI100377
Return

$ROLL_ADR
Rollback : Call ROLL From GLOCK
If !GROLL Goto TR_ADR : Endif
Return

$AB_ADR
Rollback
Return

#---------------------------------------#
# Alimentation de l'adresse livraison   #
#---------------------------------------#
$CHARGE_ADRBPD
[F:SRH]BPDNAM(0)    = [M:ADB2]BPRNAM(0)
[F:SRH]BPDNAM(1)    = [M:ADB2]BPRNAM(1)
[F:SRH]BPDADDLIG(0) = [M:ADB2]BPAADDLIG(0)
[F:SRH]BPDADDLIG(1) = [M:ADB2]BPAADDLIG(1)
[F:SRH]BPDADDLIG(2) = [M:ADB2]BPAADDLIG(2)
[F:SRH]BPDPOSCOD    = [M:ADB2]POSCOD
[F:SRH]BPDCTY       = [M:ADB2]CTY
[F:SRH]BPDSAT       = [M:ADB2]SAT
[F:SRH]BPDCRY       = [M:ADB2]CRY
[F:SRH]BPDCRYNAM    = [M:ADB2]CRYNAM
Return

#------------------------------------------------------#
# Chargement des adresses libres avant (ré)écriture    #
#------------------------------------------------------#
$CHARGEADR
Local Integer I
# Alimentation de l'adresse livraison
[F:SRH]CNDNAM = [M:ADB2]CNTNAM
If GACTSAD=2 & find([M:ADB2]ADBFLG,0,1) Call CHARGE_ADRMSK("ADB2", [F:SRH]BPCORD) From TRTVENDIV : Endif
Gosub CHARGE_ADRBPD
Return

#########################################################################
$LEC_LIV
# -- Lecture lockée entête livraison
Readlock [SDH] SDH0=[F:SRD]SDHNUM
If fstat = 1 GOK =-1
     GLOCK = "$SDELIVERY"-[F:SRD]SDHNUM : Return
Elsif fstat=5
     WMAJ_LIV=0 : Return
Elsif fstat  GOK = 0
     Call RSTA ("SDH",[F:SRD]SDHNUM)  From GLOCK : Return
Endif

# -- Lecture lockée détail livraison
Readlock [SDD] SDD0=[F:SRD]SDHNUM;[F:SRD]SDDLIN
If fstat = 1 GOK = -1
    GLOCK = "$SDELIVERYD"-[F:SRD]SDHNUM-num$([F:SRD]SDDLIN) : Return
Elsif fstat=5
    WMAJ_LIV=0 : Return
Elsif fstat  GOK =  0
    Call RSTA ("SDD",[F:SRD]SDHNUM-num$([F:SRD]SDDLIN)) From GLOCK : Return
Endif
Return
########################################################################
$LEC_PNH
# -- Lecture lockée entête retour fournisseur
Readlock [PNH] PNH0=[F:SRD]PNHNUM
If fstat = 1 GOK =-1
     GLOCK = "$PRETURN"-[F:SRD]PNHNUM : Return
Elsif fstat=5
     WMAJ_PNH=0 : Return
Elsif fstat  GOK = 0
     Call RSTA ("PNH",[F:SRD]PNHNUM)  From GLOCK : Return
Endif

# -- Lecture lockée détail retour fournisseur
Readlock [PND] PND0=[F:SRD]PNHNUM;[F:SRD]PNDLIN
If fstat = 1 GOK = -1
    GLOCK = "$PRETURND"-[F:SRD]PNHNUM-num$([F:SRD]PNDLIN) : Return
Elsif fstat=5
    WMAJ_PNH=0 : Return
Elsif fstat  GOK =  0
    Call RSTA ("PND",[F:SRD]PNHNUM-num$([F:SRD]PNDLIN)) From GLOCK : Return
Endif
Return
########################################################################
$VALLIGCRE
#----------------------------------#
# Traitement de VALLIG en création #
#----------------------------------#
DELTAQTY    = [F:SRD]QTY
DELTAQTYSTU = [F:SRD]QTYSTU

# Réalimentation du no ligne retour pour maj stock
[M]SRDLIN(NOL) = [F:SRD]SRDLIN

If [F:SRD]SDHNUM <> "" & WMAJ_LIV=1
   # -- Maj du détail livraison (qté retour en uv et en us)
   If DELTAQTYSTU <> 0
       Gosub CONV_LIV_DELTAQTY
       Gosub MAJLIV : If GOK < 1 Return Endif
   Endif
   # -- Maj mouvement client (livré non facturé) si facture non émise et pas de facturation qté retournée
   If ([M]SIHNUMFAC(NOL) = "" & DELTAQTYSTU <> 0) & GDLVRTNCNO=1

        # X3-1152 : Non invoiceable deliveries
#       WLIVTTC += WCNVDELTAQTY * [F:SDD]NETPRIATI
        WLIVTTC += WCNVDELTAQTY * [F:SDD]NETPRIATI * ([F:SDH]SDHCAT<>4 & [F:SDH]SDHCAT<>0)
        # X3-1152 : Non invoiceable deliveries

   Endif
   # -- Réimputation ligne commande
   # -- si pas déjà fait, si facture n'est pas crée, si liv/cde, si <>composé ou composant kit/sous-traité
   # -- si quantité créée
   If [M]XORDUPD(NOL)<>2 & [M]ORDUPD(NOL)=2 & [M]SIHNUMFAC(NOL)="" & [F:SDD]SOHCAT=1
&     & [F:SDD]SOHNUM<>"" & !find([F:SDD]LINTYP,2,3,4,5,10,11,12,13) & [M]QTY(NOL) <> 0
      Gosub MAJCDE : If GOK < 1  Return Endif
   Endif
Endif

If [F:SRD]PNHNUM <> "" & WMAJ_PNH=1
   # -- Maj du détail retour fournisseur (qté retour en us)
   If DELTAQTYSTU <> 0
       Gosub MAJPND : If GOK < 1 Return Endif
   Endif
Endif

# -- Maj du stock
If [M]RTNSTOUPD(NOL)=2
   Gosub MAJ_STOCK : If GOK < 1 Return Endif
# Bug 81935 : Retour de livraison intersite sans mvt de stock :
# --> Maj stock transit et transféré car ils ont été maj à la livraison ou au retour fsseur
#     (sortie de stock donc maj systématique des stocks)
Elsif [M]BETFCY=2 & [F:SRD]SDHNUM<>"" & [M]PNHFCY<>""
   Gosub MAJ_ITMMVT : If GOK < 1 Return Endif
# Bug 81935
Endif

Return
########################################################################
$VALLIGMOD
#--------------------------------------------------#
# Traitement de VALLIG en modification (SIGN = +1) #
#--------------------------------------------------#
DELTAQTY    = [M]QTY(NOL) - [M]XQTY(NOL)
DELTAQTYSTU = [M]QTYSTU(NOL) - [M]XQTYSTU(NOL)

If [F:SRD]SDHNUM <> "" & WMAJ_LIV=1
   # -- Maj du détail livraison (qté retour en uv & us)
   If DELTAQTYSTU <> 0
      Gosub CONV_LIV_DELTAQTY
      Gosub MAJLIV : If GOK < 1 Return Endif
   Endif
   # -- Maj mouvement client (livré non facturé) si facture non émise et pas de facturation qté retournée
   If ([M]SIHNUMFAC(NOL) = "" & DELTAQTYSTU <> 0) & GDLVRTNCNO=1
      # X3-1152 : Non invoiceable deliveries
#      WLIVTTC += WCNVDELTAQTY * [F:SDD]NETPRIATI
      WLIVTTC += WCNVDELTAQTY * [F:SDD]NETPRIATI * ([F:SDH]SDHCAT<>4 & [F:SDH]SDHCAT<>0)
      # X3-1152 : Non invoiceable deliveries
   Endif
   # -- Réimputation ligne commande
   # -- si pas déjà fait, si facture n'est pas crée, si liv/cde, si composé ou composant kit/sous-traité
   # -- si quantité retour
   If [M]XORDUPD(NOL) <> 2 & [M]ORDUPD(NOL) = 2 & [M]SIHNUMFAC(NOL) = "" & [F:SDD]SOHCAT=1
&     & [F:SDD]SOHNUM<>"" & !find([F:SDD]LINTYP,2,3,4,5,10,11,12,13) & [M]QTY(NOL) <> 0
      Gosub MAJCDE : If GOK < 1  Return Endif
   Endif
Endif
If [F:SRD]PNHNUM <> "" & WMAJ_PNH=1
   # -- Maj du détail retour fournisseur (qté retour en us)
   If DELTAQTYSTU <> 0
      Gosub MAJPND : If GOK < 1 Return Endif
   Endif
Endif

# -- Maj du stock
If [M]RTNSTOUPD(NOL)=2 & [M]WSTOSEQ(NOL)<>0
   Gosub MAJ_STOCK : If GOK < 1 Return Endif
# Bug 81935 : Retour de livraison intersite sans mvt de stock :
# --> Maj stock transit et transféré car ils ont été maj à la livraison ou au retour fsseur
#     (sortie de stock donc maj systématique des stocks)
Elsif [M]BETFCY=2 & [F:SRD]SDHNUM<>"" & [M]PNHFCY<>""
   Gosub MAJ_ITMMVT : If GOK < 1 Return Endif
# Bug 81935
Endif

Return
########################################################################
$VALLIGANN
#--------------------------------------#
# Traitement de VALLIG en annulation   #
#--------------------------------------#
DELTAQTY    = -1 * [F:SRD]QTY
DELTAQTYSTU = -1 * [F:SRD]QTYSTU

If [F:SRD]SDHNUM <> "" & WMAJ_LIV=1
   # -- Maj du détail livraison (qté retour en uv & us)
   If DELTAQTYSTU <> 0
      Gosub CONV_LIV_DELTAQTY
      Gosub MAJLIV : If GOK < 1 Return Endif
   Endif
   # -- Maj mouvement client (livré non facturé) si facture non émise et pas de facturation qté retournée
   If ([F:SDH]SIHNUM = "" & DELTAQTYSTU <> 0) & GDLVRTNCNO=1
       # Calcul de la qté retour dans l'unité de la livraison
#       If [F:SDD]SAU=[F:SRD]SAU & [F:SDD]SAUSTUCOE=[F:SRD]SAUSTUCOE
#           WRTNQTY    = [F:SRD]QTY
#       Else
#           # l'unité de la livraison n'est pas l'unité du retour
#           # On repart de la qté retour en US et on convertit dans l'unité de la livraison
#           WRTNQTY=[F:SRD]QTYSTU/[F:SDD]SAUSTUCOE
#           Call QTEARR(WRTNQTY, [F:SDD]SAU) From TRTDIV
#       Endif
#      WLIVTTC -= [F:SRD]QTY * [F:SDD]NETPRIATI
       # X3-1152 : Non invoiceable deliveries
#       WLIVTTC += WCNVDELTAQTY * [F:SDD]NETPRIATI
       WLIVTTC += WCNVDELTAQTY * [F:SDD]NETPRIATI * ([F:SDH]SDHCAT<>4)
       # X3-1152 : Non invoiceable deliveries
   Endif
Endif
If [F:SRD]PNHNUM <> "" & WMAJ_PNH=1
   # -- Maj du détail retour fournisseur (qté retour en us)
   If DELTAQTYSTU <> 0
      Gosub MAJPND : If GOK < 1 Return Endif
   Endif
Endif

# Bug 81935 : Retour de livraison intersite sans mvt de stock :
# --> Maj stock transit et transféré car ils ont été maj à la livraison ou au retour fsseur
#     (sortie de stock donc maj systématique des stocks)
If [M]RTNSTOUPD(NOL)=1 & [M]BETFCY=2 & [F:SRD]SDHNUM<>"" & [M]PNHFCY<>""
   Gosub MAJ_ITMMVT : If GOK < 1 Return Endif
Endif
# Bug 81935

# X3-80406 - customer return line deleted then mark this document as deleted in any non-conformances
If func AFNC.ACTIV ("NCS")
    Local Integer WSTAT
    WSTAT = func NCSDOCHDR_CSTD.DELETE_NON_CONFORMANCE_DOCUMENTS (2, [F:SRD]SRHNUM, [F:SRD]SRDLIN)
    If WSTAT
        GMESSAGE = mess(47,3702,1)
        GOK = 0
        Return
    Endif
Endif
# X3-80406 - endif

Return
########################################################################
$CONV_LIV_DELTAQTY
#-----------------------------------------------------------------------------#
# Conversion delta de la qté retournée dans l'unité de vente de la livraison  #
#-----------------------------------------------------------------------------#
# -- Alimentation quantité retournée en UV
If [F:SDD]SAU=[F:SRD]SAU & [F:SDD]SAUSTUCOE=[F:SRD]SAUSTUCOE
    WCNVDELTAQTY    = DELTAQTY
Else
    WCNVDELTAQTY=DELTAQTYSTU/[F:SDD]SAUSTUCOE
#    Call QTEARR(WCNVDELTAQTY, [F:SDD]SAU) From TRTDIV
    WCNVDELTAQTY = arr(WCNVDELTAQTY,0.000001)
Endif
Return
#########################################################################
$MAJLIV
#-------------------------#
# Maj ligne de livraison  #
#-------------------------#

# -- Alimentation quantité retournée en UV
#If [F:SDD]SAU=[F:SRD]SAU & [F:SDD]SAUSTUCOE=[F:SRD]SAUSTUCOE
#    [F:SDD]RTNQTY    += DELTAQTY
#Else
#    WRTNQTY=DELTAQTYSTU/[F:SDD]SAUSTUCOE
#    Call QTEARR(WRTNQTY, [F:SDD]SAU) From TRTDIV
#    [F:SDD]RTNQTY    += WRTNQTY
#Endif

# 40127 : Return status management
Local  Integer  WRTNLINNBR     : # Nb lignes retournées pour la livraison
# -- la ligne étaient totalement retournée
If [F:SDD]RTNQTYSTU = [F:SDD]QTYSTU
   WRTNLINNBR -= 1
Endif
# 40127

# -- Alimentation quantité retournée en UV
[F:SDD]RTNQTY    += WCNVDELTAQTY
# -- Alimentation quantité retournée en US
[F:SDD]RTNQTYSTU += DELTAQTYSTU
# Bug 38359 : Suppr. du ctrl qui a dû être effectué en amont
## -- pas de maj si qté retournée > qté livrée
#If [F:SDD]RTNQTY > [F:SDD]QTY
#   GERR = 1 : GMESSAGE=mess(64,192,1) : GOK  = 0 : Return
#Endif

# 40127 : Return status management
# -- la ligne est maintenant totalement retournée
If [F:SDD]RTNQTYSTU = [F:SDD]QTYSTU
   WRTNLINNBR += 1
Endif
# 40127

# -- Récriture du détail livraison
Rewrite [SDD]
If fstat : GOK = 0 : Call FSTA("SDD") From GLOCK : Return : Endif

# 40127 : Return status management
#-------------------------#
# Maj entête livraison    #
#-------------------------#

# -- Alimentation nombre lignes totalement retournées
[F:SDH]RTNLINNBR += WRTNLINNBR

# -- Maj etat de retour
If [F:SDH]RTNLINNBR >= [F:SDH]LINNBR : [F:SDH]RTNSTA = 3
Else
    Filter [SDD1] Where SDHNUM=[F:SDD]SDHNUM & SDDLIN<>[F:SDD]SDDLIN & RTNQTYSTU<>0
    Read [SDD1]SDD0 First
    If fstat = 0
        [F:SDH]RTNSTA=2
    Else
        If [F:SDH]RTNLINNBR  = 0 & [F:SDD]RTNQTYSTU=0
            [F:SDH]RTNSTA = 1
        Else
            [F:SDH]RTNSTA = 2
        Endif
    Endif
    Filter [SDD1]
Endif

# -- Récriture de l'entête livraison
Rewrite [SDH]
If fstat : GOK = 0 : Call FSTA("SDH") From GLOCK : Return : Endif
# 40127

Return
#########################################################################
$MAJCDE
#-------------------------#
# Maj lignes de commandes #
#-------------------------#
Local  Integer  STAT
Local  Decimal  WDIFF, WCPLQTY, WDLVQTY, WRTNQTY
Local  Char     WTRTORD

# -- Lecture avec lock détail commande
Readlock [SOQ] SOQ0=[F:SDD]SOHNUM;[F:SDD]SOPLIN;[F:SDD]SOQSEQ
If fstat = 1 GOK = -1
   GLOCK = "$SORDERQ"-[F:SDD]SOHNUM-num$([F:SDD]SOPLIN)-num$([F:SDD]SOQSEQ) : Return
Elsif fstat  GOK =  0
   Call RSTA ("SOQ",[F:SDD]SOHNUM-num$([F:SDD]SOPLIN)-num$([F:SDD]SOQSEQ)) From GLOCK : Return
Endif
# -- Lecture détail commande
Read [SOP] SOP0=[F:SDD]SOHNUM;[F:SDD]SOPLIN;[F:SDD]SOQSEQ
If fstat = 1 GOK = -1
    GLOCK = "$SORDERP"-[F:SDD]SOHNUM-num$([F:SDD]SOPLIN)-num$([F:SDD]SOQSEQ) : Return
Elsif fstat  GOK =  0
    Call RSTA ("SOQ",[F:SDD]SOHNUM-num$([F:SDD]SOPLIN)-num$([F:SDD]SOQSEQ)) From GLOCK : Return
Endif

# Calcul de la qté retour dans l'unité de vente de la commande
If [F:SOP]SAU=[F:SRD]SAU & [F:SOP]SAUSTUCOE=[F:SRD]SAUSTUCOE
    WRTNQTY = [F:SRD]QTY
Else
    WRTNQTY = [F:SRD]QTYSTU/[F:SOP]SAUSTUCOE
    Call QTEARR(WRTNQTY, [F:SOP]SAU) From TRTDIV
Endif

# -- Mise à jour possible sur la commande ?
#If [F:SOQ]DLVQTY - [F:SRD]QTY < 0
If [F:SOQ]DLVQTY - WRTNQTY < 0
   GERR = 1 : GMESSAGE = mess(74,192,1)+"\"+mess(108,192,1) : GOK  = 0 : Return
Endif

# maj entête commande (avant maj détail cde)
Gosub MAJENTCDE : If GOK = 0 : Return : Endif

# Diminution de la quantité livrée
#[F:SOQ]DLVQTY    -= [F:SRD]QTY
[F:SOQ]DLVQTY    -= WRTNQTY
[F:SOQ]DLVQTYSTU -= [F:SRD]QTYSTU

# Maj de l'état de la ligne
If   ([F:SOQ]ODLQTY + [F:SOQ]DLVQTY) >= [F:SOQ]QTY
     [F:SOQ]SOQSTA = 3
Else [F:SOQ]SOQSTA = 1
Endif

# Récriture du détail commande (SOQ)
Rewrite [SOQ]
If fstat : GOK = 0 : Call FSTA("SOQ") From GLOCK : Return : Endif

# Récriture du détail commande (SOP) si cde normale
If [F:SOH]SOHCAT <> 4
   [F:SOP]SOQSTA = [F:SOQ]SOQSTA
   Rewrite [SOP]
   If fstat : GOK = 0 : Call FSTA("SOP") From GLOCK : Return : Endif
Endif

# Maj de l'en-cde client dans les mouvements article
# --> Si cde signée ou Si paramètre maj encours article cde non signée à Oui
If ([F:SOH]APPFLG>2 | GSOHAPPORD=2) & [F:SOQ]STOMGTCOD <> 1
    #-------------------------------------#
    # Maj de l'en-cours pour qte livrée   #
    #-------------------------------------#
    WCPLQTY = [F:SOQ]DLVQTYSTU
    WTRTORD = "M"
    Gosub APPELWIP From TRTVENMAJ
    If GOK < 1 Return Endif

    # v6 affectations
    Gosub MAJ_MTO_SOQ From SALMTOLIB

    #----------------------------------------------------#
    # Maj de l'en-cde client dans les mouvements article #
    #----------------------------------------------------#
    #-- X3Suivi 85514 : Resynchronisation ITMMVT (SALSTO) si retour réactive la commande ---#
    If WSTA22 = 2
      #--- Si Commande Soldé et Livraison partiellement livrée, le retour désolde la commande --> recalcul SALSTO --#
      Gosub RESYNCHO_SALSTO
      Call  MAJITVVEN ([F:SOQ]ITMREF, [F:SOQ]STOFCY, WQTYRET , "=", "S", WRET) From TRTVENMAJ
      If GOK<=0  Return : Endif
    Else
      Call  MAJITVVEN ([F:SOQ]ITMREF, [F:SOQ]STOFCY, [F:SRD]QTYSTU, "+", "S", WRET) From TRTVENMAJ
      If GOK<=0  Return : Endif
    Endif

Endif
Return

#########################################################################
$MAJPND
#---------------------------------#
# Maj ligne de retour fournisseur #
#---------------------------------#
# -- Alimentation quantité retournée en US
[F:PND]SRDQTYSTU += DELTAQTYSTU
# -- pas de maj si qté retournée > qté du retour
If [F:PND]SRDQTYSTU > [F:PND]QTYSTU
   GERR = 1 : GMESSAGE=mess(275,192,1) : GOK  = 0 : Return

Endif
# -- Alimentation du n°retour vente
If TRTLIG="C"
    [F:PND]SRHNUM=[F:SRD]SRHNUM
    [F:PND]SRDLIN=[F:SRD]SRDLIN
Elsif TRTLIG="A"
    # Suppression de la ligne : Recherche du dernier n° retour
    If [F:PND]SRDQTYSTU<>0
        Call RECH_DERSRDPND
    Else
        Raz [F:PND]SRHNUM, [F:PND]SRDLIN
    Endif
Endif
# -- Récriture du détail retour fournisseur
Rewrite [PND]
If fstat : GOK = 0 : Call FSTA("PND") From GLOCK : Return : Endif

Return
#########################################################################
Subprog RECH_DERSRDPND
#---------------------------------------------------------------------------------#
# Recherche dernier no retour vente de la ligne retour fsseur suite à suppression #
#---------------------------------------------------------------------------------#

Filter [SRD1] Where PNHNUM=[F:PND]PNHNUM & PNDLIN=[F:PND]PNDLIN
&            Order By Key NEWCLE=PNHNUM;PNDLIN
Read [SRD1]NEWCLE Last
If fstat = 0
   If ([F:SRD1]SRHNUM=[F:SRD]SRHNUM) & ([F:SRD1]SRDLIN=[F:SRD]SRDLIN)
      # Le dernier n°retour vente est celui qui est en cours de suppression : On lit le précédent
      Read [SRD1]NEWCLE Prev
      If fstat = 0
         [F:PND]SRHNUM = [F:SRD1]SRHNUM
         [F:PND]SRDLIN = [F:SRD1]SRDLIN
      Else
         Raz [F:PND]SRHNUM, [F:PND]SRDLIN
      Endif
   Else
      # Le dernier n°retour vente n'est pas celui qui est en cours de suppression : On le prend
      [F:PND]SRHNUM = [F:SRD1]SRHNUM
      [F:PND]SRDLIN = [F:SRD1]SRDLIN
   Endif
Else
   # Il n'y a pas d'autre retour vente pour cette ligne de retour fsseur
   Raz [F:PND]SRHNUM, [F:PND]SRDLIN
Endif
Filter [SRD1]
End
########################################################################
$MAJENTCDE
#---------------------------------------------#
# Maj entête de commande (traitement général) #
#---------------------------------------------#
Local  Decimal  MNTCALC, QTECALC

# Lecture avec lock de l'entête commande
Readlock [SOH] SOH0=[F:SDD]SOHNUM
If fstat = 1 : GOK = -1
   GLOCK = "$SORDER"-[F:SDD]SOHNUM : Return
Elsif fstat  GOK =  0
   Call RSTA ("SOH",[F:SDD]SOHNUM) From GLOCK : Return
Endif

# Lecture du détail prix
Readlock [SOP] SOP0=[F:SDD]SOHNUM;[F:SDD]SOPLIN;[F:SDD]SOQSEQ
If fstat = 1 : GOK = -1
   GLOCK = "$SORDERP"-[F:SDD]SOHNUM-num$([F:SDD]SOPLIN)-num$([F:SDD]SOQSEQ) : Return
Elsif fstat GOK = 0
   Call RSTA ("SOP",[F:SDD]SOHNUM-num$([F:SDD]SOPLIN)-num$([F:SDD]SOQSEQ)) From GLOCK : Return
Endif

#-- X3Suivi 85514 : Resynchronisation ITMMVT (SALSTO) si retour réactive la commande ---#
Local Decimal WQTYRET : Local Integer WSTA22 : WSTA22 = 1
#--- Si Commande Soldé et Livraison partiellement livrée, le retour désolde la commande --> recalcul SALSTO --#
If [F:SOH]ORDSTA=2 & [F:SOH]DLVSTA=2
  WSTA22 = 2
Endif

#-------------------------------------------------#
# Maj entête de commande en modification de ligne #
#-------------------------------------------------#
# La ligne de commande qui est en ligne n'est pas encore mise à jour

#QTECALC = [F:SOQ]ODLQTY+[F:SOQ]DLVQTY-[F:SRD]QTY
QTECALC = [F:SOQ]ODLQTY+[F:SOQ]DLVQTY-WRTNQTY
# La ligne de commande était soldée
If [F:SOQ]SOQSTA = 3
#  La qte cde devient > à la qte livrée --> la ligne n'est plus soldée
   If [F:SOQ]QTY > QTECALC
      [F:SOH]CLELINNBR -= 1
      [F:SOH]ORDSTA     = 1
   Endif
Endif

QTECALC = [F:SOQ]ALLQTY+[F:SOQ]OPRQTY+[F:SOQ]PREQTY+[F:SOQ]ODLQTY+[F:SOQ]DLVQTY
If [F:SOQ]STOMGTCOD <> 1
   # Il n'y avait plus rien à allouer sur la ligne de commande
   If QTECALC >= [F:SOQ]QTY
      #  Il y a maintenant une quantité à allouer sur la ligne de commande
      If QTECALC - [F:SRD]QTY < [F:SOQ]QTY
         [F:SOH]ALLLINNBR += 1
         If [F:SOH]ALLLINNBR >= [F:SOH]LINNBR : [F:SOH]ALLSTA = 1 : # La cde devient non allouée
            # On ne sait pas déterminer si la cde devient partiellement allouée ou non allouée
            # (Si aucune autre ligne gérée en stock, la cde est non allouée)
         Else                                   [F:SOH]ALLSTA = 2 : # La cde devient partiellement allouée
         Endif
      Endif
   Endif
Endif

QTECALC = [F:SOQ]DLVQTY+[F:SOQ]ODLQTY
# La ligne de commande était livrée
If QTECALC >= [F:SOQ]QTY
#  La ligne de commande n'est plus livrée
#   If QTECALC - [F:SRD]QTY < [F:SOQ]QTY
   If QTECALC - WRTNQTY < [F:SOQ]QTY
      [F:SOH]DLVLINNBR -= 1
      If [F:SOH]DLVLINNBR = 0 : [F:SOH]DLVSTA = 1 : # La cde devient non livrée
      Else                      [F:SOH]DLVSTA = 2 : # La cde devient partiellement livrée
      Endif
   Endif
Endif

#-------------------------------------#
# Maj des montants à livrer HT et TTC #
#-------------------------------------#
# Ecart entre qte cde et qte liv de la ligne cde
ECARTQTY = [F:SOQ]QTY - ([F:SOQ]ODLQTY+[F:SOQ]DLVQTY)
If ECARTQTY > 0
#      QTECALC = [F:SRD]QTY
      QTECALC = WRTNQTY
Else
#      If [F:SRD]QTY > abs(ECARTQTY) : QTECALC = [F:SRD]QTY - abs(ECARTQTY)
      If WRTNQTY > abs(ECARTQTY) : QTECALC = WRTNQTY - abs(ECARTQTY)
      Else                         QTECALC = 0
      Endif
Endif

MNTCALC = QTECALC * [F:SOP]NETPRINOT
Call ARRDEV(MNTCALC,[F:SOH]CUR) From TRTDIV
[F:SOH]DLRNOT += MNTCALC
MNTCALC = QTECALC * [F:SOP]NETPRIATI
Call ARRDEV(MNTCALC,[F:SOH]CUR) From TRTDIV
[F:SOH]DLRATI += MNTCALC

# Récriture de l'entête commande (SOH)
Rewrite [SOH]
If fstat : GOK = 0 : Call FSTA("SOH") From GLOCK : Return : Endif

#-----------------------------#
# Maj de l'en commande client #
#-----------------------------#
Raz WCDEHT, WCDETTC
#  Si la ligne cde n'était pas soldée, on annule ce qu'il restait à livrer
If [F:SOQ]SOQSTA <> 3 : ECARTQTY = 0 : Endif
#  Si diminution qte livrée < (qte liv-qte cde) de la cde, pas de maj
If ECARTQTY > 0 | (ECARTQTY <= 0 & [F:SDD]QTY > ECARTQTY*(-1))
#  Augmentation de l'en cde
   If (ECARTQTY + [F:SRD]QTY) > 0
#      WCDETTC = (ECARTQTY+[F:SRD]QTY) * [F:SOP]NETPRIATI
#      WCDEHT  = (ECARTQTY+[F:SRD]QTY) * [F:SOP]NETPRINOT
      WCDETTC = (ECARTQTY+WRTNQTY) * [F:SOP]NETPRIATI
      WCDEHT  = (ECARTQTY+WRTNQTY) * [F:SOP]NETPRINOT
   Endif
Endif

# Maj si cde signée ou Si Paramètre maj encours client cde non signée à "Oui" et cde non intra-société
If ([F:SOH]APPFLG>2 | GSOHAPPOST=2) & !([F:SOH]BETFCY=2 & [F:SOH]BETCPY<=1)
    # Maj mouvement client (en commande)
    Call MAJMVC ([F:SOH]BPCORD, [F:SOH]CUR, [F:SOH]CHGTYP, 0, [F:SOH]ORDDAT, [F:SOH]SOHNUM, [F:SOH]SALFCY,
&                WCDEHT, WCDETTC, "+", "F", "", [F:SOH]SOHCAT) From TRTBPMVT
    If  GOK<1 Return Endif
Endif
Raz WCDETTC, WCDEHT
Return

#####################################
## $RESYNCHO_SALSTO
#####################################
$RESYNCHO_SALSTO
#-- X3Suivi 85514 : Resynchronisation ITMMVT (SALSTO) si retour réactive la commande ---#
WQTYRET = 0
If clalev ([F:ORDW])=0 Local File ORDERS [ORDW] Endif
#-- Recalcul quantité en commande et cdes clients fermes
For [ORDW]ORD1 Where STOFCY=[F:ITV]STOFCY & ITMREF=[F:ITV]ITMREF &
&                    WIPSTA=1 & find(WIPTYP,1,2,5,7,8,9)
  If find([F:ORDW]WIPTYP,1,8)
    WQTYRET  += [F:ORDW]RMNEXTQTY
  Endif
Next
Default File [SRD]  : # 100356
Return

#########################################################################
$ETAT_ZONE

#--CPO 71065 Code affaire sur les retours
If GPJTSNGDOC = G_NON Then
  Call PJT_MODFCY([M:SRH0]STOFCY, "[M:SRH1]DPJT") From TRTPJT
Endif
#--/CPO

Actzo [M:SRH0]1-99
Actzo [M:SRH1]1-99
Actzo [M:SRH2]1-99

If GREP = "C"
   If GMANCOU <> 2 Diszo [M:SRH0]SRHNUM : Endif
Else
   Diszo [M:SRH0]STOFCY, BPCORD, BPAADD
   Diszo [M:SRH0]SRHTYP                   :#--CPO 75115
   Diszo [M:SRH2]AUZUSR
Endif

#--CPO 71065 Code affaire sur les retours
If GPJTSNGDOC = G_OUI Then
  Call PJT_MODFCY([M:SRH0]STOFCY, "[M:SRH1]DPJT") From TRTPJT
Endif
#--/CPO

Return
#########################################################################
$DEVERROU_PICKING

#-----------------------------------------------------------------------#
# Déverrouillage des documents bloqués par le picking                   #
#-----------------------------------------------------------------------#
Local Integer I
Local Char    SYMBOLE2(50)
# Déblocage des documents en cours de picking
For I=0 To [M:SRH1]NBLIG-1
   If [M:SRH1]CREFLG(I)=0 & [M:SRH1]DETSDHNUM(I)<>""
       SYMBOLE2 = "SDH"+[M:SRH1]DETSDHNUM(I)
       Unlock = SYMBOLE2
   Endif
   If [M:SRH1]CREFLG(I)=0 & [M:SRH1]PNHNUM(I)<>""
       SYMBOLE2 = "PNH"+[M:SRH1]PNHNUM(I)
       Unlock = SYMBOLE2
   Endif
Next I

Return
#########################################################################
$VERIF
#---------------------------------------------------#
# Verifications et traitements avant creation/modif #
#---------------------------------------------------#
# --> Vérification que tous les axes entête ont bien été saisis (s'il sont saississables)
If GHEADIE = 1 : # Axes entêtes saisissables (Initialisé par GETCPY)
   If dim([M]NBAXE)>0
      For nolign = 1 To GNBDIE
          If [M]CCE(nolign-1)="" & GOBLDIE(nolign)=2
             GERR=1 : GMESSAGE=mess(177,199,1) : OK=0 : Break
          Endif
      Next nolign
   Endif
   If OK = 0 Return Endif
Endif

# Issue X3-44998 - 2017-07-27 by CPO : Duplicated sale documents: analytical dimension not controlled (idem X3SUIVI93839)
#--This control has to be done also during Creation/Update of a document (moved outside GREP="D")
Gosub VERIF_CTL_ALLCCE From SUBSRHA
If OK=0 : Return : Endif
# End issue X3-44998

#---------------------------------------------------------------------#
# Contrôle de cohérence entre les quantités de STOENTW et le document #
#          et vérifie que les info lot sont validées                  #
#---------------------------------------------------------------------#
Call CTLSTOENT( "SRH1", "QTYSTU", [M:SRH1]NBLIG, OK ) From STKECR
If OK=0 Return : Endif
# --> Il doit y avoir au moins une ligne
If [M:SRH1]NBLIG = 0 GERR=1 : GMESSAGE = mess(61,199,1) : OK=0 : Return : Endif
Local Integer WQTENOK : WQTENOK=0
Local Integer WIJ

# BRBAN 01/09/2014 #93745
If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([M:SRH0]STOFCY,'')=1
  Raz WQTENOK,WIJ
  For WIJ=0 To [M:SRH1]NBLIG-1
    If [M:SRH1]QTY(WIJ)=0 : WQTENOK=WIJ+1 : Break : Endif
  Next
  If WQTENOK : GERR=1 : GMESSAGE = mess(160,195,1)-num$(WQTENOK)-mess(579,199,1) : OK=0 : Return : Endif
Endif

#--CPO 71065 Code affaire sur les retours
Call PJT_CONTROLE_HEAD_DETAIL("[M:SRH2]PJT", "[M:SRH1]DPJT") From TRTPJT
If GERR <> 0 Then
  OK = 0
  Return
Endif
#--/CPO

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN

Local Char    INVCAN_DOC(255) : [L]INVCAN_DOC = ""

# Alimentation du code structure
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If [F:CPY]CPY<>GSOCIETE
    Read [CPY] CPY0=GSOCIETE
    If fstat Raz [F:CPY] Endif
Endif

Raz WIJ
For WIJ = 0 To [M:SRH1]NBLIG-1
  If [M:SRH1]RTNCNOFLG(WIJ) = 2 & [M:SRH1]DETSDHNUM(WIJ) <> ''
    Local Integer   RET
    Local Char V_LEG(30)

    Call GETLEG([F:CPY]CPY,"",[L]V_LEG) From TRTLECLEG

    If func AFNC.ACTIV("INVCA") = 1 & func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"
      Call INVCAN_NOCREM([M:SRH1]DETSDHNUM(WIJ),[L]RET) From TRTINVCAN
      If [L]RET = 1
        [L]INVCAN_DOC += num$([M:SRH1]NBLIG-1) + ","
        [M:SRH1]RTNCNOFLG(WIJ) = 1
      Endif
    Endif
  Endif
Next

If [L]INVCAN_DOC <> ""
  [L]INVCAN_DOC = left$([L]INVCAN_DOC, len([L]INVCAN_DOC) - 1)
  Call ECR_TRACE(func AFNC.MES1(mess(193,7711,1),[L]INVCAN_DOC),0) From GESECRAN
Endif

Affzo [M:SRH1]RTNCNOFLG
#105200 RICAR 2015/05/25 - Inv Cancelation - END

If func AFNC.ACTIV("KPO")>0
  If func PORLEGLIB.CTLDOCTYP([M:SRH0]SRHTYP,"SRH",GMESSAGE) = 1
    OK = 0 : GERR = 1 : Return
  Endif
Endif

Return
#---------------------------------------------------------------------#
# Bug 81935
# Retour de livraison intersite sans mvt de stock :
# --> Maj stock transit et transféré car ils ont été maj à la livraison ou au retour fsseur
#     (sortie de stock donc maj systématique des stocks)
#-------------------------------#
# Maj des mouvements articles   #
#-------------------------------#
$MAJ_ITMMVT
Local Integer LRET
Local Char    LSENS : LSENS="-"
Local Char    LTYP
# Mise à jour du stock sur le site d'expédition
If [F:SRD]PNHNUM<>""
  LTYP="TRF"  : # Retour issu d'un retour fournisseur : Maj stock en transit
Else
  LTYP="TRA"  : # Retour issu d'une livraison         : Maj stock transféré
Endif
Call  MAJITVVEN ([F:SRD]ITMREF, [F:SRD]STOFCY, DELTAQTYSTU, LSENS, LTYP, LRET) From TRTVENMAJ

# Mise à jour sur le site de réception
If [F:SRD]PNHNUM<>""
  LTYP="TRA"  : # Retour issu d'un retour fournisseur : Maj stock transféré
Else
  LTYP="TRF"  : # Retour issu d'une livraison         : Maj stock en transit
Endif

Call  MAJITVVEN ([F:SRD]ITMREF, [M]PNHFCY, DELTAQTYSTU, LSENS, LTYP, LRET) From TRTVENMAJ

Return
# Bug 81935

#########################################################################
#-------------------------------#
# Maj des stocks                #
#-------------------------------#
$MAJ_STOCK

Local Decimal LQTA
Local Decimal LSHT
Local Integer LNBR, LNBJ, LRET
Local Char     LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)

Raz [M:STW]
[M:STW]STOFCY  = [M:SRH0]STOFCY
[M:STW]TRSTYP  = 12
[M:STW]TRAFLG  = 1 : # Pas de trace
[M:STW]VCRTYP  = 13
[M:STW]VCRNUM  = [M:SRH0]SRHNUM
[M:STW]VCRLIN  = [M:SRH1]SRDLIN (NOL)
[M:STW]ITMREF  = [M:SRH1]ITMREF (NOL)
[M:STW]MVTDES  = [M:SRH1]MVTDES (NOL)
[M:STW]PRIORDH = [M:SRH1]PRIORD (NOL)
[M:STW]PJT     = ""
[M:STW]TRSFAM  = [M:SRH2]TRSFAM
[M:STW]TRSCOD  = [M:SRH0]TRSCOD
#[M:STW]ENTCOD  = WSLTENTCOD
[M:STW]ENTCOD  = [M:SRH0]ENTCOD
[M:STW]IPTDAT  = [M:SRH1]DETRTNDAT (NOL)
[M:STW]BPRNUM  = [M:SRH0]BPCORD
[M:STW]CUR     = [M:SRH1]CUR
If [M:SRH1]BETFCY=2
    [M:STW]TRFFCY = [M:SRH0]PNHFCY
    [M:STW]BETCPY = [M:SRH1]BETCPY
Else
    [M:STW]TRFFCY = ""
    [M:STW]BETCPY = 1
Endif
If [M:SRH1]PNHNUM(NOL) <> ""
    [M:STW]VCRTYPORI2 = 8
    [M:STW]VCRNUMORI2 = [M:SRH1]PNHNUM(NOL)
    [M:STW]VCRLINORI2 = [M:SRH1]PNDLIN(NOL)
Endif
If [M:SRH1]DETSDHNUM(NOL) <> ""
    [M:STW]VCRTYPORI = 4
    [M:STW]VCRNUMORI = [M:SRH1]DETSDHNUM(NOL)
    [M:STW]VCRLINORI = [M:SRH1]SDDLIN(NOL)
    #--- Bug 59617
    If [F:SDD]SDHNUM<>[M:STW]VCRNUMORI & [F:SDD]SDDLIN<>[M:STW]VCRLINORI
       Read [SDD]SDD0=[M:STW]VCRNUMORI;[M:STW]VCRLINORI
    Endif
    [M:STW]ORIFCY = [F:SDD]STOFCY
    #---
# 106058
Elsif [M:SRH1]PNHNUM(NOL) <> ""
    [M:STW]VCRTYPORI = 8
    [M:STW]VCRNUMORI = [M:SRH1]PNHNUM(NOL)
    [M:STW]VCRLINORI = [M:SRH1]PNDLIN(NOL)
    If [F:PND]PNHNUM<>[M:STW]VCRNUMORI & [F:PND]PNDLIN<>[M:STW]VCRLINORI
       Read [PND]PND0=[M:STW]VCRNUMORI;[M:STW]VCRLINORI
    Endif
    [M:STW]ORIFCY = [F:PND]PNHFCY
# 106058
Endif
[M:STW]CCECOD  ="STKSRT"

# Issue 80482 - 2012-04-24 by CCC : Le détail de prix n'était pas renseigné
Raz [M:VALW]
Raz LECCMAJ, LECCMIN
If dim([M:SRH1]ECCVALMAJ)>0
    [L]LECCMAJ = string$([M:SRH1]ECCVALMAJ(NOL)<>"$",[M:SRH1]ECCVALMAJ(NOL))
    [L]LECCMIN = string$([M:SRH1]ECCVALMIN(NOL)<>"$",[M:SRH1]ECCVALMIN(NOL))
Endif
Call SETNEWPRI([M:SRH1]ITMREF(NOL),LECCMAJ,LECCMIN,[M:SRH0]STOFCY,[M:SRH1]DETRTNDAT(NOL),[M:SRH1]WSTOSEQ(NOL),[M:SRH1]PRIORD(NOL),"") From STKVAL
Call ALISTOWORK (2,[M:SRH1]WSTOSEQ(NOL),LQTA,LSHT,LNBR,LNBJ,LRET) From STKINT
Call MAJ_STOCK From STKMAJ
If GOK
   If GREP <> "A"
      Call STKFREQCQ("SRH1",[M:SRH0]STOFCY,NOL,[M:SRH1]ITMREF(NOL),"","V",[M:SRH1]QUAFLG(NOL),0) From STKACT   # hcb V6CQ (freq)
   Endif
Endif

Return
#--------------------------------------------------------------------------#
# Chargement des paramètres avec GFCY = Site du retour                     #
# ------------------------------------------------------------------------ #
# Chargement des globales référenciels, comptes et sections de la société  #
# Chargement des paramètres de localisation                                #
# ------------------------------------------------------------------------ #
$CHARG_PARAM

# --- Chargement des globales référenciels, comptes et sections de la société
Call GETCPY(GFCY,"SLT",6,GFLAG) From TRTX3CPT
#--CPO 71065 Code affaire sur les retours
GPJTSNGDOC = func TRTPJT.GET_PARAM_PJTSNGDOC(GFCY)
#--/CPO

#--CPO 75115 Remplacé par appel à REC_CPT_RET en fonction de SRHTYP etc.
# --- Si changement société
#If GSOC_UPDFLG
#    # --- Récupération du code compteur
#    If dim(OK)<1  Local Integer OK : Endif
#    Call LECTCA(5,OK) From SUBTCA
#    If fstat | !OK
#        GERR=1 : GMESSAGE=mess(58,105,1)-mess(5,14,1)-mess(250,199,1) : Return
#    Endif
#    GMANCOU=[F:TCA]MANCOU(2) : GCPT=[F:TCA]CODNUM(2)
#Endif

Return
##########################################################################################################
#------------------------------------------------------------------------#
# Affichage entêtes colonnes variables (comptes et sections analytiques) #
#------------------------------------------------------------------------#
$AFF_TITCOL
If GSOC_UPDFLG & !GIMPORT & dim([M:SRH1]CCE1)>0
  Local Char BASPAG(10)
  BASPAG="NBLIG" : Gosub TIT_COL From ="W1WK6"+GFLAG+"1"
  #----- Pour forcer l'utilisation des formats évalués si tableau vide -----#
  If [M:SRH1]NBLIG=0
    [M:SRH1]NBLIG=1 : Affzo [SRH1]20 : Effzo [SRH1]20
  Endif
  #-----
Endif
Raz GSOC_UPDFLG
Return

#########################################
$GRISE
# Accès à un document créé en multi-dépôt avec une transaction mono-dépôt
# --> pas d'application du mono-dépôt
If [F:SRH]WRHE="" & GWRHOBY=2
   GWRHOBY=1
   If [M]STOFCY<>[F:FCY]FCY : Read [FCY]FCY0=[M]STOFCY : Endif
   If [F:FCY]WRHGES=2 : Call MESSAGE(mess(351,184,1)) From GESECRAN : Endif
Endif
Return

#------------------------------------------#
# Actzo ou Grizo des dépôts selon le site  #
#------------------------------------------#
$WRH_ETAT
If GWRHACT<>2 Return Endif
If [M]STOFCY<>[F:FCY]FCY
   Read [FCY]FCY0=[M]STOFCY
Endif
If [F:FCY]WRHGES=2
   If find(GREP,"C","D")
      Actzo [M:SRH1]WRHE
      If GWRHOBY=2
         Diszo [M:SRH1]WRH
      Else
         Actzo [M:SRH1]WRH
      Endif
   Elsif [M:SRH1]WRHE<>""
      Diszo [M:SRH1]WRHE
      Diszo [M:SRH1]WRH
   Else
      Actzo [M:SRH1]WRHE
      Actzo [M:SRH1]WRH
   Endif
Else
  Raz   [M:SRH1]WRHE
  Grizo [M:SRH1]WRHE
  Grizo [M:SRH1]WRH
Endif
Return

