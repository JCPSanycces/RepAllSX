#LIPET - 2017-05-11 - X3-35993 - START
Subprog CTRL_DATES_PLF(DATDEB,DATFIN)
Value Date    DATDEB,DATFIN

  If DATFIN=[0/0/0] Then End : Endif

  If year(DATDEB)=year(DATFIN) Then
    End
  Else
    If year(DATDEB)+2<year(DATFIN) Then
      GMESSAGE=mess(310,10717,1) : # Le plan prévisionnel ne doit pas excéder 24 mois
      mkstat=2
    Endif
  Endif
End
#LIPET - 2017-05-11 - X3-35993 - END
######################################################################################
#LIPET - 2017-05-11 - X3-35993 - START
Subprog GRISE_FLGCLO(P_FLGCLO)
Value Integer P_FLGCLO
If P_FLGCLO = 2 Then
  Diszo [M:PLF1] : Diszo [M:PLF2] : Diszo [M:PLF3] : Diszo [M:PLF4]
Else
  Actzo [M:PLF1] : Actzo [M:PLF2] : Actzo [M:PLF3] : Actzo [M:PLF4]
Endif
End
#LIPET - 2017-05-11 - X3-35993 - END
#####################################################################################

$OUVRE
If clalev([F:ADI])=0    : Local File ATABDIV  [ADI]   : Endif
If clalev([F:ADI2])=0   : Local File ATABDIV  [ADI2]  : Endif
If clalev([F:ID])=0     : Local File EMPLOID  [ID]    : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR [HRCTR] : Endif
If clalev([F:ECT])=0    : Local File EMPCTR   [ECT]   : Endif
If clalev([F:DEM])=0    : Local File DEMANDE  [DEM]   : Endif
If clalev([F:DML])=0    : Local File DEMLIG   [DML]   : Endif
If clalev([F:STG])=0    : Local File STAGE    [STG]   : Endif
If clalev([F:HRSES])=0  : Local File SESSIONS [HRSES] : Endif
If clalev([F:FCY])=0    : Local File FACILITY [FCY]   : Endif
If clalev([F:COU])=0    : Local File COUT     [COU]   : Endif
If clalev([F:HRCOR])=0  : Local File COUTREEL [HRCOR] : Endif
If clalev([F:PLFF])=0   : Local File PLNFORM  [PLFF]  : Endif
# SYMEU : EXI 66191 LOT 11 - V6.1 : table DEMANDE pour la màj de l'année du plan définitif
# dans les demandes
If clalev([F:DEM2])=0   : Local File DEMANDE  [DEM2]  : Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 : table DEMLIG pour alimentation des zones supplémentaires
# des demandes
If clalev([F:DML2])=0   : Local File DEMLIG   [DML2]  : Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 : table BUDREF pour afficher le montant du budget référence
If clalev([F:BUR])=0    : Local File BUDREF   [BUR]   : Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 : table EMPLOCTR pour calcul des taux moyens des participants
If clalev([F:CTR2])=0   : Local File EMPLOCTR [CTR2]  : Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation des coûts
Global Integer FLAG_REVALO : FLAG_REVALO = 1
# SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation des coûts, pour affichage message
Global Integer FLAG_MESSAGE : FLAG_MESSAGE = 1
# SYMEU : EXI 66191 LOT 10 - V6.1 : picking des demandes de formation
If clalev([F:TDM])=0 : Local File TMPDEMANDE  [TDM] : Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini
Global Char L_STAGE_NON_DEF(GLONSTG)
L_STAGE_NON_DEF = func DIVFOR.GET_STG_NON_DEF
# SYMEU : EXI 66191 LOT 10 - V6.1 : nouvelle table PLNBUD, pour enveloppes de coûts
If clalev([F:HRPLB])=0 : Local File PLNBUD  [HRPLB] : Endif
# FQ70589 - MABON 25/03/11 - Ouverture table si le lien sur le service n'est pas activé dans la transaction de saisie
If clalev([F:SRV])=0 : Local File SERVICE [SRV] : Endif

## Pour le VTB qui gère la liste de picking
Local Integer NBPAR

#40237
#Link [DML] With [DEM]DEM0=[F:DML]DEMNUM, [ID]ID0=[F:DEM]REFNUM
#& As [LDML]
#& Where [DML]STA=len(mess(0,10454,1)) & [DML]FLGINS<3 & [DEM]YEAPLF<>""
#& Order By Key CLE=[F:DEM]THM;STG;DEMNUM

# SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (plus de filtre sur l'année, et
# seulement pour demandes qui ne sont pas hors plan et dont Suivi = Saisie) (demandes qui ne
# sont pas déjà dans un plan définitif)
#Link [DML] With [DEM]DEM0=[F:DML]DEMNUM, [ID]ID0=[F:DEM]REFNUM
#& As [LDML]
#& Where [DML]STA=len(mess(0,10454,1)) & [DML]FLGINS<3 & [DEM]YEAPLF<>""
#& Order By Key CLE=[F:DEM]THM;[F:DEM]STG;[F:DEM]DEMNUM

#Link [DML] With [DEM]DEM0=[F:DML]DEMNUM, [ID]ID0=[F:DEM]REFNUM
#& As [LDML]
#& Where [DML]STA=len(mess(0,10454,1)) & [DML]FLGINS=1
#&   and [F:DEM]FLGPLF=1 and [F:DEM]YEAPLF=""
#& Order By Key CLE=[F:DEM]THM;[F:DEM]STG;[F:DEM]DEMNUM

Link [DML] With [DEM]DEM0=[F:DML]DEMNUM, [ID]ID0=[F:DEM]REFNUM, [ECT]ECT0=[F:DEM]REFNUM;[F:DEM]CTR
& As [LDML]
& Where [DML]STA=len(mess(0,10454,1)) & [DML]FLGINS=1
&   and [F:DEM]FLGPLF=1 and [F:DEM]YEAPLF=""
& Order By Key CLE=[F:DEM]THM;[F:DEM]STG;[F:DEM]DEMNUM

For [LDML]CLE(3)
 NBPAR +=1
Next

# 40594
If NBPAR=0
 NBPAR = 1
Endif

# SYMEU : EXI 66191 LOT 10 - V6.1 : on ajoute le prénom WSRN
Local Char    WTHM(GLONADI)(1..NBPAR),WDESTHM(GLONDES)(1..NBPAR),WSTG(GLONSTG)(1..NBPAR),WDEMNUM(GLONVCR)(1..NBPAR)
&           , WNAM(40)(1..NBPAR),WSRN(40)(1..NBPAR),WYEAPLF(4)(1..NBPAR),WCPY(GLONCPY)(1..NBPAR),WFCY(GLONFCY)(1..NBPAR)
Local Date    WDATDEM(1..NBPAR)

# SYMEU : EXI 66191 LOT 10 - V6.1 : on ajoute le prénom WSRN
# SBA : 20120626 ne semble plus utilisé
#Local File   (Char THM(GLONADI),Char DESTHM(GLONDES),Char STG(GLONSTG),Char DEMNUM(GLONVCR),Char NAM(40),
#&             Char SRN(40), Date DATDEM, Char YEAPLF(4),Char CPY(GLONCPY),Char FCY(GLONFCY))
#&             From Variable WTHM,WDESTHM,WSTG,WDEMNUM,WNAM,WSRN,WDATDEM,WYEAPLF,WCPY,WFCY As [DDEM]
#&             Order By Key CLE=THM ; STG ; DEMNUM
##
#fin SBA provoque un plantage sur affichage -> choisir une transaction
Local Integer I, J, K, WPICK, NBSUP, TYP
# 40594
Local Integer SAVADXMXL
Local Decimal TXSAL1, TXSAL2, TXPAT1, TXPAT2, NBH
Local Char    CRIT1(250)
Local Mask PLFFIL [PFI]
Raz [PFI]
[M:PFI]NAL    = 1
[M:PFI]ALLCPY = 2
[M:PFI]ALLFCY = 2
#LIPET - 2017-05-11 - X3-35993 - START
# Issue X3-11279 - 2017-01-25 by BRBAN : Default value
[M:PFI]ALLSRV = 2
Global Integer WOKFIL : [V]WOKFIL = 0
# -
# X3-11689
If clalev([F:HRTCR])=0 : Local File HRTRACSTREP     [HRTCR] : Endif
Local Integer LIN, LINREF
#LIPET - 2017-05-11 - X3-35993 - END
If clalev([F:CPY])=0    : Local File COMPANY [CPY]   : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

#LIPET - 2017-05-11 - X3-35993 - START
Subprog EFFTYPCRGI(J,COD,WTYPCST)
Value Decimal J
Value Char COD
Value Integer WTYPCST
Local Integer I,L

For I=[M:PLF1]NBRINV-1 To 0 Step -1
  If [M:PLF1]CHAMP(I)=num$(J)+COD
    # tout type ou automatique ou manuel
    If WTYPCST=0 | (WTYPCST<>0 &  WTYPCST=[M:PLF1]TYPCSTI(I)) : # X3-17093
      Dela I,1 [M:PLF1]NBRINV
      [M:PLF1]NBRINV-=1
    Endif : # X3-17093
  Endif
Next
#Affzo [PLF1]20 :# X3PEOP-11689 - to remove
End
#LIPET - 2017-05-11 - X3-35993 - END

#TIVAN - 06/07/2017 - X3-35993 - Start
# X3-11689
Subprog EFFTYPCRG(COD)
Value Char COD
Local Integer I,L

For I=[M:PLF1]NBRCST-1 To 0 Step -1
  If [M:PLF1]TYPCRG(I)=COD
    Dela I,1 [M:PLF1]NBRCST
    [M:PLF1]NBRCST-=1
  Endif
Next
Affzo [M:PLF1]15
End
#TIVAN - 06/07/2017 - X3-35993 - End

#LIPET - 2017-05-11 - X3-35993 - START
# X3-11689
$DECL_REPART
 Local Integer REPART_TODO, INV1, INV2 :# X3-17093
 Local Char TIMESTP(20) # X3-17093
 Local Decimal RESULT(0..1)
 Local Char WTCRCOD(5)
 Local Decimal WCSTTOTIDV, WCSTIPTIDV
 # X3-17093
 # for trtcout
 Local Char W_TCRCOD(20),W_TYPCRG(20)
Return
#LIPET - 2017-05-11 - X3-35993 - END

#LIPET - 2017-05-11 - X3-35993 - START
# X3-17093
$IS_REPART_TODO
  [L]REPART_TODO=0
  [L]W_TCRCOD=[L]WTCRCOD
  [L]W_TYPCRG=[F:ADI]CODE
  Gosub GET_RECORD_REP From TRTCOUT
  [L]REPART_TODO=[L]IS_REP
  # repartition des frais
#  If [L]WTCRCOD<>""
#    Read [F:HRTCR]HRTCR1(2)=[L]WTCRCOD;[F:ADI]CODE
#    If !fstat
#      [L]REPART_TODO=1
#    Endif
#  Endif
Return
#LIPET - 2017-05-11 - X3-35993 - END

#TIVAN - 06/07/2017 - Start
# X3-11689
$GET_REPART_CODE
[L]WTCRCOD=""
If [F:DEM]STG<>""
  If [F:DEM]STG<>[F:STG]COD
    Read [STG]STG0=[F:DEM]STG
    If fstat : Raz [F:STG] : Endif
  Endif
  [L]WTCRCOD= [F:STG]TCRCOD
Endif
Return
#TIVAN - 06/07/2017 - End

#LIPET - 2017-05-11 - X3-35993 - START
# X3-17093
$REPART_PLF1_INV
# 1st line
If NOT_PICKING
  # already done - from visible table
Else
  [M:PLF1]TYPFINI(INV1) = [F:HRTCR]TYPFIN
  [M:PLF1]ORGFINI(INV1) = [F:HRTCR]ORGFIN
  [L]TIMESTP=timestamp$
  [M:PLF1]LNKREPI(INV1) = [L]TIMESTP
Endif

# 2nd line
[M:PLF1]NBRINV +=1
# insert 2nd line
Insa INV1+1,1,[M:PLF1]NBRINV [M:PLF1]NBRINV
INV2=INV1+1
[M:PLF1]TYPCRGI(INV2)    = [M:PLF1]TYPCRGI(INV1)
[M:PLF1]TYPFINI(INV2)    = [M:PLF1]TYPFINI(INV1)
[M:PLF1]TYPCSTI(INV2)    = 1 # Automatique
[M:PLF1]CSTTOTCLLI(INV2) = 0
[M:PLF1]CSTIPTCLLI(INV2) = 0
[M:PLF1]DESTYPFRTI(INV2) = [M:PLF1]DESTYPFRTI(INV1)

[M:PLF1]NUMLIGI(INV2)    = [M:PLF1]NUMLIGI(INV1)
[M:PLF1]LNKREPI(INV2)    = [M:PLF1]LNKREPI(INV1)+"D" :# X3-17093
[M:PLF1]CHAMP(INV2)      = [M:PLF1]CHAMP(INV1)

If NOT_PICKING
  If I>=dim([M:PLF1]TYPCRG)
    # 'Tableau des coûts plein'
    GMESSAGE=mess(304,10717,1)
    Return
  Endif
  # from visible table
  [M:PLF1]ORGFINI(INV2)    = [M:PLF1]ORGFIN(I)
  # Amounts shared
  [M:PLF1]CSTTOTIDVI(INV2) = [M:PLF1]CSTTOTIDV(I)
  [M:PLF1]CSTIPTIDVI(INV2) = [M:PLF1]CSTIPTIDV(I)
Else
  [M:PLF1]ORGFINI(INV2)    = [F:HRTCR]ORGFIN2
  # # share amounts between 1st and 2nd lines
  # arrondi
  Call  CALCULATE( [L]WTCRCOD,[M:PLF1]TYPCRGI(INV1),[M:PLF1]TYPFINI(INV1),[M:PLF1]ORGFINI(INV1),[L]NBH,0,[M:PLF1]CSTTOTIDVI(INV1),[L]RESULT) From SUBHRTCR
  [M:PLF1]CSTTOTIDVI(INV1)=arr([L]RESULT(0),0.01)  :  # 1st line
  [M:PLF1]CSTTOTIDVI(INV2)=arr([L]RESULT(1),0.01)  :  # 2nd line

  Call  CALCULATE( [L]WTCRCOD,[M:PLF1]TYPCRGI(INV1),[M:PLF1]TYPFINI(INV1),[M:PLF1]ORGFINI(INV1),[L]NBH,0,[M:PLF1]CSTIPTIDVI(INV1),[L]RESULT) From SUBHRTCR
  [M:PLF1]CSTIPTIDVI(INV1)=arr([L]RESULT(0),0.01) :  # 1st line
  [M:PLF1]CSTIPTIDVI(INV2)=arr([L]RESULT(1),0.01) :  # 2nd line
Endif
Return
#LIPET - 2017-05-11 - X3-35993 - END
#####################################################################################################################
#TIVAN - 06/07/2017 - X3-35993 - Start
# FQ70605 - MABON 28/03/11 - Remplissage de la grille des demandes sélectionnables
$DEBUT
Local Integer I, OKENR
Local Char    CRIT1 (250), CRIT2 (250), CRIT3 (250), CRIT4 (250)

  # FQ81085 - US1637 - 31/05/13 - Ajout Catégorie 2483 dans la fenêtre de sélection, uniquement si FRA
  Case [M:DIA]LEGPLF1
    When "FRA"
      Chgfmt [M:LDEM]CATFRT With "KP:10BX"
    When Default
      Chgfmt [M:LDEM]CATFRT With "-KP:10AX"
      Raz [M:LDEM]CATFRT
  Endcase
  # Fin FQ81085

  # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (plus de filtre sur l'année)
  # CRITDEM = 'STG<>"" & YEAPLF="'+num$([M:DIA]YEAPLF1)+'"'
  # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (la demande ne doit pas être sur un plan définitif)
  CRITDEM = '[F:DEM]STG<>""  & [F:DEM]YEAPLF=""'
  # SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini : on ne le prend pas
  If L_STAGE_NON_DEF <> "" Then
    CRITDEM -= '& [F:DEM]STG<>"'+L_STAGE_NON_DEF+'"'
  Endif
  # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (filtre sur les demandes qui ne
  # sont pas hors plan)
  CRITDEM -= '& [F:DEM]FLGPLF=1'
  # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (prendre en compte la borne de
  # dates de demande)
  If [M:DIA]STRDAT <> [0/0/0] Then
    CRITDEM -= '& [F:DEM]DATDEM >=['+format$(GFMD,[M:DIA]STRDAT)+']'
  Endif
  If [M:DIA]ENDDAT <> [0/0/0] Then
    CRITDEM -= '& [F:DEM]DATDEM <=['+format$(GFMD,[M:DIA]ENDDAT)+']'
  Endif

  CRITDML = '[F:DML]FLGINS=1' : # Demande saisie (ni sur plan définitif, ni inscrite, ni réalisée)
  # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (ajout de critères : société, site)
  If [M:DIA]CPYPLF1 <> "" Then
    CRITDML -= '& [F:DML]CPY="'+[M:DIA]CPYPLF1+'"'
  Endif
  If [M:DIA]FCYPLF1 <> "" Then
    CRITDML -= '& [F:DML]FCY="'+[M:DIA]FCYPLF1+'"'
  Endif

  For L=1 To len(mess(0,10454,1))
    If [M:DIA]REPDEM(L-1)=1
      CRITDML -= '& [F:DML]STA<>'+num$(L)
    Endif
  Next

  Link [F:DML] With [F:DEM]DEM0=[F:DML]DEMNUM As [DM_] Where evalue(CRITDEM) & evalue(CRITDML)
  I=0
  For [F:DM_]
    If I<dim([M:LDEM]SELFLG) Then
      Call FILL_LDEM(I, OKENR) From SUBPLF
      If OKENR=2 Then I += 1 : Endif
    Else
      Break
    Endif
  Next
  [M:LDEM]NBDEMPLF=I
  Affzo [M:LDEM]
Return
#TIVAN - 06/07/2017 - X3-35993 - End
#####################################################################################################################
$READ_BUR
# JML 02/09/2015 We need a budget to have the startind/ending dates
Read [BUR]BUR0(4)=[F:PLF]YEAPLF;[F:PLF]CPYPLF;[F:PLF]FCYPLF; [F:PLF]LEGPLF
If fstat
 Raz [F:BUR]
 Actzo [M:PLF0]STRDAT, ENDDAT
 [M:PLF0]STRDAT = [F:PLF]STRDAT
 [M:PLF0]ENDDAT = [F:PLF]ENDDAT
Else
 Grizo [M:PLF0]STRDAT, ENDDAT
 [M:PLF0]STRDAT = [F:BUR]STRDAT
 [M:PLF0]ENDDAT = [F:BUR]ENDDAT
Endif
Affzo [M:PLF0]STRDAT,ENDDAT
Return
#####################################################################################################################
#TIVAN - 06/07/2017 - X3-35993 - Start
$FILGAUCHE
If currbox=BOXPIC : # Liste de picking
 # SYMEU : EXI 66191 LOT 10 - V6.1 : fonction Proposition (plus de filtre sur l'année)
 # FILGAUSUP(IFILGAUSUP) = 'YEAPLF="'+[M:PLF0]YEAPLF+'"'
 FILGAUSUP(IFILGAUSUP) = '1=1'
 If [M:PFI]NAL=2
  FILGAUSUP(IFILGAUSUP) -= '& FCY = ""'
 Else
  If [M:PFI]ALLCPY<>2
   FILGAUSUP(IFILGAUSUP) -= '& CPY = "'+[M:PFI]CPY+'"'
  Endif
  If [M:PFI]ALLFCY<>2
   FILGAUSUP(IFILGAUSUP) -= '& FCY = "'+[M:PFI]FCY+'"'
  Endif
 Endif
#LIPET - 2017-05-11 - X3-35993 - START
 # Issue X3-11279 - 2017-01-24 by BRBAN : added Department filter
 If [M:PFI]ALLSRV<>2
   FILGAUSUP(IFILGAUSUP) -= '& SRV = "'+[M:PFI]SRV+'"'
 Endif
 # -
#LIPET - 2017-05-11 - X3-35993 - END
 # 40594
 # FQ81085 - MABON 25/06/12 - Filter left list according LEGFIL
 If GCURLEG<>""
  FILGAUSUP(IFILGAUSUP) -= "& (find(LEG,'"+GCURLEG+"','')>0)"
 Endif
 # End MABON
 adxmxl=SAVADXMXL
Endif
Return
#####################################################################################################################
$LIENS
# Mise à jour de la session dans le tableau des lignes du plan
If [M:PLF1]DEMNUM(nolign-1)<>""
 Call LECTURE("DEM",[M:PLF1]DEMNUM(nolign-1),"") From CONTOBJ
 [M:PLF1]SES(nolign-1) = [F:DEM]SES
 # SYMEU : EXI 66191 LOT 10 - V6.1 - DEBUT
 # on renseigne les colonnes supplémentaires de la demande
 If [M:PLF1]EMP(nolign-1) <> "" Then
   Filter [F:DML2] Where DEMNUM=[M:PLF1]DEMNUM(nolign-1) and EMP=[M:PLF1]EMP(nolign-1)
 Else
   Filter [F:DML2] Where DEMNUM=[M:PLF1]DEMNUM(nolign-1)
 Endif
 [M:PLF1]STA(nolign-1) = 0
 For [F:DML2]
  [M:PLF1]STA(nolign-1) = [F:DML2]STA
  Break
 Next
 Filter [F:DML2]
 [M:PLF1]ORI(nolign-1) = [F:DEM]ORIDEM
 [M:PLF1]FLGPRO(nolign-1) = [F:DEM]FLGPRO
 [M:PLF1]DAT(nolign-1) = [F:DEM]DATDEM
 [M:PLF1]DOM(nolign-1) = [F:DEM]DOM
 [M:PLF1]THM(nolign-1) = [F:DEM]THM
 [M:PLF1]PIO(nolign-1) = [F:DEM]PIO
 # SYMEU : EXI 66191 LOT 10 - V6.1 - FIN
Else
 # SYMEU : EXI 66191 LOT 10 - V6.1 - DEBUT
 # on initialise les colonnes supplémentaires de la demande
 [M:PLF1]STA(nolign-1) = 0
 [M:PLF1]ORI(nolign-1) = 0
 [M:PLF1]FLGPRO(nolign-1) = 0
 Raz [M:PLF1]DAT(nolign-1)
 [M:PLF1]DOM(nolign-1) = [F:PLF]DOM
 [M:PLF1]THM(nolign-1) = [F:PLF]THM
 [M:PLF1]PIO(nolign-1) = [F:PLF]PIO
 If [M:PLF1]PIO(nolign-1) = 0 Then [M:PLF1]PIO(nolign-1) = 1 Endif
 # SYMEU : EXI 66191 LOT 10 - V6.1 - FIN
Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 - fiche 71317 (bug)
If [M:PLF1]PIO(nolign-1) = 0 Then
  [M:PLF1]PIO(nolign-1) = 1
Endif

# On stocke les coûts du plan dans le tableau invisible
# SYMEU : EXI 66191 LOT 10 - V6.1 : on ajoute la société et le site
# Filter [PLC] Where YEAPLF=[F:PLF]YEAPLF & VERPLF=[F:PLF]VERPLF & NUMLIG=[F:PLF]NUMLIG
# FQ81085 - MABON 22/05/12 - Adding field LEGPLF
Filter [PLC] Where YEAPLF=[F:PLF]YEAPLF & VERPLF=[F:PLF]VERPLF & NUMLIG=[F:PLF]NUMLIG
&                & CPYPLF=[F:PLF]CPYPLF & FCYPLF=[F:PLF]FCYPLF
&                & LEGPLF=[F:PLF]LEGPLF
For [PLC]PLC0
 [M:PLF1]NUMLIGI(I)    = [F:PLC]NUMLIG
 [M:PLF1]TYPCRGI(I)    = [F:PLC]TYPCRG
 [M:PLF1]TYPCSTI(I)    = [F:PLC]TYPCST # SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
 [M:PLF1]CSTTOTCLLI(I) = [F:PLC]CSTTOTCLL
 [M:PLF1]CSTTOTIDVI(I) = [F:PLC]CSTTOTIDV
 [M:PLF1]CSTIPTCLLI(I) = [F:PLC]CSTIPTCLL
 [M:PLF1]CSTIPTIDVI(I) = [F:PLC]CSTIPTIDV
 [M:PLF1]DESTYPFRTI(I) = [F:PLC]DESTYPFRT
 [M:PLF1]TYPFINI(I)    = [F:PLC]TYPFIN
 [M:PLF1]ORGFINI(I)    = [F:PLC]ORGFIN
 #LIPET - 2017-05-11 - X3-35993 - START
 [M:PLF1]LNKREPI(I)    = [F:PLC]LNKREP   :# X3-17093
 #LIPET - 2017-05-11 - X3-35993 - END
 [M:PLF1]CHAMP(I)      = num$([F:PLC]NUMLIG)+[F:PLC]TYPCRG
 I +=1
Next
Filter [PLC]
# SYMEU : EXI 66191 LOT 10 - V6.1 : on renseigne le prénom, l'emploi type et le poste - DEBUT
If [M:PLF1]EMP(nolign-1) <> "" Then
  If [M:PLF1]EMP(nolign-1) <> [F:ID]REFNUM Then
    Read [ID]ID0=[M:PLF1]EMP(nolign-1)
  Endif
  [M:PLF1]SRN(nolign-1) = [F:ID]SRN
  If [M:PLF1]CTRNUM(nolign-1) <> "" Then
    Filter [HRCTR] Where REFNUM=[M:PLF1]EMP(nolign-1) & CTRNUM=[M:PLF1]CTRNUM(nolign-1) & CTRDAT<=date$
    Read [HRCTR]CTR0 Last
    Filter [HRCTR]
    If !fstat
      [M:PLF1]JOBPOT(nolign-1) = [F:HRCTR]JOBPOT
      [M:PLF1]POT(nolign-1)    = [F:HRCTR]POT
      #SBA : 27/06/2012
      # ne sert à rien. GCURLEG suffit. GSOCIETE pose problème car uniquement inititalisé sur la présence
      # d'un contrat au chargement du document. Il n'est jamais réinitialisé par la suite
#      Call LECTURE("FCY",[HRCTR]ETRFCY,"") From CONTOBJ
#      Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
#      GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
      #SBA fin
    Endif
  Endif
Else
  [M:PLF1]JOBPOT(nolign-1) = [F:PLF]JOBPOT
  [M:PLF1]POT(nolign-1)    = [F:PLF]POT
Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 : on renseigne le prénom, l'emploi type et le poste - FIN
If GNBLEG=1 : GCURLEG = GDOSLEG : Endif

#PCA 25/05/12 SHOW FIELDS BASED ON LEG
GCURLEG = [F:PLF]LEGPLF
If dim([M:PLF0]LEGPLF)>0 Then
  [M:PLF0]LEGPLF=GCURLEG
Endif
 Call DISPLAY_HIDE() From SUBPLFLEG
 # JML
Gosub READ_BUR
If !find(GREP,"C","D")
 Grizo [M:PLF0]STRDAT, ENDDAT
Endif
Return
#TIVAN - 06/07/2017 - X3-35993 - End
#####################################################################################################################
$MODIF
[F:PLF] = [M:PLF0]                 : # JML 11/09/2015 :#TIVAN
# SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
FLAG_REVALO = 1

## Mise à jour des coûts
Raz [F:PLC]
[F:PLC]YEAPLF = [M:PLF0]YEAPLF
# FQ81085 - MABON 21/05/12 - Field LEGPLF has been added
If dim([M:PLF0]LEGPLF)>0 Then
  [F:PLC]LEGPLF = [M:PLF0]LEGPLF
Else
  [F:PLC]LEGPLF = GCURLEG
Endif
# End MABON
# SYMEU : EXI 66191 LOT 10 - V6.1 : on récupère la société et le site
[F:PLC]CPYPLF = [M:PLF0]CPYPLF
[F:PLC]FCYPLF = [M:PLF0]FCYPLF
[F:PLC]VERPLF = [M:PLF0]VERPLF
[F:PLC]CREDAT = date$ : [F:PLC]CREUSR = GUSER : [F:PLC]CRETIM = time
For I=0 To [M:PLF1]NBRINV-1
 # SYMEU : EXI 66191 LOT 10 - V6.1 - fiche 71884 : seulement si au moins un montant <> 0
 If [M:PLF1]CSTTOTCLLI(I) <> 0 or [M:PLF1]CSTTOTIDVI(I) <> 0 or [M:PLF1]CSTIPTCLLI(I) <> 0 or [M:PLF1]CSTIPTIDVI(I) <> 0
   [F:PLC]NUMLIG    = [M:PLF1]NUMLIGI(I)
   [F:PLC]TYPCRG    = [M:PLF1]TYPCRGI(I)
   [F:PLC]TYPCST    = [M:PLF1]TYPCSTI(I) # SYMEU : EXI 66191 LOT 10 - V6.1 : revalorisation
   [F:PLC]CSTTOTCLL = [M:PLF1]CSTTOTCLLI(I)
   [F:PLC]CSTTOTIDV = [M:PLF1]CSTTOTIDVI(I)
   [F:PLC]CSTIPTCLL = [M:PLF1]CSTIPTCLLI(I)
   [F:PLC]CSTIPTIDV = [M:PLF1]CSTIPTIDVI(I)
   [F:PLC]DESTYPFRT = [M:PLF1]DESTYPFRTI(I)
   [F:PLC]TYPFIN    = [M:PLF1]TYPFINI(I)
   [F:PLC]ORGFIN    = [M:PLF1]ORGFINI(I)
   #LIPET - 2017-05-11 - X3-35993 - START
   [F:PLC]LNKREP    = [M:PLF1]LNKREPI(I)   :# X3-17093
   #LIPET - 2017-05-11 - X3-35993 - END
   [F:PLC]CUR       = [M:PLF0]CUR
   Write [F:PLC]
   If fstat
    GOK = 0 : Call FSTA("PLC") From GLOCK : Break
   Endif
 Endif # SYMEU : EXI 66191 LOT 10 - V6.1 - fiche 71884 : seulement si au moins un montant <> 0
Next
If GOK=0 : Return : Endif

# SYMEU : EXI 66191 LOT 10 - V6.1 : enveloppes de coûts : mise à jour - DEBUT
Raz [F:HRPLB]
[F:HRPLB]YEAPLF = [M:PLF0]YEAPLF
# FQ81085 - MABON 21/05/12 - Field LEGPLF has been added
If dim([M:PLF0]LEGPLF)>0 Then
  [F:HRPLB]LEGPLF = [M:PLF0]LEGPLF
Else
  [F:HRPLB]LEGPLF = GCURLEG
Endif
# End MABON
[F:HRPLB]CPYPLF = [M:PLF0]CPYPLF
[F:HRPLB]FCYPLF = [M:PLF0]FCYPLF
[F:HRPLB]VERPLF = [M:PLF0]VERPLF
[F:HRPLB]CREDAT = date$ : [F:HRPLB]CREUSR = GUSER : [F:HRPLB]CRETIM = time
For I=0 To [M:PLF4]NBRBUD-1
 [F:HRPLB]TYPCRG    = [M:PLF4]TYPCRGBUD(I)
 [F:HRPLB]CSTTOT    = [M:PLF4]CSTTOTBUD(I)
 [F:HRPLB]CSTIPT    = [M:PLF4]CSTIPTBUD(I)
 [F:HRPLB]DESTYPFRT = [M:PLF4]DESTYPFRTBUD(I)
 [F:HRPLB]TYPFIN    = [M:PLF4]TYPFINBUD(I)
 [F:HRPLB]ORGFIN    = [M:PLF4]ORGFINBUD(I)
 [F:HRPLB]CUR       = [M:PLF0]CUR
 Write [F:HRPLB]
 If fstat
  GOK = 0 : Call FSTA("HRPLB") From GLOCK : Break
 Endif
Next
If GOK=0 : Return : Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 : enveloppes de coûts : mise à jour - FIN

# SYMEU : EXI 66191 LOT 11 - V6.1 : mise à jour de l'année du plan définitif
# dans les demandes
If [M:PLF0]FLGCLO=2 Then
  For I=0 To [M:PLF1]NBRPLF-1
    If [M:PLF1]DEMNUM(I)<>""
      Readlock [F:DEM2]DEM0 = [M:PLF1]DEMNUM(I)
      If fstat=1 Then # enregistrement déjà verrouillé
        [V]GOK =-1
        [V]GLOCK="$"+"DEM2"-[M:PLF1]DEMNUM(I)
        Break
      Elsif fstat Then # autre erreur
        [V]GOK = 0
        Call RSTA("DEM2",[M:PLF1]DEMNUM(I)) From GLOCK
        Break
      Else
        If [F:DEM2]YEAPLF <> "" and [F:DEM2]YEAPLF <> [M:PLF0]YEAPLF Then
          # Si l'année de la demande est déjà renseignée, cela signifie qu'elle a été mise
          # sur un autre plan définitif. Elle ne peut donc pas être mise sur le plan définitif
          # en cours
          [V]GOK = 0
          # 9999999 : La demande fait déjà partie d'un plan définitif sur l'année 9999
          [V]GMESSAGE = [M:PLF1]DEMNUM(I)-":"-mess(212,10717,1)-num$([F:DEM2]YEAPLF)
          Break
        Elsif [F:DEM2]YEAPLF = ""
          [F:DEM2]YEAPLF = [M:PLF0]YEAPLF
#TIVAN - START
          [F:DEM2]STRDAT = [M:PLF0]STRDAT  : # JML 27/08/15 STRDAT, ENDDAT
          [F:DEM2]ENDDAT = [M:PLF0]ENDDAT  : # JML 27/08/15 STRDAT, ENDDAT
#TIVAN - END
          Rewrite [F:DEM2]
          If fstat Then
            [V]GOK = 0
            Call FSTA("DEM2") From GLOCK
            Break
          Endif
        Endif
      Endif
    Endif
  Next I
Endif
If GOK<=0 : Return : Endif

Return
#####################################################################################################################
$REPART_PLF1_CST
# 1st line
[M:PLF1]TYPFIN(I-1)=[F:HRTCR]TYPFIN
[M:PLF1]ORGFIN(I-1)=[F:HRTCR]ORGFIN
[L]TIMESTP=timestamp$ : # X3-17093
[M:PLF1]LNKREP(I-1)=[L]TIMESTP :  # X3-17093
# Add 2nd line in table
  # X3-17093
  If [M:PLF1]NBRCST>=dim([M:PLF1]TYPCRG)
    GMESSAGE = mess(304,717,1)   # Tableau des couts plein
    Return
  Endif
[M:PLF1]NBRCST +=1
# share amounts between 1st and 2nd lines
# arrondi
Call  CALCULATE( [L]WTCRCOD,[M:PLF1]TYPCRG(I-1),[M:PLF1]TYPFIN(I-1),[M:PLF1]ORGFIN(I-1),[L]NBH,0,[M:PLF1]CSTTOTIDV(I-1),[L]RESULT) From SUBHRTCR
[M:PLF1]CSTTOTIDV(I-1)=arr([L]RESULT(0),0.01)  : # 1st line
[M:PLF1]CSTTOTIDV(I)  =arr([L]RESULT(1),0.01)  : # 2nd line

Call  CALCULATE( [L]WTCRCOD,[M:PLF1]TYPCRG(I-1),[M:PLF1]TYPFIN(I-1),[M:PLF1]ORGFIN(I-1),[L]NBH,0,[M:PLF1]CSTIPTIDV(I-1),[L]RESULT) From SUBHRTCR
[M:PLF1]CSTIPTIDV(I-1)=arr([L]RESULT(0),0.01)  : # 1st line
[M:PLF1]CSTIPTIDV(I)  =arr([L]RESULT(1),0.01)  : # 2nd line

[M:PLF1]TYPCRG(I)    = [M:PLF1]TYPCRG(I-1)
[M:PLF1]TYPCST(I)    = 1 # Automatique
[M:PLF1]CSTTOTCLL(I) = [M:PLF1]CSTTOTCLL(I-1)
[M:PLF1]CSTIPTCLL(I) = [M:PLF1]CSTIPTCLL(I-1)
[M:PLF1]DESTYPFRT(I) = [M:PLF1]DESTYPFRT(I-1)
[M:PLF1]TYPFIN(I)    = [M:PLF1]TYPFIN(I-1)

[M:PLF1]ORGFIN(I)    = [F:HRTCR]ORGFIN2
[M:PLF1]LNKREP(I)=TIMESTP+"D" : # X3-17093
Return
#####################################################################################################################
$RESET_FLGCHG
Local Integer WVAL
Gosub UPDATE_FLGCHG
Return

$SET_FLGCHG
Local Integer WVAL : WVAL=1
Gosub UPDATE_FLGCHG
Return

$UPDATE_FLGCHG
[M]FLGCHG(nolign-1)=WVAL
Return
# end X3-17093
#####################################################################################################################
# X3-17093 TIVAN - 06/07/2017 - X3-35993 - Start
$RESET_LNKREP
If [M:PLF1]FLGCHG(nolign-1)=1
  Local Char WTIMSTP(30)
  Local Integer WLIN
  If [M:PLF1]LNKREP(nolign-1)<>""
    # define LNKREP corresponding - for line linked ( lnkrep+D ou LNKREP-D)
    [L]WTIMSTP=[M:PLF1]LNKREP(nolign-1)
    If right$([L]WTIMSTP,len(WTIMSTP))="D"
      [L]WTIMSTP=left$(WTIMSTP,len(WTIMSTP)-1)
    Else
      [L]WTIMSTP+="D"
    Endif

    [L]WLIN=find([L]WTIMSTP,[M:PLF1]LNKREP(0..[M:PLF1]NBRCST-1))
    If [L]WLIN
      [M:PLF1]TYPCST(WLIN-1)=2 : # Manual
      [M:PLF1]LNKREP(WLIN-1)=""
      Affzo [M:PLF1]TYPCST(WLIN-1)
      Affzo [M:PLF1]LNKREP(WLIN-1)
    Endif
    [M:PLF1]LNKREP(nolign-1)=""
    Affzo [M:PLF1]LNKREP(nolign-1)
  Endif
Endif
Return
# X3-17093 TIVAN - 06/07/2017 - X3-35993 - End
