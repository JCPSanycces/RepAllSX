#<AdxTL>@(#)0.0.0.0 $Revision$
#CHECK IGNORE_SOURCE
#############################################################
#
# Fixed Assets migration process to V9
#
# --> Change ATBDIV 604 (building) in an object BUI
# --> Transfer of the table LOCALIZAT to table PHYLCT
# --> Manage new PHYELT & PHYMVT table from the old PHYELT table
# --> Delete import/export templates using inventory tables
# --> Update the FAS setup template by deleting INVPAR
# --> Delete duplicate keys in table CDFCOD
#
#############################################################
#
#  CBO   12.09.2017  X3-55064  : FCY must be financial on Location
#  CBO   10.03.2016  FQ115092  : contrôle si PHYMVT existe
#  MWA   28.12.2015  FQ113010  : Erreur à la validation du dossier table LOCALIZAT
#  CBO   23.12.2015  FQ113241  : Code activité PHY à tester
#  MDJ   06.11.2015  FQ112330  : PROPLNH remis dans AMAJ au lieu de MAJ
#  MDJ   05.11.2015  FQ112176  : Update UOM field of PROPLNH
#  CBO   23.07.2015  FQ109754  : Création à tort de mvt si MVT = 1 (ancien test = 5)
#  CBO   23.07.2015  FQ109750  : Trace plus explicite pour comprendre l'erreur + globalisation du Onerrgo
#  CBO   23.07.2015  FQ109751  : Désignation de PHYBUI non traductible : on prend celle de GLANGUE
#  MWA   06.07.2015  FQ109277  : Empty UOM in PROPLNH table
#  GLE   02.06.2015  FQ108289  : Archive folder management
#  GLE   08.06.2015  FQ108704  : GLONBCL doesn't exist
#############################################################

Subprog AMAJ
#** Called from DOSMAJ60
#*!
  Local Shortint IS_HISTO_FOLDER : IS_HISTO_FOLDER = func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER) : # FQ108289

  Call ECR_TRACE("Start AMAJ from FASMAJ60 on" - [F:ADS]DOSSIER, 0) From GESECRAN

  If !IS_HISTO_FOLDER : # FQ108289
    # Not to perform in an archive folder (settings data)
    # Change ATBDIV 604 (building) in an object BUI
    Gosub AMAJ_BUI_604

    # Not to perform in an archive folder (metadata)
    # Delete import/export templates using inventory tables
    Gosub AMAJ_DEL_AOE

    # Not to perform in an archive folder (metadata)
    # Update FAS setup templates (GESAPH)
    Gosub AMAJ_UPD_APH

    # Not to perform in an archive folder (settings data)
    # Manage recodification settings table CDFCOD to avoid duplicate keys
    Gosub AMAJ_CDFCOD
  Endif

  # Change the name of the table LOCALIZAT to PHYLCT
  Gosub AMAJ_LOCATION

  # Manage new PHYELT & PHYMVT table from the old PHYELT table
  Gosub AMAJ_PHYELT

  # Update empty UOM with default unit (PROPLNH) FQ109277
  Gosub AMAJ_PROPLNH

  Call ECR_TRACE("End AMAJ from FASMAJ60",0) From GESECRAN

End

Subprog MAJ
#** Called from DOSMAJ60
#*!
End

################################################################

################################################################
#
# change ATBDIV 604 (building) in an object BUI
#
################################################################
$AMAJ_BUI_604

  # Issue 113241 - 2015-12-23 by CBO : PHYBUI doesn't exist if no PHY activity code
  If filinfo(filpath("FIL", "PHYBUI", "fde", [F:ADS]DOSSIER), 0) <= 0
    Return
  Endif

Local Integer  N_BUI_ORI
Local Integer  N_BUI_CRT
Local Integer  N_BUI_EXIST

  Call ECR_TRACE("Start of migration from ATBDIV 604 (building) to the object BUI", 0) From GESECRAN

  If clalev([F:ADI]) :   Close File  [ADI] :   Endif
  Local File =[F:ADS]DOSSIER + ".ATABDIV" [ADI]

  If clalev([F:ADV]) :   Close File  [ADV] :   Endif
  Local File =[F:ADS]DOSSIER + ".ATABTAB" [ADV]

  If clalev([F:AXX2]) :  Close File  [F:AXX2] :  Endif
  Local File =[F:ADS]DOSSIER + ".ATEXTRA" [AXX2]

  If clalev([F:BUI]) :   Close File  [BUI] :   Endif
  Local File =[F:ADS]DOSSIER + ".PHYBUI" [BUI]

  GOK = 1
  Raz N_BUI_CRT
  Raz N_BUI_ORI
  Raz N_BUI_EXIST

  Onerrgo ERR_FASMAJ60

  Trbegin [BUI]
  #---------------------------------
  For [F:ADI]CODE Where NUMTAB = 604
    N_BUI_ORI += 1
    [F:BUI]BUICOD  = [F:ADI]CODE

    # FQ109751
    Read [F:AXX2]AXX0 = "ATABDIV"; "LNGDES"; GLANGUE; num$(604); [F:ADI]CODE
    If fstat
      [F:BUI]BUIDES  = [F:BUI]BUICOD
    Else
      [F:BUI]BUIDES  = [F:AXX2]TEXTE
    Endif

    #------------
    Write [F:BUI]
    If fstat = 3  # already exists
        N_BUI_EXIST += 1
    Elsif fstat
        GOK = 0
        Call ECR_TRACE("Error writing [PHYBUI] <" + [F:BUI]BUICOD + "> fstat=" + num$(fstat), 1) From GESECRAN
        Break
    Else
        N_BUI_CRT += 1
    Endif
  Next
  #---------------------------------

  If GOK
    Delete [F:AXX2] Where CODFIC="ATABDIV" and IDENT1=num$(604)
    Delete [F:ADI]  Where NUMTAB=604
    Delete [F:ADV]  Where NUMTAB=604
  Endif

  If GOK
    Commit
  Else
    Rollback
  Endif

  Onerrgo

  # FQ109750
  If GOK
    Call ECR_TRACE("From" - num$(N_BUI_ORI) - " Building(s) in 604 ATABDIV", 0) From GESECRAN
    Call ECR_TRACE("        "- num$(N_BUI_CRT) -  " Building(s) created in PHYBUI table", 0) From GESECRAN
    Call ECR_TRACE("        "- num$(N_BUI_EXIST)- " Building already exist(s) in PHYBUI table", 0) From GESECRAN
  Else
    Call ECR_TRACE(num$(N_BUI_ORI) - " Building(s) in 604 ATABDIV read", 0) From GESECRAN
    Call ECR_TRACE(num$(N_BUI_EXIST) - "already exist(s) in PHYBUI and" - num$(N_BUI_CRT) - "not created (because Rollback)", 0) From GESECRAN
    Call ECR_TRACE("Errors detected in LOCALIZAT migration - Rollback executed", 0) From GESECRAN
  Endif
  Call ECR_TRACE("", 0) From GESECRAN
  Call ECR_TRACE("End of migration from ATABDIV 604 (BUILDING) to the object BUI", 0) From GESECRAN

Return

################################################################

################################################################
#
# Change the name of the table LOCALIZAT to PHYLCT
#
################################################################
$AMAJ_LOCATION

  # Issue 113241 - 2015-12-23 by CBO : LOCALIZAT or PHYLCT don't exist if no PHY activity code
  If filinfo(filpath("FIL", "LOCALIZAT", "fde", [F:ADS]DOSSIER), 0) <= 0
    Return
  Endif
  If filinfo(filpath("FIL", "PHYLCT", "fde", [F:ADS]DOSSIER), 0) <= 0
    Return
  Endif

Local Integer  N_LOC_ORI
Local Integer  N_LOC_CRT
Local Integer  N_LOC_EXIST

  Call ECR_TRACE(" Start of migration from  LOCALIZAT table to PHYLCT table", 0) From GESECRAN

  If (IS_HISTO_FOLDER) and (func DOSVUE.ISVIEW([F:ADS]DOSSIER,"LOCALIZAT")) : # FQ108289
    Call ECR_TRACE("LOCALIZAT is a view. Nothing to do",0) From GESECRAN
  Else
    If (IS_HISTO_FOLDER) : # FQ108289
      # In an archive folder, if LOCALIZAT is a table and not a view, we must create the PHYLCT table and migrate it
      Call CRE_HISTAB([F:ADS]DOSREF, [F:ADS]DOSSIER, [F:ADS]TYPDBA, "PHYLCT") From CREHISTO
    Endif

    # Old table LOCALIZAT
    If clalev([F:LOC]) :  Close File  [LOC]   :  Endif
    Local File =[F:ADS]DOSSIER + ".LOCALIZAT" [LOC]

    # New table PHYLCT
    If clalev([F:LCT]) :  Close File  [LCT]   :  Endif
    Local File =[F:ADS]DOSSIER + ".PHYLCT" [LCT]

    # table COMPANY
    If clalev([F:FCY]) :  Close File  [FCY]   :  Endif
    Local File =[F:ADS]DOSSIER + ".FACILITY"  [FCY]

    GOK = 1
    Raz N_LOC_ORI
    Raz N_LOC_EXIST
    Raz N_LOC_CRT

    Onerrgo ERR_FASMAJ60

    Trbegin [LCT]

    For [F:LOC]LOC0
      N_LOC_ORI += 1
#     [F:LCT]CPY      = [F:LOC]CPY    # ATTENTION : pas de CPY dans l'ancienne table (LOCALIZAT)
      [F:LCT]LCTCOD   = [F:LOC]LOCCOD
      [F:LCT]BUICOD   = [F:LOC]LOCBUI
      [F:LCT]FLOOR    = [F:LOC]LOCFLO
      [F:LCT]BAC      = [F:LOC]LOCBAC
      [F:LCT]DFLFLG   = [V]CST_ANO
#      [F:LCT]FCY      = [F:LOC]LOCIVYFCY # X3-55064
#      Read[FCY]FCY0= [F:LCT]FCY          # X3-55064
      Read[FCY]FCY0= [F:LOC]LOCIVYFCY     # X3-55064
      If fstat
        Call ECR_TRACE("Warning facility not read <" + [F:LOC]LOCIVYFCY + "> fstat =" - num$(fstat), 0) From GESECRAN
        [F:LCT]CPY=""
        [F:LCT]FCY=""
      Else
        [F:LCT]CPY = [F:FCY]LEGCPY
        [F:LCT]FCY = [F:FCY]FINRSPFCY # X3-55064 : we must have a financial FCY : if FINFLG = 2, it's the same as FCYone
      Endif
      [F:LCT]LCTDES   = [F:LOC]LOCDES
      Write [F:LCT]
      If fstat = 3  # already exists
        N_LOC_EXIST += 1
      Elsif fstat
        GOK = 0
        Call ECR_TRACE("Error writing [LOCATION] <" + [F:LCT]LCTCOD + "> fstat =" - num$(fstat), 1) From GESECRAN
        Break
      Else
        N_LOC_CRT += 1
      Endif
    Next

    If GOK
      Commit
      Call ECR_TRACE("From" - num$(N_LOC_ORI) - "LOCALIZAT", 0) From GESECRAN
      Call ECR_TRACE(num$(N_LOC_EXIST) - "already exist(s) in LOCALIZAT and" - num$(N_LOC_CRT) - "are created", 0) From GESECRAN
    Else
      Rollback
      # FQ109750
      Call ECR_TRACE(num$(N_LOC_ORI) - "LOCALIZAT read", 0) From GESECRAN
      Call ECR_TRACE(num$(N_LOC_EXIST) - "already exist(s) in LOCATION and" - num$(N_LOC_CRT) - "not created (because Rollback)", 0) From GESECRAN
      Call ECR_TRACE("Errors detected in LOCALIZAT migration - Rollback executed", 0) From GESECRAN
    Endif
    Close File  [LOC],  [LCT]

     # 113010 MWA
     # The migration process at first adds new fields in existing tables and add new tables, ...
     # Then it runs migration program
     # Finally, it deletes fields that does not exist any longer in existing tables and delete tables that doesn't exist any longer
     # As LOCALIZAT table doesn't exist in reference folder it will be deleted at the very end of the migration (table and dictionnary)

#    Call ANNULE([F:ADS]DOSSIER, "LOCALIZAT", GOK) From DOSTAB
#    If GOK
#      Call ECR_TRACE("Old table LOCALIZAT deleted", 0) From GESECRAN
#    Else
#      Call ECR_TRACE("Error : Old table LOCALIZAT not deleted", -1) From GESECRAN
#    Endif

     # 113010 MWA
     # If migration program is run more than once, it will generate duplicate keys when writing LOCALIZAT into PHYLCT one more time
     # It is then advised to clear LOCALIZAT table when one is sure that data were well copied into PHYLCT table
    If GOK
      Call VIDE([F:ADS]DOSSIER, "LOCALIZAT", GOK) From DOSTAB
      If GOK
        Call ECR_TRACE("LOCALIZAT Table has been cleared", 0) From GESECRAN
      Else
        Call ECR_TRACE("Error : LOCALIZAT Table not cleared", -1) From GESECRAN
      Endif
    Endif

    Onerrgo

  Endif

  Call ECR_TRACE("", 0) From GESECRAN
  Call ECR_TRACE("End of migration from LOCALIZAT table to PHYLCT table", 0) From GESECRAN

Return

################################################################

################################################################
#
# Manage CDFCOD to avoid duplicate keys
#
# All of duplicate couples REFCDF/VALOLDCOD must be deleted
#
################################################################
$AMAJ_CDFCOD
  Local Integer N_DEL : N_DEL = 0
  Local Char REF(10), COD(20), LOC(60) # FQ108704

  Call ECR_TRACE("Start of migration CDFCOD", 0) From GESECRAN

  If clalev([F:CDC]) : Close File  [CDC] : Endif
  Local File =[F:ADS]DOSSIER + ".CDFCOD" [CDC]

  GOK = 1
  Onerrgo ERR_FASMAJ60

  Trbegin [CDC]

  Filter [F:CDC] Order By REFCDF Asc; VALOLDCOD Asc; VALOLDLOC Asc
  Read [F:CDC] First
  While !fstat
    REF = [F:CDC]REFCDF
    COD = [F:CDC]VALOLDCOD
    LOC = [F:CDC]VALOLDLOC

    Delete [F:CDC] Where REFCDF=REF and VALOLDCOD=COD and VALOLDLOC>LOC
    N_DEL += adxdlrec

    Read [F:CDC] Next
  Wend
  Filter [F:CDC]

  If GOK
    Commit
    Call ECR_TRACE("    Record deleted:"-num$(N_DEL), 0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("Errors detected in CDFCOD migration - Rollback executed", 0) From GESECRAN
  Endif

  Close Local File [CDC]

  Onerrgo # Issue 115092

  Call ECR_TRACE("", 0) From GESECRAN
  Call ECR_TRACE("End of migration CDFCOD", 0) From GESECRAN

Return

################################################################
#
# Manage new PHYELT & PHYMVT table from the old PHYELT table
#
#  - ENAFLG initialisation
#  - ISSTYP update depending on new Physical Asset issue types
#  - new LCTCOD field set with the value of the old LOC field
#  - pending mouvement array moved to the new PHYMVT table
#
################################################################
$AMAJ_PHYELT

  # Issue 113241 - 2015-12-23 by CBO : PHYELT doesn't exist if no PHY activity code
  If filinfo(filpath("FIL", "PHYELT", "fde", [F:ADS]DOSSIER), 0) <= 0
    Return
  Endif

  # Issue 115092
  If filinfo(filpath("FIL", "PHYMVT", "fde", [F:ADS]DOSSIER), 0) <= 0
    Return
  Endif
  If func AFNC.ACTIVDOS([F:ADS]DOSSIER, "PHY") <= 0
    Return
  Endif

  Call ECR_TRACE("Start of migration PHYELT table splitted into PHYELT & PHYMVT tables", 0) From GESECRAN

  If (IS_HISTO_FOLDER) and (func DOSVUE.ISVIEW([F:ADS]DOSSIER,"PHYELT")) : # FQ108289
    Call ECR_TRACE("PHYELT is a view. Nothing to do",0) From GESECRAN
  Else
    If (IS_HISTO_FOLDER) : # FQ108289
      # In an archive folder, if LOCALIZAT is a table and not a view, we must create the PHYLCT table and migrate it
      Call CRE_HISTAB([F:ADS]DOSREF, [F:ADS]DOSSIER, [F:ADS]TYPDBA, "PHYMVT") From CREHISTO
    Endif

    If clalev([F:PHY]) : Close File  [PHY] : Endif
    Local File =[F:ADS]DOSSIER + ".PHYELT" [PHY]

    If clalev([F:PMVT]) : Close File  [PMVT] : Endif
    Local File =[F:ADS]DOSSIER + ".PHYMVT" [PMVT]

    If clalev([F:FAS]) : Close File  [FAS] : Endif
    Local File =[F:ADS]DOSSIER + ".FXDASSETS" [FAS]

    GOK = 1
    Onerrgo ERR_FASMAJ60

    Local Integer N_READ_PHY : N_READ_PHY = 0
    Local Integer N_WRT_PMVT : N_WRT_PMVT = 0
    Local Integer N_UPD_PHY  : N_UPD_PHY  = 0

    Trbegin [PHY], [PMVT]
    # >>>>
    For [F:PHY]PHY0
      N_READ_PHY += 1

      # - ENAFLG
      If ([F:PHY]AASREF = "") Then
        [F:PHY]ENAFLG = 2
      Else
        Read [FAS]FAS0=[F:PHY]AASREF
        If not (fstat) Then
          [F:PHY]ENAFLG = [F:FAS]ENAFAS
        Else
          [F:PHY]ENAFLG = 2
        Endif
      Endif

      # - ISSTYP
      Case [F:PHY]ISSTYP
        When 1
          [F:PHY]ISSTYP = 3
        When 2
          [F:PHY]ISSTYP = 4
        When 4
          [F:PHY]ISSTYP = 5
        When Default
          [F:PHY]ISSTYP = 1
      Endcase

      # - LCTCOD
      [F:PHY]LCTCOD   = [F:PHY]LOC

      Local Integer I_MVT
      [F:PMVT]NUM = 0
      For I_MVT = 0 To 3
        # All the pending movements except transfer cancellation movement
        #  FQ109754
        If [F:PHY]MVT(I_MVT) <> 0 and [F:PHY]MVT(I_MVT) <> 1
          [F:PMVT]PHYREF    = [F:PHY]PHYREF
          [F:PMVT]NUM      += 1
          [F:PMVT]MVT       = [F:PHY]MVT      (I_MVT)
          [F:PMVT]MVTDAT    = [F:PHY]MVTDAT   (I_MVT)
          [F:PMVT]MVTTRANS  = [F:PHY]MVTTRANS (I_MVT)

          # Not issued
          [F:PMVT]MVTISSTYP = 1
          If ([F:PHY]MVT(I_MVT) = 2 or [F:PHY]MVT(I_MVT) = 3)
            # Disposal or Disposal cancellation
            Case [F:PHY]MVTSORTIE
              When 1
                [F:PMVT]MVTISSTYP = 3
              When 2
                [F:PMVT]MVTISSTYP = 4
              When 4
                [F:PMVT]MVTISSTYP = 5
              When Default
            Endcase
            #  FQ109754
          Endif

          [F:PMVT]MVTFCY    = [F:PHY]MVTFCY (I_MVT)
          [F:PMVT]MVTLCTCOD = [F:PHY]MVTLOC (I_MVT)
          #====
          Write [F:PMVT]
          If fstat
            GOK = 0
            Call ECR_TRACE("Error Write [PHYMVT] <" + [F:PMVT]PHYREF + "/" + num$([F:PMVT]NUM) + "> fstat =" - num$(fstat), 1) From GESECRAN
            Break 2
          Else
            N_WRT_PMVT += 1
          Endif
        Endif
      Next

      Rewrite [F:PHY]
      If fstat
        GOK = 0
        Call ECR_TRACE("Error Write [PHYELT] <" + [F:PHY]PHYREF + "> fstat =" - num$(fstat), 1) From GESECRAN
        Break
      Else
        N_UPD_PHY  += 1
      Endif
    Next
    # <<<<

    # FQ109750
    If GOK
      Commit
      Call ECR_TRACE("        "- num$(N_READ_PHY) -  " Physical assets read      in PHYELT table", 0) From GESECRAN
      Call ECR_TRACE("        "- num$(N_UPD_PHY)  -  " Physical assets updated   in PHYELT table", 0) From GESECRAN
      Call ECR_TRACE("        "- num$(N_WRT_PMVT) -  " Pending movements created in PHYMVT table", 0) From GESECRAN
    Else
      # FQ109750
      Call ECR_TRACE(num$(N_READ_PHY) - "PHYELT read", 0) From GESECRAN
      Call ECR_TRACE(num$(N_UPD_PHY) - "not updated and" - num$(N_WRT_PMVT) - "Pending movements not created (because Rollback)", 0) From GESECRAN
      Call ECR_TRACE("Errors detected in PHYELT migration - Rollback executed", 0) From GESECRAN
      Rollback
    Endif
    Onerrgo

    Close Local File [PHY]
    Close Local File [PMVT]
    Close Local File [FAS]
  Endif

  Call ECR_TRACE("", 0) From GESECRAN
  Call ECR_TRACE("End of migration PHYELT in PHYELT & PHYMVT tables", 0) From GESECRAN
Return

################################################################

################################################################
#
# Delete import/export templates using inventory tables
#
# INVSTA, LOCALIZAT, PHYELT, TMPINVEXP, TMPINVEXPW
#
################################################################
$AMAJ_DEL_AOE

  Local Integer I_TAB
  Local Char TABLE_LIST(20)(1..5)

  # If one of those tables is found in the import/export template, the template is deleted
  TABLE_LIST(1) = "INVSTA"
  TABLE_LIST(2) = "LOCALIZAT"
  TABLE_LIST(3) = "PHYELT"
  TABLE_LIST(4) = "TMPINVEXP"
  TABLE_LIST(5) = "TMPINVEXPW"

  Call ECR_TRACE("Inventory import/export templates deletion", 0) From GESECRAN

  If clalev([F:AOE]) : Close File  [AOE] : Endif
  Local File =[F:ADS]DOSSIER + ".AOBJEXT" [AOE]

  If clalev([F:AOD]) : Close File  [AOD] : Endif
  Local File =[F:ADS]DOSSIER + ".AOBJEXTD" [AOD]

  If clalev([F:AXX]) : Close File  [AXX] : Endif
  Local File =[F:ADS]DOSSIER + ".ATEXTRA" [AXX]

  If clalev([F:ARV]) : Close File  [ARV] : Endif
  Local File =[F:ADS]DOSSIER + ".AREPORTV" [ARV]

  If clalev([F:ARX]) : Close File  [ARX] : Endif
  Local File =[F:ADS]DOSSIER + ".AREPORTX" [ARX]

  GOK = 1
  Onerrgo ERR_FASMAJ60

  For [F:AOE]AOE0
    For I_TAB = 1 To dim(TABLE_LIST)
      If find(TABLE_LIST(I_TAB), [F:AOE]FIL)
        Call ECR_TRACE("Deleting import/export template "-[F:AOE]EXT,0) From GESECRAN

        Delete [AOD] Where EXT=[F:AOE]EXT
        If fstat
          Call ECR_TRACE("Error deleting AOBJEXTD <"-[F:AOE]EXT-">"-num$(fstat),1) From GESECRAN
          GOK = 0 : Break 2
        Endif

        Delete [AXX] Where CODFIC="AOBJEXT" & ZONE="INTIT"  & IDENT1=[F:AOE]EXT
        If fstat
          Call ECR_TRACE("Error deleting ATEXTRA <"-[F:AOE]EXT-">"-num$(fstat),1) From GESECRAN
          GOK = 0 : Break 2
        Endif

        Delete [AXX] Where CODFIC="AOBJEXTD" & ZONE="INTFLD"  & IDENT1=[F:AOE]EXT
        If fstat
          Call ECR_TRACE("Error deleting ATEXTRA <"-[F:AOE]EXT-">"-num$(fstat),1) From GESECRAN
          GOK = 0 : Break 2
        Endif

        Delete [ARV] Where TYPCOD=4 & ETAT = [F:AOE]EXT
        If fstat
          Call ECR_TRACE("Error deleting AREPORTV <"-[F:AOE]EXT-">"-num$(fstat),1) From GESECRAN
          GOK = 0 : Break 2
        Endif

        Delete [ARX] Where TYPCOD=4 & EXTCOD = [F:AOE]EXT
        If fstat
          Call ECR_TRACE("Error deleting AREPORTX <"-[F:AOE]EXT-">"-num$(fstat),1) From GESECRAN
          GOK = 0 : Break 2
        Endif

        Delete [AOE] Curr
        If fstat
          Call ECR_TRACE("Error deleting AOBJEXT <"-[F:AOE]EXT-">"-num$(fstat),1) From GESECRAN
          GOK = 0 : Break 2
        Endif

        Break
      Endif
    Next
  Next

  Onerrgo
  Call ECR_TRACE("End of inventory import/export templates deletion", 0) From GESECRAN

  Close File [AOE]
  Close File [AOD]
  Close File [AXX]
  Close File [ARV]
  Close File [ARX]

Return

################################################################

################################################################
#
# Update the FAS setup template by deleting INVPAR
#
################################################################
$AMAJ_UPD_APH

  Call ECR_TRACE("Update the FAS setup template by deleting INVPAR", 0) From GESECRAN

  If clalev([F:APH]) : Close File  [APH] : Endif
  Local File =[F:ADS]DOSSIER + ".APATCHMOD" [APH]

  Delete [APH] Where MODPAT="FAS" & MODDON="INVPAR"
  If fstat
    Call ECR_TRACE("Error deleting APATCHMOD"-num$(fstat),1) From GESECRAN
  Endif
  If adxdlrec > 0
    Call ECR_TRACE("  --> template updated"-num$(fstat),0) From GESECRAN
  Endif

  Call ECR_TRACE("End of FAS setup template update", 0) From GESECRAN

  Close File [APH]
Return

################################################################
#
# Update empty UOM with default unit (PROPLNH) FQ109277
#
################################################################
$AMAJ_PROPLNH

  Call ECR_TRACE("Update UOM field of PROPLNH when it is empty with default unit according to DEFUOM folder parameter", 0) From GESECRAN

  If (IS_HISTO_FOLDER) and (func DOSVUE.ISVIEW([F:ADS]DOSSIER,"PROPLNH"))
    Call ECR_TRACE("PROPLNH is a view. Nothing to do",0) From GESECRAN
  Else
    If clalev([F:PLH]) : Close File  [PLH] : Endif
    Local File =[F:ADS]DOSSIER + ".TABUNIT" [ZTUN]
    Local File =[F:ADS]DOSSIER + ".PROPLNH" [PLH]
    Local File =[F:ADS]DOSREF  + ".ADOVAL"  [ZADW]

    Local Char L_DEFUOM(20)
    Call  PARAM("","DEFUOM",L_DEFUOM)  From ADOVAL
    If (L_DEFUOM = "") Then
      For [ZTUN]TUN0 Where (UOM="UN" or UOM="Un")
        Read [ZTUN]First
        Break
      Next
      If fstat
        [F:ZTUN]UOM     = "UN"
        [F:ZTUN]DES     = "Unité"
        [F:ZTUN]UOMTYP  = 6        # Numération
        [F:ZTUN]UOMDEC  = 0
        L_DEFUOM= [F:ZTUN]UOM
        Write [ZTUN]
        If  fstat
          GOK = 0
          Call ECR_TRACE("Error writing [TABUNIT] <" + [F:ZTUN]UOM + "> fstat=" + num$(fstat), 1) From GESECRAN
          Return
        Else
          Call ECR_TRACE("Unit UN has been created in TABUNIT table", 0) From GESECRAN
        Endif
      Else # The unit "UN" or "Un" is found
        L_DEFUOM= [F:ZTUN]UOM
        Call ECR_TRACE("DEFUOM initialized with the value "+ [F:ZTUN]UOM, 0) From GESECRAN
      Endif
    Endif
    Update [PLH] Where UOM="" With UOM = L_DEFUOM
    If fstat
      Call ECR_TRACE("Error updating PROPLNH"-num$(fstat),1) From GESECRAN
    Endif
    # If adxdlrec > 0
    If adxuprec > 0
      Call ECR_TRACE("  --> records updated"-num$(fstat),0) From GESECRAN
    Endif

    Call ECR_TRACE("End of UOM update", 0) From GESECRAN

    Close File [ZADW]
    Close File [ZTUN]
    Close File [PLH]
  Endif

Return

# FQ109750
$ERR_FASMAJ60
  GOK = 0
  Call ECR_TRACE(errm-errmes$(errn) - "/" -errp, -1) From GESECRAN
  Call ECR_TRACE("Line =" - num$(errl) - "Err number =" - num$(errn), -1) From GESECRAN
Resume

