########################################
Subprog AV_QTYSTU(VALEUR)
Variable Decimal VALEUR
If [M:SOM]WAIFLG(nolign-1)=1
   Chgstl QTYSTU(nolign-1) With "AWARNLOW"
Else
   Chgstl QTYSTU(nolign-1) With ""
Endif
End

########################################
Subprog C_QTYSTU(VALEUR)
Variable Decimal VALEUR
Local    Decimal WVARQTY, WVARQTA, WQTYSTUACT, WK
Local    Integer OK, NOL, NBL
NOL = nolign-1
NBL = [M:SOM]NBLIG-1

# Pas de quantité nulle, vous devez supprimer la ligne
If VALEUR=0
   mkstat=2 : GMESSAGE=mess(392,199,1) : End
Endif

# La quantité a été modifiée
If VALEUR<>[M:SOM]QTYSTU(NOL)

   # Calcul nouvelle quantité UA
   WQTYSTUACT = VALEUR

   If [M:SOM]WAIFLG(NOL)<>1
      If dim([M:SOM]POT)>0
         # Si gestion en titres ou UI, calcul quantité en UA
         Case [M:SOM]STOMGTCOD
          When 3 : If [M:SOM]POT(NOL)<>0
                      WQTYSTUACT = VALEUR*([M:SOM]POT(NOL)/100)
                      Call QTEARR(WQTYSTUACT,[M:SOM]STU) From TRTDIV
                   Endif
          When 4 : If [M:SOM]POT(NOL)<>0
                      WQTYSTUACT = VALEUR*[M:SOM]POT(NOL)
                      Call QTEARR(WQTYSTUACT,[M:SOM]STU) From TRTDIV
                   Endif
         Endcase
      Endif
   Endif

   # Variation de la quantité
   WVARQTY = VALEUR    -[M:SOM]QTYSTU(NOL)
   WVARQTA = WQTYSTUACT-[M:SOM]QTYSTUACT(NOL)

   # Si mvt normal et augmentation de la quantité
   If [M:SOM]WAIFLG(NOL)<>1 & WVARQTY>0
      # Si no série en sortie, il faut calculer la qté sortie (WK)
      # pour les lignes ayant le même chrono stock que celle modifieé
      If [M:SOM]SERMGTCOD=2
         Case NOL
          When 0       : WK = sigma(J=1,NBL,(([M]QTYSTU(J)-[M]QTYSTUORI(J))*([M]STOCOU(J)=[M]STOCOU(NOL))))
          When NBL     : WK = sigma(J=0,NBL-1,(([M]QTYSTU(J)-[M]QTYSTUORI(J))*([M]STOCOU(J)=[M]STOCOU(NOL))))
          When Default : WK = sigma(J=0,NOL-1,(([M]QTYSTU(J)-[M]QTYSTUORI(J))*([M]STOCOU(J)=[M]STOCOU(NOL))))
                         WK+= sigma(J=NOL+1,NBL,(([M]QTYSTU(J)-[M]QTYSTUORI(J))*([M]STOCOU(J)=[M]STOCOU(NOL))))
         Endcase
         # Si qté à sortir > disponible - somme des qtés sorties du même chrono
         If VALEUR>[M:SOM]AVAQTYSTU(NOL)-WK
            mkstat=2 : GMESSAGE=mess(446,196,1) : End
         Else
            Gosub VERF_DISPO
            # Pas de stock disponible
            If WQTYSTUACT>WDISPO
               mkstat=2 : GMESSAGE =mess(446,196,1) : End
            Endif
         Endif
      # Sinon si qté à sortir > disponible
      Elsif VALEUR>[M:SOM]AVAQTYSTU(NOL)
         mkstat=2 : GMESSAGE=mess(446,196,1) : End
      Else
         Gosub VERF_DISPO
         # Pas de stock disponible
         If WQTYSTUACT>WDISPO
            mkstat=2 : GMESSAGE =mess(446,196,1) : End
         Endif
      Endif

   # Si mvt normal et diminution de la quantité
   Elsif [M:SOM]WAIFLG(NOL)<>1 & WVARQTY<0
      If dim([M:SOM]LOC)>0 & [M:SOM]LOC(NOL)<>""
         Call STKCTREMPM([M:SOM]LOC(NOL)) From STKLOC
         If mkstat : End : Endif
      Endif

   # Mvt en attente et qté totale US + variation US > qté à sortir US
   Elsif [M:SOM]WAIFLG(NOL)=1 & ([M:SOM]PECQTYACT+WVARQTA)>[M:SOM]SORQTYACT
      mkstat=2 : GMESSAGE=mess(393,199,1) : End
   Endif

   # Alimentation nouvelle quantité UA
   [M:SOM]QTYSTUACT(NOL) = WQTYSTUACT
Endif
End

$VERF_DISPO
Local Integer LTYPLOC, LSTA
Local Decimal WDISPO
# Calcul du stock disponible sur l'article
Raz LTYPLOC, LSTA
If [M:SOM]PECPLFLOC=2 LTYPLOC+=1 Endif
If [M:SOM]PECSCOLOC=2 LTYPLOC+=4 Endif
# Si pas d'emplacements internes
If [M:SOM]PECINTLOC=1 LTYPLOC=LTYPLOC*(-1) Endif
If [M:SOM]AAASTA=2    LSTA   +=1 Endif
If [M:SOM]QQQSTA=2    LSTA   +=2 Endif
If [M:SOM]RRRSTA=2    LSTA   +=4 Endif
Call STODISTOT("[F:ITV]",LTYPLOC,LSTA,[M:SOM]PECOWNER,WDISPO) From STKLIB
# On rajoute la qté initiale de la ligne
WDISPO += [M:SOM]QTYSTUACT(NOL)
Return

########################################
Subprog AM_QTYSTU(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL, WRET, WNBSER
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)
Local    Integer OK : OK=1               : #--- Issue 110327
NOL    = nolign-1

# X3-80367 - STWIL - Before we delete the stock transaction if it is a customer return, purchase receipt or production tracking
# check if this document is in any non-conformances
If func AFNC.ACTIV ("NCS")
    Local Integer EXISTS
    Local Char NCSMESS(255)

    [L]EXISTS = func NCSDOCHDR_CSTD.NON_CONFORMANCE_EXISTS (3, [M:SOM]VCRNUM, 0, [L]NCSMESS, 0)
    If [L]EXISTS > 0 & GNCSLINFLG = 0
        Call OUINON([L]NCSMESS,OK) From GESECRAN
        GNCSLINFLG = 1
        If OK = 1
            GMESSAGE = ""
            GERR = 1
            mkstat = 2
            End
        Endif
    Endif
Endif

If [M:SOM]WAIFLG(NOL)<>1
   # Calcul quantité en UC
   If [M:SOM]XPCUSTUCOE(NOL)=0 [M:SOM]XPCUSTUCOE(NOL)=1 Endif
   [M:SOM]QTYPCU(NOL) = VALEUR/[M:SOM]XPCUSTUCOE(NOL)
   Call QTEARR([M:SOM]QTYPCU(NOL),[M:SOM]XPCU(NOL)) From TRTDIV
   Affzo [M]QTYPCU(NOL)
Endif

#--- Issue 110327
# Si pas de mvt en attente et séries non gérés en sortie ou en E/S globale --> pas de recalcul
#If [M:SOM]WAIFLG(NOL)<>1 & [M:SOM]SERMGTCOD<>2 End Endif
If [M:SOM]SERMGTCOD<2 | ([M:SOM]WAIFLG(NOL)<>1 & !find([M:SOM]SERMGTCOD,2,4)) End Endif
#---
# Si pas de no série saisie --> pas de recalcul
If dim([M:SOM]SERNUM)<=0 | (dim([M:SOM]SERNUM)>0 & [M:SOM]SERNUM(NOL)="")  End Endif

# La quantité a diminué
If VALEUR < [M:SOM]QTYSTU(NOL)
   WNBSER  = VALEUR
   WNUMDEB = [M:SOM]SERNUM(NOL)
   If WNBSER=1
      [M:SOM]SERNUMF(NOL) = WNUMDEB
   Else
      Call PLUS_NB(WNUMDEB,WNBSER,WNUMFIN,WRET) From STKLIB
      If WRET=0
         [M:SOM]SERNUMF(NOL) = WNUMFIN
      Else
         mkstat=2 : GMESSAGE=WNUMDEB-":"-mess(476,197,1) : End
      Endif
   Endif
# La quantité a augmenté
Else
   # Vérification que les no série n'existent pas
   # pour le surplus et alimentation du no série fin
   WNBSER  = VALEUR-[M:SOM]QTYSTU(NOL)
   WNUMDEB = [M:SOM]SERNUMF(NOL)

   # Si mvt mis à jour
   If [M:SOM]WAIFLG(NOL)<>1
      For J=1 To WNBSER
         Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
         If WRET=0
            Read [STS]STS0=[M:SOM]ITMREF;WNUMFIN
            #--- Issue 110327
            #If fstat
            #   WNUMDEB = WNUMFIN
            ## Le no série existe
            #Else
            #   # S'il n'a pas été sortie par cette pièce --> erreur
            #   If [F:STS]SDHTYP<>[M:SOM]VCRTYP | [F:STS]SDHNUM<>[M:SOM]VCRNUM
#&               | [F:STS]SDDLIN<>[M:SOM]VCRLIN
            #      mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
            #   # S'il a une pièce entrée --> erreur
            #   Elsif [F:STS]RCPVCRTYP<>0 & [F:STS]RCPVCRNUM<>""
            #      mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
            #   Endif
            #Endif
            # Si séries en E/S globale
            If [F:ITM]SERMGTCOD=4
               If fstat
                  mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(43,196,1) : Break
               Elsif [F:STS]STOCOU<>0 & [F:STS]STOCOU<>[M:SOM]STOCOU(NOL)
                  mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(447,184,1) : Break
               Elsif [F:STS]ISSDAT<>[0/0/0] & ([F:STS]SDHNUM<>[M:SOM]VCRNUM | [F:STS]SDDLIN<>[M:SOM]VCRLIN)
                  mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(37,184,1) : Break
               Elsif [F:STS]ISSDAT=[0/0/0] & [F:STS]SDHNUM<>"" & !find([F:STS]SDHNUM,[M:SOM]VCRNUM,[M:SOM]VCRNUMORI)
                  mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(443,184,1) : Break
               Endif
               If OK=1 & [M:SOM]VCRTYP=8 & [M:SOM]VCRNUMORI<>""
                 If [F:STS]RCPVCRTYP<>6 | [F:STS]RCPVCRNUM<>[M:SOM]VCRNUMORI | [F:STS]RCPVCRLIN<>[M:SOM]VCRLINORI
                   OK=1 : Call AVERTIR([F:STS]SERNUM+"\"+mess(489,184,1), OK) From GESECRAN
                   If OK=1  mkstat=2 : Break  Endif
                 Endif
               Endif
            # Si série en sortie qui existe
            Elsif !fstat
               # S'il n'a pas été sortie par cette pièce --> erreur
               If [F:STS]SDHTYP<>[M:SOM]VCRTYP | [F:STS]SDHNUM<>[M:SOM]VCRNUM
&               | [F:STS]SDDLIN<>[M:SOM]VCRLIN
                  mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
               # S'il a une pièce entrée --> erreur
               Elsif [F:STS]RCPVCRTYP<>0 & [F:STS]RCPVCRNUM<>""
                  mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
               Endif
            Endif
            WNUMDEB = WNUMFIN
            #--- End issue 110327
         Else
            mkstat=2 : GMESSAGE=WNUMDEB-":"-mess(476,197,1)  : Break
         Endif
      Next J
      If mkstat=2 End Endif
      [M:SOM]SERNUMF(NOL) = WNUMFIN
   # Sinon (mvt en attente) no série gérés en E/S
   Elsif [M:SOM]SERMGTCOD=3
      For J=1 To WNBSER
         Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
         If WRET=0
            Read [STS]STS0=[M:SOM]ITMREF;WNUMFIN
            If fstat
               WNUMDEB = WNUMFIN
            Else
               mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
            Endif
         Else
            mkstat=2 : GMESSAGE=WNUMDEB-":"-mess(476,197,1) : Break
         Endif
      Next J
      If mkstat=2 End Endif
      [M:SOM]SERNUMF(NOL) = WNUMFIN
   Endif
Endif

#--- Issue 110327
[M:SOM]QTYSTU(NOL) = VALEUR
#---
Affzo [M:SOM]SERNUM(NOL), SERNUMF(NOL)

End

########################################
Subprog AV_QTYPCU(VALEUR)
Variable Decimal VALEUR
If [M:SOM]WAIFLG(nolign-1)=1
   Chgstl QTYPCU(nolign-1) With "AWARNLOW"
Else
   Chgstl QTYPCU(nolign-1) With ""
Endif
End

########################################
Subprog AS_QTYPCU(VALEUR)
Variable Decimal VALEUR
If [M:SOM]WAIFLG(nolign-1)=1 | [M:SOM]XPCU(nolign-1)=[M:SOM]STU
   mkstat=2
Endif
End

########################################
Subprog C_QTYPCU(VALEUR)
Variable Decimal VALEUR
Local    Decimal WVARQTY, WVARQTA, WQTYSTU, WQTYSTUACT, WK
Local    Integer OK, NOL, NBL
NOL = nolign-1
NBL = [M:SOM]NBLIG-1

# La quantité a été modifiée
If VALEUR<>[M:SOM]QTYPCU(NOL)

   # Pas de quantité nulle, vous devez supprimer la ligne
   If VALEUR=0
      mkstat=2 : GMESSAGE=mess(392,199,1) : End
   Endif

   # Calcul quantité en US
   If [M:SOM]XPCUSTUCOE(NOL)=0 [M:SOM]XPCUSTUCOE(NOL)=1 Endif
   WQTYSTU = VALEUR*[M:SOM]XPCUSTUCOE(NOL)
   Call QTEARR(WQTYSTU,[M:SOM]STU) From TRTDIV

   # Calcul nouvelle quantité UA
   WQTYSTUACT = WQTYSTU

   If [M:SOM]WAIFLG(NOL)<>1
      If dim([M:SOM]POT)>0
         # Si gestion en titres ou UI, calcul quantité en UA
         Case [M:SOM]STOMGTCOD
          When 3 : If [M:SOM]POT(NOL)<>0
                      WQTYSTUACT = WQTYSTU*([M:SOM]POT(NOL)/100)
                      Call QTEARR(WQTYSTUACT,[M:SOM]STU) From TRTDIV
                   Endif
          When 4 : If [M:SOM]POT(NOL)<>0
                      WQTYSTUACT = WQTYSTU*[M:SOM]POT(NOL)
                      Call QTEARR(WQTYSTUACT,[M:SOM]STU) From TRTDIV
                   Endif
         Endcase
      Endif
   Endif

   # Variation de la quantité
   WVARQTY = WQTYSTU   -[M:SOM]QTYSTU(NOL)
   WVARQTA = WQTYSTUACT-[M:SOM]QTYSTUACT(NOL)

   # Si mvt normal et augmentation de la quantité
   If [M:SOM]WAIFLG(NOL)<>1 & WVARQTY>0
      # Si no série en sortie, il faut calculer la somme des qtés sortie (WK)
      # pour les lignes ayant le même chrono stock que celle modifiée
      If [M:SOM]SERMGTCOD=2
         Case NOL
          When 0       : WK = sigma(J=1,NBL,(([M]QTYSTU(J)-[M]QTYSTUORI(J))*([M]STOCOU(J)=[M]STOCOU(NOL))))
          When NBL     : WK = sigma(J=0,NBL-1,(([M]QTYSTU(J)-[M]QTYSTUORI(J))*([M]STOCOU(J)=[M]STOCOU(NOL))))
          When Default : WK = sigma(J=0,NOL-1,(([M]QTYSTU(J)-[M]QTYSTUORI(J))*([M]STOCOU(J)=[M]STOCOU(NOL))))
                         WK+= sigma(J=NOL+1,NBL,(([M]QTYSTU(J)-[M]QTYSTUORI(J))*([M]STOCOU(J)=[M]STOCOU(NOL))))
         Endcase
         # Si qté à sortir > disponible - somme (qté sortie - qté sortie origine)
         # du même chrono
         If WQTYSTU>[M:SOM]AVAQTYSTU(NOL)-WK
            mkstat=2 : GMESSAGE=mess(446,196,1) : End
         Else
            Gosub VERF_DISPO
            # Pas de stock disponible
            If WQTYSTUACT>WDISPO
               mkstat=2 : GMESSAGE =mess(446,196,1) : End
            Endif
         Endif
      # Sinon si qté à sortir > disponible
      Elsif WQTYSTU>[M:SOM]AVAQTYSTU(NOL)
         mkstat=2 : GMESSAGE=mess(446,196,1) : End
      Else
         Gosub VERF_DISPO
         # Pas de stock disponible
         If WQTYSTUACT>WDISPO
            mkstat=2 : GMESSAGE =mess(446,196,1) : End
         Endif
      Endif

   # Si mvt normal et diminution de la quantité
   Elsif [M:SOM]WAIFLG(NOL)<>1 & WVARQTY<0
      If dim([M:SOM]LOC)>0 & [M:SOM]LOC(NOL)<>""
         Call STKCTREMPM([M:SOM]LOC(NOL)) From STKLOC
         If mkstat : End : Endif
      Endif

   # Mvt en attente et qté totale US + variation US > qté à sortir US
   Elsif [M:SOM]WAIFLG(NOL)=1 & ([M:SOM]PECQTYACT+WVARQTA)>[M:SOM]SORQTYACT
      mkstat=2 : GMESSAGE=mess(393,199,1) : End
   Endif

   # Alimentation nouvelles quantités US et UA
   [M:SOM]QTYSTU(NOL)    = WQTYSTU
   [M:SOM]QTYSTUACT(NOL) = WQTYSTUACT
Endif

End

########################################
Subprog AM_QTYPCU(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL, WRET, WNBSER
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)
Local    Integer OK : OK=1               : #--- Issue 110327
NOL    = nolign-1

Affzo [M]QTYSTU(nolign-1)

# Si pas de mvt en attente et séries non gérés en sortie --> pas de recalcul
If [M:SOM]WAIFLG(NOL)<>1 & [M:SOM]SERMGTCOD<>2 End Endif
# Si pas de no série saisie --> pas de recalcul
If [M:SOM]SERNUM(NOL)="" End Endif

# La quantité a diminué
If VALEUR < [M:SOM]QTYPCU(NOL)
   WNBSER  = [M:SOM]QTYSTU(NOL)
   WNUMDEB = [M:SOM]SERNUM(NOL)
   If WNBSER=1
      [M:SOM]SERNUMF(NOL) = WNUMDEB
   Else
      Call PLUS_NB(WNUMDEB,WNBSER,WNUMFIN,WRET) From STKLIB
      If WRET=0
         [M:SOM]SERNUMF(NOL) = WNUMFIN
      Else
         mkstat=2 : GMESSAGE=WNUMDEB-":"-mess(476,197,1) : End
      Endif
   Endif
# La quantité a augmenté
Else
   # Vérification que les no série n'existent pas
   # et alimentation du no série fin
   WNBSER  = [M:SOM]QTYSTU(NOL)
   WNUMDEB = [M:SOM]SERNUM(NOL)

   # Si mvt mis à jour
   If [M:SOM]WAIFLG(NOL)<>1
      For J=2 To WNBSER
         Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
         If WRET=0
            Read [STS]STS0=[M:SOM]ITMREF;WNUMFIN
            #--- Issue 110327
            #If fstat
            #   WNUMDEB = WNUMFIN
            ## Le no série existe
            #Else
            #   # S'il n'a pas été sortie par cette pièce --> erreur
            #   If [F:STS]SDHTYP<>[M:SOM]VCRTYP | [F:STS]SDHNUM<>[M:SOM]VCRNUM
#&               | [F:STS]SDDLIN<>[M:SOM]VCRLIN
            #      mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
            #   # S'il a une pièce entrée --> erreur
            #   Elsif [F:STS]RCPVCRTYP<>0 & [F:STS]RCPVCRNUM<>""
            #      mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
            #   Endif
            #Endif
            # Si séries en E/S globale
            If [F:ITM]SERMGTCOD=4
               If fstat
                  mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(43,196,1) : Break
               Elsif [F:STS]STOCOU<>0 & [F:STS]STOCOU<>[M:SOM]STOCOU(NOL)
                  mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(447,184,1) : Break
               Elsif [F:STS]ISSDAT<>[0/0/0] & ([F:STS]SDHNUM<>[M:SOM]VCRNUM | [F:STS]SDDLIN<>[M:SOM]VCRLIN)
                  mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(37,184,1) : Break
               Elsif [F:STS]ISSDAT=[0/0/0] & [F:STS]SDHNUM<>"" & !find([F:STS]SDHNUM,[M:SOM]VCRNUM,[M:SOM]VCRNUMORI)
                  mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(443,184,1) : Break
               Endif
               If OK=1 & [M:SOM]VCRTYP=8 & [M:SOM]VCRNUMORI<>""
                 If [F:STS]RCPVCRTYP<>6 | [F:STS]RCPVCRNUM<>[M:SOM]VCRNUMORI | [F:STS]RCPVCRLIN<>[M:SOM]VCRLINORI
                   OK=1 : Call AVERTIR([F:STS]SERNUM+"\"+mess(489,184,1), OK) From GESECRAN
                   If OK=1  mkstat=2 : Break  Endif
                 Endif
               Endif
            # Si série en sortie qui existe
            Elsif !fstat
               # S'il n'a pas été sortie par cette pièce --> erreur
               If [F:STS]SDHTYP<>[M:SOM]VCRTYP | [F:STS]SDHNUM<>[M:SOM]VCRNUM
&               | [F:STS]SDDLIN<>[M:SOM]VCRLIN
                  mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
               # S'il a une pièce entrée --> erreur
               Elsif [F:STS]RCPVCRTYP<>0 & [F:STS]RCPVCRNUM<>""
                  mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
               Endif
            Endif
            WNUMDEB = WNUMFIN
            #--- End issue 110327
         Else
            mkstat=2 : GMESSAGE=WNUMDEB-":"-mess(476,197,1)  : Break
         Endif
      Next J
      If mkstat=2 End Endif
      [M:SOM]SERNUMF(NOL) = WNUMFIN
   # Sinon (mvt en attente) no série gérés en E/S
   Elsif [M:SOM]SERMGTCOD=3
      For J=2 To WNBSER
         Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
         If WRET=0
            Read [STS]STS0=[M:SOM]ITMREF;WNUMFIN
            If fstat
               WNUMDEB = WNUMFIN
            Else
               mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
            Endif
         Else
            mkstat=2 : GMESSAGE=WNUMDEB-":"-mess(476,197,1) : Break
         Endif
      Next J
      If mkstat=2 End Endif
      [M:SOM]SERNUMF(NOL) = WNUMFIN
   Endif
Endif

Affzo [M:SOM]SERNUM(NOL), SERNUMF(NOL)

End


#########################################################################
# TRAITEMENTS LIES AU PICKING DES LIGNES DE STOCK                       #
#########################################################################

#########################################################################
# Actions de la saisie fenêtre (traitement GSAISIE)                     #
#########################################################################

#########################################################################
#--- Issue 110327
# Remplacement de l'ancienne étiquette $FILGAUCHE
# par les nouvelles étiquettes $FILGAUCHE, $FILGAUSTO, $FILGAUSTS, $FILGAU2
#########################################################################
$FILGAUCHE

Raz FILGAUSUP(1)
Raz FILGAUSUP(2)
Raz FILGAUSUP(3)

Case currbox
 When GBOXSTO : Gosub FILGAUSTO
 When GBOXSTS : Gosub FILGAUSTS
Endcase
Return

#########################################################################
$FILGAUSTO

#--- Issue 117892
#If WAFFPICK=0 | LABR="SIH4" | LCONSULT
If WAFFPICK=0 | LABR="SIH4" | LCONSULT | GCONSULT
#---
   # Rien dans la liste de picking
   FILGAUSUP(0)='[F:STO]ITMREF=""&[F:STO]STOFCY=""'
   Return
Endif

# Filtre article, site
WCRITSTO1 = '[F:STO]ITMREF=[M:SOM]ITMREF&[F:STO]STOFCY=[M:SOM]STOFCY'
FILGAUSUP(0)=WCRITSTO1
# Filtre lot
If WCRITSTO2<>""
   FILGAUSUP(0)+='&'+WCRITSTO2
Endif
#--- TS 106217
# Prise en compte filtre version
If [M:SOM]PECECC=2
   # Si version renseignée et exclusive
   If WCRITSTO21<>""
      FILGAUSUP(0)+='&'+WCRITSTO21
   Endif
Endif
#---
# Filtre péremption
If [M:SOM]FLGDLULOT = 1 & WCRITSTO31<>""
   FILGAUSUP(0)+='&'+WCRITSTO31
Elsif [M:SOM]FLGSHLLOT = 1 & WCRITSTO3<>""
   FILGAUSUP(0)+='&'+WCRITSTO3
Endif

Gosub FILGAU2

Return

#########################################################################
$FILGAUSTS

If WAFFPICK=0 | [F:ITM]SERMGTCOD<>4 | LABR="SIH4" | LCONSULT | GCONSULT
   # Rien dans la liste de picking
   FILGAUSUP(0)='[F:STS]ITMREF=""&[F:STS]STOFCY=""'
   Return
Endif

# Filtre article, site
WCRITSTO1 = '[F:STS]ITMREF=[M:SOM]ITMREF&[F:STS]STOFCY=[M:SOM]STOFCY'
FILGAUSUP(0)=WCRITSTO1

# Filtre série dispo et ok
FILGAUSUP(0)+='&[F:STS]ISSDAT=[0/0/0]&[F:STS]STOCOU<>0&([F:STS]SDHNUM=""|[F:STS]SDHNUM=[M:SOM]VCRNUM)'

# Filtre lot
If WCRITSTO2<>""
   FILGAUSUP(0)+='&'+WCRITSTO2
Endif
#--- TS 106217
# Prise en compte filtre version
If [M:SOM]PECECC=2
   # Si version renseignée et exclusive
   If WCRITSTO21<>""
      FILGAUSUP(0)+='&'+WCRITSTO21
   Endif
Endif
#---

Gosub FILGAU2

Return

#########################################################################
$FILGAU2

# Filtre inventaire
FILGAUSUP(0)+='&[F:STO]CUNLOKFLG<>2'

# Filtre catégorie emplacement
If dim([M:SOM]LOC)>0 & WCRITSTO5<>""
   FILGAUSUP(1)+='&('+WCRITSTO5+')'         #--- TS 106217  (0-->1)
Endif
#--- TS 106217
# Filtre propriétaire
FILGAUSUP(1)+='&'+WCRITSTO6
#---
# Filtre propriétaire
#FILGAUSUP(0)+='&'+WCRITSTO6
# Filtre statuts
#If [M:SOM]XSTA<>"" | WCRITSTO4<>""
If WCRITSTO4<>""
   FILGAUSUP(1)+='&('+WCRITSTO4+')'
Else
   Raz WCRIT
   If [M:SOM]AAASTA=2
      WCRIT+=WCRITSTOA
   Endif
   If [M:SOM]QQQSTA=2
      If WCRIT<>"" WCRIT+='|' Endif
      WCRIT+=WCRITSTOQ
   Endif
   If [M:SOM]RRRSTA=2
      If WCRIT<>"" WCRIT+='|' Endif
      WCRIT+=WCRITSTOR
   Endif
   If WCRIT<>''
      FILGAUSUP(1)+='&('+WCRIT+')'
   Endif
Endif
# Filtre inventaire
#FILGAUSUP(1)+='&[F:STO]CUNLOKFLG<>2'
# Filtre lignes de stock indisponibles
#If [M:SOM]STODISFLG<>2
#   FILGAUSUP(1)+='&([F:STO]QTYSTU-[F:STO]CUMALLQTY-[F:STO]CUMWIPQTY>0)'
#Endif
# Filtres supplémentaires
#--- Issue X3-53322
If !find([M:SOM]FLPNNUM,"","*")
   FILGAUSUP(2)+='&pat([F:STO]LPNNUM,[M:SOM]FLPNNUM)<>0'
Endif
#---
If !find([M:SOM]XPALNUM,"","*")
   FILGAUSUP(2)+='&pat([F:STO]PALNUM,[M:SOM]XPALNUM)<>0'    #--- TS 106217   (1-->2)
Endif
If !find([M:SOM]XCTRNUM,"","*")
   FILGAUSUP(2)+='&pat([F:STO]CTRNUM,[M:SOM]XCTRNUM)<>0'    #--- TS 106217   (1-->2)
Endif
If [M:SOM]XPCUFIL<>""
    FILGAUSUP(2)+='&[F:STO]PCU=[M:SOM]XPCUFIL'               #--- TS 106217   (1-->2)
Endif

# Si lot (sous-lot) obligatoire le no doit être connu
If [F:ITM]LOTMGTCOD=3
   FILGAUSUP(2)+='&[F:STO]LOT<>""'                          #--- TS 106217   (1-->2)
Elsif [F:ITM]LOTMGTCOD=4
   FILGAUSUP(2)+='&[F:STO]LOT<>""&[F:STO]SLO<>""'           #--- TS 106217   (1-->2)
Endif
# Si série en E/S le no doit être connu
If [M:SOM]SERMGTCOD=3
   FILGAUSUP(2)+='&[F:STO]SERNUM<>""'                       #--- TS 106217   (1-->2)
Endif

# Si prise en compte filtre emplacement de la règle d'allocation
If [M:SOM]PECTRU=2
   If GSTOLOC<>""
      FILGAUSUP(3)+='&(pat([F:STO]LOC,GSTOLOC)<>0'
   Endif
   If GDEFLOC<>""
      If FILGAUSUP(3)=""
         FILGAUSUP(3)+='&(pat([F:STO]LOC,GDEFLOC)<>0'
      Else
         FILGAUSUP(3)+='|pat([F:STO]LOC,GDEFLOC)<>0'
      Endif
   Elsif GDEFLOCTYP<>""
      If FILGAUSUP(3)=""
         FILGAUSUP(3)+='&(pat([F:STO]LOCTYP,GDEFLOCTYP)<>0'
      Else
         FILGAUSUP(3)+='|pat([F:STO]LOCTYP,GDEFLOCTYP)<>0'
      Endif
   Endif
   If GDEFLOC2<>""
      If FILGAUSUP(3)=""
         FILGAUSUP(3)+='&(pat([F:STO]LOC,GDEFLOC2)<>0'
      Else
         FILGAUSUP(3)+='|pat([F:STO]LOC,GDEFLOC2)<>0'
      Endif
   Elsif GDEFLOCTYP2<>""
      If FILGAUSUP(3)=""
         FILGAUSUP(3)+='&(pat([F:STO]LOCTYP,GDEFLOCTYP2)<>0'
      Else
         FILGAUSUP(3)+='|pat([F:STO]LOCTYP,GDEFLOCTYP2)<>0'
      Endif
   Endif
   If GDEFLOC3<>""
      If FILGAUSUP(3)=""
         FILGAUSUP(3)+='&(pat([F:STO]LOC,GDEFLOC3)<>0'
      Else
         FILGAUSUP(3)+='|pat([F:STO]LOC,GDEFLOC3)<>0'
      Endif
   Elsif GDEFLOCTYP3<>""
      If FILGAUSUP(3)=""
         FILGAUSUP(3)+='&(pat([F:STO]LOCTYP,GDEFLOCTYP3)<>0'
      Else
         FILGAUSUP(3)+='|pat([F:STO]LOCTYP,GDEFLOCTYP3)<>0'
      Endif
   Endif
   If FILGAUSUP(3)<>"" FILGAUSUP(3)+=')' Endif
Endif

# Filtre lignes de stock indisponibles
If [M:SOM]STODISFLG<>2
   FILGAUSUP(3)+='&([F:STO]QTYSTU-[F:STO]CUMALLQTY-[F:STO]CUMWIPQTY>0)'
Endif

#--- TS 106217
# Filtre propriétaire
#FILGAUSUP(3)+='&'+WCRITSTO6
#---

Return

##########################################################################
$AP_FILGAUCHE

WPICK=2 : Gosub RAFFRAICHI

Return

#########################################################################
$CLE_GAUCHE

#--- Issue 110327
If currbox=GBOXSTO
   SNSLIS = 1       : # Ascendant
   # No série en E/S
   If [M:SOM]SERMGTCOD=3
      LENLIS = 8
      Case [M:SOM]LOTMGT
       When 1,3 : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STO]LOT;[F:STO]SLO;[F:STO]SERNUM;[F:STO]STOCOU"
                  LENLIS   = 6
       When 2   : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STL]LOTCREDAT;[F:STO]LOT;[F:STO]SLO;[F:STS]RCPDAT;[F:STO]SERNUM;[F:STO]STOCOU"
       When 4   : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STL]LOTCREDAT desc;[F:STO]LOT desc;[F:STO]SLO desc;[F:STS]RCPDAT desc;[F:STO]SERNUM desc;[F:STO]STOCOU Desc"
                  SNSLIS   = 2  : # Descendant
      Endcase
   Else
      LENLIS = 7
      Case [M:SOM]LOTMGT
       When 1   : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STO]LOT;[F:STO]SLO;[F:STO]LOC;[F:STO]STOCOU"
                  LENLIS   = 6
       When 2   : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STL]LOTCREDAT;[F:STO]LOT;[F:STO]SLO;[F:STO]LOC;[F:STO]STOCOU"
       When 3   : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STL]SHLDAT;[F:STO]LOT;[F:STO]SLO;[F:STO]LOC;[F:STO]STOCOU"
       When 4   : CLELISTE = "[F:STO]ITMREF;[F:STO]STOFCY;[F:STL]LOTCREDAT desc;[F:STO]LOT desc;[F:STO]SLO desc;[F:STO]LOC desc;[F:STO]STOCOU desc"
                  SNSLIS   = 2  : # Descendant
      Endcase
   Endif
#--- Issue 110327
Endif

Return
#########################################################################
$HINT_KEY

#Case currbox
# When Default : Return
# When GBOXSQ1 : HINTLIS(val(right$(GBOXSQ1,8)))="SQD1"
#Endcase

Return

##########################################################################
$DEB_PIC
Local Integer I, WRET
Local Char    SYMBOLE2(20)

Return

#########################################################################
#--- Issue 110327
# Remplacement de l'ancienne étiquette $CRE_PIC par les nouvelles étiquettes
# $CRE_PIC, $CRE_PICSTO, $CRE_PICSTS, $CTRL_PIC, $CTRL_DISPO et $ALIM_PIC
#########################################################################
$CRE_PIC
Case currbox
 When GBOXSTO : Gosub CRE_PICSTO
 When GBOXSTS : Gosub CRE_PICSTS
Endcase

Return

#########################################################################
$CRE_PICSTO

Raz WPICKSTO

Read [STO]STO0=[F:STO]STOFCY;[F:STO]STOCOU
If fstat
   Call RSTA ("STO",[F:STO]STOFCY-num$([F:STO]STOCOU)) From GLOCK
   FOK=0 : Return
Endif
Read [STL]STL0=[M:SOM]ITMREF;[F:STO]LOT;[F:STO]SLO
If fstat
   Call RSTA ("STL",[M:SOM]ITMREF-[F:STO]LOT-[F:STO]SLO) From GLOCK
   FOK=0 : Return
Endif

Gosub CTRL_PIC
If FOK=0 | GERR=1 : Return : Endif

Gosub CTRL_DISPO
If FOK=0 | GERR=1 : Return : Endif

# Contrôle de l'insertion
If [M:SOM]NBLIG+1 >= dim([M:SOM]STA)-1
   FOK=0 : GERR=1
   GMESSAGE=mess(122,199,1)
   Return
Endif

#--- La sélection est correcte

# Ouverture de la ligne
nolign = [M:SOM]NBLIG
Insa nolign,1,[M:SOM]NBLIG [M:SOM]NBLIG
[M:SOM]NBLIG += 1
nolign = [M:SOM]NBLIG
NOL = nolign-1
status = 0

[M:SOM]ICOMVTATT(NOL)=""

Raz [M:SOM]WAIFLG(NOL), [M:SOM]MVTSEQ(NOL), [M:SOM]MVTIND(NOL)

# Quantité UA restant à traiter
WQTYSTU=[M:SOM]SORQTYACT-([M:SOM]PECQTYACT+[M:SOM]SHTQTY)

If WDISPO>=WQTYSTU
   [M:SOM]QTYSTUACT(NOL)=WQTYSTU
Else
   [M:SOM]QTYSTUACT(NOL)=WDISPO
Endif

[M:SOM]QTYSTU(NOL) = [M:SOM]QTYSTUACT(NOL)

If dim([M:SOM]POT)>0
   If [M:SOM]STOMGTCOD=3
      [M:SOM]POT(NOL) = [F:STL]POT
   Elsif [M:SOM]STOMGTCOD=4
      [M:SOM]POT(NOL) = [F:STL]ACT
   Endif
   # Si gestion en titres ou UI, calcul quantité en UA
   Case [M:SOM]STOMGTCOD
    When 3 : If [M:SOM]QTYSTUACT(NOL)=[F:STO]QTYSTUACT    : #--- Issue 114287
                [M:SOM]QTYSTU(NOL)=[F:STO]QTYSTU          : #--- Issue 114287
             Elsif [M:SOM]POT(NOL)<>0
                [M:SOM]QTYSTU(NOL) = [M:SOM]QTYSTUACT(NOL)*100/[M:SOM]POT(NOL)
                Call QTEARR([M:SOM]QTYSTU(NOL),[M:SOM]STU) From TRTDIV
             Endif
    When 4 : If [M:SOM]QTYSTUACT(NOL)=[F:STO]QTYSTUACT    : #--- Issue 114287
                [M:SOM]QTYSTU(NOL)=[F:STO]QTYSTU          : #--- Issue 114287
             Elsif [M:SOM]POT(NOL)<>0
                [M:SOM]QTYSTU(NOL) = [M:SOM]QTYSTUACT(NOL)/[M:SOM]POT(NOL)
                Call QTEARR([M:SOM]QTYSTU(NOL),[M:SOM]STU) From TRTDIV
             Endif
   Endcase
Endif

[M:SOM]XPCU(NOL)       = [F:STO]PCU
[M:SOM]XPCUSTUCOE(NOL) = [F:STO]PCUSTUCOE

If [M:SOM]XPCUSTUCOE(NOL)=0 [M:SOM]XPCUSTUCOE(NOL)=1 Endif
[M:SOM]QTYPCU(NOL) = [M:SOM]QTYSTU(NOL)/[M:SOM]XPCUSTUCOE(NOL)
Call QTEARR([M:SOM]QTYPCU(NOL),[M:SOM]XPCU(NOL)) From TRTDIV

[M:SOM]AVAQTYPCU(NOL)  = WPCUDIS
[M:SOM]AVAQTYSTU(NOL)  = WSTUDIS
[M:SOM]TOTQTYSTU(NOL)  = [F:STO]QTYSTU

If dim([M:SOM]SERNUM)>0  [M:SOM]SERNUM(NOL) = [F:STO]SERNUM Endif
If dim([M:SOM]SERNUMF)>0 [M:SOM]SERNUMF(NOL)= [F:STO]SERNUM Endif
# Ligne de stock avec no série ?
Raz [M:SOM]SERNUMFLG(NOL)
If [F:STO]SERNUM<>"" [M:SOM]SERNUMFLG(NOL)=1 Endif

Gosub ALIM_PIC

Return

#########################################################################
$CRE_PICSTS

Raz WPICKSTO

Read [STS]STS0=[F:STS]ITMREF;[F:STS]SERNUM
If fstat
   Call RSTA ("STS",[F:STS]ITMREF-[F:STS]SERNUM) From GLOCK
   FOK=0 : Return
Endif
Read [STO]STO0=[F:STS]STOFCY;[F:STS]STOCOU
If fstat
   Call RSTA ("STO",[F:STS]STOFCY-num$([F:STS]STOCOU)) From GLOCK
   FOK=0 : Return
Endif
Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
If fstat
   Call RSTA ("STL",[F:STO]ITMREF-[F:STO]LOT-[F:STO]SLO) From GLOCK
   FOK=0 : Return
Endif

#--- No série en cours de traitement?
If func STKLIB.REC_STOSERW_UID([F:STS]ITMREF,[F:STS]SERNUM,adxuid(1))<>0
   GERR=1 : GMESSAGE=[F:STS]SERNUM-":"-mess(449,184,1)
   FOK=0  : Return
Endif

If [M:SOM]VCRTYP=8 & [M:SOM]VCRNUMORI<>""
  If [F:STS]RCPVCRTYP<>6 | [F:STS]RCPVCRNUM<>[M:SOM]VCRNUMORI | [F:STS]RCPVCRLIN<>[M:SOM]VCRLINORI
    OK=1 : Call AVERTIR([F:STS]SERNUM+"\"+mess(489,184,1), OK) From GESECRAN
    If OK=1  FOK=0 : Return  Endif
  Endif
Endif

Raz I, J, OK
# La ligne de stock est-elle déjà dans le tableau [M:SOM]
If [M:SOM]NBLIG <> 0
  I = find([F:STS]STOCOU,[M:SOM]STOCOU(J..[M:SOM]NBLIG-1))
Endif

# Calcul et contrôle disponible ligne de stock
Gosub CTRL_DISPO
If FOK=0 | GERR=1 : Return : Endif

If I<=0
  # Les contrôles sur la ligne de stock ne sont à faire que celle-ci
  # n'est pas déjà dans le tableau [M:SOM]
  Gosub CTRL_PIC
  If FOK=0 | GERR=1 : Return : Endif
Else
  # Contrôle du disponible de la ligne de stock du no série
  # cette ligne de stock peut être présente plusieurs fois dans le tableau
  Local Decimal WSTOCOU
  WSTOCOU=[M:SOM]STOCOU(I-1)
  WQTY=sigma(J=0,[M:SOM]NBLIG-1,([M:SOM]QTYSTU(J)-[M:SOM]QTYSTUORI(J))*([M:SOM]STOCOU(J)=WSTOCOU))
  WQTY+=1
  If WQTY>[M:SOM]AVAQTYSTU(I-1)
     FOK=0 : GERR=1 : GMESSAGE=mess(446,196,1)
     Return
  Endif

  # Si article non géré en titre ou en UI
  If !find([M:SOM]STOMGTCOD,3,4)
    # La quantité est déjà supérieure à la qte à traiter
    If [M:SOM]PECQTYACT+[M:SOM]SHTQTY>=[M:SOM]SORQTYACT
      FOK=0 : GERR=1 : GMESSAGE=mess(393,199,1)
      Return
    Endif
  Endif
  # Recherche si le no série pické peut être ajouté à une séquence de séries
  # pour la ligne de stock concernée (début ou fin)
  Raz J
  While OK<>1
    I = find([F:STS]STOCOU,[M:SOM]STOCOU(J..[M:SOM]NBLIG-1))
    If I<>0
      NOL = J+I-1
      J   = NOL+1
      Call PLUS_UN([F:STS]SERNUM,WNUMDEB,LRET) From STKLIB
      If LRET=0 & WNUMDEB=[M:SOM]SERNUM(NOL)
        OK=2 : Break
      Endif
      Call MOINS_UN([F:STS]SERNUM,WNUMFIN,LRET) From STKLIB
      If LRET=0 & WNUMFIN=[M:SOM]SERNUMF(NOL)
        OK=3 : Break
      Endif
    Else
      OK=1
    Endif
  Wend
Endif
# Si OK=2 ou 3, le no série peut être ajouté à la ligne de stock indicé par NOL
# dans le tableau [M:SOM]
If OK>1
  If OK=2
    [M:SOM]SERNUM(NOL)  = [F:STS]SERNUM
  Elsif OK=3
    [M:SOM]SERNUMF(NOL) = [F:STS]SERNUM
  Endif
  [M:SOM]QTYSTUACT(NOL) += 1
  [M:SOM]QTYSTU(NOL)    += 1
  [M:SOM]QTYPCU(NOL)    += 1
  [M:SOM]PECQTY         += 1
  [M:SOM]PECQTYACT      += 1
# Sinon il faut ajouter une ligne dans [M:SOM]
Else
  # Contrôle de l'insertion
  If [M:SOM]NBLIG+1 >= dim([M:SOM]STA)-1
    FOK=0 : GERR=1
    GMESSAGE=mess(122,199,1)
    Return
  Endif
  # Ouverture de la ligne
  nolign = [M:SOM]NBLIG
  Insa nolign,1,[M:SOM]NBLIG [M:SOM]NBLIG
  [M:SOM]NBLIG += 1
  nolign = [M:SOM]NBLIG
  NOL = nolign-1
  status = 0

  Raz [M:SOM]WAIFLG(NOL), [M:SOM]MVTSEQ(NOL), [M:SOM]MVTIND(NOL)
  [M:SOM]SERNUM(NOL)    = [F:STS]SERNUM
  [M:SOM]SERNUMF(NOL)   = [F:STS]SERNUM
  [M:SOM]ICOMVTATT(NOL) = ""
  [M:SOM]QTYSTUACT(NOL) = 1
  [M:SOM]QTYSTU(NOL)    = 1
  [M:SOM]QTYPCU(NOL)    = 1
  If dim([M:SOM]POT)>0
    If [M:SOM]STOMGTCOD=3
      [M:SOM]POT(NOL) = [F:STL]POT
    Elsif [M:SOM]STOMGTCOD=4
      [M:SOM]POT(NOL) = [F:STL]ACT
    Endif
  Endif
  [M:SOM]XPCU(NOL)       = [F:STO]PCU
  [M:SOM]XPCUSTUCOE(NOL) = [F:STO]PCUSTUCOE
  If [M:SOM]XPCUSTUCOE(NOL)=0 [M:SOM]XPCUSTUCOE(NOL)=1 Endif

  [M:SOM]AVAQTYPCU(NOL)  = WPCUDIS
  [M:SOM]AVAQTYSTU(NOL)  = WSTUDIS
  [M:SOM]TOTQTYSTU(NOL)  = [F:STO]QTYSTU

  [M:SOM]SERNUMFLG(NOL)=1

  Gosub ALIM_PIC

Endif

#--- Si no série en cours de traitement, il faut l'ajouter au disponible
If [F:ITM]SERMGTCOD=4
  If func STKLIB.REC_STOSERW([M:SOM]ITMREF,[F:STS]SERNUM)<>0
    [M:SOM]AVAQTYPCU(NOL) += 1
    [M:SOM]AVAQTYSTU(NOL) += 1
  Endif
Endif

Return

#########################################################################
#--- Contrôle de la ligne de stock pické
$CTRL_PIC

#--- TS 106217
# Contrôle version par rapport à la règle de gestion
If [F:STO]ECCVALMAJ<>""
  Call CTLECCVALMAJ([F:STO]ITMREF,[M:SOM]WECCVALMAJ,[F:STO]ECCVALMAJ,[M:SOM]IPTDAT,"",LRET) From STKSOR
  If LRET<>0
    FOK=0 : GERR=1
    Return
  Endif
Endif
#---

If [F:STO]LOCCAT=2
   Raz WRET
   # Contrôle que la ligne de stock en attente de rangement est complète
   Call CTLPLFLOC([M:SOM]ITMREF,"",WRET) From STKSOR
   If WRET<>0
      FOK=0 : GERR=1
      GMESSAGE =[F:STO]STOFCY-[F:STO]ITMREF-[F:STO]LOC-":"-mess(378,199,1)
      GMESSAGE+="\"+mess(377,199,1)-":"
      Case WRET
       When 1 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)
       When 2 : GMESSAGE+=mess(453,197,1)
       When 3 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)-","-mess(453,197,1)
      Endcase
      Return
   Endif
Endif

# Ligne de stock faisant l'objet d'une demande d'analyse
If [M:SOM]PECQLYCTL<>2 & [F:STO]QLYCTLDEM<>""
   FOK=0 : GERR=1
   GMESSAGE =mess(399,198,1)-":"-[F:STO]STA
   If [F:ITM]LOTMGTCOD>1
      GMESSAGE-=mess(43,197,1)-":"-[F:STO]LOT
   Endif
   If [F:ITM]LOTMGTCOD=4
      GMESSAGE-=mess(456,197,1)-":"-[F:STO]SLO
   Endif
   If [F:ITM]SERMGTCOD=3
      GMESSAGE-=mess(453,197,1)-":"-[F:STO]SERNUM
   Endif
   If [F:ITF]LOCMGTCOD=2
      GMESSAGE-=mess(44,197,1)-":"-[F:STO]LOC
   Endif
   GMESSAGE+="\"+mess(460,199,1)
Endif

# Si non administrateur stock, contrôle ligne pickée par rapport
# à la péremption et à la règle d'allocation
If GSTOADMIN<>2
   WPICKSTO=string$(evalue(WCRITPIC),"OK")
   If WPICKSTO<>"OK"
      FOK=0 : GERR=1
      GMESSAGE =mess(399,198,1)-":"-[F:STO]STA
      If [F:ITM]LOTMGTCOD>1
         GMESSAGE-=mess(43,197,1)-":"-[F:STO]LOT
      Endif
   If [F:ITM]LOTMGTCOD=4
      GMESSAGE-=mess(456,197,1)-":"-[F:STO]SLO
   Endif
   If [F:ITM]SERMGTCOD=3
      GMESSAGE-=mess(453,197,1)-":"-[F:STO]SERNUM
   Endif
   If [F:ITF]LOCMGTCOD=2
      GMESSAGE-=mess(44,197,1)-":"-[F:STO]LOC
   Endif
      GMESSAGE+="\"+mess(366,199,1)
      Return
   Endif
Endif

# La quantité est déjà supérieure à la qte à traiter
If [M:SOM]PECQTYACT+[M:SOM]SHTQTY>=[M:SOM]SORQTYACT
   FOK=0 : GERR=1
   GMESSAGE=mess(393,199,1)
   Return
Endif

Return

#########################################################################
#--- Calcul et contrôle du disponible de la ligne de stock pické
$CTRL_DISPO

# Calcul du stock disponible sur l'article
Raz LTYPLOC, LSTA
If [M:SOM]PECPLFLOC=2 LTYPLOC+=1 Endif
If [M:SOM]PECSCOLOC=2 LTYPLOC+=4 Endif
# Si pas d'emplacements internes
If [M:SOM]PECINTLOC=1 LTYPLOC=LTYPLOC*(-1) Endif
If [M:SOM]AAASTA=2    LSTA   +=1 Endif
If [M:SOM]QQQSTA=2    LSTA   +=2 Endif
If [M:SOM]RRRSTA=2    LSTA   +=4 Endif
Call STODISTOT("[F:ITV]",LTYPLOC,LSTA,[M:SOM]PECOWNER,WTOTACTDIS) From STKLIB

# Contrôle du disponible pour sortie sur la ligne de stock
Call STODISSOR("[F:STO]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB

# Disponible = min(dispo ligne stock, dispo article)
WDISPO = min(WSTUACTDIS,WTOTACTDIS)

# Pas de stock disponible
If WDISPO<=0
   FOK=0 : GERR=1
   If WTOTACTDIS <= 0
      GMESSAGE = mess(80,197,1)-[M:SOM]ITMREF-": "
   Else
      GMESSAGE = mess(644,197,1)-": "
   Endif
   GMESSAGE += mess(367,199,1)
   If GWIPSTOLCK=2 & [F:STO]LOCCAT=2
      # La qté en attente de rangement est peut être dans une liste à ranger
      GMESSAGE += "\"+mess(150,184,1)
   Endif
   Return
Endif

Return

#########################################################################
#--- Alimentation de la ligne de stock pické
$ALIM_PIC

If dim([M:SOM]LOT)>0     [M:SOM]LOT(NOL)    = [F:STO]LOT    Endif
If dim([M:SOM]SLO)>0     [M:SOM]SLO(NOL)    = [F:STO]SLO    Endif
If dim([M:SOM]LOC)>0     [M:SOM]LOC(NOL)    = [F:STO]LOC    Endif
If dim([M:SOM]WRH)>0     [M:SOM]WRH(NOL)    = [F:STO]WRH    Endif
#--- TS 106217
If dim([M:SOM]ECCVALMAJ)>0 [M:SOM]ECCVALMAJ(NOL) = [F:STO]ECCVALMAJ Endif
If dim([M:SOM]ECCVALMIN)>0 [M:SOM]ECCVALMIN(NOL) = [F:STL]ECCVALMIN Endif
#---
[M:SOM]STA(NOL)       = [F:STO]STA
[M:SOM]OWNER(NOL)     = [F:STO]OWNER

If dim([M:SOM]SHLDAT)>0  [M:SOM]SHLDAT(NOL) = [F:STL]SHLDAT Endif

#--- Issue X3-53322
If dim([M:SOM]LPNNUM)>0  [M:SOM]LPNNUM(NOL) = [F:STO]LPNNUM Endif
#---
If dim([M:SOM]PALNUM)>0  [M:SOM]PALNUM(NOL) = [F:STO]PALNUM Endif
If dim([M:SOM]CTRNUM)>0  [M:SOM]CTRNUM(NOL) = [F:STO]CTRNUM Endif

If dim([M:SOM]STOFLD1)>0 [M:SOM]STOFLD1(NOL)= [F:STO]STOFLD1 Endif
If dim([M:SOM]STOFLD2)>0 [M:SOM]STOFLD2(NOL)= [F:STO]STOFLD2 Endif

[M:SOM]STOCOU(NOL)    = [F:STO]STOCOU

[M:SOM]PECQTY        += [M:SOM]QTYSTU(NOL)
[M:SOM]PECQTYACT     += [M:SOM]QTYSTUACT(NOL)

If dim([M:SOM]LOT)>0    Diszo [M:SOM]LOT(NOL)    Endif
If dim([M:SOM]SLO)>0    Diszo [M:SOM]SLO(NOL)    Endif
If dim([M:SOM]LOC)>0    Diszo [M:SOM]LOC(NOL)    Endif
If dim([M:SOM]WRH)>0
   If WRHGES=2
      Diszo [M:SOM]WRH(NOL)
   Else
      Grizo [M:SOM]WRH(NOL)
   Endif
Endif
#--- TS 106217
If dim([M:SOM]ECCVALMAJ)>0 Diszo [M:SOM]ECCVALMAJ(NOL) Endif
#---

If [M:SOM]SERMGTCOD=2
   If dim([M:SOM]SERNUM)>0
      # No série déjà existant ou retour fournisseur, pas de saisie
      If [M:SOM]SERNUMFLG(I)=1 | [M:SOM]VCRTYP=8
         Diszo [M:SOM]QTYSTU(NOL)
         Diszo [M:SOM]QTYPCU(NOL)
         Diszo [M:SOM]SERNUM(I)
      Else
         Actzo [M:SOM]QTYSTU(NOL)
         Actzo [M:SOM]QTYPCU(NOL)
         # Si trf inter-site mais intra-société, pas de saisie no série
         If [M:SOM]TRFFCY<>"" & [M:SOM]BETCPY<>2
            Diszo [M:SOM]SERNUM(I)
         Else
            Actzo [M:SOM]SERNUM(I)
         Endif
      Endif
   Else
      Actzo [M:SOM]QTYSTU(NOL)
      Actzo [M:SOM]QTYPCU(NOL)
   Endif
Elsif [M:SOM]SERMGTCOD=3
   Diszo [M:SOM]QTYSTU(NOL)
   Diszo [M:SOM]QTYPCU(NOL)
   If dim([M:SOM]SERNUM)>0 Diszo [M:SOM]SERNUM(NOL) Endif
#--- Issue 110327
Elsif [M:SOM]SERMGTCOD=4
   Actzo [M:SOM]QTYSTU(NOL)
   Diszo [M:SOM]QTYPCU(NOL)
   If dim([M:SOM]SERNUM)>0 Actzo [M:SOM]SERNUM(NOL) Endif
#---
Else
   Actzo [M:SOM]QTYSTU(NOL)
   Actzo [M:SOM]QTYPCU(NOL)
   If dim([M:SOM]SERNUM)>0 Diszo [M:SOM]SERNUM(NOL) Endif
Endif
Diszo [M:SOM]STA(NOL)

Return

#########################################################################
#--- Issue 110327
# Remplacement de l'ancienne étiquette $ANU_PIC
# par les nouvelles étiquettes $ANU_PIC, $ANU_PICSTO, $ANU_PICSTS
#########################################################################
$ANU_PIC

Raz I,J
Case currbox
 When GBOXSTO : Gosub ANU_PICSTO
 When GBOXSTS : Gosub ANU_PICSTS
Endcase
Return

#########################################################################
$ANU_PICSTO

Raz I,J
OK = 0
If [M:SOM]NBLIG <> 0
   # Le dépick d'une ligne de stock peut entraîner la suppression
   # de plusieurs lignes de [SOR] (même chrono stock)
   # - si article avec no série en sortie
   # - de façon exceptionnelle suite à une régul de mvt en attente ou ...
   While OK <> 1
      I = find([F:STO]STOCOU,[M:SOM]STOCOU(J..[M:SOM]NBLIG-1))
      If I<>0
         NOL = J+I-1
         J   = NOL
         [M:SOM]PECQTY    -= [M:SOM]QTYSTU(NOL)
         [M:SOM]PECQTYACT -= [M:SOM]QTYSTUACT(NOL)
         Dela NOL,1,[M:SOM]NBLIG-1 [M:SOM]NBLIG
         [M:SOM]NBLIG -= 1
         If J>[M:SOM]NBLIG-1 OK=1 Endif
      Else
         OK=1
      Endif
   Wend
Endif

Return

#########################################################################
$ANU_PICSTS

OK = 0
If [M:SOM]NBLIG <> 0
  While OK <> 1
    I = find([F:STS]STOCOU,[M:SOM]STOCOU(J..[M:SOM]NBLIG-1))
    If I<>0
      NOL = J+I-1
      J   = NOL+1
      # Le no sére dépické est celui de la séquence unitaire de série de [M:SOM]
      If [F:STS]SERNUM=[M:SOM]SERNUM(NOL) & [F:STS]SERNUM=[M:SOM]SERNUMF(NOL)
        [M:SOM]PECQTY    -= [M:SOM]QTYSTU(NOL)
        [M:SOM]PECQTYACT -= [M:SOM]QTYSTUACT(NOL)
        Dela NOL,1,[M:SOM]NBLIG-1 [M:SOM]NBLIG
        [M:SOM]NBLIG -= 1
        OK=1
      # Le no série dépické est le premier de la séquence de série de [M:SOM]
      Elsif [F:STS]SERNUM=[M:SOM]SERNUM(NOL)
        [M:SOM]QTYSTU(NOL)    -= 1
        [M:SOM]QTYSTUACT(NOL) -= 1
        [M:SOM]PECQTY         -= 1
        [M:SOM]PECQTYACT      -= 1
        Call PLUS_UN([F:STS]SERNUM,[M:SOM]SERNUM(NOL),WRET) From STKLIB
        OK=1
      # Le no série dépické est le dernier de la séquence de série de [M:SOM]
      Elsif [F:STS]SERNUM=[M:SOM]SERNUMF(NOL)
        [M:SOM]QTYSTU(NOL)    -= 1
        [M:SOM]QTYSTUACT(NOL) -= 1
        [M:SOM]PECQTY         -= 1
        [M:SOM]PECQTYACT      -= 1
        Call MOINS_UN([F:STS]SERNUM,[M:SOM]SERNUMF(NOL),WRET) From STKLIB
        OK=1
      # Le no série dépické est dans la séquence de série de [M:SOM]
      # Il faut éclaté en 2 la ligne correspondante dans [M:SOM]
      Elsif [F:STS]SERNUM>[M:SOM]SERNUM(NOL) & [F:STS]SERNUM<[M:SOM]SERNUMF(NOL)
        Insa NOL+1,1,[M:SOM]NBLIG+1 [M:SOM]NBLIG
        [M:SOM]NBLIG += 1
        [M:SOM]ICOMVTATT(NOL+1)  = [M:SOM]ICOMVTATT(NOL)
        [M:SOM]SERNUMFLG(NOL+1)  = [M:SOM]SERNUMFLG(NOL)
        [M:SOM]STA(NOL+1)        = [M:SOM]STA(NOL)
        [M:SOM]XPCU(NOL+1)       = [M:SOM]XPCU(NOL)
        [M:SOM]XPCUSTUCOE(NOL+1) = [M:SOM]XPCUSTUCOE(NOL)
        [M:SOM]OWNER(NOL+1)      = [M:SOM]OWNER(NOL)
        [M:SOM]STOCOU(NOL+1)     = [M:SOM]STOCOU(NOL)
        If dim([M:SOM]LOT)>0       [M:SOM]LOT(NOL+1)       = [M:SOM]LOT(NOL)       Endif
        If dim([M:SOM]SLO)>0       [M:SOM]SLO(NOL+1)       = [M:SOM]SLO(NOL)       Endif
        If dim([M:SOM]ECCVALMAJ)>0 [M:SOM]ECCVALMAJ(NOL+1) = [M:SOM]ECCVALMAJ(NOL) Endif
        If dim([M:SOM]ECCVALMIN)>0 [M:SOM]ECCVALMIN(NOL+1) = [M:SOM]ECCVALMIN(NOL) Endif
        If dim([M:SOM]WRH)>0       [M:SOM]WRH(NOL+1)       = [M:SOM]WRH(NOL)       Endif
        If dim([M:SOM]LOC)>0       [M:SOM]LOC(NOL+1)       = [M:SOM]LOC(NOL)       Endif
        If dim([M:SOM]SHLDAT)>0    [M:SOM]SHLDAT(NOL+1)    = [M:SOM]SHLDAT(NOL)    Endif
        If dim([M:SOM]POT)>0       [M:SOM]POT(NOL+1)       = [M:SOM]POT(NOL)       Endif
        #--- Issue X3-53322
        If dim([M:SOM]LPNNUM)>0    [M:SOM]LPNNUM(NOL+1)    = [M:SOM]LPNNUM(NOL)    Endif
        #---
        If dim([M:SOM]PALNUM)>0    [M:SOM]PALNUM(NOL+1)    = [M:SOM]PALNUM(NOL)    Endif
        If dim([M:SOM]CTRNUM)>0    [M:SOM]CTRNUM(NOL+1)    = [M:SOM]CTRNUM(NOL)    Endif
        If dim([M:SOM]STOFLD1)>0   [M:SOM]STOFLD1(NOL+1)   = [M:SOM]STOFLD1(NOL)   Endif
        If dim([M:SOM]STOFLD2)>0   [M:SOM]STOFLD2(NOL+1)   = [M:SOM]STOFLD2(NOL)   Endif
        [M:SOM]PRIORD(NOL+1)     = [M:SOM]PRIORD(NOL)
        [M:SOM]PRIVAL(NOL+1)     = [M:SOM]PRIVAL(NOL)
        [M:SOM]WAIFLG(NOL+1)     = [M:SOM]WAIFLG(NOL)
        [M:SOM]MVTSEQ(NOL+1)     = 0
        [M:SOM]MVTIND(NOL+1)     = 0
        If dim([M:SOM]SERNUMF)>0
          [M:SOM]SERNUMF(NOL+1)   = [M:SOM]SERNUMF(NOL)
          Call MOINS_UN([F:STS]SERNUM,[M:SOM]SERNUMF(NOL),WRET) From STKLIB
        Endif
        If dim([M:SOM]SERNUM)>0
          Call PLUS_UN([F:STS]SERNUM,[M:SOM]SERNUM(NOL+1),WRET) From STKLIB
        Endif
        Call NB_SERIE([M:SOM]SERNUM(NOL),[M:SOM]SERNUMF(NOL),WNBSER,WRET) From STKLIB
        [M:SOM]QTYSTU(NOL+1)    = [M:SOM]QTYSTU(NOL)-WNBSER-1
        [M:SOM]QTYPCU(NOL+1)    = [M:SOM]QTYSTU(NOL+1)
        [M:SOM]QTYSTUACT(NOL+1) = [M:SOM]QTYSTU(NOL+1)
        [M:SOM]QTYSTU(NOL)      = WNBSER
        [M:SOM]QTYPCU(NOL)      = [M:SOM]QTYSTU(NOL)
        [M:SOM]QTYSTUORI(NOL)   = [M:SOM]QTYSTU(NOL)
        [M:SOM]QTYSTUACT(NOL)   = [M:SOM]QTYSTU(NOL)
        [M:SOM]TOTQTYSTU(NOL+1) = [M:SOM]TOTQTYSTU(NOL)

        # Le stock dispo ne change pas, il est le même pour les deux [SOR]
        [M:SOM]AVAQTYSTU(NOL+1) = [M:SOM]AVAQTYSTU(NOL)
        [M:SOM]AVAQTYPCU(NOL+1) = [M:SOM]AVAQTYSTU(NOL+1)

        # On met toute la qté origine possible sur le [M:SOM] origine
        # puis on complète sur le nouveau [M:SOM]
        [M:SOM]QTYSTUORI(NOL+1) = 0
        If [M:SOM]QTYSTUORI(NOL)>[M:SOM]QTYSTU(NOL)
          [M:SOM]QTYSTUORI(NOL+1)  = [M:SOM]QTYSTUORI(NOL)-[M:SOM]QTYSTU(NOL)
          [M:SOM]QTYSTUORI(NOL)    = [M:SOM]QTYSTU(NOL)
        Endif
        [M:SOM]PECQTY    -= 1
        [M:SOM]PECQTYACT -= 1
      Endif
    Else
      OK=1
    Endif
  Wend
Endif

Return
#--- End issue 110327

#########################################################################
$FIN_PIC

Affzo [M:SOM]1-99

If [M:SOM]NBLIG<>0
   # Repositionnement sur la ligne pickée
   zonsui = "[M:SOM]NBLIG("+num$(NOL)+")"
Endif

Return

#########################################################################
# Etiquettes de traitement                                              #
#########################################################################

#########################################################################
$TIROIR
#-----------------------------------------------------------------------#
# Remplissage de la liste de picking                                    #
#-----------------------------------------------------------------------#

ILIS=val(right$(currbox,8))
Gosub REMPLIT From GSAISIE
If WAFFPICK<>0
   WPICK=2
   Gosub RAFFRAICHI
Endif

Return

#########################################################################
$RAFFRAICHI
#-----------------------------------------------------------------------#
# Raffraichissement de la liste picking pour les lignes déjà saisies    #
#-----------------------------------------------------------------------#

#--- Issue 110327
If currbox=GBOXSTO
#---
  If [M:SOM]NBLIG <> 0
    For I=0 To [M:SOM]NBLIG-1
      If [M:SOM]STOCOU(I) <> 0
        Read [STO]STO0=[M:SOM]STOFCY;[M:SOM]STOCOU(I)
        Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
        If [M:SOM]SERMGTCOD=3 Read [STS]STS0=[F:STO]ITMREF;[F:STO]SERNUM Endif
        If evalue(FILGAUSUP)
          If    WPICK=1 Gosub DEPICK From GSAISIE
          Elsif WPICK=2 Gosub REPICK From GSAISIE
          Endif
        Endif
      Endif
    Next I
  Endif
#--- Issue 110327
Elsif currbox=GBOXSTS
  If [M:SOM]NBLIG <> 0
    For I=0 To [M:SOM]NBLIG-1
      WRET=0
      For J=1 To [M:SOM]QTYSTU(I)
        If J=1
          WNUMFIN=[M:SOM]SERNUM(I)
        Else
          Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
          If WRET<>0 : Break : Endif
        Endif
        Read [STS]STS0=[M:SOM]ITMREF;WNUMFIN
        Read [STO]STO0=[M:SOM]STOFCY;[F:STS]STOCOU
        WNUMDEB=WNUMFIN
        If evalue(FILGAUSUP)
          If    WPICK=1 Gosub DEPICK From GSAISIE
          Elsif WPICK=2 Gosub REPICK From GSAISIE
          Endif
        Endif
      Next J
    Next I
  Endif
Endif
#--- End issue 110327

Return

##########################################################################

