#<AdxTL>@(#)1.0.0.0 $Revision$
########################################################################
# Traitement TRTSTOSOM - Modification des sorties                 V140 #
#                                                                      #
########################################################################
# Action SAISTOSOM
#    Paramètres     - LABR    Abréviation masque : "SDH1" par exemple
#                   - LNOL    No ligne écran (nolign-1)
#                   - LITM    Article
#                   - LFCY    Site
#                   - GVCRTYP Type de document
#
########################################################################
$ACTION

# Traitement de modification des sorties
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "OUVRE_BOITE"   : Gosub OUVRE_BOITE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "AVANT_ENR"     : Gosub AVANT_ENR
 When "ENR"           : Gosub ENR
 When "ABA"           : Gosub ABA
 When "BOUTON"        : Gosub BOUTON
 When "MEN"           : Gosub MENU
 When "FIN"           : Gosub FIN
 When "FINSAI"        : Gosub FINSAI
 When "RAF"           : WAFFPICK=1
 When "TIR"           : WAFFPICK=1
 When "FILGAUCHE"     : Gosub FILGAUCHE
 When "AP_FILGAUCHE"  : Gosub AP_FILGAUCHE
 When "CLE_GAUCHE"    : Gosub CLE_GAUCHE
 When "HINT"          : Gosub HINT_KEY
 When "DEB_PIC"       : Gosub DEB_PIC
 When "CRE_PIC"       : Gosub CRE_PIC
 When "ANU_PIC"       : Gosub ANU_PIC
 When "FIN_PIC"       : Gosub FIN_PIC
 When Default
Endcase

Return

#########################################################################

$OUVRE

Global Integer GSAISERIE      : # Pour maj picking si no séries (E/S) saisis  : #--- Issue 110327
Global Integer GSUPLIG        : # Pour identifier que l'on supprime une ligne
Global Char    GLOCCAT(4)     : # Pour filtrer les catégories d'emplacements
Global Integer GTYPLIG        : # 0=Normale / 1=Composant kit
Global Libelle GVCRTYP        : # Type de document
Global Char    GXSTA(12)      : # Stockage du filtre statut
Global Char    GCHARGRUPT(1)  : # Si "N" pas de rechragement des ruptures
Global Char    GSTOLOC(GLONLOC)
Global Char    GDEFLOC(GLONLOC), GDEFLOC2(GLONLOC), GDEFLOC3(GLONLOC)
Global Char    GDEFLOCTYP(GLONTLO), GDEFLOCTYP2(GLONTLO), GDEFLOCTYP3(GLONTLO)

Local Char    LABR            : # Abréviation masque origine
Local Integer LNOL            : # No ligne courante (nolign-1) masque origine
Local Char    LITM(GLONITM)   : # Article
Local Char    LFCY(GLONFCY)   : # Site
Local Decimal LQTA, LSHT
Local Integer LNBR, LNBJ, LRET
Local Integer I, J, NOL
Local Integer OKRUP           : # 1=génération de rupture
Local Integer WPICK           : # 1=depick / 2=pick
Local Integer WAFFPICK        : # 0=pas d'alimentation picking
Local Char    WTRUCOD         : # Règle d'allocation

Local Integer LSST
Local Char    LWRH(GLONWRH)
Local Integer WRHGES          : # Gestion de dépôt sur le site
Local Char    WCRITERE(150)
Local Char    WCRIT(200)
Local Char    WCRITPIC(250)   : # Critère pour contrôle ligne stock pickée
Local Char    WCRITSTO(250)   : # Critère pour chargement picking ligne stock
Local Char    WCRITSTO1(80)   : # Critère article et site
Local Char    WCRITSTO2(80)   : # Critère lot                   #--- TS 106217
Local Char    WCRITSTO21(40)  : # Critère version               #--- TS 106217
Local Char    WCRITSTO3(80)   : # Critère péremption
Local Char    WCRITSTO31(80)  : # Critère DLU                   # hcb V6percri
Local Char    WCRITSTO4(100)  : # Critère statuts
Local Char    WCRITSTO5(80)   : # Critère catégorie emplacements et dépôt
Local Char    WCRITSTO6(50)   : # Critère propriétaire du stock
Local Char    WPICKSTO(2)
Local Char    PADMIN
Local Date    WDAT            : # Date de référence pour péremption
Local Integer WA, WQ, WR
Local Decimal WPCUDIS, WSTUDIS, WSTUACTDIS, WTOTACTDIS, WDISPO
Local Decimal WQTY, WQTYSTU
#--- Issue X3-52393
Local Decimal WSORQTY, WSORQTYACT
Local Integer WGENR           : # 1 si on a enregistré , 0 sinon
Local Integer LTYPLOC, LSTA
Local Decimal LSTOCOU, LWIPQTY, LWIPQTA
Local Integer LIND1           : # Indice pour récupérer sections ana document
                                # 0 : section entête, nolign : section ligne
Local Integer LIND2           : # Indice tableau sections analytiques
Local Char    LANA(GLONCDE)   : # Code section analytique par défaut
Local Char    SECTION
Local Integer WNBLIG
Local Char    WSERSVG(GLONSER)
Local Char    WSHTECCVALMAJ(GLONECS) : # Version de rupture     #--- TS 106217
Local Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)              : #--- Issue 110327
#DLUBPC
Local Char NBDAY(10)

Local Integer LCONSULT  # Issue 91384 - 2013-08-02 by CCC
LCONSULT=0

Raz WGENR
Raz GSAISERIE         : #--- Issue 110327

# hcb 27842
# Ouverture fenêtre de modifications des sorties inutile --> on ressort
If GOUVSOR<>1
   FIN=1
   Return
Endif


If clalev([F:ITG])=0  Local File ITMCATEG   [ITG]   Endif
If clalev([F:ITM])=0  Local File ITMMASTER  [ITM]   Endif
If clalev([F:ITF])=0  Local File ITMFACILIT [ITF]   Endif
If clalev([F:ITV])=0  Local File ITMMVT     [ITV]   Endif
If clalev([F:TRU])=0  Local File TABALLRUL  [TRU]   Endif
If clalev([F:SRU])=0  Local File TABSTORUL  [SRU]   Endif
If clalev([F:STL])=0  Local File STOLOT     [STL]   Endif
If clalev([F:STO])=0  Local File STOCK      [STO]   Endif
If clalev([F:STS])=0  Local File STOSER     [STS]   Endif
If clalev([F:SWW])=0  Local File STOWIPW    [SWW]   Endif
If clalev([F:STJ])=0  Local File STOJOU     [STJ]   Endif
#--- TS 106217
If clalev([F:ECS])=0  Local File ECCSTA     [ECS]   Endif
#--- X3-53322
If clalev([F:LPN])=0  Local File LPN        [LPN]   Endif
If GWRHACT=2
   If clalev([F:ITW])=0  Local File ITMWRH    [ITW] Endif
   If clalev([F:WRH])=0  Local File WAREHOUSE [WRH] Endif
Endif
#DLUBPC
If clalev([F:ITU])=0  Local File ITMBPC     [ITU]   Endif

# Classe écran pour le moteur de maj
If clalev([M:STW])=0  Local Mask STOWORK    [STW]   Endif
If clalev([M:SVW])=0  Local Mask STOVALWORK [SVW]   Endif

# Récupération paramètre administrateur stock
Call PARAMUTIL("STOADMIN",PADMIN,"","") From SUBAUS
GSTOADMIN = val(PADMIN)

# Récupération des paramètres
LABR    = PARAM(1)
LNOL    = val(PARAM(2))
LITM    = PARAM(3)
LFCY    = PARAM(4)
GVCRTYP = val(PARAM(5))


#------------------------------------------------------------------------
# Resynchro des qtés en cours de traitement pour l'article et le site
#------------------------------------------------------------------------
Local Char  WPARAM(250)(1..20)
WPARAM(1) = LITM
WPARAM(2) = LFCY
Call TRAITE_NUM(GBIDD1,WPARAM,"","FUNSTOWIPW","",1,"XYFUNSTOWIPW") From GTRAITE
#------------------------------------------------------------------------

#--- Lecture article
If [F:ITM]ITMREF<>LITM
   Read [ITM]ITM0=LITM
   If fstat
      Call ERREUR(LITM-":"-mess(134,100,1)) From GESECRAN
      FIN=1 : Return
   Endif
Endif
#--- Lecture article site
If LFCY<>"" & ([F:ITF]ITMREF<>LITM | [F:ITF]STOFCY<>LFCY)
   Read [ITF]ITF0=[F:ITM]ITMREF;LFCY
   If fstat
      Call ERREUR(LITM-":"-mess(2,196,1)-":"-LFCY) From GESECRAN
      FIN=1 : Return
   Endif
Endif

# Passage en invisible des zones stock selon l'article
Gosub FORMAT_INV From STKLIB
#--- Issue 110678
# Rajout de la couleur : "c" et du mode affiché : "P"
#Call DYNAMIC(GWSINVLOT,":","c;") From TEXTE
#GWSINVLOT=ctrans(GWSINVLOT,";",":")
#Call DYNAMIC(GWSINVSLO,":","c;") From TEXTE
#GWSINVSLO=ctrans(GWSINVSLO,";",":")
#Call DYNAMIC(GWSINVEMP,":","c;") From TEXTE
#GWSINVEMP=ctrans(GWSINVEMP,";",":")
#Call DYNAMIC(GWSINVSER,":","c;") From TEXTE
#GWSINVSER=ctrans(GWSINVSER,";",":")
#Call DYNAMIC(GWSINVSERF,":","c;") From TEXTE
#GWSINVSERF=ctrans(GWSINVSERF,";",":")
#Call DYNAMIC(GWSINVWRH,":","c;") From TEXTE
#GWSINVWRH=ctrans(GWSINVWRH,";",":")
#--- TS 106217
#Call DYNAMIC(GWSINVECCMAJ,":","c;") From TEXTE
#GWSINVECCMAJ=ctrans(GWSINVECCMAJ,";",":")
#Call DYNAMIC(GWSINVECCMIN,":","c;") From TEXTE
#GWSINVECCMIN=ctrans(GWSINVECCMIN,";",":")
#---

# Passage en invisible des quantités en UA si non géré en titre
If [F:ITF]STOMGTCOD>2
   GSINVACT = "NPz:"+GUNTFMT
Else
   GSINVACT = "-NPz:"+GUNTFMT
Endif

# Passage en invisible des quantités en UA si non géré en titre
#If [F:ITM]STOMGTCOD>2
#   GSINVACT  = "NPz:"+GUNTFMT
#   GSINVACTS = "Nz:"+GUNTFMT
#   Call TEXTE(19667,GSINTACT1) From OBJDIV
#   Call TEXTE(19668,GSINTACT2) From OBJDIV
#   Call TEXTE(23370,GSINTACT3) From OBJDIV
#Else
#   GSINVACT  = "-NPz:"+GUNTFMT
#   GSINVACTS = "-Nz:"+GUNTFMT
#   Raz GSINTACT1, GSINTACT2, GSINTACT3
#Endif

# Passage en invisible des quantités physiques si non géré en titre
#If [F:ITM]STOMGTCOD>2
#   GSINVPHY  = "NPz:"+GUNTFMT
#   Call TEXTE(23687,GSINTPHY1) From OBJDIV
#   Call TEXTE(23688,GSINTPHY2) From OBJDIV
#Else
#   GSINVPHY  = "-NPz:"+GUNTFMT
#   Raz GSINTPHY1, GSINTPHY2
#Endif

Return

#########################################################################
$OUVRE_BOITE
#--- Issue 110327
# Récupération des noms de currbox des tiroirs
Global Char  GBOXSTO(10),GBOXSTS(10)
GBOXSTO = "GAU_CHE1"
GBOXSTS = "GAU_CHE2"
# OBJLIS n'est pas connu ???
#GBOXSTO = "GAU_CHE"+num$(find("STO",OBJLIS(1..8)))
#GBOXSTS = "GAU_CHE"+num$(find("STS",OBJLIS(1..8)))
#---

# X3-80367 - Reset the message flag for this change.
GNCSLINFLG = 0

Return

#########################################################################
$DEBUT

Raz [M:SOM]

#-----------------------------------------------------------------------
# Traitement à alimenter pour les différentes fonctions
# Chargement des blocs 1 et 2 de [M:SOM]
#-----------------------------------------------------------------------
Raz GTYPLIG
Gosub CHARGE_PARAM From TRTSTOSOMA
#--- Issue 52393
WSORQTY    = [M:SOM]SORQTY
WSORQTYACT = [M:SOM]SORQTYACT
#---
If [F:FCY]FCY<>LFCY
   Read [FCY]FCY0=LFCY
   If fstat Raz [F:FCY] Endif
Endif
WRHGES=[F:FCY]WRHGES

Call LECITM(LFCY,LITM,"",0,[M:SOM]XWRH,LRET) From STKLIB
If LRET<>0
   FIN=1 : Return
Endif

[M:SOM]ITMREF = LITM
[M:SOM]STOFCY = LFCY
#--- Bug 65418
#[M:SOM]VCRTYP = GVCRTYP
If [M:SOM]VCRTYP=0 : [M:SOM]VCRTYP=GVCRTYP : Endif
#---

# Issue 91384 - 2013-08-02 by CCC : Si une régul de sortie en FIFO est en attente => modif interdite
If func STKVAL.WAITISSADJ([M:SOM]STOFCY,[M:SOM]ITMREF,[M:SOM]VCRTYP,[M:SOM]VCRNUM,[M:SOM]VCRLIN)
    Call ERREUR(mess(415,184,1)) From GESECRAN
    LCONSULT=1
Endif

If GERR | FIN Return Endif

# Dépôt obligatoire ou renseigné sur ligne document --> non modifiable
If [M:SOM]XWRH<>""
   [M:SOM]WRHOBY=2
Else
   [M:SOM]WRHOBY=1
   LSST=0
   # Sous-traitance
   If find([M:SOM]VCRTYP,10,12) & [M:SOM]PECSCOLOC=2
#&   |([M:SOM]VCRTYP=34 & [M:SOM]LOCCAT=4)
      LSST=1
   Endif
   # Alimentation dépôt exclusif article-site pour filtrer le stock
   Call WRHAUTO([M:SOM]STOFCY,[M:SOM]ITMREF,[M:SOM]VCRTYP,LSST,LWRH) From STKWRH
   If !find(LWRH,"","*")
      [M:SOM]XWRH = LWRH
   Endif
Endif

# Stockage du filtre statut
GXSTA = [M:SOM]XSTA

# Si non renseigné car ajouté 05.08
If [M:SOM]PECINTLOC=0 [M:SOM]PECINTLOC=2 Endif
# Filtre catégorie emplacement pour le contrôle et la sélection emplacement
Raz GLOCCAT
If [M:SOM]PECINTLOC=2 GLOCCAT+="1" Endif
If [M:SOM]PECPLFLOC=2 GLOCCAT+="2" Endif
If [M:SOM]PECSCOLOC=2 GLOCCAT+="4" Endif

# Par défaut, pas d'affichage des lignes de stock indisponibles
[M:SOM]STODISFLG=1

# Alimentation du masque STOSORM
GCHARGRUPT = ""

Gosub ALI_MSK_SOM

If FIN=1 Return Endif

If [M:SOM]NBLIG>0
   Affzo [M:SOM]1-99
Else
   # Artifice (affichage du tableau) afin de traiter les colonnes invisibles
   [M:SOM]NBLIG=1
   Affzo [M:SOM]1-99
   Effzo [M:SOM]15
Endif

# Positionnement de l'état des champs 'Qté physique initiale' & 'Total physique'
If [M:SOM]STOMGTCOD>2
   Diszo [M:SOM]PECQTY
   Diszo [M:SOM]INIQTY
Else
   Grizo [M:SOM]PECQTY
   Grizo [M:SOM]INIQTY
Endif

# Positionnement de l'état du masque STOSORM (Diszo ...)
Gosub ETA_MSK_SOM

#------------------------------------------------------
# Chargement du filtre lignes de stock pour le picking
#------------------------------------------------------
# Récupération de la règle d'allocation
Case [M:SOM]VCRTYP
 When 4,5,8          : # Livraison sous-traitance
                       If [M:SOM]TRSTYP=20
                          WTRUCOD = [F:ITG]ALLRULSCO
                       # Livraison, Facture, Retour fou
                       Else
                          WTRUCOD = [F:ITG]ALLRULSHI
                       Endif
 When 12             : # Suivi matière (opération de sous-traitance)
                       If [M:SOM]PECSCOLOC=2
                          WTRUCOD = [F:ITG]ALLRULSCC
                       # Suivi matière (interne)
                       Else
                          WTRUCOD = [F:ITG]ALLRULMFG
                       Endif
 When 20,29,31,32,33 : # Sortie diverse, Changement de stock,
                       # Assemblage, Désassemblage, Demande de service
                       WTRUCOD = [F:ITG]ALLRULTRF
 When 6              : # Réception (conso matières sous-traitance)
                       WTRUCOD = [F:ITG]ALLRULSCC
 When Default
Endcase

Raz [F:TRU]
# Lecture règle d'allocation
If WTRUCOD<>""
   Read [TRU]TRU0=WTRUCOD
   If fstat Raz WTRUCOD Endif
Endif

# Stockage ordre des lots (FIFO par défaut) pour picking lignes de stock
If WTRUCOD<>""
   [M:SOM]LOTMGT=[F:TRU]LOTMGT
Else
   [M:SOM]LOTMGT=2
Endif

# Lecture de la règle de gestion à utiliser
Call LECSRU([M:SOM]STOFCY,[F:ITM]TCLCOD,[M:SOM]TRSTYP,[M:SOM]TRSCOD,"",LRET)
&           From STKLIB
If LRET<>0
   FIN=1 : Return
Endif

#--- TS 106217
# Stockage de la version de rupture si exclusivité
If [F:SRU]ORDVER=2
  WSHTECCVALMAJ = [M:SOM]WECCVALMAJ
Else
  WSHTECCVALMAJ = ""
Endif
#---

# Chargement des (types) emplacements de l'article-site paramétrés
# dans la règle d'allocation/sortie pour filtrer le picking stock
Call RECH_DEFLOCTYP("SOM") From STKALL

#-------------------------------
# Positionnement filtre picking
#-------------------------------
Raz WCRIT, WCRITSTO, WCRITPIC
Raz WCRITSTO1, WCRITSTO2, WCRITSTO3, WCRITSTO31, WCRITSTO4, WCRITSTO5, WCRITSTO6

# Article et site
WCRITSTO1 = '[F:STO]ITMREF=[M:SOM]ITMREF&[F:STO]STOFCY=[M:SOM]STOFCY'

#DLUBPC
#lecture ITMBPC  pour recuperer DLUBPC
If [M:SOM]BPRNUM <> ""
   Read [ITU]ITU0 = [F:ITM]ITMREF;[M:SOM]BPRNUM
   If fstat
      Raz [F:ITU]
   Endif
Endif

#DLU Client, calcul du nbre de jours à retrancher à la DLU article
If [F:ITU]DLUBPC <> 0
  Call CALNBDAYCLI([F:ITM]EXYMGTCOD,[F:ITM]SHL,[F:ITM]SHLUOM,[F:ITF]DLU,[F:ITU]DLUBPC,NBDAY) From STKLIB
Endif


# Lot et péremption
If dim([M:SOM]XLOT)>0
   # hcb V6dlu nouvelle gestion
   WCRITSTO3  = '([F:STL]SHLDAT=[0/0/0]|'
   WCRITSTO31 = '([F:STL]DLUDAT=[0/0/0]|'
   If [M:SOM]DLVDAT<>[0/0/0]
      WCRITSTO3  += '[F:STL]SHLDAT>=[M:SOM]DLVDAT)'
      WCRITSTO31 += '[F:STL]DLUDAT'+NBDAY+'>=[M:SOM]DLVDAT)'
   Endif
   If [F:SRU]SHLLOT=1
      WCRITPIC  = WCRITSTO3
   Elsif [F:SRU]SHLLOT=2
      WCRITPIC  = WCRITSTO31
   Endif
   If !find([M:SOM]XLOT,"","*")
      WCRITSTO2 = 'pat([F:STO]LOT,[M:SOM]XLOT)<>0'
   Endif
Endif
#--- TS 106217
# Si version renseignée et exclusive
If [M:SOM]WECCVALMAJ<>"" & [F:SRU]ORDVER=2
   WCRITSTO21 = '[F:STO]ECCVALMAJ=[M:SOM]WECCVALMAJ'
Endif
#---

# Catégorie emplacement et dépôt
If [M:SOM]PECINTLOC=2
   If [M:SOM]PECPLFLOC=2
      WCRITSTO5 = 'find([F:STO]LOCCAT,1,2)<>0'
      If [M:SOM]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:SOM]XWRH)<>0' Endif         # hcb 57672
   Else
      WCRITSTO5 = '[F:STO]LOCCAT=1'
      If [M:SOM]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:SOM]XWRH)<>0' Endif         # hcb 57672
   Endif
Elsif [M:SOM]PECPLFLOC=2
   WCRITSTO5 = '[F:STO]LOCCAT=2'
   If [M:SOM]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:SOM]XWRH)<>0' Endif            # hcb 57672
Endif
If [M:SOM]PECSCOLOC=2
   If WCRITSTO5=""
      WCRITSTO5  = '[F:STO]LOCCAT=4'
   Else
      WCRITSTO5 += '|[F:STO]LOCCAT=4'
   Endif
Elsif WCRITSTO5=""
   # Pour ne rien avoir (paramétrage incohérent)
   WCRITSTO5 = '[F:STO]LOCCAT=9'
Endif

# Propriétaire
If [M:SOM]PECOWNER=""
   [M:SOM]OWNFLG=2 : [M:SOM]NOTOWNFLG=1
   WCRITSTO6 = '[F:STO]OWNER=[F:STO]STOFCY'
Else
   [M:SOM]OWNFLG=2 : [M:SOM]NOTOWNFLG=2
   WCRITSTO6 = 'find([F:STO]OWNER,[F:STO]STOFCY,[M:SOM]PECOWNER)'
Endif

Raz WA, WQ, WR
# Statuts autorisés par les règles de gestion d'E/S
If find([F:SRU]AUZSTA,1,3,5,7) WA=1  Endif
If find([F:SRU]AUZSTA,2,3,6,7) WQ=1  Endif
If find([F:SRU]AUZSTA,4,5,6,7) WR=1  Endif

[M:SOM]XSTA=vireblc([M:SOM]XSTA,4)

# Si statuts renseignés dans filtre allocation
If !find([M:SOM]XSTA,"","*")
   # Décodage de la liste de statuts --> transformation en
   # une formule contenant des 'pat(%,statut)'
   Call DECODE_STAT([M:SOM]XSTA,WCRIT) From TRTCATEG
   # Remplacement des '%' par la variable à tester
   Call CREE_FORMULE(WCRIT,"[F:STO]STA",WCRITSTO4) From TRTCATEG
# Sinon prise en compte des sous-statuts autorisés
Elsif !find([F:SRU]AUZSST,"","*")
   Call CREE_FORMULE([F:SRU]FORSTA,"[F:STO]STA",WCRITSTO4) From TRTCATEG
Endif

WCRITSTOA = 'pat([F:STO]STA,"A*")<>0'
WCRITSTOQ = 'pat([F:STO]STA,"Q*")<>0'
WCRITSTOR = 'pat([F:STO]STA,"R*")<>0'

# Alimentation des zones de la fenêtre critère et du filtre
# pour contrôle ligne stock pickée (si non administrateur stock)
[M:SOM]AUZSST=[F:SRU]AUZSST
[M:SOM]FORSTA=[F:SRU]FORSTA
[M:SOM]AAASTA=1
[M:SOM]QQQSTA=1
[M:SOM]RRRSTA=1
# hcb V6percri deb
[M:SOM]FLGSHLLOT = 2
[M:SOM]FLGDLULOT = 2
If [F:SRU]SHLLOT = 2
   [M:SOM]FLGSHLLOT = 1
   [M:SOM]FLGDLULOT = 1
Endif
If [F:SRU]SHLLOT = 1
   [M:SOM]FLGSHLLOT = 1
   [M:SOM]FLGDLULOT = 2
Endif
# hcb V6percri fin

Raz WCRIT
If WA=1
   WCRIT+='pat([F:STO]STA,"A*")<>0'
   [M:SOM]AAASTA=2
Endif
If WQ=1
   If WCRIT<>"" WCRIT+='|' Endif
   WCRIT+='pat([F:STO]STA,"Q*")<>0'
   [M:SOM]QQQSTA=2
Endif
If WR=1
   If WCRIT<>"" WCRIT+='|' Endif
   WCRIT+='pat([F:STO]STA,"R*")<>0'
   [M:SOM]RRRSTA=2
Endif

If WCRITSTO4<>""
   If WCRITPIC<>""
      WCRITPIC+='&('+WCRITSTO4+')'
   Else
      WCRITPIC+=WCRITSTO4
   Endif
Elsif WCRITPIC<>""
   If WCRIT<>""
      WCRITPIC+='&('+WCRIT+')'
   Endif
Else
   If WCRIT<>""
      WCRITPIC+=WCRIT
   Else
      WCRITPIC='1=1'
   Endif
Endif

WAFFPICK=1
Gosub TIROIR

Return

#########################################################################
$ALI_MSK_SOM

Local Decimal WPCUDIS, WSTUDIS, WSTUACTDIS
Local Integer WRET, WMAX, I1, I2
Local Char    WMES(255)
Local Integer WPMPLOT
Local Decimal WAMTORD, WAMTVAL, WQTYSTU
Raz WPMPLOT, WAMTORD, WAMTVAL, WQTYSTU

# Nb de lignes maximum du tableau [SOM]
WMAX = dim([M:SOM]STOCOU)

Raz [M:SOM]INIQTY, [M:SOM]INIQTYACT
Raz [M:SOM]PECQTY, [M:SOM]PECQTYACT, [M:SOM]SHTQTY, [M:SOM]PECQTYORI

[M:SOM]COEFUCUS  = " ="+format$("N:5.4",[M:SOM]PCUSTUCOE)-[M:SOM]STU
[M:SOM]STOMGTCOD = [F:ITF]STOMGTCOD
[M:SOM]NEGSTO    = [F:ITM]NEGSTO
[M:SOM]SERMGTCOD = [F:ITM]SERMGTCOD

NOL=0
nolign=1

WCRITERE  = 'STOFCY=[M:SOM]STOFCY & VCRTYP=[M:SOM]VCRTYP & VCRNUM=[M:SOM]VCRNUM'
WCRITERE += '& VCRLIN=[M:SOM]VCRLIN & REGFLG<>2 & ITMREF = [F:ITM]ITMREF'
# Si livraison de prêt ou de sous-traitance, on ne charge que le mvt de sortie
If find([M:SOM]TRSTYP,17,20)
   WCRITERE += '& QTYSTU<0'
Endif

For [STJ]STJ1 Where evalue(WCRITERE)

   # Nb max de lignes atteint
   If NOL>=WMAX Goto ALI_MSK_SOM_SUI Endif

   [M:SOM] = [F:STJ]

   If NOL=0
      # CCC (15/11/04) : Ajout de PRINATH dans STOSORM
      [M:SOM]PRINATH = [F:STJ]PRINAT
      [M:SOM]PRIORDH = [F:STJ]PRIORD
      [M:SOM]PRIVALH = [F:STJ]PRIVAL
      #[M:SOM]IPTDAT  = [F:STJ]IPTDAT
      #[M:SOM]MVTDES  = [F:STJ]MVTDES
      #[M:SOM]ENTCOD  = [F:STJ]ENTCOD
      #[M:SOM]TRSFAM  = [F:STJ]TRSFAM
      #[M:SOM]PJT     = [F:STJ]PJT
      # Alimentation des sections analytiques
      For J=1 To GNBDIE
         If dim([M:SOM]CCE(J-1))>0
            [M:SOM]CCE(J-1) = [F:STJ]CCE(J-1)
         Endif
      Next J
   Endif

   #[M:SOM]MVTSEQ(NOL) = [F:STJ]MVTSEQ
   #[M:SOM]MVTIND(NOL) = [F:STJ]MVTIND
   #[M:SOM]PRIORD(NOL) = [F:STJ]PRIORD
   #[M:SOM]PRIVAL(NOL) = [F:STJ]PRIVAL
   # Cumul mnts et qtés mouvements pour calculer un prix moyen ligne document
   # qui sera utilisé pour valoriser les nouveaux mvts
   # Uniquement si la valo était en prix moyen lot (WPMPLOT=1)
   WAMTORD += abs([F:STJ]AMTORD)
   WAMTVAL += abs([F:STJ]AMTVAL)
   WQTYSTU += abs([F:STJ]QTYSTU)
   If [F:STJ]PRINAT=7 WPMPLOT=1 Endif

   # Si mvt mis à jour, récupération du chrono stock
   If [F:STJ]UPDCOD=2
      [M:SOM]ICOMVTATT(NOL) = ""
      WSERSVG = [F:STJ]SERNUM
      # Si no série géré en sortie et no série non créé par une entrée
      # il ne doit pas faire partie des caractéristiques de la ligne de stock
      If [M:SOM]SERMGTCOD=2
         Read [STS]STS0=[M:SOM]ITMREF;[F:STJ]SERNUM
         If !fstat & [F:STS]RCPVCRTYP=0 & [F:STS]RCPVCRNUM=""
            Raz [F:STJ]SERNUM
         Endif
      Endif

      #--- Issue X3-53322 : Ajout LPN
      Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,
&                 [F:STJ]BPSLOT,[F:STJ]PALNUM,[F:STJ]CTRNUM,[F:STJ]STA,
&                 [F:STJ]LOC,[F:STJ]PCU,[F:STJ]PCUSTUCOE,[F:STJ]SERNUM,
&                 [F:STJ]QLYCTLDEM,[F:STJ]OWNER,
&                 [F:STJ]STOFLD1,[F:STJ]STOFLD2,[F:STJ]LPNNUM,LSTOCOU) From STKLIB
      [M:SOM]STOCOU(NOL) = LSTOCOU
      [M:SOM]WAIFLG(NOL) = 0
      [F:STJ]SERNUM      = WSERSVG
   Else
      [M:SOM]ICOMVTATT(NOL) = "247"
      [M:SOM]STOCOU(NOL)    = 0
      [M:SOM]WAIFLG(NOL)    = 1
   Endif

   #If dim([M:SOM]LOT)>0    [M:SOM]LOT(NOL)   =[F:STJ]LOT    Endif
   #If dim([M:SOM]SLO)>0    [M:SOM]SLO(NOL)   =[F:STJ]SLO    Endif
   #If dim([M:SOM]LOC)>0    [M:SOM]LOC(NOL)   =[F:STJ]LOC    Endif
   #[M:SOM]STA(NOL)=[F:STJ]STA

   Raz [M:SOM]SERNUMFLG(NOL)

   # Si mvt mis à jour
   If [F:STJ]UPDCOD=2
      [M:SOM]QTYPCU(NOL)     = abs([F:STJ]QTYPCU)
      [M:SOM]XPCU(NOL)       = [F:STJ]PCU
      [M:SOM]XPCUSTUCOE(NOL) = [F:STJ]PCUSTUCOE
      #If dim([M:SOM]SHLDAT)>0 [M:SOM]SHLDAT(NOL)=[F:STJ]SHLDAT Endif
      If dim([M:SOM]POT)>0
         If [M:SOM]STOMGTCOD=3
            [M:SOM]POT(NOL) = [F:STJ]POT
         Elsif [M:SOM]STOMGTCOD=4
            [M:SOM]POT(NOL) = [F:STJ]ACT
         Endif
      Endif
      If dim([M:SOM]SERNUM)>0
         [M:SOM]SERNUM(NOL)  = [F:STJ]SERNUM
         # No série géré en E/S
         If [M:SOM]SERMGTCOD=3
            [M:SOM]SERNUMF(NOL) = [M:SOM]SERNUM(NOL)
         #--- Issue 110327
         Elsif [M:SOM]SERMGTCOD=4
            [M:SOM]SERNUM(NOL)    = [F:STJ]SERDEB
            [M:SOM]SERNUMF(NOL)   = [F:STJ]SERFIN
            [M:SOM]SERNUMORI(NOL) = [F:STJ]SERDEB
            [M:SOM]SERNUMFORI(NOL)= [F:STJ]SERFIN
         #---
         # No série géré en Sortie
         #--- Issue X3-67440
         #Else
         Elsif [M:SOM]SERMGTCOD=2
         #---
            WNB = abs([F:STJ]ACTQTY)
            If WNB = 1
               [M:SOM]SERNUMF(NOL) = [M:SOM]SERNUM(NOL)
               # A t-il une pièce d'entrée ?
               Read [STS]STS0=[M:SOM]ITMREF;[M:SOM]SERNUM(NOL)
               If !fstat & [F:STS]RCPVCRTYP<>0 & [F:STS]RCPVCRNUM<>""
                  [M:SOM]SERNUMFLG(NOL)=1
               Endif
            Else
               Call PLUS_NB([M:SOM]SERNUM(NOL),WNB,[M:SOM]SERNUMF(NOL),WRET)
&                           From STKLIB
               If WRET<>0
                  Raz [M:SOM]SERNUM(NOL), [M:SOM]SERNUMF(NOL)
               Endif
            Endif
         Endif
      Endif
   # Sinon si mvt en attente
   Else
      Raz [M:SOM]AVAQTYPCU(NOL),[M:SOM]AVAQTYSTU(NOL),[M:SOM]TOTQTYSTU(NOL)
      Raz [M:SOM]QTYPCU(NOL),[M:SOM]XPCU(NOL),[M:SOM]XPCUSTUCOE(NOL)
      If dim([M:SOM]SHLDAT)>0 Raz [M:SOM]SHLDAT(NOL) Endif
      If dim([M:SOM]POT)>0    Raz [M:SOM]POT(NOL)    Endif
      If dim([M:SOM]SERNUM)>0
         #--- Issue 110327
         If [M:SOM]SERMGTCOD=4
            [M:SOM]SERNUM(NOL)    = [F:STJ]SERDEB
            [M:SOM]SERNUMF(NOL)   = [F:STJ]SERFIN
            [M:SOM]SERNUMORI(NOL) = [F:STJ]SERDEB
            [M:SOM]SERNUMFORI(NOL)= [F:STJ]SERFIN
         Else
         #---
            [M:SOM]SERNUM(NOL) =[F:STJ]SERNUM
            If [M:SOM]SERNUM(NOL)<>""
               WNB = abs([F:STJ]ACTQTY)
               If WNB = 1
                  [M:SOM]SERNUMF(NOL) = [M:SOM]SERNUM(NOL)
               Else
                  Call PLUS_NB([M:SOM]SERNUM(NOL),WNB,[M:SOM]SERNUMF(NOL),WRET)
&                              From STKLIB
                  If WRET<>0
                     Raz [M:SOM]SERNUM(NOL), [M:SOM]SERNUMF(NOL)
                  Endif
               Endif
            Endif
         #--- Issue 110327
         Endif
         #---
      Endif
   Endif

   [M:SOM]QTYSTU(NOL)     = abs([F:STJ]QTYSTU)
   [M:SOM]QTYSTUORI(NOL)  = abs([F:STJ]QTYSTU)
   [M:SOM]QTYSTUACT(NOL)  = abs([F:STJ]ACTQTY)
   # Si mvt en attente, on alimente la qté US avec la qté UA
   If [M:SOM]WAIFLG(NOL)=1
      [M:SOM]QTYSTU(NOL) = [M:SOM]QTYSTUACT(NOL)
   Endif

   # La ligne de stock existe
   If [M:SOM]STOCOU(NOL)<>0
      Read [STO]STO0=[M:SOM]STOFCY;[M:SOM]STOCOU(NOL)
      If fstat
         [M:SOM]WAIFLG(NOL)=0
         [M:SOM]AVAQTYSTU(NOL) = [M:SOM]QTYSTU(NOL)
         [M:SOM]AVAQTYPCU(NOL) = [M:SOM]QTYPCU(NOL)
         [M:SOM]TOTQTYSTU(NOL) = [M:SOM]QTYSTU(NOL)
      Else
         # Calcul du disponible pour sortie sur la ligne de stock
         Call STODISSOR("[F:STO]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS)
&                       From STKLIB
         # On rajoute la quantité sortie de la ligne au disponible
         [M:SOM]AVAQTYSTU(NOL) = WSTUDIS + [M:SOM]QTYSTU(NOL)
         [M:SOM]AVAQTYPCU(NOL) = WPCUDIS + [M:SOM]QTYPCU(NOL)
         [M:SOM]TOTQTYSTU(NOL) = [F:STO]QTYSTU
      Endif
   # La ligne de stock n'existe plus
   Elsif [M:SOM]WAIFLG(NOL)=0
      [M:SOM]AVAQTYSTU(NOL) = [M:SOM]QTYSTU(NOL)
      [M:SOM]AVAQTYPCU(NOL) = [M:SOM]QTYPCU(NOL)
      [M:SOM]TOTQTYSTU(NOL) = [M:SOM]QTYSTU(NOL)
   # Mouvement en attente
   Else
      Raz [M:SOM]AVAQTYSTU(NOL),[M:SOM]AVAQTYPCU(NOL),[M:SOM]TOTQTYSTU(NOL)
   Endif

   # Mouvement en attente
   If [M:SOM]WAIFLG(NOL)=1
      [M:SOM]INIQTY    += [M:SOM]QTYSTUACT(NOL)
      [M:SOM]INIQTYACT += [M:SOM]QTYSTUACT(NOL)
      [M:SOM]SHTQTY    += [M:SOM]QTYSTUACT(NOL)
   Else
      [M:SOM]INIQTY    += [M:SOM]QTYSTU(NOL)
      [M:SOM]INIQTYACT += [M:SOM]QTYSTUACT(NOL)
      [M:SOM]PECQTY    += [M:SOM]QTYSTU(NOL)
      [M:SOM]PECQTYACT += [M:SOM]QTYSTUACT(NOL)
      [M:SOM]PECQTYORI += [M:SOM]QTYSTUACT(NOL)
   Endif

   #--- Dem 83423
   GPOINT="STJ_SOM" : Gosub ENTREE From EXEFNC

   $ALI_MSK_SOM_SUI
   NOL += 1
   nolign += 1
Next

# Si la valo était en prix moyen lot, calcul du prix moyen (ordre et valo)
# qui servira à valoriser les nouveaux mouvements
If WPMPLOT = 1
   [M:SOM]PRIORDH = WAMTORD/WQTYSTU
   [M:SOM]PRIVALH = WAMTVAL/WQTYSTU
Endif

# Tableau chargé
If NOL<WMAX
   [M:SOM]NBLIG = NOL
# Nombre mouvements à charger (NOL) > Nombre de lignes maxi du tableau (WMAX)
# Veuillez modifier le code activité SLS pour pouvoir modifier les mouvements
Else
   I1   = instr(1,mess(69,184,1),"%")
   I2   = instr(I1+1,mess(69,184,1),"%")
   WMES = left$(mess(69,184,1),I1-1)+num$(NOL)+mid$(mess(69,184,1),I1+1,I2-I1-1)
&         +num$(WMAX)+right$(mess(69,184,1),I2+1)
   Call ERREUR(WMES+chr$(13)+mess(71,184,1)) From GESECRAN
   Effzo [M:SOM]1-99
   FIN = 1
Endif

Return

#########################################################################
$ETA_MSK_SOM

# Si pas de ligne, on se casse
If [M:SOM]NBLIG=0 Return Endif

#--- Issue 117892
# Pas d'accés aux mouvements si facture validée ou mode consultation
#If LABR="SIH4" | LCONSULT
If LABR="SIH4" | LCONSULT | GCONSULT
#---
   Diszo [M:SOM]1-99
   Return
Endif

# Pas d'accés à la quantité à sortir
# si livraison d'un composé ou composant de kit/sous-traité
# ou si retour fournisseur
If (LABR="SDH1" & find([M:SDH1]LINTYP(LNOL),2,3,4,5,10,11,12,13)) | LABR="PNH1"
   Diszo [M:SOM]SORQTYACT
Endif

If dim([M:SOM]WRH)>0
   If WRHGES=2
      Diszo [M:SOM]WRH
   Else
      Grizo [M:SOM]WRH
   Endif
Endif
If dim([M:SOM]LOT)>0     Diszo [M:SOM]LOT    Endif
If dim([M:SOM]SLO)>0     Diszo [M:SOM]SLO    Endif
If dim([M:SOM]LOC)>0     Diszo [M:SOM]LOC    Endif
If dim([M:SOM]PALNUM)>0  Diszo [M:SOM]PALNUM Endif
If dim([M:SOM]CTRNUM)>0  Diszo [M:SOM]CTRNUM Endif
If dim([M:SOM]STOFLD1)>0 Diszo [M:SOM]STOFLD1 Endif
If dim([M:SOM]STOFLD2)>0 Diszo [M:SOM]STOFLD2 Endif
#--- TS 106217
If dim([M:SOM]ECCVALMAJ)>0 Diszo [M:SOM]ECCVALMAJ Endif
#--- Issue X3-53322
If dim([M:SOM]LPNNUM)>0  Diszo [M:SOM]LPNNUM Endif

# Si no séries gérés en sortie
If [M:SOM]SERMGTCOD=2
   Actzo [M:SOM]QTYSTU
   Actzo [M:SOM]QTYPCU
   If dim([M:SOM]SERNUM)>0
      Actzo [M:SOM]SERNUM
      # Si trf inter-site et intra-société, pas de saisie des no séries
      If [M:SOM]TRFFCY<>"" & [M:SOM]BETCPY<>2 Diszo [M:SOM]SERNUM Endif
   Endif
   Diszo [M:SOM]STA
# Si no séries gérés en E/S
Elsif [M:SOM]SERMGTCOD=3
   Diszo [M:SOM]QTYSTU
   Diszo [M:SOM]QTYPCU
   If dim([M:SOM]SERNUM)>0 Diszo [M:SOM]SERNUM Endif
   Diszo [M:SOM]STA
#--- Issue 110327
# Si no séries gérés en E/S globale (à voir : diszo ou actzo ?)
Elsif [M:SOM]SERMGTCOD=4
   Actzo [M:SOM]QTYSTU
   Diszo [M:SOM]QTYPCU
   If dim([M:SOM]SERNUM)>0 Actzo [M:SOM]SERNUM Endif
   Diszo [M:SOM]STA
#---
Else
   Actzo [M:SOM]QTYSTU
   Actzo [M:SOM]QTYPCU
   If dim([M:SOM]SERNUM)>0 Diszo [M:SOM]SERNUM Endif
   Diszo [M:SOM]STA
Endif

# Si no séries gérés en sortie et (no série existant ou retour fournisseur)
# ou si mouvement en attente, on boucle sur le tableau pour affiner l'état
If ([M:SOM]SERMGTCOD=2 & ([M:SOM]VCRTYP=8 | sigma(NOL=0,[M:SOM]NBLIG-1,[M:SOM]SERNUMFLG(NOL)=1)>0))
&  | sigma(NOL=0,[M:SOM]NBLIG-1,[M:SOM]WAIFLG(NOL)=1)>0
   For NOL=0 To [M:SOM]NBLIG-1
      # Si mouvement en attente
      If [M:SOM]WAIFLG(NOL)=1
         Actzo [M:SOM]QTYSTU(NOL) : Affzo [M:SOM]QTYSTU(NOL)
         Diszo [M:SOM]QTYPCU(NOL) : Affzo [M:SOM]QTYPCU(NOL)
         If dim([M:SOM]LOT)>0
            Actzo [M:SOM]LOT(NOL)
            If [M:SOM]LOT(NOL)<>"" Affzo [M:SOM]LOT(NOL) Endif
         Endif
         If dim([M:SOM]SLO)>0
            Actzo [M:SOM]SLO(NOL)
            If [M:SOM]SLO(NOL)<>"" Affzo [M:SOM]SLO(NOL) Endif
         Endif
         If dim([M:SOM]WRH)>0
            If WRHGES=2
               If [M:SOM]XWRH=""
                  Actzo [M:SOM]WRH(NOL)
               Else
                  If [M:SOM]WRHOBY=2
                     Diszo [M:SOM]WRH(NOL)
                  Else
                     Actzo [M:SOM]WRH(NOL)
                  Endif
                  [M:SOM]WRH(NOL)=[M:SOM]XWRH
               Endif
               If [M:SOM]WRH(NOL)<>"" Affzo [M:SOM]WRH(NOL) Endif
            Else
               Grizo [M:SOM]WRH(NOL)
            Endif
         Endif
         #--- TS 106217
         If dim([M:SOM]ECCVALMAJ)>0
            #--- Si version exclusive et renseignée, pas de modification
            If [M:SOM]ECCVALMAJ(NOL)<>"" & [F:SRU]ORDVER=2
               Diszo [M:SOM]ECCVALMAJ(NOL)
            Else
               Actzo [M:SOM]ECCVALMAJ(NOL)
            Endif
            Affzo [M:SOM]ECCVALMAJ(NOL)
         Endif
         #---
         If dim([M:SOM]LOC)>0
            Actzo [M:SOM]LOC(NOL)
            If [M:SOM]LOC(NOL)<>"" Affzo [M:SOM]LOC(NOL) Endif
         Endif
         If dim([M:SOM]SERNUM)>0
            # Si no série géré en sortie, pas de saisie
            # car problème pour régulariser par la suite
            If [M:SOM]SERMGTCOD=2
               Diszo [M:SOM]SERNUM(NOL)
            Else
               Actzo [M:SOM]SERNUM(NOL)
            Endif
            If [M:SOM]SERNUM(NOL)<>"" Affzo [M:SOM]SERNUM(NOL) Endif
         Endif
         Actzo [M:SOM]STA(NOL)
         If [M:SOM]STA(NOL)<>"" Affzo [M:SOM]STA(NOL) Endif
      # Si no séries gérés en sortie
      Elsif [M:SOM]SERMGTCOD=2 & dim([M:SOM]SERNUM)>0
         # Si no série existant ou retour fournisseur, pas de saisie
         If [M:SOM]SERNUMFLG(NOL)=1 | [M:SOM]VCRTYP=8
            Diszo [M:SOM]QTYSTU(NOL)
            Diszo [M:SOM]QTYPCU(NOL)
            Diszo [M:SOM]SERNUM(NOL)
         Endif
      Endif
   Next NOL
Endif

Return

#########################################################################
$SETBOUT

# Pour interdire la navigation
GREP="M"

# Si facture validée
#--- Issue 117892
#If LABR="SIH4" | LCONSULT
If LABR="SIH4" | LCONSULT | GCONSULT
#---
   Call VIREBOUT(CHMEN,"23L") From GOBJET
   Return
Endif

If !find("=",CHBOU) CHBOU+="=" Endif
If !find("A",CHBOU) CHBOU+="A" Endif
If !find("E",CHBOU) CHBOU+="E" Endif

# Pas de Raz si pas de ligne
If [M:SOM]NBLIG=0
   Call VIREBOUT(CHMEN,"3") From GOBJET
Endif

# Si stock négatif interdit, pas de sortie d'un stock manquant
#--- dem 61614
#If [M:SOM]NEGSTO<>2 | [M:SOM]PECQTYACT+[M:SOM]SHTQTY>=[M:SOM]SORQTYACT
If ([M:SOM]TRSTYP<>4 & [M:SOM]NEGSTO<>2) | ([M:SOM]TRSTYP=4 & GSHTDLV<3) |
&   [M:SOM]PECQTYACT+[M:SOM]SHTQTY>=[M:SOM]SORQTYACT
   Call VIREBOUT(CHMEN,"L") From GOBJET
Endif

Return

#########################################################################
$APRES_MODIF
Local Integer I,J,K
NOL = nolign-1

#--- 110327
If find(COUZON,"SERNUM","QTYSTU","QTYPCU")
   GSAISERIE=1
Endif
# Raffraichissement du picking suite à saisie des no série (E/S)
If GSAISERIE=1
   Gosub TIROIR
Endif
#---

# Si suppression d'une ligne, raffraichissement du picking
If GSUPLIG=65 & [M:SOM]STOCOU(NOL)<>0
   # Plusieurs lignes ont-elles le même chrono stock ?
   K=sigma(J=0,[M:SOM]NBLIG-1,(1*([M:SOM]STOCOU(J)=[M:SOM]STOCOU(NOL))))
   # Si chrono stock unique, on dépicke
   If K=1
      Read [STO]STO0=[M:SOM]STOFCY;[M:SOM]STOCOU(NOL)
      If !fstat
         Read [STL]STL0=[M:SOM]ITMREF;[F:STO]LOT;[F:STO]SLO
         If !fstat
            If evalue(FILGAUSUP) Gosub DEPICK From GSAISIE Endif
         Endif
      Endif
   Endif
Endif

# Si suppression de n lignes, raffraichissement du picking
If find(GSUPLIG,68,83)

   # Si raz de la quantité à sortir
   If COUZON="SORQTYACT"
      nolign  = 1
      nolign1 = [M:SOM]NBLIG
   Endif

   For I=nolign-1 To nolign1-1
      If [M:SOM]STOCOU(I)<>0
         # Plusieurs lignes ont-elles le même chrono stock ?
         K=sigma(J=0,[M:SOM]NBLIG-1,(1*([M:SOM]STOCOU(J)=[M:SOM]STOCOU(I))))
         # Si chrono stock unique, on dépicke
         If K=1
            Read [STO]STO0=[M:SOM]STOFCY;[M:SOM]STOCOU(I)
            If !fstat
               Read [STL]STL0=[M:SOM]ITMREF;[F:STO]LOT;[F:STO]SLO
               If !fstat
                  If evalue(FILGAUSUP) Gosub DEPICK From GSAISIE Endif
               Endif
            Endif
         Endif
      Endif
   Next I
   # Si raz de la quantité à sortir
   If COUZON="SORQTYACT"
      Raz   [M:SOM]PECQTY, [M:SOM]PECQTYACT, [M:SOM]SHTQTY
      Affzo [M:SOM]PECQTY, PECQTYACT, SHTQTY
      Effzo [M:SOM]15
   Endif
Endif
Raz GSUPLIG
Raz GSAISERIE         : #--- Issue 110327

Return

#########################################################################
$AVANT_ENR

OKRUP=0

# - 101090 - Confirm user wants to edit address if a BOL is attached
If LABR="SDH1"
  OK=2
  Call VERIF_BOLMOD(OK) From SUBSDHB
  If OK<>2 : FOK=0 : Return : Endif
Endif

#--- Issue 110327
# Si no série en E/S globale
If [M:SOM]SERMGTCOD=4
  If find("",[M:SOM]SERNUM(0..[M:SOM]NBLIG-1))
    # Les no série n'ont pas été renseignés
    GMESSAGE = mess(312,184,1)
    GERR=1 : FOK=0 : Return
  Endif
Endif
#---

# Si no séries gérés en sortie ou E/S globale,				: #--- Issue 110327
# contrôle de cohérence entre les différentes lignes (pas de colision entre no)
#--- Issue 110327
#If [M:SOM]SERMGTCOD=2 & dim([M:SOM]SERNUM)>0 & [M:SOM]NBLIG>1
If find([M:SOM]SERMGTCOD,2,4) & dim([M:SOM]SERNUM)>0 & [M:SOM]NBLIG>1
#---
   If clalev([M:SOR])=0  Local Mask STOSOR  [SOR]  Endif
   Default Mask [SOM]
   J=0
   # Alimentation des no début et fin dans l'écran [SOR] pour tri
   For I=0 To [M:SOM]NBLIG-1
      If [M:SOM]SERNUM(I)<>""
         [M:SOR]SERNUM(J)  = [M:SOM]SERNUM(I)
         [M:SOR]SERNUMF(J) = [M:SOM]SERNUMF(I)
         J+=1
      Endif
   Next I
   [M:SOR]NBLIG = J
   If [M:SOR]NBLIG>1
      # Tri des no séries
      Sorta [M:SOR]NBLIG [M:SOR]SERNUM,[M:SOR]SERNUMF
      J=0
      For J=1 To [M:SOR]NBLIG-1
         If [M:SOR]SERNUMF(J-1)>=[M:SOR]SERNUM(J)
            # Des no série sont présents plusieurs fois
            #--- Issue 110327
            #GMESSAGE = mess(464,199,1)
            GMESSAGE = mess(464,199,1)-[M:SOR]SERNUM(J)-"-->"-[M:SOR]SERNUMF(J-1)
            #---
            GERR=1 : FOK=0 : Break
         Endif
      Next J
      If GERR=1 Return Endif
   Endif
Endif

# Si article géré en titre ou en UI et on ne traite pas un retour fournisseur
# on permet de ne pas respecter la qté à sortir
If find([M:SOM]STOMGTCOD,3,4) & LABR<>"PNH1"
   # Si quantité totale > quantité à sortir, confirmer vous la saisie ?
   If [M:SOM]PECQTYACT+[M:SOM]SHTQTY > [M:SOM]SORQTYACT
      GMESSAGE = mess(465,199,1)+"\"+mess(623,196,1)
      # Non par défaut
      OK=0
      Call OUINON(GMESSAGE,OK) From GESECRAN
      Raz GMESSAGE
      # Saisie non confirmée
      If OK<>2 FOK=0 Endif
   # Sinon si quantité totale < quantité à sortir
   Elsif [M:SOM]PECQTYACT+[M:SOM]SHTQTY < [M:SOM]SORQTYACT
      # Si stock négatif autorisé, générer rupture ou confirmer saisie ?
      If [M:SOM]NEGSTO=2
         Local Char    PARMSK(250)(1..20) , SAVACT(20)
         SAVACT = GACTION : GACTION = "DIVCHX1"
         PARMSK(1) = "466"
         PARMSK(2) = "199"
         Call SAISIE_NUM(VALEUR,PARMSK,"ICHX1","STKECR2","") From GSAISIE
         GACTION = SAVACT
         # Génération rupture
         If PARMSK(3)="A"
            OKRUP=1
         # Saisie non confirmée
         Elsif PARMSK(3)<>"B"
            FOK=0
         Endif
      # Sinon confirmez-vous la saisie ?
      Else
         GMESSAGE = mess(466,199,1)+"\"+mess(623,196,1)
         # Non par défaut
         OK=0
         Call OUINON(GMESSAGE,OK) From GESECRAN
         Raz GMESSAGE
         # Saisie non confirmée
         If OK<>2 FOK=0 Endif
      Endif
   Endif
# Si article non géré en titre ou en UI ou retour fournisseur
Else
   # Si quantité totale > quantité à sortir
   If [M:SOM]PECQTYACT+[M:SOM]SHTQTY > [M:SOM]SORQTYACT
      GMESSAGE = mess(465,199,1)
      GERR=1 : FOK=0
   # Sinon si quantité totale < quantité à sortir
   Elsif [M:SOM]PECQTYACT+[M:SOM]SHTQTY < [M:SOM]SORQTYACT
      # Si composant de kit
      If GTYPLIG=1
         GMESSAGE = mess(427,199,1)
         GERR=1 : FOK=0
      # Sinon si stock négatif autorisé
      Elsif [M:SOM]NEGSTO=2 & LABR<>"PNH1"
         GMESSAGE=mess(395,199,1)
         # Non par défaut
         OK=0
         Call OUINON(GMESSAGE,OK) From GESECRAN
         Raz GMESSAGE
         # Génération rupture
         If OK=2
            OKRUP=1
         Else
            FOK=0
         Endif
      Else
         GMESSAGE = mess(466,199,1)
         GERR=1 : FOK=0
      Endif
   Endif
Endif
#--- Bug 84473
# Si livraison d'un ordre de sous-traitance alloué, il n'est pas possible
# de diminuer la quantité car l'allocation pointe alors sur un emp interne
If [M:SOM]VCRTYP=4 & [M:SOM]TRSTYP=20
   Read [SDD]SDD0=[M:SOM]VCRNUM;[M:SOM]VCRLIN
   #--- Issue X3-95566
   #If !fstat & [F:SDD]VCRTYPORI=36 & [F:SDD]VCRNUMORI<>""
   If !fstat & find([F:SDD]VCRTYPORI,10,36) & [F:SDD]VCRNUMORI<>""
   #---
      If [M:SOM]PECQTYACT < [M:SOM]INIQTYACT
         For [STA]STA2 Where ITMREF=[F:SDD]ITMREF & VCRTYP=[F:SDD]VCRTYPORI
&                          & VCRNUM=[F:SDD]VCRNUMORI & VCRLIN=[F:SDD]VCRLINORI
&                          & VCRSEQ=[F:SDD]VCRSEQORI
            GMESSAGE = mess(407,184,1)-[F:SDD]VCRNUMORI
            GERR=1 : FOK=0
            Break
         Next
      Endif
   Endif
Endif
#---

Return

#########################################################################
$ENR

# Génération d'une ligne de rupture si nécessaire
If OKRUP=1
   nolign =  [M:SOM]NBLIG+1
   NOL = nolign-1
   [M:SOM]QTYSTUACT(NOL)=[M:SOM]SORQTYACT-([M:SOM]PECQTYACT+[M:SOM]SHTQTY)
   # Calcul nouvelle quantité US
   [M:SOM]QTYSTU(NOL) = [M:SOM]QTYSTUACT(NOL)
   # Calcul nouvelle quantité rupture
   [M:SOM]SHTQTY += [M:SOM]QTYSTUACT(NOL)
   Raz [M:SOM]SERNUMFLG(NOL)
   # Mvt en attente
   [M:SOM]WAIFLG(NOL) = 1

   Insa [M:SOM]NBLIG+1,1,[M:SOM]NBLIG [M:SOM]NBLIG
   [M:SOM]NBLIG += 1
Endif

If !GIMPORT
   Call OUVRE_TRACE(mess(177,198,1)) From LECFIC
Endif

# Transaction de mise à jour
Call DEBTRANS From GLOCK
Trbegin [STO]

# Chargement écran travail pour interface maj stock
Gosub CHARGE_STW
# Interface pour la maj des stocks
Call ALISTOWORK(5,0,LQTA,LSHT,LNBR,LNBJ,LRET) From STKINT
If LRET=0

  #121495.sn MJH 3/1/17
  #When coming from an assembly, if the finished products price was manually entered,
  #we dont want it to recalculate after modification of issues for its component.
  If GFONCTION = "GESBBY"
    Global Char SKIP_PARENT(GLONITM)
    Local File SMVTD [SMDL]
    Filter [SMDL] Where VCRTYP = [M:STW]VCRTYP and VCRNUM = [M:STW]VCRNUM Order By VCRLIN Asc
    Read [SMDL] First

    If [SMDL]UPDPRI = 2
      SKIP_PARENT = [SMDL]ITMREF
    Endif
    LogicClose File [SMDL]
  Endif#121495.en MJH 3/1/17

  # Mise à jour des stocks
  Call MAJ_STOCK From STKMAJ

  If GFONCTION = "GESBBY"#121495.sn
    Raz SKIP_PARENT
    Kill SKIP_PARENT
  Endif#121495.en

  If GOK < 1 Goto AB_TRT Endif
Else
  Raz GOK : Goto AB_TRT
Endif

# On a enregistré
WGENR = 1

#-----------------------------------------------------------------------
# Traitement à alimenter pour les différentes fonctions
# pour exploiter ce qui a été fait dans l'écran de gestion des sorties
#-----------------------------------------------------------------------
Gosub APRES_ENR From TRTSTOSOMA
If GOK=0
   GERR=1 : Goto AB_TRT
Endif

Commit

If !GIMPORT & GTRACE<>""
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE From LECFIC
Endif
# Pour sortir
FIN = 1

Return

#-----------------------------------------------------------------------#
# Chargement écran travail pour interface maj stock                     #
#-----------------------------------------------------------------------#
$CHARGE_STW

Raz [M:STW]
[M:STW]STOFCY    = [M:SOM]STOFCY
[M:STW]TRSTYP    = [M:SOM]TRSTYP
[M:STW]VCRTYP    = [M:SOM]VCRTYP
[M:STW]VCRNUM    = [M:SOM]VCRNUM
[M:STW]VCRLIN    = [M:SOM]VCRLIN
[M:STW]ITMREF    = [M:SOM]ITMREF
[M:STW]MVTDES    = [M:SOM]MVTDES
[M:STW]TRSCOD    = [M:SOM]TRSCOD
[M:STW]IPTDAT    = [M:SOM]IPTDAT
[M:STW]ENTCOD    = [M:SOM]ENTCOD
[M:STW]TRSFAM    = [M:SOM]TRSFAM
[M:STW]PJT       = [M:SOM]PJT
[M:STW]TRFFCY    = [M:SOM]TRFFCY
[M:STW]BETCPY    = [M:SOM]BETCPY
If [M:STW]TRSTYP=6
   [M:STW]VCRTYPORI = [M:SOM]VCRTYPORI
   [M:STW]VCRNUMORI = [M:SOM]VCRNUMORI
   [M:STW]VCRLINORI = [M:SOM]VCRLINORI
   [M:STW]VCRSEQORI = [M:SOM]VCRSEQORI
Else
   [M:STW]VCRTYPORI = 0
   [M:STW]VCRNUMORI = ""
   [M:STW]VCRLINORI = 0
   [M:STW]VCRSEQORI = 0
Endif
#--- Bug 70372
[M:STW]BPRNUM    = [M:SOM]BPRNUM

# Emplacement prêt ou sous-traitance
If find([M:STW]TRSTYP,17,20)
   [M:STW]LOCENT = [M:SOM]BPCLOC
Else
   Raz [M:STW]LOCENT
Endif
[M:STW]CCECOD    = ""
[M:STW]PRIORDH   = 0
[M:STW]PRIPUR    = 0
[M:STW]SEQ       = 0

Return

#########################################################################
$ABA

WPICK=1
Gosub RAFFRAICHI
Effzo [M]15
GCHARGRUPT = ""
Gosub ALI_MSK_SOM
#--- Issue 52393
[M:SOM]SORQTY    = WSORQTY
[M:SOM]SORQTYACT = WSORQTYACT
#---
Affzo [M]1-99
WPICK=2
Gosub RAFFRAICHI
Return

#########################################################################
$BOUTON
#--------------------------------------------
# "2" : Après Critères    (Action SAISORCRI)
# "3" : Raz
#--------------------------------------------
Case BOUT
 When "2" : Raz WCRITSTO2, WCRITSTO4, WCRITSTO5, WCRIT
            If dim([M:SOM]XLOT)>0 & !find([M:SOM]XLOT,"","*")
               WCRITSTO2 = 'pat([F:STO]LOT,[M:SOM]XLOT)<>0'
            Endif
            #--- TS 106217
            # Si version renseignée et exclusive
            If [M:SOM]WECCVALMAJ<>"" & [F:SRU]ORDVER=2
               If WCRITSTO2<>"" WCRITSTO2 += "&" Endif
               WCRITSTO2 += '[F:STO]ECCVALMAJ=[M:SOM]WECCVALMAJ'
            Endif
            #---
            [M:SOM]XSTA=vireblc([M:SOM]XSTA,4)
            # Si statuts renseignés dans filtre allocation
            If !find([M:SOM]XSTA,"","*")
               # Décodage de la liste de statuts --> transformation en
               # une formule contenant des 'pat(%,statut)'
               Call DECODE_STAT([M:SOM]XSTA,WCRIT) From TRTCATEG
               # Remplacement des '%' par la variable à tester
               Call CREE_FORMULE(WCRIT,"[F:STO]STA",WCRITSTO4) From TRTCATEG
            # Sinon prise en compte des sous-statuts autorisés
            Elsif !find([M:SOM]AUZSST,"","*")
               # Décodage de la liste de statuts --> transformation en
               # une formule contenant des 'pat(%,statut)'
               Call DECODE_STAT([M:SOM]AUZSST,WCRIT) From TRTCATEG
               # Remplacement des '%' par la variable à tester
               Call CREE_FORMULE(WCRIT,"[F:STO]STA",WCRITSTO4) From TRTCATEG
            Endif

            # Catégorie emplacement et dépôt
            If [M:SOM]PECINTLOC=2
               If [M:SOM]PECPLFLOC=2
                  WCRITSTO5 = 'find([F:STO]LOCCAT,1,2)<>0'
                  If [M:SOM]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:SOM]XWRH)<>0' Endif  # hcb 57672
               Else
                  WCRITSTO5 = '[F:STO]LOCCAT=1'
                  If [M:SOM]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:SOM]XWRH)<>0' Endif  # hcb 57672
               Endif
            Elsif [M:SOM]PECPLFLOC=2
               WCRITSTO5 = '[F:STO]LOCCAT=2'
               If [M:SOM]XWRH<>"" WCRITSTO5 += '&pat([F:STO]WRH,[M:SOM]XWRH)<>0' Endif     # hcb 57672
            Endif
            If [M:SOM]PECSCOLOC=2
               If WCRITSTO5=""
                  WCRITSTO5  = '[F:STO]LOCCAT=4'
               Else
                  WCRITSTO5 += '|[F:STO]LOCCAT=4'
               Endif
            Elsif WCRITSTO5=""
               # Pour ne rien avoir (paramétrage incohérent)
               WCRITSTO5 = '[F:STO]LOCCAT=9'
            Endif
            # Propriétaire
            If [M:SOM]OWNFLG=2
               If [M:SOM]NOTOWNFLG=2
                  If [M:SOM]PECOWNER=""
                     WCRITSTO6 = '1=1'
                  Else
                     WCRITSTO6 = 'find([F:STO]OWNER,[F:STO]STOFCY,[M:SOM]PECOWNER)'
                  Endif
               Else
                  WCRITSTO6 = '[F:STO]OWNER=[F:STO]STOFCY'
               Endif
            Else
               If [M:SOM]NOTOWNFLG=2
                  If [M:SOM]PECOWNER=""
                     WCRITSTO6 = '[F:STO]OWNER<>[F:STO]STOFCY'
                  Else
                     WCRITSTO6 = '[F:STO]OWNER=[M:SOM]PECOWNER'
                  Endif
               Else
                  # Si rien de coché, on force : 'stock propriétaire'
                  [M:SOM]OWNFLG=2
                  WCRITSTO6 = '[F:STO]OWNER=[F:STO]STOFCY'
               Endif
            Endif
            WAFFPICK=1
            Gosub TIROIR
 When "3" : WPICK=1
            Gosub RAFFRAICHI
            Raz   [M:SOM]PECQTY, [M:SOM]PECQTYACT, [M:SOM]SHTQTY
            Affzo [M:SOM]PECQTY, PECQTYACT, SHTQTY
            Effzo [M:SOM]15
Endcase

Return

#########################################################################
$MENU

#--------------------------------------------
# "L" : Sortie d'un stock manquant
#--------------------------------------------
Case BOUT
 When "L"     : Call B1_NBLIG
Endcase

Return

#########################################################################
$FIN

# Si on a pas enregistré
If WGENR<>1
   Goto FIN_SUI
Endif

# Pas de ligne saisie
If [M:SOM]NBLIG=0
   Goto FIN_SUI
Endif

# Réalimente les champs lot,sous-lot,emplacement,statut et no de série
# de la ligne de document après saisie du détail de cette ligne
Local Char     LSERNUMF(GLONSER)
Local Integer  I
Local Char     CAR(1)            : CAR = "$"
Local Char     WLOT(GLONLOT)
Local Char     WSLO(GLONSLO)
Local Char     WLOC(GLONLOC)
Local Char     WSTA(GLONSTA)
Local Char     WSERNUM(GLONSER)
Local Char     WSERNUMF(GLONSER)
Local Char     WPALNUM(GLONPAL)
Local Char     WCTRNUM(GLONCTR)
Local Char     WWRH(GLONWRH)
#--- Issue 53322
Local Char     WLPNNUM(GLONLPN)
Local Shortint WABRLPN
#---
Local Shortint WABRLOT
Local Shortint WABRSLO
Local Shortint WABRLOC
Local Shortint WABRSTA
Local Shortint WABRSER
Local Shortint WABRPAL
Local Shortint WABRCTR
Local Shortint WABRWRH

Raz LRET

# Positionnement des flags présence zone dans l'écran
Raz WABRLOT, WABRSLO, WABRLOC, WABRSTA, WABRSER, WABRPAL, WABRCTR, WABRWRH
If evalue("dim([M:"+LABR+"]LOT(LNOL))")>0
   WABRLOT=1
Endif
If evalue("dim([M:"+LABR+"]SLO(LNOL))")>0
   WABRSLO=1
Endif
If evalue("dim([M:"+LABR+"]LOC(LNOL))")>0
   WABRLOC=1
Endif
If evalue("dim([M:"+LABR+"]STA(LNOL))")>0
   WABRSTA=1
Endif
If evalue("dim([M:"+LABR+"]SERNUM(LNOL))") >0 &
&  evalue("dim([M:"+LABR+"]SERNUMF(LNOL))")>0
   WABRSER=1
Endif
If evalue("dim([M:"+LABR+"]PALNUM(LNOL))")>0
   WABRPAL=1
Endif
If evalue("dim([M:"+LABR+"]CTRNUM(LNOL))")>0
   WABRCTR=1
Endif
#--- Issue 53322
If evalue("dim([M:"+LABR+"]LPNNUM(LNOL))")>0
   WABRLPN=1
Endif
#---
#If evalue("dim([M:"+LABR+"]WRH(LNOL))")>0
#   WABRWRH=1
#Endif

Raz WLOT, WSLO, WLOC, WSTA, WSERNUM, WSERNUMF, WPALNUM, WCTRNUM, WWRH
#--- Issue 53322
Raz WLPNNUM

# Si gestion no séries et no série définis dans l'écran -> tri selon ces no
If [M:SOM]SERMGTCOD>1 & WABRSER=1
   Sorta [M:SOM]NBLIG [M:SOM]NBLIG Order By [M:SOM]SERNUM(indice)
Endif

Raz WQTY
For I=0 To [M:SOM]NBLIG-1
   If I=0
      If WABRLOT=1 WLOT    = [M:SOM]LOT(I)    Endif
      If WABRSLO=1 WSLO    = [M:SOM]SLO(I)    Endif
      If WABRLOC=1 WLOC    = [M:SOM]LOC(I)    Endif
      If WABRSTA=1 WSTA    = [M:SOM]STA(I)    Endif
      If WABRPAL=1 WPALNUM = [M:SOM]PALNUM(I) Endif
      If WABRCTR=1 WCTRNUM = [M:SOM]CTRNUM(I) Endif
      If WABRSER=1
         WSERNUM  = [M:SOM]SERNUM(I)
         WSERNUMF = [M:SOM]SERNUMF(I)
      Endif
      #--- Issue 53322
      If WABRLPN=1 WLPNNUM = [M:SOM]LPNNUM(I) Endif
      #---
      #If WABRWRH=1 WWRH    = [M:SOM]WRH(I)    Endif
   Else
      If WABRLOT=1 & WLOT<>CAR
         If WLOT<>[M:SOM]LOT(I) WLOT=CAR Endif
      Endif
      If WABRSLO=1 & WSLO<>CAR
         If WSLO<>[M:SOM]SLO(I) WSLO=CAR Endif
      Endif
      If WABRLOC=1 & WLOC<>CAR
         If WLOC<>[M:SOM]LOC(I) WLOC=CAR Endif
      Endif
      If WABRSTA=1 & WSTA<>CAR
         If WSTA<>[M:SOM]STA(I) WSTA=CAR Endif
      Endif
      If WABRPAL=1 & WPALNUM<>CAR
         If WPALNUM<>[M:SOM]PALNUM(I) WPALNUM=CAR Endif
      Endif
      If WABRCTR=1 & WCTRNUM<>CAR
         If WCTRNUM<>[M:SOM]CTRNUM(I) WCTRNUM=CAR Endif
      Endif
      #--- Issue 53322
      If WABRLPN=1 & WLPNNUM<>CAR
         If WLPNNUM<>[M:SOM]LPNNUM(I) WLPNNUM=CAR Endif
      Endif
      #---
      If WABRSER=1
         If WSERNUM="" WSERNUM = [M:SOM]SERNUM(I) Endif
         WSERNUMF = [M:SOM]SERNUMF(I)
      Endif
      #If WABRWRH=1 & WWRH<>CAR
      #   If WWRH<>[M:SOM]WRH(I)       WWRH=CAR    Endif
      #Endif
   Endif
   WQTY += [M:SOM]QTYSTU(I)
Next

If [F:ITM]LOTMGTCOD =1 Raz WLOT             Endif
If [F:ITM]LOTMGTCOD<>4 Raz WSLO             Endif
If [F:ITF]LOCMGTCOD<>2 Raz WLOC             Endif
If [F:ITM]SERMGTCOD <2 Raz WSERNUM,WSERNUMF Endif
If WRHGES<>2           Raz WWRH             Endif
#--- Issue X3-53322
If [F:ITF]LPNMGTCOD<>2 Raz WLPNNUM          Endif
#---

If WABRSER=1 & WSERNUM<>"" & WSERNUMF<>""
   Call PLUS_NB(WSERNUM,WQTY,LSERNUMF,LRET) From STKLIB
   If LRET<>0 Return Endif
   If LSERNUMF<>WSERNUMF
      WSERNUM = CAR
      WSERNUMF= CAR
   Endif
Endif

If WABRLOT=1 Assign "[M:"+LABR+"]LOT(LNOL)" With WLOT Endif
If WABRSLO=1 Assign "[M:"+LABR+"]SLO(LNOL)" With WSLO Endif
If WABRLOC=1 Assign "[M:"+LABR+"]LOC(LNOL)" With WLOC Endif
If WABRSTA=1 Assign "[M:"+LABR+"]STA(LNOL)" With WSTA Endif
If WABRPAL=1 Assign "[M:"+LABR+"]PALNUM(LNOL)" With WPALNUM Endif
If WABRCTR=1 Assign "[M:"+LABR+"]CTRNUM(LNOL)" With WCTRNUM Endif
#--- Issue X3-53322
If WABRLPN=1 Assign "[M:"+LABR+"]LPNNUM(LNOL)" With WLPNNUM Endif
#---
If WABRSER=1
   Assign "[M:"+LABR+"]SERNUM(LNOL)"  With WSERNUM
   Assign "[M:"+LABR+"]SERNUMF(LNOL)" With WSERNUMF
Endif
#If WABRWRH=1 Assign "[M:"+LABR+"]WRH(LNOL)" With WWRH Endif
Assign "[M:"+LABR+"]MVTDES(LNOL)" With [M:SOM]MVTDES

$FIN_SUI

Return

#########################################################################
$FINSAI

# Si on a pas enregistré
If WGENR<>1 : Return : Endif

Default Mask "["+LABR+"]"

# Affichage de l'écran contenant les lignes de document
Affzo [M]1-99

#--- Issue 118815
#mkstat=3
If WGENR=1 & GREP="" mkstat=4 Endif              # hcb 53526

Return

#########################################################################
$AB_TRT

Rollback

If !GIMPORT & GTRACE<>""
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE From LECFIC
Endif
Return

#########################################################################
# Action sur champs
#########################################################################

########################################
Subprog AM_SORQTYACT(VALEUR)
Variable Decimal VALEUR
Local Integer OK, NOL

# Si désassemblage, pas de qté à 0
If GVCRTYP=32 & VALEUR=0
   GMESSAGE=mess(9,184,1)
   mkstat=2 : End
Endif

# On ne sait pas calculé la qté en unité physique globale
# on initialise avec la quantité active
[M:SOM]SORQTY = VALEUR

If VALEUR=0
   OK=1
   Call AVERTIR(mess(102,184,1),OK) From GESECRAN
   If OK=1 mkstat=2 : End Endif

   For NOL=0 To [M:SOM]NBLIG-1
      If dim([M:SOM]LOC)>0 & [M:SOM]LOC(NOL)<>""
         Call STKCTREMPM([M:SOM]LOC(NOL)) From STKLOC
         If mkstat : Break : Endif
      Endif
   Next NOL
   If mkstat : End : Endif

Endif

# Si raz de la quantité à sortir, positionnement du contexte 'supp ligne'
# pour suppression des lignes dans l'action 'APRES_MODIF'
If VALEUR=0 & [M:SOM]NBLIG<>0
   GSUPLIG = 83
Endif

# X3-80367 - STWIL - Before we delete the stock transaction if it is a customer return, purchase receipt or production tracking
# check if this document is in any non-conformances
If func AFNC.ACTIV ("NCS")
    Local Integer EXISTS
    Local Char NCSMESS(255)

    [L]EXISTS = func NCSDOCHDR_CSTD.NON_CONFORMANCE_EXISTS (3, [M:SOM]VCRNUM, 0, [L]NCSMESS, 0)
    If [L]EXISTS > 0 & GNCSLINFLG = 0
        Call OUINON([L]NCSMESS,OK) From GESECRAN
        GNCSLINFLG = 1
        If OK = 1
            GMESSAGE = ""
            GERR = 1
            mkstat = 2
            End
        Endif
    Endif
Endif

End

########################################
Subprog AV_SHTQTY(VALEUR)
Variable Decimal VALEUR
pcolor=GCOUL(2)
End

########################################
Subprog IB_NBLIG
Local Integer NOL
NOL = nolign-1

# Si stock négatif interdit, pas de sortie d'un stock manquant
If [M:SOM]NEGSTO<>2 | [M:SOM]PECQTYACT+[M:SOM]SHTQTY>=[M:SOM]SORQTYACT
   Raz GBOUT1
Endif

#--- Issue 110327
# Si no série non géré en sortie ou E/S globale, ou mvt en attente,
# ou no série déjà existant, ou quantité <= 1 pas de saisie éclatée des no série
#If [M:SOM]SERMGTCOD<>2 | [M:SOM]WAIFLG(NOL)=1 | [M:SOM]SERNUMFLG(NOL)=1 |
#&  [M:SOM]QTYSTU(NOL)<=1
If !find([M:SOM]SERMGTCOD,2,4) | [M:SOM]WAIFLG(NOL)=1 | [M:SOM]SERNUMFLG(NOL)=1 |
&  [M:SOM]QTYSTU(NOL)<=1
#---
   Raz GBOUT2
Endif

# Si no série géré en sortie et trf inter-site mais intra-société
# pas de saisie éclatée des no série
If [M:SOM]SERMGTCOD=2 & [M:SOM]TRFFCY<>"" & [M:SOM]BETCPY<>2
   Raz GBOUT2
Endif

End

########################################
Subprog B1_NBLIG
Local Integer NOL
Local Integer WRHGES

If [F:FCY]FCY<>[M:SOM]STOFCY
   Read [FCY]FCY0=[M:SOM]STOFCY
   If fstat Raz [F:FCY] Endif
Endif
WRHGES=[F:FCY]WRHGES

nolign =  [M:SOM]NBLIG+1
NOL = nolign-1

[M:SOM]ICOMVTATT(NOL)="247"

[M:SOM]QTYSTUACT(NOL)=[M:SOM]SORQTYACT-([M:SOM]PECQTYACT+[M:SOM]SHTQTY)

# Calcul nouvelle quantité US
[M:SOM]QTYSTU(NOL) = [M:SOM]QTYSTUACT(NOL)

# Calcul nouvelle quantité rupture
[M:SOM]SHTQTY += [M:SOM]QTYSTUACT(NOL)

# Calcul quantité en UC
#If [M:SOM]XPCUSTUCOE(NOL)=0 [M:SOM]XPCUSTUCOE(NOL)=1 Endif
#[M:SOM]QTYPCU(NOL) = [M:SOM]QTYSTU(NOL)/[M:SOM]XPCUSTUCOE(NOL)
#Call QTEARR([M:SOM]QTYPCU(NOL),[M:SOM]XPCU(NOL)) From TRTDIV

Raz [M:SOM]SERNUMFLG(NOL), [M:SOM]MVTSEQ(NOL), [M:SOM]MVTIND(NOL)

# Mvt en attente
[M:SOM]WAIFLG(NOL) = 1

Insa [M:SOM]NBLIG+1,1,[M:SOM]NBLIG [M:SOM]NBLIG
[M:SOM]NBLIG += 1

Affzo [M]PECQTY, PECQTYACT, SHTQTY

Actzo [M:SOM]QTYSTU(NOL)
Diszo [M:SOM]QTYPCU(NOL)
If dim([M:SOM]LOT)>0    Actzo [M:SOM]LOT(NOL)    Endif
If dim([M:SOM]SLO)>0    Actzo [M:SOM]SLO(NOL)    Endif
If dim([M:SOM]LOC)>0    Actzo [M:SOM]LOC(NOL)    Endif
If dim([M:SOM]SERNUM)>0
   # Si no série géré en sortie, pas de saisie
   # car problème pour régulariser par la suite
   If [M:SOM]SERMGTCOD=2
      Diszo [M:SOM]SERNUM(NOL)
   Else
      Actzo [M:SOM]SERNUM(NOL)
   Endif
Endif
Actzo [M:SOM]STA(NOL)
If dim([M:SOM]WRH)>0
   If WRHGES=2
      # Dépôt saisi sur la ligne de document
      If [M:SOM]XWRH=""
         Actzo [M:SOM]WRH(NOL)
      Else
         If [M:SOM]WRHOBY=2
            Diszo [M:SOM]WRH(NOL)
         Else
            Actzo [M:SOM]WRH(NOL)
         Endif
         [M:SOM]WRH(NOL)=[M:SOM]XWRH
      Endif
   Else
      Grizo [M:SOM]WRH(NOL)
   Endif
Endif
#--- TS 106217
If dim([M:SOM]ECCVALMAJ)>0
   #--- Si version exclusive et renseignée, pas de modification
   If [M:SOM]WECCVALMAJ<>"" & [F:SRU]ORDVER=2
      [M:SOM]ECCVALMAJ(NOL) = [M:SOM]WECCVALMAJ
      Diszo [M:SOM]ECCVALMAJ(NOL)
   Else
      Actzo [M:SOM]ECCVALMAJ(NOL)
   Endif
   Affzo [M:SOM]ECCVALMAJ(NOL)
Endif
#---
Affzo [M:SOM]15
mkstat=4

End

########################################
Subprog AVANT_NBLIG
Local Integer I, NOL
NOL = nolign-1

# Calcul nouvelle quantité sélectionnée
If [M:SOM]WAIFLG(NOL)=1
   [M]SHTQTY    -= [M]QTYSTU(NOL)
Else
   [M]PECQTY    -= [M]QTYSTU(NOL)
   [M]PECQTYACT -= [M]QTYSTUACT(NOL)
Endif

End

########################################
Subprog APRES_NBLIG
Local Integer NOL
NOL = nolign-1

# Calcul nouvelle quantité sélectionnée
If [M:SOM]WAIFLG(NOL)=1
   [M]SHTQTY    += [M]QTYSTU(NOL)
Else
   [M]PECQTY    += [M]QTYSTU(NOL)
   [M]PECQTYACT += [M]QTYSTUACT(NOL)
Endif

Affzo [M]PECQTY, PECQTYACT, SHTQTY

End

########################################
Subprog C_NBLIG
Local Integer NOL
NOL=nolign-1

# --> Suppression de lignes
If find(status,65,68,83)

    # X3-80367 - STWIL - Before we delete the stock transaction if it is a customer return, purchase receipt or production tracking
    # check if this document is in any non-conformances
    If func AFNC.ACTIV ("NCS")
        Local Integer EXISTS
        Local Integer LOK
        Local Char NCSMESS(255)

        [L]EXISTS = func NCSDOCHDR_CSTD.NON_CONFORMANCE_EXISTS (3, [M:SOM]VCRNUM, 0, [L]NCSMESS, 0)
        If [L]EXISTS > 0 & GNCSLINFLG = 0
            Call OUINON([L]NCSMESS,LOK) From GESECRAN
            GNCSLINFLG = 1
            If LOK = 1
                GMESSAGE = ""
                GERR = 1
                mkstat = 2
                End
            Endif
        Endif
    Endif


   # --> Contrôle de suppression de lignes
   Case status
    When 65    : If dim([M:SOM]LOC)>0 & [M:SOM]LOC(NOL)<>""
                    Call STKCTREMPM([M:SOM]LOC(NOL)) From STKLOC
                    If mkstat : End : Endif
                 Endif
    When 68,83 : For NOL=nolign-1 To nolign1-1
                    If dim([M:SOM]LOC)>0 & [M:SOM]LOC(NOL)<>""
                       Call STKCTREMPM([M:SOM]LOC(NOL)) From STKLOC
                       If mkstat : Break : Endif
                    Endif
                 Next NOL
                 If mkstat : End : Endif
   Endcase

   GSUPLIG = status
Else
   Raz GSUPLIG
Endif

# --> Reprise interdite
If status=82 mkstat=2 Endif

End

