&              [M:SOM]IPTDAT,LRET) From STKSOR
If LRET>0 mkstat=2 Endif
End
#---

########################################
Subprog AV_SERNUM(VALEUR)
Variable Char    VALEUR()
If [M:SOM]WAIFLG(nolign-1)=1
   Chgstl SERNUM(nolign-1) With "AWARNLOW"
Else
   Chgstl SERNUM(nolign-1) With ""
Endif
End

########################################
Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL, J, WRET, WNBSERIE
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)
Local    Integer OK : OK=1               : #--- Issue 110327
NOL = nolign-1

# No série non modifié
If [M:SOM]SERNUM(NOL)=VALEUR End Endif

# Si mvt mis à jour
If [M:SOM]WAIFLG(NOL)<>1
   #--- Issue 110327
   # No série gérés en sortie
   #If [M:SOM]SERMGTCOD=2
   #   Read [STS]STS0=[M:SOM]ITMREF;VALEUR
   #   # Le no série existe
   #   If !fstat
   #      # S'il n'a pas été sortie par cette pièce --> erreur
   #      If [F:STS]SDHTYP<>[M:SOM]VCRTYP | [F:STS]SDHNUM<>[M:SOM]VCRNUM
#&         | [F:STS]SDDLIN<>[M:SOM]VCRLIN
   #         mkstat=1 : GMESSAGE=VALEUR-":"-mess(3,187,1) : End
   #      # S'il a une pièce entrée --> erreur
   #      Elsif [F:STS]RCPVCRTYP<>0 & [F:STS]RCPVCRNUM<>""
   #         mkstat=1 : GMESSAGE=VALEUR-":"-mess(3,187,1) : End
   #      Endif
   #   Endif
   # No série gérés en sortie ou en E/S globale
   If find([M:SOM]SERMGTCOD,2,4)
      Read [STS]STS0=[M:SOM]ITMREF;VALEUR
      # Si séries en E/S globale
      If [F:ITM]SERMGTCOD=4
         # On contrôle uniquement si le no série n'était pas déjà dans la séquence initiale
         # Fonctionne uniquement la première fois: ensuite les contrôles ne sont plus ok
         # car [M:SOM]SERNUM et [M:SOM]SERNUMF n'ont plus les valeurs initiales
         If VALEUR<[M:SOM]SERNUMORI(NOL) | VALEUR>[M:SOM]SERNUMFORI(NOL)
            If fstat
               mkstat=2 : GMESSAGE=VALEUR-":"-mess(43,196,1) : End
            Elsif [F:STS]STOCOU<>0 & [F:STS]STOCOU<>[M:SOM]STOCOU(NOL)
               mkstat=2 : GMESSAGE=VALEUR-":"-mess(447,184,1) : End
            Elsif [F:STS]ISSDAT<>[0/0/0] & ([F:STS]SDHNUM<>[M:SOM]VCRNUM | [F:STS]SDDLIN<>[M:SOM]VCRLIN)
               mkstat=2 : GMESSAGE=VALEUR-":"-mess(37,184,1) : End
            Elsif [F:STS]ISSDAT=[0/0/0] & [F:STS]SDHNUM<>"" & !find([F:STS]SDHNUM,[M:SOM]VCRNUM,[M:SOM]VCRNUMORI)
               mkstat=2 : GMESSAGE=VALEUR-":"-mess(443,184,1) : End
            Endif
            If [M:SOM]VCRTYP=8 & [M:SOM]VCRNUMORI<>""
              If [F:STS]RCPVCRTYP<>6 | [F:STS]RCPVCRNUM<>[M:SOM]VCRNUMORI | [F:STS]RCPVCRLIN<>[M:SOM]VCRLINORI
                OK=1 : Call AVERTIR([F:STS]SERNUM+"\"+mess(489,184,1), OK) From GESECRAN
                If OK=1  mkstat=2 : End  Endif
              Endif
            Endif
         Endif
      # No série en sortie qui existe
      Elsif !fstat
         # S'il n'a pas été sortie par cette pièce --> erreur
         If [F:STS]SDHTYP<>[M:SOM]VCRTYP | [F:STS]SDHNUM<>[M:SOM]VCRNUM
&         | [F:STS]SDDLIN<>[M:SOM]VCRLIN
            mkstat=1 : GMESSAGE=VALEUR-":"-mess(3,187,1) : End
         # S'il a une pièce entrée --> erreur
         Elsif [F:STS]RCPVCRTYP<>0 & [F:STS]RCPVCRNUM<>""
            mkstat=1 : GMESSAGE=VALEUR-":"-mess(3,187,1) : End
         Endif
      Endif
      #--- End issue 110327

      # Si qté =1, alimentation no série fin
      If [M:SOM]QTYSTU(NOL)=1
         [M:SOM]SERNUMF(NOL) = VALEUR
      Else
         # Vérification que les no série n'existent pas
         # et alimentation du no série fin
         WNBSERIE = [M:SOM]QTYSTU(NOL)
         WNUMDEB  = VALEUR
         For J=2 To WNBSERIE
            Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
            If WRET=0
               Read [STS]STS0=[M:SOM]ITMREF;WNUMFIN
               #--- Issue 110327
               #If fstat
               #   WNUMDEB = WNUMFIN
               ## Le no série existe
               #Else
               #   # S'il n'a pas été sortie par cette pièce --> erreur
               #   If [F:STS]SDHTYP<>[M:SOM]VCRTYP | [F:STS]SDHNUM<>[M:SOM]VCRNUM
#&                  | [F:STS]SDDLIN<>[M:SOM]VCRLIN
               #      mkstat=1 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
               #   # S'il a une pièce entrée --> erreur
               #   Elsif [F:STS]RCPVCRTYP<>0 & [F:STS]RCPVCRNUM<>""
               #      mkstat=1 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
               #   Else
               #      WNUMDEB = WNUMFIN
               #   Endif
               #Endif
               # Si séries en E/S globale
               If [F:ITM]SERMGTCOD=4
                  # On contrôle uniquement si le no série n'était pas déjà dans la séquence initiale
                  # Fonctionne uniquement la première fois: ensuite les contrôles ne sont plus ok
                  # car [M:SOM]SERNUM et [M:SOM]SERNUMF n'ont plus les valeurs initiales
                  If WNUMFIN<[M:SOM]SERNUMORI(NOL) | WNUMFIN>[M:SOM]SERNUMFORI(NOL)
                     If fstat
                        mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(43,196,1) : Break
                     Elsif [F:STS]STOCOU<>0 & [F:STS]STOCOU<>[M:SOM]STOCOU(NOL)
                        mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(447,184,1) : Break
                     Elsif [F:STS]ISSDAT<>[0/0/0] & ([F:STS]SDHNUM<>[M:SOM]VCRNUM | [F:STS]SDDLIN<>[M:SOM]VCRLIN)
                        mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(37,184,1) : Break
                     Elsif [F:STS]ISSDAT=[0/0/0] & [F:STS]SDHNUM<>"" & !find([F:STS]SDHNUM,[M:SOM]VCRNUM,[M:SOM]VCRNUMORI)
                        mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(443,184,1) : Break
                     Endif
                     If OK=1 & [M:SOM]VCRTYP=8 & [M:SOM]VCRNUMORI<>""
                        If [F:STS]RCPVCRTYP<>6 | [F:STS]RCPVCRNUM<>[M:SOM]VCRNUMORI | [F:STS]RCPVCRLIN<>[M:SOM]VCRLINORI
                           OK=1 : Call AVERTIR([F:STS]SERNUM+"\"+mess(489,184,1), OK) From GESECRAN
                           If OK=1  mkstat=2 : Break  Endif
                        Endif
                     Endif
                  Endif
               # No série en sortie qui existe
							 Elsif !fstat
                  # S'il n'a pas été sortie par cette pièce --> erreur
                  If [F:STS]SDHTYP<>[M:SOM]VCRTYP | [F:STS]SDHNUM<>[M:SOM]VCRNUM
&                  | [F:STS]SDDLIN<>[M:SOM]VCRLIN
                     mkstat=1 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
                  # S'il a une pièce entrée --> erreur
                  Elsif [F:STS]RCPVCRTYP<>0 & [F:STS]RCPVCRNUM<>""
                     mkstat=1 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
                  Endif
               Endif
               WNUMDEB = WNUMFIN
               #--- End issue 110327
            Else
               mkstat=1 : GMESSAGE=WNUMDEB-":"-mess(476,197,1)  : Break
            Endif
         Next J
         If mkstat<>0 End Endif
         [M:SOM]SERNUMF(NOL) = WNUMFIN
      Endif
   Endif
# Sinon (mvt en attente) no série gérés en E/S
Elsif [M:SOM]SERMGTCOD=3
   Read [STS]STS0=[M:SOM]ITMREF;VALEUR
   # Si no série existe, erreur
   If !fstat
      mkstat=1 : GMESSAGE=VALEUR-":"-mess(3,187,1) : End
   Endif
   # Si qté =1, alimentation no série fin
   If [M:SOM]QTYSTU(NOL)=1
      [M:SOM]SERNUMF(NOL) = VALEUR
   Else
      # Vérification que les no série n'existent pas
      # et alimentation du no série fin
      WNBSERIE = [M:SOM]QTYSTU(NOL)
      WNUMDEB  = VALEUR
      For J=2 To WNBSERIE
         Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
         If WRET=0
            Read [STS]STS0=[M:SOM]ITMREF;WNUMFIN
            If fstat
               WNUMDEB = WNUMFIN
            Else
               mkstat=1 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
            Endif
         Else
            mkstat=1 : GMESSAGE=WNUMDEB-":"-mess(476,197,1)  : Break
         Endif
      Next J
      If mkstat<>0 End Endif
      [M:SOM]SERNUMF(NOL) = WNUMFIN
   Endif
Endif
#--- Issue 110327
[M:SOM]SERNUM(NOL) = VALEUR
#---
Affzo [M]SERNUMF(NOL)

End

########################################
Subprog AV_SERNUMF(VALEUR)
Variable Char    VALEUR()
If [M:SOM]WAIFLG(nolign-1)=1
   Chgstl SERNUMF(nolign-1) With "AWARNLOW"
Else
   Chgstl SERNUMF(nolign-1) With ""
Endif
End

