#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion objet ACLA4
########################################################################
# Fenêtres de saisie                                                   #
# ------------------                                                   #
# ACLAATYP  : Content Types                                             #
########################################################################
$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "OK"            : Gosub OK
 When "FIN"           : Gosub FIN
Endcase
Return

#########################################################################
#    Actions liés au type fenêtre de saisie                             #
#########################################################################
$OUVRE
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
Return

$FIN
nolign=SAVNOLIGN
Return

$DEBUT
Case GACTION
 When "ACLAATYP"    : Gosub DEB_ACLAATYP
Endcase
Return

$OK
Case GACTION
 When "ACLAATYP"    : Gosub OK_ACLAATYP
Endcase
Return


#----------------------------------------------------------
$DEB_ACLAATYP
Effzo [M:ACLA10]
[M:ACLA10]CURFLD=[M:ACLA6]FLDCLA(SAVNOLIGN-1)
[M:ACLA10]CODTYP=[M:ACLA6]CODTYP(SAVNOLIGN-1)
Local Integer J
# parameters (ACLA8)
For J=0 To [M:ACLA8]WNBRPARALL-1
 If [M:ACLA8]WTYPPAR(J)=2 & [M:ACLA10]CURFLD=[M:ACLA8]WFLDCLA(J) & [M:ACLA8]WCODTYP(J)=[M:ACLA10]CODTYP
    [M:ACLA10]ATYP([M:ACLA10]NBRTYP) = [M:ACLA8]WVALEUR(J)
    Read [ATYP]ATYP0=[M:ACLA10]ATYP([M:ACLA10]NBRTYP)
    If !fstat
     [M:ACLA10]PROTYP([M:ACLA10]NBRTYP)=[F:ATYP]PROTYP
    Endif
    [M:ACLA10]NBRTYP += 1
 Endif
Next
Affzo [M:ACLA10]
Return

#----------------------------------------------------------
$OK_ACLAATYP
Local Integer J
# parameters (ACLA8)
For J=0 To [M:ACLA8]WNBRPARALL-1
 If [M:ACLA8]WTYPPAR(J)=2 & [M:ACLA10]CURFLD=[M:ACLA8]WFLDCLA(J)
     Dela J,1 [M:ACLA8]WNBRPARALL
     [M:ACLA8]WNBRPARALL -=1
     J-=1
 Endif
Next
For J=0 To [M:ACLA10]NBRTYP-1
   [M:ACLA8]WCODTYP([M:ACLA8]WNBRPARALL)    = [M:ACLA10]CODTYP
   [M:ACLA8]WCODPAR([M:ACLA8]WNBRPARALL)    = "ATYP~"+num$(J+1)
   [M:ACLA8]WTYPPAR([M:ACLA8]WNBRPARALL)    = 2
   [M:ACLA8]WFLDCLA([M:ACLA8]WNBRPARALL)    = [M:ACLA10]CURFLD
   [M:ACLA8]WTYPKEY([M:ACLA8]WNBRPARALL)    = 1
   [M:ACLA8]WVALEUR([M:ACLA8]WNBRPARALL)    = [M:ACLA10]ATYP(J)
   [M:ACLA8]WNUMPAR([M:ACLA8]WNBRPARALL)    = J+1
   [M:ACLA8]WTYPINTPAR([M:ACLA8]WNBRPARALL) = 7
   [M:ACLA8]WNBRPARALL  +=1
Next
Return

######################################################################################
Subprog C_ATYP(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:ACLA10]ATYP(0..[M:ACLA10]NBRTYP-1)) From OBJDIV
If mkstat : End : Endif
Local Integer WTYPINT
Read [ATY]CODTYP=[M:ACLA10]CODTYP
WTYPINT=[F:ATY]TYPTYP
Read [ATYP]ATYP0=VALEUR
If WTYPINT<>[F:ATYP]TYPTYP
    GMESSAGE = mess(260,143,1)
    GERR=1
    mkstat=2
    End
Elsif [F:ATYP]PREFLG=2
    GMESSAGE = mess(83,123,1)
    GERR=1
    mkstat=2
    End
Endif
End
######################################################################################
Subprog AM_ATYP(VALEUR)
Variable Char    VALEUR()
Read [ATYP]ATYP0=VALEUR
If !fstat
 [M:ACLA10]PROTYP(nolign-1)=[F:ATYP]PROTYP
Else
 [M:ACLA10]PROTYP(nolign-1)=""
Endif
Affzo [M:ACLA10]PROTYP(nolign-1)
End


######################################################################################
