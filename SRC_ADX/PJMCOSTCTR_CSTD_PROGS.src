###################################################################################################
# Classe PJMCOSTCTR
###################################################################################################
# PROGS
###################################################################################################
#**
#* Search rate from Date input, cost type and unit of measure
#* @param PPCOD
#* @param PDATE  date du jour (current date)
#* @param SUOM
#* @param SCUR
#* @param WRATE
#*!
Subprog GETRATE_FROMDATE(PPCOD, PDATE, SUOM, SCUR, WRATE)
Value Char  PPCOD
Value Date  PDATE
Variable Char SUOM
Variable Char SCUR
Variable Decimal WRATE

  #------------------------------
  Raz SUOM
  Raz SCUR
  Raz WRATE
  #------------------------------
  Local File PJMCOSTCTR [PCC]
  Local File PJMCOSTDAT [CSTD]
  #-- max select : premiere date à prendre
  #-- Tri by Desc ------------------------
  Filter [CSTD] Where PCCCOD=PPCOD and PCCDATCST<=PDATE and PCCDATCST<>[0/0/0] Order By PCCDATCST Desc
  For [CSTD]
    WRATE = [F:CSTD]PCCCST
    Read [F:PCC]PCC0 = [F:CSTD]PCCCOD
    SUOM = [F:PCC]PCCU
    SCUR = [F:PCC]PCCCUR
    PPCOD = [F:PCC]PCCCOD
    Break : #-- out loop
  Next
  Filter[CSTD] : #-- defilter
End

###################################################################################################
Funprog GET_DESAXX(PJMCOSCTR, PPCOD)
Variable Instance PJMCOSCTR Using OBJECT
Value Char PPCOD
#------------------------------
Local Char SARENDRE(GLONDCO)
  #------------------------------
  Raz SARENDRE
  Call LECTEXTRA_SYR(PJMCOSCTR, AVOID.ACHAR, SARENDRE, "PJMCOSTCTR", "DESAXX", PPCOD, AVOID.ACHAR) From ATEXTRA
End SARENDRE

###################################################################################################
Funprog IS_ITMREF_VALID(SITMREF, SMESSAGE)
# Issue X3-3414/119352 - 2016-10-25 by SINGC
Value Char SITMREF
Variable Char SMESSAGE
#------------------------------
Local Integer IRET
#------------------------------
Local File ITMMASTER [ITM]
Local File ITMCATEG  [ITG]

  IRET = [V]CST_AOK
  Raz SMESSAGE
  # ----------------------------------
  Read [ITM]ITM0 = SITMREF
  Read [ITG]ITG1 = [F:ITM]TCLCOD;""
  # ----------------------------------
  If [F:ITG]SALFLG <> [V]CST_AYES or [F:ITG]SCSFLG <> [V]CST_AYES Then
    SMESSAGE = mess(437,2260,1)
    IRET = [V]CST_AERROR
  Endif
End IRET

###################################################################################################
Funprog IS_PCCCOD_ENABLE(ACTX, SPCCCOD)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SPCCCOD

Local Integer IARENDRE

  # Issue X3-5329 - 2017-04-28 by FGR
  IARENDRE = [V]CST_AYES
  # -------------------
  Local File PJMCOSTCTR [PJCC]
  Read [F:PJCC]PCC0=SPCCCOD
  If [F:PJCC]ENAFLG <> [V]CST_AYES Then
    IARENDRE = [V]CST_ANO
  Endif
End IARENDRE

