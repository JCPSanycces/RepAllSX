#<AdxTL>@(#)2.0.0.0 $Revision$
##################################################################################################################
#   Programmes utilitaires pour la gestion des publipostages XML             Module CRM       5 Novembre 2003
##################################################################################################################
#
# LOADMXL1      : Chargement du paramétrage d'un publipostage
# SAVEMXL1      : Enregistrement du paramétrage d'un publipostage
# LOADPARAM     : Chargement du paramétrage par défaut d'un tiers
# CHECKDUP      : Vérifie la présence de doublons de tag dans le publipostage
# MAILCCN       : Création de la version standard du publipostage MAILCCN
# MAILBPR       : Création de la version standard du publipostage MAILBPR
#
#############################################################################################
##########################################################################################################
# Chargement du paramétrage d'un publipostage
#############################################################################################
$LOADMXL1
Local Integer ITERNBLIG

  ITERNBLIG = 0
  Raz [M:MXL1]NBLIG
  Raz [M:MXL1]TAB
  Raz [M:MXL1]FIE
  Raz [M:MXL1]LBEXML
  Filter [MXD] Where [F:MXD]NUM = [M:MXL0]NUM Order By [F:MXD]TAB Asc; [F:MXD]FIE Asc
  For [MXD]
    If ITERNBLIG >= dim([M:MXL1]TAB) Then
      Break
    Endif
    [M:MXL1]TAB(ITERNBLIG) = [F:MXD]TAB
    [M:MXL1]FIE(ITERNBLIG) = [F:MXD]FIE
    [M:MXL1]LBEXML(ITERNBLIG) = [F:MXD]LBEXML
    ITERNBLIG += 1
  Next
  Filter [MXD]
  [M:MXL1]NBLIG = ITERNBLIG
Return

##########################################################################################################
# Chargement du paramétrage d'un publipostage
#############################################################################################
$SAVEMXL1
Local Integer ITER

  #On efface tout
  Delete [MXD] Where [F:MXD]NUM = [M:MXL0]NUM
  If fstat Then
    If fstat Then
      GOK = 0
      #Erreur lors de l'enregistrement du paramétrage du publipostage XML. Transaction abandonnée.
      GMESSAGE = mess(645,182,1)
      GERR = 1
      Return
    Endif
  Endif
  #On récrée
  For ITER = 0 To [M:MXL1]NBLIG-1
    Raz [F:MXD]
    [F:MXD]NUM = [M:MXL0]NUM
    [F:MXD]TAB = [M:MXL1]TAB(ITER)
    [F:MXD]FIE = [M:MXL1]FIE(ITER)
    [F:MXD]LBEXML = [M:MXL1]LBEXML(ITER)
    Write [MXD]
    If fstat Then
      #Erreur lors de l'enregistrement du paramétrage du publipostage XML. Transaction abandonnée.
      GMESSAGE = mess(645,182,1)
      GERR = 1
      GOK = 0
      Break
    Endif
  Next
Return

##########################################################################################################
# Chargement du paramétrage par défaut
#############################################################################################
$LOADPARAM
Local Integer ITERATZ
Local Integer ITERWHILE
Local Integer ITERDIM
Local Char SZTABT(GLONATB)
Local Char SZABRFIC(GLONABR)
Local Integer IFIEDIM

  If !clalev([F:REP]) : Local File SALESREP [REP] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif
  ITERATZ = 0
  ITEWHILE = 0
  SZTAB = ""
  IFIEDIM = 0
  ITERDIM = 0
  SZABRFIC = ""
  Raz [M:MXL1]NBLIG
  Raz [M:MXL1]TAB
  Raz [M:MXL1]FIE
  Raz [M:MXL1]LBEXML
  While 1
    If [M:MXL0]TYP = 1 Then
      #Tiers
      If ITERWHILE = 0 Then
        SZTAB = "BPADDRESS"
        SZABRFIC = "BPA"
      Elsif ITERWHILE = 1 Then
        SZTAB = "BPARTNER"
        SZABRFIC = "BPR"
      Elsif ITERWHILE = 2 Then
        SZTAB = "BPCUSTOMER"
        SZABRFIC = "BPC"
      Elsif ITERWHILE = 4 Then
        SZTAB = "SALESREP"
        SZABRFIC = "REP"
      Elsif ITERWHILE = 5 Then
        Break
      Endif
    Elsif [M:MXL0]TYP = 2 Then
      #Interlocuteurs
      If ITERWHILE = 0 Then
        SZTAB = "BPADDRESS"
        SZABRFIC = "BPA"
      Elsif ITERWHILE = 1 Then
        SZTAB = "BPARTNER"
        SZABRFIC = "BPR"
      Elsif ITERWHILE = 2 Then
        SZTAB = "BPCUSTOMER"
        SZABRFIC = "BPC"
      Elsif ITERWHILE = 3 Then
        SZTAB = "CONTACT"
        SZABRFIC = "CNT"
      Elsif ITERWHILE = 4 Then
        SZTAB = "CONTACTCRM"
        SZABRFIC = "AIN"
      Elsif ITERWHILE = 5 Then
        SZTAB = "SALESREP"
        SZABRFIC = "REP"
      Elsif ITERWHILE = 6 Then
        Break
      Endif
    Endif
    Filter [ATZ] Where [F:ATZ]CODFIC = SZTAB
    For [ATZ]CODZONE
      If ITERATZ >= dim([M:MXL1]TAB) Then
        Break
      Endif
      IFIEDIM = evalue("Dim([F:" + SZABRFIC + "]" + [F:ATZ]CODZONE + ")")
      IFIEDIM -= 1
      For ITERDIM = 0 To IFIEDIM
        If ITERDIM = 0 Then
          [M:MXL1]FIE(ITERATZ) = [F:ATZ]CODZONE
        Else
          [M:MXL1]FIE(ITERATZ) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
        Endif
        [M:MXL1]TAB(ITERATZ) = [F:ATZ]CODFIC
        [M:MXL1]LBEXML(ITERATZ) = ""
        ITERATZ += 1
      Next
    Next
    Filter [ATZ]
    ITERWHILE += 1
  Wend
  [M:MXL1]NBLIG = ITERATZ
Return

##########################################################################################################
# Vérifie la présence de doublons de tag dans le publipostage
############################################################
$CHECKDUP
Local Integer ITERLOOP
Local Integer ITERLIG
Local Integer IDUPOK
Local Char SZCTL(200)
Local Char SZLBEXML(type([M:MXL1]LBEXML)-10)

  ITERLOOP = 0
  SZCTL = ""
  IDUPOK = 1
  ITERLIG = 0
  SZLBEXML = ""
  #Nom
  If [M:MXL0]ROT = [M:MXL0]NUM Then
    IDUPOK = 0
  Endif
  If [M:MXL0]TTR = [M:MXL0]NUM Then
    IDUPOK = 0
  Endif
  #Objet XML
  If [M:MXL0]NUM = [M:MXL0]ROT Then
    IDUPOK = 0
  Endif
  If [M:MXL0]TTR = [M:MXL0]ROT Then
    IDUPOK = 0
  Endif
  #Titre
  If [M:MXL0]NUM = [M:MXL0]TTR Then
    IDUPOK = 0
  Endif
  If [M:MXL0]ROT = [M:MXL0]TTR Then
    IDUPOK = 0
  Endif
  #En-tête
  If !IDUPOK Then
    #Des doublons de tags XML ont été détectés parmi les informations d'en-tête.
    GMESSAGE = mess(654,182,1)
    GERR = 2
    OK = 0
    Return
  Endif
  #Lignes avec en-tête
  While 1
    #Nom
    If ITERLOOP = 0 Then
      SZCTL = [M:MXL0]NUM
    Endif
    #Objet XML
    If ITERLOOP = 1 Then
      SZCTL = [M:MXL0]ROT
    Endif
    #Titre
    If ITERLOOP = 2 Then
      SZCTL = [M:MXL0]TTR
    Endif
    #Sortie
    If ITERLOOP = 3 Then
      Break
    Endif
    For ITERLIG = 0 To [M:MXL1]NBLIG-1
      If [M:MXL1]LBEXML(ITERLIG) <> "" Then
        If [M:MXL1]LBEXML(ITERLIG) = SZCTL Then
          IDUPOK = 0
          Break
        Endif
      Endif
    Next
    ITERLOOP += 1
    If !IDUPOK Then
      Break
    Endif
  Wend
  If !IDUPOK Then
    #Des doublons de tags XML ont été détectés entre les informations d'en-tête et les lignes.
    GMESSAGE = mess(652,182,1)
    GERR = 2
    OK = 0
    Return
  Endif
  #Lignes entres elles
  For ITERLOOP = 0 To [M:MXL1]NBLIG-1
    For ITERLIG = 0 To [M:MXL1]NBLIG-1
      If ITERLIG <> ITERLOOP Then
        If [M:MXL1]LBEXML(ITERLIG) <> ""
          If [M:MXL1]LBEXML(ITERLOOP) <> "" Then
            If [M:MXL1]LBEXML(ITERLIG) = [M:MXL1]LBEXML(ITERLOOP) Then
              SZLBEXML = [M:MXL1]LBEXML(ITERLOOP)
              [M:MXL1]LBEXML(ITERLOOP) = "**" - SZLBEXML - "**"
              IDUPOK = 0
            Endif
          Endif
        Endif
      Endif
    Next
  Next
  If !IDUPOK Then
    #Des doublons de tags XML ont été détectés parmi la liste des champs.
    GMESSAGE = mess(653,182,1)
    GERR = 2
    OK = 0
    Return
  Endif
Return

##########################################################################################################
# Vérifie la présence d'au moins un champ à extraire
############################################################
$CHKEMPTY
Local Integer ITEREMP
Local Integer ISAVEOK

  ISAVEOK = OK
  OK = 0
  For ITEREMP = 0 To [M:MXL1]NBLIG-1
    If [M:MXL1]LBEXML(ITEREMP) <> "" Then
      OK = ISAVEOK
      Break
    Endif
  Next
  If OK = 0 Then
    #Le paramétrage d'un publipostage requiert au minimum un champ d'extraction.
    GMESSAGE = mess(655,182,1)
    GERR = 2
  Endif
Return

##########################################################################################################
# Supprime les éventuels caractères de doublonnage résiduels.
############################################################
$CLEANSTAR
Local Integer ITERCLEAN

  For ITERCLEAN = 0 To [M:MXL1]NBLIG-1
    If [M:MXL1]LBEXML(ITERCLEAN) <> "" Then
      If left$([M:MXL1]LBEXML(ITERCLEAN), 2) = "**"
        [M:MXL1]LBEXML(ITERCLEAN) = [M:MXL1]FIE(ITERCLEAN)
      Endif
    Endif
  Next
Return

##########################################################################################################
# Création de la version standard du publipostage MAILBPR
#######################################################################
Subprog CREMAILBPR(IERRINF)
Variable Integer IERRINF

Local Integer ISTR
Local Integer ILOOPSECURE
Local Char SZ1(250)
Local Char SZ2(250)
Local Char SZ3(250)
Local Char SZ4(250)
Local Integer ITERATZ
Local Integer ITERWHILE
Local Integer ITERDIM
Local Char SZTAB(GLONATB)
Local Char SZABRFIC(GLONABR)
Local Integer IFIEDIM
Local Integer ITAKEFIELD

  If !clalev([F:MXL]) : Local File MAILXML [MXL] : Endif
  If !clalev([F:MXD]) : Local File MAILXMLD [MXD] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:REP]) : Local File SALESREP [REP] : Endif
  IERRINF = 0
  ILOOPSECURE = 0
  ISTR = 0
  SZ1 = ""
  SZ2 = ""
  SZ3 = ""
  SZ4 = ""
  ITERATZ = 0
  ITEWHILE = 0
  SZTAB = ""
  IFIEDIM = 0
  ITERDIM = 0
  SZABRFIC = ""
  ITAKEFIELD = 0
  Call DEBTRANS From GLOCK
  Trbegin [MXL], [MXD]
  Delete [MXL] Where [F:MXL]NUM = "MAILBPR"
  If fstat Then
    IERRINF = 666
    Rollback
    End
  Endif
  Delete [MXD] Where [F:MXD]NUM = "MAILBPR"
  If fstat Then
    IERRINF = 666
    Rollback
    End
  Endif
  Commit
  Call DEBTRANS From GLOCK
  Trbegin [MXL], [MXD]
  #En-tête
  Raz [F:MXL]
  [F:MXL]NUM = "MAILBPR"
  [F:MXL]TYP = 1
  [F:MXL]ROT = "BPARTNER"
  [F:MXL]SRT = "SRT"
  [F:MXL]TTR = "TTR"
  [F:MXL]REPFNCFLG = 2
  [F:MXL]CREDAT = date$
  [F:MXL]CREUSR = GUSER
  Write [MXL]
  If fstat Then
    IERRINF = 666
    Rollback
    End
  Endif
  #Paramétrage
  While 1
    If ITERWHILE = 0 Then
      SZTAB = "BPADDRESS"
      SZABRFIC = "BPA"
    Elsif ITERWHILE = 1 Then
      SZTAB = "BPARTNER"
      SZABRFIC = "BPR"
    Elsif ITERWHILE = 2 Then
      SZTAB = "BPCUSTOMER"
      SZABRFIC = "BPC"
    Elsif ITERWHILE = 3 Then
      SZTAB = "SALESREP"
      SZABRFIC = "REP"
    Elsif ITERWHILE = 4 Then
      Break
    Endif
    Filter [ATZ] Where [F:ATZ]CODFIC = SZTAB
    For [ATZ]CODZONE
      IFIEDIM = evalue("Dim([F:" + SZABRFIC + "]" + [F:ATZ]CODZONE + ")")
      IFIEDIM -= 1
      Gosub CHKBPRFIELD
      For ITERDIM = 0 To IFIEDIM
        ILOOPSECURE = 0
        Raz [F:MXD]
        [F:MXD]NUM = "MAILBPR"
        [F:MXD]TAB = SZTAB
        If ITERDIM = 0 Then
          [F:MXD]FIE = [F:ATZ]CODZONE
        Else
          [F:MXD]FIE = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
        Endif
        If ITAKEFIELD Then
          [F:MXD]LBEXML = [F:MXD]FIE
          #On enlève les parenthèses
          While instr(1, [F:MXD]LBEXML, "(")
            ISTR = instr(1, [F:MXD]LBEXML, "(")
            SZ1 = left$([F:MXD]LBEXML, ISTR - len("("))
            SZ2 = right$([F:MXD]LBEXML, ISTR + 1)
            SZ3 = SZ1 + SZ2
            [F:MXD]LBEXML = SZ3
            ILOOPSECURE += 1
            If ILOOPSECURE > 10000 Then
              Break
            Endif
          Wend
          ISTR = 0
          SZ1 = ""
          SZ2 = ""
          SZ3 = ""
          While instr(1, [F:MXD]LBEXML, ")")
            ISTR = instr(1, [F:MXD]LBEXML, ")")
            SZ1 = left$([F:MXD]LBEXML, ISTR - len(")"))
            SZ2 = right$([F:MXD]LBEXML, ISTR + 1)
            SZ3 = SZ1 + ' ' + SZ2
            [F:MXD]LBEXML = SZ3
            ILOOPSECURE += 1
            If ILOOPSECURE > 20000 Then
              Break
            Endif
          Wend
          SZ4 = [F:MXD]LBEXML
          [F:MXD]LBEXML = vireblc(SZ4, 4)
        Else
          [F:MXD]LBEXML = ""
        Endif
        Write [MXD]
        If fstat Then
          IERRINF = 666
          Break
        Endif
      Next
      If IERRINF Then
        Break
      Endif
    Next
    Filter [ATZ]
    ITERWHILE += 1
    If IERRINF Then
      Break
    Endif
  Wend
  If IERRINF Then
    Rollback
  Else
    Commit
  Endif
End

##########################################################################################################
# Définition des champs standards
###################################################
$CHKBPRFIELD
  ITAKEFIELD = 0
  If SZTAB = "BPADDRESS" Then
    #Adresse
    If [F:ATZ]CODZONE = "BPAADDLIG" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "CRY" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "CRYNAM" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "CTY" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "FAX" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "POSCOD" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "SAT" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "TEL" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "WEB" Then
      ITAKEFIELD = 1
    Endif
  Elsif SZTAB = "BPARTNER" Then
    #Tiers
    If [F:ATZ]CODZONE = "BPRNAM" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "BPRNUM" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "NAF" Then
      ITAKEFIELD = 1
    Endif
  Elsif SZTAB = "BPCUSTOMER" Then
  #Client
    If [F:ATZ]CODZONE = "BUS" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "ORIPPT" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "REP" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "SALFCY" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "TSCCOD" Then
      ITAKEFIELD = 1
    Endif
  Elsif SZTAB = "SALESREP" Then
    #Représentant
    If [F:ATZ]CODZONE = "REPNUM" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "REPNAM" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "REP" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "AUSNUM" Then
      ITAKEFIELD = 1
    Endif
  Endif
Return

##########################################################################################################
# Création de la version standard du publipostage MAILCCN
#######################################################################
Subprog CREMAILCCN(IERRINF)
Variable Integer IERRINF

Local Integer ISTR
Local Integer ILOOPSECURE
Local Char SZ1(250)
Local Char SZ2(250)
Local Char SZ3(250)
Local Char SZ4(250)
Local Char SZMXDFIE(250)
Local Char SZATZCODZONE(250)
Local Integer ITERATZ
Local Integer ITERWHILE
Local Integer ITERDIM
Local Char SZTAB(GLONATB)
Local Char SZABRFIC(GLONABR)
Local Integer IFIEDIM
Local Integer ITAKEFIELD

  If !clalev([F:MXL]) : Local File MAILXML [MXL] : Endif
  If !clalev([F:MXD]) : Local File MAILXMLD [MXD] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif
  If !clalev([F:REP]) : Local File SALESREP [REP] : Endif
  IERRINF = 0
  ILOOPSECURE = 0
  ISTR = 0
  SZ1 = ""
  SZ2 = ""
  SZ3 = ""
  SZ4 = ""
  ITERATZ = 0
  ITEWHILE = 0
  SZTAB = ""
  IFIEDIM = 0
  ITERDIM = 0
  SZABRFIC = ""
  ITAKEFIELD = 0
  SZATZCODZONE = ""
  SZMXDFIE = ""
  Call DEBTRANS From GLOCK
  Trbegin [MXL], [MXD]
  Delete [MXL] Where [F:MXL]NUM = "MAILCCN"
  If fstat Then
    IERRINF = 667
    Rollback
    End
  Endif
  Delete [MXD] Where [F:MXD]NUM = "MAILCCN"
  If fstat Then
    IERRINF = 667
    Rollback
    End
  Endif
  Commit
  Call DEBTRANS From GLOCK
  Trbegin [MXL], [MXD]
  #En-tête
  Raz [F:MXL]
  [F:MXL]NUM = "MAILCCN"
  [F:MXL]TYP = 2
  [F:MXL]ROT = "CONTACTCRM"
  [F:MXL]SRT = "SRT"
  [F:MXL]TTR = ""
  [F:MXL]REPFNCFLG = 2
  [F:MXL]CREDAT = date$
  [F:MXL]CREUSR = GUSER
  Write [MXL]
  If fstat Then
    IERRINF = 667
    Rollback
    End
  Endif
  #Paramétrage
  While 1
    If ITERWHILE = 0 Then
      SZTAB = "BPADDRESS"
      SZABRFIC = "BPA"
    Elsif ITERWHILE = 1 Then
      SZTAB = "BPARTNER"
      SZABRFIC = "BPR"
    Elsif ITERWHILE = 2 Then
      SZTAB = "BPCUSTOMER"
      SZABRFIC = "BPC"
    Elsif ITERWHILE = 3 Then
      SZTAB = "CONTACT"
      SZABRFIC = "CNT"
    Elsif ITERWHILE = 4 Then
      SZTAB = "CONTACTCRM"
      SZABRFIC = "AIN"
    Elsif ITERWHILE = 5 Then
      SZTAB = "SALESREP"
      SZABRFIC = "REP"
    Elsif ITERWHILE = 6 Then
      Break
    Endif
    Filter [ATZ] Where [F:ATZ]CODFIC = SZTAB
    For [ATZ]CODZONE
      SZATZCODZONE = ""
      IFIEDIM = evalue("Dim([F:" + SZABRFIC + "]" + [F:ATZ]CODZONE + ")")
      IFIEDIM -= 1
      Gosub CHKBPRFIELD
      Gosub CHKCCNFIELD
      For ITERDIM = 0 To IFIEDIM
        ILOOPSECURE = 0
        Raz [F:MXD]
        [F:MXD]NUM = "MAILCCN"
        [F:MXD]TAB = SZTAB
        If SZATZCODZONE = "" Then
          If ITERDIM = 0 Then
            [F:MXD]FIE = [F:ATZ]CODZONE
          Else
            [F:MXD]FIE = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
          Endif
        Else
          If ITERDIM = 0 Then
            [F:MXD]FIE = [F:ATZ]CODZONE
            SZMXDFIE = SZATZCODZONE
          Else
            [F:MXD]FIE = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
            SZMXDFIE = SZATZCODZONE + "(" + num$(ITERDIM) + ")"
          Endif
        Endif
        If ITAKEFIELD Then
          If SZATZCODZONE = "" Then
            [F:MXD]LBEXML = [F:MXD]FIE
          Else
            [F:MXD]LBEXML = SZMXDFIE
          Endif
          #On enlève les parenthèses
          While instr(1, [F:MXD]LBEXML, "(")
            ISTR = instr(1, [F:MXD]LBEXML, "(")
            SZ1 = left$([F:MXD]LBEXML, ISTR - len("("))
            SZ2 = right$([F:MXD]LBEXML, ISTR + 1)
            SZ3 = SZ1 + SZ2
            [F:MXD]LBEXML = SZ3
            ILOOPSECURE += 1
            If ILOOPSECURE > 10000 Then
              Break
            Endif
          Wend
          ISTR = 0
          SZ1 = ""
          SZ2 = ""
          SZ3 = ""
          While instr(1, [F:MXD]LBEXML, ")")
            ISTR = instr(1, [F:MXD]LBEXML, ")")
            SZ1 = left$([F:MXD]LBEXML, ISTR - len(")"))
            SZ2 = right$([F:MXD]LBEXML, ISTR + 1)
            SZ3 = SZ1 - SZ2
            [F:MXD]LBEXML = SZ3
            ILOOPSECURE += 1
            If ILOOPSECURE > 20000 Then
              Break
            Endif
          Wend
          SZ4 = [F:MXD]LBEXML
          [F:MXD]LBEXML = vireblc(SZ4, 4)
        Else
          [F:MXD]LBEXML = ""
        Endif
        Write [MXD]
        If fstat Then
          IERRINF = 667
          Break
        Endif
      Next
      If IERRINF Then
        Break
      Endif
    Next
    Filter [ATZ]
    ITERWHILE += 1
    If IERRINF Then
      Break
    Endif
  Wend
  If IERRINF Then
    Rollback
  Else
    Commit
  Endif
End

##########################################################################################################
# Définition des champs standards
###################################################
$CHKCCNFIELD
  If ITAKEFIELD Then
    Return
  Endif
  If SZTAB = "CONTACT" Then
    #Contact
    If [F:ATZ]CODZONE = "CNTFNC" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "CNTMSS" Then
      ITAKEFIELD = 1
    Endif
  Elsif SZTAB = "CONTACTCRM" Then
    #Interlocuteur
    If [F:ATZ]CODZONE = "ADD" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "CNTBIR" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "CNTCSP" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "CNTEMA" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "CNTETS" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "CNTFAX" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "CNTFNA" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "CNTFULNAM" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "CNTLAN" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "CNTLNA" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "CNTMOB" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "CNTNUM" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "CNTTTL" Then
      ITAKEFIELD = 1
    Elsif [F:ATZ]CODZONE = "CRY" Then
      ITAKEFIELD = 1
      SZATZCODZONE = "AINCRY"
    Elsif [F:ATZ]CODZONE = "CTY" Then
      ITAKEFIELD = 1
      SZATZCODZONE = "AINCTY"
    Elsif [F:ATZ]CODZONE = "SAT" Then
      ITAKEFIELD = 1
      SZATZCODZONE = "AINSAT"
    Elsif [F:ATZ]CODZONE = "ZIP" Then
      ITAKEFIELD = 1
    Endif
  Endif
Return
