#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* This Function is working on Fusion Session Client AND Syracuse session client
#* It permit to add document to Syracuse Storage Area.
#* See : https://github.com/Sage-ERP-X3/Syracuse/blob/master/node_modules/syracuse-orm/lib/storageArea.md
#*
#* @param BLOBDOC : Blbfile : The BLOB Document is encoded in base64 before to be send to Syracuse
#* @param DESCRIPTION : Char : Description used to upload Document
#* @param FILE_NAME : Char : The file name corresponding to the uploaded document
#* @param CONTENT_TYPE : Char : The content type corresponding to the uploaded document
#* @param PROPS_COD : Array of Char : Additional properties name that can be assigned to the document.
#* @param PROPS_VAL : Array of Char : Additional properties values corresponding to properties name.
#* @param ID : Clbfile : The uuid of the document to erase. Create new document if doesn't exist
#* @param VOLUME : Char : The name of the volume where a new document will be stored. 'STD' by default.
#* @param FUTURE : Integer : 1 to be called in 'future' mode or 0 for the 'wait' mode.
#*
#* @param RESHEAD : Clbfile : The response header
#* @param RESBODY : Clbfile : Document Descriptor UUID or 'null' if document was not found.
#* @return STATUSCODE : Integer : The status code return by the javascript runner module.
#*!
Funprog WRITEALL(BLOBDOC, DESCRIPTION, FILE_NAME, CONTENT_TYPE, PROPS_COD, PROPS_VAL, ID, VOLUME, FUTURE, RESHEAD, RESBODY)
Value Blbfile BLOBDOC()
Value Char DESCRIPTION()
Value Char FILE_NAME()
Value Char CONTENT_TYPE()
Variable Char ID()
Value Char PROPS_COD()(1..)
Value Char PROPS_VAL()(1..)
Value Char VOLUME()
Value Integer FUTURE
Variable Clbfile RESHEAD()
Variable Clbfile RESBODY()

Local Char MODULE(100) : MODULE = 'syracuse-orm/lib/storageArea'
Local Char FONCTION(30) : FONCTION = 'writeAll'
Local Char MODE(10)
If (FUTURE = 1) : MODE = 'future' : Else : MODE = 'wait' : Endif
Local Char ENCODINGS(40) : ENCODINGS = '0,1,0,0'
Local Char RETURNS(50) : RETURNS = '$uuid'

Local Clbfile OPTIONAL_PROPS(0)
Call STRINGIFY_PROPS(PROPS_COD, PROPS_VAL, OPTIONAL_PROPS) From ASYRJSUTILS

Local Clbfile PROPS(2)
PROPS = '{"description": "' + escJson(DESCRIPTION) + '","content": {"contentType": "' + CONTENT_TYPE + '","fileName": "' + FILE_NAME + '"}'

If (len(OPTIONAL_PROPS) > 0)
Append PROPS, "," + OPTIONAL_PROPS
Endif
Append PROPS, '}'
Local Char FILTE(250) : FILTE = 'null'
If (len(ID) > 0)
  FILTE = '{"jsonWhere":{ "$uuid": "'+ID+'"}}'
Endif
Local Clbfile CLB(8)
Local Integer COUNT
COUNT = b64Encode(BLOBDOC, CLB)
Local Clbfile ARGUMENTS(0)
ARGUMENTS = PROPS + ', "' + CLB + '",' + FILTE + ', "' + VOLUME + '"'
Local Integer STATUSCODE
# Call 'writeAll' function
STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, ENCODINGS, 0, RETURNS, '', RESHEAD, RESBODY)
ID = RESBODY
End STATUSCODE

#**
#* This Function is working on Fusion Session Client AND Syracuse session client
#* It permit to get document from Syracuse Storage Area.
#* See : https://github.com/Sage-ERP-X3/Syracuse/blob/master/node_modules/syracuse-orm/lib/storageArea.md
#*
#* @param ID : Char : The document's uuid.
#* @param FUTURE : Integer : 1 to be called in 'future' mode or 0 for the 'wait' mode.
#*
#* @param RESHEAD : Clbfile : The response header
#* @param BLOBDOC : Blbfile : The document as Blob
#* @return STATUSCODE : Integer : The status code return by the javascript runner module.
#*!
Funprog READALL(ID, FUTURE, RESHEAD, BLOBDOC)
Value Char ID()
Value Integer FUTURE
Variable Clbfile RESHEAD()
Variable Blbfile BLOBDOC()

Local Char MODULE(100) : MODULE = 'syracuse-orm/lib/storageArea'
Local Char FONCTION(30) : FONCTION = 'readAll'
Local Char MODE(10)
If (FUTURE = 1) : MODE = 'future' : Else : MODE = 'wait' : Endif
Local Char RETURNS_ENC(3) : RETURNS_ENC = '1'
Local Clbfile ARGUMENTS(1) : ARGUMENTS = '{"jsonWhere":{ "$uuid": "'+ID+'"}}'
Clbfile B64BODY(8)
Local Integer STATUSCODE
# Call 'readAll' function
STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, '', 0, '', RETURNS_ENC, RESHEAD, B64BODY)
If (len(B64BODY) <> 0)
  Local Integer COUNT
  COUNT = b64Decode(B64BODY, BLOBDOC)
Endif
End STATUSCODE

#**
#* This Function is working on Fusion Session Client AND Syracuse session client
#* It permit to open or create a document into Syracuse Storage Area.
#* See : https://github.com/Sage-ERP-X3/Syracuse/blob/master/node_modules/syracuse-orm/lib/storageArea.md
#*
#* @param ID : Char : The document's uuid. Can be '' to create a new document
#* @param VOLUME : Char : The volume where store the document if it's a new document. 'STD' by default.
#* @param RECORDSEP : Char : Defines the records delimiters to add after each WRITESEQ calls. This delimiter is also used by the READSEQ function to retrieve only the wanted part of the document.
#* @param FUTURE : Integer : 1 to be called in 'future' mode or 0 for the 'wait' mode.
#*
#* @param RESHEAD : Clbfile : The response header
#* @param DOCID : Clbfile : Document Descriptor UUID or 'null' if document was not found.
#* @return STATUSCODE : Integer : The status code return by the javascript runner module.
#*!
Funprog OPENDOC(ID, VOLUME, RECORDSEP, FUTURE, RESHEAD, RESBODY)
Variable Char ID()
Value Char VOLUME()
Value Char RECORDSEP()
Value Integer FUTURE
Variable Clbfile RESHEAD
Variable Clbfile RESBODY

Local Integer STATUSCODE
Local Char MODULE(100) : MODULE = 'syracuse-orm/lib/storageArea'
Local Char FONCTION(30) : FONCTION = 'open'
Local Char MODE(10)
If (FUTURE = 1) : MODE = 'future' : Else : MODE = 'wait' : Endif
Local Clbfile FILTE : FILTE = 'null'
If (len(ID) > 0)
  FILTE = '{"jsonWhere":{ "$uuid": "'+ID+'"}}'
Endif
Local Clbfile PROPS
PROPS = '{"volume": "'+VOLUME+'", "recordSep": "'+RECORDSEP+'"}'
Local Clbfile ARGUMENTS
ARGUMENTS = FILTE + ',' + PROPS
# Call 'open' function

STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, '', 0, '', '', RESHEAD, RESBODY)
ID = RESBODY
End STATUSCODE

#**
#* This Function is working on Fusion Session Client AND Syracuse session client
#* Close the document store and persist the content in datastore.
#* IMPORTANT : this FUNCTION MUST BE CALLED AFTER `OPENDOC` FUNCTION !!!!
#* See : https://github.com/Sage-ERP-X3/Syracuse/blob/master/node_modules/syracuse-orm/lib/storageArea.md
#*
#* @param ID : Clbfile : The document's uuid.
#* @param FUTURE : Integer : 1 to be called in 'future' mode or 0 for the 'wait' mode.
#*
#* @param RESHEAD : Clbfile : The response header
#* @param DOCID : Clbfile : Document Descriptor UUID or 'null' if document was not found.
#* @return STATUSCODE : Integer : The status code return by the javascript runner module.
#*!
Funprog CLOSEDOC(ID, FUTURE, RESHEAD, RESBODY)
Variable Char ID()
Value Integer FUTURE
Variable Clbfile RESHEAD()
Variable Clbfile RESBODY()

Local Integer STATUSCODE
Local Char MODULE(100) : MODULE = 'syracuse-orm/lib/storageArea'
Local Char FONCTION(30) : FONCTION = 'close'
Local Char MODE(10)
If (FUTURE = 1) : MODE = 'future' : Else : MODE = 'wait' : Endif
Local Clbfile ARGUMENTS(0)
ARGUMENTS = '"' + ID + '", true'
Local Char RETURNS(50) : RETURNS = '$uuid'
# Call 'close' function

STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, '', 0, RETURNS, '', RESHEAD, RESBODY)
ID = RESBODY
End STATUSCODE

#**
#* This Function is working on Fusion Session Client AND Syracuse session client
#* It permit to read partial content of document instance.
#* See : https://github.com/Sage-ERP-X3/Syracuse/blob/master/node_modules/syracuse-orm/lib/storageArea.md
#*
#* this function CAN be called between `OPENDOC` and `CLOSEDOC` functions.
#*
#* @param ID : Clbfile : The document's uuid.
#* @param SIZE : The length to read. If not valued, will read until the next delimiter records defined by the OPENDOC function.
#* @param FUTURE : Integer : 1 to be called in 'future' mode or 0 for the 'wait' mode.
#*
#* @param RESHEAD : Clbfile : The response header
#* @param TXT : Clbfile : Document Descriptor UUID or 'null' if document was not found.
#* @return STATUSCODE : Integer : The status code return by the javascript runner module.
#*!
Funprog READSEQ(ID, SIZE, FUTURE, RESHEAD, TXT)
Value Char ID()
Value Integer SIZE
Value Integer FUTURE
Variable Clbfile RESHEAD()
Variable Clbfile TXT()

Local Integer STATUSCODE
Local Char MODULE(100) : MODULE = 'syracuse-orm/lib/storageArea'
Local Char FONCTION(30) : FONCTION = 'read'
Local Char MODE(10)
If (FUTURE = 1) : MODE = 'future' : Else : MODE = 'wait' : Endif
Local Clbfile ARGUMENTS(0)
ARGUMENTS = '"' + ID + '",' + num$(SIZE)
# Call 'read' function
STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, '', 0, '', '', RESHEAD, TXT)
End STATUSCODE

#**
#* This Function is working on Fusion Session Client AND Syracuse session client
#* It permit to add or erase document into Syracuse Storage Area.
#* See : https://github.com/Sage-ERP-X3/Syracuse/blob/master/node_modules/syracuse-orm/lib/storageArea.md
#*
#* @param ID : Clbfile : The document's uuid.
#* @param TXT : Blbfile : The text to append in the document.
#* @param DESCRIPTION : Char : Description used to upload Document
#* @param FILE_NAME : Char : The file name corresponding to the uploaded document
#* @param PROPS_COD : Array of Char : Additional properties name that can be assigned to the document.
#* @param PROPS_VAL : Array of Char : Additional properties values corresponding to properties name.
#* @param FUTURE : Integer : 1 to be called in 'future' mode or 0 for the 'wait' mode.
#*
#* @param RESHEAD : Clbfile : The response header
#* @return STATUSCODE : Integer : The status code return by the javascript runner module.
#*!
Funprog WRITESEQ(ID, TXT, DESCRIPTION, FILE_NAME, PROPS_COD, PROPS_VAL, FUTURE, RESHEAD)
Value Char ID()
Value Clbfile TXT()
Value Char DESCRIPTION()
Value Char FILE_NAME()
Value Char PROPS_COD()(1..)
Value Char PROPS_VAL()(1..)
Value Integer FUTURE
Variable Clbfile RESHEAD()

Local Integer STATUSCODE
Local Char MODULE(100) : MODULE = 'syracuse-orm/lib/storageArea'
Local Char FONCTION(30) : FONCTION = 'write'
Local Char MODE(10)
If (FUTURE = 1) : MODE = 'future' : Else : MODE = 'wait' : Endif

Local Clbfile OPTIONAL_PROPS(0)
Call STRINGIFY_PROPS(PROPS_COD, PROPS_VAL, OPTIONAL_PROPS) From ASYRJSUTILS

Local Clbfile PROPS(2)
PROPS = '{"description": "'+ DESCRIPTION + '","content": {"contentType": "plain/text","fileName": "' + FILE_NAME + '"}'

If (len(OPTIONAL_PROPS) > 0)
Append PROPS, "," + OPTIONAL_PROPS
Endif
Append PROPS, '}'

Local Clbfile ARGUMENTS(0)
ARGUMENTS = '"' + ID + '",' + PROPS + ',"'+TXT+'"'
Local Clbfile RESBODY(0)
# Call 'write' function
STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, '', 0, '', '', RESHEAD, RESBODY)
End STATUSCODE

#**
#* This Function is working on Fusion Session Client AND Syracuse session client
#* It permit to remove document from Syracuse Storage Area.
#*
#* @param ID : Clbfile : The document's uuid.
#* @param FUTURE : Integer : 1 to be called in 'future' mode or 0 for the 'wait' mode.
#*
#* @param RESHEAD : Clbfile : The response header
#* @param RES : Integer : Must be 1 if all goes well.
#* @return STATUSCODE : Integer : The status code return by the javascript runner module.
#*!
Funprog REMOVE(ID, FUTURE, RESHEAD, RES)
Value Char ID()
Value Integer FUTURE
Variable Clbfile RESHEAD()
Variable Integer RES()

Local Clbfile RESBODY(0)
Local Integer STATUSCODE
Local Char MODULE(100) : MODULE = 'syracuse-orm/lib/storageArea'
Local Char FONCTION(30) : FONCTION = 'remove'
Local Char MODE(10)
If (FUTURE = 1) : MODE = 'future' : Else : MODE = 'wait' : Endif
Local Clbfile ARGUMENTS(0) : ARGUMENTS = 'null'
If (len(ID) > 0)
  ARGUMENTS = '{"jsonWhere":{ "$uuid": "'+ID+'"}}'
Endif
# Call 'remove' function
STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, '', 0, '', '', RESHEAD, RESBODY)
RES = val(RESBODY)
End STATUSCODE

#**
#* This Function is working on Fusion Session Client AND Syracuse session client
#* It permit to fetch document from Syracuse Storage Area.
#*
#* @param FILTERS : Char : Allow to add some properties filters with sdata filter syntax.
#* @param EXPECTED_PROPS : Array of Char : Defines what properties would be returned in VALUES array.
#* @param FUTURE : Integer : 1 to be called in 'future' mode or 0 for the 'wait' mode.
#*
#* @param RESHEAD : Clbfile : The response header
#* @param VALUES : Array of Array of Char :
#* @return STATUSCODE : Integer : The status code return by the javascript runner module.
#*!
Funprog LIST(FILTERS, EXPECTED_PROPS, FUTURE, RESHEAD, VALUES)
Value Clbfile FILTERS()
Value Char EXPECTED_PROPS()(1..)

Value Integer FUTURE
Variable Clbfile RESHEAD()
Variable Char VALUES()(1.., 1..)

Local Clbfile RESBODY(0)
Local Integer STATUSCODE
Local Char MODULE(100) : MODULE = 'syracuse-orm/lib/storageArea'
Local Char FONCTION(30) : FONCTION = 'listDocuments'
Local Char MODE(10)
If (FUTURE = 1) : MODE = 'future' : Else : MODE = 'wait' : Endif


If (len(FILTERS) > 0)
  FILTERS = '{"sdataWhere":"'+FILTERS+'"}'
Else
  FILTERS = 'null'
Endif

Local Clbfile EXPECTED(0) : EXPECTED = "["
If (dim(EXPECTED_PROPS) > 0)
  Local Integer I
  Local Char SEP(2)
  SEP = ""
  For I=1 To maxtab(EXPECTED_PROPS)
   If (len(EXPECTED_PROPS(I)) > 0)
      Append EXPECTED, SEP+'"' + EXPECTED_PROPS(I) + '"'
      SEP = ","
   Endif
  Next I
Endif
Append EXPECTED, ']'

Local Clbfile ARGUMENTS(0)
ARGUMENTS = FILTERS + ', true, ' + EXPECTED

Local Clbfile RESBODY(0)
STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, '', 0, '', '', RESHEAD, RESBODY)

Local Instance  NODES(1..) Using C_ASYRJSO
Local Instance  NODE  Using C_ASYRJSO

Local Integer ERR
ERR = func ASYRJSONPARSE.PARSEJSON(GACTX,RESBODY,NODES,NODE)

Local Instance CUR  Using C_ASYRJSO
Local Clbfile CURCNT
Local Integer I : I = 1
Local Integer J : J = 1
While dim(NODE.NEX) <> -1
  CUR = NODE.SUB
  While dim(CUR.PRO) <> -1
    CURCNT = fmet CUR.AGETCNT
    If (left$(CURCNT,1) = '"')
      VALUES(I, J) = seg$(CURCNT, 2, len(CURCNT)-1)
    Else
      VALUES(I, J) = CURCNT
    Endif
    CUR = CUR.NEX
    J = J + 1
  Wend
  NODE = NODE.NEX
  I = I + 1
  J = 1
Wend

FreeGroup NODES(1)

End STATUSCODE
