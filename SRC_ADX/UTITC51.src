#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################################################
# UTITC51                                                  Module Tronc commun                        #
# Suppression des paramètres obsolètes WORDPATH                                                       #
########################################################################################################

Local Char APPLI(30) : APPLI = nomap
Call SAIDOS(APPLI,"") From SAIDOS
If APPLI <> ""
 If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
 Read [ADS]DOSSIER=[L]APPLI : If fstat Raz [F:ADS] : Endif

 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTITC51: WORDPATH parameter deletion") From LECFIC

 Call MAJ_UTITC51(APPLI)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End

########################################################################
Subprog MAJ_UTITC51(APPLI)
Value Char APPLI
Local Char PARNAM(250)
Local Integer STAT, N

  Call ECR_TRACE("UUTITC51: Process Start on: "+APPLI,0) From GESECRAN
  Local File =APPLI+".ADOPAR"    [ADP]
  Local File =APPLI+".ADOVAL"    [ADW]
  Local File =APPLI+".AGLOBVAR"  [AGB]
  #
  Trbegin [ADP]
  [L]PARNAM = "WORDPATH"
  Read [ADP]ADP0="CRM";[L]PARNAM
  If !fstat
    Delete [ADP]Curr
    If fstat Then
      # Erreur d'effacement
      GOK = 0 : Call ECR_TRACE(mess(28,125,1)-"ADOPAR : "+[L]PARNAM,-1) From GESECRAN : Goto AB_UUTITC51
    Else
      # Suppression enregistrements
      Call ECR_TRACE(mess(499,196,1)-"ADOPAR : "+"CRM"-[L]PARNAM,0) From GESECRAN
      For [ADW] Where PARAM=[L]PARNAM
        Delete [ADW]Curr
        # Suppression
        Call ECR_TRACE(mess(53,123,1)-[F:ADW]CMP-[F:ADW]FCY-[F:ADW]PARAM, 0) From GESECRAN
      Next
      #
      Read [AGB]AGB0="GWORDPATH"
      If !fstat Then
        Delete [AGB]Curr
        If fstat Then
          # Erreur d'effacement
          GOK = 0 : Call ECR_TRACE(mess(28,125,1)-"AGLOBVAR : GWORDPATH",-1) From GESECRAN : Goto AB_UUTITC51
        Else
          # Suppression enregistrements
          Call ECR_TRACE(mess(499,196,1)-"AGLOBVAR : GWORDPATH",0) From GESECRAN
        Endif
      Endif
    Endif
  Endif
  Commit
  Call ECR_TRACE("UUTITC51: Process End on: "+APPLI,0) From GESECRAN
End

$AB_UUTITC51
  Rollback
End

########################################################################
# Pour exécution automatique en gestion de patch                       #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  # test de présence du module Tiers
  If [F:ADS]MODULE(2)<>2 : End : Endif
  Call MAJ_UTITC51(APPLI)
End

########################################################################
# Pour exécution depuis dosmaj (validation dossier)                    #
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  # test de présence du module Tiers
  If [F:ADS]MODULE(2)<>2 : End : Endif
  Call MAJ_UTITC51(APPLI)
End
