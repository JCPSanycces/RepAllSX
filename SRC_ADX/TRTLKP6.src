#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################################################
#   Recherche d'un tiers                                             Module CRM         27 février 2001 #
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When "AVANT_OK"     : Gosub AVANT_OK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  If !clalev([F:RSE]) : Local File REPSEC [RSE] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif

  If PARAM(1) = "" Then
    #Aucun code client n'a été communiqué. Accès refusé.
    GMESSAGE = mess(697,182,1)
    GERR = 1
    FIN = 1
  Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  ETABOU(GSPE1) = 1
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Local Integer I
Local Integer IADINUM

  IADINUM = 19 + GFAMCIA
  [M:LKP6]BPC = PARAM(1)
  Raz [M:LKP6]NBREP
  Raz [M:LKP6]NBREPSEL
  Raz [M:LKP6]MAIREP
  Raz [M:LKP6]NBSEC
  Raz [M:LKP6]NBSECSEL
  Raz [M:LKP6]SECREP
  Raz [M:LKP6]MSS
  Raz [M:LKP6]GRPITM
  #Représentants secondaires
  Read [BPC] BPC0 = [M:LKP6]BPC
  If !fstat Then
    For I = 0 To dim([F:BPC]REP)-1
      If [F:BPC]REP(I) <> "" Then
        If [M:LKP6]NBREP = 0 Then
          [M:LKP6]NBREPSEL(0) = "->"
          [M:LKP6]SELREP = [F:BPC]REP(I)
        Endif
        [M:LKP6]MAIREP([M:LKP6]NBREP) = [F:BPC]REP(I)
        [M:LKP6]NBREP += 1
      Endif
    Next
  Endif
  #Représentants secondaires
  I = 0
  Filter [RSE] Where [F:RSE]BPCNUM = [M:LKP6]BPC
  For [RSE]
    [M:LKP6]SECREP(I) = [F:RSE]REPNUM
    [M:LKP6]MSS(I) = [F:RSE]MSS
    [M:LKP6]GRPITM(I) = [F:RSE]GRPITM
    I += 1
  Next
  Filter [RSE]
  [M:LKP6]NBSEC = I
  Affzo [M:LKP6]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:LKP6]
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  If BOUT = "1" Then
    Gosub ONOK
  Endif
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$AVANT_OK
Return

##########################################################################################################
$ONOK
  VALEUR = [M:LKP6]SELREP
  mkstat = 4
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESBAP" Then
      Affzo [M:BAP2]1-99
    Elsif GNAVIG(GPILNAV-1) = "GESCLL" Then
      Affzo [M:CLL1]1-99
    Elsif GNAVIG(GPILNAV-1) = "GESTSK" Then
      Affzo [M:TSK1]1-99
    Elsif GNAVIG(GPILNAV-1) = "GESOPP" Then
      Affzo [M:OPP1]1-99
    Elsif GNAVIG(GPILNAV-1) = "GESCON" Then
      Affzo [M:CON1]1-99
    Endif
  Endif
  FIN = 1
Return
