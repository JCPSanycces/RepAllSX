#<AdxTL>@(#)10.0.0.0 $Revision$
#######################################################################
#                                                                     #
#    TRAITEMENTS de SAISIE ou VISU en FENETRE dans les VENTES         #
#                                                                     #
#######################################################################
#                                                                     #
# ACTION MODELISATION E-COMMERCE : GACTION                            #
#---------------------------------------------------------------------#
#                                                                     #
# DIVADRBPC   : Positionnement bouton adresse saisie libre            #
#                                                                     #
# SAICEE      : Saisie des informations douanières                    #
# SAIADRBPC   : Saisie d'une adresse libre client                     #
#               si ADBFLG = 0 --> Aucune adresse chargée              #
#                           1 --> Adresse chargée mais non modifiée   #
#                           2 --> Adresse chargée et modifiée         #
#                           3 --> Adresse chargée avec fichier cde    #
#                                                                     #
# TRTADRBPC   : Traitement d'une adresse libre pour client divers     #
# TRTORDALL   : Allocation à la commande                              #
# TRTORDETA   : Visualisation de l'état de le commande                #
# TRTRPLITM   : Gestion des articles de remplacement                  #
#                                                                     #
# VISUDERLIV  : Visualisation des dernières livraisons                #
# VISUDERPRI  : Visualisation des derniers prix                       #
# VISUDETALL  : Visualisation du détail allocation                    #
# VISUDETLOT  : Visualisation du stock lot                            #
# VISUQTYSOQ  : Visualisation des quantité d'une ligne commande       #
# VISUSITSQH  : Visualisation de la situation devis                   #
# VISUVALLIG  : Visualisation valorisation ligne devis, cde, liv, fac #
# VISUDTAVAT  : Visualisation des taxes d'un élément de facturation   #
#                                                                     #
#######################################################################
# Issue 121186 - 20170317 by LD : Problème affichage en situation de commande

$ACTION
#--- Actions liés au type traitement et affichage divers
Case ACTION
 When "TRT_DIV"    : Gosub TRT_DIV
Endcase
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "TITRE"      : Gosub TIT
 When "SETBOUT"    : Gosub SETBOUT
 When "DEBUT"      : Gosub DEBUT
 When "OK"         : Gosub OK
 When "ABA"        : Gosub ABA
 When "APRES_MODIF": Gosub APRES_MODIF
 When "BOUTON"     : Gosub BOUTON
 When "FIN"        : Gosub FIN
Endcase
#--- Actions liés au type traitement standard
Case ACTION
 When "INIT"       : Gosub INIT
 When "CONTROLE"   : Gosub CONTROLE
 When "EXEC"       : Gosub EXEC
 When "TERMINE"    : Gosub TERMINE
Endcase
Return

#################################################################################
#    Actions liés au type traitement et affichage divers                        #
#################################################################################
# Allocation à la commande : TRTORDALL                                          #
# Il faut une action bidon pour activer les boutons allocation/désallocation    #
#################################################################################
$TRT_DIV
Case TRAIT
    When "DIVADRBPC"  :  GBOUT2 = mess(27,198,1) : # Bouton saisie adresse libre
    When "DIVORDALL"  : # Bouton allocation
Endcase
Return

#########################################################################
#    Actions liés au type fenêtre de saisie                             #
#########################################################################
$OUVRE
Case GACTION
 When "TRTORDALL"  : Gosub OUV_TRTORDALL
 When "TRTORDETA"  : Gosub OUV_TRTORDETA
 When "TRTRPLITM"  : Gosub OUV_TRTRPLITM
 When "VISUDERLIV" : Gosub OUV_VISUDERLIV
 When "VISUDERPRI" : Gosub OUV_VISUDERPRI
 When "VISUDETALL" : Gosub OUV_VISUDETALL
 When "VISUDETLOT" : Gosub OUV_VISUDETLOT
 When "VISUSITSQH" : Gosub OUV_VISUSITSQH
 When "VISUVALLIG" : Gosub OUV_VISUVALLIG
 When "VISUDTAVAT" : Gosub OUV_VISUDTAVAT
Endcase
Return

$TIT
If GACTION="SAIADRBPC"
Case PARAM(1)
    When "ADB1": TIT=mess(  8,195,1)
    When "ADB2": TIT=mess( 10,195,1)
    When "ADB3": TIT=mess(  9,195,1)
    When "ADI4": TIT=mess(296,195,1)
Endcase
Endif

Return

$SETBOUT
Case GACTION
 When "TRTORDALL"  : Gosub SETB_TRTORDALL
 When "TRTRPLITM"  : Gosub SETB_TRTRPLITM
 When "VISUDETALL" : Gosub SETB_VISUDETALL
Endcase
Return

$DEBUT
Case GACTION
 When "SAIADRBPC", "TRTADRBPC" :
                     Gosub DEB_SAIADRBPC
                     Affzo [M]1-99
 When "SAICEE"     : Gosub DEB_SAICEE
                     Affzo [M]1-99
 When "TRTORDALL"  : Gosub DEB_TRTORDALL
 When "TRTORDETA"  : Gosub DEB_TRTORDETA
                     Affzo [M]1-99
 When "TRTRPLITM"  : Gosub DEB_TRTRPLITM
 When "VISUDERLIV" : Gosub DEB_VISUDERLIV
                     Affzo [M]1-99
 When "VISUDERPRI" : Gosub DEB_VISUDERPRI
                     Affzo [M]1-99
 When "VISUDETALL" : Gosub DEB_VISUDETALL
                     Affzo [M]1-99
 When "VISUDETLOT" : Gosub DEB_VISUDETLOT
                     Affzo [M]1-99
 When "VISUQTYSOQ" : Gosub DEB_VISUQTYSOQ
 When "VISUSITSQH" : Gosub DEB_VISUSITSQH
                     Affzo [M]1-99
 When "VISUVALLIG" : Gosub DEB_VISUVALLIG
 When "VISUDTAVAT" : Gosub DEB_VISUDTAVAT
Endcase
Return

$OK
Case GACTION
 When "SAIADRBPC", "TRTADRBPC" :
                     #LTA.sn
                     # If func AFNC.ACTIV("LTA") and GLOCUSATAX and func TRTADRLIB.CHKADR_CRY([M:ADC]CRY) and dim([M:ADC]ADRVAL) > 0 and PARAM(1) = "ADB2" and [M:ADC]ADRVAL <> 2   # 106867.o
                     If func AFNC.ACTIV("LTA") and func TRTTAXSST.CHK_SSTTAXACT(GSOCIETE) and func TRTADRLIB.CHKADR_CRY([M:ADC]CRY) and dim([M:ADC]ADRVAL) > 0 and PARAM(1) = "ADB2" and [M:ADC]ADRVAL
& <> 2   # 106867.n
                       Local Integer WOK : WOK = 2
                       Call VALADRFF_CLICK() From TRTADRLIB
                       If [M:ADC]ADRVAL <> 2
                         If func TRTADRLIB.CHKADR_MANDATORY()
                           WOK = 1  # Address validation mandatory, so don't let them leave
                         Else
                           Call AVERTIR(mess(61,115,1), WOK) From GESECRAN
                         Endif
                       Endif
                       If WOK = 2
                         Gosub OK_SAIADRBPC
                         FIN=1
                       Else
                         FIN=0
                       Endif
                     Else  #LTA.en
                       Gosub OK_SAIADRBPC
                       FIN=1
                     Endif

 When "SAICEE"     : Gosub OK_SAICEE
 When "TRTRPLITM"  : Gosub OK_TRTRPLITM
Endcase
Return

$ABA
Case GACTION
 When "SAIADRBPC", "TRTADRBPC" :
                     Gosub ABA_SAIADRBPC
                     REP = ""
                     Affzo [M]1-99
 When "SAICEE"     : Gosub DEB_SAICEE
                     REP = ""
                     Affzo [M]1-99
Endcase
Return

$APRES_MODIF
Case GACTION
 When "SAIADRBPC", "TRTADRBPC" :
                     REP = "M"
                     If dim([M:ADC]ADRVAL) > 0 & [M:ADC]ADRVAL <>  1 : [M:ADC]ADRVAL = 1 : Affzo [M:ADC]ADRVAL : Endif #LTA.n
 When "SAICEE"     : REP = "M"
Endcase
Return

$BOUTON
Case GACTION
 When "TRTORDALL"  : Gosub BOUT_TRTORDALL
 When "VISUDETALL" : Gosub BOUT_VISUDETALL
Endcase
Return

$FIN
Case GACTION
 When "TRTORDALL"  : Gosub FIN_TRTORDALL
 When "TRTORDETA"  : Gosub FIN_TRTORDETA
 When "TRTRPLITM"  : Gosub FIN_TRTRPLITM
 When "VISUDERLIV" : Gosub FIN_VISUDERLIV
 When "VISUDERPRI" : Gosub FIN_VISUDERPRI
 When "VISUDETALL" : Gosub FIN_VISUDETALL
Endcase
Return

#########################################################################
#    Actions liés au type traitement standard                           #
#########################################################################
$INIT
Case GACTION
 When "TRTADRBPC"  : Gosub INI_TRTADRBPC
 When "TRTORDALL"  : Gosub INI_TRTORDALL
 When "TRTORDETA"  : Gosub INI_TRTORDETA
 When "TRTRPLITM"  : Gosub INI_TRTRPLITM
Endcase
Return

$CONTROLE
Case GACTION
 When "TRTORDALL"    : Gosub CONT_TRTORDALL
Endcase
Return

$EXEC
Case GACTION
 When "TRTORDALL"    : Gosub EXEC_TRTORDALL
 When "TRTRPLITM"    : Gosub EXEC_TRTRPLITM
Endcase
Return

$TERMINE
Case GACTION
 When "TRTORDALL"    : Gosub TERMINE_TRTORDALL
 When "TRTADRBPC"    : Gosub TERMINE_TRTADRBPC
Endcase
Return

################################################################################
# DETAIL DES ACTIONS                                                           #
################################################################################

################################################################################
# TRTADRBPC : Saisie adresse libre des clients                                 #
################################################################################
$INI_TRTADRBPC
Local Char WBPR    : WBPR = PARAM(2)

# ---------------------------------------------------------------------------- #
# Action appelée en AP_ du client si client divers                             #
# --> Appel direct de fenêtre de saisie d'adresse                              #
# ---------------------------------------------------------------------------- #
If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
If [F:BPC]BPCNUM <> WBPR
    Read [F:BPC]BPC0 = WBPR
    If fstat Raz [F:BPC] : Endif
Endif
If [F:BPC]BPCTYP <> 2 | GIMPORT : FIN=1 : Endif
# --> Appel uniquement si le client a changé (pour ne pas l'avoir systématiquement)
If PARAM(1) = "ADB1" & [M]BPCORD = WBPR FIN=1 : Endif
If PARAM(1) = "ADB3" & [M]BPCINV = WBPR FIN=1 : Endif
If PARAM(1) = "ADI4" & [M]BPRPAY = WBPR FIN=1 : Endif
# --> Si modif client raz adresse avant de passer dans le bouton adresse
If !GIMPORT
    If PARAM(1) = "ADB1" & WBPR <> [M]BPCORD
        Raz [M:ADB1]
    Endif
    If PARAM(1) = "ADB3" & WBPR <> [M]BPCINV
        Raz [M:ADB3]
    Endif
    If PARAM(1) = "ADI4" & WBPR <> [M]BPRPAY
        Raz [M:ADI4]
    Endif


#    If dim([M:ADB1]CNTNAM)>0 & [M:ADB1]CNTNAM = ""
#        Call RECH_CNTNAM(WBPR, [F:BPC]BPAADD, [M:ADB1]CNTNAM) From TRTVENDIV
#    Endif
#    If dim([M:ADB1]CNTNAM)>0 & [M:ADB1]CNTNAM = ""
#        Call RECH_CNTNAM(WBPR, [F:BPD]BPAADD, [M:ADB2]CNTNAM) From TRTVENDIV
#    Endif
#    If dim([M:ADB3]CNTNAM)>0 & [M:ADB3]CNTNAM = ""
#        Call RECH_CNTNAM(WBPR, WBPAINV, [M:ADB3]CNTNAM) From TRTVENDIV
#    Endif

Endif
Return

$DEB_SAIADRBPC
#----- Variables pour sauvegarde du masque -----#
Local Char    BPRNAM(GLONNAM)(2)
Local Char    BPAADD(GLONADR)
Local Char    BPAADDLIG(GLONADL)(3)
Local Char    CRY(GLONCRY)
Local Char    CRYNAM(GLONNCY)
Local Char    SAT(GLONSAT)
Local Char    POSCOD(GLONPOS)
Local Char    CTY(GLONCTY)
Local Char    CNTNAM(GLONAIN)
Local Integer ADRVAL            #LTA.n
#Local Char    EECNUM(GLONEEC)
Local Char    EECNUMX(GLONEEC) #RMA #82772
Local Integer PORVAT           #RMA #82772
Local Char    CRN(GLONCRT) # X3-84945:Review mandatory mentions / Sales invoices (French law) X3-85350 (LCC 22/05/18)

Local Char WBPR    : WBPR = PARAM(2)
Local Char WABMSK  : WABMSK = PARAM(3)

If clalev([F:BPR]) = 0 Local File BPARTNER   [BPR] : Endif
If clalev([F:BPC]) = 0 Local File BPCUSTOMER [BPC] : Endif
If clalev([F:BPA]) = 0 Local File BPADDRESS  [BPA] : Endif
If clalev([F:TCY]) = 0 Local File TABCOUNTRY [TCY] : Endif
# PARAM(1) = Param ABREV de l'action SAIADRBPC

[L]PORVAT = 0
Case PARAM(1)
  When "ADB1"
    [M:ADC] = [M:ADB1]
    If dim([M:ADC]EECNUMX)  > 0   : Chgfmt [M:ADC]EECNUMX With "-K:1X" : Endif #RMA #82772
  When "ADB2"
    [M:ADC] = [M:ADB2]
    Chgfmt [M:ADC]BPAADD With "-K:1X"
    If dim([M:ADC]EECNUMX)  > 0   : Chgfmt [M:ADC]EECNUMX With "-K:1X" : Endif #RMA #82772
  When "ADB3"
    [M:ADC] = [M:ADB3]
    #RMA #82772
    If dim([M:ADC]EECNUMX) > 0 & WABMSK <> ""
      If func AFNC.PARAM("PORVAT",evalue ("[M:"+WABMSK+"]SALFCY")) = "2"
        [L]PORVAT = 1
      Endif
    Endif
    If dim([M:ADC]EECNUMX) > 0 & [L]PORVAT <> 1
      Chgfmt [M:ADC]EECNUMX With "-K:1X"
    Endif
  When "ADI4"
    [M:ADC] = [M:ADI4]
    If dim([M:ADC]EECNUMX)  > 0   : Chgfmt [M:ADC]EECNUMX With "-K:1X" : Endif #RMA #82772
Endcase
If [F:BPR]BPRNUM <> WBPR
   Read [BPR]BPR0 = WBPR
   If fstat Raz [F:BPR] Endif
Endif
If [F:BPC]BPCNUM <> WBPR
   Read [BPC]BPC0 = WBPR
   If fstat Raz [F:BPC] Endif
Endif
# ACA - ADI4 - Adresse payeur :
# Si client divers, tout est accessible, sinon, seulement code adresse
If PARAM(1)="ADI4" and [F:BPC]BPCTYP<>2 # Client non divers
    Diszo [M:ADC]CRY
    Diszo [M:ADC]CRYNAM
    Diszo [M:ADC]BPAADDLIG
    Diszo [M:ADC]SAT
    Diszo [M:ADC]POSCOD
    Diszo [M:ADC]CTY
    Diszo [M:ADC]CNTNAM
Endif

# Chargement de la classe écran si nécessaire
If [M:ADC]ADBFLG = 0
   If PARAM(1) = "ADI4" & [M:ADC]BPAADD = "" : # ADI4: adr payeur
      Read [BPA]BPA0=1;WBPR;[F:BPC]BPAPYR
      If fstat: Read [BPA]BPA0=1;WBPR;[F:BPC]BPAADD: Endif :## SAM # 119565
   Elsif [M:ADC]BPAADD <> ""
      Read [BPA]BPA0=1;WBPR;[M:ADC]BPAADD
   Else
      Read [BPA]BPA0=1;WBPR;[F:BPC]BPAADD
   Endif
   If fstat Raz [F:BPA] Endif
   [M:ADC]BPRNAM(0)    = [F:BPR]BPRNAM(0)
   [M:ADC]BPRNAM(1)    = [F:BPR]BPRNAM(1)
   If PARAM(1) = "ADB2" & [M:ADC]BPAADD <> "" : # ADB2: adr livraison
       If [F:BPD]BPCNUM <> WBPR | [F:BPD]BPAADD <> [M:ADC]BPAADD
           Read [BPD]BPD0 = WBPR;[M:ADC]BPAADD
           If fstat = 0
               [M:ADC]BPRNAM(0) = [F:BPD]BPDNAM(0)
               [M:ADC]BPRNAM(1) = [F:BPD]BPDNAM(1)
           Endif
       Else
           [M:ADC]BPRNAM(0) = [F:BPD]BPDNAM(0)
           [M:ADC]BPRNAM(1) = [F:BPD]BPDNAM(1)
       Endif
   Endif
#   If dim([M:ADC]EECNUM)>0
#      If [M:ADC]EECNUM = "" [M:ADC]EECNUM = [F:BPR]EECNUM Endif
#   Endif
   [M:ADC]BPAADD       = [F:BPA]BPAADD
   [M:ADC]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
   [M:ADC]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
   [M:ADC]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
   [M:ADC]CRY          = [F:BPA]CRY
   If [F:TCY]CRY<>[M]CRY
       Read [TCY]TCY0=[M]CRY : If fstat Raz [F:TCY] Endif
   Endif

   If dim([M]SAT)>0
      #FQ 66310
      #If [F:TCY]ETAT<>2
      #     Effzo SAT
      #     Grizo SAT
      # Else
       If [F:TCY]ETAT > 1 :#rajout : Saisie Subdivision 1 ou Subdivision 2
      #fin FQ 66310
           If PARAM(1)<>"ADI4" or [F:BPC]BPCTYP=2 # ACA - Si adresse payeur -> client divers?
               Actzo SAT
           Endif
       Endif
   Endif
   [M:ADC]CRYNAM       = [F:BPA]CRYNAM
   [M:ADC]SAT          = [F:BPA]SAT
   [M:ADC]POSCOD       = [F:BPA]POSCOD
   [M:ADC]CTY          = [F:BPA]CTY
   [M:ADC]ADBBPR       = [F:BPR]BPRNUM
   [M:ADC]ADBFLG       = 1
   # X3-84945:Review mandatory mentions / Sales invoices (French law) X3-85351 (LCC 29/05/18)
   If dim([M:ADC]CRN)>0 & dim([M:SIH0]CRN)>0
     [M:ADC]CRN=[F:BPR]CRN
     [M:SIH0]CRN=[F:BPR]CRN
   Endif
   # End X3-84945:Review mandatory mentions / Sales invoices (French law) X3-85351 (LCC 29/05/18)
   If dim([M:ADC]ADRVAL) > 0 : [M:ADC]ADRVAL = [F:BPA]ADRVAL : Endif  #LTA.n
Endif

If WABMSK <> "" & [L]PORVAT = 1  & PARAM(1)="ADB3"#RMA *82772
  If dim([M:ADC]EECNUMX) > 0 & evalue ("dim([M:"+WABMSK+"]BPIEECNUM)") > 0
    [M:ADC]EECNUMX = evalue ("[M:"+WABMSK+"]BPIEECNUM")
  Endif
Endif

#Case PARAM(1)
# When "ADB1","ADB2"  :
#    If dim([M:ADB3]EECNUM) > 0
#        If [M:ADB3]ADBBPR = [M:ADC]ADBBPR
#            [M:ADC]EECNUM=[M:ADB3]EECNUM
#        Else
#            [M:ADC]EECNUM=[F:BPR]EECNUM
#        Endif
#    Endif
#Endcase

# Sauvegarde valeurs initiales
[L] = [M:ADC]

# Ctrl autorisation modification
If !find (GREP, "C", "D")
    GBIDC2="M": Gosub AUTORIS_OPT From CONTX3
    If !GBIDI2  Diszo [M:ADC] : Endif
Endif
# Si ce n'est pas une adresse de facturation on grize le n°identification CEE
#If PARAM(1) <> "ADB3"
#   If dim([M:ADC]EECNUM)>0 Grizo [M:ADC]EECNUM Endif
#Endif

# Si on est en gestion facture, il faut diszoner l'écran si la facture est validée ou si aucun droit de modif (Bug 53726)
If GFONCTION="GESSIH"
    If dim([M:SIH1]INVSTA)>0 & [M:SIH1]INVSTA=3 | GCONSDIA Diszo [M:ADC]1-99 : Endif
Endif

# BRBAN 105200#US2
If GFONCTION="GESSIH" & func AFNC.ACTIV("INVCA")>0
  If [F:TSV]INVCAN=2
    If [F:FCY]FCY<>[F:SIH]FCY : Read [F:FCY]FCY0=[F:SIH]FCY : Endif
    If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
      Diszo [ADC]1-99 : FLGSAI=0
      #GCONSULT=1
    Endif
  Endif
Endif
# -

#Fq66051-Gbn
If GCONSULT>0
  Diszo [ADC]1-99 : FLGSAI=0
Endif

#LTA.sn
# If func AFNC.ACTIV("LTA") and dim([M:ADC]VALADR) > 0 and (PARAM(1) <> "ADB2" or GLOCUSATAX = 0 or !func TRTADRLIB.CHKADR_CRY([M:ADC]CRY))   # 106867.o
If func AFNC.ACTIV("LTA") and dim([M:ADC]VALADR) > 0 and (PARAM(1) <> "ADB2" or !func TRTTAXSST.CHK_SSTTAXACT(GSOCIETE) or !func TRTADRLIB.CHKADR_CRY([M:ADC]CRY))   # 106867.o
  Chgfmt [M:ADC]VALADR With "-LA:1"
  Chgfmt [M:ADC]ADRVAL With "-K:10X"
Endif
#LTA.en

# X3-84945:Review mandatory mentions / Sales invoices (French law) X3-85133 (LCC 18/04/18)
If GFONCTION="GESSIH" & PARAM(1) = "ADB3"
 If [M:ADC]CRY<>[F:TCY]CRY
    Read [TCY]TCY0=[M]CRY: If fstat: Raz [F:TCY]: Endif
 Endif
 If [F:TCY]CRTFMTFLG=2 # X3-84945:Review mandatory mentions / Sales invoices (French law) X3-85350 (LCC 22/05/18)
  [M:ADC]FORMAT="K:"+[F:TCY]CRTFMT
  If [F:BPC]BPCTYP<>2 or [M:SIH1]INVSTA=3: [M:ADC]FORMAT="KP:"+[F:TCY]CRTFMT: Endif
 Else
  [M:ADC]FORMAT="-K:20X"
 Endif
  [M:ADC]CRN=[M:SIH0]CRN
  [L]CRN=[M:ADC]CRN
Endif
# End X3-84945:Review mandatory mentions / Sales invoices (French law) X3-85133 (LCC 18/04/18)
Return

#------------------------------------------------------------------------------#
$OK_SAIADRBPC
Local Integer WMOD :    Raz WMOD
# Test si adresse modifiée
If [M:ADC]BPRNAM(0)    <> [L]BPRNAM(0)    |
&  [M:ADC]BPRNAM(1)    <> [L]BPRNAM(1)    |
&  [M:ADC]BPAADD       <> [L]BPAADD       |
&  [M:ADC]BPAADDLIG(0) <> [L]BPAADDLIG(0) |
&  [M:ADC]BPAADDLIG(1) <> [L]BPAADDLIG(1) |
&  [M:ADC]BPAADDLIG(2) <> [L]BPAADDLIG(2) |
&  [M:ADC]CRY          <> [L]CRY          |
&  [M:ADC]CRYNAM       <> [L]CRYNAM       |
&  [M:ADC]SAT          <> [L]SAT          |
&  [M:ADC]POSCOD       <> [L]POSCOD       |
&  [M:ADC]CTY          <> [L]CTY          |
&  (dim([M:ADC]ADRVAL) > 0 and PARAM(1) = "ADB2" and [M:ADC]ADRVAL <> [L]ADRVAL) |
&  (dim([M:ADC]EECNUMX) > 0 and PARAM(1) = "ADB3" and [M:ADC]EECNUMX <> [L]EECNUMX) |
&  ([M:ADC]CRN <> [L]CRN and PARAM(1) = "ADB3")

   # - 101090 - Confirm user wants to edit address if a BOL is attached
   If PARAM(1)="ADB2" & dim([M:SDH2]BOLNUM)>0 & [M:SDH2]BOLNUM<>""
    Local Integer OK : OK = 2
    Call VERIF_BOLMOD(OK) From SUBSDHB
    If OK<>2 : FIN=0 : Endif
   Endif

   # Chargement classe écran pour maj en sortie
   [M:ADC]ADBFLG=2
   Case PARAM(1)
    When "ADB1"  : [M:ADB1] = [M:ADC]
    When "ADB2"  : [M:ADB2] = [M:ADC]
    When "ADB3"  : [M:ADB3] = [M:ADC]: If dim([M:SIH0]CRN)>0: [M:SIH0]CRN=[M:ADC]CRN: Endif # X3-84945 & X3-102617:Review mandatory mentions / Sales invoices (French law) X3-85350 (LCC 22/05/18)
    When "ADI4"  : [M:ADI4] = [M:ADC]
   Endcase
   If GACTION="SAIADRBPC" mkstat=4 Endif
   # 79705 : V7 : SAT in SPRICLINK
   If PARAM(1)="ADB2" & ([M:ADC]SAT<>[L]SAT | [M:ADC]CRY<>[L]CRY)
      # New global to trigger recalucate prices
      Global Char GADDACTMOD(GLONDES) : GADDACTMOD = "1"
   Endif
   # 79705 : V7 : SAT in SPRICLINK
   If WABMSK <> "" #RMA *82772
     If dim([M:ADC]EECNUMX) > 0 & evalue ("dim([M:"+WABMSK+"]BPIEECNUM)") > 0 & [L]PORVAT = 1
       Assign ("[M:"+WABMSK+"]BPIEECNUM") With [M:ADC]EECNUMX
     Endif
   Endif

   # Issue 114050 - 2016-02-04 by CPO : Refresh problem on customs information from GESSDH
   If PARAM(1)="ADB2" and GACTDEB>0 and dim([M]CRY)>0
     Case PARAM(3)
       When "SQH0" : If dim([M:SQH0]EECNUMCRY)>0 : [M:SQH0]EECNUMCRY = [M]CRY : Endif
       When "SOH0" : If dim([M:SOH0]EECNUMCRY)>0 : [M:SOH0]EECNUMCRY = [M]CRY : Endif
       When "SDH0" : If dim([M:SDH0]EECNUMCRY)>0 : [M:SDH0]EECNUMCRY = [M]CRY : Endif
       When "SIH0" : If dim([M:SIH0]EECNUMCRY)>0 : [M:SIH0]EECNUMCRY = [M]CRY : Endif
       When "SRH0" : If dim([M:SRH0]EECNUMCRY)>0 : [M:SRH0]EECNUMCRY = [M]CRY : Endif
       When "SRL0" : If dim([M:SRL0]EECNUMCRY)>0 : [M:SRL0]EECNUMCRY = [M]CRY : Endif
       When "SRS0" : If dim([M:SRS0]EECNUMCRY)>0 : [M:SRS0]EECNUMCRY = [M]CRY : Endif
       When Default
     Endcase
    Endif
   # End issue 114050

Else
    If [M:ADC]CNTNAM <> [L]CNTNAM
       Case PARAM(1)
        When "ADB1"  : [M:ADB1]CNTNAM = [M:ADC]CNTNAM
        When "ADB2"  : [M:ADB2]CNTNAM = [M:ADC]CNTNAM
        When "ADB3"  : [M:ADB3]CNTNAM = [M:ADC]CNTNAM
        When "ADI4"  : [M:ADI4]CNTNAM = [M:ADC]CNTNAM
       Endcase
       If GACTION="SAIADRBPC" mkstat=4 Endif
    Endif
#   If dim([M:ADC]EECNUM)>0
#       If [M:ADC]EECNUM <> [L]EECNUM
#          Case PARAM(1)
#           When "ADB3"  : [M:ADB3]EECNUM = [M:ADC]EECNUM
#                          [M:ADB3]ADBBPR = [M:ADC]ADBBPR
#          Endcase
#          If GACTION="SAIADRBPC" mkstat=4 Endif
#       Endif
#    Endif
Endif

# ACA - Flag client divers - copie dans les autres adresses
If [F:BPC]BPCTYP=2 and [M:ADC]ADBFLG=2 # and GREP="C" # ici : GREP=""
    If PARAM(1)<>"ADB1" and dim([M:ADB1]BPAADD)>0 and [M:ADB1]BPAADD=""
        [M:ADB1] = [M:ADC]
    Endif
    If PARAM(1)<>"ADB2" and dim([M:ADB2]BPAADD)>0 and [M:ADB2]BPAADD=""
        [M:ADB2] = [M:ADC]
    Endif
    If PARAM(1)<>"ADB3" and dim([M:ADB3]BPAADD)>0 and [M:ADB3]BPAADD=""
        [M:ADB3] = [M:ADC]
    Endif
    If PARAM(1)<>"ADI4" and dim([M:ADI4]BPAADD)>0 and [M:ADI4]BPAADD=""
        [M:ADI4] = [M:ADC]
    Endif
Endif
Return

#------------------------------------------------------------------------------#
$ABA_SAIADRBPC
# Abandon : Rechargement classe écran avec les anciennes valeurs
[M:ADC] = [L]

Return

#------------------------------------------------------------------------------#
$TERMINE_TRTADRBPC

Case PARAM(1)
    When "ADB1"  : # Adresse de commande
#       --> Réalimentation de la raison sociale
#       --> Répercution sur adresse liv. et fac. si même client
        If [M:ADB1]ADBFLG = 2
            If [M:ADB1]BPRNAM(0) <> ""
                [M]BPCNAM = [M:ADB1]BPRNAM(0)
            Else
                [M]BPCNAM = [F:BPC]BPCNAM
            Endif
            If dim([M:ADB2]BPRNAM) > 0
                [M:ADB2] = [M:ADB1]
            Endif
            If dim([M:ADB3]BPRNAM) > 0
                If dim([M]BPCINV) > 0
#                    If [F:BPC]BPCINV = WBPR
                    If [M]BPCINV = WBPR
                        [M:ADB3] = [M:ADB1]
                        [M]BPINAM = [M]BPCNAM
                    Endif
                Endif
            Endif
        Endif
    When "ADB3"  : # Adresse de facture
#       --> Réalimentation de la raison sociale
        If [M:ADB3]ADBFLG = 2
            If [M:ADB3]BPRNAM(0) <> ""
                [M]BPINAM = [M:ADB3]BPRNAM(0)
            Else
                [M]BPINAM = [F:BPC]BPCNAM
            Endif
#           --> Si gestion des factures, répercution sur l'adresse livraison
            If dim([M:ADB2]BPRNAM) > 0 & dim([M:ADB1]BPRNAM) <= 0
                [M:ADB2] = [M:ADB3]
            Endif
        Endif
    When "ADI4"  : # Adresse de règlement
Endcase
Return

######################################################################################
# SAICEE : Saisie des informations douanières                                        #
######################################################################################
$DEB_SAICEE
Local Char    WABMSK : WABMSK = PARAM(1)

If clalev([F:BPT]) = 0 Local File BPCARRIER  [BPT] : Endif
If clalev([F:BPA]) = 0 Local File BPADDRESS  [BPA] : Endif
# Table utile pour saisie XEECNUM (type EEC)
If clalev([F:TCY]) = 0 Local File TABCOUNTRY [TCY] : Endif

#-- Pour tous les écrans sauf les factures et avoirs
#   Suppression du bloc "Flux régularisation"
If !find(WABMSK,"SIH0")
   Chgtbk [M]20 With ""
   If dim([M]XEECNATR)>0  : Chgfmt [M]XEECNATR With "-K:1X" : Endif
   If dim([M]ZXEECNATR)>0 : Chgfmt [M]ZXEECNATR With "-K:1X" : Endif
   If dim([M]XEECSCHR)>0  : Chgfmt [M]XEECSCHR  With "-K:1X" : Endif
   If dim([M]ZXEECSCHR)>0 : Chgfmt [M]ZXEECSCHR With "-K:1X" : Endif
Endif
#--
#-- Pour les devis, commandes, contrat-article :
#   Suppression du bloc "Flux physique"
#   Suppression du champs Mode transport CEE du bloc Informations CEE
If find(WABMSK,"SQH0","SOH0","SOI1")
   Chgtbk [M]15 With ""
   If dim([M]XEECNAT)>0  : Chgfmt [M]XEECNAT With "-K:1X" : Endif
   If dim([M]ZXEECNAT)>0 : Chgfmt [M]ZXEECNAT With "-K:1X" : Endif
   If dim([M]XEECSCH)>0  : Chgfmt [M]XEECSCH  With "-K:1X" : Endif
   If dim([M]ZXEECSCH)>0 : Chgfmt [M]ZXEECSCH With "-K:1X" : Endif

   If dim([M]XEECTRN)>0  : Chgfmt [M]XEECTRN With "-K:1X" : Endif
Endif
#--

Raz [M:SCEE]

[M]ABRMSK = WABMSK           # FGR 20/08/2015 : X3SUIVI109467

[M]XSTOMVT = 2
[M]XINVTYP = 0

If dim([M]XEECICT)>0 & evalue ("dim([M:"+WABMSK+"]EECICT)")>0 [M]XEECICT = evalue("[M:"+WABMSK+"]EECICT") Endif
If dim([M]XICTCTY)>0 & evalue ("dim([M:"+WABMSK+"]ICTCTY)")>0 [M]XICTCTY = evalue("[M:"+WABMSK+"]ICTCTY") Endif
If dim([M]XFFWNUM)>0 & evalue ("dim([M:"+WABMSK+"]FFWNUM)")>0 [M]XFFWNUM = evalue("[M:"+WABMSK+"]FFWNUM") Endif
If dim([M]XFFWADD)>0 & evalue ("dim([M:"+WABMSK+"]FFWADD)")>0 [M]XFFWADD = evalue("[M:"+WABMSK+"]FFWADD") Endif

If GACTDEB=2
    #-- Bloc Informations CEE
    #--      N°identification CEE
    If dim([M]XEECNUM)>0 & evalue ("dim([M:"+WABMSK+"]BPIEECNUM)")>0 [M]XEECNUM = evalue("[M:"+WABMSK+"]BPIEECNUM") Endif

    If dim([M]XCRY)>0
        If evalue ("dim([M:"+WABMSK+"]EECNUMCRY)")>0 [M]XCRY = evalue("[M:"+WABMSK+"]EECNUMCRY") Endif
    Endif

    #--      Lieu transport CEE
    If dim([M]XEECLOC)>0 & evalue ("dim([M:"+WABMSK+"]EECLOC)")>0 [M]XEECLOC = evalue("[M:"+WABMSK+"]EECLOC") Endif

    If !find(WABMSK,"SQH0","SOH0","SOI1")
        #--      Mode transport CEE
        If dim([M]XEECTRN)>0 & evalue ("dim([M:"+WABMSK+"]EECTRN)")>0 [M]XEECTRN = evalue("[M:"+WABMSK+"]EECTRN") Endif

        #-- Bloc Flux physique
        #--      Nature transaction
        If dim([M]XEECNAT)>0 & evalue ("dim([M:"+WABMSK+"]EECNAT)")>0 [M]XEECNAT = evalue("[M:"+WABMSK+"]EECNAT") Endif
        #--      Régime CEE
        If dim([M]XEECSCH)>0 & evalue ("dim([M:"+WABMSK+"]EECSCH)")>0 [M]XEECSCH = evalue("[M:"+WABMSK+"]EECSCH") Endif
    Endif
    #-- Bloc Flux régularisation
    If find(WABMSK,"SIH0")
        #--      Nature transaction
        If dim([M]XEECNATR)>0 & evalue ("dim([M:"+WABMSK+"]EECNATR)")>0 [M]XEECNATR = evalue("[M:"+WABMSK+"]EECNATR") Endif
        #--      Régime CEE
        If dim([M]XEECSCHR)>0 & evalue ("dim([M:"+WABMSK+"]EECSCHR)")>0 [M]XEECSCHR = evalue("[M:"+WABMSK+"]EECSCHR") Endif
    Endif
Endif

If WABMSK = "SIH0"
   [M]XINVTYP = evalue("[M:"+WABMSK+"]INVTYP")
   [M]XSTOMVT = [M:SIH1]STOMVTFLG
Endif

# FGR 20/08/2015 : X3SUIVI109467 (début) déplace dans SUBSCEE.AV_XEECNUM
## Ctrl autorisation modification
#If !find (GREP, "C", "D")
#    GBIDC2="M": Gosub AUTORIS_OPT From CONTX3
#    If !GBIDI2  Diszo [M]1-99 : Return Endif
#Endif
#
## Visu des infos CEE si aucun droit de modif (Bug 39742) (Bug 53726)
#If WABMSK = "SIH0"
#   If [M:SIH1]INVSTA=3 | GCONSULT | GCONSDIA Diszo [M]1-99 Endif
#Elsif WABMSK = "SDH0"
#   If [M:SDH1]CFMFLG=2 | GCONSULT | GCONSDIA Diszo [M]1-99 Endif
## 91606 :(04/08/14) Transportation notes (Sales part dev)
#Elsif WABMSK = "TNH0"
#   If [M:TNH1]CFMFLG=2 | GCONSULT | GCONSDIA Diszo [M]1-99 Endif
## 91606 :(04/08/14) Transportation notes (Sales part dev)
#Elsif WABMSK = "SOH0"
#   If GCONSULT Diszo [M]1-99 Endif
#Elsif GCONSULT
#  Diszo [M]1-99 #Fq66051-Gbn
#Endif
# FGR 20/08/2015 : X3SUIVI109467 (fin) déplace dans SUBSCEE.AV_XEECNUM

If [M]XFFWNUM="" Diszo [M]XFFWADD Endif

#If GACTDEB<>2 Grizo [M]XEECNUM, XEECNAT, XEECSCH, XEECLOC, XEECTRN : Endif

Return

#------------------------------------------------------------------------------#
$OK_SAICEE

If WABMSK="SIH0" & [M:SIH1]INVSTA=3 FIN=1 : Return Endif
If WABMSK="SDH0" & [M:SDH1]CFMFLG=2 FIN=1 : Return Endif
If WABMSK="TNH0" & [M:TNH1]CFMFLG=2 FIN=1 : Return Endif : # 91606 :(04/08/14) Transportation notes (Sales part dev)

If dim([M]XEECICT)>0 & evalue ("dim([M:"+WABMSK+"]EECICT)")>0 Assign "[M:"+WABMSK+"]EECICT" With [M]XEECICT Endif
#-- CPO 65018
If dim([M]XEECICT)>0
  Case WABMSK
    When "SOH0" : If dim([M:SOH2]EECICT)>0 : [M:SOH2]EECICT = [M]XEECICT : Affzo [M:SOH2]EECICT : Endif
                  If dim([M]ZXEECICT)>0 & dim([M:SOH2]ZEECICT)>0 : [M:SOH2]ZEECICT = [M]ZXEECICT : Affzo [M:SOH2]ZEECICT : Endif
    When "SQH0" : If dim([M:SQH1]EECICT)>0 : [M:SQH1]EECICT = [M]XEECICT : Affzo [M:SQH1]EECICT : Endif
                  If dim([M]ZXEECICT)>0 & dim([M:SQH1]ZEECICT)>0 : [M:SQH1]ZEECICT = [M]ZXEECICT : Affzo [M:SQH1]ZEECICT : Endif
    When "SDH0" : If dim([M:SDH2]EECICT)>0 : [M:SDH2]EECICT = [M]XEECICT : Affzo [M:SDH2]EECICT : Endif
                  If dim([M]ZXEECICT)>0 & dim([M:SDH2]ZEECICT)>0 : [M:SDH2]ZEECICT = [M]ZXEECICT : Affzo [M:SDH2]ZEECICT : Endif
    # 91606 :(04/08/14) Transportation notes (Sales part dev)
    When "TNH0" : If dim([M:TNH2]EECICT)>0 : [M:TNH2]EECICT = [M]XEECICT : Affzo [M:TNH2]EECICT : Endif
                  If dim([M]ZXEECICT)>0 & dim([M:TNH2]ZEECICT)>0 : [M:TNH2]ZEECICT = [M]ZXEECICT : Affzo [M:TNH2]ZEECICT : Endif
    # 91606 :(04/08/14) Transportation notes (Sales part dev)
    When "SIH0" : If dim([M:SIH1]EECICT)>0 : [M:SIH1]EECICT = [M]XEECICT : Affzo [M:SIH1]EECICT : Endif
                  If dim([M]ZXEECICT)>0 & dim([M:SIH1]ZEECICT)>0 : [M:SIH1]ZEECICT = [M]ZXEECICT : Affzo [M:SIH1]ZEECICT : Endif
    When "SOI1" : If dim([M:SOI1]EECICT)>0 : Affzo [M:SOI1]EECICT : Endif
                  If dim([M]ZXEECICT)>0 & dim([M:SOI1]ZEECICT)>0 : [M:SOI1]ZEECICT = [M]ZXEECICT : Affzo [M:SOI1]ZEECICT : Endif
    When Default
  Endcase
Endif
If dim([M]XICTCTY)>0 & evalue ("dim([M:"+WABMSK+"]ICTCTY)")>0 Assign "[M:"+WABMSK+"]ICTCTY" With [M]XICTCTY Endif
#-- CPO 65018
If dim([M]XICTCTY)>0
  Case WABMSK
    When "SOH0" : If dim([M:SOH2]ICTCTY)>0 : [M:SOH2]ICTCTY = [M]XICTCTY : Affzo [M:SOH2]ICTCTY : Endif
    When "SQH0" : If dim([M:SQH1]ICTCTY)>0 : [M:SQH1]ICTCTY = [M]XICTCTY : Affzo [M:SQH1]ICTCTY : Endif
    When "SDH0" : If dim([M:SDH2]ICTCTY)>0 : [M:SDH2]ICTCTY = [M]XICTCTY : Affzo [M:SDH2]ICTCTY : Endif
    # 91606 :(04/08/14) Transportation notes (Sales part dev)
    When "TNH0" : If dim([M:TNH2]ICTCTY)>0 : [M:TNH2]ICTCTY = [M]XICTCTY : Affzo [M:TNH2]ICTCTY : Endif
    # 91606 :(04/08/14) Transportation notes (Sales part dev)
    When "SIH0" : If dim([M:SIH1]ICTCTY)>0 : [M:SIH1]ICTCTY = [M]XICTCTY : Affzo [M:SIH1]ICTCTY : Endif
    When "SOI1" : If dim([M:SOI1]ICTCTY)>0 : Affzo [M:SOI1]ICTCTY : Endif
    When Default
  Endcase
Endif
If dim([M]XFFWNUM)>0 & evalue ("dim([M:"+WABMSK+"]FFWNUM)")>0 Assign "[M:"+WABMSK+"]FFWNUM" With [M]XFFWNUM Endif
If dim([M]XFFWADD)>0 & evalue ("dim([M:"+WABMSK+"]FFWADD)")>0 Assign "[M:"+WABMSK+"]FFWADD" With [M]XFFWADD Endif

If GACTDEB=2
    If dim([M]XEECNUM)>0 & evalue ("dim([M:"+WABMSK+"]BPIEECNUM)")>0 Assign "[M:"+WABMSK+"]BPIEECNUM" With [M]XEECNUM Endif
    If dim([M]XEECLOC)>0 & evalue ("dim([M:"+WABMSK+"]EECLOC)")>0    Assign "[M:"+WABMSK+"]EECLOC" With [M]XEECLOC Endif
    If !find(WABMSK,"SQH0","SOH0","SOI1")
        If dim([M]XEECTRN)>0 & evalue ("dim([M:"+WABMSK+"]EECTRN)")>0 Assign "[M:"+WABMSK+"]EECTRN" With [M]XEECTRN Endif
        If dim([M]XEECNAT)>0 & evalue ("dim([M:"+WABMSK+"]EECNAT)")>0 Assign "[M:"+WABMSK+"]EECNAT" With [M]XEECNAT Endif
        If dim([M]XEECSCH)>0 & evalue ("dim([M:"+WABMSK+"]EECSCH)")>0 Assign "[M:"+WABMSK+"]EECSCH" With [M]XEECSCH Endif
    Endif
    If find(WABMSK,"SIH0")
        If dim([M]XEECNATR)>0 & evalue ("dim([M:"+WABMSK+"]EECNATR)")>0 Assign "[M:"+WABMSK+"]EECNATR" With [M]XEECNATR Endif
        If dim([M]XEECSCHR)>0 & evalue ("dim([M:"+WABMSK+"]EECSCHR)")>0 Assign "[M:"+WABMSK+"]EECSCHR" With [M]XEECSCHR Endif
    Endif
Endif
mkstat = 4
FIN = 1
Return

################################################################################
# TRTORDALL : Saisie de la fenêtre du bouton allocation ds les commandes       #
################################################################################

#------------------------------------------------------------------------------#
$INI_TRTORDALL
Local Integer WALLPAR
Local Integer WSHTFLG
Local Integer WIMPCLI

Local Integer WRET

Local Integer OK     : OK = 2
Local Integer I
Local Decimal WQTY, WSTUDIS, WCPLQTY
Local Decimal WALL, WALLSTU, WSHTSTU
Local Decimal WCOE, TALLQTY, TALLQTYSTU
Local Decimal WALLCLI, WSHT
Local Char    WTRTORD, WTIT(50), WMESS(80), WMESS1(80), WMESS2(80)
Local Integer WTRTALL, WALLCTM, WRAZCTM, WGENSHT

Return


#------------------------------------------------------------------------------#
$OUV_TRTORDALL

PARAM(5)= num$(0)
Raz PARAM(7)       : # Bug 82110 : Raz Code retour allocation/désallocation
Return

#------------------------------------------------------------------------------#
$DEB_TRTORDALL
Raz [M:SAL7]ALLPAR, SHTFLG, ALLCTM, RAZCTM

# --> Récupération du paramêtre stock : Génération de ruptures
Local Char     WPARAM(10)
Call PARAML([M:SOH2]STOFCY,"GENSHT",WPARAM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
GGENSHT=val(WPARAM)

[M:SAL7]ALLSTA = [M:SOH1]ALLSTA
[M:SAL7]ALLTYP = [M:SOH2]ALLTYP
If sum([M:SOH4]SHTQTYSTU) <> 0 [M:SAL7]SHTLIN = 2 Else [M:SAL7]SHTLIN = 1 Endif
If find (2, [M:SOH4]FMI(0..[M:SOH4]NBLIG-1)) |
&  find (3, [M:SOH4]FMI(0..[M:SOH4]NBLIG-1)) |
&  find (5, [M:SOH4]FMI(0..[M:SOH4]NBLIG-1))
     [M:SAL7]CTMLIN = 2
Else [M:SAL7]CTMLIN = 1
Endif

[M:SAL7]GENSHT = GGENSHT
[M:SAL7]IMPCLI = GUSERERBPC
If GUSERERBPC=3 [M:SAL7]IMPCLI=2 : Endif

Affzo [M:SAL7]1-99

Gosub GRISE_TRTORDALL

Return

#------------------------------------------------------------------------------#
$SETB_TRTORDALL

Case [M:SAL7]ALLSTA
    When 1 :    # Commande non allouée
        If ((GSOHAPPORD=1 | GSOHAPPALL=1) & [M:SOH1]APPFLG<=2)
            # Désactivation bt allocation si pas d'encours ou pas d'alloc. des commandes non signées
            Call VIREBOUT(CHMEN, "1") From GOBJET
        Endif
        If [M:SAL7]SHTLIN = 1
            Call VIREBOUT(CHMEN, "2") From GOBJET : # désallocation
        Endif
        Call VIREBOUT(CHMEN, "3") From GOBJET     : # visu allocation
    When 3 :    # Commande totalement allouée
        Call VIREBOUT(CHMEN, "1") From GOBJET     : # allocation
Endcase
If func MANHLDLIB.BLK_ALLOC([M:SOH1]HLDSTA,[M:SOH1]HLDCOD)  # order holds
  Call VIREBOUT(CHMEN,"1") From GOBJET  # allocation
Endif
Return

#------------------------------------------------------------------------------#
$BOUT_TRTORDALL

Case BOUT
    When "1"  :  # allocation
        PARAM(1) = num$([M]ALLPAR)
        PARAM(2) = num$([M]SHTFLG)
        PARAM(3) = num$([M]IMPCLI)
        PARAM(4) = num$([M]ALLCTM)
        PARAM(5) = num$([M]RAZCTM)
        PARAM(6) = num$([M]GENSHT)
        PARAM(7) = num$(1)
        FIN=1
    When "2"  :  # désallocation
        PARAM(1) = num$([M]ALLPAR)
        PARAM(2) = num$([M]SHTFLG)
        PARAM(3) = num$([M]IMPCLI)
        PARAM(4) = num$([M]ALLCTM)
        PARAM(5) = num$([M]RAZCTM)
        PARAM(6) = num$([M]GENSHT)
        PARAM(7) = num$(2)
        FIN=1
    When Default  :
Endcase

Gosub GRISE_TRTORDALL

Return


$GRISE_TRTORDALL
Grizo [M:SAL7]ALLSTA, ALLTYP, SHTLIN, CTMLIN
Case [M:SAL7]ALLSTA
    When 1 :    # Commande non allouée
        Actzo [M:SAL7]ALLPAR, SHTFLG, GENSHT, IMPCLI
        If [M:SAL7]SHTLIN = 1
            Grizo [M:SAL7]ALLCTM, RAZCTM
        Else
            Gosub GRIZE_CTM
        Endif
    When 2 :    # Commande partiellement allouée
        Actzo [M:SAL7]ALLPAR, SHTFLG, GENSHT, IMPCLI
        Gosub GRIZE_CTM
    When 3 :    # Commande totalement allouée
        Grizo [M:SAL7]ALLPAR, SHTFLG, GENSHT, IMPCLI
        Gosub GRIZE_CTM
Endcase
Return

$GRIZE_CTM
If [M:SAL7]CTMLIN = 1
    Grizo [M:SAL7]ALLCTM
Else
    Actzo [M:SAL7]ALLCTM
Endif
If [M:SAL7]ALLCTM = 1
    Grizo [M:SAL7]RAZCTM
Else
    Actzo [M:SAL7]RAZCTM
Endif
Return

#------------------------------------------------------------------------------#
$FIN_TRTORDALL

Return

#------------------------------------------------------------------------------#
$CONT_TRTORDALL
  # ---- il faut récupérér les paramêtres saisis dans la fenêtre de critères
  WALLPAR = val(PARAM(1))
  WSHTFLG = val(PARAM(2))
  WIMPCLI = val(PARAM(3))
  WALLCTM = val(PARAM(4))
  WRAZCTM = val(PARAM(5))
  WGENSHT = val(PARAM(6))
  WTRTALL = val(PARAM(7))
  If WTRTALL = 0 FIN=1 : Return : Endif
  # Bug 66218
  If WTRTALL = 1
    If [M:SOH1]CDTSTA = 2
      GERR = 1 : GMESSAGE = mess(43,192,1) : FIN=1
    Elsif [M:SOH1]CDTSTA = 3
      If !([M:SOH1]BETFCY = 2 & [M:SOH1]BETCPY <> 2) or GCTLBETFCY = 2 Then    # FGR 10/03/2015 : X3SUIVI23273 - Si pas (Intersit & non intersoc) ou si Ctrl intersit encours&prix
        If GCDTUNL=1
          GERR = 1 : GMESSAGE = mess(101,197,1) : FIN=1
        Else
          GERR = 3 : GMESSAGE = mess(17,191,1)
        Endif
      Endif
    Elsif [M:SOH1]CDTSTA = 4
      GERR = 3 : GMESSAGE = mess(18,191,1)
    Elsif [M:SOH1]CDTSTA = 5
      GERR = 1 : GMESSAGE = mess(43,192,1) : FIN=1
    Endif
  Endif
  If FIN=1 Return Endif
  # Bug 66218
  # ---- Traitement de l'allocation/désallocation de la commande ----
  Read [SOH]SOH0=[M:SOH0]SOHNUM
  If fstat
    FIN=1
    Return
  Endif
  If WTRTALL = 1
    TIT = mess(58,191,1)
  Else
    TIT = mess(59,191,1)
  Endif
  TMP=1
Return

#------------------------------------------------------------------------------#
$EXEC_TRTORDALL

Call OUVRE_TRACE(TIT) From LECFIC
Call ECR_TRACE(mess(98,197,1)+" "+[M:SOH0]SOHNUM,0) From GESECRAN
TRA=1

Gosub TR_ALLOC From SUBSOHB

Return

#------------------------------------------------------------------------------#
$TERMINE_TRTORDALL

Call FERME_TRACE From LECFIC

Return

################################################################################
# TRTORDETA : Visu de l'état d'une commande (livrée, facturée)                 #
################################################################################

$INI_TRTORDETA

If [M:SOH0]SOHCAT = 3
    BOITE = "ISOHI"
Else
    BOITE = "ISOHD"
Endif
Return

#------------------------------------------------------------------------------#
$OUV_TRTORDETA
#Local Integer WSOHACV, NOL, I, J
Local Integer NOL, I, J, WIND_LIN : # Bug 56066
Local Integer REPONSE
Local Integer SNOL    :    SNOL=nolign
Local Integer ORITYP
Local Decimal WQTY, WOPRQTY, WPREQTY, WQTYDLV

#If   !clalev([F:ACV]) : Local File ACTIV [ACV] : Endif
#Read [ACV] CODACT = "SOH"
#If   !fstat : WSOHACV = [F:ACV]DIME : Endif
#If   WSOHACV = 0
#     FIN=1 : GERR=1 : MESSAGE = "SOH"+ mess(8,176,1): Return
#Endif
#Close Local File [ACV]

# 107888 : Scheduled invoices : (LD:11/05/16)
#If [M:SOH0]SOHCAT = 3
#   If clalev ([F:SIV]) <= 0 Local File SINVOICEV  [SIV] Endif
#Else
#   If clalev ([F:SDD]) <= 0 Local File SDELIVERYD [SDD] Endif
#   If clalev ([F:SDH]) <= 0 Local File SDELIVERY  [SDH] Endif
#   If clalev ([F:PRL]) <= 0 Local File STOPRELIS  [PRL] Endif
#   If clalev ([F:PRH]) <= 0 Local File STOPREH    [PRH] Endif
#   If clalev ([F:PRE]) <= 0 Local File STOPRED    [PRE] Endif
#Endif
If clalev ([F:SID]) <= 0 Local File SINVOICED  [SID]  Endif
If clalev ([F:SID1])<= 0 Local File SINVOICED  [SID1] Endif
If clalev ([F:SIV]) <= 0 Local File SINVOICEV  [SIV]  Endif
If clalev ([F:SDD]) <= 0 Local File SDELIVERYD [SDD]  Endif
If clalev ([F:SDH]) <= 0 Local File SDELIVERY  [SDH]  Endif
If clalev ([F:PRL]) <= 0 Local File STOPRELIS  [PRL]  Endif
If clalev ([F:PRH]) <= 0 Local File STOPREH    [PRH]  Endif
If clalev ([F:PRE]) <= 0 Local File STOPRED    [PRE]  Endif
# 107888 : Scheduled invoices : (LD:11/05/16)

Return

#------------------------------------------------------------------------------#
$DEB_TRTORDETA

# Chargement du masque situation commande

Gosub CHARGE_SDI

Return

#------------------------------------------------------------------------------#
# Chargement du masque visualisation commande
$CHARGE_SDI

Local Char WPE_TYPLIG : # Type de ligne pour alimentation par le PE

Raz [M]
Raz I,J, WIND_LIN : # Bug 56066

For I=0 To [M:SOH4]NBLIG-1
   [M]ITMREF(J) = [M:SOH4]ITMREF(I)
   WIND_LIN=J : # Bug 56066
   [M]QTY(J)    = [M:SOH4]QTY(I)
   [M]ALLQTY(J) = [M:SOH4]ALLQTY(I)
   [M]SHTQTY(J) = [M:SOH4]SHTQTY(I)
   [M]SOQSTA(J) = [M:SOH4]SOQSTA(I)
   [M]SAU(J)    = [M:SOH4]SAU(I)
   [M]FMINUM(J) = [M:SOH4]FMINUM(I)
   [M]FMI(J)    = [M:SOH4]FMI(I)
   # 107888 : Scheduled invoices : (LD:11/05/16)
   If [M:SOH0]SOHCAT <> 3
      [M]ITMDLVFLG(J) = [M:SOH4]DLVFLG(I)
      [M]DLVFLG(J) = 0
   Endif
   # 107888 : Scheduled invoices : (LD:11/05/16)
   WPE_TYPLIG="SOQ" : Gosub PE_ALIORDETA
   # 107888 : Scheduled invoices : (LD:11/05/16)
   #If [M:SOH0]SOHCAT = 3
   # --> Commande à facturation directe
   # --> Commande normale et article non livrable
   If [M:SOH0]SOHCAT = 3 | [M:SOH4]DLVFLG(I)=1
   # 107888 : Scheduled invoices : (LD:11/05/16)
      For [SID]SID0 Hint Key SID1
&                   Where [SID]BPCINV=[M:SOH1]BPCINV & [SID]SALFCY=[M:SOH0]SALFCY &
&                         [SID]SOHNUM=[M:SOH0]SOHNUM & [SID]SOPLIN=[M:SOH4]SOPLIN(I)
         If [F:SIV]NUM<>[F:SID]NUM
            Read [SIV]SIV0=[F:SID]NUM
            If fstat Raz [F:SIV] Endif
         Endif
         If [F:SIV]NUM=[F:SID]NUM & [F:SIV]INVTYP=1
            [M]NUM(J)    = [F:SID]NUM
            [M]INVDAT(J) = [F:SIV]INVDAT
            [M]QTYFAC(J) = [F:SID]QTY
            WPE_TYPLIG="SID" : Gosub PE_ALIORDETA
            If [F:SIV]INVCNOSTA=2
               # La facture a fait l'objet d'avoirs : On les affiche
               For [SID1]SID0 Hint Key SID1
&                 Where [SID1]BPCINV=[SID]BPCINV & [SID1]SALFCY=[SID]SALFCY &
&                       [SID1]SIHORINUM=[SID]NUM & [SID1]SIDORILIN=[SID]SIDLIN
                     J+=1
                     If J=dim([M]ITMREF) Call MESSAGE (mess(26,100,1)) From GESECRAN : Break Endif
                     [M]NUM(J)    = [F:SID1]NUM
                     [M]INVDAT(J) = [F:SID1]INVDAT
                     [M]QTYFAC(J) = [F:SID1]QTY*-1
                     [M]SOQSTA(J)=0 : # Bug 83943
                     WPE_TYPLIG="SID1" : Gosub PE_ALIORDETA
                     #Raz [M]ITMREF(J), [M]QTY(J)
               Next
               If J=dim([M]ITMREF) Break Endif
            Endif
            J+=1
            If J=dim([M]ITMREF) Call MESSAGE (mess(26,100,1)) From GESECRAN : Break Endif
            Raz [M]ITMREF(J), [M]QTY(J), [M]SAU(J)
            [M]SOQSTA(J)=0 : # Bug 83943
            # 107888 : Scheduled invoices : X3-5103 (LD:03/11/16)

            #MGG  SAL_X3-47095_TRTVENFEN_ITMDLVFLG_error_6_variable_non_existant
              If[M:SOH0]SOHCAT<>3
                [M]ITMDLVFLG(J)=0
                [M]DLVFLG(J)=0
              Endif
            #END MGG  SAL_X3-47095_TRTVENFEN_ITMDLVFLG_error_6_variable_non_existant

            [M]FMI(J)=0
            # 107888 : Scheduled invoices : X3-5103 (LD:03/11/16)
         Endif
      Next
   Else
   # 107888 : Scheduled invoices : (LD:11/05/16)
   # --> Commande normale/prêt et article livrable
      #[M]DLVFLG(J)=0
   # 107888 : Scheduled invoices : (LD:11/05/16)
      WORITYP=[M:SOH0]SOHCAT
      Raz WOPRQTY, WPREQTY, WQTYDLV
      If sum([M:SOH4]LPRQTY(I),[M:SOH4]OPRQTY(I),[M:SOH4]PREQTY(I))<>0
         # Il y a des listes de préparations pour cette commande
         For [PRL]PRL1 Where [PRL]ORITYP=WORITYP & [PRL]ORINUM=[M:SOH0]SOHNUM & [PRL]ORILIN=[M:SOH4]SOPLIN(I) &
&                            [PRL]ORISEQ=[M:SOH4]SOPLIN(I)
            [M]PRLNUM(J) = [F:PRL]PRLNUM
            WQTY=[F:PRL]QTYSTU*(1/[M:SOH4]SAUSTUCOE(I))
            Call QTEARR(WQTY, [M:SOH4]SAU(I)) From TRTDIV
            If [F:PRL]PRHNUM <> ""
               If [F:PRH]PRHNUM <> [F:PRL]PRHNUM
                  Read [PRH]PRH0=[F:PRL]PRHNUM
                  If fstat Raz [F:PRH] Endif
               Endif
               [M]PRHNUM(J) = [F:PRH]PRHNUM
               [M]DLVFLG(J) = [F:PRH]DLVFLG
               If [F:PRH]DLVFLG=3
                  If [F:PRH]SDHNUM <> ""
                     If [F:SDH]SDHNUM <> [F:PRH]SDHNUM
                        Read [SDH]SDH0=[F:PRH]SDHNUM
                        If fstat Raz [F:SDH] Endif
                     Endif
                     [M]SDHNUM(J) = [F:SDH]SDHNUM
                     [M]SHIDAT(J) = [F:SDH]SHIDAT
                     # On ne sait pas remonter sur le détail livraison
                     # Issue 121186
                     #[M]QTYLIV(J) = WQTY
                     For [SDD] Where [SDD]SDHNUM=[F:SDH]SDHNUM & [SDD]PRHNUM=[F:PRE]PRHNUM &
&                        [SDD]SDDLIN=[F:PRE]PRELIN
                         [M]QTYLIV(J) += [F:SDD]QTY
                         [M]QTYRET(J) += [F:SDD]RTNQTY
                     Next
                     #[M]QTYRET(J) = 0
                     # End issue 121186
                     [M]NUM(J)    = [F:SDH]SIHNUM
                     If [F:SDH]SIHNUM <> ""
                        # On ne sait pas remonter sur le détail facture
                        # Issue 121186
                        #[M]QTYFAC(J) = WQTY
                        [M]QTYFAC(J) = [M]QTYLIV(J)
                        # End issue 121186
                        # 107888 : Scheduled invoices : (LD:31/05/16)
                        If [F:SIV]NUM <> [F:SDH]SIHNUM
                           Read [SIV]SIV0=[F:SDH]SIHNUM
                           If fstat Raz [F:SIV] Endif
                        Endif
                        [M]INVDAT(J) = [F:SIV]INVDAT
                        # 107888 : Scheduled invoices : (LD:31/05/16)
                     Endif
                  Endif
                  # Quantité livrée
                  WQTYDLV     += WQTY
               Elsif [F:PRH]DLVFLG=2
                  # Quantité préparée
                  WPREQTY     += WQTY
                  [M]QTYPRE(J) = WQTY
               Elsif [F:PRH]DLVFLG<>4
                  # Quantité en préparation
                  WOPRQTY     += WQTY
                  [M]QTYPRE(J) = WQTY
               Endif
            Else
               # Quantité sur liste de préparation
               [M]QTYLPR(J) = WQTY
               [M]DLVFLG(J) = 0
            Endif
            WPE_TYPLIG="LPR" : Gosub PE_ALIORDETA
            J+=1
            If J=dim([M]ITMREF) Call MESSAGE (mess(26,100,1)) From GESECRAN : Break Endif
            Raz [M]ITMREF(J), [M]QTY(J), [M]SAU(J), [M]DLVFLG(J)
            [M]SOQSTA(J)=0 : # Bug 83943
         Next
      Endif
      If sum([M:SOH4]OPRQTY(I),[M:SOH4]PREQTY(I))<>0 & (WOPRQTY<>[M:SOH4]OPRQTY(I) | WPREQTY<>[M:SOH4]PREQTY(I))
         # Il y a des bons de préparations pour cette commande qui ne sont pas liés à des listes de préparations
         #--- Issue 116484
         #For [PRE] Where [PRE]ORITYP=WORITYP & [PRE]ORINUM=[M:SOH0]SOHNUM & [PRE]ORILIN=[M:SOH4]SOPLIN(I) &
#&                        [PRE]ORISEQ=[M:SOH4]SOPLIN(I)
         For [PRE] Where [PRE]ORINUM=[M:SOH0]SOHNUM & [PRE]ORILIN=[M:SOH4]SOPLIN(I) &
&                        [PRE]ORISEQ=[M:SOH4]SOPLIN(I) & [PRE]ORITYP=WORITYP
         #---
            If !find([F:PRE]PRHNUM, [M]PRHNUM(WIND_LIN..J-1)) : # Bug 58070
               If [F:PRH]PRHNUM <> [F:PRE]PRHNUM
                  Read [PRH]PRH0=[F:PRE]PRHNUM
                  If fstat Raz [F:PRH] Endif
               Endif
               If [F:PRH]PRHNUM<>""
                  [M]PRHNUM(J) = [F:PRE]PRHNUM
                  WQTY=[F:PRE]QTYSTU*(1/[M:SOH4]SAUSTUCOE(I))
                  Call QTEARR(WQTY, [M:SOH4]SAU(I)) From TRTDIV
                  [M]DLVFLG(J) = [F:PRH]DLVFLG
                  If [F:PRH]DLVFLG=3
                     If [F:PRH]SDHNUM <> ""
                        If [F:SDH]SDHNUM <> [F:PRH]SDHNUM
                           Read [SDH]SDH0=[F:PRH]SDHNUM
                           If fstat Raz [F:SDH] Endif
                        Endif
                        [M]SDHNUM(J) = [F:SDH]SDHNUM
                        [M]SHIDAT(J) = [F:SDH]SHIDAT
                        # On ne sait pas remonter sur le détail livraison
                        # Issue 121186
#                        [M]QTYLIV(J) = WQTY
                        Raz [M]QTYLIV(J)
                        Raz [M]QTYRET(J)
                        For [SDD] Where [SDD]SDHNUM=[F:SDH]SDHNUM & [SDD]PRHNUM=[F:PRE]PRHNUM &
&                           [SDD]PRELIN=[F:PRE]PRELIN
                            [M]QTYLIV(J) += [F:SDD]QTY
                            [M]QTYRET(J) += [F:SDD]RTNQTY
                        Next
                        #[M]QTYRET(J) = 0
                        # End issue 121186
                        [M]NUM(J)    = [F:SDH]SIHNUM
                        If [F:SDH]SIHNUM <> ""
                           # On ne sait pas remonter sur le détail facture
                           # Issue 121186
                           #[M]QTYFAC(J) = WQTY
                           [M]QTYFAC(J) = [M]QTYLIV(J)
                           # End issue 121186
                           # 107888 : Scheduled invoices : (LD:31/05/16)
                           If [F:SIV]NUM <> [F:SDH]SIHNUM
                              Read [SIV]SIV0=[F:SDH]SIHNUM
                              If fstat Raz [F:SIV] Endif
                           Endif
                           [M]INVDAT(J) = [F:SIV]INVDAT
                           # 107888 : Scheduled invoices : (LD:31/05/16)
                        Endif
                     Endif
                     # Quantité livrée
                     # Issue 121186
                     #WQTYDLV     += WQTY
                     WQTYDLV     += [M]QTYLIV(J)
                     # End issue 121186
                  Elsif [F:PRH]DLVFLG=2
                     # Quantité préparée
                     [M]QTYPRE(J) = WQTY
                  Elsif [F:PRH]DLVFLG<>4
                     # Quantité en préparation
                     [M]QTYPRE(J) = WQTY
                  Endif
                  WPE_TYPLIG="PRH" : Gosub PE_ALIORDETA
                  J+=1
                  If J=dim([M]ITMREF) Call MESSAGE (mess(26,100,1)) From GESECRAN : Break Endif
                  Raz [M]ITMREF(J), [M]QTY(J), [M]SAU(J)
                  [M]SOQSTA(J)=0 : # Bug 83943
               Endif
            Endif
         Next
      Endif
      If sum([M:SOH4]ODLQTY(I),[M:SOH4]DLVQTY(I))<>0 & WQTYDLV<>sum([M:SOH4]ODLQTY(I), [M:SOH4]DLVQTY(I))
         # Il y a des bons de livraisons pour cette commande qui ne sont pas liés à des bons de préparations
         Filter [SDD] Where [SDD]SOHNUM=[M:SOH0]SOHNUM & [SDD]SOPLIN=[M:SOH4]SOPLIN(I)
&                     Order By Key SDW0=[F:SDD]SHIDAT;[F:SDD]SDHNUM
         For [F:SDD]SDW0
            Read [SDH]SDH0=[F:SDD]SDHNUM
            If !fstat
               # Issue 121186
#               If [F:SDD]PRHNUM<>"" & !find([F:SDD]PRHNUM, [M]PRHNUM(WIND_LIN..J-1))  : # Bug 56066
#                   [M]PRHNUM(J) = [F:SDD]PRHNUM                                       : # Bug 56066
#                   [M]DLVFLG(J) = 3                                                   : # Bug 56066
#               Else                                                                   : # Bug 83943
#                   [M]DLVFLG(J) = 0                                                   : # Bug 83943
#               Endif                                                                  : # Bug 56066
#               [M]SDHNUM(J) = [F:SDD]SDHNUM
#               [M]SHIDAT(J) = [F:SDD]SHIDAT
#               [M]QTYLIV(J) = [F:SDD]QTY
#               [M]QTYRET(J) = [F:SDD]RTNQTY
#               [M]NUM(J)    = [F:SDH]SIHNUM
#               [M]FMI(J)    = [M:SOH4]FMI(I)
#               #[M]DLVFLG(J) = 0 : # Bug 56066
#               If [F:SDH]SIHNUM <> ""
#                  Read [SID]SID3=[F:SDD]SDHNUM;[F:SDD]SDDLIN
#                  If fstat Raz [F:SID] Endif
#                  [M]QTYFAC(J) = [F:SID]QTY
#                  # 107888 : Scheduled invoices : (LD:31/05/16)
#                  [M]INVDAT(J) = [F:SID]INVDAT
#                  # 107888 : Scheduled invoices : (LD:31/05/16)
#               Endif
#               WPE_TYPLIG="SDD" : Gosub PE_ALIORDETA
#               J+=1
#               If J=dim([M]ITMREF) Call MESSAGE (mess(26,100,1)) From GESECRAN : Break Endif
#               Raz [M]ITMREF(J), [M]QTY(J), [M]SAU(J)
#               [M]SOQSTA(J)=0 : # Bug 83943
               If [F:SDD]PRHNUM="" | !find([F:SDD]PRHNUM, [M]PRHNUM(WIND_LIN..J-1))
                   If [F:SDD]PRHNUM<>""
                       [M]PRHNUM(J) = [F:SDD]PRHNUM
                       [M]DLVFLG(J) = 3
                   Else
                       [M]DLVFLG(J) = 0
                   Endif
                   [M]SDHNUM(J) = [F:SDD]SDHNUM
                   [M]SHIDAT(J) = [F:SDD]SHIDAT
                   [M]QTYLIV(J) = [F:SDD]QTY
                   [M]QTYRET(J) = [F:SDD]RTNQTY
                   [M]NUM(J)    = [F:SDH]SIHNUM
                   [M]FMI(J)    = [M:SOH4]FMI(I)
                   #[M]DLVFLG(J) = 0 : # Bug 56066
                   If [F:SDH]SIHNUM <> ""
                      Read [SID]SID3=[F:SDD]SDHNUM;[F:SDD]SDDLIN
                      If fstat Raz [F:SID] Endif
                      [M]QTYFAC(J) = [F:SID]QTY
                      # 107888 : Scheduled invoices : (LD:31/05/16)
                      [M]INVDAT(J) = [F:SID]INVDAT
                      # 107888 : Scheduled invoices : (LD:31/05/16)
                   Endif
                   WPE_TYPLIG="SDD" : Gosub PE_ALIORDETA
                   J+=1
                   If J=dim([M]ITMREF) Call MESSAGE (mess(26,100,1)) From GESECRAN : Break Endif
                   Raz [M]ITMREF(J), [M]QTY(J), [M]SAU(J)
                   [M]SOQSTA(J)=0 : # Bug 83943
               Endif
               # End issue 121186
            Endif
         Next
         Filter [SDD]
      Endif
   Endif
   If J=dim([M]ITMREF) Break Endif

   If [M]ITMREF(J)<>"" J+=1 Endif
   If J=dim([M]ITMREF) Call MESSAGE (mess(26,100,1)) From GESECRAN : Break Endif
Next I
[M]NBLIG = J

Return

$PE_ALIORDETA

# -------------------------------------------------------------------------
# Point d'entrée ALIORDETA pour affichage champs spécifiques
# -------------------------------------------------------------------------
GPOINT="ALIORDETA" : Gosub ENTREE From EXEFNC

Return

# Chargement du masque visualisation commande
$CHARGE_SDIANC

Raz [M]
Raz I,J

For I=0 To [M:SOH4]NBLIG-1
   [M]ITMREF(J) = [M:SOH4]ITMREF(I)
   [M]QTY(J)    = [M:SOH4]QTY(I)
   [M]ALLQTY(J) = [M:SOH4]ALLQTY(I)
   [M]SHTQTY(J) = [M:SOH4]SHTQTY(I)
   [M]SOQSTA(J) = [M:SOH4]SOQSTA(I)
   [M]SAU(J)    = [M:SOH4]SAU(I)
   [M]FMINUM(J) = [M:SOH4]FMINUM(I)
   [M]FMI(J)    = [M:SOH4]FMI(I)
   If [M:SOH0]SOHCAT = 3
      For [SID]SID0 Hint Key SID1
&                   Where [SID]BPCINV=[M:SOH1]BPCINV & [SID]SALFCY=[M:SOH0]SALFCY &
&                         [SID]SOHNUM=[M:SOH0]SOHNUM & [SID]SOPLIN=[M:SOH4]SOPLIN(I)
         If [F:SIV]NUM<>[F:SID]NUM
             Read [SIV]SIV0=[F:SID]NUM
             If fstat Raz [F:SIV] Endif
         Endif
         If [F:SIV]NUM=[F:SID]NUM & [F:SIV]INVTYP=1
            [M]SAU(J)    = [M:SOH4]SAU(I)
            [M]SOQSTA(J) = [M:SOH4]SOQSTA(I)
            [M]NUM(J)    = [F:SID]NUM
            [M]INVDAT(J) = [F:SIV]INVDAT
            [M]QTYFAC(J) = [F:SID]QTY
            [M]FMI(J)    = [M:SOH4]FMI(I)
            J+=1
#            If J=WSOHACV Break Endif
            If J=dim([M]ITMREF) Call MESSAGE (mess(26,100,1)) From GESECRAN : Break Endif

            Raz [M]ITMREF(J), [M]QTY(J), [M]SAU(J)
         Endif
      Next
   Else
      Filter [SDD] Where [SDD]SOHNUM=[M:SOH0]SOHNUM & [SDD]SOPLIN=[M:SOH4]SOPLIN(I)
&                  Order By Key SDW0=[F:SDD]SHIDAT;[F:SDD]SDHNUM
      For [F:SDD]SDW0
         Read [SDH]SDH0=[F:SDD]SDHNUM
         If !fstat
            [M]SAU(J)    = [M:SOH4]SAU(I)
            [M]SOQSTA(J) = [M:SOH4]SOQSTA(I)
            [M]SDHNUM(J) = [F:SDD]SDHNUM
            [M]SHIDAT(J) = [F:SDD]SHIDAT
            [M]QTYLIV(J) = [F:SDD]QTY
            [M]QTYRET(J) = [F:SDD]RTNQTY
            [M]NUM(J)    = [F:SDH]SIHNUM
            [M]FMI(J)    = [M:SOH4]FMI(I)
            If [F:SDH]SIHNUM <> "" [M]QTYFAC(J) = [F:SDD]QTY - [F:SDD]RTNQTY : Endif
            J+=1
#            If J=WSOHACV Break Endif
            If J=dim([M]ITMREF) Call MESSAGE (mess(26,100,1)) From GESECRAN : Break Endif
            Raz [M]ITMREF(J), [M]QTY(J), [M]SAU(J)
         Endif
      Next
      Filter [SDD]
   Endif
   If [M]ITMREF(J)<>"" J+=1 Endif
#   If J=WSOHACV Break Endif
   If J=dim([M]ITMREF) Call MESSAGE (mess(26,100,1)) From GESECRAN : Break Endif

Next I
[M]NBLIG = J

Return
#------------------------------------------------------------------------------#
$FIN_TRTORDETA

nolign=SNOL

Return

################################################################################
# TRTRPLITM : Gestion d'un article de remplacement                             #
################################################################################

$INI_TRTRPLITM
Local     Char    WITM        :    WITM = PARAM(1)
Local     Char    WFCY        :    WFCY = PARAM(2)
Local     Decimal WQTY        :    WQTY = val(PARAM(3))
Local     Char    WSAU        :    WSAU = PARAM(4)
Local     Date    WDAT        :    WDAT = PARAM(5)
Local     Char    WFLDNAM     :    WFLDNAM = PARAM(6)

Local     Integer WRET        :    WRET=0
Local     Integer WSTA
Local     Decimal WDISPO

Return

$OUV_TRTRPLITM
Local     Char    WITM        :    WITM = PARAM(1)
Local     Char    WFCY        :    WFCY = PARAM(2)
Local     Decimal WQTY        :    WQTY = val(PARAM(3))
Local     Char    WSAU        :    WSAU = PARAM(4)
Local     Date    WDAT        :    WDAT = PARAM(5)
Local     Integer WRET        :    WRET = 0

Local     Integer SNOL        :    SNOL = nolign
Local     Char    SAVZONCOU   :    SAVZONCOU = zoncou
Local     Char    WRPLITM

If clalev([F:TRU]) =0  Local File TABALLRUL  [TRU]   Endif
If clalev([F:ITF]) =0  Local File ITMFACILIT [ITF]   Endif
If clalev([F:ITG]) =0  Local File ITMCATEG   [ITG]   Endif
If clalev([F:ITV]) =0  Local File ITMMVT     [ITV]   Endif

Return

#------------------------------------------------------------------------------#
$DEB_TRTRPLITM

Gosub CHARGE_SRM
If WRET=1 FIN=1 Endif

Return

#------------------------------------------------------------------------------#
$CHARGE_SRM
# Lecture de l'article à remplacer
If [F:ITM]ITMREF <> WITM
    Read [ITM]ITM0=WITM
    If fstat Return Endif
Endif
If [F:ITM]RPLITM = "" Return Endif
WRPLITM = [F:ITM]RPLITM

Read [ITM]ITM0=WRPLITM
If fstat Return Endif
Read [ITS]ITS0=WRPLITM
If fstat Return Endif

[M]ITMREF  = WRPLITM
#[M]ITMDES1 = [F:ITS]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M]ITMDES1, "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56270
[M]QTY     = WQTY
[M]SAU     = WSAU
[M]STOFCY  = WFCY
[M]STU     = [F:ITM]STU

If [F:ITM]STOMGTCOD=1 Return Endif

# Lecture des tables article
Call LECITM2(WFCY,WRPLITM,"",WRET) From STKLIB
If WRET<>0 : Return : Endif

If [F:ITF]STOMGTCOD=1 Return Endif

[M]PHYSTO    = [F:ITV]PHYSTO
[M]CTLSTO    = [F:ITV]CTLSTO
[M]REJSTO    = [F:ITV]REJSTO
[M]PHYALL    = [F:ITV]PHYALL + [F:ITV]CTLALL + [F:ITV]REJALL
[M]DETSHT    = [F:ITV]DETSHT
[M]GLOALL    = [F:ITV]GLOALL
[M]GLOSHT    = [F:ITV]GLOSHT
[M]PLFPHYSTO = [F:ITV]PLFPHYSTO + [F:ITV]PLFCTLSTO + [F:ITV]PLFREJSTO
[M]SCOPHYSTO = [F:ITV]SCOPHYSTO + [F:ITV]SCOCTLSTO + [F:ITV]SCOREJSTO
[M]BPRPHYSTO = [F:ITV]BPRPHYSTO + [F:ITV]BPRCTLSTO + [F:ITV]BPRREJSTO
[M]WAISTO    = [F:ITV]WAISTO

#--- calcul du stock dispo
WSTA=0
WDISPO=0
If [F:ITG]GLOAAAFLG = 2   WSTA += 1  Endif
If [F:ITG]GLOQQQFLG = 2   WSTA += 2  Endif
If [F:ITG]GLORRRFLG = 2   WSTA += 4  Endif
#--- TS 106217
#Call STODISPO("",WFCY,WRPLITM,"*","*",1,WSTA,"","","",WDISPO) From STKLIB
Call STODISPO("",WFCY,WRPLITM,"*","*",1,WSTA,"","","","",WDISPO) From STKLIB
#---
[M]AVASTO= WDISPO

Return

#------------------------------------------------------------------------------#
$SETB_TRTRPLITM
If [F:ITM]STOMGTCOD=1 | [F:ITF]STOMGTCOD=1
    Call VIREBOUT(CHMEN, "12") From GOBJET     : # interro stock et disponible à la vente
Endif
Return

#------------------------------------------------------------------------------#
$OK_TRTRPLITM

WRET=2
WITM = WRPLITM
FIN=1

Return

#------------------------------------------------------------------------------#
$FIN_TRTRPLITM
zoncou=SAVZONCOU
nolign=SNOL

PARAM(1) = WITM
PARAM(6) = num$(WRET)

Return

#------------------------------------------------------------------------------#
$EXEC_TRTRPLITM
Local Integer NOL      : NOL=nolign-1

WITM=PARAM(1)
WRET=val(PARAM(6))

# traitement de remplacement
If WRET <> 2 FIN=1 : Return : Endif

Gosub TRT_RPLITM From SUBSOHB
If !mkstat
#   Tout s'est bien passé
#   Si on vient de l'article
    If WFLDNAM = "ITMREF" VALEUR = WITM Endif
    Affzo [M:SOH4]ITMREF(NOL)
    Affzo [M:SOH4]ITMDES(NOL), ITMDES1(NOL), SAU(NOL), SAUSTUCOE(NOL), LINTYP(NOL)
    Affzo [M:SOH4]VACITM1(NOL), VACITM2(NOL),VACITM3(NOL)
    Affzo [M:SOH4]PCK(NOL), PCKCAP(NOL), DEMSTA(NOL)
    Affzo [M:SOH4]FMI(NOL)
    If [M:SOH4]QTY(NOL) <> 0
        Gosub AFF_RECH_TAR From SUBSOH
        Affzo [M:SOH4]CPRPRI(NOL), PFM(NOL)
    Endif
#    If dim([M]CCE1(NOL))>0 Affzo [M]CCE1(NOL) : Endif
#    If dim([M]CCE2(NOL))>0 Affzo [M]CCE2(NOL) : Endif
#    If dim([M]CCE3(NOL))>0 Affzo [M]CCE3(NOL) : Endif
#    If dim([M]CCE4(NOL))>0 Affzo [M]CCE4(NOL) : Endif
#    If dim([M]CCE5(NOL))>0 Affzo [M]CCE5(NOL) : Endif
#    If dim([M]CCE6(NOL))>0 Affzo [M]CCE6(NOL) : Endif
#    If dim([M]CCE7(NOL))>0 Affzo [M]CCE7(NOL) : Endif
#    If dim([M]CCE8(NOL))>0 Affzo [M]CCE8(NOL) : Endif
#    If dim([M]CCE9(NOL))>0 Affzo [M]CCE9(NOL) : Endif
    [M]WIPFLG(nolign-1) = "A" :
    If (WFLDNAM="QTY" & [M]QTY(NOL) <> 0) mkstat=4 Endif
Endif

Return

################################################################################
# VISUDERLIV : Visu des dernières livraisons                                   #
################################################################################

$OUV_VISUDERLIV
Local Integer  SNOL,NOL

SNOL=nolign
If clalev ([F:SDD]) <= 0 Local File SDELIVERYD [SDD] Endif
If clalev ([F:SOC]) <= 0 Local File SORDERC [SOC]    Endif
If [F:SOC]SOHNUM<>[M:SOQ1]SOHNUM & [F:SOC]SOPLIN<>[M:SOQ1]SOPLIN
   Read [SOC]SOC0=[M:SOQ1]SOHNUM;[M:SOQ1]SOPLIN
   If fstat
      Call RSTA ("SOC",[M:SOQ1]SOHNUM-num$([M:SOQ1]SOPLIN)) From GLOCK
      FIN=1
   Endif
Endif
Return

#------------------------------------------------------------------------------#
$DEB_VISUDERLIV

Raz [M:SLV]
Raz NOL

Filter [SDD] Where [F:SDD]SOHNUM = [M:SOQ1]SOHNUM & [F:SDD]SOPLIN = [M:SOQ1]SOPLIN
&            Order By Key SDD9 = [F:SDD]SHIDAT Desc;[F:SDD]SDHNUM Desc
For [F:SDD]SDD9
   [M:SLV]SDHNUM(NOL) = [F:SDD]SDHNUM
   [M:SLV]SHIDAT(NOL) = [F:SDD]SHIDAT
   [M:SLV]QTY(NOL)    = [F:SDD]QTY
   [M:SLV]SAU(NOL)    = [F:SDD]SAU
   If NOL = 0
      [M:SLV]QTYCUM(NOL) = [F:SOC]DLVQTYCUM
   Else
      [M:SLV]QTYCUM(NOL) = [M:SLV]QTYCUM(NOL-1) - [M:SLV]QTY(NOL-1)
   Endif
   NOL += 1
   If NOL=30 Break Endif
Next
Filter [SDD]
[M:SLV]NBLIG = NOL
Return

#------------------------------------------------------------------------------#
$FIN_VISUDERLIV
nolign=SNOL
Return

################################################################################
# VISUDERPRI  : Visu des derniers prix appliqués sur un article dans les cdes  #
################################################################################

$OUV_VISUDERPRI
Local   Char     ART(GLONITV) : ART = PARAM(1)
Local   Char     CLI(GLONBPC) : CLI = PARAM(2)
Local   Char     SOC(GLONCPY) : SOC = PARAM(3)

Local   Integer  SNOL,NOL,I
Local   Char     SAVGCOLREM(20)(0..8)
Local   Char     SAVGFMTREM(1)(0..8)
Local   Char     SAVGFMTCOL(20)(0..8)
Local   Char     SAVGFORREM(20)(0..8)

For I=0 To 8
    SAVGCOLREM(I)=GCOLREM(I)
    SAVGFMTREM(I)=GFMTREM(I)
    SAVGFMTCOL(I)=GFMTCOL(I)
    SAVGFORREM(I)=GFORREM(I)
Next

SNOL=nolign
If clalev ([F:SOH]) <= 0 Local File SORDER     [SOH] : Endif
If clalev ([F:SOP]) <= 0 Local File SORDERP    [SOP] : Endif
If clalev ([F:SOQ]) <= 0 Local File SORDERQ    [SOQ] : Endif
If clalev ([F:TCU]) <= 0 Local File TABCUR     [TCU] : Endif
If clalev ([F:BPC]) <= 0 Local File BPCUSTOMER [BPC] : Endif
If clalev ([F:CPY]) <= 0 Local File COMPANY    [CPY] : Endif

If [F:CPY]CPY<>SOC
    Read [CPY] CPY0=GSOCIETE
    If fstat Raz [F:CPY] Endif
Endif

Call COLREM("C",1,[F:CPY]PLISTC) From TRTPRICE
Return

#------------------------------------------------------------------------------#
# FGR 12/01/2014 : X3SUIVI103019 (début)
$DEB_VISUDERPRI
  Raz [M:SVDP]
  If CLI <> [F:BPC]BPCNUM Then
    Read [BPC]BPC0=CLI
    If fstat Then
      Raz [F:BPC]BPCNAM
    Endif
  Endif
  #
  Link [SOQ] With [F:SOH]SOH0=[F:SOQ]SOHNUM,
&                 [F:SOP]SOP0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
&              As [LNK]
&           Where [F:SOP]ITMREF = ART and [F:SOP]BPCORD = CLI and [F:SOP]CPY = SOC and [F:SOP]SOHCAT <> 4
&           Order By Key CLE=[F:SOH]ORDDAT Desc;[F:SOH]SOHNUM Desc;[F:SOQ]SOPLIN Desc;[F:SOQ]SOQSEQ Desc
  #
  nolign = 1
  For [LNK]
      If [F:SOH]PLISTC = [F:CPY]PLISTC Then
        [M:SVDP] = [F:SOH]
        [M:SVDP] = [F:SOP]
        [M:SVDP] = [F:SOQ]
        nolign += 1
        If nolign = dim([M:SVDP]NUMLIG)+1 Then
          Break
        Endif
      Endif
  Next
  [M:SVDP]BPCNAM = [F:BPC]BPCNAM
  NOL = nolign
  If nolign <> 1 Then
    [M:SVDP]NBLIG = NOL-1
  Else
    FIN = 1
    GERR = 1
    GMESSAGE = mess(137,191,1)
  Endif
Return

#$DEB_VISUDERPRI
#
#Raz [M:SVDP]
#
#If CLI<>[F:BPC]BPCNUM
#   Read [BPC]BPC0=CLI
#   If fstat Raz [F:BPC]BPCNAM Endif
#Endif
#
##Filter [SOP] Where ITMREF=ART & BPCORD = CLI Order By ENDDAT Desc;SOHNUM DESC
#Filter [SOP] Where ITMREF=ART & BPCORD=CLI & CPY=SOC & SOHCAT<>4 Order By Key SOP1 Desc
#nolign=1
#For [SOP]
#    Read [SOH]SOH0=[SOP]SOHNUM
#    If fstat = 0
##        If [F:SOH]SOHCAT <> 4
#        If [F:SOH]PLISTC=[F:CPY]PLISTC
#            Read [SOQ]SOQ0=[SOP]SOHNUM;[SOP]SOPLIN;[SOP]SOPSEQ
#            If fstat Raz [F:SOQ]: Endif
##            Call FMTREM("SVDP", [F:SOH]CUR) From TRTPRICE
##            For I=0 To 8
##                Assign "[M]FMTREM"+num$(I+1)+"(nolign-1)" With [M]FMTREM(I)
##            Next
#            [M:SVDP] = [F:SOH]:[M:SVDP] = [F:SOP]:[M:SVDP] = [F:SOQ]
#            nolign+=1
#            If nolign=dim([M:SVDP]NUMLIG)+1: Break : Endif
#        Endif
#    Endif
#Next
#Filter [SOP]
#
#[M:SVDP]BPCNAM=[F:BPC]BPCNAM
#
#NOL=nolign
#If nolign <> 1
#    [M:SVDP]NBLIG = NOL-1
#Else
#    FIN=1 : GERR=1 : GMESSAGE=mess(137,191,1)
#Endif
#
#Return
# FGR 12/01/2014 : X3SUIVI103019 (fin)

#------------------------------------------------------------------------------#
$FIN_VISUDERPRI

nolign=SNOL

For I=0 To 8
    GCOLREM(I)=SAVGCOLREM(I)
    GFMTREM(I)=SAVGFMTREM(I)
    GFMTCOL(I)=SAVGFMTCOL(I)
    GFORREM(I)=SAVGFORREM(I)
Next

Return

################################################################################
# VISUDETALL : Visu du détail des allocations d'une ligne cde, liv ou fac      #
################################################################################

$OUV_VISUDETALL
Local Char    WABMSK   : WABMSK = PARAM(1)
Local Char    SITE     : SITE   = PARAM(2)
Local Integer TYP      : TYP    = val(PARAM(3))
Local Char    NUM      : NUM    = PARAM(4)
Local Integer LIN      : LIN    = val(PARAM(5))
Local Integer SEQ1     : SEQ1   = val(PARAM(6))

Local Integer SNOL, NOL,I
Local Decimal WQTY

SNOL=nolign
If clalev ([F:STA]) <= 0 Local File STOALL    [STA] : Endif
If clalev ([F:STO]) <= 0 Local File STOCK     [STO] : Endif
If clalev ([F:ITM]) <= 0 Local File ITMMASTER [ITM] : Endif
If clalev ([F:STL]) <= 0 Local File STOLOT    [STL] : Endif

Return

#------------------------------------------------------------------------------#
$DEB_VISUDETALL
# Chargement du masque de détail des allocations
Gosub CHARGE_SDA
#Affzo [M]1-99
Return

#------------------------------------------------------------------------------#
$SETB_VISUDETALL

If (WABMSK="SDH1" & [M:SDH1]QTY(SNOL-1)=[M:SDH1]YQTY(SNOL-1))
&   | (WABMSK="SIH4" & [M:SIH4]QTY(SNOL-1)=[M:SIH4]YQTY(SNOL-1))
    ETABOU(GSPE1) = 1 : # Modification
# Ctrl autorisation modification
    If !find (GREP, "C", "D")
        GBIDC2="M": Gosub AUTORIS_OPT From CONTX3
        If !GBIDI2  ETABOU(GSPE1) = 0 : Endif
    Endif
Else
    ETABOU(GSPE1) = 0
Endif
#ETABOU(GABAN) = 1 :    # Fin

Return
#------------------------------------------------------------------------------#
$BOUT_VISUDETALL

If GOK = 1 Gosub CHARGE_SDA : Affzo [M]1-99 : Endif

Return

#------------------------------------------------------------------------------#
$FIN_VISUDETALL

nolign=SNOL

Return

#------------------------------------------------------------------------------#
# Chargement du masque de détail des allocations
$CHARGE_SDA
Raz [M]
If WABMSK = "SOQ1"
   [M]XITMREF  = evalue("[M:"+WABMSK+"]ITMREF")
   [M]XITMDES1 = evalue("[M:"+WABMSK+"]ITMDES1")
   [M]XSTU     = evalue("[M:"+WABMSK+"]STU")
Else
   [M]XITMREF  = evalue("[M:"+WABMSK+"]ITMREF(SNOL-1)")
   [M]XITMDES1 = evalue("[M:"+WABMSK+"]ITMDES1(SNOL-1)")
   [M]XSTU     = evalue("[M:"+WABMSK+"]STU(SNOL-1)")
Endif

[M]XSTOFCY  = SITE

Raz WQTY
Filter [STA] Where VCRTYP=TYP & VCRNUM=NUM & VCRLIN=LIN & VCRSEQ= SEQ1
&           Order By Key STA1
nolign=1
For [STA]
   If find([F:STA]ALLTYP,2,4)
      WQTY += [F:STA]QTYSTUACT
   Endif
   [M:SDA]=[F:STA]
   Case [F:STA]ALLTYP
    When 1,3,4,5 : [M]ALLTYP(nolign-1) = [F:STA]ALLTYP
                   [M]XQTY(nolign-1)   = [F:STA]QTYSTUACT
                   nolign+=1
    When 2       : Read [STO]STO0=[F:STA]STOFCY;[F:STA]STOCOU
                   If fstat = 0
                      [M]ALLTYP(nolign-1) = [F:STA]ALLTYP
                      [M]XQTY(nolign-1)   = [F:STA]QTYSTUACT
                      [M]LOT(nolign-1)    = [F:STO]LOT
                      [M]SLO(nolign-1)    = [F:STO]SLO
                      # FGR 30/04/2015 : X3SUIVI105605 (début)
                      If dim([M]ECCVALMAJ) >= 0 Then
                        [M]ECCVALMAJ(nolign-1) = [F:STO]ECCVALMAJ
                      Endif
                      If dim([M]ECCVALMIN) >= 0 and dim([M]ECCVALMAJ) >= 0 and [M]ECCVALMAJ(nolign-1) <> "" Then
                        # Pour ne le faire que si la version majeure est alimentée
                        Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
                        If !fstat Then
                          [M]ECCVALMIN(nolign-1) = [F:STL]ECCVALMIN
                        Endif
                      Endif
                      # FGR 30/04/2015 : X3SUIVI105605 (fin)
                      [M]LOC(nolign-1)    = [F:STO]LOC
                      [M]STA(nolign-1)    = [F:STO]STA
                      [M]PALNUM(nolign-1) = [F:STO]PALNUM
                      [M]CTRNUM(nolign-1) = [F:STO]CTRNUM
                      [M]SERNUM(nolign-1) = [F:STO]SERNUM
                      [M]OWNER(nolign-1)  = [F:STO]OWNER
                      [M]PCU(nolign-1)    = [F:STO]PCU
                      [M]XQTYPCU(nolign-1) = [F:STA]QTYSTU / [F:STO]PCUSTUCOE
                      Call QTEARR([M]XQTYPCU(nolign-1),[F:STO]PCU) From TRTDIV
                      If [F:ITM]ITMREF<>[M]XITMREF
                          Read [ITM]ITM0=[M]XITMREF
                          If fstat Raz [F:ITM] Endif
                      Endif
                      # Si article géré en lot : récup date péremption
                      If [F:ITM]LOTMGTCOD>1
                          Read [STL]STL0=[M]XITMREF;[M]LOT(nolign-1);[M]SLO(nolign-1)
                          If !fstat [M]SHLDAT(nolign-1) = [F:STL]SHLDAT : Endif
                      Endif
                      nolign+=1
                   Endif
    When Default
   Endcase
   # FGR 13/11/2009 : X3SUIVI59852
   #If nolign=50 Break Endif
   If nolign = dim([M:SDA]ALLTYP) Then Break Endif
Next
Filter [STA]

NOL=nolign
[M:SDA]NBLIG = NOL-1

Return

################################################################################
# VISUDETLOT : Visualisation du stock lot                                      #
################################################################################

$OUV_VISUDETLOT
Local Char    WABMSK
Local Integer TYP
Local Integer WTYP         : # Issue X3-69499 06.01.2018 By TS
Local Integer SNOL, NOL, I

SNOL   = nolign
WABMSK = PARAM(1)
TYP    = val(PARAM(2))

If TYP = 41
    If [M]CFMFLG = 2 TYP +=1 Endif
Elsif TYP = 51
    If [M]INVSTA = 3 TYP +=1 Endif
Endif


# Issue X3-69499 06.01.2018 By TS
Case TYP
 When 21,51    : If clalev ([F:STA]) <= 0 Local File STOALL    [STA] : Endif
                 If clalev ([F:STO]) <= 0 Local File STOCK     [STO] : Endif
                 If clalev ([F:STL]) <= 0 Local File STOLOT    [STL] : Endif
                 If clalev ([F:ITM]) <= 0 Local File ITMMASTER [ITM] : Endif
 When 41       : If clalev ([F:STA]) <= 0 Local File STOALL    [STA] : Endif
                 If clalev ([F:STO]) <= 0 Local File STOCK     [STO] : Endif
                 If clalev ([F:STL]) <= 0 Local File STOLOT    [STL] : Endif
                 If clalev ([F:ITM]) <= 0 Local File ITMMASTER [ITM] : Endif
                 If clalev ([F:STJ]) <= 0 Local File STOJOU    [STJ] : Endif
 When 42,52    : If clalev ([F:STJ]) <= 0 Local File STOJOU    [STJ] : Endif
Endcase
#Case TYP
# When 21,41,51 : If clalev ([F:STA]) <= 0 Local File STOALL    [STA] : Endif
#                 If clalev ([F:STO]) <= 0 Local File STOCK     [STO] : Endif
#                 If clalev ([F:STL]) <= 0 Local File STOLOT    [STL] : Endif
#                 If clalev ([F:ITM]) <= 0 Local File ITMMASTER [ITM] : Endif
# When 42,52    : If clalev ([F:STJ]) <= 0 Local File STOJOU    [STJ] : Endif
#Endcase
# End issue X3-69499

Return

#------------------------------------------------------------------------------#
$DEB_VISUDETLOT
Local Char WITMREF

Raz [M]

Raz NOL
For I=0 To evalue("[M:"+WABMSK+"]NBLIG-1")
   [M]XITMREF(NOL) = evalue("[M:"+WABMSK+"]ITMREF(I)")
   [M]XQTY(NOL)    = evalue("[M:"+WABMSK+"]QTYSTU(I)")
   [M]XSTU(NOL)    = evalue("[M:"+WABMSK+"]STU(I)")
   WITMREF = [M]XITMREF(NOL)
   Raz [M]LOT(NOL), [M]LOC(NOL), [M]STA(NOL)

   # Issue X3-69499 06.01.2018 By TS
   WTYP=TYP
   If WTYP=41 & evalue("[M:"+WABMSK+"]LINCFMFLG(I)")=2
     WTYP=42
   Endif
   # End issue X3-69499

   # Issue X3-69499 06.01.2018 By TS : replace TYP with WTYP
   Case WTYP
    When 21 : Filter [STA] Where VCRTYP=2 & VCRNUM=[M:SOH0]SOHNUM &
&                                VCRLIN=[M:SOH4]SOPLIN(I) Order By Key STA1
    When 41 : Filter [STA] Where VCRTYP=4 & VCRNUM=[M:SDH0]SDHNUM &
&                                VCRLIN=[M:SDH1]SDDLIN(I) Order By Key STA1
    When 51 : Filter [STA] Where VCRTYP=5 & VCRNUM=[M:SIH0]NUM &
&                                VCRLIN=[M:SIH4]SIDLIN(I) Order By Key STA1
    When 42 : Filter [STJ] Where STOFCY=[M:SDH0]STOFCY & VCRTYP=4 & VCRNUM=[M:SDH0]SDHNUM &
&                                VCRLIN=[M:SDH1]SDDLIN(I) & REGFLG<>2 Order By Key STJ1
    When 52 : Filter [STJ] Where STOFCY=[M:SIH1]STOFCY & VCRTYP=5 & VCRNUM=[M:SIH0]NUM &
&                                VCRLIN=[M:SIH4]SIDLIN(I) & REGFLG<>2 Order By Key STJ1
   Endcase
   nolign=NOL+1

   # Issue X3-69499 06.01.2018 By TS : replace TYP with WTYP
   Case WTYP
    When 21, 41,51 : For [STA]
                        [M:SDL]=[F:STA]
                        Raz [M:SDL]WRUPT(NOL)
                        Case [F:STA]ALLTYP
                         When 1 : [M]LOT(NOL)  = ""                          : # Global
                                  [M]XQTY(NOL) = [F:STA]QTYSTUACT
                                  [M]XSTU(NOL) = evalue("[M:"+WABMSK+"]STU(I)")
                                  NOL += 1
                         When 2 : Read [STO]STO0=[F:STA]STOFCY;[F:STA]STOCOU : # Détail
                                  If fstat = 0
                                     [M]XQTY(NOL)   = [F:STA]QTYSTUACT
                                     [M]XSTU(NOL)   = evalue("[M:"+WABMSK+"]STU(I)")
                                     [M]LOT(NOL)    = [F:STO]LOT
                                     [M]SLO(NOL)    = [F:STO]SLO
                                     # FGR 30/04/2015 : X3SUIVI105605 (début)
                                     If dim([M]ECCVALMAJ) >= 0 Then
                                       [M]ECCVALMAJ(NOL) = [F:STO]ECCVALMAJ
                                     Endif
                                     If dim([M]ECCVALMIN) >= 0 and dim([M]ECCVALMAJ) >= 0 and [M]ECCVALMAJ(NOL) <> "" Then
                                       # Pour ne le faire que si la version majeure est alimentée
                                       Read [STL]STL0=[F:STO]ITMREF;[F:STO]LOT;[F:STO]SLO
                                       If !fstat Then
                                         [M]ECCVALMIN(NOL) = [F:STL]ECCVALMIN
                                       Endif
                                     Endif
                                     # FGR 30/04/2015 : X3SUIVI105605 (fin)
                                     [M]LOC(NOL)    = [F:STO]LOC
                                     [M]STA(NOL)    = [F:STO]STA
                                     [M]SERNUM(NOL) = [F:STO]SERNUM
                                     If [F:ITM]ITMREF<>WITMREF
                                         Read [ITM]ITM0=WITMREF
                                         If fstat Raz [F:ITM] Endif
                                     Endif
                                     # Si article géré en titre ou géré en lot : récup date péremption et titre
                                     If [F:ITM]LOTMGTCOD>1
                                         Read [STL]STL0=WITMREF;[M]LOT(nolign-1);[M]SLO(nolign-1)
                                         If !fstat [M]SHLDAT(nolign-1) = [F:STL]SHLDAT : Endif
                                     Endif
                                     [M]PALNUM(NOL) = [F:STO]PALNUM
                                     [M]CTRNUM(NOL) = [F:STO]CTRNUM
                                     NOL += 1
                                  Endif
                         When 4 : [M]XQTY(NOL)      = [F:STA]QTYSTUACT      : # Manquant détail
                                  [M]XSTU(NOL)      = evalue("[M:"+WABMSK+"]STU(I)")
                                  [M:SDL]WRUPT(NOL) = 1
                                  NOL += 1
                         When 5 : [M]XQTY(NOL)      = [F:STA]QTYSTUACT      : # Manquant global
                                  [M]XSTU(NOL)      = evalue("[M:"+WABMSK+"]STU(I)")
                                  [M:SDL]WRUPT(NOL) = 1
                                  NOL += 1
                        Endcase
                        nolign=NOL+1
                        #If NOL>=300 X3-54642 (LCC-21/02/18) Cannot display all delivery lines in Stock Lot
                        If NOL>=dim([M:SDL]XQTY)
                           Filter [STA]
                           Break 2
                        Endif
                        Raz [M]XITMREF(NOL)
                     Next
                     Filter [STA]
    When 42,52     : For [STJ]
                        [M:SDL]=[F:STJ]
                        If [F:STJ]UPDCOD=2
                           [M:SDL]WRUPT(NOL) = 0
                        Else
                           [M:SDL]WRUPT(NOL) = 1
                        Endif
                        If [F:STJ]QTYSTU < 0
                           [M]XQTY(NOL) = abs([F:STJ]QTYSTU)
                           [M]XSTU(NOL) = [F:STJ]STU
                           NOL += 1
                           nolign=NOL+1
                           #If NOL>=300 X3-54642 (LCC-21/02/18) Cannot display all delivery lines in Stock Lot
                           If NOL>=dim([M:SDL]XQTY)
                              Filter [STJ]
                              Break 2
                           Endif
                           Raz [M]XITMREF(NOL)
                        Endif
                     Next
                     Filter [STJ]
   Endcase
Next I
[M:SDL]NBLIG = NOL

Return

################################################################################
# !! Cette fenêtre n'est plus utilisée !!
################################################################################
################################################################################
# VISUQTYSOQ : Affichage fenêtre des qtés d'une ligne de commande              #
################################################################################
################################################################################
$DEB_VISUQTYSOQ
Local Integer NOLIG    : NOLIG = val(PARAM(1))
Local Char    WABMSK   : WABMSK = PARAM(2)

Local Decimal TALLQTY, WQTY

[M:SOHQ]WB=mess(505,197,1)

# Commande à facturation directe
If WABMSK="SOH4" & [M:SOH0]SOHCAT = 3
   Grizo [M:SOHQ]ODLQTY, DLVQTY, RDLVQTY
Else
   Grizo [M:SOHQ]OINQTY
Endif
# Article non géré en stock
If (WABMSK="SOH4" & [M:SOH4]STOMGTCOD(NOLIG)=1) | (WABMSK="SOQ1" & [M:SOQ1]XSTOMGTCOD=1)
   Grizo [M:SOHQ]ALLQTY, RALLQTY, YALLQTY, AALLQTY, SHTQTY
Endif

[M:SOHQ]QTY     = evalue("[M:"+WABMSK+"]QTY(NOLIG)")

If WABMSK="SOH4"
    [M:SOHQ]SAU     = [M:SOH4]SAU(NOLIG)
Elsif WABMSK="SOQ1"
    [M:SOHQ]SAU     = [M:SOQ1]SAU
Endif
[M:SOHQ]SOQSTA  = evalue("[M:"+WABMSK+"]SOQSTA(NOLIG)")

# Total alloué : Déjà alloué + Rupture + A allouer
[M:SOHQ]ALLQTY  = evalue("[M:"+WABMSK+"]WALLQTY(NOLIG)")
# Déjà alloué
[M:SOHQ]YALLQTY = evalue("[M:"+WABMSK+"]ALLQTY(NOLIG)")
[M:SOHQ]SHTQTY  = evalue("[M:"+WABMSK+"]SHTQTY(NOLIG)")
# A Allouer
[M:SOHQ]AALLQTY = evalue("[M:"+WABMSK+"]WALLQTY(NOLIG)")-(evalue("[M:"+WABMSK+"]ALLQTY(NOLIG)")+evalue("[M:"+WABMSK+"]SHTQTY(NOLIG)"))

[M:SOHQ]LPRQTY  = evalue("[M:"+WABMSK+"]LPRQTY(NOLIG)")
[M:SOHQ]OPRQTY  = evalue("[M:"+WABMSK+"]OPRQTY(NOLIG)")
[M:SOHQ]PREQTY  = evalue("[M:"+WABMSK+"]PREQTY(NOLIG)")

If WABMSK="SOH4" & [M:SOH0]SOHCAT = 3
   [M:SOHQ]OINQTY = [M:SOH4]ODLQTY(NOLIG)
   Raz [M:SOHQ]ODLQTY
   Raz [M:SOHQ]DLVQTY
   Raz [M:SOHQ]RDLVQTY
Else
   [M:SOHQ]ODLQTY = evalue("[M:"+WABMSK+"]ODLQTY(NOLIG)")
   [M:SOHQ]DLVQTY = evalue("[M:"+WABMSK+"]DLVQTY(NOLIG)")
   Raz [M:SOHQ]OINQTY
Endif
[M:SOHQ]INVQTY  = evalue("[M:"+WABMSK+"]INVQTY(NOLIG)")

# ---------------------------------- #
# --- Calcul du reste à préparer --- #
# ---------------------------------- #
[M:SOHQ]RPREQTY = 0
# ---> Ligne non soldée et commande à livrer
If [M:SOHQ]SOQSTA <> 3
    If WABMSK="SOQ1" | (WABMSK="SOH4" & [M:SOH0]SOHCAT<>3)
    #   --> Commandé non livré et non préparé ou qté allouée si elle est supérieure
        WQTY = [M:SOHQ]LPRQTY+[M:SOHQ]OPRQTY+[M:SOHQ]PREQTY+[M:SOHQ]ODLQTY+[M:SOHQ]DLVQTY
        If WQTY < [M:SOHQ]QTY WQTY = [M:SOHQ]QTY-WQTY Else Raz WQTY : Endif
        [M:SOHQ]RPREQTY = max(WQTY, [M:SOHQ]ALLQTY)
    Endif
Endif
# ---------------------------------- #
# --- Calcul du reste à livrer   --- #
# ---------------------------------- #
[M:SOHQ]RDLVQTY = 0
WQTY = 0
# ---> Ligne non soldée et commande à livrer
If [M:SOHQ]SOQSTA <> 3
    If WABMSK="SOQ1" | (WABMSK="SOH4" & [M:SOH0]SOHCAT<>3)
#       --> Commandé non livré ou qté allouée si elle est supérieure
        If ([M:SOHQ]ODLQTY + [M:SOHQ]DLVQTY) < [M:SOHQ]QTY
            WQTY = [M:SOHQ]QTY - [M:SOHQ]ODLQTY - [M:SOHQ]DLVQTY
        Endif
        [M:SOHQ]RDLVQTY = max(WQTY, [M:SOHQ]ALLQTY)
    Endif
Endif
# ---------------------------------- #
# --- Calcul du total alloué     --- #
# ---------------------------------- #
# --> Déjà alloué (alloué + rupture + en prépa + préparé) + livré (ou facturé)
TALLQTY = [M:SOHQ]ALLQTY + [M:SOHQ]OPRQTY + [M:SOHQ]PREQTY
If WABMSK="SOH4" & [M:SOH0]SOHCAT = 3
    TALLQTY += [M:SOHQ]OINQTY + [M:SOHQ]INVQTY
Else
    TALLQTY += [M:SOHQ]ODLQTY + [M:SOHQ]DLVQTY
Endif
# ---------------------------------- #
# --- Calcul du reste à allouer  --- #
# ---------------------------------- #
# --> Commandé - total alloué
If TALLQTY < [M:SOHQ]QTY & [M:SOHQ]SOQSTA <> 3
    [M:SOHQ]RALLQTY = [M:SOHQ]QTY - TALLQTY
Else
    [M:SOHQ]RALLQTY = 0
Endif
# ---------------------------------- #
# --- Calcul du reste à facturer --- #
# ---------------------------------- #
[M]RINVQTY = 0
WQTY = 0
If WABMSK="SOQ1" | (WABMSK="SOH4" & INVFLG(NOLIG) = 1)
    If WABMSK="SOH4" & [M:SOH0]SOHCAT = 3
#       Ligne de commande à facturation directe
#       --> Commandé non facturé ou qté allouée si elle est supérieure
        If [M:SOHQ]OINQTY + [M:SOHQ]INVQTY < [M:SOHQ]QTY
            WQTY = [M:SOHQ]QTY - [M:SOHQ]OINQTY - [M:SOHQ]INVQTY
        Endif
        [M:SOHQ]RINVQTY = max(WQTY, [M:SOHQ]ALLQTY)
    Else
#       Ligne de commande à livrer
#       --> Livré non facturé
        If [M:SOHQ]INVQTY < [M:SOHQ]ODLQTY + [M:SOHQ]DLVQTY
            [M:SOHQ]RINVQTY = ([M:SOHQ]ODLQTY + [M:SOHQ]DLVQTY) - [M:SOHQ]INVQTY
        Endif
    Endif
Endif

# Article non géré en stock
If (WABMSK="SOH4" & [M:SOH4]STOMGTCOD(NOLIG)=1 & !find([M:SOH4]LINTYP(NOLIG),2,10)) | (WABMSK="SOQ1" & [M:SOQ1]XSTOMGTCOD=1)
   [M:SOHQ]YALLQTY = 0
   [M:SOHQ]RALLQTY = 0
   [M:SOHQ]AALLQTY = 0
Endif

Affzo [M:SOHQ]1-99

Return

$DEB_VISUQTYSOQANC
Local Integer NOLIG    : NOLIG = val(PARAM(1))

Local Decimal TALLQTY, WQTY

[M:SOHQ]WB=mess(505,197,1)

# Commande à facturation directe
If [M:SOH0]SOHCAT = 3
   Grizo [M:SOHQ]ODLQTY, DLVQTY, RDLVQTY
Else
   Grizo [M:SOHQ]OINQTY
Endif
# Article non géré en stock
If [M:SOH4]STOMGTCOD(NOLIG) = 1
   Grizo [M:SOHQ]ALLQTY, RALLQTY, YALLQTY, AALLQTY, SHTQTY
Endif

[M:SOHQ]QTY     = [M:SOH4]QTY(NOLIG)
[M:SOHQ]SAU     = [M:SOH4]SAU(NOLIG)
[M:SOHQ]SOQSTA  = [M:SOH4]SOQSTA(NOLIG)

# Total alloué : Déjà alloué + Rupture + A allouer
[M:SOHQ]ALLQTY  = [M:SOH4]WALLQTY(NOLIG)
# Déjà alloué
[M:SOHQ]YALLQTY = [M:SOH4]ALLQTY(NOLIG)
[M:SOHQ]SHTQTY  = [M:SOH4]SHTQTY(NOLIG)
# A Allouer
[M:SOHQ]AALLQTY = [M:SOH4]WALLQTY(NOLIG)-([M:SOH4]ALLQTY(NOLIG)+[M:SOH4]SHTQTY(NOLIG))

[M:SOHQ]LPRQTY  = [M:SOH4]LPRQTY(NOLIG)
[M:SOHQ]OPRQTY  = [M:SOH4]OPRQTY(NOLIG)
[M:SOHQ]PREQTY  = [M:SOH4]PREQTY(NOLIG)

# ---------------------------------- #
# --- Calcul du reste à préparer --- #
# ---------------------------------- #
[M:SOHQ]RPREQTY = 0
# ---> Ligne non soldée et commande à livrer
If [M:SOHQ]SOQSTA <> 3 & [M:SOH0]SOHCAT <> 3
#   --> Commandé non livré et non préparé ou qté allouée si elle est supérieure
    WQTY = [M:SOHQ]LPRQTY+[M:SOHQ]OPRQTY+[M:SOHQ]PREQTY+[M:SOHQ]ODLQTY+[M:SOHQ]DLVQTY
    If WQTY < [M:SOHQ]QTY WQTY = [M:SOHQ]QTY-WQTY Else Raz WQTY : Endif
    [M:SOHQ]RPREQTY = max(WQTY, [M:SOHQ]ALLQTY)
Endif

If [M:SOH0]SOHCAT = 3
   [M:SOHQ]OINQTY = [M:SOH4]ODLQTY(NOLIG)
   Raz [M:SOHQ]ODLQTY
   Raz [M:SOHQ]DLVQTY
   Raz [M:SOHQ]RDLVQTY
Else
   [M:SOHQ]ODLQTY = [M:SOH4]ODLQTY(NOLIG)
   [M:SOHQ]DLVQTY = [M:SOH4]DLVQTY(NOLIG)
   Raz [M:SOHQ]OINQTY
Endif
[M:SOHQ]INVQTY  = [M:SOH4]INVQTY(NOLIG)

# ---------------------------------- #
# --- Calcul du reste à livrer   --- #
# ---------------------------------- #
[M:SOHQ]RDLVQTY = 0
WQTY = 0
# ---> Ligne non soldée et commande à livrer
If [M:SOHQ]SOQSTA <> 3 & [M:SOH0]SOHCAT <> 3
#   --> Commandé non livré ou qté allouée si elle est supérieure
    If ([M:SOHQ]ODLQTY + [M:SOHQ]DLVQTY) < [M:SOHQ]QTY
        WQTY = [M:SOHQ]QTY - [M:SOHQ]ODLQTY - [M:SOHQ]DLVQTY
    Endif
    [M:SOHQ]RDLVQTY = max(WQTY, [M:SOHQ]ALLQTY)
Endif
# ---------------------------------- #
# --- Calcul du total alloué     --- #
# ---------------------------------- #
# --> Déjà alloué (alloué + rupture + en prépa + préparé) + livré (ou facturé)
TALLQTY = [M:SOHQ]ALLQTY + [M:SOHQ]OPRQTY + [M:SOHQ]PREQTY
If [M:SOH0]SOHCAT = 3
    TALLQTY += [M:SOHQ]OINQTY + [M:SOHQ]INVQTY
Else
    TALLQTY += [M:SOHQ]ODLQTY + [M:SOHQ]DLVQTY
Endif
# ---------------------------------- #
# --- Calcul du reste à allouer  --- #
# ---------------------------------- #
# --> Commandé - total alloué
If TALLQTY < [M:SOHQ]QTY & [M:SOHQ]SOQSTA <> 3
    [M:SOHQ]RALLQTY = [M:SOHQ]QTY - TALLQTY
Else
    [M:SOHQ]RALLQTY = 0
Endif
# ---------------------------------- #
# --- Calcul du reste à facturer --- #
# ---------------------------------- #
[M]RINVQTY = 0
WQTY = 0
If [M:SOH4]INVFLG(NOLIG) = 1
    If [M:SOH0]SOHCAT = 3
#   Ligne de commande à facturation directe
#   --> Commandé non facturé ou qté allouée si elle est supérieure
        If [M:SOHQ]OINQTY + [M:SOHQ]INVQTY < [M:SOHQ]QTY
            WQTY = [M:SOHQ]QTY - [M:SOHQ]OINQTY - [M:SOHQ]INVQTY
        Endif
        [M:SOHQ]RINVQTY = max(WQTY, [M:SOHQ]ALLQTY)
    Else
#   Ligne de commande à livrer
#   --> Livré non facturé
        If [M:SOHQ]INVQTY < [M:SOHQ]ODLQTY + [M:SOHQ]DLVQTY
            [M:SOHQ]RINVQTY = ([M:SOHQ]ODLQTY + [M:SOHQ]DLVQTY) - [M:SOHQ]INVQTY
        Endif
    Endif
Endif

# Article non géré en stock
If [M:SOH4]STOMGTCOD(NOLIG) = 1 & !find([M:SOH4]LINTYP(NOLIG),2,10)
   [M:SOHQ]YALLQTY = 0
   [M:SOHQ]RALLQTY = 0
   [M:SOHQ]AALLQTY = 0
Endif

Affzo [M:SOHQ]1-99

Return
################################################################################
# VISUSITSQH : Visu de la situation devis                                      #
################################################################################
#------------------------------------------------------------------------------#
$OUV_VISUSITSQH
#Local Integer WSQHACV, NOL, I, J
Local Integer NOL, I, J
Local Integer REPONSE
Local Integer SNOL    :    SNOL=nolign

#If   !clalev([F:ACV]) : Local File ACTIV [ACV] : Endif
#Read [ACV] CODACT = "SQH"
#If   !fstat : WSQHACV = [F:ACV]DIME : Endif
#If   WSQHACV = 0
#     FIN=1 : GERR=1 : MESSAGE = "SQH"+ mess(8,176,1): Return
#Endif
#Close Local File [ACV]
Return

#------------------------------------------------------------------------------#
$DEB_VISUSITSQH
Local Char WKEY(10) : Raz WKEY

# Chargement du masque situation devis

If clalev ([F:SOP]) <= 0 Local File SORDERP [SOP] Endif
If clalev ([F:SOQ]) <= 0 Local File SORDERQ [SOQ] Endif
If clalev ([F:ANX]) <= 0 Local File AINDEX  [ANX] Endif

# Avec la clause With Nohint on va forcément prendre la clé d'optimisation si elle est active (avec Bug 42341)
#For [ANX]ANX2 Where TABLE="SORDERP" & FLACT=2
#   If left$([F:ANX]DESCRIPT,13) = "SQHNUM+SQDLIN"
#      WKEY = [F:ANX]CODIND
#      Break
#   Endif
#Next

Raz [M]
Raz J

For I=0 To [M:SQH2]NBLIG-1
    [M]ITMREF(J) = [M:SQH2]ITMREF(I)
    [M]SAU(J)    = [M:SQH2]SAU(I)
    [M]QTY(J)    = [M:SQH2]QTY(I)

#   Calcul de la qté commandée
#    [M]SOHNUM(J) = [M:SQH2]DSOHNUM(I)
#    If [M]SOHNUM(J) <> ""
#        If clalev([F:SOQ]) = 0 Local File SORDERQ [SOQ] : Endif
#        Read [SOQ]SOQ0=[M:SQH2]DSOHNUM(I);[M:SQH2]SOPLIN(I);[M:SQH2]SOPLIN(I)
#        If !fstat [M]ORDQTY(J)= [F:SOQ]QTY : Endif
#    Endif
#    For [F:SOP]SOP0 Hint Key=WKEY
#&                   Where [SOP]SQHNUM=[M:SQH0]SQHNUM & [SOP]SQDLIN=[M:SQH2]SQDLIN(I)
    For [F:SOP]SOP0 Where [SOP]SQHNUM=[M:SQH0]SQHNUM & [SOP]SQDLIN=[M:SQH2]SQDLIN(I) With Nohint
        Read [SOQ]SOQ0=[F:SOP]SOHNUM;[F:SOP]SOPLIN;[F:SOP]SOPSEQ
        If !fstat
           [M]SOHNUM(J) = [F:SOQ]SOHNUM
           [M]ORDQTY(J) = [F:SOQ]QTY
           J+=1
           Raz [M]ITMREF(J), [M]QTY(J)
           [M]SAU(J)    = [M:SQH2]SAU(I)
#           If J>=WSQHACV Break Endif
           If J>=dim([M]ITMREF) Call MESSAGE (mess(26,100,1)) From GESECRAN : Break Endif
        Endif
    Next
    If [M]ITMREF(J)<>"" J+=1 Endif
#    If J>=WSQHACV Break Endif
    If J>=dim([M]ITMREF) Call MESSAGE (mess(26,100,1)) From GESECRAN : Break Endif
Next I
[M]NBLIG = J

Close Local File [ANX]
Return


################################################################################
# VISUVALLIG : Affichage fenêtre valorisation ligne devis, cde, liv, fac       #
#------------------------------------------------------------------------------#
#   PARAM(1) = WABFIC : Abréviation de la table des lignes                     #
#   PARAM(2) = WABREV : Abréviation du masque écran contenant les lignes       #
#   PARAM(2) = NOLIGN : No. de la ligne à traiter (nolign)                     #
################################################################################

$OUV_VISUVALLIG
Global Integer GJL_PRITYP : GJL_PRITYP=1          : # pour libelles background HT ou TTC
Case PARAM(1)
     When "SQD"             GJL_PRITYP=[M:SQH1]PRITYP
     When "SOQ"             GJL_PRITYP=[M:SOH1]PRITYP
     When "SDD"             GJL_PRITYP=[M:SDH1]PRITYP
     When "SID"             GJL_PRITYP=[M:SIH1]PRITYP
Endcase
Return

#------------------------------------------------------------------------------#

$DEB_VISUVALLIG

Local Char    WABFIC    : WABFIC = PARAM(1)
Local Char    WABREV    : WABREV= PARAM(2)
Local Integer NOLIG     : NOLIG = val(PARAM(3))-1

Local Integer JL0,JL1
Local Char    WABFICV   :      # Abr. de la table de valorisation

If !clalev ([F:SPR]) : Local File SPREASON  [SPR] : Endif
If !clalev ([F:TCU]) : Local File TABCUR    [TCU] : Endif
If !clalev ([F:TUN]) : Local File TABUNIT   [TUN] : Endif
Gosub OPEN_SFI From TRTX3CPY: #If !clalev ([F:SFI]) : Local File SFOOTINV  [SFI] : Endif
If !clalev ([F:AXX]) : Local File ATEXTRA   [AXX] : Endif

Raz [M]
# --- devis
If WABFIC="SQD"
   Read [SQD]SQD0=[M:SQH0]SQHNUM;[M:SQH2]SQDLIN(NOLIG)
   If fstat : Raz [F:SQD] : Endif
   [M]TYPORI=1
   [M]NUMORI=[M:SQH0]SQHNUM
   [M]LINORI=[M:SQH2]SQDLIN(NOLIG)
   [M]PRITYP=[M:SQH1]PRITYP
   GCUR=[M:SQH0]CUR
   [M]AMTNOTLIN=[M:SQH2]LINQUONOT(NOLIG)

Endif

# --- commande
If WABFIC="SOQ"
   Read [SOQ]SOQ0=[M:SOH0]SOHNUM;[M:SOH4]SOPLIN(NOLIG);[M:SOH4]SOPLIN(NOLIG)
   If fstat : Raz [F:SOQ] : Endif
   [M]TYPORI=20
   [M]NUMORI=[M:SOH0]SOHNUM
   [M]LINORI=[M:SOH4]SOPLIN(NOLIG)
   [M]PRITYP=[M:SOH1]PRITYP
   GCUR=[M:SOH0]CUR
   [M]AMTNOTLIN=[M:SOH4]LINORDNOT(NOLIG)
Endif

# --- livraison
If WABFIC="SDD"
   Read [SDD]SDD0=[M:SDH0]SDHNUM;[M:SDH1]SDDLIN(NOLIG)
   If fstat : Raz [F:SDD] : Endif
   [M]TYPORI=2
   [M]NUMORI=[M:SDH0]SDHNUM
   [M]LINORI=[M:SDH1]SDDLIN(NOLIG)
   [M]PRITYP=[M:SDH1]PRITYP
   GCUR=[M:SDH1]CUR
   [M]AMTNOTLIN=[M:SDH1]LINDLVNOT(NOLIG)
Endif

# --- facture
If WABFIC="SID"
   WABFICV="SIV"
   Read [SIV]SIV0=[M:SIH0]NUM
   If fstat : Raz [F:SIV] : Endif
   Read [SID]SID0=[M:SIH0]NUM;[M:SIH4]SIDLIN(NOLIG)
   If fstat : Raz [F:SID] : Endif
   [M]TYPORI=4
   [M]NUMORI=[M:SIH0]NUM
   [M]LINORI=[M:SIH4]SIDLIN(NOLIG)
   [M]PRITYP=[M:SIH1]PRITYP
   GCUR=[M:SIH0]CUR
   [M]AMTNOTLIN=[M:SIH4]AMTNOTLIN(NOLIG)
Endif

# --- donnees communes
If [F:TCU]CUR<>GCUR : Read [TCU]TCU0=GCUR : Endif
[M]CUR=GCUR
[M]UOM=evalue("[M:"+WABREV+"]SAU(NOLIG)")
[M]QTYUOM=evalue("[M:"+WABREV+"]QTY(NOLIG)")
[M]NETPRI=evalue("[M:"+WABREV+"]NETPRINOT(NOLIG)")
[M]ITMREF=evalue("[M:"+WABREV+"]ITMREF(NOLIG)")
[M]ITMDES=evalue("[M:"+WABREV+"]ITMDES1(NOLIG)")

# --- bloc prix unit et frais/remises

GNBREM=sigma(I=0,dim(GDISCRGTYP)-1,GDISCRGTYP(I)<>0)
[M]NBREM=GNBREM+1

[M]COLDES(0)=mess(GJL_PRITYP+20,2281,1)
[M]AMT(0)=format$("N:8.4",evalue("[M:"+WABREV+"]GROPRI(NOLIG)"))
[M]REN(0)=evalue("[M:"+WABREV+"]PRIREN(NOLIG)")

For I=1 To GNBREM
    [M]COLDES(I)=GCOLREM(I-1)
    If GDISCRGTYP(I-1)=1
       [M]AMT(I)=format$(GFORREM(I-1),evalue("[M:"+WABREV+"]DISCRGVAL"+num$(I)+"(NOLIG)"))
    Else
       [M]RAT(I)=format$(GFORREM(I-1),evalue("[M:"+WABREV+"]DISCRGVAL"+num$(I)+"(NOLIG)"))
    Endif
    [M]REN(I)=evalue("[M:"+WABREV+"]DISCRGREN"+num$(I)+"(NOLIG)")
Next I


#For I=0 To GNBREM-1
#    [M]COLDES(I)=GCOLREM(I)
#    If GDISCRGTYP(I)=1
#       [M]AMT(I)=format$(GFORREM(I),evalue("[M:"+WABREV+"]DISCRGVAL"+num$(I+1)+"(NOLIG)"))
#    Else
#       [M]RAT(I)=format$(GFORREM(I),evalue("[M:"+WABREV+"]DISCRGVAL"+num$(I+1)+"(NOLIG)"))
#    Endif
#    [M]REN(I)=evalue("[M:"+WABREV+"]DISCRGREN"+num$(I+1)+"(NOLIG)")
#Next I

# --- bloc montants repartis
If GREP=""                              : # pas de visu de la repartition si en cours de m.a.j.
   Chgfmt [M]LIBEL With "-K:1X"
   Raz JL0
   SAV_DEFAULT=dbgstr(2)
#   NEW_DEFAULT="["+WABFIC+"],["+WABFICV+"]"
   NEW_DEFAULT="["+WABFIC+"]"
   Default File NEW_DEFAULT

   For I=0 To dim([F]DDTANUM)-1
       If [F]DDTANUM(I)<>0
          [M]DDTANUM(JL0)=[F]DDTANUM(I)
          [M]DDTANOT(JL0)=[F]DDTANOT(I)
#          Read [SFI]SFI0=GSOCIETE;[M]DDTANUM(JL0)
          Read [SFI]SFI0=[M]DDTANUM(JL0)
          If fstat : Raz [F:SFI] : Endif
          [M]DSPLIN(JL0)=[F:SFI]DSPLIN
#          JL1=find([M]DDTANUM(JL0),[F]DTA)
#          If JL1
          Read [SVF]SVF1=[M]TYPORI;[M]NUMORI;[M]DDTANUM(JL0)
          If fstat=0
#             [M]DTANOT(JL0)=[F]DTANOT(JL1-1)
             [M]DTANOT(JL0)=[F:SVF]DTANOT
          Endif
          JL0 +=1 : [M]NBVAL=JL0
       Endif
   Next I
  Default File SAV_DEFAULT

Else
     [M]LIBEL=mess(77,187,1)
     Chgfmt [M]NBVAL With "-K:1X"
Endif

Affzo [M]1-99

Return

################################################################################
################################################################################
# VISUDTAVAT : Affichage du détail des taxes d'un élément de facturation       #
#------------------------------------------------------------------------------#
#   PARAM(1) = No. de la ligne à traiter (nolign)                              #
################################################################################

$OUV_VISUDTAVAT
Local Integer  NOLIG : NOLIG=val(PARAM(1))
Local Integer  WI, WJ

#If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif
If clalev([F:TVT])=0 : Local File TABVAT     [TVT] : Endif :#--CPO 71937 TVT et multi-lèg


Return

$DEB_VISUDTAVAT
Local Integer  WRET :#--CPO 71937 TVT et multi-lèg
If clalev([F:TVT])=0 : Local File TABVAT     [TVT] : Endif :#--CPO 71937 TVT et multi-lèg

Raz [M:SIHT]
[M:SIHT]SFINUM =[M:SIHV]XFNUM(NOLIG)
[M:SIHT]FSMI   =[M:SIHV]XFSMI(NOLIG)
[M:SIHT]FVATAMT=[M:SIHV]XFVATAMT(NOLIG)

For WI=0 To 9
#    If evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",WI+1)+"("+num$(NOLIG)+")")<>0
    #--CPO 92252 Cas d'une facture ayant le prix de la première ligne à 0
    #If evalue ("[M:SIHV]DTAVAT"+format$("N0:2",WI+1)+"("+num$(NOLIG)+")")<>""
    #    [M:SIHT]DTANET(WI)    = evalue ("[M:SIHV]DTANET"+format$("N0:2",WI+1)+"("+num$(NOLIG)+")")
    #    [M:SIHT]DTAVAT(WI)    = evalue ("[M:SIHV]DTAVAT"+format$("N0:2",WI+1)+"("+num$(NOLIG)+")")
    #    [M:SIHT]DTAVATRAT(WI) = evalue ("[M:SIHV]DTAVATRT"+format$("N0:2",WI+1)+"("+num$(NOLIG)+")")
    #    [M:SIHT]DTAVATAMT(WI) = evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",WI+1)+"("+num$(NOLIG)+")")
    #    WJ=find([M:SIHT]DTAVAT(WI),[M:SIHV]XVTAX(0..[M:SIHV]NBVAT-1))
    #    If WJ>0
    #        [M:SIHT]DTASHO(WI)=[M:SIHV]XVSHO(WJ-1)
    #    Else
    #    		#--CPO 71937 TVT et multi-lèg
    #    		Call LEC_TVT_LEG(GCURLEG,[M:SIHT]DTAVAT(WI),WRET) From TRTLECLEG
    #    		If WRET : Raz [F:TVT] Endif
    #        Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:SIHT]DTASHO(WI)) From TRTX3TEX
    #        #Read [AXX]AXX0="TABVAT";"SHOAXX";GLANGUE;[M:SIHT]DTAVAT(WI);""
    #        #If !fstat : [M:SIHT]DTASHO(WI)=[F:AXX]TEXTE : Endif
    #        #--/CPO
    #    Endif
    #    [M:SIHT]NBVAT+=1
    #Endif
    If evalue ("[M:SIHV]DTAVAT"+format$("N0:2",WI+1)+"("+num$(NOLIG)+")")<>""
        [M:SIHT]DTANET([M:SIHT]NBVAT)    = evalue ("[M:SIHV]DTANET"  +format$("N0:2",WI+1)+"("+num$(NOLIG)+")")
        [M:SIHT]DTAVAT([M:SIHT]NBVAT)    = evalue ("[M:SIHV]DTAVAT"  +format$("N0:2",WI+1)+"("+num$(NOLIG)+")")
        [M:SIHT]DTAVATRAT([M:SIHT]NBVAT) = evalue ("[M:SIHV]DTAVATRT"+format$("N0:2",WI+1)+"("+num$(NOLIG)+")")
        [M:SIHT]DTAVATAMT([M:SIHT]NBVAT) = evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",WI+1)+"("+num$(NOLIG)+")")
        WJ=find([M:SIHT]DTAVAT([M:SIHT]NBVAT),[M:SIHV]XVTAX(0..[M:SIHV]NBVAT-1))
        If WJ>0
            [M:SIHT]DTASHO([M:SIHT]NBVAT)=[M:SIHV]XVSHO(WJ-1)
        Else
        		#--CPO 71937 TVT et multi-lèg
        		Call LEC_TVT_LEG(GCURLEG,[M:SIHT]DTAVAT([M:SIHT]NBVAT),WRET) From TRTLECLEG
        		If WRET : Raz [F:TVT] Endif
            Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:SIHT]DTASHO([M:SIHT]NBVAT)) From TRTX3TEX
            #Read [AXX]AXX0="TABVAT";"SHOAXX";GLANGUE;[M:SIHT]DTAVAT(WI);""
            #If !fstat : [M:SIHT]DTASHO(WI)=[F:AXX]TEXTE : Endif
            #--/CPO
        Endif
        [M:SIHT]NBVAT+=1
    Endif
    #--/
Next

Affzo [M:SIHT]1-99

Return

