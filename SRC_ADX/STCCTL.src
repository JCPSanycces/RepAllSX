#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################################
# Traitement STCCTL - Landed Cost - Contrôles                       V7                                #
# CONTROL_CSTSTC  Contrôle de cohérence de la structure de coûts                                      #
# CONTROL_UOM_STCD Contrôle de l'unité saisie en détail SDC/document par rapport à unités autorisées  #
# CONTROL_USEFCS  Contrôle de l'exploitation d'une Charge sur un dosument non soldé/validé ou dans STC#
#######################################################################################################
#
########################################################################
# CONTROL_CSTSTC  Contrôle de cohérence de la structure de coûts
#                 - unités définies dans la structure par rapport
#                   aux unités catégorie/articles/articles fournisseur
#-----------------------------------------------------------------------
# Paramètres E    LSTCNUM : code structure
#                 LORI    : origine du contrôle
#                           "ITG" : la catégorie est en ligne
#                           "ITM" : l'article est en ligne
#                           "ITP" : article fou et article sont en ligne
#                           "STC" : la structure est en ligne
#                           "ITPF": product site supplier is online
# Paramètres S    LRET    : code retour (0 ok / 1 erreur)
########################################################################
Subprog CONTROL_CSTSTC(LSTCNUM,LORI,LRET)
Value    Char    LSTCNUM
Value    Char    LORI
Variable Integer LRET

Local    Char    LABR
Local    Char    WCHG(80), WMSG(80)
Local    Char    WMSG1(160), WMSG2(160), WMSG3(160)
Local    Char    WVOUWEU
Local    Integer I, WNUC, WRET, WERR
LRET=0
WRET=0
If !find(LORI,"ITG","ITM","ITP","STC","ITPF") LRET=1 : End Endif

If clalev([F:STCL])= 0 : Local File COSTSTCL   [STCL] : Endif
If clalev([F:ITG]) = 0 : Local File ITMCATEG   [ITG]  : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM]  : Endif
If clalev([F:ITP]) = 0 : Local File ITMBPS     [ITP]  : Endif
If clalev([F:TUN]) = 0 : Local File TABUNIT    [TUN]  : Endif
If clalev([F:TCO]) = 0 : Local File TABCOEFF   [TCO]  : Endif
If clalev([F:ITPF]) = 0 : Local File ITMBPSFCY   [ITPF]  : Endif  # Issue X3-112358 - 2018-10-11 by SDEM


If LORI="STC"

  Call OUVRE_TRACE("") From LECFIC

  # Structure de coût
  Call ECR_TRACE("----"-mess(6,2389,1)-LSTCNUM,0) From GESECRAN

  LABR="[F:ITG]"
  For [ITG]ITG0 Where STOFCY="" & STCNUM=LSTCNUM
    # Catégorie
    Call ECR_TRACE("--"-mess(340,183,1)-[F:ITG]TCLCOD,0) From GESECRAN
    Gosub VERIF_STC
  Next

  LABR="[F:ITM]"
  For [ITM]ITM0 Where STCNUM=LSTCNUM
    # Article
    Call ECR_TRACE("--"-mess(133,187,1)-[F:ITM]ITMREF,0) From GESECRAN
    Gosub VERIF_STC
  Next

  LABR="[F:ITP]"
  For [ITP]ITP0 Where STCNUM=LSTCNUM
    If [F:ITM]ITMREF<>[F:ITP]ITMREF
      Read [ITM]ITM0=[F:ITP]ITMREF
    Endif
    # Article-Fournisseur
    Call ECR_TRACE("--"-mess(23,198,1)-[F:ITP]ITMREF-"-"-[F:ITP]BPSNUM,0) From GESECRAN
    Gosub VERIF_STC
  Next

  LABR="[F:ITPF]"     # Issue X3-112358 - 2018-10-11 by SDEM
  For [ITPF]ITPF0 Where STCNUM=LSTCNUM
    If [F:ITM]ITMREF<>[F:ITPF]ITMREF
      Read [ITM]ITM0=[F:ITPF]ITMREF
    Endif
    # Product site supplier
    Call ECR_TRACE("--"-mess(14,752,1)-[F:ITPF]ITMREF-"-"-[F:ITPF]BPSNUM,0) From GESECRAN
    Gosub VERIF_STC
  Next

  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC

Else
  WERR=0
  WMSG1="" : WMSG2="" : WMSG3=""
  LABR="[F:"+LORI+"]"
  Gosub VERIF_STC
  If LRET=1
    Case WERR
      When 1       : Call ERREUR(WMSG1) From GESECRAN
      When 2       : Call ERREUR(WMSG1+"\"+WMSG2) From GESECRAN
      When Default : Call ERREUR(WMSG1+"\"+WMSG2+"\ ...") From GESECRAN
    Endcase
  Endif
Endif

End

#--------------------------------------------------------------------------
# Vérification cohérence structure pour une catégorie ou article ou art-fou
#--------------------------------------------------------------------------
$VERIF_STC

For [STCL]STCL0 Where STCNUM=LSTCNUM
  If find([F:STCL]DIRCLCMOD,3,4,5,6)
    Case [F:STCL]BAS
      When 1 : Gosub CTL_UA
      When 2 : Gosub CTL_UV
      When 3 : Gosub CTL_UP
    Endcase
  Endif
  If WRET=1 & LRET=0 : LRET=WRET : Endif
  WRET=0
Next

Return

# Contrôle unité achat
$CTL_UA

#If LABR="[F:ITP]"
#  WNUC=dim([F:ITM]PCU)-1
#  If !find([F:STCL]UOM,[F:ITM]STU,[F:ITP]PUU,[F:ITM]PUU,[F:ITP]PCU,[F:ITM]PCU(0,WNUC))
#    WRET=1
#  Endif
#Else
#  WNUC=evalue("dim("+LABR+"PCU)")-1
#  If !find([F:STCL]UOM,evalue(LABR+"STU"),evalue(LABR+"PUU"),
#&          evalue(LABR+"PCU(0.."+num$(WNUC)+")"))
#    WRET=1
#  Endif
#Endif

If LABR="[F:ITP]" or LABR="[F:ITPF]"    # Issue X3-112358 - 2018-10-11 by SDEM begin
  WNUC=dim([F:ITM]PCU)-1
  If !find([F:STCL]UOM,[F:ITM]STU,[F:ITP]PUU,[F:ITM]PUU,[F:ITP]PCU,[F:ITM]PCU(0,WNUC))
    WRET=1
  Endif
Else
  WNUC=evalue("dim("+LABR+"PCU)")-1
  If !find([F:STCL]UOM,evalue(LABR+"STU"),evalue(LABR+"PUU"),
&          evalue(LABR+"PCU(0.."+num$(WNUC)+")"))
    WRET=1
  Endif
Endif                                   # Issue X3-112358 - 2018-10-11 by SDEM end

If WRET=1
  # Charge
  WCHG=mess(407,198,1)-[F:STCL]FCSCOD
  Case LABR
    When "[F:ITP]" : WMSG="("+[F:ITP]PUU+","+[F:ITM]PUU+","+[F:ITM]STU
                     If [F:ITP]PCU<>""
                       WMSG+=","+[F:ITP]PCU
                     Endif
                     For I=0 To WNUC
                       If [F:ITM]PCU(I)<>"" : WMSG+=","+[F:ITM]PCU(I) : Endif
                     Next I
                     WMSG+=")"
    When "[F:ITM]" : WMSG="("+[F:ITM]PUU+","+[F:ITM]STU
                     For I=0 To WNUC
                       If [F:ITM]PCU(I)<>"" : WMSG+=","+[F:ITM]PCU(I) : Endif
                     Next I
                     WMSG+=")"
    When "[F:ITG]" : WMSG="("+[F:ITG]PUU+","+[F:ITG]STU
                     For I=0 To WNUC
                       If [F:ITG]PCU(I)<>"" : WMSG+=","+[F:ITG]PCU(I) : Endif
                     Next I
                     WMSG+=")"
    When "[F:ITPF]" : WMSG="("+[F:ITP]PUU+","+[F:ITM]PUU+","+[F:ITM]STU         # Issue X3-112358 - 2018-10-11 by SDEM
                     If [F:ITPF]PCU<>""
                       WMSG+=","+[F:ITPF]PCU
                     Endif
                     For I=0 To WNUC
                       If [F:ITM]PCU(I)<>"" : WMSG+=","+[F:ITM]PCU(I) : Endif
                     Next I
                     WMSG+=")"
  Endcase
  If GTRACE<>""
    Call ECR_TRACE(WCHG-":"-mess(1,2091,1)-[F:STCL]UOM-mess(168,187,1)-WMSG,1) From GESECRAN
  Else
    WERR+=1
    If WERR<3
      Assign "WMSG"+num$(WERR) With "-"-WCHG-":"-mess(1,2091,1)-[F:STCL]UOM-mess(168,187,1)-WMSG
    Endif
  Endif
Endif
Return

# Contrôle unité volume
$CTL_UV
#If LABR="[F:ITP]"
#  If [F:STCL]UOM=[F:ITM]VOU | [F:ITM]VOU=""
#    Return
#  Else
#    Look [TCO]TCO0=[F:STCL]UOM;[F:ITM]VOU
#    If fstat
#      Look [TCO]TCO0=[F:ITM]VOU;[F:STCL]UOM
#      If fstat WRET=1 Endif
#    Endif
#  Endif
#Else
#  If [F:STCL]UOM=evalue(LABR+"VOU") | evalue(LABR+"VOU")=""
#    Return
#  Else
#    Look [TCO]TCO0=[F:STCL]UOM;evalue(LABR+"VOU")
#    If fstat
#      Look [TCO]TCO0=evalue(LABR+"VOU");[F:STCL]UOM
#      If fstat WRET=1 Endif
#    Endif
#  Endif
#Endif
#If WRET=1
#  # Charge
#  WCHG=mess(407,198,1)-[F:STCL]FCSCOD
#  If LABR="[F:ITP]"
#     WVOUWEU="[F:ITM]VOU"
#  Else
#     WVOUWEU=LABR+"VOU"
#  Endif
#  If GTRACE<>""
#    Call ECR_TRACE(WCHG-":"-mess(2,2091,1)-[F:STCL]UOM-mess(169,187,1)-evalue(WVOUWEU),1) From GESECRAN
#  Else
#    WERR+=1
#    If WERR<3
#      Assign "WMSG"+num$(WERR) With "-"-WCHG-":"-mess(2,2091,1)-[F:STCL]UOM-mess(169,187,1)-evalue(WVOUWEU)
#    Endif
#  Endif
#Endif

If LABR="[F:ITP]" or LABR="[F:ITPF]"               # Issue X3-112358 - 2018-10-11 by SDEM begin
  If [F:STCL]UOM=[F:ITM]VOU | [F:ITM]VOU=""
    Return
  Else
    Look [TCO]TCO0=[F:STCL]UOM;[F:ITM]VOU
    If fstat
      Look [TCO]TCO0=[F:ITM]VOU;[F:STCL]UOM
      If fstat WRET=1 Endif
    Endif
  Endif
Else
  If [F:STCL]UOM=evalue(LABR+"VOU") | evalue(LABR+"VOU")=""
    Return
  Else
    Look [TCO]TCO0=[F:STCL]UOM;evalue(LABR+"VOU")
    If fstat
      Look [TCO]TCO0=evalue(LABR+"VOU");[F:STCL]UOM
      If fstat WRET=1 Endif
    Endif
  Endif
Endif
If WRET=1
  # Charge
  WCHG=mess(407,198,1)-[F:STCL]FCSCOD
  If LABR="[F:ITP]" or LABR="[F:ITPF]"
     WVOUWEU="[F:ITM]VOU"
  Else
     WVOUWEU=LABR+"VOU"
  Endif
  If GTRACE<>""
    Call ECR_TRACE(WCHG-":"-mess(2,2091,1)-[F:STCL]UOM-mess(169,187,1)-evalue(WVOUWEU),1) From GESECRAN
  Else
    WERR+=1
    If WERR<3
      Assign "WMSG"+num$(WERR) With "-"-WCHG-":"-mess(2,2091,1)-[F:STCL]UOM-mess(169,187,1)-evalue(WVOUWEU)
    Endif
  Endif
Endif                                               # Issue X3-112358 - 2018-10-11 by SDEM End

Return

# Contrôle unité poids
$CTL_UP

#If LABR="[F:ITP]"
#  If [F:STCL]UOM=[F:ITM]WEU | [F:ITM]WEU=""
#    Return
#  Else
#    Look [TCO]TCO0=[F:STCL]UOM;[F:ITM]WEU
#    If fstat
#      Look [TCO]TCO0=[F:ITM]WEU;[F:STCL]UOM
#      If fstat WRET=1 Endif
#    Endif
#  Endif
#Else
#  If [F:STCL]UOM=evalue(LABR+"WEU") | evalue(LABR+"WEU")=""
#    Return
#  Else
#    Look [TCO]TCO0=[F:STCL]UOM;evalue(LABR+"WEU")
#    If fstat
#      Look [TCO]TCO0=evalue(LABR+"WEU");[F:STCL]UOM
#      If fstat WRET=1 Endif
#    Endif
#  Endif
#Endif
#If WRET=1
#  If LABR="[F:ITP]"
#     WVOUWEU="[F:ITM]WEU"
#  Else
#     WVOUWEU=LABR+"WEU"
#  Endif
#
#  # Charge
#  WCHG=mess(407,198,1)-[F:STCL]FCSCOD
#  If GTRACE<>""
#    Call ECR_TRACE(WCHG-":"-mess(3,2091,1)-[F:STCL]UOM-mess(169,187,1)-evalue(WVOUWEU),1) From GESECRAN
#  Else
#    WERR+=1
#    If WERR<3
#      Assign "WMSG"+num$(WERR) With "-"-WCHG-":"-mess(3,2091,1)-[F:STCL]UOM-mess(169,187,1)-evalue(WVOUWEU)
#    Endif
#  Endif
#Endif

If LABR="[F:ITP]" or LABR="[F:ITPF]"                # Issue X3-112358 - 2018-10-11 by SDEM begin
  If [F:STCL]UOM=[F:ITM]WEU | [F:ITM]WEU=""
    Return
  Else
    Look [TCO]TCO0=[F:STCL]UOM;[F:ITM]WEU
    If fstat
      Look [TCO]TCO0=[F:ITM]WEU;[F:STCL]UOM
      If fstat WRET=1 Endif
    Endif
  Endif
Else
  If [F:STCL]UOM=evalue(LABR+"WEU") | evalue(LABR+"WEU")=""
    Return
  Else
    Look [TCO]TCO0=[F:STCL]UOM;evalue(LABR+"WEU")
    If fstat
      Look [TCO]TCO0=evalue(LABR+"WEU");[F:STCL]UOM
      If fstat WRET=1 Endif
    Endif
  Endif
Endif
If WRET=1
  If LABR="[F:ITP]" or LABR="[F:ITPF]"
     WVOUWEU="[F:ITM]WEU"
  Else
     WVOUWEU=LABR+"WEU"
  Endif

  # Charge
  WCHG=mess(407,198,1)-[F:STCL]FCSCOD
  If GTRACE<>""
    Call ECR_TRACE(WCHG-":"-mess(3,2091,1)-[F:STCL]UOM-mess(169,187,1)-evalue(WVOUWEU),1) From GESECRAN
  Else
    WERR+=1
    If WERR<3
      Assign "WMSG"+num$(WERR) With "-"-WCHG-":"-mess(3,2091,1)-[F:STCL]UOM-mess(169,187,1)-evalue(WVOUWEU)
    Endif
  Endif
Endif                                   # Issue X3-112358 - 2018-10-11 by SDEM end

Return

# Issue 91193 - 2013-09-12 by SR
########################################################################
# CONTROL_UOM_STCD  en saisie de détail structure de coût sur un document
#                   Contrôler le type d'unité (Poids,Volume)
#                   Contrôler l'unité saisie par rapport
#                   aux unités catégorie/articles/articles fournisseur
#-----------------------------------------------------------------------
# Paramètres E    LFCY    : Site
#                 LITM    : Article
#                 LBPS    : Fournisseur
#                 LBAS    : UA,Volume,Poids
#                 LUOM    : Unité saisie
#                 LWEU    : Unité de poids du document
#                 LVOU    : Unité de volume du document
# Paramètres S    LRET    : code retour (0 ok / 1 erreur)
#                           Positionnement de GMESSAGE
########################################################################
Subprog CONTROL_UOM_STCD(LFCY,LITM,LBPS,LBAS,LUOM,LWEU,LVOU,LRET)
Value    Char    LFCY,LITM,LBPS,LUOM,LWEU,LVOU
Value    Integer LBAS
Variable Integer LRET
Local   Integer WNUC,I
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM]  : Endif
If clalev([F:ITP]) = 0 : Local File ITMBPS     [ITP]  : Endif
If clalev([F:TCO]) = 0 : Local File TABCOEFF   [TCO]  : Endif
If clalev([F:TUN]) = 0 : Local File TABUNIT    [TUN]  : Endif


# Contrôle type d'unité
If find(LBAS,2,3)
  Read [TUN]TUN0=LUOM
  If LBAS = 3  #unité de poids
    If [F:TUN]UOMTYP <> 4
      GMESSAGE= mess(51,139,1) # Type incorrect
      LRET = 1
      End
    Endif
   Else       #unité de volume
    If [F:TUN]UOMTYP <> 3
      GMESSAGE = mess(51,139,1) # Type incorrect
      LRET = 1
      End
      Endif
    Endif
Endif

# Contrôle unité autorisée
Raz LRET,WNUC

If [F:ITM]ITMREF <> LITM
    Read [F:ITM]ITM0 = LITM
    If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITP]ITMREF <> LITM | [F:ITP]BPSNUM <> LBPS
   Read [F:ITP]ITP0 = LITM;LBPS
   If fstat : Raz [F:ITP] : Endif
Endif
Case LBAS
  When 1 :
    WNUC=dim([F:ITM]PCU)-1
    If !find(LUOM,[F:ITM]STU,[F:ITP]PUU,[F:ITM]PUU,[F:ITP]PCU,[F:ITM]PCU(0,WNUC))
       # xxx ne fait pas partie des unités d'achat, de stock et de conditionnement yy1,yy2,.....
       GMESSAGE = LUOM-mess(168,187,1)
       GMESSAGE-="("+[F:ITP]PUU+","+[F:ITM]PUU+","+[F:ITM]STU
                   If [F:ITP]PCU<>""
                       GMESSAGE+=","+[F:ITP]PCU
                     Endif
                     For I=0 To WNUC
                       If [F:ITM]PCU(I)<>"" : GMESSAGE+=","+[F:ITM]PCU(I) : Endif
                     Next I
                     GMESSAGE+=")"
       LRET = 1
    Endif
  When 2 :
#    If LUOM = [F:ITM]VOU | [F:ITM]VOU = "" : End : Endif
    If LUOM = LVOU  : End : Endif
    Look [TCO]TCO0=LUOM;LVOU
    If fstat
      Look [TCO]TCO0=LVOU;LUOM
      If fstat
        # xxx n'a pas de coefficient de conversion avec l'unité yyy
        GMESSAGE = LUOM-mess(169,187,1)-LVOU
        LRET=1
      Endif
    Endif
  When 3 :
#  If LUOM = [F:ITM]WEU | [F:ITM]WEU = "" : End : Endif
  If LUOM = LWEU  : End : Endif
    Look [TCO]TCO0=LUOM;LWEU
    If fstat
      Look [TCO]TCO0=LWEU;LUOM
      If fstat
        # xxx n'a pas de coefficient de conversion avec l'unité yyy
        GMESSAGE = LUOM-mess(169,187,1)-LWEU
        LRET=1
      Endif
    Endif
Endcase
End

#############################################################################################
# CONTROL_USEFCS  Contrôle de l'exploitation d'une charge sur un document non soldé/validé
# ou dans une structure de coût
#-----------------------------------------------------------------------
# Paramètres E    LFCSCOD : code charge
#                 LORI    : "LIENS" sur action LIENS
#                           "AVANT_MOD" sur action AVANT_MOD
# Paramètres S    LRET    : code retour (0 ok / 1 erreur)
########################################################################
Subprog CONTROL_USEFCS(LFCSCOD,LRET,LORI)
Value    Char    LFCSCOD
Value    Char    LORI
Variable Integer LRET
If !clalev([F:STCD]) :  Local File COSTSTCD    [STCD] : Endif
If !clalev([F:STCL]) :  Local File COSTSTCL    [STCL] : Endif
If !clalev([F:STCH]) :  Local File COSTSTCH    [STCH] : Endif
If !clalev([F:POQ])  :  Local File PORDERQ     [POQ]  : Endif
If !clalev([F:PTD])  :  Local File PRECEIPTD   [PTD]  : Endif
If !clalev([F:PIH])  :  Local File PINVOICE    [PIH]  : Endif
If !clalev([F:PID])  :  Local File PINVOICED   [PID]  : Endif
Raz LRET

# contrôle sur structure de coût
Link[STCL] With [STCH]STCH0 = [F:STCL]STCNUM As [STCK] Where [F:STCL]FCSCOD = LFCSCOD & [F:STCH]ENAFLG=2
For [STCK]
  If LORI = "AVANT_MOD"
    # charge exploitée dans une structure de coût nnn : Modification impossible
    GMESSAGE=func AFNC.MES3(mess(614,199,1),mess(616,199,1),mess(615,199,1), [F:STCL]STCNUM+"/"+ num$([F:STCL]STCLIN))
    mkstat=2
  Else
    Diszo [M:FCS1]DIRFLG, FCSNAT
  Endif
  LRET=1
  Break
Next

# contrôle sur commande non soldée
If LRET : End : Endif
Link [STCD] With [POQ]POQ0 = [F:STCD]VCRNUM;[F:STCD]VCRLIN;[F:STCD]VCRSEQ As [STCK]
&           Where [F:STCD]FCSCOD= LFCSCOD & [F:POQ]LINCLEFLG <2
For [STCK]
  If LORI = "AVANT_MOD"
    #charge exploitée par commande d'achat nnn : Modification impossible
    GMESSAGE=func AFNC.MES3(mess(614,199,1),mess(616,199,1),mess(14,701,1), [F:POQ]POHNUM+"/"+ num$([F:POQ]POPLIN))
    mkstat=2
  Else
    Diszo [M:FCS1]DIRFLG, FCSNAT
  Endif
  LRET=1
  Break
Next

# contrôle sur réception non facturée
If LRET : End : Endif
Link [STCD] With [PTD]PTD0 = [F:STCD]VCRNUM;[F:STCD]VCRLIN As [STCK]
&           Where [F:STCD]FCSCOD= LFCSCOD & [F:PTD]LININVFLG <2
For [STCK]
  If LORI = "AVANT_MOD"
    #charge exploitée par réception nnn : Modification impossible
    GMESSAGE=func AFNC.MES3(mess(614,199,1),mess(616,199,1),mess(6,701,1), [F:PTD]PTHNUM+"/"+ num$([F:PTD]PTDLIN))
    mkstat=2
  Else
    Diszo [M:FCS1]DIRFLG, FCSNAT
  Endif
  LRET=1
  Break
Next

# contrôle sur facture non validée
If LRET : End : Endif
Link [STCD] With [PID]PID0 = [F:STCD]VCRNUM;[F:STCD]VCRLIN , [PIH]PIH0 = [F:PID]NUM As [STCK]
&           Where [F:STCD]FCSCOD= LFCSCOD & [F:PIH]STA <> 3
For [STCK]
  If LORI = "AVANT_MOD"
    #charge exploitée par facture nnn : Modification impossible
    GMESSAGE=func AFNC.MES3(mess(614,199,1),mess(616,199,1),mess(17,701,1), [F:PID]NUM+"/"+ num$([F:PID]PIDLIN))
    mkstat=2
  Else
    Diszo [M:FCS1]DIRFLG, FCSNAT
  Endif
  LRET=1
  Break
Next

End

