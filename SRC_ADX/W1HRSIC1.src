#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRSIC1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:46"
A_USER  = "DOC"
A_STAMP = "20181109230446"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRSIC1 [HRSIC1]
Gosub HORODAT
Local Inpbox "HRSIC1" From GFONCTION At A_STAMP With A_WINDPREV Mask [HRSIC1] As [SIM_]
Grizo [HRSIC1]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [HRSIC1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=25
Return

$ON_SICDIV
Onevent INIT_AREA Call D_SICDIV(zc) From W1HRSIC1
Onevent CONTROL Call C_SICDIV(zc) From W1HRSIC1
Onevent BEFORE_INPUT Call AS_SICDIV(zc) From W1HRSIC1
Return

Subprog D_SICDIV(VALEUR)
Variable Char    VALEUR()
If varinit([M]SICDIV,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"11672","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_SICDIV(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"11672") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_SICDIV(zc) From W1HRSIC1
Onkey   2 Titled GBOUTS Call S_SICDIV(zc) From W1HRSIC1
Onkey 144 Titled GBOUTP Call P_SICDIV(zc) From W1HRSIC1
Onkey 146 Titled GBOUTA Call SA_SICDIV(zc) From W1HRSIC1
Gosub _AFF
End

Subprog C_SICDIV(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"11672","") From SUBADI
If mkstat : GERR = 1 : GZONE = "SICDIV" : GZNUM = 14850 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"11672",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "SICDIV" : GZNUM = 14850 : Endif
Endif
Gosub _AFF
End

Subprog S_SICDIV(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "11672"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_SICDIV(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"11672") From GOBJET
Gosub _AFF
End

Subprog SA_SICDIV(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "11672"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_SICDIV(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "11672"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_SICGRP
Onevent INIT_AREA Call D_SICGRP(zc) From W1HRSIC1
Onevent CONTROL Call C_SICGRP(zc) From W1HRSIC1
Onevent BEFORE_INPUT Call AS_SICGRP(zc) From W1HRSIC1
Return

