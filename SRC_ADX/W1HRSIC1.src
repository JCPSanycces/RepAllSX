Subprog P_SICGRP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "11673"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ETIAGEEXO
Onevent INIT_AREA Call D_ETIAGEEXO(zc) From W1HRSIC1
Onevent BEFORE_INPUT Call AS_ETIAGEEXO(zc) From W1HRSIC1
Return

Subprog D_ETIAGEEXO(VALEUR)
Variable Integer VALEUR
If varinit([M]ETIAGEEXO,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_ETIAGEEXO(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


