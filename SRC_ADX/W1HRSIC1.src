Raz mkstat
Call TITADI(GBOUT1,"11673") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_SICGRP(zc) From W1HRSIC1
Onkey   2 Titled GBOUTS Call S_SICGRP(zc) From W1HRSIC1
Onkey 144 Titled GBOUTP Call P_SICGRP(zc) From W1HRSIC1
Onkey 146 Titled GBOUTA Call SA_SICGRP(zc) From W1HRSIC1
Gosub _AFF
End

Subprog C_SICGRP(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"11673","") From SUBADI
If mkstat : GERR = 1 : GZONE = "SICGRP" : GZNUM = 616 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"11673",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "SICGRP" : GZNUM = 616 : Endif
Endif
Gosub _AFF
End

Subprog S_SICGRP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "11673"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_SICGRP(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"11673") From GOBJET
Gosub _AFF
End

Subprog SA_SICGRP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "11673"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
