###################################################################################################
# PJM2
###################################################################################################
Subprog C_NBPJM2

  If status = 82 or status = 73 Then
    # Insert line
    If [M:PJM2]CPP(nolign-1) = AVOID.ACHAR Then
      ILINE = fmet GZINSPJM.ADDLINE("CPP", [V]CST_ALASTPOS)
      If ILINE <> [V]CST_ANOTDEFINED Then
        Call SHOW_PJM_PJM2(ILINE) From SUBPJMA
      Else
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
        GERR = 4
        mkstat = 2
        GOK = 1
        End
      Endif
      Affzo [M:PJM2]5
    Endif
  Elsif status = 65 Then
    # Delete a line
    IRET = fmet GZINSPJM.ADELLINE("CPP", GZINSPJM.CPP([M:PJM2]COLLIN(nolign-1)).AORDER)
    If IRET = [V]CST_ANOTDEFINED Then
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

