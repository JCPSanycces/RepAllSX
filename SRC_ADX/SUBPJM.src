  Endif
End

###################################################################################################
Subprog AM_OPPNUM(VALEUR)
Variable Char    VALEUR()

  If GREP = AVOID.ACHAR Then
    # Issue X3-61731 - 2018-04-19 by FGR : BEGIN
    If VALEUR = AVOID.ACHAR Then
      GMESSAGE = mess(1182,196,1)
      GERR = 1
      mkstat = 2
      End
    Else
      Local File OPPOR [OPP]
      Look [OPP]OPP0=VALEUR
      If fstat <> [V]CST_AOK Then
        GMESSAGE = mess(1182,196,1)
        GERR = 1
        mkstat = 2
        End
      Endif
    Endif
    # Issue X3-61731 - 2018-04-19 by FGR : END
  Else
    GZINSPJM.OPPNUM = VALEUR
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    If GERR = 1 Then
      GZINSPJM.OPPNUM = GZINSPJM.snapshot.OPPNUM
      GERR = 1
      mkstat = 2
      End
    Else
      Call SHOW_PJM_HEADER() From SUBPJMA
    Endif
  Endif
End

