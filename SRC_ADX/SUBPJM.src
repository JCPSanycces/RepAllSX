#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion objet PJM
###################################################################################################
# Objet PJM
###################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE               From SUBPJMA
    When "FERME"        : Gosub FERME               From SUBPJMA
    When "LIENS"        : Gosub LIENS               From SUBPJMA
    When "FIN_ACTION"   : Gosub FIN_ACTION          From SUBPJMA
    When "ABANDON"      : Gosub ABANDON             From SUBPJMA
    When "BOITE"        : Gosub BOITE               From SUBPJMA
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE         From SUBPJMA
    When "FILTRE"       : Gosub FILTRE              From SUBPJMA
    When "FILGAUCHE"    : Gosub FILGAUCHE           From SUBPJMA
    When "AVANTBOUT"    : Gosub AVANTBOUT           From SUBPJMA     # Issue X3-99928 - 2018-07-19 by FGR
    When "SETBOUT"      : Gosub SETBOUT             From SUBPJMA
    When "EXEBOUT"      : Gosub EXEBOUT             From SUBPJMA
    When "STATUT"       : Gosub STATUT              From SUBPJMA
    When "RAZCRE"       : Gosub RAZCRE              From SUBPJMA
    When "RAZDUP"       : Gosub RAZDUP              From SUBPJMA
    When "CREATION"     : Gosub CREATION            From SUBPJMA
    When "APRES_CRE"    : Gosub APRES_CRE           From SUBPJMA
    When "MODIF"        : Gosub MODIF               From SUBPJMA
    When "APRES_MOD"    : Gosub APRES_MOD           From SUBPJMA
    When "AV_ANNULE"    : Gosub AV_ANNULE           From SUBPJMA
    When "ANNULE"       : Gosub ANNULE              From SUBPJMA
    When "AVANT_OUVRE"  : Gosub AVANT_OUVRE         From SUBPJMA
    When Default
  Endcase
Return

###################################################################################################
# Screens fields
###################################################################################################
# PJM0
###################################################################################################
Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()

Local Integer MY_STATUS
Local Char WMODELE(GLONGCM)

  # ------------------------
  If GZINSPJM = null Then
    GMESSAGE = mess(1013,196,1)
    GERR = 1
    mkstat = 2
    End
  Endif
  # ------------------------
  GZINSPJM.SALFCY = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GZINSPJM.SALFCY = GZINSPJM.snapshot.SALFCY
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_PJM_HEADER() From SUBPJMA
  Endif
  # ------------------------
  Call SETGCM(GSOCIETE, [L]WMODELE) From CPTDIV
  #----- Chargement codes plans, types de référentiel d'une société   -----#
  Call SETPLAN3([L]WMODELE, GNBCOA, GCOA, GTYPLED) From CPTDIV
  [L]MY_STATUS = func SUBPJMA.CDIE_CLASS_TO_SCREEN(GZINSPJM.PJM(1), "PJM4", "NBRDIE", "SUBPJMA")
  Affzo [M:PJM4]1-99
  Call LOAD_TITLES_10_20() From SUBPJMA          # Issue X3-91451 - 2018-05-29 by FGR
End

###################################################################################################
Subprog AM_OPEDEFFCY(VALEUR)
