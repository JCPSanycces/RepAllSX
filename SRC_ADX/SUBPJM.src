Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR

  # Issue X3-101322 - 2018-08-09 by FGR
  If VALEUR = AVOID.ADATE and [M:PJM1]ENDDAT <> AVOID.ADATE Then
    VALEUR = [M:PJM1]ENDDAT
  Endif
End

