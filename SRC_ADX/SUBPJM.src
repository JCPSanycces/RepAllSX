    End
  Else
    Call SHOW_PJM_PJM6([M:PJM6]COLLIN(nolign-1)) From SUBPJMA
  Endif
  Affzo [M:PJM6]1-99
End

###################################################################################################
Subprog AM_PAFROL(VALEUR)
Variable Char    VALEUR()

  GZINSPJM.PJM(1).PAF([M:PJM6]COLLIN(nolign-1)).PAFROL = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GZINSPJM.PJM(1).PAF([M:PJM6]COLLIN(nolign-1)).PAFROL = GZINSPJM.PJM(1).PAF([M:PJM6]COLLIN(nolign-1)).snapshot.PAFROL
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_PJM_PJM6([M:PJM6]COLLIN(nolign-1)) From SUBPJMA
  Endif
  Affzo [M:PJM6]1-99
End

