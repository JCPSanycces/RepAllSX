# PJM5E
###################################################################################################
Subprog CL_REFRESH(VALEUR)
Variable Char    VALEUR()

  If GREP <> "C" Then        # Issue X3-91451 - 2018-05-29 by FGR : Not allowed in create mode
    Call EXTRACT_ALL_10_20() From SUBPJMA
  Endif
End

###################################################################################################
# PJM6
###################################################################################################
Subprog C_NBPJM6

  If status = 82 or status = 73 Then
    # Insert line
    If [M:PJM6]PAFCLB(nolign-1) = AVOID.ACHAR Then
      ILINE = fmet GZINSPJM.PJM(1).ADDLINE("PAF", [V]CST_ALASTPOS)
      If ILINE <> [V]CST_ANOTDEFINED Then
