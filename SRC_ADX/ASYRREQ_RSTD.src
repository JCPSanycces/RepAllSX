#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe ASYRREQ


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
Endcase
Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
     When "AQUERY_TRANS_AFTER"       : Gosub AQUERY_TRANS_AFTER
    Endcase
Endcase
Return




$AQUERY_TRANS_AFTER
Local Integer STAT
Local File ABATRQT [ABR], ABATRQTL [ABL], ABATPAR [ABP]
Local Char HH(10), HS(10)
Local Date DD

Onerrgo ERR_TRANS
Local File =this.ABR.DOSSIER+".AUTILIS" [AUS]
Read [AUS]CODUSR=this.ABR.USER
If fstat
 this.ABR.LOGIN=this.ABR.USER
Else
 this.ABR.LOGIN=[F:AUS]LOGIN
Endif
#If this.ABR.LAN=""
# this.ABR.LAN=func ADS_TOOL.GET_LANDEF(this.ABR.DOSSIER)
#Endif
If this.ABR.LAN<>""
this.ABR.LANISO=func ADS_TOOL.SEARCH_ISOLAN(this.ABR.DOSSIER,this.ABR.LAN )
Endif

If this.ABR.MAISRV<>2 & this.ABR.TACHE<>""
 Local File ABATTAC [ABT]
 Read [ABT]CODTAC=this.ABR.TACHE
 If fstat : Raz [F:ABT] : Endif
 this.ABR.MAISRV = func ASYRDIV.NEED_PRIMARY_SERVER(this.ABR.TACHE,[F:ABT]FONCTION)
Endif
this.ABR.RECURRENT=(this.ABR.FRQ<>0)+1


Gosub DEF_DOSSIER From SERVSYS
If filinfo(filpath("",GBATCHDIR+"/TRA/RQT"+format$("N0:8#",this.ABR.NUMREQ),"tra",NOMDOSX3,"",adxmac(0)),0)>=0
 If baseUrl<>""
  this.RQTTRAURL = baseUrl
 Else
  this.RQTTRAURL = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"AWRKSYRA")
 Endif
 If right$(this.RQTTRAURL,len(this.RQTTRAURL))<>"/"
  this.RQTTRAURL += '/'
 Endif
 this.RQTTRAURL+="$service/upload?fileName=[SRV]/TRA/RQT"+format$("N0:8#",this.ABR.NUMREQ)+".tra&type=1&$format=text/plain"
Else
 #[L]STAT = fmet this.ASETLINKDISABLE("ATRARQT",[V]CST_AFFLNKREC)
 this.RQTTRAURL="$format=text/plain"
Endif

# X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
Call SCHEDULING_DATE_TIME   ( [L]DD, [L]HH, [L]HS) From SERVEUR

If this.ABR.FLAG<>1
this.EXENOW = 2
Elsif this.ABR.DAT<DD or (this.ABR.DAT=DD & this.ABR.HEURE<=HH)
this.EXENOW = 2
Else
this.EXENOW = 1
Endif
Onerrgo
Return

$ERR_TRANS
If find(this.ABR.FLAG,1,2,5)>0
Local Char MESSAGE(250)
MESSAGE=errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-":"-errmes$(errn)-errm
Local Integer REQUETE,NUMERO
REQUETE=this.ABR.NUMREQ
NUMERO=this.ABR.NUMGRP
Gosub TR_INTERR From ASYRREQ_CSTD
this.ABR.FLAG=NEWFLAG
Read [ABR]NUMREQ=REQUETE
If fstat
 Return
Endif
Local Char    RQTID(50)
Local Char    FICTRQ(GDIMFIC)
Gosub IDENT_RQT From SERVEUR

# X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
Call SCHEDULING_DATE_TIME   ( [L]DD, [L]HH, [L]HS) From SERVEUR

#Call STRACE(FICTRA,10001,[F:ABR]NUMREQ,toupper(WSEVERITY)-':'-WMESSAGE) From SERVEUR
Call RTRACE(FICTRQ,10001,MESSAGE) From SERVEUR
Endif
Resume

