  If WRET : Raz [F:TVT] : Endif
  #Read [TVT]TVT0=[F:SIH]TAX(1)
  #--/CPO
  If [F:SIV]NUM<>""
#   recherche taux de la taxe dans la table des taxes
    Read [SVV]SVV0=4;[F:SIH]NUM;[F:SIH]TAX(1)
    If !fstat
      [F:TVT]VATRAT=[F:SVV]VATRAT
    Endif
##   recherche taux de la taxe dans les taxes produit
#    I1 = find([F:SIH]TAX(1),[F:SIV]VAT(0..dim([F:SIV]VAT)-1))
#    If I1
#      [F:TVT]VATRAT=[F:SIV]VATRAT(I1-1)
#    Else
##     recherche taux dans les taxes pied facture
