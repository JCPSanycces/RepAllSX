#----------------------------------------------------------------------
#   Echeance1 ( [F:DUD] )
$E_GIMP41
Local Integer I1
Raz [F:DUD]
#p Filter [DUD] Where NUM=[F:SIH]NUM Order By Key DUD1
#p For [DUD]
For [DUD]DUD1 Where ACCNUM=[F:SIH]ACCNUM
  If !fstat : I1 +=1
    If I1=1 : Break : Endif
  Endif
Next
If I1<>1 : Raz [F:DUD] : Endif
#p Filter [DUD]
Return

#----------------------------------------------------------------------
#   Echeance2 ( [F:DUD] )
$E_GIMP42
Local Integer I1
Raz [F:DUD]
For [DUD]DUD1 Where ACCNUM=[F:SIH]ACCNUM
  If !fstat : I1 +=1
    If I1=2 : Break : Endif
  Endif
Next
If I1<>2 : Raz [F:DUD] : Endif
Return

#----------------------------------------------------------------------
#   Echeance3 ( [F:DUD] )
$E_GIMP43
Local Integer I1
Raz [F:DUD]
For [DUD]DUD1 Where ACCNUM=[F:SIH]ACCNUM
  If !fstat : I1 +=1
    If I1=3 : Break : Endif
  Endif
Next
If I1<>3 : Raz [F:DUD] : Endif
Return

#----------------------------------------------------------------------
#   Echeance4 ( [F:DUD] )
$E_GIMP44
Local Integer I1
Raz [F:DUD]
For [DUD]DUD1 Where ACCNUM=[F:SIH]ACCNUM
  If !fstat : I1 +=1
    If I1=4 : Break : Endif
  Endif
Next
If I1<>4 : Raz [F:DUD] : Endif
Return

#----------------------------------------------------------------------
#   Echeance5 ( [F:DUD] )
$E_GIMP45
Local Integer I1
Raz [F:DUD]
For [DUD]DUD1 Where ACCNUM=[F:SIH]ACCNUM
  If !fstat : I1 +=1
    If I1=5 : Break : Endif
  Endif
Next
If I1<>5 : Raz [F:DUD] : Endif
Return

#----------------------------------------------------------------------
#   Texte ligne facture
$E_GIMP51

Return

#----------------------------------------------------------------------
#   Chgt article ( [F:ITM] + [F:ITS] + [F:ITU] )
$E_GIMP52
Raz [F:ITM], [F:ITS], [F:ITU]
If [F:ITM]ITMREF<>[F:SID]ITMREF
  Read [ITM]ITM0=[F:SID]ITMREF
  If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITS]ITMREF<>[F:SID]ITMREF
  Read [ITS]ITS0=[F:SID]ITMREF
  If fstat : Raz [F:ITS] : Endif
Endif
If [F:ITU]ITMREF<>[F:SID]ITMREF | [F:ITU]BPCNUM<>[F:SIV]BPCORD
  Read [ITU]ITU0=[F:SID]ITMREF;[F:SIV]BPCORD
  If fstat : Raz [F:ITU] : Endif
Endif
Return

#----------------------------------------------------------------------
#   Poids brut ligne
$E_GIMP53

Return

#----------------------------------------------------------------------
#   Total taxes ligne ( dev. facture )
$E_GIMP54
GIMP(54)=num$(sum([F:SID]AMTTAXLIN))
Return

#######################################################################
