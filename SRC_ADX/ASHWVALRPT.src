#<AdxTL>@(#)0.0.0.0 $Revision$

Gosub TEST From ASHWVAL
End

#---------------------------------------------------------------------------------------------------#
# Ecriture du traitement
#---------------------------------------------------------------------------------------------------#
Subprog VALTRT_RPT(DOSSIER,CODREP,ASHW,AERR)
Value Char DOSSIER , CODREP
Variable  Instance  ASHW  Using C_ASW
Variable  Instance  AERR(1..) Using C_AERROR

Gosub DEFVAR From ASHWVALTRT

Raz [L]NBPRG
NOMTRTREP  = func APREFIXTRT.GET_PREFIX_RPT+CODREP : # WMRPT
Call STC_VERF(NOMTRTREP,ASHW.ACLAV.IDENTREP,APPLI,MACHINE,"TRT",OK,AERR) From ACLASUB
If OK
 Raz CLOB
 Gosub CRYSTAL
 Call STC_DEB(APPLI,MACHINE,[L]NOMTRTREP,ASHW.ACLAV.IDENTREP,[L]CODREP,ASHW.INTITREP,ASHW.ACLAV.MAGIC,ASHW.ACLAV.TITETA,"TRT") From ACLASUB
 Call TRT_FIN(CLOB,[L]NOMTRTREP,0,DOSSIER,"TRT",OK,AERR) From ACLASUB
 If  maxtab(AERR)>0 : End : Endif
Endif
Close Local File
End

#-------------------------------------------------------#
$ERFIC
ER = errn
Resume

#-------------------------------------------------------#
$ADDCLB
Append CLOB,space$(DIF)+LIGNE+chr$(10)
Return

#-------------------------------------------------------#
$ADDCLB0
Append CLOB,"&"+space$(DIF)+LIGNE
Raz LIGNE
Return

#-------------------------------------------------------#
$CRYSTAL
LIGNE = "#-------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# load parameters of report" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$ALOAD_REPORT_CRYSTAL" : Gosub ADDCLB
LIGNE = "Case [L]ACODLNK" : Gosub ADDCLB
Raz J
Local Instance ASWK Using C_ASWLNK
For I=1 To maxtab(ASHW.ASWK)
 ASWK = ASHW.ASWK(I)
 If ASWK.TYPLNK=6
  DIF +=5
  LIGNE = 'When "'+ASWK.CODLNK+'"' : Gosub ADDCLB
  DIF +=5
  LIGNE = '[L]ETAT="'+ASWK.RPTCOD+'"': Gosub ADDCLB
  For J=1 To maxtab(ASWK.ATBPAR)
   LIGNE = '[L]TBPAR('+num$(J)+') = "'
   If ASWK.ATBPAR(J).TYPKEY=3
     Case tolower(right$(ASWK.ATBPAR(J).CODPAR,len(ASWK.ATBPAR(J).CODPAR)-2))
      When "deb" : LIGNE += left$(ASWK.ATBPAR(J).CODPAR,len(ASWK.ATBPAR(J).CODPAR)-3)+"fin"
      When "str" : LIGNE += left$(ASWK.ATBPAR(J).CODPAR,len(ASWK.ATBPAR(J).CODPAR)-3)+"end"
     Endcase
   Else
    LIGNE += ASWK.ATBPAR(J).CODPAR
   Endif
   LIGNE += '"' : Gosub ADDCLB
   LIGNE = "[L]TBVAL("+num$(J)+") = "
   If ASWK.ATBPAR(J).ALIAS<>""
    LIGNE += "num$(WDET."+ASWK.ATBPAR(J).VALEUR+")"
   Else
    LIGNE += +"'"+ASWK.ATBPAR(J).VALEUR+"'"
   Endif
   Gosub ADDCLB
   Raz LIGNE : Gosub ADDCLB
  Next
  DIF -=5
  DIF -=5
 Endif
Next
DIF+=5 : LIGNE = "When Default" : Gosub ADDCLB : DIF-=5
LIGNE = "Endcase" : Gosub ADDCLB

LIGNE = "Return": Gosub ADDCLB
LIGNE = "": Gosub ADDCLB
Return

