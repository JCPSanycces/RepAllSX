#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################################################
#  Sous programmes pour la gestion des pistes                           Module CRM     aout 2006
##########################################################################################################
#
#  CRE_AIN : traitement table CONTACTCRM en création
#  MODIF_AIN : traitement table CONTACTCRM en modif
#  ANNULE_AIN : : traitement table CONTACTCRM en annulation
#  LIENS_AIN : : traitement table CONTACTCRM au liens
#  INICLOB : Initialisation des clob
#  SAVECLOB : Enregistrement des CLOBs
#  DELCLOB : Suppression des CLOBs
#  LOADCLOB : Chargement du CLOB compte-rendu
#  DEFOBJORI : Définition du type de pièce
#  VERIFORI : Vérification cohérence entre origine et numéro de pièce 
#  GEREMODIFLDSCOR : gestion / mise à jopur table CORRESPOND
#  TEST_AIN_AIN_SAVE  : test si différence sur écran pour pour partie CONTACTCRM
#  TEST_LDS_LDS_SAVE  : test si différence sur écran pour pour partie LEAD
#  TEST_AIN_F_CORW_F_AIN 
#  TEST_LDS_F_CORW_F_LDS
#  LIELDSTOBPR        : lie une LEAD à un tiers existant
##########################################################################################################
$CRE_AIN
  [F:AIN]CNTNUM = [F:LDS]PSTNUM
  #
  Gosub ALIM_F_AIN_CRE_MOD
  [F:AIN]CREUSR = GUSER
  [F:AIN]CREDAT = date$    
  #
  Write [AIN]
  If fstat <> 0 Then
    #Erreur lors de l'enregistrement table CONTACTCRM
    GMESSAGE = mess(460,177,1)
    GERR = 2
    GOK = 0
  Endif
Return

##########################################################################################################
$MODIF_AIN
  Readlock [AIN]AIN0=[F:LDS]PSTNUM
  If fstat <> 0 Then
    #Erreur lors de la lecture table CONTACTCRM+" : CNTNUM="+[F:LDS]PSTNUM
    GMESSAGE = mess(461,177,1) - ": CNTNUM=" + [F:LDS]PSTNUM
    GERR = 2
    GOK = 0
    Return
  Endif
  #
  Gosub ALIM_F_AIN_CRE_MOD
  [F:AIN]UPDUSR = GUSER
  [F:AIN]UPDDAT = date$    
  #
  Rewrite [AIN]
  If fstat <> 0 Then
    #Erreur lors de l'enregistrement table CONTACTCRM
    GMESSAGE = mess(460,177,1)
    GERR = 2
    GOK = 0
  Endif
Return

##########################################################################################################
$ALIM_F_AIN_CRE_MOD
  [F:AIN]CNTTTL = [M:LDS0]CNTTTL
  [F:AIN]CNTLNA = [M:LDS0]CNTLNA
  [F:AIN]CNTFNA = [M:LDS0]CNTFNA
  [F:AIN]CNTFULNAM = func SUBAIN.CLE([F:AIN]CNTLNA, [F:AIN]CNTFNA)
  [F:AIN]CNTTYP = 2 # =Lead
  #
  [F:AIN]CRY = [M:LDS3]CRY
  [F:AIN]CRYNAM = [M:LDS3]CRYNAM
  [F:AIN]CNTETS = [M:LDS3]CNTETS
  [F:AIN]CNTFAX = [M:LDS3]CNTFAX
  [F:AIN]CNTMOB = [M:LDS3]CNTMOB
  [F:AIN]CNTEMA = [M:LDS3]CNTEMA
  [F:AIN]CNTLAN = [M:LDS3]CNTLAN
  [F:AIN]CNTBIR = [M:LDS3]CNTBIR
  [F:AIN]CNTCSP = [M:LDS3]CNTCSP
  [F:AIN]ADD(0) = [M:LDS3]ADD1
  [F:AIN]ADD(1) = [M:LDS3]ADD2
  [F:AIN]ADD(2) = [M:LDS3]ADD3
  [F:AIN]ZIP = [M:LDS3]ZIP
  [F:AIN]CTY = [M:LDS3]CTY
  If dim([M:LDS3]SAT) > 0 Then
    [F:AIN]SAT = [M:LDS3]SAT
  Endif
  [F:AIN]CNTFBDMAG = 1 : # par définition un lead accepte de recevoir des mailings puisqu'il a accepté d'être un lead
Return

##########################################################################################################
$ANNULE_AIN
  Delete [AIN] Where [F:AIN]CNTNUM=[M:LDS0]PSTNUM
  If fstat <> 0 Then
    #Erreur lors de la suppression table CONTACTCRM+" : CNTNUM="+[M:LDS0]PSTNUM
    GMESSAGE = mess(464,177,1) - ": CNTNUM=" + [M:LDS0]PSTNUM
    GERR = 2
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
$LIENS_AIN
  Read [AIN]AIN0=[F:LDS]PSTNUM
  If fstat <> 0 Then
    #Erreur lors de la lecture table CONTACTCRM+" : CNTNUM="+[F:LDS]PSTNUM
    GMESSAGE = mess(461,177,1) - ": CNTNUM=" + [F:LDS]PSTNUM
    GERR = 2
    GOK = 0
    Return
  Endif
  [M:LDS0]CNTTTL = [F:AIN]CNTTTL
  [M:LDS0]CNTLNA = [F:AIN]CNTLNA
  [M:LDS0]CNTFNA = [F:AIN]CNTFNA
  [M:LDS3]CRY = [F:AIN]CRY
  [M:LDS3]CRYNAM = [F:AIN]CRYNAM
  [M:LDS3]CNTETS = [F:AIN]CNTETS
  [M:LDS3]CNTFAX = [F:AIN]CNTFAX
  [M:LDS3]CNTMOB = [F:AIN]CNTMOB
  [M:LDS3]CNTEMA = [F:AIN]CNTEMA
  [M:LDS3]CNTLAN = [F:AIN]CNTLAN
  [M:LDS3]CNTBIR = [F:AIN]CNTBIR
  [M:LDS3]CNTCSP = [F:AIN]CNTCSP
  [M:LDS3]ADD1 = [F:AIN]ADD(0)
  [M:LDS3]ADD2 = [F:AIN]ADD(1)
  [M:LDS3]ADD3 = [F:AIN]ADD(2)
  [M:LDS3]ZIP = [F:AIN]ZIP
  [M:LDS3]CTY = [F:AIN]CTY
  If dim([M:LDS3]SAT) > 0 Then
    [M:LDS3]SAT = [F:AIN]SAT
  Endif
Return

##########################################################################################################
# Initialisation des clob
$INICLOB
Local Char SZCTLCLOB(250)

  Raz SZCTLCLOB
  Setlob SZCTLCLOB With [M:LDS5]CLOB
  If SZCTLCLOB <> "" Then
    [M:LDS5]NUMCLOB = [M:LDS0]PSTNUM
    [F:LDS]NUMCLOB = [M:LDS5]NUMCLOB    
  Else    
    Raz [M:LDS5]NUMCLOB
    Raz [F:LDS]NUMCLOB
  Endif
Return

##########################################################################################################
#Enregistrement des CLOBs
$SAVECLOB
  If [M:LDS0]PSTNUM <> "" Then
    Gosub DELCLOB
    If GOK < 1 Then
      Return
    Endif
  Endif
  #Compte-rendu
  If [M:LDS5]NUMCLOB <> "" Then
    Raz [F:HD8]
    [F:HD8]NUM = [M:LDS5]NUMCLOB
    [F:HD8]TYP = "LDS"
    [F:HD8]CLOB = [M:LDS5]CLOB
    Write [HD8]
    If fstat <> 0 Then
      #Erreur lors de l'enregistrement du compte-rendu de la LEAD.
      GMESSAGE = mess(462,177,1)
      GERR = 1
      Call FSTA("HD8") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
#Suppression des CLOBs
$DELCLOB
  Delete [HD8] Where [F:HD8]NUM = [M:LDS0]PSTNUM and [F:HD8]TYP = "LDS"
  If fstat <> 0 Then
    #Erreur lors de la suppression du compte-rendu de la LEAD
    GMESSAGE = mess(436,177,1)
    GERR = 1
    Call FSTA("HD8") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
# Chargement du CLOB compte-rendu
$LOADCLOB
  If [M:LDS5]NUMCLOB = "" Then
    Raz [M:LDS5]CLOB
    return
  Endif
  Read [HD8]HD80=[M:LDS5]NUMCLOB;"LDS"
  If fstat <> 0 Then
    Raz [M:LDS5]CLOB
  Else
    [M:LDS5]CLOB = [F:HD8]CLOB
    [M:LDS5]NUMCLOB = [F:HD8]NUM
  Endif
Return

##########################################################################################################
#Définition du type de pièce
$DEFOBJORI
  Case [M:LDS5]PSTORI
    When 0
      [M:LDS5]PSTORIOBC = ""
    When 1
      [M:LDS5]PSTORIOBC = ""
    When 2
      [M:LDS5]PSTORIOBC = "OMM"
    When 3
      [M:LDS5]PSTORIOBC = "OMP"
    When 4
      [M:LDS5]PSTORIOBC = "OMT"
    When 5
      [M:LDS5]PSTORIOBC = "OMN"
    When 6
      [M:LDS5]PSTORIOBC = "CMG"
    When Default
      Raz [M:LDS5]PSTORIOBC
  Endcase
Return

##########################################################################################################
#Vérification cohérence entre origine et numéro de pièce
$VERIFORI
Local Integer IBOBLOGATOIRE

  IBOBLOGATOIRE = 0
  Case [M:LDS5]PSTORI
    When 2
      IBOBLOGATOIRE = 1
    When 3
      IBOBLOGATOIRE = 1
    When 4
      IBOBLOGATOIRE = 1
    When 5
      IBOBLOGATOIRE = 1
    When 6
      IBOBLOGATOIRE = 1
    When Default
  Endcase
  If IBOBLOGATOIRE = 1 Then
    If [M:LDS5]PSTORIVCR = "" Then
      #Le numéro de pièce / ligne est obligtoire pour la liaison spécifiée.    
      GMESSAGE = mess(442,177,1)
      GERR = 2
      OK = 0   
    Endif
  Endif
Return

##########################################################################################################
$GEREAFFECTLDSCOR
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR 

Local Integer INBCOR
Local Char SZCOR(GLONVCR)
Local Char SZSYDUSR
Local Char SZSYDUSRINI
Local Integer IBUSRSYNC_OK
Local Integer IBUSRINISYNC_OK
Local Integer IBSYNCHRO
Local Integer IBEXIST
Local Integer IBGEREUSR_SYD
Local Integer IBERROR
Local Integer INBDELETE
Local Integer LERRCOD
Local Integer INBRECORD

  If !clalev([F:SYD]) : Local File SYNCDATA [SYD] : Endif
  If !clalev([F:CORL]) : Local File CORRESPOND [CORL] : Endif
  If !clalev([F:COPL]) : Local File CORREP [COPL] : Endif
  IBRETOUR = 1
  INBCOR = 0
  Raz SZSYDUSR
  Raz SZSYDUSRINI
  IBUSRSYNC_OK = 0
  IBUSRINISYNC_OK = 0
  IBSYNCHRO = 0
  IBEXIST = 0
  IBGEREUSR_SYD = 0
  IBERROR = 0
  INBDELETE = 0
  INBRECORD = 0
  LERRCOD = 0
  #
  If GCRMSYNC <> 2 Then
    Return  # FGR 03/01/2012 : X3SUIVI79049 : pas End
  Endif
  If GCRMSYNCCOR <> 2 Then
    Return  # FGR 03/01/2012 : X3SUIVI79049 : pas End
  Endif
  If [M:LDS0]PSTREP = [M:PS0S]PSTREP Then
    #pas de modification d'affectation
  Endif
  INBCOR = 0
  For [CORL] Where [F:CORL]CNTNUM=[M:LDS0]PSTNUM
    If [F:CORL]BPRNUM <> "" Then
      #Erreur : la LEAD est liée à un correspondant rattaché à un tiers.+"( "+[F:CORL]CORNUM+" )"
      GMESSAGE = mess(475,177,1) - "(" + [F:CORL]CORNUM + ")"
      GERR = 1
      IBERROR = 1
      GOK = 0
      Break
    Endif
    SZCOR = [F:CORL]CORNUM
    INBCOR += 1
  Next
  If INBCOR > 1 Then
    #Erreur : la LEAD est liée à plusieurs correspondants.
    GMESSAGE = mess(476,177,1)
    GERR = 1
    IBERROR = 1
    GOK = 0
  Endif
  If IBERROR = 1 Then
    GOK = 0
  Endif
  If GOK < 1 Then
    Return
  Endif
  #
  If INBCOR = 1 Then
    #Un correspondant existe déjà
    IBSYNCHRO = 0
    If [M:LDS0]PSTREP <> "" Then
      #---------------------------------------------------#
      # Récupération de l'utilisateur
      #---------------------------------------------------#
      Call SYDUSRFROMREP ([M:LDS0]PSTREP, SZSYDUSR, IBUSRSYNC_OK, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
      If IBUSRSYNC_OK = 1 Then
        Call SYDUSRSYNCTYP (SZSYDUSR, "COR", IBUSRSYNC_OK, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
        If IBUSRSYNC_OK = 1 Then
          IBSYNCHRO = 1
        Endif
      Endif
    Endif
    If IBSYNCHRO = 1 and IBERROR = 0 Then
      #On peut synchroniser et COR existe
      #On vérifie si le correspondant est défini pour le représentant
      Call CORREPEXIST (SZCOR, [M:LDS0]PSTREP, IBEXIST, IERRINF, ICHAPTER, IBRETOUR) From SUBCORB
      If IBRETOUR = 1 Then
        If IBEXIST = 0 Then
          Call CORREPCRE(SZCOR, [M:LDS0]PSTREP, IERRINF, ICHAPTER, IBRETOUR) From SUBCORB
          If IBRETOUR = 1 Then
            IBGEREUSR_SYD = 1
          Else
            IERROR = 1
            GMESSAGE = mess(IERRINF,ICHAPTER,1)
          Endif
        Endif
      Else
        IBERROR = 1
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
      Endif
    Endif        
    IBSYNCHRO = 0
    If [M:PS0S]PSTREP <> "" and IBERROR = 0 Then
      Call CORREPDEL(SZCOR, [M:PS0S]PSTREP, INBDELETE, IERRINF, ICHAPTER, IBRETOUR) From SUBCORB
      If IBRETOUR = 1 Then
        If INBDELETE <> 0 Then
          #---------------------------------------------------#
          # Récupération de l'utilisateur
          #---------------------------------------------------#
          Call SYDUSRFROMREP ([M:PS0S]PSTREP, SZSYDUSRINI, IBUSRINISYNC_OK, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
          If IBRETOUR = 1 Then
            INBRECORD = 0
            Filter [SYD] Where [F:SYD]SYDUSR = SZSYDUSRINI and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDKEY = SZCOR and [F:SYD]SYDGEN = 0
            For [SYD]SYD1
              INBRECORD += 1
              Readlock [SYD]Curr
              If fstat = 0 Then
                [F:SYD]SYDATTTYP = "A"
                [F:SYD]SYDOTKSTA = 1
                [F:SYD]SYDUPD = 0
                [F:SYD]SYDDAT = date$
                [F:SYD]SYDHOU = time$
                [F:SYD]UPDUSR= GUSER
                [F:SYD]UPDDAT = date$
                Rewrite [SYD]
                If fstat <> 0 Then
                  IBERROR = 1
                  #Erreur lors de la modification des données de synchronisation pour le correspondant+" : " + SZCOR
                  GMESSAGE = mess(280,177,1) - ":" - SZCOR
                  Break
                Endif
              Else
                IBERROR = 1
                #Impossible de locker les données de synchronisation pour le correspondant+" : " + SZCOR
                GMESSAGE = mess(281,177,1) - ":" - SZCOR
                Break
              Endif
            Next
            Filter [SYD]
            If INBRECORD = 0 and IBERROR = 0 Then
              #On n'a pas de données de synchro, il faut créer
              Call SYDWRITE (SZSYDUSRINI, "", SZCOR, "COR", "A", 1, 0, 0, IERRINF, IERRINF, IBRETOUR)  From SUBSYDB
              If IBRETOUR = 0 Then
                IBERROR = 1
                GMESSAGE = mess(IERRINF,IERRINF,1)
              Endif
            Endif
          Endif
        Endif
      Else
        IBERROR = 1
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
      Endif
    Endif
  Else
    #On n'a pas de correspondant, il faut creer 
    Call CRECOR("SUBLDSCORD", 1, 0, SZCOR, LERRCOD) From SUBCORCC
    If LERRCOD <> 0 Then
      #Erreur lors de la création du correspondant
      GMESSAGE = mess (318,177,1)
      IBERROR = 1
    Else
      IBGEREUSR_SYD = 1 
    Endif
  Endif
  If IBGEREUSR_SYD = 1 and IBERROR = 0 Then
    INBRECORD = 0
    Filter [SYD] Where [F:SYD]SYDUSR = SZSYDUSR and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDKEY = SZCOR and [F:SYD]SYDGEN = 0
    For [SYD]SYD1
      INBRECORD += 1
      Readlock [SYD]Curr
      If fstat = 0 Then
        [F:SYD]SYDATTTYP = "R"
        [F:SYD]SYDOTKSTA = 1
        [F:SYD]SYDUPD = 0
        [F:SYD]SYDDAT = date$
        [F:SYD]SYDHOU = time$
        [F:SYD]UPDUSR= GUSER
        [F:SYD]UPDDAT = date$
        Rewrite [SYD]
        If fstat <> 0 Then
          IBERROR = 1  
          #Erreur lors de la modification des données de synchronisation pour le correspondant :
          GMESSAGE = mess(280,177,1) 
          Break
        Endif
      Else
        IBERROR = 1
        #Impossible de locker les données de synchronisation pour le correspondant :
        GMESSAGE = mess(281,177,1)
        Break
      Endif
    Next
    Filter [SYD]
    If INBRECORD = 0 and IBERROR = 0 Then
      #On n'a pas de données de synchro, il faut créer
      Call SYDWRITE (SZSYDUSR , "", SZCOR, "COR", "C", 1, 0, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
      If IBRETOUR = 0 Then
        IBERROR = 1
        GMESSAGE = mess(IERRINF,ICHAPTER,1) 
      Endif
    Endif
  Endif
  If IBERROR = 1 Then
    GERR = 1
    GOK = 0
  Endif
Return

##########################################################################################################
$GEREMODIFLDSCOR
Local Integer IBMODIF
Local Integer IBWRITE
Local Integer IBERROR
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Char SZCOPUSER
Local Integer IBUSRSYNC_OK
Local Integer INBRECORD
Local Integer WI

  If !clalev([F:SYD]) : Local File SYNCDATA [SYD] : Endif
  If !clalev([F:CORL]) : Local File CORRESPOND [CORL] : Endif
  If !clalev([F:COPL]) : Local File CORREP [COPL] : Endif
  IBMODIF = 0
  IBERROR = 0
  IBWRITE = 0
  Raz SZCOPUSER
  IBUSRSYNC_OK = 0
  INBRECORD = 0
  #Est ce qu'il y a des modifs dans la partie AIN
  Gosub TEST_AIN_AIN_SAVE
  If IBMODIF = 0 Then
    Gosub TEST_LDS_LDS_SAVE
  Endif
  If IBMODIF = 1 Then
    #Il y a eu des changements
    For [CORL] Where [F:CORL]CNTNUM = [F:LDS]PSTNUM and [F:CORL]CORTYP = "AIN" and [F:CORL]CNTNUM <> ""
      IBWRITE = 0
      #On verifie si différence sur la partie interlocuteur
      Gosub TEST_AIN_F_CORW_F_AIN
      #On verifie si différence sur la partie LEAD
      If IBMODIF = 1 Then
        #On a des différences, on reporte
        [F:CORL]TTL = [M:LDS0]CNTTTL
        [F:CORL]LNA = [M:LDS0]CNTLNA
        [F:CORL]FNA = [M:LDS0]CNTFNA
        [F:CORL]BIR = [M:LDS3]CNTBIR
        [F:CORL]LAN = [M:LDS3]CNTLAN
        [F:CORL]CSP = [M:LDS3]CNTCSP
        [F:CORL]HOMCRY = [M:LDS3]CRY
        [F:CORL]HOMCRYNAM = [M:LDS3]CRYNAM
        If dim([M:LDS3]ADD1) > 0 Then
            [F:CORL]HOMADD(0) = [M:LDS3]ADD1
        Endif
        If dim([M:LDS3]ADD1) > 0 Then
          [F:CORL]HOMADD(1) = [M:LDS3]ADD2
        Endif
        If dim([M:LDS3]ADD1) > 0 Then
          [F:CORL]HOMADD(2) = [M:LDS3]ADD3
        Endif
        [F:CORL]HOMZIP = [M:LDS3]ZIP
        [F:CORL]HOMCTY = [M:LDS3]CTY
        If dim([M:LDS3]SAT) > 0 Then
          [F:CORL]HOMSAT = [M:LDS3]SAT
        Endif
        [F:CORL]HOMTEL = [M:LDS3]CNTETS
        [F:CORL]HOMFAX = [M:LDS3]CNTFAX
        [F:CORL]HOMMOB = [M:LDS3]CNTMOB
        [F:CORL]HOMEML = [M:LDS3]CNTEMA
        IBWRITE = 1
      Endif
      Gosub TEST_LDS_F_CORW_F_LDS
      If IBMODIF = 1 Then
        [F:CORL]BPRLIB = [M:LDS2]CPYNAM
        [F:CORL]FNC = [M:LDS2]FNC
        [F:CORL]FNCLIB = [M:LDS2]FNCLIB
        [F:CORL]MSS = [M:LDS2]MSS
        [F:CORL]SRV = [M:LDS2]SRV
        #
        WI = func GET_IND_ADD_PRINC()
        [F:CORL]CPYBPADES = [M:BPAL]BPADES(WI-1)
        If dim([F:CORL]CPYADD(0)) > 1 Then
          [F:CORL]CPYADD(0) = [M:BPAL]ADDLIG1(WI-1)
        Endif
        If dim([F:CORL]CPYADD(1)) > 1 Then
          [F:CORL]CPYADD(1) = [M:BPAL]ADDLIG2(WI-1)
        Endif
        If dim([F:CORL]CPYADD(2)) > 1 Then
          [F:CORL]CPYADD(2) = [M:BPAL]ADDLIG3(WI-1)
        Endif
        [F:CORL]CPYZIP = [M:BPAL]POSCOD(WI-1)
        [F:CORL]CPYCTY = [M:BPAL]CTY(WI-1)
        If dim([F:CORL]SAT) > 1 Then
          [F:CORL]CPYSAT = [M:BPAL]SAT(WI-1)
        Endif
        [F:CORL]CPYCRY = [M:BPAL]BPACRY(WI-1)
        [F:CORL]CPYCRYNAM = [M:BPAL]CRYNAM(WI-1)
        [F:CORL]CPYEML = [M:BPAL]WEB1(WI-1)  # FGR 20/07/2010 : X3SUIVI66067 : plus WEB
        [F:CORL]CPYTEL = [M:BPAL]TEL1(WI-1)  # FGR 20/07/2010 : X3SUIVI66067 : plus TEL
        [F:CORL]CPYFAX = [M:BPAL]TEL2(WI-1)  # FGR 20/07/2010 : X3SUIVI66067 : plus FAX
        [F:CORL]CPYMOB = [M:BPAL]TEL5(WI-1)  # FGR 20/07/2010 : X3SUIVI66067 : plus MOB
        #
        IBWRITE = 1
      Endif
      If IBWRITE = 1 Then
        [F:CORL]UPDUSR = GUSER
        [F:CORL]UPDDAT = date$
        Rewrite [CORL]
        If fstat <> 0 Then
          IBERROR = 1
          #Erreur lors de la modification du correspondant+ " : + [F:CORL]CORNUM
          GMESSAGE = mess(285,177,1) - ":" - [F:CORL]CORNUM
          GOK = 0
        Endif
        If IBERROR = 0 Then
          Gosub GERE_COP From SUBCORB
        Endif    
        If IBERROR = 1 Then
          Break
        Endif
      Endif
    Next
  Endif
  If IBERROR = 1 Then
    GOK = 0
    Return
  Endif

  #On test si il y a des modifications sur la partie LEAD
Local Integer ILIGNE
Local Integer ILIGNEOLD
Local Integer IBTROUVE

  ILIGNE = 0
  ILIGNEOLD = 0
  IBTROUVE = 0
  If IBERROR = 1 Then
    GOK = 0
  Endif
Return

##########################################################################################################
$TEST_AIN_AIN_SAVE
  IBMODIF = 0
  #On test les différentes zones
  If [M:LDS0]CNTTTL <> [M:PS0S]CNTTTL Then
    IBMODIF = 1
  Endif
  If [M:LDS0]CNTLNA <> [M:PS0S]CNTLNA Then
    IBMODIF = 1
  Endif
  If [M:LDS0]CNTFNA <> [M:PS0S]CNTFNA Then
    IBMODIF = 1
  Endif
