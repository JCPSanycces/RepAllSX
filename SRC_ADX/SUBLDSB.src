##########################################################################################################
$TEST_LDS_F_CORW_F_LDS
Local Integer WI # FGR 25/07/2008 : X3SUIVI48267

  IBMODIF = 0
  #On test les différentes zones
  If [F:CORL]BPRLIB <> [M:LDS2]CPYNAM Then
    IBMODIF = 1
  Endif
  If [F:CORL]FNC <> [M:LDS2]FNC Then
    IBMODIF = 1
  Endif
  If [F:CORL]FNCLIB <> [M:LDS2]FNCLIB Then
    IBMODIF = 1
  Endif
  If [F:CORL]MSS <> [M:LDS2]MSS Then
    IBMODIF = 1
  Endif
  If [F:CORL]SRV <> [M:LDS2]SRV Then
    IBMODIF = 1
  Endif
  #
  # FGR 25/07/2008 : X3SUIVI48267
  WI = func GET_IND_ADD_PRINC()
  If WI <> 0 Then
    If [F:CORL]CPYBPANUM <> [M:BPAL]CODADR(WI-1) Then
      IBMODIF = 1
    Endif
    If [F:CORL]CPYBPADES <> [M:BPAL]BPADES(WI-1) Then
      IBMODIF = 1
    Endif
    If dim([F:CORL]CPYADD(0)) > 1 Then
      If [F:CORL]CPYADD(0) <> [M:BPAL]ADDLIG1(WI-1) Then
        IBMODIF = 1
      Endif
    Endif
    If dim([F:CORL]CPYADD(1)) > 1 Then
      If [F:CORL]CPYADD(1) <> [M:BPAL]ADDLIG2(WI-1) Then
        IBMODIF = 1
      Endif
    Endif
    If dim([F:CORL]CPYADD(2)) > 1 Then
      If [F:CORL]CPYADD(2) <> [M:BPAL]ADDLIG3(WI-1) Then
        IBMODIF = 1
      Endif
    Endif
    If [F:CORL]CPYZIP <> [M:BPAL]POSCOD(WI-1) Then
      IBMODIF = 1
    Endif
    If [F:CORL]CPYCTY <> [M:BPAL]CTY(WI-1) Then
      IBMODIF = 1
    Endif
    If dim([F:CORL]SAT) > 1 Then
      If [F:CORL]CPYSAT <> [M:BPAL]SAT(WI-1) Then
        IBMODIF = 1
      Endif
    Endif
    If [F:CORL]CPYCRY <> [M:BPAL]BPACRY(WI-1) Then
      IBMODIF = 1
    Endif
    If [F:CORL]CPYCRYNAM <> [M:BPAL]CRYNAM(WI-1) Then
      IBMODIF = 1
    Endif
    If [F:CORL]CPYEML <> [M:BPAL]WEB1(WI-1) Then  # FGR 20/07/2010 : X3SUIVI66067 : plus WEB
      IBMODIF = 1
    Endif
    If [F:CORL]CPYTEL <> [M:BPAL]TEL1(WI-1) Then  # FGR 20/07/2010 : X3SUIVI66067 : plus TEL
      IBMODIF = 1
    Endif
    If [F:CORL]CPYFAX <> [M:BPAL]TEL2(WI-1) Then  # FGR 20/07/2010 : X3SUIVI66067 : plus FAX
      IBMODIF = 1
    Endif
    If [F:CORL]CPYMOB <> [M:BPAL]TEL5(WI-1) Then  # FGR 20/07/2010 : X3SUIVI66067 : plus MOB
      IBMODIF = 1
    Endif
  Endif
Return

##########################################################################################################
UPDCORORIGINE
  If !clalev([F:CORL]) : Local File CORRESPOND [CORL] : Endif
  Read [CORL] COR0=[M:COR0]CORNUM
  If fstat <> 0 Then
    #Erreur lors de la lecture du correspondant+" : "+[M:COR0]CORNUM
    GMESSAGE = mess(271,177,1) - ":" - [M:COR0]CORNUM          
    GERR = 2
    GOK = 0
  Else
    [F:CORL]CNTNUM = [F:AIN]CNTNUM
    [F:CORL]UPDCNTNUM = 0
    Rewrite [CORL]
    If fstat <> 0 Then
      #Erreur lors de la modification du correspondant+ " : + [F:CORL]CORNUM
      GMESSAGE = mess(285,177,1) - ":" - [F:CORL]CORNUM
      GOK = 0
      GERR = 2
    Endif
  Endif  
Return

##########################################################################################################
# initialisation création LEAD  à partir d'un correspondant
$CRELDSFROMCOR
  [M:LDS0]CNTTTL = [M:COR0]TTL
  [M:LDS0]CNTLNA = [M:COR0]LNA
  [M:LDS0]CNTFNA = [M:COR0]FNA

  [M:LDS3]CNTLAN = [M:COR3]LAN
  [M:LDS3]CNTBIR = [M:COR3]BIR
  [M:LDS3]CNTCSP = [M:COR3]CSP

  [M:LDS3]CRY = [M:COR3]HOMCRY
  [M:LDS3]CRYNAM = [M:COR3]HOMCRYNAM
  [M:LDS3]CNTETS = [M:COR3]HOMTEL
  [M:LDS3]CNTFAX = [M:COR3]HOMFAX
  [M:LDS3]CNTMOB = [M:COR3]HOMMOB
  [M:LDS3]CNTEMA = [M:COR3]HOMEML

  If dim([M:LDS3]ADD1) > 0 Then
    [M:LDS3]ADD1 = [M:COR3]HOMADD(0)
  Endif
  If dim([M:LDS3]ADD2) > 0 Then
    [M:LDS3]ADD2 = [M:COR3]HOMADD(1)
  Endif
  If dim([M:LDS3]ADD3) > 0 Then
    [M:LDS3]ADD3 = [M:COR3]HOMADD(2)
  Endif
  [M:LDS3]ZIP = [M:COR3]HOMZIP
  [M:LDS3]CTY = [M:COR3]HOMCTY
  If dim([M:LDS3]SAT) > 0 and dim([M:COR3]HOMSAT) > 0 Then
    [M:LDS3]SAT = [M:COR3]HOMSAT
  Endif

  [M:LDS2]CPYNAM = [M:COR2]BPRLIB
  [M:LDS2]FNC = [M:COR2]FNC
  [M:LDS2]FNCLIB = [M:COR2]FNCLIB
  [M:LDS2]MSS = [M:COR2]MSS
  [M:LDS2]SRV = [M:COR2]SRV
  [M:LDS2]CPYCRY = [M:COR2]CPYCRY
  # FGR 10/03/2009 : X3SUIVI53094 (DEBUT)
  [M:BPAL]NBADR = 0
  If [M:COR2]CPYBPANUM = "" Then
    [M:BPAL]CODADR([M:BPAL]NBADR) = "001"
  Else
    [M:BPAL]CODADR([M:BPAL]NBADR) = [M:COR2]CPYBPANUM
  Endif
  [M:BPAL]BPADES([M:BPAL]NBADR) = [M:COR2]CPYBPADES
  [M:BPAL]BPACRY([M:BPAL]NBADR) = [M:COR2]CPYCRY
  [M:BPAL]CRYNAM([M:BPAL]NBADR) = [M:COR2]CPYCRYNAM
  [M:BPAL]ADDLIG1([M:BPAL]NBADR) = [M:COR2]CPYADD(0)
  [M:BPAL]ADDLIG2([M:BPAL]NBADR) = [M:COR2]CPYADD(1)
  [M:BPAL]ADDLIG3([M:BPAL]NBADR) = [M:COR2]CPYADD(2)
  If dim([M:BPAL]SAT) > 0 Then
    [M:BPAL]SAT([M:BPAL]NBADR) = [M:COR2]CPYSAT
  Endif
  [M:BPAL]POSCOD([M:BPAL]NBADR) = [M:COR2]CPYZIP
  [M:BPAL]CTY([M:BPAL]NBADR) = [M:COR2]CPYCTY
  [M:BPAL]TEL1([M:BPAL]NBADR) = [M:COR2]CPYTEL  # FGR 20/07/2010 : X3SUIVI66067 : plus TEL
  [M:BPAL]TEL2([M:BPAL]NBADR) = [M:COR2]CPYFAX  # FGR 20/07/2010 : X3SUIVI66067 : plus FAX
  [M:BPAL]TEL5([M:BPAL]NBADR) = [M:COR2]CPYMOB  # FGR 20/07/2010 : X3SUIVI66067 : plus MOB
  [M:BPAL]WEB1([M:BPAL]NBADR) = [M:COR2]CPYEML  # FGR 20/07/2010 : X3SUIVI66067 : plus WEB
  [M:BPAL]BPAADDFLG([M:BPAL]NBADR) = 2
  [M:BPAL]NBADR += 1
  # FGR 10/03/2009 : X3SUIVI53094 (FIN)
  Affzo [M:LDS0]1-99
  Affzo [M:LDS2]1-99
  nolign = 1
  Affzo [M:BPAL]1-99  # FGR 10/03/2009 : X3SUIVI53094
  Affzo [M:LDS3]1-99
Return

