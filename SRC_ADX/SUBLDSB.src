##########################################################################################################
$TRANSAINLDS
  Readlock [LDS]LDS0=[M:LDS0]PSTNUM
  If fstat <> 0 Then
    #Erreur : impossible de locker la LEAD
    GMESSAGE = mess(466,177,1)
    GERR = 2
    GOK = 0
    Return
  Endif
  [F:LDS]PSTTYP = 1
  Rewrite [LDS]
  If fstat <> 0 Then
    #Erreur lors de la modification de la LEAD
    GMESSAGE = mess(467,177,1)
    GERR = 2
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
Subprog LIELDSTOBPR (SZPSTNUM, SZBPRNUM, SZADRNUM, SZMESSAGE, IBRETOUR)
Value Char SZPSTNUM
Value Char SZBPRNUM 
Value Char SZADRNUM
Variable Char  SZMESSAGE
Variable Integer IBRETOUR

  If !clalev([F:LDS]) : Local File LEAD [LDS] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  IBRETOUR = 1
  If SZPSTNUM = "" Then
    #La référence LEAD est obligatoire
    SZMESSAGE = mess(472,177,1)
    IBRETOUR = 0
    GOK = 0
  Endif
  If SZPSTNUM = "" Then
    #La référence tiers est obligatoire
    SZMESSAGE = mess(473,177,1)
    IBRETOUR = 0
    GOK = 0
  Endif
  If IBRETOUR = 0 Then
    End
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [LDS]
  Readlock [LDS]LDS0=SZPSTNUM
  If fstat <> 0 Then
    #Erreur : impossible de locker la LEAD + " : "+SZPSTNUM
    SZMESSAGE = mess(466,177,1) - ":" - SZPSTNUM
    IBRETOUR = 0
    GOK = 0
  Endif
  Readlock [AIN]AIN0=SZPSTNUM
  If fstat <> 0 Then
    #Erreur : impossible de locker l'interlocuteur + " : "+SZPSTNUM
    SZMESSAGE = mess(421,177,1) - ":" - SZPSTNUM
    IBRETOUR = 0
    GOK = 0
  Endif
  If IBRETOUR = 0 Then
    Rollback
    End
  Endif
End

##########################################################################################################
$VERIFRETOUR
Local Integer IBCHANGE

  If !clalev([F:LDSL]) : Local File LEAD [LDSL] : Endif
  IBCHANGE = 0
  Read [LDSL]LDS0=[M:LDS0]PSTNUM
  If fstat = 0 Then
    If [F:LDSL]PSTTYP = 1 Then
      IBCHANGE = 1
    Endif
  Endif
  If IBCHANGE = 1 Then
    #Indique que plus clé courant pour raz écran
    CLECUR = 0
  Endif
Return

##########################################################################################################
Funprog GET_IND_ADD_PRINC()
Local Integer INDADDPRINC

  # FGR 25/07/2008 : X3SUIVI48267
  If dim([M:BPAL]NBADR) > 0 Then
    INDADDPRINC = find (2, [M:BPAL]BPAADDFLG (0..[M:BPAL]NBADR-1)) # Indice de l'adresse principale
  Else
    INDADDPRINC = 0
  Endif
End INDADDPRINC 
