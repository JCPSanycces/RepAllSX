# Superviseur
# Gestion du masque HRMAT9 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBREXM
mkstat = 0
zoncou = "NBREXM"
indice = 0
status = 1
zoncou = "NBREXM"
If varmode([M]NBREXM,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBREXM From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBREXM : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBREXM" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBREXM
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBREXM = nolign
   status = 75
   Call SAI_NBREXM(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_NBREXM From SUBEML2
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NBREXM" : GZNUM = 0 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

