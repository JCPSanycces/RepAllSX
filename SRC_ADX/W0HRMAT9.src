####################################
## Bloc tableau 1
####################################
Subprog SAI_NBREXM(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBREXM
mkstat = 0
zoncou = "NBREXM"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBREXM From SUBEML2
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBREXM" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone DOMEXM
mkstat = 0
zoncou = "DOMEXM"
If varinit([M]DOMEXM,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]DOMEXM(indice),"10381","") From SUBADI
 GACTION = SAVACT
Endif

## Zone LEVEXM
mkstat = 0
zoncou = "LEVEXM"
If varinit([M]LEVEXM,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEVEXM(indice),"10382","") From SUBADI
 GACTION = SAVACT
Endif

## Zone ORGEXM
mkstat = 0
zoncou = "ORGEXM"
If varinit([M]ORGEXM,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]ORGEXM(indice),"10383","") From SUBADI
 GACTION = SAVACT
Endif

## Zone NBREXM
mkstat = 0
zoncou = "NBREXM"

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_NBRTRY(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRTRY
mkstat = 0
zoncou = "NBRTRY"
SAVACT = GACTION : GACTION = "STD"
Call C_NBRTRY From SUBEML2
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "NBRTRY" : GZNUM = 0 : Endif
Gosub AFF From GSAISIE
If mkstat : End : Endif

## Zone STATRY
mkstat = 0
zoncou = "STATRY"
If varinit([M]STATRY,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]STATRY(indice),"10380","") From SUBADI
 GACTION = SAVACT
Endif

## Zone NBRTRY
mkstat = 0
zoncou = "NBRTRY"

End

