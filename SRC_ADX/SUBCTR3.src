Raz GPILOBJ,GNBMASKOUV
Raz GBIDC1, GBIDC2
Call OBJET("CTR",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
# Modifications :
#     #Selection salarié dans fonction contrat si GREP<>"C"
#                                  Selection contrat par salarié
#                                  Test entrée au contrôle du motif CTRGRD
#                                  Repositionnement sur ACCCOD si code comptable est vide
#                                  ET SI LA Case INFOS COMPTABLES AU CONTRAT EST COCHÉE
#     #Synchronisation des populations
#     #Initialisation de TIP.CTRDAT selon règle métier
#     #[F:ID]REFNUM lost after tunnel on JOB Type , standard job
#     FQ92876-US2582 - Accounting Interface
#     SEGAY - 09/04/14 - FQ96877 FQ96876 : Update populations of inactive contract (old)
######################################################################################

########################################################
$ACTION

If dim([L]CSUBB)<=0
 Local Integer CSUBB
 Call EXISTE_ADX("","","SUBCTR2",CSUBB) From ORDSYS
Endif

Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "OUVRE_BOITE": Gosub OUVRE_BOITE
 When "LIENS"      : Gosub LIENS
 When "STYLE"      : Gosub STYLE
 When "GRISE"      : Gosub GRISE From SUBCTR2
 When "VERIF_CRE"  : Gosub VERIF_CRE
 When "VERIF_MOD"  : Gosub VERIF_MOD
 When "INICRE"     : Gosub INICRE
 When "INIMOD"     : Gosub INIMOD
 When "RAZCRE"     : Gosub RAZCRE
 When "RAZDUP"     : Gosub RAZDUP
 When "CREATION"   : Gosub CREATION
 When "APRES_CRE"  : Gosub APRES_CRE
 When "APRES_MOD"  : Gosub APRES_MOD
 When "AP_ANNULE"  : Gosub AP_ANNULE
 When "MODIF"      : Gosub MODIF
 When "ANNULE"     : Gosub ANNULE
 When "AV_VERF_ANU": Gosub AV_VERF_ANU
 When "SETBOUT"    : Gosub SETBOUT
 When "FILTRE"     : Gosub FILTRE
 When "FILGAUCHE"  : Gosub FILGAUCHE
 When "FIN"        : Gosub FIN
 When "AVANT_CHOI" : Read [ID]ID0=[F:CTR]REFNUM : # Recharger [ID] apres Fillbox de REMPLIT
 When "AVANTBOUT"  : Gosub AVANTBOUT
 When "STATUT"     : Gosub STATUT
 When "FERME"      : Gosub FERME
 When Default
Endcase

If CSUBB
 Gosub ACTION From SUBCTR2
Endif

#BRBAN - 2014/04/16 - Fields for KPO
# Issue 110164 - 2016-01-15 by BRBAN
If func AFNC.ACTIV("KPOAO")>0 & func DIVPAYE.EXISTE_KXX("SUBCTRKPO") Then
    Gosub ACTION From SUBCTRKPO
Endif

If func AFNC.ACTIV("KFR") & func DIVPAYE.EXISTE_KXX("SUBCTRKFR") Then
    Gosub ACTION From SUBCTRKFR
Endif

Return

########################################################
$OUVRE
Local Integer I, STAT, VOK
Local Char    COMPTEUR(GLONANM), CRITCTRL (250), ZONE(10)
Gosub OUVRE From DEFTABLE
Gosub OUVRE From SUBCTR2

Local Char    L_POPUL(GLONPOP)(0..)
Local Integer L_NB_POPUL

Global Integer GRETTIP
Global Integer GLASTCTR

Local Date WXITDAT
#US 4029_112391
Local Char DISP_EVA(2)
Local Integer IS_FNCA
IS_FNCA=func AFNC.ACTIV("NCA")

Return

$OUVRE_BOITE
# It's better to test activity code K** (More over the good test would be on GDOSLEG(1)) !
#JASMI - 2016-02-15 - Issue 114547 - START
## It's better to test activity code K** (More over the good test would be on GDOSLEG(1)) !
##If GDOSLEG="POR"
#If func AFNC.ACTIV("KPO")>0
#    Chgfmt [M:CTR1]MODTPS   With "-LA:15"   : Raz [M:CTR1]MODTPS
#    Chgtbk [M:CTR2]35       With ""
#    Chgfmt [M:CTR2]CATFRT   With "-K:20X"   : Raz [M:CTR2]CATFRT
#    Chgfmt [M:CTR2]ZCATFRT  With "-KP:20X"  : Raz [M:CTR2]ZCATFRT
#    Chgfmt [M:CTR5]INSAMT   With "-Nz:12"   : Raz [M:CTR5]INSAMT
#    Chgfmt [M:CTR5]INSDAY   With "-Nz:2"    : Raz [M:CTR5]INSDAY
#    Chgtbk [M:CTR5]10       With ""
#Endif
#
##FRLAA - 2015-08-04 - Requirement 109427 - US 3711 ## Comment
###JASMI - 2014-09-08 - START
###Hide fields for SA
##If func AFNC.ACTIV("KZA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
##  If func DIVPAYE.EXISTE_KXX("SUBCTRKSA") Then
##    Gosub OUVRE_BOITE From SUBCTRKSA
##  Endif
##Endif
###JASMI - 2014-09-08 - END
##FRLAA - 2015-08-04 - Requirement 109427 - US 3711 ## Comment
Gosub OUVRE_BOITE From SUBCTR2
#JASMI - 2016-02-15 - Issue 114547 - END
Return

########################################################
$LIENS

Call LECTURE("FCY",[M:CTR0]ETRFCY,"") From CONTOBJ
GSOCIETE=[F:FCY]LEGCPY : [M:CTR0]CPY=GSOCIETE
If [M]RPL(dim([M]RPL)-1)<>""
 [M]NBRRPL = dim([M]RPL)
Else
 [M]NBRRPL = find("",[M]RPL) - 1
Endif

Look [ELC]ELC0=[F:CTR]REFNUM;[F:CTR]ETRFCY
[M]MAIFCY=1+!fstat

If [F:CTR]REFNUM<>[F:ID]REFNUM
 Read [ID]ID0=[F:CTR]REFNUM
 If fstat : Return : Endif
Endif
[M]SRN = [F:ID]NAM-[F:ID]SRN

Gosub GRISE From SUBCTR2
Gosub CHARGE_CTR3
Gosub CHARGE_EPC_SAL
Gosub CHARGE_EVT
Gosub CHARGE_CPR
Gosub CHARGE_BULDEM

#Done once is enough
Call CHARGE_POPUL([F:CTR]REFNUM,L_POPUL,L_NB_POPUL) From SUBCTR2

If GPAYE
 Gosub LOAD_RETROCTR From SUBCTRRET
Endif

If [M:CTR0]FLGVAR=2
 Diszo [M:CTR1]SUICAR
Else
 Actzo [M:CTR1]SUICAR
Endif
GRETTIP=0
GLASTCTR = 1

Filter [CTR1] Where REFNUM=[F:CTR]REFNUM & CTRNUM=[F:CTR]CTRNUM
Read [CTR1]CTR0 Last
Filter [CTR1]
If fstat<=2 & [F:CTR1]CTRDAT<>[F:CTR]CTRDAT
 GLASTCTR = 0
Endif

Gosub STYLE

Return

########################################################
$STYLE

  If func AFNC.ACTIV("KZA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
    If func DIVPAYE.EXISTE_KXX("SUBCTRKSA") Then
      Gosub STYLE  From SUBCTRKSA
    Endif
  Endif
Return

########################################################
$CHARGE_CTR3
# Appelé aussi par SUBENT
If GINTMT=1
 If [F:ID]FLGINT<>2
  Effzo [CTR3]
  [M:CTR3]STACTR = [F:CTR]STACTR
  Grizo [CTR3]
 Else
  Actzo [CTR3]
  nolign = 1
  ## Add filter on CTRDAT
  For [PSN]PSN0 Where CTRNUM=[F:CTR]CTRNUM & CTRDAT=[F:CTR]CTRDAT
   [M:CTR3] = [F:PSN]
   If [F:PSN]BUL<>""
    Read [VEP]VEP5=[F:PSN]BUL
    If !fstat
     [M:CTR3]PYRDAT(nolign-1) = [F:VEP]PYRDAT
    Endif
   Endif
   nolign +=1
  Next
  [M:CTR3]NBRPSN = nolign-1
  Sorta [M]NBRPSN [M]NBRPSN Order By PSNSTRDAT([S]indice)
 Endif
 Affzo [CTR3]
Endif
Return

