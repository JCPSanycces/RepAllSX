End

Subprog AV_PLNDES(VALEUR)
Variable Char    VALEUR()
Call LIB_PLANNING([M]PLNTYP)
VALEUR = [M]PLNDES
End

Subprog LIB_PLANNING(VALEUR)
Value Char VALEUR
Local Integer ANNEE
If VALEUR<>""
 ANNEE=year(GMOIPAY)
 # Contrat actif sur le mois de paye
 If [F:CTR]FLGRET<>2 & year([F:CTR]CTRDAT)>year(GMOIPAY)
  ANNEE=year([F:CTR]CTRDAT)
 Elsif [F:CTR]FLGRET=2 & year([F:CTR]RETDATEFF)>year(GMOIPAY)
  ANNEE=year([F:CTR]RETDATEFF)
 Elsif [F:CTR]XITDAT<>[0/0/0] & year([F:CTR]XITDAT)<year(GMOIPAY)
  ANNEE=year([F:CTR]XITDAT)
 Endif
 Filter [PLN] Where COD=VALEUR & YEA=ANNEE
 Read [PLN]PLN1 Last
 Filter [PLN]
 If !fstat
  [M]PLNDES = [F:PLN]DES
 Else
  GMESSAGE=VALEUR-":"-mess(84,701,1)-num$(ANNEE)
  mkstat=2 : End
 Endif
Else
  [M]PLNDES=""
Endif
End

