 If MA
  If [M]TYPJOB=1 & [M]DNACODTIM<>5
   # Le type d'emploi doit être différent de "Temps plein"
   GMESSAGE=func AFNC.MES1(mess(59,701,1),mess([M]TYPJOB,312,1))
   mkstat=2 : End
