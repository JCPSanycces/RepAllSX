######################################################################################


Funprog ISKSA()
Local Integer RES
RES=func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
End RES

Funprog ISKAQ()
Local Integer RES
RES=func AFNC.ACTIV("KAQ")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
End RES

Funprog ISKZAKAQ
Local Integer RES
RES=(func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) & (func AFNC.ACTIV("KZA")>0 or func AFNC.ACTIV("KAQ")>0)
End RES

Funprog ISKPO()
Local Integer RES
 RES=func AFNC.ACTIV("KPO")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KSA")=0)
End RES

Funprog ISKMIEA()
Local Integer RES
RES=func AFNC.ACTIV("KMIEA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
End RES

Funprog ISKZA()
Local Integer RES
RES=func AFNC.ACTIV("KZA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
End RES

#######################################################################################
Subprog AM_WRKCRN(VALEUR)
Variable Char    VALEUR()
Local Char ZONE(10) : ZONE = "WRKNATLEG"
Gosub SET_ZONE From SUBCTR
If MA
 [M]WRKCRN=VALEUR
 Gosub INI_WRKNATLEG From SUBCTR2
Endif
End

Subprog AM_WRKFLGADD(VALEUR)
Variable Integer  VALEUR()
Local Char ZONE(10) : ZONE = "WRKNATLEG"
Gosub SET_ZONE From SUBCTR
If MA
 [M]WRKFLGADD=VALEUR
 Gosub INI_WRKNATLEG From SUBCTR2
Endif
End

