If fstat | (val([F:ADI]A1)=98 & [M]DNACCP<>3) | (val([F:ADI]A1)<>98 & [M]DNACCP=3)
 GMESSAGE=mess(1,702,1)
 mkstat=2 : End
Endif
End

Subprog D_PRUACV(VALEUR)
Variable Integer VALEUR
Gosub LIRE_SITE
Case [F:SIT]REGPRH
 When 1       : VALEUR=3
 When 2       : VALEUR=1
 When 3       : VALEUR=2
 When 4       : VALEUR=4
 When Default : VALEUR=1
Endcase
End

