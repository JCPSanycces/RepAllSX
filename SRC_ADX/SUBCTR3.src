#################################
Subprog AS_STRPAY(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] : End : Endif
If !clalev([F:VEPW]): Local File VALEMP      [VEPW] : Endif
Filter [VEPW] Where EMP=[F:CTR]REFNUM & CTRNUM=[F:CTR]CTRNUM & CTRDAT=[M:CTRA]STRDAT(nolign-1)
&                   & STRDAT>=[M:CTRA]RETDATEFF & STA>1 & RVS<>2 & RVSDAT=[0/0/0]
Read [VEPW]VEP5 First
Filter [VEPW]
If !fstat
 VALEUR=[F:VEPW]PYRDAT
 [M:CTRA]STRBUL(nolign-1)=[F:VEPW]BUL
Endif
End

#################################
Subprog C_STRPAY(VALEUR)
Variable Date    VALEUR
Call SELBUL([M:CTR0]REFNUM,VALEUR,[M:CTR0]CTRNUM,[M:CTRA]STRDAT(nolign-1),[M:CTRA]STRBUL(nolign-1)) From DIVPAYE
If [M:CTRA]STRBUL(nolign-1) = ""
 GMESSAGE = mess(23,100,1) : # Fiche inexistante
 mkstat = 2 : End
Else
 If !clalev([F:VEPW]): Local File VALEMP      [VEPW] : Endif
 Read [VEPW]VEP5=[M:CTRA]STRBUL(nolign-1)
 If fstat | [VEPW]STRDAT<[M:CTRA]RETDATEFF | [VEPW]STA<=1 | [VEPW]RVS=2 | [VEPW]RVSDAT<>[0/0/0]
  GMESSAGE = mess(83,123,1)   : # Valeur incorrecte
  mkstat = 2 : End
 Endif
Endif
End

#################################
Subprog AS_ENDPAY(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] : End : Endif
If !clalev([F:VEPW]): Local File VALEMP      [VEPW] : Endif
Filter [VEPW] Where EMP=[F:CTR]REFNUM & CTRNUM=[F:CTR]CTRNUM & CTRDAT=[M:CTRA]STRDAT(nolign-1)
&                   & STRDAT>=[F:CTR]RETDATEFF & STA>1 & RVS<>2 & RVSDAT=[0/0/0]
Read [VEPW]VEP5 Last
Filter [VEPW]
If !fstat
 VALEUR=[F:VEPW]PYRDAT
 [M:CTRA]ENDBUL(nolign-1)=[F:VEPW]BUL
Endif
End

#################################
Subprog C_ENDPAY(VALEUR)
Variable Date    VALEUR
Call SELBUL([M:CTR0]REFNUM,VALEUR,[M:CTR0]CTRNUM,[M:CTRA]STRDAT(nolign-1),[M:CTRA]ENDBUL(nolign-1)) From DIVPAYE
If [M:CTRA]ENDBUL(nolign-1) = ""
 GMESSAGE = mess(23,100,1) : # Fiche inexistante
 mkstat = 2 : End
Else
 If !clalev([F:VEPW]): Local File VALEMP      [VEPW] : Endif
 Read [VEPW]VEP5=[M:CTRA]ENDBUL(nolign-1)
 If fstat | [VEPW]STRDAT<[M:CTRA]RETDATEFF | [VEPW]STA<=1 | [VEPW]RVS=2 | [VEPW]RVSDAT<>[0/0/0]
  GMESSAGE = mess(83,123,1)    : # Valeur incorrecte
  mkstat = 2 : End
 Endif
Endif
[M:CTRA]LIGUNI(nolign-1)=format$(GFMD,[M:CTRA]STRDAT(nolign-1))+'|'+ [M:CTRA]FLD(nolign-1)+'|'+ [M:CTRA]STRBUL(nolign-1) +'|'+ [M:CTRA]ENDBUL(nolign-1)
Call UNICITE([M:CTRA]LIGUNI(nolign-1),[M:CTRA]LIGUNI(0..[M:CTRA]NBRRCR-1)) From OBJDIV
If mkstat=2 : End : Endif
End

##**92316 US2225
#################################
Subprog C_RETDATEFF(VALEUR)
Variable Date    VALEUR
If [L]VALEUR >= [M:CTR0]CTRDAT
 # mess(101,701,1) : La date de prise d'effet est incohérente par rapport à la date de contrat
 [V]GMESSAGE = mess(101, 701, 1)
 mkstat = 2 : End
Endif
If GINTMT
 If [F:ID]FLGINT=2
  If clalev([F:PSNW])=0 : Local File PRESTATION [PSNW] : Endif
  Filter[PSNW] Where CTRNUM=[M:CTR0]CTRNUM & CTRDAT=[M:CTR0]CTRDAT & PSNSTRDAT=VALEUR
  Look [PSNW]PSN0 First
  Filter[PSNW]
  If fstat
   #Aucune prestation débutant à cette date
   [V]GMESSAGE = mess(175,701,1)
   mkstat = 2 : End
  Endif
  Close File [PSNW]
 Endif
Endif
End

#################################
Subprog C_NBRRCR
# Pas de modif manuelle dans le tableau pour les intermittents...
If GINTMT & [F:ID]FLGINT=2  & !adxgtb
 mkstat=2 : End
Endif
End

