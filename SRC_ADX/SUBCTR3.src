Subprog C_CHEFCTR(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
If clalev([F:ID5])=0 : Local File EMPLOID [ID5] : Endif
Read [ID5]ID0=VALEUR
If fstat
 # Matricule inexistant
 GMESSAGE = mess(83,702,1)
 mkstat = 2 : End
Elsif [F:ID5]FLGNEWSAL=2 | [F:ID5]ENAFLG<>2
 # Salarié inactif
 GMESSAGE = mess(33,702,1)
 mkstat = 2 : End
Endif
End

Subprog AV_NAMCHEF(VALEUR)
Variable Char    VALEUR()
If clalev([F:ID5])=0 : Local File EMPLOID [ID5] : Endif
If [M]CHEFCTR(nolign-1)<>""
 Read [ID5]ID0=[M]CHEFCTR(nolign-1)
 If !fstat
  VALEUR = [F:ID5]NAM-[F:ID5]SRN
 Endif
Else
 VALEUR=""
Endif
End

############################################################################################################
##                                      SOUS-PROGRAMMES
############################################################################################################
$SET_ZONE
Local Integer MA , I
Local Char    AB(1)
MA=0
For I=1 To 12
 AB = mid$("0123456789AB",I,1)
 If evalue("dim([M:CTR"+AB+"]"+ZONE+")")>0
  MA = I
  Break
 Endif
Next I
Case MA
 When  1 : Default Mask [CTR0]
 When  2 : Default Mask [CTR1]
 When  3 : Default Mask [CTR2]
 When  4 : Default Mask [CTR3]
 When  5 : Default Mask [CTR4]
 When  6 : Default Mask [CTR5]
 When  7 : Default Mask [CTR6]
 When  8 : Default Mask [CTR7]
 When  9 : Default Mask [CTR8]
 When 10 : Default Mask [CTR9]
 When 11 : Default Mask [CTRA]
Endcase
Return

########################################################
$LIRE_SITE
Call LECTURE("FCY",[M]ETRFCY,"") From CONTOBJ
Read[SIT]SIT0=[M]ETRFCY
Return


################################################################################################################
#                                    LES $CONTROLE*
##################################################################################################################

#Controle statut cadre / statut catégoriel
#Controle Nature de contrat / Type d'emploi (Travail temporaire & intérimaire)
########################################################
$CONTROLE_STATUT
Local Integer JADI
Local Char CODA1 (10)
Read[F:ADI]CODE=354;[M:CTR0]NATCON
If !fstat
 CODA1=[F:ADI]A1
 If GDOSLEG="FRA" & ((val(CODA1)=3 & [M]TYPJOB>3) | (val(CODA1)<>3 & [M]TYPJOB=3))
  # Incohérence entre la zone "nature" de contrat et la zone "type" de l'emploi.
  GMESSAGE = mess(20,701,1)
  OK = 0 : Return
 Endif
Endif
Return

#Controle de non chevauchement des périodes de préavis
########################################################
$CONTROLE_PREAVIS

If [M]FLGPRV=2 & [M]FLGPRV2=2
 If ([M]STRTIMNTC>=[M]STRNTC2   & [M]STRTIMNTC<=[M]ENDNTC2)
& | ([M]STRNTC2  >=[M]STRTIMNTC & [M]ENDNTC2  <=[M]ENDTIMNTC)
  #Périodes de préavis : chevauchement impossible
  GMESSAGE =mess(57,701,1)
  OK=0 : Return
 Endif
Endif
If [M]FLGPRV=2 & [M]FLGPRV3=2
 If ([M]STRTIMNTC>=[M]STRNTC3   & [M]STRTIMNTC<=[M]ENDNTC3)
& | ([M]STRNTC3  >=[M]STRTIMNTC & [M]ENDNTC3  <=[M]ENDTIMNTC)
  #Périodes de préavis : chevauchement impossible
  GMESSAGE =mess(57,701,1)
  OK=0 : Return
 Endif
Endif
If [M]FLGPRV2=2 & [M]FLGPRV3=2
 If ([M]STRNTC2>=[M]STRNTC3 & [M]STRNTC2<=[M]ENDNTC3)
& | ([M]STRNTC3>=[M]STRNTC2 & [M]ENDNTC3<=[M]ENDNTC2)
  #Périodes de préavis : chevauchement impossible
  GMESSAGE =mess(57,701,1)
  OK=0 : Return
 Endif
Endif
Return

########################################################
$CONTROLE
CRITCTRL="CTRNUM='"+[M]CTRNUM+"'"
CRITCTRL-="& CTRDAT=["+num$([M]CTRDAT)+"]"
Call CONTROLE_PAYE([M]REFNUM, CRITCTRL)
If mkstat
 # Modification impossible : Paies présentes sur la période
 GMESSAGE = mess(12,701,1)
 mkstat = 2 : Return
Endif
Return

########################################################
$CONTROLE_TIP
CRITCTRL="REFNUM='"+[M]REFNUM+"' & CTRNUM='"+[M]CTRNUM+"'"
If [M]CTRDAT<>[0/0/0]
 CRITCTRL-="& (CTRDAT=[0/0/0] | CTRDAT=["+num$([M]CTRDAT)+"])"
 CRITCTRL-="& ([M]FLGRET=2 & DATPYR>=["+num$([M]RETDATEFF)+"] | DATPYR>=["+num$([M]CTRDAT)+"])"
Endif
If [M]XITDAT<>[0/0/0]
 CRITCTRL-="& ENDDAT<=["+num$([M]XITDAT)+"]"
Endif
Filter [TIP] Where evalue(CRITCTRL)
Read [TIP]TIP2 First
Filter [TIP]
If !fstat
 # Modification impossible : Temps saisis sur la période
 GMESSAGE = mess(13,701,1)
 mkstat = 2 : Return
Endif
Return

# CONTROL TIP For ANNULE contract or CREATE new contract
########################################################
$CONTROLE_TIP3
Local Integer W_OK
Local Char WMESSAGE(250)
CRITCTRL="REFNUM='"+[M]REFNUM+"'"
CRITCTRL += "& CTRNUM='"+[M]CTRNUM+"'"
If [M]CTRDAT<>[0/0/0]
 CRITCTRL-="& (CTRDAT=[0/0/0] | CTRDAT=["+num$([M]CTRDAT)+"])"
 CRITCTRL-="& ([M]FLGRET=2 & DATPYR>=["+num$([M]RETDATEFF)+"] | DATPYR>=["+num$([M]CTRDAT)+"])"
Endif
If [M]XITDAT<>[0/0/0]
 CRITCTRL-="& ENDDAT<=["+num$([M]XITDAT)+"]"
Endif
Filter [TIP] Where evalue(CRITCTRL)
If ACTION="AV_VERF_ANU"
# Test s'il existe temps sur une autre période d'activité
  Call CONTROLE_TIP4([M]REFNUM,[M]CTRNUM,[M]CTRDAT,W_OK) From SUBCTR2
  If !W_OK
     # Suppression impossible : Temps saisis sur la période
     GMESSAGE = mess(152,701,1)
     mkstat = 2
     Return
  Endif
Endif
Read [TIP]TIP2 First
Filter [TIP]
If !fstat
  If ACTION<>"AV_VERF_ANU" : # CONTROLE_PAYE est déjà testé au "AV_VERF_ANU"
    CRITCTRL = "CTRNUM='"+[M]CTRNUM+"'"
    CRITCTRL-="& CTRDAT=["+num$([M]CTRDAT)+"]"
    Call CONTROLE_PAYE([M]REFNUM, CRITCTRL)
    If mkstat
         If GREP<>"M"
           # Creation impossible : Paies présentes sur la période
           WMESSAGE=mess(7,123,1)-":"-mess(147,701,1)
         Else
           # Modification impossible : Paies présentes sur la période
           GMESSAGE = mess(12,701,1)
         Endif
       mkstat = 2 : Return
    Endif
  Endif
  W_OK = 2
  If ACTION="AV_VERF_ANU"
   # Suppression : Temps saisis sur la période
   Call AVERTIR (mess(14,701,1),W_OK) From GESECRAN
  Else
   If GREP<>"M"
    # Creation : Temps saisis sur la période
     Call AVERTIR (mess(59,123,1)-":"-mess(143,701,1),W_OK) From GESECRAN
   Else
    # Modification : Temps saisis sur la période
     Call AVERTIR (mess(142,701,1),W_OK) From GESECRAN
   Endif
  Endif
  If W_OK=1 : mkstat = 2 : Return : Endif
  GRETTIP=1
Endif
Return

########################################################
# CONTROL TIP For ANNULE contract
# Test s'il existe temps sur une autre période d'activité
Subprog CONTROLE_TIP4(REFNUM,CTRNUM,CTRDAT,POK)
Value   Char  REFNUM,CTRNUM
Value   Date  CTRDAT
Variable Integer POK
Local Integer NBCTR
Local Date MCTRDA

If clalev([F:TIP])=0  : Local File TIMEMP     [TIP] : Endif

POK=2
For [F:TIP]
# Test s'il existe temps sur une autre période d'activité
 MCTRDA=func TPSSTD.CALC_CTRDATDEF2([L]REFNUM,[L]CTRNUM,[L]CTRDAT,[F:TIP]ENDDAT,[F:TIP]DATPYR,[F:TIP]ENDDAT,NBCTR)
 If  MCTRDA= [0/0/0] or !NBCTR Then
   POK=0
   Break
 Endif
Next
End

# CONTROL TIP after modify XITDAT(date de sortie)
########################################################
$CONTROLE_TIP2
If clalev([F:TIP])=0  : Local File TIMEMP     [TIP] : Endif
Local Integer W_OK
CRITCTRL="REFNUM='"+[M]REFNUM+"' & CTRNUM='"+[M]CTRNUM+"'"
If [M]CTRDAT<>[0/0/0]
 CRITCTRL-="& (CTRDAT=[0/0/0] | CTRDAT=["+num$([M]CTRDAT)+"])"
 CRITCTRL-="& ([M]FLGRET=2 & DATPYR>=["+num$([M]RETDATEFF)+"] | DATPYR>=["+num$([M]CTRDAT)+"])"
Endif
If WXITDAT<>[0/0/0]
 CRITCTRL-="& ENDDAT > ["+num$(WXITDAT)+"]"
Endif
Filter [TIP] Where evalue(CRITCTRL)
Read [TIP]TIP2 First
Filter [TIP]
If !fstat
  # Modification : Temps saisi au-delà de la période
  W_OK = 2
  Call AVERTIR (mess(60,123,1)-":"-mess(143,701,1),W_OK) From GESECRAN
  If W_OK=1 : mkstat = 2 : Return : Endif
Endif
Return

$CONTROLE_PRVPAIE
Local Integer L_OK
If clalev([F:VPR])=0  : Local File VALPRV           [VPR] : Endif
Filter [F:VPR] Where EMP=[M]REFNUM & CTRNUM=[M]CTRNUM & CTRDAT=[M]CTRDAT & DAT>WXITDAT & VARVAL<>0
Read [F:VPR]VPR0 First
Filter [F:VPR]
If !fstat
  L_OK = 2
  #Valeur(s) prévisionnelle(s) existante(s), postérieure(s) au
  Call AVERTIR(mess(153,701,1)-num$(WXITDAT),L_OK) From GESECRAN
  If L_OK<>2 : mkstat=2 : Return : Endif
Endif

If clalev([F:PPD])=0  : Local File PPREQUESTD       [PPD] : Endif
Filter [F:PPD] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & CTRDAT=[M]CTRDAT & APLSTR>WXITDAT  & (DEMAMT<>0 | ACPAMT<>0)
Read [F:PPD]PPD0 First
Filter [F:PPD]
If !fstat
  L_OK = 2
  #Bordereau de prépa-paie existant, postérieur au
  Call AVERTIR(mess(154,701,1)-num$(WXITDAT),L_OK) From GESECRAN
  If L_OK<>2 : mkstat=2 : Return : Endif
Endif
Return

################################################################################################################
#                                    LES Subprog CONTROLE* ()
##################################################################################################################

## Controle paies
########################################################
Subprog CONTROLE_PAYE(MATRI, CRITERE)
Variable Char MATRI ()
Variable Char CRITERE
Raz mkstat
If GPAYE<>1 : End : Endif
If clalev([F:VEP])=0  : Local File VALEMP   [VEP]  : Endif
Filter [F:VEP] Where EMP=MATRI & evalue (CRITERE)
Read [F:VEP]VEP0 First
Filter [F:VEP]
If !fstat : mkstat=1 : Endif
End

## Controle date de sortie
########################################################
Subprog CONTROLE_SORTIE(ENTREE, VALEUR, MATRI, CONTRAT)
Variable Date VALEUR, ENTREE
Variable Char MATRI (), CONTRAT ()
Local Char CRITERE (250)
Local Integer OK
If clalev([F:CTR1])=0 : Local File EMPLOCTR [CTR1] : Endif
If clalev([F:ID1])=0  : Local File EMPLOID  [ID1]  : Endif
If VALEUR<>"00/00/00"
 If VALEUR < ENTREE
  GMESSAGE = mess(6,702,1): #La date de sortie ne peut pas être inférieure à la date d'entrée
  mkstat = 1 : End
 Endif
 Read [F:CTR1]CTR0=MATRI;CONTRAT;ENTREE
 If !fstat
  CRITERE="CTRNUM='"+[F:CTR1]CTRNUM+"' & ENDDAT>["+num$(VALEUR)+"]"
  Call CONTROLE_PAYE(MATRI, CRITERE)
  If mkstat
   #Paie(s) existante(s), postérieure(s) au
   GMESSAGE = mess(10,701,1)-num$(VALEUR)
   Call AVERTIR(GMESSAGE,OK) From GESECRAN
   If OK<>2 : mkstat=1 : Else mkstat=0 : End : Endif
  Endif
  If func AFNC.ACTIV("NOF")
   CRITERE="CTRNUM='"+[F:CTR1]CTRNUM+"' & DATEXS>["+num$(VALEUR)+"]"
   Call CONTROLE_FRAIS([L]CRITERE,[L]MATRI)
   If mkstat
    GMESSAGE = mess(16,718,1)-num$([L]VALEUR)
    Call AVERTIR(GMESSAGE,[L]OK) From GESECRAN
    # Il existe des frais postérieurs au
    If [L]OK<>2 : mkstat=1 : Else mkstat=0 : End : Endif
   Endif
  Endif
 Endif
Endif
End

## Controle date de sortie / dates d'entrée pour les non artistes
########################################################
Subprog CONTROLE_ENT
Local Integer SORTIE_VIDE, OK, I
Local Char    CRITERE(250)
Local Date    OLDDAT
If clalev([F:CTR1])=0 : Local File EMPLOCTR [CTR1] : Endif
If clalev([F:ID])=0   : Local File EMPLOID  [ID]   : Endif
If clalev([F:MOE])=0  : Local File MOTENT   [MOE]  : Endif

If [M:CTR8]XITDAT=[00/00/00]
 SORTIE_VIDE = 1
 I = 1
Endif

If [M:CTR0]REFNUM<>[F:ID]REFNUM
 Read [ID]ID0=[M:CTR0]REFNUM
  If fstat : GOK=0 : End : Endif
Endif

If [F:ID]FLGMULCTR=2
 Filter [CTR1] Where REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM & FLGVAR<>2
Else
 Filter [CTR1] Where REFNUM=[M:CTR0]REFNUM & FLGVAR<>2
Endif

#Verif chronologie
For [CTR1]CTR1
 If [F:CTR1]CTRNUM<>[M:CTR0]CTRNUM | [F:CTR1]CTRDAT<>[M:CTR0]CTRDAT
  If [F:CTR1]XITDAT="00/00/00"
   SORTIE_VIDE +=1
   If [F:CTR1]CTRNUM=[M:CTR0]CTRNUM & [F:CTR1]CTRDAT<>[M:CTR0]CTRDAT
    I +=1
    OLDDAT = [F:CTR1]CTRDAT
   Endif
  Endif
  If ([F:CTR1]XITDAT>=[M:CTR0]CTRDAT & [F:CTR1]CTRDAT<=[M:CTR8]XITDAT & [M:CTR8]XITDAT<>[0/0/0] & [F:CTR1]XITDAT<>[0/0/0])
&|   ([F:CTR1]CTRDAT>=[M:CTR0]CTRDAT & [F:CTR1]XITDAT=[0/0/0] & ([M:CTR8]XITDAT=[0/0/0] | [M:CTR8]XITDAT>=[F:CTR1]CTRDAT))
&|   ([F:CTR1]XITDAT>=[M:CTR0]CTRDAT & [F:CTR1]CTRDAT<=[M:CTR0]CTRDAT & [F:CTR1]XITDAT<>[0/0/0])
   # La période du contrat chevauche celle d'un contrat déja existant :
   GMESSAGE = mess(35,701,1)-num$([F:CTR1]CTRDAT)-num$([F:CTR1]XITDAT)
   GERR = 1 : Break
  Endif
 Endif
Next
Filter [CTR1]

If GERR=1 : GOK=0 : End : Endif

If SORTIE_VIDE>1
 If [M:CTR8]XITDAT=[00/00/00] & I=2
  Gosub TR_ENT
 Else
  # Nombre de sorties incorrect en fonction des entrées
  GMESSAGE = mess(8,702,1)
  GERR = 1
 Endif
Elsif SORTIE_VIDE=1 & [M:CTR8]XITDAT<>[0/0/0] & OLDDAT<[M:CTR0]CTRDAT & OLDDAT<>[0/0/0] #bug 91300 Suite 85360
 Gosub TR_ENT
Endif
If GERR=1 : GOK=0 : End : Endif
End

########################################################
$TR_ENT
Read [MOE]MOE0=[M:CTR0]CTRGRD
If !fstat & [F:MOE]CTRXITAUT=2 & [F:MOE]CTRXITGRD<>""
 Readlock [CTR1]CTR0=[M:CTR0]REFNUM;[M:CTR0]CTRNUM;OLDDAT
 If fstat=1
  GOK=-1 : GLOCK="$EMPLOCTR"-[M:CTR0]REFNUM-[M:CTR0]CTRNUM-num$(OLDDAT) : Return
 Elsif fstat
  GOK=0 : Call FSTA("CTR1") From GLOCK : Return
 Endif
 [F:CTR1]XITDAT = [M:CTR0]CTRDAT-1
 [F:CTR1]XITGRD = [F:MOE]CTRXITGRD
 Rewrite [CTR1]
 If fstat
  GOK=0 : Call FSTA("CTR1") From GLOCK : Return
 Endif
Else
 # Nombre de sorties incorrect en fonction des entrées
 GMESSAGE = mess(8,702,1)
 GERR = 1
Endif
Return

## Controle date de sortie / dates d'entrée pour les non artistes
########################################################
Subprog CONTROLE_ENT_CTRGRD(PCTRGRD,PMAJ,POK)
Value Char PCTRGRD()
Value Integer PMAJ
Variable Integer POK
Local Integer SORTIE_VIDE, OK, I
Local Char    CRITERE(250)
Local Date    OLDDAT
Local Char    OLDCTR(GLONCTR)
If clalev([F:CTR1])=0 : Local File EMPLOCTR [CTR1] : Endif
If clalev([F:ID])=0   : Local File EMPLOID  [ID]   : Endif
If clalev([F:MOE])=0  : Local File MOTENT   [MOE]  : Endif

If [M:CTR8]XITDAT=[00/00/00]
 SORTIE_VIDE = 1
 I = 1
Endif
Raz OLDCTR

If [M:CTR0]REFNUM<>[F:ID]REFNUM
 Read [ID]ID0=[M:CTR0]REFNUM
 If fstat : POK=0 : End : Endif
Endif

If [F:ID]FLGMULCTR=2
 Filter [CTR1] Where REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM & FLGVAR<>2
Else
 Filter [CTR1] Where REFNUM=[M:CTR0]REFNUM & FLGVAR<>2
Endif

#Verif chronologie
For [CTR1]CTR1
 If [F:CTR1]CTRNUM<>[M:CTR0]CTRNUM | [F:CTR1]CTRDAT<>[M:CTR0]CTRDAT
  If [F:CTR1]XITDAT="00/00/00"
   SORTIE_VIDE +=1
   OLDCTR=[F:CTR1]CTRNUM
   If [F:CTR1]CTRNUM=[M:CTR0]CTRNUM & [F:CTR1]CTRDAT<>[M:CTR0]CTRDAT
    I +=1
    OLDDAT = [F:CTR1]CTRDAT
   Endif
  Endif
  If ([F:CTR1]XITDAT>=[M:CTR0]CTRDAT & [F:CTR1]CTRDAT<=[M:CTR8]XITDAT & [M:CTR8]XITDAT<>[0/0/0] & [F:CTR1]XITDAT<>[0/0/0])
&|   ([F:CTR1]CTRDAT>=[M:CTR0]CTRDAT & [F:CTR1]XITDAT=[0/0/0] & ([M:CTR8]XITDAT=[0/0/0] | [M:CTR8]XITDAT>=[F:CTR1]CTRDAT))
&|   ([F:CTR1]XITDAT>=[M:CTR0]CTRDAT & ([F:CTR1]CTRDAT<=[M:CTR0]CTRDAT | ([F:CTR1]CTRDAT>[M:CTR0]CTRDAT & [M:CTR8]XITDAT=[0/0/0])
&&    [F:CTR1]XITDAT<>[0/0/0]))
   # La période du contrat chevauche celle d'un contrat déja existant :
   GMESSAGE = mess(35,701,1)-num$([F:CTR1]CTRDAT)-num$([F:CTR1]XITDAT)
   POK = 0 : Break
  Endif
 Endif
Next
Filter [CTR1]

If !POK : End : Endif

If SORTIE_VIDE>1
 If [M:CTR8]XITDAT=[00/00/00] & I=2
  Gosub TR_ENT_CTRGRD
 Else
  # Un contrat encore actif existe pour ce matricule
  GMESSAGE = mess(137,701,1)-[M:CTR0]REFNUM-"/"-OLDCTR
  POK = 0
 Endif
Elsif SORTIE_VIDE=1 & [M:CTR8]XITDAT<>[0/0/0] & OLDDAT<[M:CTR0]CTRDAT & OLDDAT<>[0/0/0] #bug 91300 Suite 85360
 Gosub TR_ENT_CTRGRD
Endif
If !POK : End : Endif
End

########################################################
$TR_ENT_CTRGRD
Read [MOE]MOE0=PCTRGRD
If !fstat & [F:MOE]CTRXITAUT=2 & [F:MOE]CTRXITGRD<>""
  If PMAJ
   Readlock [CTR1]CTR0=[M:CTR0]REFNUM;[M:CTR0]CTRNUM;OLDDAT
   If fstat=1
    GOK=-1 : GLOCK="$EMPLOCTR"-[M:CTR0]REFNUM-[M:CTR0]CTRNUM-num$(OLDDAT) : Return
   Elsif fstat
    GOK=0 : Call FSTA("CTR1") From GLOCK : Return
   Endif
   [F:CTR1]XITDAT = [M:CTR0]CTRDAT-1
   [F:CTR1]XITGRD = [F:MOE]CTRXITGRD
   Rewrite [CTR1]
   If fstat
    GOK=0 : Call FSTA("CTR1") From GLOCK : Return
   Endif
  Endif
Else
 # Un contrat encore actif existe pour ce matricule
 GMESSAGE = mess(137,701,1)-[M:CTR0]REFNUM-"/"-OLDCTR
 POK = 0
Endif
Return

## Controle existante de frais sur la période
########################################################
Subprog CONTROLE_FRAIS(CRITERE,MATRI)
Variable Char CRITERE
Variable Char MATRI()
If !clalev([F:EXS]) : Local File EXPENSES [EXS] : Endif
mkstat=0
Filter [EXS] Where REFNUM=[L]MATRI & evalue(CRITERE)
Read [EXS]EXS1 First
Filter [EXS]
If !fstat : mkstat=1 : Endif
End

## Controle avantages en nature
########################################################
Subprog CONTROLE_AVNNAT(VALEUR)
Variable Char    VALEUR()
If !func AFNC.ACTIV("FPAY") : End : Endif
Local Integer I, J, COMPTEUR, LONG
# Ne peut contenir que N(nourriture), L(logement), V(voiture), A(autres).
If VALEUR<>""
 LONG=len (VALEUR)
 For I=1 To LONG
  COMPTEUR=0
  DOUBLON=mid$(VALEUR,I,1)
  If !find(DOUBLON,"N","L","V","A")
     GMESSAGE = DOUBLON-mess(1,702,1)-": (NLVA)" : # Valeur incorrecte
     mkstat = 1 : End
  Endif
  For J=1 To LONG
   If DOUBLON = mid$(VALEUR,J,1)
    COMPTEUR=COMPTEUR+1
    If COMPTEUR>1
     GMESSAGE = DOUBLON-mess(5,702,1) : # Valeur doublée
     mkstat = 1 : End
    Endif
   Endif
  Next J
 Next I
Endif
End

## Controle frais professionnels
########################################################
Subprog CONTROLE_EXSPFL(VALEUR)
Variable Char    VALEUR()
If !func AFNC.ACTIV("FPAY") : End : Endif
Local Integer I, J, COMPTEUR, LONG
# Ne peut contenir que F,R,P,D
If VALEUR<>""
 LONG=len (VALEUR)
 For I=1 To LONG
  COMPTEUR=0
  DOUBLON=mid$(VALEUR,I,1)
  If !find(DOUBLON,"F","R","P","D")
     GMESSAGE = DOUBLON-mess(1,702,1)-": (FRPD)" : # Valeur incorrecte
     mkstat = 1 : End
  Endif
  For J=1 To LONG
   If DOUBLON = mid$(VALEUR,J,1)
    COMPTEUR=COMPTEUR+1
    If COMPTEUR>1
     GMESSAGE = DOUBLON-mess(5,702,1) : # Valeur doublée
     mkstat = 1 : End
    Endif
   Endif
  Next J
 Next I
Endif
End

# SETMSK_CTR9 : Défini l'état saisissable ou non du masque CTR9 - Infos compta / contrat
########################################################
Subprog SETMSK_CTR9(FCY)
Value Char FCY()

Local Integer FLGCTRCPT
Local Char VOIDCHAR(250)

Raz [L]FLGCTRCPT, [L]VOIDCHAR

Call PARAM([L]FCY, "CTRCPT", [L]VOIDCHAR) From ADOVAL
[L]FLGCTRCPT = max(val(vireblc([L]VOIDCHAR, 4)), 1)

# Parameter Value is able to modify screen field
Case [L]FLGCTRCPT
  When 1 : # [M:CTR9]FLGCTRCPT must be unavailable
    [M:CTR9]FLGCTRCPT = 1 : Grizo [M:CTR9]

  When Default :
    If find([V]GREP,"C") :# --- Creating
      Case [L]FLGCTRCPT
        When 2
            [M:CTR9]FLGCTRCPT = 1
        When 3
            [M:CTR9]FLGCTRCPT = 2
      Endcase
    Endif

    If [M:CTR9]FLGCTRCPT = 1
        Grizo [M:CTR9]            : # On grise tout
    Else
        Actzo [M:CTR9]            : # On active tout
    Endif
    Actzo [M:CTR9]FLGCTRCPT
Endcase
Affzo [M:CTR9]FLGCTRCPT

End




## VALDEF_CTR9_CPT : Charge les valeurs par défaut du bloc compta du masque CTR9 en fonction du salarié
#########################################################
Subprog VALDEF_CTR9_CPT(REFNUM)
Value Char REFNUM()
#
Local Char WZONE(20)
#
Read [F:CPT]CPT0 = [L]REFNUM
If fstat = 0
    # Cas particulier des imports : on ne veut pas que des valeurs imposées
    # par l'import soit écrasées
    If not [V]GIMPORT
        [M:CTR9]BPR = [F:CPT]BPR
        [M:CTR9]ACCCOD = [F:CPT]ACCCOD
        [M:CTR9]DSP = [F:CPT]DSP
        Call LECTEXTRA([M:CTR9]DSPDES, "CADSP","DESTRA",[F:CPT]DSP,"") From ATEXTRA
    Else

    Endif
    #JOJAC - 2017-01-23 - START
    #Look [F:CAC]CAC0 = 14 ; [M:CTR9]ACCCOD
    Look [F:CAC]CAC0 = 35 ; [M:CTR9]ACCCOD
    #JOJAC - 2017-01-23 - END
    If fstat <> 0
        Raz [M:CTR9]ACCCOD
        # Pour conserver un comportement identique à la saisie
        #JOJAC - 2017-01-23 - START
        #Call INITACCCOD([M:CTR9]ACCCOD,14) From TRTINTCPT
        Call INITACCCOD([M:CTR9]ACCCOD,35) From TRTINTCPT
        #JOJAC - 2017-01-23 - END
    Endif
Endif
End

Subprog VALDEF_CTR9_ANA(WCHARGE,WCPY)
Value Integer WCHARGE  :# 0 : default values, 1 : value from EMPLOCTRCPT
Value Char WCPY()

Local Integer J
Local Integer NBPLAN, NBAXE
Local Integer REFTYP(1..10)
Local Integer OBLIG(1..max(GOPTCANA,20))
Global Char   GPLAN(GLONCOA)(1..10)
Local Char    ACMCUR(GLONGCM)

If dim([M]DIE)<=0 : Return : Endif
  nolign = 1
  Raz [M]DIE, CCE, INICCE


    Call SETGCM(WCPY,ACMCUR) From CPTDIV : # code du modèle de la société
    # liste des axes de tous les référentiels du modèle (nb référentiels limités à len de
    Call SETPLAN2(ACMCUR,NBPLAN,GPLAN,REFTYP,NBAXE,[M:CTR9]DIE,OBLIG) From CPTDIV
    [M]NBAXECPR = min(NBAXE,dim([M:CTR9]DIE))
    For I=0 To [M:CTR9]NBAXECPR-1
     If [L]WCHARGE=1 & [M:CTR9]DIE(I)<>"" & find([M:CTR9]DIE(I),[F:CPR]DIE(0..dim([F:CPR]DIE)-1))
      For J=0 To dim([F:CPR]DIE)-1
       If [M:CTR9]DIE(I) = [F:CPR]DIE(J)
         If [M:CTR9]DSP="" Then
          [M:CTR9]CCE(I) = [F:CPR]CCE(J)
          [M:CTR9]INICCE(I)=[F:CPR]INICCE(J)
         Endif
        Break
       Endif
      Next J
     Else
       If [M:CTR9]DSP = ""
        If [M:CTR9]DIE(I) <> ""
         [M:CTR9]INICCE(I)=3
        Endif

       Endif
     Endif
    Next I

End

Subprog D_DEGMAL(VALEUR)
Variable Integer VALEUR
VALEUR=3
End

Subprog AS_QLF(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]CATQLF<>""
 Call LECTEXTRA(VALEUR,"ATABDIV","LNGDES","605",[M]CATQLF) From ATEXTRA
Endif
End

Subprog AM_MAIFCY(VALEUR)
Variable Integer VALEUR
If [L]VALEUR=2 : End : Endif
Look [ELC]ELC0=[M]REFNUM;[M]ETRFCY
If !fstat
 [V]GMESSAGE=mess(9,715,1) : # Il faut d'abord désigner le nouveau site principal
 mkstat     =2
 End
Endif
End

Subprog AS_BUIDAYTYP(VALEUR)
Variable Integer VALEUR
GMENLOC(1)=1
End

#Catégorie BTP
Subprog AS_BUICAT(VALEUR)
Variable Integer VALEUR
Local Integer I
For I=3 To 6
 GMENLOC(I)=1
Next
For I=9 To len(mess(0,380,1))
 GMENLOC(I)=1
Next
End

#Niveau BTP
Subprog AS_BUILEV(VALEUR)
Variable Integer VALEUR
Local Integer I
GMENLOC(5)=1
GMENLOC(6)=1
For I=19 To len(mess(0,380,1))
 GMENLOC(I)=1
Next
End

Subprog C_PSNJOB(VALEUR)
Variable Char    VALEUR()
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
Read[F:ADI]CODE=362;[M]CATCSP
If !fstat & [F:ADI]A1="389b"
 If VALEUR<>""
  If GDOSLEG="FRA" Then
    Read[F:ADI]CODE=604;VALEUR
    If fstat | ([F:ADI]A1<>"T389" & [F:ADI]A1<>"C389")
     #Valeur incorrecte
      GMESSAGE=mess(1,702,1)
      mkstat=2 : End
    Endif
  Endif
 Else
  #zone obligatoire
  GMESSAGE=mess(10,123,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog C_EVECTRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<[M:CTR0]CTRDAT | ([M:CTR8]XITDAT<>[0/0/0] & VALEUR>[M:CTR8]XITDAT)
 #Valeur incorrecte
  GMESSAGE=mess(1,702,1)
  mkstat=2 : End
Endif
End

Subprog AM_XITFNL(VALEUR)
Variable Integer VALEUR

# BRBAN - Portuguese legal requirements 11/09/14
If func AFNC.ACTIV("KPO")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KSA")=0) & VALEUR=2
  Local Integer OKPRF : [L]OKPRF = 1
  #Do you want to update the employee contract profile?
  Call OUINON(mess(22,11553,1),[L]OKPRF) From GESECRAN
  If [L]OKPRF=2
    [M:CTR1]PROPRF = func AFNC.PARAMDOS(nomap,"PRFXITFNL")
    Call AM_PROPRF([M:CTR1]PROPRF) From SUBCTR
    Affzo [M:CTR1]PROPRF
  Endif
Endif


If VALEUR<>2
 [M]FLGALCCHO = 1 : Grizo FLGALCCHO : Affzo FLGALCCHO
Else
 Actzo FLGALCCHO
Endif
If func ISKZAKAQ() & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
  If func DIVPAYE.EXISTE_KXX("SUBCTRKSA") Then
    Call AM_XITFNL(VALEUR) From SUBCTRKSA
  Endif
Endif
End

Subprog C_NBRDAYCTR(VALEUR)
Variable Decimal VALEUR
If !VALEUR & [M]TYPJOB=14
 GMESSAGE=mess(10,123,1) #Zone obligatoire
 mkstat=2 : End
Endif
Call GRISE_FORFAIT(VALEUR,"NBRDAYCTR") From SUBCTR2
End

Subprog AS_NBRHOUCTR(VALEUR)
Variable Decimal VALEUR

  # On initialise le nombre d'heures si on est en unité de temps à "Forfait heure"
  If VALEUR=0 & [M]DNACODTIM=6 Then
    VALEUR=val(func AFNC.PARAM("HRSYEA",[F:CTR]ETRFCY))
  Endif
End

Subprog C_NBRHOUCTR(VALEUR)
Variable Decimal VALEUR
If !VALEUR & [M]DNACODTIM=6
  GMESSAGE=mess(10,123,1) #Zone obligatoire
  mkstat=2 : End
Endif
If VALEUR Then
  Call GRISE_FORFAIT(VALEUR,"NBRHOUCTR") From SUBCTR2
Else
  Actzo [M]NBRDAYCTR
Endif
End

Subprog AS_DATFCY(VALEUR)
Variable Date    VALEUR
#On recalcule la date d'entrée site qu'en création/duplication d'une fiche contrat...
If GREP<>"C" & GREP<>"D" : End : Endif
If clalev([F:CTR1])=0 : Local File EMPLOCTR [CTR1] : Endif
If clalev([F:MOE])=0 : Local File MOTENT    [MOE]  : Endif
Read[MOE]MOE0=[M:CTR0]CTRGRD
#Maj date entrée site si le motif le demande
If !fstat & [MOE]CTRDATFCY=2
 VALEUR=[M:CTR0]CTRDAT
Else
 #Reprise de la date d'entrée site de la fiche contrat précédente
 Filter [F:CTR1] Where REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM & CTRDAT<[M:CTR0]CTRDAT
 Read [F:CTR1]CTR0 Last
 Filter [F:CTR1]
 If !fstat
  VALEUR=[F:CTR1]DATFCY
 Endif
Endif
#Si le motif ne demande pas la MAJ et pas de fiche contrat précédente
If VALEUR=[0/0/0] :VALEUR=[M:CTR0]CTRDAT : Endif
End

Subprog AM_PROPRF(VALEUR)
Variable Char    VALEUR()
Gosub RET_EXTOURNE
If mkstat : End : Endif
Local File PROFILDEF [PFD]  : # Must be by default
Local Integer L_FORCE      : # 1 Force update else don't do anything
Local Integer L_OK
Local Char    CRITCTRL(GDIMFIC)
Local Char    VCLLCVT (GLONADI)
L_OK = 1
#We ask only if there is something to do...
Filter [PFD] Where [PFD]PRFCOD=VALEUR
Read [PFD]PFD0 First
If fstat<4
 L_OK = 2
Endif
Filter [PFD]
#Is something is calculated, we have to warn
#Even when Creating/Duplicating : #  & !find(GREP,"C","D")
If L_OK=2
 mkstat = 0
 Gosub CONTROLE
 If mkstat
  GMESSAGE = mess(96,701,1)
  ######## il existe des bulletins calculés pour ce contrat, voulez vous vraiment changer le profil ?
  Call AVERTIR(GMESSAGE,L_OK) From GESECRAN
  GMESSAGE = ""
  If L_OK<>2 : End : Endif
  mkstat = 0
 Else
  L_OK = 1
 Endif
Endif
If func IS_INIT_CTR(VALEUR,3)
  Call OUINON(mess(91,701,1),L_OK) From GESECRAN
  L_FORCE = 1
  #### Voulez-vous initialiser ce contrat par les données du profil salarié ?
  If L_OK=2
   If GPAYE : VCLLCVT=[M:CTR1]CLLCVT :  Else : VCLLCVT="" : Endif
   Call INIT_CTR(VALEUR,3,[M:CTR0]ETRFCY,L_FORCE,VCLLCVT) From SUBCTR
  Endif
Endif
Call LECTURE("PRF",VALEUR,"") From CONTOBJ
If [F:PRF]EMPMDL="" : End : Endif
End

Subprog AS_ETRFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : End : Endif
If clalev([F:ID])=0   : Local File EMPLOID   [ID]  : Endif
If [M:CTR0]REFNUM<>[F:ID]REFNUM
 Read[ID]ID0=[M:CTR0]REFNUM
 If fstat : End : Endif
Endif
VALEUR=[F:ID]FCYORI
If VALEUR="" : VALEUR=GFCYDEF : Endif
End

Subprog C_BPR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & GDOSCPT<>""
 Local File =GTABCPT+"BPARTNER"   [XBPR]
 Read[XBPR]BPR0=VALEUR
 If fstat
  GMESSAGE = mess(44,703,1) : # Ce compte individuel n'est pas un tiers comptable
  mkstat   = 2
 Endif
Endif
End

