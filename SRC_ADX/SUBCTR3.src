Variable Char    VALEUR()
If VALEUR=""
 Gosub LIRE_SITE
 VALEUR = [F:SIT]CLLCVT
Endif
End

Subprog AS_RSKWRK(VALEUR)
Variable Char    VALEUR()
# FQ95799 - 17/04/14 - Ce champ est obligatoire uniquement si localisation FRA, d'où le test sur GDOSLEG
If VALEUR="" & GDOSLEG="FRA"
 Gosub LIRE_SITE
 VALEUR = [F:SIT]RSKWRK
Endif
End

Subprog C_XITDAT(VALEUR)
Variable Date    VALEUR
If [M:CTR0]FLGVAR<>2
  Call CONTROLE_SORTIE([M]CTRDAT,VALEUR,[M]REFNUM,[M]CTRNUM)
 If mkstat : End : Endif
Endif
Call GRISE_SORTIE(VALEUR) From SUBCTR2
End

Subprog AM_XITDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & GREP<>"C" & GREP<>"D" & ([M]XITDAT =[0/0/0] | VALEUR < [M]XITDAT )
 WXITDAT=VALEUR
 Gosub CONTROLE_TIP2
 If mkstat : End : Endif
 If GPAYE
  Gosub CONTROLE_PRVPAIE
  If mkstat : End : Endif
 Endif
Endif
GRETTIP=1
If VALEUR=[0/0/0] & [M]XITFNL<>1
 [M]XITFNL = 1
 [M]FLGALCCHO = 1 : Grizo FLGALCCHO
Endif
[M:CTR0]XITDAT=VALEUR : Affzo [M:CTR0]XITDAT :#94459

If func ISKZAKAQ() Then
  If func DIVPAYE.EXISTE_KXX("SUBCTRKSA") Then
    Call AM_XITDAT(VALEUR) From SUBCTRKSA
  Endif
Endif

If dim([M:CTRB]FLGEXCPEN) > 0 & [M:CTRB]FLGEXCPEN<>2
 If [M:CTR1]POT<>""
  [M:CTR8]XITDAT=VALEUR
  Gosub CHARGE_CPN From SUBCTRKFR
 Endif
Endif
End

Subprog AM_XITGRD(VALEUR)
Variable Char    VALEUR()
If GPAYE : Call GRISE_RAZCUM(VALEUR) : Endif
Read[F:ADI]CODE=359;VALEUR
#faute lourde
If fstat | (GDOSLEG="FRA" & ([F:ADI]A1="012|88" |[F:ADI]A1="902|96"))
 Grizo FLGALCCHO
Else
 Actzo FLGALCCHO
Endif

Gosub STYLE

End

Subprog AS_DATLIC(VALEUR)
Variable Date    VALEUR
Read[F:ADI]CODE=359;[M]XITGRD
Local Integer JADI
Local Char CODA1 (10)
JADI=instr (1,[F:ADI]A1,"|")
If JADI
 CODA1=seg$([F:ADI]A1,1,JADI-1)
Else
 CODA1=[F:ADI]A1
Endif
If fstat | (GDOSLEG="FRA" & (val(CODA1)<>12 & val(CODA1)<>26))
  mkstat=1 : End
Endif
End

