Subprog C_NBRPSN
If status=65 & [M]BUL(nolign-1)<>""
 # Suppression  impossible \ Une paie existe sur la prestation
 GMESSAGE = mess(32,701,1)
 mkstat = 2 : End
Endif
If status=83
 For NOL=nolign-1 To nolign1-1
  If [M]BUL(NOL)<>""
   # Ligne x : Suppression  impossible \ Une paie existe sur la prestation
   GMESSAGE = mess(45,9009,1)-num$(NOL+1)-":"-mess(32,701,1)
   mkstat = 2 : End
  Endif
 Next
Endif
End

Subprog C_PSNENDTIM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M:CTR3]PSNSTRTIM(nolign-1)
 GMESSAGE = mess(69,134,1) : # Heure incorrecte
 mkstat = 2 : End
Endif
End

Subprog C_AMTBUD(VALEUR)
Variable Decimal  VALEUR
If VALEUR<([M]AMTCRG(nolign-1)+[M]AMTCRGEXO(nolign-1))
 # Le montant du budget ne doit pas être inférieur au montant des frais
 GMESSAGE = mess(36,701,1)
 mkstat = 2 : End
Endif
End

Subprog C_PSNSTRDAT(VALEUR)
Variable Date    VALEUR
Gosub PSNDAT
If mkstat=2 : End : Endif
End

Subprog C_PSNENDDAT(VALEUR)
Variable Date    VALEUR
Gosub PSNDAT
If mkstat=2 : End : Endif

If VALEUR>eomonth(PSNSTRDAT(nolign-1))
 GMESSAGE=mess(170,701,1)
 mkstat=2
 End
Endif
#
End

########################################################
$PSNDAT
Local Date DATREF
If GFONCTION="GESCTR"
 DATREF=[M]CTRDAT

 If [M:CTR0]FLGRET=2 : DATREF=[M]RETDATEFF : Endif
 If VALEUR<DATREF | (VALEUR>[M:CTR8]XITDAT & [M:CTR8]XITDAT<>[0/0/0])
  # Date de la prestation en dehors de la période du contrat
  If [M:CTR8]XITDAT<>[0/0/0]
   GMESSAGE = mess(37,701,1)-":"-mess(94,100,1)-format$("D:"+GFMDAT,[L]DATREF)-mess(95,100,1)-format$("D:"+GFMDAT,[M]XITDAT)
  Else
   GMESSAGE = mess(37,701,1)-":"-format$("D:"+GFMDAT,[L]DATREF)
  Endif
  mkstat = 2 : Return
 Endif
Else
 If VALEUR<[M]CTRDAT
  # Date de la prestation en dehors de la période du contrat
  GMESSAGE = mess(37,701,1)-":"-format$("D:"+GFMDAT,[M]CTRDAT)
  mkstat = 2 : Return
 Endif
Endif
Return

Subprog AV_NBRDAY(VALEUR)
Variable Decimal VALEUR
VALEUR = ([M]PSNENDDAT(nolign-1)-[M]PSNSTRDAT(nolign-1))+1
End

Subprog AS_NBRTIM(VALEUR)
Variable Decimal  VALEUR
Local Decimal VALHMDEB, VALHMFIN
If [M]PSNSTRTIM(nolign-1)<>"" & [M]PSNENDTIM(nolign-1)<>""
 Call CONVERTHM([M]PSNSTRTIM(nolign-1),VALHMDEB) From SUBSTY
 Call CONVERTHM([M]PSNENDTIM(nolign-1),VALHMFIN) From SUBSTY
 If VALHMFIN>=VALHMDEB
  VALEUR = VALHMFIN-VALHMDEB
 Else
  VALEUR = 24-VALHMDEB + VALHMFIN
 Endif
 VALEUR = VALEUR*([M]PSNENDDAT(nolign-1)-[M]PSNSTRDAT(nolign-1)+1)
 mkstat=2
Endif
End

Subprog C_NBRTIM(VALEUR)
