######################################################################################
##**V01X10
######################################################################################
Subprog C_CODCNB(VALEUR)
Variable Integer VALEUR
# Contract available after 01 January 2015
If ([M:CTR0]XITDAT=[0/0/0] | [M:CTR0]XITDAT>=[01/01/2015]) & [L]VALEUR=7
 Local Integer OK
 OK = 2
 #Code CNBF "Non Adhérent" : Valeur incorrecte
 Call AVERTIR(mess(110,200,1)-'"'+mess(VALEUR, 310,1)+'"'-':'- mess(83,123,1),OK) From GESECRAN
 If OK=1 : mkstat = 2 : End : Endif
Endif
End

