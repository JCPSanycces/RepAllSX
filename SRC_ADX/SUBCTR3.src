Subprog AM_FLGCTRCPT(VALEUR)
Variable Integer  VALEUR
If [L]VALEUR = 2
    # Activation de l'écran
    Call VALDEF_CTR9_CPT([M:CTR0]REFNUM) From SUBCTR
    Call VALDEF_CTR9_ANA(0,[M:CTR0]CPY) From SUBCTR
    Affzo [M:CTR9]
    Actzo [M:CTR9]
Else
    # Effacement de l'écran
    Effzo [M:CTR9]10,20
    Grizo [M:CTR9] : Actzo [M:CTR9]FLGCTRCPT
    Affzo [M:CTR9]
Endif

End


Subprog AM_POT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""

Local Integer L_OK
L_OK = 1

If func ISKSA()
  If func DIVPAYE.EXISTE_KXX("SUBCTRKSA") Then
    Call AM_POT(VALEUR) From SUBCTRKSA
  Endif
Endif
If ([F:POT]DATSTRVLY<>[0/0/0] & [M:CTR0]CTRDAT<[F:POT]DATSTRVLY) | ([F:POT]DATENDVLY<>[0/0/0] & [M:CTR0]CTRDAT>[F:POT]DATENDVLY)
 Call AVERTIR(VALEUR-mess(93,701,1)-format$("DD2",[F:POT]DATSTRVLY)-"-"-format$("DD2",[F:POT]DATENDVLY),L_OK) From GESECRAN
 #### Période validité poste :
 If L_OK<>2
  mkstat = 2 : End
 Endif
Endif
Local File POSTEDEF [POD]  : # Must be by default
Local Integer L_FORCE      : # 1 Force update else don't do anything
Local Char    CRITCTRL(GDIMFIC)
Local Char    VCLLCVT (GLONADI)
#Is something is calculated, we have to warn
L_OK = 1
#We ask only if there is something to do...
Filter [POD] Where [POD]COD=VALEUR
Read [POD]POD0 First
If fstat<4
 L_OK = 2
Endif
Filter [POD]
#Even when Creating/Duplicating : #  & !find(GREP,"C","D")
If L_OK=2
 mkstat = 0
 Gosub CONTROLE
 If mkstat
  GMESSAGE = mess(94,701,1)
  ######## il existe des bulletins calculés pour ce contrat, voulez vous vraiment changer le poste ?
  Call AVERTIR(GMESSAGE,L_OK) From GESECRAN
  GMESSAGE = ""
  If L_OK<>2 : End : Endif
  mkstat = 0
 Else
  L_OK = 1
 Endif
Endif
L_FORCE = 1
If func IS_INIT_CTR(VALEUR,1)
  Call OUINON(mess(89,701,1),L_OK) From GESECRAN
  #### Voulez-vous initialiser ce contrat par les données du poste ?
  If L_OK=2
   If GPAYE : VCLLCVT=[M:CTR1]CLLCVT :  Else : VCLLCVT="" : Endif
   Call INIT_CTR(VALEUR,1,[M:CTR0]ETRFCY,L_FORCE,VCLLCVT) From SUBCTR
   mkstat = 0
  Endif
Endif
If [F:POT]JOBPOT<>""
 [M]JOBPOT = [F:POT]JOBPOT
 Affzo JOBPOT
 Call AM_JOBPOT([M]JOBPOT)
 mkstat = 0
Endif
Endif
If func AFNC.ACTIV("KFR") > 0
    If dim([M:CTRB]FLGEXCPEN) > 0 & [M:CTRB]FLGEXCPEN=2 Then
     [M:CTRB]FLGEXCPEN=[F:POT]FLGEXCPEN
    Endif
    Call AM_POT([L]VALEUR) From SUBCTRKFR
Endif
End

Subprog AM_JOBPOT(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Local Integer L_OK
L_OK = 1

If ([F:JOT]DATSTRVLY<>[0/0/0] & [M:CTR0]CTRDAT<[F:JOT]DATSTRVLY) | ([F:JOT]DATENDVLY<>[0/0/0] & [M:CTR0]CTRDAT>[F:JOT]DATENDVLY)
 Call AVERTIR(VALEUR-mess(92,701,1)-format$("DD2",[F:JOT]DATSTRVLY)-"-"-format$("DD2",[F:JOT]DATENDVLY),L_OK) From GESECRAN
 #### Période validité emploi type :
 If L_OK<>2
  mkstat = 2 : End
 Endif
Endif
Local File JOBTYPDEF [JOD]  : # Must be by default
Local Integer L_FORCE      : # 1 Force update else don't do anything
Local Char    CRITCTRL(GDIMFIC)
Local Char    VCLLCVT (GLONADI)
#Is something is calculated, we have to warn
L_OK = 1
#We ask only if there is something to do...
Filter [JOD] Where [JOD]COD=VALEUR
Read [JOD]JOD0 First
If fstat<4
 L_OK = 2
Endif
Filter [JOD]
#Even when Creating/Duplicating : #  & !find(GREP,"C","D")
If L_OK=2
 mkstat = 0
 Gosub CONTROLE
 If mkstat
  GMESSAGE = mess(95,701,1)
  ######## il existe des bulletins calculés pour ce contrat, voulez vous vraiment changer l'emploi type ?
  Call AVERTIR(GMESSAGE,L_OK) From GESECRAN
  GMESSAGE = ""
  If L_OK<>2 : End : Endif
  mkstat = 0
 Else
  L_OK = 1
 Endif
Endif
L_FORCE = 1
If func IS_INIT_CTR(VALEUR,2)
  Call OUINON(mess(90,701,1),L_OK) From GESECRAN
  #### Voulez-vous initialiser ce contrat par les données de l'emploi type ?
  If L_OK=2
   If GPAYE : VCLLCVT=[M:CTR1]CLLCVT :  Else : VCLLCVT="" : Endif
   Call INIT_CTR(VALEUR,2,[M:CTR0]ETRFCY,L_FORCE,VCLLCVT) From SUBCTR
   mkstat = 0
  Endif
Endif

  If func AFNC.ACTIV("FKSQS")
    If func DIVPAYE.EXISTE_KXX("SUBCTRKSA")
      Call AM_JOBPOT(VALEUR) From SUBCTRKSA
    Endif
  Endif

 If func ISKMIEA()
  If func DIVPAYE.EXISTE_KXX("SUBCTRMID") Then
    Call AM_JOBPOT(VALEUR) From SUBCTRMID
  Endif
Endif
End

Subprog B2_POT(VALEUR)
Variable Char    VALEUR()
Call AM_POT(VALEUR) From SUBCTR
End

Subprog B2_JOBPOT(VALEUR)
Variable Char    VALEUR()
Call AM_JOBPOT(VALEUR) From SUBCTR
End

Subprog B2_PROPRF(VALEUR)
Variable Char    VALEUR()
Call AM_PROPRF(VALEUR) From SUBCTR
End

#####################################################################################
Funprog IS_INIT_CTR(L_COD, L_TYP)
Value    Char    L_COD()      : # Code for POSTE or JOBTYP
Value    Integer L_TYP        : # 1 for POSTE, 2 for JOBTYP, 3 PROFIL
Local    Integer WOK
WOK = 0
Case L_TYP
 When 1 :
    Filter [POD] Where [F:POD]COD=L_COD
    If rowcount([F:POD]) > 0
      WOK = 1
    Endif
    Filter [POD]
 When 2 :
    Filter [JOD] Where [F:JOD]COD=L_COD
    If rowcount([F:JOD]) > 0
      WOK = 1
    Endif
    Filter [JOD]
 When 3 :
    Filter [PFD] Where [F:PFD]PRFCOD=L_COD
    If rowcount([F:PFD]) > 0
      WOK = 1
   Endif
   Filter [PFD]
Endcase
End WOK

########################################################
Subprog INIT_CTR(L_COD, L_TYP,L_FCY,L_FORCE,CLL_CVT)
Value    Char    L_COD()      : # Code for POSTE or JOBTYP
Value    Integer L_TYP        : # 1 for POSTE, 2 for JOBTYP, 3 PROFIL
Value    Char    L_FCY()      : #
Value    Integer L_FORCE      : # 1 Force update else don't do anything
Value    Char    CLL_CVT      : # Empty don't use, else Convention

If L_FCY<>[F:FCY]FCY
 Read [FCY]FCY0=L_FCY
 If fstat : Raz [F:FCY] : Endif
Endif

Local Char    L_POPUL(GLONPOP)(0..)
Local Integer L_NB_POPUL
Local Char    L_CRITERE(GDIMFIC)
Local Integer L_IJ
Local Char    ZONE(10)               : # For SET_ZONE
Local Char    L_CODFLD(type([F]FLD)-10)(0..)
Local Integer NB_COD
Local Integer NBGRP
Local Char    LIS_CPY(GLONCPY)(0..100)

Call CHARGE_POPUL([M:CTR0]REFNUM,L_POPUL,L_NB_POPUL) From SUBCTR2

If GTEST=1 & GTRACE=""
 Call OUVRE_TRACE(mess(6,485,1)-[M:CTR0]REFNUM-[M:CTR0]CTRNUM) From LECFIC
 #### Modifs contrat
 Call ECR_TRACE(string$(20,"*")-string$(L_TYP=1,"POSTE")-string$(L_TYP=2,"JOBTYP")
&              -string$(L_TYP=3,"PROFIL")-string$(20,"*"),0) From GESECRAN
Endif

Raz NB_COD, L_CODFLD

# Population
For L_IJ=0 To L_NB_POPUL-1
 If L_POPUL(L_IJ)<>""
  L_CRITERE = "[F]POP='"+L_POPUL(L_IJ)+"'"
  If GTRACE<>""
   Call ECR_TRACE(string$(50,"*"),0) From GESECRAN
   Call ECR_TRACE(L_CRITERE,0) From GESECRAN
  Endif
  Gosub CHARGE
 Endif
Next L_IJ

# Convention
If CLL_CVT<>""
 L_CRITERE = "[F]CLLCVT='"+CLL_CVT+"'"
 If GTRACE<>""
  Call ECR_TRACE(string$(50,"*"),0) From GESECRAN
  Call ECR_TRACE(L_CRITERE,0) From GESECRAN
 Endif
 Gosub CHARGE
Endif

# Facility
L_CRITERE = "[F]FCY='"+L_FCY+"'"
If GTRACE<>""
 Call ECR_TRACE(string$(50,"*"),0) From GESECRAN
 Call ECR_TRACE(L_CRITERE,0) From GESECRAN
Endif
Gosub CHARGE

# Company
[L]NBGRP=0
Call GRP_WITH_CPY_IN([F:FCY]LEGCPY,[F:FCY]FCY,[L]LIS_CPY,[L]NBGRP )
L_CRITERE = " find([F]CPY, [L]LIS_CPY(0..[L]NBGRP)) "
If GTRACE<>""
 Call ECR_TRACE(string$(50,"*"),0) From GESECRAN
 Call ECR_TRACE(L_CRITERE,0) From GESECRAN
Endif
Gosub CHARGE

If GPAYE
 L_CRITERE = "[F]CPY=''&[F]FCY=''&[F]CLLCVT=''&[F]POP=''"
Else
 L_CRITERE = "[F]CPY=''&[F]FCY=''&[F]POP=''"
Endif
If GTRACE<>""
 Call ECR_TRACE(string$(50,"*"),0) From GESECRAN
 Call ECR_TRACE(L_CRITERE,0) From GESECRAN
Endif
Gosub CHARGE

If GTEST=1
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End

########################################################
$CHARGE
Case L_TYP
 When 1 : Gosub POSTE_DEF
 When 2 : Gosub JOBTYP_DEF
 When 3 : Gosub PROFIL_DEF
Endcase
Return

########################################################
$POSTE_DEF
For [POD]POD0 Where [F:POD]COD=L_COD & evalue(L_CRITERE)
 Gosub EVAL_DEF
Next
Return

########################################################
$JOBTYP_DEF
For [JOD]JOD0 Where [F:JOD]COD=L_COD & evalue(L_CRITERE)
 Gosub EVAL_DEF
Next
Return

########################################################
$PROFIL_DEF
For [PFD]PFD0 Where [F:PFD]PRFCOD=L_COD & evalue(L_CRITERE)
 Gosub EVAL_DEF
Next
Return

########################################################
$EVAL_DEF
If [F]FLD="" | [F]VALINT="" : Return : Endif
Onerrgo ERREUR
ZONE = [F]FLD
Gosub SET_ZONE
If evalue("dim([M]"+[F]FLD+")")>0 & ( L_FORCE=1 | evalue("varinit([M]"+[F]FLD+")")=0 )
 If !find([F]FLD, L_CODFLD(0.. NB_COD-1))
  L_CODFLD(NB_COD) = [F]FLD
  NB_COD += 1
  # Small problem with numerical values....
  Case evalue("type([M]"+[F]FLD+")")
   When 1,2,4,5,6,7
        Assign "[M]"+[F]FLD With val([F]VALINT)
   When Default
        Assign "[M]"+[F]FLD With [F]VALINT
  Endcase
  Affzo =[F]FLD
  If GTRACE<>""
   Call ECR_TRACE([F]FLD-[F]TIT-"="-[F]VALINT,0) From GESECRAN
  Endif
 Endif
Endif
Onerrgo
Return

########################################################
$ERREUR
Resume

Subprog AM_TYPJOB(VALEUR)
Variable Integer VALEUR
If VALEUR=6 & [M]WRKSTG=2 : [M]WRKSTG=1 : Affzo [M]WRKSTG : Endif
  If func ISKZA() & func DIVPAYE.EXISTE_KXX("SUBCTRKSA") Then
    Call AM_TYPJOB(VALEUR) From SUBCTRKSA
  Endif

# 30/12/14 - Ajout champ NBRHOUCTR
If VALEUR=14 & [M]DNACODTIM=6 Then
  [M]NBRHOUCTR=0 : Affzo [M]NBRHOUCTR
  Actzo [M]NBRDAYCTR : Actzo [M]DNACODTIM
Endif
If VALEUR=16 & [M]DNACODTIM=5 Then
  [M]NBRDAYCTR=0 : Affzo [M]NBRDAYCTR
  Actzo [M]NBRHOUCTR : Actzo [M]DNACODTIM
Endif
End

Subprog C_WRKSTG(VALEUR)
Variable Integer VALEUR
If [M]TYPJOB=6 & VALEUR=2 :#Expatrié -> Travail Etranger = oui ou frontalier (2=Non)
 # Valeur incorrecte
 GMESSAGE=mess(1,702,1)
 mkstat=2 : End
Endif
End

######################################################################################
##BTP
######################################################################################
Subprog AS_DNACCP(VALEUR)
Variable Integer VALEUR
If !func AFNC.ACTIV("BTP")
 GMENLOC(1)=1
Endif
If !func AFNC.ACTIV("INTMT")
 GMENLOC(2)=1
Endif
End

Subprog AM_STAEMP(VALEUR)
Variable Integer  VALEUR
Gosub RET_EXTOURNE
If mkstat : End : Endif
End

Subprog AS_RETTYP(VALEUR)
Variable Integer VALEUR
[V]GMENLOC(2) = 1

If GINTMT &  [F:ID]FLGINT=2 : [V]GMENLOC(1) = 1 : Endif
End

Subprog APRES_NBRSAL
[M]FLGMOD(nolign-1) = 1
End

Subprog AS_WAGPAYPER(VALEUR)
Variable Integer  VALEUR
# Par défaut "mensuel" ...
If [L]VALEUR = 0 : [L]VALEUR = 6 : Endif
End

Subprog D_DNACODMOD(VALEUR)
Variable Integer VALEUR
Case [M:CTR1]TYPJOB
    When 1
        # Temps plein si TYPJOB = temps plein
        [L]VALEUR = 1
    When 2, 15
        # Temps partiel si TYPJOB = temps partiel, temps non complet
        [L]VALEUR = 2
    When 14
        # Forfait jour , cas particulier si le salarié est multi contrat
        If dim([F:ID]FLGMULCTR) > 0 & [F:ID]FLGMULCTR = 2
            [L]VALEUR = 2
        Else
            [L]VALEUR = 1
        Endif
    When Default
        # Salarié non concerné si TYPJOB = 3, 4, 5, .... ex : assistante maternelle, vacataire, occasionnel , etc.
        [L]VALEUR = 4
Endcase
End

Subprog C_DNACODMOD(VALEUR)
Variable Integer VALEUR
 Case [L]VALEUR
    When 1
        If [M:CTR1]TYPJOB = 2
            #Modalité de travail incompatible avec le type d'emploi
            GMESSAGE=mess(126,701,1)
            mkstat = 1 : End
        Endif
    When 2, 3
        If [M:CTR1]TYPJOB = 1
            #Modalité de travail incompatible avec le type d'emploi
            GMESSAGE=mess(126,701,1)
            mkstat = 1 : End
        Endif
 Endcase

 Call GRISE_TAUX_TP([M]TYPJOB,VALEUR) From SUBCTR2
 If VALEUR <> [M]DNACODMOD
  Call AM_RATMIDWRK([M]RATMIDWRK)
 Endif
 #
End

Subprog D_DNATYPMOD(VALEUR)
Variable Integer VALEUR
Case [M:CTR1]TYPJOB
    When 4,5
        # Intermittent & Domicile
        [L]VALEUR = [M:CTR1]TYPJOB-3
    When 9
        # Saisonnier
        [L]VALEUR = 3
    When 10
        #Vacataire
       [L]VALEUR = 4
    When 13
        # Occasionnel
        [L]VALEUR = 5
   When Default
        # non concerné
        [L]VALEUR = 6
Endcase
End

Subprog C_DNATYPMOD(VALEUR)
Variable Integer VALEUR


If  ([L]VALEUR=1 & [M:CTR1]TYPJOB<>4 ) | ([L]VALEUR=2 & [M:CTR1]TYPJOB<>5) | ([L]VALEUR=3 & [M:CTR1]TYPJOB<>9)
&  |([L]VALEUR=4 & [M:CTR1]TYPJOB<>10) | ([L]VALEUR=5 & [M:CTR1]TYPJOB<>13)
    #Modalité d'activité incompatible avec le type d'emploi

    If !func AFNC.ACTIV("KPO") and !func AFNC.ACTIV("KSA") Then
      GMESSAGE=mess(127,701,1)
      mkstat = 1 : End
    Endif
Endif
End

######################################################################################
Subprog GRP_WITH_CPY_IN(WCPY,WFCY, LIS_CPY_GRP, I)
Value Char WCPY()
Value Char WFCY()
Variable Char LIS_CPY_GRP()()
Variable Integer I
Local Integer DEP

If clalev([F:AGC])=0  : Local File AGRPCPY   [AGC] : Endif
If clalev([F:FGR])=0  : Local File FACGROUP  [FGR] : Endif

   [L]DEP=[L]I
   Raz [L]LIS_CPY_GRP
   [L]LIS_CPY_GRP([L]I)=[L]WCPY

   Filter [F:AGC] Where CPY=[L]WCPY and [F:AGC]GRP <> [L]WCPY
   For [F:AGC]AGC1
    If !find([F:AGC]GRP, [L]LIS_CPY_GRP([L]DEP..[L]I)) Then
      [L]I += 1
      [L]LIS_CPY_GRP([L]I)=[F:AGC]GRP

    Endif
   Next
   Filter [F:AGC]

   Filter [F:FGR] Where FCY=[L]WFCY and CPY <> [L]WCPY
   For [F:FGR]FGR1
    If !find([F:FGR]CPY, [L]LIS_CPY_GRP([L]DEP..[L]I)) Then
     [L]I += 1
     [L]LIS_CPY_GRP([L]I)=[F:FGR]CPY
    Endif
   Next
   Filter [F:FGR]
End

######################################################################################
## Ecran CTR10
##**92316 US2226 : We decided to desactivate the entry in the table for the casual workers
## so it's not necessary to control colomns for PRESTATION fields
#####################################################################################

#################################
Subprog C_FLD(VALEUR)
Variable Char    VALEUR()
If !clalev([F:DIC]) : Local File DICOEMP     [DIC] : Endif
Read [DIC]DIC0 = VALEUR
If fstat
 GMESSAGE = VALEUR - mess(41,100,1) : # Champ inexistant
 mkstat = 2 : End
Elsif [F:DIC]FLGRET<>2
 GMESSAGE = VALEUR - mess(106,702,1) : # Champ inactif
 mkstat = 2 : End
Elsif [F:DIC]ENAFLG=1
 GMESSAGE = VALEUR - mess(106,702,1) : # Champ inactif
 mkstat = 2 : End
Elsif [F:DIC]TBL<>"EMPLOCTR"
  GMESSAGE = mess(14,715,1) : # Seule la table EMPLOCTR est utilisable
  mkstat = 2 : End
Endif
If VALEUR<>[M]FLD(nolign-1)
 Call TEXTE([F:DIC]DES,[M]TIT(nolign-1)) From OBJDIV
 Gosub LOAD_DICO  From SUBCTRRET
Endif
End

#################################
Subprog S_FLD(VALEUR)
Variable Char    VALEUR()
If !clalev([F:DIC]) : Local File DICOEMP     [DIC] : Endif
If !GWEBSERV
 Filter [DIC] Where [DIC]TBL="EMPLOCTR" & [DIC]FLGRET=2
 ## Action SELOBJW
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJW"
 PARMSK(1) = "DIC"
 PARMSK(2) = ""
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
 GACTION = SAVACT
 Filter [DIC]
Endif
Gosub AFF From GSAISIE
End

#################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
If clalev([F:CTRW])=0 : Local File EMPLOCTR         [CTRW] : Endif
Read [F:CTRW]CTR0=[M:CTR0]REFNUM;[M:CTR0]CTRNUM;VALEUR
If fstat >2
 GMESSAGE=mess(26,701,1) #: Contrat inexistant
 mkstat=2 : End
Elsif [F:CTRW]XITDAT < [M:CTRA]RETDATEFF
 GMESSAGE=mess(25,702,1) #: Période incorrecte
 mkstat=2 : End
Endif
End

#################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
If clalev([F:CTRW])=0 : Local File EMPLOCTR         [CTRW] : Endif
Read [F:CTRW]CTR0=[M:CTR0]REFNUM;[M:CTR0]CTRNUM;VALEUR
If !fstat
 [M]ENDDAT(nolign-1)=[F:CTRW]XITDAT
Endif
End

#On propose la valeur d'origine
#################################
Subprog AV_VALORI(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : End : Endif

Local Integer PSNNUM

If func AFNC.ACTIV("HIC") > 0
 If !clalev([F:HIC])  : Local File HISTOCTX [HIC] : Endif
 #Si STRBUL<>ENDBUL, la valeur d'origine proposée sera celle de ENDBUL (tant pis !)
 Read [HIC]HIC1=1;"VEP";[M:CTRA]ENDBUL(nolign-1);[M:CTRA]TBL(nolign-1);[M:CTRA]FLD(nolign-1)
 If !fstat & [F:HIC]HICVAL<>num$(evalue('[F:CTR]'+[F:HIC]HICATZ))
  VALEUR=[F:HIC]HICVAL
  [M:CTRA]VALINTORI(nolign-1)=[F:HIC]HICVAL
 Endif
Endif
#Si la valeur d'origine n'existe pas dans [F:HIC] car trop ancienne, alors on cherche quand même dans [F:CTR]
If VALEUR=""
 Call VALRCR([M:CTR0]REFNUM,[M:CTR0]CTRNUM,[M:CTRA]STRDAT(nolign-1),[M:CTRA]TBL(nolign-1),[M:CTRA]FLD(nolign-1),[M:CTRA]NOLIB(nolign-1),[L]PSNNUM,VALEUR,[M:CTRA]VALINTORI(nolign-1)) From SUBCTRRET
Endif
End

#On propose toujours la valeur courante (avenant)
#################################
Subprog AS_VALDEN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : End : Endif

Local Integer PSNNUM
Call VALRCR([M:CTR0]REFNUM,[M:CTR0]CTRNUM,[M:CTR0]CTRDAT,[M:CTRA]TBL(nolign-1),[M:CTRA]FLD(nolign-1),[M:CTRA]NOLIB(nolign-1),[L]PSNNUM,VALEUR,[M:CTRA]VALINTDEN(nolign-1)) From SUBCTRRET
End

#################################
Subprog C_VALDEN(VALEUR)
Variable Char    VALEUR()
Local Integer  L_NOL
L_NOL = nolign - 1
If [M:CTRA]CODTYP(L_NOL)="ADI"
 Call CONTSEL("ADI","!",VALEUR,[M:CTRA]VALPAR(L_NOL),mkstat) From CONTOBJ
 If mkstat : End : Endif
Elsif [M:CTRA]CODOBJ(L_NOL)<>"" & !find([M:CTRA]CODOBJ(L_NOL),"PLN")
 Call CONTSEL([M:CTRA]CODOBJ(L_NOL),"",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : End : Endif
Elsif [M:CTRA]CODTYP(L_NOL)<>"" & !find([M:CTRA]CODTYP(L_NOL),"PLN")
 Call CONTSEL([M:CTRA]CODTYP(L_NOL),"",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : End : Endif
Endif
End

