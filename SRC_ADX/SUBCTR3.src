  If dim([M:CTR5]FLGTIMREF)>=0 & VALEUR=4
    [M:CTR5]FLGTIMREF=2 : Affzo [M:CTR5]FLGTIMREF
  Endif
End

Subprog AM_DNACODTIM(VALEUR)
Variable Integer VALEUR
If dim([M:CTR5]FLGTIMREF)>=0 & VALEUR=10
 [M:CTR5]FLGTIMREF=2 : Affzo [M:CTR5]FLGTIMREF
Endif

If [F:ID]FLGINT=2 & VALEUR<>3 & VALEUR<>7 & VALEUR<>8
 [M:CTR3]TYPCAC=3
 Affzo [M:CTR3]TYPCAC
Endif
#
If VALEUR=6 & [M]NBRHOUCTR=0 Then
 zonsui="[M]NBRHOUCTR"
Endif
End

Subprog AS_TYPCAC(VALEUR)
Variable Integer VALEUR
If dim([M:CTR1]DNACODTIM)>0
 If [F:ID]FLGINT=2 & [M:CTR1]DNACODTIM<>3 & [M:CTR1]DNACODTIM<>7 & [M:CTR1]DNACODTIM<>8
  GMENLOC(1)=1
  GMENLOC(2)=1
 Endif
Endif
End

Subprog CALL_INIML1
Local Integer I
For I=0 To 9
  If evalue("clalev([M:CTR"+num$(I)+"])")>0
    Call INI_ML1("CTR"+num$(I)) From DIVPAYE
  Endif
Next I
End

