###########################################
$FERME
# [F:ID]REFNUM lost after tunnel on JOB Type , standard job
If dim([M:CTR0]REFNUM)>0 : Read [F:ID]ID0=[M:CTR0]REFNUM : Endif
Return

################################################################################################################
##                                                 Grisages / dégrisages
################################################################################################################

########################################################
Subprog GRISE_GRDCDD (VALEUR)
Value Char VALEUR ()
Call GRISE_GRDCDD (VALEUR) From SUBCTR2
End

########################################################
Subprog GRISE_ACOMPTE(VALEUR)
Value Decimal VALEUR
Call GRISE_ACOMPTE(VALEUR) From SUBCTR2

End

########################################################
Subprog GRISE_EXO(VAL1,VAL2,VAL3,VAL4)
Value Char VAL1, VAL2, VAL3, VAL4
Call GRISE_EXO(VAL1,VAL2,VAL3,VAL4) From SUBCTR2
End
########################################################
Subprog GRISE_RAZCUM(VALEUR)
Value Char VALEUR
Call GRISE_RAZCUM(VALEUR) From SUBCTR2

End

########################################################
Subprog GRISE_WRKADD(VALEUR)
Value Integer VALEUR
Call GRISE_WRKADD(VALEUR) From SUBCTR2

End

########################################################
Subprog GRISE_LNK (VALEUR)
Value Integer VALEUR
Call GRISE_LNK (VALEUR) From SUBCTR2

End

########################################################
Subprog GRISE_SEVCTR(VALEUR)
Value Integer VALEUR
Call GRISE_SEVCTR(VALEUR) From SUBCTR2

End

########################################################
$VERIF_CRE
$VERIF_MOD
If GINTMT=1 & [F:ID]FLGINT=2 & [M:CTR3]STACTR=2
 If [M:CTR3]NBRPSN=0
  # Un contrat validé d'un intermittent doit contenir au moins une prestation
  GMESSAGE = mess(38,701,1)
  OK = 0 : Return
 Endif
Endif
If GINTMT=1 & [F:ID]FLGINT=2 & [M:CTR0]CTRNUM<>""
 ## Add filter about FLGRET
 Filter [CTR1] Where CTRNUM=[M:CTR0]CTRNUM & (REFNUM<>[M:CTR0]REFNUM | CTRDAT<>[M:CTR0]CTRDAT) & FLGRET=[M:CTR0]FLGRET
 Read [CTR1]CTR0 First
 Filter [CTR1]
 If !fstat
  # Chaque contrat d'un intermittent doit avoir un numéro de dossier unique
  GMESSAGE = mess(70,701,1)
  OK = 0 : Return
 Endif
Endif

Gosub CONTROLE_STATUT
If OK=0 : Return : Endif
Gosub CONTROLE_PREAVIS
If OK=0 : Return : Endif

If dim([M:CTR9]FLGCTRCPT) > 0 & [M:CTR9]FLGCTRCPT = 2
  If [M:CTR9]ACCCOD = ""
    # mess(179,105,1) : Code comptable non défini
    GMESSAGE = mess(179, 105, 1)
    [L]OK = 0
    zonsui = "[M:CTR9]ACCCOD"
    Return
  Endif
  If [M:CTR9]DSP <> ""
#    # If DSP non authorized for the site, RAZ DSP
    Call CTRL_DSP([M:CTR9]DSP,[M:CTR0]ETRFCY,[M:CTR0]CTRDAT) From TRTHRCPT
    If mkstat
       [L]OK = 0
       zonsui = "[M:CTR9]DSP"
       Return
   Endif
 Endif
Endif

If dim([M:CTR9]CCE) > 0 & [M:CTR9]FLGCTRCPT = 2
Local Integer I, WMKSTAT
    For I=0 To dim([M:CTR9]CCE)-1
      If [M:CTR9]CCE(I)<>""
        ## Action CNTCCE
        WMKSTAT=mkstat
        Call SECTION([M:CTR9]CCE(I),2,[M:CTR0]ETRFCY,[0/0/0],[M]DIE(I)) From SUPCPT
        If mkstat
          GMESSAGE=mess(17,103,1)-GMESSAGE
          [L]OK = 0
          zonsui = "[M:CTR9]CEE"
          Break
        Endif
      Endif
    Next
    Return
Endif

If GREP<>"M"
 Filter [F:CTR1] Where REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM
 Read [F:CTR1]CTR1 Last
 Filter [F:CTR1]
 If !fstat & [F:CTR1]XITFNL=2
  VOK=1
  #Voulez-vous réinitialiser les fiches congés de ce salarié pour ce contrat ?
  Call OUINON (mess(82,701,1), VOK) From GESECRAN
  If VOK=2
   Gosub SUPPR_CNE
   If !GOK
    #"Opération impossible : pb d'ecriture sur la table CNGEMP"
    GMESSAGE = mess(157,123,1)-":"-mess(13,100,1)-"CNGEMP"
    Return
   Endif
  Endif
 Endif
 Gosub CONTROLE_TIP3
 If mkstat : Return : Endif
 GRETTIP=1
Endif

Call CALL_INIML1

If dim([M:CTRB]NBRPEN)>0 & dim([M:CTRB]FLGEXCPEN)> 0 & [M:CTRB]FLGEXCPEN=2 & [M:CTRB]NBRPEN>0
 Local Integer FLGPEN
 FLGPEN=0
 For I=0 To dim([M:CTRB]PEN)-1
  If [M]CTRDAT>[M:CTRB]ENDDATPEN(I) & [M:CTRB]ENDDATPEN(I)<>[0/0/0]
   FLGPEN+=1
   Break
  Endif
  If [M]XITDAT<>[0/0/0] & [M]XITDAT<[M:CTRB]STRDATPEN(I)
   FLGPEN+=1
   Break
  Endif
 Next
 If FLGPEN
  Call AVERTIR (mess(21,724,1), [L]VOK) From GESECRAN :#Veuillez contrôler la cohérence des dates des facteurs de pénibilité
  If [L]VOK = 1
   OK=0 : Return
  Endif
 Endif
Endif

If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) Then
  Gosub MOD_FNLXITDAT From SUBCTR2
Endif

Return

########################################################
$SUPPR_CNE
#JASMI - 2016-02-15 - Issue 114547 - START
#Filter [F:CNG] Where CPY=[M:CTR0]CPY & ((STRPER>=[F:CTR1]CTRDAT & STRPER<=[F:CTR1]XITDAT) | (ENDPER>=[F:CTR1]CTRDAT & ENDPER<=[F:CTR1]XITDAT))
#
#If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
#  Filter [F:CNE] Where REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM
#&                   & ((EMPLEASTR>=[F:CTR1]CTRDAT & EMPLEASTR<=[F:CTR1]XITDAT) | (EMPLEAEND>=[F:CTR1]CTRDAT & EMPLEAEND<=[F:CTR1]XITDAT))
# Read [F:CNE]CNE0 Last
# Filter [F:CNE]
# If !fstat
#   Filter [F:CNG] Where CPY=[M:CTR0]CPY & YEA=[F:CNE]YEA
# Endif
#Endif
#
#For [F:CNG]CNG0
# Filter [F:CNE] Where  YEA=[F:CNG]YEA & REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM
# For [F:CNE]CNE0
#  [F:CNE]NBRDAY=0
#  [F:CNE]NBRPRI=0
#  Rewrite [F:CNE]
#  If fstat
#   GOK=0 : Call FSTA("CNE") From GLOCK : Break 2
#  Endif
# Next
# Filter [F:CNE]
#Next
#Filter [F:CNG]
Gosub SUPPR_CNE From SUBCTR2
#JASMI - 2016-02-15 - Issue 114547 - END
Return

########################################################
$INICRE
If [F:ID]FLGINT<>2
 Local Integer WOK
 WOK=1
 Call CONTROLE_ENT_CTRGRD([M:CTR0]CTRGRD,1,WOK)
 If !WOK : GERR=1 : GOK=0 : Endif
Endif
If [M:CTR0]CTRNUM=""
 Read [TCA]TCA0 = 9
 COMPTEUR = [F:TCA]CODNUM(2)
 If COMPTEUR=""
  GMESSAGE = mess(39,701,1) : # Compteur contrat non défini
  GOK = 0 : Return
 Endif
 Call NUMERO(COMPTEUR,[M:CTR0]ETRFCY,[M:CTR0]CTRDAT,[M:CTR0]NATCON,[M:CTR0]CTRNUM,STAT) From SUBANM
 If STAT
  GMESSAGE = mess(4,702,1)-COMPTEUR : # "Erreur sur compteur"
  GOK = 0 : Return
 Endif
 [F:CTR]CTRNUM = [M:CTR0]CTRNUM
 Affzo [CTR0]CTRNUM
Endif

If [M]REFNUM<>[F:ID]REFNUM
 Read [ID]ID0=[M]REFNUM
 If fstat : Return : Endif
Endif
If [F:ID]FLGINT<>2
 [F:CTR]CALPAY = 1                   : # Par contrat
 [F:CTR]STACTR = 2                   : # Validé
Elsif [F:ID]FLGINT=2 & GINTMT=1 & [M:CTR3]STACTR=2
 [F:CTR]XITDAT = max([M:CTR3]PSNENDDAT)
 [F:CTR]XITGRD = "FDC"

 [M:CTR0]XITDAT=[F:CTR]XITDAT : Affzo [M:CTR0]XITDAT
 [M:CTR8]XITDAT=[F:CTR]XITDAT : [M:CTR8]XITGRD=[F:CTR]XITGRD : Affzo [M:CTR8]5

Endif
If [F:CTR]FLGVAR=0 : [F:CTR]FLGVAR=1 : Endif
Gosub SAUVE_EVT

# V01X08 - Délégation maladie disparaît (public seulement), on force la valeur trois si vide
#          pour éviter un effet de bord malencontreux.
If dim([M]DEGMAL) > 0 & [M]DEGMAL = 0
 [M]DEGMAL = 3
Endif

If GPAYE
 Gosub SAVE_RETROCTR From SUBCTRRET
 #If the field doesn't exist in screens or if it's null (security)
 #-----> We have to assign it in the file
 Local Char ZONE(10) : ZONE = "FLGCREBUL"
 Gosub SET_ZONE
 If !MA  or [M]FLGCREBUL=0
   Local Integer TEMPO
   #Manage the box 'Break payslip' (2 = Assign only)
   [L]TEMPO=[F:CTR]FLGCREBUL
   Call UPD_FLGCREBUL(TEMPO, 2) From SUBCTR2
   [F:CTR]FLGCREBUL=[L]TEMPO
 Endif
Endif
Return

########################################################
$INIMOD
If [F:ID]FLGINT<>2 & [M:CTR0]FLGVAR<>2
 Local Integer WOK
 WOK=1
 Call CONTROLE_ENT_CTRGRD([M:CTR0]CTRGRD,1,WOK) #bug 91300 Suite 85360
 If !WOK : GERR=1 : GOK=0 : Endif
Endif

If [M:CTR0]FLGRET<>2
 If GINTMT=1 & [F:ID]FLGINT=2 & [M:CTR3]STACTR=2
  If max([M:CTR3]PSNENDDAT)<[F:CTR]CTRDAT
   # La date du contrat est postérieure aux dates des prestations
   GOK=0 : GMESSAGE = mess(56,701,1)
  Else
   [F:CTR]XITDAT = max([M:CTR3]PSNENDDAT)
   [F:CTR]XITGRD = "FDC"
  Endif
 Endif
Endif
If [F:CTR]FLGVAR=0 : [F:CTR]FLGVAR=1 : Endif
Gosub SAUVE_EVT

# V01X08 - Délégation maladie disparaît (public seulement), on force la valeur trois si vide
#          pour éviter un effet de bord malencontreux.
If dim([M]DEGMAL) > 0 & [M]DEGMAL = 0
    [M]DEGMAL = 3
Endif

If GPAYE
 Gosub SAVE_RETROCTR From SUBCTRRET
Endif
Return

########################################################
$SAUVE_EVT
If dim([F:CTR]CCP)>0 & [F:CTR]CCP=0 : [F:CTR]CCP = 1 : Endif
Raz [F:CTR]EVECTRCOD
Raz [F:CTR]EVECTRCOD
For nolign=1 To [M:CTR4]NBRDP1
 [F:CTR]EVECTRCOD(nolign-1)=[M:CTR4]EVECTRCOD(nolign-1)
 [F:CTR]EVECTRDAT(nolign-1)=[M:CTR4]EVECTRDAT(nolign-1)
Next
Return

########################################################
$RAZCRE
If GINTMT=1 & [F:ID]FLGINT<>2
 Grizo [CTR3]
 Affzo [CTR3]
Endif
Call GRISE_CALPAY([F:ID]FLGINT) From SUBCTR2
Call GRISE_FLGPAY([F:ID]FLGPAY) From SUBCTR2
Call INI_GRDEXUDSN([F:ID]FLGPAY) From SUBCTR2 :#105476 - US3421
[M:CTR0]FLGVAR=1
Gosub RAZRETRO
[M:CTR4]WRKFLGADD=2
Call GRISE_WRKADD([M:CTR4]WRKFLGADD)
If [F:ID]FLGMULCTR=2 : [M:CTR2]SEVCTR = 2 : Endif
Gosub CHARGE_BULDEM

Gosub STYLE


For nolign=1 To len(mess(0,50,1))
 [M:CTR6]RESPO(nolign-1)=nolign
Next
[M:CTR6]NBRCHEF=nolign
Affzo [M:CTR6]

If func AFNC.ACTIV("KFR") > 0
  Call GRISE_PEN("FLGEXCPEN") From SUBCTRKFR
Endif
Return

########################################################
$RAZDUP
If GINTMT=1
  If [F:ID]FLGINT<>2
    Grizo [CTR3]
  Else
    Effzo [M:CTR3]AEMNUM
    Effzo [M:CTR3]30
  Endif
Endif

If dim([M:CTR1]FLGDUE)>0 Then
  Effzo [M:CTR1]FLGDUE
Endif
[M:CTR0]FLGVAR=1
Gosub RAZRETRO
Call INI_GRDEXUDSN([F:ID]FLGPAY) From SUBCTR2
Return

########################################################
$RAZRETRO
If GPAYE
 Raz [M:CTR0]RETDATEFF
 [M:CTR0]FLGRET=1
 Affzo [M:CTR0]
 Effzo [M:CTRA] : Grizo [M:CTRA]
Endif
Return

########################################################
$CREATION
If GINTMT=1
 Raz [F:PSN]
 [F:PSN]CREDAT = date$
 [F:PSN]CREUSR = GUSER
 [F:PSN]CRETIM = time
 Gosub CRE_PSN
 If [V]GOK<1 : Return : Endif
Endif
Gosub MAJ_EMPLOID
If [V]GOK<1 : Return : Endif
Gosub MAJ_EMPLOELC
If [V]GOK<1 : Return : Endif
Gosub MAJ_EMPLOCTRCPT
If [V]GOK<1 : Return : Endif
Gosub MAJ_EMPLOPOT
If [V]GOK<1 : Return : Endif
Gosub MAJ_TRAINER
If [V]GOK<1 : Return : Endif
Gosub MAJ_ESB
If [V]GOK<0 : Return : Endif

Return

########################################################
$MODIF
If GINTMT=1
 ## Add filter on CTRDAT
 Delete [PSN] Where CTRNUM=[M:CTR0]CTRNUM & CTRDAT=[M:CTR0]CTRDAT
 If fstat=1 | fstat>5
  GOK=0 : Call RSTA("PSN",[M:CTR0]CTRNUM-num$([M:CTR0]CTRDAT)) From GLOCK : Return
 Endif
 Raz [F:PSN]
 [F:PSN]UPDDAT = date$
 [F:PSN]UPDUSR = GUSER
 [F:PSN]UPDTIM = time
 Gosub CRE_PSN
 If [V]GOK<1 : Return : Endif
Endif
Gosub MAJ_EMPLOID
If [V]GOK<1 : Return : Endif
Gosub MAJ_EMPLOELC
If [V]GOK<1 : Return : Endif
Gosub MAJ_EMPLOCTRCPT
If [V]GOK<1 : Return : Endif
Gosub MAJ_EMPLOPOT
If [V]GOK<1 : Return : Endif
Gosub MAJ_TRAINER
If [V]GOK<1 : Return : Endif
If GPAYE
 Gosub MAJ_EMPLOSAL
 If [V]GOK<1 : Return : Endif
Endif
Gosub MAJ_ESB
If [V]GOK<0 : Return : Endif

Return

########################################################
$CRE_PSN
[F:PSN]CTRNUM    = [M:CTR0]CTRNUM
[F:PSN]REFNUM    = [M:CTR0]REFNUM
[F:PSN]CTRDAT    = [M:CTR0]CTRDAT
For nolign=1 To [M]NBRPSN
 [F:PSN]       = [M:CTR3]
 [F:PSN]PSNNUM = nolign
 Write [PSN]
 If fstat
  GOK=0 : Call FSTA("PSN") From GLOCK : Break
 Endif
Next
If GOK=0 : Return : Endif
Return

########################################################
$MAJ_EMPLOID
If [M:CTR0]FLGVAR=2 : Return : Endif
Readlock [ID]ID0=[M:CTR0]REFNUM
If fstat=1
 GOK=-1 : GLOCK="$EMPLOID"-[M:CTR0]REFNUM
 Return
Elsif fstat
 GOK=0 : Call FSTA("ID") From GLOCK
 Return
Endif
Filter [CTR1] Where REFNUM=[M:CTR0]REFNUM
[F:ID]NBRCTR = rowcount([CTR1])
Read [CTR1]CTR1 Last
Filter [CTR1]

If func DIVPAYE.EXISTE_KXX("SUBCTRKPO") Then
  Gosub MAJ_EMPLOID From SUBCTRKPO
Endif

[F:ID]FCY      = [F:CTR1]ETRFCY
[F:ID]SRV      = [F:CTR1]ETRSRV
[F:ID]PRF      = [F:CTR1]PROPRF
Read [FCY]FCY0=[F:CTR1]ETRFCY
[F:ID]CPY      = [F:FCY]LEGCPY
Rewrite [F:ID]
If fstat
 GOK=0 : Call FSTA("ID") From GLOCK : Return
Endif
Return

########################################################
$MAJ_TIMEMP2
Local Date MCTRDA
Local Integer WINIT, WINIT_ANA
WINIT=0 : WINIT_ANA=0
CRITCTRL="1=1"
If WACTION="AP_ANNULE" or WACTION="APRES_CRE" or WACTION="APRES_MOD"
  CRITCTRL="REFNUM='"+W_TIP_REFNUM+"'"
  CRITCTRL += "& CTRNUM='"+W_TIP_CTRNUM+"'"
  If W_TIP_CTRDAT<>[0/0/0]
   CRITCTRL-="& (CTRDAT=[0/0/0] | CTRDAT=["+num$(W_TIP_CTRDAT)+"])"
   CRITCTRL-="& DATPYR>=["+num$(W_TIP_CTRDAT)+"]"
  Endif
  If W_TIP_XITDAT<>[0/0/0]
   CRITCTRL-="& ENDDAT<=["+num$(W_TIP_XITDAT)+"]"
  Endif
Endif

Local Char    W_TIP_CPY(GLONCPY)
GMESSAGE=""
If WACTION<>"APRES_MOD" Then
  W_TIP_ETRFCY=[F:CTR1]ETRFCY
  W_TIP_ETRSRV=[F:CTR1]ETRSRV
Endif
If WACTION="APRES_MOD"
  If clalev([F:DSP])=0 : Local File CADSP [DSP] : Endif
  For [TIP]TIP2 Where evalue(CRITCTRL)
    Gosub MAJ_TPS
   If fstat
    GOK=0 : Call FSTA("TIP") From GLOCK : Break
   Endif
  Next
Else
  For [TIP]TIP2 Where REFNUM=[F:CTR1]REFNUM & CTRNUM=[F:CTR1]CTRNUM &
& (STRDAT>=[F:CTR1]CTRDAT or (WACTION="AP_ANNULE" or WACTION="APRES_CRE" & evalue(CRITCTRL)))
    Gosub MAJ_TPS
   If fstat
    GOK=0 : Call FSTA("TIP") From GLOCK : Break
   Endif
  Next
Endif
Return

$MAJ_TPS
Local Char    ACMCUR_OLD(GLONGCM), ACMCUR_NEW(GLONGCM)

  Call SETGCM([F:TIP]FCY,ACMCUR_OLD) From CPTDIV : # Récupération du modèle de l'ancienne société
  [F:TIP]FCY=W_TIP_ETRFCY
  [F:TIP]SRV=W_TIP_ETRSRV
  W_TIP_CPY=func DIVPAYE.GETSOC([F:TIP]FCY)
  If [F:TIP]CPY<>W_TIP_CPY Then
    [F:TIP]CPY=W_TIP_CPY
    If GOPTCANA Then
      Call SETGCM([F:TIP]FCY,ACMCUR_NEW) From CPTDIV
      If ACMCUR_NEW<>ACMCUR_OLD Then
        Gosub MAJ_ANA From SUBCTR2
        If !WINIT_ANA & !GSERVEUR & !GIMPORT
          GERR=2
          GMESSAGE=mess(165,701,1) : # Les données analytiques des événements temps ont été recalculées.
          WINIT_ANA=1
        Endif
      Endif
    Endif
  Endif

  MCTRDA=func TPSSTD.CALC_CTRDATDEF(W_TIP_REFNUM,W_TIP_CTRNUM,[F:TIP]ENDDAT,[F:TIP]DATPYR,[F:TIP]ENDDAT,1)
  If  MCTRDA <> [F:TIP]CTRDAT Then
    [F:TIP]CTRDAT=MCTRDA
    #Les périodes d'activités du contrat ont été affectées aux évènements temps.
    If !WINIT & !GSERVEUR & !GIMPORT
      GERR=2
      If GMESSAGE<>"" Then
        GMESSAGE += chr$(10)+chr$(13)
      Endif
      GMESSAGE+=mess(141,701,1)
      WINIT=1
    Endif
  Endif
  Rewrite [F:TIP]
Return

########################################################
$MAJ_ESB
Local  Integer L_K
If !clalev([F:SRV]) : Local File SERVICE [SRV] : Endif
If !clalev([F:SIT]) : Local File SITEPAYE [SIT] : Endif
If !clalev([F:WAD]) : Local File EMPLOAD [WAD] : Endif
If ACTION="ANNULE"
  Delete [ESB] Where [F:ESB]REFNUM=[M:CTR0]REFNUM & [F:ESB]CTRNUM=[M:CTR0]CTRNUM &  [F:ESB]CTRDAT=[M:CTR0]CTRDAT
  If fstat=1
   GOK = -1 : GLOCK = "$EMPSBD"-[M:CTR0]REFNUM-[M:CTR0]CTRNUM-[M:CTR0]CTRDAT-num$(1)-num$([F:ESB]RANG)
   Return
  Endif
  Return
Endif
Filter [F:ESB] Where [F:ESB]REFNUM=[M:CTR0]REFNUM & [F:ESB]CTRNUM=""
If rowcount([F:ESB])>0 Then
   Filter [F:ESB]
   Delete [F:ESB] Where [F:ESB]REFNUM=[M:CTR0]REFNUM & [F:ESB]CTRNUM=""
   If fstat=1
     GOK = -1 : GLOCK = "$EMPSBD"-[M:CTR0]REFNUM-[M:CTR0]CTRNUM-[M:CTR0]CTRDAT-num$([F:ESB]NIVEAU)-num$([F:ESB]RANG)
     Return
   Endif
   Read [F:WAD] AD0=[M:CTR0]REFNUM
   If !fstat
    For L_K=0 To len(mess(0,50,1))
      If [F:WAD]CHEF(L_K)<> ""
         Raz [F:ESB]
         [F:ESB]CHEF=[F:WAD]CHEF(L_K)
         [F:ESB]NIVEAU=2
         [F:ESB]RANG=L_K+1
         Gosub WRITE_ESB
         If !GOK : Break : Endif
      Endif
    Next L_K
   Endif
Endif
Filter [F:ESB]

Delete [ESB] Where [F:ESB]REFNUM=[M:CTR0]REFNUM & [F:ESB]CTRNUM=[M:CTR0]CTRNUM &  [F:ESB]CTRDAT=[M:CTR0]CTRDAT  & [F:ESB]NIVEAU=1
If fstat=1
 GOK = -1 : GLOCK = "$EMPSBD"-[M:CTR0]REFNUM-[M:CTR0]CTRNUM-[M:CTR0]CTRDAT-num$(1)-num$([F:ESB]RANG)
 Return
Endif
For L_K=0 To len(mess(0,50,1))
  If [M:CTR6]CHEFCTR(L_K)<> ""
     Raz [F:ESB]
     [F:ESB]CHEF=[M:CTR6]CHEFCTR(L_K)
     [F:ESB]NIVEAU=1
     [F:ESB]RANG=L_K+1
     Gosub WRITE_ESB
     If !GOK : Break : Endif
  Endif
Next L_K
Delete [ESB] Where [F:ESB]REFNUM=[M:CTR0]REFNUM & [F:ESB]CTRNUM=[M:CTR0]CTRNUM &  [F:ESB]CTRDAT=[M:CTR0]CTRDAT  & [F:ESB]NIVEAU=3
If fstat=1
 GOK = -1 : GLOCK = "$EMPSBD"-[M:CTR0]REFNUM-[M:CTR0]CTRNUM-[M:CTR0]CTRDAT-num$(3)-num$([F:ESB]RANG)
 Return
Endif
Read [F:SRV] SRV0=[M:CTR1]ETRSRV
If !fstat
  For L_K=0 To len(mess(0,50,1))
    If [F:SRV]CHEF(L_K)<> ""
       Raz [F:ESB]
       [F:ESB]CHEF=[F:SRV]CHEF(L_K)
       [F:ESB]SRV=[F:SRV]COD
       [F:ESB]NIVEAU=3
       [F:ESB]RANG=L_K+1
       Gosub WRITE_ESB
       If !GOK : Break : Endif
    Endif
  Next L_K
Endif

Delete [ESB] Where [F:ESB]REFNUM=[M:CTR0]REFNUM & [F:ESB]CTRNUM=[M:CTR0]CTRNUM &  [F:ESB]CTRDAT=[M:CTR0]CTRDAT  & [F:ESB]NIVEAU=4
If fstat=1
 GOK = -1 : GLOCK = "$EMPSBD"-[M:CTR0]REFNUM-[M:CTR0]CTRNUM-[M:CTR0]CTRDAT-num$(4)-num$([F:ESB]RANG)
 Return
Endif
Read [F:SIT]SIT0=[M:CTR0]ETRFCY
If !fstat
  For L_K=0 To len(mess(0,50,1))
    If [F:SIT]CHEF(L_K)<> ""
       Raz [F:ESB]
       [F:ESB]CHEF=[F:SIT]CHEF(L_K)
       [F:ESB]FCY=[F:SIT]FCY
       [F:ESB]NIVEAU=4
       [F:ESB]RANG=L_K+1
       Gosub WRITE_ESB
       If !GOK : Break : Endif
    Endif
  Next L_K
Endif
Return

########################################################
$WRITE_ESB
[F:ESB]CTRNUM=[M:CTR0]CTRNUM
[F:ESB]REFNUM=[M:CTR0]REFNUM
[F:ESB]CTRDAT=[M:CTR0]CTRDAT
If dim([F:ESB]CREDAT)>0 : [F:ESB]CREDAT = date$     : Endif
If dim([F:ESB]CRETIM)>0 : [F:ESB]CRETIM = time      : Endif
If dim([F:ESB]CREUSR)>0 : [F:ESB]CREUSR = GUSER     : Endif
Write [F:ESB]
If fstat
 GOK = 0 : Call FSTA("ESB") From GLOCK : Return
Endif
Return

############################################
$MAJ_EMPLOELC
If [M]MAIFCY<2 : Return : Endif

If [M:CTR0]FLGVAR=2 : Return : Endif

Look [ELC]ELC0=[F:CTR]REFNUM;[F:CTR]ETRFCY
If !fstat : Return : Endif

Link [ELC] With [FCY]FCY0=RPEFCY
&            As [LNK]
&         Where REFNUM=[F:CTR]REFNUM & [FCY]LEGCPY=func DIVPAYE.GETSOC([F:CTR]ETRFCY)
Read [LNK] First
If !fstat
 Readlock [ELC] Curr
 If fstat
  [V]GOK  =-1
  [V]GLOCK="$EMPLOELC"-[F:ELC]REFNUM-[F:ELC]RPEFCY
  Return
 Endif

 [F:ELC]RPEFCY=[F:CTR]ETRFCY
 [F:ELC]UPDUSR=[V]GUSER
 [F:ELC]UPDDAT=date$
 [F:ELC]UPDTIM=time

 Rewrite [ELC] Curr
 If fstat
  [V]GOK=0
  Call FSTA("ELC") From GLOCK
  Return
 Endif

Else
 Raz [F:ELC]
 [F:ELC]REFNUM=[F:CTR]REFNUM
 [F:ELC]RPEFCY=[F:CTR]ETRFCY
 [F:ELC]CREUSR=[V]GUSER
 [F:ELC]CREDAT=date$
 [F:ELC]CRETIM=time
 Write [ELC]
 If fstat
  [V]GOK=0
  Call FSTA("ELC") From GLOCK
  Return
 Endif
Endif
Return

########################################################
$MAJ_EMPLOCTRCPT
Delete [F:CPR] Where [F:CPR]REFNUM = [M:CTR0]REFNUM
&                & [F:CPR]CTRNUM = [M:CTR0]CTRNUM
&                & [F:CPR]CTRDAT = [M:CTR0]CTRDAT
If fstat <> 0
    [V]GOK = 0
    Call FSTA("CPR") From GLOCK
    Return
Endif
If [M:CTR9]FLGCTRCPT = 2 & GREP <> "A"
    Raz [F:CPR]
    [F:CPR] = [M:CTR0]
    [F:CPR] = [M:CTR9]
    Write [F:CPR]
    If fstat <> 0
        [V]GOK = 0
        Call FSTA("CPR") From GLOCK
        Return
    Endif
Endif
Return

########################################################
$MAJ_EMPLOPOT
If [M:CTR0]FLGVAR=2 : Return : Endif

Delete [EPO] Where [F:EPO]REFNUM=[M:CTR0]REFNUM
&                & [F:EPO]CTRNUM=[M:CTR0]CTRNUM
&                & [F:EPO]DATPOT=[M:CTR0]CTRDAT
&                & [F:EPO]ORIGINE=1
If fstat=1
 GOK = -1 : GLOCK = "$EMPLOPOT"-[M:CTR0]REFNUM+"\"+[M:CTR0]CTRNUM+"\"+[M:CTR0]CTRDAT+"\1" : Return
Endif
If [M:CTR1]SUICAR = 2 & GREP <> "A"
  Raz [F:EPO]
  [F:EPO] = [M:CTR1]
  [F:EPO] = [M:CTR0]
  [F:EPO]DATPOT  = [M:CTR0]CTRDAT
  [F:EPO]ORIGINE = 1 : # ML 399 Automatique
  Write [EPO]
  If fstat
   GOK = 0 : Call FSTA("EPO") From GLOCK : Return
  Endif
Endif
Return

########################################################
$MAJ_POPUL
If ACTION="AP_ANNULE" : Return : Endif
Local Char    MATRI(GLONMAT), CTR(GLONCTR)
Local Date    DATMAT,DATDIA
DATDIA=date$
Local Integer I, AUTO
Local Integer OKENR
Filter [CTR1]  Where REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM

If rowcount([CTR1])>=1
 Gosub DEFPOP From SUBPOP

 MATRI  = [M:CTR0]REFNUM
 DATMAT = [M:CTR0]CTRDAT
 CTR    = [M:CTR0]CTRNUM
 Gosub LECEMP From DEFTABLE
 I = 0
 #En création comme en modif de fiche contrat : Ajout du salarié dans les populations lui correspondant si il n'y est pas déjà
 For [POP] Where CRI<>"" & DATMAT<=DATDIA :# 96877 on ne prend pas les contrats qui ne sont pas encore actifs
  If evalue([F:POP]CRI)=1 & !find([F:POP]COD,L_POPUL(0..L_NB_POPUL-1))
   Read [F:POA]POA0=[F:POP]COD;MATRI
   If fstat Then
     [F:POA]COD    = [F:POP]COD
     [F:POA]TYP    = 0
     [F:POA]REFNUM = MATRI
     [F:POA]MAJTYP = 1 : # Automatique
     If dim([F:POA]CREUSR)>0 : [F:POA]CREUSR = GUSER : Endif
     If dim([F:POA]CREDAT)>0 : [F:POA]CREDAT = date$ : Endif
     If dim([F:POA]CRETIM)>0 : [F:POA]CRETIM = time  : Endif
     Write [POA]
     If fstat
      GOK = 0 : Call FSTA("POA") From GLOCK : Break
     Endif
     CODPOP = [F:POP]COD
     nolign=0 : AUTO=1
     Gosub AJOUTLIS From SUBEML
   Endif
  Endif
 Next
 #En modif de fiche contrat : Suppr du salarié dans les populations ne lui correspondant plus (si automatique)
 If ACTION="APRES_MOD" | ACTION="APRES_CRE" : # 96877 aprés création aussi
  For I=0 To L_NB_POPUL-1
   Read[F:POP]POP0=L_POPUL(I)
   If !fstat & [F:POP]CRI<>"" & evalue([F:POP]CRI)<>1
     If clalev([F:CTR2])=0 : Local File EMPLOCTR [CTR2] : Endif
     OKENR=1
     For [CTR2]CTR0 Where REFNUM=MATRI & CTRDAT<=DATDIA
       CTR = [F:CTR2]CTRNUM
       DATMAT=[F:CTR2]CTRDAT
       Gosub LECEMP From DEFTABLE
       If evalue([F:POP]CRI)=1 Then OKENR=2 : Break : Endif
     Next
     If  OKENR=1
      Readlock[F:POA]POA0=[F:POP]COD;MATRI
      If !fstat & [F:POA]MAJTYP = 1
       Delete [F:POA]
       If fstat=1
        GOK = -1 : GLOCK = "$POPULA"-[F:POA]COD-[F:POA]REFNUM : Break
       Endif
      Endif
     Endif
   Endif
  Next

  Read [CTR]CTR0=MATRI;CTR;DATMAT

 Endif
Endif
Filter [CTR1]
Return

########################################################
$MAJ_TRAINER
If [M:CTR0]FLGVAR=2 : Return : Endif

If func AFNC.ACTIV("FRT")>0 Then
 Local Integer LFLG_CONTRAT_ENCOURS : LFLG_CONTRAT_ENCOURS = 1

 Filter [F:CTR3] Where REFNUM=[M:CTR0]REFNUM and CTRDAT<=date$
&                     and (XITDAT = [0/0/0] or XITDAT >= date$)
&                Order By CTRDAT Asc
    If rowcount([F:CTR3]) > 0 Then
      LFLG_CONTRAT_ENCOURS = 2
    Endif
    Filter [F:CTR3]
    If LFLG_CONTRAT_ENCOURS = 1 Then
      Filter [F:TRN] Where REFNUM=[M:CTR0]REFNUM and ENAFLG=2
      For [TRN]TRN1
        [F:TRN]ENAFLG=1
        Rewrite [TRN] Curr
        If fstat
         GOK = 0 : Call FSTA("TRN") From GLOCK : Break
        Endif
      Next
      Filter [TRN]
    Endif
  Endif
Return

########################################################
$MAJ_EMPLOSAL
If [M:CTR5]NBRSAL
 For nolign = 1 To [M:CTR5]NBRSAL
  If [M:CTR5]FLGMOD(nolign-1)
   Readlock [F:SAL]SAL0 = [M:CTR0]REFNUM;[M:CTR0]CTRNUM;nolign
   If !fstat
    [F:SAL] = [M:CTR5]
    [F:SAL]UPDDAT = date$
    [F:SAL]UPDTIM = time
    [F:SAL]UPDUSR = GUSER
    Rewrite [F:SAL]
    If fstat=1
     GOK = -1 : GLOCK = "$EMPLOSAL"-[F:SAL]REFNUM-[F:SAL]CTRNUM : Break
    Elsif fstat
     GOK = 0 : Call FSTA("SAL") From GLOCK : Break
    Endif
   Endif
  Endif
 Next
Endif
Return

########################################################
$APRES_CRE
Call DEBTRANS From GLOCK
Gosub APRES
If [V]GOK<1 : Return : Endif
Call CHARGE_POPUL([F:CTR]REFNUM,L_POPUL,L_NB_POPUL) From SUBCTR2
Gosub MAJ_POPUL
If [V]GOK<1 : Return : Endif
Return

########################################################
$APRES_MOD
$AP_ANNULE
Call DEBTRANS From GLOCK
Gosub APRES
If [V]GOK<1 : Return : Endif
Gosub MAJ_POPUL
If [V]GOK<1 : Return : Endif
Return

########################################################
$APRES
GOK = 1

Trbegin [ECT],[CTR1],[TIP]
## Mise à jour de la table EMPCTR et de la zone NUMLIG de EMPLOCTR
Filter [CTR1]  Where REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM
Read [CTR1]CTR0 Last
If fstat
 Raz [F:CTR1]
Endif
Readlock [ECT]ECT0=[M:CTR0]REFNUM;[M:CTR0]CTRNUM
If fstat=1
 GOK=-1 : GLOCK="$EMPCTR"-[M:CTR0]REFNUM-[M:CTR0]CTRNUM
Elsif fstat
 [F:ECT]REFNUM = [M:CTR0]REFNUM
 [F:ECT]CTRNUM = [M:CTR0]CTRNUM
 [F:ECT]NBRCTR = rowcount([CTR1])
 [F:ECT]FCY    = [F:CTR1]ETRFCY
 [F:ECT]SRV    = [F:CTR1]ETRSRV
 [F:ECT]PRF    = [F:CTR1]PROPRF
 [F:ECT]CREUSR = [V]GUSER
 [F:ECT]CREDAT = date$
 [F:ECT]CRETIM = time
 Write [ECT]
 If fstat
  GOK=0 : Call FSTA("ECT") From GLOCK
 Endif
Else
 [F:ECT]NBRCTR = rowcount([CTR1])
 If [F:CTR1]FLGVAR<>2
  [F:ECT]FCY    = [F:CTR1]ETRFCY
  [F:ECT]SRV    = [F:CTR1]ETRSRV
  [F:ECT]PRF    = [F:CTR1]PROPRF
 Endif
 [F:ECT]UPDUSR = [V]GUSER
 [F:ECT]UPDDAT = date$
 [F:ECT]UPDTIM = time
 If [F:ECT]NBRCTR>0
  Rewrite [ECT]
  If fstat
   GOK=0 : Call FSTA("ECT") From GLOCK
  Endif
 Else
  Delete [ECT]ECT0=[M:CTR0]REFNUM;[M:CTR0]CTRNUM
  If fstat=1 | fstat>5
   GOK=0 : Call RSTA("ECT",[M:CTR0]REFNUM-[M:CTR0]CTRNUM) From GLOCK
  Endif
 Endif
Endif
If GOK=1
 I = 0
 For [CTR1]CTR0
  I +=1
  [F:CTR1]NUMLIG = I
  #First contract = Check the box 'Break payslip' is mandatory except for casual workers
  If I=1 & GPAYE
   If GINTMT & [F:ID]FLGINT=2
    [F:CTR1]FLGCREBUL=1
   Else
    [F:CTR1]FLGCREBUL=2
   Endif
  Endif
  Rewrite [CTR1]Curr
  If fstat
   GOK=0 : Call FSTA("CTR") From GLOCK : Break
  Endif
 Next
Endif
Filter [CTR1]
If GOK<0   : Goto ROLL_APRES
Elsif !GOK : Goto AB_APRES
Endif
# Si MAJ_EMPLOID fait dans ANNULE, l'enreg n'est pas encore annulé et rowid renvoie 1
If ACTION="AP_ANNULE"
 Gosub MAJ_EMPLOID
 If GOK<0   : Goto ROLL_APRES
 Elsif !GOK : Goto AB_APRES
 Endif
Endif
If GPAYE & ACTION<>"APRES_MOD"
 # MAJ du CTRDAT de la saisie des valeurs prev non encore passées en paie
 # En effet si déjà passée en paie cela signifie qu'il existe des payes donc on aura planté avant.
 Gosub MAJ_VALPREV
 If GOK<0   : Goto ROLL_APRES
 Elsif !GOK : Goto AB_APRES
 Endif
Endif

If GRETTIP
   Local Char W_TIP_REFNUM(GLONMAT)
   Local Char W_TIP_CTRNUM(GLONCTR)
   Local Char WACTION
   Local Date W_TIP_CTRDAT
   Local Date W_TIP_XITDAT
   Local Char W_TIP_ETRFCY(GLONFCY)
   Local Char W_TIP_ETRSRV(GLONSRV)


   W_TIP_REFNUM=[M]REFNUM
   W_TIP_CTRNUM=[M]CTRNUM
   W_TIP_CTRDAT=[M]CTRDAT
   W_TIP_XITDAT=[M]XITDAT
   W_TIP_ETRFCY=[M]ETRFCY
   W_TIP_ETRSRV=[M:CTR1]ETRSRV


   WACTION=ACTION
   If [M:CTR0]FLGVAR<>2 & GTPS
     Gosub MAJ_TIMEMP2
     GRETTIP=0
     If GOK<0   : Goto ROLL_APRES
     Elsif !GOK : Goto AB_APRES
     Endif
   Endif
   GRETTIP=0
Endif
Commit
Return

########################################################
$ROLL_APRES
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto APRES : Endif

########################################################
$AB_APRES
Rollback
Return

########################################################
$MAJ_VALPREV
GOK=1

Filter [F:VPR] Where EMP=[F:CTR1]REFNUM & CTRNUM=[F:CTR1]CTRNUM & DAT>=[F:CTR1]CTRDAT & CTRDAT<>[F:CTR1]CTRDAT
Look [F:VPR]VPR0 First
Filter [F:VPR]
If fstat : Return : Endif

#Création entête des valeurs prev si inexistante
Look [F:VPH]VPH0=[F:CTR1]REFNUM;[F:CTR1]CTRNUM;[F:CTR1]CTRDAT
If fstat=5
 Raz [F:VPH]
 [F:VPH]EMP=[F:CTR1]REFNUM
 [F:VPH]CTRNUM=[F:CTR1]CTRNUM
 [F:VPH]CTRDAT=[F:CTR1]CTRDAT
 [F:VPH]SRV=[F:CTR1]ETRSRV
 [F:VPH]FCY=[F:CTR1]ETRFCY
 Call LECTURE("EML",[F:CTR1]REFNUM,"") From CONTOBJ
 [F:VPH]CODACS = [F:ID]CODACS
 If dim([F:VPH]CREDAT)>0 : [F:VPH]CREDAT = date$ : Endif
 If dim([F:VPH]CREUSR)>0 : [F:VPH]CREUSR = GUSER : Endif
 If dim([F:VPH]CRETIM)>0 : [F:VPH]CRETIM = time  : Endif
 Write [VPH]
 If fstat
   GOK = 0 : Call FSTA("VPH") From GLOCK : Return
 Endif
Endif

#MAJ lignes des valeurs prev
Update [VPR] Where EMP=[F:CTR1]REFNUM & CTRNUM=[F:CTR1]CTRNUM & DAT>=[F:CTR1]CTRDAT
&                & CTRDAT<>[F:CTR1]CTRDAT With CTRDAT=[F:CTR1]CTRDAT
If fstat
 GOK = 0 : Call FSTA("VPR") From GLOCK : Return
Endif
#MAJ commentaires sur lignes des valeurs prev
Update [PCB] Where IDENT1=[F:CTR1]REFNUM & IDENT3=[F:CTR1]CTRNUM & IDENT2>=format$("D:4Y2M2D",[F:CTR1]CTRDAT)
&                & IDENT4<>[F:CTR1]CTRDAT With IDENT4=[F:CTR1]CTRDAT
If fstat
 GOK = 0 : Call FSTA("PCB") From GLOCK : Return
Endif
Return

########################################################
$ANNULE
If GINTMT=1
 Delete [PSN] Where CTRNUM=[M:CTR0]CTRNUM & CTRDAT=[M:CTR0]CTRDAT
 If fstat=1 | fstat>5
  GOK=0 : Call RSTA("PSN",[M:CTR0]CTRNUM-num$([M:CTR0]CTRDAT)) From GLOCK : Return
 Endif
 If [M:CTR0]FLGRET=2
  Gosub MAJ_PSNBUL
  If [V]GOK < 1 : Return : Endif
 Endif
Endif

Filter [CTR1] Where REFNUM=[M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM
If rowcount([CTR1])=1
 If GPAYE
  Delete [SDP] Where EMP=[M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM
  If fstat=1 | fstat>5
   GOK=0 : Call RSTA("SDP",[M:CTR0]CTRNUM) From GLOCK : Return
  Endif
 Endif

 Delete [CNE] Where REFNUM=[M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM
 If fstat=1 | fstat>5
  GOK=0 : Call RSTA("CNE",[M:CTR0]CTRNUM) From GLOCK : Return
 Endif

 Delete [EPC] Where REFNUM=[M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM
 If fstat=1 | fstat>5
  GOK=0 : Call RSTA("EPC",[M:CTR0]CTRNUM) From GLOCK : Return
 Endif

 Delete [EPO] Where REFNUM=[M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM
 If fstat=1 | fstat>5
  GOK=0 : Call RSTA("EPO",[M:CTR0]CTRNUM) From GLOCK : Return
 Endif

 Delete [SAL] Where REFNUM=[M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM
 If fstat=1 | fstat>5
  GOK=0 : Call RSTA("SAL",[M:CTR0]CTRNUM) From GLOCK : Return
 Endif

 If clalev([F:EVE])=0   : Local File EVAEMP        [EVE]  : Endif
 Delete [EVE] Where REFNUM=[M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM & EVAVAL=10
 If fstat=1 | fstat>5
  GOK=0 : Call RSTA("EVE",[M:CTR0]CTRNUM) From GLOCK : Return
 Endif


Endif
Filter [CTR1]
If [V]GOK < 1 : Return : Endif
Gosub MAJ_EMPLOPOT
If [V]GOK < 1 : Return : Endif
Gosub MAJ_EMPLOCTRCPT
If [V]GOK < 1 : Return : Endif
Gosub MAJ_ESB
If [V]GOK<0 : Return : Endif
Gosub SAVE_RETROCTR From SUBCTRRET
If [V]GOK<0 : Return : Endif

Return

########################################################
$MAJ_PSNBUL
If clalev([F:PSN2])=0 : Local File PRESTATION [PSN2] : Endif
For [PSN2]PSN0 Where REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM & CTRDAT=[M:CTRA]RETCTRDATORI & toupper(BUL)=toupper(mess(1,303,1))
  Raz [F:PSN2]BUL
  Rewrite [F:PSN2]
  If fstat
   GOK = 0 : Call FSTA("PSN2") From GLOCK : Break
  Endif
Next
If !GOK : Return : Endif
Return

########################################################
$AV_VERF_ANU
CRITCTRL = "CTRNUM='"+[M]CTRNUM+"'"
CRITCTRL-="& CTRDAT=["+num$([M]CTRDAT)+"]"
Call CONTROLE_PAYE([M]REFNUM, CRITCTRL)
If mkstat
 #Suppression impossible : Paies présentes sur la période
 Raz mkstat
 GMESSAGE = mess(9,701,1)
 OKANU=0 : Return
Endif
Gosub CONTROLE_TIP3
If mkstat
  #Suppression impossible : Temps saisis sur la période
 Raz mkstat
 OKANU=0 : Return
Endif

#Test en suppression de contrat si contrat sur fiche de rétroactivité
#Pour une obscure raison les variables déclarées dans $OUVRE ne sont plus la !
#d'où déclaration PRESENCE_REC ici ...
Local Integer PRESENCE_REC

# Pas de suppression si le contrat apparaît sur une fiche de rétroactivité
# non validée : en effet si la fiche a été validée, il existe des payes
# donc on aura planté avant. Le seul cas qui nous intéresse est d'empêcher
# de supprimer un avenant s'il apparaît sur une fiche "à traiter".
If GPAYE
 Filter [F:RES] Where [F:RES]REFNUM = [M:CTR0]REFNUM
&                   & [F:RES]CTRNUM = [M:CTR0]CTRNUM
&                   & [F:RES]CTRDAT = [M:CTR0]CTRDAT
 For [F:RES]
  [L]PRESENCE_REC = 1    : # Est ce qu'on a un enregistrement dans REC
  For [F:REC]REC0(3) Where [F:REC]RETNUM = [F:RES]RETNUM
&                        & [F:REC]RECREFNUM = [F:RES]REFNUM & [F:REC]RECCTRNUM = [F:RES]CTRNUM
   [L]PRESENCE_REC = 2    : # Oui, on a un enregistrement
   # Présence d'enregistrement sans numéro de bulletin dessus => pas traité ( calculé ).
   If [F:REC]RECBUL = ""
    [L]OKANU = 0        : # Pas de suppression
    Break 2
   Endif
  Next
  # Notre contrat apparaît dans [RES] mais pas dans [REC] : il n'a pas été calculé ou validé si extourne
  If [L]PRESENCE_REC = 1
   [L]OKANU = 0
   Break
  Endif
 Next
 Filter [F:RES]
 If [L]OKANU = 0
  # Suppression : Avenant présent sur une fiche de rétroactivité
  Call ERREUR(mess(112, 701, 1)) From GESECRAN
  [L]OKANU = 0
  Return
 Endif

 #Pas de suppression si le contrat apparaît sur une fiche de régularisation
 Filter [RGL] Where ENAFLG=2 & find([M:CTR0]REFNUM+"~"+[M:CTR0]CTRNUM+"~"+format$("D:YYYYMMDD",[M:CTR0]CTRDAT), [F:RGL]CTRCRI)
 Look [RGL]RGL0 First
 Filter [RGL]
 If !fstat
  # Suppression : Avenant présent sur une fiche de régularisation
  Call ERREUR(mess(144, 701, 1)) From GESECRAN
  [L]OKANU = 0:   Return
 Endif

 #Pas de suppression si le contrat apparaît sur une fiche d'exception de calcul
 Filter [ECH] Where find([M:CTR0]REFNUM+"~"+[M:CTR0]CTRNUM+"~"+format$("D:YYYYMMDD",[M:CTR0]CTRDAT), [F:ECH]CTRCRI)
 Look [ECH]ECH0 First
 Filter [ECH]
 If !fstat
  # Suppression : Avenant présent sur une fiche d'exception de calcul
  Call ERREUR(mess(145, 701, 1)) From GESECRAN
  [L]OKANU = 0 : Return
 Endif

 Filter [F:VPR] Where EMP=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM & CTRDAT=[M:CTR0]CTRDAT
 Look [VPR]VPR0 First
 Filter [VPR]
 If !fstat
  # Suppression : Avenant présent en saisie de valeurs prévisionnelles
  Call ERREUR(mess(148, 701, 1)) From GESECRAN
  [L]OKANU = 0 : Return
 Endif

 Filter [F:PPD] Where REFNUM=[M:CTR0]REFNUM & CTRNUM=[M:CTR0]CTRNUM & CTRDAT=[M:CTR0]CTRDAT
 Look [F:PPD]PPD0 First
 Filter [F:PPD]
 If !fstat
  # Suppression : Avenant présent sur un bordereau de prépa-paie
  Call ERREUR(mess(149, 701, 1)) From GESECRAN
  [L]OKANU = 0 : Return
 Endif
Endif

# Suppression bloquante si le contrat existe dans un autre fichier et que c'est la dernière fiche du contrat
Filter [CTR1] Where REFNUM=[M:CTR0]REFNUM & CTRNUM = [M:CTR0]CTRNUM
If rowcount([CTR1])=1
 Filter [CTR1]
 For [A_TZ] Where CODTYP="CTR" & CODFIC<>"EMPCTR" & CODFIC<>"PRESTATION"
&               & CODFIC<>"SOLDPAY" & CODFIC<>"CNGEMP"
&               & CODFIC<>"EMPLOCTR" & CODFIC<>"EMPLOCUM" & CODFIC<>"EMPLOPOT"
&               & CODFIC<>"EMPLOSAL" & CODFIC<>"EMPLOCTRCPT" & CODFIC<>"EMPSBD"
&               & CODFIC<>"EMPLOCTRSA" & CODFIC<>"EMPLOCTRPOR"
&               & CODFIC<>"EMPLOCTRFRA" & CODFIC<>"EMPLOCTRPEN"
&               & CODFIC<>"EMPLOCTRAFR" & CODFIC<>"EMPLOCTRMID"
&               & CODFIC<>"EMPLOTAXREC" & CODFIC<>"HRAFRCLASS"
&               & left$(CODFIC,3)<>"TMP"
#JASMI - 2016-04-06 - ISSUE 115628 - START - Added EMPLOTAXREC & HRAFRCLASS
  FICHIER = [F:A_TZ]CODFIC
  Read [A_TB]CODFIC = FICHIER
  Call AFF_VLC(mess(56,123,1),FICHIER) From GESECRAN : # Table
  K = 0
  If [F:A_TB]TYPFIC=3 & nomap=APPLI & filinfo(filpath("FIL",FICHIER,"fde"),0)>0 : # Table système
   K = 1
  Elsif filinfo(filpath("FIL",FICHIER,"fde",APPLI),0)>0
   K = 1
  Endif
  If K & APPLI=GDOSH
   Call VUE_OK(FICHIER,APPLI,"FIL",K) From DOSVUE
   K = !K
  Endif
  If K
   If nomap=APPLI
    Local File =FICHIER [LIE_]
   Else
    Local File =APPLI+"."+FICHIER [LIE_]
   Endif
   SUBCRIT = [F:A_TZ]CODZONE+'="'+[M]CTRNUM+'"'

   If FICHIER="EVAEMP" :
      SUBCRIT-='& EVAVAL<10'
   Endif

   Filter [LIE_] Where evalue(SUBCRIT)
   For [LIE_]
    OKANU = 0
   Next
   Filter [LIE_]

   If OKANU=0
    REFERR(1) = mess(46,150,1) : # Annulation
    REFERR(1) -= mess(198,133,1)-FICANU : # dans - Table sur laquelle on fait la suppression
    Call TEXTE([F:A_TB]INTITFIC,CHAINE) From OBJDIV
    REFERR(1) -= "("+CHAINE+")" : # Intitulé de la table associée à l'objet sur lequel on fait la suppression
    Read [A_TI]NUMLIG(2) = FICHIER;1
    CHAINE = [F:A_TI]DESCRIPT
    Raz I, CLE, CLE1, CLE2
    While CHAINE<>""
     I1 = instr(1,CHAINE,"+")
     I2 = instr(1,CHAINE,"-")
     If I2
      If I1 : I1 = min(I1,I2) : Else : I1 = I2 : Endif
     Endif
     If I1
      WCLE = left$(CHAINE,I1-1)
      CHAINE = right$(CHAINE,I1+1)
     Else
      WCLE = CHAINE
      CHAINE = ""
     Endif
     If CLE<>"" : CLE += "~" : Endif
     CLE += num$(evalue("[F:LIE_]"+WCLE))
     I += 1
     Case I
      When 1
       CLE1 = num$(evalue("[F:LIE_]"+WCLE))
      When Default
       If I>2 : CLE2 += "~" : Endif
       CLE2 += num$(evalue("[F:LIE_]"+WCLE))
     Endcase
    Wend
    REFERR(2) = mess(101,126,1)-CLE : # La fiche est utilisée par
    REFERR(2) -= mess(198,133,1) : # dans
    If APPLI<>nomap(0) : REFERR(2) -= APPLI+"."+FICHIER
    Else               : REFERR(2) -= FICHIER
    Endif
    Read [A_TB]CODFIC = FICHIER
    Call TEXTE([F:A_TB]INTITFIC,CHAINE) From OBJDIV
    If vireblc(CHAINE,4)<>"" : CHAINE = "("+CHAINE+")" : Endif
    REFERR(2) -= CHAINE : # Intitulé de la table associé à l'objet dont le type de données est concerné
    REFERR(3) = mess(176,115,1) : # Il faut d'abord supprimer ce lien

    If !GSERVEUR & !GIMPORT
     Call ERRTITT(REFERR(2)+"\"+REFERR(3),REFERR(1)) From GESECRAN
    Else
     GMESSAGE = REFERR(1)+"\"+REFERR(2)
     If !GIMPORT
      GMESSAGE+="\"+REFERR(3)
     Endif
    Endif
    Close Local File [LIE_]
    Break
   Endif
   Close Local File [LIE_]
  Endif
 Next
Else
 Filter [CTR1]
Endif

Return

########################################################
$SETBOUT
[L]CHMEN=""
If GREP="" & VERROU
 ZONE = "FLGCRECTR" : Gosub SET_ZONE
 If MA & ([M]FLGCRECTR=2 | [M]FLGCRELET=2 | [M]FLGCREAVN=2)
  [L]CHMEN+="1"
 Endif
 ZONE = "FLGVAR" : Gosub SET_ZONE
 # Possibilité de créer un avenant VAR uniquement sur le dernier contrat du chrono, si date de sortie
 If MA & [M]XITDAT<>[0/0/0] & GLASTCTR
  [L]CHMEN+="6"
 Endif

 If MA &  [M]FLGVAR<>2 & GLASTCTR & ([F:ID]FLGINT<>2 | ([F:ID]FLGINT=2 & [F:CTR]FLGRET<>2))
  [L]CHMEN+="5"
 Endif
  CHMEN+="23"
Else
 # Bouton caisses
 Call VIREBOUT (CHAINE,"4") From GOBJET
 Gosub DES_BUTEVA
Endif

#Objet à 3 éléments de clé : ajout du btn suppression
If CLECUR  CHAINE+="A"  Endif
Call VIREBOUT (CHAINE,"H") From GOBJET    :#91500

If IS_FNCA
  Call PARAM([M:CTR0]ETRFCY,"EVASUI",DISP_EVA)From ADOVAL
  If (DISP_EVA<>"2")
    Gosub DES_BUTEVA
  Endif
Endif
Return

$DES_BUTEVA
  If IS_FNCA
    Call VIREBOUT (CHAINE,"7") From GOBJET
  Endif
Return

########################################################
$FILTRE
FILTSUP   = "[F:ID]FLGNEWSAL<>2"
Call FILTREROLE("EML",FILTSUP) From SUBEML
Call FILTREROLE("CTR",FILTSUP) From SUBEML
If GUSRACS<>2
 FILTSUP -= "& find([F:CTR]ETRSRV,GAUTSRV(1..GNBSERV))"
 FILTSUP -= '& ([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
Endif
If GPILNAV>1
 If find(GNAVIG(GPILNAV-1),"GESEML") & GREP<>"C" & GREP<>"D" & dim(TUNCLE)>0
  FILTSUP -= "& CTRNUM='"+TUNCLE+"'"
 Endif
 If find(GNAVIG(GPILNAV-1), "TPSSTD")
  FILTSUP -= "& [F:ID]REFNUM=[M:TPS]REFNUM"
 Endif
 If find(GNAVIG(GPILNAV-1), "GESCNE")
  FILTSUP -= "& [F:ID]REFNUM=[M:CNE1]REFNUM"
 Endif
Endif
Return

########################################################
$FILGAUCHE
FILGAUSUP = "[F:ID]FLGNEWSAL<>2"
Call FILTREROLE("EML",FILGAUSUP) From SUBEML
Call FILTREROLE("CTR",FILGAUSUP) From SUBEML
If GUSRACS<>2
 FILGAUSUP -= "& find([F:CTR]ETRSRV,GAUTSRV(1..GNBSERV))"
 FILGAUSUP -= '& ([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
Endif
If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 FILGAUSUP -= '& find([F:CTR]ETRFCY,GUSRFCY(1..GNBAUZ))'
Endif
If GPILNAV>1
 If find(GNAVIG(GPILNAV-1), "TPSSTD")
  FILGAUSUP -= "& [F:ID]REFNUM=[M:TPS]REFNUM"
 Endif
 If find(GNAVIG(GPILNAV-1), "GESCNE")
  FILGAUSUP -= "& [F:ID]REFNUM=[M:CNE1]REFNUM"
 Endif
Endif
Return

########################################################
$FIN
# Pour raffraichir l'écran MAT6 quand tunnel à partir des salariés
If GPILNAV>1 & find(GNAVIG(GPILNAV-1), "GESEML")
 mkstat=4
Endif
Kill GRETTIP, GLASTCTR
Return

########################################################
$AVANTBOUT
Case [L]BOUT
 When "2"
  # Bulletins salariés
  GBIDC1 = [M:CTR0]CTRNUM
Endcase
Return

########################################################
$STATUT
Case [L]BOUT
 When "2"
  # Bulletins salariés
  Raz [V]GBIDC1
 When "3"
  # Changement de date
  # Comme changement de clé on fait un DEVERRROU pour que le RELIT vérouille le nvx code
  If VERROU : Gosub DEVERROU From GOBJET : Endif
  [L]CLECUR2(1) = format$(GFMD,[M:CTR0]CTRDAT)
  Gosub RELIT From GOBJSUB
 When "5","6"
  If VERROU : Gosub DEVERROU From GOBJET : Endif
  #New date de contrat pour avenant retro ou VAR
  If GBIDC2<>"" :
   [L]CLECUR2(1) = format$(GFMD,GBIDC2)
  Endif
  # Avenant VAR avec potentiellement un new chrono
  If BOUT="6" & GBIDC1<>"" : CLECUR1=GBIDC1 : Endif
  Gosub RELIT From GOBJSUB
  If BOUT='5'& GBIDC1<>"" & GBIDC2<>""
    Gosub LOAD_RETTAB  From SUBCTRRET : Gosub SAVE_RETROCTR  From SUBCTRRET
  Endif
  Raz [V]GBIDC1 :  Raz [V]GBIDC2
 Endcase
Return

################################################################################################################
##                                         Etiquettes écran
################################################################################################################
Subprog AS_REFNUM(VALEUR)
Variable Char    VALEUR()
# Tunnel à partir du fichier des salariés
If GPILNAV>1 & find(GNAVIG(GPILNAV-1), "GESEML") & dim([M:EMP0]REFNUM)>=1 & [M:CTR0]CTRNUM=""
 VALEUR = [M:EMP0]REFNUM
 Call AM_REFNUM(VALEUR)
Endif
End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
Read[ID]ID0=VALEUR
If !fstat
 [M]SRN = [F:ID]NAM-[F:ID]SRN
 If GINTMT
  If [F:ID]FLGINT<>2 : # Le salarié n'est pas un intermittent
   Effzo [CTR3]
   If dim([M:CTR3]STACTR)>0 : [M:CTR3]STACTR = 2 : Endif
   Grizo [CTR3]
  Else
   Actzo [CTR3]
  Endif
  Affzo [CTR3]
 Endif
Endif
Call GRISE_CALPAY([F:ID]FLGINT) From SUBCTR2
Call GRISE_FLGPAY([F:ID]FLGPAY) From SUBCTR2
Local Char WCTRNUMERO(GLONCTR)
WCTRNUMERO=""
If GREP<> "C"
  Call SELCTR2(VALEUR,[0/0/0],[0/0/0],WCTRNUMERO) From DIVPAYE
Endif
If WCTRNUMERO <> ""
 [M:CTR0]=[F:CTR]
Endif
End

Subprog C_CTRNUM(VALEUR)
Variable Char     VALEUR
Local Integer OK
If clalev([F:CTR2])=0 : Local File EMPLOCTR [CTR2] : Endif
If clalev([F:ID])=0   : Local File EMPLOID  [ID]   : Endif
If VALEUR<>""
 Filter [CTR2] Where REFNUM<>[M]REFNUM & CTRNUM=VALEUR
 Read[CTR2]CTR0 First
 Filter [CTR2]
 If !fstat
  # Ce contrat est rattaché au salarié
  GMESSAGE = mess(61,701,1)-[F:CTR2]REFNUM
  mkstat = 2 : End
 Endif
Else
 Filter [CTR2] Where REFNUM=[M]REFNUM
 Read[CTR2]CTR0 First
 Filter [CTR2]
 If !fstat
   OK = 2
   Call AVERTIR(mess(51,701,1),OK) From GESECRAN
   If OK=1 : mkstat = 2 : End : Endif
 Endif
Endif
If !(GPILNAV>1 & find(GNAVIG(GPILNAV-1), "GESEML")) & !GIMPORT
  If VALEUR <> "" & (VALEUR <> [M]CTRNUM | [F:CTR]CTRDAT <> [M]CTRDAT)
   If GREP<> "C" & [M]CTRDAT <> [0/0/0]
     [M:CTR0]=[F:CTR]
     Affzo [M:CTR0]
    Else
      If GREP= "C" & [M:CTR0]ETRFCY<>[F:CTR]ETRFCY
        Local Char     PETRFCY
        PETRFCY=[F:CTR]ETRFCY
        Call AM_ETRFCY(PETRFCY)
        If mkstat =2 : End : Endif
        [M:CTR0]ETRFCY=[F:CTR]ETRFCY
        Affzo [M:CTR0]ETRFCY,ZETRFCY
      Endif
   Endif
  Endif
Endif

If [M]CTRNUM<>VALEUR
 [M]CTRNUM=VALEUR
 #Manage the box 'Break payslip' (1 = Assign & Display)
 If GPAYE : Call UPD_FLGCREBUL([M]FLGCREBUL, 1) From SUBCTR2 : Endif
Endif
End

Subprog AS_CTRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR=date$
Endif
End

Subprog C_CTRGRD(VALEUR)
Variable Char    VALEUR()
Local Integer WOK
WOK=1
If !GIMPORT & (find([V]GREP,"C","D") & [F:ID]FLGINT<>2) | ([V]GREP = "M" &  [F:ID]FLGINT<>2 & [M:CTR0]FLGVAR<>2) Then
  Call CONTROLE_ENT_CTRGRD(VALEUR,0,WOK)
  If !WOK : mkstat=1 : End : Endif
Endif
If GREP="C" | GREP="D"
 Read[F:ADI]=386;VALEUR
 If !fstat & [F:ADI]N2=2
  Raz [M:CTR1]NUMRGT
  Affzo [CTR1]NUMRGT
 Endif
Endif
End

Subprog AM_NATCON(VALEUR)
Variable Char    VALEUR()
Local Char ZONE(10)
Call GRISE_GRDCDD (VALEUR)
Read[F:ADI]CODE=354;VALEUR
If fstat=0
 If VALEUR="COD"
  ZONE = "CDDGRD"
  Gosub SET_ZONE
  If MA
   [M]CDDGRD=VALEUR
   Affzo CDDGRD
  Endif
 Endif

 CODA1=[F:ADI]A1

 If GDOSLEG="FRA" & CODA1="03" : # CTT alors type d'emploi est intérimaire.
  ZONE = "TYPJOB"
  Gosub SET_ZONE
  If MA
   [M]TYPJOB = 3
   Call C_TYPJOB([M]TYPJOB)
   Affzo TYPJOB
  Endif
 Endif
Endif

 If func ISKZAKAQ() Then
  [M:CTR1]TYPJOB = func DIVPAYE.SET312(VALEUR)
  Affzo [M:CTR1]TYPJOB
Endif

End

Subprog AM_ETRFCY(VALEUR)
Variable Char    VALEUR()
Local Char    CRITCTRL (250), SOC(GLONCPY), VOIDCHAR(250)
Local Integer OK

GRETTIP=1


  If GREP<>"C" & GREP<>"D" & [F:ID]FLGINT<>2
   Gosub CONTROLE :#Paies présentes sur la période
   If mkstat : End : Endif
   Gosub CONTROLE_TIP : # Temps présents sur la période
   If mkstat : End : Endif
  Endif

  If func ISKSA()
    Call AM_ETRFCY(VALEUR,OK) From SUBCTRKSA
    If OK = 1 : mkstat = 2 : End : Endif
  Endif

# Avertissement si l'on crée une entrée sur un site appartenant à une société différente d'une entrée
# déjà existante.
If (GREP="C" | GREP="D")
 SOC =""
 If clalev([F:CTR1])=0 : Local File EMPLOCTR[CTR1] : Endif
 Filter [CTR1] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & CTRDAT<[M]CTRDAT
 Read [CTR1]CTR1 Last
 Filter [CTR1]
 If !fstat
  Call LECTURE("FCY",[F:CTR1]ETRFCY,"") From CONTOBJ
  SOC = [F:FCY]LEGCPY
# Endif
# --- The new VALUE ------
  Call LECTURE("FCY",VALEUR,"") From CONTOBJ
   If [F:FCY]LEGCPY<>SOC : #& SOC <>""
     # Changement société/Les cumuls niveau salarié sont repris dans la nouvelle société sauf si la zone Raz Cumul cochée
     OK = 2
     Call AVERTIR (mess(15,701,1),OK) From GESECRAN
     If OK=1 : mkstat = 2 : End : Endif
   Endif
 Endif
Endif

Gosub RET_EXTOURNE
If mkstat : End : Endif

# To do after all the controls,
# to display fields linked to the new FCY VALEUR

Gosub REFRESH_BULDEM

Gosub REFRESH_CPR

GSOCIETE=[F:FCY]LEGCPY
[M:CTR0]CPY=[F:FCY]LEGCPY

End

######################
$RET_EXTOURNE
If dim([M:CTRA]FLGRET) > 0 & [M:CTRA]FLGRET = 2 & [M:CTRA]RETTYP = 1
  Local Integer OK_MODIF
  #Avenant au contrat avec retroactivité, le type de retroactivité 'Extourne' est plus approprié à cette modification.
  #Confirmez-vous la modification ?
  Call AVERTIR(mess(97,701,1)+"\"+mess(180,133,1)-"?", [L]OK_MODIF) From GESECRAN
  If [L]OK_MODIF = 1 : mkstat = 2 : Return : Endif
Endif
Return

######################################################################################
## Etiquettes Ecran CTR1
######################################################################################

Subprog C_CDDGRD(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Local Integer JADI
 Local Char CODA1 (10)
 Read [F:ADI]CODE = 354;[M:CTR0]NATCON
 If !fstat
  CODA1= [F:ADI]A1
  If GDOSLEG="FRA" & CODA1="02"
   GMESSAGE = mess(10,123,1) : # Zone Obligatoire
   mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog AM_CDDGRD(VALEUR)
Variable Char    VALEUR()
If VALEUR="REM" | VALEUR="RPL"
&  | func DIVPAYE.ISTRAINEE([M]NATCON)
 Actzo MATREMP
Else
 Effzo MATREMP
 Grizo MATREMP
 If dim([M]SRNRPL) > 0 :Raz [M]SRNRPL : Affzo SRNRPL : Endif
Endif
End

Subprog C_NBRPER(VALEUR)
Variable Decimal  VALEUR
End

########################################################
$SET_REFDAT
Local Date REFDAT
If [M]FLGRET<>2
 REFDAT=[M]CTRDAT
Else
 REFDAT=[M]RETDATEFF
Endif
Return

Subprog AM_NBRPER(VALEUR)
Variable Decimal VALEUR
Gosub SET_REFDAT
If VALEUR
 Case [M]PERCON
  When 1 : [M]ENDCON = [L]REFDAT+VALEUR-1              : # Jour
  When 2 : [M]ENDCON = [L]REFDAT+(VALEUR*7)-1          : # Semaine
  When 3 : [M]ENDCON = addmonth([L]REFDAT,VALEUR)-1    : # Mois
  When 4 : [M]ENDCON = addmonth([L]REFDAT,VALEUR*12)-1 : # Année
 Endcase
Else
 [M]ENDCON=[L]REFDAT
Endif
Affzo [M]ENDCON
End

Subprog C_PERCON(VALEUR)
Variable Integer  VALEUR
End

Subprog AM_PERCON(VALEUR)
Variable Integer VALEUR
Gosub SET_REFDAT
If [M]NBRPER
 Case VALEUR
  When 1 : [M]ENDCON = [L]REFDAT+[M]NBRPER-1              : #Jour
  When 2 : [M]ENDCON = [L]REFDAT+([M]NBRPER*7)-1          : #Semaine
  When 3 : [M]ENDCON = addmonth([L]REFDAT,[M]NBRPER)-1    : #Mois
  When 4 : [M]ENDCON = addmonth([L]REFDAT,[M]NBRPER*12)-1 : #Année
 Endcase
Else
 [M]ENDCON=[L]REFDAT
Endif
Affzo [M]ENDCON
End

Subprog C_ENDCON(VALEUR)
Variable Date     VALEUR
Gosub SET_REFDAT
If VALEUR<>[0/0/0] & VALEUR<[L]REFDAT
 #Une date de fin de contrat doit être supérieure à la date de début du contrat.
 GMESSAGE=mess(137,702,1)
 mkstat=2 : End
Endif
If VALEUR=[0/0/0] & ([M]CDDGRD="REM" | [M]CDDGRD="RPL")
 GMESSAGE=mess(10,123,1) :# Zone Obligatoire
 mkstat=2 : End
Endif

If func ISKMIEA() and func DIVPAYE.EXISTE_KXX("SUBCTRMID")
    Call C_ENDCON(VALEUR) From SUBCTRMID
Endif

End

Subprog C_MATREMP(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M]REFNUM
 # Un salarié en CDD de remplacement ne peut se remplacer lui-même
 GMESSAGE = mess(25,701,1)
 mkstat = 2 : End
Endif
End

Subprog C_ENDTRY(VALEUR)
Variable Date     VALEUR
If VALEUR<>[0/0/0]
 Gosub SET_REFDAT
 If VALEUR<[L]REFDAT
  #Une date de fin de période d'essai doit être supérieure à la date de début du contrat.
  GMESSAGE=mess(138,702,1)
  mkstat=2 : End
 Endif
 If [M]ENDCON<>[0/0/0] & VALEUR>[M]ENDCON
  #Une date de fin de période d'essai doit être inférieure à la date de fin du contrat.
  GMESSAGE=mess(139,702,1)
  mkstat=2 : End
 Endif

  Call C_ENDTRY(VALEUR) From SUBCTR2

Endif
End

Subprog C_NEWTRY(VALEUR)
Variable Integer  VALEUR
Call GRISE_ESSAI2(VALEUR) From SUBCTR2
If VALEUR=2 & [M]ENDTRY=[0/0/0]
 # Une date de fin de période d'essai doit être saisie avant de renouveler la période d'essai
 GMESSAGE = mess(113,702,1)
 mkstat = 2 : End
Endif
End

Subprog AM_NEWTRY(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [M]ENDTRY2
Endif
End

Subprog C_ENDTRY2(VALEUR)
Variable Date     VALEUR
If VALEUR<=[M]ENDTRY
 # La 2ème période d'essai doit se terminer après la période d'essai initiale
 GMESSAGE = mess(112,702,1)
 mkstat = 2 : End
Endif

  Call C_ENDTRY2(VALEUR) From SUBCTR2

End

Subprog AS_PROPRF(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [F:ID]FLGPAY=2
 Gosub LIRE_SITE
 VALEUR = [F:SIT]PRF
Endif
End

Subprog C_PROPRF(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [F:ID]FLGPAY=2
 # Zone Obligatoire
 GMESSAGE = mess(10,123,1)
 mkstat = 2 : End
Endif
If VALEUR="005" : [M]DNACODTIM=6 : Endif
End

Subprog AS_ETRSRV(VALEUR)
