   If dim([M:PSH1]ECCVALMAJ) > 0
      Raz [M:PSH1]ECCVALMAJ(nolign-1)
      Raz [M:PSH1]ECCVALMIN(nolign-1)
      Raz [M:PSH1]ECCSAIFLG(nolign-1)
   Endif
Endif
End
