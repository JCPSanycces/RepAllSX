Variable Char    VALEUR()
Local    Integer PLAN : PLAN=10 : Gosub AM_LINACCX
End

$AS_LINACCX
#-------------------------------------#
# Avant saisie commune aux 10 comptes #
#-------------------------------------#
If GMODIF=0  mkstat=2 : Return : Endif
Call AVSAI_ACC(VALEUR,PLAN,"[M:PSH1]LINACC") From TRTX3CPT
Return

$C_LINACCX
#--------------------------------#
# Contrôle commun aux 10 comptes #
#--------------------------------#
Local    Shortint NOL : NOL=nolign-1
#-----
Call CTRL_ACC(VALEUR,PLAN,GFINRSP,[M:PSH0]PRQDAT,[M:PSH1]CUR(NOL),"[M:PSH1]LINACC") From TRTX3CPT
#-----
Return

$AM_LINACCX
#------------------------------------#
# Après modif commune aux 10 comptes #
#------------------------------------#
Local    Shortint I
Local    Shortint NOL : NOL=nolign-1
#-----
# Issue 106746 - 2015-04-02 by SR :
# Issue 119705 - 2016-11-10 by MUARN : ne pas fait en import (MMS)
If find(GREP,"C","D") & !GIMPORT
  For I=PLAN+1 To dim(GCOA)
      If I<=GNBCOA
         Assign "[M:PSH1]LINACC"+num$(I)+"(NOL)" With ""
      Else
         Break
      Endif
  Next
Endif
# End issue 106746
Call APMOD_ACC(VALEUR,PLAN,"[M:PSH1]LINACC") From TRTX3CPT
#-----
If [F:GAC]COA<>GCOA(PLAN) | [F:GAC]ACC<>VALEUR
   Read [GAC] GAC0=GCOA(PLAN);VALEUR : If fstat Raz [F:GAC] : Endif
Endif
If PLAN=1
  [M:PSH1]LINACC1(NOL)=VALEUR
  If !varinit([M:PSH1]LINPURTYP,NOL)
    Call D_LINPURTYP ([M:PSH1]LINPURTYP(NOL)) From SUBPSH  : # Chargement type d'achat
  Endif
Endif
Assign "[M:PSH1]LINACC"+num$(PLAN)+"(NOL)" With VALEUR
GBIDI2=1 : Gosub PREP_INIT_CCE From SUBPSH
Return

Subprog D_LINPURTYP(VALEUR)
#-------------------------------------------------------------#
# Initialisation du type d'achat en fonction du copte général #
#-------------------------------------------------------------#
Variable Integer VALEUR
#----- Recherche compte général -----#
Local Char WACC(GLONGAC)
Call RECH_ACC(1,"[M:PSH1]LINACC",nolign-1,WACC) From TRTX3CPT
If WACC<>""
  If [F:GAC]VATIPT=5
    VALEUR=3
  Elsif [F:GAC]VATIPT=4
    VALEUR=2
  Else
    VALEUR=1
  Endif
Else
  VALEUR=1
Endif
End

Subprog AS_LINPURTYP(VALEUR)
#------------------------------#
# Avant saisie du type d'achat #
#------------------------------#
Variable Integer VALEUR
If GMODIF=0  mkstat=2 : Endif
End

Subprog AM_LINPURTYP(VALEUR)
#------------------------------------#
# Après modification du type d'achat #
#------------------------------------#
Variable Integer VALEUR
Local Integer OK
OK=2 : Call OUINON(mess(340,194,1),OK) From GESECRAN
If OK=2
  Local Integer  I
  Local Shortint NOL                  : NOL=nolign-1
  Local Char     SAV_LINACC1(GLONGAC) : SAV_LINACC1=[M:PSH1]LINACC1(NOL)
  Local Char     SAV_LINACC2(GLONGAC) : SAV_LINACC2=[M:PSH1]LINACC2(NOL)
  [M:PSH1]LINPURTYP(NOL)=VALEUR
  Call INIT_COMPTES_LIGNE (NOL) From SUBPSH
  [M:PSH1]LINPURTYP(NOL)=VALEUR : # Modifié par le Call !
  # Issue 42104 - 2017-06-22 by MUARN : ne pas faire sinon on perd les données de la pièce auto (INIT_COMPTES_LIGNE)
  #If [M:PSH1]LINACC1(NOL)<>SAV_LINACC1
  #  Call AM_LINACC1([M:PSH1]LINACC1(NOL))
  #Endif
  #If [M:PSH1]LINACC2(NOL)<>SAV_LINACC2
  #  Call AM_LINACC2([M:PSH1]LINACC2(NOL))
  #Endif
  If !GIMPORT  Gosub AFFICH_LINACC : Endif
Endif
End

