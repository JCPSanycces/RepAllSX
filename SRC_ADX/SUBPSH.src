Subprog AS_BUTMMSURL(VALEUR)
Variable Char    VALEUR()
If [M:PSH1]MMSURL=""
    [S]mkstat=2
Endif
End

Subprog CL_BUTMMSURL(VALEUR)
Variable Char    VALEUR()
Local Char RETOUR (250) : Raz RETOUR
Callui RETOUR="" With "UIAction="+chr$(1)+"OpenFile",
& "UILocalDir="+chr$(1) + "HTTP",
& "UILocalFile="+ chr$(1) +[M:PSH1]MMSURL
End


# Issue 71276 - 2015-03-20 by SR : Versions
######################################################################################
# Issue 71276 - 2015-03-20 by SR : Versions
Subprog AM_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Local Char    WECCVALMAJ(GLONECS)
Local Char    WECCVALMIN(GLONICVVAL)
Local Char    PITM(GLONITM)
Raz WECCVALMAJ
Raz WECCVALMIN
Raz PITM
If [F:ITM]ITMREF <> [M:PSH1]ITMREF(nolign-1)
  Read [F:ITM]ITM0 = [M:PSH1]ITMREF(nolign-1)
  If fstat : Raz [F:ITM] : Endif
Endif
# si version majeure trouvée et si article gere la version mineure : recherche derniere version mineure
If VALEUR  <> "" & [F:ITM]ECCSTO = 3
   WECCVALMAJ = VALEUR
   PITM = [F:ITM]ITMREF
   Gosub READECCMIN From STKACT
   [M:PSH1]ECCVALMIN(nolign-1) = WECCVALMIN
   Affzo [M:PSH1]ECCVALMIN(nolign-1)
Elsif VALEUR = "" & [M:PSH1]ECCVALMIN(nolign-1) <> ""
      Raz   [M:PSH1]ECCVALMIN(nolign-1)
      Affzo [M:PSH1]ECCVALMIN(nolign-1)
Endif
End

######################################################################################

# Issue X3-5485 - 2017-08-07 by MUARN : recalcul tarif
Subprog AM_PJTH(VALEUR)
Variable Char    VALEUR()

Local Integer OK

# Faire la recherche ssi le chp est reporté sur les lignes
If (dim(GPJTACTMOD)<0 | GPJTACTMOD<>"1" | [M:PSH1]NBLIG=0) : Goto FIN_PJTH : Endif
OK=2 : Call OUINON(mess(63,196,1),OK) From GESECRAN
If OK=2
  For I=0 To [M:PSH1]NBLIG-1
    nolign = I + 1
    # si non commandée  et non soldée
    If [M:PSH1]BLOMSG(I) = 0  & [M:PSH1]LINCLEFLG(I) = 1
      [M:PSH1]PRIFLG (I) = 1
      Gosub INI_TARIF
    Endif
  Next I
Endif
$FIN_PJTH
If dim(GPJTACTMOD)>0 Kill GPJTACTMOD Endif
End


