########################################################################
# INIT_COMPTES_LIGNE : S/P d'initialisation               MBT 08/09/06 #
#                des comptes d'une ligne de DA                         #
# -------------------------------------------------------------------- #
# Subprog INIT_COMPTES_LIGNE (NOL)                                     #
#   NOL    : Indice de la ligne de DA à traiter (nolign-1)             #
########################################################################
Subprog INIT_COMPTES_LIGNE (NOL)
Value    Shortint NOL
#-----
Local    Shortint I
#----- Chargement de comptes avec "" pour désactiver l'action d'init -----#
For I=1 To 10
  If evalue("dim([M:PSH1]LINACC"+num$(I)+")")>0
    Assign "[M:PSH1]LINACC"+num$(I)+"(NOL)" With ""
  Endif
Next I
#----- Si ligne vide, pas la peine d'initialiser ! -----#
If [M:PSH1]ITMREF(NOL)=""  End : Endif
#-----
Local    Char     ID1(20)(1..2), ID2(20)(1..2)
Local    Shortint J, LIG, SAVNOLIGN : SAVNOLIGN=nolign
Local    Integer  STA
Local    Char     TPLAN  (GLONCOA)(1..10)
Local    Char     TCOMPTE(GLONGAC)(1..10)
Local    Char     WMESSAGE(80)
#-----
If !clalev([F:GAD])  Local File GAUTACED  [GAD] : Endif
If !clalev([F:TB0])  Local File PREQUISD  [TB0] : Endif
If !clalev([F:TB2])  Local File CPTANALIN [TB2] : Endif
nolign=NOL+1
#-----
If [F:BPR]BPRNUM<>[M:PSH1]BPSNUM(NOL)
  Read [BPR] BPR0=[M:PSH1]BPSNUM(NOL) : If fstat  Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[M:PSH1]BPSNUM(NOL)
  Read [BPS] BPS0=[M:PSH1]BPSNUM(NOL) : If fstat  Raz [F:BPS] : Endif
Endif
#-----
[F:TB0]=[M:PSH0] : [F:TB0]=[M:PSH1]
If [F:TB0]LINPURTYP=0  [F:TB0]LINPURTYP=1 : Endif
# Issue 76225 - 2011-09-13 by VPO : pour evaluation d'un compte avec un modificateur lié au code taxe
# il manquait l'affectation des VAT
[F:TB0]VAT(0)=[M:PSH1]VAT1(NOL)
[F:TB0]VAT(1)=[M:PSH1]VAT2(NOL)
[F:TB0]VAT(2)=[M:PSH1]VAT3(NOL)
#----- Chargement pseudo fichier lignes comptables CPTANALIN [TB2] -----#
Raz [F:TB2]
[F:TB2]ABRFIC="PSD"
[F:TB2]VCRNUM=[M:PSH0]PSHNUM
[F:TB2]VCRLIN=[M:PSH1]PSDLIN(NOL)
[F:TB2]VCRSEQ=1
[F:TB2]ANALIG=1
For I=1 To max(GNBCOA,2)
  J=GTYPLED(I)
  If J
    [F:TB2]LED(J-1)=GLEDSOC(I)
    [F:TB2]COA(J-1)=GCOA(I)
    [F:TB2]ACC(J-1)=evalue("[M:PSH1]LINACC"+num$(I)+"(NOL)")
  Endif
Next I
For I=1 To max(GNBDIE,GOPTCANA)
  [F:TB2]DIE(I-1)=GDIE(I)
  If evalue("dim([M:PSH1]CCE"+num$(I)+")")>0
    [F:TB2]CCE(I-1)=evalue("[M:PSH1]CCE"+num$(I)+"(NOL)")
  Endif
Next I
#-----
If [M:PSH0]PSHNUM=""
  Raz ID1,ID2
Else
  ID1(1)=[M:PSH0]PSHNUM
  ID1(2)=num$([M:PSH1]PSDLIN(NOL))
Endif
#-----
Call COMPTE("PQUIS",1,ID1,ID2,TPLAN,TCOMPTE,STA,WMESSAGE) From TRTACHCDE1
If STA
  Raz TPLAN, TCOMPTE
Else
  For I=1 To 10
    If TPLAN(I)<>""
     #J=find(TPLAN(I),GCOA(1..GNBCOA))
      J=find([F:GAD]LEDTYP(I-1),GTYPLED(1..GNBTYPLED))
      If J
        Assign "[M:PSH1]LINACC"+num$(J)+"(NOL)" With TCOMPTE(I)
      Endif
    Endif
  Next I
Endif
#-----
Close Local File [TB0], [TB2]
nolign=SAVNOLIGN
End


$PREP_INIT_CCE
#-----------------------------------------------------------------------------#
# Préparation des sections analytiques                                        #
# --------------------------------------------------------------------------- #
# Si l'axe est suivi en analytique et que la section correspondante est vide  #
#    il faut forcer l'initialisation grâce au Raz                             #
# Si l'axe n'est pas suivi en analytique                                      #
#    il faut "mettre  à blanc" la section correspondante                      #
# --------------------------------------------------------------------------- #
# NOL contient l'indice de la ligne en cours                                  #
# [M:PSH1]LINACC1-10(NOL) contient les comptes                                #
# GBIDI2 : 0 = Pas d'affichage des sections analytiques                       #
#          1 = Affichage des sections analytiques                             #
#-----------------------------------------------------------------------------#
If dim(I)<1    Local Integer I             : Endif
If dim(WCCE)<1 Local Char    WCCE(GLONCCE) : Endif
#----- Pas de section si pas de suivi analytique sur l'axe concerné -----#
For I=1 To GNBDIE
  WCCE=evalue("[M:PSH1]CCE"+num$(I)+"(NOL)")
  Raz mkstat
  Call SAIS_CCE(WCCE,I,"[M:PSH1]LINACC","") From TRTX3CPT
  If mkstat
    Assign "[M:PSH1]CCE"+num$(I)+"(NOL)" With ""
    Raz mkstat
  Elsif evalue("[M:PSH1]CCE"+num$(I)+"(NOL)")=""
    #----- Raz pour forcer l'initialisation -----#
    Case I
      When  1 : Raz [M:PSH1]CCE1 (NOL)
      When  2 : Raz [M:PSH1]CCE2 (NOL)
      When  3 : Raz [M:PSH1]CCE3 (NOL)
      When  4 : Raz [M:PSH1]CCE4 (NOL)
      When  5 : Raz [M:PSH1]CCE5 (NOL)
      When  6 : Raz [M:PSH1]CCE6 (NOL)
      When  7 : Raz [M:PSH1]CCE7 (NOL)
      When  8 : Raz [M:PSH1]CCE8 (NOL)
      When  9 : Raz [M:PSH1]CCE9 (NOL)
      When 10 : Raz [M:PSH1]CCE10(NOL)
      When 11 : Raz [M:PSH1]CCE11(NOL)
      When 12 : Raz [M:PSH1]CCE12(NOL)
      When 13 : Raz [M:PSH1]CCE13(NOL)
      When 14 : Raz [M:PSH1]CCE14(NOL)
      When 15 : Raz [M:PSH1]CCE15(NOL)
      When 16 : Raz [M:PSH1]CCE16(NOL)
      When 17 : Raz [M:PSH1]CCE17(NOL)
      When 18 : Raz [M:PSH1]CCE18(NOL)
      When 19 : Raz [M:PSH1]CCE19(NOL)
      When 20 : Raz [M:PSH1]CCE20(NOL)
    Endcase
  Endif
Next I
#----- Affichage des sections analytiques -----#
If GBIDI2=1
  Gosub AFFICH_CCE
Endif
Return

$RAZ_LINACC
#---------------------------------------#
# Effacement des comptes de la ligne DA #
#---------------------------------------#
If dim(J)<1  Local Integer J : Endif
For J=1 To GNBCOA
  Case J
    When  1 : Raz [M:PSH1]LINACC1 (NOL)
    When  2 : Raz [M:PSH1]LINACC2 (NOL)
    When  3 : Raz [M:PSH1]LINACC3 (NOL)
    When  4 : Raz [M:PSH1]LINACC4 (NOL)
    When  5 : Raz [M:PSH1]LINACC5 (NOL)
    When  6 : Raz [M:PSH1]LINACC6 (NOL)
    When  7 : Raz [M:PSH1]LINACC7 (NOL)
    When  8 : Raz [M:PSH1]LINACC8 (NOL)
    When  9 : Raz [M:PSH1]LINACC9 (NOL)
    When 10 : Raz [M:PSH1]LINACC10(NOL)
  Endcase
Next J
Return


$AFFICH_LINACC
#--------------------------------------#
# Affichage des comptes de la ligne DA #
#--------------------------------------#
If dim(I)<1  Local Integer I : Endif
For I=1 To GNBCOA
  Case I
    When  1 : Affzo [PSH1]LINACC1 (NOL)
    When  2 : Affzo [PSH1]LINACC2 (NOL)
    When  3 : Affzo [PSH1]LINACC3 (NOL)
    When  4 : Affzo [PSH1]LINACC4 (NOL)
    When  5 : Affzo [PSH1]LINACC5 (NOL)
    When  6 : Affzo [PSH1]LINACC6 (NOL)
    When  7 : Affzo [PSH1]LINACC7 (NOL)
    When  8 : Affzo [PSH1]LINACC8 (NOL)
    When  9 : Affzo [PSH1]LINACC9 (NOL)
    When 10 : Affzo [PSH1]LINACC10(NOL)
  Endcase
Next I
Return


