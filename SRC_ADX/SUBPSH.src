$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE>GNBDIE  Return : Endif
Call INIT_CCE(VALEUR,AXE,"PSD","[M:PSH1]LINACC",nolign-1) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
If GMODIF<>1  mkstat=2 : Return : Endif
Call SAIS_CCE(VALEUR,AXE,"[M:PSH1]LINACC","") From TRTX3CPT
# Issue 76502 - 2011-09-27 by VPO : on refait init pour cas sections précedentes
#car PREP_INIT_CCE déjà fait sur comptes
If !mkstat
   If VALEUR=""
      Call INIT_CCE(VALEUR,AXE,"PSD","[M:PSH1]LINACC",nolign-1) From TRTX3CPT
   Endif
Endif
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
Call CTRL_CCE(VALEUR,AXE,"[M:PSH1]LINACC",GFINRSP,[M:PSH0]PRQDAT) From TRTX3CPT
Return

