#<AdxTL>@(#)4.0.0.0 $Revision$
########################################################################
#               GESTION DES DEMANDES D'ACHAT                           #
# GCUR    = devise societe        GSYSCUR = devise dossier             #
# GFINRSP = site financier                                             #
#                                                                      #
# Attention il existe aussi un SUBPSH1 (suite)                         #
# Penser si ajout de zone dans ecran PSH1 à la duplication --> SUBPSH1 #
# -------------------------------------------------------------------- #
#                                                    cg novembre 1997  #
########################################################################

$ACTION
Case ACTION
 When "DEFTRANS"     : Gosub DEFTRANS     From SUBPSH1
 When "VARIANTE"     : Gosub VARIANTE     From SUBPSH1
 When "SETTRANS"     : Gosub SETTRANS     From SUBPSH1
 When "OUVRE"        : Gosub OUVRE        From SUBPSH1
 When "SETBOUT"      : Gosub SETBOUT      From SUBPSH1
 When "AVANTBOUT"    : Gosub AVANTBOUT    From SUBPSH1
 When "STATUT"       : Gosub STATUT       From SUBPSH1
 When "EXEBOUT"      : Gosub EXEBOUT      From SUBPSH1
 When "FILTRE"       : Gosub FILTRE       From SUBPSH1
 When "LIENS"        : Gosub LIENS        From SUBPSH1
 When "AV_IMPRIME"   : Gosub AV_IMPRIME   From SUBPSH1
 When "AP_IMPRIME"   : Gosub AP_IMPRIME   From SUBPSH1
 When "DEFLIG"       : Gosub DEFLIG       From SUBPSH1
 When "LIENS_LIG"    : Gosub LIENS_LIG    From SUBPSH1
 When "ABANDON"      : Gosub ABANDON      From SUBPSH1
 When "RAZCRE"       : Gosub RAZCRE       From SUBPSH1
 When "RAZDUP"       : Gosub RAZDUP       From SUBPSH1
 When "EFFMASK"      : Gosub EFFMASK      From SUBPSH1
 When "APRES_MODIF"  : Gosub APRES_MODIF  From SUBPSH1 # Issue 93463 - 2014-01-27 by SR
 When "VERIF_CRE"    : Gosub VERIF        From SUBPSH1
 When "VERIF_MOD"    : Gosub VERIF        From SUBPSH1
 When "INICRE"       : Gosub INICRE       From SUBPSH1
 When "INICRE_LIG"   : Gosub INICRE_LIG   From SUBPSH1
 When "CREATION"     : Gosub CREATION     From SUBPSH1
 When "APRES_CRE"    : Gosub APRES_CRE    From SUBPSH1
 When "AB_CREATION"  : Gosub AB_CREATION  From SUBPSH1
 When "AVANT_MOD"    : Gosub AVANT_MOD    From SUBPSH1
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC From SUBPSH1
 When "INIMOD"       : Gosub INIMOD       From SUBPSH1
 When "INIMOD_LIG"   : Gosub INIMOD_LIG   From SUBPSH1
 When "MODIF"        : Gosub MODIF        From SUBPSH1
 When "VALLIG"       : Gosub VALLIG       From SUBPSH1
 When "APRES_MOD"    : Gosub APRES_MOD    From SUBPSH1
 When "AB_MODIF"     : Gosub AB_MODIF     From SUBPSH1
 When "VERF_ANU"     : Gosub VERF_ANU     From SUBPSH1
 When "ANNULE"       : Gosub ANNULE       From SUBPSH1
 When "FERME"        : Gosub FERME        From SUBPSH1
 When Default
Endcase
Case ACTION
 When "AAM_PRHFCY"   : Gosub AAM_PRHFCY
 When "BAM_PRHFCY"   : Gosub BAM_PRHFCY
Endcase
Return
################################################################################
#################### NON STANDARD ##############################################
################################################################################
################################################################################

$INI_TARIF
#----------------------------------------#
# recherche tarif PPRICLISt et PPRICCONF #
# uniquement en creation ou duplication  #
# ou en ajout de ligne                   #
#----------------------------------------#
Local Integer WRETOUR
Local Decimal WPRIX, YEA_COUT
Local Integer WSTAT
Local Shortint SNOLIGN
WPRIX   = 0
WRETOUR = 1
SNOLIGN = nolign
If [M:PSH1]PQHNUM(nolign-1)<>"" & [M:PSH1]NETPRI(nolign-1)<> 0
   [M:PSH1]GROPRI(nolign-1)=[M:PSH1]NETPRI(nolign-1) : Return
Endif
If [F:BPS]BPSNUM <> [M:PSH1]BPSNUM (nolign-1)
  Read [BPS] BPS0 = [M:PSH1]BPSNUM (nolign-1)
  If fstat  Raz [F:BPS] : Endif
Endif
GPLISTC = [F:BPS]PLISTC : Call TARIFCHGT (6) From TRTPRICE
Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
#----- Chargement devise et type de cours si nécessaire -----#
If [M:PSH1]CUR(nolign-1)=""
  If [F:BPS]BPSNUM<>""
    [M:PSH1]CUR   (nolign-1)=GCUR
    [M:PSH1]CHGTYP(nolign-1)=GPURCHGTYP
  Else
    [M:PSH1]CUR   (nolign-1)=[F:BPS]CUR
    [M:PSH1]CHGTYP(nolign-1)=[F:BPS]CHGTYP
  Endif
Endif
#-----
If [M:PSH1]PRIFLG (nolign-1) <> 2
  [M:PSH1]PRIFLG (nolign-1) = 2
  If GPSHVLT = 2
    Call RECH_TARIF("PSH",nolign-1) From TRTACHTAR1
  Endif
  # Issue 95247 - 2014-01-02 by MUARN : gestion des gratuits selon PRIREN
  #If [M:PSH1]NETPRI (nolign-1) = 0 & GPURPRICE = 2
  If [M:PSH1]NETPRI (nolign-1) = 0 & GPURPRICE = 2 & [M:PSH1]PRIREN(nolign-1) = 0
    If clalev([F:ITC])=0  Local File ITMCOST [F:ITC] : Endif
    Local Char     LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)
    If dim([M:PSH1]ECCVALMAJ)>0
        # only one version is possible here
        [L]LECCMAJ  =[M:PSH1]ECCVALMAJ(nolign-1)
        [L]LECCMIN  =[M:PSH1]ECCVALMIN(nolign-1)
    Endif
    Call GETPRI([M:PSH1]ITMREF(nolign-1),LECCMAJ,LECCMIN,[M:PSH1]PRHFCY(nolign-1),[M:PSH0]PRQDAT,1,"","",1,GBIDD3,WSTAT) From STKVAL
    If WSTAT = 0
      GBIDD3 = [F:ITC]VLTTOT
      #----- Conversion si nécessaire à cause de la devise -----#
      If GCUR <> [M:PSH1]CUR (nolign-1)
        Call CONVERT2(GCUR,[M:PSH1]CUR(nolign-1),GCUR,[M:PSH1]CHGTYP(nolign-1),datesyst,
&                     [F:ITC]VLTTOT,GBIDD3,WSTAT) From TRTDEV
      Endif
      #------ Conversion si nécessaire à cause de l'unité ------#
      If [M:PSH1]PUU(nolign-1)<>[M:PSH1]STU(nolign-1)
        #----- Appel du S/P pour chargement du coefficient avec précision maxi -----#
        Call PCAL_QTY([M:PSH1]QTYPUU(nolign-1),[M:PSH1]PUU(nolign-1),GBIDD1,[M:PSH1]STU(nolign-1),
&                     [M:PSH1]ITMREF(nolign-1),[M:PSH1]BPSNUM(nolign-1),1,GBIDD2) From TRTACHQTE1
        If GBIDD2=0 GBIDD2=1 : Endif
        GBIDD3=GBIDD3*GBIDD2
      Endif
      #----- Prix brut et prix net -----#
      [M:PSH1]NETPRI (nolign-1) = arr(GBIDD3,10^-GDECPRI)
      [M:PSH1]GROPRI (nolign-1) = [M:PSH1]NETPRI (nolign-1)
      #----- Motif prix brut -----#
      [M:PSH1]PRIREN (nolign-1) = GUPDPRIPUR
      #VPO 26/10/10 LINFLG=1 DOIT ETRE FAIT UNIQUEMENT SUR APRES_NBLIG
      #[M:PSH1]LINFLG (nolign-1) = 1
    Endif
  Endif
  #----- Calcul et affichage du montant ligne -----#
  [M:PSH1]LINAMT(nolign-1)=[M:PSH1]NETPRI(nolign-1)*[M:PSH1]QTYPUU(nolign-1)
  Call ARRDEV([M:PSH1]LINAMT(nolign-1),[M:PSH1]CUR(nolign-1)) From TRTDIV
  If !GIMPORT
    Affzo [PSH1]NETPRI(nolign-1), LINAMT(nolign-1), CUR(nolign-1)
  Endif
Endif
nolign = SNOLIGN
Return

#######################################################################################
$INSERTION_BESOIN
Local Decimal WCOEUOM
Local Integer WNOLIGN
WNOLIGN = nolign
Local Integer NBRLIG , NBPOSTE
Local Integer I,J,K
Local Decimal WRETQTY

NBRLIG    = 0
#----------------------------------------------------#
# il faut calculer le nombre de ligne à creer        #
# tri du tableau sur qte pris en compte et sur site  #
#----------------------------------------------------#
Sorta [M:PPI1]NBLIG [M:PPI1]NBLIG Order By [M:PPI1]STOFCY (indice),
&                                          [M:PPI1]WPJT   (indice),
&                                          [M:PPI1]PICQTY (indice)

For I = 0 To [M:PPI1]NBLIG -1
   If [M:PPI1]PICQTY (I) <> 0
          NBRLIG +=1
     Endif
Next I
NBPOSTE = NBRLIG

If NBRLIG = 0 : Return : Endif

#------------------------------------------------------#
# EXPLOITATION DU PICKING AVEC REGROUPEMENT sur le site#
#------------------------------------------------------#
Call TEMPON ("O") From GESECRAN
Call DEBTRANS From GLOCK
Trbegin [PWO]
    Raz [M:PSH1]QTYPUU(WNOLIGN-1), [M:PSH1]PRHFCY(WNOLIGN-1), [F:PWO]

    [M:PSH1]WPWOLIN  (WNOLIGN-1) = max([M:PSH1]WPWOLIN (0..[M:PSH1]NBLIG-1))+1
    If [M:PSH1]WPWOLIN (WNOLIGN-1) <= 0
           [M:PSH1]WPWOLIN (WNOLIGN-1) = 1
    Endif
    If [F:ITM]ITMREF <> [M:PPI1]ITMREF
        Read [ITM]ITM0 = [M:PPI1]ITMREF
        If fstat : Raz [F:ITM] : Endif
    Endif

    #-- fichier temporaire
    [F:PWO]PRONUM = adxuid(1)
    [F:PWO]CODFNC = "PSH"
    [F:PWO]LINNUM = [M:PSH1]WPWOLIN(WNOLIGN-1)
    [F:PWO]ITMREF = [M:PPI1]ITMREF
    [F:PWO]PUU    = [F:ITM]PUU
    [F:PWO]STU    = [F:ITM]STU

    #-- pas d insertion sur la premiere ligne puisque
    #-- on est deja en insertion apres ref article
    If [M:PSH1]PQHNUM(WNOLIGN-1)="" : # Déja chargé si appel d'offre pris en compte
       [M:PSH1]ITMREF (WNOLIGN-1) = [F:ITM]ITMREF
       [M:PSH1]STU    (WNOLIGN-1) = [F:ITM]STU
       [M:PSH1]PUU    (WNOLIGN-1) = [F:ITM]PUU
       #----- Chargement des désignations article -----#
       #Call CHARGE_ITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PSH1]ITMDES(WNOLIGN-1)) From TRTX3
       #If [M:PSH1]ITMDES(WNOLIGN-1)="" [M:PSH1]ITMDES(WNOLIGN-1)=[F:ITM]ITMDES1 : Endif
       # Issue 78167 - 2011-11-24 by VPO : designation traduite selon la langue du fourn
       If [M:PSH1]BPSNUM(WNOLIGN-1)<>""
         #lecture BPR
         If [F:BPR]BPRNUM<>[M:PSH1]BPSNUM(WNOLIGN-1)
           Read [BPR] BPR0=[M:PSH1]BPSNUM(WNOLIGN-1)
           If fstat Raz [F:BPR] : Endif
         Endif
         If [F:BPR]LAN="" : [F:BPR]LAN=GLANGUE : Endif
         [M:PSH1]LAN(WNOLIGN-1)=[F:BPR]LAN
         Call CHARGE_DEFITMDES("DES1AXX",[M:PSH1]LAN(WNOLIGN-1),[F:ITM]ITMREF,[M:PSH1]ITMDES(WNOLIGN-1), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
       Else
         [M:PSH1]LAN(WNOLIGN-1)=GLANGUE
         Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PSH1]ITMDES(WNOLIGN-1), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
       Endif
       #[M:PSH1]ITMDES1(WNOLIGN-1) = [F:ITM]ITMDES1
       Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PSH1]ITMDES1(WNOLIGN-1), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
    Endif

    nolign = WNOLIGN
    Raz GMESSAGE
    For I=0 To [M:PPI1]NBLIG-1
         If [M:PPI1]PICQTY(I)<>0
             Gosub CHGCRE_LIG
             # Issue 71069 - 2013-08-22 by SR : PJT
             If mkstat <> 0 | GERR : Break  : Endif
         Endif
    Next I
    # Issue 71069 - 2013-08-22 by SR : PJT
    If mkstat <> 0 | GERR
         Rollback
    Else
         Gosub FIN_LIGNE
          # Issue X3-38385- 2017-05-30 by SR : Tester le retour
         If mkstat : Rollback : Else : Commit : Endif
#         Commit
         # End issue X3-38385
    Endif
    If GMESSAGE<>"" & !mkstat
      Call MESSAGE (GMESSAGE) From GESECRAN : Raz GMESSAGE
    Endif

Call TEMPOFF From GESECRAN
nolign = WNOLIGN
Return

###########################################################################
$CHGCRE_LIG
mkstat = 0
[F:PWO]WIPTYP = [M:PPI1]WIPTYP (I)
[F:PWO]WIPSTA = [M:PPI1]WIPSTA (I)
[F:PWO]WIPNUM = [M:PPI1]WIPNUM (I)
[F:PWO]PSDLIN = 0
# Issue 71069 - 2013-08-22 by SR : PJT
# Si première ligne & pas de code affaire à l'entête  et mono affaire on alimente le code affaire à l'entête
If [M:PSH1]PRHFCY (nolign-1) = "" & [M:PSH0]PJTH = "" & GPJTSNGDOC = 2
   [M:PSH0]PJTH = [M:PPI1]WPJT(I)
   WZONE = "[M:PSH0]PJTH"
   If func TRTPJT.IS_PJT_AVAILABLE([M:PPI1]WPJT(I),WZONE, SWMESS) = G_NON Then
    Call PJT_ADD_MSG([M:PPI1]WPJT(I), SWMESS) From TRTPJT
    GERR = 1
    OK = 0
    GMESSAGE = SWMESS
    Raz [M:PSH0]PJTH
    Return
  Endif
Endif
If [M:PSH1]PRHFCY (nolign-1) = ""
        [M:PSH1]PRHFCY (nolign-1)    = [M:PPI1]STOFCY (I)
        [M:PSH1]EXTRCPDAT (nolign-1) = [M:PPI1]ENDDAT (I)
        [M:PSH1]PJT(nolign-1)        = [M:PPI1]WPJT(I)
Endif
WZONE = "[M:PSH1]PJT"
If func TRTPJT.IS_PJT_AVAILABLE([M:PPI1]WPJT(I),WZONE, SWMESS) = G_NON Then
  Call PJT_ADD_MSG([M:PPI1]WPJT(I), SWMESS) From TRTPJT
  GERR = 1
  OK = 0
  GMESSAGE = SWMESS
#  Raz [M:PSH1]PJT(nolign-1)
  Return
Endif
# FIN Issue 71069 - 2013-08-22 by SR

#-----------------------------------------------------------------------------------#
# si rupture sur site reception ou affaire fin de la ligne et passage à autre ligne #
#-----------------------------------------------------------------------------------#
If [M:PSH1]PRHFCY (nolign-1) <> [M:PPI1]STOFCY (I) |
&  [M:PSH1]PJT (nolign-1)    <> [M:PPI1]WPJT (I)
    Gosub FIN_LIGNE
    #--------------------------------#
    # creation de la nouvelle ligne  #
    #--------------------------------#
    nolign +=1
    status = 73
    If dim([M:PSH1]ITMREF) = [M:PSH1]NBLIG
        GERR = 1 : GMESSAGE=mess(122,199,1)
        mkstat = 2
        nolign -=1
        Return
    Endif
    Call INSERE("PSDLIN") From TABLEAUX
    If mkstat <> 2
        If dim([M:PSH1]ITMREF) = [M:PSH1]NBLIG+1
              Insa nolign-1,1 [M:PSH1]NBLIG : # pas de borne sinon plantage
        Else  Insa nolign-1,1,[M:PSH1]NBLIG [M:PSH1]NBLIG
        Endif
        [M:PSH1]NBLIG +=1
        [M:PPI1]NBCRELIG += 1

        status = 0
        Call LINNUM("PSDLIN") From TABLEAUX

        #-- duplication des info de la ligne précédente
        Call DUPLI(nolign-1) From SUBPSH1
        If [F:ITM]ITMREF <> [M:PPI1]ITMREF
            Read [ITM]ITM0 = [M:PPI1]ITMREF
            If fstat : Raz [F:ITM] : Endif
        Endif
        #-------------------------#
        # chargement de la ligne  #
        #-------------------------#
#       #-- Attention certaines zones sont déja chargées par la duplication
#       #--UA et la désignation peuvent être
#       #-- différentes de celles de l'article si un appel d'offre a été pris en compte
        [M:PSH1]PRHFCY (nolign-1)    = [M:PPI1]STOFCY (I)
        [M:PSH1]EXTRCPDAT (nolign-1) = [M:PPI1]ENDDAT (I)
        [M:PSH1]PJT (nolign-1)       = [M:PPI1]WPJT (I)

        [M:PSH1]WPWOLIN  (nolign-1) = max([M:PSH1]WPWOLIN (0.. [M:PSH1]NBLIG-1))+1
        If [M:PSH1]WPWOLIN (nolign-1) <= 0
            [M:PSH1]WPWOLIN (nolign-1) = 1
        Endif

        [F:PWO]LINNUM = [M:PSH1]WPWOLIN(nolign-1)
        Raz [M:PSH1]QTYPUU (nolign-1)
    Else
         nolign-=1
         Return
    Endif
Endif

#-- conversion qté prise en ua de l'article
WRETQTY=min([M:PPI1]PICQTY(I),[M:PPI1]RMNEXTQTY(I))
Call PCAL_QTY([M:PPI1]PICQTY(I),[M:PPI1]UOM,
&           GBIDD3,[M:PSH1]PUU(nolign-1),[F:ITM]ITMREF,"",1,WCOEUOM) From TRTACHQTE1
If WRETQTY<>[M:PPI1]PICQTY(I)
  Call PCAL_QTY(WRETQTY,[M:PPI1]UOM,[F:PWO]QTYPUU,[M:PSH1]PUU(nolign-1),
&               [F:ITM]ITMREF,"",1,WCOEUOM) From TRTACHQTE1
Else
  [F:PWO]QTYPUU=GBIDD3
Endif
[M:PSH1]QTYPUU (nolign-1) += GBIDD3
#-- qté consommée en UA
[M:PSH1]WQTYORDPUU(nolign-1)+=[F:PWO]QTYPUU
#-- conversion qté prise en us
Call PCAL_QTY(WRETQTY,[M:PPI1]UOM,[F:PWO]QTYSTU,[F:PWO]STU,
&             [F:ITM]ITMREF,"",1,WCOEUOM) From TRTACHQTE1
#-- qté consommée en US
[M:PSH1]WQTYORDSTU(nolign-1)+=[F:PWO]QTYSTU
#--- mise à jour date reception
If [M:PSH1]EXTRCPDAT (nolign-1) > [M:PPI1]ENDDAT (I)
    [M:PSH1]EXTRCPDAT (nolign-1) = [M:PPI1]ENDDAT (I)
Endif

Write [PWO]
If fstat mkstat = 2 : Endif

Return

#########################################################################
$FIN_LIGNE
#-----
Local Decimal WCOEUOM, WQTY, YEA_COUT
Local Integer WSTAT
# Issue X3-55891 - 2018-08-13 by MUARN : exploitation table article/fournisseur/site
Local Char    WBPSNUM(GLONBPS)
Local Integer WITMBPS : WITMBPS = 0
#-----
If GAPPPSH>1
  [M:PSH1]LINAPPFLG (nolign-1) = 1
Else
  [M:PSH1]LINAPPFLG (nolign-1) = 4
Endif
#----- Conversion qté prise en US -----#
Call PCAL_QTY([M:PSH1]QTYPUU(nolign-1),[M:PSH1]PUU(nolign-1),[M:PSH1]QTYSTU(nolign-1),[M:PSH1]STU(nolign-1)
&        ,[M:PSH1]ITMREF(nolign-1),[M:PSH1]BPSNUM(nolign-1),1,WCOEUOM) From TRTACHQTE1
#----- Recherche du fournisseur si aucun appel d'offre pris en compte -----#
If [M:PSH1]PQHNUM(nolign-1)=""
   Raz [F:ITP], [F:ITPF], WBPSNUM
   # Issue X3-55891 - 2018-08-13 by MUARN : exploitation table article/fournisseur/site
#   # Issue X3-38385 - 2017-05-30 by SR : ne pas prendre un fournisseur = site de demande
#   #For [ITP] ITP1 Where ITMREF=[M:PSH1]ITMREF(nolign-1) & DOUFLG<>3
#   For [ITP] ITP1 Where ITMREF=[M:PSH1]ITMREF(nolign-1) & DOUFLG<>3 & BPSNUM <> [M:PSH0]PSHFCY
#      [M:PSH1]BPSNUM(nolign-1)=[F:ITP]BPSNUM : Break
#   Next
   Call DEFBPSNUM([M:PSH1]ITMREF(nolign-1),[M:PSH0]PSHFCY,[M:PSH1]PRHFCY(nolign-1),"",1,WBPSNUM,WITMBPS) From TRTACHDEF1
   # [M:PSH1]BPSNUM(NOL)=WBPSNUM
   # End issue X3-55891
   #-- Prendre PUU du couple fournisseur article
   If [F:ITP]BPSNUM <> ""
       #-------------------------#
       # chargement de la devise #
       # il faut lire BPARTNER   #
       #-------------------------#
       If [F:BPR]BPRNUM<>[F:ITP]BPSNUM
         Read [BPR] BPR0=[F:ITP]BPSNUM : If fstat  Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : Endif
       Endif
       If [F:BPS]BPSNUM<>[F:ITP]BPSNUM
         Read [BPS] BPS0=[F:ITP]BPSNUM : If fstat  Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
       Endif

       [M:PSH1]CUR(nolign-1) = [F:BPS]CUR
       Call PCAL_QTY ([M:PSH1]QTYPUU(nolign-1),[M:PSH1]PUU(nolign-1),WQTY,[F:ITP]PUU
&                    ,[M:PSH1]ITMREF (nolign-1),[F:ITP]BPSNUM,1,WCOEUOM) From TRTACHQTE1

       [M:PSH1]PUU (nolign-1)    = [F:ITP]PUU
       [M:PSH1]QTYPUU(nolign-1)  = WQTY

   Else
      #-------------------------------------------#
      # couple article - fournisseur n'existe pas #
      # mais pas de test du parametre GITMBPS     #
      #-------------------------------------------#
      [M:PSH1]BPSNUM (nolign-1) = ""
   Endif
Endif
# Issue X3-55891 - 2018-08-30 by SR : Ne charger [M:PSH1]BPSNUM que si  AM-BPSNUM OK
#Call AM_BPSNUM([M:PSH1]BPSNUM(nolign-1))
# Issue X3-38385 - 2017-05-30 by SR : Tester le code retour
#If mkstat : Return : Endif
Call AM_BPSNUM(WBPSNUM)
If mkstat
   Return
Else
   [M:PSH1]BPSNUM(nolign-1)=WBPSNUM
Endif
# End issue X3-55891
#----- Recalcul des qté en US -----#
Call PCAL_QTY([M:PSH1]QTYPUU(nolign-1),[M:PSH1]PUU(nolign-1),[M:PSH1]QTYSTU(nolign-1),[M:PSH1]STU(nolign-1)
&        ,[M:PSH1]ITMREF (nolign-1),[M:PSH1]BPSNUM(nolign-1),1,WCOEUOM) From TRTACHQTE1

#----- Date prévue de commande et contrôle indisponibilités  fournisseur -----#
[M:PSH1]EXTORDDAT(nolign-1)=[M:PSH1]EXTRCPDAT(nolign-1)-[M:PSH1]OFS(nolign-1)
If [F:BPS]BPSNUM<>[M:PSH1]BPSNUM(nolign-1)
  Read [BPS] BPS0=[M:PSH1]BPSNUM(nolign-1) : If fstat Raz [F:BPS] : Endif
Endif
Call CTL_PER ([M:PSH1]EXTORDDAT(nolign-1),[F:BPS]UVYCOD) From CONTX3
If mkstat
  GMESSAGE=mess(73,198,1)-[M:PSH1]BPSNUM(nolign-1)+"\"+GMESSAGE
  GMESSAGE=mess(1,503,1)-format$("D:"+GFMDAT,[M:PSH1]EXTORDDAT(nolign-1))-GMESSAGE
  Raz mkstat
Endif

#-- recup prix net
[M:PSH1]NETPRI(nolign-1) =  0
[M:PSH1]GROPRI(nolign-1) =  0

[M:PSH1]PRIFLG(nolign-1) = 2
If GPSHVLT = 2
  #------------------------------------------------------------------#
  # recherche tarif : si parametre valorisation ligne DA = recherche #
  #------------------------------------------------------------------#
  Call RECH_TARIF("PSH",nolign-1) From TRTACHTAR1
Endif
# Issue 95247 - 2014-01-02 by MUARN : gestion des gratuits selon PRIREN
#If [M:PSH1]NETPRI (nolign-1) = 0 & GPURPRICE = 2
If [M:PSH1]NETPRI (nolign-1) = 0 & GPURPRICE = 2 & [M:PSH1]PRIREN(nolign-1) = 0
  #-----------------#
  # prix standard   #
  #-----------------#
  If clalev([ITC])=0  Local File ITMCOST [ITC] : Endif
  Local Char     LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)
  If dim([M:PSH1]ECCVALMAJ)>0
      [L]LECCMAJ  =[M:PSH1]ECCVALMAJ(nolign-1)
      [L]LECCMIN  =[M:PSH1]ECCVALMIN(nolign-1)
  Endif
  Call GETPRI([M:PSH1]ITMREF(nolign-1),LECCMAJ,LECCMIN,[M:PSH1]PRHFCY(nolign-1),[M:PSH0]PRQDAT,1,"","",1,GBIDD3,WSTAT) From STKVAL
  If WSTAT = 0
    GBIDD3 = [F:ITC]VLTTOT
    #----- Conversion si nécessaire à cause de la devise -----#
    If GCUR <> [M:PSH1]CUR (nolign-1)
      Call CONVERT2(GCUR,[M:PSH1]CUR(nolign-1),GCUR,[M:PSH1]CHGTYP(nolign-1),datesyst,
&                   [F:ITC]VLTTOT,GBIDD3,WSTAT) From TRTDEV
    Endif
    #------ Conversion si nécessaire à cause de l'unité ------#
    If [M:PSH1]PUU(nolign-1)<>[M:PSH1]STU(nolign-1)
      #----- Appel du S/P pour chargement du coefficient avec précision maxi -----#
      Call PCAL_QTY([M:PSH1]QTYPUU(nolign-1),[M:PSH1]PUU(nolign-1),GBIDD1,[M:PSH1]STU(nolign-1),
&                   [M:PSH1]ITMREF(nolign-1),[M:PSH1]BPSNUM(nolign-1),1,GBIDD2) From TRTACHQTE1
      If GBIDD2=0 GBIDD2=1 : Endif
      GBIDD3=GBIDD3*GBIDD2
    Endif
    #----- Prix brut et prix net -----#
    [M:PSH1]NETPRI (nolign-1) = arr(GBIDD3,10^-GDECPRI)
    [M:PSH1]GROPRI (nolign-1) = [M:PSH1]NETPRI (nolign-1)
    #----- Motif prix brut -----#
    [M:PSH1]PRIREN (nolign-1) = GUPDPRIPUR
    [M:PSH1]LINFLG (nolign-1) = 1
  Endif
  Default File [PSD]
Endif
#----- calcul montant ligne -----#
[M:PSH1]LINAMT(nolign-1)=[M:PSH1]NETPRI(nolign-1)*[M:PSH1]QTYPUU(nolign-1)
Call ARRDEV([M:PSH1]LINAMT(nolign-1),[M:PSH1]CUR(nolign-1)) From TRTDIV
#----- Initialisation des comptes et du type d'achat -----#
If [M:PSH1]LINACC1(nolign-1)="" & [M:PSH1]LINACC2(nolign-1)=""
  Call INIT_COMPTES_LIGNE(nolign-1) From SUBPSH
Endif
If [M:PSH1]LINPURTYP(nolign-1)=0
  Call D_LINPURTYP([M:PSH1]LINPURTYP(nolign-1)) From SUBPSH
Endif
#----- Initialisation sections analytiques si nécessaire -----#
If GNBDIE>0
  Local Char WSECTION(GLONCCE)
  For J=1 To GNBDIE
    If evalue("[M:PSH1]CCE"+num$(J)+"(nolign-1)")=""
      Call INIT_CCE(WSECTION,J,"PSD","[M:PSH1]LINACC",nolign-1) From TRTX3CPT
      Assign "[M:PSH1]CCE"+num$(J)+"(nolign-1)" With WSECTION
    Endif
  Next J
Endif
#----- Récupération des liens texte article ou article-fournisseur -----#
If [F:ITM]ITMREF<>[M:PSH1]ITMREF(nolign-1)
  Read [ITM] ITM0=[M:PSH1]ITMREF(nolign-1)
  If fstat  Raz [F:ITM] : Endif
Endif
[M:PSH1]LINTEX(nolign-1)=[F:ITM]PURTEX
If [M:PSH1]BPSNUM(nolign1)<>""
  If [F:ITP]ITMREF<>[M:PSH1]ITMREF(nolign-1) & [F:ITP]BPSNUM<>[M:PSH1]BPSNUM(nolign-1)
    Read [ITP] ITP0=[M:PSH1]ITMREF(nolign-1);[M:PSH1]BPSNUM(nolign-1)
    If fstat  Raz [F:ITP] : Endif
  Endif
  If [F:ITP]TEX<>""  [M:PSH1]LINTEX(nolign-1)=[F:ITP]TEX : Endif
Endif
Call APRES_NBLIG
Return

########################################################################################
$POSMAJ_PWO
#----------------------------------------------------------------------#
# EXPLOTATION FICHIER DE TRAVAIL "BESOINS PRIS EN COMPTE" D'UNE LIGNE #
#----------------------------------------------------------------------#
For [PWO] PWO0 Where PRONUM=adxuid(1)
&                  & CODFNC="PSH"
&                  & LINNUM=[M:PSH1]WPWOLIN(nolign-1)
    #---- Mise à jour des ordres (Consommation POS OU POP OU SCF) -----#
    Read [ORD] ORD0=[F:PWO]WIPTYP;[F:PWO]WIPNUM;[F:PWO]ITMREF
    If fstat
      Raz [F:ORD]
    Else
      Gosub POINT_ORDLEC From TRTACHMGT1 : # Appel point d'entrée ORDLEC
    Endif
    [M:ORDK]=[F:ORD]
    [M:ORDK]MAJCOD  = "M"
    [M:ORDK]WIPTYP  = [F:PWO]WIPTYP
    [M:ORDK]WIPNUM  = [F:PWO]WIPNUM
    [M:ORDK]ITMREF  = [F:PWO]ITMREF
    [M:ORDK]CPLQTY += [F:PWO]QTYSTU
    If left$([M:ORDK]ABBFIL,1)<>"P"  [M:ORDK]ABBFIL="PUR" : Endif
    Call WIP From TRTWIP
    If GOK<1  Break : Endif
Next
If GOK<1 Return : Endif
Return

#############################################################################
$EFFAC_PWRKORDERS
#--------------------------------------------------------#
# EFFACEMENT FICHIER DE TRAVAIL "BESOINS PRIS EN COMPTE" #
#--------------------------------------------------------#
Call DEBTRANS From GLOCK
$TR_PWO
GOK=1
Trbegin [PWO]
  Delete [PWO] Where PRONUM=adxuid(1) & CODFNC="PSH"
  If fstat=1  GOK=-1 : OK=0 : GLOCK="$PWRKORDERS"-num$(adxuid(1))-"PSH"
              Rollback : Call ROLL From GLOCK
              Goto ROLL_PWO
  Elsif fstat GOK=0  : OK=0 : Call RSTA("PWO",num$(adxuid(1))-"PSH") From GLOCK
              Rollback
  Else
              Commit
  Endif
Return

$ROLL_PWO
If !GROLL Goto TR_PWO : Endif : Return
Return
#############################################################################
$EFFAC_LIG_PWRKORDERS
#--------------------------------------------------------------------#
# EFFACEMENT FICHIER DE TRAVAIL "BESOINS PRIS EN COMPTE" D'UNE LIGNE #
#--------------------------------------------------------------------#
Call DEBTRANS From GLOCK
$TR_LIG_PWO
GOK=1
Trbegin [PWO]
  Delete [PWO] Where PRONUM=adxuid(1)
&                  & CODFNC="PSH"
&                  & LINNUM=[M:PSH1]WPWOLIN(nolign-1)
  If fstat=1
    GOK=-1
    GLOCK="$PWRKORDERS"-num$(adxuid(1))-"PSH"-num$([M:PSH1]WPWOLIN(nolign-1))
    Rollback
    Call ROLL From GLOCK
    Goto ROLL_LIG_PWO
  Elsif fstat
    GOK=0
    Call RSTA("PWO",num$(adxuid(1))-"PSH"-num$([M:PSH1]WPWOLIN(nolign-1))) From GLOCK
    Rollback
  Else
    Commit
  Endif
Return

$ROLL_LIG_PWO
If !GROLL Goto TR_LIG_PWO : Endif : Return
Return

#######################################################################
#############  ACTION CHAMPS        ###################################
#######################################################################

Subprog AM_PSHFCY(VALEUR)
#-----------------------#
# Apres-modif site      #
#-----------------------#
Variable Char     VALEUR
#------------------------------------------#
# rechargement société juridique   Gsociete#
# rechargement du site financier   Gfinrsp #
# rechargement la devise societe   Gcur    #
# initialisation site reception    grcpfcy #
#------------------------------------------#
GFCY=VALEUR
Gosub CHARG_PARAM From SUBPSH1
If GMESSAGE<>""
  Local Char WMESS(80) : WMESS=GMESSAGE
  GFCY=[M:PSH0]PSHFCY : Gosub CHARG_PARAM From SUBPSH1
  GMESSAGE=WMESS
  GERR=1 : mkstat=1 : End
Endif
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL From SUBPSH1
# Issue 71069 - 2013-08-13 by SR : PJT
# A faire avant tout le reste
If GPJTSNGDOC = G_NON Then
 Call PJT_MODFCY(VALEUR,"[M:PSH1]PJT") From TRTPJT
Endif
# Issue 71069 - 2013-08-13 by SR : PJT
# A faire après tout le reste
If GPJTSNGDOC = G_OUI Then
 Call PJT_MODFCY(VALEUR,"[M:PSH1]PJT") From TRTPJT
Endif
End

Subprog AS_PSHNUM(VALEUR)
#--------------------#
# Avant-saisie n° DA #
#--------------------#
Variable Char    VALEUR()
If (GREP="C" | GREP="D") & GMANCOU<>2  mkstat=2 : Endif
End

Subprog C_PSHNUM(VALEUR)
#-------------------------#
# Contrôle sur numéro DA  #
#-------------------------#
Variable Char     VALEUR
#-------- Compteur manuel, numéro obligatoire ! --------#
# If GMANCOU=2 & VALEUR="" GMESSAGE=mess(182,199,1) : mkstat=1 : End : Endif
#----- Rien d'affiché, vérif si un enregistrement existe -----#
If [M:PSH0]PSHNUM="" & GREP<>"C"
   Look [PSH] PSH0=VALEUR
   If fstat GMESSAGE=mess(178,199,1) : mkstat=1 : End : Endif
Endif
#----- Contrôle si fournisseur actif en duplication -----#
If [M:PSH0]PSHNUM<>"" & [M:PSH0]PSHNUM<>VALEUR & GREP=""
  Local Shortint I
  For I=0 To [M:PSH1]NBLIG-1
    If [M:PSH1]BPSNUM(I)<>""
      If [F:BPS]BPSNUM<>[M:PSH1]BPSNUM(I)
        Read [BPS] BPS0=[M:PSH1]BPSNUM(I) : If fstat Raz [F:BPS] : Endif
      Endif
      If [F:BPS]ENAFLG<>2
        GMESSAGE=[M:PSH1]BPSNUM(I)-mess(220,194,1) : mkstat=1 : Break
      Endif
    Endif
  Next I
  If mkstat=1 End : Endif
  #----- Contrôle si le site de demande est un site d'achat -----#
  Call CONTROLE("FCY","G",[M:PSH0]PSHFCY,"",mkstat) From CONTOBJ
  If mkstat   End : Endif
  #-----
Endif
#----- En création ou dupli et cteur manuel, contrôle si no existe déja -----#
If (GREP<>"C" & GREP<>"D") | GMANCOU<>2 End : Endif
VALEUR=vireblc(VALEUR,2)
Look [PSH] PSH0=VALEUR
If !fstat GMESSAGE=mess(22,100,1) : mkstat=1 : End : Endif
#-----
[M:PSH0]PSHNUM=VALEUR
End

Subprog IB_NBLIG
#-------------------------------------------#
# definition bouton budget      f9   GBOUT1 #
# définition bouton duplication f10  GBOUT2 #
# définition bouton solde lign  f11  GBOUT3 #
# définition bouton texte            GBOUT4 #
# définition bouton pré-engagements  GBOUT5 #
# définition bouton explication prix GBOUT6 #
# Historique des suivis signature    GBOUT7 #
# Circuit de signature / signataires GBOUT8 #
# Traçabilité pièces achat           GBOUT9 #
# Situation ligne                    GBOUT10#
#-------------------------------------------#
GBOUT1 = "" : GBOUT2 = "" : GBOUT3 = "" : GBOUT4 = "" : GBOUT5 = "" : GBOUT6 = ""
GBOUT10 = ""
If [M:PSH1]NBLIG <> 0
   GBOUT10 = mess(164,198,1)               : # Situation ligne
   If nolign <= dim([M:PSH1]ITMREF)    : # sinon problème sur derniere ligne
      If [M:PSH1]ITMREF (nolign-1) <> ""
        # --- test  presence du module compta
        If GMODU(2) = 2
          GBOUT1 = mess (37,198,1)  : # Budget
          If GPURCMMPRP=2 & [M:PSH1]CMMPRPNUM(nolign-1)<>""
            GBOUT5=mess(327,198,1)-[M:PSH1]CMMPRPNUM(nolign-1) : # Pré-engagements
          Endif
        Endif
         GBOUT4 = mess(38,198,1)
      Endif
      If GREP <> "T"
            #VPO 29/10/10 59314 autoriser dupli si DA signée auto
            #If [M:PSH1]XAPPFLG<>3 and [M:PSH1]XAPPFLG<>5 and [M:PSH1]XCLEFLG<>2
            If [M:PSH1]XAPPFLG<>3 and [M:PSH1]XCLEFLG<>2
                    GBOUT2 = mess(388,198,1)
            Endif
            #--------------------------------------------#
            # solde ligne  si                            #
            # transaction l'autorise                     #
            # on n est pas en creation ou duplication    #
            # on n est pas en ajout de ligne (pas de test#
            #   ici mais dans le bouton car problème     #
            #  d'affichage des boutons)                  #
            #--------------------------------------------#
            If GREP<>"C" & GREP<>"D" & [F:PTR]CLEBUT=2 & [M:PSH1]ITMREF(nolign-1)<>""
                        GBOUT3 = mess (12,198,1)
            Endif
      Endif
      #-- Si le prix et la devise sont renseignés
      # Issue 95247 - 2014-01-02 by MUARN : gestion des gratuits
      #If [M:PSH1]CUR(nolign-1) <> ""  & [M:PSH1]NETPRI(nolign-1) <> 0
      If [M:PSH1]CUR(nolign-1) <> ""
        GBOUT6=mess(386,198,1)      : # Explication du prix
      Endif
    Endif
Endif
#--- Si solde non autorisé, désactivation du bouton de solde HN 24/08/2000
#--- L'utilisateur a-t-il droit au solde ???
GBIDC2="T": GFCY=[M:PSH0]PSHFCY : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2
  Raz GBOUT3
Endif
#----- Bouton 7 : Historique des suivis signature de la ligne -----#
If GPSHAPPHEA=2 | [M:PSH1]CREFLG(nolign-1)=0
  Raz GBOUT7, GBOUT8
Else
  GBOUT7=mess(118,75,1) : # Historique signatures
  GBOUT8=mess(161,75,1) : # Circuit de signature
Endif

Call IB_NOTECHECK([M:PSH1]ITMREF(nolign-1),"ITMREF",11)  From TRTNTSCTL # product notes

If find(GREP,"C","D") or find("CONSPIA",GNAVIG(1..GPILNAV)) Then Raz GBOUT9 Endif # SYMEU 09/12/2008 : branchement traçabilité pièces
End

Subprog B2_NBLIG
#----------------------#
# Bouton "Duplication" #
#----------------------#
#VPO 29/10/10 59314 autoriser dupli si DA signée auto
#If [M:PSH1]XAPPFLG = 3 | [M:PSH1]XAPPFLG = 5 | [M:PSH1]XCLEFLG = 2
If [M:PSH1]XAPPFLG = 3 | [M:PSH1]XCLEFLG = 2
    Call ERREUR (mess(122,199,1)) From GESECRAN
    mkstat = 2
    End
Endif

status = 73
If [M:PSH1]ITMREF (nolign-1) <> ""
        nolign +=1
Endif
If dim ([M:PSH1]ITMREF) = [M:PSH1]NBLIG : # insertion impossible si tableau plein
         Call ERREUR (mess(122,199,1)) From GESECRAN
         mkstat = 2
         nolign -=1
         End
Endif
Call INSERE("PSDLIN") From TABLEAUX
If mkstat <> 2
     #----------------------------#
     # insertion apres la ligne   #
     #----------------------------#
     If [M:PSH1]NBLIG +1 = dim ([M:PSH1]ITMREF)
           Insa nolign-1,1 [M:PSH1]NBLIG     : # pas de borne (plantage sur derniere ligne indice incorrecte)
     Else  Insa nolign-1,1,[M:PSH1]NBLIG [M:PSH1]NBLIG
     Endif
     [M:PSH1]NBLIG +=1
     status = 0
     Call LINNUM("PSDLIN") From TABLEAUX
     Call DUPLI(nolign-1) From SUBPSH1
     Call APRES_NBLIG
     If !GIMPORT Affzo [PSH1]1-99 : Endif
     #-------------------------------------------#
     # activation du bouton enregistrer en modif #
     #-------------------------------------------#
     mkstat = 4
Else If [M:PSH1]ITMREF (nolign-1) <> ""
        nolign -=1
     Endif
Endif
End

Subprog B3_NBLIG
#----------------#
# Bouton "Solde" #
#----------------#
If [M:PSH1]ITMREF (nolign-1) = "" : End : Endif
If GREP <> "C" & GREP <> "D" & [F:PTR]CLEBUT = 2 & [M:PSH1]CREFLG (nolign -1) <> 0
    Call SOLDE(nolign) From SUBPSH1
    #-------------------------------------------#
    # activation du bouton enregistrer en modif #
    #-------------------------------------------#
    mkstat = 4 : GMODIF=9
Else
    GERR=1 : GMESSAGE=mess(90,199,1)
Endif
End

Subprog AS_NBLIG
#----------------------#
# Avant saisie NBLIG   #
#----------------------#
# Issue 101470 - 2014-10-13 by SR : Gestion saisie acheteur et site (lignes déplacées en C_NBLIG)
# action AS_NBLIG enlevée de l'écran PSH1
#If !GIMPORT
#  If [M:PSH1]NBLIG=1
#    Diszo [PSH0]PSHFCY
#    If GPLNFLT>1
#      Diszo [PSH0]REQUSR
#    Endif
#  Elsif [M:PSH1]NBLIG=0
#    Actzo [PSH0]PSHFCY, REQUSR
#  Endif
#Endif
End

Subprog C_NBLIG
# Issue X3-102918 - 2018-08-03 by SR :Sauvegarde de status qui peut être perdu
Local Integer WSTATUS : WSTATUS = status
# Issue 101470 - 2014-10-13 by SR : Gestion saisie acheteur et site (lignes déplacées de AS_NBLIG)
If !GIMPORT
  If [M:PSH1]NBLIG=1
    Diszo [PSH0]PSHFCY
    If GPLNFLT>1
      Diszo [PSH0]REQUSR
    Endif
  Elsif [M:PSH1]NBLIG=0
    Actzo [PSH0]PSHFCY, REQUSR
  Endif
Endif
#--------------------------------------------------------#
# Contrôle sur numéro de ligne                           #
# Affichage des lignes créées par le picking des besoins #
#--------------------------------------------------------#
If [M:PSH0]NBCRELIG > 0
  [M:PSH1]NBLIG += [M:PSH0]NBCRELIG
  Raz [M:PSH0]NBCRELIG
  If !GIMPORT Affzo [PSH1]1-99 : Endif
Endif
#-------------------------------------------------#
# Il y a généralement des contrôles pour vérifier #
# qu'on peut annuler ou modifier une ligne        #
#-------------------------------------------------#
# Issue X3-102918 - 2018-08-03 by SR :Sauvegarde de status qui peut être perdu
#If GMODIF=9 status=131 : Endif : # Bouton Solde pour le WEB
If GMODIF=9 status=131 : WSTATUS = status : Endif : # Bouton Solde pour le WEB
GMODIF=1
If GREP = "C"  : End : Endif
If nolign>dim([M:PSH1]ITMREF)  End : Endif
# Issue X3-102918 - 2018-08-03 by SR :Exploitation de WSTATUS
#If status = 68 | status = 83 : # Annulation multiple
If WSTATUS = 68 | WSTATUS = 83 : # Annulation multiple
      For I = nolign - 1 To nolign1 - 1
          If [M:PSH1]BLOMSG (I) <> 0
                GERR = 1 : GMESSAGE =(mess([M:PSH1]BLOMSG(I),194,1))
                mkstat = 2
                GMODIF = 0
                Break
          Endif
      Next I
Else
# status 75 modif
# status 65 annulation
# status 73 insertion
# 1 / 4 / 5 / 20 / 21 / 26 / 92 / 93   on sort du tableau
       # Issue X3-102918 - 2018-08-03 by SR :Exploitation de WSTATUS
       #If status = 65 | status = 75
       If WSTATUS = 65 | WSTATUS = 75
             If [M:PSH1]BLOMSG (nolign-1) <> 0
                GERR = 1 : GMESSAGE = mess([M:PSH1]BLOMSG(nolign-1),194,1)
                mkstat =2
                #---------------------------------------------------#
                # on positionne un indicateur car il est impossible #
                # à ce niveau de revenir sur numero ligne           #
                # avec zonsui                                       #
                #---------------------------------------------------#
                GMODIF = 0
             Endif
       Endif
Endif
# Issue X3-102918 - 2018-08-03 by SR : restore status
status = WSTATUS
End

Subprog AVANT_NBLIG
# Issue 116364 - 2016-05-03 by SR
Local Integer NOL : NOL = nolign-1
# Issue X3-102918 - 2018-08-03 by SR :Sauvegarde de status qui peut être perdu
Local Integer WSTATUS : WSTATUS = status
If [M:PSH1]ITMREF(NOL) <> ""
  Call INIECCSTA([M:PSH1]ITMREF(NOL),"PSH1",NOL) From STKECR
Endif
#-------------------------------------------------------------------------#
# Suppression texte ligne et besoins si la ligne est créée puis supprimée #
#-------------------------------------------------------------------------#
# Issue X3-102918 - 2018-08-03 by SR : Exploitation de wstatus
#If status=65 | status=68 | status=83
If WSTATUS=65 | WSTATUS=68 | WSTATUS=83
  If [M:PSH1]CREFLG(nolign-1)=0
    If left$([M:PSH1]LINTEX(nolign-1),3)="PSD"
      Call SUP_CLOB([M:PSH1]LINTEX(nolign-1),GBIDI1) From TRTX3TEX
    Endif
    Gosub EFFAC_LIG_PWRKORDERS From SUBPSH
  Endif
  # Issue X3-102918 - 2018-08-03 by SR :Suppression de ligne en modification:
  # Forcément cela doit impacter les signatures
  # Si on supprime juste la ligne : nbr lignes du tableau <> nb lignes du fichier
  # Dans ce cas, le circuit sera annulé et relancé
  # Mais si on supprime puis ajoute :  nbr lignes du tableau = nb lignes du fichier
  # Il faut donc positionner quelque chose pour détecter ce cas
  # on se sert de l'indicateur WMODIF de l'entête
  If GREP = "M" :  [M:PSH0]WMODIF = 2 : Endif
Endif
# Issue X3-102918 - 2018-08-03 by SR : restore status
status = WSTATUS
End

Subprog APRES_NBLIG
Local Shortint NOL : NOL=nolign-1
# Issue X3-102918 - 2018-08-03 by SR :Sauvegarde de status qui peut être perdu
Local Integer WSTATUS : WSTATUS = status
#-------------------------------------------------------------#
# Contrôle que la qte est <> 0  controle non bloquant         #
# la création ou modif de la ligne ne sera pas pris en compte #
# lors de la validation de la demande                         #
#-------------------------------------------------------------#
If NOL+1<[M:PSH1]NBLIG
  If [M:PSH1]ITMREF(NOL)<>"" & [M:PSH1]QTYPUU(NOL)=0
    GERR=1 : GMESSAGE=mess(6,194,1) : End
  Endif
Endif
#----- Ligne supprimée -----#
# Issue X3-102918 - 2018-08-03 by SR : Exploitation de wstatus
#If status=65 | status=68 | status=83
If WSTATUS=65 | WSTATUS=68 | WSTATUS=83
  status = WSTATUS
  End
Endif
#----- Ligne abandonnée par escape ...etc -----#
If WSTATUS=6 | WSTATUS=7 | WSTATUS=27 | WSTATUS=28
  status = WSTATUS
  End
Endif
#----- Mise à jour indicateur budget dépassé à titre indicatif -----#
Local Integer OK
If GREP = "C" | GREP = "D" | GREP = "M"
  #VPO 09/11/10 68973 on stocke LINAMT pour CTLBUD et affect FBUFLG
  #If [M:PSH1]ITMREF(NOL)<>"" & GMODU(2)=2 & [M:PSH1]CREFLG(NOL)=0
  If [M:PSH1]ITMREF(NOL)<>"" & GMODU(2)=2
    #VPO 09/11/10 68973 on stocke LINAMT pour CTLBUD et affect FBUFLG
    #en creation ou uniquement si montant ou qte modifiés
    If [M:PSH1]CREFLG(NOL)=0 | [M:PSH1]LINAMT(NOL)<>[M:PSH1]LINAMTOLD(NOL) |
&      [M:PSH1]QTYPUU(NOL)<>[M:PSH1]QTYPUUOLD(NOL) | [M:PSH1]QTYPUU(NOL)<>[M:PSH1]QTYPUUOLD(NOL)
        Call CTLBUD (OK) From SUBPSH1
        If OK<1
          [M:PSH1]FBUFLG(NOL)=2
          If GBUDCTLPSH=2 & GBUDCTLPSL=2 & GCTLBUD>1
            GERR=2
          Else
            Raz GERR, GMESSAGE
          Endif
        Else
          [M:PSH1]FBUFLG(NOL)=1
        Endif
    Endif
  Endif
Endif
Call MAJ_CALTAX_LIG("PSH1",NOL) From TRTACHDIV1
[M:PSH1]LINFLG(NOL)=1
#----- Modification d'une ligne existante, reprise des signatures -----#
If [M:PSH1]CREFLG(NOL)<>0
  If GAPPPSH>1
     # Issue 112933 - 2015-12-03 by SR : Seulement si modification de zones impactantes
   If [M:PSH1]WAPPFLG(NOL)=2
      [M:PSH1]LINAPPFLG(NOL)=1
   Endif
   # End issue 112933
  Else
    [M:PSH1]LINAPPFLG(NOL)=4
  Endif
Endif
# Issue 71069 - 2013-08-23 by SR : PJT
# Issue 71069-50 - 2016-08-25 by SR :PJT import
# Si première ligne & pas de code affaire à l'entête et mono affaire on alimente le code affaire à l'entête
#If [M:PSH1]NBLIG <1 & [M:PSH0]PJTH = "" & GPJTSNGDOC = 2
If ([M:PSH1]NBLIG <1  | (GIMPORT & [M:PSH1]NBLIG =1)) & [M:PSH0]PJTH = "" & GPJTSNGDOC = 2
  [M:PSH0]PJTH = [M:PSH1]PJT(NOL)
  If !GIMPORT : Affzo [M:PSH0]PJTH : Endif
Endif

#                                                        hcb 71276 deb
If dim([M:PSH1]ECCVALMAJ) > 0
   If [F:ITM]ECCSTO > 1 & [M:PSH1]ECCSAIFLG(nolign-1) = 0
      If [M:PSH1]ECCVALMAJ(nolign-1) = ""
         Call STKINIECC([M:PSH1]ITMREF(nolign-1),"","PSH1",1,2,nolign-1,2,[M:PSH1]ECCVALMAJ(nolign-1)
&,"ECCVALMAJ","ECCVALMIN","","",1,[M:PSH1]BPSNUM(nolign-1)) From STKACT
      Endif
   Endif
Endif

#                                                        hcb 71276 fin

# Issue X3-102918 - 2018-08-03 by SR : restore status
status = WSTATUS
End

Subprog IB_ITMREF
#--------------------#
# Init bouton ITMREF #
#--------------------#
GBOUT1=mess(22,198,1)
If [M:PSH1]PQHNUM(nolign-1)<>""
  Raz GBOUT1
Endif
If [F:PTR]QRQBUT = 2
      GBOUT2 = mess(35,198,1)
Else  GBOUT2 =""
Endif
GBOUT3 = mess(40,198,1)
Raz GBIDI3
End

Subprog AS_ITMREF(VALEUR)
#---------------------#
# Avant saisie ITMREF #
#---------------------#
Variable Char     VALEUR
If GMODIF=0
 mkstat = 2
Endif
#----------------------------------------------------------------#
# on ne peut pas modifier la reference si la ligne est deja créée#
# creflg = 0 si nouvelle ligne                                   #
#----------------------------------------------------------------#
If [M:PSH1]CREFLG (nolign-1) <> 0
  mkstat = 2
Endif
If [M:PSH1]WQTYORDPUU (nolign-1) <> 0 | [M:PSH1]QTYPUU (nolign-1) <> 0
  mkstat = 2
Endif
End

Subprog C_ITMREF(VALEUR)
#-----------------#
# Controle ITMREF #
#-----------------#
Variable Char    VALEUR()
Local Shortint NOL : NOL=nolign-1
If [M:PSH1]PRHFCY(NOL) = ""
  [M:PSH1]PRHFCY (NOL) = GRCPFCY : Affzo [PSH1]PRHFCY(NOL)
Endif
#-------------------------------------------#
# Controleur de l'approvisionneur (PLANNER) #
#-------------------------------------------#
If (GPLNFLT=2 & [F:ITM]PLANNER<>[M:PSH0]REQUSR & [F:ITM]PLANNER<>"") |
&  (GPLNFLT=3 & [F:ITM]PLANNER<>[M:PSH0]REQUSR)
   GMESSAGE=mess(61,193,1) : mkstat=1 : End
Endif
#----- Contrôle article en fin de vie ------#
If [F:ITM]LIFENDDAT<>[0/0/0] & [F:ITM]LIFENDDAT<[M:PSH0]PRQDAT
   mkstat=1 : GMESSAGE=mess(12,318,1) : End
Endif
# Issue 80601 - 2012-03-08 by SR
# Issue 112754 - 2016-09-23 by SR :
Call C_ITMREF("PSD",VALEUR) From TRTACHCTL1 : # Acheté et non sous-traitance
If mkstat End : Endif
#----------------------------------------------------------#
# chargement du delai article - site                       #
# attention lecture avec site demande (le 16 janvier 1998) #
#----------------------------------------------------------#
If [M:PSH1]CREFLG (NOL) <> 0 : End  : Endif
If VALEUR = ""                     : End  : Endif
Read [ITF]ITF0 = VALEUR ; [M:PSH0]PSHFCY
If fstat = 0
  [M:PSH1]OFS (NOL) = [F:ITF]OFS
  If [M:PSH1]OFS (NOL) = 0
    [M:PSH1]OFS (NOL) = [F:ITM]OFS
  Endif
Else   [M:PSH1]OFS (NOL) = [F:ITM]OFS
Endif
#-------------------------------------------------------------#
# si site de reception est affiché ou invisible               #
# il faut verifier article site existe  et bloquer la saisie  #
# cas des articles gérer en stock                             #
# si non gere en stcok --> site demande                       #
#-------------------------------------------------------------#
If [F:ITM]STOMGTCOD = 1
  If GRCPFCY = ""
    [M:PSH1]PRHFCY (NOL) = [M:PSH0]PSHFCY
  Endif
  End
Endif

If [M:PSH1]PRHFCY (NOL) <> GRCPFCY
  Read [ITF]ITF0 = VALEUR ; [M:PSH1]PRHFCY (NOL)
  If fstat    Raz [F:ITF]
    [M:PSH1]PRHFCY (NOL) = GRCPFCY : Affzo [PSH1]PRHFCY(NOL)
    Read [ITF]ITF0 = VALEUR ; GRCPFCY
    If fstat    Raz [F:ITF]
      If [F:PTR]RCPFCYCOD <> 1
        GMESSAGE = mess(25,192,1)
        mkstat = 2
      Else
        [M:PSH1]PRHFCY (NOL) = ""
      Endif
    Endif
  Endif
Else
  Read [ITF]ITF0 = VALEUR ; GRCPFCY
  If fstat    Raz [F:ITF]
    If [F:PTR]RCPFCYCOD <> 1
      GMESSAGE = mess(25,192,1)
      mkstat = 2
    Else
      [M:PSH1]PRHFCY (NOL) = ""
    Endif
  Endif
Endif
# Issue 71276 - 2015-03-03 by SR : Versions
Gosub C_ITMREF_ECC From SUBPSH1
# End issue 71276
End

Subprog AM_ITMREF(VALEUR)
#-----------------------#
# Après-modif ITMREF    #
#-----------------------#
Variable Char    VALEUR()
Local Shortint NOL : NOL=nolign-1
Local Integer WRET
# Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
Local Char    WBPSNUM(GLONBPS)
Local Integer WITMBPS : WITMBPS = 0

If [M:PSH1]PQHNUM(NOL)="" : # Déja chargé si appel d'offre pris en compte
  [M:PSH1]PUU (NOL) = [F:ITM]PUU
  [M:PSH1]STU (NOL) = [F:ITM]STU
  #----- Chargement des désignations article -----#
  #Call CHARGE_ITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PSH1]ITMDES(NOL)) From TRTX3
  #If [M:PSH1]ITMDES(NOL)="" [M:PSH1]ITMDES(NOL)=[F:ITM]ITMDES1 : Endif
  # Issue 78167 - 2011-11-24 by VPO : designation traduite selon la langue du fourn
  #Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PSH1]ITMDES(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
  If [M:PSH1]BPSNUM(NOL)<>""
     #lecture BPR
     If [F:BPR]BPRNUM<>[M:PSH1]BPSNUM(NOL)
       Read [BPR] BPR0=[M:PSH1]BPSNUM(NOL)
       If fstat Raz [F:BPR] : Endif
     Endif
     If [F:BPR]LAN="" : [F:BPR]LAN=GLANGUE : Endif
     [M:PSH1]LAN(NOL)=[F:BPR]LAN
     Call CHARGE_DEFITMDES("DES1AXX",[M:PSH1]LAN(NOL),[F:ITM]ITMREF,[M:PSH1]ITMDES(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
  Else
     [M:PSH1]LAN(NOL)=GLANGUE
     Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PSH1]ITMDES(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
  Endif
  #[M:PSH1]ITMDES1(NOL) = [F:ITM]ITMDES1
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PSH1]ITMDES1(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
  #-----------------------------------------------#
  Raz [M:PSH1]QTYPUU(NOL), [M:PSH1]QTYSTU(NOL)
Endif
#----- Chargement du régime de taxe -----#
If !clalev([F:TVB]) Local File TABVACBPR [TVB] Endif :   # 71937 : Multilégislation
If !clalev([F:AGC]) Local File AGRPCPY   [AGC] Endif :   # 71937 : Multilégislation
If GPURVACBPR<>""
  [M:PSH1]VACBPR(NOL)=GPURVACBPR
# Issue 93025 - 2013-11-27 by MUARN : ne pas faire si on vient des appels d'offre
Elsif [M:PSH1]PQHNUM(NOL)=""
  # 71937 : Multilégislation
  #Filter [ADI] Where NUMTAB=1 & DEFVAL=2
  #Read [ADI] CODE First
  #Filter [ADI]
  #If !fstat  [M:PSH1]VACBPR(NOL)=[F:ADI]CODE : Endif
  # Recherche d'un régime actif pour la leg
  Filter [TVB] Where LEG=GCURLEG & REGVAC=1 & ENAFLG=2
  For [TVB]TVB0
      # Si le régime est lié à un groupe on ne prend que si le groupe est ok pour la société
      If [F:TVB]SOC<>""
        Look [AGC]AGC0 = [F:TVB]SOC;GSOCIETE
        If !fstat Break Endif
      Else
        fstat=0 : Break
      Endif
  Next
  Filter [TVB]
  If !fstat
    [M:PSH1]VACBPR(NOL)=[F:TVB]VACBPR
  Else
    # Aucune régime trouvé avec la leg : Recherche d'un régime actif ss leg
    Filter [TVB] Where LEG="" & REGVAC=1 & ENAFLG=2
    For [TVB]TVB0
      # Si le régime est lié à un groupe on ne prend que si le groupe est ok pour la société
      If [F:TVB]SOC<>""
        Look [AGC]AGC0 = [F:TVB]SOC;GSOCIETE
        If !fstat Break Endif
      Else
        fstat=0 : Break
      Endif
    Next
    Filter [TVB]
    If !fstat
      [M:PSH1]VACBPR(NOL)=[F:TVB]VACBPR
    Endif
  Endif
  # 71937 : Multilégislation
Endif
#----- Chargement du type de régime taxe -----#
# 71937 : Multilégislation
#If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>[M:PSH1]VACBPR(NOL)
#  Read [ADI] CODE=1;[M:PSH1]VACBPR(NOL) : If fstat Raz [F:ADI] : Endif
#Endif
#[M:PSH1]VACTYP(NOL)=[F:ADI]N1
Call LEC_TVB_LEG(GCURLEG,[M:PSH1]VACBPR(NOL),WRET) From TRTLECLEG
If WRET Raz [F:TVB] : Endif
[M:PSH1]VACTYP(NOL)=[F:TVB]REGVAC
# 71937 : Multilégislation
#------ Initialisation des champs de la ligne -----#
[M:PSH1]CUR(NOL)       = GCUR
[M:PSH1]CHGTYP(NOL)    = GPURCHGTYP
[M:PSH1]FBUFLG(NOL)    = 1
[M:PSH1]LINORDFLG(NOL) = 1
[M:PSH1]LINFLG(NOL)    = 0
[M:PSH1]BLOMSG(NOL)    = 0
[M:PSH1]PRIFLG(NOL)    = 1
If GAPPPSH  > 1
  [M:PSH1]LINAPPFLG(NOL) = 1
Else
  [M:PSH1]LINAPPFLG(NOL) = 4
Endif
#----- Chargement des codes taxes -----#
Call ALIVATCOD(2,[M:PSH1]BPSNUM(NOL),VALEUR,"PSH1",NOL) From TRTX3
#----- Initialisation du fournisseur si aucun appel d'offre pris en compte -----#
If [M:PSH1]PQHNUM(NOL)="" & GPSHINIBPS=2
  # Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
  #For [ITP] ITP1 Where ITMREF=VALEUR & DOUFLG<>3
    #[M:PSH1]ITMREF(NOL)=VALEUR
    # Issue 101723 - 2014-08-12 by MUARN : Ne pas mettre le même fournisseur que le site entête
    #If [M:PSH0]PSHFCY <> [F:ITP]BPSNUM
    #  [M:PSH1]BPSNUM(NOL)=[F:ITP]BPSNUM : Call AM_BPSNUM([M:PSH1]BPSNUM(NOL)) : Break
    #Endif
  #Next
  Raz [F:ITP], [F:ITPF], WBPSNUM
  Call DEFBPSNUM(VALEUR,[M:PSH0]PSHFCY,[M:PSH1]PRHFCY(nolign-1),"",1,WBPSNUM,WITMBPS) From TRTACHDEF1
  [M:PSH1]ITMREF(NOL)=VALEUR
  #[M:PSH1]BPSNUM(NOL)=WBPSNUM : Call AM_BPSNUM([M:PSH1]BPSNUM(NOL))
  Call AM_BPSNUM(WBPSNUM)
  If !mkstat : [M:PSH1]BPSNUM(NOL)=WBPSNUM : Endif
  # End issue X3-55891
Endif
#----- Récupération des liens texte article ou article-fournisseur -----#
If !find(left$([M:PSH1]LINTEX(NOL),3),"PSD")
  [M:PSH1]LINTEX(NOL)=[F:ITM]PURTEX
  If [M:PSH1]BPSNUM(NOL)<>""
    If [F:ITP]ITMREF<>VALEUR & [F:ITP]BPSNUM<>[M:PSH1]BPSNUM(NOL)
      Read [ITP] ITP0=VALEUR;[M:PSH1]BPSNUM(NOL) : If fstat  Raz [F:ITP] : Endif
    Endif
    If [F:ITP]TEX<>""  [M:PSH1]LINTEX(NOL)=[F:ITP]TEX : Endif
  Endif
Endif
# Issue 71276 - 2015-03-03 by SR : Versions
Gosub AM_ITMREF_ECC From SUBPSH1
# End issue 71276
#-----
# Issue 112754 - 2016-09-22 by SR : Init de ITMKND selon le type d'article
[M:PSH1]ITMKND(NOL) = 1
If [F:ITM]ITMREF <> VALEUR
  Read [F:ITM]ITM0 = VALEUR
  If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITM]SCSFLG = 2 : [M:PSH1]ITMKND(NOL) = 3 : Endif
# End issue 112754
#----
[M:PSH1]ITMREF(NOL)=VALEUR
# Issue 112754 - 2016-09-23 by SR : Afficher ITMKND
If !GIMPORT
  Affzo [PSH1]ITMDES(NOL),ITMDES1(NOL),PRHFCY(NOL),PUU(NOL),STU(NOL),BPSNUM(NOL),CUR(NOL),NETPRI(NOL),ITMKND(NOL)
Endif
End

Subprog IB_ITMDES
#--------------------#
# Init bouton ITMDES #
#--------------------#
#----- Tunnel sur le fichier articles -----#
Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT7, GBOUT8
GBOUT1=mess(22,198,1): GBIDI3 = nolign-1 : # Articles
#-----------------------------------------------------#
# La désignation est modifiable quel que soit article #
#-----------------------------------------------------#
End

Subprog AS_ITMDES(VALEUR)
#---------------------#
# Avant saisie ITMDES #
#---------------------#
Variable Char    VALEUR()
#MAE, bg 101751
Local Shortint NOL : NOL=nolign-1
If GMODIF = 0 : mkstat = 2 : Endif
If VALEUR = ""
  #----- Chargement des désignations article -----#
  #Call CHARGE_ITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,VALEUR) From TRTX3
  #If VALEUR="" VALEUR = [F:ITM]ITMDES1 : Endif
  # Issue 78167 - 2011-11-24 by VPO : designation traduite selon la langue du fourn
  #Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,VALEUR, "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
  If [M:PSH1]BPSNUM(nolign-1)<>""
     #lecture BPR
     If [F:BPR]BPRNUM<>[M:PSH1]BPSNUM(nolign-1)
       Read [BPR] BPR0=[M:PSH1]BPSNUM(nolign-1)
       If fstat Raz [F:BPR] : Endif
     Endif
     If [F:BPR]LAN="" : [F:BPR]LAN=GLANGUE : Endif
     [M:PSH1]LAN(nolign-1)=[F:BPR]LAN
     Call CHARGE_DEFITMDES("DES1AXX",[M:PSH1]LAN(nolign-1),[F:ITM]ITMREF,VALEUR, "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
  Else
     [M:PSH1]LAN(NOL)=GLANGUE
     Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,VALEUR, "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
  Endif
  #[M:PSH1]ITMDES1(nolign-1) = [F:ITM]ITMDES1
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PSH1]ITMDES1(nolign-1), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
Endif
#-----------------------------------------------------#
# La désignation est modifiable quel que soit article #
#-----------------------------------------------------#
End

Subprog LECPSHITM
#------------------------#
# Action suite au tunnel #
#------------------------#
Local Shortint NOL
NOL = GBIDI3
#----- Relecture article si celui-ci a été changé par le tunnel -----#
If [F:ITM]ITMREF<>[M:PSH1]ITMREF(NOL)
  Read [ITM] ITM0=[M:PSH1]ITMREF(NOL)
  If fstat Raz [F:ITM] : Endif
Endif
End

Subprog IB_ITMDES1
#---------------------#
# Init bouton ITMDES1 #
#---------------------#
#----- Tunnel sur le fichier articles -----#
Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT7, GBOUT8
GBOUT1=mess(22,198,1) : # Articles
End

Subprog AS_ITMDES1(VALEUR)
#----------------------#
# Avant saisie ITMDES1 #
#----------------------#
Variable Char    VALEUR()
#MAE, bg 101751
Local Shortint NOL : NOL=nolign-1
If GMODIF = 0 : mkstat = 2 : Endif
If VALEUR = ""
  #----- Chargement des désignations article -----#
  #Call CHARGE_ITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PSH1]ITMDES(nolign-1)) From TRTX3
  #If [M:PSH1]ITMDES(nolign-1)="" [M:PSH1]ITMDES(nolign-1)=[F:ITM]ITMDES1 : Endif
  # Issue 78167 - 2011-11-24 by VPO : designation traduite selon la langue du fourn
  #Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PSH1]ITMDES(nolign-1), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
  If [M:PSH1]BPSNUM(nolign-1)<>""
     #lecture BPR
     If [F:BPR]BPRNUM<>[M:PSH1]BPSNUM(nolign-1)
       Read [BPR] BPR0=[M:PSH1]BPSNUM(nolign-1)
       If fstat Raz [F:BPR] : Endif
     Endif
     If [F:BPR]LAN="" : [F:BPR]LAN=GLANGUE : Endif
     [M:PSH1]LAN(nolign-1)=[F:BPR]LAN
     Call CHARGE_DEFITMDES("DES1AXX",[M:PSH1]LAN(nolign-1),[F:ITM]ITMREF,[M:PSH1]ITMDES(nolign-1), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
  Else
     [M:PSH1]LAN(NOL)=GLANGUE
     Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PSH1]ITMDES(nolign-1), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
  Endif
  #VALEUR = [F:ITM]ITMDES1
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,VALEUR, "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
Endif
#-----------------------------------------------------#
# La désignation est modifiable quel que soit article #
#-----------------------------------------------------#
End

Subprog IB_PRHFCY
#--------------------#
# Init bouton PRHFCY #
#--------------------#
Raz GBOUT1, GBOUT2, GBOUT4 : # GBOUT3 est chargé par l'action CONSSFC
If [F:ITM]ITMREF<>[M:PSH1]ITMREF(nolign-1)
  Read [ITM] ITM0=[M:PSH1]ITMREF(nolign-1) : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITF]ITMREF<>[M:PSH1]ITMREF(nolign-1) | [F:ITF]STOFCY<>[M:PSH1]PRHFCY(nolign-1)
  Read [ITF] ITF0=[M:PSH1]ITMREF(nolign-1);[M:PSH1]PRHFCY(nolign-1)
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
If [F:ITF]STOMGTCOD>1 GBOUT4=mess(4,198,1) Else Raz GBOUT3 : Endif
End

Subprog AS_PRHFCY(VALEUR)
#---------------------#
# Avant saisie PRHFCY #
#---------------------#
Variable Char     VALEUR
If GMODIF = 0 : mkstat = 2 : Endif
End

Subprog AM_PRHFCY(VALEUR)
#--------------------#
# Après modif PRHFCY #
#--------------------#
Variable Char     VALEUR
Local Shortint NOL : NOL=nolign-1
# Issue X3-55891 - 2018-08-13 by MUARN : exploitation table article/fournisseur/site
Local Char    WBPSNUM(GLONBPS)
Local Integer WITMBPS : WITMBPS = 0
Local Integer WRETOUR
Local Decimal WCOEUOM, WQTY
Local Integer OK
#----- Alimentation codes taxe si nécessaire -----#
If func AFNC.ACTIV("PTX") & [M:PSH1]VACBPR(NOL)<>""
  [M:PSH1]PRHFCY(NOL)=VALEUR
  Call ALIVATCOD(2,[M:PSH1]BPSNUM(NOL),[M:PSH1]ITMREF(NOL),"PSH1",NOL) From TRTX3
Endif
#-----
# Issue X3-55891 - 2018-08-21 by MUARN : exploitation table article/fournisseur/site
OK=2 : Call OUINON(mess(590,194,1),OK) From GESECRAN
If OK=2
  Raz [F:ITP], [F:ITPF], WBPSNUM
  Call DEFBPSNUM([M:PSH1]ITMREF(NOL),[M:PSH0]PSHFCY,VALEUR,"",1,WBPSNUM,WITMBPS) From TRTACHDEF1
  If WBPSNUM<> "" & WBPSNUM<>[M:PSH1]BPSNUM(NOL)
    #[M:PSH1]BPSNUM(NOL)=WBPSNUM
    #-------------------------#
    # chargement de la devise #
    # il faut lire BPARTNER   #
    #-------------------------#
    If [F:BPR]BPRNUM<>[F:ITP]BPSNUM
      Read [BPR] BPR0=[F:ITP]BPSNUM : If fstat  Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : Endif
    Endif
    If [F:BPS]BPSNUM<>[F:ITP]BPSNUM
      Read [BPS] BPS0=[F:ITP]BPSNUM : If fstat  Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
    Endif
    [M:PSH1]CUR(NOL) = [F:BPS]CUR
    Call PCAL_QTY ([M:PSH1]QTYPUU(NOL),[M:PSH1]PUU(NOL),WQTY,[F:ITP]PUU
&                 ,[M:PSH1]ITMREF (NOL),[F:ITP]BPSNUM,1,WCOEUOM) From TRTACHQTE1
    [M:PSH1]PUU (NOL)    = [F:ITP]PUU
    [M:PSH1]QTYPUU(NOL)  = WQTY
    #Call AM_BPSNUM([M:PSH1]BPSNUM(NOL))
    Call AM_BPSNUM(WBPSNUM)
    If !mkstat : [M:PSH1]BPSNUM(NOL)=WBPSNUM : Endif
    If !GIMPORT
      Affzo [PSH1]ITMDES(NOL),ITMDES1(NOL),PUU(NOL),BPSNUM(NOL),CUR(NOL),NETPRI(NOL)
    Endif
  Elsif WBPSNUM<>""
    Call CTRL_DOUFLG(1,[M:PSH1]ITMREF(NOL),[M:PSH1]BPSNUM(NOL),[M:PSH1]PRHFCY(NOL),WITMBPS,WRETOUR) From TRTACHCTL1
    If WRETOUR<>0
      mkstat=2 : End
    Endif
  Endif
Elsif [M:PSH1]BPSNUM(NOL)<>""
  Call CTRL_DOUFLG(1,[M:PSH1]ITMREF(NOL),[M:PSH1]BPSNUM(NOL),[M:PSH1]PRHFCY(NOL),WITMBPS,WRETOUR) From TRTACHCTL1
  If WRETOUR<>0
    mkstat=2 : End
  Endif
Endif
End

$AAM_PRHFCY
#-------------------------------------------------------------#
# Avant exécution de l'action GOBJETC0A (tunnel article-site) #
#-------------------------------------------------------------#
Local Shortint NOL             : NOL=nolign-1
Local Char     SITE  (GLONFCY) : SITE=VALEUR
Local Char     WOBJET(GLONAOB) : WOBJET="ITF"
#----- Restauration de l'ancienne valeur et blocage sur le champ -----#
If GBIDI1=1  VALEUR=[M:PSH1]PRHFCY(NOL) : mkstat=1 : Endif
If GBIDI1<>2 WOBJET="" : Endif : # Pas d'exécution du tunnel
GFLTITM=[M:PSH1]ITMREF(NOL)
Return

$BAM_PRHFCY
#-------------------------------------------------------------#
# Après exécution de l'action GOBJETC0A (tunnel article-site) #
#-------------------------------------------------------------#
nolign=NOL+1: # Restitution du nolign
Raz GFLTITM
If GBIDI1=0  Return : Endif
VALEUR=SITE
Read [ITF] ITF0=[M:PSH1]ITMREF(NOL);VALEUR
If fstat Raz [F:ITF] : Endif
If [F:ITF]ITMREF="" mkstat=1 : Endif
Return

Subprog AS_EXTRCPDAT(VALEUR)
#-----------------------------#
# Avant saisie date souhaitée #
#-----------------------------#
Variable Date     VALEUR
If GMODIF = 0 : mkstat = 2 : Endif
End

Subprog AM_EXTRCPDAT(VALEUR)
#----------------------------#
# Après modif date souhaitée #
#----------------------------#
Variable Date     VALEUR
Local Shortint NOL : NOL=nolign-1
#---------------------------------------#
# date inférieure date jour --> info    #
#---------------------------------------#
If VALEUR < datesyst
  GERR = 1 : GMESSAGE = mess(65,194,1)
Endif
#----- Calcul et contrôle date prévue de commande -----#
If VALEUR<>[0/0/0] & [M:PSH1]EXTORDDAT(NOL)<>[0/0/0]
  [M:PSH1]EXTORDDAT(NOL)=VALEUR-[M:PSH1]OFS(NOL)
  If [F:BPS]BPSNUM<>[M:PSH1]BPSNUM(NOL)
    Read [BPS] BPS0=[M:PSH1]BPSNUM(NOL) : If fstat Raz [F:BPS] : Endif
  Endif
  Call CTL_PER ([M:PSH1]EXTORDDAT(NOL),[F:BPS]UVYCOD) From CONTX3
  If mkstat
    GMESSAGE=mess(73,198,1)-[M:PSH1]BPSNUM(NOL)+"\"+GMESSAGE
    GMESSAGE=mess(1,503,1)-format$("D:"+GFMDAT,[M:PSH1]EXTORDDAT(NOL))-GMESSAGE
    Call MESSAGE (GMESSAGE) From GESECRAN
    Raz mkstat, GMESSAGE
  Endif
  If !GIMPORT Affzo [PSH1]EXTORDDAT(NOL) : Endif
Endif
End

Subprog AS_PUU(VALEUR)
#--------------------#
# Avant saisie PUU   #
#--------------------#
Variable Char     VALEUR
If GMODIF=0  mkstat=2 : Endif
End

Subprog AM_PUU(VALEUR)
#-----------------#
# Après-modif PUU #
#-----------------#
Variable Char    VALEUR()
Local    Shortint NOL : NOL=nolign-1
#----- Conversion quantité dans la nouvelle unité à partir de l'US -----#
Call PCAL_QTY([M:PSH1]QTYSTU(NOL),[M:PSH1]STU(NOL),[M:PSH1]QTYPUU(NOL),VALEUR,
&             [M:PSH1]ITMREF(NOL),[M:PSH1]BPSNUM(NOL),1,GBIDD1) From TRTACHQTE1
#----- Conversion qté consommée dans la nouvelle unité à partir de l'US -----#
If [M:PSH1]WQTYORDPUU(NOL)<>0 | [M:PSH1]WQTYORDSTU(NOL)<>0
  Call PCAL_QTY([M:PSH1]WQTYORDSTU(NOL),[M:PSH1]STU(NOL),[M:PSH1]WQTYORDPUU(NOL),VALEUR,
&               [M:PSH1]ITMREF(NOL),[M:PSH1]BPSNUM(NOL),1,GBIDD1) From TRTACHQTE1
Endif
#-----
[M:PSH1]PUU(NOL)=VALEUR
If !GIMPORT  Affzo [PSH1]QTYPUU(NOL),QTYSTU(NOL) : Endif
#----- Recherche tarif ? après modif unité -----#
If [M:PSH1]LINFLG(NOL)=1
  Local Integer OK
  OK=2 : Call OUINON(mess(63,196,1),OK) From GESECRAN
  If OK=2: [M:PSH1]PRIFLG (NOL) = 1
    Gosub INI_TARIF : Endif
Else
  [M:PSH1]PRIFLG(NOL)=1 : Gosub INI_TARIF
Endif
End

Subprog IB_QTYPUU
#--------------------#
# Init bouton qtypuu #
#--------------------#
Raz GBOUT1, GBOUT2, GBOUT4 : # GBOUT3 est chargé par l'action CONSSFC
If [F:ITM]ITMREF<>[M:PSH1]ITMREF(nolign-1)
  Read [ITM] ITM0=[M:PSH1]ITMREF(nolign-1) : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITF]ITMREF<>[M:PSH1]ITMREF(nolign-1) | [F:ITF]STOFCY<>[M:PSH1]PRHFCY(nolign-1)
  Read [ITF] ITF0=[M:PSH1]ITMREF(nolign-1);[M:PSH1]PRHFCY(nolign-1)
  If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
If [F:ITF]STOMGTCOD<2 Raz GBOUT3 : Endif
End


Subprog AS_QTYPUU(VALEUR)
#------------------#
# Avant saisie qté #
#------------------#
Variable Decimal  VALEUR
If GMODIF = 0 : mkstat = 2 : Endif
End

Subprog C_QTYPUU(VALEUR)
#-------------------------#
# Controle de la quantité #
#-------------------------#
Variable Decimal  VALEUR
#------------------------------------#
# controle avec la qté consommée     #
#------------------------------------#
If [M:PSH1]WQTYORDPUU (nolign-1) <>0 & VALEUR < [M:PSH1]WQTYORDPUU (nolign -1)
             GMESSAGE = mess (3,194,1)
             mkstat = 2
Endif
End

Subprog AM_QTYPUU(VALEUR)
#--------------------#
# Après-modif qtypuu #
#--------------------#
Variable Decimal  VALEUR
Local Decimal  ANCQTE
If !GIMPORT Affzo [PSH1]QTYSTU(nolign-1) : Endif
ANCQTE = [M:PSH1]QTYPUU(nolign-1)
#----- Recherche tarif ? après modif qté -----#
[M:PSH1]QTYPUU(nolign-1)=VALEUR
If [M:PSH1]LINFLG(nolign-1)=1 & ANCQTE <> 0
  Local Integer OK
  OK=2 : Call OUINON(mess(63,196,1),OK) From GESECRAN
  If OK=2 : [M:PSH1]PRIFLG (nolign-1) = 1
    Gosub INI_TARIF : Endif
Else
  [M:PSH1]PRIFLG(nolign-1)=1 : Gosub INI_TARIF
Endif
#----------------------------#
# calcul du montant ht ligne #
#----------------------------#
If VALEUR<>0 & [M:PSH1]NETPRI(nolign-1)<>0
  [M:PSH1]LINAMT(nolign-1)=VALEUR*[M:PSH1]NETPRI(nolign-1)
  Call ARRDEV([M:PSH1]LINAMT(nolign-1),[M:PSH1]CUR(nolign-1)) From TRTDIV
  If !GIMPORT Affzo [PSH1]LINAMT(nolign-1) : Endif
Endif
End

Subprog AS_STU(VALEUR)
#--------------------------#
# Avant saisie unité stock #
#--------------------------#
Variable Char     VALEUR
If GMODIF = 0 : mkstat = 2 : Endif
End

Subprog C_QTYSTU(VALEUR)
#-----------------------------------------#
# Contrôle unité stock avec qté consommée #
#-----------------------------------------#
Variable Decimal VALEUR
If [M:PSH1]WQTYORDSTU(nolign-1)<>0 & VALEUR<[M:PSH1]WQTYORDSTU(nolign-1)
  GMESSAGE=mess(3,194,1) : mkstat=2 : Endif
End

Subprog AM_QTYSTU(VALEUR)
#-----------------------#
# Après-modif qté stock #
#-----------------------#
Variable Decimal  VALEUR
Local Shortint NOL : NOL=nolign-1
#----- Affichage de la zone qté en UA -----#
If !GIMPORT  Affzo [PSH1]QTYPUU(NOL) : Endif
#----- Calcul du montant HT ligne -----#
If [M:PSH1]NETPRI(NOL)<>0
  [M:PSH1]LINAMT(NOL)=[M:PSH1]NETPRI(NOL)*[M:PSH1]QTYPUU(NOL)
  Call ARRDEV([M:PSH1]LINAMT(NOL),[M:PSH1]CUR(NOL)) From TRTDIV
  If !GIMPORT Affzo [PSH1]LINAMT(NOL) : Endif
Endif
End

Subprog IB_BPSNUM
#--------------------------------#
# Init bouton numéro fournisseur #
#--------------------------------#
GBOUT2=mess(23,198,1)
GBOUT3=mess(24,198,1)
Call IB_NOTECHECK([M:PSH1]BPSNUM(nolign-1),"BPSNUM",4)  From TRTNTSCTL # supplier notes
End

Subprog D_BPSNUM(VALEUR)
#-----------------------------------------------------------#
# Initialisation fournisseur (non activée sur l'écran PSH1) #
#-----------------------------------------------------------#
Variable Char   VALEUR()
# Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
Local Char    WBPSNUM(GLONBPS)
Local Integer WITMBPS : WITMBPS = 0

#----- Initialisation du fournisseur si aucun appel d'offre pris en compte -----#
If [M:PSH1]PQHNUM(nolign-1)="" & GPSHINIBPS=2
  # Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
  #For [ITP] ITP1 Where ITMREF=[M:PSH1]ITMREF(nolign-1) & DOUFLG<>3
  #  VALEUR=[F:ITP]BPSNUM : Call AM_BPSNUM(VALEUR) : Break
  #Next
  Raz [F:ITP], [F:ITPF], WBPSNUM
  Call DEFBPSNUM([M:PSH1]ITMREF(nolign-1),[M:PSH0]PSHFCY,[M:PSH1]PRHFCY(nolign-1),"",1,WBPSNUM,WITMBPS) From TRTACHDEF1
  [M:PSH1]BPSNUM(NOL)=WBPSNUM : Call AM_BPSNUM(VALEUR)
  # End issue X3-55891

Endif
End

Subprog AS_BPSNUM(VALEUR)
#--------------------------#
# Avant saisie fournisseur #
#--------------------------#
Variable Char    VALEUR()
If GMODIF=0  mkstat=2 : Endif
End

Subprog AM_BPSNUM(VALEUR)
#-------------------------#
# Après modif fournisseur #
#-------------------------#
Variable Char    VALEUR
#-----
Local   Integer  WRETOUR
Local   Decimal  WQTY, WCOEUOM, QTEUA
Local   Char     WUOM(GLONUOM)
Local   Char     WPUU(GLONUOM)
Local   Char     WCURLEG(GLONADI)
Local   Shortint NOL : NOL=nolign-1
Local   Integer  WRET
# Issue X3-55891 - 2018-08-07 by MUARN : exploitation table article/fournisseur/site
Local Integer WITMBPS : WITMBPS = 0
#-----
If !clalev([F:TVB]) Local File TABVACBPR [TVB] Endif :   # 71937 : Multilégislation
If !clalev([F:AGC]) Local File AGRPCPY   [AGC] Endif :   # 71937 : Multilégislation
If VALEUR=""
  #----- Chargement du régime de taxe et de la devise -----#
  If GPURVACBPR<>""
    [M:PSH1]VACBPR(NOL)=GPURVACBPR
  Else
    # 71937 : Multilégislation
#    Filter [ADI] Where NUMTAB=1 & DEFVAL=2
#    Read [ADI] CODE First
#    Filter [ADI]
#    If !fstat
#      [M:PSH1]VACBPR(NOL)=[F:ADI]CODE
#    Else
#      If func AFNC.ACTIV("LEG") & GCURLEG<>""
#        WCURLEG=GCURLEG
#      Else
#        WCURLEG=GDOSLEG(1)
#      Endif
#      Filter [ADI] Where NUMTAB=1 & LEG=WCURLEG & N1=1
#      Read [ADI] CODE First
#      Filter [ADI]
#      If !fstat
#        [M:PSH1]VACBPR(NOL)=[F:ADI]CODE
#      Else
#        Filter [ADI] Where NUMTAB=1 & LEG="" & N1=1
#        Read [ADI] CODE First
#        Filter [ADI]
#        If !fstat
#          [M:PSH1]VACBPR(NOL)=[F:ADI]CODE
#        Endif
#      Endif
#    Endif
    # Recherche d'un régime actif pour la leg
    Filter [TVB] Where LEG=GCURLEG & REGVAC=1 & ENAFLG=2
    For [TVB]TVB0
        # Si le régime est lié à un groupe on ne prend que si le groupe est ok pour la société
        If [F:TVB]SOC<>""
          Look [AGC]AGC0 = [F:TVB]SOC;GSOCIETE
          If !fstat Break Endif
        Else
          fstat=0 : Break
        Endif
    Next
    Filter [TVB]
    If !fstat
      [M:PSH1]VACBPR(NOL)=[F:TVB]VACBPR
    Else
      # Aucune régime trouvé avec la leg : Recherche d'un régime actif ss leg
      If clalev([F:AGC])=0 : Local File AGRPCPY    [AGC] : Endif
      Filter [TVB] Where LEG="" & REGVAC=1 & ENAFLG=2
      For [TVB]TVB0
        # Si le régime est lié à un groupe on ne prend que si le groupe est ok pour la société
        If [F:TVB]SOC<>""
          Look [AGC]AGC0 = [F:TVB]SOC;GSOCIETE
          If !fstat Break Endif
        Else
          fstat=0 : Break
        Endif
      Next
      Filter [TVB]
      If !fstat
        [M:PSH1]VACBPR(NOL)=[F:TVB]VACBPR
      Endif
    Endif
    # 71937 : Multilégislation
  Endif
  #----- Chargement du type de régime taxe -----#
  # 71937 : Multilégislation
#  If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>[M:PSH1]VACBPR(NOL)
#    Read [ADI] CODE=1;[M:PSH1]VACBPR(NOL) : If fstat Raz [F:ADI] : Endif
#  Endif
#  [M:PSH1]VACTYP(NOL)=[F:ADI]N1
  Call LEC_TVB_LEG(GCURLEG,[M:PSH1]VACBPR(NOL),WRET) From TRTLECLEG
  If WRET Raz [F:TVB] : Endif
  [M:PSH1]VACTYP(NOL)=[F:TVB]REGVAC
  # 71937 : Multilégislation

  #-----
  [M:PSH1]CUR   (NOL)=GCUR
  [M:PSH1]CHGTYP(NOL)=GPURCHGTYP
  #VPO 26/10/10 58959 question prix et tarif sur chgt fournisseur
  #[M:PSH1]PRIFLG(NOL)=1
  #Gosub INI_TARIF
  # Issue 95247 - 2014-01-02 by MUARN : gestion des gratuits
  [M:PSH1]BPSNUM (NOL) = VALEUR

  If [M:PSH1]LINFLG(NOL)=1
      Local Integer OK
      OK=2 : Call OUINON(mess(63,196,1),OK) From GESECRAN
      If OK=2: [M:PSH1]PRIFLG (NOL) = 1
        Gosub INI_TARIF : Endif
  Else
      [M:PSH1]PRIFLG(NOL)=1 : Gosub INI_TARIF
  Endif
  #----- Alimentation des codes taxe -----#
  Call ALIVATCOD(2,VALEUR,[M:PSH1]ITMREF(NOL),"PSH1",NOL) From TRTX3
  #-----
  End
Endif
#----- Lecture ITMMASTER si nécessaire -----#
If [F:ITM]ITMREF<>[M:PSH1]ITMREF(NOL)
  Read [ITM] ITM0=[M:PSH1]ITMREF(NOL) : If fstat  Raz [F:ITM] : Endif
Endif
#----- Vérification couple article-fournisseur -----#
# Issue X3-55891 - 2018-08-10 by MUARN : eploitation table article/fournisseur/site
#If !clalev([F:ITP])  Local File ITMBPS [ITP] : Endif
#Read [ITP] ITP0=[M:PSH1]ITMREF(NOL);VALEUR
#If !fstat
#  #----- Test du code blocage -----#
#  If [F:ITP]DOUFLG=3
#    GMESSAGE=mess(9,194,1) : GERR=1 : mkstat=2 : End
#  Elsif [F:ITP]DOUFLG=2
#    Call AVERTIR(mess(9,194,1),WRETOUR) From GESECRAN
#    If WRETOUR=1
#      VALEUR=[M:PSH1]BPSNUM(NOL)    : mkstat=2 : End
#    Endif
#  Endif
#  WPUU=[F:ITP]PUU
#Else
#  Raz [F:ITP]
#  # Issue 77999 - 2011-11-18 by VPO : référencement inutile si fournisseur de type Divers
#  If [F:BPS]BPSNUM<>VALEUR
#    Read [BPS] BPS0=VALEUR : If fstat Raz [F:BPS] : Endif
#  Endif
#  #----- Si fournisseur <> Divers -----#
#  If [F:BPS]BPSTYP<>3
#    #----- Si article non générique -----#
#    If [F:ITM]GENFLG<>2
#      If GITMBPS=1
#        GMESSAGE=mess(8,194,1) : GERR=1 : mkstat=2 : End
#      Elsif GITMBPS=2
#        Call AVERTIR(mess(8,194,1),WRETOUR) From GESECRAN
#        If WRETOUR=1  VALEUR=[M:PSH1]BPSNUM(NOL) : mkstat=2 : End : Endif
#      Endif
#    Endif
#  Endif
#  WPUU=[F:ITM]PUU
#Endif
Call CTRL_DOUFLG(1,[M:PSH1]ITMREF(NOL),VALEUR,[M:PSH1]PRHFCY(NOL),WITMBPS,WRETOUR) From TRTACHCTL1
If WRETOUR<>0
  VALEUR=[M:PSH1]BPSNUM(NOL)    : mkstat=2 : End
Endif
If WITMBPS>0
  WPUU=[F:ITP]PUU
Else
  WPUU=[F:ITM]PUU
Endif

#-----
If !find([M:PSH1]PUU(NOL),[F:ITM]PCU(0..dim([F:ITM]PCU)-1)) & [M:PSH1]PUU(NOL)<>[F:ITP]PCU
  WUOM=WPUU
Else
  WUOM=[M:PSH1]PUU(NOL)
Endif
#----- Conversion quantité dans la nouvelle unité -----#
If WUOM=[M:PSH1]PUU(NOL)
  #----- Conversion à partir de L'UA -----#
  Call PCAL_QTY([M:PSH1]QTYPUU(NOL),[M:PSH1]PUU(NOL),WQTY,[M:PSH1]STU(NOL),
&               [M:PSH1]ITMREF(NOL),VALEUR,1,WCOEUOM) From TRTACHQTE1
  If WQTY<>[M:PSH1]QTYSTU(NOL)
    [M:PSH1]QTYSTU(NOL)=WQTY
    WQTY=[M:PSH1]QTYPUU(NOL) : [M:PSH1]QTYPUU(NOL)+=1 : # Pour provoquer une différence
  Else
    WQTY=[M:PSH1]QTYPUU(NOL)
  Endif
Else
  #----- Conversion à partir de l'US -----#
  Call PCAL_QTY([M:PSH1]QTYSTU(NOL),[M:PSH1]STU(NOL),WQTY,WUOM,
&               [M:PSH1]ITMREF(NOL),VALEUR,1,WCOEUOM) From TRTACHQTE1
  WPUU=[M:PSH1]PUU(NOL) : # Sauvegarde PUU de l'écran
  #-----
  [M:PSH1]PUU(NOL)=WUOM : QTEUA=WQTY : Gosub POINT_PURQTYRND From SUBPOHB
  #----- Si quantité en UA modifiée, il faut recalculer la quantité en US -----#
  # Issue 76174 - 2011-09-13 by VPO : ajout cas depuis CALQTY de TRTDIV
  # il faut prendre en compte arrondi de GPURQTYRND avant arrondi de l'unité
  # modif de PCAL_QTY, il faut donc recalculer QTYSTU
  #If WQTY<>QTEUA
  If WQTY<>QTEUA | ([M:PSH1]QTYSTU(NOL)*WCOEUOM)<>QTEUA
    WQTY=QTEUA
    Call PCAL_QTY(WQTY,WUOM,[M:PSH1]QTYSTU(NOL),[M:PSH1]STU(NOL),
&                 [M:PSH1]ITMREF(NOL),VALEUR,1,WCOEUOM) From TRTACHQTE1
  Endif
  #-----
  [M:PSH1]PUU(NOL)=WPUU : # Restitution PUU de l'écran
Endif
#----- Réajustement des unités et des quantités si nécessaire -----#
If WUOM<>[M:PSH1]PUU(NOL) | WQTY<>[M:PSH1]QTYPUU(NOL)
  [M:PSH1]PUU(NOL)   =WUOM
  [M:PSH1]QTYPUU(NOL)=WQTY
  #----- Conversion qté consommée dans la nouvelle unité à partir de l'US -----#
  If [M:PSH1]WQTYORDPUU(NOL)<>0 | [M:PSH1]WQTYORDSTU(NOL)<>0
    Call PCAL_QTY([M:PSH1]WQTYORDSTU(NOL),[M:PSH1]STU(NOL),[M:PSH1]WQTYORDPUU(NOL),
&                 [M:PSH1]PUU(NOL),[M:PSH1]ITMREF(NOL),VALEUR,1,WCOEUOM) From TRTACHQTE1
  Endif
  #----- Fournisseur modifié, réajustement des unités et des quantités -----#
  # Issue 105256 - 2015-04-29 by MUARN : ne pas afficher le message si c'est en init du fournisseur après saisie article
  If (!GIMPORT | GREP<>"C") & zoncou <> "ITMREF"
    Call MESSAGE(mess(315,194,1)) From GESECRAN
    Affzo [PSH1]PUU(NOL),QTYPUU(NOL),QTYSTU(NOL) : nolign=NOL+1
  Endif
Endif
#----- Lecture BPARTNER pour chargement de la devise -----#
If [F:BPR]BPRNUM<>VALEUR
  Read [BPR] BPR0=VALEUR : If fstat  Raz [F:BPR] : [F:BPR]CUR=GCUR : Endif
Endif
If [F:BPS]BPSNUM<>VALEUR
  Read [BPS] BPS0=VALEUR : If fstat  Raz [F:BPS] : [F:BPS]CUR=GCUR : [F:BPS]CHGTYP=GPURCHGTYP : Endif
Endif
#----- Contrôle que le fournisseur n'appartienne pas au même site que la demande -----#
If [F:BPR]FCY=[M:PSH0]PSHFCY
  GMESSAGE=mess(307,194,1) : GERR=1 : mkstat=1 : End
Endif
# Issue 78167 - 2011-11-24 by VPO : designation traduite selon la langue du fourn
If VALEUR<>[M:PSH1]BPSNUM(NOL)
   If [F:BPR]LAN="" : [F:BPR]LAN=GLANGUE : Endif
   If [F:BPR]LAN<>[M:PSH1]LAN(NOL)
      Local Integer OK
      OK=2 : Call OUINON(mess(426,194,1),OK) From GESECRAN
      If OK=2
        [M:PSH1]LAN(NOL)=[F:BPR]LAN
        Call CHARGE_DEFITMDES("DES1AXX",[M:PSH1]LAN(NOL),[F:ITM]ITMREF,[M:PSH1]ITMDES(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
        Affzo [M:PSH1]ITMDES(NOL)
      Endif
   Endif
   # Issue 102671 - 2015-05-11 by MUARN : réinitialisation des comptes
   If GPSHINIACC > 1
     Local Integer OK
     OK = 2
     If GPSHINIACC = 3
       OK=2 : Call OUINON(mess(340,194,1),OK) From GESECRAN
     Endif
     If OK = 2
       [M:PSH1]BPSNUM(NOL)=VALEUR
       Raz [M:PSH1]LINPURTYP(NOL)
       Call INIT_COMPTES_LIGNE(NOL)
       Call D_LINPURTYP([M:PSH1]LINPURTYP(NOL))
       GBIDI2=0 : Gosub PREP_INIT_CCE
       If !GIMPORT
         Gosub AFFICH_LINACC
         Gosub AFFICH_CCE
         Affzo [PSH1]LINPURTYP(NOL)
       Endif
     Endif
   Endif
Endif
#-----
[M:PSH1]CUR   (NOL)=[F:BPS]CUR
[M:PSH1]CHGTYP(NOL)=[F:BPS]CHGTYP
#----- Chargement du régime de taxe du fournisseur et de la devise -----#
[M:PSH1]VACBPR(NOL)=[F:BPS]VACBPR
Call INIT_REGIME(VALEUR,[M:PSH0]PSHFCY,"F",[M:PSH1]VACBPR(NOL)) From CPTSUB
#----- Chargement du type de régime taxe -----#
#If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>[M:PSH1]VACBPR(NOL)
#Read [ADI] CODE=1;[M:PSH1]VACBPR(NOL) : If fstat Raz [F:ADI] : Endif
#[M:PSH1]VACTYP(NOL)=[F:ADI]N1
Local Integer WRET
Call LEC_TVB_LEG(GCURLEG,[M:PSH1]VACBPR(NOL),WRET) From TRTLECLEG
If WRET Raz [F:TVB] : Endif
[M:PSH1]VACTYP(NOL)=[F:TVB]REGVAC
#----- Recherche tarif -----#
[M:PSH1]BPSNUM(NOL)=VALEUR
#VPO 26/10/10 58959 question prix et tarif sur chgt fournisseur
#[M:PSH1]PRIFLG(NOL)=1
#Gosub INI_TARIF
If [M:PSH1]LINFLG(NOL)=1
  Local Integer OK
  OK=2 : Call OUINON(mess(63,196,1),OK) From GESECRAN
  If OK=2: [M:PSH1]PRIFLG (NOL) = 1
    Gosub INI_TARIF : Endif
Else
  [M:PSH1]PRIFLG(NOL)=1 : Gosub INI_TARIF
Endif
#----- Contrôle date commande par rapport aux indisponibilités fournisseur -----#
If [F:BPS]BPSNUM<>VALEUR
  Read [BPS] BPS0=VALEUR : If fstat Raz [F:BPS] : Endif
Endif
If [M:PSH1]EXTORDDAT(NOL)<>[0/0/0] & VALEUR<>""
  Call CTL_PER ([M:PSH1]EXTORDDAT(NOL),[F:BPS]UVYCOD) From CONTX3
  If mkstat
    GMESSAGE=mess(73,198,1)-VALEUR+"\"+GMESSAGE
    GMESSAGE=mess(1,503,1)-format$("D:"+GFMDAT,[M:PSH1]EXTORDDAT(NOL))-GMESSAGE
    Call MESSAGE (GMESSAGE) From GESECRAN
    Raz mkstat, GMESSAGE
  Endif
Endif
#----- Récupération des liens texte article ou article-fournisseur -----#
If !find(left$([M:PSH1]LINTEX(NOL),3),"PSD")
  [M:PSH1]LINTEX(NOL)=[F:ITM]PURTEX
  If VALEUR<>""
    If [F:ITP]ITMREF<>[M:PSH1]ITMREF(NOL) & [F:ITP]BPSNUM<>VALEUR
      Read [ITP] ITP0=[M:PSH1]ITMREF(NOL);VALEUR : If fstat  Raz [F:ITP] : Endif
    Endif
    If [F:ITP]TEX<>""  [M:PSH1]LINTEX(NOL)=[F:ITP]TEX : Endif
  Endif
Endif
#----- Alimentation des codes taxe -----#
Call ALIVATCOD(2,VALEUR,[M:PSH1]ITMREF(NOL),"PSH1",NOL) From TRTX3
#-----
End


Subprog AS_PJT(VALEUR)
#----------------------#
# Avant saisie affaire #
#----------------------#
Variable Char     VALEUR
If GMODIF  = 0 : mkstat = 2 : Endif
End

Subprog AM_PJT(VALEUR)
#---------------------#
# Après modif affaire #
#---------------------#
Variable Char    VALEUR()
Local   Shortint NOL : NOL=nolign-1
#VPO 07/02/11 71372 rech tarif sur affaire
#----- Recherche tarif -----#
[M:PSH1]PJT(NOL)=VALEUR
If [M:PSH1]LINFLG(NOL)=1
  Local Integer OK
  OK=2 : Call OUINON(mess(63,196,1),OK) From GESECRAN
  If OK=2: [M:PSH1]PRIFLG (NOL) = 1
    Gosub INI_TARIF : Endif
Else
  [M:PSH1]PRIFLG(NOL)=1 : Gosub INI_TARIF
Endif
End


Subprog AV_EXTORDDAT(VALEUR)
#----------------------------#
# Date théorique de commande #
#----------------------------#
Variable Date     VALEUR
#-----
Local    Shortint NOL  : NOL=nolign-1
#----------------------------------------------------#
# Avant zone date de réception prévue :              #
# Initialisation tarif si ligne en cours de création #
# il faut recuperer le delai avant le calcul date    #
#----------------------------------------------------#
If [M:PSH1]CREFLG(NOL)=0
  If [M:PSH1]LINFLG(NOL)<>1 & [M:PSH1]ITMREF(NOL)<>""
    Gosub INI_TARIF
  Endif
Endif
#----- Initialisation des comptes et du type d'achat -----#
If !varinit([M:PSH1]LINACC1,NOL) & [M:PSH1]ITMREF(NOL)<>""
  Call INIT_COMPTES_LIGNE (NOL) From SUBPSH
  Call D_LINPURTYP([M:PSH1]LINPURTYP(NOL)) : # Initialisation type d'achat
  GBIDI2=0 : Gosub PREP_INIT_CCE From SUBPSH
  If !GIMPORT
    Gosub AFFICH_LINACC
    Gosub AFFICH_CCE
    # Issue 105858 - 2015-05-11 by MUARN : ajout affichage
    Affzo [PSH1]LINPURTYP(NOL)
  Endif
Endif
#-------------------------------------------------------#
# calcul de la date en fonction date souhaitée et délai #
#-------------------------------------------------------#
If VALEUR=[0/0/0] & [M:PSH1]EXTRCPDAT(nolign-1)<>[0/0/0]
  VALEUR=[M:PSH1]EXTRCPDAT(nolign-1)-[M:PSH1]OFS(nolign-1)
  If [F:BPS]BPSNUM<>[M:PSH1]BPSNUM(nolign-1)
    Read [BPS] BPS0=[M:PSH1]BPSNUM(nolign-1) : If fstat Raz [F:BPS] : Endif
  Endif
  Call CTL_PER (VALEUR,[F:BPS]UVYCOD) From CONTX3
  If mkstat
    GMESSAGE=mess(73,198,1)-[M:PSH1]BPSNUM(nolign-1)+"\"+GMESSAGE
    GMESSAGE=mess(1,503,1)-format$("D:"+GFMDAT,VALEUR)-GMESSAGE
    Call MESSAGE (GMESSAGE) From GESECRAN
    Raz mkstat, GMESSAGE
  Endif
Endif
End

Subprog AS_EXTORDDAT(VALEUR)
#----------------------------#
# Date théorique de commande #
#----------------------------#
Variable Date     VALEUR
If GMODIF = 0 : mkstat = 2 : Endif
End

Subprog AM_EXTORDDAT(VALEUR)
#----------------------------------------#
# Après modif date théorique de commande #
#----------------------------------------#
Variable Date     VALEUR
Local Integer OK
If [F:BPS]BPSNUM<>[M:PSH1]BPSNUM(nolign-1)
  Read [BPS] BPS0=[M:PSH1]BPSNUM(nolign-1)
  If fstat Raz [F:BPS] : Endif
Endif
Call CTL_PER (VALEUR,[F:BPS]UVYCOD) From CONTX3
If mkstat
  GMESSAGE=mess(73,198,1)-[M:PSH1]BPSNUM(nolign-1)+"\"+GMESSAGE
  GMESSAGE=mess(1,503,1)-format$("D:"+GFMDAT,VALEUR)-GMESSAGE
  OK=2 : Call AVERTIR (GMESSAGE,OK) From GESECRAN
  If OK=1 : mkstat=2 : Raz GMESSAGE : End : Endif
  Raz mkstat, GMESSAGE
Endif
End

Subprog IB_NETPRI
#----------------------#
# Init bouton prix net #
#----------------------#
Local Shortint NOL : NOL=nolign-1
Raz GBOUT4
GBOUT1 = mess(42,198,1)  : # Tarif
GBOUT2 = mess(20,198,1)  : # Remises/frais
GBOUT3 = mess(52,198,1)  : # Réinit. tarif
If [M:PSH1]BPSNUM(NOL)<> ""
  GBOUT4 = mess(386,198,1) : # Explication du prix
Endif
End

Subprog AV_NETPRI(VALEUR)
#------------------------------#
# Avant zone prix unitaire net #
#------------------------------#
Variable Decimal VALEUR
If [M:PSH1]CREFLG(nolign-1)<>0  End : Endif
# Issue X3-47010 - 2017-07-17 by SR : Si AV_NETPRI appelé en changement de site, le tableau des lignes est vide, il ne faut pas lancer INI_TARIF
If [M:PSH1]ITMREF(nolign-1)<>""
  Gosub INI_TARIF
  VALEUR=[M:PSH1]NETPRI(nolign-1)
Endif
End

Subprog AS_NETPRI(VALEUR)
#-----------------------#
# Avant saisie prix net #
#-----------------------#
Variable Decimal VALEUR
Local Shortint NOL : NOL=nolign-1
If GMODIF = 0 : mkstat = 2 : Endif
#---- Raz du GBOUT4 si valeur = 0
If VALEUR = 0
  Raz GBOUT4
Endif
#----- Lecture BPSUPPLIER si nécessaire pour nom & structure tarif -----#
If [F:BPS]BPSNUM<>[M:PSH1]BPSNUM(NOL)
   Read [BPS] BPS0=[M:PSH1]BPSNUM(NOL) : If fstat Raz [F:BPS] : Endif
Endif
#----- Chargement paramètres et libellés colonnes tarif -----#
If GPLISTC<>[F:BPS]PLISTC
  GPLISTC=[F:BPS]PLISTC : Call TARIFCHGT(6) From TRTPRICE
  Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
Endif
# Issue 120830 - 2017-01-12 by SR : Interdire la modification du prix ramené par le tarif
GPOINT = "NOMODPRI": Gosub ENTREE From EXEFNC
If mkstat = 2 : End : Endif

End

Subprog B3_NETPRI(VALEUR)
#------------------------#
# Réinitialisation tarif #
#------------------------#
Variable Decimal  VALEUR
Local Shortint SNOLIGN
SNOLIGN = nolign
[M:PSH1]PRIFLG(nolign-1)=1
Gosub INI_TARIF
VALEUR=[M:PSH1]NETPRI(nolign-1)
mkstat=99
End

Subprog AM_NETPRI(VALEUR)
#----------------------#
# Apres modif prix net #
#----------------------#
Variable Decimal  VALEUR
Local    Shortint NOL  : NOL=nolign-1
If VALEUR=[M:PSH1]NETPRI(NOL) End : Endif
#-------------------------------------#
# initialisation prix brut et remises #
#-------------------------------------#
[M:PSH1]GROPRI (NOL) = VALEUR
[M:PSH1]PRIREN (NOL) = GDACMANPUR
For I = 1 To 9
  If evalue("dim([M:PSH1]DISCRGVAL"+num$(I)+"(NOL))") >= 0
    Assign "[M:PSH1]DISCRGVAL"+num$(I)+"(NOL)" With 0
    If [M:PSH1]LINFLG (NOL) <> 1
      Assign "[M:PSH1]DISCRGREN"+num$(I)+"(NOL)" With GDACMANPUR
    Endif
  Endif
Next I
#----- Initialisation comptes et type d'achat lors de la 1ère modif du prix -----#
# Issue 105858 - 2015-05-12 by MUARN : ne pas faire si les comptes sont déjà initialisés
If [M:PSH1]CREFLG(NOL)=0 & [M:PSH1]LINFLG(NOL)<>1 & [M:PSH1]ITMREF(NOL)<>"" & !varinit([M:PSH1]LINACC1,NOL)
  [M:PSH1]NETPRI(NOL)=VALEUR
  Call INIT_COMPTES_LIGNE(NOL)
  Call D_LINPURTYP([M:PSH1]LINPURTYP(NOL))
  If !GIMPORT
    Gosub AFFICH_LINACC
    Affzo [PSH1]LINPURTYP(NOL)
  Endif
Endif
#----- Calcul du montant HT ligne -----#
[M:PSH1]LINAMT(NOL)=VALEUR*[M:PSH1]QTYPUU(NOL)
Call ARRDEV([M:PSH1]LINAMT(NOL),[M:PSH1]CUR(NOL)) From TRTDIV
If !GIMPORT Affzo [PSH1]LINAMT(NOL) : Endif
End

