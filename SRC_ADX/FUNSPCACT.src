#<AdxTL>@(#)133.0.0.0 $Revision$
######################################################################## 
# FUNSPCACT                                        JL - Novembre 2000  #
#                                                                      #
#    ACTIVATION TARIFS                                                 #
#                                                                      #
#    - Traitement        : FUNSPCACT                                   #
#    - Action e_commerce : SAISPCACT (Saisie fenêtre)                  #
#                                     Fenêtre : FSPCACT                #
#----------------------------------------------------------------------# 
# Attention : Ce traitement contient aussi les actions sur champ       # 
#             de l'écran SPCACTIF [M:SP1]                              # 
######################################################################## 

######################################################################## 
# Etiquettes ACTION
######################################################################## 
$ACTION

#--- Actions liées à la fenêtre de Recherche du tarif
Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "DEBUT"        : Raz [M:SP1]
  When "AV_CHOIX"     : Gosub AV_CHOIX
  When "APRES_MODIF"  : REP="M"
  When "ABA"          : REP=""
  When "ENR"          : Gosub ENR : REP="" 
  When Default
Endcase

######################################################################## 
# Détail des actions liées à la saisie fenêtre
######################################################################## 
$OUVRE
If clalev ([F:SPC])=0 :LOCAL File SPRICCONF [SPC] : Endif
Return

######################################################################## 
$AV_CHOIX
nolign = 0
For [SPC]
 nolign += 1
 [M] = [F:SPC]
 Call LECTEXTRA ([M]PLIDES(nolign-1),"SPRICCONF","DESAXX",[F:SPC]PLI,"") From ATEXTRA
 [M]OPIO(nolign-1)=[F:SPC]PIO
 [M]OPLIENAFLG(nolign-1)=[F:SPC]PLIENAFLG
Next
[M]NBTAR = nolign

Affzo [M:SP1]

Return

######################################################################## 
$ENR
Local Integer I

Call DEBTRANS From GLOCK

Trbegin [SPC]
For I=0 To [M]NBTAR-1  
  If [M]PIO(I)<>[M]OPIO(I) | [M]PLIENAFLG(I)<>[M]OPLIENAFLG(I)
     [M]UPDUSR(I)=GUSER
     [M]UPDDAT(I)=date$
  Endif
  Update [SPC] Where PLI=[M]PLI(I) 
&              With PLIENAFLG=[M]PLIENAFLG(I), PIO=[M]PIO(I), UPDUSR=[M]UPDUSR(I), UPDDAT=[M]UPDDAT(I) 
  If fstat GOK=0 : Call FSTA("SPC") From GLOCK : Break : Endif 
Next I  

If GOK=1   Commit  Else  Rollback   Endif


Return

 
######################################################################### 
# Actions champs de l'écran SPCACTIF                                    # 
######################################################################### 

Subprog AV_NBTAR 
If [M]NBTAR=0 : mkstat=2 : End : Endif 
End 
 
######################################## 
Subprog AM_PIO(VALEUR) 
Variable Decimal  VALEUR 
If VALEUR<1 | VALEUR>99 : mkstat=1 : Endif 
End 

######################################################################### 
 
