#<AdxTL>@(#)0.0.0.0 $Revision$
##################################
# 107513 (05/2015) : version management in Work orders
##################################

##################################
Subprog AM_ITMREF(VALEUR)
Variable Char VALEUR

Local Integer LALT
If dim([M:MFG1]ECCVALMAJ(nolign-1))>0
    Effzo [M:MFG1]ECCVALMAJ(nolign-1), ECCVALMIN(nolign-1)
    Call ECCAFF(VALEUR,"MFG1")
    If func ECCLIB.NBRCPN(VALEUR)
        Effzo [M:MFG1]BOMALT(nolign-1)
        # ECC preload of major and minor version + BOM code
        LALT = [M:MFG1]BOMALT(nolign-1)
        Raz [M:MFG1]ECCVALMAJ(nolign-1),[M:MFG1]ECCVALMIN(nolign-1)
        Call INIECCBOM(VALEUR, [M:MFG0]MFGFCY, [M:MFG1]STRDAT, 2, [M:MFG1]ECCVALMAJ(nolign-1),[M:MFG1]ECCVALMIN(nolign-1),LALT) From MFGECCLIB
        [M:MFG1]BOMALT(nolign-1) = LALT
        Affzo [M:MFG1]ECCVALMAJ(nolign-1),ECCVALMIN(nolign-1),BOMALT(nolign-1)
    Endif
Endif

End

##################################
Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
If func ECCLIB.NBRCPN([M]ITMREF(nolign-1))<1
    mkstat=2
Elsif [M:MFG1]MFGTRKFLG > 3
    # No modification of version number if WO is at least in progress
    mkstat=2
Endif
End

##################################
Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Local Integer LRET

Call CTRECC([M:MFG1]ITMREF(nolign-1),"MFG1","ECCVALMAJ",VALEUR,[M:MFG1]ECCVALMIN(nolign-1),
&           [M:MFG1]STRDAT,LRET,[M:MFG1]ECCERRMSG(nolign-1)) From ECCLIB

[M:MFG1]ECCERRCOD(nolign-1) = LRET

If find(LRET,1,4)
    GMESSAGE=[M:MFG1]ECCERRMSG(nolign-1)
    mkstat=2
Endif
End

##################################
Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
If func ECCLIB.NBRCPN([M]ITMREF(nolign-1))<2
    mkstat=2
Elsif [M:MFG1]MFGTRKFLG > 3
    # No modification of version number if WO is at least in progress
    mkstat=2
Endif
End

##################################
Subprog C_ECCVALMIN(VALEUR)
Variable Char    VALEUR()

Local Integer LRET

Call CTRECC([M:MFG1]ITMREF(nolign-1),"MFG1","ECCVALMIN",[M:MFG1]ECCVALMAJ(nolign-1),VALEUR,
&           [M:MFG1]STRDAT,LRET,[M:MFG1]ECCERRMSG(nolign-1)) From ECCLIB

[M:MFG1]ECCERRCOD(nolign-1) = LRET

If find(LRET,1,4)
    GMESSAGE=[M:MFG1]ECCERRMSG(nolign-1)
    mkstat=2
Endif
End

##################################
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()

If  VALEUR=""
& | dim([M:MFG1]ECCVALMAJ)<0
& | [M:MFG1]ECCVALMAJ(nolign-1)=""
    End
Endif
If clalev([F:STL])=0 : Local File STOLOT [STL] : Endif
Read [STL]STL0(2)=[M:MFG1]ITMREF(nolign-1);VALEUR
Filter [STL]
If !fstat & !( [F:STL]ECCVALMAJ = [M:MFG1]ECCVALMAJ(nolign-1)
&            & [F:STL]ECCVALMIN = [M:MFG1]ECCVALMIN(nolign-1))
    mkstat=2
    GMESSAGE = mess(395,184,1)
Endif

End

##################################
Subprog APRES_NBLIG(NOL)
Value Integer NOL
If func ECCLIB.NBRCPN([M:MFG1]ITMREF(NOL))
    Call HIGHLIGHT("MFG1",NOL) From ECCLIB
Endif
End

##################################
Subprog C_STRDAT(VALEUR)
Variable Date VALEUR

Local Date LSAVDAT

# VALEUR can contain a new value, but CTRECCPRD needs [M:MFG1]STRDAT
LSAVDAT = [M:MFG1]STRDAT
[M:MFG1]STRDAT = VALEUR
Call CTRECCPRD(-1)      # Control each line of product and highlight them if necessary
Call HIGHLIGHT("MFG1",-1) From ECCLIB : # Issue 119469 GH 04/11/16 - performance enhancement
[M:MFG1]STRDAT = LSAVDAT

Call CTRECCCPN(-1)      # Control each line of component and highlight them if necessary
Call HIGHLIGHT("MFG2",-1) From ECCLIB : # Issue 119469 GH 04/11/16 - performance enhancement

If dim([M:MFG1]ROUECCMAJ)=1 & !GIMPORT
   Call CTRROUECC([M:MFG1]ROUNUM,[M:MFG0]MFGFCY,"MFG1","ROUECCMIN",[M:MFG1]ROUECCMAJ,[M:MFG1]ROUECCMIN,VALEUR,GERR,GMESSAGE) From RVMLIB
   Call HIGHLIGHT("MFG1",GERR) From RVMLIB
   GMESSAGE="" : GERR=0
Endif
End

######################################################################################
# Display or hide version fields in work order context
Subprog ECCAFF(ITM, ABR)
Value Char ITM
Value Char ABR

If dim([M]ECCVALMAJ)<0 | GIMPORT : End : Endif

Local Integer LACTMAJ, LACTMIN, LACTBOM
Local Integer I
I=func ECCLIB.NBRCPNCST(ITM)

If !I
    LACTMAJ = 0
    LACTMIN = 0
    LACTBOM = 1   # if no version management => BOMALT can be entered

Else
    If I=1
        LACTMAJ = 1
        LACTMIN = 0
    Else
        LACTMAJ = 1
        LACTMIN = 1
    Endif
    LACTBOM=0   # if version management => BOMALT can't be entered
Endif

# It's necessary to define the mask (context of tunnel)
Case ABR
    When "MFG1"
         If !LACTMAJ
             Diszo [M:MFG1]ECCVALMAJ(nolign-1)
         Else
             Actzo [M:MFG1]ECCVALMAJ(nolign-1)
         Endif
         If !LACTMIN
             Diszo [M:MFG1]ECCVALMIN(nolign-1)
         Else
             Actzo [M:MFG1]ECCVALMIN(nolign-1)
         Endif
         If !LACTBOM
             Diszo [M:MFG1]BOMALT(nolign-1)
         Else
             Actzo [M:MFG1]BOMALT(nolign-1)
         Endif

    When "MFMW":
         If !LACTMAJ
             Diszo [M:MFMW]ECCVALMAJ
         Else
             Actzo [M:MFMW]ECCVALMAJ
         Endif
         If !LACTMIN
             Diszo [M:MFMW]ECCVALMIN
         Else
             Actzo [M:MFMW]ECCVALMIN
         Endif

    When "MFMF":
         If !LACTMAJ
             Diszo [M:MFMF]GHTECCMAJ
         Else
             Actzo [M:MFMF]GHTECCMAJ
         Endif
         If !LACTMIN
             Diszo [M:MFMF]GHTECCMIN
         Else
             Actzo [M:MFMF]GHTECCMIN
         Endif
         If !LACTBOM
             Diszo [M:MFMF]GHOSTALT
         Else
             Actzo [M:MFMF]GHOSTALT
         Endif
Endcase
End


Subprog CTRECCPRD(PIND)
Value Integer PIND

Local Integer LRET
Local Integer LREFRESH
Local Integer LMSGFLG
Local Integer SAVNOLIGN : SAVNOLIGN = nolign
Local Integer LINDSTR, LINDEND

If PIND<-1 | PIND>=[M:MFG1]NBLIG | dim([M:MFG1]ECCVALMAJ)<0
    End
Endif
If PIND=-1
    LINDSTR = 0
    LINDEND = [M:MFG1]NBLIG-1
Else
    LINDSTR=PIND
    LINDEND=PIND
Endif

For nolign=LINDSTR+1 To LINDEND+1
    Call CTRECC([M:MFG1]ITMREF(nolign-1),"MFG1","STRDAT",[M:MFG1]ECCVALMAJ(nolign-1),[M:MFG1]ECCVALMIN(nolign-1),
&                   [M:MFG1]STRDAT,LRET,[M:MFG1]ECCERRMSG(nolign-1)) From ECCLIB
    If LRET<>[M:MFG1]ECCERRCOD(nolign-1)
        [M:MFG1]ECCERRCOD(nolign-1) = LRET
        If PIND<>-1 : # Issue 119469 GH 04/11/16 - Performance enhancement
           Call HIGHLIGHT("MFG1",nolign-1) From ECCLIB
        Endif
    Endif
Next

nolign = SAVNOLIGN
End

Subprog CTRECCCPN(PIND)
Value Integer PIND

Local Integer LRET
Local Integer LREFRESH
Local Integer LMSGFLG
Local Integer SAVNOLIGN : SAVNOLIGN = nolign
Local Integer LINDSTR, LINDEND

If PIND<-1 | PIND>=[M:MFG2]NBLIG | dim([M:MFG2]ECCVALMAJ)<0
    End
Endif
If PIND=-1
    LINDSTR = 0
    LINDEND = [M:MFG2]NBLIG-1
Else
    LINDSTR=PIND
    LINDEND=PIND
Endif

For nolign=LINDSTR+1 To LINDEND+1
    If [M:MFG2]CPNTYP(nolign-1)<>5
        If [M:MFG2]GHTFLG(nolign-1)=1
            # Phantom for which BOM was unusable
            Call CTRECC([M:MFG2]ITMREF(nolign-1),"MFMF","GHTECCMIN",[M:MFG2]ECCVALMAJ(nolign-1),[M:MFG2]ECCVALMIN(nolign-1),
&                       [M:MFG2]RETDAT(nolign-1),LRET,[M:MFG2]ECCERRMSG(nolign-1)) From ECCLIB
        Else
            Call CTRECC([M:MFG2]ITMREF(nolign-1),"MFG2","STRDAT",[M:MFG2]ECCVALMAJ(nolign-1),[M:MFG2]ECCVALMIN(nolign-1),
&                       [M:MFG2]RETDAT(nolign-1),LRET,[M:MFG2]ECCERRMSG(nolign-1)) From ECCLIB
        Endif
        If LRET<>[M:MFG2]ECCERRCOD(nolign-1)
            [M:MFG2]ECCERRCOD(nolign-1) = LRET
            If PIND<>-1 : # Issue 119469 GH 04/11/16 - Performance enhancement
               Call HIGHLIGHT("MFG2",nolign-1) From ECCLIB
            Endif
        Endif
    Endif
Next
nolign = SAVNOLIGN
End

#####################################################################
$LIENS
If dim([M:MFG1]ECCVALMAJ)>0
    For nolign=1 To [M:MFG1]NBLIG
        If func ECCLIB.NBRCPN([M:MFG1]ITMREF(nolign-1))
            # if version management => BOMALT can't be entered
            Diszo [M:MFG1]BOMALT(nolign-1)
        Else
            # if no version management => BOMALT can be entered
            Actzo [M:MFG1]BOMALT(nolign-1)
        Endif
        # Issue 119469 GH 04/11/16 - Performance enhancement
        Call CTRECC([M:MFG1]ITMREF(nolign-1),"MFG1","STRDAT",[M:MFG1]ECCVALMAJ(nolign-1),[M:MFG1]ECCVALMIN(nolign-1),
&                   [M:MFG1]STRDAT,LRET,[M:MFG1]ECCERRMSG(nolign-1)) From ECCLIB
        [M:MFG1]ECCERRCOD(nolign-1) = LRET
    Next
    #Call CTRECCPRD(-1)

    If dim([M:MFG1]ROUECCMAJ)>0
        # ISSUE X3-30339 - 2017-04-07 By ALSHE : Release WO managed by PS - block change of routing
        If ([M:MFG1]SCDFLG=4 | [M:MFG1]MFGTRKFLG = 2) & func AFNC.ACTIV("POPS")
            Diszo [M:MFG1]25
        Else
            Call RVMAFF([M:MFG1]ROUNUM,[M:MFG0]MFGFCY,[M:MFG1]ROUALT,"MFG1") From RVMLIB
        Endif
        If !GIMPORT
            Affzo [M:MFG1]25
            Call CTRROUECC([M:MFG1]ROUNUM,[M:MFG0]MFGFCY,"MFG1","ROUECCMIN",[M:MFG1]ROUECCMAJ,[M:MFG1]ROUECCMIN,[F:MFG]STRDAT,GERR,GMESSAGE) From RVMLIB
            Call HIGHLIGHT("MFG1",GERR) From RVMLIB
            GMESSAGE="" : GERR=0
        Endif
    Endif
Endif
Return





