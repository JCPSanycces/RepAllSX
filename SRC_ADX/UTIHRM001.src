#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIHRM001 - Set activity codes (PAPI and HRNOF) values to OFF          #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Set activity codes (PAPI and HRNOF) values to OFF") From LECFIC

  Call MAJ_UTIHRM001(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTIHRM001(DOSSIER)
Value Char DOSSIER
Local Char CODE (GLONACV)

If clalev([F:ACV])=0  : Local File =DOSSIER+".ACTIV" [ACV]  : Endif

Call ECR_TRACE("UTIHRM001 : Set activity codes (PAPI and HRNOF) values to OFF : "+DOSSIER,0) From GESECRAN

Call DEBTRANS From GLOCK

Trbegin [ACV]

[L]CODE="PAPI"
Gosub MAJACV
[L]CODE="HRNOF"
Gosub MAJACV

If !GOK
  Rollback
Else
  Commit
Endif

Call ECR_TRACE("UTIHRM001: Process completed on : "+DOSSIER,0) From GESECRAN

Close Local File [ACV]

End

##############################
$MAJACV
If [L]CODE="PAPI"  & [F:ADS]MODULE(19)=2 : Return : Endif #HRM
If [L]CODE="HRNOF" & [F:ADS]MODULE(14)=2 : Return : Endif #Payroll

Readlock [F:ACV]CODACT=[L]CODE
If !fstat
  If [F:ACV]FLACT=2
    [F:ACV]FLACT=1
    Rewrite [F:ACV]
    If fstat
     GOK = 0 : Call FSTA("ACV") From GLOCK
    Endif
  Endif
Endif

Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTIHRM001(APPLI)

End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTIHRM001(APPLI)

End

