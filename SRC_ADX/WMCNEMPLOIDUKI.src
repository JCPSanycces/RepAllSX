# Supervisor
## ACLA-CLASSE ## EMPLOIDUKI
# 2018-11-06 07:05:56 439

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EMPLOIDUKI
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_REFNUM From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub INIT_FORNAM2 From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub INIT_FORNAM3 From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub INIT_PREMRDNAM From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub INIT_PRENAM From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub INIT_PREEMPREF From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub INIT_AGDDAT From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub INIT_AGDENT From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub INIT_AGDCKK From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub INIT_AGE From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub INIT_ETHORI From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub INIT_BLF From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub INIT_SEXORI From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub INIT_GDRASS From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub INIT_HDCTYP From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub INIT_ADD From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub AINIT From WMC0EMPLOIDUKI : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EMPLOIDUKI
Gosub _ALOADATTRIBUTE_REFNUM From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EMPLOIDUKI
Gosub LNKPRO_HDCTYP From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub LNKPRO_CREUSR From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC1EMPLOIDUKI : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



