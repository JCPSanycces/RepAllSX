####################################################################
# OTHERS
####################################################################

$_AOTHERS
Gosub DECLARE_VAR From WMC0PRJLOT
Local Integer ALLSTAT
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_PRJ From WMC1PRJLOT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_PRJ From WMC1PRJLOT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_LOT From WMC1PRJLOT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_LOT From WMC1PRJLOT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_DESLOT From WMC1PRJLOT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_DESLOT From WMC1PRJLOT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_ACTDAT From WMC1PRJLOT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_ACTDAT From WMC1PRJLOT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_AMTLOT From WMC1PRJLOT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_AMTLOT From WMC1PRJLOT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CURLOT From WMC1PRJLOT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CURLOT From WMC1PRJLOT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_FINMOD From WMC1PRJLOT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_FINMOD From WMC1PRJLOT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_FCY From WMC1PRJLOT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_FCY From WMC1PRJLOT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_FASGRP From WMC1PRJLOT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_FASGRP From WMC1PRJLOT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREDATTIM From WMC1PRJLOT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREDATTIM From WMC1PRJLOT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDDATTIM From WMC1PRJLOT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDDATTIM From WMC1PRJLOT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_AUUID From WMC1PRJLOT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_AUUID From WMC1PRJLOT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREUSR From WMC1PRJLOT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREUSR From WMC1PRJLOT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDUSR From WMC1PRJLOT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDUSR From WMC1PRJLOT : Gosub TESTALLSTAT :  Endif
[L]ASTATUS = fmet this.ACONTROL
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



