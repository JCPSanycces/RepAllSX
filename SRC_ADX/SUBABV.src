#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion objet ABV
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ABV",GBIDC1,GBIDC2) From GOBJET
End

#---------------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"      : Gosub LIENS
 When "CREATION"   : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "APRES_MOD"  : Gosub APRES_MOD
 When "APRES_CRE"  : Gosub APRES_CRE
 When "VERIF_CRE"  : Gosub VERIF_CRE
 When "VERIF_MOD"  : Gosub VERIF_MOD
 When "AP_ANNULE"  : Gosub AP_ANNULE
 When "SETBOUT"    : Gosub SETBOUT
 When "EXEBOUT"    : Gosub EXEBOUT
 When "RAZDUP"     : Gosub RAZDUP
 When "RAZCRE"     : Gosub RAZCRE
Endcase
Return

#--------------------------#

$OUVRE
If filinfo(filpath("FIL","AVIEWTAB","fde"),0)<0
& or filinfo(filpath("FIL","AVIEWFLD","fde"),0)<0
& or filinfo(filpath("FIL","AVIEWIND","fde"),0)<0
 Local File ATABLE  [AVWT]
 Local File ATABZON [AVWF]
 Local File ATABIND  [AVWI]
Else
 Local File AVIEWTAB [AVWT]
 Local File AVIEWFLD [AVWF]
 Local File AVIEWIND [AVWI]
Endif
Return

#--------------------------#
$LIENS
Local Char TABLE(GLONATB)
Call TEXTE([M:ABV0]INTIT,[M:ABV0]ZINTIT) From OBJDIV
nolign = 0
Filter [ABY] Where CODREG=[M]CODREG
Read [ABY] First
Filter [ABY]
TABLE = [F:ABY]TABDES
Call C_TABORG([F:ABV]TABORG)
Gosub CHARGE_CHAMP
For [ABY] Where CODREG=[M]CODREG
 K = find([F:ABY]FLDDES,[M:ABV2]FLDDES(0..[M:ABV2]NBRFLD-1))
 If K
  nolign = K
  [M:ABV2] = [F:ABY]
 Endif
Next
For nolign=1 To [M]NBRLNK
 [M]SUMLNK(nolign-1) = [M]TABLNK(nolign-1)+"~"+[M]ABRLNK(nolign-1)
Next nolign
Gosub GRISE_LNK
Gosub GRISE_DOS
Return

$CHARGE_CHAMP
nolign = 0
For [ABZ]ABZ0 Where CODABF=TABLE
 nolign += 1
 [M:ABV2]FLDDES(nolign-1) = [F:ABZ]CODFLD
 Call TEXTE([F:ABZ]INTFLD,[M:ABV2]INTDES(nolign-1)) From OBJDIV
Next
[M:ABV2]NBRFLD = nolign
Return

$GRISE_LNK
If find([M]TYPLNK,1,3)
 Raz [ABV1]FLDDEC , CNDLIG
 Grizo [ABV1]FLDDEC , CNDLIG
Else
 Actzo [ABV1]FLDDEC , CNDLIG
Endif
Return

#----------------------------------#
$RAZDUP
$RAZCRE
Gosub GRISE_DOS
Return

$GRISE_DOS
If GADONIX=2
 Actzo [ABV1]NBRDOS
Else
 Effzo [ABV1]40
 Grizo [ABV1]NBRDOS
Endif
Return

#--------------------------#
$VERIF_CRE
$VERIF_MOD
If [M]INDLEC<>""
 Local Char TABLE(250)
 Read [ABF]ABF0=[M]TABDES
 If [F:ABF]TYPMAJ=1 : # Incrémental
  K = 1
  If [M]NBRDOS=0
   Local File ATABLE [AT__]
   Read [AT__]CODFIC=[M]TABORG
   If !fstat & [F:AT__]AUDCLE<>[M]INDLEC
    TABLE = [M]TABORG
    K = 0
   Endif
   Close Local File [AT__]
  Else
   For I=1 To [M]NBRDOS
    Local File =[M]ADXDOS(I-1)+".ATABLE" [AT__]
    Read [AT__]CODFIC=[M]TABORG
    If !fstat & [F:AT__]AUDCLE<>[M]INDLEC
     TABLE = [M]ADXDOS(I-1)+"."+[M]TABORG
     K = 0
    Endif
    Close Local File [AT__]
    If !K : Break : Endif
   Next I
  Endif
  If !K
   # La clé de parcours est différente de la clé d'audit référencée dans la table #
   Call ERREUR(func AFNC.MES(mess(67,148,1),TABLE)) From GESECRAN
   OK = 0
  Endif
 Endif
Endif
Return

#--------------------------#
$CREATION
For nolign=1 To [M]NBRFLD
 [F:ABY] = [M:ABV0]
 [F:ABY] = [M:ABV2]
 [F:ABY]NUMDES = nolign
 Write [ABY]
 If fstat
  GOK=0 : Call FSTA("ABY") From GLOCK : Break
 Endif
Next nolign
Return

#--------------------------#
$MODIF
Delete [ABY] Where CODREG=[M]CODREG
If fstat=1
 GOK=-1 : Call RSTA("ABY",[M]CODREG) From GLOCK : Return
Else
 Gosub CREATION
Endif
Return

#--------------------------#
$APRES_MOD
Gosub APRES_CRE
Return

#--------------------------#
$APRES_CRE
If [M]CODREG<>""
 Call VALIDATION([M]CODREG,nomap,0)
Endif
Return

#--------------------------#
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V1") From GOBJET
Endif
If [M]DESFLG=2
 Call VIREBOUT(CHAINE,"V") From GOBJET
Endif
Return

#--------------------------#
$EXEBOUT
Case BOUT
 When "V" : Call VALIDATION([M]CODREG,nomap,0)
Endcase
Return

#--------------------------#
$AP_ANNULE
Local Char PREF(4)
Local Integer STAT
Call SET_PREF([L]CODE,PREF)
If filinfo(filpath("TRT",PREF+[L]CODE,"src",0),0)>0
 Call EFFACE(filpath("TRT",PREF+[L]CODE,"src",0),STAT) From ORDSYS
 Call EFFACE_ADX("","",PREF+[L]CODE,STAT) From ORDSYS
Endif
Return

#--------------------------#
Subprog SET_PREF(CODE,PREF)
Value Char CODE
Variable Char PREF
If len(CODE)=10 & GLONADC=12
 PREF = "WW"
Else
 PREF = "WMB"
Endif
End

########################################################
## Désactivation d'une regle en erreur
########################################################

$DESACTIVE
If APPLI=GDOSX3 : Return : Endif
If !adxlog
 Gosub TR_REGLE
Else
 Gosub MAJ_REGLE
Endif
If GOK=1
 Call ECR_TRACE(CODE-":"-mess(62,139,1),-1) From GESECRAN : # Fiche désactivée
Endif
Return

$TR_REGLE
GOK=1
Trbegin [ABV]
 Gosub MAJ_REGLE
 If GOK<0 : Goto AB_TR_REGLE : Endif
Commit
Return

$AB_TR_REGLE
Rollback
Return

$MAJ_REGLE
Readlock [ABV]ABV0 = CODE
If fstat=1
 GOK = -1 : GLOCK = "$ABIREGORG"
Else
 [F:ABV]DESFLG = 2
 Rewrite [ABV]
 If fstat
  GOK = 0 : Call FSTA("ABV") From GLOCK
 Endif
Endif
Return

#########################################################
## Pour les patches des transactions
#########################################################
Subprog PATCH(APPLI)
Value Char APPLI
Call GENDOS(APPLI)
End

#------------------------------------------------------------#
# Appelé en validation dossier
#------------------------------------------------------------#

Subprog GENDOS(APPLI)
Value Char APPLI
Local Integer OK
If filinfo(filpath("FIL","ABIREGORG","fde",APPLI),0)<=0 : End : Endif
If clalev([F:AB2])=0 : Local File =APPLI+".ABIREGORG" [AB2] : Endif
For [AB2]
 Call ECR_TRACE([F:AB2]CODREG,0) From GESECRAN
 Call VALIDATION([F:AB2]CODREG,APPLI,1)
Next AB2
End

#---------------------------------------------------------#
# Pour synchroniser les tables de faits
#---------------------------------------------------------#

Subprog VALIDATION(CODE,DOSSIER,SILENCE)
Value    Char    CODE
Value    Char    DOSSIER
Value    Integer SILENCE

Local Char     NOMPROG(GLONADC) , FICSRC(GDIMFIC)
Local Char     SAVIFS(10) , SAVIRS(10) , IDENT(20)
Local Integer  SAVIUM
Local Integer  I , J , K , OK , NBCLE , NBLNK , NBVAR , NBTAB
Local Char     CHAINE(250) , CHAINE2(250) , MAGIC(80) , PREF(4)
Local Char     MACHINE(GDIMFIC) , APPLI(GLONADS)
Local Char     CLE(GLONAVA)(1..16) , FILTRE(250)
Local Char     TBLNK(250)(1..16) , TBTAB(GLONATB)(1..16) , TBABR(GLONABR)(1..16)
Local Char     TBCLE(GLONANX)(1..16),TBTYPLNK(2)(0..16)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

If clalev([F:ABW])>0 : Close Local File [ABW] : Endif
If clalev([F:ABX])>0 : Close Local File [ABX] : Endif
If clalev([F:ABV])>0 : Close Local File [ABV] : Endif
If clalev([F:ABY])>0 : Close Local File [ABY] : Endif
If clalev([F:ATY])>0 : Close Local File [ATY] : Endif
If clalev([F:ABZ])>0 : Close Local File [ABZ] : Endif
If clalev([F:AVWT])>0 : Close Local File [AVWT] : Endif
If clalev([F:AVWF])>0 : Close Local File [AVWF] : Endif
If clalev([F:AVWI])>0 : Close Local File [AVWI] : Endif
If clalev([F:AVW])>0 : Close Local File [AVW] : Endif

If clalev([F:ABW])=0 : Local File =DOSSIER+".ABIDATWRH" [ABW] : Endif
If clalev([F:ABX])=0 : Local File =DOSSIER+".ABITABIND" [ABX] : Endif
If clalev([F:ABV])=0 : Local File =DOSSIER+".ABIREGORG" [ABV] : Endif
If clalev([F:ABY])=0 : Local File =DOSSIER+".ABIREGDES" [ABY] : Endif
If clalev([F:ATY])=0 : Local File =DOSSIER+".ATYPE"     [ATY] : Endif
If clalev([F:ABZ])=0 : Local File =DOSSIER+".ABITABFLD" [ABZ] : Endif
If clalev([F:AVW])=0 : Local File =DOSSIER+".AVIEW" [AVW] : Endif

If filinfo(filpath("FIL","AVIEWTAB","fde",DOSSIER),0)<0
& or filinfo(filpath("FIL","AVIEWFLD","fde",DOSSIER),0)<0
& or filinfo(filpath("FIL","AVIEWIND","fde",DOSSIER),0)<0
 Local File =DOSSIER+".ATABLE"   [AVWT]
 Local File =DOSSIER+".ATABZON"  [AVWF]
 Local File =DOSSIER+".ATABIND"  [AVWI]
Else
 Local File =DOSSIER+".AVIEWTAB" [AVWT]
 Local File =DOSSIER+".AVIEWFLD" [AVWF]
 Local File =DOSSIER+".AVIEWIND" [AVWI]
Endif

MAGIC   = mess(77,133,1) : # Superviseur Adonix
Call SET_PREF(CODE,PREF)
NOMPROG = PREF+CODE
IDENT   = "## BI-REGLE ##"

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

If !SILENCE
 Call TEMPON(mess(159,133,1)-NOMPROG) From GESECRAN : # Validation du traitement
Endif

Read [ABV]ABV0=CODE
If !fstat
 #{SAM120919
 If !func AFNC.IS_VALIDATION_ENABLED(APPLI,[F:ABV]CODACT,[F:ABV]MODULE)
  Gosub VALIDATION_EXIT
 Endif
 #SAM120919}
 Gosub VERIF_CLE
 If OK
  Gosub TRT_DEB
  If OK
   Gosub ETIQ
   Gosub TRT_FIN
  Else
   Gosub DESACTIVE
  Endif
 Else
  Gosub DESACTIVE
 Endif
Endif

$VALIDATION_EXIT
If !SILENCE
 Call TEMPOFF From GESECRAN
Endif

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
End

$VERIF_CLE
OK = 0
If filinfo(filpath("FIL",[F:ABV]TABORG,"fde",APPLI),0)<0
 If APPLI<>GDOSX3
  Call ECR_TRACE([F:ABV]TABORG-":"-mess(124,124,1),-1) From GESECRAN  #  :  : Table INEXISTANTE
 Endif
 Return
Endif
Filter [AVWI] Where CODFIC=[F:ABV]TABORG
If dim([F:ABV]INDLEC)>0 & [F:ABV]INDLEC<>""
 Read [AVWI]CODIND=[F:ABV]TABORG;[F:ABV]INDLEC
Else
 Read [AVWI]NUMLIG First
Endif
Filter [AVWI]
If !fstat
 If [AVWI]HOMONYM=2
  # cles avec homonymes
  Call ECR_TRACE([AVWI]CODIND-":"-mess(66,148,1),1) From GESECRAN
  Return
 Elsif func AFNC.ACTIVDOS(DOSSIER,[AVWI]CODACT)=0
  # inexistants car code activité non actif
  Call ECR_TRACE([AVWI]CODIND-":"-mess(226,126,1),1) From GESECRAN
  Return
 Endif
Else
 Call ECR_TRACE(mess(6,114,1),1) From GESECRAN  #  : Clé inexistante
 Return
Endif
OK =1
Return

#-------------------------------------------------------#
$TRT_DEB
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
FICSRC = filpath("TRT",NOMPROG,"src",APPLI,"",MACHINE)
If filinfo(FICSRC,0)>=0
 Openi FICSRC Using [SSS_]
 Raz I, OK
 Rdseq CHAINE Using [SSS_]
 While !fstat
  I += 1 : If I>5 : Break : Endif
  If left$(CHAINE,len(IDENT))=IDENT
   OK = 1 : Break
  Endif
  Rdseq CHAINE Using [SSS_]
 Wend
 Openi Using [SSS_]
 If I<=1
  OK = 1
 Elsif !OK
  # Ce traitement est déjà utilisé par un autre paramètrage
  Call ECR_TRACE(NOMPROG-":"-mess(215,139,1),1) From GESECRAN
  Return
 Endif
Else
 OK = 1
Endif
Openo FICSRC , 0
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq "#"-MAGIC
Wrseq IDENT-mess(10,148,1)-CODE : # Règle d'alimentation
Wrseq
Return

#-------------------------------------------------------#
$TRT_FIN
Wrseq
Openo
Call VALID("TRT",NOMPROG,DOSSIER,OK) From VALMSKSUB
Return

#-------------------------------------------------------#
$ETIQ
Wrseq "$OUVRE"
If [F:ABV]NBRLNK>0
 Raz NBLNK , NBVAR , NBTAB
 For L=1 To [F:ABV]NBRLNK
  If [F:ABV]TABLNK(L-1)<>""
   K = 1
   If [F:ABV]ABRLNK(L-1)="" or instr(1,format$("KTv2:250X",[F:ABV]EXPLNK(L-1)),'func')
    Look [AVWT]CODFIC=[F:ABV]TABLNK(L-1)
    If fstat : K = 0 : Endif
   Endif
   If K
    NBLNK += 1
    If [F:ABV]EXPLNK(L-1)=""
     NBTAB += 1 : TBLNK(NBLNK) = ""
    Else
     TBLNK(NBLNK) = format$("KTv2:250X",[F:ABV]EXPLNK(L-1))
    Endif
    TBTAB(NBLNK) = [F:ABV]TABLNK(L-1)
    TBCLE(NBLNK) = [F:ABV]CLELNK(L-1)
    If [F:ABV]TYPLNKTAB(L-1)=3
     [L]TBTYPLNK(NBLNK) = "~="
    Else
     [L]TBTYPLNK(NBLNK) = "="
    Endif
    If [F:ABV]ABRLNK(L-1)<>""
     TBABR(NBLNK) = [F:ABV]ABRLNK(L-1)
    Else
     Read [AVWT]CODFIC=[F:ABV]TABLNK(L-1)
     TBABR(NBLNK) = [F:AVWT]ABRFIC
    Endif
    If instr(1,TBLNK(NBLNK),'func')
     Read [AVWI]CODIND=[F:ABV]TABLNK(L-1);[F:ABV]CLELNK(L-1)
     Call SETCLE(NBCLE,CLE,[F:AVWI]DESCRIPT) From LNKSUB
     CHAINE = TBLNK(NBLNK)
     Raz TBLNK(NBLNK) , NBCLE
     While CHAINE<>""
      NBCLE += 1
      K = instr(1,CHAINE,";")
      If K
       CHAINE2 = left$(CHAINE,K-1)
       CHAINE = right$(CHAINE,K+1)
      Else
       CHAINE2 = CHAINE
       CHAINE = ""
      Endif
      If instr(1,CHAINE2,'func')
       Read [AVWF]CODZONE=[F:ABV]TABLNK(L-1);CLE(NBCLE)
       Read [ATY]CODTYP=[F:AVWF]CODTYP
       NBVAR += 1
       Case [F:ATY]TYPTYP
        When 1,2,3   : Wrseq 'Local Integer AVAR'+num$(NBVAR)
        When 4,5,6   : Wrseq 'Local Decimal AVAR'+num$(NBVAR)
        When 8       : Wrseq 'Local Date    AVAR'+num$(NBVAR)
        When Default : Wrseq 'Local Char    AVAR'+num$(NBVAR)+'(30)'
       Endcase
       Wrseq 'AVAR'+num$(NBVAR)+' = '+CHAINE2
       CHAINE2 = 'AVAR'+num$(NBVAR)
      Endif
      If TBLNK(NBLNK)<>""
       TBLNK(NBLNK) += ";"
      Endif
      TBLNK(NBLNK) += CHAINE2
     Wend
    Endif
   Endif
  Endif
 Next L
Endif
Wrseq 'Local Char FILTRE(250)'
Read [AVWT]CODFIC=[F:ABV]TABORG
If !fstat
 Wrseq 'OUVTAB = GDOSSIER+".'+[F:ABV]TABORG+'" : ';
 Wrseq 'If clalev([F:'+[F:AVWT]ABRFIC+'])=0 : Local File =OUVTAB ['+[F:AVWT]ABRFIC+'] : Endif'
 For I=1 To NBLNK
  Wrseq 'OUVTAB = GDOSSIER+".'+TBTAB(I)+'" : ';
  Wrseq 'If clalev([F:'+TBABR(I)+'])=0 : Local File =OUVTAB ['+TBABR(I)+'] : Endif'
 Next I
 If NBLNK=NBTAB
  Wrseq 'OUVTAB = GDOSSIER+".'+[F:ABV]TABORG+'" : ';
  Wrseq 'If clalev([F:A_])=0 : Local File =OUVTAB [A_] : Endif'
 Endif
 Wrseq 'OUVTAB = "Link ['+[F:AVWT]ABRFIC+']"'
 Wrseq "Link ["+[F:AVWT]ABRFIC+"] With"
 K = 0
 For I=1 To NBLNK
  If TBLNK(I)<>""
   If instr(1,TBLNK(I),"indice")
    Break
   Elsif K=0
    K = 1
   Else
    Wrseq ","
   Endif
   Wrseq "& ["+TBABR(I)+"]"+TBCLE(I)-[L]TBTYPLNK(I)-TBLNK(I);
  Endif
 Next I
 If K : Wrseq : Endif
 If NBLNK=NBTAB
  Filter [AVWI] Where CODFIC=[F:ABV]TABORG
  Read [AVWI]NUMLIG First
  Filter [AVWI]
  Call SETCLE(NBCLE,CLE,[F:AVWI]DESCRIPT) From LNKSUB
  Wrseq "& [A_]"+[F:AVWI]CODIND+"=";
  For I=1 To NBCLE
   If I>1 : Wrseq ";"; : Endif
   Wrseq "["+[F:AVWT]ABRFIC+"]"+CLE(I);
  Next I
  Wrseq
 Endif
 Wrseq "& As [LNK_]"
 FILTRE = format$("KTv2:250X",[F:ABV]FILTRE)
 If FILTRE<>"" & !instr(1,FILTRE,"func")
  Wrseq "& Where"-FILTRE
  FILTRE = ""
 Endif
 If dim([F:ABV]INDLEC)>0 & [F:ABV]INDLEC<>""
  Wrseq '& Order by key '+[F:ABV]INDLEC
 Endif
Endif
If instr(1,FILTRE,'"')
 Wrseq "FILTRE = '"+FILTRE+"'"
Else
 Wrseq 'FILTRE = "'+FILTRE+'"'
Endif
Wrseq "Return"
Wrseq
Wrseq "$FERME"
Read [AVWT]CODFIC=[F:ABV]TABORG
If !fstat
 Wrseq "If clalev([F:"+[F:AVWT]ABRFIC+"]) : Close local File ["+[F:AVWT]ABRFIC+"] : Endif"
Endif
For I=1 To NBLNK
 Wrseq "If clalev([F:"+TBABR(I)+"]) : Close local File ["+TBABR(I)+"] : Endif"
Next I
If NBLNK=NBTAB
 Wrseq "If clalev([F:A_]) : Close local File [A_] : Endif"
Endif
Wrseq "Return"
Wrseq

Wrseq "$LIEN"
K = 0
For I=1 To NBLNK
 If TBLNK(I)<>""
  If instr(1,TBLNK(I),"indice")
   K = 1
  Endif
  If K
   Wrseq "Read ["+TBABR(I)+"]"+TBCLE(I)-"="-TBLNK(I)
  Endif
 Endif
Next I
Wrseq "Return"

Wrseq ""
Gosub CHARGE_FLD
Wrseq "$MAJFLD"
Local Char FORMULE(250)
If [L]ABR_TABORG<>""
 For I=1 To NBFLD
  Wrseq "### "-TBFLD(I)
  Wrseq '[L]FLD="'+TBFLD(I)+'"'
  If instr(1,TBFOR(I),"'")
   Wrseq '[L]FORMULE="'+TBFOR(I)+'"'
  Else
   Wrseq "[L]FORMULE='"+TBFOR(I)+"'"
  Endif
  Wrseq "If dim([F:AAA_]"+TBFLD(I)+")>0"
  FORMULE = TBFOR(I)
  K = instr(1,FORMULE,"[F]")
  While K
    FORMULE= left$(FORMULE,K+1)+":AAA_"+right$(FORMULE,K+2)
   K = instr(K,FORMULE,"[F]")
  Wend
  K=1
  If FORMULE<>"" & FORMULE<>'""' & FORMULE<>"''"
   If K
    If TBMES(I) : # Mesure
     Wrseq space$(1)+"[F:AAA_]"+TBFLD(I)-"="-TBFOR(I)
    Elsif TBNUM(I)<>""
     If left$(TBNUM(I),3)="ADI"
      Wrseq space$(1)+"GBIDC1 = evalue(FORMULE)"
      Wrseq 'Call LECTEXTRA([AAA_]'+TBFLD(I)+',"ATABDIV","LNGDES","'+right$(TBNUM(I),4)+'",GBIDC1) From ATEXTRA'
     Else
      #Wrseq space$(1)+"K   = max(1,val(num$(evalue(FORMULE))))"
      Wrseq space$(1)+"K   = max(1,val(num$("+TBFOR(I)+")))"
      Case TBTYP(I)
       When 1       : Wrseq space$(1)+"[F:AAA_]"+TBFLD(I)-"= K"
       When Default : Wrseq space$(1)+"[F:AAA_]"+TBFLD(I)-"= mess(K,"+right$(TBNUM(I),2)+",1)"
      Endcase
     Endif
    Else
     # Wrseq space$(1)+"[F:AAA_]"+TBFLD(I)-"= evalue(FORMULE)"
     Wrseq space$(1)+"[F:AAA_]"+TBFLD(I)-"="-TBFOR(I)
    Endif
   Endif
  Else
   Wrseq "FORMULE = ''"
   Case TBTYP(I)
    When 1,2,3,4,5,6 : Wrseq space$(1)+"[F:AAA_]"+TBFLD(I)-"= 0"
    When 8           : Wrseq space$(1)+"[F:AAA_]"+TBFLD(I)-"= [0/0/0]"
    When Default     : Wrseq space$(1)+"[F:AAA_]"+TBFLD(I)-"= ''"
   Endcase
  Endif
  Wrseq "Endif"
  Wrseq ""
 Next I
 Wrseq "K = instr(1,GDOSSIER,'@')"
 Wrseq "If K"
 Wrseq " [F:AAA_]ADOS = right$(GDOSSIER,K+1)"
 Wrseq "Else"
 Wrseq " [F:AAA_]ADOS = GDOSSIER"
 Wrseq "Endif"
 Wrseq "[F:AAA_]AREG = '"+[F:ABV]CODREG+"'"
 Wrseq "[F:AAA_]AIND = indice"
 Wrseq '[L]FLD="ACLE"'
 Wrseq '[L]FORMULE="ACLE"'

 Local Integer OKTRT
 If [F:ABV]TRTSTD<>""
  Call EXISTE_ADX("","",[F:ABV]TRTSTD,OKTRT) From ORDSYS
  If OKTRT
  Onerrgo ERR
  Gosub SET_TCLE From =[F:ABV]TRTSTD
  Onerrgo
  Endif
 Endif

 Wrseq "[F:AAA_]ACLE = " ;
 For I=1 To NBTCLE
  If I>1
   Wrseq "+'~'+" ;
  Endif
  Wrseq "num$([F:"+[L]ABR_TABORG+"]"+TCLE(I)+")";
 Next I
 Wrseq ""
Endif
Wrseq "Return"
Return

$ERR
Resume

$CHARGE_FLD
Local Integer  NBFLD
Local Integer  MAXFLD  : MAXFLD= 250
Local Char     TBFLD(GLONAVA)(1..MAXFLD) , TBFOR(250)(1..MAXFLD) , TBNUM(10)(1..MAXFLD)
Local Integer  TBMES(1..MAXFLD) , TBTYP(1..MAXFLD)
Local Integer  NBTCLE,TTYP(1..16)
Local Char     TCLE(GLONAVA)(1..16),ABR_TABORG(GLONABR)
For [ABY]ABY2 Where CODREG=[F:ABV]CODREG
 If [F:ABY]FLDDES<>""
  NBFLD += 1
  TBFLD(NBFLD) = [F:ABY]FLDDES
  TBFOR(NBFLD) = [F:ABY]FORDES
  Read [ABZ]ABZ1=[F:ABY]TABDES;[F:ABY]FLDDES
  TBMES(NBFLD) = ([F:ABZ]TYPFLD=1) : # Mesure
  TBNUM(NBFLD) = ""
  If [F:ATY]CODTYP<>[F:ABZ]CODTYP
  Read [ATY]CODTYP=[F:ABZ]CODTYP
  Endif
  If [F:ATY]CODTYP=[F:ABZ]CODTYP
   If find([F:ATY]CODTYP,"AXX","ATX")
    TBTYP(NBFLD) = GLONDES
   Elsif [F:ATY]CODTYP="ADI" & [F:ABZ]TYPFLD=2 : # Information
    TBTYP(NBFLD) = GLONDES
    TBNUM(NBFLD) = "ADI"+num$([F:ABZ]TABDIV)
   Elsif [F:ABZ]TYPFLD=2 & [F:ATY]TYPTYP=1 : # Information et menu local
    TBTYP(NBFLD) = GLONDES
    TBNUM(NBFLD) = "M"+num$([F:ABZ]MENLOC)
   Else
    TBTYP(NBFLD) = [F:ATY]TYPTYP
   Endif
  Else
   TBTYP(NBFLD) = 11
  Endif
 Endif
Next ABY

For I=1 To NBFLD
 K = instr(1,TBFOR(I),"[F]")
 While K
  TBFOR(I) = left$(TBFOR(I),K+1)+":AAA_"+right$(TBFOR(I),K+2)
  K = instr(K,TBFOR(I),"[F]")
 Wend
Next I

Raz CHAINE
Read [AVWT]CODFIC=[F:ABV]TABORG
[L]ABR_TABORG = [F:AVWT]ABRFIC
If [F:ABV]INDLEC<>""
 Read [AVWI]CODIND=[F:ABV]TABORG;[F:ABV]INDLEC
 If !fstat : CHAINE = [F:AVWI]DESCRIPT : Endif
Else
 Read [AVWI]NUMLIG(2)=[F:ABV]TABORG;1
 If !fstat : CHAINE = [F:AVWI]DESCRIPT : Endif
Endif
If CHAINE<> ""
 Call SETCLE(NBTCLE,TCLE,CHAINE) From LNKSUB
 For I=1 To NBTCLE
  Read [F:AVWF]CODZONE = [F:ABV]TABORG;TCLE(I)
  If !fstat
   Read [ATY]CODTYP = [F:AVWF]CODTYP
   If !fstat
    TTYP(I) = [F:ATY]TYPTYP
   Endif
  Endif
  If TTYP(I)=0 : TTYP(I) = 7 : Endif
 Next
Endif
Return

#-------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File ABIREGORG [ABV1]
 Local File ABIREGDES [ABY1]
 Local File ATEXTE    [ATX1]
Else
 Local File =[M]DOSORG+".ABIREGORG" [ABV1]
 Local File =[M]DOSORG+".ABIREGDES" [ABY1]
 Local File =[M]DOSORG+".ATEXTE"    [ATX1]
Endif
If [M]DOSDES=nomap
 Local File ABIREGORG [ABV2]
 Local File ABIREGDES [ABY2]
 Local File ATEXTE    [ATX2]
Else
 Local File =[M]DOSDES+".ABIREGORG" [ABV2]
 Local File =[M]DOSDES+".ABIREGDES" [ABY2]
 Local File =[M]DOSDES+".ATEXTE"    [ATX2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ABV1] , [ABY1], [ATX1] , [ABV2] , [ABY2], [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [ABV2], [ABY2] , [ATX2]
 Delete [ABV2] Where CODREG=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ABIREGORG" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ABV2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ABY2] Where CODREG=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ABIREGDES" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ABY2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ABV1] Where CODREG=TABLE
  [F:ABV2] = [F:ABV1]
  Call COPTEXTE([F:ABV1]INTIT,[F:ABV2]INTIT) From OBJDIV
  If GOK<1 : Break : Endif
  Write [ABV2]
  If fstat
   GOK = 0 : Call FSTA("ABI2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ABY1] Where CODREG=TABLE
  [F:ABY2] = [F:ABY1]
  Write [ABY2]
  If fstat
   GOK = 0 : Call FSTA("ABY2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#------------------------------------------------------------------------------#
Subprog AM_DESFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
 Call AVERTIR(mess(152,148,1),GBIDI1) From GESECRAN
 If GBIDI1 = 2 : End :  Endif
 VALEUR = 1
 [M]DESFLG = 1 : Affzo [M]DESFLG
 mkstat = 2 : End
Else
 Call AVERTIR(mess(153,148,1),GBIDI1) From GESECRAN
 If GBIDI1 = 2 : End :  Endif
 VALEUR = 2
 [M]DESFLG = 2 : Affzo [M]DESFLG
 mkstat = 2 : End
Endif
End


Subprog C_TABORG(VALEUR)
Variable Char    VALEUR()
Read [AVWT]CODFIC = VALEUR
If !fstat
 Call TEXTE([F:AVWT]INTITFIC,[M:ABV1]LIBORG) From OBJDIV
Else
 Read [AVW]AVW0 = VALEUR
 Call TEXTE([F:AVW]INTIT,[M:ABV1]LIBORG) From OBJDIV
Endif
End

Subprog C_FLDDEC(VALEUR)
Variable Char     VALEUR
If VALEUR="" : End : Endif
Read [AVWT]CODFIC = [M]TABORG
If !fstat
 Call CONTROLE_FLD([M]TABORG,"",VALEUR) From LNKSUB
Else
 Read [AVD]AVD1 = [M]TABORG;VALEUR
 If fstat
  GMESSAGE = mess(41,100,1) : # Champ inexistant
  mkstat = 2 : End
 Endif
Endif
End

Subprog C_TYPLNK(VALEUR)
Variable Integer  VALEUR
[M]TYPLNK = VALEUR
Gosub GRISE_LNK
End

Subprog C_ABRLNK(VALEUR)
Variable Char    VALEUR()
[M]SUMLNK(nolign-1) = [M]TABLNK(nolign-1)+"~"+VALEUR
Call UNICITE2([M]SUMLNK(nolign-1),[M]NBRLNK,[M]SUMLNK) From OBJDIV
End

Subprog AS_CLELNK(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Read [AVWI]NUMLIG = [M]TABLNK(nolign-1);1
 If !fstat
  VALEUR = [F:AVWI]CODIND
 Endif
Endif
End

Subprog C_EXPLNK(VALEUR)
Variable Char    VALEUR()
#If VALEUR<>""
# Call CONTROLE_IND([M]TABLNK(nolign-1),[M]CLELNK(nolign-1),VALEUR) From LNKSUB
#Endif
End

Subprog C_FLDDES(VALEUR)
Variable Char    VALEUR()
Read [ABZ]ABZ1 = [M]TABDES;VALEUR
If fstat
 # Champ inexistant sur la table
 Call ERREUR(VALEUR-":"-mess(13,133,1)-[M]TABDES) From GESECRAN
 mkstat = 2 : End
Endif
Call TEXTE([F:ABZ]INTFLD,[M:ABV2]INTDES(nolign-1)) From OBJDIV
End

Subprog C_TABDES(VALEUR)
Variable Char    VALEUR()
Call LECTURE("ABF",VALEUR,"") From CONTOBJ
If [F:ABF]TYPMAJ=1
 Read [AVW]AVW0 = [M:ABV1]TABORG
 If !fstat
  GMESSAGE = mess(56,148,1) : # Mise à jour incrémentale impossible avec une vue
  mkstat = 2 : End
 Endif
Endif
End

Subprog AM_TABDES(VALEUR)
Variable Char    VALEUR()
Local Char TABLE(GLONATB)
TABLE = VALEUR
Effzo [ABV2]15
Gosub CHARGE_CHAMP
Affzo [ABV2]15
End

Subprog AS_FORDES(VALEUR)
Variable Char    VALEUR()
Local Integer I
Local Char    ABREV(5)
If VALEUR=""
 Read [AVWF]CODZONE = [M:ABV1]TABORG;[M]FLDDES(nolign-1)
 If !fstat
  Read [AVWT]CODFIC = [M:ABV1]TABORG
  VALEUR = "[F:"+[F:AVWT]ABRFIC+"]"+[M]FLDDES(nolign-1)
 Else
  For I=0 To [M:ABV1]NBRLNK-1
   Read [AVWF]CODZONE = [M:ABV1]TABLNK(I);[M]FLDDES(nolign-1)
   If !fstat
    ABREV = [M:ABV1]ABRLNK(I)
    If ABREV=""
     Read [AVWT]CODFIC = [M:ABV1]TABLNK(I)
     ABREV = [F:AVWT]ABRFIC
    Endif
    VALEUR = "[F:"+ABREV+"]"+[M]FLDDES(nolign-1)
    Break
   Endif
  Next I
 Endif
Endif
End

Subprog C_INDLEC(VALEUR)
Variable Char    VALEUR()
Local Integer OK , OKUNIQ
If VALEUR="" : End : Endif
Raz OK , OKUNIQ
For [AVWI] Where CODFIC=[M]TABORG
 If VALEUR=[F:AVWI]CODIND
  OK = 1
  OKUNIQ = ([F:AVWI]HOMONYM=1)
  Break
 Endif
Next
If !OK
 For [ANX]ANX1 Where TABLE=[M]TABORG & FLACT=2
  If VALEUR=[F:ANX]CODIND
   OK = 1 : Break
  Endif
 Next
Endif
If !OK
 GMESSAGE = VALEUR-":"-mess(6,114,1) : # Clé inexistante
 mkstat = 2 : End
Elsif !OKUNIQ
 GMESSAGE = VALEUR-":"-mess(66,148,1) : # Clé avec homonymes
 mkstat = 2 : End
Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran ABV1) 04/03/2014 12:25:59 (CCL)
######################################################################################
Subprog IB_TABLNK
Read [AVW]AVW0 = [M:ABV1]TABLNK(nolign-1)
If !fstat
 GBIDC1 = "AVW"
ELSEV
 GBIDC1 = "ATB"
Endif
End

Subprog C_TABLNK(VALEUR)
Variable Char    VALEUR()
Read [AVWT]CODFIC=VALEUR
If fstat
 GMESSAGE = VALEUR-":"-mess(124,124,1)
 mkstat = 2 : End
Endif
End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran ABV1) 04/03/2014 12:56:41 (CCL)
######################################################################################
Subprog C_CLELNK(VALEUR)
Variable Char    VALEUR()
Read [AVWI]CODIND=  [M:ABV1]TABLNK(nolign-1);VALEUR
If !fstat
 If [AVWI]HOMONYM=2
  # cles avec homonymes
  GMESSAGE = [AVWI]CODIND-":"-mess(66,148,1)
  mkstat = 2 : End
 Elsif func AFNC.ACTIVDOS(nomap,[AVWI]CODACT)=0
  # inexistants car code activité non actif
  GMESSAGE = [AVWI]CODIND-":"-mess(226,126,1)
  mkstat = 2 : End
 Endif
Else
 GMESSAGE = mess(6,114,1)  #  : Clé inexistante
 mkstat = 2 : End
Endif
End

