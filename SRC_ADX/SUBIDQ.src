#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion objet IDQ
######################################################################################
Raz GPILOBJ
GBIDC1="200800000272"
GBIDC2="2009~ASN999999~20090101~1~1"
Call OBJET_CHAR(GBIDC1,"IDQ",GBIDC2) From GOBJET
End


## Etiquette ajoutée par le superviseur (Objet IDQ) 23/06/2009 17:34:23 (DBA)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE From SUBHRIDP
 When "LIENS"       : Gosub LIENS
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "FILTRE"      : Gosub FILTRE
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "VERF_ANU"    : Gosub VERF_ANU
Endcase
Return


###################################
$SETBOUT    #pour désactiver le bouton nouveau & chgt clé
Call VIREBOUT (CHAINE,"CH") From GOBJET
If REP<>""| [F:IDA]FLGNEWSAL=2
 Call VIREBOUT (CHAINE,"G") From GOBJET
Endif
#Objet à 4 éléments de clé : ajout du btn suppression après que GOBJET l'ait viré !
If CLECUR & VERROU : CHAINE+="A" : Endif
Gosub SET_BOUT_SPE From GSAISIE
Return

###################################
$EXEBOUT
Case BOUT
 When "G"
  # Pas de lectcure si la création s'est mal passée...
  If !GOK : Return : Endif
  # Unlock la fiche qui était à l'écran quand on a fait "NOUVEAU"
  If VERROU : Gosub DEVERROU From GOBJET : Endif
 Gosub RAFFRAICHIR From GOBJSUB
 Gosub RELIT From GOBJSUB
Endcase
Return

###################################
$LIENS
#The read is in the object
[M:IDQ1]NAM=[F:IDA]NAM
[M:IDQ1]SRN=[F:IDA]SRN

[M:IDQ1]NUMSSEBNF1=[F:IDQ]NUMSSEBNF(0)
[M:IDQ1]NUMSSEBNF2=[F:IDQ]NUMSSEBNF(1)
Gosub CHARGE_TAB
Return

###################################
$CHARGE_TAB
nolign=0
For [IDE]IDE0 Where YEAEMPDDS=[M:IDQ1]YEAEMPDDS & EMPDDS=[M:IDQ1]EMPDDS
&  & ETRDAT=[M:IDQ1]ETRDAT & CTRNUM=[M:IDQ1]CTRNUM & TYPDAE=[M:IDQ1]TYPDAE & NUMLIG=[M:IDQ1]NUMLIG
 nolign += 1
 [M:IDQ1]=[F:IDE]
Next
[M:IDQ1]NBRDQE = nolign
Return

###################################
$INICRE
$INIMOD
[F:IDQ]NUMSSEBNF(0)=[M:IDQ1]NUMSSEBNF1
[F:IDQ]NUMSSEBNF(1)=[M:IDQ1]NUMSSEBNF2
Gosub SAUVE_TAB
Return

###################################
$SAUVE_TAB
Delete [IDE] Where YEAEMPDDS=[M:IDQ1]YEAEMPDDS & EMPDDS=[M:IDQ1]EMPDDS
&  & ETRDAT=[M:IDQ1]ETRDAT & CTRNUM=[M:IDQ1]CTRNUM & TYPDAE=[M:IDQ1]TYPDAE & NUMLIG=[M:IDQ1]NUMLIG
If fstat=1
 GOK =-1 : GLOCK = "$IDADEMP121" : Return
Endif
For nolign=1 To [M:IDQ1]NBRDQE
 [F:IDE]=[M:IDQ1]
 [F:IDE]LIG=nolign
 Write [IDE]
 If fstat<>0
  GOK = 0 : Call FSTA("IDE") From GLOCK : Break
 Endif
Next
Return


###################################
$FILTRE
If find("IDA",GPILCOD(1..GPILOBJ))
 If FILTSUP<>"" : FILTSUP += " & " : Endif
 FILTSUP -= "YEAEMPDDS='"+[F]YEAEMPDDS+"'"
 FILTSUP -= "& EMPDDS='"+[F]EMPDDS+"'"
 FILTSUP -= "& CTRNUM='"+[F]CTRNUM+"'"
 FILTSUP -= "& ETRDAT=["+format$("D:"+GFMDAT4,[F]ETRDAT)+"]"
 FILTSUP -= "& TYPDAE="+num$([F]TYPDAE)
Else
 If GUSRACS<>2
  If FILTSUP<>"" : FILTSUP += " & " : Endif
  FILTSUP -= '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
  FILTSUP -= "& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))"
 Else
  FILTSUP ="1=1"
 Endif
Endif
Return

###################################
$FILGAUCHE
If find("IDA",GPILCOD(1..GPILOBJ))
 If FILGAUSUP<>"" : FILGAUSUP += " & " : Endif
 FILGAUSUP -= "YEAEMPDDS='"+[F]YEAEMPDDS+"'"
 FILGAUSUP -= "& EMPDDS='"+[F]EMPDDS+"'"
 FILGAUSUP -= "& CTRNUM='"+[F]CTRNUM+"'"
 FILGAUSUP -= "& ETRDAT=["+format$("D:"+GFMDAT4,[F]ETRDAT)+"]"
 FILGAUSUP -= "& TYPDAE="+num$([F]TYPDAE)
Endif
Return

###################################
$VERF_ANU
Trbegin [IDQ],[IDE]
 Delete [IDQ] Where YEAEMPDDS=[M:IDQ1]YEAEMPDDS & EMPDDS=[M:IDQ1]EMPDDS
& & ETRDAT=[M:IDQ1]ETRDAT & CTRNUM=[M:IDQ1]CTRNUM & TYPDAE=[M:IDQ1]TYPDAE
& & NUMLIG=[M:IDQ1]NUMLIG
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP12" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
 Delete [IDE] Where YEAEMPDDS=[M:IDQ1]YEAEMPDDS & EMPDDS=[M:IDQ1]EMPDDS
& & ETRDAT=[M:IDQ1]ETRDAT & CTRNUM=[M:IDQ1]CTRNUM & TYPDAE=[M:IDQ1]TYPDAE
& & NUMLIG=[M:IDQ1]NUMLIG
 If fstat = 1  : # enreg locké
  GLOCK = "$IDADEMP121" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
Commit
Effzo
OK = 0 :# pour ne pas passer dans la suppression standard
Return

###################################
$ROLL_ANN
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto VERF_ANU : Endif

###################################
$AB_ANN
Rollback
Return
