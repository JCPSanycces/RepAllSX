#<AdxTL>@(#)0.0.0.0 $Revision$
# WMACONTEXTASOL_CSTD
# 2018-11-09 07:11:45 868

$PROPERTIES
Case ACTION
 When "GET" : Gosub GET
 When Default
Endcase
Return

$EVENTS
Case AEVENT
 When "AINIT" : Gosub AINIT
 When Default
Endcase
Return

$METHODS
Case [L]AMETHOD
 When Default
Endcase
Return


#------------------------------------------------------------------------------#
$AINIT
Local Char    PARAM(250)
Local Integer RES
this.isReadonly = 0
RES = fmet this.ASETATTRIBUTE("OS","STA","0")
RES = fmet this.ASETATTRIBUTE("OS2","STA","0")
RES = fmet this.ASETATTRIBUTE("IRS","STA","0")
RES = fmet this.ASETATTRIBUTE("TMPDIR","STA","0")
RES = fmet this.ASETATTRIBUTE("SERVEUR","STA","0")
Gosub INIT_FCTCUR
this.isReadonly = 1
Return

#------------------------------------------------------------------------------#
$GET
Local Char    PARAM(250)
Case CURPRO
When "OS" : Gosub GET_OS
When "OS2" : Gosub GET_OS2
When "IRS" : Gosub GET_IRS
When "TMPDIR" : Gosub GET_TMPDIR
When "SERVEUR" : Gosub GET_SERVEUR
Endcase
Return

##############################################################################
# GET for different properties
##############################################################################

#OS : Type of machine (dos/unix)
$GET_OS
Local Char    PARAM(250)
If Fmet THIS.AGETATTRIBUTE("OS","STA")<>"1"
 this.isReadonly = 0
 Gosub INIT_OS
 this.isReadonly = 1
 Local Integer RES : RES = Fmet THIS.ASETATTRIBUTE("OS","STA","1")
Endif
Return

#OS2 : Sub-type9aix/ultrix)
$GET_OS2
Local Char    PARAM(250)
If Fmet THIS.AGETATTRIBUTE("OS2","STA")<>"1"
 this.isReadonly = 0
 Gosub INIT_OS2
 this.isReadonly = 1
 Local Integer RES : RES = Fmet THIS.ASETATTRIBUTE("OS2","STA","1")
Endif
Return

#IRS : Seperate line
$GET_IRS
Local Char    PARAM(250)
If Fmet THIS.AGETATTRIBUTE("IRS","STA")<>"1"
 this.isReadonly = 0
 Gosub INIT_IRS
 this.isReadonly = 1
 Local Integer RES : RES = Fmet THIS.ASETATTRIBUTE("IRS","STA","1")
Endif
Return

#TMPDIR : Temporary index
$GET_TMPDIR
Local Char    PARAM(250)
If Fmet THIS.AGETATTRIBUTE("TMPDIR","STA")<>"1"
 this.isReadonly = 0
 Gosub INIT_TMPDIR
 this.isReadonly = 1
 Local Integer RES : RES = Fmet THIS.ASETATTRIBUTE("TMPDIR","STA","1")
Endif
Return

#SERVEUR : Task server environment
$GET_SERVEUR
Local Char    PARAM(250)
If Fmet THIS.AGETATTRIBUTE("SERVEUR","STA")<>"1"
 this.isReadonly = 0
 Gosub INIT_SERVEUR
 this.isReadonly = 1
 Local Integer RES : RES = Fmet THIS.ASETATTRIBUTE("SERVEUR","STA","1")
Endif
Return

##############################################################################
# INIT for different properties
##############################################################################

#OS : 
$INIT_OS
gosub INIT_OS from ASYRSYS
Return

#OS2 : 
$INIT_OS2
gosub INIT_OS2 from ASYRSYS 
Return

#IRS : 
$INIT_IRS
gosub INIT_IRS from ASYRSYS
Return

#TMPDIR : 
$INIT_TMPDIR
gosub INIT_TMPDIR from ASYRSYS
Return

#SERVEUR : 
$INIT_SERVEUR
this.SERVEUR=0
Return

#FCTCUR : 
$INIT_FCTCUR
this.FCTCUR=""
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

