################################################################################
# INIPTE : S/P Recherche des Conditions de Paiement par Tiers  #JPGA 30/06/2008#
#     (Recherche par déclinaison société puis par tiers client ou fournisseur) #
# ---------------------------------------------------------------------------- #
# Subprog INIPTE (WBPRPAY, WBPRINV, WBPRTYP, WPTE)                             #
# ---------------------------------------------------------------------------- #
# Entrée : WBPRPAY : Client ou Fournisseur Payeur                              #
#          WBPRINV : Client ou Fournisseur Facture                             #
#          WBPRTYP : Type tiers Client ou Fournisseur ("C" ou "F")             #
# Sortie : WPTE    : Code Conditions de paiement                               #
# ---------------------------------------------------------------------------- #
# Attention : Utilisation de la variable GPAYTERM                              #
# Attention : Utilisation de la variable GSOCIETE pour recherche dans BPEXCEPT #
################################################################################
Subprog INIPTE (CTX, WCPY, WBPRPAY, WBPRINV, WBPRTYP, WPTE, WPTE_LEG)
Value    Instance CTX Using C_WMACONTEXT
Value    Char   WCPY
Value    Char   WBPRPAY
Value    Char   WBPRINV
Value    Char   WBPRTYP
Variable Char   WPTE
Variable Char   WPTE_LEG

  Local    Char   WSVGBPR(GLONBPR)
  Local    Char   WBPR(GLONBPR)

  # Test des Variables en Entrée
  If WBPRPAY = "" End Endif
  If WBPRTYP <>"C" & WBPRTYP <>"F" End Endif

  If CTX=null : CTX = GACTX : Endif

  # Ouverture éventuelle fichier et Sauvegarde Tiers courant pour restauration après traitement
  Case WBPRTYP
    When "C"
      Local File BPCUSTOMER [BPC]
    When "F"
      Local File BPSUPPLIER [BPS]
  Endcase

  # Recherche Tiers adéquat en fonction de GPAYTERM
  Case fmet CTX.APARAM.AGETVALNUM ([V]CST_ALEVFOLD,CTX.AFOLDER,"PAYTERMVAL") #GPAYTERM
    When 1
      # Initialisation de la condition à partir du Tiers payeur
        Case WBPRTYP
          When "C"
            Read [BPC] BPC0=WBPRPAY
          When "F"
            Read [BPS] BPS0=WBPRPAY
        Endcase
        If !fstat
          [L]WBPR = WBPRPAY
        Else
          # Tiers payeur non trouvé, Pas de condition de paiement : On prend celle du Tiers facture
          [L]WBPR = WBPRINV
        Endif
    When 2
      # Initialisation de la condition à partir du Tiers facture
      [L]WBPR = WBPRINV
    When Default
      # Initialisation de la condition à partir du Tiers facture
      [L]WBPR = WBPRINV
  Endcase

  #--CPO Syracuse : plus tard
  #  # ACA (2009-09-04) Bug 56794 : Cde : conditions paiement initialisées par client commandé
  #  GPOINT="PTEBPR" : Gosub ENTREE From EXEFNC

  # Recherche Conditions de paiement par déclinaison Société
  Call INIT_CONDITIONS(CTX, [L]WBPR, WCPY, WBPRTYP, WPTE, WPTE_LEG) #From CPTSUB

End
#--------------------------------------------------------------------------------------------------
##################################################
## Recherche des conditions de paiement du tiers #
##################################################
Subprog INIT_CONDITIONS(CTX,TIERS,SIT,BPRTYP,CONDITIONS,CONDITIONS_LEG)
Value    Instance CTX Using C_WMACONTEXT
Value    Char    TIERS        # INPUT : Numero de tiers
Value    Char    SIT          #         Société ou Site
Value    Char    BPRTYP       #         Type de tiers ("C" ou "F" ou " ")
Variable Char    CONDITIONS   # I-O   : Conditions de paiement
Variable Char    CONDITIONS_LEG

  If TIERS="" : End : Endif

  #--CPO 93062
  Local File BPCUSTOMER [BPC]
  Local File BPSUPPLIER [BPS]
  Local File COMPANY    [CPY]
  Local File FACILITY   [FCY]

  #X3-63010 JUCON 07/11/2017)
#  Local File ACTIV      [ACV]
#  Local File BPEXCEPT   [BPE]

  Local File TABPAYTERM [TPT]

  Local Integer WRET

  If CTX = null : CTX =  GACTX : Endif
  #--/

  If func ASYRFNC.ACTIV("MUL") >0 #X3-63010 JUCON 07/11/2017)
    Local File ACTIV      [ACV]
    Local File BPEXCEPT   [BPE]

    # JPGA : Ouvertures tables, Initialisation Société ou site, Recherche enregistrement BPEXCEPT
    Gosub INIT_BPEXCEPT

    # JPGA : Déclinaisons Société / BPEXCEPT : Alimentation selon Client/Fournisseur/Tiers ou autre
    Case BPRTYP
      When "C"
      # Priorité d'alimentation des conditions de paiement : 1/BPEXCEPT - 2/ BPCUSTOMER
        If [L]BPE_TROUVE  &  [F:BPE]PTEBPC <> ""
          CONDITIONS = [F:BPE]PTEBPC
        Else
          Gosub LECTURE_BPC
          If [L]BPC_TROUVE  &  [F:BPC]PTE <> ""
            CONDITIONS = [F:BPC]PTE
          Endif
        Endif
      When "F"
      # Priorité d'alimentation des conditions de paiement : 1/BPEXCEPT - 2/ BPSUPPLIER
        If [L]BPE_TROUVE  &  [F:BPE]PTEBPS <> ""
          CONDITIONS = [F:BPE]PTEBPS
        Else
          Gosub LECTURE_BPS
          If [L]BPS_TROUVE  &  [F:BPS]PTE <> ""
            CONDITIONS = [F:BPS]PTE
          Endif
        Endif
      When Default
    Endcase
  Else #X3-63010 JUCON 07/11/2017)
    Case BPRTYP
      When "C"
        Gosub LECTURE_BPC
        If [L]BPC_TROUVE  &  [F:BPC]PTE <> ""
          CONDITIONS = [F:BPC]PTE
        Endif
      When "F"
        Gosub LECTURE_BPS
        If [L]BPS_TROUVE  &  [F:BPS]PTE <> ""
          CONDITIONS = [F:BPS]PTE
        Endif
    Endcase
  Endif

  If CONDITIONS<>""
    Call LEC_TPT_LEG(CTX, CONDITIONS_LEG, CONDITIONS, 1, WRET) From TRTLECLEG_SYRA
    If WRET=0
      CONDITIONS_LEG  = [F:TPT]LEG
    Endif
  Endif

End
#--------------------------------------------------------------------------------------------------
##################################################
## Recherche des Escompte et agios du tiers      #
##################################################
Subprog INIT_ESCOMPTE(TIERS,SIT,BPRTYP,ESCOMPTE)
Value    Char    TIERS        # INPUT : Numero de tiers
Value    Char    SIT          #         Société ou Site
Value    Char    BPRTYP       #         Type de tiers ("C" ou "F" ou " ")
Variable Char    ESCOMPTE     # I-O   : Escompte et agios

  If TIERS="" : End : Endif

  #--CPO 93062
  Local File BPCUSTOMER [BPC]
  Local File BPSUPPLIER [BPS]
  Local File COMPANY    [CPY]
  Local File FACILITY   [FCY]

  If func ASYRFNC.ACTIV("MUL") >0 #X3-63010 JUCON 07/11/2017)
    Local File ACTIV      [ACV]
    Local File BPEXCEPT   [BPE]

  # JPGA : Ouvertures tables, Initialisation Société ou site, Recherche enregistrement BPEXCEPT
    Gosub INIT_BPEXCEPT

  # JPGA : Déclinaisons Société / BPEXCEPT : Alimentation selon Client/Fournisseur/Tiers ou autre
    Case BPRTYP
      When "C"
      # Priorité d'alimentation des escomptes et agios : 1/BPEXCEPT - 2/ BPCUSTOMER
        If [L]BPE_TROUVE  &  [F:BPE]DEPBPC <> ""
          ESCOMPTE = [F:BPE]DEPBPC
        Else
          Gosub LECTURE_BPC
          # Bug 54743 : DEP est un champ non obligatoire, il faut toujours le charger
#         If [L]BPC_TROUVE  &  [F:BPC]DEP <> ""
          If [L]BPC_TROUVE
            ESCOMPTE = [F:BPC]DEP
          Endif
        Endif
      When "F"
      # Priorité d'alimentation des escomptes et agios : 1/BPEXCEPT - 2/ BPSUPPLIER
        If [L]BPE_TROUVE  &  [F:BPE]DEPBPS <> ""
          ESCOMPTE = [F:BPE]DEPBPS
        Else
          Gosub LECTURE_BPS
          # Bug 54743 : DEP est un champ non obligatoire, il faut toujours le charger
#        If [L]BPS_TROUVE  &  [F:BPS]DEP <> ""
          If [L]BPS_TROUVE
            ESCOMPTE = [F:BPS]DEP
          Endif
        Endif
      When Default
    Endcase
  Else #X3-63010 JUCON 07/11/2017)
    Case BPRTYP
      When "C"
        Gosub LECTURE_BPC
        If [L]BPC_TROUVE
          ESCOMPTE = [F:BPC]DEP
        Endif
      When "F"
        Gosub LECTURE_BPS
        If [L]BPS_TROUVE
          ESCOMPTE = [F:BPS]DEP
        Endif
      Endcase
   Endif
End
#--------------------------------------------------------------------------------------------------
############## Appelé depuis INIT_REGIME, INIT_CONDITIONS, INIT_ESCOMPTE, INIT_COMPTE
#--CPO 93062 Lors de la syracusation : il vaut mieux déclarer les F dans les sub/fun appelant, et non plus dans les étiquettes...
$INIT_BPEXCEPT

  Local    Char    SOC(GLONCPY)
  Local    Integer ISITE
  Local    Integer BPE_TROUVE

  # Issue 74556 - 2011-06-23 by VPO : lecture ssi besoin
  If [F:CPY]CPY<>SIT
    Read[CPY]CPY0=SIT
    If !fstat
      SOC   = [F:CPY]CPY
    Else
#      ISITE = find(SIT,GSITE(1..GNBSITE))
#      If ISITE>0 : SOC   = GSOCSITE(ISITE) : Endif
      Read [F:FCY]FCY0 = SIT
      If fstat : Raz [F:FCY] : Endif
      SOC = [F:FCY]LEGCPY
    Endif
  Else
    SOC   = [F:CPY]CPY
  Endif

  [L]BPE_TROUVE = 0

  If SOC <> ""
    # Issue 74556 - 2011-06-23 by VPO : lecture ssi besoin
    If [F:ACV]CODACT<>"MUL"
      Read [ACV]CODACT="MUL" : If fstat  Raz [F:ACV] : Endif
    Endif
    If [F:ACV]FLACT = 2
      # Issue 74556 - 2011-06-23 by VPO : lecture ssi besoin
      If [F:BPE]BPRNUM<>TIERS | [F:BPE]CPY<>SOC
        Read [BPE]BPE0=TIERS;SOC
        If !fstat
          [L]BPE_TROUVE = 1
        Endif
      Else
        [L]BPE_TROUVE = 1
      Endif
    Endif
  Endif

Return
#--------------------------------------------------------------------------------------------------
############## Appelé depuis INIT_REGIME, INIT_CONDITIONS, INIT_ESCOMPTE, INIT_COMPTE
$LECTURE_BPC

  Local Integer   BPC_TROUVE

  [L]BPC_TROUVE = 0

  If [F:BPC]BPCNUM = TIERS
    [L]BPC_TROUVE = 1
  Else
    Read [BPC]BPC0=TIERS
    If !fstat
      [L]BPC_TROUVE = 1
    Endif
  Endif

Return
#--------------------------------------------------------------------------------------------------
############## Appelé depuis INIT_REGIME, INIT_CONDITIONS, INIT_ESCOMPTE, INIT_COMPTE
$LECTURE_BPS

  Local Integer   BPS_TROUVE

  [L]BPS_TROUVE = 0

  If [F:BPS]BPSNUM = TIERS
    [L]BPS_TROUVE = 1
  Else
    Read [BPS]BPS0=TIERS
    If !fstat
      [L]BPS_TROUVE = 1
    Endif
  Endif

Return
#--------------------------------------------------------------------------------------------------
#######################################
## Recherche du régime taxe du tiers  #
#######################################
Subprog INIT_REGIME(TIERS,SIT,BPRTYP,REGIME)
Value    Char    TIERS        # INPUT : Numero de tiers
Value    Char    SIT          #         Société ou Site
Value    Char    BPRTYP       #         Type de tiers ("C" ou "F" ou " ")
Variable Char    REGIME       # I-O   : Régime de taxe

  If TIERS="" : End : Endif

  #--CPO 93062
  Local File BPCUSTOMER [BPC]
  Local File BPSUPPLIER [BPS]
  Local File COMPANY    [CPY]
  Local File FACILITY   [FCY]

  If func ASYRFNC.ACTIV("MUL") >0 #X3-63010 JUCON 07/11/2017)
    Local File ACTIV      [ACV]
    Local File BPEXCEPT   [BPE]

    # JPGA : Ouvertures tables, Initialisation Société ou site, Recherche enregistrement BPEXCEPT
    Gosub INIT_BPEXCEPT

    # JPGA : Déclinaisons Société / BPEXCEPT : Alimentation selon Client/Fournisseur/Tiers ou autre
    Case BPRTYP
      When "C", " "
        # Priorité d'alimentation du Régime : 1/BPEXCEPT - 2/ BPCUSTOMER - 3/ BPSUPPLIER
        If [L]BPE_TROUVE  &  [F:BPE]VACBPC <> ""
          REGIME = [F:BPE]VACBPC
        Else
          Gosub LECTURE_BPC
          If [L]BPC_TROUVE  &  [F:BPC]VACBPR<>""
            REGIME = [F:BPC]VACBPR
          Else
            Gosub LECTURE_BPS
            If [L]BPS_TROUVE  &  [F:BPS]VACBPR<>""
              REGIME = [F:BPS]VACBPR
            Endif
          Endif
        Endif
      When "F"
        # Priorité d'alimentation du Régime : 1/BPEXCEPT - 2/ BPSUPPLIER - 3/ BPCUSTOMER
        If [L]BPE_TROUVE  &  [F:BPE]VACBPS <> ""
          REGIME = [F:BPE]VACBPS
        Else
          Gosub LECTURE_BPS
          If [L]BPS_TROUVE  &  [F:BPS]VACBPR<>""
            REGIME = [F:BPS]VACBPR
          Else
            Gosub LECTURE_BPC
            If [L]BPC_TROUVE  &  [F:BPC]VACBPR<>""
              REGIME = [F:BPC]VACBPR
            Endif
          Endif
        Endif
      When Default
    Endcase
  Else  #X3-63010 JUCON 07/11/2017)
    Case BPRTYP
      When "C", " "
        # Priorité d'alimentation du Régime : 1/ BPSUPPLIER - 2/ BPCUSTOMER
        Gosub LECTURE_BPC
        If [L]BPC_TROUVE  &  [F:BPC]VACBPR<>""
          REGIME = [F:BPC]VACBPR
        Else
          Gosub LECTURE_BPS
          If [L]BPS_TROUVE  &  [F:BPS]VACBPR<>""
            REGIME = [F:BPS]VACBPR
          Endif
        Endif
      When "F"
        # Priorité d'alimentation du Régime : 1/ BPSUPPLIER - 2/ BPCUSTOMER
        Gosub LECTURE_BPS
        If [L]BPS_TROUVE  &  [F:BPS]VACBPR<>""
          REGIME = [F:BPS]VACBPR
        Else
          Gosub LECTURE_BPC
          If [L]BPC_TROUVE  &  [F:BPC]VACBPR<>""
            REGIME = [F:BPC]VACBPR
          Endif
        Endif
    Endcase
  Endif

End
