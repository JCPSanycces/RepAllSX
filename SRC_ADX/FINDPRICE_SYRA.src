#<AdxTL>@(#)3.0.0.0 $Revision$
#########################################################################
#-----------------------------------------------------------
# Alimentation des masques SOH et SOR
# à partir des clients
#-----------------------------------------------------------
# Entrée   PTYPCDE : 1 = commande classique / 2 = commande ouverte
#          PTYPCLI : C = client cde / L = client liv / F = client fac
#---
Subprog ALICLI (PTYPCDE,PTYPCLI,PBPCNUM, GENERIC_OBJ, VRET)
Value   Integer   PTYPCDE
Value   Char      PTYPCLI
Value   Char      PBPCNUM
Variable Instance GENERIC_OBJ Using OBJECT
Variable Integer  VRET

  If GENERIC_OBJ = null : VRET =  [V]CST_AERROR : End : Endif

  VRET = [V]CST_AOK

  Local   Decimal COURS
  Local   Integer SPSTAT
  Local   Decimal ENCOURS, MONTANT
  Local   Char    SECTION(GLONCDE), WABMSK(3)
  Local   Char    WBPCPYR(GLONBPC), WBPCINV(GLONBPC)

  Local Instance MYPARAM Using =GENERIC_OBJ.ObjectType

  MYPARAM = cast(GENERIC_OBJ,=GENERIC_OBJ.ObjectType)

  Local File BPCUSTOMER [BPC]
  Local File BPDLVCUST  [BPD]
  Local File BPARTNER   [BPR]
  Local File FACILITY   [FCY]

  Read [BPC]BPC0 = PBPCNUM
  If fstat<>0  VRET=[V]CST_AERROR : End :  Endif

  Case PTYPCLI
   When "C" : Gosub CLICDE
   When "L" : Gosub CLILIV
   When "F" : Gosub CLIFAC
  Endcase

End
#--------------------------------------------------------------------------------------------------
Subprog ALICLIBPS (PTYPCDE,PTYPCLI,PBPSNUM, GENERIC_OBJ, VRET)
Value   Integer   PTYPCDE
Value   Char      PTYPCLI
Value   Char      PBPSNUM
Variable Instance GENERIC_OBJ Using OBJECT
Variable Integer  VRET

  If GENERIC_OBJ = null : VRET =  [V]CST_AERROR : End : Endif

  VRET = [V]CST_AOK

  Local   Decimal COURS
  Local   Integer SPSTAT
  Local   Decimal ENCOURS, MONTANT
  Local   Char    SECTION(GLONCDE), WABMSK(3)
  Local   Char    WBPCPYR(GLONBPC), WBPCINV(GLONBPC)

  Local Instance MYPARAM Using =GENERIC_OBJ.ObjectType

  MYPARAM = cast(GENERIC_OBJ,=GENERIC_OBJ.ObjectType)

  Local File BPSUPPLIER [BPS]
  Local File BPDLVCUST  [BPD]
  Local File BPARTNER   [BPR]
  Local File FACILITY   [FCY]

  Read [BPS]BPS0 = PBPSNUM
  If fstat<>0  VRET=[V]CST_AERROR : End :  Endif

  Case PTYPCLI
   When "S" : Gosub FLIBPS
   #When "L" : Gosub CLILIV
   #When "F" : Gosub CLIFAC
  Endcase

End
#---

# ---------------------------------------- #
#   Alimentation depuis client commande    #
# ---------------------------------------- #
$CLICDE

  Local Char WBPDADD(GLONADR) : Raz WBPDADD :#-- CPO

  # Alimentation des codes statistiques
    If MYPARAM.C_SPKH(1) = null
      VRET = fmet MYPARAM.ADDLINE("C_SPKH",1)
      If VRET = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        VRET = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_SPKH","SFINDPRICE"), [V]CST_AERROR)
        Return
      Endif
    Endif

     # Utile pour l'init. des sections : La Section par défaut "SOH" utile [M:SQH0]BPCORD
     If dim(MYPARAM.BPCNUM)>0
       MYPARAM.BPCNUM = PBPCNUM
     Endif
     If dim(MYPARAM.BPCORD)>0
       MYPARAM.BPCORD = PBPCNUM
     Endif
     If dim(MYPARAM.C_SPKH(1).BPCINV)>0
       MYPARAM.C_SPKH(1).BPCINV = [F:BPC]BPCINV
     Endif
     If dim(MYPARAM.BPCINV)>0
       MYPARAM.BPCINV = [F:BPC]BPCINV
     Endif
  #  Alimentation code adresse client facture dans MYPARAM.                    : # Bug 69487
     If dim(MYPARAM.BPAADD) > 0                                                : # Bug 69487
        If MYPARAM.BPAADD="" MYPARAM.BPAADD = [F:BPC]BPAADD : Endif            : # Bug 69487
     Endif                                                                     : # Bug 69487
    #   If !GIMPORT & dim([M:ADB2]BPAADD) > 0
    #       If [F:BPC]BPCTYP=2 [M:ADB2]=MYPARAM. Else Raz [M:ADB2] : Endif
    #   Endif
    ##  Alimentation code adresse client facture dans [M:ADB3]
    #   If dim([M:ADB3]BPAADD) > 0
    #      If !GIMPORT If [F:BPC]BPCTYP=2 [M:ADB3]=MYPARAM. Else Raz [M:ADB3] Endif : Endif
    #      If !GIMPORT | [M:ADB3]BPAADD="" [M:ADB3]BPAADD = [F:BPC]BPAINV : Endif
    #   Endif
     If MYPARAM.C_SPKH(1)<>null and dim(MYPARAM.C_SPKH(1).BPCPYR)>0
       MYPARAM.C_SPKH(1).BPCPYR = [F:BPC]BPCPYR
     Endif
     If MYPARAM.C_SPKH(1)<>null and dim(MYPARAM.C_SPKH(1).BPCGRU)>0
       MYPARAM.C_SPKH(1).BPCGRU = [F:BPC]BPCGRU
     Endif
     If dim(MYPARAM.BPCPYR)>0
       MYPARAM.BPCPYR = [F:BPC]BPCPYR
     Endif
     If dim(MYPARAM.BPCGRU)>0
       MYPARAM.BPCGRU = [F:BPC]BPCGRU
     Endif
    #--CPO Syracuse : plus tard
    #   # Alimentation à partir du modèle d'édition
    #   Call ALI_PRTMOD("SOH0",2) From TRTX3
    #   If MYPARAM.COPNBR=0 MYPARAM.COPNBR=1 Endif


    # Initialisation du code condition de paiement
    If dim(MYPARAM.C_SPKH(1).PTE)>0
      Call INIPTE (MYPARAM.ACTX, MYPARAM.CPY, [F:BPC]BPCPYR, [F:BPC]BPCINV, "C", MYPARAM.C_SPKH(1).PTE, MYPARAM.C_SPKH(1).PTE_LEG)
    Elsif dim(MYPARAM.PTE)>0
      Call INIPTE (MYPARAM.ACTX, MYPARAM.CPY, [F:BPC]BPCPYR, [F:BPC]BPCINV, "C", MYPARAM.PTE, MYPARAM.PTE_LEG)
    Endif
    If dim(MYPARAM.LAN)>0
      MYPARAM.LAN = MYPARAM.ACTX.AFOLD.ALANGDEF
    Endif

    Read [BPR]BPR0 = PBPCNUM
    If fstat = 0 and dim(MYPARAM.LAN)>0
      MYPARAM.LAN = [F:BPR]LAN
    Endif

    If dim(MYPARAM.CNTNAM)>0 & MYPARAM.CNTNAM = ""
      Call RECH_CNTNAM(PBPCNUM, [F:BPC]BPAADD, MYPARAM.CNTNAM) From TRTVENDIV :#--fonction syracuse compatible
    Endif

    If dim(MYPARAM.OCNFLG)>0    : MYPARAM.OCNFLG    = [F:BPC]OCNFLG    : Endif
    If dim(MYPARAM.ORDMINAMT)>0 : MYPARAM.ORDMINAMT = [F:BPC]ORDMINAMT : Endif


    For I = 1 To dim([F:BPC]TSCCOD)

      If MYPARAM.C_SPKH(1).C_TSCCOD(I) = null
        VRET = fmet MYPARAM.C_SPKH(1).ADDLINE("C_TSCCOD",I)
        If VRET = [V]CST_ANOTDEFINED
          #--The insertion was not possible
          VRET = fmet MYPARAM.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_TSCCOD","SFINDPRICE.C_SPKH(1)"), [V]CST_AWARNING)
          Break :#Return
        Endif
      Endif
      MYPARAM.C_SPKH(1).C_TSCCOD(I).TSCCOD = [F:BPC]TSCCOD(I-1)

    Next I

    # Ces zones ne sont alimentées que si cde classique
    If dim(MYPARAM.ORDCLE)>0 :    MYPARAM.ORDCLE = [F:BPC]ORDCLE : Endif
    If dim(MYPARAM.ODL)   >0 :    MYPARAM.ODL    = [F:BPC]ODL    : Endif

    If dim(MYPARAM.DME)   >0 :    MYPARAM.DME    = [F:BPC]DME    : Endif

    If dim(MYPARAM.IME)>0
       If dim(MYPARAM.SOHCAT)>0 and MYPARAM.SOHCAT = 3 & [F:BPC]IME = 1
           MYPARAM.IME = 3
       Else
           MYPARAM.IME = [F:BPC]IME
       Endif
    Endif

    For I = 1 To dim([F:BPC]REP)

      If MYPARAM.C_REP(I) = null
        VRET = fmet MYPARAM.ADDLINE("C_REP",I)
        If VRET = [V]CST_ANOTDEFINED
          #--The insertion was not possible
          VRET = fmet MYPARAM.ASETERROR ("",func ASYRFNC.MES2(mess(266,133,1),"C_REP","SFINDPRICE") , [V]CST_AWARNING)
          Break :#Return
        Endif
      Endif
      If I>dim(MYPARAM.C_REP(1).REP)-1 : Break : Endif
      MYPARAM.C_REP(I).REP = [F:BPC]REP(I-1)

    Next I


    If dim(MYPARAM.TEX1)>0 and dim(MYPARAM.TEX2)>0
      If fmet MYPARAM.ACTX.APARAM.AGETVALNUM ([V]CST_ALEVFCY,MYPARAM.FCY,"SALTEXORD")=1
         #[M]SOHTEX1 = [F:BPC]ORDTEX
      Elsif fmet MYPARAM.ACTX.APARAM.AGETVALNUM ([V]CST_ALEVFCY,MYPARAM.FCY,"SALTEXORD")=2
         #[M]SOHTEX2 = [F:BPC]ORDTEX
      Endif
    Endif

     # Lecture client livré pour alimentation depuis celui-ci
     WBPDADD = MYPARAM.BPAADD
     If WBPDADD="" : WBPDADD = [F:BPC]BPDADD : Endif

     Filter [BPD] Where [BPD]BPCNUM = PBPCNUM & ENAFLG=2
     Read [BPD]BPD0 = PBPCNUM;WBPDADD
     If fstat = 0
        MYPARAM.BPAADD = [F:BPD]BPAADD
        Gosub CLILIV
     Else
        Read [BPD]BPD0 First
        If fstat = 0
           MYPARAM.BPAADD = [F:BPD]BPAADD
           Gosub CLILIV
        Endif
     Endif
     Filter [BPD]

    # Alimentation de l'état commande (à la fin pour ne pas casser [F:BPC] du clt cde)
    # L'en-cours est contrôlé sur le tiers risque du client commande
    If [F:BPC]BPCNUM<>[F:BPC]BPCRSK
        Read [BPC]BPC0 = [F:BPC]BPCRSK
        If fstat<>0 : Return : Endif
    Endif

     If dim(MYPARAM.CDTSTA)>0
       MYPARAM.CDTSTA = 1
       If [F:BPC]OSTCTL = 3 MYPARAM.CDTSTA = 2 Endif
     Endif

     If [F:BPC]BPCNUM<>MYPARAM.C_SPKH(1).BPCINV
        Read [BPC]BPC0 = MYPARAM.C_SPKH(1).BPCINV
        If fstat<>0 : Return : Endif
     Endif

  Gosub CLIFAC

  If dim(MYPARAM.BPIEECNUM)>0
      #--CPO compatible syracuse
      Call INIEECNUM (PBPCNUM,MYPARAM.BPAADD,MYPARAM.C_SPKH(1).BPCINV,MYPARAM.BPIEECNUM,MYPARAM.EECNUMCRY) From TRTVENDIV
  Endif

  ####################CPO A faire
  #If dim([M]NBAXE)>0
  #   For nolign = 1 To GOPTCANA
  #      Call INISEC(SECTION, WABMSK,num$(nolign)) From SUBCDE
  #      [M]CCE(nolign-1) = SECTION
  #   Next nolign
  #Endif

  #If dim([M]NBAXE)>0
  #  If [M]NBAXE>0
  #      For I=1 To [M]NBAXE Raz [M]CCE(I-1) : Next
  #  Endif
  #  If PTYPCDE=1
  #      Call INIT_CCEH("SOH3","NBAXE","SOH") From TRTVEN_SYRA #From TRTX3CPT
  #  Else
  #      Call INIT_CCEH("SOR1","NBAXE","SOR") From TRTVEN_SYRA #From TRTX3CPT
  #  Endif
  #Endif
  ####################/CPO A faire

Return
#--------------------------------------------------------------------------------------------------
# ---------------------------------------- #
#   Alimentation depuis client livré       #
# ---------------------------------------- #

$CLILIV

   Local Char WBPCORD(GLONBPC)
   If PTYPCLI = "C"
      WBPCORD = PBPCNUM
   Else
      If    dim(MYPARAM.BPCNUM)>0
        WBPCORD = MYPARAM.BPCNUM
      Elsif dim(MYPARAM.BPCORD)>0
        WBPCORD = MYPARAM.BPCORD
      Endif
   Endif
   If PTYPCLI = "C" and dim(MYPARAM.BPDNAM)>0 : MYPARAM.BPDNAM = [F:BPD]BPDNAM(0) : Endif
  #  On récupère le site si aucune ligne n'a été saisie ou si on dupplique avec changement de client
   If [F:BPD]STOFCY <> "" & MYPARAM.FCY <> [F:BPD]STOFCY
      If [F:FCY]FCY <> [F:BPD]STOFCY Read [FCY]FCY0=[F:BPD]STOFCY : Endif
      If [F:FCY]LEGCPY=MYPARAM.CPY
          Local Integer OK      : OK=1
          Local Char    WFCY(GLONFCY) : WFCY=[F:BPD]STOFCY
  #          If GREP="D" Gosub VERIF_LIGNE_ITF Endif
  #          If OK=0
  #              GMESSAGE -=mess(25,192,1)-WFCY-"\"-mess(96,191,1)
  #              If GTRACE <> "" Call ECR_TRACE(GMESSAGE, 0) From GESECRAN Endif
  #          Endif
          If OK=1 MYPARAM.FCY = WFCY Endif
      Endif
   Endif

   If dim(MYPARAM.DRN)   >0           : MYPARAM.DRN              = [F:BPD]DRN     : Endif
   If dim(MYPARAM.DLVPIO)>0           : MYPARAM.DLVPIO           = [F:BPD]DLVPIO  : Endif
   If dim(MYPARAM.DAYLTI)>0           : MYPARAM.DAYLTI           = [F:BPD]DAYLTI  : Endif
   If dim(MYPARAM.C_SPKH(1).MDL)   >0 : MYPARAM.C_SPKH(1).MDL    = [F:BPD]MDL     : Endif
   If dim(MYPARAM.C_SPKH(1).BPTNUM)>0 : MYPARAM.C_SPKH(1).BPTNUM = [F:BPD]BPTNUM  : Endif

  # Alimentation code adresse (client livré) dans MYPARAM. pour saisie adresse libre
    If dim(MYPARAM.BPDADD) > 0
      MYPARAM.BPDADD    = [F:BPD]BPAADD
      If dim(MYPARAM.CNTNAM)>0 & MYPARAM.CNTNAM = ""
        Call RECH_CNTNAM(WBPCORD, [F:BPD]BPAADD, MYPARAM.CNTNAM) From TRTVENDIV
      Endif
    Endif
  #  Alimentation des représentants s'ils n'ont pas été alimentés par le client commande
   If [F:BPC]BPCNUM <> WBPCORD
       Read [BPC]BPC0 = WBPCORD
       If fstat <> 0 Raz [F:BPC] : Endif
   Endif

  #  Alimentation du 1er représentant
     If dim(MYPARAM.REP) > 0 & [F:BPC]REP(0) = ""
        MYPARAM.REP(0) = [F:BPD]REP(0)
     Endif
  #  Alimentation du 2eme représentant
     If dim(MYPARAM.REP) > 1
        If MYPARAM.REP(0) <> "" & [F:BPC]REP(1) = ""
           MYPARAM.REP(1) = [F:BPD]REP(1)
        Endif
        # 81661 : Le second représentant ne doit être alimenté si le 1er réprésentant est alimenté
        If MYPARAM.REP(0)="" MYPARAM.REP(1) = "" Endif
     Endif

  For I = 1 To dim([F:BPD]REP)

    If MYPARAM.C_REP(I) = null
      VRET = fmet MYPARAM.ADDLINE("C_REP",I)
      If VRET = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        VRET = fmet MYPARAM.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_REP","SFINDPRICE"), [V]CST_AWARNING)
        Break :#Return
      Endif
    Endif

    If I>dim(MYPARAM.C_REP(1).REP)-1 : Break : Endif

    If I>1 and MYPARAM.C_REP(1).REP <> "" : Break : Endif # 81661 : Le second représentant ne doit être alimenté si le 1er réprésentant est alimenté
    MYPARAM.C_REP(I).REP = [F:BPD]REP(I-1)

  Next I

  # Alimentation régime de taxe à partir du client livré
  # JPGA : 16/06/2008 - Recherche Régime taxe s'il est renseigné dans le tiers société
  Call INIT_REGIME(WBPCORD, MYPARAM.CPY, "C", MYPARAM.VACBPR) # From CPTSUB
  If [F:BPD]VACBPR<>"" MYPARAM.VACBPR = [F:BPD]VACBPR Endif
  # Alimentation des champs relatifs au infos douanières
  #--CPO 98525
  #If dim(MYPARAM.EECICT)>0 : MYPARAM.EECICT = [F:BPD]EECICT : Endif
  If dim(MYPARAM.EECICT)>0
    MYPARAM.EECICT = [F:BPD]EECICT
  Elsif dim(MYPARAM.C_SPKH(1).EECICT)>0
    MYPARAM.C_SPKH(1).EECICT = [F:BPD]EECICT
  Elsif dim(MYPARAM.C_PPKH(1).EECICT)>0
    MYPARAM.C_PPKH(1).EECICT = [F:BPS]EECICT
  Endif
  #--/
  If dim(MYPARAM.ICTCTY)>0 : MYPARAM.ICTCTY = [F:BPD]ICTCTY : Endif
  If dim(MYPARAM.FFWNUM)>0 : MYPARAM.FFWNUM = [F:BPD]FFWNUM : Endif
  If dim(MYPARAM.FFWADD)>0 : MYPARAM.FFWADD = [F:BPD]FFWADD : Endif
  If dim(MYPARAM.EECLOC)>0
    MYPARAM.EECLOC=[F:BPD]EECLOC
    If PTYPCLI = "L"
      If dim(MYPARAM.BPIEECNUM)>0 and dim(MYPARAM.EECNUMCRY)>0
        Call INIEECNUM (WBPCORD,PBPCNUM,MYPARAM.C_SPKH(1).BPCINV,MYPARAM.BPIEECNUM,MYPARAM.EECNUMCRY) From TRTVENDIV :#--CPO compatible syracuse
      Endif
    Endif
  Endif

  If dim(MYPARAM.SSTENTCOD)>0 :MYPARAM.SSTENTCOD=[F:BPD]SSTENTCOD :Endif  #LTA.n

Return
#--------------------------------------------------------------------------------------------------
# ---------------------------------------- #
#   Alimentation depuis client facture     #
# ---------------------------------------- #
$CLIFAC

  Local Integer NBPOSTE
  Local Integer SPSTAT
  Local Char    WBPCINV(GLONBPC), WBPAINV(GLONBPR)

   If MYPARAM.CUR = "" MYPARAM.CUR = MYPARAM.GLOCALDEV Endif

   If PTYPCLI = "F"
      Read [BPR]BPR0 = PBPCNUM
   Else
      Read [BPR]BPR0 = MYPARAM.C_SPKH(1).BPCINV
   Endif

   MYPARAM.CUR    = [F:BPC]CUR

  #   If dim([M:ADB3]CNTNAM)>0 & [M:ADB3]CNTNAM = ""
  #       If PTYPCLI="F" WBPAINV=[F:BPC]BPAADD  : WBPCINV=PBPCNUM
  #       Else          WBPAINV=[M:ADB3]BPAADD : WBPCINV=MYPARAM.c_spkh(1).BPCINV : Endif
  #       Call RECH_CNTNAM(WBPCINV, WBPAINV, [M:ADB3]CNTNAM) From TRTVENDIV
  #   Endif

  #   If dim([M:ADB3]EECNUM)>0 & [M:ADB3]EECNUM = "" [M:ADB3]EECNUM = [F:BPR]EECNUM Endif
  #  Bug : 67515 : Alimentation code adresse client facture dans [M:ADB3]

  #   If dim([M:ADB3]BPAADD) > 0 & [M:ADB3]BPAADD=""
  #      If [F:BPC]BPCINV=[F:BPC]BPCNUM & [F:BPC]BPAINV<>[F:BPR]BPAADD
  #          [M:ADB3]BPAADD = [F:BPC]BPAINV
  #      Endif
  #   Endif

   If PTYPCLI = "C" and dim(MYPARAM.BPINAM)>0 : MYPARAM.BPINAM = [F:BPC]BPCNAM : Endif

   MYPARAM.CHGTYP = [F:BPC]CHGTYP
   MYPARAM.PRITYP = [F:BPC]PRITYP

  If PTYPCLI = "F" & PTYPCDE = 1 & dim(MYPARAM.BPIEECNUM)>0
      Call INIEECNUM (MYPARAM.BPCNUM,MYPARAM.BPAADD,PBPCNUM,MYPARAM.BPIEECNUM,MYPARAM.EECNUMCRY) From TRTVENDIV
  Endif

  ## Init. du tableau des éléments de facturation
  #    NBPOSTE=dim([M:SOH3]INVDTA)
  #    Raz [M:SOH3]INVDTAAMT
  #    Call STRUFOOT (3,"SOH3",NBPOSTE,MYPARAM.CHGTYP,MYPARAM.CUR, MYPARAM.CUR, "OUI") From SUBSFIT
  #    [M:SOH3]NBFAC = NBPOSTE

  # Récupération du format de saisie des frais/remises
  #    Call FMTREM("SOH4", MYPARAM.CUR) From TRTPRICE
  #Endif
  #If PTYPCDE = 2
  ## Init. du tableau des éléments de facturation
  #    NBPOSTE=dim([M:SOR1]INVDTA)
  #    Raz [M:SOR1]INVDTAAMT
  #    Call STRUFOOT (3,"SOR1",NBPOSTE,[M:SOR1]CHGTYP,[M:SOR1]CUR, [M:SOR1]CUR, "OUI") From SUBSFIT
  #    [M:SOR1]NBFAC = NBPOSTE
  #Endif
   If dim(MYPARAM.C_SPKH(1).PTE)>0 and dim(MYPARAM.C_SPKH(1).BPCPYR)>0
     Call INIPTE (MYPARAM.ACTX, MYPARAM.CPY, MYPARAM.C_SPKH(1).BPCPYR, [F:BPC]BPCNUM, "C", MYPARAM.C_SPKH(1).PTE, MYPARAM.C_SPKH(1).PTE_LEG)      # From TRTX3
   Endif
   If dim(MYPARAM.C_SPKH(1).DEP)>0
     Call INIT_ESCOMPTE ([F:BPC]BPCNUM,  MYPARAM.CPY, "C", MYPARAM.C_SPKH(1).DEP) # From CPTSUB
   Endif

    # Conversion montant mini cde devise dossier vers devise commande
    If dim(MYPARAM.ORDMINAMT)>0
      If MYPARAM.GSYSCUR <> MYPARAM.CUR
          Call CONVERT(MYPARAM.ACTX, MYPARAM.GSYSCUR, MYPARAM.CUR, MYPARAM.GLOCALDEV, MYPARAM.CHGTYP, MYPARAM.DOCDAT, MYPARAM.ORDMINAMT, MONTANT,SPSTAT) From TRTDEV_SYRA
          MYPARAM.ORDMINAMT = MONTANT
      Endif
    Endif

    # Alimentation des zones en-cours (dépend du tiers risque du client cde et de la devise du clt facture)
    # Call SDCDTSTA("",[M]BPCORD,[M]CHGTYP,0,[M]CUR,[M]ORDDAT,[M]UNL,1,[M]CDTSTA, [M]OST,[M]OSTAUZ) From TRTVENCDT

$CLIFAC1

Return
#--------------------------------------------------------------------------------------------------
$FLIBPS ####

  Local Char WBPDADD(GLONADR) : Raz WBPDADD :#-- CPO

     # Utile pour l'init. des sections : La Section par défaut "SOH" utile [M:SQH0]BPCORD
     If dim(MYPARAM.BPCNUM)>0
       MYPARAM.BPSNUM = PBPSNUM
     Endif
     If dim(MYPARAM.BPSNUM)>0
       MYPARAM.BPSNUM = PBPSNUM
     Endif
     If dim(MYPARAM.C_PPKH(1).BPSINV)>0
       MYPARAM.C_PPKH(1).BPSINV = [F:BPS]BPSINV
     Endif
     If dim(MYPARAM.BPSINV)>0
       MYPARAM.BPSINV = [F:BPS]BPSINV
     Endif
  #  Alimentation code adresse client facture dans MYPARAM.                    : # Bug 69487
     If dim(MYPARAM.BPAADD) > 0                                                : # Bug 69487
        If MYPARAM.BPAADD="" MYPARAM.BPAADD = [F:BPS]BPAADD : Endif            : # Bug 69487
     Endif                                                                     : # Bug 69487

     If MYPARAM.C_PPKH(1)<>null and dim(MYPARAM.C_PPKH(1).BPRPAY)>0  # Pay-to  BPCPYR
       MYPARAM.C_PPKH(1).BPRPAY = [F:BPS]BPRPAY
     Endif
     If MYPARAM.C_PPKH(1)<>null and dim(MYPARAM.C_SPKH(1).BPSGRU)>0
       MYPARAM.C_PPKH(1).BPSGRU = [F:BPS]BPSGRU
     Endif
     If dim(MYPARAM.BPRPAY)>0
       MYPARAM.BPRPAY = [F:BPS]BPRPAY
     Endif
     If dim(MYPARAM.BPSGRU)>0
       MYPARAM.BPSGRU = [F:BPS]BPSGRU
     Endif
    #--CPO Syracuse : plus tard
    #   # Alimentation à partir du modèle d'édition
    #   Call ALI_PRTMOD("SOH0",2) From TRTX3
    #   If MYPARAM.COPNBR=0 MYPARAM.COPNBR=1 Endif


    # Initialisation du code condition de paiement
    If dim(MYPARAM.C_PPKH(1).PTE)>0
      Call INIPTE (MYPARAM.ACTX, MYPARAM.CPY, [F:BPS]BPRPAY, [F:BPS]BPSINV, "F", MYPARAM.C_PPKH(1).PTE, MYPARAM.C_PPKH(1).PTE_LEG)
    Elsif dim(MYPARAM.PTE)>0
      Call INIPTE (MYPARAM.ACTX, MYPARAM.CPY, [F:BPS]BPRPAY, [F:BPS]BPSINV, "F", MYPARAM.PTE, MYPARAM.PTE_LEG)
    Endif
    #MYPARAM.LAN = GLANGUE

    Read [BPR]BPR0 = PBPSNUM
    If fstat = 0 and dim(MYPARAM.LAN)>0
      MYPARAM.LAN = [F:BPR]LAN
    Endif

   # If dim(MYPARAM.CNTNAM)>0 & MYPARAM.CNTNAM = ""
   #   Call RECH_CNTNAM(PBPSNUM, [F:BPS]BPAADD, MYPARAM.CNTNAM) From TRTVENDIV :#--fonction syracuse compatible
   # Endif

    If dim(MYPARAM.OCNFLG)>0    : MYPARAM.OCNFLG    = [F:BPS]OCNFLG    : Endif
    If dim(MYPARAM.ORDMINAMT)>0 : MYPARAM.ORDMINAMT = [F:BPS]ORDMINAMT : Endif

  # Alimentation des codes statistiques
    If MYPARAM.C_PPKH(1) = null
      VRET = fmet MYPARAM.ADDLINE("C_PPKH",1)
      If VRET = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        VRET = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"C_PPKH","PFINDPRICE"), [V]CST_AERROR)
        Return
      Endif
    Endif

#    For I = 1 To dim([F:BPC]TSCCOD)
#
#      If MYPARAM.C_SPKH(1).C_TSCCOD(I) = null
#        VRET = fmet MYPARAM.C_SPKH(1).ADDLINE("C_TSCCOD",I)
#        If VRET = [V]CST_ANOTDEFINED
#          #--The insertion was not possible
#          VRET = fmet MYPARAM.ASETERROR ("", "Subroutine CLICDE from FINDPRICE_SYRA : Result error for MYPARAM.C_SPKH(1).ADDLINE 'C_TSCCOD'", [V]CST_AWARNING)
#          Break :#Return
#        Endif
#      Endif
#      MYPARAM.C_SPKH(1).C_TSCCOD(I).TSCCOD = [F:BPC]TSCCOD(I-1)
#
#    Next I

    # Ces zones ne sont alimentées que si cde classique
    #If dim(MYPARAM.ORDCLE)>0 :    MYPARAM.ORDCLE = [F:BPC]ORDCLE : Endif
    #If dim(MYPARAM.ODL)   >0 :    MYPARAM.ODL    = [F:BPC]ODL    : Endif

    # If dim(MYPARAM.DME)   >0 :    MYPARAM.DME    = [F:BPC]DME    : Endif

#    If dim(MYPARAM.IME)>0
#       If dim(MYPARAM.SOHCAT)>0 and MYPARAM.SOHCAT = 3 & [F:BPC]IME = 1
#           MYPARAM.IME = 3
#       Else
#           MYPARAM.IME = [F:BPC]IME
#       Endif
#    Endif

#    For I = 1 To dim([F:BPC]REP)
#
#      If MYPARAM.C_REP(I) = null
#        VRET = fmet MYPARAM.ADDLINE("C_REP",I)
#        If VRET = [V]CST_ANOTDEFINED
#          #--The insertion was not possible
#          VRET = fmet MYPARAM.ASETERROR ("", "Subroutine CLICDE from FINDPRICE_SYRA : Result error for MYPARAM.ADDLINE 'C_REP'", [V]CST_AWARNING)
#          Break :#Return
#        Endif
#      Endif
#      If I>dim(MYPARAM.C_REP(1).REP)-1 : Break : Endif
#      MYPARAM.C_REP(I).REP = [F:BPC]REP(I-1)
#
#    Next I


    If dim(MYPARAM.TEX1)>0 and dim(MYPARAM.TEX2)>0
      If fmet MYPARAM.ACTX.APARAM.AGETVALNUM ([V]CST_ALEVFCY,MYPARAM.FCY,"SALTEXORD")=1
         #[M]SOHTEX1 = [F:BPC]ORDTEX
      Elsif fmet MYPARAM.ACTX.APARAM.AGETVALNUM ([V]CST_ALEVFCY,MYPARAM.FCY,"SALTEXORD")=2
         #[M]SOHTEX2 = [F:BPC]ORDTEX
      Endif
    Endif

     # Lecture client livré pour alimentation depuis celui-ci
     WBPDADD = MYPARAM.BPAADD
     If WBPDADD="" : WBPDADD = [F:BPC]BPDADD : Endif

     #Filter [BPD] Where [BPD]BPCNUM = PBPSNUM & ENAFLG=2
     #Read [BPD]BPD0 = PBPSNUM;WBPDADD
     #If fstat = 0
        MYPARAM.BPAADD = [F:BPD]BPAADD
        Gosub FLILIV ######################################## Needed ?
     #Else
     #   Read [BPD]BPD0 First
     #   If fstat = 0
     #      MYPARAM.BPAADD = [F:BPD]BPAADD
     #      Gosub FLILIV #################################### Needed ?
     #   Endif
     #Endif
     Filter [BPD]

    # Alimentation de l'état commande (à la fin pour ne pas casser [F:BPC] du clt cde)
    # L'en-cours est contrôlé sur le tiers risque du client commande
    If [F:BPS]BPSNUM<>[F:BPS]BPSRSK
        Read [BPS]BPS0 = [F:BPS]BPSRSK
        If fstat<>0 : Return : Endif
    Endif

#     If dim(MYPARAM.CDTSTA)>0
#       MYPARAM.CDTSTA = 1
#       If [F:BPC]OSTCTL = 3 MYPARAM.CDTSTA = 2 Endif
#     Endif

     If [F:BPS]BPSNUM<>MYPARAM.C_PPKH(1).BPSINV
        Read [BPS]BPS0 = MYPARAM.C_PPKH(1).BPSINV
        If fstat<>0 : Return : Endif
     Endif

  Gosub FLIFAC ################################## Needed ?

  If dim(MYPARAM.BPIEECNUM)>0
      #--CPO compatible syracuse
      Call INIEECNUM (PBPSNUM,MYPARAM.BPAADD,MYPARAM.C_PPKH(1).BPSINV,MYPARAM.BPIEECNUM,MYPARAM.EECNUMCRY) From TRTVENDIV
  Endif

  ####################CPO A faire
  #If dim([M]NBAXE)>0
  #   For nolign = 1 To GOPTCANA
  #      Call INISEC(SECTION, WABMSK,num$(nolign)) From SUBCDE
  #      [M]CCE(nolign-1) = SECTION
  #   Next nolign
  #Endif

  #If dim([M]NBAXE)>0
  #  If [M]NBAXE>0
  #      For I=1 To [M]NBAXE Raz [M]CCE(I-1) : Next
  #  Endif
  #  If PTYPCDE=1
  #      Call INIT_CCEH("SOH3","NBAXE","SOH") From TRTVEN_SYRA #From TRTX3CPT
  #  Else
  #      Call INIT_CCEH("SOR1","NBAXE","SOR") From TRTVEN_SYRA #From TRTX3CPT
  #  Endif
  #Endif
  ####################/CPO A faire

Return
#------------------------------------------------------------------------------------------
#--------------------------------------------------------------------------------------------------
# ---------------------------------------- #
#   Supplier lookups                       #
# ---------------------------------------- #
$FLILIV
   Local Char WBPSNUM(GLONBPS)
   If PTYPCLI = "S"
      WBPSNUM = PBPSNUM
   Else
      If    dim(MYPARAM.BPSNUM)>0
        WBPSNUM = MYPARAM.BPCSUM
      Elsif dim(MYPARAM.BPCORD)>0
        WBPSNUM = MYPARAM.BPSNUM
      Endif
   Endif
   If PTYPCLI = "S" and dim(MYPARAM.BPDNAM)>0 : MYPARAM.BPDNAM = [F:BPD]BPDNAM(0) : Endif
  #  On récupère le site si aucune ligne n'a été saisie ou si on dupplique avec changement de client
# 3/19/2014 removed below
#   If [F:BPD]RCPFCY <> "" & MYPARAM.FCY <> [F:BPD]RCPFCY ## #ALL STOFCY repalced with RCPFCY in this block
#      If [F:FCY]FCY <> [F:BPD]RCPFCY Read [FCY]FCY0=[F:BPD]RCPFCY : Endif
#      If [F:FCY]LEGCPY=MYPARAM.CPY
#          Local Integer OK      : OK=1
#          Local Char    WFCY(GLONFCY) : WFCY=[F:BPD]RCPFCY
#  #          If GREP="D" Gosub VERIF_LIGNE_ITF Endif
#  #          If OK=0
#  #              GMESSAGE -=mess(25,192,1)-WFCY-"\"-mess(96,191,1)
#  #              If GTRACE <> "" Call ECR_TRACE(GMESSAGE, 0) From GESECRAN Endif
#  #          Endif
#          If OK=1 MYPARAM.FCY = WFCY Endif
#      Endif
#   Endif

#  3/19/2014 removed below
#   If dim(MYPARAM.DRN)   >0 : MYPARAM.DRN    = [F:BPD]DRN     : Endif
#   If dim(MYPARAM.DLVPIO)>0 : MYPARAM.DLVPIO = [F:BPD]DLVPIO  : Endif
#   If dim(MYPARAM.DAYLTI)>0 : MYPARAM.DAYLTI = [F:BPD]DAYLTI  : Endif
#   If dim(MYPARAM.C_PPKH(1).MDL)   >0 : MYPARAM.C_PPKH(1).MDL    = [F:BPD]MDL     : Endif
#   If dim(MYPARAM.C_PPKH(1).BPTNUM)>0 : MYPARAM.C_PPKH(1).BPTNUM = [F:BPD]BPTNUM  : Endif

  # Alimentation code adresse (client livré) dans MYPARAM. pour saisie adresse libre
    #If dim(MYPARAM.BPDADD) > 0
    #  MYPARAM.BPDADD    = [F:BPD]BPAADD
    #Endif   3/19/2014
  #  Alimentation des représentants s'ils n'ont pas été alimentés par le client commande
   If [F:BPS]BPSNUM <> WBPSNUM
       Read [BPS]BPS0 = WBPSNUM
       If fstat <> 0 Raz [F:BPS] : Endif
   Endif

  # Alimentation régime de taxe à partir du client livré
  # JPGA : 16/06/2008 - Recherche Régime taxe s'il est renseigné dans le tiers société
  Call INIT_REGIME(WBPSNUM, MYPARAM.CPY, "F", MYPARAM.VACBPR) # From CPTSUB
  If [F:BPD]VACBPR<>"" MYPARAM.VACBPR = [F:BPD]VACBPR Endif
  # Alimentation des champs relatifs au infos douanières
  #If dim(MYPARAM.EECICT)>0 : MYPARAM.EECICT = [F:BPD]EECICT : Endif
  If dim(MYPARAM.EECICT)>0 : MYPARAM.EECICT = [F:BPS]EECICT : Endif
  #If dim(MYPARAM.ICTCTY)>0 : MYPARAM.ICTCTY = [F:BPD]ICTCTY : Endif
  #If dim(MYPARAM.FFWNUM)>0 : MYPARAM.FFWNUM = [F:BPD]FFWNUM : Endif
  #If dim(MYPARAM.FFWADD)>0 : MYPARAM.FFWADD = [F:BPD]FFWADD : Endif
  If dim(MYPARAM.EECLOC)>0
    MYPARAM.EECLOC=[F:BPD]EECLOC
    If PTYPCLI = "L"
      If dim(MYPARAM.BPIEECNUM)>0 and dim(MYPARAM.EECNUMCRY)>0
        Call INIEECNUM (WBPSNUM,PBPSNUM,MYPARAM.C_PPKH(1).BPSINV,MYPARAM.BPIEECNUM,MYPARAM.EECNUMCRY) From TRTVENDIV :#--CPO compatible syracuse
      Endif
    Endif
  Endif

  If dim(MYPARAM.SSTENTCOD)>0 :MYPARAM.SSTENTCOD=[F:BPD]SSTENTCOD :Endif  #LTA.n

Return
#--------------------------------------------------------------------------------------------------
# ---------------------------------------- #
#   Alimentation depuis client facture     #
# ---------------------------------------- #
$FLIFAC

  Local Integer NBPOSTE
  Local Integer SPSTAT
  Local Char    WBPSINV(GLONBPC), WBPAINV(GLONBPR)

   If MYPARAM.CUR = "" MYPARAM.CUR = MYPARAM.GLOCALDEV Endif

   If PTYPCLI = "S"  ############## F
      Read [BPR]BPR0 = PBPSNUM
   Else
      Read [BPR]BPR0 = MYPARAM.C_PPKH(1).BPSINV
   Endif

   MYPARAM.CUR    = [F:BPS]CUR

  #   If dim([M:ADB3]CNTNAM)>0 & [M:ADB3]CNTNAM = ""
  #       If PTYPCLI="F" WBPAINV=[F:BPC]BPAADD  : WBPCINV=PBPCNUM
  #       Else          WBPAINV=[M:ADB3]BPAADD : WBPCINV=MYPARAM.c_spkh(1).BPCINV : Endif
  #       Call RECH_CNTNAM(WBPCINV, WBPAINV, [M:ADB3]CNTNAM) From TRTVENDIV
  #   Endif

  #   If dim([M:ADB3]EECNUM)>0 & [M:ADB3]EECNUM = "" [M:ADB3]EECNUM = [F:BPR]EECNUM Endif
  #  Bug : 67515 : Alimentation code adresse client facture dans [M:ADB3]

  #   If dim([M:ADB3]BPAADD) > 0 & [M:ADB3]BPAADD=""
  #      If [F:BPC]BPCINV=[F:BPC]BPCNUM & [F:BPC]BPAINV<>[F:BPR]BPAADD
  #          [M:ADB3]BPAADD = [F:BPC]BPAINV
  #      Endif
  #   Endif

   If PTYPCLI = "S" and dim(MYPARAM.BPINAM)>0 : MYPARAM.BPINAM = [F:BPS]BPSNAM : Endif

   MYPARAM.CHGTYP = [F:BPS]CHGTYP
   # MYPARAM.PRITYP = [F:BPS]PRITYP  ##############

  If PTYPCLI = "S" & PTYPCDE = 1 & dim(MYPARAM.BPIEECNUM)>0
      Call INIEECNUM (MYPARAM.BPSNUM,MYPARAM.BPAADD,PBPSNUM,MYPARAM.BPIEECNUM,MYPARAM.EECNUMCRY) From TRTVENDIV
  Endif

  ## Init. du tableau des éléments de facturation
  #    NBPOSTE=dim([M:SOH3]INVDTA)
  #    Raz [M:SOH3]INVDTAAMT
  #    Call STRUFOOT (3,"SOH3",NBPOSTE,MYPARAM.CHGTYP,MYPARAM.CUR, MYPARAM.CUR, "OUI") From SUBSFIT
  #    [M:SOH3]NBFAC = NBPOSTE

  # Récupération du format de saisie des frais/remises
  #    Call FMTREM("SOH4", MYPARAM.CUR) From TRTPRICE
  #Endif
  #If PTYPCDE = 2
  ## Init. du tableau des éléments de facturation
  #    NBPOSTE=dim([M:SOR1]INVDTA)
  #    Raz [M:SOR1]INVDTAAMT
  #    Call STRUFOOT (3,"SOR1",NBPOSTE,[M:SOR1]CHGTYP,[M:SOR1]CUR, [M:SOR1]CUR, "OUI") From SUBSFIT
  #    [M:SOR1]NBFAC = NBPOSTE
  #Endif
   If dim(MYPARAM.C_PPKH(1).PTE)>0 and dim(MYPARAM.C_PPKH(1).BPRPAY)>0
     Call INIPTE (MYPARAM.ACTX, MYPARAM.CPY, MYPARAM.C_PPKH(1).BPRPAY, [F:BPS]BPSNUM, "F", MYPARAM.C_PPKH(1).PTE, MYPARAM.C_PPKH(1).PTE_LEG)      # From TRTX3
   Endif
   If dim(MYPARAM.C_PPKH(1).DEP)>0
     Call INIT_ESCOMPTE ([F:BPS]BPSNUM,  MYPARAM.CPY, "F", MYPARAM.C_PPKH(1).DEP) # From CPTSUB
   Endif

    # Conversion montant mini cde devise dossier vers devise commande
    If dim(MYPARAM.ORDMINAMT)>0
      If MYPARAM.GSYSCUR <> MYPARAM.CUR
          Call CONVERT(MYPARAM.ACTX, MYPARAM.GSYSCUR, MYPARAM.CUR, MYPARAM.GLOCALDEV, MYPARAM.CHGTYP, MYPARAM.DOCDAT, MYPARAM.ORDMINAMT, MONTANT,SPSTAT) From TRTDEV_SYRA
          MYPARAM.ORDMINAMT = MONTANT
      Endif
    Endif

    # Alimentation des zones en-cours (dépend du tiers risque du client cde et de la devise du clt facture)
    # Call SDCDTSTA("",[M]BPCORD,[M]CHGTYP,0,[M]CUR,[M]ORDDAT,[M]UNL,1,[M]CDTSTA, [M]OST,[M]OSTAUZ) From TRTVENCDT

$FLIFAC1

Return
