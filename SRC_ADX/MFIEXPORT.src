#<AdxTL>@(#)2.0.0.0 $Revision$
$ACTION
Case ACTION
    When "EXP_ZONE" :      Gosub EXP_ZONE
Endcase
Return

########################################################
# GIMP :                                               #
#     GIMP(1) : Emplacement par défaut pour article    #
########################################################

###################################################################################
$EXP_ZONE
Local Integer WRETOUR
If EXPFIC="MFG" & GACTION="MESINT" : #interface MES
    If EXPZON="[F:MFI]MFGDES"
        If [F:MFI]MFGDES=""
            Local Char WITMDES(GLONDES)                                                          # FGR 30/06/2009 : X3SUIVI56189
            Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:MFI]ITMREF,WITMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
            [F:MFI]MFGDES=WITMDES
        Endif
    Elsif EXPZON="GIMP(1)"
            Gosub STK_INILOC From STKLOC
            Gosub INI_STO From SUBMESINT
            Raz [M:ENTW]
            [M:ENT]STOFCY = [F:MFI]MFGFCY
            [M:ENT]ITMREF = [F:MFI]ITMREF
            [M:ENT]TRSTYP = 5
            [M:ENTW]WZONPCU = "UOM"
            [M:ENTW]WZONQUC = "UOMCPLQTY"
            [M:ENTW]WZONCCS = "UOMSTUCOE"
            [M:ENTW]WZONSTU = "STU"
            [M:ENTW]WZONQUS = "CPLQTY"
            [M:ENTW]WZONSTOUPD = ""
            Default Mask [MTK2]
            Raz [M:MTK2]
            [M:MTK2]NBITM=1
            N=0
            [M:MTK2]ITMREF(0)=[F:MFI]ITMREF
            [M:MTK2]UOM(0)=[F:MFI]UOM
            [M:MTK2]UOMCPLQTY(0)=[F:MFI]RMNEXTQTY

            Call INIZONENT([M:MTK2]ITMREF(N),"MTK2",[F:MFI]MFGFCY,"",0,"U",N,5,"",[F:MFI]MFGNUM,3,1) From STKECR
        
            # car RAZ dans INIZONENT
            If dim([M:MTK2]LOT) > 0: [M:MTK2]LOT(0) = [F:MFI]LOT  : Endif
        
            status=0
            Call STJSTOENTW("MTK2",5,15,date$,N,[M:MTK2]NBITM,"MTS",3,WRETOUR) From STKENT
            GIMP(1)=[M:MTK2]LOC(0)
    Endif
Endif
Return



