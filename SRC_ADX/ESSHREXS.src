Subprog AS_EXSSTA(VALEUR)
Variable Integer VALEUR
[V]GMENLOC(5)=1
[V]GMENLOC(6)=1
[V]GMENLOC(7)=1


If find(2,[M:ESEX0]STA(0..[M:ESEX0]NBLIG-1)) | ([L]VALEUR>1 & !instr(1,[V]GUSRAUZ(1),"2"))
 mkstat=2
Endif
End

Subprog AS_NBLIG
Call TOTAUX()
Affzo [M:ESEX0] 30
End

Subprog C_NBLIG
Local Integer ILINE,IRET



If status = 82 or status = 73 Then
  # Insert line
  If [M:ESEX0]DATEXS(nolign-1) = AVOID.ADATE Then
    ILINE = fmet I_EXPENSESESS.ADDLINE("HREXPENSES", [V]CST_ALASTPOS)
    If ILINE <> [V]CST_ANOTDEFINED Then
      Call SHOW_EXPENSES_HREXPENSES(ILINE) From ESSHREXS
      GLOBILINE = ILINE
    Else
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(I_EXPENSESESS)
      GERR = 4
      mkstat = 2
      GOK = 1
      End
    Endif
    Affzo [M:ESEX0]20
  Endif
  #Manage localisations
  Call HIDE_ACTIVITYFIELDS From WESSHREXSHIDE
  Call SHOW_LEGACTCALLS From WESSHREXSSHOW
Elsif status = 65 #or status = 71 Then
  ILINE = [M:ESEX0]LIN(nolign-1)
  # Delete a line
  IRET = fmet I_EXPENSESESS.ADELLINE("HREXPENSES", I_EXPENSESESS.HREXPENSES(ILINE).AORDER)
  If IRET = [V]CST_ANOTDEFINED Then
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(I_EXPENSESESS)
    GOK = 0
    GERR = 1
    mkstat = 2
  Endif
Elsif status = 71 Then
  If GLOBILINE <> AVOID.AINT and [M:ESEX0]CODEXP(nolign-1)=AVOID.ACHAR
    # Delete a line
    IRET = fmet I_EXPENSESESS.ADELLINE("HREXPENSES", I_EXPENSESESS.HREXPENSES(GLOBILINE).AORDER)
    Raz GLOBILINE
    If IRET = [V]CST_ANOTDEFINED Then
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(I_EXPENSESESS)
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
  Endif
Endif
End

Subprog B3_NBLIG
End

Subprog AVANT_NBLIG
If [V]GWEBSERV & [M:ESEX0]STA(nolign-1)>1 : zonsui="DATEXS(nolign)" : Endif
End

Subprog APRES_NBLIG
Call TOTAUX()
Affzo [M:ESEX0] 30
End


Subprog D_DATEXS(VALEUR)
Variable Date    VALEUR
If nolign>1 : [L]VALEUR=[M:ESEX0]DATEXS(nolign-2)
Else          [L]VALEUR=[M:ESEX0]STRDAT
Endif
End

Subprog AM_DATEXS(VALEUR)
Variable Date    VALEUR

#------------------------Hybrid-------------------------#

I_EXPENSESESS.HREXPENSES([M:ESEX0]LIN(nolign-1)).DATEXS = VALEUR
Call RECOVERS_ERROR_IN_CLASSIC(I_EXPENSESESS) From ESSHREXS
If GERR = 1 Then
  I_EXPENSESESS.HREXPENSES([M:ESEX0]LIN(nolign-1)).DATEXS = [0/0/0]#I_EXPENSESESS.HREXPENSES([M:ESEX0]LIN(nolign-1)).snapshot.DATEXS
  GERR = 1
  mkstat = 2
  End
Else
  Call SHOW_EXPENSES_HREXPENSES([M:ESEX0]LIN(nolign-1)) From ESSHREXS
Endif
Affzo [M:ESEX0]1-99

#------------------------Hybrid-------------------------#

End

