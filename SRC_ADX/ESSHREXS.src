  End
Else
  Call SHOW_EXPENSES_HREXPENSES([M:ESEX0]LIN(nolign-1)) From ESSHREXS
  [M:ESEX0]UOMDES(nolign-1)=func AFNC.TEXTRA("ATABDIV","LNGDES","10551",[F:HRTES]UOM)
Endif
Affzo [M:ESEX0]1-99

#------------------------Hybrid-------------------------#
End

