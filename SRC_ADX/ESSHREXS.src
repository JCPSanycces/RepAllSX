#<AdxTL>@(#)0.0.0.0 $Revision$ 
# Mask management ESEXS0

$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
   When "OK"          : Gosub OK
   When "SORTIE"      : Gosub SORTIE
Endcase

Return

$OUVRE
#Disabling the classic CUD operation - Hybrid development (ANOWRITE)
Global Integer GLOBILINE
Local Integer ANOWRITE
ANOWRITE = 1

#Opening tables and declaring an instance of the main class
If clalev([F:HRCTR])  = 0 : Local File EMPLOCTR     [HRCTR]   : Endif
If clalev([F:ID])     = 0 : Local File EMPLOID      [ID]      : Endif
#If clalev([F:BBB])    = 0 : Local File BBLOB        [BBB]     : Endif
If clalev([F:HRTES])  = 0 : Local File HRTABEXPENS  [HRTES]     : Endif
If clalev([F:ESB])    = 0 : Local File EMPSBD  [ESB]          : Endif

#Instantiate the EXPENSESESS class
Global Instance I_EXPENSESESS Using C_EXPENSESESS

#Manage Localisations
Call MANAGE_LOCALISATION("ESSHREXS") From DIVPAYE

Return

$DEBUT

Raz [M:ESEX0]

#-------------------------------Hybrid----------------------------------#
#Read the data from the class and transfer to the mask (Default Values)
Local Integer MY_STATUS
If I_EXPENSESESS <> null Then
  FreeGroup I_EXPENSESESS
Endif

I_EXPENSESESS = NewInstance C_EXPENSESESS AllocGroup null
[L]MY_STATUS = fmet I_EXPENSESESS.AINIT()
If [L]MY_STATUS <> [V]CST_AOK Then
  Call RECOVERS_ERROR_IN_CLASSIC(I_EXPENSESESS)
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(0009,10727,1)
  Endif
  If [L]MY_STATUS <> [V]CST_AWARNING and [L]MY_STATUS <> [V]CST_AINFO Then
    OK = 0
    Return
  Endif
Endif

#Setting GCURLEG
[V]GCURLEG = [M:ESEX0]LEG
Gosub UPDATE_ESEXS0
#---------------------------------Hybrid----------------------------------#

#Update picture
#  Read [BBB]BBB0 = "EMPPIC";[M:ESEX0]REFNUM;"";""
#  If !fstat
#   [M:ESEX0]EMPPIC = [F:BBB]BLOB
#  Endif

#Updating addtional technical fields
[M:ESEX0]NAMSRN  = I_EXPENSESESS.TCH_NAMSRN

If GFONCTION = "ESSMGREXS"
  [M:ESEX0]CHEF = [M:ESEX0]REFNUM
  Raz [M:ESEX0]REFNUM
  Raz [M:ESEX0]NAMSRN
  Raz [M:ESEX0]LEG
Endif

Gosub SHOW_HIDE

#Updating the function icons
[M:ESEX0]WPEN = "53"
[M:ESEX0]WHIS = "54"

#Manage localisations
Call HIDE_ACTIVITYFIELDS From WESSHREXSHIDE
Call SHOW_LEGACTCALLS From WESSHREXSSHOW

Affzo [M:ESEX0]1-99

Return

$SHOW_HIDE
If GFONCTION = "ESSMGREXS"
  Actzo [M:ESEX0]REFNUM
Else
  Diszo [M:ESEX0]REFNUM
Endif
Return

$OK
#Invoke the creation method on the class
Local Integer MY_STATUS, STAT
Local Char ERRMESSAGE(250)

[L]MY_STATUS = fmet I_EXPENSESESS.AINSERT()
If [L]MY_STATUS <> [V]CST_AOK Then
  Call RECOVERS_ERROR_IN_CLASSIC(I_EXPENSESESS)
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(10,10727,1)
  Endif
  If [L]MY_STATUS <> [V]CST_AWARNING and [L]MY_STATUS <> [V]CST_AINFO Then
    Return
  Endif
Endif

If GMESSAGE = AVOID.ACHAR Then
  GMESSAGE= mess(11,10727,1)
Else
  GMESSAGE= mess(11,10727,1)+":"-GMESSAGE
Endif
GERR = 2

Return

$SORTIE
#Free the instance at the end of the template
#If I_EXPENSESESS <> null Then
#  FreeGroup I_EXPENSESESS
#Endif
Return

Subprog RECOVERS_ERROR_IN_CLASSIC(I_EXPENSESESS)
Variable Instance I_EXPENSESESS Using C_EXPENSESESS

Local Integer NI
Local Char SMESSAGE(type(GMESSAGE)-10)
Local Integer MY_STATUS
Local Integer IMESSAGE
Local Integer IOPEN_TRACE

#----------Hybrid----------------------#
IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(I_EXPENSESESS, SMESSAGE)
If IMESSAGE = [V]CST_AWARNING or IMESSAGE = [V]CST_AINFO Then
  GMESSAGE = SMESSAGE
  GERR = 2
Elsif IMESSAGE = [V]CST_AERROR or IMESSAGE = [V]CST_AFATAL Then
  GMESSAGE = SMESSAGE
  GOK = 0
  GERR = 1
Endif
#----------Hybrid----------------------#


# To help debug process : write a classic log file with all errors in class.
If GERR <> 0 Then
  If GTRACE = AVOID.ACHAR Then
    Call OUVRE_TRACE("MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG" + GUSER) From LECFIC
    IOPEN_TRACE = [V]CST_AYES
  Endif
  Call ECR_TRACE("->", 0) From GESECRAN
  Call MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(I_EXPENSESESS) From SYRSTACKTOOLS
  If IOPEN_TRACE = [V]CST_AYES Then
    Call FERME_TRACE From LECFIC
  Endif
Endif
# ----------------------------------------------------------

[L]MY_STATUS = fmet I_EXPENSESESS.ADELETERRORALL()
End

$UPDATE_ESEXS0
#Load the data from the class to the screen
SetInstance [M:ESEX0] With I_EXPENSESESS
If GFONCTION = "ESSMGREXS"
  [M:ESEX0]NAMSRN  = I_EXPENSESESS.TCH_SBDSRN
Endif
Affzo [M:ESEX0]1-99
Return

#**
#* Return the message of the first most stack level of a instance including collections
#*
#* @param POOBJECT : Instance
#* @return (String) : Message found or error message if not found
#*!
Funprog MSGSTACK_GET_FIRST_MAX_MESSAGE(POOBJECT)
Variable Instance POOBJECT Using OBJECT
Local Char SMESSAGE(255)

Local Integer  NSTATUS
Local Instance OCTX Using =[V]CST_C_NAME_CLASS_CONTEXT

  OCTX = NewInstance [ZCTX] With =[V]CST_C_NAME_CLASS_CONTEXT
  NSTATUS = fmet POOBJECT._AERROR(OCTX, [V]CST_ANO) : # this invoke allows to agregate all class' and subclasses' stacks in OCTX's stack

  SMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE_INST(OCTX)

  FreeGroup OCTX

End SMESSAGE

Subprog SHOW_EXPENSES_HREXPENSES(VNLINE)
Value Integer VNLINE

  SetInstance [M:ESEX0]20 With I_EXPENSESESS.HREXPENSES(VNLINE)
  [M:ESEX0]SNS(nolign-1) = I_EXPENSESESS.HREXPENSES(VNLINE).TCH_SNS
  [M:ESEX0]LIN(nolign-1) = VNLINE   # Line index in the collection
End

Subprog EXPENSE_TOTALS()

[M:ESEX0]TOTPAY = I_EXPENSESESS.TCH_TOTPAY
[M:ESEX0]TOTRFU = I_EXPENSESESS.TCH_TOTRFU
End

Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()

If VALEUR = ""
  GMESSAGE = mess(00011,0050,1)-":"-mess(00010,00123,1)
  mkstat = 2
  GERR=2
  End
Endif

If GFONCTION = "ESSMGREXS"
  If dim([F:ESB]REFNUM) & [F:ESB]REFNUM <> ""
    VALEUR = [F:ESB]REFNUM
  Endif
Endif



End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()

#------------------------Hybrid-------------------------#
If GFONCTION = "ESSMGREXS" #Update TCH_EMP
  I_EXPENSESESS.TCH_EMPSBD = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(I_EXPENSESESS)
  If GERR = 1 Then
    I_EXPENSESESS.TCH_EMPSBD  = I_EXPENSESESS.snapshot.TCH_EMPSBD
    GERR = 1
    mkstat = 2
    End
  Else
    Gosub UPDATE_ESEXS0
  Endif
Endif
#------------------------Hybrid-------------------------#
End



