Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
#------------------------Hybrid-------------------------#

I_EXPENSESESS.HREXPENSES([M:ESEX0]LIN(nolign-1)).CPY = VALEUR
Call RECOVERS_ERROR_IN_CLASSIC(I_EXPENSESESS) From ESSHREXS
If GERR = 1 Then
  I_EXPENSESESS.HREXPENSES([M:ESEX0]LIN(nolign-1)).CPY = I_EXPENSESESS.HREXPENSES([M:ESEX0]LIN(nolign-1)).snapshot.CPY
  GERR = 1
  mkstat = 2
  End
Else
  Call SHOW_EXPENSES_HREXPENSES([M:ESEX0]LIN(nolign-1)) From ESSHREXS
  Call EXPENSE_TOTALS()
Endif
Affzo [M:ESEX0]1-99

#------------------------Hybrid-------------------------#
End

