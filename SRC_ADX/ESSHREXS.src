Subprog GETCTRLEG(VALEUR)
Value Char VALEUR()

If clalev([F:HRCTR2])=0 : Local File EMPLOCTR [HRCTR2] : Endif
If clalev([F:FCY2])=0   : Local File FACILITY [FCY2]   : Endif

  If VALEUR<>""
    Filter  [HRCTR2] Where CTRNUM=VALEUR
    Read [HRCTR2] Last
    Filter [HRCTR2]
    Read [FCY2]FCY0 = [F:HRCTR2]ETRFCY
    If !fstat
    GCURLEG = [F:FCY2]LEG
    [M:ESEX0]LEG = GCURLEG
    Affzo [M:ESEX0]LEG
    Endif
  Endif
End

Subprog TOTAUX()

Local Shortint I, J

Raz [M:ESEX0]TOTPAY, [M:ESEX0]TOTRFU, [M:ESEX0]TOTSTA
For J=0 To [M:ESEX0]NBLIG-1
 If [M:ESEX0]SNS(J)="+" : I=1 : Else I=-1 : Endif
 [M:ESEX0]TOTPAY+=I*[M:ESEX0]PAYSHR(J)
 [M:ESEX0]TOTRFU+=I*[M:ESEX0]RFUSHR(J)
 If [M:ESEX0]STA(J)=2 : [M:ESEX0]TOTSTA+=I*[M:ESEX0]RFUSHR(J) : Endif
Next
End

Subprog AM_TIT(VALEUR)
Variable Char    VALEUR()
#------------------------Hybrid-------------------------#
I_EXPENSESESS.TIT = VALEUR
Call RECOVERS_ERROR_IN_CLASSIC(I_EXPENSESESS)
If GERR = 1 Then
  I_EXPENSESESS.TIT  = I_EXPENSESESS.snapshot.TIT
  GERR = 1
  mkstat = 2
  End
Else
  Gosub UPDATE_ESEXS0
Endif
#------------------------Hybrid-------------------------#
End

