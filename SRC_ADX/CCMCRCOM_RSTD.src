# Representation script: CCMCHGREQ_RSTD, Change Request - Header

#####################
# METHODS           #
#####################
$METHODS

  Case CURPTH
    When ""
      Case ACTION
        When "IS_ADMIN_USER"          : Gosub IS_ADMIN_USER
      Endcase
  Endcase

Return
# --------------------------------------------------
# Custom Method
#
# Is the logged-in user an X3 administrator ?
# Return true or false.
$IS_ADMIN_USER
  Local Integer LOCSTATUS
  Local Instance AUTILIS Using C_AUTILIS

  AUTILIS = NewInstance C_AUTILIS AllocGroup null
  LOCSTATUS = fmet AUTILIS.AREAD(this.ACTX.USER)
  If (AUTILIS.PRFFCT = "ADMIN")
    ARET_VALUE = CST_ATRUE
  Else
    ARET_VALUE = CST_AFALSE
  Endif
  FreeGroup AUTILIS

Return

#####################
# PROPERTIES        #
#####################
$PROPERTIES

  Case CURPRO
  Endcase

Return


