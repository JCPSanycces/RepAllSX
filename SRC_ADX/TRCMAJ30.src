    Call LEC_TRACE   From LECFIC
Endif

End


#########################################################################
## M.a.j. de ATABDIV : Tables diverses
##   Table no 6 : Nature de transaction CEE
##        CrÃĐation des codes sur 2 caractÃĻres en supprimant le "0" devant
##   Table no 6 et 15
##        SupprÃĐssion des enregistrements prÃĐfixÃĐs par le code pays fonction de la lÃĐgislation
##   Table DEBREGNAT
##        SupprÃĐssion du prÃĐfix des valeurs de rÃĐgime/nature utilisÃĐs
#########################################################################
Subprog AP_ADI
Local File =[F:ADS]DOSSIER+".ATABDIV"    [ADI]
Local File =[F:ADS]DOSSIER+".ATABDIV"    [ADI2]
Local File =[F:ADS]DOSSIER+".ATEXTRA"    [AXX]
Local File =[F:ADS]DOSSIER+".ATEXTRA"    [AXX2]
Local Integer  WNBR
Raz WNBR
Call ECR_TIME("DOSMAJ30 Miscellaneous table n.6 : Update ATABDIV") From DOSSUB
Trbegin [ADI2]
  For [ADI] CODE Where NUMTAB=6 & len(CODE)>2 & left$(CODE,1)="0"
    Look [ADI2] CODE=6;right$([F:ADI]CODE,2)
    If fstat
      [F:ADI2]=[F:ADI] : [F:ADI2]CODE=right$([F:ADI]CODE,2)
      #FQ 53139 - renseignement du code lÃĐgislation
      If [F:ADS]DOSLEG(0)<>"" and [F:ADI2]LEG=""
        [F:ADI2]LEG=[F:ADS]DOSLEG(0)
      Endif

      Write [ADI2]
      If fstat
        Call ECR_TRACE("File ATABDIV 6"-[F:ADI2]CODE+", Error ="-num$(fstat),1) From GESECRAN
      Else
        For [AXX] AXX0 Where CODFIC="ATABDIV" & IDENT1="6" & IDENT2=[F:ADI]CODE
          [F:AXX2]=[F:AXX] : [F:AXX2]IDENT2=[F:ADI2]CODE
          Write [AXX2]
          If fstat
            Call ECR_TRACE("File ATEXTRA ATABDIV"-[F:AXX2]ZONE-[F:AXX2]LANGUE-[F:AXX2]IDENT1
&                          -[F:AXX2]IFDENT2+", Error ="-num$(fstat),1) From GESECRAN
          Endif
        Next
      Endif
    Endif
    Delete [ADI]
    WNBR+=1
  Next
  #FQ 53139
  If [F:ADS]DOSLEG(0)<>""
    Update [ADI2] Where NUMTAB=6 and LEG="" With LEG=[F:ADS]DOSLEG(0)
  Endif

Commit
Close Local File [ADI], [ADI2], [AXX], [AXX2]
Call ECR_TIME("DOSMAJ30 Miscellaneous table n.6 : Ended ("+num$(WNBR)+")") From DOSSUB

#FQ 54636  - Migration V5 vers V6
#-- Suppression des enregistrements tranfÃĐrÃĐs qui sont prÃĐfixÃĐ par le code pays selon la lÃĐgislation
#--Une seule lÃĐgislation sera crÃĐe par dÃĐfaut
#-Si pls lÃĐgislations, cela peut dire qu'il y a migration de V6 vers V6xx (uniquement si multilÃĐgislation...)
#-ce qui veut dire que l'on garde le paramÃĐtrage
#--Normalement pour les dossiers V6 mono-lÃĐgislation on utilise uniquement les libellÃĐs prÃĐfixÃĐs.
#-il n'y aura donc pas de suppression, tel que cela Ã  ÃĐtÃĐ dÃĐveloppÃĐ.

If [F:ADS]DOSLEG(1)<>"" : Goto END_MAJADI : Endif

Local Char WPREFIX (2) : #contient le code pays du dossier en fonction de la lÃĐgislation

Case [F:ADS]DOSLEG(0)
  When "FRA"    : WPREFIX="FR"
  When "GER"    : WPREFIX="DE"
  When "BRI"    : WPREFIX="GB"
  When "ITA"    : WPREFIX="IT"
  When "POR"    : WPREFIX="PT"
  When "SPA"    : WPREFIX="SP"
  When Default  : Goto END_MAJADI
Endcase

If filinfo(filpath("FIL","ATABDIV","fde",[F:ADS]DOSSIER),0)<=0    : End : Endif
If filinfo(filpath("FIL","ATEXTRA","fde",[F:ADS]DOSSIER),0)<=0    : End : Endif
If filinfo(filpath("FIL","PRECEIPT","fde",[F:ADS]DOSSIER),0)<=0   : End : Endif
If filinfo(filpath("FIL","PRETURN","fde",[F:ADS]DOSSIER),0)<=0    : End : Endif
If filinfo(filpath("FIL","PINVOICE","fde",[F:ADS]DOSSIER),0)<=0   : End : Endif
If filinfo(filpath("FIL","SDELIVERY","fde",[F:ADS]DOSSIER),0)<=0  : End : Endif
If filinfo(filpath("FIL","SRETURN","fde",[F:ADS]DOSSIER),0)<=0    : End : Endif
If filinfo(filpath("FIL","SINVOICEV","fde",[F:ADS]DOSSIER),0)<=0  : End : Endif
If filinfo(filpath("FIL","DEBREGNAT","fde",[F:ADS]DOSSIER),0)<=0  : End : Endif
If filinfo(filpath("FIL","DEB","fde",[F:ADS]DOSSIER),0)<=0        : End : Endif

Local File =[F:ADS]DOSSIER+".ATABDIV"   [ADI]
Local File =[F:ADS]DOSSIER+".ATEXTRA"   [AXX]
Local File =[F:ADS]DOSSIER+".PRECEIPT"  [PTH]
Local File =[F:ADS]DOSSIER+".PRETURN"   [PNH]
Local File =[F:ADS]DOSSIER+".PINVOICE"  [PIH]
Local File =[F:ADS]DOSSIER+".SDELIVERY" [SDH]
Local File =[F:ADS]DOSSIER+".SRETURN"   [SRH]
Local File =[F:ADS]DOSSIER+".SINVOICEV" [SIV]
Local File =[F:ADS]DOSSIER+".DEBREGNAT" [DRN]
Local File =[F:ADS]DOSSIER+".DEB"       [DEB]

Local Integer WOK1,WOK2,WOK3,WOK4

Trbegin [ADI]

Call ECR_TRACE(mess(81,125,1)-": DEBREGNAT"-time$,0) From GESECRAN : # maj table
#--SupprÃĐssion des prÃĐfix des codes nature et rÃĐgime utilisÃĐs dans le paramÃĐtrage des flux
#--uniquement s'il existe dans les tables respectives le mÃŠme code mais non prÃĐfixÃĐ
For [DRN] Where len(EECNAT)=4 or len(EECNATR)=4 or len(EECSCH)=4 or len(EECSCHR)=4
  Raz WOK1,WOK2,WOK3,WOK4
  If len([F:DRN]EECNAT)=4 and left$([F:DRN]EECNAT,2)=WPREFIX
    Look [ADI]CODE=6;right$([F:DRN]EECNAT,3)
    If !fstat : WOK1=1 : Endif
  Endif
  If len([F:DRN]EECNATR)=4 and left$([F:DRN]EECNATR,2)=WPREFIX
    Look [ADI]CODE=6;right$([F:DRN]EECNATR,3)
    If !fstat : WOK2=1 : Endif
  Endif
  If len([F:DRN]EECSCH)=4 and left$([F:DRN]EECSCH,2)=WPREFIX
    Look [ADI]CODE=15;right$([F:DRN]EECSCH,3)
    If !fstat : WOK3=1 : Endif
  Endif
  If len([F:DRN]EECSCHR)=4 and left$([F:DRN]EECSCHR,2)=WPREFIX
    Look [ADI]CODE=15;right$([F:DRN]EECSCHR,3)
    If !fstat : WOK4=1 : Endif
  Endif
  If WOK1 or WOK2 or WOK3 or WOK4
    #Readlock [DRN] Curr   # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
    #If !fstat
      If WOK1 : [F:DRN]EECNAT =right$([F:DRN]EECNAT,3) : Endif
      If WOK2 : [F:DRN]EECNATR=right$([F:DRN]EECNATR,3): Endif
      If WOK3 : [F:DRN]EECSCH =right$([F:DRN]EECSCH,3) : Endif
      If WOK4 : [F:DRN]EECSCHR=right$([F:DRN]EECSCHR,3): Endif
      Rewrite [F:DRN]
      If fstat
        Call ECR_TRACE("Error updating DEBREGNAT :"-[F:DRN]LEG-[F:DRN]CRY-[F:DRN]GRP-num$([F:DRN]MVT),1) From GESECRAN
      Endif
    #Endif
  Endif
Next
Call ECR_TRACE(mess(81,125,1)-": DEBREGNAT Ended"-time$,0) From GESECRAN : # maj table

Call ECR_TRACE(mess(81,125,1)-": ATABDIV NÂ°6"-time$,0) From GESECRAN : # maj table
#--SupprÃĐssion des codes prÃĐfixÃĐs s'ils ne sont pas utilisÃĐs dans les enregistrements ci-dessous
For [ADI] Where NUMTAB=6 & len(CODE)=4 & left$(CODE,2)=WPREFIX
  Filter [PTH] Where left$(EECNAT,2)=WPREFIX
  Read [F:PTH] First : If !fstat : Goto NEXT_ADI6 : Endif
  Filter [PNH] Where left$(EECNAT,2)=WPREFIX
  Read [F:PNH] First : If !fstat : Goto NEXT_ADI6 : Endif
  Filter [PIH] Where left$(EECNAT,2)=WPREFIX
  Read [F:PIH] First : If !fstat : Goto NEXT_ADI6 : Endif
  Filter [SDH] Where left$(EECNAT,2)=WPREFIX
  Read [F:SDH] First : If !fstat : Goto NEXT_ADI6 : Endif
  Filter [SRH] Where left$(EECNAT,2)=WPREFIX
  Read [F:SRH] First : If !fstat : Goto NEXT_ADI6 : Endif
  Filter [SIV] Where left$(EECNAT,2)=WPREFIX or left$(EECNATR,2)=WPREFIX
  Read [F:SIV] First : If !fstat : Goto NEXT_ADI6 : Endif
  Filter [DRN] Where left$(EECNAT,2)=WPREFIX or left$(EECNATR,2)=WPREFIX
  Read [F:DRN] First : If !fstat : Goto NEXT_ADI6 : Endif
  Filter [DEB] Where left$(EECNAT,2)=WPREFIX
  Read [F:DEB] First : If !fstat : Goto NEXT_ADI6 : Endif
  #--ArrivÃĐs ici, on est sÃŧrs que les principales piÃĻces n'utilisent pas ce code
  Delete [F:ADI] Curr
  If fstat : Call ECR_TRACE("Error deleting record :"-num$([F:ADI]NUMTAB)-[F:ADI]CODE,1) From GESECRAN : Endif
  #--Si suppression rÃĐussie
  #--on vire ÃĐgalement les intitulÃĐs de la table ATEXTRA
  If !fstat
    Delete [AXX] Where CODFIC="ATABDIV" & IDENT1="6" & IDENT2=[F:ADI]CODE
    If fstat : Call ECR_TRACE("File ATEXTRA, Error ="-num$(fstat),1) From GESECRAN : Endif
  Endif

  $NEXT_ADI6
  Filter [PTH] : Filter [PNH] : Filter [PIH]
  Filter [SDH] : Filter [SRH] : Filter [SIV]
  Filter [DRN] : Filter [DEB]
Next
Call ECR_TRACE(mess(81,125,1)-": ATABDIV NÂ°6 Ended"-time$,0) From GESECRAN : # maj table

Call ECR_TRACE(mess(81,125,1)-": ATABDIV NÂ°15"-time$,0) From GESECRAN : # maj table
#--SupprÃĐssion des codes prÃĐfixÃĐs s'ils ne sont pas utilisÃĐs dans les enregistrements ci-dessous
For [ADI] Where NUMTAB=15 & len(CODE)=4 & left$(CODE,2)=WPREFIX
  Filter [PTH] Where left$(EECSCH,2)=WPREFIX
  Read [F:PTH] First : If !fstat : Goto NEXT_ADI15 : Endif
  Filter [PNH] Where left$(EECSCH,2)=WPREFIX
  Read [F:PNH] First : If !fstat : Goto NEXT_ADI15 : Endif
  Filter [PIH] Where left$(EECSCH,2)=WPREFIX
  Read [F:PIH] First : If !fstat : Goto NEXT_ADI15 : Endif
  Filter [SDH] Where left$(EECSCH,2)=WPREFIX
  Read [F:SDH] First : If !fstat : Goto NEXT_ADI15 : Endif
  Filter [SRH] Where left$(EECSCH,2)=WPREFIX
  Read [F:SRH] First : If !fstat : Goto NEXT_ADI15 : Endif
  Filter [SIV] Where left$(EECSCH,2)=WPREFIX or left$(EECSCHR,2)=WPREFIX
  Read [F:SIV] First : If !fstat : Goto NEXT_ADI15 : Endif
  Filter [DRN] Where left$(EECSCH,2)=WPREFIX or left$(EECSCHR,2)=WPREFIX
  Read [F:DRN] First : If !fstat : Goto NEXT_ADI15 : Endif
  Filter [DEB] Where left$(EECSCH,2)=WPREFIX
  Read [F:DEB] First : If !fstat : Goto NEXT_ADI15 : Endif
  #--ArrivÃĐs ici, on est sÃŧrs que les principales piÃĻces n'utilisent pas ce code
  Delete [F:ADI] Curr
  If fstat : Call ECR_TRACE("Error deleting record :"-num$([F:ADI]NUMTAB)-[F:ADI]CODE,1) From GESECRAN : Endif
  #--Si suppression rÃĐussie
  #--on vire ÃĐgalement les intitulÃĐs de la table ATEXTRA
  If !fstat
    Delete [AXX] Where CODFIC="ATABDIV" & IDENT1="15" & IDENT2=[F:ADI]CODE
    If fstat : Call ECR_TRACE("File ATEXTRA, Error ="-num$(fstat),1) From GESECRAN : Endif
  Endif

  $NEXT_ADI15
  Filter [PTH] : Filter [PNH] : Filter [PIH]
  Filter [SDH] : Filter [SRH] : Filter [SIV]
  Filter [DRN] : Filter [DEB]
Next
Call ECR_TRACE(mess(81,125,1)-": ATABDIV NÂ°15 Ended"-time$,0) From GESECRAN : # maj table

Commit

Close Local File [F:PTH],[F:PNH],[F:PIH]
Close Local File [F:SDH],[F:SRH],[F:SIV]
Close Local File [F:DRN],[F:DEB],[F:AXX],[F:ADI]

$END_MAJADI
End


####################################################################################
Subprog UPDATZTBO(LDOS)
Value Char LDOS

Local File =LDOS+".ATABIND"     [ATI2]
Local File =LDOS+".ATABZON"     [ATZ2]
Local Integer  COMPTEUR, STOP : COMPTEUR=0
Local Integer  WPOS_BOMALT    , WPOS_BOMALTTYP , WPOS_VIRGULE     : # Position des champs dans le lien
Local Char     WCLE_BOMALT(30), WCLE_BOMALTTYP(30) : # Syntaxe  des champs dans le lien

CRITERE="1=1"
Call DEBTRANS From GLOCK
Raz COMPTEUR
Trbegin [ATZ2]
# pour la V6: si et seulement si Index de TABBOMALT TBO0=BOMALTTYP+BOMALT
Read [F:ATI2]CODIND="TABBOMALT";"TBO0"
If fstat | [F:ATI2]DESCRIPT<>"BOMALTTYP+BOMALT" : End : Endif

Filter [F:ATZ2] Where CODTYP="TBO" & LIEN="TABBOMALT"
For [F:ATZ2]
  If [F:ATZ2]EXPLIEN > " "
      WPOS_BOMALTTYP=instr(1,[F:ATZ2]EXPLIEN,"BOMALTTYP")
      WPOS_BOMALT   =instr(max(1,WPOS_BOMALTTYP+1),[F:ATZ2]EXPLIEN,"BOMALT")
      WPOS_VIRGULE  =instr(1,[F:ATZ2]EXPLIEN,";")
      If WPOS_BOMALT > 0 & WPOS_BOMALTTYP >0 & WPOS_BOMALTTYP < WPOS_BOMALT
         # la maj a deja ete lancee => Rien Ã  faire
      Elsif WPOS_BOMALT > 2 & WPOS_BOMALTTYP =0
         # la maj a deja ete lancee => Rien Ã  faire
      Elsif WPOS_BOMALT > 0 & WPOS_BOMALTTYP >0 & WPOS_BOMALTTYP > WPOS_BOMALT
         # inverser les 2 champs
         WCLE_BOMALT    = mid$([F:ATZ2]EXPLIEN,1,WPOS_VIRGULE-1)
         WCLE_BOMALTTYP = right$([F:ATZ2]EXPLIEN,WPOS_VIRGULE+1)
         [F:ATZ2]EXPLIEN = WCLE_BOMALTTYP+";"+WCLE_BOMALT
      Elsif WPOS_BOMALTTYP=0 & WPOS_VIRGULE > 0 & len([F:ATZ2]EXPLIEN)=WPOS_VIRGULE+1
         # BOMALTTYP est parfois remplacÃĐ par une constante (en dernier)
         WCLE_BOMALT    = mid$([F:ATZ2]EXPLIEN,1,WPOS_VIRGULE-1)
         WCLE_BOMALTTYP = right$([F:ATZ2]EXPLIEN,WPOS_VIRGULE+1)
         [F:ATZ2]EXPLIEN = WCLE_BOMALTTYP+";"+WCLE_BOMALT
      Elsif WPOS_BOMALTTYP=0 & WPOS_VIRGULE = 2          # FQ 51454 GA 01/2009
         # BOMALTTYP est parfois remplacÃĐ par une constante (en premier)
         # dÃĐjÃ  ok => Rien Ã  faire
      Else
         Call ECR_TRACE("File ATABZON, Link to be checked="+[F:ATZ2]EXPLIEN
&                        -"=> File definition="+[F:ATZ2]CODFIC,0) From GESECRAN
      Endif
      Rewrite [F:ATZ2]
      COMPTEUR += 1
  Endif
Next
Commit

Filter [ATZ2]
Close Local File [ATZ2]
Close Local File [ATI2]

End


###############################################################################
# UPDCBH : - INIT du type d'alternative BOMALTTYP
###############################################################################
# ParamÃĻtres E : LDOS   = Dossier
###############################################################################
Subprog UPDCBH(LDOS)
Value Char LDOS

If filinfo(filpath("FIL","CBNHEA","fde",LDOS),0) <=0   End   Endif

Local File =LDOS+".ITMMASTER"  [ITM]
Local File =LDOS+".CBNHEA"     [CBH]
Local Integer WRE

   Call ECR_TRACE("Start trace : CBNHEA => CLSTYP & BOMALTTYP" ,0) From GESECRAN
   Raz WRE
   Trbegin [CBH]
   For [CBH]
       #Readlock [CBH] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
       #If !fstat
           #---- CLSTYP ----#
           If [F:CBH]ITMREF<>""
              Read [ITM]ITM0=[F:CBH]ITMREF
              If !fstat
                 [F:CBH]MFGFLG = [F:ITM]MFGFLG
                 [F:CBH]SCPFLG = [F:ITM]SCPFLG
                 [F:CBH]SCSFLG = [F:ITM]SCSFLG
                 [F:CBH]PHAFLG = [F:ITM]PHAFLG
                 [F:CBH]GENFLG = [F:ITM]GENFLG
                 [F:CBH]TOOFLG = [F:ITM]TOOFLG
                 [F:CBH]DLVFLG = [F:ITM]DLVFLG
                 [F:CBH]PURFLG = [F:ITM]PURFLG
                 [F:CBH]SALFLG = [F:ITM]SALFLG
                 [F:CBH]INTFLG = [F:ITM]INTFLG
# FQ 51454 colonnes CLSTYP supprimÃĐe dans ces tables ...
#                 If [F:ITM]CLSTYP <> [F:CBH]CLSTYP
#                    Call ECR_TRACE([F:CBH]STOFCY-" "-[F:CBH]ITMREF-" "-mess(255,184,1)
#&                   -mess([F:CBH]CLSTYP,222,1)-mess(254,184,1)-mess([F:ITM]CLSTYP,222,1),-1) From GESECRAN
#                 Endif
              Endif
          Endif
        # GA pour la V6 par dÃĐfaut il s'agit d'une nomenclature de production
          If [F:CBH]BOMALTTYP=0 & [F:CBH]BOMALT>0 : [F:CBH]BOMALTTYP=2 : Endif
          Rewrite [CBH]
          WRE +=1
       #Endif
   Next
   Commit
   Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),0) From GESECRAN
End

