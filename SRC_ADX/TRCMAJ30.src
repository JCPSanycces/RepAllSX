Local Integer  CLE2, CLE4, CLE5

Gosub SET_FIRST From TRTFIRST

Raz CLE1, CLE2 , CLE3 , CLE4, STOP
$BOUCLE_CSC
If STOP=1
   STOP=0 : CRITERE='SCENUM >"'+CLE1+'"'
Else
   CRITERE="1=1"
Endif
CRITERE += " & BOMALT <> 0"
CRITERE += " & BOMALTTYP=0"

Call DEBTRANS From GLOCK
Raz COMPTEUR
Trbegin [CSC]
For [CSC]CSC0 Where evalue (CRITERE)
    If fstat
        Call ECR_TRACE("File CGHSCE, Error="-num$(fstat),1) From GESECRAN
    Else
        Read [F:TBO]TBO2(1) =  [F:CSC]BOMALT
        If !fstat : [F:CSC]BOMALTTYP = [F:TBO]BOMALTTYP : Endif
        Read [F:TBO]TBO2(1) =  [F:CSC]BOMALTREF
        If !fstat : [F:CSC]ALTTYPREF = [F:TBO]BOMALTTYP : Endif
        Rewrite [CSC]
    Endif
    COMPTEUR += 1

    If COMPTEUR > GMAXUPDTRS
       CLE1 = [F:CSC]SCENUM
       STOP =1
       Break
    Endif
Next
Commit

If STOP : Goto BOUCLE_CSC : Endif
Filter [CSC]
Close Local File [CSC]
Close Local File [TBO]

Gosub UNSET_FIRST From TRTFIRST

End


