####################################################################################
Subprog UPDBOD(LDOS)
Value Char LDOS

Local File =LDOS+".BOM"  [BOH]
Local File =LDOS+".BOMD" [BOD]
Local Integer  COMPTEUR, STOP
Local Char     CLE1(GLONVCR),CLE3(GLONVCR),CRITERE(250)
Local Integer  CLE2, CLE4, CLE5

Raz CLE1, CLE2 , CLE3 , CLE4, STOP
$BOUCLE_BOH
If STOP=1
   STOP=2 : CRITERE='ITMREF ="'+CLE1+'"'+'& BOMALT>'+ num$(CLE2)
Elsif STOP=2
   STOP=0 : CRITERE='ITMREF >"'+CLE1+'"'
Else
   CRITERE="1=1"
Endif

Call DEBTRANS From GLOCK
Raz COMPTEUR
Trbegin [BOD]
For [BOH] Where evalue (CRITERE)
    For [F:BOD] Where ITMREF = [F:BOH]ITMREF & BOMALT = [F:BOH]BOMALT
        #Readlock [BOD] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
        [F:BOD]BOMALTTYP = [F:BOH]BOMALTTYP
        Rewrite [F:BOD]
        COMPTEUR +=1
    Next
    If COMPTEUR > GMAXUPDTRS
       CLE1 = [F:BOH]ITMREF
       CLE2 = [F:BOH]BOMALT
       STOP =1
       Break
    Endif
Next
Commit

If STOP : Goto BOUCLE_BOH : Endif
Filter [BOH]
Filter [BOD]
Close Local File [BOH]
Close Local File [BOD]

End

####################################################################################
Subprog UPDITB(LDOS)
Value Char LDOS

Local File =LDOS+".ITMBOM"      [ITB]
Local File =LDOS+".TABBOMALT"   [TBO]
Local Integer  COMPTEUR, STOP
Local Char     CLE1(GLONVCR),CLE3(GLONVCR),CRITERE(250)
Local Integer  CLE2, CLE4, CLE5
Local Integer  WBOMALTTYP

Raz CLE1, CLE2 , CLE3 , CLE4, STOP
$BOUCLE_ITB
If STOP=1
   STOP=2 : CRITERE='ITMREF ="'+CLE1+'"'+'& BOMALT>'+ num$(CLE2)
Elsif STOP=2
   STOP=0 : CRITERE='ITMREF >"'+CLE1+'"'
Else
   CRITERE="1=1"
Endif

Call DEBTRANS From GLOCK
Raz COMPTEUR
Trbegin [ITB]
For [ITB] Where evalue (CRITERE)
    If fstat
        Call ECR_TRACE("File ITMBOM, Error="-num$(fstat),1) From GESECRAN
    Else
        If [F:ITB]LLCTYP = 0
            WBOMALTTYP = 0
            For [F:TBO] Where BOMALT = [F:ITB]BOMALT
                WBOMALTTYP = [F:TBO]BOMALTTYP
                Break
            Next
            #Readlock [ITB] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
            Case WBOMALTTYP
                When 2,3:      [F:ITB]LLCTYP = 2
                When Default:  [F:ITB]LLCTYP = 1
            Endcase
            Rewrite [ITB]
        Endif
    Endif
    COMPTEUR += 1

    If COMPTEUR > GMAXUPDTRS
       CLE1 = [F:ITB]ITMREF
       CLE2 = [F:ITB]BOMALT
       STOP =1
       Break
    Endif
Next
Commit

If STOP : Goto BOUCLE_ITB : Endif
Filter [ITB]
Close Local File [ITB]
Close Local File [TBO]

End

####################################################################################
Subprog UPDCFB(LDOS)
Value Char LDOS

# FQ 49666
If filinfo(filpath("FIL","ITMBOMCFG","fde",LDOS),0) <=0   End   Endif

Local File =LDOS+".ITMBOMCFG"   [CFB]
Local File =LDOS+".TABBOMALT"   [TBO]
Local Integer  COMPTEUR, STOP
Local Char     CLE1(GLONVCR),CLE3(GLONVCR),CRITERE(250)
Local Integer  CLE2, CLE4, CLE5
Local Integer  WBOMALTTYP

Raz CLE1, CLE2 , CLE3 , CLE4, STOP
$BOUCLE_CFB
If STOP=1
   STOP=2 : CRITERE='ITMREF ="'+CLE1+'"'+'& BOMALT>'+ num$(CLE2)
Elsif STOP=2
   STOP=0 : CRITERE='ITMREF >"'+CLE1+'"'
Else
   CRITERE="1=1"
Endif

Call DEBTRANS From GLOCK
Raz COMPTEUR
Trbegin [CFB]
For [CFB] Where evalue (CRITERE)
    If fstat
        Call ECR_TRACE("File ITMBOMCFG, Error="-num$(fstat),1) From GESECRAN
    Else
        If [F:CFB]LLCTYP = 0
            WBOMALTTYP = 0
            For [F:TBO] Where BOMALT = [F:CFB]BOMALT
                WBOMALTTYP = [F:TBO]BOMALTTYP
                Break
            Next
            Case WBOMALTTYP
                When 2,3:      [F:CFB]LLCTYP = 2
                When Default:  [F:CFB]LLCTYP = 1
            Endcase
            Rewrite [CFB]
        Endif
    Endif
    COMPTEUR += 1

    If COMPTEUR > GMAXUPDTRS
       CLE1 = [F:CFB]ITMREF
       CLE2 = [F:CFB]BOMALT
       STOP =1
       Break
    Endif
Next
Commit

If STOP : Goto BOUCLE_CFB : Endif
Filter [CFB]
Close Local File [CFB]
Close Local File [TBO]

End

####################################################################################
Subprog UPDCBB(LDOS)
Value Char LDOS

# FQ 49666
If filinfo(filpath("FIL","CFGQST","fde",LDOS),0) <=0   End   Endif
If filinfo(filpath("FIL","CFGSHA","fde",LDOS),0) <=0   End   Endif

Local File =LDOS+".CBLOB"    [CBB]
Local File =LDOS+".CFGQST"   [CQU]
Local File =LDOS+".CFGSHA"   [CSH]

Local Integer LSTOP, LNB
Local Char ID1(GLONCQU), ID2(type([F:CSH]SHANUM)-10)  # FGR 09/10/2014 : X3SUIVI102999 manquait une longueur de chaÃŪne sur ID2

$LOOP_CQU
Raz LNB
If LSTOP=1
    Filter [CQU] Where QSTNUM>ID1
    LSTOP=0
Endif
Call DEBTRANS From GLOCK
Trbegin [CQU]
For [CQU]
    Raz [F:CBB]
    #Readlock [CBB]CBB0="CQU";[F:CQU]QSTNUM;""  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
    Read [CBB]CBB0="CQU";[F:CQU]QSTNUM;""  # FGR 11/03/2010 : X3SUIVI63191
    Case fstat
        When 0:
            [F:CBB]BLOB   = [F:CQU]CQUPIC
            Call REWCBB From TRTX3BLB
        When 5:
            [F:CBB]CODBLB = "CQU"
            [F:CBB]IDENT1 = [F:CQU]QSTNUM
            [F:CBB]TYPBLB = 3
            [F:CBB]BLOB   = [F:CQU]CQUPIC
            Call ECRCBB From TRTX3BLB
    Endcase
    If fstat
        Call ECR_TRACE("File CBLOB, Error="-num$(fstat)-"QSTNUM="+[F:CQU]QSTNUM,1) From GESECRAN
        GOK=0
        Break
    Endif
    ID1 = [F:CQU]QSTNUM
    LNB+=1
    If LNB>GMAXUPDTRS
        LSTOP=1
        Break
    Endif
Next
If GOK
    Commit
    If LSTOP
        Goto LOOP_CQU
    Endif
Else
    Rollback
Endif

Raz LSTOP, ID1, ID2

$LOOP_CSH
Raz LNB
If LSTOP=1
    Filter [CSH] Where SHACAT=ID1 & SHANUM>ID2
    LSTOP+=1
Elsif LSTOP=2
    Filter [CSH] Where SHACAT>ID1
    LSTOP=0
Endif
Call DEBTRANS From GLOCK
Trbegin [CSH]
For [CSH]
    Raz [F:CBB]
    #Readlock [CBB]CBB0="CSH";[F:CSH]SHACAT;[F:CSH]SHANUM  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
    Read [CBB]CBB0="CSH";[F:CSH]SHACAT;[F:CSH]SHANUM  # FGR 11/03/2010 : X3SUIVI63191
    Case fstat
        When 0:
            [F:CBB]BLOB   = [F:CSH]CSHPIC
            Call REWCBB From TRTX3BLB
        When 5:
            [F:CBB]CODBLB = "CSH"
            [F:CBB]IDENT1 = [F:CSH]SHACAT
            [F:CBB]IDENT2 = [F:CSH]SHANUM
            [F:CBB]TYPBLB = 3
            [F:CBB]BLOB   = [F:CSH]CSHPIC
            Call ECRCBB From TRTX3BLB
    Endcase
    If fstat
        Call ECR_TRACE("File CBLOB, Error="-num$(fstat)-"SHACAT="+[F:CSH]SHACAT-"SHANUM="+[F:CSH]SHANUM,1) From GESECRAN
        GOK=0
        Break
    Endif
    ID1 = [F:CSH]SHACAT
    ID2 = [F:CSH]SHANUM
    LNB+=1
    If LNB>GMAXUPDTRS
        LSTOP=1
        Break
    Endif
Next
If GOK
    Commit
    If LSTOP
        Goto LOOP_CSH
    Endif
Else
    Rollback
Endif

End


#################################################################################
# Met Ã  jour la table OVERHEAD
#################################################################################
# Le champ [OVE]VCRTRG est nouveau et doit ÃŠtre initialisÃĐ Ã  1 (document)
#################################################################################
Subprog UPDOVE(PDOS)
Value Char PDOS

Local Integer I
Local File =PDOS+".OVERHEAD"  [OVE]
Call DEBTRANS From GLOCK
Trbegin [OVE]

For [OVE]
    #Readlock [OVE] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
    For I=0 To dim([F:OVE]OVENAT)-1
        If [F:OVE]OVENAT(I)<>""
            If [F:OVE]FXDOVEA<>0
                [F:OVE]VCRTRG(I) = 2
            Else
                [F:OVE]VCRTRG(I) = 1
            Endif
        Endif
    Next
    Rewrite [OVE]
    If fstat
        Call FSTA("OVE") From GLOCK
        Break
    Endif
Next

Commit

End

#################################################################################
# Met Ã  jour la table OVENAT
#################################################################################
# Le champ [ONA]TYPCST est nouveau et doit ÃŠtre initialisÃĐ Ã  1 (matiÃĻre)
#################################################################################
Subprog UPDONA(PDOS)
Value Char PDOS

Local Integer WI
Local File =PDOS+".OVENAT"    [ONA]
#Local File =PDOS+".GDIE"    [DIE]
Local File =PDOS+".CADIEDEF"  [CDI]

Call DEBTRANS From GLOCK
Trbegin [ONA]
For [ONA]
    # Issue number - 2011-04-08 by CCC : comment
    #[F:ONA]TYPCST = 2    # Le fonctionnement 140 correspondait Ã  un type de coÃŧt matiÃĻre
    [F:ONA]TYPCST = 1
    #---- MÃ j section ana ----#
    Raz WI
    #For [DIE] DIE0
    #    If [F:ONA]DIE(I)=""  [F:ONA]DIE(I)=[F:DIE]DIE : Endif
    #    I+=1
    #    If dim([F:ONA]DIE)<=I   Break : Endif
    #Next
    Read [CDI]CDI0 = 6
        If !fstat
           For WI=0 To [F:CDI]NBRDIE-1
              If WI<dim([F:ONA]DIE)
                 If [F:ONA]DIE(WI)="" [F:ONA]DIE(WI)=[F:CDI]DIE(WI) : Endif
              Else
                 Break
              Endif
           Next
        Endif
    Rewrite [ONA]
    If fstat
        Call FSTA("ONA") From GLOCK
        Break
    Endif
Next
Commit

End

