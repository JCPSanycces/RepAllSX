If [F:ADS]MODULE(6) = 2
  NUMPROC += 1
  Call ECR_TIME("TRCMAJ30 TC Transactions Process "+num$(NUMPROC)+": Update CFGSCE") From DOSSUB
  Call UPDCSC([F:ADS]DOSSIER)
  If GOK<>1 : Onerrgo : End : Endif

  NUMPROC += 1
