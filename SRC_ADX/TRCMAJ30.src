Call ECR_TIME("DOSMAJ30 Replacing table MFCCLCPRN with MFCDETPRT") From DOSSUB

#Readlock [F:ATB]CODFIC="MFCCLCPRN"  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
Read [F:ATB]CODFIC="MFCCLCPRN"  # FGR 11/03/2010 : X3SUIVI63191
If !fstat
   If [F:ATB]ABRFIC="MCP" [F:ATB]ABRFIC = "MC2" Endif
   Rewrite [F:ATB]
   If fstat # Erreur en cas d'abrÃĐv existante => on supprime
      Delete [F:ATZ] Where CODFIC="MFCCLCPRN"
      Delete [F:ATI] Where CODFIC="MFCCLCPRN"
      Delete [F:ATB] Where CODFIC="MFCCLCPRN"
   Endif
Endif

End

