#########################################################################
# Transfert table TABEECSCH dans ATABDIV
#
# ATABTAB : CrÃĐation DÃĐfinition table diverse : CrÃĐation table nÂ° 15
# ATABDIV : Transfert des enregistrements de TABEECSCH vers ATABDIV
# ATEXTRA : CrÃĐation des textes traduisibles liÃĐs aux table ATABTAB et ATABDIV
#########################################################################
#
# Voir si cette moulinette se justifie et la tester
#
#########################################################################
Subprog AV_EECSCH

If filinfo(filpath("FIL","TABEECSCH","fde",[F:ADS]DOSSIER),0) <=0   End   Endif

Local Char SAVGLANGUE  (5)           : # sauvegarde de GLANGUE

Call ECR_TIME("DOSMAJ30 EEC Rule Process : Update ATABDIV") From DOSSUB

Local File =[F:ADS]DOSSIER+".TABEECSCH"  [TEE]
Local File =[F:ADS]DOSSIER+".ATABDIV"    [ADI]
Local File =[F:ADS]DOSSIER+".ATABTAB"    [ADV]
Local File =[F:ADS]DOSSIER+".ATABZON"    [ATZ]
Local File =[F:ADS]DOSSIER+".ATEXTE"     [ATX]
Local File =[F:ADS]DOSSIER+".ATEXTRA"    [AXX]

Trbegin [TEE]

# CrÃĐation DÃĐfinition table diverse no 15 dans ATABTAB
Delete [ADV] Where NUMTAB=15
Raz [ADV]
[F:ADV]NUMTAB=15    : [F:ADV]NUMCAR=num$(15) : [F:ADV]MODULE=9

[F:ADV]CODTYP3="M"  : [F:ADV]SUP3=num$(205)

#[F:ADV]DEPNUM=909 :# gÃĐrÃĐ diffÃĐremment
[F:ADV]UPDFLG=2     : [F:ADV]LNGFLG=1         : [F:ADV]LNG=3

[F:ADV]CREUSR=GUSER : [F:ADV]CREDAT=date$     : [F:ADV]CRETIM=time

Write [ADV]
If fstat Call ERREUR("ATABTAB"-num$([F:ADV]NUMTAB),1) From DOSDIC Endif

SAVLANGUE=GLANGUE

# CrÃĐation de ATEXTRA de ATABTAB pour la table diverse no 15
# RÃĐcupÃĐration du numÃĐro de texte associÃĐ Ã  l'intitulÃĐ du champs EECSCH de la table TABEECSCH dans ATABZON
Read [ATZ]NUMLIG="TABEECSCH";1;"EECSCH"
If fstat Call ERREUR("ATABZON"-"TABEECSCH"-num$(1)-"EECSCH",4) From DOSDIC Endif
# IntitulÃĐ normal
If [F:ATZ]NOCOURT<>0
    # RÃĐcupÃĐration dans ATEXTE du texte pour toutes les langues prÃĐsentes le dossier
    For [ATX] Where NUMERO=[F:ATZ]NOCOURT & TEXTE<>""
        GLANGUE=[F:ATX]LAN
        Call MAJTEXTRA ([F:ATX]TEXTE,"ATABTAB","LNGDES", "15","") From ATEXTRA
    Next
Endif
# IntitulÃĐ court
If [F:ATZ]NOABREG<>0
    # RÃĐcupÃĐration dans ATEXTE du texte pour toutes les langues prÃĐsentes le dossier
    For [ATX] Where NUMERO=[F:ATZ]NOABREG & TEXTE<>""
        GLANGUE=[F:ATX]LAN
        Call MAJTEXTRA ([F:ATX]TEXTE,"ATABTAB","SHODES", "15","") From ATEXTRA
    Next
Endif
# RÃĐcupÃĐration du numÃĐro de texte associÃĐ Ã  l'intitulÃĐ du champs SCHFLO de la table TABEECSCH dans ATABZON
Read [ATZ]NUMLIG="TABEECSCH";4;"SCHFLO"
If fstat Call ERREUR("ATABZON"-"TABEECSCH"-num$(4)-"SCHFLO",4) From DOSDIC Endif
If [F:ATZ]NOCOURT<>0
    # RÃĐcupÃĐration dans ATEXTE du texte pour toutes les langues prÃĐsentes le dossier
    For [ATX] Where NUMERO=[F:ATZ]NOCOURT & TEXTE<>""
        GLANGUE=[F:ATX]LAN
        Call MAJTEXTRA ([F:ATX]TEXTE,"ATABTAB","NUMDES1", "15","") From ATEXTRA
    Next
Endif

GLANGUE=[F:ADS]LANDEF

Call MAJTEXTRA ("","ATABTAB","ALPDES1","15","") From ATEXTRA
Call MAJTEXTRA ("","ATABTAB","ALPDES2","15","") From ATEXTRA
Call MAJTEXTRA ("","ATABTAB","NUMDES2","15","") From ATEXTRA

# Transfert des enregistrements de TABEECSCH vers ATABDIV
Local Integer NBENR
Raz NBENR

Delete [ADI] Where NUMTAB=15
For [TEE]
    Raz [F:ADI]
    [F:ADI]NUMTAB =15
    [F:ADI]CODE   =[F:TEE]EECSCH

    [F:ADI]N1     =[F:TEE]SCHFLO

    [F:ADI]CREUSR =[F:TEE]CREUSR : [F:ADI]CREDAT =[F:TEE]CREDAT : [F:ADI]CRETIM =time
    [F:ADI]UPDUSR =[F:TEE]UPDUSR : [F:ADI]UPDDAT =[F:TEE]UPDDAT : [F:ADI]UPDTIM =time
    #FQ 53139 - renseignement du code lÃĐgislation
    If [F:ADS]DOSLEG(0)<>"" and [F:ADI]LEG=""
      [F:ADI]LEG=[F:ADS]DOSLEG(0)
    Endif

    Write [ADI]
    NBENR+=1
    If fstat
       Call ERREUR("ATABDIV"-num$([F:ADI]NUMTAB)-"/"-[F:ADI]CODE,1) From DOSDIC
    Endif
    Call MAJTEXTRA ([F:TEE]SCHDES,"ATABDIV","LNGDES","15",[F:ADI]CODE) From ATEXTRA
    Call MAJTEXTRA ([F:TEE]SCHSHO,"ATABDIV","SHODES","15",[F:ADI]CODE) From ATEXTRA
Next

Commit

Call ECR_TRACE("DOSMAJ30 : Processed records number :"-num$(NBENR),0) From GESECRAN

Close Local File [TEE]
Close Local File [ADI]
Close Local File [ADV]
Close Local File [ATZ]
Close Local File [ATX]
Close Local File [AXX]

GLANGUE=SAVLANGUE
End
#########################################################################
## M.a.j. de DEB : DÃĐclaration d'ÃĐchange de biens
## - Ajout et init champ DEBLIN
#########################################################################
Subprog AV_DEB
#FQ 51628
If filinfo(filpath("FIL","DEB","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": DEB"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".DEB"   [DEB]

Local Integer WINOLIN :# compteur pour flux Introduction
Local Integer WENOLIN :# compteur pour flux ExpÃĐdition
#-- On ne fait rien si le nÂ° de ligne est renseignÃĐ
#MAE, bg 70161, le 23/12/2010, on met Ã  jour DEB uniquement si DEBLIN existe
If dim([F:DEB]DEBLIN)>0
    Filter [DEB] Where DEBLIN<>0
    If rowcount([DEB])>0
      Filter [F:DEB]
      End
    Endif
    Filter [F:DEB]

    For [DEB]DEB0(2)
      Trbegin [DEB]
      WINOLIN=1 : WENOLIN=1 :# La numÃĐrotation recommence Ã  1 Ã  chaque dÃĐclaration pour une sociÃĐtÃĐ et une date
      For [DEB]DEB0
        #Readlock [F:DEB] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
        #If fstat
        #  Call ERREUR("DEB"-[F:DEB]CPY-[F:DEB]DEBDAT-num$([F:DEB]FLO)-[F:DEB]VCRNUM-num$([F:DEB]VCRLIN),5) From DOSDIC
        #  Break
        #Endif
        If    [F:DEB]FLO=1  [F:DEB]DEBLIN=WINOLIN  : WINOLIN+=1
        Elsif [F:DEB]FLO=2  [F:DEB]DEBLIN=WENOLIN  : WENOLIN+=1
        Endif
        Rewrite [DEB]
        If fstat
          Call ERREUR("DEB"-[F:DEB]CPY-[F:DEB]DEBDAT-num$([F:DEB]FLO)-[F:DEB]VCRNUM-num$([F:DEB]VCRLIN),2) From DOSDIC
        Endif
      Next
      Commit
    Next
Endif
Close Local File [DEB]
End
#########################################################################
## M.a.j. de PRICSTRUCT : Structure tarif
## - Ajout et init champs FMTCOL
#########################################################################
Subprog AV_PRS

Local Integer I

If filinfo(filpath("FIL","PRICSTRUCT","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": PRICSTRUCT"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".PRICSTRUCT"   [PRS]
Trbegin [PRS]
#For [PRS]
For [PRS] Where BPCBPS=1
    For I=0 To 8
        If [F:PRS]INCDCR(I)=0 : Break : Endif

        If [F:PRS]VALTYP(I)=1
            If [F:PRS]FMTCOL(I)="" [F:PRS]FMTCOL(I)="[F:TCU]CURFMT2" Endif
        Else
            If [F:PRS]FMTCOL(I)="" [F:PRS]FMTCOL(I)="3.2#" Endif
        Endif
    Next
    Rewrite [PRS]
    If fstat Call ERREUR("PRICSTRUCT"-[F:PRS]PLISTC,2) From DOSDIC Endif
Next
Commit

End
#########################################################################
## M.a.j. de BETCPY / BETCPYL  : ParamÃĐtrage inter-sociÃĐtÃĐs
##   BETCPY    : Bascule de CPYSOHCAT dans GRPCPYTSO
##   BETCPYL   : Bascule de CPYORI    dans GRPCPYORI
##               Bascule de CPYDES    dans GRPCPYDES
#########################################################################
Subprog AV_BCH
If filinfo(filpath("FIL","BETCPY","fde",[F:ADS]DOSSIER),0)<=0    : End : Endif
If filinfo(filpath("FIL","BETCPYL","fde",[F:ADS]DOSSIER),0)<=0   : End : Endif

Call ECR_TRACE(mess(81,125,1)-": BETCPY"-time$,0)    From GESECRAN : # maj table
Call ECR_TRACE(mess(81,125,1)-": BETCPYL"-time$,0)   From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".BETCPY"     [BCH]
Local File =[F:ADS]DOSSIER+".BETCPYL"    [BCL]

Local Integer FLGREC
Local Integer LASTNUM
Local Integer SAVAUZBETFLG
Local Integer SAVVLTFOOINV


Trbegin [BCH]
  Read [BCH]BCH0="STD"
  If !fstat
#   --- m.a.j. BETCPY
    If dim([F:BCH]CPYSOHCAT)>0
      For I=0 To dim([F:BCH]SOHCAT)-1
        If [F:BCH]SOHCAT(I)=0 : Break : Endif
        [F:BCH]GRPCPYTSO(I)=[F:BCH]CPYSOHCAT(I)
      Next I
      Rewrite [BCH]
      If fstat
        Call ERREUR("BETCPY"-[F:BCH]CLE,2) From DOSDIC
      Endif
    Endif
#   --- m.a.j. BETCPYL
    If dim([F:BCL]CPYORI)>0 & dim([F:BCL]CPYDES)>0 & dim([F:BCL]FCYORI)>0 & dim([F:BCL]FCYDES)>0
      For [BCL] BCL0
        [F:BCL]GRPCPYORI=[F:BCL]CPYORI
        [F:BCL]GRPCPYDES=[F:BCL]CPYDES
        If [F:BCL]VCRTYP=14  : [F:BCL]VCRTYPDES=2   : Endif  : # cde achat --> cde vente
        If [F:BCL]VCRTYP=5   : [F:BCL]VCRTYPDES=17  : Endif  : # fac vente --> fac achat
        [F:BCL]GRPFCYORI=[F:BCL]FCYORI
        [F:BCL]GRPFCYDES=[F:BCL]FCYDES
        If [F:BCL]CPYORI<>""  [F:BCL]FLG1CPYORI=1  Else  [F:BCL]FLG1CPYORI=3  Endif
        If [F:BCL]FCYORI<>""  [F:BCL]FLG2FCYORI=1  Else  [F:BCL]FLG2FCYORI=3  Endif
        If [F:BCL]CPYDES<>""  [F:BCL]FLG3CPYDES=1  Else  [F:BCL]FLG3CPYDES=3  Endif
        If [F:BCL]FCYDES<>""  [F:BCL]FLG4FCYDES=1  Else  [F:BCL]FLG4FCYDES=3  Endif
        [F:BCL]FLG1234  = [F:BCL]FLG1CPYORI*1000
        [F:BCL]FLG1234 += [F:BCL]FLG2FCYORI*100
        [F:BCL]FLG1234 += [F:BCL]FLG3CPYDES*10
        [F:BCL]FLG1234 += [F:BCL]FLG4FCYDES
        [F:BCL]CRIBETCPY  = num$([F:BCL]TYPBET)+"~"
        [F:BCL]CRIBETCPY += vireblc([F:BCL]GRPCPYORI,2)+"~"
        [F:BCL]CRIBETCPY += vireblc([F:BCL]GRPFCYORI,2)+"~"
        [F:BCL]CRIBETCPY += num$([F:BCL]VCRTYP)+"~"
        [F:BCL]CRIBETCPY += vireblc([F:BCL]GRPCPYDES,2)+"~"
        [F:BCL]CRIBETCPY += vireblc([F:BCL]GRPFCYDES,2)
        Rewrite [BCL]
        If fstat
          Call ERREUR("BETCPYL"-num$([F:BCL]NUMERO),2) From DOSDIC
        Endif
        #--- si les champs des sociÃĐtÃĐs et sites sont vides et le type de piÃĻce d'origine est 'cde achat'
        #--- on crÃĐer une nouvelle ligne dans la table pour le cas 'intra-site'
        If [F:BCL]CPYORI="" & [F:BCL]FCYORI="" & [F:BCL]CPYDES="" & [F:BCL]FCYDES="" & [F:BCL]VCRTYP=14
           FLGREC=1
           SAVAUZBETFLG=[F:BCL]AUZBETFLG
           SAVVLTFOOINV=[F:BCL]VLTFOOINV
        Endif
      Next
    Endif
    #--- crÃĐation de la ligne
    If FLGREC
       #--- on retient le dernier NUMERO
       LASTNUM=[F:BCL]NUMERO
       Raz [F:BCL]
       [F:BCL]NUMERO=LASTNUM+1
       [F:BCL]TYPBET=1     :# 'Intra-sociÃĐtÃĐ'
       [F:BCL]VCRTYP=14    :# 'Cde achat'
       [F:BCL]VCRTYPDES=2  :# 'Cde vente'
       [F:BCL]AUZBETFLG=SAVAUZBETFLG :# autorisation
       [F:BCL]VLTFOOINV=SAVVLTFOOINV :# ÃĐlement de facture
       [F:BCL]FLG1CPYORI=3
       [F:BCL]FLG2FCYORI=3
       [F:BCL]FLG3CPYDES=3
       [F:BCL]FLG4FCYDES=3
       [F:BCL]FLG1234  = [F:BCL]FLG1CPYORI*1000
       [F:BCL]FLG1234 += [F:BCL]FLG2FCYORI*100
       [F:BCL]FLG1234 += [F:BCL]FLG3CPYDES*10
       [F:BCL]FLG1234 += [F:BCL]FLG4FCYDES
       [F:BCL]CRIBETCPY  = num$([F:BCL]TYPBET)+"~"
       [F:BCL]CRIBETCPY += vireblc([F:BCL]GRPCPYORI,2)+"~"
       [F:BCL]CRIBETCPY += vireblc([F:BCL]GRPFCYORI,2)+"~"
       [F:BCL]CRIBETCPY += num$([F:BCL]VCRTYP)+"~"
       [F:BCL]CRIBETCPY += vireblc([F:BCL]GRPCPYDES,2)+"~"
       [F:BCL]CRIBETCPY += vireblc([F:BCL]GRPFCYDES,2)
       Write [BCL]
       If fstat
          Call ERREUR("BETCPYL"-num$([F:BCL]NUMERO),2) From DOSDIC
       Endif
    Endif
  Endif
Commit

End

#################################################################################
# AbrÃĐviation [F:ICP] table V5 ITCCLCPRN => table V6 ITCDETPRT
# GA Mail MB 16/07/2008
#    - soit on met Ã  jour l'abrÃĐviation dans ATABLE
#    - soit on supprime l'ancienne table du dico ATABLE, ATABZON et ATABIND
#################################################################################
Subprog AV_ICP
If filinfo(filpath("FIL","ITCCLCPRN","fde",[F:ADS]DOSSIER),0) <=0   End   Endif
If clalev([F:ATB])=0 : Local File =[F:ADS]DOSSIER+".ATABLE"    [ATB] : Endif
If clalev([F:ATZ])=0 : Local File =[F:ADS]DOSSIER+".ATABZON"   [ATZ] : Endif
If clalev([F:ATI])=0 : Local File =[F:ADS]DOSSIER+".ATABIND"   [ATI] : Endif

Call ECR_TIME("DOSMAJ30 Replacing table ITCCLCPRN with ITCDETPRT") From DOSSUB

#Readlock [F:ATB]CODFIC="ITCCLCPRN"  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
Read [F:ATB]CODFIC="ITCCLCPRN"  # FGR 11/03/2010 : X3SUIVI63191
If !fstat
   If [F:ATB]ABRFIC="ICP" [F:ATB]ABRFIC = "IC2" Endif
   Rewrite [F:ATB]
   If fstat # Erreur en cas d'abrÃĐv existante => on supprime
      Delete [F:ATZ] Where CODFIC="ITCCLCPRN"
      Delete [F:ATI] Where CODFIC="ITCCLCPRN"
      Delete [F:ATB] Where CODFIC="ITCCLCPRN"
   Endif
Endif

End

