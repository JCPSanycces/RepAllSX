      Delete [F:ATI] Where CODFIC="MFGCOSTW"
      Delete [F:ATB] Where CODFIC="MFGCOSTW"
   Endif
Endif

End

#################################################################################
# Initialisation nouveau champ [F:TVM]NUM = 1   (Issue 78775)
#################################################################################
Subprog AV_TVM
If filinfo(filpath("FIL","TABCOSTMVT","fde",[F:ADS]DOSSIER),0) <=0   End   Endif
If clalev([F:TVM])=0 : Local File =[F:ADS]DOSSIER+".TABCOSTMVT"    [TVM] : Endif

Call ECR_TIME("DOSMAJ30 Init [F:TVM]NUM") From DOSSUB

Trbegin [TVM]
Update [TVM] Where NUM=0
&            With NUM=1
Commit
End

#-------------------------------------------------------------------------------#
#    ---> Concerne les scÃĐnarios configurateur CFGSCE                           #
#-------------------------------------------------------------------------------#
# Stockage de la position des champs BLONBR(I) et LINNBR(I)                     #
#-------------------------------------------------------------------------------#
Subprog AV_CSC(LDOS)                                   # FQ 52854 GA 26/02/2009 #
Value Char LDOS
If filinfo(filpath("FIL","CFGSCE","fde",LDOS),0) <=0   End   Endif
#-----
Local File =LDOS+".CFGSCE"  [CSC]
Local File =LDOS+".AMSK"    [AMK2]
Local File =LDOS+".AMSKZON" [AMZ2]
If dim([F:CSC]BLONBR)>0 & dim([F:CSC]LINNBR)>0
   For [F:CSC] Where QSTNUM(0)<>"" With Lock
      # M:modif, WUX:prefixe ecran, positions des blocs 1,2,3
      Call UPDATE_CSC_FROM_AMZ("MWUX234567") From CFGLIBE
      Rewrite [F:CSC]
   Next
Else
   Call ECR_TIME("DOSMAJ30 : Configurator scripts : not updated") From DOSSUB
Endif
Close Local File [CSC]
Close Local File [AMK2]
Close Local File [AMZ2]
End

#################################################################################
# Met Ã  jour les tables dont le(s) champ(s) dÃĐsignation sont devenus traduisibles
#################################################################################
# Tables mises Ã  jour:
#  - ITMCATEG
#  - OVENAT
#  - OVERHEAD
#  - TABCOSTMET
#  - TABLINCFG
#  - TABREOPOL
#  - TABSAFSTO
#  - TABSTASTO
#################################################################################
Subprog DES2AXX(PDOS)
Value Char PDOS
If filinfo(filpath("FIL","ATEXTRA","fde",PDOS),0)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": ATEXTRA"-time$,0) From GESECRAN : # maj table

Local File =PDOS+".ATEXTRA"   [AXX]

#----- Sauvegarde puis rÃĐcupÃĐration de la langue du dossier Ã  migrer -----#
Local Char SAV_GLANGUE(GLONLAN)
SAV_GLANGUE=GLANGUE
GLANGUE=[F:ADS]LANDEF

#------- ITMCATEG [ITG] : CatÃĐgories articles ---------------------
If filinfo(filpath("FIL","ITMCATEG","fde",PDOS),0)>0
   Local File =PDOS+".ITMCATEG"   [ITG]
   Trbegin [AXX]
     For [ITG]
         Call MAJTEXTRA ([F:ITG]TCLDES,"ITMCATEG","TCLAXX",[F:ITG]TCLCOD,"") From ATEXTRA
         Call MAJTEXTRA ([F:ITG]TCLSHO,"ITMCATEG","TCLSHOAXX",[F:ITG]TCLCOD,"") From ATEXTRA
     Next
   Commit
Endif

#------- OVENAT  [ONA] : Natures FG ---------------------
If filinfo(filpath("FIL","OVENAT","fde",PDOS),0)>0
   Local File =PDOS+".OVENAT"   [ONA]
   Trbegin [AXX]
     For [ONA]
         Call MAJTEXTRA ([F:ONA]ONADES,"OVENAT","ONAAXX",[F:ONA]OVENAT,"") From ATEXTRA
         Call MAJTEXTRA ([F:ONA]ONASHO,"OVENAT","ONASHOAXX",[F:ONA]OVENAT,"") From ATEXTRA
     Next
   Commit
Endif

#------- OVERHEAD  [OVE] : Frais gÃĐnÃĐraux ---------------------
If filinfo(filpath("FIL","OVERHEAD","fde",PDOS),0)>0
   Local File =PDOS+".OVERHEAD"   [OVE]
   Trbegin [AXX]
     For [OVE]
         Call MAJTEXTRA ([F:OVE]OVEDES,"OVERHEAD","OVEAXX",[F:OVE]OVECOD,"") From ATEXTRA
         Call MAJTEXTRA ([F:OVE]OVESHO,"OVERHEAD","OVESHOAXX",[F:OVE]OVECOD,"") From ATEXTRA
     Next
   Commit
Endif

#------- TABCOEFF  [TCO] : Conversions unitÃĐs ---------------------
If filinfo(filpath("FIL","TABCOEFF","fde",PDOS),0)>0
   Local File =PDOS+".TABCOEFF"   [TCO]
   Trbegin [AXX]
     If dim([F:TCO]COESHO)>0
         For [TCO]
             Call MAJTEXTRA ([F:TCO]COESHO,"TABCOEFF","COEAX1",[F:TCO]UOM1,[F:TCO]UOM2) From ATEXTRA
             Call MAJTEXTRA ([F:TCO]COEDES,"TABCOEFF","COEAX2",[F:TCO]UOM1,[F:TCO]UOM2) From ATEXTRA
         Next
     Endif
   Commit
Endif

#------- TABCOSTMET  [TCM] : MÃĐthodes de valorisation ---------------------
If filinfo(filpath("FIL","TABCOSTMET","fde",PDOS),0)>0
   Local File =PDOS+".TABCOSTMET"   [TCM]
   Trbegin [AXX]
     For [TCM]
         Call MAJTEXTRA ([F:TCM]TCMDES,"TABCOSTMET","TCMAXX",[F:TCM]VLTCOD,"") From ATEXTRA
         Call MAJTEXTRA ([F:TCM]TCMSHO,"TABCOSTMET","TCMSHOAXX",[F:TCM]VLTCOD,"") From ATEXTRA
     Next
   Commit
Endif

#------- TABLINCFG  [TLP] : Lignes de produit ---------------------
If filinfo(filpath("FIL","TABLINCFG","fde",PDOS),0)>0
   Local File =PDOS+".TABLINCFG"   [TLP]
   Trbegin [AXX]
     For [TLP]
         Call MAJTEXTRA ([F:TLP]CFGLINDES,"TABLINCFG","CFGLINAXX",[F:TLP]CFGLIN,"") From ATEXTRA
     Next
   Commit
Endif

#------- TABREOPOL  [TRP] : Politique rÃĐappro ---------------------
If filinfo(filpath("FIL","TABREOPOL","fde",PDOS),0)>0
   Local File =PDOS+".TABREOPOL"   [TRP]
   Trbegin [AXX]
     For [TRP]
         Call MAJTEXTRA ([F:TRP]TRPDES,"TABREOPOL","TRPAXX",[F:TRP]REOPOL,"") From ATEXTRA
         Call MAJTEXTRA ([F:TRP]TRPSHO,"TABREOPOL","TRPSHOAXX",[F:TRP]REOPOL,"") From ATEXTRA
     Next
   Commit
Endif

#------- TABSAFSTO  [TSA] : Coefficients stock sÃĐcuritÃĐ ---------------------
If filinfo(filpath("FIL","TABSAFSTO","fde",PDOS),0)>0
   Local File =PDOS+".TABSAFSTO"   [TSA]
   Trbegin [AXX]
     For [TSA]
         Call MAJTEXTRA ([F:TSA]SRVRATDES,"TABSAFSTO","SRVRATAXX",num$([F:TSA]SRVRAT),"") From ATEXTRA
     Next
   Commit
Endif

#------- TABSTASTO  [TST] : Statuts de stock ---------------------
If filinfo(filpath("FIL","TABSTASTO","fde",PDOS),0)>0
   Local File =PDOS+".TABSTASTO"   [TST]
   Trbegin [AXX]
     For [TST]
         Call MAJTEXTRA ([F:TST]STADES,"TABSTASTO","STAAXX",[F:TST]STASTO,"") From ATEXTRA
         Call MAJTEXTRA ([F:TST]STASHO,"TABSTASTO","STASHOAXX",[F:TST]STASTO,"") From ATEXTRA
     Next
   Commit
Endif

#----- Restitution du code langue de connexion -----#
GLANGUE=SAV_GLANGUE
End



###############################################################################
# STKITG_CLS : MAJ des catÃĐgories:
#             -eclatement de CLSTYP + initialisation de PCKSTKFLG
###############################################################################
# ParamÃĻtres E : LDOS   = Dossier
###############################################################################
Subprog STKITG_CLS(LDOS)
Value Char LDOS


Local File =LDOS+".ITMCATEG"   [ITG]
Local File =LDOS+".ITMMASTER"  [ITM]
Local File =LDOS+".BOMRET"     [BMR]
Local File =LDOS+".ITMFACILIT" [ITF]
Local File =LDOS+".ITMSALES"   [ITS]    #MAE, bg 69273
#
Local Integer CLSTYP_AV
Local Integer WRE
Raz WRE
#----          TC
#                                           ITMCATEG ----#
Call ECR_TRACE("Start trace : ITMCATEG / CLSTYP" ,0) From GESECRAN
Local Char WVEN(250)  # FGR 09/10/2014 : X3SUIVI102999 manquait une longueur de chaÃŪne
Call TEXTFIC("ITMCATEG","SALFLG",2,WVEN) From OBJDIV

Trbegin [ITG]
For [ITG]
    #Readlock [ITG] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
    #If !fstat
        [F:ITG]PCKSTKFLG = 1
        [F:ITG]PURFLG = 1
        [F:ITG]MFGFLG = 1
        [F:ITG]SCPFLG = 1
        [F:ITG]SCSFLG = 1
        [F:ITG]PHAFLG = 1
        [F:ITG]GENFLG = 1
        [F:ITG]TOOFLG = 1
        [F:ITG]DLVFLG = 1
        [F:ITG]INTFLG = 1
        CLSTYP_AV     = [F:ITG]CLSTYP
        If [F:ITG]SALFLG = 2
           [F:ITG]DLVFLG = 2
           # FQ 68830 GA 11/2010
           # ne pas perdre les catÃĐgories "article de sous-traitance" pb sur la GPAO/rcp sous-traitance
           #If [F:ITG]CLSTYP = 6               # Sous_traitance
           #   [F:ITG]CLSTYP = 1
           #Endif
           #If [F:ITG]CLSTYP = 8               # generique
           #   [F:ITG]CLSTYP = 1
           #Endif
           If [F:ITG]CLSTYP = 9               # Outillage
              [F:ITG]CLSTYP = 1
           Endif
           If CLSTYP_AV <> [F:ITG]CLSTYP
             Call ECR_TRACE([F:ITG]STOFCY-" "-[F:ITG]TCLCOD-" "-mess(125,188,1)-" : "-WVEN-" / "
&                          -mess(CLSTYP_AV,222,1) -mess(2,2333,1)
&                          -" ! -> "-mess(2,2359,1)-" : "-mess(1,222,1)-mess(254,184,1)-mess(CLSTYP_AV,222,1),-1)
&                 From GESECRAN
           Endif
        Endif
        Case [F:ITG]CLSTYP
             When 1 :
                [F:ITG]PURFLG = 2
             When 2 :
                [F:ITG]MFGFLG = 2
             When 3 :
                [F:ITG]PURFLG = 2
                [F:ITG]MFGFLG = 2
             When 4 :
                [F:ITG]PURFLG = 2
                [F:ITG]MFGFLG = 2
             When 5 :
                [F:ITG]SCPFLG = 2
             When 6 :
                [F:ITG]SCSFLG = 2
             When 7 :
                [F:ITG]PHAFLG = 2
             When 8 :
                [F:ITG]GENFLG = 2
             When 9 :
                [F:ITG]TOOFLG = 2
        Endcase
        If [F:ITG]SCSFLG = 2
           [F:ITG]PURFLG = 2
        Endif
        If [F:ITG]TOOFLG = 2
           [F:ITG]PURFLG = 2
        Endif
        If [F:ITG]GENFLG = 2
           [F:ITG]PURFLG = 2
           [F:ITG]MFGFLG = 2
        Endif
        If [F:ITG]PHAFLG = 2
           #MAE, bg 72794 [F:ITG]PURFLG = 2
           [F:ITG]MFGFLG = 2
        Endif
        If CLSTYP_AV <> [F:ITG]CLSTYP
           [F:ITG]CLSTYP  = CLSTYP_AV
        Endif
        Rewrite [ITG]
        WRE +=1
    #Endif
Next
Commit

#Local Integer LRET
# Mise Ã  jour de l'onglet sÃĐlection de l'objet ITG (mis dans : MAJ_AOBJLST)
#Call MAJ_SEL(LDOS,"ITG") From PATCHAOB
#Call VALID("ITG",LDOS,1,LRET) From VALOBJ
#Call VALID("OITG",LDOS,1,LRET) From VALWIN

Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),0) From GESECRAN

#----            TC                                                  ITMMASTER ----#
Call ECR_TRACE("Start trace : ITMMASTER / CLSTYP" ,0) From GESECRAN
Raz WRE

Trbegin [ITM]
For [ITM]
    #Readlock [ITM] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
    #If !fstat
        [F:ITM]EECGES = 2
        [F:ITM]DLU       = 1
        [F:ITM]SHLUOM    = 1
        [F:ITM]SHLLTIUOM = 1
        #---- CLSTYP ----#
        If [F:ITM]TCLCOD<>""
            Read [ITG]ITG1=[F:ITM]TCLCOD;""
            If !fstat
               [F:ITM]MFGFLG = [F:ITG]MFGFLG
               [F:ITM]SCPFLG = [F:ITG]SCPFLG
               [F:ITM]SCSFLG = [F:ITG]SCSFLG
               [F:ITM]PHAFLG = [F:ITG]PHAFLG
               [F:ITM]GENFLG = [F:ITG]GENFLG
               [F:ITM]TOOFLG = [F:ITG]TOOFLG
               [F:ITM]DLVFLG = [F:ITG]DLVFLG
               [F:ITM]PURFLG = [F:ITG]PURFLG
               [F:ITM]SALFLG = [F:ITG]SALFLG
               [F:ITM]INTFLG = [F:ITG]INTFLG
               If [F:ITM]CLSTYP <> [F:ITG]CLSTYP
                  Call ECR_TRACE([F:ITM]ITMREF-" "-[F:ITM]TCLCOD-" "-mess(252,184,1)
&                      -mess([F:ITM]CLSTYP,222,1)-mess(254,184,1)-mess([F:ITG]CLSTYP,222,1),-1) From GESECRAN
               Endif
# si livrable et unite de vente = "" alors unite de vente = unite de stock
               If [F:ITM]SAU        = ""
                  [F:ITM]SAU        = [F:ITM]STU
               Endif
               If [F:ITM]SAUSTUCOE  = 0
                  [F:ITM]SAUSTUCOE  = 1
               Endif

            Endif
        Endif
        Rewrite [ITM]
        #MAE, bg 69273, si DLVFLG = 2, on vÃĐrifie qu'il existe un ITMSALES, sinon, on le crÃĐÃĐ
        If [F:ITM]DLVFLG = 2
           Read [ITS]ITS0 = [F:ITM]ITMREF
           If fstat > 1
              #MISE Ã  jour table ITMSALES
              [F:ITS]       = [F:ITG]
              [F:ITS]       = [F:ITM]
              Write [ITS]
              Call ECR_TRACE([F:ITS]ITMREF-" "-mess(59,123,1)-" "-mess(16,752,1), -1) From GESECRAN
              If fstat
                Call FSTA("ITS") From GLOCK
                Break
              Endif
          Endif
        Endif
        WRE +=1
    #Endif
Next
Commit

Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),0) From GESECRAN
#----
Call ECR_TRACE("Start trace : ITMFACILIT / REOCOD/ CQ" ,0) From GESECRAN
Raz WRE

Trbegin [ITF]
For [ITF]
    #Readlock [ITF] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
    #If !fstat
        [F:ITF]DLU       = 1
        [F:ITF]SHLLTIUOM = 1
        #----                    REOCOD ----#
        If [F:ITF]REOCOD = 5 : [F:ITF]REOCOD = 4 : Endif
        [F:ITF]PCKSTKFLG = 1
        #----                    QUAFRY ----#
        [F:ITF]QUAFRY    = 1
        #----                    QUANUM ----#
        [F:ITF]QUANUM    = 0
        #----                    SMPTYP ----#
        [F:ITF]SMPTYP    = 1
        #----                    GENLEVINS ----#
        [F:ITF]GENLEVINS = 4
        #----                    NQA ----#
        [F:ITF]NQA       = 12
        #----                    SMPMOD ----#
        [F:ITF]SMPMOD    = 3
        # lecture itmmaster
        If [F:ITF]ITMREF <> [F:ITM]ITMREF
           Read [ITM]ITM0=[F:ITF]ITMREF
           If fstat
              Raz [F:ITM]
           Endif
        Endif
        #----                    QUAFLG ----#
        [F:ITF]QUAFLG    = [F:ITM]QUAFLG
        #----                    QLYCRD ----#
        [F:ITF]QLYCRD    = [F:ITM]QLYCRD
        #----                    QUAACS ----#
        [F:ITF]QUAACS    = [F:ITM]QUAACS
        Rewrite [ITF]
        WRE +=1
    #Endif
Next
Commit



Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),0) From GESECRAN
#----              TC                                                BOMRET ----#

Call ECR_TRACE("Start trace : BOMRET / CLSTYP" ,0) From GESECRAN
Raz WRE

Trbegin [BMR]
For [BMR]
    #Readlock [BMR] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
    #If !fstat
        #---- CLSTYP ----#
        If [F:BMR]ITMREF<>""
            Read [ITM]ITM0=[F:BMR]ITMREF
            If !fstat
               [F:BMR]MFGFLG = [F:ITM]MFGFLG
               [F:BMR]SCPFLG = [F:ITM]SCPFLG
               [F:BMR]SCSFLG = [F:ITM]SCSFLG
               [F:BMR]PHAFLG = [F:ITM]PHAFLG
               [F:BMR]GENFLG = [F:ITM]GENFLG
               [F:BMR]TOOFLG = [F:ITM]TOOFLG
               [F:BMR]DLVFLG = [F:ITM]DLVFLG
               [F:BMR]PURFLG = [F:ITM]PURFLG
               [F:BMR]SALFLG = [F:ITM]SALFLG
               [F:BMR]INTFLG = [F:ITM]INTFLG
               If [F:ITM]CLSTYP <> [F:BMR]CLSTYP
                  Call ECR_TRACE(num$([F:BMR]BMRUID)-" "-[F:BMR]ITMREF-" "-num$([F:BMR]NIV)-" "-mess(253,184,1)
&                   -mess([F:BMR]CLSTYP,222,1)-mess(254,184,1)-mess([F:ITM]CLSTYP,222,1),-1) From GESECRAN
               Endif
            Endif
        Endif
        Rewrite [BMR]
        WRE +=1
    #Endif
Next
Commit

Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),0) From GESECRAN


End


###############################################################################
# STKITG_PCK : MAJ  itmfacilit/catÃĐgories catÃĐgories/site
#             -Rajour rubrique PCK et PCKCAP
###############################################################################
# ParamÃĻtres E : LDOS   = Dossier
###############################################################################
Subprog STKITG_PCK(LDOS)
Value Char LDOS

Local File =LDOS+".ITMCATEG"   [ITG]
Local File =LDOS+".ITMSALES"   [ITS]
Local File =LDOS+".ITMFACILIT" [ITF]
Local File =LDOS+".ITMMASTER"  [ITM]
#

Local Integer WRE

#----                                                                ITMCATEG ----#

Call ECR_TRACE("Start trace : ITMFACILIT / PCK" ,0) From GESECRAN
Raz WRE

Trbegin [ITF]

Filter [ITS] Where PCK <> ""
&            Order By Key ITS0
For [ITS]
#----
    Filter [ITF] Where ITMREF = [F:ITS]ITMREF
&            Order By Key ITF0

    For [ITF]
        #Readlock [ITF] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
        #If !fstat
           [F:ITF]PCK    = [F:ITS]PCK
           [F:ITF]PCKCAP = [F:ITS]PCKCAP
           Rewrite [ITF]
           WRE +=1
        #Endif
    Next
    Filter [ITF]
Next
Filter [ITS]
Commit

Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),0) From GESECRAN

Local Char WTCLCOD(type([F:ITM]TCLCOD)-10)  # FGR 09/10/2014 : X3SUIVI102999 manquait une longueur de chaÃŪne
Raz WTCLCOD
Local Integer WOK
Raz WOK
Local Char WPCK(type([F:ITS]PCK)-10)  # FGR 09/10/2014 : X3SUIVI102999 manquait une longueur de chaÃŪne
Raz WPCK
Local Decimal WPCKCAP
Raz WPCKCAP

Call ECR_TRACE("Start trace : ITMCATEG / PCK" ,0) From GESECRAN
Trbegin [ITG]

Raz WRE
Link [ITM] With [ITS]ITS0=[F:ITM]ITMREF
&          As [ART]
&          Where [F:ITS]PCK <> ""
&          Order By Key CLE = TCLCOD
    For [ART]
        Read [ART] Curr
        If !fstat
           If WTCLCOD = ""
              WTCLCOD = [F:ITM]TCLCOD
              WPCK    = [F:ITS]PCK
              WPCKCAP = [F:ITS]PCKCAP
           Endif
           If WTCLCOD <> [F:ITM]TCLCOD
              If WOK = 0
                 #Readlock [ITG]ITG1=WTCLCOD;""  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
                 Read [ITG]ITG1=WTCLCOD;""  # FGR 11/03/2010 : X3SUIVI63191
                 If !fstat
                    If [F:ITG]SALFLG = 2 | [F:ITG]DLVFLG = 2
                       [F:ITG]PCK    = WPCK
                       [F:ITG]PCKCAP = WPCKCAP
                       Rewrite [ITG]
                       WRE +=1
                    Endif
                 Endif
              Endif
              WPCK    = [F:ITS]PCK
              WPCKCAP = [F:ITS]PCKCAP
              WTCLCOD = [F:ITM]TCLCOD
              WOK = 0
           Else
               If WPCK <>  [F:ITS]PCK
                  Raz WPCK
                  Raz WPCKCAP
                  WOK = 9
               Endif
               If WPCKCAP <>  [F:ITS]PCKCAP
                  Raz WPCKCAP
               Endif
           Endif
        Endif
    Next
    If WOK = 0
       #Readlock [ITG]ITG1=WTCLCOD;""  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
       Read [ITG]ITG1=WTCLCOD;""  # FGR 11/03/2010 : X3SUIVI63191
       If !fstat
          If [F:ITG]SALFLG = 2 | [F:ITG]DLFVLG = 2
             [F:ITG]PCK    = WPCK
             [F:ITG]PCKCAP = WPCKCAP
             Rewrite [ITG]
             WRE +=1
          Endif
       Endif
    Endif
    Filter [ART]
Commit
Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),0) From GESECRAN


Call ECR_TRACE("Start trace : ITMCATEG site  / PCK" ,0) From GESECRAN

Local File =LDOS+".ITMCATEG"   [ITG1]

Raz WRE

Trbegin [ITG]

Filter [ITG1] Where PCK <> ""
&             Order By Key ITG0
For [ITG1]
#----
    Filter [ITG] Where TCLCOD = [F:ITG1]TCLCOD &
&                      STOFCY <> ""
&                Order By Key ITG0

    For [ITG]
        #Readlock [ITG] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
        #If !fstat
           [F:ITG]PCK    = [F:ITG1]PCK
           [F:ITG]PCKCAP = [F:ITG1]PCKCAP
           Rewrite [ITG]
           WRE +=1
        #Endif
    Next
    Filter [ITG]
Next
Filter [ITG1]
Commit

Call ECR_TRACE(mess(104,141,1)-" : "-num$(WRE),0) From GESECRAN

End

# UUMGTRTSTO02
################################################################################
## UPDITC : Met Ã  jour les tables ITMCOST et ITCNAT    A faire avant mÃ j des clÃĐs
##          Met Ã  jour le type d'alternative
################################################################################
## ParamÃĻtres E : LDOS   = Dossier
################################################################################
#Subprog UPDITC(LDOS)
#Value Char LDOS
#
#Local File =LDOS+".FISCALYEAR"  [FIY]
#Local File =LDOS+".ITMCOST"     [ITC]
#Local File =LDOS+".ITMCOST"     [ITC2]
#Local File =LDOS+".ITCNAT"      [ICN]
#Local File =LDOS+".FACILITY"    [FCY]
#Local File =LDOS+".TABBOMALT"   [TBO]
#
#Local Char LFILT(250), REQ(250)(3)
#Local Integer LSTOP
#Local Char LFCY(GLONFCY), LITM(GLONITM)
#Local Integer LTYP, LYEA, LSEQ
#Local Integer LNB, LNBENR, LNBWRN
#Local Date LSTR, LEND
#Local Integer LITCSEQ
#
#Trbegin [ITC]
