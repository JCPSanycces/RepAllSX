#################################################################################
# Met Ã  jour le champ lÃĐgislation LEG dans les tables Tronc Commun              #
# et dans PARWIPACCS (Achats), PARSTOACC (Stocks), PARWIPACC (GPAO)             #
#################################################################################
Subprog UPDLEG(PDOS)
Value Char PDOS
Local Char WLEG(type([F:ADS]DOSLEG(0))-10)  # FGR 09/10/2014 : X3SUIVI102999 manquait une longueur de chaÃŪne

If [F:ADS]DOSLEG(0)="" End Endif
WLEG=[F:ADS]DOSLEG(0)

Local File =PDOS+".TABVAT"     [TVT]
Local File =PDOS+".TABVAC"     [TVC]
Local File =PDOS+".TABSIVTYP"  [TSV]
Local File =PDOS+".TABPIVTYP"  [TPV]
Local File =PDOS+".TABPAYTERM" [TPT]
Local File =PDOS+".TABDEPAGIO" [TDA]
#Local File =PDOS+".DEBREGNAT"  [DRN] # FGR 15/12/2009 : X3SUIVI60715 : Ne

Call DEBTRANS From GLOCK
Trbegin [TVT]
  Update [TVT] Where LEG="" With LEG=WLEG
Commit
Trbegin [TVC]
  Update [TVC] Where LEG="" With LEG=WLEG
Commit
Trbegin [TSV]
  Update [TSV] Where LEG="" With LEG=WLEG
Commit
Trbegin [TPV]
  Update [TPV] Where LEG="" With LEG=WLEG
Commit
Trbegin [TPT]
  Update [TPT] Where LEG="" With LEG=WLEG
Commit
Trbegin [TDA]
  Update [TDA] Where LEG="" With LEG=WLEG
Commit
#Trbegin [DRN]                                # FGR 15/12/2009 : X3SUIVI60715
#  Update [DRN] Where LEG="" With LEG=WLEG    # FGR 15/12/2009 : X3SUIVI60715
#Commit                                       # FGR 15/12/2009 : X3SUIVI60715

If [F:ADS]MODULE(5)=2
  Local File =PDOS+".PARWIPACCS" [SWA]
  Trbegin [SWA]
    Update [SWA] Where LEG="" With LEG=WLEG
  Commit
Endif

If [F:ADS]MODULE(6)=2
  Local File =PDOS+".PARSTOACC"  [PAS]
  Trbegin [PAS]
    Update [PAS] Where LEG="" With LEG=WLEG
  Commit
Endif

If [F:ADS]MODULE(7)=2
  Local File =PDOS+".PARWIPACC"  [PWA]
  Trbegin [PWA]
    Update [PWA] Where LEG="" With LEG=WLEG
  Commit
Endif

End

#################################################################################
# Moulinette : Structure dÃĐfinitive des tables                                  #
