    Else
        Read [F:TBO]TBO2(1) =  [F:BMR]BOMALT
        If !fstat : [F:BMR]BOMALTTYP = [F:TBO]BOMALTTYP : Endif
        Rewrite [BMR]
    Endif
    COMPTEUR += 1

    If COMPTEUR > GMAXUPDTRS
       CLE1 = [F:BMR]BMRUID
       CLE2 = [F:BMR]ITMREF
       CLE3 = [F:BMR]NIV
       STOP =1
       Break
    Endif
Next
Commit

If STOP : Goto BOUCLE_BMR : Endif
Filter [BMR]
Close Local File [BMR]
Close Local File [TBO]

Gosub UNSET_FIRST From TRTFIRST

End

