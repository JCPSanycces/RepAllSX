Subprog TRCMAJ30

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("DOSMAJ30 : Process for common data") From LECFIC
    WOUV_TRACE=1
Endif

Local Integer NUMPROC
Raz NUMPROC

Onerrgo TRT_ERR

#-----
Call AP_ADI : # table divers no 6
Call AP_MVC From TRC1MAJ30 : # Mvts clients
Call AP_MVS From TRC1MAJ30 : # Mvts fournisseurs

#---- VÃĐrification clÃĐ d'accÃĻs Ã  TBO dans ATZ -----#
NUMPROC += 1
Call ECR_TIME("TRCMAJ30 TC Transactions Process "+num$(NUMPROC)+": Update ATZ (TBO link)") From DOSSUB
Call UPDATZTBO([F:ADS]DOSSIER)
If GOK<>1 : Onerrgo : End : Endif

