#-------------------------------------------------------#
# Mise Ã  jour de l'onglet sÃĐlection des objets modifiÃĐs #
#-------------------------------------------------------#
$MAJ_AOBJLST
#-----
Local File =[F:ADS]DOSSIER+".AOBJLST" [AOL]
Local File =[F:ADS]DOSREF +".AOBJLST" [AOL2]
#-----
Local Char    WOBJET(GLONAOB)
Local Integer WNBR
#-----
Call ECR_TIME("TRCMAJ30 Object Lists Process : Update AOBJLST") From DOSSUB
#-----
Raz WNBR
Trbegin [AOL]
  For WOBJET="TVC","TUN","TDA","TSO","TSV","TPV","SPR","PPR","SPC","SPP","PPC","TVT",
&            "INO","ITG","ONA","OVE","TCO","TCM","TLP","TRP","TST","PAS","PWA","DRN",
&            "TPT","PTA","PTD","PTE","PTC","PTT","PTR","PTN","PTF","SLQ","SLC","SLO",
&            "SLD","SLI","SLA","SLR","SLL","SLS","SRT","SOT","PRE","PRT","SPK","SCT",
&            "SRG","SRO","PBY","SQT","SLT","SNP","CBA","CMD","CMS","CMI","CMA","MFL",
&            "MTL","MGL","MDL","MRL","MOL","MML","MIL","MWL","MRE","MCL","MPL","BCG",
&            "BSG","TPM","HIC","HCL","PIH"
    Read [AOL] AOL0=WOBJET
    If !fstat
      Read [AOL2] AOL0=WOBJET
      If !fstat
        [F:AOL]=[F:AOL2]
        Rewrite [AOL]
        If fstat
          Call ECR_TRACE("File AOBJLST"-WOBJET+", Error ="-num$(fstat),1) From GESECRAN
        Else
          WNBR+=1
        Endif
      Endif
    Endif
  Next WOBJET
Commit
#-----
Close Local File [AOL], [AOL2]
Call ECR_TIME("TRCMAJ30 Object Lists Process : Ended ("+num$(WNBR)+")") From DOSSUB
Return ### FGR 08/07/2009 : X3SUIVI56335 End


#########################################################################################
# Modification libellÃĐ tables diverse 6 et 15                  hcb 59154
#########################################################################################
Subprog ATEXTRA

Local File =[F:ADS]DOSSIER+".ATEXTRA" [MAXX] , =[F:ADS]DOSCOP+".ATEXTRA" [CAXX]

# RÃĐcupÃĐrer le texte du "ParamÃĻtrage de la table diverse"  6
#   V5 : "Nature transaction CEE"
#   V6 : "Nature transaction DEB"

Call ECR_TIME(mess(81,125,1)-": ATEXTRA-ATABTAB-6") From DOSSUB : # maj table
Trbegin [MAXX]
For [MAXX]AXX0 Where CODFIC="ATABTAB" & ZONE="LNGDES" & IDENT1="6"
    Read [CAXX]AXX0 = "ATABTAB";"LNGDES";[F:MAXX]LANGUE;"6";""
    If !fstat
       [F:MAXX]TEXTE =   [F:CAXX]TEXTE
       Rewrite [MAXX]
       If fstat
          Call ERREUR("ATEXTRA"-"ADI-LNGDES-6",2) From DOSDIC
       Endif
    Endif
Next
For [MAXX]AXX0 Where CODFIC="ATABTAB" & ZONE="SHODES" & IDENT1="6"
    Read [CAXX]AXX0 = "ATABTAB";"SHODES";[F:MAXX]LANGUE;"6";""
    If !fstat
       [F:MAXX]TEXTE =   [F:CAXX]TEXTE
       Rewrite [MAXX]
       If fstat
          Call ERREUR("ATEXTRA"-"ADI-SHODES-6",2) From DOSDIC
       Endif
    Endif
Next
Commit

# RÃĐcupÃĐrer le texte du "ParamÃĻtrage de la table diverse"  15
#   V6 : "Regime CEE " par "Regimes statistiques DEB"

Call ECR_TIME(mess(81,125,1)-": ATEXTRA-ATABTAB-15") From DOSSUB : # maj table
Trbegin [MAXX]
For [MAXX]AXX0 Where CODFIC="ATABTAB" & ZONE="LNGDES" & IDENT1="15"
    Read [CAXX]AXX0 = "ATABTAB";"LNGDES";[F:MAXX]LANGUE;"15";""
    If !fstat
       [F:MAXX]TEXTE =   [F:CAXX]TEXTE
       Rewrite [MAXX]
       If fstat
          Call ERREUR("ATEXTRA"-"ADI-LNGDES-15",2) From DOSDIC
       Endif
    Endif
Next
For [MAXX]AXX0 Where CODFIC="ATABTAB" & ZONE="SHODES" & IDENT1="15"
    Read [CAXX]AXX0 = "ATABTAB";"SHODES";[F:MAXX]LANGUE;"15";""
    If !fstat
       [F:MAXX]TEXTE =   [F:CAXX]TEXTE
       Rewrite [MAXX]
       If fstat
          Call ERREUR("ATEXTRA"-"ADI-SHODES-15",2) From DOSDIC
       Endif
    Endif
Next
Commit

Close Local File [MAXX] , [CAXX]

End

#################################################################
# DEL_TAB : vide le contenu d'une table
#################################################################
Subprog DEL_TAB(PDOS,PTABLE)
Value Char PDOS
Value Char PTABLE

Local Char REQTSQL(250)

  If filinfo(filpath("FIL",PTABLE,"fde",PDOS),0) <=0   End   Endif

  Local File =PDOS+"."+PTABLE [TAB]

  Trbegin [TAB]

  Onerrgo ERR_TR_SQL

  Call ECR_TRACE("Delete table : "+PTABLE,0) From GESECRAN

  REQTSQL(0)="TRUNCATE TABLE "-PDOS+"."+PTABLE
  Execsql From num$(GTYPDBA*2+1) Sql REQTSQL

  Onerrgo

  Commit
End

$ERR_TR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Call ECR_TRACE(REQTSQL,1) From GESECRAN
GOK=0
Resume

#MAE, bg 85213
#################################################################################
# Met Ã  jour la table ITMCATEG
#################################################################################
Subprog UPDITG(PDOS)
Value Char PDOS

Local Integer I
Local Integer WI
Local File =PDOS+".ITMCATEG" [ITG]
Local File =PDOS+".GDIE"    [DIE]
Local File =PDOS+".CADIEDEF" [CDI]

#Lecture de la table CADIEDEF
Local Integer NBCDI : NBCDI=nbrecord([CDI])
Local Char WDIE(GLONDIE)(0..20)
Local Integer WNBRDIE
Local Integer WI

Raz WI
Read [CDI]CDI0 = 1
  If !fstat
    WNBRDIE = [F:CDI]NBRDIE
    For WI=0 To [F:CDI]NBRDIE-1
      WDIE(WI)=[F:CDI]DIE(WI)
    Next
  Endif

Call DEBTRANS From GLOCK
Trbegin [ITG]
For [ITG]
   #Mise Ã  jour des sections analytiques
  Raz WI
  For WI=0 To WNBRDIE-1
    If WI<dim([F:ITG]DIE)
       If [F:ITG]DIE(WI)=""  [F:ITG]DIE(WI)=WDIE(WI) : Endif
  Else
    Break
  Endif
  Next
  Rewrite [ITG]
  If fstat
     Call FSTA("ITG") From GLOCK
     Break
  Endif
Next
Commit
End
