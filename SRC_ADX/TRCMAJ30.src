####################################################################################
Subprog UPDCHH(LDOS)
Value Char LDOS   # FGR 01/02/2010 : X3SUIVI60986

# FQ 49731
If filinfo(filpath("FIL","CFGHISHEA","fde",LDOS),0) <=0   End   Endif

Local File =LDOS+".CFGHISHEA"   [CHH]
Local File =LDOS+".TABBOMALT"   [TBO]
Local Integer  COMPTEUR, STOP
Local Char     CLE1(GLONVCR),CLE3(GLONVCR),CRITERE(250)
Local Integer  CLE2, CLE4, CLE5

Gosub SET_FIRST From TRTFIRST

Raz CLE1, CLE2 , CLE3 , CLE4, STOP
$BOUCLE_CHH
If STOP=1
   STOP=0 : CRITERE='CFGVCRNUM >"'+CLE1+'"'
Else
   CRITERE="1=1"
Endif
CRITERE += " & BOMALT <> 0"
CRITERE += " & BOMALTTYP=0"

Call DEBTRANS From GLOCK
Raz COMPTEUR
Trbegin [CHH]
For [CHH]CHH0 Where evalue (CRITERE)
    If fstat
        Call ECR_TRACE("File CGHHISHEA, Error="-num$(fstat),1) From GESECRAN
    Else
        Read [F:TBO]TBO2(1) =  [F:CHH]BOMALT
        If !fstat : [F:CHH]BOMALTTYP = [F:TBO]BOMALTTYP : Endif
        Rewrite [CHH]
    Endif
    COMPTEUR += 1

    If COMPTEUR > GMAXUPDTRS
       CLE1 = [F:CHH]CFGVCRNUM
       STOP =1
       Break
    Endif
Next
Commit

If STOP : Goto BOUCLE_CHH : Endif
Filter [CHH]
Close Local File [CHH]
Close Local File [TBO]

Gosub UNSET_FIRST From TRTFIRST

End

####################################################################################
Subprog UPDCSC(LDOS)
Value Char LDOS

# FQ 49731
If filinfo(filpath("FIL","CFGSCE","fde",LDOS),0) <=0   End   Endif

Local File =LDOS+".CFGSCE"      [CSC]
Local File =LDOS+".TABBOMALT"   [TBO]
Local Integer  COMPTEUR, STOP
