#NUMPROC += 1
#Call ECR_TIME("DOSMAJ30 TC Transactions Process "+num$(NUMPROC)+": Update BPCUSTOMER") From DOSSUB
#Call UPDBPC([F:ADS]DOSSIER)
#If GOK<>1 : Onerrgo : End : Endif
