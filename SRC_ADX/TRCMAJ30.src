        If fstat
          Call ECR_TRACE("File HDKTRS"-num$([F:HTR]HTRTYP)-[F:HTR]HTRNUM+", Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
      [L]WNBR+=1
    Next
  Commit
  Close Local File [HTR]
  Call ECR_TIME("DOSMAJ30 Update ATEXTRA for CRM transactions : Ended ("+num$([L]WNBR)+")") From DOSSUB
Endif

#------- MFGTRS     [MTS] : Transactions de saisie module GPAO --------
If filinfo(filpath("FIL","MFGTRS","fde",[F:ADS]DOSSIER),0)>0
  Local File =[F:ADS]DOSSIER+".MFGTRS"   [MTS]
  Local Integer WNBR : Raz [L]WNBR
  Trbegin [AXX], [MTS]
    For [MTS] MTS0
      If !instr(1,[F:MTS]MTSDES,"~")
        #Readlock [MTS] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
        #If fstat
        #  Call ECR_TRACE("File MFGTRS"-num$([F:MTS]MTSTYP)-[F:MTS]MTSNUM+", Error ="-num$(fstat),1) From GESECRAN
        #Else
          Call MAJTEXTRA ([F:MTS]MTSDES,"MFGTRS","DESAXX",num$([F:MTS]MTSTYP),[F:MTS]MTSNUM) From ATEXTRA
          If GOK<1
            Call ECR_TRACE("File ATEXTRA"-"MFGTRS DESAXX"-num$([F:MTS]MTSTYP)-[F:MTS]MTSNUM+
&                          ",Error ="-num$(fstat),1) From GESECRAN
            GOK=1 : Break
          Endif
        #Endif
        [F:MTS]MTSDES=GLANGUE+"~"+[F:MTS]MTSDES
        If dim([F:MTS]MTSTYPCAR)>0  [F:MTS]MTSTYPCAR=num$([F:MTS]MTSTYP) : Endif
        Rewrite [MTS]
        If fstat
          Call ECR_TRACE("File MFGTRS"-num$([F:MTS]MTSTYP)-[F:MTS]MTSNUM+", Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
      [L]WNBR+=1
    Next
  Commit
  Close Local File [MTS]
  Call ECR_TIME("DOSMAJ30 Update ATEXTRA for manufacturing transactions : Ended ("+num$([L]WNBR)+")") From DOSSUB
Endif

#------- BENCHTRS     [BTS] : Transactions de saisie des plans --------
If filinfo(filpath("FIL","BENCHTRS","fde",[F:ADS]DOSSIER),0)>0
  Local File =[F:ADS]DOSSIER+".BENCHTRS"   [BTS]
  Local Integer WNBR : Raz [L]WNBR
  Trbegin [AXX], [BTS]
    For [BTS] BTS0
      If !instr(1,[F:BTS]BTSDES,"~")
        #Readlock [BTS] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
        #If fstat
        #  Call ECR_TRACE("File BENCHTRS"-num$([F:BTS]BTSTYP)-[F:BTS]BTSNUM+", Error ="-num$(fstat),1) From GESECRAN
        #Else
          Call MAJTEXTRA ([F:BTS]BTSDES,"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
          If GOK<1
            Call ECR_TRACE("File ATEXTRA"-"BENCHTRS DESAXX"-num$([F:BTS]BTSTYP)-[F:BTS]BTSNUM+
&                          ",Error ="-num$(fstat),1) From GESECRAN
            GOK=1 : Break
          Endif
        #Endif
        [F:BTS]BTSDES=GLANGUE+"~"+[F:BTS]BTSDES
        If dim([F:BTS]BTSTYPCAR)>0  [F:BTS]BTSTYPCAR=num$([F:BTS]BTSTYP) : Endif
        Rewrite [BTS]
        If fstat
          Call ECR_TRACE("File BENCHTRS"-num$([F:BTS]BTSTYP)-[F:BTS]BTSNUM+", Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
      [L]WNBR+=1
    Next
  Commit
  Close Local File [BTS]
  Call ECR_TIME("DOSMAJ30 Update ATEXTRA for plan transactions : Ended ("+num$([L]WNBR)+")") From DOSSUB
Endif
#------- ITMCUSNOM     [INO] : Nomenclature CEE ---------------------------------------
If filinfo(filpath("FIL","ITMCUSNOM","fde",[F:ADS]DOSSIER),0)>0
  Local File =[F:ADS]DOSSIER+".ITMCUSNOM"   [INO]
  For [INO]
    #---La transaction est gÃĐrÃĐe dans le ATEXTRA
    Call MAJTEXTRA([F:INO]ITMCUSDES,"ITMCUSNOM","DESAXX",[F:INO]ITMNOM,"") From ATEXTRA
    If GOK<1
      Call ECR_TRACE("File ATEXTRA"-"ITMCUSNOM DESAXX"-[F:INO]ITMNOM+
&                    ",Error ="-num$(fstat),1) From GESECRAN
      GOK=1 : Break
    Endif
  Next
  Close Local File [INO]
  Call ECR_TIME("DOSMAJ30 Update ATEXTRA for CEE Commodity Code : Ended ("+num$([L]WNBR)+")") From DOSSUB
Endif

#------- SINCENT  [SNE] : RÃĐvision tarifs ventes ------------------
If filinfo(filpath("FIL","SINCENT","fde",[F:ADS]DOSSIER),0)>0
   Local File =[F:ADS]DOSSIER+".SINCENT"   [SNE]
   Local Integer I
   Trbegin [SNE]
     For [SNE]
         Call MAJTEXTRA ([F:SNE]DES,"SINCENT","DESAXX",[F:SNE]COD,"") From ATEXTRA
         If dim([F:SNE]LANDESSHO)>0
            [F:SNE]LANDESSHO=GLANGUE+"~"+[F:SNE]DES
         Endif

         For I = 0 To dim ( [F:SNE]VARDES ) -1
            Call MAJTEXTRA ([F:SNE]VARDES(I),"SINCENT","VARDESAXX",[F:SNE]COD,[F:SNE]VARCOD(I)) From ATEXTRA
         Next I

         Rewrite [SNE]
         If fstat
            Call ERREUR("SINCENT"-[F:SNE]COD,2) From DOSDIC
         Endif
     Next
   Commit
Endif

#------- SINCDET  [SND] : RÃĐvision tarifs ventes ------------------
If filinfo(filpath("FIL","SINCDET","fde",[F:ADS]DOSSIER),0)>0
   Local File =[F:ADS]DOSSIER+".SINCDET"   [SND]
   Trbegin [SND]
     For [SND]
         Call MAJTEXTRA ([F:SND]DESDET,"SINCDET","DESAXX",[F:SND]COD,[F:SND]CODLINCAR) From ATEXTRA
         If dim([F:SND]LANDESSHO)>0
            [F:SND]LANDESSHO=GLANGUE+"~"+[F:SND]DESDET
         Endif
         Rewrite [SND]
         If fstat
            Call ERREUR("SINCDET"-[F:SND]COD,2) From DOSDIC
         Endif
     Next
   Commit
Endif
#----- Divers transferts dans ATEXTRA
Gosub MAJ_AXX From TRCMAJ30AXX

#----- Restitution du code langue de connexion -----#
GLANGUE=SAV_GLANGUE
End

#################################################################################
# M.a.j. de CONTACTCRM              : Interlocuteurs
#
# - Init CNTFBDMAG : Interdit mailing : InitialisÃĐ Ã  1=Non
# FGR 11/06/2008 : X3SUIVI46709
#################################################################################
Subprog AV_AIN
  If filinfo(filpath("FIL","CONTACTCRM","fde",[F:ADS]DOSSIER),0) <=0   End   Endif
  Call ECR_TIME("DOSMAJ30 Interlocuteurs : Update CONTACTCRM") From DOSSUB
  Local File =[F:ADS]DOSSIER+".CONTACTCRM" [AIN]

Local Integer NBENR
Local Integer COMPTEUR, STOP, MODIF
Local Char    CLE1 (20)
Local Char    CRITERE (90)

  Raz CLE1
  Raz NBENR
$BOUCLE_AIN
  If STOP = 1 Then
    CRITERE = 'CNTNUM>"'+CLE1+'"'
    STOP = 0
  Else
    CRITERE = "1=1"
  Endif
  Raz COMPTEUR
  Trbegin [AIN]
  # Note FGR : Je complÃĻte la condition avec "and ([F:AIN]CNTFBDMAG = 0)" pour optimiser si c'est relancÃĐ.
  #            Dans la boucle je test aussi "[F:AIN]CNTFBDMAG = 0". Comme Ã§a si une nouvelle rubrique est
  #            ajoutÃĐe il suffira d'enlever le critÃĻre sur le For.
  For [AIN]AIN0 Where evalue(CRITERE) and ([F:AIN]CNTFBDMAG = 0)
    MODIF = 0
    If [F:AIN]CNTFBDMAG = 0 Then
      [F:AIN]CNTFBDMAG = 1 # Par dÃĐfaut vaut 1:NON accepte de recevoir les mailings
      MODIF = 1
    Endif
    #
    If MODIF = 1 Then
      Rewrite [AIN]
      NBENR += 1
      If fstat Then
        Call ECR_TRACE("File CONTACTCRM, Error ="-num$(fstat),1) From GESECRAN
      Else
        COMPTEUR += 1
        If COMPTEUR > GMAXUPDTRS Then
          CLE1 = [F:AIN]CNTNUM
          STOP = 1
          Break
        Endif
      Endif
    Endif
  Next
  Commit
  If STOP Then
    Goto BOUCLE_AIN
  Endif
  Call ECR_TRACE("DOSMAJ30 : Processed records number :"-num$(NBENR),0) From GESECRAN
  Close Local File [AIN]
End

