# ----------------------------------------------------------------------------- #
# TRCMAJ30 : M.a.j Ã  effectuer lors du passage Ã  version 6  Module Tronc commun #
# ----------------------------------------------------------------------------- #
# Rectification du dictionnaire : ADICMAJ30                                     #
#   - Tables remplacÃĐes avec mÃŠme abrÃĐviation en V6                             #
#           [F:ICP] table V5 ITCCLCPRN => table V6 ITCDETPRT                    #
#           [F:MCP] table V5 MFCCLCPRN => table V6 MFCDETPRT                    #
#           [F:MCW] table V5 MFGCOSTW  => table V6 MFCWST                       #
#                                                                               #
# Avant mise Ã  jour : ATRCMAJ30                                                 #
#                                                                               #
#   - Table BPCUSTOMER : Client                                                 #
#           Init BPAPYR BPCRSK                                                  #
#           Init CUR BPAADD CNTNAM                                              #
#           Init BPDADD                                                         #
#   - Table BPDLVCUST  : Client livrÃĐ                                           #
#           Init ENAFLG                                                         #
#   - Table BPCARRIER  : Transporteurs                                          #
#           Init CUR,BPAADD,CNTNAM                                              #
#   - Table SALESREP   : ReprÃĐsentants                                          #
#           Init CUR,BPAADD                                                     #
#   - Table TABEECSCH : RÃĐgimes CEE : TransformÃĐe en table diverse              #
#           CrÃĐation DÃĐfinition table diverse : CrÃĐation table nÂ° 15            #
#           Bascule de la table TABEECSCH dans ATABDIV                          #
#           CrÃĐation des textes traduisibles liÃĐs aux table ATABTAB et ATABDIV  #
#   - Table SPRICSTRUCT : ElÃĐments de facturation vente                         #
#           Init. FMTCOL                                                        #
#   - Table BETCPY / BETCPYL  : ParamÃĐtrage inter-sociÃĐtÃĐs                      #
#           BETCPY    : Bascule de CPYSOHCAT dans GRPCPYTSO                     #
#           BETCPYL   : Bascule de CPYORI    dans GRPCPYORI                     #
#                       Bascule de CPYDES    dans GRPCPYDES                     #
#                       Bascule de FCYORI    dans GRPFCYORI                     #
#                       Bascule de FCYDES    dans GRPFCYDES                     #
#   - Table BPCUSTMVT  : Mouvements clients                                     #
#           BPCRSK : Tiers risque : Client facture                              #
#           CPY    : SociÃĐtÃĐ      : SociÃĐtÃĐ de FINRSPFCY                        #
#           CUR    : Devise       : ACCCUR                                      #
#           Bascule Mnts devise transaction : Ex : ORDBPCNOT vers ORDBPCNOTC    #
#           Init Mnts devise sociÃĐtÃĐ                                            #
#           Init Mnts devise dossier                                            #
#           Bascule LASDOCNUM, LASDOCDAT, LASDOCAMT dans nvelle table LASTCUSMVT#
#   - Table LASTCUSMVT : Derniers mvts clients                                  #
#           Init Enr. Dernier devis      : LASDOCXXX(0)                         #
#           Init Enr. DerniÃĻre commande  : LASDOCXXX(1)                         #
#           Init Enr. DerniÃĻre livraison : LASDOCXXX(2)                         #
#           Init Enr. DerniÃĻre facture   : LASDOCXXX(3)                         #
#           Init Enr. Dernier rÃĻglement  : LASDOCXXX(4)                         #
#           Init Enr. Dernier impayÃĐ     : LASDOCXXX(5)                         #
#   - Table BPSUPPMVT - Mouvements fournisseurs  :                              #
#           BPSRSK    Tiers risque                                              #
#           CPY       SociÃĐtÃĐ                                                   #
#           CUR       Devise transaction                                        #
#           Eclatement des montants en devises transaction, sociÃĐtÃĐ et          #
#           dossier avec en plus pour les commandes et rÃĐceptions les           #
#           montants HT et TTC                                                  #
#   - Table LASTSUPMVT - Derniers mvts fournisseurs                             #
#           Alimentation de cette nouvelle table                                #
#   - Table CFGSCE : ScÃĐnario configurateur                            FQ 52854 #
#                                                                               #
#################################################################################
#                                                                               #
#   - DES2AXX  : Remplacement des textes de dÃĐsignation par des textes traduits #
#   - STKITG   : Init des nouvelles rÃĻgles d'allocation dans les catÃĐgories     #
#   - UPDITC   : Met Ã  jour les tables ITMCOST et ITCNAT                        #
#   - UPDBOD   : Met Ã  jour la table BOMD                                       #
#   - UPDITB   : Mise Ã  jour ITMBOM                                             #
#   - UPDCFB   : Mise Ã  jour ITMBOMCFG                                          #
#   - UPDCBB   : Utilisation de la nouvelle table CBLOB                         #
#   - UPDOVE   : Met Ã  jour la table OVERHEAD                                   #
#   - UPDONA   : Met Ã  jour la table OVENAT                                     #
#   - UPDLEG   : Met Ã  jour le champs LEG dans les tables                       #
#                TABVAT, TABVAC, TABSIVTYP, TABPIVTYP, TABPAYTERM, TABDEPAGIO   #
#                DEBREGNAT, PARWIPACCS, PARSTOACC, PARWIPACC                    #
#                                                                               #
# AprÃĻs mise Ã  jour : TRCMAJ30                                                  #
#                                                                               #
#   - AP_ADI   : Table diverse 6 : Natures CEE : Suppression du 0 de la clÃĐ     #
#   - AP_MVC   : Table BPCUSTMVT/LASTCUSMVT : Appel resynchro encours clients   #
#   - AP_MVS   : Table BPSUPPMVT/LASTSUPMVT : Appel resynchro encours fsseurs   #
#   - UPDATZTBO: Index TBO0: BOMALTTYP;BOMALT - Rectification des liens ATZ     #
#   - UPDCBH   : Mise Ã  jour CBNHEA BOMALTTYP                                   #
#   - UPDPDH   : Mise Ã  jour PDPHEA BOMALTTYP                                   #
#   - UPDCSC   : Mise Ã  jour BOMALTTYP dans les scÃĐnarios configurateur         #
#   - UPDCHH   : Mise Ã  jour BOMALTTYP dans histo scÃĐnarios configurateur       #
#   - UPDBMR   : Mise Ã  jour BOMALTTYP dans les besoins composants              #
#   - UPDITC2  : Mise Ã  jour BOMALTTYP dans ITMCOST                             #
#   - UPDONA   : Met Ã  jour la table OVENAT                                     #
#   - UPDITM   : Met Ã  jour la table ITMMASTER                                  #
#   - UPDBPC   : Met Ã  jour la table BPCUSTOMER                                 #
#   - UPDBPS   : Met Ã  jour la table BPSUPPLIER                                 #
#   - UPDREP   : Met Ã  jour la table SALESREPR                                  #
#   - UPDORD   : Mise Ã  jour BOMALTTYP dans les en-cours                        #
#   - UPDWIP   : Mise Ã  jour BOMALTTYP dans les couts                           #
#   - UPDTUV   : Mise Ã  jour TABUNAVAIL                                         #
#                                                                               #
#################################################################################

#################################################################################
# Moulinette : Dico anciennes tables avant ajout des nouvelles tables           #
#################################################################################

Subprog ADICMAJ30
Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("DOSMAJ30 : Process for common dictionnary") From LECFIC
    WOUV_TRACE=1
Endif

# Issue 78092 - 2011-11-22 by CCC : Si plus de GPAO => on vide les tables qui ne vont pas pouvoir ÃŠtre migrÃĐes
If [F:ADS]MODULE(7)<>2
    Call DEL_TAB([F:ADS]DOSSIER,"MFCNAT")
    Call DEL_TAB([F:ADS]DOSSIER,"MFGCOST")
    Call DEL_TAB([F:ADS]DOSSIER,"WIPCOST")
    Call DEL_TAB([F:ADS]DOSSIER,"MFGWIP")
Endif
Call AV_ICP
Call AV_MCP
Call AV_MCW

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End


#################################################################################
# Moulinette : Structure tables avec anciens et nouveaux champs                 #
#################################################################################

Subprog ATRCMAJ30

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("DOSMAJ30 : Process for common data") From LECFIC
    WOUV_TRACE=1
Endif

#--- Bug 74652
# Alimentation de GSITE, GSOCSITE, GFINSITE, ...
Local File =[F:ADS]DOSSIER+".COMPANY"    [CPY]
Local File =[F:ADS]DOSSIER+".FACILITY"   [FCY]
Global Integer  GNBSOC
Global Integer  GNBSITE
Global Integer  GDIMSIT
Global Integer  GDIMSOC
Raz GNBSOC
Raz GNBSITE
GDIMSIT = max(nbrecord([FCY])+20,100)
GDIMSOC = max(nbrecord([CPY])+20,100)
Global Char     GSITE(type([F:FCY]FCY)-10)(1..GDIMSIT)               # FGR 09/10/2014 : X3SUIVI102999 : Pas 5
Global Char     GSOCSITE(type([F:FCY]FCY)-10)(1..GDIMSIT)            # FGR 09/10/2014 : X3SUIVI102999 : Pas 5
Global Char     GFINSITE(type([F:CPY]CPY)-10)(1..GDIMSIT)            # FGR 09/10/2014 : X3SUIVI102999 : Pas 5
Global Char     GSOC(type([F:CPY]CPY)-10)(1..GDIMSOC)                # FGR 09/10/2014 : X3SUIVI102999 : Pas 5
Global Libelle  GTYPSOC(1..GDIMSOC)
Global Char     GDEVSOC(type([F:CPY]ACCCUR)-10)(1..GDIMSOC)          # FGR 09/10/2014 : X3SUIVI102999 : Pas 5
Global Char     GLEGSOC(type([F:CPY]LEG)-10)(1..GDIMSOC)             # FGR 09/10/2014 : X3SUIVI102999 : Pas 20
Global Char     GGCMSOC(type([F:CPY]ACM)-10)(1..GDIMSOC)             # FGR 09/10/2014 : X3SUIVI102999 : Pas 3

For [CPY]
 GNBSOC += 1
 GSOC(GNBSOC)    = [F:CPY]CPY
 If dim([F:CPY]ACCCUR)>0
  GDEVSOC(GNBSOC) = [F:CPY]ACCCUR
 Else
  GDEVSOC(GNBSOC) = ""
 Endif
 GLEGSOC(GNBSOC) = [F:CPY]LEG
 If dim(GTYPSOC)>0
  GTYPSOC(GNBSOC) = [F:CPY]CPYLEGFLG
 Endif
 If dim(GGCMSOC)>0
  If dim([F:CPY]ACM)>0
   GGCMSOC(GNBSOC) = [F:CPY]ACM
  Else
   GGCMSOC(GNBSOC) = ""
  Endif
 Endif
Next
For [FCY]
 GNBSITE += 1
 GSITE(GNBSITE)    = [F:FCY]FCY
 GSOCSITE(GNBSITE) = [F:FCY]LEGCPY
 GFINSITE(GNBSITE) = [F:FCY]FINRSPFCY
 If GFINSITE(GNBSITE)  = ""
  GFINSITE(GNBSITE) = [F:FCY]FCY
 Endif
Next
# Issue 74556 - 2011-07-05 by VPO : chargement code activitÃĐ PTX
Local File =[F:ADS]DOSSIER+".ACTIV"    [ACV]
Call SET_ACTIVPTX From TRTX3
#---

Call AV_SPR
Call AV_PPR
Call AV_SPC
Call AV_PPC
Call AV_SPL
Call AV_PPL
Call AV_TVC
Call AV_TRA : # 98974 : Calcul facture CEE erronÃĐ suite Ã  non init. du flag VATEXEFLG ds TABRATVAT
Call AV_AXX
Call AV_AIN
#MAE, dÃĐplacÃĐ dans UUMGTRTTRC03 Call AV_BPR
#MAE, dÃĐplacÃĐ dans UUMGTRTTRC02 Call AV_BPC
#MAE, dÃĐplacÃĐ dans UUMGTRTTRC08 Call AV_BPS
#MAE, dÃĐplacÃĐ dans UUMGTRTTRC09 Call AV_BPT
#MAE, dÃĐplacÃĐ dans UUMGTRTTRC06 Call AV_REP
#Call AV_ADI
Call AV_PRS
Call AV_BCH
Call AV_MVC From TRC1MAJ30
Call AV_MVS From TRC1MAJ30 : # Traitement des mouvements fournisseurs
Call AV_EECSCH
Call AV_DEB :# Initialisation des nÂ° de ligne de DEB (par sociÃĐtÃĐ, date d'extraction et par flux)

Call AV_TVM

Local Integer NUMPROC
Raz NUMPROC

Onerrgo TRT_ERR

#---- Remplacement des dÃĐsignation par des textes traduisibles ------#
NUMPROC += 1
Call ECR_TIME("TRCMAJ30 TC Transactions Process "+num$(NUMPROC)+": DES --> AXX") From DOSSUB
Call DES2AXX([F:ADS]DOSSIER)
If GOK<>1 : Onerrgo : End : Endif

#---- Init rÃĻgle sortie sous-traitance dans les rÃĻgles de gestion ------#
NUMPROC += 1
Call ECR_TIME("TRCMAJ30 TC Transactions Process "+num$(NUMPROC)+": Update CLSTYP") From DOSSUB
Call STKITG_CLS([F:ADS]DOSSIER)
If GOK<>1 : Onerrgo : End : Endif
NUMPROC += 1
Call ECR_TIME("TRCMAJ30 TC Transactions Process "+num$(NUMPROC)+": Update PCK") From DOSSUB
Call STKITG_PCK([F:ADS]DOSSIER)
If GOK<>1 : Onerrgo : End : Endif

# UUMGTRTSTO02
##---- Mise Ã  jour de ITMCOST (suppression du champ YEA...) -----#
#NUMPROC += 1
#Call ECR_TIME("TRCMAJ30 TC Transactions Process "+num$(NUMPROC)+": Update ITC") From DOSSUB
#Call UPDITC([F:ADS]DOSSIER)
#If GOK<>1 : Onerrgo : End : Endif

#---- Initialisation nouveau champs BOMALTTYP...) -----#
NUMPROC += 1
Call ECR_TIME("TRCMAJ30 TC Transactions Process "+num$(NUMPROC)+": Update BOD") From DOSSUB
Call UPDBOD([F:ADS]DOSSIER)
If GOK<>1 : Onerrgo : End : Endif

#---- Initialisation nouveau champ LLCTYP...) -----#
NUMPROC += 1
Call ECR_TIME("TRCMAJ30 TC Transactions Process "+num$(NUMPROC)+": Update ITB") From DOSSUB
Call UPDITB([F:ADS]DOSSIER)
If GOK<>1 : Onerrgo : End : Endif

#---- Initialisation nouveau champ LLCTYP...) -----#
NUMPROC += 1
Call ECR_TIME("TRCMAJ30 TC Transactions Process "+num$(NUMPROC)+": Update CFB") From DOSSUB
Call UPDCFB([F:ADS]DOSSIER)
If GOK<>1 : Onerrgo : End : Endif

#---- Utilisation de la nouvelle table CBLOB ----#
NUMPROC += 1
Call ECR_TIME("TRCMAJ30 TC Transactions Process "+num$(NUMPROC)+": Update CBB") From DOSSUB
Call UPDCBB([F:ADS]DOSSIER)
If GOK<>1 : Onerrgo : End : Endif

#---- Init nouveaux champs OVERHEAD ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ30 TC Transactions Process "+num$(NUMPROC)+": Update OVERHEAD") From DOSSUB
Call UPDOVE([F:ADS]DOSSIER)
If GOK<>1 : Onerrgo : End : Endif

#---- Init nouveaux champs OVENAT ------#
#NUMPROC += 1
#Call ECR_TIME("DOSMAJ30 TC Transactions Process "+num$(NUMPROC)+": Update OVENAT") From DOSSUB
#Call UPDONA([F:ADS]DOSSIER)
#If GOK<>1 : Onerrgo : End : Endif

#---- Init nouveaux champs ITMMASTER ------#
#NUMPROC += 1
#Call ECR_TIME("DOSMAJ30 TC Transactions Process "+num$(NUMPROC)+": Update OVENAT") From DOSSUB
#Call UPDITM([F:ADS]DOSSIER)
#If GOK<>1 : Onerrgo : End : Endif

#---- Init lÃĐgislation LEG dans les tables TC ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ30 TC Transactions Process "+num$(NUMPROC)+": Update LEG in TC Table") From DOSSUB
Call UPDLEG([F:ADS]DOSSIER)
If GOK<>1 : Onerrgo : End : Endif

#---- Init des champs BLONBR et LINNBR dans CFGSCE ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ30 TC Transactions Process "+num$(NUMPROC)+": Update CSC (BLONBR,LINNBR)") From DOSSUB
Call AV_CSC([F:ADS]DOSSIER)     # GA 26/02/2009 FQ 52854
If GOK<>1 : Onerrgo : End : Endif


#----- Mise Ã  jour des listes de gauche des objets modifiÃĐs -----#
Gosub MAJ_AOBJLST
#-----

#----- Mise Ã  jour des listes de gauche des objets modifiÃĐs FGR 09/07/2009 X3SUIVI56335 -----#
Gosub MAJ_AOBJET From TRCMAJ30AXX
#-----

#-------------------------------------------------------------------------------------------------------#
# FGR 16/12/2009 : X3SUIVI60425 : Migration modÃĻles import/export
Call IMPORTEXPORT([F:ADS]DOSSIER, [F:ADS]DOSREF) From TRC1MAJ30
#-------------------------------------------------------------------------------------------------------#

#VPO 29/10/10 68047 correct pivot SCMDSOS
Call UTI_MOUL([F:ADS]DOSSIER) From UTITC35

# Modification libellÃĐ tables diverse 6 et 15  # hcb 59154
Call ATEXTRA                                   # hcb 59154
#-----

Onerrgo

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End

#########################################################################
## M.a.j. de SPREASON : Motifs tarifs ventes
## - Cle en alpha pour lien ATEXTRA
#########################################################################
Subprog AV_SPR
If filinfo(filpath("FIL","SPREASON","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": SPREASON"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".SPREASON"   [SPR]

Trbegin [SPR]
  For [SPR]
      [F:SPR]PRIRENCAR = num$([F:SPR]PRIREN)
      Rewrite [SPR]
      If fstat
         Call ERREUR("SPREASON"-[F:SPR]PRIRENCAR,2) From DOSDIC
      Endif
  Next
Commit

End

#########################################################################
## M.a.j. de PPREASON : Motifs tarifs achats
## - Cle en alpha pour lien ATEXTRA
#########################################################################
Subprog AV_PPR
If filinfo(filpath("FIL","PPREASON","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": PPREASON"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".PPREASON"   [PPR]

Trbegin [PPR]
  For [PPR]
      [F:PPR]PRIRENCAR = num$([F:PPR]PRIREN)
      Rewrite [PPR]
      If fstat
         Call ERREUR("PPREASON"-[F:PPR]PRIRENCAR,2) From DOSDIC
      Endif
  Next
Commit

End

#########################################################################
## M.a.j. de SPRICCONF : ParamÃĐtrage tarifs ventes
## - Ajout du champ PLIBPRCNR ( remplace BETCPY )
#########################################################################
Subprog AV_SPC
If filinfo(filpath("FIL","SPRICCONF","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": SPRICCONF"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".SPRICCONF"   [SPC]

Trbegin [SPC]
  For [SPC]
      If [F:SPC]BETCPY=2  [F:SPC]PLIBPRCNR=3  Else  [F:SPC]PLIBPRCNR=1  Endif
      Rewrite [SPC]
      If fstat
         Call ERREUR("SPRICCONF"-[F:SPC]PLI,2) From DOSDIC
      Endif
  Next
Commit

End

#########################################################################
## M.a.j. de PPRICCONF : ParamÃĐtrage tarifs ventes
## - Ajout du champ PLIBPRCNR ( remplace BETCPY )
#########################################################################
Subprog AV_PPC
If filinfo(filpath("FIL","PPRICCONF","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": PPRICCONF"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".PPRICCONF"   [PPC]

Trbegin [PPC]
  For [PPC]
      If [F:PPC]BETCPY=2  [F:PPC]PLIBPRCNR=2  Else  [F:PPC]PLIBPRCNR=1  Endif
      Rewrite [PPC]
      If fstat
         Call ERREUR("PPRICCONF"-[F:PPC]PLI,2) From DOSDIC
      Endif
  Next
Commit

End

#########################################################################
## M.a.j. de SPRICLIST : Tarifs ventes
## - Ajout et init champs FOCQTYBKT, FOCAMTMIN, FOCQTYBKT
#########################################################################
Subprog AV_SPL

If filinfo(filpath("FIL","SPRICCONF","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif
If filinfo(filpath("FIL","SPRICFICH","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif
If filinfo(filpath("FIL","SPRICLIST","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

# Bug 80493 : DÃĐplacement ouverture table pour test prÃĐsence champ FOCBKT
Local File =[F:ADS]DOSSIER+".SPRICLIST"   [SPL]
# Si FOCBKT n'existe plus, inutile de passer la moulinette (elle a dÃĐjÃ  ÃĐtÃĐ dÃĐjÃ  passÃĐe)
If dim([F:SPL]FOCBKT)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": SPRICLIST"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".SPRICCONF"   [SPC]
Local File =[F:ADS]DOSSIER+".SPRICFICH"   [SPF]
#Local File =[F:ADS]DOSSIER+".SPRICLIST"  [SPL] : # Bug 80493
For [SPC]
  If [F:SPC]FOCPRO>1                            : # uniquement si gestion des gratuits
     For [SPF] Where PLI=[F:SPC]PLI
       Trbegin [SPL]
       For [SPL] Where PLI=[F:SPF]PLI & PLICRD=[F:SPF]PLICRD
         If sum([F:SPL]FOCQTYMIN,[F:SPL]FOCBKT)<>0
            If [F:SPL]FOCQTYMIN<>0
               If find([F:SPC]PRIQTYFLG,4,5)   : [F:SPL]FOCAMTMIN=[F:SPL]FOCQTYMIN : Raz [F:SPL]FOCQTYMIN : Endif
            Endif
            If [F:SPL]FOCBKT<>0
               If find([F:SPC]PRIQTYFLG,1,2,3) : [F:SPL]FOCQTYBKT=[F:SPL]FOCBKT : Endif
               If find([F:SPC]PRIQTYFLG,4,5)   : [F:SPL]FOCAMTBKT=[F:SPL]FOCBKT : Endif
            Endif
            Rewrite [SPL]
            If fstat
               Call ERREUR("SPRICLIST"-[F:SPL]PLI-[F:SPL]PLICRD,2) From DOSDIC
            Endif
         Endif
       Next
       Commit
     Next
  Endif
Next

End

#########################################################################
## M.a.j. de PPRICLIST : Tarifs achats
## - Ajout et init champs FOCQTYBKT, FOCAMTMIN, FOCQTYBKT
#########################################################################
Subprog AV_PPL

If filinfo(filpath("FIL","PPRICCONF","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif
If filinfo(filpath("FIL","PPRICFICH","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif
If filinfo(filpath("FIL","PPRICLIST","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

# Bug 80493 : DÃĐplacement ouverture table pour test prÃĐsence champ FOCBKT
Local File =[F:ADS]DOSSIER+".PPRICLIST"   [PPL]
# Si FOCBKT n'existe plus, inutile de passer la moulinette (elle a dÃĐjÃ  ÃĐtÃĐ dÃĐjÃ  passÃĐe)
If dim([F:PPL]FOCBKT)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": PPRICLIST"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".PPRICCONF"   [PPC]
Local File =[F:ADS]DOSSIER+".PPRICFICH"   [PPF]
#Local File =[F:ADS]DOSSIER+".PPRICLIST"  [PPL] : # Bug 80493
For [PPC]
  If [F:PPC]FOCPRO>1                            : # uniquement si gestion des gratuits
     For [PPF] Where PLI=[F:PPC]PLI
       Trbegin [PPL]
       For [PPL] Where PLI=[F:PPF]PLI & PLICRD=[F:PPF]PLICRD
         If sum([F:PPL]FOCQTYMIN,[F:PPL]FOCBKT)<>0
            If [F:PPL]FOCQTYMIN<>0
               If find([F:PPC]PRIQTYFLG,4,5)   : [F:PPL]FOCAMTMIN=[F:PPL]FOCQTYMIN : Raz [F:PPL]FOCQTYMIN : Endif
            Endif
            If [F:PPL]FOCBKT<>0
               If find([F:PPC]PRIQTYFLG,1,2,3) : [F:PPL]FOCQTYBKT=[F:PPL]FOCBKT : Endif
               If find([F:PPC]PRIQTYFLG,4,5)   : [F:PPL]FOCAMTBKT=[F:PPL]FOCBKT : Endif
            Endif
            Rewrite [PPL]
            If fstat
               Call ERREUR("PPRICLIST"-[F:PPL]PLI-[F:PPL]PLICRD,2) From DOSDIC
            Endif
         Endif
       Next
       Commit
     Next
  Endif
Next

End

#########################################################################
## M.a.j. de TABVAC : DÃĐtermination du code taxe
## - Nouvelle structure des enr. de TABVAC
#########################################################################
Subprog AV_TVC
If filinfo(filpath("FIL","TABVAC","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": TABVAC"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".TABVAC"      [TVC]
Local File =[F:ADS]DOSSIER+".TABVAT"      [TVT]
Local File =[F:ADS]DOSSIER+".ATEXTRA"     [AXX]

#----- Sauvegarde puis rÃĐcupÃĐration de la langue du dossier Ã  migrer -----#
Local Char SAV_GLANGUE(GLONLAN)
SAV_GLANGUE=GLANGUE
GLANGUE=[F:ADS]LANDEF

Trbegin [TVC]
For [TVC]
  Read [TVT] TVT0=[F:TVC]VAT
  If !fstat
    [F:TVC]COD=[F:TVC]VACBPR+"_"+[F:TVC]VACITM
    Call MAJTEXTRA ([F:TVC]VACDES,"TABVAC","DESAXX",[F:TVC]COD,"") From ATEXTRA
    Call MAJTEXTRA ([F:TVC]VACSHO,"TABVAC","SHOAXX",[F:TVC]COD,"") From ATEXTRA
    If dim([F:TVC]LANDESSHO)>0
      [F:TVC]LANDESSHO=GLANGUE+"~"+[F:TVC]VACDES+"~"+[F:TVC]VACSHO
    Endif
    [F:TVC]ENAFLG=2
    [F:TVC]VATTYP=[F:TVT]VATTYP
    [F:TVC]ATB   ="TAXLINK"
    #----- RÃĐcupÃĐration du code lÃĐgislation et constitution de la formule ÃĐvaluÃĐe -----#
    Raz [F:TVC]EXPTST
    If [F:ADS]DOSLEG(0)<>""
      [F:TVC]LEG=[F:ADS]DOSLEG(0)
      [F:TVC]EXPTST='[F:TLK]LEG="'+[F:TVC]LEG+'" & '
    Endif
    [F:TVC]EXPTST+='[F:TLK]VACBPR="'+[F:TVC]VACBPR+'" & [F:TLK]VACITM="'+[F:TVC]VACITM+'"'
    #-----
    [F:TVC]UPDUSR=GUSER
    [F:TVC]UPDDAT=date$
    Rewrite [TVC]
    If fstat
      Call ERREUR("TABVAC"-[F:TVC]COD,2) From DOSDIC
    Endif
  Endif
Next
Commit

#----- Restitution du code langue de connexion -----#
GLANGUE=SAV_GLANGUE
End

# 98974 : Migration 140 V7 cdes de ventes
# --> Calcul facture CEE erronÃĐ suite Ã  non init. du flag VATEXEFLG ds TABRATVAT
#########################################################################
## M.a.j. de TABRATVAT : Table des taux de taxe
## - Alimentation flag VATEXEFLG : Flag exonÃĐration de taxe
#########################################################################
Subprog AV_TRA
If filinfo(filpath("FIL","TABVAC","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": TABRATVAT"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".TABVAC"      [TVC]
Local File =[F:ADS]DOSSIER+".TABRATVAT"   [TRA]
Local File =[F:ADS]DOSSIER+".ATABDIV"     [ADI]

Trbegin [TRA]

# Pour chaque code taxe de type TVA : On positionne Ã  Oui le flag exonÃĐration sur tous les taux
# --> s'il existe une dÃĐtermination de taxe avec un rÃĐgime de type CEE pointant sur le code taxe
Link [TVC] With [ADI]CODE=1;[TVC]VACBPR As [XTVC] Where [F:ADI]N1=4 & [F:TVC]VATTYP=1
For [XTVC]
    # On est sur une dÃĐtermination de taxe avec un rÃĐgime de type CEE pour un code taxe de type TVA
    # --> On va rechercher tous les taux de taxe de ce code et on positionne le flag exonÃĐration Ã  2

    #Call ECR_TRACE("TABVAC"-[F:TVC]COD-[F:TVC]VACBPR-[F:TVC]VACITM,0) From GESECRAN
    For [TRA]TRA0 Where VAT=[F:TVC]VAT & VATEXEFLG<>2
        #Call ECR_TRACE("TABRATVAT"-[F:TRA]VAT-[F:TRA]CPY-format$("D:",[F:TRA]STRDAT),0) From GESECRAN
        [F:TRA]VATEXEFLG=2
        Rewrite [TRA]
        If fstat
          Call ERREUR("TABRATVAT"-[F:TRA]VAT-[F:TRA]CPY-format$("D:",[F:TRA]STRDAT),2) From DOSDIC
        Endif
    Next
Next

Commit

End
# 98974

#########################################################################
## Transfert des intitulÃĐs et dÃĐsignations dans ATEXTRA
#########################################################################
Subprog AV_AXX

If filinfo(filpath("FIL","ATEXTRA","fde",[F:ADS]DOSSIER),0)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": ATEXTRA"-time$,0) From GESECRAN : # maj table

Local File =[F:ADS]DOSSIER+".ATEXTRA"   [AXX]

#----- Sauvegarde puis rÃĐcupÃĐration de la langue du dossier Ã  migrer -----#
Local Char SAV_GLANGUE(GLONLAN)
SAV_GLANGUE=GLANGUE
GLANGUE=[F:ADS]LANDEF

#------- TABUNAVAIL [TUV] : PÃĐriodes d'indisponibilitÃĐ ------------------
If filinfo(filpath("FIL","TABUNAVAIL","fde",[F:ADS]DOSSIER),0)>0
   Local File =[F:ADS]DOSSIER+".TABUNAVAIL"   [TUV]
   Trbegin [TUV]
     For [TUV]
         Call MAJTEXTRA ([F:TUV]UVYDES,"TABUNAVAIL","DESAXX",[F:TUV]UVYCOD,"") From ATEXTRA
         Call MAJTEXTRA ([F:TUV]UVYSHO,"TABUNAVAIL","SHOAXX",[F:TUV]UVYCOD,"") From ATEXTRA
         If dim([F:TUV]LANDESSHO)>0
            [F:TUV]LANDESSHO=GLANGUE+"~"+[F:TUV]UVYDES+"~"+[F:TUV]UVYSHO
         Endif
         For IJL=0 To dim([F:TUV]UVYNAM)-1
            If [F:TUV]UVYNAM(IJL)<>""
               Call MAJTEXTRA ([F:TUV]UVYNAM(IJL),"TABUNAVAIL","UVYAXX",[F:TUV]UVYCOD,num$(val([F:TUV]UVYSTRDAT(IJL))))
&                   From ATEXTRA
            Endif
         Next IJL
         Rewrite [TUV]
         If fstat
            Call ERREUR("TABUNAVAIL"-[F:TUV]UVYCOD,2) From DOSDIC
         Endif
     Next
   Commit
Endif

