#------- PURTRS     [PTR] : Transactions de saisie module achats --------
If filinfo(filpath("FIL","PURTRS","fde",[F:ADS]DOSSIER),0)>0
  Local File =[F:ADS]DOSSIER+".PURTRS"   [PTR]
  Local Integer WNBR : Raz [L]WNBR
  Trbegin [AXX], [PTR]
    For [PTR] PTR0
      If !instr(1,[F:PTR]PTRDES,"~")
        #Readlock [PTR] Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert Ã  rien ici
        #If fstat
        #  Call ECR_TRACE("File PURTRS"-num$([F:PTR]PTRTYP)-[F:PTR]PTRNUM+", Error ="-num$(fstat),1) From GESECRAN
        #Else
          Call MAJTEXTRA ([F:PTR]PTRDES,"PURTRS","DESAXX",num$([F:PTR]PTRTYP),[F:PTR]PTRNUM) From ATEXTRA
          If GOK<1
            Call ECR_TRACE("File ATEXTRA"-"PURTRS DESAXX"-num$([F:PTR]PTRTYP)-[F:PTR]PTRNUM+
&                          ",Error ="-num$(fstat),1) From GESECRAN
            GOK=1 : Break
          Endif
        #Endif
        [F:PTR]PTRDES=GLANGUE+"~"+[F:PTR]PTRDES
        If dim([F:PTR]PTRTYPCAR)>0  [F:PTR]PTRTYPCAR=num$([F:PTR]PTRTYP) : Endif
        Rewrite [PTR]
        If fstat
          Call ECR_TRACE("File PURTRS"-num$([F:PTR]PTRTYP)-[F:PTR]PTRNUM+", Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
      [L]WNBR+=1
    Next
  Commit
  Close Local File [PTR]
  Call ECR_TIME("DOSMAJ30 Update ATEXTRA for purchase transactions : Ended ("+num$([L]WNBR)+")") From DOSSUB
Endif

