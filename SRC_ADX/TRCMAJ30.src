#                 Endif
              Endif
           Endif
         # GA pour la V6 par dÃĐfaut il s'agit d'une nomenclature de production
           If [F:PDH]BOMALTTYP=0 & [F:PDH]BOMALT>0 : [F:PDH]BOMALTTYP=2 : Endif
