#<AdxTL>@(#)10.0.0.0 $Revision$
#####################################################################################################################################
#-------------------------------------Comptabilité : Actions diverses---------------------------------------------------------------#
#
# AVERTDGI  : Affichage message d'avertissement lorsqu'on cherche à comptabiliser un lot d'écritures d'une société conforme DGI  
# AVERTDGI2 : Idem AVERTDGI sauf qu'ici c'est un tableau de sociétés qui est passé 
# FRADGI    : Vérifie si la société (ou toutes les sociétés du groupe passé en paramètre) a le paramètre FRADGI à "Oui". 
#             Si c'est la cas, la variable OK est initialisée à 2 et le sous proggramme appelant doit forcer le statut de la pièce
#             à "Définitif". Dans le cas contraire (= au moins une société qui n'a pas le paramètre FRADGI à "Oui"), le statut ne
#             doit pas être forcé et doit rester accessible.
#####################################################################################################################################
Subprog AVERTDGI(TOUSOC,SOCIETE,TYPGEN,FIN) 
Value    Integer TOUSOC    : ## Flag 'Toutes sociétés' 1="Non" ; 2="Oui"
Value    Char    SOCIETE() : ## Société
Value    Integer TYPGEN    : ## Type Génération 1:Réel  >2:Simul 
Variable Integer FIN       : ## 1:On arrête  <>1:On continue
If clalev([F:ADW])=0 : Local File ADOVAL    [ADW] : Endif
Local Char    VALPAR(3)
Local Integer OKMESS, AFFMESS
If TYPGEN>1 : End : Endif
If TOUSOC = 2
 Call PARAMUTIL("FRADGIMSG",VALPAR,"","") From SUBAUS
Else
 Call PARAMUTIL("FRADGIMSG",VALPAR,"",SOCIETE) From SUBAUS
Endif
OKMESS = val(VALPAR)
If OKMESS<>2 : End : Endif
AFFMESS = 0
If TOUSOC = 2
 Filter [ADW] Where PARAM="FRADGI" & VALEUR="2"
 Read [ADW]ADW1 First
 Filter [ADW]
 If !fstat
  AFFMESS = 1
 Endif
Elsif SOCIETE<>""
 Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
 If func AFNC.PARAM("FRADGI",SOCIETE)="2"
  AFFMESS = 2
 Endif
Endif
Gosub MESSAGE
End


Subprog AVERTDGI2(NBSOC,TSOC,SITE,TYPGEN,FIN) 
Value    Integer NBSOC       : ## Nombre de sociétés
Value    Char    TSOC()(0..) : ## Société
Value    Char    SITE()      : ## Site
Value    Integer TYPGEN      : ## Type Génération 1:Réel  >2:Simul 
Variable Integer FIN         : ## 1:On arrête  <>1:On continue
If clalev([F:ADW])=0 : Local File ADOVAL    [ADW] : Endif
Local Char    VALPAR(3), SOCIETE(GLONCPY)
Local Integer OKMESS, AFFMESS, ISOC
If TYPGEN>1 : End : Endif
If NBSOC = 1
 Call PARAMUTIL("FRADGIMSG",VALPAR,"",TSOC(ISOC)) From SUBAUS
Elsif NBSOC = 0 & SITE<>""
 Call PARAMUTIL("FRADGIMSG",VALPAR,"",SITE) From SUBAUS
Else
 Call PARAMUTIL("FRADGIMSG",VALPAR,"","") From SUBAUS
Endif
OKMESS = val(VALPAR)
If OKMESS<>2 : End : Endif
AFFMESS = 0
If NBSOC = 1
 If func AFNC.PARAM("FRADGI",TSOC(0))="2"
  [L]SOCIETE = TSOC(0) : AFFMESS = 2
 Endif
Elsif NBSOC>1
 For ISOC=0 To NBSOC-1
  If func AFNC.PARAM("FRADGI",TSOC(ISOC))="2"
   AFFMESS = 1 : Break
  Endif
 Next
Elsif NBSOC = 0 & SITE<>""
 Call LECTURE("FCY",SITE,"") From CONTOBJ
 If func AFNC.PARAM("FRADGI",[F:FCY]LEGCPY)="2"
  [L]SOCIETE = [F:FCY]LEGCPY : AFFMESS = 2
 Endif
Endif
Gosub MESSAGE
End


$MESSAGE
If AFFMESS = 1
 Local Integer OK2
 OK2 = 2
 ## Les documents comptabilisés seront en ‘définitif’ pour une ou plusieurs des sociétés
 Call AVERTIR(mess(196,107,1),OK2) From GESECRAN
 If OK2<>2 : FIN=1 : Return : Endif
Elsif AFFMESS = 2
 Local Integer OK2
 OK2 = 2
 ## Les documents comptabilisés seront en ‘définitif’ pour la société
 Call AVERTIR(mess(195,107,1)-[L]SOCIETE,OK2) From GESECRAN
 If OK2<>2 : FIN=1 : Return : Endif
Endif
Return


Subprog FRADGI(NBSOC,TSOC,SITE,TYPGEN,DGI) 
Value    Integer NBSOC       : ## Nombre de sociétés
Value    Char    TSOC()(0..) : ## Société
Value    Char    SITE()      : ## Site
Value    Integer TYPGEN      : ## Type Génération 1:Réel  >2:Simul 
Variable Integer DGI         : ## 1:Non  2:Oui
If clalev([F:ADW])=0 : Local File ADOVAL    [ADW] : Endif
Local Integer ISOC
If TYPGEN>1 : End : Endif
If NBSOC = 1
 If func AFNC.PARAM("FRADGI",TSOC(0))="2"
  DGI = 2
 Else
  DGI = 1
 Endif
Elsif NBSOC>1
 ## Si au moins une société du groupe n'a pas le paramètre FRADGI à "Oui", on laissera accessible le statut (Provisoire/Définitif) 
 DGI = 2
 For ISOC=0 To NBSOC-1
  If func AFNC.PARAM("FRADGI",TSOC(ISOC))<>"2"
   DGI = 1 : Break
  Endif
 Next
Elsif NBSOC = 0 & SITE<>""
 Call LECTURE("FCY",SITE,"") From CONTOBJ
 If func AFNC.PARAM("FRADGI",[F:FCY]LEGCPY)="2"
  DGI = 2
 Else
  DGI = 1
 Endif
Endif
End

