#<AdxTL>@(#)7.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Initialisation champ LEG dans APROMEN dans les dossiers mono
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update LEG in APROMEN Tables for mono legislation folders") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJAPO
End

#-------------------#
$MAJAPO

If DOSSIER=GDOSX3
 Return
Endif

Local Integer MONO , UPD

Local File ADOSSIER [ADS_U] , ADOSACT [ADA_U]
Read [ADS_U]DOSSIER = [L]DOSSIER
Read [ADA_U]ADA0 = [L]DOSSIER;"LEG"
If fstat or [F:ADA_U]FLACT<>2
 MONO = 1
Endif
If !MONO : Goto FIN : Endif

# Mise à jour de la table APROMEN

Call ECR_TRACE(mess(81,125,1)-"APROMEN :"-time$,0) From GESECRAN

Local File =DOSSIER+".APROMEN" [APO], =DOSSIER+".APROMEN" [APO2], =DOSSIER+".ATEXTRA" [AXX]

Trbegin [APO]

 For [APO]
  If [F:APO]LEG=""
   Look [APO]APO1=[F:ADS_U]DOSLEG;[F:APO]CODMEN
   If !fstat
    Delete [APO]APO1 Curr
   Else
    Update [AXX] Where CODFIC="APROMEN" & ZONE="INTLNG" & IDENT1="" & IDENT2=[F:APO]CODMEN With IDENT1=[F:ADS_U]DOSLEG
    Update [AXX] Where CODFIC="APROMEN" & ZONE="COMMENT" & IDENT1="" & IDENT2=[F:APO]CODMEN With IDENT1=[F:ADS_U]DOSLEG
    [F:APO]LEG = [F:ADS_U]DOSLEG
    Rewrite [APO]
   Endif
   If fstat
    Call ERREUR("APROMEN"-[F:APO]CODMEN,2) From DOSDIC
   Endif
  Endif
 Next APO

Commit

#-----------------------#
$FIN

Close Local File

Return

