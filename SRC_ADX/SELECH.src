#<AdxTL>@(#)167.0.0.0 $Revision$
Local Char PARAM(30)(1..10) , VALEUR(10)
Local File GACCDUDATE [DUD2]
Close Local Mask
Filter [DUD2] Where ACCNUM>=54789
Call SAISIE_CHAR(VALEUR,PARAM,"DREGECH","SELECH","") From GSAISIE
Infbox PARAM(1)-PARAM(2)-PARAM(3)
End

###################################################### 
## 25/08/00  BY version webisée
###################################################### 
# Valeurs de STAT
# -1 : abandon
# 0  : pas d'échéance sélectionnée
# 1  : échéance sélectionnée

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "OK"          : Gosub OK
 When "END"         : Gosub FIN
 When "FINSAI"      : Gosub FINSAI
Endcase
Return

$OUVRE
Local Char    CUR(GLONCUR) , CODTRT(10)
Local Integer NUM, LIG, STAT, CHARGE
Local Char    ACTSELECH(10)
Local Integer SAVNOLIGN2 # Bug 23461
SAVNOLIGN2 = nolign : # nolign du programme appelant
CHARGE=1

If PARAM(4)<>""
 ACTSELECH = "DEBUT" : Gosub SELECH From =PARAM(4)
 If FIN : Return : Endif
Endif

If clalev([M:RECH])=0 : Local Mask REGECHW [RECH] : Endif

If CHARGE
 Raz [M:RECH]
 nolign = 1 : J = nolign
 I = dim([M:RECH]BPRPAY)
 NUM = val(PARAM(1))
 LIG = val(PARAM(2))
 For [DUD2]DUD0
  CUR = [F:DUD2]CUR
  [M:RECH] = [F:DUD2]
  [M:RECH]SOLDE(nolign-1)  = [F:DUD2]AMTCUR-[F:DUD2]PAYCUR-[F:DUD2]TMPCUR
  [M:RECH]ACCLIG(nolign-1) = [F:DUD2]DUDLIG
  [M:RECH]NECH += 1
  If [F:DUD2]ACCNUM=NUM & [F:DUD2]DUDLIG=LIG : J = nolign : Endif 
  nolign += 1
  If nolign>I : Break : Endif
 Next : # [DUD2]
Endif
 
If [M:RECH]NECH=0  :# Pas d'échéance sélectionnée
 PARAM(1) = "0"
 PARAM(2) = "0"
 PARAM(3) = "0"
 FIN = 1
Elsif [M:RECH]NECH=1 :# Une échéance
 PARAM(1) = num$([M:RECH]ACCNUM(0))
 PARAM(2) = num$([M:RECH]ACCLIG(0))
 PARAM(3) = "1"
 FIN = 1
Endif
Return

# Plusieurs échéances
$DEBUT
If clalev([F:TCU])=0 : Local File TABCUR [TCU] : Endif
Call LECTURE("TCU",[L]CUR,"") From CONTOBJ
[M]FLG(J-1) = 2
[M]LC = J
Affzo [RECH]
Return

$APRES_MODIF
If COUZON="NECH"
 Local Integer NOL
 NOL = min(nolign,[M]NECH)
 If [M]LC<>0
  [M]LC -= 1
  [M]FLG([M]LC) = 1 : Affzo FLG([M]LC)
 Endif
 [M]FLG(NOL-1) = 2 : Affzo FLG(NOL-1)
 [M]LC = NOL
Endif
Return
 
$OK
If [M]LC<>0
 PARAM(1) = num$([M:RECH]ACCNUM([M]LC-1))
 PARAM(2) = num$([M:RECH]ACCLIG([M]LC-1))
 PARAM(3) = "1"
 FIN = 1
Else
 FIN = 0
Endif
Return

$FIN
PARAM(3) = "-1"
FIN = 1
Return

$FINSAI
nolign = SAVNOLIGN2
indice = nolign-1
If PARAM(4)<>""
 ACTSELECH = "FIN" : Gosub SELECH From =PARAM(4)
Endif
Return

Subprog AV_NECH
If status=71 or status=1
 Local Integer NOL
 NOL=min(nolign,[M]NECH)
 If [M]LC<>0
  [M]LC-=1
  pcolor=GCOUL(0) : # Noir
  Affzo BPRPAY([M]LC),DUDDAT([M]LC),CUR([M]LC),AMTCUR([M]LC),SOLDE([M]LC)
 ENDIF
 pcolor=GCOUL(1) : # Rouge
 Affzo BPRPAY(NOL-1),DUDDAT(NOL-1),CUR(NOL-1),AMTCUR(NOL-1),SOLDE(NOL-1)
 [M]LC=NOL
Endif
End

Subprog AS_FLG(VALEUR)
Variable Integer VALEUR
Local Integer K
If !GMODIF  
 K = indice : Effzo FLG : indice = K 
 GMODIF = 1 : VALEUR = 2
 [M]FLG(indice) = VALEUR
Endif  
mkstat = 2
End

