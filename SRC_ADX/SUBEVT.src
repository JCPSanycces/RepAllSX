#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion objet EVT
#CHECK UNUSED_SOURCE
###############################################################################
#    ACTIVATION DES EVENEMENTS
#    GBN
#    Création le : 17/11/2003
#    Modification le : 17/11/2003
#
#    Corrections  : 24/09/2004 - 24997
#    MDJ   12.06.2013  FQ-82871  Adaptations pour Convergence (pcolor)
################################################################################
Call OBJET("EVT",GBIDC1,GBIDC2) From GOBJET
End
################################################################################
$ACTION
#If GUSER="GBO" : Infbox ACTION : Endif
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "LIENS0"      : Gosub LIENS0
 When "LIENS"       : Gosub LIENS
 When "LIENS2"      : Gosub LIENS2
 When "RAZDUP"      : Gosub RAZDUP #Gbn-290305-Bug n°29444
 When "RAZCRE"      : Gosub RAZCRE
 When "INICRE"      : Gosub INICRE
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "AVANT_MOD"   : Gosub AVANT_MOD
 When Default
Endcase
Return

$OUVRE
 Local Char    L_CPY(GLONCPY)         : # société pour contrôle habilitation
Return

$OUVRE_BOITE
Return

$LIENS0
 If !clalev([F:ADI])  : Local File ATABDIV [ADI]  : Endif
 If !clalev([F:EVT1]) : Local File EVENT   [EVT1] : Endif

 Local Integer I_T_CPY, I_PLN
 Local Integer EXIST_DEFAUT : EXISTE_DEFAUT=0
 Local Char    RUP_CPY(3)

 Local Char T_CPY(3)(1..100)

 #-> Remplissage du tableau des sociétés déjà paramétrées.

 Raz RUP_CPY, I_T_CPY
 For [EVT1]EVT0
  If [F:EVT1]CPY<>RUP_CPY
   I_T_CPY+=1
   T_CPY(I_T_CPY)=[F:EVT1]CPY
   RUP_CPY=[F:EVT1]CPY
  Endif
 Next

 #-> On cherche s'il existe un paramètrage par défaut.

 Filter [EVT1] Where CPY=""
 Read First
 If !fstat
  EXIST_DEFAUT=1
 Endif
 Filter [EVT1]

 #-> Synchronisation du paramétrage par défaut avec le contenu de la table 962 (GTD_EVENT)

 Filter [ADI] Where NUMTAB=GTD_EVENT
 For [ADI]

  #-> Création de l'enregistrement pour la société par défaut
  If EXIST_DEFAUT
   Read [F:EVT1]EVT0="";[F:ADI]CODE
   If fstat
    Case fstat
     When 5
      # Existe pas donc on crée l'enr pour ce couple Evt / Cpy
      Raz [F:EVT1]
      [F:EVT1]CPY     = ""
      [F:EVT1]EVT     = [F:ADI]CODE
      [F:EVT1]ENAFLG  = G_OUI
      [F:EVT1]CREUSR  = GUSER
      [F:EVT1]CREDAT  = date$
      [F:EVT1]EVTFLGN = G_NON
      [F:EVT1]FLGPLAN = [F:ADI]N1
      For I_PLN=0 To 14
       [F:EVT1]FLGP(I_PLN) = G_NON
      Next I_PLN
      Write [F:EVT1]
      If fstat
       # Gestion erreur accès à EVT1
      Else
       #Infbox "Création de l'enregistrement\"-[F:ADI]CODE-"/"-[F:EVT1]CPY
      Endif
     When Default
    Endcase
   Endif
  Endif

  #-> Création des enr manquant pour les sociétés autres que par défaut.

  For I_T_CPY=1 To 100
   If T_CPY(I_T_CPY)="" : Break : Endif
   Read [F:EVT1]EVT0=T_CPY(I_T_CPY);[F:ADI]CODE
   If fstat
    Case fstat
     When 5
      # Existe pas donc on crée l'enr pour ce couple Evt / Cpy
      Raz [F:EVT1]
      [F:EVT1]CPY     = [F:EVT]CPY
      [F:EVT1]EVT     = [F:ADI]CODE
      [F:EVT1]ENAFLG  = G_OUI
      [F:EVT1]CREUSR  = GUSER
      [F:EVT1]CREDAT  = date$
      [F:EVT1]EVTFLGN = G_NON
      [F:EVT1]FLGPLAN = [F:ADI]N1
      For I_PLN=0 To 14
       [F:EVT1]FLGP(I_PLN) = G_NON
      Next I_PLN
      Write [F:EVT1]
      If fstat
       # Gestion erreur accès à EVT1
      Else
       #Infbox "Création de l'enregistrement\"-[F:ADI]CODE-"/"-[F:EVT1]CPY
      Endif
     When Default
      # Erreur d'accès à la table EVENT
    Endcase
   Endif
  Next I_T_CPY
 Next

 Filter [ADI]

 #-> Il faudrait refaire une passe pour supprimer EVENT les types d'événement qui auraient été supprimés de TD 962
 #   Certainement pas utile pour le moment.

Return

$LIENS
 Local Char    PLAN
 Local Integer I_PLN
 For I_PLN=1 To G301MAX-1
  PLAN = "[M:EVT0]FLGP"+num$(I_PLN)+"(nolign-1)"
  Assign PLAN With [F:EVT]FLGP(I_PLN-1)
 Next I_PLN
 GLIBPLN=""
Return

$LIENS2
 Sorta [M:EVT0]NBEVT [M:EVT0]NBEVT Order By [M:EVT0]EVT([S]indice)
 Affzo [M:EVT0]NBEVT
Return

#Gbn-290305-Bug n°29444
$RAZDUP
 Local Integer I_EVT, I_PLN
 Local Char    PLAN
 For I_EVT=1 To [M:EVT0]NBEVT
  If [M:EVT0]EVTFLGN(I_EVT-1)=G_NON & [M:EVT0]FLGPLAN(I_EVT-1)=G_OUI
   For I_PLN=1 To G301MAX-1
    PLAN = "[M:EVT0]FLGP"+num$(I_PLN)+"(I_EVT-1)"
    Assign PLAN With G_NON
   Next I_PLN
  Endif
 Next I_EVT
Return

$RAZCRE
 Raz [M:EVT0]CPY : Affzo [M:EVT0]CPY
 Local Integer NBEVT
 If !(clalev([F:ADI])) : Local File ATABDIV [ADI] : Endif
 Raz NBEVT
 Filter [ADI] Where NUMTAB=GTD_EVENT # Table diverse 962
 For [ADI]
  NBEVT+=1
  [M:EVT0]EVT(NBEVT-1)=[F:ADI]CODE
  [M:EVT0]FLGPLAN(NBEVT-1)=[F:ADI]N1
 Next
 [M:EVT0]NBEVT  = NBEVT
 Filter [ADI]
 Affzo [M:EVT0]
Return

$INICRE
 Local Integer I_PLN
 For I_PLN=1 To G301MAX-1
  [F:EVT]FLGP(I_PLN-1)=evalue("[M:EVT0]FLGP"+num$(I_PLN)+"(nolign-1)")
 Next I_PLN
Return

$SETBOUT
 #-> On ne peut pas supprimer le paramètrage par défaut
 If [M:EVT0]CPY=""
  Call VIREBOUT(CHAINE,"A") From GOBJET
 Endif
Return

$APRES_MODIF
# Contrôle habilitation / société
If COUZON="CPY"
  L_CPY=CZ
  Gosub AUZ_CPY
  If !OK : Return : Endif
Endif
Return

$AVANT_MOD
 # Contrôle habilitation / société
 L_CPY=[M:EVT0]CPY
 Gosub AUZ_CPY
 If !OK : Return : Endif
Return

$AUZ_CPY
# Fonction de contrôle de l'habilitation / société
If GNBAUZ <> GNBSITE : # Pas d'habilitation tous sites
  If L_CPY <> ""
    mkstat=0
    Call CONTALLFCY(L_CPY) From SUPCPT
    If mkstat : OK=0 : mkstat=0 : Endif
  Else
    # Vous n'êtes pas habilité pour la modification des paramètrages par défaut
    OK=0 : GMESSAGE=mess(113,7770,1)
  Endif
Endif
Return

##########################################################################
## Gestion du masque EVT
##########################################################################

#--> Init Société

Subprog D_EVTCPY(VALEUR)
Variable Char    VALEUR()
# VALEUR=[M:EVT0]CPY(0)
End

#--> Après-modif Société

Subprog AM_EVTCPY(VALEUR)
Variable Char    VALEUR()
End

#--> Avant zone Evénement

Subprog AV_EVT(VALEUR)
Variable Char    VALEUR()
 #*FQ-82871
 #* - on garde les pcolor pour l'appli. C/S
 #* - on ajoute un chgstl pour Convergence
 If [M:EVT0]FLGPLAN(nolign-1)=2
  Chgstl NBEVT(nolign-1)  With ""
  pcolor=GCOUL(0)
 Else
  Chgstl NBEVT(nolign-1)  With "AWARNLOW"
  pcolor=GCOUL(3)
 Endif
End

#--> Après-modif Géré (Evénement)

Subprog AM_EVTFLGN(VALEUR)
Variable Integer VALEUR
 Local Integer POK, I_PLN, PERSOFLG
 Local Char    NOM_ZONE
 Case VALEUR
  When G_OUI
   For I_PLN=1 To [M:EVT0]NBPLN
    [M:EVT0]PLNFLG(I_PLN)=G_OUI
    NOM_ZONE="[M:EVT0]FLGP"+num$([M:EVT0]PLN(I_PLN-1))+"(nolign-1)"
    Assign NOM_ZONE With G_OUI
   Next I_PLN
  When G_NON
   For I_PLN=1 To [M:EVT0]NBPLN
    [M:EVT0]PLNFLG(I_PLN)=G_NON
    NOM_ZONE="[M:EVT0]FLGP"+num$([M:EVT0]PLN(I_PLN-1))+"(nolign-1)"
    Assign NOM_ZONE With G_NON
   Next I_PLN
 Endcase
 Affzo [M:EVT0]15
End

#--> Après-modif Géré (Plan)

Subprog AM_PLNFLG(VALEUR)
Variable Integer VALEUR
 Local Char PLAN
 PLAN="[M:EVT0]FLGP"+num$([M:EVT0]PLN(nolign-1))+"([M:EVT0]I_EVT)"
 Assign PLAN With VALEUR

 Local Integer FLG   : Raz FLG
 Local Integer I_PLN : I_PLN

 If VALEUR=G_OUI
  FLG=1
 Else
  For I_PLN=1 To [M:EVT0]NBPLN
   If  I_PLN<>nolign & [M:EVT0]PLNFLG(I_PLN-1)=2
    FLG=1
   Endif
  Next I_PLN
 Endif

 If FLG
  [M:EVT0]EVTFLGN([M:EVT0]I_EVT)=2
 Else
  [M:EVT0]EVTFLGN([M:EVT0]I_EVT)=1
 Endif

 Affzo [M:EVT0]EVTFLGN([M:EVT0]I_EVT)

End

#--> Avant-saisie NBEVT (ABS tableau des événements)

Subprog AS_NBEVT
 [M:EVT0]I_EVT=nolign-1
 If [M:EVT0]FLGPLAN(nolign-1)=2                                   # Si l'evt est géré par plan
  Local Integer I_PLN, I_PLNTAB
  Raz I_PLNTAB
  For I_PLN=1 To G301MAX-1                                        # On boucle sur les plans définis
   If [M:EVT0]CPY<>""
    If func GLOBIENS.CPY_PLN_GERE([M:EVT0]CPY,I_PLN)=G_OUI
     I_PLNTAB+=1
     [M:EVT0]PLN(I_PLNTAB-1)    = I_PLN
     [M:EVT0]PLNFLG(I_PLNTAB-1) = evalue("[M:EVT0]FLGP"+num$(I_PLN)+"(nolign-1)")
    Endif
   Else
    I_PLNTAB+=1
    [M:EVT0]PLN(I_PLNTAB-1)    = I_PLN
    [M:EVT0]PLNFLG(I_PLNTAB-1) = evalue("[M:EVT0]FLGP"+num$(I_PLN)+"(nolign-1)")
   Endif
  Next I_PLN

  [M:EVT0]NBPLN=I_PLNTAB
  Chgtbk [M:EVT0]15 With mess(148,7770,1)-[M:EVT0]EVT(nolign-1) # Activation par plan pour l'événement
  Affzo [M:EVT0]15
 Else
  Chgtbk [M:EVT0]15 With ""
  Effzo [M:EVT0]15
 Endif
End

#--> Avant-zone géré (Tableau événement)

Subprog AV_EVTFLGN(VALEUR)
Variable Integer VALEUR
## Gbn-23092004 - Amélioration 24997
# If [M:EVT0]FLGPLAN(nolign-1)=2
#  Diszo [M:EVT0]EVTFLGN(nolign-1)
# Else
#  Actzo [M:EVT0]EVTFLGN(nolign-1)
# Endif
End

#--> Avant-saisie géré (Tableau événement)

Subprog AS_EVTFLGN(VALEUR)
Variable Integer VALEUR
# If [M:EVT0]FLGPLAN(nolign-1)=2
#  mkstat=2
# Else
#  mkstat=0
# Endif
End

#--> Avant-saisie géré (Plan)

Subprog AS_PLNFLG(VALEUR)
Variable Integer VALEUR
If [M:EVT0]CPY<>""
 If func GLOBIENS.CPY_PLN_GERE([M:EVT0]CPY,[M:EVT0]PLN(nolign-1))=G_NON
  VALEUR = 1
  mkstat = 2
 Elsif func GLOBIENS.CPY_PLN_GERE([M:EVT0]CPY,[M:EVT0]PLN(nolign-1))=G_OUI
  mkstat = 0
 Endif
Endif
End

##########################################################################
## S/P et routines communes.
##########################################################################

Subprog CHARGE_PLAN(PCPY,PPLN)
Value  Char    PCPY
Value  Integer PPLN
Local  Integer I_PLN

End

#
# S/p renvoyant le flag de gestion de l'événement pour le plan (si l'evt est géré par plan)
#
Funprog IS_EVT_GERE(PCPY,PEVT,PPLN)
Value Char    PCPY
Value Char    PEVT
Value Integer PPLN

Local Integer IS_GERE : IS_GERE=G_NON

If !clalev([F:EVT]) : Local File EVENT [EVT] : Endif

Read [EVT]EVT0=PCPY;PEVT  # On cherche le couple CPY/EVT dans la table EVENT
If fstat=5
 If PCPY=""
  End IS_GERE
 Else
  Read [EVT]EVT0="";PEVT  # On cherche le couple ""/EVT dans la table EVENT si on a pas trouvé CPY/EVT
  If fstat=5
   End IS_GERE
  Elsif fstat=0
   Case [F:EVT]FLGPLAN
    When G_OUI                                              # Evénement géré par plan
     If [F:EVT]FLGP(PPLN-1)= G_OUI : IS_GERE=G_OUI : Endif  # Evénénement activé pour le plan
    When G_NON                                              # Evénement non géré par plan
     If [F:EVT]EVTFLGN=G_OUI : IS_GERE=G_OUI : Endif        # Evénément activé
   Endcase
  Endif
 Endif
Elsif fstat=0
 Case [F:EVT]FLGPLAN
  When G_OUI                                              # Evénement géré par plan
   If [F:EVT]FLGP(PPLN-1)= G_OUI : IS_GERE=G_OUI : Endif  # Evénénement activé pour le plan
  When G_NON                                              # Evénement non géré par plan
   If [F:EVT]EVTFLGN=G_OUI : IS_GERE=G_OUI : Endif        # Evénément activé
 Endcase
Endif

End IS_GERE
