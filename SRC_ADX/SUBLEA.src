Subprog AM_RPUDAT(VALEUR)
Variable Date    VALEUR

  If ( VALEUR <> [0/0/0] &  [M:LEA0]LEATYP <> GVML_CREBAIL  ) Then
    GERR= 1
    GMESSAGE= mess(38, GML_MSGGRT, 1)
    mkstat = 2
    End
  Endif

End

