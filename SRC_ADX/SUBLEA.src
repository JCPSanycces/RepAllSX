#
#=====================================================================
# R1010 - Site financier :non saisissable en modification
#========================================================================
Subprog AV_FCY(VALEUR)
Variable Char    VALEUR()

  Affzo [M:LEA0]ZCPY

End

#==========================================================================
# C_ Site financier : Contrôles
#==========================================================================
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

  Local Integer ISITE, OK
  Local Char    SOCIETE (GLONCPY)

  # Recherche de la société du site
  ISITE = find(VALEUR,GSITE(1..GNBSITE))
  If ISITE
    SOCIETE = GSOCSITE(ISITE)
  Else
    GMESSAGE = mess(15,104,1) : # Site inexistant
    mkstat = 2 : End
  Endif

  # La duplication ne peut avoir lieu que sur un site financier appartenant à la même société
  If (GREP = 'D' and VALEUR <> [M:LEA0]FCY) Then
    If ( GCOUSOC <> SOCIETE ) Then
      # Site financier invalide
      GERR= 1: GMESSAGE = mess(19,GML_MSGFAS,1)
      mkstat = 2 : End
    Endif
  Endif

  # Issue X3-77642
  If ([M:LEA0]CPY <> "" and SOCIETE <> [M:LEA0]CPY) Then
    # Site financier invalide
    GERR= 1: GMESSAGE = func GLOFUNC.SUBSTIT1(mess(171,104,1), [M:LEA0]CPY)
    mkstat = 2 : End
  Endif
  # End issue X3-77642

  [M:LEA0]CPY= SOCIETE

  Call ACTION_FCY (VALEUR, [M:LEA0]CPY) From GLOFCYCPY

  ##Fq-6108 La société doit avoir un plan IAS si le pays est "FR"
  #Fq-61084   If GCNXPROIAS = G_NON and
  #Fq-6108&     ( func GLOFCYCPY.GET_SOC_PAYS([M:LEA0]CPY) = "FR" or func GLOFCYCPY.GET_SOC_LEG([M:LEA0]CPY) = "FRA" )
  #Fq-6108
  #Fq-6108  # Aucun plan ne correspond à la norme IAS/IFRS pour cette société
  #Fq-6108  GERR= 1: GMESSAGE = mess(401,GML_MSGFAS,1)
  #Fq-6108  mkstat = 2 : End
  #Fq-6108Endif

  # Activation CLF même si pas de gestion de l'IAS
  # Contrôle de l'existence du contexte IAS/IFRS
  OK=1

End

#==========================================================================
# R1020 - Site financier : le site doit être dépendant d'une société pour
# laquelle le contexte IAS est géré
#==========================================================================
Subprog AP_FCY(VALEUR)
Variable Char    VALEUR()
Local Date    PCPTDAT(1..5)
Local Date    PIASDAT(1..5)
Local Integer PRET1, PRET2

  LSOC = [M:LEA0]CPY
  #
  # Valeurs des variables globales en fonction du site
  #
  Call ACTION_FCY (VALEUR, [M:LEA0]CPY) From GLOFCYCPY

  # FQ79404 Rechargement de FPC
  If [M:FPC]CPY=""
    Local Integer ERR
    Call LOAD_FASPARCPY([M:LEA0]CPY,"",G_NON,ERR) From GLOFCYCPY
  Endif
  #
  # Récupération de la devise société
  #
  If GCNXCURCPF <> ""
    [M:LEA0]CUR    = [V]GCNXCURCPF # Devise société
  Endif
  GDEVFMTC="13.2"
  GDEVFMTC = GDEVFMT1(max(find([M:LEA0]CUR, GDEVISE(1..GNBDEV)), 1))  : # X3-77642
  If GCNXPROIAS = G_OUI
    [M:LEA0]IASCUR = [V]GCNXCURIAS
    GDEVFMTI="13.2"
    GDEVFMTI = GDEVFMT1(max(find([M:LEA0]IASCUR,GDEVISE(1..GNBDEV)),1))  : # X3-77642
  Endif # Devise société

  #
  # Récupération de la date de fin de l'exercice courant
  # et de la date de fin de la période courante du contexte IAS
  # pour l'affichage de la valeur d'entrée IAS des biens rattachés au contrat
  #
  [M:LEA0]FIYENDCPT = [0/0/0]
  [M:LEA0]PERENDCPT = [0/0/0]
  [M:LEA0]FIYENDIAS = [0/0/0]
  If GCNXPROIAS = G_OUI : [M:LEA0]PERENDIAS = [0/0/0] : Endif

  Call GET_CNX_DAT([M:LEA0]CPY,G300CPFI,PCPTDAT,PRET2) From GLOBIENS
  [M:LEA0]FIYENDCPT = PCPTDAT(2)
  If PCPTDAT(4) <> [0/0/0]
     [M:LEA0]PERENDCPT = PCPTDAT(4)
  Else
     [M:LEA0]PERENDCPT = PCPTDAT(2)
  Endif

  If GCNXPROIAS = G_OUI
     # Récupération dates fin période et fin exercice courant
     # pour alimenter CPTDATINT dans les événements
     Call GET_CNX_DAT([M:LEA0]CPY,G300IAS,PIASDAT,PRET1) From GLOBIENS
     [M:LEA0]FIYENDIAS = PIASDAT(2)
     If PIASDAT(4) <> [0/0/0]
        [M:LEA0]PERENDIAS= PIASDAT(4)
     Else
        [M:LEA0]PERENDIAS= PIASDAT(2)
     Endif
  Endif

  Affzo [M:LEA0]
  #Infbox "AP_FCY"
  Gosub INIT_GENERALE

End
#==========================================================================
# AM_ Site financier : c'est pour mettre à jour dynamiquement la désignation
#                      de la société lorsqu'on a modifié le site financier
#==========================================================================
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  Local Char LSOC

  # Affichage de l'intitulé société (non pris en compte par les actions associées au type de donnée BFC)
  If dim([M:LEA0]ZCPY) > 0
    Affzo [M:LEA0]ZCPY
  Endif

  # Affichage des valeurs par defaut dépendant de l'établissement
  [M:LEA0]FCY = VALEUR
  #CBO 2012.06.25
  Local Integer ERR
  Call LOAD_FASPARCPY([M:LEA0]CPY,"",G_NON,ERR) From GLOFCYCPY
  #CBO 2012.06.25
  #Infbox "AM_FCY"
#  # X3-77642 Company without context is forbidden
#  If (GCNXPROCPF <> G_OUI) Then
#    GERR     = 1
#    GMESSAGE = mess(1,7772, 1)
#    mkstat   = 2
#  Endif
  Gosub INIT_GENERALE

End
#*************************************
#*     INITIALISATION GENERALE       *
#*************************************
$INIT_GENERALE

Local Integer I_CNXIAS

  #Infbox "INIT_GENERALE conditionne IAS"
  #--------------------------------
  #   Contexte comptable et Fiscal
  # ----- Lecture contexte CPFI
  #--------------------------------

  Read [CNX]CNX0=[M:LEA0]CPY;G300CPFI
  If ( fstat )  : Raz [F:CNX] : Endif
  [M:LEA1]CURTYP=[F:CNX]CURTYP : Affzo [M:LEA1]CURTYP

  # -----  Initialisation devise société
  #* Récupération de la devise société et de la devise IAS
  [M:LEA0]CUR    = GCOUDEV     : Affzo [M:LEA0]CUR
  [M:LEA1]CUR    = GCOUDEV     : Affzo [M:LEA1]CUR
  [M:LEA3]CUR    = GCOUDEV     : Affzo [M:LEA3]CUR   : # X3-84302
  [M:LEA5]CUR    = GCOUDEV     : Affzo [M:LEA5]CUR   : # X3-84302
  GDEVFMTC="13.2"
  GDEVFMTC = GDEVFMT1(max(find([M:LEA0]CUR, GDEVISE(1..GNBDEV)), 1))  : # X3-77642
  If ( GCNXPROIAS = G_OUI) Then
    [M:LEA0]IASCUR = GCNXCURIAS  : Affzo [M:LEA0]IASCUR
    [M:LEA1]IASCUR = GCNXCURIAS  : Affzo [M:LEA1]IASCUR
    [M:LEA3]IASCUR  = GCNXCURIAS  : Affzo [M:LEA3]IASCUR    : # X3-84302
    [M:LEA3]IASCUR2 = GCNXCURIAS  : Affzo [M:LEA3]IASCUR2   : # X3-84302
    [M:LEA5]IASCUR  = GCNXCURIAS  : Affzo [M:LEA5]IASCUR    : # X3-84302
    GDEVFMTI="13.2"
    GDEVFMTI = GDEVFMT1(max(find([M:LEA0]IASCUR, GDEVISE(1..GNBDEV)), 1))  : # X3-77642
  Endif

  # Détermination du taux en fonction du  type de cours
  If [M:LEA1]LEACUR <> ""
    Call CDVCAL( [M:LEA1]RATCUR, [M:LEA1]LEACUR, [M:LEA1]CUR, [M:LEA0]CPY, [M:LEA1]CURTYP,  [M:LEA1]STRLEADAT  )
&                From TRTDIV
  Else
    [M:LEA1]RATCUR = 1
  Endif
  Affzo [M:LEA1]RATCUR
  #--------------------------
  #   Plan IAS géré
  #--------------------------
  If GCNXPROIAS = G_OUI
    # ----- Lecture contexte IAS
    For [CNX]CNX0 Where CPY= [M:LEA0]CPY
      I_CNXIAS = find(G301IAS,[F:CNX]PLNCAA)
      If I_CNXIAS > 0 : Break : Endif
    Next
    [M:LEA1]IASCURTYP=[F:CNX]CURTYP : Affzo [M:LEA1]IASCURTYP
    # Détermination du taux en fonction du  type de cours IAS
    If [M:LEA1]LEACUR <> ""
      Call CDVCAL( [M:LEA1]IASRATCUR, [M:LEA1]LEACUR, [M:LEA1]IASCUR, [M:LEA0]CPY, [M:LEA1]IASCURTYP,
&                  [M:LEA1]STRLEADAT  ) From TRTDIV
      Affzo [M:LEA1]IASRATCUR : Diszo [M:LEA1]IASRATCUR
    Else
      [M:LEA1]IASRATCUR    = 1
    Endif
    Affzo  [M:LEA1]IASRATCUR : Diszo [M:LEA1]IASRATCUR
  Else
    #*Fq-61084
    [M:LEA1]IASCUR       = ""      :  Affzo [M:LEA1]IASCUR
    Raz [M:LEA1]IASRATCUR          :  Affzo [M:LEA1]IASRATCUR
    Raz [M:LEA1]IASCURTYP          :  Affzo [M:LEA1]IASCURTYP
  Endif

  Gosub MANAGE_IAS_FIELDS

  #>FQ98512 Chargement du tableau des axes et sections analytiques
  Local Integer LNBRLEA
  Call LOAD_TAB_CCE("[F:LEA]", "[M:FPC]", "[M:LEA4]", LNBRLEA) From GLOBIENSANA
  [M:LEA4]NBRCCE = LNBRLEA
  Affzo  [M:LEA4]

Return
#*********************************************
Subprog C_LEAREF(VALEUR)
Variable Char    VALEUR()

  If GLEAAUTNUM=1 and VALEUR=""
    GERR     = 1
    GMESSAGE = mess(3,GML_MSGFAS, 1)
    mkstat   = 2
  Endif

End
#
#=============================================================================
# AM_LEATYP : si on passe en crédit-bail : avertissement si certaines rubriques
# sont renseignées
#=============================================================================
Subprog AM_LEATYP(VALEUR)
Variable Integer VALEUR

  Local Integer OK
  Local Integer LLEATYP

  LLEATYP = [M:LEA0]LEATYP

  # Détachez les biens avant de modifier le type de contrat
  If [M:LEA1]CUMIASBSE > 0  or [M:LEA3]NBLIG3 > 0
    GERR= 1
    GMESSAGE= mess(65, GML_MSGGRT, 1)
    [M:LEA0]LEATYP = LLEATYP
    Affzo [M:LEA0]LEATYP
    mkstat = 2
    End
  Endif


  If VALEUR <> GVML_CREBAIL
    If [M:LEA1]LEAAMT > 0 or [M:LEA1]RPUVAL > 0 or [M:LEA1]RPUDAT <> [0/0/0]
      Call AVERTIR (mess(59,GML_MSGGRT,1), OK) From GESECRAN
      If OK=1
        mkstat = 2
        End
      Endif
    Endif

  # Issue start X3-111936
# Call ACTION_BLOCK(ACB_EFFZO, "LEA1", "RPUVAL") From GLOBIENS
# Call ACTION_BLOCK(ACB_DISZO, "LEA1", "RPUVAL") From GLOBIENS
  Effzo [M:LEA1]RPUVAL : Effzo [M:LEA1]RPUVALDEV : Effzo[M:LEA1]RPUVALIAS
  Diszo [M:LEA1]RPUVAL : Diszo [M:LEA1]RPUVALDEV : Diszo[M:LEA1]RPUVALIAS
  # End issue X3-111936

    [M:LEA1]RPUDAT = [0/0/0]
    Diszo [M:LEA1]RPUDAT
    Affzo [M:LEA1]RPUDAT
  Else
    Actzo [M:LEA1]LEACUR,LEAAMT,RPUVAL,RPUDAT
  Endif


  # Issue 77642
  If (VALEUR = GVML_LOCATION) Then
    [M:LEA2]LEACUR2 = [M:LEA1]LEACUR
    [M:LEA2]CUR2    = [M:LEA1]CUR
    [M:LEA2]IASCUR2 = [M:LEA1]IASCUR
  Endif
  # End issue 77642


  [M:LEA0]LEATYP = VALEUR
  Call DISPLAY_CASE_LOCATION([M:LEA0]LEATYP)   # Issue X3-68588
  Gosub MANAGE_LOCATION_FIELDS                 # Issue X3-68589
#  Call EVALUE_SUMPAY_ARRAY  ([M:LEA0]LEATYP)   # Issue X3-70469
#  Call EVALUE_CVAYEA        ([M:LEA0]LEATYP,0) # Issue X3-70469

  Affzo [M:LEA2]

End
#=======================================================
# R2010 - AS_Statut du contrat
#=======================================================
#
Subprog AS_LEASTA(VALEUR)
Variable Integer VALEUR

  # l'utilisateur ne peut passer que de "à valider" à "encours"
  If !GIMPORT
    Raz GMENLOC
    GMENLOC(3)=1 :  GMENLOC(4)=1   :  GMENLOC(5)=1 : GMENLOC(6)=1

    # X3-72994
    If [M:LEA0]LEASTA = GVML_STENCOU and GLEACRT = G_NON
      GMENLOC(1)=1
    Endif
  Endif

End
#===============================================================
# R2011 - AM_Statut du contrat : n'est plus modifiable dès lors
# qu'il devient différent de "à valider" ou "encours"
#==============================================================
Subprog AM_LEASTA(VALEUR)
Variable Integer VALEUR

  If (VALEUR = GVML_STENCOU) & ([M:LEA0]LEASTA = GVML_STAVAL)
    GLEACRT = G_OUI
  Else
    GLEACRT = G_NON
  Endif

  If (  VALEUR <> GVML_STAVAL & VALEUR <> GVML_STENCOU) Then
    Diszo [M:LEA0]LEASTA   :  Affzo [M:LEA0]LEASTA
  Else
    Actzo [M:LEA0]LEASTA   :  Affzo [M:LEA0]LEASTA
  Endif

  If VALEUR <> GVML_STAVAL
    If [M:LEA1]STRLEADAT <> [0/0/0]
      Diszo [M:LEA1]STRLEADAT
    Else
      Actzo [M:LEA1]STRLEADAT
    Endif
    If [M:LEA1]ENDLEADAT <> [0/0/0]
      Diszo [M:LEA1]ENDLEADAT
    Else
      Actzo [M:LEA1]ENDLEADAT
    Endif

    If [M:LEA1]LEAAMT <> 0
      Diszo [M:LEA1]LEACUR
      Diszo [M:LEA1]LEAAMT
      Diszo [M:LEA1]RPUVAL
      Diszo [M:LEA1]RPUDAT
    Else
      Actzo [M:LEA1]LEAAMT
    Endif
  Else
#    Issue X3-71287
#    If [M:LEA1]CUMIASBSE <> 0
      Actzo [M:LEA1]STRLEADAT
      Actzo [M:LEA1]ENDLEADAT
      Actzo [M:LEA1]LEAAMT
#    Endif
  Endif

  Affzo [M:LEA1]

End

######################################################################################
#FQ61803
Subprog AS_LEADES(VALEUR)
Variable Char    VALEUR()

  If GDEBUG<>G_OUI : GBOUT1 = "" : Endif

End

##########################################################################
#
#*********************************************************************
#                     E C R A N      L E A 1
#*********************************************************************
#===========================================================================
## AS_poste bilan : suppression des postes non compatibles avec la nature
#==========================================================================
Subprog AS_BSENAT(VALEUR)
Variable Integer VALEUR

  If !GIMPORT
    If [M:LEA1]LEANAT = 1
      GMENLOC(2)=1 : GMENLOC(3)=1  :  GMENLOC(4)=1 :  GMENLOC(5)=1 :  GMENLOC(6)=1
    Else
      GMENLOC(1)=1
    Endif
  Endif

End
#=======================================================
# C_Date de début du contrat
#=======================================================
#
Subprog C_STRLEADAT(VALEUR)
Variable Date     VALEUR

  Local Integer OK

  #
  # La date de début doit être < à la date de fin lorsque celle-ci est renseignée
  #
  If (VALEUR <> [0/0/0] &  VALEUR >= [M:LEA1]ENDLEADAT & [M:LEA1]ENDLEADAT <> [0/0/0]  )
    GERR= 1
    GMESSAGE= mess(33, GML_MSGGRT, 1)
    mkstat = 2 : End
  Endif

  #
  # R2010 - Demande de confirmation lorsque la date de début du contrat est <
  #              à la date de début de l'exercice courant du contexte IAS
  If GCNXPROIAS = G_OUI
    If (VALEUR < GDEBEXEIAS  ) and !GIMPORT : # FQ80815 : ajout de !GIMPORT pour passer l'avertissement en import
      Call AVERTIR (mess(32,GML_MSGGRT,1), OK) From GESECRAN
      If OK=1
        mkstat=2 : End
      Endif
    Endif
  Endif

End
#=======================================================
# AM_ Date de début du contrat
#=======================================================
#
Subprog AM_STRLEADAT(VALEUR)
Variable Date     VALEUR

  Local Integer OK
  Local Date LSTRDATO

  # Si modification de la Date début, on envoie le message :
  #     "Votre modification de la Date début va réinitialiser l'échéancier : confirmez-vous ? "
  #     - Si la réponse est Oui, l'échéancier est remis à vide
  #     - Si la réponse est Non, la nouvelle date n'est pas prise en compte : on ré-alimente l'ancienne et l'échéancier
  #     n'est pas modifié
  #
  If  (VALEUR <> [M:LEA1]STRLEADAT)  &  ([M:LEA2]NBPER2 > 0)
    LSTRDATO  = [M:LEA1]STRLEADAT
    Call OUINON (mess(36,GML_MSGGRT,1), OK) From GESECRAN
    If ( OK <> 1 )
      # réponse = "oui"
      [M:LEA1]STRLEADAT= VALEUR
      Affzo  [M:LEA1]STRLEADAT
      Gosub RAZ_LEA2   : # Issue X3-70469
      # Issue X3-77642
      Gosub INIT_GENERALE
      Call AP_LEAAMT([M:LEA1]LEAAMT)
      Call AM_RPUVAL([M:LEA1]RPUVAL)
      # End issue X3-77642
    Else
      # réponse = "non"
      [M:LEA1]STRLEADAT = LSTRDATO
      Affzo  [M:LEA1]STRLEADAT
      mkstat = 2 : End
    Endif
  Endif

End

#=======================================================
# C_ Date de fin du contrat
#=======================================================
#
Subprog C_ENDLEADAT(VALEUR)
Variable Date     VALEUR

  #
  # La date de fin doit être > à la date de début
  #
  If ( VALEUR <= [M:LEA1]STRLEADAT ) Then
    GERR= 1
    GMESSAGE= mess(33, GML_MSGGRT, 1)
    mkstat = 2
    End
  Endif

End
#=======================================================
# AM_ Date de fin du contrat
#=======================================================
#
Subprog AM_ENDLEADAT(VALEUR)
Variable Date     VALEUR

  Local Integer OK, I, J, NOL
  Local Date LENDDATO

  #
  # Suite à une modification, le sytème propose de réinitialiser l'échéancier s'il existe
  #

  # Issue X3-84300
  #If  (VALEUR <> [0/0/0]) &  (GREP=""  or  GREP="M") & ([M:LEA2]NBPER2 > 0)
  If  (VALEUR <> [0/0/0]) &  (GREP="" or GREP="M" or GREP="D") & ([M:LEA2]NBPER2 > 0)

    # Si  modification de la Date fin et nouvelle Date < ancienne date, on envoie le message :
    #     "Votre modification de la Date fin va supprimer les échéances postérieures à cette nouvelle date :
    #     confirmez-vous ? "
    #     - Si la réponse est Oui, les échéances postérieures à la nouvelle date fin sont supprimées
    #     - Si la réponse est Non, la nouvelle date n'est pas prise en compte : on ré-alimente l'ancienne et l'échéancier
    #     n'est pas modifié
    #
    If  VALEUR < [M:LEA1]ENDLEADAT
      LENDDATO = [M:LEA1]ENDLEADAT
      Call OUINON (mess(62,GML_MSGGRT,1), OK) From GESECRAN
      If ( OK = G_OUI ) Then
        # réponse = "oui"
        NOL = 0
        While NOL <= [M]NBPER2-1
          If  [M:LEA2]STRPERDAT(NOL) >= VALEUR
            [M:LEA2]CUMRNTAMT -= [M:LEA2]RNTAMT(NOL) : # Issue X3-84300
            Dela NOL,1,[M]NBPER2-1 [M]NBPER2
            [M]NBPER2-= 1
          Else
            NOL += 1
          Endif
        Wend
        [M:LEA2]NBPER2 = NOL
        [M:LEA2]ENDPERDAT(NOL-1) = VALEUR
        Affzo  [M:LEA2]ENDPERDAT(NOL-1)

        # Issue X3-84300
        Call EVALUE_SUMPAY_ARRAY([M:LEA0]LEATYP)
        Call EVALUE_CVAYEA ([M:LEA0]LEATYP,0)
        Affzo [M:LEA2]
        # End issue X3-84300

      Else
        # réponse = "non"
        [M:LEA1]ENDLEADAT = LENDDATO
        Affzo [M:LEA1]ENDLEADAT
        mkstat = 2 : End
      Endif

    Else
      #
      # Si modification de la Date fin et nouvelle Date > ancienne date, on le message d'information :
      #     "Votre échéancier devra être complété compte tenu de la prolongation de votre contrat."
      #
      LENDDATO = [M:LEA1]ENDLEADAT
      Call AVERTIR (mess(63,GML_MSGGRT,1), OK) From GESECRAN
      If ( OK = G_OUI ) Then
        # réponse = "OK"
        Affzo  [M:LEA1]

        # Issue X3-84302 start

        # Ajout des lignes

        nolign = [M:LEA2]NBPER2
        [M:LEA1]ENDLEADAT = VALEUR
        While [M:LEA1]ENDLEADAT > [M:LEA2]ENDPERDAT(nolign-1)
          If [M:LEA2]STRPERDAT(nolign-1) <> [0/0/0] & [M:LEA2]ENDPERDAT(nolign-1) <> [0/0/0]
            Call PER_CALCUL_POIDS () From SUBLEA
            Call CALCUL_DATES_ECHEANCE ([M]STRPERDAT(nolign-1),[M]ENDPERDAT(nolign-1),[M]NBRMONPER(nolign-1)) From SUBLEA
          Endif
        Wend

        [M:LEA2]NBPER2 = nolign
        [M:LEA2]ENDPERDAT([M:LEA2]NBPER2-1) = [M:LEA1]ENDLEADAT

        Call EVALUE_SUMPAY_ARRAY([M:LEA0]LEATYP) From SUBLEA
        Call EVALUE_CVAYEA ([M:LEA0]LEATYP,0) From SUBLEA
        Affzo [M:LEA2]
        # End issue X3-84302

      Else
        # réponse = "Annuler"
        [M:LEA1]ENDLEADAT = LENDDATO
        Affzo [M:LEA1]ENDLEADAT
        mkstat = 2 : End
      Endif
    Endif
  Endif

  Affzo  [M:LEA2]NBPER2

End
#
#=================================================================
# C_ Montant du capital emprunté : doit être obligatoirement renseigné
# si type contrat = "crédit-bail"
#=================================================================
#
Subprog C_LEAAMT(VALEUR)
Variable Decimal VALEUR

  If [M:LEA0]LEATYP = GVML_CREBAIL
    If  VALEUR = 0
      GERR= 1
      GMESSAGE= mess(41, GML_MSGGRT, 1)
      mkstat = 2 :  End
    Endif
  Endif

End
