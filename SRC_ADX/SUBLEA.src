#
#*********************************************************************
#                     E C R A N      L E A 2
#*********************************************************************
#
#===============================================================================
#
Subprog AS_NBPER2

  # l'option  "Reporter échéances"  n'est accessible que si la 1ère échéance est renseignée
  # et que le contrat n'a pas été actualisé
  If [M:LEA2]RNTAMT(0) = 0
    GBOUT1=""
  Endif
  # l'option  "RAZ périodes "  n'est accessible que si le contrat n'a pas été actualisé
  If [M:LEA1]CUTDAT(0) <> [0/0/0]
    GBOUT2=""
  Endif

End

######################################################################################
# pour éviter qu'un escape sur la 1ère ligne du tableau de l'échéancier remette à blanc
# la 1ère ligne et laisse les lignes d'échéances suivantes (dates de début et de fin)
######################################################################################
Subprog APRES_NBPER2

  # Issue X3-70469
  If ([M:LEA2]NBPER2 <> 0) Then
    Local Integer NOL

    NOL= nolign-1

    If NOL = 0
      If [M:LEA2]STRPERDAT(0) = [0/0/0] & GDPERDAT0 <> [0/0/0]
        [M:LEA2]STRPERDAT(0) = GDPERDAT0
        Affzo [M:LEA2]STRPERDAT(0)
      Endif

      If [M:LEA2]ENDPERDAT(0) = [0/0/0] & GFPERDAT0 <> [0/0/0]
        [M:LEA2]ENDPERDAT(0) = GFPERDAT0
        Affzo [M:LEA2]ENDPERDAT(0)
      Endif

      If ([M:LEA0]LEATYP = GVML_CREBAIL) Then : # X3-84302
        If [M:LEA1]LEAAMT <> 0  #FQ104388
          [M:LEA2]RMNTPA(0) = [M:LEA1]LEAAMT
        Endif
      Endif

      If [M:LEA2]STRPERDAT(0) <> [0/0/0] & [M:LEA2]ENDPERDAT(0) <> [0/0/0]
        Call PER_CALCUL_POIDS ()
        Call CALCUL_DATES_ECHEANCE ([M]STRPERDAT(0),[M]ENDPERDAT(0),[M]NBRMONPER(0))
      Endif
      Affzo [M:LEA2]NBPER2
    Endif
  Endif

End

######################################################################################
#===============================================================================
# R3000 -  B1_ Reporter échéances :  à partir d'une ligne quelconque de l'échéancier,
#              cette action permet la génération automatique des échéances suivantes
#              jusqu'à la date de fin du contrat
#===============================================================================
Subprog B1_NBPER2

  # Reporter redevances
  # X3-84302
  #If  ([M:LEA0]LEATYP <> GVML_CREBAIL and [M:LEA0]LEATYP <> GVML_LOCATION) and ( [M:LEA2]RMNTPA(0) <= 0 )
  If  ([M:LEA0]LEATYP = GVML_CREBAIL and [M:LEA2]RMNTPA(0) <= 0 )
    # Si crédit bail et montant à rembourser inférieur ou égal à 0
    End
  Endif

  Local Integer I
  Local Decimal LRNTAMT, LFINDPR, LFINEXS, NBRWEKPER, NBRDAYPER
  Local Char LTRT

  Local Decimal LVARPAY, LRSDVAL, LTERPEN, LPUROPT   : # X3-70469

  #*-----------------------------------------------------------------
  # il faut obligatoirement être positionné sur une ligne
  # d'échéances renseignée pour effectuer la génération automatique
  # des échéances suivantes ==> si cela n'est pas le cas, on
  # décrémente nolign jusqu'à trouver une échéance renseignée
  #*-----------------------------------------------------------------

  While [M:LEA2]RNTAMT(nolign-1)= 0 and nolign > 1
    nolign -=1
  Wend

  LRNTAMT = [M:LEA2]RNTAMT(nolign-1)
  If  ([M:LEA0]LEATYP = GVML_LOCATION)
    # Issue X3-77642
    Local Decimal LVARPAY, LRSDVAL, LTERPEN, LPUROPT
    LVARPAY = [M:LEA2]VARPAY(nolign-1)
    LRSDVAL = [M:LEA2]RSDVAL(nolign-1)
    LTERPEN = [M:LEA2]TERPEN(nolign-1)
    LPUROPT = [M:LEA2]PUROPT(nolign-1)
    # End issue X3-77642
  Else
    LFINDPR = [M:LEA2]FINDPR(nolign-1)
    LFINEXS = [M:LEA2]FINEXS(nolign-1)
  Endif

  NBRWEKPER =  [M:LEA2]NBRWEKPER(nolign-1)
  NBRDAYPER =  [M:LEA2]NBRDAYPER(nolign-1)
  nolign += 1

  For I = nolign To [M:LEA2]NBPER2
    If ( [M:LEA2]FARFLG(nolign-1) <> G_OUI  and [M:LEA2]FARFLGI(nolign-1) <> G_OUI )
    # X3-84302    (Later)
    # If ( [M:LEA2]FARFLG(nolign-1) <> G_OUI  and [M:LEA2]FARFLGI(nolign-1) <> G_OUI and
    #&     [M:LEA2]PAYDAT(nolign-1) = [0/0/0]  and  [M:LEA2]PAYREF(nolign-1) = "" ) Then
      [M:LEA2]RNTAMT(nolign-1) = LRNTAMT
      If  ([M:LEA0]LEATYP = GVML_LOCATION)
        # Issue X3-77642 Location longue durée & location
        [M:LEA2]VARPAY(nolign-1) = LVARPAY
        [M:LEA2]RSDVAL(nolign-1) = LRSDVAL
        [M:LEA2]TERPEN(nolign-1) = LTERPEN
        [M:LEA2]PUROPT(nolign-1) = LPUROPT
        # End issue X3-77642
      Else
        [M:LEA2]FINDPR(nolign-1) = LFINDPR
        [M:LEA2]FINEXS(nolign-1) = LFINEXS
      Endif
    Endif
    nolign += 1
  Next I

  If  ([M:LEA0]LEATYP = GVML_CREBAIL) #FQ104388
    Call CALCUL_ECHEANCIER
  Endif

  # Issue X3-70469
  Local Integer I_L
  Raz [M:LEA2]CUMRNTAMT
  For I_L = 1 To [M:LEA2]NBPER2
     [M:LEA2]CUMRNTAMT += [M:LEA2]RNTAMT(I_L-1)
  Next I_L
  Affzo [M:LEA2]CUMRNTAMT

  # Issue X3-70469
  Call EVALUE_SUMPAY_ARRAY([M:LEA0]LEATYP)
  # Issue 70469
  Call EVALUE_CVAYEA ([M:LEA0]LEATYP,0)

  Affzo [M:LEA2]

  # Issue X3-70469
   mkstat = 4

End
#
#=============================================================================
# R4000 - B2_ RAZ Périodes : cette action permet la suppression des périodes de l'échéancier
# à condition que le statut du contrat soit "à valider ou "en cours"
# et que le contrat n'ait pas subi d'actualisation
#=============================================================================
#
Subprog B2_NBPER2
Local Integer N_I

  # Remettre à zéro redevances

  If (([M:LEA0]LEASTA <> GVML_STAVAL) &  ([M:LEA0]LEASTA <> GVML_STENCOU)) or ([M:LEA1]CUTDAT > [0/0/0])
    GERR= 1
    GMESSAGE= mess(49, GML_MSGGRT, 1)
    mkstat = 2
    End
  Endif

  For N_I=[M:LEA2]NBPER2-1 To 0 Step -1
      If [M:LEA2]FARFLG(N_I) <> G_OUI and [M:LEA2]FARFLGI(N_I) <> G_OUI
      # X3-84302    (Later)
      #If ( [M:LEA2]FARFLG(nolign-1) <> G_OUI  and [M:LEA2]FARFLGI(nolign-1) <> G_OUI and
      #&    [M:LEA2]PAYDAT(nolign-1) = [0/0/0]  and  [M:LEA2]PAYREF(nolign-1) = "" ) Then
      #  Issue X3-70469
      Raz [M:LEA2]STRPERDAT(N_I), ENDPERDAT(N_I), RNTAMT(N_I)
      If ([M:LEA0]LEATYP = GVML_LOCATION) Then
        Raz [M:LEA2]VARPAY(N_I), RSDVAL(N_I), TERPEN(N_I), PUROPT(N_I)
        Raz [M:LEA2]LEAYEA(N_I), SUMPAY(N_I)
      Else
        Raz [M:LEA2]RMNTPA(N_I), FINDPR(N_I), FINEXS(N_I), RPACAP(N_I)
      Endif : #  Issue X3-70469
    Else
      Break
    Endif
  Next
  [M:LEA2]NBPER2 = N_I + 1
  Affzo [M:LEA2]NBPER2

  Raz [M:LEA2]CUMRNTAMT # Issue X3-70469

  # Issue X3-70469
  Call EVALUE_SUMPAY_ARRAY([M:LEA0]LEATYP)
  # Issue X3-70469
  Call EVALUE_CVAYEA ([M:LEA0]LEATYP,0)

  Affzo[M:LEA2]

  # Issue X3-70469
  mkstat = 4
End

#
#=============================================================================
#  AM_ Date de début de période :
#=============================================================================
#
Subprog AM_STRPERDAT(VALEUR)
Variable Date    VALEUR

# Issue X3-70469

#  Local Integer NOL
#
#
#  NOL=nolign-1
#
#  #* la date de début de la 1ère période (seule période saisie) ne peut pas être antérieure à la date de début du contrat
#  If (VALEUR <> [0/0/0]) & (VALEUR <  [M:LEA1]STRLEADAT)
#    GERR= 1
#    GMESSAGE= mess(44, GML_MSGGRT, 1)
#    mkstat = 2 : End
#  Endif
#
#  #*la date de début de période doit être <= à la date de fin de contrat
#  If VALEUR >  [M:LEA1]ENDLEADAT
#    GERR= 1
#    GMESSAGE= mess(46, GML_MSGGRT, 1)
#    mkstat = 2 : End
#  Endif
#
#  #*la date de début de période doit être > à la date de fin de la période précédente
#  If NOL > 0 and VALEUR <=  [M:LEA2]ENDPERDAT(NOL-1)
#    GERR= 1
#    GMESSAGE= mess(61, GML_MSGGRT, 1)
#    mkstat = 2 : End
#  Endif



End
#=============================================================================
#  C_ Date de début de période :
#=============================================================================
#
Subprog C_STRPERDAT(VALEUR)
Variable Date    VALEUR


  Local Integer NOL

  NOL=nolign-1

  #* la date de début de la 1ère échéance doit être renseignée
  If NOL=0 and VALEUR  = [0/0/0]
    GERR= 1
    GMESSAGE= mess(45, GML_MSGGRT, 1)
    mkstat = 2 : End
  Endif

  #* la date de début de la 1ère période (seule période saisie) ne peut pas être antérieure à la date de début du contrat
  If VALEUR <  [M:LEA1]STRLEADAT
    GERR= 1
    GMESSAGE= mess(44, GML_MSGGRT, 1)
    mkstat = 2 : End
  Endif

  #*la date de début de période doit être <= à la date de fin de contrat
  If VALEUR >  [M:LEA1]ENDLEADAT
    GERR= 1
    GMESSAGE= mess(46, GML_MSGGRT, 1)
    mkstat = 2 : End
  Endif

  #*la date de début de période doit être > à la date de fin de la période précédente
  If NOL > 1 and VALEUR <=  [M:LEA2]ENDPERDAT(NOL-1)
    GERR= 1
    GMESSAGE= mess(61, GML_MSGGRT, 1)
    mkstat = 2 : End
  Endif

  # Sauvegarde de la date de début de la 1ère période
  If NOL = 0
    GDPERDAT0 = VALEUR
  Endif

End
#
#=============================================================================
#  C_ Date de fin de période :  ne peut être <= à la date de début de période
#=============================================================================
#
Subprog C_ENDPERDAT(VALEUR)
Variable Date    VALEUR

  Local Integer NOL

  NOL=nolign-1

  # Issue X3-70469
  Local Integer LYEA1, LYEA2
  LYEA1 = year([M:LEA2]STRPERDAT(nolign-1))
  LYEA2 = year(VALEUR)
  If (LYEA1 <> LYEA2) Then
    GERR= 1
    # Période incorrecte
    GMESSAGE= mess(10, 116, 1)
    mkstat = 2 : End
  Endif

  If VALEUR <> [0/0/0] & VALEUR < [M:LEA2]STRPERDAT(nolign-1)
    # la date de fin ne peut être < au début
    GMESSAGE = mess(43,GML_MSGGRT,1)
    GERR=1
    mkstat = 2
    End
  Endif

  # Sauvegarde de la date de fin de la 1ère période
  If NOL = 0
    GFPERDAT0 = VALEUR
  Endif

End
#
#=============================================================================
#  AM_ Date de fin de période :  on recalcule les dates des échéances suivantes
#=============================================================================
#
Subprog AM_ENDPERDAT(VALEUR)
Variable Date    VALEUR

  Local Integer NOL

  #*la date de fin de période doit être <= à la date de fin de contrat
  If VALEUR >  [M:LEA1]ENDLEADAT
    GERR= 1
    GMESSAGE= mess(66, GML_MSGGRT, 1)
    mkstat = 2 : End
  Endif

  If VALEUR <> [0/0/0] & VALEUR < STRPERDAT(nolign-1)
    # la date de fin ne peut être < à la date de début de période
    GMESSAGE = mess(43,GML_MSGGRT,1)
    GERR=1
    mkstat = 2
    End
  Endif

  NOL = nolign-1
  [M:LEA2]ENDPERDAT(NOL) = VALEUR

  If  VALEUR <> [0/0/0]  & (!GIMPORT)

    # If  [M:LEA0]LEATYP <> GVML_LOCATION X3-84302
    If ([M:LEA0]LEATYP = GVML_CREBAIL) Then : # X3-84302
      If NOL = 0
        If  [M:LEA1]LEAAMT <> 0  #FQ104388
          [M:LEA2]RMNTPA(NOL) = [M:LEA1]LEAAMT
  #       Else  # Issue X3-70469
  #         [M:LEA2]RMNTPA(NOL)= [M:LEA2]RMNTPA(NOL-1)-[M:LEA2]RPACAP(NOL-1)  # Issue X3-70469
        Endif
      Else   # Issue X3-70469
        [M:LEA2]RMNTPA(NOL)= [M:LEA2]RMNTPA(NOL-1)-[M:LEA2]RPACAP(NOL-1)  # Issue X3-70469
      Endif
    Endif

    Call PER_CALCUL_POIDS ()
    If NOL = 0
      Call CALCUL_DATES_ECHEANCE ([M]STRPERDAT(NOL),[M]ENDPERDAT(NOL),[M]NBRMONPER(NOL))
    Endif

  Endif

  Affzo[M:LEA2]NBPER2

  If GREP="M"
    If (NOL > 0) and  ([M:LEA2]STRPERDAT(NOL+1) <> [M:LEA2]ENDPERDAT(NOL)+1)
      For N_I = [M:LEA2]NBPER2-1 To NOL+1 Step -1
        If [M:LEA2]FARFLG(N_I) = G_NON and [M:LEA2]FARFLG(N_I) = G_NON
        # X3-84302    (Later)
        # If ( [M:LEA2]FARFLG(nolign-1) <> G_OUI  and [M:LEA2]FARFLGI(nolign-1) <> G_OUI and
        #&     [M:LEA2]PAYDAT(nolign-1) = [0/0/0]  and  [M:LEA2]PAYREF(nolign-1) = "" ) Then
          # Issue X3-70469
          # Raz [M:LEA2]STRPERDAT(N_I), ENDPERDAT(N_I), RMNTPA(N_I), RNTAMT(N_I), FINDPR(N_I), FINEXS(N_I), RPACAP(N_I)
          Raz [M:LEA2]STRPERDAT(N_I), ENDPERDAT(N_I), RNTAMT(N_I)
          If ([M:LEA0]LEATYP = GVML_LOCATION) Then
            Raz [M:LEA2]RMNTPA(N_I), FINDPR(N_I), FINEXS(N_I), RPACAP(N_I)
          Else
            Raz [M:LEA2]LEAYEA(N_I), SUMPAY(N_I), VARPAY(N_I), RSDVAL(N_I), TERPEN(N_I), PUROPT(N_I)
          Endif
        Else
          Break
        Endif
      Next
      [M:LEA2]NBPER2 = N_I + 1
      Affzo[M:LEA2]
      # Issue X3-70469
      # mkstat = 4
    Endif
  Endif

  # Issue X3-70469
  If ([M:LEA0]LEATYP = GVML_LOCATION) Then
    If (nolign > [M:LEA2]NBPER2) Then : [M:LEA2]NBPER2 = nolign : Affzo [M:LEA2]NBPER2 :  Endif
    Call EVALUE_SUMPAY_ARRAY([M:LEA0]LEATYP)
    Affzo [M:LEA2]5
    # Issue X3-70469
    Call EVALUE_CVAYEA ([M:LEA0]LEATYP,0)
    Affzo [M:LEA2]15-20
  Endif


  If [M:LEA2]RNTAMT(0)= 0
    GERR= 1
    zonsui="[M:LEA2]RNTAMT(0)"
    Affzo [M:LEA2]RNTAMT(0)
  Endif

End

#
#=============================================================================
#  AS_ Reste à rembourser
#=============================================================================
#
# Issue X3-68589
Subprog AV_RMNTPA(VALEUR)
Variable Decimal VALEUR

  Gosub MANAGE_IAS_FIELDS
End


Subprog AS_RMNTPA(VALEUR)
Variable Decimal  VALEUR
  #
  # Seul le reste à rembourser de la première échéance est accessible
  #
  If  nolign <> 1
    mkstat = 2
  Else #FQ104388
    If  [M:LEA1]LEAAMT<> 0
      [M:LEA2]RMNTPA(nolign-1) = [M:LEA1]LEAAMT
      Affzo [M:LEA2]
    Endif
  Endif
End
#
#=============================================================================
#  AM_ Reste à rembourser  pour la période : pour la 1ère période = montant du contrat
#=============================================================================
#
Subprog AM_RMNTPA(VALEUR)
Variable Decimal  VALEUR

  [M:LEA2]RMNTPA(nolign-1) = VALEUR
  Affzo [M:LEA2]RMNTPA(nolign-1)

End
#
#=============================================================================
#  AP_ Montant de la redevance pour la période
#=============================================================================
#
Subprog AP_RNTAMT(VALEUR)
Variable Decimal  VALEUR

  If ([M:LEA0]LEATYP = GVML_CREBAIL)  #FQ104388
    If nolign=1  &  VALEUR = 0  & [M:LEA2]ENDPERDAT(nolign-1) > [0/0/0]
      # 'Le montant redevance est obligatoire pour chaque période'
      GERR= 1 : GMESSAGE= mess(60, GML_MSGGRT, 1) : mkstat = 2 : End
    Endif
  Endif #FQ104388

End
#
#=============================================================================
#  C_ Montant de la redevance pour la période
#=============================================================================
#
Subprog C_RNTAMT(VALEUR)
Variable Decimal VALEUR
Local Integer NOL

  If ([M:LEA0]LEATYP = GVML_CREBAIL)  #FQ104388
    If  VALEUR = 0 & [M:LEA2]ENDPERDAT(nolign-1) > [0/0/0]
      # 'Le montant redevance est obligatoire pour chaque période'
      GERR= 1 : GMESSAGE= mess(60, GML_MSGGRT, 1) : mkstat = 2 :  End
    Endif
  Endif #FQ104388

End
#
#=============================================================================
#  AM_ Montant de la redevance pour la période
#=============================================================================
#
#----------------------
Subprog AM_RNTAMT(VALEUR)
Variable Decimal  VALEUR

  Local Decimal LRNTAMT

  [M:LEA2]RNTAMT(nolign-1) = VALEUR  # X3-70469
  Affzo [M:LEA2]RNTAMT(nolign-1)
  LRNTAMT = [M:LEA2]RNTAMT(nolign-1)

  # Issue X3-70469
  If (nolign > [M:LEA2]NBPER2) Then : [M:LEA2]NBPER2 = nolign : Affzo [M:LEA2]NBPER2 :  Endif
  Local Integer I_L
  Raz [M:LEA2]CUMRNTAMT
  For I_L = 1 To [M:LEA2]NBPER2
     [M:LEA2]CUMRNTAMT += [M:LEA2]RNTAMT(I_L-1)
  Next I_L
  Affzo [M:LEA2]CUMRNTAMT

  # End issue X3-70469
  If ([M:LEA0]LEATYP = GVML_LOCATION) Then
    Gosub EVALUE_SUMPAY_LINE
  Endif
  # End issue X3-70469
End
#----------------------
Subprog AM_VARPAY(VALEUR)
Variable Decimal VALEUR
  # Issue X3-70469
  [M:LEA2]VARPAY(nolign-1) = VALEUR
  Gosub EVALUE_SUMPAY_LINE
End

#----------------------
Subprog AM_RSDVAL(VALEUR)
Variable Decimal VALEUR
  # Issue X3-70469
  [M:LEA2]RSDVAL(nolign-1) = VALEUR
  Gosub EVALUE_SUMPAY_LINE
End

#----------------------
Subprog AM_PUROPT(VALEUR)
Variable Decimal VALEUR
  # Issue X3-70469
  [M:LEA2]PUROPT(nolign-1) = VALEUR
  Gosub EVALUE_SUMPAY_LINE
End

#----------------------
Subprog AM_TERPEN(VALEUR)
Variable Decimal VALEUR
  # Issue X3-70469
  [M:LEA2]TERPEN(nolign-1) = VALEUR
  Gosub EVALUE_SUMPAY_LINE
End

$EVALUE_SUMPAY_LINE
  # Issue X3-70469
  [M:LEA2]SUMPAY(nolign-1) = [M:LEA2]RNTAMT(nolign-1) +
&                            [M:LEA2]VARPAY(nolign-1) +
&                            [M:LEA2]RSDVAL(nolign-1) +
&                            [M:LEA2]PUROPT(nolign-1) +
&                            [M:LEA2]TERPEN(nolign-1)
  Affzo [M:LEA2]SUMPAY(nolign-1)
  If (nolign > [M:LEA2]NBPER2) Then : [M:LEA2]NBPER2 = nolign : Affzo [M:LEA2]NBPER2 : Endif
  Call EVALUE_CVAYEA ([M:LEA0]LEATYP,[M:LEA2]LEAYEA(nolign-1))
  Affzo [M:LEA2]15-20
Return
#
#=============================================================================
#   APRES_MODIF  Amortiss. Financiers  :
#=============================================================================
#
Subprog AM_FINDPR(VALEUR)
Variable Decimal  VALEUR


  Local Decimal LRNTAMT, LFINDPR, LFINEXS
  Local Integer I

  LFINDPR = VALEUR
  [M:LEA2]FINDPR(nolign-1) = VALEUR
  Affzo [M:LEA2]FINDPR(nolign-1)
  LRNTAMT = [M:LEA2]RNTAMT(nolign-1)

  If  ([M:LEA0]LEATYP = GVML_CREBAIL) #FQ104388
    LFINEXS=[M:LEA2]RNTAMT(nolign-1)-LFINDPR
  Else
    LFINEXS = [M:LEA2]FINEXS(nolign-1)   #FQ104388
  Endif

  ##FQ104388 [M:LEA2]FINEXS(nolign-1)=[M:LEA2]RNTAMT(nolign-1)-LFINDPR
  [M:LEA2]FINEXS(nolign-1)=LFINEXS
  Affzo [M:LEA2]FINEXS(nolign-1)

  If  ([M:LEA0]LEATYP = GVML_CREBAIL) #FQ104388
    If nolign=1
      [M:LEA2]RPACAP(nolign-1)= LFINDPR
    Else
      [M:LEA2]RPACAP(nolign-1)= [M:LEA2]RPACAP(nolign-2)+LFINDPR
    Endif
    Affzo [M:LEA2]RPACAP(nolign-1)
  Endif

  If nolign <> 1
    nolign += 1

    For I = nolign To [M:LEA2]NBPER2
      [M:LEA2]RNTAMT(nolign-1) = LRNTAMT
      [M:LEA2]FINDPR(nolign-1) = LFINDPR
      nolign += 1
    Next I

    If  ([M:LEA0]LEATYP = GVML_CREBAIL) #FQ104388
      Call CALCUL_ECHEANCIER
    Endif #FQ104388
  Endif

  Affzo [M:LEA2]

End
#
#=============================================================================
#   APRES_ZONE  Amortiss. Financiers  :
#=============================================================================
#
Subprog AP_FINDPR(VALEUR)
Variable Decimal  VALEUR

  Local Decimal LRNTAMT, LFINDPR
  Local Integer I

  If  ([M:LEA0]LEATYP <> GVML_CREBAIL) #FQ104388
    End
  Endif

  LFINDPR = VALEUR

  [M:LEA2]FINEXS(nolign-1)=[M:LEA2]RNTAMT(nolign-1)-LFINDPR
  Affzo [M:LEA2]FINEXS(nolign-1)

  If nolign=1
    [M:LEA2]RPACAP(nolign-1)= LFINDPR
  Else
    [M:LEA2]RPACAP(nolign-1)= [M:LEA2]RPACAP(nolign-2)+LFINDPR
  Endif

  Affzo [M:LEA2]RPACAP(nolign-1)

End
#
#=============================================================================
#   CONTROLE  Amortiss. Financiers  :  obligatoire si  contrat de type crédit-bail
#=============================================================================
#
Subprog C_FINDPR(VALEUR)
Variable Decimal VALEUR

  If VALEUR = 0 and [M:LEA0]LEATYP = GVML_CREBAIL  and [M:LEA2]ENDPERDAT(nolign-1) > [0/0/0]
    GERR= 1
    GMESSAGE= mess(41, GML_MSGGRT, 1)
    mkstat = 2 :  End
  Endif

End
#
#=============================================================================
# CONTROLE  Frais financiers  : la valeur des frais financiers  doit  être obligatoirement
# renseignée si le  type contrat est  "crédit-bail"
#=============================================================================
#
Subprog C_FINEXS(VALEUR)
Variable Decimal VALEUR

  If VALEUR = 0 and [M:LEA0]LEATYP = GVML_CREBAIL and [M:LEA2]ENDPERDAT(nolign-1) > [0/0/0]
    GERR= 1
    GMESSAGE= mess(41, GML_MSGGRT, 1)
    mkstat = 2 :  End
  Endif

End
#
#=============================================================================
# CONTROLE  Capital remboursé  : la valeur du capital remboursé doit  être obligatoirement
# renseignée si le  type contrat est  "crédit-bail"
#=============================================================================
#
Subprog C_RPACAP(VALEUR)
Variable Decimal VALEUR


  If VALEUR = 0 and [M:LEA0]LEATYP = GVML_CREBAIL and [M:LEA2]ENDPERDAT(nolign-1) > [0/0/0]
    GERR= 1
    GMESSAGE= mess(41, GML_MSGGRT, 1)
    mkstat = 2 :  End
  Endif

End
#
#=============================================================================
# R3010 - CALCUL montants de l'échéancier
#=============================================================================
#
Subprog CALCUL_ECHEANCIER

 Local Integer I
 Local Decimal LFINCUM, LDEP

  nolign = 1
  LFINCUM = 0  # Cumul Amortissement financier
  # Si le reste à payer n'est pas saisi, le montant capital est pris par défaut
  #FQ104388 If (  [M:LEA2]RMNTPA(nolign - 1) = 0 ) Then
  If (  [M:LEA2]RMNTPA(nolign - 1) = 0  and [M:LEA1]LEAAMT<> 0)
    LDEP = [M:LEA1]LEAAMT
  Else
    LDEP = [M:LEA2]RMNTPA(nolign - 1)
  Endif

  For I = 1 To [M:LEA2]NBPER2

    # Reste à payer = Capital - cumul Amortissement financier
    [M:LEA2]RMNTPA(nolign-1) = LDEP - LFINCUM

    # Frais financier = Redevance - Amortissement financier
    [M:LEA2]FINEXS(nolign-1) = [M:LEA2]RNTAMT(nolign-1) - [M:LEA2]FINDPR(nolign-1)

    # Capital remboursé = Montant capital - Reste à rembourser - Amortissement financier
    If [M:LEA1]LEAAMT > 0
      [M:LEA2]RPACAP(nolign-1) = [M:LEA1]LEAAMT - [M:LEA2]RMNTPA(nolign-1) + [M:LEA2]FINDPR(nolign-1)
    Else
      [M:LEA2]RPACAP(nolign-1) = [M:LEA2]RMNTPA(0) - [M:LEA2]RMNTPA(nolign-1) + [M:LEA2]FINDPR(nolign-1)
    Endif

    # Entretien du cumul Amortissement financier
    [L]LFINCUM += [M:LEA2]FINDPR(nolign-1)
    nolign +=1
  Next I

End
#
#=============================================================================
# R3010 - CALCUL dates échéances
#=============================================================================
#
Subprog CALCUL_DATES_ECHEANCE (BORNE_DEB, BORNE_FIN, DURPER)
Value Date    BORNE_DEB
Value Date    BORNE_FIN
Value Integer DURPER

  # Calcul de la date de début et de fin des différentes échéances
  Local Date DEB, FIN, LBORNE_DEB,  LBORNE_FIN, LWENDAT
  Local Integer  I,  LFREQ #Fq-71281, DURPER
  Local Char CONT(1)
  Local Integer JOUR_1_DATE
  Local Integer JOUR_2_DATE

  LWENDAT=[0/0/0]
  If DURPER <=1
    LFREQ = 1
  Else
    LFREQ = DURPER
  Endif

  LBORNE_DEB = BORNE_DEB
  LBORNE_FIN = BORNE_FIN
  [L]CONT = "T"

  #
  # Alimentation de la première ligne Début de période = Date début du contrat
  # fin de période = Date de fin de contrat ou début de période + ( 1 mois, 1 trimestre ou une année )
  #
  nolign = 1

  While  [L]CONT = 'T'

    If ([M:LEA2]ENDPERDAT(nolign-1)) = [M:LEA1]ENDLEADAT
      [L]CONT = "F"
      If (nolign > 1) Then : # Issue 70469
        nolign-=1
      Endif
    Else
      nolign += 1
      [M:LEA2]STRPERDAT(nolign-1) = [M:LEA2]ENDPERDAT(nolign-2)+1

      JOUR_1_DATE = day([M:LEA2]STRPERDAT(nolign-1))
      JOUR_2_DATE = day([M:LEA2]ENDPERDAT(nolign-1))

      If LFREQ = 1   # Mois
        If JOUR_1_DATE = 1
          [M:LEA2]ENDPERDAT(nolign-1) = eomonth( [M:LEA2]STRPERDAT(nolign-1))
        Else
          [M:LEA2]ENDPERDAT(nolign-1) = gdat$ (JOUR_1_DATE-1, month([M:LEA2]STRPERDAT(nolign-1)) + 1, year([M:LEA2]STRPERDAT(nolign-1) ))
        Endif
      Else
        If JOUR_1_DATE = 1
          [M:LEA2]ENDPERDAT(nolign-1) = eomonth(addmonth([M:LEA2]STRPERDAT(nolign-1), LFREQ-1))
        Else
          LWENDAT = addmonth([M:LEA2]STRPERDAT(nolign-1), LFREQ-1)
          [M:LEA2]ENDPERDAT(nolign-1) =  gdat$ (JOUR_1_DATE-1, month(LWENDAT), year(LWENDAT))
        Endif
      Endif

      Call PER_CALCUL_POIDS ()
      [M:LEA2]NBRMONPER(nolign-1) = LFREQ

      Gosub DETERM_FIN_ECHEANCIER
    Endif
  Wend

  [M:LEA1]DURPER=LFREQ
  [M:LEA2]NBPER2 = nolign

  Affzo [M:LEA1]
  Affzo [M:LEA2]

End
#
#===============================================================================
# R3020 - RECALCUL dates échéances  après modification des dates de début et/ou
#               de fin de contrat
#===============================================================================
#
Subprog RECALCUL_DATES_ECHEANCE (PDEB, PFIN, PDURPER)
Value Date    PDEB
Value Date    PFIN
Value Integer PDURPER

  #
  # Calcul de la date de début et de fin des différentes échéances
  #
  Local Date DEB, FIN, LBORNE_DEB, LBORNE_FIN, LWENDAT
  Local Integer   I, J, LFREQR
  Local Char CONT(1)
  Local Integer JOUR_1_DATE
  Local Integer JOUR_2_DATE

  Raz[M:LEA2]NBPER2
  Affzo [M:LEA2]NBPER2

  LWENDAT=[0/0/0]
  LFREQR = PDURPER
  LBORNE_DEB = PDEB
  LBORNE_FIN = PFIN
  CONT = "T"
  #
  # Alimentation de la première ligne Début de période = Date début du contrat
  # fin de période = Date de fin de contrat ou début de période + ( 1 mois, 1 trimestre ou une année )
  #
  nolign = 1

  [M:LEA2]STRPERDAT(nolign-1) = PDEB  : Affzo [M:LEA2]STRPERDAT(nolign-1)
  JOUR_1_DATE = day([M:LEA2]STRPERDAT(nolign-1))

  Gosub CALCUL_FIN_PERIODE
  Gosub DETERM_FIN_ECHEANCIER

  While  CONT = 'T'
    nolign += 1
    [M:LEA2]STRPERDAT(nolign-1) = [M:LEA2]ENDPERDAT(nolign-2)+1
    JOUR_1_DATE = day([M:LEA2]STRPERDAT(nolign-1))
    Gosub CALCUL_FIN_PERIODE
  Wend

  [M:LEA1]DURPER=LFREQR
  [M:LEA2]NBPER2 = nolign

  Affzo [M:LEA2]


  If [M:LEA1]CUTDAT > [0/0/0]
    For nolign = 1 To [M:LEA2]NBPER2
      If [M:LEA2]ENDPERDAT(nolign-1) < [M:LEA1]CUTDAT
        # Issue X3-70469
        Diszo [M:LEA2]STRPERDAT(nolign-1)   :  Diszo [M:LEA2]ENDPERDAT(nolign-1) : Diszo [M:LEA2]RNTAMT(nolign-1)
        If ( [M:LEA0]LEATYP = GVML_LOCATION)
          # Issue X3-70469
          Diszo [M:LEA2]VARPAY(nolign-1)
          Diszo [M:LEA2]RSDVAL(nolign-1)
          Diszo [M:LEA2]TERPEN(nolign-1)
          Diszo [M:LEA2]PUROPT(nolign-1)
        Else
          Diszo [M:LEA2]FINDPR(nolign-1)
          Diszo [M:LEA2]FINEXS(nolign-1)
          If ( [M:LEA0]LEATYP = GVML_CREBAIL) Then : # X3-84302
            Diszo [M:LEA2]RMNTPA(nolign-1)
            Diszo [M:LEA2]RPACAP(nolign-1)
          Endif
        Endif
      Endif
    Next nolign
  Endif

End
#
#=============================================================================
# R3030 - CALCUL date de fin de chaque période :  en fonction du jour de la date
#               de fin de période retenue comme point de départ
#=============================================================================
#
$CALCUL_FIN_PERIODE
  #
  #--------------------------------------
  # durée de la période = 1 mois
  #--------------------------------------
  If LFREQR = 1
    #---------------------------------------
    # si 1er jour début période = 01
    #---------------------------------------
    If JOUR_1_DATE = 1
      [M:LEA2]ENDPERDAT(nolign-1) = eomonth( [M:LEA2]STRPERDAT(nolign-1))
    Else
        #-----------------------------------------
        # si 1er jour début période <> 01
        #-----------------------------------------
       [M:LEA2]ENDPERDAT(nolign-1) = gdat$ (JOUR_1_DATE-1, month([M:LEA2]STRPERDAT(nolign-1)) + 1, year([M:LEA2]STRPERDAT(nolign-1) ))
    Endif
  #--------------------------------------------------------
  # durée de la période > 1 mois et < 12 mois
  #-------------------------------------------------------
  Elsif  (LFREQR < 12)
    #---------------------------------------
    # si 1er jour début période = 01
    #---------------------------------------
    If JOUR_1_DATE = 1
      [M:LEA2]ENDPERDAT(nolign-1) = eomonth(addmonth([M:LEA2]STRPERDAT(nolign-1), LFREQR-1))
      #---------------------------------------
      # si 1er jour début période <> 01
      #---------------------------------------
    Else
      LWENDAT = addmonth([M:LEA2]STRPERDAT(nolign-1), LFREQR-1)
      [M:LEA2]ENDPERDAT(nolign-1) =  gdat$ (JOUR_1_DATE-1, month(LWENDAT), year(LWENDAT))
    Endif
  #-------------------------------------
  # durée de la période = 1 an
  #-------------------------------------
  Else
    [M:LEA2]ENDPERDAT(nolign-1) = gdat$ ( 31, 12, year([M:LEA2]STRPERDAT(nolign-1)) + 1   )
  Endif

  Call PER_CALCUL_POIDS()
  [M:LEA2]NBRMONPER(nolign-1) = LFREQR
  Gosub DETERM_FIN_ECHEANCIER

Return
#
#=============================================================================
# - Détermination  date de fin de l'échéancier :  en fonction de la date de fin du contrat
#=============================================================================
#
$DETERM_FIN_ECHEANCIER

  If ( [M:LEA2]ENDPERDAT(nolign-1) >= [M:LEA1]ENDLEADAT )
    CONT = 'F'
    [M:LEA2]ENDPERDAT(nolign-1) = [M:LEA1]ENDLEADAT
  Endif
  Affzo [M:LEA2]ENDPERDAT(nolign-1)

  [M:LEA2]NBPER2 = nolign-1

Return
#
#=============================================================================
# - CALCUL du nombre de jour, mois et semaines pour une période saisie
#=============================================================================
#
Subprog PER_CALCUL_POIDS

  Local Integer NB_JOURS
  Local Integer NB_MOIS
  Local Integer NB_WEEK

  Call CALCUL_NB_D_M_W ([M]STRPERDAT(nolign-1), [M]ENDPERDAT(nolign-1), NB_JOURS, NB_MOIS, NB_WEEK)
  [M:LEA2]NBRMONPER(nolign-1) = NB_MOIS
  [M:LEA2]NBRDAYPER(nolign-1) = NB_JOURS
  [M:LEA2]NBRWEKPER(nolign-1) = NB_WEEK

  Affzo [M:LEA2]NBRMONPER(nolign-1)
  Affzo [M:LEA2]NBRWEKPER(nolign-1)
  Affzo [M:LEA2]NBRDAYPER(nolign-1)

End
#########################################################################
Subprog CALCUL_NB_D_M_W (P_DATE_DEB, P_DATE_FIN, R_NB_JOUR, R_NB_MOIS, R_NB_WEEK)
Value Date P_DATE_DEB
Value Date P_DATE_FIN
# calcul les nombres de jour, mois et semaines pour une période

  Variable Integer R_NB_JOUR
  Variable Integer R_NB_MOIS
  Variable Integer R_NB_WEEK

  #Fq-53971 Call GET_DATE_MONTH_DELTA (P_DATE_DEB, P_DATE_FIN, R_NB_MOIS) From GLOBIENS
  Call GET_DATE_MONTH_DELTA (P_DATE_DEB, P_DATE_FIN, R_NB_MOIS)
  R_NB_JOUR = P_DATE_FIN - P_DATE_DEB + 1
  R_NB_WEEK = arr (R_NB_JOUR/7, 0)

End
######################################################################
Subprog GET_DATE_MONTH_DELTA (PDATEDEB, PDATEFIN, RNBMOIS)
# rend le nombre de mois compris entre deux dates
# Note : un mois commencé compte pour un mois
# RNBMOIS = -1 si l'une ou l'autre des dates n'est pas renseignée
# ------------------------------------------------------------------------------
Value Date PDATEDEB
Value Date PDATEFIN
Variable Integer RNBMOIS

  Local Integer AN_1_DATE
  Local Integer AN_2_DATE
  Local Integer MOIS_1_DATE
  Local Integer MOIS_2_DATE
  Local Integer JOUR_1_DATE
  Local Integer JOUR_2_DATE

  If PDATEDEB = [0/0/0] or PDATEFIN = [0/0/0] Then
    RNBMOIS = -1
  Else
#      AN_1_DATE = year (PDATEDEB)
#      MOIS_1_DATE = month (PDATEDEB)
#      JOUR_1_DATE = day(PDATEDEB)
#      AN_2_DATE = year (PDATEFIN)
#      MOIS_2_DATE = month (PDATEFIN)
#      JOUR_2_DATE = day(PDATEFIN)
#      RNBMOIS = abs ((abs (AN_1_DATE - AN_2_DATE) * 12) + (abs (MOIS_1_DATE - MOIS_2_DATE) + 1))
#      #* si le nombre de mois calculé est égal à 2 alors que la différence réelle entre les 2 dates n'est que d'1 mois
#      #* (cas où le jour de début de période ne correspond pas au jour de début du mois)  ==> RNBMOIS = 1
#      #FQ107913 If  RNBMOIS <> ((MOIS_2_DATE - MOIS_1_DATE ) + 1)
#      #FQ107913   RNBMOIS -= 1
#      #FQ107913 Endif
#      #FQ117042
#      If  RNBMOIS <> ((MOIS_2_DATE - MOIS_1_DATE )) and RNBMOIS > 1
#        RNBMOIS -= 1
#      Endif #End Fq-117042

    # Issue 61130 - 2017-10-31 by MWA : Periods splitting
    RNBMOIS = ((year(PDATEFIN)-year(PDATEDEB))*12)+ (month(PDATEFIN)-month(PDATEDEB))+1
  Endif

End
#################################################################################################
# Fonction :  GET_LEASTA(PLEAREF)                                                                #
# récupération du statut du contrat de location passé en paramètre                              #
#################################################################################################
Funprog GET_LEASTA(PLEAREF)
Value Char    PLEAREF

  Local Integer  STALEA

  If clalev([F:LEA]) =0    : Local File LEASE       [LEA]    : Endif
  Read[LEA]LEA0 = PLEAREF
  If fstat = 0
    STALEA = [F:LEA]LEASTA
  Endif

End STALEA
