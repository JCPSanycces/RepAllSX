Subprog C_LEACUR(VALEUR)
Variable Char    VALEUR()

End

#------------------------------------------------
Subprog AM_LEACUR(VALEUR)
Variable Char    VALEUR()

  [M:LEA1]LEACUR  = VALEUR : Affzo [M:LEA1]LEACUR
  [M:LEA2]LEACUR  = VALEUR : Affzo [M:LEA2]LEACUR
  [M:LEA2]LEACUR2 = VALEUR : Affzo [M:LEA2]LEACUR2
  [M:LEA3]LEACUR  = VALEUR : Affzo [M:LEA3]LEACUR
  [M:LEA5]LEACUR  = VALEUR : Affzo [M:LEA5]LEACUR   : #  X3-84302

  GDEVFMTL="13.2"
  GDEVFMTL = GDEVFMT1(max(find([M:LEA1]LEACUR, GDEVISE(1..GNBDEV)), 1))  : # X3-77642

  Gosub INIT_GENERALE
  Call AP_LEAAMT([M:LEA1]LEAAMT)
  Call AM_RPUVAL([M:LEA1]RPUVAL)

  # Issue X3-77642
  If ( [M:LEA0]LEATYP = GVML_LOCATION ) Then
    [M:LEA2]LEACUR2 = VALEUR : Affzo [M:LEA2]LEACUR2
  Endif

  Gosub MANAGE_LOCATION_FIELDS
  Gosub ROUNDING_LEACUR_AMOUNTS

  Affzo [M:LEA2]
  # End issue X3-77642


End

#------------------------------------------------
Subprog AP_LEAAMT(VALEUR)
Variable Decimal VALEUR

  Local Decimal MTDES
  Local Integer STAT

  If VALEUR <> 0
    # ------------- Conversion en devise société
    # LEAAMT -> LEAAMTDEV
    Call RECALCUL_MONTANT_DEVSOC([M:LEA1]LEACUR, [M:LEA1]CUR, GCOUDEV, [M:LEA1]CURTYP,
&        [M:LEA1]STRLEADAT, VALEUR, 0, [M:LEA1]LEAAMTDEV)
    Affzo [M:LEA1]LEAAMTDEV
    Affzo [M:LEA1]RATCUR

    If ( GCNXPROIAS = G_OUI )
      # ------------- Conversion en devise IAS
      # LEAAMT -> LEAAMTIAS
      Call RECALCUL_MONTANT_DEVIAS([M:LEA1]LEACUR, [M:LEA1]IASCUR, GCOUDEV, [M:LEA1]IASCURTYP,
&          [M:LEA1]STRLEADAT, VALEUR, 0, [M:LEA1]LEAAMTIAS)
      Affzo [M:LEA1]LEAAMTIAS
      Affzo [M:LEA1]IASRATCUR : Diszo [M:LEA1]IASRATCUR
    Endif
  Endif

  # If we change lease currency and thefore the number of decimals of amounts
  Affzo [M:LEA1]
  Affzo [M:LEA2]

End

#------------------------------------------------
Subprog AM_LEAAMT(VALEUR)
Variable Decimal VALEUR

  Local Decimal MTDES
  Local Integer STAT

  If VALEUR <> 0
    # ------------- Conversion en devise société
    # LEAAMT -> LEAAMTDEV
    Call RECALCUL_MONTANT_DEVSOC([M:LEA1]LEACUR, [M:LEA1]CUR, GCOUDEV, [M:LEA1]CURTYP,
&        [M:LEA1]STRLEADAT, VALEUR, 0, [M:LEA1]LEAAMTDEV)
    Affzo [M:LEA1]LEAAMTDEV
    Affzo [M:LEA1]RATCUR

    If ( GCNXPROIAS = G_OUI )
      # ------------- Conversion en devise IAS
      # LEAAMT -> LEAAMTIAS
      Call RECALCUL_MONTANT_DEVIAS([M:LEA1]LEACUR, [M:LEA1]IASCUR, GCOUDEV, [M:LEA1]IASCURTYP,
&          [M:LEA1]STRLEADAT, VALEUR, 0, [M:LEA1]LEAAMTIAS)
      Affzo [M:LEA1]LEAAMTIAS
      Affzo [M:LEA1]IASRATCUR  : Diszo [M:LEA1]IASRATCUR
    Endif
  Endif

End

#------------------------------------------------
Subprog AM_RPUVAL(VALEUR)
Variable Decimal VALEUR

  Local Decimal MTDES
  Local Integer STAT

  If VALEUR <> 0
    # ------------- Conversion en devise société
    # RPUVAL -> RPUVALDEV
    Call RECALCUL_MONTANT_DEVSOC([M:LEA1]LEACUR, [M:LEA1]CUR, GCOUDEV, [M:LEA1]CURTYP,
&        [M:LEA1]STRLEADAT, VALEUR, 0, [M:LEA1]RPUVALDEV)
    Affzo [M:LEA1]RPUVALDEV

    If ( GCNXPROIAS = G_OUI )
      # ------------- Conversion en devise IAS
      # RPUVAL -> RPUVALIAS
      Call RECALCUL_MONTANT_DEVIAS([M:LEA1]LEACUR, [M:LEA1]IASCUR, GCOUDEV, [M:LEA1]IASCURTYP,
&          [M:LEA1]STRLEADAT, VALEUR, 0, [M:LEA1]RPUVALIAS)
      Affzo [M:LEA1]RPUVALIAS : Diszo [M:LEA1]RPUVALIAS
    Endif
  Endif

End

#------------------------------------------------
Subprog AM_LEARAT(VALEUR)
Variable Decimal VALEUR

  # Issue X3-70469
  If ( [M:LEA0]LEATYP = GVML_LOCATION ) Then
    If ([M:LEA1]IMPLEARAT = 0 and [M:LEA1]ICRBRWRAT = 0) Then :  # Issue X3-72297
      If ( [M:LEA2]NBYEA > 0 ) Then
        [M:LEA1]LEARAT = VALEUR
        # X3-72297
        Local Decimal LRATYEA
        Call EVALUE_RATYEA([M:LEA1]IMPLEARAT, [M:LEA1]ICRBRWRAT, [M:LEA1]LEARAT, LRATYEA)
        For nolign = 1 To [M:LEA2]NBYEA
          [M:LEA2]RATYEA(nolign-1) = LRATYEA
        Next
        Call EVALUE_CVAYEA ([M:LEA0]LEATYP,0)
        Affzo [M:LEA2]15-20
      Endif
    Endif
  Endif
End

#------------------------------------------------
Subprog AM_IMPLEARAT(VALEUR)
Variable Decimal VALEUR

  # Issue X3-72297
  If ( [M:LEA0]LEATYP = GVML_LOCATION ) Then
    If ( [M:LEA2]NBYEA > 0 ) Then
      [M:LEA1]IMPLEARAT = VALEUR
      Local Decimal LRATYEA
      Call EVALUE_RATYEA([M:LEA1]IMPLEARAT, [M:LEA1]ICRBRWRAT, [M:LEA1]LEARAT, LRATYEA)
      For nolign = 1 To [M:LEA2]NBYEA
        [M:LEA2]RATYEA(nolign-1) = LRATYEA
      Next
      Call EVALUE_CVAYEA ([M:LEA0]LEATYP,0)
      Affzo [M:LEA2]15-20
    Endif
  Endif
End

#------------------------------------------------
Subprog AM_ICRBRWRAT(VALEUR)
Variable Decimal VALEUR

  # Issue X3-72297
  If ( [M:LEA0]LEATYP = GVML_LOCATION ) Then
    If ([M:LEA1]IMPLEARAT = 0) Then
      If ( [M:LEA2]NBYEA > 0 ) Then
        [M:LEA1]ICRBRWRAT = VALEUR
        Local Decimal LRATYEA
        Call EVALUE_RATYEA([M:LEA1]IMPLEARAT, [M:LEA1]ICRBRWRAT, [M:LEA1]LEARAT, LRATYEA)
        For nolign = 1 To [M:LEA2]NBYEA
          [M:LEA2]RATYEA(nolign-1) = LRATYEA
        Next
        Call EVALUE_CVAYEA ([M:LEA0]LEATYP,0)
        Affzo [M:LEA2]15-20
      Endif
    Endif
  Endif
End

#3-----------------------------------------------
Subprog C_DSP(VALEUR)
Variable Char    VALEUR()

 If VALEUR <> ""
   If !clalev([DSP]) : Local File CADSP [DSP] : Endif

   Read [DSP]DSP0 = VALEUR;1 : # Lecture de la première ligne

   #> Vérification site / société
   If [F:DSP]FCY<>"" Then
     Call VERIF_FCY("DSP", [F:DSP]FCY, [M:LEA0]CPY, [M:LEA0]FCY, VALEUR) From GLOBIENS
     If mkstat : End : Endif
   Endif
Endif

End
#------------------------------------------------
Subprog AM_DSP(VALEUR)
Variable Char    VALEUR()

  Local Integer N_CCE

  For N_CCE = 0 To GOPTCANA-1
    If VALEUR = ""
      # Si une clé de répartition est remise à blanc, il faut dégriser les axes
      Actzo [M:LEA4]CCE(N_CCE)
    Else
      # Si une clé de répartition est saisie, il faut griser les axes
      [M:LEA4]CCE(N_CCE) = ""
      Diszo [M:LEA4]CCE(N_CCE)
    Endif
  Next N_CCE

End
######################################################################################
##Fq-79815 Activation et contrôle des sections analytiques
######################################################################################
Subprog AS_NBRCCE

  # Pour récupèree les sections par défautce il faut être en  Création/Duplication de contrat
  # .... et ne pas avoir renseigné de clé répartition
  If (GREP <> "C"  and GREP <> "D" ) or  [M:LEA4]DSP <> ""
    End
  Endif

  Local Integer AXE
  ##*Section analytiques par défaut
  [M]NBRCCE=[M:FPC]NBDIE
  Local Integer I_DIE
  For I_DIE = 1 To [M:FPC]NBDIE
    [M:LEA4]DIE(I_DIE-1) = [M:FPC]DIE(I_DIE-1)
    If [M:LEA4]CCE(I_DIE-1)= ""
      Call INISEC([M:LEA4]CCE(I_DIE-1),"FXDLEASE", [M:FPC]DIE(I_DIE-1)) From SUBCDE
    Endif
    Affzo [M:LEA4]DIE(I_DIE-1) : Affzo [M:LEA4]ZDIE(I_DIE-1)
    Affzo [M:LEA4]CCE(I_DIE-1) : Affzo [M:LEA4]ZCCE(I_DIE-1)
  Next I_DIE
  Affzo [M:LEA4]NBRCCE

  For AXE=1 To G_NBAXE
    Actzo [M:LEA4]CCE(AXE-1)
    Affzo [M:LEA4]CCE(AXE-1)
  Next

End
#######################################
Subprog C_NBRCCE

  # adxgtb= 0 = On est encore en saisie dans le tableau
  # adxgtb= 1 = Sortie invalide du tableau ==> pas la peine de faire ces contrôles car il y a au préalable des anomalies à corriger
  # adxgtb= 2 = Sortie valide du tableau ==>  on fait des contrôles complémentaires sur chaque ligne du tableau
  If adxgtb=2
    If clalev([F:CAZ])=0  : Local File CAAUZ   [CAZ]  : Endif
    If clalev([F:CCE])=0  : Local File CACCE   [CCE]  : Endif  : # Sections
    If clalev([F:CCE2])=0 : Local File CACCE   [CCE2] : Endif  : # Sections

    For AXE=1 To G_NBAXE

      If [M]CCE(AXE-1)<>""

        nolign=AXE
        # Contrôle interdiction section/section
        Call LECTURE("CCE",[M]CCE(AXE-1),[M]DIE(AXE-1)) From CONTOBJ

        For I=AXE+1 To G_NBAXE
          If [M]CCE(I-1)<>""
            Read [F:CCE2]CCE0 = [M]DIE(I-1) ; [M]CCE(I-1)
            Look [CAZ]CAZ0 = 1 ; [F:CCE]AUZ ; [F:CCE2]AUZ
            If !fstat
              # Interdit avec la section
              GMESSAGE = [M]CCE(AXE-1)-mess(26,106,1)-[M]CCE(I-1)
              mkstat = 1 : Break 2
            Endif
          Endif
        Next

      Endif
    Next
  Endif

End

#------------------------------------------------
Subprog AP_RATCUR(VALEUR)
Variable Decimal VALEUR

  If VALEUR <> [M:LEA1]RATCUR
    [M:LEA1]RATCUR = VALEUR
    # LEAAMT -> LEAAMTDEV
    Call RECALCUL_MONTANT_DEVSOC([M:LEA1]LEACUR, [M:LEA1]CUR, GCOUDEV, [M:LEA1]CURTYP,
&        [M:LEA1]STRLEADAT, [M:LEA1]LEAAMT, [M:LEA1]RATCUR, [M:LEA1]LEAAMTDEV)
    # RPUVAL -> RPUVALDEV
    Call RECALCUL_MONTANT_DEVSOC([M:LEA1]LEACUR, [M:LEA1]CUR, GCOUDEV, [M:LEA1]CURTYP,
&        [M:LEA1]STRLEADAT, [M:LEA1]RPUVAL, [M:LEA1]RATCUR, [M:LEA1]RPUVALDEV)
    If ( GCNXPROIAS = G_OUI ) Then
      # LEAAMT -> LEAAMTIAS
      Call RECALCUL_MONTANT_DEVIAS([M:LEA1]LEACUR, [M:LEA1]IASCUR, GCOUDEV, [M:LEA1]IASCURTYP,
&          [M:LEA1]STRLEADAT, [M:LEA1]LEAAMT, [M:LEA1]IASRATCUR, [M:LEA1]LEAAMTIAS)
      # RPUVAL -> RPUVALIAS
      Call RECALCUL_MONTANT_DEVIAS([M:LEA1]LEACUR, [M:LEA1]IASCUR, GCOUDEV, [M:LEA1]IASCURTYP,
&          [M:LEA1]STRLEADAT, [M:LEA1]RPUVAL, [M:LEA1]IASRATCUR, [M:LEA1]RPUVALIAS)
    Endif
  Endif

End
#------------------------------------------------
Subprog AM_RATCUR(VALEUR)
Variable Decimal VALEUR

  If VALEUR <> [M:LEA1]RATCUR
    [M:LEA1]RATCUR = VALEUR
    Affzo [M:LEA1]RATCUR
    Call AP_RATCUR([M:LEA1]RATCUR)
  Endif

End
#------------------------------------------------
Subprog AP_IASRATCUR(VALEUR)
Variable Decimal VALEUR

  If ( GCNXPROIAS = G_OUI )  #*Fq-61084
    If VALEUR <> [M:LEA1]IASRATCUR
      [M:LEA1]IASRATCUR = VALEUR
      Affzo [M:LEA1]IASRATCUR
      Call AP_RATCUR([M:LEA1]RATCUR)
    Endif
  Endif

End
#------------------------------------------------
Subprog AM_IASRATCUR(VALEUR)
Variable Decimal VALEUR

  If ( GCNXPROIAS = G_OUI )  #*Fq-61084
    If VALEUR <> [M:LEA1]IASRATCUR
      [M:LEA1]IASRATCUR = VALEUR
      Affzo [M:LEA1]IASRATCUR
      Call AP_RATCUR([M:LEA1]RATCUR)
    Endif
  Endif

End
#=============================================================================
##
#=================================================================================================
Subprog RECALCUL_MONTANT_DEVSOC(PDEVORI, PDEVDES, PDEVSOC, PTYPCOURS, PDATCOURS, PMTORI, PCOURS, RMTDES)
#=============================================================================
Value    Char    PDEVORI           : # Devise d'origine
Value    Char    PDEVDES           : # Devise de destination
Value    Char    PDEVSOC           : # Devise société
Value    Integer PTYPCOURS         : # Type de cours
Value    Date    PDATCOURS         : # Date du cours
Value    Decimal PMTORI            : # Montant origine
Variable Decimal RMTDES            : # Montant destination
Value    Decimal PCOURS            : # Cours devise -> destination eventuelt donné

  Local Integer    STAT
  Local Decimal    MTDES

  # ------------- Conversion en devise société
  Call CONVERT3(PDEVORI, PDEVDES, GCOUDEV, PTYPCOURS, PDATCOURS, PMTORI, MTDES, PCOURS, STAT) From CPTSUB
  If STAT = 0 Then
    Call GET_MNT_ARRONDI (MTDES, [M:LEA1]CUR, MTDES) From GLOBIENS
    RMTDES=MTDES
  Else
    GMESSAGE = mess(18,GML_MSGFAS,1)
    GERR=1
    mkstat = 2
    End
  Endif

End
#=============================================================================
#
Subprog RECALCUL_MONTANT_DEVIAS(PDEVORI, PDEVDES, PDEVSOC, PTYPCOURS, PDATCOURS, PMTORI, PCOURS, RMTDES)

Value    Char    PDEVORI           : # Devise d'origine
Value    Char    PDEVDES           : # Devise de destination
Value    Char    PDEVSOC           : # Devise société
Value    Integer PTYPCOURS         : # Type de cours
Value    Date    PDATCOURS         : # Date du cours
Value    Decimal PMTORI            : # Montant origine
Variable Decimal RMTDES            : # Montant destination
Value    Decimal PCOURS            : # Cours devise -> destination eventuelt donné

  Local Integer    STAT
  Local Decimal    MTDES
  If ( GCNXPROIAS = G_OUI )
    # ------------- Conversion en devise IAS
    Call CONVERT3(PDEVORI, PDEVDES, PDEVSOC, PTYPCOURS, PDATCOURS, PMTORI, MTDES, PCOURS, STAT) From CPTSUB
    If STAT = 0
      Call GET_MNT_ARRONDI (MTDES, PDEVDES, MTDES) From GLOBIENS
      RMTDES=MTDES
    Else
      GMESSAGE = mess(18,GML_MSGFAS,1)
      GERR=1
      mkstat = 2
      End
    Endif
  Endif

End
#=============================================================================
#<*Fq-48189
$SORTIR_BIENS

  Global Char   WCPY
  Global Char   WFCY
  Global Char   WAASREF

  For I = 1 To  [M:LEA3]NBLIG3
    Read [FAS]FAS0  = [M:LEA3]AASREF(I-1)
    If fstat= 0
      WCPY       =  [M:LEA0]CPY
      WFCY       =  [M:LEA0]FCY
      WAASREF    =  [F:FAS] AASREF
      Gosub TRAITER_SORTIE
      If GOK=0
         Break
      Endif
    Endif
  Next I

  #> Suppression des globales
  Call  KILL_GLO_SILTRT() From  TRCPROCOM

  Call  LEC_TRACE()  From LECFIC

Return
#=============================================================================
$TRAITER_SORTIE
  Local Integer RETOUR
  Local Char    LIGNE(115)
  Local Char    LSTOBJREF

  Call OUVRE_TRACE(mess(671,GML_MSGFAS,1)) From LECFIC

  #> Appel de la sortie en mode silencieux
  Call LAUNCH_SILTRT("FASISS","SUBLEA",RETOUR) From TRCPROCOM

  #> Traitement du résultat de la sortie en mode  silencieux.

  If G_MAJOK=G_OUI
    Call  ECR_TRACE(mess(673,GML_MSGFAS,1),0)  From GESECRAN
  Else
    GOK=0
    If dim(GT_OBJ_REF)>0
      Call  ECR_TRACE(mess(671,GML_MSGFAS,1),1) From GESECRAN
      Call  ECR_TRACE(GT_OBJ_REF(0),0) From GESECRAN
      For  I=1 To dim(GT_LIS_ERR)
        LIGNE = GT_LIS_ERR(I-1)
        Call  ECR_TRACE(num$(I)-LIGNE,0) From GESECRAN
      Next  I
    Else
      Call  ECR_TRACE(GT_LIS_ERR(0),0)  From GESECRAN
    Endif
  Endif

Return
#=============================================================================
$CHGT_IMPUTATION_CPTABLE

  # Ouverture table
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif

  # Variables
  Global Char    WCPY
  Global Char    WFCY
  Global Char    WAASREF
  Global Integer WSIM    : WSIM    = G_NON
  Global Char    WACCCOD : WACCCOD = ""
  Global Integer WGACACN : WGACACN = 0
  Global Integer WIASACN : WIASACN = 0
  Global Char    WACGGRP : WACGGRP = ""

  For I = 1 To  [M:LEA3]NBLIG3
    Read [FAS]FAS0  = [M:LEA3]AASREF(I-1)
    If fstat= 0
      WCPY       =  [M:LEA0]CPY
      WFCY       =  [M:LEA0]FCY
      WAASREF    =  [F:FAS]AASREF
      # Table diverse 625
      Read[ADI]CODE=GTD_LEACCO;[F:FAS]ACCCOD
      If fstat=0
        WACCCOD =  [F:ADI]A2
      Else
        GMESSAGE = mess(110,GML_MSGGRT,1) # Code comptable pour transfert : inexistant dans la table 625
        GOK=0 : Break
      Endif
      Gosub TRAITER_CHGIMP
      If GOK=0 :
        Break
      Endif
    Endif
  Next I

  #> Suppression des globales
  Call  KILL_GLO_SILTRT() From  TRCPROCOM

  Call  LEC_TRACE()  From LECFIC

Return
#=============================================================================
$TRAITER_CHGIMP
  Local Integer RETOUR
  Local Char    LIGNE(115)
  Local Char    LSTOBJREF

  Call OUVRE_TRACE(mess(675,GML_MSGFAS,1)) From LECFIC

  Gosub  PREPARE_FASTRFC
  #> Appel du changement d'imputation comptable en mode silencieux
  Call LAUNCH_SILTRT("FASTRFC","SUBLEA",RETOUR) From TRCPROCOM

  #> Traitement du résultat de la sortie en mode  silencieux.
  If G_MAJOK=G_OUI
    Call  ECR_TRACE(mess(674,GML_MSGFAS,1),0)  From GESECRAN
  Else
    GOK=0
    If dim(GT_OBJ_REF)>0
      Call  ECR_TRACE(mess(675,GML_MSGFAS,1),1) From GESECRAN
      Call  ECR_TRACE(GT_OBJ_REF(0),0) From GESECRAN
      For  I=1 To dim(GT_LIS_ERR)
        LIGNE = GT_LIS_ERR(I-1)
        Call  ECR_TRACE(num$(I)-LIGNE,0) From GESECRAN
      Next  I
    Else
      Call  ECR_TRACE(GT_LIS_ERR(0),0)  From GESECRAN
    Endif
  Endif

Return

#==================================================
# PREPARATION DES INFOS NECESSAIRES AU LANCEMENT
# SILENCIEUX DE L'ACTION DE TRANSFERT
#==================================================
$PREPARE_FASTRFC

  # Variables
  Global Integer G_CNX

  # Tables
  If !clalev([F:FAS])  : Local File FXDASSETS [F:FAS]  : Endif
  If !clalev([F:MAS1]) : Local File FXDASSETS [F:MAS1] : Endif
  If !clalev([F:DEP])  : Local File DEPREC    [F:DEP]  : Endif

Return
#=========================================================================
# PREPARATION DES PARAMETRES NECESSAIRES AU TRAITEMENT EN MODE SILENCIEUX
#=============================================================================
#----- Sortie des biens
#----- Changement d'imputation comptable
$ALIM_MASK

  # Flag de simulation
  FLGSIM          =  G_NON
  [M:MHC]FLGSIM   =  G_NON

  # Alimentation de l'en-tête
  [M:MHC]FLGCPY(find(WCPY,[M:MHC]CPY)-1)  = G_OUI
  [M:MHC]FLGFCY(find(WFCY,[M:MHC]FCY)-1)  = G_OUI

  # Alimentation de l'onglet sélection pour fournir la référence du bien à traiter
  [M:ASL]TBL1          = "FXDASSETS"
  [M:ASL]FLD1          = "AASREF"
  [M:ASL]OPE1          = 2

  [M:ASL]VAL1          = WAASREF
  [M:ASL]VALI1         = WAASREF

  Case G_ACT
    When "LEAEND", "LEARES"
      [M:FASS]ISSDAT       = [F:FAS]ISSDAT
      [M:FASS]ISSTYP       = [F:FAS]ISSTYP
      [M:FASS]ISSDATRUL    = [F:FAS]ISSDATRUL
      [M:FASS]ISSAMTTYP    = GVML_TVAUCUN
      [M:FASS]ISSAMT       = [F:FAS]ISSAMT
      [M:FASS]PYBVATTYP    = GVML_SNSREGU
      [M:FASS]CCLISSFLG    = G_NON
    When"LEALEV"
      # Alimentation de l'onglet paramètres (Changement de méthode)
      Call INIT_PLAN_AMT(WCPY)From TRTFASTRFC
      # alimentation des globales
      GDATREF = [M:LEA1]RPUDAT
      G_CNX   = 1
      # Alimentation de l'onglet paramÃ©tres (Transfert imputation comptable)
      [M:FASC]MVTTYP       = "MES"
      [M:FASC]FLGACC       = G_OUI
      [M:FASC]ACCCODD      = WACCCOD
      [M:FASC]OWNTYPD      = 1

      Call AM_ACCCODD(WACCCOD) From TRTFASTRFC
      G_GAC       = [M:FASC]GACD
      If ( GCNXPROIAS = G_OUI )  : G_IASACC    = [M:FASC]IASACCD : Endif #Fq-61084
   Endcase

Return





######################################################################################
# Issue X3-70469
Subprog EVALUE_SUMPAY_ARRAY(PLEATYP)
Value Integer PLEATYP

Local Integer I_L
  For I_L = 1 To [M:LEA2]NBPER2
    If (PLEATYP = GVML_LOCATION) Then
      [M:LEA2]LEAYEA(I_L-1) = year([M:LEA2]STRPERDAT(I_L-1))
      [M:LEA2]SUMPAY(I_L-1) = [M:LEA2]RNTAMT(I_L-1) +
&                           [M:LEA2]VARPAY(I_L-1) +
&                           [M:LEA2]RSDVAL(I_L-1) +
&                           [M:LEA2]PUROPT(I_L-1) +
&                           [M:LEA2]TERPEN(I_L-1)
    Else
      [M:LEA2]LEAYEA(I_L-1) = 0
      [M:LEA2]SUMPAY(I_L-1) = 0
    Endif
  Next I_L

End

######################################################################################
Subprog EVALUE_CVAYEA(PLEATYP, PYEAR)
Value Integer PLEATYP
Value Integer PYEAR


  # Issue X3-70469 Uniquement pour les contrats de type Location
  If (PLEATYP <> GVML_LOCATION) Then : End : Endif

  Local Integer I_YD  # first line of a year NBPER2
  Local Integer I_YF  # last  line of a year NBPER2
  Local Integer N2
  Local Integer I_LIN  : I_LIN = 1
  Local Integer IND  :   IND = 1

  If ([M:LEA2]NBPER2 = 0) Then
    Raz [M:LEA2]NBYEA
    Raz [M:LEA2]CUMCVAYEA
    Raz [M:LEA2]CUMCVAYEAC : # X3-77642
    Raz [M:LEA2]CUMCVAYEAI : # X3-77642
    Raz [M:LEA2]CUMCVAUSE  : # X3-77643
    Raz [M:LEA2]CUMCVAUSEC : # X3-77643
    Raz [M:LEA2]CUMCVAUSEI : # X3-77643
    If (G_LEASTA = GVML_STAVAL)
      Raz [M:LEA2]INIPREVAL
      Raz [M:LEA2]INIPREVALC : # X3-77642
      Raz [M:LEA2]INIPREVALI : # X3-77642
      Raz [M:LEA2]INIPREUSE  : # X3-77643
      Raz [M:LEA2]INIPREUSEC : # X3-77643
      Raz [M:LEA2]INIPREUSEI : # X3-77643
    Endif
  Elsif ([M:LEA2]NBPER2 = 1) Then
    Raz [M:LEA2]NBYEA
    Raz [M:LEA2]CUMCVAYEA
    Raz [M:LEA2]CUMCVAYEAC : # X3-77642
    Raz [M:LEA2]CUMCVAYEAI : # X3-77642
    Raz [M:LEA2]CUMCVAUSE  : # X3-77643
    Raz [M:LEA2]CUMCVAUSEC : # X3-77643
    Raz [M:LEA2]CUMCVAUSEI : # X3-77643
    [M:LEA2]PERSTRYEA(0) = [M:LEA2]LEAYEA(0)
    [M:LEA2]NUMYEA   (0) = 1
    [M:LEA2]PAYYEA   (0) = [M:LEA2]SUMPAY(0)
    I_LIN = 1
    Gosub EVALUE_CVAYEA_B
    [M:LEA2]NBYEA        = 1
  Else
    If ( PYEAR = 0 ) Then
      Raz [M:LEA2]NBYEA
      Raz [M:LEA2]CUMCVAYEA
      Raz [M:LEA2]CUMCVAYEAC : # X3-77642
      Raz [M:LEA2]CUMCVAYEAI : # X3-77642
      Raz [M:LEA2]CUMCVAUSE  : # X3-77643
      Raz [M:LEA2]CUMCVAUSEC : # X3-77643
      Raz [M:LEA2]CUMCVAUSEI : # X3-77643
      I_YD = 1
      While IND > 0
        IND = find([M:LEA2]LEAYEA(I_YD-1) + 1,[M:LEA2]LEAYEA)
        If ( IND = 0 ) Then
          I_YF = [M:LEA2]NBPER2
        Else
          I_YF = IND-1
        Endif
        [M:LEA2]PERSTRYEA(I_LIN-1) = [M:LEA2]LEAYEA(I_YD-1)
        [M:LEA2]NUMYEA   (I_LIN-1) = I_LIN
        [M:LEA2]PAYYEA(I_LIN-1) = 0
        For N2 = I_YD To I_YF
          [M:LEA2]PAYYEA(I_LIN-1)   += [M:LEA2]SUMPAY(N2-1)
        Next
        Gosub EVALUE_CVAYEA_B
        I_YD = IND
        I_LIN += 1
      Wend
      [M:LEA2]NBYEA = I_LIN - 1
    Else
      I_YF = find(PYEAR + 1,[M:LEA2]LEAYEA)
      If (I_YF = 0) Then
        I_YF = find(PYEAR, [M:LEA2]LEAYEA)
        If (I_YF = 0) Then
        Else
          I_YF = [M:LEA2]NBPER2
        Endif
      Else
        I_YF = I_YF - 1
      Endif
      I_YD = find(PYEAR,[M:LEA2]LEAYEA)
      If (I_YF <> 0) Then
        I_LIN = find(PYEAR, [M:LEA2]PERSTRYEA)
        [M:LEA2]PAYYEA(I_LIN-1) = 0
        For N2 = I_YD To I_YF
          [M:LEA2]PAYYEA(I_LIN-1)   += [M:LEA2]SUMPAY(N2-1)
        Next
        [M:LEA2]CUMCVAYEA         -= [M:LEA2]CVAYEA(I_LIN-1)
        Gosub EVALUE_CVAYEA_B
      Else
        # New line
        I_LIN = [M:LEA2]NBYEA + 1
        [M:LEA2]NBYEA = I_LIN

        [M:LEA2]PERSTRYEA(I_LIN-1) = PYEAR
        [M:LEA2]NUMYEA   (I_LIN-1) = [M:LEA2]NUMYEA(I_LIN-2) + 1
        [M:LEA2]PAYYEA   (I_LIN-1) = [M:LEA2]SUMPAY([M:LEA2]NBPER2-1)
        Gosub EVALUE_CVAYEA_B
      Endif
    Endif
  Endif

  # Issue 77642
  # CUMCVAYEA -> CUMCVAYEAC
  Call RECALCUL_MONTANT_DEVSOC([M:LEA1]LEACUR, [M:LEA1]CUR, GCOUDEV, [M:LEA1]CURTYP,
&      [M:LEA1]STRLEADAT, [M:LEA2]CUMCVAYEA, [M:LEA1]RATCUR, [M:LEA2]CUMCVAYEAC)
  If ( GCNXPROIAS = G_OUI )
    # CUMCVAYEA -> CUMCVAYEAI
    Call RECALCUL_MONTANT_DEVIAS([M:LEA1]LEACUR, [M:LEA1]IASCUR, GCOUDEV, [M:LEA1]IASCURTYP,
&        [M:LEA1]STRLEADAT, [M:LEA2]CUMCVAYEA, [M:LEA1]IASRATCUR, [M:LEA2]CUMCVAYEAI)
  Endif

  If (G_LEASTA = GVML_STAVAL) Then
    [M:LEA2]INIPREVAL    = [M:LEA2]CUMCVAYEA
    [M:LEA2]INIPREVALC   = [M:LEA2]CUMCVAYEAC : # X3-77642
    If ( GCNXPROIAS = G_OUI )
      [M:LEA2]INIPREVALI   = [M:LEA2]CUMCVAYEAI : # X3-77642
    Endif
  Endif
  # End issue 77642

  Gosub RIGHT_OF_USE : # X3-77643

End
#***************
$EVALUE_CVAYEA_B

  # Issue X3-70469
  If ([M:LEA2]RATYEA(I_LIN-1) = 0) Then
    # X3-72297
    Local Decimal LRATYEA
    Call EVALUE_RATYEA([M:LEA1]IMPLEARAT, [M:LEA1]ICRBRWRAT, [M:LEA1]LEARAT, LRATYEA)
    [M:LEA2]RATYEA(I_LIN-1) = LRATYEA
  Endif
  [M:LEA2]CVAYEA(I_LIN-1)    = [M:LEA2]PAYYEA(I_LIN-1) / ( (1+([M:LEA2]RATYEA(I_LIN-1)/100))^I_LIN )
  Call GET_MNT_ARRONDI ([M:LEA2]CVAYEA(I_LIN-1), [M:LEA1]LEACUR, [M:LEA2]CVAYEA(I_LIN-1)) From GLOBIENS
  [M:LEA2]CUMCVAYEA         += [M:LEA2]CVAYEA(I_LIN-1)

Return
#***************


#***************
$RAZ_LEA2
  # Issue X3-70469
  Raz [M:LEA2]
  Raz [M:LEA2]NBPER2
  Raz [M:LEA2]CUMRNTAMT
  If ([M:LEA0]LEATYP = GVML_LOCATION)
    Raz [M:LEA2]NBYEA
    If (G_LEASTA <> GVML_STAVAL)
      Raz [M:LEA2]INIPREVAL
      Raz [M:LEA2]INIPREVALC : # X3-77642
      Raz [M:LEA2]INIPREVALI : # X3-77642
      Raz [M:LEA2]INIPREUSE  : # X3-77643
      Raz [M:LEA2]INIPREUSEC : # X3-77643
      Raz [M:LEA2]INIPREUSEI : # X3-77643
    Endif
    Raz [M:LEA2]CUMCVAYEA
    Raz [M:LEA2]CUMCVAYEAC : # X3-77642
    Raz [M:LEA2]CUMCVAYEAI : # X3-77642
    Raz [M:LEA2]CUMCVAUSE  : # X3-77643
    Raz [M:LEA2]CUMCVAUSEC : # X3-77643
    Raz [M:LEA2]CUMCVAUSEI : # X3-77643
  Endif
  Affzo [M:LEA2]
Return
#***************

######################################################################################
Subprog EVALUE_RATYEA(PIMPLEARAT, PICRBRWRAT, PLEARAT, RRATYEA)
Value Decimal    PIMPLEARAT
Value Decimal    PICRBRWRAT
Value Decimal    PLEARAT
Variable Decimal RRATYEA

  # X3-72927
  If (PIMPLEARAT <> 0.) Then
    RRATYEA = PIMPLEARAT
  Elsif (PICRBRWRAT <> 0) Then
    RRATYEA = PICRBRWRAT
  Else
    RRATYEA = PLEARAT
  Endif

End

######################################################################################
# Issue X3-68589
#**
#* Hide columns when location type
#*!
$MANAGE_LOCATION_FIELDS

  If (GDEVFMTL = "") Then : GDEVFMTL = "13.2" : Endif  : # X3-84302
  If (GDEVFMTC = "") Then : GDEVFMTC = "13.2" : Endif
  If (GDEVFMTI = "") Then : GDEVFMTI = "13.2" : Endif

  If ([M:LEA0]LEATYP = GVML_LOCATION) Then
    Chgfmt [M:LEA2]RMNTPA With "-N:13.2#"
    Chgfmt [M:LEA2]FINDPR With "-N:13.2#"
    Chgfmt [M:LEA2]FINEXS With "-N:13.2#"
    Chgfmt [M:LEA2]RPACAP With "-N:13.2#"
    Chgfmt [M:LEA2]VARPAY With "Nz3:"+GDEVFMTL
    Chgfmt [M:LEA2]RSDVAL With "Nz3:"+GDEVFMTL
    Chgfmt [M:LEA2]PUROPT With "Nz3:"+GDEVFMTL
    Chgfmt [M:LEA2]TERPEN With "Nz3:"+GDEVFMTL

    # Issue X3-70469
    Chgfmt [M:LEA2]NBYEA       With "N:4"
    Chgfmt [M:LEA2]INIPREVAL   With "Nz3:"+GDEVFMTL
    Chgfmt [M:LEA2]CUMCVAYEA   With "Nz3:"+GDEVFMTL
    Chgfmt [M:LEA2]INIPREUSE   With "Nz3:"+GDEVFMTL : # X3-77643
    Chgfmt [M:LEA2]CUMCVAUSE   With "Nz3:"+GDEVFMTL : # X3-77643

    Chgfmt [M:LEA2]SUMPAY      With "Nz3:"+GDEVFMTL
    Chgfmt [M:LEA2]PAYYEA      With "Nz3:"+GDEVFMTL
    Chgfmt [M:LEA2]CVAYEA      With "Nz3:"+GDEVFMTL

    Chgfmt [M:LEA2]LEACUR2     With "A3"
    # Issue 77642
    Chgfmt [M:LEA2]CUR2        With "A3"
    Chgfmt [M:LEA2]INIPREVALC  With "Nz3:"+GDEVFMTC
    Chgfmt [M:LEA2]CUMCVAYEAC  With "Nz3:"+GDEVFMTC
    Chgfmt [M:LEA2]INIPREUSEC  With "Nz3:"+GDEVFMTC : # X3-77643
    Chgfmt [M:LEA2]CUMCVAUSEC  With "Nz3:"+GDEVFMTC : # X3-77643
    If GCNXPROIAS = G_OUI
      Chgfmt [M:LEA2]IASCUR2     With "A3"
      Chgfmt [M:LEA2]INIPREVALI  With "Nz3:"+GDEVFMTI
      Chgfmt [M:LEA2]CUMCVAYEAI  With "Nz3:"+GDEVFMTI
      Chgfmt [M:LEA2]INIPREUSEI  With "Nz3:"+GDEVFMTI : # X3-77643
      Chgfmt [M:LEA2]CUMCVAUSEI  With "Nz3:"+GDEVFMTI : # X3-77643
    Endif
    # End issue 77642
  Elsif ([M:LEA0]LEATYP = GVML_CREBAIL) Then
    # The old columns are displayed  when LEATYP <> GVML_LOCATION (3)
    Chgfmt [M:LEA2]FINDPR With "Nz3:"+GDEVFMTL
    Chgfmt [M:LEA2]FINEXS With "Nz3:"+GDEVFMTL
    Chgfmt [M:LEA2]RMNTPA With "Nz3:"+GDEVFMTL
    Chgfmt [M:LEA2]RPACAP With "Nz3:"+GDEVFMTL

    #X3-68589-MDJ:  The new columns are hidden when  when LEATYP not equal to GVML_LOCATION (3)
    Chgfmt [M:LEA2]VARPAY    With "-Nz3:13.2"
    Chgfmt [M:LEA2]RSDVAL    With "-Nz3:13.2"
    Chgfmt [M:LEA2]PUROPT    With "-Nz3:13.2"
    Chgfmt [M:LEA2]TERPEN    With "-Nz3:13.2"

    # Issue X3-70469
    Chgfmt [M:LEA2]NBYEA       With "-N:4"
    Chgfmt [M:LEA2]INIPREVAL   With "-Nz3:13.2"
    Chgfmt [M:LEA2]CUMCVAYEA   With "-Nz3:13.2"
    Chgfmt [M:LEA2]INIPREUSE   With "-Nz3:13.2" : # X3-77643
    Chgfmt [M:LEA2]CUMCVAUSE   With "-Nz3:13.2" : # X3-77643

    Chgfmt [M:LEA2]SUMPAY      With "-Nz3:13.2"
    Chgfmt [M:LEA2]PAYYEA      With "-Nz3:13.2"
    Chgfmt [M:LEA2]CVAYEA      With "-Nz3:13.2"

    Chgfmt [M:LEA2]LEACUR2     With "-A3"
    # Issue 77642
    Chgfmt [M:LEA2]CUR2        With "-A3"
    Chgfmt [M:LEA2]INIPREVALC  With "-Nz3:"+GDEVFMTC
    Chgfmt [M:LEA2]CUMCVAYEAC  With "-Nz3:"+GDEVFMTC
    Chgfmt [M:LEA2]INIPREUSEC  With "-Nz3:"+GDEVFMTC : # X3-77643
    Chgfmt [M:LEA2]CUMCVAUSEC  With "-Nz3:"+GDEVFMTC : # X3-77643
    Chgfmt [M:LEA2]IASCUR2     With "-A3"
    Chgfmt [M:LEA2]INIPREVALI  With "-Nz3:"+GDEVFMTI
    Chgfmt [M:LEA2]CUMCVAYEAI  With "-Nz3:"+GDEVFMTI
    Chgfmt [M:LEA2]CUMCVAUSEI  With "-Nz3:"+GDEVFMTI : # X3-77643
    Chgfmt [M:LEA2]INIPREUSEI  With "-Nz3:"+GDEVFMTI : # X3-77643
    # End issue 77642
  Else
    # X3-84302 Location longue durée
    Chgfmt [M:LEA2]FINDPR With "Nz3:"+GDEVFMTL
    Chgfmt [M:LEA2]FINEXS With "Nz3:"+GDEVFMTL

    Chgfmt [M:LEA2]RMNTPA With "-Nz3:"+GDEVFMTL
    Chgfmt [M:LEA2]RPACAP With "-Nz3:"+GDEVFMTL

    Chgfmt [M:LEA2]VARPAY    With "-Nz3:13.2"
    Chgfmt [M:LEA2]RSDVAL    With "-Nz3:13.2"
    Chgfmt [M:LEA2]PUROPT    With "-Nz3:13.2"
    Chgfmt [M:LEA2]TERPEN    With "-Nz3:13.2"

    # Issue X3-70469
    Chgfmt [M:LEA2]NBYEA       With "-N:4"
    Chgfmt [M:LEA2]INIPREVAL   With "-Nz3:13.2"
    Chgfmt [M:LEA2]CUMCVAYEA   With "-Nz3:13.2"
    Chgfmt [M:LEA2]INIPREUSE   With "-Nz3:13.2" : # X3-77643
    Chgfmt [M:LEA2]CUMCVAUSE   With "-Nz3:13.2" : # X3-77643

    Chgfmt [M:LEA2]SUMPAY      With "-Nz3:13.2"
    Chgfmt [M:LEA2]PAYYEA      With "-Nz3:13.2"
    Chgfmt [M:LEA2]CVAYEA      With "-Nz3:13.2"

    Chgfmt [M:LEA2]LEACUR2     With "-A3"
    # Issue 77642
    Chgfmt [M:LEA2]CUR2        With "-A3"
    Chgfmt [M:LEA2]INIPREVALC  With "-Nz3:"+GDEVFMTC
    Chgfmt [M:LEA2]CUMCVAYEAC  With "-Nz3:"+GDEVFMTC
    Chgfmt [M:LEA2]INIPREUSEC  With "-Nz3:"+GDEVFMTC : # X3-77643
    Chgfmt [M:LEA2]CUMCVAUSEC  With "-Nz3:"+GDEVFMTC : # X3-77643
    Chgfmt [M:LEA2]IASCUR2     With "-A3"
    Chgfmt [M:LEA2]INIPREVALI  With "-Nz3:"+GDEVFMTI
    Chgfmt [M:LEA2]CUMCVAYEAI  With "-Nz3:"+GDEVFMTI
    Chgfmt [M:LEA2]CUMCVAUSEI  With "-Nz3:"+GDEVFMTI : # X3-77643
    Chgfmt [M:LEA2]INIPREUSEI  With "-Nz3:"+GDEVFMTI : # X3-77643
  Endif

  # Start Necessary to apply the change FMT on each defined line
  Local Decimal LMNT
  For nolign = 1 To [M:LEA2]NBPER2
     # RNTAMT
     LMNT = [M:LEA2]RNTAMT(nolign-1)
     Effzo [M:LEA2]RNTAMT(nolign-1)
     [M:LEA2]RNTAMT(nolign-1) = LMNT : Affzo [M:LEA2]RNTAMT(nolign-1)

     If ([M:LEA0]LEATYP = GVML_LOCATION) Then
       # SUMPAY
       LMNT = [M:LEA2]SUMPAY(nolign-1)
       Effzo [M:LEA2]SUMPAY(nolign-1)
       [M:LEA2]SUMPAY(nolign-1) = LMNT : Affzo [M:LEA2]SUMPAY(nolign-1)
       # VARPAY
       LMNT = [M:LEA2]VARPAY(nolign-1)
       Effzo [M:LEA2]VARPAY(nolign-1)
       [M:LEA2]VARPAY(nolign-1) = LMNT : Affzo [M:LEA2]VARPAY(nolign-1)
       # RSDVAL
       LMNT = [M:LEA2]RSDVAL(nolign-1)
       Effzo [M:LEA2]RSDVAL(nolign-1)
       [M:LEA2]RSDVAL(nolign-1) = LMNT : Affzo [M:LEA2]RSDVAL(nolign-1)
       # PUROPT
       LMNT = [M:LEA2]PUROPT(nolign-1)
       Effzo [M:LEA2]PUROPT(nolign-1)
       [M:LEA2]PUROPT(nolign-1) = LMNT : Affzo [M:LEA2]PUROPT(nolign-1)
       # TERPEN
       LMNT = [M:LEA2]TERPEN(nolign-1)
       Effzo [M:LEA2]TERPEN(nolign-1)
       [M:LEA2]TERPEN(nolign-1) = LMNT : Affzo [M:LEA2]TERPEN(nolign-1)
     Else
       # FINDPR
       LMNT = [M:LEA2]FINDPR(nolign-1)
       Effzo [M:LEA2]FINDPR(nolign-1)
       [M:LEA2]FINDPR(nolign-1) = LMNT : Affzo [M:LEA2]FINDPR(nolign-1)
       # FINEXS
       LMNT = [M:LEA2]FINEXS(nolign-1)
       Effzo [M:LEA2]FINEXS(nolign-1)
       [M:LEA2]FINEXS(nolign-1) = LMNT : Affzo [M:LEA2]FINEXS(nolign-1)
       If ([M:LEA0]LEATYP = GVML_CREBAIL) Then : # X3-84302
         # RMNTPA
         LMNT = [M:LEA2]RMNTPA(nolign-1)
         Effzo [M:LEA2]RMNTPA(nolign-1)
         [M:LEA2]RMNTPA(nolign-1) = LMNT : Affzo [M:LEA2]RMNTPA(nolign-1)
         # RPACAP
         LMNT = [M:LEA2]RPACAP(nolign-1)
         Effzo [M:LEA2]RPACAP(nolign-1)
         [M:LEA2]RPACAP(nolign-1) = LMNT : Affzo [M:LEA2]RPACAP(nolign-1)
       Endif
     Endif
  Next nolign

  If ([M:LEA0]LEATYP = GVML_LOCATION) Then
    For nolign = 1 To [M:LEA2]NBYEA
      # PAYYEA
      LMNT = [M:LEA2]PAYYEA(nolign-1)
      Effzo [M:LEA2]PAYYEA(nolign-1)
      [M:LEA2]PAYYEA(nolign-1) = LMNT : Affzo [M:LEA2]PAYYEA(nolign-1)
      # CVAYEA
      LMNT = [M:LEA2]CVAYEA(nolign-1)
      Effzo [M:LEA2]CVAYEA(nolign-1)
      [M:LEA2]CVAYEA(nolign-1) = LMNT : Affzo [M:LEA2]CVAYEA(nolign-1)
    Next nolign
  Endif
  # End Necessary to apply the change FMT on each defined line

Return
# issue X3-68589 End


######################################################################################
# Issue X3-77642
#**
#* Hide IAS columns
#*
#* @param PLEATYP   location type
#*!
$MANAGE_IAS_FIELDS

  If (GDEVFMTI = "") Then : GDEVFMTI = "13.2" : Endif
  If ( GCNXPROIAS = G_OUI ) Then
    If ([M:LEA0]LEATYP = GVML_LOCATION) Then
      Chgfmt [M:LEA2]IASCUR2    With "KP:3#"
      Chgfmt [M:LEA2]INIPREVALI With "Nz3:"+GDEVFMTI
      Chgfmt [M:LEA2]CUMCVAYEAI With "Nz3:"+GDEVFMTI
      Chgfmt [M:LEA2]INIPREUSEI With "Nz3:"+GDEVFMTI
      Chgfmt [M:LEA2]CUMCVAUSEI With "Nz3:"+GDEVFMTI
    Endif
    Chgfmt [M:LEA1]IASCUR       With "KP:3#"
    Chgfmt [M:LEA3]IASCUR       With "KP:3#"
    Chgfmt [M:LEA3]IASCUR2      With "KP:3#"
    Chgfmt [M:LEA1]IASRATCUR    With L_RATCURFMT     : # X3-84302
    Chgfmt [M:LEA1]LEAAMTIAS    With "Nz3:"+GDEVFMTI
    Chgfmt [M:LEA1]RPUVALIAS    With "Nz3:"+GDEVFMTI
    Chgfmt [M:LEA3]BSEDEVIAS    With "Nz3:"+GDEVFMTI
    Chgfmt [M:LEA3]CUMBSEIAS    With "Nz3:"+GDEVFMTI
    Chgfmt [M:LEA3]DIFRNTBSE    With "Nz3:"+GDEVFMTI
    Chgfmt [M:LEA5]VIASRATCUR   With L_RATCURFMT     : # X3-84302
    Chgfmt [M:LEA5]VLEAAMTIAS   With "Nz3:"+GDEVFMTI
  Else
    If ([M:LEA0]LEATYP = GVML_LOCATION) Then
      Chgfmt [M:LEA2]IASCUR2    With "-KP:3#"
      Chgfmt [M:LEA2]INIPREVALI With "-Nz3:13.2"
      Chgfmt [M:LEA2]CUMCVAYEAI With "-Nz3:13.2"
      Chgfmt [M:LEA2]INIPREUSEI With "-Nz3:13.2"
      Chgfmt [M:LEA2]CUMCVAUSEI With "-Nz3:13.2"
    Endif
    Chgfmt [M:LEA1]IASCUR        With "-KX:3#"
    Chgfmt [M:LEA3]IASCUR        With "-KX:3#"
    Chgfmt [M:LEA1]ZIASCUR       With "-KX:20#"
    Chgfmt [M:LEA1]IASRATCUR     With "-N:11F#"
    Chgfmt [M:LEA3]IASCUR2       With "-KX:3#"
    Chgfmt [M:LEA1]LEAAMTIAS     With "-NX:13.2#"
    Chgfmt [M:LEA1]RPUVALIAS     With "-NX:13.2#"
    Chgfmt [M:LEA2]FARFLGI       With "-NX:1#"
    Chgfmt [M:LEA3]BSEDEVIAS     With "-NX:13.2#"
    Chgfmt [M:LEA3]CUMBSEIAS     With "-NX:13.2#"
    Chgfmt [M:LEA3]DIFRNTBSE     With "-NX:13.2#"
    Chgfmt [M:LEA5]VIASRATCUR    With "-NX:13.2#"
    Chgfmt [M:LEA5]VLEAAMTIAS    With "-NX:13.2#"
  Endif
#format$
Return

######################################################################################
# Issue X3-77642
#**
#* Rounding ammounts in finance currency
#*
#* @param PLEATYP   location type
#*!
$ROUNDING_LEACUR_AMOUNTS

  Call GET_MNT_ARRONDI ([M:LEA1]LEAAMT,    [M:LEA1]LEACUR, [M:LEA1]LEAAMT)    From GLOBIENS
  Call GET_MNT_ARRONDI ([M:LEA1]RPUVAL,    [M:LEA1]LEACUR, [M:LEA1]RPUVAL)    From GLOBIENS
  Call GET_MNT_ARRONDI ([M:LEA1]BEFRNT,    [M:LEA1]LEACUR, [M:LEA1]BEFRNT)    From GLOBIENS
  Call GET_MNT_ARRONDI ([M:LEA1]LEAEXS,    [M:LEA1]LEACUR, [M:LEA1]LEAEXS)    From GLOBIENS
  Call GET_MNT_ARRONDI ([M:LEA1]INIDIRCST, [M:LEA1]LEACUR, [M:LEA1]INIDIRCST) From GLOBIENS
  Call GET_MNT_ARRONDI ([M:LEA1]RESCOS,    [M:LEA1]LEACUR, [M:LEA1]RESCOS)    From GLOBIENS

  Raz [M:LEA2]CUMRNTAMT
  For nolign = 1 To [M:LEA2]NBPER2
    Call GET_MNT_ARRONDI ([M:LEA2]RNTAMT(nolign-1), [M:LEA1]LEACUR, [M:LEA2]RNTAMT(nolign-1)) From GLOBIENS
    [M:LEA2]CUMRNTAMT +=[M:LEA2]RNTAMT(nolign-1)
    If ([M:LEA0]LEATYP = GVML_LOCATION) Then
      Call GET_MNT_ARRONDI ([M:LEA2]VARPAY(nolign-1), [M:LEA1]LEACUR, [M:LEA2]VARPAY(nolign-1)) From GLOBIENS
      Call GET_MNT_ARRONDI ([M:LEA2]PUROPT(nolign-1), [M:LEA1]LEACUR, [M:LEA2]PUROPT(nolign-1)) From GLOBIENS
      Call GET_MNT_ARRONDI ([M:LEA2]RSDVAL(nolign-1), [M:LEA1]LEACUR, [M:LEA2]RSDVAL(nolign-1)) From GLOBIENS
      Call GET_MNT_ARRONDI ([M:LEA2]TERPEN(nolign-1), [M:LEA1]LEACUR, [M:LEA2]TERPEN(nolign-1)) From GLOBIENS
    Else
      Call GET_MNT_ARRONDI ([M:LEA2]FINDPR(nolign-1), [M:LEA1]LEACUR, [M:LEA2]FINDPR(nolign-1)) From GLOBIENS
      Call GET_MNT_ARRONDI ([M:LEA2]FINEXS(nolign-1), [M:LEA1]LEACUR, [M:LEA2]FINEXS(nolign-1)) From GLOBIENS
      If ([M:LEA0]LEATYP = GVML_CREBAIL) Then : # X3-84302
        Call GET_MNT_ARRONDI ([M:LEA2]RMNTPA(nolign-1), [M:LEA1]LEACUR, [M:LEA2]RMNTPA(nolign-1)) From GLOBIENS
        Call GET_MNT_ARRONDI ([M:LEA2]RPACAP(nolign-1), [M:LEA1]LEACUR, [M:LEA2]RPACAP(nolign-1)) From GLOBIENS
      Endif
    Endif
  Next

  Affzo [M:LEA1]
  Affzo [M:LEA2]

  Call EVALUE_SUMPAY_ARRAY([M:LEA0]LEATYP)
  Affzo [M:LEA2]5
  Call EVALUE_CVAYEA ([M:LEA0]LEATYP,0)
  Affzo [M:LEA2]15-20


Return

######################################################################################
# Issue X3-77643
#**
#* Calculate right of use ammounts in finance currency then converted in company currency and IFRS currency
#*
#*!
$RIGHT_OF_USE
  If ([M:LEA0]LEATYP = GVML_LOCATION) Then
    [M:LEA2]INIPREUSE = [M:LEA1]BEFRNT + [M:LEA1]LEAEXS + [M:LEA1]INIDIRCST + [M:LEA1]RESCOS + [M:LEA2]INIPREVAL
    [M:LEA2]CUMCVAUSE = [M:LEA1]BEFRNT + [M:LEA1]LEAEXS + [M:LEA1]INIDIRCST + [M:LEA1]RESCOS + [M:LEA2]CUMCVAYEA
    # INIPREUSE -> INIPREUSEC
    Call RECALCUL_MONTANT_DEVSOC([M:LEA1]LEACUR, [M:LEA1]CUR, GCOUDEV, [M:LEA1]CURTYP,
&        [M:LEA1]STRLEADAT, [M:LEA2]INIPREUSE, [M:LEA1]RATCUR, [M:LEA2]INIPREUSEC)
    # CUMCVAUSE -> CUMCVAUSEC
    Call RECALCUL_MONTANT_DEVSOC([M:LEA1]LEACUR, [M:LEA1]CUR, GCOUDEV, [M:LEA1]CURTYP,
&        [M:LEA1]STRLEADAT, [M:LEA2]CUMCVAUSE, [M:LEA1]RATCUR, [M:LEA2]CUMCVAUSEC)
    If ( GCNXPROIAS = G_OUI )
      # INIPREUSE -> INIPREUSEI
      Call RECALCUL_MONTANT_DEVIAS([M:LEA1]LEACUR, [M:LEA1]IASCUR, GCOUDEV, [M:LEA1]IASCURTYP,
&          [M:LEA1]STRLEADAT, [M:LEA2]INIPREUSE, [M:LEA1]IASRATCUR, [M:LEA2]INIPREUSEI)
      # CUMCVAUSE -> CUMCVAUSEI
      Call RECALCUL_MONTANT_DEVIAS([M:LEA1]LEACUR, [M:LEA1]IASCUR, GCOUDEV, [M:LEA1]IASCURTYP,
&          [M:LEA1]STRLEADAT, [M:LEA2]CUMCVAUSE, [M:LEA1]IASRATCUR, [M:LEA2]CUMCVAUSEI)
    Endif
  Endif
Return
######################################################################################
# Issue X3-109499 - RD - Events Icon in header
######################################################################################
Subprog CL_EVTLIST(VALEUR)
Variable Char    VALEUR()

 Call CL_EVTLIST(VALEUR) From SUBFRZ

End
######################################################################################


$EVALUE_RATCUR_FMT
  #  X3-84302
  Local Char L_RATCURFMT(6)
  Case GDECRCU
  When 1 : L_RATCURFMT = "N:1.9#"
  When 2 : L_RATCURFMT = "N:2.8#"
  When 3 : L_RATCURFMT = "N:3.7#"
  When 4 : L_RATCURFMT = "N:4.6#"
  When 5 : L_RATCURFMT = "N:5.5#"
  When 6 : L_RATCURFMT = "N:6.4#"
  When 7 : L_RATCURFMT = "N:7.3#"
  When 8 : L_RATCURFMT = "N:8.2#"
  When 9 : L_RATCURFMT = "N:9.1#"
  When Default : L_RATCURFMT = "N:3.6#"
  Endcase
Return

