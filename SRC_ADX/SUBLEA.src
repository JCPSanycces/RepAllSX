#<AdxTL>@(#)0.0.0.0 $Revision$
#*******************************************************************************
#
#                    GESTION DES CONTRATS DE LOCATION FINANCEMENT
#
#*******************************************************************************
#    Création V6
#    MDJ - 08.10.2008
#
#**********************************************************************************
#    Modification
# Issue X3-84302 - 10.10.2018 by MWA : Manage the open schedule of the contract
# Issue X3-109499 -2018-09-20 by MDJ : RD - Events Icon in header
# Issue X3-77643 - 2018-03-08 by MWA : IFRS16 - Right of use
# Issue X3-81205 - 2018-03-08 by MWA : IFRS16 - Import contract lease
# Issue X3-77642 - 2018-02-20 by MWA : IFRS16 - Present value in currency
# Issue X3-72994 - 2018-01-23 by MWA : IFRS16 - Fixes on lease
# Issue X3-72927 - 2018-01-23 by MWA : IFRS16 - New rates fields
# Issue X3-70469 - 2018-01-10 by MWA : IFRS16 - Fixed assets valuation
# Issue X3-68589 - 2017-12-18 by CBO : hide columns when location type
# Issue X3-68588 - 2017-12-18 by CBO : Change title when location type
# MWA  08.11.2017 X3-61130  : Lease payments - Splitting periods
# CBO  07.11.2017 X3-8349   : IFRS 2016
# MDJ  20.09.2016 117042    : Calcul nombre de mois erroné : NBRMONPER incorrect
# MDJ  11.05.2015 FQ107913  : Calcul échéances erroné : NBRMONPER incorrect
# MDJ  24.02.2015 FQ105960  : Alimentation de certains champs (CUR, NBRMONPER, NBRWEKPER )
# MDJ  01.12.2014 FQ104388  : Echéancier contrat  location longue durée nok quand capital non saisi
# MDJ  13.05.2014 FQ98512   : Tableau des imputations analytiques non renseigné en création
# MDJ  13.05.2014 FQ98512   : Possibilité de créer un contrat sans Désignation
# MDJ  17.05.2013 FQ89986   : Devise affichée dans LEA2 incorrecte
# MDJ  14.03.2013 FQ79815   : Defaults analytical dimensions
# CBO  08.03.2013 FQ84089   : pas de LOA si aucun bien
# MWA  31.10.2012 FQ85464   : Prise en compte de la legislation dans la numérotation automatique
# CBO  22.06.2012 FQ82709   : contrôle (général) des axes analytiques
# GLE  03.04.2012 FQ80815   : Possibilité d'importer des contrats dont date début contrat < date début exercice du contexte IAS/IFRS
# GLE  25.01.2012 FQ79404   : Pb initialisation du tableau des axes analytiques
# MDJ  03.10.2011 FQ70853   : Remise à 0 de CUMIASBSE en cas de duplication d'un CLF
# MDJ  22.03.2011 Fq61084   : Contrat location-financement sans plan IAS
# MDJ  02.02.2011 Fq71281   : Pb sur déclaration de DURPER dans CALCUL_DATES_ECHEANCE
# MDJ  22.12.2010 Fq70141   : Vérification de sources (interne)
# MDJ  26.04.2010 Fq64312   : Certification NF NC35 : Echéancier et dotations
# GBO  27.01.2010 FQ61803   : Faire disparaître le menu contextuel "paramétrage société" si le paramètre DBG est à non
# MDJ  22.12.2009 Fq61084   : Contrat location-financement sans plan IAS
# MDJ  09.10.2009 Fq58845   : Problème de conversions
# MDJ  09.10.2009 Fq58569   : CLF racheté ou résilié ==> toutes  modifications interdites
# MDJ  06.05.2009 Fq55017   : Duplication si statut "En cours" : statut passe à "A valider"
# MDJ  03.04.2009 Fq54129   : Calcul auto nombre de mois échéancier
#**********************************************************************************
#
  Raz GPILOBJ
  Call DEFVAR From GLOBIMM
  Call INIVAR From GLOBIMM
  Call OBJET("LEA",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
  Case ACTION
    When "SETTRANS"        : Local Integer LLEATRS : Gosub SET_TRS_PARM From SUBTSH
    When "OUVRE"           : Gosub OUVRE
    When "RAZCRE"          : Gosub RAZCRE
    When "RAZDUP"          : Gosub RAZDUP
    When "VERROU"          : Gosub VERROU
    When "DEVERROU"        : Gosub DEVERROU
    When "VERIF_CRE"       : Gosub VERIF_CRE
    When "INICRE"          : Gosub INICRE
    When "CREATION"        : Gosub CREATION
    When "APRES_CRE"       : Gosub APRES_CRE
    When "LIENS"           : Gosub LIENS
    When "STYLE"           : Gosub STYLE
    When "APRES_MODIF"     : Gosub APRES_MODIF
    When "SETBOUT"         : Gosub SETBOUT
    When "AVANTBOUT"       : Gosub AVANTBOUT
    When "AVANT_MOD"       : Gosub AVANT_MOD
    When "VERIF_MOD"       : Gosub VERIF_MOD
    When "AVANT_MODFIC"    : Gosub AVANT_MODFIC
    When "INIMOD"          : Gosub INIMOD
    When "MODIF"           : Gosub MODIF
    When "APRES_MOD"       : Gosub APRES_MOD
    When "AB_MODIF"        : Gosub AB_MODIF
    When "AV_ANNULE"       : Gosub AV_ANNULE
    When "APRES_CHOI"      : Gosub APRES_CHOI
    When "FERME"           : Gosub FERME
    When "FIN_ACTION"      : Gosub FIN_ACTION
    When "FIN"             : Gosub FIN
    When Default
  Endcase
Return
#
#*********************************************************************
#
$OUVRE

  # X3-68589 MWA
  Local Integer B_FIRST : B_FIRST = 1
  Global Integer G_LEASTA

  # Numérotation automatique
  Local Integer STAT

  # Gestion tables
  If clalev([F:LEA]) =0    : Local File LEASE       [LEA]    : Endif
  If clalev([F:LBB]) =0    : Local File LEABILBOOK  [LBB]    : Endif
  If clalev([F:TCA]) =0    : Local File TABCOUAFF   [TCA]    : Endif
  If clalev([F:FAS]) =0    : Local File FXDASSETS   [FAS]    : Endif
  If clalev([F:FIS]) =0    : Local File FISCYEAR    [FIS]    : Endif
  If clalev([F:DEP]) =0    : Local File DEPREC      [DEP]    : Endif
  If clalev([F:CNX]) =0    : Local File CONTEXT     [CNX]    : Endif
  #Inutilisé en V8/AKIRA If clalev([F:ELA])= 0    : Local File EVELEA      [ELA]    : Endif
  If clalev([F:E42])= 0    : Local File ELEACRT     [E42]    : Endif
  If clalev([F:E41])= 0    : Local File ELEAACTU    [E41]    : Endif

  #-----------------------------------------------------------------------------------#
  # Si on vient par tunnel il faut sauvegarder les variables globales   #
  #-----------------------------------------------------------------------------------#
  If TUNNEL : Gosub SAUVE_GLOBAL_SV From GLOBIMM : Endif
  If TUNNEL : Gosub SAUVE_GLOB_TUNNEL From TRUPROACT : Endif
  #-------------------------
  # Appel à la fonction de gestion des zones libres
  Gosub OUVRE From SUBFRZ
  #-------------------------
  # Appel au sous-programme d'initialisation de la gestion des globales d'environnement
  Call INIT_FCY () From GLOFCYCPY

  #Fq-48779
  Global Char GPAYS
  If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
  Read [CPY]CPY0=GSOCIETE
  If fstat
    GPAYS = ""
  Else
    GPAYS = [F:CPY]CRY
  Endif

  Global Date    GDPERDAT0  # date de début de la 1ère période de l'échéancier
  Global Date    GFPERDAT0  # date de fin de la 1ère période de l'échéancier
  Global Integer GLEACRT    : GLEACRT=G_NON # Indicateur de modif statut de "A valider" à "En cours"
  Global Integer G_NBAXE    : #Fq-79815 Nb d'axes à saisir (max 20)
  Global Char    GDEVFMTL(10) : # Lease   currency format
  Global Char    GDEVFMTC(10) : # Company currency format
  Global Char    GDEVFMTI(10) : # IFRS    currency format

  Gosub EVALUE_RATCUR_FMT From SUBLEA : # => L_RATCURFMT  X3-84302

Return
#=====================================================================
#
$RAZCRE

  [M:LEA1]LEACUR  = GLOCALDEV : Affzo [M:LEA1]LEACUR  : # X3-77462
  [M:LEA2]LEACUR  = GLOCALDEV : Affzo [M:LEA2]LEACUR  : # X3-77462
  [M:LEA2]LEACUR2 = GLOCALDEV : Affzo [M:LEA2]LEACUR2 : # X3-77462
  G_LEASTA       = GVML_STAVAL  : # Issue X3-70469
  GLEACRT        = G_NON        : # Issue X3-71287

  [M:LEA0]LEATYP = GVML_CREBAIL : # Issue X3-84302
  Gosub MANAGE_LOCATION_FIELDS  : # Issue X3-68589 MWA

Return
#=====================================================================
#
$RAZDUP

  [M:LEA0]LEASTA = GVML_STAVAL #* FQ-55017
  Actzo [M:LEA0]LEASTA
  G_LEASTA       = GVML_STAVAL # Issue X3-70469
  GLEACRT        = G_NON       # Issue X3-71287

  # Issue X3-72994
  Actzo [M:LEA0]LEATYP

  # Issue X3-70469
  If ([M:LEA0]LEATYP = GVML_LOCATION) Then
    [M:LEA2]INIPREVAL    = [M:LEA2]CUMCVAYEA
    # Issue 77642
    [M:LEA2]INIPREVALC   = [M:LEA2]CUMCVAYEAC
    If ( GCNXPROIAS = G_OUI )
      [M:LEA2]INIPREVALI   = [M:LEA2]CUMCVAYEAI
    Endif
    Gosub RIGHT_OF_USE : # X3-77643
    # End issue 77642
    Actzo [M:LEA1]STRLEADAT, ENDLEADAT
    Raz [M:LEA1]ENDLEADATO
  Endif

  Affzo [M:LEA0]
  Affzo [M:LEA1]
  Affzo [M:LEA2]
  Affzo [M:LEA4]
  Affzo [M:LEA5]

  #  Remise à blanc du tableau des biens qui étaient associés au contrat dupliqué
  Raz   [M:LEA3]
  Affzo [M:LEA3]
  Raz   [M:LEA1] CUMIASBSE  #Fq-70853
  Affzo [M:LEA1]            #Fq-70853

  # Issue X3-83749
  Actzo [M:LEA1]LEAAMT

  # Issue X3-83749
  Local Integer IE
  For IE=1 To [M:LEA2]NBPER2
    [M:LEA2]FARFLG (IE-1) = [V]CST_ANO
    [M:LEA2]FARFLGI(IE-1) = [V]CST_ANO
    # Issue X3-84300
    Actzo [M:LEA2]STRPERDAT(IE-1), ENDPERDAT(IE-1), RNTAMT(IE-1)
    If ([M:LEA0]LEATYP = GVML_LOCATION) Then
      Actzo [M:LEA2]VARPAY(IE-1), RSDVAL(IE-1), TERPEN(IE-1), PUROPT(IE-1)
      Actzo [M:LEA2]LEAYEA(IE-1), SUMPAY(IE-1)
    Else
      # X3-84302
      Actzo [M:LEA2]FINDPR(IE-1), FINEXS(IE-1)
      If ([M:LEA0]LEATYP = GVML_CREBAIL) Then
        Actzo [M:LEA2]RMNTPA(IE-1), RPACAP(IE-1)
      Endif
    Endif
  Next IE
  Affzo [M:LEA2]

Return
#-------------------------------------------------------------------------------
$VERROU

  Local Char LLOCK(200)

  # Pour interdire toute modification sur l'objet
  LLOCK = func GLOBIENS.GET_KEY_LEASE ([M:LEA0]LEAREF)
  If func GLOBIENS.IS_SYMBOLE_LOCKED ("LEA", [M:LEA0]CPY, LLOCK) = 0 Then
    # Test si la société est verrouillée sur cette table pour en empêcher la modification
    OK = 0
  Else
    # sinon on gère à la main le verrou identifiant+société pour permettre le contrôle
    # de tester si le lockage de la table pour la société est possible
    If func GLOBIENS.LOCK_SYMBOLE_CPY ("LEA", [M:LEA0]CPY, LLOCK, 0) = 0 Then
      # on teste rien, normalement ça marche puisqu'on a pu locker l'enregistrement
      # et que la société n'est pas lockée
    Endif
  Endif

Return
#-------------------------------------------------------------------------------
$DEVERROU

  Local Char LLOCK(200)

  LLOCK = func GLOBIENS.GET_KEY_LEASE ([M:LEA0]LEAREF)
  Call UNLOCK_SYMBOLE_CPY ("LEA", [M:LEA0]CPY, LLOCK) From GLOBIENS

Return
#=====================================================================
#
$SETBOUT

  # Désactivation de l'action  Changer de clé
  Call VIREBOUT(CHAINE,"H") From GOBJET

  # Désactivation du bouton Supprimer si biens rattachés et statut <> "résilié", "rachat" ou "échu"
  If ([M:LEA0]LEASTA <> GVML_STAVAL)&([M:LEA0]LEASTA <> GVML_STECHU)&([M:LEA0]LEASTA <> GVML_STRESIL)&([M:LEA0]LEASTA <> GVML_STRACHA)
    Call VIREBOUT(CHAINE,"A") From GOBJET
  Endif

  # Activation menu Actions

  # Menu B Actions
  #        Option S Enregistrer la fin du contrat   uniquement si statut du contrat est "en cours"
  #        Option T Lever l'option d'achat          uniquement si statut du contrat est "en cours"
  #        Option U Résilier le contrat             uniquement si statut du contrat est "en cours"
  #        Option V Actualiser le contrat           uniquement si statut du contrat est "en cours"
  #        Option E Liste des événements
  #
  #If ([M:LEA0]LEASTA = GVML_STENCOU)  : # X3-111936
  If ([M:LEA0]LEASTA = GVML_STENCOU) and GREP = ""  # X3-84302
    # FQ84089 Si pas de bien : la levée de l'option d'achat n'est pas possible
    # test complété par le nb de biens liés
    If  ([M:LEA0]LEATYP = GVML_CREBAIL and [M:LEA3]NBLIG3)
      [L]CHMEN+="STUVE"
    Elsif([M:LEA0]LEATYP = GVML_LOCATION)
      # Issue X3-56289
      If (GREP = "M") Then
        [L]CHMEN+="E"
      Else
        [L]CHMEN+="SUVE"
      Endif
    Else
      [L]CHMEN+="SUVE"
    Endif
  Else
    [L]CHMEN+="E"
  Endif

  #~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
  # GBN # Menus
  # Pour chaque action métier, ajouter une occurrence dans LIS_ACT
  # Ecrire la condition d'activation du bouton dans le traitement
  # TRT+nomAction dans l'étiquette CRITMEN de ACTMET en alimentant
  # la variable CRITMEN

  Local Char LIS_ACT(15)(20)
  LIS_ACT(0)="X"
  Gosub ACTION From TRTOBJACT
  #~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

  Gosub SET_BOUT_SPE  From GSAISIE

Return
#=====================================================================
$AVANTBOUT

  # Fermeture des masques si déjà ouverts
  If (clalev([M:OAC0])) Then : Close Mask [OAC0] : Endif
  If (clalev([M:OCP]))  Then : Close Mask [OCP] : Endif
  If (clalev([M:LEAL])) Then : Close Mask [LEAL] : Endif
  If (clalev([M:LEAR])) Then : Close Mask [LEAR] : Endif
  If (clalev([M:LEAC])) Then : Close Mask [LEAC] : Endif

  # Ouverture des masques de la fenêtre d'une action métier
  Case BOUT
    When "T"        :
      Local Mask LEALEV0   [OAC0]
      Local Mask LEALEV    [LEAL]
      Local Mask CMPLEV    [OCP]
      Gosub SETMASK        From GOBJET
    When "U"        :
      Local Mask LEARES0   [OAC0]
      Local Mask LEARES    [LEAR]
      Local Mask CMPRES    [OCP]
      Gosub SETMASK        From GOBJET
    When "S"        :
      Local Mask LEAEND0   [OAC0]
      Local Mask LEAEND    [LEAE]
      Local Mask CMPEND    [OCP]
      Gosub SETMASK        From GOBJET
    When "V"        :
      Local Mask LEAACT0   [OAC0]
      Local Mask LEAACT    [LEAC]
      Local Mask CMPACT    [OCP]
      Gosub SETMASK        From GOBJET
    When Default
  Endcase

  Gosub ACTION From TRTOBJACT

Return
#-----------------------------------------------------------------------------------
$FERME
  #-----------------------------------------------------------------------------------#
  # Si on vient par tunnel il faut restaurer les variables globales   #
  #-----------------------------------------------------------------------------------#
  If TUNNEL : Gosub RESTAURE_GLOBAL_SV From GLOBIMM : Endif
  If TUNNEL : Gosub RESTAURE_GLOB_TUNNEL From TRUPROACT : Endif

Return
#=====================================================================
$FIN_ACTION
  #
  # Gestion actions objets métiers
  Gosub ACTION From TRTOBJACT

Return
#=====================================================================
$APRES_MODIF

  If GREP = "C"
    If func GLOBIENS.IS_SYMBOLE_LOCKED("LEA", [M:LEA0]CPY, "¤¤¤") = 0
      # Test si la société est verrouillée sur cette table pour en empêcher la création
      # Obligé de mettre n'importe quoi dans l'identifiant parce que sinon ça demande si c'est
      # la société qui est lockable, et si quelqu'un est dessus ça refuse.
      OK        = 0
      GMESSAGE  = G_MSGQUILOCK
      Return
    Endif
  Endif

Return
#=====================================================================
#
$LIENS

  Local Integer I_PLN
  Local Char    WK_EVTINT

  Local Char    PCLASSE
  Local Char    WNOMVAR
  Local Char    WCHAMP
  Local Char    WDEVORI
  Local Char    WDEVDES
  Local Char    WDEVORI
  Local Decimal WMTORI
  Local Decimal RMTDES
  Local Decimal WMTVAR
  Local Decimal MTDES
  Local Integer STAT
  Local Date    PCPTDAT(1..5)
  Local Date    PIASDAT(1..5)
  Local Integer PRET1, PRET2

  G_LEASTA  = [F:LEA]LEASTA # Issue X3-70469
  GLEACRT   = G_NON         # Issue X3-71287

  #> Chargement du masque de travail contenant le paramétrage comptable de la société
  Local Integer ERR
  Call LOAD_FASPARCPY([F:LEA]CPY, "", G_NON, ERR) From GLOFCYCPY

  GDEVFMTL="13.2"
  GDEVFMTL = GDEVFMT1(max(find([F:LEA]LEACUR, GDEVISE(1..GNBDEV)), 1))  : # X3-77642

  GREP = ""
  # CBO - 22.06.2012 (FQ 82709)
  #> Chargement du tableau des axes et sections analytiques
  Local Integer LNBRLEA
  Call LOAD_TAB_CCE("[F:LEA]", "[M:FPC]", "[M:LEA4]", LNBRLEA) From GLOBIENSANA
  [M:LEA4]NBRCCE = LNBRLEA

  G_NBAXE = LNBRLEA  #Fq-79815

  If ( [F:LEA]LEASTA <> GVML_STAVAL) & ([F:LEA]LEASTA <> GVML_STENCOU)
    Diszo [M:LEA0]  : # Affzo [M:LEA0]  # X3-84302
    Diszo [M:LEA1]  :  Affzo [M:LEA1]
    Diszo [M:LEA2]  :  Affzo [M:LEA2]
    # Issue X3-84302
    Actzo [M:LEA0]EVTLIST :  Affzo [M:LEA0]
  Else
    Actzo [M:LEA0]  :  Affzo [M:LEA0]
    Actzo [M:LEA1]  :  Affzo [M:LEA1]
    Actzo [M:LEA2]  :  Affzo [M:LEA2]
  Endif
  # CBO 2012.06.22 FQ82709
  Affzo [M:LEA4]

  #*Récupération de la devise société et de la devise IAS
  #Fq-61084 ==> devise IAS : uniquement si le plan IAS est géré
  If (GCNXCURCPF <> "") Then : # X3-77642
    [M:LEA0]CUR    = GCNXCURCPF  : Affzo [M:LEA0]CUR       # Devise société
    [M:LEA1]CUR    = GCNXCURCPF  : Affzo [M:LEA1]CUR       # Devise soci��té
    [M:LEA3]CUR    = GCNXCURCPF  : Affzo [M:LEA3]CUR       # Devise société X3-84302
  Endif
  GDEVFMTC="13.2"
  GDEVFMTC = GDEVFMT1(max(find([M:LEA0]CUR, GDEVISE(1..GNBDEV)), 1))  : # X3-77642
  If ( GCNXPROIAS = G_OUI )
    [M:LEA0]IASCUR = GCNXCURIAS
    [M:LEA1]IASCUR = GCNXCURIAS
    [M:LEA3]IASCUR2  = GCNXCURIAS : # X3-84302
    GDEVFMTI="13.2"
    GDEVFMTI = GDEVFMT1(max(find([M:LEA0]IASCUR, GDEVISE(1..GNBDEV)), 1))  : # X3-77642
    Affzo [M:LEA0]IASCUR
    Affzo [M:LEA1]IASCUR   # Devise IAS
    # X3-84302
    #Diszo [M:LEA1]ZIASCUR
    Affzo [M:LEA3]IASCUR
    Affzo [M:LEA3]IASCUR2
  Else
    [M:LEA0]IASCUR = ""
    [M:LEA1]IASCUR = ""
    Diszo [M:LEA0]IASCUR
    Diszo [M:LEA1]IASCUR   # Devise IAS
  Endif
  If LEASTA <> GVML_STAVAL
    Diszo [M:LEA0]LEATYP       #*Fq-48189
    Diszo [M:LEA1]STRLEADAT
    Diszo [M:LEA1]ENDLEADAT
    Diszo [M:LEA1]LEAAMT
    Diszo [M:LEA1]RPUDAT
    Diszo [M:LEA1]RPUVAL
    Diszo [M:LEA1]LEACUR
    Diszo [M:LEA1]CUR
    Diszo [M:LEA1]IASCUR
    Diszo [M:LEA1]ACCCOD
  Endif

  Diszo [M:LEA1]LEAAMTDEV
  Diszo [M:LEA1]LEAAMTIAS
  Diszo [M:LEA1]RPUVALDEV
  Diszo [M:LEA1]RPUVALIAS

  If [M:LEA0]LEATYP <> GVML_CREBAIL
    Diszo [M:LEA1]RPUVAL
    Diszo [M:LEA1]RPUDAT
  Endif

  Affzo [M:LEA1]ENDLEADAT

  # Lecture de l'échéancier
  Effzo [M:LEA2]
  Gosub MANAGE_IAS_FIELDS
  Gosub MANAGE_LOCATION_FIELDS # Issue X3-68589
  nolign = 1
  For [LBB]LBB0 Where LEAREF = [M:LEA0]LEAREF
    [M:LEA2]=[F:LBB]
    nolign += 1
  Next
  [M:LEA2]NBPER2 = nolign - 1
  Affzo [M:LEA2]

  Local Integer I_L
  For I_L = 1 To [M:LEA2]NBPER2
    If ([M:LEA1]CUTDAT > [0/0/0] and [M:LEA2]ENDPERDAT(I_L-1) < [M:LEA1]CUTDAT) or
&      ([M:LEA2]FARFLG(I_L-1)  = G_OUI) or
&      ([M:LEA2]FARFLGI(I_L-1) = G_OUI)
      # X3-84302 Test on PAYDAT & PAYREF   (Later)
#&      ([M:LEA2]PAYDAT(I_L-1) <> [0/0/0]) or
#&      ([M:LEA2]PAYREF(I_L-1) <> "")
      Diszo [M:LEA2]STRPERDAT(I_L-1)
      Diszo [M:LEA2]ENDPERDAT(I_L-1)
      Diszo [M:LEA2]RNTAMT(I_L-1)
      If ( [M:LEA0]LEATYP = GVML_LOCATION)
        # Issue X3-70469
        Diszo [M:LEA2]VARPAY(I_L-1)
        Diszo [M:LEA2]RSDVAL(I_L-1)
        Diszo [M:LEA2]TERPEN(I_L-1)
        Diszo [M:LEA2]PUROPT(I_L-1)
      Else
        Diszo [M:LEA2]FINDPR(I_L-1)
        Diszo [M:LEA2]FINEXS(I_L-1)
        If ( [M:LEA0]LEATYP = GVML_CREBAIL ) Then : # X3-84302
          Diszo [M:LEA2]RMNTPA(I_L-1)
          Diszo [M:LEA2]RPACAP(I_L-1)
        Endif
      Endif
    Endif
    [M:LEA2]CUMRNTAMT +=[M:LEA2]RNTAMT(I_L-1)    #*FQ-64312
  Next
  [M:LEA2]LEACUR  = [M:LEA1]LEACUR  #Fq-89986
  [M:LEA2]LEACUR2 = [M:LEA1]LEACUR  # Issue X3-70469
  [M:LEA2]CUR2    = [M:LEA1]CUR     # Issue X3-77642
  [M:LEA2]IASCUR2 = [M:LEA1]IASCUR  # Issue X3-77642

  Call DISPLAY_CASE_LOCATION([M:LEA0]LEATYP) # Issue X3-68588

  Affzo [M:LEA2]

  #* Ecran récapitulatif des actualisations
  For[E42] Where (CPY=[M:LEA0]CPY & REF=[M:LEA0]LEAREF & DPRPLN = G301CPT)
    [M:LEA5]VCUTDAT(0)       = [F:E42]EVTDAT
    [M:LEA5]VLEAAMT(0)       = [F:E42]LEAAMT
    [M:LEA5]VRATCUR(0)       = [F:LEA]RATCUR
    If ( GCNXPROIAS = G_OUI )
      [M:LEA5]VIASRATCUR(0)    = [F:LEA]IASRATCUR
    Endif #Fq-61084
    If [F:E42]LEAAMT <> 0
      # ------------- Conversion en devise société
      # [F:E42]LEAAMT -> [M:LEA5]VLEAAMTDEV(0)
      Call RECALCUL_MONTANT_DEVSOC([M:LEA1]LEACUR, [M:LEA1]CUR, GCOUDEV, [M:LEA1]CURTYP,
&          [M:LEA1]STRLEADAT, [F:E42]LEAAMT, 0, [M:LEA5]VLEAAMTDEV(0))
      Affzo [M:LEA5]VLEAAMTDEV(0)
      If ( GCNXPROIAS = G_OUI )
        # ------------- Conversion en devise IAS
        # [F:E42]LEAAMT -> [M:LEA5]VLEAAMTIAS(0)
        Call RECALCUL_MONTANT_DEVIAS([M:LEA1]LEACUR, [M:LEA1]IASCUR, GCOUDEV, [M:LEA1]IASCURTYP,
&            [M:LEA1]STRLEADAT, [F:E42]LEAAMT, 0, [M:LEA5]VLEAAMTIAS(0))
        Affzo [M:LEA5]VLEAAMTIAS(0)
      Endif
      [M:LEA5]NBACTU = 1
    Endif
    Break
  Next
  [M:LEA5]NBACTU = 1
  Affzo [M:LEA5]NBACTU

  nolign=2

  For[E41] Where (CPY=[M:LEA0]CPY & REF=[M:LEA0]LEAREF & DPRPLN = G301CPT)
    [M:LEA5]VCUTDAT(nolign-1)       = [F:E41]EVTDAT
    [M:LEA5]VLEAAMT(nolign-1)       = [F:E41]LEAAMTN
    [M:LEA5]VRATCUR(nolign-1)       = [F:LEA]RATCUR
    If GCNXPROIAS = G_OUI
      [M:LEA5]VIASRATCUR(nolign-1) = [F:LEA]IASRATCUR
    Endif #Fq-61084

    # VLEAAMT -> VLEAAMTDEV
    Call RECALCUL_MONTANT_DEVSOC([F:LEA]LEACUR, [F:LEA]CUR, GCOUDEV, [F:LEA]CURTYP,
&        [F:LEA]STRLEADAT, [M:LEA5]VLEAAMT(nolign-1), [F:LEA]RATCUR, [M:LEA5]VLEAAMTDEV(nolign-1))
    # IAS/IFRS
    If GCNXPROIAS = G_OUI
      # VLEAAMT -> VLEAAMTIAS
      Call RECALCUL_MONTANT_DEVIAS([F:LEA]LEACUR, [F:LEA]IASCUR, GCOUDEV, [F:LEA]IASCURTYP,
&          [F:LEA]STRLEADAT, [M:LEA5]VLEAAMT(nolign-1), [F:LEA]IASRATCUR, [M:LEA5]VLEAAMTIAS(nolign-1))
    Endif
  nolign+=1
  Next

  [M:LEA5]NBACTU = nolign-1
  Affzo [M:LEA5]NBACTU

  # Récupération de la devise société
  [M:LEA5]CUR    = [M:LEA0]CUR
  Affzo [M:LEA5]CUR       # Devise société
  If GCNXPROIAS = G_OUI  #Fq-61084
    [M:LEA5]IASCUR = [M:LEA0]IASCUR   : Affzo [M:LEA5]IASCUR
    # Récupération de la date de fin de l'exercice courant
    # et de la date de fin de la période courante du contexte IAS
    # pour l'affichage de la valeur d'entrée IAS des biens rattachés au contrat
    [M:LEA0]FIYENDIAS = [0/0/0]
    [M:LEA0]PERENDIAS = [0/0/0]
  Endif  #Fq-61084
  Call GET_CNX_DAT([M:LEA0]CPY, G300CPFI, PCPTDAT, PRET2) From GLOBIENS
  [M:LEA0]FIYENDCPT = PCPTDAT(2)
  If PCPTDAT(4) <> [0/0/0]
    [M:LEA0]PERENDCPT = PCPTDAT(4)
  Else
    [M:LEA0]PERENDCPT = PCPTDAT(2)
  Endif

  If GCNXPROIAS = G_OUI
    # Récupération dates début période et exercice dans laquelle se trouve date de début amortissement
    # pour alimenter CPTDATINT dans les événements
    Call GET_CNX_DAT([M:LEA0]CPY, G300IAS, PIASDAT, PRET1) From GLOBIENS
    [M:LEA0]FIYENDIAS = PIASDAT(2)
    If PIASDAT(4)<> [0/0/0]
      [M:LEA0]PERENDIAS = PIASDAT(4)
    Else
      [M:LEA0]PERENDIAS = PIASDAT(2)
    Endif
  Endif

  # Issue X3-70469
  Call EVALUE_SUMPAY_ARRAY([M:LEA0]LEATYP)
  Call EVALUE_CVAYEA ([M:LEA0]LEATYP,0)
  If ([M:LEA0]LEASTA <> GVML_STAVAL and [M:LEA0]LEATYP = GVML_LOCATION) Then
    [M:LEA2]INIPREVAL    = [F:LEA]INIPREVAL
    # Issue 77642
    [M:LEA2]INIPREVALC   = [F:LEA]INIPREVALC
    If ( GCNXPROIAS = G_OUI )
    [M:LEA2]INIPREVALI   = [F:LEA]INIPREVALI
    Endif
    Gosub RIGHT_OF_USE : # X3-77643
    # End issue 77642
  Endif

  # Biens rattachés au contrat
  Gosub BIENS_DU_CONTRAT
  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LEA0]FCY", 0) = G_OUI
    Diszo [M:LEA0]FCY
  Endif


  If TUNNEL
    Gosub SAUVE_GLOB_TUNNEL From TRUPROACT
  Endif

Return



# Issue X3-68588
#**
#* Change title of 3 fields when location type
#*
#* @param PLEATYP   location type
#*!
Subprog DISPLAY_CASE_LOCATION(PLEATYP)
Value Integer PLEATYP

  If PLEATYP = GVML_LOCATION
    Chgtzn [M:LEA1]LEAAMT    With mess(122, GML_MSGGRT, 1)
    Chgtzn [M:LEA1]LEAAMTDEV With mess(122, GML_MSGGRT, 1)
    Chgtzn [M:LEA1]LEAAMTIAS With mess(122, GML_MSGGRT, 1)
  Else
    Chgtzn [M:LEA1]LEAAMT With func GET_FIELD_DESI("LEA1", "LEAAMT", GLANGUE)
    Chgtzn [M:LEA1]LEAAMTDEV With func GET_FIELD_DESI("LEA1", "LEAAMTDEV", GLANGUE)
    Chgtzn [M:LEA1]LEAAMTIAS With func GET_FIELD_DESI("LEA1", "LEAAMTIAS", GLANGUE)
  Endif

End
# End issue X3-68588
#=====================================================================
#Fq-61084
$STYLE

  # X3-68589 MWA
  # RMNTPA doit être dans certains cas caché. Il etait porteur du type de donnée MD1 qui en avant saisie
  # execute un chgfmt qui fait réapparaitre le champ à tort. Pour contourner ce problème, on utilise le type
  # de donnée DCB et on applique l'équivalent de INIDEV de MD1.
  If (B_FIRST)
    B_FIRST = 0
    If clalev([F:ACT]) =0    : Local File ACTION       [ACT]    : Endif
    Local Char WINSTRU(100)
    WINSTRU = 'GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find(%1,GDEVISE(1..GNBDEV)),1))'
    Read [ACT]ACTION ="INIDEV"
    If ([F:ACT]INSTRU <> WINSTRU)
      Local Integer WOK
      Call WARNING("(DCB)" - mess(113,127, 1) -"      " - "[M:LEA2]RMNTPA", WOK) From GESECRAN
    Endif
  Endif

  Gosub MANAGE_IAS_FIELDS
  Gosub MANAGE_LOCATION_FIELDS # Issue X3-68589

Return

#=====================================================================
#
$BIENS_DU_CONTRAT

  Local Decimal WMTDES
  #  Lecture des Biens rattachés au contrat

  nolign=1
  Raz [M:LEA3]CUMBSELEA
  Raz [M:LEA3]CUMBSESOC
  Raz [M:LEA3]CUMBSEIAS
  Raz [M:LEA1]CUMIASBSE  #FQ-64312
  Raz [M:LEA3]DIFRNTBSE  #FQ-64312
  # Récupération de la devise société et de la devise IAS
  [M:LEA3]CUR    =  [M:LEA0]CUR    :  Affzo  [M:LEA3]CUR
  If ( GCNXPROIAS = G_OUI )
    [M:LEA3]IASCUR  =  [M:LEA0]IASCUR  :  Affzo  [M:LEA3]IASCUR
    [M:LEA3]IASCUR2 =  [M:LEA3]IASCUR  :  Affzo  [M:LEA3]IASCUR2  #FQ-64312
  Endif  #Fq-61084

  For [FAS]FAS0 Where (LEAREF =  [M:LEA0]LEAREF )

     [M:LEA3]AASREF(nolign-1)     = [F:FAS]AASREF
     [M:LEA3]AASDES1(nolign-1)    = [F:FAS]AASDES1
     [M:LEA3]PURDAT (nolign-1)    = [F:FAS]PURDAT
     [M:LEA3]RNTSTRDAT (nolign-1) = [F:FAS]RNTSTRDAT
     [M:LEA3]RNTENDDAT (nolign-1) = [F:FAS]RNTENDDAT
     # Récupération de la valeur d'entrée IAS du bien considéré
     If GCNXPROIAS = G_OUI
       [M:LEA3]BSEDEVIAS(nolign-1)  = [F:FAS]IASETRNOT + [F:FAS]IVCVATAMTI - [F:FAS]DEDVATAMTI
       [M:LEA3]CUMBSEIAS += [M:LEA3]BSEDEVIAS(nolign-1)
       [M:LEA1]CUMIASBSE += [M:LEA3]BSEDEVIAS(nolign-1)   #FQ-64312
       # ------------- Conversion en devise de financement
       # BSEDEVIAS -> BSEDEVLEA
       Call RECALCUL_MONTANT_DEVIAS([M:LEA1]IASCUR, [M:LEA1]LEACUR, GCOUDEV, [M:LEA1]IASCURTYP,
&           [F:FAS]PURDAT, [M:LEA3]BSEDEVIAS(nolign-1), 0, [M:LEA3]BSEDEVLEA(nolign-1))
       Affzo [M:LEA3]BSEDEVLEA(nolign-1)
       [M:LEA3]CUMBSELEA+= [M:LEA3]BSEDEVLEA(nolign-1)
     Endif
     # ------------- Conversion en devise société
     # BSEDEVLEA -> BSEDEVSOC
     Call RECALCUL_MONTANT_DEVSOC([M:LEA1]LEACUR, [M:LEA1]CUR, GCOUDEV, [M:LEA1]CURTYP,
&         [F:FAS]PURDAT, [M:LEA3]BSEDEVLEA(nolign-1), 0, [M:LEA3]BSEDEVSOC(nolign-1))
     Affzo [M:LEA3]BSEDEVSOC(nolign-1)
     [M:LEA3]CUMBSESOC+= [M:LEA3]BSEDEVSOC(nolign-1)

     nolign += 1
  Next

  If GCNXPROIAS = G_OUI
    [M:LEA3]DIFRNTBSE = [M:LEA2]CUMRNTAMT - [M:LEA3]CUMBSEIAS
  Endif

  [M:LEA3]NBLIG3 = nolign-1
  Affzo [M:LEA3]

Return
####################################################################################################
$CHARGE_CUMULS_LEA5

  Local Decimal CUM_LEAAMT         # Cumul capital en devise de financement
  Local Decimal CUM_LEAAMTDEV      # Cumul capital en devise société
  Local Decimal CUM_LEAAMTIAS      # Cumul capital en devise IFRS

  #------------------------------------------------------------------------------------------#
  # Les totaux sont calculés à partir du tableau des actualisations
  #------------------------------------------------------------------------------------------#
  For nolign=1 To [M]NBACTU
    CUM_LEAAMT        += [M:LEA5]VLEAAMT(nolign-1)
    CUM_LEAAMTDEV     += [M:LEA5]VLEAAMTDEV(nolign-1)
    If ( GCNXPROIAS = G_OUI )  : CUM_LEAAMTIAS     += [M:LEA5]VLEAAMTIAS(nolign-1) : Endif #Fq-61084
  Next nolign

  [M:LEA5]CLEAAMT    = CUM_LEAAMT    : Affzo [M:LEA5]CLEAAMT
  [M:LEA5]CLEAAMTDEV = CUM_LEAAMTDEV : Affzo [M:LEA5]CLEAAMTDEV
  If GCNXPROIAS = G_OUI : [M:LEA5]CLEAAMTIAS = CUM_LEAAMTIAS : Affzo [M:LEA5]CLEAAMTIAS : Endif

Return

#=====================================================================
#
$VERIF_CRE


  # Issue X3-81205
  #* la date de début de la 1ère période (seule période saisie) ne peut pas être antérieure à la date de début du contrat
  If [M:LEA2]STRPERDAT(0) <> [0/0/0] and [M:LEA2]STRPERDAT(0) < [M:LEA1]STRLEADAT : # X3-84266
    GERR= 1
    GMESSAGE= mess(44, GML_MSGGRT, 1)
    OK= 0: Return
  Endif

  # En import
  If ( GIMPORT ) : Return : Endif  #FQ105960

  # Issue X3-72994
  Local Integer LOK
  If ([M:LEA2]NBPER2 < 1 and GLEACRT = G_OUI) Then
    # Le contrat ne contient pas d'échéancier
    Call OUINON(mess(123,GML_MSGGRT, 1)+mess(179,133, 1), LOK) From GESECRAN
    If ( LOK = 1) Then
      GERR=1: OK= 0: Return
    Endif
  Endif

  # Issue X3-70469
  If ([M:LEA2]NBPER2 > 1) Then
    Local Integer I_L : I_L = 1
    Local Integer LOK
    For nolign = 2 To [M:LEA2]NBPER2
      # Chevauchement de périodes
      If ([M:LEA2]ENDPERDAT(nolign-2) >= [M:LEA2]STRPERDAT(nolign-1))
        GERR=1: GMESSAGE= mess(45, 101, 1) : OK= 0
        Break
      Endif
      If ([M:LEA2]ENDPERDAT(nolign-2)+1 <> [M:LEA2]STRPERDAT(nolign-1))
        # Trous dans les périodes
        Call OUINON(func ASYRFNC.MES2(mess(353,7770, 1),
&                   num$([M:LEA2]STRPERDAT(nolign-1)), num$([M:LEA2]ENDPERDAT(nolign-2)))+ "\"+mess(179,133, 1), LOK) From GESECRAN
        If ( LOK = 1) Then
          GERR=1: OK= 0: Break
        Endif
        Break
      Endif
    Next nolign
  Endif
  If (GERR) Then : Return : Endif

  Local Integer I, J

  # Contrôle cohérence société/site
  OK = func GLOFCYCPY.IS_CPYFCY_OK([M:LEA0]CPY,[M:LEA0]FCY)
  # Site financier et société incompatibles
  If !OK : Return : Endif


  # la date de fin de la 1ère échéance doit être postérieure à la date de début de cette échéance
  If [M:LEA2]ENDPERDAT(0) < [M:LEA2]STRPERDAT(0)
    GERR=1: GMESSAGE = mess(47,GML_MSGGRT, 1): OK= 0: Return
    Affzo[M:LEA2]NBPER2
  Endif

  # Issue Start X3-84302
#  If ([M:LEA0]LEATYP = GVML_CREBAIL)  #FQ104388
#    For I = 1 To [M:LEA2]NBPER2-1
#      If [M:LEA2]STRPERDAT(I-1) <> [0/0/0] & [M:LEA2]RNTAMT(I-1) = 0
#        # 'Le montant redevance est obligatoire pour chaque période'
#        GERR=1: GMESSAGE= mess(60, GML_MSGGRT, 1) : OK= 0: Return
#      Endif
#      #* Suppression échéance avec Reste à rembourser négatif
#      If    ([M:LEA2]RMNTPA(I-1) <= 0)
#        J = [M:LEA2]NBPER2 - (I-1)
#        Dela I-1, J  [M:LEA2]NBPER2
#        [M:LEA2]NBPER2 -=J
#        Break
#      Endif
#    Next I
#  Endif #FQ104388
#
#  Affzo [M:LEA2]NBPER2
#  Raz  [M:LEA2]CUMRNTAMT #*FQ-64312
#
#  For nolign = 1 To [M:LEA2]NBPER2
#    #FQ104388 If ([M:LEA2]RPACAP(nolign-1)> [M:LEA1]LEAAMT
#    If ( [M:LEA0]LEATYP = GVML_CREBAIL)
#      If ([M:LEA2]RPACAP(nolign-1)> [M:LEA1]LEAAMT)
#        # Attention, le montant remboursé est supérieur au capital emprunté
#        Call MESSAGE(mess(64,GML_MSGGRT,1)) From GESECRAN
##        If nolign > 1
##           zonsui = "[M:LEA2]RPACAP(nolign-2)"
##        Endif
##        Break
#      Endif
#    Endif
#    [M:LEA2]CUMRNTAMT +=[M:LEA2]RNTAMT(nolign-1) #*FQ-64312
#  Next nolign
#
#  Affzo [M:LEA2]CUMRNTAMT #*FQ-64312

  Raz [M:LEA2]CUMRNTAMT
  For nolign = 1 To [M:LEA2]NBPER2
    [M:LEA2]CUMRNTAMT +=[M:LEA2]RNTAMT(nolign-1)
  Next nolign
  Affzo [M:LEA2]CUMRNTAMT

  If ([M:LEA0]LEATYP = GVML_CREBAIL)  #FQ104388
    For I = 1 To [M:LEA2]NBPER2-1
      If [M:LEA2]STRPERDAT(I-1) <> [0/0/0] & [M:LEA2]RNTAMT(I-1) = 0
        # 'Le montant redevance est obligatoire pour chaque période'
        GERR=1: GMESSAGE= mess(60, GML_MSGGRT, 1) : OK= 0: Return
      Endif
      If ([M:LEA2]RPACAP(I-1)> [M:LEA1]LEAAMT) or [M:LEA2]RMNTPA(I-1) <= 0
        # Attention, le montant remboursé est supérieur au capital emprunté
        Local Integer L_REP
        Call OUINON(mess(64,GML_MSGGRT,1), L_REP) From GESECRAN
        If (L_REP = 1) Then
          GERR     = 1 : OK= 0 : mkstat= 2 : Return
        Else
          # Suppression échéance avec Reste à rembourser négatif
          J = [M:LEA2]NBPER2 - (I-1)
          Dela I-1, J  [M:LEA2]NBPER2
          [M:LEA2]NBPER2 -=J
          Break : Return
        Endif
      Endif
    Next I
  Endif

  Affzo [M:LEA2]NBPER2
  Affzo [M:LEA2]CUMRNTAMT
# End issue X3-84302



  #FQ82709
  # Contrôle de validité des axes analytiques :
  Gosub CTRL_TAB_CCE From GLOBIENSANA
  #Fq-79815 ajout de l'alimentation des axes par défaut, si non-renseignés en Import
  If GIMPORT
    If LERR
      Call  AS_NBRCCE() From SUBLEA
      GMESSAGE="" : OK=1
    Endif
  Endif  #Fq-79815

  # Issue X3-72994
  If ([M:LEA0]LEASTA <> GVML_STAVAL)
    Diszo [M:LEA0]LEATYP : Affzo [M:LEA0]LEATYP
    Diszo [M:LEA0]LEASTA : Affzo [M:LEA0]LEASTA
  Endif

Return
#
#=====================================================================
#
$INICRE

#==================================================
# R0030-Numérotation automatique de la réf. contrat
#==================================================

  If GLEAAUTNUM = 2 or (GLEAAUTNUM = 3 and [M:LEA0]LEAREF = "")
    # Appel du compteur de document FQ85464
    Call GET_NUMERO("LEA",GVML_NUMLEA-1,1,[M:LEA0]CPY, [M:LEA0]FCY,[M]STRLEADAT,[F:LEA]LEAREF,STAT) From GLOBIENS
    If STAT
      GOK      = 0
      Return
    Endif
    [M:LEA0]LEAREF=[F:LEA]LEAREF
    Affzo[M:LEA0]LEAREF
  Endif

  [F:LEA]LEACUR = [M:LEA1]LEACUR
  [F:LEA]CUR    = [M:LEA1]CUR
  If GCNXPROIAS = G_OUI : [F:LEA]IASCUR = [M:LEA1]IASCUR : Endif

  # Issue X3-81205
  If GIMPORT
    Call EVALUE_SUMPAY_ARRAY([M:LEA0]LEATYP)
    Call EVALUE_CVAYEA ([M:LEA0]LEATYP,0)
  Endif

  # Issue X3-70469 X3-81205
  If ([M:LEA0]LEATYP <> GVML_LOCATION or ( GIMPORT and [M:LEA0]LEASTA = GVML_STENCOU)) Then
    [F:LEA]INIPREVAL  = 0
    [F:LEA]INIPREVALC = 0 : # X3-77642
    [F:LEA]INIPREVALI = 0 : # X3-77642
  Else
    [F:LEA]INIPREVAL  = [M:LEA2]INIPREVAL
    [F:LEA]INIPREVALC = [M:LEA2]INIPREVALC : # X3-77642
    If ( GCNXPROIAS = G_OUI )
      [F:LEA]INIPREVALI = [M:LEA2]INIPREVALI : # X3-77642
    Endif
  Endif

Return
#
#=====================================================================
#
$CREATION
  #
  #  * Insert Echéancier
  Gosub INSERT

Return
#-------------------------------------------------------------------------------
$APRES_CRE

  # En import
  If ( GIMPORT ) : Return : Endif  #FQ105960

  If func GLOBIENS.IS_CHAMP_ENABLE ("[M:LEA0]FCY", 0) = G_OUI Then : Diszo [M:LEA0]FCY : Endif
  Local Integer ERROR
  Call COMPTA_DIRECTE([M:LEA0]CPY, [M:LEA0]FCY, [M:LEA0]LEAREF, 0, "", ERROR) From TRTCPTINT


  G_LEASTA = [M:LEA0]LEASTA  # Issue X3-70469
  GLEACRT  = G_NON           # Issue X3-71287

Return

#=====================================================================
$AVANT_MOD

  #Fq- 58569 Le contrat n'est plus en cours, il ne peut plus être modifié.
  If ([M:LEA0]LEASTA <> GVML_STENCOU) & ([M:LEA0]LEASTA <> GVML_STAVAL)
    GERR=1 : GMESSAGE = mess(111,GML_MSGGRT,1)
    GOK=0
  Endif

Return
#
#=====================================================================
#
$MODIF
  #   * Annule et remplace  Echéancier
  Delete[F:LBB] Where LEAREF= [M:LEA0]LEAREF
  If fstat= 1
    [V]GOK = 0
    Call RSTA("LEA",CLECUR1+"/"+num$(CLECUR2)) From GLOCK
    Return
  Endif

  #  * Insert Echéancier
  Gosub INSERT

  If GOK=0 : Return : Endif

  If [M:LEA0]LEATYP <> GVML_CREBAIL and
&  ([M:LEA3]RNTSTRDAT(0) <> [M:LEA1]STRLEADAT or [M:LEA3]RNTENDDAT(0) <> [M:LEA1]ENDLEADAT)
   Gosub MAJ_BIENS
  Endif

Return
#=====================================================================
$VERIF_MOD

  # Issue X3-72994
  Local Integer LOK
  If ([M:LEA2]NBPER2 < 1 and GLEACRT = G_OUI) Then
    # Le contrat ne contient pas d'échéancier
    Call OUINON(mess(123,GML_MSGGRT, 1)+mess(180,133, 1), LOK) From GESECRAN
    If ( LOK = 1) Then
      GERR=1: OK= 0: Return
    Endif
  Endif

  # Issue X3-70469
  If ([M:LEA2]NBPER2 > 1) Then
    Local Integer I_L : I_L = 1
    Local Integer LOK
    For nolign = 2 To [M:LEA2]NBPER2
      # Chevauchement de périodes
      If ([M:LEA2]ENDPERDAT(nolign-2) >= [M:LEA2]STRPERDAT(nolign-1))
        GERR=1: GMESSAGE= mess(45, 101, 1) : OK= 0
        Break
      Endif
      If ([M:LEA2]ENDPERDAT(nolign-2)+1 <> [M:LEA2]STRPERDAT(nolign-1))
        # Trous dans les périodes
        Call AVERTIR(func ASYRFNC.MES2(mess(353,7770, 1),
&                   num$([M:LEA2]STRPERDAT(nolign-1)), num$([M:LEA2]ENDPERDAT(nolign-2)))+ "\"+mess(180,133, 1), LOK) From GESECRAN
        If ( LOK = 1) Then
          GERR=1: OK= 0: Return
        Endif
        Break
      Endif
    Next nolign
  Endif

  Local Integer I, J
  # R2020 - si l'on revient de l'action actualiser
  If clalev([M:LEAC])

    Affzo [M:LEA1]ENDLEADAT
    Affzo [M:LEA1]RPUVAL
    Affzo [M:LEA1]RPUDAT
    Affzo [M:LEA1]LEAAMT
    Affzo [M:LEA1]ACCCOD

    If [M:LEA1]CUTDAT > [0/0/0]
      For nolign = 1 To [M:LEA2]NBPER2
        If [M:LEA2]ENDPERDAT(nolign-1) < [M:LEA1]CUTDAT
          # Issue X3-70469
          Diszo [M:LEA2]STRPERDAT(nolign-1) :  Diszo [M:LEA2]ENDPERDAT(nolign-1) :  Diszo [M:LEA2]RNTAMT(nolign-1)
          If ([M:LEA0]LEATYP = GVML_LOCATION)
            Diszo [M:LEA2]VARPAY(nolign-1)  : Diszo [M:LEA2]RSDVAL(nolign-1)     :  Diszo [M:LEA2]TERPEN(nolign-1)
            Diszo [M:LEA2]PUROPT(nolign-1)
          Else
            Diszo [M:LEA2]FINDPR(nolign-1)
            Diszo [M:LEA2]FINEXS(nolign-1)
            If ( [M:LEA0]LEATYP = GVML_CREBAIL ) Then : # X3-84302
              Diszo [M:LEA2]RMNTPA(nolign-1)
              Diszo [M:LEA2]RPACAP(nolign-1)
            Endif
          Endif
        Else
          #FQ104388 If nolign > 1
          If ( [M:LEA0]LEATYP = GVML_CREBAIL ) Then : # X3-84302
            If nolign > 1 and [M:LEA1]LEAAMT>0
              RMNTPA(nolign-1)=[M:LEA1]LEAAMT-RPACAP(nolign-2)
            Endif
          Endif
        Endif
      Next nolign
    Endif

    For nolign = 1 To [M:LEA2]NBPER2

       If ( [M:LEA2]FARFLG(nolign-1) = G_OUI ) and ( [M:LEA2]FARFLGI(nolign-1) = G_OUI )
         # X3-84302    (Later)
         # If ( [M:LEA2]FARFLG(nolign-1) = G_OUI  or  [M:LEA2]FARFLGI(nolign-1) = G_OUI or
         #&     [M:LEA2]PAYDAT(nolign-1) <> [0/0/0]  or  [M:LEA2]PAYREF(nolign-1) <> "" ) Then
        # Issue X3-70469
        Diszo [M:LEA2]STRPERDAT(nolign-1) :  Diszo [M:LEA2]ENDPERDAT(nolign-1) :  Diszo [M:LEA2]RNTAMT(nolign-1)
        If ([M:LEA0]LEATYP = GVML_LOCATION)
          Diszo [M:LEA2]VARPAY(nolign-1)
          Diszo [M:LEA2]RSDVAL(nolign-1)       :  Diszo [M:LEA2]TERPEN(nolign-1)
          Diszo [M:LEA2]PUROPT(nolign-1)
        Else
          Diszo [M:LEA2]FINDPR(nolign-1)
          Diszo [M:LEA2]FINEXS(nolign-1)
          If ( [M:LEA0]LEATYP = GVML_CREBAIL ) Then : # X3-84302
            Diszo [M:LEA2]RMNTPA(nolign-1)
            Diszo [M:LEA2]RPACAP(nolign-1)
          Endif
        Endif
      Endif
    Next nolign

  Endif

  # Issue start X3-84302
#  If ([M:LEA0]LEATYP = GVML_CREBAIL)  #FQ104388
#    For I = 1 To [M:LEA2]NBPER2-1
#      If [M:LEA2]STRPERDAT(I-1) <> [0/0/0] & [M:LEA2]RNTAMT(I-1) = 0
#        # 'Le montant redevance est obligatoire pour chaque période'
#        GERR=1: GMESSAGE= mess(60, GML_MSGGRT, 1) : OK= 0: Return
#      Endif
#      # Suppression échéance avec Reste à rembourser négatif
#      If [M:LEA2]RMNTPA(I-1) <= 0
#        J = [M:LEA2]NBPER2 - (I-1)
#        Dela I-1, J  [M:LEA2]NBPER2
#        [M:LEA2]NBPER2 -=J
#        Break : Return
#      Endif
#    Next I
#  Endif   #FQ104388
#
#  Affzo [M:LEA2]NBPER2
#  Raz [M:LEA2]CUMRNTAMT
#
#  For nolign = 1 To [M:LEA2]NBPER2
#    #FQ104388 If ([M:LEA2]RPACAP(nolign-1)> [M:LEA1]LEAAMT
#    If ( [M:LEA0]LEATYP = GVML_CREBAIL)
#      If ([M:LEA2]RPACAP(nolign-1)> [M:LEA1]LEAAMT)
#        # Attention, le montant remboursé est supérieur au capital emprunté
#        Call MESSAGE(mess(64,GML_MSGGRT,1)) From GESECRAN
#        If nolign > 1
#          zonsui = "[M:LEA2]RPACAP(nolign-2)"
#        Endif
#        Break : Return
#      Endif
#    Endif
#    [M:LEA2]CUMRNTAMT +=[M:LEA2]RNTAMT(nolign-1) #*FQ-64312
#  Next nolign
#
#  Affzo [M:LEA2]NBPER2
#  Affzo [M:LEA2]CUMRNTAMT #*FQ-64312

  Raz [M:LEA2]CUMRNTAMT
  For nolign = 1 To [M:LEA2]NBPER2
    [M:LEA2]CUMRNTAMT +=[M:LEA2]RNTAMT(nolign-1)
  Next nolign
  Affzo [M:LEA2]CUMRNTAMT

  If ([M:LEA0]LEATYP = GVML_CREBAIL)  #FQ104388
    For I = 1 To [M:LEA2]NBPER2-1
      If [M:LEA2]STRPERDAT(I-1) <> [0/0/0] & [M:LEA2]RNTAMT(I-1) = 0
        # 'Le montant redevance est obligatoire pour chaque période'
        GERR=1: GMESSAGE= mess(60, GML_MSGGRT, 1) : OK= 0: Return
      Endif
      If ([M:LEA2]RPACAP(I-1)> [M:LEA1]LEAAMT) or [M:LEA2]RMNTPA(I-1) <= 0
        # Attention, le montant remboursé est supérieur au capital emprunté
        Local Integer L_REP
        Call OUINON(mess(64,GML_MSGGRT,1), L_REP) From GESECRAN
        If (L_REP = 1) Then
          GERR     = 1 : OK= 0 : mkstat= 2 : Return
        Else
          # Suppression échéance avec Reste à rembourser négatif
          J = [M:LEA2]NBPER2 - (I-1)
          Dela I-1, J  [M:LEA2]NBPER2
          [M:LEA2]NBPER2 -=J
          Break : Return
        Endif
      Endif
    Next I
  Endif
# End issue X3-84302

  Affzo [M:LEA2]NBPER2
  Affzo [M:LEA2]CUMRNTAMT #*FQ-64312

  Gosub MANAGE_IAS_FIELDS

  # CBO 2012.06.22 FQ82709
  # Contrôle de validité des axes analytiques :
  Gosub CTRL_TAB_CCE From GLOBIENSANA

  # Issue X3-72994
  If ([M:LEA0]LEASTA <> GVML_STAVAL)
    Diszo [M:LEA0]LEATYP : Affzo [M:LEA0]LEATYP
    Diszo [M:LEA0]LEASTA : Affzo [M:LEA0]LEASTA
  Endif

Return
#=====================================================================
$AVANT_MODFIC

  # Gestion actions objets métiers
  Gosub ACTION From TRTOBJACT

Return
#=====================================================================
$INIMOD

  [F:LEA]LEACUR=[M:LEA1]LEACUR
  [F:LEA]IASCUR=[M:LEA1]IASCUR

  # Issue X3-70469
  If ([M:LEA0]LEATYP <> GVML_LOCATION) Then
    [F:LEA]INIPREVAL  = 0
    [F:LEA]INIPREVALC = 0 : # X3-77642
    [F:LEA]INIPREVALI = 0 : # X3-77642
  Else
    [F:LEA]INIPREVAL  = [M:LEA2]INIPREVAL
    [F:LEA]INIPREVALC = [M:LEA2]INIPREVALC : # X3-77642
    If ( GCNXPROIAS = G_OUI )
      [F:LEA]INIPREVALI = [M:LEA2]INIPREVALI : # X3-77642
    Endif
  Endif

  # Gestion actions objets métiers
  Gosub ACTION From TRTOBJACT

Return
#=====================================================================
$APRES_MOD

  G_LEASTA = [M:LEA0]LEASTA  # Issue X3-70469
  GLEACRT  = G_NON           # Issue X3-71287

  If dim(G_ACT)>0

#    If G_ACT = "LEAEND" or G_ACT = "LEARES"  X3-110500
    If G_ACT = "LEAEND"
      Gosub SORTIR_BIENS
      Kill G_ACT
    Else
      If G_ACT = "LEALEV" and
&       !( func GLOFCYCPY.GET_SOC_PAYS([M:LEA0]CPY) = "FR" or func GLOFCYCPY.GET_SOC_LEG([M:LEA0]CPY) = "FRA" )
        Gosub CHGT_IMPUTATION_CPTABLE
        Kill G_ACT
      Endif
    Endif

  Endif

  If GOK=0 : Gosub AB_MODIF : Endif

  Local Integer ERROR
  Call COMPTA_DIRECTE([M:LEA0]CPY, [M:LEA0]FCY, [M:LEA0]LEAREF, 0, "", ERROR) From TRTCPTINT

  # Gestion actions objets métiers
  Gosub ACTION From TRTOBJACT

Return
#=====================================================================
$AB_MODIF

  # Gestion actions objets métiers
  Gosub ACTION From TRTOBJACT

Return

#=====================================================================
$AV_ANNULE
  Local Integer LCDRET
  Local Integer NBEVESUP
  Call SUPP_EVE_OBJ(GVML_OMLOCFI,[F:LEA]CPY,[F:LEA]FCY,[F:LEA]LEAREF,0,[0/0/0],NBEVESUP,LCDRET) From GENEVE
  If LCDRET
    #Infbox "SUPP_EVE_OBJ =>"-num$(LCDRET)
    GOK=0
    Return
  Endif
  Call CRE_EVE_CNL_OBJ(GVML_OMLOCFI,[F:LEA]CPY,[F:LEA]FCY,[F:LEA]LEAREF,0,[0/0/0],LCDRET) From GENEVE
  If LCDRET
    #Infbox "CRE_EVE_CNL_OBJ =>"-num$(LCDRET)
    GOK=0
    Return
  Endif
Return

#=====================================================================
$APRES_CHOI

  # Gestion actions objets métiers
  Gosub ACTION From TRTOBJACT

Return
#
#=====================================================================
#
$INSERT

  Local Integer NOL
  Local Char    LCDINT (30)
  Local Date    WDATEFF
  Local Date    WDATFINPER
  Local Date    WDATCPTINT
  Local Integer LCDRET

  # * Création de l'échéancier
  For nolign = 1 To [M:LEA2]NBPER2
    Raz  [F:LBB]
    [F:LBB]         = [M:LEA2]
    [F:LBB]CPY      = [M:LEA0]CPY
    [F:LBB]FCY      = [M:LEA0]FCY
    [F:LBB]LEAREF   = [M:LEA0]LEAREF
    # Issue X3-70469
    If ( [M:LEA0]LEATYP = GVML_LOCATION) Then
      Raz [F:LBB]RMNTPA, FINDPR, FINEXS, RPACAP
    Else
      Raz [F:LBB]VARPAY, RSDVAL, TERPEN, PUROPT
    Endif
    Write [F:LBB]
    If fstat
      [V]GOK = 0
      Call FSTA("LBB") From GLOCK
      Break
    Endif
  Next nolign

  If OK=0 : Return : Endif

  GREASON = mess(92,GML_MSGGRT,1)
  WDATEFF= [M:LEA1]STRLEADAT

  Local Integer L_RET
  Local Date    L_CNXDAT(1..5)
  Call GET_CNX_DAT2([M:LEA0]CPY, G300CPFI, GVML_TECOURA, L_CNXDAT, L_RET) From GLOBIENS
  If L_CNXDAT(4)=[0/0/0]
    WDATFINPER = L_CNXDAT(2)
  Else
    WDATFINPER = L_CNXDAT(4)
  Endif

  If ((GREP="C" or GREP="D") and ([M:LEA0]LEASTA = GVML_STENCOU )) or
&     ( REP="M" and GLEACRT=G_OUI )
    # Génération d'un évènement de type "LEACRT" plan Comptable
    LCDINT= "LEACRT"+num$(G301CPT)
    WDATCPTINT=max([M:LEA1]STRLEADAT,  WDATFINPER)
    Call GENER_EVE (GVML_OMLOCFI,[M:LEA0]CPY,[M:LEA0]FCY,[M:LEA0]LEAREF,0,LCDINT,WDATEFF,WDATCPTINT,LCDRET)  From GENEVE
    If (LCDRET > 20 )
      GOK = 0
      Call FSTA("ELEACRT") From GLOCK
    Endif
    # Issue X3-83749 X3-84302
    #If GCNXPROIAS = G_OUI & ([M:LEA0]LEATYP = GVML_CREBAIL or [M:LEA0]LEATYP = GVML_LOCATION )
    If GCNXPROIAS = G_OUI
      # Génération d'un évènement de type "LEACRT" plan IAS
      LCDINT= "LEACRT"+num$(G301IAS)
      WDATCPTINT=max([M:LEA1]STRLEADAT, [M:LEA0]PERENDIAS)
      Call GENER_EVE (GVML_OMLOCFI,[M:LEA0]CPY,[M:LEA0]FCY,[M:LEA0]LEAREF,0,LCDINT,WDATEFF,WDATCPTINT,LCDRET)  From GENEVE
      If (LCDRET > 20 )
        GOK = 0
        Call FSTA("ELEACRT") From GLOCK
      Endif
    Endif
    GLEACRT=G_NON
  Endif
#
Return
#
#=====================================================================
#
$MAJ_BIENS
  Local Integer NOL
  #
  For nolign = 1 To [M:LEA3]NBLIG3
    Read [FAS]FAS0 = [M:LEA3]AASREF(nolign-1)
    If [F:FAS]NPL <> ""
      [F:FAS]RNTSTRDAT  = [M:LEA1]STRLEADAT
      [F:FAS]RNTENDDAT  = [M:LEA1]ENDLEADAT
    Else
      [F:FAS]RNTSTRDAT  = [0/0/0]
      [F:FAS]RNTENDDAT  = [0/0/0]
    Endif
    Rewrite [F:FAS]
    If fstat
      [V]GOK = 0
      Call RSTA("FAS",[M:LEA3]AASREF(nolign-1)) From GLOCK
      Break
    Endif
  Next nolign

  If OK=0 : Return : Endif
#
Return
#=====================================================================
$FIN
  Local Integer FROMSUBOBJ
  Gosub ACTION From TRTOBJACT
  Kill FROMSUBOBJ
  If dim(GDPERDAT0)>0  : Kill GDPERDAT0  : Endif
  If dim(GFPERDAT0)>0  : Kill GFPERDAT0  : Endif
  If dim(NUMACT)>0     : Kill NUMACT     : Endif
  If dim(G_CNX)>0      : Kill G_CNX      : Endif

  # Issue X3-70469
  If dim(G_LEASTA)>0   : Kill G_LEASTA   : Endif

  # Issue X3-77642
  If dim(GDEVFMTL)>0  : Kill GDEVFMTL  : Endif
  If dim(GDEVFMTC)>0  : Kill GDEVFMTC  : Endif
  If dim(GDEVFMTI)>0  : Kill GDEVFMTI  : Endif

Return

# issue X3-68588
#**
#* Give the designation of a field's mask
#*
#* @param PMASK
#* @param PFIELD
#* @param PLANGAGE
#*!
Funprog GET_FIELD_DESI(PMASK, PFIELD, PLANGAGE)
Value Char PMASK(), PFIELD(), PLANGAGE()

  Local Char WDES(30)
  If clalev([F:AMZ]) = 0    : Local File AMSKZON       [AMZ]    : Endif
  If clalev([F:ATX]) = 0    : Local File ATEXTE        [ATX]    : Endif

  Read [AMZ]CODE = PMASK; PFIELD
  If fstat = 0
    Read [ATX]NUMERO = PLANGAGE; [F:AMZ]INTIT
    If fstat = 0
      WDES = [F:ATX]TEXTE
    Endif
  Endif

End WDES
# End issue X3-68588
