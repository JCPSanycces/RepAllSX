#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTISTO23   [F:STJ]ACCDAT initialization                                #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
#--- Issue 108760 by TS
#Call SAIDOS(DOSSIER,"") From SAIDOS
Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
#---
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  #--- Issue 108760 By TS
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  #---

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Init [STJ]ACCDAT") From LECFIC

  Call MAJ_UTISTO23(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTISTO23(DOSSIER)
Value Char     DOSSIER

# Uniquement si module stock & compta
If [F:ADS]MODULE(6)<>2 : End : Endif
If [F:ADS]MODULE(1)<>2 : End : Endif

Call ECR_TRACE("UTISTO23: Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If filinfo(filpath("FIL","GACCENTRY","fde",DOSSIER),0) < 0 : End : Endif
If filinfo(filpath("FIL","STOJOU","fde",DOSSIER),0) < 0 : End : Endif
If clalev([F:STJ])  =0  Local File =DOSSIER+".STOJOU"     [STJ]  : Endif

If dim([F:STJ]ACCDAT)<=0
    Call ECR_TRACE("ACCDAT doesn't exist in STOJOU",1) From GESECRAN
Else

    Filter [STJ] Where ACCDAT=[0/0/0]
&                    & NUMVCR<>""
    Look [STJ] First
    Filter [STJ]
    If !fstat
        Local Integer IREQ
        Local Char REQ(250)(3)

        # Log of errors
        Gosub ERR

        # Update
        Gosub UPD

        Filter [STJ] Where ACCDAT<>[0/0/0]
        Call ECR_TRACE(num$(rowcount([STJ]))-"records updated",0) From GESECRAN
        Filter [STJ]
    Else
        Call ECR_TRACE("no record to update",0) From GESECRAN
    Endif
Endif

Call ECR_TRACE("UTISTO23: Process End",0) From GESECRAN
End

$UPD

Raz REQ, IREQ
# Update ACCDAT in STOJOU
Case GTYPDBA
    When 1 : Call ADDCRIT(REQ, IREQ, "", "Update "+DOSSIER+".STOJOU STJ", " ") From GOBJSUB
    When 2 : Call ADDCRIT(REQ, IREQ, "", "Update STJ", " ") From GOBJSUB
Endcase
Call ADDCRIT(REQ, IREQ, "", "SET STJ.ACCDAT_0 =", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "  (SELECT HAE.ACCDAT_0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "  From "+DOSSIER+".GACCENTRY HAE", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "  Where STJ.GTE_0  = HAE.TYP_0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "  and STJ.NUMVCR_0 = HAE.NUM_0 )", " ") From GOBJSUB
If GTYPDBA=2
    Call ADDCRIT(REQ, IREQ, "", "From "+DOSSIER+".STOJOU STJ", " ") From GOBJSUB
Endif
Call ADDCRIT(REQ, IREQ, "", "Where STJ.NUMVCR_0   <>' '", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "and EXISTS (SELECT 1 From "+DOSSIER+".GACCENTRY HAE", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",             "Where STJ.GTE_0 = HAE.TYP_0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",               "and STJ.NUMVCR_0 = HAE.NUM_0)", " ") From GOBJSUB

Trbegin [STJ]
Execsql From num$(GTYPDBA*2+1) Sql REQ
Commit

# Update ACCDAT in STOJOU
Raz REQ, IREQ
Case GTYPDBA
    When 1 : Call ADDCRIT(REQ, IREQ, "", "Update "+DOSSIER+".STOJOU STJ", " ") From GOBJSUB
    When 2 : Call ADDCRIT(REQ, IREQ, "", "Update STJ", " ") From GOBJSUB
Endcase
Call ADDCRIT(REQ, IREQ, "", "SET STJ.ACCDAT_0 =", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "  (SELECT HAT.ACCDAT_0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "  From "+DOSSIER+".GACCTMP HAT", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "  Where STJ.GTE_0  = HAT.TYP_0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",   "  and STJ.NUMVCR_0 = HAT.NUM_0 )", " ") From GOBJSUB
If GTYPDBA=2
    Call ADDCRIT(REQ, IREQ, "", "From "+DOSSIER+".STOJOU STJ", " ") From GOBJSUB
Endif
Call ADDCRIT(REQ, IREQ, "", "Where STJ.NUMVCR_0   <>' '", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",   "and EXISTS (SELECT 1 From "+DOSSIER+".GACCTMP HAT", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",              " Where STJ.GTE_0  = HAT.TYP_0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",                 "and STJ.NUMVCR_0 = HAT.NUM_0 )", " ") From GOBJSUB

Trbegin [STJ]
Execsql From num$(GTYPDBA*2+1) Sql REQ
Commit

Return

$ERR
# Look for all NUMVCR not existing in GACCENTRY and GACCTMP
Raz REQ, IREQ
Call ADDCRIT(REQ, IREQ, "", "SELECT GTE_0, NUMVCR_0, STOFCY_0, ITMREF_0, IPTDAT_0 From "+DOSSIER+".STOJOU STJ", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "Where STJ.NUMVCR_0 <>' '", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "  and not EXISTS", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "    (SELECT 1", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "    From "+DOSSIER+".GACCENTRY HAE", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "    Where STJ.GTE_0  = HAE.TYP_0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "    and STJ.NUMVCR_0 = HAE.NUM_0 )", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "  and not EXISTS", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "    (SELECT 1", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "    From "+DOSSIER+".GACCTMP HAT", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "    Where STJ.GTE_0  = HAT.TYP_0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "    and STJ.NUMVCR_0 = HAT.NUM_0 )", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "GROUP By GTE_0, NUMVCR_0, STOFCY_0, ITMREF_0, IPTDAT_0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "", "ORDER By GTE_0, NUMVCR_0, STOFCY_0, ITMREF_0, IPTDAT_0", " ") From GOBJSUB

For (Char GTE, Char NUMVCR, Char STOFCY, Char ITMREF, Date IPTDAT) From num$(GTYPDBA*2+1) Sql REQ As [SQLX]
    Call ECR_TRACE("GACCENTRY record doesn't exist :"-[F:SQLX]GTE-[F:SQLX]NUMVCR-"("+[F:SQLX]STOFCY-[F:SQLX]ITMREF-num$([F:SQLX]IPTDAT)+")",1) From GESECRAN
Next

# Update ACCDAT in STOJOU
Raz REQ, IREQ
Case GTYPDBA
    When 1 : Call ADDCRIT(REQ, IREQ, "", "Update "+DOSSIER+".STOJOU STJ", " ") From GOBJSUB
    When 2 : Call ADDCRIT(REQ, IREQ, "", "Update STJ", " ") From GOBJSUB
Endcase
Call ADDCRIT(REQ, IREQ, "", "SET STJ.ACCDAT_0 = STJ.IPTDAT_0", " ") From GOBJSUB
If GTYPDBA=2
    Call ADDCRIT(REQ, IREQ, "", "From "+DOSSIER+".STOJOU STJ", " ") From GOBJSUB
Endif
Call ADDCRIT(REQ, IREQ, "", "Where STJ.NUMVCR_0   <>' '", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",   "and Not EXISTS (SELECT 1 From "+DOSSIER+".GACCENTRY HAE", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",                   "Where STJ.GTE_0 = HAE.TYP_0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",                     "and STJ.NUMVCR_0 = HAE.NUM_0)", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",   "and not EXISTS", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",   "  (SELECT 1", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",     " From "+DOSSIER+".GACCTMP HAT", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",     " Where STJ.GTE_0  = HAT.TYP_0", " ") From GOBJSUB
Call ADDCRIT(REQ, IREQ, "",      "  and STJ.NUMVCR_0 = HAT.NUM_0 )", " ") From GOBJSUB

Trbegin [STJ]
Execsql From num$(GTYPDBA*2+1) Sql REQ
Commit

Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
#--- Issue 108760 by TS
#If APPLI="X3" : End : Endif
If APPLI=GDOSX3 : End : Endif
#---
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
#--- Issue 108760 by TS
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
#---
#--- Issue 108760 by TS
If filinfo(filpath("FIL","STOJOU","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table
If func DOSVUE.ISVIEW(APPLI,"STOJOU") : End : Endif                  : # For Archive folder
#---
Call MAJ_UTISTO23(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
#--- Issue 108760 by TS
#If APPLI="X3" : End : Endif
If APPLI=GDOSX3 : End : Endif
#---
#--- Issue 108760 by TS
If filinfo(filpath("FIL","STOJOU","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table
If func DOSVUE.ISVIEW(APPLI,"STOJOU") : End : Endif                  : # For Archive folder
#---
Call MAJ_UTISTO23(APPLI)
End

