#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ
Raz GBIDC1,GBIDC2

Call OBJET("ARV",GBIDC1,GBIDC2) From GOBJET
End
###############################################################################
# RAPPEL:
# CASE TYPCODE
#  when 1 : ETAT
#  when 2 : REQUETE
#  when 3 : REQUETE SQL
#  when 4 : EXPORT
# ENDCASE
###############################################################################
$ACTION
Case ACTION
 When "SETBOUT"     : Gosub SETBOUT
 When "LIENS"       : Gosub LIENS
 When "LIENS2"      : Gosub LIENS2
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "VERF_LISTE"  : Gosub VERF_LISTE
Endcase
Return
##########################################
$APRES_MODIF
Case zoncou
 When "TYPCOD"
  [M]INTIT = mess(zc,7818,1) : MA = 1 : Gosub TITMASK From =WINPROG
  Effzo [M]ETAT
  Effzo [M]20
Endcase
Return

$LIENS2
Case [F:ARV]TYPCOD
 When 1
  For [ARD]ARD0 Where RPTCOD = [F:ARV]ETAT & PARSAI=2
   For NOL = 0  To [M]NBLIG-1
    If [F:ARD]PARCOD = [M]PARAM(NOL)
     [M]TRI(NOL) = [ARD]PARNUM
     [M]PARAM(NOL)= [F:ARD]PARCOD
     [M]PARDES(NOL)= [F:ARD]PARCOD
    Endif
   Next
  Next
 When 2
  For [ALD]ALD0 Where COD = [F:ARV]ETAT & STREND >1
   For NOL = 0  To [M]NBLIG-1
    If [F:ALD]TBL+"~"+[F:ALD]FLD = [M]PARAM(NOL)
     [M]TRI(NOL) = [F:ALD]LIG
     Call LECTEXTRA([M]PARDES(NOL),"ALISTED","INTITLIG",[F:ALH]COD,num$([F:ALD]LIG)) From ATEXTRA
    Endif
   Next
  Next
 When 3
  For [ALD]ALD0 Where COD = [F:ARV]ETAT & ORD > 100
   For NOL = 0  To [M]NBLIG-1
    If num$([F:ALD]LIG) = [M]PARAM(NOL)
     [M]TRI(NOL)    = [F:ALD]LIG
     Call LECTEXTRA([M]PARDES(NOL),"ALISTED","INTITLIG",[F:ALH]COD,num$([F:ALD]LIG)) From ATEXTRA
    Endif
   Next
  Next
 When 4
  For [AOD]AOD0 Where EXT= [F:ARV]ETAT & SEL >1
   For NOL = 0  To [M]NBLIG-1
    If [F:AOD]FIL+"~"+[F:AOD]FLD=[M]PARAM(NOL)
     [M]TRI(NOL) = [F:AOD]NUMLIG
     [M]PARDES(NOL) = func SUBAOE.INTFLD([F:AOD]EXT,[F:AOD]FIL,[F:AOD]FLD)
    Endif
   Next
  Next
 When 5
  For [ABQ]ABQ0  Where COD = [F:ARV]ETAT
   For NOL = 0  To [M]NBLIG-1
    If num$([F:ABQ]LIG) = [M]PARAM(NOL)
     [M]TRI(NOL) = [ABQ]LIG
     [M]PARDES(NOL) = func AFNC.TEXTE([F:ABQ]TEX)
    Endif
   Next
  Next
Endcase
Gosub FORMULE
Sorta [M]NBLIG [M]NBLIG Order By [M]TRI([S]indice)
Return

$LIENS
Case [F:ARV]TYPCOD
 When 1
  Read[ARP]ARP0 = [F:ARV]ETAT
  Call TEXTE([F:ARP]RPTDES,[M]DESETA) From OBJDIV
 When 2,3
  Read[ALH]ALH0 = [F:ARV]ETAT
  Call LECTEXTRA([M]DESETA,"ALISTEH","INTIT",[F:ALH]COD,"") From ATEXTRA
 When 4
  Read[AOE]AOE0 = [F:ARV]ETAT
  Call LECTEXTRA([M]DESETA,"AOBJEXT","INTIT",[F:AOE]EXT,"") From ATEXTRA
 When 5
  Read[ABO]ABO0 = [F:ARV]ETAT
  Call TEXTE([F:ABO]DES,[M]DESETA) From OBJDIV
Endcase
[M]INTIT = mess([F:ARV]TYPCOD,7818,1) : MA = 1 : Gosub TITMASK From ="WG"+GBOITE
Return
#########################################
$SETBOUT
If CLECUR & REP="" & VERROU : CHAINE += "A" : Endif
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Endif
Return
##########################################
$SEL_LISTE
Case LISTE
 When "SELARP3" : Gosub SEL_PARAM3
Endcase
Return
##########################################
$VERF_LISTE
VALEUR = TEX2(find(VALEUR,TEX))
Case LISTE
 When "SELARP3"
  Case [M]TYPCOD
   When 1
   [M]TRI(nolign-1)   = val(right$(VALEUR,instr(0,VALEUR,"~")+1))
   VALEUR             = left$(VALEUR,instr(0,VALEUR,"~")-1)
   [M]PARAM(nolign-1) = VALEUR
  When 2
   [M]TRI(nolign-1)   = val(right$(VALEUR,instr(0,VALEUR,"@")+1))
   [M]PARAM(nolign-1) = left$(VALEUR,instr(0,VALEUR,"@")-1)
   Call LECTEXTRA(VALEUR,"ALISTED","INTITLIG",[M]ETAT,num$([M]TRI(nolign-1))) From ATEXTRA
  When 3
   [M]TRI(nolign-1)   = val(VALEUR)
   [M]PARAM(nolign-1) = VALEUR
   Call LECTEXTRA(VALEUR,"ALISTED","INTITLIG",[M]ETAT,num$([M]TRI(nolign-1))) From ATEXTRA
  When 4
   Read [AOD]AOD0 = [M]ETAT;val(VALEUR)
   If !fstat
    [M]TRI(nolign-1)   = [F:AOD]NUMLIG
    [M]PARAM(nolign-1) = [F:AOD]FIL+"~"+[F:AOD]FLD
    VALEUR             = func SUBAOE.INTFLD([F:AOD]EXT,[F:AOD]FIL,[F:AOD]FLD)
   Endif
  When 5
   [M]TRI(nolign-1)   = val(VALEUR)
   [M]PARAM(nolign-1) = VALEUR
   Call LECTEXTRA(VALEUR,"ABIREPORTD","TEX",[M]ETAT,num$([M]TRI(nolign-1))) From ATEXTRA
 Endcase
Endcase
Return
##########################################
$SEL_PARAM3
Local Char TEXTE(80)(1..300,1..1) , TEX(80)(1..300) , TEX2(80)(1..300)
FORCE = 1
NBTEX = 0
Case [M]TYPCOD
 When 1 : # Etat
  Local Char TEXTE(80)(1..300,1..2)
  For [ARD]ARD1 Where RPTCOD = [M]ETAT & PARSAI=2
   If NBTEX>=dim(TEX)-1 : Break : Endif
   If !find([ARD]PARCOD,[M]PARDES(0..[M]NBLIG))
    NBTEX += 1
    Call TEXTE([F:ARD]PARNAM,TEXTE(NBTEX,2)) From OBJDIV
    TEX(NBTEX)      = [ARD]PARCOD
    TEXTE(NBTEX,1)  = TEX(NBTEX)
    TEX2(NBTEX)  = [F:ARD]PARCOD+"~"+num$([ARD]PARNUM)
   Endif
  Next
  TIT(1) = mess(7,42,1)   : # Paramètres
  TIT(2) = mess(30,109,1) : # Intitulé
 When 2 : # Requêtes
  For [ALD]ALD0 Where COD = [M]ETAT & STREND >1
   If NBTEX>=dim(TEX)-1 : Break : Endif
   If !find([F:ALD]TBL+"~"+[F:ALD]FLD,[M]PARAM(0..[M]NBLIG))
    NBTEX += 1
    Call LECTEXTRA(TEXTE(NBTEX,1),"ALISTED","INTITLIG",[F:ALH]COD,num$([F:ALD]LIG)) From ATEXTRA
    TEX2(NBTEX)    = [F:ALD]TBL+"~"+[F:ALD]FLD+"@"+num$([F:ALD]LIG)
    TEX(NBTEX)     = TEXTE(NBTEX,1)
   Endif
  Next
  TIT(1) = mess(30,109,1) : # Intitulé
 When 3
  For [ALD]ALD0 Where COD = [M]ETAT & ORD > 100
   If NBTEX>=dim(TEX)-1 : Break : Endif
   If !find(num$([F:ALD]LIG),[M]PARAM(0..[M]NBLIG))
    NBTEX += 1
    Call LECTEXTRA(TEXTE(NBTEX,1),"ALISTED","INTITLIG",[F:ALH]COD,num$([F:ALD]LIG)) From ATEXTRA
    TEX2(NBTEX)    = num$([F:ALD]LIG)
    TEX(NBTEX)     = TEXTE(NBTEX,1)
   Endif
  Next
  TIT(1) = mess(30,109,1) : # Intitulé
 When 4
  For [AOD]AOD0 Where EXT= [M]ETAT & SEL >1
   If NBTEX>=dim(TEX)-1 : Break : Endif
   If !find([F:AOD]FIL+"~"+[F:AOD]FLD,[M]PARAM(0..[M]NBLIG))
    NBTEX += 1
    TEX(NBTEX)       = func SUBAOE.INTFLD([F:AOD]EXT,[F:AOD]FIL,[F:AOD]FLD)
    TEXTE(NBTEX,1)   = func SUBAOE.INTFLD([F:AOD]EXT,[F:AOD]FIL,[F:AOD]FLD)
    TEX2(NBTEX)      = num$([F:AOD]NUMLIG)
   Endif
  Next
  TIT(1) = mess(30,109,1) : # Intitulé
 When 5
  For [ABQ]ABQ0 Where COD = [M]ETAT
   If NBTEX>=dim(TEX)-1 : Break : Endif
   If !find(num$([F:ABQ]LIG),[M]PARAM(0..[M]NBLIG))
    NBTEX += 1
    TEXTE(NBTEX,1) = func AFNC.TEXTE([F:ABQ]TEX)
    TEX2(NBTEX)    = num$([F:ABQ]LIG)
    TEX(NBTEX)     = TEXTE(NBTEX,1)
   Endif
  Next
  TIT(1) = mess(30,109,1) : # Intitulé
Endcase
TIT(0) = mess(168,139,1): # Choix parametres
Return

##########################################
$FORMULE
Local Integer NBFOR
Local Char    AJOUT_FOR(20)

If [M]FONCTION <> ""
 Read [AFC]CODINT = [M]FONCTION
 If !fstat & [AFC]ACTION <> ""
  Read [ACT]ACTION = [AFC]ACTION
  If !fstat  & find([ACT]TYP,1,2,3,4)
   Case [ACT]TYP
    When 1 : # Gestion objet
     Read [AOB]ABREV= seg$([AFC]VALPAR(0),2,len([AFC]VALPAR(0))-1)
     If !fstat
      Filter [AWI] Where OBJ = [AOB]ABREV
      Read [AWI]AWI1 First
      Filter [AWI]
      Gosub CHARGE_WIN : AJOUT_FOR = ""
     Endif
    When 2 : # Consultation
     If [ACT]PARAM1 <> ""
      Read [ACN]ACN0 = [ACT]PARAM1
      If !fstat
       Read [AWI]AWI0 = [ACN]WND1
       If !fstat : Gosub CHARGE_WIN : Endif
       Read [AWI]AWI0 = [ACN]WND0
       If !fstat : Gosub CHARGE_WIN : Endif
      Endif
     Endif
    When 3 : # Traitement standard
     If [ACT]PARAM3 = 4
      Read [AWI]AWI0 = [ACT]PARAM4
      If !fstat : Gosub CHARGE_WIN : AJOUT_FOR = "" : Endif
     Endif
    When 4 : # Saisie fenetre
     If [ACT]PARAM2 <> ""
      Read [AWI]AWI0 = [ACT]PARAM2
      If !fstat : Gosub CHARGE_WIN : AJOUT_FOR = "" : Endif
     Endif
   Endcase
  Endif
 Endif
Endif
Return

$INC_FOR
If NBFOR<dim([M]HLPFOR) & !find(AJOUT_FOR,[M]HLPFOR(0..NBFOR+1))
 NBFOR += 1
 [M]HLPFOR(NBFOR-1) = [L]AJOUT_FOR
 AJOUT_FOR = ""
Endif
Return

$CHARGE_WIN
If [AWI]MSKENT <> ""
 Read [AMK]CODMSK = [F:AWI]MSKENT
 If !fstat
  AJOUT_FOR = "[M:"+[F:AMK]ABRMSK+"]"+[AWI]MSKENT
 Else
  AJOUT_FOR = "[M]"+[AWI]MSKENT
 Endif
 Gosub INC_FOR : AJOUT_FOR = ""
Endif
For I=0 To [AWI]NBMSK-1
 Read [AMK]CODMSK = [AWI]NOMMSK(I)
 If !fstat
  AJOUT_FOR = "[M:"+[F:AMK]ABRMSK+"]"+[AWI]NOMMSK(I)
 Else
  AJOUT_FOR = "[M]"+[AWI]NOMMSK(I)
 Endif
 Gosub INC_FOR : AJOUT_FOR = ""
Next
Return

##########################################
Subprog AM_ETAT(VALEUR)
Variable Char    VALEUR()

NOL = 0
[M]PARAM = ""
Effzo [M]20, NBLIG
Case [M]TYPCOD
 When 1
  Filter [ARD] Where RPTCOD=VALEUR & PARSAI=2
  For [ARD]
   [M]PARAM(NOL) = [F:ARD]PARCOD
   [M]TRI(NOL)   = [F:ARD]PARNUM
   [M]PARDES(NOL)= [F:ARD]PARCOD
   NOL +=1
  Next
  Filter [ARD]

 When 2
  Read [ALH]ALH0 = VALEUR
  Filter [ALD] Where COD=[F:ALH]COD & STREND >1
  For [ALD]
   [M]PARAM(NOL) = [F:ALD]TBL+"~"+[F:ALD]FLD
   [M]TRI(NOL) = [F:ALD]LIG
   Call LECTEXTRA([M]PARDES(NOL),"ALISTED","INTITLIG",[F:ALH]COD,num$([F:ALD]LIG)) From ATEXTRA
   NOL+= 1
  Next
  Filter [ALD]

 When 3
  Read [ALH]ALH0 = VALEUR
  Filter [ALD] Where COD=[F:ALH]COD & ORD > 100
  For [ALD]
   [M]PARAM(NOL)   = num$([F:ALD]LIG)
   Call LECTEXTRA([M]PARDES(NOL),"ALISTED","INTITLIG",[F:ALH]COD,num$([F:ALD]LIG)) From ATEXTRA
   [M]TRI(NOL) = [F:ALD]LIG
   NOL+= 1
  Next
  Filter [ALD]

 When 4
  For [AOD]AOD0 Where EXT=VALEUR & SEL >1
   [M]PARAM(NOL) = [F:AOD]FIL+"~"+[F:AOD]FLD
   [M]TRI(NOL) = [F:AOD]NUMLIG
   [M]PARDES(NOL) = func SUBAOE.INTFLD([F:AOD]EXT,[F:AOD]FIL,[F:AOD]FLD)
   NOL+= 1
  Next

 When 5
  Filter [ABQ] Where COD=VALEUR
  For [ABQ]
   [M]PARAM(NOL)  = num$([F:ABQ]LIG)
   [M]TRI(NOL)    = [F:ABQ]LIG
   [M]PARDES(NOL) =   func AFNC.TEXTE([F:ABQ]TEX)
   NOL +=1
  Next
  Filter [ABQ]

Endcase
[M]NBLIG = NOL
Sorta [M]NBLIG [M]NBLIG Order By [M]TRI([S]indice)
Affzo [M]
End
##########################################
Subprog AS_VALDEF2(VALEUR)
Variable Char VALEUR
Local Char FIN(3)
If [M]TYPCOD = 1
 Read [ARD]ARD1 = [M]PARAM(nolign-1);[M]ETAT
 If [F:ARD]PARSTREND<2
  mkstat = 1 : End
 Endif
Endif
If [M]TYPCOD = 5
 mkstat = 1 : End
Endif
End
##########################################
Subprog IB_ETAT
Case [M:ARV1]TYPCOD
 When 1 : # Etats
  GBIDC1 = "ARP"
  Raz GBOUT1 , GBOUT3 , GBOUT4 , GBOUT5 , GBOUT6 , GBOUT7
 When 2 : # Requetes
  GBIDC1 = "ALH"
  GBIDC2 = "ALT"
  Raz GBOUT2 , GBOUT4 , GBOUT6 , GBOUT7
 When 3 : # Requêtes SQL
  GBIDC1 = "ALQ"
  Raz GBOUT1 , GBOUT2 , GBOUT3 , GBOUT5 , GBOUT6 , GBOUT7
 When 4 : # Exports
  GBIDC1 = "AOE"
  Raz GBOUT1 , GBOUT2 , GBOUT3 , GBOUT4 , GBOUT5 , GBOUT7
 When 5 : # BO
  GBIDC1 = "ABO"
  Raz GBOUT1 , GBOUT2 , GBOUT3 , GBOUT4 , GBOUT5 , GBOUT6
Endcase
End
##########################################
Subprog C_ETAT(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
 Case [M:ARV1]TYPCOD
  When 1 : # Etats
   Read[ARP]ARP0 = VALEUR
   If fstat
    GMESSAGE = mess(163,123,1) :  # Etat inexistant
    mkstat=2 : End
   Endif

  When 2 : # Requetes
   Read[ALH]ALH0 = VALEUR
   If fstat
    GMESSAGE = mess(119,133,1) :  # Requete inexistante
    mkstat=2 : End
   Elsif !find([F:ALH]TYP,1,3)
    GMESSAGE = mess(255,133,1) : # La requête existe, mais elle n'est pas du bon type
   Endif

  When 3 : # Requêtes SQL
   Read[ALH]ALH0 = VALEUR
   If fstat
    GMESSAGE = mess(119,133,1) :  # Requête SQL inexistante
    mkstat=2 : End
   Elsif [F:ALH]TYP<>2
    GMESSAGE = mess(255,133,1) : # La requête existe, mais elle n'est pas du bon type
   Endif

  When 4 : # Exports
   Read[AOE]AOE0 = VALEUR
   If fstat
    GMESSAGE = mess(150,141,1) :  # Export inexistant
    mkstat=2 : End
   Else
    If [AOE]EXPORT <> 2
     GMESSAGE = mess(110,141,1) :  # Export impossible sur ce modèle
     mkstat=2 : End
    Endif
   Endif

  When 5 : # Etats BO
   Read[ABO]ABO0 = VALEUR
   If fstat
    GMESSAGE = mess(163,123,1) :  # Etat inexistant
    mkstat=2 : End
   Endif
 Endcase
Endif
End
##########################################
Subprog AM_FONCTION(VALEUR)
Variable Char    VALEUR()
[M]FONCTION = VALEUR
Gosub FORMULE
End
##########################################
Subprog B2_NBLIG
Local Integer OK
OK =0
Case [M]TYPCOD
 When 1
  For [ARD] Where RPTCOD=[M]ETAT & PARSAI=2
   If !find([F:ARD]PARCOD,[M]PARAM(0..[M]NBLIG-1))
    [M]PARAM([M]NBLIG)  = [F:ARD]PARCOD
    [M]PARDES([M]NBLIG) = [F:ARD]PARCOD
    [M]TRI([M]NBLIG)    = [ARD]PARNUM
    [M]NBLIG+= 1
    OK = 1
   Endif
  Next
 When 2
  For [ALD]ALD0 Where COD = [M]ETAT & STREND >1
   If !find([F:ALD]TBL+"~"+[F:ALD]FLD,[M]PARAM(0..[M]NBLIG-1))
    Call LECTEXTRA([M]PARDES([M]NBLIG),"ALISTED","INTITLIG",[F:ALH]COD,num$([F:ALD]LIG)) From ATEXTRA
    [M]PARAM([M]NBLIG)  = [F:ALD]TBL+"~"+[F:ALD]FLD
    [M]TRI([M]NBLIG)    = [F:ALD]LIG
    [M]NBLIG+= 1
    OK = 1
   Endif
  Next
 When 3
  For [ALD]ALD0 Where COD = [M]ETAT & ORD > 100
   If !find(num$([F:ALD]LIG),[M]PARAM(0..[M]NBLIG-1))
    Call LECTEXTRA([M]PARDES([M]NBLIG),"ALISTED","INTITLIG",[F:ALH]COD,num$([F:ALD]LIG)) From ATEXTRA
    [M]PARAM([M]NBLIG)  = num$([F:ALD]LIG)
    [M]TRI([M]NBLIG)    = [F:ALD]LIG
    [M]NBLIG+= 1
    OK = 1
   Endif
  Next
 When 4
  For [AOD]AOD0 Where EXT=[M]ETAT & SEL >1
   If !find([F:AOD]FIL+"~"+[F:AOD]FLD,[M]PARAM(0..[M]NBLIG-1))
    [M]PARAM([M]NBLIG)  = [F:AOD]FIL+"~"+[F:AOD]FLD
    [M]TRI([M]NBLIG)    = [F:AOD]NUMLIG
    [M]PARDES([M]NBLIG) = func SUBAOE.INTFLD([F:AOD]EXT,[F:AOD]FIL,[F:AOD]FLD)
    [M]NBLIG+= 1
    OK = 1
   Endif
  Next
 When 5
  For [ABQ] Where COD=[M]ETAT
   If !find(num$([F:ABQ]LIG),[M]PARAM(0..[M]NBLIG-1))
    [M]PARDES([M]NBLIG) =   func AFNC.TEXTE([F:ABQ]TEX)
    [M]PARAM([M]NBLIG)  = num$([F:ABQ]LIG)
    [M]TRI([M]NBLIG)    = [F:ABQ]LIG
    [M]NBLIG+= 1
    OK = 1
   Endif
  Next
Endcase
Sorta [M]NBLIG [M]NBLIG Order By [M]TRI([S]indice)
Affzo [M]
If OK
 mkstat = 4
Else
 Call MESSAGE(mess(165,139,1)) From GESECRAN : # tous les parametres presents
Endif
End
##########################################
Subprog C_PARDES(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If VALEUR <> ""
 Case TYPCOD
 When 1
  OK = 0
  For [ARD]ARD0 Where [F:ARD]RPTCOD = [M]ETAT & [F:ARD]PARSAI=2
   If left$(toupper([F:ARD]PARCOD),len(VALEUR)) = toupper(VALEUR)
    OK = 1 : Break
   Endif
  Next
  If OK
   [M]TRI(nolign-1)   = [F:ARD]PARNUM
   [M]PARAM(nolign-1) = [F:ARD]PARCOD
   VALEUR = [F:ARD]PARCOD
  Else
   GMESSAGE = mess(2,114,1) : # Paramètre inexistant
   mkstat = 2
  Endif
 When 2
  OK = 0
  For [AXX]AXX0 Where CODFIC = "ALISTED" & ZONE = "INTITLIG" & IDENT1 = [M]ETAT
   If left$(toupper([F:AXX]TEXTE),len(VALEUR)) = toupper([L]VALEUR)
    OK =1
    Break
   Endif
  Next
  If OK
   Read [ALD]ALD0 = [M]ETAT;val([AXX]IDENT2)
   If !fstat   & [F:ALD]STREND >1
    [M]TRI(nolign-1)   = [F:ALD]LIG
    [M]PARAM(nolign-1) = [F:ALD]TBL+"~"+[F:ALD]FLD
    VALEUR = [AXX]TEXTE
   Else
    GMESSAGE = mess(2,114,1) : # Paramètre inexistant
    mkstat = 2
   Endif
  Else
   GMESSAGE = mess(2,114,1) : # Paramètre inexistant
   mkstat = 2
  Endif
 When 3
  OK = 0
  For  [AXX]AXX0 Where CODFIC = "ALISTED" & ZONE = "INTITLIG" & IDENT1 = [M]ETAT
   If left$(toupper([F:AXX]TEXTE),len(VALEUR)) = toupper(VALEUR)
    OK =1
    Break
   Endif
  Next
  If OK
   Read [ALD]ALD0 = [M]ETAT;val([AXX]IDENT2)
   If !fstat & [F:ALD]ORD > 100
    [M]TRI(nolign-1)   = [F:ALD]LIG
    [M]PARAM(nolign-1) = num$([F:ALD]LIG)
    VALEUR = [AXX]TEXTE
   Else
    GMESSAGE = mess(2,114,1) : # Paramètre inexistant
    mkstat = 2
   Endif
  Else
   GMESSAGE = mess(2,114,1) : # Paramètre inexistant
   mkstat = 2
  Endif
 When 4
  OK = 0
  For [AOD]AOD0 Where EXT = [M:ARV1]ETAT & SEL >1
   If left$(toupper(func SUBAOE.INTFLD([F:AOD]EXT,[F:AOD]FIL,[F:AOD]FLD)),len(VALEUR)) = toupper(VALEUR)
    OK = 1
    Break
   Endif
  Next
  If OK
   [M]TRI(nolign-1)   =  [F:AOD]NUMLIG
   [M]PARAM(nolign-1) =  [F:AOD]FIL+"~"+[F:AOD]FLD
   VALEUR = func SUBAOE.INTFLD([F:AOD]EXT,[F:AOD]FIL,[F:AOD]FLD)
  Else
   GMESSAGE = mess(2,114,1) : # Paramètre inexistant
   mkstat = 2
  Endif
 When 5
  OK = 0
  For  [ATX]TEXTE Where LAN= GLANGUE
   If left$(toupper([F:ATX]TEXTE),len(VALEUR)) = toupper(VALEUR)
    OK =1
    Break
   Endif
  Next
  If OK
   Read [ABQ]ABQ0 = [M]ETAT;[M]TRI(nolign-1)
   If !fstat
    [M]TRI(nolign-1)   = [F:ABQ]LIG
    [M]PARAM(nolign-1) = num$([F:ABQ]LIG)

   Else
    GMESSAGE = mess(2,114,1) : # Paramètre inexistant
    mkstat = 2
   Endif
  Else
   GMESSAGE = mess(2,114,1) : # Paramètre inexistant
   mkstat = 2
  Endif
 Endcase
Endif
End

Subprog AS_TYPCOD(VALEUR)
Variable Integer VALEUR
If func AFNC.ACTIV("ABI") = 0
 GMENLOC(5) = 1
Endif
End

Subprog IB_PARDES
Gosub CTL_NBR_PARM
If !NBTEX
 GBOUTS = ""
Endif
End

Subprog IB_NBLIG
Gosub CTL_NBR_PARM
If !NBTEX
 GBOUT2 = ""
Endif
End

Subprog IB_VALDEF1
Local Char TYP(5)
Case [M]TYPCOD
 When 1
  Read [ARD]ARD1 = [M]PARAM(nolign-1);[M]ETAT
  If fstat<=2
   TYP = [F:ARD]PARTYP
  Endif
 When 2,4
  Local Char    TABLE(30)
  Local Integer I
  TABLE = [M]PARAM(nolign-1)
  I = instr(1,TABLE,"~")
  If I
   Read [ATZ]CODZONE = left$(TABLE,I-1);right$(TABLE,I+1)
   If fstat<=2
    TYP = [F:ATZ]CODTYP
   Endif
  Endif
 When 3
  Read [ALD]ALD0 = [M]ETAT;val([M]PARAM(nolign-1))
  If fstat<=2
   TYP = [F:ALD]CODTYP
  Endif
 When 5
  Filter [ABQ] Where COD=[M]ETAT & TEX=[M]PARDES(nolign-1)
  Read [ABQ] First
  Filter [ABQ]
  If fstat<=2
   TYP = [F:ABQ]TYP
  Endif
Endcase
If TYP<>""
 Call LECTURE("ATY",TYP,"") From CONTOBJ
 If [F:ATY]TYPTYP<>8
  Raz GBOUT4
 Endif
Endif
End

Subprog IB_VALDEF2
Call IB_VALDEF1
End

$CTL_NBR_PARM
Local Integer NBTEX
Case [M]TYPCOD
 When 1 : # Etat
  For [ARD]ARD1 Where RPTCOD = [M]ETAT
   If !find([ARD]PARCOD,[M]PARDES(0..[M]NBLIG))
    NBTEX += 1
   Endif
  Next
 When 2 : # Requêtes
  For [ALD]ALD0 Where COD = [M]ETAT & STREND >1
   If !find([F:ALD]TBL+"~"+[F:ALD]FLD,[M]PARAM(0..[M]NBLIG))
    NBTEX += 1
   Endif
  Next
 When 3
  For [ALD]ALD0 Where COD = [M]ETAT & ORD > 100
   If !find(num$([F:ALD]LIG),[M]PARAM(0..[M]NBLIG))
    NBTEX += 1
   Endif
  Next
 When 4
  For [AOD]AOD0 Where EXT= [M]ETAT & SEL >1
   If !find([F:AOD]FIL+"~"+[F:AOD]FLD,[M]PARAM(0..[M]NBLIG))
    NBTEX += 1
   Endif
  Next
 When 5 : # Etat BO
  For [ABQ]ABQ0 Where COD = [M]ETAT
   If !find(num$([F:ABQ]LIG),[M]PARDES(0..[M]NBLIG))
    NBTEX += 1
   Endif
  Next
Endcase
Return

################################################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File AREPORTV  [ARV1]
Else
 Local File =[M]DOSORG+".AREPORTV"  [ARV1]
Endif
If [M]DOSDES=nomap
 Local File AREPORTV  [ARV2]
 Local File AREPORT   [ARP2]
 Local File AOBJEXT   [AOE2]
 If filinfo(filpath("FIL","ALISTEH","fde",nomap),0)>0
  Local File ALISTEH   [ALH2]
 Endif
 If filinfo(filpath("FIL","ABIREPORT","fde",nomap),0)>0
  Local File ABIREPORT [ABO2]
 Endif
Else
 Local File =[M]DOSDES+".AREPORTV"  [ARV2]
 Local File =[M]DOSDES+".AREPORT"   [ARP2]
 Local File =[M]DOSDES+".AOBJEXT"   [AOE2]
 If filinfo(filpath("FIL","ALISTEH","fde",[M]DOSDES),0)>0
  Local File =[M]DOSDES+".ALISTEH"   [ALH2]
 Endif
 If filinfo(filpath("FIL","ABIREPORT","fde",[M]DOSDES),0)>0
  Local File =[M]DOSDES+".ABIREPORT" [ABO2]
 Endif
Endif

Case val(TABLE2)
 When 1   : Read [F:ARP2]ARP0 = TABLE3
 When 2,3 : If clalev([F:ALH2])>0 : Read [F:ALH2]ALH0 = TABLE3 : Endif
 When 4   : Read [F:AOE2]AOE0 = TABLE3
 When 5   : If clalev([F:ABO2])>0 : Read [F:ABO2]ABO0 = TABLE3 : Endif
Endcase
If fstat
 Call ERREUR(mess(3,23,1)-[M]DOSDES-mess(val(TABLE2),7818,1)-TABLE3-mess(163,123,1)) From GESECRAN
Else
 Call TEMPON("T") From GESECRAN
 Call DEBTRANS From GLOCK
 Gosub TR_COP
 Call TEMPOFF From GESECRAN
Endif
Close Local File [ARV1], [ARV2], [ARP2], [AOE2]
If clalev([F:ALH2])>0 : Close Local File [ALH2] : Endif
If clalev([F:ABO2])>0 : Close Local File [ABO2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [ARV2]
 Delete [ARV2] Where FONCTION=TABLE & TYPCOD = val(TABLE2) & ETAT=TABLE3
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AREPORTV" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ARV2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ARV1] Where FONCTION=TABLE & TYPCOD = val(TABLE2) & ETAT=TABLE3
  [F:ARV2] = [F:ARV1]
  If dim([F:ARV2]UPDUSR)>0 : [F:ARV2]UPDUSR = GUSER : Endif
  If dim([F:ARV2]UPDDAT)>0 : [F:ARV2]UPDDAT = date$ : Endif
  Write [ARV2]
  If fstat
   GOK = 0 : Call FSTA("ARV2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return
