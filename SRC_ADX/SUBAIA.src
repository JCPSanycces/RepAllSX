#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion du fichier AIMPAUS
Raz GPILOBJ
Call OBJET("AIA",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "SETBOUT"    : Gosub SETBOUT
 When "LIENS"      : Gosub LIENS
 When "MODIF"      : Gosub MODIF
Endcase
Return

$SETBOUT
Call VIREBOUT(CHAINE,"CDAH") From GOBJET
Return

$LIENS
nolign = 0
For [AIA]AIA0 Where USR=[F:AUS]USR
 nolign += 1
 [M] = [F:AIA]
Next
[M]NBLIG = nolign
Return
 
$MODIF
Delete [AIA] Where USR=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$APRTAUS"-CLECUR1 : Return
Endif
For nolign=1 To [M]NBLIG
 [F:AIA] = [M]
 Write [AIA]
 If fstat
  GOK = 0 : Call FSTA("AIA") From GLOCK : Break
 Endif
Next nolign
Return

########################################
Subprog C_RPTCOD(VALEUR)
Variable Char    VALEUR()
End

Subprog C_CMP(VALEUR)
Variable Char VALEUR()
Local Integer I , NOL
NOL = nolign-1
For I=0 To [M]NBLIG-1
 If I<>NOL & [M]RPTCOD(I)=[M]RPTCOD(NOL) & [M]CMP(I)=VALEUR
  GMESSAGE = mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
  mkstat = 2 : Break
 Endif
Next I
End

Subprog C_PRT(VALEUR)
Variable Char    VALEUR()
Read [ARP]ARP0 = [M]RPTCOD(nolign-1)
Read [AIM]AIM0 = VALEUR
If [F:AIM]PRT=2 & [F:AIM]PRTNAT>1 & [F:ARP]PRTNAT<>[F:AIM]PRTNAT
 GMESSAGE = mess(5,133,1)-"("+mess([F:AIM]PRTNAT,22,1)+")" : # Imprimante de type incorrect
 mkstat = 2 : End 
Endif
If [F:AIM]ACS<>""
 Read [ACC]CODACC = [M]USR;[F:AIM]ACS
 If fstat or [F:ACC]EXEC<>2
  GMESSAGE = mess(6,133,1)-[M]USR-"("+[F:AIM]ACS+")" : # Imprimante non autorisée
  mkstat = 2 : End
 Endif
Endif
End

Subprog AVANT_NBLIG
If [M]RPTCOD(nolign-1)<>""
 Call LECTURE("ARP",[M]RPTCOD(nolign-1),"") From CONTOBJ
Endif
End

