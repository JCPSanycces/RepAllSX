#Handle functions and subprograms for KZA - ESS
Subprog AM_RSAID(VALEUR)
Variable Char    VALEUR()
#------------------------Hybrid-------------------------#
I_ESSEMPKZA.RSAID = VALEUR
Call RECOVERS_ERROR_IN_CLASSIC(I_ESSEMPKZA) From ESS_WRKFLOW_FUNC_HYBRID
If GERR = 1 Then
  I_ESSEMPKZA.RSAID   = I_ESSEMPKZA.snapshot.RSAID
  GERR = 1
  mkstat = 2
  End
Else
  Gosub UPDATE_ESSEMPKZA From ESSEMP
Endif
#------------------------Hybrid-------------------------#
End

