#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion du masque MGC1
########################################
Subprog IB_NBPNL
  If nolign >= dim([M:MGC1]MGCCOLKEY) Then
    Raz GBOUT1
  Else
    If [M:MGC1]MGCCOLKEY(nolign-1) = "" Then
      Raz GBOUT1
    Else
      If GSZMGCZOOM = "" Then
        Raz GBOUT1
      Else
        GBOUT1 = mess(65,198,1) #Détail
      Endif
    Endif
  Endif
End
