#<AdxTL>@(#)0.0.0.0 $Revision$
##########################
Subprog TRANIDPYH(TYP,NUM,ID)
##########################
Value Integer TYP
Value Char    NUM()
Variable Char ID

Local Integer OK, I, STACUR, ACCCUR, ERR
Local Libelle EXISTE
Local Char    OMESSAGE(255), ADI304(3), MESSA(250)

If !clalev([F:PAN]) : Local File PAYACCNUM  [PAN] : Endif
If !clalev([F:DAE]) : Local File GACCENTRYD [DAE] : Endif
If !clalev([F:HAE]) : Local File GACCENTRY  [HAE] : Endif
If !clalev([F:DAT]) : Local File GACCTMPD   [DAT] : Endif

Filter [PAN] Where TYPNUM=[L]TYP & NUM=[L]NUM & STA>0
&              Order By Key CLE = TYPNUM ; NUM ; ACCSTA; ACCNUM
For [PAN]CLE
  GCLE=""
  Read [DAE]DAE2 = [F:PAN]ACCNUM
  If fstat=0
   Read [F:HAE]HAE0=[DAE]TYP;[DAE]NUM
   If len([F:DAE]TYP+ctrans([F:DAE]NUM,"_-.\/",""))>20
     GCLE = format$("D:YYYY[-]MM[-]DD",[F:DAE]ACCDAT) + " " + [F:HAE]JOU + " " + ctrans([F:DAE]NUM,"_-.\/","")
   Else
     GCLE = format$("D:YYYY[-]MM[-]DD",[F:DAE]ACCDAT) + " " + [F:HAE]JOU + " " + [F:HAE]TYP+ctrans([F:DAE]NUM,"_-.\/","")
   Endif
  Else
   Read [DAT]DAT1 = [F:PAN]ACCNUM
   If fstat=0
    Break
   Else
    GCLE=num$([F:PAN]ACCNUM)
   Endif
  Endif
Next
Filter [PAN]
ID = GCLE
End

