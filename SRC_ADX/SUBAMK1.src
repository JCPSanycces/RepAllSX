Raz GPILOBJ
Call OBJET("AMK",GBIDC1,GBIDC2) From GOBJET
End

########################################
## Etiquettes masque AMK1             ##
########################################
Subprog AM_TRTSPE(VALEUR)
Variable Char    VALEUR()
Gosub VERFTRT
End

$VERFTRT
Local Integer OK
Call EXISTE_ADX("","",VALEUR,OK) From ORDSYS
If OK>0
 OK=2
 Call AVERTIR(mess(143,123,1),OK) From GESECRAN : # Traitement déjà existant
 If OK<>2 : mkstat=2 : Endif
Endif
Return

Subprog AM_TRTSPV(VALEUR)
Variable Char    VALEUR()
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If clalev([F:ADW])=0 : Local File ADOVAL   [ADW] : Endif
Read [ADW]ADW0="";"";"SUPDOS"
Read [ADS]DOSSIER=nomap
If [F:ADS]DOSREF<>[F:ADW]VALEUR & GREP<>"D"
 GMESSAGE = mess(9,123,1) : # Modification impossible
 mkstat = 2 : End
Endif
If VALEUR=""
 Filter [AMA] Where CODAFF=[M]CODMSK & TYPAFF=1 & ACTION="SPV"
 Read [AMA]NOACT First
 Filter [AMA]
 If !fstat
  GMESSAGE = mess(124,139,1) : # Il existe des actions SPV
  mkstat = 2 : End
 Endif
Else
 Gosub VERFTRT
Endif
End

Subprog C_ZTITBLOC(VALEUR)
Variable Char    VALEUR()
Call C_QUOTE(VALEUR)
End

Subprog C_QUOTE(CHAINE)
Variable Char CHAINE()
If instr(1,CHAINE,'"')
 GMESSAGE = '"'-":"-mess(94,123,1) : # Caractère interdit
 mkstat=2 : End
Endif
End

Subprog C_NBBLOC
Local Integer I , J , K
Local Integer LIG , COL , LAR , HAU
Local Integer MAP(1..10,1..10)
Raz MAP
If status<65 or (status>90 & status<=1729)
 If [M]NBBLOC=0
  GMESSAGE = mess(144,123,1) : # Aucun bloc défini
  mkstat = 1 : End
 Endif
 For I=0 To [M]NBBLOC-1
  If find([M]RANG(I),[M]RANG(0..I-1),[M]RANG(I+1..[M]NBBLOC-1))
   GMESSAGE = mess(145,123,1)-num$([M]RANG(I))
   # Il existe 2 blocs avec le rang ...
   mkstat = 2 : Break
  Endif
  If [M]TYPBLOC(I)<>5 & [M]TYPBLOC(I)<>10
   For J=I+1 To [M]NBBLOC-1
    If [M]TYPBLOC(J)<>5 & [M]TYPBLOC(J)<>10  & [M]POSBLOC(J)=[M]POSBLOC(I)
     GMESSAGE = mess(87,133,1)-num$([M]POSBLOC(I))
     # Il existe 2 blocs avec la position ...
     mkstat = 2 : Break 2
    Endif
   Next J
  Endif
  If [M]TYPBLOC(I)<>5 & [M]TYPBLOC(I)<>10
   LIG = int([M]POSBLOC(I))
   COL = 10*([M]POSBLOC(I)-LIG)
   If COL=0 : COL = 1 : Endif
   LAR = [M]COLBLOC(I)
   HAU = [M]LINBLOC(I)
   For J=0 To HAU-1
    For K=0 To LAR-1
     If MAP(LIG+J,COL+K)
      GMESSAGE = mess(89,133,1)-":"-num$(I+1)-num$(MAP(LIG+J,COL+K))
      mkstat = 2 : Break 3
     Else
      MAP(LIG+J,COL+K) = I+1
     Endif
    Next K
   Next J
  Endif
 Next I
Endif
End

Subprog APRES_NBBLOC
Local Integer I , NOL
NOL = nolign
If status<>6
 # Insertion d'un bloc
 If    GSTATUS=73
  For I=0 To [M:AMK2]NBLIG-1
   If [M:AMK2]NUMBLOC(I)>=NOL
    [M:AMK2]NUMBLOC(I) += 1
   Endif
  Next I
  Affzo [AMK2]NUMBLOC

 # Suppression d'un bloc

 Elsif GSTATUS=65
  For I=0 To [M:AMK2]NBLIG-1
   If [M:AMK2]NUMBLOC(I)>NOL
    [M:AMK2]NUMBLOC(I) -= 1
   Endif
  Next I
  Affzo [AMK2]NUMBLOC
 Endif

 If GSTATUS=73 | GSTATUS=82
  If find([M:AMK1]TYPBLOC(NOL-1),1,6,7,8,9)
   # Verif exsistance champ parametres dans AMK2
   Local Integer NBBASPAG
   For I=0 To [M:AMK2]NBLIG-1
    If [M:AMK2]CODZON(I)= [M:AMK1]BASPAG(NOL-1)
     NBBASPAG = 1
     Break
    Endif
   Next I
   If !NBBASPAG
    ### Ajout champ ABS dans AMK2 en fin de tableau
    [M:AMK2]NBLIG += 1
    [M:AMK2]CODZON([M:AMK2]NBLIG-1) = [M:AMK1]BASPAG(NOL-1)
    [M:AMK2]NUMBLOC([M:AMK2]NBLIG-1)= NOL
    [M:AMK2]NOZONE([M:AMK2]NBLIG-1) = 1
    Case [M:AMK1]TYPBLOC(NOL-1)
     When 1
     [M:AMK2]CODTYP([M:AMK2]NBLIG-1) = "ABS"
     [M:AMK2]DIME([M:AMK2]NBLIG-1)   = 0
    When 6,8,9
     [M:AMK2]CODTYP([M:AMK2]NBLIG-1) = "AC0"
    When 7
     [M:AMK2]CODTYP([M:AMK2]NBLIG-1) = "AB0"
    Endcase
    If find([M:AMK1]TYPBLOC(NOL-1),6,7,8,9)
     [M:AMK2]LONG([M:AMK2]NBLIG-1) = 1
     [M:AMK2]DIME([M:AMK2]NBLIG-1) = 1
     [M:AMK2]VAL1([M:AMK2]NBLIG-1) = 10
     [M:AMK2]VAL2([M:AMK2]NBLIG-1) = 10
     [M:AMK2]VAL3([M:AMK2]NBLIG-1) = 1
     [M:AMK2]TYPGRAPH([M:AMK2]NBLIG-1) = 10
    Endif
    [M:AMK2]NOLIB([M:AMK2]NBLIG-1)  = 0
    [M:AMK2]CODACT([M:AMK2]NBLIG-1) = ""
    Affzo [AMK2]NBLIG,CODZON,NOZONE,CODTYP,DIME,CODACT,NUMBLOC,LONG,TYPGRAPH
   Endif
  Endif
 Endif

 # Changement de type d'un bloc

 If find([M:AMK1]TYPBLOC(NOL-1),1,6,7,8,9) & [M]OTYPBLOC(NOL-1)<>1 : # Ajout d'un tableau
  For I=0 To [M:AMK2]NBLIG-1
   If [M:AMK2]NUMBLOC(I)=NOL
    If [M:AMK2]CODZON(I)=[M]BASPAG(NOL-1)
     Case [M:AMK1]TYPBLOC(I)
      When 1
       [M:AMK2]CODTYP(I) = "ABS"
       [M:AMK2]DIME(I)   = 0
      When 6
       [M:AMK2]CODTYP(I) = "AC0"
      When 7
       [M:AMK2]CODTYP(I) = "AB0"
     Endcase
     If find([M:AMK1]TYPBLOC(NOL-1),6,7,8,9)
      [M:AMK2]LONG(I) = 1
      [M:AMK2]DIME(I) = 1
      [M:AMK2]VAL1(I) = 10
      [M:AMK2]VAL2(I) = 10
      [M:AMK2]VAL3(I) = 1
      [M:AMK2]TYPGRAPH(I) = 10
     Endif
     [M:AMK2]CODACT(I) = ""
    Else
     [M:AMK2]MODE(I) = 1
     If [M]ACTBLOC(NOL-1)<>""
      [M:AMK2]CODACT(I) = [M]ACTBLOC(NOL-1)
     Else
      [M:AMK2]DIME(I) = [M]NBLIGT(NOL-1)
     Endif
    Endif
   Endif
  Next I
  Affzo [AMK2]CODTYP,DIME,CODACT,MODE,LONG,TYPGRAPH
 Endif
# Change from table bloc to non-table
# the deletion of a table bloc is managed in AVANT_NBBLOC
 If [M]TYPBLOC(NOL-1)<>1 & [M]OTYPBLOC(NOL-1)=1
  For I=0 To [M:AMK2]NBLIG-1
   If [M:AMK2]NUMBLOC(I)=NOL
    [M:AMK2]DIME(I) = 1
    [M:AMK2]MODE(I) = 0     # Issue X3-61517 - 2017-11-15 by CCC : change only fields in the bloc modified
   Endif
   #[M:AMK2]MODE(I) = 0
  Next I
  Affzo [AMK2]DIME,MODE
 Endif
 If [M]TYPBLOC(NOL-1)=5 & [M]OTYPBLOC(NOL-1)<>5 : # Création bloc invisible
  For I=0 To [M:AMK2]NBLIG-1
   If [M:AMK2]NUMBLOC(I)=NOL
    [M:AMK2]SAIAFF(I) = 3
    [M:AMK2]OPTSAI(I) = ""
    [M:AMK2]OPTFOR(I) = ""
    [M:AMK2]OPTLNG(I) = 0
	# CCL 116176
    [M:AMK2]TUNNEL(I) = 0
    [M:AMK2]LIEN(I) = 0
   Endif
  Next I
 Endif
 If [M]TYPBLOC(NOL-1)=10 & [M]OTYPBLOC(NOL-1)<>10 : # Création bloc technique
  For I=0 To [M:AMK2]NBLIG-1
   If [M:AMK2]NUMBLOC(I)=NOL
    [M:AMK2]SAIAFF(I) = 2
    [M:AMK2]OPTSAI(I) = "*"
    [M:AMK2]OPTFOR(I) = ""
    [M:AMK2]OPTLNG(I) = 0
   Endif
  Next I
 Endif
 Affzo [AMK2]SAIAFF,OPTSAI
Endif
[M]OTYPBLOC(NOL-1) = [M]TYPBLOC(NOL-1)
End

Subprog AVANT_NBBLOC
GSTATUS = status

# Issue X3-61517 - 2017-11-15 by CCC : manage removing of table bloc in "AVANT_NBBLOC" as old informations are still known
# Deletion of a table bloc (not the last bloc)
If status=65 & nolign<[M:AMK1]NBBLOC
    For I=0 To [M:AMK2]NBLIG-1
        If [M:AMK2]NUMBLOC(I)=nolign
            If [M]TYPBLOC(nolign)=1
                # new bloc is a table
                [M:AMK2]DIME(I) = [M]NBLIGT(nolign)
                [M:AMK2]MODE(I) = ([M]SAIAFF(I)<3)     # =1 if not hidden
            Else
                # new bloc is not a table
                If [M]OTYPBLOC(nolign-1)=1
                    [M:AMK2]DIME(I) = 1     # the bloc was a table => remove old dimension
                    [M:AMK2]MODE(I) = 0
                Endif
            Endif
        Endif
    Next I
    Affzo [AMK2]DIME,MODE
Endif
End

Subprog AS_TYPBLOC(VALEUR)
Variable Integer VALEUR
GMENLOC(3) = 1 : # Photo supprimé
End

Subprog AM_TYPBLOC(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
Case VALEUR
 When 1 : # Tableau
  [M]OPTION(NOL) = "KARID"
  [M]LNGLIB(NOL) = 0
  [M]NBLIGT(NOL) = 10
  [M]BLOCTYPT(NOL)=1
  If dim([M]BLOCVIEW)>0 : [M]BLOCVIEW(NOL)="" : Endif
 When 2 : # Liste
  [M]OPTION(NOL) = ""
  [M]BASPAG(NOL) = ""
  If dim([M]BLOCVIEW)>0 : [M]BLOCVIEW(NOL)="" : Endif
  [M]NBLIGT(NOL) = 0
  [M]LNGLIB(NOL) = 20
  [M]BLOCTYPT(NOL)=0
 When 3,4,5,10 : # Photo, Texte, Invisible
  [M]OPTION(NOL) = ""
  [M]BASPAG(NOL) = ""
  If dim([M]BLOCVIEW)>0 : [M]BLOCVIEW(NOL)="" : Endif
  [M]NBLIGT(NOL) = 0
  [M]LNGLIB(NOL) = 0
  [M]BLOCTYPT(NOL)=0
 When 6,8,11 : # Flash, Bureautique, Editeur html
  [M]OPTION(NOL) = ""
  [M]BASPAG(NOL) = ""
  [M]NBLIGT(NOL) = 0
  [M]BLOCTYPT(NOL)=0
 When 7,9 : # Browser
  [M]OPTION(NOL) = ""
  [M]NBLIGT(NOL) = 0
  [M]BLOCTYPT(NOL) = 0
  If dim([M]BLOCVIEW)>0 : [M]BLOCVIEW(NOL)="" : Endif
Endcase
[M]TYPBLOC(NOL) = VALEUR
Affzo OPTION(NOL),LNGLIB(NOL),BASPAG(NOL),NBLIGT(NOL),BLOCTYPT(NOL)
End

Subprog AS_RANG(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 If nolign=1 : VALEUR = 5
 Else        : VALEUR = [M]RANG(nolign-2)+5
 Endif
Endif
End

Subprog C_RANG(VALEUR)
Variable Decimal VALEUR
Local Integer OK
Gosub SETNOL
If [M]TYPBLOC(NOL)=1 & mod(VALEUR,5)<>0
 GMESSAGE = mess(146,123,1) : # Le rang doit être multiple de 5
 mkstat = 2 : End
Endif
If GADONIX=2 & GSOPHIA & mod(VALEUR,5)<>0 :#X3PLAT-2092
   GMESSAGE = mess(330,123,1) : # Le rang doit être multiple de 5 sur les blocs standards
   Call AVERTIR(GMESSAGE,OK) From GESECRAN
   If OK<>2 : mkstat = 2 : Else: Raz GMESSAGE : Endif
Endif
End

Subprog C_ACTBLOC(VALEUR)
Variable Char     VALEUR
Read [ACV]CODACT = VALEUR
If !fstat
 Local Integer I
 I = [F:ACV]DIME
 Gosub LIMITE
Endif
End

Subprog AS_NBLIGT(VALEUR)
Variable Decimal VALEUR
If [M]TYPBLOC(nolign-1)<>1
 VALEUR = 0 : mkstat=1 : End
Else
 If [M]ACTBLOC(nolign-1)<>""
  Read [ACV]CODACT = [M]ACTBLOC(nolign-1)
  If !fstat & [F:ACV]DIME<>0
   mkstat = 1 : End
  Endif
 Endif
Endif
End

Subprog C_NBLIGT(VALEUR)
Variable Decimal VALEUR
Local Integer I
I = VALEUR
Gosub LIMITE
End

$LIMITE
Local Shortint LIMITE , ERR
Onerrgo ERRLIM
LIMITE = I
Onerrgo
If ERR
 Call ERREUR(mess(135,141,1)) From GESECRAN : # Valeur hors limite
 mkstat = 1
Endif
Return

$ERRLIM
ERR = errn
Resume

Subprog AS_OPTION(VALEUR)
Variable Char    VALEUR
If [M]TYPBLOC(nolign-1)<>1
 VALEUR = "" : mkstat=1
Endif
End

Subprog C_OPTION(VALEUR)
Variable Char    VALEUR
Local Integer I, K
If VALEUR="" :  End  : Endif
Gosub DEFOPT_TAB From SELAMK
VALEUR = toupper(VALEUR)
Raz K
For I=1 To len(VALEUR)
 If instr(1,"123456789",mid$(VALEUR,I,1))
  K += 1
 Endif
 If K>1
  GMESSAGE = mess(99,123,1) : # Option incorrecte
  mkstat=2 : Break
 Endif
 If !instr(1,sum(TEX(1..NBTEX))+"123456789",mid$(VALEUR,I,1))
  GMESSAGE = mid$(VALEUR,I,1)-mess(99,123,1) : # Option incorrecte
  mkstat=2 : Break
 Endif
Next I
End

Subprog C_DETBLC(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0 & VALEUR<=[M]NBBLOC & [M]TYPBLOC(VALEUR-1)<>1
 GMESSAGE = mess(27,176,1) : # Bloc de type liste
 mkstat = 2 : End
Endif
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

Subprog C_FICREF(VALEUR)
Variable Char     VALEUR
Call UNICITE(VALEUR,[M]FICREF) From OBJDIV
End

Subprog AS_POSBLOC(VALEUR)
Variable Decimal VALEUR
Local Decimal VALPREV
Local Integer I
If [M]TYPBLOC(nolign-1)=5 | [M]TYPBLOC(nolign-1)=10
 mkstat = 1
Elsif VALEUR=0
 If nolign=1
  VALEUR = 1.1
 Else
  For I=nolign-2 To 0 Step -1
    VALPREV=[M]POSBLOC(I)
    If VALPREV<>0 : Break 1 : Endif
  Next I
#  VALEUR = int([M]POSBLOC(nolign-2))+1.1
  VALEUR = int(VALPREV)+1.1
 Endif
Endif
End

Subprog C_POSBLOC(VALEUR)
Variable Decimal VALEUR
If VALEUR<1
 VALEUR = 1
Endif
If VALEUR=int(VALEUR)
 VALEUR = VALEUR+0.1
Endif
End

Subprog AS_COLBLOC(VALEUR)
Variable Decimal VALEUR
If [M]TYPBLOC(nolign-1)=5 | [M]TYPBLOC(nolign-1)=10
 mkstat = 1
Elsif VALEUR=0
 VALEUR = 1
Endif
End

Subprog C_COLBLOC(VALEUR)
Variable Decimal VALEUR
If VALEUR+10*([M]POSBLOC(nolign-1)-int([M]POSBLOC(nolign-1)))>10
 GMESSAGE = "Pas plus de 10 colonnes"
 mkstat = 2 : End
Endif
End

Subprog AS_LINBLOC(VALEUR)
Variable Decimal VALEUR
If [M]TYPBLOC(nolign-1)=5 | [M]TYPBLOC(nolign-1)=10
 mkstat = 1
Elsif VALEUR=0
 VALEUR = 1
Endif
End

Subprog C_LINBLOC(VALEUR)
Variable Decimal VALEUR
If VALEUR+int([M]POSBLOC(nolign-1))>10
 GMESSAGE = "Pas plus de 10 lignes"
 mkstat = 2 : End
Endif
End

Subprog AS_HTBLOC(VALEUR)
Variable Decimal VALEUR
If [M]TYPBLOC(nolign-1)<>1
 mkstat = 1 : End
Endif
End

Subprog AS_LGBLOC(VALEUR)
Variable Decimal VALEUR
If [M]TYPBLOC(nolign-1)<>1
 mkstat = 1 : End
Endif
End

Subprog AS_LNGLIB(VALEUR)
Variable Decimal VALEUR
End

Subprog AM_TYPMSK(VALEUR)
Value Integer VALEUR
If find(VALEUR,3,4)
 Effzo [AMK1]NBRLIG,NBRCOL
 Grizo [AMK1]NBRLIG,NBRCOL
Else
 Actzo [AMK1]NBRLIG,NBRCOL
Endif
End

Subprog AS_NBRLIG(VALEUR)
Variable Decimal VALEUR
Local Char    PARAM(10)
Local Integer RES , COL , LIG , BRW
Case [M]TYPMSK
 When 1 : # Onglet
  If VALEUR=0
   Call PARAM("","ECRRESOL",PARAM) From ADOVAL
   RES = val(PARAM)
   Call RESOLUTION(RES,COL,LIG,BRW) From GLOBVAR
   VALEUR = LIG-3 : # 25
  Endif
 When 3,4 : # Plein écran
  mkstat = 1
 When 5 : # Entête
  If VALEUR=0 : VALEUR = 2 : Endif
 When 6 : # VT
  If VALEUR=0 : VALEUR = 7 : Endif
 When Default : # Boîte de dialogue
  If VALEUR=0
   Call PARAM("","ECRRESOL",PARAM) From ADOVAL
   RES = val(PARAM)
   Call RESOLUTION(RES,COL,LIG,BRW) From GLOBVAR
   VALEUR = LIG : # 28
  Endif
Endcase
End

Subprog AS_NBRCOL(VALEUR)
Variable Decimal VALEUR
Local Char    PARAM(10)
Local Integer RES , COL , LIG , BRW
Case [M]TYPMSK
 When 3,4 : # Plein écran
  mkstat = 1
 When 6 : # VT
  If VALEUR=0 : VALEUR = 20 : Endif
 When Default : # Entête, onglet, boîte de dialogue
  If VALEUR=0
   Call PARAM("","ECRRESOL",PARAM) From ADOVAL
   RES = val(PARAM)
   Call RESOLUTION(RES,COL,LIG,BRW) From GLOBVAR
   VALEUR = BRW : # 74 ou 88
  Endif
Endcase
End

Subprog C_NBRLIG(VALEUR)
Variable Decimal VALEUR
End

Subprog C_NBRCOL(VALEUR)
Variable Decimal VALEUR
End

Subprog IB_BLOCTYPT
Gosub SETNOL
If [M]BLOCTYPT(NOL)<2
  GBOUT2=""
Endif
End

Subprog AV_BLOCTYPT(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If [M]TYPBLOC(NOL)<>1
  mkstat=1
Endif
End

Subprog AV_BLOCVIEW(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M]TYPBLOC(NOL)<>6
  mkstat=1
Endif
End

Subprog IB_NBBLOC
Gosub SETNOL
If [M]TYPBLOC(NOL)<>8
  GBOUT2=""
Endif
If [M]TYPBLOC(NOL)<>7
  GBOUT3=""
Endif
End

