#<AdxTL>@(#)7.0.0.0 $Revision$
## Sous-Programmes comptables syracusés appelés par plusieurs traitements

#################################################################
#   Check the dimension                                        ##
#################################################################
Subprog CONTCCE(VALEUR,LED,DIE,FCY,DAT,ACC,SOCIETE,TYP,COLEXP,MESSAGE,OK)
Variable Char     VALEUR
Value Char        LED()
Value Char        DIE()
Value Char        FCY()
Value Date        DAT
Value Char        ACC()
Value Char        SOCIETE
Value Char        TYP
Value Instance    COLEXP Using OBJECT
Variable Char     MESSAGE
Variable Integer  OK

OK = 1

## Si pas de compte, inutile d'aller plus loin
If ACC="" : End : Endif

Local File COMPANY    [CPY]
Local File GTYPACCENT [GTE]
Local File CACCE      [CCE]
Local File CAAUZ      [CAZ]
Local File GACCOUNT   [GAC]
Local File GLED       [LED]
Local File CACCE      [CCE2]

Local Integer I,J,K : Raz I,J,K
Local Integer SUIVI
Local Integer VU
Local Integer AXI
Local Char    BID(GLONCCE)
Local Integer FLGPER : Raz FLGPER # Flag des pièces d'à-nouveau (permet d'inhiber les contrôles analytiques)

Call LEC_CPY(SOCIETE) From CPTLEC

If VALEUR<>""
 Call LEC_CCE(VALEUR,DIE) From CPTLEC
 If fstat<>[V]CST_AOK
  ## Section inexistante
  MESSAGE = mess(35,106,1)
  OK = 0 : End
 Endif
 If [F:CCE]IPT<>2
  MESSAGE = VALEUR-mess(24,106,1) : # Section non imputable
  OK = 0 : End
 Endif
Endif

#--- Contrôle exclusivement réservé aux pièces d'à-nouveau (inhiber les contrôles de section)
If TYP<>""
 Call LEC_GTE_LEG([F:CPY]LEG,TYP) From CPTLEC
 If [F:GTE]PER=2 : FLGPER=1 : Endif
Endif


If LED<>""
 Call LEC_LED(LED) From CPTLEC
 AXI = find(DIE,[F:LED]DIE(0..[F:LED]DIENBR-1))
 If fstat<>[V]CST_AOK or !AXI : End : Endif

 Call LEC_GAC([L]ACC,[F:LED]COA) From CPTLEC

 #--- Axe est il suivi...
 SUIVI = find([L]DIE,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))

 #--- Contrôle que l'axe est obligatoire
 VU = find([L]DIE,[F:CPY]DIE(0..dim([F:CPY]DIE)-1))
 If VALEUR="" & SUIVI & VU & [F:CPY]OBYDIE(VU-1) = 2 & !FLGPER
  MESSAGE = [L]ACC-"("+[F:LED]COA+")"-mess(46,106,1)-DIE : # Section obligatoire/axe
  OK = 0 : End
 Endif

 #--- Contrôle qu'au moins un axe est renseigné (si le compte est suivi)
 If VALEUR="" & [F:LED]DIEDACOBY=2 & [F:GAC]DACDIENBR>0 & !FLGPER
  OK = 0
  For I=AXI+1 To [F:LED]DIENBR
   If find(evalue("[F:LED]DIE("+num$(I-1)+")"),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
    OK = 1 : Break
   Endif
  Next I
  If !OK : # C'est le dernier axe saisissable...
   For I=1 To AXI-1
    For J=1 To maxtab(COLEXP.DIMCEN)
     If COLEXP.DIMCEN(J).ASTALIN<>[V]CST_ADEL & COLEXP.DIMCEN(J).ASTALIN<>[V]CST_ANEWDEL
&     & evalue("[F:LED]DIE("+num$(I-1)+")")= COLEXP.DIMCEN(J).DIE & COLEXP.DIMCEN(J).CCE<>AVOID.ACHAR
      OK = 1 : Break 2
     Endif
    Next
   Next
   If !OK
    # Au moins un axe doit être renseigné
    MESSAGE = [L]ACC-"("+[F:LED]COA+")"-mess(98,106,1)
    OK = 0 : End
   Endif
  Endif
 Endif

 If VALEUR="" : End : Endif

 #--- Contrôle code interdiction compte/section
 If [F:GAC]AUZ<>"" & [F:CCE]AUZ<>""
  Look [CAZ]CAZ0 = 2 ; [F:GAC]AUZ ; [F:CCE]AUZ
  If fstat=[V]CST_AOK
   MESSAGE = VALEUR-mess(27,106,1)-[L]ACC-"("+[F:LED]COA+")" : # Interdit avec le compte
   OK = 0 : End
  Endif
 Endif
Endif

If VALEUR="" : End : Endif

#--- Section compatible avec le site/société.
If [L]FCY<>"" # Le site n'est pas obligatoire (BUO-Gestion différente)
 Call VERIF([F:CCE]FCY,[L]FCY,VALEUR,MESSAGE,OK)
 If !OK : End : Endif
Endif

#--- Code d'accès... Droit d'execution.
Call CONTEXE([F:CCE]ACS,COLEXP.ACTX.USER,MESSAGE,OK)
If !OK : MESSAGE = VALEUR-MESSAGE : End : Endif

#--- Contrôle de validité de dates.
Call CTLVLYDAT([L]DAT,[F:CCE]VLYSTR,[F:CCE]VLYEND,MESSAGE,OK)
If !OK : MESSAGE = VALEUR-MESSAGE : End : Endif

#--- Contrôle code interdiction section/section
If [F:CCE]AUZ<>""
 For J=1 To maxtab(COLEXP.DIMCEN)
 If COLEXP.DIMCEN(J).ASTALIN<>[V]CST_ADEL & COLEXP.DIMCEN(J).ASTALIN<>[V]CST_ANEWDEL & [L]DIE<>COLEXP.DIMCEN(J).DIE
  If COLEXP.DIMCEN(J).CCE<>""
    Read [CCE2]CCE0 = COLEXP.DIMCEN(J).DIE;COLEXP.DIMCEN(J).CCE
    If fstat=[V]CST_AOK & [F:CCE2]AUZ<>""
     Look [CAZ]CAZ0 = 1 ; [F:CCE]AUZ ; [F:CCE2]AUZ
     If fstat=[V]CST_AOK
      MESSAGE = VALEUR-mess(26,106,1)-[F:CCE2]CCE : # Interdit avec la section
      OK = 0 : Break
     Endif
    Endif
   Endif
  Endif
 Next J
Endif
End


#################################################################
## Check the validity of a date                                ##
#################################################################
Subprog CTLVLYDAT(DAT,DATDEB,DATFIN,MESSAGE,OK)
Value    Date     DAT
Value    Date     DATDEB
Value    Date     DATFIN
Variable Char     MESSAGE
Variable Integer  OK
OK = 1
If !(DAT>=DATDEB & (DATFIN=AVOID.ADATE | DAT<=DATFIN))
 MESSAGE = mess(13,104,1) : # Hors limite des dates de validité
 OK = 0
Endif
End

#################################################################
## Check the execution rights                                  ##
#################################################################
Subprog CONTEXE(ACCES,USR,MESSAGE,OK)
Value    Char    ACCES
Value    Char    USR
Variable Char    MESSAGE
Variable Integer OK
OK = 1
# GUSRACS non encore gérée
#If ACCES="" or GUSRACS=2 : End : Endif
If ACCES="" : End : Endif
Local File ACCES [ACC]
Read [ACC]CODACC = USR;ACCES
If fstat<>[V]CST_AOK | [F:ACC]EXEC<>2
 # Vous n'avez pas les droits d'exécution
 MESSAGE = mess(7,104,1) : OK = 0
Endif

End

#################################################################
##  Check that a site is correct compared to                   ##
##  a site/company/group of sites                              ##
#################################################################
Subprog VERIF(ZONE,SITE,VALEUR,MESSAGE,OK)
Value    Char    ZONE
Value    Char    SITE
Value    Char    VALEUR
Variable Char    MESSAGE
Variable Integer OK

OK = 1
If ZONE="" : End  : Endif

Local File COMPANY  [CPY]
Local File FACILITY [FCY]
Local File FACGROUP [FGR]

Call LEC_FCY(ZONE) From CPTLEC
If fstat=[V]CST_AOK
 If ZONE<>SITE
  MESSAGE = VALEUR-":"-mess(64,133,1)-ZONE : # réservé au site
  OK = 0
 Endif
Else
 Call LEC_CPY(ZONE) From CPTLEC
 If [F:CPY]CPYLEGFLG=2
  Call LEC_FCY(SITE) From CPTLEC
  If [F:FCY]LEGCPY<>ZONE
   MESSAGE = VALEUR-":"-mess(65,133,1)-ZONE : # réservé à la société
   OK = 0
  Endif
 Else
  Read [FGR]FGR0 = ZONE;SITE
  If fstat<>[V]CST_AOK
   MESSAGE = VALEUR-":"-mess(66,133,1)-ZONE : # réservé au groupe de site
   OK = 0
  Endif
 Endif
Endif

End


###################################################################
##  Check the creation date of a document over a range of dates  ##
##  of one module                                                ##
###################################################################
Subprog CTLDATMOD(MODULE,DAT,LCPY,DATSTR,DATEND,MESSAGE,OK)
Value    Date    DAT
Value    Integer MODULE
Value    Char    LCPY
Value    Date    DATSTR
Value    Date    DATEND
Variable Char    MESSAGE
Variable Integer OK

Local Char MODULESTR(15)

OK = 1
MESSAGE=""

# Get the values of the financials or AP/AR accounting parameters. It depends on the module
If MODULE = 2 #Comptabilité
 MODULESTR = mess(2,14,1)
Elsif MODULE = 3 #Tiers
 MODULESTR = mess(3,14,1)
Endif

# Both dates must be set otherwise no check is made
If (DATSTR<>AVOID.ADATE & DAT<DATSTR) | (DATEND<>AVOID.ADATE & DAT>DATEND)
  # Date Interdite pour le module MODULESTR
 MESSAGE = mess(140,104,1)- MODULESTR
 OK = 0 : End
Endif
End

#############################################################################
##  Check the authorizations of the business partner with the company      ##
#############################################################################
Subprog CONTBPRCPY(VALEUR,SIT,PLAN,COLL,BPRTYP,MESSAGE,OK)
Value Char       VALEUR
Value Char       SIT
Value Char       PLAN
Value Char       COLL
Value Char       BPRTYP
Variable Char    MESSAGE
Variable Integer OK

Local Char    SOC(GLONCPY)

#If GCOMPTA=3 : End : Endif

Local File COMPANY    [CPY]
Local File FACILITY   [FCY]
Local File ACTIV      [ACV]
Local File BPCUSTOMER [BPC]
Local File BPARTNER   [BPR]
Local File GACCOUNT   [GAC]
If func ASYRFNC.ACTIV("MUL") >0 : # Issue 56229 - 2017-11-15 by MWA
  Local File BPEXCEPT   [BPE]
Endif
OK = 1

Read[CPY]CPY0=SIT
If fstat=[V]CST_AOK
 SOC = [F:CPY]CPY
Else
 Read[FCY]FCY0=SIT
 If fstat=[V]CST_AOK
  SOC = [F:FCY]LEGCPY
 Endif
Endif

If SOC<>""
 # Issue 56229 - 2017-11-15 by MWA
 # Read[ACV]CODACT="MUL"
 # If fstat=[V]CST_AOK & [F:ACV]FLACT=2
 If func ASYRFNC.ACTIV("MUL") >0 :
  Read[BPE]BPE0=VALEUR;SOC
  If fstat=[V]CST_AOK
   If [F:BPE]ACEAUZ<>2
    # Tiers non autorisé pour cette société
    MESSAGE=mess(29,104,1) : OK=0
   Endif
   End
  Endif
 Endif
Endif
If COLL<>"" & BPRTYP<>"F"
 If [L]PLAN=""
  Call LECMAINPLAN(1,SOC,PLAN) From FINLIBINI
 Endif
 Read[GAC]GAC0=PLAN;COLL
 Read[BPR]BPR0=VALEUR
 Read[BPC]BPC0=VALEUR
 If fstat=[V]CST_AOK & [F:BPC]BPCTYP=4 & [F:GAC]AUZBPR(0)=2
  OK = 0
  If BPRTYP<>"C"
   If [F:BPR]BPSFLG=2 & [F:GAC]AUZBPR(1)=2 : OK = 1 : Endif
   If [F:BPR]BPTFLG=2 & [F:GAC]AUZBPR(2)=2 : OK = 1 : Endif
   If [F:BPR]FCTFLG=2 & [F:GAC]AUZBPR(3)=2 : OK = 1 : Endif
   If [F:BPR]REPFLG=2 & [F:GAC]AUZBPR(4)=2 : OK = 1 : Endif
   If [F:BPR]BPRACC=2 & [F:GAC]AUZBPR(5)=2 : OK = 1 : Endif
  Endif
  If OK=0
   # Prospect non autorisé
   MESSAGE = mess(30,104,1)
  Endif
 Endif
Endif

End

##############################################################################
##  Check the currency capture with the euro and the validity date          ##
##############################################################################
Subprog CONTDEV(DEVISE,DAT,MESSAGE,OK)
Value Char       DEVISE
Value Date       DAT
Variable Char    MESSAGE
Variable Integer OK

Local Char    EURO(GLONCUR)
Local Integer EURDAC
Local Date    EURDAT

Local File TABCUR  [TCU]
Local File AUTILIS [AUS]

OK = 1

Read [TCU]TCU0=DEVISE
If fstat<>[V]CST_AOK
 MESSAGE = DEVISE-":"-mess(151,105,1) # Devise inexistante
 OK=0 : End
Endif

Look [AUS]CODUSR=GACTX.USER
If fstat<>[V]CST_AOK
 MESSAGE = GACTX.USER-":"-mess(1,948,1) # Utilisateur incorrect
 OK=0 : End
Endif

# Date de validité
If [F:TCU]CURENDDAT<>[0/0/0] & DAT>=[F:TCU]CURENDDAT
 # Devise non valide à partir du
 MESSAGE = DEVISE-":"-mess(96,107,1)-num$([F:TCU]CURENDDAT) : # format$ avec GFMDAT4 non disponible
 OK = 0 : End
Endif

# Contrôle utilisateur
EURO = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,"","EURO")
If DEVISE = EURO : End : Endif
EURDAT = fmet GACTX.APARAM.AGETUSERVALDATE("DATDEBCTR")
EURDAC = fmet GACTX.APARAM.AGETUSERVALNUM("SAIDEVISE")


If EURDAT<>[0/0/0] & datesyst>EURDAT
 If [F:TCU]EURFLG=2 & DEVISE<>EURO
  If EURDAC<>2
   OK = 0   : # An error
  Else
  # A warning is displayed in some functions GESGAS GESGAF GESBIC GESBIS GESPAY GESCMM GESLOT GESPIH GESFAS
  # GESBUP GESFRM GESPAB GESSQH GESSOH GESSOR GESSDH GESSIH GESPPD GESPSH GESPOI GESPOH GESPOC SUBHLN* BUDDET*
  # BUDNAT* BUDSEC* PAYPRO*
   OK = 2
  Endif
  MESSAGE = mess(94,107,1) : # Saisie en devise in interdite
  End
 Endif
Endif

End

