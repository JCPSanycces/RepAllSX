##################################################

Subprog PATCH_X3(APPLI)
Value Char APPLI

If filinfo(filpath("FIL","AYTELTFLD","fde",APPLI),0) <0 or func AFNC.ACTIVDOS(APPLI,"AYT")<1
 End
Endif

Call MAJAYGAXX(APPLI)
Call MAJAYSAXX(APPLI)
Call MAJAYFAXX(APPLI)
Call MAJAYDAXX(APPLI)
Call MAJAYBAXX(APPLI)
Call MAJAYWAXX(APPLI)
Call MAJAYLAXX(APPLI)
Call MAJAYIAXX(APPLI)
Call MAJAYEAXX(APPLI)
Call MAJAYAAXX(APPLI)
Call MAJAYMAXX(APPLI)
Call MAJAYCAXX(APPLI)
Call MAJAYFAYX(APPLI)
Call MAJAFCXTD(APPLI)
End
##################################################

Subprog PATCH(APPLI)
Value Char APPLI

If filinfo(filpath("FIL","AYTELTFLD","fde",APPLI),0) <0 or func AFNC.ACTIVDOS(APPLI,"AYT")<1
 End
Endif

Call MAJAYGAXX(APPLI)
Call MAJAYSAXX(APPLI)
Call MAJAYFAXX(APPLI)
Call MAJAYDAXX(APPLI)
Call MAJAYBAXX(APPLI)
Call MAJAYWAXX(APPLI)
Call MAJAYLAXX(APPLI)
Call MAJAYIAXX(APPLI)
Call MAJAYEAXX(APPLI)
Call MAJAYAAXX(APPLI)
Call MAJAYMAXX(APPLI)
Call MAJAYCAXX(APPLI)
Call MAJAYFAYX(APPLI)
Call MAJAFCXTD(APPLI)
End 

##################################################
## fonction GESAYX invicible
##################################################
Subprog MAJAFCXTD(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".AFONCTION"      [AFC]

Call ECR_TRACE(mess(81,125,1)-"AFONCTION- fonction GESAYX :"-time$,0) From GESECRAN
Trbegin [AFC]
Read [AFC]CODINT = "GESAYX"
If !fstat
 Raz [F:AFC]MENU
 Raz [F:AFC]RANG
 Rewrite [F:AFC]
 If fstat
  Call ERREUR("AFC",2) From DOSDIC
 Endif
Endif
Commit

Close Local File [AFC]
End

End

##################################################
## Recup  champ spe dans AYF
##################################################
Subprog MAJAYFAYX(DOSSIER)
Value Char DOSSIER
#CHECK UNUSED_BEGIN
Local File =DOSSIER+".AYTELTFLD"      [AYF]
Local File =DOSSIER+".AYTELTSPE"      [AYX]
Local File =DOSSIER+".ATEXTRA"        [AXX]

Call ECR_TRACE(mess(81,125,1)-"AYTELTFLD-AYTELTSPE :"-time$,0) From GESECRAN
Trbegin [AYF]
 If dim([F:AYF]ENASPE) > 0
  Update [AYF]  Where  [F:AYF]ENASPE = 0 With [F:AYF]ENASPE = 1
  For [AYX]AYX0
   Read [F:AYF]AYF0 =[F:AYX]FCYCOD;[F:AYX]SPXCOD
   If fstat
    Raz [F:AYF]
    [F:AYF]       = [F:AYX]
    [F:AYF]FIECOD = [F:AYX]SPXCOD
    [F:AYF]ENASPE = 2
    Call MAJTEXTRA(func AFNC.TEXTE([F:AYX]DES),"AYTELTFLD","INTIT",[F:AYX]FCYCOD,[F:AYX]SPXCOD)
    Write [F:AYF]
    If fstat
     Call ERREUR("AYF",1) From DOSDIC
    Endif
   Else
    If [F:AYF]ENASPE = 1
     Call ECR_TRACE([F:AYX]FCYCOD-"-"-[F:AYX]SPXCOD-" : Champ deja existant dans le dico des champs normaux",1) From GESECRAN
    Endif
   Endif
  Next
 Endif
Commit

Close Local File [AYF],[AXX],[AYX]
#CHECK UNUSED_END
End


##################################################
## Recup textes Liste de valeurs  AYC
##################################################
Subprog MAJAYCAXX(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".AYTMEN"      [AYC]
Local File =DOSSIER+".ATEXTRA"     [AXX]

If dim([F:AYC]DES)>0 
 Call ECR_TRACE(mess(81,125,1)-"AYTMEN :"-time$,0) From GESECRAN
 Trbegin [AXX]
  For [AYC]AYC0
   If [F:AYC]DES>0
    Call MAJTEXTRA(func AFNC.TEXTE([F:AYC]DES),"AYTMEN","INTIT",[F:AYC]FCYCOD,[F:AYC]MENCOD)
   Endif
  Next
 Commit
Endif
Close Local File [AYC],[AXX]
End

