##################################################
## Recup textes interface AYI
##################################################
Subprog MAJAYIAXX(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".AYTINT"         [AYI]
Local File =DOSSIER+".ATEXTRA"        [AXX]
If filinfo(filpath("FIL","AWEBSERVIC","fde",DOSSIER),0)>0
 Local File =DOSSIER+".AWEBSERVIC"     [AWE]
Endif

If dim([F:AYI]DES)>0
 Call ECR_TRACE(mess(81,125,1)-"AYTINT :"-time$,0) From GESECRAN
 Trbegin [AXX]
  For [AYI]AYI0
   If [F:AYI]DES>0
    Call MAJTEXTRA(func AFNC.TEXTE([F:AYI]DES),"AYTINT","INTIT",[F:AYI]FCYCOD,[F:AYI]INTCOD)
   Endif
   If find([F:AYI]TYP,2,20) & dim([F:AWE]PRG)>0
    Read [AWE]AWE1 = [F:AYI]WEBSRCCOD
    If !fstat & [F:AYI]PRG="" & [F:AYI]SUBPRG=""
     [F:AYI]PRG    = [F:AWE]PRG
     [F:AYI]SUBPRG = [F:AWE]SUBPRG
     Rewrite [F:AYI]
    Endif
   Endif
  Next
 Commit
Endif

Close Local File [AYI],[AXX]
If filinfo(filpath("FIL","AWEBSERVIC","fde",DOSSIER),0)>0
 Close Local File[AWE]
Endif
End

