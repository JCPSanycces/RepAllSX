#<AdxTL>@(#)0.0.0.0 $Revision$Class Path
# Supervisor
## ATY-ATYPE ## EPH
# 2018-11-09 07:14:14 192

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,MSGCOD,MSGREL,MSGFILNOR,PATHID,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Integer AVALUE
Value Char MSGCOD
Value Char MSGREL
Value Char MSGFILNOR
Value Integer PATHID
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File EDIXMLFILP [EXFP]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".EDIXMLFILP" [EXFP]
Endif

Default File [F:EXFP]
Read [F:EXFP]EXFP0 = [L]MSGCOD;[L]MSGREL;[L]MSGFILNOR;[L]PATHID
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]MSGCOD)+"~"+num$([L]MSGREL)+"~"+num$([L]MSGFILNOR)+"~"+num$([L]PATHID)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]MSGCOD)+"~"+num$([L]MSGREL)+"~"+num$([L]MSGFILNOR)+"~"+num$([L]PATHID)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


