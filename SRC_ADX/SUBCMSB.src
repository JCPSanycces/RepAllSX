Local Char SZTYP_ACTION

  SZTYP_ACTION = "READ"
  Gosub CHAMPS
Return

##########################################################################################################
# Traitement de gestion des champs
$CHAMPS
Local Integer INBFIENAM
Local Char SZTEXTE(100)
Local Char SZCHAMPS(50)
Local Integer ITROUVE
Local Integer IVISIBLE
Local Integer IPOSITION
Local Integer IMODE
Local Integer ISAISIE
Local Integer IAFFICHE

  INBFIENAM = 0
  If SZTYP_ACTION = "ENREG" Then
    Raz [F:HTV]FIENAM
    Raz [F:HTV]FIEVAL
  Endif
  #Ecran SRE0
  #[SRE0]SCO
  #---------------------#
  # Chrono client
  SZREFERENCE = "[SRE0]SRENUMBPC"
  If SZTYP_ACTION = "INIT" Then
    [M:CMS2]NUMBPCCOD= 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMS2]NUMBPCCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMS2]NUMBPCCOD = 1
    Else
      [M:CMS2]NUMBPCCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[SRE0]SREDOO
  #[SRE0]SREDOOX
  #---------------------#
  # Donneur d'ordre
  SZREFERENCE = "[SRE0]SREDOO"
  If SZTYP_ACTION = "INIT" Then
    [M:CMS2]DOOCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMS2]DOOCOD)
    INBFIENAM += 1
    If [M:CMS2]DOOCOD > 2 Then
      [F:HTV]FIENAM(INBFIENAM) = "[SRE0]SREDOOX"
      [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMS2]DOOCOD)
      INBFIENAM += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMS2]DOOCOD = 1
    Else
      [M:CMS2]DOOCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[SRE0]ICOSAT
  #---------------------#
  # Icône Etat
  SZREFERENCE = "[SRE0]ICOSAT"
  If SZTYP_ACTION = "INIT"
    [M:CMS2]SATCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMS2]SATCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMS2]SATCOD = 1
    Else
      [M:CMS2]SATCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[SRE0]ICOGRALEV
  #---------------------#
  # Icône Niveau de gravité
  SZREFERENCE = "[SRE0]ICOGRALEV"
  If SZTYP_ACTION = "INIT" Then
    [M:CMS2]SATCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMS2]GRALEVCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMS2]GRALEVCOD = 1
    Else
      [M:CMS2]GRALEVCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[SRE1]TSDCOD
  #---------------------#
  # Familles statistiques
  SZREFERENCE = "[SRE1]TSDCOD"
  If SZTYP_ACTION = "INIT" Then
    [M:CMS2]SRETSDCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMS2]SRETSDCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMS2]SRETSDCOD = 1
    Else
      [M:CMS2]SRETSDCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #Ecran SRE7
  #SRE7
  #Compétence
  #"[SRE7]PBL"
  #"[SRE7]PBLCLA"
  If SZTYP_ACTION = "ENREG" Then
    If [M:CMS1]TSREPBLFLG <> 2 Then
      [F:HTV]FIENAM(INBFIENAM) = "[SRE7]PBL"
      [F:HTV]FIEVAL(INBFIENAM) = "3"
      INBFIENAM += 1
      [F:HTV]FIENAM(INBFIENAM) = "[SRE7]PBLCLA"
      [F:HTV]FIEVAL(INBFIENAM) = "3"
