##########################################################################################################
# Traitement de gestion des blocs
$BLOCS
Local Integer INBBLOCINVI

  INBBLOCINVI = 0
  If SZTYP_ACTION = "ENREG" Then
    Raz [F:HTR]BLOCINVI
  Endif
  #Ecran SRE0
  #Ecran SRE1
  # Familles statistiques
  SZREFERENCE = "[SRE1]25"
  If SZTYP_ACTION = "ENREG" Then
    If [M:CMS2]SRETSDCOD > 2 Then
      [F:HTR]BLOCINVI(INBBLOCINVI) = SZREFERENCE
      INBBLOCINVI += 1
    Endif
  Endif
  #Gestion du parc
  SZREFERENCE = "[SRE7]5"
  If SZTYP_ACTION = "INIT" Then
    [M:CMS1]TSREMACFLG=2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMS1]TSREMACFLG <> 2 Then
      [F:HTR]BLOCINVI(INBBLOCINVI) = "[SRE7]5"
      INBBLOCINVI += 1
      [F:HTR]BLOCINVI(INBBLOCINVI) = "[SRE7]10"
      INBBLOCINVI += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]BLOCINVI)
    If ITROUVE = 0 Then
      [M:CMS1]TSREMACFLG = 2
    Else
      [M:CMS1]TSREMACFLG = 1
    Endif
  Endif
  #Gestion des composants parc
  SZREFERENCE = "[SRE7]15"
  If SZTYP_ACTION = "INIT" Then
    [M:CMS1]TSRECPNFLG = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMS1]TSRECPNFLG <> 2 Then
      [F:HTR]BLOCINVI(INBBLOCINVI) = SZREFERENCE
      INBBLOCINVI += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]BLOCINVI)
    If ITROUVE = 0 Then
      [M:CMS1]TSRECPNFLG = 2
    Else
      [M:CMS1]TSRECPNFLG = 1
    Endif
  Endif
  #Gestion des compétences
  SZREFERENCE = "[SRE7]20"
  If SZTYP_ACTION = "INIT" Then
    [M:CMS1]TSREPBLFLG = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMS1]TSRECPNFLG <> 2 Then
      [F:HTR]BLOCINVI(INBBLOCINVI) = SZREFERENCE
      INBBLOCINVI += 1
    Endif
  Elsif SZTYP_ACTION = "READ"
    ITROUVE = find(SZREFERENCE, [F:HTR]BLOCINVI)
    If ITROUVE = 0 Then
      [M:CMS1]TSREPBLFLG = 2
    Else
      [M:CMS1]TSREPBLFLG = 1
    Endif
  Endif
  #Horodatage
  SZREFERENCE = "[SRE2]20"
  If SZTYP_ACTION = "INIT" Then
    [M:CMS1]TSREHORFLG = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMS1]TSREHORFLG <> 2 Then
      [F:HTR]BLOCINVI(INBBLOCINVI) = SZREFERENCE
      INBBLOCINVI += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]BLOCINVI)
    If ITROUVE = 0 Then
      [M:CMS1]TSREHORFLG = 2
    Else
      [M:CMS1]TSREHORFLG = 1
    Endif
  Endif
  #Escalade
  SZREFERENCE = "[SRE2]25"
  If SZTYP_ACTION = "INIT" Then
    [M:CMS1]TSREESCFLG= 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMS1]TSREESCFLG <> 2 Then
      [F:HTR]BLOCINVI(INBBLOCINVI) = SZREFERENCE
      INBBLOCINVI += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]BLOCINVI)
    If ITROUVE = 0 Then
      [M:CMS1]TSREESCFLG = 2
    Else
      [M:CMS1]TSREESCFLG = 1
    Endif
  Endif
  #Eléments de facturation
  SZREFERENCE = "[SRE8]20"
  If SZTYP_ACTION = "ENREG" Then
    If [M:CMS4]INVDTACOD = 3 Then
      [F:HTR]BLOCINVI(INBBLOCINVI) = SZREFERENCE
      INBBLOCINVI += 1
    Endif
  Endif
  #SRE9
  #Gestion des consommations
  SZREFERENCE = "[SRE9]5"
  If SZTYP_ACTION = "INIT" Then
    [M:CMS1]TSREHDTFLG = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMS1]TSREHDTFLG <> 2 Then
      [F:HTR]BLOCINVI(INBBLOCINVI) = SZREFERENCE
      INBBLOCINVI += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]BLOCINVI)
    If ITROUVE = 0 Then
      [M:CMS1]TSREHDTFLG = 2
    Else
      [M:CMS1]TSREHDTFLG = 1
    Endif
  Endif
  #Sous totaux
  SZREFERENCE = "[SRE9]10"
  If SZTYP_ACTION = "INIT" Then
    [M:CMS3]SBBTOTFLG = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMS3]SBBTOTFLG <> 2 Then
      [F:HTR]BLOCINVI(INBBLOCINVI) = SZREFERENCE
      INBBLOCINVI += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]BLOCINVI)
    If ITROUVE = 0 Then
      [M:CMS3]SBBTOTFLG = 2
    Else
      [M:CMS3]SBBTOTFLG = 1
    Endif
  Endif
  #Totaux
  SZREFERENCE = "[SRE9]15"
  If SZTYP_ACTION = "INIT" Then
    [M:CMS3]HDTTOTFLG = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMS3]HDTTOTFLG <> 2 Then
      [F:HTR]BLOCINVI(INBBLOCINVI) = SZREFERENCE
      INBBLOCINVI += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]BLOCINVI)
    If ITROUVE = 0 Then
      [M:CMS3]HDTTOTFLG = 2
    Else
      [M:CMS3]HDTTOTFLG = 1
    Endif
  Endif
  #Totalisation s points
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 30/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    SZREFERENCE = "[SRE9]20"
    If SZTYP_ACTION = "INIT" Then
      [M:CMS1]TSREPITFLG = 2
    Elsif SZTYP_ACTION = "ENREG" Then
      If [M:CMS1]TSREPITFLG <> 2 Then
        [F:HTR]BLOCINVI(INBBLOCINVI) = SZREFERENCE
        INBBLOCINVI += 1
      Endif
    Elsif SZTYP_ACTION = "READ" Then
      ITROUVE = find(SZREFERENCE, [F:HTR]BLOCINVI)
      If ITROUVE = 0 Then
        [M:CMS1]TSREPITFLG = 2
      Else
        [M:CMS1]TSREPITFLG = 1
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Traitement de gestion des colonnes fixes en initialisation
$COLFIX_INIT
Local Char SZTYP_ACTION

  SZTYP_ACTION = "INIT"
  Gosub COLFIX
Return

##########################################################################################################
# Traitement de gestion des colonnes fixes lors de l'enregistrement
$COLFIX_ENREG
Local Char SZTYP_ACTION

  SZTYP_ACTION = "ENREG"
  Gosub COLFIX
Return

##########################################################################################################
# Traitement de gestion des colonnes fixes lors de la lecture
$COLFIX_READ
Local Char SZTYP_ACTION

  SZTYP_ACTION = "READ"
  Gosub COLFIX
Return

##########################################################################################################
# Traitement de gestion des colonnes fixes
$COLFIX
Local Integer ITROUVE
Local Integer INBTABLEAU
Local Char SZREFERENCE

  Raz SZREFERENCE
  INBTABLEAU = 0
  If SZTYP_ACTION = "ENREG" Then
    Raz [F:HTR]COLFIXNAM
    Raz [F:HTR]COLFIXVAL
    INBTABLEAU = 0
  Endif
  #SRE7
  SZREFERENCE = "[SRE7]NBMAC"
  If SZTYP_ACTION = "INIT" Then
    [M:CMS1]COLFIXMAC = 0
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMS1]COLFIXMAC <> 0 Then
      [F:HTR]COLFIXNAM(INBTABLEAU) = SZREFERENCE
      [F:HTR]COLFIXVAL(INBTABLEAU) = [M:CMS1]COLFIXMAC
      INBTABLEAU += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]COLFIXNAM)
    If ITROUVE = 0 Then
      [M:CMS1]COLFIXMAC = 0
    Else
      [M:CMS1]COLFIXMAC = [F:HTR]COLFIXVAL(ITROUVE-1)
    Endif
  Endif
  SZREFERENCE = "[SRE7]NBCPN"
  If ACTION = "INIT" Then
    [M:CMS1]COLFIXCPN= 0
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMS1]COLFIXCPN <> 0 Then
      [F:HTR]COLFIXNAM(INBTABLEAU) = SZREFERENCE
      [F:HTR]COLFIXVAL(INBTABLEAU) = [M:CMS1]COLFIXCPN
      INBTABLEAU += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]COLFIXNAM)
    If ITROUVE = 0 Then
      [M:CMS1]COLFIXCPN = 0
    Else
      [M:CMS1]COLFIXCPN = [F:HTR]COLFIXVAL(ITROUVE-1)
    Endif
  Endif
  #SRE9
  SZREFERENCE = "[SRE9]NBLIG"
  If SZTYP_ACTION = "INIT" Then
    [M:CMS1]COLFIXHDT = 0
  Endif
  If SZTYP_ACTION = "ENREG" Then
    If [M:CMS1]COLFIXHDT <> 0 Then
      [F:HTR]COLFIXNAM(INBTABLEAU) = SZREFERENCE
      [F:HTR]COLFIXVAL(INBTABLEAU) = COLFIXHDT
      INBTABLEAU += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]COLFIXNAM)
    If ITROUVE = 0 Then
      [M:CMS1]COLFIXHDT = 0
    Else
      [M:CMS1]COLFIXHDT = [F:HTR]COLFIXVAL(ITROUVE-1)
    Endif
  Endif
Return

