#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################################################
#   Programmes utilitaires pour la gestion des transactions des demandes de services  Module CRM 6/01/2004
#
#   SETGRAY      : Gère le grisage de la transaction de saisie
# LOADDATA      : traitement lors du chargement des données
# LOADBROWSERS  : Charge le tableau des browsers
# ONGLETS_INIT :  Traitement de gestion des onglets en initialisation
# ONGLETS_ENREG : Traitement de gestion des onglets en enregistrement
# ONGLETS_READ : Traitement de gestion des onglets lors de la lecture
# ONGLETS :  Traitement de gestion des onglets
# BLOCS_INIT :  Traitement de gestion des blocs en initialisation
# BLOCS_ENREG : Traitement de gestion des blocs en enregistrement
# BLOCS_READ : Traitement de gestion des blocs lors de la lecture
# BLOCS:  Traitement de gestion des blocs
# COLFIX_INIT :  Traitement de gestion des colonnes fixes en initialisation
# COLFIX_ENREG : Traitement de gestion des colonnes fixes lors de l'enregistrement
# COLFIX_READ : Traitement de gestion des colonnes fixes lors de la lecture
# COLFIX : Traitement de gestion des colonnes fixes
# CHAMPS_INIT : Traitement de gestion des champs en initialisation
# CHAMPS_ENREG : Traitement de gestion des champs lors de l'enregistrement
# CHAMPS_READ : Traitement de gestion des champs lors de la lecture
# CHAMPS : Traitement de gestion des champs
###########################################################################################################
##########################################################################################################
# Gère le grisage de la transaction de saisie
##########################################################################################################
$SETGRAY
  If [M:CMS1]TSREMACFLG = 2 Then
    Actzo [M:CMS1]TSRECPNFLG
  Else
    [M:CMS1]TSRECPNFLG = 1
    Grizo [M:CMS1]TSRECPNFLG
  Endif
  If [M:CMS1]TSREHDTFLG = 2 Then
    Actzo [M:CMS1]TSREINVFLG
  Else
    [M:CMS1]TSREINVFLG = 1
    Grizo [M:CMS1]TSREINVFLG
  Endif
  If [M:CMS1]TSREHDTFLG = 2 Then
    Actzo [M:CMS3]
    Actzo [M:CMS5]10
    Actzo [M:CMS4]
  Else
    Grizo [M:CMS3]
    Grizo [M:CMS5]10
    Grizo [M:CMS4]
  Endif
  If [M:CMS1]TSREINVFLG = 2 Then
    If [M:CMS1]TSREHDTFLG = 2 Then
      Actzo [M:CMS4]
    Endif
  Else
    Grizo [M:CMS4]
  Endif
Return

##########################################################################################################
#traitement lors du chargement des données
$LOADDATA
Local Char SZMESSAGE(250)
Local Integer IBRETOUR
Local Char SZLIBELLE (50)

  Read [HTV]HTV0=[F:HTR]HTRTYP;[F:HTR]HTRNUM
  If fstat <> 0 Then
    Raz [F:HTV]
  Endif
  Gosub LOADBROWSERS From SUBCMSB
  Gosub ONGLETS_READ From SUBCMSB
  Gosub BLOCS_READ From SUBCMSB
  Gosub COLFIX_READ  From SUBCMSB
  Gosub CHAMPS_READ From SUBCMSB
  Gosub PE_HDKTRS From SUBHDKTRS
Return

##########################################################################################################
# Charge le tableau des browsers
##########################################################################################################
$LOADBROWSERS
Local Integer ITERCMS6

  If !clalev([F:AOB]) : Local File AOBJET [AOB] : Endif
  Raz [M:CMS6]NBLIG
  For ITERCMS6 = 0 To dim([M:CMS6]OBJLIS)-1
    If [M:CMS6]OBJLIS(ITERCMS6) = "" Then
      Break
    Endif
    [M:CMS6]NBLIG += 1
  Next
  For ITERCMS6 = 0 To [M:CMS6]NBLIG-1
    If [M:CMS6]OBJLIS(ITERCMS6) <> "" Then
      Read [AOB]ABREV=[M:CMS6]OBJLIS(ITERCMS6)
      If fstat Then
        [M:CMS6]OBJLISCLA(ITERCMS6) = ""
      Else
        Call TEXTE([F:AOB]LIBEL, [M:CMS6]OBJLISCLA(ITERCMS6)) From OBJDIV
      Endif
    Endif
  Next
Return

##########################################################################################################
# Traitement de gestion des onglets en initialisation
$ONGLETS_INIT
Local Char SZTYP_ACTION

  SZTYP_ACTION = "INIT"
  Gosub ONGLETS
Return

##########################################################################################################
# Traitement de gestion des onglets en enregistrement
$ONGLETS_ENREG
Local Char SZTYP_ACTION

  SZTYP_ACTION = "ENREG"
  Gosub ONGLETS
Return

##########################################################################################################
# Traitement de gestion des onglets lors de la lecture
$ONGLETS_READ
Local Char SZTYP_ACTION

  SZTYP_ACTION = "READ"
  Gosub ONGLETS
Return

##########################################################################################################
# Traitement de gestion des onglets
$ONGLETS
Local Integer INBONGLET
Local Integer ITROUVE
Local Char SZREFERENCE
Local Integer ITROUVE

  INBONGLET = 0
  ITROUVE = 0
  Raz SZREFERENCE
  #If ACTION = "INIT" Then
  If SZTYP_ACTION = "INIT" or SZTYP_ACTION = "ENREG" Then
    # FGR 13/10/2009 : X3SUIVI57386 faut le réinitialiser avant parce que sinon on modif les valeurs qui y sont ne sont pas ecrasées
    Raz [F:HTR]ONGINVISI
    INBONGLET = 0
  Endif
  SZREFERENCE = "SRE7"
  If SZTYP_ACTION = "ENREG" Then
    If [M:CMS1]TSREMACFLG <> 2 and [M:CMS1]TSREPBLFLG <> 2 Then
      [F:HTR]ONGINVISI(INBONGLET) = SZREFERENCE
      INBONGLET += 1
    Endif
  Endif
  SZREFERENCE = "SRE8"
  If SZTYP_ACTION = "INIT" Then
    [M:CMS1]TSREINVFLG = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMS1]TSREINVFLG <> 2 Then
      [F:HTR]ONGINVISI(INBONGLET) = SZREFERENCE
      INBONGLET += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]ONGINVISI)
    If ITROUVE = 0 Then
      [M:CMS1]TSREINVFLG = 2
    Else
      [M:CMS1]TSREINVFLG = 1
    Endif
  Endif
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 30/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    SZREFERENCE = "SRE9"
    If SZTYP_ACTION = "ENREG" Then
      If [M:CMS1]TSREPITFLG <> 2 and [M:CMS1]TSREHDTFLG <> 2 Then
        [F:HTR]ONGINVISI(INBONGLET) = SZREFERENCE
        INBONGLET += 1
      Endif
    Endif
  Else
    SZREFERENCE = "SRE9"
    If SZTYP_ACTION = "ENREG" Then
      If [M:CMS1]TSREHDTFLG <> 2 Then
        [F:HTR]ONGINVISI(INBONGLET) = SZREFERENCE
        INBONGLET += 1
      Endif
    Endif
  Endif
Return

