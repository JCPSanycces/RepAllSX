  If SZTYP_ACTION = "INIT" Then
    [M:CMS1]TSRECOVFLG = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMS1]TSRECOVFLG <> 2 Then
      #Couverture parc
      [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
      [F:HTV]FIEVAL(INBFIENAM) = "3"
      INBFIENAM += 1
      [F:HTV]FIENAM(INBFIENAM) = "[SRE7]COVSPT"
      [F:HTV]FIEVAL(INBFIENAM) = "3"
      INBFIENAM += 1
      [F:HTV]FIENAM(INBFIENAM) = "[SRE7]COVVCR"
      [F:HTV]FIEVAL(INBFIENAM) = "3"
      INBFIENAM += 1
      #Couverture composant
      [F:HTV]FIENAM(INBFIENAM) = "[SRE7]CPNCOVFLG"
      [F:HTV]FIEVAL(INBFIENAM) = "3"
      INBFIENAM += 1
      [F:HTV]FIENAM(INBFIENAM) = "[SRE7]CPNCOVSPT"
      [F:HTV]FIEVAL(INBFIENAM) = "3"
      INBFIENAM += 1
      [F:HTV]FIENAM(INBFIENAM) = "[SRE7]CPNCOVVCR"
      [F:HTV]FIEVAL(INBFIENAM) = "3"
      INBFIENAM += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMS1]TSRECOVFLG = 2
    Else
      If val([F:HTV]FIEVAL(ITROUVE-1)) = 3 Then
        [M:CMS1]TSRECOVFLG = 1
      Else
        [M:CMS1]TSRECOVFLG = 2
      Endif
    Endif
  Endif
  #Points débités (Forfait)
