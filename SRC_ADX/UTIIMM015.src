#<AdxTL>@(#)0.0.0.0 $Revision$
###########################################################################################
# MODIFIE PAR : GBO
# LE          : 09 Septembre 2010 10:14:29
# Moulinette pour initialiser le champ DPRPLN à 16 sur les types d'écriture dont le type
# de source est provision pour renouvellement.
# FQ66710
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIIMM015: Objet TPE : plan sur les PPR alimenté avec 16") From LECFIC
  Call EXE_UTIIMM015(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

 Subprog EXE_UTIIMM015(APPLI)
 Value Char APPLI
 If clalev([F:ZTPE]) : Close Local File [ZTPE] : Endif
 Local File =APPLI+".TYPACE" [ZTPE]
  Call ECR_TRACE("UTIIMM015: Process Start on : "+APPLI,0) From GESECRAN

  Call DEBTRANS From GLOCK
  Gosub TR_UTIIMM015

  Call ECR_TRACE("UTIIMM015: Process End on : "+APPLI,0) From GESECRAN

 End

########################################
#### Corps de la moulinette - début ####
########################################
$TR_UTIIMM015
  Trbegin [ZTPE]
  GOK=1
  Update [ZTPE] Where SRCTYP=4 With DPRPLN=G301AUC
  If fstat
   GOK=0
   Call ECR_TRACE("UTIIMM015 error UPDATE [ZTPE] fstat="+num$(fstat),1) From GESECRAN   
  Else
   Call ECR_TRACE("   number of updated records"-num$(adxuprec),0) From GESECRAN
  Endif
  If !GOK Then
    Goto AB_UTIIMM015
  Else
    Commit
  Endif
Return

$AB_UTIIMM015
 Rollback
Return
########################################
#### Corps de la moulinette - fin ######
########################################

#######################################################################
# Pour exécution depuis passage de patch
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI


 If filinfo(filpath("FIL","TYPACE","fde",APPLI),0) < 0 : End : Endif

  Call EXE_UTIIMM015(APPLI)
End

#######################################################################
# Pour exécution depuis dosmajx (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI


 If filinfo(filpath("FIL","TYPACE","fde",APPLI),0) < 0 : End : Endif

  Call EXE_UTIIMM015(APPLI)
End
