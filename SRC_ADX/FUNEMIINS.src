#<AdxTL>@(#)5.0.0.0 $Revision$

#########################################################################
#                                       Module Ventes - Septembre 2000  #
#     EMISSION DES ACOMPTES                                             #
#                                                                       #
#     - Traitement        : FUNEMIINS                                   #
#     - Action e_commerce : TRTEMIINS  (Traitement standard)            #
#                                                                       #
#########################################################################

#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#--- Actions liées au traitement standard

Case ACTION
 When "OUVRE_BATCH" : Gosub INIT_TRTEMIINS
 When "INIT"        : Gosub INIT_TRTEMIINS
 When "DEBUT"       : Affzo [DIA]1-99
 When "OK"          : GOK=1
 When "END"         : GOK=0 : FIN=1
 When "CONTROLE"    : Gosub CONTROLE_TRTEMIINS
 When "EXEC"        : Gosub EXEC_TRTEMIINS
 When "TERMINE"     : Gosub TERMINE_TRTEMIINS
 When Default
Endcase
Return

#########################################################################
# Détail des actions liées au traitement standard                       #
#########################################################################

#########################################################################
$INIT_TRTEMIINS

#----- Ouverture des tables et déclaration des variables pour les états -----#
Gosub INIT_ETAT From TRTX3ETA
#-----

# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Gosub OUVRE

Local Mask SEMIINS [DIA]


Raz [M:DIA]

[M:DIA]EXPSENDAT=date$
[M:DIA]PRNFLG=1
#[M:DIA]PRNNAM=GREPORT1  : # mis dans action champ

Call LECMEMO ("STD","[M:DIA]","vf9") From GMEMO

Return

#########################################################################
$CONTROLE_TRTEMIINS
If GOK < 1  FIN=1 Else TMP=1  Endif

Return

#########################################################################
$EXEC_TRTEMIINS

If !GSERVEUR
# --> ouverture de la trace
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("SEMIINS","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

# --> Boucle de traitement
Gosub MAJDUD

Return

#########################################################################
$TERMINE_TRTEMIINS

#    document acompte
If [M:DIA]PRNFLG=2 & [M:DIA]PRNNAM<>"" & [M:DIA]PRNDEN<>""
  Call PRINT_ETAT (1,WARP_NUMREQ,[M:DIA]PRNDEN) From TRTX3ETA
Endif

If !GSERVEUR
   Call ECR_TRACE(mess(74,196,1),0) From GESECRAN
# --> fermeture trace
   Call FERME_TRACE From LECFIC
   TRA=1
Endif

Return

#-----------------------------------------------------------------------#
#    Ouverture
#-----------------------------------------------------------------------#
$OUVRE
Local Integer OK
Local Char WMSG(80)

If clalev ([F:DUD]) <= 0 : Local File GACCDUDATE [DUD] : Endif
If clalev ([F:SOH]) <= 0 : Local File SORDER     [SOH] : Endif

Return

#-----------------------------------------------------------------------#
#    Traitement
#-----------------------------------------------------------------------#
$MAJDUD

Call DEBTRANS From GLOCK
GOK = 1
Trbegin [DUD]
Lock [DUD]
If fstat = 1
   GOK = -1 : GLOCK = "$GACCDUDATE" : Goto TR_ROLL
Elsif fstat
   GOK = 0 : Call RSTA("DUD","*") From GLOCK : Goto AB_CREAT
Endif

Filter [F:DUD] Where PAMTYP > 1 & SENINS = 1 & EXPSENDAT<=[M]EXPSENDAT
For [F:DUD] With Nohint
    If [F:SOH]SOHNUM <> [F:DUD]NUM
        Read [SOH]SOH0 = [F:DUD]NUM
        If fstat Raz [F:SOH] : Endif
    Endif
    # La commande doit être signée pour que les acomptes puissent être émis
    If [F:SOH]APPFLG>2
        [F:DUD]SENDAT = date$
        [F:DUD]SENINS = 2

        Rewrite [DUD]
        If fstat
            GOK = 0 : Call FSTA("DUD") From GLOCK : Break
        Endif

        WMSG= format$("K:3X",[F:DUD]TYP)+"/"+format$("K:3X",num$([F:DUD]LIG))
&             +"/"+format$("K:15X",[F:DUD]NUM)+"/"+format$("K:3X",num$([F:DUD]DUDLIG))
&             -num$(format$("N3*:15F",[F:DUD]AMTCUR))
&             -format$("K:3X",[F:DUD]CUR)
&             -mess(001,664,1)
&             -format$("D<:DD[ ]3M[ ]YYYY",[F:DUD]DUDDAT)
        Call ECR_TRACE(WMSG,0) From GESECRAN

        If [M:DIA]PRNFLG=2 & [M:DIA]PRNNAM <> "" & [M:DIA]PRNDEN <> ""
            WARP_RPTCOD(0)=[M:DIA]PRNNAM   : # pas de poste facture acompte dans le modele impression
           #Gbn-73266
           #WARP_NBRCPY=1                  : # pas de parametrage du nombre exemplaires
            WARP_NBRCPY=[M:DIA]PRTCOP
            #----- Ecriture AREPORTM et màj indicateur d'impression -----#
            Call ALIM_ETAT(1,WARP_NBRCPY,WARP_RPTCOD,WARP_NUMREQ,WARP_NUMLIG,WARP_SEQREQ) From TRTX3ETA
            #-----
        Endif
    Endif
Next
Filter [F:DUD]

If    GOK < 0 : Goto TR_ROLL
Elsif GOK = 0 : Goto AB_CREAT
Endif
Commit

$FIN_CREAT
Return

$TR_ROLL
Rollback
Call ROLL From GLOCK
Goto FIN_CREAT

$AB_CREAT
Rollback
Goto FIN_CREAT

#########################################################################
#                            ACTIONS CHAMPS
#########################################################################

Subprog AS_EXPSENDAT(VALEUR)
Variable Date    VALEUR
If [M]PRNFLG <> 2
  Grizo [M]PRNNAM, PRNDEN
Else
  Actzo [M]PRNNAM, PRNDEN
Endif
End

########################################
Subprog AP_PRNFLG(VALEUR)
Variable Integer VALEUR

Local Integer K


If VALEUR = 1
   Raz [M]PRNNAM, [M]PRNDEN, [M]PRNIMP, [M]PRNSRV
   Diszo [M]PRNNAM, PRNDEN
Else
   If vireblc([M]PRNNAM,2)=""
#     recherche du document defini dans la fonction
      If clalev([AFC])=0 : Local File AFONCTION [AFC] : Endif
      Read [AFC]CODINT=GFONCTION
#    Bug 51937 SEGAY le 23/01/09
#     If !fstat : [M]PRNNAM=[F:AFC]RPT1 : Endif
#     Si on a un code impression, on prend le premier code état, sinon on prend le code de la fonction
      If !fstat Then
        [M]PRNNAM=[F:AFC]RPT1
        If !clalev([F:ARX]) : Local File AREPORTX   [ARX] : K=0 : Else K=1 : Endif
        Read [ARX]ARX0(1) =[F:AFC]RPT1
        If !fstat : [M]PRNNAM=[F:ARX]EXTCOD : Endif
        If !K : Close Local File [ARX] : Endif
      Endif

      Actzo [M]PRNNAM, PRNDEN
   Endif
Endif
Affzo [M]PRNNAM, PRNDEN, PRNIMP, PRNSRV
End

########################################
Subprog C_PRNNAM(VALEUR)
Variable Char    VALEUR()
Local    Char    AUTSIT(10)
Local    Integer OK
# Document obligatoire si impression document acomptes
If [M:DIA]PRNFLG = 2 & VALEUR = ""
   GMESSAGE=mess(10,123,1) : mkstat = 2
   End
Endif
End

########################################
Subprog C_PRNSRV(VALEUR)
Variable Char    VALEUR()
Gosub CTL_SRV From TRTVENIMP
End

########################################
Subprog C_PRNIMP(VALEUR)
Variable Char    VALEUR()
# Imprimante obligatoire si impression
If [M:DIA]PRNNAM <> "" & VALEUR = ""
   GMESSAGE=mess(10,123,1) : mkstat = 2
Endif
End

#########################################################################
#                            ERREUR BATCH
#########################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-ERR,1) From GESECRAN
End

##########################################################################
Subprog C_PRNDEN(VALEUR)
Variable Char    VALEUR()
# Imprimante obligatoire si impression
If [M]PRNNAM <> "" & VALEUR = ""
   GMESSAGE=mess(10,123,1) : mkstat = 2
Endif
End

##########################################################################
Subprog AP_PRNDEN(VALEUR)
Variable Char    VALEUR()
Call INIT_SRV(VALEUR, [M]PRNSRV,[M]PRNIMP) From TRTVENIMP
Affzo [M]PRNSRV, PRNIMP
[M:DIA]PRTCOP=func TRTVENIMP.GET_NBRCPY_AIM(VALEUR)#Fq73266-Gbn
End
##########################################################################
