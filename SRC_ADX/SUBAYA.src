#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion objet AYA
Raz GPILOBJ,GNBMASKOUV
Call OBJET("AYA",GBIDC1,GBIDC2) From GOBJET
End
######################################################################################
## Xtend:  Gestion Action Xtend
#
#    Table AYTLINES (AYN)
#        LINCODTYP = 3    Actions  
#        LINTYP (doc Wiki)
#                 = 20    flux aller
#                 = 21    flux retour
#                 = 40    paramètres action
#
#  Version 0002 - E47185
#
#  Remarques:
#     Chps OPTOUT déactivé en le rendant invisible 
#            Son but est de géré le flux action (menu 7918 - Chps Xtend, Perso, Processeur XSL)
######################################################################################
$ACTION
#Infbox ACTION
Case ACTION
 When "AVANT_OUVRE"    : Gosub AVANT_OUVRE
 When "AVANT_ACT"      : Gosub AVANT_ACT
 When "ANNULE"         : Gosub ANNULE
 When "CREATION"       : Gosub CREATION
 When "EXEBOUT"        : Gosub EXEBOUT
 When "EXEACT"         : Gosub EXEACT
 When "FERME"          : Gosub FERME
 When "FILTRE"         : Gosub FILTRE
 When "INICRE"         : Gosub INICRE
 When "INIMOD"         : Gosub INIMOD
 When "LIENS"          : Gosub LIENS
 When "MODIF"          : Gosub MODIF
 When "OUVRE"          : Gosub OUVRE
 When "RAZCRE"         : Gosub RAZCRE
 When "STATUT"         : Gosub STATUT
 When "SETBOUT"        : Gosub SETBOUT
 When "BAM_VALTYP40"   : If GBIDI1<>0 : mkstat=2 : Endif       # Il y a des utilisations
 When "BAM_PARCOD40"   : If GBIDI1<>0 : mkstat=2 : Endif       # Il y a des utilisations
 When default
Endcase
Return

$AVANT_OUVRE
#---------------------------------------------------------------#
Call AYT_DEBUG From AYTUTIA   # Activation debug java
Gosub INICTLFCY From SUBAYS
Return
#---------------------------------------------------------------#

$OUVRE
#---------------------------------------------------------------#
Local Char WSTR1 (250), KEYLNK(30)
Local Integer WI, AYNPOS21
Gosub DSYFCY From SUBAYS     # Infos site
Local Char WACTCOD(GLONAYA)
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$FERME
Gosub DSYCLRFCY From SUBAYS # Clear affichage site
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET : # Validation, copie
Else
 CHMEN+="3"    # Validation avec vérification interface
Endif
Return
#---------------------------------------------------------------#

$AVANT_ACT
#---------------------------------------------------------------#
If find(BOUT,"E","C")
    # Ctl paramètre saisie (cas objet pré-rempli) Flux aller
    For WI=0 To [M:AYA2]NUM20-1
        If vireblc([M:AYA2]FIEKEY20(WI),2)=""
            OK=0 : zonsui="[M:AYA2]NUM20("+num$(WI)+")" 
            GMESSAGE=mess(166,7900,1)
            Break
        Endif
    Next
Endif
Return
#---------------------------------------------------------------#
$EXEACT
Case BOUT
When "S"
    Call USG_SUPP([M]FCYCOD, GABREV, [M:AYA0]ACTCOD, WI) From CNSAYUSTD
    If WI : OK=0 : Endif
Endcase
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$EXEBOUT
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$INICRE
$INIMOD
# Clé browser X3
[F]BRWX3=[F]FCYCOD+"_"+[F]ACTCOD 
Return

#---------------------------------------------------------------#
$CREATION
$MODIF
# 
# Sup. avant recréation par. Action 
Gosub ANNULE2 : If GOK<>1 : Return : Endif

# Paramétres
For WI=0 To [M:AYA1]NUM40-1
 Raz [F:AYN]
 [F:AYN]FCYCOD    = [M]FCYCOD
 [F:AYN]LINCODTYP = 3
 [F:AYN]LINCODSTD = [M]ACTCOD
 [F:AYN]LINCOD    = toupper([M]ACTCOD)
 [F:AYN]LINTYP    = 40
 [F:AYN]PARCOD    = [M:AYA1]PARCOD40(WI)
 [F:AYN]VALTYP    = [M:AYA1]VALTYP40(WI)
 [F:AYN]VALEUR    = [M:AYA1]VALEUR40(WI)
 [F:AYN]LINNUM    = WI
 Write [AYN]
 If fstat
  GOK=0 : Call FSTA("AYN") From GLOCK : Break
 Endif
Next

# Flux aller
For WI=0 To [M:AYA2]NUM20-1
     Raz [F:AYN]
     [F:AYN]FCYCOD    = [M]FCYCOD
     [F:AYN]LINCODTYP = 3
     [F:AYN]LINCODSTD = [M]ACTCOD
     [F:AYN]LINCOD    = toupper([M]ACTCOD)
     [F:AYN]LINTYP    = 20
     [F:AYN]ENTCOD    = [M]ENTCOD20(WI)
     [F:AYN]FIECOD    = [M]FIECOD20(WI)
     [F:AYN]FIELNKENT = [M]FLNKENT20(WI)
     [F:AYN]INTTYPMLT = [M]INTMLT20(WI) 
     [F:AYN]INTFLD    = [M]DSCCOD20(WI)
     [F:AYN]INTFLDGRP = [M]DSCGRP20(WI) 
     [F:AYN]INTFLDIND = [M]DSCIND20(WI)
     [F:AYN]LINNUM = WI 
     Write [AYN]
     If fstat
      GOK=0 : Call FSTA("AYN") From GLOCK : Break
     Endif
Next

# Gestion cas action mapping retour indiquée
If [M:AYA2]ACTMAPRET=""
    # Flux retour
    For WI=0 To [M:AYA2]NUM21-1
         Raz [F:AYN]
         [F:AYN]FCYCOD    = [M]FCYCOD
         [F:AYN]LINCODTYP = 3
         [F:AYN]LINCODSTD = [M]ACTCOD
         [F:AYN]LINCOD    = toupper([M]ACTCOD)
         [F:AYN]LINTYP    = 21
         [F:AYN]ENTCOD    = [M]ENTCOD21(WI)
         [F:AYN]FIECOD    = [M]FIECOD21(WI)
         [F:AYN]FIELNKENT = [M]FLNKENT21(WI)
         [F:AYN]INTTYPMLT = [M]INTMLT21(WI) 
         [F:AYN]INTFLD    = [M]DSCCOD21(WI)
         [F:AYN]INTFLDGRP = [M]DSCGRP21(WI) 
         [F:AYN]INTFLDIND = [M]DSCIND21(WI)
         [F:AYN]LINNUM = WI 
         Write [AYN]
         If fstat
          GOK=0 : Call FSTA("AYN") From GLOCK : Break
         Endif
    Next
Endif

#  textes AXX
Call MAJTEXTRA([M]INTIT,"AYTACT","INTIT",[M:AYA0]FCYCOD,[M:AYA0]ACTCOD) From  ATEXTRA

Return

#---------------------------------------------------------------#
$LIENS
Gosub DSYFCY From SUBAYS     # Infos site
# 
Call SETACTTYP([F:AYA]ACTTYP) 
Call SETINTTYP([F:AYA]INTCOD)
Call SETACTBTN([F:AYA]WSOACT)
Call SETOUT([F:AYA]OPTOUT)
Call SETFICXML([F:AYA]OPTOUT)

# Paramétres
Raz [F:AYN]
WI=0
For [F:AYN]AYN0 Where FCYCOD=[M]FCYCOD and LINCODTYP = 3
&                     and LINCOD = toupper([M]ACTCOD) and  LINTYP = 40
 [M:AYA1]PARCOD40(WI) = [F:AYN]PARCOD
 [M:AYA1]VALTYP40(WI) = [F:AYN]VALTYP
 [M:AYA1]VALEUR40(WI) = [F:AYN]VALEUR
  WI+=1
Next
[M:AYA1]NUM40=WI

# Flux aller
Gosub LOADXT_WS

# Flux retour
# Gestion cas action mapping retour indiquée
Call SETACTMAPRET([M:AYA2]ACTMAPRET)
If [M:AYA2]ACTMAPRET=""         # Action courante porte le mapping de retour
    WACTCOD=[M:AYA0]ACTCOD
    Gosub LOADWS_XT
Endif
Return


# Chgt Flux aller
# - - - - - - - - - - - - - - - - - - - -
$LOADXT_WS
Raz [F:AYN]
WI=0
For [F:AYN]AYN0 Where FCYCOD=[M]FCYCOD and LINCODTYP = 3
&                     and LINCOD = toupper([M]ACTCOD) and  LINTYP = 20
  [M]ENTCOD20(WI) = [F:AYN]ENTCOD
  [M]FIECOD20(WI) = [F:AYN]FIECOD
  [M]FLNKENT20(WI)= [F:AYN]FIELNKENT
  If [F:AYN]FIELNKENT=""      # cas std
    [M]FIEKEY20(WI)= [AYN]FIECOD
  Else                        # champs liés
    [M]FIEKEY20(WI)= [F:AYN]FIELNKENT+"_"+[AYN]FIECOD
  Endif
  [M]INTMLT20(WI) = [F:AYN]INTTYPMLT
  [M]DSCCOD20(WI) = [F:AYN]INTFLD
  [M]DSCGRP20(WI) = [F:AYN]INTFLDGRP
  [M]DSCIND20(WI) = [F:AYN]INTFLDIND
  #
  If [M:AYA1]INTFLG=2 : [AYA2]DSCDIM20(WI)= func SUBAYI.DSCDIM([M]FCYCOD, [M]INTCOD, [F:AYN]INTFLDGRP, [F:AYN]INTFLD) : Endif
  #
  WI+=1
Next
# !! Pour éviter pb grizo du libellé tableau: Positionner NUM puis grizo... 
[M]NUM20=WI 
For WI=0 To [M]NUM20-1
  Call SETDSC_20([M]INTMLT20(WI), [M]DSCGRP20(WI), [M]DSCCOD20(WI), WI)
Next
Return

# Chgt Flux retour
# - - - - - - - - - - - - - - - - - - - -
#      WACTCOD: variable contenant le code action à charger 
#                permet de gérer le cas d'une action gérant ce mapping de retour
$LOADWS_XT
#
Raz [F:AYN]
WI=0

For [F:AYN]AYN0 Where FCYCOD=[M]FCYCOD and LINCODTYP = 3
&                     and LINCOD = WACTCOD and  LINTYP = 21
  [M]ENTCOD21(WI) = [F:AYN]ENTCOD
  [M]FIECOD21(WI) = [F:AYN]FIECOD
  [M]FLNKENT21(WI)= [F:AYN]FIELNKENT
  If [F:AYN]FIELNKENT=""      # cas std
    [M]FIEKEY21(WI)= [AYN]FIECOD
  Else                        # champs liés
    [M]FIEKEY21(WI)= [F:AYN]FIELNKENT+"_"+[AYN]FIECOD
  Endif
  [M]INTMLT21(WI) = [F:AYN]INTTYPMLT
  [M]DSCCOD21(WI) = [F:AYN]INTFLD
  [M]DSCGRP21(WI) = [F:AYN]INTFLDGRP
  [M]DSCIND21(WI) = [F:AYN]INTFLDIND
  #
  If [M:AYA1]INTFLG=2 : [AYA2]DSCDIM21(WI)= func SUBAYI.DSCDIM([M]FCYCOD, [M]INTCOD, [F:AYN]INTFLDGRP, [F:AYN]INTFLD) : Endif
  #
  WI+=1
Next
# !! Pour éviter pb grizo du libellé tableau: Positionner NUM puis grizo... 
[M]NUM21=WI 
For WI=0 To [M]NUM21-1
  Call SETDSC_21([M]INTMLT21(WI), [M]DSCGRP21(WI), [M]DSCCOD21(WI), WI)
Next

Return

#---------------------------------------------------------------#
$ANNULE
Delete [AXX] Where CODFIC="AYTACT" & ZONE = "INTIT"  & IDENT1=[L]SUPP & IDENT2=[L]CODE
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK 
Endif
$ANNULE2
Delete [AYN]AYN0=[M]FCYCOD;3;toupper([M]ACTCOD)
If fstat=1 : GOK=-1 : GLOCK="$AYTLINES ("-[M]FCYCOD-"3"-[M]ACTCOD+")" : Return : Endif
Return

#---------------------------------------------------------------#
$FILTRE
FILTSUP+=func SUBAYS.FILTFCY
Return

#---------------------------------------------------------------#
$RAZCRE
Gosub DSYFCY From SUBAYS     # Infos site
#[M]CODACT=WFCY_CODACT        # Code activité site
Return

#---------------------------------------------------------------#
$STATUT
Return

######################################################################################
#
# Utilitaires 
#
######################################################################################
#
Subprog SETACTTYP(ACTTYP)    # Gestion en fct du type d'action
If ACTTYP=3   # Logout
  Effzo [AYA1]15,20,30,50 : Grizo [AYA1]15,20,30,50
  Effzo [AYA2] : Grizo [AYA2] 
Else
  Actzo [AYA1]15,20,30,50 
  Actzo [AYA2]
Endif
End

Subprog SETINTTYP(INTCOD)
[M:AYA1]INTFLG=1
If INTCOD<>""
    Call LECTURE("AYI",INTCOD, [M]FCYCOD) From CONTOBJ
    If !fstat    
        [M:AYA1]INTFLG=2
        [M:AYA1]INTTYP=[F:AYI]TYP
        If [F:AYI]TYP=21 # Type action objet
            Actzo [M:AYA1]WSOACT
        Else
            [M:AYA1]WSOACT=0 : Grizo [M:AYA1]WSOACT
            Call SETACTBTN([M:AYA1]WSOACT)
        Endif
    Else
        Call ERREUR(mess(172,7900,1)) From GESECRAN
    Endif
Endif
End


Subprog SETACTBTN(WSOACT)
If WSOACT<>5
  Effzo [AYA1]WSOACTBTN : Grizo [AYA1]WSOACTBTN 
  Effzo [AYA1]WSOTYPPAR : Grizo [AYA1]WSOTYPPAR
Else
  Actzo [AYA1]WSOACTBTN
  Actzo [AYA1]WSOTYPPAR
Endif
End

# OPTOUT - déactivée (menu 7918) traitement du flux retour
Subprog SETOUT(OPTOUT)
If [AYA1]ACTTYP=3
    # Rien car déjà grisé 
Elsif OPTOUT<>1
  Effzo [AYA2]15,20 : Grizo [AYA2]15,20
Else
  Actzo [AYA2]15,20
Endif
End

# OPTOUT - déactivée (menu 7918) traitement du flux retour
Subprog SETFICXML(OPTOUT)
If OPTOUT<>3
  Effzo [AYA1]FICXML : Grizo [AYA1]FICXML 
Else
  Actzo [AYA1]FICXML
Endif
End

#
Subprog SETDSC_20(INTMLT, DSCGRP, DSCCOD, NOL)
Variable Integer INTMLT
Value Integer NOL
Variable Char DSCGRP, DSCCOD
If DSCGRP="" | DSCCOD="" : End : Endif

If [AYA2]DSCDIM20(NOL) = 1
  INTMLT=1
Endif
    
If INTMLT=2    # Multi
  Effzo [AYA2]DSCIND20(NOL) : Grizo [AYA2]DSCIND20(NOL)
  Raz  [AYA2]DSCDIM20(NOL)
Else
  If [AYA2]DSCDIM20(NOL) > 1
      If [AYA2]DSCIND20(NOL)=0 : [AYA2]DSCIND20(NOL)=1 : Endif
      Actzo [AYA2]DSCIND20(NOL)
  Else
      [AYA2]DSCIND20(NOL)=1 : Diszo [AYA2]DSCIND20(NOL)
  Endif
Endif

End 

#
Subprog SETDSC_21(INTMLT, DSCGRP, DSCCOD, NOL)
Value Integer INTMLT, NOL
Value Char DSCGRP, DSCCOD
#
If DSCGRP="" | DSCCOD="" : End : Endif

If [AYA2]DSCDIM21(NOL) = 1
  INTMLT=1
Endif

If INTMLT=2    # Multi
  Effzo [AYA2]DSCIND21(NOL) : Grizo [AYA2]DSCIND21(NOL)
  #$ Raz  [AYA2]DSCDIM21(NOL)
Else
  If [AYA2]DSCDIM21(NOL) > 1
      If [AYA2]DSCIND21(NOL)=0 : [AYA2]DSCIND21(NOL)=1 : Endif
      Actzo [AYA2]DSCIND21(NOL)
  Else
      [AYA2]DSCIND21(NOL)=1 : Diszo [AYA2]DSCIND21(NOL)
  Endif
Endif
End

#  Chargement tableau avec les clés d'une interface objet
Subprog SETINTKEYS(INTCOD, INTTYP, WSOACT)
Value Char INTCOD
Value Integer INTTYP     # Type interface M7912
Value Integer WSOACT     # Bouton WS      M7920

If INTTYP=21 and WSOACT<>2    # Pas avec une action xtend de création
    Local Integer WNOL, WNOLMIN, WNOLMAX
    Local Integer WI
    Local Integer WI_COD, WI_GRP, W_NB, WI_NEXT
    Local Char WMESSAGE(100) (1..10)

    # Gestion similaire à celle de AYI pour afficher le tableau
    Gosub GETWS_VAR From SUBAYIACT     # Variables pour GETWS_INF
    Call LECTURE("AYI",[L]INTCOD, [M]FCYCOD) From CONTOBJ
    If fstat : End : Endif
    WS_INTTYP=[F:AYI]TYP : WS_WSRCOD=[F:AYI]WEBSRCCOD     
    Gosub GETWS_INF  From SUBAYIACT : If WS_RET : GERR=1 : mkstat=2 : GMESSAGE=WS_MES : End: Endif
    #
    For WI=0 To dim(RUBKEYIND)-1
        WI_COD=find(RUBCOD(RUBKEYIND(WI)),[M:AYA2]DSCCOD20(0..[M:AYA2]NUM20-1))
        If WI_COD 
            WI_GRP=(RUBGRP(RUBKEYIND(WI))=[M:AYA2]DSCGRP20(WI_COD-1))
        Endif
        If !(WI_COD and WI_GRP)    # Non trouvé  
            [M:AYA2]DSCGRP20([M:AYA2]NUM20)=RUBGRP(RUBKEYIND(WI))
            [M:AYA2]DSCCOD20([M:AYA2]NUM20)=RUBCOD(RUBKEYIND(WI))
            [M:AYA2]DSCIND20([M:AYA2]NUM20)=RUBDIM(RUBKEYIND(WI)) 
            [M:AYA2]DSCDIM20([M:AYA2]NUM20)=[M:AYA2]DSCIND20([M:AYA2]NUM20) # Rq: Tj occurrence 1 sur clé...
            [M:AYA2]NUM20+=1
        Endif
    Next 
Endif
End

# Action de mapping pour le retour
Subprog SETACTMAPRET(ACTMAPRET)  
If ACTMAPRET<>""
  Local Char WACTCOD(GLONAYA)  : WACTCOD = ACTMAPRET
  Gosub LOADWS_XT    # Chgt Flux retour
  Diszo [AYA2]20 
Else
  Actzo [AYA2]20
Endif
End


######################################################################################
## Ecran AYA1
######################################################################################
Subprog AM_ACTTYP(VALEUR)
Variable Integer VALEUR
Call SETACTTYP(VALEUR) 
End


Subprog AM_INTCOD(VALEUR)
Variable Char    VALEUR()
Call SETINTTYP(VALEUR) : Affzo [M:AYA1]WSOACT
Effzo [AYA2]10,20
Call SETINTKEYS(VALEUR, [M:AYA1]INTTYP, [M:AYA1]WSOACT ) :     Affzo [M:AYA2]10 
End

Subprog AM_WSOACT(VALEUR)
Variable Integer VALEUR
Call SETACTBTN(VALEUR)
Call SETINTKEYS([M:AYA1]INTCOD, [M:AYA1]INTTYP, VALEUR ) :     Affzo [M:AYA2]10 
End

Subprog AM_OPTOUT(VALEUR)
Variable Integer VALEUR
Call SETOUT(VALEUR)
Call SETFICXML(VALEUR)
End

Subprog C_FICXML(VALEUR)
Variable Char    VALEUR()
Local Char RACINE(200),FILEPATH(250)
Local Char LANDEF(GLONLAN)
Local Integer WI
LANDEF= func SUBAYS.LANDEF([M]FCYCOD)
RACINE= func AYTGESFILE.GETPATH("",nomap,"DIRPAG",LANDEF,[M]FCYCOD,"")+
&        func AYTGESFILE.GETPATH("",nomap,"DIRSEP","","","")
FILEPATH=RACINE+VALEUR
Call EXISTE(FILEPATH, WI) From ORDSYS
If WI<>1     # pas un fichier
    GERR=3 : GMESSAGE=mess(101,100,1)-VALEUR
Endif

End

Subprog S_FICXML(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 Local Char RACINE(200),WVAL(250)
 Local Char LANDEF(GLONLAN)
 Local Integer WI
 LANDEF= func SUBAYS.LANDEF([M]FCYCOD)
 RACINE= func AYTGESFILE.GETPATH("",nomap,"DIRPAG",LANDEF,[M]FCYCOD,"")+
&        func AYTGESFILE.GETPATH("",nomap,"DIRSEP","","","")
 WVAL=RACINE+VALEUR
 ## Action SELFICREP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 Call SAISIE_CHAR(WVAL,PARMSK,"DFICREP","SELFICREP","XWDFICREP") From GSAISIE
 WI=instr(0,WVAL,RACINE)
 If WI
    VALEUR=right$(WVAL,len(RACINE)+1)
 Else
    mkstat=2
    GERR=1 : GMESSAGE=mess(101,100,1)-WVAL
 Endif 
Endif

End

Subprog AS_VALTYP40(VALEUR)
Variable Integer VALEUR
Local Integer LST(len(mess(0,GCOMBO,1))),WI
LST(WI)=1 : WI+=1    # Cst
LST(WI)=6 : WI+=1    # Saisie
Call MNLCHX(GCOMBO,LST) From AYTUTIA
End

Subprog AM_VALTYP40(VALEUR)
Variable Integer VALEUR
If VALEUR<>1  # pas cste
    Effzo [M:AYA1]VALEUR40(nolign-1)
Endif
End

Subprog C_NUM40
Local Char    VALEUR
Local Char    PARMSK(250)(1..20) , SAVACT(20)
Local Integer WRET     
# Ctl en suppression 1 ou plusieurs lignes (chainages lien dynamique et tableau interface de l'action)
If adxgtb=0 & find(status,65,68,83)
    Local Integer WNOL, WNOLMIN, WNOLMAX
    WNOLMIN=nolign-1
    If find(status,68,83) : WNOLMAX=nolign1-1 : Else WNOLMAX=WNOLMIN : Endif
    For WNOL=WNOLMIN To WNOLMAX
        SAVACT = GACTION : GACTION = "AYAPARUSG"
        PARMSK(1) = [M]FCYCOD
        PARMSK(2) = [M]ACTCOD
        PARMSK(3) = [M]PARCOD40(WNOL)
        PARMSK(4) = num$(WRET)
        PARMSK(5) = mess(144,7900,1)
        Call SAISIE_CHAR(VALEUR,PARMSK,"AYAPARUSG","SUBAYAACT","SPEAYAACT") From GSAISIE
        WRET = val(PARMSK(4))    # 0: pas d'usage ko  1: des usages
        GACTION = SAVACT
        If WRET : mkstat=2 : Break : Endif
    Next
Endif
End

Subprog C_PARCOD40(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]PARCOD40) From OBJDIV
End


######################################################################################
## Ecran AYA2
######################################################################################

##  Tableau 20 - Flux aller ##########################################################
#
Subprog C_NUM20
#Infbox num$(adxgtb)-num$(status)
If [M:AYA1]INTTYP=21 and [M:AYA1]WSOACT<>2    # Action objet et pas avec une action xtend de création
    Local Integer WNOL, WNOLMIN, WNOLMAX
    Local Integer WI
    Local Integer WI_COD, WI_GRP, W_NB, WI_NEXT
    Local Char WMESSAGE(100) (1..10)

    # Gestion similaire à celle de AYI pour afficher le tableau
    Gosub GETWS_VAR From SUBAYIACT     # Variables pour GETWS_INF
    Call LECTURE("AYI",[M:AYA1]INTCOD, [M]FCYCOD) From CONTOBJ
    If fstat : End : Endif
    WS_INTTYP=[F:AYI]TYP : WS_WSRCOD=[F:AYI]WEBSRCCOD     
    Gosub GETWS_INF  From SUBAYIACT :  If WS_RET : GERR=1 : mkstat=2 : GMESSAGE=WS_MES : End: Endif

    #
    If find(status,65,68,83)    # suppression ligne
        WNOLMIN=nolign-1
        If find(status,68,83) : WNOLMAX=nolign1-1 : Else WNOLMAX=WNOLMIN : Endif
        For WNOL=WNOLMIN To WNOLMAX
            For WI=0 To dim(RUBKEYIND)-1
                WI_COD=find(RUBCOD(WI),[M:AYA2]DSCCOD20(WNOLMIN..WNOLMAX))
                If WI_COD 
                    WI_GRP=(RUBGRP(WI)=[M:AYA2]DSCGRP20(WI_COD-1))
                    If WI_GRP : Break : Endif
                Endif
            Next
            If WI_COD and WI_GRP  
                 GMESSAGE = mess(165,7900,1)-RUBCOD(WI)
                 mkstat=2 : BREAK
            Endif
        Next 
        If mkstat=2 : End : Endif
    Endif
    #
    If adxgtb<>0 # En sortie correcte ou incorrecte
        For WI=0 To dim(RUBKEYIND)-1
            WI_COD=0 : WI_GRP=0 : WI_NEXT=0
            Repeat
                WI_COD=find(RUBCOD(RUBKEYIND(WI)),[M:AYA2]DSCCOD20(WI_NEXT..[M:AYA2]NUM20-1))
                If WI_COD 
                    WI_GRP= (RUBGRP(RUBKEYIND(WI))=[M:AYA2]DSCGRP20(WI_COD-1))
                    If WI_GRP : Break : Endif
                Else
                    Break
                Endif 
                WI_NEXT=WI_COD+1 
            Until WI_NEXT > [M:AYA2]NUM20-1
            If !( WI_COD and WI_GRP)
                W_NB+=1 : WMESSAGE(W_NB)=mess(164,7900,1)-RUBCOD(RUBKEYIND(WI))-RUBGRP(RUBKEYIND(WI))
            Endif
        Next 
        If W_NB
            GMESSAGE=WMESSAGE(1)
            For WI=2 To W_NB
                GMESSAGE+="\"+WMESSAGE(WI)
            Next
            mkstat=2
        Endif 
    Endif
 Endif
End

Subprog S_DSCCOD20(VALEUR)
Variable Char    VALEUR()
Affzo DSCGRP20(nolign-1)           # Mise à jour éventuel par la sel AYIFIESEL
End

Subprog C_DSCCOD20(VALEUR)
Variable Char    VALEUR()
Affzo [M:AYA2]DSCGRP20(nolign-1)  # Mise à jour éventuel par le ctl AYIFIECTL
End

Subprog AM_DSCCOD20(VALEUR)
Variable Char    VALEUR()
Local Integer NOL : NOL=nolign-1
[M:AYA2]DSCDIM20(NOL)= func SUBAYI.DSCDIM([M]FCYCOD, [M]INTCOD, [M:AYA2]DSCGRP20(NOL), VALEUR)
Call SETDSC_20([M:AYA2]INTMLT20(NOL), [M:AYA2]DSCGRP20(NOL), VALEUR, NOL)
End

Subprog D_DSCGRP20(VALEUR)
Variable Char    VALEUR()
If nolign > 1
    VALEUR = DSCGRP20(nolign-2)
Endif
End

Subprog AM_DSCGRP20(VALEUR)
Variable Char    VALEUR()
Local Integer NOL : NOL=nolign-1
[M:AYA2]DSCDIM20(NOL)= func SUBAYI.DSCDIM([M]FCYCOD, [M]INTCOD, VALEUR, [M:AYA2]DSCCOD20(NOL))
Call SETDSC_20([M:AYA2]INTMLT20(NOL), VALEUR, [M:AYA2]DSCCOD20(NOL), NOL)
End

Subprog AM_FIEKEY20(VALEUR)
Variable Char    VALEUR()
Local Integer NOL : NOL=nolign-1
Call FIEKEY_ANA(VALEUR, [M:AYA2]FLNKENT20(NOL),[M:AYA2]FIECOD20(NOL)) From SUBAYF
End

Subprog C_DSCIND20(VALEUR)
Variable Decimal VALEUR
If VALEUR > DSCDIM20(nolign-1) | VALEUR=0
    mkstat=2
    GMESSAGE = mess(87,7900,1)-num$(DSCDIM20(nolign-1))
Endif
End

Subprog D_ENTCOD20(VALEUR)
Variable Char    VALEUR()
If nolign > 1
    VALEUR = ENTCOD20(nolign-2)
Endif
End

Subprog D_INTMLT20(VALEUR)
Variable Integer VALEUR
Local Integer WI
If [M]DSCDIM20(nolign-1)=1  :  VALEUR=1 :  End : Endif
If [M]ENTCOD20(nolign-1)=""    # Il s'agit d'un param
    If [M]DSCDIM20(nolign-1)=1 : VALEUR=1 : Else : VALEUR=2 : Endif
Else
    If nolign > 1
        VALEUR = INTMLT20(nolign-2)  # Par défaut
        # Recherche code entité
        WI = find([M]ENTCOD20(nolign-1),[M]ENTCOD20)
        If WI<>0 & nolign>WI    # On est sur une ligne après
            VALEUR = INTMLT20(WI-1) 
        Endif
    Endif
Endif
End

Subprog AS_INTMLT20(VALEUR)
Variable Integer VALEUR
If [M]DSCDIM20(nolign-1)=1  :  mkstat=2 :  End : Endif
If [M]ENTCOD20(nolign-1)<>"" and nolign > 1    # Pas un param
    # Recherche code entité
    WI = find([M]ENTCOD20(nolign-1),[M]ENTCOD20)
    If WI<>0 & nolign>WI    # On est sur une ligne après
        VALEUR = INTMLT20(WI-1)
        #mkstat=2 # pas de saisie
    Endif
Endif
End

Subprog AM_INTMLT20(VALEUR)
Variable Integer VALEUR
Local Integer NOL : NOL=nolign-1

#<E47185>
[M:AYA2]DSCDIM20(NOL)= func SUBAYI.DSCDIM([M]FCYCOD, [M]INTCOD, [M:AYA2]DSCGRP20(NOL), [M:AYA2]DSCCOD20(NOL))
#<\E47185>

Call SETDSC_20(VALEUR, [M:AYA2]DSCGRP20(NOL), [M:AYA2]DSCCOD20(NOL), NOL)
End

#  Flux interface -> entités - Gestion par action indiquée?
Subprog AM_ACTMAPRET(VALEUR)
Variable Char    VALEUR()
Call SETACTMAPRET(VALEUR)
Affzo [M:AYA2]20
End

