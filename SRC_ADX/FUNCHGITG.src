#<AdxTL>@(#)1.0.0.0 $Revision$
#################################################################
# Changement categorie action CHGITG
################################################################
$ACTION

Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "FIN"           : Gosub FIN
 When "OK"            : Gosub OK
 When "BOUTON"        : Gosub BOUTON

 When Default
Endcase
Return


######################################################################"
#                                                                OUVRE
######################################################################"
$OUVRE

If GMODU(7) = 2 #MAE, bg 72517
  If clalev([F:STJ])=0 Local File STOJOU     [STJ]  Endif
  If clalev([F:STE])=0 Local File STOPAR     [STE]  Endif
Endif
If clalev([F:ITM])=0 Local File ITMMASTER  [ITM]  Endif
If clalev([F:TFO])=0 Local File TABFOR     [TFO]  Endif
If clalev([F:ITG])=0 Local File ITMCATEG   [ITG]  Endif
If clalev([F:ITF])=0 Local File ITMFACILIT [ITF]  Endif
If clalev([F:ITS])=0 Local File ITMSALES   [ITS]  Endif
If clalev([F:ITP])=0 Local File ITMBPS     [ITP]  Endif
If clalev([F:ITU])=0 Local File ITMBPC     [ITU]  Endif
If clalev([F:AXX])=0 Local File ATEXTRA    [AXX]  Endif # hcb 53562

If dim(GSIMCHGITG) > 0
   Kill GSIMCHGITG
Endif
Return

######################################################################"
#                                                                DEBUT
######################################################################"
$DEBUT
Raz   [M:DIA]
[M]TRACE = 2
Affzo [M:DIA]
Return

######################################################################"
#                                                                  FIN
######################################################################"
$FIN

Return


######################################################################"
#                                                                   OK
######################################################################"
$OK
Call TRT_CHGITG From FUNCHGITG

Return


######################################################################"
#                                                               BOUTON
######################################################################"
$BOUTON


Return



######################################################################"
# Calcul reappro                                            TRT_CHGITG
######################################################################"
Subprog TRT_CHGITG
Local Char    WMSG(140)
Local Char    WINT(15)
Local Integer WNBRART
Local Integer WNBRARTR
Local Integer WNBRITF

Local Integer WREP
Raz WMSG
Raz WINT
Raz WNBRART
Raz WREP

Local  Char    WFILFOR   (250)
Local  Char    WFILART   (100)
Local  Char    WFILTSI1  (250)
Local  Char    WFILTSI2  (250)
Local  Integer WERR

Local  Integer WTYP1, WTYP2
Read [ITG]ITG1=[M]TCLCODOLD;""
WTYP1 = ([F:ITG]MFGFLG=2)
&      +([F:ITG]PURFLG=2)*2
&      +([F:ITG]SCPFLG=2)*4
&      +([F:ITG]SCSFLG=2)*8    # Types de flux autorisés sur l'ancienne catégorie
# Issue 115023 - 2016-03-07 by MAE : Erreur sur la zone nouvelle catégorie
#Read [ITG]ITG1=[M]TCLCODOLD;""
Read [ITG]ITG1=[M]TCLCOD;""
WTYP2 = ([F:ITG]MFGFLG=2)
&      +([F:ITG]PURFLG=2)*2
&      +([F:ITG]SCPFLG=2)*4
&      +([F:ITG]SCSFLG=2)*8    # Types de flux autorisés sur la nouvelle catégorie

Raz WFILFOR
Raz WFILART
WFILTSI1 = "1=1"
WFILTSI2 = "1=1"
# Filtre article

WFILART = "[F:ITM]TCLCOD=[M]TCLCODOLD"
If [M]ITMREFSTR <> "" | [M]ITMREFEND <> ""
  WFILART += "&[F:ITM]ITMREF>=[M]ITMREFSTR&[F:ITM]ITMREF<=[M]ITMREFEND"
Endif

# Filtre statistique
If dim([M]TSICODSTR) > 0
  For I = 0 To dim([M]TSICODSTR)-1
    If [M]TSICODSTR(I) <> "" | [M]TSICODEND(I) <> ""
      If len(WFILTSI1) > 200
        WFILTSI2 += "&[F:ITM]TSICOD("+num$(I)+")>='"+[M]TSICODSTR(I)+
&                "'&[F:ITM]TSICOD("+num$(I)+")<='"+[M]TSICODEND(I)+"'"
      Else
        WFILTSI1 += "&[F:ITM]TSICOD("+num$(I)+")>='"+[M]TSICODSTR(I)+
&                "'&[F:ITM]TSICOD("+num$(I)+")<='"+[M]TSICODEND(I)+"'"
      Endif
    Endif
  Next I
Endif

# Filtre formule
If [M]SELFOR <> ""
  Read [TFO]TFO0=30;[M]SELFOR
  If fstat = 0
     WFILFOR = [F:TFO]FORFOR
  Endif
Endif
#
If WFILFOR    = ""
   WFILFOR    = "1=1"
Endif
If WFILART    = ""
   WFILART    = "1=1"
Endif

# comptage nombre article a traiter

Filter [ITM] Where evalue(WFILART)  &
&                  evalue(WFILTSI1) &
&                  evalue(WFILTSI2) &
&                  evalue(WFILFOR)
&            Order By Key ITM0
For [ITM]
    WNBRART += 1
Next
Filter  [ITM]
   If WNBRART = 1
      Call AVERTIR(num$(WNBRART)-mess(917,196,1),WREP) From GESECRAN
   Else
      Call AVERTIR(num$(WNBRART)-mess(916,196,1),WREP) From GESECRAN
   Endif
   If WREP <> 2
      End
   Endif

If [M:DIA]TRACE = 2 | dim(GSIMCHGITG) > 0
   Gosub OUVRE_TRACE
Endif

#message opération en cours ...
Call TEMPON("O") From GESECRAN

Raz WNBRART
Raz WNBRARTR
Raz WNBRITF
Filter [ITM] Where evalue(WFILART)  &
&                  evalue(WFILTSI1) &
&                  evalue(WFILTSI2) &
&                  evalue(WFILFOR)
&            Order By Key ITM0
For [ITM]
    Readlock [ITM] Curr
    If !fstat
       WNBRART += 1
       If [M:DIA]TRACE = 2 | dim(GSIMCHGITG) > 0
          If WNBRART = 1
             Call ECR_TRACE("*"-mess(918,196,1),0) From GESECRAN  # Article(s) traité(s)
          Endif
          Raz WMSG
          WMSG = "- "+[F:ITM]ITMREF+" "
#         Call TEXTFIC("ITMMASTER","ITMDES1",3,WINT) From OBJDIV   # hcb 53562
          Call TEXTFIC("ITMMASTER","DES1AXX",3,WINT) From OBJDIV   # hcb 53562
          #WMSG = WMSG+WINT+" : "+[F:ITM]ITMDES1+" "                                           # FGR 30/06/2009 : X3SUIVI56189
          Local Char WITMDES(GLONDES)                                                          # FGR 30/06/2009 : X3SUIVI56189
          Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,WITMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
          WMSG = WMSG+WINT+" : "+WITMDES+" "                                                   # FGR 30/06/2009 : X3SUIVI56189

          Call ECR_TRACE(WMSG,0) From GESECRAN
       Endif
       If !(dim(GSIMCHGITG) > 0)             # si pas mode simulation
          Call DEBTRANS From GLOCK
          Trbegin [ITM]
       Endif
       Gosub TRT_ITMMASTER
       If WERR <> 9                           # si pas erreur bloquante
          If !(dim(GSIMCHGITG) > 0)             # si pas mode simulation
             Rewrite [ITM]
             Commit
          Endif
          WNBRARTR += 1
       Else
          Gosub AB_TRT
       Endif
    Endif
Next
Filter [ITM]
#suppression message opération en cours ...
Call TEMPOFF   From GESECRAN

If [M:DIA]TRACE = 2 | dim(GSIMCHGITG) > 0
   Call ECR_TRACE("---------------------------------------------------------------",0) From GESECRAN
   If dim(GSIMCHGITG) > 0
      Call ECR_TRACE("*** "-mess(27,107,1)-" ***",0) From GESECRAN                # Simulation
   Endif
   Call ECR_TRACE("*"-num$(WNBRART)-"  "-mess(918,196,1),0) From GESECRAN  # Article(s) selectionné(s)
   Call ECR_TRACE("*"-num$(WNBRARTR)-"  "-mess(924,196,1),0) From GESECRAN  # Article(s) modifié(s)
   Call ECR_TRACE("*"-num$(WNBRITF)-"  "-mess(925,196,1),0) From GESECRAN  # Article-site(s) modifié(s)
   Call ECR_TRACE("---------------------------------------------------------------",0) From GESECRAN
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE   From LECFIC
Endif

End



########################################################################
# AB_TRT                                       Abandon de la transaction
########################################################################
$AB_TRT
Rollback
Return

########################################################################
# OUVRE_TRACE                                    Ouverture fichier trace
########################################################################
$OUVRE_TRACE
Call OUVRE_TRACE(mess(919,196,1)) From LECFIC
Call ECR_TRACE("---------------------------------------------------------------",0) From GESECRAN
Call ECR_TRACE("-"-mess(655,197,1)-" : "-[M:DIA0]TCLCODOLD,0) From GESECRAN  # Catégorie                     # hcb X3-99277
Call ECR_TRACE("-"-mess(656,197,1)-" : "-[M:DIA0]TCLCOD,0)    From GESECRAN  # Nouvelle Catégorie            # hcb X3-99277
Call ECR_TRACE("---------------------------------------------------------------",0) From GESECRAN
Call ECR_TRACE("*"-mess(41,120,1),0) From GESECRAN                           # Critères de sélection
If [M:DIA]ITMREFEND <> ""
   Call ECR_TRACE("-"-mess(569,197,1)-" : "-[M:DIA]ITMREFSTR-" / "-[M:DIA]ITMREFEND,0) From GESECRAN  # Article
Endif

If dim([M:DIA]TSICODSTR) > 0
   For I = 0 To dim([M:DIA]TSICODSTR)-1
       If[M:DIA]TSICODEND(I) <> ""
          Call ECR_TRACE("-"-mess(I+1,206,1)-" : "-[M:DIA]TSICODSTR(I)-" / "-[M:DIA]TSICODEND(I),0) From GESECRAN  # Statistique
    Endif
   Next I
Endif

If [M:DIA]SELFOR <> ""
   Call ECR_TRACE("-"-mess(573,197,1)-" : "-[M:DIA]SELFOR,0) From GESECRAN   # Formule
Endif
Call ECR_TRACE("---------------------------------------------------------------",0) From GESECRAN

Return

########################################################################
# TRT_ITMMASTER                                  Traitement d un article
########################################################################
$TRT_ITMMASTER
Local Char WMSG1 (100)
Local Integer WFCY
Local Integer WITS
Raz WITS
Raz WFCY
Raz WERR
Raz WMSG
#Dbgaff
If [F:ITG]TCLCOD <> [M]TCLCOD | [F:ITG]STOFCY <> ""
   Read [ITG]ITG1= [M]TCLCOD ;""
   If fstat
      WERR = 9
      Raz [ITG]
      Return
   Endif
Endif

WMSG1 = "           "+mess(925,196,1)+" : "

[F:ITM]SALFLG=[F:ITG]SALFLG
[F:ITM]PURFLG=[F:ITG]PURFLG
[F:ITM]MFGFLG=[F:ITG]MFGFLG
[F:ITM]SCPFLG=[F:ITG]SCPFLG
[F:ITM]SCSFLG=[F:ITG]SCSFLG
[F:ITM]PHAFLG=[F:ITG]PHAFLG
[F:ITM]GENFLG=[F:ITG]GENFLG
[F:ITM]TOOFLG=[F:ITG]TOOFLG
[F:ITM]DLVFLG=[F:ITG]DLVFLG
[F:ITM]INTFLG=[F:ITG]INTFLG
[F:ITM]TCLCOD=[F:ITG]TCLCOD

# Type generique et sous traitance  : pas geré en stock
If [F:ITG]SCSFLG = 2 | [F:ITG]GENFLG = 2
   #MAE, bg 72517 If [F:ITM]STOMGTCOD <> 1
   If [F:ITM]STOMGTCOD <> 1 & GMODU(7) = 2
      Filter [STJ] Where UPDCOD  = 2             &
&                  ITMREF =  [F:ITM]ITMREF
&     Order By Key STJ2
      For [STJ]
           WERR = 9
           Break
      Next
      Filter [STJ]
      If WERR <> 9
         [F:ITM]STOMGTCOD =  1     # gestion stock
         [F:ITM]LOTMGTCOD =  1     # gestion lot
         Raz [F:ITM]EXYSTA         # statut peremption
         Raz [F:ITM]SHL            # delai peremption
         Raz [F:ITM]DEFPOT         # titre par fefaut
         Raz [F:ITM]LOTCOU         # compteur lot
         If [M:DIA]TRACE = 2 | dim(GSIMCHGITG) > 0
            Call ECR_TRACE( "          ! "-mess(928,196,1),0) From GESECRAN
         Endif
         Filter [ITF] Where ITMREF = [F:ITM]ITMREF
&            Order By Key ITF0
         For [ITF]
             Readlock [ITF] Curr
             If !fstat
                If [M:DIA]TRACE = 2 | dim(GSIMCHGITG) > 0
                   WMSG1 = WMSG1 + "- "+[F:ITF]STOFCY+" "
                Endif
                Raz [F:ITF]LOCNUM              # intitule emplacement
                Raz [F:ITF]DEFLOCTYP           # type emplacement
                Raz [F:ITF]DEFLOC              # defloc emplacement
                Raz [F:ITF]REOMGTCOD           # mode reappro
                Raz [F:ITF]REOPER              # periodicite reappro
                Raz [F:ITF]REOPOL              # politique reappro
                Raz [F:ITF]DAYCOV              # couverture
                Raz [F:ITF]SAFSTO              # stock securite
                Raz [F:ITF]REOTSD              # seuil reoppro
                Raz [F:ITF]MAXSTO              # stock maximum
                [F:ITF]STOMGTCOD       = 1     # gestion stock
                [F:ITF]REOMGTCOD       = 1     # mode reappro
                [F:ITF]LOCMGTCOD       = 1     # gestion emplacement
                [F:ITF]CUNCOD          = 3     # mode inventaire
                [F:ITF]STOCOD          = 3     # mode retrait stock
                WFCY = 1

                If WTYP1<>WTYP2
                    Raz GBIDI1
                    For GBIDI1=0 To dim([F:ITF]OTRSTYP)-1
                        If !func STKVALPAR.WITHOVE([F:ITF]OTRSTYP(GBIDI1),WTYP2)
                            Raz [F:ITF]OTRSTYP(GBIDI1), OVECOD(GBIDI1), OVECPNFLG(GBIDI1)
                        Else
                            GBIDI2=find(0,[F:ITF]OTRSTYP)-1
                            If GBIDI2<>-1 & GBIDI2 < GBIDI1
                                [F:ITF]OTRSTYP(GBIDI2)=[F:ITF]OTRSTYP(GBIDI1)
                                Raz [F:ITF]OTRSTYP(GBIDI1), OVECOD(GBIDI1), OVECPNFLG(GBIDI1)
                            Endif
                        Endif
                    Next
                Endif

                If !(dim(GSIMCHGITG) > 0)        # si pas mode simulation
                   Rewrite [ITF]
                Endif
                WNBRITF += 1
             Endif
         Next
         Filter [ITF]
         If [M:DIA]TRACE = 2 | dim(GSIMCHGITG) > 0
            If WFCY = 1
               Call ECR_TRACE(WMSG1,0) From GESECRAN
            Endif
         Endif
      Else
         Call ECR_TRACE("         ! "-mess(68,188,1),0) From GESECRAN  # des enregistrements de stocks existent
         Return
      Endif
   Endif
Endif

# pas de gestion titre pour des articles vendus
#MAE,  bg 72517 If [F:ITM]STOMGTCOD = 3 & [F:ITG]SALFLG = 2
If [F:ITM]STOMGTCOD = 3 & [F:ITG]SALFLG = 2 & GMODU(7) = 2
      Filter [STJ] Where UPDCOD  = 2             &
&                  ITMREF =  [F:ITM]ITMREF
&     Order By Key STJ2
      For [STJ]
           WERR = 9
           Break
      Next
      Filter [STJ]
      If WERR <> 9
        [F:ITM]STOMGTCOD = 2
        If [M:DIA]TRACE = 2 | dim(GSIMCHGITG) > 0
           Call ECR_TRACE( "         . "-mess(929,196,1),0) From GESECRAN
        Endif
      Else
         Call ECR_TRACE("         ! "-mess(68,188,1),0) From GESECRAN  # des enregistrements de stocks existent
         Return
      Endif
Endif

# pas de unite de poids pour un  article sous-traitance
If [F:ITM]WEU <> "" & [F:ITG]SCSFLG = 2
   [F:ITM]WEU = ""
   If [M:DIA]TRACE = 2 | dim(GSIMCHGITG) > 0
       Call ECR_TRACE( "         . "-mess(930,196,1),0) From GESECRAN
   Endif
Endif

# pas de unite de volume pour un  article sous-traitance
If [F:ITM]VOU <> "" & [F:ITG]SCSFLG = 2
   [F:ITM]VOU = ""
   If [M:DIA]TRACE = 2 | dim(GSIMCHGITG) > 0
       Call ECR_TRACE( "         . "-mess(931,196,1),0) From GESECRAN
   Endif
Endif

# pas de unite de achat  pour un  article fantome
If [F:ITM]PUU <> "" & [F:ITG]PHAFLG = 2
   [F:ITM]PUU = ""
   If [M:DIA]TRACE = 2 | dim(GSIMCHGITG) > 0
       Call ECR_TRACE( "         . "-mess(932,196,1),0) From GESECRAN
   Endif
Endif

# unite de achat obligatoire pour un  article achete
If [F:ITM]PUU =  "" & [F:ITG]PURFLG = 2
   [F:ITM]PUU = [F:ITM]STU
   If [M:DIA]TRACE = 2 | dim(GSIMCHGITG) > 0
       Call ECR_TRACE( "         . "-mess(933,196,1),0) From GESECRAN
   Endif
Endif

# code reception à oui si article sous traitance
If [F:ITM]RCPFLG <> 2 & [F:ITG]SCSFLG = 2
   [F:ITM]RCPFLG  = 2
   If [M:DIA]TRACE = 2 | dim(GSIMCHGITG) > 0
       Call ECR_TRACE( "         . "-mess(934,196,1),0) From GESECRAN
   Endif
Endif

# unite de vente = stu si non renseigné
If [F:ITM]SAU = ""
   [F:ITM]SAU = [F:ITM]STU
   If [M:DIA]TRACE = 2 | dim(GSIMCHGITG) > 0
       Call ECR_TRACE( "         . "-mess(935,196,1),0) From GESECRAN
   Endif
Endif

# coeficient unite de vente = 1 si 0
If [F:ITM]SAUSTUCOE  = 0
   [F:ITM]SAUSTUCOE  = 1
   If [M:DIA]TRACE = 2 | dim(GSIMCHGITG) > 0
       Call ECR_TRACE( "         . "-mess(936,196,1),0) From GESECRAN
   Endif
Endif

# si vendu ou livrable ITMSALES doit exister
If [F:ITG]SALFLG = 2  |  [F:ITG]DLVFLG = 2
    Raz WITS
    Readlock [ITS]ITS0 = [F:ITM]ITMREF
    Case fstat
        When 0 : WITS = 1
        When 1 : WERR = 9
                 # Erreur d acces sur le fichier ITMSALES
                 Call ECR_TRACE(mess(12,100,1)-" : "-"ITMSALES",0) From GESECRAN
                 Return
        When Default : WITS = 0
    Endcase
    # Mise à jour table ITMSALES
    [F:ITS]       = [F:ITG]
    [F:ITS]       = [F:ITM]

    # Création au cas où l'enregistrement n'existe pas encore
    If !WITS
        If !(dim(GSIMCHGITG) > 0)             # si pas mode simulation
           Write [ITS]
           If fstat
              WERR = 9
              # Erreur d ecriture sur le fichier ITMSALES
              Call ECR_TRACE(mess(13,100,1)-" : "-"ITMSALES",0) From GESECRAN
              Return
           Endif
        Endif
        If [M:DIA]TRACE = 2 | dim(GSIMCHGITG) > 0
           Call ECR_TRACE("         . "-mess(927,196,1),0) From GESECRAN  # Article - vente créé
        Endif
    Else
        If !(dim(GSIMCHGITG) > 0)             # si pas mode simulation
           Rewrite [ITS]
           If fstat
              WERR = 9
              # Erreur d acces sur le fichier ITMSALES
              Call ECR_TRACE(mess(12,100,1)-" : "-"ITMSALES",0) From GESECRAN
              Return
           Endif
        Endif
        If [M:DIA]TRACE = 2 | dim(GSIMCHGITG) > 0
           Call ECR_TRACE("         . "-mess(926,196,1),0) From GESECRAN  # Article - vente modifié
        Endif
    Endif
Endif

# si non vendu suppression article client ITMBPC
If [F:ITG]SALFLG = 1
   For [ITU]ITU0 Where ITMREF = [F:ITM]ITMREF
       WERR = 1
       If !(dim(GSIMCHGITG) > 0)             # si pas mode simulation
          If [F:ITU]ITSTEX <> ""
             Call SUP_CLOB([F:ITU]ITSTEX,WRET) From TRTX3TEX
          Endif
          If [F:ITU]ITPTEX <> ""
             Call SUP_CLOB([F:ITU]ITPTEX,WRET) From TRTX3TEX
          Endif
          Delete [ITU]
          If fstat
             WERR = 9
             # Erreur d acces sur le fichier ITMSALES
             Call ECR_TRACE(mess(12,100,1)-" : "-"ITMBPC",0) From GESECRAN
             Break
          Endif
       Endif
    Next
    If WERR = 1
       If [M:DIA]TRACE = 2 | dim(GSIMCHGITG) > 0
          Call ECR_TRACE("         . "-mess(938,196,1),0) From GESECRAN  # Article client  - supprimé
       Endif
    Endif
Endif
If WERR = 9
   Return
Endif
# si non vendu suppression article fournisseur ITMBPS
If [F:ITG]PURFLG = 1 & [F:ITG]SCPFLG = 1 & [F:ITG]SCSFLG = 1 & [F:ITG]GENFLG = 1 & [F:ITG]TOOFLG = 1
   For [ITP]ITP0 Where ITMREF = [F:ITM]ITMREF
       WERR = 1
       If !(dim(GSIMCHGITG) > 0)             # si pas mode simulation
          If [F:ITP]TEX <> ""
             Call SUP_CLOB([F:ITP]TEX,WRET) From TRTX3TEX
          Endif
          Delete [ITP]
          If fstat
             WERR = 9
             # Erreur d acces sur le fichier ITMBPS
             Call ECR_TRACE(mess(12,100,1)-" : "-"ITMBPS",0) From GESECRAN
             Break
          Endif
       Endif
   Next
   If WERR = 1
      If [M:DIA]TRACE = 2 | dim(GSIMCHGITG) > 0
         Call ECR_TRACE("         . "-mess(937,196,1),0) From GESECRAN  # Article fournisseur - supprimé
      Endif
   Endif
Endif
If WERR = 9
   Return
Endif

Return


# --------------------------
#       liste des erreurs
# --------------------------
# -01- Type generique ou sous traitance  : gestion de stock à non
# -02- Type article vendu : gestion titre à non
# -03- Type sous-traitance : unite de poids à blanc
# -04- Type sous-traitance : unite de volume à blanc
# -05- Type fantome : unite de achat à blanc
# -06- Type acheté : unite d achat obligatoire --> unité de stock
# -07- Type sous traitance :  code reception à oui
# -08- Unite de vente non renseigné : --> unite de stock
# -09- Coeficient unite de vente à 0 : -- > 1

