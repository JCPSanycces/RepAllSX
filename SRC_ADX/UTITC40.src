#<AdxTL>@(#)11.0.0.0 $Revision$
#####################################################################################################
# UTITC40                                                                 Module Tronc Commun       #
#                                                                                                   #
# But de l'utilitaire :                                                                             #
#    Réinitialiser les champs DWIPTYP et RWIPTYP dans la table MTOLINK                              #
#    selon le champ WIPTYP de la table ORDERS                                                       #
#                                                                                                   #
#####################################################################################################
# Issue 80971 - 2012-06-13 by GH
#####################################################################################################

Call MAJ_UTITC40
End

#-------------------------------------------------------------------
Subprog MAJ_UTITC40

Local Char DOSSIER(30)
DOSSIER=nomap

Call SAIDOS(DOSSIER,"UTITC40 - Correction [MLK]RWIPTYP") From SAIDOS

If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTITC40 - Correction [MLK]RWIPTYP") From LECFIC
  Call EXE_UTITC40(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif

End

#-------------------------------------------------------------------
Subprog EXE_UTITC40(DOSSIER)
Value Char    DOSSIER

If filinfo(filpath("FIL","MTOLINK","fde", DOSSIER),0)<=0 : End : Endif
If filinfo(filpath("FIL","ORDERS","fde", DOSSIER),0)<=0 : End : Endif

Call ECR_TIME("UTITC40 : Correction RWIPTYP in table MTOLINK : Started") From DOSSUB

Local File =DOSSIER+".MTOLINK"   [MLK]
Local File =DOSSIER+".ORDERS"    [ORD]

Local Integer TYP, OLDTYP, ERR, NBENR
Local Char    CRITERE(250)

# TYP=0  => pas d'ordre
# TYP=-1 => des ordres de type différent
# TYP>0  => des ordres de même type (TYP)

Columns [ORD] (WIPTYP)
Trbegin [MLK], [ORD]

  Filter [MLK] Order By Key CLE = STOFCY;ITMREF;RESSTYP;RESSNUM;RESSLIN;RESSSEQ;RWIPTYP
  For [MLK]CLE(7)
    Filter [ORD] Where STOFCY=[F:MLK]STOFCY & WIPTYP=[F:MLK]RWIPTYP
    Read [ORD]ORD3 = [F:MLK]STOFCY;[F:MLK]RESSTYP;[F:MLK]RESSNUM;[F:MLK]RESSLIN;[F:MLK]RESSSEQ
    If fstat
      Filter [ORD]
      TYP=0
      For [ORD]ORD3 Where STOFCY=[F:MLK]STOFCY & ITMREF=[F:MLK]ITMREF
&                       & VCRTYP=[F:MLK]RESSTYP & VCRNUM=[F:MLK]RESSNUM & VCRLIN=[F:MLK]RESSLIN & VCRSEQ=[F:MLK]RESSSEQ
&                       & find(WIPTYP,2,5,7,9,13)<>0
          If TYP=0                    : TYP=[F:ORD]WIPTYP
          Elsif TYP<>[F:ORD]WIPTYP    : TYP=-1 : Break
          Endif
       Next

      If TYP=-1
         Call ECR_TRACE([F:MLK]STOFCY-[F:MLK]ITMREF-num$([F:MLK]RESSTYP)-[F:MLK]RESSNUM-num$([F:MLK]RESSLIN)-num$([F:MLK]RESSSEQ)
&                      -": RWIPTYP ="-num$([F:MLK]RWIPTYP)-"-> ?",1) From GESECRAN
      Elsif TYP>0
         [L]OLDTYP = [F:MLK]RWIPTYP
         CRITERE ="STOFCY='"+[F:MLK]STOFCY+"'"            : GCLE =[F:MLK]STOFCY
         CRITERE+=" & ITMREF='"+[F:MLK]ITMREF+"'"         : GCLE-=[F:MLK]ITMREF
         CRITERE+=" & RESSTYP="+num$([F:MLK]RESSTYP)      : GCLE-=num$([F:MLK]RESSTYP)
         CRITERE+=" & RESSNUM='"+[F:MLK]RESSNUM+"'"       : GCLE-=[F:MLK]RESSNUM
         CRITERE+=" & RESSLIN="+num$([F:MLK]RESSLIN)      : GCLE-=num$([F:MLK]RESSLIN)
         CRITERE+=" & RESSSEQ="+num$([F:MLK]RESSSEQ)      : GCLE-=num$([F:MLK]RESSSEQ)
         CRITERE+=" & RWIPTYP="+num$([F:MLK]RWIPTYP)      : GCLE-=num$([F:MLK]RWIPTYP)
         Update [MLK] Where RWIPTYP=[L]OLDTYP & evalue([L]CRITERE) With RWIPTYP = [L]TYP
         If fstat
            ERR=1
         Else
            ERR=0 : NBENR+=adxuprec
         Endif
         Call ECR_TRACE(GCLE-": RWIPTYP ="-num$([L]OLDTYP)-"->"-num$([L]TYP),ERR) From GESECRAN
      Endif
   Endif
  Next

  Filter [ORD]
  Filter [MLK]
Commit
Columns [ORD]

Call ECR_TIME("UTITC40 : Correction RWIPTYP in table MTOLINK : Ended"-"("-num$(NBENR)+" records processed"-")") From DOSSUB

End

#-----------------------------------------------------------------------------------------------
Subprog PATCH(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","MTOLINK","fde",DOSSIER),0)<=0 : End : Endif
If filinfo(filpath("FIL","ORDERS","fde",DOSSIER),0)<=0 : End : Endif

If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat : Raz [F:ADS] : Endif

Call EXE_UTITC40(DOSSIER)

End
#-----------------------------------------------------------------------------------------------
#------------------------------------------------------------------#
# Pour exécution depuis dosmaj (validation dossier)                #
#------------------------------------------------------------------#
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If filinfo(filpath("FIL","MTOLINK","fde",APPLI),0)<=0 : End : Endif
If filinfo(filpath("FIL","ORDERS","fde",APPLI),0)<=0 : End : Endif

If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif

Read [ADS]DOSSIER=APPLI : If fstat : Raz [F:ADS] : Endif

Call EXE_UTITC40(APPLI)

End
