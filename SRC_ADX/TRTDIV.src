##################################################
Subprog FMTSATPAY(PAYS, CONTEXT)
Value    Char    PAYS
Value    Char    CONTEXT      # FGR 05/03/2012 : X3SUIVI79830

Local Integer IETAT

  # FGR 05/03/2012 : X3SUIVI79830
  If CONTEXT = "" Then
    # -----------------------------------------
    # Cas général : On gère normalement la rubrique SAT
    If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
    If PAYS="" : PAYS = GPAYS : Endif
    If PAYS<>[F:TCY]CRY
      Read [TCY]TCY0 = PAYS
    Endif
    Onerrgo RIEN
    Case [F:TCY]ETAT
      When 1
        GFMT = ""
        GINTZON = ""
      When 2 : # Saisie subdivision 1
       GFMT = [F:TCY]ETATFMT
       Call LECTEXTRA(GINTZON,"TABCOUNTRY","ETATNAM",PAYS,"") From ATEXTRA
       If [F:TCY]ETATFLG<>2 or GFMT="" or GINTZON=""
         GFMT = ""
         GINTZON = ""
       Else
         GINTZON = space$(type(GINTZON)-10-len(GINTZON))+GINTZON
       Endif
     When 3 : # Saisie subdivision 2
      GFMT = [F:TCY]ETATFMT2
      Call LECTEXTRA(GINTZON,"TABCOUNTRY","ETATNAM2",PAYS,"") From ATEXTRA
      If [F:TCY]ETATFLG2<>2 or GFMT="" or GINTZON=""
        GFMT = ""
        GINTZON = ""
      Else
        GINTZON = space$(type(GINTZON)-10-len(GINTZON))+GINTZON
      Endif
    Endcase
    Gosub TITRES From ="W1"+maskcou
    Onerrgo
    # -----------------------------------------
  Elsif left$(CONTEXT,1) = "1" Then
    # -----------------------------------------
    # Cas : GESATU et GESALB
    # Format : 1~2 (pour subdivision 1) ou 1~3 (pour subdivision 2)
    Raz IETAT
    If instr(0, CONTEXT, "~") > 0 Then
      IETAT = val(seg$(CONTEXT, instr(0, CONTEXT, "~")+1, len(CONTEXT)))
    Endif
    # -----------------------------------------
    If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
    If PAYS="" : PAYS = GPAYS : Endif
    If PAYS<>[F:TCY]CRY
      Read [TCY]TCY0 = PAYS
    Endif
    Onerrgo RIEN
    Case IETAT
      When 2 : # Saisie subdivision 1
        GFMT = [F:TCY]ETATFMT
        Call LECTEXTRA(GINTZON,"TABCOUNTRY","ETATNAM",PAYS,"") From ATEXTRA
        If [F:TCY]ETATFLG<>2 or GFMT="" or GINTZON=""
          GFMT = ""
          GINTZON = ""
        Else
          GINTZON = space$(type(GINTZON)-10-len(GINTZON))+GINTZON
        Endif
      When 3 : # Saisie subdivision 2
        GFMT = [F:TCY]ETATFMT2
        Call LECTEXTRA(GINTZON,"TABCOUNTRY","ETATNAM2",PAYS,"") From ATEXTRA
        If [F:TCY]ETATFLG2<>2 or GFMT="" or GINTZON=""
          GFMT = ""
          GINTZON = ""
        Else
          GINTZON = space$(type(GINTZON)-10-len(GINTZON))+GINTZON
        Endif
      When Default
        GFMT = ""
        GINTZON = ""
    Endcase
    Gosub TITRES From ="W1"+maskcou
    Onerrgo
    # -----------------------------------------
  Elsif CONTEXT = "2" Then
    # FGR 24/05/2012 : X3SUIVI81067
    # -----------------------------------------
    # Cas où on ne tient pas compte du pays : (Tarif)
    # -----------------------------------------
    If PAYS <> "" Then
      If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
      If PAYS<>[F:TCY]CRY
        Read [TCY]TCY0 = PAYS
      Endif
      Onerrgo RIEN
      Case [F:TCY]ETAT
        When 1
          GFMT = "1X"  # Pour les tarifs ne doit pas être invisible
          GINTZON = ""
          mkstat = 1
        When 2 : # Saisie subdivision 1
         GFMT = [F:TCY]ETATFMT
         Call LECTEXTRA(GINTZON,"TABCOUNTRY","ETATNAM",PAYS,"") From ATEXTRA
         If [F:TCY]ETATFLG<>2 or GFMT="" or GINTZON=""
           GFMT = "1X"  # Pour les tarifs ne doit pas être invisible
           Call TEXTE(31745, GINTZON) From OBJDIV  # "Subdivisions géographiques"
           mkstat = 1
         Else
           GINTZON = space$(type(GINTZON)-10-len(GINTZON))+GINTZON
         Endif
        When 3 : # Saisie subdivision 2
         GFMT = [F:TCY]ETATFMT2
         Call LECTEXTRA(GINTZON,"TABCOUNTRY","ETATNAM2",PAYS,"") From ATEXTRA
         If [F:TCY]ETATFLG2<>2 or GFMT="" or GINTZON=""
           GFMT = "1X"  # Pour les tarifs ne doit pas être invisible
           Call TEXTE(31745, GINTZON) From OBJDIV  # "Subdivisions géographiques"
           mkstat = 1
         Else
           GINTZON = space$(type(GINTZON)-10-len(GINTZON))+GINTZON
         Endif
      Endcase
      Gosub TITRES From ="W1"+maskcou
      Onerrgo
    Else
      GFMT = num$(GLONSAT) + "X"  # Pour les tarifs sans pays On ne peut pas contrôler la valeur
      Call TEXTE(31745, GINTZON) From OBJDIV  # "Subdivisions géographiques"
    Endif
    # -----------------------------------------
  Endif
End

##################################################
Subprog OLD_FMTSATPAY(PAYS)
Value    Char    PAYS
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
If PAYS="" : PAYS = GPAYS : Endif
If PAYS<>[F:TCY]CRY
 Read [TCY]TCY0 = PAYS
Endif
Onerrgo RIEN
Case [F:TCY]ETAT
 When 1
  GFMT = ""
  GINTZON = ""
 When 2 : # Saisie subdivision 1
  GFMT = [F:TCY]ETATFMT
  Call LECTEXTRA(GINTZON,"TABCOUNTRY","ETATNAM",PAYS,"") From ATEXTRA
  If [F:TCY]ETATFLG<>2 or GFMT="" or GINTZON=""
   GFMT = ""
   GINTZON = ""
  Else
   GINTZON = space$(type(GINTZON)-10-len(GINTZON))+GINTZON
  Endif
 When 3 : # Saisie subdivision 2
  GFMT = [F:TCY]ETATFMT2
  Call LECTEXTRA(GINTZON,"TABCOUNTRY","ETATNAM2",PAYS,"") From ATEXTRA
  If [F:TCY]ETATFLG2<>2 or GFMT="" or GINTZON=""
   GFMT = ""
   GINTZON = ""
  Else
   GINTZON = space$(type(GINTZON)-10-len(GINTZON))+GINTZON
  Endif
Endcase
Gosub TITRES From ="W1"+maskcou
Onerrgo
End

