### Subprog CDVINI(COURS,DEVorg,devdes,TYPCUR,DAT)
### Subprog CONVERT(MTORG,DEVORG,MTDES,DEVDES,COURS)
##########################################################
### Subprog LITTABDEP(DEPCOD,DELAI,TAUX)
### Subprog ESC_AGIO(DEP,AMT,DATREF,DATPCE,DELAI,TAUX,AMTDEP,ACCNUM,DUDLIG)
### Subprog ARRDEV(MNT,DEV)
### Subprog QTEARR(QTE,UNITE)
### Subprog QTEARR2(QTE,UNITE,TYP)
### Subprog FMTQTY(UNITE)
### Subprog QTENBDEC(UNITE,NBDEC)
### Subprog QTEDEC(QTE,DEC)
##########################################################
### Subprog LECPAY(PAYS)
### Subprog FMTTELPAY(PAYS)
### Subprog SAIPAYS(PAYS)
### Subprog SAISAT(PAYS)
### Subprog INIPAYS(PAYS,NOMPAY) : # Initialisation nom du pays
##########################################################
# Utilisez cette zone de programmes pour tester vos sous-pro
Local Decimal COURS , RESULT
Local Integer SPSTAT
Call COURDEV("EUR","CHF",1,date$,COURS,SPSTAT)
Call CONVERT(12345.67,"USD",RESULT,"EUR",COURS)
End

##########################################################
$ACTION
Case ACTION
 When "TRT_DIV"   : Gosub TRT_DIV
 When "SEL_TABLE" : Gosub SEL_TABLE
Endcase
Return

##########################################################
$SEL_TABLE
Case TABLE
 When "SELSAT" : Gosub SEL_SAT : # Sélection état
 When "VCRSEL" : Gosub SEL_VCR : # Action sur type de données VCR
Endcase
Return

$SEL_VCR
OBJET = PARAM(1)
SUPP  = PARAM(2)
Return

#########################################################
$SEL_SAT
Local Char PAYS(GLONCRY)
Local Char SCONTEXTE(type(PARAM(2))-10)

  # FGR 06/03/2012 : X3SUIVI79830
  PAYS = PARAM(1)
  SCONTEXTE = PARAM(2)
  If (SCONTEXTE = "" or (SCONTEXTE = "2" and PAYS <> "")) Then  # FGR 24/05/2012 : X3SUIVI81067
    # Cas d'utilisation : on affiche la liste
    If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
    If clalev([F:ATU])=0 : Local File TABSUBDIV  [ATU] : Endif
    If PAYS="" : PAYS = GPAYS : Endif
    If PAYS<>[F:TCY]CRY
      Read [TCY]TCY0 = PAYS
    Endif
    If !find([F:TCY]ETAT,2,3)
      OK = 0
    Elsif func AFNC.ACTIV("KAG") & [F:TCY]ISO="AR"
      If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
      Default File [ADI]
      CRITERE = 'NUMTAB = 364'
      OBJET = "ADI"
      START = "[F:ADI]CODE"
    Else
      OBJET = "AT0"
      CRITERE = 'CRY = "'+PAYS+'"'
      CRITERE += '& TYP = '+num$([F:TCY]ETAT)
      ORDRE = "[F:ATU]COD"
      START = "[F:ATU]COD"
    Endif
  Endif
Return

#########################################################
# FGR : SAUVEGARDE ANCIENNES ETIQUETTES
#########################################################
$OLD_SEL_SAT
Local Char PAYS(GLONCRY)
PAYS = PARAM(1)
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
If clalev([F:ATU])=0 : Local File TABSUBDIV  [ATU] : Endif
If PAYS="" : PAYS = GPAYS : Endif
If PAYS<>[F:TCY]CRY
 Read [TCY]TCY0 = PAYS
Endif
If !find([F:TCY]ETAT,2,3)
 OK = 0
Elsif func AFNC.ACTIV("KAG") & [F:TCY]ISO="AR"
 If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
 Default File [ADI]
 CRITERE = 'NUMTAB = 364'
 OBJET = "ADI"
 START = "[F:ADI]CODE"
Else
 OBJET = "AT0"
 CRITERE = 'CRY = "'+PAYS+'"'
 CRITERE += '& TYP = '+num$([F:TCY]ETAT)
 ORDRE = "[F:ATU]COD"
 START = "[F:ATU]COD"
Endif
Return

#########################################################
$TRT_DIV
Case TRAIT
 When "CTLSAT" : Gosub CTL_SAT : # Contrôle état
 When "TUNSAT" : Gosub TUN_SAT : # Tunnel subdivsions géographiques
 When "INISAT" : Gosub INI_SAT : # Activation des boutons pour "AR"
Endcase
Return

#########################################################
$CTL_SAT
Local Char PAYS(GLONCRY)
Local Char SCONTEXTE(type(PARAM(2))-10)

  # FGR 06/03/2012 : X3SUIVI79830
  If VALEUR <> "" Then
    PAYS = PARAM(1)
    SCONTEXTE = PARAM(2)
    If (SCONTEXTE = "" or (SCONTEXTE = "2" and PAYS <> "")) Then  # FGR 24/05/2012 : X3SUIVI81067
      # Cas d'utilisation : on fait les contrôles
      If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
      If clalev([F:ATU])=0 : Local File TABSUBDIV  [ATU] : Endif
      If PAYS="" : PAYS = GPAYS : Endif
      If PAYS<>[F:TCY]CRY
        Read [TCY]TCY0 = PAYS
      Endif
      If find([F:TCY]ETAT,2,3) Then
        If func AFNC.ACTIV("KAG") & [F:TCY]ISO="AR"
          If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
          Read [ADI]CODE=364;VALEUR
          If fstat
            GMESSAGE = mess(5,8890,1) : # Province inexitante
            mkstat = 2 : End
          Endif
        Else
          If [F:TCY]ETATCTL = 2 Then
            Read [ATU]ATU0=PAYS;[F:TCY]ETAT;VALEUR
            If fstat
              GMESSAGE = VALEUR-":"-mess(23,100,1) : # Fiche inexistante
              mkstat = 2 : End
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
Return

#########################################################
$TUN_SAT
Local Char PAYS(GLONCRY)
Local Char SCONTEXTE(type(PARAM(2))-10)
Local Integer TYP

  # FGR 06/03/2012 : X3SUIVI79830
  PAYS = PARAM(1)
  SCONTEXTE = PARAM(2)
  #
  If (SCONTEXTE = "" or (SCONTEXTE = "2" and PAYS <> "")) Then  # FGR 24/05/2012 : X3SUIVI81067
    # Cas d'utilisation : on active les tunnels
    If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
    If clalev([F:ATU])=0 : Local File TABSUBDIV  [ATU] : Endif
    If PAYS="" : PAYS = GPAYS : Endif
    If PAYS<>[F:TCY]CRY
      Read [TCY]TCY0 = PAYS
    Endif
    If find([F:TCY]ETAT,2,3)
      If func AFNC.ACTIV("KAG") & [F:TCY]ISO="AR"
        If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
        Call OBJET_CHAR(VALEUR,"ADI","364") From GOBJET
      Else
        TYP = [F:TCY]ETAT
        Call OBJET_LIB(TYP,"ATU",PAYS+"~"+VALEUR) From GOBJET
      Endif
    Endif
  Else
    # Si SCONTEXTE<>"" pas de tunnel
  Endif
Return

#########################################################
$INI_SAT
Local Char PAYS(GLONCRY)
Local Char SCONTEXTE(type(PARAM(2))-10)

  # FGR 06/03/2012 : X3SUIVI79830
  PAYS = PARAM(1)
  SCONTEXTE = PARAM(2)
  #
  If (SCONTEXTE = "" or (SCONTEXTE = "2" and PAYS <> "")) Then  # FGR 24/05/2012 : X3SUIVI81067
    # Cas d'utilisation : on gère les boutons
    If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
    If PAYS="" : PAYS = GPAYS : Endif
    If PAYS<>[F:TCY]CRY
      Read [TCY]TCY0 = PAYS
    Endif
    If func AFNC.ACTIV("KAG") & [F:TCY]ISO="AR"
      Case [F:TCY]ETAT
        When 2       : Call LECTEXTRA(GBOUT2,"TABCOUNTRY","ETATNAM",PAYS,"") From ATEXTRA
        When 3       : Call LECTEXTRA(GBOUT2,"TABCOUNTRY","ETATNAM2",PAYS,"") From ATEXTRA
        When Default : Raz GBOUT2
      Endcase
    Else
      If [F:TCY]ETAT < 2 Then
        # Si pas saisie subdivision, on efface les boutons
        Raz GBOUTS , GBOUT2
      Endif
    Endif
  Else
    # Cas de paramétrage, on désactive les boutons
    Raz GBOUTS , GBOUT2
  Endif
Return

#########################################################
# FGR : SAUVEGARDE ANCIENNES ETIQUETTES
#########################################################
$OLDCTL_SAT
Local Char PAYS(GLONCRY)

PAYS = PARAM(1)
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
If clalev([F:ATU])=0 : Local File TABSUBDIV  [ATU] : Endif
If PAYS="" : PAYS = GPAYS : Endif
If PAYS<>[F:TCY]CRY
 Read [TCY]TCY0 = PAYS
Endif
If find([F:TCY]ETAT,2,3)
 If func AFNC.ACTIV("KAG") & [F:TCY]ISO="AR"
  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  Read [ADI]CODE = 364 ; VALEUR
  If fstat
   GMESSAGE = mess(5,8890,1) : # Province inexitante
   mkstat = 2 : End
  Endif
 Elsif 1=0 : # Pour le moment, on saisi l'intitulé et pas le code subdivision
  Read [ATU]ATU0=PAYS;[F:TCY]ETAT;VALEUR
  If fstat
   GMESSAGE = VALEUR-":"-mess(23,100,1) : # Fiche inexistante
   mkstat = 2 : End
  Endif
 Endif
Endif
Return

$OLD_TUN_SAT
Local Char PAYS(GLONCRY)
Local Integer TYP
PAYS = PARAM(1)
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
If clalev([F:ATU])=0 : Local File TABSUBDIV  [ATU] : Endif
If PAYS="" : PAYS = GPAYS : Endif
If PAYS<>[F:TCY]CRY
 Read [TCY]TCY0 = PAYS
Endif
If find([F:TCY]ETAT,2,3)
 If func AFNC.ACTIV("KAG") & [F:TCY]ISO="AR"
  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  Call OBJET_CHAR(VALEUR,"ADI","364") From GOBJET
 Else
  TYP = [F:TCY]ETAT
  Call OBJET_LIB(TYP,"ATU",PAYS+"~"+VALEUR) From GOBJET
 Endif
Endif
Return

$OLD_INI_SAT
Local Char PAYS(GLONCRY)
PAYS = PARAM(1)
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
If PAYS="" : PAYS = GPAYS : Endif
If PAYS<>[F:TCY]CRY
 Read [TCY]TCY0 = PAYS
Endif
If func AFNC.ACTIV("KAG") & [F:TCY]ISO="AR"
 Case [F:TCY]ETAT
  When 2       : Call LECTEXTRA(GBOUT2,"TABCOUNTRY","ETATNAM",PAYS,"") From ATEXTRA
  When 3       : Call LECTEXTRA(GBOUT2,"TABCOUNTRY","ETATNAM2",PAYS,"") From ATEXTRA
  When Default : Raz GBOUT2
 Endcase
Else : # Pour + tard
 Raz GBOUTS , GBOUT2
Endif
Return

#####################################################################
Subprog COURSIT(DEVORG,SITE,TYPCUR,DAT,COURS,SPSTAT)
Value    Char    DEVORG
Value    Char    SITE
Value    Libelle TYPCUR
Value    Date    DAT
Variable Decimal COURS
Variable Integer SPSTAT
Local Char DEVDES(GLONCUR)
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If SITE="" : SITE = GFCYDEF : Endif
# Issue 74556 - 2011-07-04 by VPO : lecture ssi besoin
#Call LECTURE("FCY",SITE,"") From CONTOBJ
If [F:FCY]FCY<>SITE
  Read [FCY] FCY0=SITE         : If fstat  Raz [F:FCY] : Endif
Endif
# Issue 74556 - 2011-07-04 by VPO : lecture ssi besoin
#Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
If [F:CPY]CPY<>[F:FCY]LEGCPY
  Read [CPY] CPY0=[F:FCY]LEGCPY : If fstat  Raz [F:CPY] : Endif
Endif

DEVDES = [F:CPY]ACCCUR
Goto COURS

Subprog COURDEV(DEVORG,DEVDES,TYPCUR,DAT,COURS,SPSTAT)
Value    Char    DEVORG
Value    Char    DEVDES
Value    Libelle TYPCUR
Value    Date    DAT
Variable Decimal COURS
Variable Integer SPSTAT

$COURS
SPSTAT = 0
If DAT=[0/0/0] : DAT = GHIDATE : Endif
If DEVORG=DEVDES
 COURS = 1
Else
 If clalev([F:TCH])=0 : Local File TABCHANGE [TCH] : Endif
 Filter [TCH] Where CHGTYP=TYPCUR & CURDEN=DEVDES & CUR=[L]DEVORG & CHGSTRDAT<=DAT
 Read [TCH]TCH0 Last
 If fstat<=2
  #COURS = [F:TCH]CHGRAT/[F:TCH]CHGDIV
  COURS = [F:TCH]CHGDIV/[F:TCH]REVCOURS
 Else
  Filter [TCH] Where CHGTYP=TYPCUR & CURDEN=[L]DEVORG & CUR=[L]DEVDES & CHGSTRDAT<=DAT
  Read [TCH]TCH0 Last
  If fstat<=2
   #COURS = 1/([F:TCH]CHGRAT/[F:TCH]CHGDIV)
   COURS = [F:TCH]REVCOURS/[F:TCH]CHGDIV
  Else
   #--- Issue 108240
   #COURS = 1 : SPSTAT = 1
   COURS = 1 : SPSTAT = 99 : GMESSAGE=mess(16,114,1)
   #---
  Endif
 Endif
 Filter [TCH]
Endif
End

##########################################
Subprog CONVERT(MTORG,DEVORG,MTDES,DEVDES,COURS)
Value    Decimal MTORG
Value    Char    DEVORG
Variable Decimal MTDES
Value    Char    DEVDES
Value    Decimal COURS
# Pour l'instant, on fait un bête arrondi dans la devise de destination
# après, on verra
If clalev([F:TCU])=0 : Local File TABCUR [TCU] : Endif
Call LECDEV(DEVDES)
MTDES = arr(MTORG*COURS,[F:TCU]CURRND)
End

###########################################################################
Subprog CDVRAZ(COURS)
Variable Decimal COURS
# Action CDVRAZ
# Remise à zéro du cours de devise après modif de la devise
If COURS<> 0
  COURS = 0
Endif
End

###########################################################################
Subprog CDVINI(COURS,DEVORG,DEVDES,TYPCUR,DAT)
Variable Decimal COURS  : # Cours devise
Value    Char    DEVORG : # Devise de saisie
Value    Char    DEVDES : # Devise de destination
Value    Integer TYPCUR : # Type de cours
Value    Date    DAT    : # Date du document
# Action  : CDVINI
# Comment : Détermination d'un cours de devise pour une devise,
#           une date et un type de cours donné
# BY le 24/02/98, on n'initialise plus le cours
# un bouton permet de l'initialiser
If DEVORG=DEVDES : COURS = 1 : mkstat = 2 : End : Endif
If GFONCTION="COURDEV"
 GBOUT2 = ""
Else
 GBOUT2 = mess(85,105,1) : # Init cours
Endif
End

Subprog CDVCAL(COURS,DEVORG,DEVDES,SOC,TYPCUR,DAT)
Variable Decimal COURS  : # Cours devise
Value    Char    DEVORG : # Devise de saisie
Value    Char    DEVDES : # Devise de destination
Value    Char    SOC    : # Devise socièté   # FQ 69909 Ctrl des sources avant DEVSOC
Value    Integer TYPCUR : # Type de cours
Value    Date    DAT    : # Date du document

# gh 11/02/99
Local Integer STAT
Local Char    DEVSOC(GLONCUR)

COURS = 1
STAT  = find(SOC,GSOC(1..GNBSOC))
If !STAT
 STAT = find(SOC,GSITE(1..GNBSITE))
 If STAT : STAT = find(GSOCSITE(STAT),GSOC(1..GNBSOC)) : Endif
Endif
If !STAT : End : Endif
DEVSOC = GDEVSOC(STAT)
Call CONVERT(DEVORG,DEVDES,DEVSOC,TYPCUR,DAT,10^GDECRCU,COURS,STAT) From TRTDEV
COURS = arr(COURS/10^GDECRCU,10^-GDECRCU)
End

If DAT=[0/0/0] : DAT = GHIDATE : Endif
If clalev([F:TCH])=0 : Local File TABCHANGE [TCH] : Endif
Filter [TCH] Where CHGTYP=TYPCUR & CURDEN=DEVDES & CUR=[L]DEVORG & CHGSTRDAT<=DAT
Read [TCH]TCH0 Last
If fstat<=2
 COURS = [F:TCH]CHGRAT/[F:TCH]CHGDIV
Else
 Filter [TCH] Where CHGTYP=TYPCUR & CURDEN=[L]DEVORG & CUR=[L]DEVDES & CHGSTRDAT<=DAT
 Read [TCH]TCH0 Last
 If fstat<=2
  COURS = 1/([F:TCH]CHGRAT/[F:TCH]CHGDIV)
 Else
  COURS = 1
 Endif
Endif
Filter [TCH]
End

###########################################################################
# lit la devise (si nécessaire) pour récupérer le format
Subprog LECDEV(DEV)
Value Char DEV
If DEV="" : DEV = GLOCALDEV : Endif
If DEV<>[F:TCU]CUR
 Read [TCU]TCU0 = DEV
Else        :# (Modif TB 13/08/99) NE PAS ECRASER SVP !!!!!!
 fstat = 0  :# fstat est attendu en retour du sous-pro
Endif
# BY Il vaut mieux ne pas passer par LECTURE
# ca ralentit dans les gros tableaux
#Call LECTURE("TCU",DEV,"") From CONTOBJ
End

###########################################################################
Subprog FMTFM1DEV(DEV)
Value Char DEV
If clalev([F:TCU])=0 : Local File TABCUR [TCU] : Endif
If DEV="" : DEV = GLOCALDEV : Endif
If DEV<>[F:TCU]CUR
 Read [TCU]TCU0 = DEV
Endif
GFMT = [F:TCU]CURFMT1
End

###########################################################################
Subprog FMTFM2DEV(DEV)
Value Char DEV
If clalev([F:TCU])=0 : Local File TABCUR [TCU] : Endif
If DEV="" : DEV = GLOCALDEV : Endif
If DEV<>[F:TCU]CUR
 Read [TCU]TCU0 = DEV
Endif
GFMT = [F:TCU]CURFMT2
End

###########################################################################
Subprog FMTFM3DEV(DEV)
Value Char DEV
If clalev([F:TCU])=0 : Local File TABCUR [TCU] : Endif
If DEV="" : DEV = GLOCALDEV : Endif
If DEV<>[F:TCU]CUR
 Read [TCU]TCU0 = DEV
Endif
GFMT = [F:TCU]CURFMT3
End

$XLECDEV
GDEVFMT   = GDEVFMT1(max(find(GDEV,GDEVISE(1..GNBDEV)),1))
Return

$XLECUNT
GUNTFMT   = GUNTFMT1(max(find(GUNT,GUNITE(1..GNBUNT)),1))
Return

$SETDEV
Local Integer I
For I=1 To dim(GDEV1)
 GDEVFM1(I) = GDEVFMT1(max(find(GDEV1(I),GDEVISE(1..GNBDEV)),1))
Next I
For I=1 To dim(GUNT1)
 GUNTFM1(I) = GUNTFMT1(max(find(GUNT1(I),GUNITE(1..GNBUNT)),1))
Next I
Return

###########################################################################
# lit la devise (pour récupérer le format) puis ARRONDIT le montant
Subprog ARRDEV(MNT,DEV)
Variable Decimal MNT
Variable Char DEV
If DEV = "" : DEV = GLOCALDEV : Endif
If clalev([F:TCU]) = 0 : Local File TABCUR [TCU] : Endif
Call LECDEV(DEV)
If fstat = 0
 MNT = arr(MNT,[F:TCU]CURRND)
Endif
End

###########################################################################
# SUBPROG LITTABDEP(DEP,DELAI,TAUX)
# ramène le taux d'escompte ou agio à partir du code(clé) et du délai
# (suppose que les délais vont croissant)

#####################################################################
Subprog LITTABDEP(DEP,DELAI,TAUX)
Value Char DEP
Value Integer DELAI
Variable Decimal TAUX
Local Char LEG(GLONADI) : LEG=""
If GNBLEG = 1
 LEG = GDOSLEG
Elsif dim(GCURLEG) & GCURLEG<>""
 LEG = GCURLEG
Endif
Gosub LITTABDEP2
End

$LITTABDEP2
Local Integer OK
TAUX = 0
OK = 0
If clalev([F:TDA]) = 0 : Local File TABDEPAGIO : Endif
Call LEC_TDA(LEG,DEP) From CPTLEC
If fstat : Raz [F:TDA] : Return : Endif
# pour l'Escompte on prend le poste juste supérieur
# pour l'agio     on prend le poste juste inférieur
For I = 0 To dim([F:TDA]DEPRAT)-1
 If [F:TDA]DEPDAY(I) > DELAI
  If DELAI < 0
   TAUX = [F:TDA]DEPRAT(I)
  Elsif I > 0
   TAUX = [F:TDA]DEPRAT(I - 1)
  Endif
  OK = 1 : Break
 Endif
Next

# 79249 et 80728
# on n'a rien trouvé et il s'agit d'un retard, donc on prend le taux non nul correspondant au nombre de jours maximum ET positif
If DELAI>0 and OK=0
 For I=dim([F:TDA]DEPRAT)-1 To 0 Step -1
  If [F:TDA]DEPDAY(I)>0 and [F:TDA]DEPRAT(I)<>0 : TAUX = [F:TDA]DEPRAT(I) : Break : Endif
 Next
Endif
End


###########################################################################
# SUBPROG ESC_AGIO(DEP,AMT,DATREF,DATPCE,DELAI,TAUX,AMTDEP,ACCNUM,DUDLIG)
# Calcul le montant de l'escompte agio
###########################################################################
Subprog ESC_AGIO(DEP,AMT,DATREF,DATPCE,DELAI,TAUX,AMTDEP,ACCNUM,DUDLIG)
Value    Char    DEP       # Code d'Escompte/Agio
Value    Decimal AMT       # Montant de base
Value    Date    DATREF    # Date de référence
Value    Date    DATPCE    # Date de la pièce initial
Variable Integer DELAI     # Délai
                           # (si délai=0, on calcule la <> entre les 2 dates précédentes : DATREF-DATPCE)
Variable Decimal TAUX      # Taux d'escompte ou d'agio
                           # (si taux<>0, on ne recherche pas le taux par rapport au code DEP)
                           # (Règle générale : taux<0 --> escompte / taux>0 --> agio)
Variable Decimal AMTDEP    # Montant de l'escompte ou de l'agio
Value    Integer ACCNUM    #
Value    Integer DUDLIG    # ACCNUM + DUDLIG : permet d'identifier l'échéance
                           # (possibilité de remonter jusqu'à la pièce comptable, facture...)
#CHECK IGNORE_BEGIN
Call DSCAMTCAL(DEP,AMT,DATREF,DATPCE,DELAI,TAUX,AMTDEP,ACCNUM,DUDLIG) From PAYDEPLIB3
#CHECK IGNORE_END
GPOINT = "ESC_AGIO" : Gosub ENTREE From EXEFNC
End


###########################################################################
# Lecture de l'unite et arrondi
Subprog QTEARR(QTY,UOM)
Variable Decimal QTY
Value Char UOM

If QTY=0 | UOM="" End Endif     : # Bug 73721
# lecture de l'unité
If clalev([F:TUN]) = 0 : Local File TABUNIT [TUN] : Endif
If UOM <> "" & UOM<>[F:TUN]UOM   # FQ 70409 GA 01/2011 PERFORMANCES ne pas relire si unité déjà lue
 Read [TUN]TUN0 = UOM : If fstat Raz [F:TUN] Endif
Endif
# le format est determiné par la variable globale GF..(7)
# Arrondi de la quantité selon nb de décimales :
#If QTY <> 0 & fstat = 0        : # Bug 73721
If QTY <> 0                     : # Bug 73721
 Case [F:TUN]UOMDEC
  When 0 : QTY = arr(QTY,1)
  When 1 : QTY = arr(QTY,0.1)
  When 2 : QTY = arr(QTY,0.01)
  When 3 : QTY = arr(QTY,0.001)
  When 4 : QTY = arr(QTY,0.0001)
  When 5 : QTY = arr(QTY,0.00001)
  When 6 : QTY = arr(QTY,0.000001)
 Endcase
# ou mieux : arr(QTY,10^-[F:TUN]UOMDEC)
Endif
End

# Le formatage (arrondi) de la quantité depuis un batch ...
# se fait par appel au sous-prog ci-dessus

###########################################################################
# Lecture de l'unite et arrondi
#    QTY : quantité
#    UOM : unité
#    TYP : type arrondi (1=au plus proche, 2=supérieur, 3=inférieur
#
Subprog QTEARR2(QTY,UOM,TYP)
Variable Decimal QTY
Value    Char    UOM
Value    Integer TYP

Local Decimal QTYARR

If QTY=0 | UOM="" End Endif     : # Bug 73721
# lecture de l'unité
If clalev([F:TUN]) = 0 : Local File TABUNIT [TUN] : Endif
If UOM <> "" & UOM<>[F:TUN]UOM   # FQ 70409 GA 01/2011 PERFORMANCES ne pas relire si unité déjà lue
 Read [TUN]TUN0 = UOM : If fstat Raz [F:TUN] Endif
Endif

# Arrondi de la quantité selon nb de décimales :
#If QTY <> 0 & fstat = 0        : # Bug 73721
If QTY <> 0                     : # Bug 73721
 QTYARR = arr(QTY,10^-[F:TUN]UOMDEC)
 Case TYP
  When 1 : QTY = QTYARR
  When 2 : If QTYARR - QTY >= 0 : # QTYARR >= QTY : # Issue 39115 GH 13/11/2017 - it gets around a runtime bug
              QTY = QTYARR
           Else
              Case [F:TUN]UOMDEC
               When 0 : QTY = QTYARR+1
               When 1 : QTY = QTYARR+0.1
               When 2 : QTY = QTYARR+0.01
               When 3 : QTY = QTYARR+0.001
               When 4 : QTY = QTYARR+0.0001
               When 5 : QTY = QTYARR+0.00001
               When 6 : QTY = QTYARR+0.000001
              Endcase
           Endif
  When 3 : If QTYARR - QTY <= 0 : # QTYARR <= QTY : # Issue 39115 GH 13/11/2017 - it gets arround a runtime bug
              QTY = QTYARR
           Else
              Case [F:TUN]UOMDEC
               When 0 : QTY = QTYARR-1
               When 1 : QTY = QTYARR-0.1
               When 2 : QTY = QTYARR-0.01
               When 3 : QTY = QTYARR-0.001
               When 4 : QTY = QTYARR-0.0001
               When 5 : QTY = QTYARR-0.00001
               When 6 : QTY = QTYARR-0.000001
              Endcase
           Endif
 Endcase
Endif
End

###################################################
## Init du format des quantités                  ##
###################################################
Subprog FMTQTY(UOM)
Value Char UOM
Local Integer WDEC, I

# lecture de l'unité
If clalev([F:TUN]) = 0 : Local File TABUNIT [TUN] : Endif
Case UOM
  When "", "0" :
    WDEC = -1
  When "1","2","3","4","5","6","7","8","9" :
    WDEC = val(UOM)
  When Default :
    I = find(UOM,GSUOM(0..dim(GSUOM)-1))
    If I <> 0
      WDEC =  GSUOMD(I-1)
    Else
      Read [TUN]TUN0=UOM
        If fstat
          WDEC = -1
        Else
          WDEC = [F:TUN]UOMDEC
          For I = dim(GSUOM)-2 To 0 Step -1
            GSUOM(I+1)  = GSUOM(I)
            GSUOMD(I+1) = GSUOMD(I)
          Next I
          GSUOM(0)  = [F:TUN]UOM
          GSUOMD(0) = [F:TUN]UOMDEC
        Endif
    Endif
Endcase
If WDEC < 0
  GFMTQTY = "15F"
Else
  If WDEC = 0
    GFMTQTY = "15#"
  Else
    GFMTQTY = num$(14-WDEC)+"."+num$(WDEC)+"#"
  Endif
Endif
End
####################################################
# Nombre de décimales d'une unité                  #
#   UOM   = Unité à traiter                        #
#   NBDEC = Nombre de décimale de l'unité traitée  #
####################################################
Subprog QTENBDEC(UOM,NBDEC)
Value    Char     UOM
Variable Shortint NBDEC
Raz NBDEC
If clalev([F:TUN])=0 : Local File TABUNIT [TUN] : Endif
If UOM<>""
   If UOM<>[F:TUN]UOM   # FQ 70409 GA 01/2011 PERFORMANCES ne pas relire si unité déjà lue
      Read [TUN]TUN0=UOM : If fstat Raz [F:TUN] Endif
   Endif
   NBDEC=[F:TUN]UOMDEC
Endif
End

###################################################
## Nombre de chifrres significatifs après virgule
## LQTE = tableau des zones a analyser
## LTAB = taille tableau (bas tableau) a partir de 1
## LDEC = Nombre de decimales CHARGEE SEULEMENT SI > VALEUR EN ENTREE
###################################################
Subprog QTEDEC(LQTE,LTAB,LDEC)
Value    Decimal LQTE()
Value    Decimal LTAB
Variable Integer LDEC
Local    Decimal WQTE
Local    Integer WDEC
Local    Integer I
For I = 0 To LTAB-1
  If LQTE(I) <> 0
    WQTE = (LQTE(I) - int(LQTE(I)))
    WDEC = 0
    While WQTE <> int(WQTE)
      WQTE *= 10
      WDEC += 1
    Wend
#Chargement resultat si > valeur d'entrée
    If WDEC > LDEC
      LDEC = WDEC
    Endif
  Endif
Next I
End

