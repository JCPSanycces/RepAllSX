###############################################
## Formattage des valeurs pour le web
###############################################
Subprog FORMDEC(VALEUR,FORMA)
Variable Decimal VALEUR
Value    Char    FORMA
If find(left$(FORMA,1),"+","-","/") : FORMA = right$(FORMA,2) : Endif
Onerrgo RIEN
VALEUR = val(ctrans(format$(FORMA,VALEUR),seg$(adxsca,3,4)," ."))
Onerrgo
End

Subprog FORMCHA(VALEUR,FORMA)
Value    Char    VALEUR()
Value    Char    FORMA()
Local Integer OK, I, J, K
I = instr(1,FORMA,":")
If !I: End : Endif
If VALEUR=""
 # Option 1
 J=instr(1,FORMA,"1")
 If J & J<I
  GMESSAGE=mess(10,123,1) : # Zone obligatoire
  mkstat=2 : End
 Endif
Endif
FORMA = right$(FORMA,I+1)

# Suppression des commentaires du format
Repeat
 I=instr(1,FORMA,"[")
 If I
  J=instr(I,FORMA,"]")
  If J : FORMA=left$(FORMA,I-1)+right$(FORMA,J+1) : Endif
 Endif
Until !J | !I
If I & !J : OK=0
Else
 # Format du type 12X30X>40X
 J = instr(1,FORMA,">")
 If J
  K=val(FORMA)+val(right$(FORMA,J+1))
  I=1
  While instr(1,"0123456789",mid$(FORMA,I,1)) : I += 1 : Wend
  FORMA = num$(K)+mid$(FORMA,I,1)
 Endif
 OK=(VALEUR=vireblc(format$("K:"+FORMA,VALEUR),1))
Endif
If !OK
 GMESSAGE=mess(112,123,1) : # Format incorrect
 mkstat=2
Endif
End

Subprog FORMDAT(VALEUR,FORMA)
Variable Date    VALEUR
Value    Char    FORMA
If find(left$(FORMA,1),"+","-","/") : FORMA = right$(FORMA,2) : Endif
Onerrgo RIEN
Onerrgo
End

Subprog FORMLIB(VALEUR,FORMA)
Variable Integer VALEUR
Value    Char    FORMA
If find(left$(FORMA,1),"+","-","/") : FORMA = right$(FORMA,2) : Endif
Onerrgo RIEN
VALEUR = val(ctrans(format$(FORMA,VALEUR),seg$(adxsca,3,4)," ."))
Onerrgo
End

## Le sous-programme REINIT_COURS permet de ré-initialiser le cours par point d'entrée
Subprog REINIT_COURS(DEVORG,SITE,TYPCUR,DAT,COURS,SPSTAT)
Value    Char    DEVORG        : # Devise origine
Value    Char    SITE          : # Site
Value    Libelle TYPCUR        : # Type de cours
Value    Date    DAT           : # Date du cours
Variable Decimal COURS         : # Cours
Variable Integer SPSTAT        : # Statut de retour
GPOINT = "COURS" : Gosub ENTREE From EXEFNC
End

$RIEN
Resume


