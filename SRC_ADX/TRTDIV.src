COMPTEUR = toupper(COMPTEUR)
End

#########################################################################
# garni le format de saisie pour les colonnes rem/frais des tarifs      #
# garni le code format "%" ou "M" dans GFMTREM (0..8)                   #
#-----------------------------------------------------------------------#
# IMPERATIF : Appeler COLREM auparavant                                 #
#########################################################################
Subprog FMTREM(NUMREM,DEVISE)
Value    Decimal  NUMREM
Value    Char     DEVISE
If [F:TCU]CUR<>DEVISE
   Call LECDEV(DEVISE) From TRTDIV
Endif
If NUMREM>0
 Case GFMTREM(NUMREM-1)
  When "%"
       GFORREM = "3.2#[   ]"
  When "M"
       GFORREM = [F:TCU]CURFMT2
       If [F:TCU]CURFMT2="8"
          GFORREM = [F:TCU]CURFMT2 + "[ ]"
       Endif
 Endcase
Endif
If NUMREM=0 | GCOLREM(NUMREM-1)=""
   GFORREM = "[         ]"
Endif
End

###########################################################################
## Valeur par défaut des tables diverses
###########################################################################
Subprog INIADI(VALEUR,TABLE)
Variable Char VALEUR()
Value    Char TABLE
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
Filter [ADI] Where NUMTAB=val(TABLE) & DEFVAL=2
Read [ADI] First
Filter [ADI]
If fstat<=2
 VALEUR = [F:ADI]CODE
Endif
End


