##################################################
# FGR 16/12/2014 : X3SUIVI104659 : X3SUIVI86548 n'avait pas été repris sur cette version ?
Subprog FMTADRPAY(PAYS)
Value    Char    PAYS

Local Integer IEXISTSAT                # FGR 07/03/2012 : X3SUIVI79830
Local Char SCONTEXT(GLONDES)           # FGR 07/03/2012 : X3SUIVI79830
Local Char SZADXIFS(type(adxifs)-10)   # FGR 07/03/2012 : X3SUIVI79830
Local Char SZADXIRS(type(adxirs)-10)   # FGR 07/03/2012 : X3SUIVI79830
Local Char SZPROGNAME(GLONADC)         # FGR 07/03/2012 : X3SUIVI79830
Local Char SZFULLSRC(250)              # FGR 07/03/2012 : X3SUIVI79830
Local Char SZFULLADX(250)              # FGR 07/03/2012 : X3SUIVI79830
Local Integer IVALIDOK                 # FGR 07/03/2012 : X3SUIVI79830
Local Integer SVINDICE                 # FGR 07/03/2012 : X3SUIVI79830
Local Integer PSUBB                    # FGR 12/12/2012 : X3SUIVI86548
Local Integer IOK                      # FGR 12/12/2012 : X3SUIVI86548

  Local File TABCOUNTRY [TCY]
  If PAYS="" : PAYS = GPAYS : Endif
  Read [TCY]TCY0 = PAYS
  # -------------------------------------
  If GHISTO <> 1 Then  # FGR 22/02/2013 : X3SUIVI88034 : ne pas faire ça sur un dossier historique
    # FGR 07/03/2012 : X3SUIVI79830 (début)
    SVINDICE = indice
    If indice = 0 Then
      Local File AMSKZON [AMZ]
      Filter [AMZ] Where [F:AMZ]CODMSK = maskcou and [F:AMZ]CODTYP = "SAT" and [F:AMZ]SAIAFF = 1
      IEXISTSAT = 0
      For [F:AMZ]
        IEXISTSAT = 1
        # -----------
        indice = 0
        SZADXIFS = adxifs
        SZADXIRS = adxirs
        adxifs = ""
        adxirs = chr$(10)
        # --------------------------------------------------
        # FGR 12/12/2012 : X3SUIVI86548 : Pour traiter problème de performance le traitement généré est conservé
        #                  Il a un nom lié à l'écran, la zone et le pays. Il est donc utilisé par tout le monde.
        #                  C'est seulement le premier qui y accède pour un pays qui génère et valide le traitement
        #                  On test aussi que la fiche pays n'a pas été modifiée. Si elle l'a été, on détruit le traitement
        #                  et on le regénère.
        # --------------------------------------------------
        SZPROGNAME = "WSAT" + [F:AMZ]CODMSK + [F:AMZ]CODZON + PAYS
        # jira X3-91106 le trt genere en W doit etre recupere uniquement du dossier
        # il faut mettre le nom dossier en param 2
        # Call EXISTE_ADX("","",SZPROGNAME,PSUBB) From ORDSYS
        Call EXISTE_ADX("",nomap,SZPROGNAME,PSUBB) From ORDSYS
        If PSUBB Then
          # On regarde si le traitement est toujours valable
          Call CTRLDATE(IOK) From =SZPROGNAME
          If IOK = 0 Then
            Call EFFACE(SZFULLSRC, IVALIDOK) From ORDSYS
            Call EFFACE(SZFULLADX, IVALIDOK) From ORDSYS
            PSUBB = 0
          Endif
        Endif
        If PSUBB Then
          Gosub DYNAMIQUE From =SZPROGNAME
        Else
          SZFULLSRC = filpath("TRT", SZPROGNAME, "src", nomap)
          SZFULLADX = filpath("TRT", SZPROGNAME, "adx", nomap)
          Openo SZFULLSRC, 0 Using [FPJT]
          # --------------------------------------------------
          Wrseq "#<AdxT"+GADOVERS+">@(#)%I%" Using [FPJT]
          Wrseq "#Traitement généré pour affzo dynamique" Using [FPJT]
          Wrseq "$DYNRIEN" Using [FPJT]
          Wrseq "Resume" Using [FPJT]
          Wrseq "" Using [FPJT]
          Wrseq "$DYNAMIQUE" Using [FPJT]
          Wrseq "Onerrgo DYNRIEN" Using [FPJT]
          Wrseq "Gosub AV_" + [F:AMZ]CODZON + " From W1" + maskcou Using [FPJT]
          Wrseq "Onerrgo" Using [FPJT]
          Wrseq "Return" Using [FPJT]
          Wrseq "" Using [FPJT]
          # --------------------------------------------------
          Wrseq "Subprog CTRLDATE(IOK)" Using [FPJT]
          Wrseq "Variable Integer IOK" Using [FPJT]
          Wrseq "" Using [FPJT]
          Wrseq "  IOK = 1" Using [FPJT]
          Wrseq "  If [F:TCY]UPDDAT > [" + num$([F:TCY]UPDDAT) + "] Then" Using [FPJT]
          Wrseq "    IOK = 0" Using [FPJT]
          Wrseq "  Endif " Using [FPJT]
          Wrseq "End" Using [FPJT]
          # --------------------------------------------------
          Openo Using [FPJT]
          # --------------------------------------------------
          # On restaure les variables adxifs et adxirs
          adxifs = SZADXIFS
          adxirs = SZADXIRS
          # --------------------------------------------------
          # Compilation du traitement généré
          Call VALID("TRT", SZPROGNAME, nomap, IVALIDOK) From VALMSKSUB
          # --------------------------------------------------
          If IVALIDOK Then
            Gosub DYNAMIQUE From =SZPROGNAME
          Endif
        Endif
        # --------------------------------------------------
        indice = SVINDICE
        # -----------
        Break
      Next
      Filter [AMZ]
      If IEXISTSAT = 0 Then
        Onerrgo RIEN
        Gosub TITRES From ="W1"+maskcou
        Onerrgo
      Endif
    Endif
    # FGR 07/03/2012 : X3SUIVI79830 (fin)
  Endif
  # -------------------------------------
  GFMT = [F:TCY]ADRCODFMT  # Bien faire tout à la fin
  # -------------------------------------
End

