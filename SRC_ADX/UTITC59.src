#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################
# UTITC59  Migration of Notes description from A type field to ATEXTRA AX2  SAM # 99384  #
# FGR :  April 2014                                                                      #
##########################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTITC59(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC59(DOSSIER)
Value Char DOSSIER

Local Integer IERR
Local Integer B_OK

  Call ECR_TRACE("UTITC59: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".AOBJET"  [AOB]
  IERR = 0
  #------------------------------------------------------------
  WOBJET="NTG"
  Read [AOB]ABREV=WOBJET
  If !fstat Then
    Call MAJ_SEL(DOSSIER, WOBJET) From PATCHAOB
    #
    If [F:AOB]TYPGES <> 4 Then
      # Pas de fenêtre pour les browsers
      Call VALID("O" + WOBJET, DOSSIER, 1, B_OK) From VALWIN
      If B_OK <> 1 Then
        Call ECR_TRACE("Erreur revalidation fenêtre O" + WOBJET, 1) From GESECRAN
      Endif
    Endif
    #
    Call VALID (WOBJET, DOSSIER, 1, B_OK) From VALOBJ
    If B_OK <> 1 Then
      Call ECR_TRACE("Erreur revalidation objet" - WOBJET, 1) From GESECRAN
    Endif
  Endif
  #------------------------------------------------------------
  Close Local File [AOB]
  Call ECR_TRACE("UTITC59: Process on :" - DOSSIER - "finished",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTITC59(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = "X3" Then
    End
  Endif
  Call MAJ_UTITC59(APPLI)
End
