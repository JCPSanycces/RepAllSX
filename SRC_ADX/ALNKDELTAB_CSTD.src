#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#  When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
  When "LOAD"              : Gosub LOAD
  When "GET_TABREFLNKDEL"  : Gosub GET_TABREFLNKDEL
  When "VERIFY"            : Gosub VERIFY
  When "VERIFY_ARRAY"      : Gosub VERIFY_ARRAY
  When "DELETE_LINKS"      : Gosub DELETE_LINKS
  When "DELETE_LINKS_ARRAY": Gosub DELETE_LINKS_ARRAY
Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return





#Define local constantes:
$DEFCONST
Local Integer ISSQL: ISSQL=1
Local Integer ISLOG: ISLOG=2
Return

#**
#* GET_LNKDEL
#*!
$LOAD

Local Char TABREF(GLONAVB)
If this.NBRLNK = 0

 #ALNKDEL has to be initialized:
 this.NBRLNK = -1 :# -1 => no links !
 this.CODCLA  = OBJ.ObjectType()

 If nomap=this.AFOLDER or filinfo(filpath("FIL","ACLASSE","fde",this.AFOLDER),0)<0 or this.AFOLDER=""
  Local File ACLASSE    [ACLA]
 Else
  Local File =this.AFOLDER +".ACLASSE" [ACLA]
 Endif

 #Check that the class exists:
 Read [ACLA]ACLA0 = right$(this.CODCLA,3)
 If fstat = 0
  #Get TABREF which is a parameter of GET_TABREFLNKDEL
  [L]TABREF   = [F:ACLA]TABREF
  this.TABREF = [L]TABREF
  Gosub GET_TABREFLNKDEL
 Else
  #TODO ?
  #[L]ASTATUS = fmet POBJ.ACTX.ASETERROR("VERIFY",[L]ACLASSE-":"-mess(4,140,1),[V]CST_AERROR): Goto VERIFY_END
 Endif
Endif
Return

#**
#* GET_TABREFLNKDEL:
#* Compute links' criteria
#*!
$GET_TABREFLNKDEL
Local Char         TABLE(GLONATB)
Local Integer      TYPELINKS(0..3)
Local Integer      CHECK,NBL

Local Char         TABLEINT(250)
Local Char         DESCRIPT(120)
Local Char         IDXKEYS(GLONAVA)(1..)
Local Integer      I1,I2,P,I,J,K,IK

Local Integer      INDVAL,INDMAX,FINDICE
Local Char         EXPLIEN(250),EXPTOKEN(250),EXPTOKENL(250),EXPTOKENR(250)

Local Char         DESCFLD(GLONAVA),DESCFLDTYPE(GLONATY)

Gosub DEFCONST


TYPELINKS(0)=1 : #Forbidden!
TYPELINKS(1)=2 : #Delete the entity
TYPELINKS(2)=3 : #Remove the link

If nomap=this.AFOLDER or filinfo(filpath("FIL","ATABLE","fde",this.AFOLDER),0)<0 or this.AFOLDER=""
 Local File ATABLE     [ATB]
 Local File ATABZON    [ATZ]
 Local File ATABZON    [ATZ_]
 Local File ATABIND    [ATI]
Else
 Local File =this.AFOLDER+".ATABLE"     [ATB]
 Local File =this.AFOLDER+".ATABZON"    [ATZ]
 Local File =this.AFOLDER+".ATABZON"    [ATZ_]
 Local File =this.AFOLDER+".ATABIND"    [ATI]
Endif

# CCL ajout & CODFIC<>TABREF
#Create a sorted list of ALNKDEL
#Filter [ATZ] Where LIEN=[L]TABREF & find(ANNUL,TYPELINKS)
#&       Order By Key LNKORDER=LIEN;ANNUL Asc
Filter [ATZ] Where LIEN=[L]TABREF & CODFIC<>TABREF & find(ANNUL,TYPELINKS)
&       Order By Key LNKORDER=LIEN;CODFIC;CODZONE;ANNUL Asc
For [ATZ]LNKORDER(2)
 Raz CHECK

 TABLE = [F:ATZ]CODFIC
 Read [ATB]CODFIC = TABLE

 #the table's caption is stored in the INTIFIC field:
 TABLEINT   = func ASYRFNC.TEXTE([F:ATB]INTITFIC)

 [L]DESCFLD = [F:ATB]INTIT

 If len([L]DESCFLD) >0
  Read [ATZ_]CODZONE = TABLE;[L]DESCFLD
  If !fstat
   DESCFLDTYPE = [ATZ_]CODTYP
  Endif
 Endif


 #Gets part of the TABLE's index:
 Raz IDXKEYS
 Read [ATI]NUMLIG(2) = TABLE;1
 IDXDESC = [ATI]DESCRIPT

 P=1
 While IDXDESC<>""
  I1 = instr(1,IDXDESC,"+")
  I2 = instr(1,IDXDESC,"-")
  If I2
   If I1 : I1 = min(I1,I2) : Else : I1 = I2 : Endif
  Endif
  If I1
   IDXKEYS(P) = left$(IDXDESC,I1-1)
   IDXDESC    = right$(IDXDESC,I1+1)
  Else
   IDXKEYS(P) = IDXDESC
   IDXDESC = ""
  Endif
  P +=1
 Wend


 If [F:ATB]TYPFIC=3 & nomap=this.AFOLDER & filinfo(filpath("FIL",TABLE,"fde"),0)>0 : # Table système
  CHECK = 1
 Elsif filinfo(filpath("FIL",TABLE,"fde",this.AFOLDER),0)>0
  CHECK = 1
 Endif
 #TODO GDOSH!
 # If CHECK & APPLI=POBJ.ACTX.AFOLDERH
 #  Call VUE_OK(FICHIER,APPLI,"FIL",CHECK) From DOSVUE
 #  CHECK = !CHECK
 # Endif
 If CHECK
  #For each table linked to TABREF
  For [ATZ]LNKORDER
   If len([F:ATZ]EXPLIEN) = 0
    Gosub ADD_LNKDEL
    this.ALNKDEL(NBL).EXPDIM         = 1 :#the expression contains 1 element
    this.ALNKDEL(NBL).EXPTYP(1).TYPDIM   = 1 :#the expression contains 1 SQL element
    this.ALNKDEL(NBL).EXPELT(1)          = NewInstance  C_ALNKDEL_EXPELT AllocGroup this
    this.ALNKDEL(NBL).EXPELT(1).ELT      = [F:ATZ]CODZONE
    this.ALNKDEL(NBL).EXPELT(1).PRO      = OBJ.AKEYS(1)
    this.ALNKDEL(NBL).EXPELT(1).TYP      = ISSQL
   Else
    INDVAL=0
    INDMAX=1
    #loop on indice: INDMAX will be computed during the first loop
    #works with 'While' but not with 'For'
    While INDVAL < INDMAX
     #Add a link
     Gosub ADD_LNKDEL

     #get the full expression:
     EXPLIEN = vireblc(format$("KT:80X",[F:ATZ]EXPLIEN),2)
     #split EXPLIEN
     I=1
     While EXPLIEN<>"" & OBJ.AKEYS(I) <>""
      J = instr(1,EXPLIEN,";")
      If J
       EXPTOKEN = left$(EXPLIEN,J-1)
       EXPLIEN  = right$(EXPLIEN,J+1)
      Else
       EXPTOKEN = EXPLIEN
       EXPLIEN  = ""
      Endif
      #does the token contains 'indice'?
      J = instr(1,EXPTOKEN,"indice")
      If J
       #does the token contains '(indice)'?
       K = instr(1,EXPTOKEN,"(indice)")
       If K
        #the token contains (indice):
        EXPTOKENL = left$(EXPTOKEN,K-1)
        EXPTOKENR = right$(EXPTOKEN,K+9)
        #compute INDXMAX
        Read [ATZ_]CODZONE = TABLE;EXPTOKENL
        If fstat = 0
         INDMAX = [ATZ_]DIME
         #This part of EXPLIEN refers to a TABLE's field:
         this.ALNKDEL(NBL).EXPDIM        += 1
         this.ALNKDEL(NBL).EXPTYP(1).TYPDIM  += 1
         this.ALNKDEL(NBL).EXPELT(this.ALNKDEL(NBL).EXPDIM)        = NewInstance C_ALNKDEL_EXPELT AllocGroup this
         this.ALNKDEL(NBL).EXPELT(this.ALNKDEL(NBL).EXPDIM).TYP = ISSQL
         this.ALNKDEL(NBL).EXPELT(this.ALNKDEL(NBL).EXPDIM).ELT = EXPTOKENL + '(' + num$(INDVAL) + ')'
         this.ALNKDEL(NBL).EXPELT(this.ALNKDEL(NBL).EXPDIM).PRO = OBJ.AKEYS(I)
         this.ALNKDEL(NBL).CODZONE      += '(' + num$(INDVAL) + ')'

        Endif
       Else
        #the token contains indice:
        FINDICE=1
        EXPTOKENL = left$(EXPTOKEN,J-1)
        EXPTOKENR = right$(EXPTOKEN,J+6)
        #logical condition to evaluate:
        this.ALNKDEL(NBL).EXPDIM        += 1
        this.ALNKDEL(NBL).EXPTYP(2).TYPDIM  += 1
        this.ALNKDEL(NBL).EXPELT(this.ALNKDEL(NBL).EXPDIM)        = NewInstance  C_ALNKDEL_EXPELT AllocGroup this
        this.ALNKDEL(NBL).EXPELT(this.ALNKDEL(NBL).EXPDIM).TYP = ISLOG
        this.ALNKDEL(NBL).EXPELT(this.ALNKDEL(NBL).EXPDIM).ELT = EXPTOKENL + num$(INDVAL) + EXPTOKENR
        this.ALNKDEL(NBL).EXPELT(this.ALNKDEL(NBL).EXPDIM).PRO = OBJ.AKEYS(I)

       Endif
      Else
       #EXPTOKEN doesn't contains indice
       #skip part of the link containing [V]GSUPCLE :
       J = instr(1,EXPTOKEN,"[V]GSUPCLE")
       If J=0
        If left$(EXPTOKEN,3)="[V]"
         #condition to evaluate:
         #logical condition to evaluate:
         Case EXPTOKEN
          When "[V]GLANGUE" : EXPTOKEN = "GACTX.LAN"
         Endcase
         this.ALNKDEL(NBL).EXPDIM        += 1
         this.ALNKDEL(NBL).EXPTYP(2).TYPDIM  += 1
         this.ALNKDEL(NBL).EXPELT(this.ALNKDEL(NBL).EXPDIM)        = NewInstance C_ALNKDEL_EXPELT AllocGroup this
         this.ALNKDEL(NBL).EXPELT(this.ALNKDEL(NBL).EXPDIM).ELT = EXPTOKEN
         this.ALNKDEL(NBL).EXPELT(this.ALNKDEL(NBL).EXPDIM).PRO = OBJ.AKEYS(I)

        Else
         EXPTOKENL = EXPTOKEN
         J = instr(1,EXPTOKEN,"(")
         If J>0
          EXPTOKENL = left$(EXPTOKEN,J-1)
         Endif
         #is EXPTOKENL a TABLE's field ?
         Read [ATZ_]CODZONE = TABLE;EXPTOKENL
         If fstat = 0
          #This part of EXPLIEN refers to a TABLE's field:
          this.ALNKDEL(NBL).EXPDIM        += 1
          this.ALNKDEL(NBL).EXPTYP(1).TYPDIM += 1
          this.ALNKDEL(NBL).EXPELT(this.ALNKDEL(NBL).EXPDIM)        = NewInstance  C_ALNKDEL_EXPELT AllocGroup this
          this.ALNKDEL(NBL).EXPELT(this.ALNKDEL(NBL).EXPDIM).TYP = ISSQL
          this.ALNKDEL(NBL).EXPELT(this.ALNKDEL(NBL).EXPDIM).ELT = EXPTOKENL
          this.ALNKDEL(NBL).EXPELT(this.ALNKDEL(NBL).EXPDIM).PRO = OBJ.AKEYS(I)
         Else
          #logical condition to evaluate:
          this.ALNKDEL(NBL).EXPDIM        += 1
          this.ALNKDEL(NBL).EXPTYP(2).TYPDIM += 1
          this.ALNKDEL(NBL).EXPELT(this.ALNKDEL(NBL).EXPDIM)        = NewInstance  C_ALNKDEL_EXPELT AllocGroup this
          this.ALNKDEL(NBL).EXPELT(this.ALNKDEL(NBL).EXPDIM).TYP = ISLOG
          this.ALNKDEL(NBL).EXPELT(this.ALNKDEL(NBL).EXPDIM).ELT = EXPTOKEN
          this.ALNKDEL(NBL).EXPELT(this.ALNKDEL(NBL).EXPDIM).PRO = OBJ.AKEYS(I)
         Endif
        Endif
       Endif
      Endif
      #Next key's token
      I += 1
     Wend :#While EXPLIEN<>"" & OBJ.AKEYS(I) <>""
     #Next INDVAL
     INDVAL +=1
    Wend :#While INDVAL < INDMAX
   Endif
  Next ATZ
 Endif
Next ATZ

this.NBRLNK=maxtab(this.ALNKDEL)
If this.NBRLNK = 0 : this.NBRLNK = -1 : Endif

Close Local File [ATB]
Close Local File [ATZ]
Close Local File [ATZ_]
Close Local File [ATI]
Return

$ADD_LNKDEL
NBL = maxtab(this.ALNKDEL)+1
this.ALNKDEL(NBL) = NewInstance C_ALNKDEL AllocGroup this
this.ALNKDEL(NBL).CODE       = num$([F:ATZ]ANNUL) + "." + TABLE
If [F:ATZ]ANNUL <> 2 : this.ALNKDEL(NBL).CODE += "." + [F:ATZ]CODZONE + "_" + num$(INDVAL): Endif
this.ALNKDEL(NBL).TABLE      = TABLE
#TODO For IK=1 To dim(this.ALNKDEL(NBL).IDXKEYS)
IK=1
While len([L]IDXKEYS(IK)) >0
 this.ALNKDEL(NBL).IDX(IK)          = NewInstance C_ALNKDEL_IDX AllocGroup this
 this.ALNKDEL(NBL).IDX(IK).IDXKEYS  = [L]IDXKEYS(IK)
 IK += 1
Wend
#TODO Next IK
this.ALNKDEL(NBL).ANNUL      = [F:ATZ]ANNUL
this.ALNKDEL(NBL).CODZONE    = [F:ATZ]CODZONE
this.ALNKDEL(NBL).TABLEINT   = TABLEINT
this.ALNKDEL(NBL).EXPDIM     = 0
this.ALNKDEL(NBL).INTIT      = [L]DESCFLD
this.ALNKDEL(NBL).INTITTYPE  = [L]DESCFLDTYPE
this.ALNKDEL(NBL).EXPTYP(1)  = NewInstance  C_ALNKDEL_EXPTYP AllocGroup this
this.ALNKDEL(NBL).EXPTYP(2)  = NewInstance  C_ALNKDEL_EXPTYP AllocGroup this
Return

#**VERIFY
$VERIFY
Local Char OPERATION(10):OPERATION="VERIFY"
Local Integer TYPELINKS(0..3)
Local Integer NBROBJ: NBROBJ=1
Local Instance AOBJ(1..) Using OBJECT
AOBJ(1)=OBJ

TYPELINKS(0)=1
Gosub CHECK
Return

#**VERIFY_ARRAY
$VERIFY_ARRAY
Local Char OPERATION(10):OPERATION="VERIFY"
Local Integer      TYPELINKS(0..3)
Local Integer NBROBJ
TYPELINKS(0)=1

NBROBJ = maxtab(AOBJ)
Gosub CHECK
Return

#**
#* DELETE_LINKS
#*!
$DELETE_LINKS
Local Char OPERATION(10):OPERATION="DELETE"
Local Integer      TYPELINKS(0..3)
Local Integer      NBROBJ: NBROBJ=1
Local Instance     AOBJ(1..) Using OBJECT
AOBJ(1)= OBJ
TYPELINKS(0)=2
TYPELINKS(1)=3
Gosub CHECK
Return


#**
#* DELETE_LINKS_ARRAY
#*!
$DELETE_LINKS_ARRAY
Local Char OPERATION(10):OPERATION="DELETE"
Local Integer      TYPELINKS(0..3)
Local Integer      NBROBJ: NBROBJ=1
TYPELINKS(0)=2
TYPELINKS(1)=3
Gosub CHECK
Return

#**CHECK
$CHECK
Local Integer I: I=1
Local Integer J,K,IOBJ
Local Char TABLE(GLONATB)
Local Instance LP Using C_ALNKDEL :#pointer 'previous'
Local Instance LC Using C_ALNKDEL :#pointer 'current'
Local Instance LS(0..) Using C_ALNKDEL :#pointers
Local Integer  LSL,SQLDIM
Local Char CODEC(250),CODEP(250)
Local Char CLAPRO(5+GLONACLA)
Local Char PROVAL(250),PROVALSTR(250)
Local Instance POBJ Using OBJECT
Local Clbfile CRITSQL(3)(1..),CRITERIA(0)(1..2)
Local Clbfile CRITSQLE
Local Integer IC,NC,ISSTRING,NBSTRING,NBCONST,MAXSTRING,MAXCONST : NC=1
Local Integer NBSTRING2(2),NBCONST2(2)
Local Char OBJKEYS(250)(1..)
Local Char OBJKEY(250)
Local Integer KEEP
Local Char    PROVALSTRS(250)(1..2,2),FLD,OBJSUBKEYS(250)(1..2)
Local Integer IPV,NBPROVAL,FINDCRIT
Local Integer NBEXPLOG,NBEXPSQL
Local Integer CLAPROTYPE(1..)
Local Integer LADXLOG

Gosub DEFCONST
Local Integer ISSQL: ISSQL=1
Local Integer ISLOG: ISLOG=2


If this.NBRLNK = -1
 #ALNKDEL has to be initialized:
 Gosub LOAD
Endif
[L]LADXLOG=adxlog

#loop on links:
Raz LP,LC,CODEP,LSL,SQLDIM

#loop on lnkdel elements + 1 (last element = null!)
For I=1 To maxtab(this.ALNKDEL)+1
 Raz LC,CODEC

 If (I <= maxtab(this.ALNKDEL)) & (find(this.ALNKDEL(I).ANNUL,TYPELINKS) > 0)
  #the current element matches the TYPELINKS criteria:
  LC    = this.ALNKDEL(I)
  CODEC = LC.CODE
 Endif

 If LC <> null & LP = null
  #set the previous pointer:
  LP=LC
  CODEP = LP.CODE
 Endif

 If CODEC <> CODEP : #break
  #=> execution
  If LSL > 0
   #At least one sql criteria:
   If (TABLE <> LS(0).TABLE) & clalev([LNK_])
    #close the table if open:
    Close Local File [LNK_]
   Endif

   If !clalev([LNK_])
    #open the table if it isn't:
    TABLE = LS(0).TABLE
    If nomap=this.AFOLDER or filinfo(filpath("FIL",LP.TABLE,"fde",this.AFOLDER),0)<0 or this.AFOLDER=""
     Local File = TABLE [LNK_]
    Else
     Local File = this.AFOLDER+"."+ TABLE [LNK_]
    Endif
   Endif
   Raz OBJKEYS,CRITSQL
   NC=1

   #TODO
   #GTIMESTAMP(0) = timestamp$
   Raz NBSTRING,NBCONST
   For J=0 To LSL-1
    Raz PROVALSTRS,IPV,CLAPROTYPE,OBJSUBKEYS
    MAXSTRING = 64  - LS(J).EXPTYP(1).TYPDIM
    MAXCONST  = 128 - LS(J).EXPTYP(1).TYPDIM
    For IOBJ=1 To NBROBJ
     POBJ = AOBJ(IOBJ)
     #TODO check: POBJ.accessorEnabled = 0
     OBJKEYS(IOBJ) = ""

     If LS(J).EXPDIM > 0
      If    (NBSTRING >= MAXSTRING) or (NBCONST  >= MAXCONST)
       #close the current criteria
       If FINDCRIT
        Append CRITSQL(NC) , "," + PROVALSTRS(1,1) + ") > 0 )"
        FINDCRIT = 0
       Else
        Append CRITSQL(NC) , FLD + "=" + PROVALSTRS(1,1) + ")"
       Endif
       Raz PROVALSTRS,OBJSUBKEYS,IPV,NBSTRING,NBCONST
       NC +=1
      Endif

      Raz FLD,CRITERIA
      Raz NBSTRING2,NBCONST2,NBEXPLOG,NBEXPSQL

      IPV += 1
      IPV = min(IPV,2)

      For K=1 To  LS(J).EXPDIM

       #TODO
       #GTIMESTAMP(1) = timestamp$
       CLAPRO = "POBJ." + LS(J).EXPELT(K).PRO
       PROVAL = num$(evalue(CLAPRO))
       If CLAPROTYPE(K) = 0 : CLAPROTYPE(K) = evalue("type(" + CLAPRO+ ")") : Endif
       #TODO
       #GELAPSED(1) += val(timestamp$) - val(GTIMESTAMP(1))

#      PROVAL        = POBJ.AKEYSVAL(K)
#      CLAPROTYPE(K) = POBJ.AKEYSTYP(K)

       Case CLAPROTYPE(K)
        When 1,2,4,5,6,7,8,9
         PROVALSTR = PROVAL
         ISSTRING = 0
        When 3
         PROVALSTR = '@'+ PROVAL +'@'
         ISSTRING  = 1
        When Default
         PROVALSTR = '"'+ PROVAL +'"'
         ISSTRING  = 1
       Endcase

       #TODO
       #GTIMESTAMP(4) = timestamp$

       If LS(J).EXPELT(K).TYP = ISSQL
        #keep the last value
        PROVALSTRS(IPV,0) = PROVALSTRS(IPV,1)
        PROVALSTRS(IPV,1) = PROVALSTR
        OBJSUBKEYS(IPV) +=  PROVALSTRS(IPV,0) + "~"

        If NBEXPSQL
         #add the property's value
         Append CRITERIA(ISSQL) , FLD + "=" + PROVALSTRS(IPV,0) + " and "
         OBJKEYS(IOBJ) += "~"
        Endif
        OBJKEYS(IOBJ) += PROVAL

        #keep the last field's name:
        FLD = LS(J).EXPELT(K).ELT

        NBSTRING2(0) += NBSTRING2(1)
        NBCONST2(0)  += NBCONST2(1)
        NBSTRING2(1)  = ISSTRING
        NBCONST2(1)   = abs(1-ISSTRING)
        NBEXPSQL += 1
       Else
        If NBEXPLOG : Append CRITERIA(ISLOG)," and " : Endif
        NBEXPLOG += 1
        #add the property's value
        Append CRITERIA(ISLOG) , LS(J).EXPELT(K).ELT + "=" + PROVALSTR
       Endif

       #TODO
       #GELAPSED(4) += val(timestamp$) - val(GTIMESTAMP(4))
       #TODO
       #GELAPSED(3) += val(timestamp$) - val(GTIMESTAMP(1))

      Next K
      KEEP=1
      If NBEXPLOG
       KEEP = evalue(CRITERIA(ISLOG))
      Endif
      If KEEP = 0
       #forget the value:
       PROVALSTRS(IPV,0) = ""
       PROVALSTRS(IPV,1) = ""
       OBJSUBKEYS(IPV)   = ""
       Raz CRITERIA(ISSQL)
       IPV -= 1
      Endif
      If KEEP=1 or IOBJ = NBROBJ
       #TODO
       #GTIMESTAMP(2) = timestamp$

       #'keep the element' or 'last element'
       If IPV=2
        NBSTRING += NBSTRING2(1)
        NBCONST  += NBCONST2(1)
        If    OBJSUBKEYS(1) = OBJSUBKEYS(2)
         #add an element to the 'find' clause
         If FINDCRIT
          #append a element to the find clause
          Append CRITSQL(NC) , "," + PROVALSTRS(1,1)
         Else
          #create a find clause
          Append CRITSQL(NC) , "find(" + FLD + "," + PROVALSTRS(1,1)
          FINDCRIT = 1
         Endif
         If  (IOBJ  = NBROBJ)
          #close the  find criteria
          Append CRITSQL(NC) , "," + PROVALSTRS(2,1) + ") > 0 )"
         Endif
        Else
         #close the previous criteria
         If FINDCRIT
          Append CRITSQL(NC) , "," + PROVALSTRS(1,1) + ") > 0 )"
          FINDCRIT = 0
         Else
          Append CRITSQL(NC) , FLD + "=" + PROVALSTRS(1,1) + ")"
         Endif
         If  IOBJ <> NBROBJ
          #start a new criteria
          Append CRITSQL(NC)," or (" + CRITERIA(ISSQL)
         Endif
         IPV=1
         NBSTRING += NBSTRING2(0)
         NBCONST  += NBCONST2(0)
        Endif
        PROVALSTRS(1,0) = PROVALSTRS(2,0)
        PROVALSTRS(1,1) = PROVALSTRS(2,1)
        PROVALSTRS(2,0) = ""
        PROVALSTRS(2,1) = ""
        OBJSUBKEYS(1)   = OBJSUBKEYS(2)
        OBJSUBKEYS(2)   = ""
       Elsif IPV=1
        If len(CRITSQL(NC)) > 0 : Append CRITSQL(NC)," or " : Endif
        Append CRITSQL(NC),"(" + CRITERIA(ISSQL)
        NBSTRING += NBSTRING2(0)
        NBCONST  += NBCONST2(0)
        If IOBJ = NBROBJ
         #last element : close the  criteria
         Append CRITSQL(NC) , FLD + "=" + PROVALSTRS(1,1) + ")"
        Endif
       Endif
       #TODO
       #GELAPSED(2) += val(timestamp$) - val(GTIMESTAMP(2))
      Endif #KEEP
     Endif
     #TODO check: POBJ.accessorEnabled = 1
    Next IOBJ
   Next J

   #TODO
   #GELAPSED(0) += val(timestamp$) - val(GTIMESTAMP(0))

   #execute the criteria
   For IC=1 To NC
    CRITSQLE = CRITSQL(IC)
    If len(CRITSQLE) = 0: Break : Endif

    If LP.ANNUL = 2
     #Delete entities:
      #If adxmac(-2)="pc018948.sagefr.adinternal.com" :
      # Call LOG_LINE("* delete "-TABLE-"   where "-CRITSQLE) From AXUNIT
      #Endif
      If !adxlog : Trbegin [LNK_] : Endif
      Delete [LNK_] Where evalue(CRITSQLE)
    Else
     For [LNK_] Where evalue(CRITSQLE)
      #compute OBJKEY:
      Raz OBJKEY
      For J=1 To LS(0).EXPDIM
       If LS(0).EXPELT(J).TYP = ISSQL
        #It's a SQL element :
        If len(OBJKEY) > 0: OBJKEY += "~" : Endif
        FLD = LS(0).EXPELT(J).ELT
        OBJKEY += num$(evalue("[F:LNK_]"+ LS(0).EXPELT(J).ELT))
       Endif
      Next J
      IOBJ = find(OBJKEY,OBJKEYS)
      If IOBJ > 0
       POBJ = AOBJ(IOBJ)
       Case OPERATION + "_" + num$(LP.ANNUL)
        When "VERIFY_1": Gosub VERIFY_1
        When "DELETE_3": Gosub DELETE_3
       Endcase
       If maxtab(POBJ.AERROR) > 1000 : Break : Endif
      Endif
     Next LNK_
    Endif
   Next IC

  Endif

  #RAZ LSL before next element:
  Raz LSL,SQLDIM
 Endif

 If CODEC <> ""
  #the criteria has to be taken into account:
  LS(LSL) = LC
  SQLDIM = max(SQLDIM,LS.EXPTYP(1).TYPDIM)
  LSL += 1
 Endif

Next I

If LADXLOG=0 and adxlog
 If ARET_VALUE=0
  Commit
 Else
  Rollback
 Endif
Endif

If clalev([LNK_])
 #close the table if open:
 Close Local File [LNK_]
Endif

If clalev([AXX_])
 #close the table if open:
 Close Local File [AXX_]
Endif
Return


#**
#* VERIFY_1
#*!
$VERIFY_1
Local Char  MESSAGE(250)
Local Char  RECORDKEY(250)
Local Char  RECORDKEYS(250)(1..)
Local Char  RECORDDESC(250),TABLEDESC(250)
Local Integer L: L = 1

If !clalev([AXX_])
 If nomap=this.AFOLDER or filinfo(filpath("FIL","ATEXTRA","fde",this.AFOLDER),0)<0 or this.AFOLDER=""
  Local File ATEXTRA    [AXX_]
 Else
  Local File =this.AFOLDER+".ATEXTRA"    [AXX_]
 Endif
Endif

#Compute the record key
#TODO While len(LS(0).IDX(L).IDXKEYS) > 0
For L=1 To maxtab(LS(0).IDX)
 If len(RECORDKEY) > 0 : RECORDKEY += "~" : Endif
 RECORDKEYS(L) = num$(evalue("[F:LNK_]"+LS(0).IDX(L).IDXKEYS))
 RECORDKEY += RECORDKEYS(L)
#TODO  L += 1
#TODO Wend
Next L

#Get the record RECORDDESC:
If len(LS(0).INTIT) > 0
 Case LS(0).INTITTYPE
  When "AXX","AX1","AX2","AX3"
   Read [AXX_]AXX0  = LS(0).TABLE;LS(0).INTIT;POBJ.ACTX.LAN;RECORDKEYS(1);RECORDKEYS(2)
   If !fstat : RECORDDESC = [F:AXX_]TEXTE : Endif
  When "ATX"
   RECORDDESC = func ASYRFNC.TEXTE(evalue("[F:LNK_]"+LS(0).INTIT))
  When Default
   RECORDDESC = num$(evalue("[F:LNK_]"+LS(0).INTIT))
 Endcase
Endif
If len(RECORDDESC) > 0 : RECORDDESC = "(" + RECORDDESC  + ")" : Endif
If len(LS(0).TABLEINT)>0  : TABLEDESC  = "(" + LS(0).TABLEINT + ")" : Endif

#The record $KEYS ($RECORDDESC)
Raz MESSAGE
#If toupper(adxusr)="CCL"
# MESSAGE = this.TABREF+"/"+evalue("POBJ."+AOBJ(1).AKEYS(1)) -":"
#Endif
MESSAGE = mess(101,126,1) - RECORDKEY - RECORDDESC
#is used in $TABLE ($RECORDDESC(1))
MESSAGE -= mess(198,133,1) - LS(0).TABLE - TABLEDESC
#issue #4830 : ARET_VALUE = fmet POBJ.ASETERROR("",MESSAGE,[V]CST_AERROR)
ARET_VALUE = func ASYRSUB._ASETSTATUS(POBJ,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,MESSAGE)
Return

#**
#* DELETE_3:CODZONE has to be resetted:
#*!
$DELETE_3
If !adxlog : Trbegin [LNK_] : Endif
Case evalue("type([F:LNK_]"+LS(0).CODZONE +")")
 When  1,2,4,5,6,7,8,9
  Assign "[F:LNK_]" + LS(0).CODZONE With 0
 When  3
  Assign "[F:LNK_]" + LS(0).CODZONE With [0/0/0]
 When Default
  Assign "[F:LNK_]" + LS(0).CODZONE With ""
Endcase
Rewrite [LNK_]
Return

