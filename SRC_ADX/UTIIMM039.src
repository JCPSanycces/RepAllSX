#<AdxTL>@(#)5.0.0.0 $Revision$
###########################################################################################
# MODIFIE PAR : MDJ
# LE          : 24 Juin      2014 10:24:48
# Tool for feeding the LEG in table TYPACEINT if mono-legislation folders
# FQ100826
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIIMM039: QAV7.1 : Error LEG in mono-leg folder") From LECFIC
  Call EXE_UTIIMM039(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Subroutine execution of the tool
#* @param APPLI  Folder to process
#*!
 Subprog EXE_UTIIMM039(APPLI)
 Value Char APPLI
  If clalev([F:TPI]) : Close Local File [TPI] : Endif
  Local File =APPLI+".TYPACEINT" [TPI]
  If clalev([F:WACV]) : Close Local File [WACV] : Endif
  Local File =APPLI+".ACTIV" [WACV]
  If clalev([F:WADW]) : Close Local File [WADW] : Endif
  Local File =APPLI+".ADOVAL" [WADW]

  Call ECR_TRACE("UTIIMM039: Process Start on : "+APPLI,0) From GESECRAN

  # If Folder in mono legislation
  If func ACTIV("LEG")=0
    Call DEBTRANS From GLOCK
    Gosub TR_UTIIMM039
  Else
    Call ECR_TRACE("  Multilegislation folder. Nothing to do.",0) From GESECRAN
  Endif

  Call ECR_TRACE("UTIIMM039: Process End on : "+APPLI,0) From GESECRAN
 End

########################################
#### Corps de la moulinette - début ####
########################################

$TR_UTIIMM039

   # Folder legislation
   Read [F:WADW]ADW0="";"";"DOSLEG"
   If fstat : Raz [F:WADW] : Endif
   # Updating of legislation with folder legislation
   Trbegin [TPI]
   Update [TPI] Where LEG = "" With LEG = [F:WADW]VALEUR
   If fstat
      GOK = 0
    Endif

  If !GOK Then
    Goto AB_UTIIMM039
  Else
    Call ECR_TRACE(num$(adxuprec) - "TYPACEINT updated with"-[F:WADW]VALEUR, 0) From GESECRAN
    Commit
  Endif
Return

$AB_UTIIMM039
 Rollback
Return
####################################################
## test : Mono legislation or not
####################################################
Funprog ACTIV(COD)
Value Char COD

If COD="" : End 1 : Endif

Read [WACV]CODACT = COD
If fstat or [F:WACV]FLACT<>2
   End 0
Elsif [F:WACV]TYP=2
   End [F:WACV]DIME
Else
   End 1
Endif

End
########################################
#### Corps of the tool - end ######
########################################

#**
#*  Subroutine execution of the tool
#* @param APPLI  Folder to process
#*!
Subprog PATCH(APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","TYPACEINT","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM039(APPLI)
End

#**
#* For execution from dosmajx (folder validation)
#* @param APPLI  Dossier à traiter
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","TYPACEINT","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM039(APPLI)
End
