#<AdxTL>@(#)0.0.0.0 $Revision$
# Issue X3-105283 - 2018-08-29 by BAKHA : Authorisation check removed for NC actioners

# Data Class script: PLANDET_CSTD, Plan detail

$METHODS

  Case CURPTH
    When ""
      Case ACTION
        When "ADDLINE_AFTER"
          Gosub INCREMENT_LINE_NUMBER
      Endcase
  Endcase

Return

# --------------------------------------------------
# Initialise Line no. (LINENO) and Status (LINESTATUS) for new Plan Details.
$INCREMENT_LINE_NUMBER

  Local Integer DUMMY_RTV

  this.LINENO = 1 + max(this.APARENT.PLANDET(1..maxtab(this.APARENT.PLANDET)).LINENO)
  this.LINESTATUS = 1

Return


# --------------------------------------------------

$PROPERTIES

  Local Char PROPERTYACTION(50)
  PROPERTYACTION = CURPRO +"." +ACTION

  Case PROPERTYACTION
    When "LINESTATUS.PROPAGATE"
      Gosub UPDATE_START_END_DATES
  Endcase

Return

# --------------------------------------------------
# Maintain Plan Detail Start and End dates.
$UPDATE_START_END_DATES

  Local Integer TOTALPLANLINES, PLANLINES, INPROGRESSLINES, COMPLETEDLINES

  # If line Status is Pending then reset Start and End dates,
  # If line Status is In progress then set Start date to today's date and reset End date,
  # If line Status is Completed then set Start date to today's date (if not set) and End date to today's date ...
  If (this.LINESTATUS = 1)
    this.STARTDATE = AVOID.ADATE
    this.ENDDATE = AVOID.ADATE
  Elsif (this.LINESTATUS = 2)
    this.STARTDATE = date$
    this.ENDDATE = AVOID.ADATE
  Else
    If (this.STARTDATE = AVOID.ADATE)
      this.STARTDATE = date$
    Endif
    this.ENDDATE = date$
  Endif

Return

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

