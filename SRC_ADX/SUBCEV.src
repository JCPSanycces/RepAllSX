#<AdxTL>@(#)0.0.0.0 $Revision$ Object Management CEV
#####################################################################################
# Gestion du masque CEV0 (Campagne d'entretiens)
# Gestion de fiche Campagne d'entretiens (table COMPEVAL)
#
#
# Creation :
#     SEGAY - 03/08/12 - EXI 81491 72836 US605
# Modification :
#     MABOS - 04/03/13 - FQ 81085 - US 1332 - Ctrl on GESCEV + Add LEG on GENCEV
#     MABOS - 12/03/13 - FQ 88316 - US1420 - Suivi Entretiens
#     SBA :   06/08/13   US 1840-81085 : réinitialisation des champs sur changement de législation
######################################################################################
Raz GPILOBJ
Call OBJET("CEV",GBIDC1,"") From GOBJET
End
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "MODIF"       : Gosub MODIF
 When "VERIF_MOD"   : Gosub VERIF_MOD
#DIRAS - JIRA X3-29324 - 2017/03/23 - START
 When "VERIF_CRE"   : Gosub VERIF_CRE
#DIRAS - JIRA X3-29324 - 2017/03/23 - END
 When "CREATION"    : Gosub CREATION
 When "ANNULE"      : Gosub ANNULE
 When "CHANGE"      : Gosub CHANGE
 When "LIENS"       : Gosub LIENS
 When "INIMOD"      : Gosub INIMOD
 When "RAZCRE"      : Gosub RAZCRE
 When "RAZDUP"      : Gosub RAZDUP
 When "INICRE"      : Gosub INICRE
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
# When "APRES_CHOI"  : Gosub APRES_CHOI
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "FERME"       : Gosub FERME
 When "ABANDON"     : Gosub ABANDON

 When Default
Endcase
Return

$OUVRE
#DIRAS - JIRA X3-29324 - 2017/03/23 - START
Local Decimal TOTWEI
#DIRAS - JIRA X3-29324 - 2017/03/23 - END

Gosub DECLARE
#PCA 31/08/12 Add Leg
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
Filter [F:ADW] Where PARAM='EVAYEA' & VALEUR<>""
If rowcount([F:ADW])=0 Then
  Infbox mess(95,10720,1) : # Le paramètre EVAYEA contenant le type d'entretien annuel, n'est pas renseigné
Endif
Filter [F:ADW]

#DIRAS - JIRA X3-29324 - 2017/03/23 - START
If clalev([F:FJR])=0 : Local File FLXJOBRSP [FJR] : Endif
#DIRAS - JIRA X3-29324 - 2017/03/23 - END
Return

$FERME
#PCA 31/08/12 Add Leg
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$ABANDON
#PCA 31/08/12 Add Leg
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return



#####################################
$DECLARE
Local Char VALCPT (GLONCEV)
If clalev([F:EVE])=0 : Local File EVAEMP [EVE] : Endif
Return

# FQ88696 - 25/03/13 - Message non bloquant si modif de critères alors qu'entretiens existent déjà
$VERIF_MOD
Local Integer L_OK

  If clalev([F:EVAM])=0 : Local File EVAEMP [EVAM] : Endif
  Filter [F:EVAM] Where CEV=[M:CEV0]COD
  If rowcount([F:EVAM])>0 Then
    If clalev([F:CEVM])=0 : Local File COMPEVAL [CEVM] : Endif
    Read [F:CEVM]CEV0=[M:CEV0]COD
    If [M:CEV0]CPYCEV<>[F:CEVM]CPYCEV | [M:CEV0]FCYCEV<>[F:CEVM]FCYCEV | [M:CEV0]SRVCEV<>[F:CEVM]SRVCEV | [M:CEV0]POPCEV<>[F:CEVM]POPCEV
&    | [M:CEV0]PRFCEV<>[F:CEVM]PRFCEV | [M:CEV0]POTCEV<>[F:CEVM]POTCEV | [M:CEV0]JOTCEV<>[F:CEVM]JOTCEV | [M:CEV0]LEG<>[F:CEVM]LEG Then
      # Attention, des entretiens ont déjà été générés avec des critères différents. Etes-vous sûr de vouloir effectuer ces modifications?
      L_OK = 1
      Call OUINON(mess(123,10720,1)+chr$(10)+chr$(13)+mess(124,10720,1),L_OK) From GESECRAN
      If L_OK<>2
         OK=0
      Endif
    Endif
  Endif
  Filter [F:EVAM]
#DIRAS - JIRA X3-29324 - 2017/03/23 - START
Gosub CHECK_WEIGHT
#DIRAS - JIRA X3-29324 - 2017/03/23 - END
Return
# Fin FQ88696

#DIRAS - JIRA X3-29324 - 2017/03/23 - START
$VERIF_CRE
Gosub CHECK_WEIGHT
Return
#DIRAS - JIRA X3-29324 - 2017/03/23 - END

$CREATION
$MODIF
Call MAJTEXTRA([M]DESAXX,"COMPEVAL","DESAXX",[M]COD,"") From ATEXTRA
Call MAJTEXTRA([M]SHOAXX,"COMPEVAL","SHOAXX",[M]COD,"") From ATEXTRA
Return

$ANNULE
Delete [AXX] Where CODFIC="COMPEVAL" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

$CHANGE
Update [AXX] Where CODFIC="COMPEVAL" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA COMPEVAL"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

$RAZDUP
$RAZCRE
  Actzo [M:CEV0]EVATYP, STRDAT, ENDDAT
  Diszo [M:CEV0]PRFCEV : #MABOS-04/03/13-FQ81085-US1332-No LEG -> no PRFCEV

#DIRAS - JIRA X3-29324 - 2017/03/23 - START
If func AFNC.ACTIV("EVAEN")>0
  Gosub CHARGE_MANAGERS
  [M:CEV0]MULREV = 1
  Call AM_MULREV([M:CEV0]MULREV)
Endif
#DIRAS - JIRA X3-29324 - 2017/03/23 - END

Return

$INICRE
# Affectation du code campagne
Local Char COMPJMA(3)
If [F:CEV]COD=""
 COMPJMA=left$([F:CEV]EVATYP,3)
# COMPJMA+=format$("D:DDMMYYYY",[F:CEV]STRDAT)
 Call CPT_CEV(VALCPT,COMPJMA)
 If GOK
  [M:CEV0]COD = VALCPT
  [F:CEV]COD  = VALCPT
  Affzo [M:CEV0]COD
 Endif
Endif
If GOK<=0 : Return : Endif

Return

$INIMOD
Return

#####################################
$SETBOUT

  CHMEN += "A"
  # On ne peut pas générer les campagnes si on est en création ou en train de modifier la campagne ou si la campagne n'est pas active
  If GREP<>"" |  [M:CEV0]ENAFLG <> 2
    Call VIREBOUT(CHAINE,"1") From GOBJET :#Bouton Génération en masse
    Call VIREBOUT(CHAINE,"2") From GOBJET :#Bouton Suivi entretiens : #MABOS-12/03/13-FQ88316-US1420
    Call VIREBOUT(CHAINE,"3") From GOBJET :#Bouton Relance : #MABOS-12/03/13-FQ88316-US1527
  Endif

  Filter [F:EVE] Where CEV=[F:CEV]COD
  If rowcount([F:EVE])>0 Then
    [L]CHMEN+="E"
  Else
    Call VIREBOUT(CHAINE,"2") From GOBJET :#Bouton Suivi entretiens : #MABOS-12/03/13-FQ88316-US1420
    Call VIREBOUT(CHAINE,"3") From GOBJET :#Bouton Relance : #MABOS-12/03/13-FQ88316-US1527
 Endif
  Filter [F:EVE]
Return

$EXEBOUT
  Gosub LIENS
Return

$LIENS
Local Char LEGAXX(5)

  Filter [F:EVE] Where CEV=[F:CEV]COD
  If rowcount([F:EVE])>0 Then
    Grizo [M:CEV0]EVATYP, STRDAT, ENDDAT
  Else
    Actzo [M:CEV0]EVATYP, STRDAT, ENDDAT
  Endif

#DIRAS - JIRA X3-29324 - 2017/03/23 - START
Call AFF_INTTYPENT([M:CEV0]EVATYP,[M:CEV0]CPYCEV,[M:CEV0]FCYCEV)
#DIRAS - JIRA X3-29324 - 2017/03/23 - END
  Filter [F:EVE]

#DIRAS - JIRA X3-29324 - 2017/03/23 - START
Gosub CHARGE_MANAGERS
#Managing the display for multiple reviewers
If func AFNC.ACTIV("EVAEN")>0  Call AM_MULREV([M:CEV0]MULREV) From SUBCEV : Endif
#DIRAS - JIRA X3-29324 - 2017/03/23 - END

#PCA 31/08/12 Add Leg
If GNBLEG=1 : GCURLEG = GDOSLEG : Endif
GCURLEG = [F:CEV]LEG : [M:CEV0]LEG=GCURLEG

LEGAXX=GCURLEG
#MABOS-04/03/13-FQ81085-US1332-
#MABOS-No LEG -> No PRFCEV
#If LEGAXX="" Then LEGAXX=GLEGFIL : Endif
#If LEGAXX="" Then
#  If clalev([F:PRF])=0 : Local File PROFIL [PRF] : Endif
#  Filter [F:PRF] Where PRFCOD=[M]PRFCEV
#  Read [F:PRF] First
#  If !fstat
#    LEGAXX = [F:PRF]LEG
#  Endif
#  Filter [F:PRF]
#  # Never mind, a LEG is mandatory, so we take the first one if necessary
#  If LEGAXX="" Then
#    Read [F:PRF] First
#    If !fstat
#      LEGAXX = [F:PRF]LEG
#    Endif
#  Endif
#Endif
#LIPET - 2017-10-11 - X3-29324 - START
#Call LECTEXTRA([M]PRFDES,"PROFIL","PRFDES",LEGAXX,[M]PRFCEV) From ATEXTRA
#LIPET - 2017-10-11 - X3-29324 - END
Return

#**
#* Affectation du code campagne
#* SEGAY
#* @param  VALEUR  : numéro
#* @param PCOM : composant compteur(3car Typ+datedeb(JJMMAAAAA)
#*!
Subprog CPT_CEV (VALEUR, PCOM)
Variable Char VALEUR()
Value Char PCOM ()
Local Char COMPTEUR(GLONANM)
Local Integer STAT
If clalev([F:TCA])=0 : Local File TABCOUAFF  [TCA] : Endif
GOK=1
Call LECTCA(20,STAT) From SUBTCA
If !STAT
 GMESSAGE = mess(80,10720,1) : # Compteur campagne non défini
 GOK = 0 : End
Else
 COMPTEUR= [F:TCA]CODNUM(3)
Endif

Call NUMERO(COMPTEUR,"",[M:CEV0]STRDAT,PCOM,VALEUR,STAT) From SUBANM
If STAT
 GMESSAGE = mess(104,117,1)-COMPTEUR : # "Erreur sur compteur"
 GOK = 0 : End
Endif
Call VERIF_VCR(VALEUR,COMPTEUR)
If GOK=0 : End : Endif
End

#**
#* Vérification compteur campagne d'entretiens
#* SEGAY
#* @param  NUM  : numéro
#* @param  COMPTEUR  : compteur
#*!
Subprog VERIF_VCR(NUM,COMPTEUR)
Variable Char NUM
Value    Char COMPTEUR
Local Integer STAT
If clalev([F:CEVZ])=0 : Local File COMPEVAL [CEVZ] : Endif
Read [CEVZ]CEV0=NUM
If fstat : End : Endif
While !fstat
 Call NUMERO(COMPTEUR,"",datesyst,"",NUM,STAT) From SUBANM
 Read [CEVZ]CEV0=NUM
Wend
If STAT
 # Erreur sur compteur
 GMESSAGE = mess(104,117,1)-COMPTEUR
 GOK = 0 : End
Endif
End

$SEL_TABLE

  Case TABLE
    When "SELCEV"    : Gosub SELCEV
    When "SELCTRCEV" : Gosub SELCTRCEV
  Endcase
Return

$SELCEV
Local Char EMP(GLONEML), CTR(GLONHRCTR), POT(GLONPOT), JOBPOT(GLONJOT), TYPEVA(GLONADI), CPY(GLONCPY), FCY(GLONFCY), PRF(GLONPRF), SRV(GLONSRV)
Local Date CTRDAT, STRDAT, ENDDAT

# SEGAY 10/09/12 FQ81085 US740
  Local Char CODFIC(GLONATB)
  Local Char WLEG(GLONADI)
  Local Char WCPY(GLONCPY)
#  If func AFNC.ACTIV("LEG")=0
#    WLEG = GDOSLEG
#  Else   # GCURLEG positionné par programme
#    WLEG=GCURLEG
#    If GCURLEG = ""
#      WLEG=GLEGFIL
#    Else
#      WLEG=GCURLEG
#    Endif
#  Endif
  WLEG=PARAM(9)
# END SEGAY 10/09/12 FQ81085 US740

  If clalev([F:FCY])=0   : Local File FACILITY [FCY]   : Endif
  If clalev([F:CEV])=0   : Local File COMPEVAL [CEV]   : Endif
  If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
  If clalev([F:AXC])=0   : Local File ATEXTRA  [AXC]   : Endif
  Raz EMP,CTR,CTRDAT,POT,JOBPOT,STRDAT,ENDDAT
#DIRAS - JIRA X3-29324 - 2017/03/23 - START
  OPTPROBIL=0
#DIRAS - JIRA X3-29324 - 2017/03/23 - END
  EMP     = PARAM(1)
  CTR     = PARAM(2)
# FQ81085 US830 - SEGAY 03/10/12 -
#  CTRDAT  = PARAM(3)
#  POT     = PARAM(4)
#  JOBPOT  = PARAM(5)
#  STRDAT  = PARAM(6)
#  ENDDAT  = PARAM(7)
  If GREP<>"C" | (GREP="C" & PARAM(8)<>"" & CTR<>"" & EMP<>"")
    TYPEVA  = PARAM(8)
  Endif
  If CTR<>"" & EMP<>"" Then
    STRDAT  = PARAM(6)
    ENDDAT  = PARAM(7)
    CTRDAT  = PARAM(3)
    POT     = PARAM(4)
    JOBPOT  = PARAM(5)
#DIRAS - JIRA X3-29324 - 2017/03/23 - START
    OPTPROBIL= val(PARAM(9))
#DIRAS - JIRA X3-29324 - 2017/03/23 - END
  Endif
  If CTR<>"" & EMP<>"" Then
    Read [F:HRCTR]CTR0=EMP;CTR;CTRDAT
    If !fstat Then
      PRF = [F:HRCTR]PROPRF
      SRV = [F:HRCTR]ETRSRV
      FCY = [F:HRCTR]ETRFCY
      Call LECTURE("FCY", [F:HRCTR]ETRFCY, "") From CONTOBJ
      If !fstat Then
        CPY = [F:FCY]LEGCPY
      Endif
    Endif
  Endif

  COL(1) = "[F:CEV]COD"
  COL(2) = "[F:AXC]TEXTE"
  COL(3) = "[F:CEV]EVATYP"
  COL(4) = "[F:CEV]STRDAT"
  COL(5) = "[F:CEV]ENDDAT"
  TIT(1) = mess(37,100,1)   : # Code
  TIT(2) = mess(82,123,1)   : # Intitulé
  TIT(3) = mess(59,100,1)   : # Type
  TIT(4) = mess(4,10708,1)  : # Date début
  TIT(5) = mess(5,10708,1)  : # Date fin

  TIT(0) = mess(4,10864,1)  : # Campagne d'entretiens
  NBCOL = 5
#  SEGAY 10/09/12 FQ81085 US740
  CODFIC = "COMPEVAL"
  NBCOL=6
  COL(NBCOL) = "LEG"
  Gosub TEXTE : COL(NBCOL)="string$([F:CEV]LEG<>'',[F:CEV]LEG)+string$([F:CEV]LEG='',mess(91,187,1))"
# END SEGAY 10/09/12 FQ81085 US740

  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:CEV]COD>="'+VALEUR+'"',"&") From GOBJSUB
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:CEV]ENAFLG=2',"&") From GOBJSUB
  If (GREP="C" & TYPEVA<>"") | (GREP<>"C") Then
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:CEV]EVATYP="'+TYPEVA+'"',"&") From GOBJSUB
  Endif

#DIRAS - JIRA X3-29324 - 2017/03/23 - START
  If !OPTPROBIL
    If STRDAT<>[0/0/0] Then
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:CEV]STRDAT=['+format$(GFMD,STRDAT)+']',"&") From GOBJSUB
    Endif
    If ENDDAT<>[0/0/0] Then
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:CEV]ENDDAT=['+format$(GFMD,ENDDAT)+']',"&") From GOBJSUB
    Endif
  Endif
#DIRAS - JIRA X3-29324 - 2017/03/23 - END

  If CPY<>"" Then
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'find([F:CEV]CPYCEV,"'+CPY+'","")>0',"&") From GOBJSUB
  Endif
  If FCY<>"" Then
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'find([F:CEV]FCYCEV,"'+FCY+'","")>0',"&") From GOBJSUB
  Endif
  If PRF<>"" Then
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'find([F:CEV]PRFCEV,"'+PRF+'","")>0',"&") From GOBJSUB
  Endif
  If POT<>"" Then
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'find([F:CEV]POTCEV,"'+POT+'","")>0',"&") From GOBJSUB
  Endif
  If JOBPOT<>"" Then
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'find([F:CEV]JOTCEV,"'+JOBPOT+'","")>0',"&") From GOBJSUB
  Endif
# SEGAY 10/09/12 FQ81085 US740
  If WLEG<>"" Then
     Call ADDCRIT(CRITERE,ICRITERE,""," find([F:CEV]LEG,'','"+WLEG+"')>0","&") From GOBJSUB
  Endif
# END SEGAY 10/09/12 FQ81085 US740

  Link [F:CEV] With [F:AXC]AXX0="COMPEVAL";"DESAXX";GLANGUE;[F:CEV]COD;"" As [NEW_]
  Default File [F:NEW_]

  [L]START="[F:CEV]COD"
  [L]ORDRE="[F:CEV]COD" : # For haven't [F:AXC]TEXTE in key because field null is possible
Return

# SEGAY 10/09/12 FQ81085 US740
$TEXTE
  Call TEXTFIC(CODFIC ,  COL(NBCOL), 1, TIT(NBCOL) ) From OBJDIV
Return
# END SEGAY 10/09/12 FQ81085 US740

$SEL_LISTE

  Case LISTE
    When "SELEMPCEV" : Gosub SELEMPCEV
  Endcase
Return

$SELEMPCEV
Local Char    CEV(GLONCEV), POT(GLONPOT), JOBPOT(GLONJOT), TYPEVA(GLONADI), CPY(GLONCPY), FCY(GLONFCY), PRF(GLONPRF), SRV(GLONSRV)
Local Char    CRIT1(250), CRITERE(250)
Local Date    CTRDAT, STRDAT, ENDDAT
Local Char    TEX(80)(1..), TEXTE(80)(1..,1..5)
Local Integer ICRITERE
Local Char    CRITERE1(250)

  If clalev([F:FCY])=0   : Local File FACILITY [FCY]   : Endif
  If clalev([F:CEV])=0   : Local File COMPEVAL [CEV]   : Endif
  If clalev([F:ID])=0    : Local File EMPLOID  [ID]    : Endif
  If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
  If clalev([F:ILEG])=0  : Local File EMPLOLEG [ILEG]  : Endif
  If clalev([F:POA])=0   : Local File POPULA   [POA]   : Endif
# SEGAY 10/09/12 FQ81085 US740
  If clalev([F:CPY])=0    : Local File COMPANY  [CPY]   : Endif
  Local Char WLEG(GLONADI)
  Local Char WCPY(GLONCPY)
  WCPY=GSOCIETE
#  If func AFNC.ACTIV("LEG")=0
#    WLEG = GDOSLEG
#  Else  # GCURLEG positionné par programme
#    If GCURLEG = ""
#      WLEG=GLEGFIL
#    Else
#      WLEG=GCURLEG
#    Endif
#  Endif
   WLEG=PARAM(2):# SEGAY 01/10/12 FQ81491 US803 LEG=GLEGFIL for matricule
# END SEGAY 10/09/12 FQ81085 US740
#Dbgaff
  CEV = PARAM(1)
  Call LECTURE("CEV", CEV, "") From CONTOBJ

  TIT(1) = mess(1,10319,1)    : # Matricule
  TIT(2) = mess(20,159,1)     : # Nom
  TIT(3) = mess(69,10701,1)   : # Prénom
  TIT(4) = mess(2,45,1)       : # Société
  TIT(5) = mess(3,45,1)       : # Site

  TIT(0) = mess(46,10702,1)   : # Sélection salariés
  NBCOL = 5

  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:ID]REFNUM>="'+VALEUR+'" & [F:HRCTR]CTRNUM>=""',"&") From GOBJSUB
  CRIT1="1=1"
  If [F:CEV]COD<>"" Then
#    CRIT1 -= "& (([F:HRCTR]CTRDAT<=["+format$(GFMD,[F:CEV]STRDAT)+"] | [F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=["+format$(GFMD,date$)+"])"
#    CRIT1 -= " | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=["+format$(GFMD,[F:CEV]STRDAT)+"]))"
#    CRIT1 -= "& ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=["+format$(GFMD,date$)+"])"
#  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'CTRDAT<=date$ & (XITDAT=[0/0/0] | XITDAT>=date$)',"&") From GOBJSUB
#  If [F:CEV]STRDAT<>[0/0/0] Then
#    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'CTRDAT<=['+format$(GFMD,[F:CEV]STRDAT)+']',"&") From GOBJSUB
#  Endif
#  If [F:CEV]ENDDAT<>[0/0/0] Then
#    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'CTRDAT<=['+format$(GFMD,[F:CEV]ENDDAT)+']',"&") From GOBJSUB
#  Endif
    If [F:CEV]CPYCEV<>"" Then
#      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'find([F:FCY]LEGCPY,"'+[F:CEV]CPYCEV+'","")>0',"&") From GOBJSUB
      Call CRITGSOC(CRITERE1)
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CRITERE1,"&") From GOBJSUB
    Endif
    If [F:CEV]FCYCEV<>"" Then
#      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'find(ETRFCY,"'+[F:CEV]FCYCEV+'","")>0',"&") From GOBJSUB
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:HRCTR]ETRFCY="'+[F:CEV]FCYCEV+'"',"&") From GOBJSUB
    Endif
    If [F:CEV]SRVCEV<>"" Then
#      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'find(ETRSRV,"'+[F:CEV]SRVCEV+'","")>0',"&") From GOBJSUB
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:HRCTR]ETRSRV="'+[F:CEV]SRVCEV+'"',"&") From GOBJSUB
    Endif
    If [F:CEV]PRFCEV<>"" Then
#      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'find(PROPRF,"'+[F:CEV]PRFCEV+'","")>0',"&") From GOBJSUB
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:HRCTR]PROPRF="'+[F:CEV]PRFCEV+'"',"&") From GOBJSUB
    Endif
    If [F:CEV]POTCEV<>"" Then
#      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'find(POT,"'+[F:CEV]POTCEV+'","")>0',"&") From GOBJSUB
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:HRCTR]POT="'+[F:CEV]POTCEV+'"',"&") From GOBJSUB
    Endif
    If [F:CEV]JOTCEV<>"" Then
#      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'find(JOBPOT,"'+[F:CEV]JOTCEV+'","")>0',"&") From GOBJSUB
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:HRCTR]JOBPOT="'+[F:CEV]JOTCEV+'"',"&") From GOBJSUB
    Endif
  Endif
  If [F:CEV]POPCEV<>"" Then
    Link [F:ILEG] With [F:POA]POA0=[F:CEV]POPCEV;[F:ILEG]REFNUM,[F:ID]ID0=[F:ILEG]REFNUM,[F:CPY]CPY0=[F:ILEG]LEGCPY,[F:FCY]FCY0=[F:ILEG]ETRFCY As [ILEG_]
&                 Where [F:POA]COD=[F:CEV]POPCEV
&               & ((WLEG="" or [F:CPY]LEG=WLEG) & (WCPY="" | [F:ILEG]LEGCPY = WCPY)) & evalue(CRIT1)
  Else
    Link [F:ILEG] With [F:ID]ID0=[F:ILEG]REFNUM,[F:CPY]CPY0=[F:ILEG]LEGCPY,[F:FCY]FCY0=[F:ILEG]ETRFCY As [ILEG_]
&              Where ((WLEG="" or [F:CPY]LEG=WLEG) & (WCPY="" | [F:ILEG]LEGCPY = WCPY)) & evalue(CRIT1)
  Endif

  For [F:ILEG_] Where evalue(CRITERE)
    If !find([F:ID]REFNUM, TEX) Then
      NBTEX += 1
      TEX(NBTEX)     = [F:ILEG]REFNUM
      TEXTE(NBTEX,1) = [F:ILEG]REFNUM
      TEXTE(NBTEX,2) = [F:ILEG]NAM
      TEXTE(NBTEX,3) = [F:ILEG]SRN
      TEXTE(NBTEX,4) = [F:ILEG]LEGCPY
      TEXTE(NBTEX,5) = [F:ILEG]FCYID
      If [F:ILEG]FCYID<>[F:ILEG]FCYORI & (PARAM(2)="" | [F:ILEG]LEGORI=PARAM(2))
& & [F:CPY]LEG<>[F:ILEG]LEGORI
        TEXTE(NBTEX,4) = [F:ILEG]LEGCPYORI
        TEXTE(NBTEX,5) = [F:ILEG]FCYORI
      Endif
    Endif
  Next
Return

# FQ81085 US830 - SEGAY 27/09/12 - Replace S_CTRNUM in SUBEVA by Selection TAB SELCTRCEV in SUBCEV
$SELCTRCEV
Local Char    CEV(GLONCEV), POT(GLONPOT), JOBPOT(GLONJOT), TYPEVA(GLONADI), CPY(GLONCPY), FCY(GLONFCY), PRF(GLONPRF), SRV(GLONSRV)
Local Char    CRIT1(250), CRITERE(250)
Local Date    CTRDAT, STRDAT, ENDDAT
Local Char    TEX(80)(1..), TEXTE(80)(1..,1..5)
Local Integer ICRITERE
Local Integer NB_CTR
Local Char    CRITERE1(250)

  If clalev([F:FCY])=0   : Local File FACILITY [FCY]   : Endif
  If clalev([F:CEV])=0   : Local File COMPEVAL [CEV]   : Endif
  If clalev([F:ID])=0    : Local File EMPLOID  [ID]    : Endif
  If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
  If clalev([F:ILEG])=0  : Local File EMPLOLEG [ILEG]  : Endif
  If clalev([F:POA])=0   : Local File POPULA   [POA]   : Endif
# SEGAY 10/09/12 FQ81085 US740
  If clalev([F:CPY])=0    : Local File COMPANY  [CPY]   : Endif
  Local Char WLEG(GLONADI)
  Local Char WCPY(GLONCPY)
  WCPY=GSOCIETE
  If func AFNC.ACTIV("LEG")=0
    WLEG = GDOSLEG
  Else  # GCURLEG positionné par programme
    If GREP<>"C"
      If GCURLEG = ""
        WLEG=GLEGFIL
      Else
        WLEG=GCURLEG
      Endif
    Else
      WLEG=func SUBEVA.FGET_LEGSEL(2)
    Endif
  Endif
# END SEGAY 10/09/12 FQ81085 US740
  CEV = PARAM(2)
  Call LECTURE("CEV", CEV, "") From CONTOBJ

  If(PARAM(1)<>"")
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'REFNUM="'+PARAM(1)+'"',"&") From GOBJSUB
  Endif

  CRIT1="1=1"
  CRIT1 -= "& (([F:HRCTR]CTRDAT<=["+format$(GFMD,[M:EVA0]EVADATEND)+"] )"
  CRIT1 -= " | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=["+format$(GFMD,[M:EVA0]EVADATEND)+"]))"
  CRIT1 -= "& ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=["+format$(GFMD,[M:EVA0]EVADATEND)+"])"

  If [F:CEV]COD<>"" Then
    If [F:CEV]CPYCEV<>"" Then
#      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'find([F:FCY]LEGCPY,"'+[F:CEV]CPYCEV+'","")>0',"&") From GOBJSUB
      Call CRITGSOC(CRITERE1)
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CRITERE1,"&") From GOBJSUB
    Endif
    If [F:CEV]FCYCEV<>"" Then
#      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'find([F:HRCTR]ETRFCY,"'+[F:CEV]FCYCEV+'","")>0',"&") From GOBJSUB
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:HRCTR]ETRFCY="'+[F:CEV]FCYCEV+'"',"&") From GOBJSUB
    Endif
    If [F:CEV]SRVCEV<>"" Then
#      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'find([F:HRCTR]ETRSRV,"'+[F:CEV]SRVCEV+'","")>0',"&") From GOBJSUB
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:HRCTR]ETRSRV="'+[F:CEV]SRVCEV+'"',"&") From GOBJSUB
    Endif
    If [F:CEV]PRFCEV<>"" Then
#      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'find([F:HRCTR]PROPRF,"'+[F:CEV]PRFCEV+'","")>0',"&") From GOBJSUB
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:HRCTR]PROPRF="'+[F:CEV]PRFCEV+'"',"&") From GOBJSUB
    Endif
    If [F:CEV]POTCEV<>"" Then
#      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'find([F:HRCTR]POT,"'+[F:CEV]POTCEV+'","")>0',"&") From GOBJSUB
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:HRCTR]POT="'+[F:CEV]POTCEV+'"',"&") From GOBJSUB
    Endif
    If [F:CEV]JOTCEV<>"" Then
#      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'find([F:HRCTR]JOBPOT,"'+[F:CEV]JOTCEV+'","")>0',"&") From GOBJSUB
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:HRCTR]JOBPOT="'+[F:CEV]JOTCEV+'"',"&") From GOBJSUB
    Endif
  Endif
  If [F:CEV]POPCEV<>"" Then
    Link [F:HRCTR] With [F:POA]POA0=[F:CEV]POPCEV;[F:HRCTR]REFNUM,[F:ID]ID0=[F:HRCTR]REFNUM,
&                       [F:FCY]FCY0=[F:HRCTR]ETRFCY,[F:CPY]CPY0=[F:FCY]LEGCPY As [NEW_]
&                 Where [F:POA]COD=[F:CEV]POPCEV
&               & ((WLEG="" or [F:CPY]LEG=WLEG) & (WCPY="" | [F:FCY]LEGCPY = WCPY)) & evalue(CRIT1)
  Else
    Link [F:HRCTR] With [F:ID]ID0=[F:HRCTR]REFNUM,
&                       [F:FCY]FCY0=[F:HRCTR]ETRFCY,[F:CPY]CPY0=[F:FCY]LEGCPY As [NEW_]
&              Where ((WLEG="" or [F:CPY]LEG=WLEG) & (WCPY="" | [F:FCY]LEGCPY = WCPY)) & evalue(CRIT1)
  Endif
  Default File [NEW_]
#  TODO ERROR ORACLE in rowcount link NEW_
#  Filter [NEW_] Where evalue (CRITERE) &
#&            ([F:HRCTR]CTRDAT<=[M:EVA0]EVADATEND | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=[M:EVA0]EVADATEND))
#&                 & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>=[M:EVA0]EVADATSTR)
#  NB_CTR=rowcount([NEW_])
#  Filter [NEW_]
#  If !NB_CTR
#    GMESSAGE  = mess(158,10702,1) : # Pas de contrat valide sur la période
#    VALEUR = ""
#    Raz [F:HRCTR] : mkstat = 2 : End
#  Endif

  TIT(0)  = mess(244,10717,1) : # Choix du contrat

  NBCOL = 0
  CODFIC = "EMPLOCTR"
  # Colonne Matricule
  NBCOL += 1 : COL(NBCOL) = "REFNUM" : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]REFNUM"
  CODFIC = "EMPLOID"
  # Colonne Nom
  NBCOL += 1 : TIT(NBCOL)=mess(38,100,1)    : COL(NBCOL)="[F:ID]NAM"
  # Colonne Prénom
  NBCOL += 1 : TIT(NBCOL)=mess(69,10701,1)  : COL(NBCOL)="[F:ID]SRN"

  CODFIC = "EMPLOCTR"
  # Colonne Contrat
  NBCOL += 1 : COL(NBCOL) = "CTRNUM" : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]CTRNUM"
  # Colonne Date du contrat
  NBCOL += 1 : COL(NBCOL) = "CTRDAT"
  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]CTRDAT"
  # Colonne Date de sortie
  NBCOL += 1 : COL(NBCOL) = "XITDAT"
  CODFIC = "EMPLOCTR" : Gosub TEXTE : COL(NBCOL)="[F:HRCTR]XITDAT"

  CODFIC = "EMPLOID"
  # Colonne Société
  NBCOL += 1 : COL(NBCOL) = "CPY"
  Gosub TEXTE
  # COL(NBCOL)="[F:ID]CPY"
  COL(NBCOL)="[F:FCY]LEGCPY"
  # Colonne Site
  NBCOL += 1 : TIT(NBCOL)=mess(7,47,1)
  # COL(NBCOL)="[F:ID]FCY"
  COL(NBCOL)="[F:FCY]FCY"

  [L]ORDRE = "[F:HRCTR]REFNUM;[F:ID]NAM;[F:FCY]LEGCPY;[F:FCY]FCY;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT"
  [L]EXPSTART = "[F:HRCTR]REFNUM>='"+PARAM(1)+"'"
  [L]START="[F:HRCTR]CTRNUM"
  [L]DEFPAG = 1    :# To have page up and page down
#  OBJET="CTR"

Return

#DIRAS - JIRA X3-29324 - 2017/03/23 - START
$CHARGE_MANAGERS
If func AFNC.ACTIV("EVAEN")=0 : Return : Endif
Raz nolign
For [F:FJR]FJR0 Where [F:FJR]COD = "VALENT" and [F:FJR]TYP = 1 # Only the business process for interviews
  nolign += 1
  [M:CEV0]TYPMGR(nolign-1) = [F:FJR]TYPMGR
Next
[M:CEV0]NBRREV = nolign
Affzo [M:CEV0]
Return
#DIRAS - JIRA X3-29324 - 2017/03/23 - END

#DIRAS - JIRA X3-29324 - 2017/03/23 - START
$CHECK_WEIGHT
If func AFNC.ACTIV("EVAEN")=0 : Return : Endif
#When multiple reviewers are selected, we need to make sure that the weight equals to 100
#We need to check the main reviewer weight, the multiple reviewes and the substitutes
If [M:CEV0]MULREV <> 2 : Return : Endif

Raz [L]TOTWEI
#Main reviewer
[L]TOTWEI = [M:CEV0]REVWEI

#Multiple reviewers
For nolign = 0 To NBRMULREV-1
  [L]TOTWEI += [M:CEV0]MULREVWEI(nolign)
Next

[L]TOTWEI = arr([L]TOTWEI,0.1)
If [L]TOTWEI <> 100
  OK = 0
  #NOTE: Does not exist on GX3
  GMESSAGE = mess(3,2455,1)
Endif
Return
#DIRAS - JIRA X3-29324 - 2017/03/23 - END

#DIRAS - JIRA X3-29324 - 2017/03/23 - START
#**
#*
#*
#* @param VALEUR : type of interview
#*!
Subprog AFF_INTTYPENT(VALEUR,CPY,FCY)
Value Char VALEUR()
Value Char CPY
Value Char FCY
Local Integer CHK
Local Char LIBTYPINT(30)(1..2)

  CHK=0
  Call AFF_CHK_INTTYPENT(VALEUR,CPY,FCY,CHK,LIBTYPINT)
  Chgtzn[M:CEV0]STRDAT With LIBTYPINT(1)
  Chgtzn[M:CEV0]ENDDAT With LIBTYPINT(2)
End
#DIRAS - JIRA X3-29324 - 2017/03/23 - END

#DIRAS - JIRA X3-29324 - 2017/03/23 - START
#**
#*
#*
#* @param VALEUR : type of interview
#* @param CHK : Check No =0, Check Yes =1
#* @param LIBTYPINT : return lib date of interview
#*!
Subprog AFF_CHK_INTTYPENT(VALEUR,CPY,FCY,CHK,LIBTYPINT)
Value Char VALEUR()
Value Char CPY
Value Char FCY
Value Integer CHK
Variable Char LIBTYPINT()(1..)
Local Char VARCPY(GLONCPY)
Local Char VARFCY(GLONFCY)
Local Integer ISTYPPREV, ISNOENT

#  ISNOENT=varmode([M:CEV0]STRDAT)=0
#  If ISNOENT : ISNOENT=func DIVEVA.GET_NBMONTH(VALEUR) : Endif
  ISNOENT=func DIVEVA.GET_NBMONTH(VALEUR)
#  If CHK & !ISNOENT
#    GMESSAGE=func DIVEVA.GETMESSAGE(6,"",VALEUR)
#    mkstat=2
#    End
#  Endif
  If ISNOENT
    VARCPY=CPY
    VARFCY=FCY
    If VARCPY <> ""
      ISTYPPREV =func DIVEVA.IS_GRPSOC_TYPEOF(VARCPY,"EVAPRO",VALEUR,1)  + func DIVEVA.IS_GRPSOC_TYPEOF(VARCPY,"EVABIL",VALEUR,1)
    Elsif VARFCY <> ""
      ISTYPPREV =func DIVEVA.IS_SOC_TYPEOF(VARFCY,"EVAPRO",VALEUR)  + func DIVEVA.IS_SOC_TYPEOF(VARFCY,"EVABIL",VALEUR)
    Else
      ISTYPPREV =func DIVEVA.IS_TYPEOF("EVAPRO",VALEUR) + func DIVEVA.IS_TYPEOF("EVABIL",VALEUR)
    Endif
  Endif
  # Saisissable(pas d'entretien lié) & EVAPRO ou EVABIL renseigné
#DIRAS - JIRA X3-29324 - 2017/03/23 - START
  If ISNOENT & ISTYPPREV
     LIBTYPINT(1) = mess(156,10720,1) : # "Prochain entretien déb."
     LIBTYPINT(2) = mess(157,10720,1) : # "Prochain entretien fin"
  Else
     LIBTYPINT(1) = mess(158,10720,1) : # "Période évaluée début"
     LIBTYPINT(2) = mess(159,10720,1) : # "Période évaluée fin"
  Endif

#  If ISNOENT & ISTYPPREV
#     LIBTYPINT(1) = mess(156,720,1) : # "Prochain entretien déb."
#     LIBTYPINT(2) = mess(157,720,1) : # "Prochain entretien fin"
#  Else
#     LIBTYPINT(1) = mess(158,720,1) : # "Période évaluée début"
#     LIBTYPINT(2) = mess(159,720,1) : # "Période évaluée fin"
#  Endif
 End
#DIRAS - JIRA X3-29324 - 2017/03/23 - END
#DIRAS - JIRA X3-29324 - 2017/03/23 - END

# FQ81085 US830 - SEGAY 27/09/12
Subprog CRITGSOC(CRITERE1)
Variable Char    CRITERE1()

Local Integer WK, WI
Local Char    LIS_CPY(GLONCPY)(0..100)
  CRITERE1="1=1"
  WI=0 : Call CALC_GRPCPY([F:CEV]CPYCEV, LIS_CPY, WI) From TOOLSVAR
  If WI>0 Then
    CRITERE1 -= "& find([F:FCY]LEGCPY,"
    For WK=0 To WI-1
      CRITERE1 += "'"+LIS_CPY(WK)+"'"
      If WK<WI-1 Then CRITERE1 += "," : Endif
    Next
    CRITERE1 += ")>0"
  Else
    If [F:CEV]CPYCEV <> ""
      CRITERE1="1=2"
    Endif
  Endif
End

Subprog CRITGSOCILEG(CRITERE1)
Variable Char    CRITERE1()

Local Integer WK, WI
Local Char    LIS_CPY(GLONCPY)(0..100)
  CRITERE1="1=1"
  WI=0 : Call CALC_GRPCPY([F:CEV]CPYCEV, LIS_CPY, WI) From TOOLSVAR
  If WI>0 Then
    CRITERE1 -= "& find(LEGCPY,"
    For WK=0 To WI-1
      CRITERE1 += "'"+LIS_CPY(WK)+"'"
      If WK<WI-1 Then CRITERE1 += "," : Endif
    Next
    CRITERE1 += ")>0"
  Else
    If [F:CEV]CPYCEV <> ""
      CRITERE1="1=2"
    Endif
  Endif
End


Subprog AM_POTCEV(VALEUR)
Variable Char    VALEUR()

  If clalev([F:POT])=0 : Local File POSTE [POT] : Endif
  Call LECTURE("POT",VALEUR,"") From CONTOBJ
  If [F:POT]JOBPOT<>""
    [M:CEV0]JOTCEV = [F:POT]JOBPOT
    Affzo [M:CEV0]JOTCEV,ZJOTCEV
  Endif
End


## PCA 31/08/12 - changes to add legisaltion
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
  If VALEUR = ""
#    GCURLEG=GLEGFIL
    GCURLEG=""
    Raz  [M]PRFCEV#, [M]PRFDES : #MABOS-04/03/13-FQ81085-US1332- No LEG -> No PRFCEV
    #US 1840-81085
    If(func GET_LEGEVATYP([M:CEV0]EVATYP) <>"")
      Effzo [M:CEV0]EVATYP
    Endif
  Else
    # SBA US 1840-81085
      If([M:CEV0]LEG<>VALEUR)
      Call REINI_FLDSLEG(VALEUR)
    Endif
    GCURLEG=VALEUR
  Endif
  Affzo [M]PRFCEV#, PRFDES  :#MABOS-04/03/13-FQ81085-US1332-
End

Subprog AV_PRFCEV(VALEUR)
Variable Char    VALEUR()
    If GCURLEG="" Then
      Grizo [M]PRFCEV
    Else
      Actzo  [M]PRFCEV
    Endif

End
