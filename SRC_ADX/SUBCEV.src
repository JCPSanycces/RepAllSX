#SBA : US 1840-81085
Subprog REINI_FLDSLEG(VALEUR)
Value Char VALEUR

Local Integer WOK
Local Char RESULT(10)
# on réinitialise les champs si leg <> leg sélectionnée
# verif site
# Gérer Société Site après modif.

# vérif Evatyp
RESULT= func GET_LEGEVATYP([M:CEV0]EVATYP)
If(RESULT<>"" and RESULT <> VALEUR)
 Effzo [M:CEV0]EVATYP
Endif

If([M:CEV0]SRVCEV<>"")
  Call GET_LEGSRV([M:CEV0]SRVCEV,WOK,RESULT,WOK)From TOOLSHRLEG
  If(WOK and RESULT<>"" and RESULT<>VALEUR)
      Effzo [M:CEV0]SRVCEV
  Endif
Endif
WOK=0
If([M:CEV0]POPCEV<>"")
  Call GET_LEGPOP([M:CEV0]POPCEV,WOK,RESULT,WOK)From TOOLSHRLEG
  If(WOK and RESULT<>"" and RESULT<>VALEUR)
      Effzo [M:CEV0]POPCEV
  Endif
Endif
WOK=0
If([M:CEV0]POTCEV<>"")
  Call  GET_LEGPOT([M:CEV0]POTCEV,WOK,RESULT,WOK)From TOOLSHRLEG
  If(WOK and RESULT<>"" and RESULT<>VALEUR)
      Effzo [M:CEV0]POTCEV
  Endif
Endif
WOK=0
If([M:CEV0]JOTCEV<>"")
  Call  GET_LEGJOBPOT([M:CEV0]JOTCEV,WOK,RESULT,WOK)From TOOLSHRLEG
  If(WOK and RESULT<>"" and RESULT<>VALEUR)
      Effzo [M:CEV0]JOTCEV
  Endif
Endif
Effzo [M:CEV0]PRFCEV#,PRFDES
Affzo [M]
End


Funprog GET_LEGEVATYP(VALEUR)
Value Char VALEUR()
Local Char RESULT(10)
Local Integer W_OK
If(VALEUR<>"")
  Call  GET_LEGADI("10464",VALEUR,W_OK,RESULT,W_OK)From TOOLSHRLEG
#  If clalev([F:ADI])=0    : Local File ATABDIV      [ADI]    : Endif
#  Read [F:ADI]CODE=10464;VALEUR
#  If !fstat Then
#    RESULT= [F:ADI]LEG
#  Endif
Endif
End RESULT
