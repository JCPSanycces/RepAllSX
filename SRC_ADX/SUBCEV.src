Subprog C_EVATYP(VALEUR)
Variable Char    VALEUR()
    #US 1840-81085
    If VALEUR <>"" Then
#      If clalev([F:ADI])=0    : Local File ATABDIV      [ADI]    : Endif
#      Read [F:ADI]CODE=10464;VALEUR
#      If !fstat Then
        If func GET_LEGEVATYP(VALEUR) <> ""  & [M:CEV0]LEG="" Then
        #If [F:ADI]LEG <> ""  & [M:CEV0]LEG="" Then
            mkstat=2 : GMESSAGE = mess(100,10720,1) : End
        Endif
      #Endif
    Endif
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
Local    Char    CPYLEG(5),LISTLEG(5)(1..10)
Local    Integer NBLEG,NBCPY

  If [M:CEV0]CPYCEV<>"" Then
    Call LECTURE("CPY", [M:CEV0]CPYCEV, "") From CONTOBJ
    CPYLEG=[F:CPY]LEG
    If CPYLEG="" Then
      [L]NBLEG = 0: [L]NBCPY = 0 : Raz [L]LISTLEG
      Call LIST_LEGCPY([M:CEV0]CPYCEV,[L]LISTLEG,[L]NBLEG,[L]NBCPY) From TOOLSHRLEG
      If NBLEG=1 Then
        CPYLEG=LISTLEG(1)
      Endif
    Endif
    If CPYLEG<>"" & (VALEUR="" | VALEUR<>CPYLEG) Then
      GMESSAGE=mess(133,10720,1) : # La législation doit être celle de la société
      mkstat=2
    Endif
  Endif
End




