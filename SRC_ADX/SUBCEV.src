Subprog AM_MULREV(VALEUR)
Variable Integer VALEUR
#DIRAS - JIRA X3-29324 - 2017/03/23 - START
If func AFNC.ACTIV("EVAEN")=0 : Return : Endif
If [L]VALEUR <> 2
  For I = 0 To NBRMULREV-1
    Raz [M:CEV0]MULTYPMGR(I)
    Raz [M:CEV0]MULREVWEI(I)
    Assign "[M:CEV0]NBRMULREV" With 0
  Next
  Effzo [M:CEV0]20            : Diszo [M:CEV0]20
  Effzo [M:CEV0]REVWEI        : Diszo [M:CEV0]REVWEI
Else
  #Actzo [M:CEV0]20,25
  Actzo [M:CEV0]REVWEI
  Actzo [M:CEV0]20
Endif
Affzo [M:CEV0]
#DIRAS - JIRA X3-29324 - 2017/03/23 - END
End

Subprog C_MULTYPMGR(VALEUR)
Variable Integer VALEUR
#DIRAS - JIRA X3-29324 - 2017/03/23 - START
If VALEUR <> 0
#MAPAD - 10/09/2018 - X3-107559 - START
#  Call UNICITEADDMESS(VALEUR,[M:CEV0]TYPMGR(0..[M:CEV0]NBRREV-1),mess(00005,02455,1)) From OBJDIV
#MAPAD - 10/09/2018 - X3-107559 - END
  Call UNICITE(VALEUR,[M:CEV0]MULTYPMGR(0..[M:CEV0]NBRMULREV-1)) From OBJDIV
Endif
#DIRAS - JIRA X3-29324 - 2017/03/23 - END
End

Subprog C_MULREVWEI(VALEUR)
Variable Decimal VALEUR
#DIRAS - JIRA X3-29324 - 2017/03/23 - START
If VALEUR < 0
  mkstat = 1 : GMESSAGE = mess(00180,00141,1)
Endif
#DIRAS - JIRA X3-29324 - 2017/03/23 - END
End


