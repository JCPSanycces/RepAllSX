Subprog C_FCYCEV(VALEUR)
Variable Char    VALEUR()

  If GCURLEG<>"" Then
    If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
    Call LECTURE("FCY", VALEUR, "") From CONTOBJ
    If !fstat Then
      If [F:FCY]LEG<>GCURLEG Then
        GMESSAGE=mess(3,45,1)-":"-VALEUR+chr$(10)+chr$(13)+mess(62,127,1)-[F:FCY]LEG : # Réservé à la législation
        mkstat=2 : End
      Endif
    Endif
  Endif

#MABOS-04/03/13-FQ81085-US1332- Test FCY / Group
#  If VALEUR<>"" & [M]CPYCEV<>"" & [F:FCY]LEGCPY<>[M]CPYCEV Then
#    GMESSAGE=mess(30,106,1)-[F:FCY]LEGCPY : # Ce site est dans la société
#    mkstat=2 : End
  If VALEUR<>"" & [M]CPYCEV<>"" Then
    Call CONTFCYCPY(VALEUR,[M]CPYCEV) From EXEFNC
  Endif

End

#DIRAS - JIRA X3-29324 - 2017/03/23 - START
Subprog AM_EVATYP(VALEUR)
Variable Char    VALEUR()
  Call AFF_INTTYPENT(VALEUR,[M:CEV0]CPYCEV,[M:CEV0]FCYCEV)
End
