Subprog C_CPYCEV(VALEUR)
Variable Char    VALEUR()
#Local    Integer I, K, DIFF_LEG
#Local    Char    LIS_CPY(GLONCPY)(0..100), LEG(5)
#MABOS-04/03/13-FQ81085-US1332-
Local Char LISTLEG(5)(1..10)
Local Integer NBLEG,NBCPY

  If VALEUR="" Then End : Endif

#MABOS-04/03/13-FQ81085-US1332- Ctrl / LEG
   [L]NBLEG = 0: [L]NBCPY = 0 : Raz [L]LISTLEG
   Call LIST_LEGCPY(VALEUR,[L]LISTLEG,[L]NBLEG,[L]NBCPY) From TOOLSHRLEG
   If GCURLEG<>"" Then
    If [L]NBCPY> 0 Then
      If GCURLEG <> "" & !find(GCURLEG,[L]LISTLEG)
          mkstat = 2
          If [L]NBCPY > 1
            GMESSAGE = mess(117,10720,1) : # La législation de la campagne ne fait pas partie des législations du groupe de sociétés
          Else
            GMESSAGE=mess(2,45,1)-":"-VALEUR+chr$(10)+chr$(13)+mess(62,127,1)-[F:CPY]LEG : # Réservé à la législation
          Endif
          End
      Endif
    Endif
# end #MABOS-04/03/13-FQ81085-US1332-
   Endif

  If [L]NBCPY=0 Then : # Ce n'est pas un groupe de sociétés
    If clalev([F:AGF])=0  : Local File AGRPFCY       [AGF]  : Endif
    If clalev([F:AGC])=0  : Local File AGRPCPY       [AGC]  : Endif
    Read [F:AGF]AGF0=VALEUR
    If !fstat & [F:AGF]FLGCPY=1 Then
      Filter [F:AGC] Where GRP=VALEUR
      If rowcount([F:AGC])=0 Then
        GMESSAGE=VALEUR-mess(216,10717,1) : # est un groupe de sites
        mkstat=2
      Endif
      Filter [F:AGC]
    Endif
  Endif
  #MABOS-04/03/13-FQ81085-US1332-
  Call C_CPY(VALEUR, "GESCEV") From TOOLSVAR

End

Subprog AP_LEG(VALEUR)
Variable Char    VALEUR()

  If VALEUR = ""
    GCURLEG=""
  Else
    GCURLEG=VALEUR
  Endif
End
End

Subprog AM_CPYCEV(VALEUR)
Variable Char    VALEUR()
Local    Char    CPYLEG(5),LISTLEG(5)(1..10)
Local    Integer NBLEG,NBCPY

  Effzo [M:CEV0]FCYCEV : Effzo [M:CEV0]ZFCYCEV :#MABOS-04/03/13-FQ81085-US1332-On change on CPY, Raz FCY
  If VALEUR="" Then
#    [M:CEV0]FCYCEV="" :
    Grizo [M:CEV0]FCYCEV
  Else
    Call LECTURE("CPY", VALEUR, "") From CONTOBJ
    CPYLEG=[F:CPY]LEG
    If CPYLEG="" Then
      [L]NBLEG = 0: [L]NBCPY = 0 : Raz [L]LISTLEG
      Call LIST_LEGCPY(VALEUR,[L]LISTLEG,[L]NBLEG,[L]NBCPY) From TOOLSHRLEG
      If NBLEG=1 Then
        CPYLEG=LISTLEG(1)
      Else
        If [M:CEV0]LEG<>"" & find([M:CEV0]LEG,LISTLEG)>0 Then
          CPYLEG=[M:CEV0]LEG
        Endif
      Endif
    Endif
    [M:CEV0]LEG=CPYLEG : Affzo [M:CEV0]LEG
    Actzo [M:CEV0]FCYCEV
    Call AM_LEG([M:CEV0]LEG)
  Endif
#DIRAS - JIRA X3-29324 - 2017/03/23 - START
  Call AFF_INTTYPENT([M:CEV0]EVATYP,VALEUR,[M:CEV0]FCYCEV)
#DIRAS - JIRA X3-29324 - 2017/03/23 - END
End

Subprog AV_FCYCEV(VALEUR)
Variable Char    VALEUR()

  If [M:CEV0]CPYCEV="" Then
    Grizo [M:CEV0]FCYCEV
  Else
    Actzo [M:CEV0]FCYCEV
  Endif
End


