#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
######################################################################################
$ACTION

Case ACTION
    When "LIENS0"     : Gosub LIENS0
    When "LIENS2"     : Gosub LIENS2
    When "OUVRE"      : Gosub OUVRE
    When "VERIF_CRE"  : Gosub VERIF_CRE
    When "VERIF_MOD"  : Gosub VERIF_MOD
Endcase

Return
######################################################################################
######################################################################################
$OUVRE

If !clalev([F:TVT]) : Local File TABVAT    [TVT] : Endif
If !clalev([F:CPY]) : Local File COMPANY   [CPY] : Endif
If !clalev([F:TRA]) : Local File TABRATVAT [TRA] : Endif

Return
######################################################################################
######################################################################################
$LIENS0

Local Integer RET

For [F:VCL] Where [F:VCL]PORTAXTYP = 0 With Stability
  Call LEC_TVT_LEG("POR",[F:VCL]VAT,RET) From TRTLECLEG
  If [F:TVT]VATTYP = 1
    [F:VCL]PORTAXTYP = 2
    Rewrite [F:VCL]
  Endif
Next

Return
######################################################################################
######################################################################################
$LIENS2

Call LOAD_TAX
Affzo [M:VCL1]

Return
######################################################################################
######################################################################################
VERIF_CRE

Gosub COMMON_VERIF

Return
######################################################################################
######################################################################################
VERIF_MOD

Gosub COMMON_VERIF

Return
######################################################################################
######################################################################################
COMMON_VERIF

Local Integer I : I = 0
I = uni([M]VAT(0..[M]NBLIG-1))

If I <> 0
  Call ERREUR([M]VAT(I-1)-mess(5,10702,1)) From GESECRAN
  OK = 0
Endif

For I = 0 To [M]NBLIG-1
  If [M]PORTAXTYP(I) = 0
    Call ERREUR(mess(48,184,1)+":"-num$(I+1)) From GESECRAN
  Elsif [M]PORTAXTYP(I) = 3 & [M]TAXSTPCOD(I) = ""
    Call ERREUR(mess(48,184,1)+":"-num$(I+1)) From GESECRAN
  Endif
Next

Return
######################################################################################
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

If GREP = "C" | GREP = ""
    If [F:CPY]CPY <> VALEUR
        Read [F:CPY]CPY0 = VALEUR
        If fstat : Raz [F:CPY] : Endif
    Endif
    Call LOAD_TAX
Endif

End
######################################################################################
######################################################################################
Subprog LOAD_TAX

Local Integer NEWVATFLG
Local Integer OK, TVTCTR
Local Integer I, RET

[L]NEWVATFLG = 0
For [F:TVT] Where ([F:TVT]LEG = [F:CPY]LEG | [F:TVT]LEG = "") & find([F:TVT]VATTYP,1,2,3)
  If !find([F:TVT]VAT, [M]VAT(0..[M]NBLIG-1))

    If find([F:TVT]VATTYP,2,3) & [F:TVT]VATFOR<>""
      [L]TVTCTR = 1
    Else
      Filter [F:TRA] Where [F:TRA]VAT = [F:TVT]VAT & [F:TRA]LEG = [F:TVT]LEG & ([F:TRA]CPY = [F:CPY]CPY | [F:TRA]CPY = '')
      Look [F:TRA] First
      If fstat = 0
        [L]TVTCTR = 1
      Endif
      Filter [F:TRA]
    Endif

    If [L]TVTCTR
      [M:VCL1]VAT([M]NBLIG)       = [F:TVT]VAT
      If [F:TVT]VATTYP = 1
        [M:VCL1]TAXCRYARA([M]NBLIG) = 1
        [M:VCL1]TAXLEV([M]NBLIG)    = 3
        [M:VCL1]PORTAXTYP([M]NBLIG) = 2
        Diszo [M]PORTAXTYP([M]NBLIG)
      Else
        [M:VCL1]TAXCRYARA([M]NBLIG) = 4
        [M:VCL1]TAXLEV([M]NBLIG)    = 6
        [M:VCL1]PORTAXTYP([M]NBLIG) = 5
        Diszo [M]TAXCRYARA([M]NBLIG)
        Diszo [M]TAXLEV([M]NBLIG)
      Endif
      [M]NBLIG                += 1
      [L]NEWVATFLG             = 1
    Endif

  Endif
Next

Affzo [M]

If NEWVATFLG = 1
    Call AVERTIR(mess(27,7711,1),[L]RET) From GESECRAN #There are new tax codes. Please review the tax classification.
Endif

For I = 0 To [M]NBLIG-1
  If [M]PORTAXTYP(I) = 0
    Call AVERTIR(mess(48,184,1)+":"-num$(I+1), [L]RET) From GESECRAN
    Break
  Elsif [M]PORTAXTYP(I) = 3 & [M]TAXSTPCOD(I) = ""
    Call AVERTIR(mess(48,184,1)+":"-num$(I+1), [L]RET) From GESECRAN
    Break
  Endif
Next

End
######################################################################################
######################################################################################
Subprog AS_PORTAXTYP(VALEUR)
Variable Integer VALEUR

Local Integer FLDVAL
Local Integer WRET

FLDVAL = VALEUR
Gosub SET_PORTAXTYP
VALEUR = FLDVAL

End
######################################################################################
######################################################################################
Subprog AS_TAXCRYARA(VALEUR)
Variable Integer VALEUR

Local Integer FLDVAL
Local Integer WRET

FLDVAL = VALEUR
Gosub SET_TAXCRYARA
VALEUR = FLDVAL

End
######################################################################################
######################################################################################
Subprog AS_TAXLEV(VALEUR)
Variable Integer VALEUR

Local Integer FLDVAL
Local Integer WRET

FLDVAL = VALEUR
Gosub SET_TAXLEV
VALEUR = FLDVAL

End
######################################################################################
######################################################################################
$SET_PORTAXTYP

Call LEC_TVT_LEG("POR",[M:VCL1]VAT(nolign-1),WRET) From TRTLECLEG

If [F:TVT]VATTYP = 1
  Diszo [M:VCL1]PORTAXTYP(nolign-1)
  GMENLOC(1)=1 : # Non applicable
  GMENLOC(2)=0 : # VAT              OK
  GMENLOC(3)=1 : # Tax stamp
  GMENLOC(4)=1 : # IEC
  FLDVAL    =2
Elsif [F:TVT]VATTYP = 2 | [F:TVT]VATTYP = 3
  Actzo [M:VCL1]PORTAXTYP(nolign-1)
  GMENLOC(1)=1 : # Non applicable
  GMENLOC(2)=1 : # VAT
  GMENLOC(3)=0 : # Tax stamp        OK
  GMENLOC(4)=0 : # IEC              OK
Endif

Return
######################################################################################
######################################################################################
$SET_TAXCRYARA

Call LEC_TVT_LEG("POR",[M:VCL1]VAT(nolign-1),WRET) From TRTLECLEG

If [F:TVT]VATTYP = 1
  Actzo [M:VCL1]TAXCRYARA(nolign-1)
  GMENLOC(1)=0 : # Mainland       OK
  GMENLOC(2)=0 : # Azores         OK
  GMENLOC(3)=0 : # Madeira        OK
  GMENLOC(4)=1 : # Non applicable
Elsif [F:TVT]VATTYP = 2 [F:TVT]VATTYP = 3
  Diszo [M:VCL1]TAXCRYARA(nolign-1)
  GMENLOC(1)=1 : # Mainland
  GMENLOC(2)=1 : # Azores
  GMENLOC(3)=1 : # Madeira
  GMENLOC(4)=0 : # Non applicable OK
  FLDVAL   = 4
Endif

Return

######################################################################################
######################################################################################
$SET_TAXLEV

Call LEC_TVT_LEG("POR",[M:VCL1]VAT(nolign-1),WRET) From TRTLECLEG

If [F:TVT]VATTYP = 1
  Actzo [M:VCL1]TAXLEV(nolign-1)
  GMENLOC(1)=0 : # Reduced        OK
  GMENLOC(2)=0 : # Intermediate   OK
  GMENLOC(3)=0 : # Normal         OK
  GMENLOC(4)=0 : # Exemption      OK
  GMENLOC(5)=0 : # Other          OK
  GMENLOC(6)=1 : # Non applicable
Elsif [F:TVT]VATTYP = 2 [F:TVT]VATTYP = 3
  Diszo [M:VCL1]TAXLEV(nolign-1)
  GMENLOC(1)=1 : # Reduced
  GMENLOC(2)=1 : # Intermediate
  GMENLOC(3)=1 : # Normal
  GMENLOC(4)=1 : # Exemption
  GMENLOC(5)=1 : # Other
  GMENLOC(6)=0 : # Non applicable OK
  FLDVAL   = 6
Endif

Return
######################################################################################
######################################################################################
Subprog AS_TAXSTPCOD(VALEUR)
Variable Char    VALEUR()

If [M:VCL1]PORTAXTYP(nolign-1) <> 3
  Diszo [M:VCL1]TAXSTPCOD(nolign-1)
  mkstat = 2
Else
  Actzo [M:VCL1]TAXSTPCOD(nolign-1)
Endif

Affzo [M:VCL1]TAXSTPCOD(nolign-1)

End
######################################################################################
######################################################################################
Subprog C_TAXSTPCOD(VALEUR)
Variable Char    VALEUR()

If [M:VCL1]PORTAXTYP(nolign-1) = 3 & VALEUR = ""
  GMESSAGE = mess(10,123,1)
  mkstat   = 2
Endif

End
######################################################################################
######################################################################################

