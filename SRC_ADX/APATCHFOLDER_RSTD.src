#<AdxTL>@(#)7.0.0.0 $Revision$
# Classe APATCHFOLDER

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
      When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
      When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER
      When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
      When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return





#---------------------#
$AQUERY_OPEN_AFTER
If PQRY.QWHERE<>"" : PQRY.QWHERE -= 'and' : Endif
PQRY.QWHERE -= 'FOLNAM gt ""'
Gosub LOAD_FOLDERS From APATCHFOLDER_CSTD
Local File (Char FDOSSIER(30),Char FVERSION(10),Char FRELEASE(10),Char FPATCH(10),Char FUPD(20),Char FLAN(250))
& From Variable DOSSIER,VERSION,RELEASE,PATCH,UPD,LAN
& As [LNK_]
Return

#---------------------#
$AQUERY_CLOSE_AFTER
Close Local File [LNK_]
Return

#---------------------#
$AQUERY_TRANS_AFTER
this.APATCH.FOLNAM = [LNK_]FDOSSIER
this.APATCH.FOLVER = [LNK_]FVERSION
this.APATCH.FOLREL = [LNK_]FRELEASE
this.APATCH.FOLPAT = [LNK_]FPATCH
this.APATCH.FOLUPD = [LNK_]FUPD
this.APATCH.FOLLAN = [LNK_]FLAN
Return

#----------------------------------------#
$AQUERY_DECODE_CRITERIA_AFTER
Raz NBPRO
NBPRO += 1 : TBPRO(NBPRO) = "FOLNAM" : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APSADX.FOLNAM" : TBFIL(NBPRO) = "[LNK_]FDOSSIER"
NBPRO += 1 : TBPRO(NBPRO) = "FOLVER" : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APSADX.FOLVER" : TBFIL(NBPRO) = "[LNK_]FVERSION"
NBPRO += 1 : TBPRO(NBPRO) = "FOLREL" : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APSADX.FOLREL" : TBFIL(NBPRO) = "[LNK_]FRELEASE"
NBPRO += 1 : TBPRO(NBPRO) = "FOLPAT" : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APSADX.FOLPAT" : TBFIL(NBPRO) = "[LNK_]FPATCH"
NBPRO += 1 : TBPRO(NBPRO) = "FOLUPD" : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APSADX.FOLUPD" : TBFIL(NBPRO) = "[LNK_]FUPD"
NBPRO += 1 : TBPRO(NBPRO) = "FOLLAN" : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "APSADX.FOLLAN" : TBFIL(NBPRO) = "[LNK_]FLAN"
Return

#-----------------------------------#
$AQUERY_PRIMARYKEYS_AFTER
ASTDKEY = "[LNK_]FDOSSIER "
Return

