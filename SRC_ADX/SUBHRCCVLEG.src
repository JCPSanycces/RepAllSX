########################################
#21/05/12 - SBA - Display\Hide fields based on legislation
########################################
Subprog DISPLAY_HIDE()
Local Char WSIGN(1)
#show name block
Local Integer WDISPBLCK
Local Char WNAMEBLCK

# 3 fields to hide if GCURLEG<>FRA
#block with 2 fields to hide if GCURLEG<>FRA
If clalev([F:AMKW])=0 : Local File AMSK [AMKW] : Endif
Read [F:AMKW]CODMSK = "HRCCV0"
Case GCURLEG
When "FRA" :
      WSIGN=""
      WDISPBLCK=1
When Default:
      WSIGN="-"
      WDISPBLCK=0
Endcase
# name block
If WDISPBLCK=1
  WNAMEBLCK=func AFNC.TEXTE([F:AMKW]TITBLOC(1))
Endif
Chgtbk [M:HRCCV0]10  With WNAMEBLCK
If WDISPBLCK=1
  WNAMEBLCK=func AFNC.TEXTE([F:AMKW]TITBLOC(2))
Endif
Chgtbk [M:HRCCV0]15  With WNAMEBLCK

#JOJAC - 2016-02-29 REQ 114309 US7 - START
# fields CATFRT=CATTRG in STG
#Chgfmt [M:HRCCV0]DESSHO With WSIGN+"K:10X"
#Chgfmt [M:HRCCV0]GRA With WSIGN+"K:5X"
#Chgfmt [M:HRCCV0]COE With WSIGN+"K:9X"
#Chgfmt [M:HRCCV0]IND With WSIGN+"K:9X"
#Chgfmt [M:HRCCV0]CATCSP    With WSIGN+"K:5c"
#Chgfmt [M:HRCCV0]ZCATCSP    With WSIGN+"KP:30X"
#Chgfmt [M:HRCCV0]SALMIN    With WSIGN+"Nz:6.2"
#Chgfmt [M:HRCCV0]SALMAX    With WSIGN+"Nz:6.2"

#If WSIGN="-" Then
#  Raz [M:HRCCV0]DESSHO
#  Raz [M:HRCCV0]GRA
#  Raz [M:HRCCV0]COE
#  Raz [M:HRCCV0]IND
#  Raz [M:HRCCV0]CATCSP
#  Raz [M:HRCCV0]ZCATCSP
#  Raz [M:HRCCV0]SALMIN
#  Raz [M:HRCCV0]SALMAX
#Endif
#JOJAC - 2016-02-29 REQ 114309 US7 - END


If (func AFNC.ACTIV("FKZQS")>0)
  If GCURLEG = 'ZAF'
    Chgfmt [M:HRCCV0]OCPLEV With "LA:11670"
  Else
    Chgfmt [M:HRCCV0]OCPLEV With "-LA:11670" : Raz [M:HRCCV0]OCPLEV
  Endif
Endif


##########
#refresh all screens
  Affzo [M:HRCCV0]
##########

End





Affzo [M:HRCCV0]
End

