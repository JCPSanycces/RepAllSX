#The functions in this source are shared with events from class EVAEMP (EVAEMP_CSTD_EVT)!!!
#So please consider any changes to be complaint to SOA

Subprog CALC_SCORE(STAT,I_MISWEI,I_MISEQ,I_I_IND,I_INDWEI,I_INDEQ,RETMSG)
Variable Integer STAT
Variable Char RETMSG
Value Integer I_MISWEI,I_MISEQ,I_I_IND,I_INDWEI,I_INDEQ
Local Char FUNCTION(3)
FUNCTION  = "EVA"
Default Mask [M:EVA7]
Call CALC_MISEVASCORE(FUNCTION,STAT,I_MISWEI,I_MISEQ,I_I_IND,I_INDWEI,I_INDEQ)
End

Funprog GET_REV_SCORE(VCEV,VREFNUM,VCTRNUM,VEVASTR,VEVAEND,VEVATYP,VMAIN)
Value Char VREFNUM,VCTRNUM,VEVATYP,VCEV
Value Date VEVASTR,VEVAEND
Value Integer VMAIN
Local Integer ROWCNT
Local Decimal SCORE
If clalev([F:EVE3])=0  : Local File EVAEMP        [EVE3]  : Endif
Filter [EVE3]


For [EVE3]EVE0 Where CEV = VCEV & REFNUM = VREFNUM & CTRNUM = VCTRNUM & EVADATSTR = VEVASTR & EVADATEND = VEVAEND & EVATYP = VEVATYP & EVAMAIREC = VMAIN
  If [F:EVE3]REVWEI <> 0 #We may have an interview that will not count towards total score - so we ignore
    If ([F:EVE3]MISREVSCO*[F:EVE3]REVWEI) <> 0
      SCORE += ([F:EVE3]MISREVSCO*[F:EVE3]REVWEI)/100
    Else
    #Review might not be completed
      End 0
    Endif
  Endif
Next
Filter [EVE3]
End SCORE

Funprog GET_REV_VALIDATE(VCEV,VREFNUM,VCTRNUM,VEVASTR,VEVAEND,VEVATYP,VMAIN)
Value Char VREFNUM,VCTRNUM,VEVATYP,VCEV
Value Date VEVASTR,VEVAEND
Value Integer VMAIN
If clalev([F:EVE3])=0  : Local File EVAEMP        [EVE3]  : Endif
Filter [EVE3]
For [EVE3]EVE1 Where CEV = VCEV & REFNUM = VREFNUM & CTRNUM = VCTRNUM & EVADATSTR = VEVASTR & EVADATEND = VEVAEND & EVATYP = VEVATYP & EVAMAIREC = VMAIN
  If [F:EVE3]EVAVAL < 4
   End 0
  Endif
Next
Filter [EVE3]
End 1



Subprog CALC_MISEVASCORE(FUNCTION,STAT,I_MISWEI,I_MISEQ,I_I_IND,I_INDWEI,I_INDEQ)
Variable Integer STAT
Value Integer I_MISWEI,I_MISEQ,I_I_IND,I_INDWEI,I_INDEQ
Value Char FUNCTION #Will only be used for EVA now but allows for extension
Local Decimal MISSCORE, MISLEVSCORE
Local Integer PERCUNIT : PERCUNIT = 100
Local Integer NOINDSET

#Calculate without any indicators
If I_I_IND <> 2
 Gosub CALC_NOIND
Else
  #Include Indicators
  Gosub CALC_IND
  #After calculating the indicators - calculate final score
  Gosub CALC_NOIND
Endif
End

$CALC_NOIND
MISSCORE = 0
For nolign = 1 To [M]NBRMIS
  If [M]CODMIS(nolign-1) <> ""
    If [M]EVALEVMIS(nolign-1) = "" and NOINDSET = 0 : STAT = 2 : Break : Return : Endif
    If PERCUNIT <> 0
      MISLEVSCORE = ([M]MISWEI(nolign-1) /PERCUNIT)*[M]MISSCO(nolign-1)
    Endif
    MISSCORE += MISLEVSCORE
  Endif
Next

[M]MISREVSCO = ar2(MISSCORE)

Return

$CALC_IND
#Calculating the combined scores of the Indicators and adding it to the missions
Local Integer Y,Z,K
NOINDSET = 1
For nolign = 1 To [M:EVA7]NBRMIS
  If [M:EVA7]WMIS(nolign-1) = "" : Break: Endif
  If [M:EVA7]CODMIS(nolign-1) = [M:EVA7]WMIS(nolign-1)
    MISSCORE = 0
    Y = nolign
    K = 0
    For Z = Y To [M:EVA7]NBRMIS
      If [M]INDLEV(Z-1) = "" : STAT = 2 : Break : Return :Endif
      If K > 0 and [M:EVA7]CODMIS(Z-1) = [M:EVA7]WMIS(Z-1)
      #Break the loop - new mission - write score and set nolign back -1
        #FRLAA 2016-11-07 X3PEOP-2963 START
        [M]MISSCO(Y-1) = ar2(MISSCORE)
        #[M]MISSCO(Y-1) = arr(MISSCORE,0.01)
        #FRLAA 2016-11-07 X3PEOP-2963 END
        nolign-=1
        Break
      Endif
      If PERCUNIT <> 0
        MISLEVSCORE = ([M]INDWEI(Z-1) /PERCUNIT)*[M]INDSCO(Z-1)
      Endif
      MISSCORE += MISLEVSCORE
      If[ M:EVA7]WMIS(Z) = ""
        #FRLAA 2016-11-07 X3PEOP-2963 START
        [M]MISSCO(Y-1) = ar2(MISSCORE)
        #[M]MISSCO(Y-1) = arr(MISSCORE,0.01)
        #FRLAA 2016-11-07 X3PEOP-2963 END
        Break
      Endif
      K+=1
      nolign+=1
    Next
  Endif
Next
Return



Subprog VALID_MISIND(STAT,MSKMISEQ,MSKMISARR,MISWEIARR,MSKINDFLG,MSKINDEQ,WMISARR,INDWEIARR,RETMSG)
Variable Integer STAT
Variable Char RETMSG
Value Integer MSKMISEQ,MSKINDFLG,MSKINDEQ
Variable Decimal MISWEIARR,INDWEIARR
Value Char MSKMISARR,WMISARR
Local Char ERRMESS(50)
Local Integer WRET,I : WRET = 1
#Can set mask for Position and Job
Local Integer K,Z,X,MISCOUNT,INDCOUNT
Local Decimal MISEQWEIGHT, MISEQWEIGHTRES
Local Decimal INDEQWEIGHT, INDEQWEIGHTRES, TOTINDWEIGHT, TOTINDCHECK
Local Char MISCODE(GLONMIS)
TOTINDCHECK = 100
#Check if the system must calculate equal weight - else make sure user added correct weight ( Total = 100)
If MSKMISEQ = 2
  Gosub SET_MIS_EQUAL
Else
  Gosub CHECK_MISWEIGHT
Endif

#Check if indicator has been added and check equal weight
If MSKINDFLG= 2
  If MSKINDEQ = 2
  #Set equal weight for each indicator per mission
    Gosub SET_IND_EQUAL
  Else
  #just check that the weight for each indicator totals to 100 per mission
  Gosub CHECK_INDWEIGHT
  Endif
Endif
STAT = WRET

End

Funprog GET_MISSION_COUNT(MSKMISARR)
Value Char MSKMISARR
Local Integer I, RETVAL
For I = 0 To maxtab(MSKMISARR)
  If MSKMISARR(I) <> ""
    RETVAL+=1
  Endif
  If maxtab(MSKMISARR) = dim(MSKMISARR) : Break : Endif
Next
End RETVAL

$SET_MIS_EQUAL
#Getting the total count of missions
MISCOUNT = func GET_MISSION_COUNT(MSKMISARR)
If MISCOUNT <> 0
  MISEQWEIGHT = 100/MISCOUNT
Endif

#Calculating the weight
MISEQWEIGHTRES = val(func GPLAN.FMTNUM("N0:3.2#",MISEQWEIGHT))

#Adding the calculated weights to the array

For I = 0 To dim(MSKMISARR)-1
  If MSKMISARR(I) <> ""
    MISWEIARR(I) = MISEQWEIGHTRES
  Endif
   #If maxtab(MSKMISARR) = dim(MSKMISARR) : Break : Endif
Next
Return


$CHECK_MISWEIGHT
For I = 0 To dim(MSKMISARR)-1
  If MSKMISARR(I) <> ""
    MISEQWEIGHT+=MISWEIARR(I)
  Endif
  #If maxtab(MSKMISARR) = dim(MSKMISARR) : Break : Endif
Next

MISEQWEIGHT = arr(MISEQWEIGHT,1)
If MISEQWEIGHT <> TOTINDCHECK
 Gosub IND_ERROR_MSG
Endif
Return

$SET_IND_EQUAL
For I = 0 To dim(WMISARR)-1
  If WMISARR(I) = "" : Break: Endif
  If I = 0 #will always be 1 count
    INDCOUNT = 1
    #Check if there is only record
    If dim(WMISARR) = 1
      Gosub SET_INDICATOR_COUNT
    Else
      Gosub SET_IND_EQUAL_SET
    Endif
  Else
    Gosub SET_IND_EQUAL_SET
  Endif
  #If maxtab(WMISARR) = dim(WMISARR) : Break : Endif
Next

Return


$SET_IND_EQUAL_SET
#Check if the next line is blank
If  I < dim(WMISARR)-1
  If WMISARR(I) = WMISARR(I+1)
    If I <> 0 : INDCOUNT += 1 : Endif
  Else
    #Now we need to set the weight
    If I <>  0: INDCOUNT += 1 : Endif
    Gosub SET_INDICATOR_COUNT
  Endif
Else
  #Last record - set
  If I <> 0 : INDCOUNT += 1 : Endif
  Gosub SET_INDICATOR_COUNT
Endif
Return


$CHECK_INDWEIGHT

For I = 0 To dim(MSKMISARR)-1
  If WMISARR(I)= "" : Break: Endif
  #Check if the next line is blank
  If I < dim(MSKMISARR)-1
    If WMISARR(I) = WMISARR(I+1)
      TOTINDWEIGHT += INDWEIARR(I)
    Else
      #Add
      TOTINDWEIGHT += INDWEIARR(I)
      If func VERIFY_INDWEIGHT(TOTINDWEIGHT,TOTINDCHECK) = 0
        Gosub IND_ERROR_MSG
      Endif
      TOTINDWEIGHT = 0
    Endif
  Else
    #Last record - add
    TOTINDWEIGHT += INDWEIARR(I)
    If func VERIFY_INDWEIGHT(TOTINDWEIGHT,TOTINDCHECK) = 0
      Gosub IND_ERROR_MSG
    Endif
    TOTINDWEIGHT = 0
  Endif
Next

Return

$SET_INDICATOR_COUNT
If INDCOUNT = 0 : Return : Endif
MISCODE =  WMISARR(I)
If INDCOUNT <> 0
  INDEQWEIGHT = 100/INDCOUNT
Endif

INDEQWEIGHTRES = val(func GPLAN.FMTNUM("N0:3.2#",INDEQWEIGHT))
For X = 0 To dim(WMISARR)-1
  If WMISARR(X) = MISCODE
    INDWEIARR(X) = INDEQWEIGHTRES
  Endif
Next
INDCOUNT = 0
Return

Funprog VERIFY_INDWEIGHT(TOTWEIGHT,TOTINDCHECKF)
Value Decimal TOTWEIGHT, TOTINDCHECKF
Local Integer RESVALUE : RESVALUE = 0

TOTWEIGHT = arr(TOTWEIGHT,1)
If TOTWEIGHT = TOTINDCHECKF
  RESVALUE = 1
Endif
End RESVALUE

$IND_ERROR_MSG
RETMSG = mess(3,2455,1)
WRET = 0

Return

#----------------------------------------------------------------------------------------------------------------#

