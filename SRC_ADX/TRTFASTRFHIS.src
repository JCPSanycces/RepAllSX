#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################
# AFFICHAGE DES IMPUTATIONS DU BIEN AVANT LE DERNIER TRANSFERT ANA / GEO
#
# Création le :     18/12/2007
# Modification le : XX/XX/XXXX
################################################################################
# MDJ   09.02.2015 FQ100398   : Suppression site géographique
# MWA   25.07.2013 FQ78968    : Gestion LASM Livraison à soi même.
# GLE   02.02.2010 FQ57840    : Ajout d'un paramètre à GET_IMPUT_GEOANA_ORI pour récupérer le type de tranfert
################################################################################
$ACTION
 #Infbox ACTION
 Case ACTION
  When "OUVRE" : Gosub OUVRE
  When "DEBUT" : Gosub DEBUT
  When Default
 Endcase
Return

################################################################################
$OUVRE
 Local Char    BCOREF
 Local Char    BCOCPY
 Local Char    BCOFCY
 Local Date    BCOTRFDAT
 Local Char    EVTTRF : EVTTRF="FASAFFAGE"
 Local Integer ANNEE
 Local Integer MOIS
 Local Integer JOUR
 BCOCPY    = PARAM(1)
 BCOFCY    = PARAM(2)
 BCOREF    = PARAM(3)
 ANNEE = val(left$(PARAM(4),4))
 MOIS  = val(mid$(PARAM(4),5,2))
 JOUR  = val(right$(PARAM(4),7))
 BCOTRFDAT = gdat$(JOUR,MOIS,ANNEE)
Return

################################################################################
$DEBUT
 Local Integer NBREVT  : NBREVT=0
 Local Integer I_AXE
 Local Char    SECTION

 #????
 # Local Integer PLAN
 # PLAN = func TRTFASTRFHIS.GET_PLN_EVE_TRF(BCOCPY,BCOFCY,BCOREF,BCOTRFDAT)

 If !clalev([F:TB0]) : Local File EFASAFFAGE [TB0] : Endif
 Local Integer BFIRST : BFIRST = 1
 Local Integer I_PLN
 For I_PLN = 1 To [M:FPC]NBPLN
  Filter [F:TB0] Where (CPY=BCOCPY & DPRPLN=[M:FPC]DPRPLN(I_PLN-1) & REF=BCOREF & EVTDAT=BCOTRFDAT & EVTPRINC=G_OUI)
  For [TB0]EVE0
   # On recherche l'événement du site financier d'origine au cas où il y aurait eu un transfert de site financier
   If [F:TB0]FCYD='' or [F:TB0]FCY<>[F:TB0]FCYD : Break : Endif
  Next
  Filter [F:TB0]
  If (BFIRST) Then
   BFIRST = 0
   [M:FASH]FCY    = [F:TB0]FCY
   ####[M:FASH]LOC    = [F:TB0]LOCO
   [M:FASH]AASBUS = [F:TB0]AASBUSO
   [M:FASH]UGTIAS = [F:TB0]IASCGUO
   [M:FASH]DSP    = [F:TB0]DSPO
   Raz nolign
   #???
   #For I_AXE=1 To min(GOPTCANA,9)
   # [M:FASH]DIE(I_AXE-1) = I_AXE
   # [M:FASH]CCE(I_AXE-1) = evalue("[F:TB0]CCE"+num$(I_AXE)+"O")
   #Next I_AXE
   #[M:FASH]NBLIG=I_AXE-1
   Local Integer I_DIE
   Raz nolign
   For I_DIE=1 To [M:FPC]NBDIE
    nolign+=1
    [M:FASH]DIE(nolign-1)   = [M:FPC]DIE(I_DIE-1)
   Next I_DIE
   [M:FASH]NBLIG=nolign
  Endif
  For I_DIE= 1 To [M:FPC]NBDIE
    If ( evalue("[F:TB0]DIE"+num$(I_DIE)) = "" ) Then : Break : Endif
    [M:FASH]CCE(find (evalue("[F:TB0]DIE"+num$(I_DIE)),[M:FASH]DIE)-1) = evalue("[F:TB0]CCE"+num$(I_DIE)+"O")
  Next I_DIE
 Next I_PLN

 Grizo [M:FASH]CCE
 Affzo [M:FASH]

Return

################################################################################
Subprog LST_PLN_EVE_TRF(PCPY,PFCY,PREF,PEVTDAT,REVEPLN)
Value    Char    PCPY       # Société du BCO
Value    Char    PFCY       # Site du BCO (Obsolète)
Value    Char    PREF       # référence du BCO
Value    Date    PEVTDAT    # Date d'effet du transfert
Variable Integer REVEPLN(0..) # Liste de flag d'existence d'un événement par plan

Local Integer I_PLN
For I_PLN=1 To G301MAX-1
 REVEPLN(I_PLN-1)=G_NON
Next I_PLN

If !clalev([F:TB0]) : Local File EFASAFFAGE [TB0] : Endif
Filter [TB0] Where (CPY=PCPY & REF=PREF & EVTDAT=PEVTDAT & SNSEVE<>GVML_TEAACT & EVTPRINC=G_OUI)
For [TB0]EVE0
 REVEPLN([F:TB0]DPRPLN-1)=G_OUI
Next
Filter [TB0]

End

################################################################################
Funprog GET_PLN_EVE_TRF(PCPY,PFCY,PREF,PEVTDAT)
Value    Char    PCPY       # Société du BCO
Value    Char    PFCY       # Site du BCO (Obsolète)
Value    Char    PREF       # référence du BCO
Value    Date    PEVTDAT    # Date d'effet du transfert

Local Integer PLAN
Local Integer I_PLN
Local Integer EVEPLN(0..G301MAX-2)

Call LST_PLN_EVE_TRF(PCPY,PFCY,PREF,PEVTDAT,EVEPLN) From TRTFASTRFHIS

PLAN=0

For I_PLN=1 To G301MAX-1
 If EVEPLN(I_PLN-1)=G_OUI
  PLAN=I_PLN
  Break
 Endif
Next I_PLN

End PLAN

################################################################################
Funprog EXISTE_EVE_TRF(PCPY,PPLN,PFCY,PREF,PEVTDAT)
Value Char    PCPY          # Société du BCO
Value Integer PPLN          # Plan d'amortissement à vérifier
Value Char    PFCY          # Site du BCO
Value Char    PREF          # Référence du BCO
Value Date    PEVTDAT       # Date d'effet de l'événement à retrouver.

Local Integer EXISTE : EXISTE=0

 If !clalev([F:TB0]) : Local File EFASAFFAGE [TB0] : Endif
 Filter [F:TB0] Where (CPY=PCPY & DPRPLN=PPLN & REF=PREF & EVTDAT=PEVTDAT & SNSEVE<>GVML_TEAACT & EVTPRINC=G_OUI)
 Read[TB0]EVE0 Last
 Filter [F:TB0]

If fstat=0
 EXISTE=1
Else
 EXISTE=0
Endif

End EXISTE

################################################################################

Subprog GET_ETRNOT_ORI(PCPY, PPLN, PFCY, PREF, PEVTDAT, RACGETRNOT, RIASETRNOT, RETOUR)
Value    Char    PCPY
Value    Integer PPLN
Value    Char    PFCY
Value    Char    PREF
Value    Date    PEVTDAT
Variable Decimal RACGETRNOT
Variable Decimal RIASETRNOT
Variable Integer RETOUR

 If !clalev([F:TB0]) : Local File EFASAFFAGE [TB0] : Endif
 Filter [F:TB0] Where (CPY=PCPY & DPRPLN=PPLN & REF=PREF & EVTDAT=PEVTDAT & SNSEVE<>GVML_TEAACT & EVTPRINC=G_OUI)
 For [TB0]EVE0
   # On recherche l'événement du site financier d'origine au cas où il y aurait eu un transfert de site financier
   If [F:TB0]FCYD='' or [F:TB0]FCY<>[F:TB0]FCYD : Break : Endif
 Next
 Filter [F:TB0]

If fstat=0
 RACGETRNOT = [F:TB0]ACGETRNOT
 RIASETRNOT = [F:TB0]IASETRNOT
 RETOUR=0
Else
 Raz RACGETRNOT, RIASETRNOT
 RETOUR=1
Endif

End



################################################################################
# Pour ce sous-programme, on suppose que la classe [F:EVT0] existe. Si l'événement
# est trouvé, il est chargé dans la classe et le code retour vaut 0. S'il n'est pas
# trouvé, le code retour vaut fstat
#
Subprog CHARGE_EVE_TRF(PCPY,PPLN,PREF,PEVTDAT,RCOD)
Value Char PCLASSE
Value Integer PPLN
Value Char    PFCY
Value Char    PREF
Value Date    PEVTDAT

 Filter [F:EVT0] Where (CPY=PCPY & DPRPLN=PPLN & REF=PREF & EVTDAT=PEVTDAT & SNSEVE<>GVML_TEAACT)
 Read[EVT0]EVE0 Last
 Filter [F:EVT0]

If fstat=0
 RCOD=0
Else
 RCOD=fstat
Endif

End
################################################################################
# FQ57840 FQ78968
Subprog GET_IMPUT_GEOANA_ORI(PCPY,PFCY,PREF,PEVTDAT,RFCYORI,RAASBUSORI,RIASCGUORI,RDSPORI,RCCETABORI,RTRFDATORI,
&       RPCGDEV,RIASDEV,RDEDVATRAT,RDEDVATRATI,RTRFTYP,RIVCVATAMT,RIVCVATFLG,RIVCVATAMTI,RIVCVATFLGI,
&       RTAXCOE, RTAXCOEF, RREGULPCGO, RREGULIASO, RVATREGDAT, RCOD)
#
#  Prérequis : La classe [M:FPC] doit avoir été au préalable ouverte et alimentée
#
Value    Char    PCPY
Value    Char    PFCY
Value    Char    PREF
Value    Date    PEVTDAT
Variable Char    RFCYORI
Variable Char    RAASBUSORI
Variable Char    RIASCGUORI
Variable Char    RDSPORI
Variable Char    RCCETABORI()()
Variable Date    RTRFDATORI
Variable Decimal RPCGDEV
Variable Decimal RIASDEV
Variable Decimal RDEDVATRAT
Variable Decimal RDEDVATRATI
Variable Shortint RTRFTYP : # FQ57840

Variable Decimal RIVCVATAMT # FQ78968
Variable Integer RIVCVATFLG
Variable Decimal RIVCVATAMTI
Variable Integer RIVCVATFLGI
Variable Decimal RTAXCOE
Variable Decimal RTAXCOEF
Variable Decimal RREGULPCGO
Variable Decimal RREGULIASO
Variable Date    RVATREGDAT

Variable Integer RCOD

Local Integer I_DIE
Local Integer I_AXE

#Local Integer PLAN
#PLAN=func TRTFASTRFHIS.GET_PLN_EVE_TRF(PCPY,PFCY,PREF,PEVTDAT)

Raz RCOD
RREGULPCGO = 0. : # FQ78968
RREGULIASO = 0.

If !clalev([F:TB0]) : Local File EFASAFFAGE [TB0] : Endif

Local Integer BFIRST : BFIRST = 1
Local Integer I_PLN
For I_PLN = 1 To [M:FPC]NBPLN
 Filter [F:TB0] Where (CPY=PCPY & REF=PREF & DPRPLN=[M:FPC]DPRPLN(I_PLN-1) & EVTDAT=PEVTDAT & SNSEVE<>GVML_TEAACT & EVTPRINC=G_OUI)
&               Order By TIMSTP Desc
 # On recherche l'événement correspondant au site d'origine pour le cas où il y aurait eu un transfert de site financier
 For [F:TB0]
  If [F:TB0]FCYD='' or [F:TB0]FCY<>[F:TB0]FCYD : Break : Endif
 Next
 If (BFIRST) Then
  BFIRST = 0
  RFCYORI     = [F:TB0]FCY
  ####RLOCORI     = [F:TB0]LOCO
  RAASBUSORI  = [F:TB0]AASBUSO
  RIASCGUORI  = [F:TB0]IASCGUO
  RDSPORI     = [F:TB0]DSPO
  RTRFDATORI  = [F:TB0]LASTDATTRF
  RPCGDEV     = [F:TB0]PCGDEV
  RIASDEV     = [F:TB0]IASDEV
  RDEDVATRAT  = [F:TB0]DEDVATRAT
  RDEDVATRATI = [F:TB0]DEDVATRATI
  RTRFTYP     = [F:TB0]TRFTYP : # FQ57840

  RIVCVATAMT  = [F:TB0]IVCVATAMT :# FQ78968
  RIVCVATFLG  = [F:TB0]IVCVATFLG
  RIVCVATAMTI = [F:TB0]IVCVATAMTI
  RIVCVATFLGI = [F:TB0]IVCVATFLGI
  RTAXCOE     = [F:TB0]TAXCOE
  RTAXCOEF    = [F:TB0]TAXCOEF
  RVATREGDAT  = [F:TB0]VATREGDAT
 Endif

 # FQ78968
 If ([F:TB0]DPRPLN = G301CPT) Then : RREGULPCGO = [F:TB0]REGUL : Endif
 If ([F:TB0]DPRPLN = G301IAS) Then : RREGULIASO = [F:TB0]REGUL : Endif

 For I_AXE=1 To 9
  If ( evalue("[F:TB0]DIE"+num$(I_AXE)) = "" ) Then : Break :  Endif
  I_DIE = find(evalue("[F:TB0]DIE"+num$(I_AXE)),[M:FPC]DIE)
  RCCETABORI(I_DIE-1)=evalue("[F:TB0]CCE"+num$(I_AXE)+"O")
 Next I_AXE
Next I_PLN

If fstat & BFIRST
 RCOD=1
 End
Endif

End
