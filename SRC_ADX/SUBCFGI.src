#<AdxTL>@(#)7.0.0.0 $Revision$ Gestion du masque CFGINP
############################################################
Subprog AS_SELNUM(VALEUR)
Variable Char    VALEUR()
If [M:CFGI]OPTNUM <> "" |
&  [M:CFGI]SCENUM <> ""
  mkstat = 2
Endif
End
############################################################
Subprog AM_SELNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  Read [CSE]CSE0=VALEUR
  If fstat
    mkstat = 2
  Else
    [M:CFGI]SELNUM    = VALEUR
    [M:CFGI]SELNUMTXT = [F:CSE]SELDES
    [M:CFGI]OPTNUM    = ""
    [M:CFGI]OPTNUMTXT = ""
    [M:CFGI]SCENUM    = ""
    [M:CFGI]SCEDES    = ""
    Affzo [M:CFGI]SELNUMTXT
    Affzo [M:CFGI]OPTNUM
    Affzo [M:CFGI]OPTNUMTXT
    Affzo [M:CFGI]SCENUM
    Affzo [M:CFGI]SCEDES
  Endif
Else
  [M:CFGI]SELNUMTXT = ""
  Affzo [M:CFGI]SELNUMTXT
Endif
End
############################################################
Subprog AS_OPTNUM(VALEUR)
Variable Char    VALEUR()
If [M:CFGI]SELNUM <> "" |
&  [M:CFGI]SCENUM <> ""
  mkstat = 2
Endif
End
############################################################
Subprog AM_OPTNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  Read [CSE]CSE0=VALEUR
  If fstat
    mkstat = 2
  Else
    [M:CFGI]SELNUM    = ""
    [M:CFGI]SELNUMTXT = ""
    [M:CFGI]OPTNUM    = VALEUR 
    [M:CFGI]OPTNUMTXT = [F:CSE]SELDES
    [M:CFGI]SCENUM    = ""
    [M:CFGI]SCEDES    = ""
    Affzo [M:CFGI]SELNUM
    Affzo [M:CFGI]SELNUMTXT
    Affzo [M:CFGI]OPTNUMTXT
    Affzo [M:CFGI]SCENUM
    Affzo [M:CFGI]SCEDES
  Endif
Else
  [M:CFGI]OPTNUMTXT = ""
  Affzo [M:CFGI]OPTNUMTXT
Endif
End
############################################################
Subprog AS_SCENUM(VALEUR)
Variable Char    VALEUR()
If [M:CFGI]SELNUM <> "" |
&  [M:CFGI]OPTNUM <> ""
 mkstat = 2
Endif
End
############################################################
Subprog AM_SCENUM(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  Read [CSC]CSC0=VALEUR
  If fstat
    mkstat = 2
  Else
    [M:CFGI]SELNUM    = ""
    [M:CFGI]SELNUMTXT = ""
    [M:CFGI]OPTNUM    = ""
    [M:CFGI]OPTNUMTXT = ""
    [M:CFGI]SCENUM    = VALEUR
    [M:CFGI]SCEDES    = [F:CSC]SCEDES
    Affzo [M:CFGI]SELNUM
    Affzo [M:CFGI]SELNUMTXT
    Affzo [M:CFGI]OPTNUM
    Affzo [M:CFGI]OPTNUMTXT
    Affzo [M:CFGI]SCEDES
  Endif
Else
  [M:CFGI]SCEDES = ""
  Affzo [M:CFGI]SCEDES
Endif
End
############################################################
Subprog IB_SCENUM
Local Char W_PROINI(5)
Call PARAM([M]FCY,"CFGINI",W_PROINI) From ADOVAL
If W_PROINI = ""
  GBOUT2 = ""
Endif
End

