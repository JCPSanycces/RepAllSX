End

#========================================================================
$SET_CONSTANTES

 #=> Constantes gÃĐnÃĐrales de l'action mÃĐtier

  Global Char    ACTTRTPRE(2)  : ACTTRTPRE   = "TR"   # PrÃĐfixe des traitements modÃĻles action mÃĐtier
  Global Char    ACTTRTSUF1(3) : ACTTRTSUF1  = "PRO"  # Suffixe des traitements modÃĻles action mÃĐtier
  Global Char    ACTTRTSUF2(3) : ACTTRTSUF2  = "ACT"  # Suffixe des traitements modÃĻles
  Global Integer DIMCRITACT    : DIMCRITACT  = 4      # Dimension maximum de la variable critÃĻre de sÃĐlection de population

 #=> Constantes d'ÃĐtat de l'action mÃĐtier

  Global Integer STA_DEBUT     : STA_DEBUT   = 0      # DÃĐbut de l'action : tout est Ã  faire
  Global Integer STA_LOCK      : STA_LOCK    = 1      # La population est lockÃĐe
  Global Integer STA_TEMP      : STA_TEMP    = 3      # La population est sÃĐlectionnÃĐe et chargÃĐe dans la table temporaire
  Global Integer STA_MODIF     : STA_MODIF   = 8      # Les paramÃĻtres de l'action ont ÃĐtÃĐ appliquÃĐs sur la population
  Global Integer STA_MAJ       : STA_MAJ     = 9      # Les modifications ont ÃĐtÃĐ enregistrÃĐes dans les tables de donnÃĐes

Return

#========================================================================
$DEF_GLOBALES
 #=> Globales de stockage des paramÃĻtres

  Global Char    ACTTYPGES                            # Type de traitement (Massif "M" ou unitaire "U")  Param(1)
  Global Char    ACTMETNAM                            # Nom de l'action mÃĐtier Ã  traiter                 Param(2)
  Global Char    ACTREFOBJ                            # Objet mÃĐtier auquel s'applique l'action mÃĐtier   Param(3)
  Global Integer ACTMONCPY                            # Action mono-sociÃĐtÃĐ Oui/Non                      Param(4)
  Global Integer ACTGESPLN                            # Action gÃĐrÃĐe par plan d'amortissement            Param(5)
  Global Integer ACTSILENCE                           # Action en mode silencieux                        Param(6) Facultatif
  Global Char    TRTFILMSK                            # Traitement d'alim des masques critÃĻres           Param(7) Facultatif

 #=> Globales techniques du modÃĻle action mÃĐtier

  Global Integer FLGREP                               # Objet de reprise oui/non

  Global Integer NUMACT                               # NumÃĐro de traitement
  Global Char    ACTTRTNAM                            # Nom du traitement Ã  appeler (Massif ou unitaire)
  Global Char    ACTTRTACT                            # Traitement propre Ã  l'action
  Global Char    ACTTRTSPE                            # Traitement spÃĐcifique de l'action mÃĐtier
  Global Integer ACTFLGSPE                            # Indicateur de prÃĐsence de traitement spÃĐ : contenant $ACTMET
  Global Char    TRTACTMAS                            # Idem -> pour compatibilitÃĐ modÃĻle v1
  Global Integer ACTSTATUS                            # Indique l'ÃĐtape de l'action mÃĐtier
  Global Char    ACTMET                               # Nom d'ÃĐtiquette action mÃĐtier
  Global Char    ORIACT                               # Permet l'aiguillage dans TRT+nom action (Pour l'objet de reprise)
  Global Char    LKEY                                 # Identifiant de lock
  Global Integer LOCKOK                               # Flag de Lock d'un enregistrement
  Global Integer ABANDON_TRT                          # Flag de sortie du traitement massif (pour ÃĐviter $EXEC)
  Global Char    USRDBG                               # User de debug
  Global Integer PRECHARGE                            # En unitaire, permet si G_OUI de prÃĐcharger la population sans clic sur sÃĐlectionner
  Global Integer CALC_MOTEUR                          # Action utilisant le moteur de calcul oui / non
  Global Integer GNOTRCCALC                           # UtilisÃĐ par les outils de calcul (GLOCALCx) pour la gestion de la trace
  Global Char    GTRCCPY(GLONCPY)                     # UtilisÃĐ dans GLOCALC3
  Global Integer MOTEUR_ACTIF                         # La connexion au moteur de calcul est active oui / non
  Global Integer MODELTRAX3                           # Utilise les s/p de trace standards de X3 Oui / Non
  Global Decimal TOTOBJAMT(0..4)                      # Totaux pour ventilation
  Global Integer GHEADERRTRC                          # En-tÃŠte erreur dÃĐjÃ  ÃĐmis ?
  Global Char    GHEADERRCPY                          # SociÃĐtÃĐ de rupture de l'en-tÃŠte erreurs
  Global Integer GNBTRCLST : GNBTRCLST=2              # Nombre de listes Ã  gÃĐrer au maximum
  Global Integer GHEADLSTTRC(0..GNBTRCLST-1)          # En-tÃŠte liste n dÃĐjÃ  ÃĐmis ?
  Global Char    GLSTTITRE(50)(0..GNBTRCLST-1)        # Titre des listes d'objets
  Global Char    GLSTCOLNAM(80)(0..GNBTRCLST-1)       # Titre des colonnes spÃĐcifiques (en plus de la rÃĐfÃĐrence des objets)

 #=> Globales objets et tables gÃĐrÃĐs par l'action mÃĐtier

  Global Char    TMPOBJ                               # Objet X3 de gestion de la table temporaire associÃĐe Ã  l'objet mÃĐtier
  Global Char    TABOBJ                               # Table principal de l'objet mÃĐtier
  Global Char    TMPTAB                               # Table temporaire associÃĐe Ã  l'objet mÃĐtier
  Global Char    TMPTAB2                              # Table temporaire complÃĐmentaire associÃĐe Ã  l'objet mÃĐtier
  Global Char    TMPTABPLN                            # Table temporaire par plan

 #=> Globales fonctionnelles

 #Global Char    GCURACT                              # Pour les actions mono-sociÃĐtÃĐ, devise de la sociÃĐtÃĐ

 #=> Globales statistiques

  Global Integer NBOBJ                                # Nombre d'objets dans la population
  Global Integer NBOBJLCK                             # Nombre d'objets lockÃĐs
  Global Integer NBOBJNLCK                            # Nombre d'objets non lockÃĐs
  Global Integer NBCPYTRT                             # Nombre d'objets traitÃĐs pour une sociÃĐtÃĐ
  Global Integer NBCPYMAJ                             # Nombre d'objets mis Ã  jour
  Global Integer NBCPYERR                             # Nombre d'objets erronÃĐs
  Global Integer NBTMP                                # Nombre d'enregistrements dans la table temporaire principale # pour dev.
  Global Integer NBTMPPLN                             # Nombre d'enregistrements dans la table temporaire annexe     # pour dev.

 #=> Globales critÃĻres de construction de requÃŠtes

 # RAF - On peut envoyer un EVALUE sur une variable dimensionnÃĐe. Il est donc possible de remplacer les quatre CRITxxxx
 #       par un CRITACT(255)(0..n)

  Global  Char   CRITSUPR(255)                        # CritÃĻre tous objets, toutes actions
  Global  Char   CRITOBJ(255)                         # CritÃĻre toutes actions pour un objet donnÃĐ
  Global  Char   CRITACT(255)                         # CritÃĻre particulier Ã  l'action
  Global  Char   CRITSUP1(255)                        # CritÃĻre supplÃĐmentaire sur la table de l'objet mÃĐtier associÃĐ Ã  l'action

 #=> Globales Contenant des messages ÃĐmis par le modÃĻle, modifiables par les actions utilisatrices du modÃĻle

  Global  Char   GMSGNOOBJLCK(80) : GMSGNOOBJLCK="La population est vide. Modifiez vos critÃĻres de sÃĐlection."

 #=> Raz et init de certaines globales

  Raz ACTSTATUS
  Raz ABANDON_TRT

  CALC_MOTEUR  = G_NON
  MOTEUR_ACTIF = G_NON
  MODELTRAX3   = G_OUI
  ACTSILENCE   = G_NON

  USRDBG       =""
  Raz GHEADERRTRC
  Raz GHEADERRCPY

Return

#========================================================================
$KILL_CONSTANTES

 If dim(ACTTRTPRE)>0     : Kill ACTTRTPRE     : Endif
 If dim(ACTTRTSUF1)>0    : Kill ACTTRTSUF1    : Endif
 If dim(ACTTRTSUF2)>0    : Kill ACTTRTSUF2    : Endif
 If dim(DIMCRITACT)>0    : Kill DIMCRITACT    : Endif
 If dim(STA_DEBUT)>0     : Kill STA_DEBUT     : Endif
 If dim(STA_LOCK)>0      : Kill STA_LOCK      : Endif
 If dim(STA_TEMP)>0      : Kill STA_TEMP      : Endif
 If dim(STA_MODIF)>0     : Kill STA_MODIF     : Endif
 If dim(STA_MAJ)>0       : Kill STA_MAJ       : Endif

Return

#========================================================================
$KILL_GLOBALES

 If dim(ACTTYPGES)>0   : Kill ACTTYPGES   : Endif
 If dim(ACTMETNAM)>0   : Kill ACTMETNAM   : Endif
 If dim(ACTREFOBJ)>0   : Kill ACTREFOBJ   : Endif
 If dim(ACTMONCPY)>0   : Kill ACTMONCPY   : Endif
 If dim(ACTGESPLN)>0   : Kill ACTGESPLN   : Endif
 If dim(ACTSILENCE)>0  : Kill ACTSILENCE  : Endif
 If dim(TRTFILMSK)>0   : Kill TRTFILMSK   : Endif
 If dim(FLGREP)>0      : Kill FLGREP      : Endif
 If dim(ACTTRTNAM)>0   : Kill ACTTRTNAM   : Endif
 If dim(ACTTRTACT)>0   : Kill ACTTRTACT   : Endif
 If dim(ACTTRTSPE)>0   : Kill ACTTRTSPE   : Endif
 If dim(ACTFLGSPE)>0   : Kill ACTFLGSPE   : Endif
 If dim(ACTSTATUS)>0   : Kill ACTSTATUS   : Endif
 If dim(ACTMET)>0      : Kill ACTMET      : Endif
 If dim(ORIACT)>0      : Kill ORIACT      : Endif
 If dim(LKEY)>0        : Kill LKEY        : Endif
 If dim(LOCKOK)>0      : Kill LOCKOK      : Endif
 If dim(ABANDON_TRT)>0 : Kill ABANDON_TRT : Endif
 If dim(USRDBG)>0      : Kill USRDBG      : Endif
 If dim(PRECHARGE)>0   : Kill PRECHARGE   : Endif
 If dim(CALC_MOTEUR)>0 : Kill CALC_MOTEUR : Endif
 If dim(GNOTRCCALC)>0  : Kill GNOTRCCALC  : Endif
 If dim(GTRCCPY)>0     : Kill GTRCCPY     : Endif
 If dim(MOTEUR_ACTIF)>0: Kill MOTEUR_ACTIF: Endif
 If dim(MODELTRAX3)>0  : Kill MODELTRAX3  : Endif
 If dim(TOTOBJAMT)>0   : Kill TOTOBJAMT   : Endif
 If dim(GHEADERRTRC)>0 : Kill GHEADERRTRC : Endif
 If dim(GHEADERRCPY)>0 : Kill GHEADERRCPY : Endif
 If dim(GNBTRCLST)>0   : Kill GNBTRCLST   : Endif
 If dim(GHEADLSTTRC)>0 : Kill GHEADLSTTRC : Endif
 If dim(GLSTTITRE)>0   : Kill GLSTTITRE   : Endif
 If dim(GLSTCOLNAM)>0  : Kill GLSTCOLNAM  : Endif
 If dim(TMPOBJ)>0      : Kill TMPOBJ      : Endif
 If dim(TABOBJ)>0      : Kill TABOBJ      : Endif
 If dim(TMPTAB)>0      : Kill TMPTAB      : Endif
 If dim(TMPTAB2)>0     : Kill TMPTAB2     : Endif
 If dim(TMPTABPLN)>0   : Kill TMPTABPLN   : Endif
 If dim(NBOBJ)>0       : Kill NBOBJ       : Endif
 If dim(NBOBJLCK)>0    : Kill NBOBJLCK    : Endif
 If dim(NBOBJNLCK)>0   : Kill NBOBJNLCK   : Endif
 If dim(NBCPYTRT)>0    : Kill NBCPYTRT    : Endif
 If dim(NBCPYMAJ)>0    : Kill NBCPYMAJ    : Endif
 If dim(NBCPYERR)>0    : Kill NBCPYERR    : Endif
 If dim(NBTMP)>0       : Kill NBTMP       : Endif
 If dim(NBTMPPLN)>0    : Kill NBTMPPLN    : Endif
 If dim(CRITSUPR)>0    : Kill CRITSUPR    : Endif
 If dim(CRITOBJ)>0     : Kill CRITOBJ     : Endif
 If dim(CRITACT)>0     : Kill CRITACT     : Endif
 If dim(CRITSUP1)>0    : Kill CRITSUP1    : Endif
 If dim(GMSGNOOBJLCK)>0: Kill GMSGNOOBJLCK: Endif

 If dim(TRTACTMAS)>0   : Kill TRTACTMAS : Endif # A supprimer -> pour compatibilitÃĐ modÃĻle V1

Return

#========================================================================
$GET_PARAMETRES

 #-> PARAM(1) - RÃĐcupÃĐration du paramÃĻtre Massif / unitaire
  If PARAM(1)<>""
   ACTTYPGES=PARAM(1)
  Else
   # FQ83184 "Valeur inconnue pour le paramÃĻtre ACTTYPGES"
   Infbox  mess(87,GML_MSGTRC,1) : ABANDON_TRT=1 : FIN=1 : Return
  Endif
  ACTTRTNAM=ACTTRTPRE+ACTTYPGES+ACTTRTSUF1+ACTTRTSUF2
  #Infbox ACTTYPGES # Tst

 #-> PARAM(2) - RÃĐcupÃĐration du nom de l'action mÃĐtier
  If PARAM(2)<>""
   ACTMETNAM=PARAM(2)
  Else
   # FQ83184 "Valeur inconnue pour le paramÃĻtre ACTNAM"
   Infbox mess(88,GML_MSGTRC,1) : ABANDON_TRT=1 : FIN=1 : Return
  Endif

  ACTTRTACT=ACTTRTPRE+"T"+ACTMETNAM
  TRTACTMAS=ACTTRTACT                        # A supprimer -> Pour compatibilitÃĐ modÃĻle V1

 #-> PARAM(3) - RÃĐcupÃĐration du type d'objet mÃĐtier auquel est associÃĐe l'action massive
  Case num$(PARAM(3))
   When "1" : ACTREFOBJ="LOF"
   When "2" : ACTREFOBJ="FAS"
   When "4" : ACTREFOBJ="LEA"
   When "6" : ACTREFOBJ="PHY"
   # FQ83184 "Type d'objet mÃĐtier inconnu"
   When Default : Infbox mess(89,GML_MSGTRC,1) : ABANDON_TRT=1 : FIN=1 : Return
  Endcase

 #-> PARAM(4) - RÃĐcupÃĐration du paramÃĻtre action mono-sociÃĐtÃĐ oui/non
  Case num$(PARAM(4))
   When "1" : ACTMONCPY=val(PARAM(4))
   When "2" : ACTMONCPY=val(PARAM(4))
   When Default
    Infbox mess(90,GML_MSGTRC,1): # FQ83184 "Action mono-sociÃĐtÃĐ doit ÃŠtre 1 (Non) ou 2 (Oui)"
    ABANDON_TRT=1 : FIN=1 : Return
  Endcase

 #-> PARAM(5) - RÃĐcupÃĐration du paramÃĻtre action gÃĐrÃĐe par plan d'amortissement oui / non
  Case num$(PARAM(5))
   When "1" : ACTGESPLN=val(PARAM(5))
   When "2" : ACTGESPLN=val(PARAM(5))
   When Default
    Infbox mess(91,GML_MSGTRC,1) : # FQ83184 "Action gÃĐrÃĐe par plan doit ÃŠtre 1 (Non) ou 2 (Oui)"
    ABANDON_TRT=1 : FIN=1 : Return
  Endcase

 #-> PARAM(6) - RÃĐcupÃĐration du paramÃĻtre action en mode silencieux oui / non

 If PARAM(6)<>"" & PARAM(7)<>""
  ACTSILENCE=val(PARAM(6))
  TRTFILMSK =PARAM(7)
 Else
  ACTSILENCE = G_NON
  TRTFILMSK  = ""
 Endif

Return

#========================================================================
$SET_TRTNUM

 #=> DÃĐtermination / alimentation du numÃĐro de traitement

 # Si le numÃĐro de traitement n'est pas affectÃĐ :
 #   - Mode silencieux et transaction initiÃĐe par l'appelant : on prend la derniÃĻre valeur de compteur : incrÃĐment Ã  rÃĐaliser par l'appelant
 #   - Mode silencieux et transaction non initiÃĐe par l'appelant : on incrÃĐmente le compteur
 #   - Mode non silencieux : dans tous les cas, on incrÃĐmente le compteur.

 If NUMACT=0
  If !clalev([F:ACM])  : Local File APLCOM     [ACM]  : Endif
  If dim(ACTSILENCE)>0 & ACTSILENCE=G_OUI
   If !GTRANS
    Trbegin [ACM]
    [C]TRTACTMET+=1
    Commit
    NUMACT=[C]TRTACTMET
   Else
    NUMACT=[C]TRTACTMET
   Endif
  Else
   Trbegin [ACM]
   [C]TRTACTMET+=1
   Commit
   NUMACT=[C]TRTACTMET
  Endif
 Endif

Return

#========================================================================
$PREP_ACT
#=> PrÃĐparation de l'action

 Raz PARAM : PARAM(1)=ACTREFOBJ
 Case ACTREFOBJ
  When "FAS"                   #--- Biens comptables ---------------#
   TMPTAB    = "TMPMASFAS"
   TMPTAB2   = "TMPMASFA2"
   If ACTGESPLN=G_OUI
    TMPTABPLN = "TMPPLNFAS"
   Else
    TMPTABPLN = ""
   Endif
   TMPOBJ    = "MAS"
   TABOBJ    = "FXDASSETS"
   If !clalev([F:FAS]) : Local File FXDASSETS [FAS] : Endif
  When "LOF"                  #--- DÃĐpense -------------------------#
   TMPTAB    = "TMPMASLOF"
   TMPTABPLN = ""
   TMPOBJ    = "MLF"
   TABOBJ    = "LAYOUTFAS"
   If !clalev([F:LOF]) : Local File LAYOUTFAS [LOF] : Endif
  When "LEA"                  #--- Contrats location financement ---#
   TMPTAB    = "TMPMASLEA"
   TMPTABPLN = ""
   TMPOBJ    = "TLE"
   TABOBJ    = "LEASE"
   If !clalev([F:LEA]) : Local File LEASE [LEA] : Endif
  When "PHY"                   #--- ElÃĐments physiques -------------#
   TMPTAB    = "TMPMASPHY"
   If ACTGESPLN=G_OUI
    TMPTABPLN = "TMPPLNPHY"
   Else
    TMPTABPLN = ""
   Endif
   TMPOBJ    = "MPY"
   TABOBJ    = "PHYELT"
   If !clalev([F:PHY]) : Local File PHYELT [PHY] : Endif
  When Default
 Endcase

 If !clalev([M:FPC]) : Local Mask FASPARCPY : Endif #@fq65636

 # RÃĐcupÃĐration du nom du traitement spÃĐcifique

 # Si l'action est appelÃĐ en silencieux, on dÃĐduit le nom de l'action de la globale ACTMETNAM, sinon on prend GACTION
 Local Char LACTION
 If ACTTYPGES=GTAMMAS & ACTSILENCE=G_OUI
  LACTION=ACTMETNAM+"M"
 Else
  LACTION=GACTION
 Endif

 If !clalev([F:ACT]) : Local File ACTION [ACT] : Endif
 Read [F:ACT]ACTION=LACTION
 ACTTRTSPE=""
 If !fstat
  ACTFLGSPE=1
  Local Integer EXISTE_ADX
  Call EXISTE_ADX("","",[F:ACT]SPETRT,EXISTE_ADX) From ORDSYS
  If [F:ACT]SPETRT="" | !EXISTE_ADX
   ACTFLGSPE=0
  Else
   Onerrgo $SPE_SANS_ACTMET
   Gosub ACTMET From = [F:ACT]SPETRT
   Onerrgo
   If ACTFLGSPE=1
    ACTTRTSPE=[F:ACT]SPETRT
   Endif
  Endif
 Else
  ACTFLGSPE=0
 Endif

#If GUSER="GBO" & 1=1 : Infbox "TRT spe"-mess(ACTFLGSPE+1,1,1)-":"-ACTTRTSPE : Endif

 PRECHARGE=G_NON   : ACTMET="SET_PRECHARGE" : Gosub ACTMET From TRCPROCOM
                     ACTMET="SET_CRITACT"   : Gosub ACTMET From TRCPROCOM
 CALC_MOTEUR=G_NON : ACTMET="SET_CALCPARM"  : Gosub ACTMET From TRCPROCOM

Return

#========================================================================
$ACTMET
 GPE = 0
 If dim(ACTFLGSPE)>0 & ACTFLGSPE>0
  Gosub ACTMET From =ACTTRTSPE
 Endif
 If !GPE & dim(ACTTRTACT)>0 & ACTTRTACT<>""
  Gosub ACTMET From =ACTTRTACT
 Endif
 GPE=0
Return

#========================================================================
$SPE_SANS_ACTMET
 ACTFLGSPE=0
 Resume
Return

#========================================================================
$KILL_ELEM_REG_TVA
 If dim(G_ECIMPBAS)>0 : Kill G_ECIMPBAS : Endif
 If dim(G_ECVARPRO)>0 : Kill G_ECVARPRO : Endif
 If dim(G_TENCOURS)>0 : Kill G_TENCOURS : Endif
 If dim(G_REGULIAS)>0 : Kill G_REGULIAS : Endif
 If dim(G_IMPBASVT)>0 : Kill G_IMPBASVT :  Endif
Return

#########################################################################
# Sous-programmes :
# ---------------
#
# LOCKER           # S/p de lock des enregistrements de la population
# CHARGER          # S/p de remplissage des tables temporaires de travail
# APPLIQUE_TEMP &  # S/p d'application de modifications aux tables temporaires ou aux tables de donnÃĐes
# APPLIQUE_DIRT    #
# VIDER            # S/p de vidage de la table temporaire des ÃĐlÃĐments du traitement en cours
# VISUALISER       # S/p d'appel de l'objet de contrÃīle des modifications
# UNLOCKER         # S/p pour libÃĐrer la population traitÃĐe de ces locks.
# REPORTER         # S/p de report du contenu des tables temporaires dans les tables de donnÃĐes
#
#########################################################################

#========================================================================
#
Subprog LOCKER(PCRIT1,PCRIT2,PCRIT3,PCRIT4,PTABLE,RMES,RERR)
#
# Sous-programme permettant de locker un ensemble d'enregistrements dans la table
# PTABLE sÃĐlectionnÃĐs Ã  partie des quatre critÃĻres de sÃĐlection. Les codes erreurs
# retournÃĐs sont les suivants :
#
# 0    Pas d'erreur
# 1    ParamÃĻtre PTABLE incorrect (vide)
# 5    Population vide
# 10   Enregistrement de MAS1 en cours d'utilisation
# 21   Enregistrement d'un lock propre Ã  l'action en cours d'utilisation
# 31   La table TMPMASLCK est lockÃĐe
# 33   Tentative de crÃĐation de clÃĐ en double sur la table TMPMASLCK
#
# ------------------------------------------------------------------------------

Value    Char    PCRIT1      # CritÃĻre 1 -> CritÃĻre tous objets
Value    Char    PCRIT2      # CritÃĻre 2 -> CritÃĻre pour toutes les actions d'un objet
Value    Char    PCRIT3      # CritÃĻre 3 -> CritÃĻre propre Ã  l'action
Value    Char    PCRIT4      # CritÃĻre 4 -> CritÃĻre supplÃĐmentaire (SpÃĐcifique massif)
Value    Char    PTABLE      # table sur laquelle la population est lockÃĐe
Variable Char    RMES        # Message d'erreur retournÃĐ
Variable Integer RERR        # Code retour du sous-programme

#=> DÃĐbranchement vers traitement ERREUR_SP  # Erreur sous-programme

 Onerrgo ERREUR_SP From TRCPROCOM

#=>

 Local Integer WRACTIF  : WRACTIF=G_OUI
 Local Char    L_FCYSAV : Raz L_FCYSAV #Gbn-280405-Bug nÂ°29958 # Sauvegarde du site
 Local Integer L_FCYAUT : Raz L_FCYAUT #Gbn-280405-Bug nÂ°29958 # Site autorisÃĐ ?
 Local Integer I, J
 Local Char    NOMZON
 Local Integer LOCK_CPY : LOCK_CPY = 0       : # Permet de demander par positionnement dans OUVR_LOCK un lock sociÃĐtÃĐ FQ89043
                                               # 0 : lock par objet
                                               # 1 : lock sociÃĐtÃĐ
 Local Char    CPY_LOCKED(GLONCPY)(GDIMSOC)  : # SociÃĐtÃĐs vÃĐrouillÃĐes FQ89043
#=> Initialisation variables

 Raz RMES, RERR
 Raz NBOBJ, NBOBJLCK, NBOBJNLCK

#=> ContrÃīle des paramÃĻtres
 # FQ83184  "ParamÃĻtre PTABLE incorrect."
 If PTABLE="" : RERR=1 : RMES=mess(103,GML_MSGTRC,1) : GOK=0 : End : Endif

#=> Ouverture table PTABLE
 If !clalev([F:MAS1]) : Local File =nomap+'.'+PTABLE      [MAS1] : Endif # Ouverture de la table Ã  traiter
 If !clalev([F:TML])  : Local File =nomap+'.'+"TMPMASLCK" [TML]  : Endif # Ouverture de la table des locks
 If !clalev([F:XTRA]) : Local File TRCABX3 [XTRA]                : Endif
 If !clalev([F:ALK])  : Local File APLLCK  [ALK]                 : Endif

#=> Ouverture de tables annexes

 ACTMET="OUVR_LOCK" : Gosub ACTMET From TRCPROCOM            # Ouverture de tables annexes

 If ACTTYPGES=GTAMUNI : LOCK_CPY = 0 : Endif : # Lock sociÃĐtÃĐ en massif uniquement FQ89043

#=> Scan des critÃĻres pour qu'ils ne plantent pas le filter
If PCRIT1=""   : PCRIT1="1=1" : Endif
If PCRIT2=""   : PCRIT2="1=1" : Endif
If PCRIT3=""   : PCRIT3="1=1" : Endif
If PCRIT4="" :   PCRIT4="1=1" : Endif

Raz TOTOBJAMT

#=> Pose Filtre sur [MAS1]
Filter [MAS1] Where (evalue(PCRIT1) & evalue(PCRIT2) & evalue(PCRIT3) & evalue(PCRIT4))

#=> Boucle sur [MAS1]

 For [MAS1]
   OK=1
   ######################################
   If ACTTYPGES <> GTAMUNI
     If dim(GNB_CRITFCY) > 0
       I =  find([F:MAS1]FCY, LIST_FCY_1)
       If I=0  and  dim(LIST_FCY_2) > 0     :  I= find([F:MAS1]FCY,LIST_FCY_2)  : Endif
       If I=0  and  dim(LIST_FCY_3) > 0     :  I= find([F:MAS1]FCY,LIST_FCY_3)  : Endif
       If I=0  and  dim(LIST_FCY_4) > 0     :  I= find([F:MAS1]FCY,LIST_FCY_4)  : Endif
       If I=0  and  dim(LIST_FCY_X) > 0     :  I= find([F:MAS1]FCY,LIST_FCY_X)  : Endif
       If I = 0 : OK=0 :            Endif
     #Else
     #   I= find([F:MAS1]FCY, LIST_FCY)
     #   If I = 0 : OK=0 :        Endif
     Endif
   Endif
   If OK<>0
     ###########################################
     # FQ89043 : si le lock sociÃĐtÃĐ est demandÃĐ et qu'on n'a pas dÃĐjÃ  verrouillÃĐ la sociÃĐtÃĐ on fait le verouillage
     If LOCK_CPY and !find([F:MAS1]CPY,CPY_LOCKED)
       If func GLOBIENS.LOCK_SYMBOLE (ACTREFOBJ, [F:MAS1]CPY, "", 0) = 1 Then
        CPY_LOCKED(find("",CPY_LOCKED)-1) = [F:MAS1]CPY
       Else
        GOK=-1
        NBOBJNLCK+=1
       Endif
     Endif

     ###########################################
     # - On ne traite pas les biens en cours de cession intra-groupe.
     #   Fq-53346 sauf si l'on est en sortie en mode silencieux
     If ACTREFOBJ = "FAS"    and   (ACTSILENCE=G_NON or TRTFILMSK <> "SUBCII" )
        Call TEST_BIEN_ACTIF  ([F:MAS1]AASREF, WRACTIF)  From GLOBIENS
        If WRACTIF=G_OUI
           GOK=1
        Else
           GOK=0
        Endif
     Endif

     #- si G_NOCHOI_SELALL est Ã  Oui, on teste ici les habilitations sur site. (massif uniquement)
     If dim(G_NOCHOI_SELALL)>0
       If G_NOCHOI_SELALL=G_OUI
         If L_FCYSAV<>[F:MAS1]FCY
           L_FCYAUT=G_NON
           Call CONTFCY([F:MAS1]FCY) From SUPCPT
           If mkstat
             L_FCYAUT=G_NON
           Else
             L_FCYAUT=G_OUI
           Endif
           L_FCYSAV=[F:MAS1]FCY
         Endif
         If L_FCYAUT=G_NON
            GOK=0
         Endif
       Endif
     Endif

  #=> on donne la possibilitÃĐ de rejeter un enregistrement de MAS1 en positionnant GOK Ã  0
   If GOK=1 : Raz GERR, GMESSAGE : ACTMET="MAS1_CONTROLE" : Gosub ACTMET From TRCPROCOM  : Endif #Gbn-280405-Bug nÂ°29958

   #Gbn-RAF
   #=> Si GOK=0, on donne la possibilitÃĐ de prÃĐciser la cause du rejet : positionner GERR Ã  G_OUI et GMESSAGE
   If GERR=G_OUI
     Call MESSAGE(GMESSAGE) From GESECRAN
   Endif
   Raz GERR, GMESSAGE

   #=> Si l'enregistrement n'est pas rejetÃĐ, on le lock
   If GOK = 1
    Case ACTREFOBJ
     When "LOF" : LKEY = func GLOBIENS.GET_KEY_LAYOUTFAS ([F:MAS1]CODLOF, [F:MAS1]LINLOF)
     When "FAS" : LKEY = func GLOBIENS.GET_KEY_FXDASSETS ([F:MAS1]AASREF)
     When "LEA" : LKEY = func GLOBIENS.GET_KEY_LEASE ([F:MAS1]LEAREF)
     When "PHY" : LKEY = func GLOBIENS.GET_KEY_PHYELT ([F:MAS1]PHYREF)
     When Default
    Endcase
    If !(LKEY="")
     #> On cherche d'abord si le symbole a ÃĐtÃĐ dÃĐjÃ  lockÃĐ par la session courante (appel en mode silencieux)
     Local Integer DEJA_LOCKE : DEJA_LOCKE=G_NON
     If ACTSILENCE=G_OUI : DEJA_LOCKE=func GLOBIENS.IS_SYMBOLE_ALREADY_LOCKED (ACTREFOBJ, [F:MAS1]CPY, LKEY) : Endif
     #> Aucun lock n'a ÃĐtÃĐ posÃĐ sur le symbole ou pas en mode silencieux
     If DEJA_LOCKE=G_NON
      If !LOCK_CPY : # Lock par objet si le verrouillage sociÃĐtÃĐ n'est pas demandÃĐ FQ89043
       If func GLOBIENS.LOCK_SYMBOLE (ACTREFOBJ, [F:MAS1]CPY, LKEY, 0) = 1
        GOK=1
       Else
        GOK=-1
        NBOBJNLCK+=1
       Endif
      Endif
     Endif
    Endif

   #=> Si le lock s'est bien passÃĐ, on donne la possibilitÃĐ de locker d'autres objets liÃĐs
    If GOK=1
     ACTMET="MAS1_LOCK_AUTRE" : Gosub ACTMET From TRCPROCOM   # Permet de locker d'autres objets
    #=> Si les locks spÃĐcifiques ne se sont pas bien dÃĐroulÃĐs, on unlock l'enregistrement de MAS1 # RAF - Il suffit de sortir
     If GOK<1
      Case ACTREFOBJ
       When "LOF" : LKEY = func GLOBIENS.GET_KEY_LAYOUTFAS ([F:MAS1]CODLOF, [F:MAS1]LINLOF)
       When "FAS" : LKEY = func GLOBIENS.GET_KEY_FXDASSETS ([F:MAS1]AASREF)
       When "LEA" : LKEY = func GLOBIENS.GET_KEY_LEASE ([F:MAS1]LEAREF)
       When "PHY" : LKEY = func GLOBIENS.GET_KEY_PHYELT ([F:MAS1]PHYREF)
      Endcase
      If !(LKEY="") : Call UNLOCK_SYMBOLE(ACTREFOBJ,[F:MAS1]CPY,LKEY) From GLOBIENS : Endif
      # FQ83184 RMES+="Objet :"-[F:MAS1]AASREF-[F:MAS1]AASDES1-"Echec de lock sur un objet liÃĐ"
      RMES+=func GLOFUNC.SUBSTIT2(mess(918,GML_MSGFAS,1), [F:MAS1]AASREF, [F:MAS1]AASDES1)
      RERR=21
      Break
     Else
    #=> Si les locks spÃĐcifiques sont OK, on ÃĐcrit dans la table des locks TML
      Raz [TML]
      [F:TML]TRTNUM=NUMACT
      [F:TML]OBJMAIN = G_NON
      [F:TML]OBJCPY  = [F:MAS1]CPY
      Case ACTREFOBJ
       When "LOF"
        [F:TML]OBJTYP=GVML_OMDEPEN
        [F:TML]OBJREF=[F:MAS1]CODLOF
        [F:TML]OBJLIN=[F:MAS1]LINLOF
        LKEY = func GLOBIENS.GET_KEY_LAYOUTFAS ([F:MAS1]CODLOF, [F:MAS1]LINLOF)
        If ACTTYPGES=GTAMUNI
         If (([F:TML]OBJREF=[M:OAC0]OBJREF) & ([F:TML]OBJLIN=[M:OAC0]OBJLIN)) : [F:TML]OBJMAIN = G_OUI : Endif
        Endif
       When "FAS"
        [F:TML]OBJTYP=GVML_OMBIEN
        [F:TML]OBJREF=[F:MAS1]AASREF
        Raz [F:TML]OBJLIN
        LKEY = func GLOBIENS.GET_KEY_FXDASSETS ([F:MAS1]AASREF)
        If ACTTYPGES=GTAMUNI
         If ([F:TML]OBJREF=[M:OAC0]OBJREF)                                    : [F:TML]OBJMAIN = G_OUI : Endif
        Endif
       When "LEA"
        [F:TML]OBJTYP=GVML_OMLOCFI
        [F:TML]OBJREF=[F:MAS1]LEAREF
        Raz [F:TML]OBJLIN
        LKEY = func GLOBIENS.GET_KEY_LEASE ([F:MAS1]LEAREF)
        If ACTTYPGES=GTAMUNI
         If ([F:TML]OBJREF=[M:OAC0]OBJREF)                                    : [F:TML]OBJMAIN = G_OUI : Endif
        Endif
       When "PHY"
        [F:TML]OBJTYP=GVMLOMPHY
        [F:TML]OBJREF=[F:MAS1]PHYREF
        Raz [F:TML]OBJLIN
        LKEY = func GLOBIENS.GET_KEY_PHYELT ([F:MAS1]PHYREF)
        If ACTTYPGES=GTAMUNI
         If ([F:TML]OBJREF=[M:OAC0]OBJREF)                                    : [F:TML]OBJMAIN = G_OUI : Endif
        Endif
       When Default
      Endcase
      [F:TML]OBJSYM  = LKEY
      ACTMET="MAS1_LOCK_MONTANT" : Gosub ACTMET From TRCPROCOM   # Permet d'alimenter les zones numÃĐriques de totalisation
      If [F:TML]OBJAMT(0)<>0 : TOTOBJAMT(0)+=[F:TML]OBJAMT(0) : Endif
      If [F:TML]OBJAMT(1)<>0 : TOTOBJAMT(1)+=[F:TML]OBJAMT(1) : Endif
      If [F:TML]OBJAMT(2)<>0 : TOTOBJAMT(2)+=[F:TML]OBJAMT(2) : Endif
      If [F:TML]OBJAMT(3)<>0 : TOTOBJAMT(3)+=[F:TML]OBJAMT(3) : Endif
      If [F:TML]OBJAMT(4)<>0 : TOTOBJAMT(4)+=[F:TML]OBJAMT(4) : Endif
      Write [TML]
      If fstat
       RERR=30+fstat
       Case fstat
        When 1
         # FQ83184 "La table TMPMASLCK est lockÃĐe."
         RMES=mess(93,GML_MSGTRC,1)
        When 3
         # FQ83184 "Tentative d'ÃĐcriture en double de la clÃĐ"
         RMES=mess(94,GML_MSGTRC,1)-num$([F:TML]TRTNUM)+"/"+[F:TML]OBJREF
         If ACTREFOBJ="LOF" : RMES+="/"+num$([F:TML]OBJLIN) : Endif
         # FQ83184 "/dans la table TMPMASLCK."
         RMES-=mess(95,GML_MSGTRC,1)
       Endcase
      Endif
      NBOBJLCK+=1
     Endif
    Else
     GOK  = -1
     # FQ83184 "Enregistrement en cours d'utilisation :"
     RMES = mess(96,GML_MSGTRC,1)-[F:TML]OBJREF+"."
     RERR = 10
     Break
    Endif
   Else
    GOK=1
    If ACTSILENCE=G_OUI
        G_MAJOK=G_NON

        # CBO 20120208 FQ79973 : prise en compte des diffÃĐrents objets
#        GT_OBJ_REF(I_OBJ)=[F:MAS1]AASREF
#        GT_OBJ_DES(I_OBJ)=[F:MAS1]AASDES1
        If dim(I_OBJ) < 0
            Local Integer I_OBJ
        Endif
        Case ACTREFOBJ
        When "LOF"
            GT_OBJ_REF(I_OBJ)=[F:MAS1]CODLOF
            GT_OBJ_DES(I_OBJ)=[F:MAS1]DES
        When "FAS"
            GT_OBJ_REF(I_OBJ)=[F:MAS1]AASREF
            GT_OBJ_DES(I_OBJ)=[F:MAS1]AASDES1
         When "LEA"
            GT_OBJ_REF(I_OBJ)=[F:MAS1]LEAREF
            GT_OBJ_DES(I_OBJ)=[F:MAS1]LEADES
         When "PHY"
            GT_OBJ_REF(I_OBJ)=[F:MAS1]PHYREF
            GT_OBJ_DES(I_OBJ)=[F:MAS1]PHYDES1
         When Default
    Endcase
        I_OBJ+=1
    Endif
   Endif
  Endif
 Next

#=> Suppression du filtre

 Filter [MAS1]

#=> Envoi d'un message si la population est vide

 If !NBOBJLCK & RERR=0
  GOK=0
  RERR = 5
  RMES = mess(102,GML_MSGTRC,1) : # FQ83184 "Aucun"
  Case ACTREFOBJ
   When "LOF" : RMES+=mess(97,GML_MSGTRC,1)  : # FQ83184 "dÃĐpense sÃĐlectionnÃĐe."
   When "FAS" : RMES-=mess(98,GML_MSGTRC,1)  : # FQ83184 "bien comptable sÃĐlectionnÃĐ."
   When "LEA" : RMES-=mess(99,GML_MSGTRC,1)  : # FQ83184 "contrat de location financement"
   When "PHY" : RMES-=mess(100,GML_MSGTRC,1) : # FQ83184 "ÃĐlÃĐment physique sÃĐlectionnÃĐ.
   When Default
  Endcase
  RMES-=mess(101,GML_MSGTRC,1) : # FQ83184 "/la population est vide."
  # DÃĐverrouillage des sociÃĐtÃĐs en lock sociÃĐtÃĐ FQ89043
  If LOCK_CPY
    I = 0
    While CPY_LOCKED(I)<>""
     Call UNLOCK_SYMBOLE (ACTREFOBJ, CPY_LOCKED(I), "") From GLOBIENS
     I += 1
    Wend
  Endif
 Endif

#=> Fermeture des tables

 Close Local File [MAS1], [TML]

#=> Fermeture de tables annexes

 ACTMET="CLOS_LOCK" : Gosub ACTMET From TRCPROCOM

 If GERR = G_OUI
   RERR = 50 : # pour provoquer le dÃĐlockage de la population
   RMES = GMESSAGE : GMESSAGE = ""
 Endif

#=> Affichage des totaux
 If GUSER=USRDBG
  Infbox "Total OBJAMT0"-num$(TOTOBJAMT(0))
  Infbox "Total OBJAMT1"-num$(TOTOBJAMT(1))
  Infbox "Total OBJAMT2"-num$(TOTOBJAMT(2))
  Infbox "Total OBJAMT2"-num$(TOTOBJAMT(3))
  Infbox "Total OBJAMT2"-num$(TOTOBJAMT(4))

 Endif

 Onerrgo

End

#========================================================================
#
Subprog CHARGER(PCRIT1,PCRIT2,PCRIT3,PCRIT4,PTABLE,RMES,RERR)
#
# Sous-programme permettant de crÃĐer dans les tables temporaires les enregistrements
# Ã  partir desquels l'action est exÃĐcutÃĐe
# les codes erreurs retournÃĐs sont les suivants :
# 0    Pas d'erreur
#
# ------------------------------------------------------------------------------
Value    Char    PCRIT1      # CritÃĻre 1 -> CritÃĻre tous objets
Value    Char    PCRIT2      # CritÃĻre 2 -> CritÃĻre pour toutes les actions d'un objet
Value    Char    PCRIT3      # CritÃĻre 3 -> CritÃĻre propre Ã  l'action
Value    Char    PCRIT4      # CritÃĻre 4 -> CritÃĻre supplÃĐmentaire (SpÃĐcifique massif)
Value    Char    PTABLE      # Table sur laquelle la population est lockÃĐe
Variable Char    RMES        # Message d'erreur retournÃĐ
Variable Integer RERR        # Code retour du sous-programme

 Raz RMES, RERR

 Local Integer PROG_BARRE : Raz PROG_BARRE
 Local Integer OK #Gbn-270405-Bug nÂ°XXXXX
 Local Integer I
#=> ContrÃīle des paramÃĻtres
 # FQ83184 "ParamÃĻtre PTABLE incorrect."
 If PTABLE="" : RERR=1 : RMES=mess(103,GML_MSGTRC,1) : GOK=0 : End : Endif

#=> DÃĐbranchement vers traitement ERREUR_SP  # Erreur sous-programme

 Onerrgo ERREUR_SP From TRCPROCOM

#=> Ouverture tables
 If !clalev([F:MAS1]) : Local File =nomap+'.'+PTABLE      [MAS1] : Endif # Ouverture de la table Ã  lire
 If !clalev([F:TMP1]) : Local File =nomap+'.'+TMPTAB      [TMP1] : Endif # Ouverture de la table temporaire
 If TMPTAB2<>""
  If !clalev([F:TMPC]) : Local File =nomap+'.'+TMPTAB2    [TMPC] : Endif # Ouverture de la table temporaire
 Endif
 If !clalev([F:TML])  : Local File =nomap+'.'+'TMPMASLCK' [TML]  : Endif # Ouverture de la table des locks # A supprimer
 If ACTGESPLN=G_OUI
  If !clalev([F:TPF1]) : Local File =nomap+'.'+TMPTABPLN [TPF1] : Endif  # Ouverture de la table temporaire par plan
 Endif
 If !clalev([F:XTRA]) : Local File TRCABX3 [XTRA]                : Endif

#=> Ouverture de tables annexes

 ACTMET="OUVR_ALIM_TMP1" : Gosub ACTMET From TRCPROCOM                         # Ouverture de tables annexes

#=> Scan et ÃĐventuellement modification des critÃĻres pour qu'ils ne plantent pas le filter

If PCRIT1="" : PCRIT1="1=1" : Endif
If PCRIT2="" : PCRIT2="1=1" : Endif
If PCRIT3="" : PCRIT3="1=1" : Endif
If PCRIT4="" : PCRIT4="1=1" : Endif

#=> Pose Filtre sur [MAS1]

Filter [MAS1] Where (evalue(PCRIT1) & evalue(PCRIT2) & evalue(PCRIT3) & evalue(PCRIT4))

#=> DÃĐbut transaction de mise Ã  jour

 If GUSER=USRDBG : Infbox "S/P CHARGER - GTRANS"-num$(GTRANS) : Endif

 If !GTRANS
#If !adxlog
  Call DEBTRANS From GLOCK
  If ACTGESPLN=G_OUI
   Trbegin [TMP1], [TPF1]
  Elsif ACTGESPLN=G_NON
   Trbegin [TMP1]
  Endif
 Endif

 #=> dÃĐbut de la boucle d'alimentation des tables temporaires


#=> Boucle sur [MAS1]

 For [MAS1]
   ######################################
   OK=1
   If ACTTYPGES <> GTAMUNI
     If dim(GNB_CRITFCY) > 0
       I =  find([F:MAS1]FCY, LIST_FCY_1)
       If I=0  and  dim(LIST_FCY_2) > 0     :  I= find([F:MAS1]FCY,LIST_FCY_2)  : Endif
       If I=0  and  dim(LIST_FCY_3) > 0     :  I= find([F:MAS1]FCY,LIST_FCY_3)  : Endif
       If I=0  and  dim(LIST_FCY_4) > 0     :  I= find([F:MAS1]FCY,LIST_FCY_4)  : Endif
       If I=0  and  dim(LIST_FCY_X) > 0     :  I= find([F:MAS1]FCY,LIST_FCY_X)  : Endif
       If I = 0 : OK=0 :            Endif
     Endif
   Endif
   ###########################################

  If OK<> 0
  Case ACTREFOBJ
   When "LOF"
    Read [TML]TML1=NUMACT;[F:MAS1]CODLOF;[F:MAS1]LINLOF    # Cherche si l'objet en cours a bien ÃĐtÃĐ lockÃĐ (Non rejetÃĐ par exemple par MAS1_CONTROLE)
    If fstat                                               # Si on ne le trouve pas, pas d'erreur, on se contente de ne pas le traiter
     LOCKOK=0
    Else
     LOCKOK=1
    Endif
   When "FAS"
    Read [TML]TML0=NUMACT;[F:MAS1]AASREF                    # Cherche si l'objet en cours a bien ÃĐtÃĐ lockÃĐ (Non rejetÃĐ par exemple par MAS1_CONTROLE)
    If fstat                                                # Si on ne le trouve pas, pas d'erreur, on se contente de ne pas le traiter
     LOCKOK=0
    Else
     LOCKOK=1
    Endif
   When "LEA"
   When "PHY"
    Read [TML]TML0=NUMACT;[F:MAS1]PHYREF                    # Cherche si l'objet en cours a bien ÃĐtÃĐ lockÃĐ (Non rejetÃĐ par exemple par MAS1_CONTROLE)
    If fstat                                                # Si on ne le trouve pas, pas d'erreur, on se contente de ne pas le traiter
     LOCKOK=0
    Else
     LOCKOK=1
    Endif
   When Default
  Endcase
  If LOCKOK
   NBOBJ+=1
   ACTMET="MAS1_ALIM_TMP1" : Gosub ACTMET From TRCPROCOM    # alimentation tables temporaires
   If GOK<1
    RERR=90
    # FQ83184 "Une erreur s'est produite dans l'ÃĐtiquette"-ACTMET-"du programme"-ACTTRTACT
    If RMES="" : RMES=func GLOFUNC.SUBSTIT2(mess(917,GML_MSGFAS,1), ACTMET, ACTTRTACT ) : Endif
    Break
   Endif
   If !GSERVEUR & ACTTYPGES=GTAMMAS & ACTSILENCE<>G_OUI
    # FQ83184 "Chargement de la population"
    Call AFF_BOITE(mess(104,GML_MSGTRC,1),NBOBJ,OK) From GESECRAN
   Endif #Gbn-270405-Bug nÂ°XXXXX
  Endif
  Endif
 Next

#=> Traitement Ã  fin de chargement de table temporaire

 ACTMET="END_ALIM_TMP1" : Gosub ACTMET From TRCPROCOM

#=> Mise Ã  jour des tables
 If GOK
  If !GTRANS : Commit : Endif
 #If !adxlog : Commit : Endif
 Else
  If !GTRANS : Rollback : Endif
 #If !adxlog : Rollback : Endif
 Endif

#=> suppression filtre sur [MAS1]

 Filter [MAS1]

#=> Fermeture des tables

 Close Local File [MAS1], [TMP1], [TML]
 If TMPTAB2<>"" : Close Local File [TMPC] : Endif
 If ACTGESPLN=G_OUI : Close Local File [TPF1] : Endif

#=> Fermeture de tables annexes

 ACTMET="CLOS_ALIM_TMP1" : Gosub ACTMET From TRCPROCOM

Onerrgo

End

#========================================================================
#
#
Subprog APPLIQUE_TEMP(PNUMACT,PTABLE,PTABSUP,RMES,RERR)
#
#
# Sous-programme permettant de mettre Ã  jour les enregistrements des tables
# temporaires avec les paramÃĻtres de l'action mÃĐtier
# les codes erreurs retournÃĐs sont les suivants :
# 0    Pas d'erreur
# ------------------------------------------------------------------------------
Value    Integer PNUMACT     # NumÃĐro de l'action en cours (permet la sÃĐlection des enregistrements Ã  modifier)
Value    Char    PTABLE      # Nom de la table temporaire principale Ã  ouvrir
Value    Char    PTABSUP     # Nom de la table temporaire annexe Ã  ouvrir (par plan)
Variable Char    RMES        # Message d'erreur ou d'information renvoyÃĐ par le s/p
Variable Integer RERR        # Code erreur renvoyÃĐ par le s/p

 Raz RMES, RERR

 Local Integer OK_UNI
 Local Integer ECR_MESS_ERR        : Raz ECR_MESS_ERR
 Local Char    MESSAGE_ERREUR(255) : Raz MESSAGE_ERREUR

 Local Integer NBTRT               : Raz NBTRT #Gbn-270405-Bug nÂ°XXXXX
 Local Integer OK                  :           #Gbn-270405-Bug nÂ°XXXXX

 Local Integer NOTMPCENR           : # Pas d'enregistrement TMPC Ã  mettre Ã  jour

 If GTRACE<>"" & ACTTYPGES=GTAMUNI
  OK_UNI=1
 Else
  OK_UNI=0
 Endif

#=> ContrÃīle des paramÃĻtres
# FQ83184 "ParamÃĻtre PTABLE incorrect."
 If PTABLE="" : RERR=1 : RMES=mess(103,GML_MSGTRC,1) : GOK=0 : End : Endif

#=> DÃĐbranchement vers traitement ERREUR_SP  # Erreur sous-programme

 Onerrgo ERREUR_SP From TRCPROCOM

#=> Ouverture des tables
 If !clalev([F:TMP1]) : Local File =nomap+'.'+PTABLE   [TMP1] : Endif       #=> Ouverture tables temporaire principale
 If TMPTAB2<>""
  If !clalev([F:TMPC]) : Local File =nomap+'.'+TMPTAB2 [TMPC] : Endif       #=> Ouverture tables temporaire complÃĐmentaire
 Endif
 If PTABSUP<>""
  If !clalev([F:TPF1]) : Local File =nomap+'.'+PTABSUP [TPF1] : Endif       #=> Ouverture tables temporaire annexe
 Endif
 If !clalev([F:XTRA])  : Local File TRCABX3 [XTRA]            : Endif

#=> Pose du filtre sur la table maÃŪtre

 Filter [TMP1] Where (TRTNUM=NUMACT)                                        #=> Pose filtre sur [TMP1]

#=> Ouverture transaction

 #If GUSER=USRDBG : Infbox "S/P APPLIQUE_TEMP - adxlog"-num$(adxlog) : Dbgaff : Endif

 If !GTRANS
#If !adxlog
  Call DEBTRANS From GLOCK
  If PTABSUP<>""
   Trbegin [TMP1], [TPF1]                                                    #=> DÃĐbut transaction de mise Ã  jour
  Else
   Trbegin [TMP1]
  Endif
 Endif

#=> Ouverture table annexes

 ACTMET="OUVR_APPL_TMP1" : Gosub ACTMET From TRCPROCOM

#=> Boucle sur la table maÃŪtre

 For [TMP1]

  If TMPTAB2<>""
   Read [F:TMPC]MF10=[F:TMP1]TRTNUM;[F:TMP1]OBJREF
   If fstat
    NOTMPCENR=1
   Else
    NOTMPCENR=0
   Endif
  Endif
                                                           #=> Boucle sur [TMP1]
  If PTABSUP<>""
   Filter [TPF1] Where TRTNUM=[F:TMP1]TRTNUM & OBJREF=[F:TMP1]OBJREF
   [F:TMP1]MSGERR=""    # 01/10/04 - demande mwa rÃĐinitialiser MSGERR avant le traitement des plans
   [F:TMP1]FLGERR=G_NON # 01/04/04 - demande mwa pour gestion FLGERR entre TPF1 et TMP1
   For [TPF1]                                                               #=> Boucle sur [TPF1] si nÃĐcessaire
    GOK=1
    ACTMET="TPF1_APPL_TPF1" : Gosub ACTMET From TRCPROCOM
    If OK_UNI : Gosub GERE_MESSAGE_UNITAIRE : Endif
    Rewrite [TPF1]
    If fstat
     RERR=20+fstat
     Case fstat
      When 1
       GOK=-1
       # FQ83184 "L'enregistrement"-[F:TPF1]TRTNUM+"/"+[F:TPF1]OBJREF-"est verrouillÃĐ."
       RMES=func GLOFUNC.SUBSTIT2(mess(904,GML_MSGFAS,1), num$([F:TPF1]TRTNUM),[F:TPF1]OBJREF)   # RAF Voir comment rÃĐcupÃĐrer la composition de la clÃĐ pour l'ÃĐmettre dans le message
      When 3
       GOK=0
       # FQ83184 "Tentative d'ÃĐcriture en double de la clÃĐ"-[F:TPF1]TRTNUM+"/"+[F:TPF1]OBJREF-"sur la table"-PTABSUP
       RMES=func GLOFUNC.SUBSTIT3(mess(905,GML_MSGFAS,1), num$([F:TPF1]TRTNUM),[F:TPF1]OBJREF,PTABSUP) # RAF id ci-dessus
      When 5
       GOK=0
       # FQ83184 "Enregistrement"-[F:TPF1]TRTNUM+"/"+[F:TPF1]OBJREF-"inexistant."
       RMES=func GLOFUNC.SUBSTIT2(mess(906,GML_MSGFAS,1), num$([F:TPF1]TRTNUM),[F:TPF1]OBJREF)  # RAF id ci-dessus
     Endcase
     Break 2
    Endif
   Next
   Filter [TPF1]                                                            #=> Suppression du filtre sur [TPF1]
  Endif

  If GOK=1
   ACTMET="TMP1_APPL_TMP1"
   Gosub ACTMET From TRCPROCOM


   If OK_UNI
     Gosub GERE_MESSAGE_UNITAIRE
   Endif

   Rewrite [TMP1]
   If TMPTAB2<>"" & !NOTMPCENR
    Rewrite [TMPC]
   Endif
   If fstat
    RERR=10+fstat
    Case fstat
     When 1
      GOK=-1
       # FQ83184 "L'enregistrement"-[F:TPF1]TRTNUM+"/"+[F:TPF1]OBJREF-"est verrouillÃĐ."
      RMES= mess(105,GML_MSGTRC,1)-num$([F:TMP1]TRTNUM)+"/"+[F:TMP1]OBJREF
      If ACTREFOBJ="LOF"
       RMES+="/"+[F:TMP1]OBJLIN
      Endif
      RMES-= mess(106,GML_MSGTRC,1)   # RAF Voir comment rÃĐcupÃĐrer la composition de la clÃĐ pour l'ÃĐmettre dans le message
     When 3
      GOK=0
       # FQ83184 "Tentative d'ÃĐcriture en double de la clÃĐ"-[F:TMP1]TRTNUM+"/"+[F:TMP1]OBJREF-"sur la table"-PTABLE
      RMES=mess(107,GML_MSGTRC,1) -num$([F:TMP1]TRTNUM)+"/"+[F:TMP1]OBJREF
      If ACTREFOBJ="LOF"
       RMES+="/"+[F:TMP1]OBJLIN
      Endif
      RMES-=mess(108,GML_MSGTRC,1) -PTABLE
     When 5
      GOK=0
       # FQ83184 "Enregistrement"-[F:TPF1]TRTNUM+"/"+[F:TPF1]OBJREF-"inexistant."
      RMES=mess(109,GML_MSGTRC,1)-num$([TMP1]TRTNUM)+"/"+[F:TPF1]OBJREF
      If ACTREFOBJ="LOF"
       RMES+="/"+[F:TMP1]OBJLIN
      Endif
      RMES-=mess(110,GML_MSGTRC,1)
    Endcase
    Break
   Endif

   #Gbn-270405-Bug nÂ°XXXXX
   If !GSERVEUR & ACTTYPGES=GTAMMAS & ACTSILENCE<>G_OUI
    NBTRT+=1
    # FQ83184 "Application des paramÃĻtres"
    Call AFF_BOITE(mess(111,GML_MSGTRC,1),NBTRT,OK) From GESECRAN
   Endif

  Endif

 Next

#=> Traitement de fin de MAJ des tables temporaires :

 ACTMET="END_APPL_TMP1" : Gosub ACTMET From TRCPROCOM

#=> Fin de la transaction de mise Ã  jour

 If GOK
   If !GTRANS : Commit : Endif
  #If !adxlog : Commit : Endif
 Else
   If !GTRANS : Rollback : Endif
  #If !adxlog : Rollback : Endif
 Endif

#=> Suppression du filtre

 Filter [TMP1]                                                              #=> Suppression filtre sur [TMP1]

#=> Emmission du message d'erreur dans une boÃŪte s'il n'y en a qu'un

 If OK_UNI & MESSAGE_ERREUR<>"" & !ECR_MESS_ERR
  Call ERREUR (MESSAGE_ERREUR) From GESECRAN
 Endif

#=> Fermeture des tables ouvertes

 Close Local File [TMP1]
 If TMPTAB2<>"" : Close Local File [TMPC] : Endif
 If PTABSUP<>"" : Close Local File [TPF1] : Endif

#=> Traitement de fin de sous-programme de mise Ã  jour des tables temporaires :

 ACTMET="CLOS_APPL_TMP1" : Gosub ACTMET From TRCPROCOM

Onerrgo

End

$GERE_MESSAGE_UNITAIRE
 If RMES<>""
  If MESSAGE_ERREUR=""
   MESSAGE_ERREUR=RMES
  Else
   If !ECR_MESS_ERR
    Call ECR_TRACE("",0,MESSAGE_ERREUR,1,1) From TRACEABX3
    ECR_MESS_ERR=1
   Endif
   Call ECR_TRACE("",0,RMES,1,1) From TRACEABX3
  Endif
  RERR=99
  Raz RMES
 Endif
Return

#========================================================================
#
Subprog APPLIQUE_DIRT(PCRIT1,PCRIT2,PCRIT3,PCRIT4,PTABLE,RMES,RERR)
#
# Sous-programme permettant de mettre Ã  jour les enregistrements des tables
# de donnÃĐes avec les paramÃĻtres de l'action mÃĐtier
# les codes erreurs retournÃĐs sont les suivants :
# 0    Pas d'erreur
#
# ------------------------------------------------------------------------------
Value    Char    PCRIT1      # CritÃĻre 1 -> CritÃĻre tous objets
Value    Char    PCRIT2      # CritÃĻre 2 -> CritÃĻre pour toutes les actions d'un objet
Value    Char    PCRIT3      # CritÃĻre 3 -> CritÃĻre propre Ã  l'action
Value    Char    PCRIT4      # CritÃĻre 4 -> CritÃĻre supplÃĐmentaire (SpÃĐcifique massif)
Value    Char    PTABLE      # Table sur laquelle la population est lockÃĐe
Variable Char    RMES        # Message d'erreur retournÃĐ
Variable Integer RERR        # Code retour du sous-programme

  Raz RMES, RERR

Local Char    RUPTURE_CPY       # Sauvegarde rupture sociÃĐtÃĐ pour ÃĐmission dans la trace
Local Char    RUPTURE_CUR       # Sauvegarde rupture devise  pour ÃĐmission dans la trace
Local Char    RUPTURE_CURLIB    # Sauvegarde rupture libellÃĐ devise pour ÃĐmission dans la trace
Local Integer NBMAJ_RECALC      # Si oui indique si calculÃĐ Ã  partir de NBCPYTRT-NBCPYERR

Local Integer NBTRT             : Raz NBTRT #Gbn-270405-Bug nÂ°XXXXX
Local Integer OK                :           #Gbn-270405-Bug nÂ°XXXXX
Local Integer I

	#=> ContrÃīle des paramÃĻtres
 	# FQ83184 "ParamÃĻtre PTABLE incorrect."
  If PTABLE="" : RERR=1 : RMES=mess(103,GML_MSGTRC,1) : GOK=0 : End : Endif

	#=> DÃĐbranchement vers traitement ERREUR_SP  # Erreur sous-programme

  Onerrgo ERREUR_SP From TRCPROCOM

  #=> Initialisations diverses

  NBMAJ_RECALC = G_OUI

  #=> Scan des critÃĻres pour qu'ils ne plantent pas le filter

  If PCRIT1="" : PCRIT1="1=1" : Endif
  If PCRIT2="" : PCRIT2="1=1" : Endif
  If PCRIT3="" : PCRIT3="1=1" : Endif
  If PCRIT4="" : PCRIT4="1=1" : Endif

  #=> Ouverture des tables

  If !clalev([F:MAS1]) : Local File =nomap+'.'+ PTABLE     [MAS1] : Endif    #=> Ouverture table Ã  mettre Ã  jour
  If !clalev([F:TML])  : Local File =nomap+'.'+'TMPMASLCK' [TML]  : Endif    #=> Ouverture de la table des locks # A supprimer
  If !clalev([F:XTRA]) : Local File =nomap+'.'+'TRCABX3'   [XTRA] : Endif    #=> Ouverture de la table contenant la trace

  #=> DÃĐbut de transaction de mise Ã  jour

  If GUSER=USRDBG : Infbox "S/P APPLIQUE_DIRT - adxlog"-num$(adxlog) : Endif

  #=> Avant de dÃĐbut de la transaction FQ66894

  ACTMET="DEB_APPL_DIRT" : Gosub ACTMET From TRCPROCOM

  If !GTRANS
		#If !adxlog
    Call DEBTRANS From GLOCK
    Trbegin [MAS1]
  Endif

	#=> Ouverture table annexes

  ACTMET="OUVR_APPL_DIRT" : Gosub ACTMET From TRCPROCOM

	#=> Pose du filtre

  Filter [MAS1] Where (evalue(PCRIT1) & evalue(PCRIT2) & evalue(PCRIT3) & evalue(PCRIT4)) Order By CPY Asc

	#=> Boucle sur la population sÃĐlectionnÃĐe
  For [MAS1]
    ######################################
    OK=1
    If ACTTYPGES <> GTAMUNI
      If dim(GNB_CRITFCY) > 0
        I =  find([F:MAS1]FCY, LIST_FCY_1)
        If I=0  and  dim(LIST_FCY_2) > 0     :  I= find([F:MAS1]FCY,LIST_FCY_2)  : Endif
        If I=0  and  dim(LIST_FCY_3) > 0     :  I= find([F:MAS1]FCY,LIST_FCY_3)  : Endif
        If I=0  and  dim(LIST_FCY_4) > 0     :  I= find([F:MAS1]FCY,LIST_FCY_4)  : Endif
        If I=0  and  dim(LIST_FCY_X) > 0     :  I= find([F:MAS1]FCY,LIST_FCY_X)  : Endif
        If I = 0 : OK=0 :            Endif
     #Else
     #   I= find([F:MAS1]FCY, LIST_FCY)
     #   If I = 0 : OK=0 :        Endif
      Endif
    Endif
    ###########################################
    If OK <> 0
      Case ACTREFOBJ
      When "LOF"
        Read [TML]TML1=NUMACT;[F:MAS1]CODLOF;[F:MAS1]LINLOF
        If fstat
          LOCKOK=0                                                #=> Enr pas trouvÃĐ dans TML, on le traitera pas (Pas considÃĐrÃĐ comme une erreur)
        Else
          LOCKOK=1
        Endif
      When "FAS"
        Read [TML]TML0=NUMACT;[F:MAS1]AASREF
        If fstat
          LOCKOK=0                                                #=> Enr pas trouvÃĐ dans TML, on le traitera pas (Pas considÃĐrÃĐ comme une erreur)
        Else
          LOCKOK=1
        Endif
      When "LEA"
        Read [TML]TML0=NUMACT;[F:MAS1]LEAREF
        If fstat
          LOCKOK=0                     #=> Enr pas trouvÃĐ dans TML, on le traitera pas (Pas considÃĐrÃĐ comme une erreur)
        Else
          LOCKOK=1
        Endif
      When "PHY"
        Read [TML]TML0=NUMACT;[F:MAS1]PHYREF
        If fstat
          LOCKOK=0                                                #=> Enr pas trouvÃĐ dans TML, on le traitera pas (Pas considÃĐrÃĐ comme une erreur)
        Else
          LOCKOK=1
        Endif
      When Default
      Endcase

      If LOCKOK
        #Gbn-280405-Bug NÂ°29958-DÃĐplacement de bloc car problÃĻme si G_NOCHOI_SELALL est Ã  G_OUI
        If RUPTURE_CPY<>[F:MAS1]CPY
          If RUPTURE_CPY<>""
            #GBN-09092004-Bug 24705 - Si NBCPYMAJ=0 on le recalcule par diffÃĐrence entre NBCPYTRT et NBCPYERR
            #GBN-10012005-BUG 27388 - ON AJOUTE "Et NBMAJ_RECALC=G_OUI"
            #If NBCPYMAJ=0 : NBCPYMAJ=NBCPYTRT-NBCPYERR : Endif
            If NBCPYMAJ=0 & NBMAJ_RECALC=G_OUI : NBCPYMAJ=NBCPYTRT-NBCPYERR : Endif
            Call ECR_TRACE_STAT(RUPTURE_CPY,NBCPYTRT,NBCPYMAJ,NBCPYERR)
          Endif
          RUPTURE_CPY=[F:MAS1]CPY
          Call GET_CPY_CUR([F:MAS1]CPY,RUPTURE_CUR,RUPTURE_CURLIB) From GLOFCYCPY
          Call LOAD_FASPARCPY([F:MAS1]CPY,"FPC",G_OUI,RERR) From GLOFCYCPY #@fq65636
          ACTMET="CPY_APPL_DIRT" : Gosub ACTMET From TRCPROCOM
          TRTYP=3 : TRPARM=0 : Gosub GESTRACE From TRCPROCOM2
          Raz NBCPYTRT, NBCPYMAJ, NBCPYERR
        Endif

        NBOBJ+=1
        ACTMET="MAS1_APPL_DIRT" : Gosub ACTMET From TRCPROCOM     # Mise Ã  jour directe des tables de donnÃĐes avec les paramÃĻtres de l'action
        If GOK<1
          RERR=90
          # FQ83184 "Une erreur s'est produite dans l'ÃĐtiquette"-ACTMET-"du programme"-ACTTRTACT
          # FQ99608 prise en compte de INFMES
          If RMES = ""
            If dim(INFMES) >= 0
              If INFMES <> ""
                RMES = INFMES
                NBCPYERR += 1
              Endif
            Endif
          Endif

          If RMES = ""
						RMES= func GLOFUNC.SUBSTIT2(mess(917,GML_MSGFAS,1), ACTMET, ACTTRTACT )
					Endif

          If ACTSILENCE=G_NON : Call ECR_TRACE([F:MAS1]CPY,GTRC_CRACTIO,RMES,1,1) From TRACEABX3 : Endif
          Break
        Elsif GOK=99 : # FQ66894
          If RMES<>"" & ACTSILENCE=G_NON : Call ECR_TRACE([F:MAS1]CPY,GTRC_CRACTIO,RMES,1,1) From TRACEABX3 : Endif
          Break
        Else
          If RMES<>"" & ACTSILENCE=G_NON : Call ECR_TRACE([F:MAS1]CPY,GTRC_CRACTIO,RMES,1,1) From TRACEABX3 : Endif
        Endif
        NBCPYTRT+=1

        #Gbn-270405-Bug nÂ°XXXXX
        If !GSERVEUR & ACTTYPGES=GTAMMAS & ACTSILENCE<>G_OUI
          NBTRT+=1
          # FQ83184 "Traitement de la population"
          Call AFF_BOITE(mess(112,GML_MSGTRC,1),NBTRT,OK) From GESECRAN
        Endif
      Endif
			If GUSER=USRDBG : Infbox [F:MAS1]AASREF-"GOK="-num$(GOK) : Endif
    Endif
  Next

  #GBN-09092004-Bug 24705 - Si NBCPYMAJ=0 on le recalcule par diffÃĐrence entre NBCPYTRT et NBCPYERR
  #GBN-10012005-Bug 27388 - on ajoute "Et NBMAJ_RECALC=G_OUI"
  #If NBCPYMAJ=0 : NBCPYMAJ=NBCPYTRT-NBCPYERR : Endif
  If NBCPYMAJ=0 & NBMAJ_RECALC=G_OUI : NBCPYMAJ=NBCPYTRT-NBCPYERR : Endif

  # FQ99608
  If GOK < 1
    Call ECR_TRACE_STAT(RUPTURE_CPY, NBCPYTRT, 0, NBCPYERR)

  	#    Call ECR_TRACE("", GTRC_STAT, "Une erreur dÃĐtectÃĐe : aucune mise Ã  jour rÃĐalisÃĐe.", 1, 1) From TRACEABX3
    Call ECR_TRACE("", GTRC_STAT, mess(928, GML_MSGFAS, 1), 1, 1) From TRACEABX3
    GERRTRACE -= 1
  Else
    Call ECR_TRACE_STAT(RUPTURE_CPY, NBCPYTRT, NBCPYMAJ, NBCPYERR)
  Endif

  #=> Suppression du filtre

  Filter [MAS1]

  #=> Traitement de fin de MAJ directe :
  ACTMET="END_APPL_DIRT" : Gosub ACTMET From TRCPROCOM

  #=> Fin de la transaction Commmit si pas d'erreur, rollback sinon

  If GOK & FLGSIM=G_NON
    If !GTRANS : Commit : Endif
    #If !adxlog : Commit : Endif
  Else
    If dim(GNUMTRACE)>0 & ACTSILENCE<>G_OUI
      Gosub VIDE_TRACE_EN_FICHIER From TRACEABX3
      If dim(GSEQTRACE) > 0 : Kill GSEQTRACE : Endif
      If dim(GNUMTRACE) > 0 : Kill GNUMTRACE : Endif
    Endif
    If !GTRANS : Rollback : Endif
    #If !adxlog : Rollback : Endif
    #If dim(GSEQTRACE) > 0 : Kill GSEQTRACE : Endif  # -> DÃĐplacement au dessus car ne marche pas en mode silencieux
    #If dim(GNUMTRACE) > 0 : Kill GNUMTRACE : Endif  #
  Endif

  #=> Fermeture des tables

  # Close Local File [MAS1], [TML]

  #=> Traitement de fin de sous-programme
  ACTMET="CLOS_APPL_DIRT" : Gosub ACTMET From TRCPROCOM

  Onerrgo

End

#========================================================================
#
Subprog VIDER(PNUMACT,PTMPTAB,RNBDLREC,RERR)
#
# Sous-programme permettant de vider les tables de travail des enregistrements
# de l'action en cours identifiÃĐe par le numÃĐro de traitement
# retournÃĐs sont les suivants :
# 0    Pas d'erreur
# ------------------------------------------------------------------------------
Value    Integer PNUMACT  # NumÃĐro de traitement
Value    Char    PTMPTAB  # Nom de la table temporaire principale
Variable Integer RNBDLREC # Nombre d'enregistrements dÃĐtruits
Variable Integer RERR     # Code retour du sous-programme

#=> DÃĐbranchement vers traitement ERREUR_SP  # Erreur sous-programme

 Onerrgo ERREUR_SP From TRCPROCOM

 If !clalev([F:TMP1]) : Local File =nomap+'.'+PTMPTAB   [TMP1] : Endif

 If GUSER=USRDBG : Infbox "S/P VIDER - adxlog"-num$(adxlog) : Endif
 If !GTRANS
#If !adxlog & ACTSILENCE=G_NON
  Call DEBTRANS From GLOCK
  Trbegin [TMP1]
 Endif
 Delete [TMP1] Where (TRTNUM=NUMACT)
 RNBDLREC=adxdlrec
 If !GTRANS : Commit : Endif
#If !adxlog & ACTSILENCE=G_NON : Commit : Endif
 Close Local File [TMP1]

Onerrgo

End

#========================================================================
#
Subprog VISUALISER()
#
# Sous-programme appelant l'objet de contrÃīle de visualisation de la table temporaire
# ------------------------------------------------------------------------------

 #Gbn-010206-Fq 34357-Le paramÃĻtre chargement des derniers lus ne doit pas s'appliquer sur l'objet de contrÃīle
 If GLECOBJ<>2 : If dim(SVGLECOBJ)>0 : Kill SVGLECOBJ : Endif : Local Integer SVGLECOBJ : SVGLECOBJ=GLECOBJ : GLECOBJ=2 : Endif
 Global Char ACTMAS
 TRTACTMAS = ACTTRTACT
 ACTMAS    = ACTMETNAM

 GBIDC1=num$(NUMACT) #Fq69206
 Call OBJET(TMPOBJ,GBIDC1,GBIDC2) From GOBJET

 #Gbn-010206-Fq 34357
 If dim(SVGLECOBJ)>0 : GLECOBJ=SVGLECOBJ : Kill SVGLECOBJ : Endif

 If dim(ACTMAS) >0    : Kill ACTMAS    : Endif
 If dim(ORIACT) >0    : Raz ORIACT     : Endif
End

#========================================================================
#
Subprog UNLOCKER(PNUMACT,RMES,RERR)
#
# Sous-programme permettant de supprimer les verrous posÃĐs par l'action mÃĐtier
# 0    Pas d'erreur
# ------------------------------------------------------------------------------
Value    Integer PNUMACT     # NumÃĐro de traitement
Variable Char    RMES        # Message d'erreur ou d'information renvoyÃĐ par le s/p
Variable Integer RERR        # Code erreur renvoyÃĐ par le s/p

Local Integer NBDLREC,ERR    # Nombre d'enregistrements supprimÃĐs

#=> DÃĐbranchement vers traitement ERREUR_SP  # Erreur sous-programme

Onerrgo ERREUR_SP From TRCPROCOM

ACTMET="UNLOCK_AUTRE" : Gosub ACTMET From TRCPROCOM   # Unlock des objets liÃĐs.

If    ACTTYPGES=GTAMMAS                      #=> Massif, on unlock sur le numÃĐro de processus
 Call UNLOCK_SYMBOLE("","","") From GLOBIENS
Elsif ACTTYPGES=GTAMUNI                      #=> Unitaire, il faut trouver une autre solution
 # Dans ce cas, on s'appuie sur la table temporaire des locks
 If !clalev([F:TML]) : Local File TMPMASLCK [TML] : Endif
 Filter [F:TML] Where TRTNUM=PNUMACT & OBJMAIN=G_NON
 For [TML]
  Call UNLOCK_SYMBOLE(ACTREFOBJ,[F:TML]OBJCPY,[F:TML]OBJSYM) From GLOBIENS
 Next
 Filter [F:TML]
Endif
Call VIDER(PNUMACT,"TMPMASLCK",NBDLREC,ERR) From TRCPROCOM        #=> On vide la table des objets lockÃĐs par l'action
If GUSER=USRDBG : Infbox "NBR enr supprimÃĐs dans TMPMASLCK :"-num$(NBDLREC) : Endif

Onerrgo

End

#========================================================================
#
Subprog REPORTER(PNUMACT,PTABLE,RMES,RERR)
#
# Sous-programme pour transfÃĐrer les modifs des tables temporaires dans les tables
# de donnÃĐes.
# ------------------------------------------------------------------------------
Value    Integer PNUMACT     # NumÃĐro de l'action en cours (permet la sÃĐlection des enregistrements Ã  modifier)
Value    Char    PTABLE      # Nom de la table temporaire principale Ã  ouvrir
Value    Char    PTABSUP     # Nom de la table temporaire annexe Ã  ouvrir (par plan)
Variable Char    RMES        # Message d'erreur ou d'information renvoyÃĐ par le s/p
Variable Integer RERR        # Code erreur renvoyÃĐ par le s/p

 Raz RMES, RERR

Local Char    RUPTURE_CPY       # Sauvegarde rupture sociÃĐtÃĐ pour ÃĐmission dans la trace
Local Char    RUPTURE_CUR       # Sauvegarde rupture devise  pour ÃĐmission dans la trace
Local Char    RUPTURE_CURLIB    # Sauvegarde rupture libellÃĐ devise pour ÃĐmission dans la trace
Local Integer NBMAJ_RECALC      # Recalcul automatique de NBCPYMAJ ?


#=> ContrÃīle des paramÃĻtres
 # FQ83184 "ParamÃĻtre PTABLE incorrect."
 If PTABLE="" : RERR=1 : RMES=mess(103,GML_MSGTRC,1) : GOK=0 : End : Endif

#=> DÃĐbranchement vers traitement ERREUR_SP  # Erreur sous-programme

 Onerrgo ERREUR_SP From TRCPROCOM

#=> Initialisations diverses

 NBMAJ_RECALC = G_OUI

#=> Variables du s/p

 Local Integer IS_OBJ_MAIN, FIND_MAIN

#=> Ouverture tables

 If !clalev([F:MAS1]) : Local File =nomap+'.'+ PTABLE      [MAS1] : Endif # Ouverture de la table Ã  mettre Ã  jour
 If !clalev([F:TMP1]) : Local File =nomap+'.'+ TMPTAB      [TMP1] : Endif # Ouverture de la table temporaire
 If TMPTAB2<>""
  If !clalev([F:TMPC]): Local File =nomap+'.'+ TMPTAB2    [TMPC]  : Endif # Ouverture de la table temporaire complÃĐmentaire
 Endif
 If !clalev([F:TML])  : Local File =nomap+'.'+'TMPMASLCK'  [TML]  : Endif # Ouverture de la table des locks # A supprimer
 If ACTGESPLN=G_OUI
  If !clalev([F:TPF1]) : Local File =nomap+'.'+TMPTABPLN   [TPF1] : Endif  # Ouverture de la table temporaire par plan
 Endif
 If !clalev([F:XTRA]) : Local File TRCABX3 [XTRA]                 : Endif

#=> Ouverture de la transaction (Uniquement en massif. En unitaire elle est dÃĐjÃ  ouverte)

 If GUSER=USRDBG : Infbox "S/P REPORTER - adxlog"-num$(adxlog) : Endif
 If ACTTYPGES = GTAMMAS
  If !GTRANS
 #If !adxlog
   Call DEBTRANS From GLOCK
   Trbegin [MAS1]
  Endif
 Endif

#=> Ouverture table annexes

 ACTMET="OUVR_ALIM_TABLE" : Gosub ACTMET From TRCPROCOM         # Ouverture de tables annexes

#=> Pose du filtre sur TMP1

 Filter [TMP1] Where TRTNUM = PNUMACT Order By CPY Asc

#=> Boucle sur TMP1

 FIND_MAIN   = G_NON
 IS_OBJ_MAIN = G_NON

 For [TMP1]

  If TMPTAB2<>""
   Read [TMPC]MF10=[F:TMP1]TRTNUM;[F:TMP1]OBJREF
  Endif

  If    ACTTYPGES=GTAMUNI                # En unitaire, on ne traite pas l'objet principal (cf. REPORT_MASK)
   IS_OBJ_MAIN  = G_NON
   If FIND_MAIN = G_NON
    Case ACTREFOBJ
     When "LOF"   : IS_OBJ_MAIN = func TRCPROCOM.IS_MAIN_OBJ(PNUMACT,ACTREFOBJ,[F:TMP1]OBJREF,[F:TMP1]OBJLIN)
     When Default : IS_OBJ_MAIN = func TRCPROCOM.IS_MAIN_OBJ(PNUMACT,ACTREFOBJ,[F:TMP1]OBJREF,0)
    Endcase
    If IS_OBJ_MAIN = G_OUI : FIND_MAIN=G_OUI : Endif
   Endif
   #If IS_OBJ_MAIN=G_NON  # Reporter le test sur IS_OBJMAIN dans REPORT_ENR_TMP1
    Gosub REPORT_ENR_TMP1
    If GOK<1 # Erreur
     Break
    Endif
   #Endif
  Elsif ACTTYPGES=GTAMMAS               # En massif, on boucle sur tous les enregistrements de [TMP1]
   If RUPTURE_CPY<>[F:TMP1]CPY
    If RUPTURE_CPY<>""
     #GBN-09092004-Bug 24705 - Si NBCPYMAJ=0 on le recalcule par diffÃĐrence entre NBCPYTRT et NBCPYERR
     #GBN-10012005-Bug 27388 - et si NBMAJ_RECALC=G_OUI
     #If NBCPYMAJ=0 : NBCPYMAJ=NBCPYTRT-NBCPYERR : Endif
     If NBCPYMAJ=0 & NBMAJ_RECALC=G_OUI : NBCPYMAJ=NBCPYTRT-NBCPYERR : Endif
     Call ECR_TRACE_STAT(RUPTURE_CPY,NBCPYTRT,NBCPYMAJ,NBCPYERR)
    Endif
    RUPTURE_CPY=[F:TMP1]CPY
    Call GET_CPY_CUR([F:TMP1]CPY,RUPTURE_CUR,RUPTURE_CURLIB) From GLOFCYCPY
    TRTYP=3 : TRPARM=0 : Gosub GESTRACE From TRCPROCOM2
    Raz NBCPYTRT, NBCPYMAJ, NBCPYERR
   Endif
   Gosub REPORT_ENR_TMP1
   If GOK<1 # Erreur
    Break
   Endif
   If ACTREFOBJ<>"PHY" Then
     If [F:TMP1]AASIND <> "N"
       NBCPYTRT+=1
     Endif
   Else
     NBCPYTRT+=1
   Endif
  Endif
 Next
 If ACTTYPGES=GTAMMAS
  #GBN-09092004-Bug 24705 - Si NBCPYMAJ=0 on le recalcule par diffÃĐrence entre NBCPYTRT et NBCPYERR
  #GBN-10012005-Bug 27388 - et si NBMAJ_RECALC=G_OUI
  #If NBCPYMAJ=0 : NBCPYMAJ=NBCPYTRT-NBCPYERR : Endif
  If NBCPYMAJ=0 & NBMAJ_RECALC=G_OUI : NBCPYMAJ=NBCPYTRT-NBCPYERR : Endif
  Call ECR_TRACE_STAT(RUPTURE_CPY,NBCPYTRT,NBCPYMAJ,NBCPYERR)
 Endif

#=> Suppression du filtre sur TMP1

 Filter [TMP1]

#=> Traitements de fin de la boucle

 ACTMET="END_ALIM_TABLE" : Gosub ACTMET From TRCPROCOM

#=> Fin de la transaction  (Uniquement en massif. En unitaire elle est dÃĐjÃ  ouverte)

 If ACTTYPGES = GTAMMAS
  If GOK<1 | FLGSIM=G_OUI
   If GUSER=USRDBG : Infbox "Rollback" : Endif # Tst
   If ACTSILENCE<>G_OUI : Gosub VIDE_TRACE_EN_FICHIER From TRACEABX3 : Endif
   If !GTRANS : Rollback : Endif
  #If !adxlog : Rollback : Endif
   If dim(GSEQTRACE) > 0 Then Kill GSEQTRACE : Endif
   If dim(GNUMTRACE) > 0 Then Kill GNUMTRACE : Endif
   # Le traitement appelant doit supprimer les verrous si nÃĐcessaire
  Else
   If GUSER=USRDBG : Infbox "Commit" : Endif # Tst
   If !GTRANS : Commit : Endif
  #If !adxlog : Commit : Endif
   # Le traitement appelant doit supprimer les verrous si nÃĐcessaire
  Endif
 Endif

#=> Traitements de fin de sous-programme

 ACTMET="CLOS_ALIM_TABLE" : Gosub ACTMET From TRCPROCOM

Onerrgo

End

$REPORT_ENR_TMP1
 Case ACTREFOBJ
  When "LOF"
  When "FAS"
   If [F:TMP1]AASIND <>  "N"    #**AASIND = "N"  sont des biens qui seront crÃĐÃĐs uniquement dans END_ALIM_TABLE
      Read [MAS1]FAS0=[F:TMP1]OBJREF
      If fstat
        GOK=0
       Return
      Endif
      ACTMET="TMP1_ALIM_TABLE" : Gosub ACTMET From TRCPROCOM        # Alimentation table de donnÃĐes Ã  partir tb tmp principale
      If ACTGESPLN=G_OUI & GOK=1
       Filter [TPF1] Where (TRTNUM=[F:TMP1]TRTNUM & OBJREF=[F:TMP1]OBJREF) # & FLGERR=G_NON)
       For [TPF1]
        ACTMET="TPF1_ALIM_TABLE" : Gosub ACTMET From TRCPROCOM      # Alimentation table de donnÃĐes Ã  partir tb tmp annexe
        If GOK<1
         #RERR=?
         #RMES="?"
         Break
        Endif
       Next
       Filter [TPF1]
      Endif
      If GOK=1 & [F:TMP1]FLGERR=G_NON & IS_OBJ_MAIN=G_NON  # Pas de rÃĐÃĐcriture de l'enr FXDASSETS
                                                           # Si TMP1 en erreur ou erreur de lecture ou si objet principal (unitaire)
                                                           # ou si l'enreg TMP1 correspond Ã  un nouveau bien (cas de l'ÃĐclatement)
       Rewrite [MAS1]
       If fstat
        GOK=0
        #RERR=?
        #RMESS="?"
        Return
       Endif
      Endif
   Endif
  When "LEA"
  When "PHY"
    Read [MAS1]PHY0=[F:TMP1]OBJREF
    If fstat
      GOK=0
      Return
    Endif
    ACTMET="TMP1_ALIM_TABLE" : Gosub ACTMET From TRCPROCOM        # Alimentation table de donnÃĐes Ã  partir tb tmp principale

    If ACTTYPGES = GTAMMAS Then                                   # pas de rÃĐ ÃĐcriture en unitaire.
       Rewrite [MAS1]
       If fstat
         GOK=0
         Return
       Endif
    Endif
  When Default
 Endcase
Return

#========================================================================
#
Subprog REPORT_MASK(PNUMACT,PTABLE,PTABSUP,RMES,RERR)
#
# Sous-programme utilisÃĐ uniquement en action unitaire et permettant de
# transfÃĐrer les donnÃĐes des tables temporaires dans les masques de l'ÃĐcran
# pour l'objet principal auquel s'applique l'action mÃĐtier.
# ------------------------------------------------------------------------------
Value    Integer PNUMACT     # NumÃĐro de l'action en cours (permet la sÃĐlection des enregistrements Ã  modifier)
Value    Char    PTABLE      # Nom de la table temporaire principale Ã  ouvrir
Value    Char    PTABSUP     # Nom de la table temporaire annexe Ã  ouvrir (par plan)
Variable Char    RMES        # Message d'erreur ou d'information renvoyÃĐ par le s/p
Variable Integer RERR        # Code erreur renvoyÃĐ par le s/p

 Raz RMES, RERR

#=> DÃĐbranchement vers traitement ERREUR_SP  # Erreur sous-programme

 Onerrgo ERREUR_SP From TRCPROCOM

#=> Ouverture des tables

 If !clalev([F:TMP1]) : Local File =nomap+'.'+PTABLE   [TMP1]    : Endif    #=> Ouverture tables temporaire principale
 If TMPTAB2<>""
  If !clalev([F:TMPC]) : Local File =nomap+'.'+TMPTAB2 [TMPC]    : Endif    #=> Ouverture tables temporaire complÃĐmentaire
 Endif
 If PTABSUP<>""
  If !clalev([F:TPF1]) : Local File =nomap+'.'+PTABSUP [TPF1]    : Endif    #=> Ouverture tables temporaire annexe
 Endif
 If !clalev([F:TML])  : Local File =nomap+'.'+'TMPMASLCK' [TML]  : Endif    #=> Ouverture de la table des locks # A supprimer
 If !clalev([F:XTRA]) : Local File TRCABX3 [XTRA]                : Endif

#=> Pose du filtre sur la table temporaire des locks

 Filter [TML] Where (TRTNUM=PNUMACT & OBJMAIN=G_OUI)

#=> Lecture de TML

 For [TML]
  Read [TMP1]MFS0=[F:TML]TRTNUM;[F:TML]OBJREF                                #=> Lecture de l'enregistrement TMP1
  If !fstat
   If TMPTAB2<>""
    Read [TMPC]MF10=[F:TMP1]TRTNUM;[F:TMP1]OBJREF
   Endif
   If PTABSUP<>""
    Filter [TPF1] Where TRTNUM=[F:TMP1]TRTNUM & OBJREF=[F:TMP1]OBJREF
    For [TPF1]                                                               #=> Boucle sur [TPF1] si nÃĐcessaire
     ACTMET="TPF1_ALIM_MASK" : Gosub ACTMET From TRCPROCOM
    Next
    Filter [TPF1]
   Endif
   ACTMET="TMP1_ALIM_MASK" : Gosub ACTMET From TRCPROCOM
  Endif
 Next

#=> Suppression du filtre sur TML - table des lock de l'action mÃĐtier

 Filter [TML]

Onerrgo

End

#Gbn-031105-Fq XXXXX-Emission de la liste des objets rejetÃĐs
#========================================================================
#
Subprog ECR_TRACE_NOSEL(PCPY,POBJREF,PMESSAGE)
#
# Sous-programme d'ÃĐmission de la liste des biens qui n'ont pas ÃĐtÃĐ retenus
# au moment de la phase de lock
# ------------------------------------------------------------------------------

End

#========================================================================
#
Subprog ECR_TRACE_ERREUR(PCPY,POBJREF,PPLN,PINCREMENT,PMESSAGE)
#
# Sous-programme d'ÃĐmission des messages d'erreurs fonctionnels dans la trace
# Gbn-27092004-Bug 25042 - DÃĐcrÃĐmentation du compteur superviseur GERRTRACE
#                          pour que la boÃŪte de message Ã  l'ouverture de la trace
#                          contienne le bon nombre d'erreurs.
# ------------------------------------------------------------------------------
Value Char    PCPY()
Value Char    POBJREF()
Value Integer PPLN
Value Integer PINCREMENT
Value Char    PMESSAGE()
If ACTSILENCE=G_OUI : End : Endif
Local Char    LIGNE(115)
Local Integer CHAPITRE   : CHAPITRE=GTRC_CRERREU
Local Integer OBJTYP
Local Integer LNG_REF : LNG_REF = 21
Local Integer LNG_PLN : LNG_PLN = 21
Local Integer LNG_MES : LNG_MES = 71
Local Integer LNG_LIG : LNG_LIG = 1+LNG_REF+LNG_PLN+LNG_MES+1
Local Integer NB_MES  : NB_MES  = 10
Local Char    SEP_MES : SEP_MES ="|"

Case ACTREFOBJ
 When "LOF" : OBJTYP=GVML_OMDEPEN
 When "FAS" : OBJTYP=GVML_OMBIEN
 When "LEA" : OBJTYP=GVML_OMLOCFI
 When "PHY" : OBJTYP=GVMLOMPHY
 When Default
Endcase

# Faut-il ÃĐmettre l'en-tÃŠte ?

If !GHEADERRTRC
 Gosub ET_ERREUR
 GHEADERRTRC=1
 GHEADERRCPY=PCPY
Else
 If GHEADERRCPY<>PCPY
  Gosub ET_ERREUR
  GHEADERRCPY=PCPY
 Endif
Endif

# Emission du message

 Local Integer I_DEB   : I_DEB   = 1
 Local Integer I_FIN   : I_FIN   = 1
 Local Integer I_TMSG  : I_TMSG  = 1
 Local Char    MESSERR(255)
 Local Char    TAB_MESS(LNG_MES)(NB_MES) : Raz TAB_MESS
 Local Integer TAB_FLGE(NB_MES)          : Raz TAB_FLGE  # Gbn-27092004-Bug 25042
 Local Integer I

 #> Si il y plusieurs messages (sÃĐparÃĐs par le caractÃĻre SEP_MES)
 If pat(PMESSAGE,"*"+SEP_MES+"*")

  Repeat
   I_FIN=instr(I_DEB,PMESSAGE,SEP_MES)
   MESSERR=seg$(PMESSAGE,I_DEB,I_FIN)
   If len(MESSERR)<=LNG_MES
    TAB_MESS(I_TMSG)=MESSERR
    TAB_FLGE(I_TMSG)=1
   Else
    #TAB_MESS(I_TMSG)=left$(MESSERR,LNG_MES)
    # Decoupage du message
    # Si le message est plus long que LNG_MES, il faut le dÃĐcouper proprement selon les espaces
    Local Integer I_BLANC : I_BLANC=LNG_MES+1
    Local Char    C_BLANC(1)
    Repeat
     I_BLANC-=1
     C_BLANC=mid$(MESSERR,I_BLANC,I_BLANC)
    Until (C_BLANC=" " | I_BLANC=1)
    If !(I_BLANC=1)
     TAB_MESS(I_TMSG)=left$(MESSERR,I_BLANC-1)
     I_TMSG +=1
     TAB_MESS(I_TMSG)=right$(MESSERR,I_BLANC+1)
    Endif
   Endif
   I_TMSG += 1
   I_FIN  += 1
   I_DEB   = I_FIN
  Until !instr(I_DEB,PMESSAGE,SEP_MES)

  MESSERR=right$(PMESSAGE,I_DEB)

  If len(MESSERR)<=LNG_MES
   TAB_MESS(I_TMSG)=MESSERR
  Else
   TAB_MESS(I_TMSG)=left$(MESSERR,LNG_MES)
  Endif

  TAB_FLGE(I_TMSG)=1  # Gbn-27092004-Bug 25042

 Else

  If len(PMESSAGE)<=LNG_MES
   TAB_MESS(I_TMSG)=PMESSAGE
   TAB_FLGE(I_TMSG)=1
  Else
   #TAB_MESS(I_TMSG)=left$(PMESSAGE,LNG_MES)
    # Decoupage du message
    # Si le message est plus long que LNG_MES, il faut le dÃĐcouper proprement selon les espaces
    Local Integer I_BLANC : I_BLANC=LNG_MES+1
    Local Char    C_BLANC(1)
    Repeat
     I_BLANC-=1
     C_BLANC=mid$(PMESSAGE,I_BLANC,I_BLANC)
    Until (C_BLANC=" " | I_BLANC=1)
    If !(I_BLANC=1)
     TAB_MESS(I_TMSG)=left$(PMESSAGE,I_BLANC-1) : TAB_FLGE(I_TMSG)=1  # DÃĐbut du message d'erreur # Gbn-27092004-Bug 25042
     I_TMSG +=1
     TAB_MESS(I_TMSG)=right$(PMESSAGE,I_BLANC+1) : TAB_FLGE(I_TMSG)=0 # Fin du message d'erreur # Gbn-27092004-Bug 25042
    Endif
  Endif

 Endif

 For I=1 To I_TMSG
  If I=1
   #> Sur la premiÃĻre ligne, on fait figurer le plan d'amortissement
   LIGNE=space$(1)+left$(POBJREF+space$(LNG_REF),LNG_REF)
   If PPLN
    LIGNE+=left$(mess(PPLN,3101,1)+space$(LNG_PLN),LNG_PLN)
   Else
    LIGNE+=space$(LNG_PLN)
   Endif
  Else
   LIGNE=space$(1+LNG_REF+LNG_PLN)
  Endif
  LIGNE+=TAB_MESS(I)
  Call ECR_TRACE(PCPY,CHAPITRE,LIGNE,1,1) From TRACEABX3
  If TAB_FLGE(I)=0 : GERRTRACE-=1 : Endif  # Gbn-27092004-Bug 25042
 Next I

# Emission du sÃĐparateur

# LIGNE=string$(LNG_LIG,"-") : Call ECR_TRACE(PCPY,CHAPITRE,LIGNE,0,1) From TRACEABX3

# IncrÃĐmentation du compteur d'objets en erreur

If PINCREMENT=G_OUI
 NBCPYERR+=1
Endif

End

$ET_ERREUR
Local Char ENTET

  Case ACTREFOBJ
    When "PHY"
      ENTET =""                       # mess(251,403,1)    # dÃĐsignation
    When Default
      ENTET = mess(87,7774,1)         # plan
  Endcase

 Call ECR_TRACE(PCPY,CHAPITRE,"",0,1) From TRACEABX3
 LIGNE=mess(4,7778,1)-"("+PCPY+")" : Call ECR_TRACE(PCPY,CHAPITRE,LIGNE,0,1) From TRACEABX3
 LIGNE=string$(LNG_LIG,"=") : Call ECR_TRACE(PCPY,CHAPITRE,LIGNE,0,1) From TRACEABX3
 LIGNE=space$(1)+left$(mess(OBJTYP,3141,1)+space$(LNG_REF),LNG_REF)
&     +left$(mess(87,7774,1)+space$(LNG_PLN),LNG_PLN)
&     +mess(6,123,1)
 Call ECR_TRACE(PCPY,CHAPITRE,LIGNE,0,1) From TRACEABX3
 LIGNE=string$(LNG_LIG,"=") : Call ECR_TRACE(PCPY,CHAPITRE,LIGNE,0,1) From TRACEABX3
Return


#========================================================================
#
Subprog ECR_TRACE_STAT(PCPY,PTRT,PMAJ,PERR)
#
# Sous-programme d'ÃĐmission des statistiques par sociÃĐtÃĐ
# ------------------------------------------------------------------------------
Value Char    PCPY     # SociÃĐtÃĐ pour laquelle les stats sont ÃĐmises
Value Integer PTRT     # Nombre d'objets mÃĐtiers traitÃĐs
Value Integer PMAJ     # Nombre d'objets mÃĐtiers mis Ã  jour
Value Integer PERR     # Nombre d'objet mÃĐtier en erreur

If ACTSILENCE=G_OUI : End : Endif

Local Char    LIGNE(115)
Local Integer CHAPITRE   : CHAPITRE=GTRC_STAT

Call ECR_TRACE(PCPY,CHAPITRE,"",0,1) From TRACEABX3

LIGNE=mess(506,7773,1)-"("+PCPY+")" : Call ECR_TRACE(PCPY,CHAPITRE,LIGNE,0,1) From TRACEABX3 #"Statistiques"

LIGNE=string$(36,"=") : Call ECR_TRACE(PCPY,CHAPITRE,LIGNE,0,1) From TRACEABX3

LIGNE =space$(1)
LIGNE+=left$(mess(507,7773,1)+space$(12),12)+space$(1)
LIGNE+=left$(mess(508,7773,1)+space$(10),10)+space$(2)
LIGNE+=left$(mess(509,7773,1)+space$(7),7)
Call ECR_TRACE(PCPY,CHAPITRE,LIGNE,0,1) From TRACEABX3

LIGNE=string$(36,"=") : Call ECR_TRACE(PCPY,CHAPITRE,LIGNE,0,1) From TRACEABX3
LIGNE=space$(1)+num$(PTRT)+space$(13-len(num$(PTRT)))
&              +num$(PMAJ)+space$(12-len(num$(PMAJ)))
&              +num$(PERR)+space$(12-len(num$(PERR)))
Call ECR_TRACE(PCPY,CHAPITRE,LIGNE,0,1) From TRACEABX3
LIGNE=string$(36,"-") : Call ECR_TRACE(PCPY,CHAPITRE,LIGNE,0,1) From TRACEABX3

End

#========================================================================
#
Subprog ECR_TRACE_LISTE(PLST,PCPY,POBJREF,POBJLIN,PMESS)
#
# Sous-programme d'ÃĐmission d'une liste dans la trace
# Globale utilisÃĐes :
#
#     GNBTRCLST : GNBTRCLST=1              # Nombre de listes Ã  gÃĐrer au maximum
#     GHEADLSTTRC(0..GNBTRCLST-1)          # En-tÃŠte liste n dÃĐjÃ  ÃĐmis ?
#     GLSTTITRE(50)(0..GNBTRCLST-1)        # Titre des listes d'objets
#     GLSTCOLNAM(80)(0..GNBTRCLST-1)       # Titre des colonnes spÃĐcifiques (en plus de la rÃĐfÃĐrence des objets)
#
# ------------------------------------------------------------------------------
Value Integer PLST       # NumÃĐro de la liste Ã  traiter
Value Char    PCPY       # SociÃĐtÃĐ pour laquelle la liste est ÃĐmise
Value Char    POBJREF    # RÃĐfÃĐrence de l'objet mÃĐtier
Value Integer POBJLIN    # Ligne de l'objet mÃĐtier (obligatoire uniquement pour les dÃĐpenses, 0 sinon)
Value Char    PMES       # Message Ã  associer Ã  l'objet mÃĐtier (facultatif)

If ACTSILENCE=G_OUI : End : Endif

Local Char    LIGNE(115)
Local Integer CHAPITRE      : CHAPITRE=evalue("GTRC_CRLST"+num$(PLST+1))
Local Char    SEPARATEUR(1) : SEPARATEUR="="
Local Char    OBJNAM

# Si l'en-tÃŠte n'a pas encore ÃĐtÃĐ ÃĐmis dans la trace
 If GHEADLSTTRC(PLST)=0
  Gosub HEAD_LST_TRC
  GHEADLSTTRC(PLST)=1
 Endif
# Emission du message
 Gosub BODY_LST_TRC
End

$HEAD_LST_TRC
 LIGNE="" : Call ECR_TRACE(PCPY,CHAPITRE,LIGNE,0,1) From TRACEABX3
 LIGNE=GLSTTITRE(PLST) : Call ECR_TRACE(PCPY,CHAPITRE,LIGNE,0,1) From TRACEABX3
 LIGNE=string$(35+len(GLSTCOLNAM(PLST))+1,SEPARATEUR) : Call ECR_TRACE(PCPY,CHAPITRE,LIGNE,0,1) From TRACEABX3

 Case ACTREFOBJ
  When "FAS" : OBJNAM=mess(2,3141,1)
  When "LOF" : OBJNAM=mess(1,3141,1)
  When "LEA" : OBJNAM=mess(4,3141,1)
  When "PHY" : OBJNAM=mess(6,3141,1)
  When Default
 Endcase
 LIGNE=space$(1)+left$(OBJNAM+space$(34),34)
 If GLSTCOLNAM(PLST)<>"" : LIGNE+=GLSTCOLNAM(PLST) : Endif
 Call ECR_TRACE(PCPY,CHAPITRE,LIGNE,0,1) From TRACEABX3

 LIGNE=string$(35+len(GLSTCOLNAM(PLST))+1,SEPARATEUR) : Call ECR_TRACE(PCPY,CHAPITRE,LIGNE,0,1) From TRACEABX3
Return

$BODY_LST_TRC
 Local Integer LNGCOL
 LIGNE = space$(1)
 LIGNE+= POBJREF
 LNGCOL=len(POBJREF)
 If !(POBJLIN=0)
  LIGNE+="/"+num$(POBJLIN)
  LNGCOL+=1+len(num$(POBJLIN))
 Endif
 LIGNE+=space$(34-LNGCOL)
 If PMESS<>""
  LIGNE+=PMESS
 Endif
 Call ECR_TRACE(PCPY,CHAPITRE,LIGNE,0,1) From TRACEABX3
Return

