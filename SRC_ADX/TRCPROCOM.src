$ERREUR_SP

 Local Char MESERRGRAVE(100)(0..4)
 # Nettoyage des locks
 # Emission du message

 MESERRGRAVE(0) = "Err. nÂ°"+num$(errn)-"/"-errmes$(errn)-"-"-errm
 MESERRGRAVE(1) = errp+"("+num$(errl)+")"

 If !GSERVEUR
  Errbox MESERRGRAVE
 Else
  Call ECR_TRACE(MESERRGRAVE(1)+"#"+MESERRGRAVE(0),1) From GESECRAN
 Endif

 RERR=90

 GOK=0

 If !GTRANS and adxlog : # ajout du test sur adxlog pour ne pas avoir de boucle infinie s'il n'y a pas de transaction en cours.
  Rollback
 Endif

 End : # arrÃŠt du traitement
Resume

#========================================================================
$AFF_CRITERE

Local Integer VERSION   :  VERSION=1

Case VERSION
 When 1
  Infbox "CRITSUPR"-CRITSUPR
  Infbox "CRITOBJ"-CRITOBJ
  Infbox "CRITACT"-CRITACT
  Infbox "CRITSUP1"-CRITSUP1
 When 2
  Local Integer I_CRIT
  For I_CRIT=1 To dim(CRITACT,1)
   # FQ83184 "Occurrence"
   Infbox mess(113,GML_MSGTRC,1)-num$(I_CRIT)-":"-CRITACT(I_CRIT-1)
  Next I_CRIT
 When Default
Endcase

Return

