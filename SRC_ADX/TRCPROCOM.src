$AFF_LIST_FCY
 If dim(LIST_FCY)>0
  Local Integer I_FCY
  Local Char LISTE_SITES(255)
  For I_FCY=0 To dim(LIST_FCY)-1
   If LISTE_SITES<>"" : LISTE_SITES+=" / " : Endif
   LISTE_SITES+=LIST_FCY(I_FCY)
  Next I_FCY
  Infbox(LISTE_SITES)
 Endif
Return

