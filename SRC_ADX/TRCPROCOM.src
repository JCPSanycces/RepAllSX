#fq39018
#========================================================================
#
Subprog ACTCHGCRIT2(PSIL)
#
# Sous-programme appelÃĐ par l'action CHGACTCRIM Ã  mettre en aprÃĻs modif de chaque
# champ de sÃĐlection de l'action mÃĐtier. Permet, si une sÃĐlection a dÃĐjÃ  ÃĐtÃĐ
# faite  et si le paramÃĐtre PSIL est diffÃĐrent de 2 de demander si on veut
# prendre en compte le nouveau critÃĻre de sÃĐlection
# - Si oui, on nettoie tout ce qui avait ÃĐtÃĐ crÃĐe par la premiÃĻre sÃĐlection et on
# revient Ã  l'ÃĐtape de sÃĐlection.
# - Si non, on retourne en saisie sur le champ.
# Si le paramÃĻtre PSIL vaut 2, on ne pose pas la question et on fait comme si
# l'utilisateur avait rÃĐpondu oui.
# ------------------------------------------------------------------------------
Value Integer PSIL

 If ACTTYPGES=GTAMUNI and PRECHARGE=G_OUI
  # Unitaire avec prÃĐcharge
  ACTSTATUS=STA_TEMP : # on rÃĐappliquera juste les paramÃĻtres
 Else
  If ACTSTATUS<>STA_DEBUT
   Local Integer POK,ERR,NBDLREC
   Local Char    MES
   If PSIL<>G_OUI
   Call OUINON(mess(430,7773,1)+". "+mess(431,7773,1)+".\"+mess(432,7773,1)+" ?", POK) From GESECRAN
   Endif
   If PSIL=G_OUI | PSIL<>G_OUI & POK=G_OUI
     ACTSTATUS=STA_DEBUT
    #=> Unlock la population
     Call UNLOCKER(NUMACT,MES,ERR)
    #=> Vider les tables de travail
     Call VIDER(NUMACT,TMPTAB,NBDLREC,ERR) From TRCPROCOM             #=> On vide la table temporaire principale
     If ACTGESPLN=G_OUI
      Call VIDER(NUMACT,TMPTABPLN,NBDLREC,ERR) From TRCPROCOM         #=> On vide la table temporaire par plan
     Endif
     If TMPTAB2<>""
      Call VIDER(NUMACT,TMPTAB2,NBDLREC,ERR) From TRCPROCOM           #=> On vide la table temporaire principale
     Endif
   Endif
   If PSIL<>G_OUI & POK<>G_OUI
     mkstat = 2
   Endif
  Endif
 Endif
End

#========================================================================
#
Subprog CHGACTPARM()
#
# Sous-programme appelÃĐ par l'action CHGACTPARM Ã  mettre en aprÃĻs modif de chaque
# champ de paramÃĻtre de l'action mÃĐtier. Permet, si un paramÃĻtre a dÃĐjÃ  ÃĐtÃĐ appliquÃĐ
# Ã  la population sÃĐlectionnÃĐe,  de demander si on veut prendre en compte le nouveau paramÃĻtre
#  paramÃĻtre
#      - Si oui, on nettoie tout ce qui avait ÃĐtÃĐ calculÃĐ Ã  partir des  paramÃĻtres prÃĐcÃĐdents et on
# revient Ã  l'ÃĐtape d'application des nouveaux paramÃĻtres
#     - Si non, on retourne en saisie sur le champ
# ------------------------------------------------------------------------------
 If ACTSTATUS>=STA_MODIF # Demande Mwa pour tenir compte du prÃĐchargement possible en unitaire

   Local Integer POK,ERR,NBDLREC
   Local Char    MES
  # gbn-22102004-En unitaire on ne pose pas la question car le OK peut appliquer les paramÃĐtres mÃŠme s'il y a
  #              eu un premier clic sur contrÃīler.
  If ACTTYPGES=GTAMMAS
    #Gbn-230305-Bug nÂ°29360-Suppression message en dur
    MESSAGE=mess(433,7773,1)+".\"+mess(434,7773,1)+".\"+mess(432,7773,1)+" ?"
    Call OUINON(MESSAGE,POK) From GESECRAN
    Case POK
     When G_OUI
      ACTSTATUS=STA_TEMP
     When Default
      mkstat = 2
    Endcase
  Elsif ACTTYPGES=GTAMUNI
    ACTSTATUS=STA_TEMP
  Endif
 Endif

End

#========================================================================
#
Subprog GES_PROG_BAR(PMOD,PTITRE,PNBRMAX,PNBRAFF,RERR)
#
# Sous-programme de gestion de la barre de progression
# PMOD -> Qu'est-qu'on fait avec cette barre ?
#  1 - On l'ouvre
#  2 - On rÃĐaffiche avec une nouvelle valeur pour la progression
#  3 - On ferme la boÃŪte
# ------------------------------------------------------------------------------
Value    Integer PMOD       # Action Ã  rÃĐaliser sur la boÃŪte de progression
Value    Char    PTITRE     # Titre de la barre de progression
Value    Integer PNBRMAX    # Nombre maximum - 100% de la barre
Value    Integer PNBRAFF    # Nombre Ã  afficher dans le barre - x % de la barre
Variable Integer RERR       # Code erreur

 Local Integer OK

 Case PMOD
  When 1   #=> Ouverture de la barre de progression
   Call OUVRE_BOITE(PTITRE,PNBRMAX) From GESECRAN
   Call SET_BOITE(PTITRE,PNBRMAX) From GESECRAN
  When 2   #=> RÃĐaffichage de la barre de progression
   Call AFF_BOITE(PTITRE,PNBRAFF,OK) From GESECRAN
  When 3   #=> Fermeture de la barre de progression
   Call FERME_BOITE From GESECRAN
  When Default
 Endcase

End


#========================================================================
#
Funprog IS_MAIN_OBJ(PNUMACT,POBJTYP,POBJREF,POBJLIN)
#
# Cette fonction permet de savoir si l'objet dont les rÃĐfÃĐrence est fournie
# en paramÃĻtre est l'objet principale auquel s'applique l'action ou non
#  0 - On ne trouve pas l'objet dans TML
#  1 - Non : ce n'est pas l'objet principal
#  2 - Oui : c'est l'objet principal
# ------------------------------------------------------------------------------
Value Integer PNUMACT
Value Char    POBJTYP
Value Char    POBJREF
Value Integer POBJLIN

Local Integer RETOUR : RETOUR = G_NON

If !clalev([F:TML]) : Local File TMPMASLCK [TML] : Endif

Case POBJREF
 When "LOF"   : Read [TML]TML1=PNUMACT;POBJREF;POBJLIN : If fstat : RETOUR=0 : Else : RETOUR = [F:TML]OBJMAIN : Endif
 When Default : Read [TML]TML0=PNUMACT;POBJREF         : If fstat : RETOUR=0 : Else : RETOUR = [F:TML]OBJMAIN : Endif
Endcase

End RETOUR

#========================================================================
#
Funprog IS_COMPO_DISPO(PCPY,PAASREF)
#
# Permet de savoir si aucun composant ou complÃĐmentaire n'est lockÃĐ pour
# un bien principal passÃĐ en paramÃĐtre.
# ------------------------------------------------------------------------------
Value Char    PCPY
Value Char    PAASREF
Local Integer RETOUR

Local Char    OBJ    : OBJ="FAS"
Local Char    SEP    : SEP="ÂĪ"
Local Char    SYMLCK

If !clalev([F:WFAS]) : Local File FXDASSETS [WFAS] : Endif
If !clalev([F:WALK]) : Local File APLLCK    [WALK] : Endif

RETOUR=G_OUI

Filter [WFAS] Where CMP=PAASREF
For [WFAS]
 SYMLCK=OBJ+SEP+PCPY+SEP+[WFAS]AASREF
 Read [WALK]LCKCLE=SYMLCK;0
 If !fstat
  RETOUR=G_NON
 Endif
Next
Filter [WFAS]

End RETOUR

#========================================================================
#
Funprog IS_SOC_IMMO(PCPY)
#
# Permet de savoir si la sociÃĐtÃĐ peut ÃŠtre utilisÃĐe pour les immos:
# prÃĐsence d'au moins un contexte paramÃĐtrÃĐ.
# ------------------------------------------------------------------------------
Value Char PCPY
Local Integer LREPONSE
LREPONSE=G_NON

 If !clalev([F:CNX]) : Local File CONTEXT [F:CNX] : Endif
 Filter [F:CNX] Where CPY=PCPY
 If rowcount([F:CNX]) : LREPONSE=G_OUI : Endif
 Filter [F:CNX]

End LREPONSE

#========================================================================
#
Subprog LAUNCH_SILTRT(PACTION,PTRT,RETOUR)
#
# Permet de lancer une action mÃĐtier massive en mode silencieux.
# Par exemple TRTINVRVA (validation des relevÃĐs d'inventaire)
# ------------------------------------------------------------------------------
Value    Char    PACTION    # Traitement dans lequel se trouve les instructions d'alimentation des masques paramÃĻtres
Value    Char    PTRT       # Traitement dans lequel se trouve les instructions d'alimentation des masques paramÃĻtres
Variable Integer RETOUR     # Code retour de la fonction.

Local Char    NOM_FNC                        # Nom de la fonction
Local Integer I_PAR                          # Indice de parcours des paramÃĻtres de la fonction
Local Integer NOMBRE_PAR                     # Nombre de paramÃĻtres
Local Char    VALPAR                         # Valeur de paramÃĻtre

Local Char    SUF_ACTMAS  : SUF_ACTMAS  = "M"    # Suffixe des noms de fonctions massives
Local Char    NOM_PAR_SIL : NOM_PAR_SIL = "ACTSILENCE"
Local Char    NOM_PAR_TRT : NOM_PAR_TRT = "TRTFILMSK"
Local Char    NOM_ACT_TRT : NOM_ACT_TRT = "TRT"+PACTION


If !clalev([F:ACT]) : Local File ACTION    [ACT] : Endif
If !clalev([F:AFC]) : Local File AFONCTION [AFC] : Endif

#> VÃĐrification existence de l'action passÃĐe en paramÃĻtre

Read [ACT]ACTION=PACTION
If fstat=5
 RETOUR=1    # Le code action n'existe pas
 End
Endif

#> Construction du nom de la fonction

NOM_FNC=PACTION+SUF_ACTMAS

#> Lecture de l'enr fonction

Read [AFC]CODINT=NOM_FNC
If fstat=5
 RETOUR=2    # Aucune fonction massive correspondant au code action passÃĐ en paramÃĻtre.
 End
Endif

#> DÃĐclaration variables d'appel de l'action

Local Char PARAM(30)(1..7)
Local Char VALEUR

#> Remplissage variable d'appel

PARAM(1)=GTAMMAS                          # Massif / unitaire
PARAM(2)=PACTION                          # Nom de l'action mÃĐtier
PARAM(3)=num$(evalue([F:AFC]VALPAR(3-1))) # Objet mÃĐtier de rÃĐfÃĐrence
PARAM(4)=num$(evalue([F:AFC]VALPAR(4-1))) # Action mono-sociÃĐtÃĐ ?
PARAM(5)=num$(evalue([F:AFC]VALPAR(5-1))) # Action gÃĐrant les plans d'amortissements ?
PARAM(6)=num$(G_OUI)                      # traitement silencieux
PARAM(7)=PTRT                             # Nom du traitement contenant l'alimentation des masques critÃĻres

#> Appel de l'action
#Call TRAITE_CHAR(VALEUR,PARAM,"","TRTFASTRF","FASTRFM",4,"") From GTRAITE
 Call TRAITE_CHAR(VALEUR,PARAM,"",NOM_ACT_TRT,NOM_FNC,4,"") From GTRAITE

End

#========================================================================
#
Subprog KILL_GLO_SILTRT()
#
# Lorsqu'une action mÃĐtier massive est exÃĐcutÃĐe en mode silencieux elle
# crÃĐe des globales pour stocker des informations de retour exploitÃĐes par
# le traitement appelant. Ce sous-pro permet, dans le programme appelant
# de dÃĐtruire ces globales.
# ------------------------------------------------------------------------------
  If dim(I_OBJ)>0      : Kill I_OBJ      : Endif
  If dim(G_MAJOK)>0    : Kill G_MAJOK    : Endif
  If dim(GT_OBJ_REF)>0 : Kill GT_OBJ_REF : Endif
  If dim(GT_OBJ_DES)>0 : Kill GT_OBJ_DES : Endif
  If dim(GT_LIS_ERR)>0 : Kill GT_LIS_ERR : Endif
End


