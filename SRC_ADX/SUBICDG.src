$CHARGE_GRAPH
Effzo [M:ICD1]10
For [M:ICD1]NBLIG=0 To 4
    [M:ICD1]LBL([M:ICD1]NBLIG) = mess([M:ICD1]NBLIG+1,319,1)
Next

[M:ICD1]CST(0) = [M:ICD1]MATTOT
[M:ICD1]CST(1) = [M:ICD1]MACTOT
[M:ICD1]CST(2) = [M:ICD1]LABTOT
[M:ICD1]CST(3) = [M:ICD1]SCOTOT
[M:ICD1]CST(4) = [M:ICD1]OVETOT

Affzo [M:ICD1]10


Effzo [M:ICD2]10
For [M:ICD2]NBLIG=0 To 4
    [M:ICD2]LBL([M:ICD2]NBLIG) = mess([M:ICD2]NBLIG+1,319,1)
Next

[M:ICD2]CST(0) = [M:ICD2]MATTOTLEV
[M:ICD2]CST(1) = [M:ICD2]MACTOTLEV
[M:ICD2]CST(2) = [M:ICD2]LABTOTLEV
[M:ICD2]CST(3) = [M:ICD2]SCOTOTLEV
[M:ICD2]CST(4) = [M:ICD2]OVETOTLEV

Affzo [M:ICD2]10
Return
