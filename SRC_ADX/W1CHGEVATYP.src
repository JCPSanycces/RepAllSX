#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CHGEVATYP 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:06"
A_USER  = "DOC"
A_STAMP = "20181109230306"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CHGEVATYP [CHG]
Gosub HORODAT
Local Inpbox "CHGEVATYP" From GFONCTION At A_STAMP With A_WINDPREV Mask [CHG] As [SIM_]
Grizo [CHG]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CHG]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=17 : X2(0)=95 : Y1(0)=12 : Y2(0)=17
Return

$ON_REFNUM
Return

$ON_ZREFNUM
Onevent BEFORE_AREA Gosub AV_ZREFNUM From W1CHGEVATYP
Return

$AV_ZREFNUM
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
Call LECTURE("EML",num$([M]REFNUM(indice)),"") From CONTOBJ
zc = [F:ID]NAM
Gosub _AFF
Return

$ON_CTRNUM
Return

$ON_EVADATSTR
Onevent BEFORE_AREA Gosub AV_EVADATSTR From W1CHGEVATYP
Return

$AV_EVADATSTR
Chgfmt [M]EVADATSTR(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_EVADATEND
Onevent BEFORE_AREA Gosub AV_EVADATEND From W1CHGEVATYP
Return

$AV_EVADATEND
Chgfmt [M]EVADATEND(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_EVATYP
Onevent INIT_AREA Call D_EVATYP(zc) From W1CHGEVATYP
Onevent CONTROL Call C_EVATYP(zc) From W1CHGEVATYP
Onevent BEFORE_INPUT Call AS_EVATYP(zc) From W1CHGEVATYP
Onevent AFTER_CHANGE Gosub AMM_EVATYP From W1CHGEVATYP
Return

Subprog D_EVATYP(VALEUR)
Variable Char    VALEUR()
If varinit([M]EVATYP,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10464","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_EVATYP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"10464") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_EVATYP(zc) From W1CHGEVATYP
Onkey   2 Titled GBOUTS Call S_EVATYP(zc) From W1CHGEVATYP
Onkey 144 Titled GBOUTP Call P_EVATYP(zc) From W1CHGEVATYP
Onkey 146 Titled GBOUTA Call SA_EVATYP(zc) From W1CHGEVATYP
Gosub _AFF
End

Subprog C_EVATYP(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"10464","") From SUBADI
If mkstat : GERR = 1 : GZONE = "EVATYP" : GZNUM = 46680 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"10464",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "EVATYP" : GZNUM = 46680 : Endif
 If !mkstat
  ## Action STD
  Call C_EVATYP(VALEUR) From CHGEVATYP
  If mkstat : GERR = 1 : GZONE = "EVATYP" : GZNUM = 46680 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_EVATYP
Call AM_EVATYP(zc)
If !mkstat & GOBJET
 zoncou = "EVATYP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_EVATYP(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZEVATYP)")>indice
 [M]EVATYP(indice) = VALEUR
 Affzo ZEVATYP(indice)
Endif
Gosub _AFF
End

Subprog S_EVATYP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "10464"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_EVATYP(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"10464") From GOBJET
Gosub _AFF
End

Subprog SA_EVATYP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "10464"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_EVATYP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "10464"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZEVATYP
Onevent BEFORE_AREA Gosub AV_ZEVATYP From W1CHGEVATYP
Return

$AV_ZEVATYP
Call LECTEXTRA(zc,"ATABDIV","LNGDES","10464",num$([M]EVATYP(indice))) From ATEXTRA
Gosub _AFF
Return

$CHG_STY
Return


