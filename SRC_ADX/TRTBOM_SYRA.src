#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################
# TRTBOM_SYRA  Traitement pour les nomenclatures en Syracuse
# Sous-pro pour le controle des droits sur les alternatives
# Utilisé dans le projet CCM
# Subprog CTLVISALT
# Subprog CTLMODALT
#######################################################################
# Global Variables replaced for Syracuse
#   GUSER   => CTX.USER
#   GUSRACS => CTX.ALLACS
#######################################################################
# Issue 101318 GA 09/2014
#######################################################################
Subprog CTLMODALT(CTX,LALT,LTYP)
Value Instance CTX Using C_WMACONTEXT : # General context
Value Integer  LALT
Value Integer  LTYP
If LALT <> [F:TBO]BOMALT | LTYP <> [F:TBO]BOMALTTYP
    Read [TBO]TBO0=LTYP;LALT
    #  Alternative de nomenclature inexistante
    If fstat GMESSAGE = mess(154,193,1) : mkstat = 2 : End : Endif
Endif
If CTX.ALLACS=2 End Endif  :# all authorizations !
If [F:TBO]ACSCOD <> "" : # saisie directe de ALTS dans le tableau
   Read [ACC]CODACC = CTX.USER;[F:TBO]ACSCOD
   If !fstat & [F:ACC]MODIF < 2
     #  "Pas d'autorisation de modif sur cette alternative"
     mkstat=2 : GMESSAGE = mess(144,199,1) : End
   Endif
Endif
End

Subprog CTLVISALT(CTX,LALT,LTYP)
Value Instance CTX Using C_WMACONTEXT : # General context
Value Integer  LALT
Value Integer  LTYP
If CTX.ALLACS=2 End Endif  :# all authorizations !
If LALT <> [F:TBO]BOMALT | LTYP <> [F:TBO]BOMALTTYP
    Read [TBO]TBO0=LTYP;LALT
    #  Alternative de nomenclature inexistante
    If fstat GMESSAGE = mess(154,193,1) : mkstat = 2 : End : Endif
Endif
If [F:TBO]ACSCOD <> ""  : # droit de consultation ?
  Call ACCES2([F:TBO]ACSCOD) From OBJDIV
  If mkstat = 2
#  "Pas d'autorisation de consultation sur cette alternative"
     GMESSAGE = mess(296,199,1)
  Endif
Endif
End

