#FRLAA - 2016-12-06 - REQUIREMENT X3-11647 US X3-12771 - START
#Handling all public methods for EPADETAILS_CSTD

$METHODS
Case [L]AMETHOD
  When "BALCONTROL"     Gosub BALCONTROL_CONTROL
Endcase
Return


$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


$BALCONTROL_CONTROL
Local Integer ARETVALUECLASS
Local Integer ARET_VALUE
Gosub BALCONTROL
Return

$BALCONTROL
#Normally we can set ARET_VALUE to a constant but in this case we need to manage different status'
[L]ARET_VALUE = 1
If PMTHINS <> 0 and PBALFLG = 2
  If PVALEUR < PMTHINS : [L]ARET_VALUE = 3 : Endif
Endif

If PVALEUR < 0
  [L]ARET_VALUE = 2
Endif
[L]ARETVALUECLASS = [L]ARET_VALUE
Return


#FRLAA - 2016-12-06 - REQUIREMENT X3-11647 US X3-12771 - END

