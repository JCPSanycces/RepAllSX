#<AdxTL>@(#)1.0.0.0 $Revision$
#<gen>
# LOADBOM : Charge les composants des produits renseignés dans le masque CST
# LOADROU : Charge les opérations des produits renseignés dans le masque CST
# LOADMFG : Charge les enregistrements d'un OF dans CST
# LOADSCO : Charge les enregistrements d'un EO dans CST
# ADDMAT : Ajoute une matière dans le tableau des matières à partir de la classe [F] par défaut
# GETVALSTJ : Cumule les valeurs des mouvements correspondant à la ligne de tableau
# LOADWIP : Charge les enregistrements WIPCOST dans CST
# COEPRO : Sous-programme nécessaire à la résolution du cas suivant:
#     Soit 2 articles produits: I1 et I2.
#     Les quantités à produire sont respectivement Qb1 et Qb2
#     Les quantités produites sont respectivement Qp1 et Qp2
#     Dans [M:CST] on connait Qp1 et Qp2 ainsi que les coef C1=Qp1/Qb1 et C2=Qp2/Qb2
#     Soit une matière M nécessaire aux 2 produits (=> pas de lien)
#     La quantité nécessaire de M est Qbm
#     La quantité nécessaire pour produire I1 (resp. I2) est Qbm*Qb1/(Qb1+Qb2) (resp. Qbm*Qb2/(Qb1+Qb2) )
#     Pour connaitre la quantité Qpm de matière qui a théoriquement été nécessaire à la production de I1 et I2
#     Qpm = Qbm*(Qp1+Qp2)/(Qb1+Qb2)
#     or Qb1=Qp1 / C1
#     --> Qpm =  Qbm * (Qp1+Qp2)/(Qp1/C1 + Qp2/C2)
#     Ce /s-pro renvoie sum(Qpi)/sum(Qpi/Ci)
#</gen>


#+-----------------------------------------------------------------------------------------------------+#
#|+---------------------------------------------------------------------------------------------------+|#
#|| Chaque ligne du tableau Produit a pour distinction: article+n°lien+n° pièce (ITMREF+ILNK+IVCRNUM) ||#
#|| L'utilisation de IVCRNUM permet de calculer les FG / document                                     ||
#|+---------------------------------------------------------------------------------------------------+|#
#+-----------------------------------------------------------------------------------------------------+#


##############################################
# LOADITM : Charge le composé
##############################################
Subprog LOADITM(PRET)
Variable Integer PRET
Raz PRET
Raz GMESSAGE
    [M:CST]NBITM      = 1
    [M:CST]ILNK(0)    = 1
    [M:CST]ITMREF(0)  = [M:CTP]ITMREF
    If dim([M:CST]IECCVALMAJ)>0 & dim([M:CTP]ECCVALMAJ)>0  # Issue By GA 07/2015
      [M:CST]IECCVALMAJ(0) = [M:CTP]ECCVALMAJ
      [M:CST]IECCVALMIN(0) = [M:CTP]ECCVALMIN
    Endif
    [M:CST]ITMTYP(0)  = 1
    [M:CST]IMATFLG(0) = 1
    [M:CST]IQTYSTU(0) = [M:CTP]QTYCLC
    [M:CST]IOVECOL(0) = [M:CTP]SLTOVECOL

    Read [ITM]ITM0=[M:CST]ITMREF(0)
    If [F:ITG]STOFCY<>[M:CST0]STOFCY | [F:ITG]TCLCOD<>[F:ITM]TCLCOD
        Read [ITG]ITG0=[M:CST0]STOFCY;[F:ITM]TCLCOD
        If fstat
            Read [ITG]ITG0="";[F:ITM]TCLCOD
        Endif
    Endif

    # Issue 73570 - 2011-06-08 by CCC : Si pas de nomenclature de production valable, on prend les FG de réception
    #If [F:ITG]MFGFLG=2 & [M:CTP]BOMALTTYP=2#MJH 118205.o
    If [F:ITG]MFGFLG=2 & find([M:CTP]BOMALTTYP,2,3)#MJH 118205.n 2016/10/07
      Filter [BOD] Where ITMREF = [M:CST]ITMREF(0)
&                        & BOMALT = [M:CTP]BOMALT
&                        & BOMALTTYP = [M:CTP]BOMALTTYP
&                        & BOMSTRDAT<=[M:CTP]CLCDAT
&                        & (BOMENDDAT>=[M:CTP]CLCDAT | BOMENDDAT=[0/0/0])
&                        & find(CPNTYP,1,2,3,4,6,7)<>0
      Look [BOD] First
      If !fstat#MJH 118205.sn
        If [M:CTP]BOMALTTYP = 2
          [M:CST]IOVECOD(0) = func STKVAL.GETOVE( [M:CST]ITMREF(0), [M:CST0]STOFCY, 5, PRET )
        Else
          [M:CST]IOVECOD(0) = func STKVAL.GETOVE( [M:CST]ITMREF(0), [M:CST0]STOFCY, 3, PRET )
        Endif
      Else
        Filter [BOD] Where ITMREF = [M:CST]ITMREF(0)
&                        & BOMALT = [M:CTP]BOMALT
&                        & BOMALTTYP = 5-[M:CTP]BOMALTTYP
&                        & BOMSTRDAT<=[M:CTP]CLCDAT
&                        & (BOMENDDAT>=[M:CTP]CLCDAT | BOMENDDAT=[0/0/0])
&                        & find(CPNTYP,1,2,3,4,6,7)<>0
        Look [BOD] First
        If !fstat
          If 5-[M:CTP]BOMALTTYP = 2
            [M:CST]IOVECOD(0) = func STKVAL.GETOVE( [M:CST]ITMREF(0), [M:CST0]STOFCY, 5, PRET )
          Else
            [M:CST]IOVECOD(0) = func STKVAL.GETOVE( [M:CST]ITMREF(0), [M:CST0]STOFCY, 3, PRET )
          Endif
        Else
          [M:CST]IOVECOD(0) = func STKVAL.GETOVE( [M:CST]ITMREF(0), [M:CST0]STOFCY, 3, PRET )
        Endif
      Endif #MJH 118205.en
    Else
      [M:CST]IOVECOD(0) = func STKVAL.GETOVE( [M:CST]ITMREF(0), [M:CST0]STOFCY, 3, PRET )
    Endif

    [M:CST]ICOEPRO(0) = 1
    If [M:CTP]FXDCSTDSP=1
        Read [ITF]=[M:CST]ITMREF(0);[M:CST0]STOFCY
        # calcul du coeff pour répartir les cout fixes au prorata:
        If [F:ITF]REOMINQTY <> 0
             [M:CST]ICOEPRO(0) = [M:CST]IQTYSTU(0) / [F:ITF]REOMINQTY
        Elsif [F:ITF]MFGLOTQTY <> 0
             [M:CST]ICOEPRO(0) = [M:CST]IQTYSTU(0) / [F:ITF]MFGLOTQTY
        Else # Issue 84318 - 2012-09-06 by CCC
#           "Pas de quantité économique pour répartition au prorata"
            Call ECRTRACE([M:CST]ITMREF(0) - mess(133,197,1),0) From TRTCST
        Endif
    Endif
End

##############################################
# LOADBOM : Charge les composants des produits renseignés dans le masque CST
##############################################
# Paramètre S : PRET=code erreur (voir ADDBOD)
##############################################
Subprog LOADBOM(PRET)
Variable Integer PRET
Raz PRET
Raz GMESSAGE

If [M:CTP]BOMALT=0
    End
Endif

Local Integer I
Local Char    LARRQTYCPN
Call PARAM([M:CST0]STOFCY, "ARRQTYCPN", LARRQTYCPN) From ADOVAL

If !clalev([F:BOH]) : Local File BOM        [BOH] : Endif
If !clalev([F:BOD]) : Local File BOMD       [BOD] : Endif
If !clalev([F:TCM]) : Local File TABCOSTMET [TCM] : Endif
If !clalev([F:ITG]) : Local File ITMCATEG   [ITG] : Endif
If !clalev([F:ITM]) : Local File ITMMASTER  [ITM] : Endif
If !clalev([F:ITF]) : Local File ITMFACILIT [ITF] : Endif
If !clalev([F:OVE]) : Local File OVERHEAD   [OVE] : Endif

Effzo [M:CST]20-25
For I=[M:CST]NBITM-1 To 0 Step -1
    If [M:CST]ITMTYP(I)=2
        Dela I,1 [M:CST]NBITM
        [M:CST]NBITM -= 1
    Endif
Next

For I=0 To [M:CST]NBITM-1

    If dim([M:CST]IECCVALMAJ)>0  # Issue By GA 07/2015
      Call FILTER_BOD([M:CST]ITMREF(I),[M:CST]IECCVALMAJ(I),[M:CST]IECCVALMIN(I),[M:CTP]BOMALT,[M:CTP]BOMALTTYP,[M:CTP]CLCDAT,"1,2,3,4,6,7")
    Else
      Call FILTER_BOD([M:CST]ITMREF(I),"","",[M:CTP]BOMALT,[M:CTP]BOMALTTYP,[M:CTP]CLCDAT,"1,2,3,4,6,7")
    Endif

    # Issue 83939 - 2012-08-20 by CCC
    Look [BOD] First
    If fstat
        Call FILTER_BOD([M:CST]ITMREF(I),[M:CST]IECCVALMAJ(I),[M:CST]IECCVALMIN(I),[M:CTP]BOMALT,5-[M:CTP]BOMALTTYP,[M:CTP]CLCDAT,"1,2,3,4,6,7")
    Endif

    If GSTOTRACE=4
        Call ECR_TRACE("ITMREF="+[M:CST]ITMREF(I),0) From GESECRAN
    Endif
    For [BOD]
        Look [ITB]ITB0 = [F:BOD]CPNITMREF;[F:BOD]BOMALT
        If fstat
            PRET=1   #Erreur art-nomenclature désynchro LLC
            GMESSAGE=[F:BOD]CPNITMREF - num$([F:BOD]BOMALT)+":"+ mess(310,197,1)
            Break
        Endif
        If GSTOTRACE=4
            Call ECR_TRACE("  +-- "+[F:BOD]CPNITMREF,0) From GESECRAN
        Endif
        Call ADDBOD(I,val(LARRQTYCPN),PRET)
        If PRET : Break : Endif
    Next
    Filter [BOD]
    If PRET : Break : Endif
Next

If PRET : End : Endif

If [M:CST0]AFFZON=2
    Affzo [M:CST]10-20
Endif
End


##############################################
# ADDBOD : ajoute un composant de nomenclature
##############################################
# Paramètres E : PIND=indice de la ligne du composé dans [M:CST]
#            S : PRET=code erreur (0 = OK)
#                                 (1 = Code activité NMI trop petit)
#                                 (2 = Code activité NMM trop petit)
#                                 (3 = Code activité NMW trop petit)
#   La table BOD est positionnée
#   Les tables BOH, ITM, ITG, TCM, ITF et OVE sont de préférence ouvertes
##############################################
Subprog ADDBOD(PIND,PARRQTYCPN,PRET)
Value Integer PIND
Value Integer PARRQTYCPN
Variable Integer PRET
Raz PRET
Raz GMESSAGE

Local Integer LRET
Local Decimal LQTN, LQTNA, LQTB, LQTBA, LQTY
Local Decimal LPRI
Local Char    LTCM(GLONTCM)

If !clalev([F:BOH]) : Local File BOM        [BOH] : Endif
If !clalev([F:BOD]) : Local File BOMD       [BOD] : Endif
If !clalev([F:TCM]) : Local File TABCOSTMET [TCM] : Endif
If !clalev([F:ITG]) : Local File ITMCATEG   [ITG] : Endif
If !clalev([F:ITM]) : Local File ITMMASTER  [ITM] : Endif
If !clalev([F:ITF]) : Local File ITMFACILIT [ITF] : Endif
If !clalev([F:OVE]) : Local File OVERHEAD   [OVE] : Endif

    If [F:BOH]ITMREF<>[F:BOD]ITMREF | [F:BOH]BOMALT<>[F:BOD]BOMALT | [F:BOH]BOMALTTYP<>[F:BOD]BOMALTTYP
        Read [BOH]BOH0=[F:BOD]ITMREF;[F:BOD]BOMALT;[F:BOD]BOMALTTYP
    Endif
    Read [F:ITM]ITM0 = [F:BOD]CPNITMREF
    # Issue 66756 - 2010-08-17 by CCC : Prise en compte du flag valo du sous-produit
    If [F:BOD]LIKQTY <> 0 & [F:BOD]CSTFLG=2
# Issue 97507 - 2015-09-11 by CCC
#        Call LIKQTY([M:CST]IQTYSTU(PIND),[F:ITM]STU,[F:BOH]BASQTY,[F:BOD]LIKQTYCOD,[F:BOD]LIKQTY,
#&                  [F:BOD]QTYRND,[F:BOD]SCA,LQTN,LQTNA,LQTB,LQTBA) From MFGLIB
        LQTY = [M:CST]IQTYSTU(PIND)
        If [F:BOD]CPNTYP = 7 & [F:BOD]BOMSTUCOE<>0
            LQTY /= [F:BOD]BOMSTUCOE
            Call CONVERT_QTY ([F:BOD]BOMUOM,[F:ITM]STU,LQTY) From TRTX3 # 115910.n - ERMIL - convert from BOMUOM to STU
        Endif
        Call LIKQTY(LQTY,[F:ITM]STU,[F:BOH]BASQTY,[F:BOD]LIKQTYCOD,[F:BOD]LIKQTY,
&                  [F:BOD]QTYRND,[F:BOD]SCA,LQTN,LQTNA,LQTB,LQTBA) From MFGLIB
        If dim(GSCAMAJ)>0 & GSCAMAJ = 1 # Issue 88918
            # Issue 72571 - 2011-05-10 by CCC : Ajout paramètre ARRQTYCPN
            If LQTNA <> 0 & PARRQTYCPN=2
                LQTY = LQTNA
            Else
                LQTY = LQTN
            Endif
        Else
            If LQTBA <> 0 & PARRQTYCPN=2
                LQTY = LQTBA
            Else
                LQTY = LQTB
            Endif
        Endif
    Else
        LQTY = 0
    Endif

# Les coûts sont pour des quantités actives
    If LQTY<>0
        # Issue 68448 - 2010-10-22 by CCC : Les coûts sont pour des quantités actives
        #If [F:ITM]STOMGTCOD=3 & [F:ITM]DEFPOT<>0
        #    LQTY = LQTY / ([F:ITM]DEFPOT / 100)
        #Endif

        Call GETTCM([F:BOD]CPNITMREF, [M:CST0]STOFCY, LTCM, LRET) From STKVAL
        If [F:BOD]CPNTYP = 4
            If dim([M:CST]ITMREF)<=[M:CST]NBITM
                PRET = 1
                GMESSAGE=mess(561,199,1)
                End
            Endif
            [M:CST]ITMREF([M:CST]NBITM)  = [F:BOD]CPNITMREF
            If dim([M:CST]MECCVALMAJ)>0
                [M:CST]IECCVALMAJ([M:CST]NBITM) = [F:BOD]ECCVALMAJ
                [M:CST]IECCVALMIN([M:CST]NBITM) = [F:BOD]ECCVALMIN
            Endif
            [M:CST]ISTU([M:CST]NBITM)    = [F:ITM]STU   # Issue 80525 - 2012-08-20 by CCC
            [M:CST]ITMTYP([M:CST]NBITM)  = 2
            [M:CST]IMATFLG([M:CST]NBITM) = 1+func SUBCSTB.ISMAT([M:CST]ITMREF([M:CST]NBITM), [M:CTP]BOMALTTYP, [M:CTP]BOMALT, [M:CTP]CLCDAT)
            [M:CST]IQTYSTU([M:CST]NBITM) = LQTY*(([F:BOD]LIKQTYCOD=1)+([F:BOD]LIKQTYCOD=2)*[M:CST]ICOEPRO(PIND))
            [M:CST]IQTYCOD([M:CST]NBITM) = [F:BOD]LIKQTYCOD
            [M:CST]IBRDCOD([M:CST]NBITM) = [F:ITM]BRDCOD
            [M:CST]ICSTCOD([M:CST]NBITM) = [F:TCM]ISSVLTCOD+1 # CCC (2010-05-03) Bug 64444 : Le menu local est le 705 pas le 480 comme les matières
            [M:CST]ILNK([M:CST]NBITM)    = [M:CST]ILNK(PIND)
            [M:CST]IOVECOD([M:CST]NBITM) = func STKVAL.GETOVE( [M:CST]ITMREF([M:CST]NBITM), [M:CST0]STOFCY, 5, LRET ) # FG entrée OF
            [M:CST]IOVECOL([M:CST]NBITM) = [M:CTP]SLTOVECOL
            [M:CST]NBITM += 1
        Elsif [F:BOD]CPNTYP = 7
            If dim([M:CST]SLNK)<=[M:CST]NBSCO
                PRET = 3
                GMESSAGE=mess(563,199,1)
                End
            Endif
            [M:CST]SLNK([M:CST]NBSCO)    = [M:CST]ILNK(PIND)
            [M:CST]SCOWST([M:CST]NBSCO)  = ""
            [M:CST]SOVECOD([M:CST]NBSCO) = ""
            [M:CST]SOVECOL([M:CST]NBSCO) = [M:CTP]SLTOVECOL
            [M:CST]SSETTIM([M:CST]NBSCO) = 0
            [M:CST]SOPETIM([M:CST]NBSCO) = 0
            [M:CST]SCOITMREF([M:CST]NBSCO) = [F:BOD]CPNITMREF
            [M:CST]SUOMSCOITM([M:CST]NBSCO) = [F:ITM]STU
            [M:CST]SQTYSCOITM([M:CST]NBSCO) = LQTY
            If [M:CST]SCOITMREF([M:CST]NBSCO) <> ""
                Raz [F:ITF]
                Read [ITF]ITF0=[M:CST]SCOITMREF([M:CST]NBSCO);[M:CST0]STOFCY
                [M:CST]SIOVECOD([M:CST]NBSCO) = func STKVAL.GETOVE( [M:CST]SCOITMREF([M:CST]NBSCO), [M:CST0]STOFCY, 3, LRET )    # Réception fournisseur
                [M:CST]SIOVECOL([M:CST]NBSCO) = [M:CTP]SLTOVECOL
                Call GETTCM([M:CST]SCOITMREF([M:CST]NBSCO), [M:CST0]STOFCY, LTCM, LRET) From STKVAL
                If LRET=2
                    GMESSAGE = [F:ROO]SCOITMREF+"/"+[M:CST0]STOFCY - mess(139,197,1)
                    PRET=1
                Endif
                # Issue 94776 - 2013-12-06 by CCC : Priorité à la valo de stock, sinon c'est le tarif
                If LRET=3
                    [M:CST]SCOEQTY([M:CST]NBSCO) = LQTY/[M:CST]IQTYSTU(PIND)
                    If [F:ITM]ITMREF<>[M:CST]SCOITMREF([M:CST]NBSCO)
                        Read [ITM]ITM0=[M:CST]SCOITMREF([M:CST]NBSCO)
                    Endif
                    [M:CST]PRISCO([M:CST]NBSCO) = func RECHTARIF2([M:CST]SCOITMREF([M:CST]NBSCO),"","",[M:CST0]STOFCY,LQTY,[M:CST]SLNK([M:CST]NBSCO),[M:CTP]CLCDAT)
                    Call GETDEV([M:CST0]STOFCY) From DEVSUB    # Remettre GLOCALDEV du site
                    # Issue 76496 - 2011-10-04 by CCC : Le prix doit rester par UO. Il est converti au moment du calcul car on ne le connais peut-être pas encore
                    ## ... puis du prix, ramené à la qté de l'article sous-traité
                    #[M:CST]PRISCO([M:CST]NBSCO) *= [M:CST]SCOEQTY([M:CST]NBSCO)
                    #If [M:CST]PRISCO([M:CST]NBSCO)>0
                    [M:CST]SCSTCOD([M:CST]NBSCO) = 7    # Prix ordre
                Else
                    [M:CST]SCSTCOD([M:CST]NBSCO) = [F:TCM]ISSVLTCOD#+1  # Issue 89622 - 2013-06-05 by CCC
                Endif
            Endif
            [M:CST]NBSCO += 1
        Else
            If dim([M:CST]MATREF)<=[M:CST]NBMAT
                PRET = 2
                GMESSAGE=mess(562,199,1)
                End
            Endif
            [M:CST]MATREF([M:CST]NBMAT)  = [F:BOD]CPNITMREF
            If dim([M:CST]MECCVALMAJ)>0
                [M:CST]MECCVALMAJ([M:CST]NBMAT) = [F:BOD]ECCVALMAJ
                [M:CST]MECCVALMIN([M:CST]NBMAT) = [F:BOD]ECCVALMIN
            Endif

            [M:CST]MSTU([M:CST]NBMAT)    = [F:ITM]STU      # Issue 80525 - 2012-08-20 by CCC
            [M:CST]SCOFLG([M:CST]NBMAT)  = max(1,[F:BOD]SCOFLG)
            [M:CST]MATFLG([M:CST]NBMAT)  = 1+func SUBCSTB.ISMAT([M:CST]MATREF([M:CST]NBMAT), [M:CTP]BOMALTTYP, [M:CTP]BOMALT, [M:CTP]CLCDAT)
            [M:CST]MQTYSTU([M:CST]NBMAT) = LQTY*(([F:BOD]LIKQTYCOD=1)+([F:BOD]LIKQTYCOD=2)*[M:CST]ICOEPRO(PIND))
            [M:CST]MQTYCOD([M:CST]NBMAT) = [F:BOD]LIKQTYCOD
            [M:CST]MBRDCOD([M:CST]NBMAT) = [F:ITM]BRDCOD
            [M:CST]MCSTCOD([M:CST]NBMAT) = [F:TCM]ISSVLTCOD
            If [M:CST]SCOFLG([M:CST]NBMAT)=3  # Si matière fournie par /s-traitant => recherche tarif
                If [F:ITM]ITMREF<>[M:CST]MATREF([M:CST]NBMAT)
                    Read [ITM]ITM0=[M:CST]MATREF([M:CST]NBMAT)
                Endif
                LPRI = func RECHTARIF2([M:CST]MATREF([M:CST]NBMAT),[M:CST]MECCVALMAJ([M:CST]NBMAT),[M:CST]MECCVALMIN([M:CST]NBMAT),[M:CST0]STOFCY,
&                                      [M:CST]MQTYSTU([M:CST]NBMAT)*[F:ITM]PUUSTUCOE,[M:CST]MLNK([M:CST]NBMAT),[M:CTP]CLCDAT)
                [M:CST]MMATCST([M:CST]NBMAT*GACTMAT+[M:CST]MBRDCOD([M:CST]NBMAT)) = LPRI*[M:CST]MQTYSTU([M:CST]NBMAT)
                [M:CST]MCSTCOD([M:CST]NBMAT) = 7
            Endif
            [M:CST]MLNK([M:CST]NBMAT)    = [M:CST]ILNK(PIND)
            # Issue 114047 - 2016-03-04 by CCC : Consider new subcontracting issues overhead setup
            If [M:CTP]BOMALTTYP=3
                [M:CST]MOVECOD([M:CST]NBMAT) = func STKVAL.GETOVE( [M:CST]MATREF([M:CST]NBMAT), [M:CST0]STOFCY, 29, LRET ) # Subcontrating issue
            Else
                [M:CST]MOVECOD([M:CST]NBMAT) = func STKVAL.GETOVE( [M:CST]MATREF([M:CST]NBMAT), [M:CST0]STOFCY, 6, LRET ) # WO issue
            Endif
            [M:CST]MOVECOL([M:CST]NBMAT) = [M:CTP]SLTOVECOL
            [M:CST]NBMAT += 1
        Endif
    Endif
End


##############################################
# LOADROU : Charge les opérations des produits renseignés dans le masque CST
##############################################
# Paramètre S : PRET=code erreur (0 = OK)
#                                (1 = Erreur sur méthode de valorisation)
#                                (2 = Code activité NMM trop petit)
#                                (3 = Code activité NMW trop petit)
##############################################
Subprog LOADROU(PRET)
Variable Integer PRET
Raz PRET
Raz GMESSAGE

# Issue 89664 - 2014-09-12 by CCC : if ROUALT=0 => it will be initialized by GETROUALT
##If [M:CTP]BOMALT=0 | GMODU(8)<> 2 : # [M:CTP]BOMALT=0 # GH 29/10/12 bug 85429
#If [M:CTP]ROUALT=0 | GMODU(8)<> 2
If GMODU(8)<> 2
    End
Endif

Effzo [M:CST]30-40

Local Integer I
Local Char    LWSTO(GLONWST)
Local Decimal WOPESTUCOE
Local Decimal LOPETIM, LSETTIM
Local Char    ITM_ROU(GLONITM)
Local Integer ROU_ALT

If !clalev([F:ROH]) : Local File ROUTING    [ROH] : Endif
If !clalev([F:ROO]) : Local File ROUOPE     [ROO] : Endif
If !clalev([F:MWS]) : Local File WORKSTATIO [MWS] : Endif
If !clalev([F:MWSM]): Local File WORKSTATIO [MWSM]: Endif
If !clalev([F:MWC]) : Local File WORKCOST   [MWC] : Endif
If !clalev([F:TCM]) : Local File TABCOSTMET [TCM] : Endif

For I=0 To [M:CST]NBITM-1

    If [M:CST]ITMTYP(I)<>2

# Issue 89664 - 2014-09-12 by CCC
#        Read [F:ITF]ITF0 = [M:CST]ITMREF(I);[M:CST0]STOFCY
#        If [F:ITF]CSTROU <> ""
#            ITM_ROU = [F:ITF]CSTROU
#        Else
#            ITM_ROU =[M:CST]ITMREF(I)
#        Endif
        Call GETROUALT([M:CTP]ITMREF,[M:CST0]STOFCY,[M:CTP]BOMALT,[M:CTP]ROUALT,ITM_ROU,ROU_ALT)

        Read [ROH]ROH0=ITM_ROU;ROU_ALT;[M:CST0]STOFCY : # Beryl Site en fin de clé primaire

        If fstat
            Raz [F:ROH]
            If GTRACE<>""
                Call ECRTRACE(mess(63,198,1) - mess(23,100,1) - ITM_ROU - num$([M:CTP]ROUALT),0) From TRTCST
            Endif
        Elsif [F:ROH]ROUSTRDAT > [M:CTP]CLCDAT
&           | ([F:ROH]ROUENDDAT <> [0/0/0] & [F:ROH]ROUENDDAT < [M:CTP]CLCDAT)
            Raz [F:ROH]
            If GTRACE<>""
                Call ECRTRACE(mess(8,193,1)- ITM_ROU - num$([M:CTP]ROUALT),0) From TRTCST
            Endif
        Endif

        For [ROO] Where FCY = [F:ROH]FCY & ITMREF = [F:ROH]ITMREF & ROUALT = [F:ROH]ROUALT
&                     & VALSTRDAT <= [M:CTP]CLCDAT
&                     & ((VALENDDAT >= [M:CTP]CLCDAT & VALENDDAT <> [0/0/0]) | VALENDDAT = [0/0/0])

            If [F:ROO]OPESTUFOR <> ""
               Read [F:TFO]TFO0=2;[F:ROO]OPESTUFOR
               If !fstat
                   # se repositionner éventuellement sur l'article produit
                   If [F:ITM]ITMREF <> [F:ROO]ITMREF
                       Read [F:ITM]ITM0 = [F:ROO]ITMREF
                       If fstat : Raz [F:ITM] : Endif
                   Endif
                   If [F:ITF]ITMREF <> [F:ROO]ITMREF | [F:ITF]STOFCY <> [F:ROO]FCY
                       Read [F:ITF]ITF0 = [F:ROO]ITMREF;[F:ROO]FCY
                       If fstat : Raz [F:ITF] : Endif
                   Endif
                   If evalue([F:TFO]FORFOR) <> 0
                       WOPESTUCOE = evalue([F:TFO]FORFOR)
                   Elsif [F:ROO]OPESTUCOE <> 0
                       WOPESTUCOE  = [F:ROO]OPESTUCOE
                   Else
                        WOPESTUCOE  = 1
                   Endif
               Else
                WOPESTUCOE  = [F:ROO]OPESTUCOE
               Endif
            Else
                WOPESTUCOE  = [F:ROO]OPESTUCOE
            Endif
            Raz LWSTO
            Read [MWS]WST0 = [F:ROO]WST;[F:ROO]FCY
            If [F:ROO]SCOWST <> "" & [F:ROO]SCOCOD = 2 : # sous-traitance structurelle
                Read [MWS]WST0 = [F:ROO]SCOWST;[F:ROO]FCY
            Endif
            Gosub ADDWST
            If PRET
                Break 2
            Endif
            If [F:ROO]LABWST <> ""
                LWSTO = [F:MWS]WST
                Read [MWS]WST0 = [F:ROO]LABWST;[F:ROO]FCY
                Gosub ADDWST
                If PRET
                    Break 2
                Endif
                Raz LWSTO
            Endif

            GPOINT = "APADDWST"
            Gosub ENTREE From EXEFNC

        Next
    Endif
Next

If PRET
    End
Endif

If [M:CST0]AFFZON=2
    Affzo [M:CST]30-40
Endif

End

#################################################
$ADDWST
If dim(LTCM)<=0 : Local Char    LTCM(GLONTCM) : Endif
If dim(LRET)<=0 : Local Integer LRET          : Endif

    Raz LSETTIM, LOPETIM

    If [F:MWS]VLTCCE<>""
        Read [MWC]WCT0 = [F:MWS]VLTCCE;[F:MWS]WCRFCY : # lecture de la section de valorisation
    Else
        Raz [F:MWC]
        If [F:MWS]VLTCCE = ""
            Call ECRTRACE(mess(153,197,1) - [F:MWS]WST - [F:MWS]WCRFCY,0) From TRTCST : # pas de section de valorisation pour ce poste !
        Endif
        [F:MWC]BRDCOD = 1
        [F:MWC]CSTTYP = 1
#        Return    # Il ne faut pas ajouter cette opé (famille de coût indéterminée) ??
    Endif

    #If the efficiency is 0 then we end up dividing by 0, this should not be allowed
    #MJH 106734.sn 14/12/2016
    If [F:ROO]EFF = 0
      GMESSAGE = func AFNC.MES1(mess(891,197,1), mess(63,198,1))
      PRET = 1 : Return
    Endif
    If [F:MWS]EFF = 0
      GMESSAGE = func AFNC.MES1(mess(891,197,1), mess(570,197,1))
      PRET = 1 : Return
    Endif#MJH 106734.en 14/12/2016

    #------------ Temps de réglage ------------------#
    If GOPEEFFAPP = 2
        LSETTIM = [F:ROO]SETTIM
    Else
        Case GEFFCSTUSE
            When 1:    LSETTIM = [F:ROO]SETTIM  # pas de prise en compte efficience
            When 2:    Case GWSTEFFINH        # v130 - héritage efficience (LLC)
                           When 1:            # efficience Poste + opération
                               LSETTIM = [F:ROO]SETTIM / ([F:ROO]EFF/100)/ ([F:MWS]EFF/100)
                               # Issue 94895 - 2014-11-21 by CCC : take into account efficiency of main wst
                               If LWSTO<>""    # poste secondaire
                                   If [F:MWSM]WST<>[F:ROO]WST | [F:MWSM]WCRFCY<>[F:ROO]FCY
                                       Read [MWSM]WST0=[F:ROO]WST;[F:ROO]FCY
                                   Endif
                                   LSETTIM /=  ([F:MWSM]EFF/100)
                               Endif
                           When Default:      # efficience opération
                               LSETTIM = [F:ROO]SETTIM / ([F:ROO]EFF/100)
                        Endcase
        Endcase
    Endif

    If [F:ROH]TIMUOMCOD=2     # temps défini en minutes
        LSETTIM=LSETTIM/60
    Endif
    If LWSTO<>""    # poste secondaire
        LSETTIM = LSETTIM * [F:ROO]SETLABCOE
    Endif
    If [F:MWC]CSTTYP = 2 : # type de taux forfaitaire
        If [F:ROO]SETTIM > 0
            LSETTIM = 1
          Else
            LSETTIM = 0
        Endif
    Endif
    If [M:CTP]FXDCSTDSP = 1 : # répartition des fixes au prorata
        LSETTIM *= [M:CST]ICOEPRO(I)
    Endif

    #------------ Temps opératoire ------------------#
    QT_OPE = func TRTCST.SUMQTY("P",[M:CST]WLNK(I)) * WOPESTUCOE
    If [F:ROO]SHR <> 0
       QT_OPE = QT_OPE * (1 + ([F:ROO]SHR / 100))
    Endif

    If [F:ROO]ROOTIMCOD = 3            : # forfaitaire
        LOPETIM = [F:ROO]OPETIM
    Elsif [F:ROO]ROOTIMCOD = 2         : # cadence
      If [F:ROO]CAD > 0                  # correction bug 17344 (14/02/03)
        LOPETIM = QT_OPE / [F:ROO]CAD
      Endif
    Elsif [F:ROO]ROOTIMCOD = 1         : # proportionnel
        LOPETIM = [F:ROO]OPETIM * QT_OPE / [F:ROO]BASQTY
    Endif

    Case GEFFCSTUSE
        When 1:    # ben rien
        When 2:    Case GWSTEFFINH     # v130 - héritage efficience (LLC)
                       When 1:         LOPETIM = LOPETIM / ([F:ROO]EFF/100)/ ([F:MWS]EFF/100)
                                       # Issue 94895 - 2014-11-21 by CCC : take into account efficiency of main wst
                                       If LWSTO<>""    # poste secondaire
                                           If [F:MWSM]WST<>[F:ROO]WST | [F:MWSM]WCRFCY<>[F:ROO]FCY
                                               Read [MWSM]WST0=[F:ROO]WST;[F:ROO]FCY
                                           Endif
                                           LOPETIM /=  ([F:MWSM]EFF/100)
                                       Endif
                       When Default:   LOPETIM = LOPETIM / ([F:ROO]EFF/100)
                   Endcase
    Endcase

    If [F:ROH]TIMUOMCOD=2    # temps défini en minutes
        LOPETIM = LOPETIM/60
    Endif
    If LWSTO<>""    # poste secondaire
        LOPETIM = LOPETIM * [F:ROO]OPELABCOE
    Endif
    If [F:MWC]CSTTYP = 2 : # type de taux forfaitaire
        If ([F:ROO]OPETIM>0 | [F:ROO]CAD>0)
            LOPETIM = 1
        Else
            LOPETIM = 0
        Endif
    Endif

    # Issue 92867 - 2013-11-07 by CCC
    If [M:CTP]FXDCSTDSP = 1 & ([F:MWC]CSTTYP = 2  | [F:ROO]ROOTIMCOD = 3) : # répartition des fixes au prorata
        LOPETIM *= [M:CST]ICOEPRO(I)
    Endif

    Case [F:MWS]WSTTYP
        When 1,2 :
            If dim([M:CST]WLNK)<=[M:CST]NBWST
                PRET = 2
                GMESSAGE=mess(562,199,1)
                Return
            Endif
            [M:CST]WLNK([M:CST]NBWST)   = [M:CST]ILNK(I)
            [M:CST]WST([M:CST]NBWST)    = [F:MWS]WST
            [M:CST]WSTTYP([M:CST]NBWST) = [F:MWS]WSTTYP
            [M:CST]WCSTTYP([M:CST]NBWST) = max(1,[F:MWC]CSTTYP)
            [M:CST]WBRDCOD([M:CST]NBWST) = max(1,[F:MWC]BRDCOD)
            [M:CST]WOVECOD([M:CST]NBWST) = [F:MWC]OVECOD
            [M:CST]WSETTIM([M:CST]NBWST) = LSETTIM
            [M:CST]WOPETIM([M:CST]NBWST) = LOPETIM
            [M:CST]WOVECOL([M:CST]NBWST) = [M:CTP]SLTOVECOL
            [M:CST]NBWST += 1
        When 3 :
            If dim([M:CST]SLNK)<=[M:CST]NBSCO
                GMESSAGE=mess(563,199,1)
                PRET = 3
                Return
            Endif
            [M:CST]SLNK([M:CST]NBSCO)    = [M:CST]ILNK(I)
            [M:CST]SCOWST([M:CST]NBSCO)  = [F:ROO]WST
            [M:CST]SOVECOD([M:CST]NBSCO) = [F:MWC]OVECOD
            [M:CST]SOVECOL([M:CST]NBSCO) = [M:CTP]SLTOVECOL
            [M:CST]SSETTIM([M:CST]NBSCO) = LSETTIM
            [M:CST]SOPETIM([M:CST]NBSCO) = LOPETIM
            [M:CST]SCOITMREF([M:CST]NBSCO) = [F:ROO]SCOITMREF
            [M:CST]SQTYSCOITM([M:CST]NBSCO) = QT_OPE
            If [F:ROO]SCOITMREF <> ""
                [M:CST]SUOMSCOITM([M:CST]NBSCO) = [F:ROO]OPEUOM
                [M:CST]SCOEQTY([M:CST]NBSCO) = WOPESTUCOE
                Raz [F:ITF]
                Read [ITF]ITF0=[F:ROO]SCOITMREF;[M:CST0]STOFCY
                # Issue (94776) - 2013-12-06 by CCC : C'est le code FG des réceptions qui doit être récupéré
                #[M:CST]SIOVECOD([M:CST]NBSCO) = [F:ITF]OVECOD
                [M:CST]SIOVECOD([M:CST]NBSCO) = func STKVAL.GETOVE( [M:CST]SCOITMREF([M:CST]NBSCO), [M:CST0]STOFCY, 3, LRET )    # RÃ©ception fournisseur
                [M:CST]SIOVECOL([M:CST]NBSCO) = [M:CTP]SLTOVECOL
                Call GETTCM([F:ROO]SCOITMREF, [M:CST0]STOFCY, LTCM, LRET) From STKVAL
                If LRET=2
                    GMESSAGE = [F:ROO]SCOITMREF+"/"+[M:CST0]STOFCY - mess(139,197,1)
                    PRET=1
                Endif
                If [F:ROO]REFPRI > 0
                    [M:CST]PRISCO([M:CST]NBSCO)  = [F:ROO]REFPRI # prix par unité d'opération
                    [M:CST]SCSTCOD([M:CST]NBSCO) = 7    # Prix ordre
                Elsif LRET=3  # Si pas de méthode de valo, on tente une recherche tarif
                    If [F:ITM]ITMREF<>[F:ROO]SCOITMREF
                        Read [ITM]ITM0=[F:ROO]SCOITMREF
                    Endif
                    LPRI = func RECHTARIF2([F:ROO]SCOITMREF,"","",[M:CST0]STOFCY,[M:CST]SQTYSCOITM([M:CST]NBSCO)*[F:ITM]PUUSTUCOE,[M:CST]SLNK([M:CST]NBSCO),[M:CTP]CLCDAT)
                    [M:CST]PRISCO([M:CST]NBSCO) = LPRI
                    [M:CST]SCSTCOD([M:CST]NBSCO) = 7    # Prix ordre
                Else
                    [M:CST]SCSTCOD([M:CST]NBSCO) = [F:TCM]ISSVLTCOD#+1  # Issue 89622 - 2013-06-05 by CCC
                Endif
            Endif
            [M:CST]NBSCO += 1
    Endcase
Return

##############################################
# Charge les enregistrements d'un OF dans CST
##############################################
# Paramètres E : PTYP = 1:produits 2:matière  3:postes
#            S : PRET=code erreur (0 = OK)
#                                 (1 = Code activité NMI trop petit)
#                                 (2 = Code activité NMM trop petit)
#                                 (3 = Code activité NMW trop petit)
##############################################
Subprog LOADMFG(PTYP,PRET)
Value Integer PTYP
Variable Integer PRET
Call LOADMFG2(PTYP,"1=1",PRET)
End

Subprog LOADMFG2(PTYP,PFILTRE,PRET)
Value Integer PTYP
Value Char    PFILTRE
Variable Integer PRET

Raz PRET
Raz GMESSAGE
If GMODU(8)<> 2 : End : Endif : # GH 29/10/12 bug 85429 par sécurité

If !clalev([F:ITB]) : Local File ITMBOM     [ITB] : Endif
If !clalev([F:MWS]) : Local File WORKSTATIO [MWS] : Endif
If !clalev([F:MWC]) : Local File WORKCOST   [MWC] : Endif
If !clalev([F:MFI]) : Local File MFGITM     [MFI] : Endif
If !clalev([F:MFM]) : Local File MFGMAT     [MFM] : Endif
If !clalev([F:MFO]) : Local File MFGOPE     [MFO] : Endif
If !clalev([F:MKM]) : Local File MFGMATTRK  [MKM] : Endif
If !clalev([F:MKO]) : Local File MFGOPETRK  [MKO] : Endif
If !clalev([F:TCM]) : Local File TABCOSTMET [TCM] : Endif
If !clalev([F:STJ]) : Local File STOJOU     [STJ] : Endif
If !clalev([F:BOH]) : Local File BOM        [BOH] : Endif
If !clalev([F:BOD]) : Local File BOMD       [BOD] : Endif
If !clalev([F:ITG]) : Local File ITMCATEG   [ITG] : Endif
If !clalev([F:ITM]) : Local File ITMMASTER  [ITM] : Endif
If !clalev([F:ITF]) : Local File ITMFACILIT [ITF] : Endif
If !clalev([F:OVE]) : Local File OVERHEAD   [OVE] : Endif

If GACTDECCST
    If !clalev([F:SJV]) : Local File STOJOUVAL  [SJV] : Endif
Endif

Local Char    LPFX(3)
Local Integer LTYP, LRET, I
Local Decimal LOPETIM, LSETTIM
Local Char    LWSTO(GLONWST)
Local Mask    SAIDECPRI [SDP]     # Pour GETVALSTJ
Local Char    LTCM(GLONTCM)
Local Char    LFILTRE(250)
Local Char    LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)

LTYP=PTYP
LFILTRE = PFILTRE
If LFILTRE=""
    LFILTRE="1=1"
Endif

# CCC (2009-09-24) Bug 58073 : Charger les paramètres en fonction du site
Local Char PARAM(250)
Call PARAM([M:CST0]STOFCY,"VLTMATEXT",PARAM) From ADOVAL
GVLTMATEXT = val(PARAM)
Call PARAM([M:CST0]STOFCY,"VLTSEMEXT",PARAM) From ADOVAL
GVLTSEMEXT = val(PARAM)

Local Char    LARRQTYCPN
Call PARAM([M:CST0]STOFCY, "ARRQTYCPN", LARRQTYCPN) From ADOVAL

Case LTYP
    When 1: #------------- PRODUITS et /s-PRODUITS ------------#
        # Issue 108611 - 2015-12-21 by BEEBE : Improve the selection, filter should be used seperate in the loop,
        #                                      a big number of values would cause a syntaxerror (too many parameters)
        Filter [MFI] Where MFGNUM=[M:CTP]VCRNUM
&                        & (ITMTYP=1 | CSTFLG=2)    # Issue 89815 - 2013-05-14 by CCC
        For [MFI]
            If evalue(LFILTRE)
                If dim([M:CST]ITMREF)<=[M:CST]NBITM
                    PRET = 1
                    GMESSAGE=mess(561,199,1)
                    #MAE, bg 70563
                    #End
                    Break
                Endif
                If [F:ITF]ITMREF<>[F:MFI]ITMREF | [F:ITF]STOFCY<>[M:CST0]STOFCY
                    Read [ITF]ITF0=[F:MFI]ITMREF;[M:CST0]STOFCY
                Endif
                If [F:ITM]ITMREF<>[F:MFI]ITMREF
                    Read [ITM]ITM0=[F:MFI]ITMREF
                Endif
                [M:CST]ITMREF([M:CST]NBITM) = [F:MFI]ITMREF
                If dim([M:CST]IECCVALMAJ)>0 # Issue GA 07/2015
                  [M:CST]IECCVALMAJ([M:CST]NBITM) = [F:MFI]ECCVALMAJ
                  [M:CST]IECCVALMIN([M:CST]NBITM) = [F:MFI]ECCVALMIN
                Endif
                [M:CST]ITMTYP([M:CST]NBITM) = [F:MFI]ITMTYP
                If [F:MFI]ITMTYP = 2
                    [M:CST]ILNK([M:CST]NBITM)   = [F:MFI]ITMLIN
                    [M:CST]IMATFLG([M:CST]NBITM)  = 1+func SUBCSTB.ISMAT([M:CST]ITMREF([M:CST]NBITM), 2, [F:MFI]BOMALT, [M:CTP]CLCDAT)
                Else
                    [M:CST]ILNK([M:CST]NBITM)   = [F:MFI]MFGLIN
                    [M:CST]IMATFLG([M:CST]NBITM)  = 1
                Endif
                [M:CST]ICOEPRO([M:CST]NBITM) = 1
                Case [M:CTP]QTYITMTYP
                    When 1 :    # Ce choix ne devrait pas être possible car STDQTY n'existe pas
                        [M:CST]IQTYSTU([M:CST]NBITM)= [F:MFI]EXTQTY
                    When 2 :
                        [M:CST]IQTYSTU([M:CST]NBITM)= [F:MFI]EXTQTY
                    When 3 :
                        [M:CST]IQTYSTU([M:CST]NBITM)= [F:MFI]CPLQTY-[F:MFI]REJCPLQTY
                        If [M:CTP]PROCPLEXT=2
                            [M:CST]ICOEPRO([M:CST]NBITM) = [M:CST]IQTYSTU([M:CST]NBITM)/[F:MFI]EXTQTY
                        Endif
                Endcase
                [M:CST]ISTU([M:CST]NBITM)   = [F:MFI]STU
                [M:CST]IOVECOD([M:CST]NBITM) = func STKVAL.GETOVE( [M:CST]ITMREF([M:CST]NBITM), [M:CST0]STOFCY, 5, LRET ) # FG entrée OF
                [M:CST]IOVECOL([M:CST]NBITM) = [M:CTP]SLTOVECOL
                [M:CST]IBRDCOD([M:CST]NBITM) = [F:ITM]BRDCOD
                If [F:MFI]ITMTYP=2
                    Read [ITB]ITB0 = [F:MFI]ITMREF;[F:MFI]BOMALT;2
                    If fstat | [F:ITB]BOMEXIFLG < 2
                        [M:CST]ICSTCOD([M:CST]NBITM) = (GVLTMATEXT+([M:CTP]CSTMATTYP=3)*(7-GVLTMATEXT))+1
                    Else
                        [M:CST]ICSTCOD([M:CST]NBITM) = (GVLTSEMEXT+([M:CTP]CSTMATTYP=3)*(7-GVLTSEMEXT))+1
                    Endif
                Else
                    [M:CST]ICSTCOD([M:CST]NBITM) = 0
                Endif
                If [M:CST]ICSTCOD([M:CST]NBITM)=7    # Valeur saisie --> il faut récupérer dans STJ
                    Call GETVALSTJ("I",1,[M:CST]NBITM)
                Endif
                [M:CST]NBITM += 1

                #----- Composants uniquement valorisés ----#
                If [M:CST]ITMTYP(I)<>2
                    If dim([M:CST]IECCVALMAJ)>0 # Issue GA 07/2015
                      Call FILTER_BOD([M:CST]ITMREF(I),[M:CST]IECCVALMAJ(I),[M:CST]IECCVALMIN(I),[F:MFI]BOMALT,2,[M:CTP]CLCDAT,"6")
                    Else
                      Call FILTER_BOD([M:CST]ITMREF(I),"","",[F:MFI]BOMALT,2,[M:CTP]CLCDAT,"6")
                    Endif
                    For [BOD]
                        Call ADDBOD(I,val(LARRQTYCPN),PRET)
                        If PRET
                            Break
                        Endif
                    Next
                    Filter [BOD]
                Endif
                If PRET
                    Break
                Endif
            Endif
        Next
        Filter [MFI]

        If PRET
            End
        Endif

        # On attend que toutes les lignes de produit soient créées pour calculer la quantité de sous-produit
        For I=0 To [M:CST]NBITM-1
            If [M:CST]ITMTYP(I)=2
                [M:CST]IQTYSTU(I) *= func COEPRO([M:CST]ILNK(I))
            Endif
        Next
    When 2: #------------- MATIERES ------------#
        If find([M:CTP]QTYMATTYP,1,2)
            If [M:CTP]QTYMATTYP=1
                Filter [MFM] Where MFGNUM=[M:CTP]VCRNUM & CPNTYP <> 5
            Else
                Filter [MFM] Where MFGNUM=[M:CTP]VCRNUM & [F:MFM]MATSTA<4 & CPNTYP <> 5
            Endif
            For [MFM]
                If [F:ITF]ITMREF<>[F:MFM]ITMREF | [F:ITF]STOFCY<>[M:CST0]STOFCY
                    Read [ITF]ITF0=[F:MFM]ITMREF;[M:CST0]STOFCY
                Endif
                If [F:ITM]ITMREF<>[F:MFM]ITMREF
                    Read [ITM]ITM0=[F:MFM]ITMREF
                Endif
                Raz [F:MFI]
                Read [MFI]MFI0=[F:MFM]MFGNUM;[F:MFM]MFGLIN
                Default File [MFM]
                If dim([M:CST]MATREF)<=[M:CST]NBMAT
                    PRET = 2
                    GMESSAGE=mess(562,199,1)
                    Break
                Endif
                Raz LECCMAJ, LECCMIN
                If dim([M:CST]MECCVALMAJ)>0
                    LECCMAJ = [F:MFM]ECCVALMAJ
                    LECCMIN = [F:MFM]ECCVALMIN
                Endif
                Call ADDMAT([F:MFM]ITMREF,LECCMAJ,LECCMIN,[F:MFM]MFGLIN,"",[F:MFI]BOMALT,[F:MFM]LIKQTYCOD,LRET)
            Next
            Filter [MFM]
        Else
        #----- Matières ajoutées en suivi ----#
            For [MKM] Where MFGNUM=[M:CTP]VCRNUM
                If [F:ITF]ITMREF<>[F:MKM]ITMREF | [F:ITF]STOFCY<>[M:CST0]STOFCY
                    Read [ITF]ITF0=[F:MKM]ITMREF;[M:CST0]STOFCY
                Endif
                If [F:ITM]ITMREF<>[F:MKM]ITMREF
                    Read [ITM]ITM0=[F:MKM]ITMREF
                Endif
                Raz [F:MFI]
                Read [MFI]MFI0=[F:MKM]MFGNUM;[F:MKM]MFGLIN
                Default File [MKM]
                If dim([M:CST]MATREF)<=[M:CST]NBMAT
                    PRET = 2
                    GMESSAGE=mess(562,199,1)
                    Break
                Endif
                Raz LECCMAJ, LECCMIN
                If dim([M:CST]MECCVALMAJ)>0 & dim([F:MKM]ECCVALMAJ)>0
                    LECCMAJ = [F:MKM]ECCVALMAJ
                    LECCMIN = [F:MKM]ECCVALMIN
                Endif
                Call ADDMAT([F:MKM]ITMREF,LECCMAJ,LECCMIN,[F:MKM]MFGLIN,[F:MKM]MFGTRKNUM,[F:MFI]BOMALT,1,LRET)
            Next
        Endif

        If PRET
            End
        Endif

    When 3: #------------- OPERATIONS ------------#
        If find([M:CTP]QTYOPETYP,1,2)
            If [M:CTP]QTYOPETYP=1
                Filter [MFO] Where MFGNUM=[M:CTP]VCRNUM                # Coût théorique => prise en compte des opé exclues
            Else
                Filter [MFO] Where MFGNUM=[M:CTP]VCRNUM & OPESTA<>6    # Pas d'opérations exclues
            Endif
            For [MFO]
                Raz [F:MWS]
                Case [M:CTP]QTYOPETYP
                    When 1 :
                        LPFX = "STD"
                    When 2 :
                        LPFX = "EXT"
                    When 3 :
                        LPFX = "CPL"
                Endcase
                LWSTO = ""
                Read [MWS]WST0 = evalue("[F:MFO]"+LPFX+"WST");[M:CST0]STOFCY
                If [F:MFO]SCOWST <> "" & [F:MFO]SCOCOD = 2 : # sous-traitance structurelle
                    Read [MWS]WST0 = [F:MFO]SCOWST;[M:CST0]STOFCY
                Endif
                Default File [MFO]
                Gosub ADDWSTMFG
                If evalue("[F:MFO]"+LPFX+"LAB") <> ""
                    LWSTO = [F:MWS]WST
                    Read [MWS]WST0 = evalue("[F:MFO]"+LPFX+"LAB");[M:CST0]STOFCY
                    Default File [MFO]
                    Gosub ADDWSTMFG
                Endif
            Next
            Filter [MFO]
        Else
            #----- Opérations réalisées ----#
            For [MKO]MKO1 Where MFGNUM=[M:CTP]VCRNUM
                LWSTO = ""
                Read [MWS]WST0 = [F:MKO]CPLWST;[M:CST0]STOFCY
                LPFX = "CPL"
                Case [F:MWS]WSTTYP
                    When 1,2 :
                        [M:CST]WVCRNUM([M:CST]NBWST)    = [F:MKO]MFGTRKNUM
                    When 3 :
                        [M:CST]SVCRNUM([M:CST]NBSCO)    = [F:MKO]MFGTRKNUM
                Endcase
                Default File [MKO]
                Gosub ADDWSTMFG
                If [F:MKO]CPLLAB <> ""
                    LWSTO = [F:MWS]WST
                    Read [MWS]WST0 = [F:MKO]CPLLAB;[M:CST0]STOFCY
                    [M:CST]WVCRNUM([M:CST]NBWST)    = [F:MKO]MFGTRKNUM
                    Default File [MKO]
                    Gosub ADDWSTMFG
                Endif
            Next
        Endif

        If PRET
            End
        Endif

Endcase

End

##############################################
# Ajoute une matière dans le tableau des matières à partir de la classe [F] par défaut
# Est appelé par le chargement OF et EO
##############################################
# Paramètres E : PVCRNUM = N° du suivi pour les matières ajoutées, sinon ""
#            S : PRET    = Code retour
##############################################
Subprog ADDMAT(PMAT, PECCMAJ, PECCMIN, PLNK,PVCRNUM,PALT,PLIKCOD,PRET)
Value    Char    PMAT
Value    Char    PECCMAJ
Value    Char    PECCMIN
Value    Integer PLNK
Value    Char    PVCRNUM
Value    Integer PALT
Value    Integer PLIKCOD
Variable Integer PRET

Local Decimal LPRI
Local Decimal LCOE

    Case [M:CTP]QTYMATTYP
        When 1 :
            [M:CST]MQTYSTU([M:CST]NBMAT) = [F]STDQTY
        When 2 :
            [M:CST]MQTYSTU([M:CST]NBMAT) = [F]RETQTY
        When 3 :
            [M:CST]MQTYSTU([M:CST]NBMAT) = [F]USEQTY
    Endcase
    # Issue 107547 by GA 10/2015
    GPE=0 : GPOINT="CTLADDMAT" : Gosub ENTREE From EXEFNC
    If [M:CST]MQTYSTU([M:CST]NBMAT)=0 | GPE   # Si la qté du composant est nulle, on ne l'ajoute pas dans le tableau
        End
    Endif

    # Issue 85341 - 2013-08-20 by CCC : lignes déplacées avant utilisation MQTYSTU
    # Issue 62860 - 2010-08-20 by CCC : Suite à la demande 18732 il ne faut pas proratiser les coûts fixes
    If PLIKCOD<>2
        [M:CST]MQTYSTU([M:CST]NBMAT) *= func COEPRO([M:CST]MLNK([M:CST]NBMAT))
        Call QTEARR([M:CST]MQTYSTU([M:CST]NBMAT),[F:ITM]STU) From TRTDIV
    Endif

    # Lorsque le type de la quantité (réelle ou prévue) est différente du type de coût (réel ou prévu),
    # on proratise le coût.
    # Ex: mfctyp=5 => qtymattyp=2 (prévu) et cstmattyp=3 (réel)
    # Donc on va récupérer le montant réel et le multiplier par le coefficient quantité prévue/quantité réelle
    LCOE = [M:CST]MQTYSTU([M:CST]NBMAT)
    Case [M:CTP]CSTMATTYP
        When 1 :
            If [F]STDQTY=0
                LCOE = 1
            Else
                LCOE /= [F]STDQTY
            Endif
        When 2 :
            If [F]RETQTY=0
                LCOE = 1
            Else
                LCOE /= [F]RETQTY
            Endif
        When 3 :
            If [F]USEQTY=0
                LCOE = 1
            Else
                LCOE /= [F]USEQTY
            Endif
    Endcase

#    # Issue 62860 - 2010-08-20 by CCC : Suite à la demande 18732 il ne faut pas proratiser les coûts fixes
#    If PLIKCOD<>2
#        [M:CST]MQTYSTU([M:CST]NBMAT) *= func COEPRO([M:CST]MLNK([M:CST]NBMAT))
#    Endif

    [M:CST]MLNK([M:CST]NBMAT)    = PLNK
    [M:CST]MATREF([M:CST]NBMAT)  = PMAT
    If dim([M:CST]MECCVALMAJ)>0
        [M:CST]MECCVALMAJ([M:CST]NBMAT) = PECCMAJ
        [M:CST]MECCVALMIN([M:CST]NBMAT) = PECCMIN
    Endif
    [M:CST]MATFLG([M:CST]NBMAT)  = 1+func SUBCSTB.ISMAT([M:CST]MATREF([M:CST]NBMAT), 2, PALT, [M:CTP]CLCDAT)    # On met le type prod mais de toute façon le type /s-trait sera aussi testé
    [M:CST]MVCRNUM([M:CST]NBMAT) = PVCRNUM
    [M:CST]MSTU([M:CST]NBMAT)    = [F]STU
    [M:CST]MBRDCOD([M:CST]NBMAT) = [F:ITM]BRDCOD
    # Issue 114047 - 2016-03-04 by CCC : Consider new subcontracting issues overhead setup
    If [M:CTP]VCRTYP=36
        [M:CST]MOVECOD([M:CST]NBMAT) = func STKVAL.GETOVE( [M:CST]MATREF([M:CST]NBMAT), [M:CST0]STOFCY, 29, PRET ) # Subcontrating issue
    Else
        [M:CST]MOVECOD([M:CST]NBMAT) = func STKVAL.GETOVE( [M:CST]MATREF([M:CST]NBMAT), [M:CST0]STOFCY, 6, PRET ) # WO issue
    Endif
    If PRET=1 # Pas de code FG
        Raz PRET
        Raz GMESSAGE
    Endif
    [M:CST]MOVECOL([M:CST]NBMAT) = [M:CTP]SLTOVECOL
    If [M:CST]SCOFLG([M:CST]NBMAT)=3
        If [M:CTP]CSTMATTYP=1    # Coût théorique => recherche tarif
            If [F:ITM]ITMREF<>[M:CST]MATREF([M:CST]NBMAT)
                Read [ITM]ITM0=[M:CST]MATREF([M:CST]NBMAT)
            Endif
            If dim([M:CST]MECCVALMAJ)>0 # Issue GA 07/2015
            LPRI = func RECHTARIF2([M:CST]MATREF([M:CST]NBMAT),[M:CST]MECCVALMAJ([M:CST]NBMAT),[M:CST]MECCVALMIN([M:CST]NBMAT),[M:CST0]STOFCY,
&                                  [M:CST]MQTYSTU([M:CST]NBMAT)*[F:ITM]PUUSTUCOE,[M:CST]MLNK([M:CST]NBMAT),[M:CTP]CLCDAT)
            Else
            LPRI = func RECHTARIF2([M:CST]MATREF([M:CST]NBMAT),"","",[M:CST0]STOFCY,
&                                  [M:CST]MQTYSTU([M:CST]NBMAT)*[F:ITM]PUUSTUCOE,[M:CST]MLNK([M:CST]NBMAT),[M:CTP]CLCDAT)
            Endif
        Elsif [M:CTP]CSTMATTYP=2    # Coût lancement => récupération du prix (saisi) dans l'OS
            # Issue 74682 - 2011-07-07 by CCC
            #LPRI = [F:SCM]NETPRI
            LPRI = [F:SCM]NETPRIL
        Endif
        [M:CST]MMATCST([M:CST]NBMAT*GACTMAT+[M:CST]MBRDCOD([M:CST]NBMAT)) = LPRI*[M:CST]MQTYSTU([M:CST]NBMAT)
        [M:CST]MCSTCOD([M:CST]NBMAT) = 7
    Else
        [M:CST]SCOFLG([M:CST]NBMAT)=max(1,[M:CST]SCOFLG([M:CST]NBMAT))
    Endif
    If LPRI = 0
        [M:CST]MCSTCOD([M:CST]NBMAT) = GVLTMATEXT+([M:CTP]CSTMATTYP=3)*(7-GVLTMATEXT)
        If PALT
            Read [ITB]ITB0 = PMAT;PALT;2
            If !fstat & [F:ITB]BOMEXIFLG=2
                [M:CST]MCSTCOD([M:CST]NBMAT) = GVLTSEMEXT+([M:CTP]CSTMATTYP=3)*(7-GVLTSEMEXT)
            Endif
        Endif
        If [M:CST]MCSTCOD([M:CST]NBMAT)=7    # Valeur saisie --> il faut récupérer dans STJ
            Call GETVALSTJ("M", LCOE, [M:CST]NBMAT)
        Endif
    Endif
    [M:CST]NBMAT += 1
End

#########################################################
# Cumule les valeurs des mouvements correspondant à la ligne de tableau
Subprog GETVALSTJ(PTYP, PCOE, PIND)
Value Char PTYP
Value Decimal PCOE
Value Integer PIND

Local Char LITM(GLONITM)
Local Char LVCRNUM(GLONVCR)

Local Char LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)
Local Char ECCCRIT(255)  # 49859.n

Case PTYP
    When "M"
        LITM    = [M:CST]MATREF(PIND)
        # Issue 49859 - 2017-11-30 by ERMIL : Do not filter on version for material issues - get all issues
        #If dim([M:CST]MECCVALMAJ)>0 # Issue GA 07/2015
        #  LECCMAJ = [M:CST]MECCVALMAJ(PIND)
        #  LECCMIN = [M:CST]MECCVALMIN(PIND)
        #Endif
        ECCCRIT = "1=1"  # 49859.n
        LVCRTYP = 12
        LVCRNUM = [M:CST]MVCRNUM(PIND)
    When "I"
        LITM    = [M:CST]ITMREF(PIND)
        If dim([M:CST]IECCVALMAJ)>0 # Issue GA 07/2015
          # Issue 49859 - 2017-11-30 by ERMIL : Include version in the filter still for main item or by-product
          ECCCRIT  = "ECCVALMAJ = [M:CST]IECCVALMAJ(PIND)"    # 49859.n
          ECCCRIT -= "& ECCVALMIN = [M:CST]IECCVALMIN(PIND)"
          #LECCMAJ = [M:CST]IECCVALMAJ(PIND)                  # 49859.o
          #LECCMIN = [M:CST]IECCVALMIN(PIND)
        Endif
        LVCRTYP = 15
        LVCRNUM = [M:CST]IVCRNUM(PIND)
Endcase

Raz [M:SDP]
# Issue 49859 - 2017-11-30 by ERMIL : Removed verions from Where and added as criteria to make conditional
For  [STJ]STJ1 Where STOFCY    = [M:CST0]STOFCY
&                  & UPDCOD    = 2
&                  & ITMREF    = LITM
&                  & VCRTYP    = LVCRTYP
&                  & (LVCRNUM="" | VCRNUM=LVCRNUM)
&                  & VCRTYPORI = 10
&                  & VCRNUMORI = [M:CTP]VCRNUM
&                  & REGFLG = 1
&                  & evalue(ECCCRIT)
    [M:SDP]AMTTOT += abs([F:STJ]AMTVAL)
    [M:SDP]QTY    += [F:STJ]ACTQTY
    If GACTDECCST  & [F:STJ]CREMVTDAT>=GDATDECCST
        Raz [F:SJV]
        Read [F:SJV]SJV0=[F:STJ]STOFCY;[F:STJ]UPDCOD;[F:STJ]ITMREF;[F:STJ]IPTDAT;[F:STJ]MVTSEQ;[F:STJ]MVTIND
        Call LOADSDP("[F:SJV]","V",sgn([F:STJ]ACTQTY)) From STKVAL
    Else
        [M:SDP]MATCST(0) += [M:SDP]AMTTOT
    Endif
Next
Call COPSDP2CST(PTYP, PIND,0, PCOE ) From TRTCST
If [M:SDP]QTY <> 0
    [M:SDP]PRI = [M:SDP]AMTTOT/[M:SDP]QTY
Endif
End


##############################################
$ADDWSTMFG
If dim(LTCM)<=0 : Local Char    LTCM(GLONTCM) : Endif
If dim(LRET)<=0 : Local Integer LRET          : Endif

    Raz LSETTIM, LOPETIM

    If [F:MWS]VLTCCE<>""
        Read [MWC]WCT0 = [F:MWS]VLTCCE;[F:MWS]WCRFCY : # lecture de la section de valorisation
    Elsif [F:MFO]SCOITMREF=""   # Si pas de section de valo ni d'article de sous-traitance, il n'y a rien à faire
        Raz [F:MWC]
        Return
    Endif

    #------------ Temps de réglage ------------------#
    # Issue 62860 - 2010-08-20 by CCC : Suite à la demande 18732 il ne faut pas proratiser les coûts fixes
    #LSETTIM = evalue("[F]"+LPFX+"SETTIM") * func COEPRO([M:CST]WLNK([M:CST]NBWST))
    LSETTIM = evalue("[F]"+LPFX+"SETTIM")

    If [F]TIMUOMCOD=2     # temps défini en minutes
        LSETTIM=LSETTIM/60
    Endif
    If LWSTO <> ""
        LSETTIM = LSETTIM * [F]SETLABCOE
    Endif
    If [F:MWC]CSTTYP = 2 : # type de taux forfaitaire
        If LSETTIM > 0
            LSETTIM = 1
          Else
            LSETTIM = 0
        Endif
    Endif

    #------------ Temps opératoire ------------------#
    LOPETIM = evalue("[F]"+LPFX+"OPETIM") * func COEPRO([M:CST]WLNK([M:CST]NBWST))

    If [F]TIMUOMCOD=2    # temps défini en minutes
        LOPETIM = LOPETIM/60
    Endif
    If LWSTO<>""
        LOPETIM = LOPETIM * [F]OPELABCOE
    Endif
    If [F:MWC]CSTTYP = 2 : # type de taux forfaitaire
        If LOPETIM>0
            LOPETIM = 1
        Else
            LOPETIM = 0
        Endif
    Endif

    Case [F:MWS]WSTTYP
        When 1,2 :
            If dim([M:CST]WLNK)<=[M:CST]NBWST
                PRET = 3
                GMESSAGE=mess(563,199,1)
                Return
            Endif
            [M:CST]WLNK([M:CST]NBWST)    = 0
            [M:CST]WST([M:CST]NBWST)     = [F:MWS]WST
            [M:CST]WSTTYP([M:CST]NBWST)  = [F:MWS]WSTTYP
            [M:CST]WCSTTYP([M:CST]NBWST) = max(1,[F:MWC]CSTTYP)
            If [M:CTP]CSTOPETYP<3
                [M:CST]WRATCOD([M:CST]NBWST) = GMFCRATEXT
            Else
                [M:CST]WRATCOD([M:CST]NBWST) = GMFCRATCPL
            Endif
            [M:CST]WBRDCOD([M:CST]NBWST) = max(1,[F:MWC]BRDCOD)
            [M:CST]WOVECOD([M:CST]NBWST) = [F:MWC]OVECOD
            [M:CST]WSETTIM([M:CST]NBWST) = LSETTIM
            [M:CST]WOPETIM([M:CST]NBWST) = LOPETIM
            [M:CST]WOVECOL([M:CST]NBWST) = [M:CTP]SLTOVECOL
            [M:CST]NBWST += 1
        When 3 :
            If dim([M:CST]SLNK)<=[M:CST]NBSCO
                PRET = 3
                GMESSAGE=mess(563,199,1)
                Return
            Endif
            [M:CST]SLNK([M:CST]NBSCO)    = 0
            [M:CST]SCOWST([M:CST]NBSCO)  = [F:MWS]WST
            [M:CST]SOVECOD([M:CST]NBSCO) = [F:MWC]OVECOD
            [M:CST]SOVECOL([M:CST]NBSCO) = [M:CTP]SLTOVECOL
            If [M:CTP]CSTOPETYP<3
                [M:CST]SRATCOD([M:CST]NBSCO) = GMFCRATEXT
            Else
                [M:CST]SRATCOD([M:CST]NBSCO) = GMFCRATCPL
            Endif
            [M:CST]SSETTIM([M:CST]NBSCO) = LSETTIM
            [M:CST]SOPETIM([M:CST]NBSCO) = LOPETIM
            If [M:CTP]QTYOPETYP=3
                # Une opération de sous-traitance ne peut pas être ajoutée en suivi
                Read [MFO]MFO0=[F:MKO]MFGNUM;[F:MKO]OPENUM;[F:MKO]OPESPLNUM
            Endif
            [M:CST]SCOITMREF([M:CST]NBSCO) = [F:MFO]SCOITMREF
            If [F:MFO]SCOITMREF <> ""
                Raz [F:ITF]
                Read [ITF]ITF0=[F:MFO]SCOITMREF;[M:CST0]STOFCY
                [M:CST]SIOVECOD([M:CST]NBSCO) = func STKVAL.GETOVE( [M:CST]SCOITMREF([M:CST]NBSCO), [M:CST0]STOFCY, 3, LRET )    # Réception fournisseur
                [M:CST]SIOVECOL([M:CST]NBSCO) = [M:CTP]SLTOVECOL

                LQTYTOT=func TRTCST.SUMQTY("P", [M:CST]SLNK([M:CST]NBSCO))
                If LQTYTOT=0
                    LQTYTOT=1
                Endif
                [M:CST]SQTYSCOITM([M:CST]NBSCO) = [F:MFO]EXTQTY
                [M:CST]SCOEQTY([M:CST]NBSCO) = [F:MFO]EXTQTY / LQTYTOT

                If [M:CTP]CSTOPETYP=1 | [M:CTP]CSTOPETYP=2 & [F:MFO]EXTPRI=0    # Le prix prévu n'est alimenté qu'au moment de la commande
                    [M:CST]PRISCO([M:CST]NBSCO)  = [F:MFO]REFPRI # prix par unité d'opération
                Else
                    Case [M:CTP]MFCTYP
                        When 1: [M:CST]SCOEQTY([M:CST]NBSCO) = [F:MFO]STDQTY / LQTYTOT
                                [M:CST]SQTYSCOITM([M:CST]NBSCO) = [F:MFO]STDQTY
                        When 2: [M:CST]PRISCO([M:CST]NBSCO)  = [F:MFO]EXTPRI    # prix par unité d'opération
                                [M:CST]SCOEQTY([M:CST]NBSCO) = [F:MFO]EXTQTY / LQTYTOT
                                [M:CST]SQTYSCOITM([M:CST]NBSCO) = [F:MFO]EXTQTY
                        When 3: [M:CST]PRISCO([M:CST]NBSCO)  = [F:MFO]CPLPRI    # prix par unité d'opération
                                [M:CST]SCOEQTY([M:CST]NBSCO) = [F:MFO]CPLQTY / LQTYTOT
                                [M:CST]SQTYSCOITM([M:CST]NBSCO) = [F:MFO]CPLQTY

                    Endcase
                Endif
                If [M:CST]PRISCO([M:CST]NBSCO)>0
                    [M:CST]SCSTCOD([M:CST]NBSCO) = 7    # Prix ordre
                Else
                    Call GETTCM([F:MFO]SCOITMREF, [M:CST0]STOFCY, LTCM, LRET) From STKVAL
                    If LRET    # Si erreur => prix=0
                        [M:CST]SCSTCOD([M:CST]NBSCO) = 7    # Prix ordre
                    Else
                        [M:CST]SCSTCOD([M:CST]NBSCO) = [F:TCM]ISSVLTCOD#+1  # Issue 89622 - 2013-06-05 by CCC
                    Endif
                Endif
                # Issue 76496 - 2011-10-04 by CCC : Le prix doit rester par UO. Il est converti au moment du calcul car on ne le connais peut-être pas encore
                ## ... puis du prix, ramené à la qté de l'article sous-traité
                #[M:CST]PRISCO([M:CST]NBSCO) *= [M:CST]SCOEQTY([M:CST]NBSCO)

            Endif
            [M:CST]NBSCO += 1
    Endcase
Return

##############################################
# Charge les enregistrements d'un EO dans CST
##############################################
# Paramètres E : PTYP = 1:produits 2:matière  3:postes
#            S : PRET=code erreur (0 = OK)
#                                 (1 = Code activité NMI trop petit)
#                                 (2 = Code activité NMM trop petit)
#                                 (3 = Code activité NMW trop petit)
##############################################
Subprog LOADSCO(PTYP,PRET)
Value Integer PTYP
Variable Integer PRET

Raz PRET
Raz GMESSAGE

If !clalev([F:ITB]) : Local File ITMBOM     [ITB] : Endif
If !clalev([F:SCI]) : Local File SCOITM     [SCI] : Endif
If !clalev([F:SCM]) : Local File SCOMAT     [SCM] : Endif
If !clalev([F:SCS]) : Local File SCOSRV     [SCS] : Endif
If !clalev([F:TCM]) : Local File TABCOSTMET [TCM] : Endif
If !clalev([F:STJ]) : Local File STOJOU     [STJ] : Endif
If GACTDECCST
    If !clalev([F:SJV]) : Local File STOJOUVAL  [SJV] : Endif
Endif

Local Char    LPFX(3)
Local Integer LTYP, LRET
Local Decimal LOPETIM, LSETTIM, LQTYTOT
Local Char    LWSTO(GLONWST)
Local Mask    SAIDECPRI [SDP]     # Pour GETVALSTJ
Local Char    LTCM(GLONTCM)
Local Char    LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)

Local Char PARAM(250)
Call PARAM([M:CST0]STOFCY,"VLTMATEXT",PARAM) From ADOVAL
GVLTMATEXT = val(PARAM)
Call PARAM([M:CST0]STOFCY,"VLTSEMEXT",PARAM) From ADOVAL
GVLTSEMEXT = val(PARAM)
Call PARAM([M:CST0]STOFCY,"VLTSCEOEXT",PARAM) From ADOVAL
GVLTSCEOEXT = val(PARAM)
If GVLTSCEOEXT=0 : GVLTSCEOEXT=7 : Endif  # Par défaut "Prix ordre"

LTYP=PTYP

Case LTYP
    When 1: #------------- PRODUITS ------------#
        Filter [SCI] Where SCONUM=[M:CTP]VCRNUM & PRHFCY=[M:CST0]STOFCY
        For [SCI]
            If dim([M:CST]ITMREF)<=[M:CST]NBITM
                PRET=1
                GMESSAGE=mess(561,199,1)
                Break
            Endif
            If [F:ITF]ITMREF<>[F:SCI]ITMREF | [F:ITF]STOFCY<>[M:CST0]STOFCY
                Read [ITF]ITF0=[F:SCI]ITMREF;[M:CST0]STOFCY
            Endif
            If [F:ITM]ITMREF<>[F:SCI]ITMREF
                Read [ITM]ITM0=[F:SCI]ITMREF
            Endif
            [M:CST]ITMREF([M:CST]NBITM) = [F:SCI]ITMREF
            If dim([M:CST]IECCVALMAJ)>0 # Issue GA 07/2015
              [M:CST]IECCVALMAJ([M:CST]NBITM) = [F:SCI]ECCVALMAJ
              [M:CST]IECCVALMIN([M:CST]NBITM) = [F:SCI]ECCVALMIN
            Endif
            [M:CST]ITMTYP([M:CST]NBITM) = 1
            [M:CST]IMATFLG([M:CST]NBITM)  = 1
            [M:CST]ILNK([M:CST]NBITM)   = [F:SCI]SCILIN
            [M:CST]ICOEPRO([M:CST]NBITM) = 1
            Case [M:CTP]QTYITMTYP
                When 1 :    # Ce choix ne devrait pas être possible car STDQTY n'existe pas
                    [M:CST]IQTYSTU([M:CST]NBITM)= [F:SCI]EXTQTY
                When 2 :
                    [M:CST]IQTYSTU([M:CST]NBITM)= [F:SCI]EXTQTY
                When 3 :
                    [M:CST]IQTYSTU([M:CST]NBITM)= [F:SCI]CPLQTY-[F:SCI]REJCPLQTY
                    If [M:CTP]PROCPLEXT=2
                        [M:CST]ICOEPRO([M:CST]NBITM) = [M:CST]IQTYSTU([M:CST]NBITM)/[F:SCI]EXTQTY
                    Endif
            Endcase
            [M:CST]ISTU([M:CST]NBITM)   = [F:SCI]STU
            # Issue 114047 - 2016-03-02 by CCC : Use receipt overheads in EO
            #[M:CST]IOVECOD([M:CST]NBITM) = func STKVAL.GETOVE( [M:CST]ITMREF([M:CST]NBITM), [M:CST0]STOFCY, 5, LRET ) # FG entrée OF
            [M:CST]IOVECOD([M:CST]NBITM) = func STKVAL.GETOVE( [M:CST]ITMREF([M:CST]NBITM), [M:CST0]STOFCY, 3, LRET ) # Receipt
            [M:CST]IOVECOL([M:CST]NBITM) = [M:CTP]SLTOVECOL
            [M:CST]IBRDCOD([M:CST]NBITM) = [F:ITM]BRDCOD
            [M:CST]ICSTCOD([M:CST]NBITM) = 0
            [M:CST]NBITM += 1
        Next
        Filter [SCI]
    When 2: #------------- MATIERES ------------#
        If [M:CTP]QTYMATTYP=1
            Filter [SCM] Where SCONUM=[M:CTP]VCRNUM & CPNTYP <> 5
        Else
            Filter [SCM] Where SCONUM=[M:CTP]VCRNUM & [F:SCM]MATSTA<>4 & CPNTYP <> 5
        Endif
        For [SCM]
            If dim([M:CST]MATREF)<=[M:CST]NBMAT
                PRET=2
                GMESSAGE=mess(562,199,1)
                Break
            Endif
            If [F:ITF]ITMREF<>[F:SCM]CPNITMREF | [F:ITF]STOFCY<>[M:CST0]STOFCY
                Read [ITF]ITF0=[F:SCM]CPNITMREF;[M:CST0]STOFCY
            Endif
            If [F:ITM]ITMREF<>[F:SCM]CPNITMREF     # Issue 104677 - 2015-02-05 by CCC : use of CPNITMREF istead of ITMREF
                Read [ITM]ITM0=[F:SCM]CPNITMREF
            Endif
            Raz [F:SCI]
            Read [SCI]SCI0=[F:SCM]SCONUM;[F:SCM]SCILIN
            Default File [SCM]
            [M:CST]SCOFLG([M:CST]NBMAT) = max(1,[F:SCM]SCOFLG)
            Raz LECCMAJ, LECCMIN
            If dim([M:CST]IECCVALMAJ)>0 # Issue GA 07/2015
              LECCMAJ = [F:SCM]ECCVALMAJ
              LECCMIN = [F:SCM]ECCVALMIN
            Else
              Raz LECCMAJ,LECCMIN
            Endif

            #Issue X3-8247.sn MJH 8 March 2017
            [M:CST]MATFCY([M:CST]NBMAT) = [F:SCM]STOFCY

            Call ADDMAT([F:SCM]CPNITMREF,LECCMAJ,LECCMIN,[F:SCM]SCILIN,"",[F:SCI]BOMALT,[F:SCM]LIKQTYCOD,LRET)
            If [M:CST]SCOFLG([M:CST]NBMAT)=3    # Pas de FG sur les matières fournies par le sous-traitant
                [M:CST]MOVECOD([M:CST]NBMAT)=""
            Endif
        Next
        Filter [SCM]
    When 3: #------------- SERVICE DE SOUS-TRAITANCE ------------#
        If [M:CTP]QTYOPETYP=1
            Filter [SCS] Where SCONUM=[M:CTP]VCRNUM                # Coût théorique => prise en compte des opé exclues
        Else
            Filter [SCS] Where SCONUM=[M:CTP]VCRNUM & OPESTA<>6    # Pas d'opérations exclues
        Endif
        For [SCS]
            If dim([M:CST]SLNK)<=[M:CST]NBSCO
                PRET=3
                GMESSAGE=mess(563,199,1)
                Break
            Endif
            [M:CST]SLNK([M:CST]NBSCO)    = [F:SCS]SCILIN
            [M:CST]SCOWST([M:CST]NBSCO)  = ""
            [M:CST]SOVECOD([M:CST]NBSCO) = ""
            [M:CST]SOVECOL([M:CST]NBSCO) = [M:CTP]SLTOVECOL
            [M:CST]SRATCOD([M:CST]NBSCO) = 0
            [M:CST]SSETTIM([M:CST]NBSCO) = 0
            [M:CST]SOPETIM([M:CST]NBSCO) = 0
            [M:CST]SCOITMREF([M:CST]NBSCO) = [F:SCS]SRVITMREF
            [M:CST]SQTYSCOITM([M:CST]NBSCO) = [F:SCS]EXTSTRQTY
            If [M:CST]SCOITMREF([M:CST]NBSCO) <> ""
                Read [F:ITM]ITM0 = [M:CST]SCOITMREF([M:CST]NBSCO)
                [M:CST]SUOMSCOITM([M:CST]NBSCO) = [F:ITM]STU
                Raz [F:ITF]
                Read [ITF]ITF0=[M:CST]SCOITMREF([M:CST]NBSCO);[M:CST0]STOFCY
                [M:CST]SIOVECOD([M:CST]NBSCO) = func STKVAL.GETOVE( [M:CST]SCOITMREF([M:CST]NBSCO), [M:CST0]STOFCY, 3, LRET )    # Réception fournisseur
                [M:CST]SIOVECOL([M:CST]NBSCO) = [M:CTP]SLTOVECOL
                Call GETTCM([M:CST]SCOITMREF([M:CST]NBSCO), [M:CST0]STOFCY, LTCM, LRET) From STKVAL

                LQTYTOT=func TRTCST.SUMQTY("P", [M:CST]SLNK([M:CST]NBSCO))
                If LQTYTOT=0
                    LQTYTOT=1
                Endif
                # Issue 76982 - 2012-03-13 by CCC : comment
                If [M:CTP]MFCTYP=3
                    [M:CST]SCOEQTY([M:CST]NBSCO) = [F:SCS]CPLQTY / LQTYTOT
                    [M:CST]SQTYSCOITM([M:CST]NBSCO) = [F:SCS]CPLQTY
                Else
                    [M:CST]SCOEQTY([M:CST]NBSCO) = [F:SCS]EXTSTRQTY / LQTYTOT
                Endif
                Case GVLTSCEOEXT
                    When 7 : # Récupération du prix d'ordre (dans SCS)
                        If [M:CTP]CSTOPETYP=1 | [M:CTP]CSTOPETYP=2 & [F:SCS]NETPRIL=0    # Le prix prévu n'est alimenté qu'au moment de la commande
                            [M:CST]PRISCO([M:CST]NBSCO)  = [F:SCS]REFPRI
                        Else
                            Case [M:CTP]MFCTYP
                                When 2: # Issue 74682 - 2011-07-07 by CCC
                                        #[M:CST]PRISCO([M:CST]NBSCO)  = [F:SCS]NETPRI
                                        [M:CST]PRISCO([M:CST]NBSCO)  = [F:SCS]NETPRIL
                                When 3: [M:CST]PRISCO([M:CST]NBSCO)  = [F:SCS]CPLPRI
                            Endcase
                        Endif
                        [M:CST]SCSTCOD([M:CST]NBSCO) = 7    # Prix ordre pour ne pas faire de recherche par la suite

                    When 9 : # Méthode de valo de sortie
                            [M:CST]SCSTCOD([M:CST]NBSCO) = [F:TCM]ISSVLTCOD#+1  # Issue 89622 - 2013-06-05 by CCC

                    When 12 : # Prix tarif
                        [M:CST]PRISCO([M:CST]NBSCO) = func RECHTARIF2([M:CST]SCOITMREF([M:CST]NBSCO),"","",[M:CST0]STOFCY,[F:SCS]EXTSTRQTY,[M:CST]SLNK([M:CST]NBSCO),[M:CTP]CLCDAT)
                        Call GETDEV([M:CST0]STOFCY) From DEVSUB    # Remettre GLOCALDEV du site
                        # Issue 76496 - 2011-10-04 by CCC : Le prix doit rester par UO. Il est converti au moment du calcul car on ne le connais peut-être pas encore
                        ## ... puis du prix, ramené à la qté de l'article sous-traité
                        #[M:CST]PRISCO([M:CST]NBSCO) *= [M:CST]SCOEQTY([M:CST]NBSCO)
                        [M:CST]SCSTCOD([M:CST]NBSCO) = 7    # Prix ordre pour ne pas faire de recherche par la suite

                    When Default :
                        [M:CST]SCSTCOD([M:CST]NBSCO) = GVLTSCEOEXT
                Endcase
            Endif
            [M:CST]NBSCO += 1
        Next
        Filter [SCS]
Endcase

End

##############################################
# Charge les enregistrements WIPCOST dans CST
##############################################
# Paramètres E : PTYP = 1:produits 2:matière  3:postes
##############################################
Subprog LOADWIP(PTYP,PRET)
Value Integer PTYP
Variable Integer PRET

Raz PRET
Raz GMESSAGE

If !clalev([F:MWI]) : Local File WIPCOST    [MWI] : Endif
If GMODU(8)=2
    If !clalev([F:MFI]) : Local File MFGITM     [MFI] : Endif
    If !clalev([F:MWC]) : Local File WORKCOST   [MWC] : Endif
Endif

# Issue X3-48924 - 2017-09-28 by ERMIL : Add entry point to allow loading custom views in place of MWI
GPOINT="LOADWIP"
Gosub ENTREE From EXEFNC

Local Integer LRET

Case PTYP
    When 1:
        Filter [MWI] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & TXNTYP=14 & OVENAT=""
&                    Order By Key MWIT=VCRLIN;ITMREF;MFGTRKNUM;MFGTRKLIN    # Issue 100887 - 2014-10-29 by CCC : aggregate WIP by tracking
#&                    Order By VCRLIN    # Issue 79075 - 2012-02-02 by CCC : Les produits doivent apparaitre avant les sous-produits correspondants
        For [MWI]MWIT(1)
            # Issue 68886 - 2010-11-05 by CCC : On ne récupère que les VCRLIN existant
            If [F:MWI]VCRTYP=10 & [F:MWI]VCRLIN<>0
                # Issue 91934 - 2013-08-21 by CCC : Le sous-produit doit être valorisé pour être pris en compte
                If [F:MWI]ITMTYP = 2
                    Filter [MFI] Where MFGNUM=[F:MWI]VCRNUM
&                                    & MFGLIN=[F:MWI]VCRLIN
&                                    & CSTFLG=2
                Else
                    Filter [MFI] Where MFGNUM=[F:MWI]VCRNUM
&                                    & MFGLIN=[F:MWI]VCRLIN
                Endif
                Look [MFI]MFI0 First
                Filter [MFI]
            Else
                Raz fstat
            Endif
            If fstat
                For [MWI]MWIT
                    Break
                Next
            Else
                For [MWI]MWIT(4)
                    If dim([M:CST]ITMREF)<=[M:CST]NBITM
                        PRET=1
                        GMESSAGE=mess(561,199,1)
                        Break 2
                    Endif
                    If [F:ITF]ITMREF<>[F:MWI]ITMREF | [F:ITF]STOFCY<>[M:CST0]STOFCY
                        Read [ITF]ITF0=[F:MWI]ITMREF;[M:CST0]STOFCY
                    Endif
                    If [F:ITM]ITMREF<>[F:MWI]ITMREF
                        Read [ITM]ITM0=[F:MWI]ITMREF
                    Endif
                    For [MWI]MWIT
                        [M:CST]ITMREF([M:CST]NBITM) = [F:MWI]ITMREF
                        If dim([M:CST]IECCVALMAJ)>0 # Issue GA 07/2015
                          [M:CST]IECCVALMAJ([M:CST]NBITM) = [F:MWI]ECCVALMAJ
                          [M:CST]IECCVALMIN([M:CST]NBITM) = [F:MWI]ECCVALMIN
                        Endif
                        [M:CST]ITMTYP([M:CST]NBITM) = [F:MWI]ITMTYP
                        If [F:MWI]ITMTYP = 2
                            If [F:MFI]MFGNUM<>[F:MWI]VCRNUM | [F:MFI]MFGLIN<>[F:MWI]VCRLIN
                                Raz [F:MFI]
                                Read [MFI]MFI0=[F:MWI]VCRNUM;[F:MWI]VCRLIN
                            Endif
                            [M:CST]ILNK([M:CST]NBITM)   = [F:MFI]ITMLIN
                            [M:CST]IMATFLG([M:CST]NBITM) = max([M:CST]IMATFLG([M:CST]NBITM),1+([F:MWI]MATLEV0<>0))
                        Else
                            [M:CST]ILNK([M:CST]NBITM)   = [F:MWI]VCRLIN
                            [M:CST]IMATFLG([M:CST]NBITM) = 1
                        Endif
                        [M:CST]IVCRNUM([M:CST]NBITM)= [F:MWI]MFGTRKNUM
                        [M:CST]IQTYSTU([M:CST]NBITM)+= [F:MWI]QTYACT
                        [M:CST]ISTU([M:CST]NBITM)   = [F:MWI]STU
                        [M:CST]ICOEPRO([M:CST]NBITM) = 1
                        # Issue 114047 - 2016-03-02 by CCC : Use receipt overheads for EO
                        If [M:CTP]VCRTYP=36
                            [M:CST]IOVECOD([M:CST]NBITM) = func STKVAL.GETOVE( [M:CST]ITMREF([M:CST]NBITM), [M:CST0]STOFCY, 3, LRET ) # Receipt
                        Else
                            [M:CST]IOVECOD([M:CST]NBITM) = func STKVAL.GETOVE( [M:CST]ITMREF([M:CST]NBITM), [M:CST0]STOFCY, 5, LRET ) # WO product entry
                        Endif
                        [M:CST]IOVECOL([M:CST]NBITM) = [M:CTP]SLTOVECOL
                        [M:CST]IBRDCOD([M:CST]NBITM) = [F:ITM]BRDCOD
                        If [F:MWI]ITMTYP=2
                            [M:CST]ICSTCOD([M:CST]NBITM) = 8
                            #--------- Alimentation des montants ------------#
                            For I=0 To GACTMAT-1
                                [M:CST]IMATCST([M:CST]NBITM*GACTMAT+I) += -[F:MWI]MATCST(I)
                            Next
                            For I=0 To GACTMAC-1
                                [M:CST]IMACCST([M:CST]NBITM*GACTMAC+I) += -[F:MWI]MACCST(I)
                            Next
                            For I=0 To GACTLAB-1
                                [M:CST]ILABCST([M:CST]NBITM*GACTLAB+I) += -[F:MWI]LABCST(I)
                            Next
                            [M:CST]ISCOCST([M:CST]NBITM)    += -[F:MWI]SCOCST
                            [M:CST]IINVDTA([M:CST]NBITM)    += -[F:MWI]INVDTACST
                            [M:CST]IOVEMATCST([M:CST]NBITM) += -[F:MWI]OVEMATCST
                            [M:CST]IOVEMACCST([M:CST]NBITM) += -[F:MWI]OVEMACCST
                            [M:CST]IOVELABCST([M:CST]NBITM) += -[F:MWI]OVELABCST
                            [M:CST]IOVESCOCST([M:CST]NBITM) += -[F:MWI]OVESCOCST
                        Else
                            [M:CST]ICSTCOD([M:CST]NBITM) = 0
                        Endif

                    Next
                    [M:CST]NBITM += 1
                Next
            Endif
        Next
        Filter [MWI]

        If PRET
            End
        Endif
        #--------------------- Eléments de facturation -----------------#
        Filter [MWI] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & TXNTYP=19
        For [MWI]
            # Issue 68886 - 2010-11-05 by CCC : On ne récupère que les VCRLIN existant
            If [F:MWI]VCRTYP=10 & [F:MWI]VCRLIN<>0
                Look [MFI]MFI0=[F:MWI]VCRNUM;[F:MWI]VCRLIN
            Else
                Raz fstat
            Endif
            If !fstat
                [M:CST]DLNK([M:CST]NBINVDTA) = [F:MWI]VCRLIN
                [M:CST]DAMT([M:CST]NBINVDTA) = [F:MWI]AMOUNT
                [M:CST]NBINVDTA+=1
            Endif
        Next
        Filter [MWI]

        # Issue 83336 - 2012-08-23 by CCC : Récupérer les MFI qui n'auraient pas été produits
        #If [M:CST]NBITM=0
        # Issue 108611 - 2015-12-03 by BEEBE : usage of ILNK for find as array requires additional parameter
        Local Integer LNUMROWS
        If [M:CST]NBITM >0
            LNUMROWS = [M:CST]NBITM-1
        Else
            LNUMROWS = 0
        Endif
        Call LOADMFG2(1,"[F:MFI]ITMTYP = 1 & find([F:MFI]MFGLIN,[M:CST]ILNK(0.."-num$(LNUMROWS)-"))<=0",PRET)
        #Endif

    When 2:
        Filter [MWI] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & TXNTYP=1
&                    Order By Key MWIT=VCRLIN;ITMREF;SCOFLG;MFGTRKNUM;MFGTRKLIN
        For [MWI]MWIT(1)
            # Issue 68886 - 2010-11-05 by CCC : On ne récupère que les VCRLIN existant
            If [F:MWI]VCRTYP=10 & [F:MWI]VCRLIN<>0
                Look [MFI]MFI0=[F:MWI]VCRNUM;[F:MWI]VCRLIN
            Else
                Raz fstat
            Endif
            If fstat
                For [MWI]MWIT
                    Break
                Next
            Else
                For [MWI]MWIT(5)
                    If dim([M:CST]MATREF)<=[M:CST]NBMAT
                        PRET=2
                        GMESSAGE=mess(562,199,1)
                        Break 2
                    Endif
                    If [F:ITF]ITMREF<>[F:MWI]ITMREF | [F:ITF]STOFCY<>[M:CST0]STOFCY
                        Read [ITF]ITF0=[F:MWI]ITMREF;[M:CST0]STOFCY
                    Endif
                    For [MWI]MWIT
                        [M:CST]MATREF([M:CST]NBMAT) = [F:MWI]ITMREF
                        If dim([M:CST]MECCVALMAJ)>0 & dim([F:MWI]ECCVALMAJ)>0
                            [M:CST]MECCVALMAJ([M:CST]NBMAT) = [F:MWI]ECCVALMAJ
                            [M:CST]MECCVALMIN([M:CST]NBMAT) = [F:MWI]ECCVALMIN
                        Endif
                        [M:CST]MLNK([M:CST]NBMAT)   = [F:MWI]VCRLIN
                        [M:CST]MATFLG([M:CST]NBMAT) = max([M:CST]MATFLG([M:CST]NBMAT),1+([F:MWI]MATLEV0<>0))
                        [M:CST]MVCRNUM([M:CST]NBMAT)= [F:MWI]MFGTRKNUM
                        [M:CST]MQTYSTU([M:CST]NBMAT)+= [F:MWI]QTYACT
                        [M:CST]MSTU([M:CST]NBMAT)   = [F:MWI]STU
                        # Issue 114047 - 2016-03-02 by CCC : Use receipt overheads for EO
                        If [M:CTP]VCRTYP=36
                            [M:CST]MOVECOD([M:CST]NBMAT) = func STKVAL.GETOVE( [M:CST]MATREF([M:CST]NBMAT), [M:CST0]STOFCY, 29, LRET ) # EO issue
                        Else
                            [M:CST]MOVECOD([M:CST]NBMAT) = func STKVAL.GETOVE( [M:CST]MATREF([M:CST]NBMAT), [M:CST0]STOFCY, 6, LRET ) # WO issue
                        Endif
                        [M:CST]MOVECOL([M:CST]NBMAT) = [M:CTP]SLTOVECOL
                        [M:CST]MBRDCOD([M:CST]NBMAT) = [F:MWI]MATGRP
                        [M:CST]MCSTCOD([M:CST]NBMAT) = 7
                        [M:CST]SCOFLG([M:CST]NBMAT) = max(1,[F:MWI]SCOFLG)

                        #--------- Alimentation des montants ------------#
                        For I=0 To GACTMAT-1
                            [M:CST]MMATCST([M:CST]NBMAT*GACTMAT+I) += [F:MWI]MATCST(I)
                        Next
                        For I=0 To GACTMAC-1
                            [M:CST]MMACCST([M:CST]NBMAT*GACTMAC+I) += [F:MWI]MACCST(I)
                        Next
                        For I=0 To GACTLAB-1
                            [M:CST]MLABCST([M:CST]NBMAT*GACTLAB+I) += [F:MWI]LABCST(I)
                        Next
                        [M:CST]MSCOCST([M:CST]NBMAT)    += [F:MWI]SCOCST
                        [M:CST]MINVDTA([M:CST]NBMAT)    += [F:MWI]INVDTACST
                        [M:CST]MOVEMATCST([M:CST]NBMAT) += [F:MWI]OVEMATCST
                        [M:CST]MOVEMACCST([M:CST]NBMAT) += [F:MWI]OVEMACCST
                        [M:CST]MOVELABCST([M:CST]NBMAT) += [F:MWI]OVELABCST
                        [M:CST]MOVESCOCST([M:CST]NBMAT) += [F:MWI]OVESCOCST
                    Next
                    [M:CST]NBMAT += 1
                Next
            Endif
        Next
        Filter [MWI]

    When 3:
        Filter [MWI] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & find(TXNTYP,2,3)
&                    Order By Key MWIT=VCRLIN;WST;SETRAT;OPERAT;MFGTRKNUM;MFGTRKLIN
        For [MWI]MWIT(1)
            # Issue 68886 - 2010-11-05 by CCC : On ne récupère que les VCRLIN existant
            If [F:MWI]VCRTYP=10 & [F:MWI]VCRLIN<>0
                Look [MFI]MFI0=[F:MWI]VCRNUM;[F:MWI]VCRLIN
            Else
                Raz fstat
            Endif
            If fstat
                For [MWI]MWIT
                    Break
                Next
            Else
                For [MWI]MWIT(6)
                    If dim([M:CST]WLNK)<=[M:CST]NBWST
                        PRET=3
                        GMESSAGE=mess(563,199,1)
                        Break
                    Endif
                    For [MWI]MWIT
                        [M:CST]WST([M:CST]NBWST)    = [F:MWI]WST
                        [M:CST]WSTTYP([M:CST]NBWST) = find([F:MWI]TXNTYP,3,2)    # txntyp=3=machine ->1 ; txntyp=2=mo ->2
                        [M:CST]WLNK([M:CST]NBWST)   = 0
                        [M:CST]WVCRNUM([M:CST]NBWST)= [F:MWI]MFGTRKNUM
                        [M:CST]WOVECOL([M:CST]NBWST) = [M:CTP]SLTOVECOL
                        [M:CST]WBRDCOD([M:CST]NBWST) = [F:MWI]OPEGRP
                        [M:CST]WCSTTYP([M:CST]NBWST) = [F:MWI]CSTTYP
                        [M:CST]WSETCST([M:CST]NBWST) = [F:MWI]SETRAT
                        [M:CST]WOPECST([M:CST]NBWST) = [F:MWI]OPERAT
                        [M:CST]WSETTIM([M:CST]NBWST) += [F:MWI]CPLSETTIM
                        [M:CST]WOPETIM([M:CST]NBWST) += [F:MWI]CPLOPETIM

                        If [F:MWI]VLTCCE<>""
                            Read [MWC]WCT0 = [F:MWI]VLTCCE;[M:CST0]STOFCY : # lecture de la section de valorisation
                            [M:CST]WOVECOD([M:CST]NBWST) = [F:MWC]OVECOD
                        Else
                            [M:CST]WOVECOD([M:CST]NBWST) = ""
                        Endif

                        #--------- Alimentation des montants ------------#
                        [M:CST]WSETAMT([M:CST]NBWST) += [F:MWI]CSTELM(0)
                        [M:CST]WOPEAMT([M:CST]NBWST) += [F:MWI]CSTELM(1)
                    Next
                    [M:CST]NBWST += 1
                Next
            Endif
        Next
        Filter [MWI]

        ##--- Sous-traitance ---##
        Filter [MWI] Where VCRTYP=[M:CTP]VCRTYP & VCRNUM=[M:CTP]VCRNUM & TXNTYP=4
&                    Order By Key MWIT=VCRLIN;WST;SETRAT;OPERAT;MFGTRKNUM;MFGTRKLIN
        For [MWI]MWIT(1)
            # Issue 68886 - 2010-11-05 by CCC : On ne récupère que les VCRLIN existant
            If [F:MWI]VCRTYP=10 & [F:MWI]VCRLIN<>0
                Look [MFI]MFI0=[F:MWI]VCRNUM;[F:MWI]VCRLIN
            Else
                Raz fstat
            Endif
            If fstat
                For [MWI]MWIT
                    Break
                Next
            Else
                For [MWI]MWIT(6)
                    If dim([M:CST]SLNK)<=[M:CST]NBSCO
                        PRET=3
                        GMESSAGE=mess(563,199,1)
                        Break
                    Endif
                    For [MWI]MWIT
                        [M:CST]SCOWST([M:CST]NBSCO)  = [F:MWI]WST
                        # Issue 116399 - 2016-06-07 by CCC : if EO we need [MWI]VCRLIN to retrieve the record later in FUNWIPMFC.UPDMWIOVE
                        #[M:CST]SLNK([M:CST]NBSCO)    = 0
                        [M:CST]SLNK([M:CST]NBSCO)    = [F:MWI]VCRLIN
                        [M:CST]SVCRNUM([M:CST]NBSCO) = [F:MWI]MFGTRKNUM
                        [M:CST]SOVECOL([M:CST]NBSCO) = [M:CTP]SLTOVECOL
                        [M:CST]SBRDCOD([M:CST]NBSCO) = [F:MWI]OPEGRP
                        [M:CST]SCSTTYP([M:CST]NBSCO) = [F:MWI]CSTTYP
                        [M:CST]SSETCST([M:CST]NBSCO) = [F:MWI]SETRAT
                        [M:CST]SOPECST([M:CST]NBSCO) = [F:MWI]OPERAT
                        [M:CST]SSETTIM([M:CST]NBSCO) += [F:MWI]CPLSETTIM
                        [M:CST]SOPETIM([M:CST]NBSCO) += [F:MWI]CPLOPETIM
                        [M:CST]SQTYSCOITM([M:CST]NBSCO) += [F:MWI]QTY

                        If [F:MWI]VLTCCE<>""
                            Read [MWC]WCT0 = [F:MWI]VLTCCE;[M:CST0]STOFCY : # lecture de la section de valorisation
                            [M:CST]SOVECOD([M:CST]NBSCO) = [F:MWC]OVECOD
                        Else
                            [M:CST]SOVECOD([M:CST]NBSCO) = ""
                        Endif

                        #--------- Alimentation des montants ------------#
                        [M:CST]SSETAMT([M:CST]NBSCO) += [F:MWI]CSTELM(0)
                        [M:CST]SOPEAMT([M:CST]NBSCO) += [F:MWI]CSTELM(1)

                        [M:CST]SCOITMREF([M:CST]NBSCO) = [F:MWI]ITMREF

                        # Issue 77464 - 2011-11-18 by CCC
                        Raz [F:ITF]
                        Read [ITF]ITF0=[M:CST]SCOITMREF([M:CST]NBSCO);[M:CST0]STOFCY
                        [M:CST]SIOVECOD([M:CST]NBSCO) = func STKVAL.GETOVE( [M:CST]SCOITMREF([M:CST]NBSCO), [M:CST0]STOFCY, 3, LRET )    # Réception fournisseur
                        [M:CST]SIOVECOL([M:CST]NBSCO) = [M:CTP]SLTOVECOL

                        [M:CST]PRISCO([M:CST]NBSCO)  += [F:MWI]CSTELM(3)
                        [M:CST]SCSTCOD([M:CST]NBSCO) = 7

                    Next
                    # Issue 87944 - 2013-02-11 by CCC : utilisation de SQTYSCOITM
                    If [M:CST]SQTYSCOITM([M:CST]NBSCO)<>0
                        [M:CST]PRISCO([M:CST]NBSCO) /= [M:CST]SQTYSCOITM([M:CST]NBSCO)
                    Endif
                    # Issue 87944 - 2013-02-11 by CCC
                    If func TRTCST.SUMQTY("P", [M:CST]SLNK([M:CST]NBSCO))=0
                        [M:CST]SCOEQTY([M:CST]NBSCO) = 1
                    Else
                        [M:CST]SCOEQTY([M:CST]NBSCO) = [M:CST]SQTYSCOITM([M:CST]NBSCO) / func TRTCST.SUMQTY("P", [M:CST]SLNK([M:CST]NBSCO))
                    Endif
                    [M:CST]NBSCO += 1
                Next
            Endif
        Next
        Filter [MWI]

Endcase
End

######################################################
# Sous-programme nécessaire à la résolution du cas suivant:
#     Soit 2 articles produits: I1 et I2.
#     Les quantités à produire sont respectivement Qb1 et Qb2
#     Les quantités produites sont respectivement Qp1 et Qp2
#     Dans [M:CST] on connait Qp1 et Qp2 ainsi que les coef C1=Qp1/Qb1 et C2=Qp2/Qb2
#     Soit une matière M nécessaire aux 2 produits (=> pas de lien)
#     La quantité nécessaire de M est Qbm
#     La quantité nécessaire pour produire I1 (resp. I2) est Qbm*Qb1/(Qb1+Qb2) (resp. Qbm*Qb2/(Qb1+Qb2) )
#     Pour connaitre la quantité Qpm de matière qui a théoriquement été nécessaire à la production de I1 et I2
#     Qpm = Qbm*(Qp1+Qp2)/(Qb1+Qb2)
#     or Qb1=Qp1 / C1
#     --> Qpm =  Qbm * (Qp1+Qp2)/(Qp1/C1 + Qp2/C2)
#     Ce /s-pro renvoie sum(Qpi)/sum(Qpi/Ci)
Funprog COEPRO(PLNK)
Value Integer PLNK

Local Decimal LRES
Local Integer LIND
Local Decimal LCOE

LRES = 1
LIND = find(PLNK,[M:CST]ILNK)-1
If LIND<0
    End LRES
Endif

If PLNK>0
    LRES = [M:CST]ICOEPRO(LIND)
Else
# Issue 91569 - 2013-07-31 by CCC : on évite la division par 0 à tous les coups sachant que de toute façon, ICOEPRO=0 ssi IQTYSTU=0
#    LCOE = sigma(0,[M:CST]NBITM-1,[M:CST]IQTYSTU(indcum)/[M:CST]ICOEPRO(indcum)*([M:CST]ITMTYP(indcum)<>2))
    LCOE = sigma(0,[M:CST]NBITM-1,[M:CST]IQTYSTU(indcum)/([M:CST]ICOEPRO(indcum)+([M:CST]ICOEPRO(indcum)=0))*([M:CST]ITMTYP(indcum)<>2))
    If LCOE=0
        LRES=0
    Else
        LRES = func TRTCST.SUMQTY("P",0) / LCOE
    Endif
Endif

End LRES

#################################################
# Recherche le tarif d'un article (service) de sous-traitance
# Le prix est chargé dans [M:CST]PRISCO(PIND)
Funprog RECHTARIF(PITM,PECCMAJ,PECCMIN,PFCY,PQTY,PLIN)
Value Char    PITM
Value Char    PECCMAJ
Value Char    PECCMIN
Value Char    PFCY
Value Decimal PQTY
Value Integer PLIN

End func RECHTARIF2(PITM,PECCMAJ,PECCMIN,PFCY,PQTY,PLIN,date$)

Funprog RECHTARIF2(PITM,PECCMAJ,PECCMIN,PFCY,PQTY,PLIN,PDAT)
Value Char    PITM
Value Char    PECCMAJ
Value Char    PECCMIN
Value Char    PFCY
Value Decimal PQTY
Value Integer PLIN
Value Date    PDAT

If clalev([F:SCS])>0 & [M:CTP]VCRNUM<>""
    Raz [F:SCS]
    Filter [SCS] Where SCONUM=[M:CTP]VCRNUM & SCILIN=PLIN & SRVITMREF=PITM
    Read [SCS] First
    Filter [SCS]
    If [F:SCO]SCONUM<>[M:CTP]VCRNUM
        Read [SCO]SCO0=[M:CTP]VCRNUM
    Endif
    If [F:SCI]SCONUM<>[M:CTP]VCRNUM | [F:SCI]SCILIN<>PLIN
        Read [SCI]SCI0=[M:CTP]VCRNUM;PLIN
    Endif
    End func STKVAL.GETPRITAR(PITM,PECCMAJ,PECCMIN,[F:SCO]POHFCY,[F:SCI]PRHFCY,PQTY,max([F:SCO]ORDDAT,PDAT),[F:SCO]RETDAT,[F:SCO]BPRNUM,[F:SCI]PJT)
Endif

End func STKVAL.GETPRITAR(PITM,PECCMAJ,PECCMIN,PFCY,PFCY,PQTY,PDAT,PDAT,"","")

################################################################################
# Contrôle du paramètre VLTSCEOEXT               (0=erreur; 1=OK)   module ACH #
################################################################################
Subprog VERF_PARAM(PPARAM,PVAL,PRET)
Value Char PPARAM
Value Char PVAL
Variable Integer PRET

PRET=1
If PVAL="" : End : Endif
If find(PPARAM,"VLTSCEOEXT")
    If !find(PVAL,"1","2","7","12")
        PRET=0
        GMESSAGE=mess(83,123,1)
    Endif
Endif
End

############################################################
# ISMAT : Indique si un article est une matière
############################################################
# Parametres E : PITM = code article
#                PALTTYP = type de nomenclature
#                PALT = n° alternative
#                PDAT = date de validité
#            S : 1 = c'est une matière
#                0 = ce n'est pas une matière
############################################################
Funprog ISMAT(PITM,PALTTYP,PALT,PDAT)
Value Char PITM
Value Integer PALTTYP
Value Integer PALT
Value Date PDAT

Local Integer LMATFLG
LMATFLG = 0

If clalev([F:BOD])=0 : Local File BOMD [BOD] : Endif

    Filter [BOD] Where ITMREF = PITM
&                    & (BOMALTTYP = PALTTYP | PALTTYP=0)
&                    & (BOMALT = PALT | PALT=0)
&                    & ( BOMSTRDAT<=PDAT
&                      & (BOMENDDAT>=PDAT | BOMENDDAT=[0/0/0])
&                      | PDAT=[0/0/0])
    Look [BOD] First
    If fstat & find(PALTTYP,2,3)
        Filter [BOD] Where ITMREF = PITM
&                        & BOMALTTYP = 5-PALTTYP
&                        & (BOMALT = PALT | PALT=0)
&                        & ( BOMSTRDAT<=PDAT
&                          & (BOMENDDAT>=PDAT | BOMENDDAT=[0/0/0])
&                          | PDAT=[0/0/0])
        Look [BOD] First
        If fstat
            LMATFLG=1
        Endif
    Endif
    Filter [BOD]

End LMATFLG

# Issue 89664 - 2014-09-12 by CCC
#**----------------------------------------------------------------<br/>
#* GETROUALT : return routing code
#**<br/>----------------------------------------------------------------<br/>
# @param PITM = item
# @param PFCY = site
# @param PBOMALT = BOM code
# @param PITMROU = routing item code
# @param PROUALT = routing code
#**<br/>----------------------------------------------------------------
Subprog GETROUALT(PITM, PFCY, PBOMALT, PROUALTDEF, PITMROU, PROUALT)
Value Char PITM
Value Char PFCY
Value Integer PBOMALT
Value Integer PROUALTDEF
Variable Char PITMROU
Variable Integer PROUALT

Local Char ITM_ROU(GLONITM)
Local Integer ROU_ALT

If PITM<>[F:ITF]ITMREF | PFCY<>[F:ITF]STOFCY
    Read [F:ITF]ITF0 = PITM;PFCY
Endif

# Priority to [F:ITF]CSTROU before the item
For LITM=[F:ITF]CSTROU,PITM
    If LITM<>""
        # Either the routing code is known and it has to be OK...
        If PROUALTDEF<>0
            Look [F:ROH]ROH0=LITM;PROUALTDEF;PFCY
            If !fstat
                PITMROU = LITM
                PROUALT = PROUALTDEF
                Break
            Endif
        Else
            # ... or default values are used: [F:ITF]CSTROUALT and after BOM code
            For LALT=[F:ITF]CSTROUALT,PBOMALT
                If LALT<>0
                    Look [F:ROH]ROH0=LITM;LALT;PFCY
                    If !fstat
                        PITMROU = LITM
                        PROUALT = LALT
                        Break 2
                    Endif
                Endif
            Next
        Endif
    Endif
Next

End

