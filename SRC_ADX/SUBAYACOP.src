#<AdxTL>@(#)10.0.0.0 $Revision$
######################################################################################
##  Xtend: Copie fiche Action
##  Version 0001
######################################################################################
#    GACTION
#        AYSCOP        Copie d'une donnée Xtend
#        AYSFCYCOP     Copie globale d'un site
#    [L]
#        FCYORG, DOSORG
#        FCYDES, DOSDES, CODACTDES
#        ELTCOD
#    [F:AYS1] Site origine       Ouvert et lu
#    [F:AYS2] Site destination   Ouvert et lu
######################################################################################
$TRTCOP
If [L]DOSORG=nomap
 Local File AYTACT    [AYA1]
 Local File ATEXTE    [ATX1]
 Local File AYTLINES  [AYN1]
 Local File ATEXTRA   [AXX1]
Else
 Local File =[L]DOSORG+".AYTACT"     [AYA1]
 Local File =[L]DOSORG+".ATEXTE"     [ATX1]
 Local File =[L]DOSORG+".AYTLINES"   [AYN1]
 Local File =[L]DOSORG+".ATEXTRA"    [AXX1]
Endif
If [L]DOSDES=nomap
 Local File AYTACT     [AYA2]
 Local File ATEXTE     [ATX2]
 Local File AYTLINES   [AYN2]
 Local File ATEXTRA    [AXX2]
Else
 Local File =[L]DOSDES+".AYTACT"     [AYA2]
 Local File =[L]DOSDES+".ATEXTE"     [ATX2]
 Local File =[L]DOSDES+".AYTLINES"   [AYN2]
 Local File =[L]DOSDES+".ATEXTRA"    [AXX2]
Endif

Read [AYA1]AYA0 = [L]FCYORG;[L]ELTCOD
If fstat
  OK=0
  Call RSTA("AYA1",[L]FCYORG-[L]ELTCOD) From GLOCK
  Goto FINALLY
Endif

Read [AYA2]AYA0 = [L]FCYDES;[L]ELTCOD
DES_ELTCOD=[F:AYA2]ACTCOD : Gosub MSGDESOBJ From AYTCOP
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif


$FINALLY
Close Local File [AYA1], [ATX1], [AYN1] , [AXX1]
&              , [AYA2], [ATX2], [AYN2] , [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [AYA2] , [ATX2], [AYN2]
 If DES_HASELT
  Delete [AYN2] Where FCYCOD=[L]FCYDES  & LINCODTYP=3 & LINCOD=toupper([L]DES_ELTCOD)
  If fstat=1
   GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTLIN" : Goto ROLL_TR_COP
  Elsif fstat>5
   GOK = 0 : Call RSTA("AYN2","") From GLOCK : Goto AB_TR_COP
  Endif
#  Delete [AYA2] Where FCYCOD=[L]FCYDES & ACTCOD=[L]ELTCOD
  Delete [AYA2] Where FCYCOD=[L]FCYDES and ACTCOD=[L]DES_ELTCOD
  If fstat=1
   GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTACT" : Goto ROLL_TR_COP
  Elsif fstat>5
   GOK = 0 : Call RSTA("AYA2","") From GLOCK : Goto AB_TR_COP
  Endif
 Endif
 #
 For [AYA1]AYA0 Where FCYCOD=[L]FCYORG & ACTCOD=[L]ELTCOD
  [F:AYA2] = [F:AYA1]
  [F:AYA2]FCYCOD = [L]FCYDES
  Call COPTEXTRA("AYTACT","INTIT",[F:AYA1]FCYCOD,[F:AYA1]ACTCOD,[L]FCYDES) From SUBAYS
  If GOK<1 : Break : Endif
  Call COPTEXTRA("AYTACT","INTITDES",[F:AYA1]FCYCOD,[F:AYA1]ACTCOD,[L]FCYDES) From SUBAYS
  If GOK<1 : Break : Endif
  [F:AYA2]UPDUSR = GUSER
  [F:AYA2]UPDDAT = date$
  # [F:AYA2]UPDTIM = time  - 93575
  Call SET_UPDTIM("AYA2") From AYTCOP # 93575
  [F:AYA2]BRWX3  = [F:AYA2]FCYCOD+"_"+[F:AYA2]ACTCOD
 #* [F:AYA2]CODACT = [L]ELTCODACT
  Write [AYA2]
  If fstat
   GOK=0 : Call FSTA("AYA2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 #
 For [AYN1]AYN0 Where FCYCOD=[L]FCYORG & LINCODTYP=3 & LINCOD=toupper([L]ELTCOD)
  [F:AYN2] = [F:AYN1]
  [F:AYN2]FCYCOD = [L]FCYDES
  Write [AYN2]
  If fstat
   GOK=0 : Call FSTA("AYN2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
