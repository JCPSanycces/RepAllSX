#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char PARAM(40)(1..3) , VALEUR(40)
VALEUR   = "LYON"
PARAM(1) = "Place Bellecour"
PARAM(2) = "France"
Call SAISIE_CHAR(VALEUR,PARAM,"AVISUPLAN","AVISUPLAN","") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE" : Gosub OUVRE
 When "DEBUT" : Gosub DEBUT
 When "FIN"   : Gosub FIN
Endcase
Return

$OUVRE
If GMAPDSP="" : FIN = 1 : Endif
Return

$DEBUT
Effzo [M]
[M]CITY    = VALEUR
[M]STREET  = PARAM(1)
[M]COUNTRY = PARAM(2)
If dim([M]ZIPCOD)>0
 [M]ZIPCOD  = PARAM(3)
Endif
Affzo [M]
Inftxt evalue(GMAPDSP) At 1
Return

$FIN
Inftxt "" At 1
Return

Subprog BOUTPLAN
If GMAPDSP="" : GBOUT1 = "" : Endif
End

