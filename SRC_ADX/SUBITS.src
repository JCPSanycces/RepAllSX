$ACTION
Case ACTION
 When Default
Endcase
Return

Subprog AM_SBSITM(VALEUR)
Variable Char     VALEUR
If VALEUR = ""
   [M:ITS]SBSDAT = [0/0/0]
   [M:ITS]SBSITMDES = ""
   If !GIMPORT
      Affzo SBSDAT, SBSITMDES
   Endif
Else
   #Call LECTEXTRA([M:ITS]SBSITMDES,"ITMMASTER","DES1AXX",VALEUR,"") From ATEXTRA
   Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,VALEUR,[M:ITS]SBSITMDES, "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
   Affzo [M:ITS]SBSITMDES
Endif
End

Subprog AM_PCK(VALEUR)
Variable Char     VALEUR
If VALEUR = ""
   [M:ITS]PCKCAP = 0
   If !GIMPORT
      Affzo PCKCAP
   Endif
Endif
End

Subprog C_SBSITM(VALEUR)
Variable Char     VALEUR

# FGR 26/06/2009 : X3SUIVI56124 (début)
# NE PAS METTRE LE TYPE ITM SUR CETTE ZONE, SINON LES AUTOMATISMES CASSENT LA
# CLASSE [F:ITM] en cours !!!!!
Local File ITMMASTER [ITM2]
# FGR 26/06/2009 : X3SUIVI56124 (fin)

Local File ITMCATEG  [ITG2]
If VALEUR <> ""
 #Read [ITM]ITM0=VALEUR
 Read [ITM]ITM0=VALEUR  # FGR 26/06/2009 : X3SUIVI56124
 If fstat
    mkstat = 2
    GMESSAGE = mess(23,100,1) # Fiche inexistante
 Else
   #Read [ITG2]ITG0="";[F:ITMV]TCLCOD : # Bug 2949
   Read [ITG2]ITG0="";[F:ITM2]TCLCOD : # FGR 26/06/2009 : X3SUIVI56124  # Bug 2949
   If !fstat & [F:ITG2]SALFLG = 1
    mkstat = 2
    GMESSAGE = mess(221,199,1)
     #  "l'article doit être de catégorie vendue"
    End
   Endif
 Endif
Endif
If VALEUR = [M:ITM0]ITMREF & [M:ITM0]ITMREF <> ""
   mkstat = 2
Endif
End

########################################
Subprog C_CTMFLG(VALEUR)
Variable Integer VALEUR
If [M:ITM4]PRQFLG=2 & VALEUR=2
   GMESSAGE=mess(164,196,1) : VALEUR=1 : mkstat=2
Endif
End

########################################
Subprog AM_CTMFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
   [M:ITS]CTMQTY = 0
   If !GIMPORT
      Affzo CTMQTY
   Endif
Endif
End

########################################
Subprog AV_ITSSAU(VALEUR)
Variable Char     VALEUR
If clalev([F:IM1]) & [F:IM1]SAU<>""
    VALEUR = [F:IM1]SAU
Elsif clalev([F:ITM]) & [F:ITM]SAU<>""
    VALEUR = [F:ITM]SAU
Elsif clalev([M:ITM3])
    VALEUR = [M:ITM3]SAU
Endif
End

Subprog AS_SBSDAT(VALEUR)
Variable Date     VALEUR
If [M:ITS]SBSITM = "" mkstat=2 Endif
End
Subprog AS_PCKCAP(VALEUR)
Variable Decimal  VALEUR
If [M:ITS]PCK = "" mkstat=2 Endif
End

