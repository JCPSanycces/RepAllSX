##########################################################################
## Etiquette ajoutée par le superviseur 28/05/2003 10:42:56 (TB)
##########################################################################
Subprog C_SBSDAT(VALEUR)
Variable Date    VALEUR
If VALEUR = [0/0/0] & [M:ITS]SBSITM <> ""
  mkstat = 2 : GMESSAGE = mess(10,123,1) # date obligatoire
Endif
End


