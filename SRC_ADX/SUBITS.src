######################################################################################
## Etiquette ajoutée par le superviseur (écran ITS) 25/04/2013 15:16:42 (MUARN)
######################################################################################
# Issue 10401 - 2011-12-09 by MUARN : orige prix de base vente possibilité % achat
Subprog AM_BASPRIORI(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
  [M:ITS]PURPRIPRC = 0
  Affzo [M:ITS]PURPRIPRC
  Diszo [M:ITS]PURPRIPRC
  Actzo [M:ITS]BASPRI
Else
  [M:ITS]BASPRI = [M:ITM4]PURBASPRI * (1+[M:ITS]PURPRIPRC/100)
  Affzo [M:ITS]BASPRI
  Actzo [M:ITS]PURPRIPRC
  Diszo [M:ITS]BASPRI
Endif
End

# Issue 10401 - 2011-12-09 by MUARN : prix vente de base en fonction prix base achat
Subprog AM_PURPRIPRC(VALEUR)
Variable Decimal VALEUR
[M:ITS]BASPRI = [M:ITM4]PURBASPRI * (1+VALEUR/100)
Affzo [M:ITS]BASPRI
End

######################################################################################
## 107890 : Scheduled invoices : (LC:31/10/16)
######################################################################################
Subprog C_ITMTYP(VALEUR)
Variable Integer VALEUR
   If [M:ITM1]DLVFLG=1 & VALEUR=3
      mkstat=2: GMESSAGE = mess(544,192,1) # Type not allowed for this product with a non deliverable service category type
   Endif
End
# 107890 : Scheduled invoices : (LC:31/10/16) (End)
