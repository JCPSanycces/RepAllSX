####################################################################################

Subprog ADCCTRUPC(AZC)
Variable    Char    AZC
#-----
#--- Bug 65499
If GVTMOD=0 End Endif
#--- Cette action n'est active que si l'on est en mode VT
If AZC<>""
  If !clalev([F:XITM])  Local File ITMMASTER [XITM] : Endif
  Local Char WITMREF(GLONITM)
  WITMREF=toupper(AZC)
  Read [F:XITM]ITM0 = WITMREF
  If !fstat
    AZC=WITMREF
  Else
    Filter [XITM] Where EANCOD=AZC
    Read [F:XITM] First
    If !fstat
      AZC=[F:XITM]ITMREF
    Else
      GERR=1 : GMESSAGE=mess(40,7750,1): mkstat=2
    Endif
    Filter [XITM]
  Endif
Endif
#-----
End


