#<AdxTL>@(#)12.0.0.0 $Revision$
Call OBJET ("SCP", GBIDC1, GBIDC2) From GOBJET
End

##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "FERME"        : Gosub FERME
    When "SETBOUT"      : Gosub SETBOUT
    When "AVANTBOUT"    : Gosub AVANTBOUT
    When "LIENS"        : Gosub LIENS
    When "RAZCRE"       : Gosub RAZCRE
    When "RAZDUP"       : Gosub RAZDUP
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "INICRE"       : Gosub INICRE
    When "CREATION"     : Gosub CREATION
    When "APRES_CRE"    : Gosub APRES_CRE
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "INIMOD"       : Gosub INIMOD
    When "MODIF"        : Gosub MODIF
    When "VERF_ANU"     : Gosub VERF_ANU
    When "AV_ANNULE"    : Gosub AV_ANNULE
    When "ANNULE"       : Gosub ANNULE
    When "APRES_MOD"    : Gosub APRES_MOD
    When "FILTRE"       : Gosub FILTRE
    When "FILGAUCHE"    : Gosub FILGAUCHE
    When "AVANT_CHOI"   : Gosub AVANT_CHOI
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BB3_NBSCQ"    : Gosub BB3_NBSCQ
    When default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GIRELITOBJ

  GIRELITOBJ = 0
Return

##########################################################################################################
$OUVRE_BOITE
  # Rien n'est saisissable depuis cet écran
  Gosub GRISE_TOUT
Return

##########################################################################################################
$GRISE_TOUT
  # Rien n'est saisissable depuis cet écran
  Diszo [M:SCP8]5
  Diszo [M:SCP8]10
  Diszo [M:SCP8]15
  Diszo [M:SCP8]20
  #
  Grizo [M:SCP8]25
  Grizo [M:SCP8]30
  Grizo [M:SCP8]35
  Grizo [M:SCP8]40
  #
  Diszo [M:SCP8]45
Return

##########################################################################################################
$FERME
  Kill GIRELITOBJ
Return

##########################################################################################################
$SETBOUT
  # Pas de création depuis ici
  Call VIREBOUT (CHAINE,"C") From GOBJET
  If REP <> "" Then 
    # Accès à [Nouveau] uniquement en consultation
    Call VIREBOUT (CHAINE, "UV") From GOBJET
  Endif
  Call VIREBOUT(CHAINE,"H") From GOBJET # FGR 14/06/2010 : X3SUIVI65270
Return

##########################################################################################################
$AVANTBOUT
Return

##########################################################################################################
$LIENS
  GIRELITOBJ = 0
  If [M:SCP0]SCPFLG = 1 Then
    [M:SCP0]ACTIF = 2
  Else
    [M:SCP0]ACTIF = 1
  Endif
  Gosub LOAD_SCQ From SUBSCPB
Return

##########################################################################################################
$RAZCRE
Return

##########################################################################################################
$RAZDUP
Return

##########################################################################################################
$VERIF_CRE_MOD
  If [M:SCP0]ACTIF = 2 Then
    [M:SCP0]SCPFLG = 1
  Else
    [M:SCP0]SCPFLG = 2
  Endif
Return

##########################################################################################################
$VERIF_CRE
  Gosub VERIF_CRE_MOD
Return

##########################################################################################################
$INICRE
Return

##########################################################################################################
$CREATION
Return

##########################################################################################################
$APRES_CRE
Return

##########################################################################################################
$VERIF_MOD
  Gosub VERIF_CRE_MOD
Return

##########################################################################################################
$INIMOD
Return

##########################################################################################################
$MODIF
  # On n'a le droit de modifier la partie questionnaire ici
  # donc la seule chose enregistrable c'est l'entête.
  # Par conséquent, rien de spécial à faire ici.
Return

##########################################################################################################
$APRES_MOD
  # FGR 03/09/2008 : X3SUIVI46675 : Je l'avais mis en APRES_MODIF. C'est pas le bon endroit je crois !
  Gosub RELIT From GOBJSUB
Return

##########################################################################################################
$VERF_ANU
Local Char SZMESS(250)
Local Integer IOKREP

  If [M:SCP0]SCPNUM = "" Then
    GERR = 1
    OK = 0
    End
  Else
    SZMESS = mess(644,196,1) - mess(645,196,1) - mess(646,196,1)
    IOKREP = 0
    # La suppression d'un script d'appel élimine également toutes les réponses enregistrée dans le questionnaire associé.
    # Il ne sera alors plus possible de réaliser des analyses marketing ultérieures sur ces réponses.
    # Confirmez-vous cette suppression ?
    Call OUINON(SZMESS, IOKREP) From GESECRAN
    If IOKREP <> 2 Then
      GERR = 1
      OK = 0
    Endif
  Endif
Return

##########################################################################################################
$AV_ANNULE
Return

##########################################################################################################
$ANNULE
Return

##########################################################################################################
$FILTRE
Return

##########################################################################################################
$FILGAUCHE
Return

##########################################################################################################
$AVANT_CHOI
Return

##########################################################################################################
$APRES_MODIF
  If GIRELITOBJ = 1 Then
    Gosub RELIT From GOBJSUB
    OK = 0
    GIRELITOBJ = 0
  Endif
Return

##########################################################################################################
$BB3_NBSCQ
  If GIRELITOBJ = 1 Then
    mkstat = 4
  Endif
Return

##########################################################################################################
$TRTCOP
  #-----------------------------------------------------------#
  # Etiquette appelée depuis le traitement superviseur ACOPIE #
  # --------------------------------------------------------- #
  # Traitement de la copie d'un script d'appel                #
  #-----------------------------------------------------------#
  If [M]DOSORG = nomap Then
    Local File SCRIPT [SCP1]
    Local File SCPQST [SCQ1]
    Local File SCPQSTCND [SQC1]
  Else
    Local File =[M]DOSORG+".SCRIPT" [SCP1]
    Local File =[M]DOSORG+".SCPQST" [SCQ1]
    Local File =[M]DOSORG+".SCPQSTCND" [SQC1]
  Endif
  If [M]DOSDES = nomap Then
    Local File SCRIPT [SCP2]
    Local File SCPQST [SCQ2]
    Local File SCPQSTCND [SQC2]
  Else
    Local File =[M]DOSDES+".SCRIPT" [SCP2]
    Local File =[M]DOSDES+".SCPQST" [SCQ2]
    Local File =[M]DOSDES+".SCPQSTCND" [SQC2]
  Endif
  OK = 1
  Look [SCP2]SCP0=TABLE
  If !fstat Then
    OK = 2
    Call AVERTIR([M]DOSDES-TABLE-mess(148,196,1),OK) From GESECRAN
    If OK<>2 Then
      OK = 0
    Endif
  Endif
  If OK Then
    Call DEBTRANS From GLOCK
    Gosub TRT_COPIE
  Endif
  Close Local File [SCP1], [SCQ1], [SQC1], [SCP2], [SCQ2], [SQC2]
Return

##########################################################################################################
$TRT_COPIE
  #--------------------------------------------------#
  # Transaction de copie d'un script d'appel         #
  #--------------------------------------------------#
  GOK = 1
  Trbegin [SQC2]
  Delete [SQC] Where SCPNUM=TABLE
  If fstat = 1 Then
    GOK = -1  
    GLOCK="$"+[M]DOSDES+".SCPQSTCND"-TABLE  
    Goto ROLL_COPIE
  Elsif fstat 
    GOK = 0 
    Call RSTA("SQC2",TABLE) From GLOCK   
    Goto AB_COPIE
  Endif
  Delete [SCQ2] Where SCPNUM=TABLE
  If fstat=1 
    GOK=-1  
    GLOCK="$"+[M]DOSDES+".SCPQST"-TABLE  
    Goto ROLL_COPIE
  Elsif fstat 
    GOK = 0 
    Call RSTA("SCQ2",TABLE) From GLOCK   
    Goto AB_COPIE
  Endif
  Delete [SCP2] Where SCPNUM=TABLE
  If fstat=1 
    GOK=-1  
    GLOCK="$"+[M]DOSDES+".SCRIPT"-TABLE  
    Goto ROLL_COPIE
  Elsif fstat 
    GOK = 0 
    Call RSTA("SCP2",TABLE) From GLOCK   
    Goto AB_COPIE
  Endif
  If GOK = 1
    Read [SCP1] SCP0=TABLE
    If !fstat
      [F:SCP2] = [F:SCP1]
      Write [SCP2]
      If fstat 
        GOK = 0  
        Call FSTA("SCP2") From GLOCK  
        Goto AB_COPIE  
      Endif
    Endif
  Endif
  If GOK = 1
    Filter [SCQ1] Where [F:SCQ1]SCPNUM = TABLE
    For [SCQ1]
      [F:SCQ2] = [F:SCQ1]
      Write [SCQ2]
      If fstat 
        GOK = 0  
        Call FSTA("SCQ2") From GLOCK  
        Goto AB_COPIE  
      Endif
    Next
    Filter [SCQ1]
  Endif
  If GOK
    Filter [SQC1] Where [F:SQC1]SCPNUM=TABLE
    For [SQC1]
      [F:SQC2] = [F:SQC1]
      Write [SQC2]
      If fstat 
        GOK = 0  
        Call FSTA("SQC2") From GLOCK  
        Goto AB_COPIE  
      Endif
    Next
    Filter [SQC1]
  Endif
  Commit
Return

##########################################################################################################
#----- Abandon de la copie -----#
$AB_COPIE
  Rollback 
Return

##########################################################################################################
#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
  Rollback 
  Call ROLL From GLOCK  
  If !GROLL Then
    Goto TRT_COPIE 
  Endif 
Return

######################################################################################
Subprog AM_ACTIF(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    [M:SCP0]SCPFLG = 1
  Else
    [M:SCP0]SCPFLG = 2
  Endif
End

######################################################################################
Subprog AS_NBSCQ
Local Integer NUMLIG

  If GREP <> "" Then
    # Le  bouton [Questionnaire] accessible uniquement en consultations
    Raz GBOUT2
  Endif
  NUMLIG = nolign-1
  Call AFFICHE_QUESTION(NUMLIG) From SUBSCPB
End

######################################################################################
Subprog AS_NBCND
Local Integer NUMLIG

  NUMLIG = nolign-1
  Call AFFICHE_CONDITION(NUMLIG) From SUBSCPB
End
