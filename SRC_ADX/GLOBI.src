  Gosub CALCUL_DLT_GLOBALES

  # Affectation de code retour
  RERROR = [M:DIV]ERROR

  #--
  # Fermeture écran CALDIV
  # FQ67110
  #If (clalev([M:DIV]))  Then : Close Local Mask [DIV]  : Endif : # Infos diverses
  If (clalev([M:DIV]) and !(G_CDIVOPN) ) Then : Close Local Mask [DIV] : Endif : # Infos diverses
  If (clalev([M:DIV2]) and !(G_CDIVOPN)) Then : Close Local Mask [DIV2] : Endif : # Infos diverses FQ77877
  If (dim(G_CDIVOPN) >0) Then : Kill G_CDIVOPN  : Endif
End

# FQ53209
#====
Subprog EVALUE_PERIODE_COURANTE_PLAN (PPLN, PMSK, RPC)
  Value Integer    PPLN  : # Plan
  Value Char       PMSK  : # Abréviation du masque de type [M:DEP] pour le plan donné
  Variable Date    RPC   : # Période courante

  Local Integer I_PLN
  I_PLN = find(PPLN, [M:DIV]PLNCAA)
  # Détermination du contexte
  Local Integer LCNX
  LCNX  = [M:DIV]PLNCNT(I_PLN-1)
  # Détermination du masque Exercice en fonction du Contexte
  Case LCNX
    When G300CPFI : LCLAS = "[M:EGCF]"
    When G300IAS  : LCLAS = "[M:EIAS]"
    When G300TEC  : LCLAS = "[M:ETEC]"
    When G300RET  : LCLAS = "[M:ERET]"
    When G300SUB  : LCLAS = "[M:ESUB]"
    When G300LIB  : LCLAS = "[M:ELI1]"
    When G300SU1  : LCLAS = "[M:ELI2]"
    When G300SU2  : LCLAS = "[M:ELI3]"
    When G300SU3  : LCLAS = "[M:ELI4]"
    When G300SU4  : LCLAS = "[M:ELI5]"
    When G300SU5  : LCLAS = "[M:ELI6]"
    When Default  : LCLAS = "[M:EGCF]"
  Endcase

  # Calcul de l'indice de la période courante

  # Exemple sur le contexte fiscal et comptable
  #   RPC = [M:EGCF]DATSTRPER( [M:EGCF]INDDEBPER(find( GVML_TECOURA, [M:EGCF]STAFIY )-1)+
  # &                          [M:EGCF]INDCURPER(find( GVML_TECOURA, [M:EGCF]STAFIY )-1)   -2 )
  Local Integer IEC, IDP, ICP, IND
  # FQ57530
  # IEC   = find( GVML_TECOURA, evalue(LCLAS+"STAFIY") )
  IEC   = evalue("find(GVML_TECOURA,"+LCLAS+"STAFIY"+")" )
  IDP   = evalue(LCLAS+"INDDEBPER("+num$(evalue(num$(IEC)+"-1"))+")")
  ICP   = evalue(LCLAS+"INDCURPER("+num$(evalue(num$(IEC)+"-1"))+")")
  IND   = IDP + ICP -2
  RPC   = evalue( LCLAS+"DATSTRPER("+num$(evalue(num$(IND)))+")")

End


#*********************************************************************
#*********************************************************************
#           CALCULER_SOCIETE
#*********************************************************************
#*********************************************************************


#########################################################
Subprog CALCULER_SOCIETE (PCPY, PTABFCY, PTABCNT, PFASCLC, RERROR)
#
# - Objet  : Calcul une société.
#            Sont concernés :
#                 - les biens des sites à calculer
#                 - les plans d'amortissement des contextes à calculer.
#
# - Entrée : Société
#            Tableau des sites     à calculer
#            Tableau des contextes à calculer
#            Indicateur recalcul des biens forcé FQ88613
#
#
# - Sortie : Code Erreur
#                 0 = Calcul société OK
#                -1 = Erreur calcul société
#                -2 = Erreur dépassement du temps limite
#                -3 = Erreur verrouillage OK
#
#            !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
#            Points d'entrée du calcul
#            CALCULER_SOCIETE     de GLOBB ( avec CALCULER_SOCIETES de FASCALC)
#            CALCULER_BIEN        de GLOBB
#            SIMULER_CALCUL_BIEN  de GLOBB
#            SIMULER_VALEUR_NETTE de GLOBB
#            !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
#

Value    Char    PCPY
Value    Char    PTABFCY()
Value    Integer PTABCNT()
Value    Integer PFASCLC
Variable Decimal RERROR

  #If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # RERROR contient le statut "erreur" passé en retour à FASCALC
  RERROR        = 0

  #-- Traitement demandeur
  [M:DIV]TRTDEM    = "CALSOC"
  # Concessions gérée - FQ54343
  Local Integer BGESCCN : BGESCCN = func AFNC.ACTIV("CCN") : [M:DIV]BACTCCN = BGESCCN
  # Localisation Polonaise - FQ67577
  Local Integer BGESKPL : BGESKPL = func AFNC.ACTIV("KPL") : [M:DIV]BACTKPL = BGESKPL
  #-- Création des globales
  Gosub CALCUL_CRT_GLOBALES

  [M:DIV]TRTLVL = 0
  [M:DIV]ERRID  = 0
  Raz [M:DIV]LVLID : [M:DIV]LVL= 0 : [M:DIV]LVLLIB= ".CALCULER_SOCIETE" : Gosub CAL_ADDLVL From =G_GLOB0
  [M:DIV]ERROR  = 0
  [M:DIV]SOC    = PCPY                    : # Société courante
  [M:DIV]PROPLN = ""                      : # Plan de production à charger
  [M:DIV]BONUS  = 0                       : # Bonus russe à charger FQ59941
  G_BERRDER     = 0                       : # Erreur derogatoire FQ82293
  [M:DIV]BCO    = ""  : #FQ79813a


  # Passage en mode first row FQ79813
  Gosub SET_FIRST From TRTFIRST

  #--
  # Ouverture des fichiers
  If clalev([F:CPY])  = 0 : Local File COMPANY     [CPY]  : Endif : # Société
  # Initialisation titre fenêtre de suivi "Calcul Société : xxx"
  Call TEMPON(mess(78,7774,1)-PCPY) From GESECRAN
  #--
  # Société : xxx aaaaaaaaaaaaaaaaaaaaa
  Filter [CPY] Where CPY=PCPY : Read [CPY]CPY0 Last : Filter [CPY]
  Call ECR_TRACE(string$(80, '-')+"\",0) From =G_GLOB0
  Call ECR_TRACE(mess(22,7774,1)-num$(PCPY)-num$([F:CPY]CPYNAM)+"\",0) From =G_GLOB0

  #--
  #-- Modif du statut de calcul des biens si modifs de paramètrage.
  #--
  Local Integer I_CNX
  Local Integer RCOD
  For I_CNX = 0 To dim(PTABCNT)-1
    If (PTABCNT(I_CNX)) Then
      #Call UPD_WAI_TRT(PCPY,PTABCNT(I_CNX),1,"*",RCOD) From UPDWAITRT : # FQ66894
      Call UPD_WAI_TRT(PCPY,PTABCNT(I_CNX),1,"*","CAL",RCOD) From UPDWAITRT
      If (RCOD) Then : Break : Endif : # FQ79813a
    Endif
  Next N_I
  If (RCOD) Then : RERROR = -1 : End : Endif

  #--
  #-- Mise à niveau des informations d'optimisation du calcul. selon paramètre CALTRACE
  #--
  Local Integer RCOD
  Local Char LPARAM
  Call PARAM("","CALTRACE",LPARAM) From ADOVAL
  If (LPARAM <> "" and val(LPARAM) = 10 ) Then
    Call CAL_OPTIMISATION (PCPY, RCOD) From =G_GLOB0
    If (RCOD) Then : RERROR = -1 : End : Endif
  Endif

  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  # E   Point d'entrée    SOCLCKCAL               E
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
#CHECK IGNORE_BEGIN
  Local Integer B_SOCLCK : B_SOCLCK = 1
  If ( G_ETP_GLOBI ) Then : # FQ114113
    GPOINT = "SOCLCKCAL"
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9000 : End
    Endif
  Endif
#CHECK IGNORE_END
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

  #--
  # Verrouillage Société ( les contextes puis les biens)
  #----------------------------------
  If (B_SOCLCK) Then
    #----------------------------------
  If ( func GLOBIENS.LOCK_SYMBOLE ("CNX", PCPY, "", 0) = 0 ) Then
    RERROR = -3
    Call ECR_TRACE(mess(107,7774,1),1) From =G_GLOB0
  #----------------------------------
  Else
    [M:DIV]TRTLVL = 1
    If ( dim(GFILTRE_FAS) < 0 )  Then
      # Lorsque GFILTRE_FAS existe, le calcul est appelé depuis une action.
      # Dans ce cas, elle a pris en charge le verrouillage des biens à traiter.
      If ( func GLOBIENS.LOCK_SYMBOLE ("FAS", PCPY, "", 0) ) = 0 Then
        RERROR = -3
        Call ECR_TRACE(mess(107,7774,1),1) From =G_GLOB0
      Endif
    Endif
    [M:DIV]TRTLVL = 2
  Endif
  #----------------------------------
  Endif
  #----------------------------------

  #-1 ---------------------------------
  If ( RERROR = 0 ) Then
    #--
    # Ouverture Fichier  Bien comptable , Plan d'amortissement
    If clalev([F:WFAS])=0  : Local File FXDASSETS     [WFAS]  :  Endif        : # Biens comptables
    If clalev([F:WDEP])=0  : Local File DEPREC        [WDEP]  :  Endif        : # Plans d'amortissement
    If clalev([F:DEPC])=0  : Local File DEPREC        [DEPC]  :  Endif       : # DEPREC courant FQ79813
    If clalev([F:DEPS])=0  : Local File DEPREC        [DEPS]  :  Endif       : # DEPREC suivant FQ79813
    If clalev([F:SEPC])=0  : Local File DEPREC        [SEPC]  :  Endif       : # DEPREC courant FQ79813
    If clalev([F:SEPS])=0  : Local File DEPREC        [SEPS]  :  Endif       : # DEPREC suivant FQ79813
    # FQ54343
    If ([M:DIV]BACTCCN) Then
      If clalev([F:WRPR])=0  : Local File CCNRPR      [WRPR]  :  Endif        : # Provisions pour renouvellement
      If clalev([F:RPRC])=0  : Local File CCNRPR      [RPRC]  :  Endif        : # Provisions pour renouvellement FQ79813
      If clalev([F:RPRS])=0  : Local File CCNRPR      [RPRS]  :  Endif        : # Provisions pour renouvellement FQ79813
    Endif
    # FQ79813
    If clalev([F:WFCY])=0  : Local File FACILITY     [WFCY]  :  Endif        : # Sites
    #--
    [M:DIV]LVLLIB = ".CALCUL_SOCIETE_PREPARE" : Gosub CAL_ADDLVL  From =G_GLOB0
    Gosub CALCUL_SOCIETE_PREPARE From =G_GLOB
    #-1 ------
    If ([M:DIV]ERROR) Then
      # Erreur logique
      Call CAL_ERREUR("", "", 0, 0) From=G_GLOB0
      # Résultat du traitement : Echec
      Call ECR_TRACE(mess(58,7774,1)-mess(60,7774,1),1) From =G_GLOB0
    Else
      [M:DIV]LVLLIB = ".CALCULER_SOCIETE_BIENS" : Gosub CAL_ADDLVL  From =G_GLOB0
      Local Integer    PTABPLN(0..G301MAX-1)  : # FQ79856 FQ88613
      Call  CALCULER_SOCIETE_BIENS (PTABFCY, PTABCNT, PTABPLN, PFASCLC) From =G_GLOB
      #--
      [M:DIV]LVLLIB = ".CALCUL_SOCIETE_FERMETURE" : Gosub CAL_ADDLVL  From =G_GLOB0
      Gosub CALCUL_SOCIETE_FERMETURE From =G_GLOB
    Endif
    #-1 ------

    # Fermeture fichier Bien comptable , Plan d'amortissement
    If (clalev([F:WFAS]))   Then : Close Local File [WFAS]  : Endif  : # Biens comptables
    If (clalev([F:WDEP]))   Then : Close Local File [WDEP]  : Endif  : # Plans d'amortissement
    If (clalev([F:DEPC]))   Then : Close Local File [DEPC]  : Endif  : # DEPREC courant FQ79813
    If (clalev([F:DEPS]))   Then : Close Local File [DEPS]  : Endif  : # DEPREC suivant FQ79813
    If (clalev([F:SEPC]))   Then : Close Local File [SEPC]  : Endif  : # DEPREC courant FQ79813
    If (clalev([F:SEPS]))   Then : Close Local File [SEPS]  : Endif  : # DEPREC suivant FQ79813
    # FQ54343
    If ([M:DIV]BACTCCN) Then
      If (clalev([F:WRPR])) Then : Close Local File [WRPR]  : Endif  : # Provisions pour renouvellement
      If (clalev([F:RPRC])) Then : Close Local File [RPRC]  : Endif  : # Provisions pour renouvellement FQ79813
      If (clalev([F:RPRS])) Then : Close Local File [RPRS]  : Endif  : # Provisions pour renouvellement FQ79813
    Endif
    If (clalev([F:WFCY]))   Then : Close Local File [WFCY]  : Endif  : # Sites FQ79813
  Endif
  #-1 ---------------------------------

  If ( [M:DIV]ERROR = 20 ) Then
   # Si dépassement du temps limite ( arrêt du calcul)
   RERROR = -2
  Endif

  # Déverrouillage Société
  Call UNLOCK_SYMBOLE ("CNX", PCPY, "") From GLOBIENS
  Call UNLOCK_SYMBOLE ("FAS", PCPY, "") From GLOBIENS

  # Fin mode first row FQ79813
  Gosub UNSET_FIRST From TRTFIRST

  #-- Suprression des globales
  Gosub CALCUL_DLT_GLOBALES

End


#*********************************************************************
#*********************************************************************
#           SIMULER_SOCIETE
#*********************************************************************
#*********************************************************************


#########################################################
Subprog SIMULER_SOCIETE (PCPY, PTABFCY, PTABCNT, PTABPLN, PHZEXE, PHZPER, PDETAI, PCRITSUP, RERROR)
#
# - Objet  : Simuler l'amortissement d'une société. FQ79856
#            Sont concernés :
#                 - les biens des sites à calculer
#                 - les plans d'amortissement des contextes à calculer.
#
# - Entrée : Société
#            Tableau des sites     à calculer
#            Tableau des contextes à calculer
#            Tableau Indicateur écriture du dernier enregistrement seulement
#            Tableau des plans     à calculer
#            Tableau des horizons exercices par contexte à calculer
#            Tableau des horizons périodes  par contexte à calculer
#            Tableau des indicateurs détail par contexte à calculer
#            Critères de sélection supplémentaires sur FXDASSETS (sélection  étendue)
#
#
# - Sortie : Code Erreur
#                 0 = Calcul société OK
#                -1 = Erreur calcul société
#                -2 = Erreur dépassement du temps limite
#                -3 = Erreur verrouillage OK
#
#            !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
#            Points d'entrée du calcul
#            SIMULER_SOCIETE      de GLOBB ( avec SIMULER_SOCIETES de FASSIMU)
#            CALCULER_SOCIETE     de GLOBB ( avec CALCULER_SOCIETES de FASCALC)
#            CALCULER_BIEN        de GLOBB
#            SIMULER_CALCUL_BIEN  de GLOBB
#            SIMULER_VALEUR_NETTE de GLOBB
#            !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
#

Value    Char    PCPY
Value    Char    PTABFCY()
Value    Integer PTABCNT()
Value    Integer PTABPLN()
Value    Integer PHZEXE()
Value    Integer PHZPER()
Value    Integer PDETAI()
Value    Char    PCRITSUP()
Variable Decimal RERROR


  #If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # RERROR contient le statut "erreur" passé en retour à FASCALC
  RERROR        = 0

  #-- Traitement demandeur
  [M:DIV]TRTDEM    = "CALDPS"
  # Concessions gérée
  Local Integer BGESCCN : BGESCCN = func AFNC.ACTIV("CCN") : [M:DIV]BACTCCN = BGESCCN

  #-- Création des globales
  Gosub CALCUL_CRT_GLOBALES

  [M:DIV]TRTLVL = 0
  [M:DIV]ERRID  = 0
  Raz [M:DIV]LVLID : [M:DIV]LVL= 0 : [M:DIV]LVLLIB= ".SIMULER_SOCIETE" : Gosub CAL_ADDLVL From =G_GLOB0
  [M:DIV]ERROR  = 0
  [M:DIV]SOC    = PCPY                    : # Société courante
  [M:DIV]SELSUP = PCRITSUP                : # Critères supplémentaires de la sélection étendue
  [M:DIV]PROPLN = ""                      : # Plan de production à charger
  G_BERRDER     = 0                       : # Erreur derogatoire FQ82293
  [M:DIV]BCO    = ""  : #FQ79813a


  # Passage en mode first row FQ79813
  Gosub SET_FIRST From TRTFIRST
  #--
  # Ouverture des fichiers
  If clalev([F:CPY])  = 0 : Local File COMPANY     [CPY]  : Endif : # Société
  # Initialisation titre fenêtre de suivi "Simulation Société : xxx"
  Call TEMPON(mess(179,7774,1)-PCPY) From GESECRAN
  #--
  # Société : xxx aaaaaaaaaaaaaaaaaaaaa
  Filter [CPY] Where CPY=PCPY : Read [CPY]CPY0 Last : Filter [CPY]
  Call ECR_TRACE(string$(80, '-')+"\",0) From =G_GLOB0
  Call ECR_TRACE(mess(22,7774,1)-num$(PCPY)-num$([F:CPY]CPYNAM)+"\",0) From =G_GLOB0

  #--
  #-- Modif du statut de calcul des biens si modifs de paramètrage.
  #--
  Local Integer I_CNX
  Local Integer RCOD
  For I_CNX = 0 To dim(PTABCNT)-1
    If (PTABCNT(I_CNX)) Then
      Call UPD_WAI_TRT(PCPY,PTABCNT(I_CNX),1,"*","CAL",RCOD) From UPDWAITRT
      If (RCOD) Then : Break : Endif : # FQ79813a
    Endif
  Next N_I
  If (RCOD) Then : RERROR = -1 : End : Endif


  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  # E   Point d'entrée    SOCLCKSIM               E
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
#CHECK IGNORE_BEGIN
  Local Integer B_SOCLCK : B_SOCLCK = 1
  If ( G_ETP_GLOBI ) Then : # FQ114113
    GPOINT = "SOCLCKSIM"
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9000 : End
    Endif
  Endif
#CHECK IGNORE_END
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

  #--
  # Verrouillage Société ( les contextes puis les biens)
  #----------------------------------
  If (B_SOCLCK) Then
    #----------------------------------
  If ( func GLOBIENS.LOCK_SYMBOLE ("CNX", PCPY, "", 0) = 0 ) Then
    RERROR = -3
    Call ECR_TRACE(mess(107,7774,1),1) From =G_GLOB0
  #----------------------------------
  Else
    [M:DIV]TRTLVL = 1
    If ( dim(GFILTRE_FAS) < 0 )  Then
      # Lorsque GFILTRE_FAS existe, le calcul est appelé depuis une action.
      # Dans ce cas, elle a pris en charge le verrouillage des biens à traiter.
      If ( func GLOBIENS.LOCK_SYMBOLE ("FAS", PCPY, "", 0) ) = 0 Then
        RERROR = -3
        Call ECR_TRACE(mess(107,7774,1),1) From =G_GLOB0
      Endif
    Endif
    [M:DIV]TRTLVL = 2
  Endif
  #----------------------------------
  Endif
  #----------------------------------

#  #- 1 ----
#  If ([M:DIV]FLGLST = G_OUI ) Then
#    # Si écriture du dernier enregistrement uniquement
#    # Suppression des enregistrements DEPSIMU de la socièté sur laquelle porte la simulation
#    Local Integer LIR
#    Local Char LREQ(250)(1..2)
#    LIR = 1 : LREQ(LIR) = "DEPSIMU.CPY_0 = '"+[M:DIV]SOC+"' "
#    # Delete sur table selon requête
#    Call CAL_DELTAB (nomap,"DEPSIMU",LREQ, LIR)  From =G_GLOB9
#  #- 1 ----
#  Else
#    #- 2 ----
#    If ([M:DIV]SELSUP = "" ) Then
#      # Si pas de sélection étendue
#      # Suppression des enregistrements DEPSIMU sur les critères sur lesquels portent la simulation
#      Local Integer LIR
#      Local Integer LDIMREQ : LDIMREQ = int(func AFNC.ACTIV("SIT")/30)+5
#      Local Char LREQ(250)(1..LDIMREQ)
#      # Société
#      LIR = 1 : LREQ(LIR) = "DEPSIMU.CPY_0 = '"+[M:DIV]SOC+"' "
#      # Sites
#      LIR+=1  : LREQ(LIR) = " AND DEPSIMU.FCY_0 IN('"+PTABFCY(0)+"'"
#      Local Integer I_S
#      For I_S = 2 To dim(PTABFCY)
#        If ( PTABFCY(I_S-1) = "") Then : Break : Endif
#        LREQ(LIR) += ",'"+PTABFCY(I_S-1)+"'"
#        If ( mod(I_S, 30) = 0 ) Then : LIR +=1 : Endif
#      Next I_S
#      LREQ(LIR) += ")"  : # Ferme IN
#      # Contextes
#      Local Integer I_C
#      LIR+=1  : LREQ(LIR) = " AND DEPSIMU.CNX_0 IN("+num$(PTABCNT(0))
#      # >>>>>>>>>>
#      For I_C = 2 To dim(PTABCNT)
#        If ( PTABCNT(I_C-1) = 0) Then : Break : Endif
#        LREQ(LIR) += ","+num$(PTABCNT(I_C-1))
#      Next I_C
#      LREQ(LIR) += ")" : # Ferme IN
#      # Plans
#      Local Integer I_P
#      LIR+=1  : LREQ(LIR) = " AND DEPSIMU.DPRPLN_0 IN("+num$(PTABPLN(0))
#      # >>>>>>>>>>
#      For I_P = 2 To dim(PTABPLN)
#        If ( PTABPLN(I_P-1) = 0) Then : Break : Endif
#        LREQ(LIR) += ","+num$(PTABPLN(I_P-1))
#      Next I_P
#      LREQ(LIR) += ")" : # Ferme IN
#      #--
#      # Delete sur table selon requête
#      Call CAL_DELTAB (nomap,"DEPSIMU",LREQ, LIR)  From =G_GLOB9
#      #--
#    Endif
#    #- 2 ----
#  Endif
#  #- 1 ----


  # Suppression des enregistrements DEPSIMU pour les contextes des sociétés
  # sur lesquels portent la simulation
  Local Integer LIR
  Local Integer LDIMREQ : LDIMREQ = int(func AFNC.ACTIV("SIT")/30)+5
  Local Char LREQ(250)(1..LDIMREQ)
  # Société
  LIR = 1 : LREQ(LIR) = "DEPSIMU.CPY_0 = '"+[M:DIV]SOC+"' "
  # Contextes
  Local Integer I_C
  LIR+=1  : LREQ(LIR) = " AND DEPSIMU.CNX_0 IN("+num$(PTABCNT(0))
  # >>>>>>>>>>
  For I_C = 2 To dim(PTABCNT)
    If ( PTABCNT(I_C-1) = 0) Then : Break : Endif
    LREQ(LIR) += ","+num$(PTABCNT(I_C-1))
  Next I_C
  LREQ(LIR) += ")" : # Ferme IN
  #--
  # Delete sur table selon requête

  # FQ102987
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  # E   Point d'entrée    DELTABSIM               E
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  If ( G_ETP_GLOBI ) Then : # FQ114113
    GPOINT = "DELTABSIM" #CHECK IGNORE_LINE
    Gosub ENTREE From EXEFNC
  Endif
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

  Call CAL_DELTAB (nomap,"DEPSIMU",LREQ, LIR)  From =G_GLOB9
  #--

  #-1 ---------------------------------
  If ( RERROR = 0 ) Then
    #--
    # Ouverture Fichier  Bien comptable , Plan d'amortissement
    If clalev([F:WFAS])=0  : Local File FXDASSETS     [WFAS]  :  Endif       : # Biens comptables
    If clalev([F:DPS]) =0  : Local File DEPSIMU       [DPS]   :  Endif       : # Résultat de simulation
    If clalev([F:WDEP])=0  : Local File DEPREC        [WDEP]  :  Endif       : # Plans d'amortissement
    If clalev([F:DEPC])=0  : Local File DEPREC        [DEPC]  :  Endif       : # DEPREC courant
    If clalev([F:DEPS])=0  : Local File DEPREC        [DEPS]  :  Endif       : # DEPREC suivant
    If clalev([F:SEPC])=0  : Local File DEPREC        [SEPC]  :  Endif       : # DEPREC courant
    If clalev([F:SEPS])=0  : Local File DEPREC        [SEPS]  :  Endif       : # DEPREC suivant
    If ([M:DIV]BACTCCN) Then
      If clalev([F:WRPR])=0  : Local File CCNRPR      [WRPR]  :  Endif        : # Provisions pour renouvellement
      If clalev([F:RPRC])=0  : Local File CCNRPR      [RPRC]  :  Endif        : # Provisions pour renouvellement
      If clalev([F:RPRS])=0  : Local File CCNRPR      [RPRS]  :  Endif        : # Provisions pour renouvellement
    Endif
    If clalev([F:WFCY])=0  : Local File FACILITY     [WFCY]  :  Endif        : # Sites

    #--
    [M:DIV]LVLLIB = ".CALCUL_SOCIETE_PREPARE" : Gosub CAL_ADDLVL  From =G_GLOB0
    Gosub CALCUL_SOCIETE_PREPARE From =G_GLOB

    #-1 ------
    If ([M:DIV]ERROR) Then
      # Erreur logique
      Call CAL_ERREUR("", "", 0, 0) From=G_GLOB0
      # Résultat du traitement : Echec
      Call ECR_TRACE(mess(58,7774,1)-mess(60,7774,1),1) From =G_GLOB0
    Else
      [M:DIV]LVLLIB = ".CALCULER_SOCIETE_BIENS" : Gosub CAL_ADDLVL  From =G_GLOB0
      Call  CALCULER_SOCIETE_BIENS (PTABFCY, PTABCNT, PTABPLN, G_NON) From =G_GLOB
      #--
      [M:DIV]LVLLIB = ".CALCUL_SOCIETE_FERMETURE" : Gosub CAL_ADDLVL  From =G_GLOB0
      Gosub CALCUL_SOCIETE_FERMETURE From =G_GLOB
    Endif
    #-1 ------

    # Fermeture fichier Bien comptable , Plan d'amortissement
    If (clalev([F:WFAS]))   Then : Close Local File [WFAS]  : Endif  : # Biens comptables
    If (clalev([F:WDEP]))   Then : Close Local File [WDEP]  : Endif  : # Plans d'amortissement
    If (clalev([F:DEPC]))   Then : Close Local File [DEPC]  : Endif  : # DEPREC courant FQ79813
    If (clalev([F:DEPS]))   Then : Close Local File [DEPS]  : Endif  : # DEPREC suivant FQ79813
    If (clalev([F:SEPC]))   Then : Close Local File [SEPC]  : Endif  : # DEPREC courant FQ79813
    If (clalev([F:SEPS]))   Then : Close Local File [SEPS]  : Endif  : # DEPREC suivant FQ79813
    # FQ54343
    If ([M:DIV]BACTCCN) Then
      If (clalev([F:WRPR])) Then : Close Local File [WRPR]  : Endif  : # Provisions pour renouvellement
      If (clalev([F:RPRC])) Then : Close Local File [RPRC]  : Endif  : # Provisions pour renouvellement FQ79813
      If (clalev([F:RPRS])) Then : Close Local File [RPRS]  : Endif  : # Provisions pour renouvellement FQ79813
    Endif
    If (clalev([F:WFCY]))   Then : Close Local File [WFCY]  : Endif  : # Sites FQ79813
  Endif
  #-1 ---------------------------------

  If ( [M:DIV]ERROR = 20 ) Then
   # Si dépassement du temps limite ( arrêt du calcul)
   RERROR = -2
  Endif

  # Déverrouillage Société
  Call UNLOCK_SYMBOLE ("CNX", PCPY, "") From GLOBIENS
  Call UNLOCK_SYMBOLE ("FAS", PCPY, "") From GLOBIENS
  #--

  # Fin mode first row FQ79813
  Gosub UNSET_FIRST From TRTFIRST

  #-- Suprression des globales
  Gosub CALCUL_DLT_GLOBALES


End
#########################################################
$CALCUL_SOCIETE_PREPARE
#
# - Objet  : Ouverture des masques & fichiers ayant servi au calcul.
#            Utilisation du gosub pour que les masques restent ouverts
#
#            rem. : Gosub ne peut pas être transformé en CALL
#                   car il effectue les ouvertures de masques écrans
#                   qui doivent rester à disposition tout au long du calcul.
#
#

  # FQ83206 I/O par bloc
  NEWMOTEUR = 1
  adxftl    = 10
  adxwrb    = 10

  # Par défaut : Calcul provision AbelX3 à réaliser dans son ensemble FQ54343
  G_CCNCLCSTD = 1

  # Par défaut : Calcul amortissement AbelX3 à réaliser dans son ensemble
  G_CLCSTD = 1

  # FQ69171 : le bloc ci-dessous est remonté dans CALCULER_SOCIETER pour ne faire le contrôle que lors du calcul massif
  ## Contrôle dépassement du nombre maximum de biens gérés par la solution
  #[M:DIV]LVLLIB = "LIC_NBFAS_SOLUTION_OVRFLW" : Gosub CAL_ADDLVL  From =G_GLOB0
  #Call LIC_NBFAS_SOLUTION_OVRFLW  From =G_GLOB0
  #If ([M:DIV]ERROR <> 0 ) Then : [M:DIV]NIVDET = 0 : Return : Endif

  # Affectation [M:DIV] des informations relatives à la société [M:DIV]SOC
  #--
  # Récupération du niveau de trace ( si calcul batch ou  calcul VNC  [M:DIV]NIVDET = 0 pas de suivi FS1 FS2)
  [M:DIV]NIVDET = 0
  If ([M:DIV]TRTDEM = "CALBCO" or [M:DIV]TRTDEM = "CALSIM" ) Then
    Local Char LPARAM
    Call PARAM("","CALTRACE",LPARAM) From ADOVAL
    If (LPARAM <> "" ) Then
      [M:DIV]NIVDET = val(LPARAM)
      If ( [M:DIV]NIVDET > 10 ) Then : [M:DIV]NIVDET = 10 : Endif
      If ( [M:DIV]NIVDET < 0  ) Then : [M:DIV]NIVDET =  0 : Endif
    Endif
  Endif


  #--
  # Operating System
  Call GET_OS("",[M:DIV]OS) From ORDSYS

  #--
  # Suppression des fichiers de suivi
  If ( [M:DIV]NIVDET > 0 ) Then
    Local Integer LSTA
    Call EFFACE( filpath("tmp", "CAL_"+[M:DIV]SOC+"_*","tmp",0), LSTA) From ORDSYS
    # Ouverture du fichier de suivi
    Call OUVRE_FICH ("FS1") From =G_GLOB0
    Call OUVRE_FICH ("FS2") From =G_GLOB0
    [M:DIV]TRTLVL = 3
  Endif

  If ( G_ETRPNT ) Then
    Call ECR_FICH("FS1", 1, "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! ") From =G_GLOB0
    Call ECR_FICH("FS1", 1, "!!!!!!!!!! Point d'entrée utilisé !!!!!!!!!!!! ") From =G_GLOB0
    Call ECR_FICH("FS1", 1, "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! ") From =G_GLOB0
    Call ECR_FICH("FS1", 1, " ") From =G_GLOB0
  Endif

  Call ECR_FICH("FS1", 1, "Version"-num$(G_CLCVER)                     ) From =G_GLOB0
  Call ECR_FICH("FS1", 1, "======================================"     ) From =G_GLOB0
  Call ECR_FICH("FS1", 1, "CALCUL_SOCIETE_PREPARE - Société"-[M:DIV]SOC) From =G_GLOB0
  #--
  # Lecture société
  [M:DIV]LVLLIB = "0.CAL_LEC_SOCIETE" : Gosub CAL_ADDLVL  From =G_GLOB0
  Gosub CAL_LEC_SOCIETE From =G_GLOB0
  If ( [M:DIV]ERROR ) Then : Return : Endif
  #--
  # Lecture des paramètres sociétés FQ103931
  [M:DIV]LVLLIB = "0.CAL_LEC_PARAMETRES" : Gosub CAL_ADDLVL  From =G_GLOB0
  Gosub CAL_LEC_PARAMETRES From =G_GLOB1
  If ( [M:DIV]ERROR ) Then : Return : Endif
  #--
  # Lecture des modes, options et taux
  If clalev([M:DPM])=0  : Local Mask CALDPM     [DPM]  :  Endif    : # Dans le call le masque est refermé
  [M:DIV]LVLLIB = "0.CAL_LEC_MODES" : Gosub CAL_ADDLVL  From =G_GLOB0
  Gosub CAL_LEC_MODES From =G_GLOB0
  If ( [M:DIV]ERROR ) Then : Return : Endif
  #--
  # Lecture des contextes à calculer
  If clalev([M:CNX])=0  : Local Mask CALCNX     [CNX]  :  Endif    : # Dans le call le masque est refermé
  [M:DIV]LVLLIB = "0.CAL_LEC_CONTEXTES" : Gosub CAL_ADDLVL  From =G_GLOB0
  Call CAL_LEC_CONTEXTES ([M:DIV]SOC, [M:DIV]ERROR) From =G_GLOB0
  If ( [M:DIV]ERROR ) Then : Return : Endif
  #--
  # Lecture de la table Plafonds Véhicules
  If clalev([M:TAB])=0   : Local Mask CALTAB    [TAB]  :  Endif    : # Dans le call le masque est refermé
  [M:DIV]LVLLIB = "0.CAL_LEC_TABLE" : Gosub CAL_ADDLVL  From =G_GLOB0
  Call CAL_LEC_TABLE ([M:DIV]SOC) From =G_GLOB0
  If ( [M:DIV]ERROR ) Then : Return : Endif

  # =====================
  # == EXERCICES
  # =====================

  #--
  If ([M:DIV]TRTDEM = "CALDPS") Then
    # FQ79856
    # EN simulation : Prise en compte des horizons de simulations
    Local Integer L_C
    For I_C = 1 To dim(PTABCNT)
      If ( PTABCNT(I_C-1) = 0) Then : Break : Endif
      L_C = find(PTABCNT(I_C-1), [M:CNX]CNX)
      If (PHZEXE(I_C-1) <> 0) Then : [M:CNX]HRZEXE   (L_C-1) = PHZEXE(I_C-1) : Endif
      If (PHZEXE(I_C-1) <> 0) Then : [M:CNX]HRZPER   (L_C-1) = PHZPER(I_C-1) : Endif
      If (PDETAI(I_C-1) <> 0) Then : [M:CNX]FLGSIMDET(L_C-1) = PDETAI(I_C-1) : Endif
    Next I_C
    Call ECR_TRACE("",0) From =G_GLOB0
  Endif

  #--
  # Exercice
  If clalev([M:FIY])=0  : Local Mask CALFIY     [FIY]  :  Endif     : # Dans le call le masque est refermé
  #--
  # Si le contexte "Comptable & Fiscal" est à calculer
  If ( find(G300CPFI, PTABCNT)) Then
    # Si le contexte "Comptable & Fiscal" est à calculer
    If clalev([M:EGCF])=0  : Local Mask CALFIY     [EGCF] :  Endif        : # Comptable & fiscal
    [M:DIV]LVLLIB="0.CAL_LEC_EXERCICES_PERIODES"-mess(G300CPFI,GML_NCONTEXT,1): Gosub CAL_ADDLVL From =G_GLOB0
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300CPFI ) From =G_GLOB0
    If ( [M:DIV]ERROR ) Then : Return : Endif
    Transmask [M:FIY] To [M:EGCF]
  Endif
  #--
  # Si le contexte "IAS/IFRS" est à calculer ( ouverture des masques )
  If ( find(G300IAS, PTABCNT) ) Then
    If clalev([M:EIAS])=0  : Local Mask CALFIY     [EIAS]  :  Endif
    [M:DIV]LVLLIB="0.CAL_LEC_EXERCICES_PERIODES"-mess(G300IAS ,GML_NCONTEXT,1): Gosub CAL_ADDLVL From =G_GLOB0
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300IAS ) From =G_GLOB0
    If ( [M:DIV]ERROR ) Then : Return : Endif
    Transmask [M:FIY] To [M:EIAS]
  Endif
  #--
  # Si le contexte "Technique" est à calculer ( ouverture des masques )
  If ( find(G300TEC, PTABCNT) ) Then
    If clalev([M:ETEC])=0  : Local Mask CALFIY     [ETEC]  :  Endif
    [M:DIV]LVLLIB="0.CAL_LEC_EXERCICES_PERIODES"-mess(G300TEC ,GML_NCONTEXT,1): Gosub CAL_ADDLVL From =G_GLOB0
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300TEC ) From =G_GLOB0
    If ( [M:DIV]ERROR ) Then : Return : Endif
    Transmask [M:FIY] To [M:ETEC]
  Endif
  #--
  # Si le contexte "Retraité" est à calculer ( ouverture des masques )
  If ( find(G300RET, PTABCNT) ) Then
    If clalev([M:ERET])=0  : Local Mask CALFIY     [ERET]  :  Endif
    [M:DIV]LVLLIB="0.CAL_LEC_EXERCICES_PERIODES"-mess(G300RET ,GML_NCONTEXT,1): Gosub CAL_ADDLVL From =G_GLOB0
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300RET ) From =G_GLOB0
    If ( [M:DIV]ERROR ) Then : Return : Endif
    Transmask [M:FIY] To [M:ERET]
  Endif
  #--
  # Si le contexte "Subvention" à calculer ( ouverture des masques )
  If ( find(G300SUB, PTABCNT) ) Then
    If clalev([M:ESUB])=0  : Local Mask CALFIY     [ESUB]  :  Endif
    [M:DIV]LVLLIB="0.CAL_LEC_EXERCICES_PERIODES"-mess(G300SUB ,GML_NCONTEXT,1): Gosub CAL_ADDLVL From =G_GLOB0
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300SUB ) From =G_GLOB0
    If ( [M:DIV]ERROR ) Then : Return : Endif
    Transmask [M:FIY] To [M:ESUB]
  Endif
  #--
  # Si le contexte "Libre 1" est à calculer ( ouverture des masques )
  If ( find(G300LIB, PTABCNT) ) Then
    If clalev([M:ELI1])=0  : Local Mask CALFIY     [ELI1]  :  Endif
    [M:DIV]LVLLIB="0.CAL_LEC_EXERCICES_PERIODES"-mess(G300LIB ,GML_NCONTEXT,1): Gosub CAL_ADDLVL From =G_GLOB0
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300LIB ) From =G_GLOB0
    Transmask [M:FIY] To [M:ELI1]
    If ( [M:DIV]ERROR ) Then : Return : Endif
  Endif
  #--
  # Si le contexte "Libre 2" est à calculer ( ouverture des masques )
  If ( find(G300SU1, PTABCNT) ) Then
    If clalev([M:ELI2])=0  : Local Mask CALFIY     [ELI2]  :  Endif
    [M:DIV]LVLLIB="0.CAL_LEC_EXERCICES_PERIODES"-mess(G300SU1 ,GML_NCONTEXT,1): Gosub CAL_ADDLVL From =G_GLOB0
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300SU1 ) From =G_GLOB0
    Transmask [M:FIY] To [M:ELI2]
    If ( [M:DIV]ERROR ) Then : Return : Endif
  Endif
  #--
  # Si le contexte "Libre 3" est à calculer ( ouverture des masques )
  If ( find(G300SU2, PTABCNT) ) Then
    If clalev([M:ELI3])=0  : Local Mask CALFIY     [ELI3]  :  Endif
    [M:DIV]LVLLIB= "0.CAL_LEC_EXERCICES_PERIODES"-mess(G300SU2 ,GML_NCONTEXT,1): Gosub CAL_ADDLVL From =G_GLOB0
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300SU2 ) From =G_GLOB0
    Transmask [M:FIY] To [M:ELI3]
    If ( [M:DIV]ERROR ) Then : Return : Endif
  Endif
  #--
  # Si le contexte "Libre 4" est à calculer ( ouverture des masques )
  If ( find(G300SU3, PTABCNT) ) Then
    If clalev([M:ELI4])=0  : Local Mask CALFIY     [ELI4]  :  Endif
    [M:DIV]LVLLIB="0.CAL_LEC_EXERCICES_PERIODES"-mess(G300SU3 ,GML_NCONTEXT,1): Gosub CAL_ADDLVL From =G_GLOB0
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300SU3 ) From =G_GLOB0
    Transmask [M:FIY] To [M:ELI4]
    If ( [M:DIV]ERROR ) Then : Return : Endif
  Endif
  #--
  # Si le contexte "Libre 5" est à calculer ( ouverture des masques )
  If ( find(G300SU4, PTABCNT) ) Then
    If clalev([M:ELI5])=0  : Local Mask CALFIY     [ELI5]  :  Endif
    [M:DIV]LVLLIB= "0.CAL_LEC_EXERCICES_PERIODES"-mess(G300SU4 ,GML_NCONTEXT,1): Gosub CAL_ADDLVL From =G_GLOB0
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300SU4 ) From =G_GLOB0
    Transmask [M:FIY] To [M:ELI5]
    If ( [M:DIV]ERROR ) Then : Return : Endif
  Endif
  #--
  # Si le contexte "Libre 6" est à calculer ( ouverture des masques )
  If ( find(G300SU5, PTABCNT) ) Then
    If clalev([M:ELI6])=0  : Local Mask CALFIY     [ELI6]  :  Endif
    [M:DIV]LVLLIB= "0.CAL_LEC_EXERCICES_PERIODES"-mess(G300SU5 ,GML_NCONTEXT,1): Gosub CAL_ADDLVL From =G_GLOB0
    Call CAL_LEC_EXERCICES_PERIODES ( [M:DIV]SOC, G300SU5 ) From =G_GLOB0
    Transmask [M:FIY] To [M:ELI6]
    If ( [M:DIV]ERROR ) Then : Return : Endif
  Endif

  # == Ouverture masque de travail
  # ------------------------------
  #--
  # Provisions pour renouvellement FQ54343
  If ([M:DIV]BACTCCN) Then
    If clalev([M:RPR]) =0   : Local Mask CCNRPR   [RPR]   :  Endif  : # Provisoins pour renouvellement
    If clalev([M:PRPR])=0   : Local Mask CCNRPR   [PRPR]  :  Endif
    If clalev([M:WRPR])=0   : Local Mask CCNRPR   [WRPR]  :  Endif

    If clalev([M:CAD]) =0   : Local Mask CALDEP   [CAD]   :  Endif  : # Caducité
    If clalev([M:AMI]) =0   : Local Mask CALDEP   [AMI]   :  Endif  : # Amortissement industriel
    If ( [M:DIV]CCNGRTPLN <> 0 ) Then
      If clalev([M:SUB]) =0 : Local Mask CALDEP   [SUB]   :  Endif  : # Subvention
    Endif
  Endif

  # Plan d'amortissement
  If clalev([M:DEP]) =0  : Local Mask CALDEP     [DEP]   :  Endif
  If clalev([M:WDEP])=0  : Local Mask CALDEP     [WDEP]  :  Endif
  # Plan de production
  If clalev([M:PPL])=0   : Local Mask CALPPL     [PPL]   :  Endif

  # Ecriture dans la trace de l'entête du tableau des contextes calculés
  [M:DIV]LVLLIB= "0.ECR_ENTETE_CONTEXTE" : Gosub CAL_ADDLVL From =G_GLOB0
  Call ECR_ENTETE_CONTEXTE() From =G_GLOB0

  # >>>>>>>>>>>>>>>>>
  # Ouverture des masques de travail des plans rattachés aux contextes à calculer
  Local Integer J_CNT
  Local Integer D_CNT
  Local Integer J_PLN
  J_CNT = 0

  While ( PTABCNT(J_CNT) <> 0 )

    [M:DIV]LVLLIB="0.ECR_ENTETE_CONTEXTE"-mess(PTABCNT(J_CNT),GML_NCONTEXT,1): Gosub CAL_ADDLVL From =G_GLOB0
    Call ECR_LIGNE_CONTEXTE(PTABCNT(J_CNT)) From =G_GLOB0

    D_CNT = find( PTABCNT(J_CNT), [M:DIV]PLNCNT )
    For J_PLN = D_CNT To [M:DIV]NB_PLN
      If ( [M:DIV]PLNCNT (J_PLN-1) <> PTABCNT(J_CNT) ) Then : Break : Endif
      Case [M:DIV]PLNCAA(J_PLN-1)
        When  G301CPT
          # Comptable
          If ( clalev([M:PCPT])=0 ) Then
            Local Mask CALDEP     [PCPT]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PCPTOPN = 1 : Endif
          Endif
        When  G301FIS
          # Fiscal
          If ( clalev([M:PFIS])=0 ) Then
            Local Mask CALDEP     [PFIS]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PFISOPN = 1 : Endif
          Endif
        When  G301MIN
          # Minimum
          If ( clalev([M:PMIN])=0 ) Then
            Local Mask CALDEP     [PMIN]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PMINOPN = 1 : Endif
          Endif
        When  G301ORI
          # 0rigine
          If ( clalev([M:PORI])=0 ) Then
            Local Mask CALDEP     [PORI]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PORIOPN = 1 : Endif
          Endif
        When  G301R76
          # Réévaluation 76
          If ( clalev([M:PR76])=0 ) Then
            Local Mask CALDEP     [PR76]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PR76OPN = 1 : Endif
          Endif
        When  G301IAS
          # IAS/IFRS
          If ( clalev([M:PIAS])=0 ) Then
            Local Mask CALDEP     [PIAS]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PIASOPN = 1 : Endif
          Endif
        When  G301TEC
          # Technique
          If ( clalev([M:PTEC])=0 ) Then
            Local Mask CALDEP     [PTEC]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PTECOPN = 1 : Endif
          Endif
        When  G301RET
          # Retraité
          If ( clalev([M:PRET])=0 ) Then
            Local Mask CALDEP     [PRET]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PRETOPN = 1 : Endif
          Endif
        When  G301SUB
          # Subvention
          If ( clalev([M:PSUB])=0 ) Then
            Local Mask CALDEP     [PSUB]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PSUBOPN = 1 : Endif
          Endif
        When  G301LI1
          # Libre 1
          If ( clalev([M:PLI1])=0 ) Then
            Local Mask CALDEP     [PLI1]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PLI1OPN = 1 : Endif
          Endif
        When  G301LI2
          # Libre 2
          If ( clalev([M:PLI2])=0 ) Then
            Local Mask CALDEP     [PLI2]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PLI2OPN = 1 : Endif
          Endif
        When  G301LI3
          # Libre 3
          If ( clalev([M:PLI3])=0 ) Then
            Local Mask CALDEP     [PLI3]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PLI3OPN = 1 : Endif
          Endif
        When  G301LI4
          # Libre 4
          If ( clalev([M:PLI4])=0 ) Then
            Local Mask CALDEP     [PLI4]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PLI4OPN = 1 : Endif
          Endif
        When  G301LI5
          # Libre 5
          If ( clalev([M:PLI5])=0 ) Then
            Local Mask CALDEP     [PLI5]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PLI5OPN = 1 : Endif
          Endif
        When  G301LI6
          # Libre 6
          If ( clalev([M:PLI6])=0 ) Then
            Local Mask CALDEP     [PLI6]
          Else
            If ([M:DIV]TRTDEM = "CALVNC") Then : G_PLI6OPN = 1 : Endif
          Endif
        When  Default
      Endcase
    Next J_PLN
    J_CNT +=1
  Wend
  # <<<<<<<<<<<<<<<<
  If ([M:DIV]TRTDEM = "CALDPS") Then
    Call ECR_TRACE(string$(107,"*")+"\",0) From =G_GLOB0
  Else
    Call ECR_TRACE(string$(98,"*")+"\",0) From =G_GLOB0
  Endif

  # FQ79856
  If ( [M:DIV]TRTDEM = "CALDPS" ) Then
    # Ecriture dans la trace de l'entête du tableau des contextes calculés
    [M:DIV]LVLLIB= "0.ECR_ENTETE_PLAN" : Gosub CAL_ADDLVL From =G_GLOB0
    Call ECR_ENTETE_PLAN() From =G_GLOB0
    J_PLN = 0
    # >>>>>>>>>>
    While ( PTABPLN(J_PLN) <> 0 )
      [M:DIV]LVLLIB="0.ECR_ENTETE_PLAN"-mess(PTABCNT(J_CNT),GML_NCONTEXT,1): Gosub CAL_ADDLVL From =G_GLOB0
      Call ECR_LIGNE_PLAN(PTABPLN(J_PLN)) From =G_GLOB0
      J_PLN +=1
    Wend
    # <<<<<<<<<<
  Endif
  Call ECR_TRACE(string$(49,"*")+"\",0) From =G_GLOB0

  If ([M:DIV]BACTCCN and [M:DIV]CCNMOD = GVML_GCRNW and [M:DIV]TRTDEM = "CALVNC" ) Then : G_PRPROPN = 1  :   Endif : # Provisions

  If ( [M:DIV]ERROR ) Then : Return : Endif


  If ([M:DIV]TRTDEM = "CALDPS") Then
    If ([M:DIV]SELSUP <> "") Then
      # Sélection étendue :
      Call ECR_TRACE(mess(182,7774,1),0) From =G_GLOB0  :# FQ79856
      Call ECR_TRACE([M:DIV]SELSUP+"\",0)   From =G_GLOB0  :# FQ79856
    Endif
    # Résultat de simulation
    Call ECR_TRACE(mess(181,7774,1)+"\",0)   From =G_GLOB0  :# FQ79856
  Else
    # Résultat du calcul
  Call ECR_TRACE(mess(134,7774,1)+"\",0) From =G_GLOB0
  Endif

  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  # E   Point d'entrée    SOCPREPA                E
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
#CHECK IGNORE_BEGIN
  If ( G_ETP_GLOBI ) Then : # FQ114113
    GPOINT = "SOCPREPA" : # FQ75488
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9003 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
    Endif
  Endif
#CHECK IGNORE_END
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

Return

#########################################################
Subprog EXPLOITER_CALCUL_BIEN ( PTABCNT, PTABPLN )
#
# - Objet  : Exploiter le résultat du calcul d'un bien
#            selon le traitement demandeur.
#

Value    Integer PTABCNT()
Value    Integer PTABPLN()   : # FQ79856

 #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  Case [M:DIV]TRTDEM
    When "CALSOC", "CALBCO"
      # Mise à jour du bien et des plans concernés
      # Appel CALCUL_MAJ_CONTEXTES avant CALCUL_MAJ_BIEN car
      #       CALCUL_MAJ_CONTEXTES exploite FLGCNXCLC contenu dans le bien avant mise à jour
      # -- DEPREC
      [M:DIV]LVLLIB = "0.CALCUL_MAJ_CONTEXTES" : Gosub CAL_ADDLVL  From =G_GLOB0
      Call CALCUL_MAJ_CONTEXTES ( PTABCNT ) From =G_GLOB0
      # -- CCNRPR
      # FQ54343
      If ( [M:DIV]BACTCCN and [F:WFAS]OWNTYP = GVML_TDCONCE and [M:DIV]CCNMOD = GVML_GCRNW ) Then
        Call CALCUL_MAJ_PROVISION From =G_GLOB0
      Endif
      # -- FXDASSETS
      [M:DIV]LVLLIB = "0.CALCUL_MAJ_BIEN" : Gosub CAL_ADDLVL  From =G_GLOB0
      Call CALCUL_MAJ_BIEN ( PTABCNT )  From =G_GLOB0

      # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
      # E   Point d'entrée    AFTMAJFAS               E
      # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
#CHECK IGNORE_BEGIN
      If ( G_ETP_GLOBI ) Then : # FQ114113
        GPOINT = "AFTMAJFAS"
        Gosub ENTREE From EXEFNC
        If !(GOK) Then
          [M:DIV]ERRID = 9000 : End
        Endif
      Endif
#CHECK IGNORE_END
      # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

    When "CALSIM"
      # Chargement et affichage du masque contenant le résultat de simulation
      [M:DIV]LVLLIB = "0.CALCUL_MAJ_MASQUE_SIMULATION" : Gosub CAL_ADDLVL  From =G_GLOB0
      Call CALCUL_MAJ_MASQUE_SIMULATION  From =G_GLOB0

    When "CALDPS"
      # Exploitation du résultat du calcul simulé à destination de DEPSITU   # FQ79856
      [M:DIV]LVLLIB = "0.SIMUL_MAJ_CONTEXTES" : Gosub CAL_ADDLVL  From =G_GLOB0
      Call SIMUL_MAJ_CONTEXTES ( PTABCNT, PTABPLN ) From =G_GLOB0
  Endcase

  If ( [M:DIV]ERROR ) Then : End : Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#########################################################
$CALCUL_SOCIETE_FERMETURE
#
# - Objet  : Fermeture des masques & fichiers ayant servi au calcul.
#
    # Fermeture écrans spécifiques au calcul
    If (clalev([M:FIY]))   Then : Close Local Mask [FIY]  : Endif : # Exercice
    If (clalev([M:DEP]))   Then : Close Local Mask [DEP]  : Endif : # Plan d'amortissement à calculer
    If (clalev([M:WDEP]))  Then : Close Local Mask [WDEP]  : Endif : # Plan d'amortissement à calculer
    If (clalev([M:PPL]))   Then : Close Local Mask [PPL]  : Endif : # Plan de production
    If (clalev([M:CNX]))   Then : Close Local Mask [CNX]  : Endif : # Globales propre à la boite noire
    If (clalev([M:DPM]))   Then : Close Local Mask [DPM]  : Endif : # Méthode d'amortissement
    If (clalev([M:TAB]))   Then : Close Local Mask [TAB]  : Endif : # Equipes & Véhicules

    #  Exercices / Périodes (FISCYEAR)
    If (clalev([M:EGCF])) Then : Close Local Mask [EGCF] : Endif : # Comptable & Fiscal
    If (clalev([M:EIAS])) Then : Close Local Mask [EIAS] : Endif : # IAS/IFRS
    If (clalev([M:ESUB])) Then : Close Local Mask [ESUB] : Endif : # Subvention
    If (clalev([M:ETEC])) Then : Close Local Mask [ETEC] : Endif : # Technique
    If (clalev([M:ERET])) Then : Close Local Mask [ERET] : Endif : # Retraité
    If (clalev([M:ELI1])) Then : Close Local Mask [ELI1] : Endif : # Libre 1
    If (clalev([M:ELI2])) Then : Close Local Mask [ELI2] : Endif : # Libre 2
    If (clalev([M:ELI3])) Then : Close Local Mask [ELI3] : Endif : # Libre 3
    If (clalev([M:ELI4])) Then : Close Local Mask [ELI4] : Endif : # Libre 4
    If (clalev([M:ELI5])) Then : Close Local Mask [ELI5] : Endif : # Libre 5
    If (clalev([M:ELI6])) Then : Close Local Mask [ELI6] : Endif : # Libre 6

    #  Plan d'amortissement (DEPREC)
    If (clalev([M:PFIS]) and !(G_PFISOPN) ) Then : Close Local Mask [PFIS] : Endif : # Fiscal
    If (clalev([M:PCPT]) and !(G_PCPTOPN) ) Then : Close Local Mask [PCPT] : Endif : # Comptable
    If (clalev([M:PMIN]) and !(G_PMINOPN) ) Then : Close Local Mask [PMIN] : Endif : # Minimum
    If (clalev([M:PORI]) and !(G_PORIOPN) ) Then : Close Local Mask [PORI] : Endif : # Origine
    If (clalev([M:PR76]) and !(G_PR76OPN) ) Then : Close Local Mask [PR76] : Endif : # Réévaluation 76
    If (clalev([M:PIAS]) and !(G_PIASOPN) ) Then : Close Local Mask [PIAS] : Endif : # IAS/IFRS
    If (clalev([M:PSUB]) and !(G_PSUBOPN) ) Then : Close Local Mask [PSUB] : Endif : # Subvention
    If (clalev([M:PTEC]) and !(G_PTECOPN) ) Then : Close Local Mask [PTEC] : Endif : # Technique
    If (clalev([M:PRET]) and !(G_PRETOPN) ) Then : Close Local Mask [PRET] : Endif : # Retraité
    If (clalev([M:PLI1]) and !(G_PLI1OPN) ) Then : Close Local Mask [PLI1] : Endif : # Libre 1
    If (clalev([M:PLI2]) and !(G_PLI2OPN) ) Then : Close Local Mask [PLI2] : Endif : # Libre 2
    If (clalev([M:PLI3]) and !(G_PLI3OPN) ) Then : Close Local Mask [PLI3] : Endif : # Libre 3
    If (clalev([M:PLI4]) and !(G_PLI4OPN) ) Then : Close Local Mask [PLI4] : Endif : # Libre 4
    If (clalev([M:PLI5]) and !(G_PLI5OPN) ) Then : Close Local Mask [PLI5] : Endif : # Libre 5
    If (clalev([M:PLI6]) and !(G_PLI6OPN) ) Then : Close Local Mask [PLI6] : Endif : # Libre 6


    # Provisions pour renouvellement FQ54343
    If ([M:DIV]BACTCCN) Then
      If (clalev([M:RPR]))  Then : Close Local Mask [RPR]  : Endif
      If (clalev([M:PRPR]) and !(G_PRPROPN)) Then : Close Local Mask [PRPR] : Endif : # Libre 6
      If (clalev([M:WRPR])) Then : Close Local Mask [WRPR] : Endif

      If (clalev([M:CAD])) Then : Close Local Mask [CAD] : Endif : # Caducité
      If (clalev([M:SUB])) Then : Close Local Mask [SUB] : Endif : # Subvention
      If (clalev([M:AMI])) Then : Close Local Mask [AMI] : Endif : # Amortissement industriel
    Endif

    # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
    # E   Point d'entrée    SOCFERME                E
    # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
#CHECK IGNORE_BEGIN
    If ( G_ETP_GLOBI ) Then : # FQ114113
      GPOINT = "SOCFERME" : # FQ75488
      Gosub ENTREE From EXEFNC
      If !(GOK) Then
        [M:DIV]ERRID = 9003 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
      Endif
    Endif
#CHECK IGNORE_END
    # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

    # Gestion des erreurs
    Gosub CAL_RMVLVL From =G_GLOB0

Return



#########################################################
Subprog CALCULER_SOCIETE_BIENS (PTABFCY, PTABCNT, PTABPLN, PFASCLC)
#
# - Objet  : Calculer les biens de la société.
#
#              Sélection des biens & plans à calculer
#              Pour chaque Bien
#                Calculer le bien (CALCUL_BIEN)
#              Mise à jour du bien et des plans concernés
#
# - Entrée :
#            Tableau des sites     à calculer
#            Tableau des contexter à calculer
#            Indicateur recalcul des amortissements forcé
#
Value    Char    PTABFCY()
Value    Integer PTABCNT()
Value    Integer PTABPLN()  : # FQ79856
Value    Integer PFASCLC    : # FQ88613

Local    Integer NBBIENCMT                          : # Nombre de biens calculés et validés
Local    Integer NBBIENCLC                          : # Nombre de biens calculés
Local    Char    REQUETE(250) (2)                   : # Compléments à la requête
Local    Char    TXTPROG(40)                        : # Gestion de la jauge : Titre
Local    Integer NBBCO                              : # Gestion de la jauge : Nbre de biens total
Local    Integer NBBCO_TRT                          : # Gestion de la jauge : Nbre de biens traités
Local    Integer LOK
Local    Integer B_SITCAL                           : # Au moins un bien à calculer pour le site courant
#FQ79813
Local    Integer B_UNDO
Local    Integer B_FIRST
#FQ81722
Local    Char    REQFAS(50)                         : # Compléments sélection sur AASREF
  #--
  # RAZ : nombre de biens calculés pour la société
  NBBIENCLC = 0
  NBBIENCMT = 0
  #--
  # Requete : Prise en compte du filtre de l'action à partir de laquelle le calcul a été invoqué
  Raz REQUETE
  Raz GBIDI1
  If ( dim(GFILTRE_FAS) > 0 ) Then
    If ( GFILTRE_FAS <> "") Then
      Call ADDCRIT( REQUETE, GBIDI1, mess(1,7774,1)-[M:DIV]SOC, GFILTRE_FAS, "&") From GOBJSUB
    Endif
    Kill GFILTRE_FAS
  Endif
  #--
  # Requete : Prise en compte uniquement des biens à calculer - FQ79856 FQ88613
  If ( [M:DIV]TRTDEM <> "CALDPS" and PFASCLC <> G_OUI )  Then
  Call ADDCRIT( REQUETE, GBIDI1, mess(1,7774,1)-[M:DIV]SOC,
&               "FLGCLC <> G_NON", "&") From GOBJSUB
  Endif
  # Requete : Prise en compte séléction étendue de la simulation - FQ79856
  If ( [M:DIV]TRTDEM = "CALDPS" ) Then
    Call ADDCRIT( REQUETE, GBIDI1, mess(1,7774,1)-[M:DIV]SOC,
&                 "ISSDAT = [0/0/0]", "&") From GOBJSUB
    If ( [M:DIV]SELSUP <> "" )  Then
    Call ADDCRIT( REQUETE, GBIDI1, mess(1,7774,1)-[M:DIV]SOC,
&                 [M:DIV]SELSUP, "&") From GOBJSUB
    Endif
    # FQ81722
    Local    Char    LCURBCO  : LCURBCO = ""
    REQFAS = " AASREF > LCURBCO "
  Else
    # FQ81722
    REQFAS = " 1=1 "
  Endif
  #--
  # Requete :Prise en compte des biens actifs et non sortis dans un exercice précédent
  Call ADDCRIT( REQUETE, GBIDI1, mess(1,7774,1)-[M:DIV]SOC,
&               "ENAFAS=G_OUI & ISSFIYPRE <> G_OUI", "&") From GOBJSUB
  #--
  # Requete :Exclusion des biens dont le type de détention est "En modèle" ou "Annulé"
  Call ADDCRIT( REQUETE, GBIDI1, mess(1,7774,1)-[M:DIV]SOC,
&               "OWNTYP <> GVML_TDMODEL & OWNTYP <> GVML_TDANNUL", "&") From GOBJSUB

  # Requete :Prise en compte des biens uniquement  "en service" ou "En cours"
  Call ADDCRIT( REQUETE, GBIDI1, mess(1,7774,1)-[M:DIV]SOC,
&               "(GACACN=GVML_NIENSER | GACACN=GVML_NIENCOU | IASACN=GVML_NIENSER | IASACN=GVML_NIENCOU)", "&")
& From GOBJSUB
  #--

  # FQ85721
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  # E   Point d'entrée    CALREQCPL               E
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
#CHECK IGNORE_BEGIN
  Local Char REQCPL(255) : REQCPL = "1=1"
  If ( G_ETP_GLOBI ) Then : # FQ114113
    GPOINT = "CALREQCPL"
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9000 : End
    Endif
  Endif
  If (REQCPL <> "1=1") Then
    Call ECR_TRACE(mess(709,7773,1)-":"-REQCPL,0) From =G_GLOB0
    Call ECR_TRACE(" ",0) From =G_GLOB0
  Endif
#CHECK IGNORE_END
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

  # If clalev([F:WFCY])=0  : Local File FACILITY     [WFCY]  :  Endif        : # Sites FQ79813
  Filter [WFCY] Where LEGCPY=[M:DIV]SOC
  #--
  # >>>>>>>>>>>>>>>
  For [WFCY]FCY1
    B_FIRST = 1 : # FQ79813
    #- 1 -------------------------
    If ( find([F:WFCY]FCY, PTABFCY) <> 0 ) Then

      #xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
      #xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
      # Séquence critique - Début de calcul pour la société courante

      # 2 >>>>>>>>>>>>>>>  FQ79813
      Repeat
        B_UNDO = 0
        # FQ85721
        Filter [WFAS] Where CPY=[M:DIV]SOC & FCY=[F:WFCY]FCY & evalue(REQFAS) & evalue(REQUETE) & evalue(REQCPL)
        #--
        If (B_FIRST) Then : # FQ79813
          Raz NBBCO, NBBCO_TRT
          If ( [M:DIV]TRTDEM = "CALDPS" ) Then : # FQ79856
            TXTPROG = mess(179,7774,1)-mess(24,7778,1)-[F:WFCY]FCY
          Else
          TXTPROG = mess(1,7774,1)-mess(24,7778,1)-[F:WFCY]FCY
          Endif
          NBBCO   = rowcount([WFAS])
          If (NBBCO=0) Then : B_SITCAL=0 : Else : B_SITCAL=1 : Endif

          Call TEMPOFF() From GESECRAN
          Call OUVRE_BOITE(TXTPROG, NBBCO) From GESECRAN
          Call SET_BOITE(TXTPROG, NBBCO) From GESECRAN
          [M:DIV]TRTLVL = 4
          B_FIRST = 0 : # FQ79813

          If (B_SITCAL) Then
            # Avant - Nombre de biens à calculer
            Call ECR_TRACE(mess(24,7778,1)-[F:WFCY]FCY-mess(148,7774,1)-num$(NBBCO),0) From =G_GLOB0
          Endif
        Endif
        #--
        # 3 >>>>>>>>>>>>>>>
        For [WFAS]FAS2
          #--
          # X3-110500
          If !(adxlog) Then : Trbegin [WFAS], [WDEP] : Endif
          #--
          #-- Si recalcul forcé, on positionne les flags du bien à recalculer FQ88613
          If (PFASCLC = G_OUI) Then
            [F:WFAS]FLGCLC = G_OUI
            Local Integer I_CNT
            For I_CNT = 1 To dim(PTABCNT)
              If ( PTABCNT(I_CNT-1) <> 0 ) Then
                [F:WFAS]FLGCNXCLC(PTABCNT(I_CNT-1)-1) = GVML_RCOUI
              Endif
            Next
            # FQ88613_2
            If ([M:DIV]BACTCCN and [M:DIV]CCNMOD = GVML_GCRNW and [F:WFAS]OWNTYP = GVML_TDCONCE) Then
              [F:WFAS]FLGRPRCLC = G_OUI
            Endif
          Endif
          #--
          NBBCO_TRT += 1
          #-- Boite de progression
          # Titre boite de suivi "sss/bbbbbbbbbbbb nnnn(traité)/nnnn(total)"
          TXTPROG    = [F:WFAS]CPY-'/'-[F:WFAS]AASREF+'['+num$(NBBCO_TRT)+'/'+num$(NBBCO)+']'
          Call AFF_BOITE(TXTPROG,NBBCO_TRT,LOK) From GESECRAN

          # ------------------------------
          [M:DIV]LVLLIB = "0.CALCUL_BIEN" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CALCUL_BIEN (PTABCNT) From =G_GLOB
          #--
          If ( [M:DIV]ERROR = 0 ) Then
            # Exploitation du calcul d'un bien
            [M:DIV]LVLLIB = "0.EXPLOITER_CALCUL_BIEN" : Gosub CAL_ADDLVL  From =G_GLOB0
            Call EXPLOITER_CALCUL_BIEN (PTABCNT, PTABPLN) From =G_GLOB   : # FQ79856
          Endif

          #---------------------
          If ([M:DIV]ERROR) Then
            # Erreur phase de calcul du bien : FQ114113
            #Call ECR_TRACE(mess(39,7774,1)-num$([F:WFAS]AASREF),0) From =G_GLOB0
            Call ECR_TRACE(mess(39,7774,1)-num$([F:WFAS]AASREF)-mess(153,7774,1)-num$([M:DIV]ERROR),0) From =G_GLOB0
            Break 2
          #---------------------
          Else
            NBBIENCLC += 1
          Endif
          #---------------------

          # Commit après n biens calculés selon code activité "BPC"
          If (mod(NBBIENCLC, [M:DIV]NBBCOTRA) = 0 ) Then
            If (adxlog) Then
              If (adxwrb > 0) Then : Flush [WDEP] : Endif : # FQ83206
              Commit
              NBBIENCMT = NBBIENCLC
            Endif
          Endif

          # Sortie de boucle pour UNDO après n biens calculés selon code activité "BDO"  FQ79813
          # FQ113295 Ne tenir compte du paramètre CALNBUNDO que si l'on n'est pas en Simulation ou en recalcul forcé
          If ([M:DIV]TRTDEM <> "CALDPS" and PFASCLC <> G_OUI)
            If (mod(NBBIENCLC, [M:DIV]NBBCOUDO) = 0 ) Then
              B_UNDO = 1 : Break
            Endif
          Endif

          # Dépassement du temps limite
          [M:DIV]LVLLIB = "0.TIMOVRFLW" : Gosub CAL_ADDLVL From =G_GLOB0
          Gosub TIMOVRFLW From =G_GLOB0
          If ( [M:DIV]ERROR = 20 )  Then
            If (adxlog) Then
              If (adxwrb > 0) Then : Flush [WDEP] : Endif  : # FQ83206
              Commit
              NBBIENCMT = NBBIENCLC
            Endif
            Break 3
          Endif
        Next FAS2
        Filter [WFAS]
        # 3 >>>>>>>>>>>>>>>

        # FQ81722 FQ107645
        #If ( [M:DIV]TRTDEM = "CALDPS" and B_UNDO )  Then
        # FQ113295
        #If ( ([M:DIV]TRTDEM = "CALDPS" or PFASCLC = G_OUI) and B_UNDO )  Then
        If ( B_UNDO )  Then
          LCURBCO = [F:WFAS]AASREF
        Endif

      # FQ79813
      Until B_UNDO = 0
      # 2 >>>>>>>>>>>>>>>

      # FQ91302
      # FQ113295
      #If ( [M:DIV]TRTDEM = "CALDPS" )  Then
      #  LCURBCO = ""
      #Endif

      If (B_SITCAL) Then
        # Après - Nombre de biens à calculer FQ85721 FQ91302
        Filter [WFAS] Where CPY=[M:DIV]SOC  & FCY=[F:WFCY]FCY  & evalue(REQFAS) & evalue(REQUETE) & evalue(REQCPL)
        Call ECR_TRACE(mess(24,7778,1)-[F:WFCY]FCY -mess(149,7774,1)-num$(rowcount([WFAS]))+"\",0) From =G_GLOB0
        Filter [WFAS]
      Endif

    Endif
    #- 1 -------------------------
  Next FCY1
  Filter [WFCY]
  # <<<<<<<<<<<<
  #------------
  If ( [M:DIV]ERROR = 0 ) Then
    If (adxlog) Then
      If (adxwrb > 0) Then : Flush [WDEP] : Endif  : # FQ83206
      Commit
    Endif
    # Nombre de biens calculés :
    Call ECR_TRACE(mess(45,7774,1)-num$(NBBIENCLC),0) From =G_GLOB0
    # Résultat du traitement : OK
    Call ECR_TRACE(mess(58,7774,1)-mess(59,7774,1),0) From =G_GLOB0
  #------------
  Else
    If (adxlog) Then : Rollback : Endif
    # Nombre de biens calculés :
    Call ECR_TRACE(mess(45,7774,1)-num$(NBBIENCLC),0) From =G_GLOB0
    # Nombre de biens validés :
    Call ECR_TRACE(mess(152,7774,1)-num$(NBBIENCMT),0) From =G_GLOB0
    # Erreur :
    If ( find([M:DIV]ERROR, 5, 14, 18, 20, 22, 23, 24, 26, 27, 29, 30, 31) > 0 ) Then
      Call CAL_ERREUR("", "", 0, 0) From =G_GLOB0
    Else
      Call ECR_TRACE(mess(153,7774,1)-num$([M:DIV]ERROR), 0) From =G_GLOB0
    Endif
    # Traitement annulé
    Call ECR_TRACE(mess(48,7774,1),0) From =G_GLOB0
     # Résultat du traitement : Echec
    Call ECR_TRACE(mess(58,7774,1)-mess(60,7774,1),1) From =G_GLOB0
  Endif
  #------------
  #xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
  #xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

  #--
  Call FERME_BOITE From GESECRAN

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#*********************************************************************
#*********************************************************************
#           CALCUL_BIEN
#*********************************************************************

#########################################################
Subprog CALCUL_BIEN (PTABCNT)
#
# - Objet  : Calculer un bien de la société.
#              Préparer le calcul des contextes du bien ( CALCUL_CONTEXTES_PREPARE )
#              Calculer le contexte du bien (CALCUL_CONTEXTE)
#
# - Entrée :
#            Tableau des contextes à calculer
#
#
# - Sortie : Code Erreur
#                 0 = Calcul société OK
#
#
#
Value    Integer PTABCNT()

Local Integer    N_C

  #If ( [M:DIV]BDEBUG  ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif


  #-- Bien courant
  [M:DIV]BCO    = [F:WFAS]AASREF

  #-- Concession
  [M:DIV]DTFNCON = [0/0/0]
  If ( [M:DIV]BACTCCN and [F:WFAS]CCNREF <> "" ) Then
    # Récupération de la date de fin de concession
    #Call CAL_DATE_FIN_CONCESSION ( [F:WFAS]CPY, [F:WFAS]CCNREF, [M:DIV]DTFNCON ) From =G_GLOB0
    [M:DIV]LVLLIB = "0.CAL_DATE_FIN_CONCESSION" : Gosub CAL_ADDLVL  From =G_GLOB0
    [M:DIV]PC(0)= [F:WFAS]CPY : [M:DIV]PC(1)= [F:WFAS]CCNREF
    Gosub GSB_CAL_DATE_FIN_CONCESSION From =G_GLOB0
    [M:DIV]DTFNCON = [M:DIV]RD(0)
  Endif

  If G_ACTCCN=G_OUI
   [M:DIV]COEACT = 0.
   If ( [M:DIV]BACTCCN and [F:WFAS]CCNREF <> "" and [F:WFAS]CCNACTCOD <> "" ) Then
     # Récupération du coefficient d'actualisation
     Local Decimal LCOEACT
     Call CCN_LEC_COEACT ([F:WFAS]CPY, [F:WFAS]CCNACTCOD,  LCOEACT) From =G_GLOB1
     [M:DIV]COEACT = LCOEACT
   Endif
  Endif

  #-- Russie
  If([M:DIV]BACTKRU or [M:DIV]BACTKPL) Then
    [M:DIV]DOTSUP = 0. : # FQ67110
    [M:DIV]BONUS  = [F:WFAS]KBONUS
    [M:DIV]PSEPLN = [F:WFAS]KPSEPLN
    [M:DIV]LVLLIB = "4RU.KRU_LEC_PSEPLN" : Gosub CAL_ADDLVL  From =G_GLOB0
    Gosub KRU_LEC_PSEPLN From =G_GLOB4RU
  Endif

  If ([M:DIV]ERROR) Then : End : Endif

  # Passage en mode first row FQ79813
  Gosub SET_FIRST From TRTFIRST

  #--
  Call ECR_FICH ( "FS1", 2, "**************************************" ) From =G_GLOB0
  Call ECR_FICH ( "FS1", 2, "CALCUL_BIEN - Societe / Réf. Bien"-[M:DIV]SOC-" / "-[M:DIV]BCO ) From =G_GLOB0
  #--


  #--
  [M:DIV]LVLLIB = "1.CALCUL_CONTEXTES_PREPARE" : Gosub CAL_ADDLVL  From =G_GLOB0
  Call CALCUL_CONTEXTES_PREPARE ( PTABCNT ) From =G_GLOB1
  #--

  For N_C = 1 To G300MAX
    If ( PTABCNT(N_C-1) <> 0 and ([M:DIV]TRTDEM <> "CALSOC" or [F:WFAS]FLGCNXCLC(PTABCNT(N_C-1)-1) <> G_NON) ) Then
      [M:DIV]LVLLIB = "1.CALCUL_CONTEXTE"-mess(PTABCNT(N_C-1),GML_NCONTEXT,1): Gosub CAL_ADDLVL From =G_GLOB0
      #--
      Call CALCUL_CONTEXTE (PTABCNT(N_C-1)) From =G_GLOB1
      #--
      If ([M:DIV]ERROR) Then : Break : Endif
    Endif
  Next NC

  # Fin mode first row FQ79813
  Gosub UNSET_FIRST From TRTFIRST

  If ([M:DIV]ERROR) Then : End : Endif


  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

