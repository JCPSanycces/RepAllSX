#<AdxTL>@(#)0.0.0.0 $Revision$
# Modification must be done for (SAM 99288)
# Very tricky modification, needs intensive testing before delivering it
# In some cases, the order of the links is not the right one
Close Local File
Raz GPILOBJ , GNBMASKOUV
GCONSULT = 0
#Call OBJET("ALT",GBIDC1,GBIDC2) From GOBJET
Call VALIDE("AQCQRY01",nomap,0,0)
End

#------------------------------------------------------------------#
# Pour la copie des transactions
#------------------------------------------------------------------#

$TRTCOP
Gosub TRTCOP From SUBALT
Return

#------------------------------------------------------------------#
# Pour les patches des transactions
#------------------------------------------------------------------#

Subprog PATCH(APPLI)
Value Char APPLI
Call GENDOS(APPLI)
End

#------------------------------------------------------------------#
# Pg de mise à jour globale
#------------------------------------------------------------------#

Subprog GENDOS(APPLI)
Value Char APPLI

Local File =APPLI+".ALISTEH"  [ALH2]
Local File =APPLI+".ALISTEH"  [ALH]
Local File =APPLI+".ALISTED"  [ALD]
Local File =APPLI+".ALISTED"  [ALD2]
Local File =APPLI+".ALISTET"  [ALT]
Local File =APPLI+".ALISTEL"  [ALL]
Local File =APPLI+".ALISTER"  [ALR]
If dim([F:ALH]TYPENV)>0 & filinfo(filpath("FIL","ALISTENV","fde",APPLI),0)>0
 Local File =APPLI+".ALISTENV" [ALV]
Endif
Local File =APPLI+".AMSK"     [AMK]
Local File =APPLI+".AMSKZON"  [AMZ]
Local File =APPLI+".AMSKACT"  [AMA]
Local File =APPLI+".AMSKACT"  [AMA2]
Local File =APPLI+".AMSKPAR"  [AMP]
Local File =APPLI+".AMSKPAR"  [AMP2]
Local File =APPLI+".AWINDOW"  [AWI]
Local File =APPLI+".AWINPAR"  [AWP]
Local File =APPLI+".AWINBRO"  [AWB]
Local File =APPLI+".AWINBOUT" [AWT]
Local File =APPLI+".ATYPE"    [ATY]
Local File =APPLI+".ACCES"    [ACC]
Local File =APPLI+".ATEXTE"   [ATX]
Local File =APPLI+".ACTIV"    [ACV]
Local File =APPLI+".AOBJET"   [AOB]
If filinfo(filpath("FIL","AVIEWTAB","fde",APPLI),0)<0
& or filinfo(filpath("FIL","AVIEWFLD","fde",APPLI),0)<0
& or filinfo(filpath("FIL","AVIEWIND","fde",APPLI),0)<0
 Local File =APPLI+".ATABLE"  [AVWT]
 Local File =APPLI+".ATABZON" [AVWF]
 Local File =APPLI+".ATABIND" [AVWI]
Else
 Local File =APPLI+".AVIEWTAB" [AVWT]
 Local File =APPLI+".AVIEWFLD" [AVWF]
 Local File =APPLI+".AVIEWIND" [AVWI]
Endif

For [ALH2]ALH0 Where TYP=3 & ENAFLG=2
 Call ECR_TRACE([F:ALH2]COD,0) From GESECRAN
 Call VALIDE([F:ALH2]COD,APPLI,0,1)
Next
End

#------------------------------------------------------------------#
# Validation d'une liste
#------------------------------------------------------------------#

Subprog VALIDE(LISTE,APPLI,DEBUG,SILENCE)
Value Char    LISTE
Value Char    APPLI
Value Integer DEBUG
Value Integer SILENCE

If clalev([F:ALD2])=0 : Local File =APPLI+".ALISTED"  [ALD2] : Endif
If clalev([F:ALH])=0  : Local File =APPLI+".ALISTEH"  [ALH]  : Endif
If clalev([F:ALD])=0  : Local File =APPLI+".ALISTED"  [ALD]  : Endif
If clalev([F:ALT])=0  : Local File =APPLI+".ALISTET"  [ALT]  : Endif
If clalev([F:ALL])=0  : Local File =APPLI+".ALISTEL"  [ALL]  : Endif
If dim([F:ALH]TYPENV)>0 & filinfo(filpath("FIL","ALISTENV","fde",APPLI),0)>0
 If clalev([F:ALV])=0 : Local File =APPLI+".ALISTENV" [ALV]  : Endif
Endif
If clalev([F:AMP])=0  : Local File =APPLI+".AMSKPAR"  [AMP]  : Endif
If clalev([F:ATY])=0  : Local File =APPLI+".ATYPE"    [ATY]  : Endif
If clalev([F:ACC])=0  : Local File =APPLI+".ACCES"    [ACC]  : Endif
If clalev([F:ATX])=0  : Local File =APPLI+".ATEXTE"   [ATX]  : Endif
If clalev([F:ACV])=0  : Local File =APPLI+".ACTIV"    [ACV]  : Endif
If clalev([F:AOB])=0  : Local File =APPLI+".AOBJET"   [AOB]  : Endif

# Added  March 18, 2014 For generating links on fields that don't have a data type associated to a table
If clalev([F:ATZ])  : LogicClose File [ATZ]  : Endif : Local File =APPLI+".ATABZON"  [ATZ]
If clalev([F:ATB])  : LogicClose File [ATB]  : Endif : Local File =APPLI+".ATABLE"   [ATB]
If clalev([F:ATI])  : LogicClose File [ATI]  : Endif : Local File =APPLI+".ATABIND"   [ATI] :#SAM 116052
If clalev([F:ACLA]) : LogicClose File [ACLA] : Endif : Local File =APPLI+".ACLASSE"  [ACLA]
If clalev([F:AFC])  : LogicClose File [AFC]  : Endif : Local File =APPLI+".AFONCTION" [AFC]

If filinfo(filpath("FIL","AVIEWTAB","fde",APPLI),0)<0
& or filinfo(filpath("FIL","AVIEWFLD","fde",APPLI),0)<0
& or filinfo(filpath("FIL","AVIEWIND","fde",APPLI),0)<0
 If clalev([F:AVWT])=0 : Local File =APPLI+".ATABLE"  [AVWT] : Endif
 If clalev([F:AVWF])=0 : Local File =APPLI+".ATABZON" [AVWF] : Endif
 If clalev([F:AVWI])=0 : Local File =APPLI+".ATABIND" [AVWI] : Endif
Else
 If clalev([F:AVWT])=0 : Local File =APPLI+".AVIEWTAB" [AVWT] : Endif
 If clalev([F:AVWF])=0 : Local File =APPLI+".AVIEWFLD" [AVWF] : Endif
 If clalev([F:AVWI])=0 : Local File =APPLI+".AVIEWIND" [AVWI] : Endif
Endif
Gosub VARIABLES From SUBALH11

OK = 1
INTRQT = mess(276,139,1)-LISTE : # Requête graphique

Read [ALH]ALH0 = LISTE
If fstat
 OK = 0 : Call ECR_TRACE(INTRQT-":"-mess(23,100,1),1) From GESECRAN : # Fiche inexistante
 Goto FIN
Endif

Gosub LIENS
Gosub FIELDS From SUBALH11

If !OK
 Gosub DESACTIVE
 Goto FIN
Endif

# Debug
If DEBUG
 Call OUVRE_TRACE("") From LECFIC
 Call ECR_TRACE(TBFIC(F),0) From GESECRAN
 For I=1 To NBFIC2
  If I<>F
   If LORG(I)<>0
    Call ECR_TRACE(TBFIC(I)-"<="-TBFIC(LORG(I))-LCLE(I),0) From GESECRAN
   Endif
  Endif
 Next I
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif

# Mise à jour des types de données, longueur et no de tabdib/menu local des champs sélectionnés
Gosub MODFLD
If !OK : Goto FIN : Endif

# Génération du traitement
Gosub SYRA_TRT From SUBALH11
If !OK : Goto FIN : Endif

#---------------------------------#
$FIN
If !OK
 GERR = 1
Endif
End

#----------------------#
$MODFLD
If !adxlog
 Gosub TR_MODFLD
Else
 Gosub MAJ_MODFLD
Endif
Return

$TR_MODFLD
GOK = 1
Trbegin [ALD]
 Gosub MAJ_MODFLD
 If GOK<0 : Goto AB_TR_MODFLD : Endif
Commit
Return

$AB_TR_MODFLD
Rollback

$MAJ_MODFLD
For [ALD] Where COD=LISTE & CLC=""
 K = 0
 Read [ATY]CODTYP=[F:ALD]CODTYP
 If !fstat & [F:ATY]LNGTYP<>0 & [F:ATY]LNGTYP<>[F:ALD]LNG
  #K = 1 : [F:ALD]LNG = [F:ATY]LNGTYP : # ccl
 Endif
 If !fstat & [F:ALD]CODTYP<>"ADI" & [F:ATY]NOLIB<>0 & [F:ATY]NOLIB<>[F:ALD]NOLIB
  K = 1 : [F:ALD]NOLIB = [F:ATY]NOLIB
 Endif
 If K
  Rewrite [ALD]
  If fstat
   GOK = 0 : Call FSTA("ALD") From GLOCK : Break
  Endif
 Endif
Next ALD
Return

#---------------------------------#
$VARIABLES
Local Char     LAN(GLONLAN)(1..1)
Local Integer  I , J , K , F , L , M , N , OK , DIME , STAT
Local Shortint MAXFIC , MAXBOUT , MAXLIEN , MAXCOL , MAXLNK
If !clalev([M:ALH1]) : Local Mask ALH1 [ALH1] : Endif
MAXFIC  = 80
MAXBOUT = 16
MAXLIEN = 30
MAXCOL  = max(16,dim([M:ALH1]FLD)-1)
MAXLNK  = 12   : # Nombre de liens maxi sur un link
Local Integer  NBFIC , NBFIC2 , NBLAN , PASSE , OKL , OKLIEN
Local Integer  P , OKFLD , ERFLD
Local Schar    TBFIC(GLONATB)(1..MAXFIC) , ABFIC(GLONABR+2)(1..MAXFIC)
Local Schar    TLIEN(250),FLDVCR(20) , FLDLIG(250) , TTYPE(GLONATY) , TBCHP(30)(1..200)
Local Schar    TCOL(30)(1..MAXBOUT,1..MAXCOL) , TTYP(GLONATY)(1..MAXBOUT,1..MAXCOL)
Local Schar    TOBJ(GLONAOB)(1..MAXBOUT) , TNIV(30)(1..MAXBOUT)
Local Schar    LCLE(GLONANX)(1..MAXFIC)
Local Integer  LIMP(1..MAXFIC) , LIMO(1..MAXFIC,1..MAXBOUT) , LIND(1..MAXFIC)
Local Decimal  TLNG(1..MAXBOUT,1..MAXCOL)
Local Integer  TMEN(1..MAXBOUT,1..MAXCOL) , THOM(1..MAXBOUT) , TINT(1..MAXBOUT)
Local Integer  LIEN(1..MAXFIC) , LORG(1..MAXFIC) , LNUM(1..MAXFIC) , LORD(1..MAXFIC)
Local Integer  RAZB(1..MAXBOUT)
Local Char     CHAINE(250) , ZONE(80) , MODLEC(2)
Local Char     LNKFIC(GLONABR+2) , DESAX(GLONAX2)
Local Char     TRAITE(GLONADC) , FICTRT(GDIMFIC) , MAGIC(80)
Local Char     SAVIFS(5) , SAVIRS(5) , IDENT(250)
Local Char     ABREV(GLONABR+2) , INDEX(GLONANX)
Local Integer  SAVIUM
Local Integer  NBCHP , NBGRP , GROUPE , SPA , LONG , NBCOL , NBLNK
Local Integer  TRI(20) , CUM , NIVEAU
Local Integer  NBTXT , LIGTXT(1..20) , TYPTXT(1..20)
Local Schar    CHTXT(GLONAVA)(1..20) , ABTXT(GLONABR+2)(1..20) , TBTXT(GLONATB)(1..20)
Local Char     AOBSIT(GLONAVA) , AOBACC(GLONAVA) , AOBFIC(GLONAVA)
Local Schar    TBORG(GLONATB)(1..MAXLIEN) , TBDES(GLONATB)(1..MAXLIEN)
Local Schar    ZNORG(20)(1..MAXLIEN) , ZNDES(20)(1..MAXLIEN)
Local Integer  AI , AJ , AK
Local Integer  NBLIEN , TBLNK(1..MAXLIEN)
Local Integer  FLCLOB
Local Char     CH2(250) , CH3(250) , CH4(250) , INTRQT(40)
Local Integer  TBRANG(1..MAXCOL)
Local Integer  LIENCOMPO
Local Schar    ESC(5)
Return

#-------------------------------------------------------#
# Désactivation d'une liste en erreur
#-------------------------------------------------------#

$DESACTIVE
If !adxlog
 Gosub TR_LISTE
Else
 Gosub MAJ_LISTE
Endif
If GOK=1
 Call ECR_TRACE(INTRQT-":"-mess(62,139,1),-1) From GESECRAN : # Fiche désactivée
Endif
Return

$TR_LISTE
GOK=1
Trbegin [ALH]
 Gosub MAJ_LISTE
 If GOK<0 : Goto AB_TR_LISTE : Endif
Commit
Return

$AB_TR_LISTE
Rollback
Return

$MAJ_LISTE
Readlock [ALH]ALH0 = LISTE
If fstat=1
 GOK = -1 : GLOCK = "$ALISTEH"
Else
 [F:ALH]ENAFLG = 1
 Rewrite [ALH]
 If fstat
  GOK = 0 : Call FSTA("ALH") From GLOCK
 Endif
Endif
Return

#---------------------------------------------------------------#
# Etablissement des liens
#---------------------------------------------------------------#

Funprog TABLE(COD,ABRFIC)
Value Char COD
Value Char ABRFIC
Local Char TABLE(GLONATB)
For [ALT]Where COD = [L]COD
 Read [AVWT]CODFIC = [F:ALT]TBL
 If !fstat & [F:AVWT]ABRFIC = [L]ABRFIC
  TABLE = [F:ALT]TBL : Break
 Endif
Next
End TABLE

$LIENS

# Nombre de tables liées sur la table principale

Raz NBLNK
If [F:ALH]OBJLNK<>""
 Read [AOB]ABREV = [F:ALH]OBJLNK
 If !fstat & [F:AOB]ZACC<>""
  NBLNK += 1
 Endif
Endif

## Numéro des colonnes des champ visibles

Raz TBRANG , I
For [ALD]ALD0 Where COD=LISTE & STREND<=2
 I += 1
 TBRANG([F:ALD]LIG) = I
Next ALD

## Chargement des tables des champs sélectionnés

Raz TBFIC , NBFIC
For [ALD]ALD0 Where COD=LISTE & STREND<=2 & CLC=""
 If find([F:ALD]CODTYP,"ATX","AXX","AX1","AX2","AX3")
  NBLNK += 1
 Endif
 If !find([F:ALD]TBL,TBFIC(1..NBFIC))
  Read [AVWT]CODFIC = [F:ALD]TBL
  If fstat
   Call ECR_TRACE(INTRQT-":"-func AFNC.MES(mess(85,133,1),[F:ALD]TBL),-1) From GESECRAN : # Table # inexistante
   OK = 0 : Break
  Else
   Read [ALT]ALT0 = LISTE;[F:ALD]TBL
   If fstat
    Call ECR_TRACE(INTRQT-":"-func AFNC.MES(mess(263,139,1),[F:ALD]TBL),-1) From GESECRAN : # Table # non déclarée
    OK = 0 : Break
   Endif
  Endif
  NBFIC += 1
  TBFIC(NBFIC) = [F:ALD]TBL
  ABFIC(NBFIC) = [F:AVWT]ABRFIC
 Endif
Next ALD
If !OK : Return : Endif

## Chargement des autres tables

For [ALT] Where COD=LISTE
 If !find([F:ALT]TBL,TBFIC(1..NBFIC))
  Read [AVWT]CODFIC = [F:ALT]TBL
  If fstat
   Call ECR_TRACE(INTRQT-":"-func AFNC.MES(mess(85,133,1),[F:ALT]TBL),-1) From GESECRAN : # Table inexistante
   OK = 0 : Break
  Else
   NBFIC += 1
   TBFIC(NBFIC) = [F:ALT]TBL
   ABFIC(NBFIC) = [F:AVWT]ABRFIC
  Endif
 Endif
Next ALT
If !OK
 Return
Elsif NBFIC=0
 Call ECR_TRACE(INTRQT-":"-mess(116,141,1),0) From GESECRAN : # Aucune table déclarée
 OK = 0 : Return
Endif

## Chargement des liens du flash

Raz TBORG , TBDES , ZNORG , ZNDES , NBLIEN , TBLNK
For [ALL] Where COD=LISTE
 K = instr(1,[F:ALL]LNKORG,"]")
 If K
  NBLIEN += 1
  ZNORG(NBLIEN) = right$([F:ALL]LNKORG,K+1)
  TBORG(NBLIEN) = func TABLE(LISTE,seg$([F:ALL]LNKORG,2,K-1))
  TBLNK(NBLIEN) = [F:ALL]LNKTYP
  K = instr(1,[F:ALL]LNKDES,"]")
  If K
   ZNDES(NBLIEN) = right$([F:ALL]LNKDES,K+1)
   TBDES(NBLIEN) = func TABLE(LISTE,seg$([F:ALL]LNKDES,2,K-1))
  Endif
 Endif
Next ALL

# Chargement des liens imposés
Raz LIMP, LIMO
For I=0 To dim([F:ALH]LNK)-1
 If [F:ALH]LNK(I)<>""
  CHAINE = vireblc([F:ALH]LNK(I),4)
  J = instr(1,CHAINE,"=")
  If J
   ZONE   = left$(CHAINE,J-1)
   CHAINE = right$(CHAINE,J+1)
   J = instr(1,ZONE,"]")
   If J
    ZONE   = seg$(ZONE,2,J-1)
   Endif
   If left$(ZONE,2)="F:" : ZONE = right$(ZONE,3) : Endif
   K = find(ZONE,ABFIC(1..NBFIC))
   If K
    Read [AVWT]CODFIC=func TABLE(LISTE,ZONE)
    If !fstat
     # Pour virer les liens saisis dans le bloc flash
     J = find([F:AVWT]CODFIC,TBDES(1..NBLIEN))
     While J
      Dela J,1 TBDES,TBORG,ZNORG,ZNDES,TBLNK
      NBLIEN -= 1
      J = find([F:AVWT]CODFIC,TBDES(1..NBLIEN))
     Wend
     LIMP(K) = 1
     LIND(K) = I
     While CHAINE<>""
      J = instr(1,CHAINE,";")
      If J
       ZONE   = left$(CHAINE,J-1)
       CHAINE = right$(CHAINE,J+1)
      Else
       ZONE   = CHAINE
       CHAINE = ""
      Endif
      If left$(ZONE,1)="["
       J = instr(1,ZONE,"]")
       If J
        ZONE = seg$(ZONE,2,J-1)
        If left$(ZONE,2)="F:" : ZONE = right$(ZONE,3) : Endif
        J = find(ZONE,ABFIC(1..NBFIC))
        If J
         LIMO(K,LIMP(K)) = J
         LIMP(K) += 1
        Endif
       Endif
      Endif
     Wend
    Endif
   Endif
  Endif
 Endif
Next I

F = 0
PASSE = 0

#---------------------------------#
# Boucle de recherche
#---------------------------------#

$LIENS0
F += 1
If F>NBFIC
 If PASSE=0
  PASSE = 1 : F = 1
 Else
  Call ECR_TRACE(INTRQT-":"-mess(7,124,1),0) From GESECRAN : # Liens impossibles
  OK = 0 : Return
 Endif
Endif

If LIMP(F) : Goto LIENS0 : Endif

Raz LIEN, LORG, LCLE
LIEN(F) = 1

## Ajout de fichiers en 2ème passe

NBFIC2 = NBFIC
If PASSE=1
 For I=1 To NBLIEN
  If TBORG(I)=TBFIC(F)
   If !find(TBDES(I),TBFIC(1..NBFIC2))
    Read [AVWT]CODFIC = TBDES(I)
    If fstat
     # Lien impossible\Table inexistante
     Call ECR_TRACE(INTRQT-":"-mess(45,105,1)-func AFNC.MES(mess(85,133,1),TBDES(I)),-1) From GESECRAN
     OK = 0 : Break
    Else
     NBFIC2 += 1
     TBFIC(NBFIC2) = TBDES(I)
     LIEN(NBFIC2)  = 1
     LORG(NBFIC2)  = F
     Gosub INDEX From SUBALH11
     LCLE(NBFIC2)  = INDEX
    Endif
   Endif
  Endif
 Next I
Endif
If !OK : Return : Endif

#---------------------------------#
# Etablissement des liens
#---------------------------------#

$LIENS1
OKL = 0
For I=1 To NBFIC2
 If LIMP(I)
  LIEN(I) = 1
 Elsif !LIEN(I)
  For J=1 To NBFIC2
   If LIEN(J)
    For K=1 To NBLIEN
     If TBDES(K)=TBFIC(I) & TBORG(K)=TBFIC(J)
# Changes in the determination of the order (SAM 99288)
# Lines to be added ? LIEN(I) is not OK
#     If LIEN(I)
#       LORG(I)=max(LORG(I),J)
#     Else
# End of addition
        LIEN(I) = 1
        LORG(I) = J
        # Recherche de l'index de la table destination
        Gosub INDEX From SUBALH11
        LCLE(I) = INDEX
        OKL = 1
# Changes in the determination of the order (SAM 99288)
# Line to be added ?
#     Endif
# Line to be suppressed ?
      Break
# End of addition
     Endif
    Next K
   Endif
   If LIEN(I) : Break : Endif
  Next J
 Endif
Next I

If sum(LIEN(1..NBFIC))<>NBFIC
 If OKL : Goto LIENS1 : Else : Goto LIENS0 : Endif
Endif

## Suppression fichiers inutiles

I = NBFIC+1
While I<=NBFIC2
 If !find(I,LORG(1..NBFIC))
  Dela I  TBFIC, LIEN, LORG, LCLE, LIND
  NBFIC2 -= 1
  For J=1 To NBFIC
   If LORG(J)>I : LORG(J) -= 1 : Endif
  Next J
 Else
  I += 1
 Endif
Wend

## Tri dans l'ordre de necessité et renumérotage

For I=1 To NBFIC2
 LNUM(I) = I
Next I

Raz LORD
LORD(F) = 1

For K=1 To NBFIC2
 For I=1 To NBFIC2
  If LIMP(I)
   If LORD(I)=0
    OKL = 1
    For J=1 To LIMP(I)-1
     If LORD(LIMO(I,J))=0 or LORD(LIMO(I,J))>K : OKL = 0 : Endif
    Next J
   Else
    OKL = 0
   Endif
  Else
   If LORG(I)>0 & LORD(LORG(I))=K
    OKL = 1
   Else
    OKL = 0
   Endif
  Endif
  If OKL : LORD(I) = K+1 : Endif
 Next I
Next K

If find(0,LORD(1..NBFIC2))
 Goto LIENS0
Endif

# LNUM dépend de l'ordre des champs affichés
# Il faut respecter cet ordre pour éviter les erreurs de liens sous SQL
# C'est-à-dire qu'une table utilisée dans un lien doit être déclarée avant dans le link

Sorta NBFIC2 LORD, LNUM, ABFIC, TBFIC, LIEN, LORG, LCLE, LIMP, LIND
#Sorta NBFIC2 LORD, TBFIC, LIEN, LORG, LCLE, LNUM, LIMP, LIND
F = 1

For I=1 To NBFIC2
 K = find(LORG(I),LNUM(1..NBFIC2))
 If K
  LORG(I) = K
 Endif
Next I

NBLNK += NBFIC2-1
If NBLNK>MAXLNK
 # Trop de liens sur cette table
 Call ECR_TRACE(INTRQT-"->"-func TABLE(LISTE,ABFIC(F))-":"-mess(12,133,1)-"(>"+num$(MAXLNK)+")",-1) From GESECRAN
 OK = 0 : Return
Endif

Return

#-------------------------------------------------------#

$VERIF_ALD
NBTXT = 0
For [ALD]ALD0 Where COD=LISTE & STREND<=2
 Read [AVWT]CODFIC = [F:ALD]TBL
 If !fstat
  Case [ALD]CODTYP
   When "ATX"
    NBTXT += 1
    TBTXT(NBTXT)  = [F:ALD]TBL
    CHTXT(NBTXT)  = [F:ALD]FLD
    LIGTXT(NBTXT) = TBRANG([F:ALD]LIG)
    ABTXT(NBTXT)  = [F:AVWT]ABRFIC
    TYPTXT(NBTXT) = 1
   When "AXX","AX1","AX2","AX3"
    NBTXT += 1
    TBTXT(NBTXT)  = [F:ALD]TBL
    CHTXT(NBTXT)  = [F:ALD]FLD
    LIGTXT(NBTXT) = TBRANG([F:ALD]LIG)
    ABTXT(NBTXT)  = [F:AVWT]ABRFIC
    TYPTXT(NBTXT) = 2
    For GBIDC1="CLECUR1","CLECUR2"
     Read [AMP]CODPAR=2;TBTXT(NBTXT);CHTXT(NBTXT);GBIDC1
     If !fstat & instr(1,[AMP]VALPAR,"+")
      #If GTRACE<>""
      # Call ECR_TRACE([F:ALD]TBL-":"-[F:ALD]FLD-"("+[ALD]CODTYP+")"-mess(214,133,1),-1) From GESECRAN
      # Endif
      TYPTXT(NBTXT) = 3 : Break
     Endif
    Next GBIDC1
  Endcase
 Endif
Next ALD
Return

