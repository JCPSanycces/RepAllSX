#<AdxTL>@(#)11.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("AMK",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBAMKB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "FILGAUCHE"  : Gosub FILGAUCHE
 When "FERME"      : Gosub FERME
 When "LIENS"      : Gosub LIENS
 When "INICRE"     : Gosub INICRE
 When "INIMOD"     : Gosub INIMOD
 When "RAZDUP"     : Gosub RAZDUP
 When "CREATION"   : Gosub CREATION
 When "ANNULE"     : Gosub ANNULE
 When "AP_ANNULE"  : Gosub AP_ANNULE
 When "MODIF"      : Gosub MODIF
 When "APRES_MOD"  : Gosub APRES_MOD
 When "SETBOUT"    : Gosub SETBOUT
 When "EXEBOUT"    : Gosub EXEBOUT
 When "VERIF_CRE"  : Gosub VERIF_CRE
 When "VERIF_MOD"  : Gosub VERIF_MOD
 When "ABANDON"    : Gosub ABANDON
 When "FIN_MOD"    : Gosub FIN_MOD
Endcase
If PSUBB
 Gosub ACTION From SUBAMKB
Endif
Return

############################################################
$OUVRE
If clalev([F:AM2])=0 : Local File AMSKACT  [AM2] : Endif
If clalev([F:AP2])=0 : Local File AMSKPAR  [AP2] : Endif
Local Integer STAT
If GLIAISON<>"" or GLIAISON(1)<>""
 If clalev([F:ALI])=0 : Local File ALINK [ALI] : Endif
 Local Integer WNB0 , WNB1
 Local Schar    WLNK0(GLONACT+3)(1..800) , WLNK1(GLONACT+3)(1..800)
Endif
Return

############################################################
$FERME
If GIMPORT : Return : Endif
If dim(GVISUW)>0
  Call SUPWINDIC(nomap,GVISUW) From INTRUTILB
  Kill GVISUW
Endif
Gosub FERME_BOITE From =WINPROG
Close Local Mask
OK=0
Inftxt " " At 2
Return

############################################################
$LIENS
If dim(GVISUW)>0
  Call SUPWINDIC(nomap,GVISUW) From INTRUTILB
  Kill GVISUW
Endif
Call TEXTE([M:AMK0]INTMSK,[M:AMK0]ZINTMSK) From OBJDIV
For I=0 To [M:AMK1]NBBLOC-1
 Call TEXTE([M:AMK1]TITBLOC(I),[M:AMK1]ZTITBLOC(I)) From OBJDIV
Next I
For I=0 To [M:AMK1]NBFIC-1
 Call LECTURE("ATB",[M:AMK1]FICREF(I),"") From CONTOBJ
Next I
For I=0 To [M:AMK1]NBBLOC-1
 If [M:AMK1]INTBLOC(I)<>""
  [M:AMK1]TITBLOC(I) = 0
  [M:AMK1]ZTITBLOC(I) = "$"
 Endif
 [M:AMK1]OTYPBLOC(I) = [M:AMK1]TYPBLOC(I)
Next I

nolign = 0
For [AMZ]CODZON Where CODMSK=[F:AMK]CODMSK
 nolign += 1
 [M:AMK2] = [F:AMZ]
# Issue X3-58759 - 2018-06-29 by CCC : to alert if Cancel is required afterwards
# Init ACTUPDFLG=1 for fields already existing
 If dim([M:AMK2]ACTUPDFLG)>0
    [M:AMK2]ACTUPDFLG(nolign-1) = 1
 Endif
 If [F:AMZ]INTEVAL<>""
  [M:AMK2]INTIT(nolign-1)  = 0
  [M:AMK2]ZINTIT(nolign-1) = "$"
 Else
  Call TEXTE([M:AMK2]INTIT(nolign-1),[M:AMK2]ZINTIT(nolign-1)) From OBJDIV
 Endif
 #Call TEXTE([M:AMK2]INFBUL(nolign-1),[M:AMK2]ZINFBUL(nolign-1)) From OBJDIV
 If [F:AMZ]CHPARG<>""
  Call LECTEXTRA([M:AMK2]ACHPARG(nolign-1),"ATABDIV","LNGDES","915",left$([F:AMZ]CHPARG,3)) From ATEXTRA
 Endif
Next AMZ
[M:AMK2]NBLIG = nolign
Default Mask [AMK2]
If [M:AMK2]NBLIG>0
 NOL=0 : Gosub SETZON From SUBAMK2
 Call CHARGE_ACT([F:AMK]CODMSK,[M:AMK2]ZONCUR) From PARMNT
Endif
If GLIAISON(1)<>""
 WNB0 = 0
 For [AMA]TYPAFF Where TYPAFF=1 & CODAFF=[F:AMK]CODMSK & !find(ACTION,"SPE","STD","SPV")
  WNB0 += 1
  WLNK0(WNB0) = "ACT"+[F:AMA]ACTION
 Next AMA
 For [AMZ]CODE Where CODMSK=[F:AMK]CODMSK & NOLIB<>0
  WNB0 += 1
  WLNK0(WNB0) = "AML"+num$([F:AMZ]NOLIB)
 Next AMZ
Endif
Call AM_TYPMSK([F:AMK]TYPMSK) From SUBAMK1
ILIS = val(right$(currbox,8))
If OBJLIS(ILIS)="AET"
 Gosub FILGAUCHE
 Gosub REMP_LISGAU From GOBJSUB
Endif
Affzo [AMK2]CODZON , CODTYP
For nolign=1 To [M:AMK2]NBLIG
 If nolign=1
  Chgstl [M:AMK2]CODZON(0) With "AMKCUR"
 Else
  Look [AMA]TYPAFF(3)=1;[M]CODMSK;[M]CODZON(nolign-1)
  If !fstat
   Chgstl [M:AMK2]CODZON(nolign-1) With "AMKACT"
  Else
   Chgstl [M:AMK2]CODZON(nolign-1) With ""
  Endif
 Endif
 K = 0
 Read [ATY]CODTYP=[M:AMK2]CODTYP(nolign-1)
 If !fstat
  K = ([F:ATY]NBTYP>0) : # Et tant pis s'il n'y a pas de paramètres
  If [F:ATY]OBJLIEN<>""
   Read [AOB]ABREV=[F:ATY]OBJLIEN
   If !fstat
    If [F:AOB]LIBPAR<>0 : K = 1 : Endif
    If [F:AOB]NBOPT<>0 : K = 1 : Endif
   Endif
  Endif
  K += ([F:ATY]PARTAB<>"")
 Endif
 If [M:AMK2]OPTOBJ(nolign-1)<>""
  K += 1
 Endif
 If K
  Chgstl [M:AMK2]CODTYP(nolign-1) With "AMKACT"
 Else
  Chgstl [M:AMK2]CODTYP(nolign-1) With ""
 Endif
Next nolign
Return


############################################################
$RAZDUP
Call DUPLI_ACT([M]CODMSK,zc) From PARMNT
Return

############################################################
$FILGAUCHE
If OBJLIS(ILIS)="AET"
 FILGAUSUP = "ELTTYP='FENX' and ELTTYPLK='SCRN' and ELTLK=[F:AMK]CODMSK"
Endif
Return

############################################################
$INICRE
$INIMOD
[F:AMK]UPDFLG = 0
[F:AMK]CODACT = [M:AMK1]CODACT : # A cause du CODACT dans les lignes [AMK2]
Return

############################################################
$CREATION
Gosub ECRIRE
If GLIAISON(1)<>""
 WNB0 = 0 : Gosub CRE_LIENS
Endif
Return

$ECRIRE
Call TEMPON("E") From GESECRAN
For nolign=1 To [M:AMK2]NBLIG
 Raz [F:AMZ]
 [F:AMZ] = [M:AMK0]
 [F:AMZ] = [M:AMK2]
 I = [F:AMZ]NUMBLOC-1
 If [F:AMK]TYPBLOC(I)=1 & [F:AMZ]CODZON<>[F:AMK]BASPAG(I)
  [F:AMZ]DIME = [F:AMK]NBLIGT(I)
 Endif
 If [F:AMK]TYPBLOC(I)=5 & [F:AMZ]SAIAFF<>3 : # mb 25.3.2 bug 13569
  [F:AMZ]SAIAFF = 3 : # Invisible
  [F:AMZ]OBLIG  = 0
  [F:AMZ]TUNNEL = 0
  [F:AMZ]LIEN   = 0
  [F:AMZ]CODACC = ""
#  [F:AMZ]MOTCLE = ""
  [F:AMZ]CONSAI = ""
  [F:AMZ]CODCTL = ""
  [F:AMZ]ISMASKABLE = 1 :#X3-91078
  [F:AMZ]BREAKAFTER = 1 # Issue X3-110075 - 2018-10-02 by ALSHE : Field initialisation
 Endif
 If dim([F:AMZ]RANG)>0
 [F:AMZ]RANG=[F:AMK]RANG(I) :#X3PLAT-2092
 Endif
 #X3-100791
 If dim([F:AMZ]ISMASKABLE)>0 and [F:AMZ]ISMASKABLE=0
  [F:AMZ]ISMASKABLE=1
 Endif
 #End X3-100791
 # Issue X3-110075 - 2018-10-02 by ALSHE : to avoid issue when updating integration branch (X3-100791)
 If dim([F:AMZ]BREAKAFTER)>0 and [F:AMZ]BREAKAFTER=0
  [F:AMZ]BREAKAFTER=1
 Endif
 # End issue X3-110075
 Write [AMZ]
 If fstat
  GOK=0 : Call FSTA("AMZ") From GLOCK : Break
 Endif
Next
AFF = CLECUR1 : Gosub VERFACT From PARMNT
Call TEMPOFF From GESECRAN
Return

############################################################
$MODIF
Delete [AMZ] Where CODMSK=CLECUR1
If fstat=1
 GOK=-1 : Call RSTA("AMZ",CLECUR1) From GLOCK : Return
Else
 Gosub ECRIRE
Endif
If GLIAISON(1)<>""
 Gosub CRE_LIENS
Endif
Return

$CRE_LIENS
WNB1 = 0
For [AMA]TYPAFF Where TYPAFF=1 & CODAFF=[F:AMK]CODMSK & !find(ACTION,"SPE","STD","SPV")
 WNB1 += 1
 WLNK1(WNB1) = "ACT"+[F:AMA]ACTION
Next AMA
For [AMZ]CODE Where CODMSK=[F:AMK]CODMSK & NOLIB<>0
 WNB1 += 1
 WLNK1(WNB1) = "AML"+num$([F:AMZ]NOLIB)
Next AMZ
For I=1 To WNB0
 If !find(WLNK0(I),WLNK1(1..WNB1))
  Delete [ALI] Where USRCOD=GLIAISON(1) & SRCOBJ=left$(WLNK0(I),3) & SRCKEY=right$(WLNK0(I),4)
&                  & DSTOBJ="AMK" & DSTKEY=[F:AMK]CODMSK
 Endif
Next I
For I=1 To WNB1
 If !find(WLNK1(I),WLNK0(1..WNB0))
  Raz [F:ALI]
  [F:ALI]USRCOD = GLIAISON(1)
  [F:ALI]SRCOBJ = left$(WLNK1(I),3)
  [F:ALI]SRCKEY = right$(WLNK1(I),4)
  [F:ALI]DSTOBJ = "AMK"
  [F:ALI]DSTKEY = [F:AMK]CODMSK
  [F:ALI]DSTXXX = [F:ALI]DSTOBJ+"|"+[F:ALI]DSTKEY
  [F:ALI]DSTTIT = 47
  Call TEXTE([F:AMK]INTMSK,[F:ALI]DSTDES) From OBJDIV
  [F:ALI]LNK    = "U"
  [F:ALI]INVFLG = 2
  [F:ALI]AUTFLG = 2
  [F:ALI]ENAFLG = 2
  [F:ALI]CREDAT = date$
  [F:ALI]CREUSR = GUSER
  Write [ALI]
 Endif
Next I
Return

############################################################
$APRES_MOD
If [F:AMK]MDL=2
 Call DEL_TRTMSK([F:AMK]CODMSK,nomap) From MSKDIV
Endif
Return

############################################################
$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET : # Changement de clé
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V236") From GOBJET : # Validation, Copie, Visu
 Call VIREBOUT(CHMEN,"6") From GOBJET
Else
 CHMEN += "784" : # Icônes
# If GVIRTDIR=""
#  Call VIREBOUT(CHAINE,"4") From GOBJET : # Pas de répertoire de publication défini
# Endif
 K = 0
 For I=0 To [M:AMK1]NBBLOC-1
  If [M:AMK1]TYPBLOC(I)<>5 : # Invisible
   If [M:AMK1]TYPBLOC(I)=1 & [M:AMK2]NBLIG>0
    J = find([M:AMK1]BASPAG(I),[M:AMK2]CODZON(0..[M:AMK2]NBLIG-1))
    If J & [M:AMK2]SAIAFF(J-1)<3 : # Invisible
     K = 1 : Break
    Else
     K = 1 : Break
    Endif
   Else
    K = 1 : Break
   Endif
  Endif
 Next I
 If !K or filinfo(filpath(adxrob(0),CLECUR1,"msk"),0)<0
  Call VIREBOUT(CHAINE,"3") From GOBJET
 Endif
 If [M:AMK1]TYPMSK=6 and GFUSION<>1
   CHMEN += "6" : # Visu VT
 Endif
Endif
If GBROWS or GFUSION=1
  Call VIREBOUT(CHAINE,"3") From GOBJET : # Visu
Endif
#If GFUSION=1
#  Call VIREBOUT(CHAINE,"4") From GOBJET : # Visu
#Endif
If [M:AMK0]MDL=2
 Call VIREBOUT(CHAINE,"V3") From GOBJET
 Call VIREBOUT(CHMEN,"6") From GOBJET
Endif
Return

############################################################
$EXEBOUT
Case REP
 When "3"
  Call VISUM(CLECUR1)
 When "4"
  Call VISUMWEB(CLECUR1)
 When "V"
  Gosub VERIF
  If OK
   OK = 2
   Call OUINON(mess(139,123,1)-CLECUR1,OK) From GESECRAN : # Validation écran
   If OK<>2 : Return : Endif
   Read [ADS]DOSSIER = nomap
   Call VALID(CLECUR1,nomap,[F:ADS]NBRLAN,[F:ADS]LAN,0,OK) From VALMSK
   If !OK : Return : Endif
   Read [AMK]CODMSK = CLECUR1

   # Exigence 52086

   Local Integer T_HAS_TABLE
   Local Integer T_HAS_REF_TABLE
   Local Integer T_NBOBJ_CHECKED
   Local Char T_OBJ_CHECKED(30)(1..10)
   Local Integer T_ALREADY_CHECKED
   Local File AWINDOW [AWI02]
   Local File AOBJET  [AOB02]

   # check if the screen has a "tableau" block
   For I=1 To [AMK]NBBLOC
    If [F:AMK]TYPBLOC(I-1) = 1
     T_HAS_TABLE = 1 : Break
    Endif
   Next I

   If T_HAS_TABLE
    # Look for the assocated object using the reference table
    Filter [AOB02] Where NOMFIC = [F:AMK]FICREF(0)
    For [AOB02]
     T_HAS_REF_TABLE = 1
     If [F:AOB02]TYPGES = 2 or [F:AOB02]TYPGES = 3
      Call VALID([F:AOB02]ABREV,nomap,1,OK) From VALOBJ
     Endif
    Next
    Filter [AOB02]

    # In case no referece table, try to find the object in this way: ECRAN - FENETRE - OBJET
    If !T_HAS_REF_TABLE
     # Look for the windows of type "object" and using the current screen as the primary screen
     Filter [F:AWI02] Where NOMMSK(0) = CLECUR1 and WINTYP = 2
     For [AWI02]
      T_ALREADY_CHECKED = 0
      # verify if this object is already checked
      If T_NBOBJ_CHECKED>0
       For I = 1 To T_NBOBJ_CHECKED
        If T_OBJ_CHECKED(I) = [AWI02]OBJ
         T_ALREADY_CHECKED = 1 : Break
        Endif
       Next
      Endif
      # check the object only if not done yet
      If !T_ALREADY_CHECKED
       T_NBOBJ_CHECKED += 1
       T_OBJ_CHECKED(T_NBOBJ_CHECKED)=[AWI02]OBJ
       Read [AOB02]ABREV = [AWI02]OBJ
       If !fstat
        # in case type is "En tableau" or "Combiné", validate the object
        If [F:AOB02]TYPGES = 2 or [F:AOB02]TYPGES = 3
         Call VALID([F:AOB02]ABREV,nomap,1,OK) From VALOBJ
        Endif
       Endif
      Endif
     Next
     Filter [AWI02]
    Endif
   Endif

   Close File [AOB02]
   Close File [AWI02]
   # End Exigence 52086

  Endif
 When "E"
  Call IMPRESSION(CLECUR1)
Endcase
Return

Subprog IMPRESSION(CLE)
Value Char CLE
End

############################################################
$ABANDON
If REP="D"
 Look [AMK]CODMSK = [M]CODMSK
 If fstat : # mb 30.10.01 Peut-être l'origine du bug des actions perdues ...
  Delete [AMA] Where TYPAFF=1 & CODAFF=[M]CODMSK
  If fstat=1  : GOK=-1 : Call RSTA("AMA",[M]CODMSK) From GLOCK : Return : Endif
  Delete [AMP] Where TYPAFF=1 & CODAFF=[M]CODMSK
  If fstat=1  : GOK=-1 : Call RSTA("AMP",[M]CODMSK) From GLOCK : Return : Endif
 Endif
Else
    Call VERIF_ACT([M]CODMSK) From PARMNT
    # Issue X3-58759 - 2018-06-29 by CCC : alert if Cancel is required and actions have already been modified
    # ACTUPDFLG=0 --> new field
    #          =1 --> action not modified
    #          =2 --> action or action's parameter modified
    If dim([M:AMK2]ACTUPDFLG)>0 & find(2, [M:AMK2]ACTUPDFLG)>0
        Local Char LSTFLD(250)
        Raz LSTFLD
        For I=0 To [M:AMK2]NBLIG-1
            LSTFLD-=string$([M:AMK2]ACTUPDFLG(I)=2,[M:AMK2]CODZON(I))
        Next
        # Modifications that can't be canceled have been done in the actions of these fields : $1$
        Call MESSAGE(func AFNC.MES1(mess(333,123,1),LSTFLD)) From GESECRAN
    Endif
Endif
Return

############################################################
$FIN_MOD
Call VERIF_ACT([M]CODMSK) From PARMNT
Return

############################################################
$VERIF_CRE
$VERIF_MOD
Call CONTPAR([M]CODMSK,OK) From PARMNT
If [M]MDL<>2
 Gosub VERIF_MAX
 If !OK : Return : Endif
Endif
Return

$VERIF
OK=1
If [M:AMK1]NBBLOC=0
 GMESSAGE = mess(144,123,1) : # Aucun bloc défini
 OK = 0 : Return
Endif
If [M:AMK1]NBBLOC>1
 For I=0 To [M:AMK1]NBBLOC-1
  If find([M:AMK1]RANG(I),[M:AMK1]RANG(0..I-1),[M:AMK1]RANG(I+1..[M:AMK1]NBBLOC-1))
   GMESSAGE = mess(145,123,1)+num$([M:AMK1]RANG(I))
   # Il existe 2 blocs avec le rang ...
   OK=0 : Break
  Endif
 Next I
Endif
If !OK : Return : Endif

#  Controle tableau
For I=0 To [M:AMK1]NBBLOC-1
 If [M:AMK1]TYPBLOC(I)=1
  J = find([M:AMK1]BASPAG(I),[M:AMK2]CODZON(0..[M:AMK2]NBLIG-1))
  If J=0
  # Variable bas de Tableau inexistante
   GMESSAGE = [M:AMK1]BASPAG(I)-":"-mess(140,123,1)
   OK=0 : Break
  Else
   For K=0 To [M:AMK2]NBLIG-1
    If [M:AMK2]NUMBLOC(K)=I+1 & K<>J-1
&    & ([M:AMK2]NOZONE(K)<[M:AMK2]NOZONE(J-1)
&   or ([M:AMK2]NOZONE(K)=[M:AMK2]NOZONE(J-1) and [M:AMK2]CODZON(K)<[M:AMK2]CODZON(J-1)))
     GMESSAGE = [M:AMK2]CODZON(J-1)-":"-mess(140,126,1)
     # La variable de bas de tableau doit être la première du bloc
     OK = 0 : Break 2
    Endif
    # Si la variable de tableau est en mode "affiché", il ne faut pas qu'il y ait de champs en mode "saisie"
    If [M:AMK2]NUMBLOC(K)=I+1 & [M:AMK2]SAIAFF(J-1)=2 & [M:AMK2]SAIAFF(K)=1
     # Mode saisie incompatible avec celui de la variable de bas de tableau
     GMESSAGE = [M:AMK2]CODZON(K)-":"-mess(186,139,1)-[M:AMK2]CODZON(J-1)
     OK = 0  : Break 2
    Endif
   Next K
   # Si bloc tableau représenté en XSL vérifie que le champ XSL existe et est un clob
   If [M:AMK1]BLOCTYPT(I)>1 and [M:AMK1]BLOCTYPG(I)=4
     J = find([M:AMK1]BLOCPAR1(I),[M:AMK2]CODZON(0..[M:AMK2]NBLIG-1))
     If J=0
      # Variable paramètre inexistante
      GMESSAGE = [M:AMK1]BLOCPAR1(I)-":"-mess(232,123,1)-mess(15,115,1)-num$(I+1)
      OK = 0 : Break
     Endif
     # Vérif type de données
     Read [ATY]CODTYP = [M:AMK2]CODTYP(J-1)
     If fstat<>0 or [F:ATY]TYPTYP<>10
      # Ce champ paramètre doit être de type Blob
      GMESSAGE = [M:AMK1]BLOCPAR1(I)-":"-mess(233,123,1)
      OK = 0 : Break
     Endif
     # Vérif que l'XSL est dans un bloc technique
     If [M:AMK1]TYPBLOC([M:AMK2]NUMBLOC(J-1)-1)<>10
      # Le champ XSL doit être dans un bloc de type technique
      GMESSAGE = [M:AMK1]BLOCPAR1(I)-mess(242,123,1)
      OK = 0 : Break
     Endif
   Endif
  Endif
 Endif
Next I
If !OK : Return : Endif

# Controle blocs avec champ paramètre
For I=0 To [M:AMK1]NBBLOC-1
 If find([M:AMK1]TYPBLOC(I),6,7,8,9)
  J = find([M:AMK1]BASPAG(I),[M:AMK2]CODZON(0..[M:AMK2]NBLIG-1))
  If J=0
  # Variable paramètre inexistante
    GMESSAGE = [M:AMK1]BASPAG(I)-":"-mess(232,123,1)
    OK=0 : Break
  Else
  # Vérifie que la variable est de type Clob ou Blob selon les blocs
    Read [ATY]CODTYP = [M:AMK2]CODTYP(J-1)
    If fstat<>0 or ([F:ATY]TYPTYP<>9 and [M:AMK1]TYPBLOC(I)=7)
&    or ([F:ATY]TYPTYP<>10 and find([M:AMK1]TYPBLOC(I),6,8,9))
      GMESSAGE = [M:AMK1]BASPAG(I)
      If [M:AMK1]TYPBLOC(I)=7
        # Ce champ paramètre doit être de type Blob
        GMESSAGE-=":"-mess(233,123,1)
      Else
        # Ce champ paramètre doit être de type Clob
        GMESSAGE-=":"-mess(234,123,1)
      Endif
      OK=0 : Break
    Endif
  Endif
 Endif
Next I
If !OK : Return : Endif

For I=0 To [M:AMK2]NBLIG-1
 If [M:AMK2]NUMBLOC(I) > [M:AMK1]NBBLOC
  GMESSAGE = num$([M:AMK2]NUMBLOC(I))-":"-mess(141,123,1) : # Bloc inexistant
  OK=0 : Break
 Endif
Next I
If !OK : Return : Endif

Gosub VERIF_MAX
Return

############################################################
$VERIF_MAX
Local Integer NBZ, REPET, OKZ
Local Integer MAXZON , MAXLIG

MAXZON = 32768
MAXLIG = 300: # sam 113950 240

# Contrôle limite 32768 champs
NBZ = 0
For I=0 To [M:AMK1]NBBLOC-1
 OKZ = 1
 If [M:AMK1]ACTBLOC(I)<>""
  Read [ACV]CODACT = [M:AMK1]ACTBLOC(I)
  If fstat or [F:ACV]FLACT<>2 : OKZ = 0 : Endif
 Endif
 If OKZ
  For K=0 To [M:AMK2]NBLIG-1
   If [M:AMK2]NUMBLOC(K)=I+1
    OKZ = 1
    REPET = 0
    Read [ATY]CODTYP = [M:AMK2]CODTYP(K)
    If !fstat & [F:ATY]CODACT<>""
     Read [ACV]CODACT = [F:ATY]CODACT
     If fstat or [F:ACV]FLACT<>2 : OKZ = 0 : Endif
    Endif
    If OKZ
     If [M:AMK2]CODACT(K)<>""
      Read [ACV]CODACT = [M:AMK2]CODACT(K)
      If fstat or [F:ACV]FLACT<>2
       OKZ = 0
      Elsif [F:ACV]TYP=2
       REPET = [F:ACV]DIME
      Endif
     Endif
     If OKZ
      If [M:AMK1]TYPBLOC(I)=1
       REPET = 1 : # Dans un bloc tableau, on compte une seule zone par colonne qq soit le nb de lignes
      Elsif REPET=0
       REPET = [M:AMK2]DIME(K)
      Endif
      NBZ += max(REPET,1)
      If [M:AMK2]LIEN(K)>1
       NBZ += max(REPET,1)
      Endif
     Endif
    Endif
   Endif
  Next K
 Endif
Next I
If NBZ>=MAXZON : # Si ce nombre de champs est dépassé, on peut avoir un sida
 GMESSAGE = num$(NBZ)-":"-mess(49,123,1)-"(>="+num$(MAXZON)+")": # Nombre de zones trop grand
 GMESSAGE += "\"+mess(257,133,1) : # Le nombre de lignes dans un écran est limité sauf pour un écran modèle
 OK = 0 : Return
Endif

# Contrôle limite 240 lignes
NBZ = 0
For I=0 To [M:AMK1]NBBLOC-1
 OKZ = 1
 If [M:AMK1]ACTBLOC(I)<>""
  Read [ACV]CODACT = [M:AMK1]ACTBLOC(I)
  If fstat or [F:ACV]FLACT<>2 : OKZ = 0 : Endif
 Endif
 If OKZ
  For K=0 To [M:AMK2]NBLIG-1
   If [M:AMK2]NUMBLOC(K)=I+1
    OKZ = 1
    Read [ATY]CODTYP = [M:AMK2]CODTYP(K)
    If !fstat & [F:ATY]CODACT<>""
     Read [ACV]CODACT = [F:ATY]CODACT
     If fstat or [F:ACV]FLACT<>2 : OKZ = 0 : Endif
    Endif
    If OKZ
     If [M:AMK2]CODACT(K)<>""
      Read [ACV]CODACT = [M:AMK2]CODACT(K)
      If fstat or [F:ACV]FLACT<>2
       OKZ = 0
      Endif
     Endif
     If OKZ
      NBZ += 1
      If [M:AMK2]LIEN(K)>1
       NBZ += 1
      Endif
     Endif
    Endif
   Endif
  Next K
 Endif
Next I
If NBZ>=MAXLIG : # Si ce nombre de lignes limite est dépassé, on plante dans la validation de l'écran
 GMESSAGE = num$(NBZ)-":"-mess(161,115,1)-"(>="+num$(MAXLIG)+")": # Trop de lignes
 GMESSAGE += "\"+mess(257,133,1) : # Le nombre de lignes dans un écran est limité sauf pour un écran modèle
 OK = 0 : Return
Endif
Return

############################################################
$ANNULE
Delete [AMZ] Where CODMSK=[L]CODE
If fstat=1  : GOK=-1 : Call RSTA("AMZ",[L]CODE) From GLOCK : Return : Endif
Delete [AMA] Where TYPAFF=1 & CODAFF=[L]CODE
If fstat=1  : GOK=-1 : Call RSTA("AMA",[L]CODE) From GLOCK : Return : Endif
Delete [AMP] Where TYPAFF=1 & CODAFF=[L]CODE
If fstat=1  : GOK=-1 : Call RSTA("AMP",[L]CODE) From GLOCK : Return : Endif
Return

############################################################
$AP_ANNULE
Call DEL_TRTMSK([L]CODE,nomap) From MSKDIV
Return

#################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File AMSK    [AMK1]
 Local File AMSKZON [AMZ1]
 Local File AMSKACT [AMA1]
 Local File AMSKPAR [AMP1]
 Local File ATEXTE  [ATX1]
Else
 Local File =[M]DOSORG+".AMSK"    [AMK1]
 Local File =[M]DOSORG+".AMSKZON" [AMZ1]
 Local File =[M]DOSORG+".AMSKACT" [AMA1]
 Local File =[M]DOSORG+".AMSKPAR" [AMP1]
 Local File =[M]DOSORG+".ATEXTE"  [ATX1]
Endif
If [M]DOSDES=nomap
 Local File AMSK    [AMK2]
 Local File AMSKZON [AMZ2]
 Local File AMSKACT [AMA2]
 Local File AMSKPAR [AMP2]
 Local File ATEXTE  [ATX2]
Else
 Local File =[M]DOSDES+".AMSK"    [AMK2]
 Local File =[M]DOSDES+".AMSKZON" [AMZ2]
 Local File =[M]DOSDES+".AMSKACT" [AMA2]
 Local File =[M]DOSDES+".AMSKPAR" [AMP2]
 Local File =[M]DOSDES+".ATEXTE"  [ATX2]
Endif
If GSOPHIA
 # Pour préserver les mot-clés d'aides saisis dans les écrans de GX3APP
 OK = (instr(1,toupper([M]DOSORG),"X3BUG") & instr(1,toupper([M]DOSDES),"GX3APP"))
 OK += (instr(1,toupper([M]DOSORG),"GX3APP") & instr(1,toupper([M]DOSDES),"X3BUG"))
 If OK
  Local Char WZON(GLONAVA)(1..400) , WMOT(10)(1..400)
  Local Integer WNBZ
 Endif
Endif
OK = 1
If GTRACE=""
 Read [AMK2]CODMSK = TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [AMK1], [AMZ1], [AMA1], [AMP1], [ATX1]
&              , [AMK2], [AMZ2], [AMA2], [AMP2], [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [AMK2] , [AMZ2] , [AMA2] , [AMP2] , [ATX2]
 Delete [AMK2] Where CODMSK=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AMSK" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AMK2","") From GLOCK : Goto AB_TR_COP
 Endif
 If dim(WNBZ)>0
  WNBZ = 0
#  For [AMZ2] Where CODMSK=TABLE
#   WNBZ += 1
#   WZON(WNBZ) = [F:AMZ2]CODZON
#   WMOT(WNBZ) = [F:AMZ2]MOTCLE
#  Next AMZ2
 Endif
 Delete [AMZ2] Where CODMSK=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AMSKZON" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AMZ2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AMA2] Where TYPAFF=1 & CODAFF=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AMSKACT" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AMA2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AMP2] Where TYPAFF=1 & CODAFF=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AMSKPAR" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AMP2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [AMK1]CODMSK Where CODMSK=TABLE
  [F:AMK2] = [F:AMK1]
  Call COPTEXTE([F:AMK1]INTMSK,[F:AMK2]INTMSK) From OBJDIV
  If GOK<1 : Break : Endif
  For I=0 To [F:AMK1]NBBLOC-1
   Call COPTEXTE([F:AMK1]TITBLOC(I),[F:AMK2]TITBLOC(I)) From OBJDIV
   If GOK<1 : Break 2 : Endif
  Next I
  If dim([F:AMK2]UPDUSR)>0 : [F:AMK2]UPDUSR = GUSER : Endif
  If dim([F:AMK2]UPDDAT)>0 : [F:AMK2]UPDDAT = date$ : Endif
  If dim([F:AMK2]UPDTIM)>0 : [F:AMK2]UPDTIM = time  : Endif
  Write [AMK2]
  If fstat
   GOK=0 : Call FSTA("AMK2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [AMZ1]CODE Where CODMSK=TABLE
  [F:AMZ2] = [F:AMZ1]
  Call COPTEXTE([F:AMZ1]INTIT,[F:AMZ2]INTIT) From OBJDIV
#  If dim([F:AMZ1]INFBUL)>0 & dim([F:AMZ2]INFBUL)>0
#   Call COPTEXTE([F:AMZ1]INFBUL,[F:AMZ2]INFBUL) From OBJDIV
#   If GOK<1 : Break : Endif
#  Endif
#  If dim(WNBZ)>0
#   I = find([F:AMZ1]CODZON,WZON(1..WNBZ))
#   If I
#    [F:AMZ2]MOTCLE = WMOT(I)
#   Endif
#  Endif
  Write [AMZ2]
  If fstat
   GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [AMA1]TYPAFF Where TYPAFF=1 & CODAFF=TABLE
  [F:AMA2] = [F:AMA1]
  If dim([F:AMA2]INTITACT)>0
   Call COPTEXTE([F:AMA1]INTITACT,[F:AMA2]INTITACT) From OBJDIV
  Endif
  Write [AMA2]
  If fstat
   GOK=0 : Call FSTA("AMA2") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR_COP : Endif
 For [AMP1]CODPAR Where TYPAFF=1 & CODAFF=TABLE
  [F:AMP2] = [F:AMP1]
  Write [AMP2]
  If fstat
   GOK=0 : Call FSTA("AMP2") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR_COP : Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

##############################################
Subprog VISUM(MASQUE)
Value Char MASQUE
Local Integer I , J , K , L
Local Char    A_WINDPREV(60) , RESOL(10)

If GBROWS : Call VISUMWEB(MASQUE) : End : Endif

Onerrgo ERR
Local File TABCUR [TCU] , TABCOUNTRY [TCY]
Call LECTURE("TCU",GSYSCUR,"") From CONTOBJ
Call LECTURE("TCY",GPAYS,"") From CONTOBJ

A_WINDPREV = "&SCR_PREVIEW"
Call PARAM("","ECRRESOL",RESOL) From ADOVAL
L = val(RESOL)
If L=1 : # Le dossier est en basse résolution
 Call RESOLUTION(L,I,J,K) From GLOBVAR
 A_WINDPREV += ";"+num$(L)+";"+num$(I-K)+";"+num$(I)+";"+num$(J+1)
Endif

If clalev([F:AMK])=0 : Local File AMSK [AMK] : Endif
Read [AMK]CODMSK = MASQUE
If !fstat & evalue("clalev([M:"+[F:AMK]ABRMSK+"])")<=0
 Gosub VISU From ="W1"+MASQUE
Else
 Local Char A_STAMP(15)
 Local Mask =MASQUE [V_IM]
 Local Inpbox MASQUE From GFONCTION At A_STAMP With A_WINDPREV Mask [V_IM] As [S_IM]
 Grizo [V_IM]
 Boxact [S_IM]
 Boxinp [S_IM] Using GBIDI1
 Close Local Inpbox [S_IM]
 Close Local Mask [V_IM]
Endif
End

$ERR
Resume

$RIEN
Return

##############################################
Subprog VISUMWEB(ECRAN)
Value Char ECRAN
Local Integer OK
Call CREWIND(nomap,ECRAN) From INTRUTILB
Call VALID("_"+ECRAN,nomap,1,OK) From VALWIN
Global Char GVISUW : GVISUW=ECRAN
If GBROWS<>0
  Call SIMUL("_"+ECRAN) From SUBAWI
Else
  Local Char URL(200),RETOUR(200),AASEP
  AASEP="/"
  If instr(1,GVIRTDIR,"\") : AASEP="\" : Endif
  URL=GVIRTDIR+AASEP+nomap+AASEP+"GEN"+AASEP+GLANGUE
  URL+=AASEP+"FENW"+AASEP+"_"+ECRAN+".xml"
  URL=ctrans(URL,"\","/")
  Callui RETOUR="" With     "UIAction="+chr$(1)+"OpenFile",
&                           "UILocalDir="+ chr$(1) +"HTTP",
&                           "UILocalFile="+ chr$(1) +URL
Endif

End


##############################################
Subprog VISUVT(ECRAN)
Value Char ECRAN

Local Char NOMFIC(200),VALL1(100)
Local Integer NLIG
If clalev([F:AMK])=0 : Local File AMSK [AMK] : Endif
If [F:AMK]CODMSK<>ECRAN
  Read [AMK]CODMSK=ECRAN
  If fstat<>0 : End : Endif
Endif

Call NAMEFIC(nomap,"SCRN","",ECRAN,NOMFIC) From INTRUTILA
NOMFIC=left$(NOMFIC,len(NOMFIC)-3)+"txt"
If filinfo(NOMFIC,7)<=0 : End : Endif

Local Char VALL2([F:AMK]NBRCOL)
Call OUVRE_TRACE(" ") From LECFIC
Call ECR_TRACE("            1         2         3         4         5         6",0) From GESECRAN
Call ECR_TRACE("   123456789 123456789 123456789 123456789 123456789 123456789",0) From GESECRAN
VALL2=string$([F:AMK]NBRCOL,"-")
Call ECR_TRACE("   "+VALL2,0) From GESECRAN

Openi NOMFIC,0 Using [VIS_]
Iomode adxifs "" Using [VIS_]
Iomode adxirs chr$(10) Using [VIS_]
Iomode adxium GUTF8 Using [VIS_]
While fstat=0
  Rdseq VALL1 Using [VIS_]
  If fstat=0
    NLIG+=1
    VALL2=VALL1
    If len(VALL2)<[F:AMK]NBRCOL
      VALL2+=string$([F:AMK]NBRCOL-len(VALL2)," ")
    Endif
    VALL1=format$("N:##",NLIG)+"!"+VALL2+"!"+format$("N:##",NLIG)
    Call ECR_TRACE(VALL1,0) From GESECRAN
  Endif
Wend
Openi Using [VIS_]

VALL2=string$([F:AMK]NBRCOL,"-")
Call ECR_TRACE("   "+VALL2,0) From GESECRAN
Call ECR_TRACE("   123456789 123456789 123456789 123456789 123456789 123456789",0) From GESECRAN
Call ECR_TRACE("            1         2         3         4         5         6",0) From GESECRAN

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

End

