#<AdxTL>@(#)4.0.0.0 $Revision$
## Gestion du masque JCO1
## Fenêtre de gestion des plan de compte ds un journal
Raz GPILOBJ
Call OBJET("JOU",GBIDC1,GBIDC2) From GOBJET
End

Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"FCOAJOU","SAICOAJOU","XWFCOAJOU") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEBUT"        : Gosub DEBUT
 When "SETBOUT"      : Gosub SETBOUT
 When "FIR"          : Gosub PLANFIRST
 When "SUI"          : Gosub PLANSUIV
 When "PRE"          : Gosub PLANPREC
 When "LAS"          : Gosub PLANLAST
 When "ENR"          : Gosub ENREG
 When "ABA"          : Gosub ABANDON
 When "FIN"          : Gosub FIN
 When "MODIF"        : Gosub MODIF
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When Default
Endcase
Return


$OUVRE
If clalev([JCO])=0 : Local File GJOUCOA  [JCO] : Endif
If clalev([JOU])=0 : Local File GJOURNAL [JOU] : Endif
If clalev([GAC])=0 : Local File GACCOUNT [GAC] : Endif
If clalev([COA])=0 : Local File GCOA     [COA] : Endif
If dim(GCURLEG)>0  : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$DEBUT
Local Integer I
Global Char PLAN , TRESO
Local Char SYMBOLE(20)
Local Libelle VERROU
VERROU   = 0
[M]JOU = PARAM(1)
If GNBLEG=1
 GCURLEG = GDOSLEG(1)
Else
 GCURLEG = PARAM(2)
 [M]LEG = GCURLEG
Endif
If GCURLEG<>""
 Link [JCO] With [COA]COA0=COA
& As [LNK]
& Where ([F:COA]LEG=GCURLEG | [F:COA]LEG="") & [F:JOU]LEG=GCURLEG & JOU=[M]JOU
Else
 Link [JCO] With [COA]COA0=COA
& As [LNK]
& Where JOU=[M]JOU
Endif
Read [LNK]JCO0 First
If !fstat
 PLAN = [F:COA]COA
 Gosub LECJCO
Endif
Return

$LECJCO
Gosub DEVERROU
VERROU = 0
[M]COA = PLAN
Effzo [M]FBDACC , FRQACC , FRQCOD , ACC
[M]FRQNBR = 0
[M]FBDNBR = 0
Read [JCO]JCO0 = [M]COA;[M]JOU;GCURLEG
If !fstat
 [M]ACC = [F:JCO]ACC
 For I=0 To [F:JCO]FBDNBR-1
  [M]FBDACC(I) = [F:JCO]FBDACC(I)
 Next
 [M]FBDNBR=[F:JCO]FBDNBR
 [M]NUMLIG1 = I
# Affzo FBDNBR , NUMLIG1 , FBDACC
 For I=0 To [F:JCO]FRQNBR-1
  [M]FRQACC(I) = [F:JCO]FRQACC(I)
  [M]FRQCOD(I) = [F:JCO]FRQCOD(I)
 Next
 [M]FRQNBR = [F:JCO]FRQNBR
 [M]NUMLIG2 = I
# Affzo FRQNBR, NUMLIG2, FRQACC, FRQCOD
 Affzo [M]
Endif
Return

$PLANFIRST
Read [LNK]JCO0 First
If fstat
 # Début/Fin de fichier
 GMESSAGE = mess(11,100,1) : GERR = 1
 Return
Else
 PLAN = [F:JCO]COA
 Look [JCO]JCO0 =  PLAN;[M]JOU;GCURLEG
 If !fstat
  Gosub LECJCO
 Else
  Filter [LNK] Where COA=PLAN
  Read [LNK]JCO0 Last
  Filter [LNK]
  PLAN  = [F:JCO]COA
  Gosub LECJCO
 Endif
Endif
Return

$PLANPREC
Read [LNK]JCO0 < PLAN
If fstat
 # Début/Fin de fichier
 GMESSAGE = mess(11,100,1) : GERR = 1
 Return
Else
 PLAN = [F:JCO]COA
 Look [JCO]JCO0 = PLAN;[M]JOU;GCURLEG
 If !fstat
  Gosub LECJCO
 Else
  Filter [LNK] Where COA=PLAN
  Read [LNK]JCO0 Last
  Filter [LNK]
  If !fstat
   PLAN  = [F:JCO]COA
   Gosub LECJCO
  Endif
 Endif
Endif
Return

$PLANSUIV
Read [LNK]JCO0 > PLAN
If fstat
 # Début/Fin de fichier
 GMESSAGE = mess(11,100,1) : GERR = 1
 Return
Else
 PLAN = [F:JCO]COA
 Look [JCO]JCO0 = PLAN;[M]JOU;GCURLEG
 If !fstat
  Gosub LECJCO
 Else
  Filter [LNK] Where COA=PLAN
  Read [LNK]JCO0 Last
  Filter [LNK]
  PLAN  = [F:JCO]COA
  Gosub LECJCO
 Endif
Endif
Return

$PLANLAST
Read [LNK]JCO0 Last
If fstat
 # Début/Fin de fichier
 GMESSAGE = mess(11,100,1) : GERR = 1
 Return
Else
 PLAN = [F:JCO]COA
 Look [JCO]JCO0 = PLAN;[M]JOU;GCURLEG
 If !fstat
  Gosub LECJCO
 Else
  Filter [LNK] Where COA=PLAN & JOU=[M]JOU & LEG=GCURLEG
  Read [LNK]JCO0 Last
  Filter [LNK]
  PLAN  = [F:JCO]COA
  Gosub LECJCO
 Endif
Endif
Return

$MODIF
For [JCO]JCO0 Where [F:JCO]COA=[M]COA & [F:JCO]JOU=[M]JOU & [F:JCO]LEG=GCURLEG
 If [F:JCO]CREUSR<>GUSER
  [F:JCO]UPDUSR = GUSER
  [F:JCO]UPDDAT = date$
 Endif
Next
Write [JCO]
If fstat
 GOK = 0 : Call FSTA("JCO") From GLOCK
Endif
Return

$APRES_MODIF
If COUZON="COA"
 Read [LNK]JCO0=[M]COA;[M]JOU;GCURLEG
 If !fstat
  PLAN = [F:COA]COA
  Gosub LECJCO
 Endif
Endif
If evalue("type([M]"+COUZON+")")=8 : # Bas de tableau
 REP = "M"
 OK = 0 : Return
Elsif !VERROU
 SYMBOLE = "JOU"+GCURLEG+"\"+[M]JOU
 Lock =SYMBOLE With lockwait=0
 If fstat  GERR = 1 : FOK=0 : Return
 Else
  VERROU = 1
  REP = "M"
 Endif
Endif
Return

$DEVERROU
Unlock =SYMBOLE
Return

$ABANDON
REP = ""
Gosub LECJCO
Return

$SETBOUT
If REP="M"
 ETABOU(GSPE1) = 0
 ETABOU(GSPE2) = 0
 ETABOU(GSPE3) = 0
 ETABOU(GSPE4) = 0
Else
 ETABOU(GSPE1) = 1
 ETABOU(GSPE2) = 1
 ETABOU(GSPE3) = 1
 ETABOU(GSPE4) = 1
Endif
Return

$ENREG
Call DEBTRANS From GLOCK
Gosub TR_JST
If GOK<1
 OK = 0 : Return
Endif
Gosub DEVERROU
VERROU = 0
REP = ""
Return

$TR_JST
GOK=1
Trbegin [JCO]
 Raz [F:JCO]
 Readlock [JCO]JCO0 = [M]COA;[M]JOU;GCURLEG
 If fstat=1
  GOK=-1 : GLOCK="$GJOUCOA" : Goto ROLL_TR_JST
 Elsif fstat
  GOK=0 : Call RSTA("JCO",[M]COA-[M]JOU-GCURLEG) From GLOCK : Goto AB_TR_JST
 Else
  [F:JCO]=[M:JCO1]
  [F:JCO]LEG = GCURLEG
  [F:JCO]UPDUSR = GUSER
  [F:JCO]UPDDAT = date$
  Rewrite[JCO]
  If fstat
   GOK=0 : Call FSTA("JCO") From GLOCK : Goto AB_TR_JST
  Endif
 Endif
Commit
Return

$ROLL_TR_JST
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_JST : Endif

$AB_TR_JST
Rollback
Return

$FIN
Gosub DEVERROU
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

############################################################################
## Etiquettes masque [JCO1]
############################################################################
Subprog C_FBDACC(VALEUR)
Variable Char    VALEUR()
Local Integer I , OK
Call FILTRE(VALEUR,"A#\*?") From CPTSUB
If VALEUR=""
 mkstat = 1 : End
Endif
If [M]ACC<>"" & [M]ACC=VALEUR
 ## Valeur incorrecte
 GMESSAGE = mess(83,123,1)
 mkstat = 2 : End
Endif
Call UNICITE(VALEUR,[M]FBDACC(0..[M]FBDNBR-1)) From OBJDIV
Call LECTURE("GAC",VALEUR,[M]COA) From CONTOBJ
If !fstat
 Call COMPAT([M:JOU0]FCY,[F:GAC]FCY,VALEUR) From CFYSUB
 If mkstat : End : Endif
Endif

End

Subprog C_FRQACC(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]FRQACC(0..[M]FRQNBR-1)) From OBJDIV
If mkstat : End : Endif
Call LECTURE("GAC",VALEUR,[M]COA) From CONTOBJ
Call COMPAT([M:JOU0]FCY,[F:GAC]FCY,VALEUR) From CFYSUB
If mkstat : End : Endif
End

Subprog C_FRQCOD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]FRQCOD(0..[M]FRQNBR-1)) From OBJDIV
End

