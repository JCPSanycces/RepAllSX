#<AdxTL>@(#)1.0.0.0 $Revision$
#28 octobre1998
Raz GBIDC1
Call OBJET("RLK",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "SETBOUT"    : Gosub SETBOUT
 When "LIENS"      : Gosub LIENS
 When "APRES_CHOI" : Gosub APRES_CHOI
 When "RAZCRE"     : Gosub RAZCRE
 When "ABANDON"    : Gosub ABANDON
 When "FILTRE"     : Gosub FILTRE
 When "VERROU"     : Gosub VERROU
 When "DEVERROU"   : Gosub DEVERROU
 When "APRES_MODIF": Gosub APRES_MODIF
 When "FERME"      : Gosub FERME
 When Default
Endcase
Return


$OUVRE
Local Char    SYMBCHK(20), NUMREL(GLONVCR), DEV(GLONCUR), DEV1(GLONCUR), COMPTREG(GLONANM), MESSA(80)
Local Char    CRIT1(200), CRIT2(255)
Local Integer SNSBNQ, SENS, SENS1, STAT, MAXLIG, COK, OKTCA
Local Decimal MTT, MTT1
Local Date    DAT1, DAT2
If clalev([F:BAN])=0  : Local File BANK       [BAN]  : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
If clalev([F:TCY])=0  : Local File TABCOUNTRY [TCY]  : Endif
If clalev([F:RBK2])=0 : Local File RELBANK    [RBK2] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:RBR])=0  : Local File RELBANKREM [RBR]  : Endif
Return

$SETBOUT
If CLECUR & CRE : CHAINE +="A" : Endif
Return

$LIENS
MAXLIG = dim([M]REF)
Gosub CHARGE_BAN
If GOK
 Gosub CHARGE_RBK
Endif
Return

$CHARGE_BAN
Read [BAN]BAN0=[M]BAN
If !fstat
 If [F:BAN]CRY="" : [M]CRY = GPAYS : Else : [M]CRY = [F:BAN]CRY
 Endif
 [M]BIDNUM = [F:BAN]BIDNUM
 [M]BANCUR = [F:BAN]CUR
 Read [RBK]RBK0 = [M]BAN;[M]RBKNUM;1;1
 If !fstat
  If [F:BAN]CUR<>[F:RBK]CUR
   [M]BANCUR = [F:RBK]CUR
  Endif
 Endif
 Call LECTURE("TCU",[M]BANCUR,"") From CONTOBJ
Endif
Return

$CHARGE_RBK
Call PARAM([F:BAN]CPY,"SNSBNQ",GDIV(0)) From ADOVAL
SNSBNQ = val(GDIV(0))
## SNSBNQ=1 : Sens de la banque : import de -1 au Débit et 1 au Crédit
## SNSBNQ=2 : Sens inverse de la banque
[M]RECTYP=1
[M]RBKLIN=1
fstat = 0

# Lecture ancien solde
Filter [RBK] Where BAN=[M]BAN & RBKNUM=[M]RBKNUM & RECTYP=1
Read [RBK]RBK0 First
If !fstat
 [M]ORI = [F:RBK]ORI
 If [M]ORI=0 : [M]ORI=1 : Endif
 [M]OLDAMT = [F:RBK]AMTCUR
 [M]OLDDAT = [F:RBK]OPEDAT
 If ([F:RBK]SNS=1 & SNSBNQ=1) | ([F:RBK]SNS=-1 & SNSBNQ=2)
  [M]OLDSNS = 1 : # Débit
 Else
  [M]OLDSNS = 2 : # Crédit
 Endif
Endif
fstat = 0

# Lecture nouveau solde
Filter [RBK] Where BAN=[M]BAN & RBKNUM=[M]RBKNUM & RECTYP=3
Read [RBK]RBK0 First
If !fstat
 [M]NEWAMT = [F:RBK]AMTCUR
 [M]NEWDAT = [F:RBK]OPEDAT
 If ([F:RBK]SNS=1 & SNSBNQ=1) | ([F:RBK]SNS=-1 & SNSBNQ=2)
  [M]NEWSNS = 1 : # Débit
 Else
  [M]NEWSNS = 2 : # Crédit
 Endif
Endif
Filter [RBK]

# Lecture détail lignes
nolign=0
For [RBK]RBK0 Where BAN=[M]BAN & RBKNUM=[M]RBKNUM & RECTYP=2 
 [M]OPEDAT(nolign) = [F:RBK]OPEDAT
 If ([F:RBK]SNS=1 & SNSBNQ=1) | ([F:RBK]SNS=-1 & SNSBNQ=2)
  [M]SNS(nolign) = 1 : # Débit
 Else
  [M]SNS(nolign) = 2 : # Crédit
 Endif
 [M]AMTCUR(nolign) = [F:RBK]AMTCUR
 [M]BANCIB(nolign) = [F:RBK]BANCIB
 [M]VALDAT(nolign) = [F:RBK]VALDAT
 [M]DES(nolign)    = [F:RBK]DES
 [M]ENTNUM(nolign) = [F:RBK]ENTNUM
 [M]REF(nolign)    = [F:RBK]REF
 [M]RENREJ(nolign) = [F:RBK]RENREJ
 [M]INDCOM(nolign) = [F:RBK]INDCOM
 [M]INDUVY(nolign) = [F:RBK]INDUVY
 [M]DATCHK(nolign) = [F:RBK]DATCHK
 [M]CHK(nolign)    = [F:RBK]CHK
 [M]CUR(nolign)    = [F:RBK]CUR
 nolign+=1
 If nolign >= MAXLIG
  GERR=2 : GMESSAGE=mess(26,100,1)  :# Tableau plein
  Break
 Endif
Next
If GERR=2 : Diszo [M] : Else : Actzo [M] : Endif
[M]NBLIG = nolign
# En attendant que le bug sur les tableaux soit corrigé...
If [M]NBLIG=0
 Raz [M]OPEDAT(0), SNS(0), CUR(0), AMTCUR(0)
Endif
Return

$APRES_CHOI
Case REPONSE 
 When GSTACRE  : Gosub CREATE : #Créer
 When GSTAANU  : Gosub ANNUL  : #Supprimer
 When GSTAENR  : Gosub MODIF  : #Enregistrer
 When GSTARET  :
  If REP="C" | REP="D" : Gosub CREATE 
  Elsif REP="M" : Gosub MODIF 
  Endif 
 When Default
Endcase
Return 

$RAZCRE
If zoncou="RBKNUM"
 Grizo [M]RBKNUM
Endif
Return

$ABANDON
If REP="C" | REP="D" : Actzo [M]RBKNUM : Endif
Return

$FILTRE
FILTSUP= "[F:RBK]RECTYP=1"  
Return 

$INICREATE
COMPTREG = ""
Call LEC_CPY([F:BAN]CPY) From CPTLEC
If [F:CPY]MAIFCY=""
 # Pas de site principal rattaché à la société - F56436
 GMESSAGE = mess(68,107,1)-[F:BAN]CPY
 GOK = 0 : Return
Else 
 Call GETSOC([F:CPY]MAIFCY) From DEVSUB
 Call LECTCA(3,OKTCA) From SUBTCA
 If OKTCA : COMPTREG = [F:TCA]CODNUM(5) : Endif
 If COMPTREG="" : COMPTREG = "RBK" : Endif
 Call NUMERO(COMPTREG,[F:CPY]MAIFCY,datesyst,"",[F:RBK]RBKNUM,STAT) From SUBANM
 If GOK<0 : Return
 Elsif GOK<1 | STAT
  GOK = 0
  If STAT
   # Problème lors de la récupération du compteur
   Gosub MESSAGE From SUBANM
   Call ECR_TRACE(mess(60,199,1)-"("+COMPTREG+") : "+MESSA,1) From GESECRAN 
  Endif
  Return
 Endif
 [M]RBKNUM=[F:RBK]RBKNUM
Endif
Return

$CREATE
Call PARAM([F:BAN]CPY,"SNSBNQ",GDIV(0)) From ADOVAL
SNSBNQ = val(GDIV(0))
If REP<>"C" and REP<>"D" : REPONSE = 0 : Return : Endif
Gosub TR1
If GOK<1 : REPONSE = 0 : Return : Endif
Gosub SET_CLE From GOBJSUB
CLECUR = 1
Gosub VERROU From SUBRLK
REP = "" : GREP = "" : # Retour en consultation
Actzo [M]RBKNUM
REPONSE = 0 
CLECUR1 = [M]RBKNUM   :# on se positionne sur le relevé créé
CLECUR2(0) = [M]BAN
CLECUR2(1) = "1"
CLECUR2(2) = "1"
Gosub RELIT From GOBJSUB
Return

$TR1
Call DEBTRANS From GLOCK
Trbegin [RBK]
 IND = 0
 Raz [F:RBK]
 Gosub INICREATE
 [F:RBK]BAN    = [M]BAN
 [F:RBK]CUR    = [M]BANCUR
 [F:RBK]DATCHK = [0/0/0]
 [F:RBK]CHK    = ""
 [F:RBK]ORI    = 2 : # Relevé saisi
 For I=1 To [M]NBLIG+2
  Case I
   When 1       : Gosub CRE_ENTETE 
   When 2       : Gosub CRE_TOTAL
   When Default : 
    [M]CUR(IND)=[M]BANCUR : If !GIMPORT : Affzo CUR(IND) : Endif
    If [M]CHK(IND)="" : [M]DATCHK(IND)=[0/0/0]
    Else : [M]DATCHK(IND)=date$ 
    Endif
    Gosub CRE_DETAIL
  Endcase
  [F:RBK]NUMRBK = uniqid([F:RBK])
  Write [RBK]
  If fstat
   GOK=0 : Call FSTA("RBK") From GLOCK
   Break
  Endif
  
  # Ajout point d'entrée pour la tréso...
  GPOINT = "CREATE" : Gosub ENTREE From EXEFNC
  If GOK<0   : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif

 Next
 Gosub MAJREL  : # Mise à jour des soldes du relevé de meme date
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$MAJREL
# Mise à jour en cascade des soldes des relevés saisis dans la meme devise :
# Si on créé ou modifie un solde S1 à la meme date qu'un ancien solde S2, il faut 
# reporter le nouveau montant S1 sur l'ancien solde S2 du relevé en question,
# donc mettre à jour le nouveau solde et ainsi de suite...
[L]DAT1 = [M]OLDDAT 
[L]DAT2 = [M]NEWDAT 
[L]MTT  = [M]NEWAMT 
[L]NUMREL = [M]RBKNUM
If ([M]NEWSNS=1 & SNSBNQ=1) | ([M]NEWSNS=2 & SNSBNQ=2)
 [L]SENS = 1 
Else
 [L]SENS = -1 
Endif
Call LECTURE("CPY",[F:BAN]CPY,"") From CONTOBJ
[L]CRIT1 = "BAN=[M]BAN & OPEDAT=[L]DAT2 & RECTYP=1 & ORI=2 & CUR=[M]BANCUR"
[L]CRIT2 = "RBKNUM<>'"+[L]NUMREL+"'"
Repeat
 Filter [RBK] Where evalue(CRIT1) & evalue(CRIT2)
 GCLE = [M]BAN-"1"-format$("DD2",[L]DAT2)
 Read [RBK]RBK1 First
 If !fstat
   COK = 1
   Read [RBK2]RBK0(3) = [F:RBK]BAN;[F:RBK]RBKNUM;3
   If !fstat
    If [F:RBK2]OPEDAT=[F:RBK]OPEDAT & [F:RBK2]OPEDAT=[L]DAT1
     If [F:RBK]RBKNUM < [L]NUMREL
       COK = 0
     Endif
    Endif
   Endif
   [L]NUMREL = [F:RBK]RBKNUM
   [L]MTT1   = [F:RBK]AMTCUR
   [L]SENS1  = [F:RBK]SNS
   [L]DAT1   = [F:RBK]OPEDAT
   If len([L]CRIT2+"& RBKNUM<>'"+[L]NUMREL+"'")>255
    Raz [L]CRIT2
    [L]CRIT2 = "RBKNUM<>'"+[L]NUMREL+"'"
   Else
    [L]CRIT2 -= "& RBKNUM<>'"+[L]NUMREL+"'"
   Endif
   If COK   # on peut mettre à jour
    If [L]MTT<>[L]MTT1 | [L]SENS<>[L]SENS1 
     Gosub MAJ1  : # Maj ancien solde
     If GOK<1 : Break : Endif
     Gosub MAJ2  : # Maj nouveau solde
     If GOK<1 : Break : Endif
    Endif
   Endif
 Endif
Until fstat 
Filter [RBK]
Return

$MAJ1
[F:RBK]AMTCUR = [L]MTT
[F:RBK]SNS    = [L]SENS
Rewrite [RBK]
If fstat
 GOK=0 : Call FSTA("RBK") From GLOCK : Return
Endif
Return

$MAJ2
Filter [RBK]
Read [RBK]RBK0(3) = [M]BAN;[L]NUMREL;3
If !fstat
 [F:RBK]AMTCUR = ([F:RBK]SNS*[F:RBK]AMTCUR)-([L]SENS1*[L]MTT1)+([L]SENS*[L]MTT)
 If [F:RBK]AMTCUR<0
  [F:RBK]AMTCUR = abs([F:RBK]AMTCUR)
  [F:RBK]SNS = -1
 Else
  [F:RBK]SNS = 1
 Endif
 Rewrite [RBK]
 If fstat
  GOK=0 : Call FSTA("RBK") From GLOCK : Return
 Else
  [L]DAT2 = [F:RBK]OPEDAT
  [L]MTT  = [F:RBK]AMTCUR
  [L]SENS = [F:RBK]SNS
 Endif
Endif
Return

$CRE_ENTETE
[F:RBK]RECTYP = 1
[F:RBK]RBKLIN = 1
If ([M]OLDSNS=1 & SNSBNQ=1) | ([M]OLDSNS=2 & SNSBNQ=2)
 [F:RBK]SNS = 1  : # Crédit bancaire
Else
 [F:RBK]SNS = -1 : # Débit bancaire
Endif
[F:RBK]AMTCUR = [M]OLDAMT
[F:RBK]OPEDAT = [M]OLDDAT
Return

$CRE_TOTAL
[F:RBK]RECTYP = 3
[F:RBK]RBKLIN = [M]NBLIG+2
If ([M]NEWSNS=1 & SNSBNQ=1) | ([M]NEWSNS=2 & SNSBNQ=2)
 [F:RBK]SNS = 1  : # Crédit bancaire
Else
 [F:RBK]SNS = -1 : # Débit bancaire
Endif
[F:RBK]AMTCUR = [M]NEWAMT
[F:RBK]OPEDAT = [M]NEWDAT
Return

$CRE_DETAIL
[F:RBK]RECTYP = 2
[F:RBK]RBKLIN = I-1
If ([M]SNS(IND)=1 & SNSBNQ=1) | ([M]SNS(IND)=2 & SNSBNQ=2)
 [F:RBK]SNS = 1  : # Crédit bancaire
Else
 [F:RBK]SNS = -1 : # Débit bancaire
Endif
[F:RBK]AMTCUR = [M]AMTCUR(IND)
[F:RBK]OPEDAT = [M]OPEDAT(IND)
[F:RBK]BANCIB = [M]BANCIB(IND)
[F:RBK]VALDAT = [M]VALDAT(IND)
[F:RBK]DES    = [M]DES(IND)
[F:RBK]ENTNUM = [M]ENTNUM(IND)
[F:RBK]REF    = [M]REF(IND)
[F:RBK]RENREJ = [M]RENREJ(IND)
[F:RBK]INDCOM = [M]INDCOM(IND)
[F:RBK]INDUVY = [M]INDUVY(IND)
[F:RBK]DATCHK = [M]DATCHK(IND)
[F:RBK]CHK    = [M]CHK(IND)
[F:RBK]CUR    = [M]CUR(IND)
IND +=1
Return

$MODIF
Call DEBTRANS From GLOCK
Gosub TR_ANNUL
Gosub TR2
If GOK<1 : Return : Endif
REP = "" : GREP = "" : # Retour en consultation
Gosub DEGRISE_CLE From =WINPROG
REPONSE = 0 
Return

$TR2
Call DEBTRANS From GLOCK
Trbegin [RBK]
 IND = 0
 Raz [F:RBK]
 [F:RBK]RBKNUM = [M]RBKNUM
 [F:RBK]BAN    = [M]BAN
 [F:RBK]CUR    = [M]BANCUR 
 [F:RBK]ORI    = [M]ORI : # en modif, on conserve l'origine du relevé
 For I=1 To [M]NBLIG+2
  Case I
   When 1 : Gosub CRE_ENTETE 
   When 2 : Gosub CRE_TOTAL
   When Default : 
    If [M]CUR(IND)=""
     [M]CUR(IND)=[M]BANCUR 
     If !GIMPORT : Affzo CUR(IND) : Endif
    Endif
    If [M]CHK(IND)="" : [M]DATCHK(IND)=[0/0/0]
    Elsif [M]DATCHK(IND)=[0/0/0] : [M]DATCHK(IND)=date$
    Endif
    Gosub CRE_DETAIL
  Endcase
  [F:RBK]NUMRBK = uniqid([F:RBK])
  Write [RBK]
  If fstat
   GOK=0 : Call FSTA("RBK") From GLOCK
   Break
  Endif
  
  # Ajout point d'entrée pour la tréso
  GPOINT = "CREATE" : Gosub ENTREE From EXEFNC
  If GOK<0   : Goto ROLL_TR2
  Elsif !GOK : Goto AB_TR2
  Endif

 Next
 Gosub MAJREL  : # Mise à jour des soldes du relevé de meme date
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

$ANNUL
OK = 1
For [RBK]RBK0 Where RBKNUM=[M]RBKNUM & BAN=[M]BAN & RECTYP=2 & CHK<>""
 OK = 0 : Break
Next
If !OK 
 GERR = 1 : GMESSAGE = mess(53,120,1) : # Suppression d'un relevé pointé impossible
 REPONSE = 0 
 Return 
Endif
If !VERROU
 Gosub VERROU From SUBRLK
 If !VERROU 
  GERR = 1 : GMESSAGE = mess(23,120,1) : # Compte en cours de pointage
  REPONSE = 0
  Return
 Else
  AFFICHE = 1 : Gosub RELIT From GOBJSUB
  Gosub SETBOUT From GOBJSUB
 Endif
Endif  
Gosub SAVCLE From GOBJSUB
OK = 1
Call OUINON(mess(28,100,1),OK) From GESECRAN
If OK=2 : # OUI
 Call DEBTRANS From GLOCK
 Gosub TR_ANNUL
 If GOK=1
  GERR = 2 : GMESSAGE = mess(23,115,1)-[M]BAN-[M]RBKNUM : #Annulation de la fiche
 Endif
Endif
Gosub DEVERROU From SUBRLK
Gosub RELIT From GOBJSUB
REPONSE = 0 
Return

$TR_ANNUL
GOK = 1
Trbegin [RBK]
 GCLE = [M]BAN-[M]RBKNUM
 Delete [RBK] Where BAN=[M]BAN & RBKNUM=[M]RBKNUM
 If fstat = 1
  GOK = -1 : GLOCK = "$RELBANK"-GCLE : Goto ROLL_TR_ANNUL
 Elsif fstat > 5
  GOK = 0 : Call RSTA("RBK",GCLE) From GLOCK : Goto AB_TR_ANNUL
 Endif

 # Intégration développement Emmanuel LATOUR
 # Annulation des commentaires associés à un relevé en cas d'annulation de celui-ci
 If REPONSE=GSTAANU
  GCLE = [M]BAN-[M]RBKNUM
  Delete [RBR] Where BAN=[M]BAN & RBKNUM=[M]RBKNUM
  If fstat = 1
   GOK = -1 : GLOCK = "$RELBANKREM"-GCLE : Goto ROLL_TR_ANNUL
  Elsif fstat > 5
   GOK = 0 : Call RSTA("RBR",GCLE) From GLOCK : Goto AB_TR_ANNUL
  Endif
 Endif

 # Ajout point d'entrée pour la tréso...
 GPOINT = "ANNUL" : Gosub ENTREE From EXEFNC
 If GOK<0   : Goto ROLL_TR_ANNUL
 Elsif !GOK : Goto AB_TR_ANNUL
 Endif

Commit
Return

$AB_TR_ANNUL
Rollback
Return

$ROLL_TR_ANNUL
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ANNUL : Endif

$DEVERROU
Unlock =SYMBCHK  
Return

$FERME
Return

$VERROU
SYMBCHK = "AUTCHK"+"\"+[M]BAN
Lock =SYMBCHK With lockwait=0
If !fstat  
 OK = 1
Else 
 OK = 0
Endif
Return

$APRES_MODIF
Case COUZON
 When "OPEDAT", "SNS", "AMTCUR", "BANCIB", "VALDAT", "DES" : Gosub TEST_MODI
 When "ENTNUM", "REF", "RENREJ", "INDCOM", "INDUVY"        : Gosub TEST_MODI
Endcase
Return

$TEST_MODI
If !find([M]CHK(nolign-1),"*","") & [M]CHK(nolign-1)<="ZZZZZ" & [M]CHK(nolign-1)>="AAAAA"
 GERR=1 : GMESSAGE=mess(54,120,1)-"\"-mess(37,100,1)-[M]CHK(nolign-1)
 # Ligne pointée en rapprochement: modification impossible
 # Code XXXXX
 OK=0
Elsif [M]CHK(nolign-1)<>""
 GERR=3 : GMESSAGE=mess(56,120,1)  :# La ligne est pointée
Endif
Return

Subprog C_RBKNUM(VALEUR)
Variable Char VALEUR
If VALEUR<>""
 Filter [RBK] Where RBKNUM = VALEUR
 Read [RBK]RBK2 First
 If fstat 
  VALEUR="" : [M]ORI = 2    # Par défaut, saisi
 Else 
  If [F:RBK]BAN<>[M]BAN : [M]ORI=2
  Else 
   [M]ORI = [F:RBK]ORI
   If [M]ORI=0 : [M]ORI=1 : Endif
  Endif
 Endif
 Filter [RBK]
Endif
End

Subprog AP_RBKNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : [M]ORI=2 : mkstat = 4 : Endif
End

Subprog AM_OLDAMT(VALEUR)
Variable Decimal VALEUR
If [M]NEWSNS<>0
 If [M]NEWSNS = [M]OLDSNS
  [M]NEWAMT = [M]NEWAMT-[M]OLDAMT+VALEUR
 Else
  [M]NEWAMT = [M]NEWAMT+[M]OLDAMT-VALEUR
 Endif
 Gosub AFFNEWAMT
 If !GIMPORT : Affzo NEWAMT, NEWSNS : Endif
Endif
End

Subprog AM_OLDSNS(VALEUR)
Variable Integer VALEUR
If [M]NEWSNS<>0
 If VALEUR=[M]NEWSNS
  [M]NEWAMT = [M]NEWAMT+2*[M]OLDAMT
 Else
  [M]NEWAMT = [M]NEWAMT-2*[M]OLDAMT
 Endif
 Gosub AFFNEWAMT
 If !GIMPORT : Affzo NEWAMT, NEWSNS : Endif
Endif
End

$AFFNEWAMT
If [M]NEWAMT<0
 [M]NEWAMT = abs([M]NEWAMT)
 If [M]NEWSNS = 1 : [M]NEWSNS += 1
 Else [M]NEWSNS -= 1
 Endif
Endif
Return

Subprog D_NEWAMT(VALEUR)
Variable Decimal VALEUR
VALEUR=[M]OLDAMT
End

Subprog D_NEWSNS(VALEUR)
Variable Integer VALEUR
VALEUR=[M]OLDSNS
End

Subprog C_OPEDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<OLDDAT | VALEUR>NEWDAT
 # Date en dehors de la période définie par l'ancien et le nouveau solde
 GMESSAGE=mess(44,120,1)
 mkstat=2 : End
Endif
Call CONTDEV([M]BANCUR,VALEUR) From TRTDEV
End

Subprog C_NBLIG
Local Integer OK, IND
Call LECTURE("BAN",[M]BAN,"") From CONTOBJ
Case status
 When 75 :        # Modification de ligne
  If !find([M]CHK(nolign-1),"*","") & [M]CHK(nolign-1)<="ZZZZZ" & [M]CHK(nolign-1)>="AAAAA"
   GMESSAGE=mess(54,120,1)-"\"-mess(37,100,1)-[M]CHK(nolign-1)
   # Ligne pointée en rapprochement: modification impossible
   # Code XXXXX
   mkstat = 2 
   End
  Elsif [M]CHK(nolign-1)<>""
   GERR=3 : GMESSAGE=mess(56,120,1)  :# La ligne est pointée
  Endif
 When 65,68,83 :  # Suppression de lignes
  If status=65 : nolign1=nolign : Endif
  For IND=nolign-1 To nolign1-1
   If [M]CHK(IND)<>""
    GMESSAGE = mess(55,120,1)-"\"-mess(61,100,1)-num$(IND+1)
    # Ligne pointée: suppression impossible
    # Ligne n°xx
    mkstat = 2 
    Break
   Endif
  Next
  If mkstat : End : Endif
 When Default 
Endcase
End

Subprog AVANT_NBLIG
If [M]NEWSNS<>0
 If ([M]SNS(nolign-1)=1 and [M]NEWSNS=1) | ([M]SNS(nolign-1)=2 and [M]NEWSNS=2)
  [M]NEWAMT = [M]NEWAMT-[M]AMTCUR(nolign-1)
 Else
  [M]NEWAMT = [M]NEWAMT+[M]AMTCUR(nolign-1)
 Endif
 Gosub AFFNEWAMT
 If !GIMPORT : Affzo NEWAMT, NEWSNS : Endif
Endif
End

Subprog APRES_NBLIG
If [M]NEWSNS<>0
 If ([M]SNS(nolign-1)=1 & [M]NEWSNS=1) | ([M]SNS(nolign-1)=2 & [M]NEWSNS=2)
  [M]NEWAMT = [M]NEWAMT+[M]AMTCUR(nolign-1)
 Else
  [M]NEWAMT = [M]NEWAMT-[M]AMTCUR(nolign-1)
 Endif
 Gosub AFFNEWAMT
 If !GIMPORT : Affzo NEWAMT, NEWSNS : Endif
Endif
End

Subprog AM_CHK(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 VALEUR = tolower(VALEUR)
Endif
End

Subprog AS_OLDAMT(VALEUR)
Variable Decimal VALEUR
Gosub VERIF_OLD
End

Subprog AS_OLDSNS(VALEUR)
Variable Integer VALEUR
Gosub VERIF_OLD
End

$VERIF_OLD
If GREP<>"C" & GREP<>"D"
 If [M]ORI<>2 : mkstat=2 : Return : Endif
 Filter [RBK] Where BAN=[M]BAN & OPEDAT=[M]OLDDAT & RECTYP=3 & ORI=2 & RBKNUM<>[M]RBKNUM
 Read [RBK]RBK1 First
 If !fstat : mkstat=2 : Endif
 Filter [RBK] Where BAN=[M]BAN & OPEDAT>=[M]NEWDAT & ORI=2 & RBKNUM<>[M]RBKNUM & CUR<>[M]BANCUR
 Read [RBK]RBK0 First
 If !fstat : mkstat=2 : Endif
 Filter [RBK] 
Endif
Return

Subprog AS_OLDDAT(VALEUR)
Variable Date    VALEUR
Gosub AS_RELEVE
End

Subprog AM_OLDDAT(VALEUR)
Variable Date    VALEUR
Local Integer STAT, SENS1, SENS2, SNSBNQ
Local Decimal MTT
Local Char CURLED(GLONCUR)

Call LECTURE("BAN",[M]BAN,"") From CONTOBJ
Filter [RBK] Where BAN=[M]BAN & OPEDAT=VALEUR & RECTYP=3 & RBKNUM<>[M]RBKNUM 
Read [RBK]RBK1 Last 
If !fstat 
 If [F:RBK]CUR=[M]BANCUR
  [L]MTT = [F:RBK]AMTCUR
 Else
  Call SETCUR(1,[F:BAN]CPY,[L]CURLED) From CPTDIV
  STAT=0
  Call CONVERT([F:RBK]CUR,[M]BANCUR,[L]CURLED,1,VALEUR,[F:RBK]AMTCUR,[L]MTT,STAT) From TRTDEV
  If STAT
   # Pas de cours de devises [F:RBK]CUR -> [M]BANCUR (VALEUR) 
   GMESSAGE = mess(16,114,1)-[F:RBK]CUR-"->"-[M]BANCUR-"("+format$("D:"+GFMDAT,VALEUR)-")"
   GOK=0 : mkstat=2
  Endif
 Endif
 Call PARAM([F:BAN]CPY,"SNSBNQ",GDIV(0)) From ADOVAL
 [L]SNSBNQ = val(GDIV(0))
 If [M]NEWSNS<>0
  If ([M]NEWSNS=1 & [L]SNSBNQ=1) | ([M]NEWSNS=2 & [L]SNSBNQ=2)
   [L]SENS1 = 1 : # Débit
  Else
   [L]SENS1 = -1 : # Crédit
  Endif
  If ([M]OLDSNS=1 & [L]SNSBNQ=1) | ([M]OLDSNS=2 & [L]SNSBNQ=2)
   [L]SENS2 = 1 : # Débit
  Else
   [L]SENS2 = -1 : # Crédit
  Endif
  [M]NEWAMT = [L]SENS1*[M]NEWAMT - [L]SENS2*[M]OLDAMT + [F:RBK]SNS*[L]MTT

  If [M]NEWAMT<0
   [M]NEWAMT = abs([M]NEWAMT)
   [M]NEWSNS = 2 : If [L]SNSBNQ=2 : [M]NEWSNS=1 : Endif
  Else
   [M]NEWSNS = 1 : If [L]SNSBNQ=2 : [M]NEWSNS=2 : Endif
  Endif

  If ([F:RBK]SNS=1 & [L]SNSBNQ=1) | ([F:RBK]SNS=-1 & [L]SNSBNQ=2)
   [M]OLDSNS = 1 : # Débit
  Else
   [M]OLDSNS = 2 : # Crédit
  Endif
  [M]OLDAMT=[L]MTT
 Endif
 If !GIMPORT : Affzo OLDAMT, OLDSNS, NEWAMT, NEWSNS : Endif
Endif
Filter [RBK]
End

Subprog AS_NEWDAT(VALEUR)
Variable Date    VALEUR
Gosub AS_RELEVE
End

Subprog C_NEWDAT(VALEUR)
Variable Date    VALEUR
Local Char NUM(GLONVCR)
Local Integer SNSBNQ, OK
Read [RBK]RBK1(3) = [M]BAN;1;[M]OLDDAT
If !fstat
 NUM  = [F:RBK]RBKNUM
 If NUM<>[M]RBKNUM
  Read [RBK]RBK0(3) = [M]BAN;NUM;3
  If !fstat
   If [F:RBK]OPEDAT=VALEUR 
    mkstat=2 : GMESSAGE=mess(58,120,1)-NUM : End : # Un relevé existe déjà avec ces dates
   Endif
  Endif
 Endif
Endif
If VALEUR<>[M]NEWDAT
 Call PARAM([F:BAN]CPY,"SNSBNQ",GDIV(0)) From ADOVAL 
 SNSBNQ = val(GDIV(0))
 Call LECTURE("BAN",[M]BAN,"") From CONTOBJ
 # Réaffecter les soldes avec la devise en cours de saisie
 If VALEUR < [F:BAN]CHGDAT
  [M]BANCUR = [F:BAN]OLDCUR
  Call LECTURE("TCU",[M]BANCUR,"") From CONTOBJ
  Filter [RBK] Where BAN=[M]BAN & RECTYP=3 & OPEDAT<=[M]OLDDAT & CUR=[M]BANCUR & ORI=2
  Read [RBK]RBK1 Last
  If !fstat
   [M]OLDAMT = [F:RBK]AMTCUR
   If ([F:RBK]SNS=1 & SNSBNQ=1) | ([F:RBK]SNS=-1 & SNSBNQ=2)
    [M]OLDSNS = 1 
   Else
    [M]OLDSNS = 2 
   Endif
   [M]NEWAMT = [M]OLDAMT
   [M]NEWSNS = [M]OLDSNS
  Endif
  Filter [RBK]
  Affzo [M]BANCUR, OLDAMT, OLDSNS, NEWAMT, NEWSNS
 Else
  [M]BANCUR = [F:BAN]CUR
  Call LECTURE("TCU",[M]BANCUR,"") From CONTOBJ
  Affzo [M]BANCUR
 Endif

 If [M]OLDDAT<[F:BAN]CHGDAT & [F:BAN]CHGDAT<=VALEUR
  mkstat=2 : GMESSAGE=mess(59,120,1)-format$(GFMD,[F:BAN]CHGDAT)
  # La devise du compte de banque a changé le [F:BAN]CHGDAT
 Endif
Endif
End

