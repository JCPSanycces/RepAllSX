# ----------------------------------------------------------------------- #
# Classe représentation SOHMANHLDM : Liste des cdes bloquées manuellement #
# ----------------------------------------------------------------------- #
# Classe de données SORDER                                                #
# ----------------------------------------------------------------------- #
#######################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
     When ""
        Case [L]AEVENT
          When "AREAD_AFTER"           : Gosub AREAD_AFTER
          When "AQUERY_TRANS_AFTER"    : Gosub AQUERY_TRANS_AFTER
        Endcase
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return
#--------------------------------------
#######################################################################################
$PROPERTIES
  Case CURPRO
    When Default
  Endcase
Return

#######################################################################################
$AREAD_AFTER

this.CURSOH1      = this.SOH.CUR

Return

#######################################################################################
$AQUERY_TRANS_AFTER

# Alimenter des propriétés qui ne sont pas dans la table

this.BPCNAM1=[F:SOH]BPCNAM(0)

Return

