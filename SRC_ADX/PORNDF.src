#**
#* Auto-Complûˋtion sur les axes
#* @param TEXDIE    : Partie de la chaine û  chercher dans le libellûˋ de l'axe
#* @param MAXREC    : Nombre d'enregistrements û  renvoyer
#* @param FIRSTREC  : Index du premier enregistrement
#* @param DIECOD    : Axes retournûˋs
#* @param DIELIB    : Libellûˋs axes retournûˋs
#* @param NBRESULT  : Nombre d'enregistrements retournûˋs
#*!
Subprog RECHDIE(TEXDIE,MAXREC,FIRSTREC,
&               DIECOD,DIELIB,NBRESULT)
Value    Char    TEXDIE()
Value    Integer MAXREC
Value    Integer FIRSTREC
# Variables retour
Variable Char    DIECOD()(1..),DIELIB()(1..)
Variable Integer NBRESULT

  If clalev([F:AXX_])=0  : Local File ATEXTRA [AXX_]  : Endif

  Gosub LOAD_PARAMRES
  Raz WFLTWHR
  Local Char WSEARCH(50)
  WSEARCH  = func AFNC.TRANSF(TEXDIE,"'","?")
  WFLTWHR  = "CODFIC='GDIE' & ZONE='DESTRA' & LANGUE='"+GLANGUE+"'"
  WFLTWHR += " & pat(toupper(TEXTE),'*"+ toupper(WSEARCH)+"*')=1"

  Filter [AXX_] Where evalue(WFLTWHR)
  WTOTALCOUNT = rowcount([AXX_])
  WMAXREC=MAXREC
  WSTART=FIRSTREC
  If WTOTALCOUNT >= WSTART
    For [AXX_]
      WNBREAD+=1
      # Job finished
      If WSTART<=WNBREAD Then
        WNBREC+=1
        DIECOD(WNBREC) = [F:AXX_]IDENT1
        DIELIB(WNBREC) = [F:AXX_]TEXTE
#        If (DIELIB(WNBREC)="") : DIELIB(WNBREC) = [F:AXX_]IDENT2 : Endif
        If WNBREC >= WMAXREC : Break: Endif
      Endif
    Next
  Endif
  NBRESULT=WNBREC
  If NBRESULT > 0 Then
    Sorta WNBREC DIECOD,DIELIB Order By DIELIB(indice+1) Asc
  Endif
  Filter[AXX_]
End

#**
#* Auto-Complûˋtion sur les sections analytiques
#* @param DIE       : Axe associûˋ
#* @param DATREF    : Date de validitûˋ
#* @param TEXCCE    : Partie de la chaine û  chercher dans le libellûˋ de la section
#* @param MAXREC    : Nombre d'enregistrements û  renvoyer
#* @param FIRSTREC  : Index du premier enregistrement
#* @param CCECOD    : Sections retournûˋes
#* @param CCELIB    : Libellûˋs sections retournûˋes
#* @param NBRESULT  : Nombre d'enregistrements retournûˋs
#*!
Subprog RECHCCE(DIE,DATREF,TEXCCE,MAXREC,FIRSTREC,
&               CCECOD,CCELIB,NBRESULT)
Value    Char    DIE,TEXCCE()
Value    Date    DATREF
Value    Integer MAXREC
Value    Integer FIRSTREC
# Variables retour
Variable Char    CCECOD()(1..),CCELIB()(1..)
Variable Integer NBRESULT

  If clalev([F:AXX_])=0  : Local File =GTABCPT+"ATEXTRA" [AXX_]  : Endif
  If clalev([F:CCE_])=0  : Local File =GTABCPT+"CACCE"   [CCE_]  : Endif

  Gosub LOAD_PARAMRES
  Raz WFLTWHR
  Local Char WSEARCH(50)
  WSEARCH  = func AFNC.TRANSF(TEXCCE,"'","?")
  WFLTWHR  = "CODFIC='CACCE' & ZONE='DESTRA' & LANGUE='"+GLANGUE+"' & IDENT1='"+DIE+"'"
  WFLTWHR += " & (pat(toupper(TEXTE),'*"+ toupper(WSEARCH)+"*')=1 | pat(toupper(CCE),'*"+ toupper(WSEARCH)+"*')=1)"
  WFLTWHR += " & (VLYSTR=[0/0/0] | VLYSTR<="+DATREF+")  & (VLYEND=[0/0/0] | VLYEND>="+DATREF+")"

  Link [F:AXX_] With [F:CCE_]CCE0=IDENT1;IDENT2
&               As [LNK_]
&               Where evalue(WFLTWHR)
#  Filter [AXX_] Where evalue(WFLTWHR)
  WTOTALCOUNT = rowcount([LNK_])
  WMAXREC=MAXREC
  WSTART=FIRSTREC
  If WTOTALCOUNT >= WSTART
#    For [AXX_]
    For [LNK_]
      WNBREAD+=1
      # Job finished
      If WSTART<=WNBREAD Then
        WNBREC+=1
        CCECOD(WNBREC) = [F:AXX_]IDENT2
        CCELIB(WNBREC) = [F:AXX_]TEXTE
        If (CCELIB(WNBREC)="") : CCELIB(WNBREC) = [F:AXX_]IDENT2 : Endif
        If WNBREC >= WMAXREC : Break: Endif
      Endif
    Next
  Endif
  NBRESULT=WNBREC
  If NBRESULT > 0 Then
    Sorta WNBREC CCECOD,CCELIB Order By CCELIB(indice+1) Asc
  Endif
  Filter[AXX_]
End

#**
#* Dûˋfinition des variables locales pour l'auto-Complûˋtion
#*!
$LOAD_PARAMRES
  Local Clbfile WFLTWHR(1)
  Local Integer WNBREAD  : WNBREAD=0
  Local Integer WSTART   : WSTART=1
  Local Integer WNBREC   : WNBREC=0
  Local Integer WTOTALCOUNT
  Local Integer WMAXREC
Return

