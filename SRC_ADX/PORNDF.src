If GUSER='MABON' Then

Local Char    CCECOD(GLONCCE)(1..),CCELIB(250)(1..)
Local Integer NBRESULT
  Call RECHCCE("AX1",[15/02/2015],"Service",10,1,CCECOD,CCELIB,NBRESULT)

Local Char    BPCNUM(GLONBPR)(0..), BPCNAM(150)(0..)
Local Integer NBRESULT
  Call GETBPCREFAC("APP","EXCLU","",100,1,BPCNUM,BPCNAM,NBRESULT)
Endif

End


$ACTION
Case [L]ACTION
 When "WEB_CREATE"    : Gosub WEB_CREATE
Endcase
Return

#-------------------------------------------------------------------------------
$AUTORIS
If [V]GFONCTION<>"GESHREXS" : #"PRHEXS" DAHOF function does not exist on GX3
 [V]GFONCTION="GESHREXS" : #"PRHEXS" DAHOF function does not exist on GX3
 Call AUTORIS From EXEFNC
Endif

If GNBAUZ = 0
 GMESSAGE = mess(74,100,1)-"("+GFONCTION+")" : # Fonction non autorisûˋe
# Call ADDMESSERR(GMESSAGE) From AWEB
 GERR = 1
Endif

Call AUTSRV From GLOBPAY

#If [L]MATRICULE<>[V]GREFNUM
If [L]MATRICULE<>[V]GREFNUM & !GERR
# SEGAY - 11/10/11 - FQ76996 -
# If !instr(1,[V]GUSRAUZ(1),"1")
#  [V]GMESSAGE="("+mess(124,142,1)+")"-mess(31,702,1)
#  # Habilitations-Vous n'avez pas les droits pour ce salariûˋ
#  [V]GERR    =1
# Elsif [V]GUSRACS<2
 If [V]GUSRACS<2
# END - FQ76996 -
  If !clalev([F:ID])  : Local File EMPLOID [ID] : Endif
  Read [ID]ID0=[L]MATRICULE
  If [F:ID]CODACS>""
   If !clalev([F:ACC]) : Local File ACCES [ACC] : Endif
   Look [ACC]CODACC=[V]GUSER;[F:ID]CODACS
   If fstat
    [V]GMESSAGE="("+mess(25,115,1)+")"-mess(31,10702,1)
    # Code d'accû´s-Vous n'avez pas les droits pour ce salariûˋ
    [V]GERR    =1
   Endif
  Endif
 Endif
Endif
Return

################################################################################
#
# Renvoie infos d'en-tûˆte des notes de frais
#
################################################################################

Subprog GETNDFRES( MATRICULE,CONTRAT,DATDEB,STATUTS,CTRNUM,EXSNUM,EXSSTA,TIT,PAYSHR,RFUSHR
&                , STASHR,CREDAT,STADAT,CMT,TODATE
&                )
Value    Date    TODATE
Value    Char    MATRICULE(), CONTRAT(), STATUTS()
Value    Date    DATDEB
Variable Char    CTRNUM()(0..), TIT()(0..), CMT()(0..)
Variable Integer EXSNUM(0..), EXSSTA(0..)
Variable Decimal PAYSHR(0..),STASHR(0..),RFUSHR(0..)
Variable Date    CREDAT(0..),STADAT(0..)

If GMODU(6) <> 2 : End : Endif : # 69157 module note de frais

Gosub AUTORIS
If [V]GERR : End : Endif

If !clalev([F:HREXS]) : Local File HREXPENSES  [F:HREXS] : Endif
If !clalev([F:EXSH])  : Local File EXPENSESHEA [F:EXSH]  : Endif
If !clalev([F:HRTES]) : Local File HRTABEXPENS [F:HRTES] : Endif
If !clalev([F:HRCTR]) : Local File EMPLOCTR  [HRCTR] : Endif

Local Shortint N, S
Local Char CRITERE(250)

If [L]CONTRAT>""        : [L]CRITERE-="& CTRNUM'"+[L]CONTRAT+"'"                  : Endif
If [L]STATUTS>""        : [L]CRITERE-="& find(EXSSTA,"+[L]STATUTS+")<>0"          : Endif
If [V]GUSRFCY<>"\"      : [L]CRITERE-="& find([HRCTR]ETRFCY,[V]GUSRFCY)"            : Endif
If [L]DATDEB <> [0/0/0] : [L]CRITERE-="& ENDDAT>=["+format$(GFMD,[L]DATDEB)+"]"   : Endif
If [L]TODATE <> [0/0/0] : [L]CRITERE-="& STRDAT<=["+format$(GFMD,[L]TODATE)+"]"   : Endif

If [L]CRITERE=""   : [L]CRITERE="1=1" : Else [L]CRITERE=right$([L]CRITERE,4) : Endif


Local Char HEA_LEG(GLONADI) : HEA_LEG = ""
Read [F:EXSH]EXSH0 = MATRICULE;EXSNUM;CONTRAT
If !fstat
  HEA_LEG = [F:EXSH]LEG
Endif

Link [HREXS] With [HRTES]HRTES0   =HEA_LEG;CODEXP
&             , [HRCTR]CTR0(2)=REFNUM;CTRNUM
&            As [LNK]
&  Order By Key CLE=EXSNUM Desc;STADAT Desc
# FQ85820 - MABON 12/11/12 - On doit prendre la date de rûˋtroactivitûˋ au lieu de la date du contrat, pour dûˋterminer la prûˋsence du salariûˋ
#For [LNK]CLE(2) Where REFNUM=[L]MATRICULE & evalue([L]CRITERE) & LIN>0
#&                   & find([CTR]ETRSRV,[V]GAUTSRV) & [CTR]CTRDAT<=DATEXS
#&                   & ([CTR]XITDAT=[0/0/0] | [CTR]XITDAT>=DATEXS)
For [LNK]CLE(2) Where REFNUM=[L]MATRICULE & evalue([L]CRITERE) & LIN>0
&                   & find([HRCTR]ETRSRV,[V]GAUTSRV) & ([HRCTR]CTRDAT<=DATEXS | ([HRCTR]FLGRET=2 & [HRCTR]RETDATEFF<=DATEXS))
&                   & ([HRCTR]XITDAT=[0/0/0] | [HRCTR]XITDAT>=DATEXS)
# Fin MABON
 If N>=dim([L]EXSNUM)
  [V]GERR=1
 Else
  [L]CTRNUM(N)=[F:HREXS]CTRNUM
  [L]EXSNUM(N)=[F:HREXS]EXSNUM
  [L]EXSSTA(N)=[F:HREXS]EXSSTA
  [L]TIT   (N)=[F:HREXS]TIT
  [L]CMT   (N)=[F:HREXS]CMT
  [L]CREDAT(N)=[F:HREXS]CREDAT
  [L]STADAT(N)=[F:HREXS]STADAT
  For [LNK]CLE
   If [F:HRTES]DEB=2 : S=-1 : Else S=1 : Endif
   [L]RFUSHR(N)+=S*[F:HREXS]RFUSHR
   [L]PAYSHR(N)+=S*[F:HREXS]PAYSHR
   If [F:HREXS]STA=2 : [L]STASHR(N)+=S*[F:HREXS]RFUSHR : Endif
  Next
 Endif
 N+=1
Next

If [V]GERR=1
 [V]GMESSAGE="GETNDFRES :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

End

################################################################################
#
# Manipule l'en-tûˆte d'une note de frais
# On passe ûˋventuellement par une ligne "0", quand on a pas de ligne
#
################################################################################

Subprog SETNOTEFRAIS( ACTION,REFNUM,CTRNUM,EXSNUM,STRDAT,ENDDAT,TIT,EXSSTA,PAYSHR,RFUSHR
&                   , STASHR
&                   , URLBACK, CMT)
Value    Char    ACTION(), REFNUM(), CTRNUM()
Variable Date    STRDAT, ENDDAT
Variable Integer EXSNUM, EXSSTA
Variable Char    TIT()
Variable Decimal PAYSHR, RFUSHR,STASHR
Value    Char    URLBACK (), CMT()

If GMODU(6) <> 2 : End : Endif : # 69157 module note de frais

Local    Char SAVABR (GLONAOB)
Local    Char MATRICULE([V]GLONMAT)

#URLBACK = "http://ecvmdev2003x64:28880/xtend/page?PAG=STD&SOL=SOLPAIEV6&FLDR=PAIEV6&SITE=RHDEV&LANG=FRA&page=VAL"
#Global   Char GURLRET001 (80)
#Global   Char GURLRET002 (80)
#Global   Char GURLRET003 (80)
# Url de retour pour message workflow, stockûˋ dans les variables contexte du workflow de longueur 80
GURLRET001 = mid$(URLBACK,001,80)
GURLRET002 = mid$(URLBACK,081,80)
GURLRET003 = mid$(URLBACK,161,80)

[L]MATRICULE=[L]REFNUM
Gosub AUTORIS
If [V]GERR : End : Endif

If !clalev([F:HREXS]) : Local File HREXPENSES  [HREXS] : Endif
If !clalev([F:HRTES]) : Local File HRTABEXPENS [HRTES] : Endif
If !clalev([F:HRCTR])   : Local File EMPLOCTR    [HRCTR]   : Endif


Local Char     CLECUR2(30)(1..4), GRPDEB(250), SYMBOLE(100) , GRPW (20)
Local Shortint S

If [L]EXSNUM>0
 # FQ85820 - MABON 12/11/12 - On doit prendre la date de rûˋtroactivitûˋ au lieu de la date du contrat, pour dûˋterminer la prûˋsence du salariûˋ
# Link [CTR] With [EXS]EXS0(2)=REFNUM;[L]EXSNUM
#&             As [LNK]
#&          Where CTRDAT<=[EXS]STRDAT & (XITDAT=[0/0/0] | XITDAT>=[EXS]ENDDAT)
 Link [HRCTR] With [HREXS]HREXS0(2)=REFNUM;[L]EXSNUM
&             As [LNK]
&          Where (CTRDAT<=[HREXS]STRDAT | (FLGRET=2 & RETDATEFF<=[HREXS]STRDAT)) & (XITDAT=[0/0/0] | XITDAT>=[HREXS]ENDDAT)
# Fin MABON
 Default File [LNK]
Else
 # FQ85820 - MABON 12/11/12 - On doit prendre la date de rûˋtroactivitûˋ au lieu de la date du contrat, pour dûˋterminer la prûˋsence du salariûˋ
# Filter [CTR] Where CTRDAT<=[L]STRDAT & (XITDAT=[0/0/0] | XITDAT>=[L]ENDDAT)
 Filter [HRCTR] Where (CTRDAT<=[L]STRDAT | (FLGRET=2 & RETDATEFF<=[L]STRDAT)) & (XITDAT=[0/0/0] | XITDAT>=[L]ENDDAT)
 # Fin MABON
 Default File [HRCTR]
Endif
For [F]CTR0 Where REFNUM=[L]REFNUM & CTRNUM=[L]CTRNUM
 If !find([F:HRCTR]ETRSRV,[V]GAUTSRV)
  [V]GMESSAGE=mess(31,10702,1) : # Vous n'avez pas les droits pour ce salariûˋ
  [V]GERR    =1
  Break
 Elsif [V]GUSRFCY<>"\"
  S=find([F:HRCTR]ETRFCY,[V]GUSRFCY)
  Case [L]ACTION
   When "CREATE"         : If !instr(1,[V]GUSRAUZ(S),"C") : [V]GERR=1 : Endif
   When "MODIFY", "SEND" : If !instr(1,[V]GUSRAUZ(S),"M") : [V]GERR=1 : Endif
   When "DELETE"         : If !instr(1,[V]GUSRAUZ(S),"S") : [V]GERR=1 : Endif
  Endcase
  If [V]GERR : [V]GMESSAGE=mess(99,9009,1) : Endif : # Action non autorisûˋe
 Endif
Next
Filter [F]
If [V]GERR : End : Endif

If [L]ACTION<>"CREATE"
 Filter [HREXS] Where EXSNUM=[L]EXSNUM
 Read [HREXS] First
 Filter [HREXS]
 If fstat
  [V]GMESSAGE=mess(23,100,1) : # Fiche inexistante
  [V]GERR    =1
  End
 Elsif ([F:HREXS]EXSSTA>1 | [F:HREXS]STA=2) & [L]ACTION<>"READ"
  [V]GMESSAGE=mess(26,10718,1) : # La note de frais n'est plus en statut brouillon
  [V]GERR    =1
  End
 Endif

 [L]CLECUR2(1)=[L]REFNUM
 [L]CLECUR2(2)=[L]CTRNUM
 [L]CLECUR2(3)="1"
Endif

If !find([L]ACTION,"CREATE","READ")
 [L]SYMBOLE="HREXS"+num$([L]EXSNUM)+"\"+[L]REFNUM+"\"+[L]CTRNUM
 Lock =[L]SYMBOLE
 If fstat
  [V]GMESSAGE=mess(98,126,1) : # La fiche est utilisûˋe par un autre utilisateur
  [V]GERR    =1
  End
 Endif
Endif

Case [L]ACTION
When "CREATE"
 Trbegin [HREXS]
  Filter [HREXS] Where LIN=0 & (REFNUM=[L]REFNUM | CREDAT<date$-1)
&       Order By Key CLE=CREDAT;CRETIM
  Readlock [HREXS] First
  While fstat=1 : Readlock [HREXS] Next : Wend
  Filter [HREXS]
  S=fstat
  If S : Raz [F:HREXS] : [F:HREXS]EXSNUM=uniqid([HREXS]) : Endif : # on crûˋe une ligne "0"
  [L]EXSNUM    =[F:HREXS]EXSNUM
  [F:HREXS]REFNUM=[L]REFNUM
  [F:HREXS]CTRNUM=[L]CTRNUM
  [F:HREXS]STRDAT=[L]STRDAT
  [F:HREXS]ENDDAT=[L]ENDDAT
  [F:HREXS]EXSSTA=1
# 56903
  [L]EXSSTA = 1
  [F:HREXS]TIT   =[L]TIT
  [F:HREXS]CMT   =[L]CMT
  [F:HREXS]CREDAT=date$
  [F:HREXS]CRETIM=time
  [F:HREXS]CREUSR=[V]GUSER
  If S : Write [HREXS] : Else Rewrite [HREXS] : Endif
 #75617
 If fstat
  Rollback
  [V]GMESSAGE="CREATE [HREXS]:"-mess(26,125,1)
  [V]GERR    =1
 Else
  Commit
 Endif
 Unlock [HREXS] #by safety
 #end 75617

When "MODIFY"
 If [L]STRDAT=[0/0/0] : [L]DATDEB=[F:HREXS]STRDAT : Endif
 If [L]ENDDAT=[0/0/0] : [L]DATFIN=[F:HREXS]ENDDAT : Endif
 If [L]TIT   =""      : [L]TIT   =[F:HREXS]TIT    : Endif
 If [L]CMT   =""      : [L]CMT   =[F:HREXS]CMT    : Endif
#56903
 [L]EXSSTA =  [F:HREXS]EXSSTA : # Pas prûˋvu de modifier le statut ici
 Filter [HREXS] Where EXSNUM=[L]EXSNUM & (DATEXS<[L]STRDAT| DATEXS>[L]ENDDAT) & LIN>0
 Look [HREXS] First
 Filter [HREXS]
 If !fstat
  [V]GMESSAGE=mess(3,10718,1) : # Date en dehors de la pûˋriode
  [V]GERR    =1
  Goto DELOCK
 Endif

 Trbegin [HREXS]
  Update [HREXS] Where EXSNUM=[L]EXSNUM
&               With STRDAT=[L]STRDAT
&                  , ENDDAT=[L]ENDDAT
&                  , TIT   =[L]TIT
&                  , CMT   =[L]CMT
 #75617
 If fstat
  Rollback
  [V]GMESSAGE="MODIFY [HREXS]:"-mess(27,125,1)
  [V]GERR    =1
 Else
  Commit
 Endif
 #end 75617

When "SEND"
 If ![F:HREXS]LIN
  [V]GMESSAGE=mess(178,123,1) : # Il doit y avoir au moins une ligne
  [V]GERR    =1
  Goto DELOCK
 Endif
 Call IDENT3("HREXS",[L]GRPDEB,num$([L]EXSNUM),[L]CLECUR2) From GOBJTXT
 Call WRKGLOB(171,[L]GRPDEB,"HREXPENSES","") From GOBJACT

 Trbegin [HREXS]
  Update [HREXS] Where EXSNUM=[L]EXSNUM With EXSSTA=2

  [F:HREXS]EXSSTA=2
# 56903
  EXSSTA = 2
# segay 75617 15/09/11
# le test sur fstat ûˋtait mal placûˋ, je le met avant l'envoi du workflow
# car celui si mofifie fstat
 If fstat
  Rollback
  [V]GMESSAGE="SEND [HREXS]:"-mess(27,125,1)
  [V]GERR    =1
 Else
  Commit
 Endif
# End 75617 15/09/11

# 59084
  SAVABR = GABREV
  GABREV = "HREXS"
#  Call WORKPLUS(2,"EXS","M",[L]GRPDEB,"",0,0,2,[L]GRPDEB) From AWRK
  Call WORKPLUS(2,"HREXS","M",[L]GRPDEB,"",0,0,2,[L]GRPW) From AWRK  : # 62014
  GABREV = SAVABR
 #75617
# segay 75617 15/09/11
# le test sur fstat ûˋtait mal placûˋ, je le met avant l'envoi du workflow
# car celui si mofifie fstat
# If fstat
#  Rollback
#  [V]GMESSAGE="SEND [EXS]:"-mess(27,125,1)
#  [V]GERR    =1
# Else
#  Commit
# Endif
 #end 75617

When "DELETE" : # suppression de la note avec toutes ses lignes
 Call ANUCOD("HREXS",num$([L]EXSNUM),[L]CLECUR2,[V]GOK) From GOBJACT
 #75617
 If [V]GOK<1
  [V]GMESSAGE="DELETE [HREXS]:"-mess(28,125,1)
  [V]GERR    =1
 Endif
 #end 75617

When "READ"
 Link [HREXS] With [HRTES]HRTES0=GCURLEG;CODEXP As [LNK]
 For [LNK]HREXS0(2) Where EXSNUM=[L]EXSNUM
  [L]EXSSTA=[F:HREXS]EXSSTA
  [L]TIT   =[F:HREXS]TIT
  [L]STRDAT=[F:HREXS]STRDAT
  [L]ENDDAT=[F:HREXS]ENDDAT
  [L]CMT   =[F:HREXS]CMT
  For [LNK]HREXS0
   If [F:HRTES]DEB=2 : S=-1 : Else S=1 : Endif
   [L]RFUSHR+=S*[F:HREXS]RFUSHR
   [L]PAYSHR+=S*[F:HREXS]PAYSHR
   If [F:HREXS]STA=2 : [L]STASHR+=S*[F:HREXS]RFUSHR : Endif
  Next
 Next
Endcase

#-------------------------------------------------------------------------------
$DELOCK
If [L]SYMBOLE>"" : Unlock=[L]SYMBOLE : Endif
End

################################################################################
#
# Manipule N lignes avec pour chacune une action particuliû´re
#
################################################################################

Subprog SETLIGFRAIS2( ACTION,EXSNUM,UID,DATEXS,CODEXP,EXPDES,CUR,CURDES,VAT,VATDES,QTY,SNS
&                   , PAYCUR,VATCUR,RFUCUR,CPY,CPYNAM,BPCNUM,BPCNAM,SOHNUM,CUSORDREF
&                   , SOHLIG,ITMDES,INVFLG,CCE1,CCE1DES,CCE2,CCE2DES,CCE3,CCE3DES,CCE4,CCE4DES
&                   ,CCE5,CCE5DES,CCE6,CCE6DES,CCE7,CCE7DES,CCE8,CCE8DES,CCE9, CCE9DES
&                  , CCE10,CCE10DES,CCE11,CCE11DES,CCE12,CCE12DES,CCE13,CCE13DES,CCE14,CCE14DES
&                  , CCE15,CCE15DES,CCE16,CCE16DES,CCE17,CCE17DES,CCE18,CCE18DES,CCE19,CCE19DES
&                  , CCE20,CCE20DES,DES,STA,TOTPAY,TOTRFU,TOTSTA,ERRMES
&                   )
Variable Char    ACTION()(0..)
Value    Integer EXSNUM
Variable Integer UID(0..), QTY(0..), SOHLIG(0..), INVFLG(0..), STA(0..), SNS(0..)
Variable Date    DATEXS(0..)
Variable Char    CODEXP()(0..), CUR()(0..), VAT()(0..), CPY()(0..), BPCNUM()(0..)
Variable Char    SOHNUM()(0..), CCE1()(0..), CCE2()(0..), CCE3()(0..), CCE4()(0..)
Variable Char    CCE5()(0..), CCE6()(0..), CCE7()(0..), CCE8()(0..), CCE9()(0..),CCE10()(0..)
Variable Char    CCE11()(0..), CCE12()(0..), CCE13()(0..), CCE14()(0..), CCE15()(0..)
Variable Char    CCE16()(0..), CCE17()(0..), CCE18()(0..), CCE19()(0..), CCE20()(0..)
Variable Char    DES()(0..), EXPDES()(0..), CURDES()(0..),VATDES()(0..), CPYNAM()(0..)
Variable Char    BPCNAM()(0..), CUSORDREF()(0..), ITMDES()(0..), CCE1DES()(0..)
Variable Char    CCE2DES()(0..), CCE3DES()(0..), CCE4DES()(0..), CCE5DES()(0..)
Variable Char    CCE6DES()(0..), CCE7DES()(0..), CCE8DES()(0..), CCE9DES()(0..),CCE10DES()(0..)
Variable Char    CCE11DES()(0..), CCE12DES()(0..), CCE13DES()(0..), CCE14DES()(0..), CCE15DES()(0..)
Variable Char    CCE16DES()(0..), CCE17DES()(0..), CCE18DES()(0..), CCE19DES()(0..), CCE20DES()(0..)

Variable Char    ERRMES()(0..)
Variable Decimal PAYCUR(0..), VATCUR(0..), RFUCUR(0..), TOTPAY, TOTRFU, TOTSTA
Local Integer ADDPJ(0..dim(CODEXP)-1)

Call SETLIGFRAIS2PJ( ACTION,EXSNUM,UID,DATEXS,CODEXP,EXPDES,CUR,CURDES,VAT,VATDES,QTY,SNS
&                   , PAYCUR,VATCUR,RFUCUR,CPY,CPYNAM,BPCNUM,BPCNAM,SOHNUM,CUSORDREF
&                   , SOHLIG,ITMDES,INVFLG,CCE1,CCE1DES,CCE2,CCE2DES,CCE3,CCE3DES,CCE4,CCE4DES
&                   ,CCE5,CCE5DES,CCE6,CCE6DES,CCE7,CCE7DES,CCE8,CCE8DES,CCE9, CCE9DES
&                  , CCE10,CCE10DES,CCE11,CCE11DES,CCE12,CCE12DES,CCE13,CCE13DES,CCE14,CCE14DES
&                  , CCE15,CCE15DES,CCE16,CCE16DES,CCE17,CCE17DES,CCE18,CCE18DES,CCE19,CCE19DES
&                  , CCE20,CCE20DES,DES,STA,TOTPAY,TOTRFU,TOTSTA,ERRMES,ADDPJ
&                   )


End







Subprog SETLIGFRAIS2PJ( ACTION,EXSNUM,UID,DATEXS,CODEXP,EXPDES,CUR,CURDES,VAT,VATDES,QTY,SNS
&                   , PAYCUR,VATCUR,RFUCUR,CPY,CPYNAM,BPCNUM,BPCNAM,SOHNUM,CUSORDREF
&                   , SOHLIG,ITMDES,INVFLG,CCE1,CCE1DES,CCE2,CCE2DES,CCE3,CCE3DES,CCE4,CCE4DES
&                   ,CCE5,CCE5DES,CCE6,CCE6DES,CCE7,CCE7DES,CCE8,CCE8DES,CCE9, CCE9DES
&                  , CCE10,CCE10DES,CCE11,CCE11DES,CCE12,CCE12DES,CCE13,CCE13DES,CCE14,CCE14DES
&                  , CCE15,CCE15DES,CCE16,CCE16DES,CCE17,CCE17DES,CCE18,CCE18DES,CCE19,CCE19DES
&                  , CCE20,CCE20DES,DES,STA,TOTPAY,TOTRFU,TOTSTA,ERRMES,ADDPJ
&                   )
Variable Char    ACTION()(0..)
Value    Integer EXSNUM
Variable Integer UID(0..), QTY(0..), SOHLIG(0..), INVFLG(0..), STA(0..), SNS(0..)
Variable Date    DATEXS(0..)
Variable Char    CODEXP()(0..), CUR()(0..), VAT()(0..), CPY()(0..), BPCNUM()(0..)
Variable Char    SOHNUM()(0..), CCE1()(0..), CCE2()(0..), CCE3()(0..), CCE4()(0..)
Variable Char    CCE5()(0..), CCE6()(0..), CCE7()(0..), CCE8()(0..), CCE9()(0..),CCE10()(0..)
Variable Char    CCE11()(0..), CCE12()(0..), CCE13()(0..), CCE14()(0..), CCE15()(0..)
Variable Char    CCE16()(0..), CCE17()(0..), CCE18()(0..), CCE19()(0..), CCE20()(0..)
Variable Char    DES()(0..), EXPDES()(0..), CURDES()(0..),VATDES()(0..), CPYNAM()(0..)
Variable Char    BPCNAM()(0..), CUSORDREF()(0..), ITMDES()(0..), CCE1DES()(0..)
Variable Char    CCE2DES()(0..), CCE3DES()(0..), CCE4DES()(0..), CCE5DES()(0..)
Variable Char    CCE6DES()(0..), CCE7DES()(0..), CCE8DES()(0..), CCE9DES()(0..),CCE10DES()(0..)
Variable Char    CCE11DES()(0..), CCE12DES()(0..), CCE13DES()(0..), CCE14DES()(0..), CCE15DES()(0..)
Variable Char    CCE16DES()(0..), CCE17DES()(0..), CCE18DES()(0..), CCE19DES()(0..), CCE20DES()(0..)

Variable Char    ERRMES()(0..)
Variable Decimal PAYCUR(0..), VATCUR(0..), RFUCUR(0..), TOTPAY, TOTRFU, TOTSTA
Variable Integer ADDPJ(0..)


If GMODU(6) <> 2 : End : Endif : # 69157 module note de frais

Local Shortint I, E
Local Decimal  ITOTPAY, ITOTRFU, ITOTSTA
If !clalev([F:HREXS]) : Local File HREXPENSES [HREXS] : Endif

Trbegin [HREXS]
 While [L]ACTION(I)>""
  Raz [L]ITOTPAY, [L]ITOTRFU, [L]ITOTSTA
  Call SETLIGFRAISPJ( [L]ACTION(I),[L]EXSNUM,[L]UID(I..I),[L]DATEXS(I..I),[L]CODEXP(I..I)
&                 , [L]EXPDES(I..I),[L]CUR(I..I),[L]CURDES(I..I),[L]VAT(I..I)
&                 , [L]VATDES(I..I),[L]QTY(I..I),[L]SNS(I..I),[L]PAYCUR(I..I)
&                 , [L]VATCUR(I..I),[L]RFUCUR(I..I),[L]CPY(I..I),[L]CPYNAM(I..I)
&                 , [L]BPCNUM(I..I),[L]BPCNAM(I..I),[L]SOHNUM(I..I),[L]CUSORDREF(I..I)
&                 , [L]SOHLIG(I..I),[L]ITMDES(I..I),[L]INVFLG(I..I)
&                 , [L]CCE1(I..I), [L]CCE1DES(I..I), [L]CCE2(I..I), [L]CCE2DES(I..I), [L]CCE3(I..I), [L]CCE3DES(I..I)
&                 , [L]CCE4(I..I), [L]CCE4DES(I..I), [L]CCE5(I..I), [L]CCE5DES(I..I), [L]CCE6(I..I), [L]CCE6DES(I..I)
&                 , [L]CCE7(I..I), [L]CCE7DES(I..I), [L]CCE8(I..I), [L]CCE8DES(I..I), [L]CCE9(I..I), [L]CCE9DES(I..I)
&                 , [L]CCE10(I..I), [L]CCE10DES(I..I), [L]CCE11(I..I), [L]CCE11DES(I..I), [L]CCE12(I..I), [L]CCE12DES(I..I)
&                 , [L]CCE13(I..I), [L]CCE13DES(I..I), [L]CCE14(I..I), [L]CCE14DES(I..I), [L]CCE15(I..I), [L]CCE15DES(I..I)
&                 , [L]CCE16(I..I), [L]CCE16DES(I..I), [L]CCE17(I..I), [L]CCE17DES(I..I), [L]CCE18(I..I), [L]CCE18DES(I..I)
&                 , [L]CCE19(I..I), [L]CCE19DES(I..I), [L]CCE20(I..I), [L]CCE20DES(I..I)
&                 ,[L]DES(I..I),[L]STA(I..I),[L]ITOTPAY,[L]ITOTRFU
&                 , [L]ITOTSTA,ADDPJ(I..I)
&                 )
  If [V]GERR
   E           +=1
   [L]ERRMES(I) =mess(61,100,1)-num$(I+1)-":"-[V]GMESSAGE : # ligne no
   Raz [V]GMESSAGE, [V]GERR
  Else
   [L]TOTPAY+=[L]ITOTPAY
   [L]TOTRFU+=[L]ITOTRFU
   [L]TOTSTA+=[L]ITOTSTA
  Endif
  I+=1
 Wend
If E
 Rollback
 [V]GMESSAGE=mess(99,116,1)-num$(E) : # Nombre d'erreurs
 [V]GERR    =1
Else
 Commit
Endif

End




################################################################################
#
# manipule 1 ligne de note de frais
#
################################################################################

Subprog SETLIGFRAIS( ACTION,EXSNUM,UID,DATEXS,CODEXP,EXPDES,CUR,CURDES,VAT,VATDES,QTY,SNS
&                  , PAYCUR,VATCUR,RFUCUR,CPY,CPYNAM,BPCNUM,BPCNAM,SOHNUM,CUSORDREF,SOHLIG
&                  , ITMDES,INVFLG,CCE1,CCE1DES,CCE2,CCE2DES,CCE3,CCE3DES,CCE4,CCE4DES
&                  , CCE5,CCE5DES,CCE6,CCE6DES,CCE7,CCE7DES,CCE8,CCE8DES,CCE9,CCE9DES
&                  , CCE10,CCE10DES,CCE11,CCE11DES,CCE12,CCE12DES,CCE13,CCE13DES,CCE14,CCE14DES
&                  , CCE15,CCE15DES,CCE16,CCE16DES,CCE17,CCE17DES,CCE18,CCE18DES,CCE19,CCE19DES
&                  , CCE20,CCE20DES,DES, STA,TOTPAY,TOTRFU,TOTSTA
&                  )

Value    Char    ACTION()
Value    Integer EXSNUM
Variable Integer UID(0..), QTY(0..), SOHLIG(0..), INVFLG(0..), STA(0..), SNS(0..)
Variable Date    DATEXS(0..)
Variable Char    CODEXP()(0..), CUR()(0..), VAT()(0..), CPY()(0..), BPCNUM()(0..)
Variable Char    SOHNUM()(0..), CCE1()(0..), CCE2()(0..), CCE3()(0..), CCE4()(0..)
Variable Char    CCE5()(0..), CCE6()(0..), CCE7()(0..), CCE8()(0..), CCE9()(0..),CCE10()(0..)
Variable Char    CCE11()(0..), CCE12()(0..), CCE13()(0..), CCE14()(0..), CCE15()(0..)
Variable Char    CCE16()(0..), CCE17()(0..), CCE18()(0..), CCE19()(0..), CCE20()(0..)
Variable Char    DES()(0..), EXPDES()(0..), CURDES()(0..),VATDES()(0..), CPYNAM()(0..)
Variable Char    BPCNAM()(0..), CUSORDREF()(0..), ITMDES()(0..), CCE1DES()(0..)
Variable Char    CCE2DES()(0..), CCE3DES()(0..), CCE4DES()(0..), CCE5DES()(0..)
Variable Char    CCE6DES()(0..), CCE7DES()(0..), CCE8DES()(0..), CCE9DES()(0..),CCE10DES()(0..)
Variable Char    CCE11DES()(0..), CCE12DES()(0..), CCE13DES()(0..), CCE14DES()(0..), CCE15DES()(0..)
Variable Char    CCE16DES()(0..), CCE17DES()(0..), CCE18DES()(0..), CCE19DES()(0..), CCE20DES()(0..)
Variable Decimal PAYCUR(0..), VATCUR(0..), RFUCUR(0..), TOTPAY, TOTRFU, TOTSTA

Local Integer  ADDPJ(0..dim(PAYCUR)-1)
Call SETLIGFRAISPJ( ACTION,EXSNUM,UID,DATEXS,CODEXP,EXPDES,CUR,CURDES,VAT,VATDES,QTY,SNS
&                  , PAYCUR,VATCUR,RFUCUR,CPY,CPYNAM,BPCNUM,BPCNAM,SOHNUM,CUSORDREF,SOHLIG
&                  , ITMDES,INVFLG,CCE1,CCE1DES,CCE2,CCE2DES,CCE3,CCE3DES,CCE4,CCE4DES
&                  , CCE5,CCE5DES,CCE6,CCE6DES,CCE7,CCE7DES,CCE8,CCE8DES,CCE9,CCE9DES
&                  , CCE10,CCE10DES,CCE11,CCE11DES,CCE12,CCE12DES,CCE13,CCE13DES,CCE14,CCE14DES
&                  , CCE15,CCE15DES,CCE16,CCE16DES,CCE17,CCE17DES,CCE18,CCE18DES,CCE19,CCE19DES
&                  , CCE20,CCE20DES,DES, STA,TOTPAY,TOTRFU,TOTSTA,ADDPJ
&                  )


End






Subprog SETLIGFRAISPJ( ACTION,EXSNUM,UID,DATEXS,CODEXP,EXPDES,CUR,CURDES,VAT,VATDES,QTY,SNS
&                  , PAYCUR,VATCUR,RFUCUR,CPY,CPYNAM,BPCNUM,BPCNAM,SOHNUM,CUSORDREF,SOHLIG
&                  , ITMDES,INVFLG,CCE1,CCE1DES,CCE2,CCE2DES,CCE3,CCE3DES,CCE4,CCE4DES
&                  , CCE5,CCE5DES,CCE6,CCE6DES,CCE7,CCE7DES,CCE8,CCE8DES,CCE9,CCE9DES
&                  , CCE10,CCE10DES,CCE11,CCE11DES,CCE12,CCE12DES,CCE13,CCE13DES,CCE14,CCE14DES
&                  , CCE15,CCE15DES,CCE16,CCE16DES,CCE17,CCE17DES,CCE18,CCE18DES,CCE19,CCE19DES
&                  , CCE20,CCE20DES,DES, STA,TOTPAY,TOTRFU,TOTSTA,ADDPJ
&                  )
Value    Char    ACTION()
Value    Integer EXSNUM
Variable Integer UID(0..), QTY(0..), SOHLIG(0..), INVFLG(0..), STA(0..), SNS(0..)
Variable Date    DATEXS(0..)
Variable Char    CODEXP()(0..), CUR()(0..), VAT()(0..), CPY()(0..), BPCNUM()(0..)
Variable Char    SOHNUM()(0..), CCE1()(0..), CCE2()(0..), CCE3()(0..), CCE4()(0..)
Variable Char    CCE5()(0..), CCE6()(0..), CCE7()(0..), CCE8()(0..), CCE9()(0..),CCE10()(0..)
Variable Char    CCE11()(0..), CCE12()(0..), CCE13()(0..), CCE14()(0..), CCE15()(0..)
Variable Char    CCE16()(0..), CCE17()(0..), CCE18()(0..), CCE19()(0..), CCE20()(0..)
Variable Char    DES()(0..), EXPDES()(0..), CURDES()(0..),VATDES()(0..), CPYNAM()(0..)
Variable Char    BPCNAM()(0..), CUSORDREF()(0..), ITMDES()(0..), CCE1DES()(0..)
Variable Char    CCE2DES()(0..), CCE3DES()(0..), CCE4DES()(0..), CCE5DES()(0..)
Variable Char    CCE6DES()(0..), CCE7DES()(0..), CCE8DES()(0..), CCE9DES()(0..),CCE10DES()(0..)
Variable Char    CCE11DES()(0..), CCE12DES()(0..), CCE13DES()(0..), CCE14DES()(0..), CCE15DES()(0..)
Variable Char    CCE16DES()(0..), CCE17DES()(0..), CCE18DES()(0..), CCE19DES()(0..), CCE20DES()(0..)
Variable Decimal PAYCUR(0..), VATCUR(0..), RFUCUR(0..), TOTPAY, TOTRFU, TOTSTA
Variable Integer  ADDPJ(0..)
If GMODU(6) <> 2 : End : Endif : # 69157 module note de frais

Gosub OUVRE From WOHREXS
If !clalev([F:AXX])   : Local File ATEXTRA            [AXX]   : Endif
If !clalev([F:HREXS]) : Local File HREXPENSES         [HREXS] : Endif
If clalev([F:AXX_])=0 : Local File =GTABCPT+"ATEXTRA" [AXX_]  : Endif

Local Shortint N, S, LASLIG
Local Libelle  TRANS
Local Char     CHAINE(250), MATRICULE([V]GLONMAT), SYMBOLE(100)

#SBA ATTACH
Local Char W_UID(20)(0..0)

#SEGAY 11/04/12 80868 : Validation diffûˋrûˋe des ûˋcrans
Call ISSCREENOK(nomap,"HREXS0") From INTRUTILB

If ACTION <> "CAL" | (ACTION = "CAL" & EXSNUM <> 0)

Filter [HREXS] Where EXSNUM=[L]EXSNUM
Read [HREXS] First
Filter [HREXS]
[L]MATRICULE=[F:HREXS]REFNUM

# FQ89539 - SEGAY 22/04/13 pour avoir le salariûˋ quand on rûˋcupû´re les sections par dûˋfaut des axes dans INISEC de SUBDCE
If !clalev([F:ID])  : Local File EMPLOID [ID] : Endif
Read [ID]ID0=[L]MATRICULE
# END FQ89539 -

Gosub AUTORIS
If [V]GERR : End : Endif

[L]TRANS=adxlog

Link [HREXS] With [HRCTR]CTR0=REFNUM;CTRNUM As [LNK]
# FQ85820 - MABON 12/11/12 - On doit prendre la date de rûˋtroactivitûˋ au lieu de la date du contrat, pour dûˋterminer la prûˋsence du salariûˋ
#For [LNK]EXS0 Where EXSNUM=[L]EXSNUM & [CTR]CTRDAT<=STRDAT
#&                 & ([CTR]XITDAT=[0/0/0] | [CTR]XITDAT>=ENDDAT)
For [LNK]HREXS0 Where EXSNUM=[L]EXSNUM & ([HRCTR]CTRDAT<=STRDAT | ([HRCTR]FLGRET=2 & [HRCTR]RETDATEFF<=STRDAT))
&                 & ([HRCTR]XITDAT=[0/0/0] | [HRCTR]XITDAT>=ENDDAT)
# Fin MABON
 If !find([F:HRCTR]ETRSRV,[V]GAUTSRV)
  [V]GMESSAGE=mess(31,10702,1) : # Vous n'avez pas les droits pour ce salariûˋ
  [V]GERR    =1
  Break
 Elsif [V]GUSRFCY<>"\"
  S=find([F:HRCTR]ETRFCY,[V]GUSRFCY)
  Case [L]ACTION
   When "CREATE"           : If !instr(1,[V]GUSRAUZ(S),"C") : [V]GERR=1 : Endif
   When "MODIFY", "DELETE" : If !instr(1,[V]GUSRAUZ(S),"M") : [V]GERR=1 : Endif
  Endcase
  If [V]GERR : [V]GMESSAGE=mess(99,9009,1) : Break : Endif : # Action non autorisûˋe
 Endif
Next
If [V]GERR : End : Endif

Filter [HREXS] Where EXSNUM=[L]EXSNUM
Read [HREXS]HREXS0 Last
Filter [HREXS]
If fstat
 [V]GMESSAGE=mess(23,100,1) : # Fiche inexistante
 [V]GERR    =1
 End
Elsif ([F:HREXS]EXSSTA>1 | [F:HREXS]STA=2) & !find([L]ACTION,"READ","CAL")
 [V]GMESSAGE=mess(26,718,1) : # La note de frais n'est plus en statut brouillon
 [V]GERR    =1
 End
Elsif !find([L]ACTION,"READ","CAL")
 [L]SYMBOLE="HREXS"+num$([F:HREXS]EXSNUM)+"\"+[F:HREXS]REFNUM+"\"+[F:HREXS]CTRNUM
 Lock =[L]SYMBOLE
 If fstat
  [V]GMESSAGE=mess(98,126,1) : # La fiche est utilisûˋe par un autre utilisateur
  [V]GERR    =1
  End
 Endif
Endif

Else
 Raz [F:HREXS]    : # Pour l'action calcul sur une note qui n'existe pas encore - WGA
 N = 0
 While DATEXS(N) <> [0/0/0]
  If ([F:HREXS]STRDAT=[0/0/0] or [F:HREXS]STRDAT > DATEXS(N) )
   [F:HREXS]STRDAT = DATEXS(N)
  Endif
  If ([F:HREXS]ENDDAT=[0/0/0] or [F:HREXS]ENDDAT < DATEXS(N) )
   [F:HREXS]ENDDAT=DATEXS(N)
  Endif
  N+=1
 Wend
Endif

# SEGAY 07/03/12 80653
If [F:HREXS]CTRNUM = "" Then
  Read [F:ID]ID0 = [F:HREXS]REFNUM
  If !fstat & [F:ID]FLGMULCTR<2
   # FQ85820 - MABON 12/11/12 - On doit prendre la date de rûˋtroactivitûˋ au lieu de la date du contrat, pour dûˋterminer la prûˋsence du salariûˋ
#   Filter [CTR] Where REFNUM=[F:EXS]REFNUM & CTRDAT<=[F:EXS]ENDDAT & (XITDAT>=[F:EXS]STRDAT | XITDAT=[0/0/0])
   Filter [HRCTR] Where REFNUM=[F:HREXS]REFNUM & (CTRDAT<=[F:HREXS]ENDDAT | (FLGRET=2 & RETDATEFF<=[F:HREXS]ENDDAT)) & (XITDAT>=[F:HREXS]STRDAT | XITDAT=[0/0/0])
   # Fin MABON
   Read [HRCTR]CTR0 First
   Filter [HRCTR]
   If fstat
    [V]GMESSAGE=func AFNC.MES2( mess(171,10709,1),format$([V]GFMD,[F:HREXS]STRDAT)
&                           , format$([V]GFMD,[F:HREXS]ENDDAT)
&                           )
    #           Pas de contrat de travail pour la pûˋriode du $1$ au $2$
    [V]GERR     = 1
    End
   Else
    [F:HREXS]CTRNUM=[F:HRCTR]CTRNUM
   Endif
  Endif
Endif
# END 80653

Case [L]ACTION
When "CREATE", "CAL"
 [L]LASLIG=[F:HREXS]LIN
 Gosub INI_IMPORT

 mkstat     =0
 #[V]GIMPORT =1
 #[V]GSILENCE=1
 For nolign=1 To [M:WI0]NBLIG
  [M:HREXS0]NBLIG=nolign
  indice       =nolign-1
  status       =75
  Call SAI_NBLIG("","WEB_CREATE","PORNDF") From W0HREXS0
#68641
  If mkstat
   If GMESSAGE = ""
    If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
    Read [ATZ]CODZONE = "HREXPENSES";GZONE
    If !fstat
     GMESSAGE = mess(32,126,1)-'"'+func AFNC.TEXTE([F:ATZ]NOLONG)+'"'
    Endif
   Endif
   [V]GERR=1 : Break
  Endif
#Fin 68641
  #67194
  Call LECTURE("HRTES",[M:HREXS0]CODEXP(nolign-1),"") From CONTOBJ
  If [F:HRTES]TYPVLT = 1
  Call INIPAYE( [M:HREXS0]DATEXS(nolign-1),[M:HREXS0]CODEXP(nolign-1)
&             , [M:HREXS0]CUR(nolign-1),[M:HREXS0]QTY(nolign-1),[M:HREXS0]PAYCUR(nolign-1)
&           ) From SUBHREXS
  Endif
  #fin 67194
 Next
 [V]GIMPORT =0
 [V]GSILENCE=0
 If [V]GERR
  If [V]GMESSAGE="" : [V]GMESSAGE=right$([V]GMESSIMP,2) : Endif
  Goto DELOCK
 Endif

 If ![L]TRANS : Trbegin [HREXS] : Endif
  For nolign=1 To [M:HREXS0]NBLIG
   [F:HREXS]=[M:HREXS0]
   #Call CCEFIC("EXS","EXS0",nolign-1) From SUBCDEB
   Call CCEFIC("HREXS","HREXS0",nolign-1)From SUBHREXS
   [L]LASLIG       +=1
   [F:HREXS]LIN       =[L]LASLIG
   If ACTION <> "CAL"
   [F:HREXS]UID       =uniqid([HRTES])
   Endif
   [F:HREXS]CREDAT    =date$
   [F:HREXS]CRETIM    =time
   [F:HREXS]CREUSR    =[V]GUSER
   [L]UID(nolign-1) =[F:HREXS]UID
   If [L]ACTION="CAL"
    N=nolign-1
    Gosub TRANSLIG
   Elsif [L]LASLIG=1
    Rewrite [HREXS]
   Else
    Write [HREXS]
   Endif
  Next

  If [L]ACTION="CREATE" : Gosub NOLIG : Endif
 If ![L]TRANS : Commit : Endif

 If [L]ACTION="CREATE"
  Link [HREXS] With [HRTES]HRTES0=GCURLEG;CODEXP As [LNK]
  For [LNK]HREXS0 Where EXSNUM=[L]EXSNUM & find(UID,[L]UID)
   N=find([F:HREXS]UID,[L]UID)-1
   Gosub TRANSLIG
  Next
 Endif

When "MODIFY"
 Gosub INI_IMPORT
 Gosub LIENS0 From SUBHREXS
 For [HREXS]HREXS0 Where EXSNUM=[L]EXSNUM & find(UID,[L]UID)
  nolign  =find([F:HREXS]UID,[L]UID)
  [M:HREXS0]=[F:HREXS]
  Gosub LIENS From SUBHREXS
  [M:HREXS0]NBLIG+=1
 Next
 Gosub LIENS2 From SUBHREXS

 mkstat=0
 #[V]GIMPORT=1
 #[V]GSILENCE=1
 For nolign=1 To [M:HREXS0]NBLIG
  indice=nolign-1
  status=75
  Call SAI_NBLIG("","WEB_CREATE","PORNDF") From W0HREXS0
#  If mkstat : [V]GERR=1 : Break : Endif
#68641
  If mkstat
   If GMESSAGE = ""
    If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
    Read [ATZ]CODZONE = "HREXPENSES";GZONE
    If !fstat
     GMESSAGE = mess(32,126,1)-'"'+func AFNC.TEXTE([F:ATZ]NOLONG)+'"'
    Endif
   Endif
   [V]GERR=1 : Break
  Endif
#Fin 68641
  # on teste les attachements
  If ADDPJ(nolign-1)=1 and func SUBHREXS.ISATTACH([F:HREXS]REFNUM,[L]EXSNUM,[M:HREXS0]UID(nolign-1))
     #SBA ATTACH
     W_UID(0)=num$([M:HREXS0]UID(nolign-1))
     Call DELETE_AOX_ATTACH("HREXS",[F:HREXS]REFNUM,num$([F:HREXS]EXSNUM),W_UID,1)From PRHPORATT
  Endif


  #67194
  Call LECTURE("HRTES",[M:HREXS0]CODEXP(nolign-1),"") From CONTOBJ
  If [F:HRTES]TYPVLT = 1
  Call INIPAYE( [M:HREXS0]DATEXS(nolign-1),[M:HREXS0]CODEXP(nolign-1)
&             , [M:HREXS0]CUR(nolign-1),[M:HREXS0]QTY(nolign-1),[M:HREXS0]PAYCUR(nolign-1)
&           ) From SUBHREXS
  Endif
  #fin 67194

 Next
 [V]GIMPORT=0
 [V]GSILENCE=0
 If [V]GERR
  If [V]GMESSAGE="" : [V]GMESSAGE=right$([V]GMESSIMP,2) : Endif
  Goto DELOCK
 Endif

 If ![L]TRANS : Trbegin [HREXS] : Endif
  For [HREXS]HREXS0 Where EXSNUM=[L]EXSNUM & find(UID,[M:HREXS0]UID)
   nolign =find([F:HREXS]UID,[M:HREXS0]UID)
   [F:HREXS]=[M:HREXS0]
   #SBA û  faire
   #Call CCEFIC("EXS","EXS0",nolign-1) From SUBCDEB
   Call CCEFIC("HREXS","HREXS0",nolign-1) From SUBHREXS
   Rewrite [HREXS] Curr
  Next

  Gosub NOLIG
 If ![L]TRANS : Commit : Endif

 Link [HREXS] With [HRTES]HRTES0=GCURLEG;CODEXP As [LNK]
 For [LNK]HREXS0 Where EXSNUM=[L]EXSNUM & find(UID,[L]UID)
  N=find([F:HREXS]UID,[L]UID)-1
  Gosub TRANSLIG
 Next

When "DELETE"
 If ![L]TRANS : Trbegin [HREXS] : Endif
  N=0
  For [HREXS]HREXS0 Where EXSNUM=[L]EXSNUM
   If find([F:HREXS]UID,[L]UID)
    # SBA PJ Delete PJ here
    If func SUBHREXS.ISATTACH([F:HREXS]REFNUM,[L]EXSNUM,[F:HREXS]UID)
      #SBA ATTACH
      W_UID(0)=num$([F:HREXS]UID)
      Call DELETE_AOX_ATTACH("HREXS",[F:HREXS]REFNUM,num$([F:HREXS]EXSNUM),W_UID,1)From PRHPORATT
    Endif
    Delete [HREXS] Curr
   Else
    N+=1
    If [F:HREXS]LIN<>N : [F:HREXS]LIN=N : Rewrite [HREXS] Curr : Endif
   Endif
  Next
  If !N
   [F:HREXS2]=[F:HREXS]
   Raz [F:HREXS]
   [F:HREXS]EXSNUM=[F:HREXS2]EXSNUM
   [F:HREXS]REFNUM=[F:HREXS2]REFNUM
   [F:HREXS]CTRNUM=[F:HREXS2]CTRNUM
   [F:HREXS]STRDAT=[F:HREXS2]STRDAT : #68641
   [F:HREXS]ENDDAT=[F:HREXS2]ENDDAT : #68641
   [F:HREXS]EXSSTA=1
   [F:HREXS]TIT   =[F:HREXS2]TIT
   [F:HREXS]CMT   =[F:HREXS2]CMT
   [F:HREXS]CREDAT=[F:HREXS2]CREDAT
   [F:HREXS]CRETIM=[F:HREXS2]CRETIM
   [F:HREXS]CREUSR=[F:HREXS2]CREUSR
   Rewrite [HREXS]
  Endif
 If ![L]TRANS : Commit : Endif

When "READ"
 Link [HREXS] With [HRTES]HRTES0=GCURLEG;CODEXP As [LNK]
 If [L]UID(0) : Filter [LNK] Where find(UID,[L]UID) : Endif
 For [LNK]HREXS0 Where EXSNUM=[L]EXSNUM
  If N>=dim([L]UID)
   [V]GERR=1
  Else
   Gosub TRANSLIG
  Endif
  N+=1
 Next
 Filter [LNK]
 If [V]GERR=1
  [V]GMESSAGE="SETLIGFRAIS :"-func AFNC.MES1(mess(80,10701,1),num$(N))
  #           Dimension des variables infûˋrieure û  $1$
 Endif
Endcase

Goto DELOCK
#-------------------------------------------------------------------------------
#
# Initilisation masque WI0 pour simuler l'import
#

$INI_IMPORT
Gosub OUVRE From SUBHREXS
Local Mask HREXS0 [HREXS0], HREXS0 [WI0]
Raz [M:HREXS0], [M:WI0]
Local Integer INDEX
Local Char WTMP

[M:HREXS0]EXSNUM=[F:HREXS]EXSNUM
[M:HREXS0]CTRNUM=[F:HREXS]CTRNUM
[M:HREXS0]REFNUM=[F:HREXS]REFNUM
[M:HREXS0]EXSSTA=[F:HREXS]EXSSTA
[M:HREXS0]STRDAT=[F:HREXS]STRDAT
[M:HREXS0]ENDDAT=[F:HREXS]ENDDAT
[M:HREXS0]TIT   =[F:HREXS]TIT
[M:HREXS0]CMT   =[F:HREXS]CMT
While N<dim([L]UID) & ([L]CODEXP(N)>"" | [L]UID(N)>0)
 [M:WI0]UID   (N)=[L]UID   (N)
 [M:WI0]DATEXS(N)=[L]DATEXS(N)
 [M:WI0]CODEXP(N)=[L]CODEXP(N)
 [M:WI0]CUR   (N)=[L]CUR   (N)
 [M:WI0]VAT   (N)=[L]VAT   (N)
# SEGAY 23/03/12 81016 init VAT for DEFVAL

#SBA comment connaitre la tva par dûˋfaut

# If [M:WI0]VAT ="" Then
#   If !clalev([F:ADI])  : Local File ATABDIV [ADI] : Endif
#   Filter [ADI] Where NUMTAB=552 & DEFVAL=2
#   Read [ADI] First
#   Filter [ADI]
#   If !fstat
#    [M:WI0]VAT=[F:ADI]CODE
#   Endif
# Endif
# END 81016 init VAT for DEFVAL
 [M:WI0]QTY   (N)=[L]QTY   (N)
 [M:WI0]PAYCUR(N)=[L]PAYCUR(N)
 [M:WI0]VATCUR(N)=[L]VATCUR(N)
 [M:WI0]RFUCUR(N)=[L]RFUCUR(N)
 [M:WI0]CPY   (N)=[L]CPY   (N)
 [M:WI0]BPCNUM(N)=[L]BPCNUM(N)
 [M:WI0]SOHNUM(N)=[L]SOHNUM(N)
 [M:WI0]SOHLIG(N)=[L]SOHLIG(N)
 [M:WI0]INVFLG(N)=[L]INVFLG(N)
 [M:WI0]DES   (N)=[L]DES   (N)
# on translate CCE
 For S=1 To 20
  WTMP=evalue("[L]CCE"+num$(S)+"(N)")
  INDEX=instr(1,WTMP,"|")
  If INDEX
    [M:HREXS0]DIETYP(S-1)=left$(WTMP,INDEX-1)
    Assign "[M:WI0]CCE"+num$(S)+"(N)" With right$(WTMP,INDEX+1)
  Endif
 Next
 N+=1
Wend
[M:WI0]NBLIG=N
Default Mask [HREXS0]
Return



$INI_IMPORT_OLD
Gosub OUVRE From SUBHREXS
Local Mask HREXS0 [HREXS0], HREXS0 [WI0]
Raz [M:HREXS0], [M:WI0]


[M:HREXS0]EXSNUM=[F:HREXS]EXSNUM
[M:HREXS0]CTRNUM=[F:HREXS]CTRNUM
[M:HREXS0]REFNUM=[F:HREXS]REFNUM
[M:HREXS0]EXSSTA=[F:HREXS]EXSSTA
[M:HREXS0]STRDAT=[F:HREXS]STRDAT
[M:HREXS0]ENDDAT=[F:HREXS]ENDDAT
[M:HREXS0]TIT   =[F:HREXS]TIT
[M:HREXS0]CMT   =[F:HREXS]CMT
While N<dim([L]UID) & ([L]CODEXP(N)>"" | [L]UID(N)>0)
 [M:WI0]UID   (N)=[L]UID   (N)
 [M:WI0]DATEXS(N)=[L]DATEXS(N)
 [M:WI0]CODEXP(N)=[L]CODEXP(N)
 [M:WI0]CUR   (N)=[L]CUR   (N)
 [M:WI0]VAT   (N)=[L]VAT   (N)
# SEGAY 23/03/12 81016 init VAT for DEFVAL
 If [M:WI0]VAT ="" Then
   If !clalev([F:ADI])  : Local File ATABDIV [ADI] : Endif
   Filter [ADI] Where NUMTAB=10552 & DEFVAL=2
   Read [ADI] First
   Filter [ADI]
   If !fstat
    [M:WI0]VAT=[F:ADI]CODE
   Endif
 Endif
# END 81016 init VAT for DEFVAL
 [M:WI0]QTY   (N)=[L]QTY   (N)
 [M:WI0]PAYCUR(N)=[L]PAYCUR(N)
 [M:WI0]VATCUR(N)=[L]VATCUR(N)
 [M:WI0]RFUCUR(N)=[L]RFUCUR(N)
 [M:WI0]CPY   (N)=[L]CPY   (N)
 [M:WI0]BPCNUM(N)=[L]BPCNUM(N)
 [M:WI0]SOHNUM(N)=[L]SOHNUM(N)
 [M:WI0]SOHLIG(N)=[L]SOHLIG(N)
 [M:WI0]INVFLG(N)=[L]INVFLG(N)
 [M:WI0]DES   (N)=[L]DES   (N)
 For S=1 To [V]GOPTCANA
  Assign "[M:WI0]CCE"+num$(S)+"(N)" With evalue("[L]CCE"+num$(S)+"(N)")
 Next
 N+=1
Wend
[M:WI0]NBLIG=N
Default Mask [HREXS0]
Return

#-------------------------------------------------------------------------------
#
# Simulation de l'import
#

$WEB_CREATE
Case evalue("type([M:WI0]"+[L]IMPZON+")")
When 1,2,4,5,6,7,8,9
 If evalue("[M:WI0]"+[L]IMPZON+"(nolign-1)")>0 : [L]IMPMOD=1 : Endif
When 3
 If evalue("[M:WI0]"+[L]IMPZON+"(nolign-1)")>[0/0/0] : [L]IMPMOD=1 : Endif
When Default
 If evalue("[M:WI0]"+[L]IMPZON+"(nolign-1)")>"" | [L]IMPZON="DES" : [L]IMPMOD=1 : Endif
Endcase
If [L]IMPMOD
 Assign "[M:HREXS0]"+[L]IMPZON+"(nolign-1)" With evalue("[M:WI0]"+[L]IMPZON+"(nolign-1)")
Endif
Return

#-------------------------------------------------------------------------------
#
# On renvoie les lignes reûÏues avec les valeurs corrigûˋes ou complûˋtûˋes
#

$TRANSLIG_OLD
[L]UID   (N)=[F:HREXS]UID
[L]DATEXS(N)=[F:HREXS]DATEXS
[L]CODEXP(N)=[F:HREXS]CODEXP
[L]CUR   (N)=[F:HREXS]CUR
[L]VAT   (N)=[F:HREXS]VAT
[L]QTY   (N)=[F:HREXS]QTY
If [F:HRTES]DEB=2 : [L]SNS(N)=-1 : Else [L]SNS(N)=1 : Endif
[L]PAYCUR(N)=[F:HREXS]PAYCUR
[L]VATCUR(N)=[F:HREXS]VATCUR
[L]RFUCUR(N)=[F:HREXS]RFUCUR
[L]CPY   (N)=[F:HREXS]CPY
[L]BPCNUM(N)=[F:HREXS]BPCNUM
[L]SOHNUM(N)=[F:HREXS]SOHNUM
[L]SOHLIG(N)=[F:HREXS]SOHLIG
[L]INVFLG(N)=[F:HREXS]INVFLG
For S=1 To [V]GOPTCANA : Assign "[L]CCE"+num$(S)+"(N)" With [F:HREXS]CCE(S-1) : Next
[L]DES   (N)=[F:HREXS]DES
[L]STA   (N)=[F:HREXS]STA

[L]TOTRFU+=[L]SNS(N)*[F:HREXS]RFUSHR
[L]TOTPAY+=[L]SNS(N)*[F:HREXS]PAYSHR
If [F:HREXS]STA=2 : [L]TOTSTA+=[L]SNS(N)*[F:HREXS]RFUSHR : Endif

[L]EXPDES(N)=[F:HRTES]CODEXP : #DAHOF ???? changed DESEXP to CODEXP
If [F:AXX]CODFIC<>"ATABDIV" | [F:AXX]ZONE<>"LNGDES" | [F:AXX]LANGUE<>[V]GLANGUE
&| [F:AXX]IDENT1<>"10552" | [F:AXX]IDENT2<>[F:HREXS]VAT
 Read [AXX]AXX0="ATABDIV";"LNGDES";[V]GLANGUE;"10552";[F:HREXS]VAT
 [L]VATDES(N)=[F:AXX]TEXTE
Endif
If [F:TCU]CUR<>[F:HREXS]CUR : Read [TCU]TCU0=[F:HREXS]CUR : Endif
[L]CURDES(N)=[F:TCU]CURDES
If [F:CPY]CPY<>[F:HREXS]CPY : Read [CPY]CPY0=[F:HREXS]CPY : Endif
[L]CPYNAM(N)=[F:CPY]CPYNAM
If [F:CPY]FDRX3>""
 Gosub REFAC
Endif
For S=1 To [V]GOPTCANA
 If [F:HREXS]CCE(S-1)>""
  If [F:HREXS]CCE(S-1)<>[F:CCE]CCE | S<>[F:CCE]AXI
   Read [CCE]CCE0=S;[F:HREXS]CCE(S-1)
  Endif
  Assign "[L]CCE"+num$(S)+"DES(N)" With [F:CCE]DES
 Endif
Next
Return

$TRANSLIG
[L]UID   (N)=[F:HREXS]UID
[L]DATEXS(N)=[F:HREXS]DATEXS
[L]CODEXP(N)=[F:HREXS]CODEXP
[L]CUR   (N)=[F:HREXS]CUR
[L]VAT   (N)=[F:HREXS]VAT
[L]QTY   (N)=[F:HREXS]QTY
If [F:HRTES]DEB=2 : [L]SNS(N)=-1 : Else [L]SNS(N)=1 : Endif
[L]PAYCUR(N)=[F:HREXS]PAYCUR
[L]VATCUR(N)=[F:HREXS]VATCUR
[L]RFUCUR(N)=[F:HREXS]RFUCUR
[L]CPY   (N)=[F:HREXS]CPY
[L]BPCNUM(N)=[F:HREXS]BPCNUM
[L]SOHNUM(N)=[F:HREXS]SOHNUM
[L]SOHLIG(N)=[F:HREXS]SOHLIG
[L]INVFLG(N)=[F:HREXS]INVFLG
[L]DES   (N)=[F:HREXS]DES
[L]STA   (N)=[F:HREXS]STA

[L]TOTRFU+=[L]SNS(N)*[F:HREXS]RFUSHR
[L]TOTPAY+=[L]SNS(N)*[F:HREXS]PAYSHR
If [F:HREXS]STA=2 : [L]TOTSTA+=[L]SNS(N)*[F:HREXS]RFUSHR : Endif

[L]EXPDES(N)=[F:HRTES]CODEXP : #DAHOF ???? changed DESEXP to CODEXP

#Read [F:AXX_]AXX0="TABVAT";"DESAXX";GLANGUE;[L]VAT(N);GDOSLEG
#If fstat
#  Read [F:AXX_]AXX0="TABVAT";"DESAXX";GLANGUE;[L]VAT(N);""
#Endif
#If fstat or [F:AXX_]TEXTE=""
#  [L]VATDES(N)=[L]VAT(N)
#Else
#  [L]VATDES(N)=[F:AXX_]TEXTE
#Endif

If [F:TCU]CUR<>[F:HREXS]CUR : Read [TCU]TCU0=[F:HREXS]CUR : Endif
[L]CURDES(N)=[F:TCU]CURDES
If [F:CPY]CPY<>[F:HREXS]CPY : Read [CPY]CPY0=[F:HREXS]CPY : Endif
[L]CPYNAM(N)=[F:CPY]CPYNAM
If [F:CPY]FDRX3>""
 Gosub REFAC
Endif

# analitique
# on parcoure,
Local Char RES(100)
Local Integer DIMANA
DIMANA=min(20,dim([F:HREXS]DIE))
For S=1 To DIMANA
    If([F:HREXS]DIE(S-1)<>"")
      Assign "CCE"+num$(S)+"(N)" With [F:HREXS]DIE(S-1)+"|"+[F:HREXS]CCE(S-1)
      [L]RES= [F:HREXS]CCE(S-1)
      Read [F:AXX_]AXX0="CACCE";"DESTRA";GLANGUE;[F:HREXS]DIE(S-1);[F:HREXS]CCE(S-1)
      If !fstat and [F:AXX_]TEXTE<>""
          [L]RES=  [F:AXX_]TEXTE
      Endif
      Assign "CCE"+num$(S)+"DES(N)" With [L]RES
    Endif
Next

# SBA = Ajout PJ
If [L]UID   (N)=0
  [L]ADDPJ(N)=0
Else
  If[F:HREXS]EXSSTA <2
    [L]ADDPJ(N)=1
  Endif
  If func SUBHREXS.ISATTACH([F:HREXS]REFNUM,[F:HREXS]EXSNUM,[L]UID(N))
    [L]ADDPJ(N)=2
  Endif
  # calc to add 2 if pj
Endif
Return



#-------------------------------------------------------------------------------
$NOLIG
N=0
Filter [HREXS] Order By Key CLE=DATEXS;CODEXP;LIN
For [HREXS]CLE Where EXSNUM=[L]EXSNUM
 N+=1
 If [F:HREXS]LIN<>N
  If N<[F:HREXS]LIN : Update [HREXS2] Where EXSNUM=[L]EXSNUM & LIN>=N With LIN+=1 : Endif
  [F:HREXS]LIN=N
  Rewrite [HREXS]
 Endif
Next
Filter [HREXS]
Return

#-------------------------------------------------------------------------------
$REFAC
Onerrgo RETOUR
If [F:HREXS]BPCNUM>""
 If !clalev([F:BPC]) : Local File =[F:CPY]FDRX3+".BPCUSTOMER" [BPC] : Endif
 If [F:BPC]BPCNUM<>[F:HREXS]BPCNUM : Read [BPC]BPC0=[F:HREXS]BPCNUM : Endif
 [L]BPCNAM(N)=[F:BPC]BPCNAM
Endif
If [F:HREXS]SOHNUM>""
 If !clalev([F:SOH]) : Local File =[F:CPY]FDRX3+".SORDER" [SOH] : Endif
 If [F:SOH]SOHNUM<>[F:HREXS]SOHNUM : Read [SOH]SOH0=[F:HREXS]SOHNUM : Endif
 [L]CUSORDREF(N)=[F:SOH]CUSORDREF
Endif
If [F:HREXS]SOHLIG>0
 If !clalev([F:SOP]) : Local File =[F:CPY]FDRX3+".SORDERP" [SOP] : Endif
 If [F:SOP]SOHNUM<>[F:HREXS]SOHNUM | [F:SOP]SOPLIN<>[F:HREXS]SOHLIG
  Read [SOP]SOP0=[F:HREXS]SOHNUM;[F:HREXS]SOHLIG
 Endif
 [L]ITMDES(N)=[F:SOP]ITMDES
Endif
Onerrgo
Return

#-------------------------------------------------------------------------------
$RETOUR
Return



################################################################################
#
# Renvoie tous les codes TVA
#
################################################################################
Subprog GETALLTVA(COD,LIB)
Variable Char COD()()
Variable Char LIB()()

If clalev([F:TVT_])=0   :  Local File =GTABCPT+"TABVAT" [TVT_] : Endif
If clalev([F:AXX_])=0  : Local File =GTABCPT+"ATEXTRA" [AXX_]  : Endif

Local Integer WI
Local Integer IND

 Link [F:TVT_] With [F:AXX_]AXX0="TABVAT";"DESAXX";GLANGUE;[F:TVT_]VAT;[F:TVT_]LEG
&               As [LNK_]

For [F:LNK_] Where (LEG=GCURLEG or LEG="") and VATTYP=1
  IND=find([F:TVT_]VAT,COD(0..WI))
  If (!IND)
      COD(WI)=[F:TVT_]VAT
      If [F:AXX_]TEXTE<>""
        LIB(WI)=[F:AXX_]TEXTE
      Else
        LIB(WI)=[F:TVT_]VAT
      Endif
     WI+=1
  Else
    If([F:TVT_]LEG=GCURLEG)
        If [F:AXX_]TEXTE<>""
          LIB(IND-1)=[F:AXX_]TEXTE
        Else
          LIB(IND-1)=COD(IND-1)
        Endif
    Endif
  Endif
Next

End


################################################################################
#
# Renvoie les informations de refacturation : client, facture, ligne facture
#
################################################################################

Subprog GETREFAC( SOCIETE,BPCNUM,BPCNAM,SOHNUM,SOPLIN,ORDDAT,PJT,CUSORDREF,ITMREF,ITMDES
&               , CCE1,CCE1DES,CCE2,CCE2DES,CCE3,CCE3DES,CCE4,CCE4DES,CCE5,CCE5DES,CCE6
&               , CCE6DES,CCE7,CCE7DES,CCE8,CCE8DES,CCE9,CCE9DES
&               )
Value    Char    SOCIETE()
Variable Char    BPCNUM()(0..), BPCNAM()(0..), SOHNUM()(0..)
Variable Integer SOPLIN(0..)
Variable Date    ORDDAT(0..)
Variable Char    PJT()(0..), CUSORDREF()(0..), ITMREF()(0..), ITMDES()(0..), CCE1()(0..)
Variable Char    CCE2()(0..), CCE3()(0..), CCE4()(0..), CCE5()(0..), CCE6()(0..)
Variable Char    CCE7()(0..), CCE8()(0..), CCE9()(0..)
Variable Char    CCE1DES()(0..), CCE2DES()(0..), CCE3DES()(0..), CCE4DES()(0..)
Variable Char    CCE5DES()(0..), CCE6DES()(0..), CCE7DES()(0..), CCE8DES()(0..)
Variable Char    CCE9DES()(0..)

If [L]SOCIETE="" : End : Endif

If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif

Local Integer N, I
Local Char    INISEC([V]GLONCDE), CCE([V]GLONCCE)

Read [CPY]CPY0=[L]SOCIETE
If fstat | [F:CPY]FDRX3="" : End : Endif
Onerrgo FDRERR
Local File =[F:CPY]FDRX3+".BPCUSTOMER" [BPC]
Local File =[F:CPY]FDRX3+".SORDER"     [SOH]
Local File =[F:CPY]FDRX3+".SORDERP"    [SOP]
#59546
If dim([F:SOP]CCE1)<=0
 Local File =[F:CPY]FDRX3+".CPTANALIN" [CAL]
Endif
# fin 59546
Onerrgo
If clalev([F:CCE])=0
 If dim([V]GTABCPT)>0 & [V]GTABCPT>"" & find("CCE",[V]GABRCPT(1..[V]GNBTABCPT))
  Local File =[V]GTABCPT+"CACCE" [CCE]
 Else
  Local File CACCE [CCE]
 Endif
Endif

If [L]BPCNUM=""
 For [BPC]BPC0 Where BPCSTA=2
  If pat([F:BPC]BPCNAM,"*"+[L]BPCNAM+"*")
   If N>=dim([L]BPCNUM)
    [V]GERR=1
   Else
    [L]BPCNUM(N)=[F:BPC]BPCNUM
    [L]BPCNAM(N)=[F:BPC]BPCNAM
   Endif
   N+=1
  Endif
 Next

Elsif [L]SOHNUM=""
 Link [SOP] With [SOH]SOH0=SOHNUM As [LNK] Order By Key CLE=SOHNUM;SOPLIN
 For [LNK]CLE Where [SOH]ORDSTA<2 & SOQSTA<3 & BPCORD=[L]BPCNUM
  If N>=dim([L]SOHNUM)
   [V]GERR=1
  Else
   [L]SOHNUM   (N)=[F:SOP]SOHNUM
   [L]SOPLIN   (N)=[F:SOP]SOPLIN
   [L]ORDDAT   (N)=[F:SOH]ORDDAT
   [L]PJT      (N)=[F:SOH]PJT
   [L]CUSORDREF(N)=[F:SOH]CUSORDREF
   [L]ITMREF   (N)=[F:SOP]ITMREF
   [L]ITMDES   (N)=[F:SOP]ITMDES
  Endif
  N+=1
 Next

Else
 #**92876 :  We'll need a new solution in V7. For the moment we fix it easier.
 #Call PARAM("","SECCDE",[L]INISEC) From ADOVAL
 [L]INISEC=string$(GOPTCANA,"0")
 #**
 For [SOP] Where SOHNUM=[L]SOHNUM
  If N>=dim([L]SOPLIN)
   [V]GERR=1
  Else
   [L]SOPLIN(N)=[F:SOP]SOPLIN
   [L]ITMREF(N)=[F:SOP]ITMREF
   [L]ITMDES(N)=[F:SOP]ITMDES
   If dim([F:SOP]CCE1)<=0
    Read [CAL]CAL0="SOP";0;[F:SOP]SOHNUM;[F:SOP]SOPLIN;[F:SOP]SOPSEQ;"";1
   Endif
   For I=1 To [V]GOPTCANA
    If mid$([L]INISEC,I,1)="1"
     If dim([F:SOP]CCE1)>0
      [L]CCE=evalue("[F:SOP]CCE"+num$(I))
     Else
      [L]CCE=evalue("[F:CAL]CCE("+num$(I-1)+")")
     Endif
     If [L]CCE>""
      Assign "[L]CCE"+num$(I)+"(N)" With [L]CCE
      If [L]CCE<>[F:CCE]CCE | I<>[F:CCE]AXI : Read [CCE]CCE0=I;[L]CCE : Endif
      Assign "[L]CCE"+num$(I)+"DES(N)" With [F:CCE]DES
     Endif
    Endif
   Next
  Endif
  N+=1
 Next
Endif

If [V]GERR
 [V]GMESSAGE="GETREFAC :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

End
#-------------------------------------------------------------------------------

################################################################################
#
# Renvoie les informations de refacturation : clients
#
# paramû´tres :
#  - sociûˋtûˋ (obligatoire)
#  - code client (facutatif)  => code exact ou code partiel attendu
#  - nom client  (facultatif) => valeur partielle attendue
#
################################################################################

Subprog GETBPCREFAC(SOCIETE,BPRN,NAME,MAXREC,FIRSTREC,
&                   BPCNUM,BPCNAM,NBRESULT)
Value    Char    SOCIETE(), BPRN() , NAME()
Value    Integer MAXREC
Value    Integer FIRSTREC
Variable Char    BPCNUM()(0..), BPCNAM()(0..)
Variable Integer NBRESULT

If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif

Gosub LOAD_PARAMRES
WMAXREC=MAXREC
WSTART=FIRSTREC

Local Integer N,WTOT

Read [CPY]CPY0=[L]SOCIETE
NBRESULT=0
If fstat | [F:CPY]FDRX3="" | !func AFNC.ACTIV("SRV") : End : Endif

Onerrgo FDRERR
Local File =[F:CPY]FDRX3+".BPCUSTOMER" [BPC]
Onerrgo

If BPRN <> ""
 Read [BPC]BPC0 = BPRN
 [L]BPCNUM(0) = [F:BPC]BPCNUM
 [L]BPCNAM(0) = [F:BPC]BPCNAM
Endif

If (BPRN <> "" & fstat) | BPRN = ""
 Filter [BPC] Where BPCSTA=2
 WTOTALCOUNT = rowcount([BPC])
 If WTOTALCOUNT >= WSTART
   For [BPC]BPC0
    If pat(toupper([F:BPC]BPCNUM),"*"+BPRN+"*") or pat(toupper([F:BPC]BPCNAM),"*"+NAME+"*")
     If N<dim([L]BPCNUM)
      [L]BPCNUM(N)=[F:BPC]BPCNUM
      [L]BPCNAM(N)=[F:BPC]BPCNAM
      If [L]BPCNAM(N)="" : [L]BPCNAM(N)=[L]BPCNUM(N) : Endif
      N+=1
     Endif
     WTOT+=1
    Endif
   Next
 Endif
 NBRESULT=WTOT
 If NBRESULT > 0 Then
  Sorta N BPCNUM,BPCNAM Order By BPCNAM(indice) Asc
 Endif
 Filter [BPC]
Endif

If [V]GERR
 [V]GMESSAGE="GETBPCREFAC :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

End
#-------------------------------------------------------------------------------

################################################################################
#
# Renvoie les informations de refacturation : commandes
#
# paramû´tres :
#  - sociûˋtûˋ (obligatoire)
#  - code commande (facultatif) => code exact ou partiel attendu
#  - code client (facutatif)  => code exact ou partiel attendu
#
################################################################################
Subprog GETSOHREFAC(SOCIETE,SOHNUM,BPCNUM,BPCNAM,ORDDAT,PJT,CUSORDREF
&               )
Value    Char    SOCIETE()
Variable Char    SOHNUM()(0..)
Variable Char    BPCNUM()(0..) , BPCNAM()(0..)
Variable Date    ORDDAT(0..)
Variable Char    PJT()(0..), CUSORDREF()(0..)

If [L]SOCIETE="" : End : Endif

If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif

Local Integer N, I
Local Char    BPR(GLONBPR) , SORD(GLONVCR)
Local Char    CRITERE(200)

BPRN = [L]BPCNUM
SORD = [L]SOHNUM
Raz [L]SOHNUM

Read [CPY]CPY0=[L]SOCIETE
If fstat | [F:CPY]FDRX3="" | !func AFNC.ACTIV("SRV") : End : Endif
Onerrgo FDRERR
Local File =[F:CPY]FDRX3+".BPCUSTOMER" [BPC]
Local File =[F:CPY]FDRX3+".SORDER"     [SOH]
Onerrgo

If SORD <> ""
 Read [SOH]SOH0 = SORD
 If !fstat
  [L]SOHNUM   (N) = [F:SOH]SOHNUM
  [L]BPCNUM   (N) = [F:SOH]BPCORD
  Read [BPC]BPC0  = [F:SOH]BPCORD
  [L]BPCNAM   (N) = [F:BPC]BPCNAM
  [L]ORDDAT   (N) = [F:SOH]ORDDAT
  [L]PJT      (N) = [F:SOH]PJT
  [L]CUSORDREF(N) = [F:SOH]CUSORDREF
 Endif
Endif

If [L]SOHNUM = ""

 CRITERE = "[SOH]ORDSTA = 1"
 If SORD <> ""
  CRITERE -='& pat([SOH]SOHNUM,"*'+SORD+'*")'
 Endif
 If BPRN<>""
  Read [BPC]BPC0  = BPRN
  If !fstat
   CRITERE -= "& [SOH]BPCORD = BPRN"
  Else
   CRITERE -='& pat([SOH]BPCORD,"*'+BPRN+'*")'
  Endif
 Endif

 For [SOH]SOH1 Where evalue(CRITERE)
  If N>=dim([L]SOHNUM)
   [V]GERR=1
  Else
   [L]SOHNUM   (N) = [F:SOH]SOHNUM
   [L]BPCNUM   (N) = [F:SOH]BPCORD
   Read [BPC]BPC0  = [F:SOH]BPCORD
   [L]BPCNAM   (N) = [F:BPC]BPCNAM
   [L]ORDDAT   (N) = [F:SOH]ORDDAT
   [L]PJT      (N) = [F:SOH]PJT
   [L]CUSORDREF(N) = [F:SOH]CUSORDREF
  Endif
  N+=1
 Next
Endif

If [V]GERR
 [V]GMESSAGE="GETSOHREFAC :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

End
#-------------------------------------------------------------------------------

################################################################################
#
# Renvoie les informations de refacturation : ligne facture
#
# paramû´tres :
#  - sociûˋtûˋ (obligatoire)
#  - code commande (facultatif) => code exact ou partiel attendu
#  - Nô¯ lig commande (facultatif) => code exact ou partiel attendu
#  - code client (facutatif)  => code exact ou partiel attendu
#
################################################################################

Subprog GETSOPREFAC( SOCIETE,SOHNUM,SOPLIN,BPCNUM,BPCNAM,ORDDAT,PJT,CUSORDREF,ITMREF,ITMDES
&               , CCE1,CCE1DES,CCE2,CCE2DES,CCE3,CCE3DES,CCE4,CCE4DES,CCE5,CCE5DES,CCE6
&               , CCE6DES,CCE7,CCE7DES,CCE8,CCE8DES,CCE9,CCE9DES
&               )
Value    Char    SOCIETE()
Variable Char    SOHNUM()(0..)
Variable Integer SOPLIN(0..)
Variable Char    BPCNUM()(0..) , BPCNAM()(0..)
Variable Date    ORDDAT(0..)
Variable Char    PJT()(0..), CUSORDREF()(0..), ITMREF()(0..), ITMDES()(0..), CCE1()(0..)
Variable Char    CCE2()(0..), CCE3()(0..), CCE4()(0..), CCE5()(0..), CCE6()(0..)
Variable Char    CCE7()(0..), CCE8()(0..), CCE9()(0..)
Variable Char    CCE1DES()(0..), CCE2DES()(0..), CCE3DES()(0..), CCE4DES()(0..)
Variable Char    CCE5DES()(0..), CCE6DES()(0..), CCE7DES()(0..), CCE8DES()(0..)
Variable Char    CCE9DES()(0..)

If [L]SOCIETE="" : End : Endif

If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif

Local Integer N, I
Local Char    INISEC([V]GLONCDE), CCE([V]GLONCCE)
Local Char    BPR(GLONBPR) , SORD(GLONVCR)
Local Integer SOPL
Local Char    CRITERE(200)

BPRN = [L]BPCNUM
SORD = [L]SOHNUM
SOPL = [L]SOPLIN
Raz [L]SOHNUM , [L]SOPLIN

Read [CPY]CPY0=[L]SOCIETE
If fstat | [F:CPY]FDRX3="" | !func AFNC.ACTIV("SRV") : End : Endif
Onerrgo FDRERR
Local File =[F:CPY]FDRX3+".BPCUSTOMER" [BPC]
Local File =[F:CPY]FDRX3+".SORDER"     [SOH]
Local File =[F:CPY]FDRX3+".SORDERP"    [SOP]
#59546
If dim([F:SOP]CCE1)<=0
 Local File =[F:CPY]FDRX3+".CPTANALIN" [CAL]
Endif
# fin 59546
Onerrgo
If clalev([F:CCE])=0
 If dim([V]GTABCPT)>0 & [V]GTABCPT>"" & find("CCE",[V]GABRCPT(1..[V]GNBTABCPT))
  Local File =[V]GTABCPT+"CACCE" [CCE]
 Else
  Local File CACCE [CCE]
 Endif
Endif


CRITERE = "([SOP]SOQSTA = 1 | [SOP]SOQSTA = 2)"
If SORD <> ""
 Read [SOH]SOH0  = SORD
 If !fstat
  CRITERE -= "& [SOP]SOHNUM = SORD"
 Else
  CRITERE -='& pat([SOP]SOHNUM,"*'+SORD+'*")'
 Endif
Endif

If SORD <> "" & SOPL <> 0
 Read  [SOP]SOP3 = SORD;SOPL
 If !fstat
  CRITERE -= "& [SOP]SOPLIN = SOPL"
 Else
  CRITERE -='& pat(num$([SOP]SOPLIN),"*'+SOPL+'*")'
 Endif
Elsif SOPL <> 0
 CRITERE -='& pat(num$([SOP]SOPLIN),"*'+SOPL+'*")'
Endif

If BPRN<>""
 Read [BPC]BPC0  = BPRN
 If !fstat
  CRITERE -= "& [SOP]BPCORD = BPRN"
 Else
  CRITERE -='& pat([SOP]BPCORD,"*'+BPRN+'*")'
 Endif
Endif

 #**92876 :  We'll need a new solution in V7. For the moment we fix it easier.
 #Call PARAM("","SECCDE",[L]INISEC) From ADOVAL
 [L]INISEC=string$(GOPTCANA,"0")
 #**

 For [SOP] Where evalue(CRITERE)
  If N>=dim([L]SOPLIN)
   [V]GERR=1
  Else

   [L]SOHNUM   (N) = [F:SOP]SOHNUM
   Read [SOH]SOH0 = [SOP]SOHNUM
   If !fstat
    [L]ORDDAT   (N) = [F:SOH]ORDDAT
    [L]PJT      (N) = [F:SOH]PJT
    [L]CUSORDREF(N) = [F:SOH]CUSORDREF
   Endif
   [L]BPCNUM   (N) = [F:SOP]BPCORD
   Read [BPC]BPC0  = [F:SOP]BPCORD
   [L]BPCNAM   (N) = [F:BPC]BPCNAM

   [L]SOPLIN(N)=[F:SOP]SOPLIN
   [L]ITMREF(N)=[F:SOP]ITMREF
   [L]ITMDES(N)=[F:SOP]ITMDES
   If dim([F:SOP]CCE1)<=0
    Read [CAL]CAL0="SOP";0;[F:SOP]SOHNUM;[F:SOP]SOPLIN;[F:SOP]SOPSEQ;"";1
   Endif
   For I=1 To [V]GOPTCANA
    If mid$([L]INISEC,I,1)="1"
     If dim([F:SOP]CCE1)>0
      [L]CCE=evalue("[F:SOP]CCE"+num$(I))
     Else
      [L]CCE=evalue("[F:CAL]CCE("+num$(I-1)+")")
     Endif
     If [L]CCE>""
      Assign "[L]CCE"+num$(I)+"(N)" With [L]CCE
      If [L]CCE<>[F:CCE]CCE | I<>[F:CCE]AXI : Read [CCE]CCE0=I;[L]CCE : Endif
      Assign "[L]CCE"+num$(I)+"DES(N)" With [F:CCE]DES
     Endif
    Endif
   Next
  Endif
  N+=1
 Next

If [V]GERR
 [V]GMESSAGE="GETSOHREFAC :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

End
#-------------------------------------------------------------------------------
$FDRERR
[V]GMESSAGE=func AFNC.MES1(mess(189,10703,1),[F:CPY]CPY)
#           Dossier X3 incorrect pour la comptabilitûˋ de la sociûˋtûˋ $1$
[V]GERR    =1
End

################################################################################
#
# Renvoie les sections analytiques d'un axe
#
################################################################################

Subprog GETLSTAXEANA(AXE,LIBAXE,CCE,DES)
Value    Integer AXE
Variable Char    LIBAXE(), CCE()(0..), DES()(0..)

Local Integer N

If !clalev([F:CCE])
 If dim([V]GTABCPT)>0 & [V]GTABCPT>"" & find("CCE",[V]GABRCPT(1..[V]GNBTABCPT))
  Local File =[V]GTABCPT+"CACCE" [CCE]
 Else
  Local File CACCE [CCE]
 Endif
Endif
If !clalev([F:ACC]) : Local File ACCES [ACC] : Endif

[L]LIBAXE=mess([L]AXE,601,1)

If[V]GUSRACS=2
 Default File [CCE]
Else
 Link [CCE] With [ACC]CODACC~=[V]GUSER;ACS As [LNK]
 Default File [LNK]
Endif

If dim([F:CCE]IPT)>0 : Filter [F] Where IPT=2 : Endif
For [F]CCE0 Where AXI=[L]AXE
 If N>=dim([L]CCE)
  [V]GERR=1
 Else
  [L]CCE(N)=[F:CCE]CCE
  [L]DES(N)=[F:CCE]DES
 Endif
 N+=1
Next
Filter [F]

If [V]GERR
 [V]GMESSAGE="GETLSTAXEANA :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

End

################################################################################
#
# Renvoie les codes frais
#
################################################################################

Subprog GETLSTFRAIS(MATRICULE,CODEXP,DESEXP,DESFLG,PLAFOND,FORFAIT,VAT,DEB)
Value Char MATRICULE
Variable Char    CODEXP()(0..), DESEXP()(0..)
Variable Integer DESFLG(0..)
Variable Decimal PLAFOND(0..), FORFAIT(0..)
Variable Char    VAT()(0..)
Variable Integer DEB(0..)   #: 65563

If GMODU(6) <> 2 : End : Endif : # 69157 module note de frais

Gosub AUTORIS
If [V]GERR : End : Endif

If !clalev([F:HRTES]) : Local File HRTABEXPENS [HRTES] : Endif
If !clalev([F:ID])    : Local File EMPLOID     [ID]    : Endif

Local Shortint N
Local Integer  T : #62198

[V]GERR=0
Read [ID]ID0=[L]MATRICULE
#For [TES]TES0 Where (VLYSTR=[0/0/0] | VLYSTR<=date$) & (VLYEND=[0/0/0] | VLYEND>=date$)

For [HRTES]HRTES0
 mkstat=0
 Call CONTEXE([F:HRTES]ACS) From CPTSUB
 If !mkstat
  If N>=dim([L]CODEXP)
   [V]GERR=1
  Else
   [L]CODEXP(N)=[F:HRTES]CODEXP
   [L]DESEXP(N)=[F:HRTES]CODEXP : #DAHOF ???? changed DESEXP to CODEXP
   [L]DESFLG(N)=[F:HRTES]DESFLG
   [L]VAT   (N)=[F:HRTES]VAT
   [L]DEB   (N)=[F:HRTES]DEB   : # 65563
   If [F:HRTES]VLTDEFPAR>""
    [L]FORFAIT(N)=func SUBHREXS.PARAM([F:HRTES]VLTDEFPAR,[F:ID]FCY,[F:ID]REFNUM,date$,T)
   Endif
   If [F:HRTES]VLTPFDPAR>""
    [L]PLAFOND(N)=func SUBHREXS.PARAM([F:HRTES]VLTPFDPAR,[F:ID]FCY,[F:ID]REFNUM,date$,T)
   Endif
  Endif
  N+=1
 Endif
Next
[V]GMESSAGE=""

If [V]GERR=1
 [V]GMESSAGE="GETLSTFRAIS :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

End


Subprog GETLSTFRAISV7_OLD(MATRICULE,CTRNUM,CODEXP,DESEXP,DESFLG,PLAFOND,FORFAIT,VAT,DEB,SAIAXE
&       ,DATCTR,SITCTR,AXECTR,TVACTR)
Value Char MATRICULE
Value Char CTRNUM
Variable Char    CODEXP()(0..), DESEXP()(0..)
Variable Integer DESFLG(0..)
Variable Decimal PLAFOND(0..), FORFAIT(0..)
Variable Char    VAT()(0..)
Variable Integer DEB(0..)   #: 65563
Variable Char  SAIAXE()(0..)
Variable Date DATCTR(0..)
Variable Char SITCTR()(0..)
Variable Char AXECTR()(0..)
Variable Char TVACTR()(0..)
If GMODU(6) <> 2 : End : Endif : # 69157 module note de frais

Gosub AUTORIS
If [V]GERR : End : Endif

If !clalev([F:HRTES]) : Local File HRTABEXPENS [HRTES]      : Endif
If !clalev([F:ID])    : Local File EMPLOID   [ID]           : Endif
If !clalev([F:CPR])   : Local File EMPLOCTRCPT   [CPR]      : Endif
If !clalev([F:HRCTR])   : Local File EMPLOCTR   [HRCTR]         : Endif
If !clalev([F:FGR])   : Local File FACGROUP   [FGR]         : Endif
If clalev([F:FCY])=0  : Local File FACILITY      [FCY]      : Endif
If clalev([F:CPY])=0  : Local File COMPANY       [CPY]      : Endif
If clalev([F:TVT])=0  :  Local File =GTABCPT+"TABVAT" [TVT] : Endif

#TVA : groupe de sociûˋtûˋ
#TES : Sociûˋtûˋ

Local Shortint N
Local Integer  T,WI : #62198
Local Char SEP(1)
[V]GERR=0
Read [ID]ID0=[L]MATRICULE
#For [TES]TES0 Where (VLYSTR=[0/0/0] | VLYSTR<=date$) & (VLYEND=[0/0/0] | VLYEND>=date$)
# Ajouter le controle sur droit sociûˋtûˋ SBA
Local Date JOUR : JOUR=date$
Local Integer WI
Local Char SEP(1)
Local Char OLD_SIT(10)
Local Char TABSOC(10)(0..100)
Local Date DATLIM
DATLIM=addmonth(date$,-12)

Filter [F:HRCTR] Where REFNUM=[L]MATRICULE and CTRNUM=[L]CTRNUM Order By CTRDAT Desc
For [F:HRCTR]
  Call LEC_FCY([F:HRCTR]ETRFCY) From CPTLEC
  If([F:HRCTR]ETRFCY<> OLD_SIT)
    OLD_SIT=[F:HRCTR]ETRFCY
    TABSOC(WI)=[F:FCY]LEGCPY
    DATCTR(WI)=[F:HRCTR]CTRDAT
    SITCTR(WI)=OLD_SIT
    SEP=""
    # on rûˋcupû´re les axes de la sociûˋtûˋ
    # û  faire je ne sais pas si on remonte jusqu'au modû´le comptable
    Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
    If !fstat
      For WJ=0 To dim([F:CPY]DIE)-1
        If([F:CPY]DIE(WJ)<>"")
          AXECTR(WI)+=SEP+[F:CPY]DIE(WJ)
          SEP=","
        Endif
      Next
    Endif
#    Read [F:CPR]CPR0=[F:CTR]REFNUM;[F:CTR]CTRNUM;[F:CTR]CTRDAT
#    If(!fstat)
#      For WJ=0 To dim([F:CPR]DIE)-1
#        If([F:CPR]DIE(WJ)<>"")
#          AXECTR(WI)+=SEP+[F:CPR]DIE(WJ)
#          SEP=","
#        Endif
#      Next
#    Endif

    SEP=""
    Local Integer ADD
    Local Char TFIND(10)(0..100)
    Local Integer WJ
    For [F:TVT] Where (LEG=GCURLEG or LEG="") and VATTYP=1
      If(!find([F:TVT]VAT,TFIND(0..WJ)))
        ADD=0
        If([F:TVT]GRP="")
          ADD=1
        Else
          Read [F:FGR]FGR0=[F:TVT]GRP;[F:HRCTR]ETRFCY
          If(!fstat)  :   ADD=1 : Endif
        Endif
        If ADD
          TVACTR(WI)+=SEP+[F:TVT]VAT
          SEP=","
          TFIND(WJ)=[F:TVT]VAT
          WJ+=1
        Endif
      Endif
    Next
    WI+=1
  Else
    DATCTR(WI)=[F:HRCTR]CTRDAT #on ajuste la date du contrat
  Endif
  If(DATLIM>[F:HRCTR]CTRDAT) : Break : Endif
# a modifier pour lien compta
Next


For [HRTES]HRTES0
  mkstat=0
  Call CONTEXE([F:HRTES]ACS) From CPTSUB
  If !mkstat
    If N>=dim([L]CODEXP)
      [V]GERR=1
    Else
      If [F:HRTES]GRP="" or find([F:HRTES]GRP,TABSOC(0..WI))
        #Ajouter le test sur le group ici uniquement sociûˋtûˋ
        [L]CODEXP(N)=[F:HRTES]CODEXP
        [L]DESEXP(N)=[F:HRTES]CODEXP : #DAHOF ???? changed DESEXP to CODEXP
        [L]DESFLG(N)=[F:HRTES]DESFLG
        [L]VAT   (N)=[F:HRTES]VAT
        [L]DEB   (N)=[F:HRTES]DEB   : # 65563
        If [F:HRTES]VLTDEFPAR>""
          [L]FORFAIT(N)=func SUBHREXS.PARAM([F:HRTES]VLTDEFPAR,[F:ID]FCY,[F:ID]REFNUM,date$,T)
        Endif
        If [F:HRTES]VLTPFDPAR>""
          [L]PLAFOND(N)=func SUBHREXS.PARAM([F:HRTES]VLTPFDPAR,[F:ID]FCY,[F:ID]REFNUM,date$,T)
        Endif

        SEP=""
        For WI=0 To dim([F:HRTES]CCEDAC)-1
          If([F:HRTES]CCEDAC(WI)=2)
            [L]SAIAXE(N)+=SEP+[F:HRTES]DIE(WI)
            SEP=","
          Endif
        Next WI
        N+=1
      Endif
    Endif
  Endif
Next
[V]GMESSAGE=""

If [V]GERR=1
 [V]GMESSAGE="GETLSTFRAIS :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

End

Subprog GETLSTFRAISV7(MATRICULE,CTRNUM,CODEXP,DESEXP,DESFLG,PLAFOND,FORFAIT,VAT,DEB,SAIAXE
&       ,DATCTR,SITCTR,AXECTR,TVACTR)
Value Char MATRICULE
Value Char CTRNUM
Variable Char    CODEXP()(0..), DESEXP()(0..)
Variable Integer DESFLG(0..)
Variable Decimal PLAFOND(0..), FORFAIT(0..)
Variable Char    VAT()(0..)
Variable Integer DEB(0..)   #: 65563
Variable Char  SAIAXE()(0..)
Variable Date DATCTR(0..)
Variable Char SITCTR()(0..)
Variable Char AXECTR()(0..)
Variable Char TVACTR()(0..)
If GMODU(6) <> 2 : End : Endif : # 69157 module note de frais

Gosub AUTORIS
If [V]GERR : End : Endif

If !clalev([F:HRTES]) : Local File HRTABEXPENS [HRTES]      : Endif
If !clalev([F:ID])    : Local File EMPLOID   [ID]           : Endif
If !clalev([F:CPR])   : Local File EMPLOCTRCPT   [CPR]      : Endif
If !clalev([F:HRCTR])   : Local File EMPLOCTR   [HRCTR]         : Endif
If !clalev([F:FGR])   : Local File FACGROUP   [FGR]         : Endif
If clalev([F:FCY])=0  : Local File FACILITY      [FCY]      : Endif
If clalev([F:CPY])=0  : Local File COMPANY       [CPY]      : Endif
If clalev([F:TVT])=0  :  Local File =GTABCPT+"TABVAT" [TVT] : Endif
#106559 US3505
If !clalev([F:GCM]): Local File =GTABCPT+"GACM"     [GCM]: Endif
If !clalev([F:LED]): Local File =GTABCPT+"GLED"     [LED]: Endif
If !clalev([F:GAC]): Local File =GTABCPT+"GACCOUNT" [GAC]: Endif
If !clalev([F:CAC]): Local File GACCCODE [CAC]: Endif
#END106559 US3505


#TVA : groupe de sociûˋtûˋ
#TES : Sociûˋtûˋ

Local Shortint N
Local Integer  T,WI : #62198
Local Char SEP(1)
[V]GERR=0
Read [ID]ID0=[L]MATRICULE
#For [TES]TES0 Where (VLYSTR=[0/0/0] | VLYSTR<=date$) & (VLYEND=[0/0/0] | VLYEND>=date$)
# Ajouter le controle sur droit sociûˋtûˋ SBA
Local Date JOUR : JOUR=date$
Local Integer WI
Local Char SEP(1)
Local Char OLD_SIT(10)
Local Char TABSOC(10)(0..100)
Local Char TABDIE(GLONDIE)(0..100,0..100) : #106559 US3505
Local Char TABDIEALL(GLONDIE)(0..100) : #106559 US3505

#Local Integer TABMAXDIE(0..100) : #106559 US3505
Local Integer WWJ,WIND,WALL : : WALL= 0 : #106559 US3505
Local Char TLED(GLONLED), ACC(GLONGAC) : #106559 US3505
Local Integer NLED, IND, AXI  #106559 US3505
Local Date DATLIM
DATLIM=addmonth(date$,-12)

Filter [F:HRCTR] Where REFNUM=[L]MATRICULE and CTRNUM=[L]CTRNUM Order By CTRDAT Desc
For [F:HRCTR]
  Call LEC_FCY([F:HRCTR]ETRFCY) From CPTLEC
  If([F:HRCTR]ETRFCY<> OLD_SIT)
    OLD_SIT=[F:HRCTR]ETRFCY
    TABSOC(WI)=[F:FCY]LEGCPY
    DATCTR(WI)=[F:HRCTR]CTRDAT
    SITCTR(WI)=OLD_SIT
    SEP=""
    # on rûˋcupû´re les axes de la sociûˋtûˋ
    # û  faire je ne sais pas si on remonte jusqu'au modû´le comptable
    Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
    If !fstat
      WWJ=0 : #106559 US3505
      For WJ=0 To dim([F:CPY]DIE)-1
        If([F:CPY]DIE(WJ)<>"") & !find([F:CPY]DIE(WJ),TABDIE(WI,0..WWJ))
#          AXECTR(WI)+=SEP+[F:CPY]DIE(WJ)
#          SEP=","
          #106559 US3505
          Call LEC_CPY(TABSOC(WI)) From CPTLEC

          Call LEC_GCM([F:CPY]ACM) From CPTLEC
          For [HRTES]HRTES0
            mkstat=0
            Call CONTEXE([F:HRTES]ACS) From CPTSUB
            If !mkstat
                If [F:HRTES]GRP="" or find([F:HRTES]GRP,TABSOC(WI))
                  For NLED=1 To 10
                    If [F:GCM]LED(NLED-1)="": Break: Endif
                    [L]TLED=[F:GCM]LED(NLED-1)
                    Call LEC_LED([L]TLED) From CPTLEC
                    Call LEC_CAC(11,[F:HRTES]ACCCOD,[F:LED]COA) From CPTLEC
                    If [F:CPY]DIE(WJ) <> ""
                       Call INDLED([L]TLED,[F:CPY]DIE(WJ),IND,AXI) From CPTDIV
                       If AXI
                         Call LECTURE("GAC",[F:CAC]ACC(0),[F:LED]COA) From CONTOBJ
                         If find([F:CPY]DIE(WJ),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
&                         & !find([F:CPY]DIE(WJ),TABDIE(WI,0..WWJ))
                            TABDIE(WI,WWJ)=[F:CPY]DIE(WJ)
                            If !find([F:CPY]DIE(WJ),TABDIEALL(0..WALL))
                              TABDIEALL(WALL)=[F:CPY]DIE(WJ)
                              WALL+=1
                            Endif
                            WWJ+=1
                            AXECTR(WI)+=SEP+[F:CPY]DIE(WJ)
                            SEP=","
                            Break
                         Endif
                       Endif
                    Endif
                  Next
                Endif
            Endif
          Next
        Endif
      Next
    Endif
#    Read [F:CPR]CPR0=[F:CTR]REFNUM;[F:CTR]CTRNUM;[F:CTR]CTRDAT
#    If(!fstat)
#      For WJ=0 To dim([F:CPR]DIE)-1
#        If([F:CPR]DIE(WJ)<>"")
#          AXECTR(WI)+=SEP+[F:CPR]DIE(WJ)
#          SEP=","
#        Endif
#      Next
#    Endif

    SEP=""
    Local Integer ADD
    Local Char TFIND(10)(0..100)
    Local Integer WJ
    For [F:TVT] Where (LEG=GCURLEG or LEG="") and VATTYP=1
      If(!find([F:TVT]VAT,TFIND(0..WJ)))
        ADD=0
        If([F:TVT]GRP="")
          ADD=1
        Else
          Read [F:FGR]FGR0=[F:TVT]GRP;[F:HRCTR]ETRFCY
          If(!fstat)  :   ADD=1 : Endif
        Endif
        If ADD
          TVACTR(WI)+=SEP+[F:TVT]VAT
          SEP=","
          TFIND(WJ)=[F:TVT]VAT
          WJ+=1
        Endif
      Endif
    Next
    WI+=1
  Else
    DATCTR(WI)=[F:HRCTR]CTRDAT #on ajuste la date du contrat
  Endif

  If(DATLIM>[F:HRCTR]CTRDAT) : Break : Endif
# a modifier pour lien compta
Next

For [HRTES]HRTES0
  mkstat=0
  Call CONTEXE([F:HRTES]ACS) From CPTSUB
  If !mkstat
    If N>=dim([L]CODEXP)
      [V]GERR=1
    Else
      If [F:HRTES]GRP="" or find([F:HRTES]GRP,TABSOC(0..WI))
        #Ajouter le test sur le group ici uniquement sociûˋtûˋ
        [L]CODEXP(N)=[F:HRTES]CODEXP
        [L]DESEXP(N)=[F:HRTES]CODEXP : #DAHOF ???? changed DESEXP to CODEXP
        [L]DESFLG(N)=[F:HRTES]DESFLG
        [L]VAT   (N)=[F:HRTES]VAT
        [L]DEB   (N)=[F:HRTES]DEB   : # 65563
        If [F:HRTES]VLTDEFPAR>""
          [L]FORFAIT(N)=func SUBHREXS.PARAM([F:HRTES]VLTDEFPAR,[F:ID]FCY,[F:ID]REFNUM,date$,T)
        Endif
        If [F:HRTES]VLTPFDPAR>""
          [L]PLAFOND(N)=func SUBHREXS.PARAM([F:HRTES]VLTPFDPAR,[F:ID]FCY,[F:ID]REFNUM,date$,T)
        Endif

        SEP=""
        WI=0
        While WI <= WALL-1
           WIND=find(TABDIEALL(WI), [F:HRTES]DIE(0..dim([F:HRTES]CCEDAC)-1))
           If !WIND | [F:HRTES]CCEDAC(WIND-1)=2
            [L]SAIAXE(N)+=SEP+TABDIEALL(WI)
            SEP=","
           Endif
           WI+=1
        Wend
      N+=1
      Endif
    Endif
  Endif
Next
[V]GMESSAGE=""

If [V]GERR=1
 [V]GMESSAGE="GETLSTFRAIS :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

End

################################################################################
#
# Renvoie les codes frais pour saisie graphique
#
################################################################################

Subprog GETGRAPHFRAIS(MATRICULE,PICTUR,GENERIC,XLOCAT,YLOCAT,RANGE,LNGDES,SHODES,CODEXP,QTY)
Value Char MATRICULE,PICTUR
Variable Char    GENERIC()(0..), CODEXP()(0..), LNGDES()(0..), SHODES()(0..)
Variable Integer XLOCAT(0..), YLOCAT(0..), RANGE(0..), QTY(0..)

If GMODU(6) <> 2 : End : Endif : # 69157 module note de frais

Local Integer    OK

Gosub AUTORIS
If [V]GERR : End : Endif

If !clalev([F:HRTES]) : Local File HRTABEXPENS [HRTES] : Endif
If !clalev([F:ADI]) : Local File ATABDIV   [ADI] : Endif
If !clalev([F:AD2]) : Local File ATABDIV   [AD2] : Endif

Local Shortint N

[V]GERR=0

Filter [F:ADI] Where NUMTAB = 10704 & A1 = [L]PICTUR   : # Codes frais banalisûˋs du portail

For [F:ADI]CODE
 If N >= dim([L]CODEXP)
   [V]GERR=1
 Else
  Read [F:AD2]CODE = 10705;[F:ADI]CODE                : # Correspondance codes banalisûˋs codes HRM
  If !fstat
   OK = 1

   If [F:AD2]A1 <> ""                               : # Code frais HRM non obligatoire, car certains
    Read [F:HRTES]HRTES0 = GCURLEG;[F:AD2]A1                    : # codes banalisûˋs ne servant qu'û  placer du texte
    If fstat : OK = 0 : Endif
    If OK & ([F:HRTES]VLYSTR > date$ | ([F:HRTES]VLYEND <> [0/0/0] & [F:HRTES]VLYEND < date$))
     OK = 0
    Endif
    If OK
     mkstat = 0
     Call CONTEXE([F:HRTES]ACS) From CPTSUB
     If mkstat : OK = 0 : Endif
    Endif
   Endif

   If OK
    GENERIC(N) = [F:ADI]CODE
    XLOCAT (N) = [F:ADI]N1
    YLOCAT (N) = [F:ADI]N2
    RANGE  (N) = [F:AD2]N1                          : # 1= gauche , 2=centre , 3=droite
    LNGDES (N) = func AFNC.TEXTRA('ATABDIV','LNGDES','10705',[F:AD2]CODE)
    SHODES (N) = func AFNC.TEXTRA('ATABDIV','SHODES','10705',[F:AD2]CODE)
    CODEXP (N) = [F:AD2]A1
    QTY    (N) = [F:AD2]N2
    N += 1
   Endif

  Endif
 Endif
Next

Filter [F:ADI]
[V]GMESSAGE=""

If [V]GERR=1
 [V]GMESSAGE="GETLSTFRAIS :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

End

################################################################################
#
# Renvoie les montants rûˋglûˋs de type note de frais
#
################################################################################

Subprog GETREGNOTEFRAIS(MATRICULE,DATDEB,CTRNUM,DAT,AMT,NBRVRC)
Value    Char    MATRICULE()
Value    Date    DATDEB
Variable Char    CTRNUM()(0..), NBRVRC()(0..)
Variable Date    DAT(0..)
Variable Decimal AMT(0..)

If GMODU(6) <> 2 : End : Endif : # 69157 module note de frais

Gosub AUTORIS
If [V]GERR : End : Endif

If !clalev([F:FRM]) : Local File FRMPAY [FRM] : Endif
If !clalev([F:STL]) : Local File STLPAY [STL] : Endif

Local Char FRS([V]GLONADI)

Link [STL] With [FRM]FRM0=NUMFRM As [LNK] Order By Key CLE=CTRNUM;[FRM]DAT
[L]FRS=func AFNC.PARAM("HREXSPAY","")

For [LNK] Where REFNUM=[L]MATRICULE & TYPPAY=[L]FRS & [FRM]DAT>=[L]DATDEB & [FRM]STA=3
 If N>=dim([L]CTRNUM)
  [V]GERR=1
 Else
  [L]CTRNUM(N)=[F:STL]CTRNUM
  [L]DAT   (N)=[F:FRM]DAT
  [L]AMT   (N)=[F:STL]AMT
  [L]NBRVRC(N)=[F:STL]NBRVRC
 Endif
 N+=1
Next

If [V]GERR=1
 [V]GMESSAGE="GETREGNOTEFRAIS :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

End

################################################################################
#
# Edition d'une note de frais
#
################################################################################
#**
#* Impression  note de frais
#*
#* @param MATRICULE : code matricule
#* @param EXSNUM    : numûˋro de note de frais
#* Paramû´tres sortant
#* @param ADDEMLPRT : Adresse mail d'impression
#*!
Subprog PRTFRAIS(MATRICULE,EXSNUM,ADDEMLPRT)
Value  Char    MATRICULE()
Value  Integer EXSNUM
Variable Char  ADDEMLPRT()
# SEGAY 28/03/12 81126
# Adresse mail pour ûˋdition portail
Local    Char    WWRKPRT(GLONAWA)

If GMODU(6) <> 2 : End : Endif : # 69157 module note de frais

Local Char     TBPAR(20)(1..50), TBVAL(20)(1..50)
Local Shortint K
Local Char     CODRPT (GLONARP)

If !clalev([F:HREXS]) : Local File HREXPENSES  [HREXS] : Endif

Gosub AUTORIS
If GERR : End : Endif

Filter [F:HREXS] Where EXSNUM = [L]EXSNUM
Read [F:HREXS] First
Filter [F:HREXS]
If  !fstat
     K=0
     CODRPT = "FICEXS"
     Raz [L]TBVAL, [L]TBPAR
     K+=1 : [L]TBPAR(K)="_FormatExport"  : [L]TBVAL(K)="29"
     K+=1 : [L]TBPAR(K)="__DESTINATION"  : [L]TBVAL(K)="3"
     K+=1 : [L]TBPAR(K)="_nolispar"      : [L]TBVAL(K)=""
     K+=1 : [L]TBPAR(K)="societe"        : [L]TBVAL(K)=[F:HREXS]CPY
     K+=1 : [L]TBPAR(K)="sitedeb"        : [L]TBVAL(K)=[F:HREXS]FCY
     K+=1 : [L]TBPAR(K)="sitefin"        : [L]TBVAL(K)=[F:HREXS]FCY
     K+=1 : [L]TBPAR(K)="service"        : [L]TBVAL(K)=""
     K+=1 : [L]TBPAR(K)="profil"         : [L]TBVAL(K)=""
     K+=1 : [L]TBPAR(K)="population"     : [L]TBVAL(K)=""
     K+=1 : [L]TBPAR(K)="matdeb"         : [L]TBVAL(K)= MATRICULE
     K+=1 : [L]TBPAR(K)="matfin"         : [L]TBVAL(K)= MATRICULE
     K+=1 : [L]TBPAR(K)="notedeb"        : [L]TBVAL(K)= num$(EXSNUM)
     K+=1 : [L]TBPAR(K)="notefin"        : [L]TBVAL(K)= num$(EXSNUM)
     K+=1 : [L]TBPAR(K)="datdeb"         : [L]TBVAL(K)= num$([F:HREXS]STRDAT)
     K+=1 : [L]TBPAR(K)="datfin"         : [L]TBVAL(K)= num$([F:HREXS]ENDDAT)
     K+=1 : [L]TBPAR(K)="coddeb"         : [L]TBVAL(K)=""
     K+=1 : [L]TBPAR(K)="codfin"         : [L]TBVAL(K)="zzzzzzzzzz"
     K+=1 : [L]TBPAR(K)="etat"           : [L]TBVAL(K)="3"           : # 63428
     K+=1 : [L]TBPAR(K)="page"           : [L]TBVAL(K)="1"
     K+=1 : [L]TBPAR(K)="impsel"         : [L]TBVAL(K)="2"

     Call PRTMSG(CODRPT,TBPAR,TBVAL) From PORSUP

     # SEGAY 28/03/12 81126
     WWRKPRT="HREXSPRINT"
     Call GETADDEMLPRT(WWRKPRT,ADDEMLPRT) From PORSUP

Endif

End
################################################################################
#
# Calcul des totaux des lignes
#
################################################################################
Subprog CALC_LIGFRAIS(ACTION,REFNUM,CTRNUM,EXSNUM,UID,DATEXS,CODEXP,EXPDES,CUR,CURDES,VAT,VATDES
&                  , QTY,SNS,PAYCUR,VATCUR,RFUCUR,CPY,CPYNAM,BPCNUM,BPCNAM,SOHNUM,CUSORDREF,SOHLIG
&                  , ITMDES,INVFLG,CCE1,CCE1DES,CCE2,CCE2DES,CCE3,CCE3DES,CCE4,CCE4DES
&                  , CCE5,CCE5DES,CCE6,CCE6DES,CCE7,CCE7DES,CCE8,CCE8DES,CCE9,CCE9DES
&                  , CCE10,CCE10DES,CCE11,CCE11DES,CCE12,CCE12DES,CCE13,CCE13DES,CCE14,CCE14DES
&                  , CCE15,CCE15DES,CCE16,CCE16DES,CCE17,CCE17DES,CCE18,CCE18DES,CCE19,CCE19DES
&                  , CCE20,CCE20DES,DES , STA,TOTPAY,TOTRFU,TOTSTA)

Variable Char    ACTION()(0..)
Variable Char    REFNUM(),CTRNUM()
Value    Integer EXSNUM
Variable Integer UID(0..), QTY(0..), SOHLIG(0..), INVFLG(0..), STA(0..), SNS(0..)
Variable Date    DATEXS(0..)
Variable Char    CODEXP()(0..), CUR()(0..), VAT()(0..), CPY()(0..), BPCNUM()(0..)
Variable Char    SOHNUM()(0..), CCE1()(0..), CCE2()(0..), CCE3()(0..), CCE4()(0..)
Variable Char    CCE5()(0..), CCE6()(0..), CCE7()(0..), CCE8()(0..), CCE9()(0..),CCE10()(0..)
Variable Char    CCE11()(0..), CCE12()(0..), CCE13()(0..), CCE14()(0..), CCE15()(0..)
Variable Char    CCE16()(0..), CCE17()(0..), CCE18()(0..), CCE19()(0..), CCE20()(0..)
Variable Char    DES()(0..), EXPDES()(0..), CURDES()(0..),VATDES()(0..), CPYNAM()(0..)
Variable Char    BPCNAM()(0..), CUSORDREF()(0..), ITMDES()(0..), CCE1DES()(0..)
Variable Char    CCE2DES()(0..), CCE3DES()(0..), CCE4DES()(0..), CCE5DES()(0..)
Variable Char    CCE6DES()(0..), CCE7DES()(0..), CCE8DES()(0..), CCE9DES()(0..),CCE10DES()(0..)
Variable Char    CCE11DES()(0..), CCE12DES()(0..), CCE13DES()(0..), CCE14DES()(0..), CCE15DES()(0..)
Variable Char    CCE16DES()(0..), CCE17DES()(0..), CCE18DES()(0..), CCE19DES()(0..), CCE20DES()(0..)
Variable Decimal PAYCUR(0..), VATCUR(0..), RFUCUR(0..), TOTPAY, TOTRFU, TOTSTA
Local Integer    ADDPJ(0..dim(PAYCUR)-1)

Call CALC_LIGFRAISPJ(ACTION,REFNUM,CTRNUM,EXSNUM,UID,DATEXS,CODEXP,EXPDES,CUR,CURDES,VAT,VATDES
&                  , QTY,SNS,PAYCUR,VATCUR,RFUCUR,CPY,CPYNAM,BPCNUM,BPCNAM,SOHNUM,CUSORDREF,SOHLIG
&                  , ITMDES,INVFLG,CCE1,CCE1DES,CCE2,CCE2DES,CCE3,CCE3DES,CCE4,CCE4DES
&                  , CCE5,CCE5DES,CCE6,CCE6DES,CCE7,CCE7DES,CCE8,CCE8DES,CCE9,CCE9DES
&                  , CCE10,CCE10DES,CCE11,CCE11DES,CCE12,CCE12DES,CCE13,CCE13DES,CCE14,CCE14DES
&                  , CCE15,CCE15DES,CCE16,CCE16DES,CCE17,CCE17DES,CCE18,CCE18DES,CCE19,CCE19DES
&                  , CCE20,CCE20DES,DES , STA,TOTPAY,TOTRFU,TOTSTA,ADDPJ)


End




Subprog CALC_LIGFRAISPJ(ACTION,REFNUM,CTRNUM,EXSNUM,UID,DATEXS,CODEXP,EXPDES,CUR,CURDES,VAT,VATDES
&                  , QTY,SNS,PAYCUR,VATCUR,RFUCUR,CPY,CPYNAM,BPCNUM,BPCNAM,SOHNUM,CUSORDREF,SOHLIG
&                  , ITMDES,INVFLG,CCE1,CCE1DES,CCE2,CCE2DES,CCE3,CCE3DES,CCE4,CCE4DES
&                  , CCE5,CCE5DES,CCE6,CCE6DES,CCE7,CCE7DES,CCE8,CCE8DES,CCE9,CCE9DES
&                  , CCE10,CCE10DES,CCE11,CCE11DES,CCE12,CCE12DES,CCE13,CCE13DES,CCE14,CCE14DES
&                  , CCE15,CCE15DES,CCE16,CCE16DES,CCE17,CCE17DES,CCE18,CCE18DES,CCE19,CCE19DES
&                  , CCE20,CCE20DES,DES , STA,TOTPAY,TOTRFU,TOTSTA,ADDPJ)

Variable Char    ACTION()(0..)
Variable Char    REFNUM(),CTRNUM()
Value    Integer EXSNUM
Variable Integer UID(0..), QTY(0..), SOHLIG(0..), INVFLG(0..), STA(0..), SNS(0..)
Variable Date    DATEXS(0..)
Variable Char    CODEXP()(0..), CUR()(0..), VAT()(0..), CPY()(0..), BPCNUM()(0..)
Variable Char    SOHNUM()(0..), CCE1()(0..), CCE2()(0..), CCE3()(0..), CCE4()(0..)
Variable Char    CCE5()(0..), CCE6()(0..), CCE7()(0..), CCE8()(0..), CCE9()(0..),CCE10()(0..)
Variable Char    CCE11()(0..), CCE12()(0..), CCE13()(0..), CCE14()(0..), CCE15()(0..)
Variable Char    CCE16()(0..), CCE17()(0..), CCE18()(0..), CCE19()(0..), CCE20()(0..)
Variable Char    DES()(0..), EXPDES()(0..), CURDES()(0..),VATDES()(0..), CPYNAM()(0..)
Variable Char    BPCNAM()(0..), CUSORDREF()(0..), ITMDES()(0..), CCE1DES()(0..)
Variable Char    CCE2DES()(0..), CCE3DES()(0..), CCE4DES()(0..), CCE5DES()(0..)
Variable Char    CCE6DES()(0..), CCE7DES()(0..), CCE8DES()(0..), CCE9DES()(0..),CCE10DES()(0..)
Variable Char    CCE11DES()(0..), CCE12DES()(0..), CCE13DES()(0..), CCE14DES()(0..), CCE15DES()(0..)
Variable Char    CCE16DES()(0..), CCE17DES()(0..), CCE18DES()(0..), CCE19DES()(0..), CCE20DES()(0..)
Variable Decimal PAYCUR(0..), VATCUR(0..), RFUCUR(0..), TOTPAY, TOTRFU, TOTSTA
Variable Integer ADDPJ(0..)
If GMODU(6) <> 2 : End : Endif : # 69157 module note de frais

Local Shortint I , N
Local Char     CHAINE(250)

If ACTION <> "CAL" : End : Endif

Gosub OUVRE From WOHREXS
If !clalev([F:HREXS]) : Local File HREXPENSES  [HREXS] : Endif
If !clalev([F:AXX]) : Local File ATEXTRA   [AXX] : Endif
If !clalev([F:HRTES]) : Local File HRTABEXPENS [HRTES] : Endif
If clalev([F:AXX_])=0   : Local File =GTABCPT+"ATEXTRA" [AXX_]  : Endif

#SEGAY 11/04/12 80868 : Validation diffûˋrûˋe des ûˋcrans
Call ISSCREENOK(nomap,"HREXS0") From INTRUTILB

I = 0
If EXSNUM(I) <> 0
 Filter [F:HREXS] Where [F:HREXS]EXSNUM= EXSNUM(I)
 Read [F:HREXS]HREXS0 Last
 Filter [F:HREXS]
 If fstat
  GMESSAGE = mess(23,100,1) : # Fiche inexistante
  GERR     = 1
  End
 Endif
Else
 Raz [F:HREXS]
 [F:HREXS]REFNUM = REFNUM(I)
 [F:HREXS]CTRNUM = CTRNUM(I)
 #62655
 [F:HREXS]STRDAT = date$
 [F:HREXS]ENDDAT = date$
# For I = 0 To dim(DATEXS)-1
#  [F:EXS]STRDAT = min(DATEXS(I),[F:EXS]STRDAT)
#  [F:EXS]ENDDAT = max(DATEXS(I),[F:EXS]ENDDAT)
# Next

# SEGAY 07/03/12 80653
 If [F:HREXS]CTRNUM = "" Then
  [F:HREXS]STRDAT = [0/0/0]
  [F:HREXS]ENDDAT = [0/0/0]
 Endif
# END 80653

 N = 0
 While DATEXS(N) <> [0/0/0]
  If ([F:HREXS]STRDAT=[0/0/0] or [F:HREXS]STRDAT > DATEXS(N) )
   [F:HREXS]STRDAT = DATEXS(N)
  Endif
  If ([F:HREXS]ENDDAT=[0/0/0] or [F:HREXS]ENDDAT < DATEXS(N) )
   [F:HREXS]ENDDAT=DATEXS(N)
  Endif
  N+=1
 Wend
 N=0

 #fin 62655
Endif

# SEGAY 07/03/12 80653
If [F:HREXS]CTRNUM = "" Then
  Read [F:ID]ID0 = [F:HREXS]REFNUM
  If !fstat & [F:ID]FLGMULCTR<2
   # FQ85820 - MABON 12/11/12 - On doit prendre la date de rûˋtroactivitûˋ au lieu de la date du contrat, pour dûˋterminer la prûˋsence du salariûˋ
#   Filter [CTR] Where REFNUM=[F:EXS]REFNUM & CTRDAT<=[F:EXS]ENDDAT & (XITDAT>=[F:EXS]STRDAT | XITDAT=[0/0/0])
   Filter [HRCTR] Where REFNUM=[F:HREXS]REFNUM & (CTRDAT<=[F:HREXS]ENDDAT | (FLGRET=2 & RETDATEFF<=[F:HREXS]ENDDAT)) & (XITDAT>=[F:HREXS]STRDAT | XITDAT=[0/0/0])
   # Fin MABON
   Read [HRCTR]CTR0 First
   Filter [HRCTR]
   If fstat
    [V]GMESSAGE=func AFNC.MES2( mess(171,10709,1),format$([V]GFMD,[F:HREXS]STRDAT)
&                           , format$([V]GFMD,[F:HREXS]ENDDAT)
&                           )
    #           Pas de contrat de travail pour la pûˋriode du $1$ au $2$
    [V]GERR     = 1
    Call ADDMESSERR(GMESSAGE) From AWEB
    End
   Else
    [F:HREXS]CTRNUM=[F:HRCTR]CTRNUM
   Endif
  Endif
Endif
# END 80653

Gosub INI_IMPORT
mkstat   = 0
#GIMPORT  = 1
#GSILENCE = 1
For nolign=1 To [M:WI0]NBLIG
 [M:HREXS0]NBLIG = nolign
 indice        = nolign-1
 status        = 75
 Call SAI_NBLIG("","WEB_CREATE","PORNDF") From W0HREXS0
 If mkstat
  GERR=1
  If GMESSAGE = "" : GMESSAGE = right$(GMESSIMP,2) : Endif
  GMESSAGE -= "(" + mess(3,40,1) - num$(nolign) + ")" : # Ligne n
#68641
    If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
    Read [ATZ]CODZONE = "HREXPENSES";GZONE
    If !fstat
     GMESSAGE -= mess(32,126,1)-'"'+func AFNC.TEXTE([F:ATZ]NOLONG)+'"'
    Endif
#Fin 68641
  Break
 Endif
 #67194
 Call LECTURE("HRTES",[M:HREXS0]CODEXP(nolign-1),"") From CONTOBJ
 If [F:HRTES]TYPVLT = 1
  Call INIPAYE( [M:HREXS0]DATEXS(nolign-1),[M:HREXS0]CODEXP(nolign-1)
&             , [M:HREXS0]CUR(nolign-1),[M:HREXS0]QTY(nolign-1),[M:HREXS0]PAYCUR(nolign-1)
&           ) From SUBHREXS
 Endif
 #fin 67194
Next
GIMPORT  = 0
GSILENCE = 0

For nolign=1 To [M:HREXS0]NBLIG
 [F:HREXS] = [M:HREXS0]
# bug : 100415

# on ajoute les axes
Local Integer DIMTAB
DIMTAB=min(20,dim([F:HREXS]CCE))
For S=1 To DIMTAB
[F:HREXS]CCE(S-1)=evalue("[M:WI0]CCE"+num$(S)+"(nolign-1)")
[F:HREXS]DIE(S-1)=[M:HREXS0]DIETYP(S-1)
Next
 If 1=2
 For S=1 To [V]GOPTCANA
  [F:HREXS]CCE(S-1)=evalue("[M:WI0]CCE"+num$(S)+"(nolign-1)")
 Next S
 Endif
 Read [F:HRTES]HRTES0 = GCURLEG;[F:HREXS]CODEXP  : # 62655
 N = nolign-1
 Gosub TRANSLIG
Next

End

################################################################################
#
# Consultation en-tûˆte d'une note de frais sans contrûÇle des autorisations
#
################################################################################

Subprog CONSNOTEFRAIS( ACTION,REFNUM,CTRNUM,EXSNUM,STRDAT,ENDDAT,TIT,EXSSTA,PAYSHR,RFUSHR
&                    , STASHR
&                    , URLBACK,CMT)
Value    Char    ACTION(), REFNUM(), CTRNUM()
Variable Date    STRDAT, ENDDAT
Variable Integer EXSNUM, EXSSTA
Variable Char    TIT()
Variable Decimal PAYSHR, RFUSHR,STASHR
Value    Char    URLBACK (), CMT()

If GMODU(6) <> 2 : End : Endif : # 69157 module note de frais

Local    Char MATRICULE(GLONMAT)

# Url de retour pour message workflow, stockûˋ dans les variables contexte du workflow de longueur 80
GURLRET001 = mid$(URLBACK,001,80)
GURLRET002 = mid$(URLBACK,081,80)
GURLRET003 = mid$(URLBACK,161,80)

[L]MATRICULE=[L]REFNUM

If !clalev([F:HREXS]) : Local File HREXPENSES  [HREXS] : Endif
If !clalev([F:HRTES]) : Local File HRTABEXPENS [HRTES] : Endif

Local Shortint S

Filter [HREXS] Where EXSNUM=[L]EXSNUM
Read [HREXS] First
Filter [HREXS]
If fstat
 GMESSAGE=mess(23,100,1) : # Fiche inexistante
 GERR    =1
 End
Endif

Link [HREXS] With [HRTES]HRTES0=GCURLEG;CODEXP As [LNK]
For [LNK]HREXS0(2) Where EXSNUM=[L]EXSNUM
 [L]EXSSTA=[F:HREXS]EXSSTA
 [L]TIT   =[F:HREXS]TIT
 [L]CMT   =[F:HREXS]CMT
 [L]STRDAT=[F:HREXS]STRDAT
 [L]ENDDAT=[F:HREXS]ENDDAT
 For [LNK]HREXS0
  If [F:HRTES]DEB=2 : S=-1 : Else S=1 : Endif
  [L]RFUSHR+=S*[F:HREXS]RFUSHR
  [L]PAYSHR+=S*[F:HREXS]PAYSHR
  If [F:HREXS]STA=2 : [L]STASHR+=S*[F:HREXS]RFUSHR : Endif
 Next
Next

End

################################################################################
#
# Consultation 1 ligne d'une note de frais sans contrûÇle des autorisations
#
################################################################################
Subprog CONSLIGFRAISPJ( ACTION,EXSNUM,UID,DATEXS,CODEXP,EXPDES,CUR,CURDES,VAT,VATDES,QTY,SNS
&                  , PAYCUR,VATCUR,RFUCUR,CPY,CPYNAM,BPCNUM,BPCNAM,SOHNUM,CUSORDREF,SOHLIG
&                  , ITMDES,INVFLG,CCE1,CCE1DES,CCE2,CCE2DES,CCE3,CCE3DES,CCE4,CCE4DES
&                  , CCE5,CCE5DES,CCE6,CCE6DES,CCE7,CCE7DES,CCE8,CCE8DES,CCE9,CCE9DES
&                  , CCE10,CCE10DES,CCE11,CCE11DES,CCE12,CCE12DES,CCE13,CCE13DES,CCE14,CCE14DES
&                  , CCE15,CCE15DES,CCE16,CCE16DES,CCE17,CCE17DES,CCE18,CCE18DES,CCE19,CCE19DES
&                  , CCE20,CCE20DES,DES,STA,TOTPAY,TOTRFU,TOTSTA,ADDPJ
&                  )
Value    Char    ACTION()
Value    Integer EXSNUM
Variable Integer UID(0..), QTY(0..), SOHLIG(0..), INVFLG(0..), STA(0..), SNS(0..)
Variable Date    DATEXS(0..)
Variable Char    CODEXP()(0..), CUR()(0..), VAT()(0..), CPY()(0..), BPCNUM()(0..)
Variable Char    SOHNUM()(0..), CCE1()(0..), CCE2()(0..), CCE3()(0..), CCE4()(0..)
Variable Char    CCE5()(0..), CCE6()(0..), CCE7()(0..), CCE8()(0..), CCE9()(0..),CCE10()(0..)
Variable Char    CCE11()(0..), CCE12()(0..), CCE13()(0..), CCE14()(0..), CCE15()(0..)
Variable Char    CCE16()(0..), CCE17()(0..), CCE18()(0..), CCE19()(0..), CCE20()(0..)
Variable Char    DES()(0..), EXPDES()(0..), CURDES()(0..),VATDES()(0..), CPYNAM()(0..)
Variable Char    BPCNAM()(0..), CUSORDREF()(0..), ITMDES()(0..), CCE1DES()(0..)
Variable Char    CCE2DES()(0..), CCE3DES()(0..), CCE4DES()(0..), CCE5DES()(0..)
Variable Char    CCE6DES()(0..), CCE7DES()(0..), CCE8DES()(0..), CCE9DES()(0..),CCE10DES()(0..)
Variable Char    CCE11DES()(0..), CCE12DES()(0..), CCE13DES()(0..), CCE14DES()(0..), CCE15DES()(0..)
Variable Char    CCE16DES()(0..), CCE17DES()(0..), CCE18DES()(0..), CCE19DES()(0..), CCE20DES()(0..)
Variable Decimal PAYCUR(0..), VATCUR(0..), RFUCUR(0..), TOTPAY, TOTRFU, TOTSTA
Variable Integer ADDPJ(0..)
If GMODU(6) <> 2 : End : Endif : # 69157 module note de frais





Gosub OUVRE From WOHREXS
If !clalev([F:AXX])     : Local File ATEXTRA  [AXX] : Endif
If !clalev([F:HREXS])     : Local File HREXPENSES [HREXS] : Endif
If clalev([F:AXX_])=0   : Local File =GTABCPT+"ATEXTRA" [AXX_]  : Endif
Local Shortint N, S
Local Char     MATRICULE(GLONMAT)

Filter [HREXS] Where EXSNUM=[L]EXSNUM
Read [HREXS]EXS0 Last
Filter [HREXS]
If fstat
 GMESSAGE=mess(23,100,1) : # Fiche inexistante
 GERR    =1
 End
Endif

Link [HREXS] With [HRTES]HRTES0=GCURLEG;CODEXP As [LNK]
If [L]UID(0) : Filter [LNK] Where find(UID,[L]UID) : Endif
For [LNK]HREXS0 Where EXSNUM=[L]EXSNUM
 If N>=dim([L]UID)
  GERR=1
 Else
  Gosub TRANSLIG
 Endif
 N+=1
Next
Filter [LNK]
If GERR=1
 GMESSAGE="SETLIGFRAIS :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

#############################################################
End


Subprog CONSLIGFRAIS( ACTION,EXSNUM,UID,DATEXS,CODEXP,EXPDES,CUR,CURDES,VAT,VATDES,QTY,SNS
&                  , PAYCUR,VATCUR,RFUCUR,CPY,CPYNAM,BPCNUM,BPCNAM,SOHNUM,CUSORDREF,SOHLIG
&                  , ITMDES,INVFLG,CCE1,CCE1DES,CCE2,CCE2DES,CCE3,CCE3DES,CCE4,CCE4DES
&                  , CCE5,CCE5DES,CCE6,CCE6DES,CCE7,CCE7DES,CCE8,CCE8DES,CCE9,CCE9DES
&                  , CCE10,CCE10DES,CCE11,CCE11DES,CCE12,CCE12DES,CCE13,CCE13DES,CCE14,CCE14DES
&                  , CCE15,CCE15DES,CCE16,CCE16DES,CCE17,CCE17DES,CCE18,CCE18DES,CCE19,CCE19DES
&                  , CCE20,CCE20DES,DES,STA,TOTPAY,TOTRFU,TOTSTA
&                  )
Value    Char    ACTION()
Value    Integer EXSNUM
Variable Integer UID(0..), QTY(0..), SOHLIG(0..), INVFLG(0..), STA(0..), SNS(0..)
Variable Date    DATEXS(0..)
Variable Char    CODEXP()(0..), CUR()(0..), VAT()(0..), CPY()(0..), BPCNUM()(0..)
Variable Char    SOHNUM()(0..), CCE1()(0..), CCE2()(0..), CCE3()(0..), CCE4()(0..)
Variable Char    CCE5()(0..), CCE6()(0..), CCE7()(0..), CCE8()(0..), CCE9()(0..),CCE10()(0..)
Variable Char    CCE11()(0..), CCE12()(0..), CCE13()(0..), CCE14()(0..), CCE15()(0..)
Variable Char    CCE16()(0..), CCE17()(0..), CCE18()(0..), CCE19()(0..), CCE20()(0..)
Variable Char    DES()(0..), EXPDES()(0..), CURDES()(0..),VATDES()(0..), CPYNAM()(0..)
Variable Char    BPCNAM()(0..), CUSORDREF()(0..), ITMDES()(0..), CCE1DES()(0..)
Variable Char    CCE2DES()(0..), CCE3DES()(0..), CCE4DES()(0..), CCE5DES()(0..)
Variable Char    CCE6DES()(0..), CCE7DES()(0..), CCE8DES()(0..), CCE9DES()(0..),CCE10DES()(0..)
Variable Char    CCE11DES()(0..), CCE12DES()(0..), CCE13DES()(0..), CCE14DES()(0..), CCE15DES()(0..)
Variable Char    CCE16DES()(0..), CCE17DES()(0..), CCE18DES()(0..), CCE19DES()(0..), CCE20DES()(0..)
Variable Decimal PAYCUR(0..), VATCUR(0..), RFUCUR(0..), TOTPAY, TOTRFU, TOTSTA
Local Integer    ADDPJ(0..dim(CODEXP)-1)

Call CONSLIGFRAISPJ( ACTION,EXSNUM,UID,DATEXS,CODEXP,EXPDES,CUR,CURDES,VAT,VATDES,QTY,SNS
&                  , PAYCUR,VATCUR,RFUCUR,CPY,CPYNAM,BPCNUM,BPCNAM,SOHNUM,CUSORDREF,SOHLIG
&                  , ITMDES,INVFLG,CCE1,CCE1DES,CCE2,CCE2DES,CCE3,CCE3DES,CCE4,CCE4DES
&                  , CCE5,CCE5DES,CCE6,CCE6DES,CCE7,CCE7DES,CCE8,CCE8DES,CCE9,CCE9DES
&                  , CCE10,CCE10DES,CCE11,CCE11DES,CCE12,CCE12DES,CCE13,CCE13DES,CCE14,CCE14DES
&                  , CCE15,CCE15DES,CCE16,CCE16DES,CCE17,CCE17DES,CCE18,CCE18DES,CCE19,CCE19DES
&                  , CCE20,CCE20DES,DES,STA,TOTPAY,TOTRFU,TOTSTA,ADDPJ
&                  )

End




