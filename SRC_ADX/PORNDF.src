 End
Endif

Link [HREXS] With [HRTES]HRTES0=GCURLEG;CODEXP As [LNK]
If [L]UID(0) : Filter [LNK] Where find(UID,[L]UID) : Endif
For [LNK]HREXS0 Where EXSNUM=[L]EXSNUM
 If N>=dim([L]UID)
  GERR=1
 Else
  Gosub TRANSLIG
 Endif
 N+=1
Next
Filter [LNK]
If GERR=1
 GMESSAGE="SETLIGFRAIS :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables infûˋrieure û  $1$
Endif

#############################################################
End

Funprog DETEXS(EXSNUM)
Value Integer  EXSNUM
Local Char     LTEXT(250)(1..)
Local Char     SEP(10) : SEP=""
Local Char     W_TEMP(150),LIBCOD(30),TITEXS(80),SNSCOD(1)
Local Integer  IT

  If clalev([F:HREXS])=0 : Local File HREXPENSES  [HREXS] : Endif

  If clalev([F:HRTES])=0 : Local File HRTABEXPENS [HRTES] : Endif
  Filter [F:HREXS] Where EXSNUM=[L]EXSNUM

  Local Char EXSLEG(GLONADI)
  If clalev([F:EXSH]) =0 : Local File EXPENSESHEA [F:EXSH]  : Endif : # DAHOF - Legislation required from header for HRTES read

  Raz LTEXT : IT=1
  For [F:HREXS]
    EXSLEG = ""
    Read [F:EXSH]EXSH0 = [F:HREXS]REFNUM;[F:HREXS]EXSNUM;[F:HREXS]CTRNUM
    If !fstat
      EXSLEG = [F:EXSH]LEG
    Endif

    LIBCOD="" : SNSCOD=""
    Read [F:HRTES]HRTES0=[L]EXSLEG;[F:HREXS]CODEXP
    If !fstat Then
      LIBCOD=[F:HRTES]CODEXP : #DAHOF ???? changed DESEXP to CODEXP
      If [F:HRTES]DEB=2 Then SNSCOD="-" : Endif
    Endif
    If LIBCOD="" Then LIBCOD=[F:HREXS]CODEXP : Endif
    W_TEMP="-"-LIBCOD-";"-mess(3,11,1)-format$(GFMD,[F:HREXS]DATEXS)-";"-mess(223,10726,1)-SNSCOD+num$([F:HREXS]PAYCUR)-[F:HREXS]CUR-";"-mess(224,10726,1)-SNSCOD+num$([F:HREXS]RFUCUR)-[F:HREXS]CUR
    If len(LTEXT(IT))+len(W_TEMP)>250 and IT<10 Then
      IT+=1
    Endif
    LTEXT(IT) += SEP+W_TEMP
    SEP=chr$(10)+chr$(13)
  Next
  Filter [F:HREXS]

End LTEXT(1)-LTEXT(2)-LTEXT(3)-LTEXT(4)-LTEXT(5)-LTEXT(6)-LTEXT(7)-LTEXT(8)-LTEXT(9)-LTEXT(10)

# NDF V7
Subprog GETLSTAXEANAV7(CODE,LIB)
Variable Char CODE()()
Variable Char LIB()()

If clalev([F:AXX_])=0  : Local File =GTABCPT+"ATEXTRA" [AXX_]  : Endif
If(clalev([F:DIE])=0)  : Local File =GTABCPT+"GDIE" [DIE]: Endif
Local Integer WI

For [F:DIE]
 CODE(WI)=[F:DIE]DIE
  Read [F:AXX_]AXX0="GDIE";"COLHEA";GLANGUE;[F:DIE]DIE;""
  If !fstat
    LIB(WI)=[F:AXX_]TEXTE
  Endif
  WI+=1
Next

#If(clalev([F:CDI])=0)  : Local File CADIEDEF [CDI]: Endif
#If clalev([F:AXX_])=0  : Local File =GTABCPT+"ATEXTRA" [AXX_]  : Endif
