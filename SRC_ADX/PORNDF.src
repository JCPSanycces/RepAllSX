#  CODE(WI)=[F:CDI]DIE(WI)
#  Read [F:AXX_]AXX0="GDIE";"COLHEA";GLANGUE;[F:CDI]DIE(WI);""
#  If !fstat
#    LIB(WI)=[F:AXX_]TEXTE
#  Endif
