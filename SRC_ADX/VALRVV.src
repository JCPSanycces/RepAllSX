#<AdxTL>@(#)4.0.0.0 $Revision$
$ACTION
Case ACTION
  When "INIT"        : Gosub INIT
  When "CONTROLE"    : Gosub CONTROLE
  When "EXEC"        : Gosub EXEC
  When "SORTIE"      : Gosub SORTIE
Endcase
Return

############################################################################################
## Validate a Routing version in development to change it to a Routing version available to use
## CCC 11/2015
############################################################################################

$INIT
Local Char ITM([V]GLONITM)
Local Char FCY([V]GLONFCY)

Local Char    TITFNC(250)
Local Integer TRC, ALT2B

ITM = [L]PARAM(1)
FCY = [L]PARAM(2)
[L]PARAM(3)="0"
Call TITFNC("VALRVV",TITFNC) From CONTOBJ

Gosub VERIF
If GERR=-1
   GMESSAGE=mess(63,198,1)-[L]ITM-[L]FCY+"\"+GMESSAGE : # Routing
   GERR=1
Endif
If GERR : FIN=1 : Return : Endif

TIT = mess(63,198,1)-[L]ITM-[L]FCY : # Routing
TIT+="\"+TITFNC-[F:RVV]ECCVALMAJ-[F:RVV]ECCVALMIN : # Validation of version
Return

$VERIF
If !clalev([F:RVV])  : Local File RVMVAL    [RVV]  : Endif
If !clalev([F:ITM])  : Local File ITMMASTER [ITM]  : Endif
If !clalev([F:TRO])  : Local File TABROUALT [TRO]  : Endif
If !clalev([F:RVV2]) : Local File RVMVAL    [RVV2] : Endif
If !clalev([F:ROO])  : Local File ROUOPE    [ROO]  : Endif
If !clalev([F:ROS])  : Local File ROUSCD    [ROS]  : Endif
If !clalev([F:ROH])  : Local File ROUTING   [ROH]  : Endif

Local Integer SEQ, ALT1, ALT2, NIV
Local Char    FCY1(GLONFCY)
Local Date    STRDAT1
Local Char    SAVFONCION([V]GLONAFC)

SAVFONCTION = GFONCTION
GFONCTION="VALRVV"
Call AUTORIS From EXEFNC

Read [ITM]ITM0 = [L]ITM
If !fstat
   NIV = func RVMLIB.NBRCPNROU([L]ITM)
Endif
If NIV<1
   GERR=1 : GMESSAGE = mess(153,187,1)-[L]ITM : # Versions not managed on this product
   Return
Endif

Filter [RVV] Where ITMREF=[L]ITM & FCY=[L]FCY & USESTA=2
Read [RVV]RVV0 Last
Filter [RVV]
If !fstat : ALT2 = [F:RVV]ROUALT
Else      : ALT2 = [F:ITM]ECCROUALT(1)
Endif
If ALT2=0
   GERR=-1 : GMESSAGE = mess(340,193,1)-"("+mess(2,240,1)+")" : # Versioned routing code not defined
   Return
Endif

Filter [RVV] Where ITMREF=[L]ITM & FCY=[L]FCY
Read [RVV]RVV0 Last
Filter [RVV]
If fstat>2
   GERR=-1 : GMESSAGE = mess(308,193,1) : # Non existing version
   Return
Elsif [F:RVV]USESTA=2
   # Last version ... Available to use
   GERR=-1 : GMESSAGE = mess(311,193,1)-[F:RVV]ECCVALMAJ-[F:RVV]ECCVALMIN-":"-mess(2,240,1)
   Return
Endif
[L]SEQ  = [F:RVV]ECCSEQ
[L]ALT1 = [F:RVV]ROUALT
[L]STRDAT1 = [F:RVV]STRDAT

If [L]ALT1=[L]ALT2
   GERR=-1 : GMESSAGE = mess(314,193,1)-"("+num$([L]ALT1)+")"-":"-mess(1,240,1)-","-mess(2,240,1) :  # Same BOM codes
   Return
Endif

Read [TRO]TRO0 = [L]ALT1
If fstat
   GERR=1 : GMESSAGE = num$([L]ALT1)-":"-mess(152,193,1) : # Non existing routing code
   Return
Endif
[L]FCY1 =[F:TRO]FCY

Read [TRO]TRO0 = [L]ALT2
If fstat
   GERR=1 : GMESSAGE = num$([L]ALT2)-":"-mess(152,193,1) : # Non existing routing code
   Return
Endif
If [L]FCY1<>[F:TRO]FCY
   GERR=-1 : GMESSAGE = func AFNC.MES2(mess(331,193,1),num$([L]ALT1),num$([L]ALT2)) : # Sites of routing codes $1$ and $2$ are not compatible
   Return
Endif

If GNBAUZ=0
  GERR=1
Elsif GUSRFCY(1)<>"\"
  If [L]FCY1<>""
     If !find([L]FCY1,GUSRFCY(1..GNBAUZ)) : GERR=1 : Endif
  Else
     # At least one authorized site (for production)
     GERR=1
     Local File FACILITY [FCY]
     For [FCY]FCY0 Where MFGFLG=2
         If find([F:FCY]FCY,GUSRFCY(1..GNBAUZ)) : GERR=0 : Break : Endif
     Next
  Endif
Endif
If GERR
   GMESSAGE=mess(1,123,1) : # Unauthorized function
   Return
Endif

# lock management
If !func RVMLIB.LCKROH([L]FCY,[L]ITM,[L]ALT1)
   GERR=1 : GMESSAGE=mess(63,198,1)-[L]FCY-[L]ITM-num$([L]ALT1)+"\"+mess(10,100,1) : Return
Elsif !func RVMLIB.LCKROH([L]FCY,[L]ITM,[L]ALT2)
   GERR=1 : GMESSAGE=mess(63,198,1)-[L]FCY-[L]ITM-num$([L]ALT2)+"\"+mess(10,100,1) : Return
Endif
Return

#############################################################

$SORTIE
If GFONCTION<>SAVFONCTION
   GFONCTION=SAVFONCTION
   Call AUTORIS From EXEFNC
Endif

Call DELOCK("ROH") From GLOCK : # Call DELOCK("ROH\") From GLOCK # Issue 118592 GH 20/09/2016
Return

#############################################################

$CONTROLE
Filter [ROO] Where ITMREF=[L]ITM
&                & FCY   =[L]FCY
&                & ROUALT=[L]ALT1
&                & (VALSTRDAT=[L]STRDAT1 | VALENDDAT=[L]STRDAT1-1)
Look [ROO] First
Filter [ROO]
If fstat>2
   # Version in development with no revised line
   OK=1 : Call OUINON(mess(322,193,1)+"\"+mess(172,100,1),OK) From GESECRAN
   If OK<>2 : FIN=1 : Return : Endif
Endif
Return

#############################################################

$EXEC
GOK=1
If ![V]GSERVEUR & GTRACE=""
   Local Char TITTRC(200)
   Call TITFNC("VALRVV",TITTRC) From CONTOBJ
   TITTRC = mess(63,198,1)-[L]ITM-[L]FCY+":"+TITTRC-[F:RVV]ECCVALMAJ-[F:RVV]ECCVALMIN : # Routing xxx Validation of version yyy
   Call OUVRE_TRACE(TITTRC) From LECFIC
   TRC=1
Endif
Call TR_EXEC1([L]ITM,[L]FCY,[L]ALT1,[L]ALT2,[L]SEQ)
If GOK<1 or GERR=1 : SAI=1 : Endif
If TRC
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE From LECFIC
Endif
If SAI=1 : SAI=0 : Return : Endif

[L]PARAM(3) = num$([L]SEQ)
Return

#############################################################
## Transaction
#############################################################

Subprog TR_EXEC1(ITM,FCY,ALT1,ALT2,SEQ)
Value Char    ITM()
Value Char    FCY()
Value Integer ALT1, ALT2
Value Integer SEQ

Local Char ABREV(GLONAOB), TRTGBM(GLONADC)

[L]TRTGBM="VALRVV"  # Process to use for BOITE action called by OBJSIM (useless for routing)
[L]ABREV="ROU"      # Name of the object for OBJSIM

If dim([V]GDATEREF)=1
   Local Date SAVDATEREF
   [L]SAVDATEREF = [V]GDATEREF
Endif

Gosub DEFVAR From OBJSIM

Call DEBTRANS From GLOCK
Gosub TR

Gosub RESTGLO From OBJSIM

If dim([V]GDATEREF)=1 & dim([L]SAVDATEREF)=1
   [V]GDATEREF=[L]SAVDATEREF
Endif
End

$TR
GOK=1

Trbegin [ROH], [ROO], [ROS], [RVV]

  If [L]SEQ=1
     Gosub TR1
  Else
     Gosub TR2
  Endif
  If GOK>0
     Gosub ANNULE
  Endif

If GOK<1
  Rollback
  If GOK<0
   Call ROLL From GLOCK
   If !GROLL : Goto TR : Endif
  Endif
  Return
Endif
Commit
Return

#############################################################
## validation of the first version
#############################################################
## Duplication (header + lines + text) of the first routing in development
## to a new one available to use with change of routing code
## + Deletion of the routing in development
$TR1
Read [ROH]ROH0 = [L]ITM;[L]ALT1;[L]FCY
If fstat
   GOK=0 : Call RSTA("ROH",[L]ITM-num$([L]ALT1)-[L]FCY) From GLOCK : Return
Endif
#
GDATEREF=[0/0/0]
Gosub CHARGE From OBJSIM
#
[M:ROU0]ROUALT = [L]ALT2
[M:ROU0]USESTA = 2
[M:ROU0]NEWALT = [L]ALT2
#
Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
[V]GREP="D"
[L]ACTION="RAZDUP" : Gosub ACTION From GOBJSUB
If [V]GOK>0
   Gosub CREATION From OBJSIM
Endif
Setmode
If GOK<0 : Return : Endif

Gosub CHANGE
If GOK<0 : Return : Endif
Return

#############################################################
## validation of the other versions
#############################################################
## Deletion of all lines of the routing available to use
## + Values transfer (header + lines + texts) from the routing in development to the routing available to use
## + Deletion of the routing in development

$TR2
Read [ROH]ROH0 = [L]ITM;[L]ALT2;[L]FCY
If fstat
   GOK=0 : Call RSTA("ROH",[L]ITM-num$([L]ALT2)-[L]FCY) From GLOCK : Return
Endif

## Routing available to use : loading and deletion of all lines
GDATEREF=[0/0/0]
Gosub CHARGE From OBJSIM
#
[V]GREP="M"
[M:ROU1]NBLIG=0 : # all lines are deleted
[M:ROU3]NOLIG=0 : # all lines are deleted
Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
Gosub MODIF From OBJSIM
Setmode
If GOK<1 : Return : Endif

## Routing available to use : values transfer from the routing in development
Gosub CHANGE
If GOK<0 : Return : Endif

Read [ROH]ROH0 = [L]ITM;[L]ALT1;[L]FCY
If fstat
   GOK=0 : Call RSTA("ROH",[L]ITM-num$([L]ALT1)-num$([L]FCY)) From GLOCK : Return
Endif
GDATEREF=[0/0/0]
Gosub CHARGE From OBJSIM
#
CLECUR1 = num$([L]ALT2)
[M:ROU0]ROUALT = [L]ALT2
[M:ROU0]USESTA = 2
[M:ROU0]NEWALT = [L]ALT2
#
# all lines are supposed to be new lines
Raz [M:ROU1]CREFLG, [L]MAXLIG
#Raz [M:ROU3]CREFLG, [L]MAXLIG2
#
[V]GREP="M"
Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
Gosub MODIF From OBJSIM
Setmode
Return

#############################################################

$CHANGE
Local Date    DATF
Local Char    VMAJ(GLONICVVAL), VMIN(GLONICVVAL)
Local Integer I

# Version : change of routing and use status
Readlock [RVV]RVV0 = [L]ITM;[L]FCY;[L]SEQ
If fstat=1
     GOK=-1 : GLOCK="$RVVVAL"-[L]ITM-[L]FCY-num$([L]SEQ) : Return
Elsif fstat
   GOK=0 : Call RSTA("RVV",[L]ITM-[L]FCY-num$([L]SEQ)) From GLOCK : Return
Endif
[F:RVV]ROUALT = [L]ALT2
[F:RVV]USESTA = 2 : # available to use
Rewrite [RVV]
If fstat
   GOK=0 : Call FSTA("RVV") From GLOCK : Return
Endif

VMAJ = [F:RVV]ECCVALMAJ
VMIN = [F:RVV]ECCVALMIN
DATF = [F:RVV]STRDAT
If [L]SEQ>1
   # change end date of the last version to the day before the starting of the new version
   Readlock [RVV]RVV0 = [L]ITM;[L]FCY;[L]SEQ-1
   If fstat=1
      GOK=-1 : GLOCK="$RVMVAL"-[L]ITM-[L]FCY-num$([L]SEQ-1) : Return
   Elsif fstat
      GOK=0 : Call RSTA("RVV",[L]ITM-[L]FCY-num$([L]SEQ-1)) From GLOCK : Return
   Endif
   [F:RVV]ENDDAT = [L]DATF-1

   # derogation calculation according to WO with starting date >= revision date
   [F:RVV]EXNDAT = [0/0/0] : [F:RVV]EXNFLG=1 : # par sécurité
   If !clalev([F:MFG]) : Local File MFGHEAD [MFG] : Endif
   Columns [MFG] (STRDAT)
   For [MFG] Where ROUNUM=[F:RVV]ITMREF & MFGFCY=[F:RVV]FCY & ROUECCMAJ=[F:RVV]ECCVALMAJ & ROUECCMIN=[F:RVV]ECCVALMIN
&                & STRDAT>[F:RVV]ENDDAT
       If [F:MFG]STRDAT>[F:RVV]EXNDAT
          [F:RVV]EXNDAT=[F:MFG]STRDAT
       Endif
   Next
   Columns [MFG]
   If [F:RVV]EXNDAT<>[0/0/0] : [F:RVV]EXNFLG=2 : Endif

   Rewrite [RVV]
   If fstat
     GOK=0 : Call FSTA("RVV") From GLOCK : Return
   Endif
Endif

Return

$ANNULE
## Text transfer
Call SUPTEXTRA("ROUTING","ROUDESAXX",[L]ITM+"~"+num$([L]ALT2),[L]FCY) From ATEXTRA
If GOK<1 : Return : Endif
Call  CHGTEXTRA("ROUTING","ROUDESAXX",[L]ITM+"~"+num$([L]ALT1),[L]FCY
&                                ,[L]ITM+"~"+num$([L]ALT2),[L]FCY) From ATEXTRA
If GOK<1 : Return : Endif

##  Deletion of the routing in developement
Read [ROH]ROH0 = [L]ITM;[L]ALT1;[L]FCY
If !fstat
   GDATEREF=[0/0/0]
   Gosub CHARGE From OBJSIM
   #
   [V]GREP="A" : [M:ROU0]NEWALT=[L]ALT2
   Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
   Call ANUCOD([L]ABREV,[L]CLECUR1,[L]CLECUR2,[L]OK) From GOBJACT
   If ![L]OK & GOK>0 : GOK=0 : Endif
   If GOK>0
      Call ANNULE([L]ABREV,[L]CLECUR1,[L]CLECUR2) From GOBJTXT
   Endif
   Setmode
Endif
Return

#**----------------------------------------------------------------<br/>
#* Validate a routing version in development to change it to a routing version available to use
#**<br/>----------------------------------------------------------------<br/>
#* @param ITM    = Product
#* @param FCY    = Site
#**<br/>----------------------------------------------------------------
#*!

Subprog TR_EXEC2(ITM,FCY)
Value Char    ITM()
Value Char    FCY()

Local Integer TRC
# INIT
GERR=0 : GMESSAGE="" : GOK=1
Gosub VERIF
If GERR=-1
   GMESSAGE=mess(14,195,1)-[L]ITM+"\"+GMESSAGE : # Article
   GERR=1
Endif
If GERR : Goto FIN2 : Endif

If clalev([F:ATX])=0 : Local File ATEXTE   [ATX] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA  [AXX] : Endif

If ![V]GSERVEUR & GTRACE=""
   Local Char TITTRC(200)
   Call TITFNC("VALRVV",TITTRC) From CONTOBJ
   TITTRC = mess(63,198,1)-[L]ITM-[L]FCY+":"+TITTRC-[F:RVV]ECCVALMAJ-[F:RVV]ECCVALMIN : # Routing xxx Validation of version yyy
   Call OUVRE_TRACE(TITTRC) From LECFIC
   TRC=1
Endif
Call TR_EXEC1([L]ITM,[L]FCY,[L]ALT1,[L]ALT2,[L]SEQ)
If TRC
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE From LECFIC
Endif

$FIN2
Gosub SORTIE
End

