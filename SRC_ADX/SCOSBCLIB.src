#<AdxTL>@(#)6.0.0.0 $Revision$
############################################################
# GA 30/08/2005 traitement des ordres de sous-traitance    #
############################################################
#-------------------------------------------------------------------------------------------
# MAJ_SBC_SCO : utilise les fonctions suivantes pour mettre à jour le SCO
# ------------
# CRE_SBC_SCI : en création     d'une ligne commande d'achat sur article lancé (consomme encours EOF)
# SUP_SBC_SCI : en suppression  d'une ligne commande d'achat sur article lancé (restaure encours EOF)
# MOD_SBC_SCI : en modification d'une ligne commande d'achat sur article lancé
# FAC_SBC_SCI : en création     d'une ligne facture  d'achat sur article lancé
# RCP_SBC_SCI : en réception/annulation réception    d'une commande d'achat sur article lancé
# RET_SBC_SCI : en retour/annulation retour          d'une commande d'achat sur article lancé
#
# CRE_SBC_SCS : en création     d'une ligne commande d'achat sur article sous-traitance(consomme encours SCF)
# SUP_SBC_SCS : en suppression  d'une ligne commande d'achat sur article sous-traitance(restaure encours SCF)
# MOD_SBC_SCS : en modification d'une ligne commande d'achat sur article sous-traitance
# FAC_SBC_SCS : en création     d'une ligne facture  d'achat sur article sous-traitance
#
# !!!!!!!!! inutilisé: il n'y a pas d'encours MSx sur ces matières .... !!!!!!!!!
# CRE_SBC_SCM : en création    d'une ligne commande d'achat sur matière fournie par le sous-traitant
# SUP_SBC_SCM : en suppression d'une ligne commande d'achat sur matière fournie par le sous-traitant
# MOD_SBC_SCM : en maj d'une commande               d'achat sur matière fournie par le sous-traitant
# FAC_SBC_SCM : en création d'une ligne facture  d'achat    sur matière fournie par le sous-traitant
#
#-------------------------------------------------------------------------------------------
# Cas particulier pour les ordres de sous-traitance
# 04/2006 si appel depuis les commandes d'achat avec un encours WIPSTA=2 Planifié (EOP ou SCP)
#         l'EO change de statut WIPSTA=1 Ferme
#-------------------------------------------------------------------------------------------

############################################################################
# 02/2007 dans SCOSRV CPNITMREF devient SRVITMREF                          #
############################################################################

############################################################################################
Subprog MAJ_SBC_SCO (LRET)
Variable Integer LRET
Local Integer WZERO
Local Char    WPJT(GLONPJT)
Local Char    WSCONUM(GLONVCR)
Local Integer WSCILIN, WSCSLIN, WSCMLIN
Local Char    WITMREFORI(GLONITM)
Local Integer WCLEFLG
Local Integer I

# Issue 87021 Raz GA 01/2013 have to use absolutely [F:ORD]WIPTYP
# Issue 86821 GA 12/2012
#Local Integer WWIPTYP : WWIPTYP=[F:ORD]WIPTYP
#If WWIPTYP=0 WWIPTYP=[M:SBCK]WIPTYP Endif

#
# GA 30/80/2005 Traitement des SCO
# ouverture tables si nécessaire
Gosub OPEN_FILES_SCO From SCOLIB
#
Case [F:ORD]WIPTYP
When 4
# l'encours SCx contient la réf de l'ordre de sous-traitance,
# un seul service commandé par ordre de sous-traitance
  WSCONUM    = [M:SBCK]VCRNUMORI
  WSCILIN    = [M:SBCK]VCRLINORI
  WSCSLIN    = [M:SBCK]VCRSEQORI
  WITMREFORI = [F:ORD]ITMREFORI
  WPJT       = [F:ORD]PJT
When 13
# l'encours EOx contient la réf de l'ordre de sous-traitance,
  WSCONUM    = [M:SBCK]VCRNUMORI : # Issue 92278 Raz Modif MBT du 01/02/2006 avant [F:ORD]VCRNUM
  WSCILIN    = [M:SBCK]VCRLINORI : # Issue 92278 Raz Modif MBT du 01/02/2006 avant [F:ORD]VCRLIN
  WITMREFORI = [F:ORD]ITMREFORI
  WPJT       = [F:ORD]PJT
When 2,7
# l'encours POF ou TRF contient la réf de l'ordre de sous-traitance,
  WSCONUM    = [M:SBCK]VCRNUMORI
  WSCILIN    = [M:SBCK]VCRLINORI
  WITMREFORI = [F:ORD]ITMREFORI
  WPJT       = [F:ORD]PJT
  LRET = func ITMLIB.READ_ITM_ITF ([F:ORD]ITMREF,[F:ORD]STOFCY)
  If LRET = 1 : Raz GMESSAGE : Raz LRET : Endif  # Issue 85454 GA 11/2012 ne pas renvoyer 1 si on ne sort pas ?
# si SCPFLG=2 on est sur l'article lancé
  If [M:SBCK]LINTYP=2 # Issue 92278 [F:ITM]SCPFLG=2
     WSCMLIN    = 0
     WSCSLIN    = 0
# si SCSFLG=2 on est sur le service, sinon on est sur une matière fournie par le sous-traitant
  Elsif [M:SBCK]LINTYP=3 # Issue 92278 [F:ITM]SCSFLG=2
     WSCSLIN    = [M:SBCK]VCRSEQORI
     WSCMLIN    = 0
  Elsif [M:SBCK]LINTYP=4 # Issue 92278
     WSCMLIN    = [M:SBCK]VCRSEQORI
     WSCSLIN    = 0
  Endif
When Default
 # Pas d'encours: sur Retour ou Facture par exemple # GA 11/2008
 # Issue 92278 Pas d'encours POF sur les matières fournies par le sous-traitant
  WSCONUM    = [M:SBCK]VCRNUMORI
  WSCILIN    = [M:SBCK]VCRLINORI
  If [M:SBCK]LINTYP=3    # Issue 92278
     WSCSLIN    = [M:SBCK]VCRSEQORI
     WSCMLIN    = 0
  Elsif [M:SBCK]LINTYP=4 # Issue 92278
     WSCMLIN    = [M:SBCK]VCRSEQORI
     WSCSLIN    = 0
  Else
     WSCSLIN    = 0
     WSCMLIN    = 0
  Endif
  # FQ 53656 ne planter en suppression si EO absent
  # article lancé ordre de sous-traitance
  Read [SCI]SCI0=WSCONUM;WSCILIN
  If fstat & [M:SBCK]MAJCOD<>"A" : LRET = 1 : Raz [F:SCI] : End : Endif

  LRET = func ITMLIB.READ_ITM_ITF ([F:SCI]ITMREF,[F:SCI]PRHFCY)
  If LRET = 1 : End : Endif  # Issue 85454 GA 11/2012 ne pas Raz GMESSAGE puisqu'on sort en erreur

  # service ordre de sous-traitance
  If WSCSLIN=0
     Read [SCS]SCS0(2)=WSCONUM;WSCILIN
  Else
     Read [SCS]SCS0=WSCONUM;WSCILIN;WSCSLIN
  Endif
  If fstat & [M:SBCK]MAJCOD<>"A" : LRET = 1 : Raz [F:SCS] : End : Endif

  # FQ 56565 Facture: Service ou composant ?
  If [M:SBCK]MAJCOD="F" & [M:SBCK]ITMREF<>[F:SCI]ITMREF
    If [M:SBCK]ITMREF=[F:SCS]SRVITMREF
      LRET = func ITMLIB.READ_ITM_ITF ([F:SCS]SRVITMREF,[F:SCS]PRHFCY)
      If LRET = 1 : End : Endif  # Issue 85454 GA 11/2012 ne pas Raz GMESSAGE puisqu'on sort en erreur
    Else
      # composant ordre de sous-traitance
      Read [SCM]SCM0=WSCONUM;WSCILIN;WSCMLIN
      If fstat & [M:SBCK]MAJCOD<>"A" : LRET = 1 : Raz [F:SCM] : End : Endif

      LRET = func ITMLIB.READ_ITM_ITF ([F:SCM]CPNITMREF,[F:SCM]STOFCY)
      If LRET = 1 : Raz GMESSAGE : GOK=1 : LRET=0 : Endif  # Issue 85454 GA 11/2012 GMESSAGE car on ne sort pas en erreur
    Endif
# Issue 87203 - 2013-01-16 by CCC
  Elsif [M:SBCK]LINTYP=4
      # composant ordre de sous-traitance
      Read [SCM]SCM0=WSCONUM;WSCILIN;WSCMLIN
      If fstat & [M:SBCK]MAJCOD<>"A" : LRET = 1 : Raz [F:SCM] : End : Endif

      LRET = func ITMLIB.READ_ITM_ITF ([F:SCM]CPNITMREF,[F:SCM]STOFCY)
      If LRET = 1 & [F:SCM]SCOFLG=2 : End : Endif
  Endif
Endcase
#
# Cas d'erreur (sauf si [M:SBCK]MAJCOD="G")
If WSCONUM="" & [M:SBCK]MAJCOD<>"G" : GOK=0 : [M:SBCK]CODRET=1 : End : Endif
Case [M:SBCK]MAJCOD
    When "C":
               If dim([M:SBCK]LINTYP)>0 # FQ 76147 GA 09/2011
                  Case [M:SBCK]LINTYP
                    When 2  : Call CRE_SBC_SCI(WSCONUM, WSCILIN, WPJT, LRET)
                    When 3  : Call CRE_SBC_SCS(WSCONUM, WSCILIN, WSCSLIN, WPJT, LRET)
                    When 4  : Call CRE_SBC_SCM(WSCONUM, WSCILIN, WSCMLIN, WPJT, LRET)
                  Endcase
               # FQ 76147 GA 09/2011 CODE OBSOLETE ...
               Elsif [F:ITM]SCPFLG=2 Call CRE_SBC_SCI(WSCONUM, WSCILIN, WPJT, LRET)
               Elsif [F:ITM]SCSFLG=2 Call CRE_SBC_SCS(WSCONUM, WSCILIN, WSCSLIN, WPJT, LRET)
               Else                  Call CRE_SBC_SCM(WSCONUM, WSCILIN, WSCMLIN, WPJT, LRET)
               Endif
    When "M":
               If dim([M:SBCK]LINTYP)>0 # FQ 76147 GA 09/2011
                  Case [M:SBCK]LINTYP
                    When 2  : Call MOD_SBC_SCI(WSCONUM, WSCILIN, WPJT, LRET)
                    When 3  : Call MOD_SBC_SCS(WSCONUM, WSCILIN, WSCSLIN, WPJT, LRET)
                    When 4  : Call MOD_SBC_SCM(WSCONUM, WSCILIN, WSCMLIN, WPJT, LRET)
                  Endcase
               # FQ 76147 GA 09/2011 CODE OBSOLETE ...
               Elsif [F:ITM]SCPFLG=2  Call MOD_SBC_SCI(WSCONUM, WSCILIN, WPJT, LRET)
               Elsif [F:ITM]SCSFLG=2  Call MOD_SBC_SCS(WSCONUM, WSCILIN, WSCSLIN, WPJT, LRET)
               Else                   Call MOD_SBC_SCM(WSCONUM, WSCILIN, WSCMLIN, WPJT, LRET)
               Endif
    When "A":
               If dim([M:SBCK]LINTYP)>0 # FQ 76147 GA 09/2011
                  Case [M:SBCK]LINTYP
                    When 2  : Call SUP_SBC_SCI(WSCONUM, WSCILIN, WPJT, LRET)
                    When 3  : Call SUP_SBC_SCS(WSCONUM, WSCILIN, WSCSLIN, WPJT, LRET)
                    When 4  : Call SUP_SBC_SCM(WSCONUM, WSCILIN, WSCMLIN, WPJT, LRET)
                  Endcase
               # FQ 76147 GA 09/2011 CODE OBSOLETE ...
               Elsif [F:ITM]SCPFLG=2  Call SUP_SBC_SCI(WSCONUM, WSCILIN, WPJT, LRET)
               Elsif [F:ITM]SCSFLG=2  Call SUP_SBC_SCS(WSCONUM, WSCILIN, WSCSLIN, WPJT, LRET)
               Else                   Call SUP_SBC_SCM(WSCONUM, WSCILIN, WSCMLIN, WPJT, LRET)
               Endif
    When "F":
               If dim([M:SBCK]LINTYP)>0 # FQ 76147 GA 09/2011
                  Case [M:SBCK]LINTYP
                    When 2  : Call FAC_SBC_SCI(WSCONUM, WSCILIN, WPJT, LRET)
                    When 3  : Call FAC_SBC_SCS(WSCONUM, WSCILIN, WSCSLIN, WPJT, LRET)
                    When 4  : Call FAC_SBC_SCM(WSCONUM, WSCILIN, WSCMLIN, WPJT, LRET)
                  Endcase
               # FQ 76147 GA 09/2011 CODE OBSOLETE ...
               Elsif [F:ITM]SCPFLG=2 Call FAC_SBC_SCI(WSCONUM, WSCILIN, WPJT, LRET)
               Elsif [F:ITM]SCSFLG=2 Call FAC_SBC_SCS(WSCONUM, WSCILIN, WSCSLIN, WPJT, LRET)
               Else                  Call FAC_SBC_SCM(WSCONUM, WSCILIN, WSCMLIN, WPJT, LRET)
               Endif
    When "T":
               # Réception Article sous-traité
               Call RCP_SBC_SCI(WSCONUM, WSCILIN, WPJT, LRET)
    When "N":
               # Retour Article sous-traité
               Call RET_SBC_SCI(WSCONUM, WSCILIN, WPJT, LRET)

    When "G":  # identification de l'ordre de sous-traitance
               [M:SBCK]VCRNUMORI = WSCONUM
               [M:SBCK]VCRLINORI = WSCILIN
               [M:SBCK]VCRSEQORI = WSCSLIN
               [M:SBCK]VCRTYPORI = 36      : # identifier le fait qu'on soit sur un SCO
               Read [SCI]SCI0=WSCONUM;WSCILIN       # FQ 73618 GA 05/2011
               If fstat Raz [F:SCI] Endif           # FQ 73618 GA 05/2011
               [M:SBCK]BPAADD    = [F:SCI]BPAADD    # Issue 88018 ceci correspond à [F:POQ]SCOADD
               # Issue 80507 pour FUNMPICKA car ITMREFORI critère de tri des lignes de commande
               If WITMREFORI<>""
                  [M:SBCK]ITMREFORI = WITMREFORI
               Else
                  [M:SBCK]ITMREFORI = [F:SCI]ITMREF
               Endif
    When Default:
         Call ECR_DEBUG("MAJ_SBC_SCO(SCOSBCLIB):"-[M:SBCK]VCRNUMORI-"MAJCOD="+[M:SBCK]MAJCOD) From SCOSTKAUTLIB
Endcase
#
End

############################################################################################
##### Mise a jour de SCOITM: en création/suppression de commande d'achat
############################################################################################
Subprog CRE_SBC_SCI(LSCONUM, LSCILIN, LPJT, LRET)
Value    Char      LSCONUM
Value    Integer   LSCILIN
Value    Char      LPJT
Variable Integer   LRET
Local    Decimal WCOEF
Local    Integer WSTA
Local    Decimal WEXTQTY

LRET = 0

If [F:SCO]SCONUM<>LSCONUM
  # lecture entête ordre de sous-traitance
  Read [SCO]SCO0=LSCONUM
  If fstat : LRET = 1 : End : Endif
Endif
If [F:SCI]SCONUM<>LSCONUM | [F:SCI]SCILIN<>LSCILIN
  # lecture article ordre de sous-traitance
  Read [SCI]SCI0=LSCONUM;LSCILIN
  If fstat : LRET = 1 : End : Endif
Endif

Call ECR_DEBUG("CRE_SBC_SCI(SCOSBCLIB):"-LSCONUM) From SCOSTKAUTLIB

# ------------------------------------------------ #
# Cas particulier: un ordre EOP a été pické        #
# On utilise MODIFICATION_SCO afin de reporter     #
# la maj de statut sur [F:SCI],[F:SCM] et [F:SCS]  #
# ------------------------------------------------ #
If [F:ORD]WIPSTA = 2
   WSTA = 1
   WEXTQTY = [F:SCI]EXTQTY
   Gosub MODIFICATION_SCO
   If LRET=1 : End : Endif
   [F:ORD]WIPSTA = 1
Endif

Call MOD_SBC_SCI(LSCONUM, LSCILIN, LPJT, LRET)


End

############################################################################################
##### Mise a jour de SCOITM:
# 1) en modification de commande d'achat
# 2) réception avec solde de la commande d'achat (qté commandée = qté réceptionnée)
# NB: comportement <> de celui des OF car plusieurs commandes rattachées à SCOITM/SCOSRV
############################################################################################
Subprog MOD_SBC_SCI(LSCONUM, LSCILIN, LPJT, LRET)
Value    Char      LSCONUM
Value    Integer   LSCILIN
Value    Char      LPJT
Variable Integer   LRET
#
Local    Integer   WSTA
Local    Decimal   WEXTQTY
Local    Decimal   WWRK,WORDQTY,WRCPQTY
Local    Integer   WSTAT
Local    Integer   WOPECLENBR : WOPECLENBR = 0
Local    Integer   WNEWBPS : WNEWBPS = 0
Local    Char      WMAT(GLONITM)
Local    Integer   WTROUVE : WTROUVE = 0
Local    Char      WPOHNUM(GLONREF) : WPOHNUM=[M:SBCK]VCRNUM
Local    Integer   WPOPLIN          : WPOPLIN=[M:SBCK]VCRLIN
#
LRET = 0
If [F:SCO]SCONUM<>LSCONUM
  # lecture entête ordre de sous-traitance
  Read [SCO]SCO0=LSCONUM
  If fstat : LRET = 1 : End : Endif
Endif
If [F:SCI]SCONUM<>LSCONUM | [F:SCI]SCILIN<>LSCILIN
  # lecture article ordre de sous-traitance
  Read [SCI]SCI0=LSCONUM;LSCILIN
  If fstat : LRET = 1 : End : Endif
Endif
Local    Integer   WSCSLIN : WSCSLIN=5
If [F:SCS]SCONUM<>LSCONUM | [F:SCS]SCILIN<>LSCILIN
  # lecture opération ordre de sous-traitance (en cas de solde)
  Read [SCS]SCS0=LSCONUM;LSCILIN
  If fstat : LRET = 1 : End : Endif
Endif
WSCSLIN=[F:SCS]SCSLIN
#
Call ECR_DEBUG("MOD_SBC_SCI(SCOSBCLIB):"-LSCONUM) From SCOSTKAUTLIB

# Y-a-t-il d'autre(s) commande(s) pour cet Article lancé ?
If WPOHNUM<>""
  Raz WORDQTY, WRCPQTY   : # Recalcul de la Qté en commande
  If clalev([F:POQ2])   = 0 : Local File PORDERQ    [POQ2]   : Endif

# Issue 98094 GA 03/2014
  If [M:SBCK]BPSNUM=""
    Read [F:POQ2]POQ0(2)=WPOHNUM;WPOPLIN
    If !fstat : [M:SBCK]BPSNUM=[F:POQ2]BPSNUM : Endif
  Endif

  For [POQ2]POQ4 Where VCRTYPORI=36
&                    & VCRNUMORI=[F:SCI]SCONUM & VCRLINORI=[F:SCI]SCILIN
&                    & VCRSEQORI=0 & ITMREF=[F:SCI]ITMREF
&                    & (POHNUM<>WPOHNUM | POPLIN<>WPOPLIN)
    # Issue 121929 - 2017-03-29 by MUARN : que si non soldé par la réception
    # Issue 106083 - 2016-03-23 by MUARN : commande soldée
    If [F:POQ2]LINCLEFLG = 2 & [F:POQ2]RCPCLEFLG=1
      WORDQTY += [F:POQ2]RCPQTYSTU
      WRCPQTY += [F:POQ2]RCPQTYSTU
    Else
      WORDQTY += [F:POQ2]QTYSTU
      WRCPQTY += [F:POQ2]RCPQTYSTU
    Endif
    If [M:SBCK]CLEFLG = 2 & [F:POQ2]LINCLEFLG<>2 [M:SBCK]CLEFLG=1 Endif # Issue 85502 GA 11/2012 don't close when others not closed purchases found
    # Issue 106083 - 2016-03-23 by MUARN : commande soldée
    If WORDQTY >0
      WTROUVE = 1
    Endif
  Next
  # Issue 90770 GA 08/2013 EO partially ordered
  If [M:SBCK]CLEFLG = 2 & WORDQTY<[F:SCI]EXTQTY : [M:SBCK]CLEFLG=1 Endif

Endif

# Issue 98094 GA 03/2014 déplacé après relecture ligne(s) commande(s) et complété
# Test changement adresse [M:SBCK]BPAADD contient [F:POQ]SCOADD
If  ([F:SCO]BPRNUM <> [M:SBCK]BPSNUM & [M:SBCK]BPSNUM<>"")
& | ([F:SCI]BPAADD <> [M:SBCK]BPAADD & [M:SBCK]BPAADD<>"") : WNEWBPS = 1 : Endif
# Issue 96725 GA 02/2014 contrôle trop contraignant :-(
#If [F:POQ]FCYADD<>[F:SCI]PRHADD : WNEWBPS = 1 : Endif # Issue 88018 GA 02/2013

# Issue 81525 GA 05/2012 Pas de changement de Fournisseur si déjà partiellement commandé
If WNEWBPS = 1
  If WTROUVE = 1 & WORDQTY>0
      If [M:SBCK]BPSNUM<>[F:POQ2]BPSNUM
         # Une commande existe pour un autre fournisseur.
         GMESSAGE=[F:POQ2]POHNUM-mess(452,194,1)-[F:POQ2]BPSNUM
         LRET = 5
      Else
         # Issue 88018 GA 02/2013
         # Une commande existe pour une autre adresse sous-traitant.
         GMESSAGE=[F:POQ2]POHNUM-mess(453,194,1)-[F:POQ2]BPSNUM-[F:POQ2]SCOADD
         LRET = 6
      Endif
   Elsif [F:SCO]BPRNUM <> [M:SBCK]BPSNUM & [M:SBCK]BPSNUM<>""
     # Issue 95944 GA 01/2014
     # Changement de fournisseur impossible pour cet ordre de sous-traitance
     GMESSAGE=[F:POQ2]POHNUM-[F:POQ2]BPSNUM-mess(461,194,1)
     LRET = 7
   Elsif [F:SCI]BPAADD <> [M:SBCK]BPAADD & [M:SBCK]BPAADD<>""
     # Issue 95308 & 95944 GA 01/2014
     # Changement d'adresse sous-traitant non autorisé  pour cet ordre de sous-traitance.
     GMESSAGE=[F:POQ2]POHNUM-[F:POQ2]BPSNUM-mess(469,194,1)
     LRET = 8
   Endif
   End
Endif

# en cas de solde de la commande, ORDQTY est plafonnée par la qté réceptionnée cf SUBPTHC
If [M:SBCK]CLEFLG = 2 & WORDQTY > WRCPQTY
   WORDQTY = WRCPQTY
Endif

# Issue 102679 GA 09/2014 new condition on [M:SBCK]RCPDAT
# Issue 96725 GA 02/2014 only one PO and new FCYADD
# FQ 75630 GA 09/2011 si date de commande modifiée, recalcul des dates et maj des prix
# si quantité commandée > quantité prévue, on réajuste la qté initiale
# On utilise MODIFICATION_SCO afin de reporter la maj de qté sur [F:SCM] et [F:SCS]
#If [M:SBCK]ORDQTY + WORDQTY > [F:SCI]EXTQTY | WNEWBPS
If [M:SBCK]ORDQTY + WORDQTY > [F:SCI]EXTQTY
& | [M:SBCK]ORDDAT<>[F:SCO]ORDDAT
& | [M:SBCK]RCPDAT<>[F:SCO]RETDAT
& | ([F:POQ]FCYADD<>"" & [F:POQ]FCYADD<>[F:SCI]PRHADD & !WTROUVE)

   WSTA    = [F:SCO]SCOSTA
   # Issue 81525 & 82238 GA 05/2012 ne pas reduire la qté si cde partielle (ajout max)
   WEXTQTY = max([M:SBCK]ORDQTY + WORDQTY,[F:SCI]EXTQTY)
   Gosub MODIFICATION_SCO
   If LRET<>0 End Endif # Issue 93771 GA 12/2013

Endif
# FQ 54554 ajout Elsif sinon on repasse dans REWRITE_SCI avec une qté Ko
# si quantité totale commandée < quantité initiale
# FQ 57911 GA 09/2009 pb de maj des infos de la cde si on est passé dans MODIFICATION_SCO
#Elsif [M:SBCK]ORDQTY + WORDQTY <= [F:SCI]EXTQTY
If [M:SBCK]ORDQTY + WORDQTY > 0

      # lecture article
      Readlock [SCI] SCI0=LSCONUM;LSCILIN
      If fstat : LRET = 1 : End : Endif

      # ajout quantité commandée
      [F:SCI]ORDQTY = [M:SBCK]ORDQTY + WORDQTY

      # mise à jour encours
      Call UPDATE_EOX("M") From SCOLIB
      #If GOK <= 0 : LRET = 1 : Infbox "MOD_SBC_SCI: erreur UPDATE_EOX (M)" : End : Endif

      # chargement enr°
      Gosub UPD_POHNUM_SCI

      # V6 Affectations
      #If [F:SCI]WIPSTA=1 : Gosub MAJ_MTO_SCI From SCOMTOLIB : Endif # GH 22/05/2013 bug 88901
      # GH 09/08/13 bug 90882
      If [F:SCI]WIPSTA=1
         Gosub CHECK_MTO From MTOLINKLIB

         Local Integer NDEM, I
         Local Integer XDIM : XDIM = 500
         Local Integer TDEM_TYP(XDIM)
         Local Char    TDEM_NUM(GLONVCR)(XDIM)
         Local Integer TDEM_LIN(XDIM)
         Local Integer TDEM_SEQ(XDIM)
         Local Libelle TDEM_WIP(XDIM)
         Local Libelle TDEM_STA(XDIM)
         Local Libelle TDEM_FRC(XDIM)
         Local Decimal TDEM_QTY1(XDIM)
         Local Decimal TDEM_QTY2(XDIM)

         # tableau des demandes affectées à l'EOF
         NDEM=0
         For [MLK]MLK1 Where STOFCY = [F:SCI]PRHFCY & ITMREF=[F:SCI]ITMREF
&                          & RESSTYP = 36
&                          & RESSNUM = [F:SCI]SCONUM
&                          & RESSLIN = [F:SCI]SCILIN
&                          & RESSSEQ = 0
             TDEM_TYP(NDEM)  = [F:MLK]DEMTYP
             TDEM_NUM(NDEM)  = [F:MLK]DEMNUM
             TDEM_LIN(NDEM)  = [F:MLK]DEMLIN
             TDEM_SEQ(NDEM)  = [F:MLK]DEMSEQ
             TDEM_WIP(NDEM)  = [F:MLK]DWIPTYP
             TDEM_STA(NDEM)  = [F:MLK]DWIPSTA
             TDEM_FRC(NDEM)  = [F:MLK]FRCFLG
             TDEM_QTY1(NDEM) = [F:MLK]LIKQTY : # qté avant maj des affectations de l'EO
             TDEM_QTY2(NDEM) = 0             : # qté après maj des affectations de l'EO
             NDEM+=1
         Next

         I=0
         If [F:SCI]ORDQTY = [F:SCI]EXTQTY
            Gosub SUP_MTO_SCI From SCOMTOLIB
            I=1
         Else
            Gosub MAJ_MTO_SCI From SCOMTOLIB
            If [M:MLIK]MAJCOD="R"
               For [MLK]MLK1 Where STOFCY = [F:SCI]PRHFCY & ITMREF=[F:SCI]ITMREF
&                                & RESSTYP = 36
&                                & RESSNUM = [F:SCI]SCONUM
&                                & RESSLIN = [F:SCI]SCILIN
&                                & RESSSEQ = 0
                   For I=0 To NDEM-1
                       If TDEM_NUM(I)  = [F:MLK]DEMNUM
&                      &  TDEM_LIN(I)  = [F:MLK]DEMLIN
&                      &  TDEM_SEQ(I)  = [F:MLK]DEMSEQ
&                      &  TDEM_TYP(I)  = [F:MLK]DEMTYP
&                      &  TDEM_WIP(I)  = [F:MLK]DWIPTYP
                          TDEM_QTY2(I)+= [F:MLK]LIKQTY : Break
                       Endif
                   Next I
               Next
               I=1
            Endif
         Endif

         If I
           # les affectations qui ne sont plus sur l'EOF sont passées sur la cde achat générée
           For I=0 To NDEM-1
               If TDEM_QTY1(I)>TDEM_QTY2(I)
                  Raz [M:MLIK]
                  [M:MLIK]MAJCOD  = "C"
                  [M:MLIK]STOFCY  = [F:SCI]PRHFCY
                  [M:MLIK]ITMREF  = [F:SCI]ITMREF
                  [M:MLIK]RESSTYP = 14
                  [M:MLIK]RESSNUM = [F:SCI]POHNUM
                  [M:MLIK]RESSLIN = [F:SCI]POPLIN
                  [M:MLIK]RESSSEQ = [F:SCI]POQSEQ
                  [M:MLIK]DEMTYP  = TDEM_TYP(I)
                  [M:MLIK]DEMNUM  = TDEM_NUM(I)
                  [M:MLIK]DEMLIN  = TDEM_LIN(I)
                  [M:MLIK]DEMSEQ  = TDEM_SEQ(I)
                  [M:MLIK]DWIPTYP = TDEM_WIP(I)
                  [M:MLIK]LIKQTY  = TDEM_QTY1(I)-TDEM_QTY2(I)
                  [M:MLIK]FRCFLG  = TDEM_FRC(I)
                  [M:MLIK]FMIFLG  = 1
                  Call UPDMTOLINK From MTOLINKLIB
                  If GOK>0 & ![M:MLIK]RET : # GH 13/10/2015 bug 111344 [M:MLIK]RET<>0 indicates something is wrong
                     Call UPDORDERS_FROM_MLIK    From MTOLINKLIB
                  Endif
               Endif
           Next I
         Endif
      Endif

      # mise à jour article
      Gosub REWRITE_SCI From SCOLIB

      # mise à jour entête SCO
      Call UPD_SCOTRKFLG(LSCONUM, LRET) From SCOLIB

Endif

# Issue 85502 GA 11/2012 à faire tout le temps si ligne de commande soldée
# Si ligne de commande soldée et indicateur "solder sous-traitance"
#If [M:SBCK]CLEFLG = 2 & GSTRCLEMOD = 2 : Goto SOLDE_SCO_SCI : Endif
If [M:SBCK]CLEFLG = 2 : Gosub SOLDE_SCO : Endif

$FIN_MOD_SCO_SCI
# si changement adresse, et que c'est l'unique commande
If LRET = 0 & WNEWBPS & [M:SBCK]ORDQTY=WORDQTY
    Call VERIF_MAT_SCO(LSCONUM, LSCILIN, WMAT)
    If WMAT <> ""
         # FQ 55325 ajout du n° EO dans le message
         If !GBROWS : Call MESSAGE(mess(229,190,1)+"("+LSCONUM-WMAT+")") From GESECRAN : Endif
    Endif
Endif

End

# -----------------------------------------------------
Subprog SUP_SBC_SCI(LSCONUM, LSCILIN, LPJT, LRET)
Value    Char      LSCONUM
Value    Integer   LSCILIN
Value    Char      LPJT
Variable Integer   LRET

Local    Decimal   WDIFF, WWRK, WORDQTY
Local    Integer   WSTAT
Local    Char      WPOHNUM(GLONREF) : WPOHNUM=[M:SBCK]VCRNUM
Local    Integer   WPOPLIN          : WPOPLIN=[M:SBCK]VCRLIN
Local    Integer   WTROUVE : WTROUVE = 0

LRET = 0
If [F:SCO]SCONUM<>LSCONUM
  # lecture entête ordre de sous-traitance
  Read [SCO]SCO0=LSCONUM
  If fstat : LRET = 1 : End : Endif
Endif
# lecture article ordre de sous-traitance
Read [SCI]SCI0=LSCONUM;LSCILIN
WSTAT = fstat

Call ECR_DEBUG("SUP_SBC_SCI(SCOSBCLIB):"-LSCONUM) From SCOSTKAUTLIB

# mémorisation quantité US
WDIFF = [F:SCI]EXTQTY

# pas de suppression dans ce cas, on laisse l'article
Case WSTAT
    When 1: # lock, on peut rien faire de plus ...
            LRET = 1
            End
    When 0: # article existant, maj
            Readlock [SCI] SCI0=LSCONUM;LSCILIN
            If fstat : LRET = 1 : End : Endif

            # Reste-t-il d'autre(s) ligne(s) de commande(s) cet Article lancé ?
            # GA à revoir cas d'un EO soldé ????
            [F:SCI]ORDQTY = 0   : # Recalcul de la Qté en commande
            If clalev([F:POQ2])   = 0 : Local File PORDERQ    [POQ2]   : Endif
            For [POQ2]POQ4 Where VCRTYPORI=36
&                              & VCRNUMORI=[F:SCI]SCONUM & VCRLINORI=[F:SCI]SCILIN
&                              & VCRSEQORI=0 & ITMREF=[F:SCI]ITMREF
&                              & (POHNUM<>WPOHNUM | POPLIN<>WPOPLIN)
                # Issue 121929 - 2017-03-29 by MUARN : que si non soldé par la réception
                # Issue 106083 - 2016-03-23 by MUARN : commande soldée
                If [F:POQ2]LINCLEFLG = 2 & [F:POQ2]RCPCLEFLG=1
                  [F:SCI]ORDQTY += [F:POQ2]RCPQTYSTU
                Else
                  [F:SCI]ORDQTY += [F:POQ2]QTYSTU
                Endif
                # Issue 106083 - 2016-03-23 by MUARN : commande soldée
                If [F:SCI]ORDQTY >0
                  WTROUVE = 1
                Endif
            Next
            If [F:POQ2]POHNUM="" | WTROUVE = 0
               Gosub SCI_ITMSTA_INI From SCOLIB
               [F:SCI]POHNUM = ""
               [F:SCI]POPLIN = 0
               [F:SCI]POQSEQ = 0
            Else
               Gosub SCI_ITMSTA_PUR From SCOLIB
               [F:SCI]POHNUM = [F:POQ2]POHNUM
               [F:SCI]POPLIN = [F:POQ2]POPLIN
               [F:SCI]POQSEQ = [F:POQ2]POQSEQ
            Endif
            # maj quantité totale commandée US
            If [M:SBCK]ORDQTY < [F:SCI]ORDQTY
               [F:SCI]ORDQTY -= [M:SBCK]ORDQTY
            Else
               [F:SCI]ORDQTY = 0
            Endif

            #If find([F:SCI]WIPTYP,2,7) => recherche à faire dans tous les cas
            #  Recherche de l'encours EOX s'il est tjs dans ORDERS
               If clalev([F:ORDW])   = 0 : Local File ORDERS    [ORDW]   : Endif
               Raz [F:SCI]WIPTYP,[F:SCI]WIPNUM,[F:SCI]WIPSTA
               Filter [ORDW] Where WIPTYP=13 & VCRTYP=36
&                               & VCRNUM=[F:SCI]SCONUM & VCRLIN=[F:SCI]SCILIN
               Read [ORDW]ORD0 First
               If !fstat
                   [F:SCI]WIPTYP=[F:ORDW]WIPTYP
                   [F:SCI]WIPNUM=[F:ORDW]WIPNUM
                   [F:SCI]WIPSTA=[F:ORDW]WIPSTA
               Endif
               Filter [ORDW]
            #Endif

            If [F:SCI]ORDQTY = 0
            # suppression encours
              Call UPDATE_EOX("A") From SCOLIB
              #If GOK <= 0 : LRET = 1 : End : Endif

            # on recrée l'encours EOX
              Call UPDATE_EOX("C") From SCOLIB
              #If GOK <= 0 : LRET = 1 : End : Endif
            Else

            # on maj l'encours EOX
              Call UPDATE_EOX("M") From SCOLIB
              #If GOK <= 0 : LRET = 1 : End : Endif
            Endif

            # V6 Affectations
            If [F:SCI]WIPSTA=1 : Gosub MAJ_MTO_SCI From SCOMTOLIB : Endif

            # mise à jour article
            Gosub REWRITE_SCI From SCOLIB
Endcase

# mise à jour entête SCO
Call UPD_SCOTRKFLG(LSCONUM, LRET) From SCOLIB

End

# -----------------------------------------------------
Subprog RCP_SBC_SCI(LSCONUM, LSCILIN, LPJT, LRET)
Value    Char      LSCONUM
Value    Integer   LSCILIN
Value    Char      LPJT
Variable Integer   LRET
#
Local    Decimal   WWRK,WORDQTY,WRCPQTY
Local    Integer   WSTAT
Local    Integer   WOPECLENBR : WOPECLENBR = 0
Local    Integer   WNEWBPS : WNEWBPS = 0
#Local    Char     WMAT(GLONITM)
Local    Integer   WTROUVE : WTROUVE = 0
Local    Char      WPOHNUM(GLONREF) : WPOHNUM=[M:SBCK]VCRNUM
Local    Integer   WPOPLIN          : WPOPLIN=[M:SBCK]VCRLIN
#
LRET = 0
If [F:SCO]SCONUM<>LSCONUM
  # lecture entête ordre de sous-traitance
  Read [SCO]SCO0=LSCONUM
  If fstat : LRET = 1 : End : Endif
Endif
If [F:SCI]SCONUM<>LSCONUM | [F:SCI]SCILIN<>LSCILIN
  # lecture article ordre de sous-traitance
  Read [SCI]SCI0=LSCONUM;LSCILIN
  If fstat : LRET = 1 : End : Endif
Endif
Local    Integer   WSCSLIN : WSCSLIN=5
If [F:SCS]SCONUM<>LSCONUM | [F:SCS]SCILIN<>LSCILIN
  # lecture opération ordre de sous-traitance (en cas de solde)
  Read [SCS]SCS0=LSCONUM;LSCILIN
  If fstat : LRET = 1 : End : Endif
Endif
WSCSLIN=[F:SCS]SCSLIN
#
Call ECR_DEBUG("RCP_SBC_SCI(SCOSBCLIB):"-LSCONUM) From SCOSTKAUTLIB

# si quantité réceptionnée renseignée
# qté < 0 si création de réception
# qté > 0 si annulation de réception
# NB: pas de maj dans ce cas, on annule et on recrée la ligne [F:PTD]
# ce qui fait qu'on peut ajouter directement la qté,
# on n'est pas obligé de refaire le total comme dans les commandes

# Issue 90024 GA 05/2013 déjà fait dans MAJ_SOUS_TRAIT (SUBPTHC)
#If [M:SBCK]RCPQTY <> 0

      # lecture article
      #Readlock [SCI] SCI0=LSCONUM;LSCILIN
      #If fstat : LRET = 1 : End : Endif

      # ajout quantité réceptionnée
      #[F:SCI]CPLQTY += [M:SBCK]RCPQTY
      #If [F:SCI]CPLQTY<0 : [F:SCI]CPLQTY=0 : Endif

      # chargement enr°
      #Gosub UPD_POHNUM_SCI

      # mise à jour article
      #Gosub REWRITE_SCI From SCOLIB
#
      # lock, et mise à jour entête SCO
      #Call UPD_SCOTRKFLG(LSCONUM, LRET) From SCOLIB
#Endif

# Issue 90024 GA 05/2013 ssi dernière commande soldée
If [M:SBCK]CLEFLG = 2
      # Y-a-t-il d'autre(s) commande(s) pour cet Article lancé ?
      If WPOHNUM<>""
      Raz WORDQTY, WRCPQTY   : # Recalcul de la Qté en commande
        If clalev([F:POQ2])   = 0 : Local File PORDERQ    [POQ2]   : Endif
        For [POQ2]POQ4 Where VCRTYPORI=36
&                          & VCRNUMORI=[F:SCI]SCONUM & VCRLINORI=[F:SCI]SCILIN
&                          & VCRSEQORI=0 & ITMREF=[F:SCI]ITMREF
&                          & (POHNUM<>WPOHNUM | POPLIN<>WPOPLIN)
          # Issue 121929 - 2017-03-29 by MUARN : que si non soldé par la réception
          # Issue 106083 - 2016-03-24 by MUARN : commande soldée
          If [F:POQ2]LINCLEFLG = 2 & [F:POQ2]RCPCLEFLG=1
            WORDQTY += [F:POQ2]RCPQTYSTU
            WRCPQTY += [F:POQ2]RCPQTYSTU
          Else
            WORDQTY += [F:POQ2]QTYSTU
            WRCPQTY += [F:POQ2]RCPQTYSTU
          Endif
          # Issue 85502 GA 11/2012 don't close when others not closed purchases found
          If [M:SBCK]CLEFLG = 2 & [F:POQ2]LINCLEFLG<>2 [M:SBCK]CLEFLG=1 Endif
          # Issue 106083 - 2016-03-24 by MUARN : commande soldée
          If WORDQTY > 0
            WTROUVE = 1
          Endif
        Next
      Endif
      # Issue 90770 GA 08/2013 don't close when EO partially ordered
      If [M:SBCK]CLEFLG = 2 & WORDQTY<[F:SCI]EXTQTY : [M:SBCK]CLEFLG=1 Endif

Endif
# Issue 85502 GA 11/2012 à faire tout le temps si ligne de commande soldée
# Si ligne de commande soldée et indicateur "solder sous-traitance"
#If [M:SBCK]CLEFLG = 2 & GSTRCLEMOD = 2 : Goto SOLDE_RCP_SCI : Endif
If [M:SBCK]CLEFLG = 2 : Gosub SOLDE_SCO : Endif
#

$FIN_RCP_SCI

End

# -----------------------------------------------------
Subprog RET_SBC_SCI(LSCONUM, LSCILIN, LPJT, LRET)
Value    Char      LSCONUM
Value    Integer   LSCILIN
Value    Char      LPJT
Variable Integer   LRET
#
Local    Decimal   WDIFF
Local    Decimal   WWRK
Local    Integer   WSTAT
Local    Integer   WOPECLENBR : WOPECLENBR = 0
Local    Integer   WNEWBPS : WNEWBPS = 0
#Local    Char     WMAT(GLONITM)
#
LRET = 0
If [F:SCO]SCONUM<>LSCONUM
  # lecture entête ordre de sous-traitance
  Read [SCO]SCO0=LSCONUM
  If fstat : LRET = 1 : End : Endif
Endif
If [F:SCI]SCONUM<>LSCONUM | [F:SCI]SCILIN<>LSCILIN
  # lecture article ordre de sous-traitance
  Read [SCI]SCI0=LSCONUM;LSCILIN
  If fstat : LRET = 1 : End : Endif
Endif
Call ECR_DEBUG("RET_SBC_SCI(SCOSBCLIB):"-LSCONUM) From SCOSTKAUTLIB

# si quantité retournée renseignée
# qté < 0 si retour
# qté > 0 si annulation de retour
If [M:SBCK]RCPQTY <> 0

      # lecture article
      Readlock [SCI] SCI0=LSCONUM;LSCILIN
      If fstat : LRET = 1 : End : Endif

      # ajout quantité retournée (valeur < 0 )
      [F:SCI]REJCPLQTY -= [M:SBCK]RCPQTY
      If [F:SCI]REJCPLQTY < 0 : [F:SCI]REJCPLQTY = 0 : Endif

      # mise à jour article
      Gosub REWRITE_SCI From SCOLIB
#
      # lock et mise à jour entête SCO
      Call UPD_SCOTRKFLG(LSCONUM, LRET) From SCOLIB
Endif

End


############################################################################################
Subprog CRE_SBC_SCS(LSCONUM, LSCILIN, LSCSLIN, LPJT, LRET)
Value    Char      LSCONUM
Value    Integer   LSCILIN
Value    Integer   LSCSLIN
Value    Char      LPJT
Variable Integer   LRET

Local    Integer   WSTA
Local    Decimal   WEXTQTY
Local    Decimal   WWRK, WDIFF
Local    Integer   I
Local    Integer   WNEWBPS : WNEWBPS = 0
#Local    Char     WMAT(GLONITM)

LRET = 0

If [F:SCO]SCONUM<>LSCONUM
  # lecture entête ordre de sous-traitance
  Read [SCO]SCO0=LSCONUM
  If fstat : LRET = 1 : End : Endif
Endif
If [F:SCI]SCONUM<>LSCONUM | [F:SCI]SCILIN<>LSCILIN
  # lecture article ordre de sous-traitance
  Read [SCI]SCI0=LSCONUM;LSCILIN
  If fstat : LRET = 1 : End : Endif
Endif
If [F:SCS]SCONUM<>LSCONUM | [F:SCS]SCILIN<>LSCILIN
  # lecture opération ordre de sous-traitance
  Read [SCS]SCS0=LSCONUM;LSCILIN
  If fstat : LRET = 1 : End : Endif
Endif
Call ECR_DEBUG("CRE_SBC_SCS(SCOSBCLIB):"-LSCONUM) From SCOSTKAUTLIB

# si opération déjà commandée => pas de pb (plusieurs commandes pour un EO)
#####If [F:SCS]OPESTA > 3 : LRET = 3 : End : Endif

# ------------------------------------------------ #
# Cas particulier: un ordre SCP a été pické        #
# On utilise MODIFICATION_SCO afin de reporter     #
# la maj de statut sur [F:SCI],[F:SCM] et [F:SCS]  #
# ------------------------------------------------ #
If [F:ORD]WIPSTA = 2
   WSTA = 1
   WEXTQTY = [F:SCI]EXTQTY
   Gosub MODIFICATION_SCO
   If LRET=1 : End : Endif
   [F:ORD]WIPSTA = 1
Endif

Call MOD_SBC_SCS(LSCONUM, LSCILIN, LSCSLIN, LPJT, LRET)

End

# -----------------------------------------------------
Subprog MOD_SBC_SCS(LSCONUM, LSCILIN, LSCSLIN, LPJT, LRET)
Value    Char      LSCONUM
Value    Integer   LSCILIN
Value    Integer   LSCSLIN
Value    Char      LPJT
Variable Integer   LRET
#
Local    Decimal   WDIFF
Local    Decimal   WWRK,WORDQTY,WRCPQTY
Local    Integer   WSTAT
Local    Integer   WOPECLENBR : WOPECLENBR = 0
Local    Integer   WNEWBPS : WNEWBPS = 0
#Local    Char     WMAT(GLONITM)
# FQ 78916 GA 01/2012 recalculer ORDQTY sinon Ko
Local    Integer   WTROUVE : WTROUVE = 0
Local    Char      WPOHNUM(GLONREF) : WPOHNUM=[M:SBCK]VCRNUM
Local    Integer   WPOPLIN          : WPOPLIN=[M:SBCK]VCRLIN
#
LRET = 0
If [F:SCO]SCONUM<>LSCONUM
  # lecture entête ordre de sous-traitance
  Read [SCO]SCO0=LSCONUM
  If fstat : LRET = 1 : End : Endif
Endif
If [F:SCI]SCONUM<>LSCONUM | [F:SCI]SCILIN<>LSCILIN
  # lecture article ordre de sous-traitance
  Read [SCI]SCI0=LSCONUM;LSCILIN
  If fstat : LRET = 1 : End : Endif
Endif
If [F:SCS]SCONUM<>LSCONUM | [F:SCS]SCILIN<>LSCILIN | [F:SCS]SCSLIN<>LSCSLIN
  # lecture opération ordre de sous-traitance
  Read [SCS]SCS0=LSCONUM;LSCILIN
  If fstat : LRET = 1 : End : Endif
Endif
#
Call ECR_DEBUG("MOD_SBC_SCS(SCOSBCLIB):"-LSCONUM) From SCOSTKAUTLIB

# FQ 78916 GA 01/2012 recalculer ORDQTY sinon Ko (idem MOD_SBC_SCI)
# Y-a-t-il d'autre(s) commande(s) pour ce Service ?
If WPOHNUM<>""
  Raz WORDQTY, WRCPQTY   : # Recalcul de la Qté en commande
  If clalev([F:POQ2])   = 0 : Local File PORDERQ    [POQ2]   : Endif
  For [POQ2]POQ4 Where VCRTYPORI=36
&                    & VCRNUMORI=[F:SCS]SCONUM & VCRLINORI=[F:SCS]SCILIN
&                    & VCRSEQORI=[F:SCS]SCSLIN & ITMREF=[F:SCS]SRVITMREF
&                    & (POHNUM<>WPOHNUM | POPLIN<>WPOPLIN)
    # Issue 121929 - 2017-03-29 by MUARN : que si non soldé par la réception
    # Issue 106083 - 2016-03-24 by MUARN : commande soldée
    If [F:POQ2]LINCLEFLG = 2 & [F:POQ2]RCPCLEFLG=1
      WORDQTY += [F:POQ2]RCPQTYSTU
      WRCPQTY += [F:POQ2]RCPQTYSTU
    Else
      WORDQTY += [F:POQ2]QTYSTU
      WRCPQTY += [F:POQ2]RCPQTYSTU
    Endif
    If [M:SBCK]CLEFLG = 2 & [F:POQ2]LINCLEFLG<>2 [M:SBCK]CLEFLG=1 Endif # Issue 85502 GA 11/2012 don't close when others not closed purchases found
    # Issue 106083 - 2016-03-24 by MUARN : commande soldée
    If WORDQTY >0
      WTROUVE = 1
    Endif
  Next
  # Issue 90770 GA 08/2013 EO partially ordered
  If [M:SBCK]CLEFLG = 2 & WORDQTY<[F:SCS]EXTQTY : [M:SBCK]CLEFLG=1 Endif

Endif
# en cas de solde de la commande, ORDQTY est plafonnée par la qté réceptionnée cf SUBPTHC
If [M:SBCK]CLEFLG = 2 & WORDQTY > WRCPQTY
   WORDQTY = WRCPQTY
Endif

# FQ 78916 GA 01/2012 recalculer ORDQTY sinon Ko (idem MOD_SBC_SCI)
# If [M:SBCK]ORDQTY >= [F:SCS]EXTSTRQTY
If [M:SBCK]ORDQTY + WORDQTY > 0
    # lecture opération
    Readlock [SCS] SCS0=LSCONUM;LSCILIN;LSCSLIN
    If fstat : LRET = 1 : End : Endif

    # qté commandée
    [F:SCS]ORDQTY = [M:SBCK]ORDQTY + WORDQTY

    # chargement enr° + màj [F:SCS]ORDQTY (avant UPDATE_SCX)
    Gosub UPD_POHNUM_SCS

    # mise à jour encours
    Call UPDATE_SCX("M") From SCOLIB
    #If GOK <= 0 : LRET = 1 : Infbox "MOD_SBC_SCS: erreur UPDATE_SCX (M2)" : End : Endif

    # mise à jour opération
    Gosub REWRITE_SCS From SCOLIB

    # lock et mise à jour entête SCO
    Call UPD_SCOTRKFLG(LSCONUM, LRET) From SCOLIB

Endif

# Issue 85502 GA 11/2012 à faire tout le temps si ligne de commande soldée
# Si ligne de commande soldée et indicateur "solder sous-traitance"
#If [M:SBCK]CLEFLG = 2 & GSTRCLEMOD = 2 : Goto SOLDE_SCO_SCS : Endif
If [M:SBCK]CLEFLG = 2 : Gosub SOLDE_SCO : Endif

$FIN_MOD_SCO_SCS

# Issue 71243 - 2011-02-24 by CCC : Calcul prévisionnel après création ou modif de la commande
If GCLCEOCAUT = 3
    # appel direct possible car la boite de dlg ne s'ouvre pas
    # charger les paramètres.   # FQ 47987 avant PARAM, VALEUR
    Local Char PARAM_CLC(50)(1..14) , VAL_CLC(10)
    # Issue 84784 - 2012-09-26 by CCC
    #PARAM_CLC(1) = [F:SCO]POHFCY
    PARAM_CLC(1) = [F:SCI]PRHFCY
    PARAM_CLC(2) = LSCONUM
    PARAM_CLC(4) = "1"
    PARAM_CLC(5) = "4"
    PARAM_CLC(14) = "36"   : # VCRTYP 36 pour EO
    Call TRAITE_CHAR(VAL_CLC,PARAM_CLC,"","SUBSCC","",3,"") From GTRAITE
Endif

End


# -----------------------------------------------------
Subprog SUP_SBC_SCS(LSCONUM, LSCILIN, LSCSLIN, LPJT, LRET)
Value    Char      LSCONUM
Value    Integer   LSCILIN
Value    Integer   LSCSLIN
Value    Char      LPJT
Variable Integer   LRET

Local    Decimal   WDIFF, WWRK, WORDQTY
Local    Integer   WSTAT
Local    Char      WPOHNUM(GLONREF) : WPOHNUM=[M:SBCK]VCRNUM
Local    Integer   WPOPLIN          : WPOPLIN=[M:SBCK]VCRLIN
Local    Integer   WOPESTA
Local    Integer   WTROUVE : WTROUVE = 0
#
LRET = 0

If [F:SCO]SCONUM<>LSCONUM
  # lecture entête ordre de sous-traitance
  Read [SCO]SCO0=LSCONUM
  If fstat : LRET = 1 : End : Endif
Endif
If [F:SCI]SCONUM<>LSCONUM | [F:SCI]SCILIN<>LSCILIN
  # lecture article ordre de sous-traitance
  Read [SCI]SCI0=LSCONUM;LSCILIN
  If fstat : LRET = 1 : End : Endif
Endif
# lecture opération ordre de sous-traitance
Read [SCS]SCS0=LSCONUM;LSCILIN;LSCSLIN
WSTAT = fstat
Call ECR_DEBUG("SUP_SBC_SCS(SCOSBCLIB):"-LSCONUM) From SCOSTKAUTLIB

# mémorisation quantité
WDIFF = [F:SCS]EXTQTY

# pas de suppression dans ce cas, on laisse l'article
Case WSTAT
    When 1: # lock, on peut rien faire de plus ...
            LRET = 1
            End
    When 0: # article existant, maj
            Readlock [SCS] SCS0=LSCONUM;LSCILIN;LSCSLIN
            If fstat : LRET = 1 : End : Endif

            # Reste-t-il d'autre(s) ligne(s) de commande(s) pour ce service ?
            # GA à revoir cas d'un EO soldé ????
            WORDQTY = 0   : # Recalcul de la Qté déjà commandée
            If clalev([F:POQ2])   = 0 : Local File PORDERQ    [POQ2]   : Endif
            For [POQ2]POQ4 Where VCRTYPORI=36
&                              & VCRNUMORI=[F:SCS]SCONUM & VCRLINORI=[F:SCS]SCILIN
&                              & VCRSEQORI=[F:SCS]SCSLIN & ITMREF=[F:SCS]SRVITMREF
&                              & (POHNUM<>WPOHNUM | POPLIN<>WPOPLIN)
                # Issue 121929 - 2017-03-29 by MUARN : que si non soldé par la réception
                # Issue 106083 - 2016-03-24 by MUARN : commande soldée
                If [F:POQ2]LINCLEFLG = 2 & [F:POQ2]RCPCLEFLG=1
                  WORDQTY += [F:POQ2]RCPQTYSTU
                Else
                  WORDQTY += [F:POQ2]QTYSTU
                Endif
                # Issue 106083 - 2016-03-24 by MUARN : commande soldée
                If WORDQTY >0
                  WTROUVE = 1
                Endif
            Next
            If [F:POQ2]POHNUM="" | WTROUVE = 0
               Gosub SCS_OPESTA_INI From SCOLIB
               [F:SCS]POHNUM = ""
               [F:SCS]POPLIN = 0
               [F:SCS]POQSEQ = 0
            Elsif WTROUVE = 1
               Gosub SCS_OPESTA_PUR From SCOLIB
               [F:SCS]POHNUM = [F:POQ2]POHNUM
               [F:SCS]POPLIN = [F:POQ2]POPLIN
               [F:SCS]POQSEQ = [F:POQ2]POQSEQ
            Endif

            #If find([F:SCS]WIPTYP,2,7) => recherche à faire dans tous les cas
            #  Recherche de l'encours SCX s'il est tjs dans ORDERS
               If clalev([F:ORDW])   = 0 : Local File ORDERS    [ORDW]   : Endif
               Raz [F:SCS]WIPTYP,[F:SCS]WIPNUM,[F:SCS]WIPSTA
               Filter [ORDW] Where WIPTYP=4 & VCRTYPORI=36
&                               & VCRNUMORI=[F:SCS]SCONUM & VCRLINORI=[F:SCS]SCILIN
&                               & VCRSEQORI=[F:SCS]SCSLIN
               Read [ORDW]ORD0 First
               If !fstat
                   [F:SCS]WIPTYP=[F:ORDW]WIPTYP
                   [F:SCS]WIPNUM=[F:ORDW]WIPNUM
                   [F:SCS]WIPSTA=[F:ORDW]WIPSTA
               Endif
               Filter [ORDW]
            #Endif

            # Issue 86457 GA 12/2012
            # maj quantité totale commandée US
            [F:SCS]ORDQTY = WORDQTY

            If WORDQTY = 0
            # suppression encours
              Call UPDATE_SCX("A") From SCOLIB
              #If GOK <= 0 : LRET = 1 : End : Endif # Issue 86457 GA 12/2012

            # on recrée l'encours SCX
              Call UPDATE_SCX("C") From SCOLIB
              If GOK <= 0 : LRET = 1 : End : Endif
            Else

            # on maj l'encours SCX
              Call UPDATE_SCX("M") From SCOLIB
              #If GOK <= 0 : LRET = 1 : End : Endif
            Endif

            # mise à jour article
            Gosub REWRITE_SCS From SCOLIB
Endcase

# lock et mise à jour entête SCO
Call UPD_SCOTRKFLG(LSCONUM, LRET) From SCOLIB
#
End



############################################################################################
Subprog CRE_SBC_SCM(LSCONUM, LSCILIN, LSCMLIN, LPJT, LRET)
Value    Char      LSCONUM
Value    Integer   LSCILIN
Value    Integer   LSCMLIN
Value    Char      LPJT
Variable Integer   LRET

LRET = 0

Call ECR_DEBUG("CRE_SBC_SCM(SCOSBCLIB):"-LSCONUM) From SCOSTKAUTLIB
Call MOD_SBC_SCM(LSCONUM, LSCILIN, LSCMLIN, LPJT, LRET)

End

# -----------------------------------------------------
Subprog MOD_SBC_SCM(LSCONUM, LSCILIN, LSCMLIN, LPJT, LRET)
Value    Char      LSCONUM
Value    Integer   LSCILIN
Value    Integer   LSCMLIN
Value    Char      LPJT
Variable Integer   LRET

Local    Decimal   WORDQTY
Local    Integer   WTROUVE : WTROUVE = 0
Local    Char      WPOHNUM(GLONREF) : WPOHNUM=[M:SBCK]VCRNUM
Local    Integer   WPOPLIN          : WPOPLIN=[M:SBCK]VCRLIN

LRET = 0
If [F:SCO]SCONUM<>LSCONUM
  # lecture entête ordre de sous-traitance
  Read [SCO]SCO0=LSCONUM
  If fstat : LRET = 1 : End : Endif
Endif
If [F:SCI]SCONUM<>LSCONUM | [F:SCI]SCILIN<>LSCILIN
  # lecture article ordre de sous-traitance
  Read [SCI]SCI0=LSCONUM;LSCILIN
  If fstat : LRET = 1 : End : Endif
Endif
If [F:SCM]SCONUM<>LSCONUM | [F:SCM]SCILIN<>LSCILIN | [F:SCM]SCMLIN<>LSCMLIN
  # lecture matière ordre de sous-traitance
  Read [SCM]SCM0=LSCONUM;LSCILIN;LSCMLIN
  If fstat : LRET = 1 : End : Endif
Endif

Call ECR_DEBUG("MOD_SBC_SCM(SCOSBCLIB):"-LSCONUM) From SCOSTKAUTLIB

# Y-a-t-il d'autre(s) commande(s) pour ce composant ?
If WPOHNUM<>""
  Raz WORDQTY   : # Recalcul de la Qté en commande
  If clalev([F:POQ2])   = 0 : Local File PORDERQ    [POQ2]   : Endif
  For [POQ2]POQ4 Where VCRTYPORI=36
&                    & VCRNUMORI=[F:SCM]SCONUM & VCRLINORI=[F:SCM]SCILIN
&                    & VCRSEQORI=[F:SCM]SCMLIN & ITMREF=[F:SCM]CPNITMREF
&                    & (POHNUM<>WPOHNUM | POPLIN<>WPOPLIN)
    # Issue 121929 - 2017-03-29 by MUARN : que si non soldé par la réception
    # Issue 106083 - 2016-03-24 by MUARN : commande soldée
    If [F:POQ2]LINCLEFLG = 2 & [F:POQ2]RCPCLEFLG=1
      WORDQTY += [F:POQ2]RCPQTYSTU
    Else
      WORDQTY += [F:POQ2]QTYSTU
    Endif
    If [M:SBCK]CLEFLG = 2 & [F:POQ2]LINCLEFLG<>2 [M:SBCK]CLEFLG=1 Endif # Issue 85502 GA 11/2012 don't close when others not closed purchases found
    # Issue 106083 - 2016-03-24 by MUARN : commande soldée
    If WORDQTY >0
      WTROUVE = 1
    Endif
  Next
  # Issue 90770 GA 08/2013 don't close when EO partially ordered
  If [M:SBCK]CLEFLG = 2 & WORDQTY<[F:SCM]RETQTY : [M:SBCK]CLEFLG=1 Endif

Endif

# Issue 87203 - 2013-01-16 by CCC
## FQ 78916 GA 01/2012 déjà fait par MODIFICATION_SCO ???
#If [M:SBCK]ORDQTY + WORDQTY > [F:SCM]RETQTY
# # on augmente la qté besoin ...
#   [F:SCM]RETQTY = [M:SBCK]ORDQTY + WORDQTY
#Endif

# FQ 78916 GA 01/2012 recalculer ORDQTY sinon Ko (idem MOD_SBC_SCI)
If [M:SBCK]ORDQTY + WORDQTY > 0
      # lecture composant matière
      Readlock [SCM] SCM0=LSCONUM;LSCILIN;LSCMLIN
      If fstat : LRET = 1 : End : Endif

      # Issue 87203 - 2013-01-16 by CCC : déplacé après la lecture
      If [M:SBCK]ORDQTY + WORDQTY > [F:SCM]RETQTY
         # on augmente la qté besoin ...
         [F:SCM]RETQTY = [M:SBCK]ORDQTY + WORDQTY
      Endif

      # quantité commandée
      [F:SCM]ORDQTY = [M:SBCK]ORDQTY + WORDQTY
      If [F:SCM]ORDQTY < 0 : [F:SCM]ORDQTY=0 : Endif

      # chargement enr°
      Gosub UPD_POHNUM_SCM

      # mise à jour article
      Gosub REWRITE_SCM From SCOLIB

    # mise à jour entête SCO
      Goto FIN_MOD_SCO_SCM
Endif

$FIN_MOD_SCO_SCM
End

End

# -----------------------------------------------------
Subprog SUP_SBC_SCM(LSCONUM, LSCILIN, LSCMLIN, LPJT, LRET)
Value    Char      LSCONUM
Value    Integer   LSCILIN
Value    Integer   LSCMLIN
Value    Char      LPJT
Variable Integer   LRET

Local    Decimal   WDIFF
Local    Integer   WSTAT
Local    Integer   WTROUVE : WTROUVE = 0
Local    Char      WPOHNUM(GLONREF) : WPOHNUM=[M:SBCK]VCRNUM
Local    Integer   WPOPLIN          : WPOPLIN=[M:SBCK]VCRLIN

If [F:SCO]SCONUM<>LSCONUM
  # lecture entête ordre de sous-traitance
  Read [SCO]SCO0=LSCONUM
  If fstat : LRET = 1 : End : Endif
Endif
If [F:SCI]SCONUM<>LSCONUM | [F:SCI]SCILIN<>LSCILIN
  # lecture article ordre de sous-traitance
  Read [SCI]SCI0=LSCONUM;LSCILIN
  If fstat : LRET = 1 : End : Endif
Endif

# lecture composant matière
Read [SCM]SCM0=LSCONUM;LSCILIN;LSCMLIN
WSTAT = fstat

Call ECR_DEBUG("SUP_SBC_SCM(SCOSBCLIB):"-LSCONUM) From SCOSTKAUTLIB

# mémorisation quantité US
WDIFF = [F:SCM]RETQTY

# pas de suppression dans ce cas, on laisse l'article
Case WSTAT
    When 1: # lock, on peut rien faire de plus ...
            LRET = 1
            End
    When 0: # article existant, maj
            Readlock [SCM] SCM0=LSCONUM;LSCILIN;LSCMLIN
            If fstat : LRET = 1 : End : Endif

            # Reste-t-il d'autre(s) ligne(s) de commande(s) cette matière ?
            [F:SCM]ORDQTY = 0   : # Recalcul de la Qté en commande
            If clalev([F:POQ2])   = 0 : Local File PORDERQ    [POQ2]   : Endif
            For [POQ2]POQ4 Where VCRTYPORI=36
&                              & VCRNUMORI=[F:SCM]SCONUM & VCRLINORI=[F:SCM]SCILIN
&                              & VCRSEQORI=[F:SCM]SCMLIN & ITMREF=[F:SCM]CPNITMREF
&                              & (POHNUM<>WPOHNUM | POPLIN<>WPOPLIN)
                # Issue 121929 - 2017-03-29 by MUARN : que si non soldé par la réception
                # Issue 106083 - 2016-03-24 by MUARN : commande soldée
                If [F:POQ2]LINCLEFLG = 2 & [F:POQ2]RCPCLEFLG=1
                  [F:SCM]ORDQTY += [F:POQ2]RCPQTYSTU
                Else
                  [F:SCM]ORDQTY += [F:POQ2]QTYSTU
                Endif
                # Issue 106083 - 2016-03-24 by MUARN : commande soldée
                If [F:SCM]ORDQTY >0
                  WTROUVE = 1
                Endif
            Next
            If [F:POQ2]POHNUM="" | WTROUVE = 0
               Gosub SCM_MATSTA_INI From SCOLIB
               [F:SCM]POHNUM = ""
               [F:SCM]POPLIN = 0
               [F:SCM]POQSEQ = 0
            Else
               Gosub SCM_MATSTA_PUR From SCOLIB
               [F:SCM]POHNUM = [F:POQ2]POHNUM
               [F:SCM]POPLIN = [F:POQ2]POPLIN
               [F:SCM]POQSEQ = [F:POQ2]POQSEQ
            Endif
            # maj quantité totale commandée US
            If [M:SBCK]ORDQTY < [F:SCM]ORDQTY
               [F:SCM]ORDQTY -= [M:SBCK]ORDQTY
            Else
               [F:SCM]ORDQTY = 0
            Endif

            # mise à jour article
            Gosub REWRITE_SCM From SCOLIB
Endcase


End


############################################################################################
Subprog FAC_SBC_SCS(LSCONUM, LSCILIN, LSCSLIN, LPJT, LRET)
Value    Char      LSCONUM
Value    Integer   LSCILIN
Value    Integer   LSCSLIN
Value    Char      LPJT
Variable Integer   LRET

Local    Decimal WRKPRI, WRKCRG, WRKQTY, WPRIUO, WQTYUO, WCRGUO
Local    Decimal W_MNT,W_MNTCRG :# pour l'agrégation opératoire

Local Decimal W_INVDTA, PRIINVDTA, WRKINVDTA

Local Char WUOM(GLONUOM)
If filinfo(filpath("FIL","SCOTRK","fde",nomap),0)<=0 : LRET = 1 : End : Endif

# Issue 100967 GA 06/2014 normal invoice/credit memo
Local Decimal W_RCP, PRIRCP, WRKRCP
Raz W_RCP, PRIRCP, WRKRCP

# Issue 99332 GA 05/2014 additional invoice/credit memo
Local Decimal W_RCPFC, PRIRCPFC, WRKRCPFC
Raz W_RCPFC, PRIRCPFC, WRKRCPFC

NBOPE     = 1
WPRIUO    = 0
WRKPRI    = 0
WRKCRG    = 0
WRKQTY    = 0
LRET = 0
If [F:SCO]SCONUM<>LSCONUM
  # lecture entête ordre de sous-traitance
  Read [SCO]SCO0=LSCONUM
  If fstat : LRET = 1 : End : Endif
Endif
If [F:SCI]SCONUM<>LSCONUM | [F:SCI]SCILIN<>LSCILIN
  # lecture article ordre de sous-traitance
  Read [SCI]SCI0=LSCONUM;LSCILIN
  If fstat : LRET = 1 : End : Endif
Endif

Call ECR_DEBUG("FAC_SBC_SCS(SCOSBCLIB):"-LSCONUM) From SCOSTKAUTLIB

If !clalev([F:SCK]) : Local File SCOTRK    [SCK] : Endif

# lecture opération ordre de sous-traitance
Readlock [SCS]SCS0=LSCONUM;LSCILIN;LSCSLIN
If fstat : LRET = 1 : End : Endif

If !clalev([F:PTDW]): Local File PRECEIPTD [PTDW]: Endif # Issue 91618 GA 08/2013 ajout clalev
Filter [PTDW] Where PTHNUM=[M:SBCK]PTHNUM
&                 & PTDLIN<[M:SBCK]PTDLIN
&                 & LINTYP=2
&            Order By Key PKX=PTHNUM;PTDLIN Desc
Read [PTDW]PKX First
Filter [PTDW]
If fstat
    Call ECR_DEBUG("FAC_SBC_SCS(SCOSBCLIB):"-LSCONUM-"No receipt"-[M:SBCK]PTHNUM-num$([M:SBCK]PTDLIN)) From SCOSTKAUTLIB
    LRET=1
    GOK=0
    End
Endif

# Issue 85814 GA 12/2012 lock déplacé
Read [SCK]SCK0=[F:SCS]SCONUM;[F:SCS]SCILIN;[F:SCS]SCSLIN;0;[M:SBCK]PTHNUM;[M:SBCK]PTDLIN
If fstat
   Raz [F:SCK]
   [F:SCK] = [F:SCS]
   [F:SCK]PTHNUM = [M:SBCK]PTHNUM
   [F:SCK]PTDLIN = [M:SBCK]PTDLIN
   # Issue 100967 GA 06/2014 take care of currency conversion
   #[F:SCK]EXTPRI = [F:SCS]NETPRI * [F:SCS]OPESTRCOE    # Issue 90045   # Prix de la rcp ????
   If [F:SCS]EXTSTRQTY<>0
      [F:SCK]EXTPRI = [F:SCS]LINAMTL / [F:SCS]EXTSTRQTY
   Endif
   # Issue 100967 GA 06/2014
   If [F:PTD]PTHNUM=[M:SBCK]PTHNUM & [F:PTD]PTDLIN = [M:SBCK]PTDLIN & [F:PTD]INVQTYSTU<>0
      [F:SCK]INVQTY = [F:PTD]INVQTYSTU
   Endif
   Gosub WRITE_SCK From SCOLIB
Endif
Readlock [SCK]SCK0=[F:SCS]SCONUM;[F:SCS]SCILIN;[F:SCS]SCSLIN;0;[M:SBCK]PTHNUM;[M:SBCK]PTDLIN
If fstat : LRET = 1 : End : Endif # Issue 85814 GA 12/2012

# Issue 99332 GA 05/2014 idem SBCLIB
WUOM=[F:SCS]OPESTU
Gosub FAC_SBC_SCK

[F:SCS]INVQTY = [F:SCK]INVQTY           # Issue 87727 GA 02/2013

Gosub REWRITE_SCK From SCOLIB
If GOK < 1 : End : Endif

# mise à jour opération
Gosub REWRITE_SCS From SCOLIB
If GOK < 1 : End : Endif

# FQ 70864 GA 02/2011
If !clalev([M:SDP]) : Local Mask SAIDECPRI [SDP] : Endif
Raz [M:SDP]
# mise à jour Wipcost
[M:SDP]QTY = [F:SCK]CPLQTY
[M:SDP]AMTTOT = arr(W_MNT,10^-8)
#[M:SDP]INVDTACST = [M:SBCK]INVDTACST
[M:SDP]INVDTACST = arr(W_INVDTA,10^-8)
[M:SDP]SCOTOT = W_MNT-[M:SDP]INVDTACST
Call ECR_DEBUG("FAC_SBC_SCS(SCOSBCLIB):"-[F:SCS]PRHFCY+";"+[M:SBCK]PTHNUM+";"+num$([M:SBCK]PTDLIN)+";"+"36"+";"+[F:SCS]SCONUM+";"+num$([F:SCS]SCILIN)+";"+[F:SCS]SRVITMREF) From SCOSTKAUTLIB
Call SCEOPEPRI_MOD([F:PTDW]PTHNUM,[F:PTDW]PTDLIN,"",LRET) From MWIPLIB
#If LRET = 1 : End : Endif

#Close File [PTDW] # Issue 91618 GA 08/2013
End

############################################################################################
Subprog FAC_SBC_SCM(LSCONUM, LSCILIN, LSCMLIN, LPJT, LRET)
Value    Char      LSCONUM
Value    Integer   LSCILIN
Value    Integer   LSCMLIN
Value    Char      LPJT
Variable Integer   LRET

Local    Decimal WRKPRI, WRKCRG, WRKQTY, WPRIUO, WQTYUO, WCRGUO
Local    Decimal W_MNT,W_MNTCRG :# pour l'agrégation opératoire

Local Decimal W_INVDTA, PRIINVDTA, WRKINVDTA

Local Char WUOM(GLONUOM)
If filinfo(filpath("FIL","SCOTRK","fde",nomap),0)<=0 : LRET = 1 : End : Endif

# Issue 100967 GA 06/2014 normal invoice/credit memo
Local Decimal W_RCP, PRIRCP, WRKRCP
Raz W_RCP, PRIRCP, WRKRCP

# Issue 99332 GA 05/2014 additional invoice/credit memo
Local Decimal W_RCPFC, PRIRCPFC, WRKRCPFC
Raz W_RCPFC, PRIRCPFC, WRKRCPFC

NBOPE     = 1
WPRIUO    = 0
WRKPRI    = 0
WRKCRG    = 0
WRKQTY    = 0
LRET = 0

If [F:SCO]SCONUM<>LSCONUM
  # lecture entête ordre de sous-traitance
  Read [SCO]SCO0=LSCONUM
  If fstat : LRET = 1 : End : Endif
Endif
If [F:SCI]SCONUM<>LSCONUM | [F:SCI]SCILIN<>LSCILIN
  # lecture article ordre de sous-traitance
  Read [SCI]SCI0=LSCONUM;LSCILIN
  If fstat : LRET = 1 : End : Endif
Endif

Call ECR_DEBUG("FAC_SBC_SCM(SCOSBCLIB):"-LSCONUM) From SCOSTKAUTLIB

Readlock [SCM]SCM0=LSCONUM;LSCILIN;LSCMLIN
If fstat : LRET = 1 : End : Endif

# Issue 99332 GA 05/2014 idem FAC_SBC_SCS
If !clalev([F:PTDW]): Local File PRECEIPTD [PTDW]: Endif
Filter [PTDW] Where PTHNUM=[M:SBCK]PTHNUM
&                 & PTDLIN<[M:SBCK]PTDLIN
&                 & LINTYP=2
&            Order By Key PKX=PTHNUM;PTDLIN Desc
Read [PTDW]PKX First
Filter [PTDW]
If fstat
    Call ECR_DEBUG("FAC_SBC_SCM(SCOSBCLIB):"-LSCONUM-"No receipt"-[M:SBCK]PTHNUM-num$([M:SBCK]PTDLIN)) From SCOSTKAUTLIB
    LRET=1
    GOK=0
    End
Endif

# Issue 85814 GA 12/2012 lock déplacé
Read [SCK]SCK0=[F:SCM]SCONUM;[F:SCM]SCILIN;[F:SCM]SCSLIN;[F:SCM]SCMLIN;[M:SBCK]PTHNUM;[M:SBCK]PTDLIN
If fstat
   Raz [F:SCK]
   [F:SCK] = [F:SCM]
   [F:SCK]PTHNUM = [M:SBCK]PTHNUM
   [F:SCK]PTDLIN = [M:SBCK]PTDLIN
   # Issue 103563 GA 10/2014 [F:SCM]QTYSTU Ko
   # Issue 100967 GA 06/2014 take care of currency conversion
   #[F:SCK]EXTPRI = [F:SCM]NETPRI / [F:SCM]BOMSTUCOE    # Issue 90045   # Prix de la rcp ????
   If [F:SCM]INVQTY<>0
      [F:SCK]EXTPRI = [F:SCM]LINAMTL / [F:SCM]INVQTY
   Endif
   # Issue 100967 GA 06/2014
   If [F:PTD]PTHNUM=[M:SBCK]PTHNUM & [F:PTD]PTDLIN = [M:SBCK]PTDLIN & [F:PTD]INVQTYSTU<>0
      [F:SCK]INVQTY = [F:PTD]INVQTYSTU
   Endif
   [F:SCK]CPLQTY=[F:SCM]USEQTY # Issue 103563 GA 11/2014 used qty
   Gosub WRITE_SCK From SCOLIB
Endif
Readlock [SCK]SCK0=[F:SCM]SCONUM;[F:SCM]SCILIN;[F:SCM]SCSLIN;[F:SCM]SCMLIN;[M:SBCK]PTHNUM;[M:SBCK]PTDLIN
If fstat : LRET = 1 : End : Endif # Issue 85814 GA 12/2012

# FQ 79859 GA 04/2012 éviter division par zéro
If [F:SCM]BOMUOM = "" | [F:SCM]BOMSTUCOE=0
   [F:SCM]BOMUOM   = [F:SCM]STU
   [F:SCM]BOMSTUCOE= 1
   [F:SCM]BOMQTY   = [F:SCM]LIKQTY
Endif

# Issue 99332 GA 05/2014 idem SBCLIB
WUOM=[F:SCM]BOMUOM
Gosub FAC_SBC_SCK

[F:SCM]INVQTY = [F:SCK]INVQTY           # Issue 99332 GA 05/2014

Gosub REWRITE_SCK From SCOLIB
If GOK < 1 : End : Endif

# mise à jour matière
Gosub REWRITE_SCM From SCOLIB

If !clalev([M:SDP]) : Local Mask SAIDECPRI [SDP] : Endif
Raz [M:SDP]
# Issue 86964 - 2013-02-04 by CCC
## mise à jour Wipcost
## Issue 71362 - 2011-04-18 by CCC : Modification du prix d'une matière fournie par le sous-traitant => màj Wipcost
#[M:SDP]QTY = [M:SBCK]INVQTY
[M:SDP]QTY = [F:SCK]CPLQTY
[M:SDP]AMTTOT = W_MNT
If GACTDECCST
    If [F:ITM]ITMREF<>[F:SCM]CPNITMREF
        Read [F:ITM]ITM0=[F:SCM]CPNITMREF
    Endif
    [M:SDP]MATCST(max(0,[F:ITM]BRDCOD-1)) = W_MNT-[M:SBCK]INVDTACST
    [M:SDP]INVDTACST = [M:SBCK]INVDTACST
Endif

Call ECR_DEBUG("FAC_SBC_SCM(SCOSBCLIB):"-[F:SCM]STOFCY+";"+[M:SBCK]PTHNUM+";"+num$([M:SBCK]PTDLIN)+";"+"36"+";"+[F:SCM]SCONUM+";"+num$([F:SCM]SCILIN)+";"+[F:SCM]CPNITMREF) From SCOSTKAUTLIB
# Issue 99332 GA 05/2014
# 1) use [F:PTDW]PTHNUM and [F:PTDW]PTDLIN
# 2) [F:SCM]SCILIN instead of [F:SCM]SCMLIN
#Call SCMPRI_MOD(6,[M:SBCK]PTHNUM,[M:SBCK]PTDLIN,36,[F:SCM]SCONUM,[F:SCM]SCMLIN,[F:SCM]CPNITMREF,LRET) From MWIPLIB
Call SCMPRI_MOD(6,[F:PTDW]PTHNUM,[F:PTDW]PTDLIN,36,[F:SCM]SCONUM,[F:SCM]SCILIN,[F:SCM]CPNITMREF,LRET) From MWIPLIB
If LRET = 1 : End : Endif

End

############################################################################################
Subprog FAC_SBC_SCI(LSCONUM, LSCILIN, LPJT, LRET)
Value    Char      LSCONUM
Value    Integer   LSCILIN
#Value    Integer   LSCMLIN  # FQ 69909 Ctrl des source
Value    Char      LPJT
Variable Integer   LRET

LRET=0

If [F:SCO]SCONUM<>LSCONUM
  # lecture entête ordre de sous-traitance
  Read [SCO]SCO0=LSCONUM
  If fstat : LRET = 1 : End : Endif
Endif

Call ECR_DEBUG("FAC_SBC_SCI(SCOSBCLIB):"-LSCONUM) From SCOSTKAUTLIB

Readlock [SCI]SCI0=LSCONUM;LSCILIN
If fstat : LRET = 1 : End : Endif

[F:SCI]INVQTY += [M:SBCK]INVQTY
If [F:SCI]INVQTY<0 : [F:SCI]INVQTY=0 : Endif

# Mise à jour article lancé
Gosub REWRITE_SCI From SCOLIB

End


############################################################################################
$FAC_SBC_SCK                                           # Issue 99332 GA 05/2014 idem SBCLIB
W_MNT = 0 : W_INVDTA = 0
W_RCP = 0 : W_RCPFC  = 0

# Issue 100967 GA 06/2014
W_RCP  = func SBCLIB.SUMRCP(36,[F:SCK]SCONUM,[F:SCK]POHNUM, [F:SCK]POPLIN)
If [F:SCK]CPLQTY<>0 # Issue 103563 GA 11/2014 no zero division
     PRIRCP = W_RCP / [F:SCK]CPLQTY
Else PRIRCP=0 Endif
Case [F:SCK]LINTYP
   When 3 : Gosub READ_MWI_SCS
            # Issue 119759 - 2017-01-06 by CCC : Invoicing elts are apart of service only. For components, they still are included in material cost.
            W_INVDTA  = -func MWIPLIB.SUMINVDTA(36,[F:SCK]SCONUM,[F:PTDW]PTHNUM, [F:PTDW]PTDLIN)
            W_MNT += W_INVDTA   # W_MNT = total of the subcontracting cost (service + invoicing elements)
            PRIINVDTA = -W_INVDTA / [F:SCK]CPLQTY

   When 4 : Gosub READ_MWI_SCM
Endcase

# Issue 99332 GA 06/2014
W_RCPFC  = func SBCLIB.SUMRCPFC(36,[F:SCK]SCONUM,[F:SCK]POHNUM, [F:SCK]POPLIN)
If [F:SCK]CPLQTY<>0 # Issue 103563 GA 11/2014 no zero division
     PRIRCPFC = W_RCPFC / [F:SCK]CPLQTY
Else PRIRCPFC=0 Endif

If W_MNT<>0  # Issue 100967 GA 06/2014 actual cost was read from MWI

Elsif ([F:SCK]CPLPRI + [F:SCK]CPLCRG)=0
    W_MNT -= [F:SCK]EXTPRI * [F:SCK]CPLQTY
Else
    W_MNT -= ([F:SCK]CPLPRI + [F:SCK]CPLCRG) * [F:SCK]CPLQTY
    If [F:SCK]CPLQTY=0
        PRIINVDTA=0
# Issue 119759 - 2017-01-06 by CCC
#    Else
#        W_INVDTA  = -func MWIPLIB.SUMINVDTA(36,[F:SCK]SCONUM,[F:PTDW]PTHNUM, [F:PTDW]PTDLIN)
#        PRIINVDTA = -W_INVDTA / [F:SCK]CPLQTY
    Endif
Endif

# Issue X3-74811 - 2018-02-22 MJH.sn
# A credit memo uses a different context for the values in [M:SBCK]INVQTY and [M:SBCK]CPLPRI
# so WQTYUO and WPRIUO need to be calculated differently
If dim([M:PIH0]PIHTYP) > 0 and [M:PIH0]PIHTYP = 3
  If [F:PID]QTYPUU=[F:PID]ORIQTYPUU
    WQTYUO = 0
  Else
    #This is the amount that is has changed by
    #current invoiced amount - Previous invoiced amount
    WQTYUO = [F:PID]QTYPUU - [F:SCK]INVQTY
  Endif
Else
  WQTYUO = [M:SBCK]INVQTY# X3-74811.o
Endif # X3-74811.en

Call QTEARR(WQTYUO,WUOM) From TRTDIV

# Issue X3-74811 - 2018-02-22 MJH.sn
If dim([M:PIH0]PIHTYP) > 0 and [M:PIH0]PIHTYP = 3
  WPRIUO = [F:PID]QTYPUU*[F:PID]NETPRI - [F:SCK]INVQTY*[F:SCK]CPLPRI
  WCRGUO = 0
Else
  WPRIUO = [M:SBCK]CPLPRI # Issue X3-74811.o
	WCRGUO = [M:SBCK]CPLCRG
Endif# Issue X3-74811.en



# Il n'y a pas encore de  quantité facturée =  On traite la 1ere facture
If [F:SCK]INVQTY = 0
    # La quantité de la facture en cours de validation est <> 0 : Facture
    If WQTYUO<>0
    # Case 1: first standard invoice
        # CCC (09/06/08) Bug 47814 : Lors de la 1ère facturation, [F:SCK]CPLPRI est nul, il faut prendre EXTPRI
        W_MNT = -[F:SCK]EXTPRI * [F:SCK]CPLQTY + W_INVDTA - W_RCPFC  # Issue 99967 GA 06/2014 additionnal invoice ?
        # CCC (05/05/08) Bug 47214
        #[F:SCK]INVQTY += WQTYUO
        #[F:SCK]CPLPRI += WPRIUO
        #[F:SCK]CPLCRG += WCRGUO
        [F:SCK]INVQTY = WQTYUO
        [F:SCK]CPLPRI = WPRIUO + PRIRCPFC # Issue 99967 GA 06/2014 additionnal invoice ?
        [F:SCK]CPLCRG = WCRGUO

        PRIINVDTA = [M:SBCK]INVDTACST / WQTYUO   # Issue 119759 - 2017-01-06 by CCC
   # La quantité de la facture en cours de validation est =  0 : Facture complémentaire
    Else
   # Case 2: first invoice is an additional invoice, have to keep standard qty & cost
   # Issue 99332 GA 05/2014: case WQTYUO=0
   # W_RCPFC contains all additional invoices including the current one
        WRKQTY         = [F:SCK]CPLQTY
        WRKPRI         = ([F:SCK]CPLQTY * [F:SCK]EXTPRI) + W_RCPFC
        WRKCRG         = ([F:SCK]CPLQTY * [F:SCK]CPLCRG) + WCRGUO
        WRKINVDTA      = ([F:SCK]CPLQTY * PRIINVDTA) + [M:SBCK]INVDTACST
        If WRKQTY<>0
            [F:SCK]CPLPRI  = WRKPRI / WRKQTY
            [F:SCK]CPLCRG  = WRKCRG / WRKQTY
            PRIINVDTA = WRKINVDTA / WRKQTY
        Endif
    Endif
# Il y a déjà une quantité facturée : On traite la Xième Facture ou Avoir ou Facture complémentaire
Else
    # La quantité de la facture en cours de validation est <> 0 : Facture ou avoir en quantité
    If WQTYUO <> 0
   # Case 3: next invoice(s)/credit memo
        WRKQTY         = [F:SCK]INVQTY + WQTYUO
        # Issue X3-74811 - 2018-02-22 MJH.n
        # for credit memos, the value in WPRIUO already is adjusted by the quantity
        If dim([M:PIH0]PIHTYP) > 0 and [M:PIH0]PIHTYP = 3
          WRKPRI         = ([F:SCK]INVQTY * [F:SCK]CPLPRI) + WPRIUO
        Else
          WRKPRI         = ([F:SCK]INVQTY * [F:SCK]CPLPRI) + (WQTYUO * WPRIUO) #X3-74811.o
        Endif
        WRKCRG         = ([F:SCK]INVQTY * [F:SCK]CPLCRG) + (WQTYUO * WCRGUO)
        WRKINVDTA      = ([F:SCK]INVQTY * PRIINVDTA) + [M:SBCK]INVDTACST

        # si avoir total, les quantités et prix facture/avoir s'annulent
        # le prix unitaire doit redevenir le prix prévu,la quantité facturée et les frais réels repassent à 0
        If WRKQTY = 0
            # Issue X3-38394 - 2017-05-22 by CCC : Total invoice amount should be equal to 0 if new invoiced qty=0
            # As is currently written, SBCLIB.SUMRCP can't provide a correct amount (consider STA, taxes...)
            ## Issue 102605 GA 12/2014 invoice + credit invoice with value not null stored in PRIRCP
            #[F:SCK]CPLPRI = [F:SCK]EXTPRI + PRIRCP + PRIRCPFC
            [F:SCK]CPLPRI = [F:SCK]EXTPRI + PRIRCPFC
            [F:SCK]CPLCRG = 0
            [F:SCK]INVQTY = 0
            PRIINVDTA = 0
        Elsif WRKQTY<>0
            [F:SCK]CPLPRI  = WRKPRI / WRKQTY
            [F:SCK]CPLCRG  = WRKCRG / WRKQTY  # Appliqué à la qté totale
            [F:SCK]INVQTY += WQTYUO
            PRIINVDTA = WRKINVDTA / WRKQTY
        Endif
    # La quantité de la facture en cours de validation est =0 : Facture complémentaire ou avoir en valeur
    Else
    # Case 4: additionnal invoice(s)/credit memo in value mode
        # Issue 119759 - 2017-03-10 by CCC : It's absolutely not sure that additional invoice is only applied in function of what has already been invoiced
        If dim([M:PIH0]PIHTYP) > 0 and [M:PIH0]PIHTYP = 3#X3-74811.sn
          WRKQTY         = [F:SCK]INVQTY
        Else
          WRKQTY         = [F:SCK]CPLQTY#X3-74811.o
        Endif#X3-74811.en
        WRKPRI         = (WRKQTY * [F:SCK]CPLPRI) + WPRIUO
        WRKCRG         = (WRKQTY * [F:SCK]CPLCRG) + WCRGUO
        WRKINVDTA      = (WRKQTY * PRIINVDTA) + [M:SBCK]INVDTACST
        [F:SCK]CPLPRI  = WRKPRI / WRKQTY
        [F:SCK]CPLCRG  = WRKCRG / WRKQTY
        PRIINVDTA      = WRKINVDTA / WRKQTY
    Endif
Endif

# Issue 119759 - 2017-03-10 by CCC
## Issue 99967 GA 06/2014 credit invoice in Qty
# Issue X3-74811 - 2018-02-22 MJH.
#We only want to run through this when we are coming from a credit memo.
#If the invoiced quantity is different from the received quantity, we want to use invoiced quantity for calculating costs
If dim([M:PIH0]PIHTYP) > 0 and [M:PIH0]PIHTYP = 3 and [F:SCK]INVQTY<>[F:SCK]CPLQTY
   W_MNT += [F:SCK]CPLPRI * [F:SCK]INVQTY
   W_MNT += [F:SCK]CPLCRG * [F:SCK]INVQTY  # delta à compter pour l'agrégation (interface tps)
   W_INVDTA += PRIINVDTA * [F:SCK]INVQTY
Else
   W_MNT += [F:SCK]CPLPRI * [F:SCK]CPLQTY
   W_MNT += [F:SCK]CPLCRG * [F:SCK]CPLQTY  # delta à compter pour l'agrégation (interface tps)
   W_INVDTA += PRIINVDTA * [F:SCK]CPLQTY
Endif
If dim([M:SBCK]ECCVALMAJ)>0 & [M:SBCK]ECCVALMAJ<>"" # Issue 107513/US4 GA 04/2015
   [F:SCK]ECCVALMAJ  = [M:SBCK]ECCVALMAJ
   [F:SCK]ECCVALMIN  = [M:SBCK]ECCVALMIN
Endif
Return

# Issue 100967 GA 06/2014 WIPCOST are linked to LINTYP=2 subcontracted item
# Receipt line reference is in [F:PTDW]PTHNUM, [F:PTDW]PTDLIN
#####################################################################
#  1 - Coût matière
#  5 - Frais matière
#####################################################################
$READ_MWI_SCM
Raz [F:MWI]
W_MNT    -= func SBCLIB.SUMTXNTYP(36,[F:SCM]SCONUM,[F:SCM]SCILIN,[F:SCM]SCMLIN,[F:PTDW]PTHNUM, [F:PTDW]PTDLIN,1)
W_MNTCRG -= func SBCLIB.SUMTXNTYP(36,[F:SCM]SCONUM,[F:SCM]SCILIN,[F:SCM]SCMLIN,[F:PTDW]PTHNUM, [F:PTDW]PTDLIN,5)
Return

# Issue 100967 GA 06/2014 WIPCOST are linked to LINTYP=2 subcontracted item
# Receipt line reference is in [F:PTDW]PTHNUM, [F:PTDW]PTDLIN
#####################################################################
#  4 - Coût sous-traitance
#  8 - Frais sous-traitance
#####################################################################
$READ_MWI_SCS
Raz [F:MWI]
W_MNT    -= func SBCLIB.SUMTXNTYP(36,[F:SCS]SCONUM,[F:SCS]SCILIN,0,[F:PTDW]PTHNUM, [F:PTDW]PTDLIN,4)
W_MNTCRG -= func SBCLIB.SUMTXNTYP(36,[F:SCS]SCONUM,[F:SCS]SCILIN,0,[F:PTDW]PTHNUM, [F:PTDW]PTDLIN,8)
Return


############################################################################################
$UPD_POHNUM_SCI
Local Integer WRET : WRET=0
#
Gosub SCI_ITMSTA_PUR From SCOLIB
[F:SCI]POHNUM = [M:SBCK]VCRNUM
[F:SCI]POPLIN = [M:SBCK]VCRLIN
[F:SCI]POQSEQ = [M:SBCK]VCRSEQ
####[F:SCI]ORDQTY += [M:SBCK]ORDQTY # déjà fait selon contexte
#
Return

############################################################################################
$UPD_POHNUM_SCS
Local Integer WRET : WRET=0
#
Gosub SCS_OPESTA_PUR From SCOLIB
[F:SCS]POHNUM = [M:SBCK]VCRNUM
[F:SCS]POPLIN = [M:SBCK]VCRLIN
[F:SCS]POQSEQ = [M:SBCK]VCRSEQ
####[F:SCS]ORDQTY += [M:SBCK]ORDQTY # déjà fait selon contexte

# FQ 75631 GA 09/2011 NETPRI relu sur [F:POP]
If clalev([F:POPW]) = 0 : Local File PORDERP     [POPW] : Endif  # ligne de cde
# Issue X3-72637-25003 - 2018-01-22 by SR : Gérer la différence de devise
If clalev([F:POHW]) = 0 : Local File PORDER      [POHW] : Endif  # entête de cde
If [F:SCS]POHNUM<>""
   Read [POPW]POP0= [F:SCS]POHNUM;[F:SCS]POPLIN;[F:SCS]POQSEQ
   If fstat Raz [F:POPW] Endif
   # Issue X3-72637-25003 - 2018-01-22 by SR : Gérer la différence de devise
   Read [F:POHW]POH0 = [F:POPW]POHNUM
   If fstat : Raz [F:POHW] : Endif
Endif
# Issue X3-72637-25003 - 2018-01-22 by SR : Gérer la différence de devise
#If [F:POPW]NETPRI<>0 & [F:POPW]NETPRI<>[F:SCS]NETPRI
If ([F:POHW]CUR = [F:SCO]CUR & [F:POPW]NETPRI<>0 & [F:POPW]NETPRI<>[F:SCS]NETPRI) | ([F:POHW]CUR <> [F:SCO]CUR & [F:POPW]NETPRI<>0 )
    # même devise, prix différents
    If [F:POHW]CUR = [F:SCO]CUR
     [F:SCS]NETPRI = [F:POPW]NETPRI
     [F:SCS]GROPRI = [F:POPW]GROPRI
    # devises différentes
    Else
      Call CONVERT2([F:POHW]CUR,[F:SCO]CUR,GLOCALDEV,[F:SCO]CHGTYP,datesyst,
&                   [F:POPW]NETPRI,[F:SCS]NETPRI,WRET) From TRTDEV
      Call CONVERT2([F:POHW]CUR,[F:SCO]CUR,GLOCALDEV,[F:SCO]CHGTYP,datesyst,
&                   [F:POPW]GROPRI,[F:SCS]GROPRI,WRET) From TRTDEV
    Endif
   [F:SCS]PRIREN = [F:POPW]PRIREN
   Gosub CALC_LINAMT_SCS  From SCOLIB
Endif
Return

############################################################################################
$UPD_POHNUM_SCM
# Issue X3-72637-25003 - 2018-01-22 by SR
Local Integer WRET : WRET=0
#
Gosub SCM_MATSTA_PUR From SCOLIB
[F:SCM]POHNUM = [M:SBCK]VCRNUM
[F:SCM]POPLIN = [M:SBCK]VCRLIN
[F:SCM]POQSEQ = [M:SBCK]VCRSEQ
####[F:SCM]ORDQTY += [M:SBCK]ORDQTY
If [M:SBCK]RCPDAT <> [0/0/0] & [F:SCM]SCOFLG=2  # cas impossible: lignes non commandées
   Local Integer WOFS : WOFS=[F:SCM]BOMOFS
   Local Date    WSTRDAT,WENDDAT
   If [F:SCS]OPESTR<>[0/0/0] WSTRDAT=[F:SCS]OPESTR Else WSTRDAT=[M:SBCK]ORDDAT Endif
   If [F:SCS]OPEEND<>[0/0/0] WENDDAT=[F:SCS]OPEEND Else WENDDAT=[M:SBCK]RCPDAT Endif
   Call UPD_MAT_DAT(WSTRDAT, WENDDAT,[F:SCM]STOFCY,WOFS,[F:SCM]DLVDAT) From SCOLIB
Endif
#
# FQ 75631 GA 09/2011 NETPRI relu sur [F:POP]
If clalev([F:POPW]) = 0 : Local File PORDERP     [POPW] : Endif  # ligne de cde
# Issue X3-72637-25003 - 2018-01-22 by SR : Gérer la différence de devise
If clalev([F:POHW]) = 0 : Local File PORDER      [POHW] : Endif  # entête de cde
If [F:SCM]POHNUM<>""
   Read [POPW]POP0= [F:SCM]POHNUM;[F:SCM]POPLIN;[F:SCM]POQSEQ
   If fstat Raz [F:POPW] Endif
   # Issue X3-72637-25003 - 2018-01-22 by SR : Gérer la différence de devise
   Read [F:POHW]POH0 = [F:POPW]POHNUM
   If fstat : Raz [F:POHW] : Endif
Endif
# Issue X3-72637-25003 - 2018-01-22 by SR : Gérer la différence de devise+ Comparer [F:POPW]NETPRI avec [F:SCM]NETPRI
#If [F:POPW]NETPRI<>0 & [F:POPW]NETPRI<>[F:SCS]NETPRI
If ([F:POHW]CUR = [F:SCO]CUR & [F:POPW]NETPRI<>0 & [F:POPW]NETPRI<>[F:SCM]NETPRI) | ([F:POHW]CUR <> [F:SCO]CUR & [F:POPW]NETPRI<>0 )
    # même devise, prix différents
    If [F:POHW]CUR = [F:SCO]CUR
      [F:SCM]NETPRI = [F:POPW]NETPRI
      [F:SCM]GROPRI = [F:POPW]GROPRI
    # devises différentes
    Else
      Call CONVERT2([F:POHW]CUR,[F:SCO]CUR,GLOCALDEV,[F:SCO]CHGTYP,datesyst,
&                   [F:POPW]NETPRI,[F:SCM]NETPRI,WRET) From TRTDEV
      Call CONVERT2([F:POHW]CUR,[F:SCO]CUR,GLOCALDEV,[F:SCO]CHGTYP,datesyst,
&                   [F:POPW]GROPRI,[F:SCM]GROPRI,WRET) From TRTDEV
    Endif
   [F:SCM]PRIREN = [F:POPW]PRIREN
   Gosub CALC_LINAMT_SCM  From SCOLIB
Endif

Return




############################################################################################
Subprog VERIF_MAT_SCO(LSCONUM, LSCILIN, LMAT)
Value     Char     LSCONUM
Value     Integer  LSCILIN
Variable  Char     LMAT
Local     Integer TROUVE
Local     Char    WBPRNUM(GLONBPR) : WBPRNUM = [M:SBCK]BPSNUM
Local     Char    WBPAADD(GLONBPD) : WBPAADD = [M:SBCK]BPAADD

If clalev([F:BPS])   = 0 : Local File BPSUPPLIER    [BPS]   : Endif

LMAT = ""

Read [SCO]SCO0=LSCONUM
If fstat : End : Endif

# parcours des matières "mises à dispo du sous-traitant"
For [SCM]SCM0 Where SCONUM = LSCONUM & SCILIN=LSCILIN & SCOFLG=2 & MATSTA<>4
    If [F:SCM]MATSTA < 3
            # FQ 55325 message seult si maj
            # si matière allouée détail, message
            # If [F:SCM]ALLSTA > 3 : LMAT = [F:SCM]CPNITMREF : Endif
            # Recherche de l'emplacement du client livré
            If WBPRNUM <> "" & WBPAADD <> ""
                Gosub READ_BPD From BPRLIB
                If [F:BPD]SCOLOC <> ""
                    If [F:SCM]LOC <> [F:BPD]SCOLOC    # FQ 55325 message seult si maj
                      [F:SCM]LOC = [F:BPD]SCOLOC
                      If [F:SCM]ALLSTA > 3 : LMAT = [F:SCM]CPNITMREF : Endif
                    Endif
                    TROUVE = 1
                Endif
            Endif
            # Recherche de l'emplacement du fournisseur
            If TROUVE =0
                If WBPRNUM <> ""
                    Gosub READ_BPS From BPRLIB
                    If [F:BPS]LOC <> ""
                        If [F:SCM]LOC <> [F:BPS]LOC    # FQ 55325 message seult si maj
                          [F:SCM]LOC = [F:BPS]LOC
                          If [F:SCM]ALLSTA > 3 : LMAT = [F:SCM]CPNITMREF : Endif
                        Endif
                        TROUVE = 1
                    Endif
                Endif
            Endif
            If TROUVE : Gosub REWRITE_SCM From SCOLIB : Endif
    Endif
Next

End

#############################################################
$SOLDE_SCO
# Issue 89749 GA 05/2013 WAUTO manquant pour l'appel SOLDE_MAT
Local Integer   WAUTO : WAUTO=0
Local Integer   WOPESTA,WITMSTA,WSCOSTA
Local Integer WOPECLENBR, WITMCLENBR, WMATCLENBR

    # lock ordre de sous-traitance
    Readlock [SCO] SCO0=LSCONUM
    If fstat : LRET = 1 : End : Endif

    # lecture article
    Readlock [SCI] SCI0=LSCONUM;LSCILIN
    If fstat : LRET = 1 : End : Endif

    If dim(LSCSLIN)>0
      # lock opération
      Readlock [SCS] SCS0=LSCONUM;LSCILIN;LSCSLIN
      If fstat : LRET = 1 : End : Endif
    Else
      # lock opération
      Readlock [SCS] SCS0(2)=LSCONUM;LSCILIN
      If fstat : LRET = 1 : End : Endif
    Endif

    #----------------------- Solde des matières   -----------------------------#
    For [F:SCM] Where SCONUM = [F:SCO]SCONUM With Lock
        Gosub SOLDE_MAT From FUNTEOCLO
        If GOK < 1 : Break : Endif
        Gosub REWRITE_SCM From SCOLIB
    Next

    # mise à jour article lancé
    #Gosub UPD_POHNUM_SCI
    Gosub SOLDE_ITM From FUNTEOCLO
    Gosub REWRITE_SCI From SCOLIB

    # mise à jour opération sous-traitance
    #Gosub UPD_POHNUM_SCS
    Gosub SOLDE_OPE From FUNTEOCLO
    Gosub REWRITE_SCS From SCOLIB

    # mise à jour entete
    Gosub SCO_SCOSTA_CLO From SCOLIB
    Gosub REWRITE_SCO From SCOLIB

    # lock et mise à jour entête SCO
    Call UPD_SCOTRKFLG(LSCONUM, LRET) From SCOLIB
    If LRET = 1 : End : Endif

Return


$MODIFICATION_SCO
#-----------------------------#
# Maj ordre de sous-traitance #
# WSTA, WEXTQTY à renseigner  #
#-----------------------------#
    If clalev([M:SCOK])  = 0 : Local Mask SCOK  [SCOK]  : Endif

    If dim(WSTA)<=0 | dim(WEXTQTY) <= 0 | dim(WNEWBPS) <= 0
       #Infbox "MODIFICATION_SCO(SCOSBCLIB): erreur interne !!!"
       LRET = 10 : Return
    Endif

    Raz [M:SCOK]
    [M:SCOK]CODMAJ = "M"
    #[M:SCOK]CODTRS = 2 : # inutilisé ...
    [M:SCOK]SCONUM = LSCONUM
    [M:SCOK]SCILIN = LSCILIN
    If WNEWBPS
       [M:SCOK]BPRNUM = [M:SBCK]BPSNUM # FQ 54554 si cde sur un autre fournisseur
       [M:SCOK]BPAADD = [M:SBCK]BPAADD # FQ 54554 si cde sur un autre fournisseur = [F:POQ]SCOADD
       If dim([M:SCOK]PRHADD)>0 & [F:POQ]FCYADD<>""  # Issue 88018 GA 02/2013
           [M:SCOK]PRHADD = [F:POQ]FCYADD
       Endif
     # Issue 93771 GA 12/2013
       Local Char MESS1(250) : MESS1 = [M:SCOK]BPRNUM-":"-mess(461,194,1)-[M:SCOK]SCONUM
       Call ECR_TRACE(MESS1,1) From GESECRAN
       LRET = 10
       Return
    Endif
    [M:SCOK]POHFCY = [F:SCO]POHFCY
    [M:SCOK]PRHFCY = [F:SCI]PRHFCY     # Issue 86437 GA 12/2012
    [M:SCOK]SCOSTA = WSTA
    [M:SCOK]ITMREF = [F:SCI]ITMREF
    [M:SCOK]BOMALT = [F:SCI]BOMALT
    # Issue 96725 GA 02/2014 only one PO
    If dim([M:SCOK]PRHADD)>0 & !WTROUVE
       [M:SCOK]PRHFCY = [F:POQ]PRHFCY
       [M:SCOK]PRHADD = [F:POQ]FCYADD
    Endif

    Local Decimal WQTYPUU, WCOEF
    If WEXTQTY<>[F:SCI]EXTQTY
       Call UPD_ITM_QTY(1,[F:SCI]STU,WEXTQTY,[F:SCI]PUU,WQTYPUU,WCOEF,-1) From SCOLIB
    Else
       WQTYPUU = [F:SCI]QTYPUU
    Endif
    [M:SCOK]PUU    = [F:SCI]PUU
    [M:SCOK]QTYPUU = WQTYPUU
    [M:SCOK]EXTQTY = WEXTQTY
    [M:SCOK]PRVQTY = [F:SCI]EXTQTY
    [M:SCOK]STRDAT = [M:SBCK]ORDDAT    # FQ 75630 GA 09/2011 avant [F:SCO]ORDDAT
    [M:SCOK]ENDDAT = [M:SBCK]RCPDAT    # FQ 75630 GA 09/2011 avant [F:SCO]RETDAT
    [M:SCOK]PJT    = [F:SCI]PJT
    [M:SCOK]LOT    = [F:SCI]LOT
    [M:SCOK]OBJDAT = [M:SBCK]RCPDAT    # FQ 75630 GA 09/2011 avant [F:SCO]RETDAT
    If dim([M:SCOK]ECCVALMAJ)>0 & dim([M:SBCK]ECCVALMAJ)>0 & [M:SBCK]ECCVALMAJ<>"" # Issue 107513/US4 GA 04/2015
       [M:SCOK]ECCVALMAJ  = [M:SBCK]ECCVALMAJ
       [M:SCOK]ECCVALMIN  = [M:SBCK]ECCVALMIN
    Endif
    # Issue X3-68900 - 2018-01-24 by MUARN : modification dates sur EO
    [M:SCOK]UPDSCO = [M:SBCK]UPDSCO

    Call MAJ_SCO From SCOAUTLIB
    If [M:SCOK]CODRET = 0
        LRET = 0
    Else
        LRET = 1 : # cas d'Erreur à traiter ...
    Endif

Return

