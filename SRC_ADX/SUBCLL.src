  Affzo [M:CLL3]1-99
Return

##########################################################################################################
$FILTRE
  Default File [CLL]
Return

##########################################################################################################
$FILGAUCHE_TUNNEL_OMP
  # FGR 16/04/2009 : X3SUIVI54457
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESOMP" Then
      Case currbox
        When GBOXCLL
          #Appels à effectuer
          Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", "CLLCMGFLG > 0", "&") From GOBJSUB
        When GBOXCL5
          #Seulement les retours marketing
          Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "CLLCMGFLG = 0", "&") From GOBJSUB
        When Default
          # Tous les autres
          Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "CLLCMGFLG > 0", "&") From GOBJSUB
      Endcase
    Endif
  Endif
Return

##########################################################################################################
$FILGAUCHE
  Default File [CLL]
  If currbox = GBOXCLL Then
    #Appels à effectuer
    Gosub FILGAUCHE_TUNNEL_OMP  # FGR 16/04/2009 : X3SUIVI54457
    Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", "(CLLDON <> 2)", "&") From GOBJSUB
  Elsif currbox = GBOXCL2 Then
    #Appels effectués
    Gosub FILGAUCHE_TUNNEL_OMP  # FGR 16/04/2009 : X3SUIVI54457
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "(CLLDON = 2)", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "CLL") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Elsif currbox = GBOXCL3 Then
    #Mes appels à effectuer
    Gosub FILGAUCHE_TUNNEL_OMP  # FGR 16/04/2009 : X3SUIVI54457
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "(CLLDON <> 2 and CLLREP = GAUSCRMF)", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "CLL") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Elsif currbox = GBOXCL4 Then
    #Mes appels effectués
    Gosub FILGAUCHE_TUNNEL_OMP  # FGR 16/04/2009 : X3SUIVI54457
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "(CLLDON = 2 and CLLREP = GAUSCRMF)", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "CLL") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Elsif currbox = GBOXCL5 Then
    #Retours marketing
    # FGR 16/04/2009 : X3SUIVI54457  CLLORIADI <> 'MAN'
    # FGR 12/11/2014 : X3SUIVI85786 c'est pas 'MAN' mais 'MAN1'
    #Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "CLLORI <> 1 and CLLCMGFLG = 0", "&") From GOBJSUB
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "(CLLORIADI <> 'MAN1' and CLLCMGFLG = 0)", "&") From GOBJSUB  # FGR 31/07/2014 : X3SUIVI101463
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "CLL") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Endif
Return

##########################################################################################################
$LIENS
  GFCY = [M:CLL0]SALFCY
  Call GETDEV(GFCY) From DEVSUB
  #Sauvegarde données courantes
  [M:CLL0]SALFCYINI = [M:CLL0]SALFCY
  [M:CLL0]CLLCMPINI = [M:CLL0]CLLCMP
  [M:CLL0]CLLDONINI = [M:CLL0]CLLDON
  [M:CLL1]CLLDATXINI = [M:CLL1]CLLDATX
  [M:CLL1]CLLREPINI = [M:CLL1]CLLREP
  #---------------------------------------------------#
  #Lecture des clobs
  Gosub LOADCLOB From SUBCLLB
  Gosub LOADCLOB2 From SUBCLLB
  #---------------------------------------------------#
  #Initialise le champs CLLDURX
  [M:CLL3]CLLDURX = mess(2,301,1)
  Affzo [M:CLL3]CLLDURX
  #---------------------------------------------------#
  #  Origine
  #---------------------------------------------------#
  If [M:CLL1]CREUSR <> "" Then
    Read [AUS]CODUSR=[M:CLL1]CREUSR
    [M:CLL1]FULNAMUSR = [F:AUS]NOMUSR
    Affzo [M:CLL1]FULNAMUSR
  Endif
  #[M:CLL1]CLLORILIB = mess([M:CLL1]CLLORITYP,3037,1)  # FGR 05/03/2010 : X3SUIVI62924
  # FGR 04/03/2010 : X3SUIVI62924 (début)
  #If [M:CLL1]CLLORI = 1 Then
  #  [M:CLL1]CLLORITXT = ""
  #Else
  #  [M:CLL1]CLLORITXT = mess([M:CLL1]CLLORI,2993,1)
  #Endif
  # FGR 04/03/2010 : X3SUIVI62924 (fin)
  #Définition du type de pièce
  #Gosub DEFOBJORI From SUBCLLB
  Call DEFOBJORI([M:CLL1]CLLORIAOB, [M:CLL1]CLLORIAVA) From CRMUTIL150    # FGR 05/03/2010 : X3SUIVI62924
  Diszo [M:CLL1]CLLORIVCR
  #Diszo [M:CLL1]CLLORITXT # FGR 04/03/2010 : X3SUIVI62924
  Diszo [M:CLL1]CLLORIADI # FGR 04/03/2010 : X3SUIVI62924
  #Call LIEN_OBJ_DYNAMIC([M:CLL1]CLLORIVCR,[M:CLL1]CLLORIOBC,[M:CLL1]CLLORIAVA,"","","[M:CLL1]CLLORIVCRD") From CRMUTIL140 # FGR 12/02/2009 : X3SUIVI52443
  Call LIEN_OBJ_DYNAMIC([M:CLL1]CLLORIVCR,[M:CLL1]CLLORIAOB,[M:CLL1]CLLORIAVA,"","","[M:CLL1]CLLORIVCRD") From CRMUTIL140 # FGR 04/03/2010 : X3SUIVI62924
  #---------------------------------------------------#
  #Affiche le nom en clair du tiers sélectionné.
  #---------------------------------------------------#
  Read [BPR]BPR0=[M:CLL0]CLLCMP
  If !fstat Then
    [M:CLL0]CLLCMPCLA = [F:BPR]BPRNAM
  Endif
  #---------------------------------------------------#
  #Affiche le type du tiers sélectionné.
  #---------------------------------------------------#
  Call AFFICHE_BCK_TIERS([M:CLL0]CLLCMP) From SUBCLLB
  #---------------------------------------------------#
  #Affiche le nom de l'interlocuteur
  #---------------------------------------------------#
  [M:CLL0]CLLCCNCLA = ""
  If [M:CLL0]CLLCCN = "" Then
    [M:CLL0]CCNTYP= 1
    #If [M:CLL1]CLLORI = 3 Then
    If [M:CLL1]CLLORIADI = "MKT3" Then  # FGR 04/03/2010 : X3SUIVI62924
      If [M:CLL1]CLLORIVCR <> "" Then
        Read [OMP]OMP0=[M:CLL1]CLLORIVCR
        If !fstat Then
          If [F:OMP]TYPSEA <> "CCN" Then
            If [F:OMP]CNTTTR <> "" Then
              [M:CLL0]CLLCCNCLA = [F:OMP]CNTTTR
            Endif
          Endif
        Endif
      Endif
    Endif
  Else
    Read [AIN]AIN0=[M:CLL0]CLLCCN
    If !fstat Then
      [M:CLL0]CCNTYP = [F:AIN]CNTTYP
      Call BUILDFULNAM("AIN", [M:CLL0]CLLCCNCLA) From CRMUTIL140
    Endif
  Endif
  If [M:CLL0]CCNTYP <> 1 and [M:CLL0]CCNTYP <> 2 Then
    [M:CLL0]CCNTYP = 1
  Endif
  If [M:CLL0]CCNTYP = 1 Then
    [M:CLL0]CCNOBJ = "AIN"
  Else
    [M:CLL0]CCNOBJ = "LDS"
  Endif
  Gosub DISPBKGCCN From SUBCLLB
  #---------------------------------------------------#
  # Contrôle de l'incrémentation du cyle de vente des affaires
  #---------------------------------------------------#
  Call SETPREOPP("CLL") From SUBOPPB
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBCLLB
  Call DISPICON_RETOUR From SUBCLLB # FGR 16/04/2009 : X3SUIVI54457
  #---------------------------------------------------#
  #Gestion de la transcodif
  Raz GTBCLLFIELDSYL
  Raz GTBCLLVALSYL
  Raz GTBCLLCHRONOSYL
  GICLLNBSYL = 0
  For [SYL] Where [F:SYL]SYLTYP = "CLL" and [F:SYL]SYLKEY = [M:CLL0]CLLNUM and [F:SYL]SYLFLGDPT = 1
    GTBCLLFIELDSYL(GICLLNBSYL) = [F:SYL]SYLFIE
    GTBCLLVALSYL(GICLLNBSYL) = evalue("[M]" + [F:SYL]SYLFIE)
    GTBCLLCHRONOSYL(GICLLNBSYL) = [F:SYL]SYLNUM
    GICLLNBSYL += 1
  Next
  Affzo [M:CLL1]1-99
  Affzo [M:CLL3]1-99
Return

##########################################################################################################
Subprog AM_CLLDAT(VALEUR)
Variable Date    VALEUR

  If VALEUR <> [00/00/00] Then
    #Met à jour le numéro de semaine avec la nouvelle date
    [M:CLL1]CLLWEE = week(VALEUR)
    [M:CLL1]CLLDATX = VALEUR
  Else
    [M:CLL1]CLLWEE = 0
    [M:CLL1]CLLDATX = [00/00/00]
  Endif
  Affzo [M:CLL1]CLLWEE
End

##########################################################################################################
Subprog C_CLLWEE(VALEUR)
Variable Decimal VALEUR

  If VALEUR < 0 or VALEUR > 53 Then
    #Contrôle de la validité du numéro de semaine
    GMESSAGE = mess(187,196,1)
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog AM_CLLWEE(VALEUR)
Variable Decimal VALEUR

Local Integer INBDAY
Local Decimal NVALEUR
Local Date DCLLDATX
Local Integer IWEEK

  # FGR 03/11/2009 : X3SUIVI59487
  NVALEUR = VALEUR
  If [M:CLL1]CLLDATX = [0/0/0] Then
    DCLLDATX = date$
    IWEEK = week(DCLLDATX)
  Else
    DCLLDATX = [M:CLL1]CLLDATX
    IWEEK = [M:CLL1]CLLWEE
  Endif
  If NVALEUR  <> [M:CLL1]CLLWEE Then
    Raz [M:CLL1]CLLDAT
    Raz [M:CLL1]CLLHOU
    Affzo [M:CLL1]CLLDAT, CLLHOU
  Endif
  #Si l'appel est exprimé en semaine. La date correspondante doit toujours être un Lundi.
  INBDAY = dayn(DCLLDATX)-1
  DCLLDATX = DCLLDATX - INBDAY
  If NVALEUR > IWEEK Then
    [M:CLL1]CLLDATX = DCLLDATX + ((NVALEUR - IWEEK) * 7)
  Else
    [M:CLL1]CLLDATX = DCLLDATX - ((IWEEK - NVALEUR) * 7)
  Endif
End

##########################################################################################################
Subprog IB_CLLCMP

  # FGR 05/04/2011 : X3SUIVI72615
  GBOUT1 = [M:CLL0]CLLCMPLIB
  If [M:CLL0]CLLCMPAOB = "BPR" Then
    Raz GBOUT3
  Endif
  Call IB_NOTECHECK([M:CLL0]CLLCMP,"CRM",4)  From TRTNTSCTL # CRM notes
End

##########################################################################################################
Subprog AM_CLLCMP(VALEUR)
Variable Char    VALEUR()

  #Définit le représentant et le site par défaut.
  If GNAVIG(GPILNAV-1) <> "GESOPP" Then  # FGR 09/08/2016 : X3SUIVI117691
    Raz [M:CLL0]CLLCCN
    Raz [M:CLL0]CLLCCNCLA
    #On réinitialise le correspondant
    Raz [M:CLL0]CLLCOR
    [M:CLL0]CLLCMP = VALEUR
    Read [BPR]BPR0=VALEUR
    If fstat Then
      #Affiche le nom en clair du tiers sélectionné.
      [M:CLL0]CLLCMPCLA = ""
      [M:CLL0]CCNTYP = 1
    Else
      #Définit l'interlocuteur par défaut du rendez-vous
      Call GETDEFCNT(VALEUR, [M:CLL0]CLLCCN) From CRMUTIL140
      If [M:CLL0]CLLCCN <> ""
        Gosub SETCCNINF From SUBCLLB
      Else
        [M:CLL0]CCNTYP = 1
      Endif
      #Affiche le nom en clair du tiers sélectionné.
      [M:CLL0]CLLCMPCLA = [F:BPR]BPRNAM
      If [M:CLL1]CLLREP = "" Then
        If [F:BPR]BPCFLG = 2 or [F:BPR]PPTFLG = 2 Then
          Read [BPC]BPC0=VALEUR
          If !fstat Then
            If [F:BPC]REP(0) <> "" Then
              [M:CLL1]CLLREP = [F:BPC]REP(0)
            Else
              If [F:BPC]REP(1) <> "" Then
                [M:CLL1]CLLREP = [F:BPC]REP(1)
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  #Affiche le type du tiers sélectionné.
  Call AFFICHE_BCK_TIERS(VALEUR) From SUBCLLB
  Call SITECRMREP("ACT", [M:CLL1]CLLREP, [M:CLL0]SALFCY) From CRM_UTIL
  Gosub VERIFCCNCOR From SUBCLLB
  Gosub DEFCOR From SUBCLLB
  Gosub DISPBKGCCN From SUBCLLB
  Affzo [M:CLL0]1-99
  Affzo [M:CLL1]1-99
End

##########################################################################################################
Subprog AM_CLLREP(VALEUR)
Variable Char    VALEUR()

  Call SITECRMREP("ACT", VALEUR, [M:CLL0]SALFCY) From CRM_UTIL
  GFCY = [M:CLL0]SALFCY
  Call GETDEV(GFCY) From DEVSUB
  Affzo [M:CLL0]SALFCY
End

##########################################################################################################
Subprog AM_CLLRPO(VALEUR)
Variable Char    VALEUR()

  # Gère le nombre d'appel effectués et à faire concernant l'éventuelle opération marketing associée.
  If [M:CLL0]CLLDON <> 2 Then
    Call MNGOMP([M:CLL1]CLLOPGTYP, [M:CLL1]CLLOPGNUM, "ADD") From SUBCLLB
  Endif
  [M:CLL0]CLLDON = 2
  [M:CLL3]CLLRPO = VALEUR
  Affzo [M:CLL3]1-99
  Affzo [M:CLL0]CLLDON
End

##########################################################################################################
#CHECK UNUSED_BEGIN
Subprog AM_CLLOPG(VALEUR)
Variable Char    VALEUR()

Local Char SZVALEUR

  SZVALEUR = VALEUR
  If VALEUR = "" Then
    [M:CLL1]CLLOPG = VALEUR
    Affzo [M:CLL1]CLLOPG
    End
  Endif
  [M:CLL1]CLLOPGTYP = left$(SZVALEUR, 3)
  [M:CLL1]CLLOPGNUM = mid$(SZVALEUR, 4, len(SZVALEUR)-3)
  #
  If [M:CLL1]CLLOPGTYP = "OMM" Then
    Read [OMM]OMM0=[M:CLL1]CLLOPGNUM
    If !fstat Then
      VALEUR = [F:OMM]DES
    Endif
  Elsif [M:CLL1]CLLOPGTYP = "OMP" Then
    Read [OMP]OMP0=[M:CLL1]CLLOPGNUM
    If !fstat Then
      VALEUR = [F:OMP]DES
    Endif
  Elsif [M:CLL1]CLLOPGTYP = "OMT" Then
    Read [OMT]OMT0=[M:CLL1]CLLOPGNUM
    If !fstat Then
      VALEUR = [F:OMT]DES
    Endif
  Elsif [M:CLL1]CLLOPGTYP = "OMN" Then
    Read [OMN]OMN0=[M:CLL1]CLLOPGNUM
    If !fstat Then
      VALEUR = [F:OMN]DES
    Endif
  Endif
  [M:CLL1]CLLOPG = VALEUR
  Affzo [M:CLL1]CLLOPG
End

##########################################################################################################
Subprog IB_CLLOPG

  If [M:CLL1]CLLCMGNUM = "" Then
    Raz GBOUT1
    Raz GBOUT2
  Else
    GBOUT1 = mess(378,196,1) #Opérations marketing.
    GBOUT2 = mess(148,195,1) #Détail
  Endif
End
#CHECK UNUSED_END

##########################################################################################################
Subprog AM_CLLOBJ(VALEUR)
Variable Char    VALEUR()

  [M:CLL1]CLLOBJ = VALEUR
  If [M:CLL0]CLLTYP = 1 Then
    If [M:CLL3]CLLRPO = "" Then
      [M:CLL3]CLLRPO = [M:CLL1]CLLOBJ
    Endif
  Endif
  Affzo [M:CLL1]CLLOBJ
  Affzo [M:CLL3]CLLRPO
End

##########################################################################################################
Subprog AM_CLLDON(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    If [M:CLL3]CLLSAO = "" Then
      Call DEFVALADI(436, [M:CLL3]CLLSAO) From CRMUTIL140
    Endif
  Endif
  Affzo [M:CLL3]CLLSAO
End

##########################################################################################################
Subprog AM_CLLTYP(VALEUR)
Variable Integer VALEUR

  [M:CLL0]CLLTYP = VALEUR
  If [M:CLL0]CLLTYP = 1 Then
    If [M:CLL3]CLLRPO = "" Then
      If [M:CLL1]CLLOBJ <> "" Then
        [M:CLL3]CLLRPO = [M:CLL1]CLLOBJ
      Endif
    Endif
  Endif
  Affzo [M:CLL0]CLLTYP
  Affzo [M:CLL1]CLLOBJ
  Affzo [M:CLL3]CLLRPO
End

##########################################################################################################
Subprog AM_CLLCCN(VALEUR)
Variable Char    VALEUR()

  #On réinitialise le correspondant
  [M:CLL0]CLLCOR = ""
  [M:CLL0]CLLCCN = VALEUR
  Gosub SETCCNINF From SUBCLLB
  Gosub DISPBKGCCN From SUBCLLB
  Affzo [M:CLL1]1-99
End

##########################################################################################################
Subprog IB_CLLREP

  Raz GBOUT3
  If [M:CLL0]CLLCMP <> "" Then
    Read [BPC]BPC0=[M:CLL0]CLLCMP
    If !fstat Then
      #Représentants secondaires
      Call TEXTE(15800, GBOUT3) From OBJDIV
    Endif
  Endif
End

##########################################################################################################
Subprog IB_FULOBJ

  Raz GBOUT1
  If [M:CLL1]FULOBJ <> "" Then
    If len([M:CLL1]FULOBJ) > GLONCLE Then
      Call TEXTE(23819, GBOUT1) From OBJDIV      #Synthèse
    Endif
  Endif
End

##########################################################################################################
Subprog AM_FULOBJ (VALEUR)
Variable Clbfile VALEUR

  Call GERE_TEXTE_SYNTHESE([M:CLL1]FULOBJ, VALEUR, [M:CLL1]CLLOBJ) From CRMUTIL150  # FGR 06/08/2014 : X3SUIVI95250
  [M:CLL1]FULOBJ = VALEUR
  Gosub DISPICON From SUBCLLB
  Affzo [M:CLL1]OBJICO
End

##########################################################################################################
Subprog IB_FULRPO

  Raz GBOUT1
  If [M:CLL3]FULRPO <> "" Then
    If len([M:CLL3]FULRPO) > GLONCLE Then
      Call TEXTE(23819, GBOUT1) From OBJDIV      #Synthèse
    Endif
  Endif
End

##########################################################################################################
Subprog AM_FULRPO (VALEUR)
Variable Clbfile VALEUR

  Call GERE_TEXTE_SYNTHESE([M:CLL3]FULRPO, VALEUR, [M:CLL3]CLLRPO) From CRMUTIL150  # FGR 06/08/2014 : X3SUIVI95250
  [M:CLL3]FULRPO = VALEUR
  Gosub DISPICON From SUBCLLB
  Affzo [M:CLL3]RPOICO
End

##########################################################################################################
Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()

  If GREP = "C" Then
    Local Char SZFCY(GLONFCY)
    Local Char SZCRMREP(GLONREP)
    Local Integer ICRMREP
    Local Char SZCRMDEF
    Local Integer ICRMDEF
    Local Char SZDONDEF
    Local Integer IDONDEF

    [M:CLL1]CLLREP = ""
    SZFCY = VALEUR
    SZCRMREP = ""
    ICRMREP = 1
    SZCRMDEF = ""
    ICRMDEF = 1
    SZDONDEF = ""
    IDONDEF = 1
    Call PARAMUTIL("CRMREPCLL", SZCRMREP, GUSER, SZFCY) From SUBAUS
    If SZCRMREP = "" Then
      ICRMREP = 1
    Else
      ICRMREP = val(SZCRMREP)
    Endif
    Call PARAMUTIL("CRMDEFREP", SZCRMDEF, GUSER, SZFCY) From SUBAUS
    If SZCRMDEF = "" Then
      ICRMDEF = 1
    Else
      ICRMDEF = val(SZCRMDEF)
    Endif
    Call PARAMUTIL("DONDEFCLL", SZDONDEF, GUSER, SZFCY) From SUBAUS
    If SZDONDEF = "" Then
      IDONDEF = 1
    Else
      IDONDEF = val(SZDONDEF)
    Endif
    #Représentant connecté prioritaire
    If ICRMREP = 2 Then
      Read [REP]REP1=GUSER
      If !fstat Then
        [M:CLL1]CLLREP = [F:REP]REPNUM
      Endif
    Endif
    If [M:CLL0]CLLCMP <> "" Then
      #Définit le représentant et le site par défaut.
      Read [BPR]BPR0=[M:CLL0]CLLCMP
      If !fstat Then
        If [M:CLL1]CLLREP = "" Then
          If [F:BPR]BPCFLG = 2 or [F:BPR]PPTFLG = 2 Then
            Read [BPC]BPC0=[M:CLL0]CLLCMP
            If !fstat Then
              If [F:BPC]REP(0) <> "" Then
                [M:CLL1]CLLREP = [F:BPC]REP(0)
              Else
                If [F:BPC]REP(1) <> "" Then
                  [M:CLL1]CLLREP = [F:BPC]REP(1)
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
    If ICRMDEF = 2 Then
      If [M:CLL1]CLLREP = "" Then
        Read [REP]REP1=GUSER
        If !fstat Then
          [M:CLL1]CLLREP = [F:REP]REPNUM
        Endif
      Endif
    Endif
    If !GIMPORT Then
      If GCLLTUNNEL = 0 Then
        #On ne vient de nulle part
        If IDONDEF = 2 Then
          #Appel effectué
          [M:CLL0]CLLDON = 2
          [M:CLL0]CLLTYP = GCLLTYPDEF
        Else
          #Appel à planifier
          [M:CLL0]CLLDON = 1
          [M:CLL0]CLLTYP = 2
        Endif
      Endif
    Endif
  Endif
  GFCY = VALEUR
  Call GETDEV(GFCY) From DEVSUB
  Affzo [M:CLL0]1-99
  Affzo [M:CLL1]1-99
End

##########################################################################################################
Subprog AM_CLLCOR(VALEUR)
Variable Char    VALEUR()

  #Table COR chargé par le controle
  If [F:COR]CNTNUM <> "" Then
    Call AM_CLLCCN([F:COR]CNTNUM) From SUBCLL
    Affzo [M:CLL0]CLLCCN
  Endif
  If [F:COR]BPRNUM <> "" Then
    If [M:CLL0]CLLCMP = "" Then
      Call AM_CLLCMP([F:COR]BPRNUM) From SUBCLL
      Affzo [M:CLL0]CLLCMP
    Endif
  Endif
End

##########################################################################################################
Subprog IB_CLLORIADI
  # FGR 04/03/2010 X3SUIVI62924
  If [M:CLL1]CLLORITYP <> 2 Then
    If varmode ([M:CLL1]CLLORIADI, 0) = 0 Then
      Raz GBOUT2
    Else
      GBOUT2 = mess(257,177,1)
    Endif
  Else
    Raz GBOUT2
  Endif
End

##########################################################################################################
Subprog AM_CLLORIADI(VALEUR)
Variable Char    VALEUR()

Local Char SZCLLORIAOB(GLONAOB)

  # FGR 04/03/2010 X3SUIVI62924
  #Définition du type de pièce
  If VALEUR = "" Then
    VALEUR = "MAN1"
  Endif
  SZCLLORIAOB = [M:CLL1]CLLORIAOB
  [M:CLL1]CLLORIAOB = func CRMUTIL150.GET_AOB_FROM_ORI(VALEUR)
  #Gosub DEFOBJORI From SUBCLLB
  Call DEFOBJORI([M:CLL1]CLLORIAOB, [M:CLL1]CLLORIAVA) From CRMUTIL150    # FGR 05/03/2010 : X3SUIVI62924
  If SZCLLORIAOB <> [M:CLL1]CLLORIAOB Then
    Raz [M:CLL1]CLLORIVCR
    Raz [M:CLL1]CLLORIVCRL
    Raz [M:CLL1]CLLCMGNUM
    Raz [M:CLL1]CLLOPGTYP
    Raz [M:CLL1]CLLOPGNUM
    Raz [M:CLL1]CLLORIVCRD
    Call DISPICON_RETOUR From SUBCLLB
    Affzo [M:CLL1]1-99
  Endif
End

##########################################################################################################
Subprog B2_CLLORIADI(VALEUR)
Variable Char    VALEUR()

  # FGR 04/03/2010 X3SUIVI62924
  Actzo [M:CLL1]CLLORIADI
  Actzo [M:CLL1]CLLORIVCR
  mkstat = 4
End

##########################################################################################################
Subprog IB_CLLORIVCR

  If [M:CLL1]CLLORIADI = "MAN1" Then
    # Si c'est "MAN1" on ne peut pas indiquer d'objet donc pas de bouton
    Raz GBOUTS
    Raz GBOUT1
    Raz GBOUT2
  Else
    Raz GBOUT1
    If [M:CLL1]CLLORITYP <> 2 Then
      If varmode([M:CLL1]CLLORIVCR, 0) <> 0 Then
        Raz GBOUTS
        GBOUT2 = mess(257,177,1)
      Else
        Raz GBOUT2
      Endif
    Else
      Raz GBOUTS
      Raz GBOUT2
    Endif
    #If [M:CLL1]CLLORIOBC <> "" and [M:CLL1]CLLORIVCR <> "" Then
    If [M:CLL1]CLLORIAOB <> "" and [M:CLL1]CLLORIVCR <> "" Then   # FGR 04/03/2010 : X3SUIVI62924
      #Détail pièce
      GBOUT1 = mess(103,182,1)
    Endif
  Endif
End

##########################################################################################################
Subprog B2_CLLORIVCR(VALEUR)
Variable Char    VALEUR()

  #Actzo [M:CLL1]CLLORITXT
  Actzo [M:CLL1]CLLORIADI   # FGR 04/03/2010 : X3SUIVI62924
  Actzo [M:CLL1]CLLORIVCR
  mkstat = 4
End

##########################################################################################################
Subprog IB_CLLCCN

  Filter [AIN]
  If [M:CLL0]CLLCMP = "" Then
    Raz GBOUT2
  Endif
End

##########################################################################################################
Subprog C_CLLORIVCR(VALEUR)
Variable Char    VALEUR()

Local Char SZMESSAGE(250)
Local Integer IBRETOUR

  #If [M:CLL1]CLLORIOBC = "" Then
  If [M:CLL1]CLLORIAOB = "" Then   # FGR 04/03/2010 : X3SUIVI62924
    If VALEUR <> "" Then
      #Vous devez d'abord choisir une origine
      GMESSAGE = mess(526,177,1)
      mkstat = 1
      End
    Endif
  Endif
  #If VALEUR <> "" and [M:CLL1]CLLORIOBC <> "" Then
  If VALEUR <> "" and [M:CLL1]CLLORIAOB <> "" Then   # FGR 04/03/2010 : X3SUIVI62924
    # FGR 21/01/2009 : X3SUIVI33671 : ajout du site
    #Call VERIFOBJCODE ([M:CLL1]CLLORIOBC, [M:CLL0]SALFCY, VALEUR, SZMESSAGE, IBRETOUR) From CRMUTIL150
    Call VERIFOBJCODE ([M:CLL1]CLLORIAOB, [M:CLL0]SALFCY, VALEUR, SZMESSAGE, IBRETOUR) From CRMUTIL150   # FGR 04/03/2010 : X3SUIVI62924
    If IBRETOUR = 0 Then
      GMESSAGE = SZMESSAGE
      mkstat = 1
      End
    Endif
  Endif
End

##########################################################################################################
Subprog AM_CLLORIVCR(VALEUR)
Variable Char    VALEUR()

# FGR 01/12/2008 : X3SUIVI50722
Local Char SZMESSAGE(250)
Local Integer IBRETOUR
Local Char SZCMGNUM(GLONVCR)

  If left$([M:CLL1]CLLORIADI, 3) = "MKT" Then          # FGR 08/03/2010 : X3SUIVI62924
    #If VALEUR <> "" and [M:CLL1]CLLORIOBC <> "" Then
    If VALEUR <> "" and [M:CLL1]CLLORIAOB <> "" Then   # FGR 04/03/2010 : X3SUIVI62924
      #Call GETCMG_OBJCODE ("", [M:CLL1]CLLORIOBC, VALEUR, SZCMGNUM, SZMESSAGE, IBRETOUR) From CRMUTIL150
      Call GETCMG_OBJCODE ("", [M:CLL1]CLLORIAOB, VALEUR, SZCMGNUM, SZMESSAGE, IBRETOUR) From CRMUTIL150   # FGR 04/03/2010 : X3SUIVI62924
      If IBRETOUR = 0 Then
        GMESSAGE = SZMESSAGE
        mkstat = 1
        End
      Endif
      [M:CLL1]CLLCMGNUM = SZCMGNUM
      #[M:CLL1]CLLOPGTYP = [M:CLL1]CLLORIOBC  # FGR 16/04/2009 : X3SUIVI54457 : ça manquait un peu !
      [M:CLL1]CLLOPGTYP = [M:CLL1]CLLORIAOB   # FGR 04/03/2010 : X3SUIVI62924
      [M:CLL1]CLLOPGNUM = VALEUR              # FGR 16/04/2009 : X3SUIVI54457 : ça manquait un peu !
    Endif
    #
    #If [M:CLL1]CLLORI = 3 Then
    If [M:CLL1]CLLORIADI = "MKT3" Then        # FGR 04/03/2010 : X3SUIVI62924
      [M:CLL1]CLLCMGFLG = GCLLOMPFLG          # FGR 17/04/2009 : X3SUIVI54457
      Call DISPICON_RETOUR From SUBCLLB
      Affzo [M:CLL1]CLLORIICO
    Endif
  Else
    Raz [M:CLL1]CLLCMGNUM
    Raz [M:CLL1]CLLOPGTYP
    Raz [M:CLL1]CLLOPGNUM
  Endif
End

##########################################################################################################
Subprog CL_CLLORIICO(VALEUR)
Variable Char    VALEUR()

Local Char SZNEW_ICONE
Local Char SZMESSAGE(250)

  # FGR 16/04/2009 : X3SUIVI54457
  Gosub ICONE_RETOUR From SUBCLLB
  If VALEUR = SZICONOCOMPTE Then
    # Non compté dans les retours : => compté
    SZNEW_ICONE = SZICOCOMPTE
  Elsif VALEUR = SZICOCOMPTE Then
    # Compté dans les retours : => non compté
    SZNEW_ICONE = SZICONOCOMPTE
  Endif
  #
  If func SUBCLLB.RETOUR_CHANGEABLE(SZNEW_ICONE, SZMESSAGE) = 1 Then
    If SZNEW_ICONE = SZICOCOMPTE Then
      # Non compté dans les retours : => compté
      VALEUR = SZNEW_ICONE
      [M:CLL1]CLLCMGFLG = 0   # Appels non comptés dans les retours
    Elsif SZNEW_ICONE = SZICONOCOMPTE Then
      # Compté dans les retours : => non compté
      VALEUR = SZNEW_ICONE
      [M:CLL1]CLLCMGFLG = 1   # Appels comptés dans les retours
    Endif
    # Le bouton fonctionne comme une bascule : ça devient le nouveau mode par défaut
    GCLLOMPFLG = [M:CLL1]CLLCMGFLG
    Call INIT_DECODE_ICON From SUBCLLB
    mkstat = 4
  Else
    GMESSAGE = mess(631,177,1) - "(" + SZMESSAGE + ")"
    mkstat = 1
    End
  Endif
End

