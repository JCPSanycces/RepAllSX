#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion du fichier PHONECALL
Call OBJET ("CLL", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################
##########################################################################################################
# GCLLOMPFLG : Mode de création/duplication par défaut des appels par rapport à une campagne d'appels
#   0 = Non compté dans les retours
#   1 = Compté dans les retours
#   Par défaut si on vient par le menu GCLLOMPFLG = 0
#   Si on vient en tunnel depuis GESOMP, GCLLOMPFLG = 1
#   Fonctionne comme une bascule. Si l'utilisateur change, le mode reste le même jusqu'à ce qu'on le change
# [M:CLL1]CLL3OMPFLG
#   Toujours à 0.
#   Mis à 1 lorsque le programme détecte un représentant ne participant pas à une campagne d'appel,
#   et que l'utilisateur souhaite l'y intégrer (SUBCLLB.$CHECKOMPREP)
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "BOITE"        : Gosub BOITE       # FGR 31/07/2014 : X3SUIVI101463
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "OUVRE"        : Gosub OUVRE
    When "FERME"        : Gosub FERME
    When "RAZCRE"       : Gosub RAZCRE
    When "RAZDUP"       : Gosub RAZDUP
    When "LIENS"        : Gosub LIENS
    When "SETBOUT"      : Gosub SETBOUT
    When "AVANTBOUT"    : Gosub AVANTBOUT
    When "INICRE"       : Gosub INICRE
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "CREATION"     : Gosub CREATION
    When "APRES_CRE"    : Gosub APRES_CRE
    When "INIMOD"       : Gosub INIMOD
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "AVANT_MODFIC" : Gosub AVANT_MODFIC
    When "MODIF"        : Gosub MODIF
    When "APRES_MOD"    : Gosub APRES_MOD
    When "AV_ANNULE"    : Gosub AV_ANNULE
    When "ANNULE"       : Gosub ANNULE
   #When "AP_ANNULE"    : Gosub AP_ANNULE    # FGR 12/08/2009 : X3SUIVI57005
    When "APRES_ANNULE" : Gosub APRES_ANNULE # FGR 22/10/2009 : X3SUIVI57254
    When "FILTRE"       : Gosub FILTRE
    When "FILGAUCHE"    : Gosub FILGAUCHE
    When "AVANT_CHOI"   : Gosub AVANT_CHOI
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char GCCLLCPT(GLONANM)   #Code compteur
Global Char GBOXCLL(10)
Global Char GBOXCL2(10)
Global Char GBOXCL3(10)
Global Char GBOXCL4(10)
Global Char GBOXCL5(10) : # FGR 16/04/2009 : X3SUIVI54457
Global Char GTBCLLFIELDSYL(30)(50)
Global Char GTBCLLVALSYL(250)(50)
Global Char GTBCLLCHRONOSYL(30)(50)
Global Integer GICLLNBSYL
Global Integer GCLLTUNNEL
Global Integer GCLLOMPFLG  # FGR 17/04/2009 : X3SUIVI54457 : Mode comptage création/duplication par défaut

Local Char SZSITE(GLONFCY)

  GCLLTUNNEL = TUNNEL
  GCCLLCPT = ""
  Raz GTBCLLFIELDSYL
  Raz GTBCLLVALSYL
  Raz GTBCLLCHRONOSYL
  GICLLNBSYL = 0
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  If !clalev([F:SYL]) : Local File SYNCLINK [SYL] : Endif
  If !clalev([F:OMM]) : Local File MAILING [OMM] : Endif
  If !clalev([F:OMP]) : Local File PHONING [OMP] : Endif
  If !clalev([F:OMT]) : Local File TRADESHOW [OMT] : Endif
  If !clalev([F:OMN]) : Local File MEDIA [OMN] : Endif
  If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif       # FGR 04/03/2010 : X3SUIVI62924
  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
  #  Read [TCA]TCA0=13
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(0)
  #  GCCLLCPT = [F:TCA]CODNUM(0)
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
  SZSITE = ""
  Call SITECRMDEF ("ACT", SZSITE) From CRM_UTIL
  GFCY = SZSITE
  Call GETDEV(GFCY) From DEVSUB
  #Affichage background CLLCCN
  Gosub DISPBKGCCN From SUBCLLB
  # FGR 17/04/2009 : X3SUIVI54457 : Mode comptage création/duplication par défaut
  GCLLOMPFLG = 0       # Appels non comptés dans les retours
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESOMP" Then
      GCLLOMPFLG = 1   # Appels comptés dans les retours
    Endif
  Endif
Return

##########################################################################################################
$BOITE
Local Char STRTSUB(GLONADC)

  # FGR 31/07/2014 : X3SUIVI101463
  STRTSUB = "SUBCLL"
  Gosub BOITE_GOBJET From CRMUTIL150
Return

##########################################################################################################
$REDEFINE_LINK
  If !clalev([F:C_LL]) Then
    # FGR 11/02/2015 : X3SUIVI106120 : Si [C_LL] pas ouvert c'est que les browsers ont été redéfinis en SPE/SPV.
    # On part, c'est à ce niveau qu'on doit faire ce travail.
    Return
  Endif
  # FGR 31/07/2014 : X3SUIVI101463
  Link [CLL] With [C_LL]CLL8=[F:CLL]CLLDAT;[F:CLL]CLLHOU;[F:CLL]CLLNUM,
&                 [AFF]AFF0~=[F:CLL]SALFCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:CLL]SALFCY,
&                 [COR]COR0=[F:CLL]CLLCOR
&              As [CL2]
  Link [CLL] With [C_LL]CLL8=[F:CLL]CLLDAT;[F:CLL]CLLHOU;[F:CLL]CLLNUM,
&                 [AFF]AFF0~=[F:CLL]SALFCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:CLL]SALFCY,
&                 [COR]COR0=[F:CLL]CLLCOR
&              As [CL3]
  Link [CLL] With [C_LL]CLL8=[F:CLL]CLLDAT;[F:CLL]CLLHOU;[F:CLL]CLLNUM,
&                 [AFF]AFF0~=[F:CLL]SALFCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:CLL]SALFCY,
&                 [COR]COR0=[F:CLL]CLLCOR
&              As [CL4]
  Link [CLL] With [C_LL]CLL8=[F:CLL]CLLDAT;[F:CLL]CLLHOU;[F:CLL]CLLNUM,
&                 [AFF]AFF0~=[F:CLL]SALFCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:CLL]SALFCY,
&                 [COR]COR0=[F:CLL]CLLCOR
&              As [CL5]
ETURN

##########################################################################################################
$OUVRE_BOITE
  #---------------------------------------------------#
  #Chargement des noms des cuurbox de chaque tiroir
  If OBJLIS(0) = "CLL" Then
    GBOXCLL = "GAU_CHE"
  Else
    GBOXCLL = "GAU_CHE"+num$(find("CLL",OBJLIS(1..8))) : #Appels à effectuer
  Endif
  If OBJLIS(0) = "CL2" Then
    GBOXCL2 = "GAU_CHE"
  Else
    GBOXCL2 = "GAU_CHE"+num$(find("CL2",OBJLIS(1..8))) : #Appels effectués
  Endif
  If OBJLIS(0) = "CL3" Then
    GBOXCL3 = "GAU_CHE"
  Else
    GBOXCL3 = "GAU_CHE"+num$(find("CL3",OBJLIS(1..8))) : #Mes appels à effectuer
  Endif
  If OBJLIS(0) = "CL4" Then
    GBOXCL4 = "GAU_CHE"
  Else
    GBOXCL4 = "GAU_CHE"+num$(find("CL4",OBJLIS(1..8))) : #Mes appels effectués
  Endif
  # FGR 16/04/2009 : X3SUIVI54457
  If OBJLIS(0) = "CL5" Then
    GBOXCL5 = "GAU_CHE"
  Else
    GBOXCL5 = "GAU_CHE"+num$(find("CL5",OBJLIS(1..8))) : #Mes appels effectués
  Endif
Return

##########################################################################################################
$FERME
  Kill GCCLLCPT   #Code compteur
  If dim(GBOXCLL) > 0 Then
    Kill GBOXCLL
    Kill GBOXCL2
    Kill GBOXCL3
    Kill GBOXCL4
    Kill GBOXCL5 : # FGR 16/04/2009 : X3SUIVI54457
  Endif
  If !GIMPORT Then
    If GPILNAV > 1 Then
      If GNAVIG(GPILNAV-1) = "GESOMP" Then
        Read [OMP]OMP0=[M:OMP0]OMPNUM
        If !fstat Then
          [M:OMP2]NBRCLLOMP = [F:OMP]NBRCLLOMP
          [M:OMP2]NBRCLLPCD = [F:OMP]NBRCLLPCD
          [M:OMP2]NBRCLLPCDX = [F:OMP]NBRCLLPCDX
          #Affiche les téléacteurs participants
          Call LOADTSALES([M:OMP0]OMPNUM) From SUBOMPB
          [M:OMP0]SELTLS = ""
          Affzo [M:OMP2]1-99
        Endif
      Endif
    Endif
  Endif
  Kill GTBCLLFIELDSYL
  Kill GTBCLLVALSYL
  Kill GTBCLLCHRONOSYL
  Kill GICLLNBSYL
  Kill GCLLTUNNEL
  Kill GCLLOMPFLG  # FGR 17/04/2009 : X3SUIVI54457 : Mode comptage création/duplication par défaut
Return

##########################################################################################################
$AVANT_CHOI
  If GBCRMFLGNEW = 1 Then
    REPONSE = GSTANEW
    Gosub NOUVEAU From GOBJSUB
    Gosub SETBOUT From GOBJSUB
    GBCRMFLGNEW = 0
  Endif
Return

##########################################################################################################
$RAZCREDUP_TUNNEL_OMP
Local Char SZRIGHTTELE(GLONREP)
Local Date DRIGHTDATE

  SZRIGHTTELE = ""
  DRIGHTDATE = [00/00/00]
  #En cas de création manuelle depuis une campagne d'appel, on réaffecte l'origine.
  If !GIMPORT Then
    If GPILNAV > 1 Then
      If GNAVIG(GPILNAV-1) = "GESOMP" Then
        If [M:OMP2]CLO <> 2 Then
          [M:CLL0]CLLDON = 1
          [M:CLL0]CLLTYP = 2
          Read [CMG]CMG0=[M:OMP0]CMGNUM
          If !fstat Then
            [M:CLL1]CLLOBJ = [F:CMG]DES
          Endif
          # FGR 04/03/2010 : X3SUIVI62924 (début)
          #[M:CLL1]CLLORI = 3
          #[M:CLL1]CLLORITXT = mess([M:CLL1]CLLORI,2993,1)
          [M:CLL1]CLLORIADI = "MKT3"
          [M:CLL1]CLLORIAOB = func CRMUTIL150.GET_AOB_FROM_ORI([M:CLL1]CLLORIADI)
          # FGR 04/03/2010 : X3SUIVI62924 (fin)
          [M:CLL1]CLLORIVCR = [M:OMP0]OMPNUM
          [M:CLL1]CLLORIVCRL = 0
          #Généré par campagne d'appels.
          [M:CLL1]CLLCMGNUM = [M:OMP0]CMGNUM
          [M:CLL1]CLLOPGNUM = [M:OMP0]OMPNUM
          [M:CLL1]CLLOPGTYP = "OMP"
          #On affecte la demande au téléacteur qui termine le plus tôt
          If [M:OMP0]SELTLS = "" Then
            SZRIGHTTELE = ""
            Call SELECTRIGHTTELE([M:CLL1]CLLOPGNUM, SZRIGHTTELE, DRIGHTDATE) From SUBCLLB
            If SZRIGHTTELE <> "" Then
              [M:CLL1]CLLREP = SZRIGHTTELE
              [M:CLL1]CLLDAT = DRIGHTDATE
              [M:CLL1]CLLHOU = "0900"
              [M:CLL1]CLLWEE = week([M:CLL1]CLLDAT)
            Endif
          Else
            SZRIGHTTELE = [M:OMP0]SELTLS
            [M:CLL1]CLLREP = SZRIGHTTELE
            Call SELECTRIGHTDATE([M:CLL1]CLLOPGNUM, SZRIGHTTELE, DRIGHTDATE) From SUBCLLB
            [M:CLL1]CLLDAT = DRIGHTDATE
            [M:CLL1]CLLHOU = "0900"
            [M:CLL1]CLLWEE = week([M:CLL1]CLLDAT)
          Endif
          #Gosub DEFOBJORI From SUBCLLB
          Call DEFOBJORI([M:CLL1]CLLORIAOB, [M:CLL1]CLLORIAVA) From CRMUTIL150    # FGR 05/03/2010 : X3SUIVI62924
          #Call LIEN_OBJ_DYNAMIC([M:CLL1]CLLORIVCR,[M:CLL1]CLLORIOBC,[M:CLL1]CLLORIAVA,"","","[M:CLL1]CLLORIVCRD") From CRMUTIL140 # FGR 12/02/2009 : X3SUIVI52443
          Call LIEN_OBJ_DYNAMIC([M:CLL1]CLLORIVCR,[M:CLL1]CLLORIAOB,[M:CLL1]CLLORIAVA,"","","[M:CLL1]CLLORIVCRD") From CRMUTIL140 # FGR 04/03/2010 : X3SUIVI62924
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$RAZCRE
Local Char SZNVGCOD

  Raz SZNVGCOD
  Raz GTBCLLFIELDSYL
  Raz GTBCLLVALSYL
  Raz GTBCLLCHRONOSYL
  GICLLNBSYL = 0
  # FGR 07/04/2015 : X3SUIVI107457 (début)
  If [M:CLL0]CLLCMP <> "" Then
    Local Char SVALEUR(type([M:CLL0]CLLCMP)-10)

    SVALEUR = [M:CLL0]CLLCMP
    Call AM_CLLCMP(SVALEUR) From W1CLL0
  Endif
  # FGR 07/04/2015 : X3SUIVI107457 (fin)
  #Clob
  [M:CLL1]TYPFULOBJ = "CLLOBJ"
  [M:CLL3]TYPFULRPO = "CLLRPO"
  #On initialise le site
  Call SITECRMDEF("ACT", [M:CLL0]SALFCY) From CRM_UTIL
  GFCY = [M:CLL0]SALFCY
  Call GETDEV(GFCY) From DEVSUB
  #Représentant connecté prioritaire
  If GCRMREPCLL = 2 Then
    Read [REP]REP1=GUSER
    If !fstat Then
      [M:CLL1]CLLREP = [F:REP]REPNUM
    Endif
  Endif
  #Initialise les valeurs par défaut de l'enregistrement
  If !GIMPORT Then
    If GPILNAV > 1 Then
      Case GNAVIG(GPILNAV-1)
        When "GESSRE"
          SZNVGCOD = [M:SRE0]NVGCOD
          Call GETSREOPP([M:SRE0]SRENUM, [M:CLL0]CLLOPP) From SUBSREB2
        When "FUNHDKAGD"
          SZNVGCOD = [M:HDK0]NVGCOD
          Call GETSREOPP([M:HDK0]HDKSRE, [M:CLL0]CLLOPP) From SUBSREB2
        When "GESBPR"
          SZNVGCOD = [M:BPR0]NVGCOD
        When "GESBPP"
          SZNVGCOD = [M:BPP0]NVGCOD
        When "GESBPC"
          SZNVGCOD = [M:BPC0]NVGCOD
        When "FUNCRM9"
          SZNVGCOD = [M:CRM9]NVGCOD
        When "FUNCRMAGD"
          SZNVGCOD = [M:CRM0]NVGCOD
        When "GESTSK"
          SZNVGCOD = [M:TSK0]NVGCOD
        When "GESCLL"
          SZNVGCOD = [M:CLL0]NVGCOD
        When "GESOPP"
          SZNVGCOD = [M:OPP0]NVGCOD
        When "GESLDS"
          # FGR 16/04/2012 : X3SUIVI81045
          SZNVGCOD = [M:LDS0]NVGCOD
        When Default
          If GDONDEFCLL = 2 Then
            SZNVGCOD = "{"
          Else
            SZNVGCOD = "("
          Endif
      Endcase
    Endif
    If SZNVGCOD = "(" Then
      #Appel à planifier
      [M:CLL0]CLLDON = 1
      [M:CLL0]CLLTYP = 2
    Elsif SZNVGCOD = "{" Then
      #Appel effectué
      [M:CLL0]CLLDON = 2
      [M:CLL0]CLLTYP = GCLLTYPDEF
    Elsif SZNVGCOD = "" Then
      #LSE 16/01/2006 Si on vient directement du menu
      [M:CLL0]CLLDON = GDONDEFCLL
      [M:CLL0]CLLTYP = GCLLTYPDEF
    Endif
  Else
    [M:CLL0]CLLDON = GDONDEFCLL
    [M:CLL0]CLLTYP = GCLLTYPDEF
  Endif
  If [M:CLL1]CLLDAT = [00/00/00] Then
    [M:CLL1]CLLDAT = date$
    [M:CLL1]CLLDATX = date$
    [M:CLL1]CLLWEE = week(date$)
  Else
    [M:CLL1]CLLDATX = [M:CLL1]CLLDAT
    [M:CLL1]CLLWEE = week([M:CLL1]CLLDAT)
  Endif
  If [M:CLL1]CLLHOU = "" Then
    [M:CLL1]CLLHOU = left$(time$, 2) + mid$(time$, 4, 2)
  Endif
  If [M:CLL1]CLLPIOLEV = "" Then
    Call DEFVALADI(405, [M:CLL1]CLLPIOLEV) From CRMUTIL140
  Endif
  Call DEFVALADI(432, [M:CLL1]CLLCAT) From CRMUTIL140
  #Origine
  [M:CLL1]CREDAT = date$
  [M:CLL1]CREUSR = GUSER
  Read [AUS]CODUSR=GUSER
  If fstat Then
    [M:CLL1]FULNAMUSR = GUSER
  Else
    [M:CLL1]FULNAMUSR = [F:AUS]NOMUSR
  Endif
  # FGR 04/03/2010 : X3SUIVI62924 (début)
  #[M:CLL1]CLLORIOBC = ""
  #[M:CLL1]CLLORI = 1
  #[M:CLL1]CLLORITXT = ""
  If [M:CLL1]CLLORIADI = "" Then
    Raz [M:CLL1]CLLORIAOB
    [M:CLL1]CLLORIADI = "MAN1"
    # FGR 15/11/2010 : X3SUIVI67018 : C'est mieux ici
    Raz [M:CLL1]CLLORIVCR
    Raz [M:CLL1]CLLORIVCRL
    Raz [M:CLL1]CLLORIVCRD
  Else
    # FGR 17/03/2010 : X3SUIVI62924 : pour faire correctement si on vient en création tunnel.
    [M:CLL1]CLLORIAOB = func CRMUTIL150.GET_AOB_FROM_ORI([M:CLL1]CLLORIADI)
    Call DEFOBJORI([M:CLL1]CLLORIAOB, [M:CLL1]CLLORIAVA) From CRMUTIL150
    Call LIEN_OBJ_DYNAMIC([M:CLL1]CLLORIVCR,[M:CLL1]CLLORIAOB,[M:CLL1]CLLORIAVA,"","","[M:CLL1]CLLORIVCRD") From CRMUTIL140
  Endif
  # FGR 04/03/2010 : X3SUIVI62924 (fin)
  Diszo [M:CLL1]CLLORIVCR
  #Diszo [M:CLL1]CLLORITXT
  Diszo [M:CLL1]CLLORIADI   # FGR 05/03/2010 : X3SUIVI62924
  If !GIMPORT Then
    [M:CLL1]CLLORITYP = 1
  Else
    If GSYNCOUTLOOK = 0 Then
      [M:CLL1]CLLORITYP = 2
    Else
      [M:CLL1]CLLORITYP = 3
    Endif
  Endif
  #[M:CLL1]CLLORILIB = mess([M:CLL1]CLLORITYP,3037,1)  # FGR 05/03/2010 : X3SUIVI62924
  If [M:CLL0]CLLCMP <> "" Then
    #Définit l'interlocuteur par défaut du rendez-vous
    If [M:CLL0]CLLCCN = "" Then
      Call GETDEFCNT([M:CLL0]CLLCMP, [M:CLL0]CLLCCN) From CRMUTIL140
    Endif
    #Définit le représentant et le site par défaut.
    Read [BPR]BPR0=[M:CLL0]CLLCMP
    If fstat Then
      #Affiche le nom en clair du tiers sélectionné.
      [M:CLL0]CLLCMPCLA = ""
    Else
      #Affiche le nom en clair du tiers sélectionné.
      [M:CLL0]CLLCMPCLA = [F:BPR]BPRNAM
      If [M:CLL1]CLLREP = "" Then
        If [F:BPR]BPCFLG = 2 or [F:BPR]PPTFLG = 2 Then
          Read [BPC]BPC0=[M:CLL0]CLLCMP
          If !fstat Then
            If [F:BPC]REP(0) <> "" Then
              [M:CLL1]CLLREP = [F:BPC]REP(0)
            Else
              If [F:BPC]REP(1) <> "" Then
                [M:CLL1]CLLREP = [F:BPC]REP(1)
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
    #Affiche le type du tiers sélectionné.
    Call AFFICHE_BCK_TIERS([M:CLL0]CLLCMP) From SUBCLLB
  Endif
  If [M:CLL0]CLLCCN <> "" Then
    Gosub SETCCNINF From SUBCLLB
  Endif
  If GCRMDEFREP = 2 Then
    If [M:CLL1]CLLREP = "" Then
      Read [REP]REP1=GUSER
      If !fstat Then
        [M:CLL1]CLLREP = [F:REP]REPNUM
      Endif
    Endif
  Endif
  Call SITECRMREP("ACT", [M:CLL1]CLLREP, [M:CLL0]SALFCY) From CRM_UTIL
  If GFCY <> [M:CLL0]SALFCY Then
    GFCY = [M:CLL0]SALFCY
    Call GETDEV(GFCY) From DEVSUB
  Endif
  [M:CLL1]CLLCMGFLG = GCLLOMPFLG         # FGR 17/04/2009 : X3SUIVI54457
  Call INIT_ICON_RETOUR([M:CLL1]CLLCMGFLG) From SUBCLLB
  #
  [M:CLL3]CLLDURX = mess(2,301,1)
  # FGR 15/11/2010 : X3SUIVI67018 : C'est pas terrible ici
  # FGR 16/04/2009 : X3SUIVI54457
  #Raz [M:CLL1]CLLORIVCR
  #Raz [M:CLL1]CLLORIVCRL
  #Raz [M:CLL1]CLLORIVCRD
  #En cas de création manuelle depuis une campagne d'appel, on réaffecte l'origine.
  Gosub RAZCREDUP_TUNNEL_OMP
  Call DISPICON_RETOUR From SUBCLLB # FGR 20/04/2009 : X3SUIVI54457
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBCLLB
  Gosub DISPBKGCCN From SUBCLLB
  Affzo [M:CLL0]1-99
  Affzo [M:CLL1]1-99
  Affzo [M:CLL3]1-99
Return

##########################################################################################################
$RAZDUP
  Raz GTBCLLFIELDSYL
  Raz GTBCLLVALSYL
  Raz GTBCLLCHRONOSYL
  GICLLNBSYL = 0
  #Origine
  [M:CLL1]CREDAT = date$
  [M:CLL1]CREUSR = GUSER
  Read [AUS]CODUSR=GUSER
  If fstat Then
    [M:CLL1]FULNAMUSR = GUSER
  Else
    [M:CLL1]FULNAMUSR = [F:AUS]NOMUSR
  Endif
  If !GIMPORT Then
    [M:CLL1]CLLORITYP = 1
  Else
    If GSYNCOUTLOOK = 0 Then
      [M:CLL1]CLLORITYP = 2
    Else
      [M:CLL1]CLLORITYP = 3
    Endif
  Endif
  # FGR 08/01/2009 : X3SUIVI51465 (début)
  [M:CLL1]CLLCMGFLG = GCLLOMPFLG         # FGR 17/04/2009 : X3SUIVI54457
  Call INIT_ICON_RETOUR([M:CLL1]CLLCMGFLG) From SUBCLLB
  # FGR 08/01/2009 : X3SUIVI51465 (fin)
  #[M:CLL1]CLLORILIB = mess([M:CLL1]CLLORITYP,3037,1)  # FGR 05/03/2010 : X3SUIVI62924
  # FGR 16/04/2009 : X3SUIVI54457 : En duplication on conserve le lien s'il y en avait un
  #[M:CLL1]CLLORIOBC = ""
  #[M:CLL1]CLLORI = 1
  #[M:CLL1]CLLORITXT = ""
  #Raz [M:CLL1]CLLORIVCR
  #Raz [M:CLL1]CLLORIVCRL
  #Raz [M:CLL1]CLLORIVCRD
  #En cas de création manuelle depuis une campagne d'appel, on réaffecte l'origine.
  Gosub RAZCREDUP_TUNNEL_OMP
  Call DISPICON_RETOUR From SUBCLLB # FGR 20/04/2009 : X3SUIVI54457
  #
  Affzo [M:CLL1]1-99
  Diszo [M:CLL1]CLLORIVCR
  #Diszo [M:CLL1]CLLORITXT
  Diszo [M:CLL1]CLLORIADI   # FGR 05/03/2010 : X3SUIVI62924
Return

##########################################################################################################
$SETBOUT
  CHMEN += "PQ"
  Case REP
    When ""
      #Impossible de reporter un appel effectué.
      If [M:CLL0]CLLDON = 2 Then
        Call VIREBOUT(CHAINE, "B") From GOBJET
      Else
        CHMEN += "N"
      Endif
      CHMEN += "O"
    When "M", "C", "D"
      Call VIREBOUT(CHAINE,"B") From GOBJET
      #Pas de bouton script lors d'un accès depuis une campagne d'appels
      If GPILNAV > 1 Then
        If GNAVIG(GPILNAV-1) = "GESOMP" Then
          Call VIREBOUT(CHAINE,"G") From GOBJET
        Endif
      Endif
    When Default
  Endcase
  If [M:CLL1]CLLSCP = "" Then
    Call VIREBOUT(CHAINE, "G") From GOBJET
  Endif
  #Menu Actions   Module Action Co
  # } : Enregistrer un rendez-vous
  # ~ : Enregistrer une tâche
  # ! : Enregistrer une affaire
  # % : Enregistrer une demande de service
  # ) : Planifier un rendez-vous
  # £ : Planifier une tâche
  # | : Traçabilité des pièces          # FGR 17/10/2012 : X3SUIVI71278
  If REP = "" Then
    CHMEN += "}~!)£|"
  Endif
  If REP = "" and GMODU(12) = 2 Then
    CHMEN += "%"
  Endif
  #Objet accédé directement depuis une campagne d'appel clôturée
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESOMP" Then
      If [M:OMP2]CLO = 2 Then
        Call VIREBOUT(CHAINE, "C") From GOBJET
      Endif
    Endif
  Endif
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

##########################################################################################################
$AVANTBOUT
  [M:CLL0]NVGCOD = BOUT
  Case BOUT
    When ")"
      #Planifier Rendez-vous
      GBCRMFLGNEW = 1
    When "£"
      #Planifier Tache
      GBCRMFLGNEW = 1
    When "}"
      #Enregistrer Rendez-vous
      GBCRMFLGNEW = 1
    When "~"
      #Enregistrer Tache
      GBCRMFLGNEW = 1
    When "!"
      #Enregistrer Affaire
      GBCRMFLGNEW = 1
    When "%"
      #Enregistrer demande de service
      GBCRMFLGNEW = 1
  Endcase
Return

##########################################################################################################
$VERIF_CRE_MOD
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Char SZMESS(250)
Local Integer IASK
Local Integer ICRECLLFLG

  IBRETOUR = 1
  GOK = 1
  SZMESS = ""
  IASK = 0
  Gosub SETCLLDATX From SUBCLLB
  # FGR 06/07/2011 : X3SUIVI74797 : En fait pas si l'origine est "synchronisation" sinon ça devient obligatoire lorsqu'on modifie dans l'écran
  # FGR 09/10/2009 : X3SUIVI58275 : Pas si synchronisation outlook : l'info n'y est pas.
  #If [M:CLL0]CLLCMP = "" and  [M:CLL0]CLLCCN = "" and [M:CLL0]CLLCOR = "" and GSYNCOUTLOOK = 0 Then
  If [M:CLL0]CLLCMP = "" and  [M:CLL0]CLLCCN = "" and [M:CLL0]CLLCOR = "" and [M:CLL1]CLLORITYP <> 3 Then
    # FGR 20/08/2009 : X3SUIVI57294 : Au moins un des champs est renseigné
    GMESSAGE = mess(976,196,1) #Aucun représentant n'est mentionné.
    GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
    OK = 0
    Return
  Endif
  [M:CLL1]CLL3OMPFLG = 0
  If ACTION = "VERIF_CRE" Then
    #Un appel créé depuis une campagne d'appel doit toujours être sortant, planifié et sans compte-rendu
    If !GIMPORT Then
      If GPILNAV > 1 Then
        If GNAVIG(GPILNAV-1) = "GESOMP" Then
          Gosub CHECKFEAOMPCLL From SUBCLLB
          If OK = 0 Then
            Return
          Endif
        Endif
      Endif
    Endif
  Endif
  #Enregistre toujours un appel entrant en tant que effectué.
  If [M:CLL0]CLLTYP = 1 Then
    If [M:CLL0]CLLDON <> 2 Then
      [M:CLL0]CLLDON = 2
      Affzo [M:CLL0]CLLDON
    Endif
  Endif
  #Affecte l'appel à l'utilisateur si rien n'a été saisi ni déduit.
  If [M:CLL1]CLLREP = "" Then
    Read [REP]REP1=GUSER
    If fstat Then
      GMESSAGE = mess(249,196,1) #Aucun représentant n'est mentionné.
      GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
      OK = 0
      Return
    Else
      #Aucun représentant n'a été saisi pour cette action. Souhaitez-vous l'affecter à :
      SZMESS = mess(409,182,1) - [F:REP]REPNAM - "(" + [F:REP]REPNUM + ")"
      Call OUINON(SZMESS, IASK) From GESECRAN
      If IASK = 2 Then
        [M:CLL1]CLLREP = [F:REP]REPNUM
        Affzo [M:CLL1]1-99
      Else
        GMESSAGE = mess(249,196,1) #Aucun représentant n'est mentionné.
        GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
        OK = 0
        Return
      Endif
    Endif
    If [M:CLL1]CLLREP <> "" Then
      Call SITECRMREP("ACT", [M:CLL1]CLLREP, [M:CLL0]SALFCY) From CRM_UTIL
      GFCY = [M:CLL0]SALFCY
      Call GETDEV(GFCY) From DEVSUB
      Affzo [M:CLL0]SALFCY
    Endif
  Endif
  # FGR 06/08/2014 : X3SUIVI95250 (début)
  #  #Assure enregistrement description abrégé
  #  If [M:CLL1]FULOBJ = "" Then
  #    [M:CLL1]CLLOBJ = ""
  #  Else
  #    [M:CLL1]CLLOBJ = left$([M:CLL1]FULOBJ,250)
  #  Endif
  #  #Assure enregistrement début cpt rendu
  #  If [M:CLL3]FULRPO = "" Then
  #    [M:CLL3]CLLRPO = ""
  #  Else
  #    [M:CLL3]CLLRPO = left$([M:CLL3]FULRPO,250)
  #  Endif
  # FGR 06/08/2014 : X3SUIVI95250 (fin)
  #Assure le bon enregistrement de l'origine de la tâche
  # FGR 04/03/2010 : X3SUIVI62924 (début)
  #If [M:CLL1]CLLORI > 1 Then
  #  [M:CLL1]CLLORITXT = mess([M:CLL1]CLLORI,2993,1)
  #Else
  #  [M:CLL1]CLLORITXT = ""
  #Endif
  # FGR 04/03/2010 : X3SUIVI62924 (fin)
  Gosub VERIFORI From SUBCLLB
  If GERR <> 0 Then
    OK = 0
    Return
  Endif
  Gosub VERIFDATE From SUBCLLB
  If OK = 0 Then
    Return
  Endif
  #Gestion du partage des clobs avec le marketing
  Gosub SHARECLOB2 From SUBCLLB
  If GOK < 1 Then
    OK = 0
    Return
  Endif
  #Contrôle de l'intégration de l'appel dans une opération marketing
  # FGR 17/04/2009 : X3SUIVI54457 : on ne le fait plus c'est via le bouton que l'utilisateur le dit maintenant
  #[M:CLL1]CLLOMPFLG = 0
  #Gosub CTLASSTOOMP From SUBCLLB
  #If GOK < 1 Then
  #  OK = 0
  #  Return
  #Endif
  #Contrôle du représentant pour les appels associés à une campagne d'appels
  Gosub CHECKOMPREP From SUBCLLB
  If OK = 0 Then
    Return
  Endif
  #Vérifie la date d'un appel de campagne d'appels
  If [M:CLL1]CLLCMGFLG = 1 Then
    If [M:CLL1]CLLCMGNUM <> "" Then
      #Campagne marketing précisée
      If [M:CLL1]CLLOPGNUM <> "" Then
        #Opération marketing précisée
        Read [OMP]OMP0=[M:CLL1]CLLOPGNUM    #La campage d'appels existe
        If !fstat Then
          If [M:CLL1]CLLDAT < [F:OMP]OMPSTR Then
            #L'appel ne peut pas être planifié avant la date de début de la campagne d'appels.
            GMESSAGE = mess(128,177,1)
            GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
            OK = 0
            Return
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$VERIF_CRE
Local Integer ICRECLLFLG

  ICRECLLFLG = 1
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  If not (GSYNCOUTLOOK = 1 and vireblc([M:CLL0]CLLNUM,2) <> "") Then
    # On n'est pas en restauration de synchro
    Call READ_COUNTER([M:CLL0]SALFCY, 13, 0, GSOCIETE, GCURLEG, GCCLLCPT, GMANCOU) From CRM_UTIL   # FGR 20/05/2015 : X3SUIVI107775
    # Récupération du compteur Activité commerciale
    If func CRM_UTIL.GET_NUMERO_CHRONO ("ACT", [M:CLL0]SALFCY, GCCLLCPT, date$, "", [M:CLL0]CLLNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
      If IBRETOUR = 1 Then
        [F:CLL]CLLNUM = [M:CLL0]CLLNUM
        Affzo [M:CLL0]CLLNUM
      Else
        # problème lors de la récupération du compteur
        GERR = 1
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GOK = 0
        Return
      Endif
    Endif
  Endif
  [F:CLL]NUMFULOBJ = [M:CLL0]CLLNUM
  [M:CLL1]NUMFULOBJ = [M:CLL0]CLLNUM
  [F:CLL]NUMFULRPO = [M:CLL0]CLLNUM
  [M:CLL3]NUMFULRPO = [M:CLL0]CLLNUM
  [F:CLL]CREHOU = left$(time$, 2) + mid$(time$, 4, 2)
  #On regarde si gestion du correspondant
  Call CORGERE ([M:CLL1]CLLREP, [M:CLL0]CLLCMP,[M:CLL0]CLLCCN,[M:CLL0]CLLCOR, IERRINF, ICHAPTER, IBRETOUR) From SUBCORB
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
    OK = 0
    Return
  Endif
  [F:CLL]CLLCOR = [M:CLL0]CLLCOR
  If [M:CLL0]CLLCOR <> "" Then
    Affzo [M:CLL0]CLLCOR
  Endif
Return

##########################################################################################################
$CREATION
Local Instance GZINSOPP Using C_OPPOR
Local Integer IRET
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  IBRETOUR = 1
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBCLLB
  If GOK < 1 Then
    Return
  Endif
  Gosub SAVECLOB2 From SUBCLLB
  If GOK < 1 Then
    Return
  Endif
  #Enregistrement des données pour les encours
  Gosub GERE_LCM_CREATION From SUBCLLB
  If GOK < 1 Then
    Return
  Endif
  #Ajout de l'appel dans le nombre des appels de la campagne d'appels
  # FGR 17/04/2009 : X3SUIVI54457 : on ajoute si [M:CLL1]CLLCMGFLG = 1
  #If [M:CLL1]CLLOMPFLG or [M:CLL1]CLL2OMPFLG Then
  If [M:CLL1]CLLCMGFLG = 1 Then
    # FGR 16/10/2009 : X3SUIVI58861
    #Gosub PUTINOMP From SUBCLLB
    Call PUTINOMP([M:CLL1]CLLCMGNUM, [M:CLL1]CLLOPGNUM, [M:CLL1]CLLREP, [M:CLL1]CLL3OMPFLG) From SUBCLLB
    If GOK < 1 Then
      Return
    Endif
  Endif
  #Traitement des données de synchro pour l'appel
  Call SYDCLLCRE (IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
  If GOK < 1 Then
    Return
  Endif
  Diszo [M:CLL1]CLLORIVCR
  #Diszo [M:CLL1]CLLORITXT
  Diszo [M:CLL1]CLLORIADI   # FGR 05/03/2010 : X3SUIVI62924
  #Incrémentation des étapes avant-vente de l'affaire
  # --------------------------------------
  # FGR 12/08/2015 : X3SUIVI108275 (début)
  #  Call ADDOPPSTE("CLL", [M:CLL0]PREOPP, [M:CLL0]CLLOPP, [M:CLL0]CLLNUM, SZMESSAGE, IBRETOUR) From SUBOPPB  # FGR 03/05/2011 : X3SUIVI71031
  #  If IBRETOUR = 0 Then
  #    GMESSAGE = SZMESSAGE
  #    GERR = 1
  #    GOK = 0
  #  Endif
  #  If GOK < 1 Then
  #    Return
  #  Endif
  If [M:CLL0]CLLOPP <> "" or [M:CLL0]PREOPP <> "" Then
    GZINSOPP = NewInstance With C_OPPOR #AllocGroup null
    IRET = fmet GZINSOPP.CRM_ADD_STEPB([M:CLL0]CLLOPP, "CLL", [M:CLL0]CLLNUM, [M:CLL0]PREOPP)
    If IRET <> [V]CST_AOK Then
      GMESSAGE = [M:CLL0]CLLOPP - ":" - func LCCLIB.MAXMSG(GZINSOPP)
      FreeGroup GZINSOPP
      GERR = 1
      GOK = 0
      Return
    Endif
    FreeGroup GZINSOPP
  Endif
  # FGR 12/08/2015 : X3SUIVI108275 (fin)
  # --------------------------------------
  # Maj des statistiques
  Call VALSTA("CLL",1) From SUBPS2
Return

##########################################################################################################
$VERIF_MOD
Local Integer ICRECLLFLG

  ICRECLLFLG = 0
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$INIMOD
  #On regarde si gestion du correspondant
  Call CORGERE ([M:CLL1]CLLREP, [M:CLL0]CLLCMP, [M:CLL0]CLLCCN, [M:CLL0]CLLCOR, IERRINF, ICHAPTER, IBRETOUR) From SUBCORB
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1  # FGR 11/01/2013 : X3SUIVI87120 : Pas GERR = 2
    OK = 0
    Return
  Endif
  [F:CLL]CLLCOR = [M:CLL0]CLLCOR
  If [M:CLL0]CLLCOR <> "" Then
    Affzo [M:CLL0]CLLCOR
  Endif
Return

##########################################################################################################
$AVANT_MODFIC
  # Classe [F:CLL] anciennes valeurs
  # Classe [M:CLLx] nouvelle valeurs
  # FGR 17/04/2009 : X3SUIVI54457
  If [M:CLL1]CLLOPGTYP <> [F:CLL]CLLOPGTYP or [M:CLL1]CLLCMGNUM <> [F:CLL]CLLCMGNUM or [M:CLL1]CLLOPGNUM <> [F:CLL]CLLOPGNUM or [M:CLL1]CLLREP <> [F:CLL]CLLREP Then
    # S'il y a eu un changement lors de la modification...
    If [F:CLL]CLLOPGTYP = "OMP" Then
      # ...et qu'avant la modification, l'appel avait "Campagne d'appel" pour origine : On décrémente sur l'origine
      # Ca recompte tout, sauf le [F:CLL]CLLNUM courant
      Call REMINOMP([F:CLL]CLLNUM, [F:CLL]CLLCMGNUM, [F:CLL]CLLOPGNUM, [F:CLL]CLLREP) From SUBCLLB
      If GOK < 1 Then
        Return
      Endif
    Endif
    If [M:CLL1]CLLOPGTYP = "OMP" and [M:CLL1]CLLCMGFLG > 0 Then
      # On est sur une campagne d'appel, et ça n'est pas un retour : on l'ajoute à la campagne d'appels
      Call PUTINOMP([M:CLL1]CLLCMGNUM, [M:CLL1]CLLOPGNUM, [M:CLL1]CLLREP, [M:CLL1]CLL3OMPFLG) From SUBCLLB
      If GOK < 1 Then
        Return
      Endif
    Endif
  Else
    # On est toujours sur les mêmes valeurs : ce qui a pu change c'est CLLCMGFLG
    If [M:CLL1]CLLOPGTYP = "OMP" Then
      If [M:CLL1]CLLCMGFLG > 0 and [F:CLL]CLLCMGFLG = 0 Then
        # On n'est plus compté dans les retours
        Call PUTINOMP([M:CLL1]CLLCMGNUM, [M:CLL1]CLLOPGNUM, [M:CLL1]CLLREP, [M:CLL1]CLL3OMPFLG) From SUBCLLB
        If GOK < 1 Then
          Return
        Endif
      Elsif [M:CLL1]CLLCMGFLG = 0 and [F:CLL]CLLCMGFLG > 0 Then
        # On n'est plus compté dans les retours
        Call REMINOMP([M:CLL0]CLLNUM, [M:CLL1]CLLCMGNUM, [M:CLL1]CLLOPGNUM, [M:CLL1]CLLREP) From SUBCLLB
        If GOK < 1 Then
          Return
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$MODIF
Local Instance GZINSOPP Using C_OPPOR
Local Integer IRET
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer IINDICE

  IBRETOUR = 1
  IINDICE = 0
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBCLLB
  If GOK < 1 Then
    Return
  Endif
  Gosub SAVECLOB2 From SUBCLLB
  If GOK < 1 Then
    Return
  Endif
  #Enregistrement des données pour les encours
  Gosub GERE_LCM_MODIF From SUBCLLB
  If GOK < 1 Then
    Return
  Endif
  # FGR 17/04/2009 : X3SUIVI54457 : Déplacé dans $AVANT_MODFIC
  #Ajout de l'appel dans le nombre des appels de la campagne d'appels
  #If [M:CLL1]CLLOMPFLG Then
  #  Gosub PUTINOMP From SUBCLLB
  #  If GOK < 1 Then
  #    Return
  #  Endif
  #Endif
  #Incrémentation des étapes avant-vente de l'affaire
  # --------------------------------------
  # FGR 12/08/2015 : X3SUIVI108275 (début)
  #  Call ADDOPPSTE("CLL", [M:CLL0]PREOPP, [M:CLL0]CLLOPP, [M:CLL0]CLLNUM, SZMESSAGE, IBRETOUR) From SUBOPPB  # FGR 03/05/2011 : X3SUIVI71031
  #  If IBRETOUR = 0 Then
  #    GMESSAGE = SZMESSAGE
  #    GERR = 1
  #    GOK = 0
  #  Endif
  #  If GOK < 1 Then
  #    Return
  #  Endif
  If [M:CLL0]CLLOPP <> "" or [M:CLL0]PREOPP <> "" Then
    GZINSOPP = NewInstance With C_OPPOR #AllocGroup null
    IRET = fmet GZINSOPP.CRM_ADD_STEPB([M:CLL0]CLLOPP, "CLL", [M:CLL0]CLLNUM, [M:CLL0]PREOPP)
    If IRET <> [V]CST_AOK Then
      GMESSAGE = [M:CLL0]CLLOPP - ":" - func LCCLIB.MAXMSG(GZINSOPP)
      FreeGroup GZINSOPP
      GERR = 1
      GOK = 0
      Return
    Endif
    FreeGroup GZINSOPP
  Endif
  # FGR 12/08/2015 : X3SUIVI108275 (fin)
  # --------------------------------------
  Gosub SETOPG From SUBCLLB
  #Traitement de la synchronisation outlook
  Call SYDCLLUPD (IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
  If GOK < 1 Then
    Return
  Endif
  #traitement des erreurs de transcodification
  If GICLLNBSYL > 0 Then
    While IINDICE < GICLLNBSYL
      If GTBCLLVALSYL(IINDICE) <> evalue ("[M]" + GTBCLLFIELDSYL(IINDICE )) Then
        #On a une modification du champs, on estime transcodif faite
        Read [SYL]SYL0=GTBCLLCHRONOSYL(IINDICE)
        If fstat = 0 Then
          [F:SYL]SYLFLGDPT = 0
          Rewrite [SYL]
        Endif
      Endif
      IINDICE = IINDICE + 1
    Wend
  Endif
  Diszo [M:CLL1]CLLORIVCR
  #Diszo [M:CLL1]CLLORITXT
  Diszo [M:CLL1]CLLORIADI # FGR 05/03/2010 : X3SUIVI62924
  #
  # Maj des statistiques
  Call VALSTA("CLL",-1) From SUBPS2
  Call VALSTA("CLL",1) From SUBPS2
Return

##########################################################################################################
$AV_ANNULE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer IASWFOUND
Local Integer IASWREP

  IBRETOUR = 1
  #Suppression des clobs
  Gosub DELCLOB From SUBCLLB
  If GOK < 1 Then
    Return
  Endif
  Gosub DELCLOB2 From SUBCLLB
  If GOK < 1 Then
    Return
  Endif
  # FGR 12/08/2009 : X3SUIVI57005 : C'est pas là que ça doit être
  #Enregistrement des données pour les encours
  #Gosub GERE_LCM_ANNULE From SUBCLLB
  #If GOK < 1 Then
  #  Return
  #Endif
  Call SYDCLLDEL (IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
  If GOK < 1 Then
    Return
  Endif
  #Suppression donnée transcodif
  Call SYLDELETE("CLL", [M:CLL0]CLLNUM, IERRINF, ICHAPTER, IBRETOUR) From SUBSYLB
  If GOK < 1 Then
    Return
  Endif
  #Suppression des tentatives d'appels
  Delete [CTT] Where [F:CTT]CLLNUM = [M:CLL0]CLLNUM
  If fstat Then
    #Erreur lors de la suppression des tentatives d'appels associées.
    GMESSAGE = mess(922,182,1)
    GERR = 1
    Call FSTA("CTT") From GLOCK
    GOK = 0
    Return
  Endif
  #Si l'appel est généré par une campagne d'appel on décrémente le nombre d'appels de la campagne.
  If [M:CLL1]CLLCMGFLG = 1 Then
    If [M:CLL1]CLLCMGNUM <> "" Then
      If [M:CLL1]CLLOPGNUM <> "" Then
        If [M:CLL1]CLLOPGTYP = "OMP" Then
          #Retrait de l'appel dans le nombre des appels de la campagne d'appels
          Call REMINOMP([M:CLL0]CLLNUM, [M:CLL1]CLLCMGNUM, [M:CLL1]CLLOPGNUM, [M:CLL1]CLLREP) From SUBCLLB
          If GOK < 1 Then
            Return
          Endif
        Endif
      Endif
    Endif
  Endif
  #Suppression des questions dans les différents scripts
  IASWREP = 0
  IASWFOUND = 0
  Filter [SCA] Where [F:SCA]CLL = [M:CLL0]CLLNUM
  For [SCA]
    IASWFOUND = 1
    Break
  Next
  Filter [SCA]
  If IASWFOUND
    #Souhaitez-vous supprimer les réponses aux scripts associés à cet appel ?
    Call OUINON(mess(139,177,1), IASWREP) From GESECRAN
    If IASWREP = 2 Then
      Delete [SCA] Where [F:SCA]CLL = [M:CLL0]CLLNUM
      If fstat Then
        #Erreur lors de la suppression des réponses aux scripts d'appels.
        GMESSAGE = mess(140,177,1)
        GERR = 1
        Call FSTA("SCA") From GLOCK
        GOK = 0
        Return
      Endif
    Endif
  Endif
Return

##########################################################################################################
$ANNULE
Local Instance GZINSOPP Using C_OPPOR # Issue X3-60113 - 2017-10-20 by FGR : was missing

  # --------------------------------------
  # FGR 12/08/2015 : X3SUIVI108275 (début)
  #  # FGR 05/05/2011 : X3SUIVI71031 (début)
  #  Call DELOPPSTE("CLL", [M:CLL0]CLLOPP, [M:CLL0]CLLNUM, SZMESSAGE, IBRETOUR) From SUBOPPB
  #  If IBRETOUR = 0 Then
  #    GMESSAGE = SZMESSAGE
  #    GERR = 1
  #    GOK = 0
  #    Return
  #  Endif
  #  # FGR 05/05/2011 : X3SUIVI71031 (fin)
  If [M:CLL0]CLLOPP <> "" Then
    GZINSOPP = NewInstance With C_OPPOR #AllocGroup null
    IRET = fmet GZINSOPP.CRM_DEL_STEPB([M:CLL0]CLLOPP, "CLL", [M:CLL0]CLLNUM)
    If IRET <> [V]CST_AOK Then
      GMESSAGE = [M:CLL0]CLLOPP - ":" - func LCCLIB.MAXMSG(GZINSOPP)
      FreeGroup GZINSOPP
      GERR = 1
      GOK = 0
      Return
    Endif
    FreeGroup GZINSOPP
  Endif
  # FGR 12/08/2015 : X3SUIVI108275 (fin)
  # --------------------------------------
  # Maj des statistiques
  Call VALSTA("CLL",-1) From SUBPS2
Return

##########################################################################################################
$APRES_ANNULE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  # FGR 12/08/2009 : X3SUIVI57005 : Pour le moment, il n'y a que là qu'on peut le mettre
  #                  Le pb c'est que ça n'est pas dans la transaction, donc si ça échoue,
  #                  L'enregistrement sera détruit, mais les Premier/Dernier/Prochain ne seront pas forcément à jour
  #Enregistrement des données pour les encours
  Gosub GERE_LCM_ANNULE From SUBCLLB
  If GOK < 1 Then
    Return
  Endif
Return

