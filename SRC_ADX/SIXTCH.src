#<AdxTL>@(#)4.0.0.0 $Revision$
#########################################################################
#  SIXTCH : pour traitements de bascule Integrale --> X3                #
#########################################################################
#                                                                       #
# Subprog SIXTCH                                                        #
#     Création des cours devises                                        #
#                                                                       #
#                                                                       #
# --------------------------------------------------------------------- #
# PRE-REQUIS :                                                          #
# --------------------------------------------------------------------- #
#     1 - Migrations précédentes : Société, Devises                     #
#     1 - Positionner GDECRCU                                           #
#                                                                       #
#                                                                       #
#                                                                       #
#########################################################################
# Sous l'Intégrale, 3 tables des cours
#  - DVS (DVS)........................... Devise
#        Paramètrage de la devise avec un taux certrain et incertain    
#            - PAYS IN -
#            Taux incertain =>  avant 01/01/99 (=Date de passage en mode de cotation certaine)
#            Taux certain   =>  après 01/01/99 
#            - PAYS OUT -
#            Taux incertain => tout le temps...
#            Taux certain   => aucune utilité... pourtant information obligatoire.
#
#
#  - HIS_DVS (HISDVS).................... Historique des cours
#        Stock pour une devise à une date donnée : un taux 'Achat', taux 'Vente', taux 'Comptabilité'
#
#  - TAU_MOY_DLR_CEE (XITAUMRCEE)........ Taux moyen déclaration CEE
#        Stock pour une devise à une date donnée, un taux moyen
#
#  - TAU_MOY_ECA_CVS (XITAUMACVS)........ Taux moyen écart conversion
#        Stock pour une devise à une date donnée, un taux moyen
#
#
#
# Pour la migration, X3 va récupérer 
#   - Taux 'Certain'              => cours du jour à la date du 01/01/99
#   - Taux 'Comptabilité'         => cours du jour à la date d'application 
#   - Taux 'Ecart de conversion'  => cours moyen
#  
# Chaque dossier Intégrale est référencé par rapport à la "Monnaie de Tenue" (Information sous la Fiche société)
#    
#
# Via l'interface de tréso. (commentaire CSB)
#  cotation au certain    : une unité de la monnaie locale est exprimée en n unités d'une devise étrangère
#  cotation à l'incertain : une unité de la devise étrangère est exprimée en unité de la devise locale
#
#########################################################################
# EXEMPLES
#
#  Lot 316 => GBP  Initialisation par le taux certain 
#  Lot 345 => DO   Saisi un cours Comptabilité, L'intégrale l'a repris.
#  Lot 346 => EE   Saisi d'une nouvelle devise OUT avec taux certain et incertain, L'intégrale a pris taux certain.
#
#  Après migration
#    Création de la pièce ODL / ODL-ZZ0702-001 => qui est à l'identique de 345
#            Intégrale => Taux historique "1.23" + Visu montant en Devise locale 813.01    (1EUR=1.23DO)
#            X3 => Affichage du cours inverse "0.81301" + Saisie des montants 1000 => Bouton Devise OK.
#
#    Création de la pièce ODL / ODL-ZZ0702-002 => qui est à l'identique de 316
#            Intégrale => Taux certain "0.6794258" + Visu Mnt en devise locale 662.32       (1EUR=0.6794258LS)
#            X3 => Affichage du cours inverse "1.47183" + Saisie des montants 450 => Bouton Devise OK.
#
#########################################################################
# Supp...
If !clalev([F:TCH])   : Local File TABCHANGE   [TCH]   : Endif   # Cours des devises
If !clalev([F:XDVS])  : Local File XIDVS       [XDVS]  : Endif   # Devises

Trbegin [TCH], [XDVS]
#Delete [TCH]  Where 1=1
Update [XDVS] Where 1=1 With FLGREP=1
Commit 
#End
Gosub SI_CONTEXT From SIXFONCTION
Global Integer X_NB
Call OUVRE_BOITE("XIDVS",nbrecord([XDVS])) From GESECRAN
Raz X_NB
Call EXEC
Call FERME_BOITE From GESECRAN
Kill X_NB
End

#########################################################################
Subprog EXEC

Local Integer WOUV_TRACE
If GTRACE = ""
 Call OUVRE_TRACE("SIXTCH : Process translation file from INTEGRALE to X3") From LECFIC
 WOUV_TRACE=1
Endif

Onerrgo TRT_ERR

#----  Migration des cours devise : TABCHANGE  ------#
Call ECR_TIME("SIXTCH : "+SI_MES(76)-"TABCHANGE") From DOSSUB

Call SI_TABCHANGE
If GOK<>1 : Goto FIN_TCH : Endif

$FIN_TCH
Onerrgo 
If WOUV_TRACE=1
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

$TRT_ERR
Call ECR_TRACE(errp-"("-num$(errl)-") :"-errmes$(errn)-errm, 1) From GESECRAN
Resume


######################################################################################
## Traitement des cours devises
######################################################################################
Subprog SI_TABCHANGE

Local Integer STOP, NB
Local Char LREPRISE(50)

Local Char CUR(GLONCUR)

## Tables Intégrale
If !clalev([F:XDVS])  : Local File =SI_DOSSIER+".XIDVS"      [XDVS]  : Endif  # Devises
If !clalev([F:XHDV])  : Local File =SI_DOSSIER+".XIHISDVS"   [XHDV]  : Endif  # Historique Devise
If !clalev([F:XTMC])  : Local File =SI_DOSSIER+".XITAUMACVS" [XTMC]  : Endif  # Taux moyen écart conversion

## Tables X3
If !clalev([F:TCU])   : Local File =SI_DOSSIER+".TABCUR"    [TCU]   : Endif  # Devises
If !clalev([F:TCH])   : Local File =SI_DOSSIER+".TABCHANGE" [TCH]   : Endif  # Cours Devises

Local Char WCUR1(GLONCUR), WCUR2(GLONCUR)
Local Decimal WRAT1, WRAT2
Local Date WDAT


SI_SUBPRG = "SIXTCH"
SI_TABLE  = "XIHISDVS"
Gosub SI_CRITSUP From SIXFONCTION

############################## A supprimer ultérieurement
Local Integer TEST
Raz TEST
#############################

$LOOP_TCH
Raz NB

If STOP=1
 CRITERE = "CODDVS>'"+LREPRISE+"'"
 STOP=0
Else
 CRITERE="1=1"
Endif

Call DEBTRANS From GLOCK
Trbegin [TCH]

# Cas particliuer pour les cours devises, le FLGREP de la tabel des devises va être utiliser pour vérifier
#  si les cours de chaque devise a été importés... ce qui permet également de les filter et de les compter cf CALNBENR
For [XDVS] Where left$(CODDVS,2)<>"$$" & FLGREP<>3
&             & evalue(CRITERE)
&             & evalue(SI_CRITERE)

 [L]CUR = func SIXFONCTION.SI_COR("XIDVS",[F:XDVS]CODDVS,"TABCUR",mess(21,129,1)-"("+[F:XDVS]CODDVS+")")
 Call AFFBOITE([L]CUR) From SUBSIM

 ## Historique des cours devise
 Gosub MAJ_HIS_CUR
 If GOK<>1 : Break : Endif

 Readlock [XDVS] Curr
 [F:XDVS]FLGREP = 3
 Rewrite [XDVS]

 # NB alimenté
 If NB>1000
  LREPRISE = [F:XDVS]CODDVS
  STOP     = 1
  Break
 Endif
Next

If GOK>0
 If SI_SIMU<>2
  Commit
 Else
  Rollback
 Endif
 If STOP
  Goto LOOP_TCH
 Endif
Else
 Rollback
Endif
End

$MAJ_HIS_CUR
# Pas d'initialisation pour la devise de reporting
If [L]CUR=GSYSCUR : Return : Endif

# Pas d'initialisation pour les devises non migré
Read [TCU]TCU0=[L]CUR
If fstat : Return : Endif

# Au cas où...
If [F:XDVS]TAUCER=0 : 
 # cours devise XXX non renseigné, veuillez le saisir manuellement
 Call ECR_TRACE(mess(21,129,1)-[F:TCU]CUR-SI_MES(250)+","-SI_MES(251),-1) From GESECRAN
 Return
Endif

# Stock "Taux certain"
Look [TCH]TCH0 = 1;[L]CUR;GSYSCUR;[01/01/1999]
If fstat
 Raz [F:TCH]
 [F:TCH]CHGTYP     = 1
 [F:TCH]CURDEN     = [L]CUR            # Devise de destination
 [F:TCH]CUR        = GSYSCUR           # Devise "Monnaie de Tenue"
 [F:TCH]CHGSTRDAT  = [01/01/1999]      # Date d'application
 [F:TCH]CHGRAT     = [F:XDVS]TAUCER
 [F:TCH]REVCOURS   = arr(1/[F:XDVS]TAUCER,10^-GDECRCU)
 [F:TCH]CHGDIV     = 1 

 [F:TCH]CREDAT     = date$
 [F:TCH]CREUSR     = GUSER              
 [F:TCH]UPDDAT     = date$
 [F:TCH]UPDUSR     = GUSER              

 SI_TABLE = "TABCHANGE"
 Gosub SI_BEFWRI From SIXFONCTION

 Write [TCH]

Else
 Readlock [TCH]TCH0 = 1;[L]CUR;GSYSCUR;[01/01/1999]
 If !fstat
  [F:TCH]CHGRAT     = [F:XDVS]TAUCER
  [F:TCH]REVCOURS   = arr(1/[F:XDVS]TAUCER,10^-GDECRCU)
  [F:TCH]CHGDIV     = 1 
  [F:TCH]UPDDAT     = date$
  [F:TCH]UPDUSR     = GUSER
  Rewrite [TCH]
 Endif
Endif
If fstat
 # Cours Devise (1): ... : Erreur d'écriture
 GOK = 0 : Call ECR_TRACE(mess(21,129,1)-"(1):"-num$([F:TCH]CHGTYP)-[F:TCH]CURDEN-[F:TCH]CUR-num$([F:TCH]CHGSTRDAT)-":"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 Return
Elsif TEST=1
 Call ECR_TRACE(mess(21,129,1)-"(1):"-num$([F:TCH]CHGTYP)-[F:TCH]CURDEN-[F:TCH]CUR-num$([F:TCH]CHGSTRDAT)-num$([F:TCH]REVCOURS),0) From GESECRAN
 NB+=1
Else
 NB+=1
Endif

Gosub INVERSE
If !GOK : Return : Endif

# Historique "Taux comptabilité"
For [XHDV] Where CODDVS=[XDVS]CODDVS
 If [F:XHDV]TAUCTB<>0
  Look [TCH]TCH0 = 1;[F:XHDV]CODDVS;GSYSCUR;[F:XHDV]DATAPP
  If fstat
   Raz [F:TCH]
   [F:TCH]CHGTYP     = 1
   [F:TCH]CURDEN     = [F:XHDV]CODDVS    # Devise de destination est celle saisie dans l'Intégrale
   [F:TCH]CUR        = GSYSCUR           # Devise "
   [F:TCH]CHGSTRDAT  = [F:XHDV]DATAPP
   [F:TCH]CHGRAT     = [F:XHDV]TAUCTB
   [F:TCH]REVCOURS   = arr(1/[F:XHDV]TAUCTB,10^-GDECRCU)
   [F:TCH]CHGDIV     = 1

   [F:TCH]CREDAT     = date$
   [F:TCH]CREUSR     = GUSER              
   [F:TCH]UPDDAT     = date$
   [F:TCH]UPDUSR     = GUSER              
 
   SI_TABLE = "TABCHANGE"
   Gosub SI_BEFWRI From SIXFONCTION

   Write [TCH]

  Else

   Readlock [TCH]TCH0 = 1;[F:XHDV]CODDVS;GSYSCUR;[F:XHDV]DATAPP
   If !fstat
    [F:TCH]CHGRAT     = [F:XHDV]TAUCTB
    [F:TCH]REVCOURS   = arr(1/[F:XHDV]TAUCTB,10^-GDECRCU)
    [F:TCH]CHGDIV     = 1
    [F:TCH]UPDDAT     = date$
    [F:TCH]UPDUSR     = GUSER              
 
    SI_TABLE = "TABCHANGE"
    Gosub SI_BEFWRI From SIXFONCTION

    Rewrite [TCH]
   Endif
  Endif
  If fstat
   # Cours Devise (2) ... : Erreur d'écriture
   GOK = 0 : Call ECR_TRACE(mess(21,129,1)-"(2):"-num$([F:TCH]CHGTYP)-[F:TCH]CURDEN-[F:TCH]CUR-num$([F:TCH]CHGSTRDAT)-":"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
   Break
  Elsif TEST=1
   Call ECR_TRACE(mess(21,129,1)-"(2):"-num$([F:TCH]CHGTYP)-[F:TCH]CURDEN-[F:TCH]CUR-num$([F:TCH]CHGSTRDAT)-num$([F:TCH]REVCOURS),0) From GESECRAN
  Endif

  Gosub INVERSE
  If !GOK : Break : Endif
 Endif
Next
If !GOK : Return : Endif

# Historique "Taux écrat de conversion"
For [XTMC] Where CODDVS=[XDVS]CODDVS
 If [F:XTMC]TAUMOY<>0
  Look [TCH]TCH0 = 2;[F:XTMC]CODDVS;GSYSCUR;[F:XTMC]DATAPP
  If fstat
   Raz [F:TCH]
   [F:TCH]CHGTYP     = 2
   [F:TCH]CURDEN     = [F:XTMC]CODDVS    # Devise de destination est celle saisie dans l'Intégrale
   [F:TCH]CUR        = GSYSCUR           # Devise "
   [F:TCH]CHGSTRDAT  = [F:XTMC]DATAPP
   [F:TCH]CHGRAT     = [F:XTMC]TAUMOY
   [F:TCH]REVCOURS   = arr(1/[F:XTMC]TAUMOY,10^-GDECRCU)
   [F:TCH]CHGDIV     = 1

   [F:TCH]CREDAT     = date$
   [F:TCH]CREUSR     = GUSER              
   [F:TCH]UPDDAT     = date$
   [F:TCH]UPDUSR     = GUSER              

   SI_TABLE = "TABCHANGE"
   Gosub SI_BEFWRI From SIXFONCTION

   Write [TCH]
  Else
   Readlock [TCH]TCH0 = 2;[F:XTMC]CODDVS;GSYSCUR;[F:XTMC]DATAPP
   If !fstat
    [F:TCH]CHGRAT     = [F:XTMC]TAUMOY
    [F:TCH]REVCOURS   = arr(1/[F:XTMC]TAUMOY,10^-GDECRCU)
    [F:TCH]CHGDIV     = 1

    [F:TCH]UPDDAT     = date$
    [F:TCH]UPDUSR     = GUSER              

    SI_TABLE = "TABCHANGE"
    Gosub SI_BEFWRI From SIXFONCTION

    Rewrite [TCH]
   Endif
  Endif

  If fstat
   # Cours Devise (3) : ... : Erreur d'écriture
   GOK = 0 : Call ECR_TRACE(mess(21,129,1)-"(3):"-[F:XDVS]CUR-":"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
   Break
  Elsif TEST=1
   Call ECR_TRACE(mess(21,129,1)-"(3):"-num$([F:TCH]CHGTYP)-[F:TCH]CURDEN-[F:TCH]CUR-num$([F:TCH]CHGSTRDAT)-num$([F:TCH]REVCOURS),0) From GESECRAN
  Endif

  Gosub INVERSE
  If !GOK : Break : Endif
 Endif
Next
If !GOK : Return : Endif
Return

$INVERSE
WCUR1 = [F:TCH]CUR
WCUR2 = [F:TCH]CURDEN
WDAT  = [F:TCH]CHGSTRDAT
WTYP  = [F:TCH]CHGTYP
WRAT1 = [F:TCH]CHGRAT
WRAT2 = [F:TCH]REVCOURS

Look [TCH]TCH0 = WTYP;WCUR1;WCUR2;WDAT
If fstat

 [F:TCH]CHGTYP    = 1
 [F:TCH]CURDEN    = WCUR1
 [F:TCH]CUR       = WCUR2
 [F:TCH]CHGSTRDAT = WDAT
 [F:TCH]CHGRAT    = WRAT2
 [F:TCH]REVCOURS  = WRAT1
 [F:TCH]CHGDIV     = 1

 [F:TCH]CREDAT     = date$
 [F:TCH]CREUSR     = GUSER              
 [F:TCH]UPDDAT     = date$
 [F:TCH]UPDUSR     = GUSER              

 SI_TABLE = "TABCHANGE"
 Gosub SI_BEFWRI From SIXFONCTION
 Write [TCH]

Else

 Readlock [TCH]TCH0 = WTYP;WCUR1;WCUR2;WDAT
 If !fstat
  [F:TCH]CHGRAT    = WRAT2
  [F:TCH]REVCOURS  = WRAT1
  [F:TCH]CHGDIV     = 1
  [F:TCH]UPDDAT     = date$
  [F:TCH]UPDUSR     = GUSER

  Rewrite [TCH]
 Endif
Endif

If fstat
 # Cours Devise ... : Erreur d'écriture
 GOK = 0 : Call ECR_TRACE(mess(21,129,1)-"(I)"-num$([F:TCH]CHGTYP)-[F:TCH]CURDEN-[F:TCH]CUR-num$([F:TCH]CHGSTRDAT)-num$([F:TCH]REVCOURS)-":"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 Return
Elsif TEST=1
  Call ECR_TRACE(mess(21,129,1)-"(I):"-num$([F:TCH]CHGTYP)-[F:TCH]CURDEN-[F:TCH]CUR-num$([F:TCH]CHGSTRDAT)-num$([F:TCH]REVCOURS),0) From GESECRAN
Endif

Return


###########################################################################################################
# CALNBENR : Compte le nombre de devises déjà traité et le nombre de devise qui reste à traiter 
#            Cas particluer de l'utilisation de FLGREP... à  3 !!
#
# Programme appelé depuis le traitement SUBSIM   
###########################################################################################################

Funprog CALNBENR(WNOL)
Value Integer WNOL
Local Char    LMES(30)

If !clalev([F:XDVS])  : Local File =SI_DOSSIER+".XIDVS"      [XDVS]  : Endif  # Devises

Filter [XDVS] Where FLGREP<>3
LMES=num$(rowcount([XDVS]))-"/"-num$(nbrecord([XDVS]))
[M:SIM4]NB2TRT(WNOL)=nbrecord([XDVS])

Filter [XDVS]
End LMES



$OLD_COMPTE # A Supprimer
If !clalev([F:TCU])   : Local File =SI_DOSSIER+".TABCUR"     [TCU]   : Endif  # Devises
If !clalev([F:TCH])   : Local File =SI_DOSSIER+".TABCHANGE"  [TCH]   : Endif  # Cours Devises

For [XDVS]

 # Pas d'initialisation pour la devise de reporting
 If [F:XDVS]X3CLE<>GSYSCUR

  # Pas d'initialisation pour les devises non migré
  Read [TCU]TCU0=[F:XDVS]X3CLE
  If !fstat & [F:XDVS]TAUCER  # TAUCER toujours renseigné...

   Read [TCH]TCH0 = 1;[F:XDVS]X3CLE;GSYSCUR;[01/01/1999]
   If !fstat : WNBCUR_OK +=1 : Endif
   
   WNBCUR_TOT+=1
  
  Endif
 Endif
Next
LMES=num$(WNBCUR_OK)-"/"-num$(WNBCUR_TOT)
[M:SIM4]NB2TRT(WNOL)=WNBCUR_TOT
Return


