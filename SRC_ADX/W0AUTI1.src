#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque AUTI1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone UTICOD
mkstat = 0
zoncou = "UTICOD"
indice = 0
If varmode([M]UTICOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "UTICOD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]UTICOD,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "UTICOD" : GZNUM = 5296 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJW"
  PARAM(1) = "AUTI"
  Local Char    VALEUR(250)
  VALEUR = [M]UTICOD
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
  [M]UTICOD = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "UTICOD" : GZNUM = 5296 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone COMMENT
mkstat = 0
zoncou = "COMMENT"
indice = 0
If varmode([M]COMMENT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "COMMENT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone UPDATEFLG
mkstat = 0
zoncou = "UPDATEFLG"
indice = 0
IMPENT = [M]UPDATEFLG
If varinit([M]UPDATEFLG,indice)=0
 IMPENT = 1
Endif
[M]UPDATEFLG = IMPENT

## Zone MODULE
mkstat = 0
zoncou = "MODULE"
indice = 0
IMPENT = [M]MODULE
If varinit([M]MODULE,indice)=0
 IMPENT = 10
Endif
If varmode([M]MODULE,indice)=0
 [M]MODULE(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "MODULE" : Gosub ACTION From =IMPTRT
  IMPENT = [M]MODULE(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "MODULE" : GZNUM = 943 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]MODULE = IMPENT

## Zone CODACT
mkstat = 0
zoncou = "CODACT"
indice = 0
If varmode([M]CODACT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODACT" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ACV","!F",[M]CODACT,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CODACT" : GZNUM = 4 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone SCRIPT
mkstat = 0
zoncou = "SCRIPT"
indice = 0
If varmode([M]SCRIPT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SCRIPT" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]SCRIPT,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "SCRIPT" : GZNUM = 51546 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone GROUPFLG
mkstat = 0
zoncou = "GROUPFLG"
indice = 0
IMPENT = [M]GROUPFLG
WNUM = IMPENT
If varinit([M]GROUPFLG,indice)=0
 IMPENT = 2
Endif
If varmode([M]GROUPFLG,indice)=0
 [M]GROUPFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "GROUPFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]GROUPFLG(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_GROUPFLG(IMPENT) From SUBAUTI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "GROUPFLG" : GZNUM = 1004320 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]GROUPFLG = IMPENT

## Zone ROOTRUN
mkstat = 0
zoncou = "ROOTRUN"
indice = 0
IMPENT = [M]ROOTRUN
If varinit([M]ROOTRUN,indice)=0
 IMPENT = 1
Endif
If varmode([M]ROOTRUN,indice)=0
 [M]ROOTRUN(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ROOTRUN" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ROOTRUN(indice)
 Endif
Endif
[M]ROOTRUN = IMPENT

## Zone CHILDRUN
mkstat = 0
zoncou = "CHILDRUN"
indice = 0
IMPENT = [M]CHILDRUN
If varinit([M]CHILDRUN,indice)=0
 IMPENT = 2
Endif
If varmode([M]CHILDRUN,indice)=0
 [M]CHILDRUN(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CHILDRUN" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CHILDRUN(indice)
 Endif
Endif
[M]CHILDRUN = IMPENT

## Zone LAUNCHTYP
mkstat = 0
zoncou = "LAUNCHTYP"
indice = 0
IMPENT = [M]LAUNCHTYP
If varinit([M]LAUNCHTYP,indice)=0
 IMPENT = 2
Endif
[M]LAUNCHTYP = IMPENT

## Zone LAUNCHTYPVAL
mkstat = 0
zoncou = "LAUNCHTYPVAL"
indice = 0
IMPENT = [M]LAUNCHTYPVAL
If varinit([M]LAUNCHTYPVAL,indice)=0
 IMPENT = 2
Endif
If varmode([M]LAUNCHTYPVAL,indice)=0
 [M]LAUNCHTYPVAL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "LAUNCHTYPVAL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]LAUNCHTYPVAL(indice)
 Endif
Endif
[M]LAUNCHTYPVAL = IMPENT

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone GROUP
mkstat = 0
zoncou = "GROUP"
indice = 0
If varmode([M]GROUP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GROUP" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone GROUPSEQ
mkstat = 0
zoncou = "GROUPSEQ"
indice = 0
If varmode([M]GROUPSEQ,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GROUPSEQ" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone LAUNCHSTATUS
mkstat = 0
zoncou = "LAUNCHSTATUS"
indice = 0
IMPENT = [M]LAUNCHSTATUS
If varinit([M]LAUNCHSTATUS,indice)=0
 IMPENT = 1
Endif
[M]LAUNCHSTATUS = IMPENT

## Zone LOGFIL
mkstat = 0
zoncou = "LOGFIL"
indice = 0
If varmode([M]LOGFIL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LOGFIL" : Gosub ACTION From =IMPTRT
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "AUTI1"
Return

