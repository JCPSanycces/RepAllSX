#* MABON - 26/08/10 - Gestion nouveau browser "Stage DIF"
#*!
$OUVRE_BOITE

  BOXDIF  = "GAU_CHE"+num$(find("ST0",OBJLIS(1..dim(OBJLIS)-1)))
Return

$RAZCRE

  Grizo [M:STG1]REF, TCHNAM
  # Fiche 70910 - SYMEU - 26/01/2011 : grisage du contrat du formateur interne
  Grizo [M:STG1]CTRNUM
  [M:STG2]NBPLAG=0
  Chgfmt [M:STG2]LIBCAT With "-K:15X"
  Chgfmt [M:STG2]LIBCPY With "-K:15X"
  Chgfmt [M:STG2]LIBFCY With "-K:15X"
  Chgfmt [M:STG2]LIBJOT With "-K:15X"
  Chgfmt [M:STG2]LIBPOT With "-K:15X"
  Chgfmt [M:STG2]LIBPOP With "-K:15X"
  Chgfmt [M:STG2]LIBHAB With "-K:15X"
  # 16/05/12 - DKA - Clear fields until FRA legislation selected
  GCURLEG = ""
  Call DISPLAY_HIDE() From SUBSTGLEG
  Affzo [M:STG2]
  #29/06/12 - DKA - Default LEG value to users LEGFIL when creating a record
  If dim([M:STG0]LEG)>0 Then
    [M:STG0]LEG=GLEGFIL
    Affzo [M:STG0]LEG
    Call AM_LEG([M:STG0]LEG)
  Endif

  # FQ79563 - MABON 11/09/12 - Gestion de l'icône "Nouvelle adresse"
  [M:STG1]CLCADD="21" : Affzo [M:STG1]CLCADD
  # Fin MABON
Return

