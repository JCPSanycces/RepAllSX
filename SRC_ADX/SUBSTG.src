#######################################
#  X3PEOP-3476
$DELETE_LINE
  Dela LINREF,1,[M]NBLIG4 [M]NBLIG4
  If [M]NBLIG4>0
    [M]NBLIG4-=1
  Endif
Return
#######################################
#  X3PEOP-3476
$ADD_NEWLINE
If LIN>=[M]NBLIG4
  [M]NBLIG4+=2
  Gosub AFFZO_BLOCCOUT
Else
  Insa LIN+1,1,[M]NBLIG4 [M]NBLIG4
  [M]NBLIG4+=1
Endif
Return
##############################
#Calcul de la synthèse des coûts
Subprog CSTMOY (VALEUR)
Value Integer VALEUR
Local Integer I
Raz [M:STG4]CSTMOYTOT
Raz [M:STG4]CSTMOYIPT
Raz [M:STG4]CSTMOYTOT2
Raz [M:STG4]CSTMOYIPT2
# FQ70982 - MABON 24/01/11 - Gestion des arrondis
For I=0 To VALEUR
 Read [ADI]CODE=10451;[M:STG4]TYPCRG(I)

 If [F:ADI]N1<3 & [F:ADI]N2=2
#  [M:STG4]CSTMOYTOT2 +=[M:STG4]CSTTOTIDV(I)
#  [M:STG4]CSTMOYIPT2 +=[M:STG4]CSTIPTIDV(I)
 Else
  [M:STG4]CSTMOYTOT +=[M:STG4]CSTTOTIDV(I)
  [M:STG4]CSTMOYIPT +=[M:STG4]CSTIPTIDV(I)
 Endif
Next
#[M:STG4]CSTMOYTOT2 +=arr([M:STG4]CSTMOYTOT*[M:STG4]NBRPRTSTD,0.01)
#[M:STG4]CSTMOYIPT2 +=arr([M:STG4]CSTMOYIPT*[M:STG4]NBRPRTSTD,0.01)
For I=0 To VALEUR
 Read [ADI]CODE=10451;[M:STG4]TYPCRG(I)

 If [F:ADI]N1<3 & [F:ADI]N2=2
  [M:STG4]CSTMOYTOT2 +=[M:STG4]CSTTOTIDV(I)
  [M:STG4]CSTMOYIPT2 +=[M:STG4]CSTIPTIDV(I)
 Else
  [M:STG4]CSTMOYTOT2+=[M:STG4]CSTTOTCLL(I)
  If [M:STG4]CSTTOTCLL(I)=0 Then
    [M:STG4]CSTMOYTOT2+=arr([M:STG4]CSTTOTIDV(I)*[M:STG4]NBRPRTSTD,0.01)
  Endif
  [M:STG4]CSTMOYIPT2+=[M:STG4]CSTIPTCLL(I)
  If [M:STG4]CSTIPTCLL(I)=0 Then
    [M:STG4]CSTMOYIPT2+=arr([M:STG4]CSTIPTIDV(I)*[M:STG4]NBRPRTSTD,0.01)
  Endif
 Endif
Next
# Fin MABON
Affzo[M:STG4]CSTMOYTOT,CSTMOYIPT,CSTMOYTOT2,CSTMOYIPT2
End

