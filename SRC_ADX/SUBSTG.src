  Else : # Sinon
    VALEUR=[M:STG2]VALINT7
    # FQ84144 - MABON 27/08/12 - Contrôle saisie
    Call C_HABTRG(VALEUR)
    # Fin MABON
    Chgstl [M:STG2]HABTRG With ""
    # Dans ce cas, il n'y a qu'une seule valeur dans [M:STG2]NBPLAG correspondant à l'habilitation
    # On la remplace par la valeur saisie manuellement ou par Sélection
    I=find("HABTRG",[M:STG2]PARPLAG(0..[M:STG2]NBPLAG-1))
    If I>0 Then [M:STG2]VALPLAG1(I-1)=[M:STG2]VALINT7 Endif
  Endif
End

#**#####################################################################################
#* MABON - 24/08/10 - Initialisation des boutons selon le contexte
#*!
Subprog IB_TRG_GEN(TRGNAME)
Value Char    TRGNAME
Local Integer IND, INDBOR

  IND=0 : INDBOR=-1
  For I=0 To [M:STG2]NBPLAG-1
    If [M:STG2]PARPLAG(I) = TRGNAME
      IND += 1
      INDBOR = I
    Endif
  Next I
  If IND>1 or (INDBOR>0 and [M:STG2]VALPLAG2(INDBOR)<>"") Then
    GBOUTS = ""
    GBOUT1 = ""
  Endif
End

Subprog IB_CATTRG
  Call IB_TRG_GEN("CATTRG")
End

Subprog IB_CPYTRG
  Call IB_TRG_GEN("CPYTRG")
End

Subprog IB_FCYTRG
  Call IB_TRG_GEN("FCYTRG")
End

Subprog IB_JOTTRG
  Call IB_TRG_GEN("JOTTRG")
End

Subprog IB_POTTRG
  Call IB_TRG_GEN("POTTRG")
End

Subprog IB_POPTRG
  Call IB_TRG_GEN("POPTRG")
End

Subprog IB_HABTRG
  Call IB_TRG_GEN("HABTRG")
End

#**#####################################################################################
#* MABON - 24/08/10 - Exécution de l'action APARPLAG : on passe par une action standard
#* dans l'écran, car on a besoin de savoir si on vient du bouton "Valeurs multiples"
#* ou du bouton "Sélection"
#*!
Subprog B2_CATTRG(VALEUR)
Variable Char VALEUR()
Local Char    PARMSK(250)(1..20) , SAVACT(20)
If dim(GB21)<0 Then Global Integer GB21 Endif

  GB21 = 2
  SAVACT = GACTION : GACTION = "APARPLAG"
  For I=1 To 20
    PARMSK(I) = ""
  Next
  PARMSK(1)  = "ADI"
  PARMSK(2)  = "20"
  PARMSK(3)  = "10453"
  PARMSK(5)  = '10453'
  PARMSK(8)  = "CATTRG"
  PARMSK(11) = "STG2"
  PARMSK(12) = "SUBSTG"
  PARMSK(13) = "CATTRG"
  PARMSK(14) = "0"
  Call TRAITE_CHAR(VALEUR,PARMSK,"APARPLAG","APARPLAG","",1,"XWAPARPLAG") From GTRAITE
  GACTION = SAVACT
End

