######################################################################################
## Etiquette Ecrans [M:STG3] (Pré-requis + Objectif)
######################################################################################

#Stage pré-requis
Subprog C_STGNEC(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M:STG0]COD
 GMESSAGE=mess(1,10702,1)  #: Valeur incorrecte
 mkstat=2 : End
Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini : contrôle du stage
Call CTL_STG_NON_DEF(VALEUR) From DIVFOR
If mkstat Then End Endif

Call UNICITE(VALEUR,[M:STG3]STGNEC(0..[M:STG3]NBLIG-1)) From OBJDIV
If mkstat=2 : End : Endif
End


Subprog AM_STGNEC(VALEUR)
Variable Char    VALEUR()
If clalev([F:STG2])=0 : Local File STAGE      [STG2] : Endif
If VALEUR<>""
 Read [F:STG2]STG0=VALEUR
 If !fstat
  For I=1 To dim([F:STG2]CPCAFT)
   If [F:STG2]CPCAFT(I-1)="" : Break : Endif
   If !find([F:STG2]CPCAFT(I-1),[M:STG3]CPCNEC(0..[M:STG3]NBLIG2-1))
    [M:STG3]CPCNEC([M:STG3]NBLIG2)=[F:STG2]CPCAFT(I-1)
    [M:STG3]LEVNEC([M:STG3]NBLIG2)=[F:STG2]LEVAFT(I-1)
    [M:STG3]NBLIG2+=1
   Endif
  Next
 Endif
Endif
Affzo [M:STG3]10
End


#Compétence pré-requise
Subprog C_CPCNEC(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:STG3]CPCNEC(0..[M:STG3]NBLIG2-1)) From OBJDIV
If mkstat=2 : End : Endif
End

#Niveau
Subprog AS_LEVNEC(VALEUR)
Variable Char    VALEUR()
#30290
#Local Integer I
#If VALEUR=""
# Call LECTURE("CPC",[M:STG3]CPCNEC(nolign-1),"") From CONTOBJ
# For I=1 To dim([F:CPC]LEVCPC)
#  If [F:CPC]LEVCPC(I-1)<>""
#   VALEUR = [F:CPC]LEVCPC(I-1) : Break
#  Endif
# Next
#Endif
End

Subprog C_LEVNEC(VALEUR)
Variable Char    VALEUR()
#61977
#Local Char VALCHAR (10)
Local Char VALCHAR (GLONNIV)
Local Integer I, J
If VALEUR<>""
 Call LECTURE("CPC",[M:STG3]CPCNEC(nolign-1),"") From CONTOBJ
 Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ

 #Egalité parfaite
 For I=0 To dim([F:HRSCA]LEV)-1
  If toupper(ctrans([F:HRSCA]LEV(I)))=toupper(ctrans(VALEUR))
   VALCHAR=[F:HRSCA]LEV(I) : Break
  Endif
 Next
 If VALCHAR=""
  #Débute par...
  For I=len(VALEUR) To 1 Step -1
   For J=0 To dim([F:HRSCA]LEV)-1
    If left$(toupper(ctrans([F:HRSCA]LEV(J))),I)=toupper(ctrans(VALEUR))
     VALCHAR=[F:HRSCA]LEV(J)
     Break 2
    Endif
   Next
  Next
 Endif
 If VALCHAR="" : VALCHAR=[F:HRSCA]LEV(0): Endif
 VALEUR = VALCHAR
Endif
If VALEUR<>""
 #Verif que le niveau objectif n'est pas inférieur au niveau pré-requis si il existe...
 I=find([M:STG3]CPCNEC(nolign-1),[M:STG3]CPCAFT(0..[M:STG3]NBLIG3-1))
 # FQ78587 - MABON 12/12/11 - On ne compare que si le niveau est renseigné
# If I
 If I & [M:STG3]LEVAFT(I-1)<>""
 # Fin MABON
  J = func SUBECP.COMPNIV([M:STG3]CPCNEC(nolign-1),[M:STG3]LEVAFT(I-1), VALEUR)
  If J
   # FQ78587 - MABON 12/12/11 - Message plus explicite
#   GMESSAGE=mess(1,10702,1)  #: Valeur incorrecte
   GMESSAGE=mess(257,10717,1)  #: Incohérence entre niveaux de compétences (pré-requis et objectifs)
   # Fin MABON
   mkstat=2 : End
  Endif
 Endif
Endif
End

#Compétence induite
Subprog C_CPCAFT(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:STG3]CPCAFT(0..[M:STG3]NBLIG3-1)) From OBJDIV
If mkstat=2 : End : Endif
End

#Niveau
Subprog AS_LEVAFT(VALEUR)
Variable Char    VALEUR()
Local Integer I
#30290
#If VALEUR=""
# Call LECTURE("CPC",[M:STG3]CPCAFT(nolign-1),"") From CONTOBJ
# For I=dim([F:CPC]LEVCPC) To 1 Step -1
#  If [F:CPC]LEVCPC(I-1)<>""
#   VALEUR = [F:CPC]LEVCPC(I-1) : Break
#  Endif
# Next
#Endif
End

Subprog C_LEVAFT(VALEUR)
Variable Char    VALEUR()
#61977
#Local Char VALCHAR (10)
Local Char VALCHAR (GLONNIV)
Local Integer I, J
If VALEUR<>""
 Call LECTURE("CPC",[M:STG3]CPCAFT(nolign-1),"") From CONTOBJ
 Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ

 #Egalité parfaite
 For I=0 To dim([F:HRSCA]LEV)-1
  If toupper(ctrans([F:HRSCA]LEV(I)))=toupper(ctrans(VALEUR))
   VALCHAR=[F:HRSCA]LEV(I) : Break
  Endif
 Next
 If VALCHAR=""
  #Débute par...
  For I=len(VALEUR) To 1 Step -1
   For J=0 To dim([F:HRSCA]LEV)-1
    If left$(toupper(ctrans([F:HRSCA]LEV(J))),I)=toupper(ctrans(VALEUR))
     VALCHAR=[F:HRSCA]LEV(J)
     Break 2
    Endif
   Next J
  Next I
 Endif
 If VALCHAR="" : VALCHAR=[F:HRSCA]LEV(0): Endif
 VALEUR = VALCHAR
Endif
If VALEUR<>""
 #Verif que le niveau objectif n'est pas inférieur au niveau pré-requis si il existe...
 I=find([M:STG3]CPCAFT(nolign-1),[M:STG3]CPCNEC(0..[M:STG3]NBLIG2-1))
 # FQ78587 - MABON 12/12/11 - On ne compare que si le niveau est renseigné
# If I
 If I & [M:STG3]LEVNEC(I-1)<>""
 # Fin MABON
  J = func SUBECP.COMPNIV([M:STG3]CPCAFT(nolign-1),VALEUR,[M:STG3]LEVNEC(I-1))
  If J
   # FQ78587 - MABON 12/12/11 - Message plus explicite
#   GMESSAGE=mess(1,10702,1)  #: Valeur incorrecte
   GMESSAGE=mess(257,10717,1)  : # Incohérence entre niveaux de compétences (pré-requis et objectifs)
   # Fin MABON
   mkstat=2 : End
  Endif
 Endif
Endif
End

Subprog AM_EXMAFT(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Effzo [M:STG3]LEVEXM : Grizo [M:STG3]LEVEXM
Else
 Actzo [M:STG3]LEVEXM
Endif
End


######################################################################################
## Etiquette Ecrans [M:STG4] (Coûts)
######################################################################################

#Si on change le nb d'heures il faut modifier les montants des charges prev du formateur interne.
Subprog AM_NBRHOUIPT(VALEUR)
Variable Decimal VALEUR
# FQ71788 - MABON 01/03/11 - Dorénavant, l'onglet des coûts prévisionnels du stage sont réservés aux coûts
#If [M:STG1]TCHEMP<>""
# Call RECALCUL (VALEUR,[M:STG1]TCHEMP,[M:STG1]CTRNUM)
#Endif
# Fin MABON
#LIPET - 2017-05-24 - X3-34429 - START
[M]NBRHOUIPT=VALEUR
Gosub COUTS_DISTRIB
#LIPET - 2017-05-24 - X3-34429 - START
End

Subprog C_NBRPRTMAX(VALEUR)
Variable Decimal VALEUR
If VALEUR<[M]NBRPRTMIN
 #Nombre de participant invalide
 GMESSAGE = mess(6,10717,1)
 mkstat = 2 : End
Endif
End


#Nb participant std
Subprog AP_NBRPRTSTD(VALEUR)
Variable Decimal VALEUR
# FQ71346 - MABON 07/02/11 - Dorénavant, le nombre standard peut être >= au nombre max
#If ([M]NBRPRTMIN<>0 & VALEUR<[M]NBRPRTMIN) |
#&  ([M]NBRPRTMAX<>0 & VALEUR>[M]NBRPRTMAX)
If ([M]NBRPRTMIN<>0 & VALEUR<[M]NBRPRTMIN)
 #Nombre de participant invalide
 GMESSAGE = mess(6,10717,1)
 mkstat = 2 : End
Endif
End

Subprog AM_NBRPRTSTD(VALEUR)
Variable Decimal VALEUR
[M]NBRPRTSTD=VALEUR
Gosub COUTS_IND
End

#Recalcul des coûts en fonction du nb de participants std
$COUTS_IND
#LIPET - 2017-05-24 - X3-34429 - START
Local Decimal VALTEMP

Gosub DECLARE
#FLGMOD=0
#For I=1 To [M]NBLIG4
# If [M]CSTTOTCLL(I-1)<>0
#  [M]CSTTOTIDV(I-1)=arr(([M]CSTTOTCLL(I-1)/VALEUR),0.01)
#  FLGMOD=1
# Endif
# If [M]CSTIPTCLL(I-1)<>0
#  [M]CSTIPTIDV(I-1)=arr(([M]CSTIPTCLL(I-1)/VALEUR),0.01)
#  FLGMOD=1
# Endif

For nolign=1 To [M]NBLIG4
  If right$([M]LNKREP(nolign-1),len([M]LNKREP(nolign-1)))<>"D"
    VALTEMP=[M]CSTTOTCLL(nolign-1)
    If [M]LNKREP(nolign-1)<>""
      VALTEMP+=[M]CSTTOTCLL(nolign)
    Endif
    If VALTEMP<>0
      Call AM_CSTTOTCLL(VALTEMP)
      [M]CSTTOTCLL(nolign-1)=VALTEMP
      FLGMOD=1
    Endif

   VALTEMP=[M]CSTIPTCLL(nolign-1)
    If [M]LNKREP(nolign-1)<>""
      VALTEMP+=[M]CSTIPTCLL(nolign)
    Endif
    If VALTEMP<>0
      Call AM_CSTIPTCLL(VALTEMP)
      [M]CSTIPTCLL(nolign-1)=VALTEMP
      FLGMOD=1
    Endif
  Endif
#LIPET - 2017-05-24 - X3-34429 - END
Next

If FLGMOD=1
 Call CSTMOY ([M]NBLIG4)
 Affzo [M]20,25,30
Endif
Return

# chg nb night. could be an impact on repartition.
$COUTS_DISTRIB
Local Decimal VALTEMP
FLGMOD=0
For nolign=1 To [M]NBLIG4
  If [M]LNKREP(nolign-1)<>"" and right$([M]LNKREP(nolign-1),len([M]LNKREP(nolign-1)))<>"D"
    VALTEMP=[M]CSTTOTCLL(nolign-1)+[M]CSTTOTCLL(nolign)
    If VALTEMP<>0
      Call AM_CSTTOTCLL(VALTEMP)
      [M]CSTTOTCLL(nolign-1)=VALTEMP
      FLGMOD=1
    Else
      VALTEMP=[M]CSTTOTIDV(nolign-1)+[M]CSTTOTIDV(nolign)
      If VALTEMP<>0
        Call AM_CSTTOTIDV(VALTEMP)
        [M]CSTTOTIDV(nolign-1)=VALTEMP
      Endif
    Endif

   VALTEMP=[M]CSTIPTCLL(nolign-1)+[M]CSTIPTCLL(nolign)
    If VALTEMP<>0
      Call AM_CSTIPTCLL(VALTEMP)
      [M]CSTIPTCLL(nolign-1)=VALTEMP
      FLGMOD=1
    Else
      VALTEMP=[M]CSTIPTIDV(nolign-1)+[M]CSTIPTIDV(nolign)
      If VALTEMP<>0
        Call AM_CSTIPTIDV(VALTEMP)
        [M]CSTIPTIDV(nolign-1)=VALTEMP
        FLGMOD=1
      Endif
    Endif
  Endif
Next
If FLGMOD=1
 Call CSTMOY ([M:STG4]NBLIG4)
 Affzo [M]20,25,30
Endif
Return

Subprog C_TYPCRG(VALEUR)
Variable Char    VALEUR()

Local Char TYPCRGLEG

# FQ71112 - MABON 28/01/11 - On ne peut saisir que des coûts non calculés, qu'ils soient Participants, Formateurs ou Autres
