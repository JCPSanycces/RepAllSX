# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini : si le stage est fictif, on ne peut
# rien saisir
Subprog TEST_FICTIF(P_FICTI)
Value Integer P_FICTI
If P_FICTI = 2 Then
  Grizo [M:STG1]1-99 : Grizo [M:STG2]1-99 : Grizo [M:STG3]1-99
  Grizo [M:STG4]1-99 : Grizo [M:STG5]1-99
  #LIPET - 2017-05-24 - X3-34429 - START
#################################
#Waiting for portal integration
#################################
  # US 2521- 96679
#  If(GPRH=2) : Grizo [M:STG6]1-99 : Endif
  #LIPET - 2017-05-24 - X3-34429 - END
Else
  Actzo [M:STG1]1-99 : Actzo [M:STG2]1-99 : Actzo [M:STG3]1-99
  Actzo [M:STG4]1-99 : Actzo [M:STG5]1-99
  #LIPET - 2017-05-24 - X3-34429 - START
#################################
#Waiting for portal integration
#################################
    # US 2521- 96679
  #If(GPRH=2) : Actzo [M:STG6]1-99 : Endif
  #LIPET - 2017-05-24 - X3-34429 - END
  Default Mask [M:STG1]
  Call AM_ORG([M:STG1]ORG)
  Call AM_EXMAFT([M:STG3]EXMAFT)
  If [M:STG1]TCHEMP<>""
    Read [ID]ID0=[M:STG1]TCHEMP
    If !fstat
      Call GRISE_CTRNUM([F:ID]FLGMULCTR)
    Endif
  Else
    Call GRISE_CTRNUM(1)
  Endif
Endif
End


