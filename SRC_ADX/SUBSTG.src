If clalev([F:HRSES])=0  : Local File SESSIONS   [HRSES] : Endif
If clalev([F:SEJ])=0    : Local File SESJOU     [SEJ]   : Endif
If clalev([F:CPC])=0    : Local File COMPETENCE [CPC]   : Endif
If clalev([F:BCB])=0    : Local File BCLOB      [BCB]   : Endif
If clalev([F:ADI])=0    : Local File ATABDIV    [ADI]   : Endif
If clalev([F:HRSCA])=0  : Local File SCALE      [HRSCA] : Endif
If clalev([F:COU])=0    : Local File COUT       [COU]   : Endif
If clalev([F:HRCOR])=0  : Local File COUTREEL   [HRCOR] : Endif
If clalev([F:ID])=0     : Local File EMPLOID    [ID]    : Endif
# SYMEU V6.1 Module Formation - Formateur interne
If clalev([F:TRN])=0    : Local File TRAINER    [TRN]   : Endif
# MABON 23/08/10 - Nouvelle table des cibles
If clalev([F:STR])=0 : Local File STAGETRG   [STR] : Endif
# FQ77785 - MABON 05/12/11 - Nouvelle table des cibles
#LIPET - 2017-05-24 - X3-34429 - START
Global Integer GPRH : GPRH=1
If clalev([F:ACV])=0 : Local File ACTIV      [ACV] : Endif
Read [F:ACV]CODACT="PRH"
If !fstat Then
  GPRH=[F:ACV]FLACT
Endif

If GPRH=2 Then
  If clalev([F:HRSTP])=0 : Local File STAGEPRH   [HRSTP] : Endif
Endif

# Fin MABON
#LIPET - 2017-05-24 - X3-34429 - END
If clalev([F:HRSTR])=0  : Local File STAGETRG   [HRSTR] : Endif

If clalev([F:STG2])=0   : Local File STAGE     [STG2]   : Endif
#LIPET - 2017-05-24 - X3-34429 - START
If clalev([F:HRTCR])=0 : Local File HRTRACSTREP     [HRTCR] : Endif
#LIPET - 2017-05-24 - X3-34429 - END
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

Gosub DECLARE

Return

