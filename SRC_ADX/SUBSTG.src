Local Integer NBSTG,I,J, MAXSTG
MAXSTG=99
Return

$STYLE
#LIPET - 2017-05-24 - X3-34429 - START
Default Mask [M:STG4]

Gosub STYLE From TRTCOUT

Default Mask [M:STG1]
#LIPET - 2017-05-24 - X3-34429 - END
Return

$FERME

  If dim(GB21)>0        Then Kill GB21        Endif
  If dim(GB22)>0        Then Kill GB22        Endif
  If dim(GB23)>0        Then Kill GB23        Endif
  If dim(GB24)>0        Then Kill GB24        Endif
  If dim(GB25)>0        Then Kill GB25        Endif
  If dim(GB26)>0        Then Kill GB26        Endif
  If dim(GB27)>0        Then Kill GB27        Endif
  If dim(GMODTYPSTG)>0  Then Kill GMODTYPSTG  Endif
  #LIPET - 2017-05-24 - X3-34429 - START
  If dim(GPRH)>0        Then Kill GPRH        Endif
  #LIPET - 2017-05-24 - X3-34429 - END
