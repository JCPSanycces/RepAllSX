Variable Char    VALEUR()
If func AFNC.ACTIV("FKSSD")>0 & func DIVPAYE.EXISTE_KXX("SUBSTGSA") Then
  Call C_CPCPIOCOD(VALEUR) From SUBSTGSA
Endif
End


######################################################################################

Subprog TEMP_CONTCTR(EMP,CTR)
Variable Char EMP()
Variable Char CTR()
  #LIPET - X3-66089 - 2017-11-27 - START
  ############################################################
  #WE DO NOT NEED TO USE THE CONTROL ON THE DATA TYPE HRCTR
  #CURRENT LEGISLATION DOES NOT NEED TO BE HANDLED
  ###########################################################

  If CTR="" : End : Endif
  If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif

  If [F:HRCTR]REFNUM = EMP & [F:HRCTR]CTRNUM = CTR
   DATC = [F:HRCTR]CTRDAT
  Endif

  Filter [HRCTR] Where CTRNUM=CTR
  Read [HRCTR]CTR0 First
  Filter [HRCTR]
  If fstat
   GMESSAGE = mess(26,10701,1) : # Contrat inexistant
   mkstat = 2 : End
  Endif
  If EMP<>""
   Filter [HRCTR] Where REFNUM=EMP & CTRNUM=CTR
   Read [HRCTR]CTR0 Last
   Filter [HRCTR]
   If fstat
    GMESSAGE = mess(62,10701,1)-EMP :# Ce contrat est rattaché au salarié
    mkstat = 2 : End
   Endif
  Endif
  #LIPET - X3-66089 - 2017-11-27 - END
End

