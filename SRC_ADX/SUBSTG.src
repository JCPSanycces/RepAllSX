Subprog C_ENDTIMSTG(VALEUR)
Variable Char    VALEUR()
# FQ78044 - MABON 09/03/12 - Comparaison des valeurs numériques
#If val(VALEUR)<>0 & VALEUR<[M:STG1]STRTIMSTG
If val(VALEUR)<>0 & val(VALEUR)<val([M:STG1]STRTIMSTG)
# Fin MABON
 #Heure incorrecte
 GMESSAGE = mess(69,134,1)
 mkstat = 2 : End
Endif
End

$CTL_SES
GOK=1
For I=1 To [M:STG5]NBLIG5
 If [M:STG1]STRVLY>[M:STG5]STRDAT(I-1) | [M:STG1]ENDVLY<[M:STG5]ENDDAT(I-1)
  #Date en dehors de la période de la session
  GMESSAGE=mess(8,10717,1)- [M:STG5]CODSES(I-1)
  GOK=0 : Break
 Endif
Next
Return

# Soit un formateur interne, soit un formateur externe, mais pas les deux
Subprog AS_TCHEMP(VALEUR)
Variable Char    VALEUR()

  If [M]ORG<>"" Then
    mkstat=2
  Endif
End

######################################################################################
# Contrôle du formateur interne
# SYMEU V6.1 Module Formation - Formateur interne
######################################################################################
Subprog C_TCHEMP(VALEUR)
Variable Char    VALEUR()

  If VALEUR<>'' Then
    Read [F:TRN]TRN2 = VALEUR
    If fstat Then
      # Formateur interne inexistant
      GMESSAGE = mess(106,10717,1)
      mkstat = 2 : End
    Endif
  Endif
End

# Si on change de formateur interne il faut modifier les montants de ses charges prev.
Subprog AM_TCHEMP(VALEUR)
Variable Char    VALEUR()
Local    Char    CATFRT(GLONADI), CONTRAT(GLONHRCTR)

If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
Raz [M:STG1]CTRNUM
If VALEUR<>""
 Read [ID]ID0=VALEUR
 If !fstat & [F:ID]FLGMULCTR<>2
  #LIPET - 2017-11-13 - X3-65677 - START
  #Call CHERCHE_CTR(VALEUR,date$,CONTRAT) From DIVPAYE
  Call SEL_CTR(VALEUR,date$,CONTRAT) From DIVPAYE
  #LIPET - 2017-11-13 - X3-65677 - END
  # SYMEU V6.1 Module Formation - Formateur interne
  Local Char L_TCHEMP(GLONEML) : L_TCHEMP = [M:STG1]TCHEMP
  [M:STG1]TCHEMP = VALEUR
  Call C_CTRNUM(CONTRAT) From SUBSTG
  If mkstat = 2 Then
    [M:STG1]TCHEMP = L_TCHEMP
    End
  Endif
  # SYMEU : fin
  [M:STG1]CTRNUM = CONTRAT
  Affzo [STG1]CTRNUM
  #LIPET - 2017-11-14 - START
  If func DIVPAYE.IS_KFR_LEG(GCURLEG) > 0 Then
  #LIPET - 2017-11-14 - END
    Call CAT2483(VALEUR,CONTRAT,CATFRT)From SUBDEM
    If CATFRT=""
     #Catégorie 2483 non définie
     Call ERREUR (VALEUR-":"-mess(77,10717,1))From GESECRAN
     #57791
    #Else
     #Call RECALCUL([M:STG4]NBRHOUIPT, VALEUR,CONTRAT)
    Endif
  Endif
  # FQ71788 - MABON 01/03/11 - Dorénavant, l'onglet des coûts prévisionnels du stage sont réservés aux coûts
  # non calculés
#  Call RECALCUL([M:STG4]NBRHOUIPT, VALEUR,CONTRAT)
  # Fin MABON
  #fin 57791
 Endif
 Call GRISE_CTRNUM([F:ID]FLGMULCTR)
 # SYMEU V6.1 Module Formation - Formateur interne : récupération du nom et prénom
 Gosub CHARGE_TRN
Else
 #57791
 Call ENLEVE(VALEUR)
 Call GRISE_CTRNUM(1)
 # SYMEU V6.1 Module Formation - Formateur interne : récupération du nom et prénom
 Raz [M:STG1]CTRNUM, NAM, SRN
 Affzo [M:STG1]CTRNUM, NAM, SRN
Endif
End

######################################################################################
# SYMEU V6.1 Module Formation - Formateur interne
# Init_bouton de TCHEMP
######################################################################################
Subprog IB_TCHEMP
  If [M:STG2]DOM = "" Then
    Raz GBOUT2
  Endif
  If [M:STG2]THM = "" Then
    Raz GBOUT3
  Endif
End

Subprog ENLEVE(FORMATEUR)
Value Char FORMATEUR ()
If clalev([F:ADI2])=0 : Local File ATABDIV     [ADI2] : Endif
Local Integer I
Filter [ADI2] Where NUMTAB=10451 & N1<3 & N2=2
For [ADI2]CODE
 I = find([F:ADI2]CODE,[M:STG4]TYPCRG)
 If I
  Dela I-1 [M:STG4]NBLIG4
  [M:STG4]NBLIG4 -=1
 Endif
Next
Filter [ADI2]
Call CSTMOY ([M:STG4]NBLIG4)
Affzo [M:STG4]20-30
End


Subprog GRISE_CTRNUM(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Actzo [M:STG1]CTRNUM
Else
 Diszo [M:STG1]CTRNUM
Endif
Affzo [M:STG1]CTRNUM
End

Subprog RECALCUL (NBRHRS, FORMATEUR, CONTRAT)
Value Decimal NBRHRS
Value Char FORMATEUR ()
Value Char CONTRAT
If clalev([F:ADI2])=0 : Local File ATABDIV     [ADI2] : Endif
If clalev([F:ADI3])=0 : Local File ATABDIV     [ADI3] : Endif
Local Decimal TAUX
Local Integer MES1, MES2, I
## Calcul des couts calculables pour formateur interne
Filter [ADI2] Where NUMTAB=10451 & N1<3 & N2=2
For [ADI2]CODE
 I = find([F:ADI2]CODE,[M:STG4]TYPCRG)
 Call TAUX_HORAIRE (FORMATEUR,CONTRAT,[M:STG1]ENDVLY,TAUX,[F:ADI2]N1,2,1) From TRTCOUT
 #If !TAUX : TAUX = rnd(1000) : Endif
 If !TAUX
  MES1 = 1
 Elsif I
  [M:STG4]CSTTOTIDV(I-1) = arr(TAUX*NBRHRS,0.01) :# Nb d'heures imputables
 Else
  Gosub AJOUT_LIG_COU
  [M:STG4]CSTTOTIDV(I-1) = arr(TAUX*NBRHRS,0.01) :# Nb d'heures imputables
 Endif
 Raz TAUX
 Call TAUX_HORAIRE (FORMATEUR,CONTRAT,[M:STG1]ENDVLY,TAUX,[F:ADI2]N1,2,2) From TRTCOUT
 #If !TAUX : TAUX = rnd(1000) : Endif
 If !TAUX
  MES2 = 1
 Elsif I
  [M:STG4]CSTIPTIDV(I-1) = arr(TAUX*NBRHRS,0.01)  :# Nb d'heures imputables
 Else
  Gosub AJOUT_LIG_COU
  [M:STG4]CSTIPTIDV(I-1) = arr(TAUX*NBRHRS,0.01)  :# Nb d'heures imputables
 Endif
Next
Filter [ADI2]

If MES1=1 & MES2=1
 # Taux horaire total non défini Taux horaire imputable non défini
 Call ERREUR (FORMATEUR-":"-mess(78,10717,1)-"\"-mess(79,10717,1))From GESECRAN
Elsif MES1=1
 # Taux horaire total non défini
 Call ERREUR (FORMATEUR-":"-mess(78,10717,1))From GESECRAN
Elsif MES2=1
 # Taux horaire imputable non défini
 Call ERREUR (FORMATEUR-":"-mess(79,10717,1))From GESECRAN
Endif

Call CSTMOY ([M:STG4]NBLIG4)
Affzo [M:STG4]20-30
End

$AJOUT_LIG_COU
[M:STG4]NBLIG4 +=1
I = [M:STG4]NBLIG4
[M:STG4]TYPCRG(I-1)  = [F:ADI2]CODE
If I>1
 [M:STG4]TYPFIN(I-1) = [M:STG4]TYPFIN(I-2)
 [M:STG4]ORGFIN(I-1) = [M:STG4]ORGFIN(I-2)
Else
 Filter [ADI3] Where NUMTAB=10462 & DEFVAL=2
 Read [ADI3]CODE First
 If !fstat : [M:STG4]TYPFIN(I-1) = [F:ADI3]CODE : Endif
 #--STA_EXI 66191 LOT 1
 Filter [ADI3]
# Filter [ADI3] Where NUMTAB=10463 & DEFVAL=2
# Read [ADI3]CODE First
# If !fstat : [M:STG4]ORGFIN(I-1) = [F:ADI3]CODE : Endif
# Filter [ADI3]
 #TODO Que prendre en valeur par défaut
# $AJOUT_LIG_COU n'est pas appeler car Call RECALCUL ne l'est plus
 If dim(GOFIDEF )>0 Then
    [M:STG4]ORGFIN(I-1) = GOFIDEF
 Endif
 #--END_EXI 66191 LOT 1

Endif
Return

Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
If [M:STG1]CTRNUM=""
 # SYMEU V6.1 Module Formation - Formateur interne : sélection des contrats du formateur
# Call SELCTR([M:STG1]TCHEMP,date$,date$,VALEUR) From DIVPAYE
 Call SELCTRFOR([M:STG1]TCHEMP,date$,date$,VALEUR) From DIVPAYE
Endif
End

Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()

  If [M:STG1]TCHEMP<>"" & VALEUR=""
   # Zone obligatoire
   GMESSAGE = mess(10,123,1)
   mkstat = 2 : End
  Endif

  #LIPET - X3-66089 - 2017-11-27 - START
   Call TEMP_CONTCTR([M:STG1]TCHEMP,VALEUR)
  #LIPET - X3-66089 - 2017-11-27 - END

  # SYMEU V6.1 Module Formation - Formateur interne : contrôle que le contrat est saisi pour
  # le formateur et qu'il est actif
  If [M:STG1]TCHEMP<>"" Then
    Read [F:TRN]TRN1 = [M:STG1]TCHEMP;VALEUR
    If fstat Then
     # Le contrat n'est pas défini pour le formateur
     GMESSAGE = mess(102,10717,1)
     mkstat = 2 : End
    Elsif [F:TRN]ENAFLG = 1 Then
      # Le contrat pour le formateur interne n'est pas actif
      GMESSAGE = mess(99,10717,1)
      mkstat = 2 : End
    Endif
  Endif
  End

  Subprog AM_CTRNUM(VALEUR)
  Variable Char    VALEUR()
  Local    Char    CATFRT(GLONADI)
  Call CAT2483([M:STG1]TCHEMP,VALEUR,CATFRT)From SUBDEM
  # FQ71788 - MABON 01/03/11 - Dorénavant, l'onglet des coûts prévisionnels du stage sont réservés aux coûts non calculés
  #If CATFRT=""
  # #Catégorie 2483 non définie
  # Call ERREUR (VALEUR-":"-mess(77,10717,1))From GESECRAN
  #Else
  # Call RECALCUL ([M:STG4]NBRHOUIPT,[M:STG1]TCHEMP,VALEUR)
  #Endif
  # Fin MABON
End

