#####################################
$CHARGE_CPC
For nolign=1 To dim([F:STG]STGNEC)
 If [F:STG]STGNEC(nolign-1)="" : Break : Endif
 [M:STG3]STGNEC(nolign-1)=[F:STG]STGNEC(nolign-1)
Next
[M:STG3]NBLIG=nolign-1

For nolign=1 To dim([F:STG]CPCNEC)
 If [F:STG]CPCNEC(nolign-1)="" : Break : Endif
 [M:STG3]CPCNEC(nolign-1)=[F:STG]CPCNEC(nolign-1)
 [M:STG3]LEVNEC(nolign-1)=[F:STG]LEVNEC(nolign-1)
Next
[M:STG3]NBLIG2=nolign-1

For nolign=1 To dim([F:STG]CPCAFT)
 If [F:STG]CPCAFT(nolign-1)="" : Break : Endif
 [M:STG3]CPCAFT(nolign-1)=[F:STG]CPCAFT(nolign-1)
 [M:STG3]LEVAFT(nolign-1)=[F:STG]LEVAFT(nolign-1)
Next
[M:STG3]NBLIG3=nolign-1
Return

#####################################
$CHARGE_COUT
nolign = 1
Filter [COU] Where TYPCOU=1 & STG=[F:STG]COD & SES=""
For [COU]COU0
 [M:STG4] = [F:COU]
 nolign +=1
Next
Filter [COU]
[M:STG4]NBLIG4 = nolign-1
Call CSTMOY ([M:STG4]NBLIG4)
Return

#####################################
$CHARGE_SESSIONS
nolign=1
For [F:HRSES]SES1 Where STG=[M:STG0]COD & ENDDAT>=datesyst
 [M:STG5]=[F:HRSES]
 [M:STG5]CODSES(nolign-1)=[F:HRSES]COD
 [M:STG5]DESSES(nolign-1)=[F:HRSES]DES
 nolign+=1
Next
[M:STG5]NBLIG5=nolign-1

# MABON - 19/08/10 - Selon le type du stage, des colonnes apparaissent ou disparaissent dans l'onglet Sessions
Call AM_TYPSTG([M:STG4]TYPSTG)
Return

#####################################
$DEF_LEG

  If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
  Filter [F:HRSES] Where STG=[M:STG0]COD
  If rowcount([F:HRSES])>0 Then
    Diszo[M:STG0]LEG
  Else
    Actzo[M:STG0]LEG
  Endif
  Filter [F:HRSES]
  Affzo [M:STG0]
Return

#####################################
# SYMEU V6.1 Module Formation - Formateur interne : récupération du nom et prénom
#####################################
$CHARGE_TRN
  [M:STG1]NAM = [F:ID]NAM
  [M:STG1]SRN = [F:ID]SRN
  Affzo [M:STG1]NAM, SRN
Return

#**#####################################################################################
#* MABON - 19/08/10 - Récupération des ressources
#*!
$CHARGE_RSC
Local Integer I, MAXI

  MAXI=0
  For I=0 To dim([F:STG]RSCNEC)-1
    If [F:STG]RSCNEC(I)<>"" Then
      [M:STG4]RSCNEC(I)=[F:STG]RSCNEC(I)
      MAXI += 1
    Endif
  Next
  [M:STG4]NBRSC=MAXI
Return

#**#####################################################################################
#* MABON - 23/08/10 - Sous-pro générique de récupération des cibles
#*!
Subprog CHARGE_TRG_GEN(TRG, TRGNAME, IND)
Value    Char    TRG, TRGNAME
Variable Integer IND
Local    Integer I, K, MULTI
Local    Char    TRG_T

  MULTI=1
  I=instr(1,TRG,";")
  If I>0 Then
    While instr(1,TRG,";")>0
      MULTI=2
      I=instr(1,TRG,";")
      TRG_T=mid$(TRG,1,I-1)
      If instr(1,TRG_T,"&")>0 Then
        K=instr(1,TRG_T,"&")
        [M:STG2]VALPLAG1(IND) = mid$(TRG_T,1,K-1)
        [M:STG2]VALPLAG2(IND) = mid$(TRG_T,K+1,len(TRG_T))
        [M:STG2]PARPLAG(IND)  = TRGNAME
        [M:STG2]BORPLAG(IND)  = 2
      Else
        [M:STG2]VALPLAG1(IND) = TRG_T
        [M:STG2]PARPLAG(IND)  = TRGNAME
        [M:STG2]BORPLAG(IND)  = 1
      Endif
      IND += 1
      TRG = right$(TRG,I+1)
    Wend
  Endif
  If instr(1,TRG,"&")>0 Then
    K=instr(1,TRG,"&")
    [M:STG2]VALPLAG1(IND) = mid$(TRG,1,K-1)
    [M:STG2]VALPLAG2(IND) = mid$(TRG,K+1,len(TRG))
    [M:STG2]PARPLAG(IND)  = TRGNAME
    [M:STG2]BORPLAG(IND)  = 2
    IND += 1
  Elsif TRG<>"" Then
    # FQ72300 - MABON 14/03/11 - On remplit les valeurs multiples uniquement s'il y en a plusieurs
    If MULTI=2 Then
      [M:STG2]VALPLAG1(IND) = TRG
      [M:STG2]PARPLAG(IND)  = TRGNAME
      [M:STG2]BORPLAG(IND)  = 1
      IND += 1
    Endif
    If MULTI=1 Then
      Assign "[M:STG2]"+TRGNAME With TRG
    Endif
  Endif
End

#**#####################################################################################
#* MABON - 23/08/10 - Récupération des cibles
#*!
$CHARGE_TRG
Local Integer JTRG

  # FQ72291 - MABON 11/03/11 - On le rend d'abord invisible, et ensuite si des cibles multiples existent, on les affiche
  Chgfmt [M:STG2]LIBCAT With "-K:15X"
  Chgfmt [M:STG2]LIBCPY With "-K:15X"
  Chgfmt [M:STG2]LIBFCY With "-K:15X"
  Chgfmt [M:STG2]LIBJOT With "-K:15X"
  Chgfmt [M:STG2]LIBPOT With "-K:15X"
  Chgfmt [M:STG2]LIBPOP With "-K:15X"
  Chgfmt [M:STG2]LIBHAB With "-K:15X"

  Read [F:HRSTR]STR0=[F:STG]COD
  If !fstat Then
    JTRG=0

    Call CHARGE_TRG_GEN([F:HRSTR]CATTRG, "CATTRG", JTRG) : # Récupération des catégories cibles
    If [F:HRSTR]CATTRG<>"" & [M:STG2]CATTRG="" Then Chgfmt [M:STG2]LIBCAT With "KP:15X" : Endif
    Call CHARGE_TRG_GEN([F:HRSTR]CPYTRG, "CPYTRG", JTRG) : # Récupération des sociétés cibles
    If [F:HRSTR]CPYTRG<>"" & [M:STG2]CPYTRG="" Then Chgfmt [M:STG2]LIBCPY With "KP:15X" : Endif
    Call CHARGE_TRG_GEN([F:HRSTR]FCYTRG, "FCYTRG", JTRG) : # Récupération des sites cibles
    If [F:HRSTR]FCYTRG<>"" & [M:STG2]FCYTRG="" Then Chgfmt [M:STG2]LIBFCY With "KP:15X" : Endif
    Call CHARGE_TRG_GEN([F:HRSTR]JOTTRG, "JOTTRG", JTRG) : # Récupération des emplois types cibles
    If [F:HRSTR]JOTTRG<>"" & [M:STG2]JOTTRG="" Then Chgfmt [M:STG2]LIBJOT With "KP:15X" : Endif
    Call CHARGE_TRG_GEN([F:HRSTR]POTTRG, "POTTRG", JTRG) : # Récupération des postes cibles
    If [F:HRSTR]POTTRG<>"" & [M:STG2]POTTRG="" Then Chgfmt [M:STG2]LIBPOT With "KP:15X" : Endif
    Call CHARGE_TRG_GEN([F:HRSTR]POPTRG, "POPTRG", JTRG) : # Récupération des populations cibles
    If [F:HRSTR]POPTRG<>"" & [M:STG2]POPTRG="" Then Chgfmt [M:STG2]LIBPOP With "KP:15X" : Endif
    Call CHARGE_TRG_GEN([F:HRSTR]HABTRG, "HABTRG", JTRG) : # Récupération des habilitations cibles
    If [F:HRSTR]HABTRG<>"" & [M:STG2]HABTRG="" Then Chgfmt [M:STG2]LIBHAB With "KP:15X" : Endif

    [M:STG2]NBPLAG=JTRG

    [M:STG2]RESPED=[F:HRSTR]RESPED
   #LIPET - 2017-05-24 - X3-34429 -START
#################################
#Waiting for portal integration
#################################
   # FQ77785 - MABON 05/12/11 - Récupération du nouveau champ FORWHO
#   If GPRH=2 Then
#      [M:STG6]FORWHO=[F:HRSTR]FORWHO
#    Endif
    # Fin MABON
  Endif
#################################
#Waiting for portal integration
#################################
  # FQ77785 - MABON 05/12/11 - Récupération du nouveau champ OBJS
#  If GPRH=2 Then
#    Read [F:HRSTP]STP0=[F:STG]COD
#    If !fstat Then
#      [M:STG6]OBJS=[F:HRSTP]OBJS
#    Endif
#  Endif
  # Fin MABON
  #LIPET - 2017-05-24 - X3-34429 - END
Return

#####################################
$AVANT_MODFIC
If dim(GMODTYPSTG)<0 Then Global Integer GMODTYPSTG : Endif

  # On veut savoir si le type de stage a été modifié
  GMODTYPSTG=1
  If [F:STG]TYPSTG<>[M:STG4]TYPSTG Then GMODTYPSTG=2 : Endif
Return

#####################################
$INICRE
$INIMOD
Gosub SAUVE_SESSION
Gosub SAUVE_CMT
Gosub SAUVE_COUT
Gosub SAUVE_TRG
#LIPET - 2017-05-24 - X3-34429 - START
# US 2521- 96679
If GPRH=1 and dim([F:STG]AUZPRH)>=0 and [F:STG]AUZPRH=0
  [F:STG]AUZPRH=2
Endif
#LIPET - 2017-05-24 - X3-34429 - END
Return

#####################################
$SAUVE_CMT
# FQ79023 - MABON 03/01/12 - Pour que l'enregistrement courant soit mis à jour
#Look [BCB]BCB0="SUBSTG";[F:STG]COD;"";"";""
Read [BCB]BCB0="SUBSTG";[F:STG]COD;"";"";""
# Fin MABON
If fstat=5
 Raz [F:BCB]
 [F:BCB]CODBLB = "SUBSTG"
 [F:BCB]IDENT1 = [F:STG]COD
 [F:BCB]CLOB   = [M:STG1]CMT
 If dim([F:BCB]CREUSR)>0 : [F:BCB]CREUSR = GUSER : Endif
 If dim([F:BCB]CREDAT)>0 : [F:BCB]CREDAT = date$ : Endif
 If dim([F:BCB]CRETIM)>0 : [F:BCB]CRETIM = time  : Endif
 Write [BCB]
 If fstat
  GOK = 0 : Call FSTA("BCB") From GLOCK : Return
 Endif
Elsif fstat<=2
 [F:BCB]CLOB   = [M:STG1]CMT
 If dim([F:BCB]UPDUSR)>0 : [F:BCB]UPDUSR = GUSER : Endif
 If dim([F:BCB]UPDDAT)>0 : [F:BCB]UPDDAT = date$ : Endif
 If dim([F:BCB]UPDTIM)>0 : [F:BCB]UPDTIM = time  : Endif
 Rewrite [BCB]
 If fstat
  GOK = 0 : Call FSTA("BCB") From GLOCK : Return
 Endif
Endif
Return

#####################################
$SAUVE_COUT
Delete [COU] Where TYPCOU=1 & STG=[F:STG]COD & SES=""
If fstat=1 | fstat>5
 GOK = 0 : Call FSTA("COU") From GLOCK : Return
Endif
For nolign=1 To [M:STG4]NBLIG4
 Raz [F:COU]
 [F:COU]       = [M:STG4]
 [F:COU]TYPCOU = 1
 [F:COU]STG    = [F:STG]COD
 [F:COU]NUMLIG = nolign
 [F:COU]CREUSR = GUSER
 [F:COU]CREDAT = date$
 [F:COU]CRETIM = time
 Write [F:COU]
 If fstat
  GOK = 0 : Call FSTA("COU") From GLOCK : Break
 Endif
Next
Return

# FQ79692 - MABON 06/02/12 - Initialisation du tableau Suivi
$INI_SUIACN
Local Integer I

  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  I=0
  For [F:ADI] Where NUMTAB=10466 and N1=2
    [F:HRSES]SUIACN(I)=[F:ADI]CODE
    I += 1
  Next
Return

#####################################
$SAUVE_SESSION
Local Integer NBRSES, CREATE_SES
CREATE_SES=1
If [M:STG5]NBLIG5>0 & find("",[M:STG5]CODSES(0..[M:STG5]NBLIG5-1))>0 Then
  CREATE_SES=2
  TIT=mess(209,10717,1)     :# Création sessions
  Call OUVRE_TRACE(TIT) From LECFIC
  Call ECR_TRACE(TIT,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  NBRSES=0
Endif
For nolign=1 To [M:STG5]NBLIG5
 #Si le code session est vide -> nouvelle session a créer
 If [M:STG5]CODSES(nolign-1)=""
  Call CPT_SES (VALCPT,[M:STG0]COD) From SUBHRSES
  If !GOK : Break : Endif
  Raz [F:HRSES]
  [F:HRSES]=[F:STG]
  Raz [F:HRSES]NBRHOUIPT
  Raz [F:HRSES]NBRDAY
  [F:HRSES]=[M:STG5]
  [F:HRSES]COD=VALCPT
  If [F:STG]SHO<>""
   [F:HRSES]DES=mess(34,10717,1)-[F:STG]SHO :#Session
  Else
   [F:HRSES]DES=mess(34,10717,1)-[F:STG]COD :#Session
  Endif
  [F:HRSES]STG=[F:STG]COD
  Raz [F:HRSES]SHO
  [F:HRSES]STASES=1
  # FQ79692 - MABON 06/02/12 - Initialisation du tableau Suivi
  Gosub INI_SUIACN
  # Fin MABON
  [F:HRSES]CREDAT = date$
  [F:HRSES]CREUSR = GUSER
  [F:HRSES]CRETIM = time
  Raz [F:HRSES]UPDDAT   :  Raz [F:HRSES]UPDUSR   :  Raz [F:HRSES]UPDTIM : Raz [F:HRSES]EXPNUM
  [F:HRSES]FLGCLO=1
  Gosub CRE_JOURS
  Write [F:HRSES]
  If fstat
   GOK = 0 : Call FSTA("HRSES") From GLOCK : Break
  Endif
  Gosub CRE_COU_SES
  If GOK=0 Then
    Break
  Else
    Call ECR_TRACE(mess(34,10717,1)-[F:HRSES]COD-mess(40,101,1)-num$([F:HRSES]STRDAT)-mess(95,100,1)-num$([F:HRSES]ENDDAT),0) From GESECRAN : # Session du
    NBRSES += 1
  Endif
 Else
  # MABON 07/02/11 - On ne modifie plus les sessions sur modification de stage (sauf si modif du type de stage)
#  Readlock [F:HRSES]SES0=[M:STG5]CODSES(nolign-1)
#  If !fstat & [F:HRSES]FLGCLO<>2
#   Raz [F:HRSES]NBRHOUIPT
#   Raz [F:HRSES]NBRDAY
#   [F:HRSES]STRDAT=[M:STG5]STRDAT(nolign-1)
#   [F:HRSES]ENDDAT=[M:STG5]ENDDAT(nolign-1)
#   [F:HRSES]STRTIM=[M:STG5]STRTIM(nolign-1)
#   [F:HRSES]ENDTIM=[M:STG5]ENDTIM(nolign-1)
#   [F:HRSES]NBRHOUBRK=[M:STG5]NBRHOUBRK(nolign-1)
#   [F:HRSES]UPDDAT=date$ :  [F:HRSES]UPDUSR=GUSER :  [F:HRSES]UPDTIM=time
#   Gosub MOD_JOURS
#   Rewrite [F:HRSES]
#   If fstat
#    GOK = 0 : Call FSTA("SES") From GLOCK : Break
#   Endif
#  Endif
 Endif
Next
# MABON 07/02/11 - Si type de stage change, il faut aussi traiter les sessions passées (et les inscriptions qui
# s'y ratachent), de façon à supprimer les jours de présence en trop (si nouveau type =2) ou à en créer (si
# nouveau type =1)
If dim(GMODTYPSTG)>0 & GMODTYPSTG=2 Then
  If clalev([F:SES2])=0 : Local File SESSIONS [SES2] : Endif
  Filter [F:SES2] Where STG=[F:STG]COD
  For [F:SES2]
    Readlock [F:HRSES]SES0=[F:SES2]COD
    If !fstat & [F:HRSES]FLGCLO<>2
     Raz [F:HRSES]NBRHOUIPT
     Raz [F:HRSES]NBRDAY
     [F:HRSES]UPDDAT=date$ :  [F:HRSES]UPDUSR=GUSER :  [F:HRSES]UPDTIM=time
     Gosub MOD_JOURS
     Rewrite [F:HRSES]
     If fstat
      GOK = 0 : Call FSTA("HRSES") From GLOCK : Break
     Endif
    Endif
  Next
  Filter [F:SES2]
Endif
If CREATE_SES=2 Then
  If NBRSES=0 Then
    Call ECR_TRACE(mess(210,10717,1),0) From GESECRAN : # Aucune session créée
  Endif
  Call FERME_TRACE From LECFIC
  # Affichage de la trace
  Call LEC_TRACE From LECFIC
Endif
If !GOK : Return : Endif
Return

#**#####################################################################################
#* Procédure globale de sauvegarde des cibles
#*!
Funprog SAUVE_TRG_GEN(TRGNAME, TRG, IND)
Value Char    TRGNAME, TRG()
Value Integer IND
Local Char    TRG_GEN(250)

  TRG_GEN=TRG
  If [M:STG2]PARPLAG(IND)=TRGNAME Then
    If TRG_GEN<>"" Then
      TRG_GEN += ";"
    Endif
    TRG_GEN += [M:STG2]VALPLAG1(IND)
    If [M:STG2]VALPLAG2(IND)<>"" or [M:STG2]BORPLAG(IND)=2 Then
      If [M:STG2]VALPLAG2(IND)<>"" Then
        TRG_GEN += "&"+[M:STG2]VALPLAG2(IND)
      Else
        TRG_GEN += "&"+[M:STG2]VALPLAG1(IND)
      Endif
    Endif
  Endif
End TRG_GEN

#**#####################################################################################
#* Sauvegarde des cibles dans la table STAGETRG
#*!
$SAUVE_TRG
Local Integer I

  Delete [HRSTR] Where COD=[F:STG]COD
  If fstat=1 | fstat>5
   GOK = 0 : Call FSTA("HRSTR") From GLOCK : Return
  Endif
  Raz [F:HRSTR]
  [F:HRSTR]COD=[F:STG]COD
  If [M:STG2]CATTRG<>"" Then [F:HRSTR]CATTRG = [M:STG2]CATTRG Endif
  If [M:STG2]CPYTRG<>"" Then [F:HRSTR]CPYTRG = [M:STG2]CPYTRG Endif
  If [M:STG2]FCYTRG<>"" Then [F:HRSTR]FCYTRG = [M:STG2]FCYTRG Endif
  If [M:STG2]JOTTRG<>"" Then [F:HRSTR]JOTTRG = [M:STG2]JOTTRG Endif
  If [M:STG2]POTTRG<>"" Then [F:HRSTR]POTTRG = [M:STG2]POTTRG Endif
  If [M:STG2]POPTRG<>"" Then [F:HRSTR]POPTRG = [M:STG2]POPTRG Endif
  If [M:STG2]HABTRG<>"" Then [F:HRSTR]HABTRG = [M:STG2]HABTRG Endif
  For I=0 To [M:STG2]NBPLAG-1
    Case [M:STG2]PARPLAG(I)
      When "CATTRG" : If [M:STG2]CATTRG="" Then [F:HRSTR]CATTRG = func SAUVE_TRG_GEN("CATTRG", [F:HRSTR]CATTRG, I) Endif
      When "CPYTRG" : If [M:STG2]CPYTRG="" Then [F:HRSTR]CPYTRG = func SAUVE_TRG_GEN("CPYTRG", [F:HRSTR]CPYTRG, I) Endif
      When "FCYTRG" : If [M:STG2]FCYTRG="" Then [F:HRSTR]FCYTRG = func SAUVE_TRG_GEN("FCYTRG", [F:HRSTR]FCYTRG, I) Endif
      When "JOTTRG" : If [M:STG2]JOTTRG="" Then [F:HRSTR]JOTTRG = func SAUVE_TRG_GEN("JOTTRG", [F:HRSTR]JOTTRG, I) Endif
      When "POTTRG" : If [M:STG2]POTTRG="" Then [F:HRSTR]POTTRG = func SAUVE_TRG_GEN("POTTRG", [F:HRSTR]POTTRG, I) Endif
      When "POPTRG" : If [M:STG2]POPTRG="" Then [F:HRSTR]POPTRG = func SAUVE_TRG_GEN("POPTRG", [F:HRSTR]POPTRG, I) Endif
      When "HABTRG" : If [M:STG2]HABTRG="" Then [F:HRSTR]HABTRG = func SAUVE_TRG_GEN("HABTRG", [F:HRSTR]HABTRG, I) Endif
    Endcase
  Next

  If [F:HRSTR]CATTRG="" Then [F:STG]CATTRG="" Endif
  [F:HRSTR]RESPED = [M:STG2]RESPED
  #LIPET - 2017-05-24 - X3-34429 - START
#################################
#Waiting for portal integration
#################################
  # FQ77785 - MABON 05/12/11 - Alimentation du nouveau champ FORWHO
#  If GPRH=2 Then
#    [F:HRSTR]FORWHO = [M:STG6]FORWHO
#  Endif
  # Fin MABON
  #LIPET - 2017-05-24 - X3-34429 - END
  [F:HRSTR]CREDAT = date$
  [F:HRSTR]CRETIM = time
  [F:HRSTR]CREUSR=GUSER
  Write [F:HRSTR]
  If fstat
    GOK = 0 : Call FSTA("HRSTR") From GLOCK
  Endif
  #LIPET - 2017-05-24 - X3-34429 - START
#################################
#Waiting for portal integration
#################################
  # FQ77785 - MABON 05/12/11 - Alimentation du nouveau champ OBJS
#  If GPRH=2 Then
#    Delete [HRSTP] Where COD=[F:STG]COD
#    If fstat=1 | fstat>5
#     GOK = 0 : Call FSTA("STP") From GLOCK : Return
#    Endif
#    Raz [F:HRSTP]
#    [F:HRSTP]COD=[F:STG]COD
#    [F:HRSTP]OBJS = [M:STG6]OBJS
#    [F:HRSTP]CREDAT = date$
#    [F:HRSTP]CRETIM = time
#    [F:HRSTP]CREUSR=GUSER
#    Write [F:HRSTP]
#    If fstat
#      GOK = 0 : Call FSTA("HRSTP") From GLOCK
#    Endif
#  Endif
  #LIPET - 2017-05-24 - X3-34429 - END
  # MABON - 23/08/10 - Récupération des cibles
  Gosub CHARGE_TRG
Return

#**#####################################################################################
#* Je ne crée pas de jour pour les samedis ni les dimanches
#* Par ailleurs, si type de stage long, on ne crée pas autant de lignes que de jours : on ne crée qu'une ligne
#* avec date de fin = date de fin de stage
#*!
$CRE_JOURS
# FQ83268 - MABON 03/07/12 - Déclaration des décimales ici, pour l'import
Local Decimal VALHMDEB, VALHMFIN
#LIPET - 2017-05-24 - X3-34429 - START
Local Date    OLDDATE
#LIPET - 2017-05-24 - X3-34429 - END
# Fin MABON
  NBJOUR=([F:HRSES]ENDDAT-[F:HRSES]STRDAT)+1
  If [F:STG]TYPSTG=1 Then
    For I=0 To NBJOUR-1
     DATREF=[F:HRSES]STRDAT+I
     # Pas le week end sauf si c'est le premier ou le dernier jour de la session.
     If dayn([L]DATREF)<6 | find([L]DATREF,[F:HRSES]STRDAT,[F:HRSES]ENDDAT)
      [F:SEJ]SES=[F:HRSES]COD
      [F:SEJ]DAT=DATREF
      [F:SEJ]DEBTIM=[F:HRSES]STRTIM
      [F:SEJ]FINTIM=[F:HRSES]ENDTIM
      [F:SEJ]NBRTIMBRK=[F:HRSES]NBRHOUBRK
      Call CONVERTHM([F:HRSES]STRTIM,VALHMDEB) From SUBHRSES
      Call CONVERTHM([F:HRSES]ENDTIM,VALHMFIN) From SUBHRSES
      [F:SEJ]NBRHOU =VALHMFIN-VALHMDEB-[F:SEJ]NBRTIMBRK
      If [F:SEJ]NBRHOU>0 :[F:SEJ]NBRJOU=1  : Else [F:SEJ]NBRJOU=0 : Endif
      Write [F:SEJ]
      If fstat
       GOK = 0 : Call FSTA("SEJ") From GLOCK : Break
      Endif
      [F:HRSES]NBRHOUIPT+=[F:SEJ]NBRHOU
      [F:HRSES]NBRDAY+=[F:SEJ]NBRJOU
      #LIPET - 2017-05-24 - X3-34429 - START
            If OLDDATE+1 = [F:SEJ]DAT
         [F:HRSES]NBRNGT+=1
      Endif
      OLDDATE=[F:SEJ]DAT
      #LIPET - 2017-05-24 - X3-34429 - END
     Endif
    Next
  Elsif [F:STG]TYPSTG=2 Then
    # MABON - 19/08/10 - Dans ce cas, un seul enregistrement, qui contient le nombre de jours et d'heures
#    Local Decimal NNBRTIMBRK, NNBRHOU

#    If [F:HRSES]STRTIM="" Then [F:HRSES]STRTIM = [F:STG]STRTIMSTG Endif
#    If [F:HRSES]ENDTIM="" Then [F:HRSES]ENDTIM = [F:STG]ENDTIMSTG Endif
    For I=0 To NBJOUR-1
      DATREF=[F:HRSES]STRDAT+I
      # Pas le week end sauf si c'est le premier ou le dernier jour de la session.
      If dayn([L]DATREF)<6 | find([L]DATREF,[F:HRSES]STRDAT,[F:HRSES]ENDDAT)
#        NNBRTIMBRK=[F:HRSES]NBRHOUBRK
#        Call CONVERTHM([F:HRSES]STRTIM,VALHMDEB)From SUBHRSES
#        Call CONVERTHM([F:HRSES]ENDTIM,VALHMFIN)From SUBHRSES
#        NNBRHOU =VALHMFIN-VALHMDEB-NNBRTIMBRK
#        [F:HRSES]NBRHOUIPT+=NNBRHOU
        [F:HRSES]NBRDAY+=1
      Endif
    Next
    [F:HRSES]NBRHOUIPT = [F:STG]NBRHOUIPT
    [F:SEJ]SES       = [F:HRSES]COD
    [F:SEJ]DAT       = [F:HRSES]STRDAT
#    [F:SEJ]DEBTIM    = [F:HRSES]STRTIM
#    [F:SEJ]FINTIM    = [F:HRSES]ENDTIM
    [F:SEJ]NBRTIMBRK = [F:HRSES]NBRHOUBRK
    [F:SEJ]NBRHOU    = [F:HRSES]NBRHOUIPT
    [F:SEJ]NBRHOUHTT = 0
    [F:SEJ]NBRJOU    = [F:HRSES]NBRDAY
    Write [F:SEJ]
    If fstat
     GOK = 0 : Call FSTA("SEJ") From GLOCK
    Endif
  Endif
Return

#####################################
# LST : pour le moment on ne passe plus dans cette étiquette !
#**#####################################################################################
#* Si type de stage long, on ne crée pas autant de lignes que de jours : on ne crée qu'une ligne
#* avec date de fin = date de fin de stage
#*!
$MOD_JOURS
# FQ83268 - MABON 03/07/12 - Déclaration des décimales ici, pour l'import
Local Decimal VALHMDEB, VALHMFIN
# Fin MABON
#Supression des jours en dehors de la période saisie
Delete [F:SEJ] Where SES=[F:HRSES]COD & (DAT<[F:HRSES]STRDAT | DAT>[F:HRSES]ENDDAT)
If fstat
 GOK = -1 : GLOCK = "$SESJOU" : Return
Endif
NBJOUR=([F:HRSES]ENDDAT-[F:HRSES]STRDAT)+1
If [F:STG]TYPSTG=1 Then
  For I=0 To NBJOUR-1
   DATREF=[F:HRSES]STRDAT+I
  #Je modifie tous les jours car l'utilisateur a pu en creer pour les samedis ou les dimanche...
  #If day$(DATREF)<>mess(6,742,1) & day$(DATREF)<>mess(7,742,1) :#Samedi & Dimanche
    Readlock[F:SEJ]SEJ0=[F:HRSES]COD;DATREF
    #Ajout des jours
    If fstat & (dayn(DATREF)<6 | find([L]DATREF,[F:HRSES]STRDAT,[F:HRSES]ENDDAT))
     [F:SEJ]SES=[F:HRSES]COD
     [F:SEJ]DAT=DATREF
     [F:SEJ]DEBTIM=[F:HRSES]STRTIM
     [F:SEJ]FINTIM=[F:HRSES]ENDTIM
     [F:SEJ]NBRTIMBRK=[F:HRSES]NBRHOUBRK
     Call CONVERTHM([F:HRSES]STRTIM,VALHMDEB)From SUBHRSES
     Call CONVERTHM([F:HRSES]ENDTIM,VALHMFIN)From SUBHRSES
     [F:SEJ]NBRHOU =VALHMFIN-VALHMDEB-[F:SEJ]NBRTIMBRK
     If [F:SEJ]NBRHOU>0 :[F:SEJ]NBRJOU=1  : Else [F:SEJ]NBRJOU=0 : Endif
     Write [F:SEJ]
     If fstat
      GOK = 0 : Call FSTA("SEJ") From GLOCK : Break
     Endif
     [F:HRSES]NBRHOUIPT+=[F:SEJ]NBRHOU
     [F:HRSES]NBRDAY+=[F:SEJ]NBRJOU
    # 58430
    #Else
    Elsif !fstat
     #Modif des jours
     If [F:HRSES]STRTIM<>"" Then [F:SEJ]DEBTIM=[F:HRSES]STRTIM : Endif
     If [F:HRSES]ENDTIM<>"" Then [F:SEJ]FINTIM=[F:HRSES]ENDTIM : Endif
     [F:SEJ]NBRTIMBRK=[F:HRSES]NBRHOUBRK
     Call CONVERTHM([F:HRSES]STRTIM,VALHMDEB)From SUBHRSES
     Call CONVERTHM([F:HRSES]ENDTIM,VALHMFIN)From SUBHRSES
     [F:SEJ]NBRHOU =VALHMFIN-VALHMDEB-[F:SEJ]NBRTIMBRK
     If [F:SEJ]NBRHOU>0 :[F:SEJ]NBRJOU=1  : Else [F:SEJ]NBRJOU=0 : Endif
     Rewrite [F:SEJ]
     If fstat
      GOK = 0 : Call FSTA("SEJ") From GLOCK : Break
     Endif
     [F:HRSES]NBRHOUIPT+=[F:SEJ]NBRHOU
     [F:HRSES]NBRDAY+=[F:SEJ]NBRJOU
    Endif
   #Endif
  Next
Elsif [F:STG]TYPSTG=2 Then
  # MABON - 19/08/10 - Dans ce cas, un seul enregistrement, qui contient le nombre de jours et d'heures
  For I=0 To NBJOUR-1
    DATREF=[F:HRSES]STRDAT+I
    # Pas le week end sauf si c'est le premier ou le dernier jour de la session.
    If dayn([L]DATREF)<6 | find([L]DATREF,[F:HRSES]STRDAT,[F:HRSES]ENDDAT)
      [F:HRSES]NBRDAY+=1
    Endif
  Next
  Delete [F:SEJ] Where SES=[F:HRSES]COD
  If fstat
   GOK = -1 : GLOCK = "$SESJOU" : Return
  Endif
  Readlock [F:SEJ]SEJ0=[F:HRSES]COD;[F:HRSES]STRDAT
  If fstat Then
    [F:HRSES]NBRHOUIPT = [F:STG]NBRHOUIPT
    [F:SEJ]SES       = [F:HRSES]COD
    [F:SEJ]DAT       = [F:HRSES]STRDAT
    [F:SEJ]NBRTIMBRK = [F:HRSES]NBRHOUBRK
    [F:SEJ]NBRHOU    = [F:HRSES]NBRHOUIPT
    [F:SEJ]NBRHOUHTT = 0
    [F:SEJ]NBRJOU    = [F:HRSES]NBRDAY
    Write [F:SEJ]
  Else
    [F:HRSES]NBRHOUIPT = [F:STG]NBRHOUIPT
    [F:SEJ]NBRJOU    = [F:HRSES]NBRDAY
    Rewrite [F:SEJ]
  Endif
  If fstat
#SEGAY - 23/02/11 bug 71824 Suppression des return dans MOD_JOURS
#   GOK = 0 : Call FSTA("SEJ") From GLOCK
   GOK = 0 : Call FSTA("SEJ") From GLOCK : Return
  Endif
Endif
Return

#####################################
$CRE_COU_SES
For I=0 To [M:STG4]NBLIG4-1
 Read [ADI]CODE=10451;[M:STG4]TYPCRG(I)
 If [F:ADI]N1<3 & [F:ADI]N2=2  : # Coût formateur
  Raz [F:HRCOR]
  [F:HRCOR]TYPCOU    = 2
  [F:HRCOR]SES       = VALCPT
  [F:HRCOR]NUMLIG    = I+1
  [F:HRCOR]TYPCRG2   = [M:STG4]TYPCRG(I)
  [F:HRCOR]TYPFIN2   = [M:STG4]TYPFIN(I)
  [F:HRCOR]ORGFIN2   = [M:STG4]ORGFIN(I)
  [F:HRCOR]CSTTOTCLL2= [M:STG4]CSTTOTCLL(I)
  [F:HRCOR]CSTTOTIDV2= [M:STG4]CSTTOTIDV(I)
  [F:HRCOR]CSTIPTCLL2= [M:STG4]CSTIPTCLL(I)
  [F:HRCOR]CSTIPTIDV2= [M:STG4]CSTIPTIDV(I)
  [F:HRCOR]CUR       = [M:STG4]CUR
  [F:HRCOR]CREDAT    = date$
  [F:HRCOR]CREUSR    = GUSER
  [F:HRCOR]CRETIM    = time
  Write [F:HRCOR]
  If fstat
   GOK = 0 : Call FSTA("HRCOR") From GLOCK : Break
  Endif
 Else
  Raz [F:COU]
  [F:COU]TYPCOU    = 2
  [F:COU]SES       = VALCPT
  [F:COU]NUMLIG    = I+1
  [F:COU]TYPCRG    = [M:STG4]TYPCRG(I)
  [F:COU]TYPFIN    = [M:STG4]TYPFIN(I)
  [F:COU]ORGFIN    = [M:STG4]ORGFIN(I)
  [F:COU]CSTTOTCLL = [M:STG4]CSTTOTCLL(I)
  [F:COU]CSTTOTIDV = [M:STG4]CSTTOTIDV(I)
  [F:COU]CSTIPTCLL = [M:STG4]CSTIPTCLL(I)
  [F:COU]CSTIPTIDV = [M:STG4]CSTIPTIDV(I)
  #LIPET - 2017-05-24 - X3-34429 - START
  If dim([M:STG4]LNKREP)<>-1
    [F:COU]LNKREP    = [M:STG4]LNKREP(I)
  Endif
  #LIPET - 2017-05-24 - X3-34429 - END
  [F:COU]CUR       = [M:STG4]CUR
  [F:COU]CREDAT    = date$
  [F:COU]CREUSR    = GUSER
  [F:COU]CRETIM    = time
  Write [F:COU]
  If fstat
   GOK = 0 : Call FSTA("COU") From GLOCK : Break
  Endif
 Endif
Next
Return

#**#####################################################################################
#* MABON - 26/08/10 - Gestion nouveau browser "Stage DIF"
#*!
$FILGAUCHE

  FILGAUSUP="1=1"
  Case currbox
    When BOXDIF : FILGAUSUP -= '& ([F:STG]DIFTRG=2)'
  Endcase
Return

#####################################
$VERIF

#Vérification que les stages pré-requis ne contiennent pas eux même le stage courant.
#Afin d'éviter une boucle de stages prérequis :
#STAG01 est un prérequis de STAGE02 du coup STAGE02 ne peut pas être  un stage prérequis de STAGE01...

Raz TABSTG : NBSTG=0 : OK=1
#Chargement dans un tableau mémoire de tous les stages pré-requis directs et indirects du stage courant
For I=0 To [M:STG3]NBLIG-1
 If !find ([M:STG3]STGNEC(I), TABSTG(0..NBSTG))
  If NBSTG<=MAXSTG
   TABSTG(NBSTG)=[M:STG3]STGNEC(I)
   NBSTG+=1
  Else
   #Trop de stages pré-requis
   GMESSAGE = mess(82,10717,1)
   OK=0 : Break
  Endif
 Endif
Next
If OK & NBSTG
 For I=0 To NBSTG
  Read[F:STG2]STG0=TABSTG(I)
  For J=0 To dim([F:STG2]STGNEC)-1
   If [F:STG2]STGNEC(J)=""
    Break
   Elsif [F:STG2]STGNEC(J)=[M:STG0]COD
    #Stage pré-requis invalide
    GMESSAGE = mess(83,10717,1)
    OK=0 : Break 2
   Elsif !find ([F:STG2]STGNEC(J), TABSTG(0..NBSTG))
    If NBSTG<=MAXSTG
     TABSTG(NBSTG)=[F:STG2]STGNEC(J)
     NBSTG+=1
    Else
     #Trop de stages pré-requis
     GMESSAGE = mess(82,10717,1)
     OK=0 : Break 2
    Endif
   Endif
  Next
 Next
Endif

# SYMEU : EXI 66191 LOT 10 - V6.1 : gestion d'un stage fictif
# Vérification, si le stage est fictif, qu'il n'y a pas un autre stage qui est fictif
If [M:STG0]FICTI = 2 Then
  Filter [F:STG] Where FICTI=2 and COD <> [M:STG0]COD
  Read [F:STG]STG0 First
  If !fstat Then
    # Vous ne pouvez pas déclarer ce stage comme fictif, car il y a déjà un stage fictif :
    GMESSAGE -= mess(192,10717,1)-[F:STG]COD
    OK = 0
  Endif
  Filter [F:STG]
Endif
Call CALL_INIML1 #FQ93180  - Initialisation ML1 <> 0

If !OK : SUIZON="[M:STG3]STGNEC(0)": Return : Endif
Return

#####################################
$ANNULE_CMT
Delete [BCB]BCB0="SUBSTG";[F:STG]COD;"";"";""
If fstat=1 | fstat>5
 GOK=-1 : GLOCK="$BCLOB"-"SUBSTG"-[F:STG]COD
Endif
Return

#FQ93180  - Initialisation ML1 <> 0
#**
#* Initialisation ML1 <> 0
#*!
Subprog CALL_INIML1
Local Integer I
For I=0 To 6
  If evalue("clalev([M:STG"+num$(I)+"])")>0
    Call INI_ML1("STG"+num$(I)) From DIVPAYE
  Endif
Next I
End

