Subprog AS_ORG(VALEUR)
Variable Char    VALEUR()

  If [M]TCHEMP<>"" Then
    mkstat=2
  Endif
End

Subprog AM_ORG(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 If dim([M]REF)>=0 :  Effzo [M]REF : Grizo [M]REF : Endif
 Effzo TCHNAM
 Grizo TCHNAM
Else
 If dim([M]REF)>=0 :  Actzo [M]REF : Endif
 Actzo TCHNAM
Endif
End

