# FQ84144 - MABON 27/08/12 - Contrôle saisie
Subprog C_CATTRG(VALEUR)
Variable Char    VALEUR()

  If VALEUR="" Then End : Endif
  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  Read [F:ADI]=10453;VALEUR
  If fstat Then GMESSAGE = mess(23,100,1) : mkstat = 2 : Endif : # Fiche inexistante
End
# Fin MABON

# FQ84144 - MABON 27/08/12 - Contrôle saisie
Subprog C_FCYTRG(VALEUR)
Variable Char    VALEUR()

  If VALEUR="" Then End : Endif
  If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
  Call LECTURE("FCY", VALEUR, "") From CONTOBJ
  If fstat Then GMESSAGE = mess(15,104,1) : mkstat = 2 : Endif : # Site inexistant
End
# Fin MABON

# FQ84144 - MABON 27/08/12 - Contrôle saisie
Subprog C_JOTTRG(VALEUR)
Variable Char    VALEUR()

  If VALEUR="" Then End : Endif
#LIPET - 2017-11-20 - X3-64350 - START
  If clalev([F:JOT])=0 : Local File JOBTYP [JOT] : Endif

  Filter [F:JOT] Where COD=VALEUR
  Read [F:JOT] First
  Filter [F:JOT]
  If fstat=0 Then
    If [F:JOT]LEG <> GCURLEG & [F:JOT]LEG <> "" Then
      GMESSAGE = VALEUR-":"-mess(62,127,1)-":"-[F:JOT]LEG
      mkstat = 2 : End
    Endif
  Endif
#LIPET - 2017-11-20 - X3-64350 - END
  Call LECTURE("JOT", VALEUR, "") From CONTOBJ
  If fstat Then GMESSAGE = mess(23,100,1) : mkstat = 2 : Endif : # Fiche inexistante
End
# Fin MABON

