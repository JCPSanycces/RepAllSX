Subprog B2_NBLIG4
  Call DELETE_MANUAL() From TRTCOUT
  # normally in am but not do in after line
  Call CSTMOY ([M]NBLIG4)
  If GREP=""
    mkstat=4
    # we lost focus so we need to force
    Local Integer LIN
    LIN=min(nolign-1,[M]NBLIG4)
    zonsui="NBLIG4("+num$(LIN)+")"
  Endif
End


