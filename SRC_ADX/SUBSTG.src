Raz GPILOBJ
Call OBJET("STG",GBIDC1,"") From GOBJET
End

$ACTION
#LIPET - 2017-05-24 - X3-34429 - START
If dim([M:STG4]WTRTCOU)<>-1 and [M:STG4]WTRTCOU="" : [M:STG4]WTRTCOU=trtcou : Endif
#LIPET - 2017-05-24 - X3-34429 - END
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "FERME"        : Gosub FERME
 When "ABANDON"      : Gosub ABANDON
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "LIENS"        : Gosub LIENS
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
 When "INIMOD"       : Gosub INIMOD
 When "INICRE"       : Gosub INICRE
 When "FILGAUCHE"    : Gosub FILGAUCHE
 When "VERIF_CRE"    : Gosub VERIF
 When "VERIF_MOD"    : Gosub VERIF
 When "APRES_CRE"    : Gosub CHARGE_SESSIONS : Affzo [M:STG5] : Gosub DEF_LEG
 When "APRES_MOD"    : Gosub CHARGE_SESSIONS : Affzo [M:STG5] : Gosub DEF_LEG
 When "RAZDUP"       : Raz [M:STG5] : Affzo [M:STG5] : Actzo [M:STG0]LEG  :#Liste des sessions
 When "RAZCRE"       : Gosub RAZCRE
 When "SETBOUT"      : Gosub SETBOUT
 When "BB1_NBLIG5"   : Gosub BB1_NBLIG5               :#Retour du clic droit pour tunnel session
 When "ANNULE"       : Gosub ANNULE_CMT
 When "CONTPAR1"     : Gosub CONTPAR1
 When "CONTPAR2"     : Gosub CONTPAR2
 When "SEL_TABLE"    : Gosub SEL_TABLE
 When "FIN_TABLE"    : Gosub FIN_TABLE
 When "STYLE"        : Gosub STYLE   #LIPET - 2017-05-24 - X3-34429
Endcase
#LIPET - 2017-05-24 - X3-34429 - START
#FRLAA - 2015-03-18 - Requirement 101301 US 1 - START
If func AFNC.ACTIV("FKSSD")>0 & func DIVPAYE.EXISTE_KXX("SUBSTGSA") Then
  Gosub ACTION From SUBSTGSA
Endif
#FRLAA - 2015-03-18 - Requirement 101301 US 1 - END
#LIPET - 2017-05-24 - X3-34429 - END
Return

