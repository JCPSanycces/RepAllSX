## Etiquette ajoutée par le superviseur (écran STG4) 03-08-2010 06:20:53 (DBA)
######################################################################################
Subprog IB_NBRDAY
End

#**#####################################################################################
#* Désactivation choix Tous
#*!
Subprog AS_TYPSTG(VALEUR)
Variable Integer VALEUR

  GMENLOC(3)=1
End

#**#####################################################################################
#* FQ71518 - MABON 28/02/11
#* On ne peut pas changer le type de stage s'il existe au moins une inscription à une session
#* rattachée au stage
#*!
Subprog C_TYPSTG(VALEUR)
Variable Integer VALEUR

  If [M:STG4]TYPSTG<>VALEUR Then
    If clalev([F:INS])=0 : Local File INSCRIPT [INS] : Endif
#    Filter [F:INS] Where STG=[F:STG]COD
    Filter [F:INS] Where STG=[M:STG0]COD
    If rowcount([F:INS])>0 Then
      mkstat=2
    Endif
    Filter [F:INS]
  Endif
End

#**#####################################################################################
#* Si Stage court : toutes les colonnes sont présentes
#* Si Autre stage : les colonnes Heure début, Heure fin, et Temps de pause disparaissent
#*!
Subprog AM_TYPSTG(VALEUR)
Variable Integer VALEUR

  # MABON - 19/08/10 - Selon le type du stage, des colonnes apparaissent ou disparaissent dans l'onglet Sessions
  If VALEUR=2 Then
    Chgfmt [M:STG5]STRTIM    With "-K:##[:]##"
    Chgfmt [M:STG5]ENDTIM    With "-K:##[:]##"
    Chgfmt [M:STG5]NBRHOUBRK With "-N:9.2"
  Else
    Chgfmt [M:STG5]STRTIM    With "K:##[:]##"
    Chgfmt [M:STG5]ENDTIM    With "K:##[:]##"
    Chgfmt [M:STG5]NBRHOUBRK With "N:9.2"
  Endif
End

#**
#* Si le stage est de type autre stage, on ne saisit pas le nombre de jours
#*
#* @param VALEUR
#*!
Subprog AS_NBRDAY(VALEUR)
Variable Decimal VALEUR

  If [M:STG4]TYPSTG=2 Then
    mkstat=2
  Endif
End

#**#####################################################################################
#* MABON - 19/08/10 - Vérification unicité des ressources
#*!
Subprog C_RSCNEC(VALEUR)
Variable Char    VALEUR()

  If VALEUR="" Then mkstat=2 : Endif
  Call UNICITE(VALEUR, [M:STG4]RSCNEC(0..[M:STG4]NBRSC-1)) From OBJDIV :#FQ99891 declare [M:STG4]NBRSC
End

#**#####################################################################################
#* MABON - 19/08/10 - Vérification de la validité de la valeur saisie
#*!
$CONTPAR1
  Call VERIF_VAL([M:APG]VAL1, [M:APG]VALINT1(nolign-1))
Return

Subprog VERIF_VAL(TRGNAME, VALINT)
Value Char TRGNAME, VALINT

  Case TRGNAME
    When "CATTRG" :
      If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
      Read [F:ADI]=10453;VALINT
      If fstat Then GMESSAGE = mess(23,100,1) : mkstat   = 1 : Endif : # Fiche inexistante

    When "CPYTRG" :
      If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
      Call LECTURE("CPY", VALINT, "") From CONTOBJ
      If fstat Then GMESSAGE = mess(16,104,1) : mkstat   = 1 : Endif : # Société inexistante
      # FQ72300 - MABON 11/03/11 - On ne peut pas sélectionner un groupe de sites
      If mkstat<>1 Then
        If clalev([F:AGF])=0 : Local File AGRPFCY [AGF] : Endif
        If clalev([F:AGC])=0 : Local File AGRPCPY  [AGC] : Endif
        Read [F:AGF]AGF0=VALINT
        If !fstat & [F:AGF]FLGCPY<>2 Then
          Filter [F:AGC] Where GRP=VALINT
          If rowcount([F:AGC])=0 Then : # Groupe de sites
            GMESSAGE=VALINT-mess(216,10717,1) : # est un groupe de sites
            mkstat=2
          Endif
          Filter [F:AGC]
        Endif
      Endif

    When "FCYTRG" :
      If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
      Call LECTURE("FCY", VALINT, "") From CONTOBJ
      If fstat Then GMESSAGE = mess(15,104,1) : mkstat   = 1 : Endif : # Site inexistant

    When "JOTTRG" :
      If clalev([F:JOT])=0 : Local File JOBTYP [JOT] : Endif
      Call LECTURE("JOT", VALINT, "") From CONTOBJ
      If fstat Then GMESSAGE = mess(23,100,1) : mkstat   = 1 : Endif : # Fiche inexistante

    When "POTTRG" :
      If clalev([F:POT])=0 : Local File POSTE [POT] : Endif
      Call LECTURE("POT", VALINT, "") From CONTOBJ
      If fstat Then GMESSAGE = mess(23,100,1) : mkstat   = 1 : Endif : # Fiche inexistante

    When "POPTRG" :
      If clalev([F:HRPOP])=0 : Local File POPUL [HRPOP] : Endif
      Call LECTURE("POP", VALINT, "") From CONTOBJ
      If fstat Then GMESSAGE = mess(23,100,1) : mkstat   = 1 : Endif : # Fiche inexistante

    When "HABTRG" :
#114309 US204
#      If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
#      Read [F:ADI]=10397;VALINT
      If clalev([F:HRLIC])=0 : Local File HRLICAUT [HRLIC] : Endif
      Look [F:HRLIC]HRLIC0 = VALINT;GCURLEG
      If fstat Then GMESSAGE = mess(23,100,1) : mkstat   = 1 : Endif : # Fiche inexistante
  Endcase
End

#**#####################################################################################
#* MABON - 19/08/10 - Vérification valeur saisie dans la borne sup des valeurs multiples
#* Vérification également de la validité de la valeur saisie
#*!
$CONTPAR2

  If [M:APG]VALINT2(nolign-1)<>"" & [M:APG]VALINT2(nolign-1)<[M:APG]VALINT1(nolign-1) Then
    GMESSAGE = mess(8,135,1) : # Valeur trop petite
    mkstat   = 1
  Endif
  Call VERIF_VAL([M:APG]VAL1, [M:APG]VALINT2(nolign-1))
Return

#**#####################################################################################
#* MABON - 24/08/10 - On vérifie si on a une seule valeur et dans ce cas, on affiche la
#* valeur dans la zone. On vérifie aussi que si pas de borne, la valeur VAPLAG2 est bien
#* vide (si on est passé de Oui à Non pour champ Bornes, le champ VALPLAG2 n'est pas remis
#* à vide dans APARPLAG)
#*!
Subprog VERIF_TRG(TRG, RET, VALRET)
Value    Char    TRG
Variable Integer RET
Variable Char    VALRET
Local    Integer I, IND, INDBOR

  IND=0 : RET=1 : INDBOR=-1
  For I=0 To [M:STG2]NBPLAG-1
    If [M:STG2]PARPLAG(I) = TRG
      IND += 1
      If [M:STG2]VALPLAG2(I)<>"" and [M:STG2]BORPLAG(I)=1 Then
        [M:STG2]VALPLAG2(I)=""
      Endif
      INDBOR = I
    Endif
  Next I
  If IND=0 Then RET=0 : Endif
  If IND=1 and [M:STG2]VALPLAG2(INDBOR)="" Then
    RET    = 2
    VALRET = [M:STG2]VALPLAG1(INDBOR)
  Endif
End

#**#####################################################################################
#* MABON - 24/08/10 - Si une seule valeur multiple saisie, on ne verdit pas la zone
#*!
Subprog AV_CATTRG(VALEUR)
Variable Char    VALEUR()

  If VALEUR<>"" Then
    Chgstl [M:STG2]CATTRG With ""
  Endif
End

Subprog AM_CATTRG(VALEUR)
Variable Char    VALEUR()
Local    Integer RET
Local    Char    VALRET

  # Si on vient de la saisie des valeurs multiples
  Chgfmt [M:STG2]LIBCAT With "-K:15X"
  If dim(GB21)>0 and GB21=2 Then
    Call VERIF_TRG("CATTRG", RET, VALRET)
    If RET>=2 Then
      Chgstl [M:STG2]CATTRG With ""
      VALEUR = VALRET
      # FQ84144 - MABON 27/08/12 - Contrôle saisie
      Call C_CATTRG(VALEUR)
      # Fin MABON
    Elsif RET=0 Then
    Else
      Chgfmt [M:STG2]LIBCAT With "KP:15X"
    Endif
    GB21=1
  Else : # Sinon
    VALEUR=[M:STG2]VALINT1
    # FQ84144 - MABON 27/08/12 - Contrôle saisie
    Call C_CATTRG(VALEUR)
    # Fin MABON
    Chgstl [M:STG2]CATTRG With ""
    # Dans ce cas, il n'y a qu'une seule valeur dans [M:STG2]NBPLAG correspondant à la catégorie
    # On la remplace par la valeur saisie manuellement ou par Sélection
    I=find("CATTRG",[M:STG2]PARPLAG(0..[M:STG2]NBPLAG-1))
    If I>0 Then [M:STG2]VALPLAG1(I-1)=[M:STG2]VALINT1 Endif
  Endif
End

#**#####################################################################################
#* MABON - 24/08/10 - Si une seule valeur multiple saisie, on ne verdit pas la zone
#*!
Subprog AV_CPYTRG(VALEUR)
Variable Char    VALEUR()

  If VALEUR<>"" Then
    Chgstl [M:STG2]CPYTRG With ""
  Endif
End

# FQ72300 - MABON 11/03/11 - On ne peut pas sélectionner un groupe de sites
Subprog C_CPYTRG(VALEUR)
Variable Char    VALEUR()

  If clalev([F:AGF])=0 : Local File AGRPFCY [AGF] : Endif
  If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif

  Read [F:AGF]AGF0=VALEUR
  If !fstat & [F:AGF]FLGCPY<>2 Then
    Filter [F:AGC] Where GRP=VALEUR
    If rowcount([F:AGC])=0 Then : # Groupe de sites
      GMESSAGE=VALEUR-mess(216,10717,1) : # est un groupe de sites
      mkstat=2
    Endif
    Filter [F:AGC]
  Endif
  # FQ84144 - MABON 27/08/12 - Contrôle saisie
  If VALEUR<>"" Then
    If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
    Call LECTURE("CPY", VALEUR, "") From CONTOBJ
    If fstat Then GMESSAGE = mess(16,104,1) : mkstat = 2 : Endif : # Société inexistante
  Endif
  # Fin MABON
End

Subprog AM_CPYTRG(VALEUR)
Variable Char    VALEUR()
Local    Integer RET
Local    Char    VALRET
#LIPET - 2017-05-24 - X3-34429 - START
#FRLAA - 2015-04-17 - Requirement 104631 US 3487 - START
If func AFNC.ACTIV("FKSSD")>0 & func DIVPAYE.EXISTE_KXX("SUBSTGSA") Then
  Call AM_CPYTRG(VALEUR) From SUBSTGSA
Endif
#FRLAA - 2015-04-17 - Requirement 104631 US 3487 - END
#LIPET - 2017-05-24 - X3-34429 - END
  # Si on vient de la saisie des valeurs multiples
  Chgfmt [M:STG2]LIBCPY With "-K:15X"
  If dim(GB22)>0 and GB22=2 Then
    Call VERIF_TRG("CPYTRG", RET, VALRET)
    If RET=2 Then
      Chgstl [M:STG2]CPYTRG With ""
      VALEUR = VALRET
      # FQ84144 - MABON 27/08/12 - Contrôle saisie
      Call C_CPYTRG(VALEUR)
      # Fin MABON
    Elsif RET=0 Then
    Else
      Chgfmt [M:STG2]LIBCPY With "KP:15X"
    Endif
    GB22=1
  Else : # Sinon
    VALEUR=[M:STG2]VALINT2
    # FQ84144 - MABON 27/08/12 - Contrôle saisie
    Call C_CPYTRG(VALEUR)
    # Fin MABON
    Chgstl [M:STG2]CPYTRG With ""
    # Dans ce cas, il n'y a qu'une seule valeur dans [M:STG2]NBPLAG correspondant à la société
    # On la remplace par la valeur saisie manuellement ou par Sélection
    I=find("CPYTRG",[M:STG2]PARPLAG(0..[M:STG2]NBPLAG-1))
    If I>0 Then [M:STG2]VALPLAG1(I-1)=[M:STG2]VALINT2 Endif
  Endif
End

