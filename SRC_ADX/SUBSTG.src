# FQ79563 - MABON 11/09/12 - Gestion de l'icône "Nouvelle adresse"
#-------------------------------------------------------------#
# Action SELADDFCY
#-------------------------------------------------------------#
$SEL_TABLE

  Case TABLE
    When "SELADDFCY"    : Gosub SELADDFCY
  Endcase
Return

$SELADDFCY

  Gosub SAVE_GLEGFIL From TOOLSHRLEG
  Gosub SAVE_GCURLEG From TOOLSHRLEG
  Case TABLE
    When "SELADDFCY" :
       DEFFILE="[F:CPY3]"
  Endcase

  If PARAM(1)<>"" Then
    Call ADDCRIT(CRITERE,ICRITERE,"","find("+DEFFILE+"LEG,'','"+PARAM(1)+"')>0","&") From GOBJSUB
  Endif
  If TABLE='SELADDFCY' & PARAM(2)<>"" Then
    Call ADDCRIT(CRITERE,ICRITERE,"","LEGCPY='"+PARAM(2)+"'","&") From GOBJSUB
  Endif
  GLEGFIL=GCURLEG
  OBJET="FCY"
Return

$FIN_TABLE

  Case TABLE
    When "SELADDFCY"    : Gosub FINADDFCY
  Endcase
Return

$FINADDFCY

  If [F:FCY]FCY<>"" Then
    If clalev([F:BPA])=0 : Local File BPADDRESS [BPA] : Endif
    Read [F:BPA]BPA0=3;[F:FCY]FCY;[F:FCY]BPAADD
    If !fstat Then
      [M]ADD(0) = [F:BPA]BPAADDLIG(0)
      [M]ADD(1) = [F:BPA]BPAADDLIG(1)
      [M]ADD(2) = [F:BPA]BPAADDLIG(2)
      [M]POSCOD = [F:BPA]POSCOD
      [M]CTY    = [F:BPA]CTY

      Affzo [M]
      mkstat=4    : # Pour forcer le passage au mode modification
      VALEUR="21" : # Pour réaffecter la valeur de l'icône, sinon VALEUR contient [F:FCY]FCY après l'appel de l'action Sélection dans table sur FCY.
    Endif
  Endif
  Gosub RESTAURE_GLEGFIL From TOOLSHRLEG
  Gosub RESTAURE_GCURLEG From TOOLSHRLEG
Return
# Fin MABON

