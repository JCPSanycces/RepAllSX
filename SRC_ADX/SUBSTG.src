#Heure de fin
Subprog C_ENDTIM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M:STG5]STRTIM(nolign-1)
 #Heure incorrecte
 GMESSAGE = mess(69,134,1)
 mkstat = 2 : End
Endif
End

Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
If !(VALEUR>=[M:STG1]STRVLY & ([M:STG1]ENDVLY=[0/0/0] | VALEUR<=[M:STG1]ENDVLY))
 #Date en dehors de la période de validité du stage
 GMESSAGE=mess(3,10717,1)
 mkstat=2 : End
Elsif dayn([L]VALEUR)>=6
 [V]GMESSAGE=func AFNC.MES1(mess(92,10717,1),day$([L]VALEUR)) : # Ce jour est un [Samedi/Diamanche]
 [V]GERR    =3 : # Avertissement
Endif
End

Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 If [M:STG4]NBRDAY>0
   VALEUR=[M:STG5]STRDAT(nolign-1)+([M:STG4]NBRDAY-1)
 Else
   VALEUR=[M:STG5]STRDAT(nolign-1)
 Endif
 Case dayn([L]VALEUR)
  When 6 : [L]VALEUR+=2 : # Samedi -> Lundi
  When 7 : [L]VALEUR+=1 : # Dimanche -> Lundi
 Endcase
Endif
End

Subprog AS_STRTIM(VALEUR)
Variable Char    VALEUR()
If val(VALEUR)=0
 If nolign-1>0
  VALEUR=[M:STG5]STRTIM(nolign-2)
 Else
  VALEUR=[M:STG1]STRTIMSTG
 Endif
Endif
End

Subprog AS_ENDTIM(VALEUR)
Variable Char    VALEUR()
If val(VALEUR)=0
 If nolign-1>0
  VALEUR=[M:STG5]ENDTIM(nolign-2)
 Else
  VALEUR=[M:STG1]ENDTIMSTG
 Endif
Endif
End

Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
If year(VALEUR)<>year([M:STG5]STRDAT(nolign-1))
 #Date en dehors d'une année civile
 GMESSAGE=mess(5,10717,1)
 mkstat=2 : End
Endif
If !(VALEUR>=[M:STG1]STRVLY & ([M:STG1]ENDVLY=[0/0/0] | VALEUR<=[M:STG1]ENDVLY))
 #Date en dehors de la période de validité du stage
 GMESSAGE=mess(3,10717,1)
 mkstat=2 : End
Elsif dayn([L]VALEUR)>=6
 [V]GMESSAGE=func AFNC.MES1(mess(92,10717,1),day$([L]VALEUR)) : # Ce jour est un [Samedi/Diamanche]
 [V]GERR    =3 : # Avertissement
Endif
End

Subprog AS_NBRHOUBRK(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 & nolign-1>0
 VALEUR=[M:STG5]NBRHOUBRK(nolign-2)
Endif
End

Subprog C_NBRHOUBRK(VALEUR)
Variable Decimal VALEUR
Local Decimal VALHMDEB, VALHMFIN
Call CONVERTHM([M:STG5]STRTIM(nolign-1),VALHMDEB) From SUBHRSES
Call CONVERTHM([M:STG5]ENDTIM(nolign-1),VALHMFIN) From SUBHRSES
If VALEUR & VALEUR>=VALHMFIN-VALHMDEB
 #Temps de pause supérieur ou égal à la durée de la session
 GMESSAGE=mess(73,10717,1)
 mkstat=2 : End
Endif
End

Subprog B1_STRTIM(VALEUR)
Variable Char    VALEUR()
Local Integer ZONE
ZONE=1
Call CONTHM(VALEUR)From OBJDIV
Goto B1_TIM

Subprog B1_ENDTIM(VALEUR)
Variable Char    VALEUR()
Local Integer ZONE
ZONE=2
Call CONTHM(VALEUR)From OBJDIV
Goto B1_TIM

Subprog B1_NBRHOUBRK(VALEUR)
Variable Decimal VALEUR
Local Integer ZONE
ZONE=3
Goto B1_TIM

$B1_TIM
Local Decimal DIFF
NOL = nolign-1
For I=NOL To [M:STG5]NBLIG5-1
 If [M:STG5]CODSES(I)=""
  Case ZONE
   When 1 : Call SUMHRS(VALEUR, [M:STG5]ENDTIM(I), DIFF) From SUBHRSES
            If DIFF-[M:STG5]NBRHOUBRK(I)>0
             [M:STG5]STRTIM(I)=VALEUR
            Endif
   When 2 : Call SUMHRS([M:STG5]STRTIM(I),VALEUR, DIFF) From SUBHRSES
            If DIFF-[M:STG5]NBRHOUBRK(I)>0
             [M:STG5]ENDTIM(I)=VALEUR
            Endif
   When 3 : Call SUMHRS([M:STG5]STRTIM(I),[M:STG5]ENDTIM(I), DIFF) From SUBHRSES
            If DIFF-VALEUR>0
             [M:STG5]NBRHOUBRK(I)=VALEUR
            Endif
  Endcase
 Endif
Next
Affzo [M:STG5]
End

$BB1_NBLIG5
Raz [M:STG5]
Gosub CHARGE_SESSIONS
Affzo [M:STG5]

Gosub DEF_LEG
Return

