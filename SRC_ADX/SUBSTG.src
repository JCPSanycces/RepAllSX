## 16/05/12 - DKA - Refresh screen after legislation changed.
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()

    GCURLEG = VALEUR
    Call DISPLAY_HIDE() From SUBSTGLEG
End
######################################################################################
## 31/05/12 PCA - Check again to ensure LEG can be changed. Is checked in LIENS
## but issue if the Session is added before the screen is refreshed.
######################################################################################
Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
   If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
    Filter [F:HRSES] Where STG=[M:STG0]COD
    If rowcount([F:HRSES])>0 Then
     [M:STG0]LEG=[F:STG]LEG
     Affzo[M:STG0]LEG
     Diszo[M:STG0]LEG
     mkstat=2
    Else
      Actzo[M:STG0]LEG
    Endif
    Filter [F:HRSES]

End


