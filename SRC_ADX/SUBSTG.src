 Endif
Else
 Call GRISE_CTRNUM(1)
Endif
# MABON - 19/08/10 - Récupération des ressources
Gosub CHARGE_RSC
# MABON - 23/08/10 - Récupération des cibles
Gosub CHARGE_TRG

Default Mask [M:STG1]

# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini : si le stage est fictif, on ne peut rien saisir
Call TEST_FICTIF([M:STG0]FICTI)

# 16/05/12 - DKA - Show\hide fields based on legislation
GCURLEG = [F:STG]LEG : [M:STG0]LEG=GCURLEG
Call DISPLAY_HIDE() From SUBSTGLEG


#30/05/12 PCA - it is not possible to alter the Leg if this is assigned to a session
#   If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
#    Filter [F:HRSES] Where STG=[M:STG0]COD
#    If rowcount([F:HRSES])>0 Then
#      Diszo[M:STG0]LEG
#    Else
#      Actzo[M:STG0]LEG
#    Endif
#    Filter [F:HRSES]
