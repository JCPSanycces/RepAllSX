Read[F:ADI]CODE=10451;VALEUR

#DKA - 23/05/12 - Store current Cost legislation
TYPCRGLEG = [F:ADI]LEG

If !fstat & [F:ADI]N1<3
 GMESSAGE=VALEUR-":"-mess(35,10717,1)-mess(33,10717,1) :# Type de coût non autorisé au niveau stage / session
 mkstat=2 : End

Else

#DKA
#sba replace by CHECKLEG_CRGFIN
#If 1=2
#Local Char SETLEG
#Local Integer I
#For I=0 To 9
#  Read[F:ADI]CODE=10451;[M:STG4]TYPCRG(I)
#  If fstat
#    Break
#  Else
#    If [F:ADI]LEG <> ""
#      SETLEG = [F:ADI]LEG
#      Break
#    Else
#      Read[F:ADI]CODE=10462;[M:STG4]TYPFIN(I)
#      If !fstat & [F:ADI]LEG <> ""
#        SETLEG = [F:ADI]LEG
#        Break
#      Endif
#    Endif
#  Endif
#Next
#  If SETLEG <> "" & TYPCRGLEG <> "" & TYPCRGLEG <> SETLEG
#    GMESSAGE=VALEUR-":"-mess(279,10717,1)-SETLEG :# The Cost and Type legislations do not match
#    mkstat=2 : End
#  Endif
#Endif
#sba
# SEGAY 81085 US 460
  Local Integer INDEX : INDEX=1
  Local Integer WOK : WOK=1
  #Call CHECKLEG_CRGFIN(VALEUR,[M:STG4]TYPFIN(nolign-1),INDEX)
  If dim([M:STG0]LEG)>0
    Call CHECKLEG_LIGCOST(VALEUR,[M:STG4]TYPFIN(nolign-1),[M:STG4]ORGFIN(nolign-1),INDEX,1,[M]WLEGLIG(nolign-1),WOK)
  Endif
Endif

# Fin MABON
End

Subprog CHECKLEG_CRGFIN(FLDCRG,FLDFIN,INDEX)
Variable Char FLDCRG()
Variable Char FLDFIN()
Variable Integer INDEX
Local Char LEGTYP(GLONADI) : LEGTYP=""
Local Char LEGFIN(GLONADI) : LEGFIN=""
If(FLDCRG<>"")
  Read[F:ADI]CODE=10451;FLDCRG
  If !fstat
    LEGTYP=[F:ADI]LEG
  Endif
Endif

If(FLDFIN<>"")
  Read[F:ADI]CODE=10462;FLDFIN
  If !fstat
    LEGFIN=[F:ADI]LEG
  Endif
Endif
If(LEGTYP="" & GCURLEG<>""):LEGTYP=GCURLEG:Endif
If(LEGFIN="" & GCURLEG<>""):LEGFIN=GCURLEG:Endif
If LEGFIN <> "" & LEGTYP <> "" & LEGTYP <> LEGFIN
  #GMESSAGE=VALEUR-":"-mess(279,10717,1)-LEGTYP:# Invalid legislation.  The legislation has already been set to <LEG>
  GMESSAGE=":"-mess(279,10717,1)
If(INDEX=1)
    GMESSAGE=FLDCRG-GMESSAGE-LEGFIN
   Else
     GMESSAGE=FLDFIN-GMESSAGE-LEGTYP
   Endif
mkstat=2 : End
Endif
End
#**#####################################################################################
#* Init legislation of a LIG
#* SEGAY 81085 US 460
#* @since 14/06/12
#* @param FLDCRG : TYPCRG code
#* @param FLDFIN : TYPFIN code
#* @param FLDOFT : organisme code 1 (training), 2 (financial) ML 10555
#* @param ORGCOD : organisme code
#* @return LEGLIG : LEG code
#*!
Subprog INILIGLEG(FLDCRG,FLDFIN,FLDOFT,LEGLIG)
Value Char FLDCRG()
Value Char FLDFIN()
Value Char FLDOFT()
Variable Char LEGLIG()
Local Char LEGCRG(GLONADI) : LEGCRG=""
Local Char LEGFIN(GLONADI) : LEGFIN=""
Local Char LEGOFT(GLONADI) : LEGOFT=""
If(FLDCRG<>"")
  Read[F:ADI]CODE=10451;FLDCRG
  If !fstat
    LEGCRG=[F:ADI]LEG
  Endif
Endif

If(FLDFIN<>"")
  Read[F:ADI]CODE=10462;FLDFIN
  If !fstat
    LEGFIN=[F:ADI]LEG
  Endif
Endif

If(FLDOFT<>"")
  LEGOFT=func TOOLSHRLEG.FGET_LEGORFINTRA(2,FLDOFT)
Endif

If LEGCRG <> ""
   LEGLIG = LEGCRG
Elsif LEGFIN <> ""
   LEGLIG = LEGFIN
Elsif LEGOFT <> ""
   LEGLIG = LEGOFT
Endif
If(LEGLIG="" & GCURLEG<>""):LEGLIG=GCURLEG:Endif
End

#**#####################################################################################
#* test legislation of a TYPCRG(INDEX=1) or TYPFIN (INDEX=2) or ORGFIN (INDEX=3)
#* SEGAY 81085 US 460
#* @since 14/06/12
#* @param FLDLIG : TYPCRG(INDEX=1) or TYPFIN (INDEX=2) or ORGFIN (INDEX=3)
#* @param INDEX :
#* @param DISPMSG : Display mesage if dispmsg <>0
#* @return LEGLIG : LEG code
#* @return POK     : flag execution. return 1 if POK
#*!
Subprog CHECKLEG_CRGFINOFT(FLDLIG,INDEX,DISPMSG,LEGLIG,POK)
Value Char FLDLIG()
Value Integer INDEX
Value Integer DISPMSG
Variable Char LEGLIG()
Variable Integer POK
Local Char LEGCRG(GLONADI) : LEGCRG=""
Local Char LEGFIN(GLONADI) : LEGFIN=""
Local Char LEGOFT(GLONADI) : LEGOFT=""
Local Char WLEG(GLONADI) : WLEG=""

If FLDLIG<>""
  Case INDEX
     When 1
        Read[F:ADI]CODE=10451;FLDLIG
        If !fstat
          LEGCRG=[F:ADI]LEG
          POK=1
        Endif
        WLEG=LEGCRG
     When 2
        Read[F:ADI]CODE=10462;FLDLIG
        If !fstat
          LEGFIN=[F:ADI]LEG
          POK=1
        Endif
        WLEG=LEGFIN
     When 3
        Call GET_LEGORFINTRA(2,FLDLIG,POK,LEGOFT) From TOOLSHRLEG
        If POK
          WLEG=LEGOFT
        Endif
  Endcase
Endif

If WLEG <> "" & LEGLIG <> "" &  WLEG <> LEGLIG
  POK=0
  If DISPMSG
    GMESSAGE=":"-mess(279,10717,1)
    GMESSAGE=FLDLIG-GMESSAGE-LEGLIG
  Endif
  mkstat=2 : End
Endif
If WLEG <> ""
  LEGLIG = WLEG
Endif
End
#**#####################################################################################
#* test legislation of a TYPCRG(INDEX=1) or TYPFIN (INDEX=2) or ORGFIN (INDEX=3)
#* SEGAY 81085 US 460
#* @since 14/06/12
#* @param FLDCRG (INDEX=1)
#* @param FLDFIN (INDEX=2)
#* @param FLDOFT (INDEX=3)
#* @param INDEX :
#* @param DISPMSG : Display mesage if dispmsg <>0
#* @return LEGLIG : LEG code
#* @return POK     : flag execution. return 1 if POK
#*!
Subprog CHECKLEG_LIGCOST(FLDCRG,FLDFIN,FLDOFT,INDEX,DISPMSG,LEGLIG,POK)
Value Char FLDCRG()
Value Char FLDFIN()
Value Char FLDOFT()
Value Integer INDEX
Value Integer DISPMSG
Variable Char LEGLIG()
Variable Integer POK
Local Char LEGCRG(GLONADI) : LEGCRG=""
Local Char LEGFIN(GLONADI) : LEGFIN=""
Local Char LEGOFT(GLONADI) : LEGOFT=""
Local Char WLEG(GLONADI) : WLEG=""
Local Char WWLEG(GLONADI) : WWLEG=""
Local Char FLDLIG(30)
If FLDCRG <> ""
    Read[F:ADI]CODE=10451;FLDCRG
    If !fstat
      LEGCRG=[F:ADI]LEG
      POK=1
    Endif
Endif
If FLDFIN <> ""
    Read[F:ADI]CODE=10462;FLDFIN
    If !fstat
      LEGFIN=[F:ADI]LEG
      POK=1
    Endif
Endif
If FLDOFT <> ""
    Call GET_LEGORFINTRA(2,FLDOFT,POK,WWLEG) From TOOLSHRLEG
    If POK
      LEGOFT=WWLEG
    Endif
Endif
Case INDEX
   When 1
      WLEG=LEGCRG
      FLDLIG=FLDCRG
   When 2
      WLEG=LEGFIN
      FLDLIG=FLDFIN
   When 3
      WLEG=LEGOFT
      FLDLIG=FLDOFT
Endcase

If WLEG <> "" & LEGLIG <> "" &  WLEG <> LEGLIG
  POK=0
  If DISPMSG
    GMESSAGE=":"-mess(279,10717,1)
    GMESSAGE=FLDLIG-GMESSAGE-LEGLIG
  Endif
  mkstat=2 : End
Endif
If WLEG <> ""
  LEGLIG = WLEG
Endif
If LEGCRG ="" & LEGFIN ="" & LEGOFT ="" & GCURLEG=""
  LEGLIG=""
Endif
End

Subprog AS_TYPFIN(VALEUR)
Variable Char    VALEUR()
#LIPET - 2017-05-24 - X3-34429 - START
#--US11689
If VALEUR="" & nolign=1
If clalev([F:ADI3])=0 : Local File ATABDIV     [ADI3] : Endif
 Filter [ADI3] Where NUMTAB=10462 & DEFVAL=2
 Read [ADI3]CODE First
 If !fstat : VALEUR = [F:ADI3]CODE : Endif
 Filter [ADI3]
Endif
#--end US11689
#LIPET - 2017-05-24 - X3-34429 - END
If VALEUR="" & nolign>1
 VALEUR = [M]TYPFIN(nolign-2)
Endif
End

#DKA - 23/05/12 - Make sure Cost and Type legislations match
Subprog C_TYPFIN(VALEUR)
Variable Char    VALEUR()

# SEGAY 81085 US 460
Local Integer INDEX : INDEX=2
Local Integer WOK : WOK=1
#Call CHECKLEG_CRGFIN([M:STG4]TYPCRG(nolign-1),VALEUR,INDEX)
If dim([M:STG0]LEG)>0
  Call CHECKLEG_LIGCOST([M:STG4]TYPCRG(nolign-1),VALEUR,[M:STG4]ORGFIN(nolign-1),INDEX,1,[M]WLEGLIG(nolign-1),WOK)
Endif
End

Subprog AS_ORGFIN(VALEUR)
Variable Char    VALEUR()
#--STA_EXI 66191 LOT 1
#If VALEUR="" & nolign>1
# VALEUR = [M]ORGFIN(nolign-2)
#Endif
If VALEUR=""
  If nolign>1
  #LIPET - 2017-05-24 - X3-34429 - START
#    VALEUR = [M]ORGFIN(nolign-2)
    #--US11689 add test dim([M]LNKREP)<=0 | (..)
    If dim([M]LNKREP)<=0 | ([M]LNKREP(nolign-2)="" | right$([M]LNKREP(nolign-2),len([M]LNKREP(nolign-2)))<>"D") #  X3PEOP-3476
      VALEUR = [M]ORGFIN(nolign-2)
    Else
      VALEUR = [M]ORGFIN(nolign-3)
    Endif
    #LIPET - 2017-05-24 - X3-34429 - END
  Else
    # Pour l'inscription on alimente avant GOFIDEF avev le paramètre niveau société
    If dim(GOFIDEF )>0 Then
      # SEGAY 81085 US 460
#      VALEUR = GOFIDEF
      Local Char WLEG(GLONADI)
      Local Integer WOK
#      Call PARAM(GSOCIETE,"OFIDEF",WOFI) From ADOVAL : # CCL
      WLEG=[M]WLEGLIG(nolign-1)
      INDEX=3
      Call CHECKLEG_CRGFINOFT(GOFIDEF,INDEX,0,WLEG,WOK) From SUBSTG
      If WOK
       VALEUR = GOFIDEF
      Endif
    Endif
  Endif
Endif
#--END_EXI 66191 LOT 1
End

Subprog C_ORGFIN(VALEUR)
Variable Char    VALEUR()
#TIVAN - 17/07/2017 - X3 - START
# On teste l'unicité de la ligne sur les zones : TYPCRG/TYPFIN/ORGFIN
Call C_ORGFIN(VALEUR) From TRTCOUT
#Local Integer I, OK
#OK = 1
#For I=0 To nolign-2
# If [M]TYPCRG(I)=[M]TYPCRG(nolign-1) & [M]TYPFIN(I)=[M]TYPFIN(nolign-1) & [M]ORGFIN(I)=VALEUR
#  OK = 0 : Break
# Endif
#Next
#If OK=1
# For I=nolign To [M:STG4]NBLIG4-1
#  If [M]TYPCRG(I)=[M]TYPCRG(nolign-1) & [M]TYPFIN(I)=[M]TYPFIN(nolign-1) & [M]ORGFIN(I)=VALEUR
#   OK = 0 : Break
#  Endif
# Next
#Endif
#If OK=0
# # Ligne de coût déjà existante en ligne xx
# GMESSAGE = mess(84,717,1)-num$(I+1)
# mkstat = 2 : End
#Endif
# SEGAY 81085 US 460
Local Integer INDEX : INDEX=3
Local Integer WOK : WOK=1
If dim([M:STG0]LEG)>0
  Call CHECKLEG_LIGCOST([M:STG4]TYPCRG(nolign-1),[M:STG4]TYPFIN(nolign-1),VALEUR,INDEX,1,[M]WLEGLIG(nolign-1),WOK)
Endif
#TIVAN - 17/07/2017 - X3 - END
End

