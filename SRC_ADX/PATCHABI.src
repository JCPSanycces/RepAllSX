#<AdxTL>@(#)11.0.0.0 $Revision$
Local Char PARAM(30)(1..1) , VALEUR(250)
Call TRAITE_CHAR(VALEUR,PARAM,"","PATCH","PATCH",3,"") From GTRAITE
End

######################################################
## Intégration d'un datamart
######################################################

$DATAMART
If !func AFNC.ACTIVDOS(APPLI,"ABI")
 Gosub FIN_OBJ From PATCH
 Return
Endif
Local Integer P_NBRABF
Local Char    P_CODABF(GLONABF)(0..50)
Local Char    P_ACTABF(GLONACV)(0..50)
Local File  =APPLI+".ABIDATMRT" [ABM]
Local File  =APPLI+".ABITABDAT" [ABF]
Read [ABM]ABM0 = NOMOBJ
If TYPENR=2 :#SCM deletion
 If fstat
  NEWOBJ = 1
  Raz [F:ABM]
 Elsif [F:ABM]CODACT>="X" & !find([F:ABM]CODACT,ACTIV(1..NBACT))
  Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spécifique
  Gosub FIN_OBJ From PATCH
  Goto FIN_ABM
 Else
  NEWOBJ = 0
 Endif
 Call DEBTRANS From GLOCK
 Gosub TR_ABM
Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_ABM
 Endif
 Gosub FIN_OBJ From PATCH
Endif
$FIN_ABM
Close Local File [ABM],[ABF]
Return

$TR_ABM
Trbegin [ABM]
 If !NEWOBJ
  Read [ABM]ABM0 = NOMOBJ
  If !fstat
   For K=0 To [F:ABM]NBRABF-1
    If !find([F:ABM]ACTABF(K),ACTIV(1..NBACT))
     P_NBRABF += 1
     P_CODABF(P_NBRABF) = [F:ABM]CODABF(K)
     P_ACTABF(P_NBRABF) = [F:ABM]ACTABF(K)
    Endif
   Next K
  Endif
 Endif
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Variable
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "ABM"   : Gosub ABM1
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ABM",NOMOBJ,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Return

$DEL_ABM
Trbegin [ABM]
 Delete [ABM] Curr
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ABIDATMRT"-NOMOBJ : Return
 Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ABM",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

## Lecture d'un datamart

$ABM1
FICHIER = "ABIDATMRT" : ABR = "ABM"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If !NEWOBJ and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0)
   If find(VARIA,"RESULT","DUREE","AUZFCY","FNC","ENAFLG","DATNUL","PREFIX")
    OK = 0
   Endif
  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
MODOBJ = max(1,[F:ABM]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
For K=0 To [F:ABM]NBRABF-1
 If !find([F:ABM]CODABF(K),P_CODABF(1..P_NBRABF))
  Read [ABF]ABF0 = [F:ABM]CODABF(K)
  If !fstat
   P_NBRABF += 1
   P_CODABF(P_NBRABF) = [F:ABM]CODABF(K)
   P_ACTABF(P_NBRABF) = [F:ABM]ACTABF(K)
  Endif
 Endif
Next K
If NEWOBJ
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ABM]CREDAT = date$
  [F:ABM]CREUSR = GUSER
  [F:ABM]UPDDAT = date$
  [F:ABM]UPDUSR = GUSER
  If dim([F:ABM]UPDTIM)>0 : [F:ABM]UPDTIM = time  : Endif
  If dim([F:ABM]CRETIM)>0 : [F:ABM]CRETIM = time  : Endif
 Endif
 Write [ABM]
Else
 For K=1 To P_NBRABF
  [F:ABM]CODABF(K-1) = P_CODABF(K)
  [F:ABM]ACTABF(K-1) = P_ACTABF(K)
 Next K
 [F:ABM]NBRABF =  P_NBRABF
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ABM]UPDDAT = date$
  [F:ABM]UPDUSR = GUSER
  If dim([F:ABM]UPDTIM)>0 : [F:ABM]UPDTIM = time  : Endif
 Endif
 Rewrite [ABM]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ABIDATMRT" : Return
Endif
Return

$ABORT
Rollback
Return

######################################################
## Intégration d'une table de faits
######################################################

$TABLE_FAIT
If !func AFNC.ACTIVDOS(APPLI,"ABI")
 Gosub FIN_OBJ From PATCH
 Return
Endif
Local File =APPLI+".ABITABDAT" [ABF]
Local File =APPLI+".ABITABFLD" [ABZ]
Local File =APPLI+".ABITABIND" [ABX]
Local File =APPLI+".ABITABLNK" [ABK]
Local File =APPLI+".ABITABAGG" [ABE]
Read [ABF]ABF0 = NOMOBJ
If fstat
 NEWOBJ = 1
 Raz [F:ABF]
Elsif [F:ABF]CODACT>="X" & !find([F:ABF]CODACT,ACTIV(1..NBACT))
 Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spécifique
 Gosub FIN_OBJ From PATCH
 Goto FIN_ABF
Else
 NEWOBJ = 0
Endif
If TYPENR=2 :#SCM deletion
 Call DEBTRANS From GLOCK
 Gosub TR_ABF
Elsif TYPENR=-2 :#SCM deletion
 Call DEBTRANS From GLOCK
 Gosub DEL_ABF
 Gosub FIN_OBJ From PATCH
Endif

$FIN_ABF
Close Local File [ABF],[ABZ],[ABX],[ABE],[ABK]
Return

$TR_ABF
Trbegin [ABF],[ABZ],[ABX],[ABE],[ABK]
 Gosub LEC_TDF
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Variable
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "ABF"   : Gosub ABF1
     When "ABZ"   : Gosub ABF2
     When "ABX"   : Gosub ABF3
     When "ABK"   : Gosub ABF4
     When "ABE"   : Gosub ABF5
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
 Gosub ECR_ABF
Commit

## Validation de la table de fait
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ABF",NOMOBJ,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif

Gosub SAV_OPENI From PATCH
# Dans l'appli X3 , on ne valide que les objets des modules Superviseur, tronc commun, développement
If APPLI<>GDOSX3
 Call VALIDATION(NOMOBJ,APPLI,1) From SUBABF
Endif
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
Gosub REST_OPENI From PATCH
Return

$DEL_ABF
Trbegin [ABF],[ABZ]
 Delete [ABZ] Where CODABF=[L]NOMOBJ
 Delete [ABF] Curr
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ABITABDAT"-NOMOBJ : Return
 Else
 Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ABF",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

$ABF1
FICHIER = "ABITABDAT" : ABR = "ABF"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If !NEWOBJ and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0)
   If find(VARIA,"NBEPU")
    OK = 0
   Endif
  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If dim([F:ABF]MODULE)>0
 MODOBJ = max(1,[F:ABF]MODULE)
 If [F:ADS]MODULE(MODOBJ-1)<>2
  OKOBJ = 0 : Return
 Endif
Endif
If NEWOBJ
 Write [ABF]
Else
 Rewrite [ABF]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ABITABDAT" : Return
Endif
Return

$ABF2 : # ABZ
FICHIER = "ABITABFLD" : ABR = "ABZ"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If !find([F:ABZ]CODFLD,S_CODFLD(0..S_NBABZ))
 P_CODABF(P_NBABZ) =[F:ABZ]CODABF
 P_CODFLD(P_NBABZ) =[F:ABZ]CODFLD
 P_INTFLD(P_NBABZ) =[F:ABZ]INTFLD
 P_INTVALFLD(P_NBABZ) =[F:ABZ]INTVALFLD
 P_INTSSC(P_NBABZ) =[F:ABZ]INTSSC
 P_INTVALSSC(P_NBABZ) =[F:ABZ]INTVALSSC
 P_CODTYP(P_NBABZ) =[F:ABZ]CODTYP
 P_TYPDAT(P_NBABZ) =[F:ABZ]TYPDAT
 P_LNGFLD(P_NBABZ) =[F:ABZ]LNGFLD
 P_MENLOC(P_NBABZ) =[F:ABZ]MENLOC
 P_TABDIV(P_NBABZ) =[F:ABZ]TABDIV
 P_ACTFLD(P_NBABZ) =[F:ABZ]ACTFLD
 P_TYPFLD(P_NBABZ) =[F:ABZ]TYPFLD
 P_TYPOPE(P_NBABZ) =[F:ABZ]TYPOPE
 P_TUNNEL(P_NBABZ) =[F:ABZ]TUNNEL
 P_NBABZ +=1
Endif
Return

$ABF3
FICHIER = "ABITABIND" : ABR = "ABX"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If !find([F:ABX]EXPIND,SX_EXPIND(0..SX_NBABX))
 SX_NBABX += 1
 SX_CODABF(SX_NBABX) = [F:ABX]CODABF
 SX_EXPIND(SX_NBABX) = [F:ABX]EXPIND
 SX_ACTIND(SX_NBABX) = [F:ABX]ACTIND
Endif
Return

$ABF4 : # ABK
FICHIER = "ABITABLNK" : ABR = "ABK"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If !find([F:ABK]CODLNK+"~"+[F:ABK]EXPLNK,SK_CLE(0..SK_NBABK))
 SK_NBABK += 1
 SK_CODABF(SK_NBABK)    = [F:ABK]CODABF
 SK_CODLNK(SK_NBABK)    = [F:ABK]CODLNK
 SK_EXPLNK(SK_NBABK)    = [F:ABK]EXPLNK
 SK_OPTJNT(SK_NBABK)    = [F:ABK]OPTJNT
 SK_TYPJNT(SK_NBABK)    = [F:ABK]TYPJNT
 SK_CLE(SK_NBABK)       = [F:ABK]CODLNK+"~"+[F:ABK]EXPLNK
 SK_INTLNK(SK_NBABK)    = [F:ABK]INTLNK
 SK_INTVALLNK(SK_NBABK) = [F:ABK]INTVALLNK
 SK_INTCOMP(SK_NBABK)    = [F:ABK]INTCOMP
 SK_INTVALCOMP(SK_NBABK) = [F:ABK]INTVALCOMP
Endif
Return

$ABF5 : # ABE
FICHIER = "ABITABAGG" : ABR = "ABE"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If !find([F:ABE]CODAGG,SE_CODAGG(0..SE_NBABE))
 SE_NBABE += 1
 SE_CODABF(SE_NBABE) =  [F:ABE]CODABF
 SE_CODAGG(SE_NBABE) =  [F:ABE]CODAGG
 SE_ACTAGG(SE_NBABE) =  [F:ABE]ACTAGG
 SE_NBRAGI(SE_NBABE) =  [F:ABE]NBRAGI
 SE_INDAGG(SE_NBABE) =  [F:ABE]INDAGG
 SE_NBRAGD(SE_NBABE) =  [F:ABE]NBRAGD
 For J=0 To dim([F:ABE]TYPAGG)-1
  SE_TYPAGG(SE_NBABE,J) =  [F:ABE]TYPAGG(J)
  SE_DIMAGG(SE_NBABE,J) =  [F:ABE]DIMAGG(J)
  SE_LNKAGG(SE_NBABE,J) =  [F:ABE]LNKAGG(J)
  SE_NIVAGG(SE_NBABE,J) =  [F:ABE]NIVAGG(J)
  SE_FLDAGG(SE_NBABE,J) =  [F:ABE]FLDAGG(J)
 Next J
Endif
Return

$LEC_TDF
##### tableau champs ABZ specifiques (S_)
Local Integer NBABZ : NBABZ = 250
Local Integer S_NBABZ
Local Char    S_CODABF(GLONABF)(0..NBABZ)
Local Char    S_CODFLD(GLONAVA)(0..NBABZ)
Local Integer S_NUMFLD(0..NBABZ)
Local Integer S_INTFLD(0..NBABZ)
Local Char    S_INTVALFLD(60)(0..NBABZ)
Local Integer S_INTSSC(0..NBABZ)
Local Char    S_INTVALSSC(60)(0..NBABZ)
Local Char    S_CODTYP(GLONATY)(0..NBABZ)
Local Char    S_TYPDAT(10)(0..NBABZ)
Local Decimal S_LNGFLD(0..NBABZ)
Local Integer S_MENLOC(0..NBABZ)
Local Integer S_TABDIV(0..NBABZ)
Local Char    S_ACTFLD(GLONACV)(0..NBABZ)
Local Integer S_TYPFLD(0..NBABZ)
Local Integer S_TYPOPE(0..NBABZ)
Local Integer S_TUNNEL(0..NBABZ)

##### tableau champs ABZ pacth (P_)
Local Integer P_NBABZ
Local Char    P_CODABF(GLONABF)(0..NBABZ)
Local Char    P_CODFLD(GLONAVA)(0..NBABZ)
Local Integer P_INTFLD(0..NBABZ)
Local Char    P_INTVALFLD(60)(0..NBABZ)
Local Integer P_INTSSC(0..NBABZ)
Local Char    P_INTVALSSC(60)(0..NBABZ)
Local Char    P_CODTYP(GLONATY)(0..NBABZ)
Local Char    P_TYPDAT(10)(0..NBABZ)
Local Decimal P_LNGFLD(0..NBABZ)
Local Integer P_MENLOC(0..NBABZ)
Local Integer P_TABDIV(0..NBABZ)
Local Char    P_ACTFLD(GLONACV)(0..NBABZ)
Local Integer P_TYPFLD(0..NBABZ)
Local Integer P_TYPOPE(0..NBABZ)
Local Integer P_TUNNEL(0..NBABZ)

##### tableau des index
Local Integer NBABX : NBABX = 60
Local Integer SX_NBABX
Local Char    SX_CODABF(GLONABF)(0..NBABX)
Local Char    SX_EXPIND(80)(0..NBABX)
Local Char    SX_ACTIND(GLONACV)(0..NBABX)

##### tableau des liens ABK
Local Integer NBABK :  NBABK = 200
Local Integer SK_NBABK
Local Char    SK_CODABF(GLONABF)(0..NBABK)
Local Char    SK_CODLNK(GLONABI)(0..NBABK)
Local Char    SK_EXPLNK(80)(0..NBABK)
Local Integer SK_OPTJNT(0..NBABK)
Local Integer SK_TYPJNT(0..NBABK)
Local Char    SK_CLE(110)(0..NBABK)
Local Integer SK_INTLNK(0..NBABZ)
Local Char    SK_INTVALLNK(60)(0..NBABZ)
Local Integer SK_INTCOMP(0..NBABZ)
Local Char    SK_INTVALCOMP(60)(0..NBABZ)
Local Char    LIENS(80)
Local Char    LIENS1(80)(0..20)
Local Integer ACT,I

#### tableau des aggregats ABE specifiques
Local Integer NBABE : NBABE = 20
Local Integer SE_NBABE
Local Char    SE_CODABF(GLONABF)(0..NBABE)  : #  "Tables de faits"
Local Char    SE_CODAGG(10)(0..NBABE)       : #  "Nom"
Local Char    SE_ACTAGG(GLONACV)(0..NBABE)  : #  "Code activitÃ©"
Local Integer SE_NBRAGD(0..NBABE)           : #  "Nb dimensions"
Local Integer SE_TYPAGG(0..NBABE,0..dim([F:ABE]TYPAGG))           : #  "Type dimension"
Local Char    SE_DIMAGG(GLONABI)(0..NBABE,0..dim([F:ABE]TYPAGG))  : #  "Dimension"
Local Char    SE_LNKAGG(80)(0..NBABE,0..dim([F:ABE]TYPAGG))       : #  "Champs"
Local Integer SE_NIVAGG(0..NBABE,0..dim([F:ABE]TYPAGG))           : #  "Niveau d'agrÃ©gation"
Local Char    SE_FLDAGG(GLONAVA)(0..NBABE,0..dim([F:ABE]TYPAGG))  : #  "Nom du champ"
Local Integer SE_NBRAGI(0..NBABE)           : #  "Nb index"
Local Char    SE_INDAGG(80)(0..NBABE)       : #  "Index"

### Remplissage tableau des champs ABZ specifiques
S_NBABZ = 0
For [ABZ]ABZ0 Where CODABF=NOMOBJ
 If [F:ABZ]ACTFLD>="X" & !find([F:ABZ]ACTFLD,ACTIV(1..NBACT))
  S_NBABZ +=1
  S_CODABF(S_NBABZ) =[F:ABZ]CODABF
  S_CODFLD(S_NBABZ) = [F:ABZ]CODFLD
  S_NUMFLD(S_NBABZ) = [F:ABZ]NUMFLD
  S_INTFLD(S_NBABZ) = [F:ABZ]INTFLD
  S_INTVALFLD(S_NBABZ) =[F:ABZ]INTVALFLD
  S_INTSSC(S_NBABZ) = [F:ABZ]INTSSC
  S_INTVALSSC(S_NBABZ) =[F:ABZ]INTVALSSC
  S_CODTYP(S_NBABZ) =[F:ABZ]CODTYP
  S_TYPDAT(S_NBABZ) =[F:ABZ]TYPDAT
  S_LNGFLD(S_NBABZ) =[F:ABZ]LNGFLD
  S_MENLOC(S_NBABZ) =[F:ABZ]MENLOC
  S_TABDIV(S_NBABZ) =[F:ABZ]TABDIV
  S_ACTFLD(S_NBABZ) =[F:ABZ]ACTFLD
  S_TYPFLD(S_NBABZ) =[F:ABZ]TYPFLD
  S_TYPOPE(S_NBABZ) =[F:ABZ]TYPOPE
  S_TUNNEL(S_NBABZ) =[F:ABZ]TUNNEL
 Endif
Next

### Remplissage tableau des index ABX specifiques
SX_NBABX = 0
For [ABX]ABX0 Where CODABF = NOMOBJ
 If [F:ABX]ACTIND>="X" & !find([F:ABX]ACTIND,ACTIV(1..NBACT))
  SX_NBABX += 1
  SX_CODABF(SX_NBABX) = [F:ABX]CODABF
  SX_EXPIND(SX_NBABX) = [F:ABX]EXPIND
  SX_ACTIND(SX_NBABX) = [F:ABX]ACTIND
 Endif
Next ABX

### Remplissage tableau des liens ABK specifiques
SK_NBABK = 0
For [ABK]ABK0 Where CODABF = NOMOBJ
 Gosub VERIF_LIENS
 If !ACT
  SK_NBABK += 1
  SK_CODABF(SK_NBABK)    = [F:ABK]CODABF
  SK_CODLNK(SK_NBABK)    = [F:ABK]CODLNK
  SK_EXPLNK(SK_NBABK)    = [F:ABK]EXPLNK
  SK_OPTJNT(SK_NBABK)    = [F:ABK]OPTJNT
  SK_TYPJNT(SK_NBABK)    = [F:ABK]TYPJNT
  SK_CLE(SK_NBABK)       = [F:ABK]CODLNK+"~"+[F:ABK]EXPLNK
  SK_INTLNK(SK_NBABK)    = [F:ABK]INTLNK
  SK_INTVALLNK(SK_NBABK) = [F:ABK]INTVALLNK
  SK_INTCOMP(SK_NBABK)    = [F:ABK]INTCOMP
  SK_INTVALCOMP(SK_NBABK) = [F:ABK]INTVALCOMP
 Endif
Next ABX

### Remplissage tableau AGG specifiques
SE_NBABE = 0
For [ABE]ABE0 Where CODABF=NOMOBJ
 If [F:ABE]ACTAGG>="X" & !find([F:ABE]ACTAGG,ACTIV(1..NBACT))
  SE_NBABE += 1
  SE_CODABF(SE_NBABE) =  [F:ABE]CODABF
  SE_CODAGG(SE_NBABE) =  [F:ABE]CODAGG
  SE_ACTAGG(SE_NBABE) =  [F:ABE]ACTAGG
  SE_NBRAGI(SE_NBABE) =  [F:ABE]NBRAGI
  SE_INDAGG(SE_NBABE) =  [F:ABE]INDAGG
  SE_NBRAGD(SE_NBABE) =  [F:ABE]NBRAGD
  For J=0 To dim([F:ABE]TYPAGG)-1
   SE_TYPAGG(SE_NBABE,J) =  [F:ABE]TYPAGG(J)
   SE_DIMAGG(SE_NBABE,J) =  [F:ABE]DIMAGG(J)
   SE_LNKAGG(SE_NBABE,J) =  [F:ABE]LNKAGG(J)
   SE_NIVAGG(SE_NBABE,J) =  [F:ABE]NIVAGG(J)
   SE_FLDAGG(SE_NBABE,J) =  [F:ABE]FLDAGG(J)
  Next J
 Endif
Next ABE
Return

$VERIF_LIENS
LIENS = [F:ABK]EXPLNK
I=0 : ACT =1
While instr(0,LIENS,";")
 LIENS1(I) = left$(LIENS,instr(0,LIENS,";")-1)
 LIENS     = right$(LIENS,instr(0,LIENS,";")+1)
 I+=1
Wend
LIENS1(I) = LIENS
For J=0 To I
 Read [ABZ]ABZ1 = NOMOBJ;LIENS1(I)
 If !fstat & [F:ABZ]ACTFLD>="X" & !find([F:ABZ]ACTFLD,ACTIV(1..NBACT))
  ACT =0
  Break
 Endif
Next J
Return

$ECR_ABF
### Ecritures champs ABZ
Delete [ABZ] Where CODABF=NOMOBJ
If fstat=1
 GOK = 0 : ER = 99 : ERFIC = "ABITABFLD"-NOMOBJ : Return
Endif
## Ajout champ spé a la bonne place
For J=1 To S_NBABZ
  Insa S_NUMFLD(J)+1,1  P_CODABF,P_CODFLD,P_INTFLD,P_INTVALFLD,P_INTSSC,P_INTVALSSC,P_CODTYP,P_TYPDAT,P_LNGFLD,P_MENLOC,P_TABDIV,P_ACTFLD,P_TYPFLD,P_TYPOPE,P_TUNNEL
  P_CODABF(S_NUMFLD(J)+1) = S_CODABF(J)
  P_CODFLD(S_NUMFLD(J)+1) = S_CODFLD(J)
  P_INTFLD(S_NUMFLD(J)+1) = S_INTFLD(J)
  P_INTVALFLD(S_NUMFLD(J)+1) = S_INTVALFLD(J)
  P_INTSSC(S_NUMFLD(J)+1) = S_INTSSC(J)
  P_INTVALSSC(S_NUMFLD(J)+1) = S_INTVALSSC(J)
  P_CODTYP(S_NUMFLD(J)+1) = S_CODTYP(J)
  P_TYPDAT(S_NUMFLD(J)+1) = S_TYPDAT(J)
  P_LNGFLD(S_NUMFLD(J)+1) = S_LNGFLD(J)
  P_MENLOC(S_NUMFLD(J)+1) = S_MENLOC(J)
  P_TABDIV(S_NUMFLD(J)+1) = S_TABDIV(J)
  P_ACTFLD(S_NUMFLD(J)+1) = S_ACTFLD(J)
  P_TYPFLD(S_NUMFLD(J)+1) = S_TYPFLD(J)
  P_TYPOPE(S_NUMFLD(J)+1) = S_TYPOPE(J)
  P_TUNNEL(S_NUMFLD(J)+1) = S_TUNNEL(J)
  P_NBABZ +=1
Next
## Ecriture des champs
I=0
For K=0 To P_NBABZ
 If P_CODFLD(K)<> ""
  I+=1
  [F:ABZ]CODABF = P_CODABF(K)
  [F:ABZ]NUMFLD = I
  [F:ABZ]CODFLD = P_CODFLD(K)
  [F:ABZ]INTFLD = P_INTFLD(K)
  [F:ABZ]INTVALFLD = P_INTVALFLD(K)
  [F:ABZ]INTSSC = P_INTSSC(K)
  [F:ABZ]INTVALSSC = P_INTVALSSC(K)
  [F:ABZ]CODTYP = P_CODTYP(K)
  [F:ABZ]TYPDAT = P_TYPDAT(K)
  [F:ABZ]LNGFLD = P_LNGFLD(K)
  [F:ABZ]MENLOC = P_MENLOC(K)
  [F:ABZ]TABDIV = P_TABDIV(K)
  [F:ABZ]ACTFLD = P_ACTFLD(K)
  [F:ABZ]TYPFLD = P_TYPFLD(K)
  [F:ABZ]TYPOPE = P_TYPOPE(K)
  [F:ABZ]TUNNEL = P_TUNNEL(K)
  Write [ABZ]
  If fstat
   GOK = 0 : ER = 99 : ERFIC = "ABITABFLD"-NOMOBJ : Break
  Endif
 Endif
Next K
If GOK = 0 : Return : Endif
#### Ecriture index
Delete [ABX] Where CODABF=NOMOBJ
If fstat=1
 GOK = 0 : ER = 99 : ERFIC = "ABITABIND"-NOMOBJ : Return
Endif
For K=1 To SX_NBABX
 [F:ABX]CODABF  = SX_CODABF(K)
 [F:ABX]NUMIND  = K
 [F:ABX]EXPIND  = SX_EXPIND(K)
 [F:ABX]ACTIND  = SX_ACTIND(K)
 Write [ABX]
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ABITABIND"-NOMOBJ : Break
 Endif
Next K
If GOK = 0 : Return : Endif
#### Ecriture Liens
Delete [ABK] Where CODABF=NOMOBJ
If fstat=1
 GOK = 0 : ER = 99 : ERFIC = "ABITABLNK"-NOMOBJ : Return
Endif
For K=1 To SK_NBABK
 [F:ABK]CODABF    = SK_CODABF(K)
 [F:ABK]NUMLNK    = K
 [F:ABK]CODLNK    = SK_CODLNK(K)
 [F:ABK]EXPLNK    = SK_EXPLNK(K)
 [F:ABK]OPTJNT    = SK_OPTJNT(K)
 [F:ABK]TYPJNT    = SK_TYPJNT(K)
 [F:ABK]INTLNK    = SK_INTLNK(K)
 [F:ABK]INTVALLNK = SK_INTVALLNK(K)
 [F:ABK]INTCOMP    = SK_INTCOMP(K)
 [F:ABK]INTVALCOMP = SK_INTVALCOMP(K)
 Write [ABK]
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ABITABLNK"-NOMOBJ : Break
 Endif
Next K
If GOK = 0 : Return : Endif
#### Ecriture aggregats
Delete [ABE] Where CODABF=NOMOBJ
If fstat=1
 GOK = 0 : ER = 99 : ERFIC = "ABITABAGG"-NOMOBJ : Return
Endif
For K=1 To SE_NBABE
 [F:ABE]NUMAGG = K
 [F:ABE]CODABF = SE_CODABF(K)
 [F:ABE]CODAGG = SE_CODAGG(K)
 [F:ABE]ACTAGG = SE_ACTAGG(K)
 [F:ABE]NBRAGI = SE_NBRAGI(K)
 [F:ABE]INDAGG = SE_INDAGG(K)
 [F:ABE]NBRAGD = SE_NBRAGD(K)
 For J=0 To dim([F:ABE]TYPAGG)-1
  [F:ABE]TYPAGG(J) = SE_TYPAGG(K,J)
  [F:ABE]DIMAGG(J) = SE_DIMAGG(K,J)
  [F:ABE]LNKAGG(J) = SE_LNKAGG(K,J)
  [F:ABE]NIVAGG(J) = SE_NIVAGG(K,J)
  [F:ABE]FLDAGG(J) = SE_FLDAGG(K,J)
 Next J
 Write [ABE]
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ABITABAGG"-NOMOBJ : Break
 Endif
Next K
If GOK = 0 : Return : Endif
Return

######################################################
## Intégration d'une dimension
######################################################

$DIMENSION
If !func AFNC.ACTIVDOS(APPLI,"ABI")
 Gosub FIN_OBJ From PATCH
 Return
Endif
Local File =APPLI+".ABIDIM"    [ABI]
Local File =APPLI+".ABIDIMFLD" [ABJ]
Read [ABI]ABI0 = NOMOBJ
If fstat
 NEWOBJ = 1
 Raz [F:ABI]
Elsif [F:ABI]CODACT>="X" & !find([F:ABI]CODACT,ACTIV(1..NBACT))
 Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spécifique
 Gosub FIN_OBJ From PATCH
 Goto FIN_ABI
Else
 NEWOBJ = 0
Endif
If TYPENR=2 :#SCM deletion
 Call DEBTRANS From GLOCK
 Gosub TR_ABI
Elsif TYPENR=-2 :#SCM deletion
 Call DEBTRANS From GLOCK
 Gosub DEL_ABI
 Gosub FIN_OBJ From PATCH
Endif
$FIN_ABI
Close Local File [ABI],[ABJ]
Return

$TR_ABI
Trbegin [ABI],[ABJ]
 Gosub LECDIM
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Variable
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "ABI"   : Gosub ABI1
     When "ABJ"   : Gosub ABI2
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
 Gosub ECR_DIM
Commit

## Validation d'une dimension
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ABI",[ABI]CODDIM,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif

Gosub SAV_OPENI From PATCH
# Dans l'appli X3 , on ne valide que les objets des modules Superviseur, tronc commun, développement
If APPLI<>GDOSX3
 Call VALIDATION(NOMOBJ,APPLI,1) From SUBABI
Endif
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
Gosub REST_OPENI From PATCH
Return


$DEL_ABI
Trbegin [ABI],[ABJ]
 Delete [ABJ] Where CODDIM=NOMOBJ
 Delete [ABI] Where CODDIM=NOMOBJ
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ABIDIM"-NOMOBJ : Return
 Else
 Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ABI",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ

Return

$ABI1
FICHIER = "ABIDIM" : ABR = "ABI"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If !NEWOBJ
   If find(VARIA,"TYPMAJ") and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0)
    OK = 0
   Endif
   If VARIA="TRTSPE"
    If [F:ABI]TRTSPE<>"" & TYPPTC<>3
     OK = 0
    Endif
   Elsif VARIA="TRTSPV"
    If [F:ABI]TRTSPV<>""& TYPPTC<>4
     OK = 0
    Endif
   Endif
  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If dim([F:ABI]MODULE)>0
 MODOBJ = max(1,[F:ABI]MODULE)
 If [F:ADS]MODULE(MODOBJ-1)<>2
  OKOBJ = 0 : Return
 Endif
Endif
If NEWOBJ
 Write [ABI]
Else
 Rewrite [ABI]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ABIDIM" : Return
Endif

Return

$ABI2
FICHIER = "ABIDIMFLD" : ABR = "ABJ"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If !find([F:ABJ]FLDDIM,SJ_FLDDIM(0..SJ_NBABJ))
 SJ_NBABJ += 1
 SJ_CODDIM(SJ_NBABJ) = [F:ABJ]CODDIM
 SJ_FLDDIM(SJ_NBABJ) = [F:ABJ]FLDDIM
 SJ_INTDIM(SJ_NBABJ) = [F:ABJ]INTDIM
 SJ_INTVALDIM(SJ_NBABJ) = [F:ABJ]INTVALDIM
 SJ_ACTDIM(SJ_NBABJ) = [F:ABJ]ACTDIM
 SJ_CODTYP(SJ_NBABJ) = [F:ABJ]CODTYP
 SJ_TYPDAT(SJ_NBABJ) = [F:ABJ]TYPDAT
 SJ_MENLOC(SJ_NBABJ) = [F:ABJ]MENLOC
 SJ_TABDIV(SJ_NBABJ) = [F:ABJ]TABDIV
 SJ_TYPFLD(SJ_NBABJ) = [F:ABJ]TYPFLD
 SJ_DIMFAT(SJ_NBABJ) = [F:ABJ]DIMFAT
 SJ_DIMINT(SJ_NBABJ) = [F:ABJ]DIMINT
 SJ_DIMVALINT(SJ_NBABJ) = [F:ABJ]DIMVALINT
 SJ_DIMFLD(SJ_NBABJ) = [F:ABJ]DIMFLD
 SJ_FLDORG(SJ_NBABJ) = [F:ABJ]FLDORG
 SJ_FLDLIE(SJ_NBABJ) = [F:ABJ]FLDLIE
 SJ_LNG(SJ_NBABJ)    = [F:ABJ]LNG
 SJ_TUNNEL(SJ_NBABJ) = [F:ABJ]TUNNEL
 SJ_AUTO(SJ_NBABJ)   = [F:ABJ]AUTO
 SJ_AUTOEVAL(SJ_NBABJ) = [F:ABJ]AUTOEVAL
 SJ_OPTJNT(SJ_NBABJ) = [F:ABJ]OPTJNT
Endif
Return

$LECDIM
#### Tableau des champ specifiques ABJ
Local Integer NBABJ : NBABJ = 200
Local Integer SJ_NBABJ
Local Char    SJ_CODDIM(GLONABI)(0..NBABJ)
Local Char    SJ_FLDDIM(GLONAVA)(0..NBABJ)
Local Integer SJ_INTDIM(0..NBABJ)
Local Char    SJ_INTVALDIM(60)(0..NBABJ)
Local Char    SJ_ACTDIM(GLONACV)(0..NBABJ)
Local Integer SJ_LNG(0..NBABJ)
Local Integer SJ_TUNNEL(0..NBABJ)
Local Char    SJ_CODTYP(GLONATY)(0..NBABJ)
Local Char    SJ_TYPDAT(10)(0..NBABJ)
Local Integer SJ_MENLOC(0..NBABJ)
Local Integer SJ_TABDIV(0..NBABJ)
Local Integer SJ_TYPFLD(0..NBABJ)
Local Char    SJ_DIMFAT(GLONABI)(0..NBABJ)
Local Integer SJ_DIMINT(0..NBABJ)
Local Char    SJ_DIMVALINT(60)(0..NBABJ)
Local Char    SJ_DIMFLD(GLONAVA)(0..NBABJ)
Local Char    SJ_FLDORG(250)(0..NBABJ)
Local Char    SJ_FLDLIE(GLONAVA)(0..NBABJ)
Local Integer SJ_AUTO(0..NBABJ)
Local Char    SJ_AUTOEVAL(60)(0..NBABJ)
Local Integer SJ_OPTJNT(0..NBABJ)

# Remplissage
SJ_NBABJ = 0
For [ABJ]ABJ0 Where CODDIM=NOMOBJ
 If [F:ABJ]ACTDIM>="X" & !find([F:ABJ]ACTDIM,ACTIV(1..NBACT))
  SJ_NBABJ += 1
  SJ_CODDIM(SJ_NBABJ) = [F:ABJ]CODDIM
  SJ_FLDDIM(SJ_NBABJ) = [F:ABJ]FLDDIM
  SJ_INTDIM(SJ_NBABJ) = [F:ABJ]INTDIM
  SJ_INTVALDIM(SJ_NBABJ) = [F:ABJ]INTVALDIM
  SJ_ACTDIM(SJ_NBABJ) = [F:ABJ]ACTDIM
  SJ_CODTYP(SJ_NBABJ) = [F:ABJ]CODTYP
  SJ_TYPDAT(SJ_NBABJ) = [F:ABJ]TYPDAT
  SJ_MENLOC(SJ_NBABJ) = [F:ABJ]MENLOC
  SJ_TABDIV(SJ_NBABJ) = [F:ABJ]TABDIV
  SJ_TYPFLD(SJ_NBABJ) = [F:ABJ]TYPFLD
  SJ_DIMFAT(SJ_NBABJ) = [F:ABJ]DIMFAT
  SJ_DIMINT(SJ_NBABJ) = [F:ABJ]DIMINT
  SJ_DIMVALINT(SJ_NBABJ) = [F:ABJ]DIMVALINT
  SJ_DIMFLD(SJ_NBABJ) = [F:ABJ]DIMFLD
  SJ_FLDORG(SJ_NBABJ) = [F:ABJ]FLDORG
  SJ_FLDLIE(SJ_NBABJ) = [F:ABJ]FLDLIE
  SJ_LNG(SJ_NBABJ)    = [F:ABJ]LNG
  SJ_TUNNEL(SJ_NBABJ) = [F:ABJ]TUNNEL
  SJ_AUTO(SJ_NBABJ)   = [F:ABJ]AUTO
  SJ_AUTOEVAL(SJ_NBABJ) = [F:ABJ]AUTOEVAL
  SJ_OPTJNT(SJ_NBABJ) = [F:ABJ]OPTJNT
 Endif
Next ABJ
Return

$ECR_DIM
#### Ecriture champ ABJ
Delete [ABJ] Where CODDIM=NOMOBJ
If fstat=1
 GOK = 0 : ER = 99 : ERFIC = "ABIDIMFLD"-NOMOBJ : Return
Endif
For K=1 To SJ_NBABJ
 [F:ABJ]CODDIM =SJ_CODDIM(K)
 [F:ABJ]FLDDIM =SJ_FLDDIM(K)
 [F:ABJ]INTDIM =SJ_INTDIM(K)
 [F:ABJ]INTVALDIM =SJ_INTVALDIM(K)
 [F:ABJ]ACTDIM =SJ_ACTDIM(K)
 [F:ABJ]CODTYP =SJ_CODTYP(K)
 [F:ABJ]TYPDAT =SJ_TYPDAT(K)
 [F:ABJ]MENLOC =SJ_MENLOC(K)
 [F:ABJ]TABDIV =SJ_TABDIV(K)
 [F:ABJ]TYPFLD =SJ_TYPFLD(K)
 [F:ABJ]DIMFAT =SJ_DIMFAT(K)
 [F:ABJ]DIMINT =SJ_DIMINT(K)
 [F:ABJ]DIMVALINT =SJ_DIMVALINT(K)
 [F:ABJ]DIMFLD =SJ_DIMFLD(K)
 [F:ABJ]FLDORG =SJ_FLDORG(K)
 [F:ABJ]FLDLIE =SJ_FLDLIE(K)
 [F:ABJ]LNG    =SJ_LNG(K)
 [F:ABJ]TUNNEL =SJ_TUNNEL(K)
 [F:ABJ]AUTO   =SJ_AUTO(K)
 [F:ABJ]AUTOEVAL =SJ_AUTOEVAL(K)
 [F:ABJ]OPTJNT =SJ_OPTJNT(K)
 [F:ABJ]NUMDIM    = K
 Write [ABJ]
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ABIDIMFLD"-NOMOBJ : Break
 Endif
Next K
Return

######################################################
## Intégration d'une règle de synchro
#####################################################

$SYNCHRO
If !func AFNC.ACTIVDOS(APPLI,"ABI")
 Gosub FIN_OBJ From PATCH
 Return
Endif
Local File =APPLI+".ABIREGORG" [ABV]
Local File =APPLI+".ABIREGDES" [ABY]
Read [ABV]ABV0 = NOMOBJ
If fstat
 NEWOBJ = 1
 Raz [F:ABV]
Elsif [F:ABV]CODACT>="X" & !find([F:ABV]CODACT,ACTIV(1..NBACT))
 Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spécifique
 Gosub FIN_OBJ From PATCH
 Goto FIN_ABV
Else
 NEWOBJ = 0
Endif
Call DEBTRANS From GLOCK
Gosub TR_ABV

$FIN_ABV
Close Local File [ABV],[ABY]
Return

$TR_ABV
Trbegin [ABV],[ABY]
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Variable
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "ABV"   : Gosub ABV1
     When "ABY"   : Gosub ABV2
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit

## Validation des regles de synchro
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ABV",[ABV]CODREG,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif

Gosub SAV_OPENI From PATCH
# Dans l'appli X3 , on ne valide que les objets des modules Superviseur, tronc commun, développement
If APPLI<>GDOSX3 and func AFNC.IS_VALIDATION_ENABLED(APPLI,[F:ABV]CODACT,[F:ABV]MODULE) :#SAM 120919
 Call VALIDATION(NOMOBJ,APPLI,1) From SUBABV
 Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
Endif
Gosub REST_OPENI From PATCH
Return

$ABV1
FICHIER = "ABIREGORG" : ABR = "ABV"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If !NEWOBJ and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0)
   If VARIA="TRTSPE"
    If [F:ABV]TRTSPE<>"" & TYPPTC<>3
     OK = 0
    Endif
   Elsif VARIA="TRTSPV"
    If [F:ABV]TRTSPV<>""& TYPPTC<>4
     OK = 0
    Endif
   Endif
  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If dim([F:ABV]MODULE)>0
 MODOBJ = max(1,[F:ABV]MODULE)
 If [F:ADS]MODULE(MODOBJ-1)<>2
  OKOBJ = 0 : Return
 Endif
Endif
If NEWOBJ
 Raz [ABV]ADXDOS
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ABV]CREDAT = date$
  [F:ABV]CREUSR = GUSER
  [F:ABV]UPDDAT = date$
  [F:ABV]UPDUSR = GUSER
 Endif
 Write [ABV]
Else
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ABV]UPDDAT = date$
  [F:ABV]UPDUSR = GUSER
 Endif
 Rewrite [ABV]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ABIREGORG" : Return
Endif

Delete [ABY] Where CODREG=[F:ABV]CODREG
If fstat : GOK = 0 : ER = 99 : ERFIC = "ABIREGDES"-[F:ABV]CODREG : Endif
Return
Return

$ABV2
FICHIER = "ABIREGDES" : ABR = "ABY"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
Write [ABY]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ABIREGDES" : Return
Endif
Return

######################################################
## Intégration d'un etat BO
#####################################################

$ETAT_BO
If !func AFNC.ACTIVDOS(APPLI,"ABI")
 Gosub FIN_OBJ From PATCH
 Return
Endif
Local File =APPLI+".ABIREPORT"  [ABO]
Local File =APPLI+".ABIREPORTD" [ABQ]
Local File =APPLI+".ABITRAUNV"  [ATV]
Local File =APPLI+".ABITRAUNV"  [ATV2]
Read [ABO]ABO0 = toupper(NOMOBJ)
If TYPENR=2 :#SCM deletion
 If fstat
  NEWOBJ = 1
  Raz [F:ABO]
 Elsif [F:ABO]ACV>="X" & !find([F:ABO]ACV,ACTIV(1..NBACT))
  Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spécifique
  Gosub FIN_OBJ From PATCH
  Goto FIN_ABO
 Else
  NEWOBJ = 0
 Endif
 Call DEBTRANS From GLOCK
 Gosub TR_ABO
Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_ABO
 Endif
 Gosub FIN_OBJ From PATCH
Endif

$FIN_ABO
Close Local File [ABO],[ABQ],[ATV],[ATV2]
Return

$TR_ABO
Trbegin [ABO],[ABQ]
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Variable
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "ABO"   : Gosub ABO1
     When "ABQ"   : Gosub ABO2
     When "ATV"   : Gosub ATV1
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ABO",[ABO]COD,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Return

$DEL_ABO
Trbegin [ABO],[ABQ]
 Delete [ABQ] Where COD=[L]NOMOBJ
 Delete [ABO] Curr
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ABIREPORT"-NOMOBJ : Return
 Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ABO",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

$ABO1
FICHIER = "ABIREPORT" : ABR = "ABO"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If !NEWOBJ and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0)
   If find(VARIA,"ACS")
    OK = 0
   Endif
  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If dim([F:ABO]MODULE)>0
 MODOBJ = max(1,[F:ABO]MODULE)
 If [F:ADS]MODULE(MODOBJ-1)<>2
  OKOBJ = 0 : Return
 Endif
Endif
If NEWOBJ
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ABO]CREDAT = date$
  [F:ABO]CREUSR = GUSER
  [F:ABO]UPDDAT = date$
  [F:ABO]UPDUSR = GUSER
 Endif
 Write [ABO]
Else
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ABO]UPDDAT = date$
  [F:ABO]UPDUSR = GUSER
 Endif
 Rewrite [ABO]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ABIREPORT" : Return
Endif

Delete [ABQ] Where COD=[F:ABO]COD
If fstat : GOK = 0 : ER = 99 : ERFIC = "ABIREPORTD"-[F:ABO]COD : Endif
Delete [ATV] Where ABM =[F:ABO]DATAM &  RAPORT=[F:ABO]REPCOD
If fstat : GOK = 0 : ER = 99 : ERFIC = "ABITRAUNV"-[F:ABO]COD : Endif
Return

$ABO2
FICHIER = "ABIREPORTD" : ABR = "ABQ"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
Write [ABQ]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ABIREPORTD" : Return
Endif
Return

$ATV1
FICHIER = "ABITRAUNV" : ABR = "ATV"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
# bug 100857 : i have to modify the index in the futur
Delete [ATV] Where ABM =[F:ABO]DATAM &  RAPORT=[F:ABO]REPCOD & LANTRA=[ATV]LANTRA & TEXTE=[ATV]TEXTE
If !fstat
 Write [ATV]
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ABITRAUNV" : Return
 Endif
Endif
Return

######################################################
## Intégration d'une hierarchie
#####################################################

$HIERARCHIE
If !func AFNC.ACTIVDOS(APPLI,"ABI")
 Gosub FIN_OBJ From PATCH
 Return
Endif
Local File =APPLI+".ABIHIERA"  [AHH]
Read [AHH]AHH0 = NOMOBJ
If TYPENR=2 :#SCM deletion
 If fstat
  NEWOBJ = 1
  Raz [F:AHH]
 Elsif [F:AHH]ACV>="X" & !find([F:AHH]ACV,ACTIV(1..NBACT))
  Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spécifique
  Gosub FIN_OBJ From PATCH
  Goto FIN_AHH
 Else
  NEWOBJ = 0
 Endif
 Call DEBTRANS From GLOCK
 Gosub TR_AHH
Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_AHH
 Endif
 Gosub FIN_OBJ From PATCH
Endif
$FIN_AHH
Close Local File [AHH]
Return

$TR_AHH
Trbegin [AHH]
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Variable
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "AHH"   : Gosub AHH1
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AHH",[AHH]COD,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Return

$DEL_AHH
Trbegin [AHH]
 Delete [AHH] Curr
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ABIHIERA"-NOMOBJ : Return
 Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AHH",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

$AHH1
FICHIER = "ABIHIERA" : ABR = "AHH"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If dim([F:AHH]MODULE)>0
 MODOBJ = max(1,[F:AHH]MODULE)
 If [F:ADS]MODULE(MODOBJ-1)<>2
  OKOBJ = 0 : Return
 Endif
Endif
If NEWOBJ
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:AHH]CREDAT = date$
  [F:AHH]CREUSR = GUSER
  If dim([F:AHH]CRETIM)>0 : [F:AHH]CRETIM = time  : Endif
  [F:AHH]UPDDAT = date$
  [F:AHH]UPDUSR = GUSER
  If dim([F:AHH]UPDTIM)>0 : [F:AHH]UPDTIM = time  : Endif
 Endif
 Write [AHH]
Else
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:AHH]UPDDAT = date$
  [F:AHH]UPDUSR = GUSER
  If dim([F:AHH]UPDTIM)>0 : [F:AHH]UPDTIM = time  : Endif
 Endif
 Rewrite [AHH]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ABIHIERA" : Return
Endif
Return

######################################################
## Intégration d'une condition prédéfinie
#####################################################

$COND_ABI
If !func AFNC.ACTIVDOS(APPLI,"ABI")
 Gosub FIN_OBJ From PATCH
 Return
Endif
Local Integer AII_ORD
Local File =APPLI+".ABICOND"   [AII]
Local File =APPLI+".ABICOND"   [AII2]
Read [AII]AII0 = toupper(NOMOBJ)
If TYPENR=2 :#SCM deletion
 If fstat
  NEWOBJ = 1
  Raz [F:AII]
  Read [AII2]AII1 Last
  If !fstat
   AII_ORD = [F:AII2]ORD+1
  Endif
 Elsif [F:AII]ACV>="X" & !find([F:AII]ACV,ACTIV(1..NBACT))
  Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spécifique
  Gosub FIN_OBJ From PATCH
  Goto FIN_AII
 Else
  NEWOBJ = 0
  Read [AII2]AII0 = toupper(NOMOBJ)
  If !fstat
   AII_ORD = [F:AII2]ORD
  Endif
 Endif

 Call DEBTRANS From GLOCK
 Gosub TR_AII
Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_AII
 Endif
 Gosub FIN_OBJ From PATCH
Endif

$FIN_AII
Close Local File [AII],[AII2]
Return

$TR_AII
Trbegin [AII]
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Variable
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "AII"   : Gosub AII1
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AII",[AII]COD,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Return

$DEL_AII
Trbegin [AII]
 Delete [AII] Curr
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ABICOND"-NOMOBJ : Return
 Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AII",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return


$AII1
FICHIER = "ABICOND" : ABR = "AII"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If dim([F:AII]MODULE)>0
 MODOBJ = max(1,[F:AII]MODULE)
 If [F:ADS]MODULE(MODOBJ-1)<>2
  OKOBJ = 0 : Return
 Endif
Endif
If NEWOBJ
 [F:AII]ORD = AII_ORD + 1
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:AII]CREDAT = date$
  [F:AII]CREUSR = GUSER
  If dim([F:AII]CRETIM)>0 : [F:AII]CRETIM = time  : Endif
  [F:AII]UPDDAT = date$
  [F:AII]UPDUSR = GUSER
  If dim([F:AII]UPDTIM)>0 : [F:AII]UPDTIM = time  : Endif
 Endif
 Write [AII]
Else
 [F:AII]ORD = AII_ORD
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:AII]UPDDAT = date$
  [F:AII]UPDUSR = GUSER
  If dim([F:AII]UPDTIM)>0 : [F:AII]UPDTIM = time  : Endif
 Endif
 Rewrite [AII]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ABICOND" : Return
Endif
Return

###################################################
## Intégration d'un .biar
###################################################

$BIAR
If filinfo(filpath("FIL","ADOSSIER","fde",APPLI),0)<0
 ## On ne l'installe que sur l'appli racine
 Gosub FIN_OBJ From PATCH
 Return
Endif
ER = 0
REPERT = filpath("BI","","",APPLI)
If filinfo(REPERT,0)<0
 Call ECR_TRACE("|"+mess(11,125,1)-ctrans(REPERT,"\","/"),0) From GESECRAN : # Création du répertoire
 K = instr(1,REPERT,"@")
 If K : REPERT = right$(REPERT,K+1) : Endif
 Call SYSTEME(adxmac(0),"ae_mkdir"-REPERT,"",STAT) From ORDSYS
 If filinfo(REPERT,0)<0
  Call ECR_TRACE(mess(184,124,1)+"\|"+REPERT+"|",1) From GESECRAN
  ER = 35
 Endif
Endif
If ER
 Gosub FIN_OBJ From PATCH
 Return
Endif
FICOLD = filpath("BI",NOMOBJ,"biar",APPLI)
If filinfo(FICOLD,0)>0
 FICSRC = filpath("BI",NOMOBJ,"bak",APPLI)
 Call MOVE(FICOLD,FICSRC,STAT) From ORDSYS
 If STAT : ER = 35 : Endif
Endif
If ER
 Gosub FIN_OBJ From PATCH
 Return
Endif
If dim(ISBIAMOD)>0
 If !ISBIAMOD or !find(NOMOBJ,ISBIANAM(1..ISBIAMOD))
  ISBIAMOD += 1
  ISBIANAM(ISBIAMOD) = NOMOBJ
 Endif
Endif
Rdseq NOCT
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
SAVPOS = adxseek(0)
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
FICSRC = filpath("BI",NOMOBJ,"biar",APPLI)
Openi FICPATCH , SAVPOS
Openo FICSRC , 0
Repeat
 NB = dim(BUFFER)
 If NOCT>NB
  Getseq NB , BUFFER
  Putseq NB , BUFFER
  NOCT -= NB
 Else
  Getseq NOCT , BUFFER
  Putseq NOCT , BUFFER
  NOCT = 0
 Endif
Until NOCT=0
Repeat
 Rdseq CHAINE
Until fstat or CHAINE=string$(10,"*")
If fstat
 ER = 33 : Return
Endif
Openo
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Gosub LIRE From PATCH
If !find(TYPENR,6,7)
 ER = 34 : Return
Endif
Return

####################################################################################
## Mise à jour du référentiel BO à partir des .biar
####################################################################################
Subprog MAJBIARV3(APPLI,BIAR,STAT,TRACE,MESSAGE)
Value    Char    APPLI , BIAR
Variable Char    STAT
Variable Char    TRACE
Variable Char    MESSAGE
If GSERVEUR
 TRACE = func SERVSYS.GET_FILE_SERVEUR("tra")   # Issue X3-70499 - 2018-03-05 by CCC : whole path => with extension file
Elsif GTRACE=""
 Call OUVRE_TRACE(mess(108,148,1)) From LECFIC : # Import ficher biar
 TRACE = filpath("TRA",GTRACE,"tra")
Else
 TRACE = filpath("TRA",GTRACE,"tra")
Endif
# penser a trier les biar pour mettre celui de la version en premier.
Call IMPBIAR(APPLI,BIAR,2,2,TRACE) From ABIIMPETA
MESSAGE = "OK"
STAT    = "1"
End


Subprog MAJBIAR(APPLI,BIAR,TRACE)
Value    Char APPLI , BIAR
Variable Char TRACE
If GSERVEUR
 TRACE = func SERVSYS.GET_FILE_SERVEUR("tra")   # Issue X3-70499 - 2018-03-05 by CCC : whole path => with extension file
Elsif GTRACE=""
 Call OUVRE_TRACE(mess(108,148,1)) From LECFIC : # Import ficher biar
 TRACE = filpath("TRA",GTRACE,"tra")
Else
 TRACE = filpath("TRA",GTRACE,"tra")
Endif
Call IMPBIAR(APPLI,BIAR,2,2,TRACE) From ABIIMPETA
End

Subprog MAJBIAR2(APPLI,BIAR,TRACE)
Value Char APPLI , BIAR
Variable Char TRACE
Local Char    PATH(GDIMFIC) , SERVEUR(250) , PORT(250) , MACHINE(250) , REPADX(GDIMFIC)
Local Char    USR(50) , PWD(200) , CHAINE(250) , ORDSYS(250)(1..2) , ORDRE(250)
Local Clbfile ORDSYS_CMD(3) , ORDSYS_TRA(3)
Local Char    FIC(30)(1..100) , FICHIER(GDIMFIC) , FICDEST(GDIMFIC) , CMD64(100),FILEPROPERTIE(GDIMFIC)
Local Integer I , J , K , ERR , NBFIC, MAC64
Local Char    MESSAGE(250), CMDTXT(250) , ORDERR(250)
Local Char BOVERSION(80)
If APPLI="" : APPLI = GDOSX3 : Endif
If GSERVEUR
 TRACE = func SERVSYS.GET_FILE_SERVEUR("tra")   # Issue X3-70499 - 2018-03-05 by CCC : whole path => with extension file
Elsif GTRACE=""
 Call OUVRE_TRACE(mess(108,148,1)) From LECFIC : # Import ficher bia
 TRACE = filpath("TRA",GTRACE,"tra")
Else
 TRACE = filpath("TRA",GTRACE,"tra")
Endif
If APPLI=""
 Call ECR_TRACE("not folder",1) From GESECRAN
 End
Endif
Call RECHPROP("busobj.adxadmin.port",PORT,ERR) From INTRUTILA
If PORT="" or ERR
 Call ECR_TRACE("busobj.adxadmin.port not available",1) From GESECRAN
 End
Endif
Call RECHPROP("component.busobj.servername",SERVEUR,ERR) From INTRUTILA
If SERVEUR="" or ERR
 Call ECR_TRACE("component.busobj.servername not available",1) From GESECRAN
 End
Endif
MACHINE = SERVEUR+":"+PORT
Call VARADX("ADXDIR",MACHINE,REPADX) From ADXD
If REPADX=""
 Call ECR_TRACE("ADXDIR in"-MACHINE-"not available",1) From GESECRAN
 End
Endif
REPADX = filpath(REPADX,"tmp","","","",MACHINE)
REPADX = right$(REPADX,instr(1,REPADX,"@")+1)
Call RECHPROP("busobj.files.path",PATH,ERR) From INTRUTILA
If PATH="" or ERR
 Call ECR_TRACE("busobj.files.path not available",1) From GESECRAN
 End
Endif
Call RECHPROP("busobj.cms.port",PORT,ERR) From INTRUTILA
If PORT="" or ERR
 Call ECR_TRACE("busobj.cms.port not available",1) From GESECRAN
 End
Endif
Call RECHPROP("busobj.login.adminusr",USR,ERR) From INTRUTILA
If USR="" or ERR
 Call ECR_TRACE("busobj.login.adminusr not available",1) From GESECRAN
 End
Endif
Call RECHPROP("busobj.login.adminpwd",PWD,ERR) From INTRUTILA
If PWD="" or ERR
 Call ECR_TRACE("busobj.login.adminpwd not available",1) From GESECRAN
 End
Endif
Call DECRYPTO(PWD,CHAINE) From GESUSER
PWD = CHAINE
Call GETBOVERSION(BOVERSION) From INTRUTILA
Call VERIF_MAC64(MAC64)
If MAC64
 CMD64 = "%Windir%\SysWOW64\CMD.exe /c "
Else
 Raz CMD64
Endif
ORDSYS(1) = filpath(REPADX,"file_cmd"+num$(adxuid(1)),"cmd","","",MACHINE)
ORDSYS(2) = filpath(REPADX,"log_cmd"+num$(adxuid(1)),"log","","",MACHINE)
ORDERR    = filpath(REPADX,"log_cmd"+num$(adxuid(1)),"err","","",MACHINE)
TRACE = ORDSYS(2)

If BOVERSION="R4"
 ORDSYS_CMD = '"'+PATH+'\SAP BusinessObjects Enterprise XI 4.0\win32_x86\jre\bin\java.exe" -jar'
 ORDSYS_CMD -= '"'+PATH+'\SAP BusinessObjects Enterprise XI 4.0\java\lib\biarengine.jar"'
Elsif BOVERSION="R3"
 ORDSYS_CMD = '"'+PATH+'\javasdk\bin\java.exe" -jar'
 ORDSYS_CMD -= '"'+PATH+'\common\4.0\java\lib\biarengine.jar"'
Else
 ORDSYS_CMD = '"'+PATH+'\J2SDK1.4.2_08\bin\java.exe" -jar'
 ORDSYS_CMD -= '"'+PATH+'\common\3.5\java\lib\InstallEntSdkWrapper.jar"'
 ORDSYS_CMD -= '"'+SERVEUR+':'+PORT+'"'
 ORDSYS_CMD -= '"'+USR+'"'
 ORDSYS_CMD -= '"'+PWD+'"'
 ORDSYS_CMD -= '"secEnterprise"'
Endif
If BIAR<>""
 CHAINE = BIAR
 Gosub EXEBIAR
Else
 ORDRE = "lsadx -a"-APPLI-"BI biar"
 Call SYSTEME2(adxmac(0),ORDRE,"",NBFIC,FIC) From ORDSYS
 NBFIC = min(NBFIC,dim(FIC))
 For I=1 To NBFIC
  CHAINE = FIC(I)
  Gosub EXEBIAR
 Next I
Endif
Call MAJ_CONNEXION
End


$EXEBIAR
FICHIER = filpath("BI",CHAINE,"biar",APPLI)
If GTRACE<>""
 Call ECR_TRACE(mess(220,139,1)-":|"-FICHIER,0) From GESECRAN : # Traitement du fichier
Endif
If filinfo(FICHIER,0)<=0
 Call ECR_TRACE(mess(101,100,1)+"\|"+FICHIER+"|",1) From GESECRAN : # Fichier inexistant
Else
 FICDEST = filpath(REPADX,CHAINE,"biar","","",MACHINE)
 Call COPIE(FICHIER,FICDEST,ERR) From ORDSYS
 If ERR or filinfo(FICDEST,0)<=0
  Call ECR_TRACE(mess(184,124,1)+"\|"+FICDEST+"|",1) From GESECRAN : # Impossible de crééer le fichier
 Else
  For J=1 To 2
   If filinfo(ORDSYS(J),0)>0
    Call EFFACE(ORDSYS(J),ERR) From ORDSYS
   Endif
  Next J
  If BOVERSION>="R3"
   FILEPROPERTIE = filpath(REPADX,"Properties"+num$(adxuid(1)),"properties","","",MACHINE)
   ORDSYS_CMD -= '"'+ right$(FILEPROPERTIE ,instr(1,FILEPROPERTIE ,"@")+1)+'"'
   Openo FILEPROPERTIE ,0 Using [TR_]
   Iomode adxifs "" Using [TR_]
   Iomode adxirs chr$(13)+chr$(10) Using [TR_]
   Iomode adxium GASCII Using [TR_]
   Wrseq "importBiarLocation="+func TRANSFORM(REPADX+string$(right$(REPADX,len(REPADX))<>"\","\")+CHAINE+".biar")  Using [TR_]
   Wrseq "action=importXML"  Using [TR_]
   Wrseq "userName="           +USR  Using [TR_]
   Wrseq "password="           +PWD  Using [TR_]
   Wrseq "CMS="                +SERVEUR+':'+PORT  Using [TR_]
   Wrseq "authentication=secEnterprise"  Using [TR_]
   Openo Using [TR_]
  Endif
  If !MAC64
   Openo ORDSYS(1),0 Using [TR_]
   Iomode adxifs "" Using [TR_]
   Iomode adxirs chr$(10) Using [TR_]
   Iomode adxium GASCII Using [TR_]
   Wrseq "" Using [TR_]
   Wrseq ORDSYS_CMD ; Using [TR_]
   If BOVERSION<"R3"
    Wrseq ' 2> "'+right$(ORDERR ,instr(1,ORDERR ,"@")+1)+'"' Using [TR_]
   Else
    Wrseq ' "'+right$(FICDEST,instr(1,FICDEST,"@")+1)+'"' Using [TR_]
   Endif
   Wrseq "" Using [TR_]
   Openo Using [TR_]
  Else
   CMDTXT= filpath(REPADX,"file_cmd64_"+num$(adxuid(1)),"cmd","","",MACHINE)
   Openo CMDTXT,0 Using [TR_]
   Iomode adxifs "" Using [TR_]
   Iomode adxirs chr$(10) Using [TR_]
   Iomode adxium GASCII Using [TR_]
   Wrseq "" Using [TR_]
   Wrseq ORDSYS_CMD ; Using [TR_]
   If BOVERSION<"R3"
       Wrseq ' 2> "'+right$(ORDERR ,instr(1,ORDERR ,"@")+1)+'"' Using [TR_]
   Else
       Wrseq ' "'+right$(FICDEST,instr(1,FICDEST,"@")+1)+'"' Using [TR_]
   Endif
   Openo Using [TR_]
   Openo ORDSYS(1),0 Using [TR_]
   Iomode adxifs "" Using [TR_]
   Iomode adxirs chr$(10) Using [TR_]
   Iomode adxium GASCII Using [TR_]
   Wrseq CMD64+'"'+right$(CMDTXT,instr(1,CMDTXT,"@")+1)+'"' Using [TR_]
   Openo Using [TR_]
  Endif
  Call SYSTEME(MACHINE,ORDSYS,"f",ERR) From ORDSYS
  If GTRACE<>""
   Openi ORDSYS(2) Using [TR_]
   Iomode adxifs "" Using [TR_]
   Iomode adxirs chr$(10) Using [TR_]
   Iomode adxium GUTF8 Using [TR_]
   K = 0
   Rdseq MESSAGE Using [TR_]
   While !fstat
    K += 1
    If K=1
     If GTEST
      ORDSYS_TRA = ORDSYS_CMD-right$(FICDEST,instr(1,FICDEST,"@")+1)
      While ORDSYS_TRA<>""
       Call ECR_TRACE("|"+left$(ORDSYS_TRA,100)+"|",0) From GESECRAN
       ORDSYS_TRA = right$(ORDSYS_TRA,101)
      Wend
     Endif
    Endif
    Call ECR_TRACE("|"+MESSAGE,0) From GESECRAN
    Rdseq MESSAGE Using [TR_]
   Wend
   Openi Using [TR_]
   If BOVERSION<"R3"
    Call ECR_TRACE("|"+ORDERR ,0) From GESECRAN
    Openi ORDERR Using [TR_]
    Iomode adxifs "" Using [TR_]
    Iomode adxirs chr$(10) Using [TR_]
    Iomode adxium GUTF8 Using [TR_]
    K = 0
    Rdseq MESSAGE Using [TR_]
    While !fstat
     K += 1
     If K=1
      If GTEST
       ORDSYS_TRA = ORDSYS_CMD-right$(FICDEST,instr(1,FICDEST,"@")+1)
       While ORDSYS_TRA<>""
        Call ECR_TRACE("|"+left$(ORDSYS_TRA,100)+"|",0) From GESECRAN
        ORDSYS_TRA = right$(ORDSYS_TRA,101)
       Wend
      Endif
     Endif
     Call ECR_TRACE("|"+MESSAGE,0) From GESECRAN
     Rdseq MESSAGE Using [TR_]
    Wend
    Openi Using [TR_]
   Endif
  Endif
 Endif
Endif
Return

Subprog VERIF_MAC64(OK)
Variable Integer OK
Local Char    ORDSYS(250)(1..2),MESSAGE (250),REPADX(250),SERVEUR(250),PORT(100),MACHINEBO(250)
Local Integer ERR
Call RECHPROP("busobj.adxadmin.port",PORT,ERR) From INTRUTILA
If PORT="" or ERR
 Call ECR_TRACE("busobj.adxadmin.port not available",1) From GESECRAN
 End
Endif
Call RECHPROP("component.busobj.servername",SERVEUR,ERR) From INTRUTILA
If SERVEUR="" or ERR
 Call ECR_TRACE("component.busobj.servername not available",1) From GESECRAN
 End
Endif
MACHINEBO = SERVEUR+":"+PORT
Call VARADX("ADXDIR",MACHINEBO,REPADX) From ADXD
ORDSYS(1) = filpath(REPADX,"file64_cmd"+num$(adxuid(1)),"txt","","",MACHINEBO)
ORDSYS(2) = filpath(REPADX,"log64_cmd"+num$(adxuid(1)),"log","","",MACHINEBO)
Openo ORDSYS(1),0 Using [TR_]
Iomode adxifs "" Using [TR_]
Iomode adxirs chr$(10) Using [TR_]
Iomode adxium GASCII Using [TR_]
Wrseq 'set' Using [TR_]
Openo Using [TR_]
Call SYSTEME(MACHINEBO,ORDSYS,"f",ERR) From ORDSYS
Openi ORDSYS(2) Using [TR_]
Iomode adxifs "" Using [TR_]
Iomode adxirs chr$(10) Using [TR_]
Iomode adxium GUTF8 Using [TR_]
Rdseq MESSAGE Using [TR_]
While !fstat
 If instr(1,MESSAGE,"PROCESSOR_ARCHITECTURE")>0 : Break :  Endif
 Rdseq MESSAGE Using [TR_]
Wend
Openi Using [TR_]
If left$(vireblc(right$(MESSAGE,instr(1,MESSAGE,"=")+1),2),3) <> "x86" : OK = 1 : Else : OK = 0 : Endif
End

Subprog MAJ_CONNEXION()
Local Clbfile ORDRE(9)
Local Char    BOTOOL(250),BOFILE(250),BOMACHINE(250),BOSERV(20),REPADXDIR(250),FICPARAM(250), BOFILE(250)
Local Char    BOPWDBI(250),BOUSRBI(250),RETOUR(250)
Local Char    ORDSYS(250)(1..2) , CHAINE(250),CMD64(100),CMDTXT(250)
Local Integer STAT,MAC64
Local Char BOVERSION(80)

Call GETBOVERSION(BOVERSION) From INTRUTILA

### Recuperation des parametres du fichier solution et boworld
Call RECHPROP("busobj.tools.path",BOTOOL,STAT) From INTRUTILA
Call RECHPROP("component.busobj.servername",BOMACHINE,STAT) From INTRUTILA
Call RECHPROP("busobj.adxadmin.port",BOSERV,STAT) From INTRUTILA
Call VARADX("ADXDIR",[L]BOMACHINE+":"+[L]BOSERV,[L]REPADXDIR) From ADXD
[L]FICPARAM   = [L]REPADXDIR+'\tmp\'+'\'+'Param_install.xml'
Call RECHPROP("busobj.files.path",BOFILE,STAT) From INTRUTILA
Call RECHPROP("busobj.login.adminusr",[L]BOUSRBI,STAT) From INTRUTILA
Call INCRYPT([L]BOUSRBI,RETOUR) From INTRUTILA
[L]BOUSRBI="CRYPT:"+RETOUR
Call RECHPROP("busobj.login.adminpwd",[L]BOPWDBI,STAT) From INTRUTILA

Call VERIF_MAC64(MAC64)
If MAC64
 CMD64 = "%Windir%\SysWOW64\CMD.exe /c "
Else
 Raz CMD64
Endif

If BOVERSION>="R3"
 End
Else
 RIGHTCMD = "BI_Rights.cmd"
Endif

ORDRE =''
& + '<?xml version="1.0" encoding="utf-8"?>'
& + '<parameters>'
& +'<bo.connect.server>'+BOMACHINE+'</bo.connect.server>'
& +'<bo.connect.user>'+[L]BOUSRBI+'</bo.connect.user>'
& +'<bo.connect.passwd>'+[L]BOPWDBI+'</bo.connect.passwd>'
& +'<bo.connect.type>secEnterprise</bo.connect.type>'
& +'</parameters>'

ORDSYS(1) = [L]BOMACHINE+':'+[L]BOSERV+'@'+[L]FICPARAM
Call ECRITURE_COMMANDE(ORDSYS(1),ORDRE) From SUBATV2

ORDRE = ''
& +'"'+[L]BOTOOL+'\TOOLS\BO\'+RIGHTCMD+'" '
& +'-t "'+[L]BOTOOL+'" '
& +'-bo "'+[L]BOFILE+'" '
& +'-u "'+[L]BOTOOL+'\BO_BASE\shared\lib" '
& +'-param "'+[L]FICPARAM+'" '
& +'-logdir "'+[L]REPADXDIR+'\tmp\'+'" '
& +'-logname "'+'rights_install" '
& +'1> "'+[L]REPADXDIR+'\Tmp\'+'\'+'rights_install.out" '
& +'2> "'+[L]REPADXDIR+'\Tmp\'+'\'+'rights_install.err" '

ORDSYS(1)= [L]BOMACHINE+':'+[L]BOSERV+'@'+[L]REPADXDIR+'\tmp\'+'\rights_install.cmd'
If !MAC64
 Call ECRITURE_COMMANDE(ORDSYS(1),ORDRE) From SUBATV2
Else
 CMDTXT= [L]BOMACHINE+':'+[L]BOSERV+'@'+[L]REPADXDIR+'\tmp\'+'\CMDrights_install.cmd'
 Call ECRITURE_COMMANDE(CMDTXT,ORDRE) From SUBATV2
 ORDRE = CMD64+'"'+right$(CMDTXT,instr(1,CMDTXT,"@")+1)+'"'
 Call ECRITURE_COMMANDE(ORDSYS(1),ORDRE)  From SUBATV2
Endif
Call SYSTEME([L]BOMACHINE+':'+[L]BOSERV,ORDSYS,"f",STAT) From ORDSYS

If GTRACE<>""
 Call ECR_TRACE('',0) From GESECRAN
 Call ECR_TRACE (mess(4,139,1)-'rights_install.out'-":",0) From GESECRAN
 Call AJOUT_TRACE([L]BOMACHINE+':'+[L]BOSERV+'@'+[L]REPADXDIR+'\tmp\'+'\rights_install.out')
& From ABICREUNV
 If filinfo([L]BOMACHINE+':'+[L]BOSERV+'@'+[L]REPADXDIR+'\tmp\'+'\rights_install.err',7)>0
  Call ECR_TRACE (mess(4,139,1)-'rights_install.err'-":",0) From GESECRAN
  Call AJOUT_TRACE([L]BOMACHINE+':'+[L]BOSERV+'@'+[L]REPADXDIR+'\tmp\'+'\rights_install.err')
& From ABICREUNV
 Endif
Endif

CHAINE = 'ae_rm "'+[L]REPADXDIR+'\tmp\'+'\*_install*"'
Call SYSTEME2([L]BOMACHINE+':'+[L]BOSERV,CHAINE,"",STAT,RETOUR) From ORDSYS
End

Funprog TRANSFORM(CHAINE)
Value Char CHAINE
Local Integer I
Local Char CHAINE2(250)

I=instr(1,CHAINE,"\")
While I>0
 CHAINE2 += left$(CHAINE,I-1)+"/\\"
 CHAINE  = right$(CHAINE,I+1)
 I=instr(1,CHAINE,"\")
Wend
CHAINE2 +=CHAINE
End CHAINE2

