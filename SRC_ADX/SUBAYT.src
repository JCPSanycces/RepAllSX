#<AdxTL>@(#)6.0.0.0 $Revision$  Objet de Test site Web
######################################################################################
## Xtend:  Objet de Test Xtend 
#  Version 0001
######################################################################################
$ACTION  
#Infbox ACTION
Case ACTION
 When "INICRE"         : Gosub INICRE
 When "INIMOD"         : Gosub INIMOD
 When "LIENS"          : Gosub LIENS
 When "ANNULE"         : Gosub ANNULE
Endcase
Return

$LIENS
Call LECTEXTRA([M:AYT1]AXXRUB1,"AYTTEST","AXXRUB1",[M:AYT1]COD2,[M:AYT1]COD1) From ATEXTRA
Call LECTEXTRA([M:AYT1]AXXRUB2,"AYTTEST","AXXRUB2",[M:AYT1]COD2,[M:AYT1]COD1) From ATEXTRA
Return

$INICRE
$INIMOD
Call MAJTEXTRA ([M:AYT1]AXXRUB1,"AYTTEST","AXXRUB1",[M:AYT1]COD2,[M:AYT1]COD1) From ATEXTRA
Call MAJTEXTRA ([M:AYT1]AXXRUB2,"AYTTEST","AXXRUB2",[M:AYT1]COD2,[M:AYT1]COD1) From ATEXTRA
[F:AYT]TYPBLB = 3
Return

$ANNULE
Call SUPTEXTRA("AYTTEST","AXXRUB1",[M:AYT1]COD2,[M:AYT1]COD1) From ATEXTRA
Call SUPTEXTRA("AYTTEST","AXXRUB2",[M:AYT1]COD2,[M:AYT1]COD1) From ATEXTRA
Return


######################################################################################
## Ecran AYT1
######################################################################################

Subprog AS_CREDAT(VALEUR)
Variable Date    VALEUR
End

Subprog AS_CREHEURE(VALEUR)
Variable Char    VALEUR()
End

Subprog AS_STATUT(VALEUR)
Variable Integer VALEUR
For WI=3 To 19 :GMENLOC(WI)=1 : Next
End

