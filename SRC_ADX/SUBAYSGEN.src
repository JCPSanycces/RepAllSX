#<AdxTL>@(#)5.0.0.0 $Revision$
Call AYT_DEBUG From AYTUTIA   # Activation debug java
DOSORG = "XTEND"
FCYORG = "ZSITE2"
Integer RET
Local Char TIM(14)
TIM = func AYTGEN.TIMESTAMP
Call XMLGEN(DOSORG, FCYORG, TIM, "","", RET)
End


######################################################################################
## Xtend: GĂŠnĂŠration fiche site
#  Version 0001
######################################################################################
#    FCYGEN 
######################################################################################
Subprog XMLGEN(DOSORG, FCYORG, TIMSTP, OPTION, ELTCOD,RET)
Value Char DOSORG        #     sodaix01:5000@XTEND ou XTEND
Value Char FCYORG        #     Code site Xtend
Value Char TIMSTP        #     RĂŠfĂŠrence time stamp 20061012093014
Value Char OPTION()(1..) #     Option 
                         #       'TRADET'=Trace dĂŠtaillĂŠe
Value Char ELTCOD        #     Code ĂŠlĂŠment
Variable Integer RET     #     1 Ok; 0: Ko ; 2: avertissement
Local Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)        # sodaix01:5000 et XTEND
Local Integer WI
Local Integer TRADETFLG   : TRADETFLG   = find("TRADET",OPTION)
Local Char WSTR1(250)

RET=1

If GTRACE<>""
 Call TITOBJ("AYS","", WSTR1) From CONTOBJ
 Call ECR_TRACE(mess(38,7900,1)-WSTR1,0) From GESECRAN : # Validation de l'ĂŠcran
Endif

Call MACHINE(DOSORG,MACORG,DOSNAMORG) From ORDSYS

If DOSORG=nomap 
 Local File AYTFCY  [AYS] 
 Local File ATEXTE  [ATX] 
 Local File ATEXTRA [AXX1]
Else 
 Local File =[L]DOSORG+".AYTFCY"  [AYS] 
 Local File =[L]DOSORG+".ATEXTE"  [ATX] 
 Local File =[L]DOSORG+".ATEXTRA" [AXX1]
Endif 
Default File "[AYS],[ATX]"

Read [F:AYS]AYS0 = FCYORG
If fstat
  OK=0
  Call RSTA("AYS",FCYORG) From GLOCK 
  Call ECR_TRACE(mess(19,9700,1)-FCYORG,1) From GESECRAN : # Site inexistant
  Goto FINALLY
Endif

#  By File
Gosub XMLF_INI From AYTGEN  
XT_DOSSIER=DOSORG : XT_MAC=MACORG : XT_DOSNAM=DOSNAMORG : XT_FCYCOD=FCYORG : XT_TIMSTP=TIMSTP
XT_XMLID="FCY"
Gosub XMLF_INI2 From AYTGEN : If XT_RET=0 : RET=0 : Goto FINALLY : Endif 

#  Nota: pas de test (If RET=0 : Goto FINALLY : Endif ) aprĂ¨s XMLF_ADD car la procĂŠdure a ĂŠtĂŠ testĂŠe
XT_TY="ELMTS"  : XT_ID=XT_XMLID                                            : Gosub XMLF_ADD From AYTGEN

XT_TY="ELMT"  : XT_ID=FCYORG     
Call LECTEXTRA(XT_VAL,"AYTFCY","INTIT",[F]FCYCOD,"") From AYTUTIA          : Gosub XMLF_ADD From AYTGEN                  

#
XT_TY="TAB"   : XT_ID="LANNBR"                                             : Gosub XMLF_ADD From AYTGEN
For WI=0 To [F]LANNBR-1
 XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
 XT_TY="COL"  : XT_ID="LANCOD"     : XT_VAL=[F]LANCOD(WI)                  : Gosub XMLF_ADD From AYTGEN
 XT_TY="COL"  : XT_ID="LANDEF"     : XT_VAL=num$([F]LANDEF(WI))
                                     XT_LAB=mess([F]LANDEF(WI),1,1)        : Gosub XMLF_ADD From AYTGEN
 XT_TY="COL"  : XT_ID="LANADS"     : XT_VAL=[F]LANADS(WI)                  : Gosub XMLF_ADD From AYTGEN
 XT_TY="COL"  : XT_ID="LANFMTCUR"  : XT_VAL=[F]LANFMTCUR(WI)               : Gosub XMLF_ADD From AYTGEN
 XT_TY="COL"  : XT_ID="LANFMTINT"  : XT_VAL=[F]LANFMTINT(WI)               : Gosub XMLF_ADD From AYTGEN
 XT_TY="COL"  : XT_ID="LANFMTDEC"  : XT_VAL=[F]LANFMTDEC(WI)               : Gosub XMLF_ADD From AYTGEN
 XT_TY="COL"  : XT_ID="LANFMTDAT"  : XT_VAL=[F]LANFMTDAT(WI)               : Gosub XMLF_ADD From AYTGEN
Next
#
XT_TY="TAB"   : XT_ID="LNKNBR"                                            : Gosub XMLF_ADD From AYTGEN
For WI=0 To [F]LNKNBR-1
 XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
 XT_TY="COL"  : XT_ID="LNKADX"     : XT_VAL=[F]LNKADS(WI)                  : Gosub XMLF_ADD From AYTGEN
 XT_TY="COL"  : XT_ID="LNKADSDEF"  : XT_VAL=num$([F]LNKADSDEF(WI))
                                     XT_LAB=mess([F]LNKADSDEF(WI),1,1)     : Gosub XMLF_ADD From AYTGEN
 XT_TY="COL"  : XT_ID="LNKBUSINT"  : XT_VAL=num$([F]LNKBUSINT(WI))
                                     XT_LAB=mess([F]LNKBUSINT(WI),1,1)     : Gosub XMLF_ADD From AYTGEN
Next
#
XT_TY="FLD"  : XT_ID="PRFENA"     : XT_VAL=num$([F]PRFENA)
                                    XT_LAB=mess([F]PRFENA,1,1)             : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"  : XT_ID="LOGMOD"     : XT_VAL=num$([F]LOGMOD)
                                    XT_LAB=mess([F]LOGMOD,1,1)             : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"  : XT_ID="TOOLMOD"    : XT_VAL=num$([F]TOOLMOD)
                                    XT_LAB=mess([F]TOOLMOD,1,1)            : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"  : XT_ID="PRODEF"     : XT_VAL=num$([F]PRODEF)
                                    XT_LAB=mess([F]PRODEF,7911,1)          : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"  : XT_ID="USRTIMOUT"  : XT_VAL=num$([F]USRTIMOUT)              : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"  : XT_ID="DIRLANG"    : XT_VAL=num$([F]DIRLAN)
                                    XT_LAB=mess([F]DIRLAN,1,1)             : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"  : XT_ID="GPRODUIT"   : XT_VAL=num$(GPRODUIT)                  : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"  : XT_ID="IMGDEF"     : XT_VAL=[F]IMGDEF                       : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"  : XT_ID="EXTDEFIMG"  : XT_VAL=[F]EXTDEFIMG                    : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"  : XT_ID="EXTDEFPJ"   : XT_VAL=[F]EXTDEFPJ                     : Gosub XMLF_ADD From AYTGEN
#
XT_TY="LST"  : XT_ID="MAICOD"                                              : Gosub XMLF_ADD From AYTGEN
For WI=0 To dim([F]MAICOD)-1
 If [F]MAICOD(WI)<>""
  XT_TY="ITM"                      :  XT_VAL=[F]MAICOD(WI)                  : Gosub XMLF_ADD From AYTGEN
 Endif
Next
#
XT_TY="TAB"   : XT_ID="PARNBR"                                             : Gosub XMLF_ADD From AYTGEN
For WI=0 To [F]PARNBR-1
 XT_TY="LIN"                                                               : Gosub XMLF_ADD From AYTGEN
 XT_TY="COL"  : XT_ID="PAR"        : XT_VAL=[F]PAR(WI)                     : Gosub XMLF_ADD From AYTGEN
 XT_TY="COL"  : XT_ID="PARVAL"     : XT_VAL=[F]PARVAL(WI)                  : Gosub XMLF_ADD From AYTGEN
Next
#
XT_TY="FLD"  : XT_ID="PAGSTR"      : XT_VAL=[F]PAGSTR                      : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"  : XT_ID="PAGLOG"      : XT_VAL=[F]PAGLOG                      : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"  : XT_ID="PAGERR"      : XT_VAL=[F]PAGERR                      : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"  : XT_ID="PAGRECNX"    : XT_VAL=[F]PAGRECNX                    : Gosub XMLF_ADD From AYTGEN
#
XT_TY="FLD"  : XT_ID="PAGMCE"      : XT_VAL=[F]PAGMCE                      : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"  : XT_ID="MCEFLG"      : XT_VAL=num$([F]MCEFLG)
                                     XT_LAB=mess([F]MCEFLG,1,1)            : Gosub XMLF_ADD From AYTGEN
#
XT_TY="FLD"  : XT_ID="BRWDEG"      : XT_VAL=num$([F]BRWDEG)
                                     XT_LAB=mess([F]BRWDEG,1,1)            : Gosub XMLF_ADD From AYTGEN


#--------------------------------------------------------------------
# Modif sb ajout paramĂ¨tres techniques.
# Localisation rĂŠpertoire
#        Menu local 7939
XT_TY="FLD"  : XT_ID="LOCHTM"      : XT_VAL=num$([F]LOCHTM)
                                     XT_LAB=mess([F]LOCHTM,7939,1)            : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"  : XT_ID="LOCFIL"      : XT_VAL=num$([F]LOCFIL)
                                     XT_LAB=mess([F]LOCFIL,7939,1)            : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"  : XT_ID="LOCFLA"      : XT_VAL=num$([F]LOCFLA)
                                     XT_LAB=mess([F]LOCFLA,7939,1)            : Gosub XMLF_ADD From AYTGEN
#     Fin localisation rĂŠpertoire
# Http cache expires
# Modif Sb 02/02/2009 on passe par un menu local 7942 pour ajouter de nouvelles valeurs.
XT_TY="FLD"  : XT_ID="HCEHTM"      : XT_VAL=num$([F]HCEHTM)
                                     XT_LAB=mess([F]HCEHTM,7942,1)            : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"  : XT_ID="HCEXTD"      : XT_VAL=num$([F]HCEXTD)
                                     XT_LAB=mess([F]HCEXTD,7942,1)            : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"  : XT_ID="HCEFIL"      : XT_VAL=num$([F]HCEFIL)
                                     XT_LAB=mess([F]HCEFIL,7942,1)            : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"  : XT_ID="HCEAPP"      : XT_VAL=num$([F]HCEAPP)
                                     XT_LAB=mess([F]HCEAPP,7942,1)            : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"  : XT_ID="HCEFLA"      : XT_VAL=num$([F]HCEFLA)
                                     XT_LAB=mess([F]HCEFLA,7942,1)            : Gosub XMLF_ADD From AYTGEN
#     Fin Http cache expires
# Scripts serveur
XT_TY="FLD"   : XT_ID="SCTROO"     : XT_VAL=num$([F]SCTROO)
                                          XT_LAB=mess([F]SCTROO,7937,1)        : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"   : XT_ID="SCTSUBREP"  : XT_VAL=[F]SCTSUBREP                 : Gosub XMLF_ADD From AYTGEN

# Fin scripts serveur

# Check timestamp
XT_TY="FLD"  : XT_ID="CTSHTM"      : XT_VAL=num$([F]CTSHTM)
                                     XT_LAB=mess([F]CTSHTM,1,1)            : Gosub XMLF_ADD From AYTGEN
XT_TY="FLD"  : XT_ID="CTSDIC"      : XT_VAL=num$([F]CTSDIC)
                                     XT_LAB=mess([F]CTSDIC,1,1)            : Gosub XMLF_ADD From AYTGEN


# fin check timestamp
# Fin modif sb
#--------------------------------------------------------------------

# Ctl de valeur (comme warning)
If [F]PAGSTR="" : Call ECR_TRACE(mess(118,7900,1),1) From GESECRAN : RET=2 : Endif 
If [F]PAGLOG="" : Call ECR_TRACE(mess(119,7900,1),1) From GESECRAN : RET=2 : Endif
If [F]PAGERR="" : Call ECR_TRACE(mess(120,7900,1),1) From GESECRAN : RET=2 : Endif

$FINALLY
Call SITEPUBLICATION(DOSORG)
Call CHECKPOOLXTD(DOSORG,FCYORG,RET)
Gosub XMLF_CL  From AYTGEN
Close Local File [AYS],[ATX],[AXX1]
End


Subprog SITEPUBLICATION(DOSORG)

Value Char DOSORG 
Value Char FCYORG 
Local Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)
Call MACHINE(DOSORG,MACORG,DOSNAMORG) From ORDSYS
If DOSORG=nomap 
 Local File AYTFCY  [AYS] 
Else 
 Local File =[L]DOSORG+".AYTFCY"  [AYS] 
Endif 


Gosub XMLF_INI From AYTGEN  
XT_DOSSIER=DOSORG : XT_MAC=MACORG : XT_DOSNAM=DOSNAMORG 
XT_XMLID="PUBSITE"
XT_STR=func AYTGESFILE.GETPATH(XT_MAC,XT_DOSNAM,"FIL"+XT_XMLID,"","","")

Openo XT_STR,0 Using [XTP]
Onerrgo
If XT_RET=0 : Return : Endif
Iomode adxifs ""  Using [XTP]
Iomode adxirs chr$(13)+chr$(10)  Using [XTP]
Iomode adxium GUTF8  Using [XTP]
Wrseq '<?xml version="1.0" encoding="utf-8" standalone="yes" ?> ' Using [XTP]
Wrseq '<ELMTS ID="'+XT_DOSSIER+'">'  Using [XTP]
 Filter [AYS] Where [F:AYS]FCYPUB=2
If !fstat Then
    For [AYS]
        Wrseq ' <ELMT ID="'+[F:AYS]FCYCOD+'"/>'  Using [XTP]
    Next
Endif
Wrseq '</ELMTS>'  Using [XTP]
Openo Using [XTP]
End


Subprog CHECKPOOLXTD(DOSORG,FCYORG,RET)

Value Char DOSORG 
Value Char FCYORG 
Variable Integer RET
Local Char MACORG(GDIMFIC), DOSNAMORG(GDIMFIC)
Call MACHINE(DOSORG,MACORG,DOSNAMORG) From ORDSYS
If DOSORG=nomap 
 Local File AYTFCY  [AYS]
 Local File AYTPOOWEB [AYO]
Else 
 Local File =[L]DOSORG+".AYTFCY"  [AYS]
 Local File =[L]DOSORG+".AYTPOOWEB"  [AYO]
Endif 
# on vĂŠrifie qu'il existe un pool Xtend 
Read [F:AYS]AYS0 = FCYORG
Local Integer INDEX

For INDEX=0 To [F:AYS]LNKNBR-1
    Read [AYO]AYO0=[F:AYS]LNKADS(INDEX)
    If fstat 
      If nbrecord([AYO])>0
       Call ECR_TRACE(mess(217,7900,1)-[F:AYS]LNKADS(INDEX),1) From GESECRAN
       RET=2
      Else
       Call ECR_TRACE(mess(217,7900,1)-[F:AYS]LNKADS(INDEX),-1) From GESECRAN
      Endif
     Endif
Next

Close Local File [AYS],[AYO]

End
