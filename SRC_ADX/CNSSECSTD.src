#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GNBMASKOUV
Raz GTUNCPT, GPILNAV
Local Char PARAM(250)(1..9)
PARAM(1)  = "ZBY2"      :# Company
PARAM(2)  = ""          :# Facility
PARAM(3)  = "2"         :# Type of ledger
PARAM(4)  = "CCT"       :# Dimension type
PARAM(5)  = "01CNSULDPT":# Analytical Dimension
PARAM(6)  = "20080101"  :# Start Date
PARAM(7)  = "20081231"  :# End Date
PARAM(8)  = ""          :# Currency
PARAM(9)  = ""          :# Filter
Call GCONSULT("SEC","",PARAM) From GCONSULT
End

Subprog PATCH(APPLI)
Value Char APPLI
If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(1)<>2 End Endif
Call VALGTC(APPLI,"SEC") From SUBGTC
End

$ACTION
Case ACTION
 When "AUTORIS"    : Gosub AUTORIS
 When "FERME"      : Gosub FERME
 When "OUVRE"      : Gosub OUVRE
 When "LECTURE"    : Gosub LECTURE
 When "SETBOUT"    : Gosub SETBOUT
 When "DEB_CRIT"   : Gosub DEB_CRIT
 When "EXEBOUT2"   : Gosub EXEBOUT2
 When "FIN_CRIT"   : Gosub FIN_CRIT
 When "AV_MAGNETO" : Gosub AV_MAGNETO
 When "AP_MAGNETO" : Gosub AP_MAGNETO
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "VERF_LISTE" : Gosub VERF_LISTE
 When "AB1_NBLIG"  : Gosub AB1_NBLIG
 When "AB2_NBLIG"  : Gosub AB2_NBLIG
 When "BB1_NBLIG"  : Gosub BB_NBLIG
 When "BB2_NBLIG"  : Gosub BB_NBLIG
 When "TRT_DIV"    : Gosub TRT_DIV From CONSSUB
Endcase
Return

$AUTORIS
Local Libelle OTUNCPT : OTUNCPT=GTUNCPT(2)
If GTUNCPT(2)
  # A function could nor be called twice.
 Call MESSAGE(mess(247,199,1)) From GESECRAN : OK=0
Else
 GTUNCPT(2) = 1
Endif
Return

$FERME
If dim(OTUNCPT)>0 : GTUNCPT(2) = OTUNCPT : Endif
Return

$OUVRE
Local Integer I, J, OK, AX, ISITE, COURTYP, SPSTAT, OKCRS :#, AXCUR
Local Char    SECCUR(GLONCCE), FCYCUR(GLONFCY), CPYCUR(GLONCPY), DEVSOC(GLONCUR), DEVLOC(GLONCUR)
Local Decimal EXERCICE, PERIODE, AMT
Local Integer NBSITE
Local Char    AXCUR
Local Char    DEVLED(GLONCUR)
Local Integer LEDTYPCUR
Local Char    DEVAFFCUR

NBSITE = max(1,GNBSITE)
Local Char    TSITE(GLONFCY)(1..NBSITE), TDEVSOC(GLONCUR)(1..NBSITE)
Local Integer TPFIN(1..NBSITE), TEFIN(1..NBSITE), TEDEB(1..NBSITE), PFIN, EFIN, EDEB
Local Char    TDEVLED(GLONCUR)(1..NBSITE)
#---------------------------------------------
# Consulting on several fiscal periods
Local Integer NBFIY : NBFIY=1
Local Integer FIYLST(1..NBFIY),FIYPEND(1..NBFIY)
Local Char    FILTCLO(250)
#---------------------------------------------
NBSITE = 0
Local Date    DDEB, DFIN, DEBDAT, FINDAT, DDCUR, DFCUR
Local Char    FILLIG(250) , FILTET(250), FILTLCT(250) , FILSEC(250)(1..3)
Local Char    DEBHAE(GLONVCR), FINHAE(GLONVCR), DEBTYP(GLONGTE), FINTYP(GLONGTE)
Local Integer DEBNUM, FINNUM, DEBLIG, FINLIG
Local Char    DEBCCE(10)(0..max(GOPTCANA,dim([F:DAA]DIE))), FINCCE(10)(0..max(GOPTCANA,dim([F:DAA]DIE)))
Local Char    VALCCE(10)(1..max(GOPTCANA,dim([F:DAA]DIE)))
Local Char    DEBSIT(GLONFCY) , FINSIT(GLONFCY)
Local Char    EXPCLE(250), ORDANA(10), OPT(1)
Local Libelle GRP, PLEIN, FLTRI, XDEV
Local Integer COHGRP
Local Date    DEBEX
Local Char    TRICUR(10)
Local Integer NUMAXE , NBAXE , NBSOC , NSOCAXE
Local Integer TBAXE(1..dim([F:DAA]DIE))
Local Char    TBSOC(GLONCPY)(1..100) , SOCREF(GLONCPY) , SOCREFCUR(GLONCPY)
Local Char    SOCAXE(GLONDIE)(1..dim([F:DAA]DIE))
Local Char    SEPDAT(1)
Local Char    NULDAT(5)

Local Mask    VENTILE  [VTL]
Local Mask    VENTILE2 [VT2]

If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:CCE])=0 : Local File CACCE      [CCE] : Endif
If clalev([F:COA])=0 : Local File GCOA       [COA] : Endif
If clalev([F:CLS])=0 : Local File GACCCLS    [CLS] : Endif

Call PARAM("","CNSTYPCUR",OPT) From ADOVAL
COURTYP = val(OPT) : OPT=""
SEPDAT = mid$(GFMDAT,4,1)
NULDAT = "0"+SEPDAT+"0"+SEPDAT+"0"
Gosub DEFCRIT
Return

$DEFCRIT
# Parameters should be consistent

If [M:SEC1]FCY<>"" & GUSRFCY(1)<>"\" & !find([M:SEC1]FCY,GUSRFCY(1..GNBAUZ))
 [M:SEC1]FCY=""
Endif
DDEB=[M:SEC1]DATDEB
DFIN=[M:SEC1]DATFIN
For I=1 To dim(PARAM)
 Case I
  When 1 : # Company
   If PARAM(I)<>""
    Call LECTURE("CPY",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:SEC1]CPY = PARAM(I)
     If [M:SEC1]FCY<>""
      Call LECTURE("FCY",[M:SEC1]FCY,"") From CONTOBJ
      If [F:FCY]LEGCPY<>[M:SEC1]CPY : [M:SEC1]FCY="" : Endif
     Endif
    Endif
   Endif
  When 2 : # Facility
   If PARAM(I)<>""
    Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
    If !fstat & (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
     [M:SEC1]FCY = PARAM(I)
     [M:SEC1]CPY = [F:FCY]LEGCPY
     PARAM(1)=""
    Endif
   Endif
  When 3 : # Ledger type
   If clalev([GCM])=0 : Local File GACM [GCM] : Endif
   If clalev([LED])=0 : Local File GLED [LED] : Endif
   If val(PARAM(I))<>0
    If [M:SEC1]CPY<>""
     Call LECTURE("CPY",[M:SEC1]CPY,"") From CONTOBJ
     If [F:CPY]CPYLEGFLG<>2
      If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
      Read [FGR]FGR0(1) = [M:SEC1]CPY
      Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
      Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
     Endif
     Call LECTURE("GCM",[F:CPY]ACM,"")  From CONTOBJ
     If [F:GCM]LED(val(PARAM(I))-1)<>""
      Call LECTURE ("LED",[F:GCM]LED(val(PARAM(I))-1),"") From CONTOBJ
      [M:SEC1]LEDTYP = val(PARAM(I))
      [M:SEC1]CURLED = [F:GCM]CUR(val(PARAM(I))-1)
     Endif
    Endif
   Else
    Call SETMAINREF([M:SEC1]CPY,GTYPGEN,GTYPANA) From CPTDIV
    [M:SEC1]LEDTYP = GTYPANA
    Call LECPLAN([M:SEC1]CPY,GTYPANA,[M:SEC1]COA) From CPTDIV
   Endif
   If [M:SEC1]LEDTYP = 0 :  [M:SEC1]LEDTYP = 2 : Endif
  When 4 : # Dimension type
   If clalev([DIE])=0 : Local File GDIE [DIE] : Endif
   If PARAM(I)<>""
    Call LECTURE("DIE",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:SEC1]AXE=PARAM(I)
    Endif
   Endif
  When 5 : # Analytical dimension
   If PARAM(I)<>""
    Read [CCE]CCE0=[M:SEC1]AXE;PARAM(I)
    If !fstat : [M:SEC1]SECTION = PARAM(I) : Endif
   Endif
  When 6 : # Start Date
   Gosub DATUS From CNSCPTSTD
   If PARAM(I)<>"" & PARAM(I)<>NULDAT & PARAM(I)<>"000000"
    If instr(1,PARAM(I),SEPDAT)
     [M:SEC1]DATDEB = evalue("["+ctrans(PARAM(I),SEPDAT,"/")+"]")
    Elsif PARAM(I)<>""
     [M:SEC1]DATDEB = PARAM(I)
    Endif
   Endif
  When 7 : # End Date
   Gosub DATUS From CNSCPTSTD
   If PARAM(I)<>"" & PARAM(I)<>NULDAT & PARAM(I)<>"000000"
    If instr(1,PARAM(I),SEPDAT)
     [M:SEC1]DATFIN = evalue("["+ctrans(PARAM(I),SEPDAT,"/")+"]")
    Elsif PARAM(I)<>""
     [M:SEC1]DATFIN = PARAM(I)
    Endif
   Endif
  When 8 : # Currency
   If PARAM(I)<>""
    Call LECTURE("TCU",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:SEC1]CURSEL = PARAM(I)
     [M:CSEC]CURSEL = PARAM(I)
    Endif
   Endif
  When 9 : # Filter on GACCENTRYA [DAA]
   [M:CSEC]FILTECT(2) = PARAM(I)
  When 10 : # Option
   For J=1 To len(PARAM(I))
    OPT = mid$(PARAM(I),J,1)
    If OPT="1" or OPT="2"
     Case J
      When 1 : # Carry Forward
       [M:CSEC]ANOUV = val(OPT)
      When 2 : # Closing
       [M:CSEC]CLOTURE = val(OPT)
     Endcase
    Endif
   Next J
  When 11 : Break
 Endcase
Next I

# Tunnel
Default Mask [SEC1]
If [M:SEC1]CPY<>""
 Local Char CODLED(GLONLED) , DEVLED(GLONCUR)
 Local Integer STAT
 Local Char MESSA(250)
 Call CNTCOHLED([M:SEC1]CPY,[M:SEC1]LEDTYP,CODLED,DEVLED,STAT,MESSA) From CPTCNT
 If STAT=0
  Filter [FGR] Where CPY=[M:SEC1]CPY
  Read [FGR]FGR0 First
  Filter [FGR]
  Read [FCY]FCY0 = [F:FGR]FCY
  [M:SEC1]CPY = [F:FCY]LEGCPY
  [M:SEC1]FCY = [F:FCY]FCY
  MESSA += "\"+mess(63,109,1)-[F:FCY]FCY : # Inquiry limited to site
  Call MESSAGE(MESSA) From GESECRAN
 Endif
Endif
Call C_LEDTYP([M:SEC1]LEDTYP)

# Default values
Default Mask [SEC1]
Call INIT(DDEB,DFIN) From CONSSUB

If [M:CSEC]ANOUV  =0 : [M:CSEC]ANOUV   = 2 : Endif
If [M:CSEC]CLOTURE=0 : [M:CSEC]CLOTURE = 2 : Endif
If [M:CSEC]SIMUL  =0 : [M:CSEC]SIMUL   = 2 : Endif
If [M:CSEC]TRI    =0 : [M:CSEC]TRI     = 1 : Endif

Gosub CRITENT From =PROGCNS
Affzo [M:SEC1]
Return



$LECTURE
If [M:SEC1]SECTION<>""
 Read [CCE]CCE0 = [M:SEC1]AXE;[M:SEC1]SECTION
 If fstat : NBLU=0 : Return : Endif
Else
 NBLU=0 : Return
Endif
If [M:SEC1]CPY="" or [M:SEC1]DATDEB=[0/0/0] or [M:SEC1]DATFIN=[0/0/0]
 NBLU=0 : Return
Endif

XDEV = 0
If  AXCUR<>[M:SEC1]AXE | SECCUR<>[M:SEC1]SECTION | CPYCUR<>[M:SEC1]CPY | FCYCUR<>[M:SEC1]FCY
& | DDCUR<>[M:SEC1]DATDEB | DFCUR<>[M:SEC1]DATFIN | LEDTYPCUR<>[M:SEC1]LEDTYP | DEVAFFCUR<>DEVAFF
 Gosub INISOC
 If GRP & !COHGRP & CHGPAG=1
  Call MESSAGE(mess(64,109,1)) From GESECRAN : # The start and end dates of the fiscal years in the group are diffferent, no balances
 Endif
Endif
If !GRP
 [M:SEC1]DEVISE = DEVLED
Else
 [M:SEC1]DEVISE = TDEVLED(1)
 If [M:SEC1]DEVISE=""
  [M:SEC1]DEVISE = [M:SEC1]CURLED
 Else
  For I=2 To NBSITE
   If TDEVLED(1)<>TDEVLED(I) : [M:SEC1]DEVISE = [M:SEC1]CURLED : XDEV=1 : Break : Endif
  Next I
 Endif
Endif
[M:SEC1]SYSCUR = DEVLED

# Balances and Totaux in selected currency
Raz [M:SEC1]CURSEL
[M:SEC1]CURSEL = [M:CSEC]CURSEL

Gosub FILTRE

Case [M:CSEC]TRI
 When 1 : # Date
  EXPCLE = "ACCDAT"
 When 2 : # Journal entry
  EXPCLE = "TYP;NUM"
 When 3 : # Analytical
  EXPCLE=""
  Local Char     LSTAXEANA(GLONDIE)(1..dim([F:DAA]DIE))
  Local Integer  NBRAXEANA, N_AXE : NBRAXEANA=0 : NUMAXE=0
  If [M:CSEC]TRIANA<>""
   Call PARSE_TRIANA([M:CSEC]TRIANA,LSTAXEANA,NBRAXEANA)
   For I=1 To NBRAXEANA
    Call GETNUMAXE([M:CSEC]SOCREF,[M:SEC1]LEDTYP,LSTAXEANA(I),N_AXE) From CPTDIV
    If N_AXE<>0
     If EXPCLE<>"" : EXPCLE +=";" : Endif
     EXPCLE +="CCE("+num$(N_AXE-1)+")"
    Endif
   Next I
  Endif
Endcase
If EXPCLE<>"" : EXPCLE+=";" : Endif
EXPCLE += "ACCNUM;ANALIN"

If CHGPAG<0
 I = 1
 Repeat
  J = instr(I,EXPCLE,";")
  If J
   EXPCLE = left$(EXPCLE,J-1)+" Desc"+right$(EXPCLE,J)
   I = J+6
  Endif
 Until !J
 EXPCLE +=" Desc"
Endif

If PROGSPE<>""
 ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif
Link [DAA] With [HAE]HAE0=[F:DAA]TYP;[F:DAA]NUM , [DAE]DAE0=[F:DAA]TYP;[F:DAA]NUM;[F:DAA]LIN;[F:DAA]LEDTYP
&          As [LNK2]
&          Where LEDTYP=[M:SEC1]LEDTYP
&                & evalue(FILLIG)
&                & evalue(FILTET)
&                & evalue(FILTLCT)
&                & evalue(FILSEC(1..3))
&          Order With EXPCLE

If CHGPAG>0
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
Else
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
Endif
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:SEC2] : Endif
PLEIN=0 : OK=0 : FLTRI=0

If AXCUR=[M:SEC1]AXE & SECCUR=[M:SEC1]SECTION
 Case CHGPAG
  When 3 : # Refresh
   Case [M:CSEC]TRI
    When 1 : # Date
     For [LNK2] Where Key >= DEBDAT;DEBNUM;DEBLIG
      Gosub REMPLIT : If PLEIN : Break : Endif
     Next
    When 2 : # Journal entry
     For [LNK2] Where Key >= DEBTYP;DEBHAE;DEBNUM;DEBLIG
      Gosub REMPLIT : If PLEIN : Break : Endif
     Next
    When 3 : # Analytical
     For I=1 To NBRAXEANA
      Call GETNUMAXE([M:CSEC]SOCREF,[M:SEC1]LEDTYP,LSTAXEANA(I),N_AXE) From CPTDIV
      If N_AXE<>0
       VALCCE(I) = DEBCCE(N_AXE)
      Endif
     Next
     Case NBRAXEANA
      When 1
       For [LNK2] Where Key >= VALCCE(1);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 2
       For [LNK2] Where Key >= VALCCE(1);VALCCE(2);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 3
       For [LNK2] Where Key >= VALCCE(1);VALCCE(2);VALCCE(3);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 4
       For [LNK2] Where Key >= VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 5
       For [LNK2] Where Key >= VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 6
       For [LNK2] Where Key >= VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 7
       For [LNK2] Where Key >= VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);VALCCE(7);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 8
       For [LNK2] Where Key >= VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);VALCCE(7);VALCCE(8);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 9
       For [LNK2] Where Key >= VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);VALCCE(7);VALCCE(8);VALCCE(9);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
     Endcase
   Endcase
   OK=1
  When 2 : # Next
   Case [M:CSEC]TRI
    When 1 : #  # Date
     For [LNK2] Where Key > FINDAT;FINNUM;FINLIG
      Gosub REMPLIT : If PLEIN : Break : Endif
     Next
    When 2 : # Journal entry
     For [LNK2] Where Key > FINTYP;FINHAE;FINNUM;FINLIG
      Gosub REMPLIT : If PLEIN : Break : Endif
     Next
    When 3 : # Analytical
     For I=1 To NBRAXEANA
      Call GETNUMAXE([M:CSEC]SOCREF,[M:SEC1]LEDTYP,LSTAXEANA(I),N_AXE) From CPTDIV
      If N_AXE<>0
       VALCCE(I) = FINCCE(N_AXE)
      Endif
     Next
     Case NBRAXEANA
      When 1
       For [LNK2] Where Key > VALCCE(1);FINNUM;FINLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 2
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);FINNUM;FINLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 3
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);FINNUM;FINLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 4
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);FINNUM;FINLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 5
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);FINNUM;FINLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 6
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);FINNUM;FINLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 7
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);VALCCE(7);FINNUM;FINLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 8
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);VALCCE(7);VALCCE(8);FINNUM;FINLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 9
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);VALCCE(7);VALCCE(8);VALCCE(9);FINNUM;FINLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
     Endcase
   Endcase
   OK=1
  When -2 : # Back
   Case [M:CSEC]TRI
    When 1 : #  # Date
     For [LNK2] Where Key > DEBDAT;DEBNUM;DEBLIG
      Gosub REMPLIT : If PLEIN : Break : Endif
     Next
    When 2 : # Journal entry
     For [LNK2] Where Key > DEBTYP;DEBHAE;DEBNUM;DEBLIG
      Gosub REMPLIT : If PLEIN : Break : Endif
     Next
    When 3 : # Analytical
     For I=1 To NBRAXEANA
      Call GETNUMAXE([M:CSEC]SOCREF,[M:SEC1]LEDTYP,LSTAXEANA(I),N_AXE) From CPTDIV
      If N_AXE<>0
       VALCCE(I) = DEBCCE(N_AXE)
      Endif
     Next
     Case NBRAXEANA
      When 1
       For [LNK2] Where Key > VALCCE(1);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 2
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 3
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 4
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 5
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 6
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 7
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);VALCCE(7);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 8
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);VALCCE(7);VALCCE(8);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 9
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);VALCCE(7);VALCCE(8);VALCCE(9);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
     Endcase
   Endcase
   OK=1
 Endcase
Endif

$BOUCLE
If !OK
 For [LNK2]
  Gosub REMPLIT : If PLEIN | FLTRI=2 : Break : Endif
 Next
Endif

# Change sorting
If TRICUR<>num$([M:CSEC]TRI)+[M:CSEC]TRIANA
 If CHGPAG=3 & !FLTRI
  FLTRI=1 : RETOUR=1 : OK=0 : Goto BOUCLE
 Endif
 TRICUR=num$([M:CSEC]TRI)+[M:CSEC]TRIANA
Endif

Local Char DEVAFF,DEVLED
DEVLED=[M:SEC1]CURLED

# Calculation of balance in the header
If !GRP
  Call SOLDAT([M:SEC1]AXE,[M:SEC1]SECTION,[M:SEC1]CPY,[M:SEC1]FCY,
&             [M:SEC1]LEDTYP,[M:SEC1]CURSEL,COURTYP,[M:SEC1]DATFIN,[M:SEC1]SOLDE)
Else
  Call SOLDAT2([M:SEC1]AXE,[M:SEC1]SECTION,[M:SEC1]CPY,
&              [M:SEC1]LEDTYP,[M:SEC1]CURSEL,COURTYP,[M:SEC1]DATFIN,[M:SEC1]SOLDE)
Endif

If [M:SEC1]CURSEL=""
 [M:SEC1]DEVISE=DEVLED
Else
 [M:SEC1]DEVISE=[M:SEC1]CURSEL
Endif

If COHGRP
 Call LECTURE("TCU",[M:SEC1]DEVISE,"") From CONTOBJ
 If [M:SEC1]SOLDE=0
  [M:SEC1]LIBSOL = "N"+right$(format$("N3:"+[F:TCU]CURFMT1,[M:SEC1]SOLDE),2)
 Elsif [M:SEC1]SOLDE>0
  [M:SEC1]LIBSOL = "D"+right$(format$("N3:"+[F:TCU]CURFMT1,[M:SEC1]SOLDE),2)
 Else
  [M:SEC1]SOLDE  = -[M:SEC1]SOLDE
  [M:SEC1]LIBSOL = "C"+right$(format$("N3:"+[F:TCU]CURFMT1,[M:SEC1]SOLDE),2)
 Endif
Else
 Raz [M:SEC1]SOLDE, [M:SEC1]LIBSOL
Endif

Affzo [M]

If COHGRP
 AXCUR     = [M:SEC1]AXE
 SECCUR    = [M:SEC1]SECTION
 CPYCUR    = [M:SEC1]CPY
 FCYCUR    = [M:SEC1]FCY
 DDCUR     = [M:SEC1]DATDEB
 DFCUR     = [M:SEC1]DATFIN
 LEDTYPCUR = [M:SEC1]LEDTYP
 DEVSELCUR = [M:SEC1]CURSEL

# # Filled in the 2nd tab
 If (CHGPAG=1 or CHGPAG=3) & dim([M:SOL3]DAT)>0
  Raz [M:SOL3]
  Call LECTURE("CPY",CPYCUR,"") From CONTOBJ
  If [F:CPY]CPYLEGFLG<>1
   Call GETPERSOC(CPYCUR,LEDTYPCUR,DDCUR,EXERCICE,PERIODE) From CPTSUB
   EDEB = EXERCICE
   Call GETPERSOC(CPYCUR,LEDTYPCUR,DFCUR,EXERCICE,PERIODE) From CPTSUB
   EFIN = EXERCICE
   Call SOLDSEC(AXCUR,SECCUR,CPYCUR,FCYCUR,LEDTYPCUR,DEVLED,DEVSELCUR,EDEB,EFIN,GERR) From SOLDSEC
  Else
   If [M:SEC1]CURSEL="" & XDEV    # Heterogeneous currencies for this grouping
      GERR=1 : GMESSAGE = mess(54,109,1)-[M:SEC1]CPY
   Else
    NBSITE = 0
    For [FGR]FGR0 Where CPY = CPYCUR
     Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
     If [F:FCY]FINFLG=2
      Filter [FIY] Where CPY=[F:FCY]LEGCPY & LEDTYP=LEDTYPCUR
      Read [FIY]FIY0 First
      If [M:SEC1]DATDEB>=[F:FIY]FIYSTR : DDEB = [M:SEC1]DATDEB : Else : DDEB = [F:FIY]FIYSTR : Endif
      Read [FIY]FIY0 Last
      If [M:SEC1]DATFIN<=[F:FIY]FIYEND : DFIN = [M:SEC1]DATFIN : Else : DFIN = [F:FIY]FIYEND : Endif
      Filter [FIY]
      If DDEB<=DFIN
       NBSITE+=1
       TSITE(NBSITE) = [F:FGR]FCY
      Endif
     Endif
    Next
    Call SOLDSEC2(AXCUR,SECCUR,NBSITE,TSITE,LEDTYP,DEVLED,DEVSELCUR,[M:SEC1]DATDEB,[M:SEC1]DATFIN,GERR) From SOLDSEC
   Endif
  Endif
  OKCRS=0
  For [LNK2]
   OK = 1
   If GRP
    ISITE = find([F:DAA]FCYLIN,TSITE(1..NBSITE))
    DEVSOC = TDEVSOC(ISITE)
    EDEB   = TEDEB(ISITE)
    EFIN   = TEFIN(ISITE)
    PFIN   = TPFIN(ISITE)
   Endif
   # -------------To filter without closing entries------------
   FILTCLO = num$([F:HAE]FIY)+">="+num$(EDEB)-"&"-num$([F:HAE]FIY)+"<="+num$(EFIN)
   If GRP
    #--------------------------
    If EFIN>EDEB & [M:CSEC]CLOTURE<>2
     Local Integer CF,LF,LP :# CurrentFiscalyear / LastFiscalyear / LastPeriod
     Local Date SDF, EDF    :# StartDateFiscalyear / EndDateFiscalyear
     NBFIY=EFIN-EDEB+1
     Local Integer FIYLST(1..NBFIY),FIYPEND(1..NBFIY)
     CF=max(1,EDEB)
     For I=1 To NBFIY
      FIYLST(I)=CF
      Call DATFIY(TBSOC(ISITE),[F:DAE]LEDTYP,CF,SDF,EDF) From CPTSUB
      Call GETPERIOD(TBSOC(ISITE),[F:DAE]LEDTYP,EDF,LF,LP) From CPTSUB
      FIYPEND(I)=LP
      CF+=1
     Next
    Endif
   Endif
   If EFIN>EDEB & find([F:HAE]FIY,FIYLST(1..NBFIY))  : #Quand on rentre dans la fonction on peut tomber en erreur
    FILTCLO -= "&"-num$([F:HAE]PER)+">"+num$(FIYPEND(find([F:HAE]FIY,FIYLST(1..NBFIY))))
   Elsif EFIN=EDEB
    FILTCLO -= "&"-num$([F:HAE]PER)+">"+num$(PFIN)
   Endif

   If [M:CSEC]CLOTURE<>2 & evalue(FILTCLO) :   OK=0
   Elsif [F:DAE]PER=0 & ([M:CSEC]ANOUV<>2 | [F:DAE]FIY<>EDEB) : OK=0
   Endif

   If [M:CSEC]FILTECT(0)<>"" & OK : OK *= evalue([M:CSEC]FILTECT(0)) : Endif
   If [M:CSEC]FILTECT(1)<>"" & OK : OK *= evalue([M:CSEC]FILTECT(1)) : Endif
   If [M:CSEC]FILTECT(2)<>"" & OK : OK *= evalue([M:CSEC]FILTECT(2)) : Endif
   If OK : GPOINT = "CONTROLE" : Gosub ENTREE From EXEFNC : Endif
   If OK
    If [F:DAA]SNS=1
     [M:SOL3]DEBLOC  += [F:DAA]AMTLED
     If [M:SEC1]CURSEL<>""
      [M:SOL3]DEBCUR  += [F:DAA]AMTCUR
     Endif
    Else
     [M:SOL3]CRELOC  += [F:DAA]AMTLED
     If [M:SEC1]CURSEL<>""
      [M:SOL3]CRECUR  += [F:DAA]AMTCUR
     Endif
    Endif
   Endif
  Next

  # Balances and Totaux in selected currency

  [M:SOL3]DEVLOC  = [M:SEC1]CURLED
  [M:SOL3]DEVLOC2 = [M:SEC1]CURLED
  [M:SOL3]SNSSOL  = ""
  [M:SOL3]DEVCUR  = [M:SEC1]CURSEL
  [M:SOL3]DEVCUR2 = [M:SEC1]CURSEL
  [M:SOL3]SNSSOL2 = ""

  If [M:SOL3]DEBLOC>=[M:SOL3]CRELOC
   [M:SOL3]SOLLOC = [M:SOL3]DEBLOC-[M:SOL3]CRELOC
   If [M:SOL3]SOLLOC<>0
    [M:SOL3]SNSSOL   = mess(1,610,1) : # "D"
   Endif
   If [M:SEC1]CURSEL<>""
    [M:SOL3]SOLCUR = [M:SOL3]DEBCUR-[M:SOL3]CRECUR
    If [M:SOL3]SOLCUR<>0
     [M:SOL3]SNSSOL2 = mess(1,610,1) : # "D"
    Endif
   Endif
  Else
   [M:SOL3]SOLLOC = [M:SOL3]CRELOC-[M:SOL3]DEBLOC
   If [M:SOL3]SOLLOC<>0
    [M:SOL3]SNSSOL   = mess(2,610,1) : # "C"
   Endif
   If [M:SEC1]CURSEL<>""
    [M:SOL3]SOLCUR = [M:SOL3]CRECUR-[M:SOL3]DEBCUR
    If [M:SOL3]SOLCUR<>0
     [M:SOL3]SNSSOL2 = mess(2,610,1) : # "C"
    Endif
   Endif
  Endif
  Affzo [SOL3]
 Endif
Elsif CHGPAG=1 or CHGPAG=3
 If dim([M:SOL3]DAT)>0 : Effzo [SOL3] : Endif
Endif
Return

$REMPLIT
OK = 1
If GRP
 ISITE = find([F:DAA]FCYLIN,TSITE(1..NBSITE))
 DEVSOC = TDEVSOC(ISITE)
 EDEB   = TEDEB(ISITE)
 EFIN   = TEFIN(ISITE)
 PFIN   = TPFIN(ISITE)
Endif
# -------------To filter without closing entries------------
FILTCLO = num$([F:HAE]FIY)+">="+num$(EDEB)-"&"-num$([F:HAE]FIY)+"<="+num$(EFIN)
If GRP
 #--------------------------
 If EFIN>EDEB & [M:CSEC]CLOTURE<>2
 Local Integer CF,LF,LP :# CurrentFiscalyear / LastFiscalyear / LastPeriod
 Local Date SDF, EDF    :# StartDateFiscalyear / EndDateFiscalyear
   NBFIY=EFIN-EDEB+1
   Local Integer FIYLST(1..NBFIY),FIYPEND(1..NBFIY)
   CF=max(1,EDEB)
   For I=1 To NBFIY
    FIYLST(I)=CF
    Call DATFIY(TBSOC(ISITE),[F:DAE]LEDTYP,CF,SDF,EDF) From CPTSUB
    Call GETPERIOD(TBSOC(ISITE),[F:DAE]LEDTYP,EDF,LF,LP) From CPTSUB
    FIYPEND(I)=LP
    CF+=1
   Next
 Endif
Endif
If EFIN>EDEB & find([F:HAE]FIY,FIYLST(1..NBFIY))  : # Could have an error here
 FILTCLO -= "&"-num$([F:HAE]PER)+">"+num$(FIYPEND(find([F:HAE]FIY,FIYLST(1..NBFIY))))
Elsif EFIN=EDEB
 FILTCLO -= "&"-num$([F:HAE]PER)+">"+num$(PFIN)
Endif

If [M:CSEC]CLOTURE<>2 & evalue(FILTCLO) : OK=0
Elsif [F:DAE]PER=0 & ([M:CSEC]ANOUV<>2 | [F:DAE]FIY<>EDEB) : OK=0
Endif

If [M:CSEC]FILTECT(0)<>"" & OK : OK *= evalue([M:CSEC]FILTECT(0)) : Endif
If [M:CSEC]FILTECT(1)<>"" & OK : OK *= evalue([M:CSEC]FILTECT(1)) : Endif
If [M:CSEC]FILTECT(2)<>"" & OK : OK *= evalue([M:CSEC]FILTECT(2)) : Endif
If OK : GPOINT = "CONTROLE" : Gosub ENTREE From EXEFNC : Endif
If OK
 If FLTRI
  If [F:DAA]ACCNUM<>DEBNUM | [F:DAA]ANALIN<>DEBLIG : RETOUR=2 : Endif
  FLTRI=2 : Return
 Endif
 If NBLU=1
  If CHGPAG=2 or CHGPAG=-2 : Raz [M:SEC2] : Endif
  NBLU=2
 Endif
 If CHGPAG>0
  If NOL>=MAXLIG-1 : SUITE = 2 : PLEIN = 1 : Return : Endif
  NOL += 1
  If NOL=0
   DEBNUM = [F:DAA]ACCNUM
   DEBLIG = [F:DAA]ANALIN
   DEBDAT = [F:DAA]ACCDAT
   DEBSIT = [F:DAA]FCYLIN
   DEBTYP = [F:HAE]TYP
   DEBHAE = [F:HAE]NUM
   For AX=1 To dim([F:DAA]DIE) : DEBCCE(AX) = [F:DAA]CCE(AX-1) : Next AX
  Endif
  FINNUM = [F:DAA]ACCNUM
  FINLIG = [F:DAA]ANALIN
  FINDAT = [F:DAA]ACCDAT
  FINSIT = [F:DAA]FCYLIN
  FINTYP = [F:HAE]TYP
  FINHAE = [F:HAE]NUM
  For AX=1 To dim([F:DAA]DIE) : FINCCE(AX) = [F:DAA]CCE(AX-1) : Next AX
 Else
  If NOL<=0 : RETOUR = 2 : PLEIN = 1 : Return : Endif
  NOL -= 1
  If NOL=MAXLIG-1
   FINNUM = [F:DAA]ACCNUM
   FINLIG = [F:DAA]ANALIN
   FINDAT = [F:DAA]ACCDAT
   FINSIT = [F:DAA]FCYLIN
   FINTYP = [F:HAE]TYP
   FINHAE = [F:HAE]NUM
   For AX=1 To dim([F:DAA]DIE): FINCCE(AX) = [F:DAA]CCE(AX-1) : Next AX
  Endif
  DEBNUM = [F:DAA]ACCNUM
  DEBLIG = [F:DAA]ANALIN
  DEBDAT = [F:DAA]ACCDAT
  DEBSIT = [F:DAA]FCYLIN
  DEBTYP = [F:HAE]TYP
  DEBHAE = [F:HAE]NUM
  For AX=1 To dim([F:DAA]DIE) : DEBCCE(AX) = [F:DAA]CCE(AX-1) : Next AX
 Endif
 nolign = NOL+1
 [M:SEC2] = [F:HAE]
 [M:SEC2] = [F:DAE]
 [M:SEC2] = [F:DAA]
 For AX=1 To dim([F:DAA]DIE)
  Assign "[M:SEC2]CCE"+num$(AX)+"("+num$(nolign-1)+")" With [F:DAA]CCE(AX-1)
 Next AX
 [M:SEC2]CURCPY(NOL) = DEVSOC

 [M:SEC2]MLTRAT(NOL) = [F:HAE]RATMLT([F:DAA]LEDTYP-1)
 [M:SEC2]DIVRAT(NOL) = [F:HAE]RATDIV([F:DAA]LEDTYP-1)
 [M:SEC2]FNLPSTNUMW(NOL)=[F:HAE]FNLPSTNUM([F:DAE]LEDTYP-1)
 [M:SEC2]CREUSR(NOL) = [F:HAE]CREUSR
 [M:SEC2]UPDUSR(NOL) = [F:HAE]UPDUSR

 If [F:DAE]SNS=1
  [M:SEC2]DEBIT (NOL) = [F:DAA]AMTCUR
  [M:SEC2]DEBLED(NOL) = [F:DAA]AMTLED
 Else
  [M:SEC2]CREDIT(NOL) = [F:DAA]AMTCUR
  [M:SEC2]CDTLED(NOL) = [F:DAA]AMTLED
 Endif
Endif
Return

$INISOC
Call LECTURE("CPY",[M:SEC1]CPY,"") From CONTOBJ

GRP=([F:CPY]CPYLEGFLG=1)
If !GRP
 DEVLED = [M:SEC1]CURLED
 Call GETPERSOC([M:SEC1]CPY,[M:SEC1]LEDTYP,[M:SEC1]DATDEB,EXERCICE,PERIODE) From CPTSUB
 EDEB = EXERCICE
 Call GETPERSOC([M:SEC1]CPY,[M:SEC1]LEDTYP,[M:SEC1]DATFIN,EXERCICE,PERIODE) From CPTSUB
 PFIN = PERIODE
 EFIN = EXERCICE
 Call GETNUMAXE([M:SEC1]CPY,[M:SEC1]LEDTYP,[M:SEC1]AXE,NUMAXE) From CPTDIV
 NBAXE = 1
 TBAXE(NBAXE) = NUMAXE
 NBSOC = 1
 TBSOC(NBSOC) = [M:SEC1]CPY
 COHGRP = 1
 #---------------------------------------------
 # Inquiry on several fiscal year without closing entries
 If EFIN>EDEB
  Local Integer CF,LF,LP :# CurrentFiscalyear / LastFiscalyear / LastPeriod
  Local Date SDF, EDF    :# StartDateFiscalyear / EndDateFiscalyear
  NBFIY=EFIN-EDEB+1
  Local Integer FIYLST(1..NBFIY),FIYPEND(1..NBFIY)
  CF=max(1,EDEB)
  For I=1 To NBFIY
   FIYLST(I)=CF
   Call DATFIY([M:SEC1]CPY,[M:SEC1]LEDTYP,CF,SDF,EDF) From CPTSUB
   Call GETPERIOD([M:SEC1]CPY,[M:SEC1]LEDTYP,EDF,LF,LP) From CPTSUB
   FIYPEND(I)=LP
   CF+=1
  Next
 Endif
 #---------------------------------------------
Else
 NBSITE = 0
 NBSOC  = 0
 NBAXE  = 0
 COHGRP = 1
 For [FGR]FGR0 Where CPY = [M:SEC1]CPY
  Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
  If [F:FCY]FINFLG=2
   Filter [FIY] Where CPY=[F:FCY]LEGCPY & LEDTYP=[M:SEC1]LEDTYP
   Read [FIY]FIY0 First
   If [M:CSEC]DATDEB>=[F:FIY]FIYSTR : DDEB=[M:SEC1]DATDEB : Else DDEB=[F:FIY]FIYSTR : Endif
   Read [FIY]FIY0 Last
   If [M:CSEC]DATFIN<=[F:FIY]FIYEND : DFIN=[M:SEC1]DATFIN : Else DFIN=[F:FIY]FIYEND : Endif
   Filter [FIY]
   If DDEB<=DFIN
    NBSITE+=1
    TSITE(NBSITE) = [F:FGR]FCY
    Call GETPERSOC([F:FCY]LEGCPY,[M:SEC1]LEDTYP,DDEB,EXERCICE,PERIODE) From CPTSUB
    TEDEB(NBSITE) = EXERCICE
    Call GETPERSOC([F:FCY]LEGCPY,[M:SEC1]LEDTYP,DFIN,EXERCICE,PERIODE) From CPTSUB
    TEFIN(NBSITE) = EXERCICE
    TPFIN(NBSITE) = PERIODE
    TDEVLED(NBSITE) = [M:SEC1]CURLED
    Call GETNUMAXE([F:FCY]LEGCPY,[M:SEC1]LEDTYP,[M:SEC1]AXE,NUMAXE) From CPTDIV
    If !find(NUMAXE,TBAXE(1..NBAXE))
     NBAXE += 1
     TBAXE(NBAXE) = NUMAXE
    Endif
    If !find([F:FCY]LEGCPY,TBSOC(1..NBSOC))
     NBSOC += 1
     TBSOC(NBSOC) = [F:FCY]LEGCPY
    Endif
    Read [FIY]FIY0 = [F:FCY]LEGCPY;[M:SEC1]LEDTYP;EXERCICE
    If NBSITE=1
     DEBEX = [F:FIY]FIYSTR
    Elsif DEBEX<>[F:FIY]FIYSTR
     COHGRP = 0
    Endif
   Endif
  Endif
 Next
Endif
SOCREF = TBSOC(1)
[M:CSEC]SOCREF = SOCREF
Call GETLSTAXE(SOCREF,[M:SEC1]LEDTYP,NSOCAXE,SOCAXE) From CPTDIV
Raz [M:SEC1]INTITDIE
For I=1 To 9
 If I<=NSOCAXE
  Call LECTEXTRA([M:SEC1]INTITDIE(I-1),"GDIE","COLHEA",SOCAXE(I),"") From ATEXTRA
 Endif
 Case I
  When  1 : Titcol [M:SEC2]NBLIG [M:SEC1]INTITDIE(0) For CCE1
  When  2 : Titcol [M:SEC2]NBLIG [M:SEC1]INTITDIE(1) For CCE2
  When  3 : Titcol [M:SEC2]NBLIG [M:SEC1]INTITDIE(2) For CCE3
  When  4 : Titcol [M:SEC2]NBLIG [M:SEC1]INTITDIE(3) For CCE4
  When  5 : Titcol [M:SEC2]NBLIG [M:SEC1]INTITDIE(4) For CCE5
  When  6 : Titcol [M:SEC2]NBLIG [M:SEC1]INTITDIE(5) For CCE6
  When  7 : Titcol [M:SEC2]NBLIG [M:SEC1]INTITDIE(6) For CCE7
  When  8 : Titcol [M:SEC2]NBLIG [M:SEC1]INTITDIE(7) For CCE8
  When  9 : Titcol [M:SEC2]NBLIG [M:SEC1]INTITDIE(8) For CCE9
 Endcase
Next I
For I=1 To NSOCAXE
 Case I
  When 1 : Chgfmt [M:SEC2]CCE1 With "KP:15X"
  When 2 : Chgfmt [M:SEC2]CCE2 With "KP:15X"
  When 3 : Chgfmt [M:SEC2]CCE3 With "KP:15X"
  When 4 : Chgfmt [M:SEC2]CCE4 With "KP:15X"
  When 5 : Chgfmt [M:SEC2]CCE5 With "KP:15X"
  When 6 : Chgfmt [M:SEC2]CCE6 With "KP:15X"
  When 7 : Chgfmt [M:SEC2]CCE7 With "KP:15X"
  When 8 : Chgfmt [M:SEC2]CCE8 With "KP:15X"
  When 9 : Chgfmt [M:SEC2]CCE9 With "KP:15X"
 Endcase
Next I
For I=NSOCAXE+1 To 9
 Case I
  When 1 : Chgfmt [M:SEC2]CCE1 With "-K:15X"
  When 2 : Chgfmt [M:SEC2]CCE2 With "-K:15X"
  When 3 : Chgfmt [M:SEC2]CCE3 With "-K:15X"
  When 4 : Chgfmt [M:SEC2]CCE4 With "-K:15X"
  When 5 : Chgfmt [M:SEC2]CCE5 With "-K:15X"
  When 6 : Chgfmt [M:SEC2]CCE6 With "-K:15X"
  When 7 : Chgfmt [M:SEC2]CCE7 With "-K:15X"
  When 8 : Chgfmt [M:SEC2]CCE8 With "-K:15X"
  When 9 : Chgfmt [M:SEC2]CCE9 With "-K:15X"
 Endcase
Next I
Return

$FILTRE
If !GRP
 FILLIG = '[F:DAA]CPY="'+[M:CSEC]CPY+'"'
 If [M:CSEC]FCY<>""
  FILLIG -= '& [F:DAA]FCYLIN="'+[M:CSEC]FCY+'"'
 Endif
Else
 # Groupement de sites
 FILLIG = "find([F:DAA]FCYLIN,TSITE(1..NBSITE))"
Endif
If [M:CSEC]DATDEB<>[0/0/0]
 FILLIG -= '& [F:DAA]ACCDAT>=['+format$(GFMD,[M:CSEC]DATDEB)+']'
Endif
If [M:CSEC]DATFIN<>[0/0/0]
 FILLIG -= '& [F:DAA]ACCDAT<=['+format$(GFMD,[M:CSEC]DATFIN)+']'
Endif
FILTLCT = ""
If [M:CSEC]COMPTE<>""
 FILTLCT -= '& [F:DAE]ACC="'+[M:CSEC]COMPTE+'"'
Endif
If FILTLCT="" : FILTLCT = '1=1'
Else          : FILTLCT = right$(FILTLCT,4)
Endif
If [M:CSEC]SIMUL=2
 FILTET = '([F:HAE]CAT<3 | [F:HAE]CAT=4)'
Else
 FILTET = '([F:HAE]CAT=1 | [F:HAE]CAT=4)'
Endif
If [M:CSEC]CURSEL<>""
 FILTET -= '& [F:HAE]CUR="'+[M:CSEC]CURSEL+'"'
Endif
Raz FILSEC
J = 1
For I=1 To NBAXE
 If J>1 or FILSEC(J)<>"" : FILSEC -= '|' : Endif
 FILSEC(J) -= '(DIE('+num$(TBAXE(I)-1)+')="'+[M:SEC1]AXE+'" & CCE('+num$(TBAXE(I)-1)+')="'+[M:SEC1]SECTION+'")'
 If len(FILSEC(J))>200 : J += 1 : Endif
Next I
If FILSEC="" : FILSEC="1=1" : Endif
Return

$SETBOUT
If [M:SEC1]SECTION<>""
 Call CONTEXE([M:SEC1]CPY,[M:SEC1]LEDTYP,[M:SEC1]DATDEB,[M:SEC1]DATFIN,OK) From CONSSUB
Else OK=0
Endif
If !OK : Call VIREBOUT(CHAINE,"O") From GCONSULT : Endif
If [M:SEC1]AXE=""
 Call VIREBOUT(CHAINE,"C") From GCONSULT
Endif
Return

$AV_MAGNETO
FILTRE="DIE='"+[M]AXE+"' & ENAFLG=2"
Return

$AP_MAGNETO
FILTRE=""
Return

$DEB_CRIT
Local Char FILTRE(250)(3)
FILTRE(0) = [M:CSEC]FILTECT(0)
If FILTRE(0)<>"" : [M:CSEC]CRITTET=2 : Else [M:CSEC]CRITTET=1 : Endif
FILTRE(1) = [M:CSEC]FILTECT(1)
If FILTRE(1)<>"" : [M:CSEC]CRITLIG=2 : Else [M:CSEC]CRITLIG=1 : Endif
FILTRE(2) = [M:CSEC]FILTECT(2)
If FILTRE(2)<>"" : [M:CSEC]CRITANA=2 : Else [M:CSEC]CRITANA=1 : Endif
Return

$EXEBOUT2
Case BOUT
 When "P" : # Header
  If [M:CSEC]FILTECT(0)<>"" & [M:CSEC]CRITTET<>2
   [M:CSEC]CRITTET=2 : GNBAFF=1
  Elsif [M:CSEC]FILTECT(0)="" & [M:CSEC]CRITTET=2
   [M:CSEC]CRITTET=1 : GNBAFF=1
  Endif
 When "Q" : # Line
  If [M:CSEC]FILTECT(1)<>"" & [M:CSEC]CRITLIG<>2
   [M:CSEC]CRITLIG=2 : GNBAFF=1
  Elsif [M:CSEC]FILTECT(1)="" & [M:CSEC]CRITLIG=2
   [M:CSEC]CRITLIG=1 : GNBAFF=1
  Endif
 When "O" : # Analytical
  If [M:CSEC]FILTECT(2)<>"" & [M:CSEC]CRITANA<>2
   [M:CSEC]CRITANA=2 : GNBAFF=1
  Elsif [M:CSEC]FILTECT(2)="" & [M:CSEC]CRITANA=2
   [M:CSEC]CRITANA=1 : GNBAFF=1
  Endif
Endcase
Return

$FIN_CRIT
Case REPONSE
 When GSTAOK, GSTARET
  If [M:CSEC]FILTECT(0)<>FILTRE(0) |
&    [M:CSEC]FILTECT(1)<>FILTRE(1) |
&    [M:CSEC]FILTECT(2)<>FILTRE(2)
   [L]CHANGE=2
  Endif
  If [M:CSEC]FILTECT(0)<>""
   Onerrgo ERR_FILTECT
   OK = evalue([M:CSEC]FILTECT(0))
   Onerrgo
  Endif
  If [M:CSEC]FILTECT(1)<>""
   Onerrgo ERR_FILTECT
   OK = evalue([M:CSEC]FILTECT(1))
   Onerrgo
  Endif
  If [M:CSEC]FILTECT(2)<>""
   Onerrgo ERR_FILTECT
   OK = evalue([M:CSEC]FILTECT(2))
   Onerrgo
  Endif
 When GSTAFIN, GSTAESC
  [M:CSEC]FILTECT(0) = FILTRE(0)
  [M:CSEC]FILTECT(1) = FILTRE(1)
  [M:CSEC]FILTECT(2) = FILTRE(2)
Endcase
Return

$ERR_FILTECT
Call ERREUR(mess(33,100,1)) From GESECRAN
[L]CHANGE=1
[M:CSEC]FILTECT(0) = FILTRE(0)
[M:CSEC]FILTECT(1) = FILTRE(1)
[M:CSEC]FILTECT(2) = FILTRE(2)
Resume

#############################################################
##        Balances as at a given date                      ##
#############################################################
Subprog SOLDAT(AXE,SECTION,SOCIETE,SITE,LEDTYP,DEVSEL,COURS,DATSOL,SOLDE)
Value    Char    AXE
Value    Char    SECTION
Value    Char    SOCIETE
Value    Char    SITE
Value    Integer LEDTYP
Value    Char    DEVSEL
Value    Integer COURS
Value    Date    DATSOL
Variable Decimal SOLDE
Raz SOLDE
Gosub SOL_DAT
SOLDE = SOLD
End

Subprog SOLDAT2(AXE,SECTION,SOC,LEDTYP,DEVSEL,COURS,DATSOL,SOLDE)
Value    Char    AXE
Value    Char    SECTION
Value    Char    SOC
Value    Integer LEDTYP
Value    Char    DEVSEL
Value    Integer COURS
Value    Date    DATSOL
Variable Decimal SOLDE
Local Char    SITE(GLONFCY), SOCIETE(GLONCPY)
Local Integer J
Raz SOLDE
For [FGR]FGR0 Where CPY=SOC
 SITE = [F:FGR]FCY
 Call LECTURE("FCY",SITE,"") From CONTOBJ
 SOCIETE = [F:FCY]LEGCPY
 Gosub SOL_DAT
 SOLDE += SOLD
Next
End

$SOL_DAT
Local Char    CODLED(GLONLED), DEVLED(GLONCUR), PLAN(GLONCOA)
Local Integer I , FLECT , SPSTAT, GRP
Local Decimal PDEB , PFIN , PMAX , EDEB , EFIN
Local Decimal EXERCICE , PERIODE , SOLD
Local Date    DATECT
Local Integer NUMAXE
Raz SOLD

Call GETNUMAXE(SOCIETE,LEDTYP,AXE,NUMAXE) From CPTDIV
If NUMAXE=0 : Return : Endif

Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
GRP=([F:CPY]CPYLEGFLG=1)

Call LECLED(SOCIETE,LEDTYP,CODLED,DEVLED) From CPTDIV
Call LECPLAN(SOCIETE,LEDTYP,PLAN) From CPTDIV

Call GETPERSOC(SOCIETE,LEDTYP,DATSOL,EFIN,PERIODE) From CPTSUB
If DATSOL = [F:PER]PEREND
 PFIN = PERIODE : FLECT = 0
Else
 PFIN = PERIODE-1 : FLECT = 1 : DATECT = [F:PER]PERSTR
Endif

Filter [FIY] Where CPY=SOCIETE & LEDTYP=[L]LEDTYP & FIYSTA=2
Read [FIY]FIY0 First
Filter [FIY]
EDEB = [F:FIY]FIYNUM
If EFIN<EDEB : EDEB = EFIN : Endif
PMAX = dim([F:BLA]DEB)-1
If !FLECT
 Call GETEXE(SOCIETE,LEDTYP,DATSOL,EXERCICE) From CPTSUB
 If DATSOL=[F:FIY]FIYEND : PFIN=PMAX : Endif
Endif

Call LEC_COA(PLAN) From CPTLEC
Call LEC_CCE(SECTION, AXE) From CPTLEC
For EXERCICE=EDEB To EFIN
 If DEVSEL<>"" & !GRP
  Filter [BLA] Where LEDTYP=[L]LEDTYP & CPY=SOCIETE & FCY=SITE & FIY=EXERCICE & BPR=""
&                  & CUR=DEVSEL
&                  & evalue("CCE"+num$(NUMAXE))=SECTION
 Else
  Filter [BLA] Where LEDTYP=[L]LEDTYP & CPY=SOCIETE & FCY=SITE & FIY=EXERCICE & BPR=""
&                  & evalue("CCE"+num$(NUMAXE))=SECTION
 Endif
 For [BLA]BLA0
  Call LEC_GAC([F:BLA]ACC, [F:BLA]COA) From CPTLEC
  Call LEC_CLS([F:COA]LEGCLS, [F:GAC]CLSCOD) From CPTLEC
  If ([F:CLS]ERA=2 & [F:CCE]FRW=2) or EXERCICE=EFIN
   If EDEB=EFIN
    If PFIN>0
     If DEVSEL<>"" & !GRP
      SOLD += sum([F:BLA]DEB(0..PFIN))-sum([F:BLA]CDT(0..PFIN))
     Else
      SOLD += sum([F:BLA]DEBLED(0..PFIN))-sum([F:BLA]CDTLED(0..PFIN))
     Endif
    Endif
   Elsif EXERCICE=EDEB
    If DEVSEL<>"" & !GRP
     SOLD += sum([F:BLA]DEB(0..PMAX))-sum([F:BLA]CDT(0..PMAX))
    Else
     SOLD += sum([F:BLA]DEBLED(0..PMAX))-sum([F:BLA]CDTLED(0..PMAX))
    Endif
   Elsif EXERCICE=EFIN
    If DEVSEL<>"" & !GRP
     SOLD += sum([F:BLA]DEB(1..PFIN))-sum([F:BLA]CDT(1..PFIN))
    Else
     SOLD += sum([F:BLA]DEBLED(1..PFIN))-sum([F:BLA]CDTLED(1..PFIN))
    Endif
   Else
    If DEVSEL<>"" & !GRP
     SOLD += sum([F:BLA]DEB(1..PMAX))-sum([F:BLA]CDT(1..PMAX))
    Else
     SOLD += sum([F:BLA]DEBLED(1..PMAX))-sum([F:BLA]CDTLED(1..PMAX))
    Endif
   Endif
  Endif
 Next
 Filter[BLA]
Next EXERCICE

If FLECT
 If DEVSEL<>"" & !GRP
  Filter [DAA] Where CPY=SOCIETE & (SITE="" | FCYLIN=SITE) & LEDTYP=[L]LEDTYP
&                  & ACCDAT>=DATECT & ACCDAT<=DATSOL & CUR=DEVSEL
&                  & evalue("CCE("+num$(NUMAXE-1)+")")=SECTION
 Else
  Filter [DAA] Where CPY=SOCIETE & (SITE="" | FCYLIN=SITE) & LEDTYP=[L]LEDTYP
&                  & ACCDAT>=DATECT & ACCDAT<=DATSOL
&                  & evalue("CCE("+num$(NUMAXE-1)+")")=SECTION
 Endif
 For [DAA]DAA1
  If DEVSEL<>"" & !GRP
   SOLD += [F:DAA]SNS*[F:DAA]AMTCUR
  Else
   SOLD += [F:DAA]SNS*[F:DAA]AMTLED
  Endif
 Next
 Filter [DAA]
Endif

Return

#############################################################
##     Screens CONSSEC1 & CRITSEC & CONSSEC2    ##
#############################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Integer NUMAXE , IAXE
Call C_CPY(VALEUR) From CONSSUB
If mkstat : End : Endif
## Acces to all the sites groupings
Call LEC_CPY(VALEUR) From CPTLEC
If [F:CPY]CPYLEGFLG<>2
 Call CONTALLFCY(VALEUR) From CPTSUB : # Access to all the site of the company ?
Endif
[M:CSEC]GROUPE = 1
[M:CSEC]SOCREF = VALEUR
If [F:CPY]CPYLEGFLG<>2
 For [FGR] Where CPY=VALEUR
  Read [FCY]FCY0 = [F:FGR]FCY
  Call GETNUMAXE([F:FCY]LEGCPY,[M]LEDTYP,[M:SEC1]AXE,IAXE) From CPTDIV
  If NUMAXE=0
   NUMAXE = IAXE
   [M:CSEC]SOCREF = [F:FCY]LEGCPY
  Elsif NUMAXE<>IAXE
   [M:CSEC]GROUPE = 2
   Break
  Endif
 Next
Endif
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR) From CONSSUB
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CONSSUB
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer OPTION
OPTION=3 : # Analytical ledger
Call LEDTYP_CHOICE([M:CSEC]SOCREF,OPTION) From CPTDIV
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Call C_LEDTYP(VALEUR) From CONSSUB
End

Subprog AM_CURSEL(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & dim([M:CSEC]CURSEL)>0
 [M:CSEC]CURSEL=VALEUR
Endif
End

Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
Call C_DATDEB(VALEUR) From CONSSUB
End

Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
Call C_DATFIN(VALEUR) From CONSSUB
End

Subprog S_AXE(VALEUR)
Variable Char    VALEUR()
Filter [DIE] Where find(DIE,[F:LED]DIE(0..[F:LED]DIENBR-1))<>0
Call SELECT("DIE","",VALEUR,"") From SELOBJ
Filter [DIE]
End

Subprog C_AXE(VALEUR)
Variable Char    VALEUR()
Call C_AXE(VALEUR) From CONSSUB
End

## Screen CRITSEC ##

Subprog C_TRI(VALEUR)
Variable Integer VALEUR
If VALEUR=3 & [M]GROUPE=2
 GMESSAGE = mess(61,109,1) : # No analytic sort on a heterogeneous site group
 mkstat = 2 : End
Endif
If VALEUR=3
 Actzo TRIANA
Else
 Effzo TRIANA
 Grizo TRIANA
Endif
End

Subprog AS_TRIANA(VALEUR)
Variable Char    VALEUR()
Call AS_TRIANA(VALEUR) From CONSSUB
End

Subprog C_TRIANA(VALEUR)
Variable Char    VALEUR()
Local Integer I , NB_AR
Local Char LIST_AR(GLONDIE)(1..dim([M:SEC1]DIE))
Local Integer NBAXE
Local Char    LSTAXE(GLONDIE)(1..dim([F:DAA]DIE))
If VALEUR<>""
 VALEUR=vireblc(toupper(VALEUR),2)
 Call PARSE_TRIANA(VALEUR,LIST_AR,NB_AR)
 Call GETLSTAXE([M]SOCREF,[M:SEC1]LEDTYP,NBAXE,LSTAXE) From CPTDIV
 For I=1 To NB_AR
  If !find(LIST_AR(I),LSTAXE(1..NBAXE))
   # This dimension type is not defined in the chosen ledger
   GMESSAGE = LIST_AR(I)-":"-mess(111,104,1)
   mkstat=2 : Break
  Endif
  If find(LIST_AR(I),LIST_AR(1..I-1))
   GMESSAGE = LIST_AR(I)-":"-mess(80,105,1) :# Dimension type already defined
   mkstat=2 : Break
  Endif
 Next I
Endif
End

Subprog PARSE_TRIANA(VALEUR,LSTAXEANA,NBRAXEANA)
Variable Char    VALEUR()
Variable Char    LSTAXEANA()(1..)
Variable Integer NBRAXEANA

Local Char    CHAINE(len(VALEUR))
Local Integer NB_ESPACE, I, J

NB_ESPACE=-1 : I=0 : J=1
Raz LSTAXEANA

#Calculation of the number of dimension type of "Value" (separator is one space)
Repeat I=instr(I+1,VALEUR," ") : NB_ESPACE+=1 : Until I=0
#The number of dimension type is the number of space +1
NBRAXEANA=NB_ESPACE+1
If NBRAXEANA>1
 CHAINE=VALEUR
 Repeat I=instr(1,CHAINE," ")
  If I<>0
   LSTAXEANA(J)=vireblc(left$(CHAINE,I-1),2)
   CHAINE=vireblc(right$(CHAINE,I+1),2)
  Else
   LSTAXEANA(J)=vireblc(CHAINE,2)
  Endif
  J+=1
 Until I=0
Else
 LSTAXEANA(1)=VALEUR
Endif
NBRAXEANA=J-1
End


$SEL_LISTE
Case LISTE
 When "TRIANA"  : Gosub SEL_TRIANA
Endcase
Return

$VERF_LISTE
Case LISTE
 When "TRIANA"  : Gosub VERF_TRIANA
Endcase
Return

$SEL_TRIANA
Local Char WVALZON(80)
Local Char NTRI(1)
WVALZON = VALEUR
VALEUR = ""
Local Char TEX(GLONDIE)(1..20)
Local Char TEXTE(GLONDES)(1..20,1..2)
TIT = mess(175,105,1)  :# Choose a Dimension Type
TIT(1)=mess(206,111,1) :# Dimension Type
TIT(2)=mess(30,109,1)  :# Title
Local Integer NBAXE
Local Char    LSTAXE(GLONDIE)(1..dim([F:DAA]DIE))
Call GETLSTAXE([M:CSEC]SOCREF,[M:SEC1]LEDTYP,NBAXE,LSTAXE) From CPTDIV
For I=1 To NBAXE
 If  LSTAXE(I)<>[M:SEC1]AXE
  NBTEX+=1
  TEX(NBTEX)= LSTAXE(I)
  TEXTE(NBTEX,1)= LSTAXE(I)
  Call LECTEXTRA(TEXTE(NBTEX,2),"GDIE","DESTRA",LSTAXE(I),"") From ATEXTRA
 Endif
Next
Return

$VERF_TRIANA
VALEUR=WVALZON
If [M:CSEC]DIE(0)=""
 Call C_LEDTYP([M:CSEC]LEDTYP)
Endif
If TEX(CHOIX)<>""
 If find(TEX(CHOIX),[M:CSEC]DIE(0..dim([M:CSEC]DIE)-1))  & !instr(1,VALEUR,TEX(CHOIX))
  If VALEUR=""
   VALEUR = TEX(CHOIX)
  Else
   VALEUR -= TEX(CHOIX)
  Endif
 Endif
Endif
Return

## Screen CONSSEC2 ##
Subprog IB_NBLIG
 Call IB_NBLIG From CONSSUB
End

## Tunnel toward Journal
$AB1_NBLIG
# A filter is still existing before this tunnel restricted the BLA to one record. So pb of writing after when
# we are in GAS to update this entry.
Filter [BLA]
Gosub SAV_CONSULT From CONSSUB
Call B1_NBLIG From CONSSUB
Return

## Tunnel toward Invoices and Payments
$AB2_NBLIG
Gosub SAV_CONSULT From CONSSUB
Call B2_NBLIG From CONSSUB
Return

$BB_NBLIG
Gosub RST_CONSULT From CONSSUB
Return

