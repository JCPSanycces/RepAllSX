#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTICRM17001   Gestion PK OPPORSTB and OPPORSTA                         #
#                                                                        #
##########################################################################
# Issue X3-57419 - 2017-10-26 by FGR                                     #
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTICRM17001(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTICRM17001(DOSSIER)
Value Char DOSSIER

Local Integer IERR
Local Integer IUPDATE
Local Integer NCOUNTOK
Local Integer NCOUNTERROR
Local Decimal NITTQTY
Local Char SOPPNUM(GLONVCR)
Local Integer ISEQNUM
Local Integer IYES_A
Local Integer IYES_B

  IERR = 0
  Call ECR_TRACE("UTICRM17001: Process Start on : "+DOSSIER, 0) From GESECRAN
  # -------------------------
  Local File =DOSSIER + ".ATABIND"  [ATI]
  Local File =DOSSIER + ".OPPORCRM" [OCRM]
  Local File =DOSSIER + ".OPPORSTB" [OSB]
  Local File =DOSSIER + ".OPPORSTB" [OSBL]
  Local File =DOSSIER + ".OPPORSTA" [OSA]
  Local File =DOSSIER + ".OPPORSTA" [OSAL]
  # -------------------------
  Trbegin [OSB]
  NCOUNT = 0
  NCOUNTERROR = 0
  # -------------------------
  Call ECR_TRACE("UTICRM17001: Updating OPPORSTB/OPPORSTB", 0) From GESECRAN
  IYES_B = 0
  Read [ATI]CODIND="OPPORSTB";"OSB0"
  If !fstat and [F:ATI]DESCRIPT = "OPPNUM+STRDAT+STELIN" Then
    IYES_B = 1
    Update [OSB] With [F:OSB]STELIN = [F:OSB]STELIN + 1000
  Endif
  IYES_A = 0
  Read [ATI]CODIND="OPPORSTA";"OSA0"
  If !fstat and [F:ATI]DESCRIPT = "OPPNUM+STRDATX+STELINX" Then
    IYES_A = 1
    Update [OSA] With [F:OSA]STELINX = [F:OSA]STELINX + 1000
  Endif
  # -------------------------
  If IYES_B = 1 or IYES_A = 1 Then
    For [OCRM]
      If IYES_B = 1 Then
        ISEQNUM = 0
        Filter [OSB] Where [F:OSB]OPPNUM = [F:OCRM]OPPNUM Order By [F:OSB]OPPNUM;[F:OSB]STRDAT
        For [OSB]
          ISEQNUM += 10
          # ---------------------
          Repeat
            Look [OSBL]OSB0=[F:OSB]OPPNUM;[F:OSB]STRDAT;ISEQNUM
            If !fstat Then
              ISEQNUM += 10
            Endif
          Until fstat
          # ---------------------
          [F:OSB]STELIN = ISEQNUM
          NCOUNT += 1
          Rewrite [OSB]
          If fstat Then
            Call ECR_TRACE("File OPPORSTB" - [F:OSB]OPPNUM - [F:OSB]STRDAT + ", Error =" - num$(fstat), 1) From GESECRAN
            GOK = 1
            IERR = 1
            NCOUNTERROR += 1
          Endif
        Next
        Filter [OSB]
      Endif
      # -------------------------
      If IYES_A = 1 Then
        ISEQNUM = 0
        Filter [OSA] Where [F:OSA]OPPNUM = [F:OCRM]OPPNUM Order By [F:OSA]OPPNUM;[F:OSA]STRDATX
        For [OSA]
          ISEQNUM += 10
          # ---------------------
          Repeat
            Look [OSAL]OSA0=[F:OSA]OPPNUM;[F:OSA]STRDATX;ISEQNUM
            If !fstat Then
              ISEQNUM += 10
            Endif
          Until fstat
          # ---------------------
          [F:OSA]STELINX = ISEQNUM
          NCOUNT += 1
          Rewrite [OSA]
          If fstat Then
            Call ECR_TRACE("File OPPORSTA" - [F:OSA]OPPNUM - [F:OSA]STRDATX + ", Error =" - num$(fstat), 1) From GESECRAN
            GOK = 1
            IERR = 1
            NCOUNTERROR += 1
          Endif
        Next
        Filter [OSA]
      Endif
    Next
  Endif
  # -------------------------
  If NCOUNTERROR = 0 Then
    Call ECR_TRACE("UTICRM17001: OPPORSTB/OPPORSTA" - num$(NCOUNT) - "updated.", 0) From GESECRAN
  Else
    Call ECR_TRACE("UTICRM17001: OPPORSTB/OPPORSTA" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
  Endif
  # -----------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTICRM17001 : records processed without error.", 0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTICRM17001 : records processed with error(s).", 0) From GESECRAN
  Endif
  # -------------------------
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","OPPORSTB","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "OPPORSTB") : End : Endif
  If filinfo(filpath("FIL","OPPORSTA","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "OPPORSTA") : End : Endif
  # -------------------------
  Call MAJ_UTICRM17001(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","OPPORSTB","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "OPPORSTB") : End : Endif
  If filinfo(filpath("FIL","OPPORSTA","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "OPPORSTA") : End : Endif
  # -------------------------
  Call MAJ_UTICRM17001(APPLI)
End

