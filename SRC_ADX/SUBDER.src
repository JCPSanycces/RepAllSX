#<AdxTL>@(#)1.0.0.0 $Revision$
#*********************************************************************
#
#                    GESTION DU PLAN DEROGATOIRE
#
#*********************************************************************
#    Création
#    MWA - 17.02.2003
#
#*********************************************************************
#    Modification
#    MWA - 12.05.2014  FQ96726  Revision affichage du plan dérogatoire
#    MWA - 23.07.2013  FQ90620  Problème sur l'affichage des champs de réintégration fiscale.
#    MDJ - 12.06.2013  FQ82871  Adaptations pour Convergence (pcolor)
#    CBO - 12.03.2012  FQ80246  GFMDAT4 au lieu de DD[/]MM[/]YYYY
#    FQ62633 - 17.02.2010    Problème d'affichage de la reprise sur sortie et du solde début pour les biens sortis (GBO)
#
#*********************************************************************
#
Raz GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM
Call OBJET("FAS",GBIDC1,GBIDC2) From GOBJET
End

#*********************************************************************
$ACTION
  Case ACTION
    When "OUVRE"         : Gosub OUVRE      : # Début            - Avant toute chose
    When "VERROU"        : Gosub VERROU     :
    When "LIENS"         : Gosub LIENS      : # Début            - Lecture informations tables liées
    When "SETBOUT"       : Gosub SETBOUT    : #                  - Désactivation des boutons
    When "AVANTBOUT"     : Gosub AVANTBOUT
    When "FERME"         : Gosub FERME      :
    When Default
  Endcase
Return
#
#*********************************************************************
#
#=====================================================================
#
$OUVRE

  # Sauvegarde du contexte - variables globales
  If TUNNEL : Gosub SAUVE_GLOBAL_SV From GLOBIMM : Endif
  #-------------------------
  # Gestion tables
  If clalev([F:FAS])   =0  : Local File FXDASSETS [FAS]   : Endif
  If clalev([F:DEP])   =0  : Local File DEPREC    [DEP]   : Endif
  If clalev([F:DEPF])  =0  : Local File DEPREC    [DEPF]  : Endif
  If clalev([F:DEPC])  =0  : Local File DEPREC    [DEPC]  : Endif
  If clalev([F:FIS])   =0  : Local File FISCYEAR  [FIS]   : Endif
  #-------------------------

  Global Integer GGESCRB : GGESCRB=G_NON
  Global Integer GAFFPER : GAFFPER=G_OUI

Return

#=====================================================================
#
$VERROU
  OK = 0
Return

#=====================================================================
#
$LIENS

Local Integer L_SITU      : # Situation : 0 => Réintégration / 1 => Dérogatoire
Local Integer COULIG1     : # ligne de l'exercice courant dans le tableau
Local Date    FIYENDMAX
Local Integer LDEP, FIS, CPT
Local Char    LPARM(10)

  FIS = G_OUI : CPT = G_OUI

  #-- Alimentation des infos de l'en-tête
  Local Integer I_PLN
  #>>>>>>>>>>>>>>>>>>>>
  For I_PLN=1 To 2
    Read [DEP]DEP0=[M:DER1]AASREF;I_PLN;GFINEXECPF;GFINPERCPF
    If ( fstat ) Then
      GOK = 0 : Return
    Else
      If ( I_PLN = 1 ) Then
        # Comptable
        [M:DER1]DPM1        = [F:DEP]DPM
        [M:DER1]STRDPRDAT1  = [F:DEP]STRDPRDAT
        [M:DER1]DPRDUR1     = [F:DEP]DPRDUR
        [M:DER1]ENDDPRDAT1  = [F:DEP]ENDDPRDAT
        [M:DER1]DPRRATFLG1  = [F:DEP]DPRRATFLG
        [M:DER1]DPRRAT1     = [F:DEP]DPRRAT
        [M:DER1]DPRBAS1     = [F:DEP]DPRBAS
        [M:DER1]ALWCOD1     = [F:DEP]ALWCOD
      Else
        # Fiscal
        [M:DER1]DPM2        = [F:DEP]DPM
        [M:DER1]STRDPRDAT2  = [F:DEP]STRDPRDAT
        [M:DER1]DPRDUR2     = [F:DEP]DPRDUR
        [M:DER1]ENDDPRDAT2  = [F:DEP]ENDDPRDAT
        [M:DER1]DPRRATFLG2  = [F:DEP]DPRRATFLG
        [M:DER1]DPRRAT2     = [F:DEP]DPRRAT
        [M:DER1]DPRBAS2     = [F:DEP]DPRBAS
        [M:DER1]ALWCOD2     = [F:DEP]ALWCOD
     Endif
    Endif
  Next I_PLN
  #<<<<<<<<<<<<<<<<<<<



  #-- Alimentation du tableau  (Période)
  Gosub TABLEAU_PAR_PERIODE From SUBDER

Return


#=====================================================================
#
$AVANTBOUT

 Case BOUT
   When "1" :
     Gosub TABLEAU_PAR_EXERCICE From SUBDER
   When "2" :
     Gosub TABLEAU_PAR_PERIODE  From SUBDER
 Endcase
 Affzo [M:DER1]

Return

#=====================================================================
#
$TABLEAU_PAR_PERIODE

 Local Integer IP
 Local Date    L_PERENDSOR

  [M:DER1]NBLIG1 = 0
  Effzo [M:DER1] 25
  IP = 1
  GAFFPER = G_OUI

  # En cas de sortie

  If ([F:FAS]ISSDAT = [0/0/0]) Then
    L_PERENDSOR = [0/0/0]
  Else
    Filter [DEP] Where AASREF=[M:DER1]AASREF and DPRPLN=G301CPT and FLGUPDISS = G_OUI
    Read[DEP]DEP0 Last
    Filter [DEP]
    If (fstat) Then  : GOK = 0 : Return : Endif
    L_PERENDSOR = [F:DEP]PERENDDAT
    If ([F:FAS]ISSDAT < [F:DEP]PERSTRDAT) Then
      # Cession retro active
      L_PERENDSOR = [F:DEP]PERENDDAT
    Else
      # Sortie dans la période d'enregistrement ou dans une période ulétérieure à celle d'enregistrement
      Filter [DEP] Where AASREF=[M:DER1]AASREF and DPRPLN=G301CPT and
&                        [F:FAS]ISSDAT >= PERSTRDAT and [F:FAS]ISSDAT <= PERENDDAT
      Read[DEP]DEP0 First
      Filter [DEP]
      If (fstat) Then  : GOK = 0 : Return : Endif
      L_PERENDSOR = [F:DEP]PERENDDAT
    Endif
  Endif

  GGESCRB = G_NON
  #>>>>>>>>>>>>>>>>>>>>
  For [DEP]DEP0 Where AASREF=[M:DER1]AASREF and DPRPLN=G301FIS

    # Pour positionner par défaut le curseur sur la période courante
    If ([F:DEP]PERENDDAT = GFINPERCPF) Then : [L]COULIG1=IP-1 : Endif

    #> Fiscal
    [F:DEPF] = [F:DEP]

    #-- Détermination de situation : réintégration
    If ( GGESCRB = G_NON  and
&       ([F:DEPF]LEGCUM    <> 0 or [F:DEPF]LEGRVECUM <> 0 or
&        [F:DEPF]PERLEGCUM <> 0 or [F:DEPF]PERLEGRVE <> 0 or
&        [F:DEPF]LEG       <> 0 or [F:DEPF]LEGRVE    <> 0     )) Then
      # Réintégration
      GGESCRB = G_OUI
    Endif

    #> Lecture Comptable
    Read [DEPC]DEP0=[M:DER1]AASREF;G301CPT;[F:DEP]FIYENDDAT;[F:DEP]PERENDDAT
    If (fstat) Then  : GOK = 0 : Break : Endif

    Gosub AFFICHE_LIGNE_DER_PERIODE

    IP += 1
  Next
  #<<<<<<<<<<<<<<<<<<<

  [M:DER1]NBLIG1 = IP-1

Return

#=====================================================================
#
$TABLEAU_PAR_EXERCICE

  Local Integer IE
  Local Date    L_FIYENDSOR
  [M:DER1]NBLIG1 = 0
  Effzo [M:DER1] 25
  IE  = 1
  GAFFPER = G_NON

  # En cas de sortie
  If ([F:FAS]ISSDAT = [0/0/0]) Then
    L_FIYENDDSOR = [0/0/0]
  Else
    # Sortie dans l'exercice d'enregistrement ou dans une période ultérieure à celle d'enregistrement
    Filter [DEP] Where AASREF=[M:DER1]AASREF and DPRPLN=G301CPT and
&                      [F:FAS]ISSDAT >= FIYSTRDAT and [F:FAS]ISSDAT <= FIYENDDAT
    Read[DEP]DEP0 First
    Filter [DEP]
    If (fstat) Then  : GOK = 0 : Return : Endif
    L_FIYENDSOR = [F:DEP]FIYENDDAT
  Endif


  #-- Alimentation du tableau de dérogatoire (Exercice)
  #>>>>>>>>>>>>>>>>>>>>
  GGESCRB = G_NON
  For [DEP]DEP0 Where AASREF=[M:DER1]AASREF and DPRPLN=G301FIS and FIYENDDAT = PERENDDAT

    [M:DER1]DERRVEISS (IE-1) = 0

    If ([F:DEP]FIYENDDAT = GFINEXECPF) Then
      [L]COULIG1=IE-1
    Endif

    #> Fiscal
    [F:DEPF] = [F:DEP]

    #-- Détermination de situation : réintégration
    If ( GGESCRB = G_NON  and
&       ([F:DEPF]LEGCUM    <> 0 or [F:DEPF]LEGRVECUM <> 0 or
&        [F:DEPF]PERLEGCUM <> 0 or [F:DEPF]PERLEGRVE <> 0 or
&        [F:DEPF]LEG       <> 0 or [F:DEPF]LEGRVE    <> 0    )) Then
      # Réintégration
      GGESCRB = G_OUI
    Endif

    #> Lecture Comptable
    Filter [DEPC] Where AASREF=[M:DER1]AASREF & DPRPLN=G301CPT & FIYENDDAT=[F:DEP]FIYENDDAT
    Read [DEPC]DEP0 Last
    Filter [DEPC]
    If (fstat) Then  : GOK = 0 : Break : Endif

    Gosub AFFICHE_LIGNE_DER_EXERCICE

    IE += 1
  Next
  #<<<<<<<<<<<<<<<<<<<

  [M:DER1]NBLIG1 = IE-1

Return


#=====================================================================
#
$AFFICHE_LIGNE_DER_PERIODE


  #-- Affichage des informations sur la ligne de l'écran DER1
  [M:DER1]FIYENDDAT(IP-1)  = [F:DEP]FIYENDDAT
  [M:DER1]PERENDDAT(IP-1)  = [F:DEP]PERENDDAT
  [M:DER1]PERENDDAT2(IP-1) = format$("D:" + GFMDAT4, [F:DEP]PERENDDAT)

  # *-- Réintégration fiscale --*
  # Solde début
    [M:DER1]CRBCUMSTR(IP-1) = ( [F:DEPF]LEGCUM    + [F:DEPF]PERLEGCUM ) -
&                             ( [F:DEPF]LEGRVECUM + [F:DEPF]PERLEGRVE )
  If (L_PERENDSOR <> [0/0/0] and L_PERENDSOR < [F:DEP]PERENDDAT ) Then
    [M:DER1]CRBCUMSTR(IP-1) = 0
  Endif

  # Réint. période
    [M:DER1]CRBAMT(IP-1)    = [F:DEPF]LEG - [F:DEPF]LEGRVE

  # Solde fin
  [M:DER1]CRBCUMEND(IP-1)   = [M:DER1]CRBCUMSTR(IP-1) + [M:DER1]CRBAMT(IP-1)

  # *-- Dérogatoire --*
  # Solde début
    [M:DER1]DERBLCSTR(IP-1) = ( [F:DEPC]LEGCUM    + [F:DEPC]PERLEGCUM )
&                           - ( [F:DEPC]LEGRVECUM + [F:DEPC]PERLEGRVE )
  If (L_PERENDSOR <> [0/0/0] and L_PERENDSOR < [F:DEP]PERENDDAT ) Then
    [M:DER1]DERBLCSTR(IP-1) -= [F:FAS]DERRVEISS
  Endif
  # Provision
  [M:DER1]DERPRVDPE(IP-1) = [F:DEPC]LEG
  # Reprise
  [M:DER1]DERRVEDPE(IP-1) = [F:DEPC]LEGRVE
  # Reprise / sortie
  If (L_PERENDSOR = [F:DEP]PERENDDAT ) Then
    [M:DER1]DERRVEISS(IP-1) = [F:FAS]DERRVEISS
  Else
    [M:DER1]DERRVEISS(IP-1) = 0
  Endif
  # Solde fin
  [M:DER1]DERBLC(IP-1)    = [M:DER1]DERBLCSTR(IP-1) + [F:DEPC]LEG - [F:DEPC]LEGRVE - [M:DER1]DERRVEISS(IP-1)


Return

#=====================================================================
#
$AFFICHE_LIGNE_DER_EXERCICE


  #-- Affichage des informations sur la ligne de l'écran DER1

  [M:DER1]FIYENDDAT(IE-1)  = [F:DEPC]FIYENDDAT
  [M:DER1]PERENDDAT(IE-1)  = [F:DEPC]PERENDDAT
  [M:DER1]PERENDDAT2(IE-1) = format$("D:" + GFMDAT4, [F:DEPC]PERENDDAT)


  # *-- Réintégration fiscale --*
  # Solde début
    [M:DER1]CRBCUMSTR(IE-1) = ( [F:DEPF]LEGCUM   - [F:DEPF]LEGRVECUM )

  # Réint. exercice
    [M:DER1]CRBAMT(IE-1)    = ( [F:DEPF]PERLEGCUM + [F:DEPF]LEG       )
&                           - ( [F:DEPF]PERLEGRVE + [F:DEPF]LEGRVE    )

  # Solde fin
  [M:DER1]CRBCUMEND(IE-1)   = [M:DER1]CRBCUMSTR(IE-1) + [M:DER1]CRBAMT(IE-1)

  # *-- Dérogatoire --*
  # Solde début
  [M:DER1]DERBLCSTR(IE-1) = [F:DEPC]LEGCUM - [F:DEPC]LEGRVECUM
  If (L_FIYENDSOR <> [0/0/0] and L_FIYENDSOR < [F:DEP]FIYENDDAT ) Then
    [M:DER1]DERBLCSTR(IE-1) -= [F:FAS]DERRVEISS
  Endif

  # Provision
  [M:DER1]DERPRVDPE(IE-1) = [F:DEPC]PERLEGCUM + [F:DEPC]LEG
  # Reprise
  [M:DER1]DERRVEDPE(IE-1) = [F:DEPC]PERLEGRVE + [F:DEPC]LEGRVE

  # Ces instructions permettent de ne présenter que la situation fin d'exercice et non pas le détail.
  # Si dans l'exercice un provision de 500 puis une reprise de 200 étaient constatées
  # seule une provision de 300 serait affichée et non pas le détail provision 500 reprise 200
#  If ( [M:DER1]DERPRVDPE(IE-1)-[M:DER1]DERRVEDPE(IE-1) <> 0 ) Then
#    If ( abs([M:DER1]DERPRVDPE(IE-1)) > abs([M:DER1]DERRVEDPE(IE-1)) ) Then
#      [M:DER1]DERPRVDPE(IE-1) -= [M:DER1]DERRVEDPE(IE-1)
#      [M:DER1]DERRVEDPE(IE-1)  = 0
#    Else
#      [M:DER1]DERRVEDPE(IE-1) -= [M:DER1]DERPRVDPE(IE-1)
#      [M:DER1]DERPRVDPE(IE-1)  = 0
#    Endif
#  Endif

   # Reprise / sortie
  If (L_FIYENDSOR = [F:DEP]FIYENDDAT ) Then
    [M:DER1]DERRVEISS(IE-1) = [F:FAS]DERRVEISS
    Else
    [M:DER1]DERRVEISS(IE-1) = 0
    Endif

  # Solde fin
  [M:DER1]DERBLC(IE-1)    = [M:DER1]DERBLCSTR(IE-1) + [M:DER1]DERPRVDPE(IE-1) - [M:DER1]DERRVEDPE(IE-1)
&                         - [M:DER1]DERRVEISS(IE-1)


Return

#=====================================================================
#
$SETBOUT

  # Désactivation de l'action Créer, Dupliquer, Supprimer, Changer de clé
  Call VIREBOUT(CHAINE,"CDAHM") From GOBJET

  # Positionnement du focus sur la ligne de l'exercice courant
  zonsui="NBLIG1("+num$([L]COULIG1)+")"

Return

#=====================================================================
#
$FERME
  If dim(GGESCRB)>0 : Kill GGESCRB : Endif
  If dim(GAFFPER)>0 : Kill GAFFPER : Endif
  If TUNNEL : Gosub RESTAURE_GLOBAL_SV From GLOBIMM : Endif
Return


######################################################################################
Subprog AV_NBLIG1
  If ( GAFFPER = G_NON ) Then
    #Chgfmt [M:DER1]PERENDDAT With "-D:"+GFMDAT4
    Chgfmt [M:DER1]PERENDDAT2 With "-K:10X"
  Else
    Chgfmt [M:DER1]PERENDDAT2 With "K:10X"
  Endif
  If GGESCRB = G_NON
    Chgfmt [M:DER1]CRBAMT    With "-Nz3:13.2#"
    Chgfmt [M:DER1]CRBCUMEND With "-Nz3:13.2#"
    Chgfmt [M:DER1]CRBCUMSTR With "-Nz3:13.2#"
  Endif
  If [F:FAS]ISSDAT = [0/0/0]
    Chgfmt [M:DER1]DERRVEISS With "-Nz3:13.2#"
  Endif
End

######################################################################################
Subprog AV_DPRRAT1(VALEUR)
Variable Decimal VALEUR
  If ( [M:DER1]DPRRATFLG1 = G_OUI) Then
    If ( GBROWS = 0 ) Then
      Chgstl [M:DER1]DPRRAT1 With "FORCAGE"
    Else
      Chgstl [M:DER1]DPRRAT1 With "TFORCAGE"
    Endif
  Else
    Chgstl [M:DER1]DPRRAT1 With ""
  Endif
End

######################################################################################
Subprog AV_DPRRAT2(VALEUR)
Variable Decimal VALEUR
  If ( [M:DER1]DPRRATFLG2 = G_OUI) Then
    If ( GBROWS = 0 ) Then
      Chgstl [M:DER1]DPRRAT2 With "FORCAGE"
    Else
      Chgstl [M:DER1]DPRRAT2 With "TFORCAGE"
    Endif
  Else
    Chgstl [M:DER1]DPRRAT2 With ""
  Endif
End

##########################################################################
Subprog AV_FIYENDDAT(VALEUR)
Variable Date    VALEUR

   #*FQ82871
   #* - on garde les pcolor pour l'appli. C/S
   #* - on ajoute un chgstl pour Convergence
  If ([M:DER1]FIYENDDAT(nolign-1) = GFINEXECPF and GAFFPER = G_NON) Then
    Chgstl NBLIG1(nolign-1)  With "AWARNLOW"
    pcolor =  GCOUL(3)
  Elsif([M:DER1]PERENDDAT(nolign-1) = GFINPERCPF and GAFFPER = G_OUI) Then
    Chgstl NBLIG1(nolign-1)  With "AWARNLOW"
    pcolor =  GCOUL(3)
  Else
     Chgstl NBLIG1(nolign-1)  With ""
    pcolor = GCOUL(0)
  Endif
End
