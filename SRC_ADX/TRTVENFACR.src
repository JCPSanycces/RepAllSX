#<AdxTL>@(#)9.0.0.0 $Revision$
#########################################################################
# TRTVENFACR
#########################################################################
# Issue 112661 - 20160204 by LD : [PERF] FUNPREDLV is slow
# Issue 118758 - 20170104 by LD : Slow performance in Sales order generation via webservices
# Issue X3-63661 - 20171204 by LD : Valuation fields creating a sale invoice.
# Issue X3-88932 - 20180607 by LD : SO via Web Services with Canadian taxes calculate incorrect totals

#########################################################################
# Action VISUVALTTC
#------------------------------------------------------------------------
# Concerne : la saisie des Devis / commandes / Livraisons
# Appel :    click droit champ TTC du bloc valorisation dans ecran lignes
#------------------------------------------------------------------------
# Si document en cours de m.a.j. : GREP <> ""
#    - Concerne : Devis / Commande / Livraion
#    - Garnissage ecran SIHV par calcul de la facture
# Si document visualisé uniquement : GREP = ""
#    - Garnissage ecran SIHV avec les tables SVCRFOOT et SVCRVAT
#########################################################################

$ACTION

Case ACTION
     When "OUVRE"      Gosub OUVRE
     When "DEBUT"      Gosub DEBUT
     When "FIN"        Gosub FIN
     When "FINSAI"     Gosub FINSAI
Endcase
Return


#########################################################################
$OUVRE

If GREP="" & !GCREPARBOU : Return : Endif

$OUVRE1
  # FGR 04/12/2014 : X3SUIVI103421 (d?but)
    If dim(GSZIMPSOH) >= 0 and GSZIMPSOH = "IMPSOH" Then
      Raz [M:SIH0]
      Raz [M:SIH1]
      Raz [M:SIH2]
      Raz [M:SIH4]
      Raz [M:SIHX]
      Raz [M:SIHV]
      Return
    Endif
  # FGR 04/12/2014 : X3SUIVI103421 (fin)
# Issue 112661
If GFONCTION = "FUNPREDLV"
    Raz [M:SIH0]
    Raz [M:SIH1]
    Raz [M:SIH2]
    Raz [M:SIH4]
    Raz [M:SIHX]
    Raz [M:SIHV]
    Return
Endif
# End issue 112661

# Issue 118758
If dim(GWEBSERV)=1 & GWEBSERV=1
    # Masks are opened the first time of the process (first webservice), for the other they are just raz
    # They will be closed at the end of the process (but not for each webservice)
    Local Integer ISIH0, ISIH1, ISIH2, ISIH4
    # Issue X3-88932
    # Local mask does not erase the mask
    # In case of several web services, masks keep datas of the previous webservice (because no more close mask)
#    If clalev ([M:SIH0]) : Raz [M:SIH0]
#    Else                 : Local Mask SIH0 [SIH0]
#    Endif
#    If clalev ([M:SIH1]) : Raz [M:SIH1]
#    Else                 : Local Mask SIH1 [SIH1]
#    Endif
#    If clalev ([M:SIH2]) : Raz [M:SIH2]
#    Else                 : Local Mask SIH2 [SIH2]
#    Endif
#    If clalev ([M:SIH4]) : Raz [M:SIH4]
#    Else                 : Local Mask SIH4 [SIH4]
#    Endif
    If !clalev ([M:SIH0]) : Local Mask SIH0 [SIH0] : Endif
    Raz [M:SIH0]
    If !clalev ([M:SIH1]) : Local Mask SIH1 [SIH1] : Endif
    Raz [M:SIH1]
    If !clalev ([M:SIH2]) : Local Mask SIH2 [SIH2] : Endif
    Raz [M:SIH2]
    If !clalev ([M:SIH4]) : Local Mask SIH4 [SIH4] : Endif
    Raz [M:SIH4]
    # End issue X3-88932

    Local Integer ISIHX, ISIHV
    If clalev ([M:SIHX]) : Raz [M:SIHX] : Endif
    If clalev ([M:SIHV]) : Raz [M:SIHV] : Endif

    Return
Endif
# End issue 118758

Local Integer ISIH0, ISIH1, ISIH2, ISIH4
If clalev ([M:SIH0]) : ISIH0=1 : Local Mask SIH0 [JIH0] : [M:JIH0]=[M:SIH0] : Raz [M:SIH0]
   Else              :           Local Mask SIH0 [SIH0]
Endif
If clalev ([M:SIH1]) : ISIH1=1 : Local Mask SIH1 [JIH1] : [M:JIH1]=[M:SIH1] : Raz [M:SIH1]
   Else              :           Local Mask SIH1 [SIH1]
Endif
If clalev ([M:SIH2]) : ISIH2=1 : Local Mask SIH2 [JIH2]

  #(MGG 08/05/2017) X3-33114
  #[M:JIH2]=[M:SIH2]
  Raz [M:JIH2]
  Transmask [M:SIH2] To [M:JIH2]
  #END(MGG 08/05/2017) X3-33114
  Raz [M:SIH2]
   Else              :           Local Mask SIH2 [SIH2]
Endif
If clalev ([M:SIH4]) : ISIH4=1 : Local Mask SIH4 [JIH4]
  #(MGG 08/05/2017) X3-33114
  #[M:JIH4]=[M:SIH4]
  Raz[M:JIH4]
  Transmask [M:SIH4] To [M:JIH4]
  #END (MGG 08/05/2017) X3-33114

  Raz [M:SIH4]
   Else              :           Local Mask SIH4 [SIH4]
Endif

If !(GACTION="SAIWRKPLN" & GFONCTION = "GESPOH")    # SAM 120225 memory issue JUCON 22/12/2016
# Bug 66823
  Local Integer ISIHX, ISIHV
  If clalev ([M:SIHX]) : ISIHX=1 : Local Mask SIHV [JIHX]
    #(MGG 08/05/2017) X3-33114
    #[M:JIHX]=[M:SIHX]
    Raz [M:JIHX]
    Transmask [M:SIHX] To [M:JIHX]
    #END(MGG 08/05/2017) X3-33114
    Raz [M:SIHX]
  Endif
  If clalev ([M:SIHV]) : ISIHV=1 : Local Mask SIHV [JIHV]
    #(MGG 08/05/2017) X3-33114
    #[M:JIHV]=[M:SIHV]
    Raz [M:JIHV]
    Transmask [M:SIHV] To [M:JIHV]
    #END(MGG 08/05/2017) X3-33114
    Raz [M:SIHV]

  Endif
# Bug 66823
Endif     # SAM 120225 memory issue JUCON 22/12/2016

Return

#########################################################################
$FIN

#If GREP="" & !GCREPARBOU : Return : Endif     :  # 101874 : V9 : Taxe code control
If WSVG_GREP="" & !GCREPARBOU : Return : Endif :  # 101874 : GREP is raz by GSAISIE after DEBUT, we can't test it

$FIN1
Case [M:SIH0]ORICLC
  When "GESSQH"
       If dim([M:SQH2]QUOINVNOT)>0 : [M:SQH2]QUOINVNOT=[M:SIHV]INVNOT : Affzo [M:SQH2]QUOINVNOT : Endif
       If dim([M:SQH2]QUOINVATI)>0 : [M:SQH2]QUOINVATI=[M:SIHV]INVATI : Affzo [M:SQH2]QUOINVATI : Endif
  When "GESSOH"
       If dim([M:SOH4]ORDINVNOT)>0 : [M:SOH4]ORDINVNOT=[M:SIHV]INVNOT : Affzo [M:SOH4]ORDINVNOT : Endif
       If dim([M:SOH4]ORDINVATI)>0 : [M:SOH4]ORDINVATI=[M:SIHV]INVATI : Affzo [M:SOH4]ORDINVATI : Endif
  When "GESSDH", "GESSDHF"
       If dim([M:SDH1]DLVINVNOT)>0 : [M:SDH1]DLVINVNOT=[M:SIHV]INVNOT : Affzo [M:SDH1]DLVINVNOT : Endif
       If dim([M:SDH1]DLVINVATI)>0 : [M:SDH1]DLVINVATI=[M:SIHV]INVATI : Affzo [M:SDH1]DLVINVATI : Endif
  # 91606 :(04/08/14) Transportation notes (Sales part dev)
  # Valorisation from TNH object only
  When "GESTNH"
       If dim([M:TNH1]DLVINVNOT)>0 : [M:TNH1]DLVINVNOT=[M:SIHV]INVNOT : Affzo [M:TNH1]DLVINVNOT : Endif
       If dim([M:TNH1]DLVINVATI)>0 : [M:TNH1]DLVINVATI=[M:SIHV]INVATI : Affzo [M:TNH1]DLVINVATI : Endif
  # 91606 :(04/08/14) Transportation notes (Sales part dev)
Endcase

# FGR 04/12/2014 : X3SUIVI103421 (début)
  If dim(GSZIMPSOH) >= 0 and GSZIMPSOH = "IMPSOH" Then
    Return
  Endif
# FGR 04/12/2014 : X3SUIVI103421 (fin)

# Issue 112661
If GFONCTION = "FUNPREDLV" Return Endif
# End issue 112661

# Issue 118758
# Masks will be closed at the end of the process (but not for each webservice)
If dim(GWEBSERV)=1 & GWEBSERV=1
    Return
Endif
# End issue 118758

$FIN_IMPORT  # FGR 04/12/2014 : X3SUIVI103421

# Bug 66823
#---CPO 73887 En création de pièce depuis les clients (GFONC1="GESBPC") il ne faut pas entrer dans le if
#If [M:SIH0]ORICLC<>GFONC1
# Bug 75398 :
# En gestion liv, Il ne faut pas restituer les anciennes valeurs si GFONC1<>ORICLC car GFONC1=GESSDH et ORICLC=GESSDHF
# Le pb écrasement valorisation ne se pose qu'en gestion facture
#If (GFONC1<>"GESBPC") and [M:SIH0]ORICLC<>GFONC1
If (GFONC1="GESSIH") and [M:SIH0]ORICLC<>GFONC1
#---CPO fin
  #(MGG 08/05/2017) X3-33114
    If ISIHX
      #[M:SIHX]=[M:JIHX]
      Raz [M:SIHX]
      Transmask [M:JIHX] To [M:SIHX]
      Close Mask [JIHX]
    Endif
    If ISIHV
     #[M:SIHV]=[M:JIHV]
     Raz [M:SIHV]
     Transmask [M:JIHV] To [M:SIHV]
     Close Mask [JIHV]
    Endif
Endif
    #(MGG 08/05/2017) X3-33114
# Bug 66823

If ISIH0 : [M:SIH0]=[M:JIH0] : Close Mask [JIH0]  Else  Close Mask [SIH0] : Endif
If ISIH1 : [M:SIH1]=[M:JIH1] : Close Mask [JIH1]  Else  Close Mask [SIH1] : Endif
If ISIH2
  #(MGG 08/05/2017) X3-33114
  #[M:SIH2]=[M:JIH2]
  Raz [M:SIH2]
  Transmask [M:JIH2] To [M:SIH2]
  #END(MGG 08/05/2017) X3-33114
  Close Mask [JIH2]
Else
  Close Mask [SIH2]
Endif
If ISIH4

 #(MGG 08/05/2017) X3-33114
 #[M:SIH4]=[M:JIH4]
   Raz [M:SIH4]
   Transmask [M:JIH4] To [M:SIH4]
   Close Mask [JIH4]
  #END (MGG 08/05/2017) X3-33114
Else
  Close Mask [SIH4]
Endif

Return

#########################################################################
$FINSAI
#--- Restitution des formats et libelles pour affichage champs analytiques
#For JL=1 To dim(GFMTDIE) : GFMTDIE(JL)=S_GFMTDIE(JL) : Next JL
#For JL=1 To dim(GCOLDIE) : GCOLDIE(JL)=S_GCOLDIE(JL) : Next JL
Return

#########################################################################
$DEBUT
Local Char WSVG_GREP(1)   :  # 101874 : V9 : Taxe code control
WSVG_GREP=GREP            :  # 101874 : GREP is raz by GSAISIE after DEBUT, we need to save it before

Raz [M:SIHV]
#--- Champs analytiques des éléments facturation mis en invisble
If dim([M:SIHV]DSP)>0      : Chgfmt [M:SIHV]DSP      With "-K:1X" : Endif
#Local Char S_GFMTDIE (15) (1..dim(GFMTDIE))
#Local Char S_GCOLDIE (20) (1..dim(GCOLDIE))

# ACA (2009-07-17) Bug number : comment
#For JL=1 To dim(GFMTDIE) : S_GFMTDIE(JL)=GFMTDIE(JL) : GFMTDIE(JL)="-K:1X" : Next JL
#For JL=1 To dim(GCOLDIE) : S_GCOLDIE(JL)=GCOLDIE(JL) : Next JL
#Raz GCOLDIE

If GFONCTION<>"GESSIH" : Diszo [M:SIHV]INVATI : Endif #Gbo-Lta

If GREP="" & !GCREPARBOU
   Gosub CHARG_SIHV                          : # chargement SIHV sans calcul
 Else
   [M:SIH0]ORICLC=PARAM(1)                   : # chargement SIHV avec calcul
   Gosub OUVRE_SIHX      From TRTVENFACC
   # Appel NEW_FACTURE qui charge SIH4 à partir tableau du tableau des lignes (SQH2 SOH4 SDH1)
   # Puis pour chaque ligne PLUS_LIGNE : En plus ds tableau des taxes XV et tableau des frais XF
   # Puis NEW_REGIME
   Gosub CHARG_TABLEAUX  From TRTVENFACC     : # Appel NEW_FACTURE qui charge SIH4 à partir tableau des lignes
   If [M:SIH4]NBLIG>0
   # Tax by document
      # If func AFNC.ACTIV("LTA") & GLOCUSATAX   # 106867.o
      If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
        GTAXBYDOC = 1
      Endif
      Gosub CAL_FACTURE     From TRTVENFACC
   Endif
Endif

# Issue X3-51824 - 2017-08-04 by CPO : Analytical sections on footer elements for sales documents
If dim([M:SIHV]GREPFLG  )>0 : [M:SIHV]GREPFLG   = GREP        : Endif
If dim([M:SIHV]NOUPDCCEFLG)>0
  [M:SIHV]NOUPDCCEFLG = [V]CST_ANO
  Case PARAM(1)
    When "GESSQH"
    When "GESSOH"
    When "GESSDH","GESSDHF"
         #--To prevent changing footer elt's analytical section on validated deliveries
         If [M:SDH1]CFMFLG = 2 : [M:SIHV]NOUPDCCEFLG = [V]CST_AYES : Endif
  Endcase
Endif
# End issue X3-51824

# ACA (2009-07-17)
Gosub AFF_TITCOL From SUBSIHV

Gosub LIENS_DIE_FOOT From SUBSIHV

#X3-107954 (LCC-19/09/18) Add an icon on sales invoices Valuation tab
If GFONCTION<>"GESSIH": Chgfmt [M:SIHV]VALUATION With "-K:3X": Endif

Affzo [SIHV]

If func AFNC.ACTIV("LTA")             # Setup to call SST Detail Tax display
  Call LTAGREP From TRTTAXSST   # 106867.n
  # Call LTAGREP From TRTTAXUSA   # 106867.o
Endif


Return

#------------------------------------------------------------------------
# Appellé dans NEW_FACTURE de TRTVENFACC :
#  - charge les masques SIH0 SIH1 SIH2 dans le contexte devis / cde / liv
#    afin de simuler un contexte facture pour le calcul
#------------------------------------------------------------------------

$CHARG_MSKSIH
Local Integer JL, JL1, JL2, JLNOL, JLSTAT

Case [M:SIH0]ORICLC
  When "GESSQH" : Gosub GESSQH  : # Gestion des devis
  When "GESSOH" : Gosub GESSOH  : # Gestion des commandes
  When "GESSDH", "GESSDHF" : Gosub GESSDH  : # Gestion des livraisons
  # 91606 :(04/08/14) Transportation notes (Sales part dev)
  # Valorisation from TNH object only
  When "GESTNH" : Gosub GESTNH  : # Transportation notes management
  # 91606 :(04/08/14) Transportation notes (Sales part dev)
Endcase

If dim([M:SIH2]CUR)>0 : [M:SIHX]VCUR=[M:SIH2]CUR : Endif

If [M:SIH0]ORICLC=""        : # Bug 63423
    [M:SIHX]NUM=[M:SIH0]NUM : # Bug 62033
    [M:SIHX]DAT=[M:SIH0]INVDAT # Issue 114057 - 2016-01-29 by CPO : Error message on analytical section with correct date
    #--For X3-51824 :
    #--needed in case of entering an invoice in update, adding a new value for an invoice footer elt and updating this elt's analytical section
    #--if user goes back to the invoice and abandon, there is a record created in CPTANALIN for the invoice number but with VCRTYP=1
    #--this is due to the affzo [M:SIHV]1-99 in AP_NBFAC for SUBSIH that triggers D_VCRTYP and as varinit([M]VCRTYP)=0 it is set to 1
    #--the varinit is 0 due to the Raz [M:SIHX] before doing the Transmask in $CAL_FACTURE.TRTVENFACC called after the present sub in AP_NBFAC.
    #--Tricky one !!!
    [M:SIHX]VCRTYP=4           # Issue X3-51824 - 2017-08-04 by CPO : Analytical sections on footer elements for sales documents
Else
    # ACA (2009-09-17) Lot S03
    If dim([F:SOH]SOHNUM)>0 & [F:SOH]SOHNUM<>""
      [M:SIHX]NUM = [F:SOH]SOHNUM : [M:SIHX]VCRTYP=20
    Elsif dim([F:SQH]SQHNUM)>0  & [F:SQH]SQHNUM<>""
      [M:SIHX]NUM = [F:SQH]SQHNUM : [M:SIHX]VCRTYP=1
    Elsif dim([F:SDH]SDHNUM)>0  & [F:SDH]SDHNUM<>""
      [M:SIHX]NUM = [F:SDH]SDHNUM : [M:SIHX]VCRTYP=2
    Endif
Endif

If [M:SIH0]ORICLC<>""
   GPOINT="CHARG_MSKSIH" : Gosub ENTREE From EXEFNC
Endif

# --- Chargement de [M:SIH4]NBLIG
Raz [M:SIH4]NBLIG
For JL=0 To dim([M:SIH4]ITMREF)-1
    If [M:SIH4]ITMREF(JL)<>"" : [M:SIH4]NBLIG=JL+1 : Endif
    #If [M:SIH4]ITMREF(JL)=""  : Break              : Endif                                                : # Bug 69529
    If [M:SIH4]ITMREF(JL)="" & JL=dim([M:SIH4]ITMREF)-1 Break Endif                                        : # Bug 73675
    If [M:SIH4]ITMREF(JL)="" & sigma(JL+1, dim([M:SIH4]ITMREF)-1,[M:SIH4]ITMREF(indcum)) = "" Break Endif  : # Bug 69529
Next JL

Return

#------------------------------------------------------------------------
$GESSQH
#--- entete

# Issue X3-33114 - 2017-05-22 by CPO : Replace transclass with Transmask in sales process (transmask cannot be used here)
[M:SIH0]=[M:SQH0] : [M:SIH0]=[M:SQH1] : [M:SIH0]=[M:SQH3]

[M:SIH0]INVDAT= [M:SQH0]QUODAT
[M:SIH0]NUM   = [M:SQH0]SQHNUM : # En cas d'erreur ds le calcul, pour mettre le n?doc ds la trace (migration V5-V6)

# Issue X3-33114 - 2017-05-22 by CPO : Replace transclass with Transmask in sales process (transmask cannot be used here)
[M:SIH1]=[M:SQH0] : [M:SIH1]=[M:SQH1] : [M:SIH1]=[M:SQH3]
# Issue X3-33114 - 2017-05-22 by CPO : Replace transclass with Transmask in sales process (transmask cannot be used here)
[M:SIH2]=[M:SQH0] : [M:SIH2]=[M:SQH1] : [M:SIH2]=[M:SQH3]


Gosub GESXXX
#    charger les elts du devis dans les elts correspondants de la facture
For JL=0 To dim([M:SQH3]INVDTA)-1
  If [M:SQH3]INVDTA(JL)=0 : Break : Endif
  JL1=find([M:SQH3]INVDTA(JL),[M:SIH2]INVDTA)
  If JL1 : [M:SIH2]INVDTAAMT(JL1-1)=[M:SQH3]INVDTAAMT(JL) : Endif
Next JL

#--- lignes

# Issue X3-63661
# In order Transmask works on a grid, NBLIG for the origin grid has to be up to date
# In some contexts (APRES_NBLIG action for exemple) NBLIG is not yet updated
Local Integer WI, WSVGNBLIG
WSVGNBLIG=[M:SQH2]NBLIG
WI=sigma(0,dim([M:SQH2]ITMREF)-1,[M:SQH2]ITMREF(indcum)<>"")
If WI=[M:SQH2]NBLIG+1 & WI<dim([M:SQH2]ITMREF)-1
    [M:SQH2]NBLIG+=1
Endif
# End Issue X3-63661

#(MGG 08/05/2017) X3-33114
#[M:SIH4]=[M:SQH2]
Transmask [M:SQH2] To [M:SIH4]
#END (MGG 08/05/2017) X3-33114

# Issue X3-63661
[M:SQH2]NBLIG=WSVGNBLIG
# End Issue X3-63661

For JL=0 To dim([M:SIH4]ITMREF)-1
    #If [M:SIH4]ITMREF(JL)="" : Break : Endif                                                              : # Bug 69529
    If [M:SIH4]ITMREF(JL)="" & JL=dim([M:SIH4]ITMREF)-1 Break Endif                                        : # Bug 73675
    If [M:SIH4]ITMREF(JL)="" & sigma(JL+1, dim([M:SIH4]ITMREF)-1,[M:SIH4]ITMREF(indcum)) = "" Break Endif  : # Bug 69529
    [M:SIH4]QTYSTU(JL)=[M:SQH2]QTY(JL)*[M:SQH2]SAUSTUCOE(JL)
Next JL

Return

#------------------------------------------------------------------------
$GESSOH
#--- entete

# Issue X3-33114 - 2017-05-22 by CPO : Replace transclass with Transmask in sales process (transmask cannot be used here)
[M:SIH0]=[M:SOH0] : [M:SIH0]=[M:SOH1] : [M:SIH0]=[M:SOH2] : [M:SIH0]=[M:SOH3]

[M:SIH0]INVDAT= [M:SOH0]ORDDAT
[M:SIH0]NUM   = [M:SOH0]SOHNUM : # En cas d'erreur ds le calcul, pour mettre le n?doc ds la trace (migration V5-V6)

# Issue X3-33114 - 2017-05-22 by CPO : Replace transclass with Transmask in sales process (transmask cannot be used here)
[M:SIH1]=[M:SOH0] : [M:SIH1]=[M:SOH1] : [M:SIH1]=[M:SOH2] : [M:SIH1]=[M:SOH3]
# Issue X3-33114 - 2017-05-22 by CPO : Replace transclass with Transmask in sales process (transmask cannot be used here)
[M:SIH2]=[M:SOH0] : [M:SIH2]=[M:SOH1] : [M:SIH2]=[M:SOH2] : [M:SIH2]=[M:SOH3]

Gosub GESXXX
#    charger les elts de la commande dans les elts correspondants de la facture
For JL=0 To dim([M:SOH3]INVDTA)-1
  If [M:SOH3]INVDTA(JL)=0 : Break : Endif
  JL1=find([M:SOH3]INVDTA(JL),[M:SIH2]INVDTA)
  If JL1 : [M:SIH2]INVDTAAMT(JL1-1)=[M:SOH3]INVDTAAMT(JL) : Endif
Next JL

#--- lignes

# Issue X3-63661
# In order Transmask works on a grid, NBLIG for the origin grid has to be up to date
# In some contexts (APRES_NBLIG action for exemple) NBLIG is not yet updated
Local Integer WI, WSVGNBLIG
WSVGNBLIG=[M:SOH4]NBLIG
WI=sigma(0,dim([M:SOH4]ITMREF)-1,[M:SOH4]ITMREF(indcum)<>"")
If WI=[M:SOH4]NBLIG+1 & WI<dim([M:SOH4]ITMREF)-1
    [M:SOH4]NBLIG+=1
Endif
# End Issue X3-63661

#(MGG 08/05/2017) X3-33114
#[M:SIH4]=[M:SOH4]
Transmask [M:SOH4] To [M:SIH4]
#END (MGG 08/05/2017) X3-33114

# Issue X3-63661
[M:SOH4]NBLIG=WSVGNBLIG
# End Issue X3-63661

Return

#------------------------------------------------------------------------
$GESSDH

#--- entete

# Issue X3-33114 - 2017-05-22 by CPO : Replace transclass with Transmask in sales process (transmask cannot be used here)
[M:SIH0]=[M:SDH0] : [M:SIH0]=[M:SDH1] : [M:SIH0]=[M:SDH2] : [M:SIH0]=[M:SDH3]

[M:SIH0]INVDAT= [M:SDH1]DLVDAT
[M:SIH0]NUM   = [M:SDH0]SDHNUM : # En cas d'erreur ds le calcul, pour mettre le n?doc ds la trace (migration V5-V6)

# Issue X3-33114 - 2017-05-22 by CPO : Replace transclass with Transmask in sales process (transmask cannot be used here)
[M:SIH1]=[M:SDH0] : [M:SIH1]=[M:SDH1] : [M:SIH1]=[M:SDH2] : [M:SIH1]=[M:SDH3]
# Issue X3-33114 - 2017-05-22 by CPO : Replace transclass with Transmask in sales process (transmask cannot be used here)
[M:SIH2]=[M:SDH0] : [M:SIH2]=[M:SDH1] : [M:SIH2]=[M:SDH2] : [M:SIH2]=[M:SDH3]

# 102423 : Belgium Early discounts
# Early discount rate determination
If find(GDEPMGTMOD, 1,5)
    Call ALIDISVAT (5, [M:SIH2]DEP, GBIDI1,[M:SIH2]DEPRAT) From SUBTDA
Endif
#  102423

# ACA - Gestion particulière de la valorisation des livraisons
# car des éléments peuvent venir de la commande.

# ACA - Chargement de la structure des éléments de facturation de la facture
Local Integer NBPOSTE : NBPOSTE=dim([M:SIH2]INVDTA)
Call SAISFOOT (8,"SIH2",NBPOSTE,[M:SIH2]CURTYP,[F:BPC]CUR,
&              [M:SIH2]CUR,"NON") From SUBSFIT
[M:SIH2]NBFAC = NBPOSTE

# ACA - ON ENLèVE L'ancien systeme de chargement des éléments de facturation
# Gosub GESXXX
#    CHARGER LES ELTS DE LA LIVRAISON DANS LES ELTS CORRESPONDANTS DE LA FACTURE
# For JL=0 To dim([M:SDH2]INVDTA)-1
#   If [M:SDH2]INVDTA(JL)=0 : Break : Endif
#   JL1=find([M:SDH2]INVDTA(JL),[M:SIH2]INVDTA)
#   If JL1 : [M:SIH2]INVDTAAMT(JL1-1)=[M:SDH2]INVDTAAMT(JL) : Endif
# Next JL
#Endif

#--- lignes

# Issue X3-63661
# In order Transmask works on a grid, NBLIG for the origin grid has to be up to date
# In some contexts (APRES_NBLIG action for exemple) NBLIG is not yet updated
Local Integer WI, WSVGNBLIG
WSVGNBLIG=[M:SDH1]NBLIG
WI=sigma(0,dim([M:SDH1]ITMREF)-1,[M:SDH1]ITMREF(indcum)<>"")
If WI=[M:SDH1]NBLIG+1 & WI<dim([M:SDH1]ITMREF)-1
    [M:SDH1]NBLIG+=1
Endif
# End Issue X3-63661

#(MGG 08/05/2017) X3-33114
#[M:SIH4]=[M:SDH1]
Transmask [M:SDH1] To [M:SIH4]
#END (MGG 08/05/2017) X3-33114

# Issue X3-63661
[M:SDH1]NBLIG=WSVGNBLIG
# End Issue X3-63661

# FGR 19/03/2014 : X3SUIVI98056 (début)
  If GWEBSERV Then
    If clalev([M:SFIT])=0 Then
      Local Mask SFITRF [SFIT]
      Raz [M:SFIT]
    Endif
  Endif
# FGR 19/03/2014 : X3SUIVI98056 (fin)

# ACA - On simule un picking livraison vers facture, pour utiliser
# le systeme SFITRF
# Sauvegarde du SFITRF actuel
If clalev([M:SFI2])=0 : Local Mask SFITRF [SFI2] Endif

#(MGG 08/05/2017) X3-33114
#[M:SFI2]=[M:SFIT]
Raz [M:SFI2]
Transmask [M:SFIT] To [M:SFI2]
#(MGG 08/05/2017) X3-33114

# Ouverture du tableau de stockage des éléments facture
Local Char EXGREP: EXGREP=GREP : GREP="C"
Local Char SFIT_OBJ : SFIT_OBJ="SIH"
Gosub INIT_SFIT From SUBSFIT

Call NEW_SFIT ("M","SIH2",[M:SIH2]CUR,[M:SIH0]BPCINV,[M:SIH1]BPCORD,[M:SIH0]INVDAT) From SUBSFIT
# Copier dans un faux F, car SUBSFIT travaille avec classe F
# Si [M:SIH0]ORICLC="GESSDHF", c'est qu'on est dans INI_MOD ou INI_CRE, donc copie inutile et même dangereuse
If [M:SIH0]ORICLC="GESSDH"
    Raz [F:SDH]
    [F:SDH]=[M:SDH0]
    [F:SDH]=[M:SDH1]
    [F:SDH]=[M:SDH2]
    [F:SDH]=[M:SDH3]
    For JL=0 To dim([M:SDH2]INVDTA)-1
        If [M:SDH2]INVDTA(JL)=0 : Break : Endif
        JL1=find([M:SDH2]INVDTA(JL),[F:SDH]INVDTA)
        If JL1 : [F:SDH]INVDTAAMT(JL1-1)=[M:SDH2]INVDTAAMT(JL) : Endif
    Next JL
Endif
If [F:SDH]SDHNUM=""
    [F:SDH]SDHNUM="DUMMY"
Endif
Integer EXNOLIGN : EXNOLIGN=nolign
nolign=1
Local Char CURSOH(GLONVCR)
For JL=0 To dim([M:SIH4]ITMREF)-1
    #If [M:SIH4]ITMREF(JL)="" Break Endif
    If [M:SIH4]ITMREF(JL)="" & JL=dim([M:SIH4]ITMREF)-1 Break Endif                                        : # Bug 73675
    If [M:SIH4]ITMREF(JL)="" & sigma(JL+1, dim([M:SIH4]ITMREF)-1,[M:SIH4]ITMREF(indcum)) = "" Break Endif  : # Bug 69529
    Raz [F:SDD]
    [F:SDD]=[M:SDH1]
    # Charge SOH
    If [M:SDH1]XSOHNUM<>""
        [L]CURSOH=[M:SDH1]XSOHNUM
    Elsif [M:SDH0]SOHNUM<>""
        [L]CURSOH=[M:SDH0]SOHNUM
    Else
        Raz [L]CURSOH
    Endif
    If [L]CURSOH<>""
        If [F:SOH]SOHNUM<>[L]CURSOH
            Read [SOH]SOH0=[L]CURSOH
        Endif
    Else
        Raz [F:SOH]
    Endif
    Gosub SDH_SIH_PLUS From SUBSFIT
    #If GERR <> 0 Then          # FGR 19/08/2014 : X3SUIVI100811
    If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
      OK = 0
      Break
    Endif
    Call MAJ_SFIT_QTY("M", "SIH2", [F:SDH]SDHNUM, [M:SIH4]QTYSTU(JL), [M:SIH4]QTY(JL) * [M:SIH4]NETPRINOT(JL), [M:SIH4]DSPLINWEI(JL), [M:SIH4]DSPLINVOL(JL)) From SUBSFIT
    nolign+=1
Next JL
#If GERR <> 0 Then          # FGR 19/08/2014 : X3SUIVI100811
If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
  Return
Endif
nolign=EXNOLIGN
Call SDH_SIH_CALCUL From SUBSFIT
GREP=EXGREP
If [F:SDH]SDHNUM="DUMMY"
    Raz [F:SDH]SDHNUM
Endif
# On restaure le masque SFIT utilisé pour les transferts des éléments de facturation
#(MGG 08/05/2017) X3-33114
#[M:SFIT]=[M:SFI2]
Raz [M:SFIT]
Transmask [M:SFI2] To [M:SFIT]
#END(MGG 08/05/2017) X3-33114

Return

# 91606 :(04/08/14) Transportation notes (Sales part dev)
$GESTNH
#--- entete

# Issue X3-33114 - 2017-05-22 by CPO : Replace transclass with Transmask in sales process (transmask cannot be used here)
[M:SIH0]=[M:TNH0] : [M:SIH0]=[M:TNH1] : [M:SIH0]=[M:TNH2] #: [M:SIH0]=[M:TNH3]

[M:SIH0]INVDAT= [M:TNH1]DLVDAT
[M:SIH0]NUM   = [M:TNH0]TNHNUM : # En cas d'erreur ds le calcul, pour mettre le n?doc ds la trace (migration V5-V6)
# Issue X3-33114 - 2017-05-22 by CPO : Replace transclass with Transmask in sales process (transmask cannot be used here)
[M:SIH1]=[M:TNH0] : [M:SIH1]=[M:TNH1] : [M:SIH1]=[M:TNH2] #: [M:SIH1]=[M:TNH3]
# Issue X3-33114 - 2017-05-22 by CPO : Replace transclass with Transmask in sales process (transmask cannot be used here)
[M:SIH2]=[M:TNH0] : [M:SIH2]=[M:TNH1] : [M:SIH2]=[M:TNH2] #: [M:SIH2]=[M:TNH3]

Gosub GESXXX
#    charger les elts de la commande dans les elts correspondants de la facture
For JL=0 To dim([M:TNH2]INVDTA)-1
  If [M:TNH2]INVDTA(JL)=0 : Break : Endif
  JL1=find([M:TNH2]INVDTA(JL),[M:SIH2]INVDTA)
  If JL1 : [M:SIH2]INVDTAAMT(JL1-1)=[M:TNH2]INVDTAAMT(JL) : Endif
Next JL

#--- lignes

#(MGG 08/05/2017) X3-33114
#[M:SIH4]=[M:TNH1]
# Issue X3-33114 - 2017-05-22 by CPO : Replace transclass with Transmask in sales valuation process (no need to Raz SIH4->already done)
Transmask [M:TNH1] To [M:SIH4]
#END (MGG 08/05/2017) X3-33114

Return
# 91606 :(04/08/14) Transportation notes (Sales part dev)

#------------------------------------------------------------------------
$GESXXX
#-- type de cours
[M:SIH2]CURTYP= [M:SIH0]CHGTYP
[M:SIHX]VCUR=[M:SIH2]CUR
#-- init du bloc saisie des elts facturation (doit etre idem au bloc en saisie facture)
Raz [M:SIH2]NBFAC, [M:SIH2]INVDTA, [M:SIH2]SHO, [M:SIH2]INVDTAAMT, [M:SIH2]AMTCOD, [M:SIH2]DEFVAL
Raz JLNOL

# 102423 : Belgium Early discounts
# Early discount rate determination
If find(GDEPMGTMOD, 1,5)
    Call ALIDISVAT (5, [M:SIH2]DEP, GBIDI1,[M:SIH2]DEPRAT) From SUBTDA
Endif
#  102423

#
For JL=0 To dim([M:SIHX]XFNUM)-1

  If [M:SIHX]DACINV(JL) <>0 & [M:SIHX]PROCOD(JL)=1 & [M:SIHX]DACINV(JL)<dim([M:SIH2]INVDTA)+1
     JLNOL +=1
     JL1=[M:SIHX]DACINV(JL)-1              : # indice dans tableau elts facture
     [M:SIH2]INVDTA(JL1)= [M:SIHX]XFNUM(JL)
     [M:SIH2]SHO(JL1)   = [M:SIHX]XFSHO(JL)
     [M:SIH2]AMTCOD(JL1)= [M:SIHX]AMTCOD(JL)
     [M:SIH2]DEFVAL(JL1)= [M:SIHX]DEFVAL(JL)

#      initialiser a partir de la valeur par defaut ?
     If [M:SIH2]DEFVAL(JL1)<>0
        If [M:SIH2]AMTCOD(JL1)= 1              : # c est un %
           [M:SIH2]INVDTAAMT(JL1)= [M:SIH2]DEFVAL(JL1)
        Endif
        If [M:SIH2]AMTCOD(JL1)= 2              : # c est un montant
           If GSYSCUR<>[M:SIH2]CUR             : # Issue 74556 - Optimisation
               Call CONVERT(GSYSCUR,[M:SIH2]CUR,GLOCALDEV,[M:SIH0]CHGTYP,[M:SIH0]INVDAT,
&                          [M:SIH2]DEFVAL(JL1),[M:SIH2]INVDTAAMT(JL1),JLSTAT) From TRTDEV
               If JLSTAT : Raz [M:SIH2]INVDTAAMT(JL1) : Endif
           Else
               [M:SIH2]INVDTAAMT(JL1)=[M:SIH2]DEFVAL(JL1)
           Endif
        Endif
     Endif

#      initialiser a partir des elts saisis dans le client
#      (uniquement si non saisis en commande)
     If [M:SIHX]DACBPC(JL)<>0
        If ([M:SIH0]ORICLC="GESSQH" & [M:SIHX]DACORD(JL)=0) |
&          ([M:SIH0]ORICLC="GESSOH" & [M:SIHX]DACORD(JL)=0) |
&          ([M:SIH0]ORICLC="GESSDH" & [M:SIHX]DACDLV(JL)=0) |
&          ([M:SIH0]ORICLC="GESSDHF" & [M:SIHX]DACDLV(JL)=0)
           If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
           If [F:BPC]BPCNUM<>[M:SIH1]BPCORD       : # Issue 74556 - Optimisation
               Read [BPC]BPC0=[M:SIH1]BPCORD
               If fstat Raz [F:BPC] Endif
           Endif
              Raz [M:SIH2]INVDTAAMT(JL1)          : # Issue 74556 - Optimisation
              JL2=find([M:SIH2]INVDTA(JL1),[F:BPC]INVDTA)
              If JL2 & [F:BPC]INVDTAAMT(JL2-1) <> 0   : # Issue 74556 - Optimisation
                 If [M:SIH2]AMTCOD(JL1)= 1        : # c est un %
                    [M:SIH2]INVDTAAMT(JL1)= [F:BPC]INVDTAAMT(JL2-1)
                 Endif
                 If [M:SIH2]AMTCOD(JL1)= 2        : # c est un montant
                    If [F:BPC]CUR=[M:SIH2]CUR
                       [M:SIH2]INVDTAAMT(JL1)= [F:BPC]INVDTAAMT(JL2-1)
                    Else
                       Call CONVERT([F:BPC]CUR,[M:SIH2]CUR,GLOCALDEV,[M:SIH0]CHGTYP,[M:SIH0]INVDAT,
&                           [F:BPC]INVDTAAMT(JL2-1),[M:SIH2]INVDTAAMT(JL1),JLSTAT) From TRTDEV
                       If JLSTAT : Raz [M:SIH2]INVDTAAMT(JL1) : Endif
                    Endif
                 Endif
              Endif
        Endif
     Endif
  Endif
Next JL
[M:SIH2]NBFAC=JLNOL

Return

# 101874 : V9 : Taxe code control
#########################################################################
# S/Programme VALTTC : Simulation d'un calcul facture
# - pour affichage champ HT et TTC du bloc valorisation dans ecran lignes
#   ( prise en compte des elements de facturation du contexte )
#------------------------------------------------------------------------
# Concerne : la saisie des Devis / commandes / Livraisons
# Appel : si modification de champs impliques dans la valorisation
# - Actions : APRES_NBLIG  : creation modification de ligne
#             C_NBFAC      : sortie du tableau des elts de facturation
#             FIN_PICK / INICRE / INIMOD
#########################################################################
Subprog VALTTC (ORICLC, PARAM_T)
Value    Char ORICLC            : # fonction origine du calcul
Variable Char PARAM_T () (0..)  : # paramètres complementaires

# Paramètres :
# PARAM_T(0) : Flag contrôle des taxes             (1=Non/2=Oui)
# PARAM_T(1) : Lecture de la trace par le sous-pro (1=Non/2=Oui)
# PARAM_T(2) : Flag retour                         (1=KO/2=OK)
Raz PARAM_T(2)

Gosub TRTVALTTC

End
##########################################################################
## S/Programme VALTTC : Simulation d'un calcul facture
## - pour affichage champ HT et TTC du bloc valorisation dans ecran lignes
##   ( prise en compte des elements de facturation du contexte )
##------------------------------------------------------------------------
## Concerne : la saisie des Devis / commandes / Livraisons
## Appel : si modification de champs impliques dans la valorisation
## - Actions : APRES_NBLIG  : creation modification de ligne
##             C_NBFAC      : sortie du tableau des elts de facturation
##             FIN_PICK / INICRE / INIMOD
##########################################################################
#
#Subprog VALTTC (ORICLC)
#Value Char ORICLC                       : # fonction origine du calcul
#
## Bug 60401:Pb en modif.d'un doc.sur le 1er champ : GREP est encore à "" et pas encore à "M"
##If GREP="" & !GCREPARBOU : End : Endif
#
##--- pour ne pas effectuer le calcul facture en fin de ligne et en sortie des elts de facture
##    ( but : performance en saisie devis, livraison et commande )
## La globale GVALTTC, si elle existe, est alimentée avant chaque appel au sous-pro VALTTC
## Dans la gestion des devis      avec GVALTTCSQH (si elle existe)
## Dans la gestion des cdes       avec GVALTTCSOH (si elle existe)
## Dans la gestion des livraisons avec GVALTTCSDH (si elle existe)
#If dim(GVALTTC)>0 & GVALTTC=1
#   Raz GVALTTC : Gosub EFFACE_VALTTC : End
#Endif
##---
#Gosub OUVRE1 From TRTVENFACR
#[M:SIH0]ORICLC=[L]ORICLC
#
#Gosub OUVRE_SIHX      From TRTVENFACC
## Appel NEW_FACTURE qui charge les masques SIH à partir de SQH ou SOH ou SDH) ($CHARG_MSKSIH)
## Puis pour chaque ligne PLUS_LIGNE : En plus ds tableau des taxes XV et tableau des frais XF
## Puis NEW_REGIME
#Gosub CHARG_TABLEAUX  From TRTVENFACC
#If [M:SIH4]NBLIG>0
#   Gosub CAL_FACTURE     From TRTVENFACC
#Endif
#
#If [M:SIH0]ORICLC="GESSQH"
#   If dim([F:SQH]QUOINVNOT)>0  : [F:SQH]QUOINVNOT =[M:SIHV]INVNOT    : Endif
#   If dim([F:SQH]QUOINVATI)>0  : [F:SQH]QUOINVATI =[M:SIHV]INVATI    : Endif
#   If dim([F:SQH]QUOINVNOTL)>0 : [F:SQH]QUOINVNOTL=[M:SIHV]INVNOTRPT : Endif
#   If dim([F:SQH]QUOINVATIL)>0 : [F:SQH]QUOINVATIL=[M:SIHV]INVATIRPT : Endif
#Endif
#If [M:SIH0]ORICLC="GESSOH"
#   If dim([F:SOH]ORDINVNOT)>0  : [F:SOH]ORDINVNOT =[M:SIHV]INVNOT    : Endif
#   If dim([F:SOH]ORDINVATI)>0  : [F:SOH]ORDINVATI =[M:SIHV]INVATI    : Endif
#   If dim([F:SOH]ORDINVNOTL)>0 : [F:SOH]ORDINVNOTL=[M:SIHV]INVNOTRPT : Endif
#   If dim([F:SOH]ORDINVATIL)>0 : [F:SOH]ORDINVATIL=[M:SIHV]INVATIRPT : Endif
#Endif
#If [M:SIH0]ORICLC="GESSDH" or [M:SIH0]ORICLC="GESSDHF"
#   If dim([F:SDH]DLVINVNOT)>0  : [F:SDH]DLVINVNOT =[M:SIHV]INVNOT    : Endif
#   If dim([F:SDH]DLVINVATI)>0  : [F:SDH]DLVINVATI =[M:SIHV]INVATI    : Endif
#   If dim([F:SDH]DLVINVNOTL)>0 : [F:SDH]DLVINVNOTL=[M:SIHV]INVNOTRPT : Endif
#   If dim([F:SDH]DLVINVATIL)>0 : [F:SDH]DLVINVATIL=[M:SIHV]INVATIRPT : Endif
#Endif
#
## 91606 :(04/08/14) Transportation notes (Sales part dev)
#If [M:SIH0]ORICLC="GESTNH"
#   If dim([F:TNH]DLVINVNOT)>0  : [F:TNH]DLVINVNOT =[M:SIHV]INVNOT    : Endif
#   If dim([F:TNH]DLVINVATI)>0  : [F:TNH]DLVINVATI =[M:SIHV]INVATI    : Endif
#   If dim([F:TNH]DLVINVNOTL)>0 : [F:TNH]DLVINVNOTL=[M:SIHV]INVNOTRPT : Endif
#   If dim([F:TNH]DLVINVATIL)>0 : [F:TNH]DLVINVATIL=[M:SIHV]INVATIRPT : Endif
#Endif
## 91606 :(04/08/14) Transportation notes (Sales part dev)
#
#Gosub FIN1 From TRTVENFACR
#
#End
# 101874

# 101874 : V9 : Taxe code control
#########################################################################
$TRTVALTTC

# Bug 60401:Pb en modif.d'un doc.sur le 1er champ : GREP est encore à "" et pas encore à "M"
#If GREP="" & !GCREPARBOU : End : Endif

#--- pour ne pas effectuer le calcul facture en fin de ligne et lors du picking
#    ( but : performance en saisie devis, commande, livraison, facture )
# La globale GVALTTC, est alimentée avant chaque appel au sous-pro VALTTC
# --> En fin de ligne et lors du picking :
# Dans la gestion des devis      avec GSQHVALLIG (paramètre général Valorisation devis à la ligne)
# Dans la gestion des cdes       avec GSOHVALLIG (paramètre général Valorisation cde   à la ligne)
# Dans la gestion des livraisons avec GSDHVALLIG (paramètre général Valorisation liv   à la ligne)
# Dans la gestion des factures   avec GSIHVALLIG (paramètre général Valorisation fac   à la ligne)
# --> Dans tous les autres cas, elle est mise à 2
# La globale GVALTTC conditionne le calcul facture :
# Si GVALTTC=1, Le calcul n'est pas effectué, dans les autres cas il est effectué
If dim(GVALTTC)>0 & GVALTTC<>2
   # Si on ne fait pas le calcul facture il ne faut rien faire, il ne faut pas remettre à 0 les totaux ...
   Raz GVALTTC : Return
Endif
#---

Gosub OUVRE1 From TRTVENFACR
[M:SIH0]ORICLC=[L]ORICLC
Gosub OUVRE_SIHX      From TRTVENFACC
# Appel NEW_FACTURE qui charge les masques SIH à partir de SQH ou SOH ou SDH) ($CHARG_MSKSIH)
# Puis pour chaque ligne PLUS_LIGNE : En plus ds tableau des taxes XV et tableau des frais XF
# Puis NEW_REGIME
Gosub CHARG_TABLEAUX  From TRTVENFACC
If [M:SIH4]NBLIG>0
   #---- Paramètres complementaires appel valorisation
   # PARAM_T(0) : Flag contrôle des taxes             (1=Non/2=Oui)
   # PARAM_T(1) : Lecture de la trace par le sous-pro (1=Non/2=Oui)
   # PARAM_T(2) : Flag retour                         (1=KO/2=OK)
   PARAM_T(2)="2"
   If PARAM_T(0)="2"
       Gosub CTLVAT From TRTVENFACC1
   Endif
   If PARAM_T(2)="2"
       Gosub CAL_FACTURE     From TRTVENFACC
   Else
       Raz [M:SIHV]
       If dim(GSZIMPSOH) >= 0 and GSZIMPSOH = "IMPSOH" Then
           Return
       Endif
       Gosub FIN_IMPORT From TRTVENFACR : Return
   Endif
Endif

If [M:SIH0]ORICLC="GESSQH"
   If dim([F:SQH]QUOINVNOT)>0  : [F:SQH]QUOINVNOT =[M:SIHV]INVNOT    : Endif
   If dim([F:SQH]QUOINVATI)>0  : [F:SQH]QUOINVATI =[M:SIHV]INVATI    : Endif
   If dim([F:SQH]QUOINVNOTL)>0 : [F:SQH]QUOINVNOTL=[M:SIHV]INVNOTRPT : Endif
   If dim([F:SQH]QUOINVATIL)>0 : [F:SQH]QUOINVATIL=[M:SIHV]INVATIRPT : Endif
Endif
If [M:SIH0]ORICLC="GESSOH"
   If dim([F:SOH]ORDINVNOT)>0  : [F:SOH]ORDINVNOT =[M:SIHV]INVNOT    : Endif
   If dim([F:SOH]ORDINVATI)>0  : [F:SOH]ORDINVATI =[M:SIHV]INVATI    : Endif
   If dim([F:SOH]ORDINVNOTL)>0 : [F:SOH]ORDINVNOTL=[M:SIHV]INVNOTRPT : Endif
   If dim([F:SOH]ORDINVATIL)>0 : [F:SOH]ORDINVATIL=[M:SIHV]INVATIRPT : Endif
Endif
If [M:SIH0]ORICLC="GESSDH" or [M:SIH0]ORICLC="GESSDHF"
   #--CPO Lors du 87919
   #--Livr. LIV-13ASN-0007220 suite 1er pick L1 cde CDE-2013-0140 =>
   #--le GESSDH.TRTVENFACR fait un raz de [F:SDH], puis [F:SDH]=[M:SDHx]
   #--Probl champs BPDNAM/BPINAM de F car dimensionnés (au contraire de ceux de [M])
   #--Du coup si on pick la 2nde ligne de la cde => Message "Raison sociale différente" !!!
   #--On a [F:SDH]BPDNAM(0)="" et [F:SDH]BPDNAM(1)="CRPOP Adresse de livr CHA 1" qui aurait du être en 1er !
   #--GREP="M" car si création avec compteur manuel, l'user a pu saisir un n° dans le masque
   #--et le F n'est pas encore dans la base...
   #--Pour l'instant on laisse tel quel => trop d'implications !!!
   #   If [M:SIH0]ORICLC="GESSDH" and [M:SDH0]SDHNUM<>"" and GREP="M"
   #     Read [F:SDH]SDH0=[M:SDH0]SDHNUM
   #     If fstat : Raz [F:SDH] : Endif
   #   Endif
   #--/CPO
   If dim([F:SDH]DLVINVNOT)>0  : [F:SDH]DLVINVNOT =[M:SIHV]INVNOT    : Endif
   If dim([F:SDH]DLVINVATI)>0  : [F:SDH]DLVINVATI =[M:SIHV]INVATI    : Endif
   If dim([F:SDH]DLVINVNOTL)>0 : [F:SDH]DLVINVNOTL=[M:SIHV]INVNOTRPT : Endif
   If dim([F:SDH]DLVINVATIL)>0 : [F:SDH]DLVINVATIL=[M:SIHV]INVATIRPT : Endif
Endif
# 91606 :(16/07/14) Transportation notes (Sales part dev)
If [M:SIH0]ORICLC="GESTNH"
   If dim([F:TNH]DLVINVNOT)>0  : [F:TNH]DLVINVNOT =[M:SIHV]INVNOT    : Endif
   If dim([F:TNH]DLVINVATI)>0  : [F:TNH]DLVINVATI =[M:SIHV]INVATI    : Endif
   If dim([F:TNH]DLVINVNOTL)>0 : [F:TNH]DLVINVNOTL=[M:SIHV]INVNOTRPT : Endif
   If dim([F:TNH]DLVINVATIL)>0 : [F:TNH]DLVINVATIL=[M:SIHV]INVATIRPT : Endif
Endif
# 91606 :(16/07/14) Transportation notes (Sales part dev)

Gosub FIN1 From TRTVENFACR

Return
# 101874

#------------------------------------------------------------------------
# Pas de calcul TTC à la ligne --> effacement des mnt du bloc valorisation
$EFFACE_VALTTC
#If [M:SIH0]ORICLC="GESSQH"                               : # 101874 : V9 : Taxe code control
If [L]ORICLC="GESSQH"                                     : # 101874 : V9 : Taxe code control
   If dim([M:SQH2]QUOINVNOT)>0 : Raz [M:SQH2]QUOINVNOT : Affzo [M:SQH2]QUOINVNOT : Endif
   If dim([M:SQH2]QUOINVATI)>0 : Raz [M:SQH2]QUOINVATI : Affzo [M:SQH2]QUOINVATI : Endif
Endif
#If [M:SIH0]ORICLC="GESSOH"                               : # 101874 : V9 : Taxe code control
If [L]ORICLC="GESSOH"                                     : # 101874 : V9 : Taxe code control
   If dim([M:SOH4]ORDINVNOT)>0 : Raz [M:SOH4]ORDINVNOT : Affzo [M:SOH4]ORDINVNOT : Endif
   If dim([M:SOH4]ORDINVATI)>0 : Raz [M:SOH4]ORDINVATI : Affzo [M:SOH4]ORDINVATI : Endif
Endif
#If [M:SIH0]ORICLC="GESSDH" or [M:SIH0]ORICLC="GESSDHF"   : # 101874 : V9 : Taxe code control
If [L]ORICLC="GESSDH" or [L]ORICLC="GESSDHF"         : # 101874 : V9 : Taxe code control
   If dim([M:SDH1]DLVINVNOT)>0 : Raz [M:SDH1]DLVINVNOT : Affzo [M:SDH1]DLVINVNOT : Endif
   If dim([M:SDH1]DLVINVATI)>0 : Raz [M:SDH1]DLVINVATI : Affzo [M:SDH1]DLVINVATI : Endif
Endif
# 91606 :(04/08/14) Transportation notes (Sales part dev)
#If [M:SIH0]ORICLC="GESTNH"                               : # 101874 : V9 : Taxe code control
If [L]ORICLC="GESTNH"                                     : # 101874 : V9 : Taxe code control
   If dim([M:TNH1]DLVINVNOT)>0 : Raz [M:TNH1]DLVINVNOT : Affzo [M:TNH1]DLVINVNOT : Endif
   If dim([M:TNH1]DLVINVATI)>0 : Raz [M:TNH1]DLVINVATI : Affzo [M:TNH1]DLVINVATI : Endif
Endif
# 91606 :(04/08/14) Transportation notes (Sales part dev)
Return

#########################################################################




#------------------------------------------------------------------------
# Garnissage du masque de valorisation SIHV a partir des tables
# - SVCRFOOT [SVF] : Eléments de facturation
# - SVCRVAT  [SVV] : Taxes
#------------------------------------------------------------------------
$CHARG_SIHV

Local Integer WVCRTYP, WCHGTYP, STAT
Local Char    WVCRNUM
Local Date    WDAT
Local Integer WRET 			 :#--CPO 71937

Case PARAM(1)
    When "GESSQH"  WVCRTYP=1  : WVCRNUM=[M:SQH0]SQHNUM : WCHGTYP=[M:SQH0]CHGTYP : WDAT=[M:SQH0]QUODAT
    When "GESSOH"  WVCRTYP=20 : WVCRNUM=[M:SOH0]SOHNUM : WCHGTYP=[M:SOH0]CHGTYP : WDAT=[M:SOH0]ORDDAT
    When "GESSDH","GESSDHF"  WVCRTYP=2  : WVCRNUM=[M:SDH0]SDHNUM : WCHGTYP=[M:SDH0]CHGTYP : : WDAT=[M:SDH1]DLVDAT
    # 91606 :(04/08/14) Transportation notes (Sales part dev)
    When "GESTNH"  WVCRTYP=22  : WVCRNUM=[M:TNH0]TNHNUM : WCHGTYP=[M:TNH0]CHGTYP : : WDAT=[M:TNH1]DLVDAT
    # 91606 :(04/08/14) Transportation notes (Sales part dev)
Endcase

If clalev([F:TVT])=0 : Local File TABVAT   [TVT] : Endif
Gosub OPEN_SFI From TRTX3CPY: #If clalev([F:SFI])=0 : Local File SFOOTINV [SFI] : Endif

# --- chargement de SIHV
Raz [M:SIHV]
#     le tableau des taxes
For [SVV]SVV1 Where VCRTYP=WVCRTYP & VCRNUM=WVCRNUM
  # Issue X3-87559
  # GSVVNULLIG=2 --> Lines with basis amount=0 are stored in SVCRVAT
  #If [F:SVV]VAT<>"" & [F:SVV]VATNET<>0
  If [F:SVV]VAT<>"" & ([F:SVV]VATNET<>0 | GSVVNULLIG=2)
  # End issue X3-87559
    #--CPO 71937 TVT and LEG as part of the key
    Call LEC_TVT_LEG(GCURLEG,[F:SVV]VAT,WRET) From TRTLECLEG
    If WRET : Raz [F:TVT] : Endif
    #Read [F:TVT]TVT0=[F:SVV]VAT
    #If fstat : Raz [F:TVT] : Endif
    #--/CPO
    [M:SIHV]XVTAX([M:SIHV]NBVAT) = [F:SVV]VAT
    [M:SIHV]XVTYP([M:SIHV]NBVAT) = [F:TVT]VATTYP : [M:SIHV]XVBAS([M:SIHV]NBVAT) = [F:TVT]VATBAS
    Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:SIHV]XVSHO([M:SIHV]NBVAT)) From TRTX3TEX
    [M:SIHV]XVNOT([M:SIHV]NBVAT) = [F:SVV]VATGRO
    [M:SIHV]XVSMI([M:SIHV]NBVAT) = [F:SVV]VATNET
    [M:SIHV]XVRAT([M:SIHV]NBVAT) = [F:SVV]VATRAT
    [M:SIHV]XVAMT([M:SIHV]NBVAT) = [F:SVV]VATAMT
    [M:SIHV]XVSUP([M:SIHV]NBVAT) = [F:SVV]VATSUPAMT
    If [F:TVT]VATTYP=1                        : # colonne TTC uniquement si taxe principale
      [M:SIHV]XVATI([M:SIHV]NBVAT) = [F:SVV]VATGRO+[F:SVV]VATAMT+[F:SVV]VATSUPAMT
    Endif

#    If func AFNC.ACTIV("KAB")
       If [F:SVV]VATTYP>3                  : # colonne TTC car les taxes annexes (globales facture)
          [M:SIHV]XVATI([M:SIHV]NBVAT) = [F:SVV]VATAMT : # ne sont pas répercutées sur les lignes taxes principales
       Endif                               : # liées aux produits
#    Endif

    [M:SIHV]NBVAT += 1

    If dim([M:SIHV]VCUR)>0 : [M:SIHV]VCUR=[F:SVV]CUR : Endif
  Endif
Next

#     le tableau des elements
For [SVF]SVF2 Where VCRTYP=WVCRTYP & VCRNUM=WVCRNUM
  If [F:SVF]DTA<>0
#     Read [SFI]SFI0=GSOCIETE;[F:SVF]DTA
     Read [SFI]SFI0=[F:SVF]DTA
     If !fstat
        Read [AXX]AXX0="SFOOTINV";"SHOAXX";GLANGUE;num$([F:SFI]SFINUM);""
        If !fstat : [M:SIHV]XFSHO([M:SIHV]NBFOOT) = [F:AXX]TEXTE : Endif
     Endif
     [M:SIHV]XFNUM([M:SIHV]NBFOOT)    = [F:SVF]DTA
     [M:SIHV]XFNOT([M:SIHV]NBFOOT)    = [F:SVF]DTANOT

     # 102423 : Belgium Early discounts
     #[M:SIHV]XFSMI([M:SIHV]NBFOOT)    = [F:SVF]DTANOT
     Raz [M:SIHV]XFSMI([M:SIHV]NBFOOT)
     # 102423

     Raz [M:SIHV]XFVATAMT([M:SIHV]NBFOOT)
     For I=0 To dim([F:SVF]DTANET)-1
         If [F:SVF]DTAVAT(I)="" Break Endif
         Assign "[M:SIHV]DTANOT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVATNOT(I)
         Assign "[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTANET(I)
         Assign "[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVAT(I)
         Assign "[M:SIHV]DTAVATRT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVATRAT(I)
         Assign "[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$([M:SIHV]NBFOOT)+")" With [F:SVF]DTAVATAMT(I)
         [M:SIHV]XFVATAMT([M:SIHV]NBFOOT)+=[F:SVF]DTAVATAMT(I)

         # 102423 : Belgium Early discounts
         [M:SIHV]XFSMI([M:SIHV]NBFOOT)+=[F:SVF]DTANET(I)
         # 102423
     Next
     If I=1
         [M:SIHV]XFSMI([M:SIHV]NBFOOT)    = [F:SVF]DTANET(I-1)
         [M:SIHV]XFTAX([M:SIHV]NBFOOT)    = [F:SVF]DTAVAT(I-1)
         [M:SIHV]XFRAT([M:SIHV]NBFOOT)    = [F:SVF]DTAVATRAT(I-1)
     Endif

     [M:SIHV]XFDTAAMT([M:SIHV]NBFOOT) = [F:SVF]DTAAMT
     [M:SIHV]XFATI([M:SIHV]NBFOOT)    = [F:SVF]DTANOT+[M:SIHV]XFVATAMT([M:SIHV]NBFOOT)
     [M:SIHV]NBFOOT += 1
  Endif
Next

#     les totaux ( zones de cumul et zones euro )
[M:SIHV]INVNOT = sum([M:SIHV]XVNOT)+sum([M:SIHV]XFNOT)
[M:SIHV]INVATI = sum([M:SIHV]XVATI)+sum([M:SIHV]XFATI)
# CH mail 29/09 : Pour Béryl exprimer ces montants en devise société
#[M:SIHV]DEVRPT1 = GSYSCUR : [M:SIHV]DEVRPT2 = GSYSCUR
[M:SIHV]DEVRPT1 = GLOCALDEV : [M:SIHV]DEVRPT2 = GLOCALDEV
#[M:SIHV]INVNOTRPT=[M:SIHV]INVNOT*[M:SIH2]RATRPT  ( voir le coef de reporting a utiliser )
#[M:SIHV]INVATIRPT=[M:SIHV]INVATI*[M:SIH2]RATRPT  ( voir le coef de reporting a utiliser )
If [M:SIHV]VCUR<>GLOCALDEV
    # On est pas dans l'objet facture [M:SIH2]RAT1, RAT2 sont non connus donc on appelle CONVERT
    Call CONVERT([M:SIHV]VCUR,GLOCALDEV,GLOCALDEV,WCHGTYP,WDAT,
&                [M:SIHV]INVNOT,[M:SIHV]INVNOTRPT,STAT) From TRTDEV
    Call CONVERT([M:SIHV]VCUR,GLOCALDEV,GLOCALDEV,WCHGTYP,WDAT,
&                [M:SIHV]INVATI,[M:SIHV]INVATIRPT,STAT) From TRTDEV
#    Local Decimal WCOURS : WCOURS=0 : If [M:SIH2]RAT1<>0 WCOURS=arr([M:SIH2]RAT2/[M:SIH2]RAT1, 10^-GDECRCU) : Endif
#    Call COURMNT([M:SIHV]VCUR,GLOCALDEV,GLOCALDEV,[M:SIH0]CHGTYP,[M:SIH0]INVDAT,1,
#&                [M:SIHV]INVNOT,[M:SIHV]INVNOTRPT,WCOURS,STAT) From TRTDEV
#    Call COURMNT([M:SIHV]VCUR,GLOCALDEV,GLOCALDEV,[M:SIH0]CHGTYP,[M:SIH0]INVDAT,1,
#&                [M:SIHV]INVATI,[M:SIHV]INVATIRPT,WCOURS,STAT) From TRTDEV
Else
    [M:SIHV]INVNOTRPT=[M:SIHV]INVNOT
    [M:SIHV]INVATIRPT=[M:SIHV]INVATI
Endif

# ACA (2009-07-17) Bug number : comment
Case PARAM(1)
    When "GESSQH"
      [M:SIHV]VCRTYP = 1
      [M:SIHV]FCY = [M:SQH0]SALFCY
    When "GESSOH"
      [M:SIHV]VCRTYP = 20
      [M:SIHV]FCY = [M:SOH0]SALFCY
    When "GESSDH","GESSDHF"
      [M:SIHV]VCRTYP = 2
      [M:SIHV]FCY = [M:SDH0]SALFCY
Endcase
[M:SIHV]NUM=WVCRNUM
[M:SIHV]DAT=WDAT

Return

###########################################################################

