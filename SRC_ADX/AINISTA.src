#<AdxTL>@(#)6.0.0.0 $Revision$
Local Mask AIMP1 [RPT]
[M:RPT]RPTCOD = "STAT"
[M:RPT]PARCOD = "code"
[M:RPT]VALEUR1 = "ZZMBQ"
Local Char ACTION(20)
ACTION = "CONTSAI"
Gosub ACTION
End

#---------------------#
$ACTION
Case ACTION
 When "CONTSAI" : Gosub CONTSAI
Endcase
Return

#---------------------#
$CONTSAI
Local Integer I , J , K
If [M:RPT]RPTCOD<>"STAT" or GSERVEUR or GBROWS
 Return
Endif
K = find("code",[M:RPT]PARCOD)
If K
 Local File PARSTA2 [XXPS]
 Read [XXPS]PS20 = [M:RPT]VALEUR1(K-1)
 If !fstat
  K = 1
  For I=1 To [F:XXPS]NBRFRM
   For J=1 To 9
    If instr(1,[F:XXPS]AMTFRM(I-1),"CC"+num$(J))
     K = 0 : Break 2
    Elsif instr(1,[F:XXPS]AMTFRM(I-1),"PP"+num$(J))
     K = 0 : Break 2
    Endif
   Next J
  Next I
  If !K
   # Cet état ne gère pas les périodes n-1
   Call MESSAGE(mess(323,139,1)) From GESECRAN  
  Endif
 Endif
 Close Local File [XXPS]
Endif
Return

#-----------------------------------------------#
Subprog IMPRIME(NBPAR,PARAMETRES)
End
