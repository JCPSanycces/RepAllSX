#<AdxTL>@(#)9.0.0.0 $Revision$
##################################################################################
# DOSMAJ34 : Mises à jour à effectuer lors du passage à la version 160 (Release 34)
# moulinette avant la version V6.4
#################################################################################
# moulinette avant la Release 34 si necessaire
##################################################################################
Subprog AMAJ
#----------------------------------------#
#       Avant mise à jour                #
#----------------------------------------#
Onerrgo ERREUR

# recupération dernier patch installé chez le client
# lecture table APATCH du dossier en cours de validation
Local Char WVERSION (5)
Local Shortint WPATCH
WPATCH = 0
Raz WVERSION

If clalev([F:ZAP])=0  : Local File =[F:ADS]DOSSIER+".APATCH" [ZAP]  : Endif
If clalev([F:ZAX])=0  : Local File APATCH [ZAX]  : Endif

Filter [ZAP] Where TYP = "P"
Read [ZAP] Last
If fstat
 [F:ZAP]PATNUM = 0
Endif
Filter [ZAP]

Filter [ZAX] Where TYP = "P"
Read [ZAX] Last
If fstat
    [F:ZAX]PATNUM = 0
Else

Endif
Filter [ZAX]

# recuperation du dernier numéro de patch du dossier a valider et du dossier X3
WPATCH = [F:ZAP]PATNUM
WVERSION = [F:ZAP]RELEASE

Close Local File

###########################################
# MOULINETTE EN AVANT maj
############################################
If left$(WVERSION,3) = "1.6"

Endif

Onerrgo
End

###################################################################################
Subprog MAJ
#----------------------------------------#
# Après mise à jour
#----------------------------------------#

Onerrgo ERREUR
# recupération dernier patch installé chez le client
# lecture table APATCH du dossier en cours de validation
Local Char WVERSION (5)
Local Shortint WPATCH, ZOK
WPATCH = 0
ZOK=0
Raz WVERSION

If clalev([F:ZAP])=0  : Local File =[F:ADS]DOSSIER+".APATCH" [ZAP]  : Endif
If clalev([F:ZAX])=0  : Local File APATCH [ZAX]  : Endif

Filter [ZAP] Where TYP = "P"
Read [ZAP] Last
If fstat
 [F:ZAP]PATNUM = 0
Endif
Filter [ZAP]

Filter [ZAX] Where TYP = "P"
Read [ZAX] Last
If fstat
    [F:ZAX]PATNUM = 0
Else

Endif
Filter [ZAX]

# recuperation du dernier numéro de patch du dossier a valider et du dossier X3
WPATCH = [F:ZAP]PATNUM
WVERSION = [F:ZAP]RELEASE

Close Local File

If left$(WVERSION,3) = "1.3"
    WPATCH =0
Endif
If left$(WVERSION,3) = "1.4"
    WPATCH =0
Endif
If left$(WVERSION,3) = "1.5"
    WPATCH =0
Endif


###########################################
# module tronc commun
# pas de test du module
###########################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.6"
      If WPATCH < 16
        If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
         Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT50
        Endif
      Endif
  Endif
Endif

###########################################
# module immos -
############################################
If left$(WVERSION,3) = "1.6"
    If [F:ADS]MODULE(13) = 2
        If WPATCH < 16
           Call UTI_MOUL([F:ADS]DOSSIER) From UTIIMM033
        Endif
    Endif
Endif

###########################################
# module achats
############################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.6"
      If [F:ADS]MODULE(5)=2
          If WPATCH < 17
             Call UTI_MOUL([F:ADS]DOSSIER) From UTIACH27
          Endif
      Endif
  Endif
Endif

###########################################
# MODULE gpao
############################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 111795 - 2015-10-15 by GH : To be checked
    If left$(WVERSION,3) = "1.6"
       If [F:ADS]MODULE(6)=2
           If WPATCH < 16
                Call UTI_MOUL([F:ADS]DOSSIER) From UTIGPA20
                Call UTI_MOUL([F:ADS]DOSSIER) From UTIGPA22
                Call UTI_MOUL([F:ADS]DOSSIER) From UTIGPA27
            Endif
           If WPATCH < 17
                Call UTI_MOUL([F:ADS]DOSSIER) From UTIGPA29
                Call UTI_MOUL([F:ADS]DOSSIER) From UTIGPA30
           Endif
        Endif
    Endif
Endif

###########################################
# module compta
############################################
If left$(WVERSION,3) = "1.6"
   If [F:ADS]MODULE(1)=2 & func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
       If WPATCH < 16
            Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT49
       Endif
    Endif
Endif

Onerrgo
End
###################################################################################
###################################################################################
###################################################################################
$ERREUR
Call ECR_TRACE(errp-"("+num$(errl)+")"-mess(6,123,1)-":"-num$(errn)-errmes$(errn)-errm,1) From GESECRAN
# Erreur
Resume

