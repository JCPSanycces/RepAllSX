#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","SITDGL","SITDIFGL",3,"") From GTRAITE
End

######################################################################################
$ACTION
Case ACTION
 When "INIT"    : Gosub INIT
 When "EXEC"    : Gosub EXEC
Endcase
Return


######################################################################################
$INIT
TMP=1
TRA=1
Gosub SI_CONTEXT From SIXFONCTION

If !clalev([F:XSOC]) : Local File =SI_DOSSIER+".XISOC"      [XSOC]  : Endif  # Société Intégrale
If !clalev([F:XJRN]) : Local File =SI_DOSSIER+".XIJRN"      [XJRN]  : Endif  # Journaux comptables

If !clalev([F:XGAC]) : Local File =SI_DOSSIER+".XIPLACBGNR" [XGAC]  : Endif  # Comptes généraux
If !clalev([F:XBPC]) : Local File =SI_DOSSIER+".XICLT"      [XBPC]  : Endif  # Clients
If !clalev([F:XBPS]) : Local File =SI_DOSSIER+".XIFOU"      [XBPS]  : Endif  # Fournisseurs

If !clalev([F:GAC])  : Local File =SI_DOSSIER+".GACCOUNT"    [GAC]  : Endif  # Comptes
If !clalev([F:DAE])  : Local File =SI_DOSSIER+".GACCENTRYD"  [DAE]  : Endif  # Lignes d'écritures
If !clalev([F:HAE])  : Local File =SI_DOSSIER+".GACCENTRY"   [HAE]  : Endif  # En-tête de pièces d'écritures

If !clalev([F:CPY])  : Local File =SI_DOSSIER+".COMPANY"     [CPY]  : Endif  # Sociétés
If !clalev([F:JOU])  : Local File =SI_DOSSIER+".GJOURNAL"    [JOU]  : Endif  # Journaux

Local Char    COMPTE(GLONGAC), TIERS(GLONBPR)
Local Integer COLL
Local Decimal DEBIT, CREDIT, DEBIT2, CREDIT2

Local Integer NBTIERS, OKTIERS        : # Nombre de tiers dans Historique général
Local Char L_TIERS(GLONBPR)(1..9000)  : # Table des tiers dans Historique général

Local Date DATPREMEX                  : # Date du premier exercice

Local Integer NBJOU                   : # Nombre de journaux
Local Char    TJOU(GLONJOU)(1..999)   : # Table des journaux

## Qu'une société forcément...
Read [CPY]CPY0 First
If !fstat
 [L]DATPREMEX = [F:CPY]STRPER
 Call SETMAINREF([F:CPY]CPY,GTYPGEN,GTYPANA) From CPTDIV
Endif
Read [XSOC]  First
Return

######################################################################################
$EXEC

Local Integer HISGNR : # Si 2:Prise en compte des écritures de l'historique
Local Integer BROGNR : # Si 2:Prise en compte des écritures du brouillard
Local Integer DETBPR : # Si 2:Détail par tiers pour les comptes collectifs

[L]HISGNR = [M:SIL]HISGNR
[L]BROGNR = [M:SIL]BROGNR
[L]DETBPR = [M:SIL]DETBPR

If [M]HISGNR<>2 & [M]BROGNR<>2 : Return : Endif

Gosub FILTRE

If !clalev([F:XGA2]) :
 Local File =SI_DOSSIER+".XIHISCBGNR" [XGA2] Where evalue (FILTINT) Order By Key CLE = CPT;CLF;DATECR;NUMECR
Endif

If !clalev([F:XGA3]) :
 Local File =SI_DOSSIER+".XIHISCBGNR" [XGA3] Where evalue (FILTINT) Order By Key CLE = CLF;CPT;DATECR;NUMECR
Endif

If !clalev([F:XGB2]) :
 Local File =SI_DOSSIER+".XIBROCBGNR" [XGB2] Where evalue (FILTINT) Order By Key CLE = CPT;CLF;DATECR;NUMLOT
Endif

If !clalev([F:XGB3]) :
 Local File =SI_DOSSIER+".XIBROCBGNR" [XGB3] Where evalue (FILTINT) Order By Key CLE = CLF;CPT;DATECR;NUMLOT
Endif

# Vérification Gd-Livre
Call OUVRE_TRACE(mess(2,643,1)) From LECFIC

For [XGAC]
 If find([XGAC]TYPCLF,"C","F","O")
  [L]COLL = 2
  [L]COMPTE = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XGAC]CPTGNR,"GACCOUNT","")
 Else
  [L]COLL = 1
  [L]COMPTE = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XGAC]CPTGNR,"GACCOUNT","")
 Endif


 Raz DEBIT, CREDIT, DEBIT2, CREDIT2

 ## Comptes généraux
 If [L]COLL = 1
  [L]TIERS = ""
  ## 1/ Historique général
  If [L]HISGNR = 2
   For [XGA2]CLE Where CPT = [F:XGAC]CPTGNR
    If [F:XGA2]X3DAT=[L]DATPREMEX or ([F:XGA2]X3DAT>[L]DATPREMEX and !find([F:XGA2]ORGECR,"A","H","Q"))
     If [F:XGA2]SENECR="D"
      DEBIT += [F:XGA2]MNTDBTFRS
     Else
      CREDIT += [F:XGA2]MNTDBTFRS
     Endif
    Endif
   Next
  Endif
  ## 2/ Brouillard général
  If [L]BROGNR = 2
   For [XGB2]CLE Where CPT = [F:XGAC]CPTGNR
     If [F:XGB2]X3DAT>=[L]DATPREMEX
     If [F:XGB2]SENECR="D"
      DEBIT += [F:XGB2]MNTDBTFRS
     Else
      CREDIT += [F:XGB2]MNTDBTFRS
     Endif
    Endif
   Next
  Endif
  Gosub ECR_X3
  Gosub TRACE

 ## Comptes collectifs
 Elsif [L]COLL = 2 & [L]DETBPR<>2
  ## 1/ Historique général
  If [L]HISGNR = 2
   For [XGA3]CLE Where CLF = [F:XGAC]CPTGNR
    If [F:XGA3]X3DAT=[L]DATPREMEX or ([F:XGA3]X3DAT>[L]DATPREMEX and !find([F:XGA3]ORGECR,"A","H","Q"))
     If [F:XGA3]SENECR="D"
      DEBIT += [F:XGA3]MNTDBTFRS
     Else
      CREDIT += [F:XGA3]MNTDBTFRS
     Endif
    Endif
   Next
  Endif
  ## 2/ Brouillard général
  If [L]BROGNR = 2
   For [XGB3]CLE Where CLF = [F:XGAC]CPTGNR
    If [F:XGB3]X3DAT>=[L]DATPREMEX
     If [F:XGB3]SENECR="D"
      DEBIT += [F:XGB3]MNTDBTFRS
     Else
      CREDIT += [F:XGB3]MNTDBTFRS
     Endif
    Endif
   Next
  Endif
  Gosub ECR_X3
  Gosub TRACE

 Else [L]COLL = 2 & [L]DETBPR=2
  ## Historique général & Brouillard
  Raz NBTIERS, L_TIERS
  If [L]HISGNR = 2 & [L]BROGNR = 2
   For [XGA3]CLE(2) Where CLF = [F:XGAC]CPTGNR
    Case [F:XGAC]TYPCLF
     When "C" : # Clients
      Filter [XBPC] Where CPTAUX = [F:XGA3]CPT
      Read [XBPC] First
      Filter [XBPC]
      If !fstat
       TIERS = func SIXFONCTION.SI_COR("XICLT",[F:XBPC]CODCLT,"BPCUSTOMER","")
      Else
       # Erreur de lecture
       Call ECR_TRACE("BPCUSTOMER"-mess(49,125,1)-[F:XGA3]CPT,1) From GESECRAN
      Endif
     When "F" : # Fournisseurs
      Filter [XBPS] Where CPTAUX = [F:XGA3]CPT
      Read [XBPS] First
      Filter [XBPS]
      If !fstat
       TIERS = func SIXFONCTION.SI_COR("XIFOU",[F:XBPS]CODFOU,"BPSUPPLIER","")
      Else
       # Erreur de lecture
       Call ECR_TRACE("BPSUPPLIER"-mess(49,125,1)-[F:XGA3]CPT,1) From GESECRAN
      Endif
     When "O" : # Tiers divers
      ## La fiche tiers (BPARTNER) a théoriquement été créée lors de la reprise des comptes (création dans
      ## BPARTNER des tiers à partir de la table Intégrale PLA_CTB_AUX (XIPLACBGNR). Ces tiers ont été créés
      ## en tant que tiers divers
      TIERS = func SIXFONCTION.SI_COR("XIPLACBAUX",[F:XGA3]CPT,"GACCOUNT","")
    Endcase
    NBTIERS+=1 : L_TIERS(NBTIERS)=TIERS
    Raz DEBIT, CREDIT, DEBIT2, CREDIT2
    For [XGA3]CLE
     If [F:XGA3]X3DAT=[L]DATPREMEX or ([F:XGA3]X3DAT>[L]DATPREMEX and !find([F:XGA3]ORGECR,"A","H","Q"))
      If [F:XGA3]SENECR="D"
       DEBIT += [F:XGA3]MNTDBTFRS
      Else
       CREDIT += [F:XGA3]MNTDBTFRS
      Endif
     Endif
    Next
    #For [XGB3]CLE Where CLF=[F:XGAC]CPTGNR & CPT=TIERS # DdM44704
    For [XGB3]CLE Where CLF=[F:XGAC]CPTGNR & CPT=[F:XGA3]CPT
     If [F:XGB3]X3DAT>=[L]DATPREMEX
      If [F:XGB3]SENECR="D"
       DEBIT += [F:XGB3]MNTDBTFRS
      Else
       CREDIT += [F:XGB3]MNTDBTFRS
      Endif
     Endif
    Next
    Gosub ECRAUX_X3
    Gosub TRACE
   Next
   For [XGB3]CLE(2) Where CLF = [F:XGAC]CPTGNR
    Case [F:XGAC]TYPCLF
     When "C" : # Clients
      Filter [XBPC] Where CPTAUX = [F:XGA3]CPT
      Read [XBPC] First
      Filter [XBPC]
      If !fstat
       TIERS = func SIXFONCTION.SI_COR("XICLT",[F:XBPC]CODCLT,"BPCUSTOMER","")
      Else
       # Erreur de lecture
       Call ECR_TRACE("BPCUSTOMER"-mess(49,125,1)-[F:XGA3]CPT,1) From GESECRAN
      Endif
     When "F" : # Fournisseurs
      Filter [XBPS] Where CPTAUX = [F:XGA3]CPT
      Read [XBPS] First
      Filter [XBPS]
      If !fstat
       TIERS = func SIXFONCTION.SI_COR("XIFOU",[F:XBPS]CODFOU,"BPSUPPLIER","")
      Else
       # Erreur de lecture
       Call ECR_TRACE("BPSUPPLIER"-mess(49,125,1)-[F:XGA3]CPT,1) From GESECRAN
      Endif
     When "O" : # Tiers divers
      ## La fiche tiers (BPARTNER) a théoriquement été créée lors de la reprise des comptes (création dans
      ## BPARTNER des tiers à partir de la table Intégrale PLA_CTB_AUX (XIPLACBGNR). Ces tiers ont été créés
      ## en tant que tiers divers
      TIERS = func SIXFONCTION.SI_COR("XIPLACBAUX",[F:XGA3]CPT,"GACCOUNT","")
    Endcase
    OKTIERS=1
    For I=1 To NBTIERS
     If TIERS=L_TIERS(I) : Raz OKTIERS : Break : Endif
    Next
    If OKTIERS
     For [XGB3]CLE
      If [F:XGB3]X3DAT>=[L]DATPREMEX #DdM44704
       If [F:XGB3]SENECR="D"
        DEBIT += [F:XGB3]MNTDBTFRS
       Else
        CREDIT += [F:XGB3]MNTDBTFRS
       Endif
      Endif
     Next
    Endif
    Gosub ECRAUX_X3
    Gosub TRACE
   Next

  Else
  ## 1/ Historique général
  If [L]HISGNR = 2
   For [XGA3]CLE(2) Where CLF = [F:XGAC]CPTGNR
    Case [F:XGAC]TYPCLF
     When "C" : # Clients
      Filter [XBPC] Where CPTAUX = [F:XGA3]CPT
      Read [XBPC] First
      Filter [XBPC]
      If !fstat
       TIERS = func SIXFONCTION.SI_COR("XICLT",[F:XBPC]CODCLT,"BPCUSTOMER","")
      Else
       # Erreur de lecture
       Call ECR_TRACE("BPCUSTOMER"-mess(49,125,1)-[F:XGA3]CPT,1) From GESECRAN
      Endif
     When "F" : # Fournisseurs
      Filter [XBPS] Where CPTAUX = [F:XGA3]CPT
      Read [XBPS] First
      Filter [XBPS]
      If !fstat
       TIERS = func SIXFONCTION.SI_COR("XIFOU",[F:XBPS]CODFOU,"BPSUPPLIER","")
      Else
       # Erreur de lecture
       Call ECR_TRACE("BPSUPPLIER"-mess(49,125,1)-[F:XGA3]CPT,1) From GESECRAN
      Endif
     When "O" : # Tiers divers
      ## La fiche tiers (BPARTNER) a théoriquement été créée lors de la reprise des comptes (création dans
      ## BPARTNER des tiers à partir de la table Intégrale PLA_CTB_AUX (XIPLACBGNR). Ces tiers ont été créés
      ## en tant que tiers divers
      TIERS = func SIXFONCTION.SI_COR("XIPLACBAUX",[F:XGA3]CPT,"GACCOUNT","")
    Endcase
    Raz DEBIT, CREDIT, DEBIT2, CREDIT2
    For [XGA3]CLE
     If [F:XGA3]X3DAT=[L]DATPREMEX or ([F:XGA3]X3DAT>[L]DATPREMEX and !find([F:XGA3]ORGECR,"A","H","Q"))
      If [F:XGA3]SENECR="D"
       DEBIT += [F:XGA3]MNTDBTFRS
      Else
       CREDIT += [F:XGA3]MNTDBTFRS
      Endif
     Endif
    Next
    Gosub ECRAUX_X3
    Gosub TRACE
   Next
  Endif
  ## 2/ Brouillard général
  If [L]BROGNR = 2
   For [XGB3]CLE(2) Where CLF = [F:XGAC]CPTGNR
    Case [F:XGAC]TYPCLF
     When "C" : # Clients
      Filter [XBPC] Where CPTAUX = [F:XGB3]CPT
      Read [XBPC] First
      Filter [XBPC]
      If !fstat
       TIERS = func SIXFONCTION.SI_COR("XICLT",[F:XBPC]CODCLT,"BPCUSTOMER","")
      Else
       # Erreur de lecture
       Call ECR_TRACE("BPCUSTOMER"-mess(49,125,1)-[F:XGB3]CPT,1) From GESECRAN
      Endif
     When "F" : # Fournisseurs
      Filter [XBPS] Where CPTAUX = [F:XGB3]CPT
      Read [XBPS] First
      Filter [XBPS]
      If !fstat
       TIERS = func SIXFONCTION.SI_COR("XIFOU",[F:XBPS]CODFOU,"BPSUPPLIER","")
      Else
       # Erreur de lecture
       Call ECR_TRACE("BPSUPPLIER"-mess(49,125,1)-[F:XGB3]CPT,1) From GESECRAN
      Endif
     When "O" : # Tiers divers
      ## La fiche tiers (BPARTNER) a théoriquement été créée lors de la reprise des comptes (création dans
      ## BPARTNER des tiers à partir de la table Intégrale PLA_CTB_AUX (XIPLACBGNR). Ces tiers ont été créés
      ## en tant que tiers divers
      TIERS = func SIXFONCTION.SI_COR("XIPLACBAUX",[F:XGB3]CPT,"GACCOUNT","")
    Endcase
    Raz DEBIT, CREDIT, DEBIT2, CREDIT2
    For [XGB3]CLE
     If [F:XGB3]X3DAT>=[L]DATPREMEX #DdM44704
      If [F:XGB3]SENECR="D"
       DEBIT += [F:XGB3]MNTDBTFRS
      Else
       CREDIT += [F:XGB3]MNTDBTFRS
      Endif
     Endif
    Next
    Gosub ECRAUX_X3
    Gosub TRACE
   Next
  Endif
  Endif
 Endif
Next

#Call LEC_TRACE From LECFIC
#Call FERME_TRACE From LECFIC
Return

$ECR_X3
If HISGNR=2 and BROGNR=2
 Link [DAE] With [HAE]HAE0 = [DAE]TYP;[DAE]NUM As [LNK]
&   Where evalue(FILTX3) & [F:DAE]ACC=[L]COMPTE
&  Order By Key CLE=[HAE]STA;[DAE]ACC;[DAE]TYP;[DAE]NUM
Elsif HISGNR=2
 Link [DAE] With [HAE]HAE0 = [DAE]TYP;[DAE]NUM As [LNK]
&   Where  evalue(FILTX3) & [F:DAE]ACC=[L]COMPTE &
&          [HAE]STA=2
&  Order By Key CLE=[HAE]STA;[DAE]ACC;[DAE]TYP;[DAE]NUM

Elsif BROGNR=2
 Link [DAE] With [HAE]HAE0 = [DAE]TYP;[DAE]NUM As [LNK]
&   Where  evalue(FILTX3) & [F:DAE]ACC=[L]COMPTE &
&          [HAE]STA=1
&  Order By Key CLE=[HAE]STA;[DAE]ACC;[DAE]TYP;[DAE]NUM

Endif

Raz DEBIT2, CREDIT2
For [LNK]CLE
 If [F:DAE]SNS=1
  DEBIT2 += [F:DAE]AMTLED
 Else
  CREDIT2 += [F:DAE]AMTLED
 Endif
Next
Return

$ECRAUX_X3
If HISGNR=2 and BROGNR=2
 Link [DAE] With [HAE]HAE0 = [DAE]TYP;[DAE]NUM As [LNK]
&   Where  evalue(FILTX3) & [F:DAE]ACC=[L]COMPTE & [F:DAE]BPR=[L]TIERS
&  Order By Key CLE=[HAE]STA;[DAE]ACC;[DAE]TYP;[DAE]NUM
Elsif HISGNR=2
 Link [DAE] With [HAE]HAE0 = [DAE]TYP;[DAE]NUM As [LNK]
&   Where  evalue(FILTX3) & [F:DAE]ACC=[L]COMPTE & [F:DAE]BPR=[L]TIERS &
&          [HAE]STA=2
&  Order By Key CLE=[HAE]STA;[DAE]ACC;[DAE]TYP;[DAE]NUM

Elsif BROGNR=2
 Link [DAE] With [HAE]HAE0 = [DAE]TYP;[DAE]NUM As [LNK]
&   Where  evalue(FILTX3) & [F:DAE]ACC=[L]COMPTE & [F:DAE]BPR=[L]TIERS &
&          [HAE]STA=1
&  Order By Key CLE=[HAE]STA;[DAE]ACC;[DAE]TYP;[DAE]NUM

Endif

Raz DEBIT2, CREDIT2
For [LNK]CLE
 If [F:DAE]SNS=1
  DEBIT2 += [F:DAE]AMTLED
 Else
  CREDIT2 += [F:DAE]AMTLED
 Endif
Next
Return


$TRACE
If DEBIT<>0 | DEBIT2<>0 | CREDIT<>0 | CREDIT2<>0
 If DEBIT<>DEBIT2 | CREDIT<>CREDIT2
  If DEBIT-CREDIT = DEBIT2-CREDIT2
   # Compte...  Solde identique
   Call ECR_TRACE(mess(45,102,1)-[L]COMPTE-[L]TIERS-":"-SI_MES(161),0) From GESECRAN
  Else
   # Compte... Solde différent
   Call ECR_TRACE(mess(45,102,1)-[L]COMPTE-[L]TIERS-":"-SI_MES(160),1) From GESECRAN
  Endif
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  # GL Intégrale : ... Débit ; ... Crédit
  Call ECR_TRACE("GL Intégrale"-":"-num$(DEBIT)-mess(1,610,1)-"    ;    "-num$(CREDIT)-mess(2,610,1),0) From GESECRAN
  # GL X3 : ... Débit ; ... Crédit
  Call ECR_TRACE("GL X3 "-":"-num$(DEBIT2)-mess(1,610,1)-"    ;    "-num$(CREDIT2)-mess(2,610,1),0) From GESECRAN
 Else
   # Compte... Mouvements et soldes identiques
  Call ECR_TRACE(mess(45,102,1)-[L]COMPTE-[L]TIERS-":"-SI_MES(162),0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  # GL Intégrale : ... Débit ; ... Crédit
  Call ECR_TRACE("GL Intégrale"-":"-num$(DEBIT)-mess(1,610,1)-"    ;    "-num$(CREDIT)-mess(2,610,1),0) From GESECRAN
  # GL X3 : ... Débit ; ... Crédit
  Call ECR_TRACE("GL X3 "-":"-num$(DEBIT2)-mess(1,610,1)-"    ;    "-num$(CREDIT)-mess(2,610,1),0) From GESECRAN
 Endif
 Call ECR_TRACE("",0) From GESECRAN
Endif
Return

$FILTRE

# Variables pour effectur le filtre
Local Char FILTINT(250)(1..4)
Local Integer IFILT : IFILT = 0

Local Char FILTX3(250)(1..4)
Local Integer IFILX : IFILX = 0

Call ADDCRIT(FILTINT,IFILT,"",'1=1'," & ") From GOBJSUB

Call ADDCRIT(FILTX3,IFILX,"",'(left$([F:HAE]REFINT,5)="INTEG")'," & ") From GOBJSUB
Call ADDCRIT(FILTX3,IFILX,"",'[F:HAE]FLGREP<>2'," & ") From GOBJSUB
Call ADDCRIT(FILTX3,IFILX,"",'[F:DAE]LEDTYP='+num$(GTYPGEN)," & ") From GOBJSUB

# Journaux
If [M:SIL]ALLJOU<>2
  # If [M:SIL]JOUSTR=[M:SIL]JOUEND
  Call ADDCRIT(FILTX3,IFILX,"JOUSTR",'[F:HAE]JOU="'+[M:SIL]JOUSTR+'"'," & ") From GOBJSUB
  Raz NBJOU, TJOU
  For [XJRN] Where X3CLE=[M:SIL]JOUSTR
   NBJOU += 1
   TJOU(NBJOU) = [F:XJRN]CODJRN
   If NBJOU>=dim(TJOU) : Break : Endif
  Next
  Call ADDCRIT(FILTINT,IFILT,"JOUSTR",'find(CODJRN,TJOU(1..NBJOU))'," & ") From GOBJSUB

# Else
#  Call ADDCRIT(FILTINT,IFILT,"JOUSTR",'CODJRN>="'+[M:SIL]JOUSTR+'"'," & ") From GOBJSUB
#  Call ADDCRIT(FILTINT,IFILT,"JOUEND",'CODJRN<="'+[M:SIL]JOUEND+'"'," & ") From GOBJSUB
#  Call ADDCRIT(FILTX3,IFILX,"JOUSTR",'[F:HAE]JOU>="'+[M:SIL]JOUSTR+'"'," & ") From GOBJSUB
#  Call ADDCRIT(FILTX3,IFILX,"JOUEND",'[F:HAE]JOU<="'+[M:SIL]JOUEND+'"'," & ") From GOBJSUB
# Endif
Endif

# Période
If [M:SIL]ALLPER<>2
 Call ADDCRIT(FILTINT,IFILT,"PERSTR",'DATECR>=['+format$(GFMD,[M:SIL]PERSTR)+']'," & ") From GOBJSUB
 Call ADDCRIT(FILTINT,IFILT,"PEREND",'DATECR<=['+format$(GFMD,[M:SIL]PEREND)+']'," & ") From GOBJSUB
 Call ADDCRIT(FILTX3,IFILX,"PERSTR",'ACCDAT>=['+format$(GFMD,[M:SIL]PERSTR)+']'," & ") From GOBJSUB
 Call ADDCRIT(FILTX3,IFILX,"PEREND",'ACCDAT<=['+format$(GFMD,[M:SIL]PEREND)+']'," & ") From GOBJSUB
Endif

Return


######################################################################################
# Gestion du masque SITDIFGL
######################################################################################
Subprog D_INI(VALEUR)
Variable Decimal VALEUR
If [M:SIL]ALLJOU<>2
 Grizo [M:SIL]JOUSTR,JOUEND
Else
 Actzo [M:SIL]JOUSTR,JOUEND
Endif
If [M:SIL]ALLPER<>2
 Grizo [M:SIL]PERSTR,PEREND
Else
 Actzo [M:SIL]PERSTR,PEREND
Endif
End

Subprog C_ALLJOU(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Grizo [M:SIL]JOUSTR,JOUEND
Else
 Actzo [M:SIL]JOUSTR,JOUEND
Endif
End

Subprog AS_JOUSTR(VALEUR)
Variable Char    VALEUR()
If [M:SIL]ALLJOU=2 : mkstat=2 : Endif
End

Subprog AS_JOUEND(VALEUR)
Variable Char    VALEUR()
If [M:SIL]ALLJOU=2 : mkstat=2 : Endif
If VALEUR="" : VALEUR=[M:SIL]JOUSTR : Endif
End

Subprog C_JOUEND(VALEUR)
Variable Char    VALEUR()
If [M:SIL]JOUSTR>VALEUR
 # La borne fin est inférieure à la borne début
 mkstat=2 : GMESSAGE = mess(44,199,1) : End
Endif
End

Subprog C_ALLPER(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Grizo [M:SIL]PERSTR,PEREND
Else
 Actzo [M:SIL]PERSTR,PEREND
Endif
End

Subprog AS_PERSTR(VALEUR)
Variable Date    VALEUR
If [M:SIL]ALLPER=2 : mkstat=2 : Endif
Local Date WDAT
If !clalev([F:PER])  : Local File =SI_DOSSIER+".PERIOD"      [PER]  : Endif   # Périodes
If VALEUR=[0/0/0]
 Call SETMAINREF(GDEFSOC,GTYPGEN,GTYPANA) From CPTDIV
 Call DATEXE(GDEFSOC,GTYPGEN,1,VALEUR,WDAT) From CPTSUB
Endif
End

Subprog C_PERSTR(VALEUR)
Variable Date    VALEUR
If !clalev([F:PER])  : Local File =SI_DOSSIER+".PERIOD"      [PER]  : Endif   # Périodes
Filter [PER] Where CPY=GDEFSOC
For [PER]PER0
 If [F:PER]PERSTR=VALEUR
   mkstat = 0
   Break
  Else
   mkstat = 2
 Endif
Next
Filter [PER]
# La date n'est pas une date de début de période
If mkstat=2 : GMESSAGE = mess(49,108,1) :  : End : Endif
End

Subprog AS_PEREND(VALEUR)
Variable Date    VALEUR
If [M:SIL]ALLPER=2 : mkstat=2 : Endif
Local Date WDAT
If !clalev([F:PER])  : Local File =SI_DOSSIER+".PERIOD"      [PER]  : Endif   # Périodes
If VALEUR=[0/0/0]
 Call SETMAINREF(GDEFSOC,GTYPGEN,GTYPANA) From CPTDIV
 Call DATEXE(GDEFSOC,GTYPGEN,1,WDAT,VALEUR) From CPTSUB
Endif
End

Subprog C_PEREND(VALEUR)
Variable Date    VALEUR
If !clalev([F:PER])  : Local File =SI_DOSSIER+".PERIOD"      [PER]  : Endif   # Périodes
Filter [PER] Where CPY=GDEFSOC
For [PER]PER0
 If [F:PER]PEREND=VALEUR
   mkstat = 0
   Break
  Else
   mkstat = 2
 Endif
Next
Filter [PER]
# La date n'est pas une date de fin de période
If mkstat=2 : GMESSAGE = mess(50,108,1) :  End : Endif
End

