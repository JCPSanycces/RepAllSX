#<AdxTL>@(#)9.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("IDP",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "LIENS"        : Gosub LIENS
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
Endcase
Return

$OUVRE
If clalev([F:GCM]) = 0 : Local File GACM [GCM] : Endif
Local Char    SOCIETE(GLONCPY)
Local Integer I
Return

$LIENS
SOCIETE=[F:IDP]CPY
Call SETGCM(SOCIETE,[M]GCM) From CPTDIV
If [F:GCM]GCM<>[M]GCM
 Call LECTURE("GCM",[M]GCM,"") From CONTOBJ
Endif
For I=0 To len(mess(0,2644,1))-1
 If !find(I+1,[M]LEDTYP(0..[M]NBRLED-1)) & [F:GCM]LED(I)<>"" & [F:GCM]CFMAUT(I)<>2
  [M]NBRLED += 1
  [M]LEDTYP([M]NBRLED-1) = I+1
  [M]ACCDACFLG([M]NBRLED-1) = 1
 Endif
Next I
Return

$AVANT_MODFIC
## On veut que compte du type de référentiel principal général soit tjs saisi en premier => stokage du
## ce type de référentiel en 1er
Sorta [M]NBRLED [M]NBRLED Order By [M]ACCDACFLG(indice)*-1, [M]DAC(indice)
Return

######################################################################################
## Etiquette masque IPD1 (Paramétrage saisie factures tiers)
######################################################################################

Subprog AS_ACCDACFLG(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
## Les comptes du référentiel principal général et analytique sont forcément saisissables...
If find([M]LEDTYP(NOL),[F:GCM]GENLEDTYP,[F:GCM]ANALEDTYP)
 VALEUR = 2
 mkstat = 2 : End
Endif
End

Subprog AS_DAC(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
If [M]ACCDACFLG(NOL)<>2
 VALEUR = 0
 mkstat = 2 : End
Endif
## Le compte du référentiel principal général sera TOUJOURS saisi en premier (n° ordre à zéro)
Call LECTURE("GCM",[M]GCM,"") From CONTOBJ
If [M]LEDTYP(NOL) = [F:GCM]GENLEDTYP
 mkstat = 1 : End
Endif
End

Subprog C_DAC(VALEUR)
Variable Decimal VALEUR
## Le compte du référentiel principal général sera TOUJOURS saisi en premier. Le numéro d'ordre des autres
## types de réféntiels devra être > à 1
If VALEUR<1
 ## Valeur incorrecte
 GMESSAGE = mess(83,123,1)
 mkstat = 2 : End
Endif
If VALEUR<>0
 Call UNICITE(VALEUR,[M]DAC) From OBJDIV
Endif
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

## Création du paramétrage de saisie de factures tiers (clients et fournisseurs)
## pour une société. Par défaut, les plans de comptes du référentiel général principal
## et du référentiel analytique principal sont saisissables
## Sous programme appelé en création d'une société
Subprog CREIDP(SOCIETE,MODELE)
Value Char SOCIETE()
Value Char MODELE()
If clalev([F:GCM]) = 0 : Local File GACM      [GCM] : Endif
If clalev([F:IDP]) = 0 : Local File INVDACPAR [IDP] : Endif
Local Integer TYPDOC, I
Call LECTURE("GCM",[L]MODELE,"") From CONTOBJ
For TYPDOC=1 To len(mess(0,2651,1))
 Raz [F:IDP]
 [F:IDP]CPY = [L]SOCIETE
 [F:IDP]TYP = [L]TYPDOC

 [F:IDP]NBRLED += 1
 [F:IDP]LEDTYP([F:IDP]NBRLED-1) = [F:GCM]GENLEDTYP
 [F:IDP]ACCDACFLG([F:IDP]NBRLED-1) = 2
 [F:IDP]DAC([F:IDP]NBRLED-1) = 0

 If [F:GCM]GENLEDTYP<>[F:GCM]ANALEDTYP
  [F:IDP]NBRLED += 1
  [F:IDP]LEDTYP([F:IDP]NBRLED-1) = [F:GCM]ANALEDTYP
  [F:IDP]ACCDACFLG([F:IDP]NBRLED-1) = 2
  [F:IDP]DAC([F:IDP]NBRLED-1) = 10
 Endif

 For I=0 To len(mess(0,2644,1))-1
  If [F:GCM]LED(I)<>"" & [F:GCM]CFMAUT(I)<>2 & I+1<>[F:GCM]GENLEDTYP & I+1<>[F:GCM]ANALEDTYP
   [F:IDP]NBRLED += 1
   [F:IDP]LEDTYP([F:IDP]NBRLED-1) = I+1
   [F:IDP]ACCDACFLG([F:IDP]NBRLED-1) = 1
  Endif
 Next I
 Write [F:IDP]
 If fstat
  GOK=0 : Call FSTA("IDP") From GLOCK : Break
 Endif
Next TYPDOC
End

