#<AdxTL>@(#)0.0.0.0 $Revision$
#** V7 : Waiting Time Management **#

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

  If clalev([F:ARM])=0    : Local File AREPORTM   [ARM]   : Endif
  If clalev([F:HSP])=0    : Local File HISTOPAYE  [HSP]   : Endif
  If clalev([F:VEP])=0    : Local File VALEMP     [VEP]   : Endif
  If clalev([F:FGR])=0    : Local File FACGROUP   [FGR]   : Endif
  If clalev([F:FCY])=0    : Local File FACILITY   [FCY]   : Endif
  If clalev([F:ID])=0     : Local File EMPLOID    [ID]    : Endif
  If clalev([F:HRPOA])=0  : Local File POPULA     [HRPOA] : Endif

  Local Integer I, NUMREQ
  Local Char    PARAM(30), ETAT([V]GLONARP), POP([V]GLONPOP)
  Local Date    DATPYR
  Local Char    CRITERE(250)

  Call GETPARAM("__REQUETE",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT
  [L]NUMREQ=val([L]PARAM)
  Call SETPARAM("numedt",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT

  Call GETPARAM("X3ETA",[L]NBPAR,[L]PARAMETRE,[L]ETAT) From ETAT

  CRITERE="1=1"
  Call GETPARAM("societe",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT    : If [L]PARAM>" " : [L]CRITERE-='& [F:FGR]CPY="'+[L]PARAM+'"' : Endif
  Call GETPARAM("sitedeb",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT    : If [L]PARAM>" " : [L]CRITERE-='& [F:FGR]FCY>="'+[L]PARAM+'"' : Endif
  Call GETPARAM("sitefin",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT    : If [L]PARAM>" " : [L]CRITERE-='& [F:FGR]FCY<="'+[L]PARAM+'"' : Endif
  Call GETPARAM("datpyr",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT     : DATPYR=[L]PARAM
  Call GETPARAM("population",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT : POP=[L]PARAM
  Call GETPARAM("matdeb",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT     : If [L]PARAM>" " : [L]CRITERE-='& [F:HSP]EMP>="'+[L]PARAM+'"' : Endif
  Call GETPARAM("matfin",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT     : If [L]PARAM>" " : [L]CRITERE-='& [F:HSP]EMP<="'+[L]PARAM+'"' : Endif
  Call GETPARAM("profil",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT     : If [L]PARAM>" " : [L]CRITERE-='& [F:VEP]PRF="'+[L]PARAM+'"'  : Endif
  Call GETPARAM("service",[L]NBPAR,[L]PARAMETRE,[L]PARAM) From ETAT    : If [L]PARAM>" " : [L]CRITERE-='& [F:VEP]SRV="'+[L]PARAM+'"'  : Endif

  If GPAYE Then
    Link [F:HSP] With [F:VEP]VEP0=[F:HSP]EMP;[F:HSP]DAT;[F:HSP]BUL, [F:ID]ID0=[F:HSP]EMP, [F:FGR]FGR1=[F:VEP]FCY
&                     As [LNK]
&                     Where evalue([L]CRITERE) & [F:ID]ENAFLG=2 & [F:HSP]TYP=6
&                     & [F:HSP]DAT=DATPYR & [F:VEP]PYRDAT=DATPYR
&                     Order By [F:HSP]EMP;[F:HSP]CTRNUM

    Call DEBTRANS From GLOCK
    $TR_EDIT
    [V]GOK=1
    Trbegin [ARM]
    Delete [F:ARM] Where USR=[V]GUSER & RPTCOD=[L]ETAT
    Gosub EDIT
    If [V]GOK=-1 Then
      Rollback
      Call ROLL From GLOCK
      If [V]GROLL : End : Else Goto TR_EDIT : Endif
    Elsif ![V]GOK Then
      Rollback
      End
    Endif
    Commit
  Endif
End

$EDIT
Local Integer OK, IND
Local Decimal NBRHOUDIF
Local Char    CTRNUM, REFNUM, SAUCTRNUM, SAUREFNUM

  Raz [F:ARM]
  [F:ARM]NUMREQ=[L]NUMREQ
  [F:ARM]USR   =[V]GUSER
  [F:ARM]RPTCOD=[L]ETAT
  [F:ARM]CREDAT=date$

  SAUCTRNUM="" : SAUREFNUM=""
  For [F:LNK]
    OK=2
    CTRNUM=[F:HSP]CTRNUM
    REFNUM=[F:HSP]EMP
    If CTRNUM<>SAUCTRNUM | REFNUM<>SAUREFNUM Then
      SAUCTRNUM=CTRNUM : SAUREFNUM=REFNUM
      If POP<>"" & POP<>" " Then
        Read [F:HRPOA]POA0=POP;[F:HSP]EMP
        If fstat Then
          OK=1
        Endif
      Endif

      If OK=2 Then
      #ADNGO - 2017-02-15 - START
#** V7 : Waiting Time Management **#
#        If GTPS & GPAYE Then
#          Call SOLDE_DIF([F:HSP]EMP,[F:HSP]CTRNUM,[F:HSP]DAT,NBRHOUDIF) From DIVPAYE
#        Endif

        If GTPS & GPAYE Then
          Call SOLDE_DIF([F:HSP]EMP,[F:HSP]CTRNUM,[F:HSP]DAT,NBRHOUDIF) From DIVPAYE
        Endif
        #ADNGO - 2017-02-15 - END
        [F:ARM]SEQREQ = 1
        [F:ARM]CLEA1  = [F:HSP]EMP
        [F:ARM]CLEA2  = [F:HSP]CTRNUM
        [F:ARM]CLEA3  = [F:VEP]FCY
        [F:ARM]CLEA4  = [F:ID]CODACS
        [F:ARM]CLEA5  = [F:VEP]BUL
        [F:ARM]CLEN1  = [F:VEP]STA
        [F:ARM]CLED1  = [F:HSP]DAT
        [F:ARM]CLEMD1 = NBRHOUDIF
        [F:ARM]NUMLIG+=1
        Write [ARM]
        If fstat
          [V]GOK=0
          Call FSTA("ARM") From GLOCK
          Break
        Endif
      Endif
    Endif
  Next
Return

