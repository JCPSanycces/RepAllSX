#<AdxTL>@(#)9.0.0.0 $Revision$
# Issue X3-28791 - 2017-08-30 by BAKHA : WO opertaions critical changes
# Issue X3-55431 - 2017-09-15 by BAKHA : Remove info message before critical fields

$ACTION
  Case ACTION
    When "SEL_TABLE"  : Case TABLE
                          When "SELRVMVAL"  : Gosub SELRVMVAL
                        Endcase
    When "VERF_TABLE" : Case TABLE
                          When "SELRVMVAL"  : Gosub VERFRVMVAL
                        Endcase
  Endcase
Return

# Selection of a route version
$SELRVMVAL
  Local Char LITMREF(GLONITM)          : LITMREF = PARAM(1)
  Local Char LFCY(GLONFCY)             : LFCY    = PARAM(2)
  Local Char LECCMAJ(GLONICVVAL)       : LECCMAJ = PARAM(3)
  Local Char LZONECCMIN(len(PARAM(4))) : LZONECCMIN = PARAM(4)
  Local Date LDAT                      : LDAT    = PARAM(5)
  Local Char LABREV(10)                : LABREV  = PARAM(6)
  Local Integer CRITERE_INDEX

  Raz CRITERE, CRITERE_INDEX

  Call ADDCRIT(CRITERE, CRITERE_INDEX, "", "[RVV]USESTA=2", "&") From GOBJSUB
  Call ADDCRIT(CRITERE, CRITERE_INDEX, "", "[RVV]ITMREF='"+LITMREF+"'", "&") From GOBJSUB
  Call ADDCRIT(CRITERE, CRITERE_INDEX, "", "[RVV]FCY='"+LFCY+"'", "&") From GOBJSUB
  Call ADDCRIT(CRITERE, CRITERE_INDEX, "", "[RVV]STRDAT<=LDAT", "&") From GOBJSUB
  Call ADDCRIT(CRITERE, CRITERE_INDEX, "", "([RVV]ENDDAT>=LDAT | [RVV]ENDDAT=[0/0/0]", "&") From GOBJSUB
  Call ADDCRIT(CRITERE, CRITERE_INDEX, "", "([RVV]EXNFLG=2 & ([RVV]EXNDAT>=LDAT | [RVV]EXNDAT=[0/0/0])))", "|") From GOBJSUB

  If (LZONECCMIN = "")
    Call ADDCRIT(CRITERE, CRITERE_INDEX, "", "[RVV]ECCVALMAJ='"+LECCMAJ+"'", "&") From GOBJSUB
    EXPSTART = "[RVV]ECCVALMAJ='"+LECCMAJ+"' & [RVV]ECCVALMIN='"+VALEUR+"'"
    START = "[RVV]ECCVALMIN"
  Else
    EXPSTART = "[RVV]ECCVALMAJ='"+VALEUR+"' & [RVV]ECCVALMIN='"+evalue(LZONECCMIN)+"'"
    START = "[RVV]ECCVALMAJ"
  Endif

  OBJET = "RVV1"
Return

$VERFRVMVAL
  If (LZONECCMIN <> "" & [F:RVV]ECCVALMIN <> evalue(LZONECCMIN))
      Assign LZONECCMIN With [F:RVV]ECCVALMIN
      Affzo = LZONECCMIN
      # Issue X3-55362 - 2017-09-20 by JUSYN : routing reload if routing selected from selection list and only minor version has changed
      If (instr(1,dbgstr(1),"MFG1")) : GROUTING = 1 : Endif
      # End issue X3-55362
      mkstat = 4
  Endif
Return

#**----------------------------------------------------------------<br/>
#* @param ROU = Route number
#* @return Number of components for a version of the routing</br>
#*         0 => Routing or folder with no versioning<br/>
#*         1 => Routing with only major version</br>
#*         2 => Routing with major and minor version
#**<br/>----------------------------------------------------------------
#*!
Funprog NBRCPNROU(ROU)
Value Char ROU()

If ROU="" : End 0 : Endif
If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
If [F:ITM]ITMREF<>[L]ROU
   Read [ITM]ITM0 = [L]ROU
   If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITM]ECCROUFLG=2
    If [F:ITM]ECCMIN<>"" : End 2
    Elsif [F:ITM]ECCMAJ<>"" : End 1
    Endif
Endif
End 0

#**----------------------------------------------------------------<br/>
#* LCKROH : Lock ROH symbole, if it is not already done by the current session
#**<br/>----------------------------------------------------------------<br/>
#* @param FCY    = Route site
#* @param ROU    = Route number
#* @param ALT    = Route code
#* @return 1 if lock is done, 0 if there is a lock issue
#**<br/>----------------------------------------------------------------
#*!
Funprog LCKROH(FCY,ROU,ALT)
Value Char    FCY()
Value Char    ROU()
Value Integer ALT

Local Char SYMBOLE(100)
Local Integer VERROU

SYMBOLE="ROH"+num$([L]ALT)+"\"+[L]ROU+"\"+[L]FCY
Call TESTLOCK(SYMBOLE,VERROU) From GLOCKM
If !VERROU
  Lock =SYMBOLE With lockwait=0
  If !fstat : VERROU=1 : Endif
Endif
End VERROU

######################################################################################################
# Before entry action to inhibite the entry of the field
# except during the developement of the first version
######################################################################################################

Subprog PASBUTRVM1
If dim([M:ROU0]ECCSEQ)=1 & [M:ROU0]ECCSEQ<>0
&  & !([M:ROU0]ECCSEQ=-1 | ([M:ROU0]ECCSEQ=1 & [M:ROU0]USESTA=1))
   # GH 23/02/2016 PE 114750 to enable to enter a field even if versioning
   GPE=0 : GPOINT = "PASBUTRVM1" : Gosub  ENTREE From EXEFNC
   If !GPE : mkstat=2 : Endif
Endif
End

######################################################################################################
# Before entry action to inhibite the entry of the field
# for a version avalailable to use
######################################################################################################

Subprog PASRVMUSE2
If dim([M:ROU0]ECCSEQ)<>1 | [M:ROU0]ECCSEQ=0 : End : Endif

Local Integer NOL
If dim([M]OPENUM)=1 : NOL=0 : Else NOL=nolign-1 : Endif
If [M]CREFLG(NOL)=0 : End : Endif

# Existing line
# Version available to use
# or Version in development & line with impact on previous versions
If [M:ROU0]USESTA=2 | [M]VALSTRDAT(NOL)<>[M:ROU0]ECCDAT
   # GH 23/02/2016 PE 114750 to enable to enter a field even if versioning
   GPE=0 : GPOINT = "PASRVMUSE2" : Gosub  ENTREE From EXEFNC
   If !GPE : mkstat=2 : Endif
Endif
End

#**----------------------------------------------------------------<br/>
#* GETRVMALT : Return the route code to use if the routing is versioned at a date
#**<br/>----------------------------------------------------------------<br/>
#* @param ROU = Route number
#* @param FCY = Route site
#* @param DAT = Date to use
#* @return Route code if the routing is versioned at the date, or 0 if not
#**<br/>----------------------------------------------------------------
#*!
Funprog GETRVMALT(ROU,FCY,DAT)
Value Char ROU()
Value Char FCY()
Value Date DAT

If func RVMLIB.NBRCPNROU([L]ROU)>0 & [F:ITM]ECCROUALT(1)<>0
    If !clalev([F:RVV]) : Local File RVMVAL [RVV] : Endif
    If [L]DAT<>[0/0/0]
        # ...try to find a version available for the date
       Filter [RVV] Where ITMREF = [L]ROU
&                       & FCY    = [L]FCY
&                       & STRDAT<= [L]DAT
&                       & USESTA = 2
&                       & ROUALT = [F:ITM]ECCROUALT(1)
    Else
        # ...try to find a version available
       Filter [RVV] Where ITMREF = [L]ROU
&                       & FCY    = [L]FCY
&                       & USESTA = 2
&                       & ROUALT = [F:ITM]ECCROUALT(1)
    Endif
    Look [RVV] First
    Filter [RVV]
    If !fstat
        End [F:ITM]ECCROUALT(1)
    Endif
Endif

End 0

#**----------------------------------------------------------------<br/>
#* INIECCROU : Return version number for a routing and a date
#**<br/>----------------------------------------------------------------<br/>
#* @param ROU = Route number
#* @param FCY = Route site
#* @param DAT = Validity date (optional, if null -> date used is today)
#* @param ALT = Route code
#* @param ECCMAJ = Major version (returned)
#* @param ECCMIN = Minor version (returned)
#**<br/>----------------------------------------------------------------
#*!
Subprog INIECCROU(ROU,FCY,DAT,ALT,ECCMAJ,ECCMIN)
Value Char    ROU()
Value Char    FCY()
Value Date    DAT
Value Integer ALT
Variable Char ECCMAJ()
Variable Char ECCMIN()

Raz [L]ECCMAJ, [L]ECCMIN
If [L]ROU="" : End : Endif

Local Date WDATE : WDATE=[L]DAT
If WDATE=[0/0/0] : WDATE=date$ : Endif

If !clalev([F:RVV]) : Local File RVMVAL [RVV] : Endif

Filter [RVV] Where [RVV]ITMREF=[L]ROU
&                & [RVV]FCY=[L]FCY
&                & [RVV]ROUALT=[L]ALT
&                & [RVV]USESTA=2
&                & [RVV]STRDAT<=WDATE
&                & ([F:RVV]ENDDAT=[0/0/0] | [F:RVV]ENDDAT>=WDATE | [F:RVV]EXNFLG=2)
&                & ([F:RVV]EXNDAT=[0/0/0] | [F:RVV]EXNDAT>=WDATE | [F:RVV]EXNFLG=1)
&                Order By STRDAT Desc   # correction done during 111414/113. Before EXNFLG;ECCSEQ was used
For [RVV]
      [L]ECCMAJ = [F:RVV]ECCVALMAJ
      [L]ECCMIN = [F:RVV]ECCVALMIN
      Break
Next
Filter [RVV]
End

# Issue 111414/113 - 2016-03-23 by JUSYN : Needed to have start date for selection of routing.
#**----------------------------------------------------------------<br/>
#* INIECCROUDAT : Returns start date of the version.
#**<br/>----------------------------------------------------------------<br/>
#* @param PROU    = Route number
#* @param PFCY    = Route site
#* @param PECCMAJ = major version
#* @param PECCMIN = minor version
#* @param PDAT    = start of validity date
#**<br/>----------------------------------------------------------------
#*!
Subprog INIECCROUDAT(PROU,PFCY,PALT,PECCMAJ,PECCMIN,PDAT)
Value    Char    PROU
Value    Char    PFCY
Value    Integer PALT
Value    Char    PECCMAJ
Value    Char    PECCMIN
Variable Date    PDAT

If [L]PROU="" : End : Endif

# Initialise PDAT; this value will be returned if no version record was found.
PDAT = [0/0/0]

If !clalev([F:RVV]) : Local File RVMVAL [RVV] : Endif

Filter [RVV] Where [RVV]ITMREF=[L]PROU
&                & [RVV]FCY=[L]PFCY
&                & [RVV]ROUALT=[L]PALT
&                & ([RVV]ECCVALMAJ=PECCMAJ | PECCMAJ="")
&                & ([RVV]ECCVALMIN=PECCMIN | PECCMIN="")
&                & [RVV]USESTA=2

For [RVV]
    PDAT=[F:RVV]STRDAT
    Break
Next

Filter [RVV]
End

#**----------------------------------------------------------------<br/>
#* RVMALT : Display or hide routing version fields and route code field
#*          in a screen according to a routing
#**<br/>----------------------------------------------------------------<br/>
#* @param ROU = Route number
#* @param FCY = Route site
#* @param ALT = Route code
#* @param ABR = Screen abbreviation (context)
#**<br/>----------------------------------------------------------------
#*!
Subprog RVMAFF(ROU,FCY,ALT,ABR)
Value Char    ROU()
Value Char    FCY()
Value Integer ALT
Value Char    ABR()

Local Char MABR(10)
If [L]ABR="" : MABR="[M]" : Else MABR = "[M:"+[L]ABR+"]" : Endif

If evalue("dim("+MABR+"ROUECCMAJ)")<0 | GIMPORT : End : Endif

Local Integer LACTMAJ, LACTMIN, LACTROU
Local Integer I, LRVVFLG

#I=func RVMLIB.NBRCPNROU([L]ROU)
#If I
#    If !clalev([F:RVV]) : Local File RVMVAL [RVV] : Endif
#    Filter [RVV] Where ITMREF = [L]ROU
#&                    & ROUALT = [L]ALT
#&                    & FCY    = [L]FCY
#&                    & USESTA = 2
#    Look [RVV] First
#    Filter [RVV]
#    If !fstat
#        LRVVFLG=1
#    Endif
#Endif

If func GETRVMALT([L]ROU,[L]FCY,[0/0/0])
   LRVVFLG=1
   I=func NBRCPNROU([L]ROU)
Endif

If !I | !LRVVFLG
    LACTMAJ = 0
    LACTMIN = 0
    LACTROU = 1   # if no version management => ROUALT can be entered
Else
    If I=1
        LACTMAJ = 1
        LACTMIN = 0
    Else
        LACTMAJ = 1
        LACTMIN = 1
    Endif
    LACTROU=0   # if version management => BOMALT can't be entered
Endif

If !LACTMAJ
    Diszo =MABR+"ROUECCMAJ"
Else
    Actzo =MABR+"ROUECCMAJ"
Endif
If !LACTMIN
    Diszo =MABR+"ROUECCMIN"
Else
    Actzo =MABR+"ROUECCMIN"
Endif
If !LACTROU
    Diszo =MABR+"ROUALT"
Else
    Actzo =MABR+"ROUALT"
Endif
End

#**----------------------------------------------------------------<br/>
#* CTRROUECC : Control if a version number can be used in a WO for a date
#**<br/>----------------------------------------------------------------<br/>
#* @param PROU = Route number
#* @param PFCY = Route site
#* @param PABR = Screen abbreviation
#* @param PFLDCOD = Field code name
#* @param PECCMAJ = Major version number
#* @param PECCMIN = Minor version number
#* @param PDAT = Date to control (if [0/0/0] => no control)
#* @param PRET (return) = Error code (0=OK, 1=Error, 2=Message, 3=Warning, 4=blocking error) (like GERR for values up to 3)
#* @param PMSG (return) = Error message or all warning messages (void if PRET=0)
#**<br/>----------------------------------------------------------------
#*!
Subprog CTRROUECC(PROU,PFCY,PABR,PFLDCOD,PECCMAJ,PECCMIN,PDAT,PRET,PMSG)
Value Char       PROU()
Value Char       PFCY()
Value Char       PABR()
Value Char       PFLDCOD()
Value Char       PECCMAJ()
Value Char       PECCMIN()
Value Date       PDAT
Variable Integer PRET
Variable Char    PMSG()

Raz PRET, PMSG

Local Integer LCTL
# 1st= control on major version existence
# 2nd= control on minor version existence
# 3rd= control if the version start date is before the requested date
# 4th= control if the version end date is after the requested date
Local Char LCTLFLG(20)
Local Integer LNBCPN
Local Integer LSCDMOD

# number of components for version number (0=no version/ 1=major / 2=major+minor)
LNBCPN = func RVMLIB.NBRCPNROU(PROU)
If LNBCPN=0
    End
Endif

Case PABR
    When "MFG1" : LSCDMOD = [M:MFG1]SCDMOD
    When "MFGK" : LSCDMOD = [M:MFGK]SCDMOD
    When "MFG"  : LSCDMOD = [F:MFG]SCDMOD
    When "MBW1" : LSCDMOD = ([M:MBW1]LABEL=mess(2,334,1))+1
    When Default : LSCDMOD = 2
Endcase

# Default : Error on existence of version
If LSCDMOD=1
    # If backward scheduling, all previous version are available but warning
    LCTLFLG = "1113"
Else
    # If forward scheduling, version has to be valid for the requested date
    LCTLFLG = "1111"  # Default : Error on existence of version
Endif

If LNBCPN=2 & find(PFLDCOD,"ROUECCMAJ")
    LCTLFLG = left$(LCTLFLG,1)+"000"   # Default : On major version we control only existence of the version if minor version is available for the item
Endif

# 1 - Control of major version existence
LCTL = val(mid$(LCTLFLG,1,1))
If !clalev([F:RVV]) : Local File RVMVAL [RVV] : Endif
Read [RVV]RVV1=PROU;PFCY;PECCMAJ
If fstat & LCTL
    Call ADDMSG(PRET,PMSG,LCTL,mess(308,193,1)) From ECCLIB     # Non existent Version  !
Endif
If find(PRET,4,1) : End : Endif


# 2 - existence Major/Minor version for current flow type
LCTL = val(mid$(LCTLFLG,2,1))
Read [RVV]RVV1=PROU;PFCY;PECCMAJ;PECCMIN
If fstat
    If LCTL
        Call ADDMSG(PRET,PMSG,LCTL,mess(406,184,1)) From ECCLIB # Version inexistante !
    Endif
Else
    If PRET<>1
        # 3 - Is the version start date before the requested date ?
        LCTL = val(mid$(LCTLFLG,3,1))
        If LCTL & PDAT<>[0/0/0]
            Local Date WDATE : WDATE=PDAT
            If  WDATE<[F:RVV]STRDAT
                Call ADDMSG(PRET,PMSG,LCTL,mess(432,184,1)-format$("D:"+GFMDAT,WDATE)) From ECCLIB # 'Unavailable version at'
            Endif
        Endif
        If find(PRET,4,1) : End : Endif
        # 4 - Is the version end date after the requested date ?
        LCTL = val(mid$(LCTLFLG,4,1))
        If LCTL & PDAT<>[0/0/0]
            Local Date WDATE : WDATE=PDAT
            If ([F:RVV]ENDDAT<>[0/0/0] & [F:RVV]ENDDAT<WDATE & [F:RVV]EXNFLG=1)
&            | ([F:RVV]EXNDAT<>[0/0/0] & [F:RVV]EXNDAT<WDATE & [F:RVV]EXNFLG=2)
                Call ADDMSG(PRET,PMSG,LCTL,mess(432,184,1)-format$("D:"+GFMDAT,WDATE)) From ECCLIB # 'Unavailable version at'
            Endif
        Endif
    Endif
Endif
If find(PRET,4,1) : End : Endif

End

#**----------------------------------------------------------------<br/>
#* HIGHLIGHT : Refresh style of routing according to the error number
#**<br/>----------------------------------------------------------------<br/>
#* @param ABR = Screen abbreviation (context)
#* @param ERR = Error gravity
#**<br/>----------------------------------------------------------------
#*!
Subprog HIGHLIGHT(ABR,ERR)
Value Char    ABR()
Value Integer ERR

If GIMPORT : End : Endif

Local Char LWRNSTY(20) : LWRNSTY = "BACKORANGE"
Local Char LERRSTY(20) : LERRSTY = "BACKRED"

Case [L]ABR
    When "MFG1"
            Case [L]ERR
                When 1, 4 : # Error
                    Chgstl [M:MFG1]ROUECCMAJ,ROUECCMIN With LERRSTY
                When 3    : # Warning
                    Chgstl [M:MFG1]ROUECCMAJ,ROUECCMIN With LWRNSTY
                When Default
                    Chgstl [M:MFG1]ROUECCMAJ,ROUECCMIN With ""
            Endcase
Endcase
End

#**----------------------------------------------------------------<br/>
#* change a date not included in the validity period of a version<br/>
#* either to the start date of the version if the date was before<br/>
#* or to the end date of the version if the date was after
#**<br/>----------------------------------------------------------------<br/>
#* @param ROU = Route number
#* @param ECCMAJ = Major version number
#* @param ECCMIN = Minor version number
#* @param FCY = Route site
#* @param DAT (return) = Date
#**<br/>----------------------------------------------------------------
#*!
Subprog CORDAT(ROU,ECCMAJ,ECCMIN,FCY,DAT)
Value Char    ROU()
Value Char    ECCMAJ()
Value Char    ECCMIN()
Value Char    FCY()
Variable Date DAT

If !clalev([F:RVV]) : Local File RVMVAL [RVV] : Endif
Read [RVV]RVV1 = [L]ROU;[L]FCY;[L]ECCMAJ;[L]ECCMIN
If    [L]DAT<[F:RVV]STRDAT                          : [L]DAT = [F:RVV]STRDAT
Elsif [F:RVV]ENDDAT<>[0/0/0] & [L]DAT>[F:RVV]ENDDAT : [L]DAT = [F:RVV]ENDDAT
Endif
End

######################################################################################################
# Issue X3-6109 - 2017-01-25 by ALSHE : Block changes on the WO-Routing "versioned"
# Before entry action to inhibite the entry of the field
# if the routing is managed by version - no change allowed
######################################################################################################
Subprog PASRVMMFM

If dim([M:MFG1]ROUECCMAJ)<0 : End : Endif : # it just concerns folders with versioning

If [M:MFG1]ROUECCMAJ<>""
    mkstat=2
    # Issue X3-28791 - Do not lock certain fields if user has permission to do critical changes on operations
    If GOPECRICHG & GREP<>"C" # Not during creation of WO
#        # Info message only once generally
#        If !GOPEREVMES & zoncou <> "REVREASON" & [M:MFG3]OPESTA(nolign-1) < 5
#            GOPEREVMES = 1
#            GERR = 2
#            GMESSAGE = mess(401,193,1) # You are about to do critical changes on a versioned routing operations
#        Endif
        If GMFGREV = 2
            mkstat = 0
        Endif
    Endif
Else
    If zoncou = "REVREASON"
        mkstat = 2
    Endif
    # End issue X3-28791
Endif
End

# Issue X3-28791 - WO opertaions critical changes
#**----------------------------------------------------------------<br/>
#* CTRECCWOOPE : Control if user has permission to do critical changes in WO operations
#**<br/>----------------------------------------------------------------<br/>
#* Sets global parameter GOPECRICHG 0 = no permission 1 = permission
#**<br/>----------------------------------------------------------------
#*!
Subprog CTRECCWOOPE()
Local Integer LRET
Local Char ECCWOOPE(30)

If dim([M:MFG1]ROUECCMAJ) < 0 : End : Endif # Issue X3-55431

Call PARAMUTIL("ECCWOOPE",ECCWOOPE,GUSER,"") From SUBAUS
If ECCWOOPE = "2"
    GOPECRICHG=1   # = Yes
Else
    GOPECRICHG=0   # = No
Endif

End

# Issue end X3-28791

# Issue X3-28791 - 2017-09-05 by JUSYN : Before entry action to allow entry of field if user has
#                                        permissions and routing is versioned
Subprog MFGRVMCRIC()

If dim([M:MFG1]ROUECCMAJ) < 0 : End : Endif
mkstat=2
If GMFGREV=2 & GOPECRICHG
    # check routing is versioned
    If GREP <> "C"
        If [M:MFG1]ROUECCMAJ <> ""
            mkstat = 0
        Endif
    Endif
Endif

End
# Issue X3-28791 - 2017-09-05 by JUSYN - End

# Issue X3-55362 - Check if operations audit exists for a Work order
#**----------------------------------------------------------------<br/>
#* CHECKWOOPEAUDIT : Check if operations audit exists for a Work order
#**<br/>----------------------------------------------------------------<br/>
#* 0 = there is no audit  |  1 = there is audit for this WO
#**<br/>----------------------------------------------------------------
#*!
Funprog CHECKWOOPEAUDIT()

Local Shortint LRET  :  LRET = 0

If dim([M:MFG1]ROUECCMAJ) < 0 : End : Endif

Local File MFGOPEREV [MOR]

Filter [MOR] Where [MOR]MFGNUM=[M:MFG0]MFGNUM
Look [MOR]MFO0 First
If !fstat
  LRET = 1
Endif
Filter [MOR]
Close Local File [F:MOR]

End LRET

# Issue end X3-55362

