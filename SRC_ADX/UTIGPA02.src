#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################
# UTIGPA02        Utilitaire problème arrondi sur fractions de jour      #
#                 dans SCHEDULING                                        #
# ---------------------------------------------------------------------- #
# Problème à résoudre :                                                  #
#   des enregistrements de SCHEDULING ont des fractions de jour          #
#   incorrectes (> 1 ou nb décimale > 4)  llc 04.02 14061                #
##########################################################################

Call MAJ_UTIGPA02
End


Subprog MAJ_UTIGPA02
Local Char DOSSIER(30) : DOSSIER=nomap
Call OUVRE_TRACE("UTIGPA02 : SCHEDULING records update") From LECFIC
Call TEMPON("O") From GESECRAN
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>"" Call EXE_UTIGPA02(DOSSIER) : Endif
Call FERME_TRACE From LECFIC
Call TEMPOFF     From GESECRAN
Call LEC_TRACE From LECFIC
End


Subprog EXE_UTIGPA02(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR, STOP 
Local Char     CLE1(20), CLE3(20), CRITERE(200)
Local Integer  CLE2, CLE4, CLE5

Call ECR_TRACE("UTIGPA02: Process Start on : "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:SCH])  =0  Local File =DOSSIER+".SCHEDULING"       [SCH] : Endif

Local Integer NBSCH : NBSCH = 0

# llc 03.02 13358
Raz CLE1,CLE2, STOP
$BOUCLE_SCH
If STOP=1
  STOP=2 : CRITERE='MFGNUM="'+CLE1+'"'+' & OPENUM='+num$(CLE2)+' & OPESPLNUM>'+num$(CLE4)
Elsif STOP=2
  STOP=3 : CRITERE='MFGNUM="'+CLE1+'"'+' & OPENUM>'+num$(CLE2)
Elsif STOP=3
  STOP=0 : CRITERE='MFGNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK
Trbegin [SCH]

For [SCH] Where evalue(CRITERE)
       GOK = 1  
       Readlock [SCH]SCH0 Curr
       If fstat
           Call ECR_TRACE("File MFGOPE, Error ="-num$(fstat),1) From GESECRAN
       Else
           If [F:SCH]INFCAPSTF > 1 : [F:SCH]INFCAPSTF = 1 : Endif
           If [F:SCH]INFCAPENF > 1 : [F:SCH]INFCAPENF = 1 : Endif
           If [F:SCH]SETENDFRD > 1 : [F:SCH]SETENDFRD = 1 : Endif
           If [F:SCH]OPESTRFRD > 1 : [F:SCH]OPESTRFRD = 1 : Endif
           If [F:SCH]OPEENDFRD > 1 : [F:SCH]OPEENDFRD = 1 : Endif
           If [F:SCH]OPEFITSTF > 1 : [F:SCH]OPEFITSTF = 1 : Endif
    
           [F:SCH]INFCAPSTF = arr([F:SCH]INFCAPSTF,0.0001)            # llc 04.02 14061
           [F:SCH]INFCAPENF = arr([F:SCH]INFCAPENF,0.0001)            # llc 04.02 14061
           [F:SCH]SETENDFRD = arr([F:SCH]SETENDFRD,0.0001)            # llc 04.02 14061
           [F:SCH]OPESTRFRD = arr([F:SCH]OPESTRFRD,0.0001)            # llc 04.02 14061
           [F:SCH]OPEENDFRD = arr([F:SCH]OPEENDFRD,0.0001)            # llc 04.02 14061    
           [F:SCH]OPEFITSTF = arr([F:SCH]OPEFITSTF,0.0001)            # llc 04.02 14061
       
           NBSCH += 1
           Rewrite [SCH]        
       Endif
       COMPTEUR += 1
       If COMPTEUR > GMAXUPDTRS 
           CLE1 = [F:SCH]MFGNUM
           CLE2 = [F:SCH]OPENUM
           CLE4 = [F:SCH]OPESPLNUM
           STOP = 1 
           Break 
       Endif
$SUITE_UTIGPA02
Next
Commit
If STOP : Goto BOUCLE_SCH : Endif
Filter [SCH]
Close Local File [SCH]

Call ECR_TRACE("UTIGPA02 : "+num$(NBSCH)+" records processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(8) <> 2 : End : Endif
Call EXE_UTIGPA02(APPLI)        # llc 05.02 cohérence
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif

# module 7 = gpao
If [F:ADS]MODULE(7) <> 2 : End : Endif
Call EXE_UTIGPA02(APPLI)        # llc 05.02 cohérence
End


