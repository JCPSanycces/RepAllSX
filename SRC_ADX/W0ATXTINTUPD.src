#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ATXTINTUPD 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone NUMERO
mkstat = 0
zoncou = "NUMERO"
indice = 0
WNUM = [M]NUMERO
If varmode([M]NUMERO,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NUMERO" : Gosub ACTION From =IMPTRT
 Endif
 If [M]NUMERO=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "NUMERO" : GZNUM = 170 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>[M]NUMERO or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_NUMERO([M]NUMERO) From ATXTINTUPD
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NUMERO" : GZNUM = 170 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone LAN
mkstat = 0
zoncou = "LAN"
indice = 0
WCHAR = [M]LAN
If varmode([M]LAN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LAN" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]LAN,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "LAN" : GZNUM = 1505 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("TLA","",[M]LAN,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "LAN" : GZNUM = 1505 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_LAN([M]LAN) From ATXTINTUPD
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "LAN" : GZNUM = 1505 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]LAN or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_LAN([M]LAN) From ATXTINTUPD
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "LAN" : GZNUM = 1505 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone TXTPDTCODA
mkstat = 0
zoncou = "TXTPDTCODA"
indice = 0
WCHAR = [M]TXTPDTCODA
If varmode([M]TXTPDTCODA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TXTPDTCODA" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_TXTPDTCODA([M]TXTPDTCODA) From ATXTINTUPD
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "TXTPDTCODA" : GZNUM = 12792 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]TXTPDTCODA or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_TXTPDTCODA([M]TXTPDTCODA) From ATXTINTUPD
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "TXTPDTCODA" : GZNUM = 12792 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

####################################
## Bloc liste 3
####################################
IMPTBL = 0

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone UPDLANORI
mkstat = 0
zoncou = "UPDLANORI"
indice = 0
If varmode([M]UPDLANORI,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "UPDLANORI" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("TLA","!",[M]UPDLANORI,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "UPDLANORI" : GZNUM = 9760 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone UPDTEXTE
mkstat = 0
zoncou = "UPDTEXTE"
indice = 0
If varmode([M]UPDTEXTE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "UPDTEXTE" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone UPDCOMMENT
mkstat = 0
zoncou = "UPDCOMMENT"
indice = 0
If varmode([M]UPDCOMMENT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "UPDCOMMENT" : Gosub ACTION From =IMPTRT
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "ATXTINTUPD"
Return

