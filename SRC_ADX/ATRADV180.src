#-----------------------------#
#     SUPERVISEUR             #
#-----------------------------#
$MAJSUPER_180
#
# si on est deja dans l'appli superviseur on ne fait rien.
# superv180 n'est pas accessible pour les filiales.
#------------------
If GPRODUIT = -1
    Return
Endif


#---------------#
# cas produit X3#
# mise a jour v7 v6 et v5#
#---------------#
WLANTRAD = [M]LAN
If GPRODUIT = 0
    If GFOLDER_V170(1) <> "" 
        Gosub X3IND170_APLSTD From ATRADAML
    Endif
    If GFOLDER_V160(1) <> "" 
        Gosub X3IND160_APLSTD From ATRADAML
    Endif
    If GFOLDER_V150(1) <> "" 
        Gosub X3IND150_APLSTD From ATRADAML
    Endif
Endif

WLANTRAD = [M]LAN
# cas produit geode 
# a faire plsu tard.......
If GPRODUIT = 1

Endif



WLANTRAD = [M]LAN
# cas produit paye quand on aura les refs
If GPRODUIT = 2
    If GFOLDER_V170(3) <> "" 
        Gosub PAYIND170_APLSTD From ATRADAML
    Endif
    If GFOLDER_V160(3) <> "" 
        Gosub PAYIND160_APLSTD From ATRADAML
    Endif
Endif


#---------------------------------
# mettre a jour le dossier superviseur et les autres produits
# dans le cas d'un chapitre du module superviseur (il est commun)
# sauf les menus locaux modifiables
#---------------------------------

# lecture table amenloc pour connaitre le module
# Cas du Titre d'un menu local : WCHAPITRE=0 ou 200 
# amenloc du dossier en cours
#-------------------
If GPRODUIT = 2
    # pas de hrm en v8 donc on ne peut aps lire aplstd de la v8
    Return
Endif

WCHAPITRES=WCHAPITRE
If WCHAPITRE= 0   : WCHAPITRES=WNUMERO     : Endif
If WCHAPITRE= 200 : WCHAPITRES=200+WNUMERO : Endif
Read [XYMV8]MENLOC = WCHAPITRES
If fstat = 0
      If [F:XYMV8]MODULE <> 1
            Return
      Endif
      If [F:XYMV8]AUZMOD = 2
            Return
      Endif
Else
      Return
Endif

# lecture table amenloc du superviseur pour connaitre si menu local perso par produit
# il n'y a que dans SUPERV qu'on a l'info
# amenloc superv8
# ------------------------------------------------
Read [XYAV8]MENLOC = WCHAPITRES
If fstat = 0
      If [F:XYAV8]FLGPRO = 2
            Return
      Endif
Else
      Return
Endif



# ok on est sur un chapitre superviseur
# lecture aplstd superv et verification si c'est le même
#------------------------
WLANTRAD = [M]LAN
Gosub SUPERV180_APLSTD From ATRADAML

#---------------------------
# ok on est sur un chapitre superviseur
#---------------------------
WLANTRAD = [M]LAN
#--------------#
# - geode
#--------------#
If GFOLDER_V180(2) <> "" 
    If GPRODUIT <> 1
        Gosub GEOIND180_APLSTD From ATRADAML
    Endif
Endif
#--------------#
# -- x3 
#--------------#
If GFOLDER_V180(1) <> "" 
    If GPRODUIT <> 0
        Gosub X3IND180_APLSTD From ATRADAML
    Endif
Endif

#--------------#
# -- paye 
#--------------#
If GFOLDER_V180(3) <> "" 
    If GPRODUIT <> 2
         Gosub PAYIND180_APLSTD From ATRADAML
    Endif
Endif
#--------------#
# -- abel 
#--------------#
If GFOLDER_V180(4) <> "" 
        # --- on ne fait plus rien sur abel depuis V7 
Endif

Return





