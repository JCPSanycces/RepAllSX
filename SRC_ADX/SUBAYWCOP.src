#<AdxTL>@(#)3.0.0.0 $Revision$
#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################################################
##  Xtend: Copie fiche Bloc conditionné
##  Version 0001
######################################################################################
#    GACTION
#        AYSCOP        Copie d'une donnée Xtend
#        AYSFCYCOP     Copie globale d'un site
#    [L]
#        FCYORG, DOSORG
#        FCYDES, DOSDES
#        ELTCOD
#    [F:AYS1] Site origine       Ouvert et lu
#    [F:AYS2] Site destination   Ouvert et lu
######################################################################################
$TRTCOP
If [L]DOSORG=nomap
 Local File AYTELTBLCW[AYW1]
 Local File ATEXTE    [ATX1]
 Local File AYTLINES  [AYN1]
 Local File ATEXTRA   [AXX1]
Else
 Local File =[L]DOSORG+".AYTELTBLCW" [AYW1]
 Local File =[L]DOSORG+".ATEXTE"     [ATX1]
 Local File =[L]DOSORG+".AYTLINES"   [AYN1]
 Local File =[L]DOSORG+".ATEXTRA"    [AXX1]
Endif
If [L]DOSDES=nomap
 Local File AYTELTBLCW [AYW2]
 Local File ATEXTE     [ATX2]
 Local File AYTLINES   [AYN2]
 Local File ATEXTRA    [AXX2]
Else
 Local File =[L]DOSDES+".AYTELTBLCW" [AYW2]
 Local File =[L]DOSDES+".ATEXTE"     [ATX2]
 Local File =[L]DOSDES+".AYTLINES"   [AYN2]
 Local File =[L]DOSDES+".ATEXTRA"    [AXX2]
Endif

Read [AYW1]AYW0 = [L]FCYORG;[L]ELTCOD
If fstat
  OK=0
  Call RSTA("AYW1",[L]FCYORG-[L]ELTCOD) From GLOCK
  Goto FINALLY
Endif

Read [AYW2]AYW0 = [L]FCYDES; [L]ELTCOD
DES_ELTCOD=[F:AYW2]BLCWHNCOD : Gosub MSGDESOBJ From AYTCOP
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif


$FINALLY
Close Local File [AYW1], [ATX1], [AYN1], [AXX1]
&              , [AYW2], [ATX2], [AYN2], [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [AYW2] , [ATX2], [AYN2]
 If DES_HASELT
     Delete [AYN2] Where FCYCOD=[L]FCYDES  & LINCODTYP=5 & LINCOD=toupper([L]DES_ELTCOD)
     If fstat=1
      GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTLIN" : Goto ROLL_TR_COP
     Endif
     Delete [AYW2] Where FCYCOD=[L]FCYDES and BLCWHNCOD=[L]DES_ELTCOD
     If fstat=1
      GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTELTBLCW" : Goto ROLL_TR_COP
     Endif
 Endif
 #
 For [AYW1]AYW0 Where FCYCOD=[L]FCYORG & BLCWHNCOD=[L]ELTCOD
  [F:AYW2] = [F:AYW1]
  [F:AYW2]FCYCOD = [L]FCYDES
  Call COPTEXTRA("AYTELTBLCW","INTIT",[F:AYW1]FCYCOD,[F:AYW1]BLCWHNCOD,[L]FCYDES) From SUBAYS
  If GOK<1 : Break : Endif
  [F:AYW2]UPDUSR = GUSER
  [F:AYW2]UPDDAT = date$
  # [F:AYW2]UPDTIM = time  - 93575
  Call SET_UPDTIM("AYW2") From AYTCOP # 93575
  [F:AYW2]BRWX3  = [F:AYW2]FCYCOD+"_"+[F:AYW2]BLCWHNCOD
#*  [F:AYW2]CODACT = [L]ELTCODACT
  Write [AYW2]
  If fstat
   GOK=0 : Call FSTA("AYW2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 #
 For [AYN1]AYN0 Where FCYCOD=[L]FCYORG & LINCODTYP=5 & LINCOD=toupper([L]ELTCOD)
  [F:AYN2] = [F:AYN1]
  [F:AYN2]FCYCOD = [L]FCYDES
  Write [AYN2]
  If fstat
   GOK=0 : Call FSTA("AYN2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
