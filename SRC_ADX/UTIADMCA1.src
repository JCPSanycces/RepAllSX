#<AdxTL>@(#)0.0.0.0 $Revision$ 
################################################################################
# UTIADMCA1
# Utility program for patches for Customer Administrator to set * in AUZFCT for ADMCA profil 
#  ONLY for a demo folder (test ADEMO)
# Jira X3-74907 - ARDET - 07/02/2018
################################################################################

End
#######################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(FOLDERNAME)
Value Char FOLDERNAME
Local integer KO 

Call ECR_TRACE("UTIADMCA1 : Update AUZFCT for customer administrator for Folder "+FOLDERNAME,0) From GESECRAN

Local File =FOLDERNAME+".ADOVAL"    [ZADW]
Local File =FOLDERNAME+".AUTILIS"   [AUS]
Local File =FOLDERNAME+".ADOVALAUS" [ADU]

KO = 0
Trbegin [ADU]
    #look for a demo folder
    Look [ZADW]ADW1(1)="ADEMO"    
    If fstat=0
		Filter [AUS] Where PRFFCT ="ADMCA"  and PRFMEN ="ADMCA"  
		For [AUS]		
				Read [ADU]ADU0 = [F:AUS]USR;"AUZFCT"
				If fstat=0				
						If [F:ADU]VALEUR =""
							[F:ADU]VALEUR = "*"
							Rewrite [ADU]
							If fstat =0 
								Call ECR_TRACE("update AUZFCT for :"+[F:AUS]USR,0) From GESECRAN
							else
								Call ECR_TRACE("Prob during rewrite AUZFCT param for :"+[F:AUS]USR,1) From GESECRAN
								KO=1
								Break
							endif
						Endif
				Else
						Raz [F:ADU]
						[F:ADU]CODUSR =[F:AUS]USR
						[F:ADU]PARAM  ="AUZFCT"
						[F:ADU]VALEUR = "*"
						Write [ADU]
						If fstat= 0
							Call ECR_TRACE("create AUZFCT for :"+[F:AUS]USR,0) From GESECRAN
						else
     						Call ECR_TRACE("Prob during write AUZFCT param for :"+[F:AUS]USR,1) From GESECRAN
							KO=1
							Break
						Endif
				Endif
		Next
		Filter [AUS]
    Endif

If KO = 1
    Rollback
Else	
    Commit
Endif
Call ECR_TRACE("UTIADMCA1 : end process ",0) From GESECRAN

Close Local File

End



