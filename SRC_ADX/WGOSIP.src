#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre OSIP

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:15:07"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"OSIP",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="SIP0;SIP1;SIP4;SIP2;SIP3;SIP6;SIP5;SIP7;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 0
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
If clalev([M:SIP0])=0 : Local Mask SIPAR0 [SIP0] : Endif
If clalev([M:SIP1])=0 : Local Mask SIPAR1 [SIP1] : Endif
If clalev([M:SIP4])=0 : Local Mask SIPAR4 [SIP4] : Endif
If clalev([M:SIP2])=0 : Local Mask SIPAR2 [SIP2] : Endif
If clalev([M:SIP3])=0 : Local Mask SIPAR3 [SIP3] : Endif
If clalev([M:SIP6])=0 : Local Mask SIPAR6 [SIP6] : Endif
If clalev([M:SIP5])=0 : Local Mask SIPAR5 [SIP5] : Endif
If clalev([M:SIP7])=0 : Local Mask SIPAR7 [SIP7] : Endif
Gosub TIT
nolign = 1
Return

$DEF_BOITE
Gosub HORODAT From WGOSIP
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OSIP" From GFONCTION At A_STAMP With A_WINDPREV Mask [SIP0]
&   Folder Mask [SIP1]
& , Folder Mask [SIP4]
& , Folder Mask [SIP2]
& , Folder Mask [SIP3]
& , Folder Mask [SIP6]
& , Folder Mask [SIP5]
& , Folder Mask [SIP7]
& As [SIP1]
Titled [SIP1] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGOSIP
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OSIP" From GFONCTION At A_STAMP With A_WINDPREV Mask [SIP0]
&   Folder Mask [SIP1]
& , Folder Mask [SIP4]
& , Folder Mask [SIP2]
& , Folder Mask [SIP3]
& , Folder Mask [SIP6]
& , Folder Mask [SIP5]
& , Folder Mask [SIP7]
& As [SIP1]
Titled [SIP1] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [SIP1] Folder AFOLDEF
Return

$SAISIE_BOITE
Boxinp [SIP1] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [SIP1]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TIT(60) , TITTRN(60)
Call TEXTE(31758,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Return

$DEFAUT_BRO
Return

$SETBOX
Return

$SETORDER
Return

$ENDORDER
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(0) = "SIPAR0"       : ABMSK(0)  = "SIP0"     : AMA(0) = 1
NOMMSK(1) = "SIPAR1"       : ABMSK(1)  = "SIP1"     : AMA(1) = 1
NOMMSK(2) = "SIPAR4"       : ABMSK(2)  = "SIP4"     : AMA(2) = 1
NOMMSK(3) = "SIPAR2"       : ABMSK(3)  = "SIP2"     : AMA(3) = 1
NOMMSK(4) = "SIPAR3"       : ABMSK(4)  = "SIP3"     : AMA(4) = 1
NOMMSK(5) = "SIPAR6"       : ABMSK(5)  = "SIP6"     : AMA(5) = 1
NOMMSK(6) = "SIPAR5"       : ABMSK(6)  = "SIP5"     : AMA(6) = 1
NOMMSK(7) = "SIPAR7"       : ABMSK(7)  = "SIP7"     : AMA(7) = 1
NBMASK = 7
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 0 : If clalev([M:SIP0])>0 : Default Mask [SIP0] : Endif
 When 1 : If clalev([M:SIP1])>0 : Default Mask [SIP1] : Endif
 When 2 : If clalev([M:SIP4])>0 : Default Mask [SIP4] : Endif
 When 3 : If clalev([M:SIP2])>0 : Default Mask [SIP2] : Endif
 When 4 : If clalev([M:SIP3])>0 : Default Mask [SIP3] : Endif
 When 5 : If clalev([M:SIP6])>0 : Default Mask [SIP6] : Endif
 When 6 : If clalev([M:SIP5])>0 : Default Mask [SIP5] : Endif
 When 7 : If clalev([M:SIP7])>0 : Default Mask [SIP7] : Endif
Endcase
Return

$TITMASK
Case MA
 When 0 : If clalev([M:SIP0])>0 : Gosub TITRES From W1SIPAR0 : Endif
 When 1 : If clalev([M:SIP1])>0 : Gosub TITRES From W1SIPAR1 : Endif
 When 2 : If clalev([M:SIP4])>0 : Gosub TITRES From W1SIPAR4 : Endif
 When 3 : If clalev([M:SIP2])>0 : Gosub TITRES From W1SIPAR2 : Endif
 When 4 : If clalev([M:SIP3])>0 : Gosub TITRES From W1SIPAR3 : Endif
 When 5 : If clalev([M:SIP6])>0 : Gosub TITRES From W1SIPAR6 : Endif
 When 6 : If clalev([M:SIP5])>0 : Gosub TITRES From W1SIPAR5 : Endif
 When 7 : If clalev([M:SIP7])>0 : Gosub TITRES From W1SIPAR7 : Endif
Endcase
Return

$FERME_MASK
If clalev([M:SIP0])>0 : Close Local Mask [SIP0] : Endif
If clalev([M:SIP1])>0 : Close Local Mask [SIP1] : Endif
If clalev([M:SIP4])>0 : Close Local Mask [SIP4] : Endif
If clalev([M:SIP2])>0 : Close Local Mask [SIP2] : Endif
If clalev([M:SIP3])>0 : Close Local Mask [SIP3] : Endif
If clalev([M:SIP6])>0 : Close Local Mask [SIP6] : Endif
If clalev([M:SIP5])>0 : Close Local Mask [SIP5] : Endif
If clalev([M:SIP7])>0 : Close Local Mask [SIP7] : Endif
Return

$RAZMASK
Case MA
 When 0 : If clalev([M:SIP0])>0 : Raz [M:SIP0] : Endif
 When 1 : If clalev([M:SIP1])>0 : Raz [M:SIP1] : Endif
 When 2 : If clalev([M:SIP4])>0 : Raz [M:SIP4] : Endif
 When 3 : If clalev([M:SIP2])>0 : Raz [M:SIP2] : Endif
 When 4 : If clalev([M:SIP3])>0 : Raz [M:SIP3] : Endif
 When 5 : If clalev([M:SIP6])>0 : Raz [M:SIP6] : Endif
 When 6 : If clalev([M:SIP5])>0 : Raz [M:SIP5] : Endif
 When 7 : If clalev([M:SIP7])>0 : Raz [M:SIP7] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 0 : If clalev([M:SIP0])>0 : Affzo [M:SIP0] : Endif
 When 1 : If clalev([M:SIP1])>0 : Affzo [M:SIP1] : Endif
 When 2 : If clalev([M:SIP4])>0 : Affzo [M:SIP4] : Endif
 When 3 : If clalev([M:SIP2])>0 : Affzo [M:SIP2] : Endif
 When 4 : If clalev([M:SIP3])>0 : Affzo [M:SIP3] : Endif
 When 5 : If clalev([M:SIP6])>0 : Affzo [M:SIP6] : Endif
 When 6 : If clalev([M:SIP5])>0 : Affzo [M:SIP5] : Endif
 When 7 : If clalev([M:SIP7])>0 : Affzo [M:SIP7] : Endif
Endcase
Return

$OUVMSKCMP
Return

$FERMSKCMP
Return

$RAZMSKCMP
Return

$AFF_ENAFLG
Return

$CHARGEFIC
Case IMA
 When 0 : If clalev([M:SIP0])>0 : [F:SPX] = [M:SIP0] : Endif
 When 1 : If clalev([M:SIP1])>0 : [F:SPX] = [M:SIP1] : Endif
 When 2 : If clalev([M:SIP4])>0 : [F:SPX] = [M:SIP4] : Endif
 When 3 : If clalev([M:SIP2])>0 : [F:SPX] = [M:SIP2] : Endif
 When 4 : If clalev([M:SIP3])>0 : [F:SPX] = [M:SIP3] : Endif
 When 5 : If clalev([M:SIP6])>0 : [F:SPX] = [M:SIP6] : Endif
 When 6 : If clalev([M:SIP5])>0 : [F:SPX] = [M:SIP5] : Endif
 When 7 : If clalev([M:SIP7])>0 : [F:SPX] = [M:SIP7] : Endif
Endcase
Return

$CHARGEMSK
Case IMA
 When 0 : If clalev([M:SIP0])>0 : [M:SIP0] = [F:SPX] : Endif
 When 1 : If clalev([M:SIP1])>0 : [M:SIP1] = [F:SPX] : Endif
 When 2 : If clalev([M:SIP4])>0 : [M:SIP4] = [F:SPX] : Endif
 When 3 : If clalev([M:SIP2])>0 : [M:SIP2] = [F:SPX] : Endif
 When 4 : If clalev([M:SIP3])>0 : [M:SIP3] = [F:SPX] : Endif
 When 5 : If clalev([M:SIP6])>0 : [M:SIP6] = [F:SPX] : Endif
 When 6 : If clalev([M:SIP5])>0 : [M:SIP5] = [F:SPX] : Endif
 When 7 : If clalev([M:SIP7])>0 : [M:SIP7] = [F:SPX] : Endif
Endcase
Return

$GRISE_CLE
If AMA(0)
 Grizo [SIP0]CLE
Else
 Grizo [SIP1]CLE
Endif
Return

$DEGRISE_CLE
If AMA(0)
 Actzo [SIP0]CLE
Else
 Actzo [SIP1]CLE
Endif
Return

$BOUTON
STDBOUT = "EA"
NBTEX  = 0
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


