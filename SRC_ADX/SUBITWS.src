#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
    When "DEBUT"       : Gosub DEBUT
Endcase
Return

$DEBUT
Local Integer I,NOL

If clalev([F:FCY1]) = 0 : Local File FACILITY   [FCY1] : Endif
If clalev([F:BPS])  = 0 : Local File BPSUPPLIER [BPS]  : Endif

Raz [M:ITWS]
Transmask [M:ITW0] To [M:ITWS] # Issue 25606_Transmask [M:ITWS]=[M:ITW0]
Transmask [M:ITW2] To [M:ITWS] # Issue 25606_Transmask [M:ITWS]=[M:ITW2]

Raz I,NOL

For [STO]STO3 Where ITMREF=[M:ITWS]ITMREF & STOFCY=[M:ITWS]STOFCY &
&                   WRH=[M:ITWS]WRH & OWNER<>[M:ITWS]STOFCY
   I = find([F:STO]OWNER,[M:ITWS]OWNER(0..[M:ITWS]NBLIG-1))
   If I=0
      NOL = [M:ITWS]NBLIG
      [M:ITWS]OWNER(NOL)      = [F:STO]OWNER

      If [F:FCY1]FCY<>[F:STO]OWNER
         Read [FCY1]FCY0=[F:STO]OWNER
         If fstat
            If [F:BPS]BPSNUM<>[F:STO]OWNER
               Read [BPS]BPS0=[F:STO]OWNER
               If !fstat
                  [M:ITWS]OWNNAM(NOL)=[F:BPS]BPSNAM
               Endif
            Else
               [M:ITWS]OWNNAM(NOL)=[F:BPS]BPSNAM
            Endif
         Else
            [M:ITWS]OWNNAM(NOL)=[F:FCY1]FCYNAM
         Endif
      Else
         [M:ITWS]OWNNAM(NOL)=[F:FCY1]FCYNAM
      Endif

      [M:ITWS]QTYSTUACT(NOL)  = [F:STO]QTYSTUACT
      [M:ITWS]CUMALLQTA(NOL)  = [F:STO]CUMALLQTA
      [M:ITWS]NBLIG += 1
   Else
      NOL = I-1
      [M:ITWS]QTYSTUACT(NOL) += [F:STO]QTYSTUACT
      [M:ITWS]CUMALLQTA(NOL) += [F:STO]CUMALLQTA
   Endif
Next

Affzo [M:ITWS]1-99

Return

