$B2_APPDOWN
  Local Char ZONE1, ZONE2
  ZONE2 = ""
  ZONE1 = "[M:MHE0]"+zoncou
  If left$(zoncou,6)="FLDVAL"
    ZONE2="[M:MHE0]VALINT"+right$(zoncou,7)
  Endif

  For I=nolign-1 To [M:MHE0]NBENT-1
    Assign ZONE1+"("+num$(I)+")" With VALEUR
    If ZONE2<>""
      Assign ZONE2+"("+num$(I)+")" With VALEUR
    Endif
  Next

  Affzo[M:MHE0]
  Gosub CHANGE_STYLE
Return

Subprog AM_SRCENT(VALEUR)
Variable Char    VALEUR()
  Raz [M:MHE0]SRCOBJ(nolign-1)
  Raz [M:MHE0]SRCDES(nolign-1)
  If VALEUR<>""
    Call INIT_MODEL(VALEUR)
    If mkstat
      GMESSAGE = mess(23,100,1) #fiche inexistante
      End
    Endif

    If [M:MHE0]SRCOBJ(nolign-1)<>""
      Call FILL_SRCDES([M:MHE0]SRCDES(nolign-1))
      Affzo [M:MHE0]SRCDES(nolign-1)
    Else
      End
    Endif

    Call GET_REFNUM(VALEUR)
    If [M:MHE0]REFNUM(nolign-1)<>""
      Affzo [M:MHE0]REFNUM(nolign-1)
      Call UPD_REFNUM([M:MHE0]REFNUM(nolign-1))
      If [M:MHE0]CTRNUM(nolign-1) <> "" & GOK
        zonsui="[M:MHE0]ENTDAT(nolign-1)"
      Endif
    Endif
  Endif
End

#fill and display SRCDES
Subprog FILL_SRCDES(VALEUR)
Variable Char VALEUR
  If [M]SRCOBJ(nolign-1)<>""
    If !clalev ([F:AOB]) : Local File AOBJET [AOB] : Endif
    Read [AOB]ABREV = [M]SRCOBJ(nolign-1)
    If !fstat
      Call TEXTE([F:AOB]LIBEL,VALEUR) From OBJDIV
    Endif
  Endif
End

Subprog GET_REFNUM(VALEUR)
Variable Char VALEUR
  Case [M:MHE0]SRCOBJ(nolign-1)
    When "EML" : [M:MHE0]REFNUM(nolign-1) = VALEUR
    When "POT"
      Call LECTURE("POT",VALEUR,"") From CONTOBJ
      If !fstat
        If [F:POT]EMPMDL<>""
          [M:MHE0]REFNUM(nolign-1) = [F:POT]EMPMDL
        Elsif [F:POT]JOBPOT<>""
          Call LECTURE("JOT",[F:POT]JOBPOT,"") From CONTOBJ
          If !fstat
            [M:MHE0]REFNUM(nolign-1) = [F:JOT]EMPMDL
          Endif
        Endif
      Endif
    When "JOT"
      Call LECTURE("JOT",VALEUR,"") From CONTOBJ
      If !fstat
        [M:MHE0]REFNUM(nolign-1) = [F:JOT]EMPMDL
      Endif
    When "PRF"
      Call LECTURE("PRF",VALEUR,GCURLEG) From CONTOBJ
      If !fstat
        [M:MHE0]REFNUM(nolign-1) = [F:PRF]EMPMDL
      Endif
  Endcase
End

Subprog S_SRCENT(VALEUR)
Variable Char    VALEUR()
  Call SELECT("EML","",VALEUR,"") From SELOBJ
End

Subprog B2_SRCENT(VALEUR)
Variable Char    VALEUR()
  Call SELECT("POT","",VALEUR,"") From SELOBJ
  mkstat=99
End

Subprog B3_SRCENT(VALEUR)
Variable Char    VALEUR()
  Call SELECT("JOT","",VALEUR,"") From SELOBJ
  mkstat=99
End

Subprog B4_SRCENT(VALEUR)
Variable Char    VALEUR()
#***DBA***
 Call SELECT("PRF","",VALEUR,GCURLEG) From SELOBJ
 mkstat=99
End

Subprog INIT_MODEL(VALEUR)
  Variable Char    VALEUR()

  Call LECTURE("EML",VALEUR,"") From CONTOBJ
  If !fstat
    [M]SRCOBJ(nolign-1)="EML"
    mkstat=0 : End
  Endif

  Call LECTURE("POT",VALEUR,"") From CONTOBJ
  If !fstat
    [M]SRCOBJ(nolign-1)="POT"
    mkstat=0 : End
  Endif

  Call LECTURE("JOT",VALEUR,"") From CONTOBJ
  If !fstat
    [M]SRCOBJ(nolign-1)="JOT"
    mkstat=0 : End
  Endif

  Call LECTURE("PRF",VALEUR,GCURLEG) From CONTOBJ
  If !fstat
    [M]SRCOBJ(nolign-1)="PRF"
    mkstat=0 : End
  Else
    mkstat = 2
  Endif
End
