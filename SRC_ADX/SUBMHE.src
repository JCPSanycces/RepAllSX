#<AdxTL>@(#)9.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("MHE",GBIDC1,"") From GOBJET
End

######################################################################################
## Objet MHE 00/00/0000 00:00:00 (WGA)
######################################################################################
$ACTION
Case ACTION
 When "FILTRE"      : Gosub FILTRE
 When "OUVRE"       : Gosub OUVRE
 When "RAZCRE"      : Gosub RAZCRE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "LIENS"       : Gosub LIENS
 When "LIENS2"      : Gosub LIENS2
 When "AVANT_MOD"   : Gosub AVANT_MOD
 When "ANNULE"      : Gosub ANNULE
 When "RAZDUP"      : Gosub RAZDUP
 When "APRES_CRE"   : Gosub APRES_CRE #72635
 When "APRES_MOD"   : Call GENHYPO(nomap,[F:MHE]COD) From SUBMHE
 When "SETBOUT"     : Gosub SETBOUT
 #72635
 When "AVANTBOUT"   : Gosub AVANTBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 #end 72635
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "FERME"        : Gosub FERME
Endcase
Return

#####################################
$FILTRE
If GFLAG<>""
 Default File [MHE]
 FILTSUP +="TRN=GFLAG"
Endif
Return

#####################################
$OUVRE
If clalev ([F:BCB])=0  : Local File BCLOB     [BCB] : Endif
If clalev ([F:TCA])=0  : Local File TABCOUAFF [TCA] : Endif
If clalev ([F:SEH])=0  : Local File SCRMHEH   [SEH] : Endif
If clalev ([F:SED])=0  : Local File SCRMHED   [SED] : Endif
If clalev ([F:ATZ])=0  : Local File ATABZON   [ATZ] : Endif
If clalev ([F:ATY])=0  : Local File ATYPE     [ATY] : Endif
If clalev ([F:MCL])=0  : Local File MSSCENAL  [MCL] : Endif
If clalev ([F:MCH])=0  : Local File MSSCENAH  [MCH] : Endif
If clalev ([F:POT])=0  : Local File POSTE     [POT] : Endif
If clalev ([F:JOT])=0  : Local File JOBTYP    [JOT] : Endif
If clalev ([F:PRF])=0  : Local File PROFIL    [PRF] : Endif
# / 72635
If clalev ([F:POD])=0  : Local File POSTEDEF  [POD] : Endif
If clalev ([F:JOD])=0  : Local File JOBTYPDEF [JOD] : Endif
If clalev ([F:HRPFD])=0  : Local File PROFILDEF [HRPFD] : Endif
#   72635 /
If clalev ([F:CPY])=0   : Local File COMPANY   [CPY]    : Endif

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
GCURLEG = 'FRA' #Total Payroll is FRA only

Gosub DEFVAR

Raz GFLDMS
Raz GVRAMS
#Chargement des champs salariés
JJ= 0
For [F:SED]SED0 Where [F:SED]COD=GFLAG & [F:SED]ORIFLD=1
 Read [F:DIC]DIC0 = [F:SED]FLD
 If !fstat & ([F:DIC]CODACT = "" | func AFNC.ACTIV([F:DIC]CODACT) > 0)
  JJ+=1
  If JJ > dim(GFLDMS) : Break : Endif
  GFLDMS(JJ,0) = [F:SED]FLD
  GFLDMS(JJ,1) = [F:SED]TIT
 Endif
Next
#Chargement des variables salariés
JJ= 0
For [F:SED]SED0 Where [F:SED]COD=GFLAG & [F:SED]ORIFLD=2
 Read [F:VRA]VRA0 = GCURLEG;[F:SED]FLD
 If !fstat
  #61896
  Call CONTEXE([F:VRA]CODACC) From CPTSUB
  If !mkstat & ([F:VRA]CODACT = "" | func AFNC.ACTIV([F:VRA]CODACT) > 0)
   JJ+=1
   If JJ > dim(GVRAMS) : Break : Endif
   GVRAMS(JJ,0) = [F:SED]FLD
   GVRAMS(JJ,1) = [F:SED]TIT
  Endif
 Endif
Next

Return

#####################################
$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$DEFVAR
Local Integer JJ
Local Integer STAT
Local Integer L,R
Local Integer MSI , MSJ , IND , IROW
Local Integer LNGFMT , I , ERR , OKACS
Local Char    COMPTEUR(GLONANM)
Local Char    TYPFMT(20) , OPTFMT(20) , CHFMT(50) , NUMFMT(10) , IACTION(20)
Local Char    VALROW(250) , VALINTROW(250)
Local Char    TABLE (GLONATB)
Local Char    VALCONT(250)
Local Char    FLDINT(30)
Local Char    VALFLDINT(250)
Return

#Ajouter par DBA le 22/04 :
#Vérouillage de la modification, de la suppression et du changement de clé en fonction du contexte
#####################################
$SETBOUT
If GREP<>"" | !VERROU
 Call VIREBOUT (CHAINE,"AH") From GOBJET
 If GREP="M" | GREP="C" | GREP="D"
  Call VIREBOUT (CHAINE,"B") From GOBJET
 Endif
Elsif  [M:MHE0]FLGCLO=2
 Call VIREBOUT (CHAINE,"AH") From GOBJET
Endif

If [M:MHE0]FLGCLO=2
 Call VIREBOUT (CHAINE,"M") From GOBJET
Endif
Return

#72635
$AVANTBOUT
  Effzo [M:MHE0]
  REP="C" : GREP="C"
  Gosub RAZCRE
  Gosub INICRE
Return

$EXEBOUT
  Case BOUT
    When "B"
      If !GOK
        REP="" : GREP=""
      Endif
      Affzo [M:MHE0]
      Gosub CHANGE_STYLE
  Endcase
Return

$APRES_CRE
  Call GENHYPO(nomap,[F:MHE]COD) From SUBMHE
Return
#end 72635

#####################################
$LIENS
If dim ([F:MHE]LEG)>=0 : GCURLEG = [F:MHE]LEG : Else GCURLEG = "FRA" : Endif
If GNBLEG=1 : GCURLEG = GDOSLEG : Endif
# On décoche Définitif si l'hypothèse n'est stockée dans aucun scénario définitif
Link [MCL] With [MCH]MCH0=[MCL]COD
& As [LMC]
& Where [MCH]FLGCLO=2 & [MCL]TYPHYP=4 & [MCL]CODHYP=[F:MHE]COD
Read [LMC]MCL1 First
If fstat
 [M:MHE0]FLGCLO = 1
 Call DEBTRANS From GLOCK
 Gosub TR_LIEN
Endif
Gosub MHE_VALROWFLD
Return

$TR_LIEN
Trbegin [MHE]
 [F:MHE]FLGCLO = 1
 Rewrite[MHE]
 If fstat : Call FSTA("MHE") From GLOCK : Rollback : Return : Endif
Commit
Return

#####################################
$LIENS2
#CMT
Default Mask [M:MHE0]
Call CHARGE_CMT ("SUBMHE",[F:MHE]COD,"","","")From SUBMSR
Gosub TITROWFLD
Gosub CHG_FMTROW
Gosub TITROWVRA
Gosub CHG_FMTVRA
Affzo [MHE0]
Gosub CHANGE_STYLE
If [M:MHE0]FLGCLO = 2
 Diszo [M:MHE0]BUD
 Diszo [M:MHE0]10
Else
 Actzo [M:MHE0]BUD
 Actzo [M:MHE0]10
Endif
Return

#####################################
$INIMOD
Default Mask [M:MHE0]
Call SAUVE_CMT ("SUBMHE",[F:MHE]COD,"","","")From SUBMSR
Return

#####################################
$INICRE
Gosub DEFVAR
## Affectation du no de MSR
If [F:MHE]COD=""
 Call LECTCA(15,STAT) From SUBTCA
 If !STAT
  GMESSAGE = mess(51,10722,1) : # Compteur MSR non défini
  GOK = 0 : Return
 Else
  COMPTEUR= [F:TCA]CODNUM(12)
 Endif
 Call NUMERO(COMPTEUR,"",date$,"",[F:MHE]COD,STAT) From SUBANM
 If STAT
  # Erreur sur compteur
  GMESSAGE = mess(4,10702,1)-COMPTEUR
  GOK = 0 : Return
 Endif
 Call VERIF_CPT([F:MHE]COD,COMPTEUR)
 If GOK=0 : Return : Endif
 [M:MHE0]COD = [F:MHE]COD
 Affzo [M:MHE0]COD
Endif

#CMT
Default Mask [M:MHE0]
Call SAUVE_CMT ("SUBMHE",[F:MHE]COD,"","","")From SUBMSR
#enregistrement champs salarié
Gosub SAV_FLDVAL
Return

#####################################
## Changement de clé
$AP_CHANGE
Call APCHANGE(4,OCODE,NCODE) From SUBMHR
Return

#####################################
$AVANT_MOD
If [M:MHE0]FLGCLO = 2
 GMESSAGE=mess(6,10722,1) : GERR=1 : OK=0
Endif
Return

#####################################
$ANNULE
Call ANNULE_CMT ("SUBMHE",[F:MHE]COD,"","","")From SUBMSR
PROG = "WPMS4"+[F:MHE]COD
Call DELTRTHYP (PROG) From SUBMHE
Return

Subprog DELTRTHYP(TRAIT)
Value Char    TRAIT
Local Char    FICHIER(GDIMFIC)
Local Integer STAT , OKTRT

FICHIER =filpath("TRT",TRAIT,"src",nomap(0))
If filinfo(FICHIER,0)>=0
 Call EFFACE(FICHIER,STAT) From ORDSYS
Endif
Call EXISTE_ADX("",nomap(0),TRAIT,OKTRT) From ORDSYS
If OKTRT>0
 Call EFFACE_ADX("",nomap(0),TRAIT,STAT) From ORDSYS
Endif
End

#####################################
$RAZCRE
[M:MHE0]FLGCLO=1
[M]TRN=GFLAG
Gosub TITROWFLD
Gosub CHG_FMTROW
Gosub TITROWVRA
Gosub CHG_FMTVRA
Affzo [M:MHE0]
Return

#####################################
$RAZDUP
[M:MHE0]FLGCLO=1
Actzo [M:MHE0]BUD
Actzo [M:MHE0]10
Affzo [M:MHE0]
Return

####################################
$CHANGE_STYLE
For nolign=1 To [M:MHE0]NBENT
 If [M:MHE0]ENAFLG1(nolign-1)=2
  Chgstl [M:MHE0]NBENT(nolign-1) With "CONTRAT"
 Else
  Chgstl [M:MHE0]NBENT(nolign-1) With ""
 Endif
Next
Return

####################################
$MHE_VALROWFLD
#alimentation du tableau des valeur des champs & variables salariés (maxi 20+15)
For L=0 To dim([M:MHE0]REFNUM)-1
 If [M:MHE0]REFNUM(L) = "" : Break : Endif
 If [F:MHE]REFNUM = [M:MHE0]REFNUM(L) & [F:MHE]CTRNUM = [M:MHE0]CTRNUM(L)
& & [F:MHE]ORD = [M:MHE0]ORD(L) : # 74218
#CHAMPS SALARIES
  For R=0 To dim([M:MHE0]FLDEML)-1
#on alimente les valeurs que l'on trouve
   Call VALROWFLD("[M:MHE0]FLDVAL"+num$(R)+"("+num$(L)+")","[F:MHE]FLDVAL("+num$(R)+")")
   Call VALROWFLD("[M:MHE0]VALINT"+num$(R)+"("+num$(L)+")","[F:MHE]FLDVAL("+num$(R)+")")
#et le code du champs si il correspond
   If [M:MHE0]FLDEML(R) = ""
    Call VALROWFLD("[M:MHE0]FLDEML"+"("+num$(R)+")","[F:MHE]FLDEML("+num$(R)+")")
   Endif
  Next
#VARIABLES SALARIES
  For R=0 To dim([M:MHE0]VRAEML)-1
   Call VALROWFLD("[M:MHE0]VRAVAL"+num$(R)+"("+num$(L)+")","[F:MHE]VRAVAL("+num$(R)+")")
   If [M:MHE0]VRAEML(R) = ""
    Call VALROWFLD("[M:MHE0]VRAEML"+"("+num$(R)+")","[F:MHE]VRAEML("+num$(R)+")")
   Endif
  Next
# Au passage alimentation des noms-prénom
  Call VAL_NAMSRN ([M:MHE0]REFNUM(L),"[M:MHE0]NAMSRN("+num$(L)+")")
#fill SRCDES
  Call FILL_SRCDES([M:MHE0]SRCDES(L))
  Break
 Endif
Next
Return

$TITROWFLD
#alimentation de la liste des champs MS et des titres de colonnes
MSI = 1
[M]OKFLD = 1
While MSI  <= dim(GFLDMS) & GFLDMS(MSI,0) <> ""
  MSJ = find(GFLDMS(MSI,0),[M]FLDEML(0..dim(GFLDMS)-1))
 If !MSJ
#Champs MS non stocké dans l'hypothèse. on tente de l'ajouter
  MSJ = find("",[M]FLDEML(0..dim(GFLDMS)-1))
  If MSJ > 0
   [M]FLDEML(MSJ-1)    = GFLDMS(MSI,0)
   [M]TITROWFLD(MSJ-1) = GFLDMS(MSI,1)
  Else
#si on a pas pu charger tous les champs MS
   [M]OKFLD = 0
  Endif
 Else
  [M]TITROWFLD(MSJ-1) = GFLDMS(MSI,1)
 Endif
 MSI +=1
Wend
Return

$TITROWVRA
#alimentation de la liste des variables MS et des titres de colonnes
MSI = 1
[M]OKVRA = 1
While MSI  <= dim(GVRAMS) & GVRAMS(MSI,0) <> ""
  MSJ = find(GVRAMS(MSI,0),[M]VRAEML(0..dim(GVRAMS)-1))
 If !MSJ
  MSJ = find("",[M]VRAEML(0..dim(GVRAMS)-1))
  If MSJ > 0
   [M]VRAEML(MSJ-1)    = GVRAMS(MSI,0)
   [M]TITROWVRA(MSJ-1) = GVRAMS(MSI,1)
  Else
#si on a pas pu charger toutes les variables MS
   [M]OKVRA = 0
  Endif
 Else
  [M]TITROWVRA(MSJ-1) = GVRAMS(MSI,1)
 Endif
 MSI +=1
Wend
Return

$CHG_FMTROW
#Formats pour champs salariés

For MSI = 0 To 19  # dépend du nb de champs FLDVALn dans MHE0
 If [M]TITROWFLD(MSI) = "" & [M]FLDEML(MSI) = ""
#  on est sur les colonnes à supprimer
  Case MSI
   When  0  : Chgfmt [M]FLDVAL0  With '-K:80X'
   When  1  : Chgfmt [M]FLDVAL1  With '-K:80X'
   When  2  : Chgfmt [M]FLDVAL2  With '-K:80X'
   When  3  : Chgfmt [M]FLDVAL3  With '-K:80X'
   When  4  : Chgfmt [M]FLDVAL4  With '-K:80X'
   When  5  : Chgfmt [M]FLDVAL5  With '-K:80X'
   When  6  : Chgfmt [M]FLDVAL6  With '-K:80X'
   When  7  : Chgfmt [M]FLDVAL7  With '-K:80X'
   When  8  : Chgfmt [M]FLDVAL8  With '-K:80X'
   When  9  : Chgfmt [M]FLDVAL9  With '-K:80X'
   When  10 : Chgfmt [M]FLDVAL10 With '-K:80X'
   When  11 : Chgfmt [M]FLDVAL11 With '-K:80X'
   When  12 : Chgfmt [M]FLDVAL12 With '-K:80X'
   When  13 : Chgfmt [M]FLDVAL13 With '-K:80X'
   When  14 : Chgfmt [M]FLDVAL14 With '-K:80X'
   When  15 : Chgfmt [M]FLDVAL15 With '-K:80X'
   When  16 : Chgfmt [M]FLDVAL16 With '-K:80X'
   When  17 : Chgfmt [M]FLDVAL17 With '-K:80X'
   When  18 : Chgfmt [M]FLDVAL18 With '-K:80X'
   When  19 : Chgfmt [M]FLDVAL19 With '-K:80X'
  Endcase
 Else
  If [M]TITROWFLD(MSI) = ""
# champ salarié dans l'hypothèse qui n'est plus dans la transaction
   [M]TITROWFLD(MSI) = "*"+[M]FLDEML(MSI)+"*"
   [M]OKFLD = 0
  Endif
  Case MSI
   When  0  : Chgfmt [M]FLDVAL0  With 'K:80X'
   When  1  : Chgfmt [M]FLDVAL1  With 'K:80X'
   When  2  : Chgfmt [M]FLDVAL2  With 'K:80X'
   When  3  : Chgfmt [M]FLDVAL3  With 'K:80X'
   When  4  : Chgfmt [M]FLDVAL4  With 'K:80X'
   When  5  : Chgfmt [M]FLDVAL5  With 'K:80X'
   When  6  : Chgfmt [M]FLDVAL6  With 'K:80X'
   When  7  : Chgfmt [M]FLDVAL7  With 'K:80X'
   When  8  : Chgfmt [M]FLDVAL8  With 'K:80X'
   When  9  : Chgfmt [M]FLDVAL9  With 'K:80X'
   When  10 : Chgfmt [M]FLDVAL10 With 'K:80X'
   When  11 : Chgfmt [M]FLDVAL11 With 'K:80X'
   When  12 : Chgfmt [M]FLDVAL12 With 'K:80X'
   When  13 : Chgfmt [M]FLDVAL13 With 'K:80X'
   When  14 : Chgfmt [M]FLDVAL14 With 'K:80X'
   When  15 : Chgfmt [M]FLDVAL15 With 'K:80X'
   When  16 : Chgfmt [M]FLDVAL16 With 'K:80X'
   When  17 : Chgfmt [M]FLDVAL17 With 'K:80X'
   When  18 : Chgfmt [M]FLDVAL18 With 'K:80X'
   When  19 : Chgfmt [M]FLDVAL19 With 'K:80X'
  Endcase
# on formtate les colonnes affichées
  Read [F:DIC]DIC0 = [M]FLDEML(MSI)
  If !fstat
   Read [F:ATZ]CODZONE = [F:DIC]TBL;[F:DIC]FLD
  Endif
  If !fstat

   [M]TYPFLD(MSI)   = [F:ATZ]CODTYP
   [M]LONGFLD(MSI)  = [F:ATZ]LONG

   If [M]TYPFLD(MSI) ="ADI"
    [M]NOLIBFLD(MSI) = val(evalue([F:DIC]PARVAL(0)))
#***DBA***
   Elsif [M]TYPFLD(MSI) ="PRF"
    [M]NOLIBFLD(MSI) = [F:ATZ]NOLIB
    [M]OBJFLD(MSI)=""
#******
   Else
    [M]NOLIBFLD(MSI) = [F:ATZ]NOLIB
    [M]OBJFLD(MSI)   = [F:DIC]PARVAL(0)
   Endif

   Call LECTURE("ATY",[F:ATZ]CODTYP,"") From CONTOBJ
   [M]TYP(MSI)      = [F:ATY]TYPTYP
   [M]OBJET(MSI)    = [F:ATY]OBJLIEN
   [M]OPTFLD(MSI)   = ""

   LNGFMT = [M]LONGFLD(MSI)
   If LNGFMT=0
    LNGFMT = [F:ATY]LNGTYP
   Endif
   Call FORMA(20,[F:ATY]TYPTYP,LNGFMT,[M]NOLIBFLD(MSI),[F:ATY]OPTION,[F:ATY]FORTYP
&            ,TYPFMT,OPTFMT,CHFMT,NUMFMT) From SUBFMT
   If [F:ATY]TYPTYP=1
    [M]FMT(MSI) = "Nzf:3#"
   Elsif [F:ATY]TYPTYP=8
    [M]FMT(MSI) = TYPFMT+OPTFMT+"Zz:"+CHFMT
   Else
    [M]FMT(MSI) = TYPFMT+OPTFMT+"z:"+CHFMT
   Endif
   If left$([M]FMT(MSI),1)="="
    If mid$([M]FMT(MSI),2,2)='"K' or mid$([M]FMT(MSI),2,2)="'K"
     [M]FMT(MSI)     = "K:30X"
     [M]LONGFLD(MSI) = 30
    Else
     Onerrgo RIEN
     ERR = 0
     [M]FMT(MSI) = evalue(right$([M]FMT(MSI),2))
     Onerrgo
     If ERR
      [M]FMT(MSI)     = "K:30X"
      [M]LONGFLD(MSI) = 30
     Endif
    Endif
   Endif
  Endif
 Endif

#on repère un éventuel déphasage
 If MSI < dim(GFLDMS) & !find(GFLDMS(MSI+1,0),[M]FLDEML(0..dim(GFLDMS)-1))
  [M]OKFLD = 0
 Endif
Next
Return

$CHG_FMTVRA
#Formats pour variables salariés
For MSI = 0 To 14  #nb de champs VRAVALn dans MHE0
 If [M]TITROWVRA(MSI) = "" & [M]VRAEML(MSI) = ""
#  on est sur les colonnes à supprimer
  Case MSI
   When  0  : Chgfmt [M]VRAVAL0  With '-N3z:10.3'
   When  1  : Chgfmt [M]VRAVAL1  With '-N3z:10.3'
   When  2  : Chgfmt [M]VRAVAL2  With '-N3z:10.3'
   When  3  : Chgfmt [M]VRAVAL3  With '-N3z:10.3'
   When  4  : Chgfmt [M]VRAVAL4  With '-N3z:10.3'
   When  5  : Chgfmt [M]VRAVAL5  With '-N3z:10.3'
   When  6  : Chgfmt [M]VRAVAL6  With '-N3z:10.3'
   When  7  : Chgfmt [M]VRAVAL7  With '-N3z:10.3'
   When  8  : Chgfmt [M]VRAVAL8  With '-N3z:10.3'
   When  9  : Chgfmt [M]VRAVAL9  With '-N3z:10.3'
   When  10 : Chgfmt [M]VRAVAL10 With '-N3z:10.3'
   When  11 : Chgfmt [M]VRAVAL11 With '-N3z:10.3'
   When  12 : Chgfmt [M]VRAVAL12 With '-N3z:10.3'
   When  13 : Chgfmt [M]VRAVAL13 With '-N3z:10.3'
   When  14 : Chgfmt [M]VRAVAL14 With '-N3z:10.3'
  Endcase
 Else
  If [M]TITROWVRA(MSI) = ""
# variable salarié dans l'hypothèse qui n'est plus dans la transaction
   [M]TITROWVRA(MSI) = "*"+[M]VRAEML(MSI)+"*"
   [M]OKVRA = 0
  Endif
  Case MSI
   When  0  : Chgfmt [M]VRAVAL0  With 'N3z:10.3'
   When  1  : Chgfmt [M]VRAVAL1  With 'N3z:10.3'
   When  2  : Chgfmt [M]VRAVAL2  With 'N3z:10.3'
   When  3  : Chgfmt [M]VRAVAL3  With 'N3z:10.3'
   When  4  : Chgfmt [M]VRAVAL4  With 'N3z:10.3'
   When  5  : Chgfmt [M]VRAVAL5  With 'N3z:10.3'
   When  6  : Chgfmt [M]VRAVAL6  With 'N3z:10.3'
   When  7  : Chgfmt [M]VRAVAL7  With 'N3z:10.3'
   When  8  : Chgfmt [M]VRAVAL8  With 'N3z:10.3'
   When  9  : Chgfmt [M]VRAVAL9  With 'N3z:10.3'
   When  10 : Chgfmt [M]VRAVAL10 With 'N3z:10.3'
   When  11 : Chgfmt [M]VRAVAL11 With 'N3z:10.3'
   When  12 : Chgfmt [M]VRAVAL12 With 'N3z:10.3'
   When  13 : Chgfmt [M]VRAVAL13 With 'N3z:10.3'
   When  14 : Chgfmt [M]VRAVAL14 With 'N3z:10.3'
  Endcase
 Endif
#on repère un éventuel déphasage
 If MSI < dim(GVRAMS) & !find(GVRAMS(MSI+1,0),[M]VRAEML(0..dim(GVRAMS)-1))
  [M]OKVRA = 0
 Endif
Next
Return

$RIEN
ERR = errn
Resume

####################################
$SAV_FLDVAL
#enregistrement valeurs salariés dans la table

For L=0 To [M:MHE0]NBENT
 If [M:MHE0]REFNUM(L) = [F:MHE]REFNUM & [M:MHE0]CTRNUM(L) = [F:MHE]CTRNUM
& & [M:MHE0]ORD(L)    = [F:MHE]ORD : # 74218
  For R=0 To dim(GFLDMS)-1
   [F:MHE]FLDVAL(R) = evalue("[M:MHE0]VALINT"+num$(R)+"("+num$(L)+")")
  Next
  For R=0 To dim(GVRAMS)-1
   [F:MHE]VRAVAL(R) = evalue("[M:MHE0]VRAVAL"+num$(R)+"("+num$(L)+")")
  Next
  Break
 Endif
Next
Return

####################################
Subprog VERIF_CPT(NUM,COMPTEUR)
Variable Char NUM
Value    Char COMPTEUR

If clalev([F:MHEX])=0 : Local File MSENTEML [MHEX] : Endif
Read [MHEX]MHE0(1)=NUM
If fstat : End : Endif
While !fstat
 Call NUMERO(COMPTEUR,"",date$,"",NUM,STAT) From SUBANM
 Read [MHEX]MHE0(1)=NUM
Wend
If STAT
 # Erreur sur compteur
 GMESSAGE = mess(4,10702,1)-COMPTEUR
 GOK = 0 : End
Endif
End

Subprog VALROWFLD (CEL,FLD)
Value Char CEL
Value Char FLD
#chargement d'une cellule champs salarié
Assign(CEL) With evalue(FLD)
End

Subprog VAL_NAMSRN (REFN,NS)
#Alimentation nom-prénom
Value Char REFN
Value Char NS
Read [F:ID]ID0 = REFN
If !fstat
 Assign(NS) With [F:ID]NAM+"-"+[F:ID]SRN
Endif
End

Subprog LOOK_FLDVAL(REFN,CTRN,LIG)
Value Char REFN
Value Char CTRN
Value Integer LIG

Local Char    TTBL  (GLONATB)(1..dim(GFLDMS))
Local Integer FILLED : #  72635

For MSI = 1 To dim(GFLDMS)
 Read [F:DIC]DIC0 = [M:MHE0]FLDEML(MSI-1)
 If !fstat & [F:DIC]TBL <> "" & [F:DIC]MSFLG = 2 & [F:DIC]ENAFLG = 2 &
&   ([F:DIC]CODACT = "" | func AFNC.ACTIV([F:DIC]CODACT) > 0)

# / 72635
  FILLED = 0
  Case [M:MHE0]SRCOBJ(LIG)
   When "PRF"     : # Profils modèle      - model Profiles
    Default File [HRPFD]
    [G:HRPFD]currind=1
    [G:HRPFD]currlen=0
   When "JOT"     : # Emplois type modèle - model standard jobs
    Default File [JOD]
    [G:JOD]currind=1
    [G:JOD]currlen=0
   When "POT"     : # Postes modèle       - model work centers
    Default File [POD]
    [G:POD]currind=1
    [G:POD]currlen=0
   When Default
    FILLED = -1
  Endcase

  If FILLED = 0     : # Objet source = PRF,JOT ou POT
    # niveau Population - Population level
    If !FILLED & dim([M:MHE0]POP) > 0 & [M:MHE0]POP <> ""
     Read [F] =  [M:MHE0]SRCENT(LIG);[M:MHE0]FLDEML(MSI-1);"";"";"";[M:MHE0]POP
     If !fstat
      FILLED = 1
     Endif
    Endif
    # niveau convention collective - CLLCVT level
    If !FILLED & dim([M:MHE0]CLLCVT) > 0 & [M:MHE0]CLLCVT <> ""
     Read [F] =  [M:MHE0]SRCENT(LIG);[M:MHE0]FLDEML(MSI-1);"";"";[M:MHE0]CLLCVT;""
     If !fstat
      FILLED = 1
     Endif
    Endif
    # niveau site - facility level
    If !FILLED & dim([M:MHE0]FCY) > 0 & [M:MHE0]FCY <> ""
     Read [F] =  [M:MHE0]SRCENT(LIG);[M:MHE0]FLDEML(MSI-1);"";FCY;"";""
     If !fstat
      FILLED = 1
     Endif
    Endif
    # niveau société - company level
    If !FILLED & dim([M:MHE0]CPY) > 0 & [M:MHE0]CPY <> ""
     Read [F] =  [M:MHE0]SRCENT(LIG);[M:MHE0]FLDEML(MSI-1);CPY;"";"";""
     If !fstat
      FILLED = 1
     Endif
    Endif
    # niveau dossier - folder level
    If !FILLED
     Read [F] =  [M:MHE0]SRCENT(LIG);[M:MHE0]FLDEML(MSI-1);"";"";"";""
     If !fstat
      FILLED = 1
     Endif
    Endif
  Endif

  If FILLED > 0    : # On a trouvé dans le modèle
   Assign("[M:MHE0]FLDVAL"+num$(MSI-1)+"("+num$(LIG)+")")  With  [F]VALINT
  Else
   # il n'y a pas de modèle ou le champ n'est pas dans le modèle
   # there is no model or the field was not found in the model
 #   72635 /

  MSJ = find([F:DIC]TBL,TTBL(1..dim(GFLDMS)))
  If !MSJ
   TTBL(MSI) = [F:DIC]TBL
   Local File =TTBL(MSI)
   MSJ = MSI
  Endif
  TABLE = TTBL(MSJ) : Gosub DEFAUT From WPDEFTABLE
  [G]currind = 1
  If dim([F]CTRNUM)>0 & TABLE="EMPLOMED"
   Filter [F] Where REFNUM=REFN & (CTRNUM=CTRN | CTRNUM="")
  Elsif dim([F]CTRNUM)>0
   Filter [F] Where REFNUM=REFN & CTRNUM=CTRN
  Else
   Filter [F] Where REFNUM=REFN
  Endif
  Read Last

  If !fstat
   Case [M:MHE0]TYP(MSI-1)
    When 1,2,3,4,5,6
     Assign("[M:MHE0]FLDVAL"+num$(MSI-1)+"("+num$(LIG)+")") With  num$(evalue("[F]"+[M:MHE0]FLDEML(MSI-1)))
    When  7
     Assign("[M:MHE0]FLDVAL"+num$(MSI-1)+"("+num$(LIG)+")") With  evalue("[F]"+[M:MHE0]FLDEML(MSI-1))
   Endcase
  Endif

  Filter [F]

  Endif : # 72635

 Endif
Next
End

$CONTROW

VALCONT = VALEUR
VALFLDINT = VALEUR
FLDINT  = "[M:MHE0]VALINT"+num$(IROW)+"(nolign-1)"
If VALEUR <> ""
 Call CONTGEN([L]VALCONT,[M:MHE0]OBJET(IROW),[M:MHE0]NOLIBFLD(IROW),[M:MHE0]OBJFLD(IROW))
 If mkstat : Return : Endif
 #/FMT
 If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif
 Call LECTURE("ATY",[M:MHE0]TYPFLD(IROW),"") From CONTOBJ
 If find([F:ATY]TYPTYP,2,3,4)
  VALFLDINT= vireblc(VALFLDINT,4)
 Else
  Local Integer J , K
  Local Char    COMT(100) , FMT(100)
  VALFLDINT = vireblc(VALFLDINT,2)
  If [F:ATY]TYPTYP=7 & [F:ATY]FORTYP<>""
   FMT = [F:ATY]FORTYP
   Repeat
    K = instr(1,FMT,"[")
    If K
     J = instr(K+1,FMT+"]","]")
     COMT = seg$(FMT,K+1,J-1)
     FMT  = left$(FMT,K-1)+right$(FMT,K+1)
     If left$(VALFLDINT,len(COMT))=COMT
      VALFLDINT = right$(VALFLDINT,len(COMT)+1)
     Elsif seg$(VALFLDINT,K,J-2)=COMT
      VALFLDINT = left$(VALFLDINT,K-1)+right$(VALFLDINT,J-1)
     Endif
    Endif
   Until K=0
  Endif
 Endif
Endif
Assign FLDINT With VALFLDINT
#/FMT
Return

Subprog CONTGEN(VALF,OBJET,NOLIB,PAROBJ)
Value Char    VALF
Value Char    OBJET
Value Integer NOLIB
Value Char    PAROBJ
If [L]OBJET<>""
 Local Char SUPP(10)
 If [L]OBJET="ADI"
  SUPP = num$([L]NOLIB)
 Elsif [L]PAROBJ<>""
  SUPP = num$(evalue([L]PAROBJ))
 Endif

#***DBA***
 Case OBJET
  When "PRF"
   Call CONTROLE([L]OBJET,"!$",VALF,GCURLEG,mkstat) From CONTOBJ
  When Default
   Call CONTROLE([L]OBJET,"!$",VALF,SUPP,mkstat) From CONTOBJ
 Endcase
 If mkstat : End : Endif
Endif
End
######################################################################################

###############################################################################################################
# Génération Traitement lié à l'hypoyhèse courante
# Ce traitement doit se nommer ainsi : "WPMS"+4+COD    (Chiffre 4 cause ML 485)
###############################################################################################################

Subprog GENHYPO(APPLI, CODHYP)
Value Char APPLI ()
Value Char CODHYP()

If clalev ([F:MHE2])=0 : Local File MSENTEML  [MHE2] : Endif
If clalev ([F:VRA])=0  : Local File VARIA      [VRA] : Endif
If clalev ([F:DIC])=0  : Local File DICOEMP    [DIC] : Endif
If clalev ([F:ATB])=0  : Local File ATABLE     [ATB] : Endif
If clalev ([F:ATZ])=0  : Local File ATABZON    [ATZ] : Endif


Local Char TETADO (50) , PROG (30) , FICSRC(250) , SAVREF(GLONEML)
Local Char CONDDEB (25) , CONDFIN (25)
Local Char XTBL (GLONATB) , XABR (GLONABR)
Local Integer L,R,C,OK
Local Integer MAXVRA : MAXVRA = func AFNC.ACTIV("MSV")
Local Integer MAXFLD : MAXFLD = func AFNC.ACTIV("MSF")

Local Char    TFLDEMP (GLONAVA)(1..MAXFLD)
Local Char    TFLDFUL (GLONABR+4+GLONAVA)(1..MAXFLD) #[F:xxxx]xxxxxx
Local Integer TFLDTYP (1..MAXFLD,1..2)

SAVIFS = adxifs
SAVIRS = adxirs
adxifs = ""
adxirs = chr$(10)

For [F:MHE2]MHE2 Where COD=CODHYP
 If SAVREF = ""
  TETADO = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
  PROG = "WPMS4"+[F:MHE2]COD
  FICSRC = filpath("TRT",PROG,"src",APPLI)
  Openo FICSRC , 0
  Wrseq TETADO-mess(4,10485,1)-CODHYP
  Wrseq "###############################################"
  Wrseq "###  ENTRANTS                                 #" : Wrseq
  Wrseq "$HYPOVAR"
  Wrseq "# On ne veut pas traiter le salarié réel"
  Wrseq "If LIGHYPO=0 : Return : Endif "
  #57202
  Wrseq "# On ne veut pas traiter des salariés modèles d'une autre hypothèse"
  Wrseq "If LISHYP(GIHYP)<>LISHYP(LIGHYPO+1) | TYPHYP(GIHYP)<>TYPHYP(LIGHYPO+1) : Return : Endif"

  Wrseq "Case MATRI"
 Endif
 If [F:MHE2]REFNUM <> SAVREF
  Wrseq space$(1)+"When '"+[F:MHE2]REFNUM+"'"
 Endif
 If [F:MHE2]ENAFLG1 = 2
#74218  Wrseq space$(2)+"If CTR='"+[F:MHE2]CTRNUM+"'"
  Wrseq space$(2)+"If CTR='"+[F:MHE2]CTRNUM+"' & [F:MHE]ORD="+num$([F:MHE2]ORD)
  For R=0 To MAXVRA-1
   If [F:MHE2]VRAVAL(R) <> 0
    Read [F:VRA]VRA0=GCURLEG;[F:MHE2]VRAEML(R)
    If !fstat
     Wrseq space$(3)+format$('K:15X','V_'+[F:VRA]COD)-' ='-num$([F:MHE2]VRAVAL(R))
    Endif
   Endif
  Next
  Wrseq space$(2)+"Endif"
 Endif
 SAVREF = [F:MHE2]REFNUM
Next
If TETADO<>""
 Wrseq space$(1)+"When default"
 Wrseq "Endcase"
 Wrseq "Return"
Endif

SAVREF=""
For [F:MHE2]MHE2 Where COD=CODHYP
 If SAVREF = ""
  Wrseq : Wrseq "###############################################"
  Wrseq "$LIRE"
  Wrseq "Case MATRI"
 Endif
 If [F:MHE2]REFNUM <> SAVREF
  Wrseq space$(1)+"When '"+[F:MHE2]REFNUM+"'"
 Endif
 If [F:MHE2]ENAFLG1 = 2 & ([F:MHE2]ENTDAT <> [00/00/0000] | [F:MHE2]XITDAT <> [00/00/0000])
  #74218 Wrseq space$(2)+"If CTR='"+[F:MHE2]CTRNUM+"'"
  Wrseq space$(2)+"If CTR='"+[F:MHE2]CTRNUM+"' & [F:MHE]ORD="+num$([F:MHE2]ORD)
  Raz CONDDEB , CONDFIN
  If [F:MHE2]XITDAT <> [00/00/0000]
   CONDDEB = " PERDEB > ["+num$([F:MHE2]XITDAT)+"]"
  Endif
  If [F:MHE2]ENTDAT <> [00/00/0000]
   CONDFIN = " PERFIN < ["+num$([F:MHE2]ENTDAT)+"]"
  Endif
  Wrseq space$(3)+"If"+CONDDEB+string$(((CONDDEB<>"")+(CONDFIN<>""))>1," |")+CONDFIN
  Wrseq space$(4)+"OKSIM = 0"
  Wrseq space$(3)+"Else"
  If CONDFIN <> ""
   Wrseq space$(4)+"PERDEB = max(PERDEB,["+num$([F:MHE2]ENTDAT)+"])"
  Endif
  If CONDDEB <> ""
   Wrseq space$(4)+"PERFIN = min(PERFIN,["+num$([F:MHE2]XITDAT)+"])"
  Endif
  Wrseq space$(3)+"Endif"
  Wrseq space$(2)+"Endif"
 Endif
 SAVREF = [F:MHE2]REFNUM
Next
If SAVREF <> ""
 Wrseq space$(1)+"When default"
 Wrseq "Endcase"
 Wrseq "Return"
Endif

SAVREF=""
Raz XTBL , XABR
Raz TFLDEMP , TFLDFUL , TFLDTYP

For [F:MHE2]MHE2 Where COD=CODHYP
 If SAVREF = ""
  Wrseq : Wrseq "###############################################"
  Wrseq "$LIRE_ENT"
  Wrseq "Case MATRI"
 Endif
 If [F:MHE2]REFNUM <> SAVREF
  Wrseq space$(1)+"When '"+[F:MHE2]REFNUM+"'"
 Endif
 If [F:MHE2]ENAFLG1 = 2
  #74218 Wrseq space$(2)+"If CTR='"+[F:MHE2]CTRNUM+"'"
  Wrseq space$(2)+"If CTR='"+[F:MHE2]CTRNUM+"' & [F:MHE]ORD="+num$([F:MHE2]ORD)

  ## 57205 date de contrat et date de fin
  Wrseq space$(3)+"[F:HRCTR]CTRDAT = ["+num$([F:MHE2]ENTDAT)+"]"
  If [F:MHE2]XITDAT<>[0/0/0]
   Wrseq space$(3)+"[F:HRCTR]XITDAT = ["+num$([F:MHE2]XITDAT)+"]"
   Wrseq space$(3)+"[F:HRCTR]XITFNL = 2"
  Endif

  ## parcours des champs salarié alimentés et génération au bon format
  For R=0 To MAXFLD-1
   Raz [F:DIC] , [F:ATB] , [F:ATZ] , [F:ATY]
   If [F:MHE2]FLDVAL(R) <> "" & [F:MHE2]FLDVAL(R) <> "0,00"
    #stockage du champ salarié et de son type
    L = find([F:MHE2]FLDEML(R),TFLDEMP(1..MAXFLD))
    If L = 0
     L = R+1
     TFLDEMP(L) = [F:MHE2]FLDEML(R)
     Read [F:DIC]DIC0=TFLDEMP(L)
     #recherche de l'abréviation de la table
     If !fstat & [F:DIC]TBL <> XTBL  : #pour ne pas relire inutilement ATABLE
      XTBL = [F:DIC]TBL
      Read [F:ATB]CODFIC=XTBL
      XABR = [F:ATB]ABRFIC
     Endif
     #recherche du type du champ
     Read [ATZ]CODZONE = [F:DIC]TBL;[F:DIC]FLD
     Read [ATY]CODTYP  = [F:ATZ]CODTYP
     TFLDTYP(L,1) = [F:ATY]TYPTYP
     TFLDTYP(L,2) = [F:ATZ]NOLIB
     TFLDFUL(L) = "[F:"+XABR+"]"+TFLDEMP(L)
    Endif
    If !find("",TFLDFUL(L)) & TFLDTYP(L,1) <> 0
     Case TFLDTYP(L,1)
      When 1 :              #menu local
       C=0
       Repeat C+=1
       Until C > len(mess(0,TFLDTYP(L,2),1)) | mess(C,TFLDTYP(L,2),1) = [F:MHE2]FLDVAL(R)
       If C <= len(mess(0,TFLDTYP(L,2),1))
        #58665 Remplace 15X par 20X
        Wrseq space$(3)+format$('K:20X',TFLDFUL(L))-' = '+num$(C)
       Endif
      When 2, 3, 4, 5, 6  : #numérique
       #58665 Remplace 15X par 20X
       Wrseq space$(3)+format$('K:20X',TFLDFUL(L))-' ='-func AFNC.TRANSF([F:MHE2]FLDVAL(R),",",".")
      When 8 :              #date
       #58665 Remplace 15X par 20X
       Wrseq space$(3)+format$('K:20X',TFLDFUL(L))-' ='-"["+[F:MHE2]FLDVAL(R)+"]"
      When Default :        #alphanumérique
       #58665 Remplace 15X par 20X
       Wrseq space$(3)+format$('K:20X',TFLDFUL(L))-' = "'+[F:MHE2]FLDVAL(R)+'"'
     Endcase
    Endif
   Endif
  Next

  Wrseq space$(2)+"Endif"
 Endif
 SAVREF = [F:MHE2]REFNUM
Next
If SAVREF <> ""
 Wrseq space$(1)+"When default"
 Wrseq "Endcase"
 Wrseq "Return"
Endif

Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
adxirs = SAVIRS
adxifs = SAVIFS
End

