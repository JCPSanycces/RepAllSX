Subprog D_BUD(VALEUR)
Variable Char    VALEUR()
Read [F:SEH]SEH0 = GFLAG
If !fstat : VALEUR = [F:SEH]BUD : Endif
End

Subprog C_NBR(VALEUR)
Variable Decimal VALEUR
If VALEUR > 500 : # dimension max le calcul paie MS
 GMESSAGE = mess(115,75,1)
 GMESSAGE = func AFNC.MES(GMESSAGE,"500") : #Valeur trop grande (maximum 500)
 GOK = 0 : mkstat = 2
Endif
End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
Call UPD_REFNUM(VALEUR)
End

Subprog UPD_REFNUM(VALEUR)
Variable Char VALEUR()

Call SELCTR(VALEUR,datesyst,datesyst,[M:MHE0]CTRNUM(nolign-1)) From DIVPAYE
If [M:MHE0]CTRNUM(nolign-1) = ""
 End
Endif

If [F:ID]FLGMULCTR>1
 Actzo [M:MHE0]CTRNUM(nolign-1)
Else
 Diszo [M:MHE0]CTRNUM(nolign-1)
Endif

Call LOOK_FLDVAL(VALEUR,[M:MHE0]CTRNUM(nolign-1),nolign-1)

#73013 : after contract ctrl
#maj nom-prénom
Call VAL_NAMSRN (VALEUR,"[M:MHE0]NAMSRN("+num$(nolign-1)+")")
Affzo [M:MHE0]NAMSRN(nolign-1)

#75787
[M:MHE0]ORD(nolign-1)=nolign

End

Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
Call LOOK_FLDVAL([M:MHE0]REFNUM(nolign-1),VALEUR,nolign-1)
End

Subprog C_XITDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<=[M:MHE0]ENTDAT(nolign-1) & VALEUR<>[0/0/0]
 GMESSAGE=mess(1,104,1) # Date incorrecte
 mkstat=2
 End
Endif
End

Subprog C_NBENT
If !adxgtb and GREP<>""
#ctrl si on a trop de champs MS ou pas les mêmes que ceux stockés dans l'hypothèse
 If [M:MHE0]OKFLD=0
  GMESSAGE=mess(3,10722,1) #Déphasage Champs salariés de l'hypothèse / champs salariés transaction
  mkstat=2 : End
 Endif
 If [M:MHE0]OKVRA=0
  GMESSAGE=mess(7,10722,1) #Déphasage Variables salariés de l'hypothèse / Variables salariés définies dans la transaction
  mkstat=2 : End
 Endif
Endif
End

Subprog C_ENAFLG1(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Chgstl [M:MHE0]NBENT(nolign-1) With "CONTRAT"
Else
 Chgstl [M:MHE0]NBENT(nolign-1) With ""
Endif
End

