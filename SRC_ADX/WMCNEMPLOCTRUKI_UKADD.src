Gosub INIT_EML From WMC1EMPLOCTRUKI_UKADD : Gosub TESTALLSTAT
Gosub INIT_TYP From WMC1EMPLOCTRUKI_UKADD : Gosub TESTALLSTAT
Gosub INIT_SETDEF From WMC1EMPLOCTRUKI_UKADD : Gosub TESTALLSTAT
Gosub INIT_NUKADD From WMC1EMPLOCTRUKI_UKADD : Gosub TESTALLSTAT
Gosub INIT_PIO From WMC1EMPLOCTRUKI_UKADD : Gosub TESTALLSTAT
Gosub INIT_MOB From WMC1EMPLOCTRUKI_UKADD : Gosub TESTALLSTAT
Gosub INIT_WRKMOB From WMC1EMPLOCTRUKI_UKADD : Gosub TESTALLSTAT
Gosub INIT_FAX From WMC1EMPLOCTRUKI_UKADD : Gosub TESTALLSTAT
Gosub INIT_ETS From WMC1EMPLOCTRUKI_UKADD : Gosub TESTALLSTAT
Gosub INIT_OTHEML From WMC1EMPLOCTRUKI_UKADD : Gosub TESTALLSTAT
Gosub AINIT From WMC0EMPLOCTRUKI_UKADD : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
