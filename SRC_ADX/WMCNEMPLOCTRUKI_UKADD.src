$AINIT
Gosub DECLARE_VAR From WMC0EMPLOCTRUKI_UKADD
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_ADDLIN1 From WMC1EMPLOCTRUKI_UKADD : Gosub TESTALLSTAT
Gosub INIT_ADDLIN2 From WMC1EMPLOCTRUKI_UKADD : Gosub TESTALLSTAT
Gosub INIT_TWN From WMC1EMPLOCTRUKI_UKADD : Gosub TESTALLSTAT
Gosub INIT_CUY From WMC1EMPLOCTRUKI_UKADD : Gosub TESTALLSTAT
