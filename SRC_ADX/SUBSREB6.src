#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################################################
$CODE_C_MAC
Local Integer IASKMACNOTUSE
Local Integer I
Local Integer ITER
Local Integer IERR
Local Integer IDELLINES
Local Integer ICANDO
Local Char SZMESS(250)
Local Integer IMESSREP
Local Integer ISTKMOVE   # FGR 12/04/2011 : X3SUIVI71931

  IERR = 0
  IDELLINES = 0
  IMESSREP = 0
  SZMESS= ""
  ICANDO = 0
  IASKMACNOTUSE = 0
  If VALEUR = "" Then
    #Valeur incorrecte
    GMESSAGE = mess(83,123,1)
    GERR = 1
    mkstat = 2
    Return
  Else
    Read [MAC]MAC0=VALEUR
    If fstat Then
      #Valeur incorrecte
      GMESSAGE = mess(83,123,1)
      GERR = 1
      mkstat = 2
      Return
    Else
      If [F:MAC]MACITNTYP <> 1 Then
        #Ce parc n'est pas utilisé. Confirmez-vous la saisie ?
        Call OUINON(mess(183,177,1), IASKMACNOTUSE) From GESECRAN
        If IASKMACNOTUSE <> 2 Then
          #Saisie refusée.
          GMESSAGE = mess(627,196,1)
          GERR = 1
          mkstat = 2
          Return
        Endif
      Else
        If [F:MAC]BPCNUM = "" Then
          If [F:MAC]CCNNUM = "" Then
            #L'utilisateur final de ce parc n'est pas identifié. Confirmez-vous la saisie ?
            Call OUINON(mess(184,177,1), IASKMACNOTUSE) From GESECRAN
            If IASKMACNOTUSE <> 2 Then
              #Saisie refusée.
              GMESSAGE = mess(627,196,1)
              GERR = 1
              mkstat = 2
              Return
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  #Vérifie si un code identique n'a pas déjà été préalablement saisi dans ce tableau
  For I = 0 To dim ([M:SRE7]MAC)-1
    If I <> nolign-1 Then
      If [M:SRE7]MAC(I) = VALEUR Then
        GMESSAGE = mess(435,196,1) #Cet identifiant de parc a déjà été saisi.
        GERR = 1
        mkstat = 2
        Break
      Endif
    Endif
  Next
  If GERR Then
    Return
  Endif
  #Suppression des lignes de consommation associées
  If [M:SRE7]MAC(nolign-1) <> "" Then
    If [M:SRE7]MAC(nolign-1) <> VALEUR Then
      ICANDO = 0
      ISTKMOVE = 0   # FGR 12/04/2011 : X3SUIVI71931
      For ITER = 0 To [M:SRE9]NBLIG-1
        If [M:SRE9]HDTMACSRE(ITER) = [M:SRE7]MAC(nolign-1) Then
          ICANDO = 1
          # FGR 12/04/2011 : X3SUIVI71931 (début)
          #Break
          If [M:SRE9]HDTTYP(ITER) = 2 Then                    # 2-Pièce
            If [M:SRE9]HDTDONDAT(ITER) <> [00/00/00] Then     # "Effectué le" saisi
              If [M:SRE9]HDTSTOISS(ITER) = 2 Then             # "Sortie de stock" effectuée
                If [M:SRE9]HDTISSQTY(ITER) > 0 Then           # "Quantité à sortir" saisie
                  If [M:SRE9]HDTISSISS(ITER) > 0 Then         # "Quantité sortie" saisie
                    If GREP <> "C" and GREP <> "D" Then
                      ISTKMOVE = 1
                      Break
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
          # FGR 12/04/2011 : X3SUIVI71931 (fin)
        Endif
      Next
      If ISTKMOVE = 1 Then # FGR 12/04/2011 : X3SUIVI71931
        # Il y a des mouvements de stocks sur ce parc. Modification interdite.
        GMESSAGE = mess(1014,182,1)
        GERR = 1
        mkstat = 2
        Return
      Else
        If ICANDO Then
          #Souhaitez-vous supprimer les lignes de consommations associées au parc indiqué précédemment ?
          SZMESS = mess(557,182,1)
          Call OUINON(SZMESS, IMESSREP) From GESECRAN
          If IMESSREP = 2 Then
            ITER = 0
            IERR = 0
            While 1
              If ITER >= dim([M:SRE9]HDTMACSRE) Then
                Break
              Endif
              If [M:SRE9]HDTMACSRE(ITER) = [M:SRE7]MAC(nolign-1) Then
                Call DELSTOSORW(ITER, ITER, "SRE9", [M:SRE9]HDTSTOFCY(ITER), IERR) From STKSOR
                If IERR Then
                  Break
                Endif
                #Suppression des débits de points complémentaires
                Call DELPIT("SRE9", ITER, IERR) From TRTAMOUNT
                If IERR Then
                  Break
                Endif
                Dela ITER, 1 [M:SRE9]NBLIG
                IDELLINES += 1
              Else
                ITER += 1
              Endif
            Wend
            If IERR Then
              #Erreur lors de suppression des lignes de consommations associées.
              GMESSAGE = mess(537,182,1)
              GERR = 1
              mkstat = 2
              Return
            Endif
            [M:SRE9]NBLIG -= IDELLINES
          Else
            For ITER = 0 To [M:SRE9]NBLIG-1
              If [M:SRE9]HDTMACSRE(ITER) = [M:SRE7]MAC(nolign-1) Then
                [M:SRE9]HDTMACSRE(ITER) = VALEUR
              Endif
            Next
            [M:SRE7]CKKHDTAMT(nolign-1) = 1
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$CODE_AM_MAC
Local Integer IERRINF
Local Integer IAFFSRE9
Local Integer ISETMAC
Local Integer ICHAPTER
Local Integer IBRETOUR

  IAFFSRE9 = 0
  IERRINF = 0
  ISETMAC = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If [M:SRE7]MAC(nolign-1) <> "" Then
    IAFFSRE9 = 1
  Endif
  If [M:SRE7]MAC(nolign-1) = "" Then
    If [M:SRE7]ITM(nolign-1) <> "" Then
      ISETMAC = 1
    Endif
  Endif
  Read [MAC]MAC0=VALEUR
  If !fstat Then
    [M:SRE7]ITM(nolign-1) = [F:MAC]MACPDTCOD
    If [M:SRE7]ITM(nolign-1) = "" Then
      [M:SRE7]ITMDES(nolign-1) = ""
    Else
      #Call LECTEXTRA([M:SRE7]ITMDES(nolign-1), "ITMMASTER", "DES1AXX", [M:SRE7]ITM(nolign-1), "") From ATEXTRA
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[M:SRE7]ITM(nolign-1),[M:SRE7]ITMDES(nolign-1), "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
    Endif
    [M:SRE7]SER(nolign-1) = [F:MAC]MACSERNUM
    [M:SRE7]QTY(nolign-1) = [F:MAC]MACQTY
    If [M:SRE7]QTY(nolign-1) = 0 Then
      [M:SRE7]QTY(nolign-1) = 1
    Endif
    [M:SRE7]LND(nolign-1) = [F:MAC]MACITNLND
    #S'il n'y aucun parc par défaut, celui-ci va le devenir
    If [M:SRE0]SREMAC = "" Then
      [M:SRE7]MACDEF(nolign-1) = 2
      [M:SRE0]SREMAC = VALEUR
    Else
      If [M:SRE7]MACDEF(nolign-1) <> 2 Then
        [M:SRE7]MACDEF(nolign-1) = 1
      Endif
    Endif
  Endif
  If [M:SRE7]SREPBLGRP <> "" Then
    If [M:SRE7]PBL(nolign-1) = "" Then
      [M:SRE7]PBL(nolign-1) = [M:SRE7]SREPBLGRP
      Read [PBL]PBL0=[M:SRE7]PBL(nolign-1)
      If fstat Then
        [M:SRE7]PBLCLA(nolign-1) = ""
      Else
        # FGR 23/09/2009 : X3SUIVI58024
        #[M:SRE7]PBLCLA(nolign-1) = [F:PBL]GRPPBLDES
        Call LECTEXTRA([M:SRE7]PBLCLA(nolign-1),"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
      Endif
    Endif
  Endif
  #On supprime les composants
  If [M:SRE7]MAC(nolign-1) <> "" Then
    Gosub RAZCPN From SUBSREB2
  Endif
  #---------------------------------------------------#
  # Suppression des points de l'ancienne fiche parc
  #---------------------------------------------------#
Local Integer ICOVNOL

  ICOVNOL = nolign-1
  If [M:SRE7]MAC(nolign-1) <> "" Then
    Call DELPITCOV(GREP, 1, ICOVNOL, IERRINF) From TRTCOVER
    If IERRINF Then
      #Erreur lors de suppression des couvertures par points. Le contrôle de couverture est abandonné.
      GMESSAGE = mess(IERRINF,182,1)
      GERR = 1
      Return
    Endif
  Endif
  [M:SRE7]MAC(nolign-1) = VALEUR
  #---------------------------------------------------#
  # Contrôle de la couverture
  #---------------------------------------------------#
  Call COVERML(ICOVNOL) From TRTCOVER
  #---------------------------------------------------#
  #si on complète une ligne après utilisation d'un modèle, on regarde les composants
  If ISETMAC = 1 Then
    Call LOADSETMACCPN ([M:SRE1]SRETPL, [M:SRE7]ITM(nolign-1)) From SUBSREB5
    Call SAVECPN([M:SRE0]CRESEQ, [M:SRE7]MAC(nolign-1), 1,IERRINF,ICHAPTER,IBRETOUR) From SUBSREB1
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 1
    Endif
    Call LOADSETHDT ([M:SRE1]SRETPL, [M:SRE7]ITM(nolign-1), VALEUR) From SUBSREB5
  Endif
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE2]1-99
  Affzo [M:SRE7]1-99
  If IAFFSRE9 Then
    Affzo [M:SRE9]1-99
  Endif
Return

##########################################################################################################
$CODE_AS_NBMAC
  If nolign >= dim([M:SRE7]MAC) Then
    Return
  Endif

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer ITER

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If [M:SRE0]DELSRE7FLG = 1 Then
    [M:SRE0]DELSRE7FLG = 0
    #Affichage du parc par défaut.
    Raz [M:SRE7]MACDEF
    If [M:SRE0]SREMAC <> "" Then
      If [M:SRE7]NBMAC >= 1 Then
        For ITER = 0 To [M:SRE7]NBMAC-1
          If [M:SRE7]MAC(ITER) = [M:SRE0]SREMAC Then
            [M:SRE7]MACDEF(ITER) = 2
            #LSE 01/07/2005 pour ne pas rendre valides tous les champs
            Affzo [M:SRE7]1-99
            Break
          Endif
        Next
      Endif
    Endif
  Endif
  If nolign > 0 Then
    If GREP = "C" Then
      Call SAVECPN([M:SRE0]CRESEQ, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), 1,IERRINF,ICHAPTER,IBRETOUR) From SUBSREB1
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1
      Endif
      Call LOADCPN([M:SRE0]CRESEQ, [M:SRE7]MAC(nolign-1), 1) From SUBSREB1
    Elsif GREP = "D" Then
      Call SAVECPN([M:SRE0]CRESEQ, [M:SRE7]MAC([M:SRE7]PRESRE7NOL),1,IERRINF,ICHAPTER,IBRETOUR) From SUBSREB1
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1
      Endif
      Call LOADCPN([M:SRE0]CRESEQ, [M:SRE7]MAC(nolign-1), 1) From SUBSREB1
    Else
      Call SAVECPN([M:SRE0]SRENUM, [M:SRE7]MAC([M:SRE7]PRESRE7NOL),0,IERRINF,ICHAPTER,IBRETOUR) From SUBSREB1
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1
      Endif
      Call LOADCPN([M:SRE0]SRENUM, [M:SRE7]MAC(nolign-1), 0) From SUBSREB1
    Endif
    If [M:SRE7]PRESRE7NOL <> nolign-1 Then
      [M:SRE7]NBMACSEL([M:SRE7]PRESRE7NOL) = ""
      [M:SRE7]NBMACSEL(nolign-1) = "->"
      [M:SRE7]PRESRE7NOL = nolign-1
      [M:SRE7]ITNGRUVAL = [M:SRE7]ITNGRU(nolign-1)
    Endif
    If [M:SRE7]PRESRE7NOL = 0 Then
      If nolign = 1 Then
        [M:SRE7]NBMACSEL(nolign-1) = "->"
      Endif
    Endif
  Endif
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE7]1-99
Return

##########################################################################################################
$CODE_C_NBMAC
  If nolign >= dim([M:SRE7]MAC) Then
    Return
  Endif

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  [M:SRE0]DELSRE7FLG = 0
  If status = 68 or status = 83 or status = 65 Then
    #Vérification du lock superviseur
    Gosub VERFLOCKSUP From SUBSREB4
    If GERR Then
      Return
    Endif
    If GREP = "" Then
      #Si la demande est lockée, on ne vas pas plus loin
      Gosub AVMCTLLOCKSRE From SUBSREA
      If !IUPDSRE Then
        mkstat = 2
        Return
      Endif
    Endif

    Local Integer ITERHDTFORMAC
    Local Integer ITERINOL
    Local Integer ITERINOL2
    Local Integer ITERINOL3
    Local Integer IDELCONTROL

    ITERHDTFORMAC = 0
    ITERINOL = 0
    ITERINOL2 = 0
    ITERINOL3 = 0
    IDELCONTROL = 0
    If status = 65 Then
      ITERHDTFORMAC = 0
      For ITERHDTFORMAC = 0 To [M:SRE9]NBLIG-1
        If [M:SRE9]HDTMACSRE(ITERHDTFORMAC) = [M:SRE7]MAC(nolign-1) Then
          If [M:SRE9]HDTISSISS(ITERHDTFORMAC) > 0 Then
            #Des consommations comportant des sorties de stock sont enregistrées pour le parc sélectionné. Suppression impossible.
            GMESSAGE = mess(172,177,1)
            GERR = 2
            IDELCONTROL = 1
            mkstat = 2
            If GREP = "" Then
              #On déverrouille la demande
              Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
            Endif
            Break
          Endif
          If GSRE9HDTISSISS(ITERHDTFORMAC) > 0 Then
            #Des consommations comportant des sorties de stock sont enregistrées pour le parc sélectionné. Suppression impossible.
            GMESSAGE = mess(172,177,1)
            GERR = 2
            IDELCONTROL = 1
            mkstat = 2
            If GREP = "" Then
              #On déverrouille la demande
              Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
            Endif
            Break
          Endif
        Endif
      Next
      If IDELCONTROL Then
        Return
      Endif
    Else
      ITERINOL = nolign-1
      ITERINOL2 = nolign1-1
      ITERINOL3 = nolign-1
      For ITERINOL3 = ITERINOL To ITERINOL2
        For ITERHDTFORMAC = 0 To [M:SRE9]NBLIG-1
          If [M:SRE9]HDTMACSRE(ITERHDTFORMAC) = [M:SRE7]MAC(ITERINOL3) Then
            If [M:SRE9]HDTISSISS(ITERHDTFORMAC) > 0 Then
              #Des consommations comportant des sorties de stock sont enregistrées pour le parc sélectionné. Suppression impossible.
              GMESSAGE = mess(172,177,1)
              GERR = 2
              IDELCONTROL = 1
              mkstat = 2
              If GREP = "" Then
                #On déverrouille la demande
                Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
              Endif
              Return
            Endif
            If GSRE9HDTISSISS(ITERHDTFORMAC) > 0 Then
              #Des consommations comportant des sorties de stock sont enregistrées pour le parc sélectionné. Suppression impossible.
              GMESSAGE = mess(172,177,1)
              GERR = 2
              IDELCONTROL = 1
              mkstat = 2
              If GREP = "" Then
                #On déverrouille la demande
                Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
              Endif
              Return
            Endif
          Endif
        Next
        If IDELCONTROL Then
          Break
        Endif
      Next
      If IDELCONTROL Then
        Return
      Endif
    Endif

    Local Integer IMESSREP

    IMESSREP = 0
    #Confirmez-vous la suppression du parc sélectionné ? Cette action ne peut pas être abandonnée.
    Call OUINON(mess(3,177,1), IMESSREP) From GESECRAN
    If IMESSREP <> 2 Then
      #La suppression du parc est abandonnée.
      GMESSAGE = mess(4,177,1)
      GERR = 2
      mkstat = 2
      If GREP = "" Then
        #On déverrouille la demande
        Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
      Endif
      Return
    Endif
  Endif

Local Integer INOL
Local Integer INOL2

  If status = 65 Then
    #Effacement d'une seule ligne
    INOL = nolign-1
    INOL2 = nolign-1
    Gosub DELMACLINES From SUBSREB4
    If GERR Then
      If GREP = "" Then
        #On déverrouille la demande
        Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
      Endif
      Return
    Endif
    Call LOADTOTHDT(1) From SUBSREB1
    Call LOADTOTPIT(1) From SUBSREB1
    If GREP = "" Then
      #On déverrouille la demande
      Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
    Endif
    #LSE 01/07/2005 pour ne pas rendre valides tous les champs
    Affzo [M:SRE9]1-99
  Elsif status = 68 or status = 83 Then
    #Effacement d'un groupe de lignes
    INOL = nolign-1
    INOL2 = nolign1-1
    Gosub DELMACLINES From SUBSREB4
    If GERR Then
      If GREP = "" Then
        #On déverrouille la demande
        Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
      Endif
      Return
    Endif
    Call LOADTOTHDT(1) From SUBSREB1
    Call LOADTOTPIT(1) From SUBSREB1
    If GREP = "" Then
      #On déverrouille la demande
      Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
    Endif
    #LSE 01/07/2005 pour ne pas rendre valides tous les champs
    Affzo [M:SRE9]1-99
  Endif
  If nolign > 0 Then
    If GREP = "C" Then
        Call SAVECPN([M:SRE0]CRESEQ, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), 1,IERRINF,ICHAPTER,IBRETOUR) From SUBSREB1
        If IBRETOUR = 0 Then
          GMESSAGE = mess(IERRINF,ICHAPTER,1)
          GERR = 1
        Endif
        Call LOADCPN([M:SRE0]CRESEQ, [M:SRE7]MAC(nolign-1), 1) From SUBSREB1
    Elsif GREP = "D" Then
      Call SAVECPN([M:SRE0]CRESEQ, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), 1,IERRINF,ICHAPTER,IBRETOUR) From SUBSREB1
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1
      Endif
      Call LOADCPN([M:SRE0]CRESEQ, [M:SRE7]MAC(nolign-1), 1) From SUBSREB1
    Else
      Call SAVECPN([M:SRE0]SRENUM, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), 0,IERRINF,ICHAPTER,IBRETOUR) From SUBSREB1
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1
      Endif
      Call LOADCPN([M:SRE0]SRENUM, [M:SRE7]MAC(nolign-1), 0) From SUBSREB1
    Endif
    If [M:SRE7]PRESRE7NOL <> nolign-1 Then
      [M:SRE7]NBMACSEL([M:SRE7]PRESRE7NOL) = ""
      [M:SRE7]NBMACSEL(nolign-1) = "->"
      [M:SRE7]PRESRE7NOL = nolign-1
      [M:SRE7]ITNGRUVAL = [M:SRE7]ITNGRU(nolign-1)
    Endif
  Endif
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE7]1-99
Return

##########################################################################################################
$CODE_IB_SREDET
Local Integer ITERPBLMAC
Local Char SZMACPBL(type([M:SRE7]PBL)-10)

  ITERPBLMAC = 0
  SZMACPBL = ""
  Raz GBOUT1  #Sélection affectation (Liste)
  Raz GBOUT2  #Sélection affectation par compétence.
  Raz GBOUT3  #Statistiques collaborateur
  Raz GBOUT4  #Statistiques queues
  Case [M:SRE2]SREASS
    When 1
      GBOUT1 = mess(261,196,1) #Sélection d'un site.
    When 2
      GBOUT1 = mess(192,196,1) #Sélection d'un collaborateur.
      If [M:SRE7]SREPBLGRP = "" Then
        If [M:SRE7]NBMAC > 0 Then
          For ITERPBLMAC = 0 To [M:SRE7]NBMAC-1
            If [M:SRE7]MACDEF(ITERPBLMAC) = 2 Then
              SZMACPBL = [M:SRE7]PBL(ITERPBLMAC)
              Break
            Endif
          Next
          If SZMACPBL <> "" Then
            GBOUT2 = mess(267,196,1) #Collaborateurs compétents
          Endif
        Endif
      Else
        GBOUT2 = mess(267,196,1) #Collaborateurs compétents
      Endif
      GBOUT3 = mess(324,196,1) #Statistiques collaborateurs.
    When 3
      GBOUT1 = mess(193,196,1) #Sélection d'une queue.
      If [M:SRE7]SREPBLGRP = "" Then
        If [M:SRE7]NBMAC > 0 Then
          For ITERPBLMAC = 0 To [M:SRE7]NBMAC - 1
            If [M:SRE7]MACDEF(ITERPBLMAC) = 2 Then
              SZMACPBL = [M:SRE7]PBL(ITERPBLMAC)
              Break
            Endif
          Next
          If SZMACPBL <> "" Then
            GBOUT2 = mess(268,196,1) #Queues concernées
          Endif
        Endif
      Else
        GBOUT2 = mess(268,196,1) #Queues concernées
      Endif
      #Statistiques queues
      Call TEXTE(16151, GBOUT4) From OBJDIV
    When Default
  Endcase
Return

##########################################################################################################
$CODE_AM_SREDET
Local Char SZVAL(250)
Local Char SZMESS(250)
Local Integer IONREP
Local Char SZHDKREP(100)
Local Integer IHDKREP

  SZHDKREP = ""
  IHDKREP = 0
  SZMESS = ""
  IONREP = 0
  SZVAL = toupper(VALEUR)
  VALEUR = SZVAL
  If VALEUR = "" Then
    [M:SRE2]SREDETCLA = ""
    Affzo [M:SRE2]SREDETCLA
    Return
  Endif
  Case [M:SRE2]SREASS
    When 1
      If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
      Read [FCY]FCY0=SZVAL
      If fstat Then
        VALEUR = ""
        [M:SRE2]SREDETCLA = VALEUR
      Else
        [M:SRE2]SREDETCLA = [F:FCY]FCYNAM
      Endif
    When 2
      Read [AUS]CODUSR=SZVAL
      If fstat Then
        VALEUR = ""
        [M:SRE2]SREDETCLA = VALEUR
      Else
        Call PARAMUTIL("AUSHDKA", SZHDKREP, SZVAL, "") From SUBAUS
        If SZHDKREP = "" Then
          IHDKREP = 1
        Else
          IHDKREP = val(SZHDKREP)
        Endif
        If IHDKREP = 2 Then
          [M:SRE2]SREDETCLA = [F:AUS]NOMUSR
        Else
          SZMESS = [F:AUS]NOMUSR - mess(619,196,1)
          Call OUINON(SZMESS, IONREP) From GESECRAN
          If IONREP = 2 Then
            [M:SRE2]SREDETCLA = [F:AUS]NOMUSR
          Else
            VALEUR = ""
            [M:SRE2]SREDETCLA = VALEUR
          Endif
        Endif
      Endif
      #LSE 16/08/2005
      Call SITECRMINTREP ("HDK", VALEUR, [M:SRE0]SALFCY) From CRM_UTIL
    When 3
      If !clalev([F:QUE]) : Local File QUEUE [QUE] : Endif
      Read [QUE]QUE0=VALEUR
      If fstat Then
        VALEUR = ""
        [M:SRE2]SREDETCLA = VALEUR
      Else
        # FGR 23/09/2009 : X3SUIVI58037
        #[M:SRE2]SREDETCLA = [F:QUE]TTR
        Call LECTEXTRA([M:SRE2]SREDETCLA,"QUEUE","QUEDESAXX",[F:QUE]NUM,"") From ATEXTRA
      Endif
    When Default
  Endcase
  Affzo [M:SRE2]SREDETCLA
  GFCY = [M:SRE0]SALFCY
  Call GETDEV(GFCY) From DEVSUB
  #Met à jour la date de dernière affectation
  [M:SRE2]SREDATASS = date$
  [M:SRE2]SREHOUASS = left$(time$, 2) + mid$(time$, 4, 2)
  Affzo [M:SRE2]SREDATASS
  Affzo [M:SRE0]SALFCY
Return

##########################################################################################################
$CODE_C_SREASS
Local  Integer IERRINF
Local  Integer ICHAPTER
Local  Integer IBRETOUR

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  #Vérification du lock superviseur
  Gosub VERFLOCKSUP From SUBSREB4
  If GERR Then
    Return
  Endif
  #Contrôle l'autorisation de clôture
  If VALEUR = 5 Then
    If GAUSHDKG <> 2 Then
      #Vous n'avez pas l'autorisation de clôturer une demande de service. Saisie refusée.
      GMESSAGE = mess(28,177,1)
      GERR = 2
      mkstat = 2
      Return
    Endif
  Endif

Local Integer ITERSRE9
Local Integer IERR
Local Integer IINVFLG
Local Integer IREP
Local Integer ISTOOK

  IREP = 0
  IINVFLG = 0
  IERR = 0
  ISTOOK = 1
  #Contrôle que toutes les sorties de stock prévuées ont été réalisées.
 If VALEUR = 5 Then
    For ITERSRE9 = 0 To [M:SRE9]NBLIG-1
      If [M:SRE9]HDTTYP(ITERSRE9) = 2 Then
        If [M:SRE9]HDTSTOISS(ITERSRE9) = 2 Then
          If [M:SRE9]HDTDONDAT(ITERSRE9) = [00/00/00] Then
            ISTOOK = 0
            Break
          Else
            If [M:SRE9]HDTISSISS(ITERSRE9) < [M:SRE9]HDTISSQTY(ITERSRE9) Then
              ISTOOK = 0
              Break
            Endif
          Endif
        Endif
     Endif
   Next
   If !ISTOOK Then
      #Des sorties de stock n'ont pas été enregistrées. Clôture refusée.
      GMESSAGE = mess(527,182,1)
      GERR = 1
      mkstat = 2
      Return
    Endif
  Endif
  #Contrôle que la demande n'a pas déjà été facturée.
  If VALEUR <> 5 and [M:SRE2]SREINVFLG = 3 Then
    #La demande de service a été facturée. Elle ne peut pas être réactivée. Action refusée.
    GMESSAGE = mess(309,182,1)
    GERR = 1
    mkstat = 2
    Return
  Endif
  #La demande est réactivée
  #On supprime HDI
  #If [M:SRE2]SREASS = 5 and [M:SRE2]SREINVFLG <> 3                            # FGR 22/03/2016 : X3SUIVI114779
  If VALEUR <> 5 and [M:SRE2]SREASS = 5 and [M:SRE2]SREINVFLG <> 3 Then        # FGR 22/03/2016 : X3SUIVI114779
    IINVFLG = 1
    For ITERSRE9 = 0 To [M:SRE9]NBLIG-1
      If [M:SRE9]HDTINV(ITERSRE9) = 2 Then
        IINVFLG = 2
        Break
      Endif
    Next
    If IINVFLG = 2 Then
      If [M:SRE0]SRENUM <> "" Then
        If GCLOINV = 2 Then
          #Confirmez-vous la réactivation de la demande ?
          #La demande de service ne sera plus facturable jusqu'à une nouvelle clôture.
          IREP = 0
          Call OUINON(mess(310,182,1), IREP) From GESECRAN
          If IREP = 2 Then
            [M:SRE2]SREINVFLG = 2
            IERR = 0
            Call DELHDI([M:SRE0]SRENUM, IERRINF,ICHAPTER,IBRETOUR) From SUBSREB2
            If IBRETOUR = 0 Then
              GMESSAGE = mess(IERRINF,ICHAPTER,1)
              GERR = 1
              mkstat = 2
              Return
            Endif
          Else
            #La réactivation de la demande a été abandonnée.
            GMESSAGE = mess(187,177,1)
            GERR = 1
            mkstat = 2
            Return
          Endif
        Else
          [M:SRE2]SREINVFLG = 1
        Endif
      Endif
    Endif
    #LSE 01/03/2005 gestion des sites
    #Actzo [M:SRE9]5
    If [M:SRE0]SREBPC = "" or [M:SRE0]SALFCY = "" or [M:SRE8]STOFCY = "" Then
      Grizo [M:SRE9]5
    Else
      Actzo [M:SRE9]5
    Endif
  Endif
  #Evite l'affichage du message "Vous modifiez une demande de service clôturée"
  #lorsqu'on rentre en modification sur le champs Affectation
  If GREP = "" Then
    [M:SRE0]SREASSDFLG = 1
  Endif
Return

##########################################################################################################
$CODE_C_SREPBLGRP
  #Vérification du lock superviseur
  Gosub VERFLOCKSUP From SUBSREB4
  If GERR Then
    Return
  Endif
  #La modification de la compétence fait rentrer en modification
  #On anticipe donc le contrôle de verrouillage de la demande effectué en principe dans l'AVANT_MOD
  If GREP = "" Then
    Local Integer OK

    OK = 1
    [M:SRE0]PREUPDFLG = 0
    Gosub AVANT_MOD From SUBSREA
    [M:SRE0]PREUPDFLG = 1
    If OK = 0 Then
      mkstat = 2
      Return
    Endif
  Endif

Local Char SZPBLCLA(50)
Local Integer IASKREP
Local Integer ITER
Local Integer INEEDASK
Local Char SZMESS(250)

  IASKREP = 0
  INEEDASK = 0
  SZPBLCLA = ""
  #On vérifie la saisie
  Gosub CTLSHORTCUT From SUBPBLB
  #LSE 17/02/2005 Fiche 26947
  If GERR Then
    Return
  Else
    If VALEUR <> "" Then
      If [F:PBL]PBLBPC <> "" Then
        If [M:SRE0]SREBPC <> "" Then
          If [M:SRE0]SREBPC <> [F:PBL]PBLBPC Then
            #Cette famille de compétence n'est normalement pas disponible pour ce client. CONFIRMEZ-VOUS L'utilisation de cette famille?
            SZMESS = mess(198,177,1)
            Call OUINON(SZMESS, IASKREP) From GESECRAN
            If IASKREP = 1 Then
              VALEUR = ""
              [M:SRE7]SREPBLGRP = VALEUR
              Affzo [M:SRE7]SREPBLGRP
              mkstat = 2
              Return
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  #Confirmez-vous la mise à jour de la famille de compétence sur chaque ligne du tableau du parc concerné ?
  SZMESS = mess(231,182,1)
  If VALEUR <> "" Then
    If [M:SRE7]NBMAC > 0 Then
      For ITER = 0 To [M:SRE7]NBMAC-1
        If [M:SRE7]PBL(ITER) <> VALEUR Then
          INEEDASK = 1
          Break
        Endif
      Next
    Endif
  Endif
  If INEEDASK Then
    Call OUINON(SZMESS, IASKREP) From GESECRAN
    If IASKREP = 2 Then
      If VALEUR = "" Then
        SZPBLCLA = ""
      Else
        Read [PBL]PBL0=VALEUR
        If fstat Then
          SZPBLCLA = ""
        Else
          # FGR 23/09/2009 : X3SUIVI58024
          #SZPBLCLA = [F:PBL]GRPPBLDES
          Call LECTEXTRA(SZPBLCLA,"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
        Endif
      Endif
      For ITER = 0 To [M:SRE7]NBMAC-1
        [M:SRE7]PBL(ITER) = VALEUR
        [M:SRE7]PBLCLA(ITER) = SZPBLCLA
      Next
    Else
      mkstat = 2
    Endif
  Endif
Return

##########################################################################################################
$CODE_AM_SREPBLGRP
Local Integer ITER
Local Integer IERRINF
Local Decimal IPITHDT     # FGR 02/02/2010 : X3SUIVI62146 : Pas Integer
Local Decimal IINVPITFLG  # FGR 02/02/2010 : X3SUIVI62146 : Pour le moment tout doit être decimal

  IERRINF = 0
  #Contrôle de la couverture de la demande
  [M:SRE7]SREPBLGRP = VALEUR
  If [M:SRE0]SREBPC = "" Then
    GMESSAGE = mess(403,196,1) #Le nom du client doit être indiqué pour contrôler la prise en charge de la demande.
    GERR = 2
  Else
    #-------------------------------------------------------
    # Contrôle de la couverture
    #-------------------------------------------------------
    Call RAZCOVMEE(6) From TRTCOVER
    Call RAZCOVMEE(10) From TRTCOVER
    Call COVERM From TRTCOVER
  Endif
  #Recherche du collaborateur compétent le moins occupé
  Gosub ASSIGNSRE From SUBSREB2
  #Recalcul des montants facturables et des points débités des consommations saisies
  For ITER = 0 To [M:SRE9]NBLIG-1
    If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
      # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
      Call AMOUNT(1, "SRE9", ITER, [M:SRE9]HDTAMT(ITER), [M:SRE9]HDTINV(ITER), [M:SRE9]HDTAMTINV(ITER), [M:SRE9]PITHDT(ITER), [M:SRE9]INVPITFLG(ITER), IERRINF) From TRTAMOUNT
    Else
      IPITHDT = 0
      IINVPITFLG = 0
      Call AMOUNT(1, "SRE9", ITER, [M:SRE9]HDTAMT(ITER), [M:SRE9]HDTINV(ITER), [M:SRE9]HDTAMTINV(ITER), IPITHDT, IINVPITFLG, IERRINF) From TRTAMOUNT
    Endif
    If IERRINF Then
      GMESSAGE = mess(IERRINF,182,1)
      GERR = 1
      Break
    Endif
  Next
  If [M:SRE9]NBLIG > 0 Then
    If !GERR Then
      Call LOADTOTHDT(0) From SUBSREB1
      Call LOADTOTPIT(0) From SUBSREB1
      #Les montants à facturer des consommations et les débits de points complémentaires ont été recalculés.
      GMESSAGE = mess(553,182,1)
      GERR = 2
    Endif
  Endif
  #Affichage de la dénomination de la famille de compétence
  If [M:SRE7]SREPBLGRP = "" Then
    [M:SRE7]SREPBLCLA = ""
  Else
    Read [PBL]PBL0=[M:SRE7]SREPBLGRP
    If fstat Then
      [M:SRE7]SREPBLCLA = ""
    Else
      # FGR 23/09/2009 : X3SUIVI58024
      #[M:SRE7]SREPBLCLA = [F:PBL]GRPPBLDES
      Call LECTEXTRA([M:SRE7]SREPBLCLA,"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
    Endif
  Endif
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE2]1-99
  Affzo [M:SRE7]1-99
  Affzo [M:SRE9]1-99
Return

##########################################################################################################
$CODE_C_NBCPN
  If nolign >= dim([M:SRE7]MAC) Then
    Return
  Endif
  If status = 68 or status = 83 or status = 65 Then
    #Vérification du lock superviseur
    Gosub VERFLOCKSUP From SUBSREB4
    If GERR Then
      Return
    Endif
    If GREP = "" Then
      #Si la demande est lockée, on ne vas pas plus loin
      Gosub AVMCTLLOCKSRE From SUBSREA
      If !IUPDSRE Then
        mkstat = 2
        Return
      Endif
    Endif

    Local Integer ITERHDTFORMAC
    Local Integer ITERINOL
    Local Integer ITERINOL2
    Local Integer ITERINOL3
    Local Integer IDELCONTROL

    ITERINOL = 0
    ITERINOL2 = 0
    ITERINOL3 = 0
    IDELCONTROL = 0
    If status = 65 Then
      For ITERHDTFORMAC = 0 To [M:SRE9]NBLIG-1
        If [M:SRE9]HDTMACSRE(ITERHDTFORMAC) = [M:SRE7]MAC([M:SRE7]PRESRE7NOL) Then
          If [M:SRE9]HDTCPN(ITERHDTFORMAC) = [M:SRE7]CPNITM(nolign-1) Then
            If [M:SRE9]HDTISSISS(ITERHDTFORMAC) > 0 Then
              #Des consommations comportant des sorties de stock sont enregistrées pour le composant sélectionné. Suppression impossible.
              GMESSAGE = mess(173,177,1)
              GERR = 2
              IDELCONTROL = 1
              mkstat = 2
              If GREP = "" Then
                #On déverrouille la demande
                Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
              Endif
              Break
            Endif
            If GSRE9HDTISSISS(ITERHDTFORMAC) > 0 Then
              #Des consommations comportant des sorties de stock sont enregistrées pour le composant sélectionné. Suppression impossible.
              GMESSAGE = mess(173,177,1)
              GERR = 2
              IDELCONTROL = 1
              mkstat = 2
              If GREP = "" Then
                #On déverrouille la demande
                Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
              Endif
              Break
            Endif
          Endif
        Endif
      Next
      If IDELCONTROL Then
        Return
      Endif
    Else
      ITERINOL = nolign-1
      ITERINOL2 = nolign1 - 1
      For ITERINOL3 = ITERINOL To ITERINOL2
        For ITERHDTFORMAC = 0 To [M:SRE9]NBLIG-1
          If [M:SRE9]HDTMACSRE(ITERHDTFORMAC) = [M:SRE7]MAC([M:SRE7]PRESRE7NOL) Then
            If [M:SRE9]HDTCPN(ITERHDTFORMAC) = [M:SRE7]CPNITM(ITERINOL3) Then
              If [M:SRE9]HDTISSISS(ITERHDTFORMAC) > 0 Then
                #Des consommations comportant des sorties de stock sont enregistrées pour le composant sélectionné. Suppression impossible.
                GMESSAGE = mess(173,177,1)
                GERR = 2
                IDELCONTROL = 1
                mkstat = 2
                If GREP = "" Then
                  #On déverrouille la demande
                  Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
                Endif
                Return
              Endif
              If GSRE9HDTISSISS(ITERHDTFORMAC) > 0 Then
                #Des consommations comportant des sorties de stock sont enregistrées pour le composant sélectionné. Suppression impossible.
                GMESSAGE = mess(173,177,1)
                GERR = 2
                IDELCONTROL = 1
                mkstat = 2
                If GREP = "" Then
                  #On déverrouille la demande
                  Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
                Endif
                Return
              Endif
            Endif
          Endif
        Next
        If IDELCONTROL Then
          Break
        Endif
      Next
      If IDELCONTROL Then
        Return
      Endif
    Endif

    Local Integer IMESSREP

    IMESSREP = 0
    #Confirmez-vous la suppression des composants sélectionnés ? Cette action ne peut pas être abandonnée.
    Call OUINON(mess(9,177,1), IMESSREP) From GESECRAN
    If IMESSREP <> 2 Then
      #La suppression des composants est abandonnée.
      GMESSAGE = mess(10,177,1)
      GERR = 2
      mkstat = 2
      If GREP = "" Then
        #On déverrouille la demande
        Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
      Endif
      Return
    Endif
  Endif

Local Integer INOL
Local Integer INOL2

  If status = 65 Then
    #Effacement d'une seule ligne
    INOL = nolign-1
    INOL2 = nolign-1
    Gosub DELCPNLINES From SUBSREB4
    If GERR Then
      If GREP = "" Then
        #On déverrouille la demande
        Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
      Endif
      Return
    Endif
    Global Char GSRE7NBCPN(10)         # FGR 01/09/2016 : X3SUIVI117427
    Call COVERM From TRTCOVER
    Call LOADTOTHDT(1) From SUBSREB1
    Call LOADTOTPIT(1) From SUBSREB1
    If GREP = "" Then
      #On déverrouille la demande
      Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
    Endif
    #LSE 01/07/2005 pour ne pas rendre valides tous les champs
    Affzo [M:SRE7]1-99
    Affzo [M:SRE9]1-99
  Elsif status = 68 or status = 83 Then
    #Effacement d'un groupe de lignes
    INOL = nolign-1
    INOL2 = nolign1-1
    Gosub DELCPNLINES From SUBSREB4
    If GERR Then
      If GREP = "" Then
        #On déverrouille la demande
        Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
      Endif
      Return
    Endif
    Global Char GSRE7NBCPN(10)         # FGR 01/09/2016 : X3SUIVI117427
    Call COVERM From TRTCOVER
    Call LOADTOTHDT(1) From SUBSREB1
    Call LOADTOTPIT(1) From SUBSREB1
    If GREP = "" Then
      #On déverrouille la demande
      Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
    Endif
    #LSE 01/07/2005 pour ne pas rendre valides tous les champs
    Affzo [M:SRE9]1-99
    Affzo [M:SRE7]1-99
  Endif
Return

##########################################################################################################
$CODE_C_CPNITM
Local Integer I
Local Integer ITER
Local Integer IERR
Local Integer IDELLINES
Local Integer ICANDO
Local Char SZMESS(250)
Local Integer IMESSREP

  IERR = 0
  IDELLINES = 0
  IMESSREP = 0
  SEMESS = ""
  ICANDO = 0
  If [M:SRE7]MAC([M:SRE7]PRESRE7NOL) = "" Then
    #Une fiche parc doit impérativement être sélectionnée avant de procéder à la saisie d'un composant.
    GMESSAGE = mess(288,182,1)
    GERR = 1
    mkstat = 2
    Return
  Endif
  If VALEUR = "" Then
    #Valeur incorrecte
    GMESSAGE = mess(83,123,1)
    GERR = 1
    mkstat = 2
    Return
  Else
    Read [ITM]ITM0=VALEUR
    If fstat Then
      #Valeur incorrecte
      GMESSAGE = mess(83,123,1)
      GERR = 1
      mkstat = 2
      Return
    Endif
  Endif
  #Vérifie si un code identique n'a pas déjà été préalablement saisi dans ce tableau
  For I = 0 To dim ([M:SRE7]CPNITM)-1
    If I <> nolign-1 Then
      If [M:SRE7]CPNITM(I) = VALEUR Then
        GMESSAGE = mess(268,182,1) - num$(I+1)   #Ce composant a déjà été saisi en ligne n°
        GERR = 1
        mkstat = 2
        Break
      Endif
    Endif
  Next
  If GERR Then
    Return
  Endif
  #Suppression des lignes de consommation associées
  If [M:SRE7]CPNITM(nolign-1) <> "" Then
    If [M:SRE7]CPNITM(nolign-1) <> VALEUR Then
      ICANDO = 0
      For ITER = 0 To [M:SRE9]NBLIG-1
        If [M:SRE9]HDTMACSRE(ITER) = [M:SRE7]MAC([M:SRE7]PRESRE7NOL) Then
          If [M:SRE9]HDTCPN(ITER) = [M:SRE7]CPNITM(nolign-1) Then
            ICANDO = 1
            Break
          Endif
        Endif
      Next
      If ICANDO Then
        #Souhaitez-vous supprimer les lignes de consommations associées au composant indiqué précédemment ?
        SZMESS = mess(559,182,1)
        Call OUINON(SZMESS, IMESSREP) From GESECRAN
        If IMESSREP = 2 Then
          ITER = 0
          IERR = 0
          While 1
            If ITER >= dim([M:SRE9]HDTMACSRE) Then
              Break
            Endif
            If [M:SRE9]HDTMACSRE(ITER) = [M:SRE7]MAC([M:SRE7]PRESRE7NOL) Then
              If [M:SRE9]HDTCPN(ITER) = [M:SRE7]CPNITM(nolign-1) Then
                Call DELSTOSORW(ITER, ITER, "SRE9", [M:SRE9]HDTSTOFCY(ITER), IERR) From STKSOR
                If IERR Then
                  Break
                Endif
                #Suppression des débits de points complémentaires
                Call DELPIT("SRE9", ITER, IERR) From TRTAMOUNT
                If IERR Then
                  Break
                Endif
                Dela ITER, 1 [M:SRE9]NBLIG
                IDELLINES += 1
              Else
                ITER += 1
              Endif
            Else
              ITER += 1
            Endif
          Wend
          If IERR Then
            #Erreur lors de suppression des lignes de consommations associées.
            GMESSAGE = mess(537,182,1)
            GERR = 1
            mkstat = 2
            Return
          Endif
          [M:SRE9]NBLIG -= IDELLINES
        Else
          For ITER = 0 To [M:SRE9]NBLIG-1
            If [M:SRE9]HDTMACSRE(ITER) = [M:SRE7]MAC([M:SRE7]PRESRE7NOL) Then
              If [M:SRE9]HDTCPN(ITER) = [M:SRE7]CPNITM(nolign-1) Then
                [M:SRE9]HDTCPN(ITER) = VALEUR
              Endif
            Endif
          Next
          [M:SRE7]CPNCKKHDT(nolign-1) = 1
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$CODE_AM_OVRCOV
Local Integer IERRINF
Local Integer IAFFSRE9
Local Integer IAFFSRE7
Local Integer ITERMAC
Local Integer ITERHDT
Local Integer ITPYFLG
Local Char SZSRENUM(GLONVCR)
Local Decimal IPITHDT     # FGR 02/02/2010 : X3SUIVI62146 : Pas Integer
Local Decimal IINVPITFLG  # FGR 02/02/2010 : X3SUIVI62146 : Pour le moment tout doit être decimal

  ITERMAC = 0
  ITERHDT = 0
  IAFFSRE9 = 0
  IAFFSRE7 = 0
  IERRINF = 0
  If GREP = "C" Then
    SZSRENUM = [M:SRE0]CRESEQ
    ITPYFLG = 1
  Elsif GREP = "D" Then
    SZSRENUM = [M:SRE0]CRESEQ
    ITPYFLG = 1
  Else
    SZSRENUM = [M:SRE0]SRENUM
    ITPYFLG = 0
  Endif
  If VALEUR = 1 or VALEUR = 2 Then
    #Pour couvrir une demande manuellement, il faut sélectionner l'une des quatre dernières options de la liste proposée.
    GMESSAGE = mess(303,182,1)
    GERR = 1
    VALEUR = [M:SRE2]OVRCOV
    [M:SRE2]OVRCOV = VALEUR
    Affzo [M:SRE2]OVRCOV
    Return
  Endif
  If VALEUR = 3 Then
    #Couverture refusée manuellement
    [M:SRE2]OVRCOVCLA = mess(9,178,1)
    [M:SRE2]OVRCOVREN = 9
  Else
    [M:SRE2]OVRCOVCLA = ""
    [M:SRE2]OVRCOVREN = 0
  Endif
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE2]1-99
  #Mise à jour des couvertures parc et des montants facturables
  [M:SRE2]SRECOVNUM = ""
  [M:SRE2]SRECOVAUT = 0
  [M:SRE2]OVRCOV = VALEUR
  #Suppression des consommations de points
  Call DELPITCOV(GREP, 0, 0, IERRINF) From TRTCOVER
  If IERRINF Then
    GMESSAGE = mess(IERRINF,182,1)
    GERR = 1
    Return
  Endif
  #Couverture parc
  If [M:SRE7]NBMAC > 0 Then
    IAFFSRE7 = 1
    Call DEBTRANS From GLOCK
    Trbegin [SRN]
    For ITERMAC = 0 To [M:SRE7]NBMAC-1
      If VALEUR = 3 Then
        #Non couverte manuellement
        [M:SRE7]COVFLG(ITERMAC) = 3
        [M:SRE7]COVSPT(ITERMAC) = 6
        [M:SRE7]COVVCR(ITERMAC) = ""
      Elsif VALEUR = 4 Then
        #Couverte par contrat de service.
        [M:SRE7]COVFLG(ITERMAC) = 1
        [M:SRE7]COVSPT(ITERMAC) = 1
        [M:SRE7]COVVCR(ITERMAC) = ""
      Elsif VALEUR = 5 Then
        #Couverte par commande de vente
        [M:SRE7]COVFLG(ITERMAC) = 1
        [M:SRE7]COVSPT(ITERMAC) = 2
        [M:SRE7]COVVCR(ITERMAC) = ""
      Elsif VALEUR = 6 Then
        #Couverte commercialement
        [M:SRE7]COVFLG(ITERMAC) = 1
        [M:SRE7]COVSPT(ITERMAC) = 3
        [M:SRE7]COVVCR(ITERMAC) = ""
      Elsif VALEUR = 7 Then
        #Couverte par facturation directe
        [M:SRE7]COVFLG(ITERMAC) = 1
        [M:SRE7]COVSPT(ITERMAC) = 4
        [M:SRE7]COVVCR(ITERMAC) = ""
      Endif
      #Mise à jour de la couverture sur les composants
      Filter [SRN] Where [F:SRN]SRENUM = SZSRENUM and [F:SRN]MACNUM = [M:SRE7]MAC(ITERMAC) and [F:SRN]TPYFLG = ITPYFLG and [F:SRN]FGVCAH = 0
      For [SRN]
        If VALEUR = 3 Then
          #Non couverte manuellement
          [F:SRN]CPNCOVFLG = 3
          [F:SRN]CPNCOVSPT = 6
          [F:SRN]CPNCOVVCR = ""
        Elsif VALEUR = 4 Then
          #Couverte par contrat de service.
          [F:SRN]CPNCOVFLG = 1
          [F:SRN]CPNCOVSPT = 1
          [F:SRN]CPNCOVVCR = ""
        Elsif VALEUR = 5 Then
          #Couverte par commande de vente
          [F:SRN]CPNCOVFLG = 1
          [F:SRN]CPNCOVSPT = 2
          [F:SRN]CPNCOVVCR = ""
        Elsif VALEUR = 6 Then
          #Couverte commercialement
          [F:SRN]CPNCOVFLG = 1
          [F:SRN]CPNCOVSPT = 3
          [F:SRN]CPNCOVVCR = ""
        Elsif VALEUR = 7 Then
          #Couverte par facturation directe
          [F:SRN]CPNCOVFLG = 1
          [F:SRN]CPNCOVSPT = 4
          [F:SRN]CPNCOVVCR = ""
        Endif
        Rewrite [SRN]
        If fstat Then
          #Erreur lors de la mise à jour de la couverture sur les composants concernés.
          GMESSAGE = mess(565,182,1)
          GERR = 1
          Break
        Endif
      Next
      Filter [SRN]
      If GERR Then
        Break
      Endif
    Next
    If GERR Then
      Rollback
    Else
      Commit
    Endif
  Endif
  If GERR Then
    Return
  Endif
  #Mise à jour des montants facturables
  If [M:SRE9]NBLIG > 0 Then
    For ITERHDT = 0 To [M:SRE9]NBLIG-1
      IAFFSRE9 = 1
      [M:SRE9]MANAMTFLG(ITERHDT) = 1
      If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
        # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
        Call AMOUNT(1, "SRE9", ITERHDT, [M:SRE9]HDTAMT(ITERHDT), [M:SRE9]HDTINV(ITERHDT), [M:SRE9]HDTAMTINV(ITERHDT), [M:SRE9]PITHDT(ITERHDT), [M:SRE9]INVPITFLG(ITERHDT), IERRINF) From TRTAMOUNT
      Else
        IPITHDT = 0
        IINVPITFLG = 0
        Call AMOUNT(1, "SRE9", ITERHDT, [M:SRE9]HDTAMT(ITERHDT), [M:SRE9]HDTINV(ITERHDT), [M:SRE9]HDTAMTINV(ITERHDT), IPITHDT, IINVPITFLG, IERRINF) From TRTAMOUNT
      Endif
      If IERRINF Then
        GMESSAGE = mess(IERRINF,182,1)
        GERR = 1
        Break
      Endif
    Next
  Endif
  If GERR Then
    Return
  Endif
  If IAFFSRE7 Then
    If GREP = "C" Then
      Call LOADCPN([M:SRE0]CRESEQ, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), 1) From SUBSREB1
    Elsif GREP = "D" Then
      Call LOADCPN([M:SRE0]CRESEQ, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), 1) From SUBSREB1
    Else
      Call LOADCPN([M:SRE0]SRENUM, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), 0) From SUBSREB1
    Endif
    #LSE 01/07/2005 pour ne pas rendre valides tous les champs
    Affzo [M:SRE7]1-99
  Endif
  If IAFFSRE9 Then
    Call LOADTOTHDT(0) From SUBSREB1
    Call LOADTOTPIT(0) From SUBSREB1
    #LSE 01/07/2005 pour ne pas rendre valides tous les champs
    Affzo [M:SRE9]1-99
  Endif
Return

##########################################################################################################
$CODE_C_OVRCOV
  #Vérification du lock superviseur
  Gosub VERFLOCKSUP From SUBSREB4
  If GERR Then
    Return
  Endif
  #La modification de la couverture globale fait rentrer en modification
  #On anticipe donc le contrôle de verrouillage de la demande effectué en principe dans l'AVANT_MOD
  If GREP = "" Then
    Local Integer OK

    OK = 1
    [M:SRE0]PREUPDFLG = 0
    Gosub AVANT_MOD From SUBSREA
    [M:SRE0]PREUPDFLG = 1
    If OK = 0 Then
      mkstat = 2
      Return
    Endif
  Endif

Local Integer IMESSREP

  IMESSREP = 0
  If [M:SRE2]OVRCOV <> VALEUR Then
    If [M:SRE7]NBMAC > 0 Then
      If [M:SRE9]NBLIG > 0 Then
        #Confirmez-vous le recalcul de toutes les couvertures du parc ainsi
        # que le recalcul du montant facturable des consommations ?
        Call OUINON(mess(560,182,1), IMESSREP) From GESECRAN
        If IMESSREP <> 2 Then
          #La modification de la couverture globale est abandonnée.
          GMESSAGE = mess(561,182,1)
          GERR = 2
          mkstat = 2
          Return
        Endif
      Else
        If [M:SRE7]NBMAC > 1 Then
          #Confirmez-vous le recalcul de toutes les couvertures du parc ?
          Call OUINON(mess(562,182,1), IMESSREP) From GESECRAN
          If IMESSREP <> 2 Then
            #La modification de la couverture globale est abandonnée.
            GMESSAGE = mess(561,182,1)
            GERR = 2
            mkstat = 2
            Return
          Endif
        Endif
      Endif
    Else
      If [M:SRE9]NBLIG > 0 Then
        If [M:SRE9]NBLIG > 1 Then
          #Confirmez-vous le recalcul du montant facturable des consommations ?
          Call OUINON(mess(563,182,1), IMESSREP) From GESECRAN
          If IMESSREP <> 2 Then
            #La modification de la couverture globale est abandonnée.
            GMESSAGE = mess(561,182,1)
            GERR = 2
            mkstat = 2
            Return
          Endif
        Else
          #Confirmez-vous le recalcul du montant facturable de la consommation ?
          Call OUINON(mess(564,182,1), IMESSREP) From GESECRAN
          If IMESSREP <> 2 Then
            #La modification de la couverture globale est abandonnée.
            GMESSAGE = mess(561,182,1)
            GERR = 2
            mkstat = 2
            Return
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$CODE_B2_SREDOO
  If VALEUR = "" Then
    Readlock [DVA]DVA0="SRE";GUSER
    If fstat = 0 Then
      Call DEBTRANS From GLOCK
      Trbegin [DVA]
      Delete [DVA] Curr
      If fstat Then
        Rollback
        Return
      Else
        Commit
      Endif
    Endif
    Return
  Endif
  #Enregistre le donneur d'ordre comme le donneur d'ordre par défaut pour cet utilisateur.
  Call DEBTRANS From GLOCK
  Trbegin [DVA]
  Readlock [DVA]DVA0="SRE";GUSER
  If fstat = 5 Then
    #Enregistrement non trouvé, il faut le créer
    [F:DVA]OBC = "SRE"
    [F:DVA]PARAM = GUSER
    [F:DVA]ALHX(0) = VALEUR
    Write [DVA]
    If fstat Then
      GMESSAGE = mess(100,141,1) #Erreur création
      GERR = 1
      Unlock [DVA]
      Rollback
      Return
    Endif
  Elsif fstat = 0 Then
    #Enregistrement trouvé, il faut le réécrire pour préserver les éventuelles modifs.
    [F:DVA]OBC = "SRE"
    [F:DVA]PARAM = GUSER
    [F:DVA]ALHX(0) = VALEUR
    Rewrite [DVA]
    If fstat Then
      GMESSAGE = mess(101,141,1) #Erreur modification
      GERR = 1
      Unlock [DVA]
      Rollback
      Return
    Endif
  Endif
  Commit
Return

##########################################################################################################
$CODE_AM_SREBPC
Local Integer IBNEWBPR

  IBNEWBPR=0
  If [M:SRE0]SREBPC <> VALEUR Then
    IBNEWBPR = 1
  Endif
  [M:SRE0]SREBPC = VALEUR
  #Nettoyage des écrans
  #[M:SRE0]SRENUMBPC = ""  # FGR 15/04/2013 : X3SUIVI89288 ne pas effacer ce champ est avant !
  Call RAZMAC From SUBSREB2
  Raz [M:SRE9]
  Raz [M:SRE2]CONSPT
  Raz [M:SRE2]CONSPTCLA
  Raz [M:SRE2]CONSPTFLG
  Raz [M:SRE2]CONSPTTYP
  #Obtient le niveau de réactivité SAV.
  Call SETRESDAT([M:SRE1]CREDAT, [M:SRE1]CREHOU, [M:SRE2]CONSPT, [M:SRE2]CONSPTTYP, [M:SRE2]SREGRALEV, 0, [M:SRE2]SRERESDAT, [M:SRE2]SRERESHOU) From TRTCOVER
  #Définition du chrono client
  If [M:SRE0]SREBPC <> "" Then
    If GSRENUMAUT = 2 Then
      Gosub SUBB1_SRENUMBPC From SUBSREB3
    Endif
  Endif
  #-------------------------------------------------------
  #Affiche le nom en clair du client avec son site
  #-------------------------------------------------------
  [M:SRE0]SRECCN = ""
  [M:SRE0]SRECCNCLA = ""
  [M:SRE0]SREBPAADD = ""
  If [M:SRE0]SREBPC = "" Then
    [M:SRE0]SREBPCCLA = ""
    [M:SRE0]SREBPAADD = ""
  Else
    #Définit l'interlocuteur par défaut de la demande
    Call GETDEFCNT([M:SRE0]SREBPC, [M:SRE0]SRECCN) From CRMUTIL140
    Read [BPR]BPR0=[M:SRE0]SREBPC
    If fstat Then
      [M:SRE0]SREBPCCLA = [M:SRE0]SREBPC
    Else
      [M:SRE0]SREBPCCLA = [F:BPR]BPRNAM
    Endif
    If [M:SRE0]SRECCN <> "" Then
      Read [AIN]AIN0=[M:SRE0]SRECCN
      If fstat Then
        [M:SRE0]SRECCNCLA = [M:SRE0]SRECCN
      Else
        Call BUILDFULNAM("AIN", [M:SRE0]SRECCNCLA) From CRMUTIL140
      Endif
    Endif
  Endif
  #-------------------------------------------------------
  #Détection d'un nouveau donneur d'ordre
  #-------------------------------------------------------
  Gosub CHECKDOO From SUBSREB2
  #-------------------------------------------------------
  #Définition des informations de facturation
  #-------------------------------------------------------
  # FGR 16/04/2012 : X3SUIVI81400 (début)
  If [M:SRE0]SREDOO = "" Then
    Call SETINVINF([M:SRE0]SREBPC) From SUBSREB1
  Endif
  # FGR 16/04/2012 : X3SUIVI81400 (fin)
  #-------------------------------------------------------
  #Si on a un modèle de contrat et que l'on vient de renseigner le tiers, il faut le déclencher
  If IBNEWBPR = 1 Then
    Call LOADSETMAC (VALEUR, [M:SRE1]SRETPL) From SUBSREB5
  Endif
  #-------------------------------------------------------
  # Parc concerné
  #-------------------------------------------------------
  If [M:SRE0]SREBPC = "" Then
    Grizo [SRE7]10
    Grizo [SRE7]15
  Else
    Actzo [SRE7]10
    Actzo [SRE7]15
  Endif
  #-------------------------------------------------------
  #Gestion des consommations
  #-------------------------------------------------------
  If [M:SRE0]SREBPC = "" or [M:SRE0]SALFCY = "" or [M:SRE8]STOFCY = "" Then
    Grizo [M:SRE9]5
  Else
    Actzo [M:SRE9]5
  Endif
  #-------------------------------------------------------
  # Contrôle de la couverture
  #-------------------------------------------------------
  Call RAZCOVMEE(0) From TRTCOVER
  # FGR 04/04/2016 : X3SUIVI115618 (début) Dans ce cadre là les contrôles vont être refait à la saisie du parc client
  #Call COVERM From TRTCOVER
  If GNAVIG(GPILNAV-1) <> "GESMAC" Then
    Call COVERM From TRTCOVER
  Endif
  # FGR 04/04/2016 : X3SUIVI115618 (fin)
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE0]1-99
  Affzo [M:SRE2]1-99
  Affzo [M:SRE7]1-99
  Affzo [M:SRE8]1-99
  Affzo [M:SRE9]1-99
Return

##########################################################################################################
$CODE_AM_HDTITM
Local Integer IERRINF
Local Char SECTION(GLONCCE)
Local Integer INOL
Local Integer J
Local Decimal IPITHDT     # FGR 02/02/2010 : X3SUIVI62146 : Pas Integer
Local Decimal IINVPITFLG  # FGR 24/02/2010 : X3SUIVI62770 : Pour le moment tout doit être decimal

  INOL = nolign-1
  J = 0
  IERRINF = 0
  #On complète le parc concerné si besoin
  If [M:SRE9]HDTMACSRE(nolign-1) = "" Then
    Gosub ADDHDTMAC From SUBSREB4
  Endif
  [M:SRE9]HDTSTOFCY(nolign-1) = ""
  [M:SRE9]HDTSTOISS(nolign-1) = 1
  Read [ITM]ITM0=VALEUR
  If fstat Then
    [M:SRE9]HDTUOM(nolign-1) = ""
    [M:SRE9]HDTSTU(nolign-1) = ""
  Else
    [M:SRE9]HDTUOM(nolign-1) = [F:ITM]SAU
    [M:SRE9]HDTSTU(nolign-1) = [F:ITM]STU
    [M:SRE9]STOMGTCOD(nolign-1) = [F:ITM]STOMGTCOD
    If [M:SRE9]HDTTYP(nolign-1) = 2 Then
      If [M:SRE9]STOMGTCOD(nolign-1) > 1 Then
        [M:SRE9]HDTSTOFCY(nolign-1) = [M:SRE8]STOFCY
        If [F:ITM]STOISSDEF = 2 Then
          [M:SRE9]HDTSTOISS(nolign-1) = 2
        Endif
      Endif
    Endif
  Endif
  [M:SRE9]HDTISSQTY(nolign-1) = 0
  [M:SRE9]HDTQTY(nolign-1) = 0
  [M:SRE9]HDTAVA(nolign-1) = 0
  [M:SRE9]HDTAVAUOM(nolign-1) = ""
  If GCLOINV = 2 Then
    [M:SRE9]HDTINV(nolign-1) = 2
  Else
    [M:SRE9]HDTINV(nolign-1) = 1
  Endif
  [M:SRE9]HDTAMT(nolign-1) = 0
  [M:SRE9]HDTCUR(nolign-1) = [M:SRE8]SRECUR
  [M:SRE9]MANAMTFLG(nolign-1) = 1
  If [M:SRE9]HDTAUS(nolign-1) = "" Then
    [M:SRE9]HDTAUSTYP(nolign-1) = 1
    [M:SRE9]HDTAUS(nolign-1) = GUSER
    Read [AUS]CODUSR=GUSER
    If fstat Then
      [M:SRE9]HDTAUSCOD(nolign-1) = ""
    Else
      [M:SRE9]HDTAUSCOD(nolign-1) = [F:AUS]NOMUSR
    Endif
  Endif
  [M:SRE9]HDTITM(nolign-1) = VALEUR
  [M:SRE9]ITMREF(nolign-1) = [M:SRE9]HDTITM(nolign-1)
  # FGR 15/10/2010 : X3SUIVI67190 (début) c'est pas là
  #Sorties de stock
  #Call INIZONSOR("SRE9", [M:SRE9]HDTITM(nolign-1), [M:SRE9]HDTSTOFCY(nolign-1), INOL, 24, [M:SRE0]TRSCOD , "") From STKECR
  # FGR 15/10/2010 : X3SUIVI67190 (fin)
  #
  # FGR 22/11/2012 : X3SUIVI85908 (début)
  If dim(GSZSECHDT) >= 0 Then
    Kill GSZSECHDT    # Ne doit surtout pas exister ici
  Endif
  # FGR 22/11/2012 : X3SUIVI85908 (fin)
  For J = 1 To GNBDIE
    If evalue("[M:SRE9]CCE"+num$(J)+"(INOL)") = "" Then
      Call INISEC(SECTION,"HDT",J) From TRTX3CPT
      Assign "[M:SRE9]CCE"+num$(J)+"(INOL)" With SECTION
    Endif
  Next
  #Détermination du montant facturable par défaut
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    Call AMOUNT(1, "SRE9", nolign-1, [M:SRE9]HDTAMT(nolign-1), [M:SRE9]HDTINV(nolign-1), [M:SRE9]HDTAMTINV(nolign-1), [M:SRE9]PITHDT(nolign-1), [M:SRE9]INVPITFLG(nolign-1), IERRINF) From TRTAMOUNT
  Else
    IPITHDT = 0
    IINVPITFLG = 0
    Call AMOUNT(1, "SRE9", nolign-1, [M:SRE9]HDTAMT(nolign-1), [M:SRE9]HDTINV(nolign-1), [M:SRE9]HDTAMTINV(nolign-1), IPITHDT, IINVPITFLG, IERRINF) From TRTAMOUNT
  Endif
  If IERRINF Then
    GMESSAGE = mess(IERRINF,182,1)
    GERR = 1
  Endif
  Affzo [M:SRE9]HDTITM(nolign-1), HDTUOM(nolign-1), HDTQTY(nolign-1), HDTAVA(nolign-1), HDTAVAUOM(nolign-1)
  Affzo [M:SRE9]HDTAMT(nolign-1), HDTCUR(nolign-1), HDTAUSTYP(nolign-1), HDTAUS(nolign-1), HDTAUSCOD(nolign-1)
  # FGR 22/02/2010 : X3SUIVI62770
  #Affzo [M:SRE9]HDTSTOFCY(nolign-1), PITHDT(nolign-1), HDTAMTINV(nolign-1), HDTINV(nolign-1)
  Affzo [M:SRE9]HDTSTOFCY(nolign-1), HDTAMTINV(nolign-1), HDTINV(nolign-1)
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    Affzo [M:SRE9]PITHDT(nolign-1)
  Endif
  Affzo [M:SRE9]HDTMACSRE(nolign-1)
Return

##########################################################################################################
$CODE_IB_NBLIG
  #---------------------------------------------------#
  # Sortie de stock
  #---------------------------------------------------#
  Raz GBOUT1
  Raz GBOUT2
  Raz GBOUT4
  If [M:SRE9]NBLIG > 0 Then
    If [M:SRE9]HDTTYP(nolign-1) = 2 Then
      If [M:SRE9]HDTDONDAT(nolign-1) <> [00/00/00] Then
        If [M:SRE9]HDTSTOISS(nolign-1) = 2 Then
          If [M:SRE9]HDTISSQTY(nolign-1) > 0 Then
            If [M:SRE9]HDTISSISS(nolign-1) > 0 Then
              If GREP <> "C" and GREP <> "D" Then
                If GREP = "" Then
                  #Modification sorties
                  Call TEXTE(23367, GBOUT2) From OBJDIV
                Endif
              Endif
            Else
              #Sorties stock
              Call TEXTE(5435, GBOUT1) From OBJDIV
            Endif
            GOUVSOR = 1
          Endif
        Endif
      Endif
    Endif
  Endif
  If [M:SRE2]SREASS = 5 Then
    Raz GBOUT1
    Raz GBOUT2
  Endif
  #Texte
  Call TEXTE(4685, GBOUT3) From OBJDIV
  If [M:SRE9]HDTNUM(nolign-1) = "" Then
    If [M:SRE9]HDTNUMSEQ(nolign-1) = "" Then
      Raz GBOUT3
    Endif
  Endif
  #Tunnel vers intervention
  If [M:SRE2]SREASS <> 5 Then
    If [M:SRE9]NBLIG > 0 Then
      If GREP = "" Then
        If [M:SRE9]HDTITM(nolign-1) <> "" Then
          If [M:SRE0]SRENUM <> "" Then
            If [M:SRE0]SREBPC <> "" Then
              If [M:SRE9]ITNNUM(nolign-1) = "" Then
                If [M:SRE9]HDTDONDAT(nolign-1) = [00/00/00] Then
                  If [M:SRE9]HDTPLNDAT(nolign-1) = [00/00/00] Then
                    Call TEXTE(24290, GBOUT4) From OBJDIV  #Planifier la consommation
                    [M:SRE7]SRENAVTYP = "HDN"
                    [M:SRE0]CURITNNUM = ""
                    [M:SRE0]CURHDTNUMX = [M:SRE9]HDTNUM(nolign-1)
                    [M:SRE0]NVGCOD = "1"
                  Endif
                Endif
              Else
                Call TEXTE(24288, GBOUT4) From OBJDIV  #Visualiser l'intervention
                [M:SRE7]SRENAVTYP = "HDY"
                [M:SRE0]CURITNNUM = [M:SRE9]ITNNUM(nolign-1)
                [M:SRE0]CURHDTNUMX = ""
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$CODE_C_NBLIG
Local Integer INOL
Local Integer INOL2
Local Integer IERR
Local Integer NUMLIG
Local Integer IMESSREP

  If nolign >= dim([M:SRE9]HDTCPN) Then
    Return
  Endif
  [M:SRE0]DELSRE9FLG = 0
  #Effacement d'un groupe de lignes
  If status = 68 or status = 83 Then
    #L'annulation multiple de lignes n'est pas possible sur ce tableau.
    GMESSAGE = mess(15,177,1)
    GERR = 2
    mkstat = 2
    Return
  Endif
  If status = 68 or status = 83 or status = 65 Then
    #Vérification du lock superviseur
    Gosub VERFLOCKSUP From SUBSREB4
    If GERR Then
      Return
    Endif
    If GREP = "" Then
      #Si la demande est lockée, on ne vas pas plus loin
      Gosub AVMCTLLOCKSRE From SUBSREA
      If !IUPDSRE Then
        mkstat = 2
        Return
      Endif
    Endif
    # FGR 05/08/2010 : X3SUIVI66063 (début) : ça c'est pas bon
    #On vérifie que la consommation a supprimer ne comporte pas de sortie de stock
    #If [M:SRE9]HDTISSISS(nolign-1) > 0 Then
    #  #Des sorties de stock ont été réalisées pour cette consommation. Suppression impossible.
    #  GMESSAGE = mess(171,177,1)
    #  GERR = 2
    #  mkstat = 2
    #  If GREP = "" Then
    #    #On déverrouille la demande
    #    Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
    #  Endif
    #  Return
    #Endif
    #If GSRE9HDTISSISS(nolign-1) > 0 Then
    #  #Des sorties de stock ont été réalisées pour cette consommation. Suppression impossible.
    #  GMESSAGE = mess(171,177,1)
    #  GERR = 2
    #  mkstat = 2
    #  If GREP = "" Then
    #    #On déverrouille la demande
    #    Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
    #  Endif
    #  Return
    #Endif
    # FGR 05/08/2010 : X3SUIVI66063 (fin) : ça c'est pas bon
    # FGR 05/08/2010 : X3SUIVI66063 (début) : D'abord on controle qu'aucune sortie de stock n'est enregistrée
    If status = 65 Then
      INOL = nolign-1
      INOL2 = nolign-1
    Else
      INOL = nolign-1
      INOL2 = nolign1-1
    Endif
    For NUMLIG = INOL To INOL2
      If [M:SRE9]HDTSTOISS(NUMLIG) = 2 and [M:SRE9]SAVSTOISS(NUMLIG) = 2 Then
        If GMESSAGE = "" Then
          GMESSAGE = mess(651,177,1) - "("
        Endif
        GMESSAGE -= num$(NUMLIG+1)
        GERR = 2
      Endif
    Next NUMLIG
    If GERR = 2 Then
      GMESSAGE -= ")"
      mkstat = 2
      If GREP = "" Then
        #On déverrouille la demande
        Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
      Endif
      Return
    Endif
    # FGR 05/08/2010 : X3SUIVI66063 (fin)
    IMESSREP = 0
    #Confirmez-vous la suppression des consommations sélectionnées ? Cette action ne peut pas être abandonnée.
    Call OUINON(mess(11,177,1), IMESSREP) From GESECRAN
    If IMESSREP <> 2 Then
      #La suppression des consommations est abandonnée.
      GMESSAGE = mess(12,177,1)
      GERR = 2
      mkstat = 2
      If GREP = "" Then
        #On déverrouille la demande
        Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
      Endif
      Return
    Endif
  Endif
  #
  IERR = 0
  If status = 65 Then
    #Effacement d'une seule ligne
    If [M:SRE9]HDTSTOISS(INOL) = 2 and [M:SRE9]SAVSTOISS(INOL) <> 2 Then # 05/08/2010 : X3SUIVI66063 : Slt si sortie de stock non enregistrée
      # Sortie de stock
      Call DELSTOSORW(INOL, INOL2, "SRE9", [M:SRE9]HDTSTOFCY(nolign-1), IERR) From STKSOR
      If IERR Then
        mkstat = 2
        Return
      Endif
    Endif
    Gosub DELHDTLINES From SUBSREB4
    If GREP = "" Then
      #On déverrouille la demande
      Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
    Endif
    # FGR 28/04/2008 : X3SUIVI46593 : (DEBUT) puisqu'on supprime une ligne il faut aussi garder le parallele GSRE9DIRTYISSISS et GSRE9HDTISSISS
    If dim([M:SRE9]HDTISSQTY) > 1 Then
      For NUMLIG = INOL To [M:SRE9]NBLIG-1
        GSRE9DIRTYISSISS(NUMLIG) = GSRE9DIRTYISSISS (NUMLIG+1)
        GSRE9HDTISSISS(NUMLIG) = GSRE9HDTISSISS (NUMLIG+1)
      Next
    Endif
    # FGR 28/04/2008 : X3SUIVI46593 : (FIN) puisqu'on supprime une ligne il faut aussi garder le parallele GSRE9DIRTYISSISS et GSRE9HDTISSISS
  Elsif status = 68 or status = 83 Then
    #Effacement d'un groupe de lignes
    # FGR 05/08/2010 : X3SUIVI66063 (début) ça manque un peu. Je fais la boucle parce que le site est sur chaque ligne
    # Sortie de stock
    For NUMLIG = INOL To INOL2
      If [M:SRE9]HDTSTOISS(NUMLIG) = 2 and [M:SRE9]SAVSTOISS(NUMLIG) <> 2 Then
        # 05/08/2010 : X3SUIVI66063 : Slt si sortie de stock non enregistrée
        Call DELSTOSORW(NUMLIG, NUMLIG, "SRE9", [M:SRE9]HDTSTOFCY(NUMLIG), IERR) From STKSOR
        If IERR Then
          Break
        Endif
      Endif
    Next NUMLIG
    If IERR Then
      mkstat = 2
      Return
    Endif
    # FGR 05/08/2010 : X3SUIVI66063 (fin)
    Gosub DELHDTLINES From SUBSREB4
    If GREP = "" Then
      #On déverrouille la demande
      Call UNLOCKSRE([M:SRE0]SRENUM) From SUBITNB1
    Endif
  Endif
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE9]1-99
Return

##########################################################################################################
$CODE_APRES_NBMAC
Local Integer ITER
Local Integer IERRINF
Local Integer ICPTFLG
Local Integer ISAVENBMAC
Local Integer IADDNOL
Local Decimal IPITHDT     # FGR 02/02/2010 : X3SUIVI62146 : Pas Integer
Local Decimal IINVPITFLG  # FGR 24/02/2010 : X3SUIVI62770 : Pour le moment tout doit être decimal

  IERRINF = 0
  ICPTFLG = 0
  IADDNOL = 0
  If nolign > [M:SRE7]NBMAC Then
    IADDNOL = 1
  Endif
  ISAVENBMAC = 0
  If [M:SRE9]NBLIG > 0 Then
    #On vérifie si des lignes de consommations sans parc ont été saisies
    If [M:SRE7]MACDEF(nolign-1) = 2 Then
      If IADDNOL Then
        ISAVENBMAC = [M:SRE7]NBMAC
        [M:SRE7]NBMAC += 1
      Endif
      For ITER = 0 To [M:SRE9]NBLIG-1
        If [M:SRE9]HDTMACSRE(ITER) = "" Then
          [M:SRE9]HDTMACSRE(ITER) = [M:SRE7]MAC(nolign-1)
          #Détermination du montant facturable par défaut
          [M:SRE9]MANAMTFLG(ITER) = 1
          If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
            # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
            Call AMOUNT(1, "SRE9", ITER, [M:SRE9]HDTAMT(ITER), [M:SRE9]HDTINV(ITER), [M:SRE9]HDTAMTINV(ITER), [M:SRE9]PITHDT(ITER), [M:SRE9]INVPITFLG(ITER), IERRINF) From TRTAMOUNT
          Else
            IPITHDT = 0
            IINVPITFLG = 0
            Call AMOUNT(1, "SRE9", ITER, [M:SRE9]HDTAMT(ITER), [M:SRE9]HDTINV(ITER), [M:SRE9]HDTAMTINV(ITER), IPITHDT, IINVPITFLG, IERRINF) From TRTAMOUNT
          Endif
          If IERRINF Then
            GMESSAGE = mess(IERRINF,182,1)
            GERR = 1
            Break
          Endif
          ICPTFLG = 1
        Endif
      Next
      If GERR Then
        [M:SRE7]NBMAC = ISAVENBMAC
        [M:SRE7]CKKHDTAMT(nolign-1) = 0
        Return
      Endif
      If ICPTFLG Then
        Call LOADTOTHDT(0) From SUBSREB1
        Call LOADTOTPIT(0) From SUBSREB1
        #Les montants à facturer des consommations et les débits de points
        # des consommations sans parc concerné ont été recalculés.
        GMESSAGE = mess(556,182,1)
        GERR = 2
        #LSE 01/07/2005 pour ne pas rendre valides tous les champs
        Affzo [M:SRE9]1-99
      Endif
      If IADDNOL Then
        [M:SRE7]NBMAC = ISAVENBMAC
      Endif
    Endif
    #Recalcul des montants facturables suite à une modification du parc ou de la compétence sur la ligne.
    If [M:SRE7]CKKHDTAMT(nolign-1) Then
      If IADDNOL Then
        ISAVENBMAC = [M:SRE7]NBMAC
        [M:SRE7]NBMAC += 1
      Endif
      For ITER = 0 To [M:SRE9]NBLIG-1
        If [M:SRE9]HDTMACSRE(ITER) = [M:SRE7]MAC(nolign-1) Then
          #Détermination du montant facturable par défaut
          [M:SRE9]MANAMTFLG(ITER) = 1
          If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
            # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
            Call AMOUNT(1, "SRE9", ITER, [M:SRE9]HDTAMT(ITER), [M:SRE9]HDTINV(ITER), [M:SRE9]HDTAMTINV(ITER), [M:SRE9]PITHDT(ITER), [M:SRE9]INVPITFLG(ITER), IERRINF) From TRTAMOUNT
          Else
            IPITHDT = 0
            IINVPITFLG = 0
            Call AMOUNT(1, "SRE9", ITER, [M:SRE9]HDTAMT(ITER), [M:SRE9]HDTINV(ITER), [M:SRE9]HDTAMTINV(ITER), IPITHDT, IINVPITFLG, IERRINF) From TRTAMOUNT
          Endif
          If IERRINF Then
            GMESSAGE = mess(IERRINF,182,1)
            GERR = 1
            Break
          Endif
          ICPTFLG = 1
        Endif
      Next
      If GERR Then
        [M:SRE7]NBMAC = ISAVENBMAC
        [M:SRE7]CKKHDTAMT(nolign-1) = 0
        Return
      Endif
      If ICPTFLG Then
        Call LOADTOTHDT(0) From SUBSREB1
        Call LOADTOTPIT(0) From SUBSREB1
        #Les montants des consommations et les débits de points ont été recalculés sur la base des modifications effectuées.
        GMESSAGE = mess(558,182,1)
        GERR = 2
        #LSE 01/07/2005 pour ne pas rendre valides tous les champs
        Affzo [M:SRE9]1-99
      Endif
      If IADDNOL Then
        [M:SRE7]NBMAC = ISAVENBMAC
      Endif
    Endif
  Endif
  [M:SRE7]CKKHDTAMT(nolign-1) = 0
Return

##########################################################################################################
$CODE_APRES_NBCPN
Local Integer INOL
Local Integer ITER
Local Integer IERRINF
Local Integer ICPTFLG
Local Integer ISAVENBMAC
Local Integer IADDNOL
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Decimal IPITHDT     # FGR 02/02/2010 : X3SUIVI62146 : Pas Integer
Local Decimal IINVPITFLG  # FGR 24/02/2010 : X3SUIVI62770 : Pour le moment tout doit être decimal

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  IERRINF = 0
  ICPTFLG = 0
  IADDNOL = 0
  INOL = nolign-1
  If nolign > 0 Then
    If GREP = "C" Then
      Call SAVECPNLIN([M:SRE0]CRESEQ, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), [M:SRE7]CPNITM(INOL), 1, INOL, IERRINF,ICHAPTER,IBRETOUR) From SUBSREB1
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1
      Endif
    Elsif GREP = "D" Then
      Call SAVECPNLIN([M:SRE0]CRESEQ, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), [M:SRE7]CPNITM(INOL), 1, INOL, IERRINF,ICHAPTER,IBRETOUR) From SUBSREB1
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1
      Endif
    Else
      Call SAVECPNLIN([M:SRE0]SRENUM, [M:SRE7]MAC([M:SRE7]PRESRE7NOL), [M:SRE7]CPNITM(INOL), 0, INOL, IERRINF,ICHAPTER,IBRETOUR) From SUBSREB1
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1
      Endif
    Endif
  Endif
  If nolign > [M:SRE7]NBCPN Then
    IADDNOL = 1
  Endif
  ISAVENBMAC = 0
  If [M:SRE9]NBLIG > 0 Then
    #Recalcul des montants facturables suite à une modification du composant
    If [M:SRE7]CPNCKKHDT(nolign-1) Then
      If IADDNOL Then
        ISAVENBMAC = [M:SRE7]NBCPN
        [M:SRE7]NBCPN += 1
      Endif
      For ITER = 0 To [M:SRE9]NBLIG-1
        If [M:SRE9]HDTMACSRE(ITER) = [M:SRE7]MAC([M:SRE7]PRESRE7NOL) Then
          If [M:SRE9]HDTCPN(ITER) = [M:SRE7]CPNITM(nolign-1) Then
            #Détermination du montant facturable par défaut
            [M:SRE9]MANAMTFLG(ITER) = 1
            If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
              # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
              Call AMOUNT(1, "SRE9", ITER, [M:SRE9]HDTAMT(ITER), [M:SRE9]HDTINV(ITER), [M:SRE9]HDTAMTINV(ITER), [M:SRE9]PITHDT(ITER), [M:SRE9]INVPITFLG(ITER), IERRINF) From TRTAMOUNT
            Else
              IPITHDT = 0
              IINVPITFLG = 0
              Call AMOUNT(1, "SRE9", ITER, [M:SRE9]HDTAMT(ITER), [M:SRE9]HDTINV(ITER), [M:SRE9]HDTAMTINV(ITER), IPITHDT, IINVPITFLG, IERRINF) From TRTAMOUNT
            Endif
            If IERRINF Then
              GMESSAGE = mess(IERRINF,182,1)
              GERR = 1
              Break
            Endif
            ICPTFLG = 1
          Endif
        Endif
      Next
      If GERR Then
        [M:SRE7]NBCPN = ISAVENBMAC
        [M:SRE7]CPNCKKHDT(nolign-1) = 0
        Return
      Endif
      If ICPTFLG Then
        Call LOADTOTHDT(0) From SUBSREB1
        Call LOADTOTPIT(0) From SUBSREB1
        #Les montants des consommations et les débits de points ont été recalculés sur la base des modifications effectuées.
        GMESSAGE = mess(558,182,1)
        GERR = 2
        #LSE 01/07/2005 pour ne pas rendre valides tous les champs
        Affzo [M:SRE9]1-99
      Endif
      If IADDNOL Then
        [M:SRE7]NBCPN = ISAVENBMAC
      Endif
    Endif
  Endif
  [M:SRE7]CPNCKKHDT(nolign-1) = 0
Return

##########################################################################################################
$CODE_AM_CPNITM
Local Char SZITMREF(GLONITM)
Local Integer IAFFSRE9
Local Integer ICOVNOL

  SZITMREF = ""
  IAFFSRE9 = 0
  If [M:SRE7]CPNITM(nolign-1) <> "" Then
    IAFFSRE9 = 1
  Endif
  Read [MAC]MAC0=[M:SRE7]MAC([M:SRE7]PRESRE7NOL)
  If !fstat Then
    If [F:MAC]MACPDTCOD <> "" Then
      SZITMREF = [F:MAC]MACPDTCOD
    Endif
  Endif
  #Obtention de l'alternative nomenclature
  If SZITMREF <> "" Then
    Read [ITM]ITM0=SZITMREF
    If !fstat Then
      #Call LECTEXTRA([M:SRE7]CPNITMDES(nolign-1), "ITMMASTER", "DES1AXX", VALEUR, "") From ATEXTRA
      # FGR 23/04/2013 : X3SUIVI88193 : pas bon et pas au bon endroit (début)
      #Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SRE7]CPNITMDES(nolign-1), "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
      # FGR 23/04/2013 : X3SUIVI88193 : pas bon et pas au bon endroit (fin)
      If [M:SRE7]CPNSEQ(nolign-1) = 0 Then
        #Recherche d'un numero de séquence
        If [F:ITM]ALTBOMHDK > 0 Then
          Filter [BOD] Where [F:BOD]ITMREF = SZITMREF and [F:BOD]BOMALT = [F:ITM]ALTBOMHDK and [F:BOD]BOMALTTYP = 1 and [F:BOD]CPNITMREF = VALEUR
&                      Order By [F:BOD]BOMSEQ Asc
          For [BOD]
            [M:SRE7]CPNSEQ(nolign-1) = [F:BOD]BOMSEQ
            Break
          Next
          Filter [BOD]
        Endif
      Endif
    Endif
  Endif
  [M:SRE7]CPNQTY(nolign-1) = 1
  [M:SRE7]CPNITM(nolign-1) = VALEUR
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,VALEUR,[M:SRE7]CPNITMDES(nolign-1), "[F:ITM]") From TRTX3 # FGR 23/04/2013 : X3SUIVI88193 : là c'est mieux
  #---------------------------------------------------#
  # Contrôle de la couverture
  #---------------------------------------------------#
  ICOVNOL = nolign-1
  Call COVERMLC(ICOVNOL, [M:SRE7]PRESRE7NOL) From TRTCOVER
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE2]1-99
  Affzo [M:SRE7]1-99
  If IAFFSRE9 Then
    Affzo [M:SRE9]1-99
  Endif
Return

##########################################################################################################
$CODE_C_HDTCPN
Local Integer IFOUND

  If VALEUR = "" Then
    Return
  Endif
  IFOUND = 0
  #Vérifie que le parc sélectionné provient de l'onglet composants concernés.
  If GREP = "C" Then
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]MACNUM = [M:SRE9]HDTMACSRE(nolign-1) and [F:SRN]TPYFLG = 1 and [F:SRN]FGVCAH = 0
    For [SRN]
      If [F:SRN]CPNITM = VALEUR Then
        IFOUND = 1
        Break
      Endif
    Next
    Filter [SRN]
  Elsif GREP = "D" Then
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]CRESEQ and [F:SRN]MACNUM = [M:SRE9]HDTMACSRE(nolign-1) and [F:SRN]TPYFLG = 1
&                  and [F:SRN]FGVCAH = 0
    For [SRN]
      If [F:SRN]CPNITM = VALEUR Then
        IFOUND = 1
        Break
      Endif
    Next
    Filter [SRN]
  Else
    Filter [SRN] Where [F:SRN]SRENUM = [M:SRE0]SRENUM and [F:SRN]MACNUM = [M:SRE9]HDTMACSRE(nolign-1) and [F:SRN]TPYFLG = 0 and [F:SRN]FGVCAH = 0
    For [SRN]
      If [F:SRN]CPNITM = VALEUR Then
        IFOUND = 1
        Break
      Endif
    Next
    Filter [SRN]
  Endif
  If !IFOUND Then
    #Le composant indiqué ne provient pas de l'onglet Parc concerné. Saisie refusée.
    GMESSAGE = mess(201,182,1)
    GERR = 1
    mkstat = 2
  Endif
Return

##########################################################################################################
$CODE_IB_NBMAC
Local Integer IFUNOPEN

  Raz GBOUT2
  If [M:SRE9]NBLIG < dim([M:SRE9]HDTCPN)-1 Then
    If [M:SRE2]SREASS <> 5 Then
      If [M:SRE2]SREASS <> 4 Then
        If GREP = "" Then
          If [M:SRE7]MAC(nolign-1) <> "" Then
            If GISRE2TIMFLG Then
              GBOUT2 = mess(183,182,1)
            Else
              GBOUT2 = mess(182,182,1)
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  Raz GBOUT1
  IFUNOPEN = 0
  Call ISFUNOPEN("GESITN", IFUNOPEN) From CRMUTIL140
  If IFUNOPEN Then
     Return
  Endif
  If [M:SRE2]SREASS <> 5 Then
    If [M:SRE7]NBMAC > 0 Then
      If GREP = "" Then
        If [M:SRE0]SRENUM <> "" Then
          If [M:SRE0]SREBPC <> "" Then
            If [M:SRE7]ITNGRU(nolign-1) = "" Then
              Call TEXTE(14607, GBOUT1) From OBJDIV      #Interventions
            Else
              GBOUT1 = mess(238,182,1) - [M:SRE7]ITNGRU(nolign-1)
            Endif
            #---------------------------------------------------#
            #Définit la clé Intervention pour les tunnels sur interventions.
            #---------------------------------------------------#
            GLASITN = ""
            Filter [ITN] Where [F:ITN]SRVDEMNUM = [M:SRE0]SRENUM and [F:ITN]MACGRU = [M:SRE7]ITNGRU(nolign-1) Order By [F:ITN]DATX Desc
            For [ITN] Hint Key ITN1
              GLASITN = [F:ITN]NUM
              Break
            Next
            Filter [ITN]
            [M:SRE7]SRENAVTYP = "MAC"
            [M:SRE7]ITNGRUVAL = [M:SRE7]ITNGRU(nolign-1)
          Endif
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$CODE_C_PBL
Local Integer IASKREP
Local Char SZMESS(250)

  IASKREP = 0
  #On vérifie la saisie
  Gosub CTLSHORTCUT From SUBPBLB
  If GERR Then
    Return
  Else
    If VALEUR <> "" Then
      If [F:PBL]PBLBPC <> "" Then
        If [M:SRE0]SREBPC <> "" Then
          If [M:SRE0]SREBPC <> [F:PBL]PBLBPC Then
            #Cette famille de compétence n'est normalement pas disponible pour ce client. CONFIRMEZ-VOUS L'utilisation de cette famille?
            SZMESS = mess(198,177,1)
            Call OUINON(SZMESS, IASKREP) From GESECRAN
            If IASKREP = 1 Then
              VALEUR = ""
              [M:SRE7]PBL (nolign-1) = VALEUR
              Affzo [M:SRE7]PBL (nolign-1)
              mkstat = 2
              Return
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  #Confirmez-vous la suppression de la famille de compétence globale ?
  SZMESS = mess(232,182,1)
  If [M:SRE7]SREPBLGRP <> "" Then
    If nolign = 0 Then
      If [M:SRE7]SREPBLGRP <> VALEUR Then
        Call OUINON(SZMESS, IASKREP) From GESECRAN
        If IASKREP = 2 Then
          [M:SRE7]SREPBLGRP = ""
        Else
          mkstat = 2
        Endif
      Endif
    Else
      Call OUINON(SZMESS, IASKREP) From GESECRAN
      If IASKREP = 2 Then
        [M:SRE7]SREPBLGRP = ""
      Else
        mkstat = 2
      Endif
    Endif
  Endif
Return

##########################################################################################################
$CODE_AM_PBL
Local Integer ITER
Local Integer IERRINF
Local Integer ICOVNOL

  IERRINF = 0
  If VALEUR = "" Then
    [M:SRE7]PBLCLA(nolign-1) = ""
  Else
    Read [PBL]PBL0=VALEUR
    If fstat Then
      [M:SRE7]PBLCLA(nolign-1) = ""
    Else
      # FGR 23/09/2009 : X3SUIVI58024
      #[M:SRE7]PBLCLA(nolign-1) = [F:PBL]GRPPBLDES
      Call LECTEXTRA([M:SRE7]PBLCLA(nolign-1),"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
    Endif
  Endif
  #---------------------------------------------------#
  # Suppression des points de l'ancienne fiche parc
  #---------------------------------------------------#
  ICOVNOL = nolign-1
  Call DELPITCOV(GREP, 1, ICOVNOL, IERRINF) From TRTCOVER
  If IERRINF Then
    #Erreur lors de suppression des couvertures par points. Le contrôle de couverture est abandonné.
    GMESSAGE = mess(IERRINF,182,1)
    GERR = 1
    Return
  Endif
  [M:SRE7]PBL(nolign-1) = VALEUR
  #---------------------------------------------------#
  # Contrôle de la couverture
  #---------------------------------------------------#
  Call COVERML(ICOVNOL) From TRTCOVER
  #---------------------------------------------------#
  # Affectation de la demande
  #---------------------------------------------------#
  If nolign = 0 Then
    Gosub ASSIGNSRE From SUBSREB2
  Endif
  #On détecte si un recalcul des montants facturables sera nécessaire en fin de ligne
  For ITER = 0 To [M:SRE9]NBLIG-1
    If [M:SRE9]HDTMACSRE(ITER) = [M:SRE7]MAC(nolign-1) Then
      [M:SRE7]CKKHDTAMT(nolign-1) = 1
      Break
    Endif
  Next
  #LSE 01/07/2005 pour ne pas rendre valides tous les champs
  Affzo [M:SRE2]1-99
  Affzo [M:SRE7]1-99
Return

##########################################################################################################
$NO_MODIF_SSTOK
Local Integer NOL

  # FGR 13/10/2010 : X3SUIVI68214 : Non modifiable si sortie de stocke faite
  NOL = nolign-1
  If [M:SRE9]HDTTYP(NOL) = 2 Then               # 2-Pièce
    If [M:SRE9]HDTSTOISS(NOL) = 2 Then          # "Sortie de stock" effectuée
      If [M:SRE9]HDTISSQTY(nolign-1) > 0 Then   # "Quantité à sortir" saisie
        If [M:SRE9]HDTISSISS(nolign-1) > 0 Then # "Quantité sortie" saisie
          mkstat = 2
        Endif
      Endif
    Endif
  Endif
Return

