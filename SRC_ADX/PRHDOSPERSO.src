#------------------------------------------------------------------
# Test unitaires
#------------------------------------------------------------------
Subprog T_PARAMS(SITE,AXPARCOD,AXPARVAL,REFNUM)
    Value    Char SITE()
    Variable Char AXPARCOD()(),AXPARVAL()(),REFNUM()
    AXPARCOD(0)="SOLCOD"
    AXPARCOD(1)="FOLCOD"
    AXPARCOD(2)="SITCOD"
    AXPARCOD(3)="USRLANG"
    AXPARVAL(0)="SOLPAIEV6"
    AXPARVAL(1)="PAIEV6"
    AXPARVAL(2)= SITE
    AXPARVAL(3)="FRA"
    #7101
    REFNUM="200800000287"
End
#-----------------------------------------------------------------
Funprog T_SITE (AXPARCOD, AXPARVAL)
    Value Char AXPARCOD()(),AXPARVAL()()
    Local Char RES(10)
    RES=func PRHUTIFILES.PARAMXTD_GET(AXPARCOD, AXPARVAL, "SITCOD")
End RES
#------------------------------------------------------------------
Subprog T_CUSTOM(MSG,CUSTFLDCOD,CUSTFLDVAL,CUSTFLDACT)
    Variable Char MSG()
    Value Char CUSTFLDCOD()(),CUSTFLDVAL()(),CUSTFLDACT()()
    Local Integer I
    MSG+="CUSTFLDCOD  - CUSTFLDVAL - CUSTFLDACT"+chr$(13)
    For I=0 To len(CUSTFLDCOD)
       If CUSTFLDCOD(I)="" Break Endif
       MSG+="["+CUSTFLDCOD(I)+"] - ["+CUSTFLDVAL(I)+"] - ["+CUSTFLDACT(I)+"]"+chr$(13)
    Next
End
#------------------------------------------------------------------
Subprog TEST(ID)
    Value Char ID()
    Local Char AXPARCOD(100)(0..10),AXPARVAL(100)(0..10),REFNUM(100)
    Call T_PARAMS("RHDEV",AXPARCOD,AXPARVAL,REFNUM)
    Case ID
        When "RIB"
            Call TESTRIB(AXPARCOD,AXPARVAL,"GET",REFNUM)
        When "CIV"
            Call TESTETATCIV(AXPARCOD,AXPARVAL,"GET",REFNUM,0)
            Call TESTETATCIV(AXPARCOD,AXPARVAL,"READ",REFNUM,21337)
    Endcase
End
#------------------------------------------------------------------
Subprog TESTRIB(AXPARCOD,AXPARVAL,AACTION, REFNUM)
    Value    Char    AXPARCOD()(),AXPARVAL()(),AACTION(),REFNUM()
    Local    Integer DEM,FNC,STA,PAYPCT(100),NBRECORDS,ACCNONREI(0..10)
    Local    Char    FNC_DESCR(100),STA_DESCR(100),BIDCRY(100)(0..10),BIDCRY_DESCR(100)(0..10),BIDNUM(100)(0..10)
    Local    Char    BIDFMT(100)(0..10),FLIBAN(100)(0..10),BNF(100)(0..10),CPYBAN(100)(0..10),CUR(100)(10),CUR_DESCR(100)(0..10)
    Local    Char    MODSTL(100)(0..10),MODSTL_DESCR(100)(0..10),PAB1(100)(0..10),PAB2(100)(0..10),PAB3(100)(0..10)
    Local    Char    PAB4(100)(0..10),TYPPAY(100)(0..10),TYPPAY_DESCR(100)(0..10)

   # Call  ACTIONRIB(AXPARCOD,AXPARVAL,AACTION,DEM,FNC,FNC_DESCR,STA,STA_DESCR,REFNUM, BIDCRY,BIDCRY_DESCR,BIDNUM,ACCNONREI,BIDFMT,FLIBAN,BNF,CPYBAN,CUR,CUR_DESCR,MODSTL,MODSTL_DESCR,PAB1,PAB2,PAB3,
# PAB4,PAYPCT,TYPPAY,TYPPAY_DESCR,NBRECORDS)
    Local Integer I,M
    Local Char MSG(255)
    For I=0 To 10
        If BIDNUM(I)<>""
            MSG+= BIDNUM(I) + " - " + BIDFMT(I) +  " - " + FLIBAN(I) +  chr$(13)
        Endif
    Next
End
#------------------------------------------------------------------
Subprog TESTETATCIV(AXPARCOD,AXPARVAL,ACTION, REFNUM, DEM)
     Value    Char     AXPARCOD()(),AXPARVAL()(),ACTION(),REFNUM()
     Value    Integer  DEM
     Local    Integer  STA,CIV (50)
     Local    Char     FNC_DESCR(50),STA_DESCR(50),NAM(50),SRN (50),OLDNAM (50),CIV_DESCR (100),NUMSSC (50),NUMSSC2 (50)
     Local    Date     DATBRN (50)
     Local    Char     CTYBRN (50),CTYBRNSEE (50),DEPBRN (50),CRYBRN (50),CRYNAMBRN (50),NTT (50),NTT_DESCR(50),NTTNAM (50)
     Local    Char     CUSTFLDCOD(50)(0..10),CUSTFLDVAL(50)(0..10),CUSTFLDACT(50)(0..10)

     Local Char MSG(255)
     MSG=""
     MSG+="Avant appel"+chr$(13)
     Call T_CUSTOM(MSG,CUSTFLDCOD,CUSTFLDVAL,CUSTFLDACT)
     #Call ETATCIVIL(ACTION,DEM,REFNUM,NAM,SRN,OLDNAM,CIV,NUMSSC,DATBRN,CTYBRN,CTYBRNSEE,DEPBRN,CRYBRN,CRYNAMBRN,NTT,NTTNAM,
# STA,FNC_DESCR,STA_DESCR,CIV_DESCR,NTT_DESCR,CUSTFLDCOD,CUSTFLDVAL,CUSTFLDACT) From PORDPI
     MSG+="Résultat appel"+chr$(13)
     MSG+="SITE["+ func T_SITE(AXPARCOD,AXPARVAL) +"] - ACTION["+ACTION+"] - REFNUM["+REFNUM+"] - DEM["+num$(DEM)+"]"+chr$(13)
     MSG+="NAM["+NAM+"] - SRN["+SRN+"]"+chr$(13)
     Call T_CUSTOM(MSG,CUSTFLDCOD,CUSTFLDVAL,CUSTFLDACT)
End
#------------------------------------------------------------------
#
# Interface dossier personnel
#
# Traitement dans PORDPI
#
# version:20111010
# 20110517 : ajout flag dans habilitations
#------------------------------------------------------------------
#------------------------------------------------------------------
# Modification des données personnelles
#------------------------------------------------------------------

Subprog ACTIONCOORPRO(AXPARCOD,AXPARVAL,AACTION,REFNUM,DEM,FNC,FNC_DESCR,STA,STA_DESCR,PFLTEL,PFLEML,PFLMOB,CUSTFLDCOD,CUSTFLDVAL,CUSTFLDACT,FLDNAM,ADDSIZE,ADDX3FMT,ADDMANDATORY)
    Value    Char     AXPARCOD()()
    Value    Char     AXPARVAL()()
    Value    Char     AACTION()
    Value    Char     REFNUM()
    Variable Integer  DEM
    Variable Integer  FNC
    Variable Char     FNC_DESCR()
    Variable Integer  STA
    Variable Char     STA_DESCR()
    Variable Char     PFLTEL ()
    Variable Char     PFLEML ()
    Variable Char     PFLMOB ()
    Variable Char     CUSTFLDCOD()(),CUSTFLDVAL()(),CUSTFLDACT()()
    Variable Char     FLDNAM()()
    Variable Integer  ADDSIZE()
    Variable Char     ADDX3FMT()()
    Variable Integer  ADDMANDATORY()
    Gosub VERIF_MAT
    Call COORPROF(AACTION,DEM,REFNUM,PFLTEL,PFLEML,PFLMOB,STA,FNC_DESCR,STA_DESCR,CUSTFLDCOD,CUSTFLDVAL,CUSTFLDACT,FLDNAM,ADDSIZE,ADDX3FMT,ADDMANDATORY)From PORDPI
End
#------------------------------------------------------------------
#modification conjoint
#------------------------------------------------------------------

Subprog ACTIONCONJOINT(AXPARCOD,AXPARVAL,AACTION,REFNUM,DEM,FNC,FNC_DESCR,STA,STA_DESCR,JNTREFNUM,JNTNAM,JNTTEL,SITFAM, ADT, CHD,CUSTFLDCOD,CUSTFLDVAL,CUSTFLDACT,FLDNAM,ADDSIZE,ADDX3FMT,ADDMANDATORY)
    Value    Char     AXPARCOD()()
    Value    Char     AXPARVAL()()
    Value    Char     AACTION()
    Value    Char     REFNUM()
    Variable Integer  DEM
    Variable Integer  FNC
    Variable Char     FNC_DESCR()
    Variable Integer  STA
    Variable Char     STA_DESCR()
    Variable Char     JNTNAM()
    Variable Char     JNTTEL()
    Variable Char JNTREFNUM()
    Variable Integer SITFAM,ADT,CHD
    Variable Char     CUSTFLDCOD()(),CUSTFLDVAL()(),CUSTFLDACT()()
    Variable Char     FLDNAM()()
    Variable Integer  ADDSIZE()
    Variable Char     ADDX3FMT()()
    Variable Integer  ADDMANDATORY()
    Gosub VERIF_MAT
    Call SITUFAMIL(AACTION,DEM,REFNUM
&                 ,JNTREFNUM,JNTNAM, JNTTEL, SITFAM, ADT, CHD
&                 ,STA,FNC_DESCR,STA_DESCR
&                 ,CUSTFLDCOD,CUSTFLDVAL,CUSTFLDACT,FLDNAM,ADDSIZE,ADDX3FMT,ADDMANDATORY
&                )From PORDPI

End
#------------------------------------------------------------------
# Modification etat civil
# CUSTFLDCOD,CUSTFLDVAL,CUSTFLDACT :     Personnalisation CodeChamps/Valeur/CodeAction
#                                        Valeurs obtenues par Call GETPERSODATA(...) From PORDPI dans PRHDPECUSTOM
#------------------------------------------------------------------

Subprog ACTIONETATCIV(AXPARCOD,AXPARVAL,AACTION,REFNUM,DEM,FNC,FNC_DESCR,STA,STA_DESCR
&                    ,NAM,SRN,OLDNAM,CIV,CIV_DESCR,NUMSSC,NUMSSC2,DATBRN,CTYBRN
&                    , CTYBRNSEE,DEPBRN,CRYBRN,CRYNAMBRN,NTT,NTT_DESCR,NTTNAM,CUSTFLDCOD,CUSTFLDVAL,CUSTFLDACT,FLDNAM,ADDSIZE,ADDX3FMT,ADDMANDATORY)

 Value    Char     AXPARCOD()(),AXPARVAL()(),AACTION(),REFNUM()
 Variable Integer  DEM,FNC
 Variable Char     FNC_DESCR()
 Variable Integer  STA
 Variable Char     STA_DESCR(),NAM(),SRN(),OLDNAM ()
 Variable Integer  CIV
 Variable Char     CIV_DESCR(),NUMSSC (),NUMSSC2 ()
 Variable Date     DATBRN()
 Variable Char     CTYBRN(),CTYBRNSEE(),DEPBRN(),CRYBRN(),CRYNAMBRN(),NTT(),NTT_DESCR(),NTTNAM ()
#Champs additionnels
 Variable Char     CUSTFLDCOD()(),CUSTFLDVAL()(),CUSTFLDACT()()
  Variable Char     FLDNAM()()
    Variable Integer  ADDSIZE()
    Variable Char     ADDX3FMT()()
    Variable Integer  ADDMANDATORY()
 Gosub VERIF_MAT
Call ETATCIVIL(AACTION,DEM,REFNUM,NAM,SRN,OLDNAM,CIV,NUMSSC,NUMSSC2,DATBRN,CTYBRN
&                , CTYBRNSEE,DEPBRN,CRYBRN,CRYNAMBRN,NTT,NTTNAM
&                , STA,FNC_DESCR,STA_DESCR,CIV_DESCR,NTT_DESCR
&                , CUSTFLDCOD,CUSTFLDVAL,CUSTFLDACT,FLDNAM,ADDSIZE,ADDX3FMT,ADDMANDATORY
&                )From PORDPI

End

