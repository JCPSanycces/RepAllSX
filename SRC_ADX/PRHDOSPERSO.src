Subprog ACTIONCOORPERSO(AXPARCOD,AXPARVAL,AACTION,DEM,FNC,FNC_DESCR,STA,STA_DESCR,REFNUM,ADD1,ADD2,ADD3,CODPOS,CODSEE,CTY,EML,FAX,FLGTEL,FLGTEL_DESCR
&                , MOB,TEL,CRY,CUSTFLDCOD,CUSTFLDVAL,CUSTFLDACT,FLDNAM,ADDSIZE,ADDX3FMT,ADDMANDATORY
&                )

    Value    Char       AXPARCOD()()
    Variable    Char       AXPARVAL()()
    Value    Char       AACTION()
    Value    Char       REFNUM()
    Variable Integer    DEM
    Variable Integer    FNC
    Variable Char       FNC_DESCR()
    Variable Integer    STA
    Variable Char       STA_DESCR()
    Variable Char       ADD1()
    Variable Char       ADD2()
    Variable Char       ADD3()
    Variable Char       CODPOS()
    Variable Char       CODSEE()
    Variable Char       CTY()
    Variable Char       EML()
    Variable Char       FAX()
    Variable Char       MOB()
    Variable Char       TEL()
    Variable Integer    FLGTEL
    Variable Char       FLGTEL_DESCR()
    Variable Char       CRY()
    Variable Char     CUSTFLDCOD()(),CUSTFLDVAL()(),CUSTFLDACT()()
     Variable Char     FLDNAM()()
    Variable Integer  ADDSIZE()
    Variable Char     ADDX3FMT()()
    Variable Integer  ADDMANDATORY()
     Gosub VERIF_MAT
Call COORPERSO(AACTION,DEM,REFNUM,ADD1,ADD2,ADD3,CODPOS,CODSEE,CTY,EML,FAX,FLGTEL,FLGTEL_DESCR
&                , MOB,TEL,CRY
&                , STA,FNC_DESCR,STA_DESCR
&                 ,CUSTFLDCOD,CUSTFLDVAL,CUSTFLDACT,FLDNAM,ADDSIZE,ADDX3FMT,ADDMANDATORY)From PORDPI
End
#------------------------------------------------------------------
# Gestion des habilitations
#------------------------------------------------------------------
Subprog ACTIONHABILITATION(AXPARCOD,AXPARVAL,AACTION,DEM,FNC,FNC_DESCR,STA,STA_DESCR,REFNUM,HAB,HAB_DESCR,HABCMT,HABPLC,HABEND,HABSTR,HABFLG,FLDNAM,ADDSIZE,ADDX3FMT,ADDMANDATORY)
    Value    Char     AXPARCOD()()
    Value    Char     AXPARVAL()()
    Value    Char     AACTION()
    Value    Char     REFNUM()
    Variable Integer  DEM
    Variable Integer  FNC
    Variable Char     FNC_DESCR()
    Variable Integer  STA
    Variable Char     STA_DESCR()
    Variable Char     HAB()()
    Variable Char     HAB_DESCR()()
    Variable Char     HABCMT()()
    Variable Char     HABPLC()()
    Variable Date     HABSTR()
    Variable Date     HABEND()
    Variable Integer  HABFLG()
     Variable Char     FLDNAM()()
    Variable Integer  ADDSIZE()
    Variable Char     ADDX3FMT()()
    Variable Integer  ADDMANDATORY()
  Gosub VERIF_MAT
  Call HABILI(AACTION,DEM,REFNUM,HAB,HABCMT,HABEND,HABPLC,HABSTR,HABFLG,STA,FNC_DESCR,STA_DESCR,HAB_DESCR,FLDNAM,ADDSIZE,ADDX3FMT,ADDMANDATORY)From PORDPI
End

#------------------------------------------------------------------
# Frais kilométriques
#------------------------------------------------------------------
Subprog ACTIONFRAIS(AXPARCOD,AXPARVAL,AACTION,DEM,FNC,FNC_DESCR,STA,STA_DESCR,REFNUM,SITE,CAT,CAT_DESCR,LIBCAT,KIL,KIL_DESCR,LIBKIL,DATVAL,FLDNAM,ADDSIZE,ADDX3FMT,ADDMANDATORY)
    Value    Char     AXPARCOD()()
    Value    Char     AXPARVAL()()
    Value    Char     AACTION()
    Value    Char     REFNUM()
    Value    Char     SITE()
    Variable Integer  DEM
    Variable Integer  FNC
    Variable Char     FNC_DESCR()
    Variable Integer  STA
    Variable Char     STA_DESCR()
    Variable Integer CAT
    Variable Char LIBCAT()
    Variable Char CAT_DESCR()
    Variable Integer KIL
    Variable Char KIL_DESCR()
    Variable Char LIBKIL()
    Variable Date DATVAL
     Variable Char     FLDNAM()()
    Variable Integer  ADDSIZE()
    Variable Char     ADDX3FMT()()
    Variable Integer  ADDMANDATORY()
    Gosub VERIF_MAT
   # Gosub INI_VARIABLE
    Call FRAIS(AACTION,DEM,REFNUM,CAT,LIBCAT,KIL,LIBKIL,CAT_DESCR,DATVAL,STA,FNC_DESCR,STA_DESCR,FLDNAM,ADDSIZE,ADDX3FMT,ADDMANDATORY)From PORDPI
    If AACTION="WRITE" and GERR<>1
      AACTION="GET"
       Call FRAIS(AACTION,DEM,REFNUM,CAT,LIBCAT,KIL,LIBKIL,CAT_DESCR,DATVAL,STA,FNC_DESCR,STA_DESCR,FLDNAM,ADDSIZE,ADDX3FMT,ADDMANDATORY)From PORDPI
    Endif
End






 $GET_LIBKIL_LIBCAT
Local Integer T
KIL= func SUBEXS.PARAM("#"+num$(WCM_NUMTRAKIL),SITE,REFNUM,date$,T)
CAT= func SUBEXS.PARAM("#"+num$(WCM_NUMCATVEH ),SITE,REFNUM,date$,T)
LIBCAT=mess(WCM_NUMCATVEH -200,200,1)
LIBKIL=mess(WCM_NUMTRAKIL-200,200,1)

Return



 #------------------------------------------------------------------
 # Renvoie la liste des visites medicales
 #------------------------------------------------------------------
Subprog ACTIONVISMED(AXPARCOD,AXPARVAL,AACTION,REFNUM
&                    ,MEDAPT,MEDAPT_DESCR,MEDDAT,MEDDCT,MEDHOU,MEDOBS,MEDTYP,MEDTYP_DESCR
&                    ,ORG_COD,ORG_DESCR, ORG_ADD1, ORG_ADD2, ORG_POS,ORG_CTY, ORG_TEL,FLDNAM,ADDSIZE,ADDX3FMT,ADDMANDATORY)

 Value    Char     AXPARCOD()()
 Value    Char     AXPARVAL()()
 Value    Char     AACTION()
 Value    Char     REFNUM()
 Variable Char    MEDAPT()()
 Variable Char    MEDAPT_DESCR()()
 Variable Date    MEDDAT()
 Variable Char    MEDDCT()()
 Variable Char    MEDHOU()()
 Variable Char    MEDOBS()()
 Variable Char    MEDTYP()()
 Variable Char    MEDTYP_DESCR()()
 Variable Char ORG_COD()(),ORG_DESCR()(), ORG_ADD1()(), ORG_ADD2()(), ORG_POS()()
 Variable Char ORG_CTY()(), ORG_TEL()()
  Variable Char     FLDNAM()()
    Variable Integer  ADDSIZE()
    Variable Char     ADDX3FMT()()
    Variable Integer  ADDMANDATORY()
 Gosub VERIF_MAT
 If AACTION="GET"
      Call VISITMED(REFNUM,MEDAPT,MEDAPT_DESCR,MEDDAT,MEDDCT,MEDHOU,MEDOBS,MEDTYP,
&    MEDTYP_DESCR, ORG_COD, ORG_DESCR,ORG_ADD1,ORG_ADD2,ORG_POS,ORG_CTY,ORG_TEL)From PORDPI

 Endif
End


$VERIF_MAT
If vireblc(REFNUM,0)="" :End :Endif
Return
