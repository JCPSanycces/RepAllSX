#------------------------------------------------------------------
# Modification Rib
#------------------------------------------------------------------
Subprog ACTIONRIB(AXPARCOD,AXPARVAL,AACTION,DEM,FNC,FNC_DESCR,STA,STA_DESCR,REFNUM
&           ,BIDCRY,BIDCRY_DESCR,BIDNUM,BIDNUM_FMT,BIDFMT,FLIBAN,BNF,CPYBAN,CUR,CUR_DESCR,MODSTL,MODSTL_DESCR,PAB1,PAB2,PAB3
&          , PAB4,PAYPCT,TYPPAY,TYPPAY_DESCR,IBAN,BICCOD,ACCNONREI,FLDNAM,ADDSIZE,ADDX3FMT,ADDMANDATORY
&          )

    Value    Char     AXPARCOD()()
    Value    Char     AXPARVAL()()
    Value    Char     AACTION()
    Variable Integer  DEM
    Variable Integer FNC
    Variable Char    FNC_DESCR()
    Variable Integer STA
    Variable Char    STA_DESCR()
    Value    Char     REFNUM()
    Variable Char    BIDCRY()()
    Variable Char    BIDCRY_DESCR()()
    Variable Char    BIDNUM()()
    Variable Char    BIDNUM_FMT()()
    Variable Char    BIDFMT()()
    Variable Char    FLIBAN()()
    Variable Char    BNF()()
    Variable Char    CPYBAN()()
    Variable Char    CUR()()
    Variable Char    CUR_DESCR()()
    Variable Char    MODSTL()()
    Variable Char    MODSTL_DESCR()()
    Variable Char    PAB1()()
    Variable Char    PAB2()()
    Variable Char    PAB3()()
    Variable Char    PAB4()()
    Variable Integer PAYPCT()
    Variable Char    TYPPAY()()
    Variable Char    TYPPAY_DESCR()(),IBAN()(),BICCOD()()
    Variable Integer  ACCNONREI()
    Variable Char     FLDNAM()()
    Variable Integer  ADDSIZE()
    Variable Char     ADDX3FMT()()
    Variable Integer  ADDMANDATORY()

     Gosub VERIF_MAT
     Call RIB(AACTION,DEM,REFNUM,BIDCRY,BIDCRY_DESCR,BIDNUM,BNF,CPYBAN,CUR,CUR_DESCR,MODSTL,MODSTL_DESCR,PAB1,PAB2,PAB3
&          , PAB4,PAYPCT,TYPPAY,TYPPAY_DESCR,FLIBAN,BIDFMT,IBAN,BICCOD,ACCNONREI,BIDNUM_FMT
&          , STA,FNC_DESCR,STA_DESCR,FLDNAM,ADDSIZE,ADDX3FMT,ADDMANDATORY) From PORDPI

End
