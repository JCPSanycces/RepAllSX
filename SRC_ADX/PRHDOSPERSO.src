    Variable Char     NAMCNT ()()
    Variable Char     SRNCNT ()()
    Variable Char     TELCNT()(),TELCNT_FMT()()
    Variable Char     MOBCNT()(),MOBCNT_FMT()()
    Variable Char     EMLCNT ()()
     Variable Char     FLDNAM()()
