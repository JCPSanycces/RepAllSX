 Variable Integer STA
 Variable Char     STA_DESCR()
  Value    Char     REFNUM()
 Variable Char     CHDNAM ()()
 Variable Char     CHDSRN ()()
 Variable Integer     CHDSEX()
 Variable Char     CHDSEX_DESCR()()
 Variable Date     DATCHDBRN()
 Variable Char     CMT ()()
  Variable Char     FLDNAM()()
    Variable Integer  ADDSIZE()
    Variable Char     ADDX3FMT()()
    Variable Integer  ADDMANDATORY()
  Gosub VERIF_MAT
  Call ENFANTS(AACTION,DEM,REFNUM,CHDNAM,CHDSRN,CHDSEX,CHDSEX_DESCR,DATCHDBRN,CMT,STA,FNC_DESCR,STA_DESCR,FLDNAM,ADDSIZE,ADDX3FMT,ADDMANDATORY)From PORDPI
End

