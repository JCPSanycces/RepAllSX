#<AdxTL>@(#)0.0.0.0 $Revision$
# General library for all common Shop Floor Tracking functions

#######################################################################################
# Calculate the duration of a task
#######################################################################################
Funprog CALC_DURATION(ISTARTDATE, IENDDATE, INUMJOBS, ISUMEMP)
Value Datetime  ISTARTDATE
Value Datetime  IENDDATE
Value Integer   INUMJOBS
Value Integer   ISUMEMP

  Local Char      STARTSTR(20), ENDSTR(20)
  Local Date      STARTDAT, ENDDAT
  Local Integer   STARTHR, STARTMIN, STARTSEC, ENDHR, ENDMIN, ENDSEC
  Local Integer   DAYS, HOURS, MINS, SECS
  Local Decimal   ODURATION

  If ISUMEMP = 0 : ISUMEMP = 1 : Endif

  # Only calculate it if we have an end time
  If IENDDATE <> AVOID.ADATTIM
    # Conver the date time to a string
    STARTSTR  = num$(ISTARTDATE)
    ENDSTR    = num$(IENDDATE)

    # Get the date parts
    STARTDAT  = gdat$(val(mid$(STARTSTR,9,2)),val(mid$(STARTSTR,6,2)),val(left$(STARTSTR,4)))
    ENDDAT    = gdat$(val(mid$(ENDSTR,9,2)),val(mid$(ENDSTR,6,2)),val(left$(ENDSTR,4)))

    # Get the hours and minutes
    STARTHR   = val(mid$(STARTSTR,12,2))
    STARTMIN  = val(mid$(STARTSTR,15,2))
    STARTSEC  = val(mid$(STARTSTR,18,2))
    ENDHR     = val(mid$(ENDSTR,12,2))
    ENDMIN    = val(mid$(ENDSTR,15,2))
    ENDSEC    = val(mid$(ENDSTR,18,2))

    #Get the difference
    DAYS  = ENDDAT - STARTDAT
    HOURS = ENDHR - STARTHR
    MINS  = ENDMIN - STARTMIN
    SECS  = ENDSEC - STARTSEC

    If SECS < 0
      MINS -= 1
      SECS += 60
    Elsif SECS >= 60
      MINS += 1
      SECS -= 60
    Endif

    If MINS < 0
      HOURS -= 1
      MINS += 60
    Elsif MINS >= 60
      HOURS += 1
      MINS -= 60
    Endif

    If HOURS < 0
      DAYS -= 1
      HOURS += 24
    Elsif HOURS >= 24
      DAYS += 1
      HOURS -= 24
    Endif

    # Convert the duration into minutes
    ODURATION = (DAYS * 24 * 60) + (HOURS * 60) + (MINS) + (SECS/60)

  Endif

  If INUMJOBS >= 1 & ODURATION > 0
    ODURATION = (ODURATION*ISUMEMP)/INUMJOBS
  Endif

End ODURATION

#######################################################################################
# Parse the DATETIME data type to individual pieces with time zone offset.
#######################################################################################
Subprog PARSEDATETIME (IDATTIM, IOFFSET, OYEAR, OMONTH, ODAY, OHOUR, OMIN)
Value Datetime  IDATTIM
Value Decimal   IOFFSET
Variable Char   OYEAR
Variable Char   OMONTH
Variable Char   ODAY
Variable Char   OHOUR
Variable Char   OMIN

  Local Char DATESTRING(20), OFFSETSTR(3)
  Local Date DATEPART
  Local Decimal DATEDEC
  Local Integer OFFSETMIN, OFFSETHOUR
  Local Integer NUMYEAR, NUMMONTH, NUMDAY, NUMHOUR, NUMMIN

  If IDATTIM = AVOID.ADATTIM : End : Endif

  DATESTRING  = num$(IDATTIM)
  NUMYEAR     = val(left$(DATESTRING, 4))
  NUMMONTH    = val(mid$(DATESTRING, 6, 2))
  NUMDAY      = val(mid$(DATESTRING, 9, 2))
  NUMHOUR     = val(mid$(DATESTRING, 12, 2))
  NUMMIN      = val(mid$(DATESTRING, 15, 2))

  # Save the date portion as a date type so we can add to it if needed.
  DATEPART    = evalue("["+num$(NUMDAY)+"/"+num$(NUMMONTH)+"/"+num$(NUMYEAR)+"]")

  If IOFFSET <> 0
    If mod(IOFFSET,1) <> 0
      OFFSETMIN   = 60 * mod(IOFFSET,1)
      OFFSETHOUR  = IOFFSET-mod(IOFFSET,1)
    Else
      OFFSETMIN   = 0
      OFFSETHOUR  = IOFFSET
    Endif

    # Minute offset - adjust if not between 0 and 59
    NUMMIN += OFFSETMIN
    If NUMMIN >= 60
      NUMMIN  -= 60
      NUMHOUR += 1
    Elsif NUMMIN < 0
      NUMMIN  += 60
      NUMHOUR -= 1
    Endif

    # Hour offset - adjust if not between 0 and 24
    NUMHOUR += OFFSETHOUR
    If NUMHOUR >= 24
      NUMHOUR   -= 24
      DATEPART  += 1
    Elsif NUMHOUR < 0
      NUMHOUR   += 24
      DATEPART  -= 1
    Endif

  Endif

  OYEAR   = num$(year(DATEPART))
  OMONTH  = format$("N0:2",num$(month(DATEPART)))
  ODAY    = format$("N0:2",num$(day(DATEPART)))
  OHOUR   = format$("N0:2",num$(NUMHOUR))
  OMIN    = format$("N0:2",num$(NUMMIN))

End

#######################################################################################
# Return the Current date and time based on the site and the offset
#######################################################################################
Subprog TIMESTAMP(IFCY,ODATE,OTIME)
Value    Char IFCY
Variable Date ODATE
Variable Char OTIME

  Local Char SYEAR(4), SMONTH(2), SDAY(2), SHOUR(2), SMIN(2), SOFFSET(3)

  # Get the offset for this site
  Call PARAM(IFCY,"SFTOFFSET",SOFFSET) From ADOVAL

  Call PARSEDATETIME (datetime$, val(SOFFSET), SYEAR, SMONTH, SDAY, SHOUR, SMIN)

  ODATE = SYEAR+SMONTH+SDAY
  OTIME = SHOUR+SMIN

End

#######################################################################################
# Converts a break time from local time to UTC date/time
#######################################################################################
Funprog CALCBREAKTIME(IDATE, IOFFSET, IBREAKTIME)
Value Date    IDATE
Value Integer IOFFSET
Value Char    IBREAKTIME

  Local Datetime  BREAKTIME
  Local Integer   BRKHOUR, BRKMIN
  Local Integer   OFFSETMIN, OFFSETHOUR
  Local Char      DATESTRING(20)

  BRKHOUR = val(left$(IBREAKTIME, 2))
  BRKMIN  = val(mid$(IBREAKTIME, 3, 2))

  If IOFFSET <> 0
    # Get the inverse of the offset to go back to UTC from local
    IOFFSET = IOFFSET * -1

    If mod(IOFFSET,1) <> 0
      OFFSETMIN   = 60 * mod(IOFFSET,1)
      OFFSETHOUR  = IOFFSET-mod(IOFFSET,1)
    Else
      OFFSETMIN   = 0
      OFFSETHOUR  = IOFFSET
    Endif

    # Minute offset - adjust if not between 0 and 59
    BRKMIN += OFFSETMIN
    If BRKMIN >= 60
      BRKMIN  -= 60
      BRKHOUR += 1
    Elsif BRKMIN < 0
      BRKMIN  += 60
      BRKHOUR -= 1
    Endif

    # Hour offset - adjust if not between 0 and 24
    BRKHOUR += OFFSETHOUR
    If BRKHOUR >= 24
      BRKHOUR -= 24
      IDATE   += 1
    Elsif BRKHOUR < 0
      BRKHOUR += 24
      IDATE  -= 1
    Endif
  Endif

  # Build a DateTime variable from our parts
  DATESTRING  = format$("D:4Y[-]2M[-]2D[T]",IDATE)
  DATESTRING  = DATESTRING+num$(BRKHOUR)+":"+num$(BRKMIN)+":00Z"
  BREAKTIME   = gdatetime$(DATESTRING)

End BREAKTIME

#######################################################################################
#Verify that the employee is not currently clocked in
#######################################################################################
Funprog EMPLOYEE_CLOCKED_IN(IEMPNUM)
Value Integer  IEMPNUM

  Local Integer CLOCKED_IN : CLOCKED_IN = [V]CST_ANO
  If !clalev([F:SFTXC]) : Local File SFTTXN [SFTXC] : Endif

  Filter [SFTXC] Where EMPNUM=IEMPNUM & SFTTYP=1 & UTCENDDATTIM=[0/0/0] Order By SFTSEQ
  Read [SFTXC] Last
  Filter [SFTXC]
  If !fstat
      CLOCKED_IN = [V]CST_AYES
  Endif

	LogicClose File [SFTXC]

End CLOCKED_IN

#######################################################################################
# Check if the employee is currently on break
#######################################################################################
Funprog EMPLOYEE_ON_BREAK(IEMPNUM)
Value Integer  IEMPNUM

  Local Integer OBREAK : OBREAK = [V]CST_ANO
  If !clalev([F:SFTXB]) : Local File SFTTXN [SFTXB] : Endif

  Filter [SFTXB] Where EMPNUM=IEMPNUM & (SFTTYP=3 | (SFTTYP=2 & INDTYP=4)) & UTCENDDATTIM=[0/0/0] Order By SFTSEQ
  Read [SFTXB] Last
  Filter [SFTXB]
  If !fstat
    OBREAK = [V]CST_AYES
  Endif

	LogicClose File [SFTXB]

End OBREAK

#######################################################################################
# Is the Employee ID a team or a person
#######################################################################################
Funprog ISTEAM(EMPNUM)
Value Integer EMPNUM
Local Integer ISTEAM

  If !clalev([TMA]) : Local File TABMAT [TMA] : Endif

  Read [TMA]TMA0=EMPNUM
  If !fstat & [F:TMA]EMPTYP = 2
    [L]ISTEAM = [V]CST_AYES
  Else
    [L]ISTEAM = [V]CST_ANO
  Endif

  LogicClose File [TMA]

End ISTEAM

#######################################################################################
# Get employee type
#######################################################################################
Funprog EMPTYP(EMPNUM)
Value Integer EMPNUM
Local Integer EMPTYP

  If !clalev([TMA]) : Local File TABMAT [TMA] : Endif

  Read [TMA]TMA0=EMPNUM
  If !fstat
    [L]EMPTYP = [F:TMA]EMPTYP
  Else
    [L]EMPTYP = 0
  Endif

  LogicClose File [TMA]

End EMPTYP
#######################################################################################
Funprog ISMACHINE(IWCENTER, IFCY)
Value Char WCENTER
Value Char IFCY
Local Integer ISMACHINE

  If !clalev([MWS]) : Local File WORKSTATIO [MWS] : Endif

  Read [MWS]WST0  = IWCENTER;IFCY
  If !fstat & [MWS]WSTTYP = 1
    [L]ISMACHINE = [V]CST_AYES
  Else
    [L]ISMACHINE = [V]CST_ANO
  Endif

  LogicClose File [MWS]

End ISMACHINE
#######################################################################################
Funprog SUMEMP(EMPNUM)
Value Integer EMPNUM
Local Integer SUMEMP

  SUMEMP = 0

  If !clalev([TMA]) : Local File TABMAT [TMA] : Endif

  Read [TMA]TMA0=EMPNUM
  If !fstat
    [L]SUMEMP = [F:TMA]SUMEMP
  Endif

  LogicClose File [TMA]

End SUMEMP
#######################################################################################
# Is the Employee ID active
#######################################################################################
Funprog EMPLOYEEACTIVE(EMPNUM)
Value Integer EMPNUM
Local Integer IACTIVE

  If !clalev([TMA]) : Local File TABMAT [TMA] : Endif

  # Default to No
  [L]IACTIVE = [V]CST_ANO

  Read [TMA]TMA0=EMPNUM
  If !fstat
    # If enabled set to yes
    If [F:TMA]ENAFLG=[V]CST_AYES
      [L]IACTIVE = [V]CST_AYES
    Endif

    # Check to make sure dates are valid (if entered)
    If ([F:TMA]ACTDAT <> AVOID.ADATE & [F:TMA]ACTDAT > date$) | ([F:TMA]INACTDAT <> AVOID.ADATE & [F:TMA]INACTDAT <= date$)
      [L]IACTIVE = [V]CST_ANO
    Endif
  Endif

  LogicClose File [TMA]

End IACTIVE

#######################################################################################
# Does the employee get access to the Elapsed Labor entry (Time tracking)
#######################################################################################
Funprog ELAPSEDLABORENTRY(EMPNUM)
Value Integer EMPNUM
Local Integer IACTIVE

  If !clalev([TMA]) : Local File TABMAT [TMA] : Endif

  Read [TMA]TMA0=EMPNUM
  If !fstat & [F:TMA]ELPFLG=[V]CST_AYES
    [L]IACTIVE = [V]CST_AYES
  Else
    [L]IACTIVE = [V]CST_ANO
  Endif

  LogicClose File [TMA]

End IACTIVE

####################################################################################
# Validate complete qty and check if the complete flag should be set to Y or N
####################################################################################
Subprog VAL_COMPLETEQTY(IMFGNUM, IOPENUM, IQTY, IQTY_HIGHER, ICLOSE)
Value    Char    IMFGNUM
Value    Integer IOPENUM
Value    Decimal IQTY
Variable Integer IQTY_HIGHER
Variable Integer ICLOSE

  Local Decimal TOTCPLQTY
  If !clalev([F:SFTXC]) : Local File SFTTXN [SFTXC] : Endif
  If !clalev([F:MFO])   : Local File MFGOPE [MFO]   : Endif

  IQTY_HIGHER = [V]CST_ANO

  Read [MFO]MFO0 = IMFGNUM; IOPENUM
  If fstat
    Call ERREUR(mess(21,2422,1) - "MFO" - IMFGNUM - num$(IOPENUM)) From GESECRAN  # Unable to read MFO...
    End
  Endif

  # determine the total quantity completed that is sitting on SFTTXN records
  # and have yet to be validated
  Raz TOTCPLQTY
  For [F:SFTXC] Where VCRNUM = IMFGNUM & OPENUM = IOPENUM & SFTTYP = 5
    TOTCPLQTY += [F:SFTXC]CPLQTY
  Next

  # check if the quantity to be made has been is higher, if so, set qty flag to yes
  If [F:MFO]CPLQTY + TOTCPLQTY + IQTY > [F:MFO]EXTQTY
    IQTY_HIGHER = [V]CST_AYES   # # TODAN-119090
#    IQTY_HIGHER = 2   # Yes
  Endif

  # check if the quantity to be made has been met, if so, set close flag to Y
  If [F:MFO]CPLQTY + TOTCPLQTY + IQTY >= [F:MFO]EXTQTY
    ICLOSE = [V]CST_AYES   # Yes
  Endif

	LogicClose File [SFTXC]
	LogicClose File [MFO]

End

####################################################################################
# When a Tracking record is deleted, check if it was in the history table and,
# if it was, return it to transaction table and delete from history.
####################################################################################
Subprog TRACKING_DELETED(IMFGNUM)
Value Char IMFGNUM

Local File SFTTXNH [SFTXH]
Local File SFTTXN  [SFTX]

Filter [SFTXH] Where MFGTRKNUM = IMFGNUM
For [SFTXH]

  [SFTX] = [SFTXH]
  [SFTX]FCY = [SFTXH]MFGFCY
  [SFTX]SFTSEQ = func SFTTXN_CSTD.NEXT_SEQ([SFTX]EMPNUM, [SFTX]SFTTYP, [SFTX]VCRNUM)

  Write [SFTX]
  If fstat
     GOK = 0 : Call FSTA("SFTX") From GLOCK : End
  Endif
  Delete [SFTXH]
  If fstat
     GOK = 0 : Call FSTA("SFTXH") From GLOCK : End
  Endif
Next


LogicClose File [SFTXH], [SFTX]

End

####################################################################################
# Get the work center group/labor center group
####################################################################################
Funprog GET_CENTER_GROUP(CENTER, SITE)
Value Char CENTER
Value Char SITE

  Local Char OCENTERGRP(5)
  If !clalev([F:MWS]) : Local File WORKSTATIO [MWS] : Endif

  # Get work center group value from work center table filtering by work center and site.
  If [F:MWS]WST<>CENTER | [F:MWS]WCRFCY<>SITE
    Read [F:MWS]WST0=CENTER;SITE
  Endif
  OCENTERGRP = [F:MWS]WCR

  LogicClose File [MWS]

End OCENTERGRP

######################################################################################
Funprog VALIDATE_WORK_CENTER(FCY, WCR, WST)
Value Char FCY  # Site
Value Char WCR  # Work Center Group
Value Char WST  # Work Center

  Local Integer RETVAL
  Local Char CRIT(255)
  If !clalev([MWS]) : Local File WORKSTATIO [MWS] : Endif

  RETVAL = [V]CST_AYES

  CRIT = "1=1"
  If FCY<>AVOID.ACHAR : CRIT+= " & WCRFCY='"+[L]FCY+"'" : Endif
  If WCR<>AVOID.ACHAR : CRIT+= " & WCR='"   +[L]WCR+"'" : Endif
  If WST<>AVOID.ACHAR : CRIT+= " & WST='"   +[L]WST+"'" : Endif

  Filter [MWS] Where evalue(CRIT)
  Read [MWS]First
  Filter [MWS]
  If fstat
    # Record not found
    RETVAL = [V]CST_ANO
  Endif
  LogicClose File [MWS]

End RETVAL
######################################################################################
Funprog EMPL_CLK_IN_OUT(EMPLID, FCY)
Value Integer EMPLID
Value Char FCY
Local Integer RESULTS

  Local Char PARAMRET(4)
  Raz PARAMRET
  Call PARAM(FCY,"SFTEMPCLK",PARAMRET) From ADOVAL
  SFTEMPCLK = val([L]PARAMRET)

  RESULTS = [V]CST_AYES

  #  Action not allowed if employee is not clocked in
  If  SFTEMPCLK = [V]CST_AYES & func SFTLIB.EMPLOYEE_CLOCKED_IN(EMPLID) = [V]CST_ANO
    Call ERREUR(func AFNC.MES1(mess(12,2422,1), num$(EMPLID))) From GESECRAN #CT-1797
    RESULTS = [V]CST_ANO
  Endif
End RESULTS
####################################################################################
# Get the work center/labor center from SFTTXN or SFTTXNH tables if existed
####################################################################################
Subprog GET_SFT_WC_LC(IMFGNUM, IOPENUM, IWSTTYP, IWCENTER, ILCENTER, OWCENTER, OLCENTER)

Value Char    IMFGNUM
Value Integer IOPENUM
Value Integer IWSTTYP # 1 = Machine, 2 = Labor
Value Char    IWCENTER
Value Char    ILCENTER
Variable Char OWCENTER
Variable Char OLCENTER

Local Integer FOUND


  If IWSTTYP = 1 #Machine work center
    Filter [F:SFTX] Where [F:SFTX]VCRNUM = IMFGNUM & [F:SFTX]OPENUM = IOPENUM & [F:SFTX]MACFLG = [V]CST_AYES
&                   Order By UTCSTRDATTIM
    Read [F:SFTX] Last
    If !fstat #Found the machine work center
      OWCENTER = [F:SFTX]WCENTER
      FOUND = [V]CST_AYES
    Endif

    If ILCENTER <>  "" #Finding associated labor work center
      Filter [F:SFTX] Where [F:SFTX]VCRNUM = IMFGNUM & [F:SFTX]OPENUM = IOPENUM & [F:SFTX]MACFLG = [V]CST_ANO
&                     Order By UTCSTRDATTIM
      Read [F:SFTX] Last
      If !fstat #Found the labor work center
        OLCENTER = [F:SFTX]WCENTER
        FOUND = [V]CST_AYES
      Endif
    Endif

  Else #Labor work center
    Filter [F:SFTX] Where [F:SFTX]VCRNUM = IMFGNUM & [F:SFTX]OPENUM = IOPENUM
&                 Order By UTCSTRDATTIM
    Read [F:SFTX] Last
    If !fstat #Found the labor work center
      OWCENTER = [F:SFTX]WCENTER
      OLCENTER = [F:SFTX]LCENTER
      FOUND = [V]CST_AYES
    Endif
  Endif


  If FOUND <> [V]CST_AYES
    If IWSTTYP = 1 #Machine work center
      Filter [F:SFTH] Where [F:SFTH]VCRNUM = IMFGNUM & [F:SFTH]OPENUM = IOPENUM & [F:SFTH]MACFLG = [V]CST_AYES
&                   Order By UTCSTRDATTIM
      Read [F:SFTH] Last
      If !fstat #Found the machine work center
        OWCENTER = [F:SFTH]WCENTER
        FOUND = [V]CST_AYES
      Endif

      If ILCENTER <>  "" #Finding associated labor work center
        Filter [F:SFTH] Where [F:SFTH]VCRNUM = IMFGNUM & [F:SFTH]OPENUM = IOPENUM & [F:SFTH]MACFLG = [V]CST_ANO
&                     Order By UTCSTRDATTIM
        Read [F:SFTH] Last
        If !fstat #Found the labor work center
          OLCENTER = [F:SFTH]WCENTER
          FOUND = [V]CST_AYES
        Endif
      Endif
    #end of machine work center search
    Else #Labor work center
      Filter [F:SFTH] Where [F:SFTH]VCRNUM = IMFGNUM & [F:SFTH]OPENUM = IOPENUM
&                   Order By UTCSTRDATTIM
      Read [F:SFTH] Last
      If !fstat #Found the labor work center
        OWCENTER = [F:SFTH]WCENTER
        OLCENTER = [F:SFTH]LCENTER
        FOUND = [V]CST_AYES
      Endif
    Endif
  Endif#End history search

End

####################################################################################
# Validate if employee has team open activities
####################################################################################
Funprog OPEN_ACTIVITIES(ITEAM, IEMPNUM)
Value    Integer ITEAM
Value    Integer IEMPNUM

  Local Integer OPEN
  Local Char CRIT(200)

  # Default to No
  [L]OPEN = [V]CST_ANO

  If !clalev([F:SFTX]) : Local File SFTTXN  [SFTX] : Endif

#  Raz OPEN

  If ITEAM = 0 : ITEAM = -1 : Endif
  If IEMPNUM <> 0
    CRIT -= "TEAMNUM<>ITEAM"
  Else
    CRIT -= "TEAMNUM=ITEAM"
  Endif

  If IEMPNUM <> 0
    CRIT -= "& EMPNUM=IEMPNUM"
  Endif

  Filter [F:SFTX] Where SFTTYP <> 1 & UTCENDDATTIM = AVOID.ADATTIM & evalue(CRIT)
  Look [F:SFTX] First
  Filter [F:SFTX]
  If !fstat
    [L]OPEN = [V]CST_AYES
  Endif

  LogicClose File [SFTX]

End OPEN

####################################################################################
# Validate if team has open exclusive tasks
####################################################################################
Funprog TEAM_ON_TASK(ITEAM, TYP)
Value Integer ITEAM
Value Char    TYP

  Local Integer OPEN

  # Default to No
  [L]OPEN = [V]CST_ANO

  #If they aren't on a team then get out
  If ITEAM = 0
    End [V]CST_ANO
  Endif

  If !clalev([F:SFTX]) : Local File SFTTXN  [SFTX] : Endif

  If TYP = "EX"
    Filter [F:SFTX] Where TEAMNUM = ITEAM & UTCENDDATTIM = AVOID.ADATTIM & BRKTXN <> AVOID.AUUID & SFTTYP <> 1
  Elsif TYP = "NON"
    Filter [F:SFTX] Where TEAMNUM = ITEAM & UTCENDDATTIM = AVOID.ADATTIM & BRKTXN = AVOID.AUUID & SFTTYP <> 1
  Endif

  Look [F:SFTX] First
  If !fstat
    [L]OPEN = [V]CST_AYES
  Endif

  LogicClose File [SFTX]

End OPEN
################################################################################################
# Verify that the employee/team exists in SFTXN and SFTXNH tables
################################################################################################
Funprog EMP_IN_TXN(IEMPNUM)
Value Integer IEMPNUM

  Local Integer RETVAL
  Local File SFTTXN [SFTX]
  Local File SFTTXNH [SFTH]

  RETVAL = [V]CST_ANO

  Filter [SFTX] Where EMPNUM = IEMPNUM  or TEAMNUM = IEMPNUM
  Look [SFTX]First
  Filter [SFTX]
  If !fstat
    # Record found
    RETVAL = [V]CST_AYES
    Goto EXIT_EMP
  Endif

  Filter [SFTH] Where EMPNUM = IEMPNUM or TEAMNUM = IEMPNUM
  Look [SFTH]First
  Filter [SFTH]
  If !fstat
    # Record found
    RETVAL = [V]CST_AYES
    Goto EXIT_EMP
  Endif

EXIT_EMP:
  LogicClose File [SFTX]
  LogicClose File [SFTH]
End RETVAL

################################################################################################
# Verify that the work center exists in SFTXN table
################################################################################################
Funprog WST_IN_TXN(IWST,IFCY)
Value Char IWST
Value Char IFCY

  Local Integer RETVAL
  Local File SFTTXN [SFTX]

  RETVAL = [V]CST_ANO

  Filter [SFTX] Where WCENTER = IWST & FCY = IFCY
  Look [SFTX]First
  Filter [SFTX]
  If !fstat
    # Record found
    RETVAL = [V]CST_AYES
    Goto EXIT_WST
  Endif

EXIT_WST:
  LogicClose File [SFTX]
End RETVAL

################################################################################################
# Verify that the employee exists in SFTTEAM table
################################################################################################
Funprog EMP_IN_TEAM(IEMPNUM,IEMPTYP)
Value Integer IEMPNUM
Value Integer IEMPTYP

  Local Integer RETVAL
  Local File SFTTEM [SFTTM]

  RETVAL = [V]CST_ANO

  If IEMPTYP=2
    Filter [SFTTM] Where TEAMNUM = IEMPNUM
  Else
    Filter [SFTTM] Where EMPNUM = IEMPNUM
  Endif

  Look [SFTTM]First
  Filter [SFTTM]
  If !fstat
    # Record found
    RETVAL = [V]CST_AYES
  Endif

  LogicClose File [SFTTM]
End RETVAL

####################################################################################
Subprog NEXT_TEAM_SEQ(ITEAM,IEMPNUM,OSEQ)
Value    Integer ITEAM
Value    Integer IEMPNUM
Variable Integer OSEQ

  # open on SFTTEMH channel to avoid conflicts
  If !clalev([F:SFTTH]) : Local File SFTTEMH [SFTTH]  : Endif

  Filter [SFTTH] Where TEAMNUM = ITEAM & EMPNUM = IEMPNUM Order By TEAMSEQ
  Read [SFTTH] Last
  Filter [SFTTH]
  If fstat
      OSEQ = 1
  Else
      OSEQ = [F:SFTTH]TEAMSEQ + 1
  Endif

  LogicClose File [SFTTH]
End
####################################################################################
Subprog TEAM_LIST (ITEAM, LABTYP, EMPLIST)
Value Integer ITEAM
Value Char LABTYPE
Variable Integer EMPLIST(1..)

  Local Integer I
  Local Integer TASK_TYPE
  Local Integer TREND

  Local Integer TEAM_TASKS : TEAM_TASKS = 1
  Local Integer NO_TASKS   : NO_TASKS   = 2

  I = 1

  Local File SFTTEM [SFTTM]

  Filter [SFTTM] Where TEAMNUM = ITEAM
  For [SFTTM]
    # Employee must be active
    If func EMPLOYEEACTIVE([F:SFTTM]EMPNUM) = [V]CST_ANO : Goto SKIP : Endif
    # Employee must be clocked in
    If func EMPLOYEE_CLOCKED_IN([F:SFTTM]EMPNUM) <> [V]CST_AYES : Goto SKIP : Endif

    If LABTYP = "A" # Actual labor only
      #Call a function that sees if we are on any team activities, non-team activities, or no activities
      TASK_TYPE = func SFTLIB.OPEN_TEAM_ACTIVITIES(ITEAM,[F:SFTTM]EMPNUM)
      Case TASK_TYPE
        When 0 # no open tasks
          #If we have seen team tasks, we want to skip this record
          If TREND = TEAM_TASKS : Goto SKIP : Endif
          #If there is no trend, we want to make the trend that there are no tasks
          If TREND = 0 : TREND = NO_TASKS : Endif
        When 1 #open team task
          #If there is no trend, we want to make the trend that there are team tasks
          If TREND = 0
            TREND = TEAM_TASKS
          Endif
          #If the trend is no task, we need to clear out the list and make the trend team tasks.
          #We dont want employees without tasks if there are employees with team tasks open
          If TREND = NO_TASKS
            Raz EMPLIST
            I = 1
            TREND = TEAM_TASKS
          Endif
        #we never want employees that have non team tasks open
        When 2 : Goto SKIP
      Endcase
    Endif

    EMPLIST(I) = [F:SFTTM]EMPNUM
    I += 1
  SKIP:
  Next
  Filter [SFTTM]

End
################################################################################################
Funprog OPEN_TEAM_ACTIVITIES(ITEAM,IEMPNUM)
Value Integer ITEAM
Value Integer IEMPNUM
#Returns 3 possible results. 0: no open activities, 1: open team activities, 2: open non-team activities

  Local Integer OPEN

  If !clalev([F:SFTX]) : Local File SFTTXN  [SFTX] : Endif

  Filter [F:SFTX] Where SFTTYP <> 1 & EMPNUM = IEMPNUM & UTCENDDATTIM = AVOID.ADATTIM
  Read [F:SFTX] First
  If fstat
    [L]OPEN = 0
  Elsif [F:SFTX]TEAMNUM = ITEAM and ITEAM <> 0
      [L]OPEN = 1
  Else
    [L]OPEN = 2
  Endif

  LogicClose File [SFTX]

End OPEN

################################################################################################
# Get employee team number
################################################################################################
Subprog EMP_TEAM_NUM(IEMPNUM,ITEAMNUM)
  Value Integer IEMPNUM
  Variable Integer ITEAMNUM

  Local File SFTTEM [SFTTM]

  Filter [SFTTM] Where EMPNUM = IEMPNUM

  ITEAMNUM = 0

  Read [SFTTM]First
  Filter [SFTTM]
  If !fstat
    # Record found
    ITEAMNUM = [SFTTM]TEAMNUM
  Endif

  LogicClose File [SFTTM]
End

####################################################################################
Subprog STOP_OPERATIONS(EMPNUM, FCY, SFTTYP, VCRNUM, OPENUM, SFTSEQ, INDTYP, CPLQTY, REJQTY, SCANUM, CLEFLG, NUM_STOPPED)
Value  Integer  EMPNUM
Value  Char     FCY
Value  Integer  SFTTYP(0..)
Value  Char     VCRNUM()(0..)  #VCRNUM or INDREF
Value  Integer  OPENUM(0..)   # TTD-1447
Value  Integer  SFTSEQ(0..)
Value  Integer  INDTYP(0..)    #INDIRECT type
Value  Integer  CPLQTY(0..)
Value  Integer  REJQTY(0..)
Value  Integer  SCANUM(0..)
Value  Integer  CLEFLG(0..)
Value  Integer  NUM_STOPPED

  Local Datetime STOPTIME
  Local Datetime T_STOPTIME #Needed for detailed team machine only
  Local Integer  ERRNUM, RETSTATUS
  Local Char     ERRMSG(255)
  Local Integer  RESTART_OPER : RESTART_OPER = 0
  Local Integer  TEAMNUM
  Local Integer  EMPTYPE
  Local Char     CRIT(255)
  Local Integer  EMPTEAMNUM : EMPTEAMNUM = 0
  Local Integer  NUM_OF_TEAM_MEMBER : NUM_OF_TEAM_MEMBER = 0  # TTD-2105
  Local Integer  LAST_TEAM_MEMBER # TTD-2536

  [L]EMPTYPE = func SFTLIB.EMPTYP(EMPNUM)

  [L]STOPTIME = datetime$
  T_STOPTIME = STOPTIME #Needed for detailed team machine only

  Local Instance SFTTXN Using C_SFTTXN
  SFTTXN = NewInstance C_SFTTXN AllocGroup null

  Local File SFTTXN [SFTX]
  Local Integer EMP_LIST(1..)
  EMP_LIST(1) = EMPNUM

  If func ISTEAM(EMPNUM) = [V]CST_AYES
    Call TEAM_LIST (EMPNUM, 'A', EMP_LIST) From SFTLIB
    TEAMNUM = EMPNUM

    # Get # of team members
    NUM_OF_TEAM_MEMBER = maxtab(EMP_LIST) # TTD-2105

    If find(SFTTYP(0),2,4) #Break/Exclusive indirect.
      #We need to add TEAMNUM so that we can restart the machine record for DETAILED team machine only records
      EMP_LIST(maxtab(EMP_LIST)+1)=TEAMNUM
    Endif
  Endif

  # Check if employee is on the team and was on individual break
  If TEAMNUM = 0 & EMPTEAMNUM = 0
    Call EMP_TEAM_NUM(EMPNUM, EMPTEAMNUM)
  Endif

  For X = 1 To maxtab(EMP_LIST)
    RESTART_OPER = 0    # TTD-1447
    For I = 0 To NUM_STOPPED-1
      #TTD-1447.s
      If [L]EMPTYPE = 2
        Filter [SFTX] Where EMPNUM = EMP_LIST(X) and SFTTYP = [L]SFTTYP(I) and
&                           VCRNUM = [L]VCRNUM(I) and OPENUM = [L]OPENUM(I) and
&                           UTCENDDATTIM = AVOID.ADATTIM
      Else
        # Read the correct record then call the correct method
        Filter [SFTX] Where EMPNUM = EMP_LIST(X) and SFTTYP = [L]SFTTYP(I) and
&                           VCRNUM = [L]VCRNUM(I) and SFTSEQ = [L]SFTSEQ(I) and
&                           UTCENDDATTIM = AVOID.ADATTIM
      Endif
      Read [SFTX] First
      If fstat : goto NEXT_OPERATION : Endif # The employee wasn't on this record. check the next operation.

      # TTD-2536. Check if this is a last team member stop the team task.
      # This is to use later for the autobreak
      If EMPTEAMNUM <> 0 & [F:SFTX]TEAMNUM <> 0
        LAST_TEAM_MEMBER = func SFTLIB.LAST_TEAM_MEMBER_ON_TEAM_TASK(EMP_LIST(X), [F:SFTX]TEAMNUM)
      Endif

      [L]RETSTATUS = fmet SFTTXN.AREAD([SFTX]EMPNUM, [SFTX]SFTTYP, [SFTX]VCRNUM, [SFTX]SFTSEQ) #TTD - 1447.n
      #TTD-1447.e

      If [L]RETSTATUS <> [V]CST_AOK
        ERRNUM=[L]RETSTATUS : ERRMSG = SFTTXN.AERROR.MES
        Break
      Endif

      If SFTTYP(I)=3 or (SFTTYP(I)=2 & INDTYP(I)=4) # Break/Exclusive Indirect Operation Stop
        # TTD-1849.s
        # Check if this is a team member stop team break
        If EMPTEAMNUM <> 0 & [SFTX]TEAMNUM = EMPTEAMNUM
            [L]RETSTATUS = fmet SFTTXN.BREAK_STOP_NO_RESTART(STOPTIME,SFTTYP(I))
            If [L]RETSTATUS <> [V]CST_AOK
              ERRNUM=[L]RETSTATUS : ERRMSG = SFTTXN.AERROR.MES
              Break
            Endif

            # Also, stop the machine only record of this team member
            Local File SFTTXN [SFTXNM]
            Local Instance SFTTXN_M Using C_SFTTXN
            SFTTXN_M = NewInstance C_SFTTXN AllocGroup null

            Filter [SFTXNM] Where EMPNUM = [F:SFTX]EMPNUM & TEAMNUM <> 0 &
&                                 MACFLG = [V]CST_AYES & UTCENDDATTIM=AVOID.ADATTIM
            For [SFTXNM]
              # Read machine only record
              [L]RETSTATUS = fmet SFTTXN_M.AREAD([SFTXNM]EMPNUM, [SFTXNM]SFTTYP,
&                                                 [SFTXNM]VCRNUM, [SFTXNM]SFTSEQ)
              If [L]RETSTATUS <> [V]CST_AOK
                ERRNUM=[L]RETSTATUS : ERRMSG = SFTTXN.AERROR.MES
                Break
              Endif
              # Stop machine only record
              [L]RETSTATUS = fmet SFTTXN_M.OPERATION_STOP([F:SFTXNM]UTCSTRDATTIM, FCY, AVOID.AINT,
&                                                         AVOID.AINT, AVOID.AINT, [V]CST_ANO)       # TODAN-119641.n
#              [L]RETSTATUS = fmet SFTTXN_M.OPERATION_STOP([F:SFTXNM]UTCSTRDATTIM, FCY, AVOID.AINT,
#&                                                         AVOID.AINT, AVOID.AINT, AVOID.AINT)      # TODAN-119641.o
              If [L]RETSTATUS <> [V]CST_AOK
                ERRNUM=[L]RETSTATUS : ERRMSG = SFTTXN.AERROR.MES
                Break
              Endif
              Next
              Filter [SFTXNM]
              LogicClose File [SFTXNM]
              FreeGroup SFTTXN_M
        Else      # Not a team member stop team break
          [L]RETSTATUS = fmet SFTTXN.BREAK_STOP(STOPTIME,SFTTYP(I))
          If [L]RETSTATUS <> [V]CST_AOK
            ERRNUM=[L]RETSTATUS : ERRMSG = SFTTXN.AERROR.MES
            Break
          Endif

          #TTD-2105.s
          # Check if this is a Team break stop and this is a the last team member.
          # Clear team break code and restart.
          If [L]TEAMNUM <> 0 & X = [L]NUM_OF_TEAM_MEMBER
            Call RESTART_TEAM_BREAK(TEAMNUM, STOPTIME) From SFTTXN_CSTD
          Endif
          #TTD-2105.e
        Endif
        #TTD-1849.e

        # TTD-2129. Stop team records if this is the last team member.
        If [L]EMPTEAMNUM <> 0
            Call STOP_TEAM_RECORDS (EMPNUM, [L]EMPTEAMNUM, AVOID.AUUID, [L]STOPTIME)
        Endif
        #TTD-1849.e
      Elsif find(SFTTYP(I),4,5) or (SFTTYP(I)=2 & INDTYP(I)=3)  # Setup/Run/Non-Exclusive Indirect Operation Stop

        #This should only happen for Detailed team machine only records
        If SFTTXN.MACFLG = [V]CST_AYES and SFTTXN.TEAMNUM <> 0 and SFTTXN.TEAMNUM <> SFTTXN.EMPNUM
          STOPTIME = SFTTXN.UTCSTRDATTIM #We want the duration for the team members machine record to be 0 so that extra time isnt posted
        Endif

       [L]RETSTATUS = fmet SFTTXN.OPERATION_STOP(STOPTIME, FCY, CPLQTY(I), REJQTY(I), SCANUM(I), CLEFLG(I))

        If [L]RETSTATUS <> [V]CST_AOK
          ERRNUM=[L]RETSTATUS : ERRMSG = SFTTXN.AERROR.MES
          Break
        Endif

        STOPTIME = T_STOPTIME #Reset STOPTIME in case we changed it for detailed team machine only

        #Stop Machine records associated with current record. Only apply to the labor records
        If EMPTEAMNUM <> 0    # TTD-1496/1447
          Call MACHINE_STOP([SFTX]EMPNUM, EMPTEAMNUM, SFTTYP(I), VCRNUM(I), [SFTX]SFTSEQ, STOPTIME, ERRNUM, ERRMSG)
        Else
          # TTD-2397/2412 for the team, wait till the last team member to close the machine record
          If X = maxtab(EMP_LIST)
            Call MACHINE_STOP([SFTX]EMPNUM, TEAMNUM, SFTTYP(I), VCRNUM(I), [SFTX]SFTSEQ, STOPTIME, ERRNUM, ERRMSG)
          Endif
        Endif

        If ERRNUM <> [V]CST_AOK : Break : Endif
        If (SFTTXN.CPLLAB <> AVOID.ACHAR or SFTTXN.NUMMAC = [V]CST_ANO)   # TODAN-119090
#        If (SFTTXN.CPLLAB <> "" or SFTTXN.NUMMAC = 0)
          RESTART_OPER += 1
        Endif

      Endif
NEXT_OPERATION:
    Next

      #MIHAL X3-2012.sn
      If SFTTXN.TEAMNUM <> 0 and EMPTEAMNUM <> 0
        Call STOP_ALL_ACTIVITIES([SFTX]EMPNUM, STOPTIME)
      Endif
      #MIHAL X3-2012.en

    # Reset the fields
    For J = 0 To NUM_STOPPED - 1
      CPLQTY(J) = 0
      REJQTY(J) = 0
      SCANUM(J) = 0
      CLEFLG(J) = [V]CST_ANO    # TODAN-119641.n
#      CLEFLG(J) = 0            # TODAN-119641.o
    Next

    # Stop and restart the setup/run operation(s) to decrement the # of jobs
    If RESTART_OPER > 0 and !find(-1,CLEFLG) #CLEFLG will only have a -1 when coming from clockout

      # Close and restart the existing operations
      Call RESTART_OPERATIONS(RESTART_OPER, STOPTIME, SFTTXN.EMPNUM, FCY, "STOP", [V]CST_ANO) From SFTTXN_CSTD #TTD - 1447.n

    Endif

    # TTD-2397/2412.s - Move out of the Restart operation loop since the restart operation does not have anything to do with
    # the run the autobreak.
    # process any autobreaks - clear the reference to the class instance first
    FreeGroup SFTTXN
    SFTTXN = NewInstance C_SFTTXN AllocGroup null
    If fmet SFTTXN.SFTAUTOBREAK(EMP_LIST(X), FCY) <> [V]CST_AOK
      ERRNUM=[L]RETSTATUS : ERRMSG = SFTTXN.AERROR.MES
    Endif

    #We need to make sure auto breaks are called for the machine record for detailed teams in case they need to get stopped.
    If TEAMNUM <> 0 and TEAMNUM <> SFTTXN.EMPNUM and ERRNUM = [V]CST_AOK and X = maxtab(EMP_LIST)
    #When X = maxtab(EMP_LIST) we are on the last loop, we now want to do detailed team
      If fmet SFTTXN.SFTAUTOBREAK(TEAMNUM, FCY) <> [V]CST_AOK
        ERRNUM=[L]RETSTATUS : ERRMSG = SFTTXN.AERROR.MES
      Endif
    Else
      # TTD-2536. Check if this is a team member that stopping the team task and
      # ...is this a last team member that work on a team task. Run autobreak for the team record(s)
      If LAST_TEAM_MEMBER = [V]CST_AYES
        If fmet SFTTXN.SFTAUTOBREAK([F:SFTX]TEAMNUM, FCY) <> [V]CST_AOK
          ERRNUM=[L]RETSTATUS : ERRMSG = SFTTXN.AERROR.MES
        Endif
      Endif
    Endif
    # TTD-2397/2412.e

    If ERRNUM<>[V]CST_AOK : Call ERREUR(ERRMSG) From GESECRAN : Endif

  Next  # EMP_LIST(X)

  FreeGroup SFTTXN

  # Update transaction id on the restart operations
  If EMPTEAMNUM <> 0
    Call UPDATE_TRANSACTION_ID(AVOID.AUUID, 0, EMP_LIST(1), EMPTEAMNUM) From SFTTXN_CSTD
  Else
    Call UPDATE_TRANSACTION_ID(AVOID.AUUID, 0, EMP_LIST(1), TEAMNUM) From SFTTXN_CSTD
  Endif
End
######################################################################################
Subprog MACHINE_STOP(IEMPNUM, ITEAMNUM, ISFTTYP,IVCRNUM, ISFTSEQ, ISTOPTIME, IERR, IERRMSG)
Value     Integer   IEMPNUM
Value     Integer   ITEAMNUM
Value     Integer   ISFTTYP
Value     Char      IVCRNUM
Value     Integer   ISFTSEQ
Value     Datetime  ISTOPTIME
Variable  Integer   IERR
Variable  Char      IERRMSG

  Local Uuident ITXNUUID
  Local Integer ISTATUS
  Local Integer TRANSFER
  Local Char    IFCY(5)
  Local Integer MACSEQ
  Local Integer NEWEMPNUM
  Local Integer INUMMAC
  Local Char    IWCENTER
  Local Integer TEMP_TEAMNUM
  Local Integer NEWSFTTYP   #53701.n

  If !clalev([SFTX])
    Local File SFTTXN [SFTX]
  Else
    LogicClose File [SFTX]
    Local File SFTTXN [SFTX]
  Endif

  If !clalev([SFTX2])
      Local File SFTTXN [SFTX2]   #53701.n
  Endif

  Local Instance SFTTXN Using C_SFTTXN
  SFTTXN = NewInstance C_SFTTXN AllocGroup null

  Read [SFTX]SFT0 = [L]IEMPNUM;[L]ISFTTYP;[L]IVCRNUM;[L]ISFTSEQ

  #No Transaction ID, no more to do
  [L]ITXNUUID = [SFTX]TXNUUID
  If ITXNUUID = AVOID.AUUID
    Goto MACHINE_STOP_END
  Endif

  #Get the associated machine record attatched to this Trasaction ID
  If ITXNUUID <> AVOID.AUUID
    # TTD-1447.s
    # Check if there is another employee open with the same transaction ID
    # if yes, meaning we should not stop the team record yet.
    # Let the last employee to stop the team record(s).
    Filter [SFTX] Where MACFLG <> [V]CST_AYES & EMPNUM <> IEMPNUM  & EMPNUM <> ITEAMNUM & TXNUUID = [L]ITXNUUID & UTCENDDATTIM = AVOID.ADATTIM
    Read [SFTX] First
    If fstat = 0 # Found one
      Goto MACHINE_STOP_END
    Endif
    Filter [SFTX]

    # Machine only record that belong to another team member?
    Filter [SFTX] Where MACFLG = [V]CST_AYES & EMPNUM <> IEMPNUM  & EMPNUM <> ITEAMNUM & TXNUUID = [L]ITXNUUID & UTCENDDATTIM = AVOID.ADATTIM
    Read [SFTX] First
    If fstat = 0 # Found one
      Goto MACHINE_STOP_END
    Endif
    Filter [SFTX]
    # TTD-1447.e

    Filter [SFTX] Where MACFLG = [V]CST_AYES and TXNUUID = [L]ITXNUUID & UTCENDDATTIM = AVOID.ADATTIM
    Read [SFTX] First
    If fstat #None exist so end
      Goto MACHINE_STOP_END
    Endif
  Else
    Filter [SFTX] Where EMPNUM = [L]IEMPNUM & SFTTYP = [L]ISFTTYP & VCRNUM = [L]IVCRNUM &
&                       MACFLG = [V]CST_AYES & UTCENDDATTIM = AVOID.ADATTIM
    Read [SFTX] First
    If fstat #None exist so end
      Goto MACHINE_STOP_END
    Endif
  Endif

  INUMMAC = [SFTX]NUMMAC

  #Read correct record into the Instance
  [L]ISTATUS = fmet SFTTXN.AREAD([SFTX]EMPNUM, [SFTX]SFTTYP, [SFTX]VCRNUM, [SFTX]SFTSEQ)
  If [L]ISTATUS <> [V]CST_AOK
    [L]IERR=[L]ISTATUS : [L]IERRMSG = SFTTXN.AERROR.MES # TTD-2123. Wrong instance was used.
    Goto MACHINE_STOP_END
  Endif

  TEMP_TEAMNUM  = [F:SFTX]TEAMNUM
  IFCY          = [SFTX]FCY
  IWCENTER      = [SFTX]WCENTER
  MACSEQ        = [SFTX]SFTSEQ

  If ITEAMNUM <> [F:SFTX]TEAMNUM
    #We have a machine from a team activity but stopping it outside a team.
    #We need to try and give it to a team member first if possible
    Filter [SFTX] Where UTCENDDATTIM = AVOID.ADATTIM  and TXNUUID = ITXNUUID and EMPNUM <> SFTTXN.EMPNUM and EMPNUM <> TEMP_TEAMNUM

    For [SFTX]
        TRANSFER=[V]CST_ANO
        Break
    Next
  Endif

  If TRANSFER=[V]CST_ANO
    # There is a team record running that can take the record.
    # Nothing left to do then.
    Goto MACHINE_STOP_END
  Endif

#53701.so
#  If SFTTXN.SFTTYP = 5  # TTD-2018. Run operation
    # If any other open records exist on this operation and NUMMAC=No for all, transfer Machine record from this one
    # TTD-2123. Add SFTTYP = SFTTXN.SFTTYP to filter the type in the scenario that two different team/employee running the
    # same operation but one run the setup and run the Run.
#53701.eo

  #53701 - we can transfer a machine from a run to a setup or a setup to a run if need be
  If SFTTXN.SFTTYP=4 or SFTTXN.SFTTYP=5

#53701.so
#    Filter [SFTX] Where VCRNUM = SFTTXN.VCRNUM and OPENUM = SFTTXN.OPENUM and SFTTYP = SFTTXN.SFTTYP and EMPNUM <> SFTTXN.EMPNUM
#&                 and (UTCENDDATTIM = AVOID.ADATTIM | BRKTXN <> AVOID.AUUID)  and (TEAMNUM <> TEMP_TEAMNUM or TEAMNUM = AVOID.AINT) # TTD - 1924. Add "| BRKTXN <> AVOID.AUUID"
#53701.eo

    #53701.sn - pass to teh oldest record first
    Filter [SFTX] Where VCRNUM = SFTTXN.VCRNUM and OPENUM = SFTTXN.OPENUM and SFTTYP= SFTTXN.SFTTYP and EMPNUM <> SFTTXN.EMPNUM
&                 and (UTCENDDATTIM = AVOID.ADATTIM | BRKTXN <> AVOID.AUUID)  and (TEAMNUM <> TEMP_TEAMNUM or TEAMNUM = AVOID.AINT) Order By UTCSTRDATTIM Asc

    For [SFTX]
      #Grab the info for the first thing we find and break out, making sure to get the Transaction ID.
      If [F:SFTX]NUMMAC=[V]CST_ANO    # TODAN-119090
#      If [F:SFTX]NUMMAC=0
        #53701.sn JOBRO - see if this employee has a machine record already
        Filter [F:SFTX2] Where EMPNUM=[F:SFTX]EMPNUM and VCRNUM = SFTTXN.VCRNUM
&         and OPENUM = SFTTXN.OPENUM and SFTTYP = [F:SFTX]SFTTYP  and MACFLG=[V]CST_AYES and NUMMAC=[V]CST_AYES
        Read [F:SFTX2] First
        Filter [F:SFTX2]
        If fstat
        #53701.en
          NEWEMPNUM = [F:SFTX]EMPNUM
          SEQNUM    = [F:SFTX]SFTSEQ
          TXNUUID   = SFTTXN.TXNUUID
          ITEAMNUM  = 0
          TRANSFER=[V]CST_AYES
          NEWSFTTYP = [F:SFTX]SFTTYP
          Break
        Endif                 #53701.n
      Endif
    Next
  Endif # TTD-2018. If SFTTXN.SFTTYP = 5

  #  #If the machine record has a TEAMNUM that isnt the same as its EMPNUM it means its a dummy record from MACHINE only Detailed team.
  If SFTTXN.TEAMNUM <> 0 and SFTTXN.TEAMNUM <> SFTTXN.EMPNUM
    [L]ISTOPTIME = SFTTXN.UTCSTRDATTIM
  Endif

  [L]ISTATUS = fmet SFTTXN.OPERATION_STOP([L]ISTOPTIME, [L]IFCY, AVOID.AINT, AVOID.AINT, AVOID.AINT, [V]CST_ANO) # TODAN-119641.n
#    [L]ISTATUS = fmet SFTTXN.OPERATION_STOP([L]ISTOPTIME, [L]IFCY, AVOID.AINT, AVOID.AINT, AVOID.AINT, AVOID.AINT)# TODAN-119641.O
  If ISTATUS <> [V]CST_AOK
    [L]IERR=[L]ISTATUS : [L]IERRMSG = SFTTXN.AERROR.MES
    Goto MACHINE_STOP_END
  Endif

  # Transferring the machine to another person
  If TRANSFER = [V]CST_AYES
    # Create a new one for the new found employee
    [L]ISTATUS = fmet SFTTXN.AREAD(NEWEMPNUM, NEWSFTTYP, IVCRNUM, [SFTX]SFTSEQ)
    If [L]ISTATUS <> [V]CST_AOK
      [L]IERR=[L]ISTATUS : [L]IERRMSG = SFTTXN.AERROR.MES # TTD-2123. Wrong instance was used.
      Goto MACHINE_STOP_END
    Endif

    # 53701.so
    # Create the new machine record for the employee
#      [L]ISTATUS = func SFTTXN_CSTD.MACHINE_START(SFTTXN.EMPNUM, SFTTXN.TEAMNUM, SFTTXN.FCY, SFTTXN.SFTTYP, AVOID.ADATE, ISTOPTIME, AVOID.ADATTIM, SFTTXN.UTCOFFSET,
#&                                       SFTTXN.VCRNUM, SFTTXN.OPENUM, SFTTXN.OPEUOM, INUMMAC, AVOID.ADEC, IWCENTER, IWCENTER, SFTTXN.TXNUUID)
    # 53701.eo

    # 53701.sn  JOBRO
    # We need to stop a labor only employee record and start a new one tied to the machine

    # Stop the labor only one
    [L]ISTATUS = fmet SFTTXN.OPERATION_STOP([L]ISTOPTIME, [L]IFCY, AVOID.AINT, AVOID.AINT, AVOID.AINT, [V]CST_ANO)

    # Start the new labor and machine
    Local Instance NEW_SFTTXN Using C_SFTTXN
    NEW_SFTTXN = NewInstance C_SFTTXN AllocGroup null
    [L]ISTATUS = fmet NEW_SFTTXN.OPERATION_START(SFTTXN.EMPNUM, SFTTXN.FCY, 1, NEWSFTTYP, [L]ISTOPTIME,
&                                             SFTTXN.VCRNUM, SFTTXN.OPENUM, INUMMAC, IWCENTER, SFTTXN.WCENTER,
&                                             SFTTXN.OPEUOM, [V]CST_ANO, 1, 0)
    # 53701.en  JOBRO

    [L]ISTATUS =  fmet SFTTXN.AUPDATE
    If [L]ISTATUS <> [V]CST_AOK
      [L]IERR=[L]ISTATUS : [L]IERRMSG = SFTTXN.AERROR.MES
      Goto MACHINE_STOP_END
    Endif


  Endif


  MACHINE_STOP_END:
  FreeGroup SFTTXN
  Kill SFTTXN
  LogicClose File [SFTX]

End

######################################################################################
# Stop all open activities. This is used when an employee stops any team task.
######################################################################################
Subprog STOP_ALL_ACTIVITIES(IEMPNUM, ISTOPTIME)
  Value Integer  IEMPNUM
  Value Datetime ISTOPTIME

  Local Integer   IERR
  Local Integer   ERRNUM
  Local Char      ERRMSG

  Local Integer   ISTATUS
  Local Datetime  T_STOPTIME : T_STOPTIME = ISTOPTIME

  If !clalev([SFTXT]) : Local File SFTTXN [SFTXT] : Endif
  Local Instance SFTTXN_T Using C_SFTTXN
  SFTTXN_T = NewInstance C_SFTTXN AllocGroup null

  Filter [SFTXT] Where EMPNUM = IEMPNUM and UTCENDDATTIM = AVOID.ADATTIM and SFTTYP <> 1
  For [SFTXT]

    #Read correct record into the Instance
    [L]ISTATUS = fmet SFTTXN_T.AREAD([SFTXT]EMPNUM, [SFTXT]SFTTYP, [SFTXT]VCRNUM, [SFTXT]SFTSEQ)
    If [L]ISTATUS <> [V]CST_AOK
      [L]ERRNUM=[L]ISTATUS : [L]ERRMSG = SFTTXN_T.AERROR.MES
      Break
    Endif

    #This should only happen for Detailed team machine only records
    If SFTTXN_T.MACFLG = [V]CST_AYES and SFTTXN_T.TEAMNUM <> 0 and SFTTXN_T.TEAMNUM <> SFTTXN_T.EMPNUM
      ISTOPTIME = SFTTXN_T.UTCSTRDATTIM #We want the duration for the team members machine record to be 0 so that extra time isnt posted
    Endif

    [L]ISTATUS = fmet SFTTXN_T.OPERATION_STOP(ISTOPTIME, SFTTXN_T.FCY, AVOID.AINT, AVOID.AINT, AVOID.AINT, [V]CST_ANO)    # TODAN-119641.n
#    [L]ISTATUS = fmet SFTTXN_T.OPERATION_STOP(ISTOPTIME, SFTTXN_T.FCY, AVOID.AINT, AVOID.AINT, AVOID.AINT, AVOID.AINT)   # TODAN-119641.o

    If [L]ISTATUS <> [V]CST_AOK
      ERRNUM=[L]ISTATUS : ERRMSG = SFTTXN_T.AERROR.MES
      Break
    Endif

    ISTOPTIME = T_STOPTIME #Reset STOPTIME in case we changed it for detailed team machine only

    Call MACHINE_STOP([SFTXT]EMPNUM, [SFTXT]TEAMNUM, [SFTXT]SFTTYP, [SFTXT]VCRNUM, [SFTXT]SFTSEQ, ISTOPTIME, ERRNUM, ERRMSG) #TTD - 1447.n

  Next

  If ERRNUM<>[V]CST_AOK : Call ERREUR(ERRMSG) From GESECRAN : Endif

  FreeGroup SFTTXN_T
  Kill SFTTXN_T
  LogicClose File [SFTXT]
End

######################################################################################
# Stop employee open team activities
######################################################################################
Subprog STOP_OPEN_ACTIVITIES(ITEAMNUM, IEMPNUM,ERRNUM,ERRMSG)
  Value    Integer  ITEAMNUM
  Value    Integer  IEMPNUM
  Variable Integer  ERRNUM
  Variable Char     ERRMSG

  Local Datetime    STOPTIME
  Local Integer     RETSTATUS
  Local Char        CRIT(255)

  [L]STOPTIME = datetime$

  Raz ERRNUM

  If !clalev([SFTX])
    Local File SFTTXN [SFTX]
  Else
    LogicClose File [SFTX]
    Local File SFTTXN [SFTX]
  Endif

  Local Instance SFTTXN_STOP Using C_SFTTXN
  SFTTXN_STOP = NewInstance C_SFTTXN AllocGroup null

  CRIT = 'EMPNUM =' + num$(IEMPNUM)

  If ITEAMNUM<>AVOID.AINT
    CRIT -= '& TEAMNUM =' + num$(ITEAMNUM)
  Endif

  For [F:SFTX] Where SFTTYP <> 1 & UTCENDDATTIM = AVOID.ADATTIM & evalue(CRIT)
    # Read the correct record then call the correct method
    [L]RETSTATUS = fmet SFTTXN_STOP.AREAD([F:SFTX]EMPNUM, [F:SFTX]SFTTYP, [F:SFTX]VCRNUM, [F:SFTX]SFTSEQ)
    If [L]RETSTATUS <> [V]CST_AOK
      ERRNUM=[L]RETSTATUS : ERRMSG = SFTTXN_STOP.AERROR.MES
      Break
    Endif

    If [F:SFTX]SFTTYP=3 | ([F:SFTX]SFTTYP=2 & [F:SFTX]INDTYP=4) # Break/Exclusive Indirect Operation Stop
      [L]RETSTATUS = fmet SFTTXN_STOP.BREAK_STOP_NO_RESTART([L]STOPTIME,[F:SFTX]SFTTYP)
      If [L]RETSTATUS <> [V]CST_AOK
        ERRNUM=[L]RETSTATUS : ERRMSG = SFTTXN_STOP.AERROR.MES
        Break
      Endif
    Else
      # Stop the operation(s)
      [L]RETSTATUS = fmet SFTTXN_STOP.OPERATION_STOP([L]STOPTIME, [F:SFTX]FCY, AVOID.AINT, AVOID.AINT, AVOID.AINT, [V]CST_ANO)  # TODAN-119641.n
#      [L]RETSTATUS = fmet SFTTXN_STOP.OPERATION_STOP([L]STOPTIME, [F:SFTX]FCY, AVOID.AINT, AVOID.AINT, AVOID.AINT, AVOID.AINT) # TODAN-119641.o
      If [L]RETSTATUS <> [V]CST_AOK
        ERRNUM=[L]RETSTATUS : ERRMSG = SFTTXN_STOP.AERROR.MES
        Break
      Else
        # Stop machine transaction if needed
        Call MACHINE_STOP([F:SFTX]EMPNUM, 0, [F:SFTX]SFTTYP, [F:SFTX]VCRNUM, [F:SFTX]SFTSEQ, [L]STOPTIME, ERRNUM, ERRMSG)
        If ERRNUM <> [V]CST_AOK : End : Endif
      Endif
    Endif
  Next
  LogicClose File [SFTX]
End
####################################################################################
#TTD-2129.s
Subprog STOP_TEAM_RECORDS(IEMPNUM, ITEAMNUM, ITXNUUID, ISTOPTIME)
Value Integer     IEMPNUM
Value Integer     ITEAMNUM
Value Uuident     ITXNUUID
Value Datetime    ISTOPTIME

  Local Integer   ERRNUM
  Local Char      ERRMSG
  Local Integer   TEAM_REC_ONLY

  Local File SFTTXN [SFTXSTR]

  TEAM_REC_ONLY = [V]CST_AYES

  If ITXNUUID <> AVOID.AUUID
    Filter [SFTXSTR] Where TXNUUID = ITXNUUID & UTCENDDATTIM = AVOID.ADATTIM
    # If there is only 1 record that mean this is a team machine record.
    If rowcount([SFTXSTR]) = 1
      Read [SFTXSTR] First
      If [F:SFTXSTR]EMPNUM = ITEAMNUM
        # Stop team machine transaction
        Call MACHINE_STOP([F:SFTXSTR]EMPNUM, [F:SFTXSTR]TEAMNUM, [F:SFTXSTR]SFTTYP,
&                       [F:SFTXSTR]VCRNUM, [F:SFTXSTR]SFTSEQ, [L]ISTOPTIME, ERRNUM, ERRMSG)
        If ERRNUM <> [V]CST_AOK : End : Endif
      Endif
    Endif
  Else
    # Check if there is another break/indirect exclusive
    Filter [SFTXSTR] Where EMPNUM <> IEMPNUM & TEAMNUM = ITEAMNUM & BRKTXN <> AVOID.AUUIDENT
    Look [SFTXSTR] First
    Filter [SFTXSTR]
    If fstat  # Not found
      # Look for open records that is not a team records
      Filter [SFTXSTR] Where EMPNUM <> IEMPNUM & TEAMNUM = ITEAMNUM & SFTTYP<>1 & UTCENDDATTIM=AVOID.ADATTIM
      For [SFTXSTR]
        If [SFTXSTR]EMPNUM <> ITEAMNUM
          TEAM_REC_ONLY = [V]CST_ANO
          Break
        Endif
      Next
      Filter [SFTXSTR]
    Else
      TEAM_REC_ONLY = [V]CST_ANO
    Endif

    If TEAM_REC_ONLY = [V]CST_AYES
      Filter [SFTXSTR] Where EMPNUM <> IEMPNUM & TEAMNUM = ITEAMNUM & SFTTYP<>1 & UTCENDDATTIM=AVOID.ADATTIM
      For [SFTXSTR]
        Call MACHINE_STOP([F:SFTXSTR]EMPNUM, [F:SFTXSTR]TEAMNUM, [F:SFTXSTR]SFTTYP,
&                         [F:SFTXSTR]VCRNUM, [F:SFTXSTR]SFTSEQ, [L]ISTOPTIME, ERRNUM, ERRMSG)
        If ERRNUM <> [V]CST_AOK : End : Endif
      Next
      Filter [SFTXSTR]
    Endif

  Endif

  Filter [SFTXSTR]
  LogicClose File [SFTXSTR]
End
#TTD-2129.e
####################################################################################
# TTD-2536.sn
Funprog LAST_TEAM_MEMBER_ON_TEAM_TASK(IEMPNUM, ITEAMNUM)
Value Integer IEMPNUM
Value Integer ITEAMNUM

  Local Integer RETVAL
  Local File SFTTXN [SFTXLTM]

  RETVAL = [V]CST_AYES

  Filter [SFTXLTM] Where EMPNUM <> IEMPNUM  & TEAMNUM = ITEAMNUM & EMPNUM <> ITEAMNUM  & UTCENDDATTIM = AVOID.ADATTIM
  Look [SFTXLTM] First
  If !fstat # Found one
    RETVAL = [V]CST_ANO
  Endif
  Filter [SFTXLTM]
  LogicClose File [SFTXLTM]

End RETVAL
# TTD-2536.en
################################################################################################
# TODAN-119090. Verify if the operation already run in SFTXN table
################################################################################################
Funprog OPERATION_RUN(VCRNUM, OPENUM, WCENTER)
Value Char VCRNUM
Value Integer OPENUM
Value Char WCENTER

  Local Integer OPER_RUN
  Local File SFTTXN [SFTXOR]

  OPER_RUN = [V]CST_ANO

  Filter [F:SFTXOR] Where [F:SFTXOR]VCRNUM = [L]VCRNUM & [F:SFTXOR]OPENUM = [L]OPENUM &
&                         [F:SFTXOR]WCENTER = [L]WCENTER & [F:SFTXOR]SFTTYP = 5  &
&                         [F:SFTXOR]UTCENDDATTIM = AVOID.ADATTIM & [F:SFTXOR]NUMMAC = 2

  Look [SFTXOR]First
  Filter [SFTXOR]
  If !fstat   # Record found
    OPER_RUN = [V]CST_AYES
  Endif

  LogicClose File [SFTXOR]

End OPER_RUN
####################################################################################
Funprog OPERATION_SETUP(VCRNUM, OPENUM, WCENTER)
Value Char VCRNUM
Value Integer OPENUM
Value Char WCENTER

  Local Integer OPER_SETUP
  Local File SFTTXN [SFTXOS]

  OPER_SETUP = [V]CST_ANO

  Filter [F:SFTXOS] Where [F:SFTXOS]VCRNUM = [L]VCRNUM & [F:SFTXOS]OPENUM = [L]OPENUM &
&                         [F:SFTXOS]WCENTER = [L]WCENTER & [F:SFTXOS]SFTTYP = 4  &
&                         [F:SFTXOS]UTCENDDATTIM = AVOID.ADATTIM & [F:SFTXOS]NUMMAC = 2

  Look [SFTXOS]First
  Filter [SFTXOS]
  If !fstat   # Record found
    OPER_SETUP = [V]CST_AYES
  Endif

  LogicClose File [SFTXOS]

End OPER_SETUP
################################################################################################
# 53701 - JOBRO See if a machine should be started for this employee start operation
################################################################################################
Funprog START_ANOTHER_MACHINE(ISFTTYP, VCRNUM, OPENUM, WCENTER, IFCY)
Value Integer ISFTTYP
Value Char VCRNUM
Value Integer OPENUM
Value Char WCENTER
Value Char IFCY

  Local Integer START_IT, NUMBER_STARTED
  Local File SFTTXN     [SFTXAM]
  Local File WORKSTATIO [MWSAM]

  START_IT = [V]CST_ANO
  NUMBER_STARTED = 0

  # Read Workcenter
  Read [F:MWSAM]WST0=WCENTER;IFCY
  If fstat or [F:MWSAM]WSTTYP <> 1  # can't find it or not a machine workcenter
    Goto ANOTHER_MACHINE_END
  Endif

  Filter [F:SFTXAM] Where [F:SFTXAM]VCRNUM = [L]VCRNUM & [F:SFTXAM]OPENUM = [L]OPENUM &
&                         [F:SFTXAM]WCENTER = [L]WCENTER & [F:SFTXAM]SFTTYP = ISFTTYP  &
&                         [F:SFTXAM]UTCENDDATTIM = AVOID.ADATTIM & [F:SFTXAM]NUMMAC = 2

  For [F:SFTXAM]
    NUMBER_STARTED += 1
  Next
  Filter [SFTXAM]

  # if the number of machines started on this operation is less than
  # the number of resources on the workcenter then start another machine
  If NUMBER_STARTED < [F:MWSAM]WSTNBR
    START_IT = [V]CST_AYES
  Endif

$ANOTHER_MACHINE_END

  LogicClose File [SFTXAM]
  LogicClose File [MWSAM]

End START_IT
################################################################################################
# 53701 - JOBRO See if this type of employee can start this operation
################################################################################################
Funprog CAN_START_OPERATION(IEMPTYP, IEMPNUM, ISFTTYP, IVCRNUM, IOPENUM)
Value Integer IEMPTYP
Value Integer IEMPNUM
Value Integer ISFTTYP
Value Char IVCRNUM
Value Integer IOPENUM

Local File SFTTXN [CSOSFTX]

Local Integer CAN_DO_IT
CAN_DO_IT = [V]CST_AYES

If IEMPTYP = 1    # Employee
  Filter [CSOSFTX] Where VCRNUM=IVCRNUM and OPENUM = IOPENUM and EMPNUM <> IEMPNUM
&   and SFTTYP = ISFTTYP and UTCENDDATTIM = AVOID.ADATTIM

  For [F:CSOSFTX]
    If func SFTLIB.EMPTYP([F:CSOSFTX]EMPNUM)> 1 or [F:CSOSFTX]TEAMNUM>0 # employee can't join if team started it
      CAN_DO_IT = [V]CST_ANO
      Break
    Endif
  Next
Else              # Detail or Summary team
  Filter [CSOSFTX] Where VCRNUM=IVCRNUM and OPENUM = IOPENUM and EMPNUM <> IEMPNUM
&   and SFTTYP = ISFTTYP and UTCENDDATTIM = AVOID.ADATTIM
  Read [F:CSOSFTX] First
  If fstat=0  : CAN_DO_IT = [V]CST_ANO  : Endif # team can't join if it is already started
Endif

LogicClose File [CSOSFTX]

End CAN_DO_IT

################################################################################################
# 53701 - JOBRO See if a machine should be started for this employee start operation
################################################################################################
Funprog START_MACHINE(IEMPTYP, IEMPNUM, ISFTTYP, IVCRNUM, IOPENUM, IWCENTER, ILCENTER, IFCY)
Value Integer IEMPTYP
Value Integer IEMPNUM
Value Integer ISFTTYP
Value Char IVCRNUM
Value Integer IOPENUM
Value Char IWCENTER
Value Char ILCENTER
Value Char IFCY

  Local Integer START_IT, NUMBER_STARTED
  Local File WORKSTATIO [MWSSM]

  START_IT = [V]CST_ANO

  # Read Workcenter
  Read [F:MWSSM]WST0=IWCENTER;IFCY
  If fstat or [F:MWSSM]WSTTYP <> 1  # can't find it or not a machine workcenter
    Goto START_MACHINE_END
  Endif

  # if there are no machines running then set to Yes
  If ISFTTYP=5 and func SFTLIB.OPERATION_RUN(IVCRNUM,IOPENUM,IWCENTER) = [V]CST_ANO
     START_IT = [V]CST_AYES
  Elsif ISFTTYP=4 and func SFTLIB.OPERATION_SETUP(IVCRNUM,IOPENUM,IWCENTER) = [V]CST_ANO
     START_IT = [V]CST_AYES
  # if there is no labor work center, set to Yes
  Elsif ILCENTER = AVOID.ACHAR
     START_IT = [V]CST_AYES
  Endif

  # if it is an employee and the other conditions didn't
  # kick in, then check to see if they can based on number of resources
  If IEMPTYP=1 and START_IT=[V]CST_ANO
    # compare number running versus number of resources
    START_IT = func SFTLIB.START_ANOTHER_MACHINE(ISFTTYP,IVCRNUM,IOPENUM,IWCENTER,IFCY)
  Endif

$START_MACHINE_END

  LogicClose File [MWSSM]

End START_IT

