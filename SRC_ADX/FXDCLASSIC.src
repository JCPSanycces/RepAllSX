#**
#* fonctions intermédiaires (classique/syracuse)
#* créée par FQ100398/13
#*!
$ACTION

  Case ACTION
    When "SEL_TABLE"        : Gosub SEL_TABLE
    When Default
  Endcase

Return


$SEL_TABLE

  Case TABLE
    When "SELLCT"    : Gosub SET_LCTFCY
  Endcase

Return

#**
#* liste des localisations
#* vient de SUBLCZ : sel de l'ancienne localisation ($SET_LOCFCY)
#*!
$SET_LCTFCY

Local Char WFCYTR(GLONFCY)
Local Char WCPYTR(GLONCPY)

  WFCYTR = PARAM(1) : # Facility
  WCPYTR = PARAM(2) : # Company

  If clalev([F:LCT]) = 0
    Local File PHYLCT [LCT]
  Endif

  If WFCYTR <> ""
    CRITERE = "FCY = WFCYTR"
  Elsif WCPYTR <> ""
    CRITERE = "LEGCPY = WCPYTR"
  Endif

##------------------------------------------------------------------------------------------------##
## Formatage de la dialogue de sélection -->                                                      ##
##   Le titre de la dialogue de selection est alimentée                                           ##
##   Pour chaque colonne -> le nom de la rubrique et le libelle de la colonne est alimenté        ##
##   la valeur à récuperer de la table est précisé : START                                        ##
##------------------------------------------------------------------------------------------------##
  Default File [LCT]

  Local Char CODFIC(10)
  CODFIC = "PHYLCT"
  Call TITOBJ("LCT","!",TIT(0)) From CONTOBJ
  TIT(0)  = mess(12,123,1)-TIT(0) : # Choix
  SIZLIG = 80             : # Défaut 80  (10 lig en 8eme de ligne)
  SIZCOL = 240            : # Défaut 240 (60 col en quart de colonne)
  NBCOL  = 0

  NBCOL += 1
  COL(NBCOL) = "FCY"
  Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1
  COL(NBCOL) = "LCTCOD"
  Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
  NBCOL += 1
  COL(NBCOL) = "LCTDES"
  Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV

  DEFPAG  = 1                            : # Pagination
  START   = "LCTCOD"                     : # Colonne à récupérer suite au choix
  ORDRE   = "FCY; LCTCOD"

Return
