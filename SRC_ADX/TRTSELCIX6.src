#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################################################
# TRTSELCIX6            TRAITEMENTS DE SELECTION DES VALEURS D'INDICE      08/02/2006      MODULE CRM    #
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "FINSAI"       : Gosub FINSAI
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  If PARAM(2) = "" Then
    GERR = 2  
    FIN = 1 
    #Il faut d'abord saisir un indice.
    GMESSAGE = mess(240,177,1) 
    Return
  Endif

Global Char GZORIGINE
Global Char GZCODEINDICE

  If !clalev([F:CIX]) : Local File CONTIDX [CIX] : Endif
  GZORIGINE = PARAM(1)
  GZCODEINDICE = PARAM(2)
Return

##########################################################################################################
$DEBUT
  Gosub LOADCIX
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  If clalev([M:CIX6]) > 0 Then
    Raz [M:CIX6]
    Kill GZORIGINE
    Kill GZCODEINDICE
  Endif
Return

##########################################################################################################
$ONOK
  If GZORIGINE = "CON4" Then
    # FGR 18/09/2007 : X3SUIVI40462 : Slt Si [M:CIX6]NBCIX6 > 0
    #                  Sinon on ecrase les valeurs qu'il peut y avoir dans CON4
    #                  Attention : pour ma mémoire, on est automatiquement positionné sur la 1ère ligne
    ##                 lorsque la liste n'est pas vide. Donc si on fait Ok, ça récupère les valeur de cette ligne
    If [M:CIX6]NBCIX6 > 0 Then
      [M:CON4]LASVALIDX = [M:CIX6]INDVAL(nolign-1)
      [M:CON4]LASIDXDAT = [M:CIX6]INDDAT(nolign-1)
      Affzo [M:CON4]LASVALIDX
      Affzo [M:CON4]LASIDXDAT
      mkstat = 4
    Endif
  Endif
Return

##########################################################################################################
# Sous-programmes
#########################################################
$LOADCIX
Local Integer ITER

  ITER = 0
  Filter [CIX] Where [F:CIX]IND = GZCODEINDICE Order By [F:CIX]INDDAT Desc
  For [CIX] Hint Key CIX1
    [M:CIX6]INDDAT(ITER) = [F:CIX]INDDAT
    [M:CIX6]INDVAL(ITER) = [F:CIX]INDVAL
    ITER += 1
  Next
  Filter [CIX]
  [M:CIX6]NBCIX6 = ITER
  Affzo [M:CIX6]1-99
Return
