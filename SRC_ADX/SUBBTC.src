#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion objet BTC
####################################################
## Paramétrage des taches comptables
####################################################

# Issue X3-113885 - 2018-10-23 by CBO : manage n folders
# Issue X3-111845 - 2018-10-05 by CBO : manage n folders
# Issue X3-111553 - 2018-10-04 by CBO : put the good folder in ABA : new field CODABT
# Issue X3-59028 - 2018-01-09 by CBO : Changes of accounting task for mindo

Raz GPILOBJ
Call OBJET("BTC",GBIDC1,GBIDC2) From GOBJET
End

$ACTION

Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "FILTRE"    : Gosub FILTRE
# When "INICRE"    : Gosub INICRE # Issue X3-59028
 When "CREATION"  : Gosub CREATION
 When "LIENS2"    : Gosub LIENS2
 When "SETBOUT"   : Gosub SETBOUT
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "AFFMASK"   : Gosub AFFMASK
 When "ANNULE"    : Gosub ANNULE
 When "AP_ANNULE" : Gosub RENUM
Endcase

Return

$OUVRE

Local Integer WTSK_STA_IS_STOPPED, FLMODIF
Local Char WPARAM(10)
Global Integer GMULBATCH
Local Integer QURSTA  # Query Progress Status

  Call PARAM("", "MULBATCH", WPARAM) From ADOVAL
  If WPARAM = "2"
    GMULBATCH = [V]CST_AYES
  Else
    GMULBATCH = [V]CST_ANO
  Endif
  If clalev([F:ABA])=0 : Local File ABATABT [ABA] : Endif # Issue X3-59028

  If clalev([F:ABD])=0 : Local File ABATABTD  [ABD] : Endif # Issue X3-111845
  If clalev([F:A22])=0 : Local File ABATABTD2 [A22] : Endif # Issue X3-111845
  If clalev([F:A11])=0 : Local File ABATRQT2  [A11] : Endif # Issue X3-111845
  If clalev([F:ABR])=0 : Local File ABATRQT   [ABR] : Endif # Issue X3-111845

Return

$FILTRE

  If GMULBATCH = [V]CST_AYES
    FILTSUP = 'COD <> "ACCENTRY"'
  Else
    FILTSUP = 'COD = "ACCENTRY"'
  Endif

Return

$LIENS2

Local Decimal WNUM_RQT # Issue X3-59028
Local Date WDATE
Local Char WTIME(20)

  FLMODIF = 1
  For I=0 To [M]NBLIG-1
    Call QUERY_STA([M]CODABT(I), QURSTA, WTSK_STA_IS_STOPPED, WNUM_RQT, WDATE, WTIME) From CPTBATCH # Issue X3-59028
    If WTSK_STA_IS_STOPPED
      [M]ACT(I) = [V]CST_ANO
    Else
      [M]ACT(I) = [V]CST_AYES
      FLMODIF = 0
    Endif
    Affzo [M]ACT(I)
  Next

Return

# Issue X3-59028
$CREATION

  # Recurring task management
  Call CRT_ACC_REC_TASK([M:BTC1]CODABT(nolign - 1), [M:BTC1]COD(nolign - 1), nomap, [V]CST_ANO) # Issue X3-113885
  If fstat
    GOK = 0
  Endif
  Affzo [M:BTC1]ZCODABT(nolign - 1)

Return
# End Issue X3-59028

$SETBOUT

  If !FLMODIF
    Call VIREBOUT(CHAINE,"M") From GOBJET
  Endif

  If GMULBATCH <> [V]CST_AYES or (GMULBATCH = [V]CST_AYES and [M]ACT(0) = [V]CST_AYES)
    Call VIREBOUT(CHAINE,"A") From GOBJET
  Endif

Return

######################################################################################
$VERIF_MOD

  For I=0 To [M]NBLIG-2
    If [M]CRI(I)=""
      GMESSAGE = mess(153,105,1) : # Seule la dernière ligne peut être vide
      OK = 0
      Break
    Endif

    For J=I+1 To [M]NBLIG-1
      If ([M]ACC(I) = 2 and [M]ACC(J) = 2 and [M]CRI(I) = [M]CRI(J))
&     or ([M]MTC(I) = 2 and [M]MTC(J) = 2 and [M]CRI(I) = [M]CRI(J))
&     or ([M]BAL(I) = 2 and [M]BAL(J) = 2 and [M]CRI(I) = [M]CRI(J))
        GMESSAGE = mess(160,105,1) - ":" - [M]COD(I) - [M]COD(J) : # 2 tâches ont le même critère
        OK = 0
        Break
      Endif
    Next J
  Next I

Return

$ANNULE

Local Char WCODABT(GLONABA)

  # delete the recurring task linked to ACC TASK
  If nolign < 1
    Return
  Endif

  WCODABT = [M:BTC1]CODABT(nolign - 1)

  Delete [ABD] Where CODABT = WCODABT
  Delete [A22] Where CODABT = WCODABT
  Delete [A11] Where CODABT = WCODABT
  Delete [ABR] Where CODABT = WCODABT
  Delete [ABA] Where CODABT = WCODABT


Return

#**
#* Get the key for recurring task of accounting task
#* Create the recurring task for an accounting task
#*
#* @param RACCTSKREC  key
#*!
Subprog CRT_KEY_ABA_ACC_TASK(RACCTSKREC)
Variable Char RACCTSKREC()

Local Uuident ACCTSKREC
Local Integer WCPTR

  Local File ABATABT [ABA2] # Issue X3-113885

  ACCTSKREC = NullUuid
  WCPTR = 0

  While ACCTSKREC = NullUuid
    ACCTSKREC = getUuid
    RACCTSKREC = "WACC" + toupper(left$(num$(ACCTSKREC), 6))

    # verify if it already exists
    Read [ABA2]CODABT = RACCTSKREC
    If fstat
      # It's the good one
      Break
    Endif
    ACCTSKREC = NullUuid
    WCPTR += 1
    If WCPTR = 100
      Infbox "No Uuid free !"
      Break
    Endif
  Wend
  Close File [ABA2]

End
# Issue X3-59028 X3-113885
#**
#* Create the recurring task for an accounting task
#*
#* @param RCODABT   code of recurring task
#* @param PCOD      code of accounting task
#* @param PDOSSIER  current folder
#* @param PACTIV_REC_TASK  ENAFLG = local menu 1
#*!
Subprog CRT_ACC_REC_TASK(RCODABT, PCOD, PDOSSIER, PACTIV_REC_TASK)
Variable Char RCODABT()
Value Char PCOD()
Value Char PDOSSIER()
Value Shortint PACTIV_REC_TASK

Local Char W_TEMPLATE_REC(GLONABA)

  W_TEMPLATE_REC = func GET_TEMPLATE_ACCTASK_ABA()
  GMESSAGE = ""
  If PACTIV_REC_TASK <> [V]CST_AYES
    PACTIV_REC_TASK = [V]CST_ANO
  Endif

  Local File ABATABT   [ABA]
  Local File ABATTAC   [ABT]
  Local File ABATABTD  [ABD]

  # Issue X3-111553
  If RCODABT = ""
    Call CRT_KEY_ABA_ACC_TASK(RCODABT)
  Endif

  # Recurring task management
  Read [ABA]CODABT = RCODABT
  If fstat
    Read [ABA]CODABT = W_TEMPLATE_REC # template of recurring task
    If fstat
	    Call CRT_TEMPLATE_ACC_REC_TASK(W_TEMPLATE_REC)
  	  If GMESSAGE <> ""
    	  End
    	Endif

    Else
      # This recurring task template never must be active
      If [F:ABA]ENAFLG <> [V]CST_ANO
        [F:ABA]ENAFLG = [V]CST_ANO
        Rewrite [ABA]
      Endif
    Endif

    [F:ABA]CODABT = RCODABT
    [F:ABA]NOMABT = func GET_DESCRIPTION_ACC_TASK(PDOSSIER, PCOD)
    [F:ABA]DOSSIER = PDOSSIER # Issue X3-111553
    [F:ABA]ENAFLG = PACTIV_REC_TASK
    [F:ABA]FRQ = max(1, [F:ABA]FRQ)

    [F:ABA]USER = "ADMIN"
    Write [ABA]

    Gosub CREATION From SUBABA

  Else
    [F:ABA]NOMABT = func GET_DESCRIPTION_ACC_TASK(PDOSSIER, PCOD)
    [F:ABA]DOSSIER = PDOSSIER # Issue X3-111553
    [F:ABA]ENAFLG = PACTIV_REC_TASK
    [F:ABA]FRQ = max(1, [F:ABA]FRQ)
    Rewrite [ABA]
  Endif

  If fstat
    GMESSAGE = "Error, recurring task not updated :" - RCODABT
  Endif

End

Funprog GET_DESCRIPTION_ACC_TASK(PDOSSIER, PCOD)
Value Char PDOSSIER(), PCOD()

Local Char WDES(50)

  WDES = PDOSSIER - PCOD

End WDES
#**
#* Get the cod of template accounting task
#*!
Funprog GET_TEMPLATE_ACCTASK_ABA()

Local Char WABA(GLONABA)

  WABA = "WACCBATREC"

End WABA

#**
#* Create the template of recurring task for accounting task
#*
#* P_TEMPLATE_REC   accounting template task
#*!
Subprog CRT_TEMPLATE_ACC_REC_TASK(P_TEMPLATE_REC)
Value Char P_TEMPLATE_REC()

  Local File ABATABT [ABA] # Issue X3-113885
  Raz [F:ABA]
  [F:ABA]CODABT = P_TEMPLATE_REC
  [F:ABA]CNTERR = 2 # X3-111845
#  [F:ABA]DOSSIER = nomap # ou adxmother(0) ?
  [F:ABA]DOSSIER = GDOSX3 # Issue X3-111553
  [F:ABA]DREL = 1
  [F:ABA]ENAFLG = 1

  [F:ABA]EPUR = 2
  [F:ABA]FDM = 1
  [F:ABA]FORCE = 1
  [F:ABA]FRQ = 1
  [F:ABA]HDEB = "0500"

  [F:ABA]HFIN = "2200"
  [F:ABA]JOUR(0) = 2
  [F:ABA]JOUR(1) = 2
  [F:ABA]JOUR(2) = 2
  [F:ABA]JOUR(3) = 2

  [F:ABA]JOUR(4) = 2
  [F:ABA]JOUR(5) = 1
  [F:ABA]JOUR(6) = 1
  [F:ABA]NOMABT = "Accounting task (template)"
  [F:ABA]ONE = 1

  [F:ABA]PERIO = 1
  [F:ABA]TACHE = "ACCBATCH1"
  [F:ABA]USER = "ADMIN"

  Write [ABA]
  If fstat
    GMESSAGE = "Error, template recurring task not created :" - P_TEMPLATE_REC
  Else
    Gosub CREATION From SUBABA
  Endif

End
# End Issue X3-59028

######################################################################################
$AFFMASK

  If evalue("dim("+clanam([M])+"BAL)")>0
    If dim(GUPDBAL)<1 or GUPDBAL<>2
      Chgfmt [M]BAL With "-K:20B"
    Endif
  Endif

Return

######################################################################################
$SETNOL

Local Integer NOL
  NOL = nolign-1

Return

Subprog AS_NBLIG

  # No insert line allowed
  If (nolign > 1) and GMULBATCH <> [V]CST_AYES
    mkstat = 2
    GERR = 1
    GOK = 0
    End
  Endif

  If GMULBATCH = [V]CST_AYES and [M]ACT(0) <> [V]CST_AYES
    Enable 73 # Insert
#    Enable 65 # delete x lines
#    Enable 68 # delete a group
#    Enable 83 # delete all lines
    Gosub RENUM
  Else
    Disable 73
#    Disable 65
#    Disable 68
#    Disable 83
    Diszo CRI, ACC, MTC, BAL
  Endif
End

# Issue X3-59028
Subprog B1_NBLIG

  # Recurring task management
  Call OBJET("ABA", [M:BTC1]CODABT(nolign - 1), "") From GOBJET

End
# End Issue X3-59028


$RENUM

Local Integer NOL
Local Integer WTRBEGIN

  WTRBEGIN = 0 # X3-111845 : rename the COD and NOMABT (when a line is deleted)
  For NOL=0 To [M]NBLIG-1

    If [M:BTC1]COD(NOL) <> "ACCENTRY" + format$("N0:2#", NOL+1)
      If WTRBEGIN = 0
        Trbegin [BTC]
        WTRBEGIN = 1
      Endif

      Read [BTC]BTC0 = [M:BTC1]COD(NOL)
      [M:BTC1]COD(NOL) = "ACCENTRY" + format$("N0:2#", NOL+1)
      [F:BTC]COD = [M:BTC1]COD(NOL)
      Rewrite [BTC]

      Read [ABA]CODABT = [M:BTC1]CODABT(NOL)
      [F:ABA]NOMABT = func GET_DESCRIPTION_ACC_TASK(nomap, [M:BTC1]COD(NOL))
      Rewrite [ABA]

    Endif
  Next NOL

  If WTRBEGIN
    Commit
  Endif
  Affzo COD, CODABT, ZCODABT

Return

######################################################################################


Subprog AS_COD(VALEUR)
Variable Char    VALEUR()

  If VALEUR=""
    If GMULBATCH = [V]CST_AYES
      VALEUR = "ACCENTRY" + format$("N0:2#", nolign)
    Else
      VALEUR = "ACCENTRY"
    Endif
  Endif

  If [M:BTC1]CODABT(nolign-1) = ""
    Call CRT_KEY_ABA_ACC_TASK([M:BTC1]CODABT(nolign-1))
    [M:BTC1]ZCODABT(nolign-1) = func GET_DESCRIPTION_ACC_TASK(nomap, VALEUR)
    Affzo [M:BTC1]ZCODABT(nolign-1)
  Endif

  mkstat = 2

End

Subprog C_MTC(VALEUR)
Variable Integer VALEUR

  If dim(GUPDBAL)<1 or GUPDBAL<>2
    If VALEUR = 1 and [M]ACC(nolign-1) = 1
      mkstat = 2
      End
    Endif
  Endif

End

Subprog C_BAL(VALEUR)
Variable Integer VALEUR

  If VALEUR = 1 and [M]ACC(nolign-1) = 1 and [M]MTC(nolign-1) = 1
    mkstat = 2
    End
  Endif

End

###############################################################################
##  Contrôle en saisie du paramètre UPDBALBTC
###############################################################################
Subprog VERF_PARAM(PARAM, VALEUR, OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK

Local Integer MORT

#  If VALEUR <> [M]VALEUR(nolign-1)   # X3-111845
  If mess(val(VALEUR), 1, 1) <> [M]VALEUR(nolign-1)   # X3-111845
    Call TEMPON("F") From GESECRAN
    Call PRESENCE(MORT) From CPTBATCH
    If MORT = 0
      # Modification impossible - Arrêter les Tâches Batch
      OK = 0
      GMESSAGE = mess(9,123,1) - "-" - mess(157,105,1)
    Endif
    Call TEMPOFF From GESECRAN
  Endif

  If PARAM = "MULBATCH" # X3-111845
    End
  Endif

  If VALEUR <> "2"

    Local File GACCTMP [HAT]
    Filter [HAT] Where FLG>=100
    Read [HAT]HAT0 First
    If fstat = 0
      # Modification impossible - Des pièces comptables sont en attente de MAJ balances
      OK = 0
      GMESSAGE = mess(9,123,1) - "-" - mess(49,114,1)
    Endif
    Close Local File [HAT]
    If OK = 0
      End
    Endif
  Endif

End

