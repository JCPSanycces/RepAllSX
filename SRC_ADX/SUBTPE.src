######################################################################################
## Fq-89249 Controls on Automatic journal
######################################################################################
Subprog C_GAU(VALEUR)
Variable Char    VALEUR()

 If VALEUR = "" : End : Endif

 If clalev([F:GAU])=0 : Local File GAUTACE [GAU] : Endif
 Read[GAU]GAU0=VALEUR
 If fstat=0
    If [M:TPE0]LEG <>""
       If dim([F:GAU]NBRLEG)>0 & [F:GAU]NBRLEG<>0
          If  !find( [M:TPE0]LEG,[F:GAU]ACTLEG(0..dim([F:GAU]ACTLEG)-1))
             # "Pièce inactive pour la législation courante"
             # "Entry code disable for the current legislation
             GERR=1 : mkstat=2
             GMESSAGE = mess(145,GML_MSGCPT,1)
          Endif
       Endif
    Endif
 Else
    # "Pièce inexistante."
    # "Nonexistent Entry code
    GERR=1 : mkstat=2 :    GMESSAGE = mess(146,GML_MSGCPT,1)
 Endif

End
######################################################################################
Subprog AM_GRA(VALEUR)
Variable Char    VALEUR()
 If VALEUR=""
  Actzo [M:TPE1]GAU
 Else
  Grizo [M:TPE1]GAU
 Endif
 Affzo [M:TPE1]GAU
End

