######################################################################################
# Force la compilation du traitement généré (Fq-89162 icone rendue invisible)
######################################################################################
Subprog CL_BUILD

 If [F:TPE]TRTINT<>""
  Gosub SUP_TRTINT   From SUBTPE
  Gosub CRE_TRTINT   From SUBTPE
  Gosub VALID_TRTINT From SUBTPE
 Endif
End
######################################################################################
# Fq-89162 Le bouton "Validation" remplace  l'icone "Compiler"
######################################################################################
Subprog VALTPE()
 If [F:TPE]TRTINT<>""
  Gosub SUP_TRTINT   From SUBTPE
  Gosub CRE_TRTINT   From SUBTPE
  Gosub VALID_TRTINT From SUBTPE
 Endif
End
######################################################################################
# Consultation du traitement généré pour le type d'écriture
######################################################################################
Subprog CL_EDIT(VALEUR)
Variable Char    VALEUR()
 If [F:TPE]TRTINT<>""
  Call EDITION([F:TPE]TRTINT) From SUBADC
 Endif
End

#**
#* Permet d'alimenter le champ GAUREF dans le masque TPE9
#*
#* @param PGAU Pièce automatique
#*!
Subprog GET_GAUREF(PGAU)
Value Char PGAU

 If !clalev([F:GAU]) : Local File GAUTACE  [GAU] : Endif
 If !clalev([F:GAD]) : Local File GAUTACED [GAD] : Endif
 If !clalev([F:GAG]) : Local File GAUTACEF [GAG] : Endif
 If !clalev([F:ATZ]) : Local File ATABZON  [ATZ] : Endif
 If !clalev([F:ATY]) : Local File ATYPE    [ATY] : Endif
 Link [F:ATZ] With [F:ATY]CODTYP=[F:ATZ]CODTYP As [ATZ1]

 Local Char    LFLDNAM(50)
 Local Integer LFIND
 Local Char    LTAB, LTABABR
 Local Integer I_FLD

 For I_FLD=1 To [M:TPE9]NBLIG
  LFIND=0
  LFLDNAM=[M:TPE9]TMPFLD(I_FLD-1)
  If [M:TPE9]TMPIND(I_FLD-1)<>0
   LFLDNAM+='('+num$([M:TPE9]TMPIND(I_FLD-1)-1)+')'
  Endif
  [M:TPE9]GAUEXP(I_FLD-1)=LFLDNAM
  If LFLDNAM<>''
   Read [F:GAU]GAU0=PGAU
   If !fstat
    If !LFIND : LTAB="GAUTACE"  : LTABABR="GAU" : Gosub TRT_TAB : Endif
    For [F:GAD] Where COD=PGAU & 1=1
     If !LFIND : LTAB="GAUTACED" : LTABABR="GAD" : Gosub TRT_TAB : Endif
    Next
    For [F:GAG] Where COD=PGAU & 1=1
     If !LFIND & 1=0 : LTAB="GAUTACEF" : LTABABR="GAD" : Gosub TRT_TAB : Endif
    Next
   Endif
  Endif
 Next I_FLD

End

######################################################################################
$TRT_TAB
 Filter [F:ATZ1] Where [F:ATZ]CODFIC=LTAB & [F:ATZ]CODTYP<>"AX3" & [F:ATZ]CODTYP<>"AX1" & [F:ATY]TYPTYP=7
 For [F:ATZ1]
  If evalue('pat(num$([F:'+LTABABR+']'+[F:ATZ1]CODZONE+'),"*"+LFLDNAM+"*")')
   [M:TPE9]GAUREF(I_FLD-1)=G_OUI
   LFIND=1 : Break
  Endif
 Next
 Filter [F:ATZ1]
Return

######################################################################################
# Synthèse du paramétrage du type d'écriture dans une trace.
######################################################################################
Subprog CL_RPT(VALEUR)
Variable Char    VALEUR()

 If GTRACE=""
  Call TEMPON("") From GESECRAN
  If !clalev([F:ATZ]) : Local File ATABZON  [ATZ] : Endif
  If !clalev([F:ATX]) : Local File ATEXTE   [ATX] : Endif
  If !clalev([F:ATB]) : Local File ATABLE   [ATB] : Endif
  If !clalev([F:GAU]) : Local File GAUTACE  [GAU] : Endif
  If !clalev([F:GAD]) : Local File GAUTACED [GAD] : Endif
  If !clalev([F:GAG]) : Local File GAUTACEF [GAG] : Endif

  Read [F:GAU]GAU0=[M:TPE1]GAU

  Filter [F:GAD] Where COD=[F:GAU]COD
  Filter [F:GAG] Where COD=[F:GAU]COD

  Local Integer I_FLD
  Local  Char   LIGNE(110)
  Local  Char   LEVALUE(80), LEVALUE2(80)
  LIGNE="Type d'écriture : alimentation table temporaire de comptabilisation"
  Call OUVRE_TRACE(LIGNE) From LECFIC
  Call ECR_TRACE("",0) From GESECRAN
  LIGNE="Type d'écriture   :"-[M:TPE0]ACETYP
  Call ECR_TRACE(LIGNE,0) From GESECRAN
  LIGNE="Traitement généré :"-[M:TPE9]TRTINT
  Call ECR_TRACE(LIGNE,0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
  LIGNE="ALIMENTATIONS ACTIVES"
  Call ECR_TRACE(LIGNE,0) From GESECRAN
  LIGNE=string$(len(LIGNE),"=")
  Call ECR_TRACE(LIGNE,0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
  For I_FLD=1 To [M:TPE9]NBLIG
   If [M:TPE9]ENALIG(I_FLD-1)=G_OUI : Gosub INFO_FLD : Endif
  Next I_FLD
  Call ECR_TRACE("",0) From GESECRAN

  LIGNE="ALIMENTATION NON PRISES EN COMPTE"
  Call ECR_TRACE(LIGNE,0) From GESECRAN
  LIGNE=string$(len(LIGNE),"=")
  Call ECR_TRACE(LIGNE,0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
  For I_FLD=1 To [M:TPE9]NBLIG
   If [M:TPE9]ENALIG(I_FLD-1)<>G_OUI & ([M:TPE9]ORITAB(I_FLD-1)<>"" | [M:TPE9]ORIEXP(I_FLD-1)<>"")
    Gosub INFO_FLD
   Endif
  Next I_FLD
  Filter [F:GAD]
  Filter [F:GAG]
  Call TEMPOFF() From GESECRAN
  Call LEC_TRACE() From LECFIC
 Endif
End

$INFO_FLD
 LIGNE="=>"-[M:TPE9]TMPFLD(I_FLD-1)
 Read [F:ATZ]CODZONE="TMPCPTDTA";[M:TPE9]TMPFLD(I_FLD-1)
 Read [F:ATX]NUMERO=GLANGUE;[F:ATZ]NOLONG
 Call ECR_TRACE("",0) From GESECRAN
 LIGNE-=[F:ATX]TEXTE
 If [M:TPE9]TMPIND(I_FLD-1)<>0
  LIGNE-="("+"Occurrence"-num$([M:TPE9]TMPIND(I_FLD-1))
  LIGNE+="/"
  LIGNE+="Indice"-num$([M:TPE9]TMPIND(I_FLD-1)-1)+")"
 Endif
 Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE=space$(3)+string$(len(LIGNE)-3,"-")
 Call ECR_TRACE(LIGNE,0) From GESECRAN
 Call ECR_TRACE("",0) From GESECRAN
 LIGNE=space$(1)+"Alimentation conditionnée"
 If [M:TPE9]ORICND(I_FLD-1)<>""
  LIGNE-=mess(G_OUI,1,1)-"Condition"-[M:TPE9]ORICND(I_FLD-1)
 Else
  LIGNE-=mess(G_NON,1,1)
 Endif
 Call ECR_TRACE(LIGNE,0) From GESECRAN
 LIGNE=space$(1)+"Source"
 If [M:TPE9]ORITAB(I_FLD-1)<>""
  LIGNE-="Table      "+[M:TPE9]ORITAB(I_FLD-1)
  If [M:TPE9]ORITAB(I_FLD-1)<>[F:ATB]CODFIC
   Read [F:ATB]CODFIC=[M:TPE9]ORITAB(I_FLD-1)
  Endif
  Read [F:ATX]NUMERO=GLANGUE;[F:ATB]INTITFIC
  LIGNE-=[F:ATX]TEXTE
  Call ECR_TRACE(LIGNE,0) From GESECRAN
  LIGNE=space$(8)+"Champ      "+[M:TPE9]ORIFLD(I_FLD-1)
  If [F:ATZ]CODFIC<>[M:TPE9]ORITAB(I_FLD-1) | [F:ATZ]CODZONE<>[M:TPE9]ORIFLD(I_FLD-1)
   Read [F:ATZ]CODZONE=[M:TPE9]ORITAB(I_FLD-1);[M:TPE9]ORIFLD(I_FLD-1)
   Read [F:ATX]NUMERO=GLANGUE;[F:ATZ]NOLONG
  Endif
  LIGNE-=[F:ATX]TEXTE
  Call ECR_TRACE(LIGNE,0) From GESECRAN
 Elsif [M:TPE9]ORIEXP(I_FLD-1)<>""
  LIGNE-="Expression "+[M:TPE9]ORIEXP(I_FLD-1)
  Call ECR_TRACE(LIGNE,0) From GESECRAN
 Endif

 Gosub UTIL_GAUACE

Return

#---------------------
$UTIL_GAUACE
 Local Integer HEAUTILIG, NBUTILIG, HEAUTIFOR, NBUTIFOR
 Local Char    LNOMFLD
 Local Char    LNOMFLD2
 LNOMFLD ="[F:TB0]"+[M:TPE9]TMPFLD(I_FLD-1)
 LNOMFLD2=""
 If [M:TPE9]TMPIND(I_FLD-1)>=1
  If [M:TPE9]TMPIND(I_FLD-1)=1
   LNOMFLD2=LNOMFLD
  Endif
  LNOMFLD+="("+num$([M:TPE9]TMPIND(I_FLD-1)-1)+")"
 Endif

 Filter [F:ATZ] Where CODFIC="GAUTACED"
 For [F:GAD]
  For [F:ATZ]
   If [F:ATZ]CODTYP="AX3" : Goto NEXT_ATZ : Endif
   LEVALUE  = 'pat(num$([F:GAD]'+[F:ATZ]CODZONE+'),"*"+LNOMFLD+"*")'
   LEVALUE2 = 'LNOMFLD2<>"" & num$([F:GAD]'+[F:ATZ]CODZONE+')='+'"'+LNOMFLD2+'"'
   If evalue(LEVALUE) | (!evalue(LEVALUE) & evalue(LEVALUE2))
    NBUTILIG+=1
    If !HEAUTILIG
     Call ECR_TRACE("",0) From GESECRAN
     Call ECR_TRACE(" * "+"Utilisation dans les lignes de la pièce automatique"-[F:GAU]COD,0) From GESECRAN
     Call ECR_TRACE("",0) From GESECRAN
     HEAUTILIG=1
    Endif
    LIGNE = space$(5)+"Ligne"-format$("N0:2",[F:GAD]LINNUM)
&                  -[F:ATZ]CODZONE+space$(20-len(format$("N0:2",[F:GAD]LINNUM)-[F:ATZ]CODZONE))
&                  + "=>"
&                  - evalue("[F:GAD]"+[F:ATZ]CODZONE)
    Call ECR_TRACE(LIGNE,0) From GESECRAN
   Endif
   $NEXT_ATZ
  Next
 Next
 For [F:GAG]
  If pat([F:GAG]FORCLC,"*"+LNOMFLD+"*") | (!pat([F:GAG]FORCLC,"*"+LNOMFLD+"*") & [F:GAG]FORCLC=LNOMFLD2)
   NBUTIFOR+=1
   If !HEAUTIFOR
    Call ECR_TRACE("",0) From GESECRAN
    Call ECR_TRACE(" * "+"Utilisation dans les formules de la pièce automatique"-[F:GAU]COD,0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
    HEAUTIFOR=1
   Endif
   If [F:GAG]LINNUM>=1
    LIGNE = space$(5)+"Ligne  "-format$("N0:2",[F:GAG]LINNUM)
   Else
    LIGNE = space$(5)+"En-tête"
   Endif
   LIGNE -=       [F:GAG]FLD+space$(20-len(format$("N0:2",[F:GAG]LINNUM)-[F:GAG]FLD))
&                 + "=>"
&                 - [F:GAG]FORCLC
   Call ECR_TRACE(LIGNE,0) From GESECRAN
  Endif
 Next
 Filter [F:ATZ]
 If !NBUTILIG & !NBUTIFOR
  Call ECR_TRACE("",0) From GESECRAN
  Call ECR_TRACE(space$(1)+"Champ non utilisé dans la pièce automatique"-[F:GAU]COD,1) From GESECRAN
 Endif
Return
######################################################################################
## Etiquette ajoutée par le superviseur (écran TPE0) 02/11/2012 10:14:57 (CBO)
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()

  # FQ85066
  If VALEUR <> ""
    Grizo [M:TPE0]CPY
  Else
    Actzo [M:TPE0]CPY
  Endif
  Affzo [M:TPE0]CPY, ZCPY

  [M:TPE0]LEG = VALEUR
  Gosub CRE_TABLEG
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran TPE1) 22/11/2012 10:38:39 (CBO)
######################################################################################
Subprog AS_NBLEG
  If [M:TPE1]LEGLIN(nolign - 1) = ""
    Grizo [M:TPE1]GTE, JOU, JOUPRO, GTEPRO
  Else
    Actzo [M:TPE1]GTE, JOU, JOUPRO, GTEPRO
  Endif

  Affzo [M:TPE1]GTE, JOU, JOUPRO, GTEPRO
End

