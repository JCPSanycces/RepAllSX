#<AdxTL>@(#)2.0.0.0 $Revision$
########################################################################################################################
#
# PARAMETRAGE DES TYPES D'ECRITURE COMTPABLE : Gestion de l'objet TPE
# ==========================================
#
# @ver        1.0.0
# @date       13.09.2007
# @user       GBO
# @modif      xx.xx.xxxx
#
# Liste des sous-programmes :
# -------------------------
#
# AM_ACETYP(VALEUR)
# AS_SRCTYP(VALEUR)
# AM_SRCTYP(VALEUR)
# AM_EVTTYP(VALEUR)
# AS_DPRPLN(VALEUR)
# C_SORTFLDTAB(VALEUR)
# AM_SORTFLDTAB(VALEUR)
# C_SORTFLD(VALEUR)
# AM_SORTFLD(VALEUR)
# AM_RUPPCEFLG(VALEUR)
# AM_GAU(VALEUR)
# C_GAU(VALEUR) # Fq-89249
# AM_DIRCPTFLG(VALEUR)
#
# Liste des fonctions :
# -------------------
#
# EXISTE_EVT_PLN(PEVETYP,PPLN)
# PLAN_COMPTABILISE(PCPY,PPLN,PACTIF)
# RPR_COMPTABILISE(PCPY,PACTIF)
#
# Liste des routines :
# ------------------
#
# $ACTION
# $FILTRE
# $LIENS
# $SETBOUT
# $VERIF_CRE
# $VERIF_MOD
# $SEL_LISTE
# $TRTCOP
# $AB_TR_COP
# $ROLL_TR_COP
# $AUZ_CPY
#
########################################################################################################################
# Modifications :
# -------------
# XXXXX JJ.MM.AAAA  nnnnnn_n Commentaire
#
# CBO   04.12.2015  112811-2 Soc tjrs disponible (elle fait partie de la clef primaire
# MDJ   15.01.2016  113620   Accounting entry "variance between plans" and not possible to do closing
# CBO   04.12.2015  112811   Accès à la soc en création
# GLE   15.01.2015  105455   Une ligne en trop est créée dans le tableau des législations si la législation du type d'cériture est à blanc
# GLE   10.12.2014  104672   Erreur sur [ADI2] lors de la copie d'une type d'écriture d'une dossier à un autre
# GLE   10.12.2014  104366   Désignation vide si la législation du type d'écriture n'est pas vide
# GLE   03.07.2014  101153   Gestion correcte de la copie vers un dossier mono-législation
# GLE   20.03.2014  98060    Prise en compte de la législation dans les contrôles sur les types d'écriture
# MDJ   25.04.2013  89162    Icone "Compiler" remplacée par le bouton de bas de page "Validation"
# MDJ   15.04.2013  89249    Multi-Leg : Pièce automatiques (prise en compte des notions de Groupe et de LEG)
# CBO   31.10.2012  85066    gestion multi-leg : refonte du paramètrage (table TYPACELEG)
# MDJ   08.08.2012  81074    Optimisation suite SPIKE Performances Contextes
# GLE   14.06.2011  74342    Le champ Législation s'affiche à tort en mono-législation si "Chargement dernier lu" à Non
# GLE   17.05.2011  73845    Gestion du champ LEG en mono-législation
# GBO   23.11.2010  69824    Interface comptable multi-référentiel
# GBO   07.09.2010  66710    Pièces multi-référentiel
# GBO   01.09.2010  66973    F5 après création de type d'écriture - perte de la législation
# GBO   28.07.2010  66210    Action de sélection SELTPE : TPE basé sur PPR non proposées si code activité CCN à non
# GBO   08.07.2010  65893    Contrôle que le plan est bien défini pour cette société
# GBO   08.07.2010  65961    Mauvais message en duplication du type d'écriture.
# GBO   04.05.2010  64544    Comptabilisation des écarts entre plans
# GLE   16.11.2009  59900    Gestion des codes activités dans la table diverse des tables d'événements 952
# GBO   13.10.2010  54343    Gestion des concessions
# GLE   12.10.2009  58667    Suite FQ58489
# GLE   07.10.2009  58489    Test de la présence du module Immo dans les sous-pro PATCH et GENDOS
# GBO   24.09.2009  56791    Problème de traduction des noms de champs dans le tableau tri / regroupement
# GBO   18.09.2009  56616    Duplication type d'écriture
# GBO   08.09.2009  57603    Changement de code : Mise à jour du nom du traitement généré
########################################################################################################################
 Call OBJET("TPE",GBIDC1,GBIDC2) From GOBJET
End
################################################################################
$ACTION
Case ACTION
 When "FILTRE"      : Gosub FILTRE
 When "OUVRE"       : Gosub OUVRE
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE : # FQ74342
 When "LIENS"       : Gosub LIENS
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "RAZDUP"      : Gosub RAZDUP
 When "RAZCRE"      : Gosub RAZCRE
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "CREATION"    : Gosub CREATION
 When "INICRE"      : Gosub INICRE
 When "VERIF_MOD"   : Gosub VERIF_CRE
 When "INIMOD"      : Gosub INIMOD
 When "MODIF"       : Gosub MODIF
 When "TERMINE"     : Gosub TERMINE
 When "AV_ANNULE"   : Gosub AV_ANNULE
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "CHANGE"      : Gosub CHANGE
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When Default
Endcase
Return
################################################################################

#=============================================================================
$OUVRE

 If !clalev([F:RTPE]) : Local File TYPACE    [RTPE] : Endif
 If !clalev([F:TPI])  : Local File TYPACEINT [TPI]  : Endif
 # FQ85066
 If !clalev([F:TPL]) : Local File TYPACELEG  [TPL] : Endif
 If !clalev([F:JOU]) : Local File GJOURNAL   [JOU] : Endif
 If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif
 If !clalev([F:GTE]) : Local File GTYPACCENT [GTE] : Endif
Return
#============================================================================= 74342
$OUVRE_BOITE

  If GNBLEG=1
    #> Dossier mono-législation
    Chgfmt [M:TPE0]LEG  With "-K:20X"
    Chgfmt [M:TPE0]ZLEG With "-K:20X"
  Endif
Return
#=============================================================================
$FILTRE
  If dim([M:CNX0]CPY)>0
    If dim(GFROMCNX)<0
      FILTSUP = "TABCPT='DEPREC' & (CPY='' | CPY=[M:CNX0]CPY) & DPRPLN=[M:CNX1]PLNCAA(nolign-1)"
      Global Integer GFROMCNX
    Endif
  Endif
Return

#=============================================================================
$LIENS
#Infbox "liens"
  # FQ85066 exclusion cpy/leg
  If (GNBLEG = 1) : # FQ74342
    If [M:TPE0]CPY = "" and [M:TPE0]LEG = ""
#      Actzo [M:TPE0]CPY, LEG # 112811-2
      Actzo [M:TPE0]LEG # 112811-2
    Elsif [M:TPE0]CPY <> ""
#      Actzo [M:TPE0]CPY# 112811-2
      Grizo [M:TPE0]LEG
    Elsif [M:TPE0]CPY = "" and [F:TPE]LEG <> ""
      Actzo [M:TPE0]LEG
#      Grizo [M:TPE0]CPY# 112811-2
    Endif
  Else
    #> Dossier multi-législation
    If [F:TPE]CPY = ""
      If [M:TPE0]LEG = ""
#        Actzo [M:TPE0]CPY, LEG# 112811-2
        Actzo [M:TPE0]LEG# 112811-2
      Else
#        Diszo [M:TPE0]CPY
        Actzo [M:TPE0]LEG
      Endif
    Else
      Call LECTURE("CPY", [F:TPE]CPY, "") From CONTOBJ #Fq66973
      [M:TPE0]LEG=[F:CPY]LEG
      Grizo [M:TPE0]LEG
    Endif
  Endif

  If [F:TPE]SRCTYP=GVML_SRCEVT
    Actzo [M:TPE1]EVTTYP
    Diszo [M:TPE1]TABCPT
  Endif

 #fq64544
  If [F:TPE]SRCTYP=GVML_SRCDEP | [F:TPE]SRCTYP=GVML_SRCRPR | [F:TPE]SRCTYP=GVML_SRCOTH | [F:TPE]SRCTYP=GVML_SRCLNK
    Diszo [M:TPE1]EVTTYP
  Endif

 #fq64544
  If [F:TPE]SRCTYP=GVML_SRCDEP | [F:TPE]SRCTYP=GVML_SRCRPR | [F:TPE]SRCTYP=GVML_SRCLNK
    Diszo [M:TPE1]TABCPT
  Else
    Actzo [M:TPE1]TABCPT
  Endif

  #FQ54343
  If [F:TPE]SRCTYP=GVML_SRCRPR
    Diszo [M:TPE1]DPRPLN
  Else
    Actzo [M:TPE1]DPRPLN #Fq66710
  Endif

 If [F:TPE]SRCTYP=GVML_SRCOTH & [F:TPE]TABCPT<>""
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  Filter [F:ATZ] Where CODFIC=[F:TPE]TABCPT & NOLIB=GML_NPLAN
  Read[ATZ]  First
  If !fstat
   Actzo [M:TPE1]DPRPLN
  Elsif fstat=5 | fstat=4
   Diszo [M:TPE1]DPRPLN
  Endif
  Filter [F:ATZ]
  Close Local File [F:ATZ]
 Endif

 If [M:TPE1]CPTREF <> 2
  Diszo [M:TPE1]SORTCCE
 Else
  Actzo [M:TPE1]SORTCCE
 Endif
 Affzo [M:TPE1]SORTCCE

 If [M:TPE1]DIRCPTFLG <> G_OUI
  Diszo [M:TPE1]DIRCPTTRA
 Else
  Actzo [M:TPE1]DIRCPTTRA
 Endif
 Affzo [M:TPE1]DIRCPTTRA

 #fq64544
 If [M:TPE1]SRCTYP<>GVML_SRCDEP & [M:TPE1]SRCTYP<>GVML_SRCRPR & [M:TPE1]SRCTYP<>GVML_SRCLNK
    Raz [M:TPE1]GTEPRO : Grizo [M:TPE1]GTEPRO
    Raz [M:TPE1]JOUPRO : Grizo [M:TPE1]JOUPRO
 Else
    Actzo [M:TPE1]GTEPRO
    Actzo [M:TPE1]JOUPRO
 Endif

 If [M:TPE1]ACCDATRUL=8
  Actzo [M:TPE1]ACCDATFIX
 Else
  Grizo [M:TPE1]ACCDATFIX
 Endif
 Affzo [M:TPE1]ACCDATFIX

#[M:TPE1]CPTREFLIB=mess([F:TPE]CPTREF,2644,1)

 If adxmother=nomap & GADONIX=G_NON
  Grizo [M:TPE0]ACETYP
 Else
  Actzo [M:TPE0]ACETYP
 Endif
 Affzo [M:TPE0]ACETYP

 #FQ56791
 #> Chargement des intitulés des champs du tableau tri/regroupement
 Local Integer I
 For I=1 To [M:TPE1]NBCRIT
  [M:TPE1]SORTFLDDES(I-1)=func SUBTPE.GET_FLD_DES([M:TPE1]SORTFLDTAB(I-1),[M:TPE1]SORTFLD(I-1))
 Next I

 #Fq68824
 If [F:TPE]GAU<>""
  Grizo [M:TPE1]GRA
  Actzo [M:TPE1]GAU
 Endif
 If [F:TPE]GRA<>""
  Grizo [M:TPE1]GAU
  Actzo [M:TPE1]GRA
 Endif
 Affzo [M:TPE1]GRA : Affzo [M:TPE1]GAU

 #> Chargement de l'onglet TPE9

 # FQ85066
 Filter [F:TPI] Where ACETYP = [F:TPE]ACETYP and LEG = [F:TPE]LEG and CPY = [F:TPE]CPY
 If rowcount([F:TPI])=0
  Gosub SET_TPE9
 Else
  Local Integer I_FLD
  For [F:TPI]
   I_FLD+=1 : nolign=I_FLD
   [M:TPE9]=[F:TPI]
  Next
  [M:TPE9]NBLIG=I_FLD
  Filter [F:TPI]

  #-> Recherche des nouveaux champs dans la table TMPCPTDTA

  Gosub DEF_LSTFLD

  Trbegin [F:TPI] : GOK=1
  For I_FLD=1 To LNBFLD
   If !find(LLISTFLD(I_FLD),[M:TPE9]TMPFLD)
    If dim(LSORT)<0 : Local Integer LSORT : Endif
    If LDIMFLD(I_FLD)>1
     Local Integer I_IND
     For I_IND=1 To LDIMFLD(I_FLD)
      #> Ajout dans le tableau
      [M:TPE9]ENALIG([M:TPE9]NBLIG) = G_NON
      [M:TPE9]TMPFLD([M:TPE9]NBLIG) = LLISTFLD(I_FLD)
      [M:TPE9]TMPIND([M:TPE9]NBLIG) = I_IND
      [M:TPE9]ORICND([M:TPE9]NBLIG) = ""
      [M:TPE9]ORITAB([M:TPE9]NBLIG) = ""
      [M:TPE9]ORIFLD([M:TPE9]NBLIG) = ""
      [M:TPE9]ORIEXP([M:TPE9]NBLIG) = ""
      [M:TPE9]NUMLIG([M:TPE9]NBLIG) = LNUMLIG(I_FLD)
      [M:TPE9]NBLIG+=1
      #> Création de l'enreg dans la table
      Raz [F:TPI]
      [F:TPI]ACETYP=[M:TPE0]ACETYP
      # FQ85066
      [F:TPI]LEG=[M:TPE0]LEG
      [F:TPI]CPY=[M:TPE0]CPY
      [F:TPI]TMPFLD=LLISTFLD(I_FLD)
      [F:TPI]TMPIND=I_IND
      [F:TPI]CREDAT=date$
      [F:TPI]CREUSR=GUSER
      Write [F:TPI]
      If fstat
       Break
       GOK=0
      Endif
     Next I_IND
    Else
     #> Ajout dans le tableau
     [M:TPE9]ENALIG([M:TPE9]NBLIG) = G_NON
     [M:TPE9]TMPFLD([M:TPE9]NBLIG) = LLISTFLD(I_FLD)
     [M:TPE9]TMPIND([M:TPE9]NBLIG) = 0
     [M:TPE9]ORICND([M:TPE9]NBLIG) = ""
     [M:TPE9]ORITAB([M:TPE9]NBLIG) = ""
     [M:TPE9]ORIFLD([M:TPE9]NBLIG) = ""
     [M:TPE9]ORIEXP([M:TPE9]NBLIG) = ""
     [M:TPE9]NUMLIG([M:TPE9]NBLIG) = LNUMLIG(I_FLD)
     [M:TPE9]NBLIG+=1
     #> Création de l'enreg dans la table
     Raz [F:TPI]
     [F:TPI]ACETYP=[M:TPE0]ACETYP
     # FQ85066
     [F:TPI]LEG=[M:TPE0]LEG
     [F:TPI]CPY=[M:TPE0]CPY
     [F:TPI]TMPFLD=LLISTFLD(I_FLD)
     [F:TPI]TMPIND=0
     [F:TPI]CREDAT=date$
     [F:TPI]CREUSR=GUSER
     Write [F:TPI]
     If fstat
      Break
      GOK=0
     Endif
    Endif
    Global Integer GTPEMOD
   Else
    Local Integer IDX_FLD
    For IDX_FLD=1 To [M:TPE9]NBLIG
     If [M:TPE9]TMPFLD(IDX_FLD-1)=LLISTFLD(I_FLD)
      If [M:TPE9]NUMLIG(IDX_FLD-1)<>LNUMLIG(I_FLD)
       [M:TPE9]NUMLIG(IDX_FLD-1)=LNUMLIG(I_FLD)
      Endif
     Endif
    Next IDX_FLD
   Endif
  Next I_FLD
  If GOK
   Commit
  Else
   Rollback
  Endif

  If dim(LSORT)>0
   Sorta [M:TPE9]NBLIG [M:TPE9]NBLIG Order By [M:TPE9]TMPFLD([S]indice), [M:TPE9]TMPIND([S]indice)
   Kill LSORT
  Endif

  #-> Suppression des champs n'existant plus dans TMPCPTDTA

  For I_FLD=1 To [M:TPE9]NBLIG
   If !find([M:TPE9]TMPFLD(I_FLD-1),LLISTFLD)
    [M:TPE9]TMPFLDSUP(I_FLD-1)=G_OUI
    If dim(LSORT)<0 : Local Integer LSORT : Endif
   Endif
  Next I_FLD

  If dim(LSORT)>0
   Sorta [M:TPE9]NBLIG [M:TPE9]NBLIG Order By [M:TPE9]TMPFLDSUP([S]indice)
   Kill LSORT
  Endif

  Local Integer I_PREMSUP : I_PREMSUP=find(G_OUI,[M:TPE9]TMPFLDSUP)
  Local Integer IDX_SUP
  If I_PREMSUP

   #> Suppression dans la table TYPACEINT

   # FQ85066
   Trbegin [F:TPI] : GOK=1
   For IDX_SUP=I_PREMSUP To [M:TPE9]NBLIG
    Delete [F:TPI] Where ACETYP = [M:TPE0]ACETYP and LEG=[M:TPE0]LEG and
&          CPY=[M:TPE0]CPY and TMPFLD=[M:TPE9]TMPFLD(IDX_SUP-1)
    If fstat : GOK=0 : Break : Endif
   Next IDX_SUP
   If GOK
    Commit
    Global Integer GTPEMOD
   Else
    Rollback
   Endif

   #> Suppression dans le masque TPE9

   Dela I_PREMSUP-1, [M:TPE9]NBLIG-I_PREMSUP+1 [M:TPE9]NBLIG
   [M:TPE9]NBLIG=[M:TPE9]NBLIG-([M:TPE9]NBLIG-I_PREMSUP+1)
  Endif

 Endif
 If GADONIX<>2
  Grizo [M:TPE9]TRTINT
 Endif
 [M:TPE9]TRTINT   =[F:TPE]TRTINT #: Affzo [M:TPE9]TRTINT
 [M:TPE9]TRTINTOLD=[F:TPE]TRTINT #: Affzo [M:TPE9]TRTINTOLD

  # FQ85066
  I_FLD = 0
  If [M:TPE0]LEG = ""
    For I_FLD = 1 To GNBLEG
      Read [TPL]TPL0 = [F:TPE]ACETYP; [M:TPE0]LEG; [F:TPE]CPY; GDOSLEG(I_FLD)

      [M:TPE1]LEGLIN(I_FLD - 1) = GDOSLEG(I_FLD)
      If fstat
        [M:TPE1]GTE(I_FLD - 1)    = ""
        [M:TPE1]JOU(I_FLD - 1)    = ""
        [M:TPE1]GTEPRO(I_FLD - 1) = ""
        [M:TPE1]JOUPRO(I_FLD - 1) = ""
      Else
        [M:TPE1]GTE(I_FLD - 1)    = [F:TPL]GTE
        [M:TPE1]JOU(I_FLD - 1)    = [F:TPL]JOU
        [M:TPE1]GTEPRO(I_FLD - 1) = [F:TPL]GTEPRO
        [M:TPE1]JOUPRO(I_FLD - 1) = [F:TPL]JOUPRO
      Endif
    Next I_FLD
    [M:TPE1]NBLEG = I_FLD - 1 : # FQ105455 : ajout du -1
  Else
    Read [TPL]TPL0 = [F:TPE]ACETYP; [M:TPE0]LEG; [F:TPE]CPY; [M:TPE0]LEG
    [M:TPE1]LEGLIN(0)    = [M:TPE0]LEG
    If fstat
      [M:TPE1]GTE(0)    = ""
      [M:TPE1]JOU(0)    = ""
      [M:TPE1]GTEPRO(0) = ""
      [M:TPE1]JOUPRO(0) = ""
    Else
      [M:TPE1]GTE(0)    = [F:TPL]GTE
      [M:TPE1]JOU(0)    = [F:TPL]JOU
      [M:TPE1]GTEPRO(0) = [F:TPL]GTEPRO
      [M:TPE1]JOUPRO(0) = [F:TPL]JOUPRO
    Endif
    [M:TPE1]NBLEG = 1
  Endif
#  Affzo [M:TPE1]LEGLIN
  Affzo [M:TPE1]NBLEG

  Gosub AFFICH_SIMU

 If dim(GTPEMOD)>0
  Call TEMPON("V") From GESECRAN
  Gosub MAJ_TRTINT
  Gosub VALID_TRTINT
  Call TEMPOFF() From GESECRAN
  Kill GTPEMOD
 Endif

Return

#=============================================================================
$SETBOUT

#*FQ-85066 : activation du bouton Supprimer
If CLECUR
   CHAINE+="A" #*FQ-85066
Endif

 # Bouton "Copie" uniquement en mode consultation

 If GREP<>""
  Call VIREBOUT(CHAINE,"2t") From GOBJET
 Endif

 # Bouton Créer, Supprimer et Changement de clé
 # disponible uniquement sur le dossier racine des dossiers de développement et sur les dossiers applicatifs

 If (nomap=adxmother & GADONIX=G_NON)
  Call VIREBOUT(CHAINE,"C") From GOBJET
  Call VIREBOUT(CHAINE,"A") From GOBJET
  Call VIREBOUT(CHAINE,"H") From GOBJET
  Call VIREBOUT(CHAINE,"M") From GOBJET
  Call VIREBOUT(CHAINE,"t") From GOBJET
 Endif

Return

#=============================================================================
$EXEBOUT
 Case BOUT
  When "t" : #Gosub EXE_TRTCPTINT
  When Default
 Endcase
Return

#=============================================================================
$RAZDUP

#  # interdiction de passer d'un type sans LEG à un type avec et inversement
#  If [M:TPE0]ACETYP = [F:TPE]ACETYP
#    If ([M:TPE0]LEG <> [F:TPE]LEG and [F:TPE]LEG = "") or
#&      ([M:TPE0]LEG <> [F:TPE]LEG and [M:TPE0]LEG = "")
#
#      Call VIREBOUT(CHAINE,"C") From GOBJET
#      GSTACRE = 0
#      GMESSAGE = "dup interdite" - GREP
#      GERR = 1
#      GOK = 0
#      mkstat = 2
#      Return
#    Endif
#  Endif

  [M:TPE9]TRTINT    = ""
  [M:TPE9]TRTINTOLD = ""
  #FQ56616-On demande si le paramétrage de l'onglet interface doit être conservé
  #Fq65961-Le message n'était pas le bon
  Call OUINON(mess(123,GML_MSGCPT,1),OK) From GESECRAN # "Voulez-vous concerser le paramétrage de l'onglet interface ?"
  If OK <> G_OUI
    Raz [M:TPE9]ENALIG, [M:TPE9]ORICND, [M:TPE9]ORITAB, [M:TPE9]ORIFLD, [M:TPE9]ORIEXP
    Affzo [M:TPE9]
  Endif
  # FQ85066

  # on passe à 1 clef sans leg : il faut tout afficher
  # OU on passe à 1 clef avec leg : il faut afficher que celle-ci
  # Ou on change de leg : il faut afficher que celle-ci
  If ([M:TPE0]LEG = "" and [M:TPE1]NBLEG = 1 and GNBLEG > 1)
&  or ([M:TPE0]LEG <> "" and [M:TPE1]NBLEG > 1 and GNBLEG > 1)
&  or ([M:TPE0]LEG <> "" and [M:TPE1]NBLEG = 1 and [M:TPE0]LEG <> [F:TPE]LEG)
    GREP = "D"
    Gosub CRE_TABLEG
    GREP = ""
  Else
    Call OUINON(mess(143,GML_MSGCPT,1),OK) From GESECRAN # "Voulez-vous conserver le paramétrage du tableau des législations ?"
    If OK <> G_OUI
      GREP = "D"
      Gosub CRE_TABLEG
      GREP = ""
    Endif
  Endif

Return

#=============================================================================
$RAZCRE

 Gosub SET_TPE9

 # Initialisation du champ LEG en mono-législation FQ73845
 If GNBLEG = 1
   [M:TPE0]LEG = GDOSLEG
 Else
   Actzo [M:TPE0]LEG # Issue 112811
 Endif
 Affzo [M:TPE0]LEG # Issue 112811

Return

# FQ85066
$CRE_TABLEG

  If GREP = "C" or GREP = "D"
    Raz[M:TPE1]LEGLIN, GTE, JOU, GTEPRO, JOUPRO

    If [M:TPE0]LEG = ""
      For I_FLD = 1 To GNBLEG
        [M:TPE1]LEGLIN(I_FLD - 1)    = GDOSLEG(I_FLD)
      Next I_FLD
      [M:TPE1]NBLEG = I_FLD
    Else
      Raz [M:TPE1]NBLEG
      [M:TPE1]LEGLIN(0)    = [M:TPE0]LEG
      [M:TPE1]NBLEG = 1
    Endif
    Affzo [M:TPE1]LEGLIN, GTE, JOU, GTEPRO, JOUPRO, ZGTE, ZJOU, ZGTEPRO, ZJOUPRO
  Endif

Return

# FQ85066
$AFFICH_SIMU
#Infbox "AFFICH_SIMU"
    If [M:TPE1]SRCTYP = GVML_SRCEVT
      Chgfmt [M:TPE1]GTEPRO With "-K:X"
      Chgfmt [M:TPE1]JOUPRO With "-K:X"
      Chgfmt [M:TPE1]ZGTEPRO With "-K:X"
      Chgfmt [M:TPE1]ZJOUPRO With "-K:X"
    Else
      Chgfmt [M:TPE1]GTEPRO With "K:5BX"
      Chgfmt [M:TPE1]JOUPRO With "K:5BX"
      Chgfmt [M:TPE1]ZGTEPRO With "+K:X"
      Chgfmt [M:TPE1]ZJOUPRO With "+K:X"
      Affzo [M:TPE1]GTEPRO, ZGTEPRO, JOUPRO, ZJOUPRO
    Endif
Return

#=============================================================================
$VERIF_CRE

  # FQ85066
  Call VERIF_AUTRE_NIV([M:TPE0]ACETYP, [M:TPE0]LEG, [M:TPE0]CPY, GOK)
  If GOK < 0
    GERR = 1
    If GOK = -1
      GMESSAGE = mess(139, GML_MSGCPT, 1) #- "Ce type d'écriture existe déja sans législation renseignée. Il ne peut être créé ainsi."
    Elsif GOK = -2
      GMESSAGE = mess(140, GML_MSGCPT, 1) #- "Ce type d'écriture existe déja avec une législation renseignée. Il ne peut être créé ainsi."
    Elsif GOK = -3
      GMESSAGE = mess(141, GML_MSGCPT, 1) #- "Ce type d'écriture existe déja avec une société renseignée. Il ne peut être créé ainsi."
    Elsif GOK = -4
      GMESSAGE = mess(142, GML_MSGCPT, 1) #- "Ce type d'écriture existe déja sans société renseignée. Il ne peut être créé ainsi."
    Endif
    GOK = 0
    Return
  Endif

 If [M:TPE1]PERCLOFLG=G_NON &
&   [M:TPE1]PERCOUFLG=G_NON &
&   [M:TPE1]PEROPEFLG=G_NON
  GERR     = 1
  GMESSAGE = mess(108,GML_MSGCPT,1) #"Au moins un type de période à traiter doit être sélectionné"
  GOK      = 0
  zonsui = "PERCLOFLG"
 Endif
Return

#=============================================================================
$CREATION
 Gosub TEXTRA
 If GOK<1 : Return : Endif

  # FQ85066
  For nolign = 1 To [M:TPE1]NBLEG
    If [M:TPE1]LEGLIN(nolign - 1) <> ""
      Raz  [F:TPL]
      [F:TPL]ACETYP = [M:TPE0]ACETYP
      [F:TPL]CPY = [M:TPE0]CPY
      [F:TPL]LEG = [M:TPE0]LEG

      [F:TPL]LEGLIN = [M:TPE1]LEGLIN(nolign - 1)
      [F:TPL]GTE    = [M:TPE1]GTE(nolign - 1)
      [F:TPL]GTEPRO = [M:TPE1]GTEPRO(nolign - 1)
      [F:TPL]JOU    = [M:TPE1]JOU(nolign - 1)
      [F:TPL]JOUPRO = [M:TPE1]JOUPRO(nolign - 1)
      Write [F:TPL]
      If ( fstat ) Then
        GOK = 0
        Break
      Endif
    Endif
  Next
Return

#=============================================================================
$INICRE
 Gosub MAJ_TPI
 Local Integer LSRCTYP : LSRCTYP=[F:TPE]SRCTYP
 Local Char    LTABCPT : LTABCPT=[F:TPE]TABCPT
 Local Integer LDPRPLN : LDPRPLN=[F:TPE]DPRPLN
 Call TEMPON("V") From GESECRAN
 Gosub DEF_TRTINT
 Gosub MAJ_TRTINT
 Gosub VALID_TRTINT
 Call TEMPOFF() From GESECRAN
Return

#=============================================================================
$INIMOD
 Gosub MAJ_TPI
 If [M:TPE9]TRTINT=""
  Local Integer LSRCTYP : LSRCTYP=[F:TPE]SRCTYP
  Local Char    LTABCPT : LTABCPT=[F:TPE]TABCPT
  Local Integer LDPRPLN : LDPRPLN=[F:TPE]DPRPLN
  Gosub DEF_TRTINT
 Endif
 Call TEMPON("V") From GESECRAN
 Gosub MAJ_TRTINT
 Gosub VALID_TRTINT
 Call TEMPOFF From GESECRAN
Return

#=============================================================================
$MODIF
 Gosub TEXTRA
 If GOK<1 : Return : Endif

  # FQ85066
  For nolign = 1 To [M:TPE1]NBLEG

    If [M:TPE1]LEGLIN(nolign - 1) <> ""
      [F:TPL]ACETYP = [M:TPE0]ACETYP
      [F:TPL]CPY = [M:TPE0]CPY
      [F:TPL]LEG = [M:TPE0]LEG

      [F:TPL]LEGLIN = [M:TPE1]LEGLIN(nolign - 1)
      [F:TPL]GTE    = [M:TPE1]GTE(nolign - 1)
      [F:TPL]GTEPRO = [M:TPE1]GTEPRO(nolign - 1)
      [F:TPL]JOU    = [M:TPE1]JOU(nolign - 1)
      [F:TPL]JOUPRO = [M:TPE1]JOUPRO(nolign - 1)
      Write [F:TPL]

      If fstat

        Update [F:TPL]
&       Where ACETYP = [M:TPE0]ACETYP and
&             CPY    = [M:TPE0]CPY and
&             LEG    = [M:TPE0]LEG and
&             LEGLIN = [M:TPE1]LEGLIN(nolign - 1)
&       With  GTE     = [M:TPE1]GTE(nolign - 1),
&             GTEPRO  = [M:TPE1]GTEPRO(nolign - 1),
&             JOU     = [M:TPE1]JOU(nolign - 1),
&             JOUPRO  = [M:TPE1]JOUPRO(nolign - 1)

        If fstat or adxuprec = 0
          GOK = 0
          Break
        Endif
      Endif
    Endif
  Next
Return

#=============================================================================
$TERMINE
 If dim(GFROMCNX)>0 : Kill GFROMCNX : Endif
Return

#=============================================================================
$AV_ANNULE

 If !clalev([F:TPI]) : Local File TYPACEINT [F:TPI] : Endif
# FQ85066
Delete [F:TPI] Where ACETYP = [F:TPE]ACETYP and
&                    LEG = [F:TPE]LEG and CPY = [F:TPE]CPY
 If fstat
  GOK=0
 Endif
 Gosub SUP_TRTINT


# FQ85066
  Delete [TPL] Where ACETYP = [F:TPE]ACETYP and
&                    LEG = [F:TPE]LEG and CPY = [F:TPE]CPY
Return

#=============================================================================
$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("TYPACE","DESTRA",CLECUR2,num$(CLECUR1),"TYPACE","DESTRA",num$([M:TPE0]ACETYP),"")  From ATEXTRA
Endif
Call MAJTEXTRA([M:TPE0]DESTRA,"TYPACE","DESTRA",[M:TPE0]ACETYP,"") From ATEXTRA
Return

#=============================================================================
$SEL_LISTE

Case LISTE
    When "SELTPELIS" : Gosub SELTPELIS
    When "SELGAULIS" : Gosub SELGAULIS
Endcase

Return

$SELTPELIS
     # Sélection liste sur les Types d'écriture
      Local Char LDES, LLEG
      Local Char LREQ(255)
      If clalev([F:TPE])=0 : Local File TYPACE [TPE] : Endif
      If PARAM(1)<>""
       If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
       Read [F:CPY]CPY0=PARAM(1)
       If !fstat : LLEG=[F:CPY]LEG : Endif
      Endif
      NBTEX = 0
      TIT = mess(107,GML_MSGCPT,1)
      LREQ='((CPY="" | CPY=PARAM(1)) & ENAFLG=G_OUI)'
      If LLEG<>""
       LREQ+='& (LEG=LLEG | LEG="")'
      Endif
      #Fq-XXXXX If PARAM(2)=""  : Filter [F:TPE] Where evalue(LREQ)    Order By CPY Asc : Endif
      Filter [F:TPE] Where evalue(LREQ)                    Order By CPY Asc
      #Fq-XXXXX      If PARAM(2)<>"" : Filter [F:TPE] Where evalue(LREQ) & evalue(PARAM(2)) Order By CPY Asc : Endif
      For [TPE]
        If [F:TPE]SRCTYP=GVML_SRCEVT
         If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
         Read [F:ADI]CODE=GTD_EVENT;[F:TPE]EVTTYP
         # FQ59900
         If !find([F:ADI]A2,GTABEVT)
          Goto $NEXT_SEL_TPE
         Endif
        Endif
        If [F:TPE]SRCTYP=GVML_SRCRPR & G_ACTCCN <>G_OUI : Goto $NEXT_SEL_TPE : Endif #@fq66210
        NBTEX += 1
        TEX(NBTEX)   = [F:TPE]ACETYP
        Call LECTEXTRA(LDES,"TYPACE","DESTRA",[F:TPE]ACETYP,"") From ATEXTRA
        TEXTE(NBTEX) = [F:TPE]ACETYP-LDES
        If [F:TPE]CPY=""
         TEXTE(NBTEX) -= "("+mess(36,GML_MSGFASPR,1)+")"
        Endif
        $NEXT_SEL_TPE
      Next
      Filter [F:TPE]

If clalev([F:TPE])=0 : Local File TYPACE     [TPE] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif

Local Char TEX(GLONDES)(0..nbrecord([TPE])+3)
Local Char TEXTE(GLONDES)(0..nbrecord([TPE])+3)
Local Char CRITERE(250)(1..2)

Local Char    WCPY(GLONCPY)
Local Char    WLEG(GLONADI)

Local Integer ERR
#--------------------------------------------------------------------------------------------------
# Récupération des paramètres
#--------------------------------------------------------------------------------------------------
WLEG    = PARAM(1)
WCPY    = PARAM(2)

#--------------------------------------------------------------------------------------------------
## Critères
#--------------------------------------------------------------------------------------------------
 CRITERE(1)   = "[F:TPE]ENAFLG=2"
 If WLEG<>""
  CRITERE(1)  +=  ' & ([F:TPE]LEG="'+WLEG+'" | [F:TPE]LEG="")'
 Else
  CRITERE(1)  +=  ' & [F:TPE]LEG=""'
 Endif
 If WCPY<>""
  CRITERE(1)  +=  ' & ([F:TPE]CPY="'+WCPY+'" | [F:TPE]CPY="")'
 Endif

# FQ104366 : suppression du code législation (et du code société qui n'était même pas pris en compte)
#Link [TPE] With [AXX]AXX0 = "TYPACE";"DESTRA";GLANGUE;[F:TPE]ACETYP;[F:TPE]LEG;[F:TPE]CPY
#&  As [LNC]
#&  Where evalue(CRITERE)
#&  Order By Key CLE = [F:TPE]ACETYP;[F:TPE]LEG;[F:TPE]CPY Desc
Link [TPE] With [AXX]AXX0 = "TYPACE";"DESTRA";GLANGUE;[F:TPE]ACETYP;""
&  As [LNC]
&  Where evalue(CRITERE)
&  Order By Key CLE = [F:TPE]ACETYP;[F:TPE]LEG;[F:TPE]CPY Desc

NBTEX = 0
For [LNC]CLE(1)
 NBTEX += 1
 TEX(NBTEX)     = [F:TPE]ACETYP
 TEXTE(NBTEX) = format$("K:"+num$(GLONTPE+3)+"X",[F:TPE]ACETYP)+ [F:AXX]TEXTE
&           +   format$("K:"+num$(GLONTPE+3)+"X",[F:TPE]LEG)
Next

Sorta NBTEX+1 TEXTE, TEX Order By TEX(indice)

TIT(0) = mess(12,123,1)  # Choix
Call TITOBJ("TPE","",TIT(1)) From CONTOBJ
TIT(0) -= TIT(1)
TIT(2) = mess(82,123,1)  # Intitulé

Return

$SELGAULIS

  # Sélection liste sur les Pièces automatiques
  Local Char LDES, LLEG
  Local Char LREQ(255)
  If clalev([F:GAU])=0 : Local File GAUTACE [GAU] : Endif
  # PARAM(1) = CPY
  # PARAM(2) = LEG
  If PARAM(1)<>"" and PARAM(2)=""
     If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
     Read [F:CPY]CPY0=PARAM(1)
     If !fstat : LLEG=[F:CPY]LEG : Endif
  Else
     If PARAM(2)<> ""
        LLEG=PARAM(2)
     Endif
  Endif
  NBTEX = 0
  TIT = mess(107,GML_MSGCPT,1)
  LREQ='((CPY="" | CPY=PARAM(1)))'
  Filter [F:GAU] Where evalue(LREQ)                    Order By COD Asc
  For [GAU]
     If LLEG<>""
        If dim([F:GAU]NBRLEG)>0 & [F:GAU]NBRLEG<>0
        If  !find(LLEG,[F:GAU]ACTLEG(0..dim([F:GAU]ACTLEG)-1))
           Goto NEXT_SEL_GAU
        Endif
     Endif
  Endif
  NBTEX += 1
  TEX(NBTEX)   = [F:GAU]COD
  Call LECTEXTRA(LDES,"GAUTACE","DESTRA",[F:GAU]COD,"") From ATEXTRA
  TEXTE(NBTEX) = [F:GAU]COD-LDES
  $NEXT_SEL_GAU
Next

Return
##################################################
# FQ85066
# interdiction, pour la création/duplication,
#  d'un type sans LEG à un type avec et inversement
##################################################
Subprog VERIF_AUTRE_NIV(PACETYP, PLEG, PCPY, ROK)
Value Char PACETYP(), PLEG(), PCPY()
Variable Integer ROK

  ROK = 1
  If PLEG = "" # cela veut dire aussi que la société est à blanc
    Filter [TPE] Where ACETYP = PACETYP and LEG <> ""
    Look [TPE]TPE0 First
    Filter [TPE]
    If fstat = 0
      ROK = -2
    Endif
  Else
    Look [TPE]TPE0(2) = PACETYP ; ""
    If fstat = 0
      ROK = -1
    Endif
  Endif

  If PCPY = ""
    Filter [TPE] Where ACETYP = PACETYP and CPY <> ""
    Look [TPE]TPE0 First
    Filter [TPE]
    If fstat = 0
      ROK = -3
    Endif
  Else
    Filter [TPE] Where ACETYP = PACETYP and CPY = ""
    Look [TPE]TPE0 First
    Filter [TPE]
    If fstat = 0
      ROK = -4
    Endif
  Endif
End

##################################################
##Fq-85066  Selection from List TPE "Posting Types"
##################################################
Subprog SELTPE(COD,LEG,CPY)
Variable Char    COD()
Value    Char    CPY()
Value    Char    LEG()
Local Char PARMSK(30)(1..10)
PARMSK(1)=[L]LEG
PARMSK(2)=[L]CPY

If clalev([F:TPE])=0 : Local File TYPACE [TPE] : Endif
# l'action SELTPE est ensuite traitée dans le Taitement SELTPE
Call S_TAB_CHAR(COD,PARMSK,"SELTPE","SELTPE","") From GACTION
End
##################################################
#Fq-85066   Tunnel TPE "Posting Types"
#################################################
## Tunnel TPE "Posting Types"
Subprog TUNTPE(COD,LEG, CPY)
Variable Char    COD()
Value    Char    LEG()
Value    Char    CPY()

Local Char LCOD
Local Char LLEG
Local Char LCPY

If clalev([F:TPE])=0 : Local File TYPACE [TPE] : Endif

LCOD = COD
LLEG = LEG
LCPY = CPY

 Read [TPE]TPE0 = LCOD;LEG;LCPY
 If fstat
     Read [TPE]TPE0 = LCOD;"";LCPY
     LLEG = ""
 Endif

   Call OBJET_CHAR(LLEG,"TPE",LCOD+"~"+LCPY) From GOBJET

End
#=============================================================================
$CHANGE
 [F:CHGT]TRTINT="WP"+NCODE
Return

#=============================================================================
$AP_CHANGE
 # Ancien code  OCODE
 # Nouveau code NCODE
 # Table à mettre à jour avec le nouveau nom de traitement [F:CHGT]
 [M:TPE0]ACETYP=NCODE
 Gosub DEF_TRTINT
 Gosub MAJ_TRTINT
Return

#=============================================================================
$SET_TPE9
 #> Initialisation du tableau de l'onglet interface :

 Gosub DEF_LSTFLD

 Local Integer I_VAR, I_FLD

 Raz [M:TPE9]

 For I_VAR=1 To LNBFLD
  If LDIMFLD(I_VAR)>1
   Local Integer I_IND
   For I_IND=1 To LDIMFLD(I_VAR)
    I_FLD+=1
    [M:TPE9]TMPFLD(I_FLD-1) = LLISTFLD(I_VAR)
    [M:TPE9]TMPIND(I_FLD-1) = I_IND
    [M:TPE9]NUMLIG(I_FLD-1) = LNUMLIG(I_VAR)
   Next I_IND
  Else
   I_FLD+=1
   [M:TPE9]TMPFLD(I_FLD-1) = LLISTFLD(I_VAR)
   [M:TPE9]TMPIND(I_FLD-1) = 0
   [M:TPE9]NUMLIG(I_FLD-1) = LNUMLIG(I_VAR)
  Endif
 Next I_VAR
 [M:TPE9]NBLIG=I_FLD

 Sorta [M:TPE9]NBLIG [M:TPE9]NBLIG Order By [M:TPE9]NUMLIG([S]indice), [M:TPE9]TMPFLD([S]indice), [M:TPE9]TMPIND([S]indice)

 Affzo [M:TPE9]
Return

#=============================================================================
$DEF_LSTFLD

 Local  Integer LNBFLD,I_ZONE, LNBEXCFLD

  # FQ85066 : ajout des nvx chps en exception : LNBEXCFLD= de 12 à 17
 LNBEXCFLD=17
 Local  Char    LEXCFLD(10)(1..LNBEXCFLD)
 LEXCFLD(01)="TRTNUM"
 LEXCFLD(02)="PCENUM"
 LEXCFLD(03)="SEQNUM"
 LEXCFLD(04)="CPTKEY"
 LEXCFLD(05)="AGRKEY"
 LEXCFLD(06)="CPTSTA"
 LEXCFLD(07)="CPY"
 LEXCFLD(08)="FCY"
 LEXCFLD(09)="REF"
 LEXCFLD(10)="LIN"
 LEXCFLD(11)="LEG"
 LEXCFLD(12)="CPTREF"
 LEXCFLD(13)="CREDATTIM"
 LEXCFLD(14)="UPDDATTIM"
 LEXCFLD(15)="CREUSR"
 LEXCFLD(16)="UPDUSR"
 LEXCFLD(17)="AUUID"

 If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
 For [F:ATZ] Where CODFIC="TMPCPTDTA"
  If !find([F:ATZ]CODZONE,LEXCFLD)
   LNBFLD+=1
  Endif
 Next

 Local  Char    LLISTFLD(10)(1..LNBFLD)
 Local  Integer LDIMFLD(1..LNBFLD)
 Local  Integer LSPEFLD(1..LNBFLD)
 Local  Integer LNUMLIG(1..LNBFLD)

 For [F:ATZ] Where CODFIC="TMPCPTDTA"
  If !find([F:ATZ]CODZONE,LEXCFLD)
   I_ZONE+=1
   LLISTFLD(I_ZONE)=[F:ATZ]CODZONE
   If [F:ATZ]CODZONE="CCE" | [F:ATZ]CODZONE="CCED" | [F:ATZ]CODZONE="DIE"
    LDIMFLD(I_ZONE)=20
   Else
    LDIMFLD(I_ZONE)=[F:ATZ]DIME
   Endif
   LNUMLIG(I_ZONE)=[F:ATZ]NUMLIG
  Endif
 Next

Return

#=============================================================================
$FILL_LSTFLD
 LLISTFLD(01)="SNS"       :  LDIMFLD(01)=1
 LLISTFLD(02)="CUR"       :  LDIMFLD(02)=1
 LLISTFLD(03)="ACCCOD"    :  LDIMFLD(03)=2
 LLISTFLD(04)="DSP"       :  LDIMFLD(04)=1
 LLISTFLD(05)="CCE"       :  LDIMFLD(05)=9
 LLISTFLD(06)="DIE"       :  LDIMFLD(06)=9
 LLISTFLD(07)="IASCGU"    :  LDIMFLD(07)=2
 LLISTFLD(08)="AASBUS"    :  LDIMFLD(08)=2
 LLISTFLD(09)="OWNTYP"    :  LDIMFLD(09)=1
 LLISTFLD(10)="ETRNAT"    :  LDIMFLD(10)=1
 LLISTFLD(11)="LEATYP"    :  LDIMFLD(11)=1
 LLISTFLD(12)="GRATYP"    :  LDIMFLD(12)=1
 LLISTFLD(13)="GRASTA"    :  LDIMFLD(13)=1
 LLISTFLD(14)="GACACN"    :  LDIMFLD(14)=2
 LLISTFLD(15)="GAC"       :  LDIMFLD(15)=4
 LLISTFLD(16)="IASACN"    :  LDIMFLD(16)=2
 LLISTFLD(17)="IASACC"    :  LDIMFLD(17)=2
 LLISTFLD(18)="EVTPRINC"  :  LDIMFLD(18)=1
 LLISTFLD(19)="AMT"       :  LDIMFLD(19)=20
 LLISTFLD(20)="ALPHA"     :  LDIMFLD(20)=4
 LLISTFLD(21)="DAT"       :  LDIMFLD(21)=2
Return

#=============================================================================
$MAJ_TPI
 Local Integer I_FLD
 GOK=1
 For I_FLD=1 To [M:TPE9]NBLIG
  Raz [F:TPI]
  # FQ85066
  Read [F:TPI]TPI0=[M:TPE0]ACETYP;[M:TPE0]LEG;[M:TPE0]CPY;[M:TPE9]TMPFLD(I_FLD-1);[M:TPE9]TMPIND(I_FLD-1)
  If fstat=5
   [F:TPI]ACETYP=[M:TPE0]ACETYP
   # FQ85066
   [F:TPI]LEG=[M:TPE0]LEG
   [F:TPI]CPY=[M:TPE0]CPY
   [F:TPI]TMPFLD=[M:TPE9]TMPFLD(I_FLD-1)
   [F:TPI]TMPIND=[M:TPE9]TMPIND(I_FLD-1)
   [F:TPI]NUMLIG=[M:TPE9]NUMLIG(I_FLD-1)
  Endif
  [F:TPI]ENALIG=[M:TPE9]ENALIG(I_FLD-1)
  [F:TPI]ORICND=[M:TPE9]ORICND(I_FLD-1)
  [F:TPI]ORIEXP=[M:TPE9]ORIEXP(I_FLD-1)
  [F:TPI]ORITAB=[M:TPE9]ORITAB(I_FLD-1)
  [F:TPI]ORIFLD=[M:TPE9]ORIFLD(I_FLD-1)
  If fstat=5
   Write [F:TPI]
  Elsif fstat=0
   Rewrite [F:TPI]
  Endif
  If fstat
   GOK=0
   Call FSTA("TPI") From GLOCK
   Break
  Endif
 Next I_FLD
Return

#=============================================================================
$DEF_TRTINT
 Local Char    LTRTINT
 Local Integer LLSTTRT
 Local Integer LDECAL
 LTRTINT="WP"+[M:TPE0]ACETYP
 [M:TPE9]TRTINT=LTRTINT
 Affzo [M:TPE9]TRTINT
Return

#=============================================================================
$MAJ_TRTINT
 If [M:TPE9]TRTINTOLD="" & [M:TPE9]TRTINT<>""
  #Infbox "Création du traitement"-[M:TPE9]TRTINT
  Gosub CRE_TRTINT
 Endif

 If [M:TPE9]TRTINT<>"" & [M:TPE9]TRTINTOLD=[M:TPE9]TRTINT
  #Infbox "Mise à jour du traitement"-[M:TPE9]TRTINT
  Gosub CRE_TRTINT
 Endif

 If [M:TPE9]TRTINT<>"" & [M:TPE9]TRTINTOLD<>"" & [M:TPE9]TRTINTOLD<>[M:TPE9]TRTINT
  #Infbox "Suppression"-[M:TPE9]TRTINTOLD-"Création"-[M:TPE9]TRTINT
  Gosub SUP_TRTINT
  Gosub CRE_TRTINT
 Endif
Return

#=============================================================================
$SUP_TRTINT
 If dim(PAPPLI)>0
   Call DELTRT([M:TPE9]TRTINTOLD,PAPPLI) From SUBADC
 Else
   Call DELTRT([M:TPE9]TRTINTOLD,nomap) From SUBADC
 Endif

Return

#=============================================================================
$CRE_TRTINT
 Local Char    NOMTRT
 Local Char    FICSRC(250)
 Local Integer I_FLD
 Local Char    LIGNE(110)
 Local Char    LDECAL

 NOMTRT = [M:TPE9]TRTINT
 If dim(PAPPLI)>0
  FICSRC = filpath("TRT",NOMTRT,"src",PAPPLI)
 Else
  FICSRC = filpath("TRT",NOMTRT,"src",nomap)
 Endif
 Openo FICSRC,0
 adxifs = ""
 adxirs = chr$(10)
 #Openo FICSRC

 #> En-tête
 #  -------

 Sorta [M:TPE9]NBLIG [M:TPE9]NBLIG Order By [M:TPE9]NUMLIG([S]indice), [M:TPE9]TMPFLD([S]indice), [M:TPE9]TMPIND([S]indice)
 Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
 Wrseq '# MODIFIE PAR :'-GUSER
 Wrseq '# LE          :'-format$("DD4",date$)
 Wrseq ''
 Wrseq '$ALIM_TCD'
 For I_FLD=1 To [M:TPE9]NBLIG
  LDECAL=""
  If [M:TPE9]ENALIG(I_FLD-1)=G_OUI
   Wrseq 'If dim([F:TCD]'+[M:TPE9]TMPFLD(I_FLD-1)+')>0'
   If [M:TPE9]ORICND(I_FLD-1)<>""
    Wrseq ' If'-[M:TPE9]ORICND(I_FLD-1)
    LDECAL=" "
   Endif
   If [M:TPE9]TMPIND(I_FLD-1)=0
    LIGNE = ' [F:TCD]'+[M:TPE9]TMPFLD(I_FLD-1)+'='
   Else
    LIGNE = ' [F:TCD]'+[M:TPE9]TMPFLD(I_FLD-1)+'('+num$([M:TPE9]TMPIND(I_FLD-1)-1)+')'+'='
   Endif
   If [M:TPE9]ORITAB(I_FLD-1)<>""
    If [M:TPE9]ORITAB(I_FLD-1)=[M:TPE1]TABCPT
     LIGNE+='[F:CPT]'
    Endif
    If [M:TPE9]ORITAB(I_FLD-1)=[M:TPE1]TABOBJ
     LIGNE+='[F:OBJ]'
    Endif
    LIGNE+=[M:TPE9]ORIFLD(I_FLD-1)
   Elsif [M:TPE9]ORIEXP(I_FLD-1)<>""
    LIGNE+=[M:TPE9]ORIEXP(I_FLD-1)
   Endif
   Wrseq LDECAL+LIGNE
   If [M:TPE9]ORICND(I_FLD-1)<>""
    Wrseq ' Endif'
   Endif
   Wrseq 'Endif '
  Endif
 Next I_FLD
 Wrseq ' GPOINT = "ALIMTCD" : Gosub ENTREE From EXEFNC'
 Wrseq 'Return'
 Sorta [M:TPE9]NBLIG [M:TPE9]NBLIG Order By [M:TPE9]TMPFLD([S]indice), [M:TPE9]TMPIND([S]indice)

 #> Fin de la génération du fichier source
 #  --------------------------------------

 Openo

Return

#=============================================================================
$VALID_TRTINT

#Infbox "Validation du traitement"-[M:TPE9]TRTINT

 # Compilation du traitement associé au code interne
 #  ------------------------------------------------

 If dim(OK)<0 : Local Integer OK : Endif

 If dim(PAPPLI)>0
  Call VALID("TRT",[M:TPE9]TRTINT,PAPPLI,OK) From VALMSKSUB
 Else
  Call VALID("TRT",[M:TPE9]TRTINT,nomap,OK) From VALMSKSUB
 Endif
 If OK=0
   GOK=0
   Local Char MESSAGE_ERR(100)
   If dim(PAPPLI)>0
    MESSAGE_ERR="Erreur de compilation du traitement"-[M:TPE9]TRTINT-PAPPLI
   Else
    MESSAGE_ERR="Erreur de compilation du traitement"-[M:TPE9]TRTINT-nomap
   Endif
   If GTRACE<>""
     Call ECR_TRACE (MESSAGE_ERR,1) From GESECRAN
   Else
     Infbox MESSAGE_ERR
   Endif
 Else
  #Infbox "Génération du traitement"-[M:TPE9]TRTINT-"Ok"
  If [M:TPE9]TRTINT<>[M:TPE9]TRTINTOLD
   [M:TPE9]TRTINTOLD = [M:TPE9]TRTINT : Affzo [M:TPE9]TRTINTOLD
   [F:TPE]TRTINT     = [M:TPE9]TRTINT
  Endif
 Endif

Return

#=============================================================================
$TRTCOP

#-----------------------------------------------------------#
# Etiquette appelée depuis le traitement superviseur ACOPIE #
# --------------------------------------------------------- #

If [M]DOSORG=nomap
 Local File TYPACE    [TPE1]
 Local File TYPACEINT [TPI1]
 Local File ATEXTRA   [AXX1]
 # FQ85066
 Local File TYPACELEG [TPL1]
Else
 Local File =[M]DOSORG+".TYPACE"    [TPE1]
 Local File =[M]DOSORG+".TYPACEINT" [TPI1]
 Local File =[M]DOSORG+".ATEXTRA"   [AXX1]
 # FQ85066
 Local File =[M]DOSORG+".TYPACELEG" [TPL1]
Endif
If [M]DOSDES=nomap
 Local File TYPACE    [TPE2]
 Local File TYPACEINT [TPI2]
 Local File ATEXTRA   [AXX2]
 # FQ85066
 Local File TYPACELEG [TPL2]
 Local File ATABDIV   [ADI2] : # Fq104672
Else
 Local File =[M]DOSDES+".TYPACE"    [TPE2]
 Local File =[M]DOSDES+".TYPACEINT" [TPI2]
 Local File =[M]DOSDES+".ATEXTRA"   [AXX2]
 # FQ85066
 Local File =[M]DOSDES+".TYPACELEG" [TPL2]
 # FQ101153
 Local File =[M]DOSDES+".ACTIV"     [ACV2]
 Local File =func DOSCONT.DOSX3([M]DOSDES)+".ADOSSIER"  [ADS2]
 Local File =[M]DOSDES+".ATABDIV"   [ADI2] : # Fq104672
Endif
Local File =[M]DOSDES+".COMPANY"    [CPY]

# FQ101153 : gestion de la législation
Local Shortint WMONOLEGDES    : # 0 : le dossier destination est mono-législation
                                # 1 : le dossier destination est multi-législation
Local Char SZDOSSIER(GLONADS) : # Nom du dossier destination sans l'adresse si c'est un dossier distant
Local Char CRITLEGLIN(255)    : # Critère de sélection sur le champ LEGLIN pour la table TYPACELEG
Local Char LEGDES(GLONADI)    : # Valeur que doit prendre le champ Législation dans les enregistrements du dossier destination
LEGDES = TABLE2

If [M]DOSDES<>nomap
 # Le dossier destination est-il mono-leg ?
 If [F:ACV2]CODACT<>"LEG"
  Read [ACV2]CODACT = "LEG"
  If fstat Raz [F:ACV2] : Endif
 Endif
 If [F:ACV2]FLACT<>2
  WMONOLEGDES=0
 Else
  WMONOLEGDES=1
 Endif

 If WMONOLEGDES =0
  # ----------------------------
  # Dossier destination mono-leg
  # ----------------------------
  LG = instr(1, [M]DOSDES, "@")
  If LG = 0 Then
   SZDOSSIER = [M]DOSDES
  Else
   SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
  Endif
  Read [ADS2]DOSSIER=SZDOSSIER
  If fstat
   # Pb lecture dossier destination
   Call MESSAGE(SZDOSSIER-":"-mess(78,133,1) ) From GESECRAN  #-- Dossier inexistant --#
   Return
  Endif
  If [F:ADS2]DOSLEG(0)=""
   # Pas de législation pour le dossier destination. Ce n'est pas normal.
   Call MESSAGE(SZDOSSIER-":"-mess(241,133,1) ) From GESECRAN  #-- Il doit y avoir au moins une législation  --#
   Return
  Endif
  If TABLE2<>[F:ADS2]DOSLEG(0) & TABLE2<>''
   # La leg de l'enreg. à copier n'est pas tte leg et elle est <> Leg dossier mono-leg
   # Pas de copie
   Call MESSAGE(mess(617,199,1)-"("-[F:ADS2]DOSLEG(0)-") :"-mess(618,199,1)) From GESECRAN
   Return
  Elsif TABLE2=''
   # La leg de l'enreg. à copier est toute leg
   # On peut copier l'enreg : Leg destination=leg du dossier mono-leg
   LEGDES=[F:ADS2]DOSLEG(0)
  Endif
 Else
  # ----------------------------
  # Dossier destination multi-leg
  # ----------------------------
  If TABLE2<>''
   # Enregistrement à copier avec leg<>""
   Local Char SZDOSSIER(GLONADS)
   Local Integer LG
   Read [ADI2]CODE=909; TABLE2
   If fstat
    Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
    Return
   Endif
   LG = instr(1, [M]DOSDES, "@")
   If LG = 0 Then
    SZDOSSIER = [M]DOSDES
   Else
    SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
   Endif
   Read [ADS2]DOSSIER=SZDOSSIER
   If !fstat Then
    If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
     Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN  #-- Législation non gérée par ce dossier --#
     Return
    Endif
   Endif
  Endif
 Endif
Endif

# FQ85066
Read [TPE1]TPE0 = TABLE; TABLE2; TABLE3
OK = G_OUI
Onerrgo ERR_VERS
#Read [TPE2]TPE0 = TABLE
Read [TPE2]TPE0 = TABLE; LEGDES; TABLE3 : # FQ101153 : TABLE2 -> LEGDES
Onerrgo
If OK = G_NON
  GOK = 0
  Return
Endif

If !fstat
 OK=1
 # FQ85066
 Local Char WMESS(250)
 WMESS = [M]DOSDES - TABLE
 WMESS -= "/" -LEGDES : # FQ101153 : TABLE2 -> LEGDES
 WMESS -= "/" -TABLE3
 WMESS -= mess(22,100,1)
 Call AVERTIR(WMESS, OK) From GESECRAN
 If OK<>2 : OK = 0 : GOK=0 : Return : Endif
Endif

Call DEBTRANS From GLOCK
Gosub TR_COP

Close Local File [TPE1], [TPE2]
Return

$TR_COP
# FQ85066 : ce GOSUB est repris par l'ajout de TABLE2 et TABLE3
# sur TPE2, TPI2 et gestion de TPL2
Local Char DESIG1(GLONDES)
GOK = 1
Trbegin [TPE2], [TPI2], [TPL2]

 Delete [TPE2]TPE0 = TABLE; LEGDES; TABLE3 : # FQ101153 : TABLE2 -> LEGDES
 If fstat
  GOK = 0 : Call FSTA("TPE2") From GLOCK : Goto AB_TR_COP
 Endif

 Delete [TPI2] Where ACETYP = TABLE and LEG = LEGDES and CPY = TABLE3 : # FQ101153 : TABLE2 -> LEGDES
 If fstat
  GOK = 0 : Call FSTA("TPI2") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [TPL2] Where ACETYP = TABLE and LEG = LEGDES and CPY = TABLE3 : # FQ101153 : TABLE2 -> LEGDES
 If fstat
  GOK = 0 : Call FSTA("TPL2") From GLOCK : Goto AB_TR_COP
 Endif

 [F:TPE2]    = [F:TPE1]
 [F:TPE2]LEG = LEGDES : # FQ101153
 If dim([F:TPE2]CREUSR)>0 : [F:TPE2]CREUSR = GUSER   : Endif
 If dim([F:TPE2]CREDAT)>0 : [F:TPE2]CREDAT = date$   : Endif
 If dim([F:TPE2]UPDUSR)>0 : [F:TPE2]UPDUSR = ""      : Endif
 If dim([F:TPE2]UPDDAT)>0 : [F:TPE2]UPDDAT = [0/0/0] : Endif
 Read [F:CPY]CPY0=[F:TPE1]CPY
 If fstat
  Raz [F:TPE2]CPY
 Endif
 Call COPTEXTRA("TYPACE","DESTRA",[M:TPE0]ACETYP,"") From ATEXTRA
 Write [TPE2]
 If fstat
  GOK = 0 : Call FSTA("TPE2") From GLOCK : Goto AB_TR_COP
 Endif

 For [F:TPI1] Where ACETYP=TABLE and LEG = TABLE2 and CPY = TABLE3
  [F:TPI2]=[F:TPI1]
  [F:TPI2]LEG = LEGDES : # FQ101153
  Write [F:TPI2]
  If fstat
   GOK = 0 : Call FSTA("TPI2") From GLOCK : Goto AB_TR_COP
  Endif
 Next

 For [F:TPL1] Where ACETYP=TABLE and LEG = TABLE2 and CPY = TABLE3
  [F:TPL2]=[F:TPL1]
  [F:TPL2]LEG = LEGDES : # FQ101153
  Write [F:TPL2]
  If fstat
   GOK = 0 : Call FSTA("TPL2") From GLOCK : Goto AB_TR_COP
  Endif
 Next

Commit
Return

# FQ85066 si version < V7 : la structure est différente :m copie impossible
$ERR_VERS
Call AVERTIR(mess(1, 201, 1), OK) From GESECRAN
OK = G_NON
Resume

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

$EXE_TRTCPTINT
 Local Char VALBOUT(30)
 Local Char PARBOUT(250)(1..10)
 Call TRAITE_CHAR(VALBOUT,PARBOUT,"","TRTCPTINT","TRTCPTINT",4,"") From GTRAITE
Return

##########################################################################
## Routine, sous-programmes et fonctions de TPE
##########################################################################

#=====================================================================#
# Sous-programme de lancement auto de la validation des transaction   #
# après intégration patch                                             #
#=====================================================================#
Subprog PATCH(PAPPLI)
 Value Char PAPPLI

 # On  regarde si le module Immobilisation est à "Oui" FQ58489
 If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
 Read [ADS] DOSSIER=PAPPLI : If fstat Raz [F:ADS] : Endif
 If [F:ADS]MODULE(13) <> 2 : End : Endif

 If PAPPLI<>GDOSX3
  Call GENDOS(PAPPLI) From SUBTPE
 Endif
End


#=====================================================================#
# Sous-programme de validation de dossier  GENDOS                     #
# Appelé par le traitement de validation en masse des transactions    #
#=====================================================================#
Subprog GENDOS(PAPPLI)
Value Char PAPPLI

Local Char WMESS(250)

 # On  regarde si le module Immobilisation est à "Oui" FQ58489
 If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
 Read [ADS] DOSSIER=PAPPLI : If fstat Raz [F:ADS] : Endif
 If [F:ADS]MODULE(13) <> 2 : End : Endif

 If !clalev([F:TPE])  : Local File  =PAPPLI+".TYPACE"    [TPE]  : Endif
 Local Integer LNOTRS

 LNOTRS=1
 For [TPE] Where ENAFLG=2
  If [F:TPE]TRTINT<>""
   # FQ85066
   Call VALIDATION(PAPPLI, [F:TPE]ACETYP, [F:TPE]LEG, [F:TPE]CPY)
   LNOTRS=0
  Else
   WMESS = [F:TPE]ACETYP
   If [F:TPE]LEG <> ""
    WMESS += "/" +[F:TPE]LEG
   Endif
   If [F:TPE]CPY <> ""
    WMESS += "/" +[F:TPE]CPY
   Endif

   Call ECR_TRACE(space$(5) + WMESS + space$(20-len(WMESS)) + mess(679,GML_MSGFAS,1),1) From GESECRAN
  Endif
 Next

 If LNOTRS
  Call ECR_TRACE(mess(202,GML_MSGFASPR,1),0) From GESECRAN
 Endif

End

#=====================================================================#
# FQ85066
Subprog VALIDATION(PAPPLI,PTPE, PLEG, PCPY)
Value Char PAPPLI
Value Char PTPE, PLEG, PCPY

  Local Integer I_FLD
  Local Char WMESS(250)

  If !clalev([F:TPE])  : Local File  =PAPPLI+".TYPACE"    [TPE]  : Endif
  If !clalev([F:RTPE]) : Local File  =PAPPLI+".TYPACE"    [RTPE] : Endif
  If !clalev([F:TPI])  : Local File  =PAPPLI+".TYPACEINT" [TPI]  : Endif
  If !clalev([F:TPE9]) : Local Mask  =PAPPLI+".TPE0"      [TPE0] : Endif
  If !clalev([F:TPE9]) : Local Mask  =PAPPLI+".TPE1"      [TPE1] : Endif
  If !clalev([F:TPE9]) : Local Mask  =PAPPLI+".TPE9"      [TPE9] : Endif
  #FQ85066
  If !clalev([F:TPL])  : Local File  =PAPPLI+".TYPACELEG" [TPL]  : Endif

  GOK=1
  If [F:TPE]ACETYP <> PTPE or [F:TPE]LEG <> PLEG or [F:TPE]CPY <> PCPY
    Read [F:TPE]TPE0 = PTPE; PLEG; PCPY
    If fstat
      GOK=0 : Call FSTA("TPE") From GLOCK
      End
    Endif
  Endif

  # FQ85066
  WMESS = [F:TPE]ACETYP
  If [F:TPE]LEG <> ""
    WMESS += "/" +[F:TPE]LEG
  Endif
  If [F:TPE]CPY <> ""
    WMESS += "/" +[F:TPE]CPY
  Endif

  If [F:TPE]TRTINT = ""
    Call ECR_TRACE(space$(5) + WMESS + space$(20-len(WMESS)) +
&        mess(679,GML_MSGFAS,1) + "(" + [F:TPE]TRTINT + ")",-1) From GESECRAN
    End
  Endif

  [M:TPE0]=[F:TPE]
  [M:TPE1]=[F:TPE]
  [M:TPE9]=[F:TPE]
  [M:TPE9]TRTINTOLD=[F:TPE]TRTINT
  # FQ85066
  Filter [F:TPI] Where ACETYP=[F:TPE]ACETYP and LEG = [F:TPE]LEG and CPY = [F:TPE]CPY
  I_FLD = 0
  For [F:TPI]
    I_FLD+=1
    nolign=I_FLD
    [M:TPE9]=[F:TPI]
  Next
  [M:TPE9]NBLIG = I_FLD
  Filter [F:TPI]

  # En fait, inutile pour la génération du traitement
  I_FLD = 0
#  Filter [F:TPL] Where ACETYP=[F:TPE]ACETYP and LEG = [F:TPE]LEG and CPY = [F:TPE]CPY
#  For [F:TPL]
#
#    [M:TPE1]LEGLIN(I_FLD) = [F:TPL]LEGLIN
#    [M:TPE1]GTE(I_FLD) = [F:TPL]GTE
#    [M:TPE1]JOU(I_FLD) = [F:TPL]JOU
#    [M:TPE1]GTEPRO(I_FLD) = [F:TPL]GTEPRO
#    [M:TPE1]JOUPRO(I_FLD) = [F:TPL]JOUPRO
#    I_FLD+=1
#  Next
  [M:TPE1]NBLEG = I_FLD
#  Filter [F:TPL]

  Gosub MAJ_TRTINT   From SUBTPE
  Gosub VALID_TRTINT From SUBTPE
  Call ECR_TRACE(space$(5) + WMESS + space$(20-len(WMESS)) +
&      mess(680,GML_MSGFAS,1) + "(" + [F:TPE]TRTINT + ")",0) From GESECRAN

End

##########################################################################
Funprog EXISTE_EVT_PLN(PEVETYP,PPLN)
Value Char    PEVETYP # Type d'événement
Value Integer PPLN    # Plan d'amortissement

Local Integer RETOUR
Local Integer I_PARM

RETOUR=0
For I_PARM=1 To [M]NBLIG
 If !(I_PARM=nolign)
  If PEVETYP=[M]EVETYP(I_PARM-1) & PPLN=[M]PLN1(I_PARM-1)
   RETOUR=I_PARM
   Break
  Endif
 Endif
Next I_PARM

End RETOUR

##########################################################################
Funprog PLAN_COMPTABILISE(PCPY,PPLN,PACTIF)
Value Char    PCPY
Value Integer PPLN
Value Integer PACTIF

Local Integer RRET : RRET = G_NON
Local Char    LLEG(GLONADI)         : # FQ98060

If !clalev([F:TPE]) : Local File TYPACE [TPE] : Endif

If PCPY<>"" : # FQ98060
  # Lecture de la société pour déterminer sa législation
  If !clalev([F:CPY]) : Local File COMPANY [F:CPY] : Endif
  If ([F:CPY]CPY = PCPY) and ([F:CPY]LEG <> "")
    LLEG = [F:CPY]LEG
  Else
    Read [F:CPY]CPY0=PCPY
    If fstat : Raz [F:CPY] : Endif
    LLEG = [F:CPY]LEG
  Endif
Endif


# FQ98060 Ajout du filtre sur LEG
# Issue 113620 the control on the source "Variance between plans" is removed because it is controlled in the function LNK_COMPTABILISE
If PACTIF=G_OUI
  # Issue 113620 Filter [F:TPE] Where (TABCPT="DEPREC" & (SRCTYP=GVML_SRCDEP|SRCTYP=GVML_SRCLNK) & (CPY=PCPY | CPY="") & ENAFLG=G_OUI & (LEG=LLEG | LEG="")) #@fq64544
  Filter [F:TPE] Where (TABCPT="DEPREC" & (SRCTYP=GVML_SRCDEP) & (CPY=PCPY | CPY="") & ENAFLG=G_OUI & (LEG=LLEG | LEG=""))
Else
  # Issue 113620 FILTER [F:TPE] Where (TABCPT="DEPREC" & (SRCTYP=GVML_SRCDEP|SRCTYP=GVML_SRCLNK) & (CPY=PCPY | CPY="") & (LEG=LLEG | LEG=""))  #@fq64544
  Filter [F:TPE] Where (TABCPT="DEPREC" & (SRCTYP=GVML_SRCDEP) & (CPY=PCPY | CPY="") & (LEG=LLEG | LEG=""))
Endif

For [F:TPE]
 If [F:TPE]DPRPLN=PPLN
  RRET = G_OUI
  Break
 Endif
Next
Filter [F:TPE]

End RRET

#@fq54644
##########################################################################
Funprog LNK_COMPTABILISE(PCPY,PPLN,PACTIF)
Value Char    PCPY
Value Integer PPLN
Value Integer PACTIF

Local Integer RRET : RRET = G_NON
Local Char    LLEG(GLONADI)         : # FQ98060

If !clalev([F:TPE]) : Local File TYPACE [TPE] : Endif

If PCPY<>"" : # FQ98060
  # Lecture de la société pour déterminer sa législation
  If !clalev([F:CPY]) : Local File COMPANY [F:CPY] : Endif
  If ([F:CPY]CPY = PCPY) and ([F:CPY]LEG <> "")
    LLEG = [F:CPY]LEG
  Else
    Read [F:CPY]CPY0=PCPY
    If fstat : Raz [F:CPY] : Endif
    LLEG = [F:CPY]LEG
  Endif
Endif

If PACTIF=G_OUI
 # FQ98060 Ajout du filtre sur LEG
 Filter [F:TPE] Where (TABCPT="DEPREC" & SRCTYP=GVML_SRCLNK & (CPY=PCPY | CPY="") & ENAFLG=G_OUI & (LEG=LLEG | LEG=""))
Else
 # FQ98060 Ajout du filtre sur LEG
 Filter [F:TPE] Where (TABCPT="DEPREC" & SRCTYP=GVML_SRCLNK & (CPY=PCPY | CPY="") & (LEG=LLEG | LEG=""))
Endif

For [F:TPE]
 If [F:TPE]DPRPLN=PPLN
  RRET = G_OUI
  Break
 Endif
Next
Filter [F:TPE]

End RRET

#FQ543443-Gestion des concessions
##########################################################################
Funprog RPR_COMPTABILISE(PCPY,PACTIF)
Value Char    PCPY
Value Integer PACTIF

Local Integer RRET : RRET = G_NON
Local Char    LLEG(GLONADI)         : # FQ98060

If !clalev([F:TPE]) : Local File TYPACE [TPE] : Endif

If PCPY<>"" : # FQ98060
  # Lecture de la société pour déterminer sa législation
  If !clalev([F:CPY]) : Local File COMPANY [F:CPY] : Endif
  If ([F:CPY]CPY = PCPY) and ([F:CPY]LEG <> "")
    LLEG = [F:CPY]LEG
  Else
    Read [F:CPY]CPY0=PCPY
    If fstat : Raz [F:CPY] : Endif
    LLEG = [F:CPY]LEG
  Endif
Endif

If PACTIF=G_OUI
 # FQ98060 Ajout du filtre sur LEG
 Filter [F:TPE] Where (SRCTYP=GVML_SRCRPR & (CPY=PCPY | CPY="") & ENAFLG=G_OUI & (LEG=LLEG | LEG=""))
Else
 # FQ98060 Ajout du filtre sur LEG
 Filter [F:TPE] Where (SRCTYP=GVML_SRCRPR & (CPY=PCPY | CPY="") & (LEG=LLEG | LEG=""))
Endif


#Fq-81074 For [F:TPE]
Look [TPE]First
If fstat= 0 #FQ-81074
 RRET = G_OUI
Endif
#Fq-81074 Break
#Fq-81074 Next
Filter [F:TPE]

End RRET

#FQ56791
##########################################################################
Funprog GET_FLD_DES(PATB,PFLD)
Value Char PATB
Value Char PFLD
Local Char RDES(80)

 If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
 If !clalev([F:ATX]) : Local File ATEXTE  [ATX] : Endif
 Read [F:ATZ]CODZONE=PATB;PFLD
 Read [F:ATX]NUMERO=GLANGUE;[F:ATZ]NOCOURT
 RDES=[F:ATX]TEXTE

End RDES

##########################################################################
$AUZ_CPY
 # Fonction de contrôle de l'habilitation / société
 If GNBAUZ <> GNBSITE : # Pas d'habilitation tous sites
  If L_CPY <> ""
   mkstat=0
   Call CONTALLFCY(L_CPY) From SUPCPT
   If mkstat : OK=0 : mkstat=0 : Endif
  Else
   # Vous n'êtes pas habilité pour la modification des paramètrages par défaut
   OK=0 : GMESSAGE=mess(113,GML_MSGFASPR,1)
  Endif
 Endif
Return

