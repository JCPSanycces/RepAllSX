##########################################################################
Subprog AM_ACETYP(VALEUR)
Variable Char VALEUR()
  # FQ85066
  Gosub CRE_TABLEG
End

######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
 Call LECTURE("CPY",VALEUR,"") From CONTOBJ

 If dim([M]LEG)>0
  If [F:CPY]LEG<>""
   [M:TPE0]LEG=[F:CPY]LEG
   Grizo [M:TPE0]LEG
  Else
   Raz [M:TPE0]LEG
   Actzo [M:TPE0]LEG
  Endif
  Affzo [M:TPE0]LEG
  Affzo [M:TPE0]ZLEG
 Endif

  # FQ85066
  Gosub CRE_TABLEG

End
######################################################################################
## FQ-89249 Contrôle du groupe saisi
######################################################################################
Subprog C_ACEGRP(VALEUR)
Variable Char    VALEUR()
Local Shortint STAT
Local Char MESSA(250)

Call CNTCOHGRPLEG(VALEUR,[M:TPE0]LEG,STAT,MESSA) From CPTCNT
If !STAT
    GMESSAGE=MESSA
    mkstat=2 : End
Endif

End
######################################################################################
# Actions champ masque TPE1
######################################################################################

######################################################################################
Subprog AS_SRCTYP(VALEUR)
Variable Integer VALEUR
  #GMENLOC(3)=GVML_SRCOTH
  #FQ54343
  If G_ACTCCN<>G_OUI
   GMENLOC(4)=1
  Endif
  #FQ64544
  If G_ACTLNK<>G_OUI
   GMENLOC(5)=1
  Endif
End

######################################################################################
Subprog AM_SRCTYP(VALEUR)
Variable Integer VALEUR

 Case VALEUR
  When GVML_SRCEVT
   Actzo [M:TPE1]EVTTYP
   Diszo [M:TPE1]TABCPT
   Effzo [M:TPE1]TABCPT
   Raz [M:TPE1]GTEPRO : Diszo [M:TPE1]GTEPRO
   Raz [M:TPE1]JOUPRO : Diszo [M:TPE1]JOUPRO
  When GVML_SRCDEP, GVML_SRCLNK
   Effzo [M:TPE1]EVTTYP
   Diszo [M:TPE1]EVTTYP
   [M:TPE1]TABCPT="DEPREC"
   [M:TPE1]TABOBJ="FXDASSETS"
   Diszo [M:TPE1]TABCPT
   Actzo [M:TPE1]DPRPLN
   Actzo [M:TPE1]GTEPRO
   Actzo [M:TPE1]JOUPRO
  When GVML_SRCOTH
   Effzo [M:TPE1]EVTTYP
   Diszo [M:TPE1]EVTTYP
   Effzo [M:TPE1]TABCPT
   Actzo [M:TPE1]TABCPT
   Effzo [M:TPE1]DPRPLN
   Diszo [M:TPE1]DPRPLN
   Effzo [M:TPE1]TABOBJ
  When GVML_SRCRPR
   #FQ54343
   Effzo [M:TPE1]EVTTYP
   Diszo [M:TPE1]EVTTYP
   [M:TPE1]TABCPT="CCNRPR"
   [M:TPE1]TABOBJ="FXDASSETS"
   Actzo [M:TPE1]TABCPT
   [M:TPE1]DPRPLN=G301AUC #Effzo [M:TPE1]DPRPLN #fq66710
   Diszo [M:TPE1]DPRPLN
 Endcase

 # FQ85066
 [M:TPE1]SRCTYP = VALEUR
 Gosub AFFICH_SIMU

 Local Integer LSRCTYP : LSRCTYP=VALEUR
 Local Char    LTABCPT : LTABCPT=[F:TPE]TABCPT
 Local Integer LDPRPLN : LDPRPLN=[F:TPE]DPRPLN
End

######################################################################################
Subprog AM_EVTTYP(VALEUR)
Variable Char    VALEUR()
 If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
 Read [F:ADI]CODE=GTD_EVENT;VALEUR # Table diverse 962
 [M:TPE1]TABCPT=[F:ADI]A2
 Case [F:ADI]N2
  When GVML_OMDEPEN : [M:TPE1]TABOBJ="LAYOUTFAS"
  When GVML_OMBIEN  : [M:TPE1]TABOBJ="FXDASSETS"
  When GVML_OMSUBV  : [M:TPE1]TABOBJ="GRANTS"
  When GVML_OMLOCFI : [M:TPE1]TABOBJ="LEASE"
 Endcase
 [M:TPE1]EVTPLN=[F:ADI]N1
 Effzo [M:TPE1]20
 Local Integer LSRCTYP : LSRCTYP=[F:TPE]SRCTYP
 Local Char    LTABCPT : LTABCPT=[F:TPE]TABCPT
 Local Integer LDPRPLN : LDPRPLN=[F:TPE]DPRPLN
End

######################################################################################
Subprog AM_TABCPT(VALEUR)
Variable Char VALEUR()
 If [M]SRCTYP=GVML_SRCOTH & VALEUR<>""
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  Filter [F:ATZ] Where CODFIC=VALEUR & NOLIB=GML_NPLAN
  Read[ATZ]  First
  If !fstat
   Actzo [M]DPRPLN
  Elsif fstat=5 | fstat=4
   Diszo [M]DPRPLN
  Endif
  Affzo [M]DPRPLN
  Filter [F:ATZ]
 Endif
End

######################################################################################
Subprog AV_TRTSPE(VALEUR)
Variable Char    VALEUR()
 If [M:TPE1]SRCTYP<>GVML_SRCOTH
  Chgfmt [M:TPE1]TRTSPE With "-K:12X"
 Else
  Chgfmt [M:TPE1]TRTSPE With "K:12X"
 Endif
End

######################################################################################
Subprog AS_DPRPLN(VALEUR)
Variable Integer VALEUR

 If GREP="C"
  Case [M]SRCTYP
   When GVML_SRCEVT
    Raz GMENLOC
    If [M:TPE1]EVTPLN=G_NON
     Local Integer I_PLN
     For I_PLN=1 To G301MAX-1
      GMENLOC(I_PLN)=1
     Next I_PLN
    Else
     GMENLOC(16)=1
     VALEUR=1
    Endif
   When GVML_SRCDEP, GVML_SRCLNK
    GMENLOC(16)=1
   When GVML_SRCOTH
    #
   When Default
  Endcase
 Endif

End

######################################################################################
Subprog AM_DPRPLN(VALEUR)
Variable Integer VALEUR
 Local Integer LSRCTYP : LSRCTYP=[F:TPE]SRCTYP
 Local Char    LTABCPT : LTABCPT=[F:TPE]TABCPT
 Local Integer LDPRPLN : LDPRPLN=VALEUR

 #> Détermination du type de référentiel cible en fonction du plan d'amortissement.

 If [M:TPE0]CPY=""
  If VALEUR=G301CPT
   [M:TPE1]CPTREF=GVML_TLSOC
  Elsif VALEUR=G301IAS
   [M:TPE1]CPTREF=GVML_TLIAS
  Else
   [M:TPE1]CPTREF=GVML_TLSOC
  Endif
 Else
  If VALEUR=G301AUC
   [M:TPE1]CPTREF=GVML_TLSOC
  Else
   #fq65893-Contrôle que le plan est bien défini pour cette société
   Local Integer RCNX
   Call GET_CNX_FROM_PLAN ([M:TPE0]CPY, VALEUR, RCNX) From GLOBIENS
   If RCNX=-1
    GERR     = 1
    GMESSAGE = mess(130,GML_MSGCPT,1) #"Ce plan d'amortissement n'est pas défini pour cette société"
    mkstat   = 2
    End
   Endif
   #
   [M:TPE1]CPTREF=func GLOBIENS.GET_LEDTYP_FROM_PLAN ([M:TPE0]CPY, VALEUR)
  Endif
 Endif
 Affzo [M:TPE1]CPTREF

End

######################################################################################
Subprog S_SORTFLDTAB(VALEUR)
Variable Char    VALEUR()
 Local Integer NBTEX, VALINT
 Local Char    TEX(50)(10) , TEXTE(50)
 TEX(1) = [M:TPE1]TABCPT-[M:TPE1]ZTABCPT : NBTEX+=1
 If [M:TPE1]SRCTYP<>GVML_SRCOTH
  TEX(2) = [M:TPE1]TABOBJ-[M:TPE1]ZTABOBJ
  NBTEX+=1
 Endif
 Call SAITEX(NBTEX,TEX,VALINT,mess(252,GML_MSGFASPR,1)) From GESECRAN #"Table source"
 Case VALINT
  When 1 : VALEUR=[M:TPE1]TABCPT
  When 2 : VALEUR=[M:TPE1]TABOBJ
  When Default
 Endcase
 mkstat=2
End
##################################################
##Fq-85066 Data Type tpe  "Types d'écritures comptables"
##################################################
## Control of Data Type TPE  "Types d'écritures comptable"
Subprog CONTTPE(COD,LEG,CPY)
Value Char    COD()
Value Char    LEG()
Value Char    CPY()
Local Integer CAS, ENA

  If GFONCTION = "GESTPE" | COD="" : End : Endif
  If clalev([F:TPE])=0 : Local File TYPACE [TPE]    : Endif
  If clalev([F:TPL])=0 : Local File TYPACELEG [TPL] : Endif

  If GNBLEG=1
     LEG = GDOSLEG
  Elsif LEG="" & GCURLEG<>""
     LEG = GCURLEG
  Endif

# CAS=1 => Record without Legislation (LEG = "")
# CAS=2 => Record with    Legislation (LEG <>"")

CAS = 1
ENA = 0 : # Document type Enable
If LEG<>""  # (Company leg)
   Read [TPE]TPE0 = COD;LEG;CPY
   If fstat
      Read [TPE]TPE0 = COD;LEG;""
      If fstat
         Read [TPL]TPL0=COD;"";"";LEG
         If !fstat
            Read [TPE]TPE0 = COD;"";""
            #*FQ 89249 We check that the document type is enable
            If fstat=0
               If [F:TPE]ENAFLG <> G_OUI
                  # Document type Disable
                  ENA=G_NON
                Endif
             Endif
         Endif
      Else
        #*FQ 89249 We check that the document type is enable
        If [F:TPE]ENAFLG <> G_OUI
           # Document type Disable
          ENA=G_NON
        Endif
      Endif
   Else
      CAS = 2
   Endif
# Si pas renseigné.....
Else
   Read  [TPE]TPE0(1) = [L]COD
   If !fstat
      LEG = [F:TPE]LEG
      CAS = 2
   Endif
Endif

If fstat
   Filter [TPE] Where ACETYP=COD
   Look [TPE]TPE0 First
   If !fstat
      If !ENA
         #Nonexistent Document type for the company
         GMESSAGE = [L]COD-":"-mess(144,GML_MSGCPT,1)-"["+[L]CPY+"]"
      Else
         # Document type : xxx  Inactive record
         Gosub TIT From WOTPE
         GMESSAGE = TIT-":"-[L]COD
         GMESSAGE += "\"+mess(2,126,1)
     Endif
 Else
    # Nonexistent Document type
    GMESSAGE = [L]COD-":"-mess(23,100,1)
 Endif
 Filter [TPE]
 mkstat = 2 : End
Endif

If ENA
   #*FQ 89249 # Document type disable
   # Document type : xxx  Inactive record
    GERR=1 : GMESSAGE = [L]COD-":"-mess(2,126,1) :  mkstat=2 : End
Endif

#If CAS=2
# Call CONTROLE("TPE","",LEG,COD,CPY,mkstat) From CONTOBJ
#Else
# Call CONTROLE("TPE","","",COD,CPY, mkstat) From CONTOBJ
#Endif

End

######################################################################################
Subprog C_SORTFLDTAB(VALEUR)
Variable Char    VALEUR()
 If VALEUR<>"" & VALEUR<>[M:TPE1]TABCPT & VALEUR<>[M]TABOBJ
  GERR     = 1
  GMESSAGE = mess(104,GML_MSGCPT,1)-[M:TPE1]TABCPT-mess(106,GML_MSGCPT,1)-[M:TPE1]TABOBJ-mess(105,GML_MSGCPT,1)
  mkstat   = 2
  End
 Endif
End

