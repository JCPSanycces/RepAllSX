#<AdxTL>@(#)11.0.0.0 $Revision$
###############################################################################
# Mise à jour des codes activités en 2 étapes :
# - Rajout et modification des codes activités pour la validation des tables
# - Moulinette d'initialisation du champ DIMMIN de la table ACTIV
###############################################################################

$DOSMAJACV

Call ECR_TRACE(string$(70,"#"),0) From GESECRAN
Call ECR_TRACE("Update Activity Codes",0) From GESECRAN

Gosub OUVTAB From DOSMAJATB
OUVFIC = 1
OBJET = "ACTIV"
Gosub COPIE From DOSMAJATB : # Rajout des nouvelles zones
Gosub FERTAB From DOSMAJATB
Call ACTIV : # Intialisation des nouvelles zones

Local File ADOSACT                  [ADA]
Local File =[F:ADS]DOSREF+".ACTIV"  [SACV]
Local File =[F:ADS]DOSSIER+".ACTIV" [ACV] 

# Nouveau code activité "AUD"
Read [SACV]CODACT="AUD"
If !fstat
 J = 0
 Read [ADA]ADA0=[F:ADS]DOSSIER;"AUD"
 If fstat
  Read [ADA]ADA0=[F:ADS]DOSSIER;"AUDIT"
  If !fstat
   [F:ADA]CODACT = "AUD"
   Write [ADA]
   If fstat
    Call ERREUR("ADOSACT"-[F:ADS]DOSSIER-[F:ADA]CODACT,1) From DOSDIC
   Else
    J = 1 
   Endif
  Endif  
 Endif
 Read [ACV]CODACT="AUD"
 If fstat
  Read [ACV]CODACT="AUDIT"
  If !fstat
   I = [F:ACV]FLACT
   [F:ACV] = [F:SACV]
   [F:ACV]FLACT = I
   If dim([F:ACV]UPDFLG)>0 : [F:ACV]UPDFLG = 1 : Endif
   Write [ACV]
   If fstat
    Call ERREUR("ACTIV"-[F:ACV]CODACT,1) From DOSDIC
   Else
    J = 1 
   Endif
  Endif
 Endif
 If J
  Call ECR_TRACE("Activity code AUD created",0) From GESECRAN
 Endif
Endif  

Trbegin [ACV]  
 For [SACV] Where CODACT<"XXX"
  Read [ACV]CODACT=[F:SACV]CODACT
  If fstat
   [F:ACV] = [F:SACV]  
   Read [ADA]ADA0 = [F:ADS]DOSSIER;[F:SACV]CODACT  
   If fstat  
    [F:ACV]FLACT = 1  
   Else  
    [F:ACV]FLACT  = [F:ADA]FLACT  
    [F:ACV]DIME   = [F:ADA]DIME  
   Endif
   If dim([F:ACV]UPDFLG)>0 : [F:ACV]UPDFLG = 1 : Endif
   Write [ACV]
   If fstat : Call ERREUR("ACTIV"-[F:ACV]CODACT,1) From DOSDIC : Endif  
  Else
   Read [ADA]ADA0 = [F:ADS]DOSSIER;[F:SACV]CODACT 
   If fstat  
    [F:ACV] = [F:SACV]  
    [F:ACV]FLACT = 1  
    If dim([F:ACV]UPDFLG)>0 : [F:ACV]UPDFLG = 1 : Endif
   Else  
    If [F:ACV]FLACT<>[F:ADA]FLACT or [F:ACV]DIME<>[F:ADA]DIME
     [F:ACV] = [F:SACV]  
     If dim([F:ACV]UPDFLG)>0 : [F:ACV]UPDFLG = 1 : Endif
    Else
     [F:ACV] = [F:SACV]  
    Endif 
    [F:ACV]FLACT  = [F:ADA]FLACT  
    [F:ACV]DIME   = [F:ADA]DIME  
   Endif
   Rewrite [ACV]
   If fstat : Call ERREUR("ACTIV"-[F:ACV]CODACT,2) From DOSDIC : Endif  
  Endif  
 Next SACV
 For [ADA]ADA0 Where DOSSIER=[F:ADS]DOSSIER & CODACT>="X"
  Read [ACV]CODACT = [F:ADA]CODACT
  If fstat
   Raz [F:ACV] 
   [F:ACV] = [F:ADA] 
   If dim([F:ACV]UPDFLG)>0 : [F:ACV]UPDFLG = 1 : Endif
   Read [SACV]CODACT = [F:ADA]CODACT
   If fstat
    [F:ACV]DIMFIL = [F:ADA]DIME
   Else
    [F:ACV]DIMFIL = [F:SACV]DIMFIL
   Endif
   Write [ACV]
   If fstat : Call ERREUR("ACTIV"-[F:ACV]CODACT,1) From DOSDIC : Endif   
  Else
   If [F:ACV]FLACT<>[F:ADA]FLACT or [F:ACV]DIME<>[F:ADA]DIME
    [F:ACV] = [F:ADA]  
    If dim([F:ACV]UPDFLG)>0 : [F:ACV]UPDFLG = 1 : Endif
   Else
    [F:ACV] = [F:ADA]  
   Endif 
   Read [SACV]CODACT = [F:ADA]CODACT
   If fstat
    [F:ACV]DIMFIL = [F:ADA]DIME
   Else
    [F:ACV]DIMFIL = [F:SACV]DIMFIL
   Endif
   Rewrite [ACV]
   If fstat : Call ERREUR("ACTIV"-[F:ACV]CODACT,2) From DOSDIC : Endif   
  Endif
 Next
Commit

Call ECR_TRACE(string$(70,"#"),0) From GESECRAN

Close Local File [ADA] , [SACV] , [ACV]

Return

#############################################################################
Subprog ACTIV
Local File =[F:ADS]DOSSIER+".ACTIV" [ACV]
Call ECR_TRACE(mess(81,125,1)-": ACTIV"-time$,0) From GESECRAN : # maj table
Trbegin [ACV]
 For [ACV]
  [F:ACV]DIMMAX = [F:ACV]DIMFIL
  If dim([F:ACV]DIMMIN)>0
   [F:ACV]DIMMIN = [F:ACV]DIME
  Endif
  If dim([F:ACV]UPDFLG)>0
   [F:ACV]UPDFLG = 0
  Endif
  Rewrite [ACV]
 Next ACV
Commit
End



