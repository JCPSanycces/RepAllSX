#<AdxTL>@(#)6.0.0.0 $Revision$

##########################################################################
# UTIGPA06        Utilitaire de resynchronisation  OF      Module GPAO   #
# ---------------------------------------------------------------------- #
# Problème à résoudre :                                                  #
#   Détection  de suivis de consommations matières pour lesquels         #
#   les mouvements de stock n'ont pas été générés. On supprime ces suivis#
#   idem pour les déclarations de production                             #
##########################################################################

Call MAJ_UTIGPA06
End


Subprog MAJ_UTIGPA06
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("Stock Synchronisation") From LECFIC
If DOSSIER <> ""
  Call EXE_UTIGPA06(DOSSIER)
Endif
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End


Subprog EXE_UTIGPA06(DOSSIER)
Value Char    DOSSIER
Local Integer WSIMFLG, OK
Local Char    WMSG(100)

# Issue 95900 GA 01/2014 traitement non valide pour la V6
If GVERSION>="1.6.0" End Endif

Call OUINON("Simulation ?",OK) From GESECRAN
If OK=2  : WSIMFLG=1 Else Raz WSIMFLG : Endif

Call ECR_TRACE("UTIGPA06 : Process start "+DOSSIER,0) From GESECRAN
If WSIMFLG=1  WMSG-="(**Simulation**)" : Endif
Call ECR_TRACE(WMSG,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([M:ORDK]) = 0 : Local Mask =DOSSIER+".ORDK" [ORDK] : Endif       # pour générer encours
If clalev([M:OPSK]) = 0 : Local Mask =DOSSIER+".OPSK" [OPSK] : Endif       # masque encours charge
If clalev([M:STOK]) = 0 : Local Mask =DOSSIER+".STOK" [STOK] : Endif       # masque STOCK
If clalev([M:JALK]) = 0 : Local Mask =DOSSIER+".JALK" [JALK] : Endif       # masque jalonnement

If clalev([F:MFG]) = 0 : Local File =DOSSIER+".MFGHEAD"    [MFG] : Endif  # ordre de fabrication
If clalev([F:MFP]) = 0 : Local File =DOSSIER+".MFGPRN"     [MFP] : Endif  # ordre de fabrication impression
If clalev([F:MFI]) = 0 : Local File =DOSSIER+".MFGITM"     [MFI] : Endif  # articles lancés
If clalev([F:MFM]) = 0 : Local File =DOSSIER+".MFGMAT"     [MFM] : Endif  # matières OF
If clalev([F:MFO]) = 0 : Local File =DOSSIER+".MFGOPE"     [MFO] : Endif  # opérations OF
If clalev([F:MWS]) = 0 : Local File =DOSSIER+".WORKSTATIO" [MWS] : Endif  # poste de charge
If clalev([F:ITM]) = 0 : Local File =DOSSIER+".ITMMASTER"  [ITM] : Endif  # article
If clalev([F:ITF]) = 0 : Local File =DOSSIER+".ITMFACILIT" [ITF] : Endif  # article-site
If clalev([F:MTK]) = 0 : Local File =DOSSIER+".MFGHEADTRK" [MTK] : Endif  # suivi de fabrication
If clalev([F:MKI]) = 0 : Local File =DOSSIER+".MFGITMTRK"  [MKI] : Endif  # suivi articles lancés
If clalev([F:MKM]) = 0 : Local File =DOSSIER+".MFGMATTRK"  [MKM] : Endif  # suivi matières OF
If clalev([F:MKO]) = 0 : Local File =DOSSIER+".MFGOPETRK"  [MKO] : Endif  # suivi opérations OF
If clalev([F:STA]) = 0 : Local File =DOSSIER+".STOALL"     [STA] : Endif  # allocations
If clalev([F:STJ]) = 0 : Local File =DOSSIER+".STOJOU"     [STJ] : Endif  # Mouvements de stock
If clalev([F:STS]) = 0 : Local File =DOSSIER+".STOSER"     [STS] : Endif  # numéros de série
#If clalev([F:STY]) = 0 : Local File =DOSSIER+".STOSERW"    [STY] : Endif  # Ficher travail numéros de série # Issue 95900
If clalev([F:OPS]) = 0 : Local File =DOSSIER+".OPERATIONS" [OPS] : Endif  # encours charge
If clalev([F:SCH]) = 0 : Local File =DOSSIER+".SCHEDULING" [SCH] : Endif  # jalonnements
If clalev([F:ORD]) = 0 : Local File =DOSSIER+".ORDERS"     [ORD] : Endif  # encours articles
If clalev([F:MTS]) = 0 : Local File =DOSSIER+".MFGTRS"     [MTS] : Endif  # Transactions de suivi
If clalev([F:ROS]) = 0 : Local File =DOSSIER+".ROUSCD"     [ROS] : Endif  # Gamme/Jalonnement opérations
If clalev([F:PJA]) = 0 : Local File =DOSSIER+".PARJAL"     [PJA] : Endif  # Paramètres jalonnement
If filinfo(filpath("FIL","CPTANALIN","fde",nomap),0)>0                    # Issue 95900 GA 01/2014
   If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif
Endif

#----- Variables locales -----#
Local Char     WMESSAGE(80)

Local Integer COMPTEUR, STOP
Local Char     CLE1(20), CLE3(20), CRITERE(200), CRITPSUP(80)
Local Integer  CLE2, CLE4, CLE5
Local Integer  WMTKNBR , WCORNBR,WTOT, WSUPP

Gosub DECL_VAR
Local Char    WWMFGTRKNUM

Raz CLE1, CLE2, CLE3, CLE4, STOP
$BOUCLE_MTK
If STOP = 1
  STOP = 0 : CRITERE='MFGTRKNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif
CRITSUP  = "(MATTRKFLG = 2 & NBRMAT <> 0) |(ITMTRKFLG = 2 & NBRITM <> 0)"

Raz COMPTEUR

Call DEBTRANS From GLOCK
Trbegin [MTK]

For [F:MTK]MTK0 Where evalue(CRITERE) & evalue(CRITSUP)
    Readlock [F:MTK]MTK0 Curr
    If fstat
        Call ECR_TRACE("File MFGHEADTRK, Error ="-num$(fstat),1) From GESECRAN
    Else
        WMTKNBR +=1
        WWMFGTRKNUM = [F:MTK]MFGTRKNUM
        Raz WSUPP
        For [F:MKM] Where MFGTRKNUM = [F:MTK]MFGTRKNUM
            Look [F:STJ]STJ1 = [F:MKM]MFGFCY;12;[F:MKM]MFGTRKNUM;[F:MKM]MATTRKLIN
            If fstat
               Call ANNULE_SUIVMAT(WTOT,WSIMFLG)
               WSUPP = 1
               If WTOT = 1 : Break : Endif
            Endif
         Next
         If WTOT = 0
             For [F:MKI] Where MFGTRKNUM = [F:MTK]MFGTRKNUM
                 Look [F:STJ]STJ1 = [F:MKI]MFGFCY;15;[F:MKI]MFGTRKNUM;[F:MKI]ITMTRKLIN
                 If fstat
                    Call ANNULE_SUIVITM(WTOT,WSIMFLG)
                    WSUPP = 1
                    If WTOT = 1 : Break : Endif
                 Endif
             Next
         Endif
    Endif
    If WSUPP = 1
       WCORNBR += 1
    Endif

    COMPTEUR += 1
    If COMPTEUR > GMAXUPDTRS
        CLE1 = WWMFGTRKNUM
        STOP = 1
        Break
    Endif

$NEXTSUIVI
Next
If GOK < 1 : Rollback
Else       : Commit
Endif
If STOP : Goto BOUCLE_MTK : Endif

Call ECR_TRACE("Analysed:"-num$(WMTKNBR),0) From GESECRAN
Call ECR_TRACE("Resynchronised:"-num$(WCORNBR),0) From GESECRAN
Call ECR_TRACE("UTIGPA06 : end of process",0) From GESECRAN

#----- Fin du traitement -----#
$FIN_UTIGPA06
End



############################################################################################
Subprog ANNULE_SUIVMAT(LTOT,LSIMFLG)
Variable Integer LTOT
Value    Integer LSIMFLG
Local    Char    WITMREF
Local    Char    WMFGNUM, WMFGTRKNUM
Local    Integer WNBR
Local    Char    WTRSNUM

Local Integer    WNBMAT
Local Integer    WOPECLENBR, WITMCLENBR, WMATCLENBR,WALLTYP
Local Decimal    WCPLQTY,WREJQTY,WQUAQTY,WUSEQTY,WALLQTY,WSHTQTY,WCOEFF,WQTY,WREPART
Local Integer    WPRN

Gosub DECL_VAR
WPRN = 1

Raz LTOT, WITMREF
If [F:MKM]MATTYP = 1
   Read [F:MFG]MFG0 = [F:MKM]MFGNUM
   If fstat : Raz [F:MFG] : Endif
   If [F:MFG]MFGSTA = 4
       Call ECR_TRACE("Of :" - [F:MKM]MFGNUM - "closed, correction not possible",1) From GESECRAN
       End
   Endif
   WMFGNUM = [F:MKM]MFGNUM
   Read [F:MFP]MFP0 = [F:MKM]MFGNUM
   If !fstat WPRN = [F:MFP]MFGFDRFLG : Endif
Endif
WMFGTRKNUM = [F:MKM]MFGTRKNUM
If [F:MTK]NBRMAT = 1 & [F:MTK]NBROPE = 0 & [F:MTK]NBRITM = 0
    If !LSIMFLG
        Gosub ANNULE_SUIV     From SUBMTKC
    Endif
    LTOT = 1
Else
    WITMREF = [F:MKM]ITMREF
    If !LSIMFLG
        Gosub ANNULE_SUIVMAT  From SUBMTKC
        If GOK < 1 : End : Endif
        Delete [F:MKM]
        If fstat : GOK = 0 : End :  Endif
        [F:MTK]NBRMAT -= 1
        Rewrite [F:MTK]
        If fstat
           GOK = 0 : Call FSTA("MTK") From GLOCK : End
        Endif
        If  [F:MTK]MFGNUM <> "" & [F:MKM]MATTYP = 1 & [F:MKM]MFMITMREF <> ""
            Call MAJMFGHEAD([F:MTK]MFGNUM,WOPECLENBR,WITMCLENBR,WMATCLENBR,WCPLQTY,WREJQTY,WQUAQTY,WPRN) From SUBMTKC
            If GOK < 1 : LRET = 1 : End : Endif
        Endif
    Endif
Endif
If LTOT
    Call ECR_TRACE("Of :" - WMFGNUM - "/" -"Tracking number :"-WMFGTRKNUM - "deleted",1) From GESECRAN
Else
    Call ECR_TRACE("Of :" - WMFGNUM - "/" -"Tracking number :"-WMFGTRKNUM - "/" - "Component" - WITMREF - "Deleted",1) From GESECRAN
Endif
End

############################################################################################
Subprog ANNULE_SUIVITM(LTOT,LSIMFLG)
Variable Integer LTOT
Value    Integer LSIMFLG

Local    Char    WITMREF
Local    Char    WMFGNUM, WMFGTRKNUM
Local    Integer WNBR
Local    Char    WTRSNUM
Local    Integer WPRN

Raz LTOT, WITMREF

Gosub DECL_VAR

WPRN = 1

If [F:MKI]PRODTYP = 1
   Read [F:MFG]MFG0 = [F:MKI]MFGNUM
   If fstat : Raz [F:MFG] : Endif
   If [F:MFG]MFGSTA = 4
       Call ECR_TRACE("Of :" - [F:MKI]MFGNUM - "closed, correction not possible",1) From GESECRAN
       End
   Endif
   WMFGNUM    = [F:MKI]MFGNUM
   Read [F:MFP]MFP0 = [F:MKI]MFGNUM
   If !fstat WPRN = [F:MFP]MFGFDRFLG : Endif
Endif

WMFGTRKNUM = [F:MKI]MFGTRKNUM
If [F:MTK]NBRITM = 1 & [F:MTK]NBROPE = 0 & [F:MTK]NBRMAT = 0
   If !LSIMFLG
        Gosub ANNULE_SUIV     From SUBMTKC
   Endif
   LTOT = 1
Else
    WITMREF = [F:MKI]ITMREF
    If !LSIMFLG
         Gosub ANNULE_SUIVITM From SUBMTKC
        If GOK < 1 : LRET = 1 : End : Endif
        Delete [F:MKI]
        If fstat : GOK = 0 : End : Endif
        [F:MTK]NBRITM -= 1
        Rewrite [F:MTK]
        If fstat
           GOK = 0 : Call FSTA("MTK") From GLOCK : End
        Endif
        If [F:MTK]MFGNUM <> "" & [F:MKI]PRODTYP = 1
            Read [F:MFI]MFI0 = [F:MKI]MFGNUM;[F:MFI]MFGLIN
            If fstat : Raz [F:MFI] : Endif
            If [F:MFI]ITMTYP = 2
                Raz WCPLQTY, WREJQTY, WQUAQTY
            Endif
            Call MAJMFGHEAD([F:MKI]MFGNUM,WOPECLENBR,WITMCLENBR,WMATCLENBR,WCPLQTY,WREJQTY,WQUAQTY,WPRN) From SUBMTKC
            If GOK < 1 : End : Endif
        Endif
    Endif
Endif

If LTOT
    Call ECR_TRACE("Of :" - WMFGNUM - "/" -"Tracking number :"-WMFGTRKNUM - "deleted",1) From GESECRAN
Else
    Call ECR_TRACE("Of :" - WMFGNUM - "/" -"Tracking number :"-WMFGTRKNUM - "/" - "Product " - WITMREF - "Deleted",1) From GESECRAN
Endif
End


############################
$DECL_VAR
Local Integer WRET,WALL,WTYP,WWIN
Local Decimal WCLE,WQTYP,WQTY,WCHR,WSEQ,WSTOCOU,WLIN,WQTYSTU,WQTYRUP,WQTYRUPP
Local Char WFCY,WNUM,WITM,WPRE, WLOC
Local Date WDAT,WDTE
Local Decimal WWALLQTY,WWSHTQTY
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(7)<>2 End : Endif
Call EXE_UTIGPA06(APPLI)
End
