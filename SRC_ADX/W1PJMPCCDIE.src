#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMPCCDIE 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:51"
A_USER  = "DOC"
A_STAMP = "20181109230551"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRDIE"
  If [M]NBRDIE=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMPCCDIE [PJCD]
Gosub HORODAT
Local Inpbox "PJMPCCDIE" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJCD] As [SIM_]
Grizo [PJCD]35
Grizo [PJCD]30
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJCD]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=3 : Y2(0)=22
X1(1)=1 : X2(1)=59 : Y1(1)=1 : Y2(1)=2
Return

$ON_DIE
Return

$ON_ZDIE
Onevent BEFORE_AREA Gosub AV_ZDIE From W1PJMPCCDIE
Return

$AV_ZDIE
Call LECTEXTRA(zc,"GDIE","DESTRA",num$([M]DIE(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_CHX
Onevent AFTER_CHANGE Gosub AMM_CHX From W1PJMPCCDIE
Onevent INIT_AREA Call D_CHX(zc) From W1PJMPCCDIE
Onevent BEFORE_INPUT Call AS_CHX(zc) From W1PJMPCCDIE
Return

Subprog D_CHX(VALEUR)
Variable Integer VALEUR
If varinit([M]CHX,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_CHX(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_CHX
Call AM_CHX(zc)
If !mkstat & GOBJET
 zoncou = "CHX" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CHX(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_CHX(VALEUR) From SUBPJCC
If mkstat : GERR = 1 : GZONE = "CHX" : GZNUM = 12414 : Endif
Gosub _AFF
End

$ON_CCE
Onevent BEFORE_AREA Gosub AV_CCE From W1PJMPCCDIE
Onevent CONTROL Call C_CCE(zc) From W1PJMPCCDIE
Onevent AFTER_CHANGE Gosub AMM_CCE From W1PJMPCCDIE
Onevent BEFORE_INPUT Call AS_CCE(zc) From W1PJMPCCDIE
Return

$AV_CCE
## Action INICCEFMT
Call INICCEFMT(num$([M:PJCD]DIE(nolign - 1))) From SETGLBDIE
If GCCEFMT<>""
 Chgfmt [M]CCE(indice) With "K:"+GCCEFMT
Else
 Chgfmt [M]CCE(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog AS_CCE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_CCE(zc) From W1PJMPCCDIE
Onkey 144 Titled GBOUTP Call P_CCE(zc) From W1PJMPCCDIE
Onkey 146 Titled GBOUTA Call SA_CCE(zc) From W1PJMPCCDIE
Gosub _AFF
End

Subprog C_CCE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CCECHOICE
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CCECHOICE"
 PARMSK(1) = num$([M:PJCD]DIE(nolign - 1))
 Call S_TAB_CHAR(VALEUR,PARMSK,"CCECHOICE","TRTSEL","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CCE" : GZNUM = 1688 : Endif
Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("CCE","!",VALEUR,num$([M:PJCD]DIE(nolign - 1)),mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CCE" : GZNUM = 1688 : Endif
Endif
Gosub _AFF
End

$AMM_CCE
Call AM_CCE(zc)
If !mkstat & GOBJET
 zoncou = "CCE" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CCE(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CCE(VALEUR) From SUBPJCC
If mkstat : GERR = 1 : GZONE = "CCE" : GZNUM = 1688 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZCCE)")>indice
 [M]CCE(indice) = VALEUR
 Affzo ZCCE(indice)
Endif
Gosub _AFF
End

Subprog S_CCE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELCCE
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELCCE"
 PARMSK(1) = [M:PJCD]DIE(nolign-1)
 PARMSK(2) = fmet GACTX.ACACHE.AFCY.AGETVALCHAR([M:PJCC0]PCCFCY, "FINRSPFCY")
 PARMSK(3) = ""
 PARMSK(4) = num$(nolign-1)
 PARMSK(5) = "[M:PJCD]DIE(1"
 PARMSK(6) = "[M:PJCD]CCE(0"
 PARMSK(7) = "GCOA(1"
 PARMSK(8) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELCCE","SELCCE","") From GACTION
 GACTION = SAVACT
Endif
If !GWEBSERV
 ## Action SELCCEGDD
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELCCEGDD"
 PARMSK(1) = [M:PJCD]DIE(nolign-1)
 PARMSK(2) = fmet GACTX.ACACHE.AFCY.AGETVALCHAR([M:PJCC0]PCCFCY, "FINRSPFCY")
 PARMSK(3) = ""
 PARMSK(4) = num$(nolign-1)
 PARMSK(5) = "[M:PJCD]DIE(1"
 PARMSK(6) = "[M:PJCD]CCE(0"
 PARMSK(7) = "GCOA(1"
 PARMSK(8) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"SELCCE","SELCCE","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_CCE(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CCE"
PARMSK(2) = num$([M:PJCD]DIE(nolign - 1))
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CCE(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = num$([M:PJCD]DIE(nolign - 1))
Call VISU("CCE",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCCE
Onevent BEFORE_AREA Gosub AV_ZCCE From W1PJMPCCDIE
Return

$AV_ZCCE
Call LECTEXTRA(zc,"CACCE","DESTRA",num$([M:PJCD]DIE(nolign - 1)),num$([M]CCE(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_ACCCOD
Onevent CONTROL Call C_ACCCOD(zc) From W1PJMPCCDIE
Onevent AFTER_CHANGE Gosub AMM_ACCCOD From W1PJMPCCDIE
Onevent BEFORE_INPUT Call AS_ACCCOD(zc) From W1PJMPCCDIE
Return

Subprog AS_ACCCOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3946,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_ACCCOD(zc) From W1PJMPCCDIE
Onkey   2 Titled GBOUTS Call S_ACCCOD(zc) From W1PJMPCCDIE
Onkey 144 Titled GBOUTP Call P_ACCCOD(zc) From W1PJMPCCDIE
Onkey 146 Titled GBOUTA Call SA_ACCCOD(zc) From W1PJMPCCDIE
Gosub _AFF
End

Subprog C_ACCCOD(VALEUR)
Variable Char    VALEUR()
## Action CONTCAC
Call CONTCAC(VALEUR,"36") From SUBCAC
If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("CAC","!",VALEUR,"36",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
Endif
Gosub _AFF
End

$AMM_ACCCOD
Call AM_ACCCOD(zc)
If !mkstat & GOBJET
 zoncou = "ACCCOD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ACCCOD(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_ACCCOD(VALEUR) From SUBPJCC
If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZACCCOD)")>indice
 [M]ACCCOD(indice) = VALEUR
 Affzo ZACCCOD(indice)
Endif
Gosub _AFF
End

Subprog S_ACCCOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELCAC
 Call SELCAC(VALEUR,"36") From SUBCAC
Endif
Gosub _AFF
End

Subprog B1_ACCCOD(VALEUR)
Variable Char    VALEUR()
Call OBJET("CAC",VALEUR,"36") From GOBJET
Gosub _AFF
End

Subprog SA_ACCCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CAC"
PARMSK(2) = "36"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_ACCCOD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "36"
Call VISU("CAC",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZACCCOD
Onevent BEFORE_AREA Gosub AV_ZACCCOD From W1PJMPCCDIE
Return

$AV_ZACCCOD
Call LECTEXTRA(zc,"GACCCODE","DESTRA","36",num$([M]ACCCOD(indice))) From ATEXTRA
Gosub _AFF
Return

$CHG_STY
Return


