#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################
# Traitement SUBCREITFMA - Creation article site en masse              #
########################################################################
# Action CREITFMA
########################################################################
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "DEBUT"     : Gosub DEBUT
 When "FINSAI"    : Gosub FINSAI
 When "OK"        : Gosub CREATION_ITF
Endcase

Return

##########################################################################
$OUVRE

If clalev([F:TFO])=0 Local File TABFOR     [TFO]  Endif
If clalev([F:FCY])=0 Local File FACILITY   [FCY]  Endif
If clalev([F:ITF])=0 Local File ITMFACILIT [ITF]  Endif
If clalev([F:ITM])=0 Local File ITMMASTER  [ITM]  Endif
If clalev([F:ITG])=0 Local File ITMCATEG   [ITG]  Endif
If clalev([F:STE])=0 Local File STOPAR     [STE]  Endif                     # hcb X3-87852

If dim(GSIMCREITF) > 0
   Kill GSIMCREITF
Endif

Return

##########################################################################
$DEBUT
Raz   [M:DIA]
[M]TRACE = 2
Affzo [M:DIA]
# chargement des droits pour la fonction GESITF
Local Char OFONCTION(20)
OFONCTION=GFONCTION
GFONCTION="GESITF" : Call AUTORIS From EXEFNC

Return

##########################################################################
$FINSAI

mkstat = 4

Return
##########################################################################
#--------------------------------------------#
# creation ITMFACILIT
#--------------------------------------------#
$CREATION_ITF

Local Char    WMSG(140)
Local Char    WINT(15)
Local Integer WNBRART, WNBFCY
Local Integer WNBRARTR
Local Integer WNBRITF
Local Integer I
I = 0

Local Integer WREP
Raz WMSG
Raz WINT
Raz WNBRART, WNBFCY
Raz WREP

Local  Char    WFILFOR   (250)
Local  Char    WFILART   (250)
Local Char     WFILFCY   (250)
Local  Integer WERR

Local Char LFCY(GLONFCY)
Raz LFCY
If [M]TRACE=2 | dim(GSIMCREITF) > 0
  Call OUVRE_TRACE("CREITFMA") From LECFIC
Endif

Call DEBTRANS From GLOCK

Raz WFILFOR
Raz WFILART
Raz WFILFCY
# Filtre article
#tous les articles
If [M]ITMALL =2
  WFILART="1=1"
Else
  #filtre sur la catégorie
  If [M]TCLCODSTR <> "" | [M]TCLCODEND <> ""
    WFILART += "[F:ITM]TCLCOD>=[M]TCLCODSTR&[F:ITM]TCLCOD<=[M]TCLCODEND"
  Endif
  #filtre sur les articles
  If [M]ITMREFSTR <> "" | [M]ITMREFEND <> ""
    If WFILART<>""
      WFILART+="&"
    Endif
    WFILART += "[F:ITM]ITMREF>=[M]ITMREFSTR&[F:ITM]ITMREF<=[M]ITMREFEND"
  Endif
Endif
If WFILART=""  WFILART="1=1" : Endif
#articles gérés en stock
If [M]ITMNSTO <> 2
  WFILART += "& ([F:ITM]STOMGTCOD = 2 | [F:ITM]STOMGTCOD = 3) "
Endif

# Filtre formule
If [M]SELFOR <> ""
  Read [TFO]TFO0=51;[M]SELFOR
  If fstat = 0
     WFILFOR = [F:TFO]FORFOR
  Endif
Endif
#Init des filtres
If WFILFOR    = ""
   WFILFOR    = "1=1"
Endif

# Filtre site
#tous les sites
If [M]FCYALL = 2
  WFILFCY = "1=1"
Else
  If [M]FCYSTR <> "" | [M]FCYEND <> ""
    WFILFCY += "[F:FCY]FCY>=[M]FCYSTR&[F:FCY]FCY<=[M]FCYEND"
  Endif
Endif
If WFILFCY=""   WFILFCY="1=1" : Endif
#Uniquement les sites de stock
WFILFCY += "&[F:FCY]WRHFLG=2 "


# comptage nombre article a traiter
Filter [ITM] Where evalue(WFILART)  &
&                  evalue(WFILFOR)
&            Order By Key ITM0

Filter [FCY] Where evalue(WFILFCY)
&            Order By Key FCY0

For [FCY]
    WNBFCY += 1
Next

For [ITM]
    WNBRART += 1
Next

If WNBRART = 1 & WNBFCY=1
      Call AVERTIR(num$(WNBRART*WNBFCY)-mess(917,196,1),WREP) From GESECRAN
   Else
      Call AVERTIR(num$(WNBRART*WNBFCY)-mess(916,196,1),WREP) From GESECRAN
   Endif
   If WREP <> 2
      #MAE, bug 105387
      Filter [ITM]
      Filter [FCY]
      #MAE, bg 104014
      Return
      #End

Endif

If [M:DIA]TRACE = 2 | dim(GSIMCREITF) > 0
   Gosub OUVRE_TRACE
Endif

#message opération en cours ...
Call TEMPON("O") From GESECRAN

Raz WNBRART
Raz WNBRARTR
Raz WNBRITF

#Affectation des roles
Local Char ABROL(GLONAOB)
ABROL = "ITF"
Gosub FILROLE From GOBJACT

For [ITM]
       #If !(dim(GSIMCREITF) > 0)             # si pas mode simulation
       #   Call DEBTRANS From GLOCK
       #Endif
       For[FCY]
         LFCY = [F:FCY]FCY
         #contrôle si l'article site existe déjà
         Read [ITF]ITF0=[F:ITM]ITMREF;LFCY
          If fstat=0
            #article site déjà existant
            Call ECR_TRACE(mess(18,7,1)+" : "+[F:ITF]ITMREF+" / "+mess(3,45,1)+" : "+LFCY+" -- "+mess(45,7779,1),1) From GESECRAN
          Else
            Gosub CRE_ITMFACILIT From SUBITM
            If mkstat<>2  WNBRARTR += 1 : Endif
         Endif
        Next
Next
WMSG=mess(451,197,1)+" "+num$(WNBRARTR)
Call ECR_TRACE(WMSG,0) From GESECRAN
Filter [ITM]
Filter [FCY]
#suppression message opération en cours ...
Call TEMPOFF   From GESECRAN

#MAE, bg 68556
If [M]TRACE=2 | dim(GSIMCREITF) > 0
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
If dim(GSIMCREITF)=0    #pas en simulation, on revient au début
  Gosub DEBUT
Endif
Return

######################################################################################
Subprog ACT_SIMCREITF
Global Integer GSIMCREITF
Gosub CREATION_ITF
Kill GSIMCREITF

End
########################################################################
# OUVRE_TRACE                                    Ouverture fichier trace
########################################################################
$OUVRE_TRACE
Call OUVRE_TRACE(mess(782,197,1)) From LECFIC
Call ECR_TRACE("*"-mess(41,120,1),0) From GESECRAN                           # Critères de sélection
If [M:DIA]TCLCODEND <> ""
   Call ECR_TRACE("-"-mess(8,105,1)-" : "-[M:DIA]TCLCODSTR-" / "-[M:DIA]TCLCODEND,0) From GESECRAN  # Catégorie
Endif
Raz WMSG
If [M]ITMALL = 2
   WMSG=mess(210,133,1)
Endif
If [M:DIA]ITMREFEND <> ""
  WMSG=[M:DIA]ITMREFSTR-" / "-[M:DIA]ITMREFEND
Endif
If WMSG<>""
  Call ECR_TRACE("-"-mess(569,197,1)-" : "-WMSG,0) From GESECRAN  # Article
Endif
Raz WMSG, WINT
If [M:DIA]SELFOR <> ""
 Call ECR_TRACE("-"-mess(573,197,1)-" : "-[M:DIA]SELFOR,0) From GESECRAN   # Formule
Endif
Raz WMSG
If [M:DIA]FCYEND <> ""
   WMSG=[M:DIA]FCYSTR-" / "-[M:DIA]FCYEND
Endif
If [M]FCYALL = 2
  WMSG=mess(210,133,1)
Endif
If WMSG <>""
   Call ECR_TRACE("-"-mess(3,45,1)-" : "-WMSG,0) From GESECRAN   # Site
Endif
Call ECR_TRACE("---------------------------------------------------------------",0) From GESECRAN
If dim(GSIMCREITF) > 0
  Call ECR_TRACE("-"-mess(6,115,1)-"-",0) From GESECRAN   # Simulation
Endif

Return



######################################################################################
## Action ecran
######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran CREITFMA) 29/04/2011 09:54:36 (MAE)
######################################################################################
Subprog IB_ITMREFSTR
If [M]ITMREFSTR = ""
   GBOUT1 = ""
Endif
End

Subprog C_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M]ITMREFEND = ""     : [M]ITMREFEND = VALEUR : Affzo [M]ITMREFEND : Endif
If [M]ITMREFEND < VALEUR : [M]ITMREFEND = VALEUR : Affzo [M]ITMREFEND : Endif
If VALEUR <> ""
    [M:DIA]ITMALL=1
Else
   [M:DIA]ITMALL=2
Endif
Affzo [M:DIA]ITMALL
End

Subprog IB_ITMREFEND
If [M]ITMREFEND = ""
   GBOUT1 = ""
Endif
End

Subprog C_ITMREFEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]ITMREFSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif

End



######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran CREITFMA) 29/04/2011 10:12:23 (MAE)
######################################################################################
Subprog IB_TCLCODSTR
End

Subprog AM_TCLCODSTR(VALEUR)
Variable Char    VALEUR()
If [M]TCLCODEND = ""     : [M]TCLCODEND = VALEUR : Affzo [M]TCLCODEND : Endif
If [M]TCLCODEND < VALEUR : [M]TCLCODEND = VALEUR : Affzo [M]TCLCODEND : Endif
If VALEUR <> ""
    [M:DIA]ITMALL=1
Else
   [M:DIA]ITMALL=2
Endif
Affzo [M:DIA]ITMALL
End

Subprog IB_TCLCODEND
End

Subprog C_TCLCODEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]TCLCODSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran CREITFMA) 17/05/2011 16:01:14 (MAE)
######################################################################################
Subprog IB_FCYSTR
End

Subprog AM_FCYSTR(VALEUR)
Variable Char    VALEUR()
If [M]FCYEND = ""     : [M]FCYEND = VALEUR : Affzo [M]FCYEND : Endif
If [M]FCYEND < VALEUR : [M]FCYEND = VALEUR : Affzo [M]FCYEND : Endif
End

Subprog IB_FCYEND
End

Subprog C_FCYEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]FCYSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
# Issue 105553 - 2015-04-30 by MUARN : ne pas faire si mkstat possitionné
If mkstat <> 2
  If VALEUR <> ""
      [M:DIA]FCYALL=1
  Else
     [M:DIA]FCYALL=2
  Endif
  Affzo [M:DIA]FCYALL
Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran CREITFMA) 22/07/2011 15:47:17 (MAE)
######################################################################################
Subprog C_FCYALL(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Effzo [M:DIA]FCYSTR
  Effzo [M:DIA]FCYEND
  Grizo [M:DIA]FCYSTR
  Grizo [M:DIA]FCYEND
Else
  Actzo [M:DIA]FCYSTR
  Actzo [M:DIA]FCYEND
Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran CREITFMA) 22/07/2011 16:55:44 (MAE)
######################################################################################
Subprog C_ITMALL(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Effzo [M:DIA]ITMREFSTR
  Effzo [M:DIA]ITMREFEND
  Grizo [M:DIA]ITMREFSTR
  Grizo [M:DIA]ITMREFEND
Else
  Actzo [M:DIA]ITMREFSTR
  Actzo [M:DIA]ITMREFEND
Endif
End


######################################################################################
