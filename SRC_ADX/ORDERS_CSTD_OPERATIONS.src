###################################################################################################
# Classe ORDERS - OPERATIONS
###################################################################################################
$ORDERS_FROM_PJM_SOQ
#Value Tinyint WIPTYP
#Value Char WIPNUM ()
#Value Char ITMREF ()
#Variable Instance TECORDERS Using C_TECORDERS : #
#Local Integer ARET_VALUE

Local Instance WIP_PARAM Using C_ORDK
Local Char SWIPNUM(type(WIPNUM)-10)

  # Issue X3-31898 - 2017-11-23 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------------------
  WIP_PARAM = NewInstance C_ORDK AllocGroup null
  # --------------------------------------------
  Local File ORDERS [ORDW]
  Read [ORDW]ORD0=WIPTYP;WIPNUM;ITMREF
  If !fstat Then
    SetInstance WIP_PARAM With [F:ORDW]
    WIP_PARAM.MAJCOD = "M"
    WIP_PARAM.ALLQTY = TECORDERS.ALLQTY
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.WIP(WIPTYP, WIPNUM, ITMREF, WIP_PARAM, SWIPNUM))
  Endif
  # --------------------------------------------
  FreeGroup WIP_PARAM
  # --------------------------------------------
Return

###################################################################################################
$ORDERS_FROM_PJM
#Value Tinyint WIPTYP
#Value Char WIPNUM ()
#Value Char ITMREF ()
#Variable Instance PJMTSKITM Using C_PJMTSKITM : #
#Variable Instance TECORDERS Using C_TECORDERS : #
#Local Integer ARET_VALUE

Local Instance WIP_PARAM Using C_ORDK
Local Integer IS_WORK
Local Decimal NEXTQTY
Local Integer I_TODELETE
Local Char SCPY(GLONCPY)     # Issue X3-97140 - 2018-06-19 by FGR

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------------------
  WIP_PARAM = NewInstance C_ORDK AllocGroup null
  IS_WORK = [V]CST_AYES
  # -------------------------------------------------
  If PJMTSKITM.ITTQTY - PJMTSKITM.SOQQTY < 0 Then
    NEXTQTY = 0
  Else
    NEXTQTY = PJMTSKITM.ITTQTY - PJMTSKITM.SOQQTY
  Endif
  # -------------------------------------------------
  I_TODELETE = [V]CST_ANO
  If PJMTSKITM.WIPNUM <> AVOID.ACHAR and NEXTQTY = 0 Then
    I_TODELETE = [V]CST_AYES
  Elsif TECORDERS.TASSTATE = 4 and TECORDERS.TASSTATE <> TECORDERS.TASSTATESNAP Then
    Local File ORDERS [ORDW]
    Read [ORDW]ORD0=WIPTYP;WIPNUM;ITMREF
    If !fstat Then
      If [F:ORDW]WIPSTA = 2 Then
        # If planned : delete
        I_TODELETE = [V]CST_AYES
      Elsif [F:ORDW]WIPSTA = 1 Then
        IS_WORK = [V]CST_ANO
        # Issue X3-101833 - 2018-08-01 by FGR : BEGIN removed
        ## Issue X3-97140 - 2018-06-19 by FGR : BEGIN
        ##[L]ARET_VALUE = fmet this.ASETERROR("", func AFNC.MES1(mess(519,2260,1), WIPNUM), [V]CST_AERROR)
        #SCPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(PJMTSKITM.STOFCY, "LEGCPY")
        #If fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY, SCPY, "TASCLOORD") = 2 Then
        #  # allowed : return a warning
        #  [L]ARET_VALUE = fmet this.ASETERROR("", func AFNC.MES3(mess(1093,2260,1), PJMTSKITM.TASCOD, WIPNUM, mess([F:ORDW]WIPSTA,317,1)), [V]CST_AWARNING)
        #Else
        #  # not allowed : return an error
        #  [L]ARET_VALUE = fmet this.ASETERROR("", func AFNC.MES2(mess(1092,2260,1), PJMTSKITM.TASCOD, WIPNUM), [V]CST_AERROR)
        #Endif
        ## Issue X3-97140 - 2018-06-19 by FGR : END
        # Issue X3-101833 - 2018-08-01 by FGR : END
      Endif
    Endif
  Else
    # Issue X3-101833 - 2018-08-01 by FGR
    If PJMTSKITM.FRCDLTALLFLG = [V]CST_AYES Then
      IS_WORK = [V]CST_ANO
    Endif
  Endif
  # -------------------------------------------------
  #If [L]ARET_VALUE <= [V]CST_AWARNING Then                          # Issue X3-97140 - 2018-06-19 by FGR
  If [L]ARET_VALUE <= [V]CST_AWARNING and IS_WORK = [V]CST_AYES Then # Issue X3-97140 - 2018-06-19 by FGR
    If PJMTSKITM.ASTALIN = [V]CST_ADEL or I_TODELETE = [V]CST_AYES Then
      WIP_PARAM.MAJCOD = "A"
      WIP_PARAM.WIPNUM = PJMTSKITM.WIPNUM
    Elsif PJMTSKITM.ASTALIN = [V]CST_ANEW or PJMTSKITM.ASTALIN = [V]CST_AUPD Then
      If NEXTQTY = 0 Then
        IS_WORK = [V]CST_ANO
      Elsif TECORDERS.TASSTATE = 1 Then
        # Nothing to do for this status : go out without error
        IS_WORK = [V]CST_ANO
      Else
        #If TECORDERS.TASSTATE = 5 or TECORDERS.TASSTATE = 2 Then                             # Issue X3-31898 - 2018-02-08 by FGR
        If TECORDERS.TASSTATE = 5 or TECORDERS.TASSTATE = 2 or TECORDERS.TASSTATE = 3 Then    # Issue X3-31898 - 2018-02-08 by FGR : started was missing
          # Plan or Launch
          If TECORDERS.TASSTATESNAP = 9 Then
            # Nothing to do for this status : was suspended and has been reactived.
            IS_WORK = [V]CST_ANO
          Elsif PJMTSKITM.WIPNUM = AVOID.ACHAR Then
            WIP_PARAM.WIPNUM = PJMTSKITM.WIPNUM
            WIP_PARAM.MAJCOD = "C"
          Elsif (TECORDERS.TASSTATESNAP = TECORDERS.TASSTATE or TECORDERS.TASSTATESNAP = 5) Then
            # Issue X3-31898/X3-66783 - 2018-02-08 by FGR : If task status have no changed or if previous task status was "Planned"
            WIP_PARAM.WIPNUM = PJMTSKITM.WIPNUM
            WIP_PARAM.MAJCOD = "M"
          Else
            WIP_PARAM.WIPNUM = PJMTSKITM.WIPNUM
            WIP_PARAM.MAJCOD = "C"
          Endif
        Else
          # Nothing to do for this status : go out without error
          IS_WORK = [V]CST_ANO
        Endif
      Endif
    Else
      # Nothing to do : go out without error
      IS_WORK = [V]CST_ANO
    Endif
    # --------------------------------------------
    If IS_WORK = [V]CST_AYES Then
      If WIP_PARAM.MAJCOD = "C" Then
        WIP_PARAM.FMI = 1
        WIP_PARAM.PIO = 1
        WIP_PARAM.ORI = 7
      Elsif WIP_PARAM.MAJCOD = "M" Then
        Local File ORDERS [ORDW]
        Read [ORDW]ORD0=WIPTYP;WIPNUM;ITMREF
        If !fstat Then
          # Issue number - 2018-01-24 by FGR : BEGIN
          #WIP_PARAM.FMI = [F:ORDW]FMI
          #WIP_PARAM.PIO = [F:ORDW]PIO
          #WIP_PARAM.ORI = [F:ORDW]ORI
          SetInstance WIP_PARAM With [F:ORDW]
          # Issue number - 2018-01-24 by FGR : END
        Endif
      Endif
      If WIP_PARAM.MAJCOD = "C" or WIP_PARAM.MAJCOD = "M" Then
        #WIP_PARAM.STOFCY     = PJMTSKITM.TASFCY             # Site de la tâche => TASFCY            # Issue X3-65941 - 2018-01-15 by FGR
        WIP_PARAM.STOFCY     = PJMTSKITM.STOFCY              # Site de stockage ligne article        # Issue X3-65941 - 2018-01-15 by FGR
        WIP_PARAM.ITMREF     = PJMTSKITM.ITMREF              # ITMREF
        If dim(PJMTSKITM.ECCVALMAJ) >= 0 Then
          WIP_PARAM.ECCVALMAJ  = PJMTSKITM.ECCVALMAJ         # ECC
        Endif
        If dim(PJMTSKITM.ECCVALMIN) >= 0 Then
          WIP_PARAM.ECCVALMIN  = PJMTSKITM.ECCVALMIN         # ECC
        Endif
        WIP_PARAM.WIPTYP     = 14                            # ML 306 - 14 = Demande affaire
        If TECORDERS.TASSTATE = 5 Then
          WIP_PARAM.WIPSTA   = 2                             # ML 317 - 1/2/3/4 = Firm/Planned/Suggested/Closed => 1 ou 2
        Else
          WIP_PARAM.WIPSTA   = 1                             # ML 317 - 1/2/3/4 = Firm/Planned/Suggested/Closed => 1 ou 2
        Endif
        WIP_PARAM.EXTQTY     = NEXTQTY                       # Quantité = ITTQTY
        WIP_PARAM.VCRTYP     = 40                            # ML 701 - 40 = Affaire
        WIP_PARAM.VCRNUM     = TECORDERS.VCRNUM              # Code tâche => TASCOD
        WIP_PARAM.VCRLIN     = PJMTSKITM.ITTSEQ              # Ligne de tâche => ITTSEQ
        WIP_PARAM.VCRSEQ     = 0                             # 0
        WIP_PARAM.PJT        = func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(this.ACTX, PJMTSKITM.OPPNUM, PJMTSKITM.TASCOD)
        WIP_PARAM.STRDAT     = TECORDERS.STRDAT
        WIP_PARAM.ENDDAT     = TECORDERS.ENDDAT
        # Issue X3-101833 - 2018-08-22 by FGR : BEGIN : In all cases
        ## Issue number - 2018-01-24 by FGR : BEGIN
        #If PJMTSKITM.TCHACTALLOC = "ALLOC" Then
        #  WIP_PARAM.ALLQTY = PJMTSKITM.ALLQTY
        #Endif
        ## Issue number - 2018-01-24 by FGR : END
        WIP_PARAM.ALLQTY = PJMTSKITM.ALLQTY
        # Issue X3-101833 - 2018-08-22 by FGR : END
      Endif
      # --------------------------------------------
      If WIP_PARAM.MAJCOD = "M" Then
        If PJMTSKITM.ITMREF <> PJMTSKITM.snapshot.ITMREF Then
          WIP_PARAM.ITMREF = PJMTSKITM.snapshot.ITMREF
          WIP_PARAM.MAJCOD = "A"
          [L]ARET_VALUE = fmet this.WIP(WIPTYP, WIPNUM, WIP_PARAM.ITMREF, WIP_PARAM, PJMTSKITM.WIPNUM)
          WIP_PARAM.ITMREF = PJMTSKITM.ITMREF
          WIP_PARAM.MAJCOD = "M"
        Endif
      Endif
      # --------------------------------------------
      If [L]ARET_VALUE = [V]CST_AOK Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.WIP(WIPTYP, WIPNUM, ITMREF, WIP_PARAM, PJMTSKITM.WIPNUM))
      Endif
    Endif
  Endif
  # --------------------------------------------
  #If [L]ARET_VALUE >= [V]CST_AERROR Then            # Issue X3-31898 - 2018-02-08 by FGR : started was missing
  If [L]ARET_VALUE >= [V]CST_AWARNING Then           # Issue X3-31898 - 2018-02-08 by FGR : started was missing
    # Copy the error(s) from the current task into the calling one
    Call MSGSTACK_COPY_TO_INST(this, PJMTSKITM) From SYRSTACKTOOLS
  Endif
  # --------------------------------------------
  FreeGroup WIP_PARAM
  # --------------------------------------------
Return

###################################################################################################
$ORDERS_FROM_PREQUISD #US 71069/260 by RBA 07/29/2016
#Value Tinyint WIPTYP
#Value Char WIPNUM ()
#Value Char ITMREF ()
#Variable Instance PREQUISD Using C_PREQUISD : #
#Variable Instance TECORDERS Using C_TECORDERS : #
#Local Integer ARET_VALUE

Local Instance WIP_PARAM Using C_ORDK
Local Integer IS_WORK

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------------------
  WIP_PARAM = NewInstance C_ORDK AllocGroup null
  IS_WORK = [V]CST_AYES
  Case PREQUISD.ASTALIN
    When [V]CST_ANEW
      WIP_PARAM.MAJCOD = "C"
    When [V]CST_AUPD
      WIP_PARAM.MAJCOD = "M"
      WIP_PARAM.WIPNUM = PREQUISD.WIPNUM
    When [V]CST_ADEL
      WIP_PARAM.MAJCOD = "A"
      WIP_PARAM.WIPNUM = PREQUISD.WIPNUM
    When Default
      # Nothing to do : go out without error
      IS_WORK = [V]CST_ANO
  Endcase
  # --------------------------------------------
  If IS_WORK = [V]CST_AYES
    # --------------------------------------------
    If not (WIP_PARAM.MAJCOD = "M" and PREQUISD.LINCLEFLG=2) #Si ce n'est pas une ligne en modification et soldée on continue
      ###
      #----- Chargement pièce origine si création autrement conservation valeurs -----#
      If WIP_PARAM.MAJCOD = "C"
        WIP_PARAM.ORIFCY    = PREQUISD.PSHFCY
        WIP_PARAM.VCRTYPORI = 0
        WIP_PARAM.VCRNUMORI = ""
        WIP_PARAM.VCRLINORI = 0
        WIP_PARAM.VCRSEQORI = 0
      Endif
      # --------------------------------------------
      If WIP_PARAM.MAJCOD = "C" or WIP_PARAM.MAJCOD = "M"
        WIP_PARAM.FMI       = 1
        WIP_PARAM.ORI       = 1
        WIP_PARAM.STOFCY    = PREQUISD.PRHFCY
        WIP_PARAM.ITMREF    = PREQUISD.ITMREF
        If dim(PREQUISD.ECCVALMAJ) >= 0 Then
          WIP_PARAM.ECCVALMAJ  = PREQUISD.ECCVALMAJ         # ECC
        Endif
        If dim(PREQUISD.ECCVALMIN) >= 0 Then
          WIP_PARAM.ECCVALMIN  = PREQUISD.ECCVALMIN         # ECC
        Endif
        WIP_PARAM.WIPTYP    = 2
        WIP_PARAM.WIPSTA    = 2
        WIP_PARAM.EXTQTY    = PREQUISD.QTYSTU
        WIP_PARAM.CPLQTY    = PREQUISD.ORDQTYSTU
        WIP_PARAM.ALLQTY    = 0
        WIP_PARAM.SHTQTY    = 0
        WIP_PARAM.VCRTYP    = 14
        WIP_PARAM.VCRNUM    = PREQUISD.PSHNUM
        WIP_PARAM.VCRLIN    = PREQUISD.PSDLIN
        WIP_PARAM.VCRSEQ    = 0
        WIP_PARAM.PJT       = PREQUISD.PJT
        WIP_PARAM.STRDAT    = PREQUISD.EXTORDDAT
        WIP_PARAM.ENDDAT    = PREQUISD.EXTRCPDAT

        WIP_PARAM.BPRNUM    = PREQUISD.BPSNUM
        WIP_PARAM.MRPMES    = 1
        WIP_PARAM.BOMALT    = 0
        WIP_PARAM.ABBFIL    = "PSD"
        # --------------------------------------------
        If WIP_PARAM.MAJCOD = "M" Then
          If PREQUISD.ITMREF <> PREQUISD.snapshot.ITMREF Then
            WIP_PARAM.ITMREF = PREQUISD.snapshot.ITMREF
            WIP_PARAM.MAJCOD = "A"
            [L]ARET_VALUE = fmet this.WIP(WIPTYP, WIPNUM, WIP_PARAM.ITMREF, WIP_PARAM, PREQUISD.WIPNUM)
            WIP_PARAM.ITMREF = PREQUISD.ITMREF
            WIP_PARAM.MAJCOD = "M"
          Endif
        Endif
        # --------------------------------------------
        If [L]ARET_VALUE = [V]CST_AOK Then
          [L]ARET_VALUE = fmet this.WIP(WIPTYP, WIPNUM, ITMREF, WIP_PARAM, PREQUISD.WIPNUM)
        Endif
        # --------------------------------------------
        If [L]ARET_VALUE >= [V]CST_AERROR Then
          # Copy the error(s) from the current task into the calling one
          Call MSGSTACK_COPY_TO_INST(this, PREQUISD) From SYRSTACKTOOLS
        Endif
      Endif
    Endif
  Endif
  # --------------------------------------------
  FreeGroup WIP_PARAM
Return

###################################################################################################
$WIP
#Value Tinyint WIPTYP
#Value Char WIPNUM ()
#Value Char ITMREF ()
#Variable Instance WIP_PARAM Using C_ORDK : #
#Variable Char RWIPNUM ()
#Local Integer ARET_VALUE

Local Integer IS_WORK

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------------------
  IS_WORK = [V]CST_AYES
  Case WIP_PARAM.MAJCOD
    When "C"
      #Goto W_CREATION
      # --------------------------------------------
      [L]ARET_VALUE = fmet this.AINIT()
      If [L]ARET_VALUE < [V]CST_AERROR Then
        [L]ARET_VALUE = fmet this._WIP_CREATE(WIP_PARAM)
        If [L]ARET_VALUE < [V]CST_AERROR Then
          [L]ARET_VALUE = fmet this.AINSERT()
        Endif
      Endif
      # --------------------------------------------
    When "M"
      #Goto W_MODIFICATION
      # --------------------------------------------
      Local File ORDERS [ORDW]
      Look [ORDW]ORD0=WIPTYP;WIPNUM;ITMREF
      If !fstat Then
        # --------------------------------------------
        If (WIP_PARAM.EXTQTY <= 0) or (WIP_PARAM.EXTQTY <= WIP_PARAM.CPLQTY) Then
          # --------------------------------------------
          WIP_PARAM.MAJCOD = "A"
          [L]ARET_VALUE = fmet this.WIP(WIPTYP, WIPNUM, ITMREF, WIP_PARAM, RWIPNUM)
          # --------------------------------------------
        Elsif WIP_PARAM.VCRTYP = 10 and WIP_PARAM.WIPTYP <> 5 and WIP_PARAM.ORDSTA = 4 Then
          # si production et élément exclu (matière ou service sous-traitance, pas d'encours)
          # --------------------------------------------
          WIP_PARAM.MAJCOD = "A"
          [L]ARET_VALUE = fmet this.WIP(WIPTYP, WIPNUM, ITMREF, WIP_PARAM, RWIPNUM)
          # --------------------------------------------
        Elsif WIP_PARAM.EXTQTY <= WIP_PARAM.CPLQTY Then
          # --------------------------------------------
          WIP_PARAM.MAJCOD = "A"
          [L]ARET_VALUE = fmet this.WIP(WIPTYP, WIPNUM, ITMREF, WIP_PARAM, RWIPNUM)
          # --------------------------------------------
        Else
          # --------------------------------------------
          [L]ARET_VALUE = fmet this.AREAD(WIPTYP, WIPNUM, ITMREF)
          If [L]ARET_VALUE < [V]CST_AERROR Then
            [L]ARET_VALUE = fmet this._WIP_UPDATE(WIP_PARAM)
            If [L]ARET_VALUE < [V]CST_AERROR Then
              [L]ARET_VALUE = fmet this.AUPDATE()
            Endif
          Endif
          # --------------------------------------------
        Endif
      Else
        WIP_PARAM.MAJCOD = "C"
        [L]ARET_VALUE = fmet this.WIP(WIPTYP, WIPNUM, ITMREF, WIP_PARAM, RWIPNUM)
      Endif
      # --------------------------------------------
    When "A"
      #Goto W_SUPPRESSION
      # --------------------------------------------
      Local File ORDERS [ORDW]
      Look [ORDW]ORD0=WIPTYP;WIPNUM;ITMREF
      If !fstat Then
        [L]ARET_VALUE = fmet this.AREAD(WIPTYP, WIPNUM, ITMREF)
        If [L]ARET_VALUE < [V]CST_AERROR Then
          [L]ARET_VALUE = fmet this.ADELETE()
        Endif
      Endif
    When "P"
      #Goto W_CONSOMMATION
      # --------------------------------------------
      Local File ORDERS [ORDW]
      Look [ORDW]ORD0=WIPTYP;WIPNUM;ITMREF
      If !fstat Then
        [L]ARET_VALUE = fmet this.AREAD(WIPTYP, WIPNUM, ITMREF)
        If [L]ARET_VALUE < [V]CST_AERROR Then
          [L]ARET_VALUE = fmet this._WIP_CONSUM(WIP_PARAM)
          If [L]ARET_VALUE < [V]CST_AERROR Then
            [L]ARET_VALUE = fmet this.AUPDATE()
          Endif
        Endif
      Else
        WIP_PARAM.CPLQTY = 0
      Endif
      # --------------------------------------------
    When Default
      IS_WORK = [V]CST_ANO
  Endcase
  # --------------------------------------------
  If IS_WORK = [V]CST_AYES Then
    If [L]ARET_VALUE < [V]CST_AERROR Then
      If (WIP_PARAM.MAJCOD = "C" or RWIPNUM = AVOID.ACHAR) and this.WIPNUM <> AVOID.ACHAR Then
        RWIPNUM = this.WIPNUM
      Elsif WIP_PARAM.MAJCOD = "A" Then
        Raz RWIPNUM
      Endif
    Endif
  Endif
  # --------------------------------------------
Return

