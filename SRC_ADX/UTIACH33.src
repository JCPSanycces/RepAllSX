#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UTIACH33      Utilitaire de lancement de la               Module ACHAT #
#               resynchro des en cours fourn. bug 85354    SR 20/11/2012 #
# ---------------------------------------------------------------------- #
##########################################################################


Call MAJ_UTIACH33
End


Subprog MAJ_UTIACH33
Local Char WDOSSIER(30)
Local Libelle WTRACE  : WTRACE=2     : # WTRACE=2 --> Trace détaillée
WDOSSIER=nomap
Call SAIDOS(WDOSSIER,"UTIACH33 - Resynchronize BP balances v6") From SAIDOS
If WDOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  If WTRACE
    Call OUVRE_TRACE("UTIACH33 : Resynchronize BP balances v6") From LECFIC
    Call ECR_TIME("UTIACH33 : Starting process on folder "+WDOSSIER) From DOSSUB
  Endif
  Call EXE_UTIACH33(WDOSSIER,WTRACE)
  Call ECR_TIME("UTIACH33 : End process on folder "+WDOSSIER) From DOSSUB
  Call TEMPOFF From GESECRAN
  If WTRACE
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
Endif
End


Subprog EXE_UTIACH33(WDOSSIER,WTRACE)
Value Char     WDOSSIER
Value Libelle  WTRACE
#----- Variables locales -----#

#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=WDOSSIER : If fstat  Raz [F:ADS] : Endif
#-----
Gosub TRT_MVS
#-----
$FIN_UTIACH33
If WTRACE
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Endif
#-----
End


#-------------------------------------------------------#
# Resynchronisation En-cours fournisseurs               #
#------------------------------------------------------ #
#-------------------------------------------------------#
$TRT_MVS
#----- Tables tronc commun et superviseur -----#
Local File =[F:ADS]DOSSIER+".BPCUSTMVT"   [MVC]
Local File =[F:ADS]DOSSIER+".BPSUPPMVT"   [MVS]
Local File =[F:ADS]DOSSIER+".LASTSUPMVT"  [LSM]
Local File =[F:ADS]DOSSIER+".BPARTNER"    [BPR] 
Local File =[F:ADS]DOSSIER+".BPCUSTOMER"  [BPC]
Local File =[F:ADS]DOSSIER+".BPSUPPLIER"  [BPS]
Local File =[F:ADS]DOSSIER+".ITMMASTER"   [ITM]
Local File =[F:ADS]DOSSIER+".PINVOICE"    [PIH]
Local File =[F:ADS]DOSSIER+".PERIOD"      [PER]
Local File =[F:ADS]DOSSIER+".FISCALYEAR"  [FIY]
Local File =[F:ADS]DOSSIER+".GACCOUNT"    [GAC]
Local File =[F:ADS]DOSSIER+".TABCUR"      [TCU]
Local File =[F:ADS]DOSSIER+".TABCUR"      [TCU0]
Local File =[F:ADS]DOSSIER+".TABCHANGE"   [TCH]
Local File =[F:ADS]DOSSIER+".COMPANY"     [CPY]
Local File =[F:ADS]DOSSIER+".FACILITY"    [FCY]
#----- Tables achats -----#
Local File =[F:ADS]DOSSIER+".PQUOTAT"     [PQH]
Local File =[F:ADS]DOSSIER+".PORDER"      [POH]
Local File =[F:ADS]DOSSIER+".PORDERQ"     [POQ]
Local File =[F:ADS]DOSSIER+".PRECEIPT"    [PTH]
Local File =[F:ADS]DOSSIER+".PRECEIPTD"   [PTD]
#----- Tables tiers -----#
If [F:ADS]MODULE(2)=2
  Local File =[F:ADS]DOSSIER+".PAYMENTH"  [PYH]
  Local File =[F:ADS]DOSSIER+".TABPAYTYP" [TPY]
Endif
#----- Tables comptabilité -----#
If [F:ADS]MODULE(1)=2
  Local File =[F:ADS]DOSSIER+".BALANCE"   [BAL]
Endif
Call RESYNCHRO_BPSMVT(2,"",2,"",1) From FUNBPSMVT
# Fermeture des tables
Close Local File [MVC], [MVS], [LSM], [BPR], [BPC], [BPS], [ITM], [PIH], [PER],
&                [FIY], [GAC], [TCU], [TCU0], [TCH], [CPY], [FCY], [PQH], [POH], [POQ],
&                [PTH], [PTD]
#-----
If [F:ADS]MODULE(2)=2  Close Local File [PYH], [TPY] : Endif
If [F:ADS]MODULE(1)=2  Close Local File [BAL] : Endif
#-----
If WTRACE
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Endif
Return


###################################################
# Pour exécution automatique  en gestion de patch #
###################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat  Raz [F:ADS] : Endif
#-----
If [F:ADS]MODULE(5)=2
  Call ECR_TRACE("UTIACH33 : Resynchronize BP balances v6",0) From GESECRAN
  Call EXE_UTIACH33(DOSSIER,1)
Endif
#-----       
End


#########################################################
# Pour exécution depuis DOSMAJ au changement de version #
#########################################################
Subprog UTI_MOUL(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If [F:ADS]MODULE(5)=2
  Call ECR_TRACE("UTIACH33 : Resynchronize BP balances v6",0) From GESECRAN
  Call EXE_UTIACH33(DOSSIER,1)
Endif
#-----
End
