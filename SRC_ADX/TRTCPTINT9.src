#=============================================================================
$EVENEMENT_GRTCRT
 If [M:TPE]TRTINT<>""
  Gosub ALIM_TCD From =[M:TPE]TRTINT
 Else
  #CHECK UNUSED_BEGIN 
  [F:TCD]CUR       = [F:CPT]CUR
  [F:TCD]GRASTA    = [F:CPT]GRASTA
  [F:TCD]ALPHA(0)  = [F:CPT]REN
  [F:TCD]GAC(0)    = [F:CPT]REINACC4
  [F:TCD]GAC(1)    = [F:CPT]GAC
  If G_ACTIAS=G_OUI
   [F:TCD]IASACC(0)= [F:CPT]REIASACC4
   [F:TCD]IASACC(1)= [F:CPT]IASACC
  Endif 
  [F:TCD]SNS       = 2*([F:CPT]SNSEVE<2)-1    # 1 => +1 (D) / 2 => -1 (C) 
  [F:TCD]AMT(0)    = [F:CPT]GRAAMT 
  GPOINT = "ALIMTCD" : Gosub ENTREE From EXEFNC
  #CHECK UNUSED_END
 Endif
Return

