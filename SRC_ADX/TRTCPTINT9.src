#=============================================================================
$EVENEMENT_LOFCIM
 If [M:TPE]TRTINT<>""
  Gosub ALIM_TCD From =[M:TPE]TRTINT
 Else
  #CHECK UNUSED_BEGIN
  [F:TCD]GAC(0)     = [F:CPT]GACO
  [F:TCD]GAC(1)     = [F:CPT]GACD
  If G_ACTIAS=G_OUI
   [F:TCD]IASACC(0) = [F:CPT]GACO
   [F:TCD]IASACC(1) = [F:CPT]GACD   
  Endif
  [F:TCD]CUR        = [F:CPT]CUR
  [F:TCD]SNS        = 2*([F:CPT]SNSEVE<2)-1    # 1 => +1 (D) / 2 => -1 (C)
  [F:TCD]AMT(0)     = [F:CPT]AMTNOTCPY+[F:CPT]AMTVATCPY-[F:CPT]AMTVATRCPY
  GPOINT = "ALIMTCD" : Gosub ENTREE From EXEFNC  
  #CHECK UNUSED_END 
 Endif
Return

#=============================================================================
$EVENEMENT_LOFVATREG
 If [M:TPE]TRTINT<>""
  Gosub ALIM_TCD From =[M:TPE]TRTINT
 Else
  #CHECK UNUSED_BEGIN
  [F:TCD]GAC(0)     = [F:CPT]GAC
  [F:TCD]GACACN(0)  = [F:CPT]GACACN
  If G_ACTIAS=G_OUI
   [F:TCD]IASACC(0) = [F:CPT]GAC
   [F:TCD]IASACN(0) = [F:CPT]GACACN
  Endif
  [F:TCD]CUR        = [F:CPT]CUR
  [F:TCD]SNS        = 2*([F:CPT]SNSEVE<2)-1    # 1 => +1 (D) / 2 => -1 (C)
  [F:TCD]AMT(0)     = [F:TCD]CRBVAT
  [F:TCD]AMT(1)     = [F:TCD]DEDVAT
  GPOINT = "ALIMTCD" : Gosub ENTREE From EXEFNC 
  #CHECK UNUSED_END   
 Endif
Return

