#=============================================================================
$EVENEMENT_GRTCASH
 If [M:TPE]TRTINT<>""
  Gosub ALIM_TCD From =[M:TPE]TRTINT
 Else
  #CHECK UNUSED_BEGIN 
  [F:TCD]CUR       = [F:CPT]CUR
