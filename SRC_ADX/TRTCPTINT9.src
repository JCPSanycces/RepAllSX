#=============================================================================
$DEPREC_ALIM
 If [M:TPE]TRTINT<>""
  Gosub ALIM_TCD From =[M:TPE]TRTINT
 Else
  #CHECK UNUSED_BEGIN
  [F:TCD]ACCCOD    = [F:OBJ]ACCCOD
  [F:TCD]GACACN    = [F:OBJ]GACACN
  [F:TCD]GAC       = [F:OBJ]GAC
  [F:TCD]AASBUS    = [F:OBJ]AASBUS
  If G_ACTIAS=G_OUI
   [F:TCD]IASCGU   = [F:OBJ]IASCGU
  Endif
  [F:TCD]DSP       = [F:OBJ]DSP
  For I_CCE=1 To GOPTCANA
   [F:TCD]CCE(I_CCE-1) = [F:OBJ]CCE(I_CCE-1)
  Next I_CCE
  [F:TCD]CUR       = func GLOFCYCPY.GET_DEVISE_PLN([F:OBJ]CPY,[F:CPT]DPRPLN)
  [F:TCD]OWNTYP    = [F:OBJ]OWNTYP
  [F:TCD]SNS       = +1
  [F:TCD]AMT(0)   += [F:CPT]DPEDEV
  [F:TCD]AMT(1)   += [F:CPT]EXCDEV
  [F:TCD]AMT(2)   += [F:CPT]DERDEV
  [F:TCD]AMT(3)   += [F:CPT]DERRVEDEV
  [F:TCD]AMT(4)   += [F:CPT]RVETRFDEV
  [F:TCD]AMT(5)   += [F:CPT]RVACRBDEV
  GPOINT = "ALIMTCD" : Gosub ENTREE From EXEFNC
  #CHECK UNUSED_END
 Endif
Return

#@fq64544
