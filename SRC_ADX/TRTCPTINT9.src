#=============================================================================
$EVENEMENT_FASREEVAL 
 If [M:TPE]TRTINT<>""
  Gosub ALIM_TCD From =[M:TPE]TRTINT
 Else
  #CHECK UNUSED_BEGIN 
  [F:TCD]ACCCOD    = [F:CPT]ACCCOD
  [F:TCD]GAC       = [F:CPT]GAC
  [F:TCD]AASBUS    = [F:CPT]AASBUS
  If G_ACTIAS=G_OUI
   [F:TCD]IASACC   = [F:CPT]IASACC
   [F:TCD]IASCGU   = [F:CPT]IASCGU
  Endif
  [F:TCD]DSP       = [F:CPT]DSP
  For I_CCE=1 To GOPTCANA
   [F:TCD]CCE(I_CCE-1) = evalue("[F:CPT]CCE"+num$(I_CCE))
  Next I_CCE
  [F:TCD]CUR       = [F:CPT]CUR
  [F:TCD]OWNTYP    = [F:CPT]OWNTYP 
  [F:TCD]SNS       = 2*([F:CPT]SNSEVE<2)-1    # 1 => +1 (D) / 2 => -1 (C)
  [F:TCD]AMT(0)    = [F:CPT]DPRBASO
  [F:TCD]AMT(1)    = [F:CPT]DPRBASD
  [F:TCD]AMT(2)    = [F:CPT]DPRCUMO+[F:CPT]PERCLOCUMO
  [F:TCD]AMT(3)    = [F:CPT]DPRCUMD+[F:CPT]PERCLOCUMD 
  [F:TCD]AMT(4)    = [F:CPT]NBVO
  [F:TCD]AMT(5)    = [F:CPT]NBVD 
  GPOINT = "ALIMTCD" : Gosub ENTREE From EXEFNC
  #CHECK UNUSED_END  
 Endif
Return

