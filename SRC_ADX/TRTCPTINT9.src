  [F:TCD]AMT(0)    = [F:CPT]RMNTPA
  GPOINT = "ALIMTCD" : Gosub ENTREE From EXEFNC
  #CHECK UNUSED_END  
 Endif
Return

#=============================================================================
$EVENEMENT_LEACNL
 If [M:TPE]TRTINT<>""
  Gosub ALIM_TCD From =[M:TPE]TRTINT
 Endif
Return
#=============================================================================
$EVENEMENT_X
 If [M:TPE]TRTINT<>""
  Gosub ALIM_TCD From =[M:TPE]TRTINT
 Endif 
Return
