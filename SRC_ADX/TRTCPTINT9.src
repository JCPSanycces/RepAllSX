  [F:TCD]ALPHA(0)  = [F:CPT]REN
  [F:TCD]GAC(0)    = [F:CPT]REINACC1
  [F:TCD]GAC(1)    = [F:CPT]REINACC7
  If G_ACTIAS=G_OUI
   [F:TCD]IASACC(0)= [F:CPT]REIASACC1
   [F:TCD]IASACC(1)= [F:CPT]REIASACC7
  Endif 
  [F:TCD]SNS       = 2*([F:CPT]SNSEVE<2)-1    # 1 => +1 (D) / 2 => -1 (C) 
  [F:TCD]AMT(0)    = [F:CPT]CRBGRAAMT
  GPOINT = "ALIMTCD" : Gosub ENTREE From EXEFNC
  #CHECK UNUSED_END  
 Endif
