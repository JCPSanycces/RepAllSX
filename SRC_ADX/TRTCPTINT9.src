  [F:TCD]ALPHA(0)  = [F:CPT]REN
  [F:TCD]GAC(0)    = [F:CPT]REINACC4
  If G_ACTIAS=G_OUI
   [F:TCD]IASACC(0)= [F:CPT]REIASACC4
  Endif 
  [F:TCD]SNS       = 2*([F:CPT]SNSEVE<2)-1    # 1 => +1 (D) / 2 => -1 (C) 
  [F:TCD]AMT(0)    = [F:CPT]CASHAMT
  GPOINT = "ALIMTCD" : Gosub ENTREE From EXEFNC
  #CHECK UNUSED_END  
 Endif
Return

