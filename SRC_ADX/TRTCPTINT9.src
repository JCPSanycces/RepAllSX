#=============================================================================
$EVENEMENT_FASCHGIMP
 If [M:TPE]TRTINT<>""
  Gosub ALIM_TCD From =[M:TPE]TRTINT
 Else
  #CHECK UNUSED_BEGIN
  [F:TCD]ACCCOD(0)  = [F:CPT]ACCCOD 
  [F:TCD]ACCCOD(1)  = [F:CPT]ACCCODD
  [F:TCD]GACACN(0)  = [F:CPT]GACACNO
  [F:TCD]GACACN(1)  = [F:CPT]GACACND
  [F:TCD]GAC(0)     = [F:CPT]GACO
  [F:TCD]GAC(1)     = [F:CPT]GACD
  If G_ACTIAS=G_OUI
   [F:TCD]IASACN(0) = [F:CPT]IASACNO
   [F:TCD]IASACN(1) = [F:CPT]IASACND
   [F:TCD]IASACC(0) = [F:CPT]IASACCO
   [F:TCD]IASACC(1) = [F:CPT]IASACCD  
  Endif
  [F:TCD]DSP       = [F:CPT]DSP
  For I_CCE=1 To GOPTCANA
   [F:TCD]CCE(I_CCE-1) = evalue("[F:CPT]CCE"+num$(I_CCE))
  Next I_CCE
  [F:TCD]CUR       = [F:CPT]CUR
  [F:TCD]OWNTYP    = [F:CPT]OWNTYPD
  [F:TCD]SNS       = 2*([F:CPT]SNSEVE<2)-1    # 1 => +1 (D) / 2 => -1 (C)
  [F:TCD]EVTPRINC  = [F:CPT]EVTPRINC
  [F:TCD]AMT(0)    = [F:CPT]DPRBAS
  [F:TCD]AMT(1)    = [F:CPT]PSTDPE
  [F:TCD]AMT(2)    = [F:CPT]EXEIMLCUM+[F:CPT]PERIMLCUM+[F:CPT]IML-[F:CPT]EXERVECUM-[F:CPT]PERRVECUM-[F:CPT]IMLRVE
  [F:TCD]AMT(3)    = [F:CPT]PSTEXC
  [F:TCD]AMT(4)    = [F:CPT]PSTDER
  [F:TCD]AMT(5)    = [F:CPT]PSTDERRVE
  [F:TCD]AMT(6)    = [F:CPT]PSTRVETRF
  [F:TCD]AMT(7)    = [F:CPT]PSTRVACRB
  GPOINT = "ALIMTCD" : Gosub ENTREE From EXEFNC 
  #CHECK UNUSED_END 
 Endif
Return

#=============================================================================
$EVENEMENT_FASCRT
 If [M:TPE]TRTINT<>""
  Gosub ALIM_TCD From =[M:TPE]TRTINT
 Else
  #CHECK UNUSED_BEGIN
  [F:TCD]CUR       = [F:CPT]CUR
  [F:TCD]ACCCOD(0) = [F:CPT]ACCCOD 
  [F:TCD]ACCCOD(1) = [F:OBJ]LEAREFORI 
  [F:TCD]OWNTYP    = [F:CPT]OWNTYPD
  [F:TCD]ETRNAT    = [F:CPT]ETRNAT
  [F:TCD]SNS       = 2*([F:CPT]SNSEVE<2)-1    # 1 => +1 (D) / 2 => -1 (C)
  [F:TCD]AMT(0)    = [F:CPT]PURVAL
  GPOINT = "ALIMTCD" : Gosub ENTREE From EXEFN
  #CHECK UNUSED_END 
 Endif
Return

