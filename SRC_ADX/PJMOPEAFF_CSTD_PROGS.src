###################################################################################################
# Class PJMOPEAFF
###################################################################################################
Funprog GET_KEYCONCAT_VARIABLES(SOPPNUM, STASCOD, IOPENUM, IOPESPLNUM, IPOANUM)
Value Char SOPPNUM
Value Char STASCOD
Value Integer IOPENUM
Value Integer IOPESPLNUM
Value Integer IPOANUM

Local Char SARENDRE(250)

  # Specially used for translated texts key
  SARENDRE = SOPPNUM + "~" + STASCOD + "~" + num$(IOPENUM) + "~" + num$(IOPESPLNUM) + "~" + num$(IPOANUM)
End SARENDRE

#--------------------------------------------------------------------------------------
Funprog GET_POADES(CTX, KEYCONCAT)
Variable Instance CTX Using OBJECT
Value Char KEYCONCAT

Local Char SARENDRE(GLONDCO)

  Raz SARENDRE
  Call LECTEXTRA_SYR(CTX, AVOID.ACHAR, SARENDRE, "PJMOPEAFF", "POADES", KEYCONCAT, AVOID.ACHAR) From ATEXTRA
End SARENDRE

#######################################################################################
Funprog POALGDES_EXIST(ACTX, SIDENT2, IIDENT3)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SIDENT2
Value Integer IIDENT3

Local Integer IARENDRE

  # Issue X3-6422/120397 - 2017-03-14 by SINGC
  IARENDRE = func OPPORPJM_CSTD_PROGS.IS_PJMCLOB_EXIST(ACTX, "PJMOPEAFF", "POALGDES", SIDENT2, num$(IIDENT3), AVOID.ACHAR)
End IARENDRE

#######################################################################################
Funprog POALGCOM_EXIST(ACTX, SIDENT2, IIDENT3)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SIDENT2
Value Integer IIDENT3

Local Integer IARENDRE

  # Issue X3-6422/120397 - 2017-03-14 by SINGC
  IARENDRE = func OPPORPJM_CSTD_PROGS.IS_PJMCLOB_EXIST(ACTX, "PJMOPEAFF", "POALGCOM", SIDENT2, num$(IIDENT3), AVOID.ACHAR)
End IARENDRE

