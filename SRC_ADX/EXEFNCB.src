#<AdxTL>@(#)2.0.0.0 $Revision$
$ACTION
Case ACTION
 When "FONCTION" : Gosub FONCTION
Endcase
Return

$FONCTION
  Case FONCTION
    When "GEXPOBJ"
      If dim(GFMTACC)>0: Raz GFMTACC : Endif
    When "EDITBLA","GESARP"
      If dim(GCCEFMT)>0 : Raz GCCEFMT : Endif
    When Default
  Endcase

  If [F:AFC]MODULE = 14 : # Module Immobilisation
    # Contrôle du nombre d'immobilisations
    If func TRTLIC.INFMSG() > 1
      # Le nombre d'immobilisations gérées est supérieur à la licence
      End : # Le "End" est volontaire, il sert à interrompre l'exécution de la fonction. Ne pas mettre "Return"
    Endif
  Endif
Return
