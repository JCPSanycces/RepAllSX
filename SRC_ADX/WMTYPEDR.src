#<AdxTL>@(#)0.0.0.0 $Revision$Class Version
# Supervisor
## ATY-ATYPE ## EDR
# 2018-11-09 07:14:08 817

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,MSGCOD,MSGREL,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char MSGCOD
Value Char MSGREL
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File EDIMSG [EMS]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".EDIMSG" [EMS]
Endif

Default File [F:EMS]
Read [F:EMS]EMS0 = [L]MSGCOD;[L]MSGREL
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]MSGCOD)+"~"+num$([L]MSGREL)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]MSGCOD)+"~"+num$([L]MSGREL)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


