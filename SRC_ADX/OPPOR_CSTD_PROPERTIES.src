#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Classe OPPOR
#######################################################################################
# PROPERTIES                                                                          #
#######################################################################################
#######################################################################################
$TCHISPJM
  Case [L]ARULE
    When "INIT"      : Gosub TCHISPJM_INIT
  Endcase
Return

$TCHISPJM_INIT
  this.TCHISPJM = func ASYRFNC.ACTIV("PJM")
Return

#######################################################################################
$TCHIMPORT
  Case [L]ARULE
    When "INIT"      : Gosub TCHIMPORT_INIT
  Endcase
Return

$TCHIMPORT_INIT
  this.TCHIMPORT = [V]CST_ANO
Return

#######################################################################################
$TCHMODULE
  Case [L]ARULE
    When "INIT"      : Gosub TCHMODULE_INIT
  Endcase
Return

$TCHMODULE_INIT
  this.TCHMODULE = 13
Return

#######################################################################################
$TCHTOREAD
  Case [L]ARULE
    When "INIT"      : Gosub TCHTOREAD_INIT
    When "CONTROL"   : Gosub TCHTOREAD_CONTROL
  Endcase
Return

$TCHTOREAD_INIT
  this.TCHTOREAD = ""
Return

$TCHTOREAD_CONTROL
  If find(this.TCHTOREAD,"","CRM","PJM","ALL") = 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TCHTOREAD", mess(357,199,1) - ":" - this.TCHTOREAD, [V]CST_AFATAL))
  Endif
  If this.TCHISPJM = [V]CST_AFALSE and find(this.TCHTOREAD,"PJM","ALL") <> 0 Then
    # If PJM module is note available, this value is not autorised.
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TCHTOREAD", mess(357,199,1) - ":" - this.TCHTOREAD, [V]CST_AFATAL))
  Endif
Return

#######################################################################################
$OPPNUM
  Case [L]ARULE
    When "CONTROL"   : Gosub OPPNUM_CONTROL
    When "PROPAGATE" : Gosub OPPNUM_PROPAGATE
  Endcase
Return

$OPPNUM_CONTROL
  If this.ASTALIN = [V]CST_AUPD Then
    If this.OPPNUM <> this.snapshot.OPPNUM Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPPNUM", mess(18,9804,1), [V]CST_AFATAL))
    Endif
  Endif
Return

$OPPNUM_PROPAGATE
  this.PIMPL.OPPNUM = this.OPPNUM
Return

#######################################################################################
$SALFCY
  Case [L]ARULE
    When "INIT"      : Gosub SALFCY_INIT
    When "CONTROL"   : Gosub SALFCY_CONTROL
    When "PROPAGATE" : Gosub SALFCY_PROPAGATE
  Endcase
Return

# Issue X3-99661 - 2018-07-05 by FGR : BEGIN
$SALFCY_INIT
Local Char SFCY(GLONFCY)

  If this.SALFCY = AVOID.ACHAR Then
    [L]ASTATUS = fmet this.ACTX.AGETPRFFCYDEF(this, this.TCHMODULE, SFCY)
    If SFCY <> AVOID.ACHAR Then
      this.SALFCY = SFCY
    Endif
  Endif
Return

#$SALFCY_INIT
#  If this.SALFCY = "" Then
#    [L]ASTATUS = fmet this.ACTX.AGETPRFFCYDEF(this, this.TCHMODULE, this.SALFCY)
#  Endif
#Return
# Issue X3-99661 - 2018-07-05 by FGR : END

$SALFCY_CONTROL
  If fmet this.ACTX.ACACHE.AFCY.AGETVALNUM(this.SALFCY,"SALFLG") <> [V]CST_AYES Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("SALFCY", func AFNC.MES1(mess(548,2260,1), this.SALFCY), [V]CST_AERROR))
  Endif
  If this.ASTALIN = [V]CST_AUPD Then
    If this.snapshot.SALFCY <> this.SALFCY Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("SALFCY", mess(1176,196,1), [V]CST_AERROR))
    Endif
  Endif
Return

$SALFCY_PROPAGATE
  this.CPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.SALFCY,"LEGCPY")
  # -----------------------------
  this.PIMPL.FCY = this.SALFCY
  # -----------------------------
  If this.CRM(1) <> null and fmet this.COM_IS_CRM_OPPOR() = [V]CST_ATRUE Then
    this.CRM(1).SALFCY = this.SALFCY
  Endif
  If this.TCHISPJM = [V]CST_ATRUE and this.PJM(1) <> null and fmet this.COM_IS_PJM_OPPOR() = [V]CST_ATRUE Then
    this.PJM(1).SALFCY = this.SALFCY
  Endif
Return

#######################################################################################
$CPY
  Case [L]ARULE
    When "PROPAGATE" : Gosub CPY_PROPAGATE
  Endcase
Return

$CPY_PROPAGATE
  # -----------------------------
  this.CUR = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(this.CPY,"RGCCUR")
  # -----------------------------
  this.PIMPL(1).CPY = this.CPY
  If this.CRM(1) <> null and fmet this.COM_IS_CRM_OPPOR() = [V]CST_ATRUE Then
    this.CRM(1).CPY = this.CPY
  Endif
  If this.TCHISPJM = [V]CST_ATRUE and this.PJM(1) <> null and fmet this.COM_IS_PJM_OPPOR() = [V]CST_ATRUE Then
    this.PJM(1).CPY = this.CPY
  Endif
  # -----------------------------
Return

#######################################################################################
$CUR
  Case [L]ARULE
    When "CONTROL"   : Gosub CUR_CONTROL
    When "PROPAGATE" : Gosub CUR_PROPAGATE
  Endcase
Return

$CUR_CONTROL
  If this.ASTALIN = [V]CST_AUPD Then
    If this.CUR <> this.snapshot.CUR Then
      If this.TCHISPJM = [V]CST_ATRUE and this.PJM(1) <> null and fmet this.COM_IS_PJM_OPPOR() = [V]CST_ATRUE Then
        If fmet this.PJM(1).BUD_COUNT() > 0 or fmet this.PJM(1).TAS_COUNT() > 0 Then
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("CUR", mess(516,2260,1), [V]CST_AERROR))
        Endif
      Endif
    Endif
  Endif
Return

$CUR_PROPAGATE
  If this.CRM(1) <> null and fmet this.COM_IS_CRM_OPPOR() = [V]CST_ATRUE Then
    this.CRM(1).CUR = this.CUR
  Endif
  If this.TCHISPJM = [V]CST_ATRUE and this.PJM(1) <> null and fmet this.COM_IS_PJM_OPPOR() = [V]CST_ATRUE Then
    this.PJM(1).CUR = this.CUR
  Endif
Return

#######################################################################################
$OPPCMP
  Case [L]ARULE
    When "CONTROL"   : Gosub OPPCMP_CONTROL
    When "PROPAGATE" : Gosub OPPCMP_PROPAGATE
  Endcase
Return

$OPPCMP_CONTROL
Local Integer IUSED

  If this.OPPCMP <> AVOID.ACHAR Then
    If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and this.OPPCMP <> this.snapshot.OPPCMP) Then
      If this.PIMPL.PIMTYP = 2 or this.PIMPL.PIMTYP = 3 Then
        Local File BPARTNER [BPR]
        Read [BPR]BPR0=this.OPPCMP
        If [F:BPR]BPCFLG <> [V]CST_AYES Then
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPPCMP", mess(983,2260,1), [V]CST_AERROR))
        Endif
      Endif
    Endif
  Endif
  If this.ASTALIN = [V]CST_AUPD Then
    If this.OPPCMP <> this.snapshot.OPPCMP Then
      #[L]ASTATUS = fmet this.SETERROR("OPPCMP", mess(18,9804,1), [V]CST_AERROR)
      # Not forbiden if the project... is not used somewhere
      IUSED = [V]CST_ANO
      # --------------------------------------------
      Local File BAPPOINT [BAP]
      Filter [BAP] Where pat([F:BAP]APTPJT, this.OPPNUM + "*") <> 0
      Look [F:BAP]First
      If !fstat Then
        IUSED = [V]CST_AYES
      Endif
      Filter [BAP]
      # --------------------------------------------
      If IUSED = [V]CST_ANO Then
        Local File PHONECALL [CLL]
        Filter [CLL] Where pat([F:CLL]CLLOPP, this.OPPNUM + "*") <> 0
        Look [F:CLL]First
        If !fstat Then
          IUSED = [V]CST_AYES
        Endif
        Filter [CLL]
      Endif
      # --------------------------------------------
      If IUSED = [V]CST_ANO Then
        Local File TASK [TSK]
        Filter [TSK] Where pat([F:TSK]TSKPJT, this.OPPNUM + "*") <> 0
        Look [F:TSK]First
        If !fstat Then
          IUSED = [V]CST_AYES
        Endif
        Filter [TSK]
      Endif
      # --------------------------------------------
      If IUSED = [V]CST_ANO Then
        Local File SERREQUEST [SRE]
        Filter [SRE] Where pat([F:SRE]SREPJT, this.OPPNUM + "*") <> 0
        Look [F:SRE]First
        If !fstat Then
          IUSED = [V]CST_AYES
        Endif
        Filter [SRE]
      Endif
      # --------------------------------------------
      If IUSED = [V]CST_ANO Then
        Local File CONTSERV [CON]
        Filter [CON] Where pat([F:CON]CONPJT, this.OPPNUM + "*") <> 0
        Look [F:CON]First
        If !fstat Then
          IUSED = [V]CST_AYES
        Endif
        Filter [CON]
      Endif
      # --------------------------------------------
      If IUSED = [V]CST_ANO Then
        Local File SQUOTED [SQD]
        Filter [SQD] Where pat([F:SQD]PJT, this.OPPNUM + "*") <> 0
        Look [F:SQD]First
        If !fstat Then
          IUSED = [V]CST_AYES
        Endif
        Filter [SQD]
      Endif
      # --------------------------------------------
      If IUSED = [V]CST_ANO Then
        Local File SORDERQ [SOQ]
        Filter [SOQ] Where pat([F:SOQ]PJT, this.OPPNUM + "*") <> 0
        Look [F:SOQ]First
        If !fstat Then
          IUSED = [V]CST_AYES
        Endif
        Filter [SOQ]
      Endif
      # --------------------------------------------
      If IUSED = [V]CST_ANO Then
        Local File SDELIVERYD [SDD]
        Filter [SDD] Where pat([F:SDD]PJT, this.OPPNUM + "*") <> 0
        Look [F:SDD]First
        If !fstat Then
          IUSED = [V]CST_AYES
        Endif
        Filter [SDD]
      Endif
      # --------------------------------------------
      If IUSED = [V]CST_ANO Then
        Local File SINVOICED [SID]
        Filter [SID] Where pat([F:SID]PJT, this.OPPNUM + "*") <> 0
        Look [F:SID]First
        If !fstat Then
          IUSED = [V]CST_AYES
        Endif
        Filter [SID]
      Endif
      # --------------------------------------------
      If IUSED = [V]CST_AYES Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPPCMP", mess(18,9804,1), [V]CST_AERROR))
      Endif
      # --------------------------------------------
    Endif
  Endif
Return

$OPPCMP_PROPAGATE
Local Integer NI
Local Integer NE   # Issue X3-107691 - 2018-10-15 by FGR

  If this.OPPCMP <> AVOID.ACHAR Then
    Local File BPARTNER [BPR]
    Local File BPCUSTOMER [BPC]
    # --------------------------------------------
    Read [BPR]BPR0=this.OPPCMP
    # --------------------------------------------
    # Définit l'interlocuteur par défaut de l'affaire
    this.OPPMCN = func CRMUTIL140_SYRA.GETDEFCNT(this.OPPCMP)
    # --------------------------------------------
    #Read [BPC]BPC0=this.OPPCMP
    #this.CUR = [F:BPC]CUR  # LSEY 27/07/2016 : currency is coming only from the company
    # --------------------------------------------
    If this.OPPREP = "" Then
      If [F:BPR]BPCFLG = [V]CST_AYES or [F:BPR]PPTFLG = [V]CST_AYES Then
        Read [BPC]BPC0=this.OPPCMP
        If !fstat Then
          If [F:BPC]REP(0) <> "" Then
            this.OPPREP = [F:BPC]REP(0)
          Else
            If [F:BPC]REP(1) <> "" Then
              this.OPPREP = [F:BPC]REP(1)
            Endif
          Endif
        Endif
      Endif
    Endif
   Endif
  # --------------------------------------------
  #If this.TCHISPJM = [V]CST_ATRUE Then                         # Issue X3-113257 - 2018-10-18 by FGR
  If this.TCHISPJM = [V]CST_ATRUE and this.PJM(1) <> null Then  # Issue X3-113257 - 2018-10-18 by FGR

    # Issue X3-113257 - 2018-10-18 by FGR : BEGIN moved into the "If this.TCHISPJM = [V]CST_ATRUE Then"
    # Issue X3-107691 - 2018-10-15 by FGR : BEGIN
    For NE = 1 To maxtab(this.PJM(1).SPLD)
      If this.PJM(1).SPLD(NE) <> null and find(this.PJM(1).SPLD(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        this.PJM(1).SPLD(NE).OPPCMP = this.OPPCMP
      Endif
    Next NE
    # Issue X3-107691 - 2018-10-15 by FGR : END
    # Issue X3-113257 - 2018-10-18 by FGR : END
    If this.PIMPL.PIMTYP = 2 or this.PIMPL.PIMTYP = 3 Then
      If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and this.OPPCMP <> this.snapshot.OPPCMP) Then
        [L]ASTATUS = fmet this.PJM_INIT_TECH_PROP()
        For NI = 1 To maxtab(this.PJM(1).TAS)
          If this.PJM(1).TAS(NI) <> null and find(this.PJM(1).TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            this.PJM(1).TAS(NI).OPPCMP = this.OPPCMP
            # Issue X3-107691 - 2018-10-15 by FGR : BEGIN
            For NE = 1 To maxtab(this.PJM(1).TAS(NI).SPLD)
              If this.PJM(1).TAS(NI).SPLD(NE) <> null and find(this.PJM(1).TAS(NI).SPLD(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
                this.PJM(1).TAS(NI).SPLD(NE).OPPCMP = this.OPPCMP
              Endif
            Next NE
            # Issue X3-107691 - 2018-10-15 by FGR : END
          Endif
        Next NI
        For NI = 1 To maxtab(this.PJM(1).BUD)
          If this.PJM(1).BUD(NI) <> null and find(this.PJM(1).BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            this.PJM(1).BUD(NI).OPPCMP = this.OPPCMP
            # Issue X3-107691 - 2018-10-15 by FGR : BEGIN
            For NE = 1 To maxtab(this.PJM(1).BUD(NI).SPLD)
              If this.PJM(1).BUD(NI).SPLD(NE) <> null and find(this.PJM(1).BUD(NI).SPLD(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
                this.PJM(1).BUD(NI).SPLD(NE).OPPCMP = this.OPPCMP
              Endif
            Next NE
            # Issue X3-107691 - 2018-10-15 by FGR : END
          Endif
        Next NI
      Endif
    Endif
  Endif
  # --------------------------------------------
Return

#######################################################################################
$OPPMCN
  Case [L]ARULE
    When "PROPAGATE" : Gosub OPPMCN_PROPAGATE
  Endcase
Return

# Issue X3-80586 - 2018-04-11 by FGR : BEGIN
$OPPMCN_PROPAGATE
  [L]ASTATUS = fmet this.COM_LOAD_OPPMCNNAM()
Return

