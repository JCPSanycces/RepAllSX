#######################################################################################
$CHGTYP
  Case [L]ARULE
    When "INIT"      : Gosub CHGTYP_INIT
    When "CONTROL"   : Gosub CHGTYP_CONTROL
    When "PROPAGATE" : Gosub CHGTYP_PROPAGATE
  Endcase
Return

$CHGTYP_INIT
  this.CHGTYP = 1
Return

$CHGTYP_CONTROL
  If this.ASTALIN = [V]CST_AUPD Then
    If this.CHGTYP <> this.snapshot.CHGTYP Then
      If this.TCHISPJM = [V]CST_ATRUE and this.PJM(1) <> null and fmet this.COM_IS_PJM_OPPOR() = [V]CST_ATRUE Then
        If fmet this.PJM(1).BUD_COUNT() > 0 or fmet this.PJM(1).TAS_COUNT() > 0 Then
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("CHGTYP", mess(515,2260,1), [V]CST_AERROR))
        Endif
      Endif
    Endif
  Endif
Return

$CHGTYP_PROPAGATE
  If this.CHGTYP <> this.snapshot.CHGTYP Then
    If this.TCHISPJM = [V]CST_ATRUE and this.PJM(1) <> null and fmet this.COM_IS_PJM_OPPOR() = [V]CST_ATRUE Then
      this.PJM(1).TCHCHGTYP = this.CHGTYP
    Endif
  Endif
Return

#######################################################################################
$OPPCLO
  Case [L]ARULE
    When "INIT"      : Gosub OPPCLO_INIT
  Endcase
Return

$OPPCLO_INIT
  this.OPPCLO = [V]CST_ANO
Return

#######################################################################################
$OPPTYP
  Case [L]ARULE
    When "INIT"      : Gosub OPPTYP_INIT
  Endcase
Return

$OPPTYP_INIT
  this.OPPTYP = func CRMUTIL140_SYRA.DEFVALADI(434)
Return

#######################################################################################
$OPPREP
  Case [L]ARULE
    When "INIT"      : Gosub OPPREP_INIT
    When "PROPAGATE" : Gosub OPPREP_PROPAGATE
  Endcase
Return

$OPPREP_INIT
  If fmet this.ACTX.APARAM.AGETUSERVALNUM("CRMREPOPP") = [V]CST_AYES Then
    Local File SALESREP [REP]
    Read [REP]REP1=this.ACTX.USER
    If !fstat Then
      this.OPPREP = [F:REP]REPNUM
    Endif
  Endif
Return

$OPPREP_PROPAGATE
  If this.OPPREP <> "" Then
    If this.CUR = "" Then
      Local File SALESREP [REP]
      Read [REP]REP0=this.OPPREP
      If !fstat Then
        this.CUR = [F:REP]CUR
      Endif
    Endif
  Endif
Return

#######################################################################################
$OPPDATOPN
  Case [L]ARULE
    When "INIT"      : Gosub OPPDATOPN_INIT
    When "PROPAGATE" : Gosub OPPDATOPN_PROPAGATE
  Endcase
Return

$OPPDATOPN_INIT
  this.OPPDATOPN = date$
Return

$OPPDATOPN_PROPAGATE
  If this.CRM(1) <> null Then
    this.CRM(1).OPPDATOPN = this.OPPDATOPN
  Endif
Return

#######################################################################################
$OPPORI
  Case [L]ARULE
    When "INIT"      : Gosub OPPORI_INIT
  Endcase
Return

$OPPORI_INIT
  this.OPPORI = 1
Return

#######################################################################################
$OPPORITYP
  Case [L]ARULE
    When "INIT"      : Gosub OPPORITYP_INIT
  Endcase
Return

$OPPORITYP_INIT
  If this.TCHIMPORT = [V]CST_AYES Then
    this.OPPORITYP = 4
  Else
    this.OPPORITYP = 1
  Endif
Return

#######################################################################################
$PJM_OPPSTATE
  # Issue X3-107401 - 2018-09-06 by FGR
  Case [L]ARULE
    When "PROPAGATE" : Gosub PJM_OPPSTATE_PROPAGATE
  Endcase
Return

$PJM_OPPSTATE_PROPAGATE
  # Issue X3-107401 - 2018-09-06 by FGR
  Case this.TCHACTION
    When AVOID.ACHAR
      If this.ASTALIN = [V]CST_ANEW Then
        If this.APARENT.ASTALIN = [V]CST_AUPD Then
          # Issue X3-110479 - 2018-10-09 by FGR
          If this.APARENT.PIMPL.TCHACTION = "STATUS" Then
            this.APARENT.PIMPL.OPPSTATE = this.OPPSTATE
          Endif
        Else
          If this.OPPSTATE = 2 Then
            If fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, this.SALFCY, "PJMDEFSTA") = 2 Then
              this.OPPDATLA = date$
              #
              this.APARENT.PIMPL.TCHACTION = "STATUS"
              this.APARENT.PIMPL.PIMSTA = [V]CST_AYES
              this.APARENT.PIMPL.OPPSTATE = this.OPPSTATE
            Endif
          Endif
        Endif
      Endif
  Endcase
Return

