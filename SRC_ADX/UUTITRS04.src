#<AdxTL>@(#)1.0.0.0 $Revision$
########################################################################################
# UUTITRS04   Utilitaire de suppression de la table TMPFUP01             Module Tiers  #
#             La table TMPFUP01 n'est plus utilisée et peut être supprimée             #
########################################################################################

Local Char APPLI(30) : APPLI = nomap
Call SAIDOS(APPLI,"") From SAIDOS
If APPLI <> ""
 If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
 Read [ADS]DOSSIER=[L]APPLI : If fstat Raz [F:ADS] : Endif

 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UUTITRS04: TMPFUP01 table deletion") From LECFIC

 Call MAJ_UTITRS04(APPLI) 
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTITRS04(APPLI)
Value Char APPLI
Local Integer STAT
Local Char    SUF(10), FICTRT(GDIMFIC), DOSHISTO(GLONADS), CODE(10)

[L]CODE = "TMPFUP01"


# test du code activité
If func AFNC.ACTIV("FUP")=0 : End : Endif

# test de présence de la table
If filinfo(filpath("FIL",[L]CODE,"fde",APPLI),0)<=0 : End : Endif

Call ECR_TRACE("UUTITRS04: Process Start on : "+APPLI,0) From GESECRAN

Local File =APPLI+".ATABLE"  [ATB]
Local File =APPLI+".ATABZON" [ATZ]
Local File =APPLI+".AMSKPAR" [AMP]
Local File =APPLI+".ATABIND" [ATI]

Trbegin [ATB]
 Delete [ATB] Where CODFIC=[L]CODE
 If fstat=1  : GOK=-1 : Call RSTA("ATB",[L]CODE) From GLOCK : End : Endif
 Delete [ATZ] Where CODFIC=[L]CODE
 If fstat=1  : GOK=-1 : Call RSTA("ATZ",[L]CODE) From GLOCK : End : Endif
 Delete [ATI] Where CODFIC=[L]CODE
 If fstat=1  : GOK=-1 : Call RSTA("ATI",[L]CODE) From GLOCK : End : Endif
 Delete [AMP] Where TYPAFF=2 & CODAFF=[L]CODE
 If fstat=1  : GOK=-1 : Call RSTA("AMP","2"+[L]CODE) From GLOCK : End : Endif

 Call SYSTEME(adxmac(0),"valfil -n"-APPLI-[L]CODE,"",STAT) From ORDSYS
 Call SYSTEME(adxmac(0),"valfil -d"-APPLI-[L]CODE,"",STAT) From ORDSYS
 For SUF = "srf", "fde", "dat", "idx" , "cfg"
  FICTRT = filpath("FIL",[L]CODE,SUF,APPLI)
  If filinfo(FICTRT,0)>=0
   Call EFFACE(FICTRT,STAT) From ORDSYS
  Endif
 Next SUF
 DOSHISTO = func DOSCONT.HISTO(APPLI)
 If DOSHISTO<>"" & filinfo(filpath("FIL",[L]CODE,"fde",DOSHISTO),0)>0
  Call SYSTEME(adxmac(0),"valfil -n"-DOSHISTO-[L]CODE,"",STAT) From ORDSYS
  Call SYSTEME(adxmac(0),"valfil -d"-DOSHISTO-[L]CODE,"",STAT) From ORDSYS
  For SUF = "srf", "fde", "viw"
   FICTRT = filpath("FIL",[L]CODE,SUF,DOSHISTO)
   If filinfo(FICTRT,0)>=0
    Call EFFACE(FICTRT,STAT) From ORDSYS
   Endif
  Next SUF
 Endif
Commit
Call ECR_TRACE("UUTITRS04: Process End on : "+APPLI,0) From GESECRAN
End

########################################################################
# Pour exécution automatique en gestion de patch                       #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI
# pas de modification dans le dossier mère
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

# test de présence du module Tiers
If [F:ADS]MODULE(2)<>2 : End : Endif
Call MAJ_UTITRS04(APPLI)
End

########################################################################
# Pour exécution depuis dosmaj (validation dossier)                    #
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI
# pas de modification dans le dossier mère
If APPLI="X3" End : Endif

# test de présence du module Tiers
If [F:ADS]MODULE(2)<>2 : End : Endif
Call MAJ_UTITRS04(APPLI)
End
