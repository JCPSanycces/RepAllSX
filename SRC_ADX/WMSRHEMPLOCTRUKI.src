ASTDKEY = ""
ASTDKEY += "[F:CTRUKI]REFNUM"
ASTDKEY += ";[F:CTRUKI]CTRNUM"
ASTDKEY += ";[F:CTRUKI]CTRDAT"
ACTION = "ASEARCH_PRIMARYKEYS_AFTER" : Gosub ASEARCH_ACTION
