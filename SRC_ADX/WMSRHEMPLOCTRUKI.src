#---------------------------------------------------------------------------------------------------#
# List of tables to open
#---------------------------------------------------------------------------------------------------#
$ASEARCH_OPEN
If filinfo(filpath("FIL","EMPLOCTRUKI","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File EMPLOCTRUKI [CTRUKI]
Local File EMPLOCTRUKI [CTRUKI_]
Local Char KEY_CTRUKI(120)(1..3)
ACTION = "ASEARCH_OPEN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to close
#---------------------------------------------------------------------------------------------------#
$ASEARCH_CLOSE
LogicClose File [CTRUKI]
LogicClose File [CTRUKI_]
ACTION = "ASEARCH_CLOSE_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to join
#---------------------------------------------------------------------------------------------------#
$ASEARCH_JOIN
Link [CTRUKI] With
& [CTRUKI_]CTRUKI0=[CTRUKI]REFNUM;[CTRUKI]CTRNUM;[CTRUKI]CTRDAT
& As [LNK_]
& Where (1=1
& )
ACTION = "ASEARCH_JOIN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to join
#---------------------------------------------------------------------------------------------------#
$ASEARCH_JOIN_INC
Link [CTRUKI] With
& [CTRUKI_]CTRUKI0=[CTRUKI]REFNUM;[CTRUKI]CTRNUM;[CTRUKI]CTRDAT
& As [LNK_]
& Where (UPDDATTIM > gdatetime$(QUPDDATTIM)
& )
ACTION = "ASEARCH_JOIN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# Create an instance of
#---------------------------------------------------------------------------------------------------#
$ASEARCH_CREATEINSTANCE
Local Integer ASTATUS
Local Integer FINS
#Create a new instance
INS = NewInstance C_EMPLOCTRUKI(GACTX,UIDINS,NUMLIN,null,"") AllocGroup null
INS.setaccessorEnabled = 0
Local Integer CI1
Local Integer CJ1
Local Char    SEPINS1(2) : SEPINS1=""
Local Char IS1(1)

Local Integer UKADD_MAXI:UKADD_MAXI= 0
If dim([F:CTRUKI]ADDLIN1)>0
    If UKADD_MAXI = 0
        UKADD_MAXI = dim([F:CTRUKI]ADDLIN1)
    Else
        UKADD_MAXI = min(UKADD_MAXI,dim([F:CTRUKI]ADDLIN1))
    Endif
Endif
If dim([F:CTRUKI]ADDLIN2)>0
    If UKADD_MAXI = 0
        UKADD_MAXI = dim([F:CTRUKI]ADDLIN2)
    Else
        UKADD_MAXI = min(UKADD_MAXI,dim([F:CTRUKI]ADDLIN2))
    Endif
Endif
If dim([F:CTRUKI]TWN)>0
    If UKADD_MAXI = 0
        UKADD_MAXI = dim([F:CTRUKI]TWN)
    Else
        UKADD_MAXI = min(UKADD_MAXI,dim([F:CTRUKI]TWN))
    Endif
Endif
If dim([F:CTRUKI]CUY)>0
    If UKADD_MAXI = 0
        UKADD_MAXI = dim([F:CTRUKI]CUY)
    Else
        UKADD_MAXI = min(UKADD_MAXI,dim([F:CTRUKI]CUY))
    Endif
Endif
If dim([F:CTRUKI]POS)>0
    If UKADD_MAXI = 0
        UKADD_MAXI = dim([F:CTRUKI]POS)
    Else
        UKADD_MAXI = min(UKADD_MAXI,dim([F:CTRUKI]POS))
    Endif
Endif
If dim([F:CTRUKI]TEL)>0
    If UKADD_MAXI = 0
        UKADD_MAXI = dim([F:CTRUKI]TEL)
    Else
        UKADD_MAXI = min(UKADD_MAXI,dim([F:CTRUKI]TEL))
    Endif
Endif
If dim([F:CTRUKI]EML)>0
    If UKADD_MAXI = 0
        UKADD_MAXI = dim([F:CTRUKI]EML)
    Else
        UKADD_MAXI = min(UKADD_MAXI,dim([F:CTRUKI]EML))
    Endif
Endif
If dim([F:CTRUKI]MOB)>0
    If UKADD_MAXI = 0
        UKADD_MAXI = dim([F:CTRUKI]MOB)
    Else
        UKADD_MAXI = min(UKADD_MAXI,dim([F:CTRUKI]MOB))
    Endif
Endif
If dim([F:CTRUKI]WRKMOB)>0
    If UKADD_MAXI = 0
        UKADD_MAXI = dim([F:CTRUKI]WRKMOB)
    Else
        UKADD_MAXI = min(UKADD_MAXI,dim([F:CTRUKI]WRKMOB))
    Endif
Endif
CJ1=1
For CI1 = 0 To UKADD_MAXI-1
#Create a new instance
INS.UKADD(CJ1) = NewInstance C_EMPLOCTRUKI_UKADD(GACTX,UIDINS,NUMLIN,INS,"") AllocGroup INS
INS.UKADD(CJ1).setaccessorEnabled = 0
 CJ1+=1
Next CI1
Return

#---------------------------------------------------------------------------------------------------#
# Set an instance
#---------------------------------------------------------------------------------------------------#
$ASEARCH_SETINSTANCE

SetInstance INS With [F:CTRUKI]
FINS = 1
Local Integer UKADD_MAXI:UKADD_MAXI= 0
Local Integer UKADD_MAX:UKADD_MAX=0
If dim([F:CTRUKI]ADDLIN1)>0
    If UKADD_MAXI = 0
        UKADD_MAXI = dim([F:CTRUKI]ADDLIN1)
    Else
        UKADD_MAXI = min(UKADD_MAXI,dim([F:CTRUKI]ADDLIN1))
    Endif
Endif
If dim([F:CTRUKI]ADDLIN2)>0
    If UKADD_MAXI = 0
        UKADD_MAXI = dim([F:CTRUKI]ADDLIN2)
    Else
        UKADD_MAXI = min(UKADD_MAXI,dim([F:CTRUKI]ADDLIN2))
    Endif
Endif
If dim([F:CTRUKI]TWN)>0
    If UKADD_MAXI = 0
        UKADD_MAXI = dim([F:CTRUKI]TWN)
    Else
        UKADD_MAXI = min(UKADD_MAXI,dim([F:CTRUKI]TWN))
    Endif
Endif
If dim([F:CTRUKI]CUY)>0
    If UKADD_MAXI = 0
        UKADD_MAXI = dim([F:CTRUKI]CUY)
    Else
        UKADD_MAXI = min(UKADD_MAXI,dim([F:CTRUKI]CUY))
    Endif
Endif
If dim([F:CTRUKI]POS)>0
    If UKADD_MAXI = 0
        UKADD_MAXI = dim([F:CTRUKI]POS)
    Else
        UKADD_MAXI = min(UKADD_MAXI,dim([F:CTRUKI]POS))
    Endif
Endif
If dim([F:CTRUKI]TEL)>0
    If UKADD_MAXI = 0
        UKADD_MAXI = dim([F:CTRUKI]TEL)
    Else
        UKADD_MAXI = min(UKADD_MAXI,dim([F:CTRUKI]TEL))
    Endif
Endif
If dim([F:CTRUKI]EML)>0
    If UKADD_MAXI = 0
        UKADD_MAXI = dim([F:CTRUKI]EML)
    Else
        UKADD_MAXI = min(UKADD_MAXI,dim([F:CTRUKI]EML))
    Endif
Endif
If dim([F:CTRUKI]MOB)>0
    If UKADD_MAXI = 0
        UKADD_MAXI = dim([F:CTRUKI]MOB)
    Else
        UKADD_MAXI = min(UKADD_MAXI,dim([F:CTRUKI]MOB))
    Endif
Endif
If dim([F:CTRUKI]WRKMOB)>0
    If UKADD_MAXI = 0
        UKADD_MAXI = dim([F:CTRUKI]WRKMOB)
    Else
        UKADD_MAXI = min(UKADD_MAXI,dim([F:CTRUKI]WRKMOB))
    Endif
Endif
CJ1=1
For CI1 = 0 To UKADD_MAXI-1
 Break ([F:CTRUKI]ADDLIN1(CI1)="" & [F:CTRUKI]ADDLIN2(CI1)="" & [F:CTRUKI]TWN(CI1)="" & [F:CTRUKI]CUY(CI1)="" & [F:CTRUKI]POS(CI1)="" & [F:CTRUKI]TEL(CI1)="" & [F:CTRUKI]EML(CI1)="" & [F:CTRUKI]MOB(CI1)="" & [F:CTRUKI]WRKMOB(CI1)="")
 UKADD_MAX+=1
 INS.UKADD(CJ1).ADDLIN1=[F:CTRUKI]ADDLIN1(CI1)
 INS.UKADD(CJ1).ADDLIN2=[F:CTRUKI]ADDLIN2(CI1)
 INS.UKADD(CJ1).TWN=[F:CTRUKI]TWN(CI1)
 INS.UKADD(CJ1).CUY=[F:CTRUKI]CUY(CI1)
 INS.UKADD(CJ1).POS=[F:CTRUKI]POS(CI1)
 INS.UKADD(CJ1).TEL=[F:CTRUKI]TEL(CI1)
 INS.UKADD(CJ1).EML=[F:CTRUKI]EML(CI1)
 INS.UKADD(CJ1).MOB=[F:CTRUKI]MOB(CI1)
 INS.UKADD(CJ1).WRKMOB=[F:CTRUKI]WRKMOB(CI1)
 CJ1+=1
Next CI1
[L]ASTATUS = fmet INS.ACTION("ASEARCH_TRANS_AFTER")
Gosub ASEARCH_TO_JSON
Return

#---------------------------------------------------------------------------------------------------#
# Serialize the entity in a JSON format
#---------------------------------------------------------------------------------------------------#
$ASEARCH_TO_JSON
If FINS=0 : Return : Endif
QCOUNT += 1
Onerrgo ERROR_VALUE
Append ASND.DATA ,SEPINS1
SEPINS1 = ','+chr$(10)
Append ASND.DATA ,'{'
Append ASND.DATA ,'"CTRNUM":'          +'"'+escJson(INS.CTRNUM)+'"'
Append ASND.DATA ,',"REFNUM":'         +'"'+escJson(INS.REFNUM)+'"'
Append ASND.DATA ,',"CTRDAT":'          + func ASYRSRH.DATE_TO_SYR(INS.CTRDAT)
Append ASND.DATA ,',"NINNUM":'         +'"'+escJson(INS.NINNUM)+'"'
IS1=""
CJ1=1
Append ASND.DATA ,',"UKADD":['
For CI1=1 To UKADD_MAX
 Append ASND.DATA ,IS1+'{'
 Append ASND.DATA ,'"ADDLIN1":'         +'"'+escJson(INS.UKADD(CJ1).ADDLIN1)+'"'
 Append ASND.DATA ,',"ADDLIN2":'        +'"'+escJson(INS.UKADD(CJ1).ADDLIN2)+'"'
 Append ASND.DATA ,',"TWN":'            +'"'+escJson(INS.UKADD(CJ1).TWN)+'"'
 Append ASND.DATA ,',"CUY":'            +'"'+escJson(INS.UKADD(CJ1).CUY)+'"'
 Append ASND.DATA ,',"POS":'            +'"'+escJson(INS.UKADD(CJ1).POS)+'"'
 Append ASND.DATA ,',"TEL":'            +'"'+escJson(INS.UKADD(CJ1).TEL)+'"'
 Append ASND.DATA ,',"EML":'            +'"'+escJson(INS.UKADD(CJ1).EML)+'"'
 Append ASND.DATA ,',"MOB":'            +'"'+escJson(INS.UKADD(CJ1).MOB)+'"'
 Append ASND.DATA ,',"WRKMOB":'         +'"'+escJson(INS.UKADD(CJ1).WRKMOB)+'"'
 Append ASND.DATA ,'}'
 IS1=","
 CJ1+=1
Next CI1
Append ASND.DATA , "]"
Append ASND.DATA ,'}'
Onerrgo
FINS = 0
Return

#---------------------------------------------------------------------------------------------------#
# Errors
#---------------------------------------------------------------------------------------------------#
$ERROR_VALUE
SVALUE ='"<error'-errmes$(errn)+'>"'
Resume
#---------------------------------------------------------------------------------------------------#
