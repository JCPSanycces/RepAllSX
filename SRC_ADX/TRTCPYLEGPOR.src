#<AdxTL>@(#)5.0.0.0 $Revision$
######################################################################################
######################################################################################
#
#  Legal Portugal data for table COMPANY
#
# Window AWI=>CPYLEGPOR
# Mask/Screen AMK=>CPYLEGPOR [CLPOR]
#
######################################################################################
######################################################################################
$ACTION

Case ACTION
  When "OUVRE"         : Gosub OUVRE
  When "DEBUT"         : Gosub DEBUT
  When "APRES_MODIF"   : Gosub APRES_MODIF
  When "ENR"           : Gosub ENR
  When "ABA"           : Gosub ABA
  When "FIN"           : Gosub FIN
Endcase

Return
######################################################################################
######################################################################################
$OUVRE

#----- Paramètres de l'action DATALEG -----#
Local Char LEG(GLONADI)
Local Char COD(max(GLONCPY,GLONVAT,5))

[L]LEG = PARAM(1)
[L]COD = PARAM(2)

#----- Tables utilisée -----#
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
If !clalev([F:ALK]) : Local File APLLCK [ALK] : Endif
If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif

#----- Masque local -----#
Local Mask CPYLEGPOR [CLPOR]

#----- Variables locales pour sauvegarde du masque -----#
Local Char PORCPYACT(GLONADI)
Local Integer PORHQR
Local Char PORFINDPR(9)
Local Char PORLRC(9)
Local Char PORCTFACN(9)
# Issue 116164 - 2016-07-13 by RICAR : POR: Company legal data
# Issue 116164
Local Char PORRESFISCDA(5)
# End issue 116164
Local Integer PORDCLPER

# Issue 110700 - 2016-04-14 by RICAR : Electronic invoices: connect with Sage component
# Issue 110700
Local Integer EFAT_ACTIVE
If func AFNC.ACTIV("EFAT")
  Local Integer COMMTYPE(9)
  Local Date STRDAT(9), ENDDAT(9)
  Local Integer J
  [L]EFAT_ACTIVE = 2
Endif
# End issue 110700

Return
######################################################################################
######################################################################################
$DEBUT

#--- Alimentation des champs de l'écran ---#
Local Libelle TYPLEDGEN,TYPLEDANA
Local Char CODLED(GLONLED),CURLED(GLONCUR)

Call LEC_CPY([L]COD) From CPTLEC
If !fstat
  [M:CLPOR] = [F:CPY]
# Issue 110700 - 2016-04-14 by RICAR : Electronic invoices: connect with Sage component
# Issue 110700
  If [L]EFAT_ACTIVE = 2
    [M:CLPOR]NBCFE = find(0,[F:CPY]COMMTYPE)-1
    If [F:CPY]COMMTYPE(0) = 0 #& [M:CLPOR]NBCFE = 0
      [M:CLPOR]COMMTYPE(0) = 1
      [M:CLPOR]STRDAT(0)   = [01/01/2012]
      [M:CLPOR]ENDDAT(0)   = [31/12/9999]
      [M:CLPOR]NBCFE       = 1
    Endif
    Affzo [M:CLPOR]COMMTYPE(0),STRDAT(0),ENDDAT(0), NBCFE
  Endif
# End issue 110700
Endif

#--- Sauvegarde des valeurs initiales du masque ---#
[L]=[M:CLPOR]

Affzo [M:CLPOR]

# Issue 110700 - 2016-04-14 by RICAR : Electronic invoices: connect with Sage component
# Issue 110700
[F:CPY]LEG = PARAM(1)
# End issue 110700

#85803 RICAR 2014/05/26 - Portuguese legal requirements - BEGIN
Gosub ENABLE_PORSIMINVISS_FIELDS
#85803 RICAR 2014/05/26 - Portuguese legal requirements - END
Return
######################################################################################
######################################################################################
$ENR

Trbegin [CPY]
Readlock [CPY]CPY0 = [L]COD
If !fstat
  If [L]EFAT_ACTIVE = 2 & [M:CLPOR]NBCFE > 0
    [M:CLPOR]ENDDAT([M:CLPOR]NBCFE-1) = [0/0/0]
    Affzo [M:CLPOR]ENDDAT([M:CLPOR]NBCFE-1)
  Endif
  [F:CPY] = [M:CLPOR]
  Rewrite [CPY]
  If fstat
    GOK = 0 : Call FSTA("CPY") From GLOCK : Return
  Endif
Endif
Commit
[L]=[M:CLPOR] : REP=""

Return
######################################################################################
######################################################################################
$ABA

[M:CLPOR]=[L]
REP=""
#Gosub ENR
Affzo [M:CLPOR]

Return
######################################################################################
######################################################################################
$APRES_MODIF

Read [ALK]LCKCLE="CPY"+[L]COD;0
If !fstat & [F:ALK]LCKPID<>adxuid(2)
  GMESSAGE=mess(10,100,1)
  GERR=1
  [M:CLPOR]=[L]
  Affzo [M:CLPOR] :# FIN=1
Else
  REP = "M"
  Local Char SYMB(20)
  SYMB="CPY"+[L]COD
  Lock SYMB With lockwait=0
Endif

Return
######################################################################################
######################################################################################
$FIN

If dim(SYMB)>0
  Unlock SYMB
Endif

Return
######################################################################################
######################################################################################
$ENABLE_PORSIMINVISS_FIELDS

#85803 RICAR 2014/05/26 - Portuguese legal requirements - BEGIN
If [M:CLPOR]PORSIMINVISS <> 2
  Grizo [M:CLPOR]PORAMTITMINV,PORAMTSERINV
Else
  Actzo [M:CLPOR]PORAMTITMINV,PORAMTSERINV
Endif
#85803 RICAR 2014/05/26 - Portuguese legal requirements - END

Return
######################################################################################
######################################################################################
Subprog AS_PORDCLPER(VALEUR)
Variable Integer VALEUR

#--------------------------#
# Avant saisie périodicité #
#--------------------------#

GMENLOC(1)=1 : # Jour
GMENLOC(2)=1 : # Semaine
GMENLOC(3)=0 : # Mois       Ok
GMENLOC(4)=0 : # Trimestre  Ok
GMENLOC(5)=1 : # Année

End
######################################################################################
######################################################################################
Subprog AS_PORHQR(VALEUR)
Variable Integer VALEUR

GMENLOC(1)=0 : # Mainland      OK
GMENLOC(2)=0 : # Azores        OK
GMENLOC(3)=0 : # Madeira       OK
GMENLOC(4)=1 : # Non applicable

End
######################################################################################
######################################################################################
######################################################################################
## Section automatically added (screen CPYLEGPOR) 05/26/2014 12:22:03 (RICAR)
######################################################################################
Subprog C_PORSIMINVISS(VALEUR)
Variable Integer VALEUR

#85803 RICAR 2014/05/26 - Portuguese legal requirements - BEGIN
If VALEUR <> 2
  Grizo [M:CLPOR]PORAMTITMINV,PORAMTSERINV
Else
  Actzo [M:CLPOR]PORAMTITMINV,PORAMTSERINV
Endif
#85803 RICAR 2014/05/26 - Portuguese legal requirements - END

End


######################################################################################
######################################################################################
## Section automatically added (screen CPYLEGPOR) 11/05/2014 16:18:15 (RICAR)
######################################################################################
Subprog C_PORRESFISCDA(VALEUR)
Variable Char    VALEUR()

# Issue 116164 - 2016-07-13 by RICAR : POR: Company legal data
# Issue 116164
# Issue 121342 - 2017-02-07 by RMA : only if valuer <> "" because field is not mandatory
If VALEUR <> ""
  Look [CPY]CPY0 = VALEUR
  If fstat
    GMESSAGE = mess(132,100,1)
    mkstat = 2 : End
  Endif
Endif
# End issue 116164

#85803 RICAR 2014/05/26 - Portuguese legal requirements - BEGIN
If VALEUR = [M:CPY0]CPY
  GMESSAGE = mess(147,7711,1)
  mkstat = 2 : End
Endif
#85803 RICAR 2014/05/26 - Portuguese legal requirements - END

End
######################################################################################
## Section automatically added (screen CPYLEGPOR) 04/14/2016 15:54:52 (RICAR)
######################################################################################
Subprog C_COMMTYPE(VALEUR)
Variable Integer VALEUR

# Issue 110700 - 2016-04-14 by RICAR : Electronic invoices: connect with Sage component
# Issue 110700
Local Integer V_NOL : V_NOL = nolign-2

# The first record must be SAFT
If nolign-1 = 0
  If VALEUR <> 1
    Call ECR_TRACE(mess(207,7711,1),1) From GESECRAN
    mkstat = 2 : End
  Endif
Endif

If nolign-2 >= 0
  If [M:CLPOR]COMMTYPE(nolign-2)=VALEUR
    Call ECR_TRACE(mess(205,7711,1),1) From GESECRAN
    mkstat = 2 : End
  Endif
  If [M:CLPOR]ENDDAT(nolign-2)=[0/0/0]
    Call ECR_TRACE(mess(233,7711,1),1) From GESECRAN
    mkstat = 2 : End
  Endif
Endif
# End issue 110700

End
######################################################################################
######################################################################################
## Section automatically added (screen CPYLEGPOR) 04/14/2016 18:20:03 (RICAR)
######################################################################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR

# ISSUE 110700 - 2016-04-14 By RICAR : ELECTRONIC INVOICES: CONNECT With SAGE COMPONENT
# Issue 110700
If nolign-2 >= 0 & VALEUR <> [00/00/00]
  If [M:CLPOR]ENDDAT(nolign-2) >= VALEUR
    Call ECR_TRACE(mess(206,7711,1),1) From GESECRAN
    mkstat = 2
    End
  Endif
  If [M:CLPOR]STRDAT(nolign-2) <> [00/00/00] & [M:CLPOR]ENDDAT(nolign-2) = [00/00/00] & VALEUR <= [M:CLPOR]STRDAT(nolign-2)
    Call ECR_TRACE(mess(229,7711,1),1) From GESECRAN
    mkstat = 2
    End
  Endif
Endif

If (day(VALEUR) <> 31 & month(VALEUR) <> 12)
  Call ECR_TRACE(mess(208,7711,1),1) From GESECRAN
  mkstat = 2
  End
Endif

[M:CLPOR]STRDAT(nolign) = VALEUR + 1
Affzo [M:CLPOR]STRDAT(nolign)
# End issue 110700

End
######################################################################################
## Section automatically added (screen CPYLEGPOR) 09/02/2016 18:39:23 (RMA)
######################################################################################
Subprog C_NBCFE

If status = 65 & nolign < [M:CLPOR]NBCFE
    Call ECR_TRACE(mess(234,7711,1),1) From GESECRAN
    mkstat = 2 : End
Endif

End
######################################################################################
######################################################################################

