##########################################################################################################
Subprog IB_NBREC
  # FGR 13/05/2009 : X3SUIVI50196 : La navigation ne fontionnait pas !
  If [M:CRM9]TYPESEARCH = "AIN" Then
    [M:CRM9]CCNKEY = [M:CRM9]CODE(nolign-1)
    [M:CRM9]BPRKEY = ""
  Else
    [M:CRM9]CCNKEY = ""
    [M:CRM9]BPRKEY = [M:CRM9]CODE(nolign-1)
  Endif
  # FGR 13/05/2009 : X3SUIVI50196
  Raz [M:CRM9]TIERS
  If [M:CRM9]TYPESEARCH = "AIN" Then
    Filter [CNT] Where BPATYP = 1 and CCNCRM = [M:CRM9]CODE(nolign-1)
    For [CNT]
      If [M:CRM9]TIERS <> "" Then
        [M:CRM9]TIERS = [M:CRM9]TIERS + ","
      Endif
      [M:CRM9]TIERS = [M:CRM9]TIERS +  "'" + [F:CNT]BPANUM + "'"
    Next
    Filter [CNT]
    If [M:CRM9]TIERS <> "" Then
      Affzo [M:CRM9]TIERS
    Else
      Raz GBOUT2
    Endif
  Else
    Raz GBOUT2
  Endif
  Raz GBOUT4
  Raz GBOUT5
  Raz GBOUT6
  #Historique Tiers
  If [M:CRM9]BPRNUM(nolign-1) <> "" and [M:CRM9]CCNNUM(nolign-1) = "" Then
    Call TEXTE(11932, GBOUT4) From OBJDIV
  Endif
  #Historique Interlocuteur
  If [M:CRM9]BPRNUM(nolign-1) = "" and [M:CRM9]CCNNUM(nolign-1) <> "" Then
    Call TEXTE(11932, GBOUT5) From OBJDIV
  Endif
  #Parc
  If GMODU(12) = 2 Then
    Call TEXTE(16568, GBOUT6) From OBJDIV
  Endif
End

##########################################################################################################
Subprog B2_NBREC
  Gosub ONLOAD From TRTCRM9
  Affzo [M:CRM9]15
End

##########################################################################################################
$RAZBPR
  Raz [M:CRM9]BPRNAM
  Raz [M:CRM9]BPRZIP
  Raz [M:CRM9]BPRCTY
  Raz [M:CRM9]BPRADEDEF
  [M:CRM9]TYPESEARCH = "AIN"
  #
  Affzo [M:CRM9]BPRNAM
  Affzo [M:CRM9]BPRZIP
  Affzo [M:CRM9]BPRCTY
  Affzo [M:CRM9]BPRADEDEF
Return

##########################################################################################################
$RAZAIN
  Raz [M:CRM9]CCNLNA
  Raz [M:CRM9]CCNFNA
  Raz [M:CRM9]TELFAXMOB       # FGR 13/05/2009 : X3SUIVI50196
  [M:CRM9]TYPESEARCH = "BPR"
  Affzo [M:CRM9]CCNLNA
  Affzo [M:CRM9]CCNFNA
  Affzo [M:CRM9]TELFAXMOB     # FGR 13/05/2009 : X3SUIVI50196
Return
