#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################
# Program Name: TRTITH
# Description : Products usage
# Date        : 04/20/2015
####################################################################################

$ACTION

Case ACTION
  When "OUVRE" : Gosub OUVRE
  When "DEBUT" : Gosub DEBUT
Endcase

Return

####################################################################################
$OUVRE
If !clalev([F:ITH]) : Local File ITMMVTHIS  : Endif
If !clalev([F:ITM]) : Local File ITMMASTER  : Endif
If !clalev([F:ITF]) : Local File ITMFACILIT : Endif
If !clalev([F:ITC]) : Local File ITMCOST    : Endif

Read [ITM]ITM0 = PARAM(1)
If fstat GERR = 1 : GMESSAGE = mess(134,100,1) : FIN = 1 : Return Endif

Read [ITF]ITF0 = PARAM(1); PARAM(2)
If fstat GERR = 1 : GMESSAGE = mess(25,192,1) : FIN = 1 : Return Endif

Read [ITC]ITC0(4) = [F:ITF]STOFCY ; [F:ITF]ITMREF ; 1 ; year(date$)
If fstat Raz [F:ITC] Endif

Return

####################################################################################
$DEBUT

Raz [M:ITH]

[M:ITH]STOFCY     = [F:ITF]STOFCY
[M:ITH]ITMREF     = [F:ITM]ITMREF
[M:ITH]TCLCOD     = [F:ITM]TCLCOD
[M:ITH]STU        = [F:ITM]STU
[M:ITH]ABCCLS     = [F:ITF]ABCCLS
[M:ITH]REOMGTCOD  = [F:ITF]REOMGTCOD
[M:ITH]SAFSTO     = [F:ITF]SAFSTO
[M:ITH]REOMINQTY  = [F:ITF]REOMINQTY
[M:ITH]MFGLOTQTY  = [F:ITF]MFGLOTQTY
[M:ITH]REOTSD     = [F:ITF]REOTSD
[M:ITH]PURBASPRI  = [F:ITM]PURBASPRI
[M:ITH]CUR        = GSYSCUR

Gosub LOAD_LINES

Return

####################################################################################
$LOAD_LINES
Local Date D : D = gdat$(1, month(date$), year(date$))
Local Decimal LEAP
Local Integer J, T, M, Y
Local Decimal MONISSQTY

For Y = 0 To 2
  For M = 12 To 1 Step -1
    Assign('[M:ITH]YRMIN' + num$(Y) + '(M - 1)') With format$('D:MM[-]YYYY', D)

    J=month(D)       # Month of current record
    LEAP=mod(year(D),4)

    If find(J,09,04,06,11) : T=30 : Elsif J=02 : T=28 : Else T=31 : Endif
    If LEAP=0 & J=02 : T=29 : Endif

    For [ITH] Where ITMREF=[F:ITF]ITMREF & STOFCY=[F:ITF]STOFCY & PERSTR>=D & PERSTR < D + T
      [L]MONISSQTY += [F:ITH]MONISSQTY
    Next

    Assign('[M:ITH]USEMIN' + num$(Y) + '(M - 1)') With [L]MONISSQTY
    D = addmonth(D, -1)
    Raz K, [L]MONISSQTY
  Next
Next

[M:ITH]NBLIG  = 13 : [M:ITH]YRMIN2(12) = mess(52,103,1) : [M:ITH]USEMIN2(12) = sum([M:ITH]USEMIN2)
[M:ITH]NBLIG2 = 13 : [M:ITH]YRMIN1(12) = mess(52,103,1) : [M:ITH]USEMIN1(12) = sum([M:ITH]USEMIN1)
[M:ITH]NBLIG3 = 13 : [M:ITH]YRMIN0(12) = mess(52,103,1) : [M:ITH]USEMIN0(12) = sum([M:ITH]USEMIN0)

Affzo [M:ITH]

Return
####################################################################################

