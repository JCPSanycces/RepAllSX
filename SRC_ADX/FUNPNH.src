#<AdxTL>@(#)1.0.0.0 $Revision$
########################################################################
# FUNPNH          Gestion des avoirs à recevoir         MBT 18/11/2004 #
# -------------------------------------------------------------------- #
# GLOCALDEV = devise societe         GSYSCUR = devise dossier          #
# GFINRSP   = site financier                                           #
# -------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement standard GTRAITE)               #
#   - TRTFUNPNH2: Fonction de gestion des avoirs à recevoir            #
########################################################################


$ACTION
#---------------------------------------------------------#
# Actions sur le traitement standard (GTRAITE)            #
# TRTFUNPNH2  : Fonction de gestion des avoirs à recevoir #
#---------------------------------------------------------#
Case ACTION
 When "OUVRE_BATCH" : Gosub OUVRE
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When "OK"          : FIN=1 : GOK=1
 When "END"         : FIN=1 : GOK=0
 #When "DEBUT"       : Affzo [DIA]1-99        : # 71937 : Multilégislation
 When "DEBUT"       : Gosub DEBUT_FUNPNH      : # 71937 : Multilégislation
 When "SORTIE"      : Gosub SORTIE
 When "BOUTON"      : Gosub BOUTON            # Issue X3-57740 - 2017-11-08 by MUARN : Memo et globales
Endcase
Return

#################################################
# Initialisations avant exécution du traitement #
#################################################
$INIT

# 71937 : Multilégislation
Local Char      SAVGFCYDEF(GLONFCY)

If GSERVEUR
  Onerrgo ERRBATCH  : # En batch, il vaut mieux mettre onerrgo
Endif
Gosub OUVRE         : # Ouverture fichiers et déclaration variables locales
Local Mask PNHPST [DIA]
Raz [M:DIA]

# ----- chargement de l'écran en fonction des habilitations
# 71937 : Multilégislation
SAVGFCYDEF=GFCYDEF(0)
# Issue X3-57740 - 2017-11-08 by MUARN : GFCYDEF(6) au lieu de GFCYDEF(5)
GFCYDEF(0)=GFCYDEF(6)
# 71937

[M:DIA]XCPYFLG=1
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE : [M:DIA]XCPYFLG = 1 : Endif
If [M:DIA]XCPYFLG = 1
   Call INICPY([M:DIA]CPY) From CPTSUB
Endif
GFCYDEF(0)=SAVGFCYDEF : : # 71937 : Multilégislation
[M:DIA]XFCYFLG=2
If [M:DIA]XCPYFLG=1
        Call INIALLFCY([M:DIA]XFCYFLG,[M:DIA]CPY) From CPTTRT
Endif
If [M:DIA]XFCYFLG = 1
        Call INIFCY([M:DIA]RCPFCY,[M:DIA]CPY) From CPTSUB
Endif

[M:DIA]XFCYFLG  =2
[M:DIA]BORNE    =datesyst
[M:DIA]TYP      =2
[M:DIA]ACCDAT   =datesyst
[M:DIA]ITMSTOFLG=3

Gosub DATE_EXTOURNE
[M:DIA]TRACE    =2
Call LECMEMO("STD","[M:DIA]","pm8") From GMEMO
TIT=mess(611,197,1) : # Titre de la boite de dialogue et message de temporisation
TMP=1               : # Affichage d'un message de temporisation

# 71937 : Multilégislation
Gosub INIT_TYPPCEJOU         : # Init. de la pièce auto, du type de pièce et du code journal

Return

# 71937 : Multilégislation
#########################################################################
## $DEBUT_FUNPNH
#########################################################################
$DEBUT_FUNPNH
Call FMTLEG From TRTX3 : # Pour rendre invisible si nécessaire le champ "Législation"
Gosub GRILEG
Affzo [DIA]1-99
Return

######################################################################
## $GRILEG
######################################################################
$GRILEG
If func AFNC.ACTIV("LEG")=0 : # Dossier mono-législation
  Diszo [M:DIA]LEG
  [M:DIA]LEG=GDOSLEG(1)
  Affzo [M:DIA]LEG
Elsif [M:DIA]XCPYFLG=1
  Diszo [M:DIA]LEG
Else
  Actzo [M:DIA]LEG
Endif
Return
# 71937

##########################################
# Contrôle avant exécution du traitement #
##########################################
$CONTROLE
If GOK<1  FIN=1 Else TMP=1 : Endif

## Demande de modif 56230 - Lot CE5
If FIN : Return : Endif
Call AVERTDGI([M:DIA]XCPYFLG,[M:DIA]CPY,[M:DIA]TYP,SAI) From CPTDIV2
If SAI : Return : Endif
## Fin demande 56230
Return


###########################
# Exécution du traitement #
###########################
$EXEC
#----- Variables locales pour création pièces AAR et extourne AAR -----#
# X3-39795 MWA Start
#If [M:DIA]TYP=1 : # Génération réelle
#  Local Char WZONE (GLONAVA)(1..8)
#  Local Char WVALZONE (20)(1..8)
#Else            : # Génération simulée
#  Local Char WZONE (GLONAVA)(1..7)
#  Local Char WVALZONE (20)(1..7)
#Endif
Local Char    WZONE(GLONAVA)(1..10)           : # Table of the zones to be forced (Ex: ORICOD)
Local Char    WVALZONE(30)(1..10)            : # Table of values for zones to be forced
# X3-39795 MWA End
#-----
WNBPCE=1
GOK=1
#----- Début de la trace si nécessaire -----#
If !GSERVEUR & [M:DIA]TRACE=2
  #----- Ouverture fichier trace et écriture des sélections -----#
  Call OUVRE_TRACE(mess(611,197,1))  From LECFIC
  Call ECR_TRACE(" ",0)              From GESECRAN
  Call ECR_TRACE(string$(88,"-"),0)  From GESECRAN
  Call PRTSCR("PNHPST","DIA","",0,1) From ATRTX3
  Call ECR_TRACE(" ",0)              From GESECRAN
  Call ECR_TRACE(mess(594,197,1)-mess([M:DIA]ITMSTOFLG,563,1),0) From GESECRAN
  Call ECR_TRACE(string$(88,"-"),0)  From GESECRAN
Endif
# Issue X3-38252 - 2018-03-02 by SR: calcul date extourne
#--If the check box "All cpy" is checked, we have to control that for a LEG, all companies have the same period dates for a fiscal year
If [M:DIA]XCPYFLG=2 and [M:DIA]LEG<>""

  If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
  If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
  If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif

  Local Date ZPERSTR, ZPEREND : ZPERSTR=[0/0/0] : ZPEREND = [0/0/0]
  Local Integer ZWOK : ZWOK = [V]CST_AOK
  Local Char    ZWCPY(GLONCPY)

  Link [F:PER] With  [F:CPY]CPY0=[F:PER]CPY,
&                    [F:FIY]FIY0=[F:PER]CPY;[F:PER]LEDTYP;[F:PER]FIYNUM
&              As    [PERLNK]
&              Where [F:CPY]LEG = [M:DIA]LEG        and
&                    [F:FIY]FIYSTR <= [M:DIA]ACCDAT and
&                    [F:FIY]FIYEND >= [M:DIA]ACCDAT and
&                    [F:FIY]FIYSTA  = 2             and
&                    [F:PER]PERSTR <= [M:DIA]ACCDAT and
&                    [F:PER]PEREND >= [M:DIA]ACCDAT and
&                    [F:PER]CLODAT  = [0/0/0]       and
&                    [F:PER]PERSTA  = 2
  For [PERLNK]
    #--avoiding looping on all ledgers
    If ZWCPY<>[F:PERLNK]CPY
      ZWCPY=[F:PERLNK]CPY
      If ZPERSTR=[0/0/0] : ZPERSTR = [PERLNK]PERSTR : Endif
      If ZPEREND=[0/0/0] : ZPEREND = [PERLNK]PEREND : Endif
      #--if one of this date is different, then the fonction cannot continue
      If ZPERSTR<>[PERLNK]PERSTR or ZPEREND<>[PERLNK]PEREND
        ZWOK = [V]CST_AERROR
        Break
      Endif
    Endif
  Next
  Raz [F:CPY],[F:PER],[F:FIY] #--we don't want to keep values (those are read afterward)
  If ZWOK=[V]CST_AERROR
    Call ECR_TRACE(func AFNC.MES1(mess(681,199,1),[M:DIA]LEG)+"."+mess(682,199,1),1) From GESECRAN
    GOK=0 : Goto FIN_EXEC
  Endif
Endif
# End issue X3-38252
# Issue 115551 - 2016-04-07 by SR : lock société
Call LOCKCPYAFC([M:DIA]CPY,"FUNPNH",WOKLOCK) From TRTX3
If !WOKLOCK
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Raz GMESSAGE
  Goto FIN_EXEC_TRA
Endif

#----- Effacement des fichiers de travail temporaires par sécurité -----#
Gosub DEL_PWRK : If GOK<1  Goto FIN_EXEC_TRA : Endif

#----- Constitution du filtre sur les retours -----#
WCRIT="(PSTFLG<>2 | PSTDAT<["+format$(GFMD,[M:DIA]ACCDAT)+"])"
WCRIT+=" & (BETFCY<>2 | (BETFCY=2 & BETCPY=2)) & CFMFLG=2"
If [M:DIA]BPSSTR <> ""
  WCRIT+=' & BPSNUM>="'+[M:DIA]BPSSTR+'"'
Endif
If [M:DIA]BPSEND<>""
  WCRIT+=' & BPSNUM<="'+[M:DIA]BPSEND+'"'
Endif
If [M:DIA]XCPYFLG<>2
  WCRIT+=' & CPY="'+[M:DIA]CPY+'"'
Endif
If [M:DIA]XFCYFLG<>2
  WCRIT+=' & PNHFCY="'+[M:DIA]RCPFCY+'"'
Endif
If [M:DIA]BORNE<>[0/0/0]
  WCRIT+=' & RTNDAT<=['+format$(GFMD,[M:DIA]BORNE)+']'
Endif
# Issue X3-83998 - 2018-04-16 by SR :
If [M:DIA]LEG<> ""
   WCRIT+= '& [F:CPY]LEG ="'+[M:DIA]LEG+'"'
Endif

#----- Constitution du filtre sur les lignes de retour -----#
If [M:DIA]ITMSTOFLG=1
  WCRIT2="STOMGTCOD>1"
Elsif [M:DIA]ITMSTOFLG=2
  WCRIT2="STOMGTCOD<2"
Else
  WCRIT2="1=1"
Endif

#---------------------------------------------------------------------------#
# Point d'entrée PNHFILTRE pour ajouter un filtre supplémentaire            #
# ------------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                               #
#                                                                           #
# WCRIT     : Filtre constitué par le traitement à partir de l'écran PNHPST #
# PNHFILTRE : Filtre supplémentaire sur l'entête de retour                  #
#---------------------------------------------------------------------------#
Raz PNHFILTRE
SAV_WCRIT=WCRIT
# Issue 116409 - 2016-05-09 by SR :
SAV_WCRIT2=WCRIT2
GPOINT="PNHFILTRE" : Gosub ENTREE From EXEFNC
If WCRIT<>SAV_WCRIT
  WMSG="WCRIT"-mess(382,197,1)-WCRIT
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
If PNHFILTRE<>""
  WMSG="PNHFILTRE"-mess(382,197,1)-PNHFILTRE
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
# Issue 116409 - 2016-05-09 by SR
If WCRIT2<>SAV_WCRIT2
  WMSG="WCRIT2"-mess(382,197,1)-WCRIT2
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
# Issue 116409 - 2016-05-09 by SR : Ajout test de WCRIT2
If WCRIT<>SAV_WCRIT | PNHFILTRE<>"" | WCRIT2<>SAV_WCRIT2
  Call ECR_TRACE(" ",0)             From GESECRAN
  Call ECR_TRACE(string$(88,"-"),0) From GESECRAN
  Call ECR_TRACE(" ",0)             From GESECRAN
Endif
If WCRIT=""     WCRIT    ="1=1" : Endif
If PNHFILTRE="" PNHFILTRE="1=1" : Endif
#-----
If parse(WCRIT)
  Call ECR_TRACE("Filter error WCRIT",1)     From GESECRAN : Goto FIN_EXEC
Endif
If parse(PNHFILTRE)
  Call ECR_TRACE("Filter error PNHFILTRE",1) From GESECRAN : Goto FIN_EXEC
Endif

#-------------------------------------------------#
# Remplissage des fichiers de travail temporaires #
#-------------------------------------------------#
Raz GSOCIETE, WNBPCE
# Issue X3-83998 - 2018-04-16 by SR :
#For [PNH] Where evalue(WCRIT) & evalue(PNHFILTRE) With Nohint
Link [PNH] With [CPY]CPY0=[F:PNH]CPY As [KPNH]
For [KPNH] Where evalue(WCRIT) & evalue(PNHFILTRE) With Nohint
  #----- Récupération société (GSOCIETE) et devise société (GLOCALDEV) -----#
  If GSOCIETE<>[F:PNH]CPY
    Call GETDEV([F:PNH]PNHFCY) From DEVSUB
    Call LECLED(GSOCIETE,GTYPGEN,WLEDGEN,WDEVLED) From CPTDIV
    Call LECLED(GSOCIETE,GTYPANA,WLEDANA,WDEVLED) From CPTDIV
    #----- Liste des types de référentiel de la société -----#
    Call LSTLEDTYP(GSOCIETE,0,TBTYPLED,I) From CPTDIV
  Endif
  #-----
  Gosub TRTPND : If GOK<1  Break : Endif
  #-----
Next
If GOK<1 Goto FIN_EXEC : Endif

#-----------------------------------------#
# Suppression des écritures de simulation #
#-----------------------------------------#
Gosub DEL_SIMULATION : If GOK<1 Goto FIN_EXEC : Endif

#----------------------------------------------------------#
# Génération des écritures AAR, engagements et màj retours #
#----------------------------------------------------------#
If clalev([F:PWE1])=0  Local File PWRKPNH  [PWE1] : Endif
Raz GWCPY, GWPNHFCY, GWBPSINV, GWCUR, J, WMONTHT, WMONTTTC
NB_PWE=6
#-----
For [PWE1] PWE1 Where PRONUM=adxuid(1)
  If NB_PWE=6
&  | [F:PWE1]CPY   <>GWCPY
&  | [F:PWE1]PNHFCY<>GWPNHFCY
&  | [F:PWE1]BPSINV<>GWBPSINV
&  | [F:PWE1]CUR   <>GWCUR
    If GWCPY<>[F:PWE1]CPY | GWPNHFCY<>[F:PWE1]PNHFCY
      If GWCPY<>[F:PWE1]CPY
        Call GETSOC([F:PWE1]PNHFCY) From DEVSUB
        #----- Recherche code pièce auto -----#
        Call PARAM(GFINRSP,"GAUPNH",WPCEAUTO) From ADOVAL
        If WPCEAUTO=""  WPCEAUTO="PNH" : Endif
        #----- Lecture pièce auto PNH pour savoir si traitement ligne à ligne -----#
        Read [GAU] GAU0=WPCEAUTO : If fstat  Raz [F:GAU] : Endif
        If [F:GAU]GRPFLG=1
          NB_PWE=6
        Else
          NB_PWE=5
        Endif
        #----- Recherche type de cours -----#
        Read [GAG] GAG0=WPCEAUTO;0;"TCR"
        If fstat  Raz [F:GAG] : Endif
        If [F:GAG]FORCLC<>""
          WCHGTYPA=[F:GAG]FORCLC         : # Type de cours de la pièce auto
        Else
          #Read [GTE] GTE0=[M:DIA]TYPPCE
          Local Integer WRET
          Call LEC_GTE_LEG(GCURLEG,[M:DIA]TYPPCE,WRET) From TRTLECLEG
          If WRET : Raz [F:GTE] : Endif
          If [F:GTE]TYPRAT<>0
            WCHGTYPA=num$([F:GTE]TYPRAT) : # Type de cours du type de pièce
          Else
            WCHGTYPA="[F:PWE]CHGTYP"     : # Type de cours du retour
          Endif
        Endif
        #------
      Endif
      If GWCPY<>""  Gosub CUMUL_RECAP : Endif
      If [M:DIA]TRACE=2
        Call ECR_TRACE (" ",0)  From GESECRAN
        WMSG ="----- "+mess(2,45,1)-[F:PWE1]CPY+space$(16-len([F:PWE1]CPY))
        WMSG+=mess(3,45,1)-[F:PWE1]PNHFCY
        Call ECR_TRACE (WMSG,0) From GESECRAN
      Endif
      Raz GWBPSINV, GWCUR
    Endif
    If GWBPSINV<>[F:PWE1]BPSINV | GWCUR<>[F:PWE1]CUR
      If [M:DIA]TRACE=2
        If [F:BPS]BPSNUM<>[F:PWE1]BPSINV
          Read [BPS] BPS0=[F:PWE1]BPSINV : If fstat Raz [F:BPS] : Endif
        Endif
        WMSG ="----- "+mess(73,198,1)-[F:PWE1]BPSINV+space$(GLONBPS+2-len([F:PWE1]BPSINV))
        WMSG+=[F:BPS]BPSNAM+space$(GLONNAM+1-len([F:BPS]BPSNAM))+[F:PWE1]CUR
        Call ECR_TRACE (WMSG,0) From GESECRAN
      Endif
    Endif
    GWCPY   =[F:PWE1]CPY
    GWPNHFCY=[F:PWE1]PNHFCY
    GWBPSINV=[F:PWE1]BPSINV
    GWCUR   =[F:PWE1]CUR
    GWPNHNUM=[F:PWE1]PNHNUM
    Call DEBTRANS From GLOCK
    Gosub TR1
  Endif
Next
If GWCPY<>""  Raz [F:PWE1] : Gosub CUMUL_RECAP : Endif
#----- Ecriture de la récapitulation dans la trace -----#
If [M:DIA]TRACE=2 & J>0
  Call ECR_TRACE(string$(88,"-"),0)  From GESECRAN
  For I=0 To J-1
    If len(CPYFCY(I))<GLONCPY+1
      Call GETDEV(vireblc(mid$(CPYFCY(I+1),GLONCPY+1,GLONFCY),1)) From DEVSUB
      WMSG =mess(2,45,1)-CPYFCY(I)+space$(GLONFCY+1)+GLOCALDEV+" "
      WMSG+=format$("N3*:"+[F:TCU]CURFMT1,CUMULHT (I))-mess(1,243,1)+" "
      WMSG+=format$("N3*:"+[F:TCU]CURFMT1,CUMULTTC(I))-mess(2,243,1)
      Call ECR_TRACE (WMSG,0) From GESECRAN
    Else
      WMSG =space$(1+len(mess(2,45,1)))+mess(3,45,1)+" "
      WMSG+=right$(CPYFCY(I),GLONCPY+1)+" "+GLOCALDEV+" "
      WMSG+=format$("N3:"+[F:TCU]CURFMT1,CUMULHT (I))-mess(1,243,1)+" "
      WMSG+=format$("N3:"+[F:TCU]CURFMT1,CUMULTTC(I))-mess(2,243,1)
      Call ECR_TRACE (WMSG,0) From GESECRAN
    Endif
  Next I
  Call ECR_TRACE(string$(88,"-"),0)  From GESECRAN
Endif

#-------------------#
# Fin du traitement #
#-------------------#
$FIN_EXEC
If [M:DIA]TYP=1      : # Si génération réelle,
  Gosub DEVERROU_PNH : # suppression locks logiques sur PNH par sécurité
Endif
Gosub DEL_PWRK       : # Effacement fichiers de travail temporaires
#----- Fin de la trace éventuelle avec fermeture -----#
$FIN_EXEC_TRA
## Issue 115551 - 2016-04-07 by SR : Lock société
Call UNLOCKCPYAFC([M:DIA]CPY,"FUNPNH") From TRTX3

If !GSERVEUR & [M:DIA]TRACE=2
  If WNBPCE=0
    Call ECR_TRACE(mess(8,107,1),0) From GESECRAN : # Aucune pièce à traiter !
  Endif
  Call FERME_TRACE From LECFIC
Endif
Return


#####################################
# Fin après exécution du traitement #
#####################################
$TERMINE
Kill GWCPY, GWPNHNUM, GWPNHFCY
Raz GWBPSINV, GWCUR
If !GSERVEUR & [M:DIA]TRACE=2  TRA=1 Else TRA=0 : Endif

Return


$SORTIE
Return

# Issue X3-57740 - 2017-11-08 by MUARN : memeo et globales
$BOUTON
Case BOUT
  When "R"
    If [M:DIA]CPY <> ""
      Raz GSOC_ACTIVE
      If [M:DIA]RCPFCY <> ""
        If [F:FCY]FCY <> [M:DIA]RCPFCY
          Read [FCY] FCY0=[M:DIA]RCPFCY : If fstat Raz [F:FCY] : Endif
        Endif
      Else
        Filter [F:FCY] Where LEGCPY=[M:DIA]CPY
        Read [F:FCY] First
        If fstat : Raz [F:FCY] : Endif
        Filter [F:FCY]
      Endif
      GFCY=[F:FCY]FCY
      Gosub CHARG_PARAM
    Else
      Raz GSOCIETE, GCURLEG, GFCY, GCURFCY
      GCURLEG=[M:DIA]LEG
    Endif
Endcase
Return
# End issue X3-57740

#--------------------------------#
# Effacement fichiers de travail #
#--------------------------------#
$DEL_PWRK
Call DEBTRANS From GLOCK
$TR_DEL_PWRK
GOK=1
Trbegin [PWE], [PWR]
  #----- Suppression des entêtes retours dans fichier temporaire -----#
  WMSG=mess(155,197,1)-"PWRKPNH"-num$(adxuid(1))
  Delete [PWE] Where PRONUM=adxuid(1)
  If fstat=1
    GOK=-1 : GLOCK="$PWRKPNH"-num$(adxuid(1))            : Goto ROLL_PWRK
  Elsif fstat
    GOK=0  : Call RSTA("PWE",num$(adxuid(1))) From GLOCK : Goto AB_PWRK
  Endif
  #----- Suppression des lignes retour dans fichier temporaire -----#
  WMSG=mess(155,197,1)-"PWRKPND"-num$(adxuid(1))
  Delete [PWR] Where PRONUM=adxuid(1)
  If fstat=1
    GOK=-1 : GLOCK="$PWRKPND"-num$(adxuid(1))            : Goto ROLL_PWRK
   Elsif fstat
    GOK=0  : Call RSTA("PWR",num$(adxuid(1))) From GLOCK : Goto AB_PWRK
  Endif
  #----- Suppression détail qtés engagement commande dans fichier temporaire -----#
  WMSG=mess(155,197,1)-"PWRKPOQ"
  Delete [PWQ] Where TYPORI=1 & EXTOURNE<=[M:DIA]ACCDAT
  If fstat=1
    GOK=-1 : GLOCK="$PWRKPOQ"               : Goto ROLL_PWRK
   Elsif fstat
    GOK=0  : Call RSTA("PWQ","") From GLOCK : Goto AB_PWRK
  Endif
  #----- Effacement des quantités temporaires -----#
  Update [PWQ] Where TYPORI=1 & TMPQTYPUU<>0  With TMPQTYPUU=0
  If fstat
    GOK=0  : Call FSTA("PWQ") From GLOCK    : Goto AB_PWRK
  Endif
  #-----
Commit
Return
#----- Abandon -----#
$AB_PWRK
Rollback
Gosub AB_TRANSACTION_MSG
Return
#----- Nouvel essai ou abandon si conflit d'accès -----#
$ROLL_PWRK
Rollback
Call ROLL From GLOCK
If !GROLL
  Goto TR_DEL_PWRK
Else
  Gosub AB_TRANSACTION_MSG
Endif
Return


#-----------------------------------------------------------------------#
# Remplissage fichier de travail et blocage logique des retours traités #
#-----------------------------------------------------------------------#
$TRTPND
Raz WMONTHT, WMONTTTC, WQUANTITY, WECRITURE
#----- Lecture BPSUPPLIER si nécessaire -----#
If [F:BPS]BPSNUM<>[F:PNH]BPSNUM
  Read [BPS] BPS0=[F:PNH]BPSNUM : If fstat  Raz [F:BPS] : mkstat=1 : End : Endif
Endif
WCHGTYP=[F:BPS]CHGTYP
#----- Lecture BPARTNER si nécessaire -----#
If [F:BPR]BPRNUM<>[F:PNH]BPSNUM
  Read [BPR] BPR0=[F:PNH]BPSNUM : If fstat  Raz [F:BPR] : mkstat=1 : End : Endif
Endif
WCUR   =[F:BPS]CUR
#-----
If [F:TCU]CUR<>WCUR
  Read [TCU] TCU0=WCUR : If fstat Raz [F:TCU] : Endif
Endif
#-----
Trbegin [PWE], [PWR]
  For [PND] PND0 Where PNHNUM=[F:PNH]PNHNUM
&                    & (LININVFLG=1 | INVQTYPUU<>0)
&                    & NETPRIPUU<>0
&                    & evalue(WCRIT2)
    If [F:PND]LINPSTFLG<>2 | [F:PND]LINPSTDAT<[M:DIA]ACCDAT
      #---------------------------------#
      # On charge le fichier temporaire #
      #---------------------------------#
      If [F:PND]INVQTYPUU=0
        #-----------------------------------------------#
        # On pose verrou sur PNH                        #
        # si locké logiquement, on passe à autre retour #
        #-----------------------------------------------#
        If WECRITURE=0 & [M:DIA]TYP=1  Gosub VERROU_PNH : Endif
        If !mkstat
          WQUANTITY=[F:PND]QTYPUU
          Gosub ECRIT_PWR
          If GOK<1  Break : Endif
        Else
          Break
        Endif
      Else
        WQUANTITY=[F:PND]QTYPUU-[F:PND]INVQTYPUU
        GBIDD2=[F:PND]INVQTYPUU
        #---------------------------------------------------------------#
        # Lecture des avoirs associés au retour                         #
        # si date avoir est supérieure à borne on écrit ret dans compta #
        #---------------------------------------------------------------#
        Filter [PID] Where TYPORI=3 & NUMORI=[F:PND]PNHNUM & LINORI=[F:PND]PNDLIN
&                        & SEQORI=0 Order By Key PID1
        For [PID]
          #----- On lit tous les avoirs pour cette ligne de retour -----#
          If [F:PIH]NUM<>[F:PID]NUM
            Read [PIH] PIH0=[F:PID]NUM : If fstat  Raz [F:PIH] : Endif
          Endif
          If [F:PIH]ACCDAT>[M:DIA]BORNE
            WQUANTITY-=[F:PID]QTYPUU*(3-(2*[F:PIH]INVTYP))
            GBIDD2   +=[F:PID]QTYPUU*(3-(2*[F:PIH]INVTYP))
          Elsif [F:PID]PRTFLG=1
            GBIDD2    =[F:PND]QTYPUU
            WQUANTITY =0
            Break
          Endif
        Next
        Filter [PID]
        #----- Enlever le surplus de qté facturée hors borne -----#
        If GBIDD2<0  WQUANTITY+=GBIDD2 : Endif
        #-----
        If WQUANTITY>0
          #-----------------------------------------------#
          # On pose verrou sur PNH                        #
          # si locké logiquement, on passe à autre retour #
          #-----------------------------------------------#
          If WECRITURE=0 & [M:DIA]TYP=1  Gosub VERROU_PNH : Endif
          If !mkstat
            Gosub ECRIT_PWR
            If GOK<1  Break : Endif
          Else
            Break
          Endif
        Endif
      Endif
    Endif
  Next
  #----- Ecriture fichier de travail entête -----#
  If WECRITURE<>0 & GOK=1
    [F:PWE]PRONUM=adxuid(1)
    [F:PWE]=[F:PNH]
    #----- Relecture devise si nécessaire -----#
    If [F:TCU]CUR<>WCUR
      Read [TCU] TCU0=WCUR : If fstat Raz [F:TCU] : Endif
    Endif
    #-----
    If [F:TCU]EURFLG=2 & [M:DIA]ACCDAT>[F:TCU]CURENDDAT
      [F:PWE]CUR =GEURO
    Else
      [F:PWE]CUR =WCUR
    Endif
    [F:PWE]CURLEDANA=WDEVLED
    [F:PWE]CHGTYP=WCHGTYP
    [F:PWE]CPY=GSOCIETE
    #----- Montant TTC et montant HT -----#
    [F:PWE]AMTNOT=WMONTHT
    [F:PWE]AMTATI=WMONTTTC

    ###################################################################
    # Intervenir sur la classe [F:PWE] champs DIE et CCE dimensionnés # JHA
    ###################################################################
    #----- Comptabilité: Cas des AAR avant report sur enveloppe annuelle -----#
    Call BUOENV_SWITCH(2,[F:PNH]CPY,[F:PWE]RTNDAT,[F:PWE]DIE,[F:PWE]CCE,[M:DIA]TRACE) From TRTGDD
    #----- Fin intervention Comptabilité - Cas des AAR - JHA 08/12/10 -----#

    CLEFIC=num$([F:PWE]PRONUM)-[F:PWE]PNHNUM
    WMSG=mess(13,100,1)-"PWRKPNH"-CLEFIC : # Erreur d'écriture sur le fichier ...
    Write [PWE]
    If fstat
      GOK=0 : Call FSTA("PWE") From GLOCK
      Gosub AB_TRANSACTION_MSG
    Endif
    WNBPCE=1
  Endif
  #----- Déblocage logique si incident ou aucune ligne retour traitée ----#
  If GOK<1 | WECRITURE=0
    SYMBOL2="PNH"+[F:PNH]PNHNUM
    Unlock=SYMBOL2
  Endif
  If GOK<1  Rollback : Return : Endif
  #----- Point d'entrée permettant d'intervenir sur les tables de travail -----#
  # Table de travail PWRKPNH clé PWE0=adxuid(1)+[F:PNH]PNHNUM                  #
  #                  Contient l'entête de retour en cours de traitement        #
  #                                                                            #
  # Table de travail PWRKPND clé PWR0(2)=adxuid(1)+[F:PNH]PNHNUM               #
  #                  Contient toutes les lignes du retour en cours             #
  #                                                                            #
  # Nota : La classe [F:PNH] est significative (retour en cours)               #
  #        Il y a une transaction en cours                                     #
  #----------------------------------------------------------------------------#
  If WECRITURE<>0
    GPOINT="PNHPWRK" : Gosub ENTREE From EXEFNC
    If GOK<1  Rollback : Return : Endif
  Endif
  #-----
Commit
Return


#-------------------------------------#
# Blocage logique des retours traités #
#-------------------------------------#
$VERROU_PNH
Raz WMSG, mkstat
SYMBOL2="PNH"+[F:PNH]PNHNUM
Lock=SYMBOL2 With lockwait=0
If fstat
  If [M:DIA]TRACE=2
    WMSG=mess(192,198,1)-[F:PNH]PNHNUM-mess(10,100,1)
    Call ECR_TRACE(WMSG,1) From GESECRAN
  Endif
  mkstat=2
Endif
Return


#---------------------------------------------#
# Déverrou locks logiques sur retours traités #
#---------------------------------------------#
$DEVERROU_PNH
For [PWE]
  SYMBOL2="PNH"+[F:PWE]PNHNUM : Unlock=SYMBOL2
Next
Return


#-----------------------------#
# Ecriture fichier de travail #
#-----------------------------#
$ECRIT_PWR
Raz [F:PWR]
[F:PWR]PRONUM=adxuid(1)
[F:PWR]      =[F:PND]
[F:PWR]BPSINV=[F:PNH]BPSINV
#----- Récupération des comptes et sections analytiques -----#
Read [CAL] CAL0="PND";0;[F:PND]PNHNUM;[F:PND]PNDLIN;0;"";1
If !fstat
  For I=0 To dim([F:CAL]COA)-1
    [F:PWR]LED(I)   =[F:CAL]LED(I)
    [F:PWR]COA(I)   =[F:CAL]COA(I)
    [F:PWR]LINACC(I)=[F:CAL]ACC(I)
  Next I
  For I=0 To dim([F:CAL]DIE)-1
    [F:PWR]DIE(I)   =[F:CAL]DIE(I)
    [F:PWR]CCE(I)   =[F:CAL]CCE(I)
  Next I
Else
  Raz [F:CAL]
Endif
#----- Relecture devise si nécessaire -----#
If [F:TCU]CUR<>WCUR
  Read [TCU] TCU0=WCUR : If fstat Raz [F:TCU] : Endif
Endif
#-----
If [F:TCU]EURFLG=2 & [M:DIA]ACCDAT>[F:TCU]CURENDDAT
  [F:PWR]CUR =GEURO
Else
  [F:PWR]CUR =WCUR
Endif
[F:PWR]CURLEDANA=WDEVLED
#----------------------------------------------------------#
# Point d'entrée PNHQTY pour modifier la quantité de l'AAR #
# -------------------------------------------------------- #
# Variables utilisables par le point d'entrée              #
#                                                          #
# WQUANTITY     : Quantité de l'AAR exprimée en UA         #
#                 Cette quantité est modifiable            #
# [F:PND]PUU    : Unité d'achat de la quantité             #
# [F:PND]PNHNUM : No de retour en cours de traitement      #
# [F:PND]PNDLIN : Ligne retour en cours de traitement      #
#----------------------------------------------------------#
GPOINT="PNHQTY" : Gosub ENTREE From EXEFNC
If WQUANTITY<=0  Return : Endif
#-----
[F:PWR]QTYPUU=WQUANTITY
#----- Recalcul unité stock -----#
Call PCAL_QTY([F:PWR]QTYPUU,[F:PWR]PUU,[F:PWR]QTYSTU,[F:PWR]STU,[F:PWR]ITMREF,
&             [F:PNH]BPSNUM,1,GBIDD3) From TRTACHQTE1
#----- Conversion du prix net en devise entête -----#
WPRIX=0
If [F:PWR]NETCUR<>[F:PWR]CUR
  Call CONVERT2([F:PWR]NETCUR,[F:PWR]CUR,GLOCALDEV,WCHGTYP,[M:DIA]ACCDAT,
&               [F:PWR]NETPRIPUU,GBIDD3,STAT) From TRTDEV
  WPRIX=arr(GBIDD3,10^-GDECPRI)
Else
  WPRIX=[F:PWR]NETPRIPUU
Endif
#----- On calcul le montant ht ligne et 3 montants taxe ligne -----#
[F:PWR]AMTNOTLIN=[F:PWR]QTYPUU*WPRIX
#----------------------------------------------------------------#
# Point d'entrée PNHAMTLIN pour modifier le mt HT ligne de l'AAR #
# -------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                    #
#                                                                #
# [F:PWR]QTYPUU   : Quantité de l'AAR exprimée en UA             #
# [F:PND]PUU      : Unité d'achat de la quantité                 #
# [F:PND]PNHNUM   : No de retour en cours de traitement          #
# [F:PND]PNDLIN   : Ligne retour en cours de traitement          #
# [F:PWR]NETPRIPUU: Prix unitaire d'une UA en devise d'achat     #
# [F:PWR]NETCUR   : Devise du [F:PWR]NETPRIPUU                   #
#  WPRIX          : Prix unitaire d'une UA en devise de l'AAR    #
# [F:PWR]CUR      : Devise du WPRIX et du [F:PWR]AMTNOLIN        #
# [F:PWR]AMTNOTLIN: Montant ligne HT calculé non encore arrondi  #
#                   Ce montant est modifiable et sera arrondi en #
#                          fonction de la devise [F:PWR]CUR      #
#----------------------------------------------------------------#
GPOINT="PNHAMTLIN" : Gosub ENTREE From EXEFNC
#-----
Call ARRDEV([F:PWR]AMTNOTLIN,[F:PWR]CUR) From TRTDIV
WMONTHT +=[F:PWR]AMTNOTLIN
WMONTTTC+=[F:PWR]AMTNOTLIN
#-----------------------------#
# Calcul des montants de taxe #
#-----------------------------#
If [F:BPS]BPSNUM<>[F:PNH]BPSNUM
  Read [BPS] BPS0=[F:PNH]BPSNUM : If fstat  Raz [F:BPS] : Endif
Endif
#----- Chargement du régime de taxe du fournisseur -----#
Raz WVACBPR
If [F:PND]POHNUM<>""
  If [F:POH]POHNUM<>[F:PND]POHNUM
    Read [POH] POH0=[F:PND]POHNUM : If fstat  Raz [F:POH] : Endif
  Endif
  WVACBPR=[F:POH]VACBPR
Endif
If WVACBPR=""
  Call INIT_REGIME([F:PNH]BPSNUM,[F:PNH]PNHFCY,"F",WVACBPR) From CPTSUB
Endif
#------------------------------#
# Récuperation du type de taxe #
#------------------------------#
# Issue 117271 - 2016-06-28 by SR :
#Read [ADI] CODE=1;WVACBPR
#If fstat  Raz [F:ADI] : Endif
#If [F:ADI]N1=4
#  [F:PWR]CEEFLG=2
#Else
#  [F:PWR]CEEFLG=1
#Endif
Raz WRETOUR
Call LEC_TVB_LEG(GCURLEG,WVACBPR,WRETOUR) From TRTLECLEG
If WRETOUR Raz [F:TVB] : Endif
If [F:TVB]REGVAC=4
  [F:PWR]CEEFLG=2
Else
  [F:PWR]CEEFLG=1
Endif
# End issue 117271
#-----
Call ALICLCAMT2([F:PWR]ITMREF,[F:PWR]QTYPUU,-1,"PWR",WCLCAMT) From TRTX3
#-----
For I=1 To WNBTAXE
  Case I
    When 1 : WTAXE(1)=[F:PWR]VAT(0)
    When 2 : WTAXE(2)=[F:PWR]VAT(1)
    When 3 : WTAXE(3)=[F:PWR]VAT(2)
    When 4 : WTAXE(4)=[F:PWR]TAXRCP
    When 5 : WTAXE(5)=[F:PWR]TAXISS
    When 6 : WTAXE(6)=[F:PWR]TAXOTH1
    When 7 : WTAXE(7)=[F:PWR]TAXOTH2
  Endcase
Next I
#-----
Call CALTAXE2([F:PWR]PNHFCY,[F:PWR]RTNDAT,WVACBPR,[F:PWR]CUR,WNBTAXE,WTAXE,1,[F:PWR]AMTNOTLIN,
&             WCLCAMT,WMONTTAX,WMONTTAXDED,WTYPREG,WRETOUR) From SUBTVT
#-----
For I=1 To WNBTAXE
  Case I
    When 1 : [F:PWR]CLCAMT1   =WCLCAMT(1)
             [F:PWR]AMTTAXLIN1=WMONTTAX(1)
             [F:PWR]DEDTAXLIN1=WMONTTAXDED(1)
             If [F:PWR]CEEFLG<>2  WMONTTTC+=[F:PWR]AMTTAXLIN1 : Endif
    When 2 : [F:PWR]CLCAMT2   =WCLCAMT(2)
             [F:PWR]AMTTAXLIN2=WMONTTAX(2)
             [F:PWR]DEDTAXLIN2=WMONTTAXDED(2)
             If [F:PWR]CEEFLG<>2  WMONTTTC+=[F:PWR]AMTTAXLIN2 : Endif
    When 3 : [F:PWR]CLCAMT3   =WCLCAMT(3)
             [F:PWR]AMTTAXLIN3=WMONTTAX(3)
             [F:PWR]DEDTAXLIN3=WMONTTAXDED(3)
             If [F:PWR]CEEFLG<>2  WMONTTTC+=[F:PWR]AMTTAXLIN3 : Endif
    When 4 : [F:PWR]CLCAMT4   =WCLCAMT(4)
             [F:PWR]AMTTAXRCP =WMONTTAX(4)
             [F:PWR]DEDTAXRCP =WMONTTAXDED(4)
             If [F:PWR]CEEFLG<>2  WMONTTTC+=[F:PWR]AMTTAXRCP  : Endif
    When 5 : [F:PWR]CLCAMT5   =WCLCAMT(5)
             [F:PWR]AMTTAXISS =WMONTTAX(5)
             [F:PWR]DEDTAXRCP =WMONTTAXDED(5)
             If [F:PWR]CEEFLG<>2  WMONTTTC+=[F:PWR]AMTTAXISS  : Endif
    When 6 : [F:PWR]CLCAMT6   =WCLCAMT(6)
             [F:PWR]AMTTAXOTH1=WMONTTAX(6)
             [F:PWR]DEDTAXOTH1=WMONTTAXDED(6)
             If [F:PWR]CEEFLG<>2  WMONTTTC+=[F:PWR]AMTTAXOTH1 : Endif
    When 7 : [F:PWR]CLCAMT7   =WCLCAMT(7)
             [F:PWR]AMTTAXOTH2=WMONTTAX(7)
             [F:PWR]DEDTAXOTH2=WMONTTAXDED(7)
             If [F:PWR]CEEFLG<>2  WMONTTTC+=[F:PWR]AMTTAXOTH2 : Endif
  Endcase
Next I
#----- Recherche compte général -----#
Raz WCOMPTE
I=find(WLEDGEN,[F:CAL]LED(0..9))
If I
  WCOMPTE=[F:CAL]ACC(I-1)
Endif
#----- Recherche compte analytique -----#
Raz WCPTANA
I=find(WLEDANA,[F:CAL]LED(0..9))
If I
  WCPTANA=[F:CAL]ACC(I-1)
  WCOA   =[F:CAL]COA(I-1)
Endif
#----- Recherche des comptes si nécessaire -----#
If WCOMPTE="" & WCPTANA=""
  If [F:PND]POHNUM<>""
    ID1(1)=[F:PND]POHNUM
    ID2(1)=[F:PND]POHNUM
    ID2(2)=num$([F:PND]POPLIN)
    ID2(3)=num$([F:PND]POQSEQ)
    Read [TB0] POH0=[F:PND]POHNUM
    If fstat  Raz [F:TB0] : Endif
    Read [TB1] POQ0=[F:PND]POHNUM;[F:PND]POPLIN;[F:PND]POQSEQ
    If fstat  Raz [F:TB1] : Endif
    Read [TB2] CAL0="POP";0;[F:PND]POHNUM;[F:PND]POPLIN;[F:PND]POQSEQ;"";1
    If fstat  Raz [F:TB2] : Endif
  Else
    Raz ID1, ID2
    [F:TB0]=[F:PNH]
    If !find([F:PNH]PNHFCY,GSITE(1..GNBSITE))
      [F:TB0]INVFCY=[F:PNH]PNHFCY
    Else
      [F:TB0]INVFCY=GFINSITE(find([F:PNH]PNHFCY,GSITE(1..GNBSITE)))
    Endif
    [F:TB1]=[F:PND]
    Read [TB2] CAL0="PND";0;[F:PND]PNHNUM;[F:PND]PNDLIN;0;"";1
    If fstat  Raz [F:TB2] : Endif
  Endif
  Call SETREF(GSOCIETE,I,[F:PWR]LED) From CPTDIV
  Call COMPTE ("PORD",1,ID1,ID2,TPLAN,TCOMPTE,STAT,WMSG) From TRTACHCDE1
  If STAT
    Raz TPLAN, TCOMPTE
  Else
    For I=1 To 10
      If TPLAN(I)<>""
        J=find([F:GAD]LEDTYP(I-1),TBTYPLED(1..10))
        If J
          [F:PWR]COA   (J)=TPLAN  (I)
          # Issue 77334 - 2011-10-21 by SR
          [F:PWR]LINACC(J)=TCOMPTE(I)
        Endif
      Endif
    Next I
  Endif
  #----- Récupération compte général -----#
  Call LECPLAN(GSOCIETE,GTYPGEN,WCOA) From CPTDIV
  I=find(WCOA,TPLAN(1..10))
  If I  WCOMPTE=TCOMPTE(I) : Endif
  #----- Récupération compte analytique -----#
  Call LECPLAN(GSOCIETE,GTYPANA,WCOA) From CPTDIV
  I=find(WCOA,TPLAN(1..10))
  If I  WCPTANA=TCOMPTE(I) : Endif
Endif
#-----
[F:PWR]COAANA=WCOA
[F:PWR]ACCANA=WCPTANA
#----- Recherche de l'unité d'oeuvre (WGLU) -----#
If [F:GAC]COA<>WCOA | [F:GAC]ACC<>WCPTANA
  Read [GAC] GAC0=WCOA;WCPTANA : If fstat  Raz [F:GAC] : Endif
Endif
WGLU=[F:GAC]UOM
If WGLU<>""
  #----- Calcul qté en unité d'oeuvre (WQTYGLU) -----#
  Call PCAL_QTY([F:PWR]QTYPUU,[F:PWR]PUU,WQTYGLU,WGLU,
&               [F:PWR]ITMREF,[F:PNH]BPSNUM,1,GBIDD1) From TRTACHQTE1
  If [F:TCO]UOM1=""
    Call PCAL_QTY([F:PWR]QTYSTU,[F:PWR]STU,WQTYGLU,WGLU,
&               [F:PWR]ITMREF,[F:PNH]BPSNUM,1,GBIDD1) From TRTACHQTE1
    #----- Coefficient de convertion introuvable ! -----#
    If [F:TCO]UOM1="" & [M:DIA]TRACE=2
      Call ECR_TRACE ([F:PWR]STU-"->"-WGLU-mess(473,199,1),0) From GESECRAN
    Endif
  Endif
  #-----
  [F:PWR]QTYPUU=WQTYGLU
  [F:PWR]PUU   =WGLU
  [F:PWR]QTYSTU=WQTYGLU
  [F:PWR]STU   =WGLU
  [F:PWR]GLU   =WGLU
Else
  [F:PWR]GLU   =[F:PWR]STU
Endif
#----- Chargement zones pour engagement -----#
Gosub CHARG_ENGAGEMENT
#----- Ecriture fichier de travail ligne -----#

###################################################################
# Intervenir sur la classe [F:PWR] champs DIE et CCE dimensionnés # JHA
###################################################################
#----- Comptabilité: Cas des AAR avant report sur enveloppe annuelle -----#
Call BUOENV_SWITCH(2,[F:PNH]CPY,[F:PWR]RTNDAT,[F:PWR]DIE,[F:PWR]CCE,[M:DIA]TRACE) From TRTGDD
#----- Fin intervention Comptabilité - Cas des AAR - JHA 08/12/10 -----#

CLEFIC=num$([F:PWR]PRONUM)-[F:PWR]PNHNUM-num$([F:PWR]PNDLIN)
WMSG=mess(13,100,1)-"PWRKPND"-CLEFIC : # Erreur d'écriture sur le fichier ...
Write [PWR]
If fstat
  GOK=0 : Call FSTA("PWR") From GLOCK
  Gosub AB_TRANSACTION_MSG
Else
  WECRITURE=1
Endif
Return


#-----------------------------------------#
# Suppression des écritures de simulation #
#-----------------------------------------#
$DEL_SIMULATION
GOK=1 : # Le Call DELPCE est une transaction à part entière (Trbegin-Commit)
Raz WFLAG
If [M:DIA]XCPYFLG=2
  Filter [HAE1] Where REFSIM="AAR-SS"
Elsif [M:DIA]XFCYFLG=2
  Filter [HAE1] Where REFSIM="AAR-SS" & CPY=[M:DIA]CPY
Else
  If dim([L]WFCY)<1  Local Char WFCY(GLONFCY) : Endif
  [L]WFCY=[M:DIA]RCPFCY
  Read [FCY] FCY0=[M:DIA]RCPFCY : If fstat  Raz [F:FCY] : Endif
  If [F:FCY]FINRSPFCY<>""  [L]WFCY=[F:FCY]FINRSPFCY : Endif
  Filter [HAE1] Where REFSIM="AAR-SS" & CPY=[M:DIA]CPY & FCY=[L]WFCY
Endif
For [HAE1] HAE2
  If [M:DIA]TRACE=2 & WFLAG=0
    Call ECR_TRACE(mess(3,107,1),0) From GESECRAN
  Endif
  WFLAG=1
  CLEFIC=num$([F:HAE1]TYP)-[F:HAE1]NUM
  WMSG=mess(12,100,1)-"GACCENTRY"-CLEFIC : # Erreur d'accès sur le fichier ...
  Call DELPCE([F:HAE1]TYP,[F:HAE1]NUM) From CPTBATCH
  If GOK<1  Break : Endif
  If [M:DIA]TRACE=2
    Call ECR_TRACE(mess(41,107,1)-[F:HAE1]TYP-[F:HAE1]NUM,0) From GESECRAN
  Endif
Next
Filter [HAE1]
If GOK<1 Gosub AB_TRANSACTION_MSG : Endif
If [M:DIA]TRACE=2 & WFLAG<>0
  Call ECR_TRACE(string$(88,"-"),0)  From GESECRAN
Endif
Return


##############################################
#                 Traitement                 #
#  ----------------------------------------  #
#  - Création pièces AAR et extourne AAR     #
#  - Création pièce désengagement            #
#  - Création pièce réengagement             #
#  - Màj date et indicateur ligne  retour    #
#  - Màj date et indicateur entête retour    #
##############################################
$TR1
GOK=1
Trbegin [PNH], [PND], [PWQ]
  #-------------------------------------#
  # Création pièces AAR et extourne AAR #
  #-------------------------------------#
  COMPTA_CRIT ="PRONUM=adxuid(1)"
  COMPTA_CRIT-="& CPY=GWCPY & PNHFCY=GWPNHFCY & BPSINV=GWBPSINV & CUR=GWCUR"
  If NB_PWE=6
    COMPTA_CRIT-="& PNHNUM=GWPNHNUM"
  Endif
  #----- Chargement des zones pour création pièces AAR et extourne AAR -----#
  WZONE   (1) = "JOU"
  WVALZONE(1) = num$([M:DIA]JOURNAL)
  WZONE   (2) = "ACCDAT"
  WVALZONE(2) = num$(val([M:DIA]ACCDAT))
  WZONE   (3) = "CAT"
  WVALZONE(3) = num$([M:DIA]TYP)
  WZONE   (4) = "TYP"
  WVALZONE(4) = [M:DIA]TYPPCE
  WZONE   (5) = "STA"
  WVALZONE(5) = num$([M:DIA]STA)
  ## Demande de modif 56231
  If [M:DIA]TYP = 1 & func AFNC.PARAM("FRADGI",GWCPY)="2"
   WZONE(5) = "STA" : WVALZONE(5) = num$(2)
  Elsif [M:DIA]TYP <> 1
   WZONE(5) = "STA" : WVALZONE(5) = num$(1)
  Endif
  ## Fin demande 56231
  # DBA le 06/03/03 : type d'échéance (2=facture)
  WZONE   (6) = "TYPDUD"
  WVALZONE(6) = "2"
  If [M:DIA]TYP=1
    #----- Génération réelle -----#
    WZONE   (7) = "RVSDAT"
    WVALZONE(7) = num$(val([M:DIA]EXTOURNE))
    WZONE   (8) = "RVS"
    WVALZONE(8) = "2"
  Else
    #----- Génération simulée (active ou non active) -----#
    WZONE   (7) = "REFSIM"
    WVALZONE(7) = "AAR-SS"
  Endif
  WZONE(9) ="ORIGIN" : WVALZONE(9) ="2"               : # X3-39795 MWA Automatic loading
  WZONE(10)="ORICOD" : WVALZONE(10)= WPCEAUTO         : # X3-39795 MWA

  #----- Création pièces AAR et extourne AAR -----#
  GFCYDEF(0)=GFCYDEF(2)
  Raz WMESSAGE
  Call VALPCE4(WPCEAUTO,COMPTA_CRIT,WRETOUR,WMESSAGE,WZONE,WVALZONE) From CPTAUTO  : # Bug 56858
  GFCYDEF(0)=GFCYDEF(6)
  WMSG=" "
  If NB_PWE=6  WMSG+=mess(192,198,1)-GWPNHNUM+" " : Endif
  If WMESSAGE=""
    If [F:PWE1]AMTNOT=0
      WMSG+=mess(62,194,1)-format$("N3:9.2",[F:PWE1]AMTNOT)
    Else
      #----- Pièce automatique xxxxx : Montant 999999,99 non traité -----#
      WMSG-=mess(88,105,1)-WPCEAUTO-":"
      WMSG-=mess(157,154,1)-format$("N3:9.2",[F:PWE1]AMTNOT)-mess(414,177,1)
    Endif
  Else
    WMSG+=WMESSAGE
  Endif
  If WRETOUR | GOK=0 | WMESSAGE=""
    #----- Erreur à la création des pièces (Abandon) -----#
    GOK=0
    Goto AB_TR1
  Elsif GOK=-1
    #----- Conflit d'accès à la création des pièces (Nouvel essai) -----#
    Goto ROLL_TR1
  Else
    #----- Les pièces ont été créées correctement ! -----#
    If [M:DIA]TRACE=2
      WMSG=mess(17,853,1)+"  : "+ctrans(WMESSAGE,"\"," ")
      Call ECR_TRACE(WMSG,0) From GESECRAN
    Endif
  Endif
  #-----
  Raz WCMMNUM1, WCMMNUM2, WPSTLINNBR, WFLAG, WPOHFCY, WPARAM
  For [PWE] PWE1 Where evalue(COMPTA_CRIT)
    For [PWR] PWR0 Where PRONUM=adxuid(1) & PNHNUM=[F:PWE]PNHNUM
      #-------------------------------------------------------------#
      # Création pièces désengagement et réengagement si nécessaire #
      #-------------------------------------------------------------#
      If WPOHFCY="" | WPOHFCY<>[F:PWR]POHFCY
        Call PARAM([F:PWR]POHFCY,"PURCMM",WPARAM) From ADOVAL
        WPOHFCY=[F:PWR]POHFCY
      Endif
      If ([F:PWR]QTYBUDLIN<>0 | [F:PWR]AMTCUR<>0) & val(WPARAM)=2
        Call GETSOC([F:PWR]POHFCY) From DEVSUB
        If GFINRSP="" GFINRSP=[F:PWR]POHFCY : Endif
        #----- Chargement codes axes et sections analytiques -----#
        For I=1 To GOPTCANA
          TBDIE(I)=[F:PWR]DIE(I-1)
          TBCCE(I)=[F:PWR]CCE(I-1)
        Next I
        #----- Filtrage des codes et sections analytiques sur référentiel analytique -----#
        #             On ne filtre plus à partir de la version Béryl 6.1 !                #
        #---------------------------------------------------------------------------------#
        #Call SETCCEAXE(GSOCIETE,GTYPANA,TBDIE,TBCCE,TBDIE2,TBCCE2) From CPTDIV
        #-----
        ID2(1)=[F:PWR]POHNUM       : WDOCUMENT(1)=[F:PWR]POHNUM
        ID2(2)=num$([F:PWR]POPLIN) : WDOCUMENT(2)=num$([F:PWR]POPLIN)
        ID2(3)=num$([F:PWR]POQSEQ) : WDOCUMENT(3)=num$([F:PWR]POQSEQ)
        If [F:TB1]POHNUM<>[F:PWR]POHNUM |
&          [F:TB1]POPLIN<>[F:PWR]POPLIN |
&          [F:TB1]POQSEQ<>[F:PWR]POQSEQ
          Read [TB1] POQ0=[F:PWR]POHNUM;[F:PWR]POPLIN;[F:PWR]POQSEQ
          If fstat Raz [F:TB1] : Endif
        Endif
        If [F:TB1]POHTYP=2  TYPORG=2 Else  TYPORG=1 : Endif
        #----- Récupération du numéro d'engagement de la ligne de commande -----#
        WCMMNUM1=[F:TB1]CMMNUM
        WCMMNUM2=[F:TB1]CMMNUM
        #----- Chargement des motifs -----#
        WMOTIF(1)=1 : # Création
        WMOTIF(2)=5 : # AAR
        #----- Création pièce de réengagement à date comptable -----#
        WOK_MAJENG=1 : WTYPMAJ=3 : Gosub POINT_MAJENG From TRTACHCDE1
        #-----
        If WOK_MAJENG
#         Call MAJENGOLD([M:DIA]ACCDAT,GFINRSP,[F:PWR]CUR,[F:PWR]AMTCUR,[F:PWR]CURLEDANA,
#&                    [F:PWR]AMTLED,[F:PWR]QTYBUDLIN,[F:PWR]ACCANA,[F:PWE]BPSNUM,
#&                    TBDIE2,TBCCE2,1,+1,2,0,WCMMNUM1,[F:PWR]POHNUM,
#&                    OK,WMESSAGE,"PORD",ID2,"","",TYPORG,[F:PWE]CHGTYP) From CPTENG
          #----- Nouvel appel Béryl 6.1 -----#
          Call MAJENG([M:DIA]ACCDAT,GFINRSP,[F:PWR]CUR,[F:PWR]AMTCUR,[F:PWR]RATDIV,
&                     [F:PWR]RATMLT,[F:PWR]QTYBUDLIN,[F:PWR]LINACC,[F:PWR]LED,[F:PWE]BPSNUM,
&                     TBDIE,TBCCE,1,+1,2,0,WCMMNUM1,WDOCUMENT,WMOTIF,
&                     OK,WMESSAGE,"PORD",ID2,"","",TYPORG,[F:PWE]CHGTYP) From CPTENG
          WMSG=mess(192,198,1)-GWPNHNUM-num$([F:PWR]PNDLIN)-WMESSAGE
          If OK<>1 | GOK=0
            #----- Erreur à la création du réengagement (Abandon) -----#
            GOK=0 : Break 2
          Elsif GOK=-1
            #----- Conflit d'accès à la création du réengagement (Nouvel essai) -----#
            Break 2
          Endif
        Endif
        #----- Chargement des motifs -----#
        WMOTIF(1)=5 : # Extourne
        WMOTIF(2)=5 : # AAR
        #----- Création pièce de désengagement à date d'extourne -----#
        WOK_MAJENG=1 : WTYPMAJ=4 : Gosub POINT_MAJENG From TRTACHCDE1
        #-----
        If WOK_MAJENG
#         Call MAJENGOLD([M:DIA]EXTOURNE,GFINRSP,[F:PWR]CUR,[F:PWR]AMTCUR,[F:PWR]CURLEDANA,
#&                    [F:PWR]AMTLED,[F:PWR]QTYBUDLIN,[F:PWR]ACCANA,[F:PWE]BPSNUM,
#&                    TBDIE2,TBCCE2,1,-1,2,0,WCMMNUM2,[F:PWR]POHNUM,
#&                    OK,WMESSAGE,"PORD",ID2,"","",TYPORG,[F:PWE]CHGTYP) From CPTENG
          #----- Nouvel appel Béryl 6.1 -----#
          Call MAJENG([M:DIA]EXTOURNE,GFINRSP,[F:PWR]CUR,[F:PWR]AMTCUR,[F:PWR]RATDIV,
&                     [F:PWR]RATMLT,[F:PWR]QTYBUDLIN,[F:PWR]LINACC,[F:PWR]LED,[F:PWE]BPSNUM,
&                     TBDIE,TBCCE,1,-1,2,0,WCMMNUM2,WDOCUMENT,WMOTIF,
&                     OK,WMESSAGE,"PORD",ID2,"","",TYPORG,[F:PWE]CHGTYP) From CPTENG
          WMSG=mess(192,198,1)-GWPNHNUM-num$([F:PWR]PNDLIN)-WMESSAGE
          If OK<>1 | GOK=0
            #----- Erreur à la création du désengagement (Abandon) -----#
            GOK=0 : Break 2
          Elsif GOK=-1
            #----- Conflit d'accès à la création du désengagement (Nouvel essai) -----#
            Break 2
          Endif
        Endif
        #----- Ecriture trace réengagement/désengagement -----#
        If [M:DIA]TRACE=2 & WFLAG=0 & (WCMMNUM1<>"" | WCMMNUM2<>"")
          WMSG=""
          If WCMMNUM1<>""  WMSG+=mess(461,197,1)-mess(2,631,1)-":"-WCMMNUM1 : Endif
          If WCMMNUM2<>""  WMSG+=" "+mess(64,106,1)+"    : "+WCMMNUM2       : Endif
          Call ECR_TRACE(WMSG,0) From GESECRAN
        Endif
        WFLAG=1
      Endif
      #----- Ecriture de la trace ligne retour traitée -----#
      If [M:DIA]TRACE=2 & (WMESSAGE<>"" | [F:PWR]AMTNOTLIN<>0)
        If [F:TCU]CUR<>[F:PWR]CUR
          Read [TCU] TCU0=[F:PWR]CUR
          If fstat [F:TCU]CURFMT1="9.2" : Endif
        Endif
        WMSG ="  "+mess(192,198,1)-[F:PWR]PNHNUM+space$(GLONPTH+1-len([F:PWR]PNHNUM))
        WMSG+=mess(80,197,1)-[F:PWR]ITMREF+space$(GLONITM+1-len([F:PWR]ITMREF))
        WMSG+=[F:PWR]CUR+space$(GLONCUR+1-len([F:PWR]CUR))
        WMSG+=format$("N3:"+[F:TCU]CURFMT1,[F:PWR]AMTNOTLIN)-mess(1,243,1)
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      #-----------------------------------------------#
      # Mise à jour ligne retour si génération réelle #
      #-----------------------------------------------#
      If [M:DIA]TYP=1
        CLEFIC=[F:PWR]PNHNUM-num$([F:PWR]PNDLIN)
        WMSG=mess(12,100,1)-"PRETURND"-CLEFIC : # Erreur d'accès sur le fichier ...
        Readlock [PND] PND0=[F:PWR]PNHNUM;[F:PWR]PNDLIN
        If fstat=1
          GOK=-1 : GLOCK="$PRETURND"-CLEFIC           : Break 2
        Elsif fstat
          GOK=0  : Call RSTA("PND",CLEFIC) From GLOCK : Break 2
        Endif
        If [F:PND]LINPSTFLG<>2  WPSTLINNBR+=1 : Endif
        [F:PND]LINPSTFLG=2
        [F:PND]LINPSTDAT=[M:DIA]EXTOURNE
        Rewrite [PND]
        If fstat  GOK=0 : Call FSTA("PND") From GLOCK : Break 2 : Endif
        #----- Mise à jour fichier de travail détail qtés engagement par commande -----#
        If [F:PND]POHNUM<>""
          CLEFIC="1"-[F:PND]POHNUM-num$([F:PND]POPLIN)-num$([F:PND]POQSEQ)
          WMSG=mess(12,100,1)-"PWRKPOQ"-CLEFIC : # Erreur d'accès sur le fichier ...
          Readlock [PWQ] PWQ0=1;[F:PND]POHNUM;[F:PND]POPLIN;[F:PND]POQSEQ
          If !fstat
            [F:PWQ]TMPQTYPUU-=[F:PWR]QTYBUDLIN
            [F:PWQ]CMMQTYPUU+=[F:PWR]QTYBUDLIN
            Rewrite [PWQ]
            If fstat  GOK=0 : Call FSTA("PWQ") From GLOCK : Break 2 : Endif
          Endif
        Endif
        #-----
      Endif
    Next
    #----- Cumul des montants HT et TTC en devise société -----#
    If GLOCALDEV<>[F:PWR]CUR
      Call CONVERT([F:PWE]CUR,GLOCALDEV,GLOCALDEV,evalue(WCHGTYPA),[M:DIA]ACCDAT,
&                  [F:PWE]AMTNOT,GBIDD1,STAT) From TRTDEV
      WMONTHT +=GBIDD1
      Call CONVERT([F:PWE]CUR,GLOCALDEV,GLOCALDEV,evalue(WCHGTYPA),[M:DIA]ACCDAT,
&                  [F:PWE]AMTATI,GBIDD1,STAT) From TRTDEV
      WMONTTTC+=GBIDD1
    Else
      WMONTHT +=[F:PWE]AMTNOT
      WMONTTTC+=[F:PWE]AMTATI
    Endif
    #------------------------------------------------#
    # Mise à jour entête retour si génération réelle #
    #------------------------------------------------#
    If [M:DIA]TYP=1
      CLEFIC=[F:PWE]PNHNUM
      WMSG=mess(12,100,1)-"PRETURN"-CLEFIC : # Erreur d'accès sur le fichier ...
      Readlock [PNH] PNH0=[F:PWE]PNHNUM
      If fstat=1
        GOK=-1 : GLOCK="$PRETURN"-CLEFIC           : Break
      Elsif fstat
        GOK=0  : Call RSTA("PNH",CLEFIC) From GLOCK : Break
      Endif
      [F:PNH]PSTLINNBR+=WPSTLINNBR : Raz WPSTLINNBR
      If [F:PNH]PSTLINNBR>=[F:PNH]LINNBR
        [F:PNH]PSTFLG=2 : [F:PNH]PSTDAT=[M:DIA]EXTOURNE
      Endif
      Rewrite [PNH]
      #----- Déverrou retour -----#
      SYMBOL2="PNH"+[F:PNH]PNHNUM
      Unlock=SYMBOL2
      #-----
      If fstat  GOK=0 : Call FSTA("PNH") From GLOCK : Break : Endif
    Endif
  Next
  If GOK=-1 Goto ROLL_TR1 : Endif
  If GOK=0  Goto AB_TR1   : Endif
Commit
Return

#------------------------------------------------------#
# Nouvel essai de transaction ou abandon suivant GROLL #
#------------------------------------------------------#
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If !GROLL
  Goto TR1
Else
  Gosub AB_TRANSACTION_MSG
  Return
Endif

#---------------------------#
# Abandon de la transaction #
#---------------------------#
$AB_TR1
Rollback
Gosub AB_TRANSACTION_MSG
Return


#---------------------------------------------#
# Messages en cas d'abandon de la transaction #
#---------------------------------------------#
$AB_TRANSACTION_MSG
If [M:DIA]TRACE=2
  If WMSG<>"" Call ECR_TRACE(WMSG,1) From GESECRAN : Endif
Endif
Raz WMSG
Return


#--------------------------------------------------#
# Cumul des montants HT et TTC par société et site #
#--------------------------------------------------#
$CUMUL_RECAP
If J=0 CPYFCY(J)=GWCPY+space$(GLONCPY-len(GWCPY)) : J+=1 : Endif
If J<dim(CPYFCY)
  CPYFCY  (J) =GWCPY+space$(GLONCPY-len(GWCPY))+GWPNHFCY+space$(GLONFCY-len(GWPNHFCY))
  CUMULHT (J) =WMONTHT
  CUMULTTC(J) =WMONTTTC
  I=find(GWCPY+space$(GLONCPY-len(GWCPY)),CPYFCY(0..J-1))-1
  CUMULHT (I)+=WMONTHT
  CUMULTTC(I)+=WMONTTTC
  J+=1
  If GWCPY<>[F:PWE1]CPY & [F:PWE1]CPY<>"" & J<dim(CPYFCY)
    CPYFCY(J)=[F:PWE1]CPY+space$(GLONCPY-len([F:PWE1]CPY)) : J+=1
  Endif
Endif
Raz WMONTHT, WMONTTTC
Return


#---------------------------------------------------------#
# Ouverture des fichiers et déclaration variables locales #
#---------------------------------------------------------#
$OUVRE
#----- Variables locales -----#
Local  Char     WCUR(GLONCUR)
Local  Libelle  WCHGTYP
Local  Char     WVACBPR(GLONTVB)
Local  Char     WCOMPTE(GLONGAC)
Local  Char     WCPTANA(GLONGAC)
Local  Integer  TBTYPLED(1..10)
Local  Char     TPLAN  (GLONCOA)(1..10)
Local  Char     TCOMPTE(GLONGAC)(1..10)
Local  Char     TBDIE  (GLONDIE)(1..GOPTCANA)
Local  Char     TBCCE  (GLONCCE)(1..GOPTCANA)
#Local  Char     TBDIE2 (GLONDIE)(1..GOPTCANA)
#Local  Char     TBCCE2 (GLONCCE)(1..GOPTCANA)
Local  Char     WLEDGEN(GLONLED)
Local  Char     WLEDANA(GLONLED)
Local  Char     WDEVLED(GLONCUR)
Local  Char     WCOA   (GLONCOA)
Local  Char     ID1(20)(1..1), ID2(20)(1..3)
Local  Char     WGLU   (GLONUOM)
Local  Decimal  WQTYGLU
Local  Char     WCRIT(250), SYMBOL2(30), CLEFIC(30), SAV_WCRIT(250), PNHFILTRE(250)
# Issue 116409 - 2016-05-09 by SR : WCRIT2 Passé de 30 à 250 caractères, SAV_WCRIT2 déclaré
Local  Char     WCRIT2(250), SAV_WCRIT2(250)
Local  Integer  WECRITURE
Local  Decimal  WQUANTITY
Local  Decimal  WMONTHT
Local  Decimal  WMONTTTC
Local  Libelle  WNBTAXE : WNBTAXE=3+4*(func AFNC.ACTIV("PTX"))
Local  Char     WTAXE (GLONVAT)(1..WNBTAXE)
Local  Decimal  WMONTTAX (1..WNBTAXE)
Local  Decimal  WMONTTAXDED (1..WNBTAXE)
Local  Integer  WTYPREG
Local  Decimal  WPRIX
Local  Integer  STAT, OK, I, WFLAG, WTYPMAJ, WOK_MAJENG
Local  Char     WCRIT_CHARGPWR(240)
Local  Integer  WNBPCE
Local  Integer  WRETOUR , WECRITURE, MAXI, TYPORG
Local  Char     COMPTA_CRIT(250)
Local  Char     WMESSAGE(250), WMSG(120)
Local  Libelle  NB_PWE, CREFLG
Local  Char     SOCIETE(GLONCPY), SITE(GLONFCY), VALPAR(30)
Local  Date     DAT
Local  Decimal  EXERCICE, PERIODE, WMT1, WMT2, WMT3
Local  Char     WCMMNUM1(GLONVCR), WCMMNUM2(GLONVCR)
Local  Shortint WPSTLINNBR
Local  Char     CPYFCY(GLONCPY+GLONFCY)(300)
Local  Decimal  CUMULHT  (300)
Local  Decimal  CUMULTTC (300)
Local  Shortint J
Local  Char     WCHGTYPA(80)
Local  Char     WPCEAUTO(GLONGAU)
Local  Char     WPOHFCY(GLONFCY), WPARAM(10)
Local  Decimal  WCLCAMT(1..7)
Local  Char     WDOCUMENT(GLONPOH)(1..3)
Local  Libelle  WMOTIF(1..2)
# Issue 115551 - 2016-04-07 by SR : Lock société
Local  Integer     WOKLOCK
Global Char     GWCPY(GLONCPY), GWPNHNUM(GLONPNH), GWPNHFCY(GLONFCY)
#----- Ouverture des fichiers -----#
If clalev([F:BPS])=0  : Local File BPSUPPLIER  [BPS] : Endif
If clalev([F:BPR])=0  : Local File BPARTNER    [BPR] : Endif
If clalev([F:BPA])=0  : Local File BPADDRESS   [BPA] : Endif
If clalev([F:PNH])=0  : Local File PRETURN     [PNH] : Endif
If clalev([F:PND])=0  : Local File PRETURND    [PND] : Endif
If clalev([F:CAL])=0  : Local File CPTANALIN   [CAL] : Endif
If clalev([F:PIH])=0  : Local File PINVOICE    [PIH] : Endif
If clalev([F:PID])=0  : Local File PINVOICED   [PID] : Endif
If clalev([F:FCY])=0  : Local File FACILITY    [FCY] : Endif
If clalev([F:GCM])=0  : Local File GACM        [GCM] : Endif
If clalev([F:GAU])=0  : Local File GAUTACE     [GAU] : Endif
If clalev([F:GAD])=0  : Local File GAUTACED    [GAD] : Endif
If clalev([F:GAG])=0  : Local File GAUTACEF    [GAG] : Endif
If clalev([F:CAC])=0  : Local File GACCCODE    [CAC] : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT    [GAC] : Endif
If clalev([F:CPY])=0  : Local File COMPANY     [CPY] : Endif
If clalev([F:TCU])=0  : Local File TABCUR      [TCU] : Endif
If clalev([F:TCH])=0  : Local File TABCHANGE   [TCH] : Endif
If clalev([F:GDE])=0  : Local File GDIAENTRY   [GDE] : Endif
If clalev([F:GDD])=0  : Local File GDIAENTRYD  [GDD] : Endif
If clalev([F:TCK])=0  : Local File TABACCLIK   [TCK] : Endif
If clalev([F:GTE])=0  : Local File GTYPACCENT  [GTE] : Endif
If clalev([F:DUD])=0  : Local File GACCDUDATE  [DUD] : Endif
If clalev([F:PBS])=0  : Local File GAPARBSE    [PBS] : Endif
If clalev([F:JOU])=0  : Local File GJOURNAL    [JOU] : Endif
If clalev([F:JST])=0  : Local File GAJOUSTA    [JST] : Endif
If clalev([F:CCE])=0  : Local File CACCE       [CCE] : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR  [FIY] : Endif
If clalev([F:PER])=0  : Local File PERIOD      [PER] : Endif
If clalev([F:TUN])=0  : Local File TABUNIT     [TUN] : Endif
If clalev([F:DSP])=0  : Local File CADSP       [DSP] : Endif
If clalev([F:AUZ])=0  : Local File CAAUZ       [AUZ] : Endif
If clalev([F:ANM])=0  : Local File ACODNUM     [ANM] : Endif
If clalev([F:AVN])=0  : Local File AVALNUM     [AVN] : Endif
If clalev([F:CCE2])=0 : Local File CACCE      [CCE2] : Endif
If clalev([F:HAE1])=0 : Local File GACCENTRY  [HAE1] : Endif
If clalev([F:HAE2])=0 : Local File GACCTMP    [HAE2] : Endif
If clalev([F:ADI])=0  : Local File ATABDIV     [ADI] : Endif
If clalev([F:TCO])=0  : Local File TABCOEFF    [TCO] : Endif
If clalev([F:TVT])=0  : Local File TABVAT      [TVT] : Endif
If clalev([F:TRA])=0  : Local File TABRATVAT   [TRA] : Endif
If clalev([F:BAL])=0  : Local File BALANCE     [BAL] : Endif
If clalev([F:BLA])=0  : Local File BALANA      [BLA] : Endif
If clalev([F:ITM])=0  : Local File ITMMASTER   [ITM] : Endif
If clalev([F:ITP])=0  : Local File ITMBPS      [ITP] : Endif
If clalev([F:ITS])=0  : Local File ITMSALES    [ITS] : Endif
If clalev([F:POH])=0  : Local File PORDER      [POH] : Endif
If clalev([F:POP])=0  : Local File PORDERP     [POP] : Endif
If clalev([F:CMD])=0  : Local File GCOMMITD    [CMD] : Endif
# Issue 117271 - 2016-06-28 by SR :
If clalev([F:TVB])=0  : Local File TABVACBPR   [TVB] : Endif
#----- Fichiers temporaires pour faciliter le traitement -----#
If clalev([F:PWE])=0  : Local File PWRKPNH     [PWE] : Endif
If clalev([F:PWR])=0  : Local File PWRKPND     [PWR] : Endif
If clalev([F:PWQ])=0  : Local File PWRKPOQ     [PWQ] : Endif
#----- Fichier pour pièces automatiques de comptabilité -----#
Local File PORDER    [TB0]
Local File PORDERQ   [TB1]
Local File CPTANALIN [TB2]
#----- Récupération du nombre maximum de lignes d'écriture par pièce -----#
Local File ACTIV   [ACV]
Read [ACV] CODACT="GAS" : If fstat  Raz [F:ACV] : Endif
MAXI=max([F:ACV]DIME-20,10) : # Pour extension future
Close Local File   [ACV]

# Issue X3-57740 - 2017-11-08 by MUARN : Pb Legislation
Raz GSOC_ACTIVE : GFCY=GFCYDEF(6) : Gosub CHARG_PARAM
Return


#--------------------------------------#
# Initialisation de la date d'extourne #
#--------------------------------------#
$DATE_EXTOURNE
If dim(SOCIETE) <0 Local  Char    SOCIETE(GLONCPY) : Endif
If dim(DAT)     <0 Local  Date    DAT              : Endif
If dim(EXERCICE)<0 Local  Decimal EXERCICE         : Endif
If dim(PERIODE) <0 Local  Decimal PERIODE          : Endif
If dim(SITE)    <0 Local  Char    SITE(GLONFCY)    : Endif
If dim(VALPAR)  <0 Local  Char    VALPAR(30)       : Endif
If [M:DIA]XFCYFLG=1
  SITE=[M:DIA]RCPFCY
  Call GETSOC(SITE) From DEVSUB : SOCIETE=GSOCIETE
Elsif [M:DIA]XCPYFLG=1
  Read [CPY] CPY0=[M:DIA]CPY
  SITE=[F:CPY]MAIFCY
  SOCIETE=[M:DIA]CPY
  # Issue X3-57740 - 2017-11-08 by MUARN : inutile et Pb si pas de site par défau
  #Call GETSOC(SITE) From DEVSUB
# Issue X3-38252 - 2018-03-02 by SR : calcul date extourne
#--in case of a legislation context, we have to test if GFCYDEF(6)'s company has the right legislation
Elsif [M:DIA]LEG<>"" and [M:DIA]XCPYFLG=2 and [M:DIA]XFCYFLG=2
  Local Integer WCPODEFFCY : WCPODEFFCY = [V]CST_AYES
  Raz [M:DIA]EXTOURNE
  SOCIETE = ""
  SITE=GFCYDEF(6)
  If SITE<>""
    Read [F:FCY]FCY0=SITE
    If fstat : Raz [F:FCY]
      GERR=2 #--set as warning
      GMESSAGE = mess(77,123,1)-"'"+SITE+"'"-":"-mess(23,100,1)
    Endif
    SOCIETE = [F:FCY]LEGCPY
  Else
    SOCIETE = GDEFSOC
    WCPODEFFCY = [V]CST_ANO
  Endif

  If SOCIETE<>""
    Read [F:CPY]CPY0=SOCIETE
    If fstat : Raz [F:CPY] : Endif
    If [F:CPY]LEG<>"" and [F:CPY]LEG<>[M:DIA]LEG
      mkstat = 2
      GERR=2
      If WCPODEFFCY=[V]CST_AYES
        GMESSAGE = mess(77,123,1)-"'"+SITE+"'"-":"-mess(171,187,1)
      Else
        GMESSAGE = mess(180,124,1)-"'"+SOCIETE+"'"-":"-mess(171,187,1)
      Endif
      Raz SOCIETE
    Endif
  Endif

  #-- ! Keep if and don't use else because of the Raz SOciete further up !
  If SOCIETE=""
    #--if not a default site for the actual leg, read the first company of the current leg
    Filter [F:CPY] Where LEG=[M:DIA]LEG
    Read [F:CPY] First
    If fstat : Raz [F:CPY] : Endif
    SOCIETE = [F:CPY]CPY
    Filter [F:CPY]
  Endif

  GSOCIETE = SOCIETE : GCURLEG = [M:DIA]LEG
  Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV
  GCURFCY = SITE
# End issue X3-38252

Else
  SITE=GFCYDEF(2)
  Call GETSOC(SITE) From DEVSUB : SOCIETE=GSOCIETE
Endif
DAT=[M:DIA]ACCDAT
# Issue X3-38252 - 2018-03-02 by SR : calcul date extourne
Raz [F:PER] #--Raz of [F:PER]
Call GETPERSOC(SOCIETE,GTYPGEN,DAT,EXERCICE,PERIODE) From CPTSUB
[M:DIA]EXTOURNE=[F:PER]PEREND+1
If [M:DIA]EXTOURNE<=[M:DIA]ACCDAT
  [M:DIA]EXTOURNE=addmonth(gdat$(1,month([M:DIA]ACCDAT),year([M:DIA]ACCDAT)),1)
Endif
Return


#--------------------------------------#
# Chargement des zones pour engagement #
#--------------------------------------#
$CHARG_ENGAGEMENT
#If [M:DIA]TYP=1 & [F:PND]POHNUM<>"" & GOPTCANA>0 & [F:PWR]ACCANA<>""
#-----
WCRIT_CHARGPWR="[M:DIA]TYP=1 & [F:PND]POHNUM<>'' & GOPTCANA>0 & [F:PWR]ACCANA<>''"
GPOINT="PWRCRIT" : Gosub ENTREE From EXEFNC
If parse(WCRIT_CHARGPWR)
  Call ECR_TRACE("Filter error WCRIT_CHARGPWR",1) From GESECRAN
  WCRIT_CHARGPWR="[M:DIA]TYP=1 & [F:PND]POHNUM<>'' & GOPTCANA>0 & [F:PWR]ACCANA<>''"
Endif
#-----
If evalue(WCRIT_CHARGPWR)
  If [F:TB1]POHNUM<>[F:PND]POHNUM |
&    [F:TB1]POPLIN<>[F:PND]POPLIN |
&    [F:TB1]POQSEQ<>[F:PND]POQSEQ
    Read [TB1] POQ0=[F:PND]POHNUM;[F:PND]POPLIN;[F:PND]POQSEQ
    If fstat  Raz [F:TB1] : Endif
  Endif
  #-----
  If [F:TB1]CMMNUM<>"" & ([F:TB1]LINCLEFLG<>2 | [F:TB1]RCPCLEFLG=2)
    If [F:TB1]POHTYP<>2
      Read [POP] POP0=[F:PND]POHNUM;[F:PND]POPLIN;[F:PND]POQSEQ
      If fstat Raz [F:POP] : Return : Endif
    Else
      Filter [POP] Where POHNUM =[F:PND]POHNUM
&                      & POPLIN =[F:PND]POPLIN
&                      & POPDAT>=[F:TB1]DEMRCPDAT
      Read [POP] POP1 First
      Filter [POP]
      If fstat Raz [F:POP] : Return : Endif
    Endif
    #----- Calcul de la qté UA à désengager -----#
    CREFLG=0
    CLEFIC=[F:PND]POHNUM-num$([F:PND]POPLIN)-num$([F:PND]POQSEQ)
    WMSG=mess(12,100,1)-"PWRKPOQ"-CLEFIC : # Erreur d'accès sur le fichier ...
    #----- Lecture fichier de travail détail qtés engagement par commande -----#
    Readlock [PWQ] PWQ0=1;[F:PND]POHNUM;[F:PND]POPLIN;[F:PND]POQSEQ
    If fstat=1
      GOK=0 : Gosub AB_TRANSACTION_MSG : Return
    Elsif fstat
      Raz [F:PWQ]
      [F:PWQ]TYPORI  =1              : # Origine AAR
      [F:PWQ]POHNUM  =[F:PND]POHNUM
      [F:PWQ]POPLIN  =[F:PND]POPLIN
      [F:PWQ]POQSEQ  =[F:PND]POQSEQ
      [F:PWQ]EXTOURNE=[M:DIA]EXTOURNE
      CREFLG=1
    Elsif [M:DIA]ACCDAT>=[F:PWQ]EXTOURNE
      Raz [F:PWQ]TMPQTYPUU,[F:PWQ]CMMQTYPUU : [F:PWQ]EXTOURNE=[M:DIA]EXTOURNE : # Par sécurité !
    Endif
    GBIDD1 =[F:PND]QTYPUU
    GBIDD1-=([F:PWQ]CMMQTYPUU+[F:PWQ]TMPQTYPUU)
    If [F:PND]QTYPUU-[F:PND]INVQTYPUU<GBIDD1
      [F:PWR]QTYBUDLIN=[F:PND]QTYPUU-[F:PND]INVQTYPUU
    Else
      [F:PWR]QTYBUDLIN=GBIDD1
    Endif
    #----- Ajout des qtés facturées postérieures à la date de borne -----#
    [F:PWR]QTYBUDLIN+=(WQUANTITY-([F:PND]QTYPUU-[F:PND]INVQTYPUU))
    #-----
    If [F:PWR]QTYBUDLIN<0  Raz [F:PWR]QTYBUDLIN : Endif
    [F:PWQ]TMPQTYPUU+=[F:PWR]QTYBUDLIN
    CLEFIC=[F:PND]POHNUM-num$([F:PND]POPLIN)-num$([F:PND]POQSEQ)
    WMSG=mess(13,100,1)-"PWRKPOQ"-CLEFIC : # Erreur d'écriture sur le fichier ...
    If CREFLG=1  Write [PWQ] Else Rewrite [PWQ] : Endif
    If fstat
      GOK=0 : Call FSTA("PWQ") From GLOCK
      Gosub AB_TRANSACTION_MSG
      Return
    Endif
    If [F:PWR]QTYBUDLIN<>0
      #----- Calcul du montant à désengager -----#
      Case [F:TB1]CMMTAX
        When 2       : #----- Engagement HT + taxes non déductibles
          [F:PWR]AMTCUR=[F:TB1]LINAMT
          If [F:TB1]LINATIAMT>[F:TB1]LINAMT
            [F:PWR]AMTCUR+=([F:TB1]AMTTAXLIN1-[F:TB1]DEDTAXLIN1)
            [F:PWR]AMTCUR+=([F:TB1]AMTTAXLIN2-[F:TB1]DEDTAXLIN2)
            [F:PWR]AMTCUR+=([F:TB1]AMTTAXLIN3-[F:TB1]DEDTAXLIN3)
            [F:PWR]AMTCUR+=([F:TB1]AMTTAXRCP -[F:TB1]DEDTAXRCP )
            [F:PWR]AMTCUR+=([F:TB1]AMTTAXISS -[F:TB1]DEDTAXISS )
            [F:PWR]AMTCUR+=([F:TB1]AMTTAXOTH1-[F:TB1]DEDTAXOTH1)
            [F:PWR]AMTCUR+=([F:TB1]AMTTAXOTH2-[F:TB1]DEDTAXOTH2)
          Endif
          If [F:TB1]QTYPUU=0 [F:TB1]QTYPUU=1 : Endif
          [F:PWR]AMTCUR=[F:PWR]AMTCUR*[F:PWR]QTYBUDLIN/[F:TB1]QTYPUU
        When 3       : #----- Engagement TTC
          If [F:TB1]QTYPUU=0 [F:TB1]QTYPUU=1 : Endif
          [F:PWR]AMTCUR=[F:TB1]LINATIAMT*[F:PWR]QTYBUDLIN/[F:TB1]QTYPUU
        When Default : #----- Engagement HT
          If [F:TB1]UOMPUUCOE=0  [F:TB1]UOMPUUCOE=1 : Endif
          [F:PWR]AMTCUR=[F:PWR]QTYBUDLIN*[F:POP]NETPRI/[F:TB1]UOMPUUCOE
      Endcase
      Call ARRDEV([F:PWR]AMTCUR,[F:PWR]CUR) From TRTDIV
      #-----
      Raz WMT1
      If [F:TB1]CMMNUM<>""
        #----- Recherche des engagements pour en déduire le taux de conversion -----#
        Raz WMT1, WMT2
        For [CMD] CMD0 Where NUM=[F:TB1]CMMNUM
          WMT1+=[F:CMD]AMTCUR
          WMT2+=[F:CMD]AMTLED
        Next
        If WMT1<>0
          If WMT1<>[F:PWR]AMTCUR
            [F:PWR]AMTLED=[F:PWR]AMTCUR*(WMT2/WMT1)
            Call ARRDEV([F:PWR]AMTLED,WDEVLED) From TRTDIV
          Else
            [F:PWR]AMTLED=WMT2
          Endif
        Endif
      Endif
      If WMT1=0
        #----- Lecture entête commande si nécessaire -----#
        If [F:TB0]POHNUM<>[F:PND]POHNUM
          Read [TB0] POH0=[F:PND]POHNUM
          If fstat  Raz [F:TB0] : Endif
        Endif
        #----- Engagements non trouvés : Conversion avec taux devise -----#
        If WDEVLED<>[F:PWR]CUR
          Call CONVERT([F:PWR]CUR,WDEVLED,GLOCALDEV,[F:TB0]CHGTYP,[F:TB0]ORDDAT,
&                      [F:PWR]AMTCUR,[F:PWR]AMTLED,STAT) From TRTDEV
        Else
          [F:PWR]AMTLED=[F:PWR]AMTCUR
        Endif
      Endif
      If [F:TB1]PUU<>[F:PWR]GLU
        Call PCAL_QTY([F:PWR]QTYBUDLIN,[F:TB1]PUU,WQTYGLU,[F:PWR]GLU,
&                     [F:PND]ITMREF,[F:PND]BPSNUM,1,GBIDD1) From TRTACHQTE1
        If [F:TCO]UOM1=""
          Call PCAL_QTY([F:PWR]QTYBUDLIN,[F:TB1]PUU,WQTYGLU,[F:TB1]STU,
&                       [F:PND]ITMREF,[F:PND]BPSNUM,1,GBIDD1) From TRTACHQTE1
          If [F:TB1]STU<>[F:PWR]GLU
            Call PCAL_QTY(WQTYGLU,[F:TB1]STU,[F:PWR]QTYBUDLIN,[F:PWR]GLU,
&                         [F:PND]ITMREF,[F:PND]BPSNUM,1,GBIDD1) From TRTACHQTE1
            #----- Coefficient de convertion introuvable ! -----#
            If [F:TCO]UOM1="" & [M:DIA]TRACE=2
              Call ECR_TRACE ([F:TB1]STU-"->"-[F:PWR]GLU-mess(473,199,1),0) From GESECRAN
            Endif
          Else
            [F:PWR]QTYBUDLIN=WQTYGLU
          Endif
        Else
          [F:PWR]QTYBUDLIN=WQTYGLU
        Endif
      Endif
    Endif
  Endif
Endif
Return


###########################################################
# Sous-Programmes des actions sur champ de l'écran PNHPST #
###########################################################

Subprog AV_XCPYFLG(VALEUR)
#------------------------------------#
# Avant zone du flag toutes sociétés #
# ---------------------------------- #
# Complément de l'initialisation des #
# champs faite dans INIT_DIA et      #
# grisage des champs                 #
#------------------------------------#
Variable Integer  VALEUR

If !GHISTO
  Actzo [M]
  If varinit([M]XCPYFLG) & [M]XCPYFLG<>0
    If func AFNC.ACTIV("LEG") | ([M]XCPYFLG=1 & GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE)
       # 71937 : Multilégislation
       #Grizo XCPYFLG
    Endif
    If [M]XCPYFLG=2 & [M]XFCYFLG=2  Grizo XFCYFLG : Endif
    If [M]XFCYFLG=1
      Call INIALLFCY([M]XFCYFLG,[M]CPY) From FUNPNH
      If mkstat  Grizo XFCYFLG : Raz mkstat : Endif
    Endif
    If [M]XCPYFLG=2  Diszo CPY      : Endif
    If [M]XFCYFLG=2  Diszo RCPFCY   : Endif
    If [M]TYP<>1     Grizo EXTOURNE : Endif

    If [M:DIA]CPY<>"" : Diszo [M:DIA]LEG : Endif :   # 71937 : Multilégislation

    End
  Endif
Endif

#----- Traitement des champs société -----#
[M]XCPYFLG=1
VALEUR=1
If func AFNC.ACTIV("LEG") | (GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE)
  Grizo XCPYFLG
Endif
Call INICPY([M]CPY) From CPTSUB
Affzo CPY : If dim([M]ZCPY)>0  Affzo ZCPY : Endif
If GNBAUZ=1 Diszo CPY : Endif
#----- Traitement des champs site -----#
Call INIALLFCY([M]XFCYFLG,[M]CPY) From FUNPNH
If mkstat
  [M]XFCYFLG=1
  Grizo XFCYFLG : Raz mkstat
Endif
If [M]XFCYFLG=1
  Call INIFCY([M]RCPFCY,[M]CPY) From CPTSUB
  Affzo RCPFCY : If dim([M]ZRCPFCY)>0  Affzo ZRCPFCY : Endif
Endif
If GNBAUZ=1 | [M]XFCYFLG=2 Diszo RCPFCY : Endif
#----- Traitement champ état des écritures -----#
If [M]TYP<>1 Grizo STA : Endif
#----- Initialisation type pièce et journal -----#
Gosub INIT_TYPPCEJOU
#----- Traitement date d'extourne -----#
If [M]TYP<>1
  Effzo EXTOURNE : Grizo EXTOURNE
Else
  Actzo EXTOURNE
Endif
End


Subprog AM_XCPYFLG(VALEUR)
#-------------------------------------#
# Après modif du flag toutes sociétés #
#-------------------------------------#
Variable Integer  VALEUR
If VALEUR=1
  Actzo CPY
  Call INICPY([M:DIA]CPY) From CPTSUB
  Affzo [DIA]CPY : If dim([M:DIA]ZCPY)>0  Affzo [DIA]ZCPY : Endif
  If GNBAUZ=1 Diszo [DIA]CPY : Endif
  Call INIALLFCY([M:DIA]XFCYFLG,[M:DIA]CPY) From FUNPNH
  If mkstat
    Grizo [DIA]XFCYFLG : Actzo [DIA]RCPFCY : Raz mkstat
    Call INIFCY([M:DIA]RCPFCY,[M:DIA]CPY) From CPTSUB
    Affzo [DIA]RCPFCY : If dim([M:DIA]ZRCPFCY)>0  Affzo [DIA]ZRCPFCY : Endif
    If GNBAUZ=1 Diszo [DIA]RCPFCY : Endif
  Else
    Actzo [DIA]XFCYFLG
    If [M:DIA]XFCYFLG=1
      Call INIFCY([M:DIA]RCPFCY,[M:DIA]CPY) From CPTSUB
      Affzo [DIA]RCPFCY : If dim([M:DIA]ZRCPFCY)>0  Affzo [DIA]ZRCPFCY : Endif
    Endif
  Endif
Else
  [M:DIA]XFCYFLG=2 : Affzo [DIA]XFCYFLG : Grizo [DIA]XFCYFLG
  Effzo [DIA]CPY, RCPFCY
  # Issue X3-57740 - 2017-11-08 by MUARN : Pb Legislation
  Raz GSOCIETE, GCURLEG, GFCY, GCURFCY
  # 71937 : Multilégislation
  Effzo [M:DIA]LEG
  If dim([M:DIA]ZLEG)>0     Effzo [DIA]ZLEG    : Endif
  # 71937

  If dim([M:DIA]ZCPY)>0     Effzo [DIA]ZCPY    : Endif
  If dim([M:DIA]ZRCPFCY)>0  Effzo [DIA]ZRCPFCY : Endif
  Diszo [DIA]CPY, RCPFCY
  If [M:DIA]TYP=1 : Actzo STA : Endif
Endif
#----- Initialisation type pièce et journal -----#
Gosub INIT_TYPPCEJOU

# 71937 : Multilégislation
[M]XCPYFLG=VALEUR : Gosub GRILEG
Affzo [M:DIA]LEG
# 71937

If !GIMPORT  Affzo [DIA]TYPPCE, JOURNAL : Endif
End


Subprog C_CPY(VALEUR)
#------------------------------------------------------------------#
# Contrôle société : Obligatoire si flag toutes sociétés non coché #
#------------------------------------------------------------------#
Variable Char    VALEUR()
If [M]XCPYFLG<>2 & VALEUR="" mkstat=1 : End : Endif
End


Subprog AM_CPY(VALEUR)
#---------------------------#
# Après modif de la société #
#---------------------------#
Variable Char    VALEUR()
Call INIALLFCY([M:DIA]XFCYFLG,VALEUR) From FUNPNH
If mkstat
  Grizo [DIA]XFCYFLG : Actzo [DIA]RCPFCY : Raz mkstat
  Call INIFCY([M:DIA]RCPFCY,VALEUR) From CPTSUB
  Affzo [DIA]RCPFCY : If dim([M:DIA]ZRCPFCY)>0  Affzo [DIA]ZRCPFCY : Endif
  If GNBAUZ=1 Diszo [DIA]RCPFCY : Endif
Else
  Actzo [DIA]XFCYFLG
  If [M]XFCYFLG=1
    Raz [M:DIA]RCPFCY       : # 71937 : Multilégislation
    Call INIFCY([M:DIA]RCPFCY,VALEUR) From CPTSUB
    Affzo [DIA]RCPFCY : If dim([M:DIA]ZRCPFCY)>0  Affzo [DIA]ZRCPFCY : Endif
  Endif
Endif
If  [M:DIA]TYP=1
 If func AFNC.PARAM("FRADGI",VALEUR)="2" : # Paramètre à Oui
  [M:DIA]STA = 2 : Grizo STA
  Affzo STA
 Else
  Actzo STA
 Endif
Endif
#----- Initialisation type pièce et journal -----#
[M:DIA]CPY=VALEUR
Gosub INIT_TYPPCEJOU
If !GIMPORT  Affzo [DIA]TYPPCE, JOURNAL : Endif
#-----

# 71937 : Multilégislation
Gosub GRILEG
Affzo [M:DIA]LEG
# 71937

# Issue X3-57740 - 2017-11-08 by MUARN : Pb Legislation
If [F:FCY]LEGCPY<>VALEUR
  Filter [F:FCY] Where LEGCPY=VALEUR
  Read [F:FCY] First
  If fstat : Raz [F:FCY] : Endif
  Filter [F:FCY]
Endif
If [F:FCY]FCY<>""
  Raz GSOC_ACTIVE : GFCY=[F:FCY]FCY : Gosub CHARG_PARAM
Endif
# End issue X3-57740
End

# 71937 : Multilégislation
# ---------------------------- Législation -----------------------------
Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG=VALEUR
End

# 71937 : Multilégislation
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()

Gosub INIT_TYPPCEJOU
Affzo [DIA]TYPPCE, JOURNAL

End

Subprog AM_XFCYFLG(VALEUR)
#--------------------------------#
# Après modif du flag tous sites #
#--------------------------------#
Variable Integer VALEUR
If VALEUR=1
  Actzo [DIA]RCPFCY
  Call INIFCY([M:DIA]RCPFCY,[M:DIA]CPY) From CPTSUB
  Affzo [DIA]RCPFCY : If dim([M:DIA]ZRCPFCY)>0  Affzo [DIA]ZRCPFCY : Endif
  If GNBAUZ=1 Diszo [DIA]RCPFCY : Endif
Else
  Effzo [DIA]RCPFCY : If dim([M:DIA]ZRCPFCY)>0  Effzo [DIA]ZRCPFCY : Endif
  Diszo [DIA]RCPFCY
Endif
#----- Initialisation type pièce et journal -----#
Gosub INIT_TYPPCEJOU
If !GIMPORT  Affzo [DIA]TYPPCE, JOURNAL : Endif

# 71937 : Multilégislation
Gosub GRILEG
Affzo [M:DIA]LEG
# 71937

#-----
End


Subprog C_RCPFCY(VALEUR)
#----------------------------------------------#
# Contrôle que le site est un site de stockage #
#----------------------------------------------#
Variable Char     VALEUR
If [M]XFCYFLG<>2 & VALEUR=""
  mkstat=1 : End : # Obligatoire si flag tous sites non coché
Endif
If [F:FCY]WRHFLG<>2
  mkstat=1 : GMESSAGE=mess(58,199,1) : End : # Ce site n'est pas un dépôt
Endif
End


Subprog AM_RCPFCY(VALEUR)
#---------------------#
# Après modif du site #
#---------------------#
Variable Char    VALEUR()
#----- Initialisation type pièce et journal -----#
[M:DIA]RCPFCY=VALEUR
Gosub INIT_TYPPCEJOU
If !GIMPORT  Affzo [DIA]TYPPCE, JOURNAL : Endif
#-----

# 71937 : Multilégislation
Gosub GRILEG
Affzo [M:DIA]LEG
# 71937

# Issue X3-57740 - 2017-11-08 by MUARN : Pb Legislation
If VALEUR<>""
  Raz GSOC_ACTIVE : GFCY=VALEUR : Gosub CHARG_PARAM
Endif
# End issue X3-57740

End


Subprog AS_BPSEND(VALEUR)
#------------------------------#
# Avant-saisie fournisseur fin #
#------------------------------#
Variable Char    VALEUR()
If VALEUR="" | VALEUR<[M]BPSSTR : VALEUR=[M]BPSSTR : Endif
End


Subprog C_BPSEND(VALEUR)
#--------------------------#
# Contrôle fournisseur fin #
#--------------------------#
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]BPSSTR
 GMESSAGE = mess(44,199,1) :# La borne fin est inferieure a la borne debut
 mkstat = 1
Endif
End


Subprog AM_TYP(VALEUR)
#-----------------------------------#
# Après modif du type de génération #
#-----------------------------------#
Variable Integer VALEUR
If VALEUR<>1 Grizo [DIA]STA Else Actzo [DIA]STA : Endif
If VALEUR = 1
 If [M]CPY<>""
  If func AFNC.PARAM("FRADGI",[M]CPY)="2" : # Paramètre à Oui
   [M]STA = 2 : Grizo STA
  Else : Actzo STA
  Endif
 Else : Actzo STA
 Endif
Endif
#----- Traitement date d'extourne -----#
If VALEUR<>1
  Effzo [DIA]EXTOURNE : Grizo [DIA]EXTOURNE
Else
  Gosub DATE_EXTOURNE
  Actzo [DIA]EXTOURNE
Endif
#----- Initialisation type pièce et journal -----#
[M:DIA]TYP=VALEUR
Gosub INIT_TYPPCEJOU
#----- Affichage type de pèce et journal et date d'extourne -----#
If !GIMPORT  Affzo [DIA]TYPPCE, JOURNAL, EXTOURNE : Endif
End


Subprog C_TYPPCE(VALEUR)
#------------------------#
# Contrôle type de pièce #
#------------------------#
Variable Char    VALEUR()

# 71937 : Multilégislation
#Call LECTURE("GTE",VALEUR,"") From CONTOBJ
Local Integer WRET
Call LEC_GTE_LEG([M:DIA]LEG,VALEUR,WRET) From TRTLECLEG

Call CONTEXE([F:GTE]ACS)      From CPTSUB
If mkstat  End : Endif
If [M:DIA]TYP=1 & [F:GTE]VCRREA<>2
  #----- Type de pièce interdit en réel -----#
  GMESSAGE=mess(33,107,1) : mkstat=2 : End
Elsif [M:DIA]TYP>=2 & [F:GTE]VCRSIM<>2
  #----- Type de pièce interdit en simulation -----#
  GMESSAGE=mess(32,107,1) : mkstat=2 : End
Endif
End


Subprog C_JOURNAL(VALEUR)
#---------------------#
# Contrôle du journal #
#---------------------#
Variable Char    VALEUR()
Call CONTEXE([F:JOU]ACS) From CPTSUB
If mkstat  GMESSAGE=VALEUR-GMESSAGE : Return : Endif
If [M:DIA]CPY<>"" & [M:DIA]RCPFCY<>""
  Call VERSOC([F:JOU]FCY,[M:DIA]CPY,[M:DIA]RCPFCY,VALEUR) From CFYSUB
  If mkstat  End : Endif
Endif

# 71937 : Multilégislation
#Call LECTURE("GTE",[M:DIA]TYPPCE,"") From CONTOBJ
Local Integer WRET
Call LEC_GTE_LEG([M:DIA]LEG,[M:DIA]TYPPCE,WRET) From TRTLECLEG

If [F:GTE]AUZJOU([F:JOU]TYP-1)<>2
  GMESSAGE=[F:JOU]JOU-mess(8,106,1) : # Journal non autorisé sur ce type de pièce
  mkstat=2 : End
Endif
End

# Issue X3-57740 - 2017-11-08 by MUARN : memeo et globales
#######################################################################
#--------------------------------------------------------------------------#
# Chargement des paramètres avec GFCY = Site de la facture                 #
# ------------------------------------------------------------------------ #
# Chargement des globales référenciels, comptes et sections de la société  #
# Chargement des paramètres de localisation                                #
# ------------------------------------------------------------------------ #
$CHARG_PARAM
Local  Char     PARAM2(10)
# --- Chargement GSOCIETE GFINRSP GCURLEG GCURFCY (GETSOC) GLOCALDEV (GETDEV)
# --- Chargement des globales référenciels, comptes et sections de la société
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
Return
# End issue X3-57740

#-----------------------------------------------#
# Initialisation du type de pièce et du journal #
#-----------------------------------------------#
$INIT_TYPPCEJOU
#-----
Local Integer WSTAT
Local Char    WPCEAUTO(GLONGAU)
#----- Chargement du site financier -----#
If [M:DIA]CPY="" & [M:DIA]RCPFCY=""
  [M:DIA]FCY=""
Elsif [M:DIA]CPY=""
  Call GETSOC([M:DIA]RCPFCY) From DEVSUB
  [M:DIA]FCY=GFINRSP
Else
  Read [CPY] CPY0=[M:DIA]CPY
  If [F:CPY]MAIFCY=""                                 : # 71937
    GCURLEG=[F:CPY]LEG                                : # 71937
  Else                                                : # 71937
    Call GETSOC([F:CPY]MAIFCY) From DEVSUB
    [M:DIA]FCY=GFINRSP
  Endif                                               : # 71937
Endif
#----- Recherche code de la pièce auto ----#
If [M]FCY<>""
  Call PARAM([M:DIA]FCY,"GAUPNH",WPCEAUTO) From ADOVAL
Elsif [M]CPY<>""
  Call PARAM([M:DIA]CPY,"GAUPNH",WPCEAUTO) From ADOVAL
Else
  Call PARAM("","GAUPNH",WPCEAUTO) From ADOVAL
Endif
If WPCEAUTO=""  WPCEAUTO="PNH" : Endif
#----- Traitement type de pièce -----#
If [M:DIA]TYP<>1
  #----- Paramètre TYPACC : type de pièce utilisé en simulation -----#
  If [M:DIA]FCY<>""
    Call PARAM([M:DIA]FCY,"TYPACC",[M:DIA]TYPPCE) From ADOVAL
  Elsif [M:DIA]CPY<>""
    Call PARAM([M:DIA]CPY,"TYPACC",[M:DIA]TYPPCE) From ADOVAL
  Else
    Call PARAM("","TYPACC",[M:DIA]TYPPCE) From ADOVAL
  Endif
Else
  #----- Pièce auto PNH : Avoirs à recevoir -----#
  Call LECTURE("GAU",WPCEAUTO,"") From CONTOBJ
  If !clalev([F:TB0]) : Local File =[F:GAU]TBL [TB0] : Endif
  Gosub OUVRE From ="WMGAU"+[F:GAU]COD
  Gosub LIENS From ="WMGAU"+[F:GAU]COD
  Call EVAL_CHAR([M:DIA]TYPPCE,"GTE",1,0,"",WSTAT) From CPTAUTO
Endif
#----- Traitement du journal -----#
Raz [M:DIA]JOURNAL
If [M:DIA]TYP=1
  Call LECTURE("GAU",WPCEAUTO,"") From CONTOBJ
  Call EVAL_CHAR([M:DIA]JOURNAL,"JOU",1,0,"",WSTAT) From CPTAUTO
Endif
If [M:DIA]JOURNAL=""

  # 71937 : Multilégislation
  #Call LECTURE("GTE",[M:DIA]TYPPCE,"") From CONTOBJ
  Local Integer WRET
  Call LEC_GTE_LEG([M:DIA]LEG,[M:DIA]TYPPCE,WRET) From TRTLECLEG

  [M:DIA]JOURNAL=[F:GTE]DEFJOU
Endif
#-----

If [M:DIA]CPY<>"" : [M]LEG=GCURLEG : Diszo [M:DIA]LEG : Endif :   # 71937 : Multilégislation

Return


Subprog C_ACCDAT(VALEUR)
#------------------------#
# Contrôle date de pièce #
#------------------------#
Variable Date    VALEUR
If VALEUR<[M:DIA]BORNE
  GMESSAGE=mess(564,199,1) : mkstat=1 : End
Endif
End


Subprog C_EXTOURNE(VALEUR)
#--------------------------#
# Contrôle date d'extourne #
#--------------------------#
Variable Date    VALEUR
#-----
If VALEUR<=[M:DIA]ACCDAT
  GMESSAGE=mess(565,199,1) : mkstat=1 : End
Endif
#-----
Local  Char    SOCIETE(GLONCPY)
Local  Decimal EXERCICE
Local  Decimal PERIODE
Local  Char    SITE(GLONFCY)
#-----
If [M:DIA]XFCYFLG=1
  SITE=[M:DIA]RCPFCY
  Call GETSOC(SITE) From DEVSUB : SOCIETE=GSOCIETE
Elsif [M:DIA]XCPYFLG=1
  Read [CPY] CPY0=[M:DIA]CPY
  SITE=[F:CPY]MAIFCY
  SOCIETE=[M:DIA]CPY
  Call GETSOC(SITE) From DEVSUB
Else
  SITE=GFCYDEF(2)
  Call GETSOC(SITE) From DEVSUB : SOCIETE=GSOCIETE
Endif
#----- Permet d'alimenter la classe [F:PER] -----#
Call GETPERSOC(SOCIETE,GTYPGEN,[M:DIA]ACCDAT,EXERCICE,PERIODE) From CPTSUB
#-----
If VALEUR<=[F:PER]PEREND
  GMESSAGE=mess(565,199,1) : mkstat=1 : End
Endif
#-----
End


#############################################
# Contrôle si tous les sites sont autorisés #
#############################################
Subprog INIALLFCY(VALEUR,SOC)
Variable Integer  VALEUR
Value    Char     SOC
Local    Integer  I, OK
If GUSRFCY(1)="\"  End : Endif
If GNBAUZ=GNBSITE  End : Endif

If clalev([F:FGR])=0  Local File FACGROUP [FGR] : Endif
If clalev([F:CPY])=0  Local File COMPANY  [CPY] : Endif
If [L]SOC<>""
  OK=1
  Call LECTURE("CPY",[L]SOC,"") From CONTOBJ
  If [F:CPY]CPYLEGFLG=2  : # Société juridique
    For I=1 To GNBSITE
      If [L]SOC=GSOCSITE(I) & !find(GSITE(I),GUSRFCY(1..GNBAUZ))
        OK=0 : Break
      Endif
    Next I
  Else
    For [FGR]FGR0 Where CPY=[L]SOC
      If !find([F:FGR]FCY,GUSRFCY(1..GNBAUZ))
        OK=0 : Break
      Endif
    Next
  Endif
Endif
If !OK
  VALEUR=1 : mkstat=2 : End : # Tous les sites de la société ne sont pas accessibles
Endif
End


###################
# Si erreur Batch #
###################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

