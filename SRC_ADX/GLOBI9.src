#########################################################
Funprog CAL_DAT_ISNOTNULL( PDAT )
# - Objet  : Renvoie 1 si la date n'est pas nulle.
#
# - Entrûˋe : Date û  tester
#
# - Sortie : 0 date nulle 1 date non nulle
#
#
Value Date     PDAT
Local Shortint RTRN
  RTRN = 0
  If ( PDAT <> [0/0/0] ) Then : RTRN = 1  : Endif
End RTRN

#
#########################################################
Funprog CAL_DAT_ISNULL( PDAT )
# - Objet  : Renvoie 1 si la date est nulle.
#
# - Entrûˋe : Date û  tester
#
# - Sortie : 0 date non nulle 1 date nulle
#
#
Value Date      PDAT
Local Shortint  RTRN
  RTRN = 0
  If ( PDAT = [0/0/0] ) Then : RTRN = 1  : Endif
End RTRN

#########################################################
Funprog CAL_DAT_INSIDE( PDAT, PDEB, PFIN, PBORNES )
# - Objet  : Renvoie 1 si la date se situe dans l'intervalle de dates.
#
# - Entrûˋe : Date û  situer
#            Borne dûˋbut de l'intervalle
#            Borne fin de l'intervalle
#            Prise en compte des bornes : (I)ncluses ou (E)xclues
# - Sortie : 0 hors intervalle 1 dans l'intervalle
#
#
Value    Date     PDAT, PDEB, PFIN
Value    Char     PBORNES
Local    Shortint RTRN : RTRN = 0



  #----------------------------------
  If ( PDAT <> [0/0/0] and PDEB <> [0/0/0]  and PFIN <> [0/0/0] ) Then
    If ( PBORNES = "I" and PDAT >= PDEB and PDAT <= PFIN ) Then : RTRN = 1 : Endif
    If ( PBORNES = "E" and PDAT >  PDEB and PDAT <  PFIN ) Then : RTRN = 1 : Endif
  Endif
  #----------------------------------

End RTRN

#
#########################################################
Funprog CAL_DAT_BISS( PANN )
# - Objet  : Renvoie le nombre de jours de l'annûˋe passûˋe en paramû´tre
#            Permet en outre de dûˋterminer si l'annûˋe est bissextile.
# - Entrûˋe : Annûˋe
# - Sortie : Nombre de jours dans l'annûˋe
#   Boite noire DTBISS (as400)
#
Value Integer    PANN
Local Shortint   RTRN
  RTRN = gdat$(31,12,PANN)-gdat$(01,01,PANN)+1
End RTRN

#
#########################################################
Funprog CAL_DAT_DERN( PDAT, PTYP )
#
# - Objet  : Rend la date correspondant au dernier jour de l'annûˋe, du mois,
#            de la quinzaine ou de la semaine
#            en fonction de la date et du type passûˋs en paramû´tre.
# - Entrûˋe : Date
#            Type "Y" Annûˋe, "M" Mois, "Q" Demi mois, "W" Semaine, "T" 1/2 trimestre
# - Sortie : Date correspondant au dernier jour de l'annûˋe ou du mois
#   Boite noire DTDERN (as400)
#
Value Date    PDAT
Value Char    PTYP
Local Date    RTRN

Local Decimal WRNG

  RTRN = [0/0/0]
  #----------------------------------
  If ( PDAT <> [0/0/0] ) Then
    Case PTYP
      When "Y"     : RTRN = gdat$(31,12,year(PDAT))
      When "M"     : RTRN = eomonth(PDAT)
      When "Q"
        If ( day(PDAT) >= 01 and day(PDAT) <= 15 ) Then
          RTRN = gdat$(15,month(PDAT),year(PDAT))
        Else
          RTRN = eomonth(PDAT)
        Endif
      When "T"
        If    (PDAT > gdat$(15,11,year(PDAT))) Then
          RTRN = gdat$(31,12,year(PDAT))
        Elsif (PDAT > gdat$(30,09,year(PDAT))) Then
          RTRN = gdat$(15,11,year(PDAT))
        Elsif (PDAT > gdat$(15,08,year(PDAT))) Then
          RTRN = gdat$(30,09,year(PDAT))
        Elsif (PDAT > gdat$(30,06,year(PDAT))) Then
          RTRN = gdat$(15,08,year(PDAT))
        Elsif (PDAT > gdat$(15,05,year(PDAT))) Then
          RTRN = gdat$(30,06,year(PDAT))
        Elsif (PDAT > gdat$(31,03,year(PDAT))) Then
          RTRN = gdat$(15,05,year(PDAT))
        Elsif (PDAT > gdat$(15,02,year(PDAT))) Then
          RTRN = gdat$(31,03,year(PDAT))
        Else
          RTRN = gdat$(15,02,year(PDAT))
        Endif
      When "W"
        # FQ90048(2)
        # WRNG = (7-dayn(PDAT))
        # RTRN = func GLOBB9.CAL_DAT_PLUS( PDAT, WRNG, "D" )
        Local Integer WINCR : WFIN_SEM
        If ([M:DIV2]WEESTRDAY = 0 ) Then : [M:DIV2]WEESTRDAY = 1 : Endif
        Case [M:DIV2]WEESTRDAY
          When 1
            WFIN_SEM = 7
          When Default
            WFIN_SEM = [M:DIV2]WEESTRDAY - 1
        Endcase

        If ([M:DIV2]WEESTRDAY = 0 ) Then : [M:DIV2]WEESTRDAY = 1 : Endif
        RTRN = PDAT
        While dayn(RTRN) <> WFIN_SEM
          RTRN += 1
        Wend
      When Default : RTRN = [0/0/0]
    Endcase
  Endif
  #----------------------------------

End RTRN

#
#########################################################
Funprog CAL_DAT_ISENDOFMONTH( PDAT )
#
# - Objet  : Renvoie 1 si la date correspond û  une fin de mois.

# - Entrûˋe : Date
#
# - Sortie :
#
#   Boite noire
#
  Value Date    PDAT
  Local Integer LANN

    LANN = year(PDAT)
    If ( day(PDAT) = 31 or
&      ( day(PDAT) = 30 and ( month(PDAT)= 4 or month(PDAT)=6 or month(PDAT)= 9 or month(PDAT)= 11 )) or
&      ( day(PDAT) = 28 and month(PDAT) = 2 and func GLOBB9.CAL_DAT_BISS(LANN) = 365 ) ) or
&      ( day(PDAT) = 29 and month(PDAT) = 2  ) Then
      RTRN = 1
    Else
      RTRN = 0
    Endif

End RTRN

#
#########################################################
Funprog CAL_DAT_ISENDOFHLFM( PDAT )
#
# - Objet  : Renvoie 1 si la date correspond û  une fin de quinzaine.
#            Soit le 15 soit fin de mois.

# - Entrûˋe : Date
#
# - Sortie :
#
#   Boite noire
#
  Value Date    PDAT
  Local Integer RTRN
    If (day(PDAT) = 15 or func GLOBB9.CAL_DAT_ISENDOFMONTH(PDAT)) Then
      RTRN = 1
    Else
      RTRN = 0
    Endif
End RTRN

#
#########################################################
Funprog CAL_DAT_ISENDOFHLFQ( PDAT )
#
# - Objet  : Renvoie 1 si la date correspond û  une fin de 1/2 trimestre.
#            Soit le 15 soit fin de mois.

# - Entrûˋe : Date
#
# - Sortie :
#
#   Boite noire
#
  Value Date    PDAT

  Local Integer RTRN
  Local Integer WMOIS

    RTRN = 0
    WMOIS = month(PDAT)
    If ( WMOIS <> 1 and WMOIS <> 4 and WMOIS <> 7 and WMOIS <> 10) Then
      Local Integer WJOUR
      WJOUR = day(PDAT)
      If ( ( WJOUR = 15 and ( WMOIS = 2 or WMOIS =  5 or WMOIS = 8 or WMOIS = 11 ) ) or
&          ( WJOUR = 30 and ( WMOIS = 6 or WMOIS =  9 ) ) or
&          ( WJOUR = 31 and ( WMOIS = 3 or WMOIS = 12 ) ) ) Then
        RTRN = 1
      Endif
    Endif
End RTRN

#
#########################################################
Funprog CAL_DAT_ISENDOFWEEK( PDAT )
#
# - Objet  : Renvoie 1 si la date correspond û  une fin de semaine.

# - Entrûˋe : Date
#
# - Sortie :
#
#   Boite noire
#
  Value Date    PDAT

  Local Integer RTRN


# FQ90048(2)
#  If (dayn(PDAT) = 7) Then
#    RTRN = 1
#  Else
#    RTRN = 0
#  Endif

    Local Integer WFIN_SEM
    If ([M:DIV2]WEESTRDAY = 0 ) Then : [M:DIV2]WEESTRDAY = 1 : Endif
    # Dernier jour de la semaine
    Case [M:DIV2]WEESTRDAY
      When 1
        WFIN_SEM = 7
      When Default
        WFIN_SEM = [M:DIV2]WEESTRDAY - 1
    Endcase

    If (dayn(PDAT) = WFIN_SEM) Then
      RTRN = 1
    Else
      RTRN = 0
    Endif
End RTRN

#
#########################################################
Funprog CAL_DAT_ISBEGINNINGOFWEEK( PDAT )
#
# - Objet  : Renvoie 1 si la date correspond au dûˋbut de la semaine.

# - Entrûˋe : Date
#
# - Sortie :
#
#   Boite noire
#
  Value Date    PDAT

  Local Integer RTRN

# FQ90048(2)
#    If (dayn(PDAT) = 1) Then
#      RTRN = 1
#    Else
#      RTRN = 0
#    Endif

  If ([M:DIV2]WEESTRDAY = 0 ) Then : [M:DIV2]WEESTRDAY = 1 : Endif
  If (dayn(PDAT) = [M:DIV2]WEESTRDAY) Then
      RTRN = 1
    Else
      RTRN = 0
    Endif
End RTRN

#
#########################################################
Funprog CAL_DAT_PREM( PDAT, PTYP )
#
# - Objet  : Rend la date correspondant au premier jour de l'annûˋe, du mois,
#            de la quinzaine ou de la semaine
#            en fonction de la date et du type passûˋs en paramû´tre.
# - Entrûˋe : Date
#            Type "Y" Annûˋe, "M" Mois, "Q" Demi mois "W" Semaine
# - Sortie : Date correspondant au premier jour de l'annûˋe ou du mois
#   Boite noire
#
Value Date    PDAT
Value Char    PTYP
Local Date    RTRN

Local Decimal WRNG

  RTRN = [0/0/0]
  #----------------------------------
  If ( PDAT <> [0/0/0] ) Then
    Case PTYP
      When "Y"
        RTRN = gdat$(01,01,year(PDAT))
      When "M"
        RTRN = gdat$(01,month(PDAT),year(PDAT))
      When "Q"
        If ( day(PDAT) >= 01 and day(PDAT) <= 15 ) Then
          RTRN = gdat$(01,month(PDAT),year(PDAT))
        Else
          RTRN = gdat$(16,month(PDAT),year(PDAT))
        Endif
      When "T"
        If    (PDAT > gdat$(15,11,year(PDAT))) Then
          RTRN = gdat$(16,11,year(PDAT))
        Elsif (PDAT > gdat$(30,09,year(PDAT))) Then
          RTRN = gdat$(01,10,year(PDAT))
        Elsif (PDAT > gdat$(15,08,year(PDAT))) Then
          RTRN = gdat$(16,08,year(PDAT))
        Elsif (PDAT > gdat$(30,06,year(PDAT))) Then
          RTRN = gdat$(01,07,year(PDAT))
        Elsif (PDAT > gdat$(15,05,year(PDAT))) Then
          RTRN = gdat$(16,05,year(PDAT))
        Elsif (PDAT > gdat$(31,03,year(PDAT))) Then
          RTRN = gdat$(01,04,year(PDAT))
        Elsif (PDAT > gdat$(15,02,year(PDAT))) Then
          RTRN = gdat$(16,02,year(PDAT))
        Else
          RTRN = gdat$(01,01,year(PDAT))
        Endif
      When "W"
        # FQ90048(2)
        #WRNG = -(dayn(PDAT)-1)
        #RTRN = func GLOBB9.CAL_DAT_PLUS( PDAT, WRNG, "D" )
        If ([M:DIV2]WEESTRDAY = 0 ) Then : [M:DIV2]WEESTRDAY = 1 : Endif
        RTRN = PDAT
        While dayn(RTRN) <> [M:DIV2]WEESTRDAY
          RTRN -= 1
        Wend
      When Default : RTRN = [0/0/0]
    Endcase
  Else
  #----------------------------------
    RTRN = [0/0/0]
  Endif
  #----------------------------------

End RTRN


#
#########################################################
Subprog CAL_DAT_DIFF( Z01DTDB, Z01DTFN, Z01TYP, X01DIFF )
#
# - Objet  : Rend le nombre de jours, de semaines, de mois ou d'annûˋe entre deux dates
#            selon le type passûˋ en paramû´tre.
# - Entrûˋe : Date dûˋbut
#            Date fin
#            Type "Y" Annûˋe, "T" Trimestre, Mois, "M" Mois, "Q" Quinzaine, "W" Semaine, "D" Jours
# - Sortie : Nombre de jours, de semaines de mois ou d'annûˋe entre les deux dates
#   Boite noire DTDIFF (as400)
#
Value    Date      Z01DTDB
Value    Date      Z01DTFN
Value    Char      Z01TYP
Variable Decimal   X01DIFF


#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
Local Shortint CALL_Z01
Goto $DEB_CAL_DAT_DIFF
$GSB_CAL_DAT_DIFF
  # Dûˋclaration des paramû´tres en entrûˋe
  Local Date      Z01DTDB      : Z01DTDB = [M:DIV]PD(0)
  Local Date      Z01DTFN      : Z01DTFN = [M:DIV]PD(1)
  Local Char      Z01TYP       : Z01TYP  = [M:DIV]PC(0)
  Local Decimal   X01DIFF
$DEB_CAL_DAT_DIFF
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

Local Integer   Z01RTRN
Local Date      Z01LDAT

  Z01RTRN = 0
  #----------------------------------
  If ( Z01DTDB <> [0/0/0] and Z01DTFN <> [0/0/0]) Then
    Case Z01TYP
      When "Y"     : Z01RTRN = (year(Z01DTFN)-year(Z01DTDB))+1
      When "M"     : Z01RTRN = ((year(Z01DTFN)-year(Z01DTDB))*12)+ (month(Z01DTFN)-month(Z01DTDB))+1
      When "W"     : Z01RTRN = arr(((Z01DTFN-Z01DTDB)+1)/7,1)
      When "D"     : Z01RTRN = (Z01DTFN-Z01DTDB)+1
      When "Q"     : Z01RTRN = ((year(Z01DTFN)-year(Z01DTDB))*24)+ ((month(Z01DTFN)-month(Z01DTDB))*2)+2
                     If (day(Z01DTDB) > 15 ) Then : Z01RTRN -= 1 : Endif
                     If (day(Z01DTFN) < 16 ) Then : Z01RTRN -= 1 : Endif
      When "T"     : Z01RTRN = ((year(Z01DTFN)-year(Z01DTDB))*24)+ ((month(Z01DTFN)-month(Z01DTDB))*2)+2
                     If (day(Z01DTDB) > 15 ) Then : Z01RTRN -= 1 : Endif
                     If (day(Z01DTFN) < 16 ) Then : Z01RTRN -= 1 : Endif
# FQ88728                   Z01RTRN = Z01RTRN / 3

      When Default : Z01RTRN = 0
    Endcase
  Endif
  #----------------------------------
  X01DIFF = Z01RTRN

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
If (dim(CALL_Z01)<0) Then
 # Rûˋcupûˋration des paramû´tres en sortie
 [M:DIV]RV(0) = X01DIFF
 Return
Endif
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

End

#
#########################################################
Funprog CAL_DAT_PLUS( PDAT, PVALINCR, PTYPINCR )
#
# - Objet  : Ajoute ou soustrait selon le signe de PINCR
#            un nombre de jours, de semaines de mois ou d'annûˋe û  PDAT
#            selon PTYPINCR.
# - Entrûˋe : Date dûˋbut
#            Valeur de l'incrûˋment positif ou nûˋgatif
#            Type incrûˋment "Y" Annûˋe, "M" Mois, "W" Semaine, "D" Jours
# - Sortie : Date
#   Boite noire DTPLUS (as400)
#
Value    Date      PDAT
Value    Decimal   PVALINCR
Value    Char      PTYPINCR
Local    Date      RTRN

Local Char    LTYPINCR
Local Decimal LVALINCR

  If ( PDAT = [0/0/0] )  Then : RTRN = [0/0/0] : End RTRN : Endif
  LTYPINCR = PTYPINCR
  LVALINCR = PVALINCR
  #----------------------------------
  # Si incrûˋment en annûˋe,  conversion des annûˋes en mois
  If (LTYPINCR = "Y" ) Then
    LTYPINCR="M"
    LVALINCR= arr(LVALINCR*12,1)
  Endif
  #----------------------------------
  #----------------------------------
  If ( LVALINCR <> 0 ) Then
    Case LTYPINCR
      When "M"     : RTRN = addmonth(PDAT,LVALINCR)
      When "W"     : RTRN = PDAT+(LVALINCR*7)
      When "D"     : RTRN = PDAT+LVALINCR
      When Default : RTRN = [0/0/0]
    Endcase
  Else
  #----------------------------------
    RTRN = PDAT
  Endif
  #----------------------------------

End RTRN

#
#########################################################
Funprog CAL_LOCALISE_DAT (PDAT, PTABDATD, PTABDATF, P_DEB, P_FIN)
#
# - Objet  : Retourne l'indice  de l'intervalle de dates dans lequel
#            se trouve la date de rûˋfûˋrence passûˋe en paramû´tre.
#
# - Entrûˋe : Date de rûˋfûˋrence
#            2 tableaux de dates croissantes et contigues
#            ( Ex: exercices, pûˋriodes, ...)
#            borne infûˋrieure tableau PTABDATD ( 0 inclus)
#            borne supûˋrieure tableau PTABDATF
#
# - Sortie : Indice  de l'intervalle dans lequel se trouve la date (0 û  n)
#            -1 En dehors de la borne infûˋrieure
#            -2 En dehors de la borne supûˋrieure
#   Boite noire
#
Value Date     PDAT
Value Date     PTABDATD(0..), PTABDATF(0..)
Value Integer  P_DEB
Value Integer  P_FIN
Local Integer  RTRN

Local Integer  I

  #----------------------------------
  If ( PDAT < PTABDATD(P_DEB) ) Then
    # Hors borne infûˋrieure
    RTRN = -1
  Elsif ( PDAT > PTABDATF(P_FIN) ) Then
  #----------------------------------
    # Hors borne supûˋrieure
    RTRN = -2
  Else
  #----------------------------------
    # Rûˋcupûˋration de l'indice
    RTRN = sigma (I= P_DEB, P_FIN, PTABDATF(I) < PDAT)
  Endif
  #----------------------------------

End RTRN

#
#########################################################
Subprog CAL_DAT_FIN_SELON_DUREE ( PDTDB, PDUR, PTYPPRO, RDTFN )
#
# - Objet  : Renvoie une date de fin correspondant
#            û  une date de dûˋbut
#            û  laquelle est ajoutûˋe une durûˋe en annûˋe
#            1 jour est enlevûˋ û  la date obtenue
#            Cadrage selon type prorata
#
# - Entrûˋe :
#            Date de dûˋbut
#            Durûˋe
#
# - Sortie : Date de fin
#
#   Boite noire
#
Value    Date      PDTDB
Value    Decimal   PDUR
Value    Integer   PTYPPRO
Variable Date      RDTFN

Local    Decimal   LDECI   : LDECI = PDUR - fix(PDUR)
Local    Decimal   LENT    : LENT  = PDUR - LDECI

Local    Decimal   WINCR
Local    Date      LDTFN
Local    Integer   LANN

Local    Integer   LTAB30(4)

  If ( PDTDB = [0/0/0] )  Then : RDTFN = [0/0/0] : End  : Endif

  # Date de fin sur la base d'un nombre d'annûˋes entiû´res
  RDTFN = func GLOBB9.CAL_DAT_PLUS( PDTDB, LENT , "Y")
  LDTFN = RDTFN

  #-1-------------------------
  If ( LDECI  <> 0 ) Then
    # La durûˋe possû´de une partie dûˋcimale
    LANN = year(PDTDB)
    #-2-------------------------
    If ( day(PDTDB) = 1 or func GLOBB9.CAL_DAT_ISENDOFMONTH(PDTDB) ) Then
      # La date de dûˋpart commence en dûˋbut de mois ou fin de mois
      # FQ59941 arrondi de la durûˋe sur 2 dûˋc.
      Local Decimal WDECI : WDECI = arr(LDECI, 0.01)
      Case WDECI
        When 0.08
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 1  , "M")
        When 0.16 , 0.17
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 2  , "M")
        When 0.25
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 3  , "M")
        When 0.33
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 4  , "M")
        When 0.41 , 0.42
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 5  , "M")
        When 0.50
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 6  , "M")
        When 0.58
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 7  , "M")
        When 0.66 , 0.67
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 8  , "M")
        When 0.75
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 9  , "M")
        When 0.83
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 10 , "M")
        When 0.91 , 0.92
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, 11 , "M")
        When Default
          # Il est enlevûˋ un jour au nombre de jour obtenue
          LDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN , -1 , "D")
          LANN = year(LDTFN)
          WINCR = arr( (func GLOBB9.CAL_DAT_BISS(LANN) * LDECI), 1 )
          RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, WINCR , "D")
      Endcase
    #-2-------------------------
    Else
      # Il est enlevûˋ un jour au nombre de jour obtenue
      LDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN , -1 , "D")
      LANN = year(LDTFN)
      WINCR = arr( (func GLOBB9.CAL_DAT_BISS(LANN) * LDECI), 1 )
      RDTFN = func GLOBB9.CAL_DAT_PLUS( LDTFN, WINCR , "D")
    Endif
    #-2-------------------------
  Endif
  #-1-------------------------

  # Il est enlevûˋ un jour au nombre de jour obtenue
  RDTFN = func GLOBB9.CAL_DAT_PLUS( RDTFN , -1 , "D")

  # Cadrage selon prorata
  Case PTYPPRO
    When GVML_TPSEMA
      # FQ90048
      If !( func GLOBB9.CAL_DAT_ISENDOFWEEK (RDTFN) ) Then
        # Prorata en semaine - Ajustement û  la fin de la semaine prûˋcûˋdente
         RDTFN = func GLOBB9.CAL_DAT_PLUS( RDTFN , -7, "D")
         RDTFN = func GLOBB9.CAL_DAT_DERN( RDTFN , "W")
      Endif
    When GVML_TPMOIS
      # Prorata en mois - Ajustement û  la fin du mois
      RDTFN = func GLOBB9.CAL_DAT_DERN( RDTFN , "M")
    When GVML_TPHLFY
      # Prorata en mois - Ajustement û  la fin du mois
      RDTFN = func GLOBB9.CAL_DAT_DERN( RDTFN , "M")
    When GVML_TPHLFM
      # Prorata en mois - Ajustement û  la fin de quinzaine
      RDTFN = func GLOBB9.CAL_DAT_DERN( RDTFN , "Q")
    When GVML_TPHLFQ
      # Prorata en 1/2 trimestre - Ajustement û  la fin du 1/2 trimestre
      RDTFN = func GLOBB9.CAL_DAT_DERN( RDTFN , "T")
    When Default
  Endcase
End

#
#########################################################
Subprog CAL_RETRAITE_DUREE_EN_MOIS ( PDUR, RDUR )
#
# - Objet  : Renvoie une durûˋe dont la partie dûˋcimale a ûˋtûˋ retraitûˋe
#            pour correspondre û  un nombre de mois prûˋcis lorsque la
#            durûˋe n'est pas assez prûˋcise.
#
# - Entrûˋe :
#            Durûˋe
#
# - Sortie : Durûˋe retraitûˋe
#
#   Boite noire
#
# FQ59941 modes russes

Value    Decimal   PDUR
Variable Decimal   RDUR

Local    Decimal   LDECI   : LDECI = PDUR - fix(PDUR)
Local    Decimal   LENT    : LENT  = PDUR - LDECI
Local    Decimal   LDECR   : LDECR = 0.                  : # Partie dûˋcimale retraitûˋe

  If LDECI > 0.958
    LDECR = 1.
  Elsif LDECI > 0.875
    LDECR = 0.917
  Elsif LDECI > 0.791
    LDECR = 0.833
  Elsif LDECI > 0.708
    LDECR = 0.75
  Elsif LDECI > 0.625
    LDECR = 0.667
  Elsif LDECI > 0.541
    LDECR = 0.583
  Elsif LDECI > 0.458
    LDECR = 0.5
  Elsif LDECI > 0.375
    LDECR = 0.417
  Elsif LDECI > 0.291
    LDECR = 0.333
  Elsif LDECI > 0.208
    LDECR = 0.25
  Elsif LDECI > 0.125
    LDECR = 0.167
  Elsif LDECI > 0.041
    LDECR = 0.083
  Else
    LDECR = 0.
  Endif

  RDUR = LENT + LDECR

End

#
#########################################################
Subprog CAL_DUREE_OU_NBMOIS ( PTYP, PDUR, PNBM, RDUR, RNBM )
#
# - Objet  :
#            Renvoie selon le type d'entrûˋe
#            Soit un nombre de mois obtenu û  partir d'une durûˋe
#            Soit une durûˋe exprimûˋe en annûˋe milliû´me d'annûˋe û  partir d'un nombre de mois
#
# - Entrûˋe :
#            Type d'entrûˋe : "D" Durûˋe / "M" Mois
#            Nombre de mois en entrûˋe
#            Durûˋe en entrûˋe
#
# - Sortie : Selon type d'entrûˋe
#            "D"
#            Durûˋe passûˋe en entrûˋe
#            Nombre de mois obtenue û  partir de la durûˋe
#            "M"
#            Durûˋe obtenue û  partir du nombre de mois
#            Nombre de mois passûˋ en entrûˋe
#
#   Boite noire
#

Value    Char      PTYP
Value    Decimal   PDUR
Value    Integer   PNBM
Variable Decimal   RDUR
Variable Integer   RNBM

  If ( find( PTYP, "D","M") = 0 ) Then : RDUR = PDUR : RNBM = PNBM : End : Endif
  If ( PTYP = "D" ) Then
    Local    Decimal   LDECI   : LDECI = PDUR - fix(PDUR)
    Local    Decimal   LENT    : LENT  = PDUR - LDECI
    Local    Decimal   LDECM   : LDECM = 0.                  : # Partie dûˋcimale exprimûˋe en mois
    If LDECI > 0.958
      LDECM = 12
    Elsif LDECI > 0.875
      LDECM = 11
    Elsif LDECI > 0.791
      LDECM = 10
    Elsif LDECI > 0.708
      LDECM = 9
    Elsif LDECI > 0.625
      LDECM = 8
    Elsif LDECI > 0.541
      LDECM = 7
    Elsif LDECI > 0.458
      LDECM = 6
    Elsif LDECI > 0.375
      LDECM = 5
    Elsif LDECI > 0.291
      LDECM = 4
    Elsif LDECI > 0.208
      LDECM = 3
    Elsif LDECI > 0.125
      LDECM = 2
    Elsif LDECI > 0.041
      LDECM = 1
    Else
      LDECM = 0.
    Endif
    RDUR = PDUR
    RNBM = (LENT*12) + LDECM
  Endif

  If ( PTYP = "M" ) Then
    Local Integer NBA
    Local Integer RST
    NBA = PNBM /12
    RST = PNBM - (NBA*12)
    Local Decimal LDECR  : # Partie dûˋcimale rûˋsultante
    Case RST
      When 0
        LDECR = 0.
      When 1
        LDECR = 0.083
      When 2
        LDECR = 0.167
      When 3
        LDECR = 0.25
      When 4
        LDECR = 0.333
      When 5
        LDECR = 0.417
      When 6
        LDECR = 0.5
      When 7
        LDECR = 0.583
      When 8
        LDECR = 0.667
      When 9
        LDECR = 0.75
      When 10
        LDECR = 0.833
      When 11
        LDECR = 0.917
    Endcase
    RNBM = PNBM
    RDUR = NBA + LDECR
  Endif
  #-----------
End


#
#########################################################
Funprog CAL_DAT_NBJ_BISS ( PDTDB, PDTFN )
#
# - Objet  : Renvoie le nombre de 29/02/nn contenu entre
#            entre 2 dates
#
# - Entrûˋe :
#            Date de dûˋbut
#            Date de fin
#
# - Sortie : Nombre de 29/02/nn
#
#   Boite noire
#
Value    Date      PDTDB
Variable Date      PDTFN
Local    Shortint  RTRN

Local Date         LDAT
Local Integer      LANN
Local Integer      LDEB
Local Integer      LFIN

  LANN = year(PDTDB)
  #--------------------------
  If ( func GLOBB9.CAL_DAT_BISS(LANN) = 366 ) Then
    LDAT = gdat$(29,02,LANN)
    #--------------------------
    If ( func GLOBB9.CAL_DAT_INSIDE(LDAT,PDTDB,PDTFN,"I") ) Then
      RTRN += 1
    Endif
    #--------------------------
  Endif
  #--------------------------

  #-1-------------------------
  If ( year(PDTDB) <> year(PDTFN) ) Then
    LANN = year(PDTFN)
    #-------------------------
    If ( func GLOBB9.CAL_DAT_BISS(LANN) = 366 ) Then
      LDAT = gdat$(29,02,LANN)
      #--------------------------
      If ( func GLOBB9.CAL_DAT_INSIDE(LDAT,PDTDB,PDTFN,"I") ) Then
        RTRN += 1
      Endif
      #--------------------------
    Endif
    #--------------------------
    If ( year(PDTFN) - year(PDTDB) > 1 ) Then
      LDEB = year(PDTDB) + 1
      LFIN = year(PDTFN) - 1
      # >>>>
      For LANN = LDEB To LFIN
        If ( func GLOBB9.CAL_DAT_BISS(LANN) = 366 ) Then : RTRN += 1 : Endif
      Next LANN
      # <<<<
    Endif
    #--------------------------
  Endif
  #-1-------------------------



End RTRN


#
#########################################################
Subprog  CAL_DAT_BORNES ( Z02DTDB1, Z02DTFN1,
&                         Z02DTDB2, Z02DTFN2, Z02DTDB3, Z02DTFN3, Z02DTFN4, Z02DTFN5,  X02DTDB, X02DTFN)
#
# - Objet  : Calcule les bornes dûˋbut & fin d'un intervalle selon diffûˋrentes dates
#            la borne de dûˋbut ûˋtant le max des dates debut
#            la borne de fin   ûˋtant le min des dates fin (non nulles)
#
# - Rem.   : Date de dûˋbut 1 et Date de fin 1 doivent ûˆtre obligatoirement renseignûˋes
#            Si l'une ou l'autre est nulle alors la durûˋe de dûˋtention sera nulle
#
#
# - Entrûˋe : Table des pûˋriodes
#            Date de dûˋbut 1 (obligatoire)
#            Date de fin   1 (obligatoire)
#            Date de dûˋbut 2
#            Date de fin   2
#            Date de dûˋbut 3
#            Date de fin   3
#            Date de fin   4
#            Date de fin   5
#
# - Sortie : Durûˋe de dûˋtention
#
#   Boite noire
#
Value    Date      Z02DTDB1, Z02DTDB2, Z02DTDB3, Z02DTFN1, Z02DTFN2, Z02DTFN3, Z02DTFN4, Z02DTFN5
Variable Date      X02DTDB , X02DTFN

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
Local Shortint CALL_Z02
Goto $DEB_CAL_DAT_BORNES
$GSB_CAL_DAT_BORNES
  # Dûˋclaration des paramû´tres en entrûˋe
  Local Date      Z02DTDB1        : Z02DTDB1     = [M:DIV]PD(0)
  Local Date      Z02DTFN1        : Z02DTFN1     = [M:DIV]PD(1)
  Local Date      Z02DTDB2        : Z02DTDB2     = [M:DIV]PD(2)
  Local Date      Z02DTFN2        : Z02DTFN2     = [M:DIV]PD(3)
  Local Date      Z02DTDB3        : Z02DTDB3     = [M:DIV]PD(4)
  Local Date      Z02DTFN3        : Z02DTFN3     = [M:DIV]PD(5)
  Local Date      Z02DTFN4        : Z02DTFN4     = [M:DIV]PD(6)
  Local Date      Z02DTFN5        : Z02DTFN5     = [M:DIV]PD(7)
  Local Date      X02DTDB
  Local Date      X02DTFN

$DEB_CAL_DAT_BORNES
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

Local Date    W02DTFN2, W02DTFN3, W02DTFN4, W02DTFN5

  # ContrûÇle des paramû´tres obligatoires
  If ( Z02DTDB1 = [0/0/0] or Z02DTFN1 = [0/0/0] ) Then
    # Les dates passûˋes en paramû´tres sont inconsistantes
    [M:DIV]ERRID = 26 : Call ERRFND From =G_GLOB0  : # Dûˋpilement suite û  erreur logique
    If (dim(CALL_Z02)<0) Then :  Return : Else : End : Endif
  Endif

  # Date de dûˋbut
  X02DTDB = max( Z02DTDB1, Z02DTDB2, Z02DTDB3 )

  #----------------------------------
  # Date de fin
  W02DTFN2 = Z02DTFN2 : W02DTFN3 = Z02DTFN3 : W02DTFN4 = Z02DTFN4 : W02DTFN5 = Z02DTFN5

  If ( W02DTFN2 = [0/0/0] ) Then : W02DTFN2 = Z02DTFN1 : Endif
  If ( W02DTFN3 = [0/0/0] ) Then : W02DTFN3 = Z02DTFN1 : Endif
  If ( W02DTFN4 = [0/0/0] ) Then : W02DTFN4 = Z02DTFN1 : Endif
  If ( W02DTFN5 = [0/0/0] ) Then : W02DTFN5 = Z02DTFN1 : Endif
  X02DTFN = min( Z02DTFN1, W02DTFN2, W02DTFN3, W02DTFN4, W02DTFN5 )


#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
If (dim(CALL_Z02)<0) Then
 # Rûˋcupûˋration des paramû´tres en sortie
 [M:DIV]RD(1) = X02DTDB
 [M:DIV]RD(2) = X02DTFN
 Return
Endif
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

End

#
#########################################################
Subprog CAL_DAT_DEBUT_SEMESTRE ( PDTDBEXE, PDTFNEXE, PDTDBAMT,  RDTDBSEM )
#
# - Objet  : Renvoie la date de dûˋbut du semestre dans laquelle se situe la date de
#            dûˋbut d'amortissement pour un exercice donnûˋ. Cet exercice peut ûˆtre
#            > ou < û  12 mois.
#
#
# - Entrûˋe :
#            Date de dûˋbut d'exercice
#            Date de fin d'exercice
#
# - Sortie : Date de dûˋbut du semestre
#
#   Boite noire gcfc6a
#
Value    Date      PDTDBEXE
Value    Date      PDTFNEXE
Value    Date      PDTDBAMT
Variable Date      RDTDBSEM

Local Date  WDTDBSEM

  WDTDBSEM = PDTFNEXE
  While WDTDBSEM >= PDTDBAMT
    WDTDBSEM = func GLOBB9.CAL_DAT_PLUS( WDTDBSEM , -6, "M" )
    WDTDBSEM = func GLOBB9.CAL_DAT_DERN( WDTDBSEM , "M" )
  Wend

  If (WDTDBSEM < PDTDBEXE) Then
    RDTDBSEM = PDTDBEXE
  Else
    RDTDBSEM = func GLOBB9.CAL_DAT_PLUS( WDTDBSEM , 1, "D")
  Endif

End

#
#########################################################
Subprog CAL_DAT_FIN_SEMESTRE ( PDTDBEXE, PDTFNEXE, PDTDBAMT,  RDTFNSEM )
#
# - Objet  : Renvoie la date de fin du semestre dans laquelle se situe la date de
#            dûˋbut d'amortissement pour un exercice donnûˋ. Cet exercice peut ûˆtre
#            > ou < û  12 mois.
#
#
# - Entrûˋe :
#            Date de dûˋbut d'exercice
#            Date de fin d'exercice
#
# - Sortie : Date de fin du semestre
#
#   Boite noire
#
Value    Date      PDTDBEXE
Value    Date      PDTFNEXE
Value    Date      PDTDBAMT
Variable Date      RDTFNSEM

Local Date  WDATE
Local Date  WDTDBSEM

  If ( day(PDTDBAMT) = 31 ) Then
    WDATE = gdat$( 30, month(PDTDBAMT), year(PDTDBAMT))
  Else
    WDATE = PDTDBAMT
  Endif

  WDATE = func GLOBB9.CAL_DAT_PLUS( WDATE , +6, "M" )
  If (WDATE > PDTFNEXE) Then
    RDTFNSEM = PDTFNEXE
  Else
    Call CAL_DAT_DEBUT_SEMESTRE ( PDTDBEXE, PDTFNEXE, WDATE,  WDTDBSEM ) From =G_GLOB9
    RDTFNSEM = func GLOBB9.CAL_DAT_PLUS( WDTDBSEM , -1, "D")
  Endif

End


