#########################################################
Subprog CAL_ORANOLOG (PDOSSIER,PTABLE)
Value Char PDOSSIER
Value Char PTABLE
#
# Passage de la table du dossier en NOLOGGING  FQ79813
#

  If ( GTYPDBA = 1 ) Then : #Oracle
    # Passage en mode Nologging
    Local Char SQLREQLOG (250)
    SQLREQLOG = "ALTER TABLE "+PDOSSIER+"."+PTABLE+" NOLOGGING"
    Execsql From "3" Sql SQLREQLOG
  Endif
End

#########################################################
Subprog CAL_ORALOG (PDOSSIER,PTABLE)
Value Char PDOSSIER
Value Char PTABLE
#
# Passage de la table du dossier en LOGGING  FQ79813
#
  If ( GTYPDBA = 1 ) Then : #Oracle
    # Retour en mode Logging
    Local Char SQLREQLOG (250)
    SQLREQLOG = "ALTER TABLE "+PDOSSIER+"."+PTABLE+" LOGGING"
    Execsql From "3" Sql SQLREQLOG
  Endif
End

#########################################################
Funprog CAL_TAB_DIFF (PDOSSIER,PTABORI,PTABDES)
Value Char PDOSSIER
Value Char PTABORI
Value Char PTABDES
Local Shortint B_DIFF

#  Comparaison de la structure de 2 tables FQ79813

B_DIFF=0
Local Char REQSQL (250)(2)

  If ( GTYPDBA = 1 ) Then
    # Oracle
    REQSQL(0)="select COLUMN_NAME,DATA_TYPE from all_tab_columns T1 where T1.OWNER='"+PDOSSIER+"' AND T1.TABLE_NAME='"+PTABORI+"' "
    REQSQL(1)="AND NOT EXISTS ( SELECT 'X' from all_tab_columns T2 where T2.OWNER=T1.OWNER AND T2.COLUMN_NAME=T1.COLUMN_NAME AND T2.TABLE_NAME='"+PTABDES+"') ORDER BY COLUMN_NAME"
    For (Char VCOL(50),Char VTYP(50)) From num$(GTYPDBA*2+1) Sql REQSQL(0..1) As [BZZ]
      B_DIFF = 1
    Next
    If not(B_DIFF) Then
      REQSQL(0)="select COLUMN_NAME,DATA_TYPE from all_tab_columns T1 where T1.OWNER='"+PDOSSIER+"' AND T1.TABLE_NAME='"+PTABDES+"' "
      REQSQL(1)="AND NOT EXISTS ( SELECT 'X' from all_tab_columns T2 where T2.OWNER=T1.OWNER AND T2.COLUMN_NAME=T1.COLUMN_NAME AND T2.TABLE_NAME='"+PTABORI+"') ORDER BY COLUMN_NAME"
      For (Char VCOL(50),Char VTYP(50)) From num$(GTYPDBA*2+1) Sql REQSQL(0..1) As [BZZ]
        B_DIFF = 1
      Next
    Endif
  Else
    # SQL server
    REQSQL(0)="select t1.name,t3.name from syscolumns t1, sys.types t3 where t1.xtype=t3.user_type_id and t1.id=object_id('"+PDOSSIER+"."+PTABORI+"') "
    REQSQL(1)="and not exists(select 'x' from syscolumns t2 where t1.name=t2.name and t2.id=object_id('"+PDOSSIER+"."+PTABDES+"')) order by t1.name"
    For (Char VCOL(50),Char VTYP(50)) From num$(GTYPDBA*2+1) Sql REQSQL(0..1) As [BZZ]
      If [BZZ]VCOL<>"ROWID"
        B_DIFF = 1
      Endif
    Next
    If not(B_DIFF) Then
      REQSQL(0)="select t1.name,t3.name from syscolumns t1, sys.types t3 where t1.xtype=t3.user_type_id and t1.id=object_id('"+PDOSSIER+"."+PTABDES+"') "
      REQSQL(1)="and not exists(select 'x' from syscolumns t2 where t1.name=t2.name and t2.id=object_id('"+PDOSSIER+"."+PTABORI+"')) order by t1.name"
      For (Char VCOL(50),Char VTYP(50)) From num$(GTYPDBA*2+1) Sql REQSQL(0..1) As [BZZ]
        If [BZZ]VCOL<>"ROWID"
          B_DIFF = 1
        Endif
      Next
    Endif
  Endif

End B_DIFF


#########################################################
Subprog CAL_TAB_RAZ (PDOSSIER,PTABLE)
Value Char PDOSSIER
Value Char PTABLE
#
# Remise û  blanc d'une table d'un dossier  FQ79813
#

If filinfo(filpath("FIL",PTABLE,"fde",PDOSSIER),0) < 0 : End : Endif

Local File =PDOSSIER+"."+PTABLE  [TB1]
Local Char REQTSQL (250)

Trbegin [TB1]
REQTSQL(0)="TRUNCATE TABLE "-PDOSSIER+"."+PTABLE
Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
Commit

Close File [TB1]
End

#########################################################
Subprog CAL_CONNECTED_USERS(DOSSIER,NBCON,RERR)
Value Char       DOSSIER
Variable Integer NBCON
Variable Integer RERR
#
# Nombre de sessions ouvertes dans le dossier FQ79813
#
RERR = 0
Local Char       SID(12) , SCLI(80) , SDOS(30) , STYP(12)
Local Char       MACHINE(GLONAMC) , APPLI(GLONADS)
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
Local File (SID,SCLI,SDOS,STYP,SLOG) From System MACHINE+"@psadx -tf -b"-APPLI As [SYS_] Where [SYS_]SDOS=APPLI
NBCON = 0
For [SYS_]
 If !find([SYS_]STYP,"4","5","7") : # Web services/Terminal/Bridge Java
  NBCON += 1
  If (NBCON > 1) Then
    RERR = 1
  Endif
 Endif
Next SYS_
Close Local File [SYS_]
End


#########################################################
Subprog CAL_VERROU_DOSSIER(PDOSSIER,RERR)
Value    Char    PDOSSIER
Variable Integer RERR
#
# Verrouillage du dossier si au plus 1 utilisateur est connectûˋ FQ79813
#

Local Integer    NBUSR

  RERR = 0
  # Pas de verrouillage d'un dossier racine
  If (PDOSSIER = GDOSX3) Then
    #  Pas de verrou sur dossier racine
    Call ECR_TRACE("Verrouillage du dossier racine interdit ",1) From GESECRAN
    RERR = 39
    End
  Endif

  #   Y-a t-il plus d'un utilisateur connectûˋ de type ADAPI
  Call CAL_CONNECTED_USERS(nomap,NBUSR, RERR)
  If ( RERR ) Then
    #  Pus d'un utilisateur connectûˋ sur ce dossier
    Call ECR_TRACE(num$(NBUSR)-mess(48,125,1),1) From GESECRAN
    RERR = 40
    End
  Endif

  # Accû´s û  MONO
  Local File =nomap+".ADOVAL" [ADW]
  Read [ADW]ADW0 = "";"";"MONO"
  MONO = val([F:ADW]VALEUR)
  If (fstat) Then
    Call ECR_TRACE(mess(49,125,1)-"ADOVAL"-"MONO",1) From GESECRAN
    # Erreur de lecture
    RERR = 41
    End
  Endif

  # Test si le dossier n'est pas dûˋjû  verrouillûˋ
  If (MONO) Then
     Call ECR_TRACE(mess(47,125,1),1) From GESECRAN
     # Dossier en cours d'utilisation
     RERR = 42
     End
   Endif

  # Verrouillage du dossier
   Trbegin [ADW]
     [F:ADW]VALEUR = "2"
     Rewrite [ADW]
     If fstat
       Call ECR_TRACE(mess(26,125,1)-"ADOVAL"-"MONO",1) From GESECRAN
       # Erreur d'ûˋcriture
       RERR = 41
     Endif
   Commit
End

#########################################################
Subprog CAL_DEVERROU_DOSSIER(PDOSSIER,RERR)
Value    Char    PDOSSIER
Variable Integer RERR
#
# Dûˋverrouillage du dossier. FQ79813
#
  RERR = 0

  # Dûˋverrouillage du dossier
  Local File =PDOSSIER+".ADOVAL" [ADW]
  Trbegin [ADW]
    Read [ADW]ADW0 = "";"";"MONO"
    If (fstat) Then
      RERR = 44
      Call ECR_TRACE(mess(49,125,1)-"ADOVAL"-"MONO",1) From GESECRAN
    Else
      [F:ADW]VALEUR = "0"
      Rewrite [ADW]
      If fstat
        RERR = 44
        Call ECR_TRACE(mess(26,125,1)-"ADOVAL"-"MONO",1) From GESECRAN
        #  Erreur d'ûˋcriture
      Endif
    Endif
  Commit
End

#########################################################
Subprog CAL_DELIND (PDOSSIER,PTABLE)
Value Char PDOSSIER
Value Char PTABLE
#
# Supprime tous les index d'une table sauf le 1er FQ79813
#


  #on lit le 1er index de la table dans ATABIND
  Local File =PDOSSIER+".ATABIND"     [ATI]   : # index
  Read [ATI]NUMLIG=PTABLE;1
  If fstat : Raz [ATI] : Endif

  #on boucle sur les index de la table pour les supprimer
  If GTYPDBA=1 : #Oracle
    #--------------------
    Local Char SQLREQIND (250)
    For (Char VTAB(50),Char VIND(50)) From '3' Sql
&   "SELECT table_name,index_name"
&  -"From ALL_INDEXES"
&  -"where substr(index_name,1,6)!='SYS_IL'"
&  -"and table_name='"+PTABLE+"'"
&  -"and owner='"+PDOSSIER+"'"
&  -"Order BY 1,2"
&   As [BXX]
      If [BXX]VIND<>PTABLE+'_'+[F:ATI]CODIND
        SQLREQIND = "DROP INDEX "+PDOSSIER+"."+[BXX]VIND
        Execsql From "3" Sql SQLREQIND
      Else
        SQLREQIND = "ALTER INDEX "+PDOSSIER+"."+[BXX]VIND+" NOLOGGING"
        Execsql From "3" Sql SQLREQIND
      Endif
    Next
    #----------------------
  Else : # SQLServer
    Trbegin [ATI]
    #-----------------------------
    Local Char SQLREQIND (250)
    Local Char REQSQL (250) (2)
    Local Integer RERR

    REQSQL(0) = "SELECT cast(o.name as varchar),i.name "

    Local Char WVERSSQL
    Call NOVERS_SQL(WVERSSQL,RERR) From SQLPROP
    If RERR<>0 : Return : Endif
    If WVERSSQL="8"
      REQSQL(1) ="From sysindexes i,sysobjects o,sysusers u"
&     -"where o.id=i.id and o.uid=u.uid and i.name<>o.name"
&     -"and i.name not like '%ROWID'"
&     -"and i.name<>'t'+o.name"
&     -"and i.status in (0,2)"
&     -"and u.name='"+PDOSSIER+"'"
&     -"and cast(o.name as varchar)='"+PTABLE+"'"
&     -"order by o.name,i.name"
    Else
      REQSQL(1) ="From sysindexes i,sysobjects o"
&     -"where o.id=i.id and i.name<>o.name"
&     -"and i.name not like '%ROWID'"
&     -"and i.name<>'t'+o.name"
&     -"and i.status in (0,2)"
&     -"and SCHEMA_NAME(o.uid)='"+PDOSSIER+"'"
&     -"and cast(o.name as varchar)='"+PTABLE+"'"
&     -"order by o.name,i.name"
    Endif

    For (Char VTAB(50),Char VIND(50)) From '5' Sql REQSQL As [BXX]
      If [BXX]VIND<>PTABLE+'_'+[F:ATI]CODIND
        SQLREQIND = "DROP INDEX ["+PDOSSIER+"].["+PTABLE+"]."+[BXX]VIND
        Execsql From "5" Sql SQLREQIND
      Endif
    Next
    #--------------------------
    Commit
  Endif
End

#########################################################
Subprog CAL_CREIND (PDOSSIER,PTABLE,RERR)
Value    Char PDOSSIER
Value    Char PTABLE
Variable Integer RERR
#
# Rûˋcrûˋation des indexes d'une table FQ79813
#
  Local Char    ORDSYS(250)(1..2)
  Local Char    MESSAGE(80)(1..5) , FICTRA(250)
  Local Integer STAT

  RERR = 0

  FICTRA  = filpath("tmp",PTABLE,"tra",PDOSSIER)
  If filinfo(FICTRA,0)>=0
   Call EFFACE(FICTRA ,STAT) From ORDSYS
  Endif
  ORDSYS(1) = "valfil -s -e"
  ORDSYS(1) -= PDOSSIER-PTABLE
  ORDSYS(2) = FICTRA
  Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
  adxifs = ""
  adxirs = chr$(10)
  Openi FICTRA
  Raz MESSAGE
  Rdseq MESSAGE(1)
  Rdseq MESSAGE(2)
  Rdseq MESSAGE(3)
  Openi
  If (MESSAGE(1)<>"") Then
   RERR= 43 : # Erreur en validation de la table
   Call ECR_TRACE(mess(51,123,1)-PDOSSIER-PTABLE+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3),1) From GESECRAN
  Endif
End

#########################################################
Subprog CAL_DELTAB (PDOSSIER,PTABLE,PREQ, PIR)
Value Char    PDOSSIER
Value Char    PTABLE
Value Char    PREQ() (1..)
Value Integer PIR

# Delete des enregistrement d'une table d'un dossier selon requûˆte

Local Char WTABCOL(250)(1..200) : Raz WTABCOL
Local Integer WNBCOL

  Local File =PDOSSIER+".ATABLE"  [ATB2]
  #====
  # DELETE
  WNBCOL =1 : WTABCOL(WNBCOL)="DELETE"-PDOSSIER+"."
  #WNBCOL+=1 : WTABCOL(WNBCOL)=PTABLE+" D1"
  WNBCOL+=1 : WTABCOL(WNBCOL)=PTABLE

  # WHERE
  If (PIR) Then
    WNBCOL+=1 : WTABCOL(WNBCOL)=" WHERE "
    Local Integer IR
    For IR = 1 To PIR
      WNBCOL+=1 : WTABCOL(WNBCOL) = PREQ(IR)
    Next IR
  Endif
  Execsql From num$(GTYPDBA*2+1) Sql WTABCOL(1..WNBCOL)
  #====

End

#########################################################
Subprog CAL_REQ_DAT (PDATE,RDATE)
Value Date PDATE
Variable Char RDATE
#
#  Formattage d'une date pour requûˆte selon base Oracle ou SQL Server
#
# ---------------
# Oracle
# date nulle = 31/12/1599
# to_date('"+VALEUR+"','YYYYMMDD')
# ex :  to_date(ã15991231ã,ãYYYYMMDD')
# ---------------
# SqlServer
# date nulle = 01/01/1753
# convert(datetime,'"+VALEUR+"',112) -> avec la date au format YYYYMMDD
# ex :  convert(datetime,ã17530101ã,112)

  RDATE = ""

  If ( GTYPDBA = 1 ) Then
    # Oracle
    RDATE = "to_date('"+format$("D:YYYYMMDD",PDATE)+"','YYYYMMDD')"
  Else
    # SQL Server
    RDATE = "convert(datetime,'"+format$("D:YYYYMMDD",PDATE)+"',112)"
  Endif

End

#########################################################
Subprog CAL_INSTAB (PDOSSIER,PTABORI,PTABDES,PREQ, PIR)
Value Char    PDOSSIER
Value Char    PTABORI
Value Char    PTABDES
Value Char    PREQ() (1..)
Value Integer PIR

# Copie de certains enregistrement d'une table d'un dossier selon requûˆte


Local Char WTABCOL(80)(1..1000) : Raz WTABCOL
Local Integer WNBCOL  : WNBCOL=0

Local Char REQSQL (250)(2)

Local File =PDOSSIER+".ATABLE"  [ATB2]
Trbegin [ATB2]

  If GTYPDBA=1 : #Oracle
    # INSERT INTO (destination)
    WNBCOL=1
    WTABCOL(WNBCOL)="INSERT INTO"-PDOSSIER+"." : WNBCOL+=1
    WTABCOL(WNBCOL)=PTABDES+"(": WNBCOL+=1
    PREM=0
    For (Char VCOL(50)) From num$(GTYPDBA*2+1) Sql "select COLUMN_NAME from all_tab_columns where OWNER='"+PDOSSIER+"' AND TABLE_NAME='"+PTABORI+"' ORDER BY COLUMN_NAME" As [BXX]
        If PREM
            WTABCOL(WNBCOL)=","
        Endif
        PREM=1
        WTABCOL(WNBCOL)+=[BXX]VCOL : WNBCOL+=1
    Next
    # SELECT
    WTABCOL(WNBCOL)=") SELECT " : WNBCOL+=1
    PREM=0
    For (Char VCOL(50)) From num$(GTYPDBA*2+1) Sql "select COLUMN_NAME from all_tab_columns where OWNER='"+PDOSSIER+"' AND TABLE_NAME='"+PTABORI+"' ORDER BY COLUMN_NAME" As [BXX]
        If PREM
            WTABCOL(WNBCOL)=","
        Endif
        PREM=1
        WTABCOL(WNBCOL)+=[BXX]VCOL : WNBCOL+=1
    Next
    # FROM  (origine)
    WTABCOL(WNBCOL)=" FROM"-PDOSSIER+"." : WNBCOL+=1
    WTABCOL(WNBCOL)=PTABORI+" D1"

    # WHERE
    If (PIR) Then
      WNBCOL+=1 : WTABCOL(WNBCOL)=" WHERE "
      Local Integer IR
      For IR = 1 To PIR
        WNBCOL+=1 : WTABCOL(WNBCOL) = PREQ(IR)
      Next IR
    Endif

    Execsql From num$(GTYPDBA*2+1) Sql WTABCOL(1..WNBCOL)

  Else  : # SQL Server
    # INSERT INTO (destination)
    WNBCOL=1
    WTABCOL(WNBCOL)="INSERT INTO"-PDOSSIER+"." : WNBCOL+=1
    WTABCOL(WNBCOL)=PTABDES+"(": WNBCOL+=1
    PREM=0
    For (Char VCOL(50)) From num$(GTYPDBA*2+1) Sql "select name from syscolumns where id=object_id('"+PDOSSIER+"."+PTABORI+"') order by name" As [BXX]
      If [BXX]VCOL<>"ROWID"
        If PREM
            WTABCOL(WNBCOL)=","
        Endif
        PREM=1
        WTABCOL(WNBCOL)+=[BXX]VCOL : WNBCOL+=1
      Endif
    Next
    # SELECT
    WTABCOL(WNBCOL)=") SELECT " : WNBCOL+=1
    PREM=0
    For (Char VCOL(50)) From num$(GTYPDBA*2+1) Sql "select name from syscolumns where id=object_id('"+PDOSSIER+"."+WTABLE(NOTAB)+"') order by name" As [BXX]
      If [BXX]VCOL<>"ROWID"
        If PREM
            WTABCOL(WNBCOL)=","
        Endif
        PREM=1
        WTABCOL(WNBCOL)+=[BXX]VCOL : WNBCOL+=1
      Endif
    Next
    # FROM  (origine)
    WTABCOL(WNBCOL)=" FROM"-PDOSSIER+"." : WNBCOL+=1
    WTABCOL(WNBCOL)=PTABORI+" D1"

    # WHERE
    If (PIR) Then
      WNBCOL+=1 : WTABCOL(WNBCOL)=" WHERE "
      Local Integer IR
      For IR = 1 To PIR
        WNBCOL+=1 : WTABCOL(WNBCOL) = PREQ(IR)
      Next IR
    Endif

    Execsql From num$(GTYPDBA*2+1) Sql WTABCOL(1..WNBCOL)

  Endif

Commit


End


#########################################################
Funprog CAL_CMP_MNT (PMNT1, POPE, PMNT2, PMNTREF)
Value Decimal PMNT1
Value Char    POPE
Value Decimal PMNT2
Value Decimal PMNTREF
Local Integer RRES

# FQ107633
# Compare deux montants en fonction du signe d'un montant de rûˋfûˋrence et selon un opûˋrateur
# Opûˋrateur pris en compte <, <=, =, >=, >

  Local Decimal MNT1
  Local Decimal MNT2
  If (PMNTREF < 0) Then
    MNT1 = PMNT1 * -1
    MNT2 = PMNT2 * -1
  Else
    MNT1 = PMNT1
    MNT2 = PMNT2
  Endif

  RRES = 0
  Case POPE
    When "<"
      If (MNT1 < MNT2)  : RRES = 1 : Endif
    When "<="
      If (MNT1 <= MNT2) : RRES = 1 : Endif
    When "="
      If (MNT1 = MNT2)  : RRES = 1 : Endif
    When ">="
      If (MNT1 >= MNT2) : RRES = 1 : Endif
    When ">"
      If (MNT1 >  MNT2) : RRES = 1 : Endif
  Endcase

End RRES
