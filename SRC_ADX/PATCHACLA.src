#<AdxTL>@(#)11.0.0.0 $Revision$
Local Char PARAM(30)(1..1) , VALEUR(250)
GSERVEUR = 0
Call TRAITE_CHAR(VALEUR,PARAM,"","PATCH","PATCH",3,"") From GTRAITE
End

#---------------------------------------------------#
## Integration of data classes
#---------------------------------------------------#

$CLASSES
Local File =DOSSIER(D)+".ACLASSE"    [ACLA]
&         ,=DOSSIER(D)+".ACLASSE"    [ACLA2]
&         ,=DOSSIER(D)+".ACLASSE"    [ACLA3]
&         ,=DOSSIER(D)+".ACLAFLD"    [ACLAF]
&         ,=DOSSIER(D)+".ACLAPARFLD" [ACLFP]
&         ,=DOSSIER(D)+".ACLAPARFLD" [ACLFP2]
&         ,=DOSSIER(D)+".ACLAMET"    [ACLAM]
&         ,=DOSSIER(D)+".ACLAMET"    [ACLAM2]
&         ,=DOSSIER(D)+".ACLAPARDEF" [ACLPD]
&         ,=DOSSIER(D)+".ACLAPARDEF" [ACLPD2]
&         ,=DOSSIER(D)+".ACLAMETSTD" [ACLAT]
&         ,=DOSSIER(D)+".ACLAMETSTD" [ACLAT2]
&         ,=DOSSIER(D)+".ACLALNK"    [ACLAK]
&         ,=DOSSIER(D)+".ACLALNK"    [ACLAK2]
&         ,=DOSSIER(D)+".ACLAOPT"    [ACLAO]
&         ,=DOSSIER(D)+".ACLAOPT"    [ACLAO2]
&         ,=DOSSIER(D)+".ACLACOL"    [ACLAC]
&         ,=DOSSIER(D)+".ACLACOL"    [ACLAC2]
&         ,=DOSSIER(D)+".ACLAMAP"    [ACLAKP]
&         ,=DOSSIER(D)+".ACLAMAP"    [ACLAKP2]
&          ,=DOSSIER(D)+".AOBJET"     [AOB9]

Local Integer NMET, NOPE, NMETSTD, NLNK, NCOL, NOPT
Local Char    TBMET(GLONASM)(1..)
Local Char    TBCOL(GLONAVA)(1..)
Local Char    TBOPT(10)(1..)
Local Char    TBMETSTD(GLONASM)(1..)
Local Char    TBLNK(200)(1..)
Local Char    OLDACT(GLONACT)
Local Integer B,J
#95271
Local Char    RES_COD(80)(0..),RES_CLA(GLONACLA)(0..), RES_TIT(30)(0..)
Local Integer RES_TYP(0..), RES_MOD(0..), RES_ORD(0..), RES_NBR, RES_NO
Local Char    WWCODPAR(80)(0..),WWCODCLAPAR(GLONACLA)(0..),WWCODCUR(80)(0..),WWFLDCLE(250)(0..), WWINTITPAR(30)(0..)
Local Integer WWTYPINTPAR(0..), WWADRVAL(0..), WWTYPKEY(0..), WWNUMPAR(0..),WWTYPPAR(0..),WWNOLIB(0..),WWLNG(0..),WWTYPAFF(0..), WWNBRPARALL
#
Local Integer NBACLAKSPE,NBACLAKSTD

Read [ACLA]ACLA0 = NOMOBJ
If TYPENR=2 :#SCM deletion
 If fstat
  NEWOBJ = 1
  Raz [F:ACLA]
 Elsif [F:ACLA]CODACT>="X" & !find([F:ACLA]CODACT,ACTIV(1..NBACT))
  Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spécifique
  Gosub FIN_OBJ From PATCH
  Goto FIN_CLASSES
 Else
  NEWOBJ = 0
 Endif
 # Pour faire synchro des liens en fin de patch
 If dim(ISASWMOD)>0 : ISASWMOD+=1 : Endif
 Call DEBTRANS From GLOCK
 Gosub TR_ACLA
Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_ACLA
 Endif
 Gosub FIN_OBJ From PATCH
Endif
$FIN_CLASSES
Close Local File [ACLA], [ACLAF], [ACLFP], [ACLAM], [ACLPD], [ACLAT], [ACLAK], [ACLAO], [ACLAC] , [ACLAKP]
Close Local File [ACLA2], [ACLA3], [ACLFP2], [ACLAM2], [ACLPD2], [ACLAT2], [ACLAK2], [ACLAO2], [ACLAC2] , [ACLAKP2]
Close Local File [AOB9]
Return

$DEL_ACLA
Local Char CODE(GLONASW) : [L]CODE = [L]NOMOBJ
Trbegin [ACLA]
 Gosub ANNULE From SUBACLA
 If fstat : GOK = 0 : ER = 99 : ERFIC = "ACLASSE"-NOMOBJ : Return : Endif
 Delete [ACLA] Curr
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ACLASSZE"-NOMOBJ : Return
 Endif
Commit
Call  UPDATE_RIGHTSETAG(DOSSIER(D)) From ASYRFNC
Call DELETE_ALLSTC(DOSSIER(D),[L]NOMOBJ) From ACLAVALSUB
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ACLA",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

#-------------------------------------------------#
$TR_ACLA
[F:ACLA2]=[F:ACLA]
Trbegin [ACLA], [ACLAF], [ACLFP], [ACLAM], [ACLPD], [ACLAT], [ACLAK] , [ATX]#, [ACLAO]
#95271
Delete [ACLFP]  Where CODCLA=NOMOBJ & TYPPAR=9

NBACLAKSTD=0
NBACLAKSPE=0
NBZ = 0
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Normal End
    Break
   When 3 : # For each element
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "ACLA"   : Gosub ACLA1
     When "ACLAF"  : Gosub ACLA2
     When "ACLFP"  : Gosub ACLA3
     When "ACLAM"  : Gosub ACLA4
     When "ACLAO"  : Gosub ACLA5
     When "ACLPD"  : Gosub ACLA6
     When "ACLAT"  : Gosub ACLA7
     When "ACLAK"  : Gosub ACLA8
     When "ACLAC"  : Gosub ACLA9
     When "ACLAKP"  : Gosub ACLA10
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif

## removal of excess fields

 For [ACLAF]ACLAF0 Where CODCLA=NOMOBJ
  If !find([F:ACLAF]FLDCLA,ZONE(1..NBZ))
&  & ([F:ACLAF]ACTFLD<"X" or find([F:ACLAF]ACTFLD,ACTIV(1..NBACT)))
   Delete [ACLFP] Where CODCLA=[F:ACLAF]CODCLA & FLDCLA=[F:ACLAF]FLDCLA
   Delete [ACLAF] Curr
  Else
#   #96230
#   If [F:ACLAF]ACTFLD<>"" & APPLI<>GDOSX3 & [F:ACLAF]CODTYP<>""
#    Read [ACV]CODACT=[F:ACLAF]ACTFLD
#    If fstat or [F:ACV]FLACT<>2
#     Read [ATY]CODTYP=[F:ACLAF]CODTYP
#     If !fstat
#      Call CHANGE_CODTYP(0,[F:ATY]TYPTYP,[F:ACLAF]CODTYP,[F:ACLAF]LONG) From DOSDICDIV
#     Else
#      [F:ACLAF]CODTYP  = "A"
#      [F:ACLAF]LONG    = 1
#     Endif
#     [F:ACLAF]FLDGRP = ""
#     Rewrite [ACLAF]
#     If fstat
#      GOK = 0 : ER = 99 : ERFIC = "ACLAFLD"-[F:ACLAF]CODCLA-[F:ACLAF]FLDCLA : Break
#     Endif
#    Endif
#   Endif
#   #96528
#   If [F:ACLAF]ACTFLD<>"" & APPLI<>GDOSX3 & [F:ACLAF]LNKCLA<>""
#    Read [ACV]CODACT=[F:ACLAF]ACTFLD
#    If fstat or [F:ACV]FLACT<>2
#     Delete [ACLFP] Where CODCLA=[F:ACLAF]CODCLA & FLDCLA=[F:ACLAF]FLDCLA
#     Delete [ACLAF] Curr
#     Goto SUITEACLAF
#    Endif
#   Endif
   #96528
   If [F:ACLAF]ACTFLD<>"" & APPLI<>GDOSX3
    Read [ACV]CODACT=[F:ACLAF]ACTFLD
    If fstat or [F:ACV]FLACT<>2
     Delete [ACLFP] Where CODCLA=[F:ACLAF]CODCLA & FLDCLA=[F:ACLAF]FLDCLA
     Delete [ACLAF] Curr
     Goto SUITEACLAF
    Endif
   Endif
   #95271
   Gosub FILL_FLD_PAR
   For RES_NO=0 To [L]RES_NBR-1
    If !find(RES_COD(RES_NO),"AINSTANCE","APRONAME","AVALCNT","AEXIST","AVALUE","AFORMAT")
     Read [ACLFP]ACLFP0 = NOMOBJ;1;1;[F:ACLAF]FLDCLA;[L]RES_COD(RES_NO)
     If fstat
      Read [ACLFP]ACLFP0 = NOMOBJ;9;1;[F:ACLAF]FLDCLA;[L]RES_COD(RES_NO)
      If !fstat
       [F:ACLFP]TYPPAR=1
       Write [ACLFP]
       If fstat
        GOK = 0 : ER = 99 : ERFIC = "ACLAPARFLD"-[F:ACLFP]CODCLA-[F:ACLFP]FLDCLA-[F:ACLFP]CODPAR
        Break 2
       Endif
      Endif
     Endif
    Endif
   Next
   For RES_NO=0 To [L]WWNBRPARALL-1
    Read [ACLFP]ACLFP0 = NOMOBJ;1;2;[F:ACLAF]FLDCLA;[L]WWCODPAR(RES_NO)
    If fstat
     Read [ACLFP]ACLFP0 = NOMOBJ;9;2;[F:ACLAF]FLDCLA;[L]WWCODPAR(RES_NO)
     If !fstat
      [F:ACLFP]TYPPAR=1
      Write [ACLFP]
      If fstat
       GOK = 0 : ER = 99 : ERFIC = "ACLAPARFLD"-[F:ACLFP]CODCLA-[F:ACLFP]FLDCLA-[F:ACLFP]CODPAR
       Break 2
      Endif
     Endif
    Endif
   Next
  Endif
 $SUITEACLAF
 Next
 #95271
 Delete [ACLFP]  Where CODCLA=NOMOBJ & TYPPAR=9
 If ER or !OKOBJ : Goto ABORT : Endif

## removal of excess methods

 For [ACLAM]ACLAM0 Where CODCLA=NOMOBJ
  If !find([F:ACLAM]CODMET,TBMET(1..NMET))
&  & ([F:ACLAM]ACTMET<"X" or find([F:ACLAM]ACTMET,ACTIV(1..NBACT)))
   Delete [ACLPD] Where CODCLA=[F:ACLAM]CODCLA & CODE=[F:ACLAM]CODMET
   Delete [ACLAM]
  Endif
 Next

## removal of excess standard methods

 For [ACLAT]ACLAT0 Where CODCLA=NOMOBJ
  If !find([F:ACLAT]CODMETSTD,TBMETSTD(1..NMETSTD))
&  & ([F:ACLAT]ACTMETSTD<"X" or find([F:ACLAT]ACTMETSTD,ACTIV(1..NBACT)))
   Delete [ACLAT]
  Endif
 Next

## removal of excess Links

 For [ACLAK]ACLAK1 Where CODCLA=NOMOBJ
  If !find([F:ACLAK]REFLNK,TBLNK(1..NLNK))
&  & ([F:ACLAK]ACVLNK<"X" or find([F:ACLAK]ACVLNK,ACTIV(1..NBACT)))
   Delete [ACLAKP] Where CODCLA=[ACLAK]CODCLA & REFLNK=[F:ACLAK]REFLNK
   Delete [ACLAK]
  #96528
  Elsif [F:ACLAK]ACVLNK<>"" & [F:ACLAK]ACVLNK<"X" & APPLI<>GDOSX3
   Read [ACV]CODACT = [F:ACLAK]ACVLNK
   If fstat or [ACV]FLACT<>2
    Delete [ACLAKP] Where CODCLA=[F:ACLAK]CODCLA & REFLNK=[F:ACLAK]REFLNK
    Delete [ACLFP] Where CODCLA=[F:ACLAK]CODCLA & FLDCLA=[F:ACLAK]REFLNK
    Delete [ACLAF] Where CODCLA=[F:ACLAK]CODCLA & FLDCLA=[F:ACLAK]REFLNK
    Delete [ACLAK] Curr
   Endif
  Elsif [F:ACLAK]ACVLNK>="X" & !find([F:ACLAK]ACVLNK,ACTIV(1..NBACT)) : # Specific
   NBACLAKSPE+=1
   [F:ACLAK]NUMLIG=NBACLAKSTD+NBACLAKSPE
   Rewrite [ACLAK]
   If fstat
    GOK = 0 : ER = 99 : ERFIC = "ACLALNK"-[F:ACLA]CODCLA
   Endif
  Endif
 Next
 If ER or !OKOBJ : Goto ABORT : Endif

## removal of excess options

 For [ACLAO]ACLAO0 Where CODCLA=NOMOBJ
  If !find([F:ACLAO]OPTCOD,TBOPT(1..NOPT))
&  & ([F:ACLAO]OPTACT<"X" or find([F:ACLAO]OPTACT,ACTIV(1..NBACT)))
   Delete [ACLAO]
  Endif
 Next

## removal of excess collections, delete non-used collections

 For [ACLAC]ACLAC0 Where CODCLA=NOMOBJ
  J=0
  For [ACLAF] Where CODCLA=[F:ACLA]CODCLA & FLDGRP=[F:ACLAC]CODCOL
    J=1
    Break
  Next
  If J=0
   Delete [ACLAC]
#  Elsif !find([F:ACLAC]CODCOL,TBCOL(1..NCOL))
#&  & ([F:ACLAC]ACTCOL<"X" or find([F:ACLAC]ACTCOL,ACTIV(1..NBACT)))
#   Delete [ACLAC]
  Endif
 Next

 If ER or !OKOBJ : Goto ABORT : Endif

Commit

## Classe validation
If [L]ISOKSPOTTING=2
 Call TRACE_COR_PATCH("ACLA",NOMOBJ,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET
Endif

Gosub SAV_OPENI From PATCH
# Dans l'appli X3 , on ne valide que les objets des modules Superviseur, tronc commun, développement
# 119695: si patch SCM, on valide toujours
If GPRODUIT<>0 | APPLI<>GDOSX3 | find([F:ACLA]MODULE,1,9,10) | (dim([L]ISFULLMOD)>0 & [L]ISFULLMOD = 2)
 Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
 Local Integer ASAVGVALID : ASAVGVALID =GVALIDDIFF
 GVALIDDIFF = 3
 Call VALIDATION(0,APPLI,NOMOBJ) From SUBACLA
 GVALIDDIFF = ASAVGVALID
Endif
Gosub REST_OPENI From PATCH
Return

$ABORT
Rollback
Return


#---------------------------------------------------#
## Header data classes
#---------------------------------------------------#

$ACLA1
FICHIER = "ACLASSE" : ABR = "ACLA"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  # Respect des codes d'accès, table de contrôle , categ search
  If !NEWOBJ and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) and find(VARIA,"FLGSEARCH")>0
   If evalue("[F:ACLA]"+VARIA)=2
    OK = 0
   Endif
  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
MODOBJ = max(1,[F:ACLA]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
ACVOBJ = [F:ACLA]CODACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
 Read [ACV]CODACT = ACVOBJ
 If fstat or [F:ACV]FLACT<>2
  OKOBJ = 0 : Return
 Endif
Endif
#93648
If [F:ACLA]LNKOBJ<>""
 Read [AOB9]ABREV = [F:ACLA]LNKOBJ
 If fstat
  [F:ACLA]LNKOBJ=""
 Endif
Endif
If NEWOBJ
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ACLA]CREUSR = GUSER
  [F:ACLA]UPDUSR = GUSER
 Endif
 Write [ACLA]
Else
 # Get specifics treatments
 For B=0 To [F:ACLA2]NBRTRT-1
  If [F:ACLA2]ACTTRT(B)>="X" & !find([F:ACLA2]ACTTRT(B),ACTIV(1..NBACT))
   J=find([F:ACLA2]CODTRT(B),[F:ACLA]CODTRT(0..[F:ACLA]NBRTRT-1))
   If J
      [F:ACLA]CODTRT(J-1) = [F:ACLA2]CODTRT(B)
      [F:ACLA]TYPTRT(J-1) = [F:ACLA2]TYPTRT(B)
      [F:ACLA]ACTTRT(J-1) = [F:ACLA2]ACTTRT(B)
      [F:ACLA]RANTRT(J-1) = [F:ACLA2]RANTRT(B)
   Else
      J=[F:ACLA]NBRTRT
      [F:ACLA]NBRTRT +=1
      [F:ACLA]CODTRT(J) = [F:ACLA2]CODTRT(B)
      [F:ACLA]TYPTRT(J) = [F:ACLA2]TYPTRT(B)
      [F:ACLA]ACTTRT(J) = [F:ACLA2]ACTTRT(B)
      [F:ACLA]RANTRT(J) = [F:ACLA2]RANTRT(B)
   Endif
  Endif
 Next B
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ACLA]UPDUSR = GUSER
 Endif
 Rewrite [ACLA]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ACLASSE"-[F:ACLA]CODCLA : Return
Endif

If [F:ACLA]FLGACTX=2 or [F:ACLA]FLGBUFFER=2
 If dim(ISACTXMOD)>0 : ISACTXMOD+=1 : Endif
Endif
Return

#---------------------------------------------------#
## Properties
#---------------------------------------------------#

$ACLA2
NBZ += 1 : ZONE(NBZ) = IDENT
FICHIER = "ACLAFLD" : ABR = "ACLAF"
Read [ACLAF]ACLAF0 = NOMOBJ;IDENT
If fstat
 NEWZON = 1
 OLDACT = ""
 Raz [F:ACLAF]
Elsif ([F:ACLAF]ACTFLD>="X" & !find([F:ACLAF]ACTFLD,ACTIV(1..NBACT)))
# Specific
 Call ECR_TRACE([F:ACLAF]FLDCLA-mess(147,126,1)-"("+[F:ACLAF]ACTFLD+")",0) From GESECRAN
# Specific
 Gosub FIN_FIC From PATCH
 OLDACT = [F:ACLAF]ACTFLD
 Return
Else
 NEWZON = 0
 OLDACT = [F:ACLAF]ACTFLD
Endif
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  # Respect des codes d'accès, table de contrôle , categ search
  If !NEWOBJ and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) and find(VARIA,"ACS","CODCTL","TABCONT","CATSEARCH")>0
   If evalue("[F:ACLAF]"+VARIA)<>""
    OK = 0
   Endif
  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
#95271
Update [ACLFP2] Where CODCLA=NOMOBJ & TYPPAR=1 & FLDCLA=[F:ACLAF]FLDCLA With TYPPAR=9
Delete [ACLFP2] Where CODCLA=NOMOBJ & TYPPAR=2 & FLDCLA=[F:ACLAF]FLDCLA
#
If NEWZON
 Write [ACLAF]
Else
 Rewrite [ACLAF]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ACLAFLD"-[F:ACLAF]CODCLA-[F:ACLAF]FLDCLA : Return
Endif

Return



#---------------------------------------------------#
## Properties parameters
#---------------------------------------------------#

$ACLA3
FICHIER = "ACLAPARFLD" : ABR = "ACLFP"
Read [ACLAF]ACLAF0 = NOMOBJ;IDENT
If !fstat & OLDACT>="X" & !find(OLDACT,ACTIV(1..NBACT)) : # Specific
 Gosub FIN_FIC From PATCH
 Return
Endif
Raz [F:ACLFP]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
#95271
#Delete [ACLFP2] Where CODCLA=NOMOBJ & TYPPAR=[F:ACLFP]TYPPAR & TYPKEY=[F:ACLFP]TYPKEY & FLDCLA=[F:ACLFP]FLDCLA & CODPAR=[F:ACLFP]CODPAR
Write [ACLFP]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ACLAPARFLD"-[F:ACLFP]CODCLA-[F:ACLFP]FLDCLA-[F:ACLFP]CODPAR : Return
Endif
Return

#---------------------------------------------------#
## Methods
#---------------------------------------------------#

$ACLA4
FICHIER = "ACLAMET" : ABR = "ACLAM"
NMET += 1 : TBMET(NMET) = IDENT
Read [ACLAM]ACLAM0 = NOMOBJ;IDENT
If !fstat & [F:ACLAM]ACTMET>="X" & !find([F:ACLAM]ACTMET,ACTIV(1..NBACT)) : # Specific
 Gosub FIN_FIC From PATCH
 OLDACT = [F:ACLAM]ACTMET
 Return
Elsif !fstat
 OLDACT = [F:ACLAM]ACTMET
Else
 OLDACT = ""
Endif
Raz [F:ACLAM]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif

Delete [ACLPD2] Where CODCLA=NOMOBJ & CODE=[F:ACLAM]CODMET
Delete [ACLAM2] Where CODCLA=NOMOBJ & CODMET=[F:ACLAM]CODMET
Write [ACLAM]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ACLAMET"-[F:ACLAM]CODCLA-[F:ACLAM]CODMET : Return
Endif
Return

#---------------------------------------------------#
## Options
#---------------------------------------------------#

$ACLA5
FICHIER = "ACLAOPT" : ABR = "ACLAO"
NOPT += 1 : TBOPT(NOPT) = IDENT
Read [ACLAO]ACLAO0 = NOMOBJ;IDENT
If !fstat & [F:ACLAO]OPTACT>="X" & !find([F:ACLAO]OPTACT,ACTIV(1..NBACT)) : # Specific
 Gosub FIN_FIC From PATCH
 OLDACT = [F:ACLAO]OPTACT
 Return
Elsif !fstat
 OLDACT = [F:ACLAO]OPTACT
Else
 OLDACT = ""
Endif
Raz [F:ACLAO]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif

Delete [ACLAO2] Where CODCLA=NOMOBJ & OPTCOD=[F:ACLAO]OPTCOD
Write [ACLAO]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ACLAOPT"-[F:ACLAO]CODCLA-[F:ACLAO]OPTCOD : Return
Endif
Return

#---------------------------------------------------#
## Methods/Operations parameters
#---------------------------------------------------#

$ACLA6
FICHIER = "ACLAPARDEF" : ABR = "ACLPD"
Read [ACLAM]ACLAM0 = NOMOBJ;IDENT
If !fstat & OLDACT>="X" & !find(OLDACT,ACTIV(1..NBACT)) : # Specific
 Gosub FIN_FIC From PATCH
 Return
Endif
Raz [F:ACLPD]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
Delete [ACLPD2] Where CODCLA=NOMOBJ & CODE=[F:ACLPD]CODE & CODPAR=[F:ACLPD]CODPAR
Write [ACLPD]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ACLAPARDEF"-[F:ACLPD]CODCLA-[F:ACLPD]CODE-[F:ACLPD]CODPAR : Return
Endif
Return

#---------------------------------------------------#
## Mapping clés
#---------------------------------------------------#

$ACLA10
FICHIER = "ACLAMAP" : ABR = "ACLAKP"
Read [ACLAK]ACLAK0 = NOMOBJ;IDENT
If !fstat & OLDACT>="X" & !find(OLDACT,ACTIV(1..NBACT)) : # Specific
 Gosub FIN_FIC From PATCH
 Return
Endif
Raz [ACLAKP]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
Delete [ACLAKP2] Where CODCLA=NOMOBJ & REFLNK=[F:ACLAKP]REFLNK & KEYMAP=[F:ACLAKP]KEYMAP
Write [ACLAKP]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ACLAMAP"-[ACLAKP]CODCLA-[ACLAKP]REFLNK-[ACLAKP]KEYMAP : Return
Endif
Return

#---------------------------------------------------#
## Standard Methods
#---------------------------------------------------#

$ACLA7
FICHIER = "ACLAMETSTD" : ABR = "ACLAT"
NMETSTD += 1 : TBMETSTD(NMETSTD) = IDENT
Read [ACLAT]ACLAT0 = NOMOBJ;IDENT
If !fstat & [F:ACLAT]ACTMETSTD>="X" & !find([F:ACLAT]ACTMETSTD,ACTIV(1..NBACT)) : # Specific
 Gosub FIN_FIC From PATCH
 Return
Endif
Raz [F:ACLAT]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif

Delete [ACLAT2] Where CODCLA=NOMOBJ & CODMETSTD=[F:ACLAT]CODMETSTD
Write [ACLAT]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ACLAMETSTD"-[F:ACLAT]CODCLA-[F:ACLAT]CODMETSTD : Return
Endif
Return

#---------------------------------------------------#
## Links
#---------------------------------------------------#

$ACLA8
FICHIER = "ACLALNK" : ABR = "ACLAK"
NLNK += 1 : TBLNK(NLNK) = IDENT
Read [ACLAK]ACLAK0 = NOMOBJ;IDENT
If !fstat & [F:ACLAK]ACVLNK>="X" & !find([F:ACLAK]ACVLNK,ACTIV(1..NBACT)) : # Specific
 Gosub FIN_FIC From PATCH
 Return
Endif
Raz [F:ACLAK]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif

NBACLAKSTD=max(NBACLAKSTD,[F:ACLAK]NUMLIG)
Delete [ACLAK2] Where CODCLA=NOMOBJ & REFLNK=[F:ACLAK]REFLNK
Write [ACLAK]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ACLALNK"-[F:ACLAK]CODCLA-num$([F:ACLAK]NUMLIG) : Return
Endif
Return

#---------------------------------------------------#
## Collections
#---------------------------------------------------#

$ACLA9
FICHIER = "ACLACOL" : ABR = "ACLAC"
NCOL += 1 : TBCOL(NCOL) = IDENT
Read [ACLAC]ACLAC0 = NOMOBJ;IDENT
If !fstat & [F:ACLAC]ACTCOL>="X" & !find([F:ACLAC]ACTCOL,ACTIV(1..NBACT)) : # Specific
 Gosub FIN_FIC From PATCH
 OLDACT = [F:ACLAC]ACTCOL
 Return
Elsif !fstat
 OLDACT = [F:ACLAC]ACTCOL
Else
 OLDACT = ""
Endif
Raz [F:ACLAC]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif

Delete [ACLAC2] Where CODCLA=NOMOBJ & CODCOL=[F:ACLAC]CODCOL
Write [ACLAC]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ACLACOL"-[F:ACLAC]CODCLA-[F:ACLAC]CODCOL : Return
Endif
Return


#------------------------------------------------------
$FILL_FLD_PAR
#95271
Raz RES_COD,RES_CLA, RES_TIT
Raz RES_TYP, RES_MOD, RES_ORD, RES_NBR
Raz WWCODPAR,WWCODCLAPAR,WWCODCUR,WWFLDCLE, WWINTITPAR
Raz WWTYPINTPAR, WWADRVAL, WWTYPKEY, WWNUMPAR,WWTYPPAR,WWNOLIB,WWLNG,WWTYPAFF, WWNBRPARALL
If filinfo(filpath("FIL","AVIEWIND","fde",DOSSIER(D)),0)<0
 Local File =DOSSIER(D)+".ATABIND" [ATI]
Else
 Local File =DOSSIER(D)+".AVIEWIND" [ATI]
Endif
Local File =DOSSIER(D)+".ATYPE"      [ATY]

If [F:ACLAF]CODTYP<>""
 Read [ATY]CODTYP = [F:ACLAF]CODTYP
 If !fstat
  Call LOAD_TYPE_PARAM(DOSSIER(D),[F:ACLAF]CODTYP,RES_COD,RES_TYP,RES_TIT,RES_MOD,RES_CLA,RES_ORD,RES_NBR) From AFNC
 Endif
 If [F:ACLAF]LOBTAB<>""
  Read [ATI]NUMLIG = [F:ACLAF]LOBTAB;1
  If !fstat
   Call CHARGE_CLE([F:ATI]CODFIC,[F:ATI]DESCRIPT,DOSSIER(D),[F:ATY]CODCLA,[F:ACLAF]FLDCLA,1,WWCODPAR,WWCODCUR,WWTYPPAR,
& WWFLDCLE,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,
& WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,WWNBRPARALL) From SUBACLA
  Endif
 Elsif [F:ATY]CODCLA<>""
  Call CHARGE_CLA_ATI_CLE(DOSSIER(D),[F:ATY]CODCLA,[F:ACLAF]FLDCLA,1,WWCODPAR,WWCODCUR,WWTYPPAR,WWFLDCLE,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,
& WWNBRPARALL) From SUBACLA
 Endif
Endif
LogicClose File [ATI],[ATY]
Return

