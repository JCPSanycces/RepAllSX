Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DATDEB" : GZNUM = 1805 : Endif
Gosub _AFF
End

$ON_DATFIN
Onevent CONTROL Call C_DATFIN(zc) From W1HREQGOA0
Onevent BEFORE_AREA Gosub AV_DATFIN From W1HREQGOA0
Return

$AV_DATFIN
Chgfmt [M]DATFIN(indice) With "D:"+GFMDAT
Gosub _AFF
Return

Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DATFIN" : GZNUM = 1806 : Endif
Gosub _AFF
End

$CHG_STY
Return


