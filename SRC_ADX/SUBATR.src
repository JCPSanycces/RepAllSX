#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion objet ATR
Raz GPILOBJ
Call OBJET ("ATR",GBIDC1,GBIDC2) From GOBJET
End

#########################################################################
## Traitement SUBATR
#########################################################################
## Traduction table ATEXTE
#########################################################################
$ACTION
Case ACTION
      When "OUVRE"        : Gosub OUVRE
      When "FILGAUCHE"    : Gosub FILGAUCHE
      When "FILTRE"       : Gosub FILTRE
      When "SETBOUT"      : Gosub SETBOUT
      When "ABANDON"      : Gosub ABANDON
      When "VERIF_MOD"    : Gosub VERIF_MOD
      When "APRES_MODIF"  : Gosub APRES_MODIF
      When "FERME"        : Gosub FERME
      When "LIENS"        : Gosub LIENS
      When Default
Endcase
Return

########################################
$OUVRE

Gosub DEFVAR From ATRANSLATION

If !clalev([F:ATX])  : Local File ATEXTE  [ATX]  : Endif
If !clalev([F:ATX2]) : Local File ATEXTE  [ATX2] : Endif

#-----------------------------
# prog spe a chaque produit opdadx sur indusprd.....
# test si ca marche ou pas la remontée ..
#-----------------------------
Local Integer WOK
WOK = 0

Call EXISTE_ADX ("","","ATRANSLATIONB",WOK) From ORDSYS
If WOK = 1
   WOK =0
   WNBRFOLDER= 0
   Call OUVRE_FIC (GFOLDER_INDUS,GFOLDER_VERSION,GFOLDER_PRODUIT,WNBRFOLDER,WOK) From ATRANSLATIONB
Endif

Return

###########################################################
$LIENS

If not GIMPORT
    If [M]LAN <> GLANTRAD
        [M]ZLAN = GLANTRAD
        Read [ATX2]NUMERO = [M]ZLAN;[M]NUMERO
        If !fstat
         [M]ZTEXTE   = [F:ATX2]TEXTE
         [M]ZCOMMENT = [F:ATX2]COMMENT
        Else
         [M]ZTEXTE   = "?"
         [M]ZCOMMENT = ""
        Endif
    Else
        [M]ZLAN = "???"
        [M]ZTEXTE   = "?"
        [M]ZCOMMENT = ""
    Endif
Endif
Return

########################################
$FILTRE
# on affiche que les textes origine = lan ou blanc
# on ne doit pas afficher les textes francais d origine eng qui ne sont pas encore traduits
If [M]LAN=""
 #CRITERE = "[F:ATX]LAN="+"GLANREF"
 CRITERE = "LAN='"+GLANREF+"' and (LANORI='' or LANORI='"+GLANREF+"')"
Else
 #CRITERE = "[F:ATX]LAN="+"[M:TRA0]LAN"
 CRITERE = "LAN='"+[M]LAN+"' and (LANORI='' or LANORI='"+[M]LAN+"')"
Endif
Return

########################################
$FERME
Return

########################################
$SETBOUT
# En import autoriser la creation de du texte
If !GIMPORT
 Call VIREBOUT(CHAINE,"AC") From GOBJET   # A pour annul/supp et C pour création
Endif
Return

########################################
$VERIF_MOD
Gosub MISE_A_JOUR
Return

########################################
$APRES_MODIF
Return

########################################
$FILGAUCHE
# HN SI026 94912-1 GESATR filtre liste gauche ne fonctionne pas
If CRITERE=""
  If [M]LAN=""
    CRITERE = "LAN='"+GLANREF+"' and (LANORI='' or LANORI='"+GLANREF+"')"
  Else
    CRITERE = "LAN='"+[M]LAN+"' and (LANORI='' or LANORI='"+[M]LAN+"')"
  Endif
Else
  If [M]LAN="" & instr(1,CRITERE,"LAN='"+GLANREF+"' and (LANORI='' or LANORI='"+GLANREF+"')")=0
    CRITERE += " & LAN='"+GLANREF+"' and (LANORI='' or LANORI='"+GLANREF+"')"
  Elsif [M]LAN<>"" & instr(1,CRITERE,"LAN='"+[M]LAN+"' and (LANORI='' or LANORI='"+[M]LAN+"')")=0
    CRITERE += "& LAN='"+[M]LAN+"' and (LANORI='' or LANORI='"+[M]LAN+"')"
  Endif
Endif
# HN SI026 94912-1 Remplacé par ci-dessus
#If [M]LAN=""
# #CRITERE = "[F:ATX]LAN="+"GLANREF"
# CRITERE = "LAN='"+GLANREF+"' and (LANORI='' or LANORI='"+GLANREF+"')"
#Else
# #CRITERE = "[F:ATX]LAN="+"[M:TRA0]LAN"
# CRITERE = "LAN='"+[M]LAN+"' and (LANORI='' or LANORI='"+[M]LAN+"')"
#Endif
Return
######################################

$ABANDON
Return

########################################
## Mise a jour fichier                ##
########################################
$MISE_A_JOUR
Local Char MESSAGE(250)
Local Integer ASTATUS

If [M:TRA0]NUMERO = 0 : Return : Endif


If [M]ZLAN = GFRA
    # autorisé uniquement sur ls txtes sup à 50000 (100000 en V5)
    #115210/6
    If [M:TRA0]NUMERO < GMAXTXTSTD | [M:TRA0]NUMERO>GNEWTXTSTD
            Return
    Endif
Endif

If [M]LAN <> [M]ZLAN
 Trbegin [ATX2]
  Readlock [ATX2]NUMERO =[M:TRA0]ZLAN;[M:TRA0]NUMERO
  If fstat=1
   GOK=-1 : GLOCK="$ATEXTE"-num$([M:TRA0]NUMERO) : Goto ROLL_TR_MTEX
  Elsif fstat
   [F:ATX2]LAN     = [M:TRA0]ZLAN
   [F:ATX2]NUMERO  = [M:TRA0]NUMERO
   [F:ATX2]TEXTE   = [M:TRA0]ZTEXTE
   [F:ATX2]CLEREC  = left$(vireblc(toupper(ctrans([M:TRA0]ZTEXTE)),4),20)
   [F:ATX2]LONG    = [M:TRA0]LONG
   [F:ATX2]NOMZON  = [M:TRA0]NOMZON
   [F:ATX2]NOMOBJ  = [M:TRA0]NOMOBJ
   [F:ATX2]TYPOBJ  = [M:TRA0]TYPOBJ
   [F:ATX2]LANORI  = ""
   [F:ATX2]COMMENT = [M:TRA0]ZCOMMENT
   Call FLDCRE("ATX2") From OBJDIV
   Write [ATX2]
  Else
   [F:ATX2]CLEREC  = left$(vireblc(toupper(ctrans([M:TRA0]ZTEXTE)),4),20)
   [F:ATX2]TEXTE   = [M:TRA0]ZTEXTE
   [F:ATX2]COMMENT = [M:TRA0]ZCOMMENT
   If [F:ATX2]LANORI <> [F:ATX2]LAN
       [F:ATX2]LANORI  = ""
   Endif
   Call FLDUPD("ATX2") From OBJDIV
   Rewrite [ATX2]
  Endif
  If fstat
   GOK=0 : Call FSTA("ATX") From GLOCK : Goto AB_TR_MTEX
  Endif
  #115210
  If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" & ([F:ATX2]NUMERO<GMAXTXTSTD | [F:ATX2]NUMERO>GNEWTXTSTD)
    ASTATUS = func ATXTSVC.UPDATE_ONETEXT_CHAR(GPRODUIT, [F:ATX2]NUMERO, [F:ATX2]LAN, [F:ATX2]TEXTE,[F:ATX2]COMMENT,[F:ATX2]LANORI,MESSAGE)
    If ASTATUS<>[V]CST_AOK
     GMESSAGE=MESSAGE : GOK=0
    Endif
  Endif
  Commit
Endif


#----------------------------
# mise a jour des envir indus en interne
# apres le commit dans le dossier en cours car cette partie se lance depusi indusprd
If [M]LAN <> [M]ZLAN
  If WNBRFOLDER <> 0
    Local Integer WOK
    WOK = 0
    Local Char WTRACE
    Raz WTRACE
    Call EXISTE_ADX ("","","ATRANSLATIONB",WOK) From ORDSYS
    If WOK = 1
       # si tout est ok alors là on met a jour les autres envri..
        # a faire apres le commit.... sur indusprd
        WOK = 0
        Call MAJ_TRADTEX([M:TRA0]NUMERO,[M]ZLAN,GFOLDER_INDUS,GFOLDER_VERSION,GFOLDER_PRODUIT,WNBRFOLDER,WTRACE,WOK) From ATRANSLATIONB
    Endif
  Endif
Endif

Return

$AB_TR_MTEX
Rollback
Return

$ROLL_TR_MTEX
Call ROLL From GLOCK
If GROLL : Return : Else : Goto MISE_A_JOUR : Endif


#####################################################################################################
############################# ETIQUETTES CHAMP          #############################################
#####################################################################################################

########################################################
## Affichage liste de gauche en fonction du type      ##
########################################################
Subprog AM_LAN(VALEUR)
Variable Char VALEUR()
If not GIMPORT
    Filter  [ATX] Where LAN=VALEUR
    Fillbox [TRA0]  GAU_CHE
    Filter  [ATX]
Endif

[M]LAN = VALEUR
If not GIMPORT
    If [M]LAN = [M]ZLAN
        [M]ZLAN = ""
        [M]ZTEXTE = ""
        [M]ZCOMMENT= ""
        Affzo 10
      Endif
Endif
End
#########################################################################
Subprog C_NUMERO(VALEUR)
Variable Decimal VALEUR

# SI langue origine n'est pas le FRA
# on autorise que les textes spécifiques

If [M]LAN <> GFRA
    #115210/6
    If VALEUR < GMAXTXTSTD | VALEUR>GNEWTXTSTD
        mkstat = 2
        End
    Endif
Endif

End


########################################
Subprog AM_NUMERO(VALEUR)
Variable Decimal VALEUR
If GIMPORT : End : Endif

Read[ATX2]NUMERO = [M:TRA0]LAN;VALEUR
If fstat
 mkstat=2
Endif
End

########################################
Subprog AV_NUMERO(VALEUR)
Variable Decimal VALEUR
End


########################################
Subprog AM_ZLAN(VALEUR)
Variable Char    VALEUR()

If GIMPORT : End : Endif

Read[ATX2]NUMERO = VALEUR;[M:TRA0]NUMERO
If fstat=0
 [M:TRA0]ZTEXTE   = [F:ATX2]TEXTE
 [M:TRA0]ZCOMMENT = [F:ATX2]COMMENT
Else
 [M:TRA0]ZTEXTE  = "?"
 [M:TRA0]ZCOMMENT = ""
Endif

Affzo [M:TRA0]ZTEXTE
Affzo [M:TRA0]ZCOMMENT
Affzo [M:TRA0]LONG

GLANTRAD=VALEUR
End

########################################
Subprog AV_LAN(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog AM_ZTEXTE(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog C_ZTEXTE(VALEUR)
Variable Char    VALEUR()
If [M]ZLAN=""
    mkstat = 2
Endif
End

########################################
Subprog B1_NUMERO(VALEUR)
Variable Decimal VALEUR
Local Integer WNUM
End

########################################
Subprog AS_NUMERO(VALEUR)
Variable Decimal VALEUR
End

########################################
Subprog C_ZLAN(VALEUR)
Variable Char    VALEUR()

#Interdire de modifier les textes Francais
# sauf pour les textes spécifiques
If VALEUR = GFRA
    #115210/6
    If [M]NUMERO < GMAXTXTSTD | [M]NUMERO>GNEWTXTSTD
         mkstat = 2
        End
    Endif
Endif
If not GIMPORT
    # de même on interdit que lan = zlan
    If VALEUR = [M]LAN
          mkstat = 2
          End
    Endif
Endif

End
##########################################################################

