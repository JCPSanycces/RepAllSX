Global Integer GMIGX3VER70 : GMIGX3VER70=40

Global Integer GMIGX3VER80 : GMIGX3VER80=50

Global Integer GMIGX3VER90 : GMIGX3VER90=60

Global Integer GMIGX3VER100 : GMIGX3VER100=70

Global Integer GMIGX3VER110 : GMIGX3VER110=80
Global Integer GMIGX3VER112 : GMIGX3VER112=82

Global Integer GMIGX3VER120 : GMIGX3VER120=90

Endif
Return

############################################################################
Subprog TRTMIGTABX3(DOSSIER)
Value Char DOSSIER

Call ECR_TIME("TRTMIGTABX3 : Process Start on : "+DOSSIER) From DOSSUB
Gosub TRTMIGTAB_OPEN From TRTMIG
If GOK<1 : Goto FIN : Endif
Gosub DEF_VERSIONSX3
####
