#<AdxTL>@(#)11.0.0.0 $Revision$
##############################################################################
# TRTMIGTABX3      Préparation des tables de flux         Module Superviseur #
##############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOS(DOSSIER,"") From SAIDOS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("TRTMIGTABX3") From LECFIC
  Endif

  If dim(GERRDOS)<0 : Global Integer GERRDOS : Endif
  GERRDOS=0
  Call TRTMIGTABX3(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End

############################################################################
$DEF_VERSIONSX3
If dim(GMIGX3VER60)<=0

Global Integer GMIGX3VER60 : GMIGX3VER60=30
Global Integer GMIGX3VER61 : GMIGX3VER61=31
Global Integer GMIGX3VER62 : GMIGX3VER62=32
Global Integer GMIGX3VER63 : GMIGX3VER63=33
