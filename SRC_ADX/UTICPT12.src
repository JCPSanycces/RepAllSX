#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################
# UTICPT12   Suppression du code activité T1001             Module CPT   #
#                                                                        #                     
##########################################################################
Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTICPT12(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTICPT12(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTICPT12 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
Local File =DOSSIER+".ACTIV"   [ACVF]
Local File ADOSACT [ADAF]
Local File =DOSSIER+".ADOCUMENT"   [ADOF]

Call DEBTRANS From GLOCK

Trbegin [ACVF], [ADAF], [ADOF]

Readlock [ACVF]CODACT ="T1001"
If !fstat
 Delete [ACVF] Curr
 If fstat=1
  # Erreur d'effacement
  GOK = 0 : Call ECR_TRACE(mess(28,125,1)-"ACTIV : T1001",-1) From GESECRAN : Goto AB_UTICPT12 
 Endif
Endif

Readlock [ADAF]ADA0 =DOSSIER;"T1001"
If !fstat
 Delete [ADAF] Curr
 If fstat=1
  # Erreur d'effacement
  GOK = 0 : Call ECR_TRACE(mess(28,125,1)-"ADOSACT: T1001",-1) From GESECRAN : Goto AB_UTICPT12 
 Endif
Endif

Update [ADOF] Where CODACT="T1001" With CODACT = "T1000"
If fstat
 # Erreur d'effacement
 GOK = 0 : Call ECR_TRACE(mess(28,125,1)-"ADOCUMENT: T1001",-1) From GESECRAN : Goto AB_UTICPT12 
Endif

Commit
Close Local File [ACVF], [ADAF], [ADOF]
Call ECR_TRACE("UTICPT12 : record processed",0) From GESECRAN
End

$AB_UTICPT12
Rollback
End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
#If APPLI=GDOSX3: End : Endif
Call MAJ_UTICPT12(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
#If APPLI=GDOSX3 :  End : Endif 
Call MAJ_UTICPT12(APPLI)
End




