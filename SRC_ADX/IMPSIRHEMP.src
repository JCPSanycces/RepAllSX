#<AdxTL>@(#)5.0.0.0 $Revision$
################################################################################################
# Modifications :
#    MABOS - 11/04/13 - FQ71754 - US1516- Remove the control on the civility 2 (Mrs./Madame)
#                                          to give the possibility to add the birth Name in all cases.
################################################################################################

Call IMPORTATION("SIRHEMP") From GIMPOBJ
End
################################################################################################

$ACTION
Case ACTION
 When "IMP_OUVRE"     : Gosub IMP_OUVRE
 When "IMP_VERIF_CRE" : Gosub VERIF
 When "IMP_VERIF_MOD" : Gosub VERIF
 When "IMP_MODIF"     : Gosub MAJ
 When "IMP_CREATION"  : Gosub MAJ
Endcase
Return

$IMP_OUVRE
If clalev([F:ID1])=0 : Local File EMPLOID [ID1] : Endif
Return

$VERIF
# Uniquement modification. Pas d'ajout
Read[ID1]ID0=[F:ID]REFNUM
If fstat
 # Matricule inexistant
 Call TRACE(2,mess(83,10702,1)-":"-[F:ID]REFNUM) From SUBIMPOBJ
 OK=0 :  Return
Endif
Return

$MAJ
#MABOS-11/04/13-FQ71754-US1516
#If [F]CIV<>2 : # Différent de Madame => Monsieur ou Mademoiselle.
If [F]OLDNAM=""
 [F]OLDNAM = [F]NAM
Endif
If [F]CIV=1
 [F]SEX = 1
Elsif [F]CIV=2 | [F]CIV=3
 [F]SEX = 2
Endif
Rewrite
If fstat
 GOK=0 : Call FSTA(ABFIC) From GLOCK
Endif
Return
