#<AdxTL>@(#)2.0.0.0 $Revision$
Call OBJET("RLK",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "DEBUT"    : Gosub DEBUT
 When "AP_CHOIX" : Gosub CHOIX
 When Default 
Endcase
Return

$OUVRE
Local Integer OK, STAT, EXISTE, FLG1, FLG2
Local Char BANK(GLONBAN)

BANK = VALEUR
GOK = 1
Call ACCES_POINTAGE(GOK,BANK) From SUBCHK : # Contrôle accés à la fonction
If !GOK
 GMESSAGE = mess(25,120,1)-BANK
 # Vous n'avez pas accès à la banque
 mkstat = 2
 FIN=1 : Return
Endif
Read [BAN]BAN0=BANK
If [F:BAN]CRY="" : [M:RLK]CRY = GPAYS : Else : [M:RLK]CRY = [F:BAN]CRY : Endif
[M:RLK]BANCUR = [F:BAN]CUR
[M:RLK]BIDNUM = [F:BAN]BIDNUM
EXISTE=0
Read [RBK]RBK0 = BANK;[M:RLK]RBKNUM;1;1
If !fstat
  [M:RLK]ORI = [F:RBK]ORI 
  If [M:RLK]ORI=0 : [M:RLK]ORI=1 : Endif
  If [F:BAN]CUR<>[F:RBK]CUR
   [M:RLK]BANCUR = [F:RBK]CUR
  Endif
  EXISTE=1
  FIN = 1
Endif
Call LECTURE("TCU",[M:RLK]BANCUR,"") From CONTOBJ
[M:RLK]ZBANCUR = [F:TCU]CURDES
Affzo [M:RLK]BANCUR, ZBANCUR
#
If !EXISTE
  Call PARAM([F:BAN]CPY,"SNSBNQ",GDIV(0)) From ADOVAL
  Filter [RBK] Where BAN=BANK & RECTYP=3 Order By Key RBK1
  Read [RBK] Last
  Filter [RBK]
  If fstat 
   Raz [M:RLK]OLDAMT, OLDDAT : FIN=1 
  Else
   [M:RLK]OLDDAT = [F:RBK]OPEDAT
   If [M:RLK]BANCUR=[F:RBK]CUR
    [M:RLK]OLDAMT = [F:RBK]AMTCUR
    FIN = 1
   Else
    # il faut proposer l'ancien solde dans la nouvelle devise
    # si une devise 'Out' intervient, il faut donner un cours
    Gosub CNV_SOLDE
   Endif
  Endif
  Gosub AFFLIG
Endif
Return

$CNV_SOLDE
Call LECTURE("CPY",[F:BAN]CPY,"") From CONTOBJ
FLG1=1 : FLG2=1
Call LECTURE("TCU",[F:RBK]CUR,"") From CONTOBJ
If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] or [F:TCU]EURDAT<=[M:RLK]OLDDAT)
  FLG1 = 2
Endif
Call LECTURE("TCU",[M:RLK]BANCUR,"") From CONTOBJ
If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] or [F:TCU]EURDAT<=[M:RLK]OLDDAT)
  FLG2 = 2
Endif
If (FLG1=2 & FLG2=2) | (FLG1=1 & FLG2=1)
 STAT=0
 Call CONVERT([F:RBK]CUR,[M:RLK]BANCUR,[F:CPY]ACCCUR,1,[M:RLK]OLDDAT,[F:RBK]AMTCUR,
&             [M:RLK]OLDAMT,STAT) From TRTDEV
 If STAT=0
  # La devise de banque est passée en [M:RLK]BANCUR. Veuillez valider l'ancien solde.
  OK=2 : Call AVERTIR(mess(116,121,1)-[M:RLK]BANCUR+"."-mess(117,121,1),OK) From GESECRAN
 Else
  # Veuillez saisir l'ancien solde en [M:RLK]BANCUR
  OK=2 : Call AVERTIR(mess(118,121,1)-[M:RLK]BANCUR,OK) From GESECRAN
 Endif
 FIN = 1
Endif
Return

$DEBUT
[M:RLK]OLDAMT = [F:RBK]AMTCUR
Gosub AFFLIG
[M:SRTC]RATCUR = 1
If FLG1=1 & FLG2=2
 [M:SRTC]LABEL = "1"-[F:RBK]CUR-"="
 [M:SRTC]CUR2 = GEURO
Elsif FLG1=2 & FLG2=1
 [M:SRTC]LABEL = "1"-GEURO-"="
 [M:SRTC]CUR2 = [M:RLK]BANCUR
Endif
Affzo [M:SRTC]
Return

$CHOIX
Case REPONSE
 When GSTARET, GSTAOK  : Gosub ENREG
 When GSTAEND, GSTAESC : FIN=1
Endcase
Return

$ENREG
Call CONVERT3([F:RBK]CUR,[M:RLK]BANCUR,[F:CPY]ACCCUR,1,[M:RLK]OLDDAT,[F:RBK]AMTCUR,
&             [M:RLK]OLDAMT,[M:SRTC]RATCUR,STAT) From CPTSUB
Gosub AFFLIG
Return

$AFFLIG
If ([F:RBK]SNS = 1  & val(GDIV(0)) = 1) : [M:RLK]OLDSNS = 1 : Endif 
If ([F:RBK]SNS = -1 & val(GDIV(0)) = 1) : [M:RLK]OLDSNS = 2 : Endif 
If ([F:RBK]SNS = 1  & val(GDIV(0)) = 2) : [M:RLK]OLDSNS = 2 : Endif 
If ([F:RBK]SNS = -1 & val(GDIV(0)) = 2) : [M:RLK]OLDSNS = 1 : Endif 
If [M:RLK]NBLIG>0 : Dela 0,[M:RLK]NBLIG [M:RLK]NBLIG : [M:RLK]NBLIG=0 : Endif
[M:RLK]NEWAMT=[M:RLK]OLDAMT 
[M:RLK]NEWDAT=[M:RLK]OLDDAT
Affzo [M:RLK]OLDAMT, NEWAMT, NEWDAT, OLDDAT, OLDSNS, NEWSNS
Return

