#<AdxTL>@(#)0.0.0.0 $Revision$
End
############################################################
############################################################
$FILL_LOF
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T    = [F:LOF]CODLOF + "/" + num$([F:LOF]LINLOF)
  VCRTYP_T    = NUM_LOF
  #If dim(LOF_L) >= 0 Then
  #  VCRLIN_T  = LOF_L
  #Endif
  VCRLIN_T  = [F:LOF]LINLOF
  #
  VCRNUMCALC_T = [F:LOF]CODLOF + "/" + num$([F:LOF]LINLOF)
  #
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T  = [F:PKW]VCRNUM
    VCRLINORI_T  = [F:PKW]VCRLIN
    VCRTYPORI_T  = [F:PKW]VCRTYP
  Endif
  IPTDAT_T    = [F:LOF]DATIMP
  #
  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1)  = func CONSPITOOLS.GET_MESSAGE(3117, [F:LOF]TYPVCR)
  STBVCRSTAT(2) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, [F:LOF]FLGLIKAAS)
  #
  If [M:PIV1]VCRTYPSEL = NUM_LOF Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(3117, [F:LOF]TYPVCR)
    [M:PIV1]VCRSTA_S = func CONSPITOOLS.GET_MESSAGE(1, [F:LOF]FLGLIKAAS)
  Endif
  SALFCY_T    = [F:LOF]FCY
  STOFCY_T    = ""
  BPRNUM_T    = [F:LOF]BPR
  JOU_T       = [F:LOF]JOU
  REP1_T      = ""
  REP2_T      = ""

  CURS        = [F:LOF]CUR
  WCHGTYP     = [F:LOF]CURTYP
  ORDNOT_T    = [F:LOF]AMTNOTCUR
  ORDATI_T    = [F:LOF]AMTNOTCUR + [F:LOF]AMTVATCUR - [F:LOF]AMTVATRCUR
  SCURVCR_T   = [F:LOF]CUR
  WMNTORG(0)  = [F:LOF]AMTNOTCPY
  WMNTORG(1)  = [F:LOF]AMTNOTCPY + [F:LOF]AMTVATCPY - [F:LOF]AMTVATRCPY
  Gosub CALC_MNT From CONSPITOOLS
Return

############################################################
$FILL_FAS
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T    = [F:FAS]AASREF
  VCRTYP_T    = NUM_FAS
  If dim(FAS_L) >= 0 Then
    VCRLIN_T  = FAS_L
  Endif
  #
  VCRNUMCALC_T = [F:FAS]AASREF
  #
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T  = [F:PKW]VCRNUM
    VCRLINORI_T  = [F:PKW]VCRLIN
    VCRTYPORI_T  = [F:PKW]VCRTYP
  Endif
  IPTDAT_T    = [F:FAS]AASIPTDAT
  #
  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1)  = func CONSPITOOLS.GET_MESSAGE(2628, [F:FAS]GACACN)
  If [F:FAS]ISSDAT <> [0/0/0] Then
    STBVCRSTAT(2) += STBVCRSTAT(0) + format$("D:"+GFMDAT4, [F:FAS]ISSDAT)
    STBVCRSTAT(3) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(3159, [F:FAS]ISSTYP)
  Else
    STBVCRSTAT(2) = ""
    STBVCRSTAT(3) = ""
  Endif
  #
  If [M:PIV1]VCRTYPSEL = NUM_LOF Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(2628, [F:FAS]GACACN)
    If [F:FAS]ISSDAT <> [0/0/0] Then
      [M:PIV1]VCRSTA_L = format$("D:"+GFMDAT4, [F:FAS]ISSDAT)
    Endif
    [M:PIV1]VCRSTA_C = func CONSPITOOLS.GET_MESSAGE(3159, [F:FAS]ISSTYP)
  Endif
  SALFCY_T    = [F:FAS]FCY
  STOFCY_T    = ""
  BPRNUM_T    = [F:FAS]BPR
  JOU_T       = ""
  REP1_T      = ""
  REP2_T      = ""

  CURS        = [F:FAS]ACGCUR
  ###WCHGTYP     = [F:FAS]CURTYP
  ORDNOT_T    = [F:FAS]ACGETRNOT
  ORDATI_T    = [F:FAS]ACGETRNOT + [F:FAS]IVCVATAMT - [F:FAS]DEDVATAMT
  SCURVCR_T   = [F:FAS]ACGCUR
  WMNTORG(0)  = [F:FAS]ACGETRNOT
  WMNTORG(1)  = [F:FAS]ACGETRNOT + [F:FAS]IVCVATAMT - [F:FAS]DEDVATAMT
  Gosub CALC_MNT From CONSPITOOLS
Return

############################################################
$FILTER_LOF
  WABFIC = "LOF"
  If dim([M:PIV1]VCRNUMSEL) > 0 and [M:PIV1]VCRNUMSEL <> "" Then
    Call ADDCRIT(WFIL,GBIDI1,"WFIL","pat([F:LOF]CODLOF,[M:PIV1]VCRNUMSEL)<>0","&") From GOBJSUB
    Call ADDCRIT(WFIL1,GBIDI1,"WFIL1","pat([F:LOF]CODLOF,[M:PIV1]VCRNUMSEL)<>0","&") From GOBJSUB
  Endif
Return

############################################################
$FILTER_FAS
  WABFIC = "FAS"
  If dim([M:PIV1]VCRNUMSEL) > 0 and [M:PIV1]VCRNUMSEL <> "" Then
    Call ADDCRIT(WFIL,GBIDI1,"WFIL","pat([F:FAS]AASREF,[M:PIV1]VCRNUMSEL)<>0","&") From GOBJSUB
    Call ADDCRIT(WFIL1,GBIDI1,"WFIL1","pat([F:FAS]AASREF,[M:PIV1]VCRNUMSEL)<>0","&") From GOBJSUB
  Endif
Return
