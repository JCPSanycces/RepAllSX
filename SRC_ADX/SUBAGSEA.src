#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
    When "OUVRE"   : Gosub OUVRE
    When "FINSAI"  : Gosub FINSAI
    When "SETBOUT" : Gosub SETBOUT
    When "DEBUT"   : Gosub DEBUT
    When "BOUTON"  : Gosub BOUTON
    When "APRES_MODIF" : Gosub APRES_MODIF
Endcase

Return

##############################################
$OUVRE
Local File AGDPRSETTING [AGS]
Return

##############################################
$FINSAI
LogicClose File [AGS]
Return

##############################################
$SETBOUT
If [M:AGSEA0]CODSEA=""
    Call VIREBOUT(CHMEN,"S") From GOBJET : # Search
Endif
If [M:AGSEA1]NBLIG=0
    Call VIREBOUT(CHMEN,"E") From GOBJET : # Export
Endif
Return

##############################################
$DEBUT
Effzo [M:AGSEA0]10
nolign=0
# Load list of "References"
For [AGS] Where TYP=1 & ENAFLG=2
    nolign+=1
    [M:AGSEA0] = [F:AGS]
    [M:AGSEA0]NBLIG += 1
Next
Affzo [M:AGSEA0]10
Return

##############################################
$BOUTON
Case BOUT
    When "S" : Call SEARCH
    When "E" : Call EXPORT
Endcase
Return

$APRES_MODIF
# To be able to test the new value of CODSEA in SETBOUT we must assign it
If COUZON="CODSEA"
    [M:AGSEA0]CODSEA = CZ
Endif
Return


Subprog SEARCH
Local Char TYPLST(type([F:AGS]CODE)-10)(1..)
Call GET_TYPLST(TYPLST)
Local Char LMSG(250)
# no selection => no search
If TYPLST(1)=""
    End
Endif
If func TRTAGSEA.SEARCH_MINMAX(nomap,TYPLST,[M:AGSEA0]CODSEA,1,LMSG)<>[V]CST_AOK
    Call ERREUR(LMSG) From GESECRAN
Endif
Affzo [M:AGSEA1]
End

Subprog EXPORT
Local Char TYPLST(type([F:AGS]CODE)-10)(1..)
Local Char LMSG(250)
# Upload file to client
Local Char FICCLI(GDIMFIC)
Local Char FICSRV(GDIMFIC)
Local Integer STA

Call GET_TYPLST(TYPLST)
# Write in a file all the matches
FICSRV = filpath("TRA", "PData_"+[M:AGSEA0]CODSEA , "tra")
Openo FICSRV, 0 Using [AGDPR]
If func TRTAGSEA.SEARCH_CODE(nomap, TYPLST, [M:AGSEA0]CODSEA, "", 2, LMSG)=[V]CST_AERROR
    Call ERREUR(LMSG) From GESECRAN
Endif
Openo Using [AGDPR]

FICCLI = "PersonnalData_"+[M:AGSEA0]CODSEA+".csv"
Call SET_NAMCLI(FICCLI) From ORDSYS
Call MOVCLI(FICSRV,FICCLI,STA) From ORDSYS
Call EFFACE(FICSRV,STA) From ORDSYS

End

#**
#* return list of GDPR setting codes selected in the screen [M:AGSEA0]
#*
#* @param PTYPLST
#*!
Subprog GET_TYPLST(PTYPLST)
Variable Char PTYPLST()(1..)
Local Integer I,J
J=0
For I=0 To [M:AGSEA0]NBLIG-1
    If [M:AGSEA0]SELFLG(I)=2
        J+=1
        PTYPLST(J) = [M:AGSEA0]CODE(I)
    Endif
Next
End

######################################################################################
Subprog AM_CODSEA(VALEUR)
Variable Char    VALEUR()
Call SELECT_TYP(nomap,VALEUR)
Effzo [M:AGSEA1]
End


######################################################################################
Subprog SELECT_TYP(PDOSSIER,PCODSEA)
Value Char PDOSSIER
Value Char PCODSEA
Local Integer I
Local Integer DATATYPE

For I=0 To [M:AGSEA0]NBLIG-1
    [M:AGSEA0]SELFLG(I)=1
    If [M:AGSEA0]CODATB(I)<>""
&    & [M:AGSEA0]CODFLD(I)<>""
&    & filinfo(filpath("FIL",[M:AGSEA0]CODATB(I),"fde",PDOSSIER),0)>=0
        Local File =PDOSSIER+"."+[M:AGSEA0]CODATB(I) [REF]
        DATATYPE = evalue("type([F:REF]"+[M:AGSEA0]CODFLD(I)+")")

        If DATATYPE>0 & DATATYPE<8
            # check that code to search is numerical
            If val(PCODSEA)=0 & PCODSEA<>string$(len(PCODSEA),"0")
                DATATYPE=-1
            Endif
        Endif
        If DATATYPE>0 & DATATYPE<8
            Filter [REF] Where evalue([M:AGSEA0]CODFLD(I)+"="+PCODSEA)
        Elsif DATATYPE>10 & DATATYPE<266
            Filter [REF] Where evalue([M:AGSEA0]CODFLD(I)+"='"+PCODSEA+"'")
        Endif
        If DATATYPE>0 & DATATYPE<266
            Look [REF] First
            If fstat=[V]CST_AOK
                [M:AGSEA0]SELFLG(I)=2
            Endif
            Filter [REF]
        Endif

        LogicClose File [REF]
    Endif
    Affzo [M:AGSEA0]SELFLG(I)
Next
End

