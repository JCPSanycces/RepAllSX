#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion objet AYC
Raz GPILOBJ,GNBMASKOUV
Call OBJET("AYC",GBIDC1,GBIDC2) From GOBJET
End
######################################################################################
## Xtend:  Gestion Menu Xtend
#
#    Table AYTLINES (AYN)
#        LINCODTYP = 7    Menu  
#        LINTYP    = 60    lignes de menu  
#
#        MENLINTYP    0    menu racine
#                     1    entrĂŠe dossier
#                     2    entrĂŠe lien dynamique
#
#  Version 0002
#
#  Nota $001: Code pour forcer l'entrĂŠe en modif (en V5, on ne sait pas remontĂŠe un flag
#             pour activer le bouton enregistrer de l'objet)
#                Pose un pb avec le bouton validation
#                - une piste comme les requĂŞtes graphiques
#                    abandonnĂŠe car trop contraignante -> tj en modif dĂ¨s qu'on est sur le chps graph.
#                - utilisation d'un flag et ctl dans APRES_CHOI 
#  E46684     Gestion menu hiĂŠrachique
######################################################################################

$ACTION
#Onerrgo JJJ
#Infbox ACTION - num$([M:AYC1]NUM10)
#If [M:AYC1]NUM10=2 : Dbgaff : Endif
#Onerrgo
#Infbox ACTION
Case ACTION
 When "APRES_CHOI"     
       If GMODHIE and !find(REP,"M","C","D") and REPONSE <> GSTAANU     # Gestion modif hiĂŠrarchie   $001
            REP="M" : REPONSE=0 : GMODHIE =0              #   Si pas dĂŠjĂ  en modif/crĂŠation/dup et si pas bouton sup
            GMESSAGE=mess(195,7900,1)  
       Endif
 When "AVANT_OUVRE"    : Gosub AVANT_OUVRE
 When "ANNULE"         : Gosub ANNULE
 When "CREATION"       : Gosub CREATION
 When "EXEBOUT"        : Gosub EXEBOUT
 When "EXEACT"         : Gosub EXEACT
 When "FERME"          : Gosub FERME
 When "FILTRE"         : Gosub FILTRE
 When "INICRE"         : Gosub INICRE
 When "INIMOD"         : Gosub INIMOD
 When "LIENS"          : Gosub LIENS
 When "MODIF"          : Gosub MODIF
 When "OUVRE"          : Gosub OUVRE
 When "RAZCRE"         : Gosub RAZCRE
 When "STATUT"         : Gosub STATUT
 When "SETBOUT"        : Gosub SETBOUT
 When "VERIF_CRE"      : Gosub VERIF_CRE
 When "VERIF_MOD"      : Gosub VERIF_MOD

# When "STYLE"          : Gosub STYLE            # Voir nota $001
# When "DEGRISE"        : Gosub DEGRISE          # Voir nota $001

 When "AB10_NUM10"    # Appel objet AYL    
    Local Integer SAVNOL : SAVNOL=nolign

 When "BB10_NUM10"
    nolign=SAVNOL 
    # Maj libellĂŠ
    Gosub SETNOL :  WL=NOL
    Call LNDES(LNLIBORI10(WL),LNCHP10(WL),LNCHPNUM10(WL),LNADV10(WL),LNADI10(WL),LNADISHO10(WL),
&            LNTYP10(WL),LNDLK10(WL),LNVAL10(WL),LNFIECOD10(WL),
&            WLNDES10(WL),WLNDESL10(WL),WLNDESS10(WL))
    Affzo 40 : mkstat=4
 When default
Endcase
Return

$AVANT_OUVRE
#---------------------------------------------------------------#
Call AYT_DEBUG From AYTUTIA   # Activation debug java
Gosub INICTLFCY From SUBAYS
Return

$OUVRE
#---------------------------------------------------------------#
Local Char WSTR1 (250), KEYLNK(30)
Local Integer WI, WPAR, WL, WFLG
Local Integer SAVNOL
Gosub DSYFCY From SUBAYS     # Infos site

Global Char    GLANREF(GLONLAN) : GLANREF=GLANGUE    # PF12 sur nÂ° ligne message
Global Integer GMODHIE                               # Flag gestion modif. hierarchie
GMODHIE=0
# Mask pour gestion menu (boutons)
Local Mask AYCMAJLIN[AYC8] 
Local Mask AYCADDLIN[AYC9] 
Default Mask [AYC1]

Return


#---------------------------------------------------------------#
$FERME
Gosub DSYCLRFCY From SUBAYS # Clear affichage site
If clalev([M:AYC8]) : Close Local Mask [AYC8] : Endif 
If clalev([M:AYC9]) : Close Local Mask [AYC9] : Endif
Return

#---------------------------------------------------------------#
$DEGRISE        # Voir nota $001
$STYLE
Setmok [AYC1] With 0
Return


#---------------------------------------------------------------#
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET : # Validation, copie
Endif
If [M:AYC1]GESOPT=3    # Gestion import
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Endif
Return

#---------------------------------------------------------------#
$EXEBOUT
Return

#---------------------------------------------------------------#
$EXEACT
Case BOUT
When "S"
#    Call USG_SUPP([M]FCYCOD, GABREV, [M:AYE0]ENTCOD, WI) From CNSAYUSTD
#    If WI : OK=0 : Endif
Endcase
Return
#---------------------------------------------------------------#

#---------------------------------------------------------------#
$INICRE
$INIMOD
# ClĂŠ browser X3
[F]BRWX3=[F]FCYCOD+"_"+[F]MENCOD 
Return

#---------------------------------------------------------------#
$CREATION
$MODIF

Case [M:AYC1]GESOPT
When 1
    # Lignes du menu cas std
    # Sup. avant recrĂŠation AYTLINES 
    Gosub ANNULE2 : If GOK<>1 : Return : Endif
    #
    For WL=0 To [M:AYC1]NUM10-1
     Raz [F:AYN]
     [F:AYN]FCYCOD    = [M]FCYCOD
     [F:AYN]LINCODTYP = 7
     [F:AYN]LINCOD    = [M]MENCOD
     [F:AYN]LINCODSTD = [M]MENCOD
     [F:AYN]LINTYP    = 60
     [F:AYN]LINNUM    = WL
     [F:AYN]MENCOD        = val(mid$([M:AYC1]LNCOD10(WL),2,12))   
     [F:AYN]MENCODPAR     = val(mid$([M:AYC1]LNPAR10(WL),2,12))   
     [F:AYN]MENLIBORI     = [M:AYC1]LNLIBORI10(WL)
     [F:AYN]MENCHP        = [M:AYC1]LNCHP10(WL)   
     [F:AYN]MENCHPNUM     = [M:AYC1]LNCHPNUM10(WL)
     [F:AYN]MENADV        = [M:AYC1]LNADV10(WL)   
     [F:AYN]MENADI        = [M:AYC1]LNADI10(WL)   
     [F:AYN]MENADISHO     = [M:AYC1]LNADISHO10(WL)
     [F:AYN]MENTYP        = [M:AYC1]LNTYP10(WL)   
     [F:AYN]DLKCOD        = [M:AYC1]LNDLK10(WL)   
     [F:AYN]VALEUR        = [M:AYC1]LNVAL10(WL)   
     [F:AYN]FIECOD        = [M:AYC1]LNFIECOD10(WL)   
     Write [AYN]
     If fstat
      GOK=0 : Call FSTA("AYN") From GLOCK : Break
     Endif
    Next
    If GOK<>1 : Return : Endif
When 2
    # Lignes du menu cas auto
    # Sup. avant recrĂŠation AYTLINES 
    Gosub ANNULE2 : If GOK<>1 : Return : Endif
    #
    For WL=1 To [M:AYC1]NUM10-1
     Raz [F:AYN] : WFLG=0
     If ([M:AYC1]GESORI = 2) 
        WFLG = ([M:AYC1]LNVAL10(WL)<> [M:AYC1]LNADI10(WL) or [M:AYC1]LNDLK10(WL)<>"")
     Else
        WFLG = ([M:AYC1]LNVAL10(WL)<> num$([M:AYC1]LNCHPNUM10(WL)) or [M:AYC1]LNDLK10(WL)<>"")
     Endif
     WFLG+=[M:AYC1]LNFIECOD10(WL)<>""
     If WFLG        # Stockage si chgt
         [F:AYN]FCYCOD    = [M]FCYCOD
         [F:AYN]LINCODTYP = 7
         [F:AYN]LINCOD    = [M]MENCOD
         [F:AYN]LINCODSTD = [M]MENCOD
         [F:AYN]LINTYP    = 60
         [F:AYN]LINNUM    = WL
         [F:AYN]MENCOD        = val(mid$([M:AYC1]LNCOD10(WL),2,12))   
         [F:AYN]MENCODPAR     = val(mid$([M:AYC1]LNPAR10(WL),2,12))   
         [F:AYN]MENLIBORI     = [M:AYC1]LNLIBORI10(WL)
         [F:AYN]MENCHP        = [M:AYC1]LNCHP10(WL)   
         [F:AYN]MENCHPNUM     = [M:AYC1]LNCHPNUM10(WL)
         [F:AYN]MENADV        = [M:AYC1]LNADV10(WL)   
         [F:AYN]MENADI        = [M:AYC1]LNADI10(WL)   
         [F:AYN]MENADISHO     = [M:AYC1]LNADISHO10(WL)
         [F:AYN]MENTYP        = [M:AYC1]LNTYP10(WL)   
         [F:AYN]DLKCOD        = [M:AYC1]LNDLK10(WL)   
         [F:AYN]VALEUR        = [M:AYC1]LNVAL10(WL)
         [F:AYN]FIECOD        = [M:AYC1]LNFIECOD10(WL)   
         Write [AYN]
         If fstat
          GOK=0 : Call FSTA("AYN") From GLOCK : Break
         Endif
     Endif
    Next
    If GOK<>1 : Return : Endif
When 3
    # Mise Ă  jour batch (pas de maj AYN)
Endcase

#  textes AXX
Call MAJTEXTRA([M]INTIT,"AYTMEN","INTIT",[M]FCYCOD,[M]MENCOD) From  ATEXTRA

Return

#---------------------------------------------------------------#
$LIENS
Gosub DSYFCY From SUBAYS     # Infos site
#
GMODHIE=0        # $001
Call GES_ACTGRI(0, [F:AYC]GESOPT , [F:AYC]GESORI, [F:AYC]DEPFLG)  

Call DISPLAY (0, [F:AYC]GESOPT, [F:AYC]GESORI, [F:AYC]GESCHP, 
&                [F:AYC]GESADV, [F:AYC]GESADISHO, [F:AYC]DEPFLG, [F:AYC]DEPNIV)


Return


#---------------------------------------------------------------#
$FILTRE
FILTSUP+=func SUBAYS.FILTFCY
Return

#---------------------------------------------------------------#
$RAZCRE
Gosub DSYFCY From SUBAYS     # Infos site

# 1 er ligne
[M:AYC1]CPTCOD=1
WL=0
[M:AYC1]LNCOD10(WL)      = "C1"
[M:AYC1]LNPAR10(WL)      = ""
[M:AYC1]LNLIBORI10(WL)   = 0
[M:AYC1]LNCHP10(WL)      = 0
[M:AYC1]LNCHPNUM10(WL)   = 0
[M:AYC1]LNADV10(WL)      = 0
[M:AYC1]LNADI10(WL)      = ""
[M:AYC1]LNADISHO10(WL)   = 0
[M:AYC1]LNTYP10(WL)      = 0
[M:AYC1]LNDLK10(WL)      = ""
[M:AYC1]LNVAL10(WL)      = ""
[M:AYC1]LNFIECOD10(WL)   = ""
[M:AYC1]WLNDESL10(WL)    = [M:AYC1]INTIT
[M:AYC1]WLNDESS10(WL)    = [M:AYC1]INTIT
#
[M:AYC1]WLNICO10(WL)      = func SETICO([M:AYC1]LNTYP10(WL))
[M:AYC1]NUM10            =1
Call INIXSL([M:AYC1]XSL1,"ANOMV") From INTRUTILA
Affzo 40
Affzo [M:AYC1]XSL1
Return

#---------------------------------------------------------------#
$ANNULE
Delete [AXX] Where CODFIC="AYTELTBLC" & ZONE = "INTIT"   & IDENT1=[L]SUPP & IDENT2=[L]CODE
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK 
Endif
$ANNULE2
Delete [AYN]AYN0=[M]FCYCOD;7;toupper([M]MENCOD)
If fstat=1 : GOK=-1 : GLOCK="$AYTLINES ("-[M]FCYCOD-"7"-[M]MENCOD+")" : Return : Endif
Return

#---------------------------------------------------------------#
$STATUT
Return

#---------------------------------------------------------------#
$VERIF_CRE
$VERIF_MOD
Return

######################################################################################
## Utilitaires
######################################################################################

# Gestion grisage auto
#---------------------------------------------------------------#
Subprog GES_ACTGRI (AFFZO_FLG, GESOPT, GESORI, DEPFLG)        # Gesopt: auto, manuel, batch    Gesori: Message, table diverse    DepFlg: gestion dĂŠpendance
Value Integer AFFZO_FLG
Value Integer GESOPT
Value Integer GESORI
Value Integer DEPFLG
    Case GESOPT        # Gestion
     When 2               # Auto
        Effzo [AYC1]20 : Grizo [AYC1]20
        Actzo [AYC1]40
        Actzo [AYC1]GESORI 
        Case GESORI    # Origine
         When 2
            Effzo [AYC1]GESCHP : Grizo [AYC1]GESCHP
            Effzo [M:AYC1]WCHPDES : Grizo [M:AYC1]WCHPDES
            Actzo [AYC1]GESADV    : Actzo [AYC1]GESADISHO
            Actzo [M:AYC1]DEPFLG
            If DEPFLG=2
                If [M:AYC1]DEPNIV<2 : [M:AYC1]DEPNIV=2 : Endif
                Actzo [M:AYC1]DEPNIV 
            Else
                Effzo [M:AYC1]DEPNIV : Grizo [M:AYC1]DEPNIV
            Endif
         When 1
            Effzo [AYC1]GESADV : Grizo [AYC1]GESADV
            Effzo [AYC1]GESADISHO : Grizo [AYC1]GESADISHO
            Effzo [M:AYC1]DEPFLG,DEPNIV : Grizo [M:AYC1]DEPFLG,DEPNIV
            Actzo [AYC1]GESCHP
       Endcase
     When 1               # Manu
        Effzo [AYC1]10,20 : Grizo [AYC1]10,20
        Actzo [AYC1]40
     When 3               # Batch 
        Effzo [AYC1]10,40 : Grizo [AYC1]10,40
        Actzo  [AYC1]20
    Endcase
End

# Gestion affichage 
#---------------------------------------------------------------#
Subprog DISPLAY (AFFZO_FLG, GESOPT, GESORI, GESCHP, GESADV, GESADISHO, GESDEPFLG, GESDEPNIV)
Value Integer AFFZO_FLG
Value Integer GESOPT
Value Integer GESORI
Value Integer GESCHP
Value Integer GESADV
Value Integer GESADISHO
Value Integer GESDEPFLG
Value Integer GESDEPNIV

Effzo [M:AYC1]40
Local Integer WL, WLMAX
WLMAX=dim([M:AYC1]LNCOD10,1)

Case GESOPT        # Gestion
When 1               # Manu
    Gosub AFF_STDAYN
When 2               # Auto
    If GESORI=2
        If GESADV=0 : End : Endif
        If GESDEPFLG<>2
            Gosub AFF_GESTAB
        Else
            Gosub AFF_GESTABHI
        Endif
    Else
        Gosub AFF_GESCHP
    Endif
When 3               # Batch
Endcase
If AFFZO_FLG : Affzo 40 : Endif
End

# Affichage cas non automatique
#  Tout est gĂŠrĂŠ dans AYN
# - - - - - - - - - - - - - - - - - - - - - - - 
$AFF_STDAYN
# Lignes du menu
Raz [F:AYN]
WL=0
For [F:AYN]AYN0 Where FCYCOD=[M]FCYCOD and LINCODTYP = 7
&                     and LINCOD = [M]MENCOD and  LINTYP = 60
 [M:AYC1]LNCOD10(WL)      = "C"+num$([F:AYN]MENCOD)
 If WL<>0 : [M:AYC1]LNPAR10(WL)      = "C"+num$([F:AYN]MENCODPAR) : Endif
 [M:AYC1]LNLIBORI10(WL)   = [F:AYN]MENLIBORI
 [M:AYC1]LNCHP10(WL)      = [F:AYN]MENCHP
 [M:AYC1]LNCHPNUM10(WL)   = [F:AYN]MENCHPNUM
 [M:AYC1]LNADV10(WL)      = [F:AYN]MENADV
 [M:AYC1]LNADI10(WL)      = [F:AYN]MENADI
 [M:AYC1]LNADISHO10(WL)   = [F:AYN]MENADISHO
 [M:AYC1]LNDLK10(WL)      = [F:AYN]DLKCOD
 [M:AYC1]LNVAL10(WL)      = [F:AYN]VALEUR
 [M:AYC1]LNFIECOD10(WL)   = [F:AYN]FIECOD

 [M:AYC1]LNTYP10(WL)      = func SETTYP(WL, [M:AYC1]LNDLK10(WL), [M:AYC1]LNFIECOD10(WL))
 [M:AYC1]WLNICO10(WL)     = func SETICO([M:AYC1]LNTYP10(WL))
 If WL=0
    [M:AYC1]WLNDESL10(WL)     = [M:AYC1]INTIT
    [M:AYC1]WLNDESS10(WL)     = [M:AYC1]INTIT
 Else
     Call LNDES(LNLIBORI10(WL),LNCHP10(WL),LNCHPNUM10(WL),LNADV10(WL),LNADI10(WL),LNADISHO10(WL),
&            LNTYP10(WL),LNDLK10(WL),LNVAL10(WL),LNFIECOD10(WL),
&            WLNDES10(WL),WLNDESL10(WL),WLNDESS10(WL))
 Endif
 WL+=1
 If WL >= WLMAX : Infbox mess(197,7900,1) - num$(WLMAX) : Break : Endif
Next
[M:AYC1]NUM10=WL
Return

# Affichage cas chapitre (voir trt APLSTD Ouvre)
#  On suppose que la numĂŠrotation des messages est fixe (pas d'insertion)
# - - - - - - - - - - - - - - - - - - - - - - - 
$AFF_GESCHP
If GESCHP=0 : Return : Endif

[M:AYC1]WCHPDES = func SUBAYCACT.CHAP_DES(GESCHP)

Gosub AFF_1ER

# Ordre imposĂŠ APLSTD et AYN sur nÂ°ligne sinon pb...
Link [AST]  With [AYN]AYN0 = [M:AYC1]FCYCOD;7;[M:AYC1]MENCOD;60;[F:AST]LANNUM 
& As [AST_] 

For [AST_] Where LAN=GLANGUE and LANCHP=GESCHP and LANNUM<>0
    [M:AYC1]LNCOD10(WL)      = "C"+num$(WL+1)
    [M:AYC1]LNPAR10(WL)      = "C1" 
    [M:AYC1]LNLIBORI10(WL)   = GESORI
    [M:AYC1]LNCHP10(WL)      = GESCHP
    [M:AYC1]LNCHPNUM10(WL)   = [F:AST]LANNUM 
    [M:AYC1]LNADV10(WL)      = 0
    [M:AYC1]LNADI10(WL)      = ""
    [M:AYC1]LNADISHO10(WL)   = 1
    [M:AYC1]LNDLK10(WL)      = ""
    [M:AYC1]LNVAL10(WL)      = num$([F:AST]LANNUM)
    [M:AYC1]LNFIECOD10(WL)   = ""
    If ([F:AYN]LINTYP)    # AYN trouvĂŠ
        [M:AYC1]LNDLK10(WL)      = [F:AYN]DLKCOD
        [M:AYC1]LNVAL10(WL)      = [F:AYN]VALEUR
        [M:AYC1]LNFIECOD10(WL)   = [F:AYN]FIECOD
    Endif
    [M:AYC1]LNTYP10(WL)      = func SETTYP(WL, [M:AYC1]LNDLK10(WL), [M:AYC1]LNFIECOD10(WL))
    [M:AYC1]WLNICO10(WL)     = func SETICO([M:AYC1]LNTYP10(WL))
    Call LNDES(LNLIBORI10(WL),LNCHP10(WL),LNCHPNUM10(WL),LNADV10(WL),LNADI10(WL),[M:AYC1]GESADISHO,
&                LNTYP10(WL),LNDLK10(WL),LNVAL10(WL),LNFIECOD10(WL),
&                WLNDES10(WL),WLNDESL10(WL),WLNDESS10(WL))

    WL+=1
    If WL >= WLMAX : Infbox mess(197,7900,1) - num$(WLMAX) : Break : Endif
Next
[M:AYC1]NUM10=WL
[M:AYC1]CPTCOD=WL
Return

# Affichage cas table diverse
# - - - - - - - - - - - - - - - - - - - - - - - 
$AFF_GESTAB
Gosub AFF_1ER
Filter [AYN] Where FCYCOD=[M:AYC1]FCYCOD and LINCODTYP=7 and LINCOD=[M:AYC1]MENCOD and LINTYP=60
For [ADI]CODE Where NUMTAB=GESADV
    [M:AYC1]LNCOD10(WL)      = "C"+num$(WL+1)
    [M:AYC1]LNPAR10(WL)      = "C1" 
    [M:AYC1]LNLIBORI10(WL)   = GESORI
    [M:AYC1]LNCHP10(WL)      = 0
    [M:AYC1]LNCHPNUM10(WL)   = 0
    [M:AYC1]LNADV10(WL)      = GESADV
    [M:AYC1]LNADI10(WL)      = [F:ADI]CODE
    [M:AYC1]LNADISHO10(WL)   = [L]GESADISHO
    [M:AYC1]LNDLK10(WL)      = ""
    [M:AYC1]LNVAL10(WL)      = [F:ADI]CODE
    [M:AYC1]LNFIECOD10(WL)   = ""
    For [AYN] Where MENADI=[F:ADI]CODE                    # Ordre non certain
        [M:AYC1]LNDLK10(WL)      = [F:AYN]DLKCOD
        If [F:AYN]DLKCOD<>"" : [M:AYC1]LNTYP10(WL)      = 2 : Endif
        [M:AYC1]LNVAL10(WL)      = [F:AYN]VALEUR
        [M:AYC1]LNFIECOD10(WL)   = [F:AYN]FIECOD
        Break
    Next
    [M:AYC1]LNTYP10(WL)      = func SETTYP(WL, [M:AYC1]LNDLK10(WL), [M:AYC1]LNFIECOD10(WL))
    [M:AYC1]WLNICO10(WL)     = func SETICO([M:AYC1]LNTYP10(WL))
    Call LNDES(LNLIBORI10(WL),LNCHP10(WL),LNCHPNUM10(WL),LNADV10(WL),LNADI10(WL),LNADISHO10(WL),
&                LNTYP10(WL),LNDLK10(WL),LNVAL10(WL),LNFIECOD10(WL),
&                WLNDES10(WL),WLNDESL10(WL),WLNDESS10(WL))

    WL+=1
    If WL >= WLMAX : Infbox mess(197,7900,1) - num$(WLMAX) : Break : Endif
Next
[M:AYC1]NUM10=WL
[M:AYC1]CPTCOD=WL
Filter [AYN] 
Return

# Affichage cas table diverse hiĂŠrarchique (E46684)
# - - - - - - - - - - - - - - - - - - - - - - - 
$AFF_GESTABHI
Gosub AFF_1ER : [M:AYC1]NUM10=WL

If !clalev([F:ADV])   : Local File ATABTAB  [ADV]  : Endif

Filter [AYN] Where FCYCOD=[M:AYC1]FCYCOD and LINCODTYP=7 and LINCOD=[M:AYC1]MENCOD and LINTYP=60
Call AFF_TABLEV(WLMAX, "C1", "", GESADV, GESADISHO, GESDEPNIV, 1)

[M:AYC1]CPTCOD=[M:AYC1]NUM10
Filter [AYN] 
Close Local File [ADV]
Return


Subprog AFF_TABLEV(LMAX, FATHKEY, FATHDEPADI, ADVCOD, GESADISHO, NIVMAX, NIVCUR)
Value Integer LMAX           # Nb ligne maxi ecran
Value Char    FATHKEY        # PĂ¨re - ClĂŠ interne
Value Char    FATHDEPADI     # PĂ¨re - Code ADI ( recherche dĂŠpendance)
Value Integer ADVCOD         # Code table diverse
Value Integer GESADISHO      # IntitulĂŠ court
Value Integer NIVMAX         # Niveau maxi 
Value Integer NIVCUR         # Niveau demandĂŠ

Local Char    WCODDIVCUR     # Code courant de la ligne de la table diverse
Local Integer WLCUR          # NumĂ¨ro de ligne
Local Integer WFLGDEP        # Traiter les dĂŠpendances
Local Char    WEVLDEP(30)    # Filtre dĂŠpendance
Local Integer WI

If NIVCUR>NIVMAX : End : Endif

Local Integer ADVCHILDMAX                    # Nb maxi de filles gĂŠrĂŠes (cas rare...)
ADVCHILDMAX=10
Local Integer ADVCHILDNB                     # Nb de filles gĂŠrĂŠes 
Local Integer ADVCHILD(1..ADVCHILDMAX)       # Code Tables filles     

# Recherche tables filles 
For [ADV]CODE Where DEPNUM=ADVCOD
    If !find(NUMTAB, ADVCHILD)
        ADVCHILDNB +=1
        ADVCHILD(ADVCHILDNB)=[ADV]NUMTAB
    Endif
Next 

# Filtre dĂŠpenance
WEVLDEP="1=1" : If FATHDEPADI<>"" : WEVLDEP='DEPCOD = "' +FATHDEPADI+ '"' : Endif

# boucle
$TABLEV_BCL
WLCUR=[M:AYC1]NUM10
For [ADI]CODE Where NUMTAB=ADVCOD and CODE > WCODDIVCUR and evalue(WEVLDEP)
     WCODDIVCUR              = [F:ADI]CODE
    [M:AYC1]LNCOD10(WLCUR)      = "C"+num$(WLCUR+1)
    [M:AYC1]LNPAR10(WLCUR)      = FATHKEY
    [M:AYC1]LNLIBORI10(WLCUR)   = GESORI
    [M:AYC1]LNCHP10(WLCUR)      = 0
    [M:AYC1]LNCHPNUM10(WLCUR)   = 0
    [M:AYC1]LNADV10(WLCUR)      = ADVCOD
    [M:AYC1]LNADI10(WLCUR)      = [F:ADI]CODE
    [M:AYC1]LNADISHO10(WLCUR)   = [L]GESADISHO
    [M:AYC1]LNDLK10(WLCUR)      = ""
    [M:AYC1]LNVAL10(WLCUR)      = [F:ADI]CODE
    [M:AYC1]LNFIECOD10(WLCUR)   = ""
    For [AYN] Where MENADV=ADVCOD and MENADI=[F:ADI]CODE
        [M:AYC1]LNDLK10(WLCUR)      = [F:AYN]DLKCOD
        If [F:AYN]DLKCOD<>"" : [M:AYC1]LNTYP10(WLCUR)      = 2 : Endif
        [M:AYC1]LNVAL10(WLCUR)      = [F:AYN]VALEUR
        [M:AYC1]LNFIECOD10(WLCUR)   = [F:AYN]FIECOD
        Break
    Next
    [M:AYC1]LNTYP10(WLCUR)      = func SETTYP(WLCUR, [M:AYC1]LNDLK10(WLCUR), [M:AYC1]LNFIECOD10(WLCUR))
    [M:AYC1]WLNICO10(WLCUR)     = func SETICO([M:AYC1]LNTYP10(WLCUR))
    Call LNDES(LNLIBORI10(WLCUR),LNCHP10(WLCUR),LNCHPNUM10(WLCUR),LNADV10(WLCUR),LNADI10(WLCUR),LNADISHO10(WLCUR),
&                LNTYP10(WLCUR),LNDLK10(WLCUR),LNVAL10(WLCUR),LNFIECOD10(WLCUR),
&                WLNDES10(WLCUR),WLNDESL10(WLCUR),WLNDESS10(WLCUR))

    WLCUR+=1
    If WLCUR > LMAX : Infbox mess(197,7900,1) - num$(LMAX) : Break : Endif

    Raz WFLGDEP
    If ADVCHILDNB : WFLGDEP=1 : Break : Endif    # Il faut traiter les tables liĂŠes
Next
[M:AYC1]NUM10=WLCUR
If [M:AYC1]NUM10 >= LMAX : Goto TABLEV_END : Endif

# DĂŠpendances
If WFLGDEP
    Raz WFLGDEP
    For WL=1 To ADVCHILDNB 
        Call AFF_TABLEV(LMAX, [M:AYC1]LNCOD10(WLCUR-1), [M:AYC1]LNADI10(WLCUR-1), ADVCHILD(WL), GESADISHO, NIVMAX, NIVCUR+1)
        If [M:AYC1]NUM10 >= LMAX : Break : Endif
    Next
    If [M:AYC1]NUM10 >= LMAX : Goto TABLEV_END : Endif
    Goto TABLEV_BCL
Endif

$TABLEV_END
End

# Affichage 1er ligne
# - - - - - - - - - - - - - - - - - - - - - - - 
$AFF_1ER
WL=0
[M:AYC1]LNCOD10(WL)      = "C1"
[M:AYC1]LNPAR10(WL)      = ""
[M:AYC1]LNLIBORI10(WL)   = 0
[M:AYC1]LNCHP10(WL)      = 0
[M:AYC1]LNCHPNUM10(WL)   = 0
[M:AYC1]LNADV10(WL)      = 0
[M:AYC1]LNADI10(WL)      = ""
[M:AYC1]LNADISHO10(WL)   = 0
[M:AYC1]LNTYP10(WL)      = 0
[M:AYC1]LNDLK10(WL)      = ""
[M:AYC1]LNVAL10(WL)      = ""
[M:AYC1]LNFIECOD10(WL)   = ""
[M:AYC1]WLNDESL10(WL)     = [M:AYC1]INTIT
[M:AYC1]WLNDESS10(WL)     = [M:AYC1]INTIT
#
[M:AYC1]WLNICO10(WL)      = func SETICO([M:AYC1]LNTYP10(WL))
WL+=1
Return

# Type en fct des donnĂŠes
#---------------------------------------------------------------#
Funprog SETTYP(LNNUM, LNDLK, LNFIE)
Value Integer     LNNUM
Value Char        LNDLK
Value Char        LNFIE
#  Retour  TYP    =  1*(!IsEntete)+2*(IsDlk)+4*(IsFie)    # Type portĂŠ sur la ligne
Local Integer WRET
WRET = 1*(LNNUM<>0)
WRET +=2*(LNDLK<>"")
WRET +=4*(LNFIE<>"")
End WRET

# Retourne les infos en fonction du type
#---------------------------------------------------------------#
Subprog TYPGET(LNTYP, IS_TOP, IS_DLK, IS_FIE)
Value Integer     LNTYP            # Type portĂŠ sur la ligne
Variable Integer     IS_TOP
Variable Integer     IS_DLK
Variable Integer     IS_FIE
IS_FIE=(LNTYP/4>=1) : WMOD=mod(LNTYP,4)
IS_DLK=(WMOD/2>=1)  : WMOD=mod(WMOD,2)
IS_TOP=(WMOD=0)
End

# Icones en fonction du type
#---------------------------------------------------------------#
Funprog SETICO(LNTYP)
Value Integer LNTYP    
Local Char WICO(50)
Local Integer IS_TOP,IS_DLK, IS_FIE
Call TYPGET(LNTYP, IS_TOP,IS_DLK, IS_FIE)
If IS_TOP
    WICO="asp.gif"
Else
    If IS_DLK or IS_FIE
        WICO="ico.gif"
    Else
        WICO="Folder.gif"
    Endif
Endif
End WICO

# DĂŠsignations 
# Rq: UtilisĂŠe aussi par subaycact
#---------------------------------------------------------------#
Subprog LNDES(LNLIBORI,LNCHP,LNCHPNUM,LNADV,LNADI,LNADISHO,LNTYP,LNDLK,LNVAL,LNFIE,LNDES,LNDESL,LNDESS)
Value Integer LNLIBORI
Value Integer LNCHP
Value Integer LNCHPNUM
Value Integer LNADV
Value Char    LNADI
Value Integer LNADISHO
Value Integer LNTYP
Value Char    LNDLK
Value Char    LNVAL
Value Char    LNFIE
Variable Char LNDES            # LibellĂŠ seul
Variable Char LNDESL           # LibellĂŠ long pour la nomenclature
Variable Char LNDESS           #  "   "  court   "    "    "

Case LNLIBORI
When 1    # Message
    LNDES=mess(LNCHPNUM, LNCHP, 1)
    LNDESS = mess(78,100,1)-num$(LNCHP)-"/"-num$(LNCHPNUM)
When 2    # Table div.
  LNDESS = mess(2,26,1)-num$(LNADV)-"/"-num$(LNADI)
  If LNADISHO=2
    Call LECTEXTRA(LNDES,"ATABDIV","SHODES",num$(LNADV),LNADI) From ATEXTRA
  Else 
    Call LECTEXTRA(LNDES,"ATABDIV","LNGDES",num$(LNADV),LNADI) From ATEXTRA
  Endif
Endcase

#
Local Integer IS_TOP,IS_DLK, IS_FIE
Call TYPGET(LNTYP, IS_TOP,IS_DLK, IS_FIE)
If IS_DLK and IS_FIE
    LNDESL = LNDES -"(" -LNVAL -"-" -mess(10,7910,1) +":" -LNDLK -"-" -mess(5,7910,1) +":" -LNFIE -")"
Elsif IS_DLK
    LNDESL = LNDES -"(" -LNVAL -"-" -mess(10,7910,1) +":" -LNDLK -")"
Elsif IS_FIE
    LNDESL = LNDES -"(" -LNVAL -"-" -mess(5,7910,1)  +":" -LNFIE -")"
Else
    LNDESL = LNDES -"(" -LNVAL -")"
Endif
End

# Calcul des niveaux - les lignes sont supposĂŠes classĂŠes
#---------------------------------------------------------------#
Subprog LEVELS
Local Integer WNIV
For WNIV=0 To [M:AYC1]NUM10-1
    If WNIV=0 
        [M:AYC1]WLNLVL10(WNIV)=1
    Else
        WPAR = find([M:AYC1]LNPAR10(WNIV),[M:AYC1]LNCOD10(0..WNIV-1))
        If WPAR
            [M:AYC1]WLNLVL10(WNIV)=[M:AYC1]WLNLVL10(WPAR-1)+1
        Else
            Infbox ("Error: Father not found for: " -[M:AYC1]LNPAR10(WNIV)-"Line:"-num$(WNIV))
            Break
        Endif
    Endif
Next
End 

# Flag de la hiĂŠrarchie d'une ligne
#---------------------------------------------------------------#
Funprog FLGHIE(NOL)
Value Integer NOL
Raz [M:AYC1]WLNFLGHIE
Local Integer WI, WNB
Local Integer LVLNOL : LVLNOL=[M:AYC1]WLNLVL10(NOL)
For WI=NOL To [M:AYC1]NUM10-1
    If WI<>NOL and [M:AYC1]WLNLVL10(WI) <= LVLNOL : Break : Endif
    [M:AYC1]WLNFLGHIE(WI)=1 : WNB+=1
Next
#Infbox "Nbsel " + num$(WNB)
End WNB

#  Trt maj nomenclature XSL (origine SUBAPN)
#---------------------------------------------------------------#
Subprog MAJHIER(CODACT,NLISTR,NLIEND,KEYDROP,MESSAGE,CODRET)
Value    Char    CODACT        # M: Move    E: Double-clik -> maj dans notre cas
Value    Integer NLISTR        # Ligne de dĂŠpart          (commence comme nolign)
Value    Integer NLIEND        # Ligne d'arrivĂŠe au drop  (commence comme nolign)
Value    Integer KEYDROP       # Toucle clavier ĂŠventuelle associĂŠe au drop (0: aucune, 1: Alt, -1: Shift)
Variable Char    MESSAGE
Variable Integer CODRET
Local Integer SAVNOL

If find([M:AYC1]GESOPT,2,3)
    Infbox mess(196,7900,1)
    End
Endif

#Infbox "MAJHIER" -num$("CODACT")-CODACT -"NLISTR"-num$(NLISTR) 
#&    -"NLIEND"-num$(NLIEND) -"KEYDROP"-num$(KEYDROP) -"MESSAGE" -MESSAGE -"CODRET" -num$(CODRET)


Case CODACT
When "E"
    SAVNOL=nolign
    nolign=NLISTR
    Call B3_NUM10 From W1AYC1    # emulation mise Ă  jour
    nolign=SAVNOL
    mkstat=4 : GREP="M"     # $001 NE permettent pas d'activer le bouton enregistrer# $001    
When "M"
    Gosub MOVHIE
    Affzo 40
Endcase
End

# DĂŠplacement hiĂŠrarchie
# - - - - - -
$MOVHIE
#
# Si Alt n'est pas active  : la hiĂŠrarchie est placĂŠe sous la ligne d'arrivĂŠe en dernier fils
# Si Alt est active        : la hiĂŠrarchie est placĂŠe au niveau de la ligne d'arrivĂŠe en frĂ¨re au-dessous
# Si Shfit est active      : la hiĂŠrarchie est placĂŠe au niveau de la ligne d'arrivĂŠe en frĂ¨re au-dessus
# 
Local Integer WI
Local Integer WNOLCURORG, WNOLCURDES    # Ligne encours origine et destination (genre NOL)
Local Integer WDESNB                    # Nb de lignes menu destination
Local Char    WDESCOD, WDESPAR          # Destination code et parent
Local Integer WNBMOVE                   # Nb de lignes Ă  dĂŠplacer
Local Integer INSBEF                    # Flag insertion avant
Local Integer FLGALT                    # Touche Alt activĂŠe
FLGALT=(KEYDROP = 1)      
Local Integer FLGSHF                    # Touche Shift activĂŠe
FLGSHF=(KEYDROP = -1)      

#Local integer DBG : DBG=2
#If DBG=2 : Dbgaff : Endif

# Protections
If !find(KEYDROP, 0, -1, 1) : End : Endif

If NLISTR=NLIEND : End : Endif
GMODHIE=1

# Calcul hiĂŠrarchie
Call LEVELS
# Elts participant Ă  la demande
WDESNB  = func FLGHIE(NLIEND-1)
WDESCOD = LNCOD10(NLIEND-1)
WDESPAR = LNPAR10(NLIEND-1)
WNBMOVE = func FLGHIE(NLISTR-1)

# Place de l'insertion
If FLGSHF                              # Shift                
    WINSBEF = (NLIEND < NLISTR)
Elsif FLGALT                           # Alt                
    # If NLISTR+1=NLIEND and WLNLVL10(NLISTR)+WNBMOVE=WLNLVL10(NLIEND) : End : Endif  # dĂŠja en place
    WINSBEF = (NLIEND+WDESNB <= NLISTR)
Else                                   # Std
    #If NLISTR+1=NLIEND and WLNLVL10(NLISTR)=WLNLVL10(NLIEND)+WNBMOVE : End : Endif  # dĂŠja en place
    # Flag sens
    WINSBEF = (NLIEND+WDESNB <= NLISTR)
Endif

# Calcul des NOL du dĂŠplacement
WI=0
If WINSBEF
    WNOLCURORG=(NLISTR-1)+1
Else
    WNOLCURORG=NLISTR-1
Endif
If FLGSHF                              # Shift                
    WNOLCURDES=(NLIEND-1)
Elsif FLGALT                           # Alt                
    WNOLCURDES=(NLIEND-1)+WDESNB
Else                                   # Std
    WNOLCURDES=(NLIEND-1)+WDESNB
Endif

# Move un Ă  un pour ĂŠviter les pbs de taille tableau
While WI< WNBMOVE   
    #Infbox "WNOLCURORG" -num$(WNOLCURORG) - "WNOLCURDES" -num$(WNOLCURDES) -num$([M]NUM10)

    Insa WNOLCURDES,1,[M]NUM10 [M]NUM10
    #If DBG=2 : Affzo 40 : Endif #$$$
    If WI=0        # pĂ¨re sur noeud dĂŠplacĂŠ
        If FLGSHF                              # Shift                
            LNPAR10(WNOLCURDES)      = WDESPAR     
        Elsif FLGALT                           # Alt                
            LNPAR10(WNOLCURDES)      = WDESPAR     
        Else                                   # Std
            LNPAR10(WNOLCURDES)      = WDESCOD         
        Endif
    Else
            LNPAR10(WNOLCURDES)      = LNPAR10(WNOLCURORG)        
    Endif

    LNCOD10(WNOLCURDES)      = LNCOD10(WNOLCURORG)
    LNLIBORI10(WNOLCURDES)   = LNLIBORI10(WNOLCURORG)
    LNCHP10(WNOLCURDES)      = LNCHP10(WNOLCURORG)   
    LNCHPNUM10(WNOLCURDES)   = LNCHPNUM10(WNOLCURORG)
    LNADV10(WNOLCURDES)      = LNADV10(WNOLCURORG)   
    LNADI10(WNOLCURDES)      = LNADI10(WNOLCURORG)   
    LNADISHO10(WNOLCURDES)   = LNADISHO10(WNOLCURORG)
    LNDLK10(WNOLCURDES)      = LNDLK10(WNOLCURORG)   
    LNVAL10(WNOLCURDES)      = LNVAL10(WNOLCURORG)   
    LNFIECOD10(WNOLCURDES)   = LNFIECOD10(WNOLCURORG)
    LNTYP10(WNOLCURDES)      = LNTYP10(WNOLCURORG)   
    WLNICO10(WNOLCURDES)     = WLNICO10(WNOLCURORG)  
    WLNDES10(WNOLCURDES)     = WLNDES10(WNOLCURORG)  
    WLNDESL10(WNOLCURDES)    = WLNDESL10(WNOLCURORG) 
    WLNDESS10(WNOLCURDES)    = WLNDESS10(WNOLCURORG)  
    #If DBG=2 : Affzo 40 : Endif #$$$
    Dela WNOLCURORG,1,[M]NUM10 [M]NUM10
    #If DBG=2 : Affzo 40 : Endif #$$$
    If WINSBEF
        WNOLCURDES = WNOLCURDES + 1
        WNOLCURORG = WNOLCURORG + 1 
    Endif
    WI+=1
Wend

Return

######################################################################################
## Gestion Ecran AYC1
######################################################################################
$SETNOL
Local Integer NOL
NOL = nolign-1
Return

Subprog C_GESCHP(VALEUR)
Variable Decimal VALEUR
Local File APLSTD [AST]
Local Integer OK
For [AST]CLE Where LANCHP = VALEUR
 OK =1
 Break
Next
If !OK
 GMESSAGE = mess(208,115,1) : # Chapitre INEXISTANT
 mkstat = 2 : End
Endif 
End

Subprog C_GESADV(VALEUR)
Variable Decimal VALEUR
End


# Modif lib menu
# - - - - - - - - - - - - - - - - - - - - -
Subprog AM_INTIT(VALEUR)
Variable Char    VALEUR()
[M:AYC1]WLNDESL10(0)     = VALEUR
[M:AYC1]WLNDESS10(0)     = VALEUR
Affzo 40
End

Subprog AP_INTIT(VALEUR)  # Voir nota $001
Variable Char    VALEUR()
#  mkstat=4  
End

# Gestion boutons actifs
# - - - - - - - - - - - - - - - - - - - - -
Subprog IB_NUM10
# Bout    1    Ajout 1 ligne
#         2    Ajout n lignes 
#         3    Maj 1 ligne
#         4    Supprimer
#         10   Acces fiche lien dynamique
#
Gosub SETNOL
#Raz GBOUT2 # tempo

Case [M:AYC1]GESOPT
 When 2        # Auto
    Raz GBOUT1,GBOUT2,GBOUT4
Endcase

Case [M:AYC1]LNTYP10(NOL)
When 0    # Menu
    Raz GBOUT10,GBOUT3,GBOUT4
When 1    # Dossier
    Raz GBOUT10
When 2    # Dlk
Endcase

End

# Ajout 1 ligne ( retour ĂŠcran AYCMAJLIN AYC8 )
# la hiĂŠrarchie est placĂŠe sous la ligne d'arrivĂŠe en dernier fils
# - - - - - - - - - - - - - - - - - - - - -
Subprog B1_NUM10    
If [M:AYC8]LNLIBORI_8=0 : End : Endif        # Pas d'infos
Gosub SETNOL
Local Integer WNBHIE, WL,  WLMAX
WLMAX=dim([M:AYC1]LNCOD10,1)

If  [M]NUM10=WLMAX : GMESSAGE=mess(198,7900,1)-num$(WLMAX): GERR=2 : End : Endif

# Calcul hiĂŠrarchie 
Call LEVELS
# Elts participant Ă  la demande
WNBHIE = func FLGHIE(NOL)
WL=NOL+WNBHIE 

# Calcul Identifiant ligne
[M:AYC1]CPTCOD+=1

#
Insa WL,1,[M]NUM10 [M]NUM10
[M]NUM10+=1
[M:AYC1]LNCOD10(WL)      = "C"+num$([M:AYC1]CPTCOD)
[M:AYC1]LNPAR10(WL)      = [M:AYC1]LNCOD10(NOL)        # pĂ¨re

Goto MAJ_AYC1
End

# Ajout n lignes ( retour ĂŠcran AYCADDLIN AYC9 )
# la hiĂŠrarchie est placĂŠe sous la ligne d'arrivĂŠe en dernier fils
# - - - - - - - - - - - - - - - - - - - - -
Subprog B2_NUM10    
If [M:AYC9]NUM_9=0 : End : Endif        # Pas de ligne
Gosub SETNOL
Local Integer WNBHIE
Local Integer  WL, WL_AYC9, WLMAX

# Calcul hiĂŠrarchie 
Call LEVELS
# Elts participant Ă  la demande
WNBHIE = func FLGHIE(NOL)
#
WLMAX=dim([M:AYC1]LNCOD10,1)
WL=NOL+WNBHIE 

# Insertion Ă  suivre
For WL_AYC9=0 To [M:AYC9]NUM_9-1
    #
    If  [M]NUM10=WLMAX : GMESSAGE=mess(198,7900,1)-num$(WLMAX): GERR=2 : Break : Endif
    # Calcul Identifiant ligne
    [M:AYC1]CPTCOD+=1
    #
    Insa WL,1,[M]NUM10 [M]NUM10
    [M]NUM10+=1
    [M:AYC1]LNCOD10(WL)      = "C"+num$([M:AYC1]CPTCOD)
    [M:AYC1]LNPAR10(WL)      = [M:AYC1]LNCOD10(NOL)        # pĂ¨re
    [M:AYC1]LNLIBORI10(WL)   = [M:AYC9]LNLIBORI_9(WL_AYC9)
    [M:AYC1]LNCHP10(WL)      = [M:AYC9]LNCHP_9(WL_AYC9)
    [M:AYC1]LNCHPNUM10(WL)   = [M:AYC9]LNCHPNUM_9(WL_AYC9)
    [M:AYC1]LNADV10(WL)      = [M:AYC9]LNADV_9(WL_AYC9)
    [M:AYC1]LNADI10(WL)      = [M:AYC9]LNADI_9(WL_AYC9)
    [M:AYC1]LNADISHO10(WL)   = [M:AYC9]LNADISHO_9(WL_AYC9)
    [M:AYC1]LNDLK10(WL)      = [M:AYC9]LNDLK_9(WL_AYC9)
    [M:AYC1]LNVAL10(WL)      = [M:AYC9]LNVAL_9(WL_AYC9)
    [M:AYC1]LNFIECOD10(WL)   = [M:AYC9]LNFIECOD_9(WL_AYC9)
    #
    [M:AYC1]LNTYP10(WL)      = func SETTYP(WL, [M:AYC1]LNDLK10(WL), [M:AYC1]LNFIECOD10(WL))
    [M:AYC1]WLNICO10(WL)      = func SETICO([M:AYC1]LNTYP10(WL))
    Call LNDES(LNLIBORI10(WL),LNCHP10(WL),LNCHPNUM10(WL),LNADV10(WL),LNADI10(WL),LNADISHO10(WL),
&            LNTYP10(WL),LNDLK10(WL),LNVAL10(WL),LNFIECOD10(WL),
&            WLNDES10(WL),WLNDESL10(WL),WLNDESS10(WL))
    #
    WL+=1
Next

Affzo 40
mkstat=4

End

# Modification une ligne
# - - - - - - - - - - - - - - - - - - - - -
Subprog B3_NUM10    
If [M:AYC8]LNLIBORI_8=0 : End : Endif        # Pas d'infos
Gosub SETNOL

Local Integer WL
WL=NOL

# Maj chps (partie commune)
$MAJ_AYC1
[M:AYC1]LNLIBORI10(WL)   = [M:AYC8]LNLIBORI_8
[M:AYC1]LNCHP10(WL)      = [M:AYC8]LNCHP_8
[M:AYC1]LNCHPNUM10(WL)   = [M:AYC8]LNCHPNUM_8
[M:AYC1]LNADV10(WL)      = [M:AYC8]LNADV_8
[M:AYC1]LNADI10(WL)      = [M:AYC8]LNADI_8
[M:AYC1]LNADISHO10(WL)   = [M:AYC8]LNADISHO_8
[M:AYC1]LNDLK10(WL)      = [M:AYC8]LNDLK_8
[M:AYC1]LNVAL10(WL)      = [M:AYC8]LNVAL_8
[M:AYC1]LNFIECOD10(WL)   = [M:AYC8]LNFIECOD_8
#
[M:AYC1]LNTYP10(WL)      = func SETTYP(WL, [M:AYC1]LNDLK10(WL), [M:AYC1]LNFIECOD10(WL))
[M:AYC1]WLNICO10(WL)     = func SETICO([M:AYC1]LNTYP10(WL))
Call LNDES(LNLIBORI10(WL),LNCHP10(WL),LNCHPNUM10(WL),LNADV10(WL),LNADI10(WL),LNADISHO10(WL),
&            LNTYP10(WL),LNDLK10(WL),LNVAL10(WL),LNFIECOD10(WL),
&            WLNDES10(WL),WLNDESL10(WL),WLNDESS10(WL))

Affzo 40
##  zonsui = "NUM10(5)" #+num$(WL)+")"  Ne marche pas si pas de chp en saisie et provoque une entrĂŠe dans le champs sinon
#zonsui = "LIN10(5)"
mkstat=4
End

# Suppression
# - - - - - - - - - - - - - - - - - - - - -
Subprog B4_NUM10     
Gosub SETNOL
Local Integer WI, WNB

# Calcul hiĂŠrarchie
Call LEVELS
# Elts participant Ă  la demande
WNB = func FLGHIE(NOL)

# Suppression
Dela NOL,WNB,[M]NUM10-1 [M]NUM10
[M]NUM10 -= WNB

Affzo 40
mkstat=4
End

Subprog AM_GESOPT(VALEUR)
Variable Integer VALEUR
Call GES_ACTGRI (1, VALEUR, [M:AYC1]GESORI, [M:AYC1]DEPFLG )
If VALEUR=2
    Effzo [M:AYC1]40
Endif
End

Subprog AM_GESORI(VALEUR)
Variable Integer VALEUR
Call GES_ACTGRI (1, [M:AYC1]GESOPT, VALEUR, [M:AYC1]DEPFLG)
Effzo [M:AYC1]40
End

Subprog AM_GESCHP(VALEUR)
Variable Decimal VALEUR
Call DISPLAY (1, [M:AYC1]GESOPT, [M:AYC1]GESORI, VALEUR, 0, 0, 0, 0)
End

Subprog AM_GESADV(VALEUR)
Variable Decimal VALEUR
Call DISPLAY (1,[M:AYC1]GESOPT, [M:AYC1]GESORI, 0, VALEUR, [M:AYC1]GESADISHO, [M:AYC1]DEPFLG, [M:AYC1]DEPNIV)
End

Subprog AM_GESADISHO(VALEUR)
Variable Integer VALEUR
Call DISPLAY (1,[M:AYC1]GESOPT, [M:AYC1]GESORI, 0, [M:AYC1]GESADV, VALEUR, [M:AYC1]DEPFLG, [M:AYC1]DEPNIV)
End

Subprog AM_DEPFLG(VALEUR)
Variable Integer VALEUR
Call GES_ACTGRI (1, [M:AYC1]GESOPT, [M:AYC1]GESORI, VALEUR)
Call DISPLAY (1,[M:AYC1]GESOPT, [M:AYC1]GESORI, 0, [M:AYC1]GESADV, [M:AYC1]GESADISHO, VALEUR, [M:AYC1]DEPNIV)
End

Subprog AM_DEPNIV(VALEUR)
Variable Decimal VALEUR
Call DISPLAY (1,[M:AYC1]GESOPT, [M:AYC1]GESORI, 0, [M:AYC1]GESADV, [M:AYC1]GESADISHO, [M:AYC1]DEPFLG, VALEUR)
End

Subprog AS_RESRAC(VALEUR)
Variable Integer VALEUR
GMENLOC(1)=1
End

Subprog C_DEPNIV(VALEUR)
Variable Decimal VALEUR
If VALEUR < 2 or VALEUR > 10
    mkstat=2 : GMESSAGE=mess(210,7900,1)
Endif
End


Subprog C_RESSUBFIC(VALEUR)
Variable Char    VALEUR()
Local Char RACINE(200),FILEPATH(250)
Local Char WLAN(GLONLAN) : WLAN= func SUBAYS.LANDEF([M]FCYCOD)
Local Integer WI
If len(VALEUR)<4 or toupper(right$(VALEUR,len(VALEUR)-3))<>".XML"
        GERR=1 : GMESSAGE=mess(204,7900,1)-VALEUR : End
Endif

RACINE = func AYTUTIA.MNL7937REP([M]FCYCOD, WLAN, [M]RESRAC)
FILEPATH=RACINE+VALEUR
Call EXISTE(FILEPATH, WI) From ORDSYS
If WI<>1     # pas un fihier
    GERR=3 : GMESSAGE=mess(101,100,1)-VALEUR        # GERR=3: avertissement GERR=2: message
Endif
End

Subprog S_RESSUBFIC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 Local Char RACINE(200),WVAL(250)
 Local Char WLAN(GLONLAN) : WLAN= func SUBAYS.LANDEF([M]FCYCOD)
 Local Integer WI
 RACINE = func AYTUTIA.MNL7937REP([M]FCYCOD, WLAN, [M]RESRAC) 

 #
 # <=> Action SELFICREP  (TRT SELFICREP)
 WVAL=RACINE+VALEUR
 Call SELFICREP(WVAL) From SELFICREP
 #
 WI=instr(0,WVAL,RACINE)
 If WI
    # Remove eventuel du dirsep en derniĂ¨re position
    If right$(WVAL,len(WVAL))= func AYTGESFILE.GETPATH("",nomap,"DIRSEP","","","") : WVAL=left$(WVAL,len(WVAL)-1) : Endif
    WVAL=right$(WVAL,len(RACINE)+1)
    If len(WVAL)<>0 : VALEUR=WVAL : Endif
 Else
    mkstat=2
    GERR=1 : GMESSAGE=mess(16,7900,1)-WVAL
 Endif 
Endif

End


