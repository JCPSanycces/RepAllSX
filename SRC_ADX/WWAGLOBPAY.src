#<AdxTL>@(#)0.0.0.0 $Revision$ Global variables
Subprog DEFVAR
Local Char    PARAM(250)
Global Date     GMOIPAY             : # Current payroll month
Global Date     GDEBANN             : # Start of current year
Global Date     GFINANN             : # Start of current year
Global Integer  GJMAX               : # Maximum overdue days
Global Integer  GDECVAR(1..12)      : # No. of decimals of employee pages
Global Char     GPRFRUB(GLONPRF)    : # Profile being calculated
Global Libelle  GPRFTAB1(1..15000)  : # Table of headings/profile
Global Libelle  GPRFTAB2(1..15000)  : # Table of headings/profile
Global Libelle  GPRFTAB3(1..15000)  : # Table of headings/profile
Global Libelle  GPRFTAB4(1..15000)  : # Table of headings/profile
Global Libelle  GPRFTAB5(1..15000)  : # Table of headings/profile
Global Libelle  GPRFTAB6(1..15000)  : # Table of headings/profile
Global Libelle  GPRFTAB7(1..15000)  : # Table of headings/profile
Global Integer  GPLANOK(1..40)      : # Updated payroll
Global Libelle  GHYPMSR(1..15000)   : # Table of TP headings activated/scenario
Global Libelle  GPRFMSR(1..15000)   : # TP heading table/profile
Global Char     GEMPTAB(GLONATB)(1..50) : # Employee table
Global Integer  GNBEMPTAB           : # No. of tables
Global Integer  GTYPTAB(1..50)      : # Table type
Global Integer  GIMPRIME            : # To print directly
Global Integer  GNBSERV             : # No. of services
Global Char     GAUTSRV(GLONSRV)(1..500) : # Authorized services
Global Char     GPHOTO(10)          : # Photo extension
Global Char     GWRK(120)(1..50)    : # Workflow text
Global Integer  GERRHRM             : # Action process error
Global Integer  GPAYE               : # Payroll module active
Global Integer  GINTMT              : # INTMT activity code activated
Global Integer  GTPS                : # Time Mgmt available
Global Integer  GMAS                : # Total payroll module activated
Global Integer  GNBHOR              : # Nb of time slots managed
Global Char     GFLDMS(40)(1..max(1,func AFNC.ACTIV("MSF")),0..1) : # TP employee fields
Global Char     GVRAMS(40)(1..max(1,func AFNC.ACTIV("MSV")),0..1) : # TP employee variables
Global Integer  GPLANMSOK(1..40)    : # Updated TP payroll plan
Global Char     GURLRET001(80)      : # Collaborative portal workflow feedback URL
Global Char     GURLRET002(80)      : # Collaborative portal workflow feedback URL
Global Char     GURLRET003(80)      : # Collaborative portal workflow feedback URL
Global Char     GCOMMENTSIG(250)    : # Workflow signature comment
End
