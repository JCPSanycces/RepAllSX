#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque PDSYSRH

######################################################################################
## Clic droit Pièce sur la livraison
######################################################################################
Subprog IB_NBSDH

  GBOUT2 = mess(54,198,1)
  If GPILNAV>1 Then
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If find("GESSDH",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
  Endif
End

Subprog B2_NBSDH
Local Integer NOL

  If clalev([F:SDH])=0 : Local File SDELIVERY [SDH] : Endif 
  Filter [F:SDH]
  GCONSULT = 2
  Local Char SAV_VCRNUM
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  NOL = nolign-1
  SAV_VCRNUM = [M]SDHNUM(NOL)
  Call OBJET("SDH",[M]SDHNUM(NOL),"") From GOBJET
  [M]SDHNUM(NOL) = SAV_VCRNUM 

  GCONSULT = 0
End

######################################################################################
## Clic droit Pièce sur l'avoir
######################################################################################
Subprog IB_NBSIH

  GBOUT2 = mess(2,267,1)
  If GPILNAV>1 Then
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If find("GESSIH",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
  Endif
End

Subprog B2_NBSIH
Local Integer NOL

  If clalev([F:SIH])=0 : Local File SINVOICE [SIH] : Endif 
  Filter [F:SIH]
  GCONSULT = 2
  Local Char SAV_VCRNUM
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  NOL = nolign-1
  SAV_VCRNUM = [M:PRH2]NUM(NOL)
  Call OBJET("SIH",[M:PRH2]NUM(NOL),"2") From GOBJET
  [M:PRH2]NUM(NOL) = SAV_VCRNUM 

  GCONSULT = 0
End



