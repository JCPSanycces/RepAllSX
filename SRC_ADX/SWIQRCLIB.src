################################
# Creditor agent
################################

Funprog IS_CDTRAGT()
#End 1 # TODO (DNE): Remove!
    If func IS_QRC()
        End 0 # Not available in QR code of type "SPC".
    Elsif [F:BID]BICCOD <> ""
        End 1
    Endif
End 0 # Might always be FALSE after 2019-01-01



################################
# Remittance information
################################

Funprog IS_RMTINF()
    If !func IS_QRC()
        End 0
    Endif
    If [F:SWIQRC]REF <> "" or [F:SWIQRC]USTREF <> ""
        End 1
    Endif
End 0

Funprog IS_RMTINF_STRD()
    If !func IS_RMTINF()
        End 0
    Endif
    If [F:SWIQRC]REF <> ""
        End 1
    Endif
End 0

Funprog IS_RMTINF_USTRD()
    If !func IS_RMTINF()
        End 0
    Endif
    If func IS_RMTINF_STRD()
        End 0
    Endif
    If [F:SWIQRC]USTREF <> ""
        End 1
    Endif
End 0




################################
# Fields that behave differently
# when using QR codes.
################################

Funprog CREDITOR_NAME
    If func IS_QRC() and [F:SWIQRC]CDTRNAM <> ""
        End [F:SWIQRC]CDTRNAM
    Endif
End string$( [F:PYH]BPANAM <> "", [F:PYH]BPANAM ) + string$( [F:PYH]BPANAM = "", [F:PYH]BPR )

Funprog CREDITOR_IBAN()
    If func IS_QRC() and [F:SWIQRC]IBACOD <> ""
        End [F:SWIQRC]IBACOD
    Endif
End [F:BID]IBAN + [F:BID]BIDNUM

