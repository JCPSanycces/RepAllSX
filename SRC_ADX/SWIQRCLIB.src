#*****************************************************************************************************
# IS_QRC        returns if the current payment refers to a QR code invoice (1 = yes, 0 = no)
#* @return      1 = yes, invoice is QR invoice, 0 = no, invoice isn't a QR invoice
#*****************************************************************************************************
#*!
Funprog IS_QRC()
    # OR code handling for ISO3 is only available for active Swiss localisation (ACV "KSW").
    If !func AFNC.ACTIV("KSW")
        End 0
    Endif

    If [F:PIH]NUM <> ""
        If ( [F:SWIQRC]ORIMOD <> 6 ) or ( [F:SWIQRC]NUM <> [F:PIH]NUM ) # Not on needed DB record?
            Read [F:SWIQRC]SWIQRC0 = [F:PIH]NUM; 6
            If fstat
                Raz [F:SWIQRC]
                End 0
            Endif
        Endif
        If [F:SWIQRC]QRCODTYP = "SPC"
            End 1
        Else
            Raz [F:SWIQRC]
            End 0
        Endif
    Endif
    Raz [F:SWIQRC]
End 0
#*****************************************************************************************************


