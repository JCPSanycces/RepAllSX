################################
# Creditor address
################################

Funprog IS_CDTR_ADR()
    If !func IS_QRC()
        End 0
    Endif
    If [F:SWIQRC]CDTRSTRNAM <> "" or [F:SWIQRC]CDTRBLDGNBR or [F:SWIQRC]CDTRPSTCOD <> "" or [F:SWIQRC]CDTRCTY <> "" or [F:SWIQRC]CDTRCRY <> ""
        End 1
    Endif
End 0

Funprog IS_CDTR_ADR_STR()
    If !func IS_CDTR_ADR()
        End 0
    Endif
    If [F:SWIQRC]CDTRSTRNAM <> ""
        End 1
    Endif
End 0

Funprog IS_CDTR_ADR_BLDGNB()
    If !func IS_CDTR_ADR_STR()
        End 0
    Endif
    If [F:SWIQRC]CDTRBLDGNBR <> ""
        End 1
    Endif
End 0

Funprog IS_CDTR_ADR_PSTCD()
    If !func IS_CDTR_ADR()
        End 0
    Endif
    If [F:SWIQRC]CDTRPSTCOD <> ""
        End 1
    Endif
End 0

Funprog IS_CDTR_ADR_TWNNM()
    If !func IS_CDTR_ADR()
        End 0
    Endif
    If [F:SWIQRC]CDTRCTY <> ""
        End 1
    Endif
End 0

Funprog IS_CDTR_ADR_CTRY()
    If !func IS_CDTR_ADR()
        End 0
    Endif
    If [F:SWIQRC]CDTRCRY <> ""
        End 1
    Endif
End 0




