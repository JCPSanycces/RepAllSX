#<AdxTL>@(#)0.0.0.0 $Revision$
#Local Integer TOTALSUM

#** #############################################################################################################
#*
#* Function:   GET_EXEDAT_AND_INIT_SUM
#*
#* Purpose:    Get formated execution date and initalize
#*
#*
#* Parameters:
#*
#* @param ESUM         amount value
#*
#* @return            fixed ESUM value
#*! #############################################################################################################
Funprog GET_EXEDAT_AND_INIT_SUM(XEXEDAT)
Value Char XEXEDAT
Local Char XEXEDAT1(30)
XEXEDAT1 = "010100"
If XEXEDAT< format$("D:YY",date$)+format$("D:YYMMDD",date$) or XEXEDAT="" Then
   XEXEDAT1= format$("D:YY",date$)+format$("D:YYMMDD",date$)
Else
   XEXEDAT1= XEXEDAT
Endif

If clalev([F:AVN])=0 : Local File AVALNUM [AVN] : Endif
  Trbegin [F:AVN]
   Readlock [F:AVN]AVN0(1) = "DTAZV"
   If !fstat
      [F:AVN]VALEUR = 0
      Rewrite [F:AVN]
      Unlock [F:AVN]
      Commit
   Else
    Raz [F:AVN]
    [F:AVN]CODNUM = "DTAZV"
    [F:AVN]VALEUR = 0
    Write [F:AVN]
    If !fstat
      Unlock [F:AVN]
      Commit
    Else
      Rollback
    Endif
  Endif


End XEXEDAT1


#** #############################################################################################################
#*
#* Function:   ADD_TO_TOTAL_SUM
#*
#* Purpose:    Adding single amount values to the total amount in table Avalnum
#*
#*
#* Parameters:
#*
#* @param ESUM         amount value
#*
#* @return            fixed ESUM value
#*! #############################################################################################################
Funprog ADD_TO_TOTAL_SUM(ESUM)

  Value Integer ESUM

  If clalev([F:AVN])=0 : Local File AVALNUM [AVN] : Endif

     Trbegin [F:AVN]
     Readlock [F:AVN]AVN0(1) = "DTAZV"
     If !fstat
        [F:AVN]VALEUR += fix(ESUM)
        Rewrite [F:AVN]
        Unlock [F:AVN]
        Commit
       Else
        Rollback
     Endif

End fix(ESUM)


#** #############################################################################################################
#*
#* Function:   GET_TOTAL_SUM
#*
#* Purpose:    Returns the total amount stored in table AVALNUM
#*
#* @return     Total sum
#*! #############################################################################################################
Funprog GET_TOTAL_SUM()

  Local Integer TOTALSUM
  If clalev([F:AVN])=0 : Local File AVALNUM [AVN] : Endif
  Trbegin [F:AVN]
     Readlock [F:AVN]AVN0(1) = "DTAZV"
     If !fstat
      TOTALSUM = [F:AVN]VALEUR
      [F:AVN]VALEUR = 0
      Rewrite [F:AVN]
      Unlock [F:AVN]
      Commit
     Else
      Rollback
    Endif

End TOTALSUM

