#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque POT6 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:03"
A_USER  = "DOC"
A_STAMP = "20181109230603"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRFAM"
  If [M]NBRFAM=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask POT6 [POT6]
Gosub HORODAT
Local Inpbox "POT6" From GFONCTION At A_STAMP With A_WINDPREV Mask [POT6] As [SIM_]
Grizo [POT6]5
Grizo [POT6]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [POT6]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=80 : Y1(0)=1 : Y2(0)=3
X1(1)=1 : X2(1)=80 : Y1(1)=4 : Y2(1)=24
Return

$ON_JOBGRP
Onevent INIT_AREA Call D_JOBGRP(zc) From W1POT6
Return

Subprog D_JOBGRP(VALEUR)
Variable Char    VALEUR()
If varinit([M]JOBGRP,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10460","") From SUBADI
Endif
Gosub _AFF
End

$ON_ZJOBGRP
Onevent BEFORE_AREA Gosub AV_ZJOBGRP From W1POT6
Return

$AV_ZJOBGRP
Call LECTEXTRA(zc,"ATABDIV","LNGDES","10460",num$([M]JOBGRP(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_UOMGRP
Onevent INIT_AREA Call D_UOMGRP(zc) From W1POT6
Return

Subprog D_UOMGRP(VALEUR)
Variable Char    VALEUR()
If varinit([M]UOMGRP,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10459","") From SUBADI
Endif
Gosub _AFF
End

$ON_ZUOMGRP
Onevent BEFORE_AREA Gosub AV_ZUOMGRP From W1POT6
Return

$AV_ZUOMGRP
Call LECTEXTRA(zc,"ATABDIV","LNGDES","10459",num$([M]UOMGRP(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_NBRFAM
Onevent AFTER_LINE Call APRES_NBRFAM From W1POT6
Return

Subprog APRES_NBRFAM
Local Decimal BASPAG
## Action STD
Call APRES_NBRFAM From SUBPOT
If mkstat : End : Endif
Gosub _AFF
End

$ON_CPCFAM
Onevent INIT_AREA Call D_CPCFAM(zc) From W1POT6
Onevent CONTROL Call C_CPCFAM(zc) From W1POT6
Onevent BEFORE_INPUT Call AS_CPCFAM(zc) From W1POT6
Onevent AFTER_CHANGE Gosub AMM_CPCFAM From W1POT6
Return

Subprog IB_CPCFAM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call IB_CPCFAM From SUBPOT
Gosub _AFF
End

Subprog D_CPCFAM(VALEUR)
Variable Char    VALEUR()
If varinit([M]CPCFAM,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10461","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_CPCFAM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"10461") From TRTDIV
Call TEXTE(45514,GBOUT2) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Call IB_CPCFAM(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_CPCFAM(zc) From W1POT6
Onkey 130 Titled GBOUT2 Call B2_CPCFAM(zc) From W1POT6
Onkey   2 Titled GBOUTS Call S_CPCFAM(zc) From W1POT6
Onkey 144 Titled GBOUTP Call P_CPCFAM(zc) From W1POT6
Onkey 146 Titled GBOUTA Call SA_CPCFAM(zc) From W1POT6
If VALEUR="" : Call INIADI(VALEUR,"10461") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_CPCFAM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CPCFAM" : GZNUM = 45514 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"10461","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "CPCFAM" : GZNUM = 45514 : Endif
 If !mkstat
  ## Action STD
  Call C_CPCFAM(VALEUR) From SUBPOT
  If mkstat : GERR = 1 : GZONE = "CPCFAM" : GZNUM = 45514 : Endif
  If !mkstat
   ## Action CONTOBJN
   Local Char    PARMSK(250)(1..20) , SAVACT(20)
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CPCFAM" : GZNUM = 45514 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CPCFAM
Call AM_CPCFAM(zc)
If !mkstat & GOBJET
 zoncou = "CPCFAM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CPCFAM(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCPCFAM)")>indice
 [M]CPCFAM(indice) = VALEUR
 Affzo ZCPCFAM(indice)
Endif
Gosub _AFF
End

Subprog S_CPCFAM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "10461"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CPCFAM(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"10461") From GOBJET
Gosub _AFF
End

Subprog B2_CPCFAM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action GOBJETC0
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC0"
 Local Char    OBJCLE(30)
 OBJCLE = ""
 Call OBJET_CHAR(OBJCLE,"GCP",num$(4)+"~"+""+"~"+VALEUR) From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_CPCFAM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "10461"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CPCFAM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "10461"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCPCFAM
Onevent BEFORE_AREA Gosub AV_ZCPCFAM From W1POT6
Return

$AV_ZCPCFAM
Call LECTEXTRA(zc,"ATABDIV","LNGDES","10461",num$([M]CPCFAM(indice))) From ATEXTRA
Gosub _AFF
Return

$CHG_STY
Return


