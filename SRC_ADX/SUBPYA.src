####################################################################################
# Program Name: SUBPYA
# Description : HRMS payroll NA parameters
# Author      : GRNA
####################################################################################

Call OBJET ("PYA", GBIDC1, GBIDC2) From GOBJET
End

######################################################################################
$ACTION
Case ACTION
 When "OUVRE" : Gosub OUVRE
 When Default
Endcase
Return


######################################################################################
$OUVRE
If !clalev([F:AOE]) : Local File AOBJEXT [AOE] : Endif
Return

          
######################################################################################
Subprog AM_EXPTEMP(VALEUR)
Variable Char    VALEUR()
If [M]DRTISS="" : [M]DRTISS = [F:AOE]FILEXT : Endif  
End


######################################################################################
Subprog AM_IMPTEMP(VALEUR)
Variable Char    VALEUR()
If [M]DRTRCP="" : [M]DRTRCP = [F:AOE]FILEXT : Endif
End

