#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIACH35 : Recherche des EO incomplets                  Module Achats  #
##########################################################################
#   Achats de sous-traitance                                 Issue 88384 #
##########################################################################

Call MAJ_UTIACH35
End

##################################
Subprog MAJ_UTIACH35
Local Char DOSSIER(30) : DOSSIER=nomap
#Call SAIDOS(DOSSIER,"") From SAIDOS
If [L]DOSSIER<>""
   If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
   Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

   Call EXE_UTIACH35([L]DOSSIER)
Endif
End

##################################
Subprog EXE_UTIACH35(DOSSIER)
Value Char DOSSIER

Local Integer LRET

Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTIACH35 : Rectification des EO avec données manquantes") From LECFIC
Call ECR_TRACE("UTIACH35 : Début traitement du dossier "+DOSSIER,0) From GESECRAN

# Traitement des EO
If GMODU(6)=2 : # Module Achat actif
  Gosub TRT_SCO_EO
Endif


$FIN_UTIACH35
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC

End


##################################
$TRT_SCO_EO

Local File =DOSSIER+".SCOHEAD"    [SCOW]
Local File =DOSSIER+".SCOITM"     [SCIW]
Local File =DOSSIER+".SCOMAT"     [SCMW]
Local File =DOSSIER+".SCOSRV"     [SCSW]

Local File =DOSSIER+".FACILITY"   [FCY]
Local File =DOSSIER+".ITMFACILIT" [ITF]
Local File =DOSSIER+".ITMMASTER"  [ITM]
Local File =DOSSIER+".ITMBPS"     [ITP]
Local File =DOSSIER+".BPARTNER"   [BPR]
Local File =DOSSIER+".BPSUPPLIER" [BPS]
Local File =DOSSIER+".BPDLVCUST"  [BPD]

Local Mask =DOSSIER+".ORDK"       [ORDK]

Local Char     WSCONUM(GLONVCR),WBPRNUM(GLONBPR)
Local Integer  WSIMFLG, ISCO
Local Shortint STAT : STAT=0

WSIMFLG=2
If !GBATCH
   Call OUINON(mess(6,115,1)-"?"-nomap,WSIMFLG) From GESECRAN
Endif

Call ECR_TRACE(" ",0) From GESECRAN
If WSIMFLG=2
   Call ECR_TRACE("Correction des données EO"-mess(6,115,1),0) From GESECRAN
Else
   Call ECR_TRACE("Correction des données EO",0) From GESECRAN
Endif
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(" ",0) From GESECRAN

Gosub CTL_MISSING_SCO
Gosub CTL_MISSING_SCI

$FIN_UTIACH35_EO
Close Local File [SCOW]
Close Local File [SCIW]
Close Local File [SCMW]
Close Local File [SCSW]

Close Local File [FCY]
Close Local File [ITM]
Close Local File [ITF]
Close Local File [ITP]
Close Local File [BPR]
Close Local File [BPS]
Return

$CTL_MISSING_SCO
Local Integer WRET : WRET=0
Call ECR_TRACE("------------------------------------------",0) From GESECRAN
Call ECR_TRACE("UTIACH35 : Liste des EO incomplets: entête",0) From GESECRAN
Call ECR_TRACE("------------------------------------------",0) From GESECRAN
Trbegin [SCOW]
Raz ISCO
Filter [SCIW] Where SCOSTA<3
For [SCIW]
   Read [SCSW]SCS0(2)=[F:SCIW]SCONUM;[F:SCIW]SCILIN
   If fstat
      Raz [F:SCSW]
      Call ECR_TRACE("SCOSRV: ordre de sous-traitance sans service"-[F:SCIW]SCONUM-[F:SCIW]PRHFCY,1) From GESECRAN
   Endif
   Read [SCOW]SCO0=[F:SCIW]SCONUM
   If fstat &  [F:SCSW]SCONUM= [F:SCIW]SCONUM
      Call ECR_TRACE("SCOHEAD: ordre de sous-traitance sans entête"-[F:SCIW]SCONUM-[F:SCIW]PRHFCY,1) From GESECRAN
      [F:SCOW] = [F:SCIW]
      [F:SCOW] = [F:SCSW]
      [F:SCOW]ORDDAT = [F:SCSW]OPESTR
      [F:SCOW]RETDAT = [F:SCSW]OPEEND
      Write [SCOW]
      Call UPD_SCOTRKFLG([F:SCIW]SCONUM,WRET) From SCOLIB
      ISCO+=1
   Endif

$NEXT_SCO
Next

Filter [SCOW]
If ISCO=0
   Call ECR_TRACE("SCOHEAD: Aucune anomalie trouvée",0) From GESECRAN
Elsif WSIMFLG=2
   Call ECR_TRACE(num$(ISCO)-"Lignes SCOHEAD manquantes",0)  From GESECRAN
Else
   Call ECR_TRACE(num$(ISCO)-"Lignes SCOHEAD regénérées",0)  From GESECRAN
Endif
If WSIMFLG=2
   Rollback
   Call ECR_TRACE("Mode simulation: Rollback !!!",0) From GESECRAN
Else
   Commit
Endif

Return

$CTL_MISSING_SCI
Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
Call ECR_TRACE("UTIACH35 : Liste des EO incomplets: article lancé",0) From GESECRAN
Call ECR_TRACE("-------------------------------------------------",0) From GESECRAN
Trbegin [SCOW]
Raz ISCO
Filter [SCOW] Where SCOSTA<3
For [SCOW]
   Filter [SCIW] Where SCONUM=[F:SCOW]SCONUM
   Read [SCIW] First
   If fstat
      Raz [F:SCIW]
      ISCO+=1
      Call ECR_TRACE("SCOITM: ordre de sous-traitance sans article lancé"-[F:SCOW]SCONUM-[F:SCOW]POHFCY,1) From GESECRAN
      Gosub DELETE_EO
      Goto NEXT_SCI
   Endif
   Filter [SCSW] Where SCONUM=[F:SCOW]SCONUM
   Read [SCSW] First
   If fstat
      Raz [F:SCSW]
      ISCO+=1
      Call ECR_TRACE("SCOSRV: ordre de sous-traitance sans service"-[F:SCOW]SCONUM-[F:SCOW]POHFCY,1) From GESECRAN
      Gosub DELETE_EO
      Goto NEXT_SCI
   Endif
$NEXT_SCI
   Filter [SCIW]
   Filter [SCSW]
Next

Filter [SCOW]
If ISCO=0
   Call ECR_TRACE("SCOITM: Aucune anomalie trouvée",0) From GESECRAN
Elsif WSIMFLG=2
   Call ECR_TRACE(num$(ISCO)-"Lignes SCOITM manquantes",0)  From GESECRAN
Endif
If WSIMFLG=2
   Rollback
   Call ECR_TRACE("Mode simulation: Rollback !!!",0) From GESECRAN
Else
   Commit
Endif

Return

$DELETE_EO
If clalev ([M:SCOK])= 0 : Local Mask SCOK [SCOK]: Endif
Raz [SCOK]
[M:SCOK]CODMAJ = "A"
[M:SCOK]SCONUM = [F:SCOW]SCONUM
Call MAJ_SCO From SCOAUTLIB
Return

#----------------------------------------------------------------------#
# Chargement des paramètres avec GFCY = Site de la commande            #
# -------------------------------------------------------------------- #
# Chargement GSOCIETE   : Société juridique                            #
#            GLOCALDEV  : Devise société juridique                     #
#----------------------------------------------------------------------#
$CHARG_PARAM
Local  Char     PARAM2(10)
If [F:ADS]MODULE(1) = 2  # Dossier avec module comptabilité
  Call GLOBVAR(GFCY)  From WWGLOBCPT
  #----- Chargement des globales référentiels, comptes et sections de la société -----#
  Call GETCPY(GFCY,"PTR",9,GSCOPTRNUM) From TRTX3CPT
Endif
Call GLOBVAR(GFCY)    From WWGLOBACH
Raz GMESSAGE
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
############## uniquement si nécessaire de maj les données
############## Call EXE_UTIACH35(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
############## uniquement si nécessaire de maj les données
############## Call EXE_UTIACH35(APPLI)
End

#######################################################################
