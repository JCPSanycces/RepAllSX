##########################################################################################################
$ABANDON
  GIPATCHAMCONCOT = 0
  GICONCREATION = 0
Return

##########################################################################################################
Subprog AM_SALREP(VALEUR)
Variable Char    VALEUR()

Local Char SZCUR(GLONCUR)

  SZCUR = [M:CON0]CUR
  Call SITECRMREP("HDK", VALEUR, [M:CON0]SALFCY) From CRM_UTIL
  GFCY=[M:CON0]SALFCY
  Call GETDEV(GFCY) From DEVSUB
  Call SETCUR([M:CON0]CONBPC, VALEUR, SZCUR) From CRM_UTIL
  [M:CON0]CUR = SZCUR
  [M:CON4]CONCUR3 = SZCUR
  [M:CON2]CONCUR4 = SZCUR
  Affzo [M:CON0]SALFCY
  Affzo [M:CON0]CUR
  Affzo [M:CON4]CONCUR3
  Affzo [M:CON2]CONCUR4
End

##########################################################################################################
Subprog IB_CONBPC

  Call IB_NOTECHECK([M:CON0]CONBPC,"CRM",3)  From TRTNTSCTL # CRM notes
End

##########################################################################################################
Subprog AM_CONBPC(VALEUR)
Variable Char    VALEUR()

Local Integer IRESP
Local Char SZCUR(GLONCUR)

  SZCUR = [M:CON0]CUR
  IRESP = 0
  Raz [M:CON0]CONCCN
  Raz [M:CON0]CONCCNCLA
  Read [BPC]BPC0=VALEUR
  If !fstat Then
    If [F:BPC]REP(0) <> "" Then
      [M:CON1]SALREP = [F:BPC]REP(0)
    Else
      If [F:BPC]REP(1) <> "" Then
        [M:CON1]SALREP = [F:BPC]REP(1)
      Endif
    Endif
    If [F:BPC]CUR <> "" Then
      SZCUR = [F:BPC]CUR
    Endif
  Endif
  Call SETSITECRM("HDK", VALEUR, [M:CON1]SALREP, [M:CON0]SALFCY) From CRM_UTIL
  GFCY = [M:CON0]SALFCY
  Call GETDEV(GFCY) From DEVSUB
  If [M:CON0]SALFCY <> "" Then
    #Déduit le code société
    Read [FCY]FCY0=[M:CON0]SALFCY
    If !fstat Then
      [M:CON0]CPY = [F:FCY]LEGCPY
    Endif
  Endif
  Read [BPR]BPR0=VALEUR
  Call SETCUR(VALEUR, [M:CON1]SALREP, SZCUR) From CRM_UTIL
  [M:CON0]CUR = SZCUR
  [M:CON4]CONCUR3 = SZCUR
  [M:CON2]CONCUR4 = SZCUR
  [M:CON0]CONBPC = VALEUR
  If [M:CON0]CONBPC <> "" Then
    Call SETINVINF([M:CON0]CONBPC) From SUBCONB1
  Endif
  If [M:CON0]CONBPC <> "" Then
    #Définit l'interlocuteur par défaut du contrat
    If [M:CON0]CONCCN = "" Then
      Call GETDEFCNT([M:CON0]CONBPC, [M:CON0]CONCCN) From CRMUTIL140
    Endif
  Endif
  Gosub DISPCCN From SUBCONB2
  # Issue X3-77320 - 2018-03-30 by FGR : BEGIN
  Call INIT_CCEH("CON8","NBAXE","CON") From TRTX3CPT
  # Issue X3-77320 - 2018-03-30 by FGR : END
  Affzo [M:CON8]1-99
  Affzo [M:CONG]1-99
  Affzo [M:CON0]1-99
  Affzo [M:CON1]1-99
  Affzo [M:CON4]1-99
  Affzo [M:CON2]CONCUR4
End

######################################################################################
# 71065 : PJT
######################################################################################
# Issue X3-77320 - 2018-03-30 by FGR : BEGIN
Subprog AM_CONPJT(VALEUR)
Variable Char    VALEUR()

Local Integer NI

  # Réinitialisation des sections analytiques
  If dim([M:CON8]NBAXE) > 0 Then
    [M:CONG]CONPJT = VALEUR
    # Issue X3-89428 - 2018-05-04 by FGR : BEGIN
    #If [M:CON8]NBAXE > 0 Then
    #  For NI = 1 To [M:CON8]NBAXE
    #    Raz [M:CON8]CCE(NI-1)
    #  Next
    #Endif
    # Issue X3-89428 - 2018-05-04 by FGR : END
    Call INIT_CCEH("CON8", "NBAXE", "CON") From TRTX3CPT
    Affzo [M:CON8]15
  Endif
End

