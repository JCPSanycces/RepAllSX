##########################################################################################################
Subprog AM_REWFRY(VALEUR)
Variable Decimal VALEUR

Local Integer IVALEUR

  IVALEUR = VALEUR
  [M:CON4]FLGUPDDAT = 1
  #Active ou désactive le champs unité de la fréquence de renouvellement
  If VALEUR > 0 Then
    If [M:CON4]REWFRYBAS = 6 Then
      [M:CON4]REWFRYBAS = 2
    Endif
    Actzo [M:CON4]REWFRYBAS
  Else
    [M:CON4]REWFRYBAS = 6
    Grizo [M:CON4]REWFRYBAS
  Endif
  If [M:CON4]REWFRYBAS = 6 Then #vide
    [M:CON4]CONSTRDAT = [00/00/00]
    [M:CON4]CONENDDAT = [00/00/00]
  Else
    If [M:CON4]CONSTRDAT = [00/00/00] Then
      # FGR 02/09/2008 : Suite mail JAM : On alimente la date debut si elle est vide...
      [M:CON4]CONSTRDAT = [M:CON4]SIUDAT
    Endif
    # FGR 02/09/2008 : ... par contre si on passe là c'est qu'il y a eu un changement : donc on calcule toujours la date de fin
    Call SETENDDAT([M:CON4]CONSTRDAT, IVALEUR, [M:CON4]REWFRYBAS, [M:CON4]CONENDDAT) From SUBCOND
  Endif
  [M:CON4]REWFRY = VALEUR
  Affzo [M:CON4]1-99
End

##########################################################################################################
Subprog AM_REWFRYBAS(VALEUR)
Variable Integer VALEUR

Local Integer IVALEUR

  IVALEUR = VALEUR
  [M:CON4]FLGUPDDAT = 1
  If VALEUR = 6 Then #vide
    [M:CON4]CONSTRDAT = [00/00/00]
    [M:CON4]CONENDDAT = [00/00/00]
  Else
    If [M:CON4]CONSTRDAT = [00/00/00] Then
      # FGR 02/09/2008 : Suite mail JAM : On alimente la date debut si elle est vide...
      [M:CON4]CONSTRDAT = [M:CON4]SIUDAT
    Endif
    # FGR 02/09/2008 : ... par contre si on passe là c'est qu'il y a eu un changement : donc on calcule toujours la date de fin
    Call SETENDDAT([M:CON4]CONSTRDAT, [M:CON4]REWFRY, IVALEUR, [M:CON4]CONENDDAT) From SUBCOND
  Endif
  [M:CON4]REWFRYBAS = VALEUR
  Affzo [M:CON4]1-99
End

##########################################################################################################
Subprog AM_CONSTRDAT(VALEUR)
Variable Date    VALEUR

Local Date IVALEUR

  IVALEUR = VALEUR
  [M:CON4]FLGUPDDAT = 1
  # FGR 02/09/2008 : Suite mail JAM : Si on modifie la date debut la date de fin est automatiquement recalculée
  Call SETENDDAT(IVALEUR, [M:CON4]REWFRY, [M:CON4]REWFRYBAS, [M:CON4]CONENDDAT) From SUBCOND
End

##########################################################################################################
Subprog AM_EVRMAC(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    [M:CON1]CRSCOVSAM = 2
    Grizo [M:CON1]CRSCOVSAM
  Else
    [M:CON1]CRSCOVSAM = 1
    Actzo [M:CON1]CRSCOVSAM
  Endif
  [M:CON1]EVRMAC = VALEUR
  Affzo [M:CON1]1-99
End

##########################################################################################################
Subprog AM_INVFRY(VALEUR)
Variable Decimal VALEUR

  If VALEUR > 0 Then
    If [M:CON8]INVFRYBAS = 6 Then
      [M:CON8]INVFRYBAS = 2
    Endif
    Actzo [M:CON8]INVFRYBAS
  Else
    [M:CON8]INVFRYBAS = 6
    Grizo [M:CON8]INVFRYBAS
  Endif
  Affzo [M:CON8]INVFRYBAS
  [M:CON8]INVFRY = VALEUR
  Affzo [M:CON8]INVFRY
End

##########################################################################################################
Subprog AM_INVLTI(VALEUR)
Variable Decimal VALEUR

  If VALEUR > 0 Then
    If [M:CON8]INVLTIBAS = 6 Then
      [M:CON8]INVLTIBAS = 2
    Endif
    Actzo [M:CON8]INVLTIBAS
  Else
    [M:CON8]INVLTIBAS = 6
    Grizo [M:CON8]INVLTIBAS
  Endif
  Affzo [M:CON8]INVLTIBAS
End

##########################################################################################################
Subprog AM_RVAFRY(VALEUR)
Variable Decimal VALEUR

  If VALEUR > 0 Then
    If [M:CON4]RVAFRYBAS = 6 Then
      [M:CON4]RVAFRYBAS = 2
    Endif
    Actzo [M:CON4]RVAFRYBAS
    If [M:CON4]RVASSP = 1 Then
      Actzo [M:CON4]CONBASIDX
      Grizo [M:CON4]CONBASFOR
      Actzo [M:CON4]LASVALIDX
      Actzo [M:CON4]LASIDXDAT
    Elsif [M:CON4]RVASSP = 2 Then
      Grizo [M:CON4]CONBASIDX
      Actzo [M:CON4]CONBASFOR
      Grizo [M:CON4]LASVALIDX
      Grizo [M:CON4]LASIDXDAT
    Else
      Grizo [M:CON4]CONBASIDX
      Grizo [M:CON4]CONBASFOR
      Grizo [M:CON4]LASVALIDX
      Grizo [M:CON4]LASIDXDAT
    Endif
  Else
    [M:CON4]RVAFRYBAS = 6
    Grizo [M:CON4]RVAFRYBAS
    [M:CON4]CONBASIDX = ""
    Grizo [M:CON4]CONBASIDX
    [M:CON4]CONBASFOR = ""
    Grizo [M:CON4]CONBASFOR
    [M:CON4]LASVALIDX = 0
    Grizo [M:CON4]LASVALIDX
    [M:CON4]LASIDXDAT = [00/00/00]
    Grizo [M:CON4]LASIDXDAT
  Endif
End

##########################################################################################################
Subprog AM_CONBASIDX(VALEUR)
Variable Char    VALEUR()

  If [M:CON8]INVMET = 1 Then
    If VALEUR <> "" and [M:CON4]LASVALIDX = 0 Then
      Call SETINDVAL(date$, VALEUR) From SUBCONB1
    Endif
  Else
    [M:CON4]LASVALIDX = 0
    [M:CON4]LASIDXDAT = [00/00/00]
  Endif
End

##########################################################################################################
Subprog AM_RSILTI(VALEUR)
Variable Decimal VALEUR

  If VALEUR > 0 Then
    If [M:CON4]RSILTIBAS = 6 Then
      [M:CON4]RSILTIBAS = 2
    Endif
    Actzo [M:CON4]RSILTIBAS
  Else
    [M:CON4]RSILTIBAS = 6
    Grizo [M:CON4]RSILTIBAS
  Endif
  Affzo [M:CON4]RSILTIBAS
End

##########################################################################################################
Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()

  If [M:CON0]CUR <> "" Then
    If VALEUR <> "" Then
      Call INVDTAAMT([M:CON0]CUR, VALEUR, [M:CONG]CONCHGTYP) From SUBCONB2
    Endif
  Endif
  [M:CON4]CONCUR3 = VALEUR
  [M:CON2]CONCUR4 = VALEUR
  [M:CON0]CUR = VALEUR
  Affzo [M:CON0]CUR
  Affzo [M:CON4]CONCUR3
  Affzo [M:CON2]CONCUR4
  Affzo [M:CONG]1-99
End

##########################################################################################################
Subprog AM_RSIFLG(VALEUR)
Variable Integer VALEUR

  #Définit la date de résiliation par défaut si le contrat est résilié
  If VALEUR = 2 Then
    Actzo [M:CON5]RSIDAT
    Actzo [M:CON5]RSIREN
    Grizo [M:CON5]FDDFLG
    If [M:CON5]RSIDAT = [00/00/00] Then
      [M:CON5]RSIDAT = date$
    Endif
    [M:CON5]FDDFLG = 1
    [M:CON5]FDDUSR = ""
    [M:CON5]FDDUSRCLA = ""
    If [M:CON5]RSIREN = "" Then
      Call DEFVALADI(429, [M:CON5]RSIREN) From CRMUTIL140
    Endif
  Else
    Raz [M:CON5]RSIDAT
    Raz [M:CON5]RSIREN
    Raz [M:CON5]FDDFLG
    Grizo [M:CON5]RSIDAT
    Grizo [M:CON5]RSIREN
    Actzo [M:CON5]FDDFLG
  Endif
  Affzo [M:CON5]1-99
End

##########################################################################################################
Subprog AM_FDDFLG(VALEUR)
Variable Integer VALEUR

Local Integer IMESSREP

  IMESSREP = 0
  If VALEUR = 2 Then
    If [M:CON1]CONCAT = 4 Then
      If [M:CON2]NEXINVAMT > 0 Then
        #Ce contrat n'a pas été facturé et ne sera plus facturable. Confirmez-vous son archivage ?
        Call OUINON(mess(18,177,1), IMESSREP) From GESECRAN
        If IMESSREP <> 2 Then
          VALEUR = 1
          [M:CON5]FDDFLG = VALEUR
          Affzo [M:CON5]1-99
          End
        Endif
      Endif
    Endif
  Endif
  #Définit la date par défaut si le contrat est archivé
  If VALEUR = 2 Then
    Actzo [M:CON5]RSIDAT
    Grizo [M:CON5]RSIFLG
    Raz [M:CON5]RSIREN
    Grizo [M:CON5]RSIREN
    If [M:CON5]RSIDAT = [00/00/00] Then
      [M:CON5]RSIDAT = date$
    Endif
    [M:CON5]FDDUSR = GUSER
    Read [AUS]CODUSR=GUSER
    If fstat Then
      [M:CON5]FDDUSRCLA = ""
    Else
      [M:CON5]FDDUSRCLA = [F:AUS]NOMUSR
    Endif
  Else
    Raz [M:CON5]RSIDAT
    Raz [M:CON5]RSIREN
    [M:CON5]FDDUSR = ""
    [M:CON5]FDDUSRCLA = ""
    Grizo [M:CON5]RSIDAT
    Grizo [M:CON5]RSIREN
    Actzo [M:CON5]RSIFLG
  Endif
  Affzo [M:CON5]RSIFLG, RSIDAT, RSIREN
End

##########################################################################################################
Subprog AS_NBINV

  If nolign > 0 Then
    If nolign < dim([M:CON2]INVVCR)-1 Then
      If GCONINVNUM <> [M:CON2]INVVCR(nolign-1) Then
        GCONINVNUM = [M:CON2]INVVCR(nolign-1)
        Call LOADECHE(GCONINVNUM) From SUBCONB1
      Endif
    Endif
  Endif
End

