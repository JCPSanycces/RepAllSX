##########################################################################################################
Subprog IB_SALREP

  Raz GBOUT3
  Raz GBOUT4
  If [M:CON0]CONBPC <> "" Then
    Read [BPC]BPC0=[M:CON0]CONBPC
    If !fstat Then
      #Représentants secondaires
      Call TEXTE(15800, GBOUT3) From OBJDIV
    Endif
  Endif
  If GMODU(13) = 2 Then
    #Saisie représentants
    Call TEXTE(23615, GBOUT4) From OBJDIV
  Endif
End

##########################################################################################################
Subprog C_PITTOL(VALEUR)
Variable Decimal VALEUR

  If VALEUR > 100 Then
    #Ce pourcentage ne peut être supérieur à 100. Saisie refusée
    GMESSAGE = mess(279,182,1)
    GERR = 1
    mkstat = 2
  Elsif VALEUR < 0 Then
    #Ce pourcentage ne peut être négatif. Saisie refusée.
    GMESSAGE = mess(344,182,1)
    GERR = 1
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog AM_RVASSP(VALEUR)
Variable Integer VALEUR

  If !GIMPORT Then
    [M:CON4]CONBASIDX = ""
    [M:CON4]CONBASFOR = ""
    [M:CON4]LASVALIDX = 0
    [M:CON4]LASIDXDAT = [00/00/00]
  Endif
  If VALEUR = 1 Then
    Actzo [M:CON4]CONBASIDX
    Actzo [M:CON4]LASVALIDX
    Actzo [M:CON4]LASIDXDAT
    Grizo [M:CON4]CONBASFOR
  Elsif VALEUR = 2 Then
    Grizo [M:CON4]CONBASIDX
    Grizo [M:CON4]LASVALIDX
    Grizo [M:CON4]LASIDXDAT
    Actzo [M:CON4]CONBASFOR
  Else
    Grizo [M:CON4]CONBASIDX
    Grizo [M:CON4]LASVALIDX
    Grizo [M:CON4]LASIDXDAT
    Grizo [M:CON4]CONBASFOR
  Endif
  Affzo [M:CON4]1-99
End

##########################################################################################################
Subprog AM_CONCAT(VALEUR)
Variable Integer VALEUR

  [M:CON1]CONCAT = VALEUR
  If [M:CON0]CONBPC <> "" Then
    Call SETINVINF([M:CON0]CONBPC) From SUBCONB1
  Endif
  If VALEUR = 4 Then
    [M:CON1]EVRPBL = 2
    [M:CON1]EVRMAC = 2
    [M:CON1]CRSCOVSAM = 2
  Endif
  Call SETGRAY From SUBCONB1
  Affzo [M:CON4]1-99
End

