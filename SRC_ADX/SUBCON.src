#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion du fichier CONTSERV
##########################################################################################################
$ACTION

  Case ACTION
    When "BOITE"        : Gosub BOITE       # FGR 31/07/2014 : X3SUIVI101463
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "OUVRE"        : Gosub OUVRE
    When "LIENS"        : Gosub LIENS
    When "SETBOUT"      : Gosub SETBOUT
    When "RAZDUP"       : Gosub RAZDUP
    When "RAZCRE"       : Gosub RAZCRE
    When "FERME"        : Gosub FERME
    When "INICRE"       : Gosub INICRE
    When "ABANDON"      : Gosub ABANDON
    When "GRISE"        : Gosub GRISE
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "APRES_CRE"    : Gosub APRES_CRE
    When "CREATION"     : Gosub CREATION
    When "MODIF"        : Gosub MODIF
    When "VERF_ANU"     : Gosub VERF_ANU
    When "ANNULE"       : Gosub ANNULE
   #When "AP_ANNULE"    : Gosub AP_ANNULE     # FGR 12/08/2009 : X3SUIVI57005
    When "APRES_ANNULE" : Gosub APRES_ANNULE  # FGR 22/10/2009 : X3SUIVI57254
    When "APRES_MOD"    : Gosub APRES_MOD
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "STATUT"       : Gosub STATUT
    When "FILGAUCHE"    : Gosub FILGAUCHE
    When "AVANT_MOD"    : Gosub AVANT_MOD
    When "AVANTBOUT"    : Gosub AVANTBOUT     # FGR 11/07/2008 : X3SUIVI48011
    When "EXEBOUT"      : Gosub EXEBOUT       # FGR 11/07/2008 : X3SUIVI48011
    When "BB1_NBINV"    : Gosub BB1_NBINV     # FGR 20/03/2015 : X3SUIVI107100
    When Default
  Endcase
Return

##########################################################################################################
$APRES_MODIF
  # FGR 20/03/2015 : X3SUIVI107100 (début)
  If dim (GSAM107100) >= 0 Then
    Kill GSAM107100
    Gosub RELIT From GOBJSUB
    OK = 0
  Endif
  # FGR 20/03/2015 : X3SUIVI107100 (fin)
Return

##########################################################################################################
$BB1_NBINV
  # FGR 20/03/2015 : X3SUIVI107100
  Global Integer GSAM107100
  mkstat = 4
Return

##########################################################################################################
$CHARG_PARAM
Local  Char     PARAM2(10)

  # FGR 26/07/2013 : X3SUIVI87923 (début)
  If func AFNC.ACTIV("SDD") Then
    Call PARAML(GFCY, "SDDMGT", PARAM2) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
    GSDDMGT = val(PARAM2)
    If GSDDMGT <> 1 and GSDDMGT <> 2 Then
      GSDDMGT = 1
    Endif
  Endif
  # FGR 26/07/2013 : X3SUIVI87923 (fin)
Return

##########################################################################################################
$AVANTBOUT
  # FGR 11/07/2008 : X3SUIVI48011 (DEBUT)
  Case BOUT
    When "Y"
      # Tunnel sur FACTURE à créer
      GCREPARBOU = 2
      GBIDC2 = "F" # Ca on le trouve sur la fonction "GESSRE" dans la liste des options
      Gosub AUTORIS_OPT From CONTX3
      If !GBIDI2 Then
        GERR = 1
        GMESSAGE = mess(2,104,1)
        Return
      Endif
      GINVTYP = 1
      WFONC1 = GFONC1
      GFONC1 = "GESCON"
      #
      Lock = "CON"+[M:CON0]CONNUM
      If fstat Then
        # modification en cours sur un autre poste
        GERR = 1
        GMESSAGE = [M:CON0]CONNUM - ":" - mess(10,100,1)
      Else
        GCREPARBOU = 1
      Endif

      # V6.2 : Certification
      # Si ctrl date documents : Le contrat doit avoir une date <= datesyst (La facture est générée avec datesyst)
      If GCTLDATORI=2 & [F:CON]CONSTRDAT>datesyst
          GMESSAGE=mess(7,413,1)-[F:CON]CONNUM-format$(GFMD,[F:CON]CONSTRDAT)-":\"-mess(347,192,1)-":"-format$(GFMD,datesyst)
          GERR=1 : Return
      Endif
    When Default
  Endcase
  # FGR 11/07/2008 : X3SUIVI48011 (FIN)
Return

##########################################################################################################
$EXEBOUT
  # FGR 11/07/2008 : X3SUIVI48011 (DEBUT)
  Case BOUT
    When "Y"
      # Tunnel sur FACTURE à créer
      Gosub RELIT From GOBJSUB
    When Default
  Endcase
  # FGR 11/07/2008 : X3SUIVI48011 (FIN)
Return

##########################################################################################################
$GRISE
  If !GIPATCHAMCONCOT Then
    Return
  Endif
  If GIMPORT Then
    Return
  Endif
  Read [COT]COT0=[M:CON1]CONCOT
  If fstat Then
    [M:CON1]CONCOTNAM = ""
  Else
    [M:CON1]CONCOTNAM = [F:COT]TPLNAM
  Endif
  #Qualification selon le modèle sélectionné.
  Call SELECTCOT ([M:CON1]CONCOT, "CON") From TRTCON9
  If [M:CONG]ITMREF <> "" Then
    Read [ITM]ITM0=[M:CONG]ITMREF
    If fstat Then
      [M:CONG]SAU = ""
    Else
      [M:CONG]SAU = [F:ITM]SAU
    Endif
  Endif
  GIPATCHAMCONCOT = 0
  GICON9OPGFLG = 0
  Affzo [M:CON1]CONCOT, CONCOTNAM
  Affzo [M:CONG]1-99
Return

##########################################################################################################
$AVANT_MOD
Return

##########################################################################################################
$BOITE
Local Char STRTSUB(GLONADC)

  # FGR 31/07/2014 : X3SUIVI101463
  STRTSUB = "SUBCON"
  Gosub BOITE_GOBJET From CRMUTIL150
Return

##########################################################################################################
$REDEFINE_LINK
  If !clalev([F:C_ON]) Then
    # FGR 11/02/2015 : X3SUIVI106120 : Si [C_ON] pas ouvert c'est que les browsers ont été redéfinis en SPE/SPV.
    # On part, c'est à ce niveau qu'on doit faire ce travail.
    Return
  Endif
  #---------------------------------------------------#
  # FGR 30/07/2014 : X3SUIVI101463
  Link [CON] With [C_ON]CON0=[F:CON]CONNUM,
&                 [AFF]AFF0~=[F:CON]SALFCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:CON]SALFCY
&              As [CO2_]
  Link [CON] With [C_ON]CON0=[F:CON]CONNUM,
&                 [AFF]AFF0~=[F:CON]SALFCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:CON]SALFCY
&              As [CO3_]
Return

##########################################################################################################
$OUVRE_BOITE
  #---------------------------------------------------#
  #Chargement des noms des cuurbox de chaque tiroir
  If OBJLIS(0) = "CON" Then
    GBOXCON= "GAU_CHE"
  Else
    GBOXCON = "GAU_CHE"+num$(find("CON",OBJLIS(1..8))) : #Contrats actifs
  Endif
  If OBJLIS(0) = "CO2" Then
    GBOXCO2= "GAU_CHE"
  Else
    GBOXCO2 = "GAU_CHE"+num$(find("CO2",OBJLIS(1..8))) : #Contrats à renouveler
  Endif
  If OBJLIS(0) = "CO3" Then
    GBOXCO3= "GAU_CHE"
  Else
    GBOXCO3 = "GAU_CHE"+num$(find("CO3",OBJLIS(1..8))) : #Contrats résiliés ou clôturés
  Endif
Return

##########################################################################################################
$OUVRE
Global Shortint GINVTYP        # FGR 11/07/2008 : X3SUIVI48011 : 1 = facture / 2 = avoir / 5 = proforma
Global Char GCCONCPT(GLONANM)  # Code compteur pour contrat
Global Integer GICONCREATION
Global Integer GISETFCOT
Global Integer GICURCHANGED
Global Integer GICON9OPGFLG
Global Decimal GIOLDAMOUNT
Global Char GSZVALEUR(250)      # Issue X3-77320 - 2018-03-30 by FGR
Global Char GCONINVNUM(GLONVCR) # FGR 16/06/2009 : X3SUIVI55856 GSZINVNUM renommée à cause GESSRE
Global Char GSZPCOCUR(GLONCUR)  # Issue X3-77320 - 2018-03-30 by FGR
Global Char GSZOLDCCUR(GLONCUR) # Issue X3-77320 - 2018-03-30 by FGR
Global Integer GIPATCHAMCONCOT
Global Char GBOXCON(10)
Global Char GBOXCO2(10)
Global Char GBOXCO3(10)
Local Char SZSITE(GLONFCY)


  #Contrôle des points
  If !GIMPORT Then
    Local Integer IERRINFPIT
    Local Integer ITSTPRONUM

    ITSTPRONUM = 0
    IERRINFPIT = 0
    Gosub EXECPIT From TRTPITGEN
  Endif
  If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif
  If !clalev ([F:TCA]): Local File TABCOUAFF [TCA] : Endif
  If !clalev([F:MAC]) : Local File MACHINES [MAC] : Endif
  If GMODU(2) = 2 Then
    #si module compta actif
    If !clalev([F:GCM]) : Local File GACM[GCM] : Endif
  Endif
  GSZPCOCUR = ""
  GSZVALEUR = ""
  GICONCREATION = 0
  GCONINVNUM = ""
  GISETFCOT = 0
  GICON9OPGFLG = 0
  GICURCHANGED = 0
  GSZOLDCCUR = ""
  GIOLDAMOUNT = 0
  GIPATCHAMCONCOT = 0
  Raz GSOC_ACTIVE
  SZSITE = ""
  Call SITECRMDEF ("HDK", SZSITE) From CRM_UTIL
  GFCY = SZSITE

  # X3-91735 (LCC-30/05/18) The value of GFMTDIE & GHEADIE variable is changed in SUBCON
  If GFONCTION1="GESSOH"
    Global Char SAVFMTDIE(15)(1..dim(GFMTDIE))
    Global Integer SAVGHEADIE: SAVGHEADIE=GHEADIE
    For X=1 To dim(GFMTDIE)
      SAVFMTDIE(X)=GFMTDIE(X)
    Next
  Endif
  # End X3-91735 (LCC-30/05/18) The value of GFMTDIE variable is changed in SUBCON
  Call GETCPY(GFCY,"",0,"") From TRTX3CPT


  GHEADIE = 1  # FGR 19/03/2010 : X3SUIVI63222 : Pas de transaction sur les contrats. Donc Axes tj saisissables
  #---- Chargement de GCUR
  Call CHARGE_GCUR() From TRTX3
  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  Read [TCA]TCA0=12
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(0)
  #  GCCONCPT = [F:TCA]CODNUM(0)
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
  #Renouvellement des garanties à tacite reconduction
  If !GIMPORT Then
    Call REWWARRANTY From SUBCONB2
  Endif
  If !GIMPORT Then
    If ITSTPRONUM Then
      #Le contrôle de cohérence des points a échoué.
      GMESSAGE = mess(634,182,1)
      GERR = 2
    Endif
  Endif
  Gosub CHARG_PARAM # FGR 26/07/2013 : X3SUIVI87923 (fin)
Return

##########################################################################################################
$FERME
  #Met à jour le contrat sélectionné sur la demande de service
  If !GIMPORT Then
    If GPILNAV > 1 Then
      If GNAVIG(GPILNAV-1) = "GESSRE" Then
        Gosub SELECTCON From SUBSREB3
      Endif
    Endif
  Endif
  Kill GCCONCPT
  Kill GICONCREATION
  Kill GSZVALEUR
  Kill GCONINVNUM
  Kill GISETFCOT
  Kill GSZPCOCUR
  Kill GICURCHANGED
  Kill GSZOLDCCUR
  Kill GIOLDAMOUNT
  Kill GICON9OPGFLG
  Kill GIPATCHAMCONCOT
  If dim(GBOXCON) > 0 Then
    Kill GBOXCON
    Kill GBOXCO2
    Kill GBOXCO3
  Endif

  # X3-91735 (LCC-30/05/18) The value of GFMTDIE & GHEADIE  variables is changed in SUBCON
  If GFONCTION1="GESSOH"
    GHEADIE=SAVGHEADIE
    For X=1 To dim(GFMTDIE)
      GFMTDIE(X)=SAVFMTDIE(X)
    Next
    Kill SAVGHEADIE
    Kill SAVFMTDIE
  Endif
  # End X3-91735 (LCC-30/05/18) The value of GFMTDIE & GHEADIE variables is changed in SUBCON

Return

##########################################################################################################
$SETBOUT
  If REP = "" Then
    # FGR 17/10/2011 : X3SUIVI71278 Traçabilité des pièces "T"
    CHMEN += "T"
    #Couverture article
    If [M:CON1]EVRMAC <> 2 Then
      CHMEN += "G"
    Endif
    #Compétences couvertes
    If [M:CON1]EVRPBL <> 2 Then
      CHMEN += "I"
    Endif
    #Plan d'entretien
    If [M:CON1]CONCAT = 2 Then
      CHMEN += "O"
    Endif
    #Renouvellement du contrat
    If [M:CON0]DSYWND = 2 or [M:CON0]DSYWND = 4 Then
      If [M:CON4]CONREW <> 2 Then
        If [M:CON1]CONCAT <> 4 Then
          CHMEN += "Q"
        Endif
      Endif
    Endif
    #Contraintes qualités
    CHMEN += "N"
  Endif
  Call VIREBOUT(CHAINE,"H") From GOBJET
  # FGR 08/07/2008 : X3SUIVI48011 (DEBUT)
  If GREP <> "" Then
    # Si on n'est pas en consultation le bouton "Facture" est grisé
    Call VIREBOUT(CHAINE, "Y") From GOBJET
  # FGR 21/11/2013 : X3SUIVI94039 (début) Test incomplet au niveau de la résiliation
#  Elsif not (   [F:CON]NEXSHIINV <= datesyst
#&           and [F:CON]NEXINVDAT <> [00/00/00]
#&           and [F:CON]RSIFLG <> 2
#&           and [F:CON]FDDFLG <> 2
#&           and [F:CON]CONCAT <> 1
#&           and [F:CON]CONAMT > 0
#&           and [F:CON]ITMREF <> ""
#&           )
#& Then
# Issue SAM120356 - 2017-01-09 by FGR add : 'and [F:CON]NEXINVDAT >= [F:CON]CONENDDAT'
#  Elsif not (   [F:CON]NEXSHIINV <= datesyst
#&           and [F:CON]NEXINVDAT <> [00/00/00]
#&           and (([F:CON]RSIFLG<>2) or ([F:CON]RSIFLG=2 and [F:CON]NEXINVDAT<[F:CON]RSIDAT))
#&           and [F:CON]FDDFLG <> 2
#&           and [F:CON]CONCAT <> 1
#&           and [F:CON]CONAMT > 0
#&           and [F:CON]ITMREF <> ""
#&           )
#& Then
  Elsif not (   [F:CON]NEXSHIINV <= datesyst
&           and [F:CON]NEXINVDAT <> [00/00/00]
&           and [F:CON]NEXINVDAT <= [F:CON]CONENDDAT
&           and (([F:CON]RSIFLG<>2) or ([F:CON]RSIFLG=2 and [F:CON]NEXINVDAT<[F:CON]RSIDAT))
&           and [F:CON]FDDFLG <> 2
&           and [F:CON]CONCAT <> 1
&           and [F:CON]CONAMT > 0
&           and [F:CON]ITMREF <> ""
&           )
& Then
  # FGR 21/11/2013 : X3SUIVI94039 (fin)
    # Si la contrat de service n'est pas facturable le bouton "Facture" est grisé
    # Note pour moi : Le premier critère de la liste de picking est [F:CON]NEXSHIINV <= [M]INVDAT
    # [M]INVDAT est alimenté par "datesyst"
    # Je reproduits ça ici, mais je suis perplexe dans ce contexte !
    Call VIREBOUT(CHAINE, "Y") From GOBJET
  Endif
  # FGR 08/07/2008 : X3SUIVI48011 (FIN)

  #85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
  If func AFNC.ACTIV("KPO")
    Local Char    LSIVTIP(30) : [L]LSIVTIP=''
    Call PARAML([M:CON0]SALFCY,"SIVTYP",[L]LSIVTIP) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
    If func PORLEGLIB.VAL_SIMINV([L]LSIVTIP) = 2
      Call VIREBOUT(CHAINE,"Y") From GOBJET
    Endif
  Endif
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END

Return

##########################################################################################################
$RAZDUP
  GIPATCHAMCONCOT = 0
  Raz [M:CON2]
  Raz [M:CON5]
  Raz [M:CON1]CONCOT
  Raz [M:CON1]CONCOTNAM
  Raz [M:CON4]LASVALIDX
  Raz [M:CON4]LASIDXDAT
  Raz [M:CON4]RVADAT
  [M:CON4]SIUDAT = date$
  [M:CON4]CONSTRDAT = date$
  Call SETENDDAT([M:CON4]CONSTRDAT, [M:CON4]REWFRY, [M:CON4]REWFRYBAS, [M:CON4]CONENDDAT) From SUBCOND
  [M:CON1]CONORI = 6
  [M:CON1]CONORIVCR = [M:CON0]CONNUM
  [M:CON1]CONORIVCRL = 0
  #Modele de contrat
  Actzo  [M:CON1]CONCOT
  Affzo [M:CON1]1-99
  Affzo [M:CON4]1-99
  Affzo [M:CON2]1-99
  Affzo [M:CON5]1-99
Return

##########################################################################################################
$RAZCRE
  #On initialise le site
  Call SITECRMDEF("HDK", [M:CON0]SALFCY) From CRM_UTIL
  Call SITECRMREP("HDK", [M:CON1]SALREP, [M:CON0]SALFCY) From CRM_UTIL
  GFCY = [M:CON0]SALFCY
  Call GETCPY(GFCY,"",0,"") From TRTX3CPT
  GHEADIE = 1  # FGR 19/03/2010 : X3SUIVI63222 : Pas de transaction sur les contrats. Donc Axes tj saisissables
  GIPATCHAMCONCOT = 0
  GICURCHANGED = 0
  GSZOLDCCUR = [M:CON0]CUR
  GIOLDAMOUNT = 0
  [M:CON0]CUR = GCUR
  #Origine
  [M:CON1]CONORITYP = ""
  [M:CON1]CONORI = 1
  Diszo [M:CON1]CONORIVCR
  #Code client issu de la navigation
  If [M:CON0]CONBPC <> "" Then
    # FGR 07/04/2015 : X3SUIVI107457 (début)
    Local Char SVALEUR(type([M:CON0]CONBPC)-10)

    SVALEUR = [M:CON0]CONBPC
    Call AM_CONBPC(SVALEUR) From W1CON0
    # FGR 07/04/2015 : X3SUIVI107457 (fin)
    Read [BPC]BPC0=[M:CON0]CONBPC
    If fstat Then  # FGR 24/10/2011 : X3SUIVI77225
      [M:CON0]CONBPC = ""
    Else
      If [F:BPC]BPCTYP = 4 Then
        [M:CON0]CONBPC = ""
      Endif
      If [F:BPC]CUR <> ""  Then
        [M:CON0]CUR = [F:BPC]CUR
        IBCUROK = 1
      Endif
    Endif
    Read [BPR]BPR0=[M:CON0]CONBPC
  Endif
  # FGR 30/06/2008 : X3SUIVI48128 : GSZMACNUMRULE n'existe que si le contrat est créé de façon indirecte
  If dim(GSZMACNUMRULE) > 0 Then
    # FGR 16/06/2008 X3SUIVI48039 : retirer le test GIMPORT
    If GSZMACNUMRULE <> "" Then
      Read [MAC]MAC0=GSZMACNUMRULE
      If fstat Then
        # La machine n'existe pas on passe par le standard
        Raz [F:MAC]
        Gosub STDRAZCRE From SUBCONB2
      Else
        #Création assistée d'un contrat de garantie pour la fiche parc origine
        Gosub SETWTYDEF From SUBCONB2
      Endif
    Else
      Gosub STDRAZCRE From SUBCONB2
    Endif
  Else
    # FGR 27/08/2008 : X3SUIVI48780 : Suite a X3SUIVI48128, le STDRAZCRE n'était plus déclenché
    Gosub STDRAZCRE From SUBCONB2
  Endif
  If [M:CON0]CONBPC <> "" Then
    Call SETINVINF([M:CON0]CONBPC) From SUBCONB1
  Endif
  If [M:CON0]SALFCY <> "" Then
    #Déduit le code société
    Read [FCY]FCY0=[M:CON0]SALFCY
    If !fstat Then
      [M:CON0]CPY = [F:FCY]LEGCPY
    Endif
  Endif
  GFCY = [M:CON0]SALFCY
  Call GETCPY(GFCY,"",0,"") From TRTX3CPT
  Gosub CHARG_PARAM # FGR 26/07/2013 : X3SUIVI87923 (fin)
  # V6.2 : Certification
  # --- Contrôle date documents
  Call LOAD_GCTLDATORI() From CRMUTIL150  # FGR 25/01/2012 : X3SUIVI78765
  #Local  Char     PARAM(GLONADP)
  #Call PARAM(GFCY,"CTLDATORI",PARAM)    From ADOVAL
  #GCTLDATORI=val(PARAM)  : If GCTLDATORI=0   GCTLDATORI=2  : Endif

  GHEADIE = 1  # FGR 19/03/2010 : X3SUIVI63222 : Pas de transaction sur les contrats. Donc Axes tj saisissables
  [M:CON0]OLDCRSCOV = [M:CON1]CRSCOVSAM
  [M:CON0]OLDEVRMAC = [M:CON1]EVRMAC
  [M:CON0]OLDEVRPBL = [M:CON1]EVRPBL
  [M:CON4]CONCUR3 = [M:CON0]CUR
  [M:CON2]CONCUR4 = [M:CON0]CUR
  If [M:CON0]CONBPC <> "" Then
    #Définit l'interlocuteur par défaut du contrat
    If [M:CON0]CONCCN = "" Then
      Call GETDEFCNT([M:CON0]CONBPC, [M:CON0]CONCCN) From CRMUTIL140
    Endif
  Endif
  #Affichage de l'interlocuteur
  Gosub DISPCCN From SUBCONB2
  #
  [M:CON5]PRERSIFLG = [M:CON5]RSIFLG
  [M:CON5]PREFDDFLG = [M:CON5]FDDFLG
  #Modele de contrat
  Actzo [M:CON1]CONCOT
  Affzo [M:CON0]1-99
  Affzo [M:CON1]1-99
  Affzo [M:CON2]1-99
  Affzo [M:CON4]1-99
  Affzo [M:CON5]1-99
  Affzo [M:CON8]1-99
  Affzo [M:CONG]1-99
Return

##########################################################################################################
$FILGAUCHE
  Default File [CON]
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESSRE" Then
      If type(GSZSRECON) > 0 Then
        If GSZSRECON <> "" Then
          Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", "CONBPC = [M:SRE0]SREBPC", "&") From GOBJSUB
          Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "CONBPC = [M:SRE0]SREBPC", "&") From GOBJSUB
        Endif
      Endif
    Endif
  Endif
  If currbox = GBOXCON Then
    #Contrats de services actifs
    Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", "(DSYWND = 1 or DSYWND = 4)", "&") From GOBJSUB
  Elsif currbox = GBOXCO2 Then
    #Contrats de services à renouveler
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "(DSYWND = 2 or DSYWND = 4)", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "CON") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Elsif currbox = GBOXCO3 Then
    #Contrats de services résiliés ou archivés
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "(DSYWND = 3)", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "CON") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Endif
Return

##########################################################################################################
$LIENS
Local Integer TESTNBLIG
Local Integer I
Local Integer INB

  GICURCHANGED = 0
  GSZOLDCCUR = [M:CON0]CUR
  GIOLDAMOUNT = [M:CON4]CONAMT
  [M:CON0]OLDCRSCOV = [M:CON1]CRSCOVSAM
  [M:CON0]OLDEVRMAC = [M:CON1]EVRMAC
  [M:CON0]OLDEVRPBL = [M:CON1]EVRPBL
  If GFCY<>[M:CON0]SALFCY Then
    GFCY = [M:CON0]SALFCY

#  #X3-91735 (LCC-30/05/18) The value of GFMTDIE variable is changed in SUBCON
#  If GFONCTION1="GESSOH"
#    Local Char SAVFMTDIE(15)(1..dim(GFMTDIE))
#    For X=1 To dim(GFMTDIE)
#      SAVFMTDIE(X)=GFMTDIE(X)
#    Next
#  Endif
#  # End X3-91735 (LCC-30/05/18) The value of GFMTDIE variable is changed in SUBCON

  Call GETCPY(GFCY,"",0,"") From TRTX3CPT

#  #X3-91735 (LCC-30/05/18) The value of GFMTDIE variable is changed in SUBCON
#  If GFONCTION1="GESSOH"
#    For X=1 To dim(GFMTDIE)
#      GFMTDIE(X)=SAVFMTDIE(X)
#    Next
#  Endif
#  # End X3-91735 (LCC-30/05/18) The value of GFMTDIE variable is changed in SUBCON

    Gosub CHARG_PARAM # FGR 26/07/2013 : X3SUIVI87923 (fin)
    # V6.2 : Certification
    # --- Contrôle date documents
    Call LOAD_GCTLDATORI() From CRMUTIL150  # FGR 25/01/2012 : X3SUIVI78765
    #Local  Char     PARAM(GLONADP)
    #Call PARAM(GFCY,"CTLDATORI",PARAM)    From ADOVAL
    #GCTLDATORI=val(PARAM)  : If GCTLDATORI=0   GCTLDATORI=2  : Endif
    GHEADIE = 1  # FGR 19/03/2010 : X3SUIVI63222 : Pas de transaction sur les contrats. Donc Axes tj saisissables
  Endif
  Call CHARG_CCEH("CON8", "NBAXE", "CON") From TRTX3CPT
  #Nouveaux champs V140
  If [M:CON4]RVAMET = 0 Then
    [M:CON4]RVAMET = 1
  Endif
  If [M:CON4]RVASSP = 0 Then
    [M:CON4]RVASSP = 1
  Endif
  If [M:CON8]INVMET = 0 Then
    [M:CON8]INVMET = 1
  Endif
  #---------------------------------------------------#
  #  Origine
  #---------------------------------------------------#
  If [M:CON1]CONORI = 0 Then
    [M:CON1]CONORI = 1
  Endif
  #Définition du type de pièce
  Case [M:CON1]CONORI
    When 1
      [M:CON1]CONORITYP = ""
    When 2
      [M:CON1]CONORITYP = "SOH"
    When 3
      [M:CON1]CONORITYP = "SDH"
    When 4
      [M:CON1]CONORITYP = "SIH"
    When 5
      [M:CON1]CONORITYP = "RQW"
    When Default
      [M:CON1]CONORITYP = ""
  Endcase
  Diszo [M:CON1]CONORIVCR
  #---------------------------------------------------#
  #  Modèle
  #---------------------------------------------------#
  If [M:CON1]CONCOT = "" Then
    [M:CON1]CONCOTNAM = ""
  Else
    Read [COT]COT0=[M:CON1]CONCOT
    If fstat Then
      [M:CON1]CONCOTNAM = ""
    Else
      [M:CON1]CONCOTNAM = [F:COT]TPLNAM
    Endif
  Endif
  #---------------------------------------------------#
  # Eléments de facturation
  #---------------------------------------------------#
  #Sections analytiques
  #---- nb de lignes dans tableau des axes analytiques
  If dim([M:CON8]NBAXE) > 0 Then
    If [M:CON8]NBAXE = 0 Then
      [M:CON8]NBAXE = GOPTCANA
    Endif
  Endif
  #Eléments de facturation
  If [M:CON1]CONCAT <> 1 Then
    Gosub CON_FOOT From SUBCONB1
  Endif
  #Unité de vente du contrat
  If [M:CONG]ITMREF = "" Then
    [M:CONG]SAU = ""
  Else
    Read [ITM]ITM0=[M:CONG]ITMREF
    If fstat Then
      [M:CONG]SAU = ""
    Else
      [M:CONG]SAU = [F:ITM]SAU
    Endif
  Endif
  #---------------------------------------------------#
  #  Remplit les tableaux
  #---------------------------------------------------#
  TESTNBLIG = 0
  INB = 0
  GISETFCOT = 0
  # Chargement du tableau des litiges acceptés
  TESTNBLIG = 0
  For I = 0 To dim([F:CON]ACPDPTCOD)-1
    If [M:CON8]ACPDPTCOD(I) = "" Then
      Break
    Endif
    TESTNBLIG += 1
  Next
  [M:CON8]NBDPT = TESTNBLIG
  # Chargement du tableau des factures
  Call LOADINV(INB) From SUBCONB1
  If INB > 0 Then
    GCONINVNUM = [M:CON2]INVVCR(0)
    Call LOADECHE([M:CON2]INVVCR(0)) From SUBCONB1
  Else
    GCONINVNUM = ""
  Endif
  # Chargement du relevé des points
  Call LOADPIT([M:CON0]CONNUM, 1) From SUBCONB2
  # Chargement du tableau des bases annuelles
  Call LOADAMT From SUBCONB1
  # Chargement du tableau des renouvellements
  Call LOADREW From SUBCONB1
  # Chargement de l'archiveur
  If [M:CON5]FDDUSR <> "" Then
    Read [AUS]CODUSR=[M:CON5]FDDUSR
    If fstat
      [M:CON5]FDDUSRCLA = ""
    Else
      [M:CON5]FDDUSRCLA = [F:AUS]NOMUSR
    Endif
  Endif
  #Affiche les devises
  [M:CON4]CONCUR3 = [M:CON0]CUR
  [M:CON2]CONCUR4 = [M:CON0]CUR
  #Sauvegarde données courant
  [M:CON0]CPYINI=[M:CON0]CPY
  [M:CON0]SALFCYINI=[M:CON0]SALFCY
  [M:CON0]CONBPCINI=[M:CON0]CONBPC
  [M:CON4]CONSTRDATI=[M:CON4]CONSTRDAT
  Call SETGRAY From SUBCONB1
  [M:CON5]PRERSIFLG = [M:CON5]RSIFLG
  [M:CON5]PREFDDFLG = [M:CON5]FDDFLG
  #Affichage de l'interlocuteur
  Gosub DISPCCN From SUBCONB2
  # --------------------------------------
  # FGR 02/05/2016 : X3SUIVI116347 (début)
  Diszo [M:CON0]CPY
  Diszo [M:CON0]SALFCY
  Diszo [M:CON0]CONBPC
  # FGR 02/05/2016 : X3SUIVI116347 (fin)
  # --------------------------------------
  Affzo [M:CON0]1-99
  #Modele de contrat
  Grizo [M:CON1]CONCOT
  # Call SET_GLOCUSATAX([M:CON0]CPY)  From TRTADRLIB   # 106867.o
  Call LEC_CPY(GSOCIETE) From CPTLEC   # 106867.n
  Gosub SHOW_HIDE_ENTCOD From TRTADRLIB   # 106867.n
  # 101380 - Show/Hide SST fields as needed
  Call SETUP_SSTFIELDS
Return

##########################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  Call READ_COUNTER([M:CON0]SALFCY, 12, 0, [M:CON0]CPY, GCURLEG, GCCONCPT, GMANCOU) From CRM_UTIL  # FGR 20/05/2015 : X3SUIVI107775
  # Récupération du compteur de contrat de service.
  If func CRM_UTIL.GET_NUMERO_CHRONO ("HDK", [M:CON0]SALFCY, GCCONCPT, date$, "", [M:CON0]CONNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 1 Then
      [F:CON]CONNUM = [M:CON0]CONNUM  # FGR 23/07/2009 : X3SUIVI56676  [M:CON0]CONNUM = [M:CON0]CONNUM
      Affzo [M:CON0]CONNUM
    Else
      # problème lors de la récupération du compteur
      GERR = 1
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
$CREATION
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  IBRETOUR = 1
  #Enregistrement des données pour les encours
  Gosub GERE_LCM_CREATION From SUBCONB3
  If GOK < 1 Then
    Return
  Endif
  # Maj des statistiques
  Call VALSTA("CON",1) From SUBPS2
Return

##########################################################################################################
$MODIF
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  IBRETOUR = 1
  #Enregistrement des données pour les encours
  Gosub GERE_LCM_MODIF From SUBCONB3
  If GOK < 1 Then
     Return
  Endif
  # Maj des statistiques
  Call VALSTA("CON",-1) From SUBPS2
  Call VALSTA("CON",1) From SUBPS2
Return

##########################################################################################################
$ANNULE
  # Maj des statistiques
  Call VALSTA("CON",-1) From SUBPS2
Return

##########################################################################################################
$APRES_ANNULE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  # FGR 12/08/2009 : X3SUIVI57005 : Pour le moment, il n'y a que là qu'on peut le mettre
  #                  Le pb c'est que ça n'est pas dans la transaction, donc si ça échoue,
  #                  L'enregistrement sera détruit, mais le Dernier ne sera pas forcément à jour
  #Enregistrement des données pour les encours
  Gosub GERE_LCM_ANNULE From SUBCONB3
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$APRES_CRE
  #Chargement du relevé des points
  Call LOADPIT([M:CON0]CONNUM, 1) From SUBCONB2
  GICONCREATION = 0
  #Définit les articles couverts et les familles de compétence si le contrat a été initialisé via un modèle de contrat
  If GISETFCOT Then
    Call LOADPBLMAC ([M:CON1]CONCOT) From TRTCON9
    Call LOADTQUAL ([M:CON1]CONCOT) From TRTCON9
    Call LOADPCARE ([M:CON1]CONCOT) From TRTCON9
    GISETFCOT = 0
  Endif
  GIPATCHAMCONCOT = 0
  GICURCHANGED = 0
  GSZOLDCCUR = [M:CON0]CUR
  GIOLDAMOUNT = [M:CON4]CONAMT
  [M:CON0]COVLOWLEV = 0
  [M:CON0]OLDCRSCOV = [M:CON1]CRSCOVSAM
  [M:CON0]OLDEVRMAC = [M:CON1]EVRMAC
  [M:CON0]OLDEVRPBL = [M:CON1]EVRPBL
  [M:CON5]PRERSIFLG = [M:CON5]RSIFLG
  [M:CON5]PREFDDFLG = [M:CON5]FDDFLG
  #Sauvegarde données courant
  [M:CON0]CPYINI=[M:CON0]CPY
  [M:CON0]SALFCYINI=[M:CON0]SALFCY
  [M:CON0]CONBPCINI=[M:CON0]CONBPC
  [M:CON4]CONSTRDATI=[M:CON4]CONSTRDAT
  Call SETTZN From SUBCONB2
  [M:CON4]FLGUPDDAT=0
  #Modele de contrat
  Grizo [M:CON1]CONCOT
  Affzo [M:CON2]1-99
  Affzo [M:CON4]1-99
Return

##########################################################################################################
$APRES_MOD
  #Chargement du relevé des points
  Call LOADPIT([M:CON0]CONNUM, 1) From SUBCONB2
  #Définit les articles couverts et les familles de compétence si le contrat a été initialisé via un modèle de contrat
  If GISETFCOT Then
    Call LOADPBLMAC ([M:CON1]CONCOT) From TRTCON9
    Call LOADTQUAL ([M:CON1]CONCOT) From TRTCON9
    Call LOADPCARE ([M:CON1]CONCOT) From TRTCON9
    GISETFCOT = 0
  Endif
  #Gère la modification de la devise du contrat
  Call MNGCONCURCHG From SUBCONB1
  GIPATCHAMCONCOT = 0
  GICURCHANGED = 0
  GSZOLDCCUR = [M:CON0]CUR
  GIOLDAMOUNT = [M:CON4]CONAMT
  [M:CON0]COVLOWLEV = 0
  [M:CON0]OLDCRSCOV = [M:CON1]CRSCOVSAM
  [M:CON0]OLDEVRMAC = [M:CON1]EVRMAC
  [M:CON0]OLDEVRPBL = [M:CON1]EVRPBL
  [M:CON5]PRERSIFLG = [M:CON5]RSIFLG
  [M:CON5]PREFDDFLG = [M:CON5]FDDFLG
  [M:CON4]FLGUPDDAT = 0
  #Sauvegarde données courant
  [M:CON0]CPYINI = [M:CON0]CPY
  [M:CON0]SALFCYINI = [M:CON0]SALFCY
  [M:CON0]CONBPCINI = [M:CON0]CONBPC
  [M:CON4]CONSTRDATI = [M:CON4]CONSTRDAT
  Call SETTZN From SUBCONB2
  Affzo [M:CON2]1-99
  Affzo [M:CON4]1-99
Return

##########################################################################################################
$STATUT
Return

##########################################################################################################
$VERIF_CRE_MOD
Local Integer IBRETOUR
Local Integer IREPONSE
Local Integer ITERSTT

  IBRETOUR = 1
  IREPONSE = 2
  If [M:CON0]CONBPC = "" Then
    #Un code client doit obligatoirement être mentionné sur le contrat. Création refusée.
    GMESSAGE = mess(175,177,1)
    GERR = 2
    OK = 0
    Return
  Endif
  If [M:CON1]CONCAT <> 1 Then
    # FGR 10/04/2009 : X3SUIVI53935
    If GDEFCONITM <> "" and [M:CONG]ITMREF = "" Then
      [M:CONG]ITMREF = GDEFCONITM
    Endif
    If [M:CONG]ITMREF = "" Then
      #Un code article doit obligatoirement être mentionné sur le contrat. Création refusée.
      GMESSAGE = mess(637,182,1)
      GERR = 2
      OK = 0
      Return
    Endif
  Endif
  #Les familles statistiques sont-elles obligatoires
  If GCONTSIOBY = 2 Then
    For ITERSTT = 0 To dim([M:CON1]CONTYP)-1
      If [M:CON1]CONTYP(ITERSTT) = "" Then
        #Les familles statistiques du contrat de service sont obligatoires. Elles doivent être renseignées.
        GMESSAGE = mess(393,182,1)
        GERR = 2
        OK = 0
        Break
      Endif
    Next
    If OK = 0 Then
      Return
    Endif
  Endif
  If [M:CON4]SIUDAT = [00/00/00] Then
    [M:CON4]SIUDAT = date$
  Endif
  If [M:CON0]SALFCY = "" Then
    #Un site de vente doit obligatoirement être mentionné. Création refusée.
    GMESSAGE = mess(353,196,1)
    GERR = 2
    OK = 0
    Return
  Endif
  #LSE 07/10/2005 bug 32480
  #Verifie que société et site sont compatible
  Read [FCY]FCY0=[M:CON0]SALFCY
  If fstat Then
    GMESSAGE = mess(83,123,1) #Valeur incorrect.
    GERR = 2
    OK = 0
    Return
  Else
    If [F:FCY]LEGCPY <> [M:CON0]CPY Then
      #Le site n'est pas sur la même société juridique
      GMESSAGE = mess(2,194,1)
      GERR = 2
      OK = 0
      Return
    Endif
  Endif
  #LSE 12/01/2006 FQ 34194 Nouveaux contrôle
  #Vérifie que la date de début est saisi
  If [M:CON4]CONSTRDAT = [00/00/00] Then
    #La date de début n'a pas été précisée.
    GMESSAGE = mess(217,177,1)
    GERR = 2
    OK = 0
    Return
  Endif
  #Vérifie si une fréquence de renouvellement a été renseignée
  If [M:CON4]REWFRY < 1 Then
    #Aucune fréquence de renouvellement n'a été saisie. Création refusée.
    If ACTION  = "VERIF_CRE" Then
      GMESSAGE = mess(452,196,1)
    Else
      GMESSAGE = mess(453,196,1)
    Endif
    GERR = 2
    OK = 0
    Return
  Endif
  If [M:CON4]REWFRY > 0 Then
    If [M:CON4]REWFRYBAS = 6 Then
      #Aucune base de fréquence de renouvellement n'a été saisie. Création refusée.
      If ACTION  = "VERIF_CRE" Then
        GMESSAGE = mess(641,182,1)
      Else
        GMESSAGE = mess(642,182,1)
      Endif
      GERR = 2
      OK = 0
      Return
    Endif
  Endif
  #Vérifie si la durée du contrat est supérieure à une journée
  If [M:CON4]REWFRYBAS = 2 Then
    If [M:CON4]REWFRY <= 1 Then
      #La fréquence de renouvellement du contrat doit être supérieure à une journée.
      GMESSAGE = mess(60,177,1)
      GERR = 2
      OK = 0
      Return
    Endif
  Endif
  #LSE 12/01/2006 FQ 34194 Nouveaux contrôle
  If  [M:CON4]CONENDDAT =[00/00/00] Then
    #La date de fin n'a pas été précisée.
    GMESSAGE = mess(98,177,1)
    GERR = 2
    OK = 0
    Return
  Endif
  #LSE 12/01/2006 FQ 34194 Nouveaux contrôle
  #Vérifie que la date de fin est inférieur à la date de début
  If [M:CON4]CONENDDAT < [M:CON4]CONSTRDAT Then
    #La date de fin ne doit pas être inférieure à la date de début.
    GMESSAGE = mess(99,177,1)
    GERR = 2
    OK = 0
    Return
  Endif
  #LSE 12/01/2006 FQ 34194 Nouveaux contrôle
  #Vérifie que la date souscription est inférieur à la date de fin
  If [M:CON4]CONENDDAT < [M:CON4]SIUDAT Then
    #La date de souscription doit être inférieure à la date de fin.
    GMESSAGE = mess(215,177,1)
    GERR = 2
    OK = 0
    Return
  Endif
  #LSE 12/01/2006 FQ 34194 Nouveaux contrôle
  #Verifie si si cohérence date début/date fin/Durée
  If ACTION  = "VERIF_CRE" or [M:CON4]FLGUPDDAT = 1 Then
    Call CTRLDATCON([M:CON4]CONSTRDAT, [M:CON4]REWFRY, [M:CON4]REWFRYBAS, [M:CON4]CONENDDAT,IBRETOUR) From SUBCOND
    If IBRETOUR = 0 Then
      #Non cohérence, on demande confirmation
      IREPONSE = 2
      #La date de fin ne correspond pas à une date de fin calculée. Voulez-vous continuer?
      Call OUINON (mess(216,177,1),IREPONSE) From GESECRAN
      If IREPONSE = 1 Then
        OK = 0
        Return
      Endif
    Endif
  Endif
  #Vérifie si une fréquence de facturation a été renseignée
  If [M:CON1]CONCAT > 1 Then
    If [M:CON1]CONCAT < 4 Then
      If [M:CON4]CONAMT > 0 Then
        If [M:CON8]INVFRY < 1 Then
          #Aucune fréquence de facturation n'a été saisie. Création refusée.
          If ACTION  = "VERIF_CRE" Then
            GMESSAGE = mess(639,182,1)
          Else
            GMESSAGE = mess(643,182,1)
          Endif
          GERR = 2
          OK = 0
          Return
        Endif
      Endif
    Endif
  Endif
  #Vérifie si une fréquence de facturation a été renseignée
  If [M:CON1]CONCAT > 1 Then
    If [M:CON1]CONCAT < 4 Then
      If [M:CON4]CONAMT > 0 Then
        If [M:CON8]INVFRY > 0 Then
          If [M:CON8]INVFRYBAS = 6 Then
            #Aucune base de fréquence de facturation n'a été précisée. Création refusée.
            If ACTION  = "VERIF_CRE" Then
              GMESSAGE = mess(640,182,1)
            Else
              GMESSAGE = mess(644,182,1)
            Endif
            GERR = 2
            OK = 0
            Return
          Endif
        Endif
      Endif
    Endif
  Endif
  #Vérifie la durée de la fréquence de facturation a été renseignée
  If [M:CON1]CONCAT > 1 Then
    If [M:CON1]CONCAT < 4 Then
      If [M:CON4]CONAMT > 0 Then
        If [M:CON8]INVFRYBAS = 2 Then
          If [M:CON8]INVFRY <= 1 Then
            #La fréquence de facturation du contrat doit être supérieure à une journée.
            GMESSAGE = mess(61,177,1)
            GERR = 2
            OK = 0
            Return
          Endif
        Endif
      Endif
    Endif
  Endif
  #Vérifie la durée de la fréquence de réévaluation a été renseignée
  If [M:CON1]CONCAT > 1 Then
    If [M:CON1]CONCAT < 4 Then
      If [M:CON4]CONAMT > 0 Then
        If [M:CON4]RVAFRYBAS = 2 Then
          If [M:CON4]RVAFRY <= 1 Then
            #La fréquence de réévaluation du contrat doit être supérieure à une journée.
            GMESSAGE = mess(62,177,1)
            GERR = 2
            OK = 0
            Return
          Endif
        Endif
      Endif
    Endif
  Endif
  #Vérifie la saisie des réévaluations
  If [M:CON1]CONCAT > 1 Then
    If [M:CON1]CONCAT < 4 Then
      If [M:CON4]CONAMT > 0 Then
        If [M:CON4]RVAFRY > 0 Then
          If [M:CON4]RVAFRYBAS > 1 Then
            If [M:CON4]RVAFRYBAS < 6 Then
              If [M:CON4]RVASSP = 1 Then
                If [M:CON4]CONBASIDX = "" Then
                  #Aucun indice n'a été précisé pour la réévaluation du contrat.
                  GMESSAGE = mess(63,177,1)
                  GERR = 2
                  OK = 0
                  Return
                Endif
                #LSE 10/02/2006 FQ34774
                If [M:CON4]LASVALIDX = 0 or [M:CON4]LASIDXDAT = [00/00/00] Then
                  #Dans le cas d'une réévaluation par indice, la dernière valeur utilisée et la date  doivent être renseignées.
                  GMESSAGE = mess(241,177,1)
                  GERR = 2
                  OK = 0
                  Return
                Endif
              Endif
              If [M:CON4]RVASSP = 2 Then
                If [M:CON4]CONBASFOR = "" Then
                  #Aucune formule n'a été précisée pour la réévaluation du contrat.
                  GMESSAGE = mess(64,177,1)
                  GERR = 2
                  OK = 0
                  Return
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  #Vérifie si une condition de paiement a été renseignée
  If [M:CON1]CONCAT > 1 Then
    If [M:CON4]CONAMT > 0 Then
      If [M:CON8]PTE = "" Then
        #Aucune condition de paiement n'a été précisée. Création refusée.
        If ACTION  = "VERIF_CRE" Then
          GMESSAGE = mess(47,177,1)
        Else
          GMESSAGE = mess(48,177,1)
        Endif
        GERR = 2
        OK = 0
        Return
      Endif
      #-- X3Suivi 71937 : Données par législation pour le Conditions de paiement
      Call CONTTPT([M:CON8]PTE, GCURLEG, '', '', '', '', '') From SUBTPT
      If mkstat Then
        GERR = 1
        OK = 0
        GMESSAGE = mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","CON8~PTE")+'"\'+GMESSAGE
        Return
      Endif
      # FGR 22/07/2013 : X3SUIVI87923 (début)
      Call CTRL_PTE_SEPA_SDD([M:CON8]PTE, [M:CON0]CPY, [M:CONG]CONBPCPYR) From TRTVENSDD
      If mkstat Then
        GERR = 1
        OK = 0
        GMESSAGE = mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","CON8~PTE")+'"\'+GMESSAGE
        Return
      Endif
      # FGR 22/07/2013 : X3SUIVI87923 (fin)
    Endif
  Endif
  #Vérifie si des points ont été crédités
  If [M:CON1]CONCAT = 4 Then
    If [M:CON4]PITCDT <= 0 Then
      #Aucun point n'a été crédité sur ce contrat. Création refusée.
      If ACTION  = "VERIF_CRE" Then
        GMESSAGE = mess(185,177,1)
      Else
        GMESSAGE = mess(186,177,1)
      Endif
      GERR = 2
      OK = 0
      Return
    Endif
  Endif
  # FGR 09/07/2014 : X3SUIVI101294 (début)
  If ACTION  = "VERIF_CRE" Then
    # On teste à la fin parce que lors de la saisie du client, le type de contrat n'est pas encore connu.
    If [F:BPC]BPCNUM <> [M:CON0]CONBPC Then
      Read [BPC]BPC0=[M:CON0]CONBPC
    Endif
    If [F:BPC]BPCSTA <> 2 Then
      # Si le client n'est pas actif
      If [M:CON1]CONCAT = 1 Then
        # Contrat de garantie
        If !clalev([M:MACW]) Then
          # Si on est en saisie directe (donc que n'est [M:MACW] pas ouvert) : la création est refusée
          GMESSAGE = [M:CON0]CONBPC - ":" - mess(4,119,1)
          GERR = 2
          OK = 0
          Return
        Else
          # Si on est en création depuis une pièce de vente, c'est autorisé, mais on met un message dans la trace
          If GTRACE <> "" Then
            Call ECR_TRACE ([M:CON0]CONBPC - ":" - mess(4,119,1) + "." - mess(671,177,1), 0) From GESECRAN
          Endif
        Endif
      Else
        # Les autres types de contrat : la création est toujours refusée
        GMESSAGE = [M:CON0]CONBPC - ":" - mess(4,119,1)
        GERR = 2
        OK = 0
        Return
      Endif
    Endif
  Endif
  # FGR 09/07/2014 : X3SUIVI101294 (fin)
  #Vérifie si la fréquence de facturation n'est pas supérieure à la fréquence de renouvellement.
  Gosub CHECKREWINV From SUBCONB2
  If !OK Then
    Return
  Endif
  # Issue X3-77320 - 2018-03-30 by FGR : BEGIN
  #--> Vérification que tous les axes entête ont bien été saisis (s'ils sont saisissables)
  If GHEADIE = 1 Then
    # Axes entêtes saisissables (Initialisé par GETCPY)
    If dim([M:CON8]NBAXE) > 0 Then
      For nolign = 1 To GNBDIE
        If [M:CON8]CCE(nolign-1) = AVOID.ACHAR and GOBLDIE(nolign) = [V]CST_AYES Then
          GERR = 1
          GMESSAGE = mess(177,199,1) - "(" + [M:CON8]DIE(nolign-1) + ")"
          OK = 0
          Break
        Endif
      Next nolign
    Endif
    If OK = 0
      Return
    Endif
  Endif
  # Issue X3-77320 - 2018-03-30 by FGR : END
Return

##########################################################################################################
$CONTRAT_POINT
  #Affecte la catégorie en clair
  [M:CON1]CONTYPCLA = mess([M:CON1]CONCAT,2976,1)
  #Les contrat à point sont toujours toutes compétences et tous articles
  If [M:CON1]CONCAT = 4 Then
    [M:CON1]EVRPBL = 2
    [M:CON1]EVRMAC = 2
  Endif
  #On clôture un contrat qui n'a plus de points consommables
  If [M:CON1]CONCAT = 4 Then
    If [M:CONG]PITBLC <= 0 Then
      If [M:CON5]FDDFLG <> 2 Then
        [M:CON5]FDDFLG = 2
        [M:CON5]FDDUSR = GUSER
        Read [AUS]CODUSR=[M:CON5]FDDUSR
        If fstat Then
          [M:CON5]FDDUSRCLA = ""
        Else
          [M:CON5]FDDUSRCLA = [F:AUS]NOMUSR
        Endif
        [M:CON5]RSIDAT = date$
        Affzo [M:CON5]1-99
      Endif
    Endif
  Endif
Return

##########################################################################################################
$VERIF_CRE
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    #On crédite les points
    [M:CONG]PITBLC = [M:CON4]PITCDT
  Endif
  Call CPTCONINF From SUBCONB1
  Gosub CONTRAT_POINT
Return

##########################################################################################################
$VERIF_MOD
Local Integer IDIFFERENT
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer IASKCRS

  IDIFFERENT = 0
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
  #Gestion de la modification de la couverture parc
  IASKCRS = 0
  If [M:CON0]OLDEVRMAC <> [M:CON1]EVRMAC Then
    If [M:CON1]EVRMAC = 2 Then
      If GIMPORT Then
        IASKCRS = 2
      Else
        #Confirmez-vous la suppression de toutes les descriptions de couverture relatives au parc client.
        Call OUINON(mess(434,182,1), IASKCRS) From GESECRAN
      Endif
      If IASKCRS = 2 Then
        #Vide le tableau de couverture article si le contrat devient de type "Toutes compétences"
        Call RAZPCOV("CON", [M:CON0]CONNUM, IERRINF, ICHAPTER, IBRETOUR) From TRTCONH
        If IBRETOUR = 0 Then
          GMESSAGE = mess(IERRINF,ICHAPTER,1)
          GERR = 1
          Return
        Endif
      Else
        OK = 0
        Return
      Endif
    Endif
  Endif
  #Gestion de la modification de la couverture compétence
  IASKCRS = 0
  If [M:CON0]OLDEVRPBL <> [M:CON1]EVRPBL Then
    If [M:CON1]EVRPBL = 2 Then
      If GIMPORT Then
        IASKCRS = 2
      Else
        #Confirmez-vous la suppression de toutes les descriptions de couverture relatives aux familles de compétence.
        Call OUINON(mess(435,182,1), IASKCRS) From GESECRAN
      Endif
      If IASKCRS = 2 Then
        #Vide le tableau des familles de compétences si le contrat devient de type "Toutes compétences"
        Call RAZPBL("CON", [M:CON0]CONNUM, IERRINF, ICHAPTER, IBRETOUR) From TRTCONH
        If IBRETOUR = 0 Then
          GMESSAGE = mess(IERRINF,ICHAPTER,1)
          GERR = 1
          Return
        Endif
      Else
        OK = 0
        Return
      Endif
    Endif
  Endif
  #Gestion de la couverture croisée identique.
  IASKCRS = 0
  If [M:CON0]OLDCRSCOV <> [M:CON1]CRSCOVSAM Then
    IDIFFERENT = 1
    If [M:CON0]OLDCRSCOV = 0 Then
      If [M:CON1]CRSCOVSAM = 1 Then
        IDIFFERENT = 0
      Endif
    Endif
    If [M:CON0]OLDCRSCOV = 1 Then
      If [M:CON1]CRSCOVSAM = 0 Then
        IDIFFERENT = 0
      Endif
    Endif
    If IDIFFERENT Then
      If [M:CON1]EVRMAC <> 2 Then
        If [M:CON1]CRSCOVSAM = 2 Then
          If GIMPORT Then
            IASKCRS = 2
          Else
            #Confirmez-vous la définition de toutes les couvertures croisées sur la base de la couverture du parc.
            Call OUINON(mess(433,182,1), IASKCRS) From GESECRAN
          Endif
          If IASKCRS = 2 Then
            IASKCRS = 0
            Call DOCRSCOVSAM([M:CON0]CONNUM, "", 1, IASKCRS) From TRTCONH
            If IASKCRS Then
              #Erreur lors de l'enregistrement de la couverture croisée à l'identique.
              GMESSAGE = mess(432,182,1)
              GERR = 1
            Endif
          Else
            OK = 0
            Return
          Endif
        Else
          #Suppression des couvertures croisées
          If GIMPORT Then
            IASKCRS = 0
          Else
            #Souhaitez-vous supprimer la définition des couvertures croisées de ce contrat ?
            Call OUINON(mess(46,177,1), IASKCRS) From GESECRAN
          Endif
          If IASKCRS = 2 Then
            IASKCRS = 0
            Call DELCRSCOVSAM([M:CON0]CONNUM, 1, IASKCRS) From TRTCONH
            If IASKCRS Then
              #Erreur lors de la suppression des couvertures croisées.
              GMESSAGE = mess(45,177,1)
              GERR = 1
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  Call CPTCONINF From SUBCONB1
  Gosub CONTRAT_POINT
Return

##########################################################################################################
$VERF_ANU
Local Integer IANNREP
Local Integer IVALINV

  # -------------------------------------
  # FGR 14/02/2014 : X3SUIVI96419 (début)
  Case [M:CON1]CONORI
    When 2, 3, 4, 5
      # Commande, Livraison, Facture, Demande de garantie
      GERR = 1
      GMESSAGE = mess(1142,196,1) - mess([M:CON1]CONORI,2977,1) - ":" - mess(1143,196,1)
      OK = 0
      Return
    When Default
  Endcase
  # FGR 14/02/2014 : X3SUIVI96419 (fin)
  # -------------------------------------
  # FGR 27/04/2009 : X3SUIVI54600 : Le test n'était pas assez complet
  If !clalev([F:SIDV]) Then
    Link [SID] With [F:SIV]SIV0=[F:SID]NUM As [SIDV] Where [F:SIV]SIHORI = 7 and [F:SID]CONNUM <> ""
  Endif
  IANNREP = 0
  #Vérifie si des factures validées sont associées au contrat à supprimer.
  #If !GIMPORT Then  # FGR 14/02/2014 : X3SUIVI96419 : Je ne vois pas pourquoi ça serait autorisé en import !
    IVALINV = 0
    Filter [SIDV] Where [F:SID]CONNUM = [M:CON0]CONNUM and [F:SIV]INVSTA = 3
    For [SIDV]
      IVALINV += 1
      Break
    Next
    Filter [SIDV]
    If IVALINV Then
      # FGR 03/07/2012 X3SUIVI83302
      GERR = 1
      GMESSAGE = mess(1088,196,1)
      OK = 0
      Return
    Else
      IVALINV = 0
      Filter [SIDV] Where [F:SID]CONNUM = [M:CON0]CONNUM and [F:SIV]INVSTA <> 3
      For [SIDV]
        IVALINV += 1
        Break
      Next
      Filter [SIDV]
      If IVALINV Then
        # FGR 03/07/2012 X3SUIVI83302
        GERR = 1
        GMESSAGE = mess(1089,196,1)
        OK = 0
        Return
      Endif
    Endif
  #Endif
Return

