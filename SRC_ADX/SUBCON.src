Subprog AS_CONCAT(VALEUR)
Variable Integer VALEUR

  # FGR 29/04/2008 : X3SUIVI 46864
  Raz GMENLOC
  # FGR 29/05/2008 : GMENLOC(2) = 1 est pour la V5. En V6 ça existe il ne faut pas virer l'option 2 du menu
  #GMENLOC(2) = 1
