##########################################################################################################
Subprog C_ACPDPTCOD(VALEUR)
Variable Char    VALEUR()

Local Integer I

  If VALEUR = "" Then
    mkstat = 2
  Endif
  #Vérifie si ce code litige n'a pas déjà été préalablement saisi dans ce tableau
  For I = 0 To dim ([M:CON8]ACPDPTCOD)-1
    If I <> nolign-1 Then
      If [M:CON8]ACPDPTCOD(I) = VALEUR and [M:CON8]ACPDPTCOD(I) <> "" Then
        VALEUR = ""
        mkstat = 2
        GMESSAGE = mess(437,196,1) #Ce code litige a déjà été saisi.
        GERR = 2
      Endif
    Endif
  Next
End

##########################################################################################################
Subprog AM_CONAMT(VALEUR)
Variable Decimal VALEUR

Local Decimal IARRVALEUR

  IARRVALEUR = arr(VALEUR, 10^-GDECPRI)
  VALEUR = IARRVALEUR
  GICURCHANGED = 1
  [M:CON4]CONAMT = VALEUR
End

##########################################################################################################
Subprog C_CONCOT(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    Read [COT]COT0=VALEUR
    If fstat Then
      #Cet identifiant ne correspond à aucun modèle de contrat enregistré.
      GMESSAGE = mess(354,182,1)
      GERR = 1
      mkstat = 2
    Else
      If !GIMPORT Then
        If [F:COT]CONCAT <> [M:CON1]CONCAT Then
          #La catégorie du modèle sélectionné ne correspond pas à la catégorie du contrat.
          GMESSAGE = mess(355,182,1)
          GERR = 1
          mkstat = 2
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AM_CONCOT(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    [M:CON1]CONCOTNAM = ""
  Else
    Read [COT]COT0=VALEUR
    If fstat Then
      [M:CON1]CONCOTNAM = ""
    Else
      [M:CON1]CONCOTNAM = [F:COT]TPLNAM
    Endif
    #Qualification selon le modèle sélectionné.
    If !GICON9OPGFLG Then
      Call SELECTCOT (VALEUR, "CONCOT") From TRTCON9
      #Ce contrat a été initialisé sur la base du modèle : XXXXX
      If !GIMPORT Then
        GMESSAGE = mess(356,182,1) - ':' - [F:COT]TPLNAM
        GERR = 3
      Endif
    Endif
    If !GIMPORT Then
      If [M:CONG]ITMREF <> "" Then
        Read [ITM]ITM0=[M:CONG]ITMREF
        If fstat Then
          [M:CONG]SAU = ""
        Else
          [M:CONG]SAU = [F:ITM]SAU
        Endif
      Endif
    Endif
  Endif
  [M:CON1]CONCOT = VALEUR
  GICON9OPGFLG = 0
  If GIMPORT Then
    GIPATCHAMCONCOT = 0
  Else
    If GREP = "" Then
      If [M:CON0]CONNUM = "" Then
        GIPATCHAMCONCOT = 0
      Else
        GIPATCHAMCONCOT = 1
      Endif
    Else
      GIPATCHAMCONCOT = 0
    Endif
  Endif
  Affzo [M:CON1]CONCOT, CONCOTNAM
  If !GIMPORT Then
    Affzo [M:CONG]1-99
  Endif
End

