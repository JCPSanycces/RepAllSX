#########################################################################
# 101380 - Setup SST Override related fields
#########################################################################
Subprog SETUP_SSTFIELDS

# If GLOCUSATAX & dim([M:CONG]SFISSTCOD)>0   # 106867.o
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 & dim([M:CONG]SFISSTCOD)>0   # 106867.n
  Chgfmt [M:CONG]SFISSTCOD  With "K:"   + num$(type([M:CONG]SFISSTCOD)-10)  + "B"     # Show enterable
  Affzo [M:CONG]SFISSTCOD
Else
  Chgfmt [M:CONG]SFISSTCOD  With "-K:"  + num$(type([M:CONG]SFISSTCOD)-10)  + "B"     # Hide
Endif

End

######################################################################################
Subprog AV_SFISSTCOD(VALEUR)
Variable Char    VALEUR()
#Do not alow updating of SST code for certain cases.
#See SUBSFIT for setting of override flag.
If [M:CONG]SFISSTOVRFLG(nolign-1)=1 : mkstat=2 : Endif
End


