#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque APWDCNTSYRA 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:01:35"
A_USER  = "DOC"
A_STAMP = "20181109230135"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask APWDCNTSYRA [PWDSYRA]
Gosub HORODAT
Local Inpbox "APWDCNTSYRA" From GFONCTION At A_STAMP With A_WINDPREV Mask [PWDSYRA] As [SIM_]
Grizo [PWDSYRA]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PWDSYRA]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=32 : X2(0)=81 : Y1(0)=12 : Y2(0)=16
Return

$ON_USER
Onevent CONTROL Call C_USER(zc) From W1APWDCNTSYRA
Return

Subprog C_USER(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "USER" : GZNUM = 190 : Endif
Gosub _AFF
End

$ON_PASSE
Onevent CONTROL Call C_PASSE(zc) From W1APWDCNTSYRA
Return

Subprog C_PASSE(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PASSE" : GZNUM = 967 : Endif
Gosub _AFF
End

$CHG_STY
Return


