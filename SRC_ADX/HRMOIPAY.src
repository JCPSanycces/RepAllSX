#<AdxTL>@(#)8.0.0.0 $Revision$ Modification du mois de paye
#################################################################################
# Modification SEGAY - 01/06/11 - BUG 74187
#        Ne pas faire afficher dans la trace les salariés
#        auquels l'utilisateur n'a pas le droit d'accès
#################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
GACTION = "MOIPAY"
Call TRAITE_CHAR(VALEUR,PARAM,"","HRMOIPAY","MOIPAY",3,"") From GTRAITE
End

$ACTION
Case GACTION
 When "MOIPAY"
  Case ACTION
   When "INIT"        : Gosub INIT
   When "INIT_DIA"    : Gosub INIT_DIA
   When "EXEC"        : Gosub EXEC
   When "SORTIE"      : Gosub SORTIE
  Endcase
 When "VERFPAY"
  Case ACTION
   When "INIT"
    If VALEUR=GMOIPAY : FIN = 1 : Return : Endif
    TIT = mess(38,10702,1) : # Vérification des payes
   When "CONTROLE" : TRA = 1 : TMP = 1
   When "EXEC"     : Call VERIF_PAYE
  Endcase
Endcase
Return

$INIT
Lock MOIPAY
If fstat
 Call ERREUR(mess(30,100,1)) From GESECRAN : # Fonction en cours sur autre poste
Endif
If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
##64942
If clalev([F:ADU])=0 : Local File ADOVALAUS [ADU] : Endif
Return

$SORTIE
Unlock MOIPAY
Return

$INIT_DIA
Local Char VALPAR(10) , PARCOD(10)
Onerrgo RIEN
[M:DIA]MOIPAY = gdat$(func DIVPAYE.INIPARUSR("MOIPAY","",""))
[M:DIA]DEBPAY = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
[M:DIA]FINPAY = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))
[M:DIA]DATREG = gdat$(func DIVPAYE.INIPARUSR("DATREG","",""))
[M:DIA]DATPAY = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))
[M:DIA]DEBANN = gdat$(func DIVPAYE.INIPARUSR("DEBANNPAY","",""))
[M:DIA]FINANN = gdat$(func DIVPAYE.INIPARUSR("FINANNPAY","",""))

#JOJAC - 2016-09-07 - X3PEOP-755 - START
#JASMI - 2015-11-25 - Requirement 104630 US 3682 - START
#If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
#set tax dates
  #[M:DIA]TAXSTRDAT=func AFNC.PARAMDOS(nomap,"TAXSTRDAT")
  #[M:DIA]TAXENDDAT=func AFNC.PARAMDOS(nomap,"TAXENDDAT")
Endif
#JASMI - 2015-11-25 - Requirement 104630 US 3682 - end
#JOJAC - 2016-09-07 - X3PEOP-755 - END

Onerrgo
Return

$RIEN
Resume

$EXEC
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1
 GDEBANN = [M:DIA]DEBANN
 GFINANN = [M:DIA]FINANN
 GMOIPAY = [M:DIA]MOIPAY
Endif
Return

$TR1
GOK = 1
Trbegin [ADU]
 VALPAR = format$("YYYYMMDD",[M:DIA]DATPAY) : PARCOD = "DATPAY" : Gosub SETPAR
 If GOK<0 : Goto ROLL_TR1 : Elsif !GOK : Goto AB_TR1 : Endif
 VALPAR = format$("YYYYMMDD",[M:DIA]DEBPAY) : PARCOD = "DEBPAY" : Gosub SETPAR
 If GOK<0 : Goto ROLL_TR1 : Elsif !GOK : Goto AB_TR1 : Endif
 VALPAR = format$("YYYYMMDD",[M:DIA]FINPAY) : PARCOD = "FINPAY" : Gosub SETPAR
 If GOK<0 : Goto ROLL_TR1 : Elsif !GOK : Goto AB_TR1 : Endif
 VALPAR = format$("YYYYMMDD",[M:DIA]DATREG) : PARCOD = "DATREG" : Gosub SETPAR
 If GOK<0 : Goto ROLL_TR1 : Elsif !GOK : Goto AB_TR1 : Endif
 VALPAR = format$("YYYYMMDD",[M:DIA]MOIPAY) : PARCOD = "MOIPAY" : Gosub SETPAR
 If GOK<0 : Goto ROLL_TR1 : Elsif !GOK : Goto AB_TR1 : Endif
 VALPAR = format$("YYYYMMDD",[M:DIA]DEBANN) : PARCOD = "DEBANNPAY" : Gosub SETPAR
 If GOK<0 : Goto ROLL_TR1 : Elsif !GOK : Goto AB_TR1 : Endif
 VALPAR = format$("YYYYMMDD",[M:DIA]FINANN) : PARCOD = "FINANNPAY" : Gosub SETPAR
 If GOK<0 : Goto ROLL_TR1 : Elsif !GOK : Goto AB_TR1 : Endif
Commit
Return

$SETPAR
Readlock [ADU]ADU0 = GUSER;PARCOD
If fstat=1
 GOK = -1 : GLOCK = "$ADOVALAUS" : Return
Elsif fstat
 Raz [F:ADU]
 [F:ADU]PARAM  = PARCOD
 [F:ADU]CODUSR = GUSER
 [F:ADU]VALEUR = VALPAR
 Write [ADU]
Else
 [F:ADU]VALEUR = VALPAR
 Rewrite [ADU]
#MIPEA - 2018-03-15- US X3-81875- START
If dim(GACTX)>=0
  Local Integer WIND_RESULT
  WIND_RESULT= fmet GACTX.APARAM._ACLEAN
Endif
#MIPEA - 2018-03-15- US X3-81875- END
Endif
If fstat
 GOK = 0 : Call FSTA("ADU") From GLOCK : Return
Endif
Return

$OLDSETPAR
Readlock [ADW]ADW0 = "";"";PARCOD
If fstat=1
 GOK = -1 : GLOCK = "$ADOVAL" : Return
Elsif fstat
 Raz [F:ADW]
 [F:ADW]PARAM  = PARCOD
 [F:ADW]VALEUR = VALPAR
 Write [ADW]
Else
 [F:ADW]VALEUR = VALPAR
 Rewrite [ADW]
Endif
If fstat
 GOK = 0 : Call FSTA("ADW") From GLOCK : Return
Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

########################################
Subprog AM_MOIPAY(VALEUR)
Variable Date    VALEUR
Local Integer OK , MOIS , NMOIS
MOIS  = 12*year(GMOIPAY)+month(GMOIPAY)
NMOIS = 12*year(VALEUR)+month(VALEUR)
If !instr(1,GUSRAUZ(1),"1")
 If NMOIS<>MOIS & NMOIS<>MOIS+1
  GMESSAGE = mess(153,10702,1) : # Changement de mois paye impossible
  mkstat = 2 : End
 Endif
Endif

#JOJAC - 2016-09-07 - X3PEOP-755 - START
##JASMI - 2015-12-03 - Morocco localization - START
##If (func AFNC.ACTIV("KZA")>0|func AFNC.ACTIV("KAQ")>0) & (func AFNC.ACTIV("KMA")=0 & func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
##JOJAC - 2017-02-20 - START
#If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG) | func DIVPAYE.IS_AFRICA_LEG(GCURLEG)
##JASMI - 2015-12-03 - Morocco localization - END
##JASMI - 2016-03-30 - Issue 115626 - START
#  If VALEUR>[M:DIA]TAXENDDAT
##JASMI - 2016-03-30 - Issue 115626 - END
#    GMESSAGE =  mess(45,11662,1)
#    mkstat = 2 : End
#  Endif
#Endif
##JOJAC - 2017-02-20 - END
##JASMI - 2015-11-25 - Requirement 104630 US 3682 - END
#JOJAC - 2016-09-07 - X3PEOP-755 - END


If NMOIS<>MOIS
 OK = 2 : Call OUINON(mess(27,10702,1),OK) From GESECRAN
# Changement de mois de paye ?
 If OK<>2 : mkstat = 2 : End : Endif
Endif
[M]DEBPAY = gdat$(1,month(VALEUR),year(VALEUR))
[M]FINPAY = eomonth(VALEUR)
[M]DATREG = eomonth(VALEUR)
[M]DATPAY = eomonth(VALEUR)
Affzo DATPAY,DEBPAY,FINPAY,DATREG
End

Subprog VERIF_PAYE
Local Integer TIT
Local Char    VALPAR(10) , PARCOD(10)
Local Date    MOIPAY , DEBPAY , FINPAY , DD , DF
Local Char    CONTRAT(GLONVCR)
# SEGAY - 01/06/11 - Bug 74187
Local Integer OK

If clalev([F:VEP])=0    : Local File VALEMP     [VEP]   : Endif
If clalev([F:ID])=0     : Local File EMPLOID    [ID]    : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR   [HRCTR] : Endif
# SEGAY - 01/06/11 - Bug 74187
If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif

MOIPAY=gdat$(func DIVPAYE.INIPARUSR("MOIPAY","",""))
DEBPAY=gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
FINPAY=gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))
#
Call OUVRE_TRACE(mess(38,10702,1)) From LECFIC : # Vérification des payes
# Payes saisies et non validées
TIT = 0
For [VEP]VEP1 Where PYRMON=MOIPAY & STA=1
 If !TIT
  Call ECR_TRACE(mess(39,10702,1),0) From GESECRAN : # Payes saisies et non validées
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  TIT = 1
 Endif
 Read [ID]ID0 = [F:VEP]EMP
# SEGAY - 01/06/11 - Bug 74187
# Call ECR_TRACE([F:ID]REFNUM-format$("D:"+GFMDAT4,[F:VEP]PYRDAT)-[F:ID]NAM-[F:ID]SRN-"("+[F:VEP]BUL+")",0) From GESECRAN
 OK = 1
 Gosub CONTROLE_ID
 If OK=1
   Call ECR_TRACE([F:ID]REFNUM-format$("D:"+GFMDAT4,[F:VEP]PYRDAT)-[F:ID]NAM-[F:ID]SRN-"("+[F:VEP]BUL+")",0) From GESECRAN
 Endif
 # END - Bug 74187
Next
If TIT : Call ECR_TRACE("",0) From GESECRAN : Endif
# Salariés présents et non payés
TIT = 0
#35720
For [ID]ID0 Where FLGPAY=2 & FLGINT<>2 : # On ne vérifie pas les intermittents
 Filter [HRCTR] Where REFNUM=[F:ID]REFNUM & CTRDAT<FINPAY & (XITDAT=[0/0/0] or XITDAT>=DEBPAY)
 For [HRCTR]
  CONTRAT = [F:HRCTR]CTRNUM
# SEGAY - 01/06/11 - Bug 74187
#  Gosub VERF_PAYE
  OK = 1
  Call CONTROLE([F:HRCTR]REFNUM, FINPAY, [F:HRCTR]CTRNUM, "", [L]OK, 1) From DIVPAYE
  If OK=1
    Gosub VERF_PAYE
  Endif
  # END - Bug 74187
 Next
Next
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

###############################################################################
# SEGAY - 01/06/11 - Bug 74187
$CONTROLE_ID
If [F:ID]CODACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:ID]CODACS
 If fstat or [F:ACC]CONSUL<>2
  OK = 0 : Return
 Endif
Endif
Return

###############################################################################

$VERF_PAYE
Filter [VEP] Where EMP=[F:ID]REFNUM & PYRMON=MOIPAY & CTRNUM=CONTRAT
Read [VEP]VEP1 Last
Filter [VEP]
If fstat>2
 If !TIT
  Call ECR_TRACE(mess(40,10702,1),0) From GESECRAN : # Salariés présents et n'ayant pas de paie
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  TIT = 1
 Endif
 DD = max([F:HRCTR]CTRDAT,DEBPAY)
 If [F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT<FINPAY
  DF = [F:HRCTR]XITDAT
 Else
  DF = FINPAY
 Endif
 Call ECR_TRACE([F:ID]REFNUM-format$("D:"+GFMDAT4,DD)+"-"+format$("D:"+GFMDAT4,DF)
&              -[F:ID]NAM-[F:ID]SRN-"("+CONTRAT+")",0) From GESECRAN
Endif
Return

Subprog C_DATPAY(VALEUR)
Variable Date    VALEUR
Local Integer OK
If VALEUR<[M]MOIPAY or VALEUR>eomonth([M]MOIPAY)+GJMAX
 GMESSAGE = mess(21,10702,1) : mkstat = 2 : End
# Date incompatible avec le mois de paye
Endif
If VALEUR<[M]MOIPAY+GJMAX
 OK = 2 : Call AVERTIR(mess(22,10702,1)-"("+format$("D:"+GFMDAT4,[M]MOIPAY+GJMAX)
&  +"-"+format$("D:"+GFMDAT4,eomonth([M]MOIPAY)+GJMAX)+")",OK) From GESECRAN
# Date en dehors de la période de paye
 If OK<>2 : mkstat = 2 : End : Endif
Endif
End

Subprog C_FINPAY(VALEUR)
Variable Date    VALEUR
If VALEUR<[M]DEBPAY
 GMESSAGE = mess(25,10702,1) : # Période incorrecte
 mkstat = 2 : End
Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran MOIPAY) 09/01/2014 16:14:35 (LANEG)
######################################################################################
#81491
Subprog AM_DATPAY(VALEUR)
Variable Date    VALEUR
If [M]DATREG<VALEUR
 [M]DATREG=VALEUR
 Affzo DATREG
Endif
End

Subprog C_DATREG(VALEUR)
Variable Date    VALEUR
If VALEUR<[M]DATPAY
 GMESSAGE= mess(229,10703,1)
 mkstat=2 : End
Endif
If VALEUR>eomonth([M]DATPAY)
 Local Integer OK
 OK = 2
 Call AVERTIR(mess(232,10703,1),OK) From GESECRAN
 If OK=1 : mkstat = 2 : End : Endif
Endif
End


######################################################################################

