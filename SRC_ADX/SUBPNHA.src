#<AdxTL>@(#)4.0.0.0 $Revision$
#########################################################################
# SUBPNHA : Gestion des retours fournisseurs               MBT 08/01/03 #
# --------------------------------------------------------------------- #
# Traitement des actions "GOSUB" de l'objet "PNH"                       #
# Les traitements sur champ "Call" se trouvent dans le SUBPNH           #
#########################################################################

$DEFTRANS
#--------------------------------------------------------#
# Avant lecture des transactions de saisie disponibles : #
# Si GFLAG est renseigné la transaction est déja choisie #
# par le menu. Vérifier si elle est valide               #
#--------------------------------------------------------#
Local Shortint OUVFICFLG
If !clalev([F:PTR])  Local File PURTRS [PTR] : Endif
If GFLAG<>""
  Read [PTR] PTR0=7;GFLAG
  If fstat | [F:PTR]ENAFLG=1 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  If [F:PTR]ACSCOD<>"" & GPROFIL<>GSUPER
    If !clalev([F:ACC])  Local File ACCES  [ACC] : OUVFICFLG=1 : Endif
    Read [ACC] CODACC=GUSER;[F:PTR]ACSCOD
    If fstat | [F:ACC]EXEC<>2 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  Endif
Endif
$FIN_DEFTRANS
If OUVFICFLG=1  Close Local File [ACC] : Raz OUVFICFLG : Endif
Return


$VARIANTE
#---------------------------------------#
# Après lecture de chaque transaction : #
# La transaction est-elle valide ?      #
# VARCOD contient le code transaction.  #
# Mettre OK à zéro si non valide.       #
#---------------------------------------#
Read [PTR] PTR0=7;VARCOD
If fstat | [F:PTR]ENAFLG=1 OK=0 : Endif
Return


$SETTRANS
If dim(GSVGWRHOBY)<0 Global Integer GSVGWRHOBY Endif
#-------------------------------------#
# Après sélection de la transaction : #
# GFLAG = code transaction choisie    #
#-------------------------------------#
If clalev ([F:PTR])=0  Local File PURTRS [PTR] : Endif
Read [PTR] PTR0=7;GFLAG : If fstat Raz [F:PTR] : Endif

#MAE, le 30/01/08, GRP_SITE
GGRPFCY = [F:PTR]GFY

# Dépôt entête obligatoire ou non
If GWRHACT=2
  GWRHOBY = [F:PTR]WRHOBY
Else
  GWRHOBY = 1
Endif
GSVGWRHOBY = GWRHOBY

Return


$FILTRE
#-------------------------------------#
# Repositionnement fichier par défaut #
#-------------------------------------#
Default File [F:PNH]
Return


$AV_IMPRIME
#-----------------------------------------------#
# Avant impression : Chargement nom du document #
#-----------------------------------------------#
If [F:PTR]PTRTYP<>7 | [F:PTR]PTRNUM<>GPTRNUM  : # Relecture transaction si nécessaire
   Read [PTR] PTR0=7;GPTRNUM : If fstat Raz [F:PTR] : Endif
Endif
#----- Si document renseigné (écran ou transaction), prendre celui-la -----#
If [M:PNH1]DOCNAM<>""
  AREPORT=[M:PNH1]DOCNAM
Elsif [F:PTR]DOCNAM<>""
  AREPORT=[F:PTR]DOCNAM
Endif
#-----
Return


$AP_IMPRIME
#---------------------------------------------------------------#
# Après une impression il faut etre sur d'etre sur le bon enreg #
#---------------------------------------------------------------#
Raz [L]AREPORT
Gosub RELIT From GOBJSUB
Return


$AVANT_OUVRE
#---------------------------------------------------------------#
# Si déjà ouvert et si on vient par tunnel il faut réouvrir le  #
# fichier ligne réception à cause du bug sur les "Links" tiroir #
#---------------------------------------------------------------#
Local Libelle OUVFICPTD
If clalev([F:PTD]) & GFONC1<>"GESPNH" & !GIMPORT
  Local File PRECEIPTD [PTD] : OUVFICPTD=1
Endif
Return


$OUVRE
If dim(GSVGWRHOBY)<0 Global Integer GSVGWRHOBY Endif
Raz GSOC_ACTIVE
#---------------------------------------------------------------------#
# Dans EXEFNC si pas de site par défaut pour le module concerné       #
# GFCYDEF(0) = premier site de la table sites (modif Beinat 15/12/99) #
# FAUX, il faut toujours avoir GFCYDEF(0) = site par défaut du module #
# même si ce site par défaut est vide !                               #
#---------------------------------------------------------------------#
GFCYDEF(0)=GFCYDEF(6)
GCOEUOM = 0
#----- Variables locales pour gestion picking liste de gauche -----#
Local Char     WNUM(GLONPTH), WVCRNUMORI(GLONVCR), SYMBOL2(30)
Local Integer  WLIN, WVCRTYPORI, WINDICE, WRET
Local Integer  I, J, K
Local Shortint NOL, WPICK, SAVNBLIG
Local Decimal  WQTE1, WQTE2, WQTYSTU
# Issue X3-65722 - 2018-03-05 by SR :
Local Char WCRITERE(240)
#-----
Global Integer  GPNH_VERROU
Global Libelle  GPNH_PICK : # Indique qu'un picking/dépicking est en cours
Global Libelle  GPNH_EECFLG
Global Char     GPNH_CPYCRY(GLONCPY), GPNH_POHFCY(GLONFCY)
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
GCONSDIA=0 : # Rend saisissable les écrans avec abréviation [DIA]
GPTRNUM=[F:PTR]PTRNUM
#----- Ouverture fichiers des retours sous une autre abréviation -----#
If clalev([F:PNHB])=0 Local File PRETURN  [PNHB] : Endif
If clalev([F:PNDB])=0 Local File PRETURND [PNDB] : Endif
# Issue X3-38307 - 2017-06-08 by SR :Pour contrôle date de fin de validité de l'article
If clalev([F:POC]) =0 Local File PORDERC   [POC] : Endif

#-----
If !clalev([F:TCA])  Local File TABCOUAFF  [TCA] : Endif
If !clalev([F:TCY])  Local File TABCOUNTRY [TCY] : Endif
If !clalev([F:POS])  Local File POSCOD     [POS] : Endif
If !clalev([F:BPR2]) Local File BPARTNER  [BPR2] : Endif
If !clalev([F:GCM])  Local File GACM       [GCM] : Endif
If !clalev([F:PFI])  Local File PFOOTINV   [PFI] : Endif
If func AFNC.ACTIV("TRSNE") > 0
  If !clalev([F:TPN])  Local File TABPNHTYP  [TPN] : Endif #85785
Endif
#----- Ouverture fichiers pour inter-sites / inter-sociétés -----#
If GMODU(5)=2 : # Si module Ventes présent
  If !clalev([F:BPC])  Local File BPCUSTOMER [BPC] : Endif
  If !clalev([F:ITS])  Local File ITMSALES   [ITS] : Endif
  If !clalev([F:MVC])  Local File BPCUSTMVT  [MVC] : Endif
  If !clalev([F:SOH])  Local File SORDER     [SOH] : Endif
  If !clalev([F:BPD])  Local File BPDLVCUST  [BPD] : Endif
Endif
#----- Link fichiers retours pour recherche des retours non validés -----#
If !clalev([PNX])
  Link [PNDB] With [PNHB] PNH0=[F:PNDB]PNHNUM As [PNX]
Endif
#----- Link pour recherche site d'expédition -----#
If !clalev([F:ITFY])
  Link [ITF]  With [FCY] FCY0=[F:ITF]STOFCY   As [ITFY]
Endif
#----- Ouverture masques adresses, complément et infos douanières -----#
If !clalev([M:AD65])  Local Mask ADRBPR   [AD65] : Endif : # Masque adresse fournisseur
If !clalev([M:PCEY])  Local Mask PCEE     [PCEY] : Endif : # Masque informations douanières
If !clalev([M:PNHC])  Local Mask PNH2     [PNHC] : Endif : # Masque compléments
If !clalev([M:ORDK])  Local Mask ORDK     [ORDK] : Endif : # Masque paramètres encours
If !clalev([M:PCRW])  Local Mask PCRITRCP [PCRW] : Endif : # Masque critères picking RCP
If !clalev([M:SBCK])  Local Mask SBCK     [SBCK] : Endif : # Masque pour màj sous-traitance
#-----
If !clalev([M:ALP])   Local Mask ALLPAR   [ALP]  : Endif : # Masque paramètres allocations
If !clalev([M:SOW])   Local Mask STOSORW  [SOW]  : Endif : # Masque travail sorties stock
# BRBAN 24/07/2014 SAM #93745 US2 - Digital signature table
If func AFNC.ACTIV('DKS')>0
  If clalev([F:PTDKD])=0 : Local File DKSDATA [PTDKD] : Endif
Endif
#----- Appels pour la gestion des tarifs -----#
GPLISTC="néant" : # Pour forcer l'affichage des entêtes de colonne si structure=""
Call CTLSTRUCT(2,WRET) From TRTPRICE : If WRET<>0 OK=0 : Return : Endif
Call COLREM("C",2,"")  From TRTPRICE
Call TYPREM(2,"")      From TRTPRICE
Call TARIFCHGT(6)      From TRTPRICE
#----- chargement des formats évalués -----#
For I=0 To 8  [M:PNH1]FMTREM(I)="NZ:9.2#" : Next I
#----- Récupération des paramètres achats et budget -----#
GFCY=GFCYDEF(7)
Call GETFCYDEF(GFCY,"[F:FCY]WRHFLG=2") From TRTX3
Gosub CHARG_PARAM
GORITITCOL=1
#----- Déclaration des variables pour tableau lignes -----#
Gosub DECLARE From TABLEAUX
Return


$OUVRE_BOITE
#-------------------------------#
# Après ouverture de la fenêtre #
#-------------------------------#
#----- Chargement des noms des Currbox de chaque tiroir -----#
Global Char     GBOXPT2(10)
GBOXPT2="GAU_CHE"+num$(find("PT2",OBJLIS(1..8))) : # Picking des réceptions
Return


$AFFMASK
#----------------------------------------------------#
# Premier affichage écran après appel de la fonction #
# -------------------------------------------------- #
#         Chargement des formats évalués             #
#----------------------------------------------------#
For I=0 To 8  [M:PNH1]FMTREM(I)="NZ:9.2#" : Next I
Return


$CHARG_PARAM
#----------------------------------------------------------------#
# Chargement des paramètres avec GFCY = site du retour           #
# -------------------------------------------------------------- #
# Chargement GSOCIETE   : Société juridique                      #
#            GLOCALDEV  : Devise société juridique               #
#            GFINRSP    : Site financier                         #
#            GPIH_CPYCRY: Pays de la société courante (GSOCIETE) #
# Récupération des paramètres stocks                             #
# Récupération des paramètres achats                             #
#----------------------------------------------------------------#
#----- Chargement des globales référentiels, comptes et sections de la société -----#
Call GETCPY(GFCY,"PTR",7,GPTRNUM) From TRTX3CPT
If GFINRSP="" GFINRSP=GFCY : Endif
#----- Lecture des affectations compteur si changement société -----#
If GSOC_UPDFLG
  If dim(OK)<1  Local Integer OK : Endif
  If func AFNC.ACTIV("TRSNE") > 0
    Gosub REC_CPT_PNH From SUBPNH #85785
  Else
    #----- Compteur des commandes -----#
    Call LECTCA(6,OK) From SUBTCA
    If fstat | !OK
      GERR=1 : GMESSAGE=mess(58,105,1)-mess(6,14,1)-mess(250,199,1) : Return
    Endif
    If [M:PNH1]BETFCY<>2 | [M:PNH1]BETCPY=2
      GMANCOU=[F:TCA]MANCOU(6)  : GCODNUM=[F:TCA]CODNUM(6)
    Else
      GMANCOU=[F:TCA]MANCOU(13) : GCODNUM=[F:TCA]CODNUM(13)
    Endif
  Endif
  #------ Compteur des encours article ------#
  Call LECTCA(7,OK) From SUBTCA
  If fstat | !OK
    GERR=1 : GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1) : Return
  Endif
  GWIP=[F:TCA]CODNUM(8)
  #----- Contrôle longueur compteur pas supérieure à 15 caractères -----#
  #Call CTRCPT(GWIP,25,OK) From STKLIB
  #If OK<>0  GERR=1 : GMESSAGE=mess(222,199,1) : OK=0 : Return : Endif

  # Issue 71069 - 2013-08-23 by MUARN : PJT
  GPJTSNGDOC = func TRTPJT.GET_PARAM_PJTSNGDOC(GFCY)

Endif
#----- Chargement du pays de la société GPIH_CPYCRY -----#
Raz GBIDI1
If clalev([F:CPY])<=0 Local File COMPANY [CPY] : GBIDI1=1 : Endif
Read [CPY] CPY0=GSOCIETE : If fstat Raz [F:CPY] : Endif
GPIH_CPYCRY=[F:CPY]CRY
If GBIDI1=1 Close Local File [CPY] : Raz GBIDI1 : Endif
#-----
Call GLOBVAR(GFCY)  From WWGLOBSTO
Call GLOBVAR(GFCY)  From WWGLOBACH
#-----
Call PARAMUTIL("PNHDIR",GBIDC3,"",GFCY) From SUBAUS
GPNHDIR=val(GBIDC3)
#----- Alimentation de la province d'entrée -----#
If func AFNC.ACTIV("PTX") & dim([M:PNH1]SATRCP)>0
  #----- Lecture du site de réception si nécessaire -----#
  If [F:FCY]FCY<>GFCY
    Read [FCY] FCY0=GFCY : If fstat  Raz [F:FCY] : Endif
  Endif
  #----- Lecture de l'adresse d'expédition si nécessaire -----#
  If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>GFCY | [F:BPA]BPAADD<>[F:FCY]BPAADD
    Read [BPA] BPA0=3;GFCY;[F:FCY]BPAADD
    If fstat  Raz [F:BPA] : Endif
  Endif
  #-----
  [M:PNH1]SATRCP=[F:BPA]SAT
Endif
Return


$RAZCRE
# Issue 71069 - 2013-08-23 by MUARN : PJT
GFCY=GFCYDEF(7)
Call GETFCYDEF(GFCY,"[F:FCY]WRHFLG=2") From TRTX3
[M:PNH1]PNHFCY = GFCY
#85785 * RMA
If func AFNC.ACTIV("TRSNE") > 0
  ## Get purchage type
  Local Char WPNHTYP(GLONTPN)
  Gosub PNHTYP From TRTACHRET1
  If WPNHTYP<>"" : [M:PNH1]PNHTYP=WPNHTYP : Affzo [M:PNH1]PNHTYP : Endif
Endif
#----- Récupération des paramètres achats et budget -----#
Gosub CHARG_PARAM
# Issue 71069 - 2013-08-23 by MUARN : pjt
If GPJTSNGDOC = G_NON Then
 Call PJT_MODFCY([M:PNH1]PNHFCY,"[M:PNH1]PJT") From TRTPJT
Endif

#------------------------------------------------------#
# Valeurs par défaut et initialisations avant création #
#------------------------------------------------------#
Actzo [PNH1]RTNDAT, PNHNUM, BUY, BPSNUM, 10-15
#----- chargement des formats évalués -----#
For I=0 To 8  [M:PNH1]FMTREM(I)="NZ:9.2#" : Next I
#-----
# Issue 71069 - 2013-08-23 by MUARN : PJT
#GFCY=GFCYDEF(7)
#Call GETFCYDEF(GFCY,"[F:FCY]WRHFLG=2") From TRTX3

#If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
#  If !find(GFCY,GUSRFCY(1..GNBAUZ))
#    GFCY=GUSRFCY(1)    : # On prend le premier site autorisé
#  Endif
#  If GNBAUZ=1
#    Diszo [PNH1]PNHFCY : # Saisie inutile si un seul site permis
#  Else
#    Actzo [PNH1]PNHFCY
#  Endif
#Else
#  Actzo [PNH1]PNHFCY
#Endif

# Issue 71069 - 2013-08-23 by MUARN : PJT
#[M:PNH1]PNHFCY = GFCY

If !GIMPORT
  If GNBAUZ=1 & GFCY<>""  Diszo [PNH1]PNHFCY  Else  Actzo [PNH1]PNHFCY : Endif
Endif
#----- Récupération des paramètres achats et budget -----#
#Gosub CHARG_PARAM
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL
#-----
Call RAZSTOSORW From STKSOR
Raz [M:AD65], [M:PNHC], [M:PCRW], [M:PCEY]
[M:PNH1]RTNDAT=date$
[M:PNH1]PCLFLG=2
[M:PNH1]BUY=GUSER
[M:PNH1]PRNFLG=1
#----- Chargement code mouvement et pièce auto stock -----#
If [F:PTR]PTRTYP<>7 | [F:PTR]PTRNUM<>GPTRNUM  : # Relecture transaction si nécessaire
   Read [PTR] PTR0=7;GPTRNUM : If fstat Raz [F:PTR] : Endif
Endif
[M:PNH1]TRSCOD=[F:PTR]TRSCOD
[M:PNH1]ENTCOD=[F:PTR]ENTCOD
#----- Gestion des textes -----#
Call RAZ_CLOB From ACLOB : GCONSDIA=0 : # Rend saisissable le texte
Raz [M:PNH1]TEX1, [M:PNH1]TEX2, [M:PNH1]LINTEX
Call RESET_IMAGE (4) From GESECRAN
Affzo [PNH1]1-99
#----- Mise à jour des listes de gauche picking -----#
If !GIMPORT
  [M:PNH1]CFMFLG=2   : # Pour vider la liste de picking des réceptions
  FILGAUSUP(0)="[F:PTD]PRHFCY=''"
  Gosub TIROIR
  Raz [M:PNH1]CFMFLG : # Remise à l'état initial
Endif

If dim([M:PNH1]WRHE)>0
   Call WRHINIT([M:PNH1]WRHE,[M:PNH1]PNHFCY,6) From STKWRH
Endif

# Actzo ou Grizo des dépôts selon le site
Gosub WRH_ETAT

# Issue 71069 - 2013-08-23 by MUARN : PJT
# A faire apres tout le reste
If GPJTSNGDOC = G_OUI Then
 Call PJT_MODFCY([M:PNH1]PNHFCY,"[M:PNH1]PJT") From TRTPJT
Endif

Return


$RAZDUP
#-------------------#
# Avant duplication #
#-------------------#
Raz [M:PNH1]PNHNUM
Actzo [PNH1]RTNDAT, PNHNUM, BUY, BPSNUM, 10-15
Raz [M:PCRW]

# 101090 - BOL
If dim ([M:PNHC]BOLNUM)>0   : Raz [M:PNHC]BOLNUM  : Endif
If dim ([M:PNHC]SCAC)>0     : Raz [M:PNHC]SCAC    : Endif
If dim ([M:PNHC]PRONUM)>0   : Raz [M:PNHC]PRONUM  : Endif
If dim ([M:PNHC]TRAILER)>0  : Raz [M:PNHC]TRAILER : Endif

# Issue 71069 - 2013-08-23 by MUARN : pjt
If GPJTSNGDOC = G_NON Then
 Call PJT_MODFCY([M:PNH1]PNHFCY,"[M:PNH1]PJT") From TRTPJT
Endif

Call RAZSTOSORW From STKSOR

# Issue 71069 - 2013-08-23 by MUARN :PJT
# Code affaire à la ligne (Partie : rajout paramètre société pour contrôle documents mono-affaire)
#--Duplication avec paramètre à OUI => si le code affaire de la ligne est <> de celui de l'en-tête, on reprend l'en-tête
Call TRAITE_DUPLICATION("[M:PNH1]PJTH") From TRTPJT

#----- Chargement code mouvement et pièce auto stock -----#
If [F:PTR]PTRTYP<>7 | [F:PTR]PTRNUM<>GPTRNUM  : # Relecture transaction si nécessaire
   Read [PTR] PTR0=7;GPTRNUM : If fstat Raz [F:PTR] : Endif
Endif
[M:PNH1]TRSCOD=[F:PTR]TRSCOD
[M:PNH1]ENTCOD=[F:PTR]ENTCOD
#----- Gestion des textes -----#
Call RAZ_CLOB From ACLOB : GCONSDIA=0 : # Rend saisissable le texte
If left$([M:PNH1]TEX1,3)="PNH"
  Call DUP_CLOB("PNH",[M:PNH1]TEX1,WRET) From TRTX3TEX
  If WRET<1  Raz [M:PNH1]TEX1 : Endif
Endif
If left$([M:PNH1]TEX2,3)="PNH"
  Call DUP_CLOB("PNH",[M:PNH1]TEX2,WRET) From TRTX3TEX
  If WRET<1  Raz [M:PNH1]TEX2 : Endif
Endif
For I=0 To [M:PNH1]NBLIG-1
  If left$([M:PNH1]LINTEX(I),3)="PND"
    Call DUP_CLOB("PND",[M:PNH1]LINTEX(I),WRET) From TRTX3TEX
    If WRET<1  Raz [M:PNH1]LINTEX(I) : Endif
  Endif
Next I
#----- Mise à jour des listes de gauche picking -----#
If !GIMPORT Gosub TIROIR : Endif

# Actzo ou Grizo des dépôts selon le site
Gosub WRH_ETAT

# Issue 71069 - 2013-08-23 by MUARN : PJT
# A faire apres tout le reste
If GPJTSNGDOC = G_OUI Then
 Call PJT_MODFCY([M:PNH1]PNHFCY,"[M:PNH1]PJT") From TRTPJT
Endif

Return


$DEFLIG
#----------------------------------#
# Définition du fichier des lignes #
#----------------------------------#
Default Mask [PNH1]
Default File [PND]
CRIT   = 'PNHNUM="'+[M:PNH1]PNHNUM+'"'
FICLIG = "PRETURND"
ABLIG  = "PND"
ZONLIG = "PNDLIN"
Return


$LIENS
#------------------------------------#
# Chargement GFCY : Site du retour   #
# Récupération des paramètres ACHATS #
#------------------------------------#
Raz GPNH_POHFCY
Raz [M:PCRW] : [M:PCRW]WBPSNUM=[F:PNH]BPSNUM
GFCY=[M:PNH1]PNHFCY
Gosub CHARG_PARAM
Call RAZSTOSORW From STKSOR : # Remise à zéro de l'écran de travail STOSORW
Gosub LIENS From TABLEAUX

# Issue 71069 - 2013-08-23 by MUARN : pjt
If GPJTSNGDOC = G_NON Then
 Call PJT_MODFCY([M:PNH1]PNHFCY,"[M:PNH1]PJT") From TRTPJT
Endif

Call ETAZONSOR("PNH1")  From STKECR : # Diszo des champs stock ligne document sortie
[M:PCEY] = [F:PNH]
[M:PCEY]WPOSCOD=[F:PNH]POSCOD
[M:PCEY]WBPSNUM=[F:PNH]BPSNUM
[M:PCEY]WBPAADD=[F:PNH]BPAADD
[M:PCEY]WCRY   =[F:PNH]CRY
[M:PNHC] = [F:PNH]

# BRBAN 24/07/2014 SAM #93745 US2
# ATDTCOD from DKS
If func AFNC.ACTIV("KPO") > 0
  Read [F:PTDKD]DKD0="SAFT-PT";[F:PNH]PNHTYP;[F:PNH]PNHNUM
  If !fstat & [F:PTDKD]ATDTCOD<>''
    [M:PNHC]ATDTCODR= [F:PTDKD]ATDTCOD
  Endif
Endif
#-

#----- Chargement de la classe [M:AD65] zones adresse -----
If [F:PNH]CRY<>"" | [F:PNH]CTY<>""
  [M:AD65]       = [F:PNH]
  [M:AD65]ADBBPR = [F:PNH]BPSNUM
  [M:AD65]ADBFLG = 2
Else
  Raz [M:AD65]
  [M:AD65]BPAADD = [F:PNH]BPAADD
  [M:AD65]ADBBPR = [F:PNH]BPSNUM
Endif
#----- Lecture BPSUPPLIER et BPARTNER si nécessaire -----#
If [F:BPS]BPSNUM<>[F:PNH]BPSNUM
  Read [BPS] BPS0=[F:PNH]BPSNUM :  If fstat  Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
Endif
If [F:BPR]BPRNUM<>[F:PNH]BPSNUM
  Read [BPR] BPR0=[F:PNH]BPSNUM :  If fstat  Raz [F:BPR] : [F:BPR]LAN=GLANGUE   : Endif
Endif
[M:PNH1]LAN=[F:BPR]LAN
GCUR=[F:BPS]CUR
#----- Alimentation à partir du modèle d'édition du fournisseur commande -----#
Call ALI_PRTMOD("PNH1",10) From TRTX3
#----- Positionnement indicateur CEE -----#
If GACTDEB=2
  If [F:TCY]CRY<>[F:BPR]CRY
    Read [TCY] TCY0=[F:BPR]CRY : If fstat Raz [F:TCY] : Endif
  Endif
  If GPNH_CPYCRY<>[F:BPR]CRY & [F:TCY]EECFLG=2
    GPNH_EECFLG=2
  Else
    GPNH_EECFLG=1
  Endif
Else
  GPNH_EECFLG=0
Endif
#----- Chargement des sections analytiques entête -----#
If dim([M:PNH1]NBAXE)>0
  Call CHARG_CCEH("PNH1","NBAXE","PNH") From TRTX3CPT
Endif
#----- Chargement libellés/formats colonnes tarif -----#
If GPLISTC<>[F:BPS]PLISTC
  GPLISTC=[F:BPS]PLISTC
  Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
  Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
  Call TARIFCHGT(6)                From TRTPRICE
  GSOC_UPDFLG=1 : # Pour forcer l'affichage des entêtes de colonne variables
Endif
Call FMTREM("PNH1",GCUR) From TRTPRICE
#----- Affichage entêtes de colonne variables -----#
If !clalev([F:ADL])  Gosub AFF_TITCOL : Endif
#-----
If [M:AD65]ADBFLG=2
  [M:PNH1]BPSNAM=[M:AD65]BPRNAM(0)
Else
  [M:PNH1]BPSNAM=[F:BPR]BPRNAM
Endif
#-----
If GFONC1="GESPNH"  Call RAZ_CLOB From ACLOB    : Endif
If [M:PNH1]CFMFLG=2  GCONSDIA=2 Else GCONSDIA=0 : Endif
#----- Affichage icone texte -----#
If [M:PNH1]TEX1<>"" | [M:PNH1]TEX2<>""
  Call SET_IMAGE (4)   From GESECRAN
Else
  Call RESET_IMAGE (4) From GESECRAN
Endif
#----- Si retour validé -----#
If [M:PNH1]CFMFLG=2
  Actzo  [PNH1]PNHNUM
  # Issue 71069 - 2016-04-12 by SR : ajout PJTH
  Diszo  [PNH1]PNHFCY, RTNDAT, BUY, BPSNUM, PJTH, 10-15
#----- Si retour non validé -----#
Else
  # Issue 71069 - 2016-04-12 by SR :ajout PJTH
  Actzo  [PNH1]PNHNUM, RTNDAT, AUZNUM, PJTH,  15
  Diszo  [PNH1]PNHFCY, BUY, BPSNUM, BPAADD
Endif
#----- Mise à jour des listes de gauche picking -----#
If !GIMPORT & !clalev([F:ADL])  Gosub TIROIR : Endif

# Actzo ou Grizo des dépôts selon le site
GWRHOBY = GSVGWRHOBY
Gosub WRH_ETAT

# Issue 71069 - 2013-08-23 by MUARN : PJT
# A faire apres tout le reste
If GPJTSNGDOC = G_OUI Then
 Call PJT_MODFCY([M:PNH1]PNHFCY,"[M:PNH1]PJT") From TRTPJT
Endif

#101090 - Setup BOL related fields
Call SETUP_BOL

# BRBAN * 01/04/2015 * #107394
If func AFNC.ACTIV("TRSNE") > 0 & dim([M:PNH1]PNHTYP)>0
  Diszo [M:PNH1]PNHTYP
Endif
Return


$LIENS_LIG
#-----------------------------#
# Après lecture ligne [F:PND] #
#-----------------------------#
NOL=nolign-1
If dim([M:PNH1]TSICOD1(NOL))>0 [M:PNH1]TSICOD1(NOL)=[F:PND]TSICOD(0) : Endif
If dim([M:PNH1]TSICOD2(NOL))>0 [M:PNH1]TSICOD2(NOL)=[F:PND]TSICOD(1) : Endif
If dim([M:PNH1]TSICOD3(NOL))>0 [M:PNH1]TSICOD3(NOL)=[F:PND]TSICOD(2) : Endif
If dim([M:PNH1]TSICOD4(NOL))>0 [M:PNH1]TSICOD4(NOL)=[F:PND]TSICOD(3) : Endif
If dim([M:PNH1]TSICOD5(NOL))>0 [M:PNH1]TSICOD5(NOL)=[F:PND]TSICOD(4) : Endif
[M:PNH1]VAT1(NOL)=[F:PND]VAT(0)
[M:PNH1]VAT2(NOL)=[F:PND]VAT(1)
[M:PNH1]VAT3(NOL)=[F:PND]VAT(2)
If [F:PND]LININVFLG=2 [M:PNH1]AVOFLG(NOL)=1 Else [M:PNH1]AVOFLG(NOL)=2 : Endif
#----- Lecture article si nécessaire -----#
If [F:ITM]ITMREF<>[M:PNH1]ITMREF(NOL)
  Read [ITM] ITM0=[M:PNH1]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
Endif
#----- Calcul qté maxi à retourner que si le retour n'est pas validé -----#
If [M:PNH1]CFMFLG<>2
  Gosub CAL_QTEMAX From SUBPNHB
Endif
#----- Mise à jour indicateur ligne (0=en cours de création, 1=Créée) -----#
[M:PNH1]LINFLG(NOL)=1
#----- Alimentation des zones stock d'une ligne document sortie -----#
If [M:PNH1]STOMGTCOD(NOL)>1 & [M:PNH1]LINTYP(NOL)<3
  Call RECSTOSOR (3-[M:PNH1]CFMFLG,"PNH1",NOL,[M:PNH1]PNHFCY,[F:PND]ITMREF,
&                 8,[F:PND]PNHNUM,[F:PND]PNDLIN,"",WRET) From STKECR
  [M:PNH1]WSTOSAI(NOL)="00022222022"
  [M:PNH1]WSTOFLG(NOL)=1
Else
  [M:PNH1]WSTOSAI(NOL)="00022222222"
  [M:PNH1]WSTOFLG(NOL)=2
Endif
#----- Chargement comptes et sections analytiques -----#
Call CHARG_ACCCCE(NOL,"[M:PNH1]LINACC","","[M:PNH1]CCE",
&                "PND",0,[F:PND]PNHNUM,[F:PND]PNDLIN,0,"") From TRTX3CPT
#-----
[M:PNH1]PREQTYPUU(NOL)=[M:PNH1]QTYPUU(NOL)
Return


$SETBOUT
#-------------------------------------------------------------------------#
# Activation / désactivation des menus (ToolBar) et boutons (bas d'écran) #
# --------------------------------------+-------------------------------- #
# A  Menu Texte                         ! Boutons de bas d'écran          #
#      AF : Texte entête                !      1  : Complément            #
#      AG : Texte pied                  !      2  : Validation            #
# B  Menu Adresse                       !                                 #
#      BH : Adresse fournisseur         !                                 #
# C  Menu Option                        !                                 #
#      CI : Critères de picking         !                                 #
#      CJ : Informations douanières     !                                 #
#      CK : Sections analytiques entête !                                 #
#      CL : Consultation de retours     !                                 #
#      CM : Transaction                 !                                 #
#---------------------------------------+---------------------------------#
GPNH_VERROU=VERROU
#----- Menus "Texte entête" et "Texte pied" dans la ToolBar -----#
If GREP="C" | GREP="D" | [M:PNH1]PNHNUM<>""
  CHMEN+="FG"
Endif
#----- Menu "Adresse fournisseur" dans la ToolBar -----#
If GREP<>"" | CLECUR
  CHMEN+="H"
Endif
#----- Menu "Critères picking" et "Sections analytiques entête" -----#
If [M:PNH1]PNHFCY<>"" & [M:PNH1]RTNDAT<>[0/0/0] & [M:PNH1]BUY<>"" & [M:PNH1]CFMFLG<2
  #----- Si modif non autorisée, désactivation du picking -----#
  If GREP<>"C"
    GBIDC2="M" : Gosub AUTORIS_OPT From CONTX3
    If GBIDI2 CHMEN+="I" : Endif
  Else
    CHMEN+="I"
  Endif
Endif
#----- Menu "Informations douanières" -----#
If CLECUR
  CHMEN+="J"
Endif
#----- Menu sections analytiques entête -----#
If [M:PNH1]PNHFCY<>"" & [M:PNH1]RTNDAT<>[0/0/0] & [M:PNH1]BUY<>"" & GHEADIE<>3
  CHMEN+="K"
Endif
#----- Menu "Consultation retours" -----#
If GREP="" & CLECUR & !clalev([M:CPN2])
  CHMEN+="L"
Endif
#----- Menu "Transaction" -----#
CHMEN+="M"
#----- Menu "Traçabilité" -----#
# SYMEU 10/12/2008 : branchement traçabilité pièces
If !find(GREP,"C","D") and !find("CONSPIA",GNAVIG(1..GPILNAV)) Then CHMEN += "N" Endif
# - 101090 - Bill of lading menu
CHMEN+="B"
#----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
Gosub SET_BOUT_SPE From GSAISIE
#----- Suppression des boutons selon contexte -----#
If !CLECUR | GREP<>""
  #--- Pas d'enregistrement chargé ou modif commencée on vire les boutons spéciaux ---#
  Call VIREBOUT(CHAINE,"12")     From GOBJET
Else
  Call VIREBOUT(CHAINE,"H")       From GOBJET
  If CLECUR
    Call VIREBOUT(CHAINE,"D")     From GOBJET
    If [M:PNH1]RTNDAT>date$
      Call VIREBOUT(CHAINE,"2")   From GOBJET
    Endif
    If [M:PNH1]CFMFLG=2
      Call VIREBOUT(CHAINE,"AM2") From GOBJET
    Endif
  Endif
Endif

# BRBAN 26-06-2014 SAM 93745
If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN([M:PNH1]PNHFCY ,'')=1
  If [F:PNH]CFMFLG=2 & func PORLEGLIB.DOCCTR(9,[F:PNH]BPSNUM,[F:PNH]PNHTYP,[F:PNH]PNHFCY)=1
    Read [F:PTDKD]DKD0 = "SAFT-PT";[M:PNH1]PNHTYP;[M:PNH1]PNHNUM
    # BRBAN 24-03-2015 #106027
    If !fstat & [F:PTDKD]ATDTCOD = "" & func PORLEGLIB1.CTRL_COMDAT([F:PNH]PNHFCY,[F:PNH]DPEDATR,[F:PNH]ETDR)=1
       CHMEN += "U"
    Endif
  Endif
Endif

#----- Après touche f5 réactualisation de la liste de picking -----#
#-------------------------------------------------------------------------#
# N'est plus nécessaire car effectué par l'appel de l'action AP_FILGAUCHE #
#-------------------------------------------------------------------------#
# If num$(REPONSE)="1799" WPICK=2 : Gosub ACTUALIS_MARQUAGE : Endif
Return


$AVANTBOUT
#------------------------------#
# Avant exécution des boutons  #
# ---------------------------- #
# 1 = Complément               #
# 2 = Validation               #
#                              #
# F = Texte entête             #
# G = Texte pied               #
# H = Adresse fournisseur      #
# I = Critères picking         #
# J = Informations douanières  #
# K = Sections analytiques     #
# L = Consultation des retours #
# M = Transaction              #
#------------------------------#
Local  Integer  SAV_GCONSULT : SAV_GCONSULT=GCONSULT
GPNH_VERROU=VERROU : Raz SYMBOL2
If [M:PNH1]PNHNUM<>"" & GPNH_VERROU=0 & find(BOUT,"1","2","H","I","J","K")
  SYMBOL2="PNH"+[M:PNH1]PNHNUM : Lock=SYMBOL2
  If !fstat  GPNH_VERROU=1  Else  Raz SYMBOL2 : Endif
Endif
#-----
Case BOUT
  When "2"     : Gosub AVANTBOUT_VAL
  When "F","G" : If GREP="" & dim(ACTMOD)>0 & !ACTMOD  GCONSDIA=2 : Endif
  When "H"     : # If GREP="" & (!ACTMOD | !VERROU)  GCONSULT=1 : Endif
  When "I"     : If [M:PNH1]PNHFCY=""|[M:PNH1]RTNDAT=[0/0/0]|[M:PNH1]BUY=""|[M:PNH1]CFMFLG=2
                   GERR=1 : GMESSAGE=mess(219,194,1) : OK=0
                 Endif
  When "J","K" : Local  Integer WEXEFLG : WEXEFLG=4
  # - 101090 - Bill of lading menu, setting creation mode
  When "B"     : If [M:PNHC]BOLNUM=""
                  If [F:PNH]BPTNUM="" | [F:PNH]MDL=""
                    GMESSAGE = mess(3,2086,1)   # The carrier and/or delivery method are blank
                    GERR=1
                  Else
                    GCREFONC=1
                  Endif
                 Endif
Endcase
If !OK & SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Return


$AVANTBOUT_VAL
#-------------------------#
# Avant bouton validation #
#-------------------------#
Local Integer WSTA
Local Char    WCPY(GLONCPY)
Local Integer WNBR, LRET : LRET=0
#----- Vérification des droits -----#
GBIDC2="V" : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  GERR=1 : GMESSAGE=mess(2,104,1): OK=0 : Return : Endif
#----- Retour déja validé ! -----#
If [F:PNH]CFMFLG=2
  GMESSAGE=mess(127,100,1) : GERR=1 : OK=0 : Return
Endif
#----- Contrôle numéro d'autorisation renseigné ? -----#
If [F:PNH]AUZNUM="" & GPURRMA=2
  OK=2 : Call OUINON (mess(124,194,1),OK) From GESECRAN
  If OK=1  OK=0 : Return Else OK=1 : Endif
Else
  OK=2 : Call AVERTIR(mess(156,196,1),OK) From GESECRAN
  If OK=1  OK=0 : Return Else OK=1 : Endif
Endif
If clalev([F:PER])=0  Local File PERIOD   [PER] : Endif
If clalev([F:FCY])=0  Local File FACILITY [FCY] : Endif
If [F:PNH]PNHFCY<>[F:FCY]FCY
  Read [FCY] FCY0=[F:PNH]PNHFCY : If fstat  Raz [F:FCY] : Endif
Endif
WSTA=0
WCPY = [F:FCY]LEGCPY
For [PER]PER0 Where CPY=WCPY
  If [F:PNH]RTNDAT>=[F:PER]PERSTR & [F:PNH]RTNDAT<=[F:PER]PEREND
    WSTA=[F:PER]PERSTOSTA : Break
  Endif
Next
#----- Message : période indéfinie ou traitement interdit à cette date -----#
If WSTA<>1
  GERR=1 : GMESSAGE=mess(21,196,1) : OK=0 : Return
Endif
Gosub OPEN_FILE From FUNPNHTRT
# Issue 92294 - 2013-09-04 by MUARN : Seulement habilitation Validation, sans modification
#If !VERROU  OK=0 : GMESSAGE=mess(10,100,1) : GERR=1 : Return : Endif
Return


$EXEBOUT
#------------------------------------#
# Après exécution des boutons du bas #
# 1 = Complément                     #
# 2 = Validation                     #
#------------------------------------#
If SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Case BOUT
  When "1"  : Gosub APRESBOUT_COMPLE
  When "2"  : Default File [PNH] : Filter [PNH] : Filter [PND]
              If func PORLEGLIB.DIGSIGN([M:PNH1]PNHFCY, "") : CLECUR1 = [M:PNH1]PNHNUM : Endif #85785
Endcase
Gosub RELIT From GOBJSUB
Return


$APRESBOUT_COMPLE
#----------------------------------------#
# Après exécution du bouton "Complément" #
#----------------------------------------#
If [F:PNH]PNHNUM<>[M:PNH1]PNHNUM
  Read [PNH] PNH0=[M:PNH1]PNHNUM : If fstat  Raz [F:PNH] : Endif
Endif
Local Integer ACTFLDS : [L]ACTFLDS = 1
If func AFNC.ACTIV("KPO") > 0
  If  !([M:PNHC]MANDOCR      =[F:PNH]MANDOCR       &
&     [M:PNHC]ATDTCODR       =[F:PNH]ATDTCODR)
      [L]ACTFLDS = 0
  Endif
Endif
#----- Pas de mise à jour si rien n'a été modifié -----#
# FGR 18/07/2014 : X3SUIVI91606 : LICPLATER TRLLICPLATER DPEDATR ETDR ARVDATR ETAR
If [M:PNHC]BPSINV        =[F:PNH]BPSINV       &
&  [M:PNHC]BPAINV        =[F:PNH]BPAINV       &
&  [M:PNHC]BPRPAY        =[F:PNH]BPRPAY       &
&  [M:PNHC]BPAPAY        =[F:PNH]BPAPAY       &
&  [M:PNHC]MDL           =[F:PNH]MDL          &
&  [M:PNHC]BPTNUM        =[F:PNH]BPTNUM       &
&  [M:PNHC]TOTGROWEI     =[F:PNH]TOTGROWEI    &
&  [M:PNHC]WEU           =[F:PNH]WEU          &
&  [M:PNHC]TOTNETWEI     =[F:PNH]TOTNETWEI    &
&  [M:PNHC]TOTVOL        =[F:PNH]TOTVOL       &
&  [M:PNHC]VOU           =[F:PNH]VOU          &
&  [M:PNHC]REM           =[F:PNH]REM          &
&  [M:PNHC]LICPLATER     =[F:PNH]LICPLATER    &
&  [M:PNHC]TRLLICPLATER  =[F:PNH]TRLLICPLATER &
&  [M:PNHC]DPEDATR       =[F:PNH]DPEDATR      &
&  [M:PNHC]ETDR          =[F:PNH]ETDR         &
&  [M:PNHC]ARVDATR       =[F:PNH]ARVDATR      &
&  [M:PNHC]ETAR          =[F:PNH]ETAR         &
&  [L]ACTFLDS            =1
  Return
Endif
#----- Mise à jour de l'entête de retour -----#
Call DEBTRANS From GLOCK
$TR_COMPLE
Trbegin [PNH]
  If [F:PNH]BPSINV<>[M:PNHC]BPSINV | [F:PNH]BPAINV<>[M:PNHC]BPAINV
    Update [PND] Where PNHNUM=[M:PNH1]PNHNUM With BPSINV=[M:PNHC]BPSINV, BPAINV=[M:PNHC]BPAINV
    If fstat GOK=0 : Call FSTA("PND") From GLOCK : Goto AB_COMPLE : Endif
  Endif
  Readlock [PNH] PNH0=[M:PNH1]PNHNUM
  If fstat=1
    GOK=-1 : GLOCK="$PRETURN"-[M:PNH1]PNHNUM            : Goto ROLL_COMPLE
  Elsif fstat
    GOK=0  : Call RSTA("PNH",[M:PNH1]PNHNUM) From GLOCK : Goto AB_COMPLE
  Endif
  # BRBAN 24/07/2014 SAM #93745 US2
  # If the document is posted and communicated, it should allways have the same code as DKD
  If func AFNC.ACTIV("KPO") > 0
    If [F:PNH]CFMFLG=2
      Read [F:PTDKD]DKD0="SAFT-PT";[F:PNH]PNHTYP;[F:PNH]PNHNUM
      If [F:PTDKD]ATDTCOD <> ''
        [M:PNHC]ATDTCODR = [F:PTDKD]ATDTCOD
        Affzo [M:PNHC]ATDTCODR
      Endif
    Endif
  Endif
  #-
  [F:PNH]=[M:PNHC]
  Rewrite [PNH]
  If fstat GOK=0 : Call FSTA("PNH") From GLOCK : Goto AB_COMPLE : Endif
Commit
Return
#-----
$ROLL_COMPLE
Rollback : Call ROLL From GLOCK
If GROLL  Return  Else  Goto TR_COMPLE : Endif
#-----
$AB_COMPLE
Rollback
Return


$STATUT
#-------------------------------------------#
# Après exécution des boutons de la ToolBar #
# F = Texte entête                          #
# G = Texte pied                            #
# H = Adresse fournisseur                   #
# I = Critères picking                      #
# J = Informations douanières               #
# K = Sections analytiques                  #
# L = Consultation des retours              #
# M = Transaction                           #
#-------------------------------------------#
If SYMBOL2<>""  Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Case BOUT
  When "F"  : Gosub APRESBOUT_TEXTE
  When "G"  : Gosub APRESBOUT_TEXTE
  When "H"  : [M:PNH1]BPAADD=[M:AD65]BPAADD : Affzo [PNH1]BPAADD
              If !GCONSULT & GREP="" Gosub APRESBOUT_ADR : Endif
  When "I"  : Gosub TIROIR
  When "J"  : Gosub ACTIV_GSTAENR
  When "K"  : If mkstat=4  WEXEFLG=9 : mkstat=0 : Gosub ACTIV_GSTAENR : Endif
Endcase
GCONSULT=SAV_GCONSULT
Return
#----- Activation du bouton enregistrer -----#
$ACTIV_GSTAENR
If GREP="" & WEXEFLG=9
  Gosub ENTRE_MODIF From GOBJSUB
Endif
Return


$APRESBOUT_TEXTE
#--------------------------------#
# Texte entête et pied de retour #
#--------------------------------#
If mkstat=4 & GREP="" : # Texte modifié
  Gosub ENTRE_MODIF From GOBJSUB
Endif
#----- Affichage icone texte -----#
If !GIMPORT
  If GREP="" & ([M:PNH1]TEX1<>"" | [M:PNH1]TEX2<>"")
    Call SET_IMAGE(4)   From GESECRAN
  Else
    Call RESET_IMAGE(4) From GESECRAN
  Endif
Endif
Return


$APRESBOUT_ADR
#-----------------------------------#
# Après exécution du bouton adresse #
#-----------------------------------#
If [M:AD65]ADBFLG=0 & GACTSAD<>2  [M:AD65]BPAADD=[F:PNH]BPAADD : Return : Endif
#----- Mise à jour entête de retour -----#
Call DEBTRANS From GLOCK
$TR_ADR
Trbegin [PNH]
  Readlock [PNH] PNH0=[M:PNH1]PNHNUM
  If fstat=1
    GOK=-1 : GLOCK="$PRETURN"-[M:PNH1]PNHNUM            : Goto ROLL_ADR
  Elsif fstat
    GOK=0  : Call RSTA("PNH",[M:PNH1]PNHNUM) From GLOCK : Goto AB_ADR
  Endif
  If [M:AD65]ADBFLG=1  [F:PNH]BPAADD=[M:AD65]BPAADD : Endif
  Gosub CHARG_ADRESSE : # Traitement nom et adresse fournisseur
  Rewrite [PNH]
  If fstat GOK=0 : Call FSTA("PNH") From GLOCK : Goto AB_ADR : Endif
Commit
Gosub DEVERROU From GOBJET : Gosub RELIT From GOBJET
Return
#-----
$ROLL_ADR
Rollback : Call ROLL From GLOCK
If GROLL  Return  Else  Goto TR_ADR : Endif
#-----
$AB_ADR
Rollback
Return


$VERIF_CRE
#--------------------------#
# Vérification en création #
#--------------------------#
Gosub VERIF
Return


$VERIF_MOD
#------------------------------#
# Vérification en modification #
#------------------------------#
Gosub VERIF
Return

$VERF_ANU
#------------------------------#
# Verification of deletion     #
#------------------------------#
# 101090 - Can't delete return if BOL exists
If dim([M:PNHC]BOLNUM)>0 & [M:PNHC]BOLNUM<>""
  GERR=1 : GMESSAGE=func AFNC.MES1(mess(8,2086,1),[M:PNHC]BOLNUM) : OK=0
Endif

Return

$VERIF
Local Shortint RES
Local Integer IFIND # Issue 81918 - 2012-05-23 by MUARN : ligne avec quantité nulle
# VPO 07/12/10 69066 verifier valeur Regime de taxe
# VPO 01/03/11 71999 ameliorer message d'erreur
If [M:PNH1]VACBPR<>""
    mkstat=0
    # 71937 : Multilégislation
    #Call CONTADI([M:PNH1]VACBPR,"1","") From SUBADI
    #If mkstat : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","PNH1~VACBPR")+'"\'+GMESSAGE : Return : Endif
    #Call CONTROLE("ADI","",[M:PNH1]VACBPR,"1",RES) From CONTOBJ
    #If RES : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","PNH1~VACBPR")+'"\'+GMESSAGE : Return : Endif
    Call CONTTVB([M:PNH1]VACBPR,GCURLEG,"PNH1","VACBPR",[M:PNH1]PNHFCY,"","") From SUBTVB
    If mkstat : GERR=1 : OK=0 : GMESSAGE=mess(32,126,1)-'"'+func AFNC.INTCLE("AMZ","PNH1~VACBPR")+'"\'+GMESSAGE : Return : Endif
    # 71937 : Multilégislation
    Endif
#-----------------------------------------------------#
# Contrôle qu'au moins une ligne article a été saisie #
#-----------------------------------------------------#
If [M:PNH1]NBLIG=0
  GERR=1 : GMESSAGE=mess(61,199,1) : SUIZON="NBLIG" : OK=0 : Return
Endif

# Issue 81918- 2012-05-22 by MUARN : ligne quantité nulle
IFIND = find(0,[M:PNH1]QTYUOM(0..[M:PNH1]NBLIG-1))
If  IFIND <>0
 GERR=1 : GMESSAGE=mess(7,194,1) : SUIZON= "NBLIG" : OK=0 : Return
Endif

Call CTLSTOSOR ("PNH1","QTYSTUACT",[M:PNH1]NBLIG,WRET) From STKECR
If WRET  OK=0 : Return : Endif

# Issue 71069 - 2013-08-23 by MUARN : PJT
Call PJT_CONTROLE_HEAD_DETAIL("[M:PNH1]PJTH", "[M:PNH1]PJT") From TRTPJT
If GERR <> 0
  OK = 0
  Return
Endif

# Issue 110704 US5 - 2016-01-08 by BRBAN
If func AFNC.ACTIV("KPO")>0
  If func PORLEGLIB.CTLDOCTYP([M:PNH1]PNHTYP,"PNH",GMESSAGE) = 1
    OK = 0 : GERR = 1 : Return
  Endif
Endif

Return


$HINTCLE
#-----------------------------------------------------------#
# Clé pour optimisation du remplissage des listes de gauche #
#-----------------------------------------------------------#
Case currbox
  When GBOXPT2 : HINTLIS(val(right$(GBOXPT2,8)))="PTD3"
Endcase
Return


$FILGAUCHE
# Issue X3-65722 - 2018-03-05 by SR : Section complètement revue pour :
#Remplissage de FILGAUSUP via ADDCRIT
#Utilisation de CRMUTIL150 pour récupérer les rôles
#----------------------------------------------#
# Filtrer les enregistrements listes de gauche #
#----------------------------------------------#
Raz FILGAUSUP, IFILGAUSUP
If [M:PNH1]PNHFCY<>"" & [M:PNH1]RTNDAT<>[0/0/0] & [M:PNH1]BUY<>"" &
&  [M:PNH1]CFMFLG<2
  If currbox=GBOXPT2   : # Picking des réceptions
    WCRITERE ="[F:PTD]PRHFCY=[M:PNH1]PNHFCY"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    If [M:PCRW]WBPSNUM<>""
      WCRITERE="pat([F:PTD]BPSNUM,[M:PCRW]WBPSNUM)<>0"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Endif
    If [M:PCRW]WITMREF<>""
      WCRITERE="pat([F:PTD]ITMREF,[M:PCRW]WITMREF)<>0"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Endif
    If [M:PCRW]WNUMRCP<>""
      WCRITERE="pat([F:PTD]PTHNUM,[M:PCRW]WNUMRCP)<>0"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Endif
    If [M:PCRW]WNUMCDE<>""
      WCRITERE="pat([F:PTD]POHNUM,[M:PCRW]WNUMCDE)<>0"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Endif
    WCRITERE ="[F:FCY]LEGCPY=GSOCIETE"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    If [M:PCRW]WBPSNDE<>""
      WCRITERE="pat([F:PTH]BPSNDE,[M:PCRW]WBPSNDE)<>0"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Endif
    If GBUYFLT=2
      WCRITERE='([F:ITM]BUY=[M:PNH1]BUY | [F:ITM]BUY="")'
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Endif
    If GPRTNQTY=1 : # Articles non gérés (qtés R ou A+R suivant paramètre GPRTNQTY)
      WCRITERE=" (([F:PTD]STOMGTCOD<2 & [F:PTD]RRRQTYSTU-[F:PTD]RTNQTYSTU>0)"
      WCRITERE+=" | ([F:PTD]STOMGTCOD>1 & [F:PTD]QTYSTU-[F:PTD]RTNQTYSTU>0))"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Else          : # Articles gérés (qtés A+Q+R) sera affiné plus tard par règle gestion
      WCRITERE="([F:PTD]QTYPUU-[F:PTD]RTNQTYPUU>0"
      WCRITERE+=" | [F:PTD]QTYSTU-[F:PTD]RTNQTYSTU>0)"
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Endif
    WCRITERE="[F:PTD]LINTYP<3"
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    # Issue 71069 - 2013-08-23 by MUARN : PJT
    If ([M:PNH1]NBLIG > 0 | ([M:PNH1]NBLIG = 0 & [M:PNH1]PJTH <> "")) & GPJTSNGDOC = G_OUI
      WCRITERE='[F:PTD]PJT=[M:PNH1]PJTH'
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
    Endif
    Call AJOUTE_CONDITION_ROLE(FILGAUSUP,IFILGAUSUP,"PTH") From CRMUTIL150
  Endif
Elsif currbox=GBOXPT2
  WCRITERE="[F:PTD]PRHFCY=''"
  Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", WCRITERE, "&") From GOBJSUB
Endif
Return


$AP_FILGAUCHE
#---------------------------------------------------------#
# Après pagination avant ou arrière d'une liste de gauche #
#---------------------------------------------------------#
If !find(currbox,GBOXPT2) Return : Endif
WPICK=2 : Gosub ACTUALIS_MARQUAGE
Return


$TIROIR
#---------------------------------------------------#
# Click sur un tiroir                               #
# Désormais entièrement géré par l'objet :          #
# - le remplissage                                  #
# - et l'actualisation (boules bleues)              #
#   par l'appel à la suite de l'action AP_FILGAUCHE #
# ------------------------------------------------- #
# Autres appels par l'applicatif dans les cas       #
# d'abandon, d'après création, d'après modif ...etc #
#---------------------------------------------------#
If currbox<>GBOXPT2  Return : Endif
#-----
ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB
Return


$DEB_PICK
#---------------#
# Début picking #
#---------------#
If currbox=GBOXPT2
  SAVNBLIG=[M:PNH1]NBLIG
Endif
GPNH_PICK=1
Return


$PICKE
#----------------------#
# Nouvel élément pické #
#----------------------#
Local Char SWPJTMSG(250)  # Issue 71069 - 2013-08-23 by MUARN : PJT
If currbox=GBOXPT2
  If REP=""
    If !CLECUR | !VERROU | !ACTMOD | GCONSULT  OK=0 : Return : Endif
  Endif
  Gosub PICKE_RCP  From SUBPNHB
  Gosub GRISAGE
Endif
Return


$DEPICK
#------------------------#
# Nouvel élément dépické #
#------------------------#
If currbox=GBOXPT2
  Gosub DEPICK_RCP  From SUBPNHB
  Gosub GRISAGE
Endif
Return


$FIN_PICK
#-------------#
# Fin picking #
#-------------#
GPNH_PICK=0
If REP=""
  If !VERROU
    GMESSAGE=mess(10,100,1) : GERR=1 : OK=0 : Return
  Elsif !CLECUR | !ACTMOD | GCONSULT
    GMESSAGE=mess(9,123,1)  : GERR=1 : OK=0 : Return
  Endif
Endif
If WPICK=9  WPICK=2 : Gosub TIROIR : Endif : # Picking actualisé après sélection fournisseur
Affzo [PNH1]15
zonsui="[M:PNH1]NBLIG(max(0,nolign-1))"
Return


$GRISAGE
#-----------------------------------------------------#
# Traitement du grisage et dégrisage des champs écran #
#-----------------------------------------------------#
If [M:PNH1]NBLIG=0 & GREP="C"
  If GNBAUZ>1 Actzo [PNH1]PNHFCY : Endif
  Actzo [PNH1]BUY, BPSNUM
Else
  If GNBAUZ>1 Diszo [PNH1]PNHFCY : Endif
  Diszo [PNH1]BUY, BPSNUM
Endif
Return


$ACTUALIS_MARQUAGE
#---------------------------------------------------------------#
# Actualisation des éléments "pickés" dans les listes de gauche #
# WPICK : 0 = On ne fait rien                                   #
#         1 = Enlever le marquage des éléments "pickés"         #
#         2 = Marquer les éléments "pickés"                     #
#---------------------------------------------------------------#
If [M:PNH1]NBLIG>0
  Raz I
  While I<[M:PNH1]NBLIG
    Gosub MARQUAGE_LIGNE
    I=I+1
  Wend
Endif
Return


$MARQUAGE_LIGNE
#--------------------------------------------------------------#
# Actualisation d'un élément "pické" dans les listes de gauche #
# WPICK : 0 = On ne fait rien                                  #
#         1 = Enlever le marquage de l'élément "pické"         #
#         2 = Marquer l'élément "pické"                        #
#     I : indice de la ligne du tableau à traiter              #
#--------------------------------------------------------------#
#----- Si appel depuis Subprog (C_NBLIG.. etc) les variables locales n'existent pas !
If dim(FILGAUSUP)<1
  #----- Variables locales superviseur -----#
  Local Integer FILTREG : FILTREG=1
  Local Integer INDCUR  : INDCUR=1
  Local Integer ICRITERE, IFILROLE, IFILSUITE, IFILGAUSUP
  Local Char    FILTSUP(240), FILROLE(250)(0..2) , FILSUITE(250)(0..5), CRITERE(250)
  Local Char    FILGAUSUP(240)(0..3)
  Local Char    WINPROG(GLONADC), ACTION(20) : WINPROG="WGOPNH"
  Local Char    HINTLIS(10)(0..8)
  #-----
  HINTLIS(val(right$(GBOXPT2,8)))="PTD3"
  #----- Variables locales pour gestion picking liste de gauche -----#
  Local Shortint J
  Local Integer  WLIN
  Local Char     WNUM(GLONVCR)
Endif
#-----
If [M:PNH1]PTHNUM(I)<>"" : # & [M:PNH1]CREFLG(I)=0
  J=WPICK
  WNUM=[M:PNH1]PTHNUM(I) : WLIN=[M:PNH1]PTDLIN(I)
  Read [PTD] PTD0=WNUM;WLIN     : If fstat Raz [F:PTD] : Endif
  Read [PTH] PTH0=[F:PTD]PTHNUM : If fstat Raz [F:PTH] : Endif
  Read [FCY] FCY0=[F:PTD]PRHFCY : If fstat Raz [F:FCY] : Endif
  Read [ITM] ITM0=[F:PTD]ITMREF : If fstat Raz [F:ITM] : Endif
  If [F:PTH]PTHNUM="" & [F:FCY]FCY="" & [F:ITM]ITMREF="" WPICK=0 : Endif
  If currbox=GBOXPT2
    Case WPICK
      When 1 : Gosub DEPICK From GOBJSUB
      When 2 : Gosub REPICK From GOBJSUB
    Endcase
  Endif
  WPICK=J
Endif
Return


$APRES_MODIF
#------------------------------------#
# Après modification de chaque champ #
#------------------------------------#
If currbox<>GBOXPT2 Return : Endif
# Issue 71069 - 2013-08-23 by MUARN : PJT
If !find(COUZON,"PNHFCY","BUY","BPSNUM","PJTH") | GIMPORT Return : Endif
If COUZON="PNHFCY" [M:PNH1]PNHFCY=CZ : Endif
If COUZON="BUY"    [M:PNH1]BUY=CZ    : Endif
# Issue 71069 - 2013-08-23 by MUARN : PJT
If COUZON="PJTH" [M:PNH1]PJTH=CZ : Endif
If FILGAUSUP(0)<>"[F:PTD]PRHFCY=''" | [M:PCRW]WBPSNUM<>"" | COUZON ="PJTH"
  Gosub TIROIR
Endif
Return


$INICRE
#---------------------------#
# Chargement avant le Write #
#---------------------------#
If GMANCOU<>2 | (GMANCOU=2 & vireblc([M:PNH1]PNHNUM,2)="")
  If func AFNC.ACTIV("TRSNE") > 0
    Call NUMERO(GCPT,GFCY,[M:PNH1]RTNDAT,"",[M:PNH1]PNHNUM,WRET) From SUBANM #85785
  Else
    Call NUMERO(GCODNUM,GFCY,[M:PNH1]RTNDAT,"",[M:PNH1]PNHNUM,WRET) From SUBANM
  Endif
  If GOK<0
    Return
  Elsif GOK<1 | WRET<>0
    GOK=0 : GERR=1 : GMESSAGE=GCODNUM-mess(60,199,1)
    Return
  Endif
  [F:PNH]PNHNUM=[M:PNH1]PNHNUM
Endif
# Alimentation dépôt entête si mono-dépôt
If dim([M:PNH1]WRHE)>0 & GWRHOBY=2
  [F:PNH]WRHE = [M:PNH1]WRHE
Else
  [F:PNH]WRHE = ""
Endif
[F:PNH]LINNBR = [M:PNH1]NBLIG
[F:PNH]CPY=GSOCIETE
[F:PNH]CFMFLG = 1
[F:PNH]PURTYP = 1
[F:PNH]PRNFLG = 1
[F:PNH]PSTFLG = 1
Gosub CHARG_ADRESSE : # Traitement nom et adresse fournisseur
[F:PNH] = [M:PNHC]
#----- Récupération informations douanières de la réception -----#
#--- CPO 72237 Le champ EECNUM est soumis à code activité (par le bloc dans le [M:PCEE])
If GACTDEB=2 and dim([M:PCEY]EECNUM)> 0
  If [M:PNH1]PTHNUM(0)<>"" & (!GIMPORT | [M:PCEY]EECNUM="")
    Read [PTH] PTH0=[M:PNH1]PTHNUM(0)
    If !fstat
      [M:PCEY]EECNUM=[F:PTH]EECNUM
    Endif
  Endif
Endif
[F:PNH] = [M:PCEY]
#----- Création ou duplication des textes entête et pied -----#
Gosub CHARG_TEXT_ENTETE
#----- Initialisation des régimes et natures CEE -----#
#If !GIMPORT & dim([F:PNH]EECSCH)>0  : # Bug 73295
If !GIMPORT & GACTDEB=2              : # Bug 73295
  Call INICRE_EEC("PNH",GBIDI2,[F:PNH]EECNAT,[F:PNH]EECSCH,GBIDI3,GBIDC2,GBIDC3) From FUNDEBA
Endif
Return


$INICRE_LIG
#----------------------------#
# Avant le Write de la ligne #
#----------------------------#
Local Shortint NOL : NOL=nolign-1
[M:PNH1]PNDLIN(NOL)=[F:PND]PNDLIN : # Renumérotation de 1000 en 1000 en création !
[F:PND]BPSINV=[F:PNH]BPSINV
[F:PND]BPAINV=[F:PNH]BPAINV
If [F:PND]LININVFLG=0  [F:PND]LININVFLG=1 : Endif
If [F:PND]LINPSTFLG=0  [F:PND]LINPSTFLG=1 : Endif
If GACTDEB=2
  If [F:PND]LINEECFLG=0 [F:PND]LINEECFLG=1 : Endif
Endif
[F:PND]PNHNUM=[M:PNH1]PNHNUM
[F:PND]RTNDAT=[M:PNH1]RTNDAT
[F:PND]CPY=GSOCIETE
# Alimentation dépôt ligne si renseigné
If dim([M:PNH1]WRH)>0 & [M:PNH1]WRH(NOL)<>""
  [F:PND]WRH = [M:PNH1]WRH(NOL)
Else
  [F:PND]WRH = ""
Endif
#----- Chargement codes stat article, taxe, axes et flag attente avoir -----#
If dim([M:PNH1]TSICOD1(NOL))>0 [F:PND]TSICOD(0)=[M:PNH1]TSICOD1(NOL) : Endif
If dim([M:PNH1]TSICOD2(NOL))>0 [F:PND]TSICOD(1)=[M:PNH1]TSICOD2(NOL) : Endif
If dim([M:PNH1]TSICOD3(NOL))>0 [F:PND]TSICOD(2)=[M:PNH1]TSICOD3(NOL) : Endif
If dim([M:PNH1]TSICOD4(NOL))>0 [F:PND]TSICOD(3)=[M:PNH1]TSICOD4(NOL) : Endif
If dim([M:PNH1]TSICOD5(NOL))>0 [F:PND]TSICOD(4)=[M:PNH1]TSICOD5(NOL) : Endif
[F:PND]VAT(0)=[M:PNH1]VAT1(NOL)
[F:PND]VAT(1)=[M:PNH1]VAT2(NOL)
[F:PND]VAT(2)=[M:PNH1]VAT3(NOL)
[F:PND]LINPRNFLG = 1
[F:PND]LINPSTFLG = 1
If [M:PNH1]AVOFLG(NOL)=2
  [F:PND]LININVFLG=1
Else
  [F:PND]LININVFLG=2 : [M:PNH1]INVLINNBR+=1
Endif
#----- Récupération prix de revient et devise et coeff d'approche -----#
Read [PTD] PTD0=[M:PNH1]PTHNUM(NOL);[M:PNH1]PTDLIN(NOL) : If fstat Raz [F:PTD] : Endif
[F:PND]CPRCUR=[F:PTD]CPRCUR
[F:PND]CPR   =[F:PTD]CPR
[F:PND]CPRCOE=[F:PTD]CPRCOE
#----- Création ou duplication du texte ligne -----#
Gosub CHARG_TEXT_LIGNE
Return


$VALLIG
#----------------------------------------------------------------------#
# Traitements complémentaires ligne retour                             #
# SIGN vaut +1 en création ou modification                             #
#      vaut -1 en annulation (TRTLIG="A") ou avant modif. (TRTLIG="M") #
#----------------------------------------------------------------------#
If dim(NOL)<0  Local Shortint NOL : Endif
NOL=nolign-1
#----- Lecture article si nécessaire -----#
If [F:ITM]ITMREF<>[F:PND]ITMREF
  Read [ITM] ITM0=[F:PND]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
#-----
Case SIGN
  When  1 : Gosub MODCRELIG
  When -1 : Gosub MODSUPLIG
  When Default
Endcase
#----- Mise à jour statistiques ligne retour -----#
Call VALSTA("PND",SIGN) From SUBPS2 : If GOK<1 Return : Endif
Return


$MODCRELIG
#------------------------------------------------------#
# Après Write ou Rewrite de la ligne de retour [F:PND] #
#------------------------------------------------------#
#----- Ecriture des comptes et sections de la ligne de retour -----#
Call ENREG_ACCCCE(nolign-1,"[M:PNH1]LINACC","[M:PNH1]LINDSP","[M:PNH1]CCE","PND",
&                 0,[F:PND]PNHNUM,[F:PND]PNDLIN,0,"",TRTLIG) From TRTX3CPT
If GOK<1  Return : Endif
#----- Article géré en stock et création ligne -----#
If [F:PND]STOMGTCOD>1 & [F:PND]LINTYP<3 & TRTLIG="C"
  #----- Création des allocations -----#
  WRET=1 : Gosub CHARG_ALLPAR From SUBPNH
  Call ENRSTOALL ([M:PNH1]WSTOSEQ(nolign-1),0,WRET) From STKALL
  If WRET  GOK=0 : Return : Endif
Endif
#----- Mise à jour du flag facturé -----#
Case [M:PNH1]AVOFLG(nolign-1)
  When 2 : #----- Attente d'avoir
    If [F:PND]LININVFLG=2 : # Si flag facturé était OUI
      [F:PND]LININVFLG=1
      [M:PNH1]INVLINNBR-=1
    Endif
  When 1 : #----- Pas d'attente d'avoir
    If [F:PND]LININVFLG=1 : # Si flag facturé était NON
      [F:PND]LININVFLG=2
      [M:PNH1]INVLINNBR+=1
    Endif
Endcase
If [M:PNH1]PTHNUM(nolign-1)<>"" & [M:PNH1]PTDLIN(nolign-1)>0
  If [M:PNH1]PTHNUM(nolign-1)<>[F:PTD]PTHNUM
     Read [PTD]PTD0=[M:PNH1]PTHNUM(nolign-1);[M:PNH1]PTDLIN(nolign-1)
     If fstat : Raz [F:PTD] : Endif
  Endif
  # GA 03/2006 cas particulier achat de sous-traitance
  If find([F:PTD]VCRTYPORI,10,36) & [F:PTD]LINTYP<3
    # Retour de réception de sous-traitance
    Gosub CRELIG From SUBPNHC
  Endif
Endif
Return


$MODSUPLIG
#-------------------------------------------------------#
# Avant Delete ou Rewrite de la ligne de retour [F:PND] #
#-------------------------------------------------------#
If dim(WQTE1) <0  Local Decimal  WQTE1  : Endif
If dim(WQTE2) <0  Local Decimal  WQTE2  : Endif
If dim(WRET)  <0  Local Integer  WRET   : Endif
If TRTLIG="A"
  #----- Suppression comptes et sections de la ligne de retour -----#
  Call ENREG_ACCCCE(0,"","","","PND",0,[F:PND]PNHNUM,[F:PND]PNDLIN,0,"","A") From TRTX3CPT
  If GOK<1  Return : Endif
  #-----
  If [F:PND]LININVFLG=2 [M:PNH1]INVLINNBR-=1 : Endif
  #----- Suppression des allocations -----#
  If [F:PND]STOMGTCOD>1 & [F:PND]LINTYP<3 : # Article géré en stock et suppression ligne
    WRET=1 : Gosub CHARG_ALLPAR From SUBPNH
    [M:ALP]QTY=0
    Call ENRSTOALL (0,0,WRET) From STKALL
    If WRET  GOK=0 : Return : Endif
  Endif
  #----- Suppression du texte ligne si nécessaire -----#
  If left$([F:PND]LINTEX,3)="PND"
    Call SUP_CLOB([F:PND]LINTEX,GBIDI1) From TRTX3TEX
  Endif
#----- Article géré en stock et modification ligne -----#
Elsif [F:PND]STOMGTCOD>1 & [F:PND]LINTYP<3
  #----- Màj des allocations -----#
  If [M:PNH1]WSTOSEQ(nolign-1)<>0
    WRET=1 : Gosub CHARG_ALLPAR From SUBPNH
    Call ENRSTOALL ([M:PNH1]WSTOSEQ(nolign-1),0,WRET) From STKALL
    If WRET  GOK=0 : Return : Endif
  Endif
Endif
If TRTLIG="M"
  #----- Cas particulier où l'on modifie le texte en le supprimant -----#
  If [M:PNH1]LINTEX(nolign-1)="" & left$([F:PND]LINTEX,3)="PND"
    Call SUP_CLOB([F:PND]LINTEX,GBIDI1) From TRTX3TEX
  Endif
Endif
If [M:PNH1]PTHNUM(nolign-1)<>"" & [M:PNH1]PTDLIN(nolign-1)>0
  If [M:PNH1]PTHNUM(nolign-1)<>[F:PTD]PTHNUM
     Read [PTD]PTD0=[M:PNH1]PTHNUM(nolign-1);[M:PNH1]PTDLIN(nolign-1)
     If fstat : Raz [F:PTD] : Endif
  Endif
  # GA 03/2006 cas particulier achat de sous-traitance
  If find([F:PTD]VCRTYPORI,10,36) & [F:PTD]LINTYP<3
    # Retour de réception de sous-traitance
    Gosub SUPLIG From SUBPNHC
  Endif
Endif
Return


$INIMOD_LIG
#------------------------------#
# Avant le Rewrite de la ligne #
#------------------------------#
If [F:ITM]ITMREF<>[F:PTD]ITMREF
  Read [ITM] ITM0=[F:PTD]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
[F:PND]RTNDAT=[M:PNH1]RTNDAT
#----- Chargement codes stat article, taxe, axes et flag attente avoir -----#
If dim([M:PNH1]TSICOD1(NOL))>0 [F:PND]TSICOD(0)=[M:PNH1]TSICOD1(NOL) : Endif
If dim([M:PNH1]TSICOD2(NOL))>0 [F:PND]TSICOD(1)=[M:PNH1]TSICOD2(NOL) : Endif
If dim([M:PNH1]TSICOD3(NOL))>0 [F:PND]TSICOD(2)=[M:PNH1]TSICOD3(NOL) : Endif
If dim([M:PNH1]TSICOD4(NOL))>0 [F:PND]TSICOD(3)=[M:PNH1]TSICOD4(NOL) : Endif
If dim([M:PNH1]TSICOD5(NOL))>0 [F:PND]TSICOD(4)=[M:PNH1]TSICOD5(NOL) : Endif
[F:PND]VAT(0)=[M:PNH1]VAT1(NOL)
[F:PND]VAT(1)=[M:PNH1]VAT2(NOL)
[F:PND]VAT(2)=[M:PNH1]VAT3(NOL)
#----- Gestion du flag "attente d'un avoir" -----#
If [M:PNH1]AVOFLG(nolign-1)=2
  If [F:PND]LININVFLG=2
    [F:PND]LININVFLG=1 : [M:PNH1]INVLINNBR-=1
  Endif
Else
  If [F:PND]LININVFLG=1
    [F:PND]LININVFLG=2 : [M:PNH1]INVLINNBR+=1
  Endif
Endif
#----- Création ou duplication du texte ligne -----#
Gosub CHARG_TEXT_LIGNE
Return


$CREATION
#-------------------------------#
# Création des lignes de retour #
#-------------------------------#
Gosub CREATION From TABLEAUX
If GOK<1 : Return : Endif
#----- Mise à jour statistiques entête retour -----#
SIGN=1 : Call VALSTA("PNH",SIGN) From SUBPS2 : If GOK<1 Return : Endif
Return


$APRES_CRE
#-------------------------------------------------------------#
# Effacement fichier de travail et affichage numéro de retour #
#-------------------------------------------------------------#
Affzo [PNH1]PNHNUM
Gosub LIENS From TABLEAUX
Diszo [PNH1]BPAADD
#----- Affichage icone texte sauf en import -----#
If !GIMPORT
  If [M:PNH1]TEX1<>"" | [M:PNH1]TEX2<>""
    Call SET_IMAGE (4)   From GESECRAN
  Else
    Call RESET_IMAGE (4) From GESECRAN
  Endif
  # Issue X3-74330 - 2018-05-18 by SR : A faire après MAJ_INVFLG_PNH afin de ne pas perdre [M:PNH1]INVLINNBR
  ## Issue 120772 - 2017-01-10 by MUARN : Perte informations douanières
  #Gosub RELIT From GOBJSUB
Endif
Gosub MAJ_INVFLG_PNH : # Màj indicateur facturé, est-ce nécessaire ?
#----- Mise à jour des listes de gauche picking -----#
# Issue X3-74330 - 2018-05-18 by SR : Faire le RELIT ici
If !GIMPORT : Gosub RELIT From GOBJSUB :  Gosub TIROIR : Endif
Return


$AB_CREATION
#-------------------------------------------#
# Abandon de la création suite à une erreur #
#-------------------------------------------#
Call DELSTOSORW (-1,0,"PNH1",[M:PNH1]PNHFCY,WRET) From STKSOR
Return


$APRES_MOD
#------------------------------------------------------------------------#
# Après modification : effacement fichier travail et rechargement lignes #
#------------------------------------------------------------------------#
Gosub LIENS From TABLEAUX
#----- Affichage icone texte sauf en import -----#
If !GIMPORT
  If [M:PNH1]TEX1<>"" | [M:PNH1]TEX2<>""
    Call SET_IMAGE (4)   From GESECRAN
  Else
    Call RESET_IMAGE (4) From GESECRAN
  Endif
Endif
Gosub MAJ_INVFLG_PNH : # Màj indicateur facturé, est-ce nécessaire ?
#----- Mise à jour des listes de gauche picking -----#
# Issue X3-74330 - 2018-05-18 by SR : Faire le RELIT afin de recharger l'écran
If !GIMPORT : Gosub RELIT From GOBJSUB : Gosub TIROIR : Endif
Return


$AB_MODIF
#-----------------------------------------------#
# Abandon de la modification suite à une erreur #
#-----------------------------------------------#
Return


$AVANT_MODFIC
#---------------------------------------------------------------#
# Avant chargement des nouvelles valeurs dans la classe [F:PNH] #
#---------------------------------------------------------------#
#----- Cas particulier où l'on modifie le texte en le supprimant -----#
If [M:PNH1]TEX1="" & left$([F:PNH]TEX1,3)="PNH"
  Call SUP_CLOB([F:PNH]TEX1,GBIDI1) From TRTX3TEX
Endif
If [M:PNH1]TEX2="" & left$([F:PNH]TEX2,3)="PNH"
  Call SUP_CLOB([F:PNH]TEX2,GBIDI1) From TRTX3TEX
Endif
#-----
If [M:PNH1]RTNDAT<>[F:PNH]RTNDAT
  Update [PND] Where PNHNUM=[M:PNH1]PNHNUM With RTNDAT=[M:PNH1]RTNDAT
  If fstat=1
    GOK=-1 : GLOCK="$PRETURND"-[M:PNH1]PNHNUM           : Return
  Elsif fstat
    GOK=0  : Call RSTA("PND",[M:PNH1]PNHNUM) From GLOCK : Return
  Endif
Endif

# Réalimenter [M]WRHE avec [F]WRHE pour ne pas écraser le mono-dépôt
If dim([M:PNH1]WRHE)>0
   [M:PNH1]WRHE = [F:PNH]WRHE
Endif

#----- Mise à jour statistiques entête retour -----#
Local Integer SIGN
SIGN=-1 : Call VALSTA("PNH",SIGN) From SUBPS2 : If GOK<1 Return : Endif
Return


$INIMOD
#-------------------------------------#
# Chargement avant le Rewrite [F:PNH] #
#-------------------------------------#
Gosub CHARG_ADRESSE : # Traitement nom et adresse fournisseur
[F:PNH] = [M:PCEY]
[F:PNH] = [M:PNHC]
[F:PNH]LINNBR = [M:PNH1]NBLIG
If [F:PNH]PSTFLG=0  [F:PNH]PSTFLG=1 : Endif
#----- Création ou duplication des textes entête et pied -----#
Gosub CHARG_TEXT_ENTETE
Return


$MODIF
#--------------------------------#
# Modification des lignes retour #
#--------------------------------#
Gosub MODIF From TABLEAUX : If GOK<1  Return : Endif
#----- Mise à jour statistiques entête retour -----#
SIGN=1 : Call VALSTA("PNH",SIGN) From SUBPS2 : If GOK<1  Return : Endif
Return


$ANNULE
#---------------------------------------------------#
# Annulation de retour : il ne doit pas être validé #
#---------------------------------------------------#
#----- Supression des textes entête et pied -----#
If left$([F:PNH]TEX1,3)="PNH"
  Call SUP_CLOB([F:PNH]TEX1,GBIDI1) From TRTX3TEX
Endif
If left$([F:PNH]TEX2,3)="PNH"
  Call SUP_CLOB([F:PNH]TEX2,GBIDI1) From TRTX3TEX
Endif
#-----
Gosub ANNULE From TABLEAUX
#----- Mise à jour statistiques entête retour -----#
SIGN=-1 : Call VALSTA("PNH",SIGN) From SUBPS2 : If GOK<1 Return : Endif
Return


$AP_ANNULE
#-----------------------------------------#
# Après annulation complète d'une facture #
#-----------------------------------------#
#----- Mise à jour des listes de gauche picking (reporté en FIN_ACTION) -----#
#If !GIMPORT  Raz [M:PNH1] : Endif
Return


$ABANDON
#----------------------------------------------------#
# Abandon création ou modification par l'utilisateur #
#----------------------------------------------------#
Local Shortint SAVGOK : SAVGOK=GOK : # Sauvegarde de GOK
Call DELSTOSORW (-1,0,"PNH1",[M:PNH1]PNHFCY,WRET) From STKSOR
Gosub SUPPRESS_TEX                 : # Suppression des textes entête, pied et lignes
GOK=SAVGOK                         : # Restitution de GOK
#----- Mise à jour des listes de gauche picking -----#
If GREP="C" & !GIMPORT & BOUT="A" Raz [M:PNH1] : Gosub TIROIR : Endif
#----- Effacement message dans la barre de status -----#
If !GIMPORT  Inftxt "" At 2 : Endif
Return


$FIN_ACTION
#--------------------#
# Après toute action #
#--------------------#
If REPONSE=GSTAANU
  #----- Mise à jour des listes de gauche picking après une annulation -----#
  If !GIMPORT & [M:PNH1]PNHFCY=""  Raz CRITERE : Gosub TIROIR : Endif
Endif

# 101090 - Update BOL fields if coming back from BOL button
If dim(BOUT)>0 & BOUT="B" : Call SETUP_BOL : Endif
Return


$FERME
#--------------------------------------------------------------#
# Pour évolution future lorsque l'objet PNH sera avec variante #
# fermeture fichier ligne réception pour éviter un plantage en #
# AVANT_OUVRE lors du changement de transaction par la ToolBar #
#--------------------------------------------------------------#
If dim(OUVFICPTD)>0
  If OUVFICPTD=1
    Close Local File [PTD] : Raz OUVFICPTD
  Endif
Endif
#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
#-----
If clalev([M:AD65])  Close Local Mask [AD65] : Endif
If clalev([M:PCEY])  Close Local Mask [PCEY] : Endif
#-----
If GFONC1="GESPNH"
  Raz GORITITCOL, GMENBOUT, GCONSDIA
Endif
#----- Effacement icone texte sauf en import ou en WEB -----#
If !GIMPORT  Call RESET_IMAGE(4) From GESECRAN : Endif
#----- Suppression variable globale "nom du currbox" -----#
If dim(GBOXPT2)>0
  Kill GBOXPT2
Endif
#----- Suppression autres variables globales -----#
If dim(GPNH_VERROU)>0
  Kill GPNH_VERROU, GPNH_PICK, GPNH_EECFLG, GPNH_CPYCRY, GPNH_POHFCY
Endif
#----- Effacement message dans la barre de status -----#
If !GIMPORT  Inftxt "" At 2 : Endif
Return


$MAJ_INVFLG_PNH
#---------------------------------------------------------------------------#
# Mise à jour du nbre de lignes facturées et de l'indicateur de facturation #
#---------------------------------------------------------------------------#
Call DEBTRANS From GLOCK
$TR_MAJPNH
GOK=1
Trbegin [PNH]
  If [M:PNH1]INVLINNBR=[F:PNH]LINNBR
    [M:PNH1]INVFLG=3
  Elsif [M:PNH1]INVLINNBR=0
    [M:PNH1]INVFLG=1
  Else
    [M:PNH1]INVFLG=2
  Endif
  Update [PNH] Where PNHNUM=[M:PNH1]PNHNUM
&              With  INVLINNBR=[M:PNH1]INVLINNBR, INVFLG=[M:PNH1]INVFLG
  If fstat=1  GOK=-1 : OK=0 : GLOCK="$PRETURN"-[M:PNH1]PNHNUM
              Goto ROLL_MAJPNH
  Elsif fstat GOK=0  : OK=0 : Call RSTA("PNH",[M:PNH1]PNHNUM) From GLOCK
              Goto AB_MAJPNH
  Endif
  [F:PNH]INVLINNBR=[M:PNH1]INVLINNBR : # La clase [F] n'est pas màj par l'Update
  [F:PNH]INVFLG   =[M:PNH1]INVFLG    : # La clase [F] n'est pas màj par l'Update
Commit
Return
$AB_MAJPNH
Rollback : Return
$ROLL_MAJPNH
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_MAJPNH : Endif : Return


$SUPPRESS_TEX
#-----------------------------------------#
# Suppression des textes après un abandon #
#-----------------------------------------#
#----- Suppression texte entête et pied -----#
If GREP="D"
  If left$([M:PNH1]TEX1,3)="PNH"
    Call SUP_CLOB([M:PNH1]TEX1,GBIDI1) From TRTX3TEX
  Endif
  If left$([M:PNH1]TEX2,3)="PNH"
    Call SUP_CLOB([M:PNH1]TEX2,GBIDI1) From TRTX3TEX
  Endif
Endif
#----- Suppression des textes ligne -----#
For I=0 To [M:PNH1]NBLIG-1
  If left$([M:PNH1]LINTEX(I),3)="PND" & [M:PNH1]CREFLG(I)=0
    Call SUP_CLOB([M:PNH1]LINTEX(I),GBIDI1) From TRTX3TEX
  Endif
Next I
#-----
Call RAZ_CLOB From ACLOB
Return


#--------------------------------------------------#
# Traitement du nom et de l'adresse du fournisseur #
#--------------------------------------------------#
$CHARG_ADRESSE
If [M:AD65]ADBFLG<>2
  If GACTSAD=2 : # Stockage systématique de l'adresse !
    #----- Lecture BPARTNER si nécessaire -----#
    If [F:BPR]BPRNUM<>[F:PNH]BPSNUM
      Read [BPR] BPR0=[F:PNH]BPSNUM
      If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
    Endif
    #----- Lecture de l'adresse si nécessaire -----#
    If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:PNH]BPSNUM | [F:BPA]BPAADD<>[F:PNH]BPAADD
      Read [BPA] BPA0=1;[F:PNH]BPSNUM;[F:PNH]BPAADD
      If fstat  Raz [F:BPA] : Endif
    Endif
    #-----
    [F:PNH]BPRNAM(0)    = [F:BPR]BPRNAM(0)
    [F:PNH]BPRNAM(1)    = [F:BPR]BPRNAM(1)
    [F:PNH]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
    [F:PNH]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
    [F:PNH]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
    [F:PNH]CRY          = [F:BPA]CRY
    [F:PNH]CRYNAM       = [F:BPA]CRYNAM
    [F:PNH]SAT          = [F:BPA]SAT
    [F:PNH]POSCOD       = [F:BPA]POSCOD
    [F:PNH]CTY          = [F:BPA]CTY
  Else
    Raz [F:PNH]BPRNAM,[F:PNH]BPAADDLIG,[F:PNH]CRY,[F:PNH]CRYNAM,
&       [F:PNH]SAT,[F:PNH]POSCOD,[F:PNH]CTY
  Endif
Else
  [F:PNH]=[M:AD65]
Endif
Return


#--------------------------------------#
# Chargement des textes entête et pied #
#--------------------------------------#
$CHARG_TEXT_ENTETE
If [M:PNH1]TEX1<>""
  If left$([M:PNH1]TEX1,3)="PNH"
    Call CRE_CLOB([M:PNH1]TEX1,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Elsif left$([M:PNH1]TEX1,3)<>"BPS"
    Call DUP_CLOB("PNH",[M:PNH1]TEX1,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Endif
  [F:PNH]TEX1=[M:PNH1]TEX1
Endif
If [M:PNH1]TEX2<>""
  If left$([M:PNH1]TEX2,3)="PNH"
    Call CRE_CLOB([M:PNH1]TEX2,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Elsif left$([M:PNH1]TEX2,3)<>"BPS"
    Call DUP_CLOB("PNH",[M:PNH1]TEX2,GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Endif
  [F:PNH]TEX2=[M:PNH1]TEX2
Endif
Return


#---------------------------------#
# Chargement du texte de la ligne #
#---------------------------------#
$CHARG_TEXT_LIGNE
If [M:PNH1]LINTEX(nolign-1)<>""
  If left$([M:PNH1]LINTEX(nolign-1),3)="PND"
    Call CRE_CLOB([M:PNH1]LINTEX(nolign-1),GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Elsif !find(left$([M:PNH1]LINTEX(nolign-1),3),"ITM","ITP")
    Call DUP_CLOB("PND",[M:PNH1]LINTEX(nolign-1),GOK) From TRTX3TEX
    If GOK<1  Return : Endif
  Endif
  [F:PND]LINTEX=[M:PNH1]LINTEX(nolign-1)
Endif
Return


#---------------------------------------------------------------------------------------#
# Affichage entêtes colonnes variables (frais/remises, comptes et sections analytiques) #
#---------------------------------------------------------------------------------------#
$AFF_TITCOL
If GSOC_UPDFLG & !GIMPORT & (dim([M:PNH1]DISCRGVAL1)>0 | dim([M:PNH1]LINACC1)>0 | dim([M:PNH1]CCE1)>0)
  Local Char BASPAG(10)
  BASPAG="NBLIG" : Gosub TIT_COL From ="W1WE7"+GPTRNUM+"1"
  #----- Pour forcer l'utilisation des formats évalués si tableau vide -----#
  If [M:PNH1]NBLIG=0
    [M:PNH1]NBLIG=1 : Affzo [PNH1]15 : Effzo [PNH1]15
  Endif
  #-----
Endif
Raz GSOC_UPDFLG
Return

#########################################
$GRISE
# Accès à un document créé en multi-dépôt avec une transaction mono-dépôt
# --> pas d'application du mono-dépôt
If [F:PNH]WRHE="" & GWRHOBY=2
   GWRHOBY=1
   #--- Bug 62402
   #Call MESSAGE(mess(351,184,1)) From GESECRAN
   If [M:PNH1]PNHFCY<>[F:FCY]FCY : Read [FCY]FCY0=[M:PNH1]PNHFCY : Endif
   If [F:FCY]WRHGES=2 : Call MESSAGE(mess(351,184,1)) From GESECRAN : Endif
   #---
Endif
Return

#------------------------------------------#
# Actzo ou Grizo des dépôts selon le site  #
#------------------------------------------#
$WRH_ETAT
If GWRHACT<>2 Return Endif
If [M:PNH1]PNHFCY<>[F:FCY]FCY
   Read [FCY]FCY0=[M:PNH1]PNHFCY
Endif
If [F:FCY]WRHGES=2
   If find(GREP,"C","D")
      Actzo [M:PNH1]WRHE
      If GWRHOBY=2
         Diszo [M:PNH1]WRH
      Else
         Actzo [M:PNH1]WRH
      Endif
   Elsif [M:PNH1]WRHE<>""
      Diszo [M:PNH1]WRHE
      Diszo [M:PNH1]WRH
   Else
      Actzo [M:PNH1]WRHE
      Actzo [M:PNH1]WRH
   Endif
Else
  Raz   [M:PNH1]WRHE
  Grizo [M:PNH1]WRHE
  Grizo [M:PNH1]WRH
Endif
Return

#########################################################################
# 101090 - Verify changes that affect the BOL
#########################################################################
Subprog VERIF_BOLMOD(OK)
Variable  Integer OK

#Default to OK
OK=2

#Verify that the global variable exists
If dim(GBOLERR)<0 : Global Integer GBOLERR : Endif

# If no linked BOL, exit
If dim([M:PNHC]BOLNUM)<0 : End : Endif
If [M:PNHC]BOLNUM=""     : End : Endif

#If GBOLERR=0, we have not asked before (or they said NO) so ask this time.
If GBOLERR=0
  Call AVERTIR(func AFNC.MES1(mess(7,2086,1),[M:PNHC]BOLNUM),OK) From GESECRAN
  If OK=2 : GBOLERR=1 : Endif
Endif

End

#########################################################################
# 101090 - Setup BOL related fields (called from SUBPNHA.LIENS)
#########################################################################
Subprog SETUP_BOL

# If coming back from the BOL button - make sure we are still on the same record
If [F:PNH]PNHNUM<>[M:PNH1]PNHNUM
  Read [PNH] PNH0=[M:PNH1]PNHNUM : If fstat : Raz [F:PNH] : Endif
Endif

#Global variable used to know when to show the warning on changes
If dim(GBOLERR)<0 : Global Integer GBOLERR : Endif
Raz GBOLERR

#Hide fields as needed
If func AFNC.ACTIV("KUS")
  If func AFNC.PARAM("USABOL",[M:PNH1]PNHFCY)="2"
    Chgfmt [M:PNHC]SCAC    With "K:" + num$(type([M:PNHC]SCAC)-10) + "B"    # Show enterable
    Chgfmt [M:PNHC]PRONUM  With "K:" + num$(type([M:PNHC]PRONUM)-10) + "B"  # Show enterable
  Else
    Chgfmt [M:PNHC]SCAC    With "-K:" + num$(type([M:PNHC]SCAC)-10) + "B"   # Hide enterable
    Chgfmt [M:PNHC]PRONUM  With "-K:" + num$(type([M:PNHC]PRONUM)-10) + "B" # Hide enterable
  Endif
Endif

# Fill in values from the BOL
If dim([M:PNHC]BOLNUM)>0
  If [F:PNH]BOLNUM<>""
    If !clalev([F:BOLH]) : Local File BILLLADH [BOLH] : Endif

    If [M:PNHC]BOLNUM<>[F:PNH]BOLNUM
      [M:PNHC]BOLNUM=[F:PNH]BOLNUM
      Affzo [M:PNHC]BOLNUM
    Endif

    Read [F:BOLH]BOLH0 = [F:PNH]BOLNUM
    If !fstat
      [M:PNHC]TRAILER = [F:BOLH]TRAILER
      Affzo [M:PNHC]TRAILER

      # Only enable SCAC and Pro number fields if KUS is activated and USABOL is Yes
      If func AFNC.ACTIV("KUS")
        If func AFNC.PARAM("USABOL",[M:PNH1]PNHFCY)="2"
          [M:PNHC]SCAC    = [F:BOLH]SCAC
          [M:PNHC]PRONUM  = [F:BOLH]PRONUM

          Affzo [M:PNHC]SCAC,PRONUM
        Else
          Raz [M:PNHC]SCAC
          Raz [M:PNHC]PRONUM
          Grizo [M:PNHC]SCAC,PRONUM
        Endif
      Endif
    Endif
  Else
    Raz   [M:PNHC]BOLNUM
    Raz   [M:PNHC]TRAILER
    Grizo [M:PNHC]BOLNUM,TRAILER
    If dim([M:PNHC]SCAC)>0
      Raz [M:PNHC]SCAC  : Grizo [M:PNHC]SCAC
    Endif
    If dim([M:PNHC]PRONUM)>0
      Raz [M:PNHC]PRONUM : Grizo [M:PNHC]PRONUM
    Endif
  Endif
Endif

End

