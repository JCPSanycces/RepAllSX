Value    Char    MACHINE , APPLI , UID
Variable Char    FONCTION
Variable Integer MODULE
Variable Char    LOGIN
Call GET_CURFCT(MACHINE,APPLI,UID,FONCTION,MODULE,LOGIN) From ASYRPSADX
End

