#--------------------------------------------------------------------------------------------#
# Pour avoir la liste des utilisateurs connectés sur une appli
#--------------------------------------------------------------------------------------------#

#Subprog USER_LISTE(APPLI,NBUSR,LISTE)
#Value Char APPLI
#Variable Integer NBUSR
#Variable Char LISTE
#Local Char    SID(12) , SCLI(80) , SDOS(30) , SSER(10) , SLOG(20)
#Local File (SID,SCLI,SDOS,SLOG,SSER) From System adxmac(0)+"@psadx -t -fg" As [SYS_] Where [SYS_]SDOS=APPLI & [SYS_]SSER<>"33"
#Raz NBUSR , LISTE
#For [SYS_]
# NBUSR += 1
# If !instr(1,LISTE," "+[F:SYS_]SLOG+" ")
#  LISTE += " "+[F:SYS_]SLOG+" "
# Endif
#Next SYS_
#If LISTE<>""
# LISTE = "("+vireblc(LISTE,2)+")"
#Endif
#Close Local File [SYS_]
#End

Subprog USER_LISTE(APPLI,NBUSR,LISTE)
Value Char APPLI
Variable Integer NBUSR
Variable Char LISTE
If func ASESSIONS.ISMNGSESSIONS
 Call USER_LISTE(APPLI,NBUSR,LISTE) From ASESSIONS
 End
Endif
Local Char WTABUSR(250)(1..)
Local Integer WTABNUMUSR(1..)
Local Integer WNBUSR,IFOUND
Local Char    SID(12) , SCLI(80) , SDOS(30) , SSER(10) , SLOG(20), WSER(10)
#Local File (SID,SCLI,SDOS,SLOG,SSER) From System adxmac(0)+"@psadx -t -fg" As [SYS_] Where [SYS_]SDOS=APPLI & [SYS_]SSER<>"33"
Local File (SID,SCLI,SDOS,SLOG,SSER) From System adxmac(0)+"@psadx -t -fg" As [SYS_] Where [SYS_]SDOS=APPLI
Raz NBUSR , LISTE
For [SYS_]
 WSER=[F:SYS_]SSER
 If find([F:SYS_]SSER,"25","33")>0 : WSER="825" : Endif
 IFOUND=find([F:SYS_]SLOG-WSER-[F:SYS_]SCLI,WTABUSR(1..WNBUSR))
 If IFOUND
   WTABNUMUSR(IFOUND)+=1
   If WTABNUMUSR(IFOUND)<>2 | find(adxtyp,25,33)=0
    NBUSR += 1
   Endif
 Else
  NBUSR += 1
  WNBUSR+=1
  WTABUSR(WNBUSR)=[F:SYS_]SLOG-WSER-[F:SYS_]SCLI
  WTABNUMUSR(WNBUSR)+=1
  If !instr(1,LISTE," "+[F:SYS_]SLOG+" ")
   LISTE += " "+[F:SYS_]SLOG+" "
  Endif
 Endif
Next SYS_
If LISTE<>""
 LISTE = "("+vireblc(LISTE,2)+")"
Endif
Close Local File [SYS_]
End

#--------------------------------------------------------------------------------------------------------------------------------------#
# Pour connaître le proprio d'un processus (adxuid(1)) pour éventuellement lui envoyer un mail l'invitant à déverrouiller le symbole
#--------------------------------------------------------------------------------------------------------------------------------------#

Subprog USER_QUI(PROCESS,DOSSIER,CLIENT,USER,MAIL)
Value Char PROCESS , DOSSIER
Variable Char CLIENT , USER , MAIL
If func ASESSIONS.ISMNGSESSIONS
 Call USER_QUI(PROCESS,DOSSIER,CLIENT,USER,MAIL) From ASESSIONS
 End
Endif
Local Char SID(12), SCLI(80) , SUSR(30), SUID(12)
Local Char MACHINE(GLONAMC) , APPLI(GLONADS)
Raz CLIENT , USER , MAIL
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
Local File (SID,SCLI,SUSR,SUID) From System MACHINE+"@psadx -ig" As [SYS_] Where [SYS_]SUID=PROCESS
For [SYS_]
 CLIENT = [SYS_]SCLI
 If DOSSIER=nomap or DOSSIER=""
  Local File AUTILIS [AUX_]
 Else
  Local File =DOSSIER+".AUTILIS" [AUX_]
 Endif
 USER = toupper([SYS_]SUSR)
 Read [AUX_]LOGIN = USER
 If !fstat
  USER = [F:AUX_]USR-[F:AUX_]NOMUSR
  MAIL = [F:AUX_]ADDEML
 Endif
 Close Local File [AUX_]
 Break
Next SYS_
Close Local File [SYS_]
End

