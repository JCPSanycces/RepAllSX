#<AdxTL>@(#)1.0.0.0 $Revision$
#Call USER_LISTE("SUPERV",GBIDI1,GBIDC1) : Infbox num$(GBIDI1)-GBIDC1 : End
#Call PROCLI("SERVSUP","BATCH",adxtcp,3,GBIDC1) : Infbox GBIDC1 : End
Local Char PARAM(30)(1..5) , VALEUR(10)
PARAM(1) = "" : # Uid
PARAM(2) = "" : # No Process
PARAM(4) = nomap
Raz GNBMASKOUV
Call SAISIE_CHAR(VALEUR,PARAM,"PSADX","PSADX","XWPSADX") From GSAISIE
End

#--------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "BOUTON"      : Gosub BOUTON
 When "RAF"         : Gosub RAF
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "MEN"         : Gosub MENU
 When "FIN"         : Gosub FIN
 When "SEL_TABLE"   : Gosub SEL_TABLE
Endcase
Return

#--------------------------------------------------#
$OUVRE
Local Mask PSADX [PSA]
Local Char     CODUID(10) , CODPROC(10)
Local Integer  TRICUR , ALERTE
Local Char     SAVFONC(GLONAFC)
Raz [M]
TRICUR = 1
SAVFONC = GFONCTION
GFONCTION = "PSADX"
CODUID  = PARAM(1)
CODPROC = PARAM(2)
If dim(PARAM)>=5
 If dim([M:PSA]SERVEUR)>0 : [M:PSA]SERVEUR = PARAM(3) : Endif
 If dim([M:PSA]APPLI)>0   : [M:PSA]APPLI   = PARAM(4) : Endif
 If dim([M:PSA]UTIL)>0    : [M:PSA]UTIL    = PARAM(5) : Endif
Endif
If dim(PARAM)>=6
 If dim([M:PSA]ALLPRO)>0  : [M:PSA]ALLPRO  = val(PARAM(6)) : Endif
Endif
Call AUTORIS From EXEFNC
Return

#---------------------------#
$FIN
GFONCTION = SAVFONC
Inftxt "" At 1
Return

#---------------------------#
$DEBUT

Gosub LIRE
SUIZON = "+"
Return

#---------------------------#
$SETBOUT
CHBOU += "=" : # Raffraîchir
Return

#---------------------------#
$BOUTON
Case BOUT
 When "1" : Gosub LIRE
 When "2" : Call RECHERCHE(CODPROC) : If CODPROC<>"" : Gosub LIRE : Endif
 When "3" : Gosub ADELSESS
Endcase
Return

#---------------------------#
$MENU
TRICUR = instr(1,"ABCDE",BOUT)
Gosub TRI
Affzo 20
Return

#---------------------------#
$TRI
Case TRICUR
 When 1
  Sorta [M:PSA]NBLIG [M:PSA]NBLIG Order By [M:PSA]DOSSIER(indice),[M:PSA]CLIENT(indice)
 When 2
  Sorta [M:PSA]NBLIG [M:PSA]NBLIG Order By [M:PSA]CLIENT(indice),[M:PSA]DOSSIER(indice)
 When 3
  Sorta [M:PSA]NBLIG [M:PSA]NBLIG Order By [M:PSA]USER(indice),[M:PSA]DOSSIER(indice)
 When 4
  Sorta [M:PSA]NBLIG [M:PSA]NBLIG Order By [M:PSA]LOGIN(indice),[M:PSA]DOSSIER(indice)
 When 5
  Sorta [M:PSA]NBLIG [M:PSA]NBLIG Order By [M:PSA]DATCON(indice),[M:PSA]HRECON(indice)
Endcase
Return

#---------------------------#
$APRES_MODIF
Case COUZON
 When "SERVEUR" : Default [L] : [M]SERVEUR = CZ : Gosub LIRE
Endcase
Return

#--------------------------------------------------#
$RAF
$LIRE
Call TEMPON("L") From GESECRAN
Call RAZ_CURFCT("") : # Ménage dans la table AFCTCUR
Call LISTE(CODUID)
Call TEMPOFF From GESECRAN

Affzo

# Alerte sur les temps cpu > 10'
For I=0 To [M]NBLIG-1
 K = instr(1,[M]CPU(I),":")
 If K & val(left$([M]CPU(I),K-1))>=10
  Chgstl [M]CPU(I) With "AERROR"
  ALERTE = 1
 Endif
Next I
If ALERTE : # Evite de faire des raffraichissement de style s'il n'y a jamais eu d'alerte
 For I=0 To [M]NBLIG-1
  K = instr(1,[M]CPU(I),":")
  If !K or val(left$([M]CPU(I),K-1))<10
   Chgstl [M]CPU(I) With ""
  Endif
 Next I
Endif

# Recherche de la ligne correspondant au process passé en argument
J = 0
If CODPROC<>""
 K = find(CODPROC,[M]TBNUM)
 If K
  For I=0 To [M]NBLIG-1
   If K-1>=[M]PTD(I) & K-1<=[M]PTF(I)
    J = I : Break
   Endif
  Next I
 Endif
 CODPROC = ""
Endif

SUIZON = "NBLIG("+num$(J)+")"
Return

# 2017-09-12 JPGA : X3-48260 - Remove inactive sessions
#---------------------------#
$ADELSESS
  Local Integer NBDEL_ASM3   : # Number of records deleted in ASYSSMDBASSO session table
  Local Integer NBDEL_ASM0   : # Number of records deleted in ASYSSMINTERN session table
  Local Integer NBDEL_ASM1   : # Number of records deleted in ASYSSMEXTERN session table
  Local Integer NBDEL_ASM2   : # Number of records deleted in ASYSSMPROCES session table
  Local Integer ASTATUS      : # Return_code returned by Funprog
  Local Char    MESSAGE(250) : # Message in case of error returned by Funprog

  # Calling the MAIN deletion procedure with the current folder as INPUT (must be a ROOT folder)
  [L]ASTATUS=func ASESSIONS.RAZ_DEAD_SESSION (nomap, [L]NBDEL_ASM3, [L]NBDEL_ASM0, [L]NBDEL_ASM1, [L]NBDEL_ASM2, [L]MESSAGE)

  # Processing results after calling the MAIN deletion procedure with the current folder as INPUT  (must be a ROOT folder)
  If [L]ASTATUS <> [V]CST_AOK
    [L]MESSAGE=mess(218,123,1)+" #"+num$([L]ASTATUS)+" : "+[L]MESSAGE : # Code retour global #n ...
    GMESSAGE=[L]MESSAGE
    GERR = 1 : Return
  Else
    Call ECR_TRACE(mess(246,100,1)+" :"+" ASYSSMDBASSO="+num$([L]NBDEL_ASM3) +
&                                       " ASYSSMINTERN="+num$([L]NBDEL_ASM0) +
&                                       " ASYSSMEXTERN="+num$([L]NBDEL_ASM1) +
&                                       " ASYSSMPROCES="+num$([L]NBDEL_ASM2),0) From GESECRAN
  Endif
Return

#--------------------------------------------------#
Subprog LISTE(CODUID)
Value Char CODUID

If clalev([M:PSA])=0 : Local Mask PSADX [PSA] : Endif

Local Integer  STAT , OKUSR
Local Char     ORDSYS(250) , SERVEUR(GLONAMC) , APPLI(GLONADS) , UTIL(GLONAUS)
Local Integer  I , J , K , L , ER
Local Integer  NBCHAMP , LTET , NBPROC , MAXPROC , ALLPRO, CPUFLG
Local Char     CHAINE(255) , PROCESS(255),ERRMES(250)
Local Integer  ANNEE , MOIS , JOUR
Local Char     HEURE(10)
Local Integer  MORT
Local Char     FICLIC(250)
Local Char     CHCLI(48)(1..4) , CHDIS(48)(1..4) , VERSION(10)
Local Date     DATDEB , DATFIN
Local Integer  USER , DIVERS(1..9) , NOMBRE(1..12) , LIGUID , TRICUR , LIGENT

Onerrgo ER
If clalev([F:AFU])=0 : Local File AFCTCUR  [AFU] : Endif
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Local File ASYSSMPROCES [ASM2]
Onerrgo

If [M:PSA]SERVEUR=""
 [M:PSA]SERVEUR = adxmac(0)
Endif
[L]SERVEUR = [M:PSA]SERVEUR
If dim([M:PSA]APPLI)>0
 [L]APPLI = [M:PSA]APPLI
Endif
If dim([M:PSA]UTIL)>0
 [L]UTIL = [M:PSA]UTIL
Endif
If dim([M:PSA]ALLPRO)>0
 [L]ALLPRO = [M:PSA]ALLPRO
Endif
# Issue X3-70598 - 2018-03-30 by CCC : cpu time calculation
If dim([M:PSA]CPUFLG)>0
 [L]CPUFLG = [M:PSA]CPUFLG
Endif

Raz [M:PSA]

NBPROC  = 0
MAXPROC = dim([M:PSA]TBPROC)-1
[M:PSA]SERVEUR = [L]SERVEUR
If dim([M:PSA]APPLI)>0
 [M:PSA]APPLI = APPLI
Endif
If dim([M:PSA]UTIL)>0
 [M:PSA]UTIL = [L]UTIL
Endif
If dim([M:PSA]ALLPRO)>0
 [M:PSA]ALLPRO = [L]ALLPRO
Endif
# Issue X3-70598 - 2018-03-30 by CCC : cpu time calculation
If dim([M:PSA]CPUFLG)>0
 [M:PSA]CPUFLG = [L]CPUFLG
Endif

If func ASESSIONS.ISMNGSESSIONS
 Gosub REMPLIT_SYS_SESSION
Else
 Gosub REMPLIT_SYS
Endif

TRICUR = 1
Gosub TRI
[M:PSA]SESS5 = [M:PSA]SESS1+[M:PSA]SESS2+[M:PSA]SESS3+[M:PSA]SESS4+[M:PSA]SESS41
If dim([M:PSA]SESS42)>0 : [M:PSA]SESS5 += [M:PSA]SESS42 : Endif
If dim([M:PSA]SESS43)>0 : [M:PSA]SESS5 += [M:PSA]SESS43 : Endif

FICLIC=""
# Suppression du serial_adonix begin
#I=func GLOBSUP.FICSERIAL(GPRODUIT,[L]SERVEUR,FICLIC)
#
#Call SERIAL(FICLIC,[M:PSA]LICENCE,CHCLI,CHDIS,DATDEB,DATFIN,USER,DIVERS,NOMBRE) From VISULIC
#[M:PSA]MAX1 = "("+num$(DIVERS(1))+")"
#[M:PSA]MAX2 = "("+num$(DIVERS(2))+")"
#[M:PSA]MAX3 = "("+num$(DIVERS(3))+")"
#[M:PSA]MAX4 = "("+num$(DIVERS(4))+")"
#[M:PSA]MAX41 = "("+num$(DIVERS(5))+")"
#If dim([M:PSA]MAX42)>0
# [M:PSA]MAX42 = "("+num$(DIVERS(6))+")"
#Endif
#If dim([M:PSA]MAX43)>0
# [M:PSA]MAX43 = "("+num$(DIVERS(7))+")"
#Endif
# Suppression du serial_adonix end
End


$REMPLIT_SYS_SESSION
Local Integer WAND
# X3SM0.REMOTE_0,X3SM0.PEER_0,X3SM0.SYSTEMUSER_0,X3SM0.NATURE_0,X3SM0.CREDATTIM_0,X3SM0.UPDDATTIM_0,X3SM0.ALOGIN_0,X3SM0.UPDUSR_0
Gosub INIT_RQT From ASESSIONS
WSELECT = "X3SM0.SESSIONID_0,X3SM0.FOLD_0,X3SM0.LAN_0,X3SM0.SOLUTION_0,X3SM0.SESSIONTYPE_0,"
Gosub ADD_SELECT_RQT From ASESSIONS
WSELECT = "X3SM0.REMOTE_0,X3SM0.PEER_0,X3SM0.SYSTEMUSER_0,X3SM0.NATURE_0,X3SM0.ALOGIN_0,"
Gosub ADD_SELECT_RQT From ASESSIONS
WSELECT = "X3SM0.PROCESSADX_0,X3SM0.UPDUSR_0,X3SM0.CREDATTIM_0 "
Gosub ADD_SELECT_RQT From ASESSIONS
If dim([M:PSA]APPLI)>0 & [M:PSA]APPLI<>""
 WAND = 1
 WWHERE  = "X3SM0.FOLD_0='"+[M:PSA]APPLI+"'"     : Gosub ADD_WHERE_RQT From ASESSIONS
Endif
#If dim([M:PSA]UTIL)>0 & [M:PSA]UTIL<>""
#  If WAND>0 : WWHERE  = " and " : Endif
#  WWHERE  += "X3SM0.ALOGIN_0='"+tolower([M:PSA]UTIL)+"'"     : Gosub ADD_WHERE_RQT From ASESSIONS
#Endif

#SAM 121056 02/02/2017 LSE
If dim(CODUID)>0 & CODUID<>""
  If WAND>0 : WWHERE  = " and " : Endif
  WWHERE  += "X3SM0.SESSIONID_0="+ CODUID     : Gosub ADD_WHERE_RQT From ASESSIONS
Endif

#SESSIONID,FOLD,LAN,SOLUTION,MODULE,FONCTION,SESSIONTYPE,REMOTE,PEER,SYSTEMUSER,NATURE,CREDATTIM,UPDDATTIM,ALOGIN,UPDUSR
For (Integer SESSIONID,Char FOLD(GLONADS),Char LAN(GLONLAN),Char SOLUTION(40),Integer SESSIONTYPE,Char REMOTE(40),
&    Char PEER(250),Char SYSTEMUSER(250),Integer NATURE,Char ALOGIN(30),Integer PROCESSADX,Char UPDUSR(GLONAUS),Datetime CREDATTIM)
&    From num$((GTYPDBA*2)+1)  Sql RQT_SESSION As [SYS_]
 Gosub ADD_SESSIONS
Next
Sorta [M:PSA]NBTOT [M:PSA]NBTOT Order By [M:PSA]TYPINTSES(indice)  Desc
Return

$ADD_SESSIONS
K = [M:PSA]NBLIG
[M:PSA]ID(K)       = num$([F:SYS_]SESSIONID)      : # Identifiant (adxuid(1))
[M:PSA]CLIENT(K)   = [F:SYS_]REMOTE : #[F:SYS_]SCLI      : # Poste client
If find([F:SYS_]SESSIONTYPE,25,33)>0
 [M:PSA]IPCLI(K) = [F:SYS_]PEER :# [F:SYS_]SIPCLI : #Adresse client
Endif
[M:PSA]ADRESSE(K)  = [F:SYS_]PEER  : #[F:SYS_]SADR  : #Adresse client ou serveur syracuse
[M:PSA]DOSSIER(K)  = [F:SYS_]FOLD      : # Dossier
[M:PSA]USER(K)     = [F:SYS_]ALOGIN     : # Login X3
[M:PSA]UID(K)      = num$([F:SYS_]SESSIONID  )    : # ID adonix adxuid(2)
[M:PSA]TYP(K)      = [F:SYS_]SESSIONTYPE : # Type de session
If dim([M:PSA]ALLPRO)<=0 or [M:PSA]ALLPRO<>1
 [M:PSA]LOGIN(K)    = [F:SYS_]SYSTEMUSER: # [F:SYS_]SLOG      : # Login système
 #[M:PSA]CPU(K)      = "" # space$(6-min(instr(1,[F:SYS_]STIME,":"),5))+[F:SYS_]STIME : # Temps cpu du process adonix
Endif
[M:PSA]DATCON(K) = func ASYRFNC.DATE_FROM_DT([F:SYS_]CREDATTIM)
[M:PSA]HRECON(K) = func ASYRFNC.TIME_FROM_DT([F:SYS_]CREDATTIM)
[M:PSA]DATTIME(K) = format$("D:4Y[-]2M[-]2D",[M:PSA]DATCON(K)) + "T" + [M:PSA]HRECON(K) + "Z" # X3-105217 17.09.2018
[M:PSA]NATURE(K) = [F:SYS_]NATURE
Call GET_CURFCT([L]SERVEUR,[M:PSA]DOSSIER(K),[M:PSA]ID(K),[M:PSA]FONCTION(K),[M:PSA]MODULE(K),[M:PSA]USER(K))
For [F:ASM2]SESSIONID Where SESSIONID=[SYS_]SESSIONID
 NBPROC += 1
 If NBPROC<MAXPROC
  [M:PSA]TBNUM(NBPROC) = num$([F:ASM2]SYSTEMID)
  [M:PSA]TBMAC(NBPROC) = [F:ASM2]SERVER
  [M:PSA]TBPROC(NBPROC) = [F:ASM2]PROCESSNAME
  If [M:PSA]PTD(K)=0
   [M:PSA]PTD(K) = NBPROC
  Endif
  [M:PSA]PTF(K) = NBPROC
 Endif
 If [F:SYS_]PROCESSADX = [F:ASM2]PROCESSID
  [M:PSA]PORT(K)     = num$([F:ASM2]PORT) : # [F:SYS_]SPORT     : # Port
  If [M:PSA]CPUFLG=2
    Call CPU_PROCESS([F:ASM2]SERVER,num$([F:ASM2]SYSTEMID),[M:PSA]CPU(K) ,ERRMES)
  Else
    Raz [M:PSA]CPU(K)
  Endif
 Endif
Next
[M:PSA]NBLIG += 1
Gosub TOTAL_SESSION_TYPES
Return

$TOTAL_SESSION_TYPES
If dim([M:PSA]NBTOT)
 Local Integer IPOS
 IPOS = find([M:PSA]TYP(K),[M:PSA]TYPINTSES(0..[M:PSA]NBTOT))
 If IPOS=0 and [M:PSA]TYPINTSES(0)=[M:PSA]TYP(K)
  [M:PSA]TOTSES(0) +=1
 Elsif IPOS>0
  [M:PSA]TOTSES(IPOS-1) +=1
 Else
  [M:PSA]TOTSES([M:PSA]NBTOT) +=1
  [M:PSA]TYPINTSES([M:PSA]NBTOT) =[M:PSA]TYP(K)
  [M:PSA]TYPSES([M:PSA]NBTOT) =mess([M:PSA]TYP(K),924,1)
  [M:PSA]NBTOT+=1
 Endif
 [M:PSA]NBTOTSES+=1
Endif
Return

#----------------------------------------------------------------#
$REMPLIT_SYS
Local Char SID(250) , SPORT(20) , SCLI(80) , SADR(40) , SDOS(40) , SFCT(50)
Local Char SDATW(20) , SDATM(20) , SDATD(20) , SDATH(20) , SDATY(20)
Local Char SLOG(50) , STIME(20) , SUSER(50) , SMOD(50)
Local Char SUID(20) , SSER(30) , SPRO(250)

Local Char VERSRUN(30)
Local Integer IPCLI
VERSRUN=func ASYRSYS.VERSRUN(GACTX,[L]SERVEUR+string$([L]SERVEUR="",adxmac(0)))
If VERSRUN>="18r.102"
 IPCLI=1
 Local Char SIPCLI(40)
Endif

ORDSYS = [L]SERVEUR+"@psadx -"
ORDSYS += "a" : # Adresse du client (serveur syracuse, poste client sur fat client...)
If IPCLI
ORDSYS += "e" : # Adresse IP du client (web page, Classic client)
Endif
ORDSYS += "f" : # Dossier
ORDSYS += "g" : # user X3 (GUSER)
ORDSYS += "h" : # Jour et heure de connexion
ORDSYS += "i" : # ID adonix
If dim([M:PSA]ALLPRO)<=0 or [M:PSA]ALLPRO<>1
 ORDSYS += "n" : # Login
Endif
ORDSYS += "t" : # Type de session
ORDSYS += "p" : # No de port utilisé
ORDSYS += "x" : # Processus
If dim([M:PSA]ALLPRO)<=0 or [M:PSA]ALLPRO<>1
 ORDSYS += "z" : # Temps CPU du processus adonix
Endif
ORDSYS += " -l"-GLANGUE
If dim([M:PSA]APPLI)>0 & [M:PSA]APPLI<>""
 ORDSYS += " -b"-[M:PSA]APPLI
Endif
If dim([M:PSA]UTIL)>0 & [M:PSA]UTIL<>""
 ORDSYS += " -u"-tolower([M:PSA]UTIL)
Endif

GPOINT = "SYSTEM" : Gosub ENTREE From EXEFNC : # Demande 61565
If IPCLI
 If dim([M:PSA]ALLPRO)<=0 or [M:PSA]ALLPRO<>1
  Local File (SID,SPORT,SCLI,SADR,SDOS,SDATW,SDATM,SDATD,SDATH,SDATY,SLOG,STIME,SUSER,SUID,SSER,SIPCLI,SPRO) From System ORDSYS As [SYS_]
 Else
  Local File (SID,SPORT,SCLI,SADR,SDOS,SDATW,SDATM,SDATD,SDATH,SDATY,SUSER,SUID,SSER,SIPCLI,SPRO) From System ORDSYS As [SYS_]
 Endif
Else
 If dim([M:PSA]ALLPRO)<=0 or [M:PSA]ALLPRO<>1
  Local File (SID,SPORT,SCLI,SADR,SDOS,SDATW,SDATM,SDATD,SDATH,SDATY,SLOG,STIME,SUSER,SUID,SSER,SPRO) From System ORDSYS As [SYS_]
 Else
  Local File (SID,SPORT,SCLI,SADR,SDOS,SDATW,SDATM,SDATD,SDATH,SDATY,SUSER,SUID,SSER,SPRO) From System ORDSYS As [SYS_]
 Endif
Endif
Raz LIGENT , OKUSR
For [SYS_]
 If LIGENT<2
  LIGENT += 1
 Else
  #On décale si pb sur SUSER ou SIPCLI
  If IPCLI
   If [F:SYS_]SPRO="" & [F:SYS_]SIPCLI="" & [F:SYS_]SSER<>"" & [F:SYS_]SUID<>"" & [F:SYS_]SUSER<>"" & instr(1,[F:SYS_]SSER,":")>0
    [F:SYS_]SPRO=[F:SYS_]SSER
    [F:SYS_]SIPCLI=""
    [F:SYS_]SSER=[F:SYS_]SUID
    [F:SYS_]SUID=[F:SYS_]SUSER
    [F:SYS_]SUSER="???"
   Elsif [F:SYS_]SPRO="" & [F:SYS_]SIPCLI<>"" & instr(1,[F:SYS_]SIPCLI,":")>0
    [F:SYS_]SPRO=[F:SYS_]SIPCLI
    [F:SYS_]SIPCLI=""
   Endif
  Else
   If [F:SYS_]SPRO="" & [F:SYS_]SSER<>"" & [F:SYS_]SUID<>"" & [F:SYS_]SUSER<>"" & instr(1,[F:SYS_]SSER,":")>0
    [F:SYS_]SPRO=[F:SYS_]SSER
    [F:SYS_]SSER=[F:SYS_]SUID
    [F:SYS_]SUID=[F:SYS_]SUSER
    [F:SYS_]SUSER="???"
   Endif
  Endif
  ###
  If [F:SYS_]SUSER="" & [F:SYS_]SPORT<>""
   # Dernière ligne
  Elsif [F:SYS_]SUSER="" : # Ligne de processus
   If OKUSR
    PROCESS = [F:SYS_]SID
    Gosub PROCESS
   Endif
  Else : # Ligne utilisateur
   If CODUID="" or CODUID=[F:SYS_]SUID
    If [M:PSA]NBLIG>=dim([M:PSA]ID)
     Call ERREUR(mess(161,115,1)) From GESECRAN : # Trop de lignes
     Break
    Endif
    OKUSR = 1
    [M:PSA]NBLIG += 1
    Gosub LIGNE_SYS
   Else
    OKUSR = 0
   Endif
  Endif
 Endif
Next SYS_
Sorta [M:PSA]NBTOT [M:PSA]NBTOT Order By [M:PSA]TYPINTSES(indice)  Desc
Close Local File [SYS_]
Return

#-----------------#
$LIGNE_SYS
K = [M:PSA]NBLIG-1
[M:PSA]ID(K)       = [F:SYS_]SID       : # Identifiant (adxuid(1))
[M:PSA]PORT(K)     = [F:SYS_]SPORT     : # Port
[M:PSA]CLIENT(K)   = [F:SYS_]SCLI      : # Poste client
If IPCLI & find(val([F:SYS_]SSER),25,33)>0 & [F:SYS_]SIPCLI<>""
 [M:PSA]IPCLI(K) = [F:SYS_]SIPCLI : #Adresse client
Endif
[M:PSA]ADRESSE(K)  = [F:SYS_]SADR  : #Adresse client ou serveur syracuse
[M:PSA]DOSSIER(K)  = [F:SYS_]SDOS      : # Dossier
[M:PSA]USER(K)     = [F:SYS_]SUSER     : # Login X3
[M:PSA]UID(K)      = [F:SYS_]SUID      : # ID adonix adxuid(2)
[M:PSA]TYP(K)      = val([F:SYS_]SSER) : # Type de session
If dim([M:PSA]ALLPRO)<=0 or [M:PSA]ALLPRO<>1
 [M:PSA]LOGIN(K)    = [F:SYS_]SLOG      : # Login système
 #115751
 #[M:PSA]CPU(K)      = space$(6-min(instr(1,[F:SYS_]STIME,":"),5))+[F:SYS_]STIME : # Temps cpu du process adonix
 [M:PSA]CPU(K)      = [F:SYS_]STIME : # Temps cpu du process adonix
Endif
PROCESS            = [F:SYS_]SPRO      : # Processus système
MOIS = find(toupper([F:SYS_]SDATM),"JAN","FEB","MAR","APR","MAY","JUN","JUL","AUG","SEP","OCT","NOV","DEC")
If MOIS
 JOUR = val([F:SYS_]SDATD)
 ANNEE = val([F:SYS_]SDATY)
 If JOUR>=1 & JOUR<=31 & ANNEE>=1600 & ANNEE<=9999
  [M:PSA]DATCON(K) = gdat$(JOUR,MOIS,ANNEE)
  [M:PSA]HRECON(K) = [F:SYS_]SDATH
  [M:PSA]DATTIME(K) = format$("D:4Y[-]2M[-]2D",[M:PSA]DATCON(K)) + "T" + [M:PSA]HRECON(K) + "Z" # X3-105217 17.09.2018
 Endif
Endif
Case [M:PSA]TYP(K)
 When 1 : [M:PSA]SESS1 += 1
 When 2 : [M:PSA]SESS2 += 1
 When 3 : [M:PSA]SESS3 += 1
 When 4 : [M:PSA]SESS4 += 1
 When 5 : [M:PSA]SESS41 += 1
 When 6 : [M:PSA]SESS42 += 1
 When 7 : If dim([M:PSA]SESS43)>0 : [M:PSA]SESS43 += 1 : Endif
Endcase
Gosub TOTAL_SESSION_TYPES
Gosub PROCESS
Call GET_CURFCT([L]SERVEUR,[M:PSA]DOSSIER(K),[M:PSA]ID(K),[M:PSA]FONCTION(K),[M:PSA]MODULE(K),[M:PSA]USER(K))
Return

#---------------------------#
$PROCESS
K = [M:PSA]NBLIG-1
If NBPROC<MAXPROC
 NBPROC += 1
 Call GET_PROCESS(PROCESS,[M:PSA]TBNUM(NBPROC),[M:PSA]TBMAC(NBPROC),[M:PSA]TBPROC(NBPROC))
 If [M:PSA]PTD(K)=0
  [M:PSA]PTD(K) = NBPROC
 Endif
 [M:PSA]PTF(K) = NBPROC
Endif
Return

#---------------------------------------------------------------------#
# Saucissonnage du psadx -> processus:nomProcessus(machine)
#---------------------------------------------------------------------#

Subprog GET_PROCESS(PROCESS,NUM,MAC,PRO)
Value Char PROCESS
Variable Char NUM , MAC , PRO
Local Integer J , L
J = instr(1,PROCESS,":")
If J
 NUM     = left$(PROCESS,J-1)
 PROCESS = right$(PROCESS,J+1)
Else
 NUM     = PROCESS
 PROCESS = ""
Endif
J = instr(1,PROCESS,"(")
If J
 PRO = left$(PROCESS,J-1)
 L = instr(J,PROCESS,")")
 If L
  MAC = seg$(PROCESS,J+1,L-1)
 Else
  L = instr(J,PROCESS,".")     : # Bug 84142   CC 16/11/2012
  If L
    MAC = seg$(PROCESS,J+1,L-1)
  Else
    MAC = right$(PROCESS,J+1)
  Endif
 Endif
Else
 PRO = PROCESS
 MAC = adxmac(0)
Endif
End

#--------------------------------------------------#
$SEL_TABLE
Local Integer MAXFIC
MAXFIC = 1000
Local Char    WCLI(GLONAMC)(1..MAXFIC) , WDOS(GLONADS)(1..MAXFIC) , WFCT(GLONAFC)(1..MAXFIC)
Local Char    WNUM(10)(1..MAXFIC) , WPRC(20)(1..MAXFIC) , WMAC(GLONAMC)(1..MAXFIC)
Local Char    WTIM(10)(1..MAXFIC) , WSRV(10)(1..MAXFIC) , WUSR(20)(1..MAXFIC)
Local Integer WTYP(1..MAXFIC)
Local Date    WDAT(1..MAXFIC)
Local File   (Char CLI(GLONAMC) , Char DOS(GLONADS) , Char FCT(GLONAFC) , Date DAT , Char TIM(10)
&           , Char NUM(10) , Char PRC(20) , Char MAC(GLONAMC) , Char SRV(10) , Char USR(20) , Integer TYP)
&     From    Variable WCLI , WDOS , WFCT , WDAT , WTIM , WNUM , WPRC , WMAC , WSRV , WUSR , WTYP
&     As     [FIC]
NBCOL  = 1 : COL(NBCOL) = "[F:FIC]CLI" : COLTYP(NBCOL) = type([F:FIC]CLI) : TIT(NBCOL) = mess(87,134,1)
NBCOL += 1 : COL(NBCOL) = "[F:FIC]DOS" : COLTYP(NBCOL) = type([F:FIC]DOS) : TIT(NBCOL) = mess(3,23,1)
NBCOL += 1 : COL(NBCOL) = "[F:FIC]FCT" : COLTYP(NBCOL) = type([F:FIC]FCT) : TIT(NBCOL) = mess(75,123,1)
NBCOL += 1 : COL(NBCOL) = "[F:FIC]DAT" : COLTYP(NBCOL) = type([F:FIC]DAT) : TIT(NBCOL) = mess(88,100,1)
NBCOL += 1 : COL(NBCOL) = "[F:FIC]TIM" : COLTYP(NBCOL) = type([F:FIC]TIM) : TIT(NBCOL) = mess(91,134,1)
NBCOL += 1 : COL(NBCOL) = "[F:FIC]NUM" : COLTYP(NBCOL) = type([F:FIC]NUM) : TIT(NBCOL) = mess(3,134,1)
NBCOL += 1 : COL(NBCOL) = "[F:FIC]PRC" : COLTYP(NBCOL) = type([F:FIC]PRC) : TIT(NBCOL) = mess(88,134,1)
NBCOL += 1 : COL(NBCOL) = "[F:FIC]MAC" : COLTYP(NBCOL) = type([F:FIC]MAC) : TIT(NBCOL) = mess(89,134,1)
NBCOL += 1 : COL(NBCOL) = "[F:FIC]SRV" : COLTYP(NBCOL) = type([F:FIC]SRV) : TIT(NBCOL) = mess(22,151,1)
NBCOL += 1 : COL(NBCOL) = "[F:FIC]USR" : COLTYP(NBCOL) = type([F:FIC]USR) : TIT(NBCOL) = mess(24,151,1)
NBCOL += 1 : COL(NBCOL) = "mess([F:FIC]TYP,924,1)" : COLTYP(NBCOL) = 1    : TIT(NBCOL) = mess(59,100,1)
K = 0
For I=0 To [M:PSA]NBLIG-1
 For J=[M:PSA]PTD(I) To [M:PSA]PTF(I)
  If K+1>MAXFIC : Break 2 : Endif
  K += 1
  WCLI(K) = [M:PSA]CLIENT(I)
  WDOS(K) = [M:PSA]DOSSIER(I)
  WFCT(K) = [M:PSA]FONCTION(I)
  WDAT(K) = [M:PSA]DATCON(I)
  WTIM(K) = [M:PSA]HRECON(I)
  WNUM(K) = [M:PSA]TBNUM(J)
  WPRC(K) = [M:PSA]TBPROC(J)
  WMAC(K) = [M:PSA]TBMAC(J)
  WSRV(K) = [M:PSA]PORT(I)
  WUSR(K) = [M:PSA]USER(I)
  WTYP(K) = [M:PSA]TYP(I)
 Next J
Next I
For I=K+1 To MAXFIC
 WNUM(I) = chr$(255)
Next I
adxmxl = K
Default File [FIC]
TIT   = mess(90,134,1)-"("+num$(K)+")" : # Liste des processus
ORDRE = "NUM"
START = "NUM"
Return


#--------------------------------------------------#
#  Test d'existence d'un processus
#--------------------------------------------------#

Subprog TEST_PROCESS(MACHINE,APPLI,PROCESS,STAT)
Value    Char    MACHINE
Value    Char    APPLI
Value    Char    PROCESS
Variable Integer STAT

Local Char    ORDRE(250)
Local Char    RESULT(10)
Local Char    OS(250)(1..3)

Call GET_OS(MACHINE,OS) From ORDSYS
Case OS(1)
 When "unix"
  ORDRE = "ent_ps" - PROCESS - ">/dev/null ; echo $?"
  Call SYSTEME2(MACHINE,ORDRE,"",STAT,RESULT) From ORDSYS
  STAT = val(RESULT)
 When "dos"
  Local Integer IJ
  Local Char    VAL_PID(10)
  Local Char    ORDRE(250)
  Local Char    TEMPON(250)
  Local Char    FICBAT(250) , SYSBAT(250)
  Local Char    FICRES(250) , SYSRES(250)
  FICBAT = filpath("tmp","psadx","bat",APPLI,"",MACHINE)
  SYSBAT = FICBAT
  IJ = instr(1,SYSBAT,"@")
  If IJ
   SYSBAT = right$(SYSBAT,IJ+1)
  Endif
  FICRES = filpath("tmp","psadx","res",APPLI,"",MACHINE)
  SYSRES = FICRES
  IJ = instr(1,SYSRES,"@")
  If IJ
   SYSRES = right$(SYSRES,IJ+1)
  Endif
  Openo FICBAT , 0 Using [CMD]
  Iomode adxifs "" Using [CMD]
  Iomode adxirs chr$(13)+chr$(10) Using [CMD]
  Iomode adxium GASCII Using [CMD]
  Wrseq "@echo off" Using [CMD]
  If adxmac(0)=""
   #102739
   #Wrseq "SET ADXDIR="+adxdir Using [CMD]
   #Wrseq "SET TMPDIR="+adxdir+"\tmp" Using [CMD]
   #Wrseq "SET PATH=%ADXDIR%\ebin;%ADXDIR%\bin;%PATH%" Using [CMD]
   Wrseq "%ADXDIR%\bin\KILLADX.EXE -e"-num$(val(PROCESS))-">"-SYSRES Using [CMD]
  Else
   Wrseq "KILLADX.EXE -e"-num$(val(PROCESS))-">"-SYSRES Using [CMD]
  Endif
  Wrseq "exit" Using [CMD]
  Openo Using [CMD]
  ORDRE = SYSBAT
  Call SYSTEME(MACHINE,ORDRE,"",STAT) From ORDSYS
  VAL_PID = ""
  Openi FICRES Using [CMD]
  Iomode adxifs "" Using [CMD]
  Iomode adxirs chr$(13)+chr$(10) Using [CMD]
  Iomode adxium GASCII Using [CMD]
  STAT = 1
  Rdseq TEMPON Using [CMD]
  While fstat=0
   If pat(TEMPON,"*STILL ALIVE*")>0 : STAT = 0 : Endif
   Rdseq TEMPON Using [CMD]
  Wend
  Openi Using [CMD]
Endcase
End


#--------------------------------------------------#
Subprog RECHERCHE(NUPROC)
Variable Char NUPROC
Local Integer OK
Local Mask PSADXR [DIA]
Call DIALWIN(OK,mess(86,134,1),"PSADXR") From GESECRAN : # Recherche d'un processus
If OK=2
 NUPROC = [M:DIA]NUPROC
Endif
End


