Funprog LOGIN
If func ASESSIONS.ISMNGSESSIONS
 End func ASESSIONS.LOGIN
Endif
Local Char LOGIN_RESEAU(30)
Local Char SID(12) , SCLI(80) , SLOG(20)
Local File (SID,SCLI,SLOG) From System adxmac(0)+"@psadx -n -l"-GLANGUE As [SYS_] Where [SYS_]SID=num$(adxuid(1))
For [SYS_]
 LOGIN_RESEAU = [F:SYS_]SLOG : Break
Next SYS_
Close Local File [SYS_]
End LOGIN_RESEAU

#----------------------------------------------------------------#
# Quel est ma machine ?
#----------------------------------------------------------------#

Funprog MYPC
If func ASESSIONS.ISMNGSESSIONS
 End func ASESSIONS.MYPC
Endif
Local Char PC(80)
Local Char SID(12) , SCLI(80)
Local File (SID,SCLI,SLOG) From System adxmac(0)+"@psadx -l"-GLANGUE As [SYS_] Where [SYS_]SID=num$(adxuid(1))
For [SYS_]
 PC = [F:SYS_]SCLI : Break
Next SYS_
Close Local File [SYS_]
If PC="" : # Si la session de l'utilisateur n'est pas encore inscrite (connecté)
 PC = adxmac(-2)
Endif
End PC

#----------------------------------------------------------------#
# Permet de killer un processus
#----------------------------------------------------------------#

Subprog KILLPROC(MACHINE,PROCESS,MESSA,ERRMES)
Value Char    MACHINE , PROCESS , MESSA
Variable Char ERRMES
Local Char    ORDSYS(250)(1..2) , FICTRA(GDIMFIC)
Local Char    MESSAGE(80)(1..5) , OS(20) , MOTIF(GLONADI)
Local Integer K , STAT , OK
ERRMES = ""
Call GET_OS(MACHINE,OS) From ORDSYS
$KILL_OS
Case OS
 When "unix" : ORDSYS(1) = "killadx -9"-PROCESS
 When "dos"  : ORDSYS(1) = "killadx"-PROCESS
 When ""
  If !(left$(MACHINE,1)>="0" & left$(MACHINE,1)<="9")
   K = instr(1,MACHINE,".")
   If K
    MACHINE = left$(MACHINE,K-1)
    Call GET_OS(MACHINE,OS) From ORDSYS
   Endif
  Endif
  If OS="" | !find(OS,"unix","dos")
   ERRMES = MACHINE-":"-mess(199,100,1) : # Machine inaccessible
   End
  Endif
  Goto KILL_OS
Endcase
FICTRA = filpath("tmp","psadx_"+num$(adxuid(2)),"tra",nomap)
Openo FICTRA,0 Using [TR_]
Openo Using [TR_]
ORDSYS(2)  = FICTRA
Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
If STAT
 # Erreur
 ERRMES = mess(6,123,1)-num$(STAT)-"SYSTEME"+"\|"+ORDSYS(1)
Endif
Openi FICTRA Using [TR_]
Iomode adxifs "" Using [TR_]
Iomode adxirs chr$(10) Using [TR_]
Raz MESSAGE
Rdseq MESSAGE(1) Using [TR_]
Rdseq MESSAGE(2) Using [TR_]
Rdseq MESSAGE(3) Using [TR_]
Rdseq MESSAGE(4) Using [TR_]
Rdseq MESSAGE(5) Using [TR_]
Openi Using [TR_]
OK = 1
If MESSAGE(1)<>""
 OK = 0
 For I=1 To 5
  If instr(1,MESSAGE(I),"(3)") or instr(1,MESSAGE(I),"(87)") : # Processus inexistant
   OK = 1 : Break
  Endif
 Next I
Endif
If !OK
 # Arrêt processus
 ERRMES = mess(54,115,1)-PROCESS+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3)+"|\|"+MESSAGE(4)
Endif
Call EFFACE(FICTRA,STAT) From ORDSYS
If STAT
 # Erreur
 ERRMES = mess(6,123,1)-num$(STAT)-"EFFACE"+"\|"+FICTRA
Elsif ORDSYS(1)<>""
 # Espionnage des kill process
 Call TRACE_ORDRE(MOTIF,ORDSYS(1)-"("+MESSA+")") From ESPION
Endif
End

#----------------------------------------------------------------#
# Permet de retrouver le adxuid(1) d'un symbole verrouillé
#----------------------------------------------------------------#

Subprog PROCESS_LOCK_SYMB(DOSSIER,SYMBOLE,UID)
Value Char DOSSIER , SYMBOLE
Variable Char UID
If DOSSIER="" or DOSSIER=nomap
 Local File APLLCK [ALK]
Else
 Local File =DOSSIER+".APLLCK" [ALK]
Endif
UID = ""
Read [ALK]LCKCLE(1) = SYMBOLE
If !fstat
 UID = num$([F:ALK]LCKPID)
Endif
End

#-----------------------------------------------------------------------------------#
# Permet de killer tous les processus d'un adxuid(1)
#-----------------------------------------------------------------------------------#

Subprog KILL_ALLPROC(UID)
Value Char UID
If func ASESSIONS.ISMNGSESSIONS
 Call KILL_ALLPROC(UID) From ASESSIONS
 End
Endif
Local Char SID(250) , SCLI(80) , SADR(40) , SUSER(50) , SDOS(40) , SPRO(250)
Local Char ORDSYS(250) , NUM(30) , MAC(80) , PROC(20) , ERRMES(250) , MESSA(250)
Local Integer OK
ORDSYS = adxmac(0)+"@psadx -agix"
Local File (SID,SCLI,SADR,SUSER,SUID,SPRO) From System ORDSYS As [SYS_]
Raz OK , MESSA
For [SYS_]
 If !OK & [F:SYS_]SUID=UID
  OK = 1
 Endif
 If OK
  If [F:SYS_]SUID=UID : # Ligne d'entête
   Call GET_PROCESS([F:SYS_]SPRO,NUM,MAC,PROC)
   MESSA = [F:SYS_]SCLI-[F:SYS_]SADR-[F:SYS_]SUSER
  Elsif [F:SYS_]SUID="" : # Ligne de processus
   Call GET_PROCESS([F:SYS_]SID,NUM,MAC,PROC)
  Else
   Break
  Endif
  Call KILLPROC(MAC,NUM,MESSA,ERRMES)
 Endif
Next SYS_
Close Local File [SYS_]
End

Subprog LOGIN_CPU(USER,APPLI,UID,LOGIN,CPU)
Value Char USER , APPLI , UID
Variable Char LOGIN , CPU
If func ASESSIONS.ISMNGSESSIONS
 Call LOGIN_CPU(USER,APPLI,UID,LOGIN,CPU) From ASESSIONS
 End
Endif
Local Char       SID(12) , SCLI(80) , SDOS(80) , SLOG(30) , SCPU(20) , SUSER(30)
If [L]APPLI="" : [L]APPLI = nomap : Endif
If [L]USER=""  : [L]USER  = GUSER : Endif
Local File (SID,SCLI,SDOS,SLOG,SCPU,SUSR) From System adxmac(0)+"@psadx -nz"-"-u"-[L]USER-"-b"-[L]APPLI As [SYS_]
For [SYS_]
 If [L]UID=[F:SYS_]SID
  [L]LOGIN = [F:SYS_]SLOG
  #115751
  #[L]CPU   = space$(6-min(instr(1,[F:SYS_]SCPU,":"),5))+[F:SYS_]SCPU
  [L]CPU   = [F:SYS_]SCPU
  Break
 Endif
Next SYS_
Close Local File [SYS_]
End

#--------------------------------------------------#
# Récupérer le no de process d'un poste client
#--------------------------------------------------#

Subprog PROCLI(APPLI,CLIENT,PORT,SESSION,PROCESS)
Value    Char APPLI , CLIENT
Value Integer PORT , SESSION
Variable Char PROCESS()(1..)
Local Char    SID(250) , SPORT(20) , SCLI(80) , SDOS(40)
Local Char    SSER(30) , SPRO(250) , ORDSYS(250)
Local Integer I , LIGENT , K , NBPROC
ORDSYS = "psadx -xptf"
LIGENT = 0
NBPROC = 0
Raz PROCESS
Local File (SID,SPORT,SCLI,SDOS,SSER,SPRO) From System ORDSYS As [SYS_]
For [SYS_]
 If LIGENT<2
  LIGENT += 1
 Else
  If [F:SYS_]SID="" & [F:SYS_]SPORT<>""
   # Dernière ligne
  Elsif [F:SYS_]SID=""
   # Ligne de processus
  Else
   K = (APPLI="" or [F:SYS_]SDOS=APPLI)
   K *= (CLIENT="" or [F:SYS_]SCLI=CLIENT)
   K *= (PORT=0 or [F:SYS_]SPORT=num$(PORT))
   K *= (SESSION=0 or [F:SYS_]SSER=num$(SESSION))
   If K
    If NBPROC>=dim(PROCESS)
     Break
    Else
     NBPROC += 1
     PROCESS(NBPROC) = [F:SYS_]SPRO
     I = instr(1,PROCESS(NBPROC),":")
     If I
      PROCESS(NBPROC) = left$(PROCESS(NBPROC),I-1)
     Endif
    Endif
   Endif
  Endif
 Endif
Next SYS_
Close Local File [SYS_]
End

#--------------------------------------------------#
# Récupérer le  temsp CPU du process
#--------------------------------------------------#

Subprog CPU_PROCESS(MACHINE,PROCESS,TIMECPU,ERRMES)
Value Char    MACHINE , PROCESS
Variable Char TIMECPU,ERRMES

If func ASESSIONS.ISMNGSESSIONSWITHCPU=[V]CST_AFALSE : Raz TIMECPU : End : Endif

Local Char    ORDSYS(250)(1..2) , FICTRA(GDIMFIC)
Local Char    MESSAGE(80)(1..5) , OS(20) , MOTIF(GLONADI)
Local Integer K , STAT , OK
ERRMES = ""
Call GET_OS(MACHINE,OS) From ORDSYS
$CPUPROCESS
Case OS
 When "unix" : ORDSYS(1) = "killadx -u"-PROCESS
 When "dos"  : ORDSYS(1) = "killadx -u"-PROCESS
 When ""
  If !(left$(MACHINE,1)>="0" & left$(MACHINE,1)<="9")
   K = instr(1,MACHINE,".")
   If K
    MACHINE = left$(MACHINE,K-1)
    Call GET_OS(MACHINE,OS) From ORDSYS
   Endif
  Endif
  If OS="" | !find(OS,"unix","dos")
   ERRMES = MACHINE-":"-mess(199,100,1) : # Machine inaccessible
   End
  Endif
  Goto CPUPROCESS
Endcase
FICTRA = filpath("tmp","psadx_"+num$(adxuid(2)),"tra",nomap)
Openo FICTRA,0 Using [TR_]
Openo Using [TR_]
ORDSYS(2)  = FICTRA
Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
If STAT
 # Erreur
 ERRMES = mess(6,123,1)-num$(STAT)-"SYSTEME"+"\|"+ORDSYS(1)
Endif
Openi FICTRA Using [TR_]
Iomode adxifs "" Using [TR_]
Iomode adxirs chr$(10) Using [TR_]
Raz MESSAGE
Rdseq MESSAGE(1) Using [TR_]
Rdseq MESSAGE(2) Using [TR_]
Rdseq MESSAGE(3) Using [TR_]
Rdseq MESSAGE(4) Using [TR_]
Openi Using [TR_]
Call EFFACE(FICTRA,STAT) From ORDSYS
TIMECPU = sum(MESSAGE)
If pat(TIMECPU,"**:**:**")=0 : Raz TIMECPU : Endif
End

#--------------------------------------------------------------------------------------------------------#
# Ecran PSADX
#--------------------------------------------------------------------------------------------------------#

Subprog AS_NBLIG
Local Integer I , NOL , NOL1
If nolign>=1 & nolign<=[M]NBLIG & [M]PTD(nolign-1)<>0
 NOL = nolign-1
 [M]LIGSES = nolign
 [M]NBPROC = 0
 For I=[M]PTD(NOL) To [M]PTF(NOL)
  NOL1 = [M]NBPROC
  [M]NBPROC += 1
  [M]NUMERO(NOL1)  = [M]TBNUM(I)
  [M]PROCESS(NOL1) = [M]TBPROC(I)
  [M]MACHINE(NOL1) = [M]TBMAC(I)
 Next I
 If dim([M]ALLPRO)>0 & [M]ALLPRO=1
  Call LOGIN_CPU([M]USER(NOL),[M]DOSSIER(NOL),[M]ID(NOL),[M]LOGIN(NOL),[M]CPU(NOL))
  Affzo LOGIN(NOL) , CPU(NOL)
 Endif
 Inftxt [M]CLIENT(NOL)-"("+[M]LOGIN(NOL)+")"-[M]FONCTION(NOL)-"cpu:"+[M]CPU(NOL) At 1
 Affzo 30
 nolign = NOL+1
Else
 Raz [M]NBPROC,[M]NUMERO,[M]PROCESS,[M]MACHINE
 Affzo 30
Endif
End

Subprog C_SERVEUR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Local Integer OK
 Call LECMAC(VALEUR,OK) From DOSCONT
 If !OK : mkstat = 2 : Endif
Endif
End

Subprog AM_SERVEUR(VALEUR)
Variable Char    VALEUR()
End

Subprog IB_NBPROC
If instr(1,GUSRAUZ(1),"K")
 GBOUT1 = mess(248,100,1) : # Session closure
Else
 GBOUT1 = ""
Endif
End

Subprog S_NUPROC(VALEUR)
Variable Char    VALEUR()
Local Char PARAM(250)(1..1)
Call S_TAB_CHAR(VALEUR,PARAM,"PROCESSUS","PSADX","") From GACTION
End

Subprog B1_NBPROC
  Local Char     MESSAGE(250), PROCESS(100), OUTPUT_LOGNAME(100)
  Local Integer  OK, NOL, LECTRACE

  # 2018-01-13 - JPGA X3-64517 : Adding-session-kill-button-in-PSADX-APSDX
  If [M]LIGSES>0 and [M]NBPROC>0
    # We retreive the list of Processes for the Session given by the current record
    Raz PROCESS
    For NOL=0 To [M]NBPROC-1
      If [M]NUMERO(NOL)<>""
        PROCESS -= [M]NUMERO(NOL)
      Endif
    Next NOL

    # We initiate the Session closure calling a SYRACUSE function
    MESSAGE=[M]CLIENT([M]LIGSES-1)-[M]DOSSIER([M]LIGSES-1)-[M]PORT([M]LIGSES-1)-[M]USER([M]LIGSES-1)
    OK = 2 : Call OUINON(mess(248,100,1)-[M]ID([M]LIGSES-1)-"("+MESSAGE+")"-mess(90,134,1)-":"-PROCESS,OK) From GESECRAN
    If OK=2
      [L]LECTRACE=[V]CST_AYES

      Call CLOSE_SOCKET_WITH_LOG([M]ID([M]LIGSES-1), null, PROCESS, MESSAGE, [L]LECTRACE, [L]OUTPUT_LOGNAME) From ASESSIONS
    Endif
  Endif
  status = GSTABOU+1 : mkstat = 3 : # Pour réactualiser
End

