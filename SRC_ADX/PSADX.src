#-----------------------------------------------------------------------------------#
# Recherche du nombre de sessions ouvertes dans une appli pour un utilisateur
#-----------------------------------------------------------------------------------#

Subprog USER_CONNECT(LOGIN,APPLI,NBSES)
Value Char LOGIN , APPLI
Variable Integer NBSES
If func ASESSIONS.ISMNGSESSIONS
 Call USER_CONNECT(LOGIN,APPLI,NBSES) From ASESSIONS
 End
Endif
Local Char       SID(12) , SCLI(80) , SUSR(30) , SDOS(30)
If APPLI="" : APPLI = nomap : Endif
Local File (SID,SCLI,SDOS,SUSR) From System adxmac(0)+"@psadx -g"-"-b"-APPLI As [SYS_]
NBSES = 0
For [SYS_]
 If tolower([F:SYS_]SUSR)=tolower(left$(LOGIN,func MAXCAR_LOG))
  NBSES += 1
 Endif
Next SYS_
Close Local File [SYS_]
End

#--------------------------------------------------------------#
# Limite (vient du psadx) de la longueur du login en v6
#--------------------------------------------------------------#

Funprog MAXCAR_LOG
End 20

#-------------------------------------------------------------------------------------------------#
# Utilisé pour savoir s'il y a des connections ADAPI sur l'appli avant de passer en mono
#-------------------------------------------------------------------------------------------------#

Subprog USER_CONADAPI(DOSSIER,NBSES)
Value Char DOSSIER
Variable Integer NBSES
If func ASESSIONS.ISMNGSESSIONS
 Call USER_CONADAPI(DOSSIER,NBSES) From ASESSIONS
 End
Endif
Local Char       SID(12) , SCLI(80) , SDOS(30) , STYP(12)
Local Char       MACHINE(GLONAMC) , APPLI(GLONADS)
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
Local File (SID,SCLI,SDOS,STYP) From System MACHINE+"@psadx -tf -b"-APPLI As [SYS_] Where [SYS_]SDOS=APPLI
NBSES = 0
For [SYS_]
 If !find([SYS_]STYP,"4","7") : # Web services/Bridge Java
  NBSES += 1
 Endif
Next SYS_
Close Local File [SYS_]
End

#--------------------------------------------------------------------------------------------#
# Pour savoir le nombre de session ouvertes par type et éventuellement pour un utilisateur
#--------------------------------------------------------------------------------------------#

Subprog USER_NBCON(LOGIN,TYPSES,NBSES)
Value Char LOGIN
Value Integer TYPSES
Variable Integer NBSES
If func ASESSIONS.ISMNGSESSIONS
 Call USER_NBCON(LOGIN,TYPSES,NBSES) From ASESSIONS
 End
Endif
Local Char SID(12), SCLI(80), SUSR(30), SSER(10)
Local Integer K
If LOGIN<>""
 Local File (SID,SCLI,SUSR,SSER) From System adxmac(0)+"@psadx -t -g" As [SYS_]
Else
 Local File (SID,SCLI,SSER) From System adxmac(0)+"@psadx -t" As [SYS_]
Endif
NBSES = 0
For [SYS_]
 K = (mod(val([SYS_]SSER),8)=TYPSES)
 K *= (dim([SYS_]SUSR)<0 or (dim([SYS_]SUSR)>0 & tolower([SYS_]SUSR) = tolower(left$(LOGIN,func MAXCAR_LOG))))
 If K
  NBSES += 1
 Endif
Next SYS_
Close Local File [SYS_]
End

#---------------- adxtyp ----------------------------------#
# 1       : # C/S
# 2       : # Session secondaire C/S
# 3       : # Batch
# 9,10,17 : # Session Web : Primaire/Secondaire/Futur
# 13      : # Terminal VT
# 12      : # Session Web-service
# 25      : # Classic page
# 33      : # Web page
#----------------------------------------------------------#

#--------------------------------------------------------------------------------------------#
# Pour savoir le nombre de session ouvertes par type sur une appli
#--------------------------------------------------------------------------------------------#

Subprog USER_NBCON_APP(APPLI,TYPSES,NBSES)
Value Char APPLI
Value Integer TYPSES
Variable Integer NBSES
If func ASESSIONS.ISMNGSESSIONS
 Call USER_NBCON_APP(APPLI,TYPSES,NBSES) From ASESSIONS
 End
Endif
If APPLI="" : APPLI = nomap : Endif
Local Char    SID(12) , SCLI(80) , SDOS(30) , SSER(10)
Local File (SID,SCLI,SDOS,SSER) From System adxmac(0)+"@psadx -t -b"-APPLI As [SYS_] Where [SYS_]SDOS=APPLI
NBSES = 0
For [SYS_]
 If TYPSES=0 or mod(val([SYS_]SSER),8)=TYPSES
  NBSES += 1
 Endif
Next SYS_
Close Local File [SYS_]
End

#--------------------------------------------------------------------------------------------#
# Pour savoir le nombre de session ouvertes par type sur une appli pour un user
# non web donc sauf adxtyp=25
#--------------------------------------------------------------------------------------------#
#118292
Subprog NBCON_APPNOWEB_USER(LOGIN,APPLI,TYPSES,NBSES)
Value Char LOGIN
Value Char APPLI
Value Integer TYPSES
Variable Integer NBSES
If func ASESSIONS.ISMNGSESSIONS
 Call NBCON_APPNOWEB_USER(LOGIN,APPLI,TYPSES,NBSES) From ASESSIONS
 End
Endif
If APPLI="" : APPLI = nomap : Endif
Local Char    SID(12) , SCLI(80) , SDOS(30) , SSER(10), SUSR(30)
Local Integer K
If LOGIN<>""
 Local File (SID,SCLI,SDOS,SUSR,SSER) From System adxmac(0)+"@psadx -t -b"-APPLI-"-g" As [SYS_] Where [SYS_]SDOS=APPLI
Else
 Local File (SID,SCLI,SDOS,SSER) From System adxmac(0)+"@psadx -t -b"-APPLI As [SYS_] Where [SYS_]SDOS=APPLI
Endif
NBSES = 0
For [SYS_]
 K = (mod(val([SYS_]SSER),8)=TYPSES) & val([SYS_]SSER)<>25
 K *= (dim([SYS_]SUSR)<0 or (dim([SYS_]SUSR)>0 & tolower([SYS_]SUSR) = tolower(left$(LOGIN,func MAXCAR_LOG))))
 If K
  NBSES += 1
 Endif
Next SYS_
Close Local File [SYS_]
End

