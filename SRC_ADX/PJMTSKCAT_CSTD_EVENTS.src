#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Classe PJMTSKCAT
#######################################################################################
# EVENTS                                                                              #
#######################################################################################
$ACONTROL
  # if task type is 1 or 4 then value must be 4 else must not be 4
  If this.TASTYP = 1 or this.TASTYP = 4 Then
    If this.TCAMOD <> 4 Then
      [L]ASTATUS = fmet this.ASETERROR("TCAMOD", func AFNC.MES2(mess(72,2260,1), mess(this.TCAMOD,2263,1), mess(this.TASTYP,2252,1)), [V]CST_AERROR)
    Endif
  Else
    If this.TCAMOD = 4 Then
      [L]ASTATUS = fmet this.ASETERROR("TCAMOD", func AFNC.MES2(mess(72,2260,1), mess(this.TCAMOD,2263,1), mess(this.TASTYP,2252,1)), [V]CST_AERROR)
    Endif
  Endif
Return

#######################################################################################
$AINSERT_CONTROL_BEFORE
  Gosub AINSERT_AUPDATE_CONTROL_BEFORE
Return

#######################################################################################
$AUPDATE_CONTROL_BEFORE
  Gosub AINSERT_AUPDATE_CONTROL_BEFORE
Return

#######################################################################################
$AINSERT_AUPDATE_CONTROL_BEFORE
  If this.TCADESX = AVOID.ACHAR Then
    this.TCADESX = left$(this.TCADESAXX, type(this.TCADESX)-10)
  Endif
Return

