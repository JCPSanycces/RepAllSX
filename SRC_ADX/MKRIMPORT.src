#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPORTATION("MKR") From GIMPOBJ
End

###################################################################################
$ACTION
Case ACTION
    When "EXPORT"    :  Gosub EXPORT
    When "IMP_ZONE"  :  Gosub IMP_ZONE
    When "IMP_FERME" :  Gosub IMP_FERME
Endcase
Return

###################################################################################
$EXPORT
If clalev ([F:MTK]) = 0 : Local File MFGHEADTRK  [MTK] : Endif
Read [F:MTK]MTK0 = [F:MKM]MFGTRKNUM
If fstat : Raz [F:MTK] : Endif
# Cf 57336 Modification du nombre de paramètres de SETDATE
Call SETDATE([F:MTK]MFGTRKDAT,GIMP(1),[F:AOE]OPTDAT) From SUBEXPOBJ
Return

###################################################################################
$IMP_FERME
# Cf bug 87599 gestion du lock symbole sur OF
Call DELOCK("MFG") From GLOCK
If GSTK_TRACE=2
  GSTK_ACT="FERME" : GSTK_PGM="GOBJSUB" : Gosub TRACE_DETAILLEE From STKIMP
Endif
[L]ACTION="FERME"       : Gosub ACTION From GOBJSUB : Gosub DEFAUT From WOMKM
GSTK_ACTION="IMP_FERME" : Gosub ACTION From STKIMP
Kill GSTK_ACTION, GSTK_BASTAB, GSTK_TRSTYP, GSTK_VCRTYP, GSTK_TRACE
Kill GNOLIG  # GH 10/07/2017 Issue 38585 - cleaning for the new global variable
Return

###################################################################################
$IMP_ZONE
Case IMPFIC
  When "MKM"
      #----- Pas de contrôle si les comptes et sections sont importés avec "CAL" -----#
    Case IMPZON
      When "LINACC1","LINACC2","LINACC3","LINACC4","LINACC5",
&          "LINACC6","LINACC7","LINACC8","LINACC9","LINACC10",
&          "CCE1", "CCE2", "CCE3", "CCE4", "CCE5", "CCE6", "CCE7", "CCE8", "CCE9", "CCE10",
&          "CCE11","CCE12","CCE13","CCE14","CCE15","CCE16","CCE17","CCE18","CCE19","CCE20"
          If find("CPTANALIN",[M:AOE1]FLGFIL(0..[M:AOE1]NBRFLG))
            OK=0 : mkstat=1 : # Zones non concernées par PRECEIPTD
          Endif
      #-----
    Endcase
  When "CAL"
    #----- La zone présente dans le modèle a déjà été chargée par IMPORT_ACCCCE du $SAIMSK
    If find("[F:CAL]"+IMPZON+"(0)",[M:AOE2]ZONMSK1)
      If GSTK_TRACE=2
        GSTK_ACT="IMP_ZONE("+IMPZON+")" : GSTK_PGM="MKRIMPORT"
        Gosub TRACE_DETAILLEE From STKIMP
      Endif
      IMPMOD=1
    Endif
    OK=0
    #-----
     When "STJ"
           GSTK_ACTION="IMP_ZONE" : Gosub ACTION From STKIMP
Endcase
Return

###########################################################
# Ouvertures                                              #
# GIMP :                                                  #
#     GIMP(1) : Date du suivi                             #
#     GIMP(2) : Transaction suivi des matières à utiliser #
#     GIMP(3) : Indicateur de solde                       #
###########################################################
$OUVRE
Local   Char    WMESSAGE(250)
Global  Char    GMRENUM(GLONTRS) : Raz GMRENUM
Global  Integer G_DATOK, G_TRSOK, G_CLEFLGOK
Global  Integer G_LIN, G_WNBMAT
Global  Integer G_WMATCLENBR
Global  Date    G_DATE
# Cf 86522 : sauvegarde du site précédent
Global  Char    G_FCY(GLONFCY)
Global  Char    G_MFGNUM(GLONVCR),G_WMFGNUM(GLONVCR),G_MFGTRKNUM(GLONVCR)

Global   Char    GSTK_ACTION (20)                              : # Nom action de STKIMP
Global   Char    GSTK_BASTAB (20) : GSTK_BASTAB="[M:MBR]NBLIG": # Nom variable bas tableau
Global   Libelle GSTK_TRSTYP      : GSTK_TRSTYP=19              : # Type mouvement (M.704)
Global   Libelle GSTK_VCRTYP      : GSTK_VCRTYP=12              : # Type pièce (M.701)

#---- Cf bug 92531
Global   Libelle GSTK_TRACE       : GSTK_TRACE =1              : # Trace détaillée si =2
If GSTOTRACE>2 : GSTK_TRACE=2 : Endif

Global Integer GNOLIG  : # GH 10/07/2017 Issue 38585 - declared because used in TRTSTOENT by fields SLOAFF and LOTAFF
#-----

Local Integer DEBENR_SVG, LCOMMIT
Local Integer WMKMFLG : WMKMFLG=1
Local Integer WADXSEK, NBENR_SVG
#
#Pour savoir si la date de suivi et la transaction à utiliser sont paramétrées
Call TST_CHAMP("MKM","*1",G_DATOK)    From SUBIMPOBJ    : # date du suivi
Call TST_CHAMP("MKM","*2",G_TRSOK)    From SUBIMPOBJ    : # Transaction de suivi des temps
Call TST_CHAMP("MKM","*3",G_CLEFLGOK) From SUBIMPOBJ    : # Indicateur de solde
#


###---
If clalev([M:MBR])=0  : Local Mask MTKBENCHR [MBR]  : Endif       # masque buffer suivi matière
If clalev([F:MKMR])<=0 : Local File MFGMATTRK  [MKMR] : Endif
If clalev([F:TBO])<=0 : Local File TABBOMALT  [TBO] : Endif
If clalev([F:TCA])<=0 : Local File TABCOUAFF  [TCA] : Endif
If clalev([F:BTS])<=0 : Local File BENCHTRS   [BTS] : Endif

Gosub OUVRE From FUNBENCHR
GFCY=""     # allow to call CHARG_PARAM on the first record

Gosub FLD_MODELE From TRTX3IMP

GSTK_ACTION="OUVRE" : Gosub ACTION From STKIMP
[L]WSTK_ABRTTR="BTS" : # Abréviation table transaction de saisie

Return

####################################################
$CHARG_PARAM

# Cf 81181 : Récupération de la transaction par défaut
If G_TRSOK
    Read [F:BTS]BTS0 = 63;GIMP(2)
    If !fstat
        GMRENUM=GIMP(2)
    Endif
Else
    fstat=5
Endif
If fstat
    Call PARAM(GFCY,"MKRTRSNUM",GMKRTRSNUM) From ADOVAL
    Read [F:BTS]BTS0 = 63;GMKRTRSNUM
    If fstat
        OK = 0 : GOK = 0
        Call ECR_TRACE(mess(6,199,1)-'BTSNUM="'+GMKRTRSNUM+'"',1) From GESECRAN
        Return
    Else
        GMRENUM=GMKRTRSNUM
    Endif
Endif

Gosub CHARG_PARAM From FUNBENCHR
Call GETCPY(GFCY,"BTS",63,GMRENUM) From TRTX3CPT

# Cf 86725 : idem 72699/SUBMTKA Change counter when change current site
Local Integer WOK
Call LECTCA(8,WOK) From SUBTCA
If WOK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : Return : Endif
GCODNUM    = [F:TCA]CODNUM(2)   # compteur suivi
GMANCOU    = [F:TCA]MANCOU(2)
GOPS       = [F:TCA]CODNUM(4)   # compteur encours opérations

Return

######################################################
# Réinitialisation après création (début de lecture)
$RAZCRE
Raz [M:MTMK]
GREP="C"
Raz [M:MBR]
If GSTK_TRACE=2
  GSTK_ACT="RAZCRE" : GSTK_PGM="GOBJSUB" : Gosub TRACE_DETAILLEE From STKIMP
Endif
[L]ACTION="RAZCRE"   : Gosub ACTION From GOBJSUB : Gosub DEFAUT From WOMKM
GSTK_ACTION="RAZCRE" : Gosub ACTION From STKIMP
Return

######################################################
$SAIMSK
Local Integer I,J
Local Integer WRET

If IMPFIC<>"MKM" : WMKMFLG=0 :Endif # Permet de savoir si on importe autre chose que seulement le suivi

Case IMPFIC
  When "MKM"
      OK=1 : GOK=1
      If GSTK_NBLIG
          GSTK_ACTION="RUPT_LIGDOC" : Gosub ACTION From STKIMP : # Articles gérés stock
      Endif
      Call DELSTOENTW(-1,-1,"MBR",1,1,[M:MBR]FCY,0,"") From STKENT
      nolign=1 : indice=0

      # Issue 85182 - 2012-10-25 by CCC
      Raz [F:CAL]

      # Control MATTYP
      If !find([F:MKM]MATTYP,3,4)
        OK=0
        GOK=0
        Call ECR_TRACE("MATTYP ="-num$([F:MKM]MATTYP)-":"-mess(83,123,1),1) From GESECRAN
      Endif

      If OK
          [F:MKMR] = [F:MKM]    # [F:MKMR] used in CHARG_MASK to retrieve import data
          [M:MBR]FCY = [F:MKM]MFGFCY
          # Issue 81181 - 2012-03-29 by CCC : Récupération de la transaction par défaut
          If [M:MBR]FCY <> GFCY
               GFCY = [M:MBR]FCY
               Gosub CHARG_PARAM
          Endif
      Endif

      If OK
          # Load [M:MBR]
          Gosub CHARG_MASK From FUNBENCHR
          [F:MKM]=[F:MKMR]

          If [M:MBR]NBLIG<>1
               Raz WMESSAGE
               If [F:MKMR]MFGNUM<>""
                   WMESSAGE-=mess(10,701,1)-[F:MKMR]MFGNUM
               Endif
               If [F:MKMR]MFGTRKNUM<>""
                   WMESSAGE-=mess(12,701,1)-[F:MKMR]MFGTRKNUM-num$([F:MKMR]MATTRKLIN)
               Endif
               WMESSAGE-=[F:MKMR]ITMREF
               If [M:MBR]NBLIG=0
                  Call ECR_TRACE(WMESSAGE-":"-mess(113,75,1),1) From GESECRAN
               Else
                   # Just in case but should not happen
                   Call ECR_TRACE(WMESSAGE-mess(826,196,1)-"([M:MBR]NBLIG="+num$([M:MBR]NBLIG)+")",1) From GESECRAN
               Endif
               OK = 0
               GOK = 0
          Endif

          If G_DATOK
              Call SETDATE([M:MBR]IPTDAT(0),GIMP(1),[M:AOE1]OPTDAT,WRET) From SUBIMPOBJ
              If WRET
                  Call ECR_TRACE("IPTDAT ="-num$([M:MBR]IPTDAT)-":"-mess(83,123,1),1) From GESECRAN
                  OK = 0
                  GOK = 0
              Endif
          Else
              [M:MBR]IPTDAT(0) = date$
          Endif
      Endif

      If OK
          nolign = 1
          indice = 0
          GNOLIG = nolign-1 # GH 10/07/2017 Issue 38585 - affected as parameter NOLIG for action SAIENTLOT on screen MTKBENCHR
          If [F:ITM]ITMREF<>[M:MBR]ITMREF([M:MBR]NBLIG-1)
             Read [ITM] ITM0=[M:MBR]ITMREF([M:MBR]NBLIG-1)
             If fstat  Raz [F:ITM] : Endif
          Endif
          If [F:ITF]ITMREF<>[M:MBR]ITMREF([M:MBR]NBLIG-1) | [F:ITF]STOFCY<>[M:MBR]FCY
             Read [ITF] ITF0=[M:MBR]ITMREF([M:MBR]NBLIG-1);[M:MBR]FCY
             If fstat  Raz [F:ITF] : Endif
          Endif

          # Cf 93975
          Call LECSRU([F:MKM]MFGFCY,[F:ITM]TCLCOD,5,[M:MBR]TRSCODS,"",WRET) From STKLIB
          [M:MBR]PECFLG(0)=2
          [M:MBR]REIQTYPCU(0) = [F:MKM]USEQTY
          [M:MBR]REIQTY(0)    = [F:MKM]USEQTY
          If [M:MBR]PCU(0) = "" : [M:MBR]PCU(0) =   [F:ITM]STU : Endif
          # Cf 98435 : statut par défaut après lecture ITM et SRU
          If [M:MBR]STA(indice)=""
              Local Char    WSTADEF(GLONSTA)
              Call STKINISTA(WSTADEF,"",[F:ITF]QUAFLG) From STKACT
              [M:MBR]STA(indice)=WSTADEF
          Endif

          If GSTK_TRACE=2
             GSTK_ACT="SAI_NBLIG" : GSTK_PGM="W0MTKBENCHR" : Gosub TRACE_DETAILLEE From STKIMP
          Endif
          Default Mask [MBR]
          Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
          # suite aux tests pour demande 38391
          Call SAI_NBLIG("MKM","IMP_ZONE","SUBIMPOBJ") From W0MTKBENCHR
          Setmode

          # Cf 81873 & 87780 : la zone est initialisée dans SAI_NBLIG il faut donc l'alimenter après
          If G_CLEFLGOK
              [M:MBR]CLEFLG = val(GIMP(3))
          Endif
          If [M:MBR]CLEFLG(0) = 0
              [M:MBR]CLEFLG = 3     # To be calculated
          Endif

          If mkstat
              GREP="" : REP="" : mkstat=0 : GOK=0
          Else
              Gosub AAPRES_NBLIG From FUNBENCHR
          Endif
      Endif

  When "CAL"
       # Cf 94225
        Default Mask [MBR]
        indice=0 : mkstat=0

        For I=1 To GNBDIE # before: max(GNBDIE,GOPTCANA)
    #----------------- Contrôle des sections analytiques -----------------#
            Call CTRL_CCE([F:CAL]CCE(I-1),I,"",GFINRSP,[M:MBR]IPTDAT) From TRTX3CPT
            If mkstat
                Call ECR_TRACE(GMESSAGE,1) From GESECRAN
                Raz GMESSAGE
                Raz OK, GOK
                Break
            Endif
            J=find([F:CAL]DIE(I-1),GDIE(1..GNBDIE))
            If J
                Assign "[M:MBR]CCE"+num$(J) With [F:CAL]CCE(I-1)
            Endif
        Next I

   When "STJ"
        If GOK=1
            Default File [STJ]
            GSTK_ACTION="SAIMSK" : Gosub ACTION From STKIMP
            If mkstat
                GREP="" : REP="" : mkstat=0 : GOK=0
            Else
                Raz GOUVENT
            Endif
        Endif
Endcase
If GOK<1
  GOK=1
  LCOMMIT=1
  Gosub FIN_DOC
  LCOMMIT=0
  GOK=0
Endif
Return

######################################################
# Contrôles et mises à jour
$VALID

If GSTK_TRACE=2
  GSTK_ACT='VALID(GREP="'+GREP+'")' : GSTK_PGM="MKRIMPORT" : Gosub TRACE_DETAILLEE From STKIMP
Endif

# If data missing (lot or sernum...) => message
If GOUVENT
    Default File [STJ]
    GSTK_ACTION="SAIMSK" : Gosub ACTION From STKIMP
    If mkstat
        GREP="" : REP="" : mkstat=0 : GOK=0
    Else
        Raz GOUVENT
    Endif
Endif

If GREP="" | GOK=0
    Raz GSTK_NBLIG
    OK=0
    LCOMMIT=1
    Goto FIN_VALID
Endif

[L]OK=1 : Raz GERREUR
If GREP="C"
  #-----
  GSTK_ACTION="VALID" : Gosub ACTION From STKIMP
  If ![L]OK
    Raz GSTK_NBLIG
    OK=0
    LCOMMIT=1
    Goto FIN_VALID
  Endif
Endif

Local Char LSEC(GLONCCE)
If [M:MBR]USEQTY = 0
    WMESSAGE = mess(28,190,1) - [M:MBR]MFGNUM(0)-[M:MBR]ITMREF(0)
    Call ECR_TRACE(WMESSAGE,1) From GESECRAN
    OK = 0
    GOK = 0
    LCOMMIT=1
    # Cf 78484 & 78521 : il faut continuer pour fermer la transaction
    Goto FIN_VALID
Endif
# Chargement [MTMK]
Raz [M:MTMK]
[M:MTMK]             = [M:MBR]
[M:MTMK]MFGFCY       = [M:MBR]FCY
# Cf 40392
[M:MTMK]WNBMAT       = G_WNBMAT

# Cf 83567
Call GETSOC([M:MTMK]MFGFCY) From DEVSUB
Call GETCPY([M:MTMK]MFGFCY,"",0,"") From TRTX3CPT

Raz [M:MTMK]MFGTRKNUM

[M:MTMK]STOCODMAN    = [F:BTS]STOCODMAN
[M:MTMK]ENTCOD     = [F:BTS]ENTCODS
[M:MTMK]TRSFAM     = [F:BTS]TRSFAMS
[M:MTMK]TRSCODS    = [F:BTS]TRSCODS
[M:MTMK]USEQTY     = [M:MBR]REIQTY(0)

If [M:MTMK]MFGNUM <> ""
    [M:MTMK]TYPTRT = 14
Elsif [M:MTMK]BOMNUM <> "" & [M:MTMK]BOMALT <> 0
    [M:MTMK]TYPTRT = 16
Else
  # Aucun suivi effectué
   WMESSAGE = mess(28,190,1)-[M:MTMK]BOMNUM-num$([M:MTMK]BOMALT)
   Call ECR_TRACE(WMESSAGE,1) From GESECRAN
   GOK=0
   LCOMMIT=1
   Goto FIN_VALID
Endif

If [M:MTMK]MVTDES=""
    [M:MTMK]MVTDES     =  mess(145,190,1)
Endif

#
Read [F:ITM]ITM0 = [M:MTMK]ITMREF
If fstat : Raz [F:ITM] : Endif

# Cf 83567
For I=1 To GNBDIE
    J=find([F:CAL]DIE(I-1),GDIE(1..GNBDIE))
    If J
        Assign "[M:MTMK]CCE"+num$(J) With [F:CAL]CCE(I-1)
    Endif
Next

# Cf 83567
For I=1 To GNBDIE
    If evalue("[M:MTMK]CCE"+num$(I))=""
        Raz LSEC
        Call INIT_CCE(LSEC,I,"MKMB","",0) From TRTX3CPT
        Assign "[M:MTMK]CCE"+num$(I) With LSEC
    Endif
Next I
#

Gosub CONTROLE_IMP
If !OK
    Call ECR_TRACE(WMESSAGE,1) From GESECRAN
    GOK = 0
    LCOMMIT=1
Else  # Cf 57648 : En cas d'erreur on continue pour fermer la transaction mais on ne crée pas la ligne de suivi
    [M:MTMK]STU = [F:ITM]STU

    # Cf 78118
    Raz WMESSAGE
    Gosub CRE_SUIVI
    If GOK < 1
        If WMESSAGE<>""
            Call ECR_TRACE(WMESSAGE,1) From GESECRAN
        Endif
         WMESSAGE = mess(254,193,1)
         Call ECR_TRACE(WMESSAGE,1) From GESECRAN
         WMESSAGE = mess(255,193,1)
         Call ECR_TRACE(WMESSAGE,1) From GESECRAN
         Gosub COP_SVG
    Endif
Endif

$FIN_VALID

If LCOMMIT & GOK=0
    GOK=1
    Gosub FIN_DOC
    GOK=0
Else
    Gosub FIN_DOC
Endif

LCOMMIT=0
Return


$FIN_DOC
If IMPFIN | GOK<=0 | LCOMMIT
   If G_WMFGNUM <> "" : Gosub MAJ_ENTOF  : Endif
   If G_WNBMAT <> 0
      Gosub CRE_ENTETE
      If GOK < 1
         WMESSAGE = mess(254,193,1)
         Call ECR_TRACE(WMESSAGE,1) From GESECRAN
         WMESSAGE = mess(255,193,1)
         Call ECR_TRACE(WMESSAGE,1) From GESECRAN
         Gosub COP_SVG
      Endif
   Else
      If adxlog <> 0 : Rollback : Endif
   Endif
   OK  = 0
   TRA = 0
   #GOK=1
Endif
Return

######################################################
# Contrôles
$CONTROLE_IMP
Local Date    WDAT
Local Char    WFCY(GLONFCY)
Local Char    WITM(GLONITM)
Local Char    WLOC(GLONLOC)
Local Char    WLOT(GLONLOT)
Local Integer WALT, WALTTYP, WBOD_OK, I , J
Local Integer TABTBO(3)
Local Integer WCUNFLG
Local Decimal WDIS, WALLQTY, WALLQTYSHT
Local Integer WRET

Call LECSRU([M:MTMK]MFGFCY,[F:ITM]TCLCOD,6,[M:MTMK]TRSCODS,"",WRET) From STKLIB

# Cf 81181 : Déjà fait dans SAIMSK
#Call GETCPY([M:MTMK]MFGFCY,"BTS",63,GMKRTRSNUM) From TRTX3CPT    # alimentation de GSOCIETE et GTYPGEN

If [M:MTMK]TYPTRT = 14
    # Cf 87599 gestion du lock symbole sur OF
    Lock ="MFG"+[M:MTMK]MFGNUM
    If fstat
       # Ordre de fabrication : Modification en cours sur un autre poste
       WMESSAGE = mess(156,197,1)-[M:MTMK]MFGNUM-":"-mess(10,100,1) : OK=0 : Return
    Endif

    Read [F:MFM]MFM0 = [M:MTMK]MFGNUM;[M:MTMK]MFGLIN;[M:MTMK]BOMSEQ;[M:MTMK]ITMREF
    # Pouvoir importer des suivis sur matières non prévues
    If fstat
       WMESSAGE = mess(85,195,1)-[M:MTMK]MFGNUM-[M:MTMK]ITMREF
       Call ECR_TRACE(WMESSAGE,0) From GESECRAN
       [M:MTMK]TYPTRT=15
    Else
        Read [CAL] CAL0="MFM";0;[F:MFM]MFGNUM;[F:MFM]MFGLIN;[F:MFM]BOMSEQ;[F:MFM]ITMREF;1
        If !fstat
            For I=1 To max(GNBDIE,GOPTCANA)
                J=find([F:CAL]DIE(I-1),GDIE(1..GNBDIE))
                If J & evalue("[M:MTMK]CCE"+num$(J))=""
                  Assign "[M:MTMK]CCE"+num$(J) With [F:CAL]CCE(I-1)
                Endif
            Next I
        Endif
    Endif
    If [M:MTMK]MFGFCY = "" : [M:MTMK]MFGFCY = [F:MFM]MFGFCY : Endif
    Read [MFG]MFG0 = [M:MTMK]MFGNUM
    If fstat
       WMESSAGE = mess(151,193,1) - [M:MTMK]MFGNUM
       OK = 0
       Return
    Endif
    #L'OF doit être complet
    If [F:MFG]TYPMOD = 1    : WMESSAGE = mess(51,190,1)- [M:MTMK]MFGNUM : OK = 0 : Return : Endif
    #L'OF doit être ferme
    If [F:MFG]MFGSTA <> 1   : WMESSAGE = mess(19,190,1)- [M:MTMK]MFGNUM : OK = 0 : Return : Endif
    #Selon paramètre général l'OF doit être alloué complètement
    If GMTKALLMGT = 2 & !find([F:MFG]ALLSTA,3,5) & [F:MFG]MATLINNBR <> 0
         WMESSAGE = mess(18,190,1) - [M:MTMK]MFGNUM
         OK = 0
         Return
    Endif
    #Selon paramètre général, l'OF doit être édité
    If  [F:MFG]MFGTRKFLG < 3 &  GDOSFAB = 2
        WMESSAGE = mess(20,190,1) - [M:MTMK]MFGNUM
        OK = 0
        Return
    Endif

Elsif [M:MTMK]TYPTRT = 16
    #Contrôle nomenclature
    WITM=[M:MTMK]BOMNUM
    WDAT=[M:MTMK]IPTDAT
    WFCY=[M:MTMK]MFGFCY
    WALT=[M:MTMK]BOMALT
    WALTTYP=2
    #    Lecture BOM
    Read [TBO]TBO0=WALTTYP;WALT
    If fstat : WMESSAGE = mess(154,193,1) - [M:MTMK]BOMNUM+"/"+num$([M:MTMK]BOMALT): OK = 0 : Return : Endif
    Read [BOH]BOH0=WITM;WALT;WALTTYP
    If fstat
        WMESSAGE = mess(95,193,1) - [M:MTMK]BOMNUM+"/"+num$([M:MTMK]BOMALT)
        OK = 0
        Return
    Endif
    Call CONTMFGNOM(WFCY,WALT,WDAT,1) From MFGLIB
    If WALT=0 : OK = 0 : Return : Endif
    Raz WBOD_OK
    Read [F:BOD]BOD0 = WITM;WALT;[M:MTMK]BOMSEQ;[M:MTMK]ITMREF;WALTTYP
    If fstat
       #Lecture invalide, traversée éventulelle des fantômes
       For [BOD]BOD0 Where ITMREF = WITM & BOMALT = WALT & BOMALTTYP = WALTTYP
           Read [F:ITM]ITM0 = [F:BOD]CPNITMREF
           If [F:ITM]PHAFLG = 2
              Read [F:BOD1]BOD0 = [F:ITM]ITMREF;WALT;[M:MTMK]BOMSEQ;[M:MTMK]ITMREF;WALTTYP
              If ! fstat : WBOD_OK = 1 : Break : Endif
           Endif
       Next
    Else
       If !find([F:BOD]CPNTYP,5,6) :  WBOD_OK = 1 : Endif
    Endif
  # pouvoir importer des suivis sur matières non prévues
    If !WBOD_OK : [M:MTMK]TYPTRT = 17 :  Endif
Endif
# controle site
Call LECTURE("FCY",[M:MTMK]MFGFCY,"") From CONTOBJ
If fstat | [F:FCY]MFGFLG <> 2
    WMESSAGE = mess(1,193,1)  - [M:MTMK]MFGFCY
    OK = 0
    Return
Endif
If [M:MTMK]MFGFCY <> GFCY
    GFCY = [M:MTMK]MFGFCY
    Gosub CHARG_PARAM
    OK = 0
    Return
Endif
#Controle de la date
GMESSAGE = ""
Call STKCTRIPT([M:MTMK]IPTDAT, [M:MTMK]MFGFCY, "1") From STKLIB
If GMESSAGE <> "": WMESSAGE = GMESSAGE : GMESSAGE="" : OK = 0 : Return : Endif
# controle article
If [F:ITM]ITMREF <> [M:MTMK]ITMREF
   Read [ITM]ITM0 = [M:MTMK]ITMREF
   If fstat
      WMESSAGE = mess(134,100,1) - [M:MTMK]ITMREF
      OK = 0
      Return
   Endif
Endif
# controle article-site
If [F:ITF]ITMREF <> [M:MTMK]ITMREF | [F:ITF]STOFCY <> [M:MTMK]MFGFCY
    Read [ITF]ITF0 = [M:MTMK]ITMREF;[M:MTMK]MFGFCY
    If fstat
        WMESSAGE = mess(2,196,1)+" : "+[M:MTMK]ITMREF - [M:MTMK]MFGFCY
        OK = 0
        Return
    Endif
Endif
#Contrôle inventaire
If [F:ITF]CUNFLG = 2
    Raz WCUNFLG
    If [M:MTMK]TYPTRT = 4 & [F:MFM]ALLSTA > 3
        Gosub REC_LOC From SUBMTKB
    Else
        # sr 06.02 Si emplacement importé on doit controler sur celui ci
        If [M:MTMK]LOCPREF <> ""
            Filter [F:STO] Where STOFCY = [F:ITF]STOFCY & ITMREF = [F:ITF]ITMREF &
&                                LOC = [M:MTMK]LOCPREF & CUNLOKFLG = 1
&                      Order By Key STO3

        Else
            Filter [F:STO] Where STOFCY = [F:ITF]STOFCY & ITMREF = [F:ITF]ITMREF & CUNLOKFLG = 1
&                      Order By Key STO3
        Endif
        Read [F:STO]STO3 First
        If fstat WCUNFLG = 2 : Endif
        Filter [F:STO]
    Endif
    If WCUNFLG = 2 : WMESSAGE = mess(185,199,1)+" : " +[M:MTMK]ITMREF-[M:MTMK]MFGFCY
       OK = 0
       Return
    Endif
Endif

Return

######################################################
$CRE_SUIVI
Local Integer STAT, WOK
If G_LIN = 0
   G_DATE = [M:MTMK]IPTDAT
   G_FCY = [M:MTMK]MFGFCY
   If find([M:MTMK]TYPTRT,14,15) : G_MFGNUM  = [M:MTMK]MFGNUM
                                  G_WMFGNUM = [M:MTMK]MFGNUM : Endif
   Gosub DECL_SVG
   GOK = 1
   Call DEBTRANS From GLOCK
   Trbegin [MKM]
   Call NUMERO(GCODNUM,[M:MTMK]MFGFCY,G_DATE,"",G_MFGTRKNUM,STAT) From SUBANM
   If STAT
     WMESSAGE = mess(60,199,1)-GCODNUM-num$([L]STAT)
     GOK = 0
     Gosub TR_ROLL
     Return
   Endif
Else
   If [M:MTMK]IPTDAT <> G_DATE | [M:MTMK]MFGFCY <> GFCY
      If G_WMFGNUM <> ""
         Gosub MAJ_ENTOF
         Raz   G_WMFGNUM
      Endif
      Gosub CRE_ENTETE
      If GOK < 1 : Return : Endif
      GOK = 1
      Call DEBTRANS From GLOCK
      Trbegin [MKM]
      G_DATE = [M:MTMK]IPTDAT
      G_FCY = [M:MTMK]MFGFCY
      If find([M:MTMK]TYPTRT,14,15) : G_MFGNUM  = [M:MTMK]MFGNUM
                                     G_WMFGNUM = [M:MTMK]MFGNUM : Endif
      Call NUMERO(GCODNUM,[M:MTMK]MFGFCY,G_DATE,"",G_MFGTRKNUM,STAT) From SUBANM
      If STAT
         WMESSAGE = mess(60,199,1)-GCODNUM-num$([L]STAT)
         GOK = 0
         Gosub TR_ROLL
         Return
      Endif
   Else
      If [M:MTMK]MFGNUM <> G_WMFGNUM
         Raz G_MFGNUM
      Endif
      If [M:MTMK]MFGNUM <> G_WMFGNUM & G_WMFGNUM <> ""
         Gosub MAJ_ENTOF
         Raz G_WMFGNUM
         If find([M:MTMK]TYPTRT,4,12,14) : G_WMFGNUM = [M:MTMK]MFGNUM : Endif
      Endif
   Endif
Endif
[M:MTMK]MATTRKLIN    = G_LIN + 1
[M:MTMK]MFGTRKNUM    = G_MFGTRKNUM
[M:MTMK]FICFLG       = 0
[M:MTMK]WLINUM    = 1
[M:MTMK]WMATCLENBR    = G_WMATCLENBR

Call CRE_MKM("",0) From MTKAUTLIB
If GOK < 1 : Gosub TR_ROLL : Return
Else Gosub TRACE_SVG
Endif
G_LIN                = [M:MTMK]MATTRKLIN
G_WMATCLENBR         = [M:MTMK]WMATCLENBR
G_WNBMAT             = [M:MTMK]WNBMAT                # 08.06 demande 37221
#
Return

$TR_ROLL
#Rollback
#Raz G_MFGNUM, G_WMFGNUM, G_MFGTRKNUM, G_WNBMAT, G_LIN
Return

#######################################
$MAJ_ENTOF
#Maj entête d'OF
Readlock [F:MFG]MFG0 = G_WMFGNUM
If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-G_WMFGNUM : Return
Elsif fstat GOK=0  : Call RSTA("MFG",G_WMFGNUM) From GLOCK
      Return
Endif
If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
&  [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
&  [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
   [F:MFG]MFGTRKFLG = 5
Else
   [F:MFG]MFGTRKFLG = 4
Endif

# Cf 44021
If [F:MFG]TRKLAST<G_DATE
   [F:MFG]TRKLAST   = G_DATE
Endif
If [F:MFG]TRKLASTC<date$
   [F:MFG]TRKLASTC  = date$
Endif
If [F:MFG]TRKFIRST>G_DATE | [F:MFG]TRKFIRST = "00/00/00"
    [F:MFG]TRKFIRST = G_DATE
Endif
If [F:MFG]TRKFIRSTC>date$ | [F:MFG]TRKFIRSTC = "00/00/00"
    [F:MFG]TRKFIRSTC = date$
Endif
[F:MFG]UPDDAT    = date$
[F:MFG]UPDUSR    = GUSER
Rewrite [F:MFG]
If fstat
   GOK = 0 : Call FSTA("MFG") From GLOCK : Return
Endif
#----- MISE à jour statistiques entête d'OF -----#
Call VALSTA("MFG",1) From SUBPS2
If GOK < 1 : Return : Endif
Raz G_WMATCLENBR
Return

#######################################
$CRE_ENTETE
If GOK = 1
    Raz [F:MTK]
    If G_MFGNUM <> ""
       Read [F:MFG] = G_MFGNUM
       If !fstat : [F:MTK] = [F:MFG] : Endif
    Endif
    [F:MTK]MFGFCY    = G_FCY      # Issue 90461 GA 07/201 avant GFCY
    [F:MTK]TRSCODS   = [M:MTMK]TRSCODS
    [F:MTK]MFGTRKNUM = G_MFGTRKNUM
    [F:MTK]MFGTRKDAT = G_DATE
    [F:MTK]OPETRKFLG = 1
    [F:MTK]ITMTRKFLG = 1
    [F:MTK]MATTRKFLG = 2
    [F:MTK]NBRMAT    = G_WNBMAT
    [F:MTK]CREDAT    = date$
    [F:MTK]CREUSR    = GUSER
    [F:MTK]EXPNUM    = [C]EXPORT
    Raz [F:MTK]UPDUSR
    Raz [F:MTK]UPDDAT
    Write [F:MTK]
    If fstat : GOK = 0 : Call FSTA("MTK") From GLOCK : Endif
Endif
If GOK < 1 : Rollback
    # Enregistrement dans SAS si nécessaire
    If WMKMFLG & [L]AOWSTA=2
        DEBENR_TMP = DEBENR
        WDEBENR_TMP = WDEBENR
        DEBENR = DEBENR_SVG
        WADXSEK = adxseek("IMP")
        OLDIRS = adxirs
        OLDIFS = adxifs
        OLDIUM = adxium
        adxirs = IMPIRS
        adxifs = IMPIFS
        adxium = IMPIUM
        GOK=1
        GNUMAOW=NBENR_SVG+1
        For I=1 To NBENR-NBENR_SVG-2
            Gosub IMPORT_SAS From =NOMTRT
            GNUMAOW+=1

            Seek First + DEBENR Using [IMP]
            Call RD_SEQ(VALIMP,BLBIMP,CLBIMP,IMPFIC,SEPNUMS,IMPFINS,WDEBENR) From SUBIMPOBJ
            DEBENR=adxseek("IMP")
        Next
        IMPSTA=0
        NUMFLD=0
        LIG=0
        Raz [F:AOV], [F:AOW]
        DEBENR = DEBENR_TMP
        WDEBENR = WDEBENR_TMP
        Seek First + WADXSEK Using [IMP]
        GOK=0
        adxirs = OLDIRS
        adxifs = OLDIFS
        adxium = OLDIUM
    Endif
Else       : Commit
             Gosub CLEAR_SVG
             DEBENR_SVG=DEBENR
             WMSGSUI = mess(79,190,1)-[F:MTK]MFGTRKNUM
             TRA = 1
             Call ECR_TRACE(WMSGSUI,0) From GESECRAN
             Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

NBENR_SVG = G_WNBMAT

Raz G_MFGNUM, G_WMFGNUM, G_MFGTRKNUM, G_WNBMAT, G_LIN
Return


#####################################################
# Déclaration du fichier sauvegarde
$DECL_SVG
MKMSVG = filpath("tmp",tolower(GFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"mkmsvg")
adxifs = ";"
adxirs = chr$(10)
Gosub CLEAR_SVG
Return

#####################################################
# sauvegarde de l'enregistrement en cours de traitement
$TRACE_SVG
Local Char    OLDIRS(5), OLDIFS(5)
Local Integer OLDIUM, FINENR, NBCAR , NBCAR2
OLDIRS = adxirs
OLDIFS = adxifs
OLDIUM = adxium
adxirs = IMPIRS
adxifs = IMPIFS
adxium = IMPIUM
FINENR = adxseek("IMP")
NBCAR  = WDEBENR-DEBENR
Seek First + DEBENR Using [IMP]
Openo MKMSVG , -1 Using [SVG]
While NBCAR>0
 NBCAR2 = min(NBCAR,32000)
 Local Schar CAR(1)(1..NBCAR2)
 Getseq NBCAR2 , CAR Using [IMP]
 Putseq NBCAR2 , CAR Using [SVG]
 NBCAR -= NBCAR2
Wend
Openo Using [SVG]
Seek First + FINENR Using [IMP]
adxirs = OLDIRS
adxifs = OLDIFS
adxium = OLDIUM
Return

#####################################################
# Copie du fichier des sauvegardes dans le fichier erreur du superviseur
$COP_SVG
Local Char    OLDIRS(5), OLDIFS(5)
Local Integer OLDIUM, FINENR, NBCAR , NBCAR2
OLDIRS = adxirs
OLDIFS = adxifs
OLDIUM = adxium
adxirs = IMPIRS
adxifs = IMPIFS
adxium = IMPIUM
Openi MKMSVG Using [SVG]
Seek Last Using [SVG]
NBCAR  = adxseek("SVG")
Seek First Using [SVG]
Openo FICERR , -1 Using [ERR]
While NBCAR>0
 NBCAR2 = min(NBCAR,32000)
 Local Schar CAR(1)(1..NBCAR2)
 Getseq NBCAR2 , CAR Using [SVG]
 Putseq NBCAR2 , CAR Using [ERR]
 NBCAR -= NBCAR2
Wend
Openo Using [ERR]
Openi Using [SVG]
Gosub CLEAR_SVG
adxirs = OLDIRS
adxifs = OLDIFS
adxium = OLDIUM
Return

#####################################################
# réinitialisation du fichier des sauvegardes
$CLEAR_SVG
Openo MKMSVG , 0 Using [SVG]
Openo MKMSVG Using [SVG]
Return

