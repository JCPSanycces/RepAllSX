#<AdxTL>@(#)10.0.0.0 $Revision$
#########################################################################
# Fonction Historique PEC        GPAO          LLC - JUI   1999         #
# modélisation MM - OCT 2003                                            #
#                                                                       #
# Paramètres                                                            #
# LFCY  = Site de stockage                                              #
# LITM  = Article                                                       #
# LTYP  = Type pièce                                                    #
# LVCR  = Pièce                                                         #    
# LLIN  = Ligne                                                         #
# LSEQ  = Séquence                                                      #  
#                                                                       #
# ACTION  :                                                             #
#    SAIMCOV : action de saisie fenêtre                                 #
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################


$ACTION
#---Actions liées à la saisie fenêtre
Case ACTION
   When "OUVRE"      : Gosub OUVRE
   When "DEBUT"      : Gosub DEBUT
   When "SETBOUT"    : Gosub SETBOUT
   When "BOUTON"     : Gosub BOUTON
   When "EDI"        : Gosub EDIT
   When Default
Endcase


Return
####################################################################### 
$OUVRE
Local Char     WFCY    :    WFCY = PARAM(1)
Local Char     WITM    :    WITM = PARAM(2)
Local Integer  WTYP    :    WTYP = val(PARAM(3))
Local Char     WVCR    :    WVCR = PARAM(4)
Local Integer  WLIN    :    WLIN = val(PARAM(5))
Local Integer  WSEQ    :    WSEQ = val(PARAM(6))
Local Integer  WSTA    :    WSTA = val(PARAM(7))

Local Integer L,I,J 
Local Integer  WVCRTYP

If clalev ([F:ORC])  <= 0 : Local File ORDCOV     [ORC]   : Endif 
If clalev ([F:ORC1]) <= 0 : Local File ORDCOV     [ORC1]  : Endif 
If clalev ([F:FCY])  <= 0 : Local File FACILITY   [FCY]   : Endif
If clalev ([F:ITM])  <= 0 : Local File ITMMASTER  [ITM]   : Endif
If clalev ([F:ITF])  <= 0 : Local File ITMFACILIT [ITF]   : Endif 

GFCY   = GFCYDEF(7)               # mm 12.02  
Gosub CHARG_PARAM

Return

######################################################################## 
$DEBUT
Raz [M:COV1]

If WFCY<>""
    [M:COV1]STOFCY = WFCY
Else
    [M:COV1]STOFCY = GFCYDEF(7)        
Endif

If WITM <> ""
    [M:COV1]ITMREF    = WITM
    If [F:ITM]ITMREF <> [M:COV1]ITMREF
        Read [ITM]ITM0=[M:COV1]ITMREF
    Endif
    If [F:ITF]ITMREF <> [M:COV1]ITMREF
        Read [ITF]ITF0=[M:COV1]ITMREF;[M:COV1]STOFCY
    Endif
    Gosub AFF_DES
Endif

If WTYP <> 0  
    Case WTYP
        When 14:    [M:COV1]VCRTYP = 1
        When 10:    [M:COV1]VCRTYP = 2
        When  2:    [M:COV1]VCRTYP = 3
        When  7:    [M:COV1]VCRTYP = 4
    Endcase
Endif
If WVCR <> "" : [M:COV1]VCRNUM = WVCR : Endif
If WLIN <> 0  : [M:COV1]VCRLIN = WLIN : Endif
If WSEQ <> 0  : [M:COV1]VCRSEQ = WSEQ : Endif
If WSTA <> 0  : [M:COV1]VCRSTA = WSTA : [M:COV1]XVCRSTA = mess([M:COV1]VCRSTA, 317, 1) : Endif
Affzo [M:COV1]5-10

If WFCY <> "" & WITM <> "" & WVCR <> ""
  Gosub CHARGE_COV1
Endif

Return

###########################################################################
$SETBOUT
CHBOU += "I"   # impression
ETABOU(GSPE1) = 1  # recherche
Return

###########################################################################
$BOUTON 
Case BOUT 
       When "1" : Gosub CHARGE_COV1         # recherche
Endcase
Return


###########################################################################
$CHARGE_COV1

Effzo [M:COV1]15-20
Case [M:COV1]VCRTYP
    When 1:     WVCRTYP = 14
    When 2:     WVCRTYP = 10
    When 3:     WVCRTYP = 2
    When 4,5:   WVCRTYP = 7
Endcase

Case WVCRTYP
    When 10,14:
        Filter [ORC] Where VCRTYPDST = WVCRTYP & 
&                          VCRNUMDST = [M:COV1]VCRNUM &
&                          VCRLINDST = [M:COV1]VCRLIN &
&                          VCRSEQDST = [M:COV1]VCRSEQ &
&                          WIPSTADST = [M:COV1]VCRSTA
        I = 0
        For [ORC]
            [M:COV1]WIPSTA1(I) = [F:ORC]WIPSTA
            [M:COV1]WIPTYP1(I) = [F:ORC]WIPTYP
            [M:COV1]WIPTYPSTA1(I) = mess([F:ORC]WIPTYP,341,1)+mess([F:ORC]WIPSTA,342,1)
            [M:COV1]VCRNUM1(I) = [F:ORC]VCRNUM
            [M:COV1]VCRLIN1(I) = [F:ORC]VCRLIN
            [M:COV1]VCRSEQ1(I) = [F:ORC]VCRSEQ
            [M:COV1]STRDAT1(I) = [F:ORC]STRDAT
            [M:COV1]ENDDAT1(I) = [F:ORC]ENDDAT
            [M:COV1]EXTQTY1(I) = [F:ORC]EXTQTY
            [M:COV1]COVQTY1(I) = [F:ORC]COVQTY
            [M:COV1]ORIFCY1(I) = [F:ORC]ORIFCY
            [M:COV1]PJT1(I)    = [F:ORC]PJT   
            [M:COV1]BPRNUM1(I) = [F:ORC]BPRNUM
            [M:COV1]PIO1(I)    = [F:ORC]PIO    
            [M:COV1]FMI1(I)    = [F:ORC]FMI    
            [M:COV1]VCRTYPORI1(I) = [F:ORC]VCRTYPORI
            [M:COV1]VCRNUMORI1(I) = [F:ORC]VCRNUMORI
            [M:COV1]VCRLINORI1(I) = [F:ORC]VCRLINORI
            [M:COV1]VCRSEQORI1(I) = [F:ORC]VCRSEQORI
            I += 1
        Next
        Filter [ORC]
        [M:COV1]NBLIG1 = I 
        Filter [ORC] Where VCRTYP = WVCRTYP & 
&                          VCRNUM = [M:COV1]VCRNUM &
&                          VCRLIN = [M:COV1]VCRLIN &
&                          VCRSEQ = [M:COV1]VCRSEQ &
&                          WIPSTA = [M:COV1]VCRSTA        
        L = 0
        # llc 05.02 14394 Performances
        For [ORC]ORC1                                    
            If [M:COV1]NBLIG1 <> 0
                If find([F:ORC]VCRNUMDST,[M:COV1]VCRNUM1(0..[M:COV1]NBLIG1-1)) : Goto NXT1 : Endif
            Endif
            [M:COV1]WIPSTA2(L) = [F:ORC]WIPSTADST
            [M:COV1]WIPTYP2(L) = [F:ORC]WIPTYPDST
            [M:COV1]WIPTYPSTA2(L) = mess([F:ORC]WIPTYPDST,341,1)+mess([F:ORC]WIPSTADST,342,1)
            [M:COV1]VCRNUM2(L) = [F:ORC]VCRNUMDST
            [M:COV1]VCRLIN2(L)  = [F:ORC]VCRLINDST
            [M:COV1]VCRSEQ2(L)  = [F:ORC]VCRSEQDST
            [M:COV1]COVQTY2(L) = [F:ORC]COVQTY
            L += 1
        $NXT1
        Next
        Filter [ORC]
        [M:COV1]NBLIG2 = L 
    When Default:
        Filter [ORC] Where VCRTYP = WVCRTYP & 
&                          VCRNUM = [M:COV1]VCRNUM &
&                          VCRLIN = [M:COV1]VCRLIN &
&                          VCRSEQ = [M:COV1]VCRSEQ &
&                          WIPSTA = [M:COV1]VCRSTA
        L = 0
        # llc 05.02 14394 Performances
        For [ORC]ORC1                                    
            [M:COV1]WIPSTA2(L) = [F:ORC]WIPSTADST
            [M:COV1]WIPTYP2(L) = [F:ORC]WIPTYPDST
            [M:COV1]WIPTYPSTA2(L) = mess([F:ORC]WIPTYPDST,341,1)+mess([F:ORC]WIPSTADST,342,1)
            [M:COV1]VCRNUM2(L) = [F:ORC]VCRNUMDST
            [M:COV1]VCRLIN2(L) = [F:ORC]VCRLINDST
            [M:COV1]VCRSEQ2(L) = [F:ORC]VCRSEQDST
            [M:COV1]COVQTY2(L) = [F:ORC]COVQTY
            J  = L
            L += 1
            Filter [ORC1] Where VCRTYP = [F:ORC]VCRTYPDST & 
&                               VCRNUM = [F:ORC]VCRNUMDST &
&                               VCRLIN = [F:ORC]VCRLINDST &
&                               VCRSEQ = [F:ORC]VCRSEQDST &
&                               WIPSTA = [F:ORC]WIPSTADST
            # llc 05.02 14394 Performances
            For [ORC1]ORC1                                
                [M:COV1]WIPSTA2(L) = [F:ORC1]WIPSTADST
                [M:COV1]WIPTYP2(L) = [F:ORC1]WIPTYPDST
                [M:COV1]WIPTYPSTA2(L) = mess([F:ORC1]WIPTYPDST,341,1)+
&                                       mess([F:ORC1]WIPSTADST,342,1)
                [M:COV1]VCRNUM2(L)  = [F:ORC1]VCRNUMDST
                [M:COV1]VCRLIN2(L)  = [F:ORC1]VCRLINDST
                [M:COV1]VCRSEQ2(L)  = [F:ORC1]VCRSEQDST
                [M:COV1]COVQTY2(L)  = [F:ORC1]COVQTY
                [M:COV1]COVQTY2(J) -= [F:ORC1]COVQTY
                L += 1
            Next
            Filter [ORC1]            
        Next
        Filter [ORC]
        [M:COV1]NBLIG2 = L        
        J = find(0, [M:COV1]COVQTY2(0..[M:COV1]NBLIG2-1))       
        While J <> 0
            I = J-1
            Dela I,1 [M:COV1]NBLIG2   
            [M:COV1]NBLIG2 -= 1
            J = find(0, [M:COV1]COVQTY2(0..[M:COV1]NBLIG2-1))
        Wend
Endcase
Affzo [M:COV1]
Return

###########################################################################
$AFF_DES
[M:COV1]STU     = [F:ITM]STU
Affzo [M:COV1]5-10
Return

######################################################################## 
$EDIT
If WFCY <> "" & WITM <> "" & WVCR <> "" 
    Call PRTSCR("COVER1","COV1",mess(109,195,1),0,0) From ATRTX3
Endif
Return
######################################################################## 
$CHARG_PARAM 
#----- Variables globales stock 
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return 
##########################################################################
## Etiquette ajoutée par le superviseur 18-10-2003 10:13:41 (MB)
##########################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()

If VALEUR <> GFCY                   # mm 12.02
    GFCY=VALEUR                     # mm 12.02
    Gosub CHARG_PARAM
Endif                               # mm 12.02
End

Subprog IB_ITMREF
GBOUT1 = mess(4,198,1)
End

Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
    If fstat : mkstat = 2 : End : Endif
Endif
If [F:ITF]ITMREF <> VALEUR
    Read [ITF]ITF0=VALEUR;[M:COV1]STOFCY
    If fstat : mkstat = 2 : End : Endif
Endif
[M:COV1]ITMREF = VALEUR
Gosub AFF_DES
End

Subprog B1_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Char    WFILA(255)   

GFLTITM=VALEUR   
 
#   on applique un petit filtre de base sur le site et éventuellement le planificateur 
#   on peut faire plus mais est-ce vraiment nécessaire ? 
#   filtre site 
WFILA = '(STOFCY=[M:COV1]STOFCY)' 
Local File ITMFACILIT [ITF] Where evalue(WFILA) 
Call OBJET("ITF",[M:COV1]STOFCY,VALEUR) From GOBJET  
GFLTITM="" 
End

Subprog AV_NBLIG1
If [M:COV1]NBLIG1 <> 0 : pcolor = GCOUL(3) : Endif
End

Subprog AV_NBLIG2
If [M:COV1]NBLIG2 <> 0 : pcolor = GCOUL(3) : Endif
End


##########################################################################

##########################################################################
## Etiquette ajoutée par le superviseur 20/10/2003 14:21:06 (MM)
##########################################################################
Subprog S_VCRNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer WTYP
Local    Char    WVCR
Local    Integer WLIN
Local    Integer WSEQ
Local    Integer WSTA
Local    Char    WITM

WITM = [M:COV1]ITMREF
Case [M:COV1]VCRTYP
    When 1:     WTYP = 14
    When 2:     WTYP = 10
    When 3:     WTYP = 2
    When 4,5:   WTYP = 7
Endcase
Call SELCOV(WTYP, [M:COV1]STOFCY, WITM, WVCR, WLIN, WSEQ,WSTA) From MFGLIB
If WVCR <> ""
        VALEUR = WVCR
        [M:COV1]VCRLIN = WLIN
        [M:COV1]VCRSEQ = WSEQ
        [M:COV1]VCRSTA = WSTA
        [M:COV1]XVCRSTA = mess([M:COV1]VCRSTA, 317, 1)
        Affzo [M:COV1]10
        End
Endif
mkstat = 1

End


##########################################################################

