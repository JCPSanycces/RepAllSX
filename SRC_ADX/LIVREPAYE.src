#<AdxTL>@(#)10.0.0.0 $Revision$
Call IMPRIME("LIVREPAYE","") From ETAT
End

$ACTION
 Case ACTION
  When "CONT1"    : Gosub CONT1
  When "FINAIMP1" : Gosub FINAIMP1
 Endcase
Return

# To manage filter by legsilation on selections
$CONT1
Case toupper([M]PARCOD(nolign-1))
 When "SOCIETE" :
  If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
  Call LECTURE("CPY",VALEUR,"") From CONTOBJ
  Gosub SAVE_GCURLEG From TOOLSHRLEG : GCURLEG=[F:CPY]LEG
  Gosub SAVE_GLEGFIL From TOOLSHRLEG : GLEGFIL=[F:CPY]LEG
Endcase
Return

$FINAIMP1
 Gosub RESTAURE_GCURLEG From TOOLSHRLEG
 Gosub RESTAURE_GLEGFIL From TOOLSHRLEG
Return

####################################################
## Etat livrepaye
####################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

If clalev([F:HSP])=0 : Local File HISTOPAYE [HSP] : Endif
If clalev([F:VEP])=0 : Local File VALEMP    [VEP] : Endif
If clalev([F:VLA])=0 : Local File VALEUR    [VLA] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP  [FGR] : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
If clalev([F:RUB])=0 : Local File RUBRIQUE  [RUB] : Endif
If clalev([F:LPA])=0 : Local File LIVREPAYE [LPA] : Endif
If clalev([F:TMP])=0 : Local File TMPLIVRE  [TMP] : Endif
If clalev([F:ATB])=0 : Local File ATABLE    [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE     [ATY] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE    [ATX] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA   [AXX] : Endif
If clalev([F:DIC])=0 : Local File DICOEMP   [DIC] : Endif
If clalev([F:HRPOA])=0 : Local File POPULA    [HRPOA] : Endif
If clalev([F:ACC])=0 : Local File ACCES     [ACC] : Endif
If clalev([F:CUM])=0 : Local File CUMUL     [CUM] : Endif
If clalev([F:ECT])=0 : Local File EMPCTR    [ECT] : Endif

Gosub OUVRE From WPDEFTABLE

Local Char    SOCIETE(GLONCPY) , SITEDEB(GLONFCY) , SITEFIN(GLONFCY) , MATDEB(GLONEML) , MATFIN(GLONEML)
Local Date    DATEDEB , DATEFIN
Local Char    PARAM(20) , PROFIL(GLONPRF) , SERVICE(GLONSRV) , LIVRE(GLONLPA)
Local Char    CRIT1(250), CRIT2(250)
Local Integer DETPAY
Local Integer I , J , K , NBMOIS , GRP , NUMREQ , LIGTMP , NCOL , OK

Local Decimal MONTP(1..200)
Local Integer DECP(1..200)

###
Local Char    CHAMP(20) , OBJ(3)
Local Integer TABDIV(1..10) , NOLIB(1..10)
Local Char    FICHIER(10)(1..10) , OBJET(3)(1..10) , CHLIB(20)(1..10) , LIBEL(30)(1..10)
Local Char    CRIT(20)(1..10) , LIB(30)(1..10)
Local Char    MATRI(GLONEML) , POPULATION(GLONPOP), CTR(GLONHRCTR)
Local Date    DATMAT

Local Integer NFRM , NRUB , NCUM , NVAR , NPAT , IFRM
Local Char    FORMULE(250)(1..dim([F:LPA]RUBCOD))
Local Char    EXPR(250) , OPE(2) , CODE(20) , REMPL(30)
Local Char    CRUB(GLONRUB)(1..200) , CPAT(GLONRUB)(1..200)
Local Char    CCUM(GLONCUM)(1..200) , CVAR(GLONVRA)(1..200)
Local Decimal RU(1..200) , PA(1..200) , CU(1..200) , VA(1..200)
Local Decimal CL(1..dim([F:LPA]RUBCOD))
Local Integer WER(1..dim([F:LPA]RUBCOD))
Local Char    RUBRIQUE(50)
Local Char    TABLE(GLONATB)
Local Integer TYPMONT , BASE
Local Integer LIGNUL , ZERO

NCOL = 6
If GNBLEG = 1
 GCURLEG = GDOSLEG
Else
 Call GETPARAM("leg",NBPAR,PARAMETRE,GCURLEG)
Endif
Call GETPARAM("livre",NBPAR,PARAMETRE,LIVRE)
Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE)
Call GETPARAM("sitedeb",NBPAR,PARAMETRE,SITEDEB)
Call GETPARAM("sitefin",NBPAR,PARAMETRE,SITEFIN)
Call GETPARAM("population",NBPAR,PARAMETRE,POPULATION)
Call GETPARAM("matdeb",NBPAR,PARAMETRE,MATDEB)
Call GETPARAM("matfin",NBPAR,PARAMETRE,MATFIN)
Call GETPARAM("datedeb",NBPAR,PARAMETRE,PARAM) : DATEDEB = PARAM
Call GETPARAM("datefin",NBPAR,PARAMETRE,PARAM) : DATEFIN = PARAM
Call GETPARAM("profil",NBPAR,PARAMETRE,PROFIL)
Call GETPARAM("service",NBPAR,PARAMETRE,SERVICE)
Call GETPARAM("detpay",NBPAR,PARAMETRE,PARAM)  : DETPAY = val(PARAM)
Call GETPARAM("lignul",NBPAR,PARAMETRE,PARAM)  : LIGNUL = val(PARAM)
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) : [L]NUMREQ = val(PARAM)

PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

Read [LPA]LPA0 = GCURLEG;LIVRE
If fstat
 Call ERREUR(mess(66,10702,1)) From GESECRAN : # Code livre de paye non défini
 GOK = 0 : End
Endif
Read [CPY]CPY0 = SOCIETE
If fstat
 Call ERREUR(mess(65,10702,1)) From GESECRAN : # Société inexistante
 GOK = 0 : End
Elsif [CPY]LEG<>GCURLEG
 Call ERREUR("Société d'autre legislation") From GESECRAN
 GOK = 0 : End
Endif

GERR = 0
Gosub DECODE_FORMULE
If GERR
 Call ERREUR(GMESSAGE) From GESECRAN
 GOK = 0 : End
Endif

Call TEMPON("O") From GESECRAN

For I=1 To [F:LPA]NBRSRT
 CHAMP = [F:LPA]CRI(I-1)
 K = instr(1,CHAMP,"]")
 If K : CHAMP = right$(CHAMP,K+1) : Endif
 Read [DIC]DIC0 = CHAMP
 If !fstat
  Read [ATZ]CODZONE = [F:DIC]TBL;CHAMP
  If !fstat
   Call TEXTE([F:ATZ]NOLONG,LIBEL(I)) From OBJDIV
   If [F:ATZ]CODTYP="ADI"
    TABDIV(I) = val([F:ATZ]EXPLIEN)
   Else
    If [F:ATZ]NOLIB<>0
     NOLIB(I) = [F:ATZ]NOLIB
    Endif
    Read [ATY]CODTYP = [F:ATZ]CODTYP
    If !fstat
     If [F:ATY]FICLIEN<>""
      OBJ = [F:ATY]OBJLIEN
      Read [ATB]CODFIC = [F:ATY]FICLIEN
      If [F:ATB]INTIT<>""
       CHP = [F:ATB]INTIT
      Elsif [F:ATB]INTITC<>""
       CHP = [F:ATB]INTIT
      Endif
      If CHP<>""
       Read [ATZ]CODZONE = [F:ATY]FICLIEN;CHP
       If !fstat
        Read [F:ATY]CODTYP = [F:ATZ]CODTYP
        If !fstat
         If [F:ATY]TYPTYP=7
          OBJET(I)   = OBJ
          FICHIER(I) = [F:ATB]CODFIC
          CHLIB(I)   = "[F:"+[F:ATB]ABRFIC+"]"+CHP
         Endif
        Endif
       Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Next I

PARAM = num$([F:LPA]NBRSRT)
Call SETPARAM("nbtri",NBPAR,PARAMETRE,PARAM) From ETAT
Call SETPARAM("X3TIT",NBPAR,PARAMETRE,[F:LPA]DES) From ETAT
Call SETPARAM("nomsoc",NBPAR,PARAMETRE,[F:CPY]CPYNAM) From ETAT

For I=1 To [F:LPA]NBRSRT
 If FICHIER(I)<>""
  Read [ATB]CODFIC = FICHIER(I)
  If evalue("clalev([F:"+[F:ATB]ABRFIC+"])")=0
   Local File =FICHIER(I)
  Endif
 Endif
 Call SETPARAM("libel"+num$(I),NBPAR,PARAMETRE,LIBEL(I)) From ETAT
 PARAM = num$(([F:LPA]TOT(I-1)=2))
 Call SETPARAM("stot"+num$(I),NBPAR,PARAMETRE,PARAM) From ETAT
 PARAM = num$(([F:LPA]PAG(I-1)=2))
 Call SETPARAM("pag"+num$(I),NBPAR,PARAMETRE,PARAM) From ETAT
Next I

For I=1 To dim([F:LPA]DESCOL)
 Call SETPARAM("tit"+num$(I),NBPAR,PARAMETRE,[F:LPA]DESCOL(I-1)) From ETAT
Next I

CRIT1 = '1=1' :#Salarié
If MATDEB<>""
 CRIT1 -= '& [F:ID]REFNUM>="'+MATDEB+'"'
Endif
If MATFIN<>""
 CRIT1 -= '& [F:ID]REFNUM<="'+MATFIN+'"'
Endif
CRIT2 = '1=1'
If SITEDEB<>""
 CRIT2 -= '& [F:VEP]FCY>="'+SITEDEB+'"'
Endif
If SITEFIN<>""
 CRIT2 -= '& [F:VEP]FCY<="'+SITEFIN+'"'
Endif
If PROFIL<>""
 CRIT2 -= '& [F:VEP]PRF="'+PROFIL+'"'
Endif
If SERVICE<>""
 CRIT2 -= '& [F:VEP]SRV="'+SERVICE+'"'
Endif

If POPULATION<>""
 Link [ECT] With
&    [ID]ID0=[F:ECT]REFNUM
& ,  [HRPOA]POA0=POPULATION;[F:ID]REFNUM
& As [LID]
& Where evalue(CRIT1) & [F:HRPOA]REFNUM<>""
& Order By Key CLE=[F:ID]REFNUM;[F:ECT]CTRNUM
Else
 Link [ECT] With
&    [ID]ID0=[F:ECT]REFNUM
& As [LID]
& Where evalue(CRIT1)
& Order By Key CLE=[F:ID]REFNUM;[F:ECT]CTRNUM
Endif

#FQ69466 - MABON 30/11/2010
SVFONCTION = GFONCTION
Call GETPARAM("X3FCT",NBPAR,PARAMETRE,GFONCTION)
Call AUTORIS From EXEFNC

Call DEBTRANS From GLOCK
Gosub TR1
Call TEMPOFF From GESECRAN
#FQ69466 - SEGAY 09/12/13
GFONCTION = SVFONCTION
Call AUTORIS From EXEFNC
End

$TR1
Raz WER
GOK = 1
LIGTMP = 0
Trbegin [TMP]
 For TABLE = "EMPLOCPT","EMPLOAD","EMPLOCUM","EMPLOID","EMPLOCTR","EMPLOEXM","EMPLOCHD","EMPLOMED","EMPLOTRY","EMPLORIB","EMPLOSAL"
  Gosub DEFAUT From WPDEFTABLE
 Next
 Delete [TMP] Where USR=GUSER & CREDAT<date$
 If fstat=1
  GOK = -1 : GLOCK = "TMPLIVRE"-GUSER : Goto ROLL_TR1
 Endif
 For [LID]CLE : # Salarié+Contrat
  MATRI  = [F:ECT]REFNUM
  CTR    = [F:ECT]CTRNUM
  For [VEP]VEP0 Where EMP=MATRI & PYRDAT>=DATEDEB & PYRDAT<=DATEFIN & evalue(CRIT2)& CTRNUM=CTR
   DATMAT = [F:VEP]ENDDAT
   Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATMAT
   Read [HRCTR]CTR0 Last
   Filter [HRCTR]
   If !fstat
    Call CONTROLE(MATRI,DATMAT,CTR,"",OK,0) From DIVPAYE
   Else
    OK = 0
   Endif
   Read [FGR]FGR0=SOCIETE;[F:VEP]FCY
   If !fstat & OK
    Gosub LECEMP From WPDEFTABLE
    Raz CRIT,LIB
    For I=1 To [F:LPA]NBRSRT
     CRIT(I) = num$(evalue([F:LPA]CRI(I-1)))
     If NOLIB(I)
      CRIT(I) = mess(val(CRIT(I)),NOLIB(I),1)
     Endif
     If CRIT(I)<>""
      If TABDIV(I)<>0
       Read [ADI]CODE = TABDIV(I);CRIT(I)
       Read[F:AXX]AXX0="ATABDIV";"LNGDES";GLANGUE;num$(TABDIV(I));CRIT(I)
       LIB(I) = [F:AXX]TEXTE
      Elsif OBJET(I)<>""
       Call LECTURE(OBJET(I),CRIT(I),"") From CONTOBJ
       LIB(I) = evalue(CHLIB(I))
      Endif
     Endif
    Next I
    Raz MONTP,RU,PA,VA,CU
    ###56118
    Raz DECP
    ZERO = 1
    For K=1 To NRUB
     RUBRIQUE = CRUB(K)
     TYPMONT  = 1
     BASE     = 0
     Gosub RUBRIQUE
     RU(K) = RESULT
    Next K
    For K=1 To NPAT
     RUBRIQUE = CPAT(K)
     TYPMONT  = 2
     BASE     = 0
     Gosub RUBRIQUE
     PA(K) = RESULT
    Next K
    For K=1 To NCUM
     RUBRIQUE = CCUM(K)
     TYPMONT  = 6
     BASE     = 0
     Gosub RUBRIQUE
     CU(K) = RESULT
    Next K
    For K=1 To NVAR
     RUBRIQUE = CVAR(K)
     Gosub VARIA
     VA(K) = RESULT
    Next K
    IFRM = 0
    For K=1 To [F:LPA]NBRCOL
     Case [F:LPA]TYPAMT(K-1)
      When 1,2,3,4,5,6
       RUBRIQUE = [F:LPA]RUBCOD(K-1)
       TYPMONT  = [F:LPA]TYPAMT(K-1)
       BASE     = ([F:LPA]BASE(K-1)=2)
       Gosub RUBRIQUE
      When 7
       RUBRIQUE = [F:LPA]RUBCOD(K-1)
       Gosub VARIA
      #60971
      When 8
       Gosub AUCUN
      When 9
       IFRM += 1
       Onerrgo ERRFRM
       RESULT = evalue(FORMULE(IFRM))
       Onerrgo
      #Taxe Band
      When 13,14,15,16,17,18
       RUBRIQUE = [F:LPA]RUBCOD(K-1)
       TYPMONT  = [F:LPA]TYPAMT(K-1)-3
       BASE     = ([F:LPA]BASE(K-1)=2)
       Gosub RUBRIQUE
     Endcase
     MONTP(K) = RESULT
     #57869
     If !DECP(K) : DECP(K)=2 : Endif
     If MONTP(K)<>0
      ZERO = 0
     Endif
    Next K

    If LIGNUL or !ZERO
     For GRP=1 To int(([F:LPA]NBRCOL-1)/NCOL)+1
      If sigma(NCOL*(GRP-1)+1,NCOL*GRP,abs(MONTP(indcum)))<>0
       Raz [F:TMP]
       If DETPAY
        For I=1 To NCOL
         J = NCOL*(GRP-1)+I
         If J<=[F:LPA]NBRCOL
          [F:TMP]AMT(I-1) = MONTP(J)
          [F:TMP]DEC(I-1) = DECP(J)
         Endif
        Next I
        LIGTMP += 1
        [F:TMP]LIG = LIGTMP
        [F:TMP]USR = GUSER
        [F:TMP]RQT = [L]NUMREQ
        [F:TMP]GRP = GRP
        [F:TMP]EMP = [F:VEP]EMP
        [F:TMP]DAT = [F:VEP]PYRDAT
        [F:TMP]CTR = [F:VEP]CTRNUM
        [F:TMP]CREDAT = date$
        For I=1 To [F:LPA]NBRSRT
         [F:TMP]TRI(I-1) = CRIT(I)
         [F:TMP]LIB(I-1) = LIB(I)
        Next I
        Write [TMP]
        If fstat
         GOK = 0 : Call FSTA("TMP") From GLOCK : Break 2
        Endif
       Else
        Filter [TMP] Where USR=GUSER & RQT=[L]NUMREQ & GRP=[L]GRP & EMP=[F:ID]REFNUM & CTR=[F:ECT]CTRNUM
&       & DAT=date$ & CREDAT=date$ & TRI(0)=CRIT(1) & TRI(1)=CRIT(2) & TRI(2)=CRIT(3)
&       & TRI(3)=CRIT(4) & TRI(4)=CRIT(5) & TRI(5)=CRIT(6) & TRI(6)=CRIT(7)
&       & TRI(7)=CRIT(8) & TRI(8)=CRIT(9) & TRI(9)=CRIT(10)
        Readlock [TMP]TMP0 First
        Filter [TMP]
        If fstat=1
         GOK = -1 : GLOCK = "$TMPLIVRE" : Break 2
        Elsif fstat=0
         For I=1 To NCOL
          J = NCOL*(GRP-1)+I
          If J<=[F:LPA]NBRCOL
           [F:TMP]AMT(I-1) += MONTP(J)
          Endif
         Next I
         Rewrite [TMP]
        Elsif fstat>1
         [F:TMP]USR = GUSER
         [F:TMP]RQT = [L]NUMREQ
         [F:TMP]GRP = GRP
         [F:TMP]EMP = [F:ID]REFNUM
         [F:TMP]CTR = [F:ECT]CTRNUM
         [F:TMP]DAT = date$
         [F:TMP]CREDAT = date$
         For I=1 To [F:LPA]NBRSRT
          [F:TMP]TRI(I-1) = CRIT(I)
          [F:TMP]LIB(I-1) = LIB(I)
         Next I
         For I=1 To NCOL
          J = NCOL*(GRP-1)+I
          If J<=[F:LPA]NBRCOL
          [F:TMP]AMT(I-1) = MONTP(J)
          [F:TMP]DEC(I-1) = DECP(J)
          Endif
         Next I
         LIGTMP += 1
         [F:TMP]LIG = LIGTMP
         Write [TMP]
        Endif
        If fstat
         GOK = 0 : Call FSTA("TMP") From GLOCK : Break 2
        Endif
       Endif : # DETPAY
      Endif
     Next GRP
    Endif : # lignul

   Endif : # !fstat & OK
  Next : # VEP
 Next : # ID
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$ERRFRM
If WER(IFRM)=0
 WER(IFRM) = 1
 Call ECR_TRACE([F:LPA]RUBCOD(K-1)+"\"+errmes$(errn)+"\"+errm,1) From GESECRAN
Endif
RESULT = 0
Resume

$RUBRIQUE
RESULT = 0
###56118 : calcul du nb de décimales à l'afficher à l'édition
Call LECTURE("RUB",RUBRIQUE,GCURLEG) From CONTOBJ
If [F:RUB]DEC
 DECP(K)=len(num$([F:RUB]DEC))-len(num$(fix([F:RUB]DEC)))-1 :#-1 pour le séparateur ,
Endif
###
###57869 : pour les arrondis défini par une valeur entière
If DECP(K)<0 : DECP(K)=0 : Endif
###

Read [HSP]HSP3 = [F:VEP]BUL;RUBRIQUE;TYPMONT
If !fstat
 If BASE
  RESULT = [F:HSP]BAS
 Else
  If TYPMONT<>6
   RESULT = [F:HSP]AMT
  Else
   #\38252
   If [F:HSP]AMT<>[F:HSP]BAS
    RESULT = [F:HSP]AMT-[F:HSP]BAS
   Else
    Read [CUM]CUM0=GCURLEG;[L]RUBRIQUE
    If !fstat & [F:CUM]PERCUM<>1
&    & mid$(func AFNC.PARAM("PERCUM"+num$([F:CUM]CUMPER),[F:VEP]FCY),month([F:VEP]ENDDAT),1)="O"
     RESULT=[F:HSP]AMT
    Else
     RESULT=0
    Endif
   Endif
   #/38252
  Endif
 Endif
Endif
#Gestion des réguls
If TYPMONT<3
 Read [HSP]HSP3 = [F:VEP]BUL;RUBRIQUE;(TYPMONT+6)
 If !fstat
  If BASE
   RESULT += [F:HSP]BAS
  Else
   RESULT += [F:HSP]AMT
  Endif
 Endif
Endif
Return

$VARIA
RESULT = 0
Read [VLA]VLA0 = 4;"";"";"";[F:VEP]EMP;[F:VEP]PYRDAT;RUBRIQUE;[F:VEP]BUL
If !fstat
 RESULT = [F:VLA]VARVAL
Endif
Return

#60971
$AUCUN
RESULT = 0
Return

###############################################################################
Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End

###############################################################################
## Décodage des formules
###############################################################################
$DECODE_FORMULE
Raz NFRM,NRUB,NCUM,NVAR,NPAT
For K=1 To [F:LPA]NBRCOL
 If [F:LPA]TYPAMT(K-1)=9
  EXPR = vireblc(format$("KT:250X",[F:LPA]RUBCOD(K-1)),2)
  I = 1
  While I<=len(EXPR)
   OPE = mid$(EXPR,I,2)
   If find(OPE,"R_","V_","C_","F0")
    J = I+2 : I += 2
    While I<len(EXPR) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(EXPR,I+1,1))
     I += 1
    Wend
    CODE = seg$(EXPR,J,I)
    If OPE="R_"
     If mid$(EXPR,I+1,3)="(1)"
      I += 3
     Elsif mid$(EXPR,I+1,3)="(2)"
      OPE = "P_" : I += 3
     Endif
    Endif
    Case OPE
     When "R_"
      L = find(CODE,CRUB(1..NRUB))
      If L=0
       NRUB += 1
       CRUB(NRUB) = CODE
       L = NRUB
      Endif
      REMPL = "RU("+num$(L)+")"
     When "P_"
      L = find(CODE,CPAT(1..NPAT))
      If L=0
       NPAT += 1
       CPAT(NPAT) = CODE
       L = NPAT
      Endif
      REMPL = "PA("+num$(L)+")"
     When "C_"
      L = find(CODE,CCUM(1..NCUM))
      If L=0
       NCUM += 1
       CCUM(NCUM) = CODE
       L = NCUM
      Endif
      REMPL = "CU("+num$(L)+")"
     When "V_"
      L = find(CODE,CVAR(1..NVAR))
      If L=0
       NVAR += 1
       CVAR(NVAR) = CODE
       L = NVAR
      Endif
      REMPL = "VA("+num$(L)+")"
     When "F0"
      REMPL = "MONTP("+CODE+")"
    Endcase
    If (J-3)+len(REMPL)+len(right$(EXPR,I+1))>250
     GERR = 1
     GMESSAGE =  mess(109,10702,1)-":"-[F:LPA]RUBCOD(K-1) : # L'évaluation de la formule dépasse les 250 caractères
     Break
    Endif
    EXPR = left$(EXPR,J-3)+REMPL+right$(EXPR,I+1)
    I = (J-3)+len(REMPL)
   Endif
   I += 1
  Wend
  NFRM += 1
  FORMULE(NFRM) = EXPR
 Endif
Next K
Return
