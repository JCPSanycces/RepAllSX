#<AdxTL>@(#)%I%
# Supervisor
# Inquiry LTA

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "08:11:09"
A_USER  = "ADMIN"
A_STAMP = "20181109081109"
Return

$DEFAUT
Return

$OUVFIC
Return

$NOMFIC
Local Char    TIT(GLONDES) , TITT(GLONDES)
Local Char    PROGSTD(GLONADC) , PROGSPE(GLONADC)
Local Char    ABMSK(GLONABR)(16) , NOMMSK(GLONAMK)(16) , CABMSK(GLONABR) , CNOMMSK(GLONAMK)
Local Char    BOITE(GLONFEN) , CBOITE(GLONFEN)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , OBJDERLU(GLONAOB)
Local Char    CODMSKDEF(GLONAMK) , CMEMO(GLONAMM)
Local Libelle MAGNETO
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA)
Call TEXTE(1002236,TITT) From OBJDIV
TIT        = mess(15,126,1)
If dim(CNSCOD)>0 : TIT -= CNSCOD : Endif
PROGSTD    = "SUBHRLTA"
PROGSPE    = "SPECNSLTA"
BOITE      = "CONSLTA"
NOMMSK(0)  = "CONSLTA1"
ABMSK(0)   = "HRLTA1"
NOMMSK(1)  = "CONSLTA2"
ABMSK(1)   = "HRLTA2"
NOMMSK(2)  = "CONSLTA3"
ABMSK(2)   = "HRLTA3"
NOMMSK(3)  = "CONSLTA4"
ABMSK(3)   = "HRLTA4"
MAGNETO    = 1
Return

$SETCLE
Local Char    CLE(10), CLECMP(10)(0..0), CLEMSK(10)(0..0)
Local Integer NBCMP
Local Char    FILTRE(250)
CLE = ""
NBCMP = 0
CLECMP = "" : CLEMSK = ""
Return

$OUVRE
Return

$OUVRE_MSK
Case MA
 When  0 : Local Mask =NOMMSK(0) [HRLTA1]
 When  1 : Local Mask =NOMMSK(1) [HRLTA2]
 When  2 : Local Mask =NOMMSK(2) [HRLTA3]
 When  3 : Local Mask =NOMMSK(3) [HRLTA4]
Endcase
Return

$GRISE_MSK
Case MA
 When  0 : Grizo [HRLTA1]
 When  1 : Grizo [HRLTA2]
 When  2 : Grizo [HRLTA3]
 When  3 : Grizo [HRLTA4]
Endcase
Return

$GRISE_CLE
Return

$GRISE_CRIT
Return

$FERME_MSK
Case MA
 When  0 : If clalev([M:HRLTA1])>0 : Close Local Mask [HRLTA1] : Endif
 When  1 : If clalev([M:HRLTA2])>0 : Close Local Mask [HRLTA2] : Endif
 When  2 : If clalev([M:HRLTA3])>0 : Close Local Mask [HRLTA3] : Endif
 When  3 : If clalev([M:HRLTA4])>0 : Close Local Mask [HRLTA4] : Endif
Endcase
Return

$SETMASK
Case MA
 When  0 : Default Mask [HRLTA1]
 When  1 : Default Mask [HRLTA2]
 When  2 : Default Mask [HRLTA3]
 When  3 : Default Mask [HRLTA4]
Endcase
Return

$RAZMASK
Case MA
 When  0 : Raz [M:HRLTA1]
 When  1 : Raz [M:HRLTA2]
 When  2 : Raz [M:HRLTA3]
 When  3 : Raz [M:HRLTA4]
Endcase
Return

$CRITENT
Return

$ENTCRIT
Return

$CRITAFF
Local Integer NBCA
Local Char    CRITAFF(10)(1..1) , CRITAFF2(10)(1..1)
NBCA = 0
Return

$STYLEPLAG
Return

Subprog GETACT(NOL,TITBOUT,VALBOUT)
Value Integer NOL
Variable Char TITBOUT()(1..) , VALBOUT()(1..)
Local Integer ONOL , NBBOUT
ONOL   = nolign
nolign = NOL
indice = max(0,nolign-1)
Call AS_NBLIG From ="W1CONSLTA2"
NBBOUT = 0
nolign = ONOL
indice = max(0,nolign-1)
End

Subprog ACTRUN(INFO)
Value Char INFO
Local Char    BOUT(3)
Local Integer ONOL
ONOL    = nolign
BOUT    = func AFNC.PART(INFO,1)
nolign  = val(func AFNC.PART(INFO,2))
indice  = max(0,nolign-1)
Gosub NOMFIC
For MA=0 to dim(NOMMSK)-1
 Gosub OUVRE_MSK
Next MA
For MA=0 to dim(NOMMSK)-1
 Gosub SETMASK
Next MA
Case BOUT
Endcase
nolign = ONOL
indice = max(0,nolign-1)
End

$RIEN
Resume


