#<AdxTL>@(#)3.0.0.0 $Revision$ Sélection d'une échéance
Local File GACCDUDATE [DUD]
Call SELDUD("PAR","")
Infbox num$([F:DUD]ACCNUM)-num$([F:DUD]DUDLIG)
End

########################################
## Version modélisée de la bête
########################################
$SEL_DUD
If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif
Link [DUD] With [HAE]HAE0 = [F:DUD]TYP;[F:DUD]NUM As [LNK]

NBCOL = 0  : TIT(0) = mess(9,117,1) : # Choix échéance
#NBCOL += 1 : COL(NBCOL) = "[F:DUD]TYP"      : TIT(NBCOL) = mess(59,100,1)
NBCOL += 1 : COL(NBCOL) = "[F:DUD]NUM"      : TIT(NBCOL) = mess(11,105,1)
NBCOL += 1 : COL(NBCOL) = "[F:HAE]ACCDAT"   : TIT(NBCOL) = mess(14,105,1)
NBCOL += 1 : COL(NBCOL) = "[F:DUD]BPR"      : TIT(NBCOL) = mess(31,105,1)
NBCOL += 1 : COL(NBCOL) = "[F:HAE]BPRVCR"   : TIT(NBCOL) = mess(53,117,1)
NBCOL += 1 : COL(NBCOL) = "[F:DUD]DUDDAT"   : TIT(NBCOL) = mess(3,629,1)
NBCOL += 1 : COL(NBCOL) = "[F:DUD]CUR"      : TIT(NBCOL) = mess(18,105,1)
NBCOL += 1 : COL(NBCOL) = "[F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR" : TIT(NBCOL) = mess(1,106,1)
 COLTYP(NBCOL) = 7
NBCOL += 1 : COL(NBCOL) = "[F:DUD]AMTCUR"   : TIT(NBCOL) = mess(32,105,1)
NBCOL + =1 : COL(NBCOL) = "[F:DUD]DEP"      : TIT(NBCOL) = mess(119,121,1)
NBCOL += 1 : COL(NBCOL) = "[F:DUD]PAM"      : TIT(NBCOL) = mess(29,121,1)
NBCOL += 1 : COL(NBCOL) = "[F:DUD]BPRPAY"   : TIT(NBCOL) = mess(1,672,1)
NBCOL += 1 : COL(NBCOL) = "[F:DUD]FCY"      : TIT(NBCOL) = mess(12,105,1)
NBCOL += 1 : COL(NBCOL) = "[F:DUD]SAC"      : TIT(NBCOL) = mess(27,102,1)
NBCOL += 1 : COL(NBCOL) = "[F:DUD]ACCNUM"   : TIT(NBCOL) = mess(5,159,1)
NBCOL += 1 : COL(NBCOL) = "[F:DUD]DUDLIG"   : TIT(NBCOL) = mess(17,109,1)

#ORDRE = "[F:DUD]AMTCUR"
# Adaptation V140 (CP : 21/07/03) : Il faut une clé unique
ORDRE = "[F:DUD]AMTCUR;[F:DUD]TYP;[F:DUD]NUM;[F:DUD]LIG;[F:DUD]DUDLIG"
START = "[F:DUD]NUM"
Default File [LNK]
DEFPAG = 1

GPOINT = "DEFZONE" : Gosub ENTREE From EXEFNC

# Vérif au cas où le point d'entrée fait n'importe quoi
If !find("[F:DUD]ACCNUM",COL(1..NBCOL))
 NBCOL += 1 : COL(NBCOL) = "[F:DUD]ACCNUM"   : TIT(NBCOL) = mess(5,159,1)
Endif
If !find("[F:DUD]DUDLIG",COL(1..NBCOL))
 NBCOL += 1 : COL(NBCOL) = "[F:DUD]DUDLIG"   : TIT(NBCOL) = mess(17,109,1)
Endif
If NBCOL<10
 For K=NBCOL+1 To 10
  COL(K) = "[F:DUD]DUDLIG" : TIT(K) = ""
 Next K
 NBCOL = 10
Endif
# Adaptation V140 (CP : 21/07/03) : Il faut une clé unique
If ORDRE=""
 # ORDRE = "[F:DUD]DUDDAT"
 # Adaptation V140 (CP : 21/07/03) : Il faut une clé unique
 ORDRE = "[F:DUD]DUDDAT;[F:DUD]TYP;[F:DUD]NUM;[F:DUD]LIG;[F:DUD]DUDLIG"
Endif

# Critères obligatoires
Raz CRITERE
ICRITERE = 0

# depuis la V6, l'instruction num$ est supportée dans les "Link"
If GFONCTION<>"CONSFAC" : Call ADDCRIT(CRITERE,ICRITERE,"FLGREP ",'num$([F:HAE]FLGREP)<>"2"',"&")  From GOBJSUB : Endif

# Critères facultatif
If TIERS<>""
 Call ADDCRIT(CRITERE,ICRITERE,"BPRPAY ",'[F:DUD]BPRPAY="'+TIERS+'"',"&") From GOBJSUB
Endif
If SITE<>""
 Call ADDCRIT(CRITERE,ICRITERE,"FCY ",'[F:DUD]FCY="'+SITE+'"',"&") From GOBJSUB
Endif

Return

########################################
## Ancienne version
########################################
Subprog SELDUD(SITE,TIERS)
Value Char    SITE()
Value Char    TIERS()

If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif

Link [DUD] With [HAE]HAE0 = [F:DUD]TYP;[F:DUD]NUM As [LNK]

Local Integer I , J , K , ICRI , RAPIDE
Local Char    VALCHP(30)
Local Decimal VALNUM , PCENT
Local Date    VALDAT
Local Integer NBZ , TYP(1..20) , CRI(1..20)
Local Char    ZONE(50)(1..20) , TIT(30)(1..20) , FMT(15)(1..20) , ZTRI(20)(1..20)
Local Char    CRITERE(250)(1..3) , CRITRI(80)
Local Char    SAVCRIT(250)(1..3)
Local Integer HAUT , LARGE
Local Char    ZZ(50)(1..50)
Local Integer ANNEE , JOUR , MOIS
Local Char    TITBOI(50)

SAVMXL = adxmxl
adxmxl = GNBSEL
HAUT   = 80
LARGE  = 300
TITBOI = mess(9,117,1) : # Choix échéances
Call PARAM("","PRCTOL",VALCHP) From ADOVAL
PCENT = val(VALCHP)
If PCENT<=0 | PCENT>100 : PCENT=10 : Endif

NBZ = 0
NBZ += 1 : ZONE(NBZ) = "[F:DUD]TYP"      : TYP(NBZ) = 1 : FMT(NBZ) = "K:3X"      : TIT(NBZ) = mess(59,100,1)
NBZ += 1 : ZONE(NBZ) = "[F:DUD]NUM"      : TYP(NBZ) = 1 : FMT(NBZ) = "K:15X"     : TIT(NBZ) = mess(11,105,1)
NBZ += 1 : ZONE(NBZ) = "[F:DUD]BPR"      : TYP(NBZ) = 1 : FMT(NBZ) = "K:10X"     : TIT(NBZ) = mess(31,105,1)
NBZ += 1 : ZONE(NBZ) = "[F:DUD]BPRPAY"   : TYP(NBZ) = 1 : FMT(NBZ) = "K:10X"     : TIT(NBZ) = mess(1,672,1)
NBZ += 1 : ZONE(NBZ) = "[F:DUD]DUDDAT"   : TYP(NBZ) = 3 : FMT(NBZ) = "D:"+GFMDAT : TIT(NBZ) = mess(3,629,1)
NBZ += 1 : ZONE(NBZ) = "[F:DUD]CUR"      : TYP(NBZ) = 1 : FMT(NBZ) = "K:3X"      : TIT(NBZ) = mess(18,105,1)
NBZ += 1 : ZONE(NBZ) = "[F:DUD]AMTCUR"   : TYP(NBZ) = 2 : FMT(NBZ) = "N3:13.2"   : TIT(NBZ) = mess(32,105,1)
NBZ += 1 : ZONE(NBZ) = "[F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR" : ZTRI(NBZ) = "[F:DUD]AMTCUR"
 TYP(NBZ) = 2 : FMT(NBZ) = "N3:13.2" : TIT(NBZ) = mess(1,106,1)
NBZ += 1 : ZONE(NBZ) = "[F:DUD]PAM"      : TYP(NBZ) = 1 : FMT(NBZ) = "K:3X"      : TIT(NBZ) = mess(29,121,1)
NBZ += 1 : ZONE(NBZ) = "[F:DUD]FCY"      : TYP(NBZ) = 1 : FMT(NBZ) = "K:3X"      : TIT(NBZ) = mess(12,105,1)
NBZ += 1 : ZONE(NBZ) = "[F:DUD]SAC"      : TYP(NBZ) = 1 : FMT(NBZ) = "K:4X"      : TIT(NBZ) = mess(27,102,1)
NBZ += 1 : ZONE(NBZ) = "[F:HAE]BPRVCR"   : TYP(NBZ) = 1 : FMT(NBZ) = "K:15X"     : TIT(NBZ) = mess(53,117,1)
NBZ += 1 : ZONE(NBZ) = "[F:DUD]ACCNUM"   : TYP(NBZ) = 0 : FMT(NBZ) = "N:8#"      : TIT(NBZ) = mess(5,159,1)
NBZ += 1 : ZONE(NBZ) = "[F:DUD]DUDLIG"   : TYP(NBZ) = 0 : FMT(NBZ) = "N:3#"      : TIT(NBZ) = mess(17,109,1)

# Peut être un petit point d'entrée serait le bienvenu ??

Raz CRITERE, CRI
ICRI   = 1

GPOINT = "DEFZONE" : Gosub ENTREE From EXEFNC

# Vérif au cas où le point d'entrée fait n'importe quoi
If !find("[F:DUD]ACCNUM",ZONE(1..NBZ))
 NBZ += 1 : ZONE(NBZ) = "[F:DUD]ACCNUM"   : TYP(NBZ) = 0 : FMT(NBZ) = "N:8#"      : TIT(NBZ) = mess(5,159,1)
Endif
If !find("[F:DUD]DUDLIG",ZONE(1..NBZ))
 NBZ += 1 : ZONE(NBZ) = "[F:DUD]DUDLIG"   : TYP(NBZ) = 0 : FMT(NBZ) = "N:3#"      : TIT(NBZ) = mess(17,109,1)
Endif
If NBZ<10
 For K=NBZ+1 To 10
  ZONE(K) = "[F:DUD]DUDLIG" : TYP(K) = 0 : FMT(K) = "N:#" : TIT(K) = ""
 Next K
 NBZ = 10
Endif
RAPIDE = 0

$CHOOS

# Critères obligatoires
## Petite ruse pour ne pas transmettre à Oracle la condition sur une table
## liée avec une jointure gauche (facultative)
Call ADDCRIT(CRITERE,ICRI,'num$([F:HAE]FLGREP)<>"2"')

# Critères facultatif
K = find("[F:DUD]BPRPAY",ZONE(1..NBZ))
If (K=0 or CRI(K)=0) & TIERS<>""
 Call ADDCRIT(CRITERE,ICRI,'[F:DUD]BPRPAY="'+TIERS+'"')
Endif
K = find("[F:DUD]FCY",ZONE(1..NBZ))
If (K=0 or CRI(K)=0) & SITE<>""
 Call ADDCRIT(CRITERE,ICRI,'[F:DUD]FCY="'+SITE+'"')
Endif

For K=1 To dim(CRITERE)
 If CRITERE(K)="" : CRITERE(K) = "1=1" : Endif
Next K

# Ordre de tri
K = find(1,CRI(1..NBZ))
If K
 If ZTRI(K)<>""
  CRITRI = ZTRI(K)
 Else
  CRITRI = ZONE(K)
 Endif
Else
 CRITRI = "[F:DUD]DUDDAT"
Endif

Raz [F:DUD]

Gosub CHOO

Case status
 When 0
  Call MESSAGE(mess(99,100,1)) From GESECRAN
  If RAPIDE
   For K=1 To dim(CRITERE)
    CRITERE(K) = SAVCRIT(K)
   Next K
   RAPIDE = 0
   Raz CRI
   Goto CHOOS
  Else
   Raz [F:DUD] : mkstat=2 : Goto FIN_SEL
  Endif
 When 7
  Raz [F:DUD] : mkstat=2 : Goto FIN_SEL
 When GSTASRA
  Gosub CRIT_CHOOS : Goto CHOOS
 When Default
  I = find("[F:DUD]ACCNUM",ZONE(1..NBZ))
  J = find("[F:DUD]DUDLIG",ZONE(1..NBZ))
  If I & J
   [F:DUD]ACCNUM = val(ZZ(I))
   [F:DUD]DUDLIG = val(ZZ(J))
   Read [DUD]DUD1 =
  Else
   Raz [F:DUD]
   mkstat = 2
  Endif
  Goto FIN_SEL
Endcase

$FIN_SEL
adxmxl = SAVMXL
End

$CRIT_CHOOS
RAPIDE = 1
For K=1 To dim(CRITERE)
 SAVCRIT(K) = CRITERE(K)
Next K
Raz CRITERE, CRI
ICRI = 1
For I=1 To NBZ
 Case TYP(I)
  When 1 : # alpha
   VALCHP = ZZ(I)
   Repeat
    K = instr(1,VALCHP,'"')
    If K : VALCHP = left$(VALCHP,K-1)+right$(VALCHP,K+1) : Endif
   Until K=0
   If VALCHP<>""
    If instr(1,VALCHP,"*") or instr(1,VALCHP,"?")
     Call ADDCRIT(CRITERE,ICRI,'pat('+ZONE(I)+',"'+VALCHP+'")')
    Else
     Call ADDCRIT(CRITERE,ICRI,ZONE(I)+'>="'+VALCHP+'"')
    Endif
    CRI(I) = 1
   Endif
  When 2 : # Num
   VALNUM = val(ZZ(I))
   If VALNUM<>0
    Call ADDCRIT(CRITERE,ICRI,ZONE(I)+'>='+num$(min(VALNUM*(1-PCENT/100),VALNUM*(1+PCENT/100)))
&                        -'&'-ZONE(I)+'<='+num$(max(VALNUM*(1-PCENT/100),VALNUM*(1+PCENT/100))))
    CRI(I) = 1
   Endif
  When 3 : # Date
   ANNEE = 0 : JOUR = 0 : MOIS = 0
   If ZZ(I)<>""
    Case left$(GFMDAT,2)
     When "DD" : JOUR  = val(left$(ZZ(I),2))
     When "MM" : MOIS  = val(left$(ZZ(I),2))
     When "YY" : ANNEE = val(left$(ZZ(I),2))
    Endcase
    Case mid$(GFMDAT,6,2)
     When "DD" : JOUR  = val(mid$(ZZ(I),3,2))
     When "MM" : MOIS  = val(mid$(ZZ(I),3,2))
     When "YY" : ANNEE = val(mid$(ZZ(I),3,2))
    Endcase
    Case mid$(GFMDAT,11,2)
     When "DD" : JOUR  = val(mid$(ZZ(I),5,2))
     When "MM" : MOIS  = val(mid$(ZZ(I),5,2))
     When "YY" : ANNEE = val(mid$(ZZ(I),5,2))
    Endcase
    If ANNEE<mod(adxdcs,100)
     ANNEE += adxdcs+100-mod(adxdcs,100)
    Else
     ANNEE += adxdcs-mod(adxdcs,100)
    Endif
    If JOUR>0 & JOUR<32 & MOIS>0 & MOIS<13 & ANNEE>1600 & ANNEE<9999
     VALDAT = gdat$(JOUR,MOIS,ANNEE)
     Call ADDCRIT(CRITERE,ICRI,ZONE(I)+'>=['+format$(GFMD,VALDAT)+']')
     CRI(I) = 1
    Endif
   Endif
 Endcase
Next I
Return

Subprog ADDCRIT(CRITERE,ICRI,SUBCRIT)
Variable Char    CRITERE()(1..)
Variable Integer ICRI
Value    Char    SUBCRIT
If len(CRITERE(ICRI))+len(SUBCRIT)>240
 ICRI += 1
Endif
If CRITERE(ICRI)<>"" : CRITERE(ICRI) -= '&' : Endif
CRITERE(ICRI) -= SUBCRIT
End

$CHOO
Case NBZ
 When 20
  Choose [LNK] Where evalue(CRITERE(1)) & evalue(CRITERE(2)) & evalue(CRITERE(3))
&  Order By evalue(CRITRI)
&  Using
&    ZZ(01) = format$(FMT(01),evalue(ZONE(01))) Titled TIT(01)
&   ,ZZ(02) = format$(FMT(02),evalue(ZONE(02))) Titled TIT(02)
&   ,ZZ(03) = format$(FMT(03),evalue(ZONE(03))) Titled TIT(03)
&   ,ZZ(04) = format$(FMT(04),evalue(ZONE(04))) Titled TIT(04)
&   ,ZZ(05) = format$(FMT(05),evalue(ZONE(05))) Titled TIT(05)
&   ,ZZ(06) = format$(FMT(06),evalue(ZONE(06))) Titled TIT(06)
&   ,ZZ(07) = format$(FMT(07),evalue(ZONE(07))) Titled TIT(07)
&   ,ZZ(08) = format$(FMT(08),evalue(ZONE(08))) Titled TIT(08)
&   ,ZZ(09) = format$(FMT(09),evalue(ZONE(09))) Titled TIT(09)
&   ,ZZ(10) = format$(FMT(10),evalue(ZONE(10))) Titled TIT(10)
&   ,ZZ(11) = format$(FMT(11),evalue(ZONE(11))) Titled TIT(11)
&   ,ZZ(12) = format$(FMT(12),evalue(ZONE(12))) Titled TIT(12)
&   ,ZZ(13) = format$(FMT(13),evalue(ZONE(13))) Titled TIT(13)
&   ,ZZ(14) = format$(FMT(14),evalue(ZONE(14))) Titled TIT(14)
&   ,ZZ(15) = format$(FMT(15),evalue(ZONE(15))) Titled TIT(15)
&   ,ZZ(16) = format$(FMT(16),evalue(ZONE(16))) Titled TIT(16)
&   ,ZZ(17) = format$(FMT(17),evalue(ZONE(17))) Titled TIT(17)
&   ,ZZ(18) = format$(FMT(18),evalue(ZONE(18))) Titled TIT(18)
&   ,ZZ(19) = format$(FMT(19),evalue(ZONE(19))) Titled TIT(19)
&   ,ZZ(20) = format$(FMT(20),evalue(ZONE(20))) Titled TIT(20)
&  Sized(HAUT,LARGE)
&  Titled TITBOI
 When 19
  Choose [LNK] Where evalue(CRITERE(1)) & evalue(CRITERE(2)) & evalue(CRITERE(3))
&  Order By evalue(CRITRI)
&  Using
&    ZZ(01) = format$(FMT(01),evalue(ZONE(01))) Titled TIT(01)
&   ,ZZ(02) = format$(FMT(02),evalue(ZONE(02))) Titled TIT(02)
&   ,ZZ(03) = format$(FMT(03),evalue(ZONE(03))) Titled TIT(03)
&   ,ZZ(04) = format$(FMT(04),evalue(ZONE(04))) Titled TIT(04)
&   ,ZZ(05) = format$(FMT(05),evalue(ZONE(05))) Titled TIT(05)
&   ,ZZ(06) = format$(FMT(06),evalue(ZONE(06))) Titled TIT(06)
&   ,ZZ(07) = format$(FMT(07),evalue(ZONE(07))) Titled TIT(07)
&   ,ZZ(08) = format$(FMT(08),evalue(ZONE(08))) Titled TIT(08)
&   ,ZZ(09) = format$(FMT(09),evalue(ZONE(09))) Titled TIT(09)
&   ,ZZ(10) = format$(FMT(10),evalue(ZONE(10))) Titled TIT(10)
&   ,ZZ(11) = format$(FMT(11),evalue(ZONE(11))) Titled TIT(11)
&   ,ZZ(12) = format$(FMT(12),evalue(ZONE(12))) Titled TIT(12)
&   ,ZZ(13) = format$(FMT(13),evalue(ZONE(13))) Titled TIT(13)
&   ,ZZ(14) = format$(FMT(14),evalue(ZONE(14))) Titled TIT(14)
&   ,ZZ(15) = format$(FMT(15),evalue(ZONE(15))) Titled TIT(15)
&   ,ZZ(16) = format$(FMT(16),evalue(ZONE(16))) Titled TIT(16)
&   ,ZZ(17) = format$(FMT(17),evalue(ZONE(17))) Titled TIT(17)
&   ,ZZ(18) = format$(FMT(18),evalue(ZONE(18))) Titled TIT(18)
&   ,ZZ(19) = format$(FMT(19),evalue(ZONE(19))) Titled TIT(19)
&  Sized(HAUT,LARGE)
&  Titled TITBOI
 When 18
  Choose [LNK] Where evalue(CRITERE(1)) & evalue(CRITERE(2)) & evalue(CRITERE(3))
&  Order By evalue(CRITRI)
&  Using
&    ZZ(01) = format$(FMT(01),evalue(ZONE(01))) Titled TIT(01)
&   ,ZZ(02) = format$(FMT(02),evalue(ZONE(02))) Titled TIT(02)
&   ,ZZ(03) = format$(FMT(03),evalue(ZONE(03))) Titled TIT(03)
&   ,ZZ(04) = format$(FMT(04),evalue(ZONE(04))) Titled TIT(04)
&   ,ZZ(05) = format$(FMT(05),evalue(ZONE(05))) Titled TIT(05)
&   ,ZZ(06) = format$(FMT(06),evalue(ZONE(06))) Titled TIT(06)
&   ,ZZ(07) = format$(FMT(07),evalue(ZONE(07))) Titled TIT(07)
&   ,ZZ(08) = format$(FMT(08),evalue(ZONE(08))) Titled TIT(08)
&   ,ZZ(09) = format$(FMT(09),evalue(ZONE(09))) Titled TIT(09)
&   ,ZZ(10) = format$(FMT(10),evalue(ZONE(10))) Titled TIT(10)
&   ,ZZ(11) = format$(FMT(11),evalue(ZONE(11))) Titled TIT(11)
&   ,ZZ(12) = format$(FMT(12),evalue(ZONE(12))) Titled TIT(12)
&   ,ZZ(13) = format$(FMT(13),evalue(ZONE(13))) Titled TIT(13)
&   ,ZZ(14) = format$(FMT(14),evalue(ZONE(14))) Titled TIT(14)
&   ,ZZ(15) = format$(FMT(15),evalue(ZONE(15))) Titled TIT(15)
&   ,ZZ(16) = format$(FMT(16),evalue(ZONE(16))) Titled TIT(16)
&   ,ZZ(17) = format$(FMT(17),evalue(ZONE(17))) Titled TIT(17)
&   ,ZZ(18) = format$(FMT(18),evalue(ZONE(18))) Titled TIT(18)
&  Sized(HAUT,LARGE)
&  Titled TITBOI
 When 17
  Choose [LNK] Where evalue(CRITERE(1)) & evalue(CRITERE(2)) & evalue(CRITERE(3))
&  Order By evalue(CRITRI)
&  Using
&    ZZ(01) = format$(FMT(01),evalue(ZONE(01))) Titled TIT(01)
&   ,ZZ(02) = format$(FMT(02),evalue(ZONE(02))) Titled TIT(02)
&   ,ZZ(03) = format$(FMT(03),evalue(ZONE(03))) Titled TIT(03)
&   ,ZZ(04) = format$(FMT(04),evalue(ZONE(04))) Titled TIT(04)
&   ,ZZ(05) = format$(FMT(05),evalue(ZONE(05))) Titled TIT(05)
&   ,ZZ(06) = format$(FMT(06),evalue(ZONE(06))) Titled TIT(06)
&   ,ZZ(07) = format$(FMT(07),evalue(ZONE(07))) Titled TIT(07)
&   ,ZZ(08) = format$(FMT(08),evalue(ZONE(08))) Titled TIT(08)
&   ,ZZ(09) = format$(FMT(09),evalue(ZONE(09))) Titled TIT(09)
&   ,ZZ(10) = format$(FMT(10),evalue(ZONE(10))) Titled TIT(10)
&   ,ZZ(11) = format$(FMT(11),evalue(ZONE(11))) Titled TIT(11)
&   ,ZZ(12) = format$(FMT(12),evalue(ZONE(12))) Titled TIT(12)
&   ,ZZ(13) = format$(FMT(13),evalue(ZONE(13))) Titled TIT(13)
&   ,ZZ(14) = format$(FMT(14),evalue(ZONE(14))) Titled TIT(14)
&   ,ZZ(15) = format$(FMT(15),evalue(ZONE(15))) Titled TIT(15)
&   ,ZZ(16) = format$(FMT(16),evalue(ZONE(16))) Titled TIT(16)
&   ,ZZ(17) = format$(FMT(17),evalue(ZONE(17))) Titled TIT(17)
&  Sized(HAUT,LARGE)
&  Titled TITBOI
 When 16
  Choose [LNK] Where evalue(CRITERE(1)) & evalue(CRITERE(2)) & evalue(CRITERE(3))
&  Order By evalue(CRITRI)
&  Using
&    ZZ(01) = format$(FMT(01),evalue(ZONE(01))) Titled TIT(01)
&   ,ZZ(02) = format$(FMT(02),evalue(ZONE(02))) Titled TIT(02)
&   ,ZZ(03) = format$(FMT(03),evalue(ZONE(03))) Titled TIT(03)
&   ,ZZ(04) = format$(FMT(04),evalue(ZONE(04))) Titled TIT(04)
&   ,ZZ(05) = format$(FMT(05),evalue(ZONE(05))) Titled TIT(05)
&   ,ZZ(06) = format$(FMT(06),evalue(ZONE(06))) Titled TIT(06)
&   ,ZZ(07) = format$(FMT(07),evalue(ZONE(07))) Titled TIT(07)
