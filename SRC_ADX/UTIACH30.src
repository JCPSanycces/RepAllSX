#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIACH30   Création du paramètre VLTSCEOEXT                            #
##########################################################################
# DM 76982 - 2012-03-13 by CCC
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTIACH30(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIACH30(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Char WOBJET(GLONAOB)
Local Integer WNBR
Local Integer B_OK

  Call ECR_TRACE("UTIACH30: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".ADOVAL"  [ADW]
  Trbegin [ADW]
  Look [F:ADW]ADW0="";"";"VLTSCEOEXT"
  If fstat
      Raz [F:ADW]
      [F:ADW]PARAM = "VLTSCEOEXT"
      [F:ADW]CREDAT = date$
      [F:ADW]CREUSR = GUSER
      [F:ADW]VALEUR = "7"
      Write [F:ADW]
      If fstat
          Call ECR_TRACE("VLTSCEOEXT: can't create parameter",1) From GESECRAN
      Endif
  Endif
  Commit
  Close Local File [ADW]
  Call ECR_TRACE("UTIACH30 : finish",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTIACH30(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  Call MAJ_UTIACH30(APPLI)
End
