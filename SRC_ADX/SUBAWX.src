#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion objet AWX
Raz GPILOBJ , GNBMASKOUV
Call OBJET("AWX",GBIDC1,GBIDC2) From GOBJET
End
######################################################################################
$ACTION
Case ACTION
 When "LIENS"       : Gosub LIENS
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub ECRIRE
 When "MODIF"       : Gosub ECRIRE
 When "EXEBOUT"     : Gosub EXEBOUT
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_CRE"   : Call VALID([M:AWX1]CODE)
 When "APRES_MOD"   : Call VALID([M:AWX1]CODE)
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "FIN_TABLE"   : Gosub FIN_TABLE
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "VERF_LISTE"  : Gosub VERF_LISTE
 When "ANNULE"      : Gosub ANNULE
Endcase
Return

######################################################################################
#-------------------            Etiquettes                ---------------------------#
######################################################################################
$LIENS
Local Char ZONE(20)
Local Integer K
If [F:AWX]CODEVT<>""
 Case [M:AWX1]TYPEVT
  When 1
  [M:AWX1]TYPEVT2 = 2
  [M:AWX1]CODEVT(0)  = [F:AWX]CODEVT
   Read [AOB]ABREV = [M:AWX1]CODEVT(0)
   If !fstat
    Call TEXTE([F:AOB]LIBEL,[M]LIBEVT(0)) From OBJDIV
    [M]ATB = [F:AOB]NOMFIC
   Endif
  When 2
  [M:AWX1]TYPEVT2 = 3
  [M:AWX1]CODEVT(1)  = [F:AWX]CODEVT
   Read [AFC]CODINT = [M:AWX1]CODEVT(1) # Issue X3-106451 - 2018-09-06 by ALSHE : replace VALEUR by CODVET
   If !fstat : Call TEXTE([F:AFC]NOM,[M]LIBEVT(1)) From OBJDIV : [M]ATB = "AFONCTION" : Endif
  When 3
  [M:AWX1]TYPEVT2 = 4
  [M:AWX1]CODEVT(2)  = [F:AWX]CODEVT
   Read [ARP]ARP0 = [M:AWX1]CODEVT(2) # Issue X3-106451 - 2018-09-06 by ALSHE : replace VALEUR by CODVET
   If !fstat : Call TEXTE([F:ARP]RPTDES,[M]LIBEVT(2)) From OBJDIV : Endif
  When 4
  [M:AWX1]TYPEVT2 = 5
  [M:AWX1]CODEVT(3)  = [F:AWX]CODEVT
   Read [ABT]CODTAC = [M:AWX1]CODEVT(3) # Issue X3-106451 - 2018-09-06 by ALSHE : replace VALEUR by CODVET
   If !fstat : Call TEXTE([F:ABT]DES,[M]LIBEVT(3)) From OBJDIV : [M]ATB = "ABATRQT" : Endif
 Endcase
 Raz [M]HLPFOR
 Gosub CHARGE_HLP
Endif
For I=1 To 3
 If mid$([F:AWX]OPERATION,I,1) = "C"
  [M:AWX1]ACREA = 2
 Elsif mid$([F:AWX]OPERATION,I,1) = "M"
  [M:AWX1]AMODI = 2
 Elsif mid$([F:AWX]OPERATION,I,1) = "A"
  [M:AWX1]ASUPP = 2
 Endif
Next
For I=0 To 4
 K = instr(1,[F:AWX]FLD(I),"(")
 If K
  DIME = val(right$([F:AWX]FLD(I),K+1))
  ZONE =left$([F:AWX]FLD(I),K-1)
 Else
  DIME = 0
  ZONE = [F:AWX]FLD(I)
 Endif
 Read [ATZ]CODZONE = [M]ATB;ZONE
 If !fstat
  Assign("[M]CHAMP"+num$(I+1))   With [F:AWX]FLD(I)
  If DIME > 0
   Assign("[M]FLD"+num$(I+1))     With func AFNC.TEXTE([ATZ]NOCOURT) +"("+num$(DIME)+")"
  Else
   Assign("[M]FLD"+num$(I+1))     With func AFNC.TEXTE([ATZ]NOCOURT)
  Endif
  Assign("[M]ANDOR"+num$(I+1))   With [F:AWX]ANDOR(I)
  Assign("[M]OPE"+num$(I+1))     With [F:AWX]OPE(I)
  Assign("[M]VALEUR"+num$(I+1))  With [F:AWX]VALEUR(I)
  Assign("[M]VALI"+num$(I+1))    With [F:AWX]VALI(I)
  If evalue("[M]FLD"+num$(I+1)) <> "" : I=I+1: Gosub AM_FLD : I=I-1 Endif
 Endif
Next
For I=0 To 1
 Assign("[M]TYPDES"+num$(I+1)) With [F:AWX]TYPDES(I)
 Assign("[M]DESTIN"+num$(I+1)) With [F:AWX]DESTIN(I)
 Assign("[M]FNCDES"+num$(I+1)) With [F:AWX]FNCDES(I)
 Assign("[M]ENVOI"+num$(I+1))  With [F:AWX]ENVOI(I)
 Assign("[M]SUIVI"+num$(I+1))  With [F:AWX]SUIVI(I)
Next
Gosub GRISE_CONDITION
Gosub GRISE_OPERATION
Gosub GRISE_DESTINATAIRE
Gosub GRISE_CODEVT
Return

$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET : # Changement de clé
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET
Endif
Return

$ANNULE
Delete [AXX] Where CODFIC="AWRKPARX" & IDENT1=[L]CODE & ZONE="INTIT"
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK
Endif
Return

$EXEBOUT
Case REP
 When "V"
  Call VALID(CLECUR1)
Endcase
Return

$VERIF_CRE
Read [AWA]AWA0 = [M]CODE
If !fstat
 Call ERREUR([M]CODE-":"-mess(165,75,1)) From GESECRAN : # Règle workflow avancée existante
 zonsui = "CODE"
 OK = 0 : Return
Endif

$VERIF_MOD
Local Integer D , F , T , L , S ,I
Local Char    MESSA(255) , TEXCLB(200)(1..200) , FORMULE(255)
Gosub SET_SEP
If [M:AWX1]ACREA<>2 & [M:AWX1]AMODI<>2 & [M:AWX1]ASUPP<>2 & [M:AWX1]TYPEVT =1
 Call ERREUR(mess(166,75,1)) From GESECRAN : # Il faut renseigner au moins une opération
 zonsui = "ACREA"
 OK = 0 : Return
Endif
If [M:AWX1]ENVOI1 <> 2 & [M:AWX1]SUIVI1<>2
 Call ERREUR(mess(169,75,1)) From GESECRAN : # Il faut renseigner au moins un type d'envoi
 zonsui = "ENVOI1"
 OK = 0 : Return
Endif
If [M:AWX1]DESTIN2 <> "" & [M:AWX1]ENVOI2 <> 2 & [M:AWX1]SUIVI2<>2
 Call ERREUR(mess(169,75,1)) From GESECRAN : # Il faut renseigner au moins un type d'envoi
 zonsui = "ENVOI2"
 OK = 0 : Return
Endif
Setlob TEXCLB With [M]TEXTE
I = 1
Raz T , S
While TEXCLB(I)<>""
 D = instr(1,TEXCLB(I),SEP)
 If D
  TEXCLB(I) = right$(TEXCLB(I),D+1)
  FORMULE = ""
  F = instr(1,TEXCLB(I),SEP)
  While !F & I<dim(TEXCLB)
   FORMULE += TEXCLB(I)
   I += 1
   F = instr(1,TEXCLB(I),SEP)
  Wend
  If F
   FORMULE += left$(TEXCLB(I),F-1)
   TEXCLB(I) = right$(TEXCLB(I),F+1)
   If TEXCLB(I)="" : I += 1 : Endif
  Else
   Call ERREUR(mess(116,75,1)) From GESECRAN : # Séparateurs mal définis dans le texte
   zonsui = "TEXTE"
   OK = 0 : Break
  Endif
  FORMULE = format$("KTv2:255X",FORMULE)
  If toupper(FORMULE)="LIG"
   If [M]TEXLIG=""
    Call ERREUR(mess(75,75,1)) From GESECRAN : # Le texte ligne est vide
    zonsui = "TEXTE"
    OK = 0 : Break
   Else
    T = 1
   Endif
  Elsif toupper(left$(FORMULE,4))="SIG/"
   # SIG/code action/Texte à mettre devant le lien http
   K = instr(1,FORMULE,"/")
   L = instr(K+1,FORMULE,"/")
   S = 1
   MESSA = mess(164,75,1) : # Présence d'un lien http dans le message
   If !K | !L
    Call ERREUR(MESSA+"\"+mess(123,75,1)) From GESECRAN : # Lien signature mal paramétré dans le texte
    zonsui = "TEXTE"
    OK = 0 : Break
   Elsif [M]ENAMES<>2
    Call ERREUR(MESSA+"\"+mess(94,75,1)) From GESECRAN : # L'envoi de mail est désactivé
    zonsui = "ENAMES"
    OK = 0 : Break
   Elsif [M]ENASUI<>2
    Call ERREUR(MESSA+"\"+mess(95,75,1)) From GESECRAN : # Le suivi est désactivé
    zonsui = "ENASUI"
    OK = 0 : Break
   Elsif !find(toupper(seg$(FORMULE,K+1,L-1)),[M]ACTSIG)
    Call ERREUR(MESSA+"\"+toupper(seg$(FORMULE,K+1,L-1))-":"-mess(76,75,1)) From GESECRAN
    # Opération de signature inexistante
    zonsui = "TEXTE"
    OK = 0 : Break
   Endif
  Endif
 Else
  I += 1
 Endif
Wend
If !OK : Return : Endif
Return

$SET_SEP
Local Char SEP(1)
SEP = "|" : # Les formules à évaluer dans le clob sont entre deux caractères "|"
Return

$INICRE
$INIMOD
[F:AWX]CODE = [M:AWX1]CODE
[F:AWX]TYPEVT = [M:AWX1]TYPEVT
Case [M:AWX1]TYPEVT
 When 1 : [F:AWX]CODEVT = [M:AWX1]CODEVT(0)
 When 2 : [F:AWX]CODEVT = [M:AWX1]CODEVT(1)
 When 3 : [F:AWX]CODEVT = [M:AWX1]CODEVT(2)
 When 4 : [F:AWX]CODEVT = [M:AWX1]CODEVT(3)
Endcase
[F:AWX]OPERATION = ""
If [M:AWX1]ACREA = 2
 [F:AWX]OPERATION = "C"
Endif
If [M:AWX1]AMODI = 2
 [F:AWX]OPERATION += "M"
Endif
If [M:AWX1]ASUPP = 2
 [F:AWX]OPERATION += "A"
Endif
[F:AWX]TRACE = [M:AWX1]TRACE
For I=0 To 4
 [F:AWX]ANDOR(I)  =evalue("[M]ANDOR"+num$(I+1))
 [F:AWX]FLD(I)    =evalue("[M]CHAMP"+num$(I+1))
 [F:AWX]OPE(I)    =evalue("[M]OPE"+num$(I+1))
 [F:AWX]VALEUR(I) =evalue("[M]VALEUR"+num$(I+1))
 [F:AWX]VALI(I)   =evalue("[M]VALI"+num$(I+1))
Next
[F:AWX]EXP1 = [M:AWX1]EXP1
For I=0 To 1
 [F:AWX]TYPDES(I) =evalue("[M]TYPDES"+num$(I+1))
 [F:AWX]DESTIN(I) =evalue("[M]DESTIN"+num$(I+1))
 [F:AWX]FNCDES(I) =evalue("[M]FNCDES"+num$(I+1))
 [F:AWX]ENVOI(I)  =evalue("[M]ENVOI"+num$(I+1))
 [F:AWX]SUIVI(I)  =evalue("[M]SUIVI"+num$(I+1))
Next
[F:AWX]OBJET = [M:AWX1]OBJET
[F:AWX]TEXTE = [M:AWX1]TEXTE
Return

$ECRIRE
Call MAJTEXTRA([M]INTIT,"AWRKPARX","INTIT",[M:AWX1]CODE,"") From ATEXTRA
Return

$CHARGE_HLP
Local Integer I , J , NBFOR
Local Char    A_AHLP(50) , OBJET(GLONAOB)
Local Char    FEN(GLONFEN)
A_HLP = "AUTILIS" : Gosub INC_HLP
FEN = ""
Case TYPEVT
 When 1 : # Objet
  OBJET = [M]CODEVT(0)
  Gosub SET_FENOBJ
 When 3 : # Report
  FEN = "AIMP1"
 When 4 : # Batch
  Read [ABT]CODTAC = [M]CODEVT(3)
  If !fstat & [F:ABT]FONCTION<>""
   Read [AFC]CODINT = [F:ABT]FONCTION
   If !fstat & [F:AFC]ACTION<>""
    Read [ACT]ACTION=[F:AFC]ACTION
    If !fstat & [F:ACT]PARAM4<>""
     FEN = [F:ACT]PARAM4
    Endif
   Endif
  Endif
Endcase
If FEN<>""
 Read [AWI]AWI0 = FEN
 If fstat : FEN = "" : Endif
Endif
Case [M]TYPEVT
 When 1 : # Objet
  Read [AOB]ABREV = [M]CODEVT(0)
  If !fstat
   A_HLP  = [F:AOB]NOMFIC : Gosub INC_HLP
   Gosub CHARGE_AWI
  Endif
 When 2 : # Fonction
  A_HLP = "AFONCTION" : Gosub INC_HLP
 When 3 : # Report
  A_HLP = "AREPORT" : Gosub INC_HLP
  Gosub CHARGE_AWI
 When 4 : # Batch
  A_HLP = "[V]GERRBATCH"  : Gosub INC_HLP
  A_HLP = "[V]GMESSBATCH" : Gosub INC_HLP
  A_HLP = "[V]GERRTRACE"  : Gosub INC_HLP
  A_HLP = "ABATRQT"       : Gosub INC_HLP
  Gosub CHARGE_AWI
Endcase
Return

$INC_HLP
If NBFOR<dim([M]HLPFOR) & !find(A_HLP,[M]HLPFOR(0..NBFOR+1))
 NBFOR += 1
 [M]HLPFOR(NBFOR-1) = A_HLP
Endif
Return

#--------------------------------------------#
$SET_FENOBJ
Filter [AWI] Where OBJ=OBJET
Read [AWI]AWI0 = "O"+OBJET
If !fstat
 FEN = [F:AWI]WIN
Else
 For [AWI]
  FEN = [F:AWI]WIN : Break
 Next AWI
Endif
Filter [AWI]
Return

#--------------------------------------------#
$CHARGE_AWI
If FEN<>""
 If [F:AWI]MSKENT<>""
  Read [AMK]CODMSK = [F:AWI]MSKENT
  If !fstat
   A_HLP = "[M:"+[F:AMK]ABRMSK+"]"+[F:AWI]MSKENT : Gosub INC_HLP
  Else
   A_HLP = "[M]"+[F:AWI]MSKENT : Gosub INC_HLP
  Endif
 Endif
 For I=0 To [F:AWI]NBMSK-1
  If [F:AWI]NOMMSK(I)<>""
   J = 1
   If [F:AWI]ACTMSK(I)<>""
    Read [ACV]CODACT = [F:AWI]ACTMSK(I)
    If fstat | [F:ACV]FLACT<>2
     J = 0
    Endif
   Endif
   If J
    Read [AMK]CODMSK = [F:AWI]NOMMSK(I)
    If !fstat
     A_HLP = "[M:"+[F:AMK]ABRMSK+"]"+[F:AWI]NOMMSK(I)
    Else
     A_HLP = "[M]"+[F:AWI]NOMMSK(I)
    Endif
    Gosub INC_HLP
   Endif
  Endif
 Next I
Endif
Return

$SEL_TABLE
Case TABLE
 When "SELFLDTAB4" : Gosub SELFLDTAB4
Endcase
Return

$FIN_TABLE
Case TABLE
 When "SELFLDTAB4" : Gosub F_SELFLDTAB4
Endcase
Return

$F_SELFLDTAB4
If [F:ATX]TEXTE <> ""
 VALEUR = [F:ATX]TEXTE
 PARAM(2) = [F:ATZ]CODZONE
Endif
Return

$SELFLDTAB4
Local Char ZONE(20),INTIT(30)
Local Integer K
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif

Link [ATZ] With
& [ATX]NUMERO=GLANGUE;NOCOURT,
& [ACV]CODACT=[F:ATZ]CODACT,
& [ATY]CODTYP=[F:ATZ]CODTYP
& As [ATZ_]
Default File [ATZ_]
K = instr(1,VALEUR,"(")
If K
 INTIT =left$(VALEUR,K-1)
Else
 INTIT = VALEUR
Endif
ZONE = PARAM(2)
K = instr(1,ZONE,"(")
If K
 ZONE =left$(ZONE,K-1)
Endif
CRITERE  = 'CODFIC = "'+PARAM(1)+'"'
CRITERE += '& [F:ATY]TYPTYP<9'
CRITERE += '& ([F:ATZ]CODACT="" |([F:ACV]FLACT=2    & [F:ACV]TYP <> 2) )'
CRITERE += '& find(CODTYP,"AXX","AX1","AX2","AX3")=0'
EXPSTART = 'left$([F:ATX]TEXTE,len("'+INTIT+'"))>="'+INTIT+'"'
EXPSTART += ' & [F:ATZ]CODZONE >= "'+ZONE+'"'
ORDRE = "[F:ATX]TEXTE;[F:ATZ]CODZONE"
TIT(0) =  mess(109,124,1) : # Choix d'un champ
DEFPAG = 1
NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "[F:ATX]TEXTE"   : TIT(NBCOL) = mess(30,109,1)   : # Intitulé
NBCOL += 1 : COL(NBCOL) = "[F:ATZ]CODZONE" : TIT(NBCOL) = mess(149,123,1)  : # Champs
#NBCOL += 1 : COL(NBCOL) = "[F:ATZ]CODTYP"  : TIT(NBCOL) = mess(21,115,1)   : # Types de données
#NBCOL += 1 : COL(NBCOL) = "[F:ATZ]DIME"    : TIT(NBCOL) = mess(6,16,1)     : # Dimensions
Return

######################################################################################
#-----------------         Etiquettes de grisage       ------------------------------#
######################################################################################
$GRISE_CODEVT
For I=1 To 4
 If [M]TYPEVT <> I
  Raz   [M]CODEVT(I-1),LIBEVT(I-1)
  Diszo [M]CODEVT(I-1)
 Else
  Actzo [M]CODEVT(I-1)
 Endif
Next
Affzo [M]CODEVT,LIBEVT
Return

$GRISE_OPERATION
Case [M:AWX1]TYPEVT
 When 1
  Raz   [M]TRACE
  Affzo [M]TRACE
  Grizo [M]TRACE
  Actzo [M]ACREA,AMODI,ASUPP,RETOUR
 When 2,3
  Raz   [M]ACREA,AMODI,ASUPP,TRACE
  Affzo [M]12
  Grizo [M]12
 When 4
  Raz   [M]ACREA,AMODI,ASUPP,RETOUR
  Affzo [M]ACREA,AMODI,ASUPP,RETOUR
  Grizo [M]ACREA,AMODI,ASUPP,RETOUR
  Actzo [M]TRACE
Endcase
Return

$GRISE_DESTINATAIRE
If [M:AWX1]DESTIN1 =""
 Raz   [M:AWX1]FNCDES1,ENVOI1,SUIVI1,TYPDES2,DESTIN2,FNCDES2,ENVOI2,SUIVI2
 Affzo [M:AWX1]FNCDES1,ENVOI1,SUIVI1,TYPDES2,DESTIN2,FNCDES2,ENVOI2,SUIVI2
 Grizo [M:AWX1]FNCDES1,SUIVI1,ENVOI1,TYPDES2,DESTIN2,FNCDES2,SUIVI2,ENVOI2
 Return
Else
 Actzo ENVOI1,SUIVI1
Endif
If [M:AWX1]DESTIN2 =""
 Raz   [M:AWX1]FNCDES2,ENVOI2,SUIVI2
 Grizo [M:AWX1]FNCDES2,ENVOI2,SUIVI2
 Affzo [M:AWX1]FNCDES2,ENVOI2,SUIVI2
Else
 Actzo ENVOI2,SUIVI2
Endif
If [M:AWX1]TYPDES1 <> 2
 Raz   [M:AWX1]FNCDES1
 Affzo [M:AWX1]FNCDES1
 Grizo [M:AWX1]FNCDES1
Elsif [M:AWX1]DESTIN1 <> ""
 Actzo  [M:AWX1]FNCDES1
Endif
If [M:AWX1]TYPDES2 <> 2
 Raz [M:AWX1]FNCDES2
 Affzo [M:AWX1]FNCDES2
 Grizo [M:AWX1]FNCDES2
Elsif [M:AWX1]DESTIN2 <> ""
 Actzo [M:AWX1]FNCDES2
Endif
Return

$GRISE_CONDITION
If [M:AWX1]TYPEVT = 3 | ( [M:AWX1]TYPEVT = 1 & [M:AWX1]CODEVT(0) = "" )
 Raz   [M]FLD1,OPE1,VALEUR1,ANDOR2,FLD2,OPE2,VALEUR2,ANDOR3,FLD3,OPE3,VALEUR3,ANDOR4,FLD4,OPE4,VALEUR4
&      ,ANDOR5,FLD5,OPE5,VALEUR5,CHAMP1,CHAMP2,CHAMP3,CHAMP4,CHAMP5
 Grizo [M]FLD1,OPE1,VALEUR1,ANDOR2,FLD2,OPE2,VALEUR2,ANDOR3,FLD3,OPE3,VALEUR3,ANDOR4,FLD4,OPE4,VALEUR4
&      ,ANDOR5,FLD5,OPE5,VALEUR5
 Affzo [M]FLD1,OPE1,VALEUR1,ANDOR2,FLD2,OPE2,VALEUR2,ANDOR3,FLD3,OPE3,VALEUR3,ANDOR4,FLD4,OPE4,VALEUR4
&      ,ANDOR5,FLD5,OPE5,VALEUR5
Else
 If [M]FLD1 = ""
  Raz   [M]OPE1,VALEUR1,ANDOR2,FLD2,OPE2,VALEUR2,ANDOR3,FLD3,OPE3,VALEUR3,ANDOR4,FLD4,OPE4,VALEUR4
&       ,ANDOR5,FLD5,OPE5,VALEUR5,CHAMP1,CHAMP2,CHAMP3,CHAMP4,CHAMP5
  Grizo [M]OPE1,VALEUR1,ANDOR2,FLD2,OPE2,VALEUR2,ANDOR3,FLD3,OPE3,VALEUR3,ANDOR4,FLD4,OPE4,VALEUR4
&       ,ANDOR5,FLD5,OPE5,VALEUR5
 Elsif [M]FLD2 = ""
  Raz   [M]OPE2,VALEUR2,ANDOR3,FLD3,OPE3,VALEUR3,ANDOR4,FLD4,OPE4,VALEUR4,ANDOR5,FLD5,OPE5,VALEUR5
&       ,CHAMP2,CHAMP3,CHAMP4,CHAMP5
  Grizo [M]OPE2,VALEUR2,ANDOR3,FLD3,OPE3,VALEUR3,ANDOR4,FLD4,OPE4,VALEUR4,ANDOR5,FLD5,OPE5,VALEUR5
 Elsif [M]FLD3 = ""
  Raz   [M]OPE3,VALEUR3,ANDOR4,FLD4,OPE4,VALEUR4,ANDOR5,FLD5,OPE5,VALEUR5,CHAMP3,CHAMP4,CHAMP5
  Grizo [M]OPE3,VALEUR3,ANDOR4,FLD4,OPE4,VALEUR4,ANDOR5,FLD5,OPE5,VALEUR5
 Elsif [M]FLD4 = ""
  Raz   [M]OPE4,VALEUR4,ANDOR5,FLD5,OPE5,VALEUR5,CHAMP4,CHAMP5
  Grizo [M]OPE4,VALEUR4,ANDOR5,FLD5,OPE5,VALEUR5
 Elsif [M]FLD5 = ""
  Raz   [M]OPE5,VALEUR5,CHAMP5
  Grizo [M]OPE5,VALEUR5
 Endif
 If[M]FLD5 <> ""
  Actzo [M]OPE5
 Endif
 If [M]FLD4 <> ""
  Actzo [M]OPE4,ANDOR5,FLD5
 Endif
 If [M]FLD3 <> ""
  Actzo [M]OPE3,ANDOR4,FLD4
 Endif
 If [M]FLD2 <> ""
  Actzo [M]OPE2,ANDOR3,FLD3
 Endif
 If [M]FLD1 <> ""
  Actzo [M]OPE1,ANDOR2,FLD2
 Endif
 Actzo [M]FLD1
 Gosub GRISE_VALEUR
Endif
Return

$GRISE_VALEUR
If [M]OPE1 > 8 | [M]OPE1 =1 | [M]OPE1 =0 : Raz [M]VALEUR1 : Grizo [M]VALEUR1 : Else : Actzo [M]VALEUR1 : Endif
If [M]OPE2 > 8 | [M]OPE2 =1 | [M]OPE2 =0 : Raz [M]VALEUR2 : Grizo [M]VALEUR2 : Else : Actzo [M]VALEUR2 : Endif
If [M]OPE3 > 8 | [M]OPE3 =1 | [M]OPE3 =0 : Raz [M]VALEUR3 : Grizo [M]VALEUR3 : Else : Actzo [M]VALEUR3 : Endif
If [M]OPE4 > 8 | [M]OPE4 =1 | [M]OPE4 =0 : Raz [M]VALEUR4 : Grizo [M]VALEUR4 : Else : Actzo [M]VALEUR4 : Endif
If [M]OPE5 > 8 | [M]OPE5 =1 | [M]OPE5 =0 : Raz [M]VALEUR5 : Grizo [M]VALEUR5 : Else : Actzo [M]VALEUR5 : Endif
Return

######################################################################################
#----------------------------         VALIDATION       ------------------------------#
######################################################################################
Subprog VALID(CODES)
Value Char CODES
Local Integer I,OK
Call DEBTRANS From GLOCK
Gosub TR_VAL
If GOK
 Call VALID([L]CODES,nomap,0,OK) From AWRKGEN
Endif
End

$TR_VAL
GOK =1
Trbegin [AWA],[AWH],[AWF]
 ####### suppression des anciens parametrages #######
 Read [AWF]AWF0 = [L]CODES
 If !fstat
  Delete [F:AWF]Curr
  If fstat=1  : GOK=-1 : Call RSTA("AWF",[L]CODES) From GLOCK : Goto ROLL_TR_VAL : Endif
 Endif
 Read [AWH]AWH0 = [L]CODES
 If !fstat
  Delete [F:AWH]Curr
  If fstat=1  : GOK=-1 : Call RSTA("AWH",[L]CODES) From GLOCK : Goto ROLL_TR_VAL : Endif
 Endif
 Read [AWA]AWA0 = [L]CODES
 If !fstat
  Delete [F:AWA]Curr
  If fstat=1  : GOK=-1 : Call RSTA("AWA",[L]CODES) From GLOCK : Goto ROLL_TR_VAL : Endif
 Endif
 ############  lecture regle simplifié  ####
 Read [AWX]AWX0 = [L]CODES
 If fstat : Goto AB_TR_VAL : Endif
 ############ Raz tables AWA, AWH , AWF ####
 Raz [AWA],[AWF],[AWH]
 ############ AWH  destinataire ############
 [F:AWH]CODE = [L]CODES
 For I=0 To 1
  If [AWX]DESTIN(I) <> ""
   [F:AWH]TYPDES(I) = [F:AWX]TYPDES(I)
   If [F:AWH]TYPDES(I)<> 1
    [F:AWH]FNCDES(I) = [F:AWX]FNCDES(I)
   Endif
   [F:AWH]DESTIN(I) = [F:AWX]DESTIN(I)
   [F:AWH]NBDEST += 1
   [F:AWH]ENVOI(I) = [F:AWX]ENVOI(I)
   [F:AWH]SUIVI(I) = [F:AWX]SUIVI(I)
  Endif
 Next
 Write [AWH]
 If fstat
  GOK=0 : Call FSTA("AWH") From GLOCK : Goto AB_TR_VAL
 Endif
 ############ AWF signature ##################
 [F:AWF]CODE = [L]CODES
 For I=0 To dim([F:AWX]SUIVI)-1
  If [F:AWX]SUIVI(I)>1
   If [F:AWX]OBJET<>""
    [F:AWF]TEXSUI = [F:AWX]OBJET
   Else
    Gosub CRE_OBJET
    [F:AWF]TEXSUI  = [L]EXPR
   Endif
   Break
  Endif
 Next I
 Write [AWF]
 If fstat
  GOK=0 : Call FSTA("AWF") From GLOCK : Goto AB_TR_VAL
 Endif
 ############ AWA regles workflow ############
 [F:AWA]CODE = [L]CODES
 Call MAJTEXTRA([M]INTIT,"AWRKPAR","INTIT",[L]CODES,"") From ATEXTRA
 If   GOK<0 : Goto ROLL_TR_VAL
 Elsif !GOK : Goto AB_TR_VAL
 Endif
 [F:AWA]ENAFLG = [F:AWX]ENAFLG
 Case [F:AWX]TYPEVT
  When 1 : [F:AWA]TYPEVT = 2
  When 2 : [F:AWA]TYPEVT = 3
  When 3 : [F:AWA]TYPEVT = 4
  When 4 : [F:AWA]TYPEVT = 5
 Endcase
 [F:AWA]CODEVT = [F:AWX]CODEVT
 [F:AWA]OPERATION = [F:AWX]OPERATION
 Gosub EXPRESSION
 If [L]EXPRESSION <> ""
  [F:AWA]NBCOND +=1
  [F:AWA]CONDITION(0) = [L]EXPRESSION
  [F:AWA]TYPCND(0) = 2
 Endif
 If [F:AWX]EXP1 <> ""
  [F:AWA]NBCOND +=1
  [F:AWA]CONDITION([F:AWA]NBCOND-1) = [F:AWX]EXP1
  [F:AWA]TYPCND([F:AWA]NBCOND-1) = 2
 Endif
 If [F:AWX]ENVOI(0) = 2 & [F:AWX]DESTIN(0)<> ""
  [F:AWA]ENAMES =2
 Endif
 If [F:AWX]SUIVI(0) = 2 & [F:AWX]DESTIN(0)<> ""
  [F:AWA]ENASUI = 2
 Endif
 If [F:AWX]ENVOI(1) = 2 & [F:AWX]DESTIN(1)<> ""
  [F:AWA]ENAMES =2
 Endif
 If [F:AWX]SUIVI(1) = 2 & [F:AWX]DESTIN(1)<> ""
  [F:AWA]ENASUI = 2
 Endif
 If [F:AWX]OBJET<>""
  [F:AWA]OBJET  = [F:AWX]OBJET
 Else
  Gosub CRE_OBJET
  [F:AWA]OBJET  = [L]EXPR
 Endif
 [F:AWA]RETOUR = [F:AWX]RETOUR
 [F:AWA]TEXTE  = [F:AWX]TEXTE
 [F:AWA]TYPMES = 1
 [F:AWA]TRACE  = [F:AWX]TRACE
 [F:AWA]CREDAT = [F:AWX]CREDAT
 [F:AWA]CREUSR = [F:AWX]CREUSR
 [F:AWA]UPDDAT = [F:AWX]UPDDAT
 [F:AWA]UPDUSR = [F:AWX]UPDUSR
 If dim([F:AWA]CRETIM)>0 & dim([F:AWX]CRETIM)>0 : [F:AWA]CRETIM = [F:AWX]CRETIM : Endif
 If dim([F:AWA]UPDTIM)>0 & dim([F:AWX]UPDTIM)>0 : [F:AWA]UPDTIM = [F:AWX]UPDTIM : Endif
 Write [AWA]
 If fstat
  GOK=0 : Call FSTA("AWA") From GLOCK : Goto AB_TR_VAL
 Endif
Commit
Return

$AB_TR_VAL
Rollback
Return

$ROLL_TR_VAL
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_VAL : Endif

######################################################################################
#----------------------------         COPIE            ------------------------------#
######################################################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File AWRKPARX [AWX1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".AWRKPARX" [AWX1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File AWRKPARX [AWX2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".AWRKPARX" [AWX2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
OK = 1
If GTRACE=""
 Read [AWX2]AWX0 = TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [AWX1] , [AWX2]  , [AXX1] , [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [AWX2]
 Delete [AWX2] Where CODE=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AWKRPARX" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AWX2","") From GLOCK : Goto AB_TR_COP
 Endif
  For [AWX1]AWX0 Where CODE=TABLE
  [F:AWX2] = [F:AWX1]
  Call COPTEXTRA("AWRKPARX","INTIT",TABLE,"") From ATEXTRA
  If dim([F:AWX2]UPDUSR)>0 : [F:AWX2]UPDUSR = GUSER : Endif
  If dim([F:AWX2]UPDDAT)>0 : [F:AWX2]UPDDAT = date$ : Endif
  If dim([F:AWX2]UPDTIM)>0 : [F:AWX2]UPDTIM = time : Endif
  Write [AWX2]
  If fstat
   GOK=0 : Call FSTA("AWX2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

######################################################################################
#--------------------         Sous programme de l'ecran       -----------------------#
######################################################################################

Subprog C_FLD1(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 1
End

Subprog C_FLD2(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 2
End

Subprog C_FLD3(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 3
End

Subprog C_FLD4(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 4
End

Subprog C_FLD5(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 5
End

$C_FLD
If VALEUR="" : Return : Endif

Local Char    NEW_VALEUR(30)
Local Integer K , DIME , DIMMAX , OK , NBTEX
Local Char    ZONE(20) , PARMSK(20)(1..2)
Local Char    TEX(80)(1..GNBSEL) , TEXTE(80)(1..GNBSEL,1..2) , TIT(80)(0..2)

NEW_VALEUR = toupper(VALEUR)
K = instr(1,NEW_VALEUR,"(")
If K
 DIME = val(right$(NEW_VALEUR,K+1))
 ZONE = left$(NEW_VALEUR,K-1)
Else
 DIME = 0
 ZONE = NEW_VALEUR
Endif

PARMSK(1) = num$(I)
PARMSK(2) = ZONE
Call S_LIS_CHAR(VALEUR,PARMSK,"","SUBAWX","") From GACTION
ZONE = PARMSK(2)

Read [ATZ]CODZONE = [M]ATB;ZONE
If fstat
 GMESSAGE = mess(9,124,1) : # Champ inexistant
 mkstat = 2 : Return
Endif
If find([F:ATZ]CODTYP,"AXX","AX1","AX2","AX3")
 GMESSAGE = [F:ATZ]CODTYP-":"-mess(14,133,1) : # Type de donnée incorrect
 mkstat = 2 : Return
Endif
Read [ATY]CODTYP = [F:ATZ]CODTYP
If !fstat & [F:ATY]TYPTYP>8
 GMESSAGE = mess([F:ATY]TYPTYP,30,1)-":"-mess(14,133,1) : # Type de donnée incorrect
 mkstat = 2 : Return
Endif
If [F:ATZ]CODACT<>""
 Read [ACV]CODACT = [F:ATZ]CODACT
 If !fstat & ([F:ACV]DIMFIL<>0 or [F:ACV]DIME<>0)
  DIMMAX = max([F:ACV]DIMFIL,[F:ACV]DIME)
 Endif
Else
 DIMMAX = [F:ATZ]DIME
Endif
If (DIME<>0 | DIMMAX<>0) & DIME>DIMMAX-1
 GMESSAGE = mess(46,105,1) : # Indice incorrect
 mkstat = 2 : Return
Endif
Case I
 When 1 : [M]CHAMP1 = ZONE : If DIME > 0 : [M]CHAMP1 += "("+num$(DIME)+")" : Endif
 When 2 : [M]CHAMP2 = ZONE : If DIME > 0 : [M]CHAMP2 += "("+num$(DIME)+")" : Endif
 When 3 : [M]CHAMP3 = ZONE : If DIME > 0 : [M]CHAMP3 += "("+num$(DIME)+")" : Endif
 When 4 : [M]CHAMP4 = ZONE : If DIME > 0 : [M]CHAMP4 += "("+num$(DIME)+")" : Endif
 When 5 : [M]CHAMP5 = ZONE : If DIME > 0 : [M]CHAMP5 += "("+num$(DIME)+")" : Endif
Endcase
If DIME>0
 VALEUR += "("+num$(DIME)+")"
Endif
Return

$SEL_LISTE
Local Integer NUMERO , NBTEX
Local Char    TEX(80)(1..GNBSEL) , TEXTE(80)(1..GNBSEL,1..2) , TIT(80)(0..2)
Local Char    ZONE(80)
NUMERO = val(PARAM(1))
ZONE = PARAM(2)
NBTEX = 0
Read [ATZ]CODZONE = [M]ATB;evalue("[M]CHAMP"+num$(NUMERO))
If !fstat & toupper(func AFNC.TEXTE([ATZ]NOCOURT))=ZONE & !find([F:ATZ]CODTYP,"AXX","AX1","AX2","AX3")
 NBTEX = 1
 TEX(NBTEX) = func AFNC.TEXTE([ATZ]NOCOURT)
 TEXTE(NBTEX,2) = [F:ATZ]CODZONE
Else
 Filter [ATZ]Where CODFIC=[M]ATB & find([F:ATZ]CODTYP,"AXX","AX1","AX2","AX3")=0
 For [ATZ]CODZONE
  If left$(ZONE,len(ZONE))=left$(toupper(func AFNC.TEXTE([ATZ]NOCOURT)),len(ZONE))
   NBTEX += 1
   TEX(NBTEX) = func AFNC.TEXTE([ATZ]NOCOURT)
   TEXTE(NBTEX,2) = [F:ATZ]CODZONE
  Endif
 Next
 Filter [ATZ]
Endif
TIT(0) = mess(149,123,1) : # Champs
TIT(1) = mess(30,109,1) : # Intitulé
TIT(2) = mess(37,100,1) : # Code
Return

$VERF_LISTE
PARAM(2) = TEXTE(CHOIX,2)
Return

Subprog AM_FLD1(VALEUR)
Variable Char VALEUR
Local Integer I
I = 1
[M]FLD1 = VALEUR
Gosub C_FLD
Gosub AM_FLD
Gosub GRISE_TAB
End

Subprog AM_FLD2(VALEUR)
Variable Char VALEUR
Local Integer I
I = 2
[M]FLD2 = VALEUR
Gosub C_FLD
Gosub AM_FLD
Gosub GRISE_TAB
End

Subprog AM_FLD3(VALEUR)
Variable Char VALEUR
Local Integer I
I = 3
[M]FLD3 = VALEUR
Gosub C_FLD
Gosub AM_FLD
Gosub GRISE_TAB
End

Subprog AM_FLD4(VALEUR)
Variable Char VALEUR
Local Integer I
I = 4
[M]FLD4 = VALEUR
Gosub C_FLD
Gosub AM_FLD
Gosub GRISE_TAB
End

Subprog AM_FLD5(VALEUR)
Variable Char VALEUR
Local Integer I
I = 5
[M]FLD5 = VALEUR
Gosub C_FLD
Gosub AM_FLD
Gosub GRISE_TAB
End

$AM_FLD
Local Char    CHAMP(20) , TABLE(GLONATB) , FORMA(30) , CAR(1) , OPTION(10) , ZONE(GLONAVA)
Local Integer NOLIB , K , LONG , TABDIV
Case I
 When 1 : If [M]FLD1 <> "" : CHAMP = [M]CHAMP1 : Endif
 When 2 : If [M]FLD2 <> "" : CHAMP = [M]CHAMP2 : Endif
 When 3 : If [M]FLD3 <> "" : CHAMP = [M]CHAMP3 : Endif
 When 4 : If [M]FLD4 <> "" : CHAMP = [M]CHAMP4 : Endif
 When 5 : If [M]FLD5 <> "" : CHAMP = [M]CHAMP5 : Endif
Endcase
TABLE = [M]ATB
K = instr(1,CHAMP,"(")
If K
 ZONE = left$(CHAMP,K-1)
Else
 ZONE = CHAMP
Endif

If ZONE=""
 FORMA = "Kf:15X"
Else
 Read [ATZ]CODZONE = TABLE;ZONE
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 NOLIB  = 0
 TABDIV = 0
 Case [F:ATY]TYPTYP
  When 1
   If [F:ATY]NOLIB<>0
    NOLIB = [F:ATY]NOLIB
   Else
    NOLIB = [F:ATZ]NOLIB
   Endif
   FORMA = "Nf:2#"
  When 7
   If [F:ATY]LNGTYP<>0
    LONG = [F:ATY]LNGTYP
   Else
    LONG = [F:ATZ]LONG
   Endif
   If LONG>20 : LONG = 20 : Endif
   OPTION = [F:ATY]OPTION+[F:ATZ]OPTION
   If instr(1,OPTION,"C")
    CAR = "d"
   Elsif instr(1,OPTION,"A")
    CAR = "d"
   Else
    CAR = "X"
   Endif
   FORMA = "Kf:"+num$(LONG)+CAR
   If [F:ATY]OBJLIEN="ADI"
    TABDIV = val([F:ATZ]EXPLIEN)
   Endif
  When 8
   FORMA = "Df:"+GFMDAT
  When 2,3
   If [F:ATY]LNGTYP<>0
    LONG = [F:ATY]LNGTYP
   Else
    LONG = [F:ATZ]LONG
   Endif
   FORMA = "Nf:"+num$(LONG)+"#"
  When 4
   If [F:ATY]LNGTYP<>0
    LONG = [F:ATY]LNGTYP
   Else
    LONG = [F:ATZ]LONG
   Endif
   FORMA = "Nf:15F"
 Endcase
 Case I
  When 1 : [M]FMT1 = [F:ATY]CODTYP : [M]NOLIB1 = NOLIB : [M]TYPTYP1 = [F:ATY]TYPTYP
           If TABDIV<>0 : [M]SUPP1 = '"'+num$(TABDIV)+'"' : Else : [M]SUPP1 = "" : Endif
  When 2 : [M]FMT2 = [F:ATY]CODTYP : [M]NOLIB2 = NOLIB : [M]TYPTYP2 = [F:ATY]TYPTYP
           If TABDIV<>0 : [M]SUPP2 = '"'+num$(TABDIV)+'"' : Else : [M]SUPP2 = "" : Endif
  When 3 : [M]FMT3 = [F:ATY]CODTYP : [M]NOLIB3 = NOLIB : [M]TYPTYP3 = [F:ATY]TYPTYP
           If TABDIV<>0 : [M]SUPP3 = '"'+num$(TABDIV)+'"' : Else : [M]SUPP3 = "" : Endif
  When 4 : [M]FMT4 = [F:ATY]CODTYP : [M]NOLIB4 = NOLIB : [M]TYPTYP4 = [F:ATY]TYPTYP
           If TABDIV<>0 : [M]SUPP4 = '"'+num$(TABDIV)+'"' : Else : [M]SUPP4 = "" : Endif
 When 5 : [M]FMT5 = [F:ATY]CODTYP : [M]NOLIB5 = NOLIB : [M]TYPTYP5 = [F:ATY]TYPTYP
           If TABDIV<>0 : [M]SUPP5 = '"'+num$(TABDIV)+'"' : Else : [M]SUPP5 = "" : Endif
Endcase
Endif
Return

$GRISE_TAB
Gosub GRISE_CONDITION
Return

Subprog C_VALEUR1(VALEUR)
Variable Char VALEUR
Local Integer I
I = 1
Goto C_VAL

Subprog C_VALEUR2(VALEUR)
Variable Char VALEUR
Local Integer I
I = 2
Goto C_VAL

Subprog C_VALEUR3(VALEUR)
Variable Char VALEUR
Local Integer I
I = 3
Goto C_VAL

Subprog C_VALEUR4(VALEUR)
Variable Char VALEUR
Local Integer I
I = 4
Goto C_VAL

Subprog C_VALEUR5(VALEUR)
Variable Char VALEUR
Local Integer I
I = 5
Goto C_VAL

$C_VAL
Local Char TYP(GLONATY)
Case I
 When 1 : TYP = [M]FMT1
 When 2 : TYP = [M]FMT2
 When 3 : TYP = [M]FMT3
 When 4 : TYP = [M]FMT4
 When 5 : TYP = [M]FMT5
Endcase
Call LECTURE("ATY",TYP,"") From CONTOBJ
If [F:ATY]TYPTYP<7 & VALEUR=""
 GMESSAGE = mess(10,123,1) : mkstat = 2 : End
# Zone obligatoire
Endif
If instr(1,VALEUR,'"')
 GMESSAGE = '" :'-mess(94,123,1) : mkstat = 2 : End
#  Caractère interdit
Endif
# Call CHARGE([M:ASL]VAL4,[M:ASL]FMT4,[M:ASL]NOLIB4,0,[M:ASL]VALI4) From FMTVAR
End

Subprog AM_CODEVT(VALEUR)
Variable Char    VALEUR()
Case [M]TYPEVT
 When 1
  [M]CODEVT(0) = VALEUR
  Gosub GRISE_CONDITION
 When 2 : [M]CODEVT(1) = VALEUR
 When 3 : [M]CODEVT(2) = VALEUR
 When 4 : [M]CODEVT(3) = VALEUR
Endcase
Raz [M]HLPFOR
Gosub CHARGE_HLP
End

Subprog AM_TYPEVT(VALEUR)
Variable Integer VALEUR
[M]TYPEVT = VALEUR
Case [M]TYPEVT
 When 1 : [M]TYPEVT2 = 2
 When 2 : [M]TYPEVT2 = 3
 When 3 : [M]TYPEVT2 = 4
 When 4 : [M]TYPEVT2 = 5
Endcase
Gosub GRISE_OPERATION
Gosub GRISE_CONDITION
Gosub GRISE_CODEVT
End

Subprog IB_CODEVT
GBOUT1 = ""
If GADONIX<>2 : End : Endif
Case [M]TYPEVT
 When 1   : GBOUT1 = mess(18,125,1) : # Objet
 When 2   : GBOUT1 = mess(21,125,1) : # Fonction
 When 3   : GBOUT1 = mess(22,125,1) : # Etat
 When 4   : GBOUT1 = mess(92,134,1) : # Tâches
Endcase
End

Subprog B1_CODEVT(VALEUR)
Variable Char    VALEUR()
Local Char OBJET(GLONAOB)
Case [M]TYPEVT
 When 1   : OBJET = "AOB" : # Objet
 When 2   : OBJET = "AFC" : # Fonction
 When 3   : OBJET = "ARP" : # Etat
 When 4   : OBJET = "ABT" : # Tâches
Endcase
Call OBJET_CHAR(VALEUR,OBJET,"") From GOBJET
End

Subprog C_CODEVT(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Case [M]TYPEVT
 When 1 : # Objet
  [M]ATB = ""
  If find(VALEUR,"AWM","AWR","AWV","AWO","AWA","ANM")
   GMESSAGE = VALEUR-mess(207,126,1) : # Objet interdit dans cette fonction
   mkstat = 2 : End
  Elsif VALEUR<>""
   Read [AOB]ABREV = VALEUR
   If fstat
    Call CONTSEL("AOB","",VALEUR,"",mkstat) From CONTOBJ
   Elsif [F:AOB]TYPGES=4
    GMESSAGE = VALEUR-mess(207,126,1) : # Objet interdit dans cette fonction
    mkstat = 2 : End
   Else
    Call TEXTE([F:AOB]LIBEL,[M]LIBEVT(0)) From OBJDIV
    [M]ATB = [F:AOB]NOMFIC
    Affzo [M]LIBEVT(0)
   Endif
  Else
   Raz [M]LIBEVT(0) : Affzo [M]LIBEVT(0)
  Endif
 When 2 : # Fonction
  [M]ATB = "AFONCTION"
  If VALEUR<>""
   Read [AFC]CODINT = VALEUR
   If fstat | [F:AFC]TYPTRAIT<>1
    Call CONTSEL("AFC","T",VALEUR,"",mkstat) From CONTOBJ
   Else
    Call TEXTE([F:AFC]NOM,[M]LIBEVT(1)) From OBJDIV
    Affzo [M]LIBEVT(1)
   Endif
  Else
   Raz [M]LIBEVT(1) : Affzo [M]LIBEVT(1)
  Endif
 When 3 : # Etat
  If VALEUR<>""
   Read [ARP]ARP0 = VALEUR
   If fstat
    Call CONTSEL("ARP","",VALEUR,"",mkstat) From CONTOBJ
   Else
    Call TEXTE([F:ARP]RPTDES,[M]LIBEVT(2)) From OBJDIV
    [M]ATB =""
   Endif
  Else
   Raz [M]LIBEVT(2) : Affzo [M]LIBEVT(2)
  Endif
 When 4 : # Batch, Abort
  [M]ATB = "ABATRQT"
  If VALEUR<>""
   Read [ABT]CODTAC = VALEUR
   If fstat
    Call CONTSEL("ABT","",VALEUR,"",mkstat) From CONTOBJ
   Elsif [F:ABT]MESSAGE<>2
    # L'option message utilisateur n'est pas activée sur cette tâche
    Call AVERTIR(mess(60,139,1),OK) From GESECRAN
    If OK<>2 : mkstat = 2 : End : Endif
   Else
    Call TEXTE([F:ABT]DES,[M]LIBEVT(3)) From OBJDIV
    Affzo [M]LIBEVT(3)
   Endif
  Else
   Raz [M]LIBEVT(3) : Affzo [M]LIBEVT(3)
  Endif
Endcase
End

Subprog B4_DESTIN1(VALEUR)
Variable Char    VALEUR()
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "ASELEMAIL"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELEMAIL","TRTBPA","") From GACTION
GACTION = SAVACT
If find(GSTATUT,GSTALFT,GSTALF2,GSTALF3,GSTALF4)
 VALEUR = '"'+VALEUR+'"'
Endif
End

