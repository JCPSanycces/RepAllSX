Subprog AM_CODE(VALEUR)
Variable Char    VALEUR()
Read [AWA]AWA0 = VALEUR
If !fstat
 # Règle workflow avancée existante
 GMESSAGE = VALEUR-":"-mess(165,75,1)
 mkstat =2 : End
Endif
End

