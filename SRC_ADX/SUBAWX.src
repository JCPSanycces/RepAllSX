Subprog AS_OPE1(VALEUR)
Variable Integer VALEUR
Local Integer I
I=1
Goto AS_OPE

Subprog AS_OPE2(VALEUR)
Variable Integer VALEUR
Local Integer I
I=2
Goto AS_OPE

Subprog AS_OPE3(VALEUR)
Variable Integer VALEUR
Local Integer I
I=3
Goto AS_OPE

Subprog AS_OPE4(VALEUR)
Variable Integer VALEUR
Local Integer I
I=4
Goto AS_OPE

Subprog AS_OPE5(VALEUR)
Variable Integer VALEUR
Local Integer I
I=5
Goto AS_OPE

$AS_OPE
If [M:AWX1]TYPEVT <> 1
 GMENLOC(9)  = 1
 GMENLOC(10) = 1
 GMENLOC(11) = 1
Elsif !find(evalue("[M]TYPTYP"+num$(I)),1,2,3,4,5,6,7,8)
 GMENLOC(10) = 1
 GMENLOC(11) = 1
Endif
Gosub CTL_CHAMP_MASK
If !KO
 GMENLOC(9)  = 1
 GMENLOC(10) = 1
 GMENLOC(11) = 1
Endif
End

$CTL_CHAMP_MASK
KO = 0
Local Char FEN(GLONFEN),ECRAN(GLONAMK)(20),ZONE(GLONAVA)
Local Integer K,N,KO,J
Filter [AWI] Where OBJ=[M:AWX1]CODEVT
Read [AWI]AWI0 = "O"+[M:AWX1]CODEVT
Filter [AWI]
If !fstat
 FEN = [F:AWI]WIN
 If [F:AWI]MSKENT<>""
  ECRAN(0) = [F:AWI]MSKENT
 Endif
 For N=0 To [F:AWI]NBMSK-1
  If [F:AWI]NOMMSK(N)<>""
   K += 1
   ECRAN(K) = [F:AWI]NOMMSK(N)
  Endif
 Next
 For N=0 To K
  J = instr(1,evalue("[M:AWX1]CHAMP"+num$(I)),"(")
  If J
   ZONE = left$(evalue("[M:AWX1]CHAMP"+num$(I)),J-1)
  Else
   ZONE = evalue("[M:AWX1]CHAMP"+num$(I))
  Endif
  Filter [AMZ] Where CODMSK = ECRAN(N) & CODZON = ZONE
  For [AMZ]CODE
   KO =1 : Break 2
  Next
  Filter [AMZ]
 Next
Endif
Return

