###################################################################################
#-------------           creation condition          -----------------------------#
###################################################################################
$EXPRESSION
If dim([M]EXPRESSION)<0
 Local Integer XFLG
 Local Char    EXPRESSION(250)
Endif
If [M]CHAMP1 = ""
 XFLG = 0
Else
 XFLG = 1
Endif
EXPRESSION = ""
If [M]CHAMP1<>""
 Call ADDCRIT(EXPRESSION,[M]ATB,[M]CHAMP1,[M]OPE1,[M]VALI1,XFLG)
 If [M]CHAMP2<>""
  Call ADDETOU(EXPRESSION,[M]ANDOR2,[M]ATB,[M]CHAMP2,[M]OPE2,[M]VALI2,XFLG)
  If [M]CHAMP3<>""
   Call ADDETOU(EXPRESSION,[M]ANDOR3,[M]ATB,[M]CHAMP3,[M]OPE3,[M]VALI3,XFLG)
   If [M]CHAMP4<>""
    Call ADDETOU(EXPRESSION,[M]ANDOR4,[M]ATB,[M]CHAMP4,[M]OPE4,[M]VALI4,XFLG)
    If [M]CHAMP5<>""
     Call ADDETOU(EXPRESSION,[M]ANDOR5,[M]ATB,[M]CHAMP5,[M]OPE5,[M]VALI5,XFLG)
     EXPRESSION += ")"
    Endif
    EXPRESSION += ")"
   Endif
   EXPRESSION += ")"
  Endif
  EXPRESSION += ")"
 Endif
Endif
If [M]EXP1<>"" & 0
 If EXPRESSION<>""
  EXPRESSION -= "&"
 Endif
 EXPRESSION -= "("+[M]EXP1+")"
Endif
Return

###########################################################
Subprog ADDETOU(EXPR,ETOU,TABLE,CHAMP,OPE,VALEUR,XFLG)
Variable Char EXPR()
If EXPR<>""
 Case ETOU
  When 1 : EXPR -= "&"
  When 2 : EXPR -= "|"
 Endcase
Endif
EXPR -= "("
Call ADDCRIT(EXPR,TABLE,CHAMP,OPE,VALEUR,XFLG)
End

###########################################################
Subprog ADDCRIT(EXPR,TABLE,CHAMP,OPE,VALEUR,XFLG)
Variable Char EXPR()
Local Integer I , J , K , L , DIME
Local Char    ZONE(20) , ZFLG(20)
K = instr(1,CHAMP,"(")
If K
 DIME = val(right$(CHAMP,K+1))
 ZONE = left$(CHAMP,K-1)
Else
 DIME = 0
 ZONE = CHAMP
Endif
If OPE<>1
 Read [ATB]CODFIC  = TABLE
 Read [ATZ]CODZONE = TABLE;ZONE
 Read [ATY]CODTYP  = [F:ATZ]CODTYP
 If XFLG=1
  ZFLG = "[F:"+[F:ATB]ABRFIC+"]"+CHAMP
 Else
  ZFLG = CHAMP
 Endif
 If OPE=8
  J = instr(1,VALEUR,"*")
  K = instr(1,VALEUR,"?")
  If J or K
   L = 0
   If K or J<>len(VALEUR)
    EXPR += 'pat('+ZFLG
    If !instr(1,ZFLG,"(") : EXPR += '(0)' : Endif
    EXPR += ',"'+VALEUR+'")=1'
    L = 1
   Endif
   If     J & K : J = min(J,K)
   Elsif !J & K : J = K
   Endif
   If J>1
    If L : EXPR -= '&' : Endif
    EXPR -= ZFLG+'>="'+left$(VALEUR,J-1)+'"'
    EXPR -= '&'
    EXPR -= ZFLG+'<"'+left$(VALEUR,J-2)+chr$(ascii(mid$(VALEUR,J-1,1))+1)+'"'
   Endif
  Else
   EXPR += ZFLG+'="'+VALEUR+'"'
  Endif
 Elsif OPE=9
  EXPR -= ZFLG- "<> [M]"+CHAMP
 Elsif OPE=10
  EXPR -= ZFLG- "< [M]"+CHAMP
 Elsif OPE=11
  EXPR -= ZFLG- "> [M]"+CHAMP
 Else
  EXPR -= ZFLG
  Case OPE
   When 2 : EXPR += "="
   When 3 : EXPR += "<>"
   When 4 : EXPR += ">"
   When 5 : EXPR += ">="
   When 6 : EXPR += "<"
   When 7 : EXPR += "<="
  Endcase
  Case [F:ATY]TYPTYP
   When 7
    EXPR += '"'+VALEUR+'"'
   When 8
    If VALEUR="" or gdat$(VALEUR)=[0/0/0]
     EXPR += '[0/0/0]'
    Else
     EXPR += '['+format$(GFMD,gdat$(VALEUR))+']'
    Endif
   When Default
    EXPR += num$(VALEUR)
  Endcase
 Endif
Else
 EXPR += "1=1"
Endif
End

$CRE_OBJET
Local Char EXPR(250)
Case [F:AWX]TYPEVT
 When 1
  # "L'objet AWX() supprimé par Christophe CLEMENT (CCL) le 11 Octobre 2006 10:00:02"
  EXPR = 'func AFNC.MES3(GOPER,GABREV-GCLE-"("+GINTIT+")",GNOMUSER-"("+GUSER+")",format$("DD4",date$))'
 When 2
  # "Entrée dans la fonction ADOTRT par Christophe CLEMENT (CCL) le 11 Octobre 2006 10:00:02"
  EXPR = 'func AFNC.MES3(mess(173,75,1),GFONCTION,GNOMUSER-"("+GUSER+")",format$("DD4",date$))'
 When 3
  # "Lancement de l'édition par Christophe CLEMENT (CCL) le 11 Octobre 2006 10:00:02"
  EXPR = 'func AFNC.MES3(mess(174,75,1),GREPORT1,GNOMUSER-"("+GUSER+")",format$("DD4",date$))'
 When 4
  # "Fin de la tâche batch par Christophe CLEMENT (CCL) le 11 Octobre 2006 10:00:02"
  EXPR = 'func AFNC.MES3(mess(175,75,1),[F:ABR]TACHE,GNOMUSER-"("+GUSER+")",format$("DD4",date$))'
 Endcase
Return

