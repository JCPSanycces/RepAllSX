#<AdxTL>@(#)7.0.0.0 $Revision$
###############################################################################################################
#
#   Génération HTML d'une Intervention                                              Version 140
#   Module CRM
#
###############################################################################################################
###############################################################################################################
Funprog PREPARE_SEND_EMAIL(ACTX, SITNNUM, SFROMAUS, IASKITNHDTDON, SMESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SITNNUM
Value Char SFROMAUS
Value Integer IASKITNHDTDON
Variable Char SMESSAGE

Local Integer IARENDRE
Local Char SA_FROM(250)
Local Char SA_USER(250)(1..)
Local Char SCC_USER(250)(1..)
Local Char SZEMAILSUBJECT(250)
Local Clbfile BODY(4)
Local Char S_ATTACHMENTS(250)(1..)

  # FGR 03/06/2015 : X3SUIVI108602
  # -------------------------------------------------
  IARENDRE = [V]CST_AYES
  Raz SMESSAGE
  # -------------------------------------------------
  IARENDRE = func PREPARE_EMAIL(ACTX, SITNNUM, "", SFROMAUS, IASKITNHDTDON, SA_FROM, SA_USER, SCC_USER, SZEMAILSUBJECT, BODY, S_ATTACHMENTS, SMESSAGE)
  If IARENDRE = [V]CST_AYES Then
    IARENDRE = func SEND_EMAIL(ACTX, SA_FROM, SA_USER, SCC_USER, SZEMAILSUBJECT, BODY, S_ATTACHMENTS, SMESSAGE)
  Endif
End IARENDRE

###############################################################################################################
Funprog PREPARE_EMAIL(ACTX, SITNNUM, IDSYTYP, SFROMAUS, IASKITNHDTDON, SA_FROM, SA_USER, SCC_USER, SZEMAILSUBJECT, BODY, S_ATTACHMENTS, SMESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SITNNUM
Value Integer IDSYTYP
Value Char SFROMAUS
Value Integer IASKITNHDTDON
Variable Char SA_FROM
Variable Char SA_USER()(1..)
Variable Char SCC_USER()(1..)
Variable Char SZEMAILSUBJECT
Variable Clbfile BODY
Variable Char S_ATTACHMENTS()(1..)
Variable Char SMESSAGE

Local Integer IARENDRE
Local Clbfile CLURL(2)
Local Integer IHDTDON
Local Integer IFOUND
Local Integer NI
Local Integer IERR
Local Integer ICHAPTER
Local Integer ASTATUS
Local Char SZFROM(250)
Local Char TABKEY(50)(1..10)
Local Char TABKEYVAL(50)(1..10)
Local Char TABPAR(50)(1..10)
Local Char TABPARVAL(250)(1..10)
Local Char SZFROM(250)
Local Char SZTO(250)
Local Char SZFULLFILENAME(250)
Local Char SZFILENAME(250)
Local Char SZAUSNAME(250)

  # FGR 03/06/2015 : X3SUIVI108602
  # -------------------------------------------------
  IARENDRE = [V]CST_AYES
  Raz SMESSAGE
  # -------------------------------------------------
  Local File AUTILIS [AUS]
  Local File INTERVEN [ITN]
  Local File BPARTNER [BPR]
  Local File BPADDRESS [BPA]
  # -------------------------------------------------
  Read [AUS]CODUSR=SFROMAUS
  If fstat Then
    SMESSAGE = mess(1162,196,1) - "(" + SFROMAUS + ")"
    IARENDRE = [V]CST_ANO
    Goto END_PREPARE_EMAIL
  Else
    If [F:AUS]ADDEML = "" Then
      SMESSAGE = mess(1162,196,1) - "(" + SFROMAUS + ")"
      IARENDRE = [V]CST_ANO
      Goto END_PREPARE_EMAIL
    Endif
  Endif
  SZFROM = [F:AUS]ADDEML
  Call LECTEXTRA(SZAUSNAME, "AUTILIS", "INTUSR", [F:AUS]USR, "") From ATEXTRA
  # -------------------------------------------------
  Read [ITN]ITN0=SITNNUM
  If fstat Then
    IARENDRE = [V]CST_ANO
    SMESSAGE = mess(1161,196,1) - "(" + SITNNUM + ")"
  Else
    # Obtention de l'adresse E-Mail
    If ([F:ITN]SCO = [V]CST_AYES and [F:ITN]SCONUM = "") or ([F:ITN]SCO <> [V]CST_AYES and [F:ITN]REP = "") Then
      #L'intervention n'est affecté à aucun intervenant.
    Else
      If [F:ITN]SCO = [V]CST_AYES Then
        # ------------
        # Sous-traitée
        # ------------
        Read [BPR]BPR0=[F:ITN]SCONUM
        If !fstat Then
          If [F:BPR]BPAADD <> "" Then
            Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
            If !fstat Then
              IFOUND = -1
              For NI = 0 To dim([F:BPA]WEB)-1
                If [F:BPA]WEB(NI) <> "" Then
                  IFOUND = NI
                  Break
                Endif
              Next NI
              If IFOUND > -1 Then
                SZTO = [F:BPA]WEB(IFOUND)
              Endif
            Endif
          Endif
        Endif
      Else
        # -------------------
        # Intervenant interne
        # -------------------
        Read [AUS]CODUSR=[F:ITN]REP
        If !fstat Then
          If [F:AUS]ADDEML <> "" Then
            SZTO = [F:AUS]ADDEML
          Endif
        Endif
      Endif
    Endif
    # ----------------------------------------
    # Constitution de sujet du message
    If [F:ITN]BPC = "" Then
      Call TEXTE(14563, SZEMAILSUBJECT) From OBJDIV      #Intervention
    Else
      Read [BPR]BPR0=[F:ITN]BPC
      If fstat Then
        Call TEXTE(14563, SZEMAILSUBJECT) From OBJDIV      #Intervention
      Else
        SZEMAILSUBJECT = mess(76,177,1) - ": (" + [F:BPR]BPRNUM + ")" - [F:BPR]BPRNAM
      Endif
    Endif
    # ----------------------------------------
    # Constitution de la pièce jointe
    Call ITNINHTML([F:ITN]NUM, IASKITNHDTDON, 1, "", "ITN_ITNASS", SZFULLFILENAME, SZFILENAME, ICHAPTER, IERR)
    If IERR Then
      SMESSAGE = mess(IERR,ICHAPTER,1)
      IARENDRE = [V]CST_ANO
      Goto END_PREPARE_EMAIL
    Endif
    # ----------------------------------------
    SA_FROM = SZFROM      # From
    Raz SA_USER           # To
    SA_USER(1) = SZTO
    Raz SCC_USER          # Copy to
    SCC_USER(1) = SZFROM  # Je mets l'émetteur du mail en copie sinon il n'a pas trace du mail envoyé dans sa messagerie
    Raz S_ATTACHMENTS     # PJ
    S_ATTACHMENTS(1) = SZFULLFILENAME
    #
    Raz BODY              # Corps du mail
    Read [AUS]CODUSR=SFROMAUS          # Relire [AUS]. A été perdu "quelque part"
    IARENDRE = func SUBHTMMAI1.GET_TEXTE(2, GLANGUE, [F:AUS]USR, BODY, SMESSAGE)
    If IARENDRE = [V]CST_AYES Then
      Append BODY, chr$(10) + SZAUSNAME
      #If [F:ITN]SCO <> [V]CST_AYES Then
        Raz TABKEY
        Raz TABKEYVAL
        Raz TABPAR
        Raz TABPARVAL
        TABKEY(1) = "NUM"
        TABKEYVAL(1) = [F:ITN]NUM
        ASTATUS = func ASYRFNC.AGET_CLASSICURL(GACTX, [V]CST_ATRUE, "GESITN", [V]CST_AMODIFFCT, TABKEY, TABKEYVAL, TABPAR, TABPARVAL, CLURL)
        If [L]ASTATUS = [V]CST_AOK Then
          Append BODY, chr$(10) + chr$(10) + chr$(10)
          Append BODY, CLURL
        Endif
      #Endif
    Endif
  Endif
$END_PREPARE_EMAIL
End IARENDRE

###############################################################################################################
Funprog CREATE_PJ(ACTX, SITNNUM, IDSYTYP, IASKITNHDTDON, S_ATTACHMENTS, SMESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SITNNUM
Value Integer IDSYTYP
Value Integer IASKITNHDTDON
Variable Char S_ATTACHMENTS()(1..)
Variable Char SMESSAGE

Local Integer IARENDRE
Local Char SZSCREENTYPE(10)
Local Integer IERR
Local Integer ICHAPTER
Local Char SZFULLFILENAME(250)
Local Char SZFILENAME(250)

  # FGR 03/06/2015 : X3SUIVI108602
  # -------------------------------------------------
  IARENDRE = [V]CST_AYES
  Raz SMESSAGE
  # -------------------------------------------------
  If IASKITNHDTDON <> [V]CST_ATRUE and IASKITNHDTDON <> [V]CST_AFALSE Then
    IASKITNHDTDON = [V]CST_AFALSE
  Endif
  # -------------------------------------------------
  Local File AUTILIS [AUS]
  Local File INTERVEN [ITN]
  Local File BPARTNER [BPR]
  Local File BPADDRESS [BPA]
  # -------------------------------------------------
  Read [ITN]ITN0=SITNNUM
  If fstat Then
    IARENDRE = [V]CST_ANO
    SMESSAGE = mess(1161,196,1) - "(" + SITNNUM + ")"
  Else
    If [F:ITN]SCO = [V]CST_AYES Then
      # ------------
      # Sous-traitée
      # ------------
      Read [BPR]BPR0=[F:ITN]SCONUM
      If !fstat Then
        If [F:BPR]BPAADD <> "" Then
          Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
        Endif
      Endif
    Else
      # -------------------
      # Intervenant interne
      # -------------------
      Read [AUS]CODUSR=[F:ITN]REP
    Endif
    # -------------------------------------------------
    SZSCREENTYPE = func TRTLKP9.GET_SCREENTYPE_FROM_DSYTYP(IDSYTYP)
    # -------------------------------------------------
    # Constitution de la pièce jointe
    Call ITNINHTML([F:ITN]NUM, IASKITNHDTDON, 1, SZSCREENTYPE, "ITN_ITNASS", SZFULLFILENAME, SZFILENAME, ICHAPTER, IERR)
    If IERR Then
      SMESSAGE = mess(IERR,ICHAPTER,1)
      IARENDRE = [V]CST_ANO
    Else
      Raz S_ATTACHMENTS     # PJ
      S_ATTACHMENTS(1) = SZFULLFILENAME
    Endif
  Endif
End IARENDRE

###############################################################################################################
Funprog SEND_EMAIL(ACTX, SA_FROM, SA_USER, SCC_USER, SZEMAILSUBJECT, BODY, S_ATTACHMENTS, SMESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SA_FROM
Value Char SA_USER()(1..)
Value Char SCC_USER()(1..)
Value Char SZEMAILSUBJECT
Value Clbfile BODY
Value Char S_ATTACHMENTS()(1..)
Variable Char SMESSAGE

Local Integer ASTATUS
Local Integer IARENDRE

  # FGR 03/06/2015 : X3SUIVI108602
  # -------------------------------------------------
  IARENDRE = [V]CST_AYES
  Raz SMESSAGE
  # -------------------------------------------------
  ASTATUS = func ASYRMAIL.ASEND_MAIL(ACTX, SA_FROM, SA_USER, SCC_USER, SZEMAILSUBJECT, BODY, S_ATTACHMENTS, [V]CST_ANO)
  If [L]ASTATUS <> [V]CST_AOK Then
    SMESSAGE = mess(1163,196,1)
    IARENDRE = [V]CST_ANO
  Endif
End IARENDRE

###############################################################################################################
Subprog ITNINHTML(SZRECNUM, IHDTDON, IGENERICFILENAME, SZSCREENTYPE, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZRECNUM
Value Integer IHDTDON                  # FGR 03/06/2015 : X3SUIVI108602
Value Integer IGENERICFILENAME
Value Char SZSCREENTYPE
Value Char SZPECONTEXT
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF

############################################
#Variables particulières pour les réservations de ressources
Local Integer ITERRRS
Local Char SZSUBPROG(GLONADC)
Local Char SZAOBABREV(GLONAOB)

  ITERRRS = 0
  ICHAPTER = 0
  IERRINF = 0
  SZFULLRETFILE = ""
  SZRETFILENAME = ""
  If SZRECNUM = "" Then
    End
  Endif
  Gosub HTMLPART1 From CRMXML140
  Call TEXTE(14563, SZHTMLTITLE) From OBJDIV      #Intervention
  SZSUBPROG = "ITNINHTML"
  SZAOBABREV = "ITN"
  Gosub HTMLPART2 From CRMXML140
  If IERRINF Then
    End
  Endif
  Gosub DOCOREHTML
  Gosub HTMLPART3 From CRMXML140
End

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOCOREHTML
  Gosub SETITNEXCEPT From CRMEXCEPT
  Gosub SETSREEXCEPT From CRMEXCEPT
  Gosub SETBPREXCEPT From CRMEXCEPT
  Gosub SETBPCEXCEPT From CRMEXCEPT
  Gosub SETBPAEXCEPT From CRMEXCEPT
  Gosub SETRRSEXCEPT From CRMEXCEPT
  Gosub SETHDTEXCEPT From CRMEXCEPT
  ############################################
  # FGR 03/06/2015 : X3SUIVI108602 (début)
  #Surcharge ponctuel pour utilisation dans l'objet intervention (Envoi automatique sans saisie de destinataire)
  #If type(GIASKITNHDTDON) > 0 Then
  #  IHDTDON = GIASKITNHDTDON
  #Endif
  # FGR 03/06/2015 : X3SUIVI108602 (fin)
  ############################################
  #On extrait
  Filter [ITN] Where [F:ITN]NUM = SZRECNUM
  For [ITN]
    Gosub HTMLITN From CRMEXCEPT
    #Réservations de ressources
    If IDISPLAYRRS Then
      Gosub ADDRRS
    Endif
    #Consommations
    If IDISPLAYHDT Then
      Gosub ADDHDT
    Endif
    #Demande de service
    If IDISPLAYSRE Then
      Gosub ADDSRE
    Endif
    #Tiers
    If IDISPLAYBPR Then
      Gosub ADDBPR
    Endif
    #Client
    If IDISPLAYBPC Then
      Gosub ADDBPC
    Endif
    #Adresse
    If IDISPLAYBPA Then
      Gosub ADDBPA
    Endif
  Next
  Filter [ITN]
Return

##########################################################
# Demande de service
##########################################################
$ADDSRE
  Filter [SRE] Where [F:SRE]SRENUM = [F:ITN]SRVDEMNUM
  For [SRE]
    Gosub HTMLSRE From CRMEXCEPT
  Next
  Filter [SRE]
Return

##########################################################
# Tiers
##########################################################
$ADDBPR
  Filter [BPR] Where [F:BPR]BPRNUM = [F:ITN]BPC
  For [BPR]
    Gosub HTMLBPR From CRMEXCEPT
  Next
  Filter [BPR]
Return

##########################################################
# Client
##########################################################
$ADDBPC
  Filter [BPC] Where [F:BPC]BPCNUM = [F:ITN]BPC
  For [BPC]
    Gosub HTMLBPC From CRMEXCEPT
  Next
  Filter [BPC]
Return

##########################################################
# Adresse
##########################################################
$ADDBPA
  Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [F:ITN]BPC
  For [BPA]
    Gosub HTMLBPA From CRMEXCEPT
  Next
  Filter [BPA]
Return

##########################################################
# Réservations de ressources
##########################################################
$ADDRRS
  For ITERRRS = 0 To dim([F:ITN]RER)-1
    If [F:ITN]RER(ITERRRS) <> "" Then
      Read [RRS]RRS0=[F:ITN]RER(ITERRRS)
      If !fstat Then
        Gosub HTMLRRS From CRMEXCEPT
      Endif
    Endif
  Next
Return

##########################################################
# Consommations
##########################################################
$ADDHDT
  Filter [HDT] Where [F:HDT]ITNNUM = SZRECNUM and [F:HDT]TPL <> 2 and [F:HDT]HDTDONDAT = [00/00/00] Order By [F:HDT]HDTDONDAT Desc; [F:HDT]HDTDONHOU Desc
  For [HDT] Hint Key HDT2
    Gosub HTMLHDT From CRMEXCEPT
  Next
  Filter [HDT]
  If IHDTDON Then
    Filter [HDT] Where [F:HDT]ITNNUM = SZRECNUM and [F:HDT]TPL <> 2 and [F:HDT]HDTDONDAT <> [00/00/00] Order By [F:HDT]HDTDONDAT Desc; [F:HDT]HDTDONHOU Desc
    For [HDT] Hint Key HDT2
      Gosub HTMLHDT From CRMEXCEPT
    Next
    Filter [HDT]
  Endif
Return

