#Endif



Return

$CREATE_TAX_RECORD_KAQ

  Filter [F:ETA] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and TAXYEA= THISTAXYEAR

  Read [F:ETA]ETA0 Last

    If fstat
        Raz [F:ETA]

        Filter [F:CTRAFR] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and CTRDAT=[HRCTR]CTRDAT
        Read [F:CTRAFR]CTRAFR0 = [HRCTR]REFNUM; [HRCTR]CTRNUM;[HRCTR]CTRDAT

          If (fstat)
            OK=1
            Call ECR_TRACE("Error occurred reading contract information please correct contract. " + " Employee ID:" +  [HRCTR]REFNUM  + " Contract chrono:" + [HRCTR]CTRNUM  +" Date " + [HRCTR]CTRDAT
& ,
& 0)
& From GESECRAN

            Return
          Endif

          [F:ETA]XITDAT=[HRCTR]XITDAT
          [F:ETA]TAXYEA = THISTAXYEAR
          [F:ETA]=[F:CTRAFR]
          [F:ETA]YEAENDRUNIND=YEAENDRUNIND
          [F:ETA]CRETAXRECIND=2
          [L]TAX_RECORDS_CREATED+=1
        Write [F:ETA]

     Else
        [L]CERNUM = [F:ETA]CERNUMENDAFR

        Delete [F:ETA] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM  and TAXYEA=THISTAXYEAR

        Filter [F:CTRAFR] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and CTRDAT=[HRCTR]CTRDAT
        Read [F:CTRAFR]CTRAFR0 = [HRCTR]REFNUM; [HRCTR]CTRNUM;[HRCTR]CTRDAT

          If (fstat)
            OK=1
            Call ECR_TRACE("Error occurred reading contract information please correct contract. " + " Employee ID:" +  [HRCTR]REFNUM  + " Contract chrono:" + [HRCTR]CTRNUM  +" Date " + [HRCTR]CTRDAT
& ,
& 0)
& From GESECRAN

            Return
          Endif

          [F:ETA]CERNUMENDAFR=[L]CERNUM
          [F:ETA]TAXYEA = THISTAXYEAR
          [F:ETA]XITDAT=[HRCTR]XITDAT
          [F:ETA]YEAENDRUNIND=YEAENDRUNIND
          [F:ETA]CRETAXRECIND=2
          [F:ETA]=[F:CTRAFR]
          #[L]TAX_RECORDS_CREATED+=1
          Write [F:ETA]
     Endif

      If fstat
        OK=1
        Call ECR_TRACE("Error creating employee tax record. Please correct and try again." + " Employee ID:" +  [HRCTR]REFNUM  + " Contract chrono:" + [HRCTR]CTRNUM  +" Date " + [HRCTR]CTRDAT ,0) From
& GESECRAN
        End
      Endif



Return

$CREATE_TAX_RECORD_KZA
  Filter [F:ETR]
  Filter [CTRSA]

  Read [CTRSA]CTRSA0 = [HRCTR]REFNUM; [HRCTR]CTRNUM; [HRCTR]CTRDAT

  If (fstat)
     OK=1
     Call ECR_TRACE("Error occurred reading contract information please correct contract. " + " Employee ID:" +  [HRCTR]REFNUM  + " Contract chrono:" + [HRCTR]CTRNUM  +" Date " + [HRCTR]CTRDAT ,0)
& From
& GESECRAN
    Return
  Endif

#delete existing tax recoerd fields
  Filter  [F:ETR] Where  REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and TAXYEA=THISTAXYEAR
  Read [F:ETR]ETR0 Last


  If fstat
    Raz [F:ETR]

    [F:ETR]=[HRCTR]
    [F:ETR]TAXYEA=THISTAXYEAR
    [F:ETR]=[CTRSA]
    [F:ETR]YEAENDRUNIND=YEAENDRUNIND
    [F:ETR]CRETAXRECIND=2
    Write [F:ETR]
    [L]TAX_RECORDS_CREATED+=1

  Else

      [F:ETR]=[HRCTR]
      [F:ETR]TAXYEA=THISTAXYEAR
      [F:ETR]=[CTRSA]
      [F:ETR]YEAENDRUNIND=YEAENDRUNIND
      [F:ETR]CRETAXRECIND=2
      Rewrite [F:ETR]
  Endif

      If fstat
        OK=0
Call ECR_TRACE("Error creating employee tax record. Please correct and try again." + " Employee ID:" +  [HRCTR]REFNUM  + " Contract chrono:" + [HRCTR]CTRNUM  +" Date " + [HRCTR]CTRDAT ,0) From
& GESECRAN
        Return
      Endif

Return

$TR3
  Commit

#display success message
  Call ECR_TRACE(string$(100, "-"), 0) From GESECRAN
  Call ECR_TRACE("Process completed successfully." ,0) From GESECRAN

Return

$BOUTON

#set trace file
  TIT="Tax record program"


  Local Integer THISTAXYEAR
  Gosub DECLARATION
    OK=1
  [L]NO_EMP_UPDATED=0
  [L]TAX_RECORDS_CREATED=0

   YESNO = 2
    Call OUINON("This will only create tax records for the current tax year. It will NOT perform a tax year end run. Continue?", YESNO) From GESECRAN
    If YESNO<>2
      OK=0
      Call ECR_TRACE("Process aborted by user." ,0) From GESECRAN
      Return
    Endif

Gosub BEGINTRAN
      #loop contracts and perform uppdates

    Link    [HRCTR]
&     With  [FCY]FCY0 = [HRCTR]ETRFCY
&     As    [LNK2]
&   Where   [FCY]LEGCPY=[M:HRYEP]CPY


     [L] YEAENDRUNIND=1
     [L]THISTAXYEAR=year([M:HRYEP]ENDDATOLD)

    For [LNK2]
      Gosub GETEXTRACTION
      [L]THISTAXYEAR=year(OLDDTAXEND)
      If  ([HRCTR]CTRDAT<=OLDDTAXEND  & ([HRCTR]XITDAT>=OLDDTAXSTR| [HRCTR]XITDAT=[0/0/0]))

            If func DIVPAYE.IS_AFRICA_LEG(GCURLEG) & GCURLEG <> 'ZAF' Then   # Africa
              Gosub CREATE_TAX_RECORD_KAQ
            Endif

            If func DIVPAYE.IS_KZA(GCURLEG) Then
              Gosub CREATE_TAX_RECORD_KZA
            Endif
       Endif
    Next

Commit


  Infbox(num$([L]TAX_RECORDS_CREATED)-"Tax records created.")
#  FIN=1
#  OK=1
  Return
#ADNGO - 2017-05-15 - JIRA X3-36435 - END

