#<AdxTL>@(#)0.0.0.0 $Revision$
#ADNGO - 2017-05-15 - JIRA X3-36435 - START
$ACTION
  Case [L]ACTION
    When "INIT"       : Gosub INIT
    When "DEBUT"      : Gosub DEBUT
    When "CONTROLE"   : Gosub CONTROLE
    When "EXEC"       : Gosub EXEC
    When "OK"         : Gosub OK
    When "END"        : FIN = 1
    When "BOUTON"     : Gosub BOUTON
  Endcase
Return

$INIT
  Gosub OUVFIC

#open screens
  Local Mask GENHRYEP [HRYEP] : Raz [HRYEP]
  Gosub DECLARATION

Return

#open files
$OUVFIC
  If clalev([F:VEP])=0      : Local File VALEMP      [VEP]    : Endif
  If clalev([F:FCY])=0      : Local File FACILITY    [FCY]    : Endif
  #ADNGO - 2017-05-15 - JIRA X3-36435 - START
  #If clalev([F:CTR])=0      : Local File EMPLOCTR    [CTR]    : Endif
  If clalev([F:HRCTR])=0      : Local File EMPLOCTR    [HRCTR]    : Endif
  #ADNGO - 2017-05-15 - JIRA X3-36435 - END
  If clalev([F:ADW]) = 0    : Local File ADOVAL      [ADW]    : Endif
  If clalev([F:ID]) = 0    : Local File EMPLOID      [ID]    : Endif

  If clalev([F:HRPEOH]) = 0    : Local File HRPEOHEA      [HRPEOH]    : Endif

  #ADNGO - 2017-05-15 - JIRA X3-36435 - START
  #If func AFNC.ACTIV("KAQ")>0 Then   # Africa
  If func AFNC.ACTIV("KAFR")>0
  #ADNGO - 2017-05-15 - JIRA X3-36435 - END
      If clalev([F:ETA]) = 0    : Local File EMPLOTAXAFR [ETA]    : Endif
      If clalev([F:CTRAFR]) = 0 : Local File EMPLOCTRAFR [CTRAFR] : Endif
  Endif
  #ADNGO - 2017-05-15 - JIRA X3-36435 - START
  #If func AFNC.ACTIV("KZA")>0 Then   # South Africa


  If func AFNC.ACTIV("FZAPH")>0
  #ADNGO - 2017-05-15 - JIRA X3-36435 - END
      If clalev([F:CTRSA])=0    : Local File EMPLOCTRSA  [CTRSA]  : Endif
      If clalev([F:ETR]) = 0    : Local File EMPLOTAXREC [ETR]    : Endif
  Endif


Return

#populate screens on startup
$DEBUT
  Gosub POPULATE_WINDOW

Return

#populate screens on startup
$POPULATE_WINDOW


Return

#declarations for process
$DECLARATION


Local Integer THISTAXYEAR, YESNO,YEAENDRUNIND,COUNTER
Local Integer NO_EMP_UPDATED, TAX_RECORDS_CREATED
Local Char CERNUM(200)
Local Integer RECOUNDRUNIND
Local Integer EXTRACTIONPERIOD
Local Char EXTRACTIONPERIODNAME(200)(0..)
Local Integer FUTUREPRECOD


Return

$CONTROLE
  If GSTATUT<>GSTAOK
   FIN = 1
  Else
   TMP = 1
   TRA = 1
  Endif

Return

$OK
  FIN = 1 : GOK = 1

Return


$GETKZACONTRACTS

Filter [F:ETR]
For [LNK9]

  Gosub GETEXTRACTION

  If  ([HRCTR]CTRDAT<=OLDDTAXEND  & ([HRCTR]XITDAT>=OLDDTAXSTR| [HRCTR]XITDAT=[0/0/0]))
    Filter [F:ETR] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and TAXYEA=year(OLDDTAXEND)

    For [F:ETR]
      Read [F:ETR]ETR0 Last # = [CTR]REFNUM;[CTR]CTRNUM;[CTR]CTRDAT;THISTAXYEAR #check if tax record created
       If (!fstat) Then
         If  [F:ETR]YEAENDRUNIND<>2 Then
           RECOUNDRUNIND = 0 #check that it was already run for this employee
         Endif
       Else
           RECOUNDRUNIND = 0 #record doesnt exsit so have to create it
       Endif
     Next
  Endif
Next

If rowcount([F:ETR]) = 0 :RECOUNDRUNIND = 0 :Endif #No tax records exsit have to create them
Return


$GETKAQCONTRACTS
Filter [F:ETA]

For [LNK9]

    Gosub GETEXTRACTION

    If  ([HRCTR]CTRDAT<=OLDDTAXEND  & ([HRCTR]XITDAT>=OLDDTAXSTR| [HRCTR]XITDAT=[0/0/0]))

      Filter [F:ETA] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and TAXYEA= year(OLDDTAXEND)

      If rowcount([F:ETA]) = 0 :RECOUNDRUNIND = 0 :  Endif #No tax records exsit have to create them

      For [F:ETA]
        Read [F:ETA]ETA0 Last #= [CTR]REFNUM;[CTR]CTRNUM;[CTR]CTRDAT;THISTAXYEAR #check if tax record created
         If (!fstat) Then
           If  [F:ETA]YEAENDRUNIND<>2 Then
             RECOUNDRUNIND = 0 #check that it was already run for this employee
           Endif
         Else
             RECOUNDRUNIND = 0 #record doesnt exsit so have to create it
         Endif
       Next


    Endif

Next



Return



$GETEXTRACTIONPERIODS

Local Integer NEXTPERIOD

FUTUREPRECOD = 0
Filter [F:HRPEOH]

For [LNK9]

  Gosub GETEXTRACTION
  Filter [F:HRPEOH]

  If  ([HRCTR]CTRDAT<=OLDDTAXEND  & ([HRCTR]XITDAT>=OLDDTAXSTR| [HRCTR]XITDAT=[0/0/0]))
      NEXTPERIOD = year(OLDDTAXEND) + 1

    Filter [F:HRPEOH] Where  PERCOD=[HRCTR]PERCOD and PERYEA=NEXTPERIOD
    Read [F:HRPEOH]HRPEOH0 Last

    If (fstat) Then

      EXTRACTIONPERIODNAME(FUTUREPRECOD) = [HRCTR]PERCOD
      FUTUREPRECOD = FUTUREPRECOD + 1
    Endif
    Filter [F:HRPEOH]
  Endif

Next


Return


$GETEXTRACTION

Local Date OLDDTAXSTR, OLDDTAXEND,NEWDTAXSTR, NEWDTAXEND
Local Integer PERYEAEXT

# Filter [F:CTRSA]  Where  [CTRSA]REFNUM=[HRCTR]REFNUM  and [CTRSA]CTRNUM=[HRCTR]CTRNUM and [CTRSA]CTRDAT=[HRCTR]CTRDAT and [CTRSA]MANIRP=1
# Read [F:CTRSA]CTRSA0 = [HRCTR]REFNUM; [HRCTR]CTRNUM; [HRCTR]CTRDAT


  Filter [F:HRPEOH]
  Filter [F:HRPEOH] Where  PERCOD=[HRCTR]PERCOD and FLGENA=2
  Read [F:HRPEOH]HRPEOH0 Last

  OLDDTAXSTR = [F:HRPEOH]CYCSTRDAT
  OLDDTAXEND = [F:HRPEOH]CYCENDDAT
  PERYEAEXT = [F:HRPEOH]PERYEA

  Filter [F:HRPEOH]
  Filter [F:HRPEOH] Where  PERCOD=[HRCTR]PERCOD and PERYEA=PERYEAEXT + 1
  Read [F:HRPEOH]HRPEOH0 Last

  If (!fstat) Then
    NEWDTAXSTR = [F:HRPEOH]CYCSTRDAT
    NEWDTAXEND = [F:HRPEOH]CYCENDDAT
  Endif


Return

$EXEC

#If func AFNC.ACTIV("KAQ")>0 Then
#Gosub EXEC From GENHRYEP2
#Return
#Endif

#set trace file
  TIT="Year end program"
  Call OUVRE_TRACE(TIT) From LECFIC

#TRACE HEADING
  Call ECR_TRACE(TIT,0) From GESECRAN
  Call ECR_TRACE(string$(100, "-"), 0) From GESECRAN
  Call ECR_TRACE("Run date:"-num$(date$),0) From GESECRAN
  Call ECR_TRACE(string$(100, "-"), 0) From GESECRAN

  OK=1
  [L]NO_EMP_UPDATED=0
  [L]TAX_RECORDS_CREATED=0
  [L]YEAENDRUNIND=2

    SCOUNT =0
    YESNO = 2
    OK=1

 #[L]THISTAXYEAR=year([M:HRYEP]ENDDATOLD)


#ADNGO - 2017-05-15 - JIRA X3-36435 - START
#    Link    [CTR]
#&     With  [FCY]FCY0 = [CTR]ETRFCY
#&     As    [LNK9]
#&   Where   ([CTR]CTRDAT<=[M:HRYEP]ENDDATOLD & ([CTR]XITDAT>=[M:HRYEP]STRDATOLD| [CTR]XITDAT=[0/0/0]))
#& &         [FCY]LEGCPY=[M:HRYEP]CPY
#    Link    [HRCTR]
#&     With  [FCY]FCY0 = [HRCTR]ETRFCY
#&     As    [LNK9]
#&   Where   ([HRCTR]CTRDAT<=[M:HRYEP]ENDDATOLD & ([HRCTR]XITDAT>=[M:HRYEP]STRDATOLD| [HRCTR]XITDAT=[0/0/0]))
#& &         [FCY]LEGCPY=[M:HRYEP]CPY
#ADNGO - 2017-05-15 - JIRA X3-36435 - END

#First get all contracts from the company
#Get the extraction period
#Get the dates of the extraction period
#Condition if contract needs to get updated.

#Start here
    Link    [HRCTR]
&     With  [FCY]FCY0 = [HRCTR]ETRFCY
&     As    [LNK9]
&   Where    [FCY]LEGCPY=[M:HRYEP]CPY



#For [LNK9]
#  Gosub GETEXTRACTION
#
#  If  ([HRCTR]CTRDAT<=OLDDTAXEND  & ([HRCTR]XITDAT>=OLDDTAXSTR| [HRCTR]XITDAT=[0/0/0]))
#
#  Endif
#Next



RECOUNDRUNIND = 1
EXTRACTIONPERIOD = 1


  If func DIVPAYE.IS_AFRICA_LEG(GCURLEG) Then   # Africa
    Gosub GETKAQCONTRACTS
  Endif

  If func DIVPAYE.IS_KZA(GCURLEG)Then   # South Africa
    Gosub GETKZACONTRACTS
  Endif





If RECOUNDRUNIND = 1  Then
  Call ECR_TRACE("A tax year end run is already performed for this company" ,0) From GESECRAN
  Call ECR_TRACE("Process aborted." ,0) From GESECRAN
  FIN=1
  Return
Endif


Gosub GETEXTRACTIONPERIODS


If FUTUREPRECOD > 0 Then
    Call ECR_TRACE("The follow extraction periods do not have record for the next cycle" ,0) From GESECRAN

    For COUNTER = 0 To dim(FUTUREPRECOD) - 1
      Call ECR_TRACE(num$(EXTRACTIONPERIODNAME(COUNTER)) ,0) From GESECRAN
    Next

    Call ECR_TRACE("Process aborted." ,0) From GESECRAN
    FIN=1
    Return
Endif


    Call OUINON("This will create tax records for the current tax year and perform a tax year end run. Continue?", YESNO
& ) From GESECRAN
    If YESNO<>2
      OK=0
      Call ECR_TRACE("Process aborted by user." ,0) From GESECRAN
      Return
    Endif



 If OK
    Gosub TR1
   If OK
      Gosub TR2
      If OK
        Gosub TR3
      Endif
    Endif


    If !OK
    #rollback udates
      Rollback
      [L]NO_EMP_UPDATED=0
      [L]TAX_RECORDS_CREATED=0
    #display aborted message
      Call ECR_TRACE(string$(100, "-"), 0) From GESECRAN
      Call ECR_TRACE("Process aborted." ,0) From GESECRAN
    Endif
 Else
  #display aborted message
    Call ECR_TRACE("Process aborted." ,0) From GESECRAN
 Endif

#display number of updates
  Call ECR_TRACE(string$(100, "-"), 0) From GESECRAN
  Call ECR_TRACE(num$([L]NO_EMP_UPDATED)-"Employees tax cycle dates updated on contracts." ,0) From GESECRAN
  Call ECR_TRACE(num$([L]TAX_RECORDS_CREATED)-"Tax records created." ,0) From GESECRAN
  Call ECR_TRACE(string$(100, "-"), 0) From GESECRAN

  Call FERME_TRACE From LECFIC

Return

$BEGINTRAN
#ADNGO - 2017-05-15 - JIRA X3-36435 - START
#If func AFNC.ACTIV("KAQ")>0 Then   # Africa
If func DIVPAYE.IS_AFRICA_LEG(GCURLEG) Then   # Africa
#ADNGO - 2017-05-15 - JIRA X3-36435 - END
 Trbegin [CTRAFR], [ETA], [ADW]
Endif
#ADNGO - 2017-05-15 - JIRA X3-36435 - START
#If func AFNC.ACTIV("KZA")>0 Then   # South Africa
If func DIVPAYE.IS_KZA(GCURLEG) Then   # South Africa
#ADNGO - 2017-05-15 - JIRA X3-36435 - END
  Trbegin [CTRSA], [ETR], [ADW]
Endif

Return


$SHOWWARNINGMSG



If YEPCPYCOUNT> 0  and VEPTOTCOUNT > 0  Then
Call OUINON("There are " + num$(YEPCPYCOUNT) + " payslip(s) that have not been posted for company  " +[M:HRYEP]CPY +
& " and " + num$(VEPTOTCOUNT) + " for other companies. Do you want to continue?" ,
& YESNO) From GESECRAN

Else
  If VEPTOTCOUNT > 0 Then
   Call OUINON("There are  " + num$(VEPTOTCOUNT) +
& " payslip(s) that have not been posted for other companies. Do you want to continue?"
& , YESNO) From GESECRAN
  Else
   If YEPCPYCOUNT> 0 Then
Call OUINON("There are " + num$(YEPCPYCOUNT) + " payslip(s) that have not been posted for company  " +[M:HRYEP]CPY +
& ". Do you want to continue?" ,
& YESNO) From GESECRAN
   Endif
  Endif


Endif



   Call OUINON(
& "Please note that if cycle parameters are updated, it will prevent posting of payslips at a later stage. Ensure all processing has been finalized before continuing with the Year end process."  +
& "Would you like to continue?"
& , YESNO) From GESECRAN



Return

$WARNINGMSG

Local Integer VEPTOTCOUNT, YEPCPYCOUNT
 YESNO = 2
 VEPTOTCOUNT = 0
 YEPCPYCOUNT = 0

  Filter [VEP]
&   Where [VEP]PYRDAT>=[M:HRYEP]STRDATOLD
& &       [VEP]PYRDAT<=[M:HRYEP]ENDDATOLD
& &       [VEP]PST<2

 VEPTOTCOUNT = rowcount([VEP])

  #check for open payslips
    Link    [VEP]
&     With  [FCY]FCY0 = [VEP]FCY
&     As    [LNK]
&   Where   [VEP]PYRDAT>=[M:HRYEP]STRDATOLD
& &         [VEP]PYRDAT<=[M:HRYEP]ENDDATOLD
& &         [VEP]PST<2
& &         [FCY]LEGCPY=[M:HRYEP]CPY


YEPCPYCOUNT = rowcount([LNK])

VEPTOTCOUNT= VEPTOTCOUNT - YEPCPYCOUNT

Gosub SHOWWARNINGMSG

    If YESNO<>2
      OK=0
      Call ECR_TRACE(string$(100, "-"), 0) From GESECRAN
      Call ECR_TRACE("Abort by user." ,0) From GESECRAN
      Call ECR_TRACE(string$(100, "-"), 0) From GESECRAN
      Call ECR_TRACE("", 0) From GESECRAN
      Return
#    Else
#      Infbox("Please note that if cycle parameters are updated, it will prevent posting of payslips at a later stage.")
    Endif


Return

$TR1

Gosub BEGINTRAN
Gosub WARNINGMSG

Return

$UPDATECYCLEPARAM
    #update tax start date parameters
      Update [ADW]
&     Where  PARAM="TAXSTRDAT" and FCY=GCURLEG
&     With   VALEUR=format$("D:YYYYMMDD",[M:HRYEP]STRDATNEW)
      If fstat
        OK=0
        Call ECR_TRACE("Error updating tax start date parameters." ,0) From GESECRAN
        Return
      Endif
    #update tax end date parameters
      Update [ADW]
&     Where  PARAM="TAXENDDAT" and FCY=GCURLEG
&     With   VALEUR=format$("D:YYYYMMDD",[M:HRYEP]ENDDATNEW)
      If fstat
        OK=0
        Call ECR_TRACE("Error updating tax end date parameters." ,0) From GESECRAN
        Return
      Endif

Return


$UPDATEKZACONTRACTS

#Local Date OLDDTAXSTR, OLDDTAXEND,NEWDTAXSTR, NEWDTAXEND
#
Filter [F:CTRSA]

 Filter [F:CTRSA]  Where  [CTRSA]REFNUM=[HRCTR]REFNUM  and [CTRSA]CTRNUM=[HRCTR]CTRNUM and [CTRSA]CTRDAT=[HRCTR]CTRDAT and [CTRSA]MANIRP=1
 Read [F:CTRSA]CTRSA0 = [HRCTR]REFNUM; [HRCTR]CTRNUM; [HRCTR]CTRDAT
#
#
#  Filter [F:HRPEOH]
#  Filter [F:HRPEOH] Where  PERCOD=[HRCTR]PERCOD and PERYEA=THISTAXYEAR
#  Read [F:HRPEOH]HRPEOH0 Last
#
#  OLDDTAXSTR = [F:HRPEOH]CYCSTRDAT
#  OLDDTAXEND = [F:HRPEOH]CYCENDDAT
#
#
#  Filter [F:HRPEOH]
#  Filter [F:HRPEOH] Where  PERCOD=[HRCTR]PERCOD and PERYEA=THISTAXYEAR + 1
#  Read [F:HRPEOH]HRPEOH0 Last
#
#  NEWDTAXSTR = [F:HRPEOH]CYCSTRDAT
#  NEWDTAXEND = [F:HRPEOH]CYCENDDAT


  [F:CTRSA]IRPSTRDAT=max(NEWDTAXSTR,[F:CTRSA]IRPSTRDAT)

  If  [HRCTR]XITDAT<>[0/0/0] and   [HRCTR]XITFNL=2 and [HRCTR]XITDAT < NEWDTAXEND Then
     [F:CTRSA]IRPENDDAT=max(OLDDTAXEND,[HRCTR]XITDAT)
   Else
     [F:CTRSA]IRPENDDAT=max(NEWDTAXEND,[HRCTR]XITDAT)
 Endif

  If [HRCTR]CTRDAT < NEWDTAXSTR Then
         Gosub RESETZAFSTATUS

  Endif
 Rewrite [F:CTRSA]



      If fstat
        OK=0

        Call ECR_TRACE("Error occurred reading contract information please correct contract. " + " Employee ID:" +  [HRCTR]REFNUM  + " Contract chrono:" + [HRCTR]CTRNUM  +" Date " + [HRCTR]CTRDAT ,0)
& From GESECRAN

      Endif

#      Update [CTRSA]
#&       Where  [CTRSA]REFNUM=[HRCTR]REFNUM and [CTRSA]CTRNUM=[HRCTR]CTRNUM and [CTRSA]CTRDAT=[HRCTR]CTRDAT
#& &            find([CTRSA]TAXSTA,2,16,17)>0
#&       With   [CTRSA]TAXSTA=1
#& ,            [CTRSA]TAXDIRNUM=""
#& ,            [CTRSA]TAXDIRAMT=0
#& ,            [CTRSA]TAXDIRPRC=0
#      If fstat
#        OK=0
#
#            Call ECR_TRACE("Error occurred reading contract information please correct contract. " + " Employee ID:" +  [HRCTR]REFNUM  + " Contract chrono:" + [HRCTR]CTRNUM  +" Date " + [HRCTR]CTRDAT
# ,
#& 0)
#& From GESECRAN
#      Endif
    #increment counter
      NO_EMP_UPDATED+=1
Return



$RESETZAFSTATUS

    If [F:CTRSA]TAXSTA = 2 or [F:CTRSA]TAXSTA = 16 or [F:CTRSA]TAXSTA = 17 Then
       [F:CTRSA]TAXSTA=1
       [F:CTRSA]TAXDIRNUM=""
       [F:CTRSA]TAXDIRAMT=0
       [F:CTRSA]TAXDIRPRC=0
    Endif

Return



$RESETAFRSTATUS
#ADNGO - 2017-05-15 - JIRA X3-36435 - START
#If func AFNC.ACTIV("KBW")>0 Then   #Botswana
If func DIVPAYE.IS_KBW_LEG(GCURLEG) Then   #Botswana
#ADNGO - 2017-05-15 - JIRA X3-36435 - END

    If [F:CTRAFR]TAXSTAAFR=9 Then
       [F:CTRAFR]TAXSTAAFR=6
      Raz [F:CTRAFR]DIRAMT
      Raz [F:CTRAFR]DIRNUM
      Raz [F:CTRAFR]DIRPRC
    Endif
Endif

#ADNGO - 2017-05-15 - JIRA X3-36435 - START
#If func AFNC.ACTIV("KLES")>0 Then   #Lesotho
If func DIVPAYE.IS_KLS_LEG(GCURLEG) Then   #Lesotho
#ADNGO - 2017-05-15 - JIRA X3-36435 - END
  If [F:CTRAFR]TAXSTAAFR=9 Then
     [F:CTRAFR]TAXSTAAFR=6

      Raz [F:CTRAFR]DIRAMT
      Raz [F:CTRAFR]DIRNUM
      Raz [F:CTRAFR]DIRPRC
  Endif
Endif

#ADNGO - 2017-05-15 - JIRA X3-36435 - START
#If func AFNC.ACTIV("KNA")>0 Then   #Nambia
If func DIVPAYE.IS_KNA_LEG(GCURLEG)   #Nambia
#ADNGO - 2017-05-15 - JIRA X3-36435 - END
  If [F:CTRAFR]TAXSTAAFR=9 Then
     [F:CTRAFR]TAXSTAAFR=1
      Raz [F:CTRAFR]DIRAMT
      Raz [F:CTRAFR]DIRNUM
      Raz [F:CTRAFR]DIRPRC
  Endif

Endif
#ADNGO - 2017-05-15 - JIRA X3-36435 - START
#If func AFNC.ACTIV("KSZ")>0 Then   #Swaziland
If func DIVPAYE.IS_KSZ_LEG(GCURLEG) Then   #Swaziland
#ADNGO - 2017-05-15 - JIRA X3-36435 - END
  If [F:CTRAFR]TAXSTAAFR=9 or  [F:CTRAFR]TAXSTAAFR=2 Then
     [F:CTRAFR]TAXSTAAFR=1
     Raz [F:CTRAFR]DIRAMT
     Raz [F:CTRAFR]DIRNUM
     Raz [F:CTRAFR]DIRPRC
  Endif

Endif

Return



$UPDATEKAQCONTRACTS
#Local Date OLDDTAXSTR, OLDDTAXEND,NEWDTAXSTR, NEWDTAXEND

 Filter [F:CTRAFR]


 Filter [F:CTRAFR]  Where  [CTRAFR]REFNUM=[HRCTR]REFNUM  and [CTRAFR]CTRNUM=[HRCTR]CTRNUM and [CTRAFR]CTRDAT=[HRCTR]CTRDAT
 Read [F:CTRAFR]CTRAFR0 = [HRCTR]REFNUM; [HRCTR]CTRNUM; [HRCTR]CTRDAT
#
#  Filter [F:HRPEOH]
#  Filter [F:HRPEOH] Where  PERCOD=[HRCTR]PERCOD and PERYEA=THISTAXYEAR
#  Read [F:HRPEOH]HRPEOH0 Last
#
#  OLDDTAXSTR = [F:HRPEOH]CYCSTRDAT
#  OLDDTAXEND = [F:HRPEOH]CYCENDDAT
#
#
#  Filter [F:HRPEOH]
#  Filter [F:HRPEOH] Where  PERCOD=[HRCTR]PERCOD and PERYEA=THISTAXYEAR + 1
#  Read [F:HRPEOH]HRPEOH0 Last
#
#
#  NEWDTAXSTR = [F:HRPEOH]CYCSTRDAT
#  NEWDTAXEND = [F:HRPEOH]CYCENDDAT


 [F:CTRAFR]TAXSTRDAT=max(NEWDTAXSTR,[F:CTRAFR]TAXSTRDAT)

  If  [HRCTR]XITDAT<>[0/0/0] and  [HRCTR]XITFNL=2 and [HRCTR]XITDAT < NEWDTAXEND Then
     [F:CTRAFR]TAXENDDAT=max(OLDDTAXEND,[HRCTR]XITDAT)
   Else
     [F:CTRAFR]TAXENDDAT=max(NEWDTAXEND,[HRCTR]XITDAT)
  Endif



  Filter [F:ETA] Where REFNUM=[HRCTR]REFNUM and CTRNUM=[HRCTR]CTRNUM and TAXYEA= [L]THISTAXYEAR
  Read [F:ETA]ETA0 Last


    If (!fstat)
     If [HRCTR]CTRDAT < NEWDTAXSTR Then
       Gosub RESETAFRSTATUS
     Endif
    Endif

 Filter [F:ETA]

  Rewrite [F:CTRAFR]

      If fstat
        OK=1
            Call ECR_TRACE("Error occurred reading contract information please correct contract. " + " Employee ID:" +  [HRCTR]REFNUM  + " Contract chrono:" + [HRCTR]CTRNUM  +" Date " + [HRCTR]CTRDAT
& ,
& 0)
& From GESECRAN
        Return
      Endif

    #increment counter
      NO_EMP_UPDATED+=1

Return


$TR2


    Link    [HRCTR]
&     With  [FCY]FCY0 = [HRCTR]ETRFCY,[ID]ID0 = [HRCTR]REFNUM
&     As    [LNK2]
&   Where   [FCY]LEGCPY=[M:HRYEP]CPY & [F:ID]FLGNEWSAL <> 2





    For [LNK2]

    Gosub GETEXTRACTION
    THISTAXYEAR = year(OLDDTAXEND)


        If  ([HRCTR]CTRDAT<=OLDDTAXEND  & ([HRCTR]XITDAT>=OLDDTAXSTR | [HRCTR]XITDAT=[0/0/0]))


            If func DIVPAYE.IS_AFRICA_LEG(GCURLEG) Then   # Africa
              Gosub CREATE_TAX_RECORD_KAQ
            Endif

            If func DIVPAYE.IS_KZA(GCURLEG) Then   # South Africa
              Gosub CREATE_TAX_RECORD_KZA
            Endif

            If !OK
              Return
            Endif

        Endif

    Next



    Link    [HRCTR]
&     With  [FCY]FCY0 = [HRCTR]ETRFCY,[ID]ID0 = [HRCTR]REFNUM
&     As    [LNK2]
&   Where   [FCY]LEGCPY=[M:HRYEP]CPY & [F:ID]FLGNEWSAL <> 2


    For [LNK2]
       Gosub GETEXTRACTION

      If [HRCTR]CTRDAT<= NEWDTAXEND & ([HRCTR]XITDAT>=NEWDTAXSTR| [HRCTR]XITDAT=[0/0/0])

         [L]THISTAXYEAR=year(OLDDTAXEND)

        If func DIVPAYE.IS_AFRICA_LEG(GCURLEG) Then   # Africa
          Gosub UPDATEKAQCONTRACTS
        Endif

        If func DIVPAYE.IS_KZA(GCURLEG) Then   # South Africa
          Gosub UPDATEKZACONTRACTS
        Endif



      #create tax record for the new tax year for each active contract
       [L]THISTAXYEAR=year(NEWDTAXEND)
       [L]YEAENDRUNIND = 1

        If func DIVPAYE.IS_AFRICA_LEG(GCURLEG)  Then   # Africa
          Gosub CREATE_TAX_RECORD_KAQ
        Endif

        If func DIVPAYE.IS_KZA(GCURLEG) Then   # South Africa
          Gosub CREATE_TAX_RECORD_KZA
        Endif
        If !OK
          Return
        Endif

      Endif
 Next



#   [L]THISTAXYEAR=year([M:HRYEP]ENDDATOLD) #check if all companys applied for the year


#    Link    [HRCTR]
#&     With  [FCY]FCY0 = [HRCTR]ETRFCY ,[ID]ID0 = [HRCTR]REFNUM
#&     As    [LNK9]
#&   Where   [F:ID]FLGNEWSAL <> 2
#
#
#     Gosub GETEXTRACTION
