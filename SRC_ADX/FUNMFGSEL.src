########################################
Subprog S_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
Call SELECT("ITM","",VALEUR,"") From SELOBJ
End

########################################
Subprog S_ITMREFFIN(VALEUR)
Variable Char    VALEUR()
Call SELECT("ITM","",VALEUR,"") From SELOBJ
End

########################################
Subprog S_VCRNUMDEB(VALEUR)
Variable Char    VALEUR()
Call SELECT("SOH","",VALEUR,"") From SELOBJ
End

########################################
Subprog S_VCRNUMFIN(VALEUR)
Variable Char    VALEUR()
Call SELECT("SOH","",VALEUR,"") From SELOBJ
End

########################################
Subprog C_TYPDENFIN(VALEUR)
Variable Integer VALEUR
If VALEUR > [M]TYPDENDEB : mkstat = 2 : Endif
End

########################################
Subprog C_MFGPIOFIN(VALEUR)
Variable Decimal VALEUR
If VALEUR > [M]MFGPIODEB : mkstat = 2 : Endif
End

