#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PJMBUD
###################################################################################################
# EVENTS
###################################################################################################
$AINSERT_CONTROL_BEFORE
#Local Char SSEPARCODE(1)
Local Integer IRET
Local Integer IERROR
Local Integer IMANUAL
Local Char SMESSAGE(250)
Local Char SCOMPTEUR(GLONANM)
Local Char SNUMERO(type(this.PBUNUM)-10)
Local Char SCPY(GLONCPY)

  [L]ASTATUS = [V]CST_AOK
  # ---------------------
  this.PIMPL.OPPNUM = this.OPPNUM
  this.PIMPL.PBUCOD = this.PBUCOD
  this.PIMPL.TASCOD = ""
  SCPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.PBUFCY,"LEGCPY")
  Call READ_COUNTER(this.ACTX, 9, 13, SCPY, SCOMPTEUR, IMANUAL, SMESSAGE, IERROR) From CRM_UTIL_SYRA
  If IERROR = [V]CST_AYES Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", SMESSAGE, [V]CST_AERROR))
    Return
  Endif
  If SCOMPTEUR = AVOID.ACHAR Then
    [L]ASTATUS = fmet this.SETERROR("", mess(366,2260,1), [V]CST_AERROR)
    Return
  Endif
  # Appel du compteur de numérotation
  IRET = func ANM_TOOL.NUMERO(this.ACTX, SCOMPTEUR, this.PBUFCY, date$, "", SNUMERO, SMESSAGE)
  If IRET = [V]CST_AERROR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(22,7770,1) - "(" + SCOMPTEUR + ") :" - SMESSAGE, [V]CST_AERROR))
    Return
  Endif
  this.PBUNUM = SNUMERO
  Gosub AINSERT_AUPDATE_CONTROL_BEFORE
Return

###################################################################################################
$AUPDATE_CONTROL_BEFORE
  [L]ASTATUS = [V]CST_AOK
  # ---------------------
  If this.PBUSTATE = 4 and this.TCHACTION <> "CLOSING" and this.TCHACTION <> "STATUS" Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(982,2260,1), mess(this.PBUSTATE,2251,1)), [V]CST_AERROR))
    Return
  Endif
  Gosub AINSERT_AUPDATE_CONTROL_BEFORE
Return

###################################################################################################
# To write it one time
$AINSERT_AUPDATE_CONTROL_BEFORE
Local Integer NI

  For NI = 1 To maxtab(this.BUDLIG)
    If this.BUDLIG(NI) <> null and find(this.BUDLIG(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.BUDLIG(NI).OPPNUM = "" or this.BUDLIG(NI).PBUCOD = "" Then
        this.BUDLIG(NI).OPPNUM = this.OPPNUM
        this.BUDLIG(NI).PBUCOD = this.PBUCOD
      Endif
      # Issue X3-74794 - 2018-02-28 by FGR : BEGIN
      If this.TCHACTION = "BUDGET_CLOSING" or this.TCHACTION = "CLOSING" Then
        If this.BUDLIG(NI).PLBFLGREM = [V]CST_ANO Then
          this.BUDLIG(NI).PLBFLGREM = [V]CST_AYES
        Endif
      Endif
      # Issue X3-74794 - 2018-02-28 by FGR : END
    Endif
  Next NI
  If this.PBUIMP = [V]CST_ANO Then
    this.PIMPL.TCHACTION = "STATUS"
    this.PIMPL.PIMSTA = [V]CST_ANO
  Endif
Return

###################################################################################################
$ACONTROL
Local Integer ICOUNT
Local Integer NI
Local Integer NE
Local Integer NE1

  [L]ASTATUS = [V]CST_AOK
  # ---------------------
  If this.APARENT = null Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(192,2260,1), [V]CST_AFATAL))
    Return
  Endif
  If this.ASTALIN = [V]CST_AUPD and this.PBUNUM <> this.snapshot.PBUNUM Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUNUM", mess(18,9804,1), [V]CST_AERROR))
  Endif
  ICOUNT = 0
  For NI = 1 To maxtab(this.BUDLIG)
    If this.BUDLIG(NI) <> null and find(this.BUDLIG(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      NE = find(this.BUDLIG(NI).PLBSEQ, this.BUDLIG(NI+1..maxtab(this.BUDLIG)).PLBSEQ)
      While NE > 0
        If this.BUDLIG(NE) <> null and find(this.BUDLIG(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          ICOUNT = NE
        Endif
        NE1 = NE
        NE = find(this.BUDLIG(NI).PLBSEQ, this.BUDLIG(NE+1..maxtab(this.BUDLIG)).PLBSEQ)
        If NE > 0 Then
          NE += NE1
        Endif
      Wend
    Endif
  Next NI
  If ICOUNT > 1 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PLBSEQ", func AFNC.MES2(mess(152,2260,1), this.PBUCOD, num$(this.BUDLIG(ICOUNT).PLBSEQ)), [V]CST_AERROR))
  Endif
  ICOUNT = 0
  For NI = 1 To maxtab(this.BUDLIG)
    If this.BUDLIG(NI) <> null and find(this.BUDLIG(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      NE = find(this.BUDLIG(NI).PCCCOD, this.BUDLIG(NI+1..maxtab(this.BUDLIG)).PCCCOD)
      While NE > 0
        If this.BUDLIG(NE) <> null and find(this.BUDLIG(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          ICOUNT = NE
        Endif
        NE1 = NE
        NE = find(this.BUDLIG(NI).PCCCOD, this.BUDLIG(NE+1..maxtab(this.BUDLIG)).PCCCOD)
        If NE > 0 Then
          NE += NE1
        Endif
      Wend
    Endif
  Next NI
  If ICOUNT > 1 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PCCCOD", func AFNC.MES1(mess(230,2260,1), this.BUDLIG(ICOUNT).PCCCOD), [V]CST_AERROR))
  Endif
  If this.PBUIMP = [V]CST_ANO Then
    Raz ICOUNT
    ICOUNT = fmet this.BUDLIG_COUNT()
    If ICOUNT > 0 Then
      # It should not be possible to unflag "Chargeable" on a budget code if there are some existing budget lines
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUIMP", mess(961,2260,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$ADELETE_CONTROL_BEFORE
  [L]ASTATUS = [V]CST_AOK
  # ---------------------
  If this.APARENT = null Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(193,2260,1), [V]CST_AFATAL))
    Return
  Endif
Return

###################################################################################################
$BUDLIG_ACONTROL
  [L]ASTATUS = [V]CST_AOK
  # ---------------------
  If this.PLBFCY <> this.APARENT.PBUFCY Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PLBFCY", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.CUR <> this.APARENT.CUR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("CUR", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.TCHPBUSTRDT <> date$ Then                        # LSEY 01-04-2016 Budgets date not managed at the moment
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TCHPBUSTRDT", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.TCHCHGTYP <> this.APARENT.TCHCHGTYP Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TCHCHGTYP", mess(18,9804,1), [V]CST_AERROR))
  Endif
  # ---------------------------------------
  If this.APARENT.TCHACTION <> "CLOSING" Then
    If this.ASTALIN = [V]CST_ANEW or this.ASTALIN = [V]CST_AUPD Then
      If this.APARENT.PBUSTATE = 4 Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(982,2260,1), mess(this.APARENT.PBUSTATE,2251,1)), [V]CST_AERROR))
      Endif
    Endif
  Endif
  If this.PLBU <> this.snapshot.PLBU Then
    If this.APARENT.PBUSTATE = 3 or this.APARENT.PBUSTATE = 4 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PLBU", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$BUDLIG_ADDLINE_BEFORE
  [L]ASTATUS = [V]CST_AOK
  # ---------------------
  If this.PBUSTATE = 4 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(982,2260,1), mess(this.PBUSTATE,2251,1)), [V]CST_AERROR))
  Endif
  If this.PBUIMP = [V]CST_ANO and this.PBUELE = [V]CST_ANO Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(209,2260,1), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$BUDLIG_ADDLINE_AFTER
Local Integer NI
Local Integer NE

  [L]ASTATUS = [V]CST_AOK
  # ---------------------
  NE = 0
  For NI = 1 To maxtab(this.APARENT.BUDLIG)
    #If this.APARENT.BUDLIG(NI) <> null Then                                                                           # Issue X3-52534 - 2017-08-11 by FGR
    If this.APARENT.BUDLIG(NI) <> null and find(this.APARENT.BUDLIG(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then   # Issue X3-52534 - 2017-08-11 by FGR : to not lost numbers
      If this.APARENT.BUDLIG(NI).PLBSEQ > NE Then
        NE = this.APARENT.BUDLIG(NI).PLBSEQ
      Endif
    Endif
  Next NI
  this.PLBSEQ = NE + 10
  # ---------------------------------------
  this.PLBFCY = this.APARENT.PBUFCY              # Stored value given by parent
  this.CUR = this.APARENT.CUR                    # Stored value given by parent
  this.TCHPBUSTRDT = date$                       # LSEY 01-04-2016 Budgets date not managed at the moment this.APARENT.PBUSTARTDT     # Technical value have to be set in method BUDLIG_INIT_TECH_PROP
  this.TCHCHGTYP = this.APARENT.TCHCHGTYP        # Technical value have to be set in method BUDLIG_INIT_TECH_PROP
  # ---------------------------------------
Return

###################################################################################################
$BUDLIG_ADELLINE_BEFORE
  [L]ASTATUS = [V]CST_AOK
  # ---------------------
  If this.PBUSTATE = 4 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(281,2260,1), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$BUDLIG_AUPDATE_CONTROL_BEFORE
  [L]ASTATUS = [V]CST_AOK
  # ---------------------
  If this.APARENT.PBUSTATE = 4 and this.APARENT.TCHACTION <> "CLOSING" Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(982,2260,1), mess(this.APARENT.PBUSTATE,2251,1)), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$PIMPL_ACONTROL
  [L]ASTATUS = [V]CST_AOK
  # ---------------------
  If this.APARENT.PBUIMP = [V]CST_ANO and this.PIMSTA = [V]CST_AYES Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUIMP", mess(272,2260,1) - this.PBUCOD, [V]CST_AERROR))
  Endif
  If this.PIMTYP <> 4 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMTYP", mess(205,2260,1) - "(" + mess(this.PIMTYP,2254,1) + ")", [V]CST_AERROR))
  Endif
  If this.PBUSTATE <> this.APARENT.PBUSTATE Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUSTATE", mess(18,9804,1) - "(" + this.PBUCOD - num$(this.PBUSTATE) - num$(this.APARENT.PBUSTATE) + ")", [V]CST_AERROR))
  Endif
  If this.FCY <> this.APARENT.PBUFCY Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("FCY", mess(18,9804,1), [V]CST_AERROR))
  Endif
Return

#######################################################################################
$SPLD_ACONTROL
  [L]ASTATUS = [V]CST_AOK
  # ---------------------
  If this.CUR <> this.APARENT.CUR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("CUR", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.OPPCMP <> this.APARENT.OPPCMP Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPPCMP", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.TASCOD <> AVOID.ACHAR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASCOD", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If this.PBUCOD <> this.APARENT.PBUCOD Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUCOD", mess(18,9804,1), [V]CST_AERROR))
  Endif
  If fmet this.ACTX.ACACHE.AFCY.AGETVALNUM(this.APARENT.PBUFCY, "WRHFLG") = [V]CST_AYES Then
    If this.STOFCY <> this.APARENT.PBUFCY Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("STOFCY", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Else
    If this.STOFCY <> AVOID.ACHAR Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("STOFCY", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

#######################################################################################
$SPLD_ADDLINE_BEFORE
  [L]ASTATUS = [V]CST_AOK
  # ---------------------
  If this.PBUSTATE = 4 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", func AFNC.MES1(mess(982,2260,1), mess(this.PBUSTATE,2251,1)), [V]CST_AERROR))
  Endif
Return

#######################################################################################
$SPLD_ADDLINE_AFTER
  [L]ASTATUS = [V]CST_AOK
  # ---------------------
  this.CUR = this.APARENT.CUR
  this.OPPCMP = this.APARENT.OPPCMP
  If fmet this.ACTX.ACACHE.AFCY.AGETVALNUM(this.APARENT.PBUFCY, "WRHFLG") = [V]CST_AYES Then
    this.STOFCY = this.APARENT.PBUFCY
  Else
    this.STOFCY = AVOID.ACHAR
  Endif
Return

#######################################################################################
$SPLD_ADELLINE_BEFORE
  [L]ASTATUS = [V]CST_AOK
  # ---------------------
  If this.PBUSTATE = 4 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(281,2260,1), [V]CST_AERROR))
  Endif
  If this.SPLD([L]ALINE).PSONUM <> AVOID.ACHAR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(196,143,1), [V]CST_AERROR))
  Endif
Return

