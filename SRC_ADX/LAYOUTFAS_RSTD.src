#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return




###############
# METHODS
###############
$METHODS
#  If (B_TRACE_R) Then
#    Call TRACE_LINE("Method :" - ACTION) From AXUNIT
#  Endif
  Case AMETHOD
    When "CONSTRUCTOR"       : Gosub CONSTRUCTOR
    When "TRANS_QUERY"       : Gosub TRANS_QUERY
    When "PROPERTIES_QUERY"  : Gosub PROPERTIES_QUERY
    When "AREAD_AFTER"       : Gosub AREAD_AFTER
    When "LOAD"              : Gosub LOAD
  Endcase
Return

###################################################################
#            METHODES DE LA CLASSE  -  LAYOUTFAS
###################################################################

$CONSTRUCTOR
Return

$PROPERTIES_QUERY
#  If (B_TRACE_R) Then
#    Call TRACE_LINE("Property :"- CURPRO - "Action" - ACTION) From AXUNIT
#  Endif
Case CURPRO
  When "DEVTRA"     : Gosub DEVTRA : # Methods attached to property DEVTRA
Endcase
Return

$TRANS_QUERY
Return

$AREAD_AFTER
#  If (B_TRACE_R) Then
#    Call TRACE_LINE("RRRR" - "AREAD_AFTER" - "Curpro"-CURPRO - "Curpth"-CURPTH  ) From AXUNIT
#  Endif
Return

$LOAD
#  If (B_TRACE_R) Then
#    Call TRACE_LINE("R_LOAD" - "______"- "Curpro"-CURPRO - "Curpth"-CURPTH  ) From AXUNIT
#  Endif

Return
###############
###############
# PROPERTY
###############
###############

$PROPERTIES
#  If (B_TRACE_R) Then
#    Call TRACE_LINE("Property :"- CURPRO - "Action" - ACTION) From AXUNIT
#  Endif
  Case CURPRO
    When "DEVTRA"    : Gosub DEVTRA
    When "DEVSOC"    : Gosub DEVSOC
    When "DEDCOE"    : Gosub DEDCOE
    When Default
    Endcase
  Return
###################################################################
#            METHODES SUR LA PROPRIETE  -  DEVTRA
###################################################################
$DEVTRA
Case ARULE
   When "INIT"      : Gosub INIT_DEVTRA      : # Init method attached to DEVTRA
   When "CONTROL"   : Gosub CONTROL_DEVTRA   : # Control method attached to DEVTRA
   When "PROPAGATE" : Gosub PROPAGATE_DEVTRA : # Propagate method attached to DEVTRA
   When "GET"       : Gosub GET_DEVTRA       : # Get method attached to DEVTRA
Endcase
Return
#---------------------
$INIT_DEVTRA
Return
#---------------------
$CONTROL_DEVTRA
Return
#---------------------
$PROPAGATE_DEVTRA
Return
#---------------------
$GET_DEVTRA
#  If (B_TRACE) Then
#    Call TRACE_LINE("Utilisateur  :"- this.ACTX.USER) From AXUNIT
#    Call TRACE_LINE("Contexte     :"- this.ACTX.AFOLD.ALANGDEF) From AXUNIT
#  Endif
   this.DEVTRA = this.LOF.CUR
Return

###################################################################
#            METHODES SUR LA PROPRIETE  -  DEVSOC
###################################################################
$DEVSOC
Case ARULE
   When "INIT"      : Gosub INIT_DEVSOC      : # Init method attached to DEVSOC
   When "CONTROL"   : Gosub CONTROL_DEVSOC   : # Control method attached to DEVSOC
   When "PROPAGATE" : Gosub PROPAGATE_DEVSOC : # Propagate method attached to DEVSOC
   When "GET"       : Gosub GET_DEVSOC       : # Get method attached to DEVSOC
Endcase
Return
#---------------------
$INIT_DEVSOC
Return
#---------------------
$CONTROL_DEVSOC
Return
#---------------------
$PROPAGATE_DEVSOC
Return
#---------------------
$GET_DEVSOC
  Local Integer L_ERROR
  FreeInstance [WCPY]
  Local Instance COMPANY Using C_COMPANY
  COMPANY = NewInstance [WCPY] With C_COMPANY
  L_ERROR = fmet COMPANY.AREAD(this.LOF.CPY)
  this.DEVSOC = COMPANY.ACCCUR
  FreeInstance [WCPY]
Return
###################################################################
#            METHODES SUR LA PROPRIETE  -  DEDCOE
###################################################################
$DEDCOE
Case ARULE
   When "INIT"      : Gosub INIT_DEDCOE      : # Init method attached to DEVTRA
   When "CONTROL"   : Gosub CONTROL_DEDCOE   : # Control method attached to DEVTRA
   When "PROPAGATE" : Gosub PROPAGATE_DEDCOE : # Propagate method attached to DEVTRA
   When "GET"       : Gosub GET_DEDCOE       : # Get method attached to DEVTRA
Endcase
Return
#---------------------
$INIT_DEDCOE
Return
#---------------------
$CONTROL_DEDCOE
Return
#---------------------
$PROPAGATE_DEDCOE
Return
#---------------------
$GET_DEDCOE
#  If (B_TRACE) Then
#    Call TRACE_LINE("Utilisateur  :"- this.ACTX.USER) From AXUNIT
#    Call TRACE_LINE("Contexte     :"- this.ACTX.AFOLD.ALANGDEF) From AXUNIT
#  Endif
  Local Decimal MNT1, MNT2
  this.DEDCOE = this.LOF.TAXCOE * this.LOF.ASJCOE * this.LOF.ADMCOE
  If ( this.DEDCOE <> 0 ) Then
    MNT1 = this.DEDCOE*1000
    MNT2 = (int(this.DEDCOE*100)*10)
    If (MNT1 <> MNT2 ) Then
      this.DEDCOE = MNT2 + 10
    Else
      this.DEDCOE = MNT2
    Endif
    this.DEDCOE = this.DEDCOE / 1000
  Endif

Return

