#<AdxTL>@(#)0.0.0.0 $Revision$
#JOJAC - 2016-08-25 - X3PEOP-1318 - START
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "ANNULE"    : Gosub ANNULE #FRLAA - 2016-06-16 - REQUIREMENT 114309 US 11
 #FRLAA - 2015/04/30 Requirement 108198 US 3580  START
# When "MODIF"     : Gosub MODIF
# When "CREATION"  : Gosub CREATION
# When "FILTRE"    : Gosub FILTRE
 #FRLAA - 2015/04/30 Requirement 108198 US 3580  END
Endcase
Return

$OUVRE
  If clalev([F:CNTSA])=0 : Local File CONTACTSA       [CNTSA]         : Endif
  #FRLAA - 2015/04/30 Requirement 108198 US 3580  START
  If clalev([F:BPASA])=0 : Local File BPADDRESSSA     [F:BPASA]       : Endif
  If clalev([F:CPYKSA])=0 : Local File HRCOMPANYKSA   [CPYKSA]        : Endif
  #FRLAA - 2015/04/30 Requirement 108198 US 3580 END
Return

$LIENS
#FRLAA - 2015/05/01 Requirement 108198 US 3580  START
If func DIVPAYE.IS_KZA(LEG)
  Call CHARG_CNT_CPY_KSA(NUMBPA,[M:CPY0]CPY) From TRTBPAKSA
  Call CHARG_BPA_CPY_KSA(NUMBPA,[M:CPY0]CPY) From TRTBPAKSA
Endif
#FRLAA - 2015/05/01 Requirement 108198 US 3580  END
Return

#FRLAA - 2015/04/30 Requirement 108198 US 3580  START
$MODIF
$CREATION
  Delete [CPYKSA] Where CPY=[F:CPY]CPY
  If fstat=1
   GOK = -1
   GLOCK = "$HRCOMPANYKSA"-[F:CPY]CPY
   Return
  Elsif fstat>5
   GOK = 0
   Call RSTA("CPYKSA",[F:CPY]CPY) From GLOCK
   Return
  Endif

  If func DIVPAYE.IS_KZA(GCURLEG)>0
    [F:CPYKSA]CPY = [F:CPY]CPY
    [F:CPYKSA]    = [M:CNT]
    Write [CPYKSA]
    If fstat
      GOK=0 : Return
    Endif
 Endif
Return


$FILTRE
If func DIVPAYE.IS_KZA(GCURLEG)>0
  If clalev([F:CPYKSA])=0 : Local File HRCOMPANYKSA    [CPYKSA]         : Endif
  If [F:CPY]CPY<>[F:CPYKSA]CPY
    Read [CPYKSA]CPYKSA0 = [F:CPY]CPY
  Endif
Endif
Return

#FRLAA - 2016-06-06 - REQUIREMENT 114309 US 11 - START
$ANNULE
  Delete [CPYKSA] Where CPY=[F:CPY]CPY
  If fstat=1
   GOK = -1
   GLOCK = "$HRCOMPANYKSA"-[F:CPY]CPY
   Return
  Elsif fstat>5
   GOK = 0
   Call RSTA("CPYKSA",[F:CPY]CPY) From GLOCK
   Return
  Endif
Return
#FRLAA - 2016-06-06 - REQUIREMENT 114309 US 11 - END



Subprog AV_EECNUM(VALEUR)
Variable Char    VALEUR()

  GFMT=""
End
#JOJAC - 2016-08-25 - X3PEOP-1318 - END

