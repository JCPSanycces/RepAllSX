#<AdxTL>@(#)2.0.0.0 $Revision$
###################################################################################
# UUMGTRTPUR43   Reprise des signatures/Historique suivi workflow    Module Achats#
###################################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
     Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
   # Issue 108760 - 2015-06-12 by SR : adaptation
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTPUR43") From LECFIC
  Endif

  #Call RAZ_UUMGTRTPUR43(DOSSIER)
  Call MAJ_UUMGTRTPUR43(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

##########################################################################
Subprog RAZ_UUMGTRTPUR43(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  End
Endif

Local Char WNAMPADM,WNAMPAPM,WNAMPACM
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPRECORD",WNAMPADM,ERR) From TRTMIG
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPROVAL",WNAMPAPM,ERR) From TRTMIG
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPCONF",WNAMPACM,ERR) From TRTMIG
If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMPADM,"fde",[F:ADS]DOSSIER),0) < 0 End Endif
If filinfo(filpath("FIL",WNAMPAPM,"fde",[F:ADS]DOSSIER),0) < 0 End Endif
If filinfo(filpath("FIL",WNAMPACM,"fde",[F:ADS]DOSSIER),0) < 0 End Endif

##2 - On vide les fichiers selon le cas
#######################################

Local File =DOSSIER+".AWRKHISSUI"  [AWS]
Trbegin [AWS]
Delete [AWS] Where CODWRK="PSHSIG" | CODWRK="PSHSIGVAL"
Commit
Trbegin [AWS]
Delete [AWS] Where CODWRK="POHSIG" | CODWRK="POHSIGVAL"
Commit
Trbegin [AWS]
Delete [AWS] Where CODWRK="POCSIG" | CODWRK="POCSIGVAL"
Commit


##3 - On vide AMIGKEY pour le flux
####################

Call MIGRAZKEY (DOSSIER,"UUMGTRTPUR43",ERR) From TRTMIG

End

##############################################################################################
##############################################################################################
Subprog MAJ_UUMGTRTPUR43(DOSSIER)
Value Char DOSSIER

# Issue 108760 - 2015-06-12 by SR : adaptation
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1

Local Integer ERR
Local Integer TOTNBR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR43",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
# Issue 89740 - 2013-05-06 by MAE : Prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR43",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

Local Char WNAMPADM,WNAMPAPM,WNAMPACM
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPRECORD",WNAMPADM,ERR) From TRTMIG
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPROVAL",WNAMPAPM,ERR) From TRTMIG
Call MIGTABNAME ([F:ADS]DOSSIER,"PAPPCONF",WNAMPACM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR43",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#

If filinfo(filpath("FIL",WNAMPADM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR43",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMPAPM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR43",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMPACM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR43",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################
Gosub MIG_OUVRE From TRTMIG

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR43",2,ERR) From TRTMIG : #2=En cours
Call MIGGETTOTNBR (DOSSIER,"PAPPRECORD",TOTNBR,ERR) From TRTMIG : #gerer nb lignes a traiter
Trbegin [AMY]
Call MIGSTKTOTNBR (DOSSIER,"UUMGTRTPUR43",TOTNBR,ERR) From TRTMIG
Commit

###################

Local Char WTAB_AWS (50) (adxwrb)
Local Shortint WCPT_AWS

Call ECR_TIME("UUMGTRTPUR43 tables Workflow monitoring history Process : Write AWRKHISSUI") From DOSSUB
Call ECR_TRACE("UUMGTRTPUR43 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Call MIGTABINIT (DOSSIER,"AWRKHISSUI",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:AWS])  = 0 : Local File =DOSSIER+".AWRKHISSUI"    [AWS]  : Endif   # Fichier X3 "Vide"

If clalev([F:PADM]) = 0 : Local File =DOSSIER+"."+WNAMPADM   [PADM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:PAD2]) = 0 : Local File =DOSSIER+"."+WNAMPADM   [PAD2] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:PAPM]) = 0 : Local File =DOSSIER+"."+WNAMPAPM   [PAPM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBLUS, NBCOMMIT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=5
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

#Gosub OUVRE_PUR From UUMGTRTPUR00
Gosub OUVRE_PUR09AWS

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTPUR43",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTPUR43" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_PAD00
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:PADM]APPRUL=val(TABMIGKEY(1)) & [F:PADM]NUM=TABMIGKEY(2) & [F:PADM]LIN=val(TABMIGKEY(3)) & [F:PADM]APPLEV>val(TABMIGKEY(4))"
Elsif STOP = 2
 STOP = 3
 CRITERE = "[F:PADM]APPRUL=val(TABMIGKEY(1)) & [F:PADM]NUM=TABMIGKEY(2) & [F:PADM]LIN>val(TABMIGKEY(3))"
Elsif STOP=3
 STOP = 4
 CRITERE = "[F:PADM]APPRUL=val(TABMIGKEY(1)) & [F:PADM]NUM>TABMIGKEY(2)"
Elsif STOP=4
 STOP = 0
 CRITERE = "[F:PADM]APPRUL>val(TABMIGKEY(1))"
Else
 CRITERE = "1=1"
Endif

Trbegin [AWS]
GOK = 1

For [PADM]PAD0 Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTPUR43" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLEAWS : Endif
  Endif

  #Appel proc de migration
  #  version < V6, traitement v6
  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_AWS
    If GOK<1 : Break : Endif
  Endif
  #  version < V7, traitement v7
  If val(VERSION)<GMIGX3VER70
    Gosub MAJV7_AWS
    If GOK<1 : Break : Endif
  Endif



  If NB>GMAXUPDTRS
    TABMIGKEY(1) = num$([F:PADM]APPRUL)
    TABMIGKEY(2) = [F:PADM]NUM
    TABMIGKEY(3) = num$([F:PADM]LIN)
    TABMIGKEY(4) = num$([F:PADM]APPLEV)
    STOP=1
    Break
  Endif
$SUITE_BOUCLEAWS
Next

$FIN_BOUCLEAWS
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR43",7,ERR) From TRTMIG : #7=Erreur
Else
  # Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#  If NEWMOTEUR & adxwrb>1
    Flush [F:AWS]
    If fstat
        Call ECR_TRACE("File AWRKHISSUI, Error ="-num$(fstat),1) From GESECRAN
        Gosub AWS_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLEAWS : #on part sur rollback
    Endif
# Endif
 # End issue 108760
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTPUR43",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLEAWS
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTPUR43",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_PAD00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [AWS]
Close Local File [PADM],[PAPM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"AWRKHISSUI",ERR) From TRTMIG
Call MIGTRTEND (DOSSIER,"UUMGTRTPUR43") From TRTMIG
Call ECR_TIME("UUMGTRTPUR43 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

################################################
$OUVRE_PUR09AWS
Local File =DOSSIER+".PREQUISD"    [PSD]
Local File =DOSSIER+".PORDER"      [POH]
Local File =DOSSIER+".ACODNUM"     [ANM]
Local File =DOSSIER+".AVALNUM"     [AVN]
Local File =DOSSIER+".AUTILIS"     [AUS]

Local Libelle  WFLAG_WRK,  WFLAG_WRG, WCLEFLG
Local Integer  WCTEUR_WRK, WCTEUR_WRG, WRET
Local Char     WOBJ(GLONAOB),WCHRONO_PREC(GLONVCR)
Local Char     WCHRONO_FIRST(GLONVCR) : # Issue 79162 - 2012-02-02 by VPO
Local Char     WUSR_FIRST(GLONAUS) : # Issue 79162 - 2012-02-02 by VPO
Local Char     WRUPTGRP1(GLONVCR+GLONAUS+8), WRUPTGRP2(GLONVCR+GLONAUS+8)
Read [ANM] ANM0="WRK" : If !fstat  WFLAG_WRK=1  Else  WFLAG_WRK=0 : Endif
Read [ANM] ANM0="WRG" : If !fstat  WFLAG_WRG=1  Else  WFLAG_WRG=0 : Endif

Return

################################################
$AWS_STK
Call STK (WTAB_AWS,WCPT_AWS,[F:AWS]CHRONO+'/'+[F:AWS]DEST) From TRTMIG
Return
##############################################################################################
$AWS_ERRTRA
Call ERRTRA (WTAB_AWS,WCPT_AWS,"File AWRKHISSUI(CHRONO/DEST)=") From TRTMIG
Return

########################################################################
$MAJV6_AWS
  If [F:PADM]ENAFLG=2 | [F:PADM]APPDAT<>[0/0/0]
      #----- Traitement du chrono workflow suivi -----#
      If WFLAG_WRK
        Call NUMERO("WRK","",date$,"",[F:AWS]CHRONO,WRET) From SUBANM
        If GOK<1 | WRET<>0
          WRET=0 : GOK=1 : Call ECR_TRACE("WRK"-mess(60,199,1),1) From GESECRAN
          WCTEUR_WRK+=1 : [F:AWS]CHRONO=WCTEUR_WRK
        Endif
      Else
        WCTEUR_WRK+=1 : [F:AWS]CHRONO=WCTEUR_WRK
      Endif
      #----- Traitement du chrono workflow groupe -----#
      If WRUPTGRP1=""  WRUPTGRP1=[F:PADM]APPUSR+[F:PADM]NUM+num$([F:PADM]LIN) : Endif
      WRUPTGRP2=[F:PADM]APPUSR+[F:PADM]NUM+num$([F:PADM]LIN)
      If [F:AWS]NUMGRP="" | WRUPTGRP1<>WRUPTGRP2
        If WFLAG_WRG
          Call NUMERO("WRG","",date$,"",[F:AWS]NUMGRP,WRET) From SUBANM
          If GOK<1 | WRET<>0
            WRET=0 : GOK=1 : Call ECR_TRACE("WRG"-mess(60,199,1),1) From GESECRAN
            WCTEUR_WRG+=1 : [F:AWS]NUMGRP=WCTEUR_WRG
          Endif
        Else
          WCTEUR_WRG+=1 : [F:AWS]NUMGRP=WCTEUR_WRG
        Endif
      Endif
      WRUPTGRP1=WRUPTGRP2
      #-----
      Case [F:PADM]APPRUL
        When 1
          WOBJ="PSH"
          [F:AWS]CLEDEC  =[F:PADM]NUM+"~"+num$([F:PADM]LIN)
          [F:AWS]TEXSUI  ="Purchase request"-[F:PADM]NUM+"/"+num$([F:PADM]LIN)
          [F:AWS]IDENTRET="GESPSH/"+[F:PADM]NUM
          [F:AWS]IDENTGRP="PREQUISD/"+[F:PADM]NUM+"~"+num$([F:PADM]LIN)
          If [F:PSD]PSHNUM<>[F:PADM]NUM | [F:PSD]PSDLIN<>[F:PADM]LIN
            Read [PSD] PSD0=[F:PADM]NUM;[F:PADM]LIN : If fstat  Raz [F:PSD] : Endif
          Endif
          If [F:PSD]LINCLEFLG=2  WCLEFLG=2  Else  WCLEFLG=0 : Endif
        When 2
          WOBJ="POH"
          [F:AWS]CLEDEC  =[F:PADM]NUM
          [F:AWS]TEXSUI  ="Purchase order"-[F:PADM]NUM
          [F:AWS]IDENTRET="GESPOH/"+[F:PADM]NUM
          [F:AWS]IDENTGRP="PORDER/"+[F:PADM]NUM
          If [F:POH]POHNUM<>[F:PADM]NUM
            Read [POH] POH0=[F:PADM]NUM : If fstat  Raz [F:POH] : Endif
          Endif
          If [F:POH]CLEFLG=2  WCLEFLG=2  Else  WCLEFLG=0 : Endif
        When 3
          WOBJ="POC"
          [F:AWS]CLEDEC  =[F:PADM]NUM
          [F:AWS]TEXSUI  ="Supplier contract"-[F:PADM]NUM
          [F:AWS]IDENTRET="GESPOC/"+[F:PADM]NUM
          [F:AWS]IDENTGRP="PORDER/"+[F:PADM]NUM
          If [F:POH]POHNUM<>[F:PADM]NUM
            Read [POH] POH0=[F:PADM]NUM : If fstat  Raz [F:POH] : Endif
          Endif
          If [F:POH]CLEFLG=2  WCLEFLG=2  Else  WCLEFLG=0 : Endif
      Endcase
      If [F:PADM]SAPFLG<>1
        [F:AWS]DEST=[F:PADM]APPUSR
      Else
        [F:AWS]DEST=[F:PADM]SBSAPPUSR
      Endif
      If [F:AUS]USR<>[F:AWS]DEST
        Read [AUS] CODUSR=[F:AWS]DEST : If fstat  Raz [F:AUS] : Endif
      Endif
      [F:AWS]EMAIL  =[F:AUS]ADDEML
      [F:AWS]CPY    =[F:PADM]CPY
      [F:AWS]LEVSIG =[F:PADM]APPLEV-1
      [F:AWS]DELEGUE=1
      [F:AWS]ENVOI  =2
      [F:AWS]USRTOP =[F:AWS]DEST
      If [F:PADM]ENAFLG<>2 & [F:PADM]APPDAT<>[0/0/0]
        [F:AWS]ACTSIG="VAL"
        [F:AWS]FLGSIG=5
        [F:AWS]USRSIG=[F:AWS]DEST
        [F:AWS]MAISIG=[F:AWS]EMAIL
        [F:AWS]DATSIG=[F:PADM]APPDAT
      Else
        [F:AWS]FLGSIG=3-WCLEFLG
        [F:AWS]ACTSIG=""
        [F:AWS]USRSIG=""
        [F:AWS]MAISIG=""
        [F:AWS]DATSIG=[0/0/0]
      Endif
      If [F:AWS]LEVSIG=0
        Case [F:PADM]APPRUL
          When 1
            [F:AWS]EMETTEUR =[F:PSD]CREUSR
            [F:AWS]DATENV   =[F:PSD]CREDAT
            [F:AWS]IDENTREF ="PREQUIS/"+[F:PADM]NUM
            [F:AWS]CONTXT   ="GESPSH/1/PSH/C/"+[F:PADM]NUM
          When 2,3
            [F:AWS]EMETTEUR =[F:POH]CREUSR
            [F:AWS]DATENV   =[F:POH]CREDAT
            [F:AWS]IDENTREF ="PORDER/"+[F:PADM]NUM
            If [F:PADM]APPRUL=2
              [F:AWS]CONTXT ="GESPOH/1/POH/C/"+[F:PADM]NUM
            Else
              [F:AWS]CONTXT ="GESPOC/1/POC/C/"+[F:PADM]NUM
            Endif
        Endcase
        [F:AWS]ABROBJ   =WOBJ
        [F:AWS]CODEVT   =WOBJ
        [F:AWS]TYPEVT   =2
        [F:AWS]CODWRK   =WOBJ+"SIG"
        [F:AWS]OPERATION="C"
        [F:AWS]CLEOBJ   =[F:PADM]NUM
        [F:AWS]NUMORG   =""
        [F:AWS]USRORG   =""
        WCHRONO_FIRST=[F:AWS]CHRONO : # Issue 79162 - 2012-02-02 by VPO
        WUSR_FIRST=[F:AWS]DEST : # Issue 79162 - 2012-02-02 by VPO
      Else
        [F:AWS]EMETTEUR =[F:PAD2]APPUSR
        [F:AWS]DATENV   =[F:PAD2]APPDAT
        [F:AWS]IDENTREF =""
        # Issue 79162 - 2012-02-02 by VPO
        #[F:AWS]ABROBJ   =""
        [F:AWS]ABROBJ   =WOBJ
        [F:AWS]CODEVT   =WOBJ+"SIG"
        [F:AWS]TYPEVT   =9
        [F:AWS]CODWRK   =WOBJ+"SIGVAL"
        [F:AWS]OPERATION="VAL"
        [F:AWS]CLEOBJ   =WCHRONO_PREC
        # Issue 79162 - 2012-02-02 by VPO
        #[F:AWS]NUMORG   =WCHRONO_PREC
        #[F:AWS]USRORG   =[F:PAD2]APPUSR
        [F:AWS]NUMORG   =WCHRONO_FIRST
        [F:AWS]USRORG   =WUSR_FIRST
        [F:AWS]CONTXT   ="SAIWRKPLN/1/"+WOBJ+"SIG/VAL/"+WCHRONO_PREC
      Endif
      If [F:AUS]USR<>[F:AWS]EMETTEUR
        Read [AUS] CODUSR=[F:AWS]EMETTEUR : If fstat  Raz [F:AUS] : Endif
      Endif
      [F:AWS]MAIENV   =[F:AUS]ADDEML
      [F:AWS]DATMAXSIG=[F:AWS]DATENV+7
      If [F:PAPM]CPY   <>[F:PADM]CPY    |
&        [F:PAPM]APPRUL<>[F:PADM]APPRUL |
&        [F:PAPM]APPCRI<>[F:PADM]APPCRI |
&        [F:PAPM]MAXVAL<>[F:PADM]MAXVAL |
&        [F:PAPM]FBUFLG<>[F:PADM]FBUFLG
        Read [PAPM] PAP0=[F:PADM]CPY;[F:PADM]APPRUL;[F:PADM]APPCRI;[F:PADM]MAXVAL;[F:PADM]FBUFLG
        If fstat  Raz [F:PAPM] : Endif
      Endif
      Raz [F:AWS]NBRUSR

      # Issue 79162 - 2012-02-02 by VPO : on renseigne les USRSIG
      If [F:PAPM]APPUSR1<>"" : [F:AWS]NBRUSR+=1 : [F:AWS]USRSIG1=[F:PAPM]APPUSR1 : Endif
      If [F:PAPM]APPUSR2<>"" : [F:AWS]NBRUSR+=1 : [F:AWS]USRSIG2=[F:PAPM]APPUSR2 : Endif
      If [F:PAPM]APPUSR3<>"" : [F:AWS]NBRUSR+=1 : [F:AWS]USRSIG3=[F:PAPM]APPUSR3 : Endif
      If [F:PAPM]APPUSR4<>"" : [F:AWS]NBRUSR+=1 : [F:AWS]USRSIG4=[F:PAPM]APPUSR4 : Endif
      If [F:PAPM]APPUSR5<>"" : [F:AWS]NBRUSR+=1 : [F:AWS]USRSIG5=[F:PAPM]APPUSR5 : Endif
      If [F:PAPM]APPUSR6<>"" : [F:AWS]NBRUSR+=1 : [F:AWS]USRSIG6=[F:PAPM]APPUSR6 : Endif
      If [F:PAPM]APPUSR7<>"" : [F:AWS]NBRUSR+=1 : [F:AWS]USRSIG7=[F:PAPM]APPUSR7 : Endif
      If [F:PAPM]APPUSR8<>"" : [F:AWS]NBRUSR+=1 : [F:AWS]USRSIG8=[F:PAPM]APPUSR8 : Endif
      If [F:PAPM]APPUSR9<>"" : [F:AWS]NBRUSR+=1 : [F:AWS]USRSIG9=[F:PAPM]APPUSR9 : Endif
      #-----
      [F:PAD2]=[F:PADM] : WCHRONO_PREC=[F:AWS]CHRONO

      # --- alimentation des champs et écriture enreg
# Issue 108760 - 2015-06-15 by SR : No more NEWMOTEUR
#      If NEWMOTEUR
#          Gosub AWS_STK : # pour stocker ref
#          WriteB [F:AWS]
#      Else
#          Write [F:AWS]
#      Endif
#      If fstat
#        If NEWMOTEUR & adxwrb>1
#          Call ECR_TRACE("File AWRKHISSUI, Error ="-num$(fstat),1) From GESECRAN
#          Gosub AWS_ERRTRA : # pour afficher les ref
#        Else
#          Call ECR_TRACE("File AWRKHISSUI(CHRONO+DEST)"-[F:AWS]CHRONO-[F:AWS]DEST+", Error ="-num$(fstat),1) From GESECRAN
#        Endif
#        GOK=0 : Return
#      Endif
       Gosub AWS_STK : # pour stocker ref
       WriteB [F:AWS]
       If fstat
          Call ECR_TRACE("File AWRKHISSUI, Error ="-num$(fstat),1) From GESECRAN
          Gosub AWS_ERRTRA : # pour afficher les ref
          GOK=0 : Return
       Endif
       # End issue 108760
      NB+=1
  Endif
Return
########################################################################
$MAJV7_AWS
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 108760 - 2015-06-12 by SR : adaptation
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif

Call MAJ_UUMGTRTPUR43(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTPUR43(APPLI)
End

