#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################
# Traitement STKALF - Librairie composants d'allocation/sortie     V12 #
#  ( Issu de STKALL )                                                  #
########################################################################

#-----------------------------------------------------------#
# Chargement des filtres sur le lot                         #
#-----------------------------------------------------------#
$FILTRE_LOT
Local Char NBDAY(10)
NBDAY=""

#DLU Client, calcul du nbre de jours à retrancher à la DLU article
If [F:ITU]DLUBPC <> 0
  Call CALNBDAYCLI([F:ITM]EXYMGTCOD,[F:ITM]SHL,[F:ITM]SHLUOM,[F:ITF]DLU,[F:ITU]DLUBPC,NBDAY) From STKLIB
Endif

#--- Issue 103189
#WCRITLOT='ITMREF=[M:ALP]ITMREF'
WCRITLOT='[F:SLF1]ITMREF=[M:ALP]ITMREF'
#---

# Si lot renseigné dans filtre allocation
If !find([M:ALP]LOT,"","*")
   [M:ALP]LOT = vireblc([M:ALP]LOT,1)
   #--- Issue 103189
   #WCRITLOT  +='&pat(LOT,[M:ALP]LOT)<>0'
   WCRITLOT  +='&pat([F:SLF1]LOT,[M:ALP]LOT)<>0'
   #---
   # Stockage lot pour rupture
   WSHTLOT    = [M:ALP]LOT
Endif

# Lots périmés interdits    # hcb v6dlu nouvelle gestion
If [F:SRU]SHLLOT<>3
   If [F:SRU]SHLLOT=1
      If [M:ALP]DLVDAT<>[0/0/0]
         WCRITLOT+='&([F:STL1]SHLDAT=[0/0/0]|[F:STL1]SHLDAT>=[M:ALP]DLVDAT)'
      Else
         WCRITLOT+='&([F:STL1]SHLDAT=[0/0/0]|[F:STL1]SHLDAT>=[M:ALP]BESDAT)'
      Endif
   Endif
   If [F:SRU]SHLLOT=2
      If [M:ALP]DLVDAT<>[0/0/0]
          #DLU Client
            WCRITLOT+='&([F:STL1]DLUDAT=[0/0/0]|[F:STL1]DLUDAT'+NBDAY+'>=[M:ALP]DLVDAT)'
      Else
          #DLU Client
            WCRITLOT+='&([F:STL1]DLUDAT=[0/0/0]|[F:STL1]DLUDAT'+NBDAY+'>=[M:ALP]BESDAT)'
      Endif
   Endif
Endif

#--- Issue 103189
WCRITLOT+='&sum(WA*[F:SLF1]AAACUMQTY,WQ*[F:SLF1]QQQCUMQTY,WR*[F:SLF1]RRRCUMQTY)>0'

#--- TS 106217
# Si version renseignée, prise en compte de celle-ci
If [M:ALP]ECCVALMAJ<>""
   WCRITECC='[F:STL1]ECCVALMAJ=[M:ALP]ECCVALMAJ'
Else
   WCRITECC='1=1'
Endif
#---

Return

#-----------------------------------------------------------#
# Chargement des filtres sur les lignes de stock, à partir  #
# - du filtre allocation (si commande ou OF)                #
# - des règles d'allocation                                 #
# - de la règle de gestion (si sortie)(pour sous-statuts)   #
# - des caractéristiques du type mouvement (catégorie art)  #
#-----------------------------------------------------------#
$FILTRE_STOCK

Raz WA, WQ, WR, WAQR
Raz WCRIT, WCRITSTO1, WCRITSTO2, WCRITSTO3

#------------------------------------------------------------------------
# Filtre sur les statuts pour restreindre les lignes de stocks éligibles
#------------------------------------------------------------------------

# Si statuts renseignés dans filtre allocation
If !find([M:ALP]STA,"","*")
   # Décodage de la liste de statuts --> transformation en
   # une formule contenant des 'pat(%,statut)'
   Call DECODE_STAT([M:ALP]STA,WCRIT) From TRTCATEG
   # Remplacement des '%' par la variable à tester
   Call CREE_FORMULE(WCRIT,"[F:STO1]STA",WCRITSTO1) From TRTCATEG
   If instr(1,WCRITSTO1,chr$(34)+"A") WA=1 Endif
   If instr(1,WCRITSTO1,chr$(34)+"Q") WQ=1 Endif
   If instr(1,WCRITSTO1,chr$(34)+"R") WR=1 Endif
   Raz WCRIT
# Sinon si autres documents, prise en compte des sous-statuts autorisés
#--- PJM_TS ajout de VCRTYP=40
Elsif !find([M:ALP]VCRTYP,2,10,36,40) & !find([F:SRU]AUZSST,"","*")
   Call CREE_FORMULE([F:SRU]FORSTA,"[F:STO1]STA",WCRITSTO1) From TRTCATEG
   If instr(1,WCRITSTO1,chr$(34)+"A") WA=1 Endif
   If instr(1,WCRITSTO1,chr$(34)+"Q") WQ=1 Endif
   If instr(1,WCRITSTO1,chr$(34)+"R") WR=1 Endif
Endif

# S'il n'y avait pas de filtre statut, on traite ceux de la règle d'allocation
# restreint par les statuts autorisés pour le mouvement ds la catégorie article
If WCRITSTO1=""
   # Si commande, OF ou EO
   #--- PJM_TS ajout de VCRTYP=40
   If find([M:ALP]VCRTYP,2,10,36,40)
      If WTRUCOD<>""
         # Statuts autorisés par les règles d'allocation
         For I=0 To dim([F:TRU]STAFLT)-1
            If [F:TRU]STAFLT(I)<>0
               If find([F:TRU]STAFLT(I),1,3,5,7) WA=1  Endif
               If find([F:TRU]STAFLT(I),2,3,6,7) WQ=1  Endif
               If find([F:TRU]STAFLT(I),4,5,6,7) WR=1  Endif
            Endif
         Next I
         WAQR = WA+2*WQ+4*WR
      Endif
   # Autres pièces
   Else
      # Statuts autorisés par la règle de gestion de stock
      WAQR=[F:SRU]AUZSTA
   Endif

   # Alimentation du filtre sur le statut
   Case WAQR
      When 1       : WCRITSTO1='left$([F:STO1]STA,1)="A"'
                     WA=1
      When 2       : WCRITSTO1='left$([F:STO1]STA,1)="Q"'
                     WQ=1
      When 3       : WCRITSTO1='(left$([F:STO1]STA,1)="A"|left$([F:STO1]STA,1)="Q")'
                     WA=1 : WQ=1
      When 4       : WCRITSTO1='left$([F:STO1]STA,1)="R"'
                     WR=1
      When 5       : WCRITSTO1='(left$([F:STO1]STA,1)="A"|left$([F:STO1]STA,1)="R")'
                     WA=1 : WR=1
      When 6       : WCRITSTO1='(left$([F:STO1]STA,1)="Q"|left$([F:STO1]STA,1)="R")'
                     WQ=1 : WR=1
      When 7       : WCRITSTO1='1=1'
                     WA=1 : WQ=1 : WR=1
      When Default : WCRITSTO1='left$([F:STO1]STA,1)="A"'
                     WA=1 : WAQR=1
   Endcase
Endif

# Pas de demande d'analyse
If [M:ALP]PECQLYCTL<>2
   If WCRITSTO1<>""
      WCRITSTO1 = "("+WCRITSTO1+")"
   Endif
   WCRITSTO1 += '&[F:STO1]QLYCTLDEM=""'
Endif

#-----------------------------------------------------------------------
# Filtre sur les unités pour restreindre les lignes de stocks éligibles
#-----------------------------------------------------------------------
Raz WUDO, WUDE, WUDI, WUDS
Raz WUCO, WUCE, WUCI, WUCS
WUD=1 : WUS=1 : WUC=1

If WTRUCOD=""
   # Si pas de règle d'allocation --> toutes les unités sans contrainte de coef
   WUS=2 : WUDO=1 : WUCO=1
Else
   # Unités autorisées par les règles d'allocation
   For I=0 To dim([F:TRU]DOCFLT)-1
      If [F:TRU]STUFLT(I)=2 WUS=2 Endif             : # US
      Case [F:TRU]COEFLT(I)
       When 1  : If [F:TRU]DOCFLT(I)=2 WUDO=1 Endif : # UD sans contrainte
                 If [F:TRU]PCUFLT(I)=2 WUCO=1 Endif : # UC sans contrainte
       When 2  : If [F:TRU]DOCFLT(I)=2 WUDE=1 Endif : # UD coef =
                 If [F:TRU]PCUFLT(I)=2 WUCE=1 Endif : # UC coef =
       When 3  : If [F:TRU]DOCFLT(I)=2 WUDI=1 Endif : # UD coef <=
                 If [F:TRU]PCUFLT(I)=2 WUCI=1 Endif : # UC coef <=
       When 4  : If [F:TRU]DOCFLT(I)=2 WUDS=1 Endif : # UD coef >=
                 If [F:TRU]PCUFLT(I)=2 WUCS=1 Endif : # UC coef >=
      Endcase
   Next I
Endif

# Valeur de WUD et WUC (Unité document et unités conditionnement)
#    1 : non
#    2 : oui sans contrainte
#    3 : oui coef =
#    4 : oui coef <=
#    5 : oui coef >=
WUD=1
If WUDO=1
   WUD=2
   Raz WUDE,WUDI,WUDS
Elsif WUDI=1 & WUDS=1
   WUD=2
   Raz WUDE,WUDI,WUDS
Elsif WUDI=1
   WUD=4
   Raz WUDE
Elsif WUDS=1
   WUD=5
   Raz WUDE
Elsif WUDE=1
   WUD=3
Endif

WUC=1
If WUCO=1
   WUC=2
   Raz WUCE,WUCI,WUCS
Elsif WUCI=1 & WUCS=1
   WUC=2
   Raz WUCE,WUCI,WUCS
Elsif WUCI=1
   WUC=4
   Raz WUCE
Elsif WUCS=1
   WUC=5
   Raz WUCE
Elsif WUCE=1
   WUC=3
Endif

# Constitution du filtre unité/coef selon US,UD et UC ainsi que le filtre coef
If WUS=2
   # Si US à oui
   Case WUC
    When 1: WCRITSTO2='[F:STO1]PCU=[M]STU'                                                            :# US
    When 2: WCRITSTO2='1=1'                                                                           :# Toutes les unités
    When 3: WCRITSTO2='[F:STO1]PCU=[M]STU|([F:STO1]PCU<>[M]STU&[F:STO1]PCUSTUCOE =[M]PCUSTUCOE)'      :# US ou UC Coef =
    When 4: WCRITSTO2='[F:STO1]PCU=[M]STU|([F:STO1]PCU<>[M]STU&[F:STO1]PCUSTUCOE<=[M]PCUSTUCOE)'      :# US ou UC Coef<=
    When 5: WCRITSTO2='[F:STO1]PCU=[M]STU|([F:STO1]PCU<>[M]STU&[F:STO1]PCUSTUCOE>=[M]PCUSTUCOE)'      :# US ou UC Coef>=
   Endcase
Else
   # Si US à non
   Case WUC
    When 1: WCRITSTO2='[F:STO1]STOCOU=0'                                                              :# Rien
    When 2: WCRITSTO2='([F:STO1]PCU<>[M]STU&[F:STO1]PCU<>[F:ITM]STU)'                                 :# Toutes les UC
    When 3: WCRITSTO2='([F:STO1]PCU<>[M]STU&[F:STO1]PCU<>[F:ITM]STU&[F:STO1]PCUSTUCOE =[M]PCUSTUCOE)' :# UC Coef =
    When 4: WCRITSTO2='([F:STO1]PCU<>[M]STU&[F:STO1]PCU<>[F:ITM]STU&[F:STO1]PCUSTUCOE<=[M]PCUSTUCOE)' :# UC Coef<=
    When 5: WCRITSTO2='([F:STO1]PCU<>[M]STU&[F:STO1]PCU<>[F:ITM]STU&[F:STO1]PCUSTUCOE>=[M]PCUSTUCOE)' :# UC Coef>=
   Endcase
Endif
# Rajout des contrainte sur l'UD
Case WUD
 When 2: WCRITSTO2+='|[F:STO1]PCU=[M]PCU'                                                             :# Ou UD
 When 3: WCRITSTO2+='|([F:STO1]PCU=[M]PCU&[F:STO1]PCUSTUCOE =[M]PCUSTUCOE)'                           :# Ou UD Coef =
 When 4: WCRITSTO2+='|([F:STO1]PCU=[M]PCU&[F:STO1]PCUSTUCOE<=[M]PCUSTUCOE)'                           :# Ou UD Coef<=
 When 5: WCRITSTO2+='|([F:STO1]PCU=[M]PCU&[F:STO1]PCUSTUCOE>=[M]PCUSTUCOE)'                           :# Ou UD Coef>=
Endcase

# Exploitation du filtre sur le propriétaire
If [M:ALP]PECOWNER=""
   WCRITSTO2+='&[F:STO1]OWNER=[F:STO1]STOFCY'
Else
   WCRITSTO2+='&find([F:STO1]OWNER,[F:STO1]STOFCY,[M:ALP]PECOWNER)'
Endif

#-----------------------------------------------------------------------------
# Filtre sur les emplacements pour restreindre les lignes de stocks éligibles
# WCRITSTO3 contient les emplacements exclusifs
#-----------------------------------------------------------------------------

Raz WDEFLOC, WDEFLOC2, WDEFLOC3, WSHTLOC
Raz WDEFLOCTYP, WDEFLOCTYP2, WDEFLOCTYP3, WSHTLOCTYP
Raz WSHTWRH
# Catégorie emplacement à prendre en compte
If [M:ALP]PECINTLOC=2
   If [M:ALP]PECPLFLOC=2
      If [M:ALP]PECSCOLOC=2
         WCRIT = 'find([F:STO1]LOCCAT,1,2,4)<>0'
      Else
         WCRIT = 'find([F:STO1]LOCCAT,1,2)<>0'
      Endif
   Elsif [M:ALP]PECSCOLOC=2
      WCRIT = 'find([F:STO1]LOCCAT,1,4)<>0'
   Else
      WCRIT = '[F:STO1]LOCCAT=1'
   Endif
Elsif [M:ALP]PECPLFLOC=2
   If [M:ALP]PECSCOLOC=2
      WCRIT = 'find([F:STO1]LOCCAT,2,4)<>0'
   Else
      WCRIT = '[F:STO1]LOCCAT=2'
   Endif
Elsif [M:ALP]PECSCOLOC=2
   WCRIT = '[F:STO1]LOCCAT=4'
Else
   # Pour ne rien avoir (paramétrage incohérent)
   WCRIT = '[F:STO1]LOCCAT=9'
Endif

# Si emplacement renseigné dans filtre allocation
If !find([M:ALP]LOC,"","*")
   [M:ALP]LOC=vireblc([M:ALP]LOC,1)
   WCRITSTO3+='&(pat([F:STO1]LOC,[M:ALP]LOC)<>0'
   Raz [M:ALP]LOCTYP
Elsif !find([M:ALP]LOCTYP,"","*")
   [M:ALP]LOCTYP=vireblc([M:ALP]LOCTYP,1)
   WCRITSTO3+='&(pat([F:STO1]LOCTYP,[M:ALP]LOCTYP)<>0'
   Raz [M:ALP]LOC
Else
   Raz [M:ALP]LOC,[M:ALP]LOCTYP
Endif

# Récupération types emplacement ou emplacement par défaut
# de l'article-site pour le type mouvement
Gosub ALI_DEFLOC

# Si règle d'allocations
If WTRUCOD<>""
   # Détermination du nombre de ligne de la règle
   I = find(0,[F:TRU]LOCFLT(0..dim([F:TRU]LOCFLT)-1))
   If I=0
      WNBL = dim([F:TRU]LOCFLT)
   Else
      WNBL = I-1
   Endif
   If min([F:TRU]LOCFLT(0..WNBL-1))>1
      # Si OF / EO ou sortie OF / EO et emplacement poste de charge, on le rajoute
      If find([M:ALP]VCRTYP,10,36) | find([M:ALP]TRSTYP,6,29)
         #--- Issue 102809 by TS
         #If [M:ALP]STOLOC<>""
         If [M:ALP]STOLOC<>"" & find(2,[F:TRU]LOCFLT(0..WNBL-1))
         #---
            If WCRITSTO3<>""
               WCRITSTO3+="|"
            Else
               WCRITSTO3+="&("
            Endif
            #--- Issue 103189
            #WCRITSTO3+='pat([F:STO1]LOC,[M:ALP]STOLOC)'
            WCRITSTO3+='pat([F:STO1]LOC,[M:ALP]STOLOC)<>0'
            #---
            # Si emp local exclusif et sans joker on le stocke pour les ruptures
            If max([F:TRU]LOCFLT)=2
&            & !instr(1,[M:ALP]STOLOC,'*') & !instr(1,[M:ALP]STOLOC,'?')
&            & !instr(1,[M:ALP]STOLOC,'!') & !instr(1,[M:ALP]STOLOC,'#')
               WSHTLOC=[M:ALP]STOLOC
            Endif
            #--- Issue 102809 by TS
            # Seul l'emplacement local est dans les règles --> c'est fini.
            #If min([F:TRU]LOCFLT)=2 Return Endif
            #---
         Endif
         # Si pas d'emplacement poste de charge, on le force à tous
         If [M:ALP]STOLOC="" [M:ALP]STOLOC="*" Endif
         #--- Issue 102809 by TS
         # Seul l'emplacement local est dans les règles --> c'est fini.
         If max([F:TRU]LOCFLT)=2
            Goto FILTRE_STOCK_SUI
         Endif
         #---
      Endif

      # 'Emplacement1': renseigné ds la règle de gestion et présent ds la règle d'alloc
      If WDEFLOC<>"" & WDEFLOCTYP<>"" & find(3,[F:TRU]LOCFLT(0..WNBL-1))
         If WCRITSTO3<>""
            WCRITSTO3+="|"
         Else
            WCRITSTO3+="&("
         Endif
         If WDEFLOC="*" & WDEFLOCTYP="*"
            WCRITSTO3+='pat([F:STO1]LOC,WDEFLOC)'
         Elsif WDEFLOC<>"*"
            WCRITSTO3+='pat([F:STO1]LOC,WDEFLOC)'
         Else
            WCRITSTO3+='pat([F:STO1]LOCTYP,WDEFLOCTYP)'
         Endif
      Endif
      # 'Emplacement2': renseigné ds la règle de gestion et présent ds la règle d'alloc
      If WDEFLOC2<>"" & WDEFLOCTYP2<>"" & find(4,[F:TRU]LOCFLT(0..WNBL-1))
         If WCRITSTO3<>""
            WCRITSTO3+="|"
         Else
            WCRITSTO3+="&("
         Endif
         If WDEFLOC2="*" & WDEFLOCTYP2="*"
            WCRITSTO3+='pat([F:STO1]LOC,WDEFLOC2)'
         Elsif WDEFLOC2<>"*"
            WCRITSTO3+='pat([F:STO1]LOC,WDEFLOC2)'
         Else
            WCRITSTO3+='pat([F:STO1]LOCTYP,WDEFLOCTYP2)'
         Endif
      Endif
      # 'Emplacement3': renseigné ds la règle de gestion et présent ds la règle d'alloc
      If WDEFLOC3<>"" & WDEFLOCTYP3<>"" & find(5,[F:TRU]LOCFLT(0..WNBL-1))
         If WCRITSTO3<>""
            WCRITSTO3+="|"
         Else
            WCRITSTO3+="&("
         Endif
         If WDEFLOC3="*" & WDEFLOCTYP3="*"
            WCRITSTO3+='pat([F:STO1]LOC,WDEFLOC3)'
         Elsif WDEFLOC3<>"*"
            WCRITSTO3+='pat([F:STO1]LOC,WDEFLOC3)'
         Else
            WCRITSTO3+='pat([F:STO1]LOCTYP,WDEFLOCTYP3)'
         Endif
      Endif

      # Alimentation (type) emplacement de rupture si nécessaire
      If WSHTLOC=""
         # I,J et K contiennent la 1ère position des catégories emp 1,2 et 3
         # dans le tableau des règles d'allocation (0 si absent)
         I = find(3,[F:TRU]LOCFLT(0..WNBL-1))
         J = find(4,[F:TRU]LOCFLT(0..WNBL-1))
         K = find(5,[F:TRU]LOCFLT(0..WNBL-1))
         # WE1,WE2 et WE3 contiennent 1 si emp par défaut 1,2 et 3
         Raz WE1, WE2, WE3
         If WDEFLOC <>"" & !instr(1,WDEFLOC,'*')  & !instr(1,WDEFLOC,'?')
&                        & !instr(1,WDEFLOC,'!')  & !instr(1,WDEFLOC,'#')
            WE1=1
         Endif
         If WDEFLOC2<>"" & !instr(1,WDEFLOC2,'*') & !instr(1,WDEFLOC2,'?')
&                        & !instr(1,WDEFLOC2,'!') & !instr(1,WDEFLOC2,'#')
            WE2=1
         Endif
         If WDEFLOC3<>"" & !instr(1,WDEFLOC3,'*') & !instr(1,WDEFLOC3,'?')
&                        & !instr(1,WDEFLOC3,'!') & !instr(1,WDEFLOC3,'#')
            WE3=1
         Endif
         # WT1,WT2 et WT3 contiennent 1 si type emp par défaut 1,2 et 3
         Raz WT1, WT2, WT3
         If WDEFLOCTYP <>"" & !instr(1,WDEFLOCTYP,'*') &!instr(1,WDEFLOCTYP,'?')
&                           & !instr(1,WDEFLOCTYP,'!') &!instr(1,WDEFLOCTYP,'#')
            WT1=1
         Endif
         If WDEFLOCTYP2<>"" & !instr(1,WDEFLOCTYP2,'*')&!instr(1,WDEFLOCTYP2,'?')
&                           & !instr(1,WDEFLOCTYP2,'!')&!instr(1,WDEFLOCTYP2,'#')
            WT2=1
         Endif
         If WDEFLOCTYP3<>"" & !instr(1,WDEFLOCTYP3,'*')&!instr(1,WDEFLOCTYP3,'?')
&                           & !instr(1,WDEFLOCTYP3,'!')&!instr(1,WDEFLOCTYP3,'#')
            WT3=1
         Endif
         # WLOCFLT contient la valeur max des catégories d'emplacement (3,4 ou 5)
         WLOCFLT = max([F:TRU]LOCFLT)

         #--- Issue 102809 by TS
         # Si emplacement local paramétré dans la règle et OF / EO ou sortie OF / EO
         # on a déjà traité le type et l'emplacement de rupture
         If min([F:TRU]LOCFLT(0..WNBL-1))=2 & (find([M:ALP]VCRTYP,10,36) | find([M:ALP]TRSTYP,6,29))
            Goto FILTRE_STOCK_SUI
         Endif
         #---

         # Exploitation des règles d'allocation pour déterminer
         # le type ou l'emplacement de rupture
         Gosub ALI_LOCATION

      Endif

   # Si on a au moins une fois 'pas de filtre'
   Else
      Raz WCRITSTO3
   Endif
# Si pas de règle d'allocation
Else
   Raz WCRITSTO3
Endif

#--- Issue 102809 by TS
$FILTRE_STOCK_SUI

# Constitution finale du filtre emplacement
If WCRITSTO3=""
   WCRITSTO3=WCRIT
Else
   WCRITSTO3=WCRIT+WCRITSTO3+')'
Endif
Raz WCRIT

If [M:ALP]PECCUNLOK<>2
   WCRITSTO3+='&[F:STO1]CUNLOKFLG<>2'
Endif
# Filtre sur dépôt ligne document
If GWRHACT=2
   If [M:ALP]WRH<>""
      WCRITSTO3+='&[F:STO1]WRH=[M:ALP]WRH'
      # Alimentation dépôt rupture
      WSHTWRH=[M:ALP]WRH
   # Filtre sur dépôt article-site si exclusif
   Else
      LSST=0
      # Sous-traitance
      If (find([M:ALP]VCRTYP,10,12) & [M:ALP]PECSCOLOC=2)
&       |(find([M:ALP]VCRTYP,3,4)   & [M:ALP]TRSTYP=20)
&       |([M:ALP]VCRTYP=34          & [M:ALP]LOCCAT=4)
          LSST=1
      Endif
      Call WRHAUTO([M:ALP]STOFCY,[M:ALP]ITMREF,[M:ALP]VCRTYP,LSST,LWRH)
&          From STKWRH
      If !find(LWRH,"","*")
         WCRITSTO3+='&pat([F:STO1]WRH,LWRH)'
         # Alimentation dépôt rupture si pas de joker
         If !instr(1,LWRH,'*') & !instr(1,LWRH,'?')
&         & !instr(1,LWRH,'!') & !instr(1,LWRH,'#')
            WSHTWRH=LWRH
         Endif
      Endif
   Endif
Endif

Return

#-----------------------------------------------------------#
# Récupération types emplacement ou emplacement par défaut  #
# de l'article-dépôt ou article-site pour le type mouvement #
#-----------------------------------------------------------#
$ALI_DEFLOC

Local Char WABR
Raz I

# Si gestion de dépôt et emplacements par défaut gérés sur article-dépôt
If GWRHACT=2 & [F:ITW]LOCDEFFLG=2
   WABR="[F:ITW]"
# Sinon emplacements par défaut gérés sur article-site
Else
   WABR="[F:ITF]"
Endif

# Si emplacement 1 renseigné
If [F:SRU]LOCNUM<>1
   If WABR="[F:ITW]"
      I = find([F:SRU]LOCNUM-1,[F:ITW]LOCNUM(0..dim([F:ITW]LOCNUM)-1))
   Else
      I = find([F:SRU]LOCNUM-1,[F:ITF]LOCNUM(0..dim([F:ITF]LOCNUM)-1))
   Endif
   If I<>0
      WDEFLOC    = evalue(WABR+"DEFLOC(I-1)")
      WDEFLOCTYP = evalue(WABR+"DEFLOCTYP(I-1)")
      If WDEFLOC="" WDEFLOC="*" Endif
      If WDEFLOCTYP="" | WDEFLOC<>"*" WDEFLOCTYP="*" Endif
   Else
      WDEFLOC   ="*"
      WDEFLOCTYP="*"
   Endif
Endif
# Si emplacement 2 renseigné
If [F:SRU]LOCNUM2<>1
   If WABR="[F:ITW]"
      I = find([F:SRU]LOCNUM2-1,[F:ITW]LOCNUM(0..dim([F:ITW]LOCNUM)-1))
   Else
      I = find([F:SRU]LOCNUM2-1,[F:ITF]LOCNUM(0..dim([F:ITF]LOCNUM)-1))
   Endif
   If I<>0
      WDEFLOC2    = evalue(WABR+"DEFLOC(I-1)")
      WDEFLOCTYP2 = evalue(WABR+"DEFLOCTYP(I-1)")
      If WDEFLOC2="" WDEFLOC2="*" Endif
      If WDEFLOCTYP2="" | WDEFLOC2<>"*" WDEFLOCTYP2="*" Endif
   Else
      WDEFLOC2   ="*"
      WDEFLOCTYP2="*"
   Endif
Endif
# Si emplacement 3 renseigné
If [F:SRU]LOCNUM3<>1
   If WABR="[F:ITW]"
      I = find([F:SRU]LOCNUM3-1,[F:ITW]LOCNUM(0..dim([F:ITW]LOCNUM)-1))
   Else
      I = find([F:SRU]LOCNUM3-1,[F:ITF]LOCNUM(0..dim([F:ITF]LOCNUM)-1))
   Endif
   If I<>0
      WDEFLOC3    = evalue(WABR+"DEFLOC(I-1)")
      WDEFLOCTYP3 = evalue(WABR+"DEFLOCTYP(I-1)")
      If WDEFLOC3="" WDEFLOC3="*" Endif
      If WDEFLOCTYP3="" | WDEFLOC3<>"*" WDEFLOCTYP3="*" Endif
   Else
      WDEFLOC3   ="*"
      WDEFLOCTYP3="*"
   Endif
Endif
Return

#---------------------------------------------#
# Exploitation des règles d'allocation pour   #
# déterminer le (type) emplacement de rupture #
#---------------------------------------------#
$ALI_LOCATION

# Pas de (type)emplacement rupture si un des couples type/emp vaut "*"
If (I<>0 & WDEFLOC ='*' & WDEFLOCTYP ='*')
& |(J<>0 & WDEFLOC2='*' & WDEFLOCTYP2='*')
& |(K<>0 & WDEFLOC3='*' & WDEFLOCTYP3='*')
   WSHTLOC   =""
   WSHTLOCTYP=""
   Return
Endif

# Si uniquement catègorie emp 1, stockage rupture
If WLOCFLT=3
   If WE1=1
      WSHTLOC=WDEFLOC
   Elsif WT1=1
      WSHTLOCTYP=WDEFLOCTYP
   Endif
Elsif WLOCFLT=4
   # Si uniquement catègorie emp 2, stockage rupture
   If I=0
      # Stockage dans (type) emplacement de rupture
      If WE2=1
         WSHTLOC=WDEFLOC2
      Elsif WT2=1
         WSHTLOCTYP=WDEFLOCTYP2
      Endif
   Endif
Elsif WLOCFLT=5
   # Si uniquement catègorie emp 3, stockage rupture
   If I=0 & J=0
      # Stockage dans (type) emplacement de rupture
      If WE3=1
         WSHTLOC=WDEFLOC3
      Elsif WT3=1
         WSHTLOCTYP=WDEFLOCTYP3
      Endif
   Endif
Endif

Return

