######################################################################################
Subprog IB_NBLIG

  # FGR 31/03/2015 : X3SUIVI107383
  If GREP <> "" Then
    Raz GBOUT1
  Else
    If [M:AIN0]TBOBJ([M]BPATYP(nolign-1)) <> "" Then
      GBOUT1 = mess([M]BPATYP(nolign-1),943,1)
    Endif
  Endif
End

