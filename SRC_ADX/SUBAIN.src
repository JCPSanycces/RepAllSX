#<AdxTL>@(#)2.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV
Call OBJET("AIN",GBIDC1,GBIDC2) From GOBJET
End


$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBAINB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "VERIF_CRE" : Gosub VERIF_CRE
 When "INICRE"    : Gosub INICRE
 When "INIMOD"    : Gosub INIMOD
 When "APRES_CRE" : Gosub APRES_CRE
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "BB1_NBLIG"   : Gosub BB1_NBLIG     # FGR 31/03/2015 : X3SUIVI107383
 When "APRES_MODIF" : Gosub APRES_MODIF   # FGR 31/03/2015 : X3SUIVI107383
Endcase
If PSUBB
 Gosub ACTION From SUBAINB
Endif
Case ACTION
 When "LIENS"     : Gosub AP_LIENS
Endcase
Return

##########################################################################################################
$APRES_MODIF
  # FGR 31/03/2015 : X3SUIVI107383
  If dim (GSAM107383) >= 0 Then
    Kill GSAM107383
    Gosub RELIT From GOBJSUB
    OK = 0
  Endif
Return

##########################################################################################################
$BB1_NBLIG
  # FGR 31/03/2015 : X3SUIVI107383
  Global Integer GSAM107383
  mkstat = 4
Return



$OUVRE
If clalev([F:AIN2])=0 : Local File CONTACTCRM [AIN2] : Endif
Local Char    CLEREC(80) , MESSA(80)
Local Integer WOK
Return

$VERIF_CRE
MESSA = mess(179,133,1) : # Confirmez_vous la création
Goto VERIF

$VERIF_MOD
MESSA = mess(180,133,1) : # Confirmez-vous la modification
Goto VERIF

$VERIF
CLEREC = func CLE([M:AIN0]CNTLNA,[M:AIN0]CNTFNA)
Read [AIN2]AIN1 = CLEREC
If !fstat
 WOK = 1
 # Interlocuteur déjà existant
 Call OUINON(mess(178,133,1)+"\"+[F:AIN2]CNTNUM-[F:AIN2]CNTLNA-[F:AIN2]CNTFNA+"\"+MESSA,WOK) From GESECRAN
 If WOK<>2
  OK = 0 : Return
 Endif
Endif
Return

$INICRE
If [M:AIN0]CNTNUM=""
 Repeat
  [F:AIN]CNTNUM = func COD([C]INTERLOC)
  [C]INTERLOC += 1
  Read [AIN2]AIN0 = [F:AIN]CNTNUM
 Until fstat
Endif
Gosub INIMOD
Return

$INIMOD
[F:AIN]CNTFULNAM = func CLE([F:AIN]CNTLNA,[F:AIN]CNTFNA)
[F:AIN]ADD(0) = [M:AIN2]ADD1
[F:AIN]ADD(1) = [M:AIN2]ADD2
[F:AIN]ADD(2) = [M:AIN2]ADD3
Return

$APRES_CRE
[M:AIN0]CNTNUM = [F:AIN]CNTNUM
Affzo [AIN0]CNTNUM
Return

$LIENS
nolign = 0
For [CNT]CNT1 Where CCNCRM=[F:AIN]CNTNUM
 If nolign>=dim([M:AIN3]BPANUM)
  Call ERREUR(mess(26,100,1)) From GESECRAN : # Tableau plein
  Break
 Endif
 nolign += 1
 [M:AIN3] = [F:CNT]
Next CNT
[M:AIN3]NBLIG = nolign
Call C_CRY([F:AIN]CRY)
[M:AIN2]ADD1 = [F:AIN]ADD(0)
[M:AIN2]ADD2 = [F:AIN]ADD(1)
[M:AIN2]ADD3 = [F:AIN]ADD(2)
If [AIN1]CRY <> ""
 Read [TCY] TCY0 = [M:AIN1]CRY
 If !fstat
  Call LECTEXTRA([M:AIN1]CRYNAM,"TABCOUNTRY","CRYDES",[M:AIN1]CRY,"") From ATEXTRA
 Endif
Endif
Return

$AP_LIENS
For nolign=1 To [M:AIN3]NBLIG
 Call LIE
Next nolign
Return

Subprog LIE
Local Char OBJET(GLONAOB)
OBJET = [M:AIN0]TBOBJ([M:AIN3]BPATYP(nolign-1))
If OBJET<>""
 Gosub NOMFIC From ="WO"+OBJET
 If evalue("clalev([F:"+ABFIC+"])")<=0
  Gosub OUVFIC From ="WO"+OBJET
 Endif
 Call LECTURE(OBJET,[M:AIN3]BPANUM(nolign-1),"") From CONTOBJ
 If !fstat
  If OBJET <> "AUS"
   [M:AIN3]OBJNAM(nolign-1) = evalue("[F:"+ABFIC+"]"+NOMINT)
  Else
   #Call LECTEXTRA([M:AIN3]OBJNAM(nolign-1),"AUTILIS","INTUSR",[F]USR,"") From ATEXTRA                       # FGR 14/12/2014 : X3SUIVI113100
   Call LECTEXTRA([M:AIN3]OBJNAM(nolign-1),"AUTILIS","INTUSR",evalue("[F:"+ABFIC+"]USR"),"") From ATEXTRA    # FGR 14/12/2014 : X3SUIVI113100
  Endif
 Endif
Endif
End

$CREATION
$MODIF
For [CNT]CNT1 Where CCNCRM=[M:AIN0]CNTNUM
 WOK = 1
 For I=0 To [M:AIN3]NBLIG-1
  If [M:AIN3]BPATYP(I)=[F:CNT]BPATYP & [M:AIN3]BPANUM(I)=[F:CNT]BPANUM
   WOK = 0 : Break
  Endif
 Next I
 If WOK
  Delete [CNT]
  If fstat=1
   GOK = -1 : GLOCK = "$CONTACT"-mess([F:CNT]BPATYP,943,1)-[F:CNT]BPANUM-[M:AIN0]CNTNUM : Break
  Endif
 Endif
Next
If GOK<1 : Return : Endif
For nolign=1 To [M:AIN3]NBLIG
 If [M:AIN3]FLMOD(nolign-1)
  Readlock [CNT]CNT0 = [M:AIN3]BPATYP(nolign-1);[M:AIN3]BPANUM(nolign-1);[M:AIN0]CNTNUM
  If fstat=1
   GOK = -1 : GLOCK = "$CONTACT"-mess([M:AIN3]BPATYP(nolign-1),943,1)-[M:AIN3]BPANUM(nolign-1)-[M:AIN0]CNTNUM : Break
  Elsif fstat
   Raz [F:CNT]
   [F:CNT] = [M:AIN0]
   [F:CNT] = [M:AIN3]
   [F:CNT]CCNCRM = [F:AIN]CNTNUM
   #==>JPGA<== 22/04/2008 : Contact par défaut [F:CNT]CNTFLG supprimé de la table CONTACT
   #==>Le nom du contact par défaut CNTNAM a été remonté dans chaque table fonctionnelle (CPY/FCY/BPC/BPR/BPS/BPP/BPT)
   ##LSE 20/06/2006
   #If [F:CNT]CNTFLG<>1 and [F:CNT]CNTFLG<>2
   #     [F:CNT]CNTFLG=1
   #Endif
   If dim([F:CNT]CREUSR)>0 : [F:CNT]CREUSR = GUSER : Endif
   If dim([F:CNT]CREDAT)>0 : [F:CNT]CREDAT = date$ : Endif
   If dim([F:CNT]CRETIM)>0 : [F:CNT]CRETIM = time  : Endif
   Write [CNT]
  Else
   [F:CNT] = [M:AIN0]
   [F:CNT] = [M:AIN3]
   #==>JPGA<== 22/04/2008 : Contact par défaut [F:CNT]CNTFLG supprimé de la table CONTACT
   #==>Le nom du contact par défaut CNTNAM a été remonté dans chaque table fonctionnelle (CPY/FCY/BPC/BPR/BPS/BPP/BPT)
   ##LSE 20/06/2006
   #If [F:CNT]CNTFLG<>1 and [F:CNT]CNTFLG<>2
   #     [F:CNT]CNTFLG=1
   #Endif
   If dim([F:CNT]UPDUSR)>0 : [F:CNT]UPDUSR = GUSER : Endif
   If dim([F:CNT]UPDDAT)>0 : [F:CNT]UPDDAT = date$ : Endif
   If dim([F:CNT]UPDTIM)>0 : [F:CNT]UPDTIM = time  : Endif
   Rewrite [CNT]
  Endif
  If fstat
   GOK = 0 : Call FSTA("CNT") From GLOCK : Break
  Endif
 Endif
Next nolign
If GOK<1 : Return : Endif
Return

##########################################################################
## Fonctions
##########################################################################

Funprog CLE(NOM,PRENOM)
Value Char NOM
Value Char PRENOM
End vireblc(ctrans(toupper(NOM+"\"+PRENOM)),4)

Funprog COD(NOMBRE)
Value Decimal NOMBRE
End format$("N0:"+num$(GLONAIN)+"#",NOMBRE)

##########################################################################
## Ecran AIN0
##########################################################################
Subprog C_CNTNUM(VALEUR)
Variable Char VALEUR()
If VALEUR="" & [M]CNTNUM=""
 If !GIMPORT : mkstat = 4 : Endif
 End
Endif
If num$(val(VALEUR))=VALEUR
 Read [AIN2]AIN0 = VALEUR
 If fstat
  VALEUR = func COD(val(VALEUR))
 Endif
Endif
End

##########################################################################
## Ecran AIN1
##########################################################################
Subprog AS_CRY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]CRYNAM=""
 VALEUR = GPAYS
Endif
End

Subprog C_CRY(VALEUR)
Value Char    VALEUR()
Call LECTURE("TCY",VALEUR,"") From CONTOBJ
Gosub TITRES From W1AIN2
If dim([M]SAT)>0
 If [F:TCY]ETAT<>2
  Effzo [AIN2]SAT
  Grizo [AIN2]SAT
 Else
  Actzo [AIN2]SAT
 Endif
Endif
If VALEUR<>""
 Diszo [AIN1]CRYNAM
Else
 Actzo [AIN1]CRYNAM
Endif
End

Subprog AS_CNTLAN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Call LECTURE("TCY",[M]CRY,"") From CONTOBJ
 VALEUR = [F:TCY]LAN
Endif
End

##########################################################################
## Ecran AIN3
##########################################################################
Subprog APRES_NBLIG
If status<>6
 [M]FLMOD(nolign-1) = 1
Endif
End

Subprog AS_BPATYP(VALEUR)
Variable Integer VALEUR
Local Integer I
For I=1 To len(mess(0,943,1))
 If [M:AIN0]TBOBJ(I)=""
  GMENLOC(I) = 1
 Endif
Next I
End

Subprog C_BPANUM(VALEUR)
Variable Char    VALEUR()
Local Char    OBJET(GLONAOB)
Local Integer NOL , I , OK , FLDINT
Local File ATABZON [ATZ]

NOL = nolign-1
OK  = 1
For I=0 To [M]NBLIG-1
 If I<>NOL & [M]BPATYP(I)=[M]BPATYP(NOL) & [M]BPANUM(I)=VALEUR
  GMESSAGE = mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
  OK = 0 : Break
 Endif
Next I
If !OK
 mkstat = 2 : End
Endif
OBJET = [M:AIN0]TBOBJ([M]BPATYP(nolign-1))
# Issue X3-46827 - 2017-07-05 by CCC : with GAC it's not possible to control and to get description as it needs COA(chart account) value
If OBJET<>"" & OBJET<>"GAC"
 # Issue X3-46827 - 2017-07-05 by CCC : Open linked table before to read
 Gosub NOMFIC From ="WO"+OBJET
 If evalue("clalev([F:"+ABFIC+"])")<=0
  Gosub OUVFIC From ="WO"+OBJET
 Endif
 Call LECTURE(OBJET, VALEUR, "") From CONTOBJ
 If fstat
  GMESSAGE =VALEUR-mess(00023,00100,1) : # FICHE INEXISTANTE
  mkstat = 2 : End
 Endif
 [M]OBJNAM(nolign-1) = func AFNC.INTCLE(OBJET,VALEUR)
 Affzo OBJNAM(nolign-1)
Endif
End

$ERRNAM
[M]OBJNAM(nolign-1) = ""
Resume

