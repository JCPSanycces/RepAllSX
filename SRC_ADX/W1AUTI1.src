#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque AUTI1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:01:57"
A_USER  = "DOC"
A_STAMP = "20181109230157"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask AUTI1 [AUTI1]
Gosub HORODAT
Local Inpbox "AUTI1" From GFONCTION At A_STAMP With A_WINDPREV Mask [AUTI1] As [SIM_]
Grizo [AUTI1]5
Grizo [AUTI1]10
Grizo [AUTI1]15
Grizo [AUTI1]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [AUTI1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=104 : Y1(0)=1 : Y2(0)=3
X1(1)=1 : X2(1)=104 : Y1(1)=4 : Y2(1)=13
X1(2)=1 : X2(2)=104 : Y1(2)=14 : Y2(2)=15
X1(3)=1 : X2(3)=104 : Y1(3)=16 : Y2(3)=25
Return

$ON_UTICOD
Onevent CONTROL Call C_UTICOD(zc) From W1AUTI1
Return

Subprog C_UTICOD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "UTICOD" : GZNUM = 5296 : Endif
If !mkstat
 ## Action CONTOBJW
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJW"
 PARMSK(1) = "AUTI"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJW","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "UTICOD" : GZNUM = 5296 : Endif
Endif
Gosub _AFF
End

$ON_UPDATEFLG
Onevent INIT_AREA Call D_UPDATEFLG(zc) From W1AUTI1
Return

Subprog D_UPDATEFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]UPDATEFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_MODULE
Onevent INIT_AREA Call D_MODULE(zc) From W1AUTI1
Onevent BEFORE_INPUT Call AS_MODULE(zc) From W1AUTI1
Onevent CONTROL Call C_MODULE(zc) From W1AUTI1
Return

Subprog D_MODULE(VALEUR)
Variable Integer VALEUR
If varinit([M]MODULE,indice)=0
 VALEUR = 10
Endif
Gosub _AFF
End

Subprog AS_MODULE(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_MODULE(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "MODULE" : GZNUM = 943 : Endif
Gosub _AFF
End

$ON_CODACT
Onevent CONTROL Call C_CODACT(zc) From W1AUTI1
Onevent BEFORE_INPUT Call AS_CODACT(zc) From W1AUTI1
Onevent AFTER_CHANGE Gosub AMM_CODACT From W1AUTI1
Return

Subprog AS_CODACT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(186,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CODACT(zc) From W1AUTI1
Onkey   2 Titled GBOUTS Call S_CODACT(zc) From W1AUTI1
Onkey 144 Titled GBOUTP Call P_CODACT(zc) From W1AUTI1
Onkey 146 Titled GBOUTA Call SA_CODACT(zc) From W1AUTI1
Gosub _AFF
End

Subprog C_CODACT(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("ACV","!F",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "CODACT" : GZNUM = 4 : Endif
Gosub _AFF
End

$AMM_CODACT
Call AM_CODACT(zc)
If !mkstat & GOBJET
 zoncou = "CODACT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CODACT(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCODACT)")>indice
 [M]CODACT(indice) = VALEUR
 Affzo ZCODACT(indice)
Endif
Gosub _AFF
End

Subprog S_CODACT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "ACV"
PARMSK(2) = "!F"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_CODACT(VALEUR)
Variable Char    VALEUR()
Call OBJET("ACV",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_CODACT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ACV"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CODACT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("ACV",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCODACT
Onevent BEFORE_AREA Gosub AV_ZCODACT From W1AUTI1
Return

$AV_ZCODACT
If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
Call LECTURE("ACV",[M]CODACT(indice),"") From CONTOBJ
Call TEXTE([F:ACV]LIBACT,zc) From OBJDIV
Gosub _AFF
Return

$ON_SCRIPT
Onevent BEFORE_INPUT Call AS_SCRIPT(zc) From W1AUTI1
Onevent CONTROL Call C_SCRIPT(zc) From W1AUTI1
Return

Subprog IB_SCRIPT(VALEUR)
Variable Char    VALEUR()
## Action STD
Call IB_SCRIPT From SUBAUTI
Gosub _AFF
End

Subprog AS_SCRIPT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(21870,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_SCRIPT(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_SCRIPT(zc) From W1AUTI1
Onkey   2 Titled GBOUTS Call S_SCRIPT(zc) From W1AUTI1
Gosub _AFF
End

Subprog C_SCRIPT(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "SCRIPT" : GZNUM = 51546 : Endif
Gosub _AFF
End

Subprog S_SCRIPT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADC
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADC"
 Call S_TAB_CHAR(VALEUR,PARMSK,"","SUBADC","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_SCRIPT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TRTADC
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "TRTADC"
 PARMSK(1) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"EDITION","SUBADC","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

