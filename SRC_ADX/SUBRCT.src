#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion objet RCT
Raz GPILOBJ
Call OBJET("RCT",GBIDC1,GBIDC2) From GOBJET
End

#####################################################################################
$ACTION
Case ACTION
  When "OUVRE" : Gosub OUVRE
  When "FERME" : Gosub FERME
  When Default
Endcase
Return

$OUVRE
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG : Endif
GCURLEG = "FRA" #this screen is only for French legislation
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

######################################################################################
## Etiquette REPCUMTDS
######################################################################################
Subprog C_VRA(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]VRA(0..[M]NBRVRA-1)) From OBJDIV
End
