# < DEBUG> ######################################################################################################
Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS( WDOSSIER, "UTITRS28 - Migration of FUPGRP table" ) From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE( "UTITRS28 - Migration of FUPGRP table - MANUAL START" ) From LECFIC
  Call MAJ_UTITRS28(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End
# </DEBUG> ######################################################################################################


########################################################################
Subprog MAJ
#** Called from DOSMAJ81
#*!
  Call MAJ_UTITRS28([F:ADS]DOSSIER)
End

##########################################################################
Subprog MAJ_UTITRS28( DOSSIER )
Value Char DOSSIER
    Local Integer COUNT : Raz COUNT

    Call ECR_TRACE( "UTITRS28 : Start of process on:" - DOSSIER, 0 ) From GESECRAN

    #----- Open tables -----#
    If clalev([F:FGP])=0  : Local File =DOSSIER+".FUPGRP" [FGP] : Endif

    Call DEBTRANS From GLOCK
    Trbegin [F:FGP]
    If dim( [F:FGP]FUPFRY )

        For [F:FGP] Where FUPFRY < 1
            [F:FGP]FUPFRY = 1
            Rewrite [F:FGP]
            If !fstat COUNT += 1 Endif
        Next
    Endif
    If dim( [F:FGP]FUPBALTRS )
        For [F:FGP] Where FUPBALTRS < 1
            [F:FGP]FUPBALTRS = 1
            Rewrite [F:FGP]
            If !fstat COUNT += 1 Endif
        Next
    Endif
    Commit

    Close Local File [F:FGP]
    Call ECR_TRACE( "UTITRS28:" -num$(COUNT) - "reminder group records updated.", 0 ) From GESECRAN

    # TODO (ALL): Insert your migration scripting here for PU 11.0.1.
    # ...
End


########################################################################
# For auto-execution in patches                                        #
########################################################################

Subprog PATCH( DOSSIER )
Value Char DOSSIER

    If DOSSIER = GDOSX3 : End : Endif

    If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
    If func DOSSUB.FILL_ADS( DOSSIER )=0 : End : Endif

    Read [F:ADS]DOSSIER = DOSSIER
    If fstat Raz [F:ADS] : Endif
    If [F:ADS]MODULE(2) <> 2 : End : Endif
    If filinfo(filpath("FIL","FUPGRP","fde",DOSSIER),0) <= 0 : End : Endif
    If func DOSVUE.ISVIEW( DOSSIER, "FUPGRP" ) : End : Endif                  : # For Archive folder

    Call MAJ_UTITRS28( DOSSIER )
End


#######################################################################
# To be executed during DOSMAJxx process (folder validation)
# Called by DOSMAJxx
########################################################################
Subprog UTI_MOUL( DOSSIER )
Value Char DOSSIER

    If DOSSIER = GDOSX3 : End : Endif

    If [F:ADS]MODULE(2) <> 2 : End : Endif
    If filinfo(filpath("FIL","FUPGRP","fde",DOSSIER),0) <= 0 : End : Endif
    If func DOSVUE.ISVIEW( DOSSIER, "FUPGRP" ) : End : Endif                  : # For Archive folder

    Call MAJ_UTITRS28( DOSSIER )
End

