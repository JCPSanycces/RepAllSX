#*!

Raz GPILBOITE
GUSRAUZ(1) = "1356"
GFONCTION  = "TRTGEN"
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTGEN","TRTGEN",4,"") From GTRAITE
End

#########################################
## Traitement des actions : TRTGEN
#########################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVFIC From TRTTPS
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 #: GOK = 0
 When "DEBUT"       : Gosub DEBUT
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

#######################################################
## (Actions nécessaires à la saisie des paramètres)
#######################################################
$OUVRE
Gosub OUVFIC From TRTTPS
#LIPET - 24-11-2016 - X3PEOP-1248 - START
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If clalev([F:HRPEOD])=0  : Local File HRPEODET [HRPEOD]  : Endif
#LIPET - 24-11-2016 - X3PEOP-1248 - END
If clalev([F:CTR1])=0 : Local File EMPLOCTR [CTR1] : Endif
If clalev([F:DCG])=0  : Local File DEMCONGE [DCG]  : Endif

Local Integer NBPCE
Local Char    CRITERE(250)
Local Char    CRITERE1(250)
Local Char    TIT(50)
Local Char    MESSA(50)
Local Char    SYMBOLE(50)
Local Date    DATDEB , DATFIN
Local Integer I , J , K , OK , OKC , OPT

TIT = mess(14,10709,1)     : # Arrêté des temps
NBPCE=0

Local Mask TRTGEN [DIA]
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","gen") From GMEMO

If !instr(1,GUSRAUZ(1),"1") : # Tous utilisateurs
 Call PARAMUTIL("REFNUM",[M]MATDEB,GUSER,"") From SUBAUS
 If [M]MATDEB=""
  GERR = 2 : FIN = 1
  # Pas d'accès
  GMESSAGE = mess(1,85,1)
  Return
 Endif
 [M]MATFIN = [M]MATDEB
Endif
Return

$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#######################################################
## Saisie fenêtre
#######################################################

$DEBUT
If !instr(1,GUSRAUZ(1),"1") : # Tous utilisateurs
 Diszo MATDEB, MATFIN
Else
 Actzo MATDEB, MATFIN
Endif
Affzo [DIA]
Setmok [DIA] With 0
#MIPEA - 2016-01-05- X3-11593- START
If [M:DIA]LEG<>""
  GCURLEG = [M:DIA]LEG
Endif
#MIPEA - 2016-01-05- X3-11593- END
Return

#######################################################
## Contrôle des paramètres
#######################################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

#######################################################
## Exécution silencieuse du traitement
#######################################################
$EXEC

Local Date    DATFINPAY , DATPAY , DATMAT
Local Integer RETOUR , OK
#JASMI
#Local Char    MATCUR(GLONMAT) , MATREF(GLONMAT) , MATRI(GLONMAT) , SYMBOLE(50), CTR(GLONCTR)
Local Char    MATCUR(GLONEML) , MATREF(GLONEML) , MATRI(GLONEML) , SYMBOLE(50), CTR(GLONHRCTR)
#JASMI

#ADNGO - 22-02-2017 - X3PEOP-1248 - START
#Call LECTURE("TIM",[M:DIA]TIM,"") From CONTOBJ
Call LECTURE("HRTIM",[M:DIA]TIM,GCURLEG) From CONTOBJ
#ADNGO - 22-02-2017 - X3PEOP-1248 - END

#ouverture de la trace et écriture de l'en-tête
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

# mise en place du filtre
CRITERE = "[F:ID]ENAFLG=2 & [F:ID]FLGTPS=2"
If [M:DIA]ALLCPY<>2  #société
 CRITERE -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2  #site
 CRITERE -= '& [F:HRCTR]ETRFCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]MATDEB<>"" #borne début matricule
 CRITERE -= '& [F:HRCTR]REFNUM>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITERE -= '& [F:HRCTR]REFNUM<="'+[M:DIA]MATFIN+'"'
Endif

#filtre sur critere contrat
# On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
CRITERE1  = '(([F:HRCTR]FLGRET<>2 &[F:HRCTR]CTRDAT<=['+format$(GFMD,[M:DIA]DATFIN)+']) | ([F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<=['+format$(GFMD,[M:DIA]DATFIN)+']))'
CRITERE1 -= ' & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=['+format$(GFMD,[M:DIA]DATDEB)+'])'
# FQ85820 - 30/04/13 - La vérification se fait maintenant dans VERIF_FLD, selon la rétroactivité
#If [M:DIA]ALLSRV<>2  #service
# CRITERE1 -= '& [F:CTR]ETRSRV = "'+[M:DIA]SRV+'"'
#Endif
#If [M:DIA]ALLPRF<>2  #profil
# CRITERE1 -= '& [F:CTR]PROPRF = "'+[M:DIA]PRF+'"'
#Endif
# Fin FQ85820

#MIPEA - 2017-01-23- X3-LEG Addition Process Functions- START
If [M:DIA]POP<>""
 Link [HRCTR] With
&   [ID]ID0   = [F:HRCTR]REFNUM
& , [FCY]FCY0 = [F:HRCTR]ETRFCY
& , [CPY]CPY0 = [F:FCY]LEGCPY
& , [POA]POA0 = [M:DIA]POP;[F:HRCTR]REFNUM
&   As [LNK]
&   Where evalue(CRITERE1) & evalue(CRITERE) & [F:POA]REFNUM<>"" & [F:FCY]LEG=GCURLEG
Else
 Link [HRCTR] With
&   [ID]ID0   = [F:HRCTR]REFNUM
& , [FCY]FCY0 = [F:HRCTR]ETRFCY
& , [CPY]CPY0 = [F:FCY]LEGCPY
&   As [LNK]
&   Where evalue(CRITERE1) & evalue(CRITERE) & [F:FCY]LEG=GCURLEG
Endif
#If [M:DIA]POP<>""
# Link [HRCTR] With
#&   [ID]ID0   = [F:HRCTR]REFNUM
#& , [FCY]FCY0 = [F:HRCTR]ETRFCY
#& , [CPY]CPY0 = [F:FCY]LEGCPY
#& , [POA]POA0 = [M:DIA]POP;[F:HRCTR]REFNUM
#&   As [LNK]
#&   Where evalue(CRITERE1) & evalue(CRITERE) & [F:POA]REFNUM<>""
#Else
# Link [HRCTR] With
#&   [ID]ID0   = [F:HRCTR]REFNUM
#& , [FCY]FCY0 = [F:HRCTR]ETRFCY
#& , [CPY]CPY0 = [F:FCY]LEGCPY
#&   As [LNK]
#&   Where evalue(CRITERE1) & evalue(CRITERE)
#Endif
#MIPEA - 2017-01-23- X3-LEG Addition Process Functions- END

# Traitement
For [LNK]
 # FQ85820 - 30/04/13 - Vérification profil/service selon rétroactivité
 #MIPEA - 2016-12-02 - X3-11593- START
  If func SUBCTRRET.VERIF_FLD([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,[M:DIA]DATFIN,"ETRSRV",[M:DIA]ALLSRV,[M:DIA]SRV,"HRCTR")=2
& & func SUBCTRRET.VERIF_FLD([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,[M:DIA]DATFIN,"PROPRF",[M:DIA]ALLPRF,[M:DIA]PRF,"HRCTR")=2 Then
# If func SUBCTRRET.VERIF_FLD([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,[M:DIA]DATFIN,"ETRSRV",[M:DIA]ALLSRV,[M:DIA]SRV,"CTR")=2
#& & func SUBCTRRET.VERIF_FLD([F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,[M:DIA]DATFIN,"PROPRF",[M:DIA]ALLPRF,[M:DIA]PRF,"CTR")=2 Then
#MIPEA - 2016-12-02 - X3-11593- END
 # Fin FQ85820
   MATRI = [F:ID]REFNUM
   CTR   = [F:HRCTR]CTRNUM
   Gosub TRTCONT
   # FQ74044 - 13/02/12 - Ajout vérification du nouveau champ FILTRE
   If OK & ([F:TIM]FILTRE<>""  | [F:TIM]POP<>"")Then
    Local Integer RET
    Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,MATRI,CTR,RET) From DIVPAYE
    If RET>0 Then OK=0 : Endif
   Endif
   # Fin FQ74044
   If OK
    Gosub GENERE
    Unlock =SYMBOLE
   Endif
 Endif
Next

If !NBPCE
#LIPET - 24-11-2016 - X3PEOP-1248 - START
 #Call ECR_TRACE(mess(2,703,1),0) From GESECRAN : # Aucun matricule à traiter
 Call ECR_TRACE(mess(2,10703,1),0) From GESECRAN : # Aucun matricule à traiter
 #LIPET - 24-11-2016 - X3PEOP-1248 - END
Else
#LIPET - 24-11-2016 - X3PEOP-1248 - START
# Call ECR_TRACE(mess(117,703,1)-":"-num$(NBPCE),0) From GESECRAN : # Nombre de salariés concernés
 Call ECR_TRACE(mess(117,10703,1)-":"-num$(NBPCE),0) From GESECRAN : # Nombre de salariés concernés
#LIPET - 24-11-2016 - X3PEOP-1248 - END
Endif

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

################################################################################
## Accès à un salarié dans les traitements
################################################################################
Subprog CONTROLE_DIV(MATRI,DATMAT,CTR,CRI,OK,FLG)
Value    Char    MATRI()
Value    Date    DATMAT
Value    Char    CRI()
Value    Char    CTR()
Variable Integer OK
Value    Integer FLG

OK = 1
If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif

## Flag actif

If [F:ID]ENAFLG<>2 & FLG=1
 OK = 0 : End
Endif

#pas [CTR] en ligne lors du Call Controle depuis le TRTCAL
#Pour être sur de toujours avoir [f:ctr] en ligne lors du contrôle des droits par site & service (Cf. +bas)
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
If CTR<>''
 Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & (CTRDAT<=DATMAT | (FLGRET=2 & RETDATEFF<=DATMAT))
Else
 Filter [HRCTR] Where REFNUM=MATRI & (CTRDAT<=DATMAT | (FLGRET=2 & RETDATEFF<=DATMAT))
Endif
Read [HRCTR]CTR1 Last
If fstat : Raz [F:HRCTR] : Endif
Filter [HRCTR]


# Critère libre
If CRI<>""
 Gosub OUVRE From DEFTABLE
 Gosub LECEMP From DEFTABLE
 If !evalue(CRI)
  OK = 0 : End
 Endif
Endif

# Code d'accès

If [F:ID]CODACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:ID]CODACS
 If fstat or [F:ACC]EXEC<>2
  OK = 0 : End
 Endif
Endif

# Droits par sites
If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 # FQ85820 - 02/05/13 - On cherche si on a une fiche de rétroactivité relative au champ ETRSRV
# If !find([F:CTR]ETRFCY,GUSRFCY(1..GNBAUZ))
 If !find(func SUBCTRRET.FIND_RETRO_FLD(MATRI,HRCTR,[F:HRCTR]CTRDAT,DATMAT,"ETRFCY","HRCTR"),GUSRFCY(1..GNBAUZ))
  OK = 0 : End
 Endif
Endif

# Droits par service
# FQ85820 - 02/05/13 - On cherche si on a une fiche de rétroactivité relative au champ ETRSRV
#If GUSRACS<>2 & !find([F:CTR]ETRSRV,GAUTSRV(1..GNBSERV))
If GUSRACS<>2 & !find(func SUBCTRRET.FIND_RETRO_FLD(MATRI,HRCTR,[F:HRCTR]CTRDAT,DATMAT,"ETRSRV","HRCTR"),GAUTSRV(1..GNBSERV))
 OK = 0 : End
Endif

End

#######################################
$TRTCONT
Local Char    LESITE(GLONFCY) : #59323

OK = 0
# FQ85820 - Utilisation de la date de rétroactivité, et comme DIVPAYE.CONTROLEest appelé partout, surchargement
# d'un sous-pro ici
Call CONTROLE_DIV([F:ID]REFNUM,[M:DIA]DATDEB,CTR,[M:DIA]CRI,OKC,1)
If !OKC : Return : Endif

## Date de paye

DATPAY = [0/0/0]
LESITE = [F:HRCTR]ETRFCY
#MIPEA - 2016-12-02 - X3-11593- START
Call PERIO(LESITE,[F:ID]REFNUM) From SUBHRPEO
#Call PERIO(LESITE,[F:ID]REFNUM) From SUBPEO
#MIPEA - 2016-12-02 - X3-11593- END

#MIPEA - 2016-12-02 - X3-11593- START
If GTPS
 If [F:TIM]MONDAC=2
  Filter [HRPEOD] Where PERSTR(0) <= [M:DIA]DATDEB & PEREND(1) >= [M:DIA]DATFIN
& &                     PERCOD=[F:HRCTR]PERCOD
&              Order By Key CLE=PERCOD Desc;PYRDAT Desc
 Else
  Filter [HRPEOD] Where PERSTR(0) <= [M:DIA]DATDEB & PEREND(0) >= [M:DIA]DATFIN
& &                     PERCOD=[F:HRCTR]PERCOD
&              Order By Key CLE=PERCOD Desc;PYRDAT Desc
 Endif
Else
  Filter [HRPEOD] Where PERSTR(1) <= [M:DIA]DATDEB & PEREND(1) >= [M:DIA]DATFIN
& &                     PERCOD=[F:HRCTR]PERCOD
&              Order By Key CLE=PERCOD Desc;PYRDAT Desc
Endif
#If GTPS
# If [F:TIM]MONDAC=2
#  Filter [HRPEOD] Where PERSTR(0) <= [M:DIA]DATDEB & PEREND(1) >= [M:DIA]DATFIN
#&                  & find(FCY,"",[L]LESITE)<>0
#&              Order By Key CLE=FCY Desc;PYRDAT Desc
# Else
#  Filter [HRPEOD] Where PERSTR(0) <= [M:DIA]DATDEB & PEREND(0) >= [M:DIA]DATFIN
#&                  & find(FCY,"",[L]LESITE)<>0
#&              Order By Key CLE=FCY Desc;PYRDAT Desc
# Endif
#Else
#  Filter [HRPEOD] Where PERSTR(1) <= [M:DIA]DATDEB & PEREND(1) >= [M:DIA]DATFIN
#&                  & find(FCY,"",[L]LESITE)<>0
#&              Order By Key CLE=FCY Desc;PYRDAT Desc
#Endif
#MIPEA - 2016-12-02 - X3-11593- END

Read [HRPEOD]CLE First
If !fstat
  DATPAY = [F:HRPEOD]PYRDAT
Endif
Filter [HRPEOD]

If DATPAY=[0/0/0] : Return : Endif

# FQ85820 - 29/04/13 - On cherche si on a une fiche de rétroactivité relative au champ PLNTYP
#If [F:CTR]PLNTYP=""

If func SUBCTRRET.FIND_RETRO_FLD([F:ID]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,DATPAY,"PLNTYP","HRCTR")=""
 #Opération impossible : Salarié sans planning
 #LIPET - 24-11-2016 - X3PEOP-1248 - START
# Call ECR_TRACE(mess(157,123,1)-":"-MATRI-mess(124,709,1),1) From GESECRAN
 Call ECR_TRACE(mess(157,123,1)-":"-MATRI-mess(124,10709,1),1) From GESECRAN
 #LIPET - 24-11-2016 - X3PEOP-1248 - END

 Return
Endif
#MIPEA - 2016-12-02 - X3-11593- START
If GTPS & [F:HRPEOD]STA<>2 & (!instr(1,GUSRAUZ(1),"5") | !instr(1,GUSRAUZ(1),"6"))
#If GTPS & [F:PEO]STA<>2 & (!instr(1,GUSRAUZ(1),"5") | !instr(1,GUSRAUZ(1),"6"))
#MIPEA - 2016-12-02 - X3-11593- START
 # Opération impossible : Période non ouverte
 #LIPET - 24-11-2016 - X3PEOP-1248 - START
 Call ECR_TRACE(num$([F:HRPEOD]PYRDAT)-mess(157,123,1)-":"-mess(58,10709,1),1) From GESECRAN
# Call ECR_TRACE(num$([F:PEO]PYRDAT)-mess(157,123,1)-":"-mess(58,709,1),1) From GESECRAN
 #Call ECR_TRACE(num$([F:PEO]PYRDAT)-mess(157,123,1)-":"-mess(58,10709,1),1) From GESECRAN
#LIPET - 24-11-2016 - X3PEOP-1248 - END
#MIPEA - 2016-12-02 - X3-11593- END
 Return
Endif
If GPAYE & !instr(1,GUSRAUZ(1),"3") : # Saisie sur paye calculée
 Filter [VEP] Where EMP=[F:ID]REFNUM & CTRNUM=CTR & PYRDAT=[F:HRPEOD]PYRDAT
 Read [VEP]VEP0 Last
 Filter [VEP]
 If !fstat & [F:VEP]STA>=2
  # Opération impossible :  Paye déjà calculée
#MIPEA - 2016-12-02 - X3-11593- START
  #LIPET - 24-11-2016 - X3PEOP-1248 - START
  Call ECR_TRACE([F:ID]REFNUM-num$([F:HRPEOD]PYRDAT)-mess(157,123,1)-":"-mess(15,10709,1),1) From GESECRAN
  #Call ECR_TRACE([F:ID]REFNUM-num$([F:PEO]PYRDAT)-mess(157,123,1)-":"-mess(15,709,1),1) From GESECRAN
  #Call ECR_TRACE([F:ID]REFNUM-num$([F:PEO]PYRDAT)-mess(157,123,1)-":"-mess(15,10709,1),1) From GESECRAN
   #LIPET - 24-11-2016 - X3PEOP-1248 - END
#MIPEA - 2016-12-02 - X3-11593- END
Return
 Endif
Endif

If GPAYE
 Filter [VEP] Where EMP=[F:ID]REFNUM & CTRNUM=CTR & PYRDAT=[F:HRPEOD]PYRDAT
 Read [VEP]VEP0 Last
 Filter [VEP]
 If !fstat  & [F:VEP]PST>1
#& | [F:VEP]FLGLOCK=2)   : # Pas de test sur Verrouillé US 2022 65062 met à jour des temps et déflag les flags temps des bulletins
  # Opération impossible :  Paye déjà comptabilisée
#  If [F:VEP]PST>1
#    Call ECR_TRACE([F:ID]REFNUM-num$([F:PEO]PYRDAT)-mess(157,123,1)-":"-mess(30,709,1),1) From GESECRAN
#  Elsif [F:VEP]FLGLOCK=2 : # Verrouillé US 2022 65062
#    # MESSAGE : Opération impossible : ce bulletin est verrouillé.
#    Call ECR_TRACE([F:ID]REFNUM-"("+mess(6,506,1)-CTR-mess(40,101,1)-format$(GFMD,[F:VEP]CTRDAT)+") :"-[F:VEP]BUL-format$(GFMD,[F:VEP]PYRDAT)-mess(224,703,1),1) From GESECRAN
#  Endif
    Call ECR_TRACE([F:ID]REFNUM-"("+mess(6,10506,1)-CTR-mess(40,101,1)-format$(GFMD,[F:VEP]CTRDAT)+") :"-[F:VEP]BUL-format$(GFMD,[F:VEP]PYRDAT)-mess(157,123,1)-":"-mess(30,10709,1),1) From GESECRAN
  Return
 Endif
Endif


# Verrou
If GPAYE
 #90728
 #SYMBOLE = "VEP"+format$("D:"+GFMDAT,DATPAY)+"\"+[F:ID]REFNUM+"\"+[F:VEP]CTRNUM+format$("D:"+GFMDAT,[F:VEP]CTRDAT)
 SYMBOLE = "VEP"+format$("D:"+GFMDAT,DATPAY)+"\"+[F:VEP]CTRNUM+format$("D:"+GFMDAT,[F:VEP]CTRDAT)
Else
 SYMBOLE = "TIP"+format$("D:"+GFMDAT4,DATPAY)+"\"+[F:ID]REFNUM
Endif
Lock =SYMBOLE
If fstat
 Call ECR_TRACE([F:ID]REFNUM-":"-mess(10,100,1),1) From GESECRAN
 Return
Endif

OK = 1
Return

################################################################################
## Traitement de génération
################################################################################
$GENERE
Local Integer PRE(1..50)
Local Integer NBJOUR , I1 , I2 #, FLGCTRL
Local Decimal JOUR(1..2) , HEURE(1..2)
Local Decimal DHEURE(1..42), DJOUR(1..42)
Local Date    DATDEBCTR

NBJOUR = [M:DIA]DATFIN-[M:DIA]DATDEB+1
## Jours de présence de l'employé
Raz PRE
For [CTR1]CTR1 Where REFNUM=MATRI & CTRNUM=CTR
 # FQ85820 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
 DATDEBCTR=[F:CTR1]CTRDAT
 If [F:CTR1]FLGRET=2 & [F:CTR1]RETDATEFF<>[0/0/0] Then
  DATDEBCTR=[F:CTR1]RETDATEFF
 Endif
 If ([F:CTR1]XITDAT=[0/0/0] |[F:CTR1]XITDAT>[M:DIA]DATFIN) & DATDEBCTR<=[M:DIA]DATFIN
  For I=max([M:DIA]DATDEB,DATDEBCTR)-[M:DIA]DATDEB+1 To [M:DIA]DATFIN-[M:DIA]DATDEB+1
    PRE(I) = 1
  Next I
 # FQ85820 - On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
 Elsif [F:CTR1]XITDAT>=[M:DIA]DATDEB & [F:CTR1]XITDAT<=[M:DIA]DATFIN
  For I=max([M:DIA]DATDEB,DATDEBCTR)-[M:DIA]DATDEB+1 To [F:CTR1]XITDAT-[M:DIA]DATDEB+1
   PRE(I) = 1
  Next I
 Endif
# Fin MABON
Next

## Contrôle des temps saisis sur la période
OK = 1
For [TIP]TIP1 Where REFNUM=MATRI and ENDDAT>=[M:DIA]DATDEB & STRDAT<=[M:DIA]DATFIN and CTRNUM=CTR
 #Création impossible : Evènement
 Call ECR_TRACE(MATRI-mess(7,123,1)-":"-mess(110,10709,1)-[F:TIP]TIM
& -format$("D:"+GFMDAT,[F:TIP]STRDAT)-"-"-format$("D:"+GFMDAT,[F:TIP]ENDDAT),1) From GESECRAN
 OK = 0
Next

If !OK : Return : Endif
## Création du ou des événements
Call DEBTRANS From GLOCK
Gosub TR1
Return

#######################################
$TR1
GOK = 1
Trbegin [TIP],[CNE],[TIC]
If clalev([F:CTRC])=0 : Local File EMPLOCTR [CTRC] : Endif
 I1 = find(1,PRE(1..NBJOUR))
 While I1>0
  I2 = I1
  While I2<NBJOUR & PRE(I2+1)=1
   I2 += 1
  Wend

  ## Mise à jour des temps
  Raz [F:TIP]
  [F:TIP]REFNUM = MATRI
  [F:TIP]CTRNUM = CTR
  [F:TIP]STRDAT = [M:DIA]DATDEB+I1-1
  [F:TIP]ENDDAT = [M:DIA]DATDEB+I2-1
  [F:TIP]DATPYR = DATPAY
  [F:TIP]LIG    = uniqid([F:TIP])
  [F:TIP]TIM    = [M:DIA]TIM
  [F:TIP]CMT    = [M:DIA]CMT
  If dim([F:TIP]CREDAT)>0 : [F:TIP]CREDAT = date$ : Endif
  If dim([F:TIP]CREUSR)>0 : [F:TIP]CREUSR = GUSER : Endif
  If dim([F:TIP]CRETIM)>0 : [F:TIP]CRETIM = time  : Endif
  # FQ82073 - Affectation date contrat sur le temps
  [F:TIP]CTRDAT = func TPSSTD.CALC_CTRDATDEF(MATRI,CTR,[F:TIP]ENDDAT,DATPAY,[F:TIP]ENDDAT,1)
  # FQ85820 - 29/04/13 - On cherche si on a une fiche de rétroactivité relative aux champs ETRFCY et ETRSRV
#  [F:TIP]FCY = [F:CTR]ETRFCY
#  Call LECTURE("FCY",[F:CTR]ETRFCY,"") From CONTOBJ
#  [F:TIP]CPY = [F:FCY]LEGCPY
#  [F:TIP]SRV = [F:CTR]ETRSRV
  Read [F:CTRC]CTR0=MATRI;CTR;[F:TIP]CTRDAT
  #MIPEA - 2016-12-02 - X3-11593- START
  [F:TIP]FCY=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:TIP]CTRDAT,DATPAY,"ETRFCY","CTRC")
#  [F:TIP]FCY=func SUBCTRRET.FIND_RETRO_FLD(MATRI,HRCTR,[F:TIP]CTRDAT,DATPAY,"ETRFCY","CTRC")
  #MIPEA - 2016-12-02 - X3-11593- START
  Call LECTURE("FCY",[F:TIP]FCY,"") From CONTOBJ
  [F:TIP]CPY = [F:FCY]LEGCPY
    #MIPEA - 2016-12-02 - X3-11593- START
    [F:TIP]SRV=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:TIP]CTRDAT,DATPAY,"ETRSRV","CTRC")
#  [F:TIP]SRV=func SUBCTRRET.FIND_RETRO_FLD(MATRI,HRCTR,[F:TIP]CTRDAT,DATPAY,"ETRSRV","CTRC")
    #MIPEA - 2016-12-02 - X3-11593- START
  # Fin FQ85820
  Call VALORIS([F:TIP]STRDAT,[F:TIP]ENDDAT,MATRI,[M:DIA]TIM,JOUR,HEURE,[F:TIP]FCY,CTR) From SUBPLN
  [F:TIP]NBRDAY = JOUR(1)
  [F:TIP]NBRHOU = HEURE(1)
#  # FQ82073 - Affectation date contrat sur le temps
#  [F:TIP]CTRDAT = func TPSSTD.CALC_CTRDATDEF(MATRI,CTR,[F:TIP]ENDDAT,DATPAY,[F:TIP]ENDDAT,1)
  If GTPS
   Gosub INISEC From TPSSUB
  Endif
  OK=1
  If [F:TIM]CATTIM=3 & [F:TIM]FLGBLC=2
   Gosub CTRL_CP
   If OK<1
    #Création impossible : Evènement XXX solde insuffisant
    Call ECR_TRACE(MATRI-mess(7,123,1)-":"-mess(110,10709,1)-[F:TIP]TIM-mess(118,10709,1),1) From GESECRAN
    Break
   Endif
  Endif
  If OK

   ## Mise à jour de la demande de congé
   Raz [F:DCG]
   [F:DCG]REFNUM = MATRI
   [F:DCG]DEM    = uniqid([DCG])
   [F:DCG]CTRNUM = CTR
   [F:DCG]STRDAT = [F:TIP]STRDAT
   [F:DCG]ENDDAT = [F:TIP]ENDDAT
   [F:DCG]STRDAY = 1
   [F:DCG]ENDDAY = 1
   [F:DCG]NBRDAY = [F:TIP]NBRDAY
   [F:DCG]TIM    = [F:TIP]TIM
   [F:DCG]STA    = 3
   [F:DCG]CMT    = [F:TIP]CMT
   [F:DCG]UID    = uniqid([TIP])
   If dim([F:DCG]CREDAT)>0 : [F:DCG]CREDAT = date$ : Endif
   If dim([F:DCG]CREUSR)>0 : [F:DCG]CREUSR = GUSER : Endif
   If dim([F:DCG]CRETIM)>0 : [F:DCG]CRETIM = time  : Endif
   Write [DCG]
   If fstat
    GOK = 0 : Call FSTA("DCG") From GLOCK : Break
   Endif

   [F:TIP]DCGUID=[F:DCG]UID
   Write [TIP]
   If fstat
    GOK = 0 : Call FSTA("TIP") From GLOCK : Break
   Endif

   NBPCE += 1
   If [F:TIM]CATTIM = 3
    #Maj cp pris
    Raz DHEURE,DJOUR
    Call VALORDET([F:TIP]STRDAT,[F:TIP]ENDDAT,[F:TIP]REFNUM,[F:TIP]TIM,DJOUR,DHEURE,[F:TIP]FCY,[F:TIP]CTRNUM) From SUBPLN
    Call ADD_CPPRIS(DJOUR) From TPSSTD1
    If GOK<1 : Break : Endif
   Endif
   Gosub FLGVEP
   Call ECR_TRACE(MATRI-num$([F:TIP]LIG)-":"-mess(37,10709,1)
& -format$("D:"+GFMDAT,[F:TIP]STRDAT)-"-"-format$("D:"+GFMDAT,[F:TIP]ENDDAT),0) From GESECRAN
   If I2>=NBJOUR : Break : Endif
   I1 = find(1,PRE(I2+1..NBJOUR))
   If I1 : I1 += I2 : Endif
  Endif
 Wend
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

#######################################
$CTRL_CP
Local Decimal DROIT
DROIT=0
#recherche sur la période de tolérence

Filter [F:CNG] Where CPY=[F:FCY]LEGCPY & TIM=[F:TIP]TIM & DEBDAT<=[F:TIP]STRDAT & FINDAT>=[F:TIP]ENDDAT
#JASMI - 2014-09-04 - START
If func AFNC.ACTIV("KZA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
 Filter [F:CNE] Where TIM=[F:TIP]TIM & REFNUM=[F:TIP]REFNUM & CTRNUM=CTR & EMPLEASTR<=[F:TIP]STRDAT & EMPLEAEND>=[F:TIP]ENDDAT
 Read [F:CNE]CNE0 Last
 Filter [F:CNE]
 If !fstat
   Filter [F:CNG] Where CPY=[F:FCY]LEGCPY & TIM=[F:TIP]TIM & YEA=[F:CNE]YEA
 Endif
Endif
#JASMI - 2014-09-04 - END

For [F:CNG]CNG0
 Read [CNE]CNE0 = [F:CNG]YEA;[F:TIP]REFNUM;CTR;[F:CNG]TIM
 If !fstat
  DROIT+=[F:CNE]NBRDAY-[F:CNE]NBRPRI
 Else
  OK=0 : Break
 Endif
Next
Filter [F:CNG]

If !OK: Return : Endif

If DROIT-[F:TIP]NBRDAY<[F:TIM]BLCMIN
 OK=0 : Return
Endif
Return

#######################################
$AB_TR1
Rollback
Return

#######################################
# FQ91472 US2857/58 - SEGAY 02/09/14
$FLGVEP
If GPAYE & GOK
 Local Date CTRDAT_VEP
 Local Date DATPAY2
 [L]DATPAY2=DATPAY
 If clalev([F:TIP])>0 & dim(CTRDAT_VEP)>0  Then
    CTRDAT_VEP=[F:TIP]CTRDAT
    Call TPSDATPAY(MATRI,CTR,[F:TIP]CTRDAT,[F:HRCTR]XITDAT,DATPAY,[F:TIP]FCY,[L]DATPAY2,[F:HRCTR]PERCOD) From TRTTPS
 Endif
 Gosub FILTRE_VEP From TRTTPS
 Filter [VEP] Where EMP=MATRI & PYRDAT=DATPAY2 & CTRNUM=CTR & evalue(CRITVEP)
 Read [VEP]VEP0 Last
 Filter [VEP]
 If !fstat
   Global Char GNUMBUL (GLONVCR)
   GNUMBUL=[F:VEP]BUL
   #LIPET - 217-06-07 - X3-43887 - START
#   Call MAJFLGTPS (MATRI,DATPAY2,HRCTR,1,1,[0/0/0]) From SUBVEP :#Génération auto
#   Call MAJFLGTPS (MATRI,DATPAY2,HRCTR,2,1,[0/0/0]) From SUBVEP :#Synthèse
#   Call MAJFLGTPS (MATRI,DATPAY2,HRCTR,3,1,[0/0/0]) From SUBVEP :#Maj variables
#   Call MAJFLGTPS (MATRI,DATPAY2,HRCTR,4,1,[0/0/0]) From SUBVEP :#Maj analytique
   Call MAJFLGTPS (MATRI,DATPAY2,CTR,1,1,[0/0/0]) From SUBVEP :#Génération auto
   Call MAJFLGTPS (MATRI,DATPAY2,CTR,2,1,[0/0/0]) From SUBVEP :#Synthèse
   Call MAJFLGTPS (MATRI,DATPAY2,CTR,3,1,[0/0/0]) From SUBVEP :#Maj variables
   Call MAJFLGTPS (MATRI,DATPAY2,CTR,4,1,[0/0/0]) From SUBVEP :#Maj analytique
   #LIPET - 217-06-07 - X3-43887 - END
   Kill GNUMBUL
 Endif
Endif
Return

