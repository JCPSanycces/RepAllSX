Call AS_PRF(VALEUR) From DIVPAYE
End

Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Gosub GRISE From DIVPAYE
End

Subprog C_MATFIN(VALEUR)
Variable Char    VALEUR()
Call C_MATFIN(VALEUR) From DIVPAYE
End

Subprog C_TIM(VALEUR)
Variable Char    VALEUR()
#ADNGO - 22-02-2017 - X3PEOP-1248 - START
#Call LECTURE("TIM",VALEUR,"") From CONTOBJ
Call LECTURE("HRTIM",VALEUR,GCURLEG) From CONTOBJ
#ADNGO - 22-02-2016 - X3PEOP-1248 - END
If [F:TIM]GNRAUT<>2
 GMESSAGE = mess(35,10709,1) : # Génération auto non autorisée
 mkstat = 2 : End
Endif
End

Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
Local Integer OK
If GTPS
#LIPET - 24-11-2016 - X3PEOP-1248 - START
#For [PEO]PEO0 Where PERSTR(0)<=VALEUR & PEREND(1)>=VALEUR
 For [HRPEOD] Where PERSTR(0)<=VALEUR & PEREND(1)>=VALEUR
#LIPET - 24-11-2016 - X3PEOP-1248 - END
   If [M]DATDEB<[F:HRPEOD]PERSTR(0)
    GMESSAGE = mess(36,10709,1) : # Période à cheval sur 2 payes
    mkstat = 2
   Endif
   Break
 Next
Else
 For [F:HRPEOD]HRPEOD0
  If VALEUR<=[F:HRPEOD]PEREND(1) & [M]DATDEB>=[F:HRPEOD]PERSTR(1)
   OK = 1
  Endif
  If VALEUR>=[F:HRPEOD]PERSTR(1) & VALEUR<=[F:HRPEOD]PEREND(1)
   If [M]DATDEB<[F:HRPEOD]PERSTR(1)
    GMESSAGE = mess(36,10709,1) : # Période à cheval sur 2 payes
    mkstat = 2
   Endif
   Break
  Endif
 Next
Endif
If mkstat=2 : End : Endif
If !GTPS & !OK
 GMESSAGE = mess(79,10701,1) : # Pas de date de paie définie sur cette période
 mkstat = 2 : End
Endif
End

Subprog C_CMT(VALEUR)
Variable Char    VALEUR()
#ADNGO - 22-02-2017 - X3PEOP-1248 - START
#Call LECTURE("TIM",[M]TIM,"") From CONTOBJ
Call LECTURE("HRTIM",[M]TIM,GCURLEG) From CONTOBJ
#ADNGO - 22-02-2017 - X3PEOP-1248 - END
If [F:TIM]CMTOBG=2 & VALEUR=""
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 2
Endif
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
#LIPET - 24-11-2016 - X3PEOP-1248 - START
  GCURLEG=VALEUR
#LIPET - 24-11-2016 - X3PEOP-1248 - END
End

