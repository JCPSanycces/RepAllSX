#<AdxTL>@(#)7.0.0.0 $Revision$
################################################################################
#    ECLATEMENT DES DEPENSES
#    FGR
#    Création le : 05/03/2003
#    Modification :
#          CBO : 27.02.2014 (FQ 97297) : Erreur prorata des ZL de l'evt.
#          GLE : 27.11.2012 (FQ 85782) : Eclatements par quantité des montants des zones libres même si valorisation à 0
#          GLE : 07.11.2012 (FQ 84794) : Gestion des montants IAS
#          MDJ : 30.10.2012 (FQ 85231) : Pas d'evt de régul. de TVA si la dépense vient juste d'être éclatée
#          MDJ : 29.09.2011 (FQ 76673) : Test valeur du code activité GRT
#          MDJ : 23.05.2011 (FQ 73971) : Le montant de la Subvention n'était pas éclaté
#          MDJ : 12.02.2010 (FQ 62494) : Eclatement par montant et répartition qté possible à tort
#          MDJ : 09.10.2009 (FQ 60736) : Eclatement incorrect dépense avec quantité > 1, par montant
################################################################################
Raz GPILOBJ
Call DEFVAR From GLOBIMM
Call INIVAR From GLOBIMM
Call OBJET("LOF",GBIDC1,GBIDC2) From GOBJET
End
################################################################################
$ACTION
  #Infbox "ACTION = "-num$(ACTION)
  Case ACTION
    When "OUVRE"          : Gosub OUVRE
    When "DEBUT"          : Gosub DEBUT
    When "SETBOUT"        : Gosub SETBOUT
    When "BOUTON"         : Gosub BOUTON
    When "APRES_MODIF"    : Gosub APRES_MODIF
    When "AVANT_MODFIC"   : Gosub AVANT_MODFIC
    When "AVANT_OK"       : Gosub AVANT_OK
    When "OK"             : Gosub OK
    When "ABA"            : Gosub ABA
    When "FIN"            : Gosub FIN
  Endcase
Return
################################################################################
#-------------------------------------------------------------------------------
$OUVRE
  Local Integer OBJNUM                         : # N° objet métier => menu local 341
  Local Integer OK                             : # Indicateur lecture dico zones libres correcte

  If clalev([F:LOFB])=0 : Local File LAYOUTFAS  [LOFB] : Endif
  If clalev([F:FRF]) =0 : Local File FREFLD     [FRF]  : Endif
  If clalev([F:TUNB])=0 : Local File TABUNIT    [TUNB] : Endif
  #--------------------------
  OBJNUM = find(right$(GFONCTION,4),GOBJTAB)
  OK     = 1
  Read [FRF]FRF0=OBJNUM;GCOUSOC : # Paramétrage Société
  If fstat
    Read [FRF]FRF0=OBJNUM;"" : # Paramétrage par défaut
    If fstat : OK = 0 : Endif
  Endif
  #--------------------------
  Gosub ACTION From TRTOBJACT
  #--------------------------
Return

#-------------------------------------------------------------------------------
$DEBUT
  [M:LOF5]NBDEP      = 0
  [M:LOF5]NBLOF      = 0
  [M:LOF5]QTYAFT     = 0                       : # Quantité
  [M:LOF5]NOTCPYAFT  = 0                       : # Montant HT Converti
  #------------------------------
  [M:LOF5]CUR        = [M:LOF1]CUR             : # Devise
  [M:LOF5]UOM        = [M:LOF1]UOM             : # Unité
  [M:LOF5]CODLOFO    = [M:LOF0]CODLOF          : # Référence dépense
  [M:LOF5]LINLOFO    = [M:LOF0]LINLOF          : # Ligne dépense
  [M:LOF5]QTYBEF     = [M:LOF1]QTY             : # Quantité
  [M:LOF5]NOTCPYBEF  = [M:LOF1]AMTNOTCPY       : # Montant HT Converti
  [M:LOF5]NOTCURBE   = [M:LOF1]AMTNOTCUR       : # Montant HT Transaction
  [M:LOF5]TVATCURBE  = [M:LOF1]AMTVATCUR       : # Montant TVA Transaction
  [M:LOF5]TVATCPYBE  = [M:LOF1]AMTVATCPY       : # Montant TVA Converti
  [M:LOF5]TVATRCURBE = [M:LOF1]AMTVATRCUR      : # Montant TVA récupérée Transaction
  [M:LOF5]TVATRCPYBE = [M:LOF1]AMTVATRCPY      : # Montant TVA récupérée Converti
  If ( G_ACTGRT=G_OUI )
  [M:LOF5]AMTGRABE   = [M:LOF2]AMTGRA          : #Fq-73971  Montant Subvention
  Endif
  If ( GCNXPROIAS=G_OUI )
    [M:LOF5]NOTIASBEF  = [M:LOF1]AMTNOTIAS     : # FQ84794
    [M:LOF5]VATIASBEF  = [M:LOF1]AMTVATIAS     : # FQ84794
    [M:LOF5]VATRIASBEF = [M:LOF1]AMTVATRIAS    : # FQ84794
  Endif
  #------------------------
  Local Integer LERROR
  Local Integer N_I                            : # Indice pour boucle sur montants libres
  Local Integer LLIGSTR

  For N_I = 1 To 6
    If OK & [F:FRF]AMTRIOIND(N_I-1) = 2
      Assign '[M:LOF5]FLGFLDM'+num$(N_I) With G_OUI
    Else
      Assign '[M:LOF5]FLGFLDM'+num$(N_I) With G_NON
    Endif
    #------------------------------
    # En attendant la disparition de FRZ9
    If !clalev([M:FRZ9])
      Assign '[M:LOF5]USRFLDM'+num$(N_I)+'BE' With evalue ('[M:LOF9]USRFLDM'+num$(N_I))
    Else
      Assign '[M:LOF5]USRFLDM'+num$(N_I)+'BE' With evalue ('[M:FRZ9]USRFLDM'+num$(N_I))
    Endif
    #------------------------------
  Next N_I
  #------------------------------
  Affzo [M:LOF5]1-99
  #------------------------------
  Call GET_NEXT_LINLOF ([M:LOF5]CODLOFO, LLIGSTR, LERROR)
  [M:LOF5]LINLOFMIN = LLIGSTR
  [M:LOF5]LIGSTR    = LLIGSTR
  [M:LOF5]LIGINC    = 1
  Affzo [M:LOF5]TYPNUM
  Affzo [M:LOF5]LINLOFMIN
  Affzo [M:LOF5]LIGSTR
  Affzo [M:LOF5]LIGINC
  #------------------------------
  Read [TUNB]TUN0=[M:LOF5]UOM
  If fstat
    # si pas d'unité on fait comme si l'unité n'avait pas de décimales
    [M:LOF5]UOMDEC = 0
    If [M:LOF5]QTYBEF < 2
      # Pour une quantité < 2 avec une unité ss décimales, pas le droit d'éclater sur la quantité
      [M:LOF5]ECLBAS = GVML_TECDAMT
      Affzo [M:LOF5]ECLBAS
      Diszo [M:LOF5]ECLBAS
      [M:LOF5]QTYECL = G_NON
      Affzo [M:LOF5]QTYECL
      Diszo [M:LOF5]QTYECL
    Else
      # sinon on propose malgré tout l'éclatement par quantité mais on peu changer
      [M:LOF5]ECLBAS = GVML_TECDQTY
      Affzo [M:LOF5]ECLBAS
      [M:LOF5]QTYECL = G_OUI
      Affzo [M:LOF5]QTYECL
      Diszo [M:LOF5]QTYECL
    Endif
  Else
    [M:LOF5]UOMDEC = [F:TUNB]UOMDEC
    If [M:LOF5]QTYBEF < 2 and [F:TUNB]UOMDEC = 0
      # Pour une quantité < 2 avec une unité ss décimales, pas le droit d'éclater sur la quantité
      [M:LOF5]ECLBAS = GVML_TECDAMT
      Affzo [M:LOF5]ECLBAS
      Diszo [M:LOF5]ECLBAS
      [M:LOF5]QTYECL = G_NON
      Affzo [M:LOF5]QTYECL
      Diszo [M:LOF5]QTYECL
    Else
      # sinon on propose malgré tout l'éclatement par quantité mais on peu changer
      [M:LOF5]ECLBAS = GVML_TECDQTY
      Affzo [M:LOF5]ECLBAS
      [M:LOF5]QTYECL = G_OUI
      Affzo [M:LOF5]QTYECL
      Actzo [M:LOF5]QTYECL
    Endif
  Endif
  #--------------------------
  Gosub ACTION From TRTOBJACT
  Setmok [M:LOF5] With 1
  #--------------------------
Return

#-------------------------------------------------------------------------------
$SETBOUT
#---------------------------------------------
# Codes des boutons spécifiques à l'éclatement
# 1 - Eclater
# 2 - Répartir
#---------------------------------------------
  If [M:LOF5]NBLOF <= 0
    # On ne peut pas éclater si on ne sait pas en combien
    Call VIREBOUT (CHMEN, "1") From GOBJET    : # Eclater
  Endif
  If [M:LOF5]NBDEP <= 0 or [M:LOF5]ECLBAS = GVML_TECDAMT
    # On ne peut pas répartir si le tableau est vide
    Call VIREBOUT (CHMEN, "2") From GOBJET    : # Répartir
  Endif
  Gosub SET_BOUT_SPE From GSAISIE
  If [M:LOF5]NBDEP <= 0
    # On le met pour être sur de pouvoir le faire que si un éclatement a été
    # fait, pas slt si on a saisi un nombre d'éclatements
    Call VIREBOUT (CHBOU, "O") From GOBJET    : # Ok
  Endif
  Gosub SET_BOUT_STD From GSAISIE
Return

#-------------------------------------------------------------------------------
$BOUTON
#---------------------------------------------
# Codes des boutons spécifiques à l'éclatement
# 1 - Eclater
# 2 - Répartir
#---------------------------------------------
  Case BOUT
    When "1"        : # Eclater
      Call CALCUL_ECLATEMENT ()
    When "2"        : # Répartir
      Call REPARTIR_MONTANT ()
    When Default
  Endcase
Return

#-------------------------------------------------------------------------------
$APRES_MODIF
  REP = "M"
Return

#-------------------------------------------------------------------------------
$AVANT_MODFIC
  Call ENREG_ECLATEMENT (LERROR)
  If !(LERROR)
     Local Integer LERROR
     Call ECLATER_EVENEMENTS(LERROR)
   Endif
   If LERROR
     GERR     = 1
     GMESSAGE = mess(14,GML_MSGLOF,1) : # Echec lors de l'enregistrement de l'éclatement
     FIN      = 0 : Return
   Endif

Return

#-------------------------------------------------------------------------------
$AVANT_OK
Local Char LMSG(200)

  Call CTRL_ECLATEMENT (LMSG)
  If LMSG <> ""
    GERR     = 1
    GMESSAGE = LMSG
    FIN      = 0 : # pour ne pas quitter la fenêtre d'éclatement
  Endif
Return

#-------------------------------------------------------------------------------
$OK
  G_ACT_MOD = 1 : # Pour mettre l'écran de la dépense en modif
  Call MAJ_LOF_ORIGINE ()
  #--------------------------
  Gosub ACTION From TRTOBJACT
  #--------------------------
Return

#-------------------------------------------------------------------------------
$ABA
  Gosub DEBUT : # Clic sur abandon, on recharge toutes les valeurs d'origine
  REP = ""    : # On repasse en mode consultation
Return

#-------------------------------------------------------------------------------
$FIN
  #--------------------------
  If dim(G_LOFSPL)  >0 :   G_LOFSPL = G_OUI : Endif  #*Fq-85231
  Gosub ACTION From TRTOBJACT
  #--------------------------
If dim([M:OCP]NBOBJ)>0
   If [M:OCP]NBOBJ = 0
      [M:OCP]OBJREF(0) = "XXX"
      [M:OCP]NBOBJ = 1
   Endif
Endif

Return

################################################################################
#
################################################################################
#-------------------------------------------------------------------------------
$ACTMET
  Case ACTMET
    When "CRITMEN"      : Gosub CRITMEN       # Critère d'activation du menu.
    When "LCK_OBJ_LNK"  : Gosub LCK_OBJ_LNK   # Lock manuel des objets liés.
    When "ULK_OBJ_LNK"  : Gosub ULK_OBJ_LNK   # Unlock manuel des objet liés
    When "FILL_HEA"     : Gosub FILL_HEA      # Alimentation zones spé à l'action de l'en-tête [OAC0]
    When "INIT_OBJ_DIV" : Gosub INIT_OBJ_DIV  # Ouvertures tables à mettre à jour dans MAJ_LNK
    When "MAJ_LNK"      : Gosub MAJ_LNK       # Mise à jour et alimentation des objets liés
    When Default
  Endcase
Return

#-------------------------------------------------------------------------------
$CRITMEN
# Permet d'alimenter la variable CRITMEN, avec le critère permettant d'activer
# le menu associé à l'action métier dans l'étiquette CRITMEN

 Local Integer ACCFCY
 Local Char AUZFCY (15)
 # Accès selon droit à l'option
 Call DROITSITE ( [M:LOF0]FCY, [L]AUZFCY, [L]ACCFCY ) From SUPCPT
 If ( not [L]ACCFCY or not instr(1, [L]AUZFCY, '4') )
   CRITMEN = "1=0"
 Else
   CRITMEN = "1=1"
 Endif
Return

#-------------------------------------------------------------------------------
$LCK_OBJ_LNK
# Ecrire les instructions de lock des objets liés dans cette étiquette
# si les objets liés ne sont pas des objets métiers.
Return

#-------------------------------------------------------------------------------
$ULK_OBJ_LNK
# Ecrire les instructions d'unlock des objets liés dans cette étiquette
# si les objets liés ne sont pas des objets métiers.
Return

#-------------------------------------------------------------------------------
$FILL_HEA
# Permet d'alimenter d'autre élément de l'en-tête en dehors de l'identifiant
# et de la désignation
Return

#-------------------------------------------------------------------------------
$INIT_OBJ_DIV
# Ouvrir les tables à mettre à jour
Return

#-------------------------------------------------------------------------------
$MAJ_LNK
# Ecrire le traitement de maj des tables des objets liés.
Return

#-------------------------------------------------------------------------------
$EVT_LNK
Return

################################################################################
# SOUS-PROGRAMMES
################################################################################
########################################
Subprog CTRL_ECLATEMENT (RMSG)
Variable Char RMSG

Local Integer N_I

  RMSG = ""
  Call TEMPON('F') From GESECRAN
  #------------------------------
  If [M:LOF5]NBDEP <> [M:LOF5]NBLOF-1
    RMSG = mess(22,GML_MSGLOF,1)-num$(N_I) : # L'éclatement n'a pas été réalisé correctement
    End
  Endif
  #------------------------------
  For N_I = 1 To [M:LOF5]NBDEP
    If [M:LOF5]TYPNUM = GVML_NEAUCU and [M:LOF5]CODLOF(N_I-1) = ""
      RMSG = mess(15,GML_MSGLOF,1)-num$(N_I) : # Référence à saisir obligatoire, ligne
      Break
    Endif
    #------------------------------
    # Suite de la boucle
  Next N_I
  Call TEMPOFF() From GESECRAN
End

########################################
Subprog ENREG_ECLATEMENT (RERROR)
# Enregistre les dépenses éclatées et met à jour la dépense support
# RERROR contient la valeur de fstat
Variable Integer RERROR

Local Char    SCODLOF
Local Integer STAT, N_I
Local Decimal NMNT
Local Char    SMESSAGE(250)

  Call TEMPON(mess(38,GML_MSGLOF,1)) From GESECRAN
  RERROR = 0
  For nolign = 1 To [M:LOF5]NBDEP
    [F:LOFB] = [F:LOF]
    [F:LOFB] = [M:LOF5]
    If [M:LOF5]TYPNUM = GVML_NENONU and [F:LOFB]CODLOF = ""
      If ( GLOFAUTNUM = 2) or (GLOFAUTNUM = 3)
        # FQ85464
        Call GET_NUMERO_CODLOF( [F:LOFB]CPY, [F:LOFB]FCY, date$, SCODLOF, SMESSAGE) From SUBLOF
        If STAT<>0
          GERR = 1: #GMESSAGE = mess(22,7770, 1)-num$(STAT)
          OK = 0 : Break : Return
        Endif
        [F:LOFB]CODLOF           = SCODLOF
        [M:LOF5]CODLOF(nolign-1) = SCODLOF
        Affzo [M:LOF5]CODLOF(nolign-1)
      Endif
    Endif
    [F:LOFB]FLGLOFMAI = G_NON        : # Si c'est la dépense principale qui est éclatée, seule la dépense
                                       # d'origine conserve le statut "principal". Les autres non !
    [F:LOFB]CREORI    = GVML_COECLAT : # Origine saisie éclatement
    If [F:LOFB]CODLOF <> ""
      Write [LOFB]
      If fstat
        RERROR = fstat
        GOK    = 0
        Call FSTA("LOFB") From GLOCK
        Break
      Endif
    Else
      GMESSAGE = mess(55,GML_MSGLOF,1) # Dépense sans référence : création impossible
      OK    = 0 : Break : End
    Endif
    #------------------------------
  # Suite de la boucle
  Next nolign
  Call TEMPOFF() From GESECRAN
End


########################################
Subprog MAJ_LOF_ORIGINE ()

Local Integer N_I

  # Quantité
  [M:LOF1]QTY          = [M:LOF5]QTYAFT      : # Quantité
  Affzo [M:LOF1]QTY

  # Montants
  [M:LOF1]AMTNOTCPY    = [M:LOF5]NOTCPYAFT   : # Montant HT Converti
  [M:LOF1]AMTNOTCUR    = [M:LOF5]NOTCURAF    : # Montant HT Transaction
  [M:LOF1]AMTVATCUR    = [M:LOF5]TVATCURAF   : # Montant TVA Transaction
  [M:LOF1]AMTVATCPY    = [M:LOF5]TVATCPYAF   : # Montant TVA Converti
  [M:LOF1]AMTVATRCUR   = [M:LOF5]TVATRCURAF  : # Montant TVA récupérée Transaction
  [M:LOF1]AMTVATRCPY   = [M:LOF5]TVATRCPYAF  : # Montant TVA récupérée Converti
  If ( G_ACTGRT=G_OUI )
  [M:LOF2]AMTGRA       = [M:LOF5]AMTGRAAF    : #FQ-73971 Montant Subvention
  Endif
  If ( GCNXPROIAS=G_OUI )
    [M:LOF1]AMTNOTIAS  = [M:LOF5]NOTIASAFT     : # FQ84794
    [M:LOF1]AMTVATIAS  = [M:LOF5]VATIASAFT     : # FQ84794
    [M:LOF1]AMTVATRIAS = [M:LOF5]VATRIASAFT    : # FQ84794
  Endif
  Call ACTION_BLOCK (ACB_AFFZO, "LOF1", "AMTNOTCPY") From GLOBIENS

  # Zones libres
  For N_I = 1 To 6
    NMNT = evalue ('[M:LOF5]USRFLDM'+num$(N_I)+'AF')
    #----------------------------------------
    # En attendant la disparition de FRZ9
    If !clalev([M:FRZ9])
      Assign '[M:LOF9]USRFLDM'+num$(N_I) With NMNT
    Else
      Assign '[M:FRZ9]USRFLDM'+num$(N_I) With NMNT
    Endif

    #------------------------------
    # Suite de la boucle
  Next N_I

  # Cet appel pose problème car c'est le masque FRZ9 qui est toujours trouvé
  #     -> remplacé par les Affzo suivants
  #Call ACTION_BLOCK (ACB_AFFZO, "FREEZON9", "USRFLDM1") From GLOBIENS

  If !clalev([M:FRZ9])
    Affzo [M:LOF9]10
  Else
    Affzo [M:FRZ9]10
  Endif

End

########################################
Subprog GET_NEXT_LINLOF (PCODLOF, RLINLOF, RERROR)
# Rend le prochain numéro de ligne de dépense
# RERROR contient la valeur de fstat
Value Char PCODLOF
Variable Integer RLINLOF
Variable Integer RERROR

  Filter [LOFB] Where CODLOF=PCODLOF
  Read [LOFB]LOF0 Last
  Filter [LOFB]
  If fstat>2
    RLINLOF = 1
  Else
    RLINLOF = [F:LOFB]LINLOF + 1
  Endif
  RERROR = fstat
End

########################################
Subprog REPARTIR_MONTANT ( )
Local Integer N_I

Local Decimal NMNTHT, NMNTHT1

  Call GET_MNT_ARRONDI ([M:LOF5]NOTCPYBEF/[M:LOF5]QTYBEF, GCOUDEV, NMNTHT) From GLOBIENS
  For N_I = 1 To [M:LOF5]NBDEP
    Call GET_MNT_ARRONDI (NMNTHT * [M:LOF5]QTY(N_I-1), GCOUDEV, NMNTHT1) From GLOBIENS
    [M:LOF5]AMTNOTCPY(N_I-1)  = NMNTHT1     : # Montant HT converti
    If ( GCNXPROIAS=G_OUI )
      Call GET_MNT_ARRONDI ([M:LOF5]NOTIASBEF/[M:LOF5]QTYBEF, GCOUDEV, NMNTHT1) From GLOBIENS : # FQ84794
      [M:LOF5]AMTNOTIAS(N_I-1)  = NMNTHT1                                                     : # FQ84794
    Endif
    Call PRORATE_MONTANT (N_I)
    #------------------------------
  # Suite de la boucle
  Next N_I
  Call ACTION_BLOCK (ACB_AFFZO, "LOFECL1", "NBDEP") From GLOBIENS
  Call CALCUL_SOLDE ()
End

########################################
Subprog CALCUL_ECLATEMENT ( )
Local Integer N_I
Local Decimal NQTY
Local Integer NINCDEB
Local Integer STAT
Local Char    SCODLOF(GLONLOF)
Local Decimal NMNTHT, NMNTHTIAS

  Call ACTION_BLOCK (ACB_EFFZO, "LOFECL1", "NBDEP") From GLOBIENS
  NINCDEB = [M:LOF5]LIGSTR
  Call GET_QTY_ARRONDIE ([M:LOF5]QTYBEF/[M:LOF5]NBLOF, [M:LOF5]UOM, NQTY) From GLOBIENS
  #*Fq-60736 Si cumuls qtés > qté origine la qté des nouvelles dépense = 1 et le reliquat est porté par
  #*Fq-60736 la dépense d'origine
  # Dans tous les cas on divise la qté par le nombre de dépenses et si la division ne tombe pas juste, le reliquat
  # est porté par la dépense d'origine
  #*Fq-60736If NQTY*[M:LOF5]NBLOF > [M:LOF5]QTYBEF
  #*Fq-60736  NQTY = 1
  #*Fq-60736Endif
  If [M:LOF5]ECLBAS = GVML_TECDAMT
    #FQ-60736 If [M:LOF5]QTYECL = G_NON
    #FQ-60736 Call GET_MNT_ARRONDI ([M:LOF5]NOTCPYBEF/[M:LOF5]NBLOF, GCOUDEV, NMNTHT) From GLOBIENS
    #FQ-60736
    #FQ-60736 Call GET_MNT_ARRONDI ([M:LOF5]NOTCPYBEF/[M:LOF5]QTYBEF, GCOUDEV, NMNTHT) From GLOBIENS
    #FQ-60736 Endif
    Call GET_MNT_ARRONDI ([M:LOF5]NOTCPYBEF/[M:LOF5]NBLOF, GCOUDEV, NMNTHT) From GLOBIENS
    Call GET_MNT_ARRONDI ([M:LOF5]NOTIASBEF/[M:LOF5]NBLOF, GCOUDEV, NMNTHTIAS) From GLOBIENS : # FQ84794
  Else
   Call GET_MNT_ARRONDI ([M:LOF5]NOTCPYBEF/[M:LOF5]NBLOF, GCOUDEV, NMNTHT) From GLOBIENS
    Call GET_MNT_ARRONDI ([M:LOF5]NOTIASBEF/[M:LOF5]NBLOF, GCOUDEV, NMNTHTIAS) From GLOBIENS : # FQ84794
  Endif

  For nolign = 1 To [M:LOF5]NBLOF-1
    [M:LOF5]NBDEP = nolign
    #------------------------------
    If [M:LOF5]TYPNUM = GVML_NEAUCU
      # numérotation à saisir et numéro de ligne à 1
      [M:LOF5]CODLOF(nolign-1) = ""
      [M:LOF5]LINLOF(nolign-1) = 1
    Elsif [M:LOF5]TYPNUM = GVML_NEINLI
      # numérotation par incrément de numéro de ligne
      [M:LOF5]CODLOF(nolign-1) = [M:LOF5]CODLOFO
      [M:LOF5]LINLOF(nolign-1) = NINCDEB
      NINCDEB = NINCDEB + [M:LOF5]LIGINC
    Elsif [M:LOF5]TYPNUM = GVML_NENONU
      # nouvelle numérotation et numéro de ligne à 1
      # A calculer à l'enregistrement, sinon si on le fait maintenant, et qu'on ne
      # valide pas : on perd les numéros du compteur
      [M:LOF5]CODLOF(nolign-1) = SCODLOF
      [M:LOF5]LINLOF(nolign-1) = 1
    Endif
    #------------------------------
    [M:LOF5]DES(nolign-1) = [M:LOF0]DES
    #------------------------------
    If [M:LOF5]ECLBAS = GVML_TECDAMT
      #*Fq-60737 If [M:LOF5]QTYECL =  G_NON
      If [M:LOF5]QTYECL <> G_OUI
        [M:LOF5]QTY(nolign-1)        = [M:LOF5]QTYBEF
        [M:LOF5]AMTNOTCPY(nolign-1)  = NMNTHT : # Montant HT converti
      Else
        [M:LOF5]QTY(nolign-1) = NQTY
        Call GET_MNT_ARRONDI (NMNTHT*[M:LOF5]QTY(nolign-1), GCOUDEV, [M:LOF5]AMTNOTCPY(nolign-1)) From GLOBIENS
      Endif
    Else
      [M:LOF5]QTY(nolign-1)   = NQTY
      Call GET_MNT_ARRONDI (NMNTHT*[M:LOF5]QTY(nolign-1), GCOUDEV, [M:LOF5]AMTNOTCPY(nolign-1)) From GLOBIENS
    Endif
    #-----------------------------------------------------
    [M:LOF5]AMTNOTCPY(nolign-1)  = NMNTHT : # Montant HT converti
    [M:LOF5]AMTNOTIAS(nolign-1)  = NMNTHTIAS : # Montant HT converti FQ84794
    Call PRORATE_MONTANT (nolign)
    #------------------------------
  # Suite de la boucle
  Next nolign
  Call ACTION_BLOCK (ACB_AFFZO, "LOFECL1", "NBDEP") From GLOBIENS
  Call CALCUL_SOLDE ( )

End

########################################
Subprog PRORATE_MONTANT (PLIGNE)
Value Integer PLIGNE

Local Decimal NMNT

  If [M:LOF5]NOTCPYBEF <> 0
    Call GET_MNT_ARRONDI ([M:LOF5]NOTCURBE / [M:LOF5]NOTCPYBEF * [M:LOF5]AMTNOTCPY(PLIGNE-1), [M:LOF5]CUR, NMNT) From GLOBIENS
    [M:LOF5]AMTNOTCUR(PLIGNE-1)  = NMNT                    : # Montant HT Transaction

    Call GET_MNT_ARRONDI ([M:LOF5]TVATCPYBE / [M:LOF5]NOTCPYBEF * [M:LOF5]AMTNOTCPY(PLIGNE-1), GCOUDEV, NMNT) From GLOBIENS
    [M:LOF5]AMTVATCPY(PLIGNE-1)  = NMNT                    : # Montant TVA converti

    Call GET_MNT_ARRONDI ([M:LOF5]TVATCURBE / [M:LOF5]NOTCPYBEF * [M:LOF5]AMTNOTCPY(PLIGNE-1), [M:LOF5]CUR, NMNT) From GLOBIENS
    [M:LOF5]AMTVATCUR(PLIGNE-1)  = NMNT                    : # Montant TVA Transaction

    Call GET_MNT_ARRONDI ([M:LOF5]TVATRCPYBE / [M:LOF5]NOTCPYBEF * [M:LOF5]AMTNOTCPY(PLIGNE-1), GCOUDEV, NMNT) From GLOBIENS
    [M:LOF5]AMTVATRCPY(PLIGNE-1) = NMNT                    : # Montant TVA récupérée converti

    Call GET_MNT_ARRONDI ([M:LOF5]TVATRCURBE / [M:LOF5]NOTCPYBEF * [M:LOF5]AMTNOTCPY(PLIGNE-1), [M:LOF5]CUR, NMNT) From GLOBIENS
    [M:LOF5]AMTVATRCUR(PLIGNE-1) = NMNT                    : # Montant TVA récupérée Transaction
    If ( G_ACTGRT=G_OUI )
    Call GET_MNT_ARRONDI ([M:LOF5]AMTGRABE / [M:LOF5]NOTCPYBEF * [M:LOF5]AMTNOTCPY(PLIGNE-1), [M:LOF5]CUR, NMNT) From GLOBIENS
    [M:LOF5]AMTGRA(PLIGNE-1)  = NMNT                    : #FQ-73971  Montant Subvention
    Endif

    # DEBUT FQ84794
    If ( GCNXPROIAS=G_OUI )
      Call GET_MNT_ARRONDI ([M:LOF5]VATIASBEF / [M:LOF5]NOTCPYBEF * [M:LOF5]AMTNOTCPY(PLIGNE-1), [M:LOF5]CUR, NMNT) From GLOBIENS
      [M:LOF5]AMTVATIAS(PLIGNE-1)  = NMNT                    : # Montant HT Transaction

      Call GET_MNT_ARRONDI ([M:LOF5]VATRIASBEF / [M:LOF5]NOTCPYBEF * [M:LOF5]AMTNOTCPY(PLIGNE-1), [M:LOF5]CUR, NMNT) From GLOBIENS
      [M:LOF5]AMTVATRIAS(PLIGNE-1)  = NMNT                    : # Montant HT Transaction
    Endif
    # FIN DEBUT FQ84794

    Call PRORATE_ZL_MONTANT (PLIGNE)
  Else
    NMNT                         = 0
    [M:LOF5]AMTNOTCUR(PLIGNE-1)  = NMNT                    : # Montant HT Transaction
    [M:LOF5]AMTVATCPY(PLIGNE-1)  = NMNT                    : # Montant TVA converti
    [M:LOF5]AMTVATCUR(PLIGNE-1)  = NMNT                    : # Montant TVA Transaction
    [M:LOF5]AMTVATRCPY(PLIGNE-1) = NMNT                    : # Montant TVA récupérée converti
    [M:LOF5]AMTVATRCUR(PLIGNE-1) = NMNT                    : # Montant TVA récupérée Transaction
    If ( G_ACTGRT=G_OUI )
    [M:LOF5]AMTGRA(PLIGNE-1)     = NMNT                    : #FQ-73971 Montant TVA récupérée Transaction
    Endif
    If ( GCNXPROIAS=G_OUI )
      [M:LOF5]AMTVATIAS(PLIGNE-1)  = NMNT                  : # FQ84794
      [M:LOF5]AMTVATRIAS(PLIGNE-1) = NMNT                  : # FQ84794
    Endif
    Call PRORATE_ZL_MONTANT (PLIGNE)
  Endif
End

########################################
Subprog PRORATE_ZL_MONTANT (PLIGNE)
Value Integer PLIGNE

Local Integer N_I
Local Decimal NMNT, NMNT1
Local Char LCUR

  For N_I = 1 To 6
    If evalue ('[M:LOF5]FLGFLDM'+num$(N_I)) = G_NON
      NMNT = evalue ('[M:LOF5]USRFLDM'+num$(N_I)+'BE')
    Else
      NMNT1 = evalue ('[M:LOF5]USRFLDM'+num$(N_I)+'BE')
      LCUR = evalue ('GABZLMNT'+num$(N_I))
      If [M:LOF5]NOTCPYBEF <> 0
        Call GET_MNT_ARRONDI (NMNT1 / [M:LOF5]NOTCPYBEF * [M:LOF5]AMTNOTCPY(PLIGNE-1), LCUR, NMNT) From GLOBIENS
      # Début FQ85782
      Elsif [M:LOF5]ECLBAS = GVML_TECDQTY
        Call GET_MNT_ARRONDI (NMNT1 / [M:LOF5]NBLOF, LCUR, NMNT) From GLOBIENS
      # Fin FQ85782
      Else
        NMNT = NMNT1
      Endif
    Endif
    Assign '[M:LOF5]USRFLDM'+num$(N_I)+'(PLIGNE-1)' With NMNT
    # ------------------
    # Suite de la boucle
  Next N_I
End

########################################
Subprog CALCUL_SOLDE ( )
Local Integer N_I, N_E, N_DBZL
Local Decimal NCUMQTY, NMNT
Local Decimal NCUMMNT (16)
      # 0      - Montant HT converti
      # 1      - Montant HT Transaction
      # 2      - Montant TVA converti
      # 3      - Montant TVA Transcation
      # 4      - Montant TVA récupérée convertie
      # 5      - Montant TVA récupérée Transaction
      # 6      - Montant Subvention
      # 7       - Montant HT IAS (FQ84794)
      # 8       - Montant TVA IAS (FQ84794
      # 9       - Montant TVA récupérée IAS (FQ84794
      # 10 à 15 - ZL Montant 1 à 6

  N_DBZL = 9
  NCUMQTY = 0
  For N_I = 0 To dim(NCUMMNT)-1
    NCUMMNT(N_I) = 0
  Next N_I
  For N_I = 1 To [M:LOF5]NBDEP
    NCUMQTY = NCUMQTY + [M:LOF5]QTY(N_I-1)
    #------------------------------
    NCUMMNT(0) = NCUMMNT(0) + [M:LOF5]AMTNOTCPY(N_I-1)  : # Montant HT converti
    NCUMMNT(1) = NCUMMNT(1) + [M:LOF5]AMTNOTCUR(N_I-1)  : # Montant HT Transaction
    NCUMMNT(2) = NCUMMNT(2) + [M:LOF5]AMTVATCPY(N_I-1)  : # Montant TVA converti
    NCUMMNT(3) = NCUMMNT(3) + [M:LOF5]AMTVATCUR(N_I-1)  : # Montant TVA Transaction
    NCUMMNT(4) = NCUMMNT(4) + [M:LOF5]AMTVATRCPY(N_I-1) : # Montant TVA récupérée converti
    NCUMMNT(5) = NCUMMNT(5) + [M:LOF5]AMTVATRCUR(N_I-1) : # Montant TVA récupérée Transaction
    If ( G_ACTGRT=G_OUI )
    NCUMMNT(6) = NCUMMNT(6) + [M:LOF5]AMTGRA(N_I-1)     : #FQ-73971  Montant Subvention
    Endif
    If ( GCNXPROIAS=G_OUI )
      NCUMMNT(7) = NCUMMNT(7) + [M:LOF5]AMTNOTIAS(N_I-1)  : # FQ84794  Montant HT IAS
      NCUMMNT(8) = NCUMMNT(8) + [M:LOF5]AMTVATIAS(N_I-1)  : # FQ84794  Montant TVA IAS
      NCUMMNT(9) = NCUMMNT(9) + [M:LOF5]AMTVATRIAS(N_I-1) : # FQ84794  Montant TVA récupérée IAS
    Endif
    #------------------------------
    # Pour les zones libres
    For N_E = 1 To 6
      If evalue ('[M:LOF5]FLGFLDM'+num$(N_E)) = G_NON
        NCUMMNT(N_DBZL+N_E) = 0
      Else
        NCUMMNT(N_DBZL+N_E) = NCUMMNT(N_DBZL+N_E) + evalue('[M:LOF5]USRFLDM'+num$(N_E)+'(N_I-1)')
      Endif
      #------------------------------
    # Suite de la boucle
    Next N_E
    #------------------------------
  # Suite de la boucle
  Next N_I
  #------------------------------
  # Quantité
  #Fq-60737 If [M:LOF5]QTYECL = G_NON  Uniquement si éclatement par montant
  If  [M:LOF5]QTYECL <> G_OUI and [M:LOF5]ECLBAS = GVML_TECDAMT
    [M:LOF5]QTYAFT = [M:LOF5]QTYBEF
  Else
    [M:LOF5]QTYAFT = [M:LOF5]QTYBEF - NCUMQTY
  Endif

  If ([M:LOF5]QTYAFT = 0) or ([M:LOF5]QTYAFT < 0  and [M:LOF5]UOMDEC = 0)
    [M:LOF5]QTYAFT = 1
  Endif

  #------------------------------
  # Montants
  [M:LOF5]NOTCPYAFT  = [M:LOF5]NOTCPYBEF  - NCUMMNT(0)     : # Montant HT converti
  [M:LOF5]NOTCURAF   = [M:LOF5]NOTCURBE   - NCUMMNT(1)     : # Montant HT Transaction
  [M:LOF5]TVATCPYAF  = [M:LOF5]TVATCPYBE  - NCUMMNT(2)     : # Montant TVA Converti
  [M:LOF5]TVATCURAF  = [M:LOF5]TVATCURBE  - NCUMMNT(3)     : # Montant TVA Transaction
  [M:LOF5]TVATRCPYAF = [M:LOF5]TVATRCPYBE - NCUMMNT(4)     : # Montant TVA récupérée Converti
  [M:LOF5]TVATRCURAF = [M:LOF5]TVATRCURBE - NCUMMNT(5)     : # Montant TVA récupérée Transaction
  If ( G_ACTGRT=G_OUI )
  [M:LOF5]AMTGRAAF   = [M:LOF5]AMTGRABE   - NCUMMNT(6)     : #FQ-73971 Montant Subvention
  Endif
  If ( GCNXPROIAS=G_OUI )
    [M:LOF5]NOTIASAFT  = [M:LOF5]NOTIASBEF  - NCUMMNT(7)   : # FQ84794  Montant HT IAS
    [M:LOF5]VATIASAFT  = [M:LOF5]VATIASBEF  - NCUMMNT(8)   : # FQ84794  Montant TVA IAS
    [M:LOF5]VATRIASAFT = [M:LOF5]VATRIASBEF - NCUMMNT(9)   : # FQ84794  Montant TVA récupérée IAS
  Endif
  #------------------------------
  # Zones libres
  For N_E = 1 To 6
    NMNT = evalue ('[M:LOF5]USRFLDM'+num$(N_E)+'BE') - NCUMMNT(N_DBZL+N_E)
    Assign '[M:LOF5]USRFLDM'+num$(N_E)+'AF' With NMNT
    #------------------------------
  # Suite de la boucle
  Next N_E
  #------------------------------
  Affzo [M:LOF5]QTYAFT
  Affzo [M:LOF5]NOTCPYAFT
  Call ACTION_BLOCK (ACB_AFFZO, "LOFECL1", "UOM") From GLOBIENS
  #------------------------------
End

################################################################################
# ECRAN : LOFECL1
################################################################################
########################################
Subprog AP_ECLBAS(VALEUR)
Variable Integer VALEUR

  If VALEUR = GVML_TECDQTY
    # Si on éclate sur la quantité on réparti obligatoirement la quantité
    [M:LOF5]QTYECL = G_OUI
    Diszo [M:LOF5]QTYECL
    Affzo [M:LOF5]QTYECL   #*Fq-60737
  Else
    Actzo [M:LOF5]QTYECL
  Endif

End

#*Fq-60737#######################################
Subprog AM_ECLBAS(VALEUR)
Variable Integer VALEUR

  If VALEUR <> [M:LOF5]ECLBAS
     If VALEUR = GVML_TECDQTY
        # Si on éclate sur la quantité on réparti obligatoirement la quantité
        [M:LOF5]QTYECL = G_OUI
        Diszo [M:LOF5]QTYECL
        Affzo [M:LOF5]QTYECL
      Else
         Actzo [M:LOF5]QTYECL
      Endif
  Endif

End

#*Fq-60737#######################################
Subprog AS_QTYECL(VALEUR)
Variable Integer VALEUR

  If [M:LOF5]ECLBAS = GVML_TECDQTY
    # Si on éclate sur la quantité on réparti obligatoirement la quantité
    [M:LOF5]QTYECL = G_OUI
    Diszo [M:LOF5]QTYECL
    Affzo [M:LOF5]QTYECL
    mkstat=2
  Else #Fq-62494
      If [M:LOF5]NBLOF > [M:LOF5]QTYBEF and [M:LOF5]UOMDEC = 0
        [M:LOF5]QTYECL = G_NON
        Diszo [M:LOF5]QTYECL
  Else
    Actzo [M:LOF5]QTYECL
  Endif
    Endif #Fq-62494
    Affzo [M:LOF5]QTYECL
End
#*Fq-60737#######################################
Subprog AM_QTYECL(VALEUR)
Variable Integer VALEUR

  If VALEUR = G_NON and [M:LOF5]ECLBAS = GVML_TECDQTY
    # Si on éclate sur la quantité on réparti obligatoirement la quantité
    [M:LOF5]QTYECL = G_OUI
    Diszo [M:LOF5]QTYECL
    Affzo [M:LOF5]QTYECL
    mkstat=2
  Endif

End
########################################
Subprog AP_QTYECL(VALEUR)
Variable Integer VALEUR

  # Obligé de faire comme ça : le mkstat=2 sur QTY ne permet pas d'affecter la valeur
  # dans le calcul
  If VALEUR = G_NON
    Diszo [M:LOF5]QTY
  Else
    Actzo [M:LOF5]QTY
  Endif
End
########################################
Subprog C_QTYECL(VALEUR)
Variable Integer VALEUR

  If VALEUR = G_NON and [M:LOF5]ECLBAS = GVML_TECDQTY
    # Si on éclate sur la quantité on réparti obligatoirement la quantité
    [M:LOF5]QTYECL = G_OUI
    Affzo [M:LOF5]QTYECL
    Diszo [M:LOF5]QTYECL
  Endif

End
########################################
Subprog AM_NBLOF(VALEUR)
Variable Decimal VALEUR


  If VALEUR < 2
    GMESSAGE = mess(10,GML_MSGLOF,1) : # Nombre d'éclatement invalide
    GERR     = 1
    mkstat   = 2
    End
  Endif
  # ---------------------
  If[M:LOF5]ECLBAS = GVML_TECDQTY
    # Eclatement par rapport à la Quantité : ne peut excéder la quantité d'origine
    # Si l'unité n'a pas de décimales
    If VALEUR > [M:LOF5]QTYBEF and [M:LOF5]UOMDEC = 0
      GMESSAGE = mess(10,GML_MSGLOF,1) : # Nombre d'éclatement invalide
      GERR     = 1
      mkstat   = 2
      End
    Endif
  Else
    # Eclatement par rapport au Montant
    If [M:LOF5]QTYECL = G_OUI
      # Si on réparti la quantité, et que l'UOM n'a pas de décimales, le nombre d'éclatements
      # Ne peut excéder la quantité d'origine.
      If VALEUR > [M:LOF5]QTYBEF and [M:LOF5]UOMDEC = 0
        GMESSAGE = mess(37,GML_MSGLOF,1) : # Dans ce cas le nombre d'éclatement ne peut excéder la quantité d'origine.
        GERR     = 1
        mkstat   = 2
        End
      Endif
    Else #Fq-62494
       If VALEUR <= [M:LOF5]QTYBEF or [M:LOF5]UOMDEC <> 0
         Actzo [M:LOF5]QTYECL : Affzo  [M:LOF5]QTYECL
    Endif
    Endif #Fq-62494
    # ---------------------
    If VALEUR > 999
      # maximum : 999 dépenses à générer
      GMESSAGE = mess(10,GML_MSGLOF,1) : # Nombre d'éclatement invalide
      GERR     = 1
      mkstat   = 2
      End
    Endif
  Endif
  # ---------------------
  # Gestion des boutons
  [M:LOF5]NBLOF = VALEUR
  # ---------------------
End

########################################
Subprog AS_TYPNUM(VALEUR)
Variable Integer VALEUR

  GMENLOC(GVML_NEADNU)   = 1

  If GLOFAUTNUM = 1
    # Si pas de numérotation automatique : pas possible de choisir nouveau numéro
    GMENLOC(GVML_NENONU) = 1
  Endif
  If GLOFAUTNUM = 2
    # Si numérotation automatique obligatoire : pas possible de choisir aucun
    GMENLOC(GVML_NEAUCU) = 1
  Endif
  If GLOFAUTNUM = 3
    # Si numérotation automatique facultative : tout est possible !
  Endif
End

########################################
Subprog AP_TYPNUM(VALEUR)
Variable Integer VALEUR

  If VALEUR = GVML_NEAUCU
    Diszo [M:LOF5]LIGSTR
    Diszo [M:LOF5]LIGINC
  Elsif VALEUR = GVML_NEINLI
    Actzo [M:LOF5]LIGSTR
    Actzo [M:LOF5]LIGINC
  Elsif VALEUR = GVML_NENONU
    Diszo [M:LOF5]LIGSTR
    Diszo [M:LOF5]LIGINC
  Endif
End

########################################
Subprog AM_LIGSTR(VALEUR)
Variable Decimal VALEUR

  If VALEUR < [M:LOF5]LINLOFMIN
    GMESSAGE = mess(11,GML_MSGLOF,1) : # Numéro de ligne invalide
    GERR     = 1
    mkstat   = 2
    End
  Endif
End

########################################
Subprog AM_LIGINC(VALEUR)
Variable Decimal VALEUR

  If VALEUR < 1
    GMESSAGE = mess(12,GML_MSGLOF,1) : # Incrément invalide
    GERR     = 1
    mkstat   = 2
    End
  Endif
End

########################################
Subprog AS_CODLOF(VALEUR)
Variable Char    VALEUR()

  If [M:LOF5]TYPNUM = GVML_NEAUCU
  Elsif [M:LOF5]TYPNUM = GVML_NEINLI
    mkstat = 2
  Elsif [M:LOF5]TYPNUM = GVML_NENONU
    If GLOFAUTNUM = 2
      mkstat = 2
    Endif
  Endif
End

########################################
Subprog AM_CODLOF(VALEUR)
Variable Char    VALEUR()

Local Integer N_I

  For N_I = 1 To [M:LOF5]NBDEP
    If N_I <> nolign
      If [M:LOF5]CODLOF(N_I-1) = VALEUR
        GMESSAGE = mess(19,GML_MSGLOF,1)-num$(N_I-1) : # Cette référence a déjà été saisie sur la ligne
        GERR     = 1
        mkstat   = 2
        Break
      Endif
    Endif
    #------------------------------
    # Suite de la boucle
  Next N_I
  If GERR = 1
    End
  Endif

  Read [LOFB]LOF0=VALEUR;[M:LOF5]LINLOF(nolign-1)
  If !fstat
    GMESSAGE = mess(20,GML_MSGLOF,1) : # Cette référence existe déjà dans
    GERR     = 1
    mkstat   = 2
    End
  Endif
End

########################################
Subprog AS_LINLOF(VALEUR)
Variable Decimal VALEUR

  If [M:LOF5]TYPNUM = GVML_NEAUCU
  Elsif [M:LOF5]TYPNUM = GVML_NEINLI
    mkstat = 2
  Elsif [M:LOF5]TYPNUM = GVML_NENONU
    mkstat = 2
  Endif
End

########################################
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR

Local Integer N_I
Local Decimal NQTY

  NQTY = VALEUR
  For N_I = 1 To [M:LOF5]NBDEP
    If N_I <> nolign
      NQTY = NQTY + [M:LOF5]QTY(N_I-1)
    Endif
    #------------------------------
    # Suite de la boucle
  Next N_I

  If [M:LOF5]UOMDEC = 0
    # Si l'unité n'a pas de décimale : il doit rester 1 pour la dépense d'origine
    If NQTY > [M:LOF5]QTYBEF-1
      GMESSAGE = mess(13,GML_MSGLOF,1) : # Quantité invalide : ne peut avoir une quantité à zéro à l'issue de l'éclatement.
      GERR     = 1
      mkstat   = 2
      End
    Endif
  Else
    # Si l'unité a des décimales : le solde doit être > 0
    If [M:LOF5]QTYBEF <= NQTY
      GMESSAGE = mess(13,GML_MSGLOF,1) : # Quantité invalide : ne peut avoir une quantité à zéro à l'issue de l'éclatement.
      GERR     = 1
      mkstat   = 2
      End
    Endif
  Endif
  #------------------------------
  [M:LOF5]QTY(nolign-1) = VALEUR
  Call CALCUL_SOLDE ( )
End

########################################
Subprog AM_AMTNOTCPY(VALEUR)
Variable Decimal VALEUR

Local Integer OK
Local Integer N_I
Local Decimal NMNT

  If [M:LOF5]NOTCPYBEF < 0 and VALEUR > 0
    # si montant d'origine < 0, le montant saisi doit l'être aussi
    GMESSAGE = mess(17,GML_MSGLOF,1) : # Le signe du montant saisi est incorrect
    GERR     = 1
    mkstat   = 2
    End
  Elsif [M:LOF5]NOTCPYBEF > 0 and VALEUR < 0
    # si montant d'origine > 0, le montant saisi doit l'être aussi
    GMESSAGE = mess(17,GML_MSGLOF,1) : # Le signe du montant saisi est incorrect
    GERR     = 1
    mkstat   = 2
    End
  Endif

  If [M:LOF5]NOTCPYBEF <> 0
    # Si dépense d'origne <> 0 on signale si la dépense éclatée est à 0
    If VALEUR = 0
      Call AVERTIR (mess(18,GML_MSGLOF,1), OK) From GESECRAN : # Le montant de la dépense est à zéro
      If OK = 1
        GERR   = 1
        mkstat = 2
        End
      Endif
    Endif
  Endif

  NMNT = abs(VALEUR)
  For N_I = 1 To [M:LOF5]NBDEP
    If N_I <> nolign
      NMNT = NMNT + abs([M:LOF5]AMTNOTCPY(N_I-1))
    Endif
    #------------------------------
    # Suite de la boucle
  Next N_I

  If abs([M:LOF5]NOTCPYBEF) <= NMNT
    GMESSAGE = mess(16,GML_MSGLOF,1) : # Montant invalide
    GERR     = 1
    mkstat   = 2
    End
  Endif
  #------------------------------
  [M:LOF5]AMTNOTCPY(nolign-1) = VALEUR
  Call PRORATE_MONTANT (nolign)
  Call CALCUL_SOLDE ()
  #------------------------------
End
########################################
Subprog ECLATER_EVENEMENTS (LERROR)
Variable Integer LERROR

Local Integer I_M, I_N, I, J
Local Char    PCLASSEO, PCLASSEN, PCLASSEM
Local Char    CHAMP_EFSO, CHAMP_EFSN, CHAMP_EFSM
Local Decimal MNTEVTO, MNTEVTN
Local Decimal WMONTANT, WMRESTE
Local Char    TAB_NOMZON(10)(40)
Local Integer TAB_ORDZON(40)
Local Integer TAB_STATUS(40)
Local Integer CODRET

If clalev([F:ADI])=0     : Local File ATABDIV     [ADI]   : Endif    # tables diverses
For [ADI] Where NUMTAB=GTD_EVENT & N2 = GVML_OMDEPEN

   If [F:ADI]CODE="FASCNL" | [F:ADI]CODE="LOFCNL" | [F:ADI]CODE="GRTCNL" | [F:ADI]CODE="LEACNL"
    Goto $NEXT_EVT
   Endif

   If clalev([F:EFS])  : Close Local File [F:EFS] : Endif
   If clalev([F:EFSO]) : Close Local File [F:EFSO] : Endif
   If clalev([F:EFSN]) : Close Local File [F:EFSN] : Endif
   If clalev([F:EFSM]) : Close Local File [F:EFSM] : Endif

   Local File =[F:ADI]A2 [EFS]
   Local File =[F:ADI]A2 [EFSO]
   Local File =[F:ADI]A2 [EFSN]
   Local File =[F:ADI]A2 [EFSM]
   # Lecture des événements existants sur le bien d'origine
   Filter[EFS] Where (CPY=[M:LOF0]CPY & REF=[M:LOF0]CODLOF & LIN=[M:LOF0]LINLOF)
   For [EFS]EVE0  With Stability
     WMRESTE = 0
      Raz [F:EFSO]
      Raz [F:EFSN]
      Raz [F:EFSM]
      [F:EFSO] = [F:EFS]
      [F:EFSN] = [F:EFS]
      [F:EFSM] = [F:EFS]
      PCLASSEO     =      "[F:EFSO]"
      PCLASSEN     =      "[F:EFSN]"
      PCLASSEM     =      "[F:EFSM]"
      #--------------------------------
      For nolign = 1 To [M:LOF5]NBDEP
         Raz TAB_NOMZON
         Raz TAB_ORDZON
         Raz TAB_STATUS
         # FQ97297 objet 2 (immos) au lieu de 1 (dépenses)
         Call GET_PRORATA_STATUS(1,[M:LOF0]CPY,[F:ADI]CODE,[F:EFSO]DPRPLN,TAB_NOMZON,TAB_ORDZON,TAB_STATUS,CODRET)
&             From GENEVE
         If [M:LOF5]NOTCPYBEF <>0
            For I=0 To dim(TAB_NOMZON)-1
               If TAB_NOMZON(I) <> ""
                 WNOMVAR = TAB_NOMZON(I)
                 CHAMP_EFSO   =   PCLASSEO+WNOMVAR
                 CHAMP_EFSN   =   PCLASSEN+WNOMVAR
                 CHAMP_EFSM   =   PCLASSEM+WNOMVAR
                 WMONTANT = (evalue(PCLASSEO+WNOMVAR)/[M:LOF5]NOTCPYBEF)*([M:LOF5]AMTNOTCPY(nolign-1))
                 Call GET_MNT_ARRONDI (WMONTANT ,[F:EFSO]CUR, MNTEVTN) From GLOBIENS
                 Assign  (CHAMP_EFSN) With MNTEVTN
                 WMRESTE = (evalue(PCLASSEM+WNOMVAR))
                 WMRESTE -= MNTEVTN
                 Assign  (CHAMP_EFSM) With WMRESTE
               Endif
             Next I
           Endif
           #--------------------------------
           [F:EFSN]TIMSTP = func GENEVE.BUILD_TIMSTP([F:EFSN]CREDAT, [F:EFSN]CRETIM)
           #----------------------------

           # Ecriture nouveaux événements
           [F:EFSN]REF = [M:LOF5]CODLOF(nolign-1)
           [F:EFSN]LIN = [M:LOF5]LINLOF(nolign-1)
           ################################################
           # Fq-GPXXX   Point d'entrée                    #
           #                                              #
           # Modifications spécifiques sur                #
           # l'enregistrement EFSN (EVTS nouveaux biens)  #
           #                                              #
           ################################################
           #GOK=1
           #GPOINT = "SPLWRIEFS" : Gosub ENTREE From EXEFNC
           #If GOK<1 : Return : Endif
           #### Point d'entrée - Fin ######################
           ################################################
           Write [F:EFSN]
           #> Si tentative d'écriture en double on attend que time soit différent
           #Local Integer NBMAXTRY : NBMAXTRY=2
           #If fstat=3
           #  For NBTRY=1 To NBMAXTRY
           #     Call TEMPO_EVT() From GENEVE
           #     [F:EFSN]CRETIM = time
           #     [F:EFSN]TIMSTP = func GENEVE.BUILD_TIMSTP([F:EFSN]CREDAT, [F:EFSN]CRETIM)
           #      ################################################
           #      # FQ-GPXXX   POINT D'entrée                    #
           #      #                                              #
           #      # Modifications spécifiques sur                #
           #      # l'enregistrement EFSN (EVTS nouveaux biens)  #
           #      #                                              #
           #      ################################################
           #      #GOK=1
           #      #GPOINT = "SPLWRIEFS" : Gosub ENTREE From EXEFNC
           #      #If GOK<1 : Return : Endif
           #      #### Point d'entrée - Fin ######################
           #      ################################################
           #     Write [F:EFSN]
           #     If !fstat
           #       Break
           #     Endif
           #  Next NBTRY
           #Endif
           #> Si la nouvelle tentative après tempo a de nouveau échouée, erreur
           If fstat
              RCOD = 90
              Infbox "Erreur : création événement /"-num$(RERROR)-"\"-[F:EFS]CPY-"-"-[F:EFS]EVT-"-"-num$([F:EFS]PLN)-"-"-[F:EFS]REF
              GOK    = 0
           Endif
        Next nolign
        ################################################
        # Fq-GPXXX   Point d'entrée                    #
        #                                              #
        # Modifications spécifiques sur                #
        # l'enregistrement EFSM (EVTS biens origine)   #
        #                                              #
        ################################################
        #GOK=1
        #GPOINT = "SPLREWEFS" : Gosub ENTREE From EXEFNC
        #If GOK<1 : Return : Endif
        #### Point d'entrée - Fin ######################
        ################################################
       #----------------------------
       # ré-écriture événements origine
       [F:EFS] = [F:EFSM]
       Rewrite[F:EFS]
       If fstat
         RERROR = fstat
         Infbox "Erreur : Modif. événement /"-num$(RERROR)-"\"-[F:EFS]CPY-"-"-[F:EFS]EVT-"-"-num$([F:EFS]PLN)-"-"-[F:EFS]REF
         GOK  = 0
       Endif

       If GOK=0 : Break 2 : Endif

      Next
      Filter [EFS]
   $NEXT_EVT
   Next

End
