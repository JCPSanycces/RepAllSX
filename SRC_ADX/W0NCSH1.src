#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque NCSH1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone NCSPROCAU
mkstat = 0
zoncou = "NCSPROCAU"
indice = 0
If varinit([M]NCSPROCAU,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]NCSPROCAU,"804","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]NCSPROCAU,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "NCSPROCAU" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]NCSPROCAU,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "NCSPROCAU" : GZNUM = 54866 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]NCSPROCAU,"804","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NCSPROCAU" : GZNUM = 54866 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]NCSPROCAU,"804",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "NCSPROCAU" : GZNUM = 54866 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone NCSDES
mkstat = 0
zoncou = "NCSDES"
indice = 0
If varmode([M]NCSDES,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NCSDES" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBLIG3
mkstat = 0
zoncou = "NBLIG3"
indice = 0
status = 1
zoncou = "NBLIG3"
If varmode([M]NBLIG3,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG3" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG3
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG3 = nolign
   status = 75
   Call SAI_NBLIG3(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBLIG3 From SUBNCSH
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBLIG3" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call AP_NBLIG3 From SUBNCSH
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NBLIG3" : GZNUM = 0 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBLIG3(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG3
mkstat = 0
zoncou = "NBLIG3"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBLIG3 From SUBNCSH
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBLIG3" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone DOCTYP
mkstat = 0
zoncou = "DOCTYP"
IMPENT = [M]DOCTYP(indice)
WNUM = IMPENT
If varinit([M]DOCTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]DOCTYP,indice)=0
 Call INICOMBO(3718) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_DOCTYP(IMPENT) From SUBNCSH
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,3718,1))))
 Endif
 [M]DOCTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DOCTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DOCTYP(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "DOCTYP" : GZNUM = 865 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_DOCTYP(IMPENT) From SUBNCSH
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DOCTYP" : GZNUM = 865 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WNUM<>IMPENT or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_DOCTYP(IMPENT) From SUBNCSH
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "DOCTYP" : GZNUM = 865 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif
[M]DOCTYP(indice) = IMPENT

## Zone VCRNUM
mkstat = 0
zoncou = "VCRNUM"
If varmode([M]VCRNUM,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_VCRNUM([M]VCRNUM(indice)) From SUBNCSH
 GACTION = SAVACT
 If mkstat=1 : Raz [M]VCRNUM(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "VCRNUM" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_VCRNUM([M]VCRNUM(indice)) From SUBNCSH
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "VCRNUM" : GZNUM = 26361 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call AP_VCRNUM([M]VCRNUM(indice)) From SUBNCSH
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "VCRNUM" : GZNUM = 26361 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone VCRTYP
mkstat = 0
zoncou = "VCRTYP"
IMPENT = [M]VCRTYP(indice)
If varinit([M]VCRTYP,indice)=0
 IMPENT = 1
Endif
[M]VCRTYP(indice) = IMPENT

## Zone VCRLIN
mkstat = 0
zoncou = "VCRLIN"
WNUM = [M]VCRLIN(indice)
If varmode([M]VCRLIN,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_VCRLIN([M]VCRLIN(indice)) From SUBNCSH
 GACTION = SAVACT
 If mkstat=1 : Raz [M]VCRLIN(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "VCRLIN" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_VCRLIN([M]VCRLIN(indice)) From SUBNCSH
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "VCRLIN" : GZNUM = 28682 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WNUM<>[M]VCRLIN(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_VCRLIN([M]VCRLIN(indice)) From SUBNCSH
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "VCRLIN" : GZNUM = 28682 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone ITMREF
mkstat = 0
zoncou = "ITMREF"
If varmode([M]ITMREF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ITMREF" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "VXADCUPC"
 Call ADCCTRUPC([M]ITMREF(indice)) From VXADCUPC
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ITMREF" : GZNUM = 3651 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("ITM","!",[M]ITMREF(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "ITMREF" : GZNUM = 3651 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone ECCVALMAJ
mkstat = 0
zoncou = "ECCVALMAJ"
If varmode([M]ECCVALMAJ,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ECCVALMAJ" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ECCVALMIN
mkstat = 0
zoncou = "ECCVALMIN"
If varmode([M]ECCVALMIN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ECCVALMIN" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone NCSQTY
mkstat = 0
zoncou = "NCSQTY"
If varmode([M]NCSQTY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NCSQTY" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DOCQTY
mkstat = 0
zoncou = "DOCQTY"
If varmode([M]DOCQTY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DOCQTY" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone STU
mkstat = 0
zoncou = "STU"
If varmode([M]STU,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "STU" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("TUN","!",[M]STU(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "STU" : GZNUM = 2076 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone DOCDAT
mkstat = 0
zoncou = "DOCDAT"
If varmode([M]DOCDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DOCDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone BPSNUM
mkstat = 0
zoncou = "BPSNUM"
If varmode([M]BPSNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BPSNUM" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("BPR","!",[M]BPSNUM(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "BPSNUM" : GZNUM = 3680 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone BPCNUM
mkstat = 0
zoncou = "BPCNUM"
If varmode([M]BPCNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BPCNUM" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("BPC","!",[M]BPCNUM(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "BPCNUM" : GZNUM = 3662 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PJT
mkstat = 0
zoncou = "PJT"
WCHAR = [M]PJT(indice)
If varmode([M]PJT,indice)=0
 SAVACT = GACTION : GACTION = "PJTBEFZON"
 Call PJT_BEFORE_ZONE([M]PJT(indice),"","","","","","","","","","","","","","","","","","","") From TRTPJT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]PJT(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "PJT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "PJTCTL"
  Call PJT_CONTROL([M]PJT(indice),"","","","","","","","","","","","","","","","","","","") From TRTPJT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PJT" : GZNUM = 1886 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]PJT(indice)
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]PJT(indice) = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PJT" : GZNUM = 1886 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]PJT(indice) or IMPMOD
     SAVACT = GACTION : GACTION = "PJTAFTMOD"
     Call PJT_AFTER_MODIFY([M]PJT(indice),"","","","","","","","","","","","","","","","","","","") From TRTPJT
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "PJT" : GZNUM = 1886 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone LINSTA
mkstat = 0
zoncou = "LINSTA"
IMPENT = [M]LINSTA(indice)
If varinit([M]LINSTA,indice)=0
 IMPENT = 1
Endif
If varmode([M]LINSTA,indice)=0
 [M]LINSTA(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "LINSTA" : Gosub ACTION From =IMPTRT
  IMPENT = [M]LINSTA(indice)
 Endif
Endif
[M]LINSTA(indice) = IMPENT

## Zone NBLIG3
mkstat = 0
zoncou = "NBLIG3"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "NCSH1"
Return

