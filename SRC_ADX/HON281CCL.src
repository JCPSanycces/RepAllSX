#<AdxTL>@(#)3.0.0.0 $Revision$
#*************************************************************************************
#* Exigence 82615 : Déclaration 281.5 des honoraires Belge
#* Traitement HON281CCL : Annulation des honoraires 281.5
#*************************************************************************************!

# Issue X3-107197 - 2018-09-11 by CBO : PARAMETER AND ACTIVITY CODE

Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","HON281CCL","HON281CCL",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

$DECLARE
Local Char    CRITHHO(250),CRITDHO(250)
Local Char    PREST(10)
Local Integer OK, NBLIN
Return

$OUVRE
If clalev([F:HHO])=0 : Local File HON281   [HHO] : Endif
If clalev([F:DHO])=0 : Local File HON281D  [DHO] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
Return

$INIT_DIA
TMP = 1 : TRA = 1
Return

$EXEC
Call HON281CCL
Return

$CRITERE
CRITDHO = 'CPY = "'+[M:DIA]CPY+'"'
If [M:DIA]STRDAT<>[0/0/0]
 CRITDHO -= '& YEA='+num$(year([M:DIA]STRDAT))
Endif
If [M:DIA]ALLPRVNUM<>2
 CRITDHO -= '& PRVNUM = "'+[M:DIA]PRVNUM+'"'
Endif
CRITHHO=CRITDHO
If [M:DIA]ALLFCY<>2
 CRITDHO -= '& FCY = "'+[M:DIA]FCY+'"'
Elsif GNBAUZ<>GNBSITE
 CRITDHO -= '& find(FCY,GUSRFCY(1..GNBAUZ))'
Endif
If [M:DIA]ALLTYP<>2
 CRITDHO -= '& TYP281 = '+num$([M:DIA]TYP281)
Endif
Return

Subprog HON281CCL
Gosub DECLARE
Gosub OUVRE

TIT = mess(58,122,1)-mess(4,3602,1) : # Annulation des lignes d'honoraires 281.5

If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif

Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(104,"-"),0) From GESECRAN

# Paramètres de lancement ---------------------------------------------------------------------
Call ECR_TRACE(mess(2,45,1)-":"-[M:DIA]CPY,0) From GESECRAN                : #Société
Call ECR_TRACE(mess(4,116,1)-":"-mess([M:DIA]ALLFCY,1,1),0) From GESECRAN  : #Tous sites
If [M:DIA]ALLFCY<>2
 Call ECR_TRACE(mess(3,45,1)-":"-[M:DIA]FCY,0) From GESECRAN               : #Site
Endif
Call ECR_TRACE(mess(2,47,1)-":"-num$(year([M:DIA]STRDAT)),0) From GESECRAN : #Année
Call ECR_TRACE(mess(20,197,1)-mess(17,122,1)-":"-mess([M:DIA]ALLPRVNUM,1,1),0) From GESECRAN : #Tous Prestaire
If [M:DIA]ALLPRVNUM<>2
 Call ECR_TRACE(mess(17,122,1)-":"-[M:DIA]PRVNUM,0) From GESECRAN          : #Prestataire
Endif
Call ECR_TRACE(mess(4,446,1)-":"-mess([M:DIA]ALLTYP,1,1),0) From GESECRAN  : #Toutes catégories
If [M:DIA]ALLTYP<>2
 Call ECR_TRACE(mess(3423,200,1)-":"-mess([M:DIA]TYP281,3623,1),0) From GESECRAN : #Catégorie 281.5
Endif
Call ECR_TRACE(string$(104,"-"),0) From GESECRAN
#----------------------------------------------------------------------------------------------

Gosub CRITERE
NBLIN = 0
For [DHO]DHO0(3) Where evalue(CRITDHO) : # DHO0 : CPY+YEA+PRVNUM+TYPLIN+NUM+LIN
 NBLIN =1

 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE([F:DHO]PRVNUM,0) From GESECRAN
 Call ECR_TRACE(string$(104,"-"),0) From GESECRAN
 PREST = [F:DHO]PRVNUM
 For [DHO]DHO0
  Call ECR_TRACE(num$([DHO]YEA)-mess([DHO]TYPLIN,3624,1)-[DHO]TYP-[DHO]NUM
&  -mess([DHO]TYP281,3623,1)-num$([DHO]AMTLEDINV),0) From GESECRAN
 Next
 Call DEBTRANS From GLOCK
 Gosub TR1
Next


If !NBLIN
 Call ECR_TRACE(mess(59,122,1),0) From GESECRAN : # Aucune ligne à annuler
Endif
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif

$SORTIE
End

$TR1
Trbegin [DHO],[HHO]
 # suppression des lignes de détail
 Delete [DHO] Where  evalue(CRITDHO) and PRVNUM=PREST
 If !fstat
  Call ECR_TRACE(PREST+" : "+num$(adxdlrec)-mess(959,196,1),0) From GESECRAN : # X enregistrements supprimés
 Elsif fstat=1
  GOK = -1
  GLOCK = "$HON281D"-PREST
  Goto ROLL_TR1
 Elsif fstat>5
  GOK = 0
  Call RSTA("DHO",PREST) From GLOCK
  Goto AB_TR1
 Endif

 # suppression des lignes d'entêtes (seulement si plus aucune ligne de détail)
 If [M:DIA]ALLTYP=2 and [M:DIA]ALLFCY=2 : # dans ce cas, on peut tout supprimer !
  Delete [HHO] Where evalue(CRITHHO) and PRVNUM=PREST
  If fstat=1
   GOK = -1
   GLOCK = "$HON281"-PREST
   Goto ROLL_TR1
  Elsif fstat>5
   GOK = 0
   Call RSTA("HHO",PREST) From GLOCK
   Goto AB_TR1
  Endif
 Else : # Dans ce cas, il faut regarder s'il ne reste pas des lignes de détail
  Filter [F:DHO] Where evalue(CRITHHO)and PRVNUM=PREST
  Read [F:DHO] First
  Filter [F:DHO]
  If fstat
   Delete [HHO] Where evalue(CRITHHO) and PRVNUM=PREST
   If fstat=1
    GOK = -1
    GLOCK = "$HON281"-PREST
    Goto ROLL_TR1
   Elsif fstat>5
    GOK = 0
    Call RSTA("HHO",PREST) From GLOCK
    Goto AB_TR1
   Endif
  Endif
 Endif

Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

$AB_TR1
Rollback
Return

#*************************************************************************************
#* Gestion du masque HON281CCL
#*************************************************************************************!

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If func AFNC.ACTIV("FEE") and func AFNC.PARAM("DCLFEES", VALEUR)<>"4" # Issue X3-107197
  # Société non définie pour traiter la 281.5
  GMESSAGE=mess(87,122,1)
  mkstat=2
Endif
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call INIALLFCY(VALEUR,[M]CPY) From CPTTRT
End

Subprog AS_FCY(VALEUR)
Variable Char VALEUR
Call AS_FCY(VALEUR) From CPTTRT
End

Subprog AS_PRVNUM(VALEUR)
Variable Char    VALEUR()
If [M]ALLPRVNUM = 2 : mkstat = 1 : End : Endif
End

Subprog AS_TYP281(VALEUR)
Variable Integer VALEUR
If [M]ALLTYP = 2 : mkstat = 1 : End : Endif
End

Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR = gdat$(1,1,year(datesyst)-1) : # Année civile précédente
Endif
End

Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 GMESSAGE=mess(1,762,1) : # Saisie obligatoire
 mkstat=2
Endif
End

Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
[M]STRDAT=gdat$(1,1,year(VALEUR))
[M]ENDDAT=gdat$(31,12,year(VALEUR))
Affzo [M]STRDAT
Affzo [M]ENDDAT
End

Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR = gdat$(31,12,year([M]STRDAT))
Endif
End

Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 GMESSAGE=mess(1,762,1) : # Saisie obligatoire
 mkstat=2
Endif
End

Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
[M]STRDAT=gdat$(1,1,year(VALEUR))
[M]ENDDAT=gdat$(31,12,year(VALEUR))
Affzo [M]STRDAT
Affzo [M]ENDDAT
End

Subprog AS_DATPCE(VALEUR)
Variable Date     VALEUR
If VALEUR=[0/0/0]
 VALEUR = [M]ENDDAT
Endif
End

#*************************************************************************************!

