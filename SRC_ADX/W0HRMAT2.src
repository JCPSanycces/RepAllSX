IMPTBL = 1

indice = 0
status = 1
zoncou = "NBRJNT"
If !mkstat
 NBLIG = [M]NBRJNT
 For nolign=1 To NBLIG
  indice = nolign-1
  [M]NBRJNT = nolign
  status = 75
  Call SAI_NBRJNT(IMPFIC,ACTION,IMPTRT)
  If mkstat : Break : Endif
 Next nolign
 If mkstat : End : Endif
 indice = 0
Endif

