## Zone SEX
mkstat = 0
zoncou = "SEX"
indice = 0
IMPENT = [M]SEX
If varinit([M]SEX,indice)=0
 IMPENT = 1
Endif
If varmode([M]SEX,indice)=0
 Call INICOMBO(10314) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_SEX(IMPENT) From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,10314,1))))
 Endif
 [M]SEX(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SEX" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SEX(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "SEX" : GZNUM = 44770 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]SEX = IMPENT

## Zone NTT
mkstat = 0
zoncou = "NTT"
indice = 0
WCHAR = [M]NTT
If varinit([M]NTT,indice)=0
 [M]NTT = GPAYS
Endif
If varmode([M]NTT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NTT" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("TCY","!",[M]NTT,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "NTT" : GZNUM = 45802 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "INIPAYS"
  Call INIPAYS([M]NTT,[M]NTTNAM) From TRTDIV
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NTT" : GZNUM = 45802 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_NTT([M]NTT) From SUBEML2
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NTT" : GZNUM = 45802 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]NTT or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_NTT([M]NTT) From SUBEML2
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "NTT" : GZNUM = 45802 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

