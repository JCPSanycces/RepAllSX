Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone OLDNAM
mkstat = 0
zoncou = "OLDNAM"
indice = 0
WCHAR = [M]OLDNAM
If varmode([M]OLDNAM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OLDNAM" : Gosub ACTION From =IMPTRT
 Endif
 If WCHAR<>[M]OLDNAM or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_OLDNAM([M]OLDNAM) From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "OLDNAM" : GZNUM = 55 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

