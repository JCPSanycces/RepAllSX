#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Objet PSO
###################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"            : Gosub OUVRE        From SUBPSOA
    When "FERME"            : Gosub FERME        From SUBPSOA        # Issue X3-49776 - 2018-06-25 by FGR
    When "LIENS"            : Gosub LIENS        From SUBPSOA
    When "RAZDUP"           : Gosub RAZDUP       From SUBPSOA
    When "RAZCRE"           : Gosub RAZCRE       From SUBPSOA
    When "CREATION"         : Gosub CREATION     From SUBPSOA
    When "INICRE"           : Gosub INICRE       From SUBPSOA
    When "APRES_CRE"        : Gosub APRES_CRE    From SUBPSOA
    When "SETBOUT"          : Gosub SETBOUT      From SUBPSOA
    When "AVANTBOUT"        : Gosub AVANTBOUT    From SUBPSOA
    When "EXEBOUT"          : Gosub EXEBOUT      From SUBPSOA
    When "MODIF"            : Gosub MODIF        From SUBPSOA
    When "AVANT_MOD"        : Gosub AVANT_MOD    From SUBPSOA        # Issue X3-49776 - 2018-06-25 by FGR
    When "AVANT_MODFIC"     : Gosub AVANT_MODFIC From SUBPSOA        # Issue X3-49776 - 2018-06-25 by FGR
    When "APRES_MODIF"      : Gosub APRES_MODIF  From SUBPSOA
    When "APRES_MOD"        : Gosub APRES_MOD    From SUBPSOA
    When "OUVRE_BOITE"      : Gosub OUVRE_BOITE  From SUBPSOA
    When "AV_ANNULE"        : Gosub AV_ANNULE    From SUBPSOA
    When "ANNULE"           : Gosub ANNULE       From SUBPSOA
    When "FILGAUCHE"        : Gosub FILGAUCHE    From SUBPSOC
    When "AP_FILGAUCHE"     : Gosub AP_FILGAUCHE From SUBPSOC
    When "HINT"             : Gosub HINT_KEY     From SUBPSOC
    When "DEB_PICK"         : Gosub DEB_PICK     From SUBPSOC
    When "PICKE"            : Gosub PICKE        From SUBPSOC
    When "DEPICK"           : Gosub DEPICK       From SUBPSOC
    When "FIN_PICK"         : Gosub FIN_PICK     From SUBPSOC
  Endcase
Return

###################################################################################################
# Screens fields
###################################################################################################
# PSO0
###################################################################################################
Subprog C_OPPNUM(VALEUR)
Variable Char    VALEUR()

  Read [OPPPJM]OPPPJM0=VALEUR
  If !fstat Then
    #If [F:OPPPJM]OPPSTATE <> 1 and [F:OPPPJM]OPPSTATE <> 2 Then                              # Issue X3-111551 - 2018-10-18 by FGR
    If [F:OPPPJM]OPPSTATE <> 1 and [F:OPPPJM]OPPSTATE <> 2 and [F:OPPPJM]OPPSTATE <> 3 Then   # Issue X3-111551 - 2018-10-18 by FGR
      GMESSAGE = func AFNC.MES1(mess(499,2260,1), VALEUR)
      GERR = 1
      mkstat = 2
      End
    Endif
    If [F:OPPPJM]OPPMOD = [V]CST_AYES Then
      GMESSAGE = func AFNC.MES1(mess(130,2260,1), VALEUR)
      GERR = 1
      mkstat = 2
      End
    Endif
  Else
    GMESSAGE = func AFNC.MES1(mess(9,2260,1), VALEUR)
    GERR = 1
    mkstat = 2
    End
  Endif
End

###################################################################################################
Subprog AM_OPPNUM(VALEUR)
Variable Char    VALEUR()

  # -----------------------------
  Read [OPP]OPP0=VALEUR
  [M:PSO1]CUR = [F:OPP]CUR
  [M:PSO1]SALFCY = func PIMPL_CSTD_PROGS.GET_FCY_VALUE(GACTX, VALEUR, AVOID.ACHAR, AVOID.ACHAR, GMESSAGE)
  # -----------------------------
  If [F:OPP]OPPCMP <> AVOID.ACHAR Then
    [M:PSO1]BPCORD = [F:OPP]OPPCMP
  Endif
  [M:PSO0]DOCTYP = 1
  # -----------------------------
  Call AM_SALFCY([M:PSO1]SALFCY)
  Call AM_DOCTYP([M:PSO0]DOCTYP)
  Call AM_BPCORD([M:PSO1]BPCORD)
  # -----------------------------
  Affzo [M:PSO0]1-99
End

###################################################################################################
Subprog IB_HDOCNUM

  If [M:PSO0]HDOCNUM = AVOID.ACHAR Then
    Raz GBOUT1
  Else
    GBOUT1 = mess([M:PSO0]DOCTYP,7718,1)
  Endif
End

###################################################################################################
Subprog AM_DOCTYP(VALEUR)
Variable Integer VALEUR

  Call CHANGEDOCTYP(VALEUR)
  Case VALEUR
    When 1
      # Quote
      Call SQ_SALFCY([M:PSO1]SALFCY)
      [M:PSO0]TUNAOB = "SQH"
    When 2
      # Sales order
      Call SO_SALFCY([M:PSO1]SALFCY)
      [M:PSO0]TUNAOB = "SOH"
    When 3
      # Direct invoice
      Call SI_SALFCY([M:PSO1]SALFCY)
      [M:PSO0]TUNAOB = "SIH"
  Endcase
End

###################################################################################################
# PSO1
###################################################################################################
Subprog C_SALFCY(VALEUR)
Variable Char    VALEUR()

Local Char WLEGCPY(GLONCPY)
Local Char WPIMCPY(GLONCPY)

  WLEGCPY = fmet GACTX.ACACHE.AFCY.AGETVALCHAR(VALEUR, "LEGCPY")
  WPIMCPY = func PIMPL_CSTD_PROGS.GET_CPY_VALUE(GACTX, [M:PSO0]OPPNUM, AVOID.ACHAR, AVOID.ACHAR, GMESSAGE)
  If GMESSAGE <> AVOID.ACHAR Then
    GERR = 1
    mkstat = 2
    End
  Endif
  If WLEGCPY <> WPIMCPY Then
    GMESSAGE = func AFNC.MES2(mess(556,2260,1), VALEUR, [M:PSO0]OPPNUM)
    GERR = 1
    mkstat = 2
    End
  Endif
End

###################################################################################################
Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()

  If [M:PSO1]STOFCY <> AVOID.ACHAR and fmet GACTX.ACACHE.AFCY.AGETVALCHAR([M:PSO1]STOFCY, "LEGCPY") <> fmet GACTX.ACACHE.AFCY.AGETVALCHAR(VALEUR, "LEGCPY") Then
    Raz [M:PSO1]STOFCY
    Affzo [M:PSO1]STOFCY
  Endif
  # -----------------------------
  GFCY = VALEUR
  Call GETSOC(VALEUR) From DEVSUB
  Call GETCPY(GFCY, "SLT", 1, GFLAG) From TRTX3CPT
  # -----------------------------
  Call DISPLAY_HIDE_REVNUM(VALEUR) From SUBPSOA  # Issue X3-49776 - 2018-06-25 by FGR
End

###################################################################################################
Subprog AM_BPCORD(VALEUR)
Variable Char VALEUR()

  If [M:PSO1]BPCORD <> VALEUR Then
    Raz [M:PSO1]BPAADD
    Raz [M:PSO1]BPCINV
    Raz [M:PSO1]BPCPYR
    Raz [M:PSO1]VACBPR
    Raz [M:PSO1]PTE
    Raz [M:PSO1]PRITYP
  Endif
  Read [BPC]BPC0=VALEUR
  If fstat Then
    Raz [F:BPC]
  Else
    If [F:BPC]BPDADD <> AVOID.ACHAR Then
      [M:PSO1]BPAADD = [F:BPC]BPDADD
    Endif
    If [F:BPC]BPCINV <> AVOID.ACHAR Then
      [M:PSO1]BPCINV = [F:BPC]BPCINV
    Endif
    If [F:BPC]BPCPYR <> AVOID.ACHAR Then
       [M:PSO1]BPCPYR = [F:BPC]BPCPYR
    Endif
    If [F:BPC]VACBPR <> AVOID.ACHAR Then
      [M:PSO1]VACBPR = [F:BPC]VACBPR
    Endif
    If [F:BPC]PTE <> AVOID.ACHAR Then
      [M:PSO1]PTE = [F:BPC]PTE
    Endif
    If [F:BPC]PRITYP <> 0 Then
      [M:PSO1]PRITYP = [F:BPC]PRITYP
    Endif
  Endif
  Read [BPD]BPD0=VALEUR;[M:PSO1]BPAADD
  If fstat Then
    Raz [F:BPD]
  Else
    If [F:BPD]STOFCY <> AVOID.ACHAR Then
      [M:PSO1]STOFCY = [F:BPD]STOFCY
    Endif
  Endif
  Affzo [M:PSO1]1-99
End

###################################################################################################
Subprog AM_BPAADD(VALEUR)
Variable Char    VALEUR()

  Read [BPD]BPD0=[M:PSO1]BPCORD;VALEUR
  If fstat Then
    Raz [F:BPD]
  Else
    Filter [BPD] Where BPCNUM = [M:PSO1]BPCORD
    If [F:BPD]STOFCY <> AVOID.ACHAR Then
      [M:PSO1]STOFCY = [F:BPD]STOFCY
    Endif
    Affzo [M:PSO1]STOFCY
    Filter [BPD]
  Endif
End

###################################################################################################
Subprog C_VLYDAT(VALEUR)
Variable Date    VALEUR

  If VALEUR < [M:PSO0]DOCDAT Then
    GMESSAGE = func AFNC.MES1(mess(557,2260,1), format$("D:"+GFMDAT4,[M:PSO0]DOCDAT))
    GERR = 1
    mkstat = 2
    End
  Endif
End

###################################################################################################
Subprog C_DEMDLVDAT(VALEUR)
Variable Date    VALEUR

Local Date WDEMDLVDAT
Local Integer WOK

  WDEMDLVDAT = VALEUR
  # --> Vérification de la date de livraison demandée
  Call CTLUVYBPD(WDEMDLVDAT, [M:PSO1]BPAADD, [M:PSO1]BPCORD, 0) From TRTVENCTL
  If mkstat = 2 Then
    WOK = 2
    Call AVERTIR(mess(496,197,1) - ":" - format$(GFMDAT,WDEMDLVDAT) - ":" - GMESSAGE, WOK) From GESECRAN
    Raz GMESSAGE
    If WOK = 1 Then
      End
    Endif
    mkstat = 0
  Endif
  VALEUR = WDEMDLVDAT
End

###################################################################################################
Subprog C_SHIDAT(VALEUR)
Variable Date    VALEUR

Local Integer WOK

  If VALEUR > [M:PSO1]DEMDLVDAT Then
    WOK = 2
    Call AVERTIR(mess(33,192,1), WOK) From GESECRAN
    Raz GMESSAGE
    If WOK = 1 Then
      mkstat = 2
      End
    Endif
  Endif
End

###################################################################################################
Subprog C_SIVTYP(VALEUR)
Variable Char    VALEUR()

  Call CONT_ROLE(VALEUR, "TSV", "SIVTYP") From SUBARL
  If mkstat Then
    End
  Endif
  If func AFNC.ACTIV("KPO") > 0 Then
    If func PORLEGLIB.CTLDOCTYP(VALEUR, "SIV", GMESSAGE) = 1 Then
      mkstat = 2
      End
    Endif
  Endif
End

###################################################################################################
Subprog C_STRDUDDAT(VALEUR)
Variable Date    VALEUR

Local Integer OK

  If VALEUR <> [M:PSO1]STRDUDDAT and VALEUR < [M:PSO0]DOCDAT Then
    OK = 1
    Call AVERTIR(mess(252,192,1), OK) From GESECRAN
    If OK = 1 Then
      mkstat = 2
    Endif
  Endif
End

###################################################################################################
# PSO2
###################################################################################################
# In SUBPSO2 script because there are field with same name than in PSO3
###################################################################################################

###################################################################################################
# PSO3
###################################################################################################
Subprog AS_NBLIG3
  If [M:PSO3]ITMREF(nolign-1) = AVOID.ACHAR Then
    mkstat = 2
  Endif
End

###################################################################################################
Subprog AM_ITMDES(VALEUR)
Variable Char    VALEUR()

Local Integer NI

  If VALEUR <> [M:PSO3]ITMDES(nolign-1) Then
    For NI = 0 To [M:PSO2]NBLIG2-1
      If [M:PSO2]SOLDSEQNUM(NI) = [M:PSO3]SEQNUM(nolign-1) Then
        [M:PSO2]ITMDES(NI) = VALEUR
        Affzo [M:PSO2]ITMDES(NI)
      Endif
    Next NI
  Endif
End

###################################################################################################
Subprog AM_BASPRI(VALEUR)
Variable Decimal VALEUR

Local Integer NI

  If VALEUR <> [M:PSO3]BASPRI(nolign-1) Then
    If (VALEUR > 0) & ([M:PSO3]APPLYBPRI(nolign-1) <> [V]CST_AYES) Then
      [M:PSO3]APPLYBPRI(nolign-1) = [V]CST_AYES
    Endif
    For NI = 0 To [M:PSO2]NBLIG2-1
      If [M:PSO2]SOLDSEQNUM(NI) = [M:PSO3]SEQNUM(nolign-1) Then
        [M:PSO2]BASPRI(NI) = VALEUR
        Affzo [M:PSO2]BASPRI(NI)
      Endif
    Next NI
  Endif
End

###################################################################################################
# PSO4
###################################################################################################
Subprog IB_NBLIG4

  # Issue X3-95321 - 2018-08-08 by FGR
  If [M:PSO4]CRRREV(nolign-1) = func SUBPSOA.GET_ICON_BASKET() Then
    Raz GBOUT1
  Endif
End

###################################################################################################
# SUBROUTINES
###################################################################################################
Subprog GREY_DOCTYP(DOCTYP)
Variable Integer DOCTYP

  # Grey fields on screen PSO1 based on document type
  Case DOCTYP
    When 1
      # Quote
      Actzo [M:PSO1]10
      Diszo [M:PSO1]15
      Diszo [M:PSO1]20
    When 2
      # Sales order
      Diszo [M:PSO1]10
      Actzo [M:PSO1]15
      Diszo [M:PSO1]20
    When 3
      # Direct invoice
      Diszo [M:PSO1]10
      Diszo [M:PSO1]15
      Actzo [M:PSO1]20
  Endcase
End

###################################################################################################
Subprog CHANGEDOCTYP(DOCTYP)
Variable Integer DOCTYP

  Case DOCTYP
    When 1
      # Quote
      Effzo [M:PSO1]15
      Effzo [M:PSO1]20
      [M:PSO1]ALLTYP = 0     # Manbatory to display it empty because this is a LM
    When 2
      # Sales order
      Effzo [M:PSO1]10
      Effzo [M:PSO1]20
    When 3
      # Direct invoice
      Effzo [M:PSO1]10
      Effzo [M:PSO1]15
      [M:PSO1]ALLTYP = 0     # Manbatory to display it empty because this is a LM
  Endcase
  Affzo [M:PSO1]1-99
  Call GREY_DOCTYP(DOCTYP)
End

###################################################################################################
Subprog SQ_SALFCY(VALEUR)
Variable Char VALEUR()

Local Integer IRET

  If GSQHTYP <> AVOID.ACHAR Then
    [M:PSO1]SQHTYP = GSQHTYP
    Affzo [M:PSO1]SQHTYP
    Call LEC_TSQ_LEG(GCURLEG, [M:PSO1]SQHTYP, IRET) From TRTLECLEG
    Call AM_SQHTYP([M:PSO1]SQHTYP) From W1PSO1
  Endif
  If dim([M:PSO2]NBLIG2) > 0 and [M:PSO2]NBLIG2 > 0 Then
    [M:PSO1]SALFCY = VALEUR
  Endif
  If GUPDCUR = 1 Then
    Diszo [M:PSO1]CUR
  Else
    Actzo [M:PSO1]CUR
  Endif
  If GNOTATI = 1 Then
    Diszo [M:PSO1]PRITYP
  Else
    Actzo [M:PSO1]PRITYP
  Endif
  If GLINBPD = 1 Then
    Diszo [M:PSO1]BPAADD
  Else
    Actzo [M:PSO1]BPAADD
  Endif
  If [M:PSO1]BPCORD <> AVOID.ACHAR Then
    If dim([M:PSO1]VACBPR) > 0 Then
      If [F:BPD]VACBPR <> AVOID.ACHAR Then # Are you sure that the current BPD is the correct one?
        If [F:BPD]VACBPR <> [M:PSO1]VACBPR Then
          [M:PSO1]VACBPR = [F:BPD]VACBPR
        Endif
      Else
        Call INIT_REGIME([M:PSO1]BPCORD, GSOCIETE, "C", [M:PSO1]VACBPR) From CPTSUB
      Endif
    Endif
    If dim([M:PSO1]PTE) > 0 Then
      Call INIPTE([F:BPC]BPCPYR, [F:BPC]BPCINV, "C", [M:PSO1]PTE) From TRTX3
    Endif
  Endif
  If [M:PSO1]STOFCY = AVOID.ACHAR Then
    If [F:BPD]STOFCY = AVOID.ACHAR or [M:PSO1]BPCORD = AVOID.ACHAR Then
      Read [FCY]FCY0=GFCYDEF(7)
      If fstat Then
        Raz [F:FCY]
      Endif
    Else
      Read [FCY]FCY0=[F:BPD]STOFCY
    Endif
    If [F:FCY]LEGCPY = GSOCIETE Then
      [M:PSO1]STOFCY = [F:FCY]FCY
    Endif
  Endif
  Affzo [M:PSO1]1-99
End

###################################################################################################
Subprog SO_SALFCY(VALEUR)
Variable Char VALEUR()

  [M:PSO1]ALLTYP = GALLTYP
  If dim([M:PSO2]NBLIG2) > 0 and [M:PSO2]NBLIG2 > 0 Then
    [M:PSO1]SALFCY = VALEUR
  Endif
  If GUPDCUR = 1 Then
    Diszo [M:PSO1]CUR
  Else
    Actzo [M:PSO1]CUR
  Endif
  If GNOTATI = 1 Then
    Diszo [M:PSO1]PRITYP
  Else
    Actzo [M:PSO1]PRITYP
  Endif
  If GLINBPD = 1 Then
    Diszo [M:PSO1]BPAADD
  Else
    Actzo [M:PSO1]BPAADD
  Endif
  If [M:PSO1]BPCORD <> AVOID.ACHAR Then
    If dim([M:PSO1]VACBPR) > 0 Then
      If [F:BPD]VACBPR <> AVOID.ACHAR Then # Are you sure that the current BPD is the correct one?
        If [F:BPD]VACBPR <> [M:PSO1]VACBPR Then
          [M:PSO1]VACBPR = [F:BPD]VACBPR
        Endif
      Else
        Call INIT_REGIME([M:PSO1]BPCORD, GSOCIETE, "C", [M:PSO1]VACBPR) From CPTSUB
      Endif
    Endif
    If dim([M:PSO1]PTE) > 0 Then
      Call INIPTE([F:BPC]BPCPYR, [F:BPC]BPCINV, "C", [M:PSO1]PTE) From TRTX3
    Endif
  Endif
  Affzo [M:PSO1]1-99
End

###################################################################################################
Subprog SI_SALFCY(VALEUR)
Variable Char    VALEUR()

Local Integer WRET

  If [M:PSO1]SIVTYP <> AVOID.ACHAR Then
    If [F:TSV]SIVTYP <> [M:PSO1]SIVTYP Then
      Call LEC_TSV_LEG(GCURLEG, [M:PSO1]SIVTYP, WRET) From TRTLECLEG
      If WRET Then
        Raz [F:TSV]
      Endif
    Endif
  Endif
  If dim([M:PSO2]NBLIG2) > 0 and [M:PSO2]NBLIG2 > 0 Then
    [M:PSO1]SALFCY = VALEUR
  Endif
  If GUPDCUR = 1 Then
    Diszo [M:PSO1]CUR
    Diszo [M:PSO1]CURTYP
  Else
    Actzo [M:PSO1]CUR
    If [M:PSO1]CUR <> GLOCALDEV Then
      Actzo [M:PSO1]CURTYP
    Endif
  Endif
  If GNOTATI = 1 Then
    Diszo [M:PSO1]PRITYP
  Else
    Actzo [M:PSO1]PRITYP
  Endif
  If [M:PSO1]BPCINV <> AVOID.ACHAR Then
    If dim([M:PSO1]VACBPR) > 0 Then
      If [F:BPD]VACBPR <> AVOID.ACHAR Then # Are you sure that the current BPD is the correct one?
        If [F:BPD]VACBPR <> [M:PSO1]VACBPR Then
          [M:PSO1]VACBPR = [F:BPD]VACBPR
        Endif
      Else
        Call INIT_REGIME([M:PSO1]BPCINV, GSOCIETE, "C", [M:PSO1]VACBPR) From CPTSUB
      Endif
    Endif
    If dim([M:PSO1]PTE) > 0 Then
      Call INIPTE([M:PSO1]BPCPYR, [M:PSO1]BPCINV, "C", [M:PSO1]PTE) From TRTX3
    Endif
  Endif
  Affzo [M:PSO1]1-99
End

###################################################################################################
Funprog FAM_OPPNUM()
  Call AM_OPPNUM([M:PJM0]OPPNUM)
End 0

