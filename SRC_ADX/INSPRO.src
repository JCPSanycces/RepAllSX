#################################################################################
# Cette action INSPRO -> bouton "Proposition" dans les inscriptions
######################################################################################
# Modifications :
#     SYMEU - 04/10/10 - EXI 66191 LOT 10 - V6.1 : stage non défini
#     SEGAY - 18/01/11 - EXI 66191 LOT 1
#              - Remplacement table ADI 463 par ORGANISME TYP=6 (financeur)
#     SEGAY - 06/09/11 - FQ75536 - Nom-Prénom
#     MABOS - 05/12/12 - FQ 81085-US1046 - Add Control /leg
#     MABOS - 22/04/13 - FQ 86015 - US 1531 - improvement traces in mass processing
#     MABOS - 26/07/13 - FQ 81085 - US 1833 - memo + modif "first entry" in the action
##################################################################################
Raz GPILOBJ
Call OBJET("INS",GBIDC1,"") From GOBJET

End

########
$ACTION

#MABOS-26/07/13-FQ81085-US1833-modif "first entry" in the action
Case ACTION
 When "INIT"       : Gosub INIT :#MABOS-26/07/13-FQ81085-US1833-
 When "OUVRE"      : Gosub OUVRE
# When "INIT_DIA"   : Gosub OUVRE:#MABOS-26/07/13-FQ81085-US1833
 When "CONTROLE"   : Gosub CONTROLE
 When "BOUTON"     : Gosub BOUTON
 When "DEBUT"      : Gosub DEBUT
 When "OK"         : Gosub OK
 When "EXEC"       : Gosub EXEC : #MABOS-05/12/12-FQ 81085-US1046
 When "FIN"        : Gosub FIN  : #MABOS-05/12/12-FQ 81085-US1046
Endcase

Return

##################################################################################
# PROPOSITION INSCRIPTIONS
##################################################################################
#MABOS-26/07/13-FQ81085-US1833-modif "first entry" in the action
$INIT
Local Mask LISDEM [LDEM]
Local Mask INSPRO [DIA]
Raz [M:DIA]
# MABOS-11/03/13-FQ81085-US1436-Add leg in the screen
If dim([M:DIA]LEG)>0  & [M:DIA]LEG = "" Then
  [M:DIA]LEG =GLEGFIL
  GCURLEG = [M:DIA]LEG
Endif
# MABON 16/09/10 - A l'ouverture, pré-sélection des paramètres
If GFONCTION="GESHRSES" and clalev([M:HRSES0])>0 Then
  If [M:HRSES0]STG<>"" :#MABOS-26/07/13
    [M:DIA]ALLSTG  = 1
    [M:DIA]STAGE   = [M:HRSES0]STG
  Endif
  # FQ79679 - MABON 31/01/12 - Changements dans l'écran de proposition
#  [M:DIA]ALLSES  = 1
  # Fin MABON
  [M:DIA]SESSION = [M:HRSES0]COD

  [M:DIA]DATSTR  = [M:HRSES1]STRDAT
  [M:DIA]DATEND  = [M:HRSES1]ENDDAT
Endif

# MABON 16/09/10 - A l'ouverture, pré-sélection des paramètres
If GFONCTION="GESCSI" and clalev([M:CSI0])>0 Then
# SEGAY 28/09/10 - Si action sur champ ligne de stage du parcours
# En paramètre le stage de la ligne écran CSI2
  If dim (PARAM(1))>0 & PARAM(1)<>"" & clalev([M:CSI2])>0 Then
    [M:DIA]STAGE = PARAM(1)
    [M:DIA]ALLSTG  = 1
  Endif
  [M:DIA]ALLCSI  = 1
  [M:DIA]CODCSI  = [M:CSI0]COD

  [M:DIA]DATSTR  = [M:CSI1]STRDAT
  [M:DIA]DATEND  = [M:CSI1]ENDDAT

Endif
# MABON 16/09/10 - A l'ouverture, pré-sélection des paramètres
If GFONCTION="GESINS" and clalev([M:INS0])>0 Then

# SBA 30/08/2013 : 1833
  If([M:INS0]STG)<>""
  [M:DIA]ALLSTG  = 1
  [M:DIA]STAGE   = [M:INS0]STG
Endif
  # FQ79679 - MABON 31/01/12 - Changements dans l'écran de proposition
#  [M:DIA]ALLSES  = 1
  # Fin MABON
  [M:DIA]SESSION = [M:INS0]SES

  If [M:INS3]NBLIG1>0 Then
    [M:DIA]DATSTR  = [M:INS3]DAT(0)
    [M:DIA]DATEND  = [M:INS3]DAT([M:INS3]NBLIG1-1)
    Grizo [M:DIA]DATSTR, DATEND
  Endif
Endif

#MABOS-05/12/12-
#[M:DIA]LEG-invisible
  If GFONCTION="GENINS" Then
    Raz [M:DIA]
    #MABOS-26/07/13-FQ81085-US1833-mémo
    Call LECMEMO("STD","[M:DIA]","pin") From GMEMO
    If dim([M:DIA]LEG)>0: If [M:DIA]LEG <>"" Then GCURLEG=[M:DIA]LEG :Endif:Endif
    #end MABOS-FQ81085-US1833
  Else
    [M:DIA]LEG = GCURLEG
  Endif
  If [M:DIA]LEG="" Then [M:DIA]LEG=GLEGFIL : Endif
  #GCURLEG=[M:DIA]LEG
Affzo [M:DIA]
Return

$OUVRE

Local Char SYMBOLE (80)
Local Char SYMBDEM (80)
Gosub OUVRE From SUBINS
Gosub OUVRE From WPDEFTABLE
If clalev([F:CSI])=0 : Local File COURSEI   [CSI] : Endif
If clalev([F:CIL])=0 : Local File COURISLIG [CIL] : Endif
# FQ72851 - MABON 12/04/11 - Ajout Prénom du salarié
If clalev([F:ID])=0  : Local File EMPLOID   [ID]  : Endif

#LIPET - X3-62866 - 2017-11-08 - START
If clalev([F:HRTCR])=0 : Local File HRTRACSTREP     [HRTCR] : Endif
#Raz [M:DIA]
#LIPET - X3-62866 - 2017-11-08 - END
#MABOS-26/07/13-FQ81085-US1833-modif "first entry" in the action
# move to $INIT
#Case BOITE
#When "INSPRO"
## MABON 16/09/10 - A l'ouverture, pré-sélection des paramètres
#If GFONCTION="GESHRSES" and clalev([M:HRSES0])>0 Then
#  [M:DIA]ALLSTG  = 1
#  [M:DIA]STAGE   = [M:HRSES0]STG
#
#  # FQ79679 - MABON 31/01/12 - Changements dans l'écran de proposition
##  [M:DIA]ALLSES  = 1
#  # Fin MABON
#  [M:DIA]SESSION = [M:HRSES0]COD
#
#  [M:DIA]DATSTR  = [M:HRSES1]STRDAT
#  [M:DIA]DATEND  = [M:HRSES1]ENDDAT
#Endif
#
## MABON 16/09/10 - A l'ouverture, pré-sélection des paramètres
#If GFONCTION="GESCSI" and clalev([M:CSI0])>0 Then
## SEGAY 28/09/10 - Si action sur champ ligne de stage du parcours
## En paramètre le stage de la ligne écran CSI2
#  If dim (PARAM(1))>0 & PARAM(1)<>"" & clalev([M:CSI2])>0 Then
#    [M:DIA]STAGE = PARAM(1)
#    [M:DIA]ALLSTG  = 1
#  Endif
#  [M:DIA]ALLCSI  = 1
#  [M:DIA]CODCSI  = [M:CSI0]COD
#
#  [M:DIA]DATSTR  = [M:CSI1]STRDAT
#  [M:DIA]DATEND  = [M:CSI1]ENDDAT
#Endif
## MABON 16/09/10 - A l'ouverture, pré-sélection des paramètres
#If GFONCTION="GESINS" and clalev([M:INS0])>0 Then
#  [M:DIA]ALLSTG  = 1
#  [M:DIA]STAGE   = [M:INS0]STG
#
#  # FQ79679 - MABON 31/01/12 - Changements dans l'écran de proposition
##  [M:DIA]ALLSES  = 1
#  # Fin MABON
#  [M:DIA]SESSION = [M:INS0]SES
#
#  If [M:INS3]NBLIG1>0 Then
#    [M:DIA]DATSTR  = [M:INS3]DAT(0)
#    [M:DIA]DATEND  = [M:INS3]DAT([M:INS3]NBLIG1-1)
#    Grizo [M:DIA]DATSTR, DATEND
#  Endif
#Endif
#
##MABOS-05/12/12-
##[M:DIA]LEG-invisible
#  If GFONCTION="GENINS" Then
#    Raz [M:DIA]
#  Else
#    [M:DIA]LEG = GCURLEG
#  Endif
#  If [M:DIA]LEG="" Then [M:DIA]LEG=GLEGFIL : Endif
#  #GCURLEG=[M:DIA]LEG
