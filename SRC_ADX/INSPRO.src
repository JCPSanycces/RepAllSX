#####################################
$CONTROLE
#MABOS-05/12/12-FQ 81085-US1046
# Control same LEG between stage, Domaine, Thème , parcours, session, borne demande
#MABOS-26/07/13-FQ81085-US1833-modif "first entry" in the action
#add "Case Boite" because same action for the both
Case BOITE
When "INSPRO"
    Local Integer WOK
    Local Char WECR(50)
    Local Char WLIBCOUR(50)
    Local Char WMESSAGE(250)
    Local Char WFIELD(30) (1..6)
    Local Char WLEG(GLONADI) (1..6)

    #If [M]LEG ="" Then
    WOK=0
    Call GET_LEGSTG([M]STAGE,WOK, WLEG(1), 0)  From TOOLSHRLEG     :# stage
    Call GET_LEGADI("10381",[M]DOMAINE,WOK, WLEG(2), 0)  From TOOLSHRLEG   :# DOMAINE
    Call GET_LEGADI("10457",[M]THEME,WOK, WLEG(3), 0)  From TOOLSHRLEG   :# THEME
    Call GET_LEGCSI([M]CODCSI,WOK, WLEG(4), 0)   From TOOLSHRLEG   :# Parcours individualisé
    Call GET_LEGHRSES([M]SESSION,WOK, WLEG(5), 0)   From TOOLSHRLEG   :# session
    If [M]DEMDEB = [M]DEMFIN & [M]DEMDEB <>"" Then
       Call GET_LEGDEM([M]DEMDEB,WOK, WLEG(6), 0)   From TOOLSHRLEG   :# borne demande
    Endif

    WECR="INSPRO"
    WFIELD(1)="STAGE"
    WFIELD(2)="DOMAINE"
    WFIELD(3)="THEME"
    WFIELD(4)="CODCSI"
    WFIELD(5)="SESSION"
    WFIELD(6)="DEMDEB"

    For I =1 To 6
       WFIELD(I)=func TOOLSHRLEG.LIB_FIELD(WECR,WFIELD(I))
    Next

    If  WOK Then

      # Population
      WLIBCOUR = WFIELD(1)
      WLEGCOUR = WLEG(1)
      #
      For I =2 To 6
        Call LEGOK(WLIBCOUR,WLEGCOUR,WFIELD(I),WLEG(I) , WOK,WMESSAGE,0) From TOOLSHRLEG
        If !WOK Then  Break :  Endif
      Next

      If !WOK
        GMESSAGE = WMESSAGE:  GERR=1 : SAI=1 : Return
      Endif
    Endif
 # Endif
Endcase:#MABOS-26/07/13-FQ81085-US1833

If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif

Return

#####################################
# MABON 18/01/11 - Remplissage du masque
Subprog FILL_LDEM(IND)
Value Integer IND
  [M:LDEM]SELFLG(IND)    = 2
  [M:LDEM]STA(IND)       = [F:DML]STA
  [M:LDEM]DEMNUM(IND)    = [F:DEM]DEMNUM
  [M:LDEM]STG(IND)       = [F:DEM]STG
  # FQ79915 - MABON 07/02/12 - Ajout nouvelles colonnes
  [M:LDEM]DATDEM(IND)    = [F:DEM]DATDEM
  # Fin MABON
  [M:LDEM]DATSTR(IND)    = [F:DEM]DATSTR
  [M:LDEM]DATEND(IND)    = [F:DEM]DATEND
  [M:LDEM]YEAPLF(IND)    = [F:DEM]YEAPLF
  [M:LDEM]PIO(IND)       = [F:DEM]PIO
  [M:LDEM]ORIDEM(IND)    = [F:DEM]ORIDEM
  [M:LDEM]SES(IND)       = [F:DEM]SES
  [M:LDEM]DESNATFIS(IND) = [F:DEM]DESNATFIS
  [M:LDEM]DESCATACN(IND) = [F:DEM]DESCATACN
  [M:LDEM]REFNUM(IND)    = [F:DML]EMP
  # FQ79915 - MABON 07/02/12 - Ajout nouvelles colonnes
  [M:LDEM]CTRNUM(IND)    = [F:DML]CTRNUM
  # Fin MABON
  # FQ72851 - MABON 12/04/11 - Ajout Prénom du salarié
#segay 06/09/11 75536
  [M:LDEM]NAM(IND)       = [F:ID]NAM-[F:ID]SRN
#END 06/09/11 75536
#  [M:LDEM]SRN(IND)       = [F:ID]SRN
  [M:LDEM]LIGNUM(IND)    = [F:DML]NUMLIG
  [M:LDEM]JOBPOT(IND)    = [F:DML]JOBPOT
  [M:LDEM]POT(IND)       = [F:DML]POT
  [M:LDEM]DOM(IND)       = [F:DEM]DOM
  [M:LDEM]THM(IND)       = [F:DEM]THM
End

$BOUTON
#MABOS-26/07/13-FQ81085-US1833-mémo + modif "first entry" in the action
#add "Case Boite" because same action for the both
Case BOITE
  When "INSPRO" :
    Case BOUT
      When "R" :
        If dim([M:DIA]LEG)>0: If [M:DIA]LEG <>"" Then GCURLEG=[M:DIA]LEG :Endif:Endif
        # SBA 30/08/2013 : 1833
         Actzo [M]5
         Call AM_SESSION([M]SESSION)
         Affzo [M] : Setmok [M] With 0
    Endcase
  When "LISDEM"
   # end MABOS-26/07/13-FQ81085-US1833
    Case BOUT
      When "C" : For I=0 To [M:LDEM]NBDEM-1 : [M:LDEM]SELFLG(I)=2 : Next
      When "D" : For I=0 To [M:LDEM]NBDEM-1 : [M:LDEM]SELFLG(I)=1 : Next

    Endcase
  Affzo [M:LDEM]
Endcase :#MABOS-26/07/13-FQ81085-US1833
Return

# Il faut vérifier que les dates de la session correspondent aux critères
Funprog VERIF_DAT(SESSION)
Value Char    SESSION
Local Integer OKENR

  OKENR=2
  If SESSION<>"" & [M:DIA]SESSION="" Then : # Il faut vérifier que les dates de la session correspondent aux critères
    Call LECTURE("HRSES", SESSION, "") From CONTOBJ
    If !fstat Then
      If [F:HRSES]STRDAT<[M:DIA]DATSTR | [F:HRSES]STRDAT>[M:DIA]DATEND Then OKENR=1 : Endif
    Endif
  Endif
End OKENR

#####################################
# MABON 14/09/10 - Remplissage de la grille des demandes sélectionnables
$DEBUT
#MABOS-26/07/13-FQ81085-US1833- modif "first entry" in the action
#add "Case Boite" because same action for the both
Case BOITE
  When "INSPRO"
    Affzo [M:DIA]
    Setmok [M:DIA] With 0
  When "LISDEM"
  #end MABOS-26/07/13-FQ81085-US1833
    Local Integer I, OKENR
    Local Char    CRIT1 (250), CRIT2 (250), CRIT3 (250), CRIT4 (250)
    Local Char WLEG(GLONADI) : #MABOS-05/12/12-FQ 81085-US1046

    Gosub AFFCRIT
    I=0
    If CRIT3="1=1" Then
      If CRIT4="1=1" Then
        Link [F:DML] With [F:DEM]DEM0=[F:DML]DEMNUM As [DM_] Where evalue(CRIT1) & evalue(CRIT2)
      Else
        Link [F:DML] With [F:DEM]DEM0=[F:DML]DEMNUM, [F:HRSES]SES0=[F:DEM]SES As [DM_] Where evalue(CRIT1) & evalue(CRIT2) & evalue(CRIT4)
      Endif
    Else
      If CRIT4="1=1" Then
        Link [F:DML] With [F:DEM]DEM0=[F:DML]DEMNUM, [F:STG]STG0=[F:DEM]STG As [DM_] Where evalue(CRIT1) & evalue(CRIT2) & evalue(CRIT3)
      Else
        Link [F:DML] With [F:DEM]DEM0=[F:DML]DEMNUM, [F:STG]STG0=[F:DEM]STG, [F:HRSES]SES0=[F:DEM]SES As [DM_] Where evalue(CRIT1) & evalue(CRIT2) & evalue(CRIT3) & evalue(CRIT4)
      Endif
    Endif
    #MABOS-05/12/12-FQ 81085-US1046
    WLEG=[M:DIA]LEG
    #WLEG = GCURLEG
    If WLEG = "" Then  WLEG = GLEGFIL : Endif
    #21/06/12 - DKA - Hide columns dependant on legislation
    Case WLEG
     When "FRA", ""
         #ADNGO - 2017-11-21 - START
         #Chgfmt [M:LDEM]DESNATFIS       With "LA:10452"  #Fiscal nature
         #Chgfmt [M:LDEM]DESCATACN       With "LA:10453"  #Action category
         Chgfmt [M:LDEM]DESNATFIS       With "K:5X"  #Fiscal nature
         Chgfmt [M:LDEM]DESCATACN       With "K:5X"  #Action category
         #ADNGO - 2017-11-21 - END
     When Default
         #ADNGO - 2017-11-21 - START
         #Chgfmt [M:LDEM]DESNATFIS       With "-LA:10452"  #Fiscal nature
         #Chgfmt [M:LDEM]DESCATACN       With "-LA:10453"  #Action category
         Chgfmt [M:LDEM]DESNATFIS       With "-K:5X"  #Fiscal nature
         Chgfmt [M:LDEM]DESCATACN       With "-K:5X"  #Action category
         #ADNGO - 2017-11-21 - END
      Endcase


    For [F:DM_]
      If I<dim([M:LDEM]SELFLG) Then
        # FQ79679 - MABON 06/02/12 - Les bornes de dates ne sont plus vérifiées ici : elles servent lorsqu'on cherche
        # une session à affecter l'inscription
  #      OKENR=func VERIF_DAT([F:DEM]SES)
        OKENR=2
        # Fin MABON
        If OKENR=2 Then
          # FQ72851 - MABON 12/04/11 - Ajout Prénom du salarié
          If [F:DML]EMP<>"" Then
            Read [F:ID]ID0=[F:DML]EMP
          Else
            Raz [F:ID]
          Endif
          # Fin MABON
          Call FILL_LDEM(I)
          I += 1
        Endif
      Else
        Break
      Endif
    Next
    # FQ79679 - MABON 06/02/12 - On affiche aussi systématiquement les demandes qui n'ont pas de session,
    # qu'on vienne des sessions ou non
  #  If GFONCTION="GESHRSES" Then
      If CRIT3="1=1" Then
        Link [F:DML] With [F:DEM]DEM0=[F:DML]DEMNUM As [DM_] Where evalue(CRIT1) & evalue(CRIT2) & SES=""
      Else
        Link [F:DML] With [F:DEM]DEM0=[F:DML]DEMNUM, [F:STG]STG0=[F:DEM]STG As [DM_] Where evalue(CRIT1) & evalue(CRIT2) & evalue(CRIT3) & SES=""
      Endif
      For [F:DM_]
        If I<dim([M:LDEM]SELFLG) Then
          If !find([F:DEM]DEMNUM, [M:LDEM]DEMNUM) Then
            # FQ79679 - MABON 06/02/12 - Les bornes de dates ne sont plus vérifiées ici : elles servent lorsqu'on cherche
            # une session à affecter l'inscription
  #          OKENR=func VERIF_DAT([F:DEM]SES)
            OKENR=2
            # Fin MABON
            If OKENR=2 Then
              Call FILL_LDEM(I)
              I += 1
            Endif
          Endif
        Else
          Break
        Endif
      Next
  #  Endif
    [M:LDEM]NBDEM=I
    Affzo [M:LDEM]
  Endcase:#MABOS-26/07/13-FQ81085-US1833
Return

######################################
# MABON 14/09/10 - Remplacement de EXEC par OK car fenêtre principale en plus maintenant
#$EXEC
$OK
#MABOS-26/07/13-FQ81085-US1833-modif "first entry" in the action
#add "Case Boite" because same action for the both
Case BOITE
  When "LISDEM"
    TIT=mess(11,10717,1)     :#Proposition d'inscriptions au xx/xx/xx
    Call OUVRE_TRACE(TIT) From LECFIC
    #Call ECR_TRACE(TIT-mess(00095,00100,1)-num$([M:DIA]DATREF),0) From GESECRAN
    Call ECR_TRACE(TIT-mess(40,101,1)-num$([M:DIA]DATSTR)-mess(95,100,1)-num$([M:DIA]DATEND),0) From GESECRAN

      Call LIB_CRIT("[M:DIA]","INSPRO")From DIVPAYE :#MABOS-22/04/13-FQ86015-US1531
    SYMBOLE = "INSPRO"
    Lock =SYMBOLE
    If fstat
     GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
     Unlock =SYMBOLE
     GERR = 1 : SAI = 1 : Return
    Endif

    Local Decimal TAUX, MTTIPT, MTTTOT
    Local Char    MATRI  (GLONEML)
    Local Char    CTR    (GLONHRCTR)
    Local Char    OLDDEM (GLONDEM)
    Local Char    OLDSTG (GLONSTG)
    Local Char    CODSES (GLONHRSES)
    Local Char    OLDSES (GLONHRSES)
    Local Char    TABSES (GLONHRSES)(0..50)
    Local Integer TABPLA (0..50)
    Local Integer ID, NBENREG, OK, NBRSES, NBRINS, DEMKO

    # MABON 14/09/10 - Le AFFCRIT est maintenant appelé dans l'étiquette DEBUT pour affichage des demandes
    # dans la fenêtre principale
    #Gosub AFFCRIT

    #For [F:DML]DML1 Where evalue(CRIT1)
    For ID=0 To [M:LDEM]NBDEM-1
      If [M:LDEM]SELFLG(ID)=2 Then : # On ne traite que les demandes sélectionnées dans la fenêtre principale
        Call LECTURE("DEM", [M:LDEM]DEMNUM(ID), "") From CONTOBJ
        Read [F:DML]DML0=[M:LDEM]DEMNUM(ID);[M:LDEM]LIGNUM(ID)
        Gosub CONTDEM
        If OK=1 & !DEMKO Then
          If OLDSTG<>[F:DEM]STG
            Gosub LISTSES
            OLDSTG=[F:DEM]STG
          Endif
          MATRI = [F:DML]EMP
          CTR   = [F:DML]CTRNUM
          Call DEBTRANS From GLOCK
          Gosub TR1
        Endif
        Unlock =SYMBDEM
      Endif
    Next

    Unlock =SYMBOLE
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    If NBENREG>0
     #Nombre d'inscriptions générées
     Call ECR_TRACE(mess(12,10717,1)-":"-num$(NBENREG),0) From GESECRAN
    Else
     #Aucune inscription à traiter
     Call ECR_TRACE(mess(55,10717,1),0) From GESECRAN
    Endif
    Call FERME_TRACE From LECFIC
    #MABOS-05/12/12-FQ 81085-US1046
    # Lecture de la trace, sinon avec la nouvelle étiquette EXEC, on ne la voit pas
    Call LEC_TRACE From LECFIC
    GMESSAGE=""

Endcase :#MABOS-26/07/13-FQ81085-US1833
Return

#MABOS-05/12/12-FQ 81085-US1046
#  - On retourne en saisie en fin de traitement
$EXEC
#MABOS-26/07/13-FQ81085-US1833-modif "first entry" in the action
#add "Case Boite" because same action for the both
Case BOITE
  When "LISDEM"
    SAI=1
Endcase
Return

#####################################
$CONTDEM
OK = 1
If OLDDEM<>[F:DML]DEMNUM
 Call LECTURE("DEM",[F:DML]DEMNUM,"") From CONTOBJ
 #MABOS-22/04/13-FQ86015-US1531
Local Char STGDES(50)
[L]STGDES=""
 If !fstat & [F:DEM]STG<>""
  Call LECTURE("STG",[F:DEM]STG,"") From CONTOBJ
  [L]STGDES=[F:STG]DES
 Endif
#end MABOS-22/04/13-FQ86015-US1531
#Demande xxx / Stage xxx
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 #MABOS-22/04/13-FQ86015-US1531
 Call ECR_TRACE(mess(13,10717,1)-[F:DEM]DEMNUM-"/"-mess(33,10717,1)-[F:DEM]STG-[L]STGDES,0) From GESECRAN
 OLDDEM = [F:DML]DEMNUM
 If evalue(CRIT2)=1 & !fstat
  SYMBDEM = "DEM"+[F:DEM]DEMNUM
  Lock =SYMBDEM
  If fstat
   #Demande de formation xxx :Modification en cours sur un autre poste
   Call ECR_TRACE(mess(1,10864,1)-[F:DEM]DEMNUM-":"-mess(10,100,1),1) From GESECRAN
   OK = 0 : Return
  Endif
 Else OK = 0 : Return
 Endif
 DEMKO = 0
 Gosub VERIFCLASS
Endif
Return

#Liste des sessions du stage demandé avec le nb d'inscrits
#####################################
$LISTSES
NBRSES=0
Raz TABSES : Raz TABPLA
#For [HRSES]SES1 Where STG=[F:DEM]STG & STRDAT>=[M:DIA]DATREF & FLGCLO<>2
If GFONCTION<>"GESHRSES" Then
  For [HRSES]SES1 Where STG=[F:DEM]STG & STRDAT>=[M:DIA]DATSTR & STRDAT<=[M:DIA]DATEND & FLGCLO<>2
   NBRINS=0
   If !find([F:HRSES]COD, TABSES(0..NBRSES))
    TABSES(NBRSES)=[F:HRSES]COD
    For [F:INS2] Where SES=[F:HRSES]COD & STA=1
     NBRINS+=1
    Next
    TABPLA(NBRSES)=[F:HRSES]NBRPRTMAX-NBRINS
    NBRSES+=1
   Endif
  Next
Else
  Read [F:HRSES]SES0=[M:HRSES0]COD
  If !fstat Then
   NBRINS=0
   If !find([F:HRSES]COD, TABSES(0..NBRSES))
    TABSES(NBRSES)=[F:HRSES]COD
    For [F:INS2] Where SES=[F:HRSES]COD & STA=1
     NBRINS+=1
    Next
    TABPLA(NBRSES)=[F:HRSES]NBRPRTMAX-NBRINS
    NBRSES+=1
   Endif
  Endif
Endif
Return

#####################################
$TR1
Local Integer AUZCFY
#--SEGAY STA_EXI 66191 LOT 1
Local Char LOFIDEF(30)
Local Char CPYSAL(GLONCPY), FCYSAL(GLONFCY), JOTSAL(GLONJOT), POTSAL(GLONPOT)
#--END_STA_EXI 66191 LOT 1
#LIPET - X3-62866 - 2017-11-08 - START
Local Integer SAV_GOK
#LIPET - X3-62866 - 2017-11-08 - END

GOK = 1
 Read [F:ID]ID0=MATRI
 If fstat : OK=0 : Return : Endif
 AUZCFY = func SUBHRSES.GET_AUZ([F:ID]CPY, [F:ID]FCY, "GENINS")
 #--SEGAY STA_EXI 66191 LOT 1
 LOFIDEF = ""
 ## Recherche des infos du salarié/contrat
 Call INFOS_SAL(MATRI,CTR,CPYSAL,FCYSAL,JOTSAL,POTSAL) From SUBDEM
 Call PARAM(CPYSAL,"OFIDEF",LOFIDEF) From ADOVAL
 #--END STA_EXI 66191 LOT 1
 If AUZCFY=2 Then
   Trbegin [INS],[DML],[INJ]

   OLDSES="" : CODSES="" : OK=0
   # FQ79679 - MABON 06/02/12 - On ne cherche une session à affecter à l'inscription, QUE si on n'a pas de session
   # sélectionnée dans les critères. D'où l'ajout du test : "If [M:DIA]SESSION="" Then... Else... Endif"
   If [M:DIA]SESSION="" Then
     If [F:DEM]SES<>""
      CODSES=[F:DEM]SES
      ## On contrôle que le matricule n'est pas déjà inscrit à cette session
      Look [F:INS]INS1=CODSES;MATRI
      If fstat
       OLDSES=[F:DEM]SES
       Gosub VERIFSES
      Endif
     Endif
     If !OK & NBRSES>0
      For I=0 To NBRSES-1
       If TABSES(I)<>OLDSES    :#OLDSES=session déja vérifiée
        CODSES=TABSES(I)
        ## On contrôle que le matricule n'est pas déjà inscrit à cette session
        Look [F:INS]INS1=CODSES;MATRI
        If fstat
         Gosub VERIFSES
         If OK=1 : Break : Endif
        Else
          OK=-1
        Endif
       Endif
      Next
     Endif
   Else
    # FQ79917 - MABON 13/03/12 - Il faut tout de même vérifier si la session est ok ou pas
#    CODSES=[M:DIA]SESSION : OK=1
    CODSES=[M:DIA]SESSION
    ## On contrôle que le matricule n'est pas déjà inscrit à cette session
    Look [F:INS]INS1=CODSES;MATRI
    If fstat
     Gosub VERIFSES
    Else
      OK=-1
    Endif
    # Fin MABON
   Endif
   If OK>0
    Gosub CREINS
    If !GOK : Goto AB_TR1 : Endif
    #LIPET - X3-62866 - 2017-11-08 - START
    SAV_GOK=GOK : Gosub WORKFLOW : GOK=SAV_GOK
    #LIPET - X3-62866 - 2017-11-08 - END
   Else
    If OK=-1 Then
      #MABOS-22/04/13-FQ86015-US1531
      Call ECR_TRACE(space$(5)+MATRI-[F:ID]NAM-[F:ID]SRN-":"-mess(207,10717,1),1) From GESECRAN : #xxx : Matricule déjà inscrit à cette session
    Else
      #Inscription du matricule xxx impossible : Pas de session disponible pour ce stage yyyyyyy
      #MABOS-22/04/13-FQ86015-US1531
      Call ECR_TRACE(space$(5)+mess(31,10717,1)-MATRI-[F:ID]NAM-[F:ID]SRN-mess(47,10717,1)-":"-mess(32,10717,1),1) From GESECRAN
    Endif
   Endif
   Commit
Endif
Return

#LIPET - X3-62866 - 2017-11-08 - START
#-------------------------------------------------------------------------------
$WORKFLOW
Local Char SAVABR (GLONAOB), SAVFONC(GLONAFC)
Local Char GRPDEB(250), GRPW(20)
Local Char CLECUR2(30)(1..4)

  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  Read [FCY]FCY0 = [F:ID]FCY
  SAVABR = GABREV   : GABREV = "INS"
  SAVFONC=GFONCTION : GFONCTION="GESINS"
  Call IDENT3("INS",[L]GRPDEB,[F:INS]REFNUM,[F:INS]SES) From GOBJTXT
  Call WRKGLOB(170,[L]GRPDEB,"INSCRIPT","") From GOBJACT
  Call WORKPLUS(2,"INS","C",[L]GRPDEB,"",0,0,0,[L]GRPW) From AWRK   : # 62014
  GABREV = SAVABR   : GFONCTION=SAVFONC
  If !GOK           : # ne peut arriver que si le workflow est en mode débug
    GERR=1
    GMESSAGE=mess(7,21,1)-mess(1,75,1) : # Erreur Workflow
  Endif
Return
#LIPET - X3-62866 - 2017-11-08 - END

$AB_TR1
Rollback
Return

$FIN
#MABOS-05/12/12-FQ 81085-US1046
Return

$CREINS
Look [F:INS]INS1=CODSES;MATRI
If fstat
 Call LECTURE("HRSES",CODSES,"") From CONTOBJ
 Raz [F:INS]
 [F:INS]=[F:DEM]
 [F:INS]REFNUM = MATRI
 [F:INS]DEM    = [F:DEM]DEMNUM
 [F:INS]SES    = CODSES
 [F:INS]STA    = 1
 [F:INS]CREDAT = date$ :  [F:INS]CREUSR = GUSER :  [F:INS]CRETIM = time
 [F:INS]FLGTPS = 1
 Raz [F:INS]UPDDAT   :  Raz [F:INS]UPDUSR   :  Raz [F:INS]UPDTIM : Raz [F:INS]EXPNUM
 [F:INS]CATFRT = [F:DML]CATFRT
 [F:INS]CTRNUM = CTR
#LIPET - X3-62866 - 2017-11-08 - START
 #  A decaler besoin du INITJOUR avant CALCOUT
 Gosub INITJOUR
 If !GOK : Return : Endif
#LIPET - X3-62866 - 2017-11-08 - END
 Gosub CALCOUT
 If !GOK : Return : Endif
 Gosub INITCPC
 Gosub INITHAB
 If !GOK : Return : Endif
 Write [F:INS]
 If fstat
  GOK = 0 : Call FSTA("INS") From GLOCK : Return
 Endif
 #Inscription du matricule xx / Session xxx
 #MABOS-22/04/13-FQ86015-US1531
 Call ECR_TRACE(space$(5)+mess(31,10717,1)-MATRI-[F:ID]NAM-[F:ID]SRN-"/"-mess(34,10717,1)-":"-[F:INS]SES,0) From GESECRAN
 NBENREG+=1
 IND=find(CODSES,TABSES(0..NBRSES-1))
 TABPLA(IND-1)-=1
 If [F:DML]FLGINS<3     :#Demandes non Inscrites
  [F:DML]OLDFLGINS=[F:DML]FLGINS
  [F:DML]FLGINS=3       :#Demandes -> Inscrites
  Rewrite [F:DML]
  If fstat
   GOK = 0 : Call FSTA("DML") From GLOCK : Return
  Endif
 Endif
 # MABON 17/09/10 - Maj des infos du parcours individualisé si nécessaire
 If [F:INS]DEM<>"" Then
   Call LECTURE("DEM", [F:INS]DEM, "") From CONTOBJ
   If [F:DEM]ORIDEM=2 Then  : # Origine demande = parcours
    Call UPDATE_CSI([F:DEM]CODCSI, CODSES, [F:INS]STG, [F:INS]REFNUM, "INS", 2, GOK) From SUBINS
    If GOK=0 Then Return : Endif
  Endif
 Endif
 # Fin MABON
Endif
Return

#####################################
#Vérifie que la session :
#soit bien comprise dans les dates souhaitées de la demande
#soit bien postérieure à la date de référence demandée
#ne soit pas pleine
$VERIFSES
Call LECTURE("HRSES",CODSES,"") From CONTOBJ
Local Integer IND
#If [F:HRSES]STRDAT<[M:DIA]DATREF : OK=0 : Return : Endif
If [F:HRSES]STRDAT<[M:DIA]DATSTR | [F:HRSES]STRDAT>[M:DIA]DATEND : OK=0 : Return : Endif
# FQ79679 - MABON 30/01/12 - On ne vérifie plus les dates de la demande
#If [F:DEM]DATSTR<>[0/0/0] & [F:HRSES]STRDAT<[F:DEM]DATSTR : OK=0 : Return : Endif
#If [F:DEM]DATEND<>[0/0/0] & [F:HRSES]ENDDAT>[F:DEM]DATEND : OK=0 : Return : Endif
# Fin MABON
# Contrôle que le matricule est présent pour la session
Gosub VERIFEMP
If OK=1
 IND=find(CODSES,TABSES(0..NBRSES-1))
 If IND<=0
  OK=0 : Return
 Elsif TABPLA(IND-1)=0
  #Inscription du matricule xxx impossible
  #Nombre de participants maximum atteint pour la session xxx
  # FQ79917 - MABON 13/03/12 - Pas de message en rouge, car peut-être qu'une autre session correspond
  # Et si aucune session ne correspond, le message final sera en rouge
#  Call ECR_TRACE(mess(31,717,1)-MATRI-mess(47,717,1),1) From GESECRAN
  # Fin MABON
  Call ECR_TRACE(mess(36,10717,1)-CODSES,0) From GESECRAN
  OK=0 : Return
 Endif
Endif
Return

#####################################
$VERIFEMP
Read[F:ID]ID0=MATRI
If fstat : OK=0 : Return : Endif

#Salarié inactif
If [F:ID]ENAFLG<>2
 #Salarié inactif
 #MABOS-22/04/13-FQ86015-US1531
 Call ECR_TRACE(space$(5)+MATRI-[F:ID]NAM-[F:ID]SRN-":"-mess(33,10702,1),1) From GESECRAN
 OK=0 : Return
Endif

# Code d'accès
If [F:ID]CODACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:ID]CODACS
 If fstat or [F:ACC]EXEC<>2
  #Vous n'avez pas les droits pour ce salarié
  #MABOS-22/04/13-FQ86015-US1531
  Call ECR_TRACE(space$(5)+MATRI-[F:ID]NAM-[F:ID]SRN-":"-mess(31,10702,1),1) From GESECRAN
  OK=0 : Return
  Endif
Endif

# FQ71013 - MABON 25/01/11 - Si le salarié n'est pas multi-contrat, le contrat n'est pas saisi sur la ligne de la
# demande et peut donc être vide
If CTR<>"" Then
  Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR
Else
  Filter [HRCTR] Where REFNUM=MATRI
Endif
Read [HRCTR]CTR0 Last
Filter [HRCTR]
If fstat : OK=0 : Return : Endif

# Droits par sites
If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 If !find([F:HRCTR]ETRFCY,GUSRFCY(1..GNBAUZ))
  #Vous n'avez pas les droits pour ce site
  #MABOS-22/04/13-FQ86015-US1531
  Call ECR_TRACE(space$(5)+MATRI-[F:ID]NAM-[F:ID]SRN-":"-mess(32,10702,1),1) From GESECRAN
  OK=0 : Return
 Endif
Endif

# Droits par service
If GUSRACS<>2 & !find([F:HRCTR]ETRSRV,GAUTSRV(1..GNBSERV))
 #Vous n'avez pas les droits pour ce service
 #MABOS-22/04/13-FQ86015-US1531
 Call ECR_TRACE(space$(5)+MATRI-[F:ID]NAM-[F:ID]SRN-":"-mess(73,10702,1),1) From GESECRAN
 OK=0 : Return
Endif

# Présent sur la période
#Call PRESEMPCTR(MATRI,[F:HRSES]STRDAT,[F:HRSES]ENDDAT,CTR,OK)From DIVPAYE
Call PRESEMPCTR(MATRI,[F:HRSES]STRDAT,[F:HRSES]ENDDAT,CTR,OK)
If !OK
 #Session xxx : XXX Employé non présent sur la période
 #MABOS-22/04/13-FQ86015-US1531
 Call ECR_TRACE(space$(5)+mess(34,10717,1)-CODSES-":"-MATRI-[F:ID]NAM-[F:ID]SRN-mess(9,10709,1),1) From GESECRAN
 OK=0 : Return
Endif
OK = 1
Return

################################################################################
## Présence d'un salarié à une période donnée pour un contrat
################################################################################
Subprog PRESEMPCTR(MATRI,DATDEB,DATFIN,CTR,OK)
Value    Char    MATRI()
Value    Date    DATDEB
Value    Date    DATFIN
Value    Char    CTR
Variable Integer OK

If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif

##Entrée-Sorties

OK = 0
# FQ71013 - MABON 25/01/11 - Si le salarié n'est pas multi-contrat, le contrat n'est pas saisi sur la ligne de la
# demande et peut donc être vide
If CTR<>"" Then
  # FQ72318 - MABON 11/03/11 - Prise en compte date d'effet
#  For [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=DATFIN & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>DATDEB)
  For [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & (CTRDAT<=DATFIN | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=DATFIN))
&                 & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>DATDEB)
   OK = 1 : Break
  Next
Else
  # FQ72318 - MABON 11/03/11 - Prise en compte date d'effet
#  For [HRCTR] Where REFNUM=MATRI & CTRDAT<=DATFIN & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>DATDEB)
  For [HRCTR] Where REFNUM=MATRI & (CTRDAT<=DATFIN | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=DATFIN))
&                 & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>DATDEB)
   OK = 1 : Break
  Next
Endif
End

