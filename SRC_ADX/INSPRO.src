# FQ79644 - MABON 06/02/12 - Si on modifie le stage, la session doit être vidée, et les dates réinitialisées
# et saisissables
Subprog AM_STAGE(VALEUR)
Variable Char    VALEUR()

  If VALEUR<>[M:DIA]STAGE Then
    If GFONCTION="GESINS" & clalev([M:INS0])>0 & VALEUR=[M:INS0]STG Then
      [M:DIA]SESSION = [M:INS0]SES
      If [M:INS3]NBLIG1>0 Then
        [M:DIA]DATSTR  = [M:INS3]DAT(0)
        [M:DIA]DATEND  = [M:INS3]DAT([M:INS3]NBLIG1-1)
        Grizo [M:DIA]DATSTR, DATEND
      Endif
    Elsif GFONCTION="GESHRSES" & clalev([M:HRSES0])>0 & VALEUR=[M:HRSES0]STG Then
      [M:DIA]SESSION = [M:HRSES0]COD

      [M:DIA]DATSTR  = [M:HRSES1]STRDAT
      [M:DIA]DATEND  = [M:HRSES1]ENDDAT
      Grizo [M:DIA]DATSTR, DATEND
    Elsif [M:DIA]SESSION<>"" Then
      [M:DIA]SESSION=""
      If GFONCTION="GESCSI" and clalev([M:CSI1])>0 Then
        [M:DIA]DATSTR  = [M:CSI1]STRDAT
        [M:DIA]DATEND  = [M:CSI1]ENDDAT
      Else
        [M:DIA]DATSTR = date$+1
        [M:DIA]DATEND = date$+1
      Endif
      Actzo [M:DIA]DATSTR, DATEND
    Endif
    Affzo [M:DIA]SESSION, ZSESSION, DATSTR, DATEND
  Endif
End

# Recherche de la législation du stage si celui-ci renseigné
Funprog LEGSTG
Local   Char    WLEG(5)

  WLEG=GLEGFIL
  If [M:DIA]ALLSTG<>2 Then
    Call LECTURE("STG",[M:DIA]STAGE,"") From CONTOBJ
    If !fstat & [F:STG]LEG<>"" Then
      WLEG=[F:STG]LEG
    Endif
  Endif
End WLEG

