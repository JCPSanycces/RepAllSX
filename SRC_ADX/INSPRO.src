## Etiquette ajoutée par le superviseur (écran INSPRO) 30/06/2006 16:24:10 (DBA)
######################################################################################
Subprog C_SESSION(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("HRSES",VALEUR,"") From CONTOBJ
 If [F:HRSES]FLGCLO=2
  # Cette session est clôturée
  GMESSAGE = mess(60,10717,1)
  mkstat = 2 : End
 Endif
 If [M]STAGE<>""
  If [F:HRSES]STG<>[M]STAGE
   #Cette session ne dépend pas du stage
   GMESSAGE=mess(30,10717,1)
   mkstat=2 : End
  Endif
 Endif
Endif
End

