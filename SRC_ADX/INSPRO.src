#LIPET - X3-62866 - 2017-11-08 - START
#####################################
# X3PEOP-3476
# new version
$CALCOUT
I = 1
# On récupère les coûts de la session
# !!!! Ajout d'une clé dans table COUT COU2!!!!!
For [COU]COU2 Where TYPCOU=2 & SES=[F:HRSES]COD
 Read [ADI]CODE=10451;[F:COU]TYPCRG
 If !fstat & [F:ADI]N1=3 & [F:ADI]N2<>2
  Gosub REMPCOUT
  [F:HRCOR]TYPFIN2    = [F:COU]TYPFIN
  [F:HRCOR]ORGFIN2    = [F:COU]ORGFIN
  [F:HRCOR]CSTTOTCLL2 = [F:COU]CSTTOTCLL
  [F:HRCOR]CSTTOTIDV2 = [F:COU]CSTTOTIDV
  [F:HRCOR]CSTIPTCLL2 = [F:COU]CSTIPTCLL
  [F:HRCOR]CSTIPTIDV2 = [F:COU]CSTIPTIDV
  [F:HRCOR]CUR        = [F:COU]CUR
  [F:HRCOR]LNKREP     = [F:COU]LNKREP # X3PEOP-3477
  # MABON - 03/09/10 - On n'a plus de flag DIF : c'est géré maintenant en dispositif comme un autre, donc dans TYPFRT
  [F:HRCOR]DESTYPFRT2 = [F:HRSES]TYPFRT
  Write [HRCOR]
  If fstat
   GOK = 0 : Call FSTA("HRCOR") From GLOCK : Break
  Endif
  I +=1
 Endif
Next
If GOK=0 : : Return : Endif

#DISTRIBUTION
Local Integer W_NBRDAY,W_NBRNIGHT
Local Decimal RESULT(0..1),W_NBRHOUR

Local Char W_TCRCOD(20),W_TYPCRG(20),W_TYPFIN(20),W_ORGFIN(20)
Local Integer IS_REP
Local Char TIMESTP(20)

[L]W_NBRHOUR = [F:HRSES]NBRHOUIPT
[L]W_NBRDAY  = [F:HRSES]NBRDAY
[L]W_NBRNIGHT= [F:HRSES]NBRNGT

If [F:INS]STG<>""
  Call LECTURE("STG",[F:INS]STG,"") From CONTOBJ
  [L]W_TCRCOD=[F:STG]TCRCOD
Endif

# On calcule les coûts calculables, c'est à dire les charges patronales et salariales du participant
For [ADI]CODE Where NUMTAB=10451 & N1<3 & N2<>2 :# coût calculé(Sal ou Pat) + pas coût formateur
 # FQ72847 - MABON 07/04/11 - Selon paramètre utilisateur CALCOUPAR, on calcule ou pas les coûts participant
 If [F:ADI]N2=1 & GCALCOUPAR<>2 Then
 Else
   MTTIPT=0 : MTTTOT=0
   Call TAUX_HORAIRE (MATRI,CTR,[F:HRSES]ENDDAT,TAUX,[F:ADI]N1,2,1) From TRTCOUT
   If !TAUX & GTRACE<>"" Then
     #Taux horaire total non défini
     Call ECR_TRACE(MATRI-"/"-[F:ADI]CODE-":"-mess(78,10717,1)-CTR,0) From GESECRAN
   Endif
   MTTTOT=arr(TAUX*[F:HRSES]NBRHOUIPT,0.1) :# Nb d'heures imputables
   Call TAUX_HORAIRE (MATRI,CTR,[F:HRSES]ENDDAT,TAUX,[F:ADI]N1,2,2) From TRTCOUT
   If !TAUX & GTRACE<>"" Then
     #Taux horaire total non défini
     Call ECR_TRACE(MATRI-"/"-[F:ADI]CODE-":"-mess(79,10717,1)-CTR,0) From GESECRAN
   Endif
   MTTIPT=arr(TAUX*[F:HRSES]NBRHOUIPT,0.1) :# Nb d'heures imputables
   If MTTIPT<>0 | MTTTOT<>0
    Gosub REMPCOUT
    # FQ78431
    If dim([F:DML]TYPFIN)>0 Then
      [F:HRCOR]TYPFIN2      = [F:DML]TYPFIN
    Endif
    If [F:HRCOR]TYPFIN2=""
     Filter [ADI2] Where NUMTAB=10462 & DEFVAL=2
     Read[ADI2]CODE First
     Filter [ADI2]
     If !fstat : [F:HRCOR]TYPFIN2 = [F:ADI2]CODE : Endif
    Endif
    # FQ78431
    If dim([F:DML]ORGFIN)>0 Then
      [F:HRCOR]ORGFIN2      = [F:DML]ORGFIN
    Else
      If dim(LOFIDEF )<0 Then Local Char LOFIDEF(30) : Endif
      If LOFIDEF="" Then
        Local Char CPYSAL(GLONCPY), FCYSAL(GLONFCY), JOTSAL(GLONJOT), POTSAL(GLONPOT)
        ## Recherche des infos du salarié/contrat
        Call INFOS_SAL(MATRI,CTR,CPYSAL,FCYSAL,JOTSAL,POTSAL) From SUBDEM
        Call PARAM(CPYSAL,"OFIDEF",LOFIDEF) From ADOVAL
      Endif
      [F:HRCOR]ORGFIN2=LOFIDEF
     Endif
     If [F:HRCOR]ORGFIN2=""
       If dim(LOFIDEF )>0 & LOFIDEF <>"" Then
         [F:HRCOR]ORGFIN2 = LOFIDEF
       Endif
      #--END_EXI 66191 LOT 1
      Endif
    # FQ78431
      If dim([F:DML]DESTYPFRT)>0 Then
       [F:HRCOR]DESTYPFRT2 = [F:DML]DESTYPFRT
      Else
       [F:HRCOR]DESTYPFRT2=[F:HRSES]TYPFRT # US4003 112241
      Endif

      #CHECK REPART
      [F:HRCOR]CSTIPTIDV2 = MTTIPT
      [F:HRCOR]CSTTOTIDV2 = MTTTOT

      If [L]W_TCRCOD<>""
        [L]W_TYPCRG= [F:HRCOR]TYPCRG2
        Gosub GET_RECORD_REP From TRTCOUT
        If IS_REP
          [F:HRCOR]ORGFIN2=[F:HRTCR]ORGFIN
          [F:HRCOR]TYPFIN2=[F:HRTCR]TYPFIN
          Call  CALCULATE([L]W_TCRCOD,[F:HRCOR]TYPCRG2,[F:HRCOR]TYPFIN2,[F:HRCOR]ORGFIN2,[L]W_NBRHOUR,[L]W_NBRNIGHT,MTTIPT,RESULT) From SUBHRTCR
          [F:HRCOR]CSTIPTIDV2=arr(RESULT(0),0.01)
          MTTIPT-=arr(RESULT(0),0.01)

          Call  CALCULATE([L]W_TCRCOD,[F:HRCOR]TYPCRG2,[F:HRCOR]TYPFIN2,[F:HRCOR]ORGFIN2,[L]W_NBRHOUR,[L]W_NBRNIGHT,MTTTOT,RESULT) From SUBHRTCR
          [F:HRCOR]CSTTOTIDV2 =arr(RESULT(0),0.01)
          MTTTOT-=arr(RESULT(0),0.01)
          TIMESTP=timestamp$ # X3PEOP-3477
          [F:HRCOR]LNKREP=TIMESTP # X3PEOP-3477
        Endif
        # on remappe sur les valeurs de la répartition

      Endif

      [F:HRCOR]CUR          = GSYSCUR
      Write [COR]
      If fstat
       GOK = 0 : Call FSTA("HRCOR") From GLOCK : Break
      Endif
      I+=1
      # Create 2nd record
      If  IS_REP
       [F:HRCOR]NUMLIG  = I
       [F:HRCOR]CSTIPTIDV2 = MTTIPT
       [F:HRCOR]CSTTOTIDV2 = MTTTOT
       [F:HRCOR]ORGFIN2=[F:HRTCR]ORGFIN2
       [F:HRCOR]LNKREP=TIMESTP+"D" # X3PEOP-3477
       Write [COR]
       If fstat
        GOK = 0 : Call FSTA("HRCOR") From GLOCK : Break
       Endif
       I+=1
      Endif
     Endif
 Endif
Next
If GOK=0 : Return : Endif
Return
#LIPET - X3-62866 - 2017-11-08 - END


$REMPCOUT
Raz [F:HRCOR]
[F:HRCOR]TYPCOU  = 3
[F:HRCOR]SES     = [F:HRSES]COD
[F:HRCOR]REFNUM  = MATRI
[F:HRCOR]NUMLIG  = I
[F:HRCOR]TYPCRG2 = [F:ADI]CODE
[F:HRCOR]CREDAT  = date$
[F:HRCOR]CREUSR  = GUSER
[F:HRCOR]CRETIM  = time

Return


#####################################
$INITJOUR
For [F:SEJ]SEJ0 Where SES=[F:HRSES]COD
 Raz[F:INJ]
 [F:INJ]=[F:SEJ]
 [F:INJ]STG       = [F:INS]STG
 [F:INJ]SES       = [F:INS]SES
 [F:INJ]REFNUM    = [F:INS]REFNUM
 [F:INJ]NBRHOUREA = [F:SEJ]NBRHOU
 [F:INJ]NBRDAYREA = [F:SEJ]NBRJOU
 # MABON - 03/09/10 - On n'a plus de flag DIF : c'est géré maintenant en dispositif comme un autre, donc dans TYPFRT
## If [F:HRSES]FLGDIF=2
# If [F:HRSES]TYPFRT=3
#  [F:INJ]TYPFRT = 3
# Else
#  [F:INJ]TYPFRT = [F:HRSES]TYPFRT
# Endif
 # FQ73110 - MABON 11/04/11 - Le dispositif de l'inscription générée, est celui de la ligne de demande
 If dim([F:DML]DESTYPFRT)>0 Then
   [F:INJ]TYPFRT    = [F:DML]DESTYPFRT
 Else
  [F:INJ]TYPFRT    = [F:HRSES]TYPFRT
  #LIPET - X3-62866 - 2017-11-08 - START
#  If [F:HRSES]TYPFRT=len(mess(0,10455,1)) Then [F:INJ]TYPFRT=1 : Endif
  #LIPET - X3-62866 - 2017-11-08 - END
 Endif
 Write[F:INJ]
 If fstat
  GOK = 0 : Call FSTA("INJ") From GLOCK : Break
 Endif
 [F:INS]NBRHOUIPT +=[F:INJ]NBRHOUREA
 [F:INS]NBRDAY    +=[F:INJ]NBRDAYREA
Next
#LIPET - X3-62866 - 2017-11-08 - START
[F:INS]NBRNGT=[F:HRSES]NBRNGT # X3PEOP-3477
#LIPET - X3-62866 - 2017-11-08 - END
If GOK=0 : Return : Endif
Return

#####################################
$INITCPC
Local Integer ICPC
Call LECTURE("STG",[F:INS]STG,"") From CONTOBJ
For ICPC=0 To dim([F:INS]CPCAFT)-1
 If [F:STG]CPCAFT(ICPC)="" : Break : Endif
 [F:INS]CPCAFT(ICPC)=[F:STG]CPCAFT(ICPC)
 [F:INS]LEVAFT(ICPC)=[F:STG]LEVAFT(ICPC)
Next
Return

$INITHAB
Local Integer IHAB, IND
# FQ75229 - MABON 22/07/11 - GTRGHAB définie sur 10 caractères au lieu de 5, au cas où...
If dim(GTRGHAB)<0 Then Global Char GTRGHAB(10)(1..50) : Endif

  IND=1 : Raz GTRGHAB
  If clalev([F:HRSTR])=0 : Local File STAGETRG [HRSTR] : Endif
  For [F:HRSTR] Where COD=[F:INS]STG
    Call CHARGE_TRG_GEN([F:HRSTR]HABTRG, IND) From SUBINS : # Récupération des habilitations cibles
  Next
  Call LECTURE("HRSES",[F:INS]SES,"") From CONTOBJ
  For IHAB=1 To min(dim([F:INS]HABAFT), IND)
    If GTRGHAB(IHAB)<>"" Then
      [F:INS]HABAFT(IHAB-1) = GTRGHAB(IHAB)
      [F:INS]HABSTR(IHAB-1) = [F:HRSES]ENDDAT
      [F:INS]HABFLG(IHAB-1) = 2
    Else
      Break
    Endif
  Next
Return

#####################################
$VERIFCLASS
#MABOS-05/12/12-FQ 81085-US1046 - add control /  Leg of contract
Local Integer WOKCTR, WDISPMSG
Local Char WLEGCTR (GLONADI)

Call GET_LEGHRCTR([F:DML]EMP,[F:DML]CTRNUM,WOKCTR,WLEGCTR,WDISPMSG) From TOOLSHRLEG
If WOKCTR & WLEGCTR = "FRA" Then

  #If [F:DEM]DESNATFIS=len(mess(0,10452,1)) :#Non défini
  If [F:DEM]DESNATFIS="" :#Non défini
   DEMKO=1
   # Il faut au moins saisir une nature fiscale
   GMESSAGE = mess(24,10717,1)
  Endif
  #If [F:DEM]DESCATACN=len(mess(0,10453,1)) :#Non défini
  If [F:DEM]DESCATACN="" :#Non défini
   If DEMKO=0
    DEMKO=1
    # Il faut au moins saisir une catégorie d'action
    GMESSAGE = mess(25,10717,1)
   Else
    # et une catégorie d'action
    GMESSAGE -= mess(86,10717,1)
   Endif
  Endif
  If DEMKO=1
   Call ECR_TRACE(space$(5)+GMESSAGE,1) From GESECRAN
  Endif

  Endif
Return

#####################################
$AFFCRIT
## Demandes acceptées uniquement et non inscrites
#CRIT1 = "[F:DML]STA="+num$(len(mess(0,10454,1)))-"& [F:DML]FLGINS<3 & [F:DML]EMP<>''"
CRIT1 = "[F:DML]FLGINS<3 & [F:DML]EMP<>''"
If [M:DIA]DEMDEB<>""
 CRIT1 -= "& [F:DML]DEMNUM>='"+[M:DIA]DEMDEB+"'"
Endif
If [M:DIA]DEMFIN<>""
 CRIT1 -= "& [F:DML]DEMNUM<='"+[M:DIA]DEMFIN+"'"
Endif
If [M:DIA]ALLSTA<>2
 CRIT1 -= "& [F:DML]STA="+num$([M:DIA]STA)
#Else
# CRIT1 -= "& [F:DML]STA="+num$(len(mess(0,10454,1)))
Endif

CRIT2 = "1=1" : CRIT4="1=1"
If [M:DIA]STAGE<>""
 CRIT2 -= "& [F:DEM]STG='"+[M:DIA]STAGE+"'"
Endif
# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini
Local Char L_STAGE_NON_DEF(GLONSTG)
L_STAGE_NON_DEF = func DIVFOR.GET_STG_NON_DEF
If L_STAGE_NON_DEF <> "" Then
  CRIT2 -= "& [F:DEM]STG<>'"+L_STAGE_NON_DEF+"'"
Endif
If [M:DIA]SESSION<>""
 If GFONCTION<>"GESHRSES" Then
  # FQ79679 - MABON 06/02/12 - La sélection des demandes ne tient pas compte de la session et des dates
#  CRIT4 -= "& [F:DEM]SES='"+[M:DIA]SESSION+"'"
#  CRIT4 -= "& [F:HRSES]STRDAT>=["+format$("D:"+GFMDAT4,[M:DIA]DATSTR)+"]"
#  CRIT4 -= "& [F:HRSES]STRDAT<=["+format$("D:"+GFMDAT4,[M:DIA]DATEND)+"]"
  # Fin MABON
# Else
#  CRIT2 -= "& ([F:DEM]SES='"+[M:DIA]SESSION+"' | [F:DEM]SES='')"
 Endif
# CRIT4 -= "& [F:HRSES]STRDAT>=["+format$("D:"+GFMDAT4,[M:DIA]DATSTR)+"]"
# CRIT4 -= "& [F:HRSES]STRDAT<=["+format$("D:"+GFMDAT4,[M:DIA]DATEND)+"]"

Endif
If [M:DIA]DOMAINE<>""
 CRIT2 -= "& [F:DEM]DOM='"+[M:DIA]DOMAINE+"'"
Endif
If [M:DIA]THEME<>""
 CRIT2 -= "& [F:DEM]THM='"+[M:DIA]THEME+"'"
Endif
If [M:DIA]CODCSI<>""
 CRIT2 -= "& [F:DEM]CODCSI='"+[M:DIA]CODCSI+"'"
Endif

CRIT3 = "1=1"
If [M:DIA]ALLTYP<>2
 CRIT3 -= "& [F:STG]TYPSTG="+num$([M:DIA]TYPSTG)
Endif
Return

