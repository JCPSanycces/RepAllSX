#<AdxTL>@(#)4.0.0.0 $Revision$
Raz [V]GPILOBJ, [V]GBIDC1, [V]GBIDC2
Call OBJET("OBI",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION
Case [L]ACTION
 When "RAZDUP"      : Effzo [OBI1] 20
 When "LIENS2"      : I=[M:OBI1]LVL : Gosub SETFMT
 When "DEBUT_CRE"   : Gosub DEBUT_CRE
 When "APRES_CRE"   : Affzo [OBI1] 20
Endcase
Return

$SETFMT
[M:OBI1]CPYFMT="-K:"+num$([V]GLONCPY)+"c"
[M:OBI1]FCYFMT="-K:"+num$([V]GLONFCY)+"c"
[M:OBI1]SRVFMT="-K:"+num$([V]GLONSRV)+"c"
Case I
 When 1 : [M:OBI1]CPYFMT=right$([M:OBI1]CPYFMT,2)
 When 2 : [M:OBI1]FCYFMT=right$([M:OBI1]FCYFMT,2)
 When 3 : [M:OBI1]SRVFMT=right$([M:OBI1]SRVFMT,2)
Endcase
Return

$DEBUT_CRE
Sorta [M:OBI1]NBLIG [M:OBI1]NBLIG
& Order By [M:OBI1]CPY(indice), [M:OBI1]FCY(indice), [M:OBI1]SRV(indice)
&        , [M:OBI1]CRI(indice)
Return

########################################
Subprog AM_LVL(VALEUR)
Variable Integer VALEUR()

Local Libelle I
I=[L]VALEUR
Gosub SETFMT

End

########################################
Subprog C_CRI(VALEUR)
Variable Char    VALEUR()

Local Shortint I

For I=0 To [M:OBI1]NBLIG-1
 If I<>nolign-1 & [M:OBI1]CPY(I)=[M:OBI1]CPY(nolign-1)
& & [M:OBI1]FCY(I)=[M:OBI1]FCY(nolign-1) & [M:OBI1]SRV(I)=[M:OBI1]SRV(nolign-1)
& & [M:OBI1]CRI(I)=[L]VALEUR
  [V]GMESSAGE=func AFNC.MES1(mess(58,10701,1),num$(I+1)) : # Doublon avec la ligne $1$
  mkstat     =2
  Break
 Endif
Next

End

########################################
Subprog AV_LIEN(VALEUR)
Variable Char    VALEUR()

Case [M:OBI1]LVL
When 1
 Call LECTURE("CPY",[M:OBI1]CPY(nolign-1),"") From CONTOBJ
 [L]VALEUR=[F:CPY]CPYNAM
When 2
 Call LECTURE("FCY",[M:OBI1]FCY(nolign-1),"") From CONTOBJ
 [L]VALEUR=[F:FCY]FCYNAM
When 3
 Call LECTEXTRA(VALEUR,"SERVICE","DES",[M:OBI1]SRV(nolign-1),"") From ATEXTRA
Endcase

End
