#<AdxTL>@(#)0.0.0.0 $Revision$
Call OBJET("GSC",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "OUVRE_BOITE": Gosub OUVRE_BOITE
 When "LIENS"      : Gosub LIENS
 When "VERIF_CRE"  : Gosub VERIF
 When "VERIF_MOD"  : Gosub VERIF
 When "CREATION"   : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "AP_CHANGE"  : Gosub AP_CHANGE
 When "ANNULE"     : Gosub ANNULE
 When "FILGAUCHE"  : Gosub FILGAUCHE
 When "FILTRE"     : Gosub FILTRE
 When "GAUCHE"     : Gosub GAUCHE
 When "SETBOUT"    : Gosub SETBOUT
 When "EXEBOUT"    : Gosub EXEBOUT
 When "EFFMASK"    : Gosub EFFMASK
 When "RAZCRE"     : Gosub RAZCRE
 When "INICRE"     : Gosub INICRE
 When "INIMOD"     : Gosub INIMOD
Endcase
Return

$OUVRE
If clalev([F:COA]) = 0 : Local File GCOA   [COA] : Endif
If !GIMPORT
 If CLE2=""
  Read [COA]COA0 First
  CLE2 = [F:COA]COA
 Endif
 GBIDC1 = CLE2
Endif
Return

$INICRE
$INIMOD
If dim([F:GSC]DES)>0
 [F:GSC]DES = [M:GSC1]DESTRA
Endif
Return

$RAZCRE
[M]COA = GBIDC1
Return

$EFFMASK
[M:GSC1]COA = GBIDC1
Affzo [M:GSC1]COA
Return

$OUVRE_BOITE
Local Integer BROWGAC
Local Char    BOXGAC(10)
BROWGAC = find("GAC",OBJLIS(1..8)) : BOXGAC = "GAU_CHE"+num$(BROWGAC)
Return

$LIENS
Read [GAC]GAC1 = [M]COA;[F:GSC]SAC
Call LECTEXTRA([M:GSC1]INTIT([F:GSC]NUMLIN-1),"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
Call LECTEXTRA([M:GSC1]DESTRA,"GRPSAC","DESTRA",[M:GSC1]COA,[M:GSC1]GRU) From ATEXTRA
Call LECTEXTRA([M:GSC1]SHOTRA,"GRPSAC","SHOTRA",[M:GSC1]COA,[M:GSC1]GRU) From ATEXTRA
Return

$SETBOUT
CHAINE += "H"
CHAINE += "A"
If GREP<>""
 Call VIREBOUT(CHAINE,"1") From GOBJET 
Endif
[M:GSC1]COA = GBIDC1 : Affzo [M:GSC1]COA : Grizo [GSC1]COA
Return

$EXEBOUT
Case REP
 When "1"
  If VALBOUT = "" : Return : Endif
  Gosub DEVERROU From GOBJET
  Effzo
  [M:GSC1]COA = VALBOUT
  Affzo [M:GSC1]COA
  GBIDC1 = [M]COA
  Gosub REMPLIT From GOBJSUB
  Raz CLECUR
  Filter [GSC] Where COA=GBIDC1
  Read [GSC]GSC0 First
  Filter [GSC]
  If !fstat
   CLECUR1 = [F:GSC]COA
   Gosub LECTURE From GOBJSUB
  Endif
Endcase  
Return

$VERIF
If [M]NBRSAC=0
 # Il doit y avoir au moins une ligne
 GMESSAGE = mess(178,123,1)
 OK = 0 : Return
Endif
Return

$FILGAUCHE
Raz FILGAUSUP
FILGAUSUP = "[F:GAC]SAC=2"
FILGAUSUP += ' & [F:GAC]COA="'+GBIDC1+'"'
Return

$FILTRE
If GIMPORT : GBIDC1 = [F:GSC]COA : Endif
If GFONCTION="GESGSC"
 If CRITERE<>"" : CRITERE += " & " : Endif
 CRITERE += '[F:GSC]COA="'+GBIDC1+'"'
Endif
Return

$GAUCHE
Case currbox
 When BOXGAC
  If [F:GAC]ACCSHO<>"" & !find([F:GAC]ACCSHO,[M]SAC(0..[M]NBRSAC-1)) & [M]NBRSAC<dim([M]SAC)
   OK = 0
   Case REP
    When "C","M","D"
     OK = 1
    When ""
     If CLECUR & VERROU & ACTMOD & !GCONSULT
      OK = 1
     Endif
   Endcase
   If OK
    [M]SAC([M]NBRSAC)   = [F:GAC]ACCSHO
    Call LECTEXTRA([M]INTIT([M]NBRSAC),"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
    [M]NBRSAC += 1
    Affzo NBRSAC,SAC,INTIT
    If REP=""
     Gosub ENTRE_MODIF From GOBJSUB
    Endif
   Endif
  Endif
Endcase
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GRPSAC","DESTRA",CLECUR2,CLECUR1,"GRPSAC","DESTRA",[M:GSC1]COA,[M:GSC1]GRU)  From ATEXTRA
 Call DUPTEXTRA("GRPSAC","SHOTRA",CLECUR2,CLECUR1,"GRPSAC","SHOTRA",[M:GSC1]COA,[M:GSC1]GRU)  From ATEXTRA
Endif
Call MAJTEXTRA([M:GSC1]DESTRA,"GRPSAC","DESTRA",[M:GSC1]COA,[M:GSC1]GRU) From ATEXTRA
Call MAJTEXTRA([M:GSC1]SHOTRA,"GRPSAC","SHOTRA",[M:GSC1]COA,[M:GSC1]GRU) From ATEXTRA
Return


$AP_CHANGE
#Class[M] à éviter car $AP_CHANGE peut être appelé d'un utilitaire externe ACHANGE
#Call CHGTEXTRA("GRPSAC","DESTRA",[M:GSC1]COA,[M:GSC1]GRU,[M:GSC1]COA,NCODE) From ATEXTRA
#Call CHGTEXTRA("GRPSAC","SHOTRA",[M:GSC1]COA,[M:GSC1]GRU,[M:GSC1]COA,NCODE) From ATEXTRA
Call CHGTEXTRA("GRPSAC","DESTRA",SUPP,OCODE,SUPP,NCODE) From ATEXTRA
Call CHGTEXTRA("GRPSAC","SHOTRA",SUPP,OCODE,SUPP,NCODE) From ATEXTRA
Return


$ANNULE
Call SUPTEXTRA("GRPSAC","DESTRA",[M:GSC1]COA,[M:GSC1]GRU) From ATEXTRA
Call SUPTEXTRA("GRPSAC","SHOTRA",[M:GSC1]COA,[M:GSC1]GRU) From ATEXTRA
Return

##############################################################################
## Etiquettes du masque GSC1
##############################################################################
Subprog C_SAC(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]SAC(0..[M]NBRSAC-1)) From OBJDIV
Call LECTEXTRA([M]INTIT(nolign-1),"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
End
