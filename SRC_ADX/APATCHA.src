  When "ANM"                            ### Compteurs document
        Local File ACODNUM [ANM2]
        WABREV="ANM2" : Gosub TRT_DATTIM
        If [M:CPAT]USR <> "" : Gosub CRITERE_USR : Endif
        For [ANM2]ANM0 Where evalue(CRITERE)
         NBO+=1
         If WAPPEL="APATCHL/CHARGE"
          Call ADD_TEX(NBTEX,TEX,TEXTE,[L]ABREV,[F:ANM2]CODNUM,func AFNC.TEXTRA("ACODNUM","DES",[F:ANM2]CODNUM,""),func LAST_CHDATE(WABREV))
         Elsif WAPPEL="FIC_OBJ"
          Call LECTEXTRA([L]LIBEL,"ACODNUM","DES",[F:ANM2]CODNUM,"") From ATEXTRA
          Call ECRIT([L]ABREV,[F:ANM2]CODNUM+"~&"+[L]LIBEL)
         Endif
        Next
  When "ACLA"                            ### Classe
        Local File ACLASSE    [ACLA2]
&         ,ACLAFLD    [ACLAF2]
&         ,ACLAMET    [ACLAM2]
&         ,ACLAMETSTD [ACLAT2]
&         ,ACLAOPT    [ACLAO2]
&         ,ACLACOL    [ACLAC2]
        WABREV="ACLA2" : Gosub TRT_DATTIM
        If [M:CPAT]USR <> "" : Gosub CRITERE_USR : Endif
        If OKCODACT
         For [ACLA2]ACLA0 Where evalue(CRITERE)
          Raz OK
          If find([F:ACLA2]CODACT,[M:CPAT]CODACT(0..NBLIG3-1))=0
           # Get specifics treatments
           For IJ=0 To [F:ACLA2]NBRTRT-1
             If find([F:ACLA2]ACTTRT(IJ),[M:CPAT]CODACT(0..NBLIG3-1))<>0
                 OK=1
                 Break
             Endif
           Next
           #options
           If !OK
            For [ACLAO2]ACLAO0 Where CODCLA=[F:ACLA2]CODCLA & find(OPTACT,[M:CPAT]CODACT(0..NBLIG3-1))<>0
               OK=1
               Break
            Next
           Endif
           #collections
           If !OK
            For [ACLAC2]ACLAC0 Where CODCLA=[F:ACLA2]CODCLA & find(ACTCOL,[M:CPAT]CODACT(0..NBLIG3-1))<>0
               OK=1
               Break
            Next
           Endif
           #
           If !OK
            For [ACLAF2]ACLAF0 Where CODCLA=[F:ACLA2]CODCLA & find(ACTFLD,[M:CPAT]CODACT(0..NBLIG3-1))<>0
               OK=1
               Break
            Next
           Endif
           If !OK
            For [ACLAM2]ACLAM0 Where CODCLA=[F:ACLA2]CODCLA & find(ACTMET,[M:CPAT]CODACT(0..NBLIG3-1))<>0
               OK=1
               Break
            Next
           Endif
           If !OK
            For [ACLAT2]ACLAT0 Where CODCLA=[F:ACLA2]CODCLA & find(ACTMETSTD,[M:CPAT]CODACT(0..NBLIG3-1))<>0
               OK=1
               Break
            Next
           Endif
          Else
           OK=1
          Endif
          If OK=1
           NBO+=1
           If WAPPEL="APATCHL/CHARGE"
            Call ADD_TEX(NBTEX,TEX,TEXTE,[L]ABREV,[F:ACLA2]CODCLA,func AFNC.TEXTE([F:ACLA2]INTCLA),func LAST_CHDATE(WABREV))
           Elsif WAPPEL="FIC_OBJ"
            Call TEXTE([F:ACLA2]INTCLA,[L]LIBEL) From OBJDIV
            Call ECRIT([L]ABREV,[F:ACLA2]CODCLA+"~&"+[L]LIBEL)
           Endif
          Endif
         Next
        Else
         For [ACLA2]ACLA0 Where evalue(CRITERE)
          NBO+=1
          If WAPPEL="APATCHL/CHARGE"
           Call ADD_TEX(NBTEX,TEX,TEXTE,[L]ABREV,[F:ACLA2]CODCLA,func AFNC.TEXTE([F:ACLA2]INTCLA),func LAST_CHDATE(WABREV))
          Elsif WAPPEL="FIC_OBJ"
           Call TEXTE([F:ACLA2]INTCLA,[L]LIBEL) From OBJDIV
           Call ECRIT([L]ABREV,[F:ACLA2]CODCLA+"~&"+[L]LIBEL)
          Endif
         Next
        Endif
  When "ASW"                            ### Représentations
        Local File ASHW       [ASW2]
&         ,ACLAOPT    [ACLAO2]
&         ,ASHWFLD    [ASWF2]
&         ,ASHWOPT    [ASWO2]
&         ,ASHWCOL    [ASWC2]
&         ,ASHWSEC    [ASWS2]
&         ,ASHWBLC    [ASWB2]
&         ,ASHWMET    [ASWM2]
&         ,ASHWEXPPRO [ASWR2]
&         ,ASHWLNK    [ASWK2]
&         ,ASHWMENU   [ASWMN2]
        WABREV="ASW2" : Gosub TRT_DATTIM
        If [M:CPAT]USR <> "" : Gosub CRITERE_USR : Endif
        If OKCODACT
         For [ASW2]ASW0 Where evalue(CRITERE)
          Raz OK
          If find([ASW2]CODACT,[M:CPAT]CODACT(0..NBLIG3-1))=0
           # Get specifics treatments
           For IJ=0 To [F:ASW2]NBRTRT-1
             If find([F:ASW2]ACTTRT(IJ),[M:CPAT]CODACT(0..NBLIG3-1))<>0
                 OK=1
                 Break
             Endif
           Next
           If !OK
            # Get specifics configuration
            For IJ=0 To [F:ASW2]NBRFAC-1
             If find([F:ASW2]ACTLNKFAC(IJ),[M:CPAT]CODACT(0..NBLIG3-1))<>0
                 OK=1
                 Break
             Endif
            Next
           Endif
           If !OK
            For [ASWC2]ASWC0 Where CODREP=[F:ASW2]CODREP & find(ACTCOL,[M:CPAT]CODACT(0..NBLIG3-1))<>0
                 OK=1
                 Break
            Next
           Endif
           If !OK
            For [ASWF2]ASWF0 Where CODREP=[F:ASW2]CODREP & find(ACTFLD,[M:CPAT]CODACT(0..NBLIG3-1))<>0
               OK=1
               Break
            Next
           Endif
           If !OK
            For [ASWM2]ASWM0 Where CODREP=[F:ASW2]CODREP & find(ACTMET,[M:CPAT]CODACT(0..NBLIG3-1))<>0
               OK=1
               Break
            Next
           Endif
           If !OK
            For [ASWS2]ASWS0 Where CODREP=[F:ASW2]CODREP & find(ACTSEC,[M:CPAT]CODACT(0..NBLIG3-1))<>0
               OK=1
               Break
            Next
           Endif
           If !OK
            For [ASWB2]ASWB0 Where CODREP=[F:ASW2]CODREP & find(ACTBLC,[M:CPAT]CODACT(0..NBLIG3-1))<>0
             OK=1
             Break
            Next
           Endif
           If !OK
            For [ASWO2]ASWO0 Where CODREP=[F:ASW2]CODREP
             If [F:ASWO2]OPTFLGCLA=2
              Read [ACLAO2]ACLAO0=[F:ASW2]CODCLA;[F:ASWO2]OPTCOD
              If !fstat & [F:ACLAO2]OPTACT>="X" & find([F:ACLAO2]OPTACT,[M:CPAT]CODACT(0..NBLIG3-1))=0
                OK=1
                Break
              Endif
             Elsif [F:ASWO2]OPTACT>="X" & find([F:ASWO2]OPTACT,[M:CPAT]CODACT(0..NBLIG3-1))=0
                OK=1
                Break
             Endif
            Next
           Endif
           If !OK
            For [ASWR2]ASWR0 Where CODREP=[F:ASW2]CODREP & find(ACTPRO,[M:CPAT]CODACT(0..NBLIG3-1))<>0
                 OK=1
                 Break
            Next
           Endif
           If !OK
            For [ASWK2]ASWK0 Where CODREP=[F:ASW2]CODREP & find(ACVLNK,[M:CPAT]CODACT(0..NBLIG3-1))<>0
              OK=1
              Break
            Next
           Endif
          Else
           OK=1
          Endif
          If OK=1
           NBO+=1
           If WAPPEL="APATCHL/CHARGE"
            Call ADD_TEX(NBTEX,TEX,TEXTE,[L]ABREV,[F:ASW2]CODREP,func AFNC.TEXTE([F:ASW2]INTREP),func LAST_CHDATE(WABREV))
           Elsif WAPPEL="FIC_OBJ"
            Call TEXTE([F:ASW2]INTREP,[L]LIBEL) From OBJDIV
            Call ECRIT([L]ABREV,[F:ASW2]CODREP+"~&"+[L]LIBEL)
           Endif
          Endif
         Next
        Else
         For [ASW2]ASW0 Where evalue(CRITERE)
          NBO+=1
          If WAPPEL="APATCHL/CHARGE"
           Call ADD_TEX(NBTEX,TEX,TEXTE,[L]ABREV,[F:ASW2]CODREP,func AFNC.TEXTE([F:ASW2]INTREP),func LAST_CHDATE(WABREV))
          Elsif WAPPEL="FIC_OBJ"
           Call TEXTE([F:ASW2]INTREP,[L]LIBEL) From OBJDIV
           Call ECRIT([L]ABREV,[F:ASW2]CODREP+"~&"+[L]LIBEL)
          Endif
         Next
        Endif
  When "ATYP"                            ### Type prototype
        Local File ATYPEPRO [ATYP2]
        WABREV="ATYP2" : Gosub TRT_DATTIM
        If OKCODACT :  CRITERE(1) += ' & find([ATYP2]CODACT,[M:CPAT]CODACT(0..NBLIG3-1))<>0 ' : Endif
        If [M:CPAT]USR <> "" : Gosub CRITERE_USR : Endif
        For [ATYP2]ATYP0 Where evalue(CRITERE)
         NBO+=1
         If WAPPEL="APATCHL/CHARGE"
          Call ADD_TEX(NBTEX,TEX,TEXTE,[L]ABREV,[F:ATYP2]COD,func AFNC.TEXTE([F:ATYP2]INTIT),func LAST_CHDATE(WABREV))
         Elsif WAPPEL="FIC_OBJ"
          Call TEXTE([F:ATYP2]INTIT,[L]LIBEL) From OBJDIV
          Call ECRIT([L]ABREV,[F:ATYP2]COD+"~&"+[L]LIBEL)
         Endif
        Next
  When "ABT"                            ### Tâches
        Local File ABATTAC [ABT2]
        WABREV="ABT2" : Gosub TRT_DATTIM
        If [M:CPAT]USR <> "" : Gosub CRITERE_USR : Endif
        For [ABT2]CODTAC Where evalue(CRITERE)
         NBO+=1
         If WAPPEL="APATCHL/CHARGE"
          Call ADD_TEX(NBTEX,TEX,TEXTE,[L]ABREV,[F:ABT2]CODTAC,func AFNC.TEXTE([F:ABT2]DES),func LAST_CHDATE(WABREV))
         Elsif WAPPEL="FIC_OBJ"
          Call TEXTE([F:ABT2]DES,[L]LIBEL) From OBJDIV
          Call ECRIT([L]ABREV,[F:ABT2]CODTAC+"~&"+[L]LIBEL)
         Endif
        Next
  When "ACTX"             ### Contextes
        Local File ACONTEXT [ACTX2]
        WABREV="ACTX2" : Gosub TRT_DATTIM
        If OKCODACT :  CRITERE(1) += ' & find([ACTX2]CODACT,[M:CPAT]CODACT(0..NBLIG3-1))<>0' : Endif
        If [M:CPAT]USR <> "" : Gosub CRITERE_USR : Endif
        For [ACTX2]ACTX0 Where evalue(CRITERE)
         NBO+=1
         If WAPPEL="APATCHL/CHARGE"
          Call ADD_TEX(NBTEX,TEX,TEXTE,[L]ABREV,[F:ACTX2]CODCTX,func AFNC.TEXTE([F:ACTX2]INTIT),func LAST_CHDATE(WABREV))
         Elsif WAPPEL="FIC_OBJ"
          Call TEXTE([F:ACTX2]INTIT,[L]LIBEL) From OBJDIV
          Call ECRIT([L]ABREV,[F:ACTX2]CODCTX+"~&"+[L]LIBEL)
         Endif
        Next
  When "AMC"             ### mot clé
        Local File AMOTCLE [AMC2]
        WABREV="AMC2" : Gosub TRT_DATTIM
        If [M:CPAT]USR <> "" : Gosub CRITERE_USR : Endif
        For [AMC2]AMC0 Where evalue(CRITERE)
         [L]LIBEL=""
         NBO+=1
         If WAPPEL="APATCHL/CHARGE"
          Call ADD_TEX(NBTEX,TEX,TEXTE,[L]ABREV,num$([F:AMC2]TYPZON)+"~"+[F:AMC2]IDENT1+"~"+[F:AMC2]IDENT2,[L]LIBEL,func LAST_CHDATE(WABREV))
         Elsif WAPPEL="FIC_OBJ"
          Call ECRIT([L]ABREV,num$([F:AMC2]TYPZON)+"~"+[F:AMC2]IDENT1+"~"+[F:AMC2]IDENT2+"~&"+[L]LIBEL)
         Endif
        Next
  When Default :
         ### Pour tous les autres objets, en plus de la valeur à patcher, on passe également le nom du champs
        Read [F:AOB]ABREV =[L]ABREV
        Raz GERREUR
        Onerrgo ERREUR
        Local File =TABLE  [ATB_]
        If !GERREUR : Read [ATB_] First :  Endif
        Onerrgo
        If !GERREUR & WAPPEL="APATCHL/CHARGE"
         Onerrgo ERREUR
         Local File ATABLE [ATB] , ATABZON [ATZ]
         If !GERREUR
          Read [ATB]CODFIC=TABLE
         Endif
         Onerrgo
         If !GERREUR
          If [F:ATB]INTIT<>""
           Read [ATZ]CODZONE=[F:AOB]NOMFIC;[F:ATB]INTIT
          Endif
         Endif
        Endif
        If !GERREUR
          Gosub SETCLE From ="WO"+[F:AOB]ABREV
          WABREV="ATB_" : Gosub TRT_DATTIM
          If OKCODACT & dim([ATB_]CODACT)>0
            CRITERE(1) += ' & find([ATB_]CODACT,[M:CPAT]CODACT(0..NBLIG3-1))<>0 '
          Endif
          If [M:CPAT]USR <> "" & dim([ATB_]UPDUSR)>0 & dim([ATB_]CREUSR)>0
           Gosub CRITERE_USR
          Endif
          For [ATB_] Where evalue(CRITERE)
             NBO+=1
             If WAPPEL="APATCHL/CHARGE"
              Case [F:ATZ]CODTYP
               When ""      : [L]LIBEL = ""
               When "ATX"   : Call TEXTE(evalue("[F:ATB_]"+[F:ATB]INTIT),[L]LIBEL) From OBJDIV
               When "AXX"   : Read [AXX]AXX0=[F:AOB]NOMFIC;[F:ATB]INTIT;GLANGUE;"";""
                              [L]LIBEL = [F:AXX]TEXTE
               When Default :
                Onerrgo ERR_INTIT
                [L]LIBEL = evalue("[F:ATB_]"+[F:ATB]INTIT)
                Onerrgo
              Endcase
              Call ADD_TEX(NBTEX,TEX,TEXTE,[L]ABREV,num$(evalue("[F:ATB_]"+CLEPRIM)),[L]LIBEL,func LAST_CHDATE(WABREV))
             Elsif WAPPEL="FIC_OBJ"
              Call ECRIT([L]ABREV,CLEPRIM+'="'+evalue("[F:ATB_]"+CLEPRIM)+'"')
             Endif
          Next
        Endif
Endcase

Close Local File
Return
#########################################
Subprog CALCUL_OBJ(ABREV,TABLE,DATEDEB,DATEFIN,NBO)
Value    Char     ABREV, TABLE
Value    Date     DATEDEB, DATEFIN
Variable Integer  NBO
Local Integer OK, I
Local Integer OKCODACT
Raz NBO, GERREUR, OKCODACT

OKCODACT =0
For I=0 To NBLIG3-1
 If [M:CPAT]CODACT(I) <> ""
  OKCODACT =2 : Break
 Endif
Next

Read [F:AOB]ABREV=[L]ABREV

If dim([VLC]NUMERO) > 0
 Call TEXTE([F:AOB]LIBEL,[VLC]NUMERO) From OBJDIV
 Call AFF_VLC(ABREV,[VLC]NUMERO) From GESECRAN
Endif

Local Char WAPPEL(30) : WAPPEL="CALCUL_OBJ"
Gosub LIST_OBJ

Close Local File
End

######################################################################
$OK
Local Integer CPTFIC, FD, OKCODACT

OKCODACT =0
For I=0 To NBLIG3-1
 If [M:CPAT]CODACT(I) <> ""
  OKCODACT =2 : Break
 Endif
Next

## CP : 28/06/01 : Contrôle de la dimension du tableau invisible
# [M:APA]NBFIC : Nb de traitement ecrit dans le tableau actuel (lors du comptage)
#  Calcul au maximum du nombre de traitement des objets liés (AMK, AOB, ACT, ARP)
# CPTFIC = Nombre de lignes du tableau invisible nécessaire pour la création du fichier patch.
CPTFIC= [M:APA]NBFIC
FD= find("AMK",[M:APA]CODE(0..[M:APA]NBLIG-1))
If FD & [M:APA]PATCH(FD-1)=2 & [M:APA]NB(FD-1)<>0
    CPTFIC+=[M:APA]NB(FD-1)
Endif
FD= find("AOB",[M:APA]CODE(0..[M:APA]NBLIG-1))
If FD & [M:APA]PATCH(FD-1)=2 & [M:APA]NB(FD-1)<>0
    CPTFIC+=[M:APA]NB(FD-1)
Endif
FD= find("ACT",[M:APA]CODE(0..[M:APA]NBLIG-1))
If FD & [M:APA]PATCH(FD-1)=2 & [M:APA]NB(FD-1)<>0
    CPTFIC+=[M:APA]NB(FD-1)
Endif
FD= find("ARP",[M:APA]CODE(0..[M:APA]NBLIG-1))
If FD & [M:APA]PATCH(FD-1)=2 & [M:APA]NB(FD-1)<>0
    CPTFIC+=[M:APA]NB(FD-1)
Endif
If CPTFIC>dim([M:APA]CODEFIC)
   Raz DEPASS : Gosub DEPASSEMENT : Return
Endif

## Création du fichier patch
Local Char    FICPATCH(GDIMFIC), CHAINE(250), CHAINE2(250), VERSION(10), COMMENT(80), TABLE(20)
Local Char    TYPOBJ(GLONATY)(0..99) , NOMOBJ(30)(0..99)
Local Char    PRODUIT(2) , URL(30)
Local Integer I , TYPPTC , STAT

If clalev([F:AOB]) = 0 : Local File AOBJET  [AOB]  : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE  [ATX]  : Endif

TYPPTC   = [M:APA]TYPPTC
VERSION  = [M:APA]VERSION : # Code version
COMMENT  = mess(143,139,1)-"("+format$(GFMD,[M:CPAT]DATDEB1)-"-"-format$(GFMD,[M:CPAT]DATFIN1)+")"
CHAINE = ""
For I=0 To NBLIG2-1
 If [M:CPAT]LANGUE(I) <> ""
  If len(CHAINE)+len([M:CPAT]LANGUE(I))+1>type(CHAINE)-20
   Break
  Endif
  If I>0 : CHAINE += "/" : Endif
  CHAINE += [M:CPAT]LANGUE(I)
 Endif
Next I
CHAINE2 = ""
For I=0 To NBLIG3-1
 If len(CHAINE2)+len([M:CPAT]CODACT(I))+1>type(CHAINE2)-20
  Break
 Endif
 If I>0 : CHAINE2 += "/" : Endif
 CHAINE2 += [M:CPAT]CODACT(I)
Next I
Case GPRODUIT
 When -1 : PRODUIT = "SU" : # Pour test
 When  0 : PRODUIT = "X3"
 When  1 : PRODUIT = "GX"
 When  2 : PRODUIT = "PA"
 When  3 : PRODUIT = "AB"
Endcase

If [M:APA]TYPEXP=1 : # Client
 Call SET_FICNAM([M:APA]FICPATCH,FICPATCH,URL) From ORDSYS
Else
 FICPATCH = [M:APA]FICPATCH
Endif

Call TEMPON("E") From GESECRAN

adxifs = ","
adxirs = chr$(10)
adxium = GUTF8
Openo FICPATCH , 0
# En-tête fichier
Wrseq '1';'"'+COMMENT+'"';'"'+CHAINE+'"';'"'+VERSION+'"';'"'+CHAINE2+'"';'"'+PRODUIT+'"';'"'+num$(TYPPTC)+'"'
For I=0 To [M:APA]NBLIG-1
    If [M:APA]PATCH(I)=2 and [M:APA]CODE(I)<>"" and [M:APA]NB(I)<>0
        Case [M:APA]CODE(I)
            When "ADX"   : Gosub FIC_ADX
            When "TRT"   : Gosub FIC_TRT
            When "ETA"   : Gosub FIC_ETA
            When "TXT"   : Gosub FIC_TXT
            When "EXE"   : Gosub FIC_EXE
            When Default : Gosub FIC_OBJ
        Endcase
    Endif
Next I
# Fin fichier
Wrseq '8';'"'+COMMENT+'"'

Openo
Call TEMPOFF From GESECRAN

If [M:APA]TYPEXP=1 & [M:APA]FLAGPAT<>2
 Call COPCLI(FICPATCH,[M:APA]FICPATCH,STAT) From ORDSYS
 GFICPATH = [M:APA]FICPATCH
Endif

## Condition de création de patch directement
If [M:APA]FLAGPAT=2
 Local Mask APATCH [DIA]
 Local Char FICHIER(GDIMFIC) : # mb 28.11.02 bug 16651
 Local File TABLAN [TLA]
 Raz [M:DIA]
 [L]FICHIER = FICPATCH
 Gosub CHARGE From APATCH
 [M:DIA]TYPEXP  = [M:APA]TYPEXP
 [M:DIA]FICPATCH = FICPATCH
 [M:DIA]COMMENT = COMMENT
 [M:DIA]DOSSIER = nomap
 [M:DIA]VERSION = "1"
 [M:DIA]PRODUIT = PRODUIT
 Call TEMPON("E") From GESECRAN
 Gosub TRIOBJ From APATCH
 Call PATCH([M:DIA]FICPATCH,[M:DIA]COMMENT,[M:DIA]DOSSIER,[M:DIA]VERSION,[M:DIA]NBOBJ,[M:DIA]TYPOBJ
& ,[M:DIA]NOMOBJ,[M:DIA]INTITOBJ,[M:DIA]NBLAN,[M:DIA]LANGUE,[M:DIA]NBACT,[M:DIA]ACTIV
& ,[M:DIA]PRODUIT,[M:DIA]TYPPTC)
&   From APATCH
 Call TEMPOFF From GESECRAN
 Close Local Mask [DIA]
 If [M:APA]TYPEXP=1
  Call COPCLI(FICPATCH,[M:APA]FICPATCH,STAT) From ORDSYS
  GFICPATH = [M:APA]FICPATCH
 Endif
Endif
Return

$FIC_ADX
For J=0 To [M:APA]NBFIC-1
    If [M:APA]CODEFIC(J)="ADX"
       Wrseq '2';'"'+[M:APA]CODEFIC(J)+'"';'"'+[M:APA]NOMFIC(J)+'"';'"'+[M:APA]DESFIC(J)+'"';
&            '"'+[M:APA]COMFIC(J)+'"'
       Wrseq '0'
       Wrseq '**********'
       Wrseq '7';'"'+[M:APA]CODEFIC(J)+'"';'"'+[M:APA]NOMFIC(J)+'"';'"'+[M:APA]DESFIC(J)+'"';
&            '"'+[M:APA]COMFIC(J)+'"'
    Endif
Next
Return

$FIC_TRT
For J=0 To [M:APA]NBFIC-1
    If [M:APA]CODEFIC(J)="ADX"
       Wrseq '2';'"'+"TRT"+'"';'"'+[M:APA]NOMFIC(J)+'"';'"'+[M:APA]DESFIC(J)+'"';'"'+[M:APA]COMFIC(J)+'"'
       Wrseq '**********'
       Wrseq '7';'"'+"TRT"+'"';'"'+[M:APA]NOMFIC(J)+'"';'"'+[M:APA]DESFIC(J)+'"';'"'+[M:APA]COMFIC(J)+'"'
    Endif
Next
Return

$FIC_ETA
For J=0 To [M:APA]NBFIC-1
    If [M:APA]CODEFIC(J)="ETA"
       Wrseq '2';'"'+[M:APA]CODEFIC(J)+'"';'"'+[M:APA]NOMFIC(J)+'"';'"'+[M:APA]DESFIC(J)+'"';
&            '"'+[M:APA]COMFIC(J)+'"'
       Wrseq '7';'"'+[M:APA]CODEFIC(J)+'"';'"'+[M:APA]NOMFIC(J)+'"';'"'+[M:APA]DESFIC(J)+'"';
&            '"'+[M:APA]COMFIC(J)+'"'
    Endif
Next
Return

$FIC_TXT
For J=0 To [M:APA]NBFIC-1
    If [M:APA]CODEFIC(J)="TXT"
       Wrseq '2';'"'+[M:APA]CODEFIC(J)+'"';'"'+[M:APA]NOMFIC(J)+'"';'"'+[M:APA]DESFIC(J)+'"';
&            '"'+[M:APA]COMFIC(J)+'"'
       Wrseq '7';'"'+[M:APA]CODEFIC(J)+'"';'"'+[M:APA]NOMFIC(J)+'"';'"'+[M:APA]DESFIC(J)+'"';
&            '"'+[M:APA]COMFIC(J)+'"'
    Endif
Next
Return

$FIC_EXE
    Wrseq '2';'"'+"EXE"+'"';'"'+[M:APA]LIBEL(I)+'"'
    Wrseq '7';'"'+"EXE"+'"';'"'+[M:APA]LIBEL(I)+'"'
Return

$FIC_OBJ
Local Char TABLE(30),ABREV(10)
Local Date DATEDEB : [L]DATEDEB = [M]DATDEB
Local Date DATEFIN : [L]DATEFIN = [M]DATFIN

Raz GERREUR
If !clalev([F:ADC])   : Local File ADICTRT  [ADC]  : Endif

[L]ABREV=[M:APA]CODE(I)
Read [F:AOB]ABREV=[L]ABREV
[L]TABLE = [F:AOB]NOMFIC

Local Char WAPPEL(30) : WAPPEL="FIC_OBJ"
Gosub LIST_OBJ

Close Local File
Return

$ERR_INTIT
[L]LIBEL = ""
Resume
Return

#----------------------------------------------------------------------------------------------------
$TRT_DATTIM
Local Integer T
If evalue("dim(["+WABREV+"]UPDDATTIM)")>=0 & evalue("dim(["+WABREV+"]CREDATTIM)")>=0
  T = evalue("type(["+WABREV+"]CREDATTIM)")
  If T=526
    WDATTIMDEB = gdatetime$(format$("D:YYYY[-]MM[-]DD",[L]DATEDEB))
    WDATTIMFIN = gdatetime$(format$("D:YYYY[-]MM[-]DD",[L]DATEFIN+1))
    WDATTIMNUL = gdatetime$("")
    CRITERE(1)  = '((UPDDATTIM<>[L]WDATTIMNUL & [L]WDATTIMDEB<=UPDDATTIM & UPDDATTIM<[L]WDATTIMFIN)'
    CRITERE(1) += '|(UPDDATTIM=[L]WDATTIMNUL  & [L]WDATTIMDEB<=CREDATTIM & CREDATTIM<[L]WDATTIMFIN))'
  Else
    WCHDATTIMDEB = func SUBADC.CNVSTP([L]DATEDEB,0)
    WCHDATTIMFIN = func SUBADC.CNVSTP([L]DATEFIN+1,0)
    WCHDATTIMNUL = ""
    CRITERE(1)  = '((UPDDATTIM<>[L]WCHDATTIMNUL & [L]WCHDATTIMDEB<=UPDDATTIM & UPDDATTIM<[L]WCHDATTIMFIN)'
    CRITERE(1) += '|(UPDDATTIM=[L]WCHDATTIMNUL  & [L]WCHDATTIMDEB<=CREDATTIM & CREDATTIM<[L]WCHDATTIMFIN))'
  Endif
Else
  CRITERE(1)  = '((UPDDAT<>[0/0/0] & [L]DATEDEB<=UPDDAT & UPDDAT<=[L]DATEFIN)'
  CRITERE(1) += '|(UPDDAT=[0/0/0]  & [L]DATEDEB<=CREDAT & CREDAT<=[L]DATEFIN))'
Endif
Return

Subprog ECRIT(CODE,CONT)
Value Char CODE
Value Char CONT
Local Char FICHIER(50), EXTENTION(3), LIB(80), CONT2(250)
Local Integer FLAG, FLAG1, FLAG2, SAUV, OKTRT
Raz FLAG, FLAG1, FLAG2, SAUV

[L]CONT2 = [L]CONT
If instr(0,[L]CONT2,"~&") > 0
 [L]CONT = left$([L]CONT2,instr(0,[L]CONT2,"~&")-1)
 [L]LIB  = right$([L]CONT2,instr(0,[L]CONT2,"~&")+2)
Endif

If CODE<>"TRT" & CODE<>"ADX"
    Wrseq '2';'"'+[L]CODE+'"';'"'+[L]CONT+'"';'"'+[L]LIB+'"'
    Wrseq '7';'"'+[L]CODE+'"';'"'+[L]CONT+'"';'"'+[L]LIB+'"'
Else
    ## condition sur l'existence
    If [L]CODE="TRT" & filinfo(filpath("TRT",[L]CONT,"src",nomap),0)<=0
     End
    Elsif [L]CODE="ADX"
     Call EXISTE_ADX("",nomap,[L]CONT,OKTRT) From ORDSYS
     If !OKTRT : End : Endif
    Endif
    ## Patch des traitements liés aux objets ACT, AMK, AOB, ARP
    ## Attention, vérification si ce traitement n'est pas déjà dans le fichier à patcher
    ## nbfic = nombre de ligne du tableau invisible
    ## sauv  = nombre de fichiers présent lors de l'initialisation du tableau invisible (sauv=nbfic initial)
    For I=0 To 1
        If ([M:APA]CODE(I)="ADX" | [M:APA]CODE(I)="TRT") & [M:APA]PATCH(I)=2
            SAUV = [M:APA]NB(I) : Break
        Endif
    Next

    ## EXISTENCE DU TRAITEMENT
    ## 1 - savoir si ce traitement exite dans le tableau invisible (initial)
    If SAUV > 0
        FLAG  = find([L]CONT,[M:APA]NOMFIC(0..SAUV-1))
        ## Indice du code (TRT ou ADX) dans le tableau
        FLAG1 = find([L]CODE,[M:APA]CODE(0..[M:APA]NBLIG-1))
        ## On vérifie si on a déjà patché le traitement
        #      - Le traitement existe (flag>0)
        #      - Le traitement est il patché (ligne=flag1 + col O/N = oui)
        If FLAG & FLAG1 & [M:APA]PATCH(FLAG1-1)=2 : End : Endif
    Endif

    ## 2 - savoir si ce traitement a été introduit ultérieurement (traitement lié aux objets)
    For I=SAUV To [M:APA]NBFIC
        If [M:APA]NOMFIC(I)=[L]CONT : End : Endif
    Next

    ## ecriture du fichier patch
    Wrseq '2';'"'+[L]CODE+'"';'"'+[L]CONT+'"';'"'+[L]LIB+'"'
    If [L]CODE="ADX"  : Wrseq "0" : Endif
    Wrseq  string$(10,"*")
    Wrseq '7';'"'+[L]CODE+'"';'"'+[L]CONT+'"';'"'+[L]LIB+'"'

    ## mise à jour du tableau invisible
    If [L]CODE="ADX"
        [M:APA]NBFIC+=1
        [M:APA]CODEFIC(NBFIC) = [L]CODE
        [M:APA]NOMFIC(NBFIC)  = [L]CONT
        [M:APA]DESFIC(NBFIC)  = ""
    Endif
Endif
End

######################################################################
$DEPASSEMENT
If DEPASS<>""
     Call MESSAGE(mess(101,115,1)-" - "-mess(99,115,1)-"\ ( "-DEPASS-")") From GESECRAN
     # Fichiers trop nombreux - Patch incomplet
Else
     Call ERREUR(mess(100,115,1)-" - "-mess(101,115,1)) From GESECRAN
     # Patch impossible - Fichiers trop nombreux
Endif
FIN=0
Return

