  When "AVW"                            ### Vues
        Local File AVIEW [AVW2]
        WABREV="AVW2" : Gosub TRT_DATTIM
        If OKCODACT :  CRITERE(1) += ' & find([AVW2]CODACT,[M:CPAT]CODACT(0..NBLIG3-1))<>0 ' : Endif
        If [M:CPAT]USR <> "" : Gosub CRITERE_USR : Endif
        For [AVW2]AVW0 Where evalue(CRITERE)
         NBO+=1
         If WAPPEL="APATCHL/CHARGE"
          Call ADD_TEX(NBTEX,TEX,TEXTE,[L]ABREV,[F:AVW2]CODVUE,func AFNC.TEXTE([F:AVW2]INTIT),func LAST_CHDATE(WABREV))
         Elsif WAPPEL="FIC_OBJ"
          Call TEXTE([F:AVW2]INTIT,[L]LIBEL) From OBJDIV
          Call ECRIT([L]ABREV,[F:AVW2]CODVUE+"~&"+[L]LIBEL)
         Endif
