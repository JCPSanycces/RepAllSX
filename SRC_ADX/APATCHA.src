  When "APR"                            ### PROCESSUS
        Local File APROCESSUS [APR2]
        WABREV="APR2" : Gosub TRT_DATTIM
        If OKCODACT :  CRITERE(1) += ' & find([APR2]CODACT,[M:CPAT]CODACT(0..NBLIG3-1))<>0 ' : Endif
        If [M:CPAT]USR <> "" : Gosub CRITERE_USR : Endif
        For [APR2]APR1 Where evalue(CRITERE)
         NBO+=1
         If WAPPEL="APATCHL/CHARGE"
          Call ADD_TEX(NBTEX,TEX,TEXTE,[L]ABREV,[F:APR2]CODLEG+"~"+[F:APR2]CODPRO,func AFNC.TEXTRA("APROCESSUS","INTIT1",[F:APR2]CODPRO,""),func LAST_CHDATE(WABREV))
         Elsif WAPPEL="FIC_OBJ"
          Call LECTEXTRA([L]LIBEL,"APROCESSUS","INTIT1",[F:APR2]CODPRO,"") From ATEXTRA
          Call ECRIT([L]ABREV,[F:APR2]CODLEG+"~"+[F:APR2]CODPRO+"~&"+[L]LIBEL)
         Endif
        Next
  When "ALH","ALQ","ALT"                            ###Requeteur
        Local File ALISTEH [ALH2]
        WABREV="ALH2" : Gosub TRT_DATTIM
        If [M:CPAT]USR <> "" : Gosub CRITERE_USR : Endif
        If [L]ABREV = "ALH"
         CRITERE(1) += '& TYP = 1 '
        Elsif [L]ABREV = "ALQ"
         CRITERE(1) += '& TYP = 2 '
        Elsif [L]ABREV = "ALT"
         CRITERE(1) += '& TYP = 3 '
        Endif
        For [ALH2]ALH0 Where evalue(CRITERE)
         NBO+=1
         If WAPPEL="APATCHL/CHARGE"
          Call ADD_TEX(NBTEX,TEX,TEXTE,[L]ABREV,[F:ALH2]COD,func AFNC.TEXTRA("ALISTEH","INTIT",[F:ALH2]COD,""),func LAST_CHDATE(WABREV))
         Elsif WAPPEL="FIC_OBJ"
          Call LECTEXTRA([L]LIBEL,"ALISTEH","INTIT",[F:ALH2]COD,"") From ATEXTRA
          Call ECRIT([L]ABREV,[F:ALH2]COD+"~&"+[L]LIBEL)
         Endif
        Next
