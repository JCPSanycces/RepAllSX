        If OKCODACT :  CRITERE(1) += ' & find([ATN2]CODACT,[M:CPAT]CODACT(0..NBLIG3-1))<>0 ' : Endif
        If [M:CPAT]USR <> "" : Gosub CRITERE_USR : Endif
        For [ATN2]ATN0 Where evalue(CRITERE)
