         Elsif WAPPEL="FIC_OBJ"
          Call TEXTE([F:ANG2]DES,[L]LIBEL) From OBJDIV
          Call ECRIT([L]ABREV,[F:ANG2]COD+"~&"+[L]LIBEL)
         Endif
        Next
  When "ATN"                            ### Types de transactions
