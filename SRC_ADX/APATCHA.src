          Call ADD_TEX(NBTEX,TEX,TEXTE,[L]ABREV,[F:AWM2]MODELE,func AFNC.TEXTE([F:AWM2]INTITMOD),func LAST_CHDATE(WABREV))
         Elsif WAPPEL="FIC_OBJ"
          Call TEXTE([F:AWM2]INTITMOD,[L]LIBEL) From OBJDIV
          Call ECRIT([L]ABREV,[F:AWM2]MODELE+"~&"+[L]LIBEL)
         Endif
        Next
   When "AWR"            ###  Model workflow
        Local File AWRKREG [AWR2]
        WABREV="AWR2" : Gosub TRT_DATTIM
        If [M:CPAT]USR <> "" : Gosub CRITERE_USR : Endif
        For [AWR2]AWR1(1) Where evalue(CRITERE)
         NBO+=1
         If WAPPEL="APATCHL/CHARGE"
          Call ADD_TEX(NBTEX,TEX,TEXTE,[L]ABREV,[F:AWR2]REGLE,func AFNC.TEXTRA("AWRKREG","INTIT",[F:AWR2]REGLE,[F:AWR2]CPY),func LAST_CHDATE(WABREV))
         Elsif WAPPEL="FIC_OBJ"
