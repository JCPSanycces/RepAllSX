Subprog C_TRT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call EXISTE_ADX("","",VALEUR,OKTRT) From ORDSYS
 If !OKTRT
  mkstat = 2
  GMESSAGE = mess(101,100,1) : # Fichier inexistant
 Endif
Endif
End

########################################
Subprog C_NBLIG2
If status<65 or (status>90 & status<=1729)
 If [M]NBLIG2=0
  GMESSAGE = mess(08,125,1) : #  IL doit y avoir au moins 1 LANGUE
  mkstat = 1 : End
 Endif
Endif
End
End

