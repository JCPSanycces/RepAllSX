########################################
Subprog IB_NBLIG
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5
GBOUT1 = mess(31,124,1)
GBOUT2 = mess(202,124,1) : # Oui à tout le reste
GBOUT3 = mess(203,124,1) : # Non à tout le reste
GBOUT4 = mess(236,139,1) : # Différence objet courant
GBOUT5 = mess(237,139,1) : # Différence tous objets
End

########################################
Subprog B2_NBLIG
Local Integer I
For I=nolign To [M]NBLIG
 [M]PATCH(I-1) = 2
Next I
Affzo 10
End

########################################
Subprog B3_NBLIG
Local Integer I
For I=nolign To [M]NBLIG
 [M]PATCH(I-1) = 1
Next I
Affzo 10
End

########################################
Subprog B4_NBLIG
Local Char PARAM(250)(1..5) , VALEUR(10)
Local Char    MOT(80) , CRITERE(250)(1..2)
Local Char    TEX(10)(1..1000) , TEXTE(30)(1..1000,1..3)
Local Integer NBTEX , OK , OKCODACT , I , J
If nolign>0
 For I=0 To NBLIG3-1
  If [M:CPAT]CODACT(I)<>""
   OKCODACT =2 : Break
  Endif
 Next
 Raz TEX,TEXTE
 Raz NBTEX
 If func ADIF.IS_ADIF_GERE([M]CODE(nolign-1))
  Gosub CHARGE From APATCHL
 Endif
 For I=1 To NBTEX
  OK = 1
  For J=1 To [M]NBFIC
   If [M]CODEFIC(J-1)=TEX(I) & [M]NOMFIC(J-1)=TEXTE(I,1)
    OK = 0 : Break
   Endif
  Next J
  If OK
   [M]NBFIC += 1
   [M]CODEFIC([M]NBFIC-1) = TEX(I)
   [M]NOMFIC([M]NBFIC-1)  = TEXTE(I,1)
  Endif
 Next I
 PARAM(1) = "[M:APA]NOMFIC"
 PARAM(2) = "[M:APA]CODEFIC"
 PARAM(3) = ""
 Call TRAITE_CHAR(VALEUR,PARAM,"","ADIF","ADIF",3,"XYADIF") From GTRAITE
Endif
End

########################################
Subprog B5_NBLIG
Local Char PARAM(250)(1..5) , VALEUR(10)
Local Char    MOT(80) , CRITERE(250)(1..2)
Local Char    TEX(10)(1..1000) , TEXTE(30)(1..1000,1..3)
Local Integer NBTEX , OK , OKCODACT , I , J
For I=0 To NBLIG3-1
 If [M:CPAT]CODACT(I)<>""
  OKCODACT =2 : Break
 Endif
Next
Raz TEX,TEXTE
Raz NBTEX
For nolign=1 To NBLIG
 If func ADIF.IS_ADIF_GERE([M]CODE(nolign-1))
  Gosub CHARGE From APATCHL
 Endif
Next nolign
For I=1 To NBTEX
 OK = 1
 For J=1 To [M]NBFIC
  If [M]CODEFIC(J-1)=TEX(I) & [M]NOMFIC(J-1)=TEXTE(I,1)
   OK = 0 : Break
  Endif
 Next J
 If OK
  [M]NBFIC += 1
  [M]CODEFIC([M]NBFIC-1) = TEX(I)
  [M]NOMFIC([M]NBFIC-1)  = TEXTE(I,1)
 Endif
Next I
PARAM(1) = "[M:APA]NOMFIC"
PARAM(2) = "[M:APA]CODEFIC"
PARAM(3) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","ADIF","ADIF",3,"XYADIF") From GTRAITE
End

