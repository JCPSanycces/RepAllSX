######################################################################################
Raz GPILOBJ
GBIDC1="200800000272"
GBIDC2="2009~ASN999999~20090101~1~1"
Call OBJET_CHAR(GBIDC1,"DAQ",GBIDC2) From GOBJET
End


## Etiquette ajoutée par le superviseur (Objet DAP) 23/06/2009 17:34:23 (DBA)
######################################################################################
$ACTION
Case ACTION
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "BS_WEMP"     : Gosub BS_WEMP From DAPC
 #SEGAY US1840 US1933 81085 25/09/2013 action envoyée de SELEMPCTR
 When "BAS_WCTR"  : Gosub BAS_CTRNUM From TOOLSHRLEG
Endcase
Return

#######################################################################################################################################
# BOITE DE DIALOGUE + BOUTON NOUVEAU
#######################################################################################################################################
###################################

###################################
$INIT_DIA
Raz [M:DIA]
[M:DIA]WYEA=[F]YEAEMPDDS
[M:DIA]WEMP=[F]EMPDDS
#SEGAY US1840 US1933 81085 25/09/2013 - Homogénéisation nom prénom
Call UPD_NAMSRN([M:DIA]WEMP,"[M:DIA]","WNAM0","WSRN0",0,0) From DIVPAYE
[M:DIA]WCTR=[F]CTRNUM
[M:DIA]WFCY=[F]ETRFCY
[M:DIA]WETRDAT=[F]ETRDAT
[M:DIA]WXITDAT=[F]XITDAT
[M:DIA]WTYP=[F]TYPDAE
Return

###################################
$CONTROLE
If GOK<1
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

###################################
$EXEC
Gosub NEWDAQ
Return

###################################
$NEWDAQ
# Vérif existance fiche DADS-U
Read [DAE2]DAE0=[M:DIA]WYEA;[M:DIA]WEMP;[M:DIA]WCTR;[M:DIA]WETRDAT;[M:DIA]WTYP;1
If fstat
 #Période d'activité salarié dads-u inexistante
 GMESSAGE = mess(80,10705,1)
 GERR = 1 : SAI = 1
 Return
Endif

SYMBOLE = "DAQ"+[M:DIA]WYEA+"\"+[M:DIA]WEMP+"\"+[M:DIA]WCTR+"\"+num$([M:DIA]WBNF)

Lock =SYMBOLE
If fstat
 GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
 GERR = 1 : SAI = 1
 Return
Endif

Call DEBTRANS From GLOCK
Gosub TR3
Unlock =SYMBOLE
Return

###################################
$TR3
GOK=1
Trbegin[DAQ2]
Gosub TR_DAQ
If GOK<0    : Goto ROL_TR3
Elsif GOK=0 : Goto AB_TR3
Endif
Commit
Return

###################################
$TR_DAQ
GOK=1
Raz[F:DAQ2]
[F:DAQ2]=[F:DAE2]
[F:DAQ2]NUMLIG=uniqid([DAQ2])
[F:DAQ2]TYPBNF=[M:DIA]WBNF
[F:DAQ2]NAMBNF=[M:DIA]WNAM
[F:DAQ2]SRNBNF=[M:DIA]WSRN
[F:DAQ2]DATBRNBNF=[M:DIA]WBRN
Write [DAQ2]
If fstat<>0
 GOK = 0 : Call FSTA("DAQ") From GLOCK
Endif
Return

###################################
$AB_TR3
Rollback
Return

###################################
$ROL_TR3
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR3 : Endif

#########################################################################################################
# Ecran
#########################################################################################################

Subprog AS_WYEA(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : Call PARAM("","DADYEA",VALEUR) From ADOVAL : Endif
End

###################################
Subprog C_WEMP(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Default File [HRDAE]
If VALEUR<>[M:DIA]WEMP & VALEUR<>[F]EMPDDS
 Filter [HRDAE] Where YEAEMPDDS=[M:DIA]WYEA & EMPDDS=VALEUR & FLGDNA=1
 Read [HRDAE]DAE0 First
 Filter [HRDAE]
 If !fstat
  Gosub AFFDIA From DAPC
 Else
  GMESSAGE=mess(23,100,1) #: Fiche inexistante
  mkstat=2 : End
 Endif
Endif
Call LECTURE("EML",VALEUR,"") From CONTOBJ
If [F:ID]FLGMULCTR=2
 Effzo [M:DIA]WCTR
 Actzo [M:DIA]WCTR
Else
 Grizo [M:DIA]WCTR
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran DAPC) 26/09/2013 12:10:29 (SEGAY)
######################################################################################
Subprog AM_WEMP(VALEUR)
Variable Char    VALEUR()
#SEGAY US1840 US1933 81085 25/09/2013 - Homogénéisation nom prénom
Call UPD_NAMSRN(VALEUR,"[M:DIA]","WNAM0","WSRN0",0,0) From DIVPAYE
End

