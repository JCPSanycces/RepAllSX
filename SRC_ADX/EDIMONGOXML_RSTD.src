###############################################################################
# Representation EDIMONGO                                                     #
# Author : RBA                                                                #
###############################################################################

$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
        When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
        When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
        When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
        When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER
        When "AREAD_AFTER"                  : Gosub AREAD_AFTER
      Endcase
  Endcase
Return

###############
# METHODS
###############
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

###############
# PROPERTIES
###############
$PROPERTIES
#  Case [L]CURPRO
#     Case [L]ARULE
#     Endcase
#  Endcase
Return

###############################################################################

$AQUERY_DECODE_CRITERIA_AFTER
  NBPRO += 1 : TBPRO(NBPRO) = "POS"        : TBTYP(NBPRO) = 1 : TBPTH(NBPRO) = "EMG.POS"        : TBFIL(NBPRO) = "[LNK_]POS"
Return

###############################################################################

$AQUERY_PRIMARYKEYS_AFTER
  ASTDKEY = ""
  ASTDKEY = ASTDKEY + "[LNK_]POS asc;"
Return

###############################################################################
$AQUERY_OPEN_AFTER
  #Declare temp variables
  Local Integer I, J
  Local Integer WPOS_TAB(1..)
  Local Char    WOBJTYP_TAB(100)(1..)
  Local Char    WKEYS_TAB(100)(1..)
  Local Char    WDES_TAB(100)(1..)
  Local Char    WCACHEUUID_TAB(36)(1..)
  Local Char    WUUIDXMLTYP(36)(1..)

  I = 0

  Local File EDIXMLFIL [EXF]
  Filter [EXF] Order By [EXF]MSGCOD Desc; [EXF]MSGREL Desc; [EXF]MSGFILNOR Desc
  For [EXF]
    I = I + 1
    WPOS_TAB(I)       = I
    WOBJTYP_TAB(I)    = "EDIXMLFIL"
    WKEYS_TAB(I)      = [EXF]MSGCOD+"-"+[EXF]MSGREL+"-"+[EXF]MSGFILNOR
    WDES_TAB(I)       = [EXF]FILDES
    WCACHEUUID_TAB(I) = num$([EXF]CACHEUUID)
    WUUIDXMLTYP(I)    = num$([EXF]UUIDXMLTYP)
  Next
  Filter [EXF]
  LogicClose File [EXF]


  #Transfert into temp table
  Local File
& (
&    Integer POS,
&    Char    OBJTYP(100),
&    Char    KEYS(100),
&    Char    DES(100),
&    Char    CACHEUUID(36)
& )
&  From Variable
&            WPOS_TAB,
&            WOBJTYP_TAB,
&            WKEYS_TAB,
&            WDES_TAB,
&            WCACHEUUID_TAB
&   As [LNK_]
Return


###############################################################################

$AQUERY_TRANS_AFTER
  this.EMG.POS       = [LNK_]POS
  this.EMG.OBJTYP    = [LNK_]OBJTYP
  this.EMG.KEYS      = [LNK_]KEYS
  this.EMG.DES       = [LNK_]DES
  this.EMG.CACHEUUID = [LNK_]CACHEUUID
Return

###############################################################################

$AQUERY_CLOSE_AFTER
  Close Local File [LNK_]
Return

###############################################################################

$AREAD_AFTER
  #Load the Detail facet
Return

