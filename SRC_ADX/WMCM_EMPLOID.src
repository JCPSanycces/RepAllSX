#<AdxTL>@(#)0.0.0.0 $Revision$Class Employee
# Supervisor
## ACLA-CLASSE ## EMPLOID
# 2018-11-06 07:05:39 817

#-------------------------------------------------------#
$METHODS
$EVENTS
Case [L]AEVENT
 When "ADDLINE_AFTER"
  Case [L]CURPTH
   When "EMPLOIDSA"
    [L]ASTATUS = fmet this.ASETATTRIBUTE("REFNUM","$namProParent","REFNUM")
    this.REFNUM = this.APARENT.REFNUM
   When "EMPLOIDUKI"
   When "EMPLORIB"
    [L]ASTATUS = fmet this.ASETATTRIBUTE("REFNUM","$namProParent","REFNUM")
    this.REFNUM = this.APARENT.REFNUM
   When "EMPLOCHD"
    [L]ASTATUS = fmet this.ASETATTRIBUTE("REFNUM","$namProParent","REFNUM")
    this.REFNUM = this.APARENT.REFNUM
   When "EMPLOJNT"
    [L]ASTATUS = fmet this.ASETATTRIBUTE("REFNUM","$namProParent","REFNUM")
    this.REFNUM = this.APARENT.REFNUM
   When "EMPLOEXM"
    [L]ASTATUS = fmet this.ASETATTRIBUTE("REFNUM","$namProParent","REFNUM")
    this.REFNUM = this.APARENT.REFNUM
   When "EMPLOTRY"
    [L]ASTATUS = fmet this.ASETATTRIBUTE("REFNUM","$namProParent","REFNUM")
    this.REFNUM = this.APARENT.REFNUM
   When Default
  Endcase
 When Default
Endcase
Return

#-------------------------------------------------------#
$PROPERTIES
Local Integer ALINE
Case [L]CURPRO
 When "REFNUM" : Gosub PRO_REFNUM
Endcase
Return

#-------------------------------------------------------#
$PRO_REFNUM
Case [L]ARULE
 When "PROPAGATE"
  If this.EMPLOIDSA<>null
   this.EMPLOIDSA.REFNUM = this.REFNUM
  Endif
  For ALINE=1 to maxtab(this.EMPLORIB)
   If this.EMPLORIB([L]ALINE)<>null
    this.EMPLORIB([L]ALINE).REFNUM = this.REFNUM
   Endif
  Next
  For ALINE=1 to maxtab(this.EMPLOCHD)
   If this.EMPLOCHD([L]ALINE)<>null
    this.EMPLOCHD([L]ALINE).REFNUM = this.REFNUM
   Endif
  Next
  For ALINE=1 to maxtab(this.EMPLOJNT)
   If this.EMPLOJNT([L]ALINE)<>null
    this.EMPLOJNT([L]ALINE).REFNUM = this.REFNUM
   Endif
  Next
  For ALINE=1 to maxtab(this.EMPLOEXM)
   If this.EMPLOEXM([L]ALINE)<>null
    this.EMPLOEXM([L]ALINE).REFNUM = this.REFNUM
   Endif
  Next
  For ALINE=1 to maxtab(this.EMPLOTRY)
   If this.EMPLOTRY([L]ALINE)<>null
    this.EMPLOTRY([L]ALINE).REFNUM = this.REFNUM
   Endif
  Next
Endcase
Return



