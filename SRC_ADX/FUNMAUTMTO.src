#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# Contient les traitements utilisée pour la modélisation                #
#########################################################################
#    ACTION MODELISATION E-COMMERCE                                     #
#                                                                       #
# GACTION  : TRTAUTMTO  : Affectations                                  #
#                                                                       #
#########################################################################
# FQ 73203 GA 04/2011 Problème suite FQ 71360 remplacer [ORD1] par [ORDB]
#########################################################################
$ACTION
Case ACTION
 When "INIT"          : Gosub INIT
 When "INIT_DIA"      : Gosub INIT_DIA
 When "CONTROLE"      : Gosub CONTROLE
 When "EXEC"          : Gosub EXEC
 When "TERMINE"       : Gosub TERMINE
Endcase
Return

#########################################################################
$INIT

# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Gosub OUVRE

# pour le traitement auto (pas de saisie), il faut au moins le site, le mode et le type
If LAUT
 If LFCY <> "" & find(LMOD,1,2) & find(LTYP2,1,2)
        # -------------------------------------------------------- #
        # Paramètres renseignés :                                  #
        # --> On initialise la fenêtre de sélection sans la saisir #
        # -------------------------------------------------------- #
        If clalev([M:DIA])=0
            If clalev([F:AWI])=0 : Local File AWINDOW [AWI] : Endif
            Read [AWI]AWI0 = BCRIT
            MASQUE = [F:AWI]NOMMSK(0)
            Close Local File [AWI]
            Local Mask =MASQUE [DIA]
            ACTION = "INIT_DIA" : Gosub ACTION From =PROG
            If LAUT : TYPPRG = 1 : Endif
        Endif
 Else
   LAUT=0
 Endif
Endif
Return

#########################################################################
$INIT_DIA
Raz [M:DIA]

Gosub OUVRE

If LFCY <> "" : GFCY = LFCY : Else Call FIND_GFCYDEF(7) From TRTX3 : Endif
[M:DIA]STOFCY = GFCY : Gosub CHARG_PARAM
If LITM <> ""      : [M:DIA]ITMREFDEB = LITM : [M:DIA]ITMREFFIN = LITM  : Endif
If find(LMOD,1,2)  : [M:DIA]PRPMOD = LMOD                               : Endif
If find(LTYP2,1,2) : [M:DIA]PRPTYP = LTYP2                              : Endif

If LFCY<>"" & LTYP <> 0 & LNUM <> "" & LLIN <> 0
   I=0
   If LITM<>"" : Filter [ORD] Where ITMREF=[L]LITM : Endif
   For [ORD]ORD3 Where STOFCY = [L]LFCY & VCRTYP = [L]LTYP & VCRNUM = [L]LNUM & VCRLIN = [L]LLIN & VCRSEQ = [L]LSEQ
    # I+=1 : Break : : # GH 29/02/12
    I+=1
    If I>1 : Break : Endif
   Next
   If LITM<>"" : Filter [ORD] : Endif
   If I=1
      If func CBNLIB.ISDEM([F:ORD]WIPTYP)
            [M:DIA]DEMTYP     = LTYP
            [M:DIA]DEMNUM     = LNUM
            [M:DIA]DEMLIN     = LLIN
            [M:DIA]DEMSEQ     = LSEQ
            [M:DIA]DEMITM     = [F:ORD]ITMREF
            [M:DIA]DEMWIP     = [F:ORD]WIPTYP : # GH 29/02/12
      Elsif func CBNLIB.ISRESS([F:ORD]WIPTYP)
            [M:DIA]RESSTYP    = LTYP
            [M:DIA]RESSNUM    = LNUM
            [M:DIA]RESSLIN    = LLIN
            [M:DIA]RESSSEQ    = LSEQ
            [M:DIA]RESSITM    = [F:ORD]ITMREF
            [M:DIA]RESSWIP    = [F:ORD]WIPTYP : # GH 29/02/12
      Endif
   Elsif LAUT
     LAUT=0
   Endif
Endif

Return

########################################################################
$OUVRE
Local    Char    LFCY(GLONFCY) : LFCY  = PARAM(1)
Local    Char    LITM(GLONITM) : LITM  = PARAM(2)
Local    Integer LTYP          : LTYP  = val(PARAM(3))
Local    Char    LNUM(GLONVCR) : LNUM  = PARAM(4)
Local    Integer LLIN          : LLIN  = val(PARAM(5))
Local    Integer LSEQ          : LSEQ  = val(PARAM(6))
Local    Integer LMOD          : LMOD  = val(PARAM(7))
Local    Integer LTYP2         : LTYP2 = val(PARAM(8))
Local    Integer LAUT          : LAUT  = val(PARAM(9))
Local    Integer LRET          : LRET = 0

Global Integer  GNBLINK

Local Integer  I, NBLINK
Local Char     TIT(50)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)
Local Char     FORMULE1(255)
Local Char     WMESS(255)
Local Char     WPTOCOD(GLONPTO)

#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:ORD])  = 0 : Local File ORDERS      [ORD]  : Endif
If clalev([F:ORDB]) = 0 : Local File ORDERS      [ORDB] : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER   [ITM]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT  [ITF]  : Endif
If clalev([F:MLK1]) = 0 : Local File MTOLINK     [MLK1] : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY    [FCY]  : Endif
If clalev([F:TFO])  = 0 : Local File TABFOR      [TFO]  : Endif
If clalev([F:PTO])  = 0 : Local File PARMTO      [PTO]  : Endif

If GMODU(6) = 2
    If clalev ([F:POQ]) <= 0 : Local File PORDERQ    [POQ] : Endif
    If clalev ([F:PSD]) <= 0 : Local File PREQUISD   [PSD] : Endif
    If clalev ([F:POC]) <= 0 : Local File PORDERC    [POC] : Endif
    If clalev ([F:SCO]) <= 0 : Local File SCOHEAD    [SCO] : Endif
    If clalev ([F:SCI]) <= 0 : Local File SCOITM     [SCI] : Endif
Endif

If GMODU(5) = 2
    If clalev ([F:SDH]) <= 0 : Local File SDELIVERY  [SDH] : Endif
    If clalev ([F:SDD]) <= 0 : Local File SDELIVERYD [SDD] : Endif
    If clalev ([F:SOP]) <= 0 : Local File SORDERP    [SOP] : Endif
    If clalev ([F:SOC]) <= 0 : Local File SORDERC    [SOC] : Endif
Endif

If GMODU(8) = 2
    If clalev ([F:MFG]) <= 0 : Local File MFGHEAD   [MFG] : Endif
    If clalev ([F:MFI]) <= 0 : Local File MFGITM    [MFI] : Endif
Endif

#
# --- Déclaration classes ecran --- #
Local Mask ORDK    [ORDK]
Local Mask MLIK    [MLIK]

Return

#########################################################################
$CONTROLE
If !GSERVEUR             &
&  !LAUT                 &
&  [M:DIA]ITMREFDEB = "" &
&  [M:DIA]ITMREFFIN = "" &
&  [M:DIA]DEMNUM    = "" &
&  [M:DIA]RESSNUM   = "" &
&  [M:DIA]FORMULE = ""
   GERR=3
   GMESSAGE = mess(64,190,1) : # Aucune sélection saisie ! Voulez vous continuer ?
   FOK=0
Endif

If !LAUT : TMP=1 : Endif

Return
#########################################################################
$EXEC
If !GSERVEUR
    Call TITAWI(BCRIT,TIT) From OBJDIV : # Titre de la trace = titre de la fenêtre
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("MAUTMTO","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
    TRA=1
Endif

# préparation des critères de filtre
Gosub SEL_LINK

# traitement des affectations
Gosub PROCESS_LINK

Return

#########################################################################
$TERMINE
If !GSERVEUR
    # fermeture trace
    Call FERME_TRACE From LECFIC
    # aucune suppression effectuee ou lecture trace
    If !GNBLINK
         GERR=2 : GMESSAGE = mess(256,193,1) : # Aucune affectation traitée
    Endif
Endif

If [M:DIA]PRPMOD = 1 & GNBLINK > 0 : LRET = 2 : Endif
PARAM(10) = num$(LRET)

Return

########################################################################
# Préparation du filtre sur la table article-site                      #
########################################################################
$SEL_LINK
Raz CRITERE
Raz CRITERE1
Raz CRITERE2

CRITERE1  = "[F:ITF]STOFCY = [M:DIA]STOFCY"             # site

If [M:DIA]DEMNUM <> ""                                  # article issu du besoin
  CRITERE = "ITMREF = [M:DIA]DEMITM"
  Gosub LOAD_CRITERE2
Elsif [M:DIA]RESSNUM <> ""                              # article issu de la ressource
  CRITERE = "ITMREF = [M:DIA]RESSITM"
  Gosub LOAD_CRITERE2
Else
 If [M:DIA]ITMREFDEB <> ""
   CRITERE = "ITMREF >= [M:DIA]ITMREFDEB"               # borne début article
   Gosub LOAD_CRITERE2
 Endif
 If [M:DIA]ITMREFFIN <> ""
   CRITERE = "ITMREF <= [M:DIA]ITMREFFIN"               # borne fin   article
   Gosub LOAD_CRITERE2
 Endif
Endif
If CRITERE2 = "" : CRITERE2 = "1=1" : Endif

Gosub ANALYSE_FORMULE
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif

Return

##################################################
$ANALYSE_FORMULE
# analyse présence formule de sélection
If [M:DIA]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=41;[M:DIA]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

Return

############################################################
$LOAD_CRITERE
If len(CRITERE1)=0
    CRITERE1 += "("
Else
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE

Return

############################################################
$LOAD_CRITERE2
If len(CRITERE)+len(CRITERE1)+1 < 225
  CRITERE1 += "&"
  CRITERE1 += CRITERE
Else
  If CRITERE2 <> ""
     CRITERE2 += "&"
  Endif
  CRITERE2 += CRITERE
Endif

Return

#---------------------------------------------------------------------#
# Traitement des ordres                                               #
#---------------------------------------------------------------------#
$PROCESS_LINK
Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF As [ITX]

# boucle de lecture
For  [ITX]ITF1 Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(FORMULE1)

    # règle d'affectation
    If [F:ITF]PTOCOD = "" : WPTOCOD = GDEFPTO : Else : WPTOCOD = [F:ITF]PTOCOD : Endif
    If [F:PTO]PTOCOD <> WPTOCOD
        Read [PTO]PTO0 = WPTOCOD
        If fstat : Raz [F:PTO] : Endif
    Endif

    # PEC dans traitements auto ?
    If [F:PTO]PTOAUT = 2
     Gosub TRTLINK
    Endif
Next

Return

#-----------------------------------------------------------------------#
# Affectation                                                           #
#-----------------------------------------------------------------------#
$TRTLINK
GNBLINK = 0

GOK = 1
Trbegin [MLK1]
    Raz [M:MLIK]
    [M:MLIK]MAJCOD    = "P"
    [M:MLIK]PRPTYP    = [M:DIA]PRPTYP
    [M:MLIK]PRPMOD    = [M:DIA]PRPMOD
    [M:MLIK]STOFCY    = [M:DIA]STOFCY
    [M:MLIK]DEMTYP    = [M:DIA]DEMTYP
    [M:MLIK]DEMNUM    = [M:DIA]DEMNUM
    [M:MLIK]DEMLIN    = [M:DIA]DEMLIN
    [M:MLIK]DEMSEQ    = [M:DIA]DEMSEQ
    [M:MLIK]DWIPTYP   = [M:DIA]DEMWIP
    [M:MLIK]RESSTYP   = [M:DIA]RESSTYP
    [M:MLIK]RESSNUM   = [M:DIA]RESSNUM
    [M:MLIK]RESSLIN   = [M:DIA]RESSLIN
    [M:MLIK]RESSSEQ   = [M:DIA]RESSSEQ
    [M:MLIK]RWIPTYP   = [M:DIA]RESSWIP : # GH 29/02/12
    [M:MLIK]ITMREF    = [F:ITM]ITMREF
    [M:MLIK]TRTNAM    = "FUNMAUTMTO"
    [M:MLIK]FRCPRO    = [M:DIA]FRCPRO
    [M:MLIK]FEEDBACK  = 2
    Call UPDMTOLINK From MTOLINKLIB
If GOK>0 & [M]PRPMOD=1 : Commit
Else                   : Rollback
 If GOK<0 & GLOCK<>""
  Call ECR_LOCK("T") From GLOCK
 Endif

Endif

If GOK>0 : NBLINK+=GNBLINK : GNBLINK=NBLINK : Endif

Return

########################################################################
$TRACE_LINK
Case [M:MLIK]FEEDBACKT
    When 1: # début retour info trace - ordre d'origine - infos dans [ORDB]
            If dim([L]WWRK)<0
               Local Decimal WWRK
               Local Char    WMESS(255)
               Local Integer WTRACE1
            Endif

            WMESS = mess([F:ORDB]WIPTYP,341,1)+mess([F:ORDB]WIPSTA,342,1)+":"-[F:ORDB]VCRNUM+"/"+num$([F:ORDB]VCRLIN)+","-mess(80,197,1)+":"-
&                   [F:ORDB]ITMREF+","-mess(646,197,1)+":"-num$([F:ORDB]MTOQTY)+","
            If (func CBNLIB.ISDEM([F:ORDB]WIPTYP))
                WMESS -= mess(158,197,1)+":"-format$("D:"+GFMDAT,[F:ORDB]ENDDAT)
            Else
                WMESS -= mess(647,197,1)+":"-format$("D:"+GFMDAT,[F:ORDB]ENDDAT)
            Endif
    When 2: # retour info sur les affectations proposées
            If !WTRACE1 : Call ECR_TRACE(WMESS,0) From GESECRAN : WTRACE1 = 1 : Endif

            WMESS = "________"-mess(254,195,1)- mess([F:ORDB]WIPTYP,341,1)+mess([F:ORDB]WIPSTA,342,1)+":"-[F:ORDB]VCRNUM+"/"+
&                   num$([F:ORDB]VCRLIN)+","-mess(646,197,1)+":"-num$(WMTOQTY)+","
            If (func CBNLIB.ISDEM([F:ORDB]WIPTYP))
                WMESS -= mess(158,197,1)+":"-format$("D:"+GFMDAT,[F:ORDB]ENDDAT)
            Else
                WMESS -= mess(647,197,1)+":"-format$("D:"+GFMDAT,[F:ORDB]ENDDAT)
            Endif
            Call ECR_TRACE(WMESS,0) From GESECRAN
            GNBLINK += 1
    When 3: # bilan affectations pour ordre d'origine
            If WTRACE1 = 0 : Return : Endif
            WTRACE1 = 0
            WWRK = [F:ORDB]EXTQTY - [F:ORDB]ALLQTY - [F:ORDB]MTOQTY
            # si simulation on soustrait WMTOQTY (pas inclus dans [ORDB]MTOQTY)
            If [M:DIA]PRPMOD = 2 : WWRK -= WCOVQTY : Endif
            WMESS = "______________"-mess(648,197,1)+":"-num$(WCOVQTY)+","-mess(649,197,1)+":"-num$(WWRK)
            Call ECR_TRACE(WMESS,0) From GESECRAN
            Call ECR_TRACE(" ",0) From GESECRAN
Endcase
Return

########################################################################
$CHARG_PARAM
#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA

Return

########################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

######################################################################################
## Etiquettes (écran MAUTMTO)
######################################################################################

Subprog AV_STOFCY(VALEUR)
Variable Char    VALEUR()
If GCONSDIA : End : Endif
Call AM_PRPTYP([M:DIA]PRPTYP)
If [M]DEMNUM<>"" | [M]RESSNUM<>""
 Effzo FORMULE
 If dim([M]ZFORMULE)=1 : Effzo ZFORMULE : Endif
 Diszo FORMULE
Else
 Actzo FORMULE
Endif
End

Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
GFCY=VALEUR
Gosub CHARG_PARAM
End

Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]ITMREFFIN = VALEUR : Endif
End

Subprog AS_DEMNUM(VALEUR)
Variable Char    VALEUR()
# Issue X3-57516 - 2017-09-28 by ALSHE : enhance selection for WIPTYP with 14 for project demands
[M]ORDFILTER = "find(WIPTYP,1,3,4,6,8,10,14)<>0"
If [M]ITMREFDEB <> "" : [M]ORDFILTER += "&ITMREF>=[M]ITMREFDEB" : Endif
If [M]ITMREFFIN <> "" : [M]ORDFILTER += "&ITMREF<=[M]ITMREFFIN" : Endif
End

Subprog C_DEMNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M]DEMNUM & VALEUR<>""
 If [M]ITMREFDEB<>"" & [M]DEMITM<[M]ITMREFDEB
  GMESSAGE = mess(162,154,1)-[M]DEMITM-"<"-[M]ITMREFDEB : # Article
  mkstat=2 : End
 Endif
 If [M]ITMREFFIN<>"" & [M]DEMITM>[M]ITMREFFIN : # Article
  GMESSAGE = mess(162,154,1)-[M]DEMITM-">"-[M]ITMREFFIN
  mkstat=2 : End
 Endif
Endif

If VALEUR<>""
 Effzo FORMULE
 If dim([M]ZFORMULE)=1 : Effzo ZFORMULE : Endif
 Diszo FORMULE
Elsif [M]RESSNUM=""
 Actzo FORMULE
Endif
End

Subprog AM_DEMNUM(VALEUR)
Variable Char    VALEUR()
If [M]FLGSEL=2 | VALEUR="" : [M]FLGSEL=0 : Else [M]FLGSEL=1 : Endif
If VALEUR="" : [M]DEMITM="" : Endif
End

Subprog S_DEMNUM(VALEUR)
Variable Char    VALEUR()
[M]FLGSEL=2
End


Subprog AS_RESSNUM(VALEUR)
Variable Char    VALEUR()
[M]ORDFILTER = "find(WIPTYP,2,5,7,9,13)<>0"
If [M]DEMNUM<>""
 [M]ORDFILTER += "&ITMREF=[M]DEMITM" : # article de la ressource figé par la demande
Else
 If [M]ITMREFDEB <> "" : [M]ORDFILTER += "&ITMREF>=[M]ITMREFDEB" : Endif
 If [M]ITMREFFIN <> "" : [M]ORDFILTER += "&ITMREF<=[M]ITMREFFIN" : Endif
Endif
End

Subprog C_RESSNUM(VALEUR)
Variable Char    VALEUR()
If find([M]FLGSEL,1,2) : [M]FLGSEL=0 : mkstat=2 : End : Endif
If VALEUR=[M]RESSNUM & VALEUR<>""
  If [M]DEMNUM=""
   If [M]ITMREFDEB<>"" & [M]RESSITM<[M]ITMREFDEB
    GMESSAGE = mess(162,154,1)-[M]RESSITM-"<"-[M]ITMREFDEB : # Article
    mkstat=2 : End
   Endif
   If [M]ITMREFFIN<>"" & [M]RESSITM>[M]ITMREFFIN : # Article
    GMESSAGE = mess(162,154,1)-[M]RESSITM-">"-[M]ITMREFFIN
    mkstat=2 : End
   Endif
  Elsif [M]RESSITM<>[M]DEMITM
   GMESSAGE = mess(291,193,1)-"("-[M]RESSITM-[M]DEMITM-")" : # Article de la ressource et de la demande différent
   mkstat=2 : End
  Endif
Endif

If VALEUR<>""
 Effzo FORMULE
 If dim([M]ZFORMULE)=1 : Effzo ZFORMULE : Endif
 Diszo FORMULE
Elsif [M]DEMNUM=""
 Actzo FORMULE
Endif
End

Subprog AM_RESSNUM(VALEUR)
Variable Char    VALEUR()
If [M]FLGSEL=-2 | VALEUR="" : [M]FLGSEL=0 : Else [M]FLGSEL=-1 : Endif
If VALEUR="" : [M]RESSITM="" : Endif
End

Subprog S_RESSNUM(VALEUR)
Variable Char    VALEUR()
[M]FLGSEL=-2
End

Subprog AS_PRPMOD(VALEUR)
Variable Integer VALEUR
GMENLOC(3) = 1
End

Subprog C_PRPMOD(VALEUR)
Variable Integer VALEUR
If find([M]FLGSEL,-1,-2) : [M]FLGSEL=0 : mkstat=2 : Endif
End

Subprog AS_PRPTYP(VALEUR)
Variable Integer VALEUR
GMENLOC(3) = 1
End

Subprog AM_PRPTYP(VALEUR)
Variable Integer VALEUR
If VALEUR = 1 : Actzo [DIA]FRCPRO : Else Grizo [DIA]FRCPRO : Endif
End

