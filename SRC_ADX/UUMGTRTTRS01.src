#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################
# UUMGTRTTRS01                              Module   A/P-A/R Accounting  #
#                                                                        #
#                    Migration Process                                   #
#                                                                        #
#      Flow for Customer BP Invoices                                     #
#            SINVOICE/BPCINVLIG/BPCINVLIGA                               #
#                                                                        #
##########################################################################
#                                                                        #
#  Optimized Index for Migration                                         #
#                                                                        #
#   SINVOICE  : CPY;NUM                                                  #
#   BPCINVLIG : CPY;NUM;LIG                                              #
#                                                                        #
#  Index to keep for Migration                                           #
#                                                                        #
#   SINVOICE   : NUM                                                     #
#   BPCINVLIG  : NUM;LIG                                                 #
#   BPCINVLIGA : NUM;LIG;ANALIG                                          #
#                                                                        #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTTRS01") From LECFIC
  Endif

  #Call RAZ_UUMGTRTTRS01(DOSSIER)
  Call MAJ_UUMGTRTTRS01(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

########################################################################
Subprog RAZ_UUMGTRTTRS01(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(2)<>2 : End : Endif

#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS01",7,ERR) From TRTMIG : End : Endif
If val(VERSION)>=GMIGX3VER110 : End : Endif

#----- File naming...  -----#
Local Char WNAMSIHM,WNAMSILM,WNAMSIAM
Call MIGTABNAME (DOSSIER,"SINVOICE",WNAMSIHM,ERR) From TRTMIG   : If ERR : End : Endif
If val(VERSION)<GMIGX3VER60
 Call MIGTABNAME (DOSSIER,"BPCINVLIG",WNAMSILM,ERR) From TRTMIG  : If ERR : End : Endif
 Call MIGTABNAME (DOSSIER,"BPCINVLIGA",WNAMSIAM,ERR) From TRTMIG : If ERR : End : Endif
Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMSIHM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif
If val(VERSION)<GMIGX3VER60
 If filinfo(filpath("FIL",WNAMSILM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif
 If filinfo(filpath("FIL",WNAMSIAM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif
Endif

#----- Deleting of records...  -----#
If val(VERSION)<GMIGX3VER60
 Call MIGTABRAZ (DOSSIER,"BPCINVLIG",ERR) From TRTMIG
 Call MIGTABRAZ (DOSSIER,"BPCINVLIGA",ERR) From TRTMIG
Endif

Local File =DOSSIER+".SINVOICE"  [SIH]
Trbegin [SIH]
Delete [SIH] Where ORIMOD=3
Commit

Call MIGRAZKEY (DOSSIER,"UUMGTRTTRS01",ERR) From TRTMIG

End

########################################################################
Subprog MAJ_UUMGTRTTRS01(DOSSIER)
Value Char DOSSIER
Local Integer ERR


If [F:ADS]MODULE(2)<>2
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS01",3,ERR) From TRTMIG : End
Endif

#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS01",7,ERR) From TRTMIG : End : Endif
If val(VERSION)>=GMIGX3VER110
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS01",3,ERR) From TRTMIG : End
Endif

#----- File naming...  -----#
Local Char WNAMSIHM,WNAMSILM,WNAMSIAM
Call MIGTABNAME (DOSSIER,"SINVOICE",WNAMSIHM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS01",7,ERR) From TRTMIG : End : Endif
If val(VERSION)<GMIGX3VER60
 Call MIGTABNAME (DOSSIER,"BPCINVLIG",WNAMSILM,ERR) From TRTMIG
 If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS01",7,ERR) From TRTMIG : End : Endif
 Call MIGTABNAME (DOSSIER,"BPCINVLIGA",WNAMSIAM,ERR) From TRTMIG
 If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS01",7,ERR) From TRTMIG : End : Endif
Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMSIHM,"fde",[F:ADS]DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS01",3,ERR) From TRTMIG : End
Endif
If val(VERSION)<GMIGX3VER60
 If filinfo(filpath("FIL",WNAMSILM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS01",3,ERR) From TRTMIG : End
 Endif
 If filinfo(filpath("FIL",WNAMSIAM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS01",3,ERR) From TRTMIG : End
 Endif
Endif

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS01",2,ERR) From TRTMIG

Call ECR_TIME("UUMGTRTTRS01 Customer BP Invoice Process : Update SINVOICE/BPCINVLIG/BPCINVLIGA") From DOSSUB
Call ECR_TRACE("UUMGTRTTRS01 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Files Updating where we will insert -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"SINVOICE",ERR) From TRTMIG
If val(VERSION)<GMIGX3VER60
 Call MIGTABINIT (DOSSIER,"BPCINVLIG",ERR) From TRTMIG
 Call MIGTABINIT (DOSSIER,"BPCINVLIGA",ERR) From TRTMIG
Endif

#--------------- Opening of files  -----#
# X3 Files
If clalev([F:SIH]) = 0 :  Local File =DOSSIER+".SINVOICE"    [SIH]   : Endif      # Customer BP Invoices
If clalev([F:SIL]) = 0 :  Local File =DOSSIER+".BPCINVLIG"   [SIL]   : Endif      # General  BP Invoices Lines
If clalev([F:SIA]) = 0 :  Local File =DOSSIER+".BPCINVLIGA"  [SIA]   : Endif      # Analytic BP Invoices Lines

# X3 Renamed File
If clalev([F:SIHM]) = 0 :  Local File =DOSSIER+"."+WNAMSIHM   [SIHM]  : Endif    # Customer BP Invoices
If val(VERSION)<GMIGX3VER60
 If clalev([F:SILM]) = 0 :  Local File =DOSSIER+"."+WNAMSILM   [SILM]  : Endif    # General  BP Invoices Lines
 If clalev([F:SIAM]) = 0 :  Local File =DOSSIER+"."+WNAMSIAM   [SIAM]  : Endif    # Analytic BP Invoices Lines
Endif
If clalev([F:SIHW]) = 0 :  Local File =DOSSIER+"."+WNAMSIHM   [SIHW]  : Endif    # Customer BP Invoices

# X3 Commun File
Gosub OPEN_FILE From UUMGTRTCPT00

#-----  Declaration of Variables
Gosub DECLARE From UUMGTRTCPT00

# Variables to manage Flush instruction
Local Char WTAB_SIH (100) (adxwrb)
Local Char WTAB_SIL (100) (adxwrb)
Local Char WTAB_SIA (100) (adxwrb)
Local Shortint WCPT_SIH,WCPT_SIL,WCPT_SIA

# Variables to Handle Loops Ruptures
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT
#

#-----  Keys's reading  -----#
# Table's AMIGKEY reading to initialize ACLEx/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTTRS01",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(3))

#-----  Link of Head Table & Line Table (except Analytic, including in For)
#-----  We don't have the line number in the key !
If val(VERSION)<GMIGX3VER60
 Link [SILM] With [SIHM]SIH0~=[F:SILM]NUM
&    As [LNK]
&    Order By Key CLE = [F:SIHM]CPY;[F:SIHM]NUM
Else
 Link [SIHW] With [SIHM]SIH0~=[F:SIHW]NUM
&    As [LNK]
&    Where [F:SIHM]ORIMOD=3
&    Order By Key CLE = [F:SIHM]CPY;[F:SIHM]NUM
Endif

# EP to add a criteria in the "where"
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTTRS01" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_TRS01
Raz NB

If STOP = 1
 STOP = 2
 CRITERE = "[F:SIHM]CPY='"+TABMIGKEY(1)+"' & [F:SIHM]NUM>'"+TABMIGKEY(2)+"'"
Elsif STOP = 2
 STOP = 0
 CRITERE = "[F:SIHM]CPY>'"+TABMIGKEY(1)+"'"
Else
 CRITERE = "1=1"
Endif


Trbegin [SIH],[SIL],[SIA]
GOK = 1

For [LNK]CLE(1) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)

 # By company - Initialization of Variables linked to the Account Core Model
 [L]COMPANY = [F:SIHM]CPY
 Gosub INI_CPY From UUMGTRTCPT00
 If !GOK : Break : Endif

 For [LNK]CLE(2)

  NBLUS +=1
  # EP to delete line
  If FILTRELIN
   FLUX="UUMGTRTTRS01" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
   If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  If val(VERSION)<GMIGX3VER60
   # Update SINVOICE Table - Head of Customer BP Invoices
   Gosub MAJ30_SIH
   If GOK<1 : Break 2 : Endif

   For [LNK]CLE

    # Update BPCINVLIG Table - # Generals Lines of Customer BP Invoices
    Gosub MAJ30_SIL
    If !GOK : Break 3 : Endif

   Next

   # Update BPCINVLIGA Table - # Analyticals Lines of Customer BP Invoices
   Gosub MAJ30_SIA
   If !GOK : Break 2 : Endif

  Else

   # Sinve V8 - Update SINVOICE Table - Head of Customer BP Invoices
   Gosub MAJ30_SIH_V8
   If GOK<1 : Break 2 : Endif

  Endif

  NB+=1
  If NB>GMAXUPDTRS
   TABMIGKEY(1)= [F:SIHM]CPY
   TABMIGKEY(2)= [F:SIHM]NUM
   STOP=1
   Break 2
  Endif

 $SUITE_BOUCLE
 Next
Next

$FIN_BOUCLE
If GOK<1
 Rollback
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS01",7,ERR) From TRTMIG : #7=Erreur
Else
 Flush [F:SIH]
 If fstat
  Call ECR_TRACE("File SINVOICE, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub SIH_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 Flush [F:SIL]
 If fstat
  Call ECR_TRACE("File BPCINVLIG, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub SIL_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 Flush [F:SIA]
 If fstat
  Call ECR_TRACE("File BPCINVLIGA, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub SIA_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 # To Save values of key ACLEx/STOP in AMIGKEY table
 If STOP
  TABMIGKEY(3)=num$(STOP)
 Else
  Raz TABMIGKEY
 Endif
 Call MIGSTKKEY (DOSSIER,"UUMGTRTTRS01",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
 If ERR
  GOK=-1 : Goto FIN_BOUCLE
 Endif
 Commit
 NBCOMMIT+=NB
 Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTTRS01",STOP,ERR) From TRTMIG
 If STOP
  Goto LOOP_TRS01
 Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [SIH], [SIL], [SIA]
Close Local File [SIHM], [SIHW]
If val(VERSION)<GMIGX3VER60
 Close Local File [SILM], [SIAM]
Endif
Close Local File [GCM], [LED], [CPY]

#----- To Re-Update files where we will insert
Call MIGTABEND (DOSSIER,"SINVOICE",ERR) From TRTMIG
If val(VERSION)<GMIGX3VER60
 Call MIGTABEND (DOSSIER,"BPCINVLIG",ERR) From TRTMIG
 Call MIGTABEND (DOSSIER,"BPCINVLIGA",ERR) From TRTMIG
Endif

$FIN
Call MIGTRTEND (DOSSIER,"UUMGTRTTRS01") From TRTMIG
Call ECR_TIME("UUMGTRTTRS01 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

#############################################################################################################
$MAJ30_SIH
#--- Transclass
# Raz [SIH]  # expensive... must RAZ new V6 fields
[SIH] = [SIHM]

#-- Update news Fields
#       Update FIY/PER Fields on Post-Migration UPOSMIGCOM01 Process
#[F:SIH]FIY = [L]EXERCICE
#[F:SIH]PER = [L]PERIODE

#--- New fields's assignation : LED/CURLED/RATxxx/DIE
For IREF=1 To dim([F:GCM]LED)
 If [F:GCM]LED(IREF-1)<>""
  [F:SIH]LED(IREF-1) = [F:GCM]LED(IREF-1)
  [F:SIH]CURLED(IREF-1) = [F:GCM]CUR(IREF-1)
  [F:SIH]RATDIV(IREF-1) = 1
  If find(IREF,1,2,3)
   [F:SIH]RATMLT(IREF-1) = [F:SIHM]RATCUR
  Else
   [F:SIH]RATMLT(IREF-1) = [F:SIHM]RATRPT
  Endif
 Else # useful to delete intruction RAZ
  [F:SIH]LED(IREF-1)    = ""
  [F:SIH]CURLED(IREF-1) = ""
  [F:SIH]RATDIV(IREF-1) = 0
  [F:SIH]RATMLT(IREF-1) = 0
 Endif
Next

For AXE=1 To dim([F:SIH]DIE)
 If AXE<10
  If [L]AXEA(AXE)<>""
   [F:SIH]DIE(AXE-1) = [L]AXEA(AXE)
  Elsif [L]AXEI(AXE-NBAAXE)<>""
   [F:SIH]DIE(AXE-1) = [L]AXEI(AXE-NBAAXE)
  Else  # useful to delete intruction RAZ
   [F:SIH]DIE(AXE-1) = ""
  Endif
 Else  # useful to delete intruction RAZ
  [F:SIH]DIE(AXE-1) = ""
 Endif
Next

If [F:SIH]STA>1
 [F:SIH]STARPT = 2
Else
 [F:SIH]STARPT = 1
Endif

Gosub WRI_SIH
Return

$MAJ30_SIH_V8
#--- Transclass
[F:SIH] = [F:SIHW]
Gosub WRI_SIH
Return

#############################################################################################################
$MAJ30_SIL
#--- Transclass
# Raz [F:SIL]  # expensive... must RAZ new V6 fields
[F:SIL] = [F:SILM]

#--- Field linked to SIH Fields
[F:SIL]STRDAT = [F:SIH]STRDATSVC
[F:SIL]ENDDAT = [F:SIH]ENDDATSVC

#--- New fields's assignation : LED/COA/ACC
For IREF=1 To dim([F:GCM]LED)
 If [F:GCM]LED(IREF-1)<>""
  [F:SIL]LED(IREF-1) = [F:GCM]LED(IREF-1)
  If find(IREF,1,2,3)
   If [F:SIL]LED(IREF-1)=LEDGEN
    [F:SIL]COA(IREF-1) = COAGEN
    [F:SIL]ACC(IREF-1) = [F:SILM]ACC
   Elsif [F:SIL]LED(IREF-1)=LEDANA
    [F:SIL]COA(IREF-1) = COAANA
    [F:SIL]ACC(IREF-1) = [F:SILM]CNA
   Elsif dim([F:SILM]ACCIAS)>0 & [F:SIL]LED(IREF-1)=LEDIAS
    [F:SIL]COA(IREF-1) = COAIAS
    [F:SIL]ACC(IREF-1) = [F:SILM]ACCIAS
   Endif
  Else # useful to delete intruction RAZ
   [F:SIL]COA(IREF-1)    = ""
   [F:SIL]ACC(IREF-1)    = ""
  Endif
 Else # useful to delete intruction RAZ
  [F:SIL]LED(IREF-1)    = ""
  [F:SIL]COA(IREF-1)    = ""
  [F:SIL]ACC(IREF-1)    = ""
 Endif
Next
Gosub WRI_SIL
Return

#############################################################################################################
$MAJ30_SIA
#--- Reading of the Analytics Lines
For [SIAM]SIA0 Where NUM=[F:SILM]NUM # & LIG=[F:SILM]LIG

 #--- Transclass
 # Raz [F:SIA]  # expensive... must RAZ new V6 fields
 [F:SIA] = [F:SIAM]

 For IREF=1 To dim([F:GCM]LED)
  If [F:GCM]LED(IREF-1)<>""
   If find(IREF,1,2,3)
    If [F:SIL]LED(IREF-1)=LEDGEN
     [F:SIA]COA(IREF-1) = COAGEN
     [F:SIA]ACC(IREF-1) = [F:SILM]ACC
    Elsif [F:SIL]LED(IREF-1)=LEDANA
     [F:SIA]COA(IREF-1) = COAANA
     [F:SIA]ACC(IREF-1) = [F:SILM]CNA
    Elsif dim([F:SILM]ACCIAS)>0 & [F:SIL]LED(IREF-1)=LEDIAS
     [F:SIA]COA(IREF-1) = COAIAS
     [F:SIA]ACC(IREF-1) = [F:SILM]ACCIAS
    Endif
   Else # useful to delete intruction RAZ
    [F:SIA]COA(IREF-1)    = ""
    [F:SIA]ACC(IREF-1)    = ""
   Endif
  Else # useful to delete intruction RAZ
   [F:SIA]COA(IREF-1)    = ""
   [F:SIA]ACC(IREF-1)    = ""
  Endif
 Next
 For AXE=1 To dim([F:SIA]DIE)
  If AXE<10
   If [L]AXEA(AXE)<>""
    [F:SIA]DIE(AXE-1) = [L]AXEA(AXE)
   Elsif [L]AXEI(AXE)<>""
    [F:SIA]DIE(AXE-1) = [L]AXEI(AXE)
   Else # useful to delete intruction RAZ
    [F:SIA]DIE(AXE-1)    = ""
   Endif
  Else # useful to delete intruction RAZ
   [F:SIA]DIE(AXE-1)    = ""
  Endif
 Next

 Gosub WRI_SIA
 If GOK<1 : Break : Endif

Next
Return


# Write Instruction
$WRI_SIH
# To Save reference
Gosub SIH_STK
WriteB [F:SIH]
If fstat
 Call ECR_TRACE("File SINVOICE, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub SIH_ERRTRA
 GOK=0 : Return
Endif
Return

$WRI_SIL
# To Save reference
Gosub SIL_STK
WriteB [F:SIL]
If fstat
 Call ECR_TRACE("File BPCINVLIG, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub SIL_ERRTRA
 GOK=0 : Return
Endif
Return

$WRI_SIA
# To Save reference
Gosub SIA_STK
WriteB [F:SIA]
If fstat
 Call ECR_TRACE("File BPCINVLIGA, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub SIA_ERRTRA
 GOK=0 : Return
Endif
Return

##############################################################################################
$SIH_STK
Call STK (WTAB_SIH,WCPT_SIH,[F:SIH]NUM) From TRTMIG
Return
$SIL_STK
Call STK (WTAB_SIL,WCPT_SIL,[F:SIL]NUM-'/'-num$([F:SIL]LIG)) From TRTMIG
Return
$SIA_STK
Call STK (WTAB_SIA,WCPT_SIA,[F:SIA]NUM-'/'-num$([F:SIA]LIG)-'/'-num$([F:SIA]ANALIG)) From TRTMIG
Return
##############################################################################################
$SIH_ERRTRA
Call ERRTRA (WTAB_SIH,WCPT_SIH,"File SINVOICE(NUM)=") From TRTMIG
Return
$SIL_ERRTRA
Call ERRTRA (WTAB_SIL,WCPT_SIL,"File BPCINVLIG(NUM/LIG)=") From TRTMIG
Return
$SIA_ERRTRA
Call ERRTRA (WTAB_SIA,WCPT_SIA,"File BPCINVLIGA(NUM/LIG/ANALIG)=") From TRTMIG
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
Call MAJ_UUMGTRTTRS01(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
Call MAJ_UUMGTRTTRS01(APPLI)
End

