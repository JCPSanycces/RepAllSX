#<AdxTL>@(#)3.0.0.0 $Revision$
$ACTION
Case ACTION
    When "DEBUT"       : Gosub DEBUT
Endcase
Return

$DEBUT
Local Integer I,NOL

If clalev([F:FCY1]) = 0 : Local File FACILITY   [FCY1] : Endif
If clalev([F:BPS])  = 0 : Local File BPSUPPLIER [BPS]  : Endif

Raz [M:ITFS]
Transmask [M:ITF0] To [M:ITFS] # Issue 25606_Transmask [M:ITFS]=[M:ITF0]
Transmask [M:ITF8] To [M:ITFS] # Issue 25606_Transmask [M:ITFS]=[M:ITF8]

Raz I,NOL
For [STO]STO3 Where ITMREF=[M:ITFS]ITMREF & STOFCY=[M:ITFS]STOFCY &
&                   OWNER<>[M:ITFS]STOFCY
   I = find([F:STO]OWNER,[M:ITFS]OWNER(0..[M:ITFS]NBLIG-1))
   If I=0
      NOL = [M:ITFS]NBLIG
      [M:ITFS]OWNER(NOL)      = [F:STO]OWNER

      If [F:FCY1]FCY<>[F:STO]OWNER
         Read [FCY1]FCY0=[F:STO]OWNER
         If fstat
            If [F:BPS]BPSNUM<>[F:STO]OWNER
               Read [BPS]BPS0=[F:STO]OWNER
               If !fstat
                  [M:ITFS]OWNNAM(NOL)=[F:BPS]BPSNAM
               Endif
            Else
               [M:ITFS]OWNNAM(NOL)=[F:BPS]BPSNAM
            Endif
         Else
            [M:ITFS]OWNNAM(NOL)=[F:FCY1]FCYNAM
         Endif
      Else
         [M:ITFS]OWNNAM(NOL)=[F:FCY1]FCYNAM
      Endif

      [M:ITFS]QTYSTUACT(NOL)  = [F:STO]QTYSTUACT
      [M:ITFS]CUMALLQTA(NOL)  = [F:STO]CUMALLQTA
      [M:ITFS]NBLIG += 1
   Else
      NOL = I-1
      [M:ITFS]QTYSTUACT(NOL) += [F:STO]QTYSTUACT
      [M:ITFS]CUMALLQTA(NOL) += [F:STO]CUMALLQTA
   Endif
Next

Affzo [M:ITFS]1-99

Return

