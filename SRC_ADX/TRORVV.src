#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################
# Maintain In development and Available to use route codes for route versions.    #
# STLIG 12-11-2015                                                                #
###################################################################################

$ACTION
  Case ACTION
    When "INIT"      : Gosub INIT
    When "INIT_DIA"  : Gosub INIT_DIA
    When "AVANT_PAR" : Gosub AVANT_PAR
    When "CONTROLE"  : Gosub CONTROLE
    When "EXEC"      : Gosub EXEC
  Endcase
Return

$INIT
  Integer ROUTE_VERSION
  Local Integer ERROR : ERROR = 0

  ROUTE_VERSION = func RVMLIB.NBRCPNROU([L]PARAM(1))
  If (ROUTE_VERSION = 0)
    GERR=1 : GMESSAGE = func AFNC.MES1(mess(335,193,1), [L]PARAM(1))
    FIN = 1
  Else
    If !clalev([F:RVV]) : Local File RVMVAL    [RVV]  : Endif
    If !clalev([F:ITM]) : Local File ITMMASTER [ITM]  : Endif
    If !clalev([F:TRO]) : Local File TABROUALT [TRO]  : Endif

    Read [ITM]ITM0 = [L]PARAM(1)
  Endif
Return

$INIT_DIA
  Raz [M:RVVA]
  [M:RVVA]ITMREF = [L]PARAM(1)

  # Initialise route and site code fields for route: Available to use ...
  Filter [RVV] Where ITMREF = [M:RVVA]ITMREF & USESTA = 2
  Read [RVV]RVV0 Last
  Filter [RVV]
  If (!fstat)
    [M:RVVA]ROUALT2 = [F:RVV]ROUALT
    [M:RVVA]RVV2 = 2
  Else
    [M:RVVA]ROUALT2 = [F:ITM]ECCROUALT(1)
    [M:RVVA]RVV2 = 1
  Endif
  Read [TRO]TRO0 = [M:RVVA]ROUALT2
  If (!fstat)
    [M:RVVA]FCY2 = [F:TRO]FCY
  Endif

  # Initialise route and site code fields for route: In development ...
  Filter [RVV] Where ITMREF = [M:RVVA]ITMREF & USESTA = 1
  Read [RVV]RVV0 Last
  Filter [RVV]
  If (!fstat)
    [M:RVVA]ROUALT1 = [F:RVV]ROUALT
    [M:RVVA]RVV1 = 2
  Else
    [M:RVVA]ROUALT1 = [F:ITM]ECCROUALT(0)
    [M:RVVA]RVV1 = 1
  Endif
  Read [TRO]TRO0 = [M:RVVA]ROUALT1
  If (!fstat)
    [M:RVVA]FCY1 = [F:TRO]FCY
  Endif
Return

$AVANT_PAR
  If (ERROR)
    Raz [M:RVVA]RVV0  # Initialise field RVV0 / Diszo route code fields if appropriate.
  Endif
Return

$CONTROLE
  If ([M:RVVA]ROUALT1 <> 0 & [M:RVVA]ROUALT1 = [M:RVVA]ROUALT2)
    GERR = 1 : GMESSAGE = mess(333,193,1) # Identical route codes.
    ERROR = 1
  Elsif [M:RVVA]ROUALT1 <> 0 & [M:RVVA]ROUALT2 <> 0 & [M:RVVA]FCY1 <> [M:RVVA]FCY2
    GERR = 1 : GMESSAGE = mess(334,193,1) # Sites incompatible between the version route codes.
    ERROR = 1
  Endif
Return

$EXEC
  GOK = 1
  Trbegin [ITM]
  Readlock [ITM]ITM0 = [M:RVVA]ITMREF
  If (fstat)
    GOK = 0 : Call RSTA("ITM",[M:RVVA]ITMREF) From GLOCK
  Else
    [F:ITM]ECCROUALT(0) = [M:RVVA]ROUALT1
    [F:ITM]ECCROUALT(1) = [M:RVVA]ROUALT2
    Rewrite [ITM]
    If (fstat)
      GOK = 0 : Call FSTA("ITM") From GLOCK
    Endif
  Endif
  If (GOK = 1)
    Commit
  Else
    Rollback
  Endif
Return

###################################################################################

Subprog D_RVV0(VALEUR)
Variable Decimal VALEUR

If ([M:RVVA]RVV1 = 2)
    Diszo [M:RVVA]ROUALT1
  Endif
  If ([M:RVVA]RVV2 = 2)
    Diszo [M:RVVA]ROUALT2
  Endif
End

Subprog AM_ROUALT1(VALEUR)
Variable Decimal VALEUR
  If (VALEUR = 0)
    Raz [F:TRO]
  Endif
  [M:RVVA]FCY1 = [F:TRO]FCY
  Affzo [RVVA]FCY1
End

Subprog AM_ROUALT2(VALEUR)
Variable Decimal VALEUR
  If (VALEUR = 0)
    Raz [F:TRO]
  Endif
  [M:RVVA]FCY2 = [F:TRO]FCY
  Affzo [RVVA]FCY2
End

